	.TITLE	DICO.ASS;	--------------------------------------;		(C) 1989 - Daniel Roux;	--------------------------------------	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal; Numros des appels; ------------------	.SYSCALL.16	DICO_DICO_OPEN	=	H'ABE0DICO_CLOSE	=	H'ABE1DICO_JUSTE	=	H'ABE2DICO_CHANGE	=	H'ABE3DICO_CONJ	=	H'ABE4DICO_ACCORD	=	H'ABE5DICO_IFMAJ	=	H'ABE6DICO_MAJ	=	H'ABE7DICO_DEF	=	H'ABE8DICO_ADD	=	H'ABE9DICO_OK		=	H'ABEADICO_SYNO	=	H'ABEBDICO_VTEMP	=	H'ABECDICO_CHIFFRE	=	H'ABEDDICO_FAMILLE	=	H'ABEEDICO_BINIT	=	H'ABEFDICO_BNEXT	=	H'ABF0DICO_BFORM	=	H'ABF1DICO_FIRST	=	DICO_OPENDICO_LAST	=	DICO_BFORM;----------\\; DICO_OPEN >  [sk];==========/; Ouvre le dictionnaire comme suit :;  1)	charge le dictionnaire de base 250000.BDICO;  2)	charge tous les dictionaires privs *.PDICO; in	-; out	D6.L	canal;	D7.W	erreur; mod	D6.L, D7.W;-----------\\; DICO_CLOSE >;===========/; Ferme le dictionnaire.; in	D6.L	canal; out	D7.W	erreur; mod	D7.W;---------\\; DICO_DEF >  [sk];=========/; Choix de quelques dfinitions gnrales.; in	D6.L	canal;	D3.W	opration (0=edit, 1=get, 2=put);	D4.L	mode (si D3=put); out	D4.L	mode (si D3=get);	D7.W	erreur; mod	D4.L, D7.W;-----------\\; DICO_VTEMP >;===========/; Vide le dictionnaire temporaire TEMP.; in	D6.L	canal;	D3.W	mode (0=clear, 1=get); out	D4.L	nb de mots contenus (si D3=get);	D7.W	erreur; mod	D4.L, D7.W;--------\\; DICO_OK >  [sk];========/; Indique que tout est correct (zro faute).; in	D6.L	canal; out	D7.W	erreur; mod	D7.W;-----------\\; DICO_IFMAJ >;===========/; Regarde si une mise  jour (avec DICO_MAJ) est ncessaire.; in	D6.L	canal; out	D7.W	zro => mise  jour inutile;	D7.W	autre => mise  jour ncessaire; mod	D7.W;---------\\; DICO_MAJ >  [sk];=========/; Met  jour tous les dictionnaires privs qui ont t modifis.; in	D6.L	canal; out	D3.W	dernire touche (F0=annule, F1=mise  jour);	D7.W	erreur; mod	D3.L, D7.W;-----------\\; DICO_JUSTE >  [sk];===========/; Vrifie si tous les mots d'une phrase sont justes.; in	D6.L	canal;	A4/D4.L	^phrase complte/lg;	A3/D3.L	^phase  vrifier/lg; out	D7.W	zro => tous les mots sont justes;	D7.W	ERDIPT => erreur;	D7.W	ERKSTO => stopp;	A4/D4.L	^mot faux/lg; mod	D4.L, D7.W, A4.L;------------\\; DICO_CHANGE >  [sk];============/; Remplace un mot suppos faux par un autre.; in	D6.L	canal;	A3/D3.L	^phase  vrifier/lg;	A4/D4.L	^mot faux/lg; out	D3.L	dernire touche presse (F1/F3/F4/F8/F9/F10);	A4/D4.L	^mot juste/lg;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.L;---------\\; DICO_ADD >  [sk];=========/; Ajoute un mot dans un dictionnaire priv.; in	D6.L	canal;	A4/D4.L	^mot  ajouter/lg; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.W;----------\\; DICO_CONJ >  [sk];==========/; Conjugue une forme verbale.; in	D6.L	canal;	A4/D4.L	^forme verbale/lg; out	D3.L	dernire touche presse (F1/F0);	A4/D4.L	^autre forme/lg;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.L;------------\\; DICO_ACCORD >  [sk];============/; Accorde un nom ou un adjectif.; in	D6.L	canal;	A4/D4.L	^forme verbale/lg; out	D3.L	dernire touche presse (F1/F4/F7/F10);	A4/D4.L	^autre forme/lg;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.L;----------\\; DICO_SYNO >  [sk];==========/; Trouve un synonyme si cela est possible.; in	D6.L	canal;	A4/D4.L	^contexte/lg;	A3/D3.L	^mot/lg; out	D3.L	dernire touche presse (F1/F0);	A4/D4.L	^synonyme/lg;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.L;-------------\\; DICO_CHIFFRE >  [sk];=============/; Transforme un nombre form de chiffres en toutes lettres.; in	D6.L	canal;	A4/D4.L	^nombre en chiffres/lg; out	D3.L	dernire touche presse (F1/F0);	A4/D4.L	^nombre en lettres/lg;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.L;-------------\\; DICO_FAMILLE >  [sk];=============/; Trouve un mot de la mme famille si cela est possible.; in	D6.L	canal;	A4/D4.L	^contexte/lg;	A3/D3.L	^mot/lg; out	D3.L	dernire touche presse (F1/F0);	A4/D4.L	^famille/lg;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.L;-----------\\; DICO_BINIT >;===========/; Initialise le recherche d'un mot quelconque.; Si le mot est inconnu (par exemple mal ortographi), aucune; erreur n'est rendue. C'est DICO_BNEXT qui donnera ventuellement; une erreur, selon le degr d'exactitude demand !; in	D6.L	canal;	A4/D4.L	^mot/lg; out	D7.W	erreur; mod	D7.W;-----------\\; DICO_BNEXT >;===========/; Cherche le mot de base suivant, selon DICO_BINIT.; Mme avec le degr d'exactitude zro (exact), il faut excuter cet appel; plusieurs fois. Soit par exemple le mot "recherche".;	BNEXT	retourne type "f" et forme 0 (nom fminin au singulier);	BNEXT	retourne type "t" et forme 1 (verbe "je recherche");	BNEXT	retourne type "t" et forme 3 (verbe "il recherche");	...	retourne encore d'autres formes verbales;	BNEXT	retourne une erreur (y'a plus rien); Liste des degrs d'exactitude possibles (D2.W) :;	0   ->	parfaitement exact;	1   ->	tolre les fautes d'accents;	2   ->	tolre les fautes de phontique;	3   ->	tolre quelques lettres oublies ou permutes;	4   ->	tolre plusieurs lettres oublies ou permutes;	5   ->	tolre des oublis ou permutations au niveau de la phontique; Types possibles (D3.[0..7]) :;	"m" ->	nom masculin;	"4" ->	nom masculin restant toujours au singulier;	"q" ->	nom masculin restant toujours au pluriel;	"f" ->	nom fminin;	"n" ->	nom masculin pouvant devenir fminin;	"3" ->	nom fminin restant toujours au pluriel;	"0" ->	nom invariable;	"a" ->	adjectif;	"y" ->	adjectif compos;	"5" ->	adjectif invariable;	"k" ->	nom masculin ou adjectif;	"w" ->	nom ou adjectif;	"o" ->	pronom;	"p" ->	dterminant (article);	"t" ->	verbe transitif;	"i" ->	verbe intransitif;	"u" ->	verbe transitif ou intransitif;	"r" ->	verbe pronominal rflchi;	"1" ->	verbe transitif, intransitif ou pronominal rflchi;	"2" ->	verbe intransitif ou pronominal rflchi;	"h" ->	verbe transitif ou pronominal rflchi;	"v" ->	verbe impersonnel;	"7" ->	verbe transitif ou impersonnel;	"z" ->	prposition;	"d" ->	adverbe;	"6" ->	prposition ou adverbe;	"s" ->	subjonction;	"j" ->	interjection;	"g" ->	sigle;	"l" ->	locution;	"8" ->	prfixe;	"P" ->	nom propre; Les auxiliaires possibles sont (D3.[8..15]) :;	"A" ->	avoir;	"E" ->	tre;	"2" ->	avoir ou tre; Formes possibles pour un adjectif (D4.W) :;	0   ->	masculin singulier;	1   ->	masculin pluriel;	2   ->	fminin singulier;	3   ->	fminin pluriel; Formes possibles pour un verbe (D4.W) :;	0        ->	infinitif;	1..6     ->	indicatif prsent (je,tu,il/elle,ils/elles,nous,vous);	7..12    ->	indicatif imparfait;	13..18   ->	indicatif pass simple;	19..24   ->	indicatif futur simple;	25..30   ->	subjonctif prsent;	31..36   ->	subjonctif imparfait;	37..42   ->	conditionnel prsent;	44,47,48 ->	impratif prsent (tu,nous,vous);	49       ->	participe prsent;	50..53   ->	participes passs (ms,mp,fs,fp); in	D6.L	canal;	D2.W	degr d'exactitude maximal admis (0..5); out	A3.L	^mot trouv;	D2.W	degr d'exactitude (0..n);	D3.W	0..7  type du mot;		8..15 auxiliaire;	D4.W	forme (0..n);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A3.L;-----------\\; DICO_BFORM >;===========/; Construit une forme quelconque d'un mot (nom, adjectif, verbe, etc.),; selon DICO_BNEXT.; in	D6.L	canal;	D4.W	forme demande (0..n); out	A3.L	^mot  la forme selon D4.W;	D7.W	erreur; mod	D7.W, A3.L; Les trois appels DICO_BINIT, DICO_BNEXT et DICO_BFORM doivent tre; excuts dans l'ordre suivant :;;	BINIT;	  BNEXT;	    BFORM;	    BFORM;	    ...;	  BNEXT;	    BFORM;	    BFORM;	    ...;	  ...; [sk]	Ce sigle indique tous les appels aprs lesquels;	il faut redessiner les soft-keys avec LIB,?AFMENU !	.END