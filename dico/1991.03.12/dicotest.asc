	.TITLE	DICOTEST.ASC	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	DICO; Variables; ---------	.LOC	0OCHDICO:.BLKB	2		; canal module DICOOCIDICO:.BLKB	4		; canal interne DICOOBUMOT:	.BLKB	100LGVAR:; Programme; ---------	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.L	A3,#R16"NMDICO	LOAD.W	D3,#DICO_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHDICO,D1	DICO_	OPEN	LOAD.L	(A6)+OCIDICO,D6LOOP:	LIB	?AFTIM	.ASCIZ	"<CR><CR>(I)nit, (N)ext, (F)orm, (END) ? "	.EVEN	LIB	?GETCAR	LIB	?MINMAJ	COMP.W	D3,#'I	JUMP,EQ INIT	COMP.W	D3,#'N	JUMP,EQ NEXT	COMP.W	D3,#'F	JUMP,EQ FORM	COMP.W	D3,#END	JUMP,EQ FINIBIP:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOPINIT:	LIB	?AFTIM	.ASCIZ	"<CR>Mot : "	.EVEN	LOAD.L	A3,#(A6)+OBUMOT	LOAD.W	D3,#100	LIB	?GETLINE	COMP.W	D3,#CR	JUMP,NE BIP	LOAD.L	A4,A3	CLR.W	D4CNT$:	INC.W	D4	TEST.B	(A3+)	JUMP,NE CNT$	SUB.W	D4,#2	LOAD.L	D6,(A6)+OCIDICO	DICO_	BINIT	JUMP,NE ERROR	JUMP	LOOPNEXT:	LIB	?AFTIM	.ASCIZ	"<CR>Degr d'exactitude : "	.EVEN	LIB	?GETDEC	COMP.W	D3,#CR	JUMP,NE BIP	LOAD.W	D2,D4	LOAD.L	D6,(A6)+OCIDICO	DICO_	BNEXT	JUMP,NE ERROR	LIB	?AFTIM	.ASCIZ	"<CR>Mot trouv = "	.EVEN	LIB	?AFTEXT	LIB	?AFTIM	.ASCIZ	"<CR>Type = "	.EVEN	LIB	?AFCAR	LIB	?AFTIM	.ASCIZ	"<CR>Auxiliaire = "	.EVEN	RR.W	D3,#8	LIB	?AFCODE	LIB	?AFTIM	.ASCIZ	"<CR>Forme = "	.EVEN	LIB	?AFX4	JUMP	LOOPFORM:	LIB	?AFTIM	.ASCIZ	"<CR>Forme demande : "	.EVEN	LIB	?GETDEC	COMP.W	D3,#CR	JUMP,NE BIP	LOAD.L	D6,(A6)+OCIDICO	DICO_	BFORM	JUMP,NE ERROR	LIB	?AFTIM	.ASCIZ	"<CR>Mot trouv = "	.EVEN	LIB	?AFTEXT	JUMP	LOOPERROR:	LIB	?AFERROR	JUMP	LOOPFINI:	LOAD.L	D6,(A6)+OCIDICO	DICO_	CLOSE	LOAD.W	D1,(A6)+OCHDICO	LIB_	CLOSEERFAT:	EXITNMDICO:	.ASCIZ	"DICO"	.EVENVAR:	.FILLB	LGVAR,0	.END	START