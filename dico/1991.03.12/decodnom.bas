 '4' : Let @GENRE% = 415910   Case 'q' : Let @GENRE% = 515920   Case '3' : Let @GENRE% = 615930 End Select15933 let c$ = left$(llign$,1)15940 If c$ = '4' Or c$ = 'q' or c$ = '3' then 15950 else 1600015950 Select Left$(LLIGN$,1)15960   Case '4' : Let @MOT$ = Butleft$(LLIGN$,1) : Let @MOTPL$ = ''15970   Case 'q','3' : Let @MOT$ = '' : Let @MOTPL$ = Butleft$(LLIGN$,1)15980 End Select15990 goto 1824016000 Let LLIGN$ = Butleft$(LLIGN$,1) 16010 Select ESPMOT%16020   Case 116030     Select Asc(Mid$(LLIGN$, Len(LLIGN$) - 1, 1))16040       Case 48..4916050         Let M$ = Butright$(LLIGN$,2) : Let @MOT$ = M$16060         Select Right$(LLIGN$,2)16070           Case '00' : Let MP$ = M$16080           Case '01' : Let MP$ = Butright$(M$,1) + 'ux'16090           Case '02' : Let MP$ = M$ + 'x'16100           Case '03' : Let MP$ = Butright$(M$,2) + 'ux'16110           Case '04' : Let MP$ = Butright$(M$,1) + 'ux'16120           Case '05' : Let MP$ = 'yeux'16130           Case '06' : Let MP$ = Butright$(M$,2) + 'a'16140           Case '07' : Let MP$ = Butright$(M$,2) + 'en'16150           Case '08' : Let MP$ = Butright$(M$,2) + 'a'16160           Case '09' : Let MP$ = M$ + 's' 16170           Case '10' : Let MP$ = Butright$(M$,1) + 'ies'16180           Case '11' : Let MP$ = Butright$(M$,2) + 'i'16190         End Select16200       Case 53..5516210         Let M$ = Butright$(LLIGN$,2) : Let @MOT$ = M$16220         Let ITER% = 0 : Let K% = 016230         Let LONG% = Len(M$)16240         Loop16250           Inc K%16260           Exit If K% > LONG%16270           If Mid$(M$,K%,1) = '-' Then Inc TIRET% : Let ITER% = K%16280         End Loop16290         Select Right$(LLIGN$,2)16300           Case '50'16310             Let MP$ = M$16320           Case '52'16330             Select TIRET%16340               Case 116350                 Let MP$ = Left$(M$, ITER% - 1) + 's-' + Right$(M$, LONG% - ITER%)16360               Case 2..416370                 Let ITER% = 016380                 Loop16390                   Inc ITER%16400                   Exit If ITER% > LONG%16410                   Exit If Mid$(M$,ITER%,1) = '-'16420                 End Loop16430                 Let MP$ = Left$(M$, ITER% - 1) + 's-' + Right$(M$, LONG% - ITER%)16440             End Select16450           Case '53','55'16460             Let MP$ = M$ + 's'16470           Case '51','54','58'16480             Let MP$ = Left$(M$, ITER% - 1) + 's-' + Right$(M$, LONG% - ITER%) + 's'16490           Case '57'16500             Let MP$ = Left$(M$, ITER% - 1) + 's-' + Right$(M$, LONG% - ITER%)16510           Case '59'16520             Let MP$ = Left$(M$, ITER% - 1) + '-' + Butright$(Right$(M$, LONG% - ITER%),1) + 'ux'16530           Case '60'16540             Let MP$ = Left$(M$, ITER% - 1) + 'x-' + Right$(M$, LONG% - ITER%) + 's'16550           Case '61'16560             Let MP$ = Left$(M$, ITER% - 1) + 'x-' + Right$(M$, LONG% - ITER%)16570           Case '62','63'16580             Let ITER% = 016590             Loop16600               Inc ITER%16610               Exit If Mid$(M$,ITER%,1) = '-'16620             End Loop16630             If Right$(LLIGN$,2) = '62' Then Let MP$ = Left$(M$, ITER% - 1) + 'x-'16640             If Right$(LLIGN$,2) = '63' Then Let MP$ = Left$(M$, ITER% - 1) + 's-'16650             Let K% = ITER% + 116660             Loop16670               Inc ITER%16680               Exit If Mid$(M$,ITER%,1) = '-'16690             End Loop16700             Let MP$ = MP$ + Mid$(M$, K%, ITER% - K%) + 's-'16710             Let MP$ = MP$ + Right$(M$, LONG% - ITER%)16720             If Right$(LLIGN$,2) = '63' Then Let MP$ = MP$ + 's'16730           Case '64'16740             Let MP$ = Left$(M$, ITER% - 2) + 'ux-' + Right$(M$,LONG% - ITER%) + 's'16750           Case '56','65'16760             Let MP$ = M$ + 'x'16770           Case '66'16780             Let MP$ = Left$(M$, ITER% - 1) + 's-' + Right$(M$,LONG% - ITER%) + 'x'16790           Case '67'16800             Let MP$ = Butright$(M$,1) + 'ies'16810           Case '68'16820             Let MP$ = Butright$(M$,1) + 'ux'16830           Case '69'16840             Let MP$ = Left$(M$, ITER% - 2) + 'ux-' + Right$(M$, LONG% - ITER%) + 's'16850         End Select16860       Case Else16865         let fini% = 116870         Let @MOTPL$ = LLIGN$ + 's'16880         Let @MOT$ = LLIGN$16890     End Select16895     if fini% = 1 then 1691016900     Let @MOTPL$ = MP$16910   Case 216920     Let TIRET% = 016930     Let LONG% = Len(LLIGN$)16940     For ITER% = 1 To LONG%16950       If Mid$(LLIGN$,ITER%,1) = '-' Then Inc TIRET%16960     Next ITER%16970     If TIRET% = 0 Then Let PART1$ = LLIGN$ : Let ITER% = 0 : Goto 1711016980     Let PART1$ = '' : Let PART2$ = '' : Let PART3$ = ''16990     Let ITER% = 0 : Let K% = 017000     Loop17010       Inc K%17020       Exit If K% > LONG%17030       Let C$ = Mid$(LLIGN$,K%,1)17040       If C$ = '-' Then Inc ITER% : Goto 1710017050       Select ITER%17060         Case 0 : Let PART1$ = PART1$ + C$17070         Case 1 : Let PART2$ = PART2$ + C$17080         Case 2 : Let PART3$ = PART3$ + C$17090       End Select17100     End Loop17110     For ITER% = 0 To TIRET%17120       Select ITER%17130         Case 0 : Let LLIGN$ = PART1$17140         Case 1 : Let LLIGN$ = PART2$17150         Case 2 : Let LLIGN$ = PART3$17160       End Select17170       Let POSIT% = 0 : Let K% = 017180       Loop17190         Inc POSIT%17200         Exit If POSIT% > Len(LLIGN$)17210         Select Mid$(LLIGN$, POSIT%, 1)17220           Case '.', '$', ',', ']' : Inc K%17230           Case Else : Let K% = 017240         End Select17250         Exit If K% > 017260       End Loop17270       Do If K% = 017280         Let RM$ = LLIGN$17290         Let RF$ = LLIGN$17300         Let MP$ = LLIGN$17310         Let FF$ = ''17320       Do Else17330         Select Right$(LLIGN$,1)17340           Case ']'17350             Let RM$ = Butright$(LLIGN$,1)17360             Let RF$ = RM$17370             Let MP$ = RM$ + 's'17380             Let FF$ = 's'17390           Case '.'17400             Let RM$ = Butright$(LLIGN$,4)17410             Let RF$ = RM$ + Chr$(20)17420             Let MP$ = RM$ + 's'17430             Let FF$ = 's' 17440           Case Else17450             Let K% = 017460             Let POSPOINT% = 0 : Let POSDOLL% = 017470             Loop17480               Inc K%17490               Exit If K% > Len(LLIGN$)17500               Select Mid$(LLIGN$,K%,1)17510                 Case '.'17520                   Let RM$ = Left$(LLIGN$, K% - 1)17530                   Let MP$ = RM$17540                   Let RF$ = RM$17550                   Let POSPOINT% = K%17560                 Case '$'17570                   Let POSDOLL% = K%17580                   Do If POSPOINT% = 017590                     Let RM$ = Left$(LLIGN$, K% - 1)17600                     Let MP$ = RM$17610                     Let RF$ = RM$17620                   Do Else17630                     Let RM$ = RM$ + Mid$(LLIGN$, POSPOINT% + 1, K% - POSPOINT% - 1)17640                     Let MP$ = Left$(RM$, POSPOINT% - 1)17650                   End Do17660                 Case ','17670                   Do If K% = POSDOLL% + 117680                   Let MP$ = RM$17690                   Do Else17700                     If Mid$(LLIGN$, POSDOLL% + 1, 1) = 's' Then Let MP$ = RM$17710                      Let MP$ = MP$ + Mid$(LLIGN$, POSDOLL% + 1, K% - POSDOLL% - 1)17720                   End Do17730                   Do If K% = Len(LLIGN$)17740                     Let RF$ = RM$ + 'e'17750                     Let FF$ = 's'17760                   Do Else17770                     Let RF$ = RF$ + Right$(LLIGN$, Len(LLIGN$) - K%) + 'e'17780                     Let FF$ = 's'17790                   End Do17800               End Select17810             End Do17820          End Loop17830        End Select17840        Select ITER%17850          Case 017860            Let MS1$ = RM$17870            Let MP1$ = MP$17880            Let FS1$ = RF$17890            Let FP1$ = FS1$ + FF$17900          Case 117910            Let MS2$ = RM$17920            Let MP2$ = MP$17930            Let FS2$ = RF$17940            Let FP2$ = FS2$ + FF$17950          Case 217960            Let MS3$ = RM$17970            Let MP3$ = MP$17980            Let FS3$ = RF$17990            Let FP3$ = FS3$ + FF$18000        End Select18010      Next ITER%18020      Select TIRET%18030        Case 018040          Let @MOT$ = MS1$18050          Let @MOTPL$ = MP1$18060          Let @MOTFS$ = FS1$18070          Let @MOTFP$ = FP1$18080        Case 118090          Let @MOT$ = MS1$ + '-' + MS2$18100          Let @MOTPL$ = MP1$ + '-' + MP2$18110          Let @MOTFS$ = FS1$ + '-' + FS2$18120          Let @MOTFP$ = FP1$ + '-' + FP2$18130        Case 218140          Let @MOT$ = MS1$ + '-' + MS2$ + '-' + MS3$18150          Let @MOTPL$ = MP1$ + '-' + MP2$ + '-' + MP3$18160          Let @MOTFS$ = FS1$ + '-' + FS2$ + '-' + FS3$18170          Let @MOTFP$ = FP1$ + '-' + FP2$ + '-' + FP3$18180      End Select18190      Select @GENRE%18200        Case 118210          Let @MOTFS$ = '' : Let @MOTFP$ = ''18220      End Select18230  End Select18240  Pop FP3$, FP2$, FP1$, FS3$, FS2$,FS1$, MP3$, MP2$, MP1$18250  Pop MS3$, MS2$, MS1$18260  Pop POSDOLL%, POSPOINT%, POSIT%, TIRET%, LONG%, K%, ITER%, fini%18270  Pop PART3$, PART2$, PART1$, FF$, RF$, RM$, MP$, C$, M$18280 Return