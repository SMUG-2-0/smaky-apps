	.SBTTL	DICOINDEX.ASI;------------\\; INDEXSEARCH >;============/; Cherche rapidement un mot d'aprs l'index  3 lettres.; in	A4/D4.L	^mot/lg; out	D7.W	erreur; mod	D7.WINDEXSEARCH:	PUSHM.L	D0..D4,A2..A4; Cherche les 3 premires lettres du mot.	COMP.L	D4,#4	JUMP,LO 80$	LOAD.L	A3,A4	LOAD.L	D0,D4	LOAD.W	D1,#3-1	CLR.L	D220$:	LOAD.B	D3,(A3+)	DEC.L	D0	JUMP,NS 80$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 20$	COMP.B	D3,#'Z	JUMP,HI 20$	LOAD.B	D2,D3	RL.L	D2,#8	DECJ.W,NMO D1,20$; Cherche l'index correspondant aux 3 premires lettres du mot.	LOAD.L	A3,#(A6)+OBUIDX-1230$:	LOAD.L	A3,#(A3)+12	; A3 <-- ^index suivant	LOAD.L	D3,(A3)	JUMP,EQ 80$	COMP.L	D3,D2	JUMP,NE 30$; Initialise pour la recherche.	LOAD.L	(A6)+OSRCPD,(A3)+4	LOAD.L	(A6)+OSRCPF,(A3)+8	CLR.W	(A6)+OSRCRD	; commence dans le dico principal	CLR.W	(A6)+OSRCNM	TEST.W	D4	JUMP,EQ 80$	LOAD.L	A3,#(A6)+OSRCM040$:	LOAD.B	D3,(A4+)	JUMP',EQ 42$	CALL	MAJMIN		; D3 <-- caractre minuscule	LOAD.B	(A3+),D3	; OSRCM0 <-- mot exact	DEC.W	D4	JUMP,NE 40$42$:	CLR.B	(A3); Recherche le mot dans la portion indique par l'index.	LOAD.L	A5,(A6)+OSRCPD	; A5 <-- ^mot dans le dictionnaire50$:	COMP.L	A5,(A6)+OSRCPF	; fin du dictionnaire ?	JUMP,EQ 80$		; oui => 80$	LOAD.L	A3,A5	LOAD.L	A4,#(A6)+OSRCMD	CALL	DECOMOT		; OSRCMD <-- mot dcod52$:	LOAD.W	D4,(A6)+OSRCNM	INC.W	(A6)+OSRCNM	LOAD.L	A3,#(A6)+OSRCBU	LOAD.L	A4,#(A6)+OSRCMD	CALL	SEARCHMOT	; OSRCBU <-- un mot en clair	JUMP',EQ 60$	COMP.W	D7,#ERDIEX	JUMP,EQ 52$54$:	TEST.B	(A5+)		; A5 <-- ^mot suivant	JUMP,NE 54$	CLR.W	(A6)+OSRCNM	JUMP	50$60$:	LOAD.L	A2,#(A6)+OSRCM062$:	TEST.B	(A2)	JUMP',EQ 64$	COMP.B	(A2+),(A3+)	JUMP,EQ 62$	JUMP'	52$64$:	TEST.B	(A3)	JUMP',NE 52$	CLR.W	D7		; D7 <-- trouv	JUMP'	90$80$:	LOAD.W	D7,#ERDIPT90$:	POPM.L	D0..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; INDEXINIT >;==========/; Gnre la table des index  3 lettres.; in	-; out	-; mod	D7.WINDEXINIT:	PUSHM.L	D0..D5,A4	LOAD.L	A4,#(A6)+OBUIDX	LOAD.W	D4,#MAXIDX-1CLR.L D5	LOAD.W	D0,#'A20$:	LOAD.W	D1,#'A21$:	LOAD.W	D2,#'A22$:	CALL	INDEXONE	; OBUIDX <-- un index	JUMP',NE 40$INC.L D5	DEC.W	D4	JUMP',EQ 50$40$:	INC.W	D2	COMP.W	D2,#'Z	JUMP,LS 22$	INC.W	D1	COMP.W	D1,#'Z	JUMP,LS 21$	INC.W	D0	COMP.W	D0,#'Z	JUMP,LS 20$50$:	CLR.L	(A4)LOAD.L D4,D5LIB ?AFX8LIB ?GETCAR	POPM.L	D0..D5,A4	RET;---------\\; INDEXONE >;---------/; Gnre un index  3 lettres, si ncessaire.; in	D0.W	premire lettre;	D1.W	deuxime lettre;	D2.W	troisime lettre;	A4.L	^buffer des index; out	A4.L	^plus loin; mod	D7.W, A4.LINDEXONE:	PUSHM.L	D4,D5,A0..A3	LOAD.W	D4,D0	SUB.W	D4,#'A		; D4 <-- 0..25	MUL.WU	D4,#27*4	LOAD.W	D5,D1	SUB.W	D5,#'A-1	; D5 <-- 0..26	MUL.WU	D5,#4	ADD.W	D4,D5	LOAD.L	A2,(A6)+OPDICO	; A2 <-- ^index	LOAD.L	A3,#(A2)+(D4.W)	LOAD.L	D4,(A3+)	JUMP,EQ 80$	LOAD.L	A0,#(A2)+(D4.L)	; A0 <-- ^dbut20$:	LOAD.L	D4,(A3+)	JUMP,EQ 20$	LOAD.L	A1,#(A2)+(D4.L)	; A1 <-- ^fin	LOAD.L	D4,A1	SUB.L	D4,A0	COMP.L	D4,#100		; y a-t-il bcp de mots ?	JUMP,LO 80$		; non => 80$; Cherche le dbut de l'index.	LOAD.L	A3,A030$:	COMP.L	A3,A1	JUMP,HS 80$	CALL	INDEXIFD	JUMP',EQ 38$	CLR.B	D434$:	COMP.B	D4,(A3+)	; A3 <-- ^mot suivant	JUMP,NE 34$	JUMP	30$38$:	LOAD.B	(A4+),D0	LOAD.B	(A4+),D1	LOAD.B	(A4+),D2	CLR.B	(A4+)	LOAD.L	(A4+),A3; Cherche la fin de l'index.40$:	CALL	INDEXIFF	JUMP',NE 48$	CLR.B	D444$:	COMP.B	D4,(A3+)	; A3 <-- ^mot suivant	JUMP,NE 44$	JUMP	40$48$:	LOAD.L	(A4+),A3	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv90$:	POPM.L	D4,D5,A0..A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; INDEXIFD >;---------/; Regarde si un mot correspond aux 3 premires lettres; donnes dans D0..D3.; in	D0.W	premire lettre;	D1.W	deuxime lettre;	D2.W	troisime lettre;	A3.L	^mot; out	D7.W	erreur; mod	D7.WINDEXIFD:	PUSHM.L	D3,A3,A4	LOAD.L	A4,#(A6)+OSRCMD	CALL	DECOMOT		; OSRCMD <-- mot dcod	INC.L	A4		; A4 <-- saute le type	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv20$:	LOAD.B	D3,(A4+)	JUMP,EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 20$	COMP.B	D3,#'Z	JUMP,HI 20$	COMP.B	D3,D0	JUMP,NE 90$30$:	LOAD.B	D3,(A4+)	JUMP',EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 30$	COMP.B	D3,#'Z	JUMP,HI 30$	COMP.B	D3,D1	JUMP',NE 90$40$:	LOAD.B	D3,(A4+)	JUMP',EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 40$	COMP.B	D3,#'Z	JUMP,HI 40$	COMP.B	D3,D2	JUMP',NE 90$	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; INDEXIFF >;---------/; Regarde si un mot correspond aux 3 premires lettres; donnes dans D0..D3.; in	D0.W	premire lettre;	D1.W	deuxime lettre;	D2.W	troisime lettre;	A3.L	^mot; out	D7.W	erreur; mod	D7.WINDEXIFF:	PUSHM.L	D3,A3,A4	LOAD.L	A4,#(A6)+OSRCMD	CALL	DECOMOT		; OSRCMD <-- mot dcod	INC.L	A4		; A4 <-- saute le type	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv20$:	LOAD.B	D3,(A4+)	JUMP,EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 20$	COMP.B	D3,#'Z	JUMP,HI 20$	COMP.B	D3,D0	JUMP,NE 90$30$:	LOAD.B	D3,(A4+)	JUMP',EQ 80$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 30$	COMP.B	D3,#'Z	JUMP,HI 30$	COMP.B	D3,D1	JUMP',NE 90$40$:	LOAD.B	D3,(A4+)	JUMP',EQ 80$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 40$	COMP.B	D3,#'Z	JUMP,HI 40$	COMP.B	D3,D2	JUMP',NE 90$80$:	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET	.END