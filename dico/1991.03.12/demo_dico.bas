 6330 Label_DECODVER(LLIGN$, @INFINIT$, @NOCONJ$, @AUXILI$) 6340 -- 6350   Select Left$(LLIGN$,1) 6360     Case 't','i','u','r','1','2','h','v','7' : Let ESPECE = 1 6370     Case Else : Let ESPECE = 0 6380   End Select 6390   If ESPECE = 0 Then Return 6400   Let INITLOCA$ = Left$(LLIGN$,1) 6410   Let LLIGN$ = Butleft$(LLIGN$,1) 6420   Let LONG% = Len(LLIGN$) : Let ITER% = LONG% + 1 6430   Let VIRGULE% = 0 : Let RECOMM% = 0 6440   Loop 6450     Dec ITER% 6460     Exit If ITER% = 0 6470     If Mid$(LLIGN$, ITER%, 1) = Chr$(44) Then Inc VIRGULE% 6480     Exit If VIRGULE% = 1 6490   End Loop 6500   Select VIRGULE% 6510     Case 1 6520       Select LONG% - ITER% 6530         Case 1 6540           Let @AUXILI$ = Right$(LLIGN$,1) 6550         Case 2 6560           Let @AUXILI$ = '2' 6570       End Select 6580       Let LLIGN$ = Butright$(LLIGN$, LONG% - ITER% + 1) 6590       Let RECOMM% = 1 6600       Let VIRGULE% = 0 6610     Case 0 6620       Select Asc(Left$(Right$(LLIGN$,2),1)) 6630         Case 48..57 6640           Let @INFINIT$ = Butright$(LLIGN$,3) 6650           Let @NOCONJ$ = Right$(LLIGN$,3) 6660         Case Else 6670           Let @INFINIT$ = LLIGN$ 6680           Let @NOCONJ$ = Upper$(Right$(LLIGN$,3)) 6690       End Select 6700       Do If RECOMM% = 1 6710         Let RECOMM% = 0 6720       Do Else 6730         Let @AUXILI$ = 'A' 6740       End Do 6750   End Select 6760   If RECOMM% = 1 Then 6500 6770   Select Right$(@NOCONJ$,2) 6780     Case 'ER' : Let @NOCONJ$ = '001' 6790     Case 'IR' : Let @NOCONJ$ = '11A' 6800   End Select 6810   Do If Left$(@INFINIT$,1) = 'H' 6820     Let @INFINIT$ = 'h' + Butleft$(@INFINIT$,1) 6830   End Do 6840   Do If INITLOCA$ = 'r' 6850     Select Left$(LLIGN$,1) 6860       Case 'h' 6870         Let @INFINIT$ = "s'" + @INFINIT$ 6880       Case Else 6890         Select Upper$(Left$(LLIGN$,1)) 6900           Case 'A', 'E', 'I', 'O', 'U', 'Y' 6910             Let @INFINIT$ = 