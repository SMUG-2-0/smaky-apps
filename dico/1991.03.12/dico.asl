	.TITLE	DICO.ASL;	--------------------------------------;		(C) 1989 - Daniel Roux;	--------------------------------------;	Source du module SMA_DICO.LIB;	Date		Amliorations; ---------------------------------------------------------------------------------------; 1.14	27.06.90	DICO_BINIT: nouveau;			DICO_BNEXT: nouveau;			DICO_BFORM: nouveau; 1.13	30.05.90	DICO_SYNO: ne plante plus si texte trop long;			DICO_FAMILLE: idem; 1.12	03.05.90	DICO_FAMILLE: nouvel appel avec 250000.FDICO;			DICO_SYNO: trouve toujours, mme aprs un AUTRE; 1.11	05.03.90	DICO_CHIFFRE: "millionime" n'a qu'un "n"; 1.10	10.01.90	DICO_JUSTE: ne plante plus si "radica.l$ux-socialiste]";			DICO_CONJ: ne plante plus si texte trop long;			DICO_ACCORD: idem; 1.9	28.12.89	DICO_OPEN: adaptation  500000.BDICO;			LGMOT = 80  (anciennement 40); 1.8	06.07.89	DICO_CHANGE: scroll-liste pour afficher le contexte;			DICO_SYNO: synonymes fonctionnant vraiment avec 250000.SDICO;			DICO_SYNO: in avec A4/D4 et A3/D3 (pour le contexte);			DICO_JUSTE: accepte "nom-ci" ou "nom-l";			DICO_CHIFFRE: nouvel appel; 1.7	30.06.89	DICO_ADD: nouvelle espce "nom propre"; 1.6	01.03.89	DICO_ADD: plus fut pour encoder les adjectifs; 1.5	27.01.89	DICO_CHANGE: si encod => MS/MP/FS/FP propos meilleur;			DICO_CHANGE: si encod => demande si "h" aspir;			DICO_CHANGE: si encod => demande verbe transitif, etc.;			DICO_CHANGE: grise les touches inutiles;			DICO_VTEMP: nouvel appel; 1.4	26.01.89	DICO_ACCORD: grise les choix impossibles;			DICO_CHANGE: refait les soft-keys; 1.3	23.01.89	DICO_JUSTE: accepte ":" pour terminer commande "boa";			DICO_JUSTE: va toujours jusqu'au bout;			DICO_JUSTE: accepte LF/TIRET dans mots; 1.2	20.01.89	DICO_CHANGE: CHOIX conserve DICO/TEMP; 1.1	13.01.89	DICO_DEF: saute les noms propres;			DICO_DEF: saute les commandes "boa";			DICO_DEF: mode (edit,get,put);			DICO_JUSTE: 7x plus rapide (index  3 ou 4 lettres);			DICO_JUSTE: pas de dbox si un seul mot;			DICO_CHANGE: dbox plus petite;			DICO_CHANGE: lutin-souris spcial pendant recherche;			DICO_CHANGE: conserve DICO/TEMP;			DICO_OPEN: dbox pendant le chargement;			DICO_SYNO: synonymes (appel bidon); 1.0	12.01.89	premire version distribue (avec PLUME 0.1c)	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal	.REF	SMAKY	.REF	MODULES	.REF	DICO	.REV	1,14; Assemblage conditionnel; -----------------------JMOUSE	=	0		; 1 => lutin-souris rotatif pendant recherche; Structure d'un fichier .BDICO; -----------------------------;;	|=======|-------------;	|       |           |;	|       |           256 (en-tte binaire);	|       |           |;	|=======|------------------------------- dbut pour les Pn;	|       |           |     |     |     |;	|       |           |     |     |     |;	|-------|-------    |     |     |     |;	|  P1.L |     |     |     |     |     |;	|-------|     6     L1    |     |     |    L1=((26*27)+1)*6;	|  P2.W |     |     |     |     |     |;	|-------|-------    |     P2    |     |;	|       |           |     |     |     |;	|       |           |     |     |     |;	|=======|-------------    |     |     |;	|       |           |     |     |     |;	|       |           |     |     |     |;	|       |           |     |     |     |;	|-------|---------- | ------    |     |;	| 3me.B|     |     |           |     |;	|-------|     |     |           |     |;	| 4me.B|     |     |           |     |;	|-------|     8     |           |     |;	|  P4.L |     |     |           P1    |;	|-------|     |     |           |     |;	|  L4.W |     |     |           |     P4;	|-------|-------    L2          |     |;	|       |           |           |     |;	|       |           |           |     |;	|       |           |           |     |;	|-------|           |           |     |;	|  0.W  |           |           |     |;	|-------|           |           |     |;	|       |           |           |     |;	|       |           |           |     |;	|       |           |           |     |;	|-------|           |           |     |;	|  0.W  |           |           |     |;	|=======|-------------          |     |;	|       |           |           |     |;	|       |           |           |     |;	|       |---------- | ------------    |;	|       |           |                 |;	|       |---------- | ------------------;	|       |           L3                |;	|       |           |                 L4;	|       |           |                 |;	|       |---------- | ------------------;	|       |           |;	|       |           |;	|=======|-------------;;	L1:	Index pour les 2 premires lettres.;		Cet index a toujours une longueur de ((26*27)+1)*6 bytes.;;		A;		AA;		AB;		AC;		B;		BA;		BB;		BC;		C;		CA;		CB;		CC;;	L2:	Index pour les 3 ou 4 premires lettres.;		La longueur de cet index est variable.;;		ABA..	A-	3me lettre;		ABC..	C-	3me lettre;		ABJ..	J-	3me lettre;			--	termine les mots en AB*;		ACCA..	CA	3me et 4me lettres;		ACCE..	CE	3me et 4me lettres;		ACCL..	CL	3me et 4me lettres;		ACH..	H-	3me lettre;		ACI..	I-	3me lettre;			--	termine les mots en AC*;			--	terminateur gnral;				"-" indique zro;;		Les deux premires lettres ne sont pas rptes.;		Pour les tranches o L4<200, l'index ne contient;		que la 3me lettre.;		Pour les tranches o L4>200, l'index contient les;		3me et 4me lettres.;;	L3:	Mots cods termins par <0>.;		Cette longueur dpend du nombre de mots contenus.; Constantes; ----------TIRET	=	H'0B		; pseudo-tiretBOA	=	H'5C		; dbut d'une commandeLGMOT	=	80		; lg maximale d'un motLGMOTS	=	500		; lg maximale d'une liste de motsLGMOTDB	=	32		; lg maximale d'un mot dans une dboxKEYDBOX	=	H'7E00		; "touche" spciale icneLCHBIN	=	40		; chiffre: lg buffer en entreLCHBINT	=	LCHBIN		; chiffre: lg buffer intermdiaireLCHBOUT	=	LCHBIN*4	; chiffre: lg buffer en sortie; Erreurs; -------ERHERE	=	H'A000		; erreur dans ce moduleERDICO	=	H'A001		; erreur de codageERDIPT	=	H'A002		; pas trouvERDIEX	=	H'A003		; n'existe pas; Fanions pour les dfinitions; ----------------------------BDFSNP	=	16		; saute les noms propresBDFSCB	=	17		; saute les commandes "boa"; Fanions pour les conjugaisons; -----------------------------BCJF1	=	0		; forme: jeBCJF2	=	1		; forme: tuBCJF3	=	2		; forme: il/elleBCJF4	=	3		; forme: ils/ellesBCJF5	=	4		; forme: nousBCJF6	=	5		; forme: vousBCJPRES	=	8		; indicatif: prsentBCJIMP	=	9		; indicatif: imparfaitBCJPASS	=	10		; indicatif: pass simpleBCJFUT	=	11		; indicatif: futur simpleBCJSPRES=	12		; subjonctif: prsentBCJSIMP	=	13		; subjonctif: imparfaitBCJCPRES=	14		; conditionnel: prsentBCJIPRES=	15		; impratif: prsentBCJPPRES=	16		; participe: prsentBCJPPASS=	17		; participe: passBCJINF	=	18		; infinitif; Fanions pour les chiffres; -------------------------BCHREGF	=	0		; franaisBCHREGS	=	1		; suisse-romandBCHREGV	=	2		; vaudoisBCHCARD	=	8		; cardinalBCHORD	=	9		; ordinalBCHMS	=	16		; masculin singulierBCHMP	=	17		; masculin plurielBCHFS	=	18		; fminin singulierBCHFP	=	19		; fminin pluriel; Table des dictionnaires utilisateurs; ------------------------------------MAXDL	=	20		; nb max de dictionnaire utilisateur	.LOC	0ODLNOM:	.BLKB	16		; nom du dictionnaireODLPT:	.BLKB	4		; ^dictionnaireODLMAJ:	.BLKB	1		; 1 => mise  jour ncessaire	.EVENLDL:; Description d'un bloc de dictionnaire utilisateur; -------------------------------------------------	.LOC	0ODUPNX:	.BLKB	4		; ^nextODUNBM:	.BLKB	2		; nombre de motODULGT:	.BLKB	4		; lg totaleODULGU:	.BLKB	4		; lg utiliseLDU:; Description d'un nom mmoris; -----------------------------MAXMM	=	20		; nb max de mots retenus	.LOC	0OMMMOT:	.BLKB	LGMOT		; motOMMDEG:	.BLKB	2		; degr d'exactitudeOMMFOR:	.BLKB	2		; formeOMMTYP:	.BLKB	1		; type	.EVENLGMM:; Variable; --------	.LOC	0OBNAME:	.BLKB	16		; nom du dictionnaire de baseOPDICO:	.BLKB	4		; ^dictionnaire de baseOSDICO:	.BLKB	4		; ^dictionnaire des synonymesOFDICO:	.BLKB	4		; ^dictionnaire des famillesOTADL:	.BLKB	(MAXDL+1)*LDL	; table des dictionnaires utilisateursOSRCPM:	.BLKB	4		; recherche: ^motOSRCLM:	.BLKB	4		; recherche: lg motOSRCPP:	.BLKB	4		; recherche: ^phraseOSRCLP:	.BLKB	4		; recherche: lg phraseOSRCPC:	.BLKB	4		; recherche: ^contexteOSRCLC:	.BLKB	4		; recherche: lg contexteOSRCRD:	.BLKB	2		; recherche: rang du dictionnaireOSRCTD:	.BLKB	1		; recherche: type du dictionnaire	.EVENOSRCPH:	.BLKB	4		; recherche: ^en-tte du blocOSRCPD:	.BLKB	4		; recherche: ^dbutOSRCPF:	.BLKB	4		; recherche: ^finOSRCLS:	.BLKB	2		; recherche: nb de lettres sres (2..0)OSRCNM:	.BLKB	2		; recherche: numro du motOSRCMD:	.BLKB	500		; recherche: mot dcod ou synonymeOSRCBU:	.BLKB	LGMOT		; recherche: mot en clairOSRCB0:	.BLKB	4		; recherche: bits pour les majusculesOSRCM0:	.BLKB	LGMOT		; recherche: mot avec niveau d'exactitude 0OSRCM1:	.BLKB	LGMOT		; recherche: mot avec niveau d'exactitude 1OSRCM2:	.BLKB	LGMOT		; recherche: mot avec niveau d'exactitude 2OSRCMX:	.BLKB	LGMOT		; recherche: mot avec niveau d'exactitudeOCHPDL:	.BLKB	4		; change: dictionnaire choisi (^dans OTADL)OCHKGP:	.BLKB	2		; change: touches grises en permananceOCHKGR:	.BLKB	2		; change: touches grisesOCHFST:	.BLKB	1		; change: flag stoppeOCHFEX:	.BLKB	1		; change: processus fils existe	.EVENODFFAN:	.BLKB	4		; df: fanionsOADLDI:	.BLKB	2		; add: dernier dictionnaire choisiOADNVE:	.BLKB	1		; add: vrification inutile	.EVENOCJPT:	.BLKB	4		; conjugaison: ^typeOCJPR:	.BLKB	4		; conjugaison: ^radicauxOCJPF:	.BLKB	4		; conjugaison: ^formesOCJL0:	.BLKB	2		; conjugaison: longueur 0OCJL1:	.BLKB	2		; conjugaison: longueur 1OCJQQ:	.BLKB	1		; conjugaison: cherche n'importe quelle forme	.EVENOSYBM:	.BLKB	LGMOT		; synonymes: mot de baseOSYBL:	.BLKB	4		; synonymes: lg mot de baseOSYBF:	.BLKB	2		; synonymes: forme mot de base (0..n)OSYBT:	.BLKB	1+1		; synonymes: type mot de baseOSYBR:	.BLKB	2		; synonymes: rang du mot de baseOSYPD:	.BLKB	4		; synonymes: ^dans dicoOSYPL:	.BLKB	4		; synonymes: ^liste trouveOSYNL:	.BLKB	2		; synonymes: nb de mots trouvsOSYRL:	.BLKB	2		; synonymes: rang trouvOSYRS:	.BLKB	2		; synonymes: rang des synonymes trouvsOSYRP:	.BLKB	4		; synonymes: position pour OSYRS (y;x)OCHFAN:	.BLKB	4		; chiffre: fanionsOCHBIN:	.BLKB	LCHBIN+2	; chiffre: buffer d'entreOCHBINT:.BLKB	LCHBINT+2	; chiffre: buffer intermdiaireOCHBOUT:.BLKB	LCHBOUT+2	; chiffre: buffer de sortieOMMNBM:	.BLKB	2		; nb de noms dans OMMBUF/OMMTRIOMMBUF:	.BLKB	(LGMM*MAXMM)+2	; buffer pour mmoriser les noms trouvsOMMTRI:	.BLKB	(LGMM*MAXMM)+2	; buffer pour mmoriser les noms trouvsOBUMOT:	.BLKB	LGMOTSOBUNOM:	.BLKB	LGMOTOBUCOD:	.BLKB	LGMOTOSLVAR1:.BLKB	LSLVAR		; scroll-liste: variables pour contexteOSLVAR2:.BLKB	LSLVAR		; scroll-liste: variables pour propositionsOSLVAR3:.BLKB	LSLVAR		; scroll-liste: variables pour dico privsOSLTXT:	.BLKB	100		; scroll-liste: une ligne de texteOWTCDB:	.BLKB	4		; wait: canal dboxOWTASC:	.BLKB	LSCVAR		; wait: ascenseurOMSPOS:	.BLKB	4		; mouse: positionOMSTMP:	.BLKB	4		; mouse: temps systmeOMSCNT:	.BLKB	2		; mouse: compteurOMSLUT:	.BLKB	((16*16)/8)+2	; mouse: lutinOEDMOT1:.BLKB	LGMOT		; dition: mot MSOEDMOT2:.BLKB	LGMOT		; dition: mot MPOEDMOT3:.BLKB	LGMOT		; dition: mot FSOEDMOT4:.BLKB	LGMOT		; dition: mot FPOBUDIS:	.BLKB	20		; buffer pour write-displayLGVAR:	.LOC	0DEBUT:; En-tte du module LIB; ---------------------	.LOC	0	DICO_	FIRST		; code du premier appel	DICO_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	1,13		; rvision.version	.W	0,END_DICO	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"DICO"		; nom du module	.FILLB	(LGHLIB-.),0	.W	_DICO_OPEN	.W	_DICO_CLOSE	.W	_DICO_JUSTE	.W	_DICO_CHANGE	.W	_DICO_CONJ	.W	_DICO_ACCORD	.W	_DICO_IFMAJ	.W	_DICO_MAJ	.W	_DICO_DEF	.W	_DICO_ADD	.W	_DICO_OK	.W	_DICO_SYNO	.W	_DICO_VTEMP	.W	_DICO_CHIFFRE	.W	_DICO_FAMILLE	.W	_DICO_BINIT	.W	_DICO_BNEXT	.W	_DICO_BFORMNMDICO:	.ASCIZ	"250000.BDICO"NNDICO:	.ASCIZ	"500000.BDICO"NSDICO:	.ASCIZ	"250000.SDICO"NFDICO:	.ASCIZ	"250000.FDICO"	.EVEN;-----------\\; _DICO_OPEN >;===========/; Ouvre le dictionnaire.; in	-; out	D6.L	canal;	D7.W	erreur; mod	D6.L, D7.W_DICO_OPEN:	PUSHM.L	D1..D5,A2..A6	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE EXIT8$	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A3,#R16"NNDICO	LOAD.L	A4,#(A6)+OSLTXT	LOAD.W	D3,#2^BOPSYS	FOS	?SARGS		; OSLTXT <-- arguments de 500000.BDICO	JUMP',NE DICO25$	LOAD.L	D3,(A4)+OBALGF	; D3 <-- longueur du fichier	ADD.L	D3,#20000	; D3 <-- ajoute petite rserve	GESMEM	?ARGMEM		; D4/D5 <-- libre/plus grand trou	COMP.L	D5,D3		; assez de mmoire ?	JUMP',LO DICO25$	; non => DICO25$	LOAD.L	A3,#R16"NMDICO	LOAD.L	A4,#(A6)+OSLTXT	LOAD.W	D3,#2^BOPSYS	FOS	?SARGS		; OSLTXT <-- arguments de 250000.BDICO	JUMP',NE DICO50$	CALL	DBOXWHAT	; demande quel dico charger ...	JUMP,NE EXIT7$	LOAD.W	D7,#ERKSTO	COMP.W	D3,#F1	JUMP,NE EXIT7$	TEST.L	D4:#1	JUMP',BS DICO50$DICO25$:	LOAD.L	A2,#R16"TDBOX_OPEN25	LOAD.L	A3,#R16"NMDICO	JUMP'	DICOXX$DICO50$:	LOAD.L	A2,#R16"TDBOX_OPEN50	LOAD.L	A3,#R16"NNDICO;	JUMP'	DICOXX$DICOXX$:	LOAD.L	A4,#(A6)+OBNAMEXFER$:	LOAD.B	(A4+),(A3+)	; OBNAME <-- nom du dico de base	JUMP,NE XFER$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE EXIT7$	LOAD.L	(A6)+ODFFAN,#H'0000FFFF ; tous les temps de conjugaison	LOAD.L	A3,#(A6)+OBNAME	LOAD.L	D3,#2^BEXNHEAD	; D3 <-- ne charge pas l'en-tte	FOS	?CLOAD		; charge le dictionnaire principal	JUMP',NE EXIT6$	LOAD.L	(A6)+OPDICO,A4	CALL	DICOLIST	; fait la liste des dictionnaires utilisateur	DBOX_	CLOSE		; ferme la DBOX	LOAD.L	D6,A6		; D6 <-- canal	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT8$EXIT6$:	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D7EXIT7$:	PUSH.W	D7	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire des variables	POP.W	D7EXIT8$:	POPM.L	D1..D5,A2..A6	TEST.W	D7		; retour EQ/NE	RETTDBOX_OPEN25:	.W	10$-TDBOX_OPEN25	.W	20$-TDBOX_OPEN25	.W	0,010$:	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Chargement du dictionnaire de base "	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"en cours (250'000 mots) ..."	.B	ODBCR,ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTDBOX_OPEN50:	.W	10$-TDBOX_OPEN50	.W	20$-TDBOX_OPEN50	.W	0,010$:	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Chargement du dictionnaire de base "	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"en cours (500'000 mots) ..."	.B	ODBCR,ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN;-----------\\; DICO_SOPEN >;===========/; Ouvre le dictionnaire des synonymes, si ncessaire.; in	-; out	D7.W	erreur; mod	D7.WDICO_SOPEN:	PUSHM.L	D2..D5,A2..A4	CLR.W	D7		; D7 <-- ok	TEST.L	(A6)+OSDICO	; dictionnaire dj charg ?	JUMP',NE 95$		; oui => 95$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A2,#R16"TDBOX_SOPEN	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE 95$	LOAD.L	A3,#R16"NSDICO	LOAD.L	D3,#2^BEXNHEAD	; D3 <-- ne charge pas l'en-tte	FOS	?CLOAD		; charge le dictionnaire des synonymes	JUMP',NE 90$	LOAD.L	(A6)+OSDICO,A490$:	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D795$:	POPM.L	D2..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_SOPEN:	.W	10$-TDBOX_SOPEN	.W	20$-TDBOX_SOPEN	.W	0,010$:	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Chargement du dictionnaire des synonymes "	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"en cours (250'000 synonymes) ..."	.B	ODBCR,ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN;-----------\\; DICO_FOPEN >;===========/; Ouvre le dictionnaire des familles, si ncessaire.; in	-; out	D7.W	erreur; mod	D7.WDICO_FOPEN:	PUSHM.L	D2..D5,A2..A4	CLR.W	D7		; D7 <-- ok	TEST.L	(A6)+OFDICO	; dictionnaire dj charg ?	JUMP',NE 95$		; oui => 95$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A2,#R16"TDBOX_FOPEN	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE 95$	LOAD.L	A3,#R16"NFDICO	LOAD.L	D3,#2^BEXNHEAD	; D3 <-- ne charge pas l'en-tte	FOS	?CLOAD		; charge le dictionnaire des familles	JUMP',NE 90$	LOAD.L	(A6)+OFDICO,A490$:	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D795$:	POPM.L	D2..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_FOPEN:	.W	10$-TDBOX_FOPEN	.W	20$-TDBOX_FOPEN	.W	0,010$:	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Chargement du dictionnaire des familles "	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"en cours (250'000 correspondances) ..."	.B	ODBCR,ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN;------------\\; _DICO_CLOSE >;============/; Ferme le dictionnaire.; in	D6.L	canal; out	D7.W	erreur; mod	D7.W_DICO_CLOSE:	PUSHM.L	D1,A3,A4,A6	LOAD.L	A6,D6		; A6 <-- ^variables	TEST.L	(A6)+OSDICO	; dictionnaire dj charg ?	JUMP',EQ 20$		; non => 20$	LOAD.L	A3,#R16"NSDICO	FOS	?CUNLOAD	; libre le dictionnaire des synonymes20$:	TEST.L	(A6)+OFDICO	; dictionnaire dj charg ?	JUMP',EQ 30$		; non => 30$	LOAD.L	A3,#R16"NFDICO	FOS	?CUNLOAD	; libre le dictionnaire des familles30$:	LOAD.L	A3,#(A6)+OBNAME	; A3 <-- ^nom du dico de base	FOS	?CUNLOAD	; libre le dictionnaire principal	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire des variables	POPM.L	D1,A3,A4,A6	CLR.W	D7		; retour EQ	RET;----------\\; _DICO_DEF >;==========/; Choix de quelques dfinitions gnrales.; in	D6.L	canal;	D3.W	mode (0=edit, 1=get, 2=put);	D4.L	fanions (si D3=put); out	D4.L	fanions (si D3=get);	D7.W	erreur; mod	D4.L, D7.W_DICO_DEF:	PUSHM.L	D1..D3,D5,A0..A6	LOAD.L	A6,D6		; A6 <-- ^variables	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	COMP.W	D3,#1	JUMP,EQ GET$	COMP.W	D3,#2	JUMP,EQ PUT$	LOAD.L	A2,#R16"TDBOX_DEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+ODFFAN	; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!100	CALL	DBOXHLINE	LOAD.W	D2,#2^BDBGCLABEL!101	CALL	DBOXHLINELOOP$:	DBOX_	EDIT		; attend une action ...;	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_DEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ OK$	COMP.W	D3,#F0	JUMP',EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$OK$:	LOAD.L	(A6)+ODFFAN,D4END$:	DBOX_	CLOSE		; ferme la DBOX	JUMP'	EXIT$PUT$:	LOAD.L	(A6)+ODFFAN,D4	JUMP'	EXIT$GET$:	LOAD.L	D4,(A6)+ODFFAN;	JUMP'	EXIT$EXIT$:	POPM.L	D1..D3,D5,A0..A6	TEST.W	D7		; retour EQ/NE	RETTDBOX_DEF:	.W	10$-TDBOX_DEF	.W	20$-TDBOX_DEF	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Conjugue les verbes aux temps suivants :"	.B	ODBCR,ODBCR	.B	ODBSQUARE,2	.ASCIZ	" indicatif pass simple"	.B	ODBTABX,28	.B	ODBSQUARE,4	.ASCIZ	" subjonctif prsent"	.B	ODBCR	.B	ODBSQUARE,6	.ASCIZ	" conditionnel prsent"	.B	ODBTABX,28	.B	ODBSQUARE,5	.ASCIZ	" subjonctif imparfait"	.B	ODBCR	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR	.B	ODBSQUARE,BDFSNP	.ASCIZ	" saute les noms propres"	.B	ODBCR	.B	ODBSQUARE,BDFSCB	.ASCIZ	/ saute les commandes "boa"/	.B	ODBCR	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEF:	.W	F1,F2,F3,0		DOKF1-TKEY_DEF	.W	F0,F13,F14,F15,0	DOKF0-TKEY_DEF	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEF	.W	0;------------\\; _DICO_VTEMP >;============/; Vide le dictionnaire temporaire TEMP.; in	D6.L	canal;	D3.W	mode (0=clear, 1=get); out	D4.L	nb de mots contenus (si D3=get);	D7.W	erreur; mod	D4.L, D7.W_DICO_VTEMP:	PUSHM.L	A4,A6	LOAD.L	A6,D6		; A6 <-- ^variables	COMP.W	D3,#1	JUMP',EQ GET$	LOAD.L	A4,(A6)+OTADL+(MAXDL*LDL)+ODLPT	CALL	DICOUNLOAD	; libre le dictionnaire temporaire	CALL	DICONEWBLOC	; A4 <-- ^mmoire pour premier bloc	LOAD.L	(A6)+OTADL+(MAXDL*LDL)+ODLPT,A4	JUMP'	EXIT$GET$:	LOAD.L	A4,(A6)+OTADL+(MAXDL*LDL)+ODLPT	CLR.L	D4GET2$:	ADD.W	D4,(A4)+ODUNBM	; D4 <-- nb mots dans le bloc	TEST.L	(A4)+ODUPNX	; bloc suivant existe ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A4,(A4)+ODUPNX	; A4 <-- ^bloc suivant	JUMP	GET2$EXIT$:	POPM.L	A4,A6	TEST.W	D7		; retour EQ/NE	RET;---------\\; _DICO_OK >;=========/; Indique que tout est correct (zro faute).; in	D6.L	canal; out	D7.W	erreur; mod	D7.W_DICO_OK:	PUSHM.L	D2..D5,A2..A4	LOAD.L	A2,#R16"TDBOX_OK	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE EXIT$	LOAD.W	D4,#4*50	NTREL	?SETTIMLOOP$:	DBOX_	EDIT		; attend une action ...	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	LOAD.W	D4,#-1	NTREL	?SETTIM	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D2..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_OK:	.W	10$-TDBOX_OK	.W	20$-TDBOX_OK	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Vrification termine, aucune"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"faute n'a t dcele !"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"   VU   "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Vu"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN;------------\\; _DICO_IFMAJ >;============/; Regarde si une mise  jour (avec DICO_MAJ) est ncessaire.; in	D6.L	canal; out	D7.W	zro => mise  jour inutile;	D7.W	autre => mise  jour ncessaire; mod	D7.W_DICO_IFMAJ:	PUSHM.L	D5,A5,A6	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	A5,#(A6)+OTADL	LOAD.W	D5,#MAXDL	LOAD.W	D7,#1		; D7 <-- mise  jour ncessaire20$:	TEST.L	(A5)+ODLPT	; dictionnaire charg ?	JUMP',EQ 50$		; non => 50$	TEST.B	(A5)+ODLMAJ	; dictionnaire  jour ?	JUMP',T 90$		; non => 90$50$:	LOAD.L	A5,#(A5)+LDL	; A5 <-- ^dictionnaire suivant	DEC.W	D5	JUMP,NE 20$	CLR.W	D7		; D7 <-- mise  jour inutile90$:	POPM.L	D5,A5,A6	TEST.W	D7		; retour EQ/NE	RET;----------\\; _DICO_MAJ >;==========/; Met  jour tous les dictionnaires privs qui ont t modifis.; in	D6.L	canal; out	D3.W	dernire touche (F0=annule, F1=mise  jour);	D7.W	erreur; mod	D3.L, D7.W_DICO_MAJ:	PUSHM.L	D4,D5,A3..A6	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	A5,#(A6)+OTADL	LOAD.W	D5,#MAXDL20$:	TEST.L	(A5)+ODLPT	; dictionnaire charg ?	JUMP,EQ 50$		; non => 50$	TEST.B	(A5)+ODLMAJ	; dictionnaire  jour ?	JUMP,F 50$		; oui => 50$	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	LOAD.L	A3,#(A5)+ODLNOM	; A3 <-- ^nom	CALL	DBOXMAJ		; mise  jour ...	JUMP',NE 90$	COMP.W	D3,#F4	JUMP',EQ 50$	COMP.W	D3,#F0	JUMP',EQ 90$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#(A5)+ODLNOM	; A3 <-- ^nom	LOAD.L	A4,(A5)+ODLPT	; A4 <-- ^dictionnaire	CALL	DICOSAVE	; sauve le dico sur disque	JUMP',NE 90$	CLR.B	(A5)+ODLMAJ	; dictionnaire  jour50$:	LOAD.L	A5,#(A5)+LDL	; A5 <-- ^dictionnaire suivant	DEC.W	D5	JUMP,NE 20$	LOAD.W	D3,#F1		; D3 <-- mise  jour effectue90$:	POPM.L	D4,D5,A3..A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXMAJ >;--------/; Demande s'il faut mettre  jour.; in	A3.L	^nom du dictionnaire; out	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D4.L, D7.WDBOXMAJ:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ		; signal qq chose de spcial !	LOAD.L	A2,#R16"TDBOX_MAJ	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!0	DBOX_	GETCO	LIB	?SETCURS	LOAD.B	D3,#'"	LIB	?AFCAR	LOAD.W	D2,#2^BAFXMA	; D2 <-- en majuscules	LOAD.W	D3,#-1		; D3 <-- pas de lg max	LIB	?AFXFILE	; affiche le nom du dictionnaire	LIB	?AFTIM	.ASCIZ	/" ?/	.EVENLOOP$:	DBOX_	EDIT		; attend une action ...;	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_MAJ	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ END$	COMP.W	D3,#F4	JUMP',EQ END$	COMP.W	D3,#F0	JUMP',EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$END$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_MAJ:	.W	10$-TDBOX_MAJ	.W	20$-TDBOX_MAJ	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Mise  jour du dictionnaire"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"priv "	.B	ODBLABEL,0	.B	ODBTEXT	.ASCIZ	"                  "	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"   OUI   "	.B	ODBCR,ODBCR	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	"   NON   "	.B	ODBTEXT	.ASCIZ	"      "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Oui"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Non"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_MAJ:	.W	F1,F2,F3,0		DOKF1-TKEY_MAJ	.W	F4,F5,F6,0		DOKF4-TKEY_MAJ	.W	F0,F13,F14,F15,0	DOKF0-TKEY_MAJ	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MAJ	.W	0;------------\\; _DICO_JUSTE >;============/; Vrifie si tous les mots d'une phrase sont justes.; in	D6.L	canal;	A4/D4.L	^phrase complte/lg;	A3/D3.L	^phase  vrifier/lg; out	D7.W	zro => tous les mots sont justes;	D7.W	ERDIPT => erreur;	D7.W	ERKSTO => stopp;	A4/D4.L	^mot faux/lg; mod	D4.L, D7.W, A4.L_DICO_JUSTE:	PUSHM.L	D1..D3,A0,A3,A6	LOAD.L	A6,D6		; A6 <-- ^variables	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	LOAD.L	D1,D4		; D1 <-- longueur phrase complte	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	CALL	JUSTEIFMANY	; y a-t-il un seul mot ?	JUMP',EQ LOOP$		; oui => LOOP$	CALL	JUSTEOPDBOX	; met la dbox d'attenteLOOP$:	LOAD.L	D1,D3	CALL	JUSTENXDBOX	; montre ce qu'il reste	CALL	SEARCHCADRE	; A4/D4 <-- ^mot/lg	TEST.L	D4	JUMP',EQ NEXT$	TEST.B	(A6)+ODFFAN+1:#BDFSNP-16 ; saute les noms propres ?	JUMP',BC VERIF$		; non => VERIF$	COMP.B	(A4),#'A	JUMP',LO VERIF$	COMP.B	(A4),#'Z	; commence par une majuscule ?	JUMP',LS NEXT$		; oui => NEXT$VERIF$:	CALL	SEARCHEX	; mot existe ?	JUMP',NE ERROR$NEXT$:	ADD.L	D3,A3	SUB.L	D3,A4	SUB.L	D3,D4		; D3 <-- longueur restante	JUMP,LE OK$	LOAD.L	A3,#(A4)+(D4.L)	; A3 <-- ^mot suivant	PUSH.L	D3	LIB	?IFCAR		; une touche presse ?	LOAD.L	D2,D3	POP.L	D3	TEST.W	D7	JUMP,NE LOOP$		; non => LOOP$	LOAD.W	D7,#ERKSTO	; D7 <-- stopp	COMP.W	D2,#KEYMGP	JUMP',EQ EXIT$	COMP.W	D2,#KEYMMP	JUMP',EQ EXIT$	COMP.W	D2,#KEYMDP	JUMP',EQ EXIT$	COMP.W	D2,#END	JUMP',EQ EXIT$	COMP.W	D2,#SPACE	JUMP',EQ EXIT$	COMP.W	D2,#F1	JUMP',EQ EXIT$	COMP.W	D2,#F2	JUMP',EQ EXIT$	COMP.W	D2,#F3	JUMP',EQ EXIT$	JUMP	LOOP$ERROR$:	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	CALL	JUSTECLDBOX	; enlve la dbox d'attente	POPM.L	D1..D3,A0,A3,A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; JUSTEIFMANY >;------------/; Regarde si la phrase  vrifier est constitue de plusieurs mots.; in	A3/D3.L	^phase  vrifier/lg; out	D7.W	zro  => un seul mots;		autre => plusieurs mots; mod	D7.WJUSTEIFMANY:	PUSHM.L	D2,D3,A3	CLR.W	D7		; D7 <-- un seul motLOOP$:	DEC.L	D3		; y a-t-il plusieurs mots ?	JUMP',NS EXIT$		; non => EXIT$	LOAD.B	D2,(A3+)	COMP.B	D2,#''	JUMP,EQ LOOP$	COMP.B	D2,#'-	JUMP,EQ LOOP$	COMP.B	D2,#'	JUMP',LO ERROR$	COMP.B	D2,#'	JUMP,LS LOOP$	COMP.B	D2,#'A	JUMP',LO ERROR$	COMP.B	D2,#'Z	JUMP,LS LOOP$	COMP.B	D2,#'a	JUMP',LO ERROR$	COMP.B	D2,#'z	JUMP,LS LOOP$ERROR$:	LOAD.W	D7,#1		; D7 <-- plusieurs motsEXIT$:	POPM.L	D2,D3,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; JUSTEOPDBOX >;------------/; Met la dbox d'attente.; in	D1.L	nombre initial; out	D7.W	erreur; mod	D7.WJUSTEOPDBOX:	PUSHM.L	D2..D5,A2,A5	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	CALL	JUSTECLDBOX	; enlve si dj l	LOAD.L	A2,#R16"TDBOX_JUSTE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE 90$	LOAD.L	(A6)+OWTCDB,D5	LOAD.L	A5,#(A6)+OWTASC	; A5 <-- ^variables de l'ascenseur	LOAD.W	D2,#2^BDBGCLABEL!1	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFCY	LOAD.W	(A5)+OSCDEBL,D3	SWAP.W	D3	LOAD.W	(A5)+OSCDEBO,D3	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,D3	SUB.W	D4,D3	LOAD.W	(A5)+OSCHTR,D4	LOAD.W	(A5)+OSCHTV,D1	SET.B	(A5)+OSCHOR	SCROLL_	DRAW		; dessine l'ascenseur	LOAD.W	(A5)+OSCPOSR,#-1090$:	POPM.L	D2..D5,A2,A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; JUSTENXDBOX >;------------/; Affiche le nombre restant dans la dbox d'attente.; in	D1.L	nombre restant; out	-; mod	D7.WJUSTENXDBOX:	PUSHM.L	D2..D5,A3,A5	TEST.L	(A6)+OWTCDB	JUMP',EQ 90$	LOAD.L	A5,#(A6)+OWTASC	; A5 <-- ^variables de l'ascenseur	LOAD.W	D3,(A5)+OSCHTV	SUB.W	D3,D1		; D3 <-- nouvelle position virtuelle	CALL	CALPOSR		; D4 <-- nouvelle position relle	SUB.W	D4,(A5)+OSCPOSR	; D4 <-- dplacement rel	COMP.W	D4,#4		; au moins 4 points plus loin ?	JUMP',LO 90$		; non => 90$	LOAD.W	(A5)+OSCPOSV,D3	SCROLL_	UPDATE		; dplace l'ascenseur90$:	POPM.L	D2..D5,A3,A5	RET;--------\\; CALPOSR >;--------/; Calcul la position relle en fonction de la position virtuelle.; in	A5.L	^variables ascenseur;	D3.W	position virtuelle; out	D4.W	position relle; mod	D4.LCALPOSR:	PUSHM.L	D2,D3	LOAD.W	D4,D3	LOAD.W	D3,(A5)+OSCHTR	SUB.W	D3,(A5)+OSCHTC	SUB.W	D3,#LGSCROLL*2	MUL.WU	D4,D3	LOAD.W	D2,(A5)+OSCHTV	DEC.W	D2	JUMP',EQ 30$	DIV.WU	D4,D2	COMP.W	D4,D3		; dpasse la fin ?	JUMP',LO 90$		; non => 90$	LOAD.W	D4,D3		; D4 <-- ne va pas plus loin	DEC.W	D4	JUMP'	90$30$:	CLR.W	D4		; D4 <-- met le minimum90$:	POPM.L	D2,D3	RET;------------\\; JUSTECLDBOX >;------------/; Enlve la dbox d'attente.; in	-; out	-; mod	-JUSTECLDBOX:	PUSHM.L	D5,D7	LOAD.L	D5,(A6)+OWTCDB	JUMP',EQ 90$	DBOX_	CLOSE		; ferme la DBOX	CLR.L	(A6)+OWTCDB90$:	POPM.L	D5,D7	RETTDBOX_JUSTE:	.W	10$-TDBOX_JUSTE	.W	20$-TDBOX_JUSTE	.W	0,010$:	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"      Vrification en cours ...     "	.B	ODBCR,ODBCR	.B	ODBLABEL,1	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" STOPPE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Stoppe"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN;-------------\\; _DICO_CHANGE >;=============/; Remplace un mot suppos faux par un autre.; in	D6.L	canal;	A3/D3.L	^phase  vrifier/lg;	A4/D4.L	^mot faux/lg; out	D3.L	dernire touche presse (F1/F3/F4/F8/F9/F10);	A4/D4.L	^mot juste/lg;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.L_DICO_CHANGE:	PUSHM.L	D0..D2,D5,D6,A0..A3,A5,A6	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	(A6)+OSRCPP,A3	LOAD.L	(A6)+OSRCLP,D3	LOAD.L	(A6)+OSRCPM,A4	LOAD.L	(A6)+OSRCLM,D4	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	LOAD.W	D4,#2	NTREL	?DELMS	CLR.L	(A6)+OMSPOS	CLR.B	(A6)+OCHFST	; ne stoppe pas	NTREL	?GETPRIO	; D4 <-- priorit de DICO	INC.B	D4		; D4 <-- fils moins prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP,NE EXIT$	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	LOAD.L	A2,#R16"TDBOX_CHANGE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.L	D0,D4	LOAD.L	A5,#(A6)+OSLVAR1	CLR.B	(A5)+OSLVID	LOAD.W	D2,#2^BDBGCLABEL!100	CALL	DBOXSLDRAW	; dessine le pourtour de la scroll-liste	CALL	DBOXPHDRAW	; affiche la phrase	LOAD.L	A5,#(A6)+OSLVAR2	CLR.B	(A5)+OSLVID	LOAD.W	D2,#2^BDBGCLABEL!102	CALL	DBOXSLDRAW	; dessine le pourtour de la scroll-liste	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	SR.W	D4,#1	ADD.W	D3,D4	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#54/2	SUB.W	D3,D2	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	ADD.W	D3,#3-10	SWAP.W	D3	SWAP.W	D4	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Une recherche des mots les plus proches est en cours ..."	.EVEN	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	SR.W	D4,#1	ADD.W	D3,D4	SUB.W	D3,#40/2	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	ADD.W	D3,#10	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OMSPOS,D3	LOAD.W	D2,#2^BDBGCLABEL!201	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#2^BDBGCLABEL!202	DBOX_	GETCO	LOAD.L	D4,D3	POP.L	D3	SUB.W	D4,D3	SUB.W	D4,(A0)+ODFCX	INC.W	D3	SUB.W	D4,#2	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,#7+2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#7+7	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour de "choix-conserve-dico/temp"	LOAD.W	D1,(A0)+ODFCX	MUL.WU	D1,#3	ADD.W	D3,D1	LOAD.W	D1,(A0)+ODFCX	MUL.WU	D1,#3+8	SUB.W	D4,D1	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	ADD.W	D3,#2	LOAD.W	D4,#8	SWAP.W	D4	SWAP.W	D3	PUSH.L	D4	CLR.W	D4	LIB	?DRSEG	POP.L	D4	PUSH.L	D4	AND.L	D4,#H'FFFF	LIB	?DRSEG	POP.L	D4	PUSH.L	D4	CLR.W	D4	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	LIB	?DRSEG	POP.L	D4	PUSH.L	D3	LOAD.W	D4,#+4	SWAP.W	D4	LOAD.W	D4,#-4	LIB	?DRSEG	POP.L	D3;	LOAD.W	D4,#+4;	SWAP.W	D4	LOAD.W	D4,#+4	LIB	?DRSEG	LOAD.W	D2,#2^BDBGCLABEL!200	DBOX_	GETCO	LOAD.W	D4,#-1	CALL	AFICONE		; affiche l'icne du degr d'exactitude	CLR.W	(A6)+OCHKGP	LOAD.L	A3,(A6)+OSRCPP	LOAD.L	D3,(A6)+OSRCLP	CALL	JUSTEIFMANY	; y a-t-il un seul mot ?	JUMP',NE MANY$		; non => MANY$	LOAD.W	(A6)+OCHKGP,#2^2!2^3 ; (TOUT) et (STOPPE) toujours grissMANY$:	LOAD.L	A4,#(A6)+OBUMOT	LOAD.L	A3,(A6)+OSRCPM	LOAD.L	D3,(A6)+OSRCLMEDIT$:	LOAD.B	(A4+),(A3+)	; OBUMOT <-- mot faux	DEC.L	D3	JUMP,NE EDIT$	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUMOT	CLR.W	(A6)+OSLVAR2+OSLCYN ; indique scroll-liste vide	CLR.W	(A6)+OSLVAR2+OSLCYS	LIB	?BUZZ		; signale une erreur rencontre !	CLR.W	(A6)+OCHKGR	; pas (encore) de touches grisesLOOP$:	CALL	DBCHGREY	; grise ou dgrise quelques touches	LOAD.L	D4,D0	DBOX_	EDIT		; attend une action ...	LOAD.L	D0,D4	TEST.B	(A6)+OCHFEX	; processus fils existe ?	JUMP',F LOOP4$		; non => LOOP4$	CALL	DBCHFSTOP	; stoppe le processus fils	PUSH.L	D3	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A6)+OSLVAR2+OSLPOS	ADD.W	D3,#LGSCROLL	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.L	D4,(A6)+OSLVAR2+OSLDIM	SUB.W	D4,#LGSCROLL+1	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface le texte dans la scroll-liste	POP.L	D3LOOP4$:	CALL	ZEROCR		; remplace <CR> par <0>	TEST.W	D3	JUMP,EQ LOOP$	LOAD.L	A1,#R16"TKEY_CHANGE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ	CLIC$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#F1	JUMP,EQ END$	COMP.W	D3,#F3	JUMP,EQ END$	COMP.W	D3,#F4	JUMP,EQ END1$	COMP.W	D3,#F7	JUMP,EQ CHOIX$	COMP.W	D3,#F8	JUMP,EQ DICO$	COMP.W	D3,#F9	JUMP,EQ TEMP$	COMP.W	D3,#F10	JUMP,EQ END1$	COMP.W	D3,#KEYDBOX+0	JUMP,EQ INIT$	COMP.W	D3,#KEYDBOX+1	JUMP,EQ FFILS$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ERROR$:	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP	POP.W	D7	LOAD.W	D2,#2^BDBSAV	DBOX_	MERROR		; affiche l'erreur ...	JUMP	SELECTSK$FFILS$:				; fin du processus fils =>	LOAD.L	A5,#(A6)+OSLVAR2	LOAD.L	A4,#R16"DBJUSLTX	LOAD.L	(A5)+OSLADL,A4	LOAD.W	(A5)+OSLCYN,(A6)+OMMNBM	CLR.W	(A5)+OSLCYS	SCROLL_	LUPDATE		; dessine le contenu de la scroll-liste	JUMP	SELECT$INIT$:	LOAD.L	A4,A3	LOAD.L	A3,(A6)+OSRCPM	LOAD.L	D3,(A6)+OSRCLMINIT2$:	LOAD.B	(A4+),(A3+)	DEC.L	D3	JUMP,NE INIT2$	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUMOT	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$CLIC$:	LIB	?IFMOUSE	JUMP,NE BIP$	SUB.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SWAP.W	D4	CALL	DBOXPHMOVE	; dplace la scroll-liste ...	JUMP,EQ LOOP$	LOAD.L	A5,#(A6)+OSLVAR2	TEST.W	(A5)+OSLCYN	JUMP,EQ BIP$	SCROLL_	LMOVE		; dplace la scroll-liste ...	JUMP,NE BIP$	JUMP'	SELECT$SELECTSK$:	LOAD.L	A2,#R16"TDBOX_CHANGE	CALL	DBOXRSK		; refait les soft-keysSELECT$:	LOAD.L	A5,#(A6)+OSLVAR2	TEST.W	(A5)+OSLCYN	JUMP',EQ SELECT5$	LOAD.L	A3,#(A6)+OMMTRI	LOAD.W	D3,(A5)+OSLCYS	MUL.WU	D3,#LGMM	ADD.L	A3,D3	LOAD.W	D2,#2^BDBGCLABEL!200	DBOX_	GETCO	LOAD.W	D4,(A3)+OMMDEG	TEST.B	(A3)	JUMP',NE SELECT1$	LOAD.W	D4,#-1SELECT1$:	CALL	AFICONE		; affiche l'icne du degr d'exactitude	LOAD.L	A4,#(A6)+OBUMOTSELECT2$:	LOAD.B	(A4+),(A3+)	JUMP,NE SELECT2$	DEC.L	A4	LOAD.L	A3,#(A6)+OBUMOT	JUMP	LOOP$SELECT5$:	LOAD.L	A4,#(A6)+OBUMOTSELECT6$:	TEST.B	(A4+)	JUMP,NE SELECT6$	DEC.L	A4	LOAD.L	A3,#(A6)+OBUMOT	JUMP	LOOP$CHOIX$:				; CONSERVE-CHOIX =>	CALL	DICOCHOIX	; A3 <-- ^dans OTADL	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE SELECTSK$	LOAD.L	(A6)+OCHPDL,A3	; OCHPDL <-- ^dans OTADLDICO$:				; CONSERVE-DICO =>	TEST.L	(A6)+OCHPDL	JUMP,EQ BIP$	LOAD.L	A3,(A6)+OCHPDL	; A3 <-- ^dans OTADL	SET.B	(A3)+ODLMAJ	LOAD.L	A4,(A3)+ODLPT	; A4 <-- ^dictionnaire	LOAD.L	A2,A3		; A2 <-- ^dans OTADL	LOAD.L	A3,(A6)+OSRCPM	; A3 <-- ^mot faux  ajouter	LOAD.L	D3,(A6)+OSRCLM	; D3 <-- lg mot faux  ajouter	CALL	CODEDIAL	; demande le codage ...	JUMP,NE ERROR$	COMP.W	D4,#F1	JUMP,NE SELECTSK$	CALL	DICOADD		; ajoute dans le dictionnaire	JUMP,NE ERROR$	LOAD.W	D3,#F8	JUMP	END1$TEMP$:				; CONSERVE-TEMP =>	LOAD.L	A4,(A6)+OTADL+(MAXDL*LDL)+ODLPT	LOAD.L	D3,A4	JUMP,EQ BIP$	LOAD.L	A3,(A6)+OSRCPM	; A3 <-- ^mot faux  ajouter	LOAD.L	D3,(A6)+OSRCLM	; D3 <-- lg mot faux  ajouter	CALL	DICOADD		; ajoute dans le dictionnaire temporaire	JUMP,NE ERROR$	LOAD.W	D3,#F9	JUMP	END1$END$:	TEST.B	(A3)		; mot de remplacement existe ?	JUMP,EQ BIP$		; non => BIP$END1$:	LOAD.L	A4,#(A6)+OBUMOT	; A4 <-- ^mot juste	LOAD.L	A3,A4	LOAD.L	D4,#-1END2$:	INC.L	D4		; D4 <-- lg du mot juste	TEST.B	(A3+)	JUMP,NE END2$	DBOX_	CLOSE		; ferme la DBOXEXIT$:	CALL	DBCHFSTOP	; stoppe le processus fils	POPM.L	D0..D2,D5,D6,A0..A3,A5,A6	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBCHGREY >;---------/; Grise ou dgrise quelques touches.; in	A3.L	^nom en dition; out	; mod	DBCHGREY:	PUSHM.L	D0..D4,A3,A4	CLR.W	D0		; D0 <-- rien n'est suppos gris	TEST.B	(A3)		; nom existe ?	JUMP',EQ 25$		; non => 25$	LOAD.L	A4,(A6)+OSRCPM	LOAD.L	D4,(A6)+OSRCLM20$:	DEC.L	D4	JUMP',NS 24$	COMP.B	(A4+),(A3+)	JUMP,EQ 20$	JUMP'	26$24$:	TEST.B	(A3)	JUMP',NE 26$25$:	TSET.L	D0:#1		; D0 <-- (REMPLACE) gris	TSET.L	D0:#2		; D0 <-- (TOUT) gris26$:	OR.W	D0,(A6)+OCHKGP	; D0 <-- touches grises en permanance	LOAD.W	D1,(A6)+OCHKGR	LOAD.W	(A6)+OCHKGR,D0	XOR.W	D1,D0		; D1 <-- changements	LOAD.W	D2,#2^BDBGCLABEL!140$:	RR.W	D0,#1	RR.W	D1,#1	TEST.L	D1:#0		; changement d'tat ?	JUMP',BC 44$		; non => 44$	TSET.L	D2:#BDBGCFULL	TEST.L	D0:#0	JUMP',BC 42$	TCLR.L	D2:#BDBGCFULL	TSET.L	D2:#BDBGCGREY42$:	DBOX_	GETCO		; grise/dgrise une touche	TCLR.L	D2:#BDBGCFULL	TCLR.L	D2:#BDBGCGREY44$:	INC.W	D2	COMP.W	D2,#2^BDBGCLABEL!3	JUMP,LS 40$	POPM.L	D0..D4,A3,A4	RET;----------\\; DBCHFSTOP >;----------/; Stoppe le processus fils.; in	-; out	-; mod	-DBCHFSTOP:	PUSHM.L	D4,D720$:	TEST.B	(A6)+OCHFEX	; processus fils existe ?	JUMP',F 80$		; non => 80$				; oui =>	SET.B	(A6)+OCHFST	; stoppe le processus fils	LOAD.W	D4,#2	NTREL	?DELMS		; attend un peu ...	JUMP	20$80$:	CLR.B	(A6)+OCHFST	POPM.L	D4,D7	RETNFILS1:	.ASCIZ	"DICO_SEARCH"	.EVENPFILS1:	SET.B	(A6)+OCHFEX	; processus fils existe	LOAD.L	A4,(A6)+OSRCPM	LOAD.L	D4,(A6)+OSRCLM	CALL	SEARCHALL	; cherche et trie tous les mots possibles ...	TEST.B	(A6)+OCHFST	; processus fils stopp ?	JUMP',T 90$		; oui => 90$	LOAD.L	D3,#KEYDBOX+1	LIB	?WRKEY		; signal la fin de la recherche90$:	CLR.B	(A6)+OCHFEX	; processus fils termin	NTREL	?ABORTTDBOX_CHANGE:	.W	10$-TDBOX_CHANGE	.W	20$-TDBOX_CHANGE	.W	0,010$:	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR,ODBCR	; scroll-liste de 3 lignes	.B	ODBTABX,67	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	" A remplacer par "	.B	ODBXLINE,26+2,26+2,2^(13-8),0,0,TDBNORM	.B	ODBTEXT	.ASCIZ	" "	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBLABEL,102	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	; scroll-liste de 7 lignes	.B	ODBTABX,67	.B	ODBLABEL,103	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBLABEL,1	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" REMPLACE "	.B	ODBLABEL,2	.B	ODBBOX,0,F3,TDBMEV	.ASCIZ	" TOUT "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" PASSE "	.B	ODBTABX,32	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	"CHOIX"	.B	ODBTEXT	.ASCIZ	"Conserve"	.B	ODBBOX,0,F8,TDBNORM	.ASCIZ	"DICO"	.B	ODBTABX,32+21	.B	ODBBOX,0,F9,TDBNORM	.ASCIZ	"TEMP"	.B	ODBLABEL,202	.B	ODBTEXT,0	.B	ODBLABEL,3	.B	ODBBOX,0,F10,TDBNORM	.ASCIZ	"STOPPE"	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	"Remplace:"	.ASCIZ	"  Un        Tout "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Passe"		;     ;     ;     ;	.ASCIZ	"Conserve:"	.ASCIZ	"Choix  Dico Temp "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Stoppe"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_CHANGE:	.W	F1,0			DOKF1-TKEY_CHANGE	.W	F3,0			DOKF3-TKEY_CHANGE	.W	F4,F5,F6,0		DOKF4-TKEY_CHANGE	.W	F7,0			DOKF7-TKEY_CHANGE	.W	F8,0			DOKF8-TKEY_CHANGE	.W	F9,0			DOKF9-TKEY_CHANGE	.W	F10,F11,F12,0		DOKF10-TKEY_CHANGE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_CHANGE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CHANGE	.W	0;---------\\; DBJUSLTX >;---------/; Donne le texte allant dans la scroll-liste des propositions.; in	A6.32	^vos variables;	D3.16	rang de la case (0..OSLCYN-1); out	D3.16	zro	-->	rien;		un	-->	ligne pointille horizontale en bas de la case;		deux	-->	ligne pleine horizontale en bas de la case;		trois	-->	ligne double horizontale en bas de la case;	A3.32	^contenu de la case termin par <0> ou <CR>;	D7.16	erreur si la case est vide; mod	D3.32, D7.16, A3.32DBJUSLTX:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OSLTXT	LOAD.L	A3,#(A6)+OMMTRI	MUL.WU	D3,#LGMM	ADD.L	A3,D3	LOAD.B	D3,(A3)+OMMTYP	; D3 <-- type	LOAD.W	D4,(A3)+OMMFOR	; D4 <-- forme;	LOAD.L	A3,#(A3)+OMMMOT	; A3 <-- ^mot	CALL	GETTXMOT	; OSLTXT <-- ligne  afficher	LOAD.L	A3,A4		; A3 <-- ^texte	LOAD.W	D3,#2		; D3 <-- ligne pointille	POPM.L	D4,A4	CLR.W	D7		; D7 <-- ok	RET;----------\\; _DICO_ADD >;==========/; Ajoute un mot dans un dictionnaire priv.; in	D6.L	canal;	A4/D4.L	^mot  ajouter/lg; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.W_DICO_ADD:	PUSHM.L	D4,D5,A0..A6	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	A0,A4	LIB	?GETPDIS	EX.L	A0,A4		; A0 <-- ^descripteur fentre	TEST.B	(A6)+OADNVE	; vrification inutile ?	JUMP',T 30$		; oui => 30$	LOAD.L	A3,A4	LOAD.L	D3,D4	CALL	_DICO_JUSTE	; est-ce que le mot existe dj ?	JUMP',NE 30$		; non => 30$	LOAD.W	D3,#BIPERR	LIB	?BEEP	LOAD.L	A3,#R16"TERR$	LOAD.W	D2,#2^BDBSAV	DBOX_	TERROR	JUMP	90$30$:	LOAD.L	A5,A4	LOAD.L	D5,D4	CALL	DICOCHOIX	; A3 <-- ^dans OTADL	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	SET.B	(A3)+ODLMAJ	LOAD.L	A4,(A3)+ODLPT	; A4 <-- ^dictionnaire	LOAD.L	A2,A3		; A2 <-- ^dans OTADL	LOAD.L	A3,A5		; A3 <-- ^mot faux  ajouter	LOAD.L	D3,D5		; D3 <-- lg mot faux  ajouter	CALL	CODEDIAL	; demande le codage ...	JUMP',NE 90$	COMP.W	D4,#F1	JUMP',NE 80$	CALL	DICOADD		; ajoute dans le dictionnaire	JUMP',NE 90$	LOAD.W	D4,#F180$:	LOAD.W	D3,D490$:	POPM.L	D4,D5,A0..A6	TEST.W	D7		; retour EQ/NE	RETTERR$:	.ASCII	"Ce mot existe dj<CR>"	.ASCIZ	"dans un dictionnaire !"	.EVEN;----------\\; DICOCHOIX >;----------/; Demande le nom du dictionnaire priv  utiliser.; in	-; out	D3.L	dernire touche presse (F1/F0);	A3.L	^dans OTADL;	D7.W	erreur; mod	D3.L, D7.W, A3.LDICOCHOIX:	PUSHM.L	D0..D2,D4,D5,A1,A2,A4,A5	LOAD.L	A2,#R16"TDBOX_DICOCHOIX	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,#B'01	; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.L	D0,D4	LOAD.L	A5,#(A6)+OSLVAR3	SET.B	(A5)+OSLVID	LOAD.L	A3,#R16"VIDE$	LOAD.W	D2,#2^BDBGCLABEL!100	CALL	DBOXSLDRAW	; dessine le pourtour de la scroll-liste	LOAD.L	A4,#R16"DBDCSLTX	LOAD.L	(A5)+OSLADL,A4	LOAD.W	(A5)+OSLCYS,(A6)+OADLDI	CALL	DICONB	LOAD.W	(A5)+OSLCYN,D4	JUMP',NE SL4$	LOAD.W	(A5)+OSLCYS,#-1SL4$:	SCROLL_	LUPDATE		; dessine le contenu de la scroll-liste	CLR.B	(A6)+OBUNOMCHANGE$:	TEST.W	(A5)+OSLCYS	JUMP,NS CHANGE4$	LOAD.W	D2,#2^BDBGCLABEL!2	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#R16"TF1S$	LIB	?AFTEXT	LOAD.L	A3,#(A6)+OTADL	LOAD.W	D3,(A5)+OSLCYS	MUL.WU	D3,#LDL	ADD.L	A3,D3		; A3 <-- ^dans OTADL	LOAD.L	A4,(A3)+ODLPT	COMP.B	(A4)+LDU,#'*	; dictionnaire encod ?	JUMP',EQ CHANGE2$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!10	DBOX_	GETCO	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!11	DBOX_	GETCO	LOAD.B	D0,#B'01	JUMP'	CHANGE3$CHANGE2$:	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!10	DBOX_	GETCO	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!11	DBOX_	GETCO	LOAD.B	D0,#B'10CHANGE3$:	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!0	DBOX_	GETCO	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!1	DBOX_	GETCO	LOAD.W	D3,#-1	DBOX_	MEDIT	JUMP'	LOOP$CHANGE4$:	LOAD.W	D2,#2^BDBGCLABEL!2	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#R16"TF1C$	LIB	?AFTEXT	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!10	DBOX_	GETCO	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!11	DBOX_	GETCO	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!0	DBOX_	GETCO	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!1	DBOX_	GETCO	LOAD.L	A3,#(A6)+OBUNOM	LOAD.L	A4,A3CHANGE5$:	LOAD.B	D3,(A4+)	JUMP',EQ CHANGE6$	COMP.B	D3,#'.	JUMP,NE CHANGE5$CHANGE6$:	CLR.B	(-A4)	CLR.W	D3	DBOX_	MEDITLOOP$:	LOAD.L	D4,D0	DBOX_	EDIT		; attend une action ...	LOAD.L	D0,D4	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_DICOCHOIX	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#F1	JUMP,EQ END$	COMP.W	D3,#F0	JUMP,EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ERROR$:	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP	POP.W	D7	LOAD.W	D2,#2^BDBSAV	DBOX_	MERROR		; affiche l'erreur ...	JUMP	CHANGE$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$CLIC$:	LIB	?IFMOUSE	JUMP,NE BIP$	SUB.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SWAP.W	D4	SCROLL_	LMOVE		; dplace la scroll-liste ...	JUMP,NE BIP$	JUMP	CHANGE$END$:	LOAD.W	D3,(A5)+OSLCYS	JUMP',NS END2$	LOAD.W	(A6)+OADLDI,D3	LOAD.L	A3,#(A6)+OTADL	MUL.WU	D3,#LDL	ADD.L	A3,D3		; A3 <-- ^dans OTADL	JUMP	END9$END2$:	TEST.B	(A3)		; nom existe ?	JUMP,EQ BIP$		; non => BIP$	LOAD.L	A4,A3END3$:	LOAD.B	D3,(A4)	JUMP',EQ END5$	CALL	MINMAJ	COMP.B	D3,#'_	JUMP',EQ END4$	COMP.B	D3,#'0	JUMP,LO BIP$	COMP.B	D3,#'9	JUMP',LS END4$	COMP.B	D3,#'A	JUMP,LO BIP$	COMP.B	D3,#'Z	JUMP,HI BIP$END4$:	LOAD.B	(A4+),D3	; met le nom en majuscules	JUMP	END3$END5$:	LOAD.L	A4,#R16"EXT$	LOAD.W	D3,#1	LIB	?ADDEXT		; force ".PDICO"	CALL	DICOCREATE	; A3 <-- ^dans OTADL	JUMP,NE ERROR$	TEST.L	D0:#1		; dictionnaire encod ?	JUMP',BC END7$		; non => END7$	PUSH.L	A3	LOAD.L	A4,(A3)+ODLPT	; A4 <-- ^dictionnaire	LOAD.L	A3,#R16"TDCOD$	LOAD.L	D3,#1	CALL	DICOADD		; met "*" dans premire ligne !	POP.L	A3END7$:	CALL	DICONB	DEC.W	D4	LOAD.W	(A6)+OADLDI,D4END9$:	LOAD.W	D3,#F1CANCEL$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RETVIDE$:	.ASCIZ	"<'<>nouveau<'>>"TF1S$:	.ASCIZ	"  CHOIX  "TF1C$:	.ASCIZ	"  CREE   "EXT$:	.ASCIZ	".PDICO"TDCOD$:	.ASCIZ	"*"	.EVENTDBOX_DICOCHOIX:	.W	10$-TDBOX_DICOCHOIX	.W	20$-TDBOX_DICOCHOIX	.W	0,010$:	.B	ODBTEXT	.ASCIZ	" Choix du dictionnaire priv  utiliser :"	.B	ODBCR,ODBCR	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBTABX,22-3	.B	ODBTEXT	.ASCIZ	"-<'>>"	.B	ODBTABX,22	.B	ODBLABEL,0	.B	ODBFILE,9+2	.B	ODBTABX,22+9+2+1	.B	ODBLABEL,1	.B	ODBBOX,0,0,TDBNORM	.ASCIZ	".PDICO"	.B	ODBCR,ODBCR	.B	ODBTABX,22+1	.B	ODBLABEL,10	.B	ODBLCIRCLE,0	.ASCIZ	" mots simples"	.B	ODBCR	.B	ODBTABX,22+1	.B	ODBLABEL,11	.B	ODBLCIRCLE,1	.ASCIZ	" mots encods"	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,22-4	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR	.B	ODBLABEL,2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"         "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Choix"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DICOCHOIX:	.W	F1,F2,F3,0		DOKF1-TKEY_DICOCHOIX	.W	F0,F13,F14,F15,0	DOKF0-TKEY_DICOCHOIX	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_DICOCHOIX	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DICOCHOIX	.W	0;---------\\; DBDCSLTX >;---------/; Donne le texte allant dans la scroll-liste.; in	A6.32	^vos variables;	D3.16	rang de la case (0..OSLCYN-1); out	D3.16	zro	-->	rien;		un	-->	ligne pointille horizontale en bas de la case;		deux	-->	ligne pleine horizontale en bas de la case;		trois	-->	ligne double horizontale en bas de la case;	A3.32	^contenu de la case termin par <0> ou <CR>;	D7.16	erreur si la case est vide; mod	D3.32, D7.16, A3.32DBDCSLTX:	LOAD.L	A3,#(A6)+OTADL	MUL.WU	D3,#LDL	ADD.L	A3,D3		; A3 <-- ^dans OTADL	LOAD.L	A3,#(A3)+ODLNOM	; A3 <-- ^nom	CLR.W	D3		; D3 <-- rien	CLR.W	D7		; D7 <-- ok	RET;-----------\\; _DICO_CONJ >;===========/; Conjugue une forme verbale.; in	D6.L	canal;	A4/D4.L	^forme verbale/lg; out	D3.L	dernire touche presse (F1/F0);	A4/D4.L	^autre forme/lg;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.L_DICO_CONJ:	PUSHM.L	D0..D2,D5,D6,A0..A3,A5,A6	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	A0,A4	LIB	?GETPDIS	EX.L	A0,A4		; A0 <-- ^descripteur fentre	PUSH.L	(A6)+ODFFAN	LOAD.L	(A6)+ODFFAN,#-1	PUSH.L	D4	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	POP.L	D4	COMP.L	D4,#LGMOT/2	; trop long ?	JUMP,HS ERRFM$		; oui => ERRFM$	LOAD.L	A3,A4	LOAD.L	D3,D4	CALL	JUSTEIFMANY	; y a-t-il un seul mot ?	JUMP,NE ERRFM$		; non => ERRFM$	CLR.W	D1		; D1 <-- rien trouv	LOAD.W	D2,#2		; D2 <-- deux lettres de sres	CALL	SEARCHINIT	; initialise pour la recherche	JUMP,NE ERRFX$SRC1$:	CLR.W	D2		; D2 <-- accepte seulement si exact	CLR.B	(A6)+OCHFST	; ne stoppe pas	CALL	SEARCHNEXT	JUMP,NE ERRFX$	INC.W	D1		; D1 <-- trouv qq chose	COMP.B	D3,#'t		; verbe ?	JUMP',EQ SRC3$		; oui => SRC3$	COMP.B	D3,#'i	JUMP',EQ SRC3$	COMP.B	D3,#'u	JUMP',EQ SRC3$	COMP.B	D3,#'r	JUMP',EQ SRC3$	COMP.B	D3,#'1	JUMP',EQ SRC3$	COMP.B	D3,#'2	JUMP',EQ SRC3$	COMP.B	D3,#'h	JUMP',EQ SRC3$	COMP.B	D3,#'v	JUMP',EQ SRC3$	COMP.B	D3,#'7	JUMP',EQ SRC3$	JUMP	SRC1$SRC3$:	LOAD.L	D0,#2^BCJINF	CLR.L	D4	LOAD.W	D4,(A6)+OSRCNM	DEC.W	D4	JUMP,EQ SRC8$	DEC.W	D4	DIV.WU	D4,#6		; D4 <-- temps (0..8)	LOAD.L	D0,#2^BCJPRES	DEC.W	D4	JUMP',NS SRC4$	LOAD.L	D0,#2^BCJIMP	DEC.W	D4	JUMP',NS SRC4$	LOAD.L	D0,#2^BCJPASS	DEC.W	D4	JUMP',NS SRC4$	LOAD.L	D0,#2^BCJFUT	DEC.W	D4	JUMP',NS SRC4$	LOAD.L	D0,#2^BCJSPRES	DEC.W	D4	JUMP',NS SRC4$	LOAD.L	D0,#2^BCJSIMP	DEC.W	D4	JUMP',NS SRC4$	LOAD.L	D0,#2^BCJCPRES	DEC.W	D4	JUMP',NS SRC4$	LOAD.L	D0,#2^BCJIPRES	DEC.W	D4	JUMP',NS SRC8$	LOAD.L	D0,#2^BCJPPRES	SWAP.W	D4	DEC.W	D4	JUMP',NS SRC8$	LOAD.L	D0,#2^BCJPPASS	SWAP.W	D4SRC4$:	SWAP.W	D4		; D4 <-- forme (0..5)	TSET.L	D0:D4SRC8$:	LOAD.L	A2,#R16"TDBOX_CONJ	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,D0		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!101	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OSRCM0	LIB	?AFTEXT		; affiche la forme initiale	LOAD.W	D2,#2^BDBGCLABEL!100	DBOX_	GETCO	LIB	?SETCURS	CLR.W	D4	LOAD.L	A3,#(A6)+OBUMOT	LOAD.L	A4,#(A6)+OSRCMD	CALL	SEARCHMOT	; OBUMOT <-- forme verbale en clair	LIB	?AFTEXT		; affiche l'infinitif du verbe	LOAD.W	D4,#1	LOAD.L	A3,#(A6)+OBUMOT	LOAD.L	A4,#(A6)+OSRCMD	CALL	SEARCHMOT	; ncessaire pour initialiser OCJxx !	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	JUMP	FG$ERRFM$:	LOAD.L	A3,#R16"TERRM$	JUMP'	ERRFX2$ERRFX$:	LOAD.L	A3,#R16"TERR1$	TEST.W	D1	JUMP',EQ ERRFX2$	LOAD.L	A3,#R16"TERR2$ERRFX2$:	LOAD.W	D3,#BIPERR	LIB	?BEEP	LOAD.W	D2,#2^BDBSAV	DBOX_	TERROR	JUMP	EXIT$LOOP$:	LOAD.L	D4,D0	DBOX_	EDIT		; attend une action ...	LOAD.L	D0,D4	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_CONJ	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#F1	JUMP,EQ END$	COMP.W	D3,#F0	JUMP,EQ END$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$KEYDBOX$:	COMP.B	D3,#8	JUMP',HS TEMPS$	CLR.B	D0	TSET.L	D0:D3	JUMP	SELECT$TEMPS$:	AND.L	D0,#H'000000FF	TSET.L	D0:D3FG$:	LOAD.L	A3,#R16"TIMP$	LOAD.B	D1,#B'110010	LOAD.B	D2,#B'000010	TEST.L	D0:#BCJIPRES	JUMP',BS FG1$	LOAD.L	A3,#R16"TPART$	LOAD.B	D1,#B'001111	LOAD.B	D2,#B'000001	TEST.L	D0:#BCJPPASS	JUMP',BS FG1$	LOAD.L	A3,#R16"TRIEN$	LOAD.B	D1,#B'000000	LOAD.B	D2,#B'000000	TEST.L	D0:#BCJINF	JUMP',BS FG1$	TEST.L	D0:#BCJPPRES	JUMP',BS FG1$	LOAD.L	A3,#R16"TNORM$	LOAD.B	D1,#B'111111	LOAD.B	D2,#B'000001FG1$:	AND.B	D0,D1	JUMP',NE FG11$	OR.B	D0,D2FG11$:	LOAD.W	D1,#2^BDBGCLABEL!BCJF1FG2$:	COMP.B	(A3),#SPACE	JUMP',EQ FG4$				; dgrise =>	LOAD.W	D2,D1	TSET.L	D2:#BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,D1	DBOX_	GETCO		; D3 <-- position	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	LIB	?SETCURS	LIB	?AFTEXT		; affiche le texte	JUMP'	FG8$FG4$:				; grise =>	LOAD.W	D2,D1	DBOX_	GETCO		; D3 <-- position	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	LIB	?SETCURS	LIB	?AFTEXT		; affiche le texte	LOAD.W	D2,D1	TSET.L	D2:#BDBGCGREY	DBOX_	GETCOFG8$:	INC.W	D1	COMP.W	D1,#2^BDBGCLABEL!BCJF6	JUMP,LS FG2$SELECT$:	CLR.W	D4	TEST.L	D0:#BCJINF	JUMP,BS SELECT4$	LOAD.W	D4,#1+(6*8)	TEST.L	D0:#BCJPPRES	JUMP,BS SELECT4$	CLR.W	D4	LOAD.B	D1,D0	JUMP',EQ SELECT2$	DEC.W	D4SELECT1$:	INC.W	D4	SR.B	D1,#1	JUMP,CC SELECT1$SELECT2$:	LOAD.W	D1,#1+(6*0)	TEST.L	D0:#BCJPRES	JUMP',BS SELECT3$	LOAD.W	D1,#1+(6*1)	TEST.L	D0:#BCJIMP	JUMP',BS SELECT3$	LOAD.W	D1,#1+(6*2)	TEST.L	D0:#BCJPASS	JUMP',BS SELECT3$	LOAD.W	D1,#1+(6*3)	TEST.L	D0:#BCJFUT	JUMP',BS SELECT3$	LOAD.W	D1,#1+(6*4)	TEST.L	D0:#BCJSPRES	JUMP',BS SELECT3$	LOAD.W	D1,#1+(6*5)	TEST.L	D0:#BCJSIMP	JUMP',BS SELECT3$	LOAD.W	D1,#1+(6*6)	TEST.L	D0:#BCJCPRES	JUMP',BS SELECT3$	LOAD.W	D1,#1+(6*7)	TEST.L	D0:#BCJIPRES	JUMP',BS SELECT3$	LOAD.W	D1,#1+(6*8)+1	TEST.L	D0:#BCJPPASS;	JUMP',BS SELECT3$SELECT3$:	ADD.W	D4,D1SELECT4$:	LOAD.L	A3,#(A6)+OBUMOT	LOAD.L	A4,#(A6)+OSRCMD	CALL	SEARCHMOT	; OBUMOT <-- forme verbale en clair	JUMP',NE SELECT8$	LOAD.L	A4,A3SELECT5$:	TEST.B	(A4+)	JUMP,NE SELECT5$	DEC.L	A4	JUMP	LOOP$SELECT8$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$END$:	LOAD.L	A4,#(A6)+OBUMOT	; A4 <-- ^mot juste	LOAD.L	A3,A4	LOAD.L	D4,#-1END2$:	INC.L	D4		; D4 <-- lg du mot juste	TEST.B	(A3+)	JUMP,NE END2$	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POP.L	(A6)+ODFFAN	POPM.L	D0..D2,D5,D6,A0..A3,A5,A6	TEST.W	D7		; retour EQ/NE	RETTERR1$:	.ASCIZ	"Ce mot est mal orthographi !"TERR2$:	.ASCIZ	"Ce n'est pas une forme verbale !"TERRM$:	.ASCII	"Il ne faut conjuguer qu'un<CR>"	.ASCIZ	"seul mot  la fois !"TNORM$:	.ASCIZ	"je       "	.ASCIZ	"tu       "	.ASCIZ	"il/elle  "	.ASCIZ	"ils/elles"	.ASCIZ	"nous     "	.ASCIZ	"vous     "TIMP$:	.ASCIZ	"         "	.ASCIZ	"(tu)     "	.ASCIZ	"         "	.ASCIZ	"         "	.ASCIZ	"(nous)   "	.ASCIZ	"(vous)   "TPART$:	.ASCIZ	"masc. s. "	.ASCIZ	"masc. pl."	.ASCIZ	"fm.  s. "	.ASCIZ	"fm.  pl."	.ASCIZ	"         "	.ASCIZ	"         "TRIEN$:	.ASCIZ	"         "	.ASCIZ	"         "	.ASCIZ	"         "	.ASCIZ	"         "	.ASCIZ	"         "	.ASCIZ	"         "	.EVENTDBOX_CONJ:	.W	10$-TDBOX_CONJ	.W	20$-TDBOX_CONJ	.W	0,010$:	.B	ODBTEXT	.ASCIZ	" Infinitif       "	.B	ODBLABEL,100	.B	ODBBOX,0,0,TDBOMBRE	.ASCIZ	"                            "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	" Forme initiale  "	.B	ODBLABEL,101	.B	ODBBOX,0,0,TDBNORM	.ASCIZ	"                            "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	" A remplacer par "	.B	ODBCLINE,26+2	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Indicatif:"	.B	ODBTABX,17	.B	ODBTEXT	.ASCIZ	"Subjonctif:"	.B	ODBTABX,32	.B	ODBTEXT	.ASCIZ	"Conditionnel:"	.B	ODBTABX,50	.B	ODBTEXT	.ASCIZ	"Personne:"	.B	ODBCR	.B	ODBLCIRCLE,BCJPRES!2^7!2^6,KEYDBOX/H'100,BCJPRES	.ASCIZ	" prsent"	.B	ODBTABX,17	.B	ODBLCIRCLE,BCJSPRES!2^7!2^6,KEYDBOX/H'100,BCJSPRES	.ASCIZ	" prsent"	.B	ODBTABX,32	.B	ODBLCIRCLE,BCJCPRES!2^7!2^6,KEYDBOX/H'100,BCJCPRES	.ASCIZ	" prsent"	.B	ODBTABX,50	.B	ODBLABEL,BCJF1	.B	ODBLCIRCLE,BCJF1!2^7!2^6,KEYDBOX/H'100,BCJF1	.ASCIZ	"          "	.B	ODBCR	.B	ODBLCIRCLE,BCJIMP!2^7!2^6,KEYDBOX/H'100,BCJIMP	.ASCIZ	" imparfait"	.B	ODBTABX,17	.B	ODBLCIRCLE,BCJSIMP!2^7!2^6,KEYDBOX/H'100,BCJSIMP	.ASCIZ	" imparfait"	.B	ODBTABX,50	.B	ODBLABEL,BCJF2	.B	ODBLCIRCLE,BCJF2!2^7!2^6,KEYDBOX/H'100,BCJF2	.ASCIZ	"          "	.B	ODBCR	.B	ODBLCIRCLE,BCJPASS!2^7!2^6,KEYDBOX/H'100,BCJPASS	.ASCIZ	" pass simple"	.B	ODBTABX,32	.B	ODBTEXT	.ASCIZ	"Participe:"	.B	ODBTABX,50	.B	ODBLABEL,BCJF3	.B	ODBLCIRCLE,BCJF3!2^7!2^6,KEYDBOX/H'100,BCJF3	.ASCIZ	"          "	.B	ODBCR	.B	ODBLCIRCLE,BCJFUT!2^7!2^6,KEYDBOX/H'100,BCJFUT	.ASCIZ	" futur simple"	.B	ODBTABX,17	.B	ODBTEXT	.ASCIZ	"Impratif:"	.B	ODBTABX,32	.B	ODBLCIRCLE,BCJPPRES!2^7!2^6,KEYDBOX/H'100,BCJPPRES	.ASCIZ	" prsent"	.B	ODBTABX,50	.B	ODBLABEL,BCJF4	.B	ODBLCIRCLE,BCJF4!2^7!2^6,KEYDBOX/H'100,BCJF4	.ASCIZ	"          "	.B	ODBCR	.B	ODBTABX,17	.B	ODBLCIRCLE,BCJIPRES!2^7!2^6,KEYDBOX/H'100,BCJIPRES	.ASCIZ	" prsent"	.B	ODBTABX,32	.B	ODBLCIRCLE,BCJPPASS!2^7!2^6,KEYDBOX/H'100,BCJPPASS	.ASCIZ	" pass"	.B	ODBTABX,50	.B	ODBLABEL,BCJF5	.B	ODBLCIRCLE,BCJF5!2^7!2^6,KEYDBOX/H'100,BCJF5	.ASCIZ	"          "	.B	ODBCR	.B	ODBTABX,50	.B	ODBLABEL,BCJF6	.B	ODBLCIRCLE,BCJF6!2^7!2^6,KEYDBOX/H'100,BCJF6	.ASCIZ	"          "	.B	ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" REMPLACE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,32	.B	ODBLCIRCLE,BCJINF!2^7!2^6,KEYDBOX/H'100,BCJINF	.ASCIZ	" infinitif"	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Remplace"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CONJ:	.W	F1,F2,F3,0		DOKF1-TKEY_CONJ	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CONJ	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CONJ	.W	0;-------------\\; _DICO_ACCORD >;=============/; Accorde un nom ou un adjectif.; in	D6.L	canal;	A4/D4.L	^forme verbale/lg; out	D3.L	dernire touche presse (F1/F4/F7/F10);	A4/D4.L	^autre forme/lg;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.L_DICO_ACCORD:	PUSHM.L	D0..D2,D5,D6,A0..A3,A5,A6	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	A0,A4	LIB	?GETPDIS	EX.L	A0,A4		; A0 <-- ^descripteur fentre	PUSH.L	D4	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	POP.L	D4	COMP.L	D4,#LGMOT/2	; trop long ?	JUMP,HS ERRFM$		; oui => ERRFM$	LOAD.L	A3,A4	LOAD.L	D3,D4	CALL	JUSTEIFMANY	; y a-t-il un seul mot ?	JUMP,NE ERRFM$		; non => ERRFM$	CLR.L	D1		; D1 <-- rien trouv	LOAD.W	D2,#2		; D2 <-- deux lettres de sres	CALL	SEARCHINIT	; initialise pour la recherche	JUMP,NE ERRFX$	JUMP'	SRC2$SRC1v$:	TSET.L	D1:#16		; D1 <-- verbe	JUMP'	SRC2$SRC1i$:	TSET.L	D1:#17		; D1 <-- invariable;	JUMP'	SRC2$SRC2$:	CLR.W	D2		; D2 <-- accepte seulement si exact	CLR.B	(A6)+OCHFST	; ne stoppe pas	CALL	SEARCHNEXT	JUMP,NE ERRFX$	INC.W	D1		; D1 <-- trouv qq chose	COMP.B	D3,#'t		; verbe ?	JUMP,EQ SRC1v$		; oui => SRC1v$	COMP.B	D3,#'i	JUMP,EQ SRC1v$	COMP.B	D3,#'u	JUMP,EQ SRC1v$	COMP.B	D3,#'r	JUMP,EQ SRC1v$	COMP.B	D3,#'1	JUMP,EQ SRC1v$	COMP.B	D3,#'2	JUMP,EQ SRC1v$	COMP.B	D3,#'h	JUMP,EQ SRC1v$	COMP.B	D3,#'v	JUMP,EQ SRC1v$	COMP.B	D3,#'7	JUMP,EQ SRC1v$	COMP.B	D3,#'4		; mon invariable ?	JUMP,EQ SRC1i$		; oui => SRC1i$	COMP.B	D3,#'q	JUMP,EQ SRC1i$	COMP.B	D3,#'3	JUMP,EQ SRC1i$	COMP.B	D3,#'5	JUMP,EQ SRC1i$	COMP.B	D3,#'z	JUMP,EQ SRC1i$	COMP.B	D3,#'d	JUMP,EQ SRC1i$	COMP.B	D3,#'6	JUMP,EQ SRC1i$	COMP.B	D3,#'c	JUMP,EQ SRC1i$	COMP.B	D3,#'s	JUMP,EQ SRC1i$	COMP.B	D3,#'j	JUMP,EQ SRC1i$	COMP.B	D3,#'b	JUMP,EQ SRC1i$	COMP.B	D3,#'g	JUMP,EQ SRC1i$	COMP.B	D3,#'l	JUMP,EQ SRC1i$	COMP.B	D3,#'8	JUMP,EQ SRC1i$	COMP.B	D3,#'P	JUMP,EQ SRC1i$	LOAD.W	D4,(A6)+OSRCNM	DEC.W	D4		; D4 <-- rang (0..3)	LOAD.W	D2,D4	CLR.W	D6	LOAD.B	D1,#B'1100	COMP.B	D3,#'m	JUMP,EQ TYPE$	LOAD.W	D6,#2	LOAD.B	D1,#B'0011	COMP.B	D3,#'f	JUMP,EQ TYPE$	CLR.W	D6	LOAD.B	D1,#B'0000	LOAD.L	A3,#(A6)+OBUMOT	LOAD.L	A4,#(A6)+OSRCMD	CLR.W	D4	CALL	SEARCHMOT	; OBUMOT <-- mot accord en clair	JUMP',EQ TYPE0$	TSET.L	D1:D4TYPE0$:	INC.W	D4	CALL	SEARCHMOT	; OBUMOT <-- mot accord en clair	JUMP',EQ TYPE1$	TSET.L	D1:D4TYPE1$:	INC.W	D4	CALL	SEARCHMOT	; OBUMOT <-- mot accord en clair	JUMP',EQ TYPE2$	TSET.L	D1:D4TYPE2$:	INC.W	D4	CALL	SEARCHMOT	; OBUMOT <-- mot accord en clair	JUMP',EQ TYPE3$	TSET.L	D1:D4TYPE3$:	TCLR.L	D1:#16		; D1 <-- pas un verbe	TSET.L	D1:#17		; D1 <-- invariable	COMP.B	D1,#B'0111	JUMP,EQ ERRFX$	COMP.B	D1,#B'1011	JUMP,EQ ERRFX$	COMP.B	D1,#B'1101	JUMP,EQ ERRFX$	COMP.B	D1,#B'1110	JUMP,EQ ERRFX$TYPE$:	ADD.W	D2,D6	CLR.L	D0	TSET.L	D0:D2		; D0 <-- fanions	LOAD.L	A2,#R16"TDBOX_ACCORD	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,D0		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	TEST.L	D1:#0	JUMP',BC GREY1$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!0	DBOX_	GETCOGREY1$:	TEST.L	D1:#1	JUMP',BC GREY2$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!1	DBOX_	GETCOGREY2$:	TEST.L	D1:#2	JUMP',BC GREY3$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!2	DBOX_	GETCOGREY3$:	TEST.L	D1:#3	JUMP',BC GREY4$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!3	DBOX_	GETCOGREY4$:	LOAD.W	D2,#2^BDBGCLABEL!101	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OSRCM0	LIB	?AFTEXT		; affiche le mot initial	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	JUMP	KEYDBOX$ERRFM$:	LOAD.L	A3,#R16"TERRM$	JUMP'	ERRFX2$ERRFX$:	LOAD.L	A3,#R16"TERR1$	TEST.W	D1	JUMP',EQ ERRFX2$	LOAD.L	A3,#R16"TERR2$	TEST.L	D1:#16	JUMP',BS ERRFX2$	LOAD.L	A3,#R16"TERR3$ERRFX2$:	LOAD.W	D3,#BIPERR	LIB	?BEEP	LOAD.W	D2,#2^BDBSAV	DBOX_	TERROR	JUMP	EXIT$LOOP$:	LOAD.L	D4,D0	DBOX_	EDIT		; attend une action ...	LOAD.L	D0,D4	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_ACCORD	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#F1	JUMP,EQ END$	COMP.W	D3,#F0	JUMP,EQ END$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$KEYDBOX$:	CLR.W	D4	LOAD.B	D1,D0	JUMP',EQ KEYDBOX2$	DEC.W	D4KEYDBOX1$:	INC.W	D4	SR.B	D1,#1	JUMP,CC KEYDBOX1$KEYDBOX2$:	SUB.W	D4,D6	LOAD.L	A3,#(A6)+OBUMOT	LOAD.L	A4,#(A6)+OSRCMD	CALL	SEARCHMOT	; OBUMOT <-- mot accord en clair	JUMP',NE SELECT8$	LOAD.L	A3,#(A6)+OBUMOT	LOAD.L	A4,A3SELECT5$:	TEST.B	(A4+)	JUMP,NE SELECT5$	DEC.L	A4	JUMP	LOOP$SELECT8$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$END$:	LOAD.L	A4,#(A6)+OBUMOT	; A4 <-- ^mot juste	LOAD.L	A3,A4	LOAD.L	D4,#-1END2$:	INC.L	D4		; D4 <-- lg du mot juste	TEST.B	(A3+)	JUMP,NE END2$	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,D6,A0..A3,A5,A6	TEST.W	D7		; retour EQ/NE	RETTERR1$:	.ASCIZ	"Ce mot est mal orthographi !"TERR2$:	.ASCIZ	"Il s'agit d'un verbe ou d'une forme verbale !"TERR3$:	.ASCIZ	"Ce mot est invariable !"TERRM$:	.ASCII	"Il ne faut accorder qu'un<CR>"	.ASCIZ	"seul mot  la fois !"	.EVENTDBOX_ACCORD:	.W	10$-TDBOX_ACCORD	.W	20$-TDBOX_ACCORD	.W	0,010$:	.B	ODBTEXT	.ASCIZ	" Mot initial     "	.B	ODBLABEL,101	.B	ODBBOX,0,0,TDBNORM	.ASCIZ	"                            "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	" A remplacer par "	.B	ODBCLINE,26+2	.B	ODBCR,ODBCR,ODBCR	.B	ODBLABEL,0	.B	ODBLCIRCLE,0!2^7,KEYDBOX/H'100,0	.ASCIZ	" masculin singulier"	.B	ODBTABX,25	.B	ODBLABEL,2	.B	ODBLCIRCLE,2!2^7,KEYDBOX/H'100,2	.ASCIZ	" fminin singulier"	.B	ODBCR	.B	ODBLABEL,1	.B	ODBLCIRCLE,1!2^7,KEYDBOX/H'100,1	.ASCIZ	" masculin pluriel"	.B	ODBTABX,25	.B	ODBLABEL,3	.B	ODBLCIRCLE,3!2^7,KEYDBOX/H'100,3	.ASCIZ	" fminin pluriel"	.B	ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" REMPLACE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Remplace"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_ACCORD:	.W	F1,F2,F3,0		DOKF1-TKEY_ACCORD	.W	F0,F13,F14,F15,0	DOKF0-TKEY_ACCORD	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_ACCORD	.W	0;-----------\\; _DICO_SYNO >;===========/; Trouve un synonyme si cela est possible.; in	D6.L	canal;	A4/D4.L	^contexte/lg;	A3/D3.L	^mot/lg; out	D3.L	dernire touche presse (F1/F0);	A4/D4.L	^synonyme/lg;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.L_DICO_SYNO:	PUSHM.L	D0..D2,D5,D6,A0..A3,A5,A6	LOAD.L	A6,D6		; A6 <-- ^variables	COMP.L	A3,A4	JUMP',LO CONTKO$	LOAD.L	A2,#(A4)+(D4.L)	COMP.L	A3,A2	JUMP',HS CONTKO$	LOAD.L	D2,D4	ADD.L	D2,A4	SUB.L	D2,A3	COMP.L	D3,D2	JUMP',LS CONTOK$CONTKO$:	LOAD.L	A3,A4	LOAD.L	D3,D4CONTOK$:	LOAD.L	(A6)+OSRCPP,A4	LOAD.L	(A6)+OSRCLP,D4	LOAD.L	(A6)+OSRCPM,A3	LOAD.L	(A6)+OSRCLM,D3	COMP.L	D3,#LGMOT/2	; trop long ?	JUMP,HS ERRFM$		; oui => ERRFM$	CALL	JUSTEIFMANY	; y a-t-il un seul mot ?	JUMP,NE ERRFM$		; non => ERRFM$	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	CALL	DICO_SOPEN	; charge le dico des synonymes si ncessaire	JUMP,NE EXIT$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A4,(A6)+OSRCPM	LOAD.L	D4,(A6)+OSRCLM	CLR.W	(A6)+OSYBR	CALL	SYNBASE		; cherche le mot de base	JUMP,NE ERROR$	CLR.W	(A6)+OSYRS	LOAD.L	(A6)+OSYPD,(A6)+OSDICO	LOAD.L	A4,#(A6)+OSYBM	LOAD.L	D4,(A6)+OSYBL	CALL	SYNSEARCH	; cherche les synonymes	JUMP,NE ERROR$	LOAD.L	A2,#R16"TDBOX_SYNO	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!204	DBOX_	GETCO	LOAD.W	D1,(A0)+ODFCY	SR.W	D1,#1		; D1 <-- 1/2 interligne	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	SUB.W	D4,D3	SR.W	D4,#1	LOAD.W	D0,D4	ADD.W	D3,D4	SWAP.W	D3	ADD.W	D3,(A0)+ODFC2Y	ADD.W	D3,#3	SWAP.W	D3	LOAD.W	D4,D1	MUL.WU	D4,#4	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	CLR.L	D4	LOAD.W	D4,D0	SUB.W	D4,D1	SUB.W	D4,D1	SUB.W	D4,D1	NEG.W	D4	LIB	?DRSEG	LOAD.L	(A6)+OSYRP,D3	LOAD.W	D4,D1	ADD.W	D4,D1	NEG.W	D4	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	LOAD.W	D4,D1	ADD.W	D4,D1	ADD.W	D4,D1	INC.W	D4	SWAP.W	D4	LOAD.W	D4,D1	ADD.W	D4,D1	ADD.W	D4,D1	INC.W	D4	NEG.W	D4	LIB	?DRSEG	NEG.W	D4	LIB	?DRSEG	LOAD.W	D4,D1	ADD.W	D4,D1	NEG.W	D4	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	CLR.L	D4	LOAD.W	D4,D0	SUB.W	D4,D1	ADD.W	D4,#2	LIB	?DRSEG	LOAD.W	D4,D1	MUL.WU	D4,#4+2	ADD.W	D4,#2+2	NEG.W	D4	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	LOAD.L	A5,#(A6)+OSLVAR1	CLR.B	(A5)+OSLVID	LOAD.W	D2,#2^BDBGCLABEL!100	CALL	DBOXSLDRAW	; dessine le pourtour de la scroll-liste	CALL	DBOXPHDRAW	; affiche la phrase	CALL	DBSYAFBM	; affiche les mots de base	LOAD.L	A5,#(A6)+OSLVAR3	CLR.B	(A5)+OSLVID	LOAD.W	D2,#2^BDBGCLABEL!102	CALL	DBOXSLDRAW	; dessine le pourtour de la scroll-liste	CALL	DBSYSLDR	; dessine le contenu de la scroll-liste	CALL	DBSYDRRS	; dessine le rang des synonymes trouvsLOOP$:	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_SYNO	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ REMP$	COMP.W	D3,#F4	JUMP,EQ NEXT$	COMP.W	D3,#F7	JUMP,EQ AUTRE$	COMP.W	D3,#F0	JUMP,EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$NEXT$:	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.W	D3,(A6)+OSYRS	INC.W	(A6)+OSYRS	LOAD.L	A4,#(A6)+OSYBM	LOAD.L	D4,(A6)+OSYBL	CALL	SYNSEARCH	; cherche les synonymes	JUMP',EQ NEXT2$	CLR.W	(A6)+OSYRS	LOAD.L	(A6)+OSYPD,(A6)+OSDICO	LOAD.L	A4,#(A6)+OSYBM	LOAD.L	D4,(A6)+OSYBL	CALL	SYNSEARCH	; cherche les synonymes	JUMP,NE ERROR$NEXT2$:	CALL	DBSYSLDR	; dessine le contenu de la scroll-liste	CALL	DBSYDRRS	; dessine le rang des synonymes trouvs	COMP.W	D3,(A6)+OSYRS	JUMP,EQ BIP$	JUMP	LOOP$AUTRE$:	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.W	D3,(A6)+OSYBR	INC.W	(A6)+OSYBR	LOAD.L	A4,(A6)+OSRCPM	LOAD.L	D4,(A6)+OSRCLM	CALL	SYNBASE		; cherche le mot de base	JUMP',EQ AUTRE2$	CLR.W	(A6)+OSYBR	CALL	SYNBASE		; cherche le mot de base	JUMP,NE ERROR$AUTRE2$:	COMP.W	D3,(A6)+OSYBR	JUMP',EQ AUTRE4$	CALL	DBSYAFBM	; affiche les mots de base	LOAD.W	(A6)+OSYRS,#-1	LOAD.L	(A6)+OSYPD,(A6)+OSDICO	JUMP	NEXT$AUTRE4$:	CALL	DBSYSLDR	; dessine le contenu de la scroll-liste	JUMP	BIP$CLIC$:	LIB	?IFMOUSE	JUMP,NE BIP$	SUB.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SWAP.W	D4	CALL	DBOXPHMOVE	; dplace la scroll-liste ...	JUMP,EQ LOOP$	SCROLL_	LMOVE		; dplace la scroll-liste ...	JUMP,NE BIP$	JUMP	LOOP$ERROR$:	LOAD.W	D4,D7	AND.W	D4,#H'FF00	COMP.W	D4,#ERHERE	; erreur interne ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.L	A3,#R16"TERR1$	JUMP'	ERRFX2$ERRFM$:	LOAD.L	A3,#R16"TERRM$;	JUMP'	ERRFX2$ERRFX2$:	LOAD.W	D3,#BIPERR	LIB	?BEEP	LOAD.W	D2,#2^BDBSAV	DBOX_	TERROR		; affiche l'erreur interne	JUMP'	EXIT$REMP$:				; (REMPLACE) =>	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A3,(A6)+OSYPL	LOAD.W	D4,(A5)+OSLCYS	MUL.WU	D4,#LGMOT	ADD.L	A3,D4		; A3 <-- ^synonyme choisi	CALL	SYNFORME	; A4/D4 <-- synonyme  la bonne forme	JUMP'	CLOSE$CANCEL$:			; (ANNULE) =>	LOAD.L	A4,(A6)+OSRCPM	LOAD.L	D4,(A6)+OSRCLMCLOSE$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	PUSH.L	A4	TEST.L	(A6)+OSYPL	JUMP',EQ NOMEM$	LOAD.L	A4,(A6)+OSYPL	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancienne liste	CLR.L	(A6)+OSYPLNOMEM$:	POP.L	A4	POPM.L	D0..D2,D5,D6,A0..A3,A5,A6	TEST.W	D7		; retour EQ/NE	RETTERR1$:	.ASCIZ	"Aucun synonyme n'a t trouv !"TERRM$:	.ASCII	"Il faut chercher le synonyme<CR>"	.ASCIZ	"d'un seul mot  la fois !"	.EVENTDBOX_SYNO:	.W	10$-TDBOX_SYNO	.W	20$-TDBOX_SYNO	.W	0,010$:	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR,ODBCR	; scroll-liste de 3 lignes	.B	ODBTABX,30+3+23	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	" Espce       "	.B	ODBLABEL,201	.B	ODBBOX,0,0,TDBNORM	.ASCIZ	"              "	; 14x	.B	ODBTABX,14+14+1	.B	ODBLABEL,202	.B	ODBBOX,0,0,TDBNORM	.ASCIZ	"                          "  ; 36x	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	" Mot de base  "	.B	ODBLABEL,203	.B	ODBBOX,0,0,TDBOMBRE	.ASCIZ	"                              "  ; 30x	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" ESPECE "	.B	ODBCR,ODBCR	.B	ODBLABEL,102	.B	ODBTEXT,0	.B	ODBTABX,30+3	.B	ODBLABEL,204	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	"   AUTRES SYNONYMES   "	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBTABX,30	.B	ODBLABEL,103	.B	ODBTEXT,0	.B	ODBTABX,30+3	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" REMPLACE "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Remplace"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Autres synonymes"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Autre espce"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_SYNO:	.W	F1,F2,F3,0		DOKF1-TKEY_SYNO	.W	F4,F5,F6,0		DOKF4-TKEY_SYNO	.W	F7,F8,F9,0		DOKF7-TKEY_SYNO	.W	F0,F13,F14,F15,0	DOKF0-TKEY_SYNO	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_SYNO	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_SYNO	.W	0;--------------\\; _DICO_FAMILLE >;==============/; Trouve un mot de la mme famille si cela est possible.; in	D6.L	canal;	A4/D4.L	^contexte/lg;	A3/D3.L	^mot/lg; out	D3.L	dernire touche presse (F1/F0);	A4/D4.L	^synonyme/lg;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.L_DICO_FAMILLE:	PUSHM.L	D0..D2,D5,D6,A0..A3,A5,A6	LOAD.L	A6,D6		; A6 <-- ^variables	COMP.L	A3,A4	JUMP',LO CONTKO$	LOAD.L	A2,#(A4)+(D4.L)	COMP.L	A3,A2	JUMP',HS CONTKO$	LOAD.L	D2,D4	ADD.L	D2,A4	SUB.L	D2,A3	COMP.L	D3,D2	JUMP',LS CONTOK$CONTKO$:	LOAD.L	A3,A4	LOAD.L	D3,D4CONTOK$:	LOAD.L	(A6)+OSRCPP,A4	LOAD.L	(A6)+OSRCLP,D4	LOAD.L	(A6)+OSRCPM,A3	LOAD.L	(A6)+OSRCLM,D3	COMP.L	D3,#LGMOT/2	; trop long ?	JUMP,HS ERRFM$		; oui => ERRFM$	CALL	JUSTEIFMANY	; y a-t-il un seul mot ?	JUMP,NE ERRFM$		; non => ERRFM$	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	CALL	DICO_FOPEN	; charge le dico des familles si ncessaire	JUMP,NE EXIT$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A4,(A6)+OSRCPM	LOAD.L	D4,(A6)+OSRCLM	CLR.W	(A6)+OSYBR	CALL	SYNBASE		; cherche le mot de base	JUMP,NE ERROR$	CLR.W	(A6)+OSYRS	LOAD.L	(A6)+OSYPD,(A6)+OFDICO	LOAD.L	A4,#(A6)+OSYBM	LOAD.L	D4,(A6)+OSYBL	CALL	SYNSEARCH	; cherche les synonymes	JUMP,NE ERROR$	LOAD.L	A2,#R16"TDBOX_FAMILLE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.L	A5,#(A6)+OSLVAR1	CLR.B	(A5)+OSLVID	LOAD.W	D2,#2^BDBGCLABEL!100	CALL	DBOXSLDRAW	; dessine le pourtour de la scroll-liste	CALL	DBOXPHDRAW	; affiche la phrase	CALL	DBSYAFBM	; affiche les mots de base	LOAD.L	A5,#(A6)+OSLVAR3	CLR.B	(A5)+OSLVID	LOAD.W	D2,#2^BDBGCLABEL!102	CALL	DBOXSLDRAW	; dessine le pourtour de la scroll-liste	CALL	DBSYSLDR	; dessine le contenu de la scroll-listeLOOP$:	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_FAMILLE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ INS1$	COMP.W	D3,#F4	JUMP,EQ INST$	COMP.W	D3,#F0	JUMP,EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	LIB	?IFMOUSE	JUMP,NE BIP$	SUB.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SWAP.W	D4	CALL	DBOXPHMOVE	; dplace la scroll-liste ...	JUMP,EQ LOOP$	SCROLL_	LMOVE		; dplace la scroll-liste ...	JUMP,NE BIP$	JUMP	LOOP$ERROR$:	LOAD.W	D4,D7	AND.W	D4,#H'FF00	COMP.W	D4,#ERHERE	; erreur interne ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.L	A3,#R16"TERR1$	JUMP'	ERRFX2$ERRFM$:	LOAD.L	A3,#R16"TERRM$;	JUMP'	ERRFX2$ERRFX2$:	LOAD.W	D3,#BIPERR	LIB	?BEEP	LOAD.W	D2,#2^BDBSAV	DBOX_	TERROR		; affiche l'erreur interne	JUMP'	EXIT$INS1$:				; (INSERE UN) =>	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A3,(A6)+OSYPL	LOAD.W	D4,(A5)+OSLCYS	MUL.WU	D4,#LGMOT	ADD.L	A3,D4		; A3 <-- ^synonyme choisi	CALL	FAMFORME1	; A4/D4 <-- mot de la mme famille	JUMP'	CLOSE$INST$:				; (INSERE TOUS) =>	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A3,(A6)+OSYPL	LOAD.W	D3,(A5)+OSLCYN	CALL	FAMFORMET	; A4/D4 <-- mot de la mme famille	LOAD.L	D3,#F1		; D3 <-- comme si (F1) !	JUMP'	CLOSE$CANCEL$:			; (ANNULE) =>	LOAD.L	A4,(A6)+OSRCPM	LOAD.L	D4,(A6)+OSRCLMCLOSE$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	PUSH.L	A4	TEST.L	(A6)+OSYPL	JUMP',EQ NOMEM$	LOAD.L	A4,(A6)+OSYPL	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancienne liste	CLR.L	(A6)+OSYPLNOMEM$:	POP.L	A4	POPM.L	D0..D2,D5,D6,A0..A3,A5,A6	TEST.W	D7		; retour EQ/NE	RETTERR1$:	.ASCII	"Il n'y a aucun mot appar-<CR>"	.ASCIZ	"tenant  la mme famille !"TERRM$:	.ASCII	"Il faut chercher la famille<CR>"	.ASCIZ	"d'un seul mot  la fois !"	.EVENTDBOX_FAMILLE:	.W	10$-TDBOX_FAMILLE	.W	20$-TDBOX_FAMILLE	.W	0,010$:	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR,ODBCR	; scroll-liste de 3 lignes	.B	ODBTABX,30+3+23	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	" Espce       "	.B	ODBLABEL,201	.B	ODBBOX,0,0,TDBNORM	.ASCIZ	"              "	; 14x	.B	ODBTABX,14+14+1	.B	ODBLABEL,202	.B	ODBBOX,0,0,TDBNORM	.ASCIZ	"                          "  ; 26x	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	" Mot de base  "	.B	ODBLABEL,203	.B	ODBBOX,0,0,TDBOMBRE	.ASCIZ	"                                         "  ; 41x	.B	ODBCR,ODBCR	.B	ODBLABEL,102	.B	ODBTEXT,0	.B	ODBTABX,30+3	.B	ODBTEXT	.ASCIZ	"Liste des mots de"	.B	ODBCR	.B	ODBTABX,30+3	.B	ODBTEXT	.ASCIZ	"la mme famille."	.B	ODBCR,ODBCR,ODBCR2	.B	ODBTABX,30+3	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"      INSERE UN       "	.B	ODBCR,ODBCR	.B	ODBTABX,30+3	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	"      INSERE TOUS     "	.B	ODBCR,ODBCR	.B	ODBTABX,30	.B	ODBLABEL,103	.B	ODBTEXT,0	.B	ODBTABX,30+3	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"        ANNULE        "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Insre un"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Insre tous"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_FAMILLE:	.W	F1,F2,F3,0		DOKF1-TKEY_FAMILLE	.W	F4,F5,F6,0		DOKF4-TKEY_FAMILLE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_FAMILLE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_FAMILLE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_FAMILLE	.W	0;---------\\; DBSYAFBM >;---------/; Affiche les mots de base.; in	-; out	-; mod	D7.WDBSYAFBM:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,#(A6)+OSLTXT	LOAD.L	A3,(A6)+OSRCPM	LOAD.L	D3,(A6)+OSRCLM20$:	LOAD.B	(A4+),(A3+)	; OSLTXT <-- mot initial	DEC.W	D3	JUMP,NE 20$	CLR.B	(A4)	LOAD.L	A4,#(A6)+OSLTXT	LOAD.L	A3,A4	LOAD.B	D3,(A6)+OSYBT	; D3 <-- type	LOAD.W	D4,(A6)+OSYBF	; D4 <-- forme	CALL	GETTXMOT	; OSLTXT <-- mot initial | espce | forme <0>30$:	COMP.B	(A3+),#'|	JUMP,NE 30$	INC.L	A3	LOAD.L	A4,A3	LOAD.W	D3,#-140$:	INC.W	D3	COMP.B	(A4+),#'|	JUMP,NE 40$	LOAD.W	D2,#2^BDBGCLABEL!201	CALL	AFFBOX		; affiche l'espce	LOAD.L	A3,#(A3)+(D3.W)+2	LOAD.L	A4,A3	LOAD.W	D3,#-150$:	INC.W	D3	TEST.B	(A4+)	JUMP,NE 50$	LOAD.W	D2,#2^BDBGCLABEL!202	CALL	AFFBOX		; affiche la forme	LOAD.W	D2,#2^BDBGCLABEL!203	LOAD.L	A3,#(A6)+OSYBM	LOAD.L	D3,(A6)+OSYBL	CALL	AFFBOX		; affiche le mot de base	POPM.L	D2..D4,A3,A4	RET;---------\\; DBSYDRRS >;---------/; Affiche le rang des synonymes trouvs.; in	-; out	-; mod	D7.WDBSYDRRS:	PUSHM.L	D2..D4	LOAD.L	D3,(A6)+OSYRP	ADD.W	D3,(A0)+ODFCX	SWAP.W	D3	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,#2	SWAP.W	D3	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A6)+OSYRS	INC.W	D4	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFSPACE	POPM.L	D2..D4	RET;---------\\; DBSYSLDR >;---------/; Dessine le contenu de la scroll-liste.; in	A5.L	^variables; out	-; mod	D7.WDBSYSLDR:	PUSHM.L	D4,A4	LOAD.W	(A5)+OSLCYN,(A6)+OSYNL	LOAD.W	(A5)+OSLCYS,(A6)+OSYRL	LOAD.L	A4,#R16"DBSYSLTX	LOAD.L	(A5)+OSLADL,A4	SCROLL_	LUPDATE		; dessine le contenu de la scroll-liste	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBSYSLTX >;---------/; Donne le texte allant dans la scroll-liste.; in	A6.32	^vos variables;	D3.16	rang de la case (0..OSLCYN-1); out	D3.16	zro	-->	rien;		un	-->	ligne pointille horizontale en bas de la case;		deux	-->	ligne pleine horizontale en bas de la case;		trois	-->	ligne double horizontale en bas de la case;	A3.32	^contenu de la case termin par <0> ou <CR>;	D7.16	erreur si la case est vide; mod	D3.32, D7.16, A3.32DBSYSLTX:	PUSHM.L	D4,A4	LOAD.W	D4,D3		; D4 <-- rang	LOAD.L	A3,(A6)+OSYPL	MUL.WU	D3,#LGMOT	ADD.L	A3,D3		; A3 <-- ^mot	LOAD.L	A4,#(A3)+LGMOT	; A4 <-- ^mot suivant	COMP.B	(A3),#'$	JUMP',NE 30$	INC.L	A3		; A3 <-- saute le "$" initial30$:	LOAD.W	D3,#1		; D3 <-- ligne pointille	TEST.W	D4		; premier mot ?	JUMP',EQ 90$		; oui => 90$	COMP.B	(A4),#'$	; "$" au dbut du mot suivant ?	JUMP',EQ 90$		; oui => 90$	CLR.W	D3		; D3 <-- rien90$:	POPM.L	D4,A4	CLR.W	D7		; D7 <-- ok	RET;--------------\\; _DICO_CHIFFRE >;==============/; Transforme un nombre form de chiffres en toutes lettres.; in	D6.L	canal;	A4/D4.L	^nombre en chiffres/lg; out	D3.L	dernire touche presse (F1/F0);	A4/D4.L	^nombre en lettres/lg;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.L_DICO_CHIFFRE:	PUSHM.L	D0..D2,D5,D6,A0..A3,A5,A6	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	A0,A4	LIB	?GETPDIS	EX.L	A0,A4		; A0 <-- ^descripteur fentre	LOAD.L	A3,#(A6)+OCHBIN	LOAD.W	D2,#LCHBIN-1INIT2$:	DEC.L	D4	JUMP',NS INIT5$	LOAD.B	D3,(A4+)	CALL	MINMAJ	COMP.B	D3,#'+	JUMP',EQ INIT4$	COMP.B	D3,#'-	JUMP',EQ INIT4$	COMP.B	D3,#'.	JUMP',EQ INIT4$	COMP.B	D3,#',	JUMP',EQ INIT4$	COMP.B	D3,#'%	JUMP',EQ INIT4$	COMP.B	D3,#''	JUMP',EQ INIT4$	COMP.B	D3,#SPACE	JUMP',EQ INIT4$	COMP.B	D3,#'L	JUMP',EQ INIT4$	COMP.B	D3,#'O	JUMP',EQ INIT4$	COMP.B	D3,#'0	JUMP,LO ERROR$	COMP.B	D3,#'9	JUMP,HI ERROR$INIT4$:	LOAD.B	(A3+),D3	DEC.W	D2	JUMP,EQ ERROR$	JUMP	INIT2$INIT5$:	CLR.B	(A3)	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OCHBIN	LOAD.L	D0,(A6)+OCHFAN	; D0 <-- fanions	JUMP',NE FANOK$	LOAD.L	D0,#2^BCHREGV!2^BCHCARD!2^BCHMPFANOK$:	LOAD.L	A2,#R16"TDBOX_CHIFFRE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,D0		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!101	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#2^BDBGCLABEL!100	DBOX_	GETCO	POP.L	D4	LOAD.W	D2,(A0)+ODFCX	SR.W	D2,#1	SUB.W	D3,D2	ADD.W	D4,D2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,#2	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT	CLR.L	D6		; D6 <-- aucun bouton grisUPDATE$:	CALL	DBCHFULLGREY	; grise qq boutons	CALL	DBCHUPDATELOOP$:	LOAD.L	D4,D0	DBOX_	EDIT		; attend une action ...	LOAD.L	D0,D4	CALL	ZEROCR		; remplace <CR> par <0>	TEST.W	D3	JUMP,EQ UPDATE$	LOAD.L	A1,#R16"TKEY_CHIFFRE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#F1	JUMP,EQ REMPL$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	UPDATE$KEYDBOX$:	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO KEYDBOX2$	RL.L	D1,#8	COMP.B	D3,#16	JUMP',LO KEYDBOX2$	RL.L	D1,#8KEYDBOX2$:	AND.L	D0,D1	TSET.L	D0:D3	JUMP	UPDATE$ERROR$:	LOAD.L	A3,#R16"TERR1$	LOAD.W	D3,#BIPERR	LIB	?BEEP	LOAD.W	D2,#2^BDBSAV	DBOX_	TERROR		; affiche l'erreur interne	JUMP'	EXIT$REMPL$:	LOAD.L	(A6)+OCHFAN,D0	LOAD.L	A3,#(A6)+OCHBIN	LOAD.L	D3,#LCHBIN	LOAD.L	A4,#(A6)+OCHBOUT	LOAD.L	D4,#LCHBOUT	CALL	CHCONV		; A4/D4 <-- chiffre en lettres	LOAD.W	D3,#F1CANCEL$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,D6,A0..A3,A5,A6	TEST.W	D7		; retour EQ/NE	RETTERR1$:	.ASCIZ	"Ce n'est pas un nombre constitu de chiffres !"	.EVENTDBOX_CHIFFRE:	.W	10$-TDBOX_CHIFFRE	.W	20$-TDBOX_CHIFFRE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Chiffre initial  "	.B	ODBXLINE,LCHBIN,LCHBIN,2^(13-8),0,0,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"A remplacer par   "	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,17+LCHBIN+1	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,BCHREGF!2^7!2^6,KEYDBOX/H'100,BCHREGF	.ASCIZ	" franais"	.B	ODBTABX,20	.B	ODBLCIRCLE,BCHCARD!2^7!2^6,KEYDBOX/H'100,BCHCARD	.ASCIZ	" cardinal"	.B	ODBTABX,20+17	.B	ODBLABEL,BCHMS	.B	ODBLCIRCLE,BCHMS!2^7!2^6,KEYDBOX/H'100,BCHMS	.ASCIZ	" masculin singulier"	.B	ODBCR	.B	ODBLCIRCLE,BCHREGS!2^7!2^6,KEYDBOX/H'100,BCHREGS	.ASCIZ	" neuchtelois"	.B	ODBTABX,20	.B	ODBLCIRCLE,BCHORD!2^7!2^6,KEYDBOX/H'100,BCHORD	.ASCIZ	" ordinal"	.B	ODBTABX,20+17	.B	ODBLABEL,BCHMP	.B	ODBLCIRCLE,BCHMP!2^7!2^6,KEYDBOX/H'100,BCHMP	.ASCIZ	" masculin pluriel"	.B	ODBCR	.B	ODBLCIRCLE,BCHREGV!2^7!2^6,KEYDBOX/H'100,BCHREGV	.ASCIZ	" vaudois"	.B	ODBTABX,20+17	.B	ODBLABEL,BCHFS	.B	ODBLCIRCLE,BCHFS!2^7!2^6,KEYDBOX/H'100,BCHFS	.ASCIZ	" fminin singulier"	.B	ODBCR	.B	ODBTABX,20+17	.B	ODBLABEL,BCHFP	.B	ODBLCIRCLE,BCHFP!2^7!2^6,KEYDBOX/H'100,BCHFP	.ASCIZ	" fminin pluriel"	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" REMPLACE "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Remplace"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CHIFFRE:	.W	F1,F2,F3,0		DOKF1-TKEY_CHIFFRE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CHIFFRE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CHIFFRE	.W	0;-------------\\; DBCHFULLGREY >;-------------/; Grise ou dgrise qq boutons.; in	D0.L	fanions;	A3.L	^chiffre frapp;	D6.L	flags boutons gris; out	D0.L	fanions;	D6.L	flags boutons gris; mod	D0.L, D6.L, D7.WDBCHFULLGREY:	PUSHM.L	D1..D4,A3	CLR.L	D1		; D1 <-- dgrise tout	TEST.L	D0:#BCHORD	JUMP',BS 50$	LOAD.L	D1,#2^BCHMP!2^BCHFP	CLR.W	D430$:	CLR.W	D3	LOAD.B	D3,(A3+)	JUMP',EQ 34$	COMP.B	D3,#'.	JUMP',EQ 34$	COMP.B	D3,#',	JUMP',EQ 34$	COMP.B	D3,#'0	JUMP,LO 30$	COMP.B	D3,#'9	JUMP,HI 30$	SUB.B	D3,#'0	MUL.WU	D4,#10	ADD.W	D4,D3	JUMP,NC 30$34$:	COMP.W	D4,#1	JUMP',LS 50$	LOAD.L	D1,#2^BCHMS!2^BCHFS50$:	LOAD.L	D2,D1	XOR.L	D1,D6		; D1 <-- boutons changs	LOAD.L	D6,D2	TEST.L	D1:#BCHMS	JUMP',BC 52$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!BCHMS	TEST.L	D6:#BCHMS	JUMP',BC 51$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!BCHMS51$:	DBOX_	GETCO52$:	TEST.L	D1:#BCHMP	JUMP',BC 54$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!BCHMP	TEST.L	D6:#BCHMP	JUMP',BC 53$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!BCHMP53$:	DBOX_	GETCO54$:	TEST.L	D1:#BCHFS	JUMP',BC 56$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!BCHFS	TEST.L	D6:#BCHFS	JUMP',BC 55$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!BCHFS55$:	DBOX_	GETCO56$:	TEST.L	D1:#BCHFP	JUMP',BC 58$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!BCHFP	TEST.L	D6:#BCHFP	JUMP',BC 57$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!BCHFP57$:	DBOX_	GETCO58$:	LOAD.L	D1,D6	AND.L	D1,D0	AND.L	D1,#H'00FF0000	; est-ce que le bouton allum est gris ?	JUMP',EQ 90$		; non => 90$	LOAD.L	D1,D6	SWAP.W	D1	LOAD.W	D2,#BCHMS-170$:	INC.W	D2		; D2 <-- cherche le premier bouton dgris	RR.B	D1,#1	JUMP,CS 70$	AND.L	D0,#H'FF00FFFF	TSET.L	D0:D2		; D0 <-- allume le premier bouton dgris90$:	POPM.L	D1..D4,A3	RET;-----------\\; DBCHUPDATE >;-----------/; Met  jour le chiffre en toutes lettres.; in	D0.L	fanions; out	-; mod	D7.WDBCHUPDATE:	PUSHM.L	D1..D4,A3,A4	LOAD.L	(A6)+OCHFAN,D0	LOAD.L	A3,#(A6)+OCHBIN	LOAD.L	D3,#LCHBIN	LOAD.L	A4,#(A6)+OCHBOUT	LOAD.L	D4,#LCHBOUT	CALL	CHCONV		; OCHBOUT <-- chiffre en lettres	PUSH.L	D4	LOAD.W	D2,#2^BDBGCLABEL!100	DBOX_	GETCO	LOAD.L	D2,D3		; D2 <-- position initiale	POP.L	D4	LOAD.L	A3,A4		; A3 <-- ^chiffre en lettres	LOAD.W	D1,#4-1		; D1 <-- nb de lignes30$:	LOAD.L	D3,D2	LIB	?SETCURS	LOAD.W	D3,D4	COMP.W	D3,#LCHBIN	JUMP',LS 34$	LOAD.W	D3,#LCHBIN34$:	LIB	?STRING	SUB.W	D4,D3		; D4 <-- lg restante	ADD.W	A3,D3		; A3 <-- ^plus loin	SUB.W	D3,#LCHBIN	NEG.W	D3	JUMP',EQ 36$	LIB	?AFTIM	.B	MSPACE,0	.EVEN	LIB	?AFCAR		; efface la fin de la ligne36$:	SWAP.W	D2	ADD.W	D2,(A0)+ODFCY	; D2 <-- position juste en dessous	SWAP.W	D2	DECJ.W,NMO D1,30$	POPM.L	D1..D4,A3,A4	RET;------------\\; _DICO_BINIT >;============/; Initialise le recherche d'un mot quelconque.; Si le mot est inconnu (par exemple mal ortographi), aucune; erreur n'est rendue. C'est DICO_BNEXT qui donnera ventuellement; une erreur, selon le degr d'exactitude demand !; in	D6.L	canal;	A4/D4.L	^mot/lg; out	D7.W	erreur; mod	D7.W_DICO_BINIT:	PUSHM.L	D2..D4,A3,A4,A6	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv	COMP.L	D4,#LGMOT/2	; trop long ?	JUMP',HS EXIT$		; oui => EXIT$	LOAD.L	A3,A4	LOAD.L	D3,D4	CALL	JUSTEIFMANY	; y a-t-il un seul mot ?	JUMP',NE EXIT$		; non => EXIT$	CALL	SEARCHCADRE	; A4/D4 <-- ^mot/lg	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv	TEST.L	D4	JUMP',EQ EXIT$	LOAD.W	D2,#2		; D2 <-- deux lettres de sres	CALL	SEARCHINIT	; initialise pour la rechercheEXIT$:	POPM.L	D2..D4,A3,A4,A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; _DICO_BNEXT >;============/; Cherche le mot de base suivant.; in	D6.L	canal;	D2.W	degr d'exactitude maximal admis (0..5); out	A3.L	^mot trouv;	D2.W	degr d'exactitude (0..n);	D3.W	0..7  type du mot;		8..15 auxiliaire;	D4.W	forme (0..n);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A3.L_DICO_BNEXT:	PUSHM.L	D1,A4,A6	LOAD.L	A6,D6		; A6 <-- ^variables	CLR.B	(A6)+OCHFST	; ne stoppe pas	CALL	SEARCHNEXT	JUMP',NE EXIT$	AND.W	D3,#H'00FF	; D3 <-- pas d'auxiliaire	COMP.B	D3,#'t	JUMP',EQ VERBE$	COMP.B	D3,#'i	JUMP',EQ VERBE$	COMP.B	D3,#'u	JUMP',EQ VERBE$	COMP.B	D3,#'r	JUMP',EQ VERBE$	COMP.B	D3,#'1	JUMP',EQ VERBE$	COMP.B	D3,#'2	JUMP',EQ VERBE$	COMP.B	D3,#'h	JUMP',EQ VERBE$	COMP.B	D3,#'v	JUMP',EQ VERBE$	COMP.B	D3,#'7	JUMP',NE EXIT$VERBE$:	OR.W	D3,#H'100*'A	; D3 <-- auxiliaire "avoir" par dfaut	LOAD.L	A4,#(A6)+OSRCMDAUX$:	LOAD.B	D1,(A4+)	JUMP',EQ EXIT$	COMP.B	D1,#',	JUMP,NE AUX$	RR.W	D3,#8	LOAD.B	D3,(A4)		; D3 <-- auxiliaire	RR.W	D3,#8EXIT$:	POPM.L	D1,A4,A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; _DICO_BFORM >;============/; Construit une forme quelconque d'un mot (nom, adjectif, verbe, etc.).; in	D6.L	canal;	D4.W	forme demande (0..n); out	A3.L	^mot  la forme selon D4.W;	D7.W	erreur; mod	D7.W, A3.L_DICO_BFORM:	PUSHM.L	A4,A6	LOAD.L	A6,D6		; A6 <-- ^variables	SET.B	(A6)+OCJQQ	; cherche n'importe quelle forme	LOAD.L	A3,#(A6)+OBUMOT	LOAD.L	A4,#(A6)+OSRCMD	CALL	SEARCHMOT	; OBUMOT <-- mot accord en clairEXIT$:	POPM.L	A4,A6	TEST.W	D7		; retour EQ/NE	RET;---------\\; GETTXMOT >;=========/; Donne le texte pour afficher un mot.; in	A4.L	^buffer;	A3.L	^mot trouv;	D3.B	type du mot;	D4.W	forme (0..n); out	-; mod	D7.WGETTXMOT:	PUSHM.L	D2..D4,A3,A4	LOAD.W	D2,#20MOT1$:	DEC.W	D2	JUMP',EQ MOT3$	LOAD.B	(A4+),(A3+)	; buffer <-- mot	JUMP,NE MOT1$	DEC.L	A4MOT2$:	LOAD.B	(A4+),#SPACE	DEC.W	D2	JUMP,NE MOT2$MOT3$:	LOAD.B	(A4+),#'|	LOAD.B	(A4+),#SPACE	LOAD.L	A3,#R16"TGENRES$-13GENRE1$:	LOAD.L	A3,#(A3)+13	COMP.B	(A3),#SPACE	JUMP',EQ GENRE2$	COMP.B	D3,(A3)	JUMP,NE GENRE1$GENRE2$:	INC.L	A3	LOAD.W	D2,#12-1GENRE4$:	LOAD.B	(A4+),(A3+)	; buffer <-- type	DECJ.W,NMO D2,GENRE4$	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'|	LOAD.B	(A4+),#SPACE	LOAD.L	A3,#R16"TACCORD$	COMP.B	D3,#'m	JUMP,EQ TYPEm$	COMP.B	D3,#'4	JUMP,EQ TYPE4$	COMP.B	D3,#'q	JUMP,EQ TYPEq$	COMP.B	D3,#'f	JUMP,EQ TYPEf$	COMP.B	D3,#'n	JUMP,EQ TYPEn$	COMP.B	D3,#'3	JUMP,EQ TYPE3$	COMP.B	D3,#'a	JUMP,EQ TYPEa$	COMP.B	D3,#'y	JUMP,EQ TYPEy$	COMP.B	D3,#'5	JUMP,EQ TYPE5$	COMP.B	D3,#'k	JUMP,EQ TYPEk$	COMP.B	D3,#'x	JUMP,EQ TYPEx$	COMP.B	D3,#'w	JUMP,EQ TYPEw$	COMP.B	D3,#'o	JUMP,EQ TYPEo$	COMP.B	D3,#'p	JUMP,EQ TYPEp$	COMP.B	D3,#'z	JUMP,EQ TYPEz$	COMP.B	D3,#'d	JUMP,EQ TYPEd$	COMP.B	D3,#'6	JUMP,EQ TYPE6$	COMP.B	D3,#'c	JUMP,EQ TYPEc$	COMP.B	D3,#'s	JUMP,EQ TYPEs$	COMP.B	D3,#'j	JUMP,EQ TYPEj$	COMP.B	D3,#'b	JUMP,EQ TYPEb$	COMP.B	D3,#'g	JUMP,EQ TYPEg$	COMP.B	D3,#'l	JUMP,EQ TYPEl$	COMP.B	D3,#'8	JUMP,EQ TYPE8$	COMP.B	D3,#'P	JUMP,EQ TYPENP$	COMP.B	D3,#'0	JUMP,EQ TYPE0$	COMP.B	D3,#'%	JUMP,EQ TYPEpc$	COMP.B	D3,#'t	JUMP,EQ VERBE$	COMP.B	D3,#'i	JUMP,EQ VERBE$	COMP.B	D3,#'u	JUMP,EQ VERBE$	COMP.B	D3,#'r	JUMP,EQ VERBE$	COMP.B	D3,#'1	JUMP,EQ VERBE$	COMP.B	D3,#'2	JUMP,EQ VERBE$	COMP.B	D3,#'h	JUMP,EQ VERBE$	COMP.B	D3,#'v	JUMP,EQ VERBE$	COMP.B	D3,#'7	JUMP,EQ VERBE$	JUMP	EXIT$TYPEm$:				; nom masculin =>	JUMP	PUTT$TYPE4$:				; nom masculin singulier =>	LOAD.W	D4,#8	JUMP	PUTT$TYPEq$:				; nom masculin pluriel =>	LOAD.W	D4,#8	JUMP	PUTT$TYPEf$:				; nom fminin =>	ADD.W	D4,#2	JUMP	PUTT$TYPEn$:				; nom masculin peut devenir fminin =>	JUMP	PUTT$TYPE3$:				; nom fminin pluriel =>	LOAD.W	D4,#8	JUMP	PUTT$TYPEa$:				; adjectif =>	JUMP	PUTT$TYPEy$:				; adjectif compos =>	JUMP	PUTT$TYPE5$:				; adjectif invariable =>	LOAD.W	D4,#8	JUMP	PUTT$TYPEk$:				; nom masculin ou adjectif =>	JUMP	PUTT$TYPEx$:				; nom fminin ou adjectif =>	JUMP	PUTT$TYPEw$:				; nom masculin, fminin ou adjectif =>	JUMP	PUTT$TYPEo$:				; pronom =>	JUMP	PUTT$TYPEp$:				; article =>	JUMP	PUTT$TYPEz$:				; prposition =>	LOAD.W	D4,#8	JUMP	PUTT$TYPEd$:				; adverbe =>	LOAD.W	D4,#8	JUMP	PUTT$TYPE6$:				; prposition ou adverbe =>	LOAD.W	D4,#8	JUMP	PUTT$TYPEc$:				; conjonction =>	LOAD.W	D4,#8	JUMP	PUTT$TYPEs$:				; subjonction =>	LOAD.W	D4,#8	JUMP	PUTT$TYPEj$:				; interjection =>	LOAD.W	D4,#8	JUMP	PUTT$TYPEb$:				; abrviation =>	LOAD.W	D4,#8	JUMP	PUTT$TYPEg$:				; sigle =>	LOAD.W	D4,#8	JUMP	PUTT$TYPEl$:				; locution =>	LOAD.W	D4,#8	JUMP	PUTT$TYPE8$:				; prfixe =>	LOAD.W	D4,#8	JUMP	PUTT$TYPENP$:			; nom propre =>	LOAD.W	D4,#8	JUMP	PUTT$TYPE0$:				; nom masculin ou fminin, invariable =>	LOAD.W	D4,#8	JUMP	PUTT$TYPEpc$:			; nom masculin fminin ou adjectif, invariable =>	LOAD.W	D4,#8	JUMP	PUTT$PUTT$:	DEC.W	D4	JUMP',NS PUTT3$PUTT2$:	TEST.B	(A3+)	JUMP,NE PUTT2$	JUMP	PUTT$PUTT3$:	LOAD.B	(A4+),(A3+)	; buffer <-- forme	JUMP,NE PUTT3$	DEC.L	A4	JUMP	EXIT$VERBE$:	TEST.W	D4		; infinitif ?	JUMP,EQ TEMPS$		; oui => TEMPS$	DEC.W	D4	AND.L	D4,#H'FFFF	DIV.WU	D4,#6		; D4 <-- temps (0..8)	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- forme (0..5)	COMP.W	D4,#8	JUMP,EQ PART$	INC.W	D4	LOAD.L	A3,#R16"TFORME$FORME1$:	DEC.W	D3	JUMP',NS FORME3$FORME2$:	TEST.B	(A3+)	JUMP,NE FORME2$	JUMP	FORME1$FORME3$:	LOAD.B	(A4+),(A3+)	; buffer <-- forme	JUMP,NE FORME3$	DEC.L	A4	JUMP'	TEMPS$PART$:				; participes prsent/pass =>	INC.W	D4	TEST.W	D3	JUMP',EQ TEMPS$	INC.W	D4;	JUMP'	TEMPS$TEMPS$:	LOAD.L	A3,#R16"TVERBE$TEMPS1$:	DEC.W	D4	JUMP',NS TEMPS3$TEMPS2$:	TEST.B	(A3+)	JUMP,NE TEMPS2$	JUMP	TEMPS1$TEMPS3$:	LOAD.B	(A4+),(A3+)	; buffer <-- temps	JUMP,NE TEMPS3$	DEC.L	A4;	JUMP	EXIT$EXIT$:	CLR.B	(A4)		; buffer <-- terminateur	POPM.L	D2..D4,A3,A4	RETTGENRES$:	.ASCII	"mnom         "	.ASCII	"4nom         "	.ASCII	"qnom         "	.ASCII	"fnom         "	.ASCII	"nnom         "	.ASCII	"3nom         "	.ASCII	"0nom         "	.ASCII	"aadjectif    "	.ASCII	"yadjectif    "	.ASCII	"5adjectif    "	.ASCII	"knom/adjectif"	.ASCII	"xnom/adjectif"	.ASCII	"wnom/adjectif"	.ASCII	"%nom/adjectif"	.ASCII	"opronom      "	.ASCII	"pdterminant "	.ASCII	"tverbe       "	.ASCII	"iverbe       "	.ASCII	"uverbe       "	.ASCII	"rverbe       "	.ASCII	"1verbe       "	.ASCII	"2verbe       "	.ASCII	"hverbe       "	.ASCII	"vverbe       "	.ASCII	"7verbe       "	.ASCII	"zprposition "	.ASCII	"dadverbe     "	.ASCII	"6prp/adverbe"	.ASCII	"cconjonction "	.ASCII	"ssubjonction "	.ASCII	"jinterjection"	.ASCII	"babrviation "	.ASCII	"gsigle       "	.ASCII	"llocution    "	.ASCII	"8prfixe     "	.ASCII	"Pnom propre  "	.ASCII	" ?           "TACCORD$:	.ASCIZ	"masculin singulier"	.ASCIZ	"masculin pluriel"	.ASCIZ	"fminin singulier"	.ASCIZ	"fminin pluriel"	.B	0,0,0,0	.ASCIZ	"invariable"TFORME$:	.ASCIZ	"(je) "	.ASCIZ	"(tu) "	.ASCIZ	"(il/elle) "	.ASCIZ	"(ils/elles) "	.ASCIZ	"(nous) "	.ASCIZ	"(vous) "TVERBE$:	.ASCIZ	"infinitif"	.ASCIZ	"prsent"	.ASCIZ	"imparfait"	.ASCIZ	"pass simple"	.ASCIZ	"futur simple"	.ASCIZ	"subj. prsent"	.ASCIZ	"subj. imparfait"	.ASCIZ	"cond. prsent"	.ASCIZ	"impratif prsent"	.ASCIZ	"participe prsent"	.ASCIZ	"participe pass"	.EVEN	.INS	DICODBOX.ASI	.INS	DICODICO.ASI	.INS	DICOCODE.ASI	.INS	DICOSEARCH.ASI	.INS	DICOSYN.ASI	.INS	DICOICONE.ASI	.INS	DICOVERBE.ASI	.INS	DICOCHIFFRE.ASIEND_DICO:	.END