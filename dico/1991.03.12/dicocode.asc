	.TITLE	DICOCODE.ASC	.PROC	M680002	.REF	SMAKYASSMILE	=	0LINDEX	=	((27*26)+1)*6	; longueur des indexMAXIDX	=	8000		; nb max d'index  3 lettres	.LOC	0OPDICO:	.BLKB	4		; ^dictionnaire en clairOPCODE:	.BLKB	4		; ^dictionnaire codONAME:	.BLKB	1		; 1 => demande les nomsOSUPP:	.BLKB	1		; 1 => 500'000 mots	.EVENOSNAME:	.BLKB	100		; nom sourceODNAME:	.BLKB	100		; nom destinationOTPD:	.BLKB	4		; tri: ^dbutOTPF:	.BLKB	4		; tri: ^finOBUMOT:	.BLKB	200OLGIDX:	.BLKB	4		; lg index  3 lettresOBUIDX:	.BLKB	MAXIDX*8	; index  3 lettresLGVAR:	.LOC	0START:	.IF	~ASSMILE	LIB	?OPELIB	.ENDIF	LOAD.L	A6,#R16"VAR	LIB	?AFTIM	.ASCIZ	"<EOP><CR>Demande les noms de fichiers ? "	.EVEN	LIB	?YESNO	COMP.W	D7,#ERKYES	JUMP,NE	10$	SET.B	(A6)+ONAME10$:	LIB	?AFTIM	.ASCIZ	"<CR>Nom du dictionnaire source : "	.EVEN	TEST.B	(A6)+ONAME	JUMP,EQ 12$	LOAD.L	A3,#(A6)+OSNAME	LOAD.W	D3,#100	LIB	?GETLINE	COMP.W	D3,#CR	JUMP,NE ERFAT	JUMP	14$12$:	LOAD.L	A3,#R16"NMDICOS	PUSH.L	A3	LIB	?AFTEXT	POP.L	A3	LIB	?AFCR14$:	CALL	DICOLOAD	; charge le dictionnaire source	JUMP,NE ERFAT	LOAD.L	(A6)+OPDICO,A4	LIB	?AFTIM	.ASCIZ	"<CR>Dictionnaire complet (500'000 mots) ? "	.EVEN	LIB	?YESNO	COMP.W	D7,#ERKYES	JUMP,NE	20$	SET.B	(A6)+OSUPP20$:	CALL	RESCODE		; rserve mmoire	JUMP,NE ERROR	CALL	TRIMOTS		; trie ...	CALL	CODEALL		; code ...	CALL	GENINDEX2	; index  2 lettres ...	CALL	GENINDEX3	; index  3 lettres ...	LIB	?BEEP	LIB	?AFTIM	.ASCIZ	"<CR>Nom du dictionnaire destination : "	.EVEN	TEST.B	(A6)+ONAME	JUMP,EQ 32$	LOAD.L	A3,#(A6)+ODNAME	LOAD.W	D3,#100	LIB	?GETLINE	COMP.W	D3,#CR	JUMP,NE ERFAT	JUMP	34$32$:	LOAD.L	A3,#R16"NMDICOD	TEST.B	(A6)+OSUPP	JUMP,EQ 33$	LOAD.L	A3,#R16"NMDICOE33$:	PUSH.L	A3	LIB	?AFTEXT	POP.L	A3	LIB	?AFCR34$:	LOAD.L	D3,#DEFATT	LIB	?FCREATE	JUMP,NE ERROR	LOAD.L	A4,(A6)+OPCODE	LOAD.L	D4,(A6)+OLGIDX	ADD.L	(A4)+OBXLG,D4	LOAD.L	D4,#256+LINDEX	FOS	?WRBYTE		; crit en-tte et index  2 lettres	JUMP,NE 80$	LOAD.L	A4,#(A6)+OBUIDX	LOAD.L	D4,(A6)+OLGIDX	FOS	?WRBYTE		; crit index  3 lettres	JUMP,NE 80$	LOAD.L	A4,(A6)+OPCODE	LOAD.L	D4,(A4)+OBXLG	ADD.L	A4,#256+LINDEX	SUB.L	D4,(A6)+OLGIDX	SUB.L	D4,#LINDEX	FOS	?WRBYTE		; crit tous les mots80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	JUMP,NE ERROR	JUMP	FINERROR:	LIB	?AFERROR	LIB	?GETCARFIN:	TEST.L	(A6)+OPDICO	JUMP,EQ 20$	LOAD.L	A4,(A6)+OPDICO	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPDICO20$:	TEST.L	(A6)+OPCODE	JUMP,EQ 30$	LOAD.L	A4,(A6)+OPCODE	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPCODE30$:ERFAT:	.IF	ASSMILE	EXIT	.ELSE	LIB	?CLOLIB	FOS	?STOP	.ENDIF;--------\\; RESCODE >;========/; Rserve la mmoire pour le dictionnaire cod.; in	-; out	D7.W	erreur; mod	D7.WRESCODE:	PUSHM.L	D1,D4,A4	LOAD.L	A4,(A6)+OPDICO	CLR.L	D420$:	INC.L	D4	TEST.B	(A4+)	JUMP,NE 20$	ADD.L	D4,#256+LINDEX+100	TEST.L	(A6)+OPCODE	JUMP,NE 50$	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE 90$	LOAD.L	(A6)+OPCODE,A450$:	LOAD.L	A4,(A6)+OPCODE	GESMEM	?CLEARMEM	CLR.W	D790$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TRIMOTS >;========/; ; in	(A6)+OPDICO.L	^dictionnaire; out	(A6)+OPCODE.L	^dictionnaire tri; mod	D7.WTRIMOTS:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,(A6)+OPCODE	ADD.L	A4,#256+LINDEX	LOAD.L	(A6)+OTPD,A4	LOAD.L	(A6)+OTPF,A4	LOAD.L	A4,(A6)+OPDICO	LIB	?AFTIM	.ASCIZ	"<CR>Trie le mot numro <NOCURS>"	.EVEN	LIB	?GETCURS	CLR.L	D420$:	TEST.B	(A4)		; fin du dictionnaire ?	JUMP',EQ 30$		; oui => 30$	COMP.B	(A4),#'S	JUMP,NE 22$	INC.L	A4	TEST.B	(A6)+OSUPP	JUMP,EQ 24$22$:	CALL	TRIMOT		; trie un mot	INC.L	D424$:	COMP.B	(A4+),#CR	; A4 <-- ^mot suivant	JUMP,NE 24$	LOAD.L	D2,D4	DIV.WU	D2,#20	SWAP.W	D2	TEST.W	D2	JUMP,NE 20$	PUSHM.L	D2..D4	LIB	?SETCURS	LOAD.W	D2,#2^BAFDCM!2^BAFDSP	LOAD.W	D3,#8	LIB	?AFDEC	POPM.L	D2..D4	JUMP	20$30$:	LOAD.L	A4,(A6)+OTPF	CLR.B	(A4+)	LOAD.L	(A6)+OTPF,A4	LOAD.L	A4,(A6)+OPCODE	LOAD.L	D4,(A6)+OTPF	SUB.L	D4,(A6)+OTPD	ADD.L	D4,#LINDEX	LOAD.L	(A4)+OBXLG,D4	LOAD.B	(A4)+OBXTYP,#2^BBXREL	LOAD.B	D3,#CURS	LIB	?AFCAR	POPM.L	D3,D4,A3,A4	RET;-------\\; TRIMOT >;-------/; Ajoute rapidement un mot dans le dictionnaire tri,; en cherchant l'endroit par bissection.; in	A4.L	^mot  ajouter; out	-; mod	D7.WTRIMOT:	PUSHM.L	D2,A0..A3	LOAD.L	A0,(A6)+OTPD	; A0 <-- borne infrieure	LOAD.L	A1,(A6)+OTPF	; A1 <-- borne suprieure	LOAD.L	A2,A0	COMP.L	A0,A1	JUMP,EQ 50$	LOAD.L	A2,A1	DEC.L	A204$:	COMP.L	A2,A0	JUMP',EQ 05$	COMP.B	(-A2),#CR	JUMP,NE 04$	INC.L	A205$:	LOAD.L	A3,A2	CALL	COMPMOTS	JUMP',HS 10$	LOAD.L	A2,A1	JUMP	50$10$:	LOAD.L	D2,A1	SUB.L	D2,A0	SR.L	D2,#1	ADD.L	D2,A0	LOAD.L	A2,D2		; A2 <-- entre les deux bornes12$:	COMP.L	A2,A0	JUMP',EQ 13$	COMP.B	(-A2),#CR	JUMP,NE 12$	INC.L	A2	JUMP'	15$13$:	COMP.L	A2,A1	JUMP',EQ 14$	COMP.B	(A2+),#CR	JUMP,NE 13$14$:	COMP.L	A2,A1	JUMP,EQ 30$15$:	LOAD.L	A3,A2	CALL	COMPMOTS	JUMP,EQ 50$	JUMP',LO 20$	LOAD.L	A1,A2		; borne suprieure <-- milieu	JUMP	10$20$:	LOAD.L	A0,A2		; borne infrieure <-- milieu	JUMP	10$30$:	LOAD.L	A2,A0	LOAD.L	A3,A0	CALL	COMPMOTS	JUMP',HI 50$	LOAD.L	A2,A150$:	LOAD.L	A3,A2	CALL	INSMOT	POPM.L	D2,A0..A3	RET;-------\\; INSMOT >;-------/; Insre un mot dans le dictionnaire tri.; in	A3.L	^o insrer;	A4.L	^mot  insrer; out	-; mod	D7.WINSMOT:	PUSHM.L	D3,D4,A1..A4	LOAD.L	A2,A4	CLR.L	D420$:	INC.L	D4		; D4 <-- lg du mot  insrer	COMP.B	(A2+),#CR	JUMP,NE 20$	LOAD.L	A2,(A6)+OTPF	LOAD.L	A1,A2	ADD.L	A1,D4	LOAD.L	(A6)+OTPF,A1	LOAD.L	D3,A2	SUB.L	D3,A3	JUMP',EQ 40$30$:	LOAD.B	(-A1),(-A2)	; creuse un trou	DEC.L	D3	JUMP,NE 30$40$:	LOAD.B	(A2+),(A4+)	; met le mot dans le trou	DEC.L	D4	JUMP,NE 40$	POPM.L	D3,D4,A1..A4	RET;---------\\; COMPMOTS >;---------/; Compare deux chanes, en ne considrant que les lettres.;	c'est--dire  -->  CESTADIRE; in	A3.L	^mot;	A4.L	^mot; out	F	selon COMP (A3+),(A4+); mod	FCOMPMOTS:	PUSHM.L	D3,D4,A3,A4	INC.L	A3	INC.L	A420$:	LOAD.B	D3,(A4+)	COMP.B	D3,#SPACE	JUMP,EQ 20$	COMP.B	D3,#''	JUMP,EQ 20$	COMP.B	D3,#'-	JUMP,EQ 20$	COMP.B	D3,#'.	JUMP,EQ 20$	COMP.B	D3,#'$	JUMP,EQ 20$	COMP.B	D3,#',	JUMP,EQ 20$	COMP.B	D3,#'|	JUMP,EQ 20$	COMP.B	D3,#':	JUMP,EQ 20$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP',LO 22$	COMP.B	D3,#'Z	JUMP',LS 23$22$:	CLR.B	D323$:	LOAD.B	D4,D330$:	LOAD.B	D3,(A3+)	COMP.B	D3,#SPACE	JUMP,EQ 30$	COMP.B	D3,#''	JUMP,EQ 30$	COMP.B	D3,#'-	JUMP,EQ 30$	COMP.B	D3,#'.	JUMP,EQ 30$	COMP.B	D3,#'$	JUMP,EQ 30$	COMP.B	D3,#',	JUMP,EQ 30$	COMP.B	D3,#'|	JUMP,EQ 30$	COMP.B	D3,#':	JUMP,EQ 30$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP',LO 32$	COMP.B	D3,#'Z	JUMP',LS 33$32$:	CLR.B	D333$:	COMP.B	D3,D4	JUMP',NE 90$	TEST.B	D3	JUMP,NE 20$90$:	POPM.L	D3,D4,A3,A4	RET;----------\\; GENINDEX2 >;==========/; Gnre les index.; in	-; out	-; mod	D7.WGENINDEX2:	PUSHM.L	D0..D3,A3,A4	LIB	?AFTIM	.ASCIZ	"<CR>Gnre l'index  2 lettres :  "	.EVEN	LOAD.L	A4,(A6)+OPCODE	ADD.L	A4,#256+LINDEX	; A4 <-- ^premier mot	LOAD.L	A3,(A6)+OPCODE	ADD.L	A3,#256		; A3 <-- ^premier index	CLR.L	D2	LOAD.B	D0,#'A20$:	LOAD.B	D3,D0	LIB	?AFCAR	CLR.B	D1	CALL	SRCINDEX	LOAD.L	(A3),D2	ADD.L	A3,#6	LOAD.B	D1,#'A30$:	CALL	SRCINDEX	LOAD.L	(A3),D2	ADD.L	A3,#6	INC.B	D1	COMP.B	D1,#'Z	JUMP,LS 30$	INC.B	D0	COMP.B	D0,#'Z	JUMP,LS 20$	LOAD.L	A4,(A6)+OPCODE	LOAD.L	(A3),(A4)+OBXLG	ADD.L	A3,#6	LIB	?AFCR	POPM.L	D0..D3,A3,A4	RET;---------\\; SRCINDEX >;---------/; Cherche un index.; in	D0.B	premire lettre;	D1.B	deuxime lettre;	A4.L	^o chercher; out	A4.L	^plus loin;	D2.L	^relatif; mod	D2.L, D7.W, A4.LSRCINDEX:	PUSHM.L	D3,A1..A3	LOAD.L	A3,A4	LOAD.L	A2,A4	LOAD.L	A1,(A6)+OPCODE	ADD.L	A1,#256		; A1 <-- ^base pour ^relatifs20$:	TEST.B	(A3)	JUMP,EQ 80$	LOAD.L	A4,#(A6)+OBUMOT	CALL	DECOMOT		; A4 <-- ^mot dcod	INC.L	A422$:	LOAD.B	D3,(A4+)	COMP.B	D3,#SPACE	JUMP,EQ 22$	COMP.B	D3,#'-	JUMP,EQ 22$	COMP.B	D3,#''	JUMP,EQ 22$	COMP.B	D3,#'|	JUMP,EQ 22$	COMP.B	D3,#':	JUMP,EQ 22$	CALL	MINMAJ	LOAD.B	D2,D3	COMP.B	D3,D0		; premire lettre trouve ?	JUMP,NE 40$	TEST.B	D1	JUMP,EQ 50$26$:	LOAD.B	D3,(A4+)	COMP.B	D3,#SPACE	JUMP,EQ 26$	COMP.B	D3,#'-	JUMP,EQ 26$	COMP.B	D3,#''	JUMP,EQ 26$	COMP.B	D3,#'|	JUMP,EQ 26$	COMP.B	D3,#':	JUMP,EQ 26$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP',LO 33$	COMP.B	D3,#'Z	JUMP',LS 34$33$:	CLR.B	D334$:	COMP.B	D3,D1		; deuxime lettre trouve ?	JUMP,EQ 50$40$:	COMP.B	D0,D2	JUMP',LO 80$42$:	TEST.B	(A3+)		; A3 <-- ^mot suivant	JUMP,NE 42$	JUMP	20$50$:	LOAD.L	A4,A3		; A4 <-- ^plus loin	LOAD.L	D2,A3	SUB.L	D2,A1		; D2 <-- ^relatif (depuis le dbut)	JUMP'	90$80$:	LOAD.L	A4,A2	CLR.L	D2		; D2 <-- ^nil90$:	POPM.L	D3,A1..A3	RET;----------\\; GENINDEX3 >;==========/; Gnre la table des index  3 lettres.; in	-; out	-; mod	D7.WGENINDEX3:	PUSHM.L	D0..D4,A3,A4	LIB	?AFTIM	.ASCIZ	"Gnre l'index  3 lettres :  "	.EVEN	LOAD.L	A4,#(A6)+OBUIDX	LOAD.L	A3,A4	CLR.W	(A4+)	LOAD.W	D0,#'A20$:	LOAD.B	D3,D0	LIB	?AFCAR	LOAD.W	D1,#'A21$:	LOAD.W	D2,#'A22$:	CALL	INDEXONE	; OBUIDX <-- un index	INC.W	D2	COMP.W	D2,#'Z	JUMP,LS 22$	TEST.W	(A4)-2	JUMP',EQ 42$	CLR.W	(A4+)		; OBUIDX <-- spare les "AB?" des "AC?"42$:	INC.W	D1	COMP.W	D1,#'Z	JUMP,LS 21$	INC.W	D0	COMP.W	D0,#'Z	JUMP,LS 20$50$:	CLR.W	(A4+)	LOAD.L	D4,A4	SUB.L	D4,A3		; D4 <-- longueur des index  3 lettres	LOAD.L	(A6)+OLGIDX,D4	LOAD.L	A4,(A6)+OPCODE	ADD.L	A4,#256	LOAD.W	D4,#(26*27)+1	LOAD.L	D3,(A6)+OLGIDX70$:	TEST.L	(A4)	JUMP',EQ 74$	ADD.L	(A4),D374$:	ADD.L	A4,#6	DEC.W	D4	JUMP,NE 70$	LOAD.L	A4,#(A6)+OBUIDX	LOAD.L	D4,(A6)+OLGIDX	LOAD.L	A3,#(A4)+(D4.L)80$:	COMP.L	A4,A3	JUMP',HS 84$	TEST.W	(A4+)	JUMP,EQ 80$	ADD.L	(A4),D4	ADD.L	A4,#8-2	JUMP	80$84$:	LIB	?AFCR	POPM.L	D0..D4,A3,A4	RET;---------\\; INDEXONE >;---------/; Gnre un index  3 lettres, si ncessaire.; in	D0.W	premire lettre;	D1.W	deuxime lettre;	D2.W	troisime lettre;	A4.L	^buffer des index; out	A4.L	^plus loin; mod	D7.W, A4.LINDEXONE:	PUSHM.L	D3..D5,A0..A3,A5	LOAD.W	D4,D0	SUB.W	D4,#'A		; D4 <-- 0..25	MUL.WU	D4,#27*6	LOAD.W	D5,D1	SUB.W	D5,#'A-1	; D5 <-- 0..26	MUL.WU	D5,#6	ADD.W	D4,D5	LOAD.L	A2,(A6)+OPCODE	LOAD.L	A2,#(A2)+256	; A2 <-- ^index	LOAD.L	A3,#(A2)+(D4.W)	LOAD.L	A5,A3	LOAD.L	D4,(A3)	ADD.L	A3,#6	JUMP,EQ 80$	LOAD.L	A0,#(A2)+(D4.L)	; A0 <-- ^dbut20$:	LOAD.L	D4,(A3)	ADD.L	A3,#6	JUMP,EQ 20$	LOAD.L	A1,#(A2)+(D4.L)	; A1 <-- ^fin	LOAD.L	D4,A1	SUB.L	D4,A0	COMP.L	D4,#200		; y a-t-il bcp de mots ?	JUMP,LO 80$		; non => 80$; Cherche le dbut de l'index.	LOAD.L	A3,A030$:	COMP.L	A3,A1	JUMP,HS 80$	CALL	INDEXIFD	JUMP',EQ 38$	CLR.B	D434$:	COMP.B	D4,(A3+)	; A3 <-- ^mot suivant	JUMP,NE 34$	JUMP	30$38$:	TEST.W	(A5)+4	JUMP',NE 39$	LOAD.L	A1,#(A6)+OBUIDX	LOAD.L	D4,A4	SUB.L	D4,A1	ADD.W	D4,#LINDEX	LOAD.W	(A5)+4,D439$:	LOAD.B	(A4+),D2	; OBUIDX <-- 3me lettre	CLR.B	(A4+)	LOAD.L	A1,A3	LOAD.L	D4,A3	SUB.L	D4,A2	LOAD.L	(A4+),D4	; OBUIDX <-- ^dbut; Cherche la fin de l'index.40$:	CALL	INDEXIFF	JUMP',NE 48$	CLR.B	D444$:	COMP.B	D4,(A3+)	; A3 <-- ^mot suivant	JUMP,NE 44$	JUMP	40$48$:	LOAD.L	D4,A3	SUB.L	D4,A1	LOAD.W	(A4+),D4	; OBUIDX <-- lg	COMP.W	D4,#200		; y a-t-il bcp de mots ?	JUMP',HS 50$		; oui => 50$	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	SUB.L	A4,#8		; A4 <-- supprime l'index  3 lettres	LOAD.W	D3,#'A52$:	CALL	INDEXONE4	; gnre plusieurs index  4 lettres	INC.W	D3	COMP.W	D3,#'Z	JUMP,LS 52$	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POPM.L	D3..D5,A0..A3,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; INDEXIFD >;---------/; Regarde si un mot correspond aux 3 premires lettres; donnes dans D0..D3.; in	D0.W	premire lettre;	D1.W	deuxime lettre;	D2.W	troisime lettre;	A3.L	^mot; out	D7.W	erreur; mod	D7.WINDEXIFD:	PUSHM.L	D3,A3,A4	LOAD.L	A4,#(A6)+OBUMOT	CALL	DECOMOT		; OBUMOT <-- mot dcod	INC.L	A4		; A4 <-- saute le type	LOAD.W	D7,#1		; D7 <-- pas trouv20$:	LOAD.B	D3,(A4+)	JUMP,EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 20$	COMP.B	D3,#'Z	JUMP,HI 20$	COMP.B	D3,D0	JUMP,NE 90$30$:	LOAD.B	D3,(A4+)	JUMP',EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 30$	COMP.B	D3,#'Z	JUMP,HI 30$	COMP.B	D3,D1	JUMP',NE 90$40$:	LOAD.B	D3,(A4+)	JUMP',EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 40$	COMP.B	D3,#'Z	JUMP,HI 40$	COMP.B	D3,D2	JUMP',NE 90$	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; INDEXIFF >;---------/; Regarde si un mot correspond aux 3 premires lettres; donnes dans D0..D3.; in	D0.W	premire lettre;	D1.W	deuxime lettre;	D2.W	troisime lettre;	A3.L	^mot; out	D7.W	erreur; mod	D7.WINDEXIFF:	PUSHM.L	D3,A3,A4	LOAD.L	A4,#(A6)+OBUMOT	CALL	DECOMOT		; OBUMOT <-- mot dcod	INC.L	A4		; A4 <-- saute le type	LOAD.W	D7,#1		; D7 <-- pas trouv20$:	LOAD.B	D3,(A4+)	JUMP,EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 20$	COMP.B	D3,#'Z	JUMP,HI 20$	COMP.B	D3,D0	JUMP,NE 90$30$:	LOAD.B	D3,(A4+)	JUMP',EQ 80$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 30$	COMP.B	D3,#'Z	JUMP,HI 30$	COMP.B	D3,D1	JUMP',NE 90$40$:	LOAD.B	D3,(A4+)	JUMP',EQ 80$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 40$	COMP.B	D3,#'Z	JUMP,HI 40$	COMP.B	D3,D2	JUMP',NE 90$80$:	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; INDEXONE4 >;----------/; Gnre un index  4 lettres, si ncessaire.; in	D0.W	premire lettre;	D1.W	deuxime lettre;	D2.W	troisime lettre;	D3.W	quatrime lettre;	A4.L	^buffer des index; out	A4.L	^plus loin; mod	D7.W, A4.LINDEXONE4:	PUSHM.L	D4,D5,A0..A3,A5	LOAD.W	D4,D0	SUB.W	D4,#'A		; D4 <-- 0..25	MUL.WU	D4,#27*6	LOAD.W	D5,D1	SUB.W	D5,#'A-1	; D5 <-- 0..26	MUL.WU	D5,#6	ADD.W	D4,D5	LOAD.L	A2,(A6)+OPCODE	LOAD.L	A2,#(A2)+256	; A2 <-- ^index	LOAD.L	A3,#(A2)+(D4.W)	LOAD.L	A5,A3	LOAD.L	D4,(A3)	ADD.L	A3,#6	JUMP,EQ 80$	LOAD.L	A0,#(A2)+(D4.L)	; A0 <-- ^dbut20$:	LOAD.L	D4,(A3)	ADD.L	A3,#6	JUMP,EQ 20$	LOAD.L	A1,#(A2)+(D4.L)	; A1 <-- ^fin	LOAD.L	D4,A1	SUB.L	D4,A0	COMP.L	D4,#200		; y a-t-il bcp de mots ?	JUMP,LO 80$		; non => 80$; Cherche le dbut de l'index.	LOAD.L	A3,A030$:	COMP.L	A3,A1	JUMP,HS 80$	CALL	INDEXIFD4	JUMP',EQ 38$	CLR.B	D434$:	COMP.B	D4,(A3+)	; A3 <-- ^mot suivant	JUMP,NE 34$	JUMP	30$38$:	TEST.W	(A5)+4	JUMP',NE 39$	LOAD.L	A1,#(A6)+OBUIDX	LOAD.L	D4,A4	SUB.L	D4,A1	ADD.W	D4,#LINDEX	LOAD.W	(A5)+4,D439$:	LOAD.B	(A4+),D2	; OBUIDX <-- 3me lettre	LOAD.B	(A4+),D3	; OBUIDX <-- 4me lettre	LOAD.L	A1,A3	LOAD.L	D4,A3	SUB.L	D4,A2	LOAD.L	(A4+),D4	; OBUIDX <-- ^dbut; Cherche la fin de l'index.40$:	CALL	INDEXIFF4	JUMP',NE 48$	CLR.B	D444$:	COMP.B	D4,(A3+)	; A3 <-- ^mot suivant	JUMP,NE 44$	JUMP	40$48$:	LOAD.L	D4,A3	SUB.L	D4,A1	LOAD.W	(A4+),D4	; OBUIDX <-- lg	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POPM.L	D4,D5,A0..A3,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; INDEXIFD4 >;----------/; Regarde si un mot correspond aux 4 premires lettres; donnes dans D0..D3.; in	D0.W	premire lettre;	D1.W	deuxime lettre;	D2.W	troisime lettre;	D3.W	quatrime lettre;	A3.L	^mot; out	D7.W	erreur; mod	D7.WINDEXIFD4:	PUSHM.L	D3,D4,A3,A4	LOAD.B	D4,D3	LOAD.L	A4,#(A6)+OBUMOT	CALL	DECOMOT		; OBUMOT <-- mot dcod	INC.L	A4		; A4 <-- saute le type	LOAD.W	D7,#1		; D7 <-- pas trouv20$:	LOAD.B	D3,(A4+)	JUMP,EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 20$	COMP.B	D3,#'Z	JUMP,HI 20$	COMP.B	D3,D0	JUMP,NE 90$30$:	LOAD.B	D3,(A4+)	JUMP',EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 30$	COMP.B	D3,#'Z	JUMP,HI 30$	COMP.B	D3,D1	JUMP',NE 90$40$:	LOAD.B	D3,(A4+)	JUMP',EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 40$	COMP.B	D3,#'Z	JUMP,HI 40$	COMP.B	D3,D2	JUMP',NE 90$50$:	LOAD.B	D3,(A4+)	JUMP',EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 50$	COMP.B	D3,#'Z	JUMP,HI 50$	COMP.B	D3,D4	JUMP',NE 90$	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; INDEXIFF4 >;----------/; Regarde si un mot correspond aux 4 premires lettres; donnes dans D0..D3.; in	D0.W	premire lettre;	D1.W	deuxime lettre;	D2.W	troisime lettre;	D3.W	quatrime lettre;	A3.L	^mot; out	D7.W	erreur; mod	D7.WINDEXIFF4:	PUSHM.L	D3,D4,A3,A4	LOAD.B	D4,D3	LOAD.L	A4,#(A6)+OBUMOT	CALL	DECOMOT		; OBUMOT <-- mot dcod	INC.L	A4		; A4 <-- saute le type	LOAD.W	D7,#1		; D7 <-- pas trouv20$:	LOAD.B	D3,(A4+)	JUMP,EQ 90$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 20$	COMP.B	D3,#'Z	JUMP,HI 20$	COMP.B	D3,D0	JUMP,NE 90$30$:	LOAD.B	D3,(A4+)	JUMP',EQ 80$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 30$	COMP.B	D3,#'Z	JUMP,HI 30$	COMP.B	D3,D1	JUMP',NE 90$40$:	LOAD.B	D3,(A4+)	JUMP',EQ 80$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 40$	COMP.B	D3,#'Z	JUMP,HI 40$	COMP.B	D3,D2	JUMP',NE 90$50$:	LOAD.B	D3,(A4+)	JUMP',EQ 80$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 50$	COMP.B	D3,#'Z	JUMP,HI 50$	COMP.B	D3,D4	JUMP',NE 90$80$:	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CODEALL >;========/; Code tous les mots.; in	-; out	-; mod	D7.WCODEALL:	PUSHM.L	D3,D4,A3,A4	LIB	?AFTIM	.ASCIZ	"<CR>Codage en cours ..."	.EVEN	LOAD.L	A4,(A6)+OPCODE	ADD.L	A4,#256+LINDEX	LOAD.L	A3,A420$:	TEST.B	(A3)	JUMP',EQ 30$	CALL	CODEMOT	JUMP	20$30$:	CLR.B	(A4+)	LOAD.L	D4,A4	LOAD.L	A4,(A6)+OPCODE	SUB.L	D4,A4	SUB.L	D4,#256	LOAD.L	(A4)+OBXLG,D4	POPM.L	D3,D4,A3,A4	RET;--------\\; CODEMOT >;========/; Code un mot.; Cette routine peut tre lente !; in	A3.L	^mot en clair <CR>;	A4.L	^buffer pour mot cod <0>; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LCODEMOT:	PUSHM.L	D2..D4,A2	LOAD.B	(A4+),(A3+)20$:	LOAD.B	D3,(A3+)	; D3 <-- premire lettre	COMP.B	D3,#CR	JUMP,EQ 50$	LOAD.B	D4,(A3)		; D4 <-- deuxime lettre	LOAD.L	A2,#R16"TACODE	; A2 <-- ^couples de lettres	LOAD.B	D2,#12830$:	COMP.B	D3,(A2)	JUMP',NE 32$	COMP.B	D4,(A2)+1	JUMP',EQ 40$32$:	ADD.L	A2,#2		; A2 <-- ^couple suivant	INC.B	D2	JUMP,NE 30$	LOAD.B	(A4+),D3	JUMP	20$40$:	INC.L	A3	LOAD.B	(A4+),D2	JUMP	20$50$:	CLR.B	(A4+)	POPM.L	D2..D4,A2	RET;--------\\; DECOMOT >;========/; Dcode un mot.; Cette routine doit tre trs rapide !; in	A3.L	^mot cod <0>;	A4.L	^buffer pour mot en clair <0>; out	-; mod	D7.WDECOMOT:	PUSHM.L	D3,A2..A4	LOAD.B	(A4+),(A3+)	LOAD.L	A2,#R16"TACODE-256 ; A2 <-- ^couples de lettres20$:	LOAD.B	(A4+),(A3+)	JUMP',EQ 90$	JUMP,NC 20$	CLR.W	D3	LOAD.B	D3,(-A4)	; D3 <-- byte cod (128..255)	SL.W	D3,#1	LOAD.B	(A4+),(A2)+(D3.W)	LOAD.B	(A4+),(A2)+(D3.W)+1	JUMP	20$90$:	POPM.L	D3,A2..A4	RET;---------\\; DICOLOAD >;=========/; Charge un dictionnaire en mmoire.; in	A3.L	^nom du dictionnaire; out	A4.L	^dictionnaire termin par <0>;	D7.W	erreur; mod	D7.W, A4.LDICOLOAD:	PUSHM.L	D1,D3,D4,D6	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre le dictionnaire	JUMP,NE 90$	LOAD.L	D4,#-1	LOAD.B	D3,D4	FOS	?SPOS		; D4 <-- longueur du fichier	PUSH.L	D4	CLR.L	D4	CLR.B	D3	FOS	?SPOS		; revient au dbut	POP.L	D4	INC.L	D4		; D4 <-- place pour <0> terminateur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer pour le fichier dictionnaire	JUMP',NE 82$	DEC.L	D4	FOS	?RDBYTE		; lit tout le fichier dictionnaire	JUMP',NE 80$	CLR.B	(A4)+(D4.L)	; met le <0> terminateur	JUMP'	82$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire du dictionnaire	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme le dictionnaire	POP.W	D790$:	POPM.L	D1,D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; MAJMIN  >;========/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMAJMIN:	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'Z	JUMP',HI 90$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule90$:	RET;-------\\; MINMAJ >;=======/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMINMAJ:	COMP.B	D3,#'		; lettre accentue ?	JUMP',LS 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+TACCENT$ ; D3 <-- lettre majuscule	POP.W	D0	RETTACCENT$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN;---------\\; NOACCENT >;=========/; in	D3.B	caractre; out	D3.B	caractre non accentu; mod	D3.BNOACCENT:	COMP.B	D3,#'	JUMP',LO 90$	COMP.B	D3,#'		; lettre accentue ?	JUMP',HI 90$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+TACCENT$ ; D3 <-- lettre non accentue	POP.W	D090$:	RETTACCENT$:	.B	'u 'a 'a 'e 'e 'e 'e 'i 'i 'o 'u 'u 'a 'o 'c	.EVEN; Cette table donne les 128 couples de lettres les plus; utilises en franais, dans l'ordre.TACODE:	.ASCII	"erntonenretimeleteisinanriraatem"	.ASCII	"ousecourioeuiearuelineitchssilqu"	.ASCII	"trlaroirtastlloralaigecaagncsiic"	.ASCII	"desadimacenieslonapaabprblolvepo"	.ASCII	"tocietacnnmiaspendomussoelauuliq"	.ASCII	"utoiuihemoimotpimphansviapbotutt"	.ASCII	"fictrtgramcrbaignovaiasurdbigapl"	.ASCII	"currocosbrecnghigiadivschophogfa"	.EVENNMDICOS:.ASCIZ	"500000.DICO"NMDICOD:.ASCIZ	"#:250000.BDICO"NMDICOE:.ASCIZ	"#:500000.BDICO"	.EVENVAR:	.FILLB	LGVAR,0	.END	START