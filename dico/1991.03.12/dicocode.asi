	.SBTTL	DICOCODE.ASI;---------\\; CODEDIAL >;=========/; Demande le codage pour un mot.; in	A2.L	^dans OTADL;	A4.L	^premier bloc du dictionnaire;	A3/D3.L	^mot simple/lg; out	A3/D3.L	^mot encod/lg;	D4.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.W, A3.LCODEDIAL:	PUSHM.L	D0..D2,A4	PUSH.L	(A6)+OSRCPM	PUSH.L	(A6)+OSRCLM	LOAD.W	D4,#F1	CLR.W	D7	COMP.B	(A4)+LDU,#'*	; dictionnaire encod ?	JUMP,NE EXIT$		; non => EXIT$	PUSH.L	A4	LOAD.L	A4,#(A6)+OBUCOD	LOAD.L	D2,D3	LOAD.L	(A6)+OSRCPM,A4	CLR.L	(A6)+OSRCLM	CLR.L	D0		; D0 <-- map des majuscules	LOAD.W	D4,#-1		; D4 <-- rang du caractreMINUS1$:	LOAD.B	D3,(A3+)	LOAD.B	D1,D3	CALL	MAJMIN	COMP.B	D3,#LF	JUMP',EQ MINUS3$	COMP.B	D3,#TIRET	JUMP',EQ MINUS3$	LOAD.B	(A4+),D3	; OBUCOD <-- mot en minuscules	INC.L	(A6)+OSRCLM	INC.W	D4		; D4 <-- rang suivant	COMP.B	D1,D3		; lettre majuscule ?	JUMP',EQ MINUS3$	; non => MINUS3$	TSET.L	D0:D4		; D0 <-- une majusculeMINUS3$:	DEC.L	D2	JUMP,NE MINUS1$	LOAD.L	(A6)+OSRCB0,D0	; OSRCB0 <-- bits pour les majuscules	POP.L	A4	CALL	CODEESP		; choix de l'espce ...	JUMP,NE EXIT$	EX.L	D3,D4	COMP.W	D4,#F1	JUMP,NE EXIT$	LOAD.L	A3,#(A6)+OBUNOM	LOAD.B	(A3+),D3	; OBUNOM <-- type	COMP.B	D3,#'4	JUMP,EQ OK$	COMP.B	D3,#'q	JUMP,EQ OK$	COMP.B	D3,#'3	JUMP,EQ OK$	COMP.B	D3,#'5	JUMP,EQ OK$	COMP.B	D3,#'o	JUMP,EQ OK$	COMP.B	D3,#'p	JUMP,EQ OK$	COMP.B	D3,#'z	JUMP,EQ OK$	COMP.B	D3,#'d	JUMP,EQ OK$	COMP.B	D3,#'6	JUMP,EQ OK$	COMP.B	D3,#'c	JUMP,EQ OK$	COMP.B	D3,#'s	JUMP,EQ OK$	COMP.B	D3,#'j	JUMP,EQ OK$	COMP.B	D3,#'b	JUMP,EQ OK$	COMP.B	D3,#'g	JUMP,EQ OK$	COMP.B	D3,#'l	JUMP,EQ OK$	COMP.B	D3,#'8	JUMP,EQ OK$	COMP.B	D3,#'P	JUMP,EQ MAJ$	LOAD.W	D4,#B'1100	COMP.B	D3,#'m	JUMP',EQ MOT4$	LOAD.W	D4,#B'0011	COMP.B	D3,#'f	JUMP',EQ MOT4$	LOAD.W	D4,#B'0000	COMP.B	D3,#'a	JUMP',EQ MOT4$	COMP.B	D3,#'y	JUMP',EQ MOT4$	COMP.B	D3,#'k	JUMP',EQ MOT4$	COMP.B	D3,#'x	JUMP',EQ MOT4$	COMP.B	D3,#'w	JUMP',EQ MOT4$	COMP.B	D3,#'t	JUMP',EQ VERBE$	COMP.B	D3,#'i	JUMP',EQ VERBE$	COMP.B	D3,#'u	JUMP',EQ VERBE$	COMP.B	D3,#'r	JUMP',EQ VERBE$	COMP.B	D3,#'1	JUMP',EQ VERBE$	COMP.B	D3,#'2	JUMP',EQ VERBE$	COMP.B	D3,#'h	JUMP',EQ VERBE$	COMP.B	D3,#'v	JUMP',EQ VERBE$	COMP.B	D3,#'7	JUMP',EQ VERBE$MOT4$:	LOAD.B	D2,D3		; D2 <-- type	CALL	CODEED4		; choix des quatre formes ...	JUMP,NE EXIT$	EX.L	D3,D4	COMP.W	D4,#F1	JUMP,NE EXIT$	CALL	CODEMOT4	; OBUNOM <-- mot(s)	JUMP	END$VERBE$:	CALL	CODEVERBE	; choix de l'infinitif ...	JUMP,NE EXIT$	EX.L	D3,D4	COMP.W	D4,#F1	JUMP,NE EXIT$	LOAD.B	(A3)-1,D2	; OBUNOM <-- type du verbe	PUSH.L	A4	LOAD.L	A4,#(A6)+OEDMOT1VERBE3$:	LOAD.B	(A3+),(A4+)	; OBUNOM <-- infinitif	JUMP,NE VERBE3$	DEC.L	A3	POP.L	A4VERBE4$:	LOAD.B	(A3+),(A4+)	; OBUNOM <-- type de conjugaison	JUMP,NE VERBE4$	JUMP	END$MAJ$:	LOAD.L	A4,(A6)+OSRCPM	LOAD.L	D4,(A6)+OSRCLM	LOAD.L	D0,(A6)+OSRCB0	; D0 <-- bits pour les majuscules	CLR.W	D1		; D1 <-- rang du caractreMAJ2$:	LOAD.B	D3,(A4+)	CALL	MAJMIN	TEST.L	D0:D1		; tait-ce une lettre majuscule ?	JUMP',BC MAJ4$		; non => MAJ4$	CALL	MINMAJ		; D3 <-- caractre majuscule	TEST.W	D1	JUMP',NE MAJ4$	COMP.B	D3,#'H		; mot commence par "H" ?	JUMP',NE MAJ4$	LOAD.B	(A3+),#'h	LOAD.B	D3,#'H		; OBUNOM <-- "hH"MAJ4$:	LOAD.B	(A3+),D3	; OBUNOM <-- mot	INC.W	D1		; D1 <-- rang suivant	DEC.W	D4	JUMP,NE MAJ2$	CLR.B	(A3)	JUMP	END$OK$:	LOAD.L	A4,(A6)+OSRCPM	LOAD.L	D4,(A6)+OSRCLMOK2$:	LOAD.B	D3,(A4+)	CALL	MAJMIN	LOAD.B	(A3+),D3	; OBUNOM <-- mot	DEC.W	D4	JUMP,NE OK2$	CLR.B	(A3)END$:	LOAD.L	A3,#(A6)+OBUNOM	CALL	CODEHASP	; demande si "h" aspir ...	JUMP',NE EXIT$	COMP.W	D4,#F1	JUMP',NE EXIT$	LOAD.L	A4,A3	LOAD.L	D3,#-1END2$:	INC.L	D3		; D3 <-- lg	TEST.B	(A4+)	JUMP,NE END2$	LOAD.W	D4,#F1	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	(A6)+OSRCLM	POP.L	(A6)+OSRCPM	POPM.L	D0..D2,A4	TEST.W	D7		; retour EQ/NE	RET.IF 0;-------\\; CODEIF >;-------/; Demande s'il faut conserver un mot.; in	A2.L	^dans OTADL; out	D4.W	dernire touche (F1/F0);	D7.W	erreur; mod	D4.L, D7.WCODEIF:	PUSHM.L	D1..D3,D5,A1..A4	LOAD.L	A4,A2	LOAD.L	A2,#R16"TDBOX_CODEIF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!100	CALL	AFFMOT		; affiche le mot  encoder	LOAD.W	D2,#2^BDBGCLABEL!101	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A4)+ODLNOM	LIB	?AFTEXT		; affiche le nom du dictionnaire	LIB	?AFTIM	.ASCIZ	" ?"	.EVENLOOP$:	DBOX_	EDIT		; attend une action ...;	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_CODEIF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ END$	COMP.W	D3,#F0	JUMP',EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$END$:	LOAD.W	D4,D3		; D4 <-- dernire touche	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D1..D3,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CODEIF:	.W	10$-TDBOX_CODEIF	.W	20$-TDBOX_CODEIF	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Conserve le mot "	.B	ODBLABEL,100	.B	ODBTEXT	.ASCIZ	"                         "	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"dans le dictionnaire "	.B	ODBLABEL,101	.B	ODBTEXT	.ASCIZ	"          "	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" CONSERVE "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Conserve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CODEIF:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_CODEIF	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CODEIF	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CODEIF	.W	0.ENDIF;--------\\; CODEESP >;--------/; Choix de l'espce.; in	-; out	D4.B	espce;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WCODEESP:	PUSHM.L	D1,D2,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_CODEESP	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,#1		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!100	CALL	AFFMOT		; affiche le mot  encoder	LIB	?AFTIM	.ASCIZ	". Choisissez son espce :"	.EVEN	TEST.B	(A6)+OSRCB0+3:#0 ; premire lettre majuscule ?	JUMP',BS LOOP$		; oui => LOOP$	PUSH.L	D4	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!15	DBOX_	GETCO		; grise l'espce "nom propre"	POP.L	D4LOOP$:	DBOX_	EDIT		; attend une action ...;	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_CODEESP	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ CODE$	COMP.W	D3,#F0	JUMP',EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CODE$:	LOAD.W	D2,#-1CODE2$:	INC.W	D2	RR.L	D4,#1	JUMP,CC CODE2$	LOAD.L	A4,#R16"TABLE$	LOAD.B	D4,(A4)+(D2.W)	; D4 <-- typeEND$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.B	'm,'4,'q,'f,'n,'3,'a,'y,'5,'k	.B	'x,'w,'o,'p	.B	't,'P,0,0,0,0,0,0,0	.B	'z,'d,'6,'c,'s,'j,'b,'g,'l,'8	.EVENTDBOX_CODEESP:	.W	10$-TDBOX_CODEESP	.W	20$-TDBOX_CODEESP	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Encodage du mot "	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBTABX,55	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,0	.ASCIZ	" nom masculin"	.B	ODBTABX,30	.B	ODBLCIRCLE,14	.ASCIZ	" verbe"	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" nom masculin singulier"	.B	ODBTABX,30	.B	ODBLCIRCLE,12	.ASCIZ	" pronom"	.B	ODBCR	.B	ODBLCIRCLE,2	.ASCIZ	" nom masculin pluriel"	.B	ODBTABX,30	.B	ODBLCIRCLE,13	.ASCIZ	" dterminant (article)"	.B	ODBCR	.B	ODBLCIRCLE,4	.ASCIZ	" nom masculin ou fminin"	.B	ODBTABX,30	.B	ODBLCIRCLE,23	.ASCIZ	" prposition"	.B	ODBCR	.B	ODBLCIRCLE,3	.ASCIZ	" nom fminin"	.B	ODBTABX,30	.B	ODBLCIRCLE,24	.ASCIZ	" adverbe"	.B	ODBCR	.B	ODBLCIRCLE,5	.ASCIZ	" nom fminin pluriel"	.B	ODBTABX,30	.B	ODBLCIRCLE,25	.ASCIZ	" prposition ou adverbe"	.B	ODBCR	.B	ODBLCIRCLE,6	.ASCIZ	" adjectif"	.B	ODBTABX,30	.B	ODBLCIRCLE,26	.ASCIZ	" conjonction"	.B	ODBCR	.B	ODBLCIRCLE,7	.ASCIZ	" adjectif compos"	.B	ODBTABX,30	.B	ODBLCIRCLE,27	.ASCIZ	" subjonction"	.B	ODBCR	.B	ODBLCIRCLE,8	.ASCIZ	" adjectif invariable"	.B	ODBTABX,30	.B	ODBLCIRCLE,28	.ASCIZ	" interjection"	.B	ODBCR	.B	ODBLCIRCLE,9	.ASCIZ	" nom masculin ou adjectif"	.B	ODBTABX,30	.B	ODBLCIRCLE,29	.ASCIZ	" abrviation"	.B	ODBCR	.B	ODBLCIRCLE,10	.ASCIZ	" nom fminin ou adjectif"	.B	ODBTABX,30	.B	ODBLCIRCLE,30	.ASCIZ	" sigle"	.B	ODBCR	.B	ODBLCIRCLE,11	.ASCIZ	" nom ou adjectif"	.B	ODBTABX,30	.B	ODBLCIRCLE,31	.ASCIZ	" locution"	.B	ODBCR	.B	ODBTABX,30	.B	ODBLABEL,15	.B	ODBLCIRCLE,15	.ASCIZ	" nom propre"	.B	ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" ENCODE "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Encode"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CODEESP:	.W	F1,F2,F3,0		DOKF1-TKEY_CODEESP	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CODEESP	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CODEESP	.W	0;--------\\; CODEED4 >;--------/; Choix des quatre formes MS/MP/FS/FP.; in	D4.W	mots impossibles (bits 0..3); out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WCODEED4:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D0,D4		; D0 <-- mots griss	LOAD.L	A2,#R16"TDBOX_CODEED4	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!100	CALL	AFFMOT		; affiche le mot  encoder	LIB	?AFTIM	.ASCIZ	"."	.EVEN	CALL	CODEPUT4	LOAD.W	D2,#2^BDBGCLABEL!0	TEST.L	D0:#0	JUMP',BS CH15$	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OEDMOT1	LIB	?AFTEXT	JUMP'	CH19$CH15$:	TSET.L	D2:#BDBGCGREY	DBOX_	GETCO	CLR.B	(A6)+OEDMOT1CH19$:	LOAD.W	D2,#2^BDBGCLABEL!1	TEST.L	D0:#1	JUMP',BS CH25$	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OEDMOT2	LIB	?AFTEXT	JUMP'	CH29$CH25$:	TSET.L	D2:#BDBGCGREY	DBOX_	GETCO	CLR.B	(A6)+OEDMOT2CH29$:	LOAD.W	D2,#2^BDBGCLABEL!2	TEST.L	D0:#2	JUMP',BS CH35$	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OEDMOT3	LIB	?AFTEXT	JUMP'	CH39$CH35$:	TSET.L	D2:#BDBGCGREY	DBOX_	GETCO	CLR.B	(A6)+OEDMOT3CH39$:	LOAD.W	D2,#2^BDBGCLABEL!3	TEST.L	D0:#3	JUMP',BS CH45$	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OEDMOT4	LIB	?AFTEXT	JUMP'	CH49$CH45$:	TSET.L	D2:#BDBGCGREY	DBOX_	GETCO	CLR.B	(A6)+OEDMOT4CH49$:	LOAD.W	D2,#-1	JUMP	CR$NEWL$:	LOAD.L	A3,#(A6)+OEDMOT1	TEST.W	D2	JUMP',EQ NEWL2$	LOAD.L	A3,#(A6)+OEDMOT2	COMP.W	D2,#1	JUMP',EQ NEWL2$	LOAD.L	A3,#(A6)+OEDMOT3	COMP.W	D2,#2	JUMP',EQ NEWL2$	LOAD.L	A3,#(A6)+OEDMOT4NEWL2$:	LOAD.L	A4,A3NEWL3$:	TEST.B	(A4+)	JUMP,NE NEWL3$	DEC.L	A4	LOAD.W	D3,D2	DBOX_	MEDITLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_CODEED4	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ CODE$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ CR$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$CR$:	INC.W	D2	COMP.W	D2,#4	JUMP',LO CR2$	CLR.W	D2CR2$:	TEST.L	D0:D2		; mot gris ?	JUMP,BS CR$		; oui => CR$	JUMP	NEWL$KEYDBOX$:	LOAD.B	D2,D3	JUMP	NEWL$CODE$:	TEST.B	(A6)+OEDMOT1	JUMP',NE CODE2$	TEST.B	(A6)+OEDMOT2	JUMP',NE CODE2$	TEST.B	(A6)+OEDMOT3	JUMP',NE CODE2$	TEST.B	(A6)+OEDMOT4	JUMP,EQ BIP$CODE2$:	LOAD.L	A3,#(A6)+OEDMOT1	CALL	CHMINUS	LOAD.L	A3,#(A6)+OEDMOT2	CALL	CHMINUS	LOAD.L	A3,#(A6)+OEDMOT3	CALL	CHMINUS	LOAD.L	A3,#(A6)+OEDMOT4	CALL	CHMINUSEND$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CODEED4:	.W	10$-TDBOX_CODEED4	.W	20$-TDBOX_CODEED4	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Encodage du mot "	.B	ODBLABEL,100	.B	ODBTEXT	.ASCIZ	"                         "	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Compltez les formes suivantes :"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Masculin singulier  "	.B	ODBLABEL,0	.B	ODBLINE,LGMOTDB!2^7,KEYDBOX/H'100,0,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Masculin pluriel    "	.B	ODBLABEL,1	.B	ODBLINE,LGMOTDB!2^7,KEYDBOX/H'100,1,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Fminin singulier   "	.B	ODBLABEL,2	.B	ODBLINE,LGMOTDB!2^7,KEYDBOX/H'100,2,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Fminin pluriel     "	.B	ODBLABEL,3	.B	ODBLINE,LGMOTDB!2^7,KEYDBOX/H'100,3,TDBNORM	.B	ODBCR,ODBCR	.B	ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" ENCODE "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Encode"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CODEED4:	.W	F1,F2,F3,0		DOKF1-TKEY_CODEED4	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CODEED4	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CODEED4	.W	0;---------\\; CODEPUT4 >;---------/; Gnre les quatre mots probables.; in	D0.W	mots impossibles (bits 0..3); out	-; mod	D7.WCODEPUT4:	PUSHM.L	D1..D4,A1..A4; Cherche la terminaison du mot original.	LOAD.L	A4,#R16"TABLE$	LOAD.W	D1,#120$:	TEST.B	(A4)		; fin de la table ?	JUMP,EQ 70$		; oui => 70$	DEC.W	D1	JUMP',NE 22$	LOAD.L	A1,A4		; A1 <-- ^terminaison MS	LOAD.W	D1,#422$:	TEST.B	(A4+)		; A4 <-- ^terminaison suivante	JUMP,NE 22$	LOAD.L	A2,#(A4)-1	; A2 <-- ^fin terminaison	LOAD.L	A3,(A6)+OSRCPM	; A3 <-- ^mot original	LOAD.L	D3,(A6)+OSRCLM	; D3 <-- lg mot original	ADD.L	A3,D324$:	LOAD.B	D2,(-A2)	JUMP',EQ 26$	DEC.L	D3	JUMP,NS 20$	COMP.B	D2,(-A3)	JUMP,EQ 24$	JUMP	20$26$:	INC.L	A2	LOAD.L	D2,#-127$:	INC.L	D2		; D2 <-- longueur de la terminaison	TEST.B	(A2+)	JUMP,NE 27$; Gnre le masculin singulier.	LOAD.L	A3,(A6)+OSRCPM	LOAD.L	D3,(A6)+OSRCLM	SUB.L	D3,D2	LOAD.L	A4,#(A6)+OEDMOT130$:	LOAD.B	(A4+),(A3+)	; OEDMOT1 <-- dbut du mot	DEC.W	D3	JUMP,NE 30$32$:	LOAD.B	(A4+),(A1+)	; OEDMOT1 <-- terminaison MS	JUMP,NE 32$; Gnre le masculin pluriel.	LOAD.L	A3,(A6)+OSRCPM	LOAD.L	D3,(A6)+OSRCLM	SUB.L	D3,D2	LOAD.L	A4,#(A6)+OEDMOT240$:	LOAD.B	(A4+),(A3+)	; OEDMOT2 <-- dbut du mot	DEC.W	D3	JUMP,NE 40$42$:	LOAD.B	(A4+),(A1+)	; OEDMOT2 <-- terminaison MP	JUMP,NE 42$; Gnre le fminin singulier.	LOAD.L	A3,(A6)+OSRCPM	LOAD.L	D3,(A6)+OSRCLM	SUB.L	D3,D2	LOAD.L	A4,#(A6)+OEDMOT350$:	LOAD.B	(A4+),(A3+)	; OEDMOT3 <-- dbut du mot	DEC.W	D3	JUMP,NE 50$52$:	LOAD.B	(A4+),(A1+)	; OEDMOT3 <-- terminaison FS	JUMP,NE 52$; Gnre le fminin pluriel.	LOAD.L	A3,(A6)+OSRCPM	LOAD.L	D3,(A6)+OSRCLM	SUB.L	D3,D2	LOAD.L	A4,#(A6)+OEDMOT460$:	LOAD.B	(A4+),(A3+)	; OEDMOT4 <-- dbut du mot	DEC.W	D3	JUMP,NE 60$62$:	LOAD.B	(A4+),(A1+)	; OEDMOT4 <-- terminaison FP	JUMP,NE 62$	COMP.W	D0,#B'0011	JUMP,NE 90$	LOAD.L	A3,#(A6)+OEDMOT1	LOAD.L	A4,#(A6)+OEDMOT366$:	LOAD.B	(A4+),(A3+)	; OEDMOT3 <-- mot MS	JUMP,NE 66$	LOAD.L	A3,#(A6)+OEDMOT2	LOAD.L	A4,#(A6)+OEDMOT467$:	LOAD.B	(A4+),(A3+)	; OEDMOT4 <-- mot MP	JUMP,NE 67$	JUMP	90$; Gnre les quatre formes standards.70$:	LOAD.L	A3,(A6)+OSRCPM	LOAD.L	D3,(A6)+OSRCLM	LOAD.L	A4,#(A6)+OEDMOT172$:	LOAD.B	(A4+),(A3+)	; OEDMOT1 <-- MS	DEC.W	D3	JUMP,NE 72$	CLR.B	(A4)	LOAD.L	A3,(A6)+OSRCPM	LOAD.L	D3,(A6)+OSRCLM	LOAD.L	A4,#(A6)+OEDMOT273$:	LOAD.B	(A4+),(A3+)	; OEDMOT2 <-- MS	DEC.W	D3	JUMP,NE 73$	CLR.B	(A4)	LOAD.L	A3,(A6)+OSRCPM	LOAD.L	D3,(A6)+OSRCLM	LOAD.L	A4,#(A6)+OEDMOT374$:	LOAD.B	(A4+),(A3+)	; OEDMOT3 <-- MS	DEC.W	D3	JUMP,NE 74$	CLR.B	(A4)	LOAD.L	A3,(A6)+OSRCPM	LOAD.L	D3,(A6)+OSRCLM	LOAD.L	A4,#(A6)+OEDMOT475$:	LOAD.B	(A4+),(A3+)	; OEDMOT4 <-- MS	DEC.W	D3	JUMP,NE 75$	CLR.B	(A4)90$:	POPM.L	D1..D4,A1..A4	RET	.B	0TABLE$:	.ASCIZ	"eux"	.ASCIZ	"eux"	.ASCIZ	"euse"	.ASCIZ	"euses"	.ASCIZ	"teur"	.ASCIZ	"teurs"	.ASCIZ	"trice"	.ASCIZ	"trices"	.ASCIZ	"eur"	.ASCIZ	"eurs"	.ASCIZ	"euse"	.ASCIZ	"euses"	.ASCIZ	"eau"	.ASCIZ	"eaux"	.ASCIZ	"elle"	.ASCIZ	"elles"	.ASCIZ	"at"	.ASCIZ	"ats"	.ASCIZ	"ate"	.ASCIZ	"ates"	.ASCIZ	"gu"	.ASCIZ	"gus"	.ASCIZ	"gu"	.ASCIZ	"gus"	.ASCIZ	"ou"	.ASCIZ	"ous"	.ASCIZ	"olle"	.ASCIZ	"olles"	.ASCIZ	"el"	.ASCIZ	"els"	.ASCIZ	"elle"	.ASCIZ	"elles"	.ASCIZ	"ul"	.ASCIZ	"uls"	.ASCIZ	"ulle"	.ASCIZ	"ulles"	.ASCIZ	"eil"	.ASCIZ	"eils"	.ASCIZ	"eille"	.ASCIZ	"eilles"	.ASCIZ	"en"	.ASCIZ	"ens"	.ASCIZ	"enne"	.ASCIZ	"ennes"	.ASCIZ	"on"	.ASCIZ	"ons"	.ASCIZ	"onne"	.ASCIZ	"onnes"	.ASCIZ	"et"	.ASCIZ	"ets"	.ASCIZ	"ette"	.ASCIZ	"ettes"	.ASCIZ	"ot"	.ASCIZ	"ots"	.ASCIZ	"otte"	.ASCIZ	"ottes"	.ASCIZ	"er"	.ASCIZ	"ers"	.ASCIZ	"re"	.ASCIZ	"res"	.ASCIZ	"oux"	.ASCIZ	"oux"	.ASCIZ	"ouse"	.ASCIZ	"ouses"	.ASCIZ	"nc"	.ASCIZ	"ncs"	.ASCIZ	"nche"	.ASCIZ	"nches"	.ASCIZ	"in"	.ASCIZ	"ins"	.ASCIZ	"igne"	.ASCIZ	"ignes"	.ASCIZ	"au"	.ASCIZ	"aux"	.ASCIZ	"aude"	.ASCIZ	"audes"	.ASCIZ	"al"	.ASCIZ	"aux"	.ASCIZ	"ale"	.ASCIZ	"ales"	.ASCIZ	"el"	.ASCIZ	"els"	.ASCIZ	"elle"	.ASCIZ	"elles"	.ASCIZ	"if"	.ASCIZ	"ifs"	.ASCIZ	"ive"	.ASCIZ	"ives"	.ASCIZ	"a"	.ASCIZ	"as"	.ASCIZ	"ate"	.ASCIZ	"ates"	.ASCIZ	"b"	.ASCIZ	"bs"	.ASCIZ	"be"	.ASCIZ	"bes"	.ASCIZ	"c"	.ASCIZ	"cs"	.ASCIZ	"ce"	.ASCIZ	"ces"	.ASCIZ	"d"	.ASCIZ	"ds"	.ASCIZ	"de"	.ASCIZ	"des"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	"f"	.ASCIZ	"fs"	.ASCIZ	"fe"	.ASCIZ	"fes"	.ASCIZ	"g"	.ASCIZ	"gs"	.ASCIZ	"ge"	.ASCIZ	"ges"	.ASCIZ	"h"	.ASCIZ	"hs"	.ASCIZ	"he"	.ASCIZ	"hes"	.ASCIZ	"i"	.ASCIZ	"is"	.ASCIZ	"ie"	.ASCIZ	"ies"	.ASCIZ	"j"	.ASCIZ	"js"	.ASCIZ	"je"	.ASCIZ	"jes"	.ASCIZ	"k"	.ASCIZ	"ks"	.ASCIZ	"ke"	.ASCIZ	"kes"	.ASCIZ	"l"	.ASCIZ	"ls"	.ASCIZ	"le"	.ASCIZ	"les"	.ASCIZ	"m"	.ASCIZ	"ms"	.ASCIZ	"me"	.ASCIZ	"mes"	.ASCIZ	"n"	.ASCIZ	"ns"	.ASCIZ	"ne"	.ASCIZ	"nes"	.ASCIZ	"o"	.ASCIZ	"os"	.ASCIZ	"o"	.ASCIZ	"os"	.ASCIZ	"p"	.ASCIZ	"ps"	.ASCIZ	"pe"	.ASCIZ	"pes"	.ASCIZ	"q"	.ASCIZ	"qs"	.ASCIZ	"qe"	.ASCIZ	"qes"	.ASCIZ	"r"	.ASCIZ	"rs"	.ASCIZ	"re"	.ASCIZ	"res"	.ASCIZ	"s"	.ASCIZ	"s"	.ASCIZ	"se"	.ASCIZ	"ses"	.ASCIZ	"t"	.ASCIZ	"ts"	.ASCIZ	"te"	.ASCIZ	"tes"	.ASCIZ	"u"	.ASCIZ	"us"	.ASCIZ	"ue"	.ASCIZ	"ues"	.ASCIZ	"v"	.ASCIZ	"vs"	.ASCIZ	"ve"	.ASCIZ	"ves"	.ASCIZ	"w"	.ASCIZ	"ws"	.ASCIZ	"we"	.ASCIZ	"wes"	.ASCIZ	"x"	.ASCIZ	"x"	.ASCIZ	"xe"	.ASCIZ	"xes"	.ASCIZ	"y"	.ASCIZ	"ys"	.ASCIZ	"ye"	.ASCIZ	"yes"	.ASCIZ	"z"	.ASCIZ	"z"	.ASCIZ	"ze"	.ASCIZ	"zes"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	"e"	.ASCIZ	"es"	.ASCIZ	""	.ASCIZ	"s"	.ASCIZ	"e"	.ASCIZ	"es"	.B	0	.EVEN;---------\\; CODEMOT4 >;---------/; Code les quatre mots le mieux possible.; in	A3.L	^buffer;	D2.B	type; out	-; mod	D7.WCODEMOT4:	PUSHM.L	D2..D4,A0..A4; Regarde, dans les quatre chanes, jusqu'o elles sont; toutes semblables.	CLR.W	D4	LOAD.L	A0,#(A6)+OEDMOT1	TEST.B	(A0)	JUMP',NE CH11$	LOAD.L	A0,#0	TSET.L	D4:#0CH11$:	LOAD.L	A1,#(A6)+OEDMOT2	TEST.B	(A1)	JUMP',NE CH12$	LOAD.L	A1,#0	TSET.L	D4:#1CH12$:	LOAD.L	A2,#(A6)+OEDMOT3	TEST.B	(A2)	JUMP',NE CH13$	LOAD.L	A2,#0	TSET.L	D4:#2CH13$:	LOAD.L	A4,#(A6)+OEDMOT4	TEST.B	(A4)	JUMP',NE CH14$	LOAD.L	A4,#0	TSET.L	D4:#3CH14$:	CLR.W	D1		; D1 <-- nombre de caractres identiquesCH2$:	COMP.L	A0,#0	JUMP',EQ CH21$	LOAD.B	D3,(A0)	JUMP'	CH24$CH21$:	COMP.L	A1,#0	JUMP',EQ CH22$	LOAD.B	D3,(A1)	JUMP'	CH24$CH22$:	COMP.L	A2,#0	JUMP',EQ CH23$	LOAD.B	D3,(A2)	JUMP'	CH24$CH23$:;	COMP.L	A4,#0;	JUMP',EQ CH24$	LOAD.B	D3,(A4);	JUMP'	CH24$CH24$:	COMP.L	A0,#0	JUMP',EQ CH31$	COMP.B	D3,(A0+)	JUMP',NE CH4$CH31$:	COMP.L	A1,#0	JUMP',EQ CH32$	COMP.B	D3,(A1+)	JUMP',NE CH4$CH32$:	COMP.L	A2,#0	JUMP',EQ CH33$	COMP.B	D3,(A2+)	JUMP',NE CH4$CH33$:	COMP.L	A4,#0	JUMP',EQ CH34$	COMP.B	D3,(A4+)	JUMP',NE CH4$CH34$:	INC.W	D1		; D1 <-- un caractre de plus	JUMP	CH2$CH4$:; Dbranchement selon le type.	COMP.B	D2,#'m	JUMP',NE TYPE2$	COMP.W	D4,#B'1100	JUMP,EQ MASC$TYPE2$:	COMP.B	D2,#'f	JUMP',NE TYPE3$	COMP.W	D4,#B'0011	JUMP,EQ FEM$TYPE3$:	TEST.W	D4	JUMP,EQ ADJ$	JUMP	SPEC$; Nom masculin.MASC$:	LOAD.L	A4,#(A6)+OEDMOT1 ; MS termin par "" ?	ADD.W	A4,D1	TEST.B	(A4)	JUMP,NE SPEC$	LOAD.L	A4,#(A6)+OEDMOT2 ; MP termin par "s" ?	ADD.W	A4,D1	COMP.B	(A4+),#'s	JUMP,NE SPEC$	TEST.B	(A4)	JUMP,NE SPEC$	LOAD.L	A4,#(A6)+OEDMOT1MASC2$:	LOAD.B	(A3+),(A4+)	JUMP,NE MASC2$	JUMP	EXIT$; Nom fminin.FEM$:	LOAD.L	A4,#(A6)+OEDMOT3 ; FS termin par "" ?	ADD.W	A4,D1	TEST.B	(A4)	JUMP,NE SPEC$	LOAD.L	A4,#(A6)+OEDMOT4 ; FP termin par "s" ?	ADD.W	A4,D1	COMP.B	(A4+),#'s	JUMP,NE SPEC$	TEST.B	(A4)	JUMP,NE SPEC$	LOAD.L	A4,#(A6)+OEDMOT3FEM2$:	LOAD.B	(A3+),(A4+)	JUMP,NE FEM2$	JUMP	EXIT$; Adjectif.ADJ$:	LOAD.L	A4,#(A6)+OEDMOT1 ; MS termin par "" ?	ADD.W	A4,D1	TEST.B	(A4)	JUMP,NE SPEC$	LOAD.L	A4,#(A6)+OEDMOT2 ; MP termin par "s" ?	ADD.W	A4,D1	COMP.B	(A4+),#'s	JUMP,NE SPEC$	TEST.B	(A4)	JUMP,NE SPEC$	LOAD.L	A4,#(A6)+OEDMOT3 ; FS termin par "" ?	ADD.W	A4,D1	TEST.B	(A4)	JUMP,NE ADJ4$	LOAD.L	A4,#(A6)+OEDMOT4 ; FP termin par "s" ?	ADD.W	A4,D1	COMP.B	(A4+),#'s	JUMP,NE ADJ4$	TEST.B	(A4)	JUMP,NE ADJ4$	LOAD.L	A4,#(A6)+OEDMOT1ADJ2$:	LOAD.B	(A3+),(A4+)	JUMP,NE ADJ2$	DEC.L	A3	LOAD.B	(A3+),#']	CLR.B	(A3)	JUMP	EXIT$ADJ4$:	LOAD.L	A4,#(A6)+OEDMOT3 ; FS termin par "e" ?	ADD.W	A4,D1	COMP.B	(A4+),#'e	JUMP,NE SPEC$	TEST.B	(A4)	JUMP,NE SPEC$	LOAD.L	A4,#(A6)+OEDMOT4 ; FP termin par "es" ?	ADD.W	A4,D1	COMP.B	(A4+),#'e	JUMP,NE SPEC$	COMP.B	(A4+),#'s	JUMP,NE SPEC$	TEST.B	(A4)	JUMP,NE SPEC$	LOAD.L	A4,#(A6)+OEDMOT1ADJ5$:	LOAD.B	(A3+),(A4+)	JUMP,NE ADJ5$	DEC.L	A3	LOAD.B	(A3+),#'$	LOAD.B	(A3+),#'s	LOAD.B	(A3+),#',	CLR.B	(A3)	JUMP	EXIT$; Met les quatre mots spars par des barres verticales.SPEC$:	CLR.B	D3	LOAD.L	A4,#(A6)+OEDMOT1	CALL	SPUT$	LOAD.L	A4,#(A6)+OEDMOT2	CALL	SPUT$	LOAD.L	A4,#(A6)+OEDMOT3	CALL	SPUT$	LOAD.L	A4,#(A6)+OEDMOT4	CALL	SPUT$	CLR.B	(A3)EXIT$:	POPM.L	D2..D4,A0..A4	RET; in	D3.B	caractre initial/zro;	A4.L	^mot <0>;	A3.L	^buffer; out	A3.L	^plus loin;	D3.B	caractre initial; mod	D3.L, A3.L, A4.LSPUT$:	TEST.B	(A4)		; mot existe ?	JUMP',EQ SPUT9$		; non => SPUT9$	TEST.B	D3	JUMP',EQ SPUT2$	LOAD.B	(A3+),D3	; buffer <-- caractre initialSPUT2$:	LOAD.B	(A3+),(A4+)	; buffer <-- mot	JUMP,NE SPUT2$	DEC.L	A3	LOAD.B	D3,#'|SPUT9$:	RET;----------\\; CODEVERBE >;----------/; Choix de l'infinitif d'un verbe.; in	-; out	D3.W	dernire touche (F1/F0);	A4.L	^type de conjugaison;	D2.B	type du verbe;	D7.W	erreur; mod	D2.L, D3.L, D7.W, A4.LCODEVERBE:	PUSHM.L	D1,D4,D5,A1..A3	LOAD.L	A2,#R16"TDBOX_CODEVERBE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,#2^16!2^0	; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!100	CALL	AFFMOT		; affiche le mot  encoder	LIB	?AFTIM	.ASCIZ	"."	.EVEN	LOAD.L	A3,(A6)+OSRCPM	LOAD.L	D3,(A6)+OSRCLM	LOAD.L	A4,#(A6)+OEDMOT1CH2$:	LOAD.B	(A4+),(A3+)	DEC.W	D3	JUMP,NE CH2$	CLR.B	(A4)	LOAD.L	A3,#(A6)+OEDMOT1LOOP$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_CODEVERBE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ CODE$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$KEYDBOX$:	LOAD.L	D1,#H'FFFF0000	COMP.B	D3,#16	JUMP',LO KEYDBOX2$	SWAP.W	D1KEYDBOX2$:	AND.L	D4,D1	TSET.L	D4:D3	JUMP	LOOP$CODE$:	TEST.B	(A3)	JUMP,EQ BIP$	CALL	CHMINUS	LOAD.B	D2,#'v	TEST.L	D4:#19	JUMP',BS CODE1$	LOAD.B	D2,#'r	TEST.L	D4:#18	JUMP',BS CODE1$	LOAD.B	D2,#'i	TEST.L	D4:#17	JUMP',BS CODE1$	LOAD.B	D2,#'tCODE1$:	LOAD.L	A4,#R16"TABLE$CODE2$:	RR.L	D4,#1	JUMP',CS END$CODE3$:	TEST.B	(A4+)	JUMP,NE CODE3$	JUMP	CODE2$END$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D1,D4,D5,A1..A3	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.ASCIZ	""	.ASCIZ	""	.ASCIZ	"003"	.ASCIZ	"01A"	.ASCIZ	"01B"	.ASCIZ	"02A"	.ASCIZ	"02B"	.ASCIZ	"03A"	.ASCIZ	"03B"	.ASCIZ	"04A"	.ASCIZ	"04B"	.ASCIZ	"05A"	.ASCIZ	"05B"	.ASCIZ	"05C"	.EVENTDBOX_CODEVERBE:	.W	10$-TDBOX_CODEVERBE	.W	20$-TDBOX_CODEVERBE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Encodage du verbe "	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBTABX,36	.B	ODBLCIRCLE,16!2^7!2^6,KEYDBOX/H'100,16	.ASCIZ	" transitif"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Donnez l'infinitif :"	.B	ODBTABX,36	.B	ODBLCIRCLE,17!2^7!2^6,KEYDBOX/H'100,17	.ASCIZ	" intransitif"	.B	ODBCR	.B	ODBTABX,36	.B	ODBLCIRCLE,18!2^7!2^6,KEYDBOX/H'100,18	.ASCIZ	" pronominal"	.B	ODBCR	.B	ODBLINE,LGMOTDB	.B	ODBTABX,36	.B	ODBLCIRCLE,19!2^7!2^6,KEYDBOX/H'100,19	.ASCIZ	" impersonnel"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Rgulier:"	.B	ODBTABX,12	.B	ODBTEXT	.ASCIZ	"Irrgulier:"	.B	ODBCR	.B	ODBLCIRCLE,0!2^7!2^6,KEYDBOX/H'100,0	.ASCIZ	" chanter"	.B	ODBTABX,12	.B	ODBLCIRCLE,2!2^7!2^6,KEYDBOX/H'100,2	.ASCIZ	" agrger"	.B	ODBTABX,24	.B	ODBLCIRCLE,6!2^7!2^6,KEYDBOX/H'100,6	.ASCIZ	" acheter"	.B	ODBTABX,36	.B	ODBLCIRCLE,10!2^7!2^6,KEYDBOX/H'100,10	.ASCIZ	" manger"	.B	ODBCR	.B	ODBLCIRCLE,1!2^7!2^6,KEYDBOX/H'100,1	.ASCIZ	" finir"	.B	ODBTABX,12	.B	ODBLCIRCLE,3!2^7!2^6,KEYDBOX/H'100,3	.ASCIZ	" appeler"	.B	ODBTABX,24	.B	ODBLCIRCLE,7!2^7!2^6,KEYDBOX/H'100,7	.ASCIZ	" rvler"	.B	ODBTABX,36	.B	ODBLCIRCLE,11!2^7!2^6,KEYDBOX/H'100,11	.ASCIZ	" nettoyer"	.B	ODBCR	.B	ODBTABX,12	.B	ODBLCIRCLE,4!2^7!2^6,KEYDBOX/H'100,4	.ASCIZ	" peler"	.B	ODBTABX,24	.B	ODBLCIRCLE,8!2^7!2^6,KEYDBOX/H'100,8	.ASCIZ	" semer"	.B	ODBTABX,36	.B	ODBLCIRCLE,12!2^7!2^6,KEYDBOX/H'100,12	.ASCIZ	" envoyer"	.B	ODBCR	.B	ODBTABX,12	.B	ODBLCIRCLE,5!2^7!2^6,KEYDBOX/H'100,5	.ASCIZ	" jeter"	.B	ODBTABX,24	.B	ODBLCIRCLE,9!2^7!2^6,KEYDBOX/H'100,9	.ASCIZ	" placer"	.B	ODBTABX,36	.B	ODBLCIRCLE,13!2^7!2^6,KEYDBOX/H'100,13	.ASCIZ	" payer"	.B	ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" ENCODE "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Encode"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CODEVERBE:	.W	F1,F2,F3,0		DOKF1-TKEY_CODEVERBE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CODEVERBE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CODEVERBE	.W	0;---------\\; CODEHASP >;---------/; Demande si le mot commence par un "h" aspir.; in	A3.L	^mot cod; out	D4.W	dernire touche (F1/F0);	D7.W	erreur; mod	D4.L, D7.WCODEHASP:	PUSHM.L	D1..D3,D5,A1..A4	CLR.W	D7	LOAD.W	D4,#F1	COMP.B	(A3)+1,#'h	; mot commence par "h" ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.L	A2,#R16"TDBOX_CODEHASP	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,#2^0		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...;	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_CODEHASP	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ CODE$	COMP.W	D3,#F0	JUMP',EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CODE$:	TEST.L	D4:#1	JUMP',BC END$	LOAD.B	(A3)+1,#'HEND$:	LOAD.W	D4,D3		; D4 <-- dernire touche	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D1..D3,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CODEHASP:	.W	10$-TDBOX_CODEHASP	.W	20$-TDBOX_CODEHASP	.W	0,010$:	.B	ODBLCIRCLE,0	.ASCIZ	/ "h" muet    (l'homme)/	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	/ "h" aspir  (le hros)/	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" ENCODE "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Encode"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CODEHASP:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_CODEHASP	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CODEHASP	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CODEHASP	.W	0;--------\\; CHMINUS >;--------/; Enlve toutes les majuscules d'une chane.; in	A3.L	^chane <0>; out	-; mod	D7.WCHMINUS:	PUSHM.L	D3,A320$:	LOAD.B	D3,(A3)	JUMP',EQ 90$	CALL	MAJMIN	LOAD.B	(A3+),D3	JUMP	20$90$:	POPM.L	D3,A3	RET	.END