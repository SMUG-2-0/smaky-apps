21000 -- =====================================================================21010 --21020 -- Module de dcodage (C) jmCRAUSAZ21030 --21040 -- =====================================================================21050 -- ***** Dcodage d'un verbe lu sur un fichier-source *.DICO21060 -- ***** Le mot brut lu sur *.DICO  est pass par LLIGN$ dans le21070 -- *****                            prsent module21080 -- ***** Retourne 3 paramtres par variable :21090 -- *****    - @INFINIT$ : > forme de l'infinitif21100 -- *****    - @NOCONJ$  : > no de la conjugaison [cf DOC et LAROUSSE]21110 -- *****                    ...ou 'ER' / 'IR' pour les verbes rguliers21120 -- *****    - @AUXILI$  : > auxiliaire utilis par le verbe :21130 -- *****                    - 'A' ---> auxiliaire AVOIR21140 -- *****                    - 'E' ---> auxiliaire ETRE21150 -- *****                    - '2' ---> auxiliaires AVOIR ou ETRE21160 -- =====================================================================21170 --21180 Label_DECODVER(LLIGN$, @INFINIT$, @NOCONJ$, @AUXILI$)21190 --21200   Select Left$(LLIGN$,1)21210     Case 't','i','u','r','1','2','h','v','7' : Let ESPECE = 121220     Case Else : Let ESPECE = 021230   End Select21240   If ESPECE = 0 Then Return21250   Let INITLOCA$ = Left$(LLIGN$,1)21260   Let LLIGN$ = Butleft$(LLIGN$,1)21270   Let LONG% = Len(LLIGN$) : Let ITER% = LONG% + 121280   Let VIRGULE% = 0 : Let RECOMM% = 021290   Loop21300     Dec ITER%21310     Exit If ITER% = 021320     If Mid$(LLIGN$, ITER%, 1) = Chr$(44) Then Inc VIRGULE%21330     Exit If VIRGULE% = 121340   End Loop21350   Select VIRGULE%21360     Case 121370       Select LONG% - ITER%21380         Case 121390           Let @AUXILI$ = Right$(LLIGN$,1)21400         Case 221410           Let @AUXILI$ = '2'21420       End Select21430       Let LLIGN$ = Butright$(LLIGN$, LONG% - ITER% + 1)21440       Let RECOMM% = 121450       Let VIRGULE% = 021460     Case 021470       Select Asc(Left$(Right$(LLIGN$,2),1))21480         Case 48..5721490           Let @INFINIT$ = Butright$(LLIGN$,3)21500           Let @NOCONJ$ = Right$(LLIGN$,3)21510         Case Else21520           Let @INFINIT$ = LLIGN$21530           Let @NOCONJ$ = Upper$(Right$(LLIGN$,3))21540       End Select21550       Do If RECOMM% = 121560         Let RECOMM% = 021570       Do Else21580         Let @AUXILI$ = 'A'21590       End Do21600   End Select21610   If RECOMM% = 1 Then 2135021620   Select Right$(@NOCONJ$,2)21630     Case 'ER' : Let @NOCONJ$ = '001'21640     Case 'IR' : Let @NOCONJ$ = '11A'21650   End Select21660   Do If Left$(@INFINIT$,1) = 'H'21670     Let @INFINIT$ = 'h' + Butleft$(@INFINIT$,1)21680   End Do21690   Do If INITLOCA$ = 'r'21700     Select Left$(LLIGN$,1)21710       Case 'h'21720         Let @INFINIT$ = "s'" + @INFINIT$21730       Case Else21740         Select Upper$(Left$(LLIGN$,1))21750           Case 'A', 'E', 'I', 'O', 'U', 'Y'21760             Let @INFINIT$ = "s'" + @INFINIT$21770           Case Else21780             Let @INFINIT$ = 'se ' + @INFINIT$21790         End Select21800     End Select21810   End Do21820 Return