	.SBTTL	DICOSYN.ASI;--------\\; SYNBASE >;========/; Cherche le mot de base, dans sa forme la plus simple, c'est--dire :;	nom		-->	singulier;	adjectif	-->	masculin singulier;	verbe		-->	infinitif; in	A4/D4.L		^synonyme/lg;	(A6)+OSYBR.W	rang du mot de base (0..n); out	(A6)+OSYBM	mot de base <0>;	(A6)+OSYBL.L	lg mot de base;	(A6)+OSYBF.W	forme (0..n);	(A6)+OSYBT.B	type;	D7.W		erreur; mod	D7.WSYNBASE:	PUSHM.L	D0..D4,A3,A4	LOAD.W	D2,#2		; D2 <-- deux lettres de sres	CALL	SEARCHINIT	; initialise pour la recherche	JUMP',NE 90$	LOAD.B	D0,#-1	LOAD.W	D1,(A6)+OSYBR20$:	CLR.W	D2		; D2 <-- accepte seulement si exact	CLR.B	(A6)+OCHFST	; ne stoppe pas	CALL	SEARCHNEXT	; chercle le mot suivant	JUMP',NE 90$	LOAD.B	(A6)+OSYBT,D3	; OSYBT <-- type	LOAD.W	(A6)+OSYBF,D4	; OSYBF <-- forme	COMP.B	D3,D0		; mot de mme type ?	JUMP,EQ 20$		; oui => 20$	LOAD.B	D0,D3	DEC.W	D1	JUMP,NC 20$	CLR.W	D4		; D4 <-- forme de base	LOAD.L	A3,#(A6)+OSYBM	; A3 <-- ^buffer pour mot en clair	LOAD.L	A4,#(A6)+OSRCMD	; A4 <-- ^mot cod	CALL	SEARCHMOT	; cherche la forme de base	JUMP',NE 90$	LOAD.L	D4,#-140$:	INC.L	D4	TEST.B	(A3+)	JUMP,NE 40$	LOAD.L	(A6)+OSYBL,D4	; OSYBL <-- lg mot de base90$:	POPM.L	D0..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; SYNFORME >;=========/; Transforme (accorde ou conjugue) un synonyme  la mme forme; que le mot initial trouv.; Si le synonyme est compos de plusieurs mots, transforme le; premier qui peut l'tre :;	s'en aller de		-->	s'en ira de;	laisser tomber		-->	laissera tomber;	faire fausse route	-->	fera fausse route; in	A3.L	^mot de base; out	A4/D4	^mot transform/lg; mod	D4.L, D7.W, A4.LSYNFORME:	PUSHM.L	D3,D5,A2,A3	COMP.B	(A3),#'$	JUMP',NE 10$	INC.L	A3		; A3 <-- saute le "$"10$:	LOAD.L	A4,#(A6)+OBUMOT+10	CLR.W	D5	JUMP'	22$20$:	LOAD.B	(A4+),(A3)-1	; OBUMOT <-- espace ou apostrophe22$:	CALL	SYNFORMEONE	; OBUMOT <-- une partie du mot	JUMP',NE 30$	CLR.W	(A6)+OSYBF	; qu'une seule transformation !30$:	TEST.B	(A3)		; encore un mot ?	JUMP,NE 20$		; oui => 20$	LOAD.L	D4,A4	LOAD.L	A4,#(A6)+OBUMOT+10 ; A4 <-- ^mot	SUB.L	D4,A4		; D4 <-- lg mot; Si le mot accord est une forme verbale, transforme encore les; "se" en "te" ou selon la personne (je/tu/il/nous/vous/ils).	DEC.W	D5	JUMP,NS 90$	LOAD.L	A3,#R16"TSE$	LOAD.L	D3,(A4)	AND.L	D3,#H'FFFFFF00	COMP.L	D3,#H'1000000*'s+H'10000*'e+H'100*SPACE ; verbe commence par "se " ?	JUMP',EQ 40$	LOAD.L	A3,#R16"TSAP$	COMP.W	(A4),#H'100*'s+'' ; verbe commence par "s'" ?	JUMP,NE 90$40$:	AND.L	D5,#H'FFFF	DIV.WU	D5,#6	SWAP.W	D5		; D5 <-- personne (0..5)42$:	DEC.W	D5	JUMP',NS 46$44$:	TEST.B	(A3+)		; A3 <-- ^"me", "te", etc.  insrer	JUMP,NE 44$	JUMP	42$46$:	LOAD.L	A2,A3	LOAD.W	D3,#-148$:	INC.W	D3		; D3 <-- lg "me", "te", etc.  insrer	TEST.B	(A2+)	JUMP,NE 48$	ADD.W	A4,#2		; A4 <-- enlve le "se" ou "s'"	SUB.W	D4,#2	SUB.W	A4,D3		; A4 <-- place pour "me", "te", etc.	ADD.W	D4,D3	LOAD.L	A2,A450$:	LOAD.B	(A2+),(A3+)	; OBUMOT <-- "me", "te", etc.	DEC.W	D3	JUMP,NE 50$90$:	POPM.L	D3,D5,A2,A3	RETTSE$:	.ASCIZ	"me"		; je me dplace	.ASCIZ	"te"		; tu te dplaces	.ASCIZ	"se"		; il se dplace	.ASCIZ	"se"		; ils se dplacent	.ASCIZ	"nous"		; nous nous dplaons	.ASCIZ	"vous"		; vous vous dplacezTSAP$:	.ASCIZ	"m'"		; je m'en vais	.ASCIZ	"t'"		; tu t'en vas	.ASCIZ	"s'"		; il s'en va	.ASCIZ	"s'"		; ils s'en vont	.ASCIZ	"nous "		; nous nous en allons	.ASCIZ	"vous "		; vous vous en allez	.EVEN;------------\\; SYNFORMEONE >;------------/; Transforme (accorde ou conjugue) un synonyme  la mme forme; que le mot initial trouv.; in	A3.L	^mot;	A4.L	^buffer pour mot transform;	D5.W	dernire forme/nil; out	A3.L	^mot suivant;	A4.L	^plus loin;	D5.W	forme si verbe;	D7.W	erreur si pas de transformation; mod	D5.L, D7.W, A3.L, A4.LSYNFORMEONE:	PUSHM.L	D1..D4,A1,A2	LOAD.L	A1,A4		; A1 <-- ^buffer	LOAD.L	A2,A3		; A2 <-- ^dbut mot	LOAD.L	A4,A3	LOAD.L	D1,#-120$:	INC.L	D1		; D1 <-- longueur du mot	LOAD.B	D3,(A4+)	JUMP',EQ 22$	COMP.B	D3,#SPACE	JUMP',EQ 22$	COMP.B	D3,#''	JUMP,NE 20$22$:	TEST.W	(A6)+OSYBF	; forme zro ?	JUMP,EQ 70$		; oui => 70$	LOAD.L	A4,A2		; A4 <-- ^mot	LOAD.L	D4,D1		; D4 <-- lg mot	LOAD.W	D2,#2		; D2 <-- deux lettres de sres	CALL	SEARCHINIT	; initialise pour la recherche	JUMP,NE 70$	CLR.W	D2		; D2 <-- accepte seulement si exact	CLR.B	(A6)+OCHFST	; ne stoppe pas	CALL	SEARCHNEXT	JUMP,NE 70$	SET.B	(A6)+OCJQQ	; cherche n'importe quelle forme	LOAD.W	D4,(A6)+OSYBF	; D4 <-- forme souhaite	LOAD.L	A3,A1		; A3 <-- ^buffer pour mot en clair	LOAD.L	A4,#(A6)+OSRCMD	; A4 <-- ^mot cod	CALL	SEARCHMOT	; cherche la bonne forme	CLR.B	(A6)+OCJQQ	; remet le mode normal	TEST.W	D7	JUMP',EQ 50$	COMP.W	D4,#2	JUMP',EQ 40$	COMP.W	D4,#3	JUMP',NE 70$40$:	LOAD.B	D3,(A4)		; D3 <-- type	COMP.B	D3,#'a	JUMP',EQ 42$	COMP.B	D3,#'y		; adjectif ?	JUMP',EQ 42$		; oui => 42$	COMP.B	D3,#'k	JUMP',EQ 42$	COMP.B	D3,#'x	JUMP',EQ 42$	COMP.B	D3,#'w	JUMP',NE 70$42$:	SET.B	(A6)+OCJQQ	; cherche n'importe quelle forme	SUB.W	D4,#2		; D4 <-- forme souhaite (F -> M)	CALL	SEARCHMOT	; cherche la forme au masculin	CLR.B	(A6)+OCJQQ	; remet le mode normal	TEST.W	D7	JUMP',NE 70$50$:	LOAD.B	D3,(A4)		; D3 <-- type	COMP.B	D3,#'t	JUMP',EQ 52$	COMP.B	D3,#'i		; verbe ?	JUMP',EQ 52$		; oui => 52$	COMP.B	D3,#'u	JUMP',EQ 52$	COMP.B	D3,#'r	JUMP',EQ 52$	COMP.B	D3,#'1	JUMP',EQ 52$	COMP.B	D3,#'2	JUMP',EQ 52$	COMP.B	D3,#'h	JUMP',EQ 52$	COMP.B	D3,#'v	JUMP',EQ 52$	COMP.B	D3,#'7	JUMP',NE 56$52$:	LOAD.W	D5,D4		; D5 <-- forme du verbe56$:	TEST.B	(A1+)	JUMP,NE 56$	DEC.L	A1	ADD.W	A2,D1	CLR.W	D7		; D7 <-- transformation ok	JUMP'	80$70$:	LOAD.B	(A1+),(A2+)	; buffer <-- mot initial	DEC.W	D1	JUMP,NE 70$	CLR.B	(A1)	LOAD.W	D7,#1		; D7 <-- pas de transformation80$:	LOAD.L	A4,A1		; A4 <-- ^plus loin	LOAD.L	A3,A2		; A3 <-- ^mot suivant82$:	COMP.B	(A3+),#SPACE	JUMP,EQ 82$	DEC.L	A384$:	COMP.B	(A3+),#''	JUMP,EQ 84$	DEC.L	A3	POPM.L	D1..D4,A1,A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; FAMFORME1 >;==========/; Prend un mot de la mme famille.; in	A3.L	^mot de base; out	A4/D4	^mot transform/lg; mod	D4.L, D7.W, A4.LFAMFORME1:	PUSHM.L	A3	COMP.B	(A3),#'$	JUMP',NE SKIP$	INC.L	A3		; A3 <-- saute le "$"SKIP$:	LOAD.L	A4,#(A6)+OBUMOT	LOAD.B	(A4+),#'[XFER$:	LOAD.B	(A4+),(A3+)	JUMP,NE XFER$	DEC.L	A4	LOAD.B	(A4+),#']	LOAD.L	D4,A4	LOAD.L	A4,#(A6)+OBUMOT	; A4 <-- ^mot	SUB.L	D4,A4		; D4 <-- lg	POPM.L	A3	RET;----------\\; FAMFORMET >;==========/; Prend tous les mots de la mme famille.; in	A3.L	^premier mot de base;	D3.W	nb de mots de base (1..n); out	A4/D4	^mot transform/lg; mod	D4.L, D7.W, A4.LFAMFORMET:	PUSHM.L	D3,A2,A3	LOAD.L	A4,#(A6)+OBUMOT	LOAD.B	(A4+),#'[	CLR.W	D4LOOP$:	COMP.W	D4,#LGMOTS-20	JUMP',HS END$	LOAD.L	A2,A3	COMP.B	(A2),#'$	JUMP',NE XFER$	INC.L	A2		; A2 <-- saute le "$"XFER$:	INC.W	D4	LOAD.B	(A4+),(A2+)	JUMP,NE XFER$	DEC.L	A4	COMP.W	D3,#1	JUMP',EQ NEXT$	INC.W	D4	LOAD.B	(A4+),#',NEXT$:	LOAD.L	A3,#(A3)+LGMOT	DEC.W	D3	JUMP,NE LOOP$END$:	LOAD.B	(A4+),#']	LOAD.L	D4,A4	LOAD.L	A4,#(A6)+OBUMOT	; A4 <-- ^mot	SUB.L	D4,A4		; D4 <-- lg	POPM.L	D3,A2,A3	RET;----------\\; SYNSEARCH >;==========/; Cherche simplement et rapidement une liste de synonymes.; in	A4/D4.L		^synonyme/lg;	(A6)+OSYPD.L	^o chercher dans le dico; out	(A6)+OSYPD.L	^plus loin;	(A6)+OSYPL.L	^liste des mots trouvs;	(A6)+OSYNL.W	nb de mots trouvs;	(A6)+OSYRL.W	rang du mot initial;	D7.W		erreur; mod	D7.WSYNSEARCH:	PUSHM.L	D0..D4,A1..A4	LOAD.L	A3,#(A6)+OSRCM0	CALL	FORMMOT0	; OSRCM0 <-- mot niveau 0	LOAD.L	A1,(A6)+OSYPD	; A1 <-- ^dico des synonymes20$:	LOAD.W	D7,#ERDIPT	; D7 <-- c'est fini	TEST.B	(A1)		; fin du dictionnaire des synonymes ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A4,#(A6)+OSRCMD	CALL	DECOSMOT	; OSRCMD <-- synonymes dcods	CLR.W	(A6)+OSYRL30$:	COMP.B	(A4),#'$	JUMP',NE 32$	INC.L	A432$:	LOAD.L	A3,#(A6)+OSRCM0	CALL	SYNCOMP		; synonyme trouv ?	JUMP',EQ 60$40$:	LOAD.B	D3,(A4+)	; A4 <-- ^mot suivant	JUMP,EQ 20$	COMP.B	D3,#SPACE	JUMP,EQ 30$	COMP.B	D3,#''	JUMP,EQ 30$	COMP.B	D3,#TAB	JUMP,NE 40$	INC.W	(A6)+OSYRL	JUMP	30$60$:	TEST.L	(A6)+OSYPL	JUMP',EQ 62$	LOAD.L	A4,(A6)+OSYPL	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancienne liste	CLR.L	(A6)+OSYPL62$:	LOAD.L	A3,#(A6)+OSRCMD	LOAD.W	D4,#164$:	LOAD.B	D3,(A3+)	JUMP',EQ 66$	COMP.B	D3,#TAB	JUMP,NE 64$	INC.W	D4		; D4 <-- un synonyme de plus	JUMP	64$66$:	LOAD.W	(A6)+OSYNL,D4	INC.W	D4	MUL.WU	D4,#LGMOT	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour liste	JUMP,NE 90$	GESMEM	?CLEARMEM	LOAD.L	(A6)+OSYPL,A4	LOAD.L	A3,#(A6)+OSRCMD70$:	LOAD.L	A2,A472$:	LOAD.B	D3,(A3+)	JUMP',EQ 80$	COMP.B	D3,#TAB	JUMP',EQ 74$	LOAD.B	(A2+),D3	; liste <-- un mot	JUMP	72$74$:	LOAD.L	A4,#(A4)+LGMOT	; A4 <-- ^suivant dans la liste	JUMP	70$80$:	CLR.W	D7		; D7 <-- ok90$:	LOAD.L	(A6)+OSYPD,A1	POPM.L	D0..D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SYNCOMP >;--------/; Compare deux mots synonymes.; in	A3.L	^chane cherche <0>;	A4.L	^chane <0>; out	A4.L	^plus loin (mais pas forcment jusqu'au suivant);	D7.W	erreur; mod	D0.L, D3.L, D4.L, D7.W, A3.L, A4.LSYNCOMP:	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv	LOAD.L	D0,(A6)+OSRCB0	; D0 <-- bits des lettres majuscules	LOAD.W	D4,#-1		; D4 <-- rang des caractres20$:	INC.W	D4		; D4 <-- rang suivant	LOAD.B	D3,(A4+)	JUMP',EQ 40$	COMP.B	D3,#TAB	JUMP',EQ 40$	COMP.B	D3,#SPACE	JUMP',EQ 40$	COMP.B	D3,(A3+)	JUMP,EQ 20$	TEST.L	D0:D4		; lettre majuscule dans le mot original ?	JUMP',BC 90$		; non => 90$	COMP.B	D3,#'	JUMP',LO 90$	COMP.B	D3,#'		; est-ce une minuscule accentue ?	JUMP',HI 30$		; non => 30$	CALL	NOACCENT	; D3 <-- minuscule sans accent	COMP.B	D3,(A3)-1	; compare une deuxime fois	JUMP,EQ 20$	JUMP'	90$30$:	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'Z		; est une majuscule ?	JUMP',HI 90$		; non => 90$;	CALL	MAJMIN		; D3 <-- lettre minuscule	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule	COMP.B	D3,(A3)-1	; compare une deuxime fois	JUMP,EQ 20$	JUMP'	90$40$:	TEST.B	(A3)	JUMP',NE 90$	CLR.W	D7		; D7 <-- trouv90$:	DEC.L	A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DECOSMOT >;=========/; Dcode un synonyme.; Cette routine doit tre trs rapide !; in	A1.L	^mot cod <0>;	A4.L	^buffer pour mot en clair <0>; out	A1.L	^mot cod suivant; mod	D7.W, A1.LDECOSMOT:	PUSHM.L	D3,A2,A4	LOAD.L	A2,#R16"TACODE-256 ; A2 <-- ^couples de lettres20$:	LOAD.B	(A4+),(A1+)	JUMP',EQ 90$	JUMP,NC 20$	CLR.W	D3	LOAD.B	D3,(-A4)	; D3 <-- byte cod (128..255)	SL.W	D3,#1	LOAD.B	(A4+),(A2)+(D3.W)	LOAD.B	(A4+),(A2)+(D3.W)+1	JUMP	20$90$:	POPM.L	D3,A2,A4	RET	.END