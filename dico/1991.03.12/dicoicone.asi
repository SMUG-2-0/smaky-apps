	.SBTTL	DICOICONE.ASI;----------\\; MSOPLUTIN >;----------/; Met le premier lutin.; in	-; out	-; mod	D7.WMSOPLUTIN:	.IF	JMOUSE	PUSHM.L	D3,A3,A4	CLR.W	(A6)+OMSCNT	LOAD.L	A4,#R16"TMS1	LOAD.L	A3,#(A6)+OMSLUT	LOAD.W	D3,#((((16*16)/8)+2)/2)-122$:	LOAD.W	(A3+),(A4+)	; OMSLUT <-- dx,dy,lutin	DECJ.W,NMO D3,22$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	LOAD.L	A4,#(A6)+OMSLUT	LOAD.L	(A3)+1,A4	LOAD.L	A4,#R16"TMSM	LOAD.L	(A3)+5,A4	LOAD.W	D3,#9	LIB	?STRING	POPM.L	D3,A3,A4	.ELSE	CLR.W	(A6)+OMSCNT	.ENDIF	RET;----------\\; MSCHLUTIN >;----------/; Change le lutin.; in	-; out	-; mod	D7.WMSCHLUTIN:	.IF	JMOUSE	PUSHM.L	D2..D5,A3,A4	NTREL	?GETSYTIME	; D4 <-- temps processeus (mod D2..D5 !)	LOAD.L	D5,D4	SUB.L	D4,(A6)+OMSTMP	COMP.L	D4,#1000	; s'est-il coul un minimum de temps ?	JUMP,LO 90$		; non => 90$	LOAD.L	(A6)+OMSTMP,D5	INC.W	(A6)+OMSCNT	LOAD.L	A4,#R16"TMS1	LOAD.L	D2,#H'00000001	LOAD.W	D3,(A6)+OMSCNT	AND.W	D3,#B'11	JUMP',EQ 20$	LOAD.L	A4,#R16"TMS2	LOAD.L	D2,#H'00010000	DEC.W	D3	JUMP',EQ 20$	LOAD.L	A4,#R16"TMS3	LOAD.L	D2,#H'0000FFFF	DEC.W	D3	JUMP',EQ 20$	LOAD.L	A4,#R16"TMS4	LOAD.L	D2,#H'FFFF000020$:	LOAD.L	A3,#(A6)+OMSLUT	LOAD.W	D3,#((((16*16)/8)+2)/2)-122$:	LOAD.W	(A3+),(A4+)	; OMSLUT <-- dx,dy,lutin	DECJ.W,NMO D3,22$	LIB	?IFMOUSE	ADD.W	D4,D2	SWAP.W	D2	SWAP.W	D4	ADD.W	D4,D2;	SWAP.W	D2	SWAP.W	D4	LIB	?PMOUSE90$:	POPM.L	D2..D5,A3,A4	.ELSE	PUSHM.L	D2..D5,A3,A4	NTREL	?GETSYTIME	; D4 <-- temps processeus (mod D2..D5 !)	LOAD.L	D5,D4	SUB.L	D4,(A6)+OMSTMP	COMP.L	D4,#1000	; s'est-il coul un minimum de temps ?	JUMP,LO 90$		; non => 90$	LOAD.L	(A6)+OMSTMP,D5	INC.W	(A6)+OMSCNT	CLR.L	D4	LOAD.W	D4,(A6)+OMSCNT	DIV.WU	D4,#8	SWAP.W	D4		; D4 <-- 0..7	LOAD.L	A4,#R16"TICOL1	COMP.W	D4,#1	JUMP',EQ 20$	LOAD.L	A4,#R16"TICOL2	COMP.W	D4,#2	JUMP',EQ 20$	LOAD.L	A4,#R16"TICOL3	COMP.W	D4,#3	JUMP',EQ 20$	LOAD.L	A4,#R16"TICOL4	COMP.W	D4,#4	JUMP',EQ 20$	LOAD.L	A4,#R16"TICOL520$:	LOAD.L	A3,#(A6)+OMSLUT+1	LOAD.B	(A3)+0,#DRAWMATRIX	LOAD.L	D3,(A6)+OMSPOS	JUMP',EQ 90$	SWAP.W	D3	LOAD.L	(A3)+1,D3	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#SETDOT	LOAD.W	D3,#10	LIB	?STRING90$:	POPM.L	D2..D5,A3,A4	.ENDIF	RET;----------\\; MSCLLUTIN >;----------/; Remet la flche normale.; in	-; out	-; mod	D7.WMSCLLUTIN:	.IF	JMOUSE	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	CLR.L	(A3)+1	CLR.L	(A3)+5	LOAD.W	D3,#9	LIB	?STRING	POPM.L	D3,A3	.ELSE	.ENDIF	RET	.IF	JMOUSETMS1:	.B	16,16	.W	B'0000011111100000	.W	B'0001100011111000	.W	B'0010000011111100	.W	B'0100000011111110	.W	B'0100000011111110	.W	B'1000000011111111	.W	B'1000000011111111	.W	B'1000000011111111	.W	B'1111111100000001	.W	B'1111111100000001	.W	B'1111111100000001	.W	B'0111111100000010	.W	B'0111111100000010	.W	B'0011111100000100	.W	B'0001111100011000	.W	B'0000011111100000TMS2:	.B	16,16	.W	B'0000011111100000	.W	B'0001100000011000	.W	B'0010000000000100	.W	B'0111000000001110	.W	B'0111100000011110	.W	B'1111110000111111	.W	B'1111111001111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111001111111	.W	B'1111110000111111	.W	B'0111100000011110	.W	B'0111000000001110	.W	B'0010000000000100	.W	B'0001100000011000	.W	B'0000011111100000TMS3:	.B	16,16	.W	B'0000011111100000	.W	B'0001111100011000	.W	B'0011111100000100	.W	B'0111111100000010	.W	B'0111111100000010	.W	B'1111111100000001	.W	B'1111111100000001	.W	B'1111111100000001	.W	B'1000000011111111	.W	B'1000000011111111	.W	B'1000000011111111	.W	B'1000000011111110	.W	B'0100000011111110	.W	B'0010000011111100	.W	B'0001100011111000	.W	B'0000011111100000TMS4:	.B	16,16	.W	B'0000011111100000	.W	B'0001111111111000	.W	B'0011111111111100	.W	B'0101111111111010	.W	B'0100111111110010	.W	B'1000011111100001	.W	B'1000001111000001	.W	B'1000000110000001	.W	B'1000000110000001	.W	B'1000001111000001	.W	B'1000011111100001	.W	B'0100111111110010	.W	B'0101111111111010	.W	B'0011111111111100	.W	B'0001111111111000	.W	B'0000011111100000TMSM:	.B	16,16	.W	B'0000011111100000	.W	B'0001111111111000	.W	B'0011111111111100	.W	B'0111111111111110	.W	B'0111111111111110	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'0111111111111110	.W	B'0111111111111110	.W	B'0011111111111100	.W	B'0001111111111000	.W	B'0000011111100000	.ELSETICOL1:	.B	40,25        .B      B'00000000,B'00000000,B'00000000,B'00000000,B'00000000        .B      B'01111111,B'11111111,B'11100111,B'11111111,B'11111110        .B      B'11010000,B'00000000,B'00011000,B'00000000,B'00001011        .B      B'11010000,B'00000000,B'00011000,B'00000000,B'00001011        .B      B'11010011,B'11110010,B'10011001,B'11100101,B'01001011        .B      B'11010000,B'00000000,B'00011000,B'00000000,B'00001011        .B      B'11010000,B'00101010,B'10011000,B'00010101,B'01001011        .B      B'11010000,B'00000000,B'00011000,B'00000000,B'00001011        .B      B'11010000,B'00000000,B'00011000,B'00010101,B'01001011        .B      B'11010011,B'11001010,B'10011000,B'00000000,B'00001011        .B      B'11010000,B'00000000,B'00011000,B'00010101,B'00001011        .B      B'11010000,B'00101010,B'10011000,B'00000000,B'00001011        .B      B'11010000,B'00000000,B'00011000,B'00000000,B'00001011        .B      B'11010000,B'00101000,B'00011001,B'11111001,B'01001011        .B      B'11010000,B'00000000,B'00011000,B'00000000,B'00001011        .B      B'11010000,B'00000000,B'00011000,B'00010101,B'01001011        .B      B'11010011,B'11100010,B'10011000,B'00000000,B'00001011        .B      B'11010000,B'00000000,B'00011000,B'00010101,B'01001011        .B      B'11010000,B'00101010,B'10011000,B'00000000,B'00001011        .B      B'11011111,B'00000000,B'00011000,B'00010100,B'11111011        .B      B'11001001,B'00101010,B'00011000,B'00000000,B'10010011        .B      B'11000101,B'000