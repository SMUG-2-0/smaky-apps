1Y	SUB.W	D3,#6	LOAD.L	(A3)+1,D3	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#SETDOT	LOAD.W	D3,#10	LIB	?STRING	POPM.L	D3,D4,A3,A4	RETTICO1:	.B	40,25        .B      B'01001111,B'11111111,B'11111111,B'11111111,B'11111111        .B      B'11000000,B'00000000,B'00000000,B'00000000,B'00000001        .B      B'01000000,B'00000000,B'00000000,B'00000000,B'00000001        .B      B'01000000,B'00000000,B'00000011,B'00110000,B'00000001        .B      B'01000000,B'00000000,B'00000011,B'00110000,B'00000001        .B      B'01000000,B'00000000,B'00000000,B'00000000,B'11000001        .B      B'11100000,B'00000000,B'00000011,B'11000001,B'11100001        .B      B'00000111,B'00000000,B'00000000,B'11000011,B'00110001        .B      B'10000011,B'00000000,B'00000000,B'11000000,B'00000001        .B      B'10000001,B'10000000,B'00000000,B'11000001,B'11100001        .B      B'10000000,B'00000000,B'01110000,B'11000011,B'00110001        .B      B'10000111,B'10000000,B'01100000,B'11000110,B'00011001        .B      B'10001100,B'11000000,B'11000000,B'11000110,B'00011001        .B      B'10000000,B'01100000,B'00000011,B'11110110,B'00011001        .B      B'10000000,B'11100000,B'11110000,B'00000110,B'00011001        .B      B'10000011,B'01100001,B'10011000,B'00000110,B'00011001        .B      B'10001100,B'01100011,B'00001100,B'00000110,B'00011001        .B      B'10011000,B'01100011,B'00001100,B'00000011,B'00110001        .B      B'10011000,B'11100011,B'11111100,B'00000001,B'11100001        .B      B'10001111,B'00110011,B'00000000,B'00000000,B'00000001        .B      B'10000000,B'00000011,B'00000000,B'00000000,B'00000001        .B      B'10000000,B'00000001,B'10011000,B'00000000,B'00000001        .B      B'10000000,B'00000000,B'11110000,B'00000000,B'00000001        .B      B'10000000,B'00000000,B'00000000,B'00000000,B'00000001        .B      B'11111111,B'11111111,B'11111111,B'11111111,B'11111111	.EVENTICO2:	.B	40,25        .B      B'01110011,B'11111111,B'11111111,B'