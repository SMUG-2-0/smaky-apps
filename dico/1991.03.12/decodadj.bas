t ITER%19450     Case 0 : Let PART1$ = PART1$ + C$19460     Case 1 : Let PART2$ = PART2$ + C$19470     Case 2 : Let PART3$ = PART3$ + C$19480   End Select19490 End Loop19500 For ITER% = 0 To TIRET%19510   Select ITER%19520     Case 0 : Let LLIGN$ = PART1$19530     Case 1 : Let LLIGN$ = PART2$19540     Case 2 : Let LLIGN$ = PART3$19550   End Select19560   Let POSIT% = 0 : Let K% = 019570   Loop19580     Inc POSIT%19590     Exit If POSIT% > Len(LLIGN$)19600     Select Mid$(LLIGN$, POSIT%, 1)19610       Case '.', '$', ',', ']' : Inc K%19630     End Select19640     Exit If K% > 019650   End Loop19660   Do If K% = 019670     Let RM$ = LLIGN$19680     Let RF$ = LLIGN$19690     Let MP$ = LLIGN$19700     Let FF$ = ''19710   Do Else19720     Select Right$(LLIGN$,1)19730       Case ']'19740         Let RM$ = Butright$(LLIGN$,1)19750         Let RF$ = RM$19760         Let MP$ = RM$ + 's'19770         Let FF$ = 's'19780       Case '.'19790         Let RM$ = Butright$(LLIGN$,4)19800         Let RF$ = RM$ + Chr$(20)19810         Let MP$ = RM$ + 's'19820         Let FF$ = 's' 19830       Case Else19840         Let K% = 019850           Let POSPOINT% = 0 : Let POSDOLL% = 019860         Loop19870           Inc K%19880           Exit If K% > Len(LLIGN$)19890           Select Mid$(LLIGN$,K%,1)19900             Case '.'19910               Let RM$ = Left$(LLIGN$, K% - 1)19920               Let MP$ = RM$19930               Let RF$ = RM$19940               Let POSPOINT% = K%19950             Case '$'19960               Let POSDOLL% = K%19970               Do If POSPOINT% = 019980                 Let RM$ = Left$(LLIGN$, K% - 1)19990               Let MP$ = RM$20000                 Let RF$ = RM$20010               Do Else20020                 Let RM$ = RM$ + Mid$(LLIGN$, POSPOINT% + 1, K% - POSPOINT% - 1)20030               Let MP$ = Left$(RM$, POSPOINT% - 1)20040               End Do20050             Case ','20060               Do If K% = POSDOLL% + 120070                 Let MP$ = RM$20080               Do Else20090                 If Mid$(LLIGN$, POSDOLL% + 1, 1) = 's' Then Let MP$ = RM$20100                 Let MP$ = MP$ + Mid$(LLIGN$, POSDOLL% + 1, K% - POSDOLL% - 1)20110               End Do20120               Do If K% = Len(LLIGN$)20130                 Let RF$ = RM$ + 'e'20140                 Let FF$ = 's'20150               Do Else20160                 Let RF$ = RF$ + Right$(LLIGN$, Len(LLIGN$) - K%) + 'e'20170                 Let FF$ = 's'20180               End Do20190         End Select20200       End Do20210     End Loop20220   End Select20230   Select ITER%20240     Case 020250       MS1$ = RM$20260       MP1$ = MP$20270       FS1$ = RF$20280       FP1$ = FS1$ + FF$20290     Case 120300       MS2$ = RM$20310       MP2$ = MP$20320       FS2$ = RF$20330       FP2$ = FS2$ + FF$20340     Case 220350       Let MS3$ = RM$20360       Let MP3$ = MP$20370       Let FS3$ = RF$20380       Let FP3$ = FS3$ + FF$20390   End Select20400 Next ITER%20410 Select TIRET%20420   Case 020430     Let @AMS$ = MS1$20440     Let @AMP$ = MP1$20450     Let @AFS$ = FS1$20460     Let @AFP$ = FP1$20470   Case 120480     Let @AMS$ = MS1$ + '-' + MS2$20490     Let @AMP$ = MP1$ + '-' + MP2$20500     Let @AFS$ = FS1$ + '-' + FS2$20510     Let @AFP$ = FP1$ + '-' + FP2$20520   Case 220530     Let @AMS$ = MS1$ + '-' + MS2$ + '-' + MS3$20540     Let @AMP$ = MP1$ + '-' + MP2$ + '-' + MP3$20550     Let @AFS$ = FS1$ + '-' + FS2$ + '-' + FS3$20560     Let @AFP$ = FP1$ + '-' + FP2$ + '-' + FP3$20570 End Select20580 Select ESPMOT%20590   Case 220600     Let @AMP$ = '' : Let @AFS$ = '' : Let @AFP$ = ''20610 End Select20620  Pop FP3$, FP2$, FP1$, FS3$, FS2$,FS1$, MP3$, MP2$, MP1$20630  Pop MS3$, MS2$, MS1$20640  Pop POSDOLL%, POSPOINT%, POSIT%, TIRET%, LONG%, K%, ITER%, ESPMOT%20650  Pop PART3$, PART2$, PART1$, FF$, RF$, RM$, MP$, C$, M$20660 Return