	.SBTTL	DICODICO.ASI;--------\\; DICOADD >;========/; Ajoute un mot dans un dictionnaire utilisateur.; in	A3/D3.L	^mot  ajouter/lg;	A4.L	^dictionnaire; out	D7.W	erreur; mod	D7.WDICOADD:	PUSHM.L	D2..D4,A2..A4	LOAD.B	D2,(A4)+LDU	; D2 <-- "*" si dictionnaire encod; Cherche le dernier bloc.20$:	TEST.L	(A4)+ODUPNX	JUMP',EQ 30$	LOAD.L	A4,(A4)+ODUPNX	; A4 <-- ^bloc suivant	JUMP	20$; Regarde si l'on peut mettre le mot dans le dernier bloc.30$:	LOAD.L	D4,(A4)+ODULGT	SUB.L	D4,(A4)+ODULGU	; D4 <-- place restante	COMP.L	D3,D4		; reste assez de place ?	JUMP',LO 50$		; oui => 50$; Demande de la mmoire pour un nouveau bloc.	LOAD.L	A2,A4	CALL	DICONEWBLOC	; A4 <-- ^mmoire pour un nouveau bloc	JUMP',NE 90$	LOAD.L	(A2)+ODUPNX,A4; Ajoute le mot  la fin du dernier bloc.50$:	LOAD.L	D4,(A4)+ODULGU	LOAD.L	A2,#(A4)+(D4.L)+LDU ; A2 <-- ^o mettre le mot	INC.W	(A4)+ODUNBM	LOAD.W	D4,D354$:	LOAD.B	D3,(A3+)	COMP.B	D2,#'*		; dictionnaire encod ?	JUMP',EQ 56$		; oui => 56$	CALL	MAJMIN56$:	COMP.B	D3,#LF	JUMP',EQ 58$	COMP.B	D3,#TIRET	JUMP',EQ 58$	LOAD.B	(A2+),D3	INC.L	(A4)+ODULGU58$:	DEC.L	D4	JUMP,NE 54$	LOAD.B	(A2),#CR	INC.L	(A4)+ODULGU	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICOSAVE >;=========/; Sauve sur disque un dictionnaire utilisateur.; in	A3.L	^nom du dictionnaire;	A4.L	^dbut; out	D7.W	erreur; mod	D7.WDICOSAVE:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A2,A4		; A2 <-- ^dictionnaire	FOS	?DELETE		; dtruit l'ancien	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le nouveau	JUMP,NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE 90$30$:	LOAD.L	A4,#(A2)+LDU	LOAD.L	D4,(A2)+ODULGU	FOS	?WRBYTE		; crit un bloc	JUMP',NE 80$	TEST.L	(A2)+ODUPNX	; encore un bloc ?	JUMP',EQ 50$		; non => 50$	LOAD.L	A2,(A2)+ODUPNX	; A2 <-- ^bloc suivant	JUMP	30$50$:	FOS	?CLOSE	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICOLOAD >;=========/; Charge en mmoire un dictionnaire utilisateur.; in	A3.L	^nom du dictionnaire; out	A4.L	^dbut;	D7.W	erreur; mod	D7.W, A4.LDICOLOAD:	PUSHM.L	D1,D3,D4,D6,A2,A3	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre le dictionnaire	JUMP,NE 90$	LOAD.L	D4,#-1	LOAD.B	D3,D4	FOS	?SPOS		; D4 <-- longueur du fichier	PUSH.L	D4	CLR.L	D4	CLR.B	D3	FOS	?SPOS		; revient au dbut	POP.L	D4	ADD.L	D4,#LDU+1	; D4 <-- place pour en-tte + <CR> terminateur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer pour le fichier dictionnaire	JUMP,NE 82$	LOAD.L	A3,A4	LOAD.L	A4,#(A4)+LDU	SUB.L	D4,#LDU+1	FOS	?RDBYTE		; lit tout le fichier dictionnaire	JUMP,NE 80$	COMP.B	(A4)+(D4.L)-1,#CR	JUMP',EQ 30$	LOAD.B	(A4)+(D4.L),#CR	INC.L	D430$:	CLR.L	(A3)+ODUPNX	LOAD.L	(A3)+ODULGT,D4	LOAD.L	(A3)+ODULGU,D4	LOAD.L	A2,#(A4)+(D4.L)	LOAD.B	D3,#CR	CLR.W	D140$:	INC.W	D1		; D1 <-- un mot de plus42$:	COMP.B	D3,(A4+)	; A4 <-- ^mot suivant	JUMP,NE 42$	COMP.L	A4,A2	JUMP,LO 40$	LOAD.W	(A3)+ODUNBM,D1	LOAD.L	A4,A3		; A4 <-- ^dictionnaire	JUMP'	82$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire du dictionnaire	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme le dictionnaire	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A2,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DICOUNLOAD >;===========/; Libre la mmoire utilise par un dictionnaire.; in	A4.L	^dictionnaire; out	-; mod	D7.WDICOUNLOAD:	PUSHM.L	D1,D4,A4	LOAD.L	D4,A420$:	TEST.L	D4		; bloc existe ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A4,D4		; A4 <-- ^bloc	LOAD.L	D4,(A4)+ODUPNX	; D4 <-- ^bloc suivant/nil	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire d'un bloc	JUMP	20$90$:	POPM.L	D1,D4,A4	RET;-----------\\; DICOCREATE >;===========/; Cre un nouveau dictionnaire.; in	A3.L	^nouveau nom; out	A3.L	^dans OTADL;	D7.W	erreur; mod	D7.W, A3.LDICOCREATE:	PUSHM.L	D2..D4,A2,A4	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP,NE 90$	LOAD.L	A2,#(A6)+OTADL	LOAD.W	D2,#MAXDL20$:	TEST.B	(A2)+ODLNOM	JUMP',NE 50$	LOAD.L	A4,#(A2)+ODLNOM30$:	LOAD.B	(A4+),(A3+)	JUMP,NE 30$	CALL	DICONEWBLOC	; A4 <-- ^mmoire pour premier bloc	JUMP',NE 90$	LOAD.L	(A2)+ODLPT,A4	LOAD.L	A3,A2		; A3 <-- ^dans OTADL	JUMP'	90$50$:	LOAD.L	A2,#(A2)+LDL	; A2 <-- ^nom suivant	DEC.W	D2	JUMP,NE 20$	LOAD.W	D7,#ERDIPT90$:	POPM.L	D2..D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DICONB >;=======/; Cherche le nombre de dictionnaires utiliss.; in	-; out	D4.W	nb (0..n); mod	D4.L, D7.WDICONB:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OTADL	LOAD.W	D3,#MAXDL	CLR.W	D420$:	TEST.B	(A3)+ODLNOM	JUMP',EQ 50$	INC.W	D450$:	LOAD.L	A3,#(A3)+LDL	; A3 <-- ^nom suivant	DEC.W	D3	JUMP,NE 20$	POPM.L	D3,A3	RET;---------\\; DICOLIST >;=========/; Effectue la liste de tous les dictionnaires utilisateurs.; in	-; out	-; mod	D7.WDICOLIST:	PUSHM.L	D2..D4,D6,A1..A4	LOAD.L	A3,#R16"DIR$	LOAD.L	A4,#R16"CRIT$	LOAD.L	D3,#2^BOPEXTEND!2^BLICNOM	FOS	?LISTOPEN	JUMP,NE 90$	LOAD.L	A2,#(A6)+OTADL	LOAD.W	D2,#MAXDL20$:	FOS	?LISTNXT	; A3/A4 <-- ^nom/^arguments	JUMP',NE 40$	LOAD.L	A1,#(A2)+ODLNOM30$:	LOAD.B	(A1+),(A3+)	; ODLNOM <-- nom	JUMP,NE 30$	LOAD.L	A3,#(A2)+ODLNOM	CALL	DICOLOAD	; charge le dictionnaire	JUMP,NE 20$	LOAD.L	(A2)+ODLPT,A4	LOAD.L	A2,#(A2)+LDL	; A2 <-- ^suivant	DEC.W	D2	JUMP,NE 20$40$:	FOS	?LISTCLOSE; Demande de la mmoire pour le dictionnaire temporaire.	CALL	DICONEWBLOC	; A4 <-- ^mmoire pour premier bloc	JUMP',NE 90$	LOAD.L	(A6)+OTADL+(MAXDL*LDL)+ODLPT,A4	LOAD.B	(A6)+OTADL+(MAXDL*LDL)+ODLNOM,#'t90$:	POPM.L	D2..D4,D6,A1..A4	RETDIR$:	.ASCIZ	""CRIT$:	.ASCIZ	"*.PDICO"	.EVEN;------------\\; DICONEWBLOC >;------------/; Rserve de la mmoire pour un nouveau bloc d'un dictionnaire.; in	-; out	A4.L	^nouveau bloc;	D7.W	erreur; mod	D7.W, A4.LDICONEWBLOC:	PUSHM.L	D1,D4	LOAD.L	D4,#LDU+500	; D4 <-- rserve arbitrairement 500 bytes !	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouveau bloc	JUMP',EQ 20$	LOAD.L	A4,#0		; A4 <-- nil	JUMP'	90$20$:	CLR.L	(A4)+ODUPNX	; ODUPNX <-- pas de bloc suivant	SUB.L	D4,#LDU	LOAD.L	(A4)+ODULGT,D4	; ODULGT <-- longueur utilisable	CLR.L	(A4)+ODULGU	; ODULGU <-- longueur utilise	CLR.W	(A4)+ODUNBM	; OBUNBM <-- aucun mot90$:	POPM.L	D1,D4	TEST.W	D7		; retour EQ/NE	RET	.END