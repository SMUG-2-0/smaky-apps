	.TITLE	SYNCODE.ASC	.PROC	M680002	.REF	SMAKYASSMILE	=	0	.LOC	0OTYPE:	.BLKB	1		; "S"/"F"	.EVENOPDICO:	.BLKB	4		; ^dictionnaire en clairOPCODE:	.BLKB	4		; ^dictionnaire codOBUMOT:	.BLKB	500LGVAR:	.LOC	0START:	.IF	~ASSMILE	LIB	?OPELIB	.ENDIF	LOAD.L	A6,#R16"VAR	LIB	?AFTIM	.ASCIZ	"<EOP><CR>(S)ynonymes, (F)amilles ? "	.EVEN	LIB	?GETCAR	LIB	?MINMAJ	LIB	?AFCODE	LOAD.B	(A6)+OTYPE,D3	LIB	?AFTIM	.ASCIZ	"<CR>Nom du dictionnaire source : "	.EVEN	LOAD.L	A3,#R16"NMDICOSS	COMP.B	(A6)+OTYPE,#'F	JUMP,NE 30$	LOAD.L	A3,#R16"NMDICOSF30$:	PUSH.L	A3	LIB	?AFTEXT	POP.L	A3	LIB	?AFCR	CALL	DICOLOAD	; charge le dictionnaire source	JUMP,NE ERFAT	LOAD.L	(A6)+OPDICO,A4	CALL	RESCODE		; rserve mmoire	JUMP,NE ERROR	CALL	CODEALL		; code ...	LIB	?BEEP	LIB	?AFTIM	.ASCIZ	"<CR>Nom du dictionnaire destination : "	.EVEN	LOAD.L	A3,#R16"NMDICODS	COMP.B	(A6)+OTYPE,#'F	JUMP',NE 40$	LOAD.L	A3,#R16"NMDICODF40$:	PUSH.L	A3	LIB	?AFTEXT	POP.L	A3	LIB	?AFCR	LOAD.L	D3,#DEFATT	LIB	?FCREATE	JUMP,NE ERROR	LOAD.L	A4,(A6)+OPCODE	LOAD.L	D4,(A4)+OBXLG	ADD.L	D4,#256	FOS	?WRBYTE		; crit tous les mots80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	JUMP,NE ERROR	JUMP	FINERROR:	LIB	?AFERROR	LIB	?GETCARFIN:	TEST.L	(A6)+OPDICO	JUMP,EQ 20$	LOAD.L	A4,(A6)+OPDICO	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPDICO20$:	TEST.L	(A6)+OPCODE	JUMP,EQ 30$	LOAD.L	A4,(A6)+OPCODE	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPCODE30$:ERFAT:	.IF	ASSMILE	EXIT	.ELSE	LIB	?CLOLIB	FOS	?STOP	.ENDIF;--------\\; RESCODE >;========/; Rserve la mmoire pour le dictionnaire cod.; in	-; out	D7.W	erreur; mod	D7.WRESCODE:	PUSHM.L	D1,D4,A4	LOAD.L	A4,(A6)+OPDICO	CLR.L	D420$:	INC.L	D4	TEST.B	(A4+)	JUMP,NE 20$	ADD.L	D4,#256+100	TEST.L	(A6)+OPCODE	JUMP,NE 50$	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE 90$	LOAD.L	(A6)+OPCODE,A450$:	LOAD.L	A4,(A6)+OPCODE	GESMEM	?CLEARMEM	CLR.W	D790$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CODEALL >;========/; Code tous les mots.; in	-; out	-; mod	D7.WCODEALL:	PUSHM.L	D3,D4,A3,A4	LIB	?AFTIM	.ASCIZ	"<CR>Codage en cours ..."	.EVEN	LOAD.L	A3,(A6)+OPDICO	LOAD.L	A4,(A6)+OPCODE	ADD.L	A4,#25620$:	TEST.B	(A3)	JUMP',EQ 30$	CALL	CODEMOT	JUMP	20$30$:	CLR.B	(A4+)	LOAD.L	D4,A4	LOAD.L	A4,(A6)+OPCODE	SUB.L	D4,A4	SUB.L	D4,#256	LOAD.L	(A4)+OBXLG,D4	LOAD.B	(A4)+OBXTYP,#2^BBXREL	POPM.L	D3,D4,A3,A4	RET;--------\\; CODEMOT >;========/; Code un mot.; Cette routine peut tre lente !; in	A3.L	^mot en clair <CR>;	A4.L	^buffer pour mot cod <0>; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LCODEMOT:	PUSHM.L	D2..D4,A2;	LOAD.B	(A4+),(A3+)20$:	LOAD.B	D3,(A3+)	; D3 <-- premire lettre	COMP.B	D3,#CR	JUMP,EQ 50$	LOAD.B	D4,(A3)		; D4 <-- deuxime lettre	LOAD.L	A2,#R16"TACODE	; A2 <-- ^couples de lettres	LOAD.B	D2,#12830$:	COMP.B	D3,(A2)	JUMP',NE 32$	COMP.B	D4,(A2)+1	JUMP',EQ 40$32$:	ADD.L	A2,#2		; A2 <-- ^couple suivant	INC.B	D2	JUMP,NE 30$	LOAD.B	(A4+),D3	JUMP	20$40$:	INC.L	A3	LOAD.B	(A4+),D2	JUMP	20$50$:	CLR.B	(A4+)	POPM.L	D2..D4,A2	RET;---------\\; DICOLOAD >;=========/; Charge un dictionnaire en mmoire.; in	A3.L	^nom du dictionnaire; out	A4.L	^dictionnaire termin par <0>;	D7.W	erreur; mod	D7.W, A4.LDICOLOAD:	PUSHM.L	D1,D3,D4,D6	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre le dictionnaire	JUMP,NE 90$	LOAD.L	D4,#-1	LOAD.B	D3,D4	FOS	?SPOS		; D4 <-- longueur du fichier	PUSH.L	D4	CLR.L	D4	CLR.B	D3	FOS	?SPOS		; revient au dbut	POP.L	D4	INC.L	D4		; D4 <-- place pour <0> terminateur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer pour le fichier dictionnaire	JUMP',NE 82$	DEC.L	D4	FOS	?RDBYTE		; lit tout le fichier dictionnaire	JUMP',NE 80$	CLR.B	(A4)+(D4.L)	; met le <0> terminateur	JUMP'	82$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire du dictionnaire	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme le dictionnaire	POP.W	D790$:	POPM.L	D1,D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET; Cette table donne les 128 couples de lettres les plus; utilises en franais, dans l'ordre.TACODE:	.ASCII	"erntonenretimeleteisinanriraatem"	.ASCII	"ousecourioeuiearuelineitchssilqu"	.ASCII	"trlaroirtastlloralaigecaagncsiic"	.ASCII	"desadimacenieslonapaabprblolvepo"	.ASCII	"tocietacnnmiaspendomussoelauuliq"	.ASCII	"utoiuihemoimotpimphansviapbotutt"	.ASCII	"fictrtgramcrbaignovaiasurdbigapl"	.ASCII	"currocosbrecnghigiadivschophogfa"	.EVENNMDICOSS:.ASCIZ	"SYN.DICO"NMDICODS:.ASCIZ	"#:250000.SDICO"NMDICOSF:.ASCIZ	"FAM.DICO"NMDICODF:.ASCIZ	"#:250000.FDICO"	.EVENVAR:	.FILLB	LGVAR,0	.END	START