	.SBTTL	DICOSEARCH.ASI;---------\\; SEARCHEX >;=========/; Cherche simplement et rapidement si un mot existe.; in	A4/D4.L	^mot faux/lg; out	D7.W	erreur; mod	D7.WSEARCHEX:	PUSHM.L	D0..D5,A3..A5	CALL	SEARCHQUICK	; cherche rapidement si petit mot	JUMP,EQ 90$	CALL	SEARCHINDEX3	; cherche rapidement selon index  3 lettres	JUMP,EQ 90$	LOAD.L	(A6)+OSRCPM,A4	LOAD.L	(A6)+OSRCLM,D4	LOAD.L	D5,D4	LOAD.W	D2,#2		; D2 <-- deux lettres assures	CALL	SEARCHINIT	; initialise pour la recherche	JUMP',NE 30$	CLR.W	D2		; D2 <-- accepte seulement si exact	CLR.B	(A6)+OCHFST	; ne stoppe pas	CALL	SEARCHNEXT	; cherche un mot ...	JUMP,EQ 90$; Vrifie encore si le mot qui n'a pas t trouv est un; mot compos, pour rsoudre les cas "verbe-pronom" ainsi; que "nom-ci" ou "nom-l" :;	donne-m'en;	aime-moi;	mange-les;	etc.;	objet-ci;	chaise-l;	etc.30$:	LOAD.L	D4,D5	LOAD.L	A5,A432$:	DEC.L	D5	JUMP,NS 90$	COMP.B	(A5+),#'-	; mot compos avec "-" ?	JUMP,NE 32$	SUB.L	D4,D5	LOAD.L	A5,#(A4)+(D4.L)	; A5 <-- ^aprs le "-"	DEC.L	D4		; D4 <-- longueur jusqu'au "-"	COMP.W	D5,#2		; lg 2me partie = 2 (pour "ci" ou "l") ?	JUMP',NE 36$		; non => 36$	LOAD.B	D3,(A5)	CALL	MAJMIN	COMP.B	D3,#'c	JUMP',NE 34$	LOAD.B	D3,(A5)+1	CALL	MAJMIN	COMP.B	D3,#'i		; 2me partie = "ci" ?	JUMP,EQ 60$		; oui => 60$34$:	LOAD.B	D3,(A5)	CALL	MAJMIN	COMP.B	D3,#'l	JUMP',NE 36$	LOAD.B	D3,(A5)+1	COMP.B	D3,#'A	JUMP,EQ 60$	COMP.B	D3,#'		; 2me partie = "l" ?	JUMP,EQ 60$		; oui => 60$36$:	LOAD.W	D2,#2		; D2 <-- deux lettres assures	CALL	SEARCHINIT	; initialise pour la recherche	JUMP,NE 90$40$:	CLR.W	D2		; D2 <-- accepte seulement si exact	CLR.B	(A6)+OCHFST	; ne stoppe pas	CALL	SEARCHNEXT	; cherche la premire partie du mot ...	JUMP,NE 90$	COMP.B	D3,#'t		; verbe ?	JUMP',EQ 44$		; oui => 44$	COMP.B	D3,#'i	JUMP',EQ 44$	COMP.B	D3,#'u	JUMP',EQ 44$	COMP.B	D3,#'r	JUMP',EQ 44$	COMP.B	D3,#'1	JUMP',EQ 44$	COMP.B	D3,#'2	JUMP',EQ 44$	COMP.B	D3,#'h	JUMP',EQ 44$	COMP.B	D3,#'v	JUMP',EQ 44$	COMP.B	D3,#'7	JUMP,NE 40$44$:	LOAD.B	D1,D3	LOAD.L	A3,A5		; A3 <-- ^aprs le "-"	LOAD.L	D3,D5		; D3 <-- longueur depuis "-"	CALL	SEARCHCADRE	; A4/D4 <-- ^mot aprs le "-"/lg	LOAD.W	D2,#2		; D2 <-- deux lettres assures	CALL	SEARCHINIT	; initialise pour la recherche	JUMP,NE 90$50$:	CLR.W	D2		; D2 <-- accepte seulement si exact	CLR.B	(A6)+OCHFST	; ne stoppe pas	CALL	SEARCHNEXT	; cherche la deuxime partie du mot ...	JUMP,NE 90$	COMP.B	D3,#'o		; pronom ?	JUMP',EQ 54$	COMP.B	D3,#'6	JUMP,NE 50$54$:	JUMP	90$60$:	LOAD.W	D2,#2		; D2 <-- deux lettres assures	CALL	SEARCHINIT	; initialise pour la recherche	JUMP,NE 90$62$:	CLR.W	D2		; D2 <-- accepte seulement si exact	CLR.B	(A6)+OCHFST	; ne stoppe pas	CALL	SEARCHNEXT	; cherche la premire partie du mot ...	JUMP,NE 90$	COMP.B	D3,#'m		; nom ?	JUMP',EQ 64$		; oui => 64$	COMP.B	D3,#'4	JUMP',EQ 64$	COMP.B	D3,#'q	JUMP',EQ 64$	COMP.B	D3,#'f	JUMP',EQ 64$	COMP.B	D3,#'n	JUMP',EQ 64$	COMP.B	D3,#'3	JUMP',EQ 64$	COMP.B	D3,#'k	JUMP',EQ 64$	COMP.B	D3,#'x	JUMP',EQ 64$	COMP.B	D3,#'w	JUMP',EQ 64$	COMP.B	D3,#'P	JUMP',EQ 64$	COMP.B	D3,#'0	JUMP',EQ 64$	COMP.B	D3,#'%	JUMP,NE 62$64$:	JUMP'	90$80$:	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv90$:	POPM.L	D0..D5,A3..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; SEARCHQUICK >;------------/; Cherche rapidement si un mot court existe.; in	A4/D4.L	^mot faux/lg; out	D7.W	erreur; mod	D7.WSEARCHQUICK:	PUSHM.L	D3,D4,A3	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv	COMP.W	D4,#1		; une lettre ?	JUMP,EQ 80$		; oui => 80$ (toujours ok)	COMP.W	D4,#3	JUMP',EQ 40$	COMP.W	D4,#2	JUMP,NE 90$				; deux lettres =>	LOAD.B	D3,(A4)	CALL	MAJMIN	SL.W	D3,#8	LOAD.B	D3,(A4)+1	CALL	MAJMIN	LOAD.L	A3,#R16"TABLE2$20$:	LOAD.W	D4,(A3+)	JUMP',EQ 90$	COMP.W	D4,D3	JUMP,NE 20$	JUMP'	80$40$:				; trois lettres =>	LOAD.B	D3,(A4)	CALL	MAJMIN	SL.L	D3,#8	LOAD.B	D3,(A4)+1	CALL	MAJMIN	SL.L	D3,#8	LOAD.B	D3,(A4)+2	CALL	MAJMIN	SL.L	D3,#8	LOAD.B	D3,#SPACE	LOAD.L	A3,#R16"TABLE3$50$:	LOAD.L	D4,(A3+)	JUMP',EQ 90$	COMP.L	D4,D3	JUMP,NE 50$80$:	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RETTABLE2$:	.ASCII	"au"	.ASCII	"ce"	.ASCII	"de"	.ASCII	"du"	.ASCII	"en"	.ASCII	"et"	.ASCII	"il"	.ASCII	"la"	.ASCII	"le"	.ASCII	"ma"	.ASCII	"me"	.ASCII	"ne"	.ASCII	"ni"	.ASCII	"on"	.ASCII	"ou"	.ASCII	"o"	.ASCII	"sa"	.ASCII	"se"	.ASCII	"si"	.ASCII	"ta"	.ASCII	"te"	.ASCII	"tu"	.ASCII	"un"	.W	0TABLE3$:	.ASCII	"aux "	.ASCII	"ces "	.ASCII	"cet "	.ASCII	"des "	.ASCII	"est "	.ASCII	"eux "	.ASCII	"ici "	.ASCII	"ils "	.ASCII	"lui "	.ASCII	"mes "	.ASCII	"moi "	.ASCII	"mon "	.ASCII	"non "	.ASCII	"oui "	.ASCII	"que "	.ASCII	"qui "	.ASCII	"ses "	.ASCII	"soi "	.ASCII	"son "	.ASCII	"sur "	.ASCII	"sr "	.ASCII	"tes "	.ASCII	"toi "	.ASCII	"ton "	.ASCII	"une "	.ASCII	"vos "	.L	0	.EVEN;-------------\\; SEARCHINDEX3 >;-------------/; Cherche rapidement un mot d'aprs l'index  3/4 lettres.; in	A4/D4.L	^mot/lg; out	D7.W	erreur; mod	D7.WSEARCHINDEX3:	PUSHM.L	D0..D4,A2..A4; Cherche les 3 premires lettres du mot.	COMP.L	D4,#4		; mot d'au moins 4 lettres ?	JUMP,LO 80$		; non => 80$	LOAD.L	A3,A4	LOAD.L	D0,D4	LOAD.W	D1,#4-1	CLR.L	D220$:	RL.L	D2,#822$:	LOAD.B	D3,(A3+)	DEC.L	D0	JUMP,NS 80$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 22$	COMP.B	D3,#'Z	JUMP,HI 22$	LOAD.B	D2,D3	DECJ.W,NMO D1,20$; Cherche l'index correspondant aux 3/4 premires lettres du mot.	LOAD.L	D0,D2	RL.L	D0,#8	AND.W	D0,#H'FF	SUB.W	D0,#'A		; D0 <-- 0..25	MUL.WU	D0,#27*6	LOAD.L	D1,D2	SWAP.W	D1	AND.W	D1,#H'FF	SUB.W	D1,#'A-1	; D1 <-- 0..26	MUL.WU	D1,#6	ADD.W	D0,D1	LOAD.L	A2,(A6)+OPDICO	; A2 <-- ^index  2 lettres	LOAD.L	A3,#(A2)+(D0.W)	LOAD.W	D0,(A3)+4	JUMP,EQ 80$	LOAD.L	A3,#(A2)+(D0.W)	; A3 <-- ^index  3 lettres	LOAD.W	D1,D2		; D2 <-- 3me et 4me lettre	CLR.B	D1		; D1 <-- 3me lettre	SUB.L	A3,#832$:	ADD.L	A3,#8		; A3 <-- ^index suivant	TEST.W	(A3)	JUMP,EQ 80$	COMP.W	D1,(A3)		; 3me lettre trouve ?	JUMP',EQ 40$		; oui => 40$	COMP.W	D2,(A3)		; 3me et 4me lettres trouves ?	JUMP,NE 32$		; non => 32$; Initialise pour la recherche.40$:	LOAD.L	D0,(A3)+2	; D0 <-- ^relatif	ADD.L	D0,A2		; D0 <-- ^absolu	LOAD.L	(A6)+OSRCPD,D0	CLR.L	D1	LOAD.W	D1,(A3)+6	; D1 <-- longueur	ADD.L	D0,D1		; D0 <-- ^fin	LOAD.L	(A6)+OSRCPF,D0	CLR.W	(A6)+OSRCRD	; commence dans le dico principal	CLR.W	(A6)+OSRCNM	TEST.W	D4	JUMP,EQ 80$	LOAD.L	A3,#(A6)+OSRCM0	CALL	FORMMOT0	; OSRCM0 <-- mot niveau 0; Recherche le mot dans la portion indique par l'index.	LOAD.L	A5,(A6)+OSRCPD	; A5 <-- ^mot dans le dictionnaire50$:	COMP.L	A5,(A6)+OSRCPF	; fin du dictionnaire ?	JUMP,EQ 80$		; oui => 80$	LOAD.L	A3,A5	LOAD.L	A4,#(A6)+OSRCMD	CALL	DECOMOT		; OSRCMD <-- mot dcod52$:	LOAD.W	D4,(A6)+OSRCNM	INC.W	(A6)+OSRCNM	LOAD.L	A3,#(A6)+OSRCBU	LOAD.L	A4,#(A6)+OSRCMD	CALL	SEARCHMOT	; OSRCBU <-- un mot en clair	JUMP',EQ 60$	COMP.W	D7,#ERDIEX	JUMP,EQ 52$54$:	TEST.B	(A5+)		; A5 <-- ^mot suivant	JUMP,NE 54$	CLR.W	(A6)+OSRCNM	JUMP	50$60$:	LOAD.L	A4,A3		; A4 <-- ^dbut de OSRCBU	LOAD.L	A3,#(A6)+OSRCM0	CALL	COMPMOTS0	JUMP,NE 52$	CLR.W	D7		; D7 <-- trouv	JUMP'	90$80$:	LOAD.W	D7,#ERDIPT90$:	POPM.L	D0..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; SEARCHALL >;==========/; Cherche tous les mots approchant un mot donn.; Les mots trouvs sont rendus tris dans l'ordre de probabilit.; in	A4/D4.L	^mot faux/lg; out	-; mod	D7.WSEARCHALL:	PUSHM.L	D0..D4,A1..A4	CALL	MSOPLUTIN	; met le lutin spcial de la souris	CLR.W	(A6)+OMMNBM; Cherche tous les mots possibles.	LOAD.W	D0,#2		; D0 <-- deux lettres de sres	LOAD.W	D1,#-1		; D1 <-- meilleur degr10$:	LOAD.W	D2,D0		; D2 <-- nombre de lettres assures	CALL	SEARCHINIT	; initialise pour la recherche	JUMP',NE 30$20$:	LOAD.W	D2,#-1		; D2 <-- accepte n'importe quoi	CALL	SEARCHNEXT	; cherche un mot ...	JUMP',NE 30$	TEST.B	(A6)+OCHFST	; stoppe le processus fils ?	JUMP,T	70$		; oui => 70$	CALL	SEARCHADD	; OMMBUF <-- ajoute le mot	COMP.W	D1,D2	JUMP,LS 20$	LOAD.W	D1,D2		; D1 <-- meilleur degr trouv	JUMP	20$30$:	TEST.W	(A6)+OMMNBM	; trouv qq chose ?	JUMP',NE 40$		; oui => 40$	LOAD.L	A4,#(A6)+OSRCM0	; A3 <-- ^mot cherch	LOAD.L	D4,#-1	DEC.W	D0		; D0 <-- une lettre sre de moins;;?	JUMP,NC 10$	JUMP,NE 10$40$:	TEST.W	(A6)+OMMNBM	; trouv qq chose ?	JUMP',EQ 42$		; non => 42$	COMP.W	D1,#16		; trouv qq chose de phontiquement ok ?	JUMP,LO 80$		; oui => 80$42$:	LOAD.L	A2,#R16"TABLE$-4	LOAD.L	A3,#(A6)+OSRCM0	LOAD.B	D0,(A3)+0	; D0 <-- premire lettre	LOAD.B	D1,(A3)+1	; D1 <-- deuxime lettre44$:	LOAD.L	A1,#(A6)+OSRCMX	LOAD.L	A3,#(A6)+OSRCM050$:	ADD.L	A2,#4		; A2 <-- ^suivant dans TABLE$	TEST.B	(A2)		; fin de la table ?	JUMP,EQ 80$		; oui => 80$	COMP.B	D0,(A2)		; premire lettre trouve	JUMP,NE 50$	COMP.B	(A2)+1,#'*	JUMP',EQ 52$	COMP.B	D1,(A2)+1	; deuxime lettre trouve ?	JUMP,NE 50$52$:	INC.L	A3		; A3 <-- saute la premire lettre	COMP.B	(A2)+1,#'*	JUMP',EQ 53$	INC.L	A3		; A3 <-- saute les deux premires lettres53$:	LOAD.B	D2,(A2)+2	COMP.B	D2,#'*	JUMP',EQ 55$	LOAD.B	(A1+),D2	LOAD.B	D2,(A2)+3	COMP.B	D2,#'*	JUMP',EQ 55$	LOAD.B	(A1+),D255$:	LOAD.B	(A1+),(A3+)	JUMP,NE 55$	LOAD.L	A4,#(A6)+OSRCMX	LOAD.L	D4,#-1	LOAD.W	D2,#2		; D2 <-- deux lettres assures	CALL	SEARCHINIT	; initialise pour la recherche	JUMP,NE 44$60$:	LOAD.W	D2,#-1		; D2 <-- accepte n'importe quoi	CALL	SEARCHNEXT	; cherche un mot ...	JUMP,NE 44$	TEST.B	(A6)+OCHFST	; stoppe le processus fils ?	JUMP',T 70$		; oui => 70$	CALL	SEARCHADD	; OMMBUF <-- ajoute le mot	JUMP	60$70$:	CLR.B	(A6)+OMMTRI	CLR.W	(A6)+OMMNBM	; rien trouv	JUMP'	90$80$:	CALL	SEARCHTRI	; A4 <-- ^liste trie90$:	CALL	MSCLLUTIN	; remet le lutin standard de la souris	POPM.L	D0..D4,A1..A4	RETTABLE$:	.ASCII	"anam"	.ASCII	"anen"	.ASCII	"anem"	.ASCII	"aman"	.ASCII	"amen"	.ASCII	"amem"	.ASCII	"enan"	.ASCII	"enam"	.ASCII	"enem"	.ASCII	"eman"	.ASCII	"emam"	.ASCII	"emen"	.ASCII	"inim"	.ASCII	"imin"	.ASCII	"h***"	.ASCII	"a*ha"	.ASCII	"e*he"	.ASCII	"i*hi"	.ASCII	"o*ho"	.ASCII	"u*hu"	.ASCII	"y*hy"	.ASCII	"phf*"	.ASCII	"f*ph"	.B	0	.EVEN;----------\\; SEARCHADD >;----------/; Ajoute un mot trouv dans OMMBUF.; in	A3.L	^mot trouv;	D2.W	degr d'exactitude (0..n);	D3.B	type du mot;	D4.W	forme (0..n); out	-; mod	D7.WSEARCHADD:	PUSHM.L	D1,A2..A4	LOAD.L	A4,#(A6)+OMMBUF	LOAD.W	D1,(A6)+OMMNBM	COMP.W	D1,#MAXMM	; buffer tout plein ?	JUMP',HS 40$		; oui => 40$	MUL.WU	D1,#LGMM	ADD.L	A4,D1	INC.W	(A6)+OMMNBM20$:	LOAD.L	A2,#(A4)+OMMMOT22$:	LOAD.B	(A2+),(A3+)	; OMMMOT <-- mot	JUMP,NE 22$	LOAD.W	(A4)+OMMDEG,D2	; OMMDEG <-- degr	LOAD.B	(A4)+OMMTYP,D3	; OMMTYP <-- type	LOAD.W	(A4)+OMMFOR,D4	; OMMFOR <-- forme	JUMP'	90$; Regarde si l'on peut liminer un mot dont le degr d'exactitude; est moins bon.40$:	LOAD.W	D1,#MAXMM-142$:	COMP.W	D2,(A4)+OMMDEG	JUMP,LO 20$	LOAD.L	A4,#(A4)+LGMM	DECJ.W,NMO D1,42$90$:	POPM.L	D1,A2..A4	RET;----------\\; SEARCHTRI >;----------/; Trie toute la liste des mots trouvs.; in	(A6)+OMMBUF	liste longue et non tris; out	(A6)+OMMTRI	liste courte et trie;	A4.L		^liste trie; mod	D7.WSEARCHTRI:	PUSHM.L	D1..D4,A2,A3	LOAD.L	A3,#(A6)+OMMBUF	LOAD.W	D1,(A6)+OMMNBM	MUL.WU	D1,#LGMM	CLR.B	(A3)+(D1.L)	LOAD.L	A3,#(A6)+OMMTRI	LOAD.W	D1,#MAXMM32$:	LOAD.L	A4,#(A6)+OMMBUF	LOAD.L	D3,#-134$:	TEST.B	(A4)+OMMMOT	; encore un mot ?	JUMP',EQ 38$		; non => 38$	LOAD.W	D4,(A4)+OMMDEG	SWAP.W	D4	LOAD.W	D4,(A4)+OMMFOR	COMP.L	D3,D4	JUMP',LS 36$	LOAD.L	D3,D4	LOAD.L	A2,A436$:	LOAD.L	A4,#(A4)+LGMM	; A4 <-- ^mot suivant	JUMP	34$38$:	COMP.L	D3,#-1	JUMP',EQ 42$	LOAD.L	A4,A2	LOAD.W	D4,#(LGMM/2)-140$:	LOAD.W	(A3+),(A2+)	; OMMTRI <-- mot trouv	DECJ.W,NMO D4,40$	LOAD.W	(A4)+OMMDEG,#-1	; le mot trouv est maintenant "prim" !	LOAD.W	(A4)+OMMFOR,#-1	DEC.W	D1	JUMP,NE 32$42$:	CLR.B	(A3)+OMMMOT	; OMMTRI <-- terminateur	LOAD.L	A4,#(A6)+OMMTRI	; A4 <-- ^liste des mots trouvs	POPM.L	D1..D4,A2,A3	RET;-----------\\; SEARCHINIT >;-----------/; Dbut d'une recherche avec SEARCHNEXT.; in	A4/D4.L	^mot faux/lg;	D2.W	nb de lettres sres (2..0); out	D7.W	erreur; mod	D7.WSEARCHINIT:	PUSHM.L	D3,D4,A3,A4	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv	LOAD.W	(A6)+OSRCLS,D2	; OSRCLS <-- nb de lettres sres	TEST.W	D4	JUMP,EQ 90$	LOAD.L	A3,#(A6)+OSRCM0	CALL	FORMMOT0	; OSRCM0 <-- mot niveau 0	LOAD.L	A4,#(A6)+OSRCM0	LOAD.L	A3,#(A6)+OSRCM1	CALL	FORMMOT1	; OSRCM1 <-- mot niveau 1	LOAD.L	A4,#(A6)+OSRCM0	LOAD.L	A3,#(A6)+OSRCM2	CALL	FORMMOT2	; OSRCM2 <-- mot niveau 2	CLR.W	D4	COMP.W	D2,#1		; une lettre sre ?	JUMP,LO 40$		; non => 40$	LOAD.L	A3,#(A6)+OSRCM0	CLR.W	D3	LOAD.B	D3,(A3)	CALL	NOACCENT	COMP.B	D3,#'a	JUMP,LO 80$	COMP.B	D3,#'z	JUMP,HI 80$	SUB.B	D3,#'a		; D3 <-- 0..25	MUL.WU	D3,#27*6	LOAD.W	D4,D3	COMP.W	D2,#2		; deux lettres sres ?	JUMP,LO 40$		; non => 40$	CLR.W	D3	LOAD.B	D3,(A3)+1	COMP.B	D3,#SPACE	JUMP',EQ 30$	COMP.B	D3,#''	JUMP',EQ 30$	COMP.B	D3,#'-	JUMP',NE 32$30$:	LOAD.B	D3,(A3)+232$:	CALL	NOACCENT	COMP.B	D3,#'a	JUMP',LO 34$	COMP.B	D3,#'z	JUMP',LS 35$34$:	LOAD.B	D3,#'a-135$:	SUB.B	D3,#'a-1	; D3 <-- 0..26	MUL.WU	D3,#6	ADD.W	D4,D340$:	LOAD.L	A4,(A6)+OPDICO	; A4 <-- ^index	LOAD.L	A3,#(A4)+(D4.W)	LOAD.L	D4,(A3)	JUMP,EQ 80$	ADD.L	D4,A4	LOAD.L	(A6)+OSRCPD,D4	LOAD.W	D4,#27*26*6	TEST.W	D2		; aucune lettre sre ?	JUMP',EQ 50$		; oui => 50$	LOAD.W	D4,#27*6	COMP.W	D2,#1		; une lettre sre ?	JUMP',EQ 50$		; oui => 50$	LOAD.W	D4,#1*650$:	ADD.W	A3,D452$:	LOAD.L	D4,(A3)	ADD.L	A3,#6	JUMP,EQ 52$	ADD.L	D4,A4	LOAD.L	(A6)+OSRCPF,D4	JUMP'	85$80$:	CLR.L	(A6)+OSRCPD	CLR.L	(A6)+OSRCPF85$:	CLR.W	(A6)+OSRCRD	; commence dans le dico principal	CLR.W	(A6)+OSRCNM	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; SEARCHCADRE >;------------/; Cherche le dbut et la fin d'un mot.; in	A3/D3.L	^mots/lg; out	A4/D4.L	^mot/lg; mod	D4.L, A4.LSEARCHCADRE:	PUSHM.L	D1..D3,A2,A3	CLR.L	D4		; D4 <-- lg mot	LOAD.L	A4,A3	LOAD.L	D2,D3	JUMP,EQ EXIT$; Cherche le dbut d'un mot.BEGIN$:	LOAD.B	D3,(A4)	COMP.B	D3,#BOA	JUMP',EQ BOA$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP',LO BEGIN2$	COMP.B	D3,#'Z		; est-ce une lettre ?	JUMP,LS PREF$		; oui => PREF$BEGIN2$:	INC.L	A4	DEC.L	D2	JUMP,NE BEGIN$	JUMP	EXIT$; Saute une commande boa.BOA$:	TEST.B	(A6)+ODFFAN+1:#BDFSCB-16 ; saute les commandes boa ?	JUMP,BC BEGIN2$		; non => BEGIN2$				; oui =>	LOAD.W	D1,#1		; D1 <-- nb de commandes boa imbriques	COMP.L	D2,#2	JUMP',LO BOA4$	LOAD.B	D3,(A4)+1	; D3 <-- caractre juste aprs le boa	COMP.B	D3,#'A	JUMP',LO BOA2$	COMP.B	D3,#'Z	JUMP',LS BOA4$	COMP.B	D3,#'a	JUMP',LO BOA2$	COMP.B	D3,#'z		; est-ce une lettre ?	JUMP',LS BOA4$		; oui => BOA4$BOA2$:				; non =>	ADD.L	A4,#2		; A4 <-- saute commande boa "courte"	SUB.L	D2,#2	JUMP	BEGIN$BOA4$:	INC.L	A4	DEC.L	D2	JUMP,EQ EXIT$	LOAD.B	D3,(A4)	COMP.B	D3,#CR	JUMP,EQ BEGIN$	COMP.B	D3,#';	JUMP',EQ BOA6$	COMP.B	D3,#':	JUMP',EQ BOA6$	COMP.B	D3,#BOA	JUMP,NE BOA4$	INC.W	D1		; D1 <-- une imbrication de plus	JUMP	BOA4$BOA6$:	DEC.W	D1		; D1 <-- une imbrication de moins	JUMP,NE BOA4$	JUMP	BEGIN$; Saute le prfixe au dbut du mot.PREF$:	LOAD.L	A2,#R16"TABLE$PREF2$:	TEST.B	(A2)		; encore un prfixe ?	JUMP',EQ END$		; non => END$	LOAD.L	A3,A4	LOAD.L	D1,D2PREF3$:	TEST.B	(A2)	JUMP',EQ PREF8$	DEC.L	D1	JUMP',NS PREF5$	LOAD.B	D3,(A3+)	CALL	MAJMIN	COMP.B	D3,(A2+)	JUMP,EQ PREF3$PREF5$:	TEST.B	(A2+)		; A2 <-- ^prfixe suivant	JUMP,NE PREF5$	JUMP	PREF2$PREF8$:	ADD.L	D2,A4	SUB.L	D2,A3		; D2 <-- longueur restante	LOAD.L	A4,A3		; A4 <-- saute le prfixe; Cherche la fin du mot.END$:	LOAD.L	A3,A4END2$:	DEC.L	D2	JUMP',NS END6$	LOAD.B	D3,(A3+)	COMP.B	D3,#''	JUMP',EQ END4$	COMP.B	D3,#'-	JUMP',EQ END4$	COMP.B	D3,#LF	JUMP',EQ END4$	COMP.B	D3,#TIRET	JUMP',EQ END4$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP',LO END5$	COMP.B	D3,#'Z	JUMP',HI END5$END4$:	INC.L	D4		; D4 <-- un caractre de plus	JUMP	END2$END5$:	DEC.L	A3END6$:	TEST.L	D4	JUMP',EQ EXIT$	COMP.B	(A3)-1,#''	; 'mot' ?	JUMP',NE EXIT$	DEC.L	D4		; D4 <-- ne compte pas le dernier 'EXIT$:	POPM.L	D1..D3,A2,A3	RETTABLE$:	.ASCIZ	"l'"		; l'oiseau	.ASCIZ	"c'"		; c'est	.ASCIZ	"s'"		; s'en alla	.ASCIZ	"t'"		; va-t'en	.ASCIZ	"m'"		; donne-m'en	.ASCIZ	"n'"		; il n'avait rien	.ASCIZ	"j'"		; j'avais	.ASCIZ	"d'"		; d'aucun	.ASCIZ	"qu'"		; qu'elles	.ASCIZ	"non-"		; non-spcialiste	.ASCIZ	"demi-"		; demi-lune	.ASCIZ	"sous-"		; sous-entendu	.B	0	.EVEN;-----------\\; SEARCHNEXT >;-----------/; Cherche le mot suivant.; in	D2.W	degr d'exactitude maximal admis (0..n); out	A3.L	^mot trouv;	D2.W	degr d'exactitude (0..n);	D3.B	type du mot;	D4.W	forme (0..n);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A3.LSEARCHNEXT:	PUSHM.L	D0,D1,A2,A4,A5	LOAD.W	D1,D2		; D1 <-- degr maximal admisBEGIN$:	LOAD.L	A5,(A6)+OSRCPD	; A5 <-- ^mot dans le dictionnaireLOOP$:	TEST.W	(A6)+OSRCRD	; tait-on dans le dico principal ?	JUMP,EQ PRINC1$		; oui => PRINC1$	TEST.B	(A6)+OSRCTD	; dictionnaire encod ?	JUMP,T	PRIVE1$		; oui => PRIVE1$	JUMP	SIMPL1$		; non => SIMPL1$NEXT$:	TEST.W	(A6)+OSRCRD	; tait-on dans le dico principal ?	JUMP,EQ PRINC3$		; oui => PRINC3$	TEST.B	(A6)+OSRCTD	; dictionnaire encod ?	JUMP,T	PRIVE3$		; oui => PRIVE3$	JUMP	SIMPL3$		; non => SIMPL3$; Cherche le mot suivant dans le dictionnaire principal.PRINC1$:	COMP.L	A5,(A6)+OSRCPF	; fin du dictionnaire ?	JUMP,EQ DICO$		; oui => DICO$	LOAD.L	A3,A5	LOAD.L	A4,#(A6)+OSRCMD	CALL	DECOMOT		; OSRCMD <-- mot dcodPRINC3$:	LOAD.W	D4,(A6)+OSRCNM	INC.W	(A6)+OSRCNM	LOAD.L	A3,#(A6)+OSRCBU	LOAD.L	A4,#(A6)+OSRCMD	CALL	SEARCHMOT	; OSRCBU <-- un mot en clair	JUMP,EQ COMP$	COMP.W	D7,#ERDIEX	JUMP,EQ PRINC3$PRINC5$:	TEST.B	(A5+)		; A5 <-- ^mot suivant	JUMP,NE PRINC5$	CLR.W	(A6)+OSRCNM	JUMP	STOP$; Cherche le mot suivant dans un dictionnaire priv encod.PRIVE1$:	COMP.L	A5,(A6)+OSRCPF	; fin du dictionnaire ?	JUMP,EQ DICO$		; oui => DICO$	LOAD.L	A3,A5	LOAD.L	A4,#(A6)+OSRCMDPRIVE22$:	LOAD.B	D3,(A3+)	COMP.B	D3,#CR	JUMP',EQ PRIVE23$	LOAD.B	(A4+),D3	; OSRCMD <-- mot <0>	JUMP	PRIVE22$PRIVE23$:	CLR.B	(A4)PRIVE3$:	LOAD.W	D4,(A6)+OSRCNM	INC.W	(A6)+OSRCNM	LOAD.L	A3,#(A6)+OSRCBU	LOAD.L	A4,#(A6)+OSRCMD	CALL	SEARCHMOT	; OSRCBU <-- un mot en clair	JUMP,EQ COMP$	COMP.W	D7,#ERDIEX	JUMP,EQ PRIVE3$	LOAD.B	D3,#CRPRIVE5$:	COMP.B	D3,(A5+)	; A5 <-- ^mot suivant	JUMP,NE PRIVE5$	CLR.W	(A6)+OSRCNM	JUMP	STOP$; Cherche le mot suivant dans un dictionnaire priv simple.SIMPL1$:SIMPL3$:	COMP.L	A5,(A6)+OSRCPF	; fin du dictionnaire ?	JUMP,EQ DICO$		; oui => DICO$	LOAD.L	A3,#(A6)+OSRCBU	LOAD.L	A4,#(A6)+OSRCMD	LOAD.B	(A4+),#'?SIMPL22$:	LOAD.B	D3,(A5+)	COMP.B	D3,#CR	JUMP',EQ SIMPL23$	LOAD.B	(A3+),D3	; OSRCBU <-- mot <0>	LOAD.B	(A4+),D3	; OSRCMD <-- ?mot <0>	JUMP	SIMPL22$SIMPL23$:	CLR.B	(A3)	CLR.B	(A4)	LOAD.L	A3,#(A6)+OSRCBU	LOAD.W	(A6)+OSRCNM,#1	JUMP	COMP$STOP$:	TEST.B	(A6)+OCHFEX	; processus fils existe ?	JUMP',F STOP2$		; non => STOP2$	CALL	MSCHLUTIN	; fait tourner le lutin de la sourisSTOP2$:	TEST.B	(A6)+OCHFST	; stoppe le processus fils ?	JUMP,F	LOOP$		; non => LOOP$	CLR.W	D7		; D7 <-- ok	JUMP	EXIT$; Cherche le bloc suivant dans le mme dictionnaire,; ou carrment le dictionnaire suivant.DICO$:	LOAD.W	D7,#ERDIPT	; D7 <-- c'est fini	COMP.W	(A6)+OSRCLS,#2	; deux lettres sres ?	JUMP,NE EXIT$		; non => EXIT$	TEST.W	(A6)+OSRCRD	; tait-on dans le dico principal ?	JUMP',EQ DICO2$		; oui => DICO2$	LOAD.L	A4,(A6)+OSRCPH	TEST.L	(A4)+ODUPNX	; encore un bloc ?	JUMP',EQ DICO2$		; non => DICO2$	LOAD.L	A4,(A4)+ODUPNX	; A4 <-- ^bloc suivant	JUMP'	DICO5$DICO2$:	INC.W	(A6)+OSRCRD	; passe au dictionnaire suivant	LOAD.W	D7,#ERDIPT	; D7 <-- c'est fini	LOAD.L	A4,#(A6)+OTADL	LOAD.W	D4,(A6)+OSRCRD	; D4 <-- rang du dictionnaire	DEC.W	D4		; D4 <-- 0..n	COMP.W	D4,#MAXDL+1	; encore un dictionnaire ?	JUMP,HS EXIT$		; non => EXIT$	MUL.WU	D4,#LDL	ADD.L	A4,D4		; A4 <-- ^dans OTADL	TEST.B	(A4)+ODLNOM	; dictionnaire existe ?	JUMP,EQ DICO2$		; non => DICO2$	TEST.L	(A4)+ODLPT	; dictionnaire charg ?	JUMP',NE DICO4$		; oui => DICO4$	LOAD.L	A3,#(A4)+ODLNOM	; A3 <-- ^nom du dictionnaire	PUSH.L	A4	CALL	DICOLOAD	; charge un dictionnaire utilisateur	LOAD.L	A3,A4	POP.L	A4	TEST.W	D7	JUMP,NE DICO2$	LOAD.L	(A4)+ODLPT,A3DICO4$:	LOAD.L	A4,(A4)+ODLPT	; A4 <-- ^premier bloc	CLR.B	(A6)+OSRCTD	COMP.B	(A4)+LDU,#'*	; dictionnaire encod ?	JUMP',NE DICO5$		; non => DICO5$	SET.B	(A6)+OSRCTDDICO5$:	LOAD.L	(A6)+OSRCPH,A4	; OSRCPH <-- ^en-tte bloc	LOAD.L	A3,#(A4)+LDU	LOAD.L	(A6)+OSRCPD,A3	; OSRCPD <-- ^dbut	ADD.L	A3,(A4)+ODULGU	LOAD.L	(A6)+OSRCPF,A3	; OSRCPD <-- ^fin	JUMP	BEGIN$; Compare les mots avec le niveau d'exactitude 0.COMP$:	LOAD.L	A4,A3		; A4 <-- ^dbut de OSRCBU	LOAD.L	A3,#(A6)+OSRCM0	CALL	COMPMOTS0	JUMP',NE COMP1$	CLR.W	D2	JUMP	FOUND$; Compare les mots avec le niveau d'exactitude 1 (accents).COMP1$:	COMP.W	D1,#1	JUMP,LO NEXT$	LOAD.L	A4,#(A6)+OSRCBU	LOAD.L	A3,#(A6)+OSRCM1	CALL	COMPMOTS1	JUMP',NE COMP2$	LOAD.W	D2,#1	JUMP	FOUND$; Compare les mots avec le niveau d'exactitude 2 (~phontique).COMP2$:	COMP.W	D1,#2	JUMP,LO NEXT$	LOAD.L	A4,#(A6)+OSRCBU	LOAD.L	A3,#(A6)+OSRCM2	CALL	COMPMOTS2	JUMP',NE COMP3$	LOAD.W	D2,#2	JUMP	FOUND$; Compare les mots avec le niveau d'exactitude 3 (permutations).COMP3$:	COMP.W	D1,#16	JUMP,LO NEXT$	LOAD.W	D2,#16	LOAD.L	A4,#(A6)+OSRCBU	LOAD.L	A3,#(A6)+OSRCM1	CALL	COMPMOTS3	JUMP',EQ FOUND$	COMP.W	D1,#32	JUMP,LO NEXT$	LOAD.W	D2,#32	LOAD.L	A4,#(A6)+OSRCMX	LOAD.L	A3,#(A6)+OSRCM2	CALL	COMPMOTS3	JUMP,NE NEXT$FOUND$:	LOAD.L	A3,#(A6)+OSRCBU	; A3 <-- ^mot trouv	LOAD.L	A4,#(A6)+OSRCMD	; A4 <-- ^type-mot	LOAD.B	D3,(A4)		; D3 <-- ^type du mot	COMP.B	D3,#'>	JUMP',NE FOUND4$	INC.L	A4FOUND2$:	COMP.B	(A4+),#'>	JUMP,NE FOUND2$	LOAD.B	D3,(A4)		; D3 <-- ^type du verbeFOUND4$:	LOAD.W	D4,(A6)+OSRCNM	DEC.W	D4		; D4 <-- forme (0..n)	CLR.W	D7		; D7 <-- trouvEXIT$:	LOAD.L	(A6)+OSRCPD,A5	POPM.L	D0,D1,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; COMPMOTS0 >;----------/; Compare deux mots avec le niveau d'exactitude 0.; in	A3.L	^chane cherche <0>;	A4.L	^chane <0>; out	D7.W	erreur; mod	D0.L, D3.L, D4.L, D7.W, A2.L, A3.L, A4.LCOMPMOTS0:	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv	LOAD.L	D0,(A6)+OSRCB0	; D0 <-- bits des lettres majuscules	LOAD.W	D4,#-1		; D4 <-- rang des caractres20$:	INC.W	D4		; D4 <-- rang suivant	LOAD.B	D3,(A4+)	JUMP',EQ 40$	COMP.B	D3,(A3+)	JUMP,EQ 20$	TEST.L	D0:D4		; lettre majuscule dans le mot original ?	JUMP',BC 90$		; non => 90$	COMP.B	D3,#'	JUMP',LO 90$	COMP.B	D3,#'		; est-ce une minuscule accentue ?	JUMP',HI 30$		; non => 30$	CALL	NOACCENT	; D3 <-- minuscule sans accent	COMP.B	D3,(A3)-1	; compare une deuxime fois	JUMP,EQ 20$	JUMP'	90$30$:	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'Z		; est une majuscule ?	JUMP',HI 90$		; non => 90$;	CALL	MAJMIN		; D3 <-- lettre minuscule	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule	COMP.B	D3,(A3)-1	; compare une deuxime fois	JUMP,EQ 20$	JUMP'	90$40$:	TEST.B	(A3)	JUMP',NE 90$	CLR.W	D7		; D7 <-- trouv90$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; COMPMOTS1 >;----------/; Compare deux mots avec le niveau d'exactitude 1 (accent).; in	A3.L	^chane cherche <0>;	A4.L	^chane <0>; out	D7.W	erreur; mod	D0.L, D3.L, D4.L, D7.W, A2.L, A3.L, A4.LCOMPMOTS1:	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv20$:	LOAD.B	D3,(A4+)	JUMP',EQ 30$	CALL	NOACCENT	CALL	MAJMIN	COMP.B	D3,(A3+)	JUMP,EQ 20$	JUMP'	90$30$:	TEST.B	(A3)	JUMP',NE 90$	CLR.W	D7		; D7 <-- trouv90$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; COMPMOTS2 >;----------/; Compare deux mots avec le niveau d'exactitude 2 (~phontique).; in	A3.L	^chane cherche <0>;	A4.L	^chane <0>; out	D7.W	erreur; mod	D0.L, D3.L, D4.L, D7.W, A2.L, A3.L, A4.LCOMPMOTS2:	LOAD.L	A2,A3	LOAD.L	A3,#(A6)+OSRCMX	CALL	FORMMOT2	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv20$:	TEST.B	(A2)	JUMP',EQ 30$	COMP.B	(A2+),(A3+)	JUMP,EQ 20$	JUMP'	90$30$:	TEST.B	(A3+)	JUMP',EQ 80$	TEST.B	(A3)	JUMP',NE 90$80$:	CLR.W	D7		; D7 <-- trouv90$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; COMPMOTS3 >;----------/; Compare deux mots avec le niveau d'exactitude 3 (permutations).; in	A3.L	^chane <0>;	D2.W	degr d'exactitude initial;	A4.L	^chane <0>; out	D2.W	degr d'exactitude trouv;	D7.W	erreur; mod	D0.L, D2.L, D3.L, D4.L, D7.W, A2.L, A3.L, A4.LCOMPMOTS3:	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv	JUMP'	20$22$:	INC.W	D221$:	INC.W	D220$:	LOAD.B	D3,(A3+)	JUMP,EQ 50$	LOAD.B	D4,(A4+)	JUMP,EQ 60$	COMP.B	D3,D4	JUMP,EQ 20$	LOAD.B	D4,(A4+)	JUMP',EQ 30$	COMP.B	D3,D4	JUMP,EQ 22$30$:	LOAD.B	D3,(A3+)	JUMP,EQ 50$	COMP.B	D3,D4	JUMP,EQ 21$	SUB.L	A4,#2	LOAD.B	D4,(A4+)	JUMP,EQ 60$	COMP.B	D3,D4	JUMP,EQ 22$	JUMP	90$50$:	TEST.B	(A4)	JUMP',NE 90$	JUMP'	80$60$:	TEST.B	(A3)	JUMP',NE 90$80$:	CLR.W	D7		; D7 <-- trouv90$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; FORMMOT0 >;---------/; Formate un mot pour le niveau d'exactitude 0.; in	A4/D4.L	^mot/lg;	A3.L	^buffer pour chane formate; out	-; mod	D7.WFORMMOT0:	PUSHM.L	D0..D3,A3,A4	CLR.L	D0		; D0 <-- map des majuscules	CLR.W	D1		; D1 <-- rang du caractreLOOP$:	LOAD.B	D3,(A4+)	JUMP',EQ TERM$	COMP.B	D3,#LF	JUMP',EQ MINUS$	COMP.B	D3,#TIRET	JUMP',EQ MINUS$	LOAD.B	D2,D3	CALL	MAJMIN		; D3 <-- caractre minuscule	LOAD.B	(A3+),D3	COMP.B	D2,D3		; lettre  majuscule ?	JUMP',EQ MINUS$		; non => MINUS$	TSET.L	D0:D1		; D0 <-- une majusculeMINUS$:	INC.W	D1		; D1 <-- rang suivant	DEC.W	D4	JUMP,NE LOOP$TERM$:	CLR.B	(A3)	LOAD.L	(A6)+OSRCB0,D0	; OSRCB0 <-- bits pour les majuscules	POPM.L	D0..D3,A3,A4	RET;---------\\; FORMMOT1 >;---------/; Formate un mot pour le niveau d'exactitude 1 (accents).; in	A4.L	^chane <0>;	A3.L	^buffer pour chane formate; out	-; mod	D7.WFORMMOT1:	PUSHM.L	D3,A3,A4LOOP$:	LOAD.B	D3,(A4+)	JUMP',EQ TERM$	CALL	NOACCENT	CALL	MAJMIN	LOAD.B	(A3+),D3	JUMP	LOOP$TERM$:	CLR.B	(A3)	POPM.L	D3,A3,A4	RET;---------\\; FORMMOT2 >;---------/; Formate un mot pour le niveau d'exactitude 2 (~phontique).; in	A4.L	^chane <0>;	A3.L	^buffer pour chane formate; out	-; mod	D7.WFORMMOT2:	PUSHM.L	D3,D4,A1..A4	LOAD.L	A2,#R16"TABLE$LOOP$:	CLR.W	D3	LOAD.B	D3,(A4+)	JUMP',EQ TERM$	COMP.B	D3,(A4)		; double lettre ?	JUMP,EQ LOOP$		; oui => LOOP$ (plus qu'une)	CALL	NOACCENT	LOAD.B	D4,D3	COMP.B	D3,#'a	JUMP,LO NORM$	COMP.B	D3,#'z	JUMP,HI NORM$	SUB.B	D3,#'a	SL.W	D3,#1	LOAD.L	A1,A2	ADD.W	A1,(A1)+(D3.W)	JUMP	(A1)		; JUMP LET?$TERM$:	CLR.B	(A3)	POPM.L	D3,D4,A1..A4	RETTABLE$:	.W	LETa$-TABLE$	.W	LETb$-TABLE$	.W	LETc$-TABLE$	.W	LETd$-TABLE$	.W	LETe$-TABLE$	.W	LETf$-TABLE$	.W	LETg$-TABLE$	.W	LETh$-TABLE$	.W	LETi$-TABLE$	.W	LETj$-TABLE$	.W	LETk$-TABLE$	.W	LETl$-TABLE$	.W	LETm$-TABLE$	.W	LETn$-TABLE$	.W	LETo$-TABLE$	.W	LETp$-TABLE$	.W	LETq$-TABLE$	.W	LETr$-TABLE$	.W	LETs$-TABLE$	.W	LETt$-TABLE$	.W	LETu$-TABLE$	.W	LETv$-TABLE$	.W	LETw$-TABLE$	.W	LETx$-TABLE$	.W	LETy$-TABLE$	.W	LETz$-TABLE$NORM$:	LOAD.B	(A3+),D4	JUMP	LOOP$LETa$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'i	JUMP',EQ LETai$	COMP.B	D3,#'u		; au -> o	JUMP,EQ SONo$	COMP.B	D3,#'n		; an -> an	JUMP,EQ SONan$	COMP.B	D3,#'m		; am -> an	JUMP,EQ SONan$	DEC.L	A4	JUMP	NORM$LETai$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'n		; ain -> in	JUMP,EQ SONin$	DEC.L	A4	JUMP	SONai$		; ai -> eLETb$:	JUMP	NORM$LETc$:	LOAD.B	D3,(A4)	COMP.B	D3,#'a		; ca -> ka	JUMP,EQ SONk$	COMP.B	D3,#'e		; ce -> se	JUMP,EQ SONs$	COMP.B	D3,#'i		; ci -> si	JUMP,EQ SONs$	COMP.B	D3,#'o		; co -> ko	JUMP,EQ SONk$	COMP.B	D3,#'u		; cu -> ku	JUMP,EQ SONk$	INC.L	A4	COMP.B	D3,#'h		; ch -> ch	JUMP,EQ SONch$	JUMP	SONk$		; c? -> k?LETd$:	JUMP	NORM$LETe$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'n		; en -> an	JUMP,EQ SONan$	COMP.B	D3,#'m		; em -> am	JUMP,EQ SONan$	COMP.B	D3,#'a	JUMP',EQ LETea$	COMP.B	D3,#'i	JUMP',EQ LETei$	DEC.L	A4	JUMP	NORM$LETea$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'u		; eau -> o	JUMP,EQ SONo$	SUB.L	A4,#2	JUMP	NORM$LETei$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'n		; ein -> in	JUMP,EQ SONin$	SUB.L	A4,#2	JUMP	NORM$LETf$:	JUMP	NORM$LETg$:	LOAD.B	D3,(A4)	COMP.B	D3,#'e		; ge -> je	JUMP,EQ SONj$	COMP.B	D3,#'i		; gi -> ji	JUMP,EQ SONj$	INC.L	A4	COMP.B	D3,#'u		; gu -> g	JUMP,EQ SONg$	COMP.B	D3,#'n		; gn -> ni	JUMP,EQ SONni$	DEC.L	A4	JUMP	NORM$LETh$:	JUMP	LOOP$		; h -> rienLETi$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'n		; in -> in	JUMP,EQ SONin$	COMP.B	D3,#'m		; im -> in	JUMP,EQ SONin$	COMP.B	D3,#'l	JUMP',EQ LETil$	DEC.L	A4	JUMP	NORM$LETil$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'l	JUMP',EQ LETill$	SUB.L	A4,#2	JUMP	NORM$LETill$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'e		; ille -> ie	JUMP,EQ SONie$	SUB.L	A4,#3	JUMP	NORM$LETj$:	JUMP	NORM$LETk$:	JUMP	SONk$LETl$:	JUMP	NORM$LETm$:	JUMP	NORM$LETn$:	JUMP	NORM$LETo$:	JUMP	NORM$LETp$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'h		; ph -> f	JUMP,EQ SONf$	DEC.L	A4	JUMP	NORM$LETq$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'u		; qu -> k	JUMP,EQ SONk$	DEC.L	A4	JUMP	NORM$LETr$:	JUMP	NORM$LETs$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'c		; sc -> s	JUMP,EQ SONs$	COMP.B	D3,#'i	JUMP',EQ LETsi$	DEC.L	A4	JUMP	NORM$LETsi$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'e	JUMP',EQ LETsie$	SUB.L	A4,#2	JUMP	NORM$LETsie$:	LOAD.B	D3,(A4)-4	COMP.B	D3,#'a	JUMP,EQ SONsie$		; <voyelle>sie -> sie	COMP.B	D3,#'e	JUMP,EQ SONsie$	COMP.B	D3,#'i	JUMP,EQ SONsie$	COMP.B	D3,#'o	JUMP,EQ SONsie$	COMP.B	D3,#'u	JUMP,EQ SONsie$	SUB.L	A4,#2	JUMP	NORM$LETt$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'i	JUMP',EQ LETti$	DEC.L	A4	JUMP	NORM$LETti$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'e	JUMP',EQ LETtie$	COMP.B	D3,#'o	JUMP',EQ LETtio$	SUB.L	A4,#2	JUMP	NORM$LETtie$:	LOAD.B	D3,(A4)-4	COMP.B	D3,#'a	JUMP,EQ SONsie$		; <voyelle>tie -> sie	COMP.B	D3,#'e	JUMP,EQ SONsie$	COMP.B	D3,#'i	JUMP,EQ SONsie$	COMP.B	D3,#'o	JUMP,EQ SONsie$	COMP.B	D3,#'u	JUMP,EQ SONsie$	SUB.L	A4,#2	JUMP	NORM$LETtio$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'n	JUMP,EQ SONsion$	; tion -> sion	SUB.L	A4,#3	JUMP	NORM$LETu$:	JUMP	NORM$LETv$:	JUMP	NORM$LETw$:	JUMP	NORM$LETx$:	JUMP	NORM$LETy$:	JUMP	SONi$		; y -> iLETz$:	JUMP	NORM$SONi$:	LOAD.B	(A3+),#'i	JUMP	LOOP$SONo$:	LOAD.B	(A3+),#'o	JUMP	LOOP$SONf$:	LOAD.B	(A3+),#'f	JUMP	LOOP$SONs$:	LOAD.B	(A3+),#'s	JUMP	LOOP$SONj$:	LOAD.B	(A3+),#'j	JUMP	LOOP$SONk$:	LOAD.B	(A3+),#'k	JUMP	LOOP$SONg$:	LOAD.B	(A3+),#'g	JUMP	LOOP$SONan$:	LOAD.B	(A3+),#'a	LOAD.B	(A3+),#'n	JUMP	LOOP$SONin$:	LOAD.B	(A3+),#'i	LOAD.B	(A3+),#'n	JUMP	LOOP$SONie$:	LOAD.B	(A3+),#'i	LOAD.B	(A3+),#'e	JUMP	LOOP$SONai$:	LOAD.B	(A3+),#'e	JUMP	LOOP$SONch$:	LOAD.B	(A3+),#'c	LOAD.B	(A3+),#'h	JUMP	LOOP$SONni$:	LOAD.B	(A3+),#'n	LOAD.B	(A3+),#'i	JUMP	LOOP$SONsie$:	LOAD.B	(A3+),#'s	LOAD.B	(A3+),#'i	LOAD.B	(A3+),#'e	JUMP	LOOP$SONsion$:	LOAD.B	(A3+),#'s	LOAD.B	(A3+),#'i	LOAD.B	(A3+),#'o	LOAD.B	(A3+),#'n	JUMP	LOOP$;----------\\; SEARCHMOT >;----------/; Cherche un mot en clair.; Si type = "P" (nom propre) =>;;	    |	muet	aspir;	----|-------------------;	min |	 h	 H	<-- dans le dico priv;	maj |	 hH	 HH	<-- dans le dico priv; in	A4.L	^mot;	D4.W	numro du mot (0..n);	A3.L	^buffer pour mot en clair; out	D7.W	erreur; mod	D7.WSEARCHMOT:	PUSHM.L	D0..D5,A0..A4DEBUT$:	LOAD.B	D2,(A4+)	; D2 <-- type	LOAD.L	A2,A4	LOAD.L	A1,A3	TEST.W	(A6)+OSRCLS	; au moins une lettre de sr ?	JUMP',NE PASTOUT$	; oui => PASTOUT$	TEST.W	D4	JUMP,NE RIEN$PASTOUT$:	TEST.W	D4	JUMP',EQ INF$	COMP.B	D2,#'t	JUMP,EQ VERBE$	COMP.B	D2,#'i	JUMP,EQ VERBE$	COMP.B	D2,#'u	JUMP,EQ VERBE$	COMP.B	D2,#'r	JUMP,EQ VERBE$	COMP.B	D2,#'1	JUMP,EQ VERBE$	COMP.B	D2,#'2	JUMP,EQ VERBE$	COMP.B	D2,#'h	JUMP,EQ VERBE$	COMP.B	D2,#'v	JUMP,EQ VERBE$	COMP.B	D2,#'7	JUMP,EQ VERBE$INF$:	COMP.B	D2,#'>	JUMP,EQ VEXCEP$	LOAD.B	D3,(A4)	COMP.B	D3,#'h	JUMP',EQ LETTH$	COMP.B	D3,#'H		; mot commence par un "h" ?	JUMP',NE LOOP$		; non => LOOP$LETTH$:	COMP.B	D2,#'P	JUMP',NE PUTHMI$	COMP.B	(A4)+1,#'H	JUMP',NE PUTHMI$;	JUMP'	PUTHMA$PUTHMA$:	ADD.L	A4,#2		; A4 <-- saute "hH" ou "HH"	LOAD.B	(A3+),#'H	JUMP'	LOOP$PUTHMI$:	INC.L	A4		; A4 <-- saute "h" ou "H"	LOAD.B	(A3+),#'h;	JUMP'	LOOP$LOOP$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'	JUMP',LO SPEC$	COMP.B	D3,#'	JUMP',LS NEXT$	COMP.B	D3,#SPACE	JUMP',EQ NEXT$	COMP.B	D3,#''	JUMP',EQ NEXT$	COMP.B	D3,#'-	JUMP',EQ NEXT$	COMP.B	D3,#'A	JUMP',LO SPEC$	COMP.B	D3,#'Z	JUMP',LS NEXT$	COMP.B	D3,#'a	JUMP',LO SPEC$	COMP.B	D3,#'z	JUMP',HI SPEC$NEXT$:	LOAD.B	(A3+),D3	JUMP	LOOP$SPEC$:	TEST.B	D3	JUMP,EQ CR$	COMP.B	D3,#'$	JUMP,EQ DOLLAR$	COMP.B	D3,#'(	JUMP,EQ CR$	COMP.B	D3,#',		; si "1monter,2"	JUMP,EQ CR$	COMP.B	D3,#'.	JUMP,EQ POINT$	COMP.B	D3,#'0	JUMP,LO ERROR$	COMP.B	D3,#'9	JUMP,LS NB$	COMP.B	D3,#':	JUMP,EQ DEUXPT$	COMP.B	D3,#']	JUMP,EQ CROCHET$	COMP.B	D3,#'|	JUMP,EQ BARRE$ERROR$:	LOAD.W	D7,#ERDICO	; D7 <-- erreur dans le dico !	JUMP	EXIT$CR$:	TEST.W	D4	JUMP,EQ OK$	COMP.B	D2,#'m	JUMP,EQ CRMOT$	COMP.B	D2,#'f	JUMP,EQ CRMOT$	JUMP	RIEN$CRMOT$:	COMP.W	D4,#1	JUMP,NE RIEN$	LOAD.B	(A3+),#'s	JUMP	OK$CROCHET$:	TEST.W	D4	JUMP,EQ OK$	COMP.W	D4,#1	JUMP,NE RIEN$	LOAD.B	(A3+),#'s	JUMP	OK$DOLLAR$:	TEST.W	D4	JUMP,EQ OK$	COMP.W	D4,#1	JUMP,EQ DOLLAR1$	COMP.W	D4,#2	JUMP,EQ DOLLAR2$	COMP.W	D4,#3	JUMP,EQ DOLLAR2$	JUMP	RIEN$DOLLAR1$:			; masculin pluriel =>	LOAD.B	D3,(A4+)	JUMP,EQ OK$	COMP.B	D3,#',	JUMP,EQ OK$	LOAD.B	(A3+),D3	JUMP	DOLLAR1$DOLLAR2$:			; fminin singulier/pluriel =>	LOAD.B	D3,(A4+)	JUMP,EQ RIEN$	COMP.B	D3,#',	JUMP,NE DOLLAR2$DOLLAR22$:	LOAD.B	D3,(A4+)	JUMP',EQ DOLLAR24$	COMP.B	D3,#'.	JUMP',EQ DOLLAR23$	LOAD.B	(A3+),D3	JUMP	DOLLAR22$DOLLAR23$:	LOAD.B	(A3+),#'	JUMP	DOLLAR25$DOLLAR24$:	LOAD.B	(A3+),#'eDOLLAR25$:	COMP.W	D4,#3	JUMP,NE OK$	LOAD.B	(A3+),#'s	JUMP	OK$POINT$:	TEST.W	D4	JUMP,EQ POINT0$	COMP.W	D4,#1	JUMP,EQ POINT1$	COMP.W	D4,#2	JUMP,EQ DOLLAR2$	COMP.W	D4,#3	JUMP,EQ DOLLAR2$	JUMP	RIEN$POINT0$:			; masculin singulier =>	LOAD.B	D3,(A4+)	JUMP,EQ RIEN$	COMP.B	D3,#'$	JUMP,EQ OK$	LOAD.B	(A3+),D3	JUMP	POINT0$POINT1$:			; masculin pluriel =>	LOAD.L	A0,A3POINT11$:	LOAD.B	D3,(A4+)	JUMP,EQ RIEN$	COMP.B	D3,#'$	JUMP',EQ POINT12$	LOAD.B	(A3+),D3	JUMP	POINT11$POINT12$:	COMP.B	(A4),#',	; $, ?	JUMP,EQ OK$	COMP.B	(A4),#'s	JUMP',NE POINT13$	COMP.B	(A4)+1,#',	; $s, ?	JUMP',EQ POINT14$	; oui => POINT14$POINT13$:			; non =>	LOAD.L	A3,A0		; A3 <-- ignore entre "." et "$"POINT14$:	LOAD.B	D3,(A4+)	JUMP,EQ RIEN$	COMP.B	D3,#',	JUMP,EQ OK$	LOAD.B	(A3+),D3	JUMP	POINT14$BARRE$:	LOAD.L	A3,A1	LOAD.L	A4,A2	LOAD.W	D1,D4BARRE2$:	DEC.W	D1	JUMP',NS BARRE4$BARRE3$:	LOAD.B	D3,(A4+)	JUMP,EQ RIEN$	COMP.B	D3,#'|	JUMP,NE BARRE3$	JUMP	BARRE2$BARRE4$:	LOAD.B	D3,(A4+)	JUMP,EQ OK$	COMP.B	D3,#'|	JUMP,EQ OK$	LOAD.B	(A3+),D3	JUMP	BARRE4$DEUXPT$:	LOAD.L	A3,A1	LOAD.L	A4,A2DEUXPT2$:	LOAD.B	D3,(A4+)	JUMP,EQ RIEN$	COMP.B	D3,#':	JUMP,NE DEUXPT2$	LOAD.B	D3,(A4)		; D3 <-- chiffre aprs le ":"	SUB.B	D3,#'0		; D3 <-- 0..n	JUMP,LO ERROR$	COMP.B	D3,D4		; as-t-on trouv le bon ?	JUMP,NE DEUXPT2$DEUXPT4$:	COMP.L	A4,A2	JUMP',EQ DEUXPT5$	COMP.B	(-A4),#'|	JUMP,NE DEUXPT4$	INC.L	A4DEUXPT5$:	LOAD.B	D3,(A4+)	JUMP,EQ OK$	COMP.B	D3,#':	JUMP,EQ OK$	LOAD.B	(A3+),D3	JUMP	DEUXPT5$NB$:	TEST.W	D4	JUMP,EQ OK$	COMP.B	D2,#'m	JUMP	NBNOM$	COMP.B	D2,#'f	JUMP	NBNOM$	JUMP	RIEN$NBNOM$:	SUB.B	D3,#'0	AND.W	D3,#H'00FF	MUL.WU	D3,#10	LOAD.B	D1,(A4+)	SUB.B	D1,#'0	JUMP,LO ERROR$	COMP.B	D1,#9	JUMP,HI ERROR$	ADD.B	D3,D1	COMP.B	D3,#50	JUMP,HS NBNOM5$	DEC.B	D3	JUMP,NS NBNOM00$	DEC.B	D3	JUMP,NS NBNOM01$	DEC.B	D3	JUMP,NS NBNOM02$	DEC.B	D3	JUMP,NS NBNOM03$	DEC.B	D3	JUMP,NS NBNOM04$	DEC.B	D3	JUMP,NS NBNOM05$	DEC.B	D3	JUMP,NS NBNOM06$	DEC.B	D3	JUMP,NS NBNOM07$	DEC.B	D3	JUMP,NS NBNOM08$	DEC.B	D3	JUMP,NS NBNOM09$	DEC.B	D3	JUMP,NS NBNOM10$	DEC.B	D3	JUMP,NS NBNOM11$	JUMP	ERROR$NBNOM5$:	COMP.B	D3,#70	JUMP,HI ERROR$	SUB.B	D3,#50	SL.W	D3,#2	LOAD.L	A0,#R16"TNBNOMC$	LOAD.L	D1,(A0)+(D3.W)	JUMP,EQ RIEN$	JUMP	NBNOMC$NBNOM00$:			; pluriel=singulier =>	COMP.W	D4,#1	JUMP,NE RIEN$	JUMP	OK$NBNOM01$:			; al -> aux	COMP.W	D4,#1	JUMP,NE RIEN$	LOAD.B	(A3)-1,#'u	LOAD.B	(A3+),#'x	JUMP	OK$NBNOM02$:			; -> x	COMP.W	D4,#1	JUMP,NE RIEN$	LOAD.B	(A3+),#'x	JUMP	OK$NBNOM03$:			; ail -> aux	COMP.W	D4,#1	JUMP,NE RIEN$	LOAD.B	(A3)-2,#'u	LOAD.B	(A3)-1,#'x	JUMP	OK$NBNOM04$:			; el -> els/eux	LOAD.B	(A3+),#'s	COMP.W	D4,#1	JUMP,EQ OK$	COMP.W	D4,#2	JUMP,NE RIEN$	LOAD.B	(A3)-2,#'u	LOAD.B	(A3)-1,#'x	JUMP	OK$NBNOM05$:			; oeil -> yeux	COMP.W	D4,#1	JUMP,NE RIEN$	LOAD.B	(A3)-4,#'y;	LOAD.B	(A3)-3,#'e	LOAD.B	(A3)-2,#'u	LOAD.B	(A3)-1,#'x	JUMP	OK$NBNOM06$:			; um -> ums/a	LOAD.B	(A3+),#'s	COMP.W	D4,#1	JUMP,EQ OK$	COMP.W	D4,#2	JUMP,NE RIEN$	SUB.L	A3,#3	LOAD.B	(A3+),#'a	JUMP	OK$NBNOM07$:			; an -> en	COMP.W	D4,#1	JUMP,NE RIEN$	LOAD.B	(A3)-2,#'e	JUMP	OK$NBNOM08$:			; um -> a	COMP.W	D4,#1	JUMP,NE RIEN$	SUB.L	A3,#2	LOAD.B	(A3+),#'a	JUMP	OK$NBNOM09$:			; -> s/es	LOAD.B	(A3+),#'s	COMP.W	D4,#1	JUMP,EQ OK$	COMP.W	D4,#2	JUMP,NE RIEN$	LOAD.B	(A3)-1,#'e	LOAD.B	(A3+),#'s	JUMP	OK$NBNOM10$:			; y -> ies	COMP.W	D4,#1	JUMP,NE RIEN$	LOAD.B	(A3)-1,#'i	LOAD.B	(A3+),#'e	LOAD.B	(A3+),#'s	JUMP	OK$NBNOM11$:			; us -> i	COMP.W	D4,#1	JUMP,NE RIEN$	SUB.L	A3,#2	LOAD.B	(A3+),#'i	JUMP	OK$NBNOMC$:			; nom compos =>	COMP.W	D4,#1	JUMP,NE RIEN$	LOAD.L	A3,A1	LOAD.L	A4,A2NBNOMC1$:	RL.L	D1,#8		; D1 <-- lettre/zroNBNOMC2$:	LOAD.B	D3,(A4+)	JUMP',EQ NBNOMC3$	COMP.B	D3,#'5	JUMP',EQ NBNOMC3$	COMP.B	D3,#'6	JUMP',EQ NBNOMC3$	COMP.B	D3,#'7	JUMP',EQ NBNOMC3$	COMP.B	D3,#'-	JUMP',EQ NBNOMC3$	LOAD.B	(A3+),D3	JUMP	NBNOMC2$NBNOMC3$:	TEST.B	D1		; pluriel existe ?	JUMP',EQ NBNOMC5$	; non => NBNOMC5$	TCLR.L	D1:#7		; al -> aux ?	JUMP',BC NBNOMC4$	LOAD.B	(A3)-1,#'uNBNOMC4$:	LOAD.B	(A3+),D1	COMP.B	D1,#'i		; y -> ies ?	JUMP',NE NBNOMC5$	LOAD.B	(A3)-2,D1	LOAD.B	(A3)-1,#'e	LOAD.B	(A3+),#'sNBNOMC5$:	TEST.B	D3	JUMP,EQ OK$	COMP.B	D3,#'5	JUMP,EQ OK$	COMP.B	D3,#'6	JUMP,EQ OK$	COMP.B	D3,#'7	JUMP,EQ OK$	LOAD.B	(A3+),D3	JUMP	NBNOMC1$VERBE$:	TEST.W	(A6)+OSRCLS	; aucune lettre de sr ?	JUMP,EQ RIEN$		; oui => RIEN$	DEC.W	D4	COMP.W	D4,#6*9	JUMP,HS RIEN$	DEC.L	A4	AND.L	D4,#H'FFFF	DIV.WU	D4,#6	LOAD.W	D5,D4		; D5 <-- temps (0..8)	SWAP.W	D4		; D4 <-- forme (0..5)	COMP.W	(A6)+OSRCLS,#2	; deux lettres de sres ?	JUMP',EQ VERBE5$	; oui => VERBE5$	COMP.W	D5,#2		; pass simple ?	JUMP,EQ EXPAS$	COMP.W	D5,#4		; subjonctif prsent ?	JUMP,EQ EXPAS$	COMP.W	D5,#5		; subjonctif imparfait ?	JUMP,EQ EXPAS$	COMP.W	D5,#6		; conditionnel prsent ?	JUMP,EQ EXPAS$	COMP.W	D5,#7		; impratif prsent ?	JUMP,EQ EXPAS$VERBE5$:	LOAD.L	D3,(A6)+ODFFAN	; D3 <-- fanions des dfinitions	TEST.L	D3:D5		; conjugue  ce temps ?	JUMP,BC EXPAS$		; non => EXPAS$	CALL	CONJUGUE	; gnre une forme verbale ...	JUMP,NE EXIT$	COMP.B	(A3),#'H	JUMP,NE EXIT$	LOAD.B	(A3),#'h	JUMP	EXIT$VEXCEP$:	COMP.B	(A4+),#'>	JUMP,NE VEXCEP$	JUMP	DEBUT$EXPAS$:	LOAD.W	D7,#ERDIEX	; D7 <-- n'existe pas	JUMP'	EXIT$RIEN$:	LOAD.W	D7,#ERDIPT	; D7 <-- pas trouv	JUMP'	EXIT$OK$:	COMP.L	A3,A1		; mot de longueur nulle ?	JUMP,EQ EXPAS$		; oui => EXPAS$	CLR.B	(A3)	CLR.W	D7		; D7 <-- trouvEXIT$:	POPM.L	D0..D5,A0..A4	TEST.W	D7		; retour EQ/NE	RET	;	1re	2me	3me	-TNBNOMC$:	.B	0	0	0	0	; 50	.B	's	's	0	0	; 51	.B	's	0	0	0	; 52	.B	0	's	0	0	; 53	.B	's	's	0	0	; 54	.B	0	's	0	0	; 55	.B	0	'x	0	0	; 56	.B	0	's	0	0	; 57	.B	0	's	's	0	; 58	.B	0	'x!2^7	0	0	; 59	.B	'x	's	0	0	; 60	.B	'x	0	0	0	; 61	.B	'x	's	0	0	; 62	.B	's	's	's	0	; 63	.B	'x!2^7	's	0	0	; 64	.B	0	'x	0	0	; 65	.B	's	'x	0	0	; 66	.B	0	'i	0	0	; 67	.B	0	'x!2^7	0	0	; 68	.B	'x!2^7	0	0	0	; 69	.B	0	0	's	0	; 70;---------\\; CONJUGUE >;=========/; Cherche une forme verbale.; forme:	0	-->	je;		1	-->	tu;		2	-->	il/elle;		3	-->	ils/elles;		4	-->	nous;		5	-->	vous; temps:	0	-->	indicatif prsent;		1	-->	indicatif imparfait;		2	-->	indicatif pass simple;		3	-->	indicatif futur simple;		4	-->	subjonctif prsent;		5	-->	subjonctif imparfait;		6	-->	conditionnel prsent;		7	-->	impratif prsent (tu,nous,vous);		8	-->	participes prsent et pass (M+F); in	A4.L	^verbe (infinitif trouv dans le dictionnaire);	D2.B	espce du verbe;	D4.W	forme (0..5);	D5.W	temps (0..8);	A3.L	^buffer pour forme verbale en clair; out	D7.W	erreur; mod	D7.WCONJUGUE:	PUSHM.L	D0..D5,A1..A5	LOAD.L	A1,A3	CLR.B	(A1)	TEST.B	(A6)+OCJQQ	; cherche n'importe quelle forme?	JUMP',T	INIT2$		; oui => INIT2$	TEST.W	D4	JUMP',NE INIT5$	TEST.W	D5	JUMP',NE INIT5$INIT2$:	CALL	CONJGROUPE	; A5 <-- ^rgles de conjugaisons	JUMP,NE EXIT9$	CALL	CONJRADICAL	; D0/D1 <-- lg des radicaux; Cherche le pointeur aux radicaux et aux formes.INIT3$:	TEST.B	(A5+)	JUMP,NE INIT3$	LOAD.L	A2,A5		; A2 <-- ^radicauxINIT4$:	TEST.B	(A5+)		; A5 <-- ^premire forme	JUMP,NE INIT4$	LOAD.L	(A6)+OCJPR,A2	LOAD.L	(A6)+OCJPF,A5	LOAD.W	(A6)+OCJL0,D0	LOAD.W	(A6)+OCJL1,D1; Traite le cas des verbes impersonnels (comme pleuvoir).INIT5$:	COMP.B	D2,#'v	JUMP',NE IMPERS$	LOAD.W	D7,#ERDIEX	COMP.W	D5,#7		; impratif prsent ?	JUMP,EQ EXIT9$	COMP.W	D5,#8		; participes ?	JUMP',EQ IMPERS$	COMP.W	D4,#2		; forme "il" ?	JUMP,NE EXIT9$		; non => EXIT9$IMPERS$:	LOAD.L	A2,(A6)+OCJPR	LOAD.L	A5,(A6)+OCJPF	LOAD.W	D0,(A6)+OCJL0	LOAD.W	D1,(A6)+OCJL1; Cherche la bonne forme.	COMP.W	D5,#5		; subjonctif imparfait ?	JUMP',NE BF2$		; non => BF2$	LOAD.W	D3,D4	SWAP.W	D4	LOAD.W	D4,#1		; D4 <-- tu	COMP.W	D3,#2		; il ?	JUMP',NE BF2$	LOAD.W	D4,#5		; D4 <-- vousBF2$:	COMP.W	D5,#6		; conditionnel prsent ?	JUMP',NE BF3$		; non => BF3$	SWAP.W	D4	LOAD.W	D4,#0		; D4 <-- jeBF3$:	COMP.W	D5,#7		; impratif prsent ?	JUMP',NE BF5$		; non => BF5$	LOAD.W	D3,D4	SWAP.W	D4	CLR.W	D4	COMP.W	D3,#1	JUMP',EQ BF5$	INC.W	D4	COMP.W	D3,#4	JUMP',EQ BF5$	INC.W	D4	COMP.W	D3,#5	JUMP,NE ERREX$BF5$:	COMP.W	D5,#8		; participes ?	JUMP',NE BF6$		; non => BF6$	LOAD.W	D3,D4	SWAP.W	D4	CLR.W	D4	TEST.W	D3	JUMP',EQ BF6$	INC.W	D4	COMP.W	D3,#2	JUMP',LS BF6$	INC.W	D4	COMP.W	D3,#4	JUMP,HI ERREX$BF6$:	LOAD.B	D3,#',	LOAD.W	D2,D4	COMP.W	D5,#0		; prsent ?	JUMP',EQ TEMPS$	LOAD.W	D2,#6	COMP.W	D5,#1		; imparfait ?	JUMP',EQ TEMPS$	LOAD.W	D2,#7	COMP.W	D5,#2		; pass simple ?	JUMP',EQ TEMPS$	LOAD.W	D2,#8	COMP.W	D5,#3		; futur simple ?	JUMP',EQ TEMPS$	LOAD.W	D2,D4	ADD.W	D2,#9	COMP.W	D5,#4		; subjonctif prsent ?	JUMP',EQ TEMPS$	LOAD.W	D2,#7	COMP.W	D5,#5		; subjonctif imparfait ?	JUMP',EQ TEMPS$	LOAD.W	D2,#8	COMP.W	D5,#6		; conditionnel prsent ?	JUMP',EQ TEMPS$	LOAD.W	D2,D4	ADD.W	D2,#15	COMP.W	D5,#7		; impratif prsent ?	JUMP',EQ TEMPS$	LOAD.W	D2,D4	ADD.W	D2,#18	COMP.W	D5,#8		; participes ?	JUMP',EQ TEMPS$	JUMP	ERRCO$TEMPS$:	DEC.W	D2	JUMP',NS TEMPS4$TEMPS2$:	COMP.B	D3,(A5+)	; A5 <-- ^forme suivante	JUMP,NE TEMPS2$	JUMP	TEMPS$TEMPS4$:	TEST.B	(A5)	JUMP',NE SRAD$	INC.L	A5; Cherche le radical selon la forme.SRAD$:	LOAD.B	D2,(A5+)	; D2 <-- numro du radical	SUB.B	D2,#'0	JUMP,EQ ERREX$	JUMP,LO ERRCO$	COMP.B	D2,#10	JUMP,HS ERRCO$	LOAD.B	D3,#SPACESRAD2$:	DEC.B	D2	JUMP',EQ GRAD$SRAD4$:	COMP.B	D3,(A2+)	; A2 <-- ^radical suivant	JUMP,NE SRAD4$	JUMP	SRAD2$; Gnre le radical.GRAD$:	INC.L	A4	LOAD.W	D2,D0	JUMP',EQ GRAD3$GRAD2$:	LOAD.B	(A3+),(A4+)	; buffer <-- dbut du radical du verbe  conjuguer	DEC.W	D0	JUMP,NE GRAD2$GRAD3$:	LOAD.L	A4,A2		; A4 <-- ^dbut radical verbe modle	ADD.W	A2,D1		; A2 <-- ^fin radical verbe modle	LOAD.B	D3,#'*GRAD4$:	COMP.L	A4,A2	JUMP',EQ GRAD6$	COMP.B	D3,(A4+)	; "*" dans radical verbe modle ?	JUMP,NE GRAD4$		; non => GRAD6$	LOAD.L	A4,A3		; oui =>GRAD5$:	DEC.W	D2	JUMP',NS GRAD6$	LOAD.B	D3,(-A4)	CALL	NOACCENT	COMP.B	D3,#'e		; "e" ou "" dans radical verbe  conjuguer ?	JUMP,NE GRAD5$		; non => GRAD6$	LOAD.B	(A4),#'	; oui => remplace par ""GRAD6$:	LOAD.B	D3,(A2+)	JUMP',EQ GRAD8$	COMP.B	D3,#SPACE	JUMP',EQ GRAD8$	COMP.B	D3,#'*	JUMP',NE GRAD7$	LOAD.B	D3,#'GRAD7$:	LOAD.B	(A3+),D3	; buffer <-- fin du radical du verbe modle	JUMP	GRAD6$GRAD8$:	COMP.B	(A5),#',	; est-ce une exception ?	JUMP',EQ TRAD$		; non => TRAD$GRAD9$:	LOAD.B	D3,(A5+)	COMP.B	D3,#',	JUMP',EQ TRAD$	LOAD.B	(A3+),D3	; buffer <-- exception	JUMP	GRAD9$; Gnre la terminaison du radical.TRAD$:	LOAD.L	A2,#R16"T0$	COMP.W	D5,#0	JUMP',EQ TRAD2$	LOAD.L	A2,#R16"T1$	COMP.W	D5,#1	JUMP',EQ TRAD2$	LOAD.L	A2,#R16"T2$	COMP.W	D5,#2	JUMP',EQ TRAD2$	LOAD.L	A2,#R16"T3$	COMP.W	D5,#3	JUMP',EQ TRAD2$	LOAD.L	A2,#R16"T4$	COMP.W	D5,#4	JUMP',EQ TRAD2$	LOAD.L	A2,#R16"T2$	COMP.W	D5,#5	JUMP',EQ TRAD2$	LOAD.L	A2,#R16"T3$	COMP.W	D5,#6	JUMP',EQ TRAD2$	LOAD.L	A2,#R16"T7$	COMP.W	D5,#7	JUMP',EQ TRAD2$	LOAD.L	A2,#R16"T8$	COMP.W	D5,#8	JUMP',EQ TRAD2$	JUMP	ERRCO$TRAD2$:	LOAD.W	D3,D4		; D3 <-- formeTRAD4$:	DEC.W	D3	JUMP',NS TRAD6$TRAD5$:	TEST.B	(A2+)		; A2 <-- ^terminaison suivante	JUMP,NE TRAD5$	JUMP	TRAD4$TRAD6$:	COMP.W	D5,#0	JUMP,EQ PRES$	COMP.W	D5,#1	JUMP,EQ IMP$	COMP.W	D5,#2	JUMP,EQ PAS$	COMP.W	D5,#3	JUMP,EQ FUT$	COMP.W	D5,#4	JUMP,EQ SPRES$	COMP.W	D5,#5	JUMP,EQ PAS$	COMP.W	D5,#6	JUMP,EQ CPRES$	COMP.W	D5,#7	JUMP,EQ IPRES$	COMP.W	D5,#8	JUMP,EQ PART$	JUMP	ERRCO$PRES$:				; PRESENT =>	COMP.B	(A5),#',	; est-ce une exception ?	JUMP,NE EXIT4$		; oui => EXIT4$	JUMP	EXIT2$IMP$:				; IMPARFAIT =>	COMP.W	D4,#4		; nous/vous ?	JUMP,LO EXIT2$		; non => EXIT2$	COMP.B	(A3)-1,#'e	; eions/eiez ?	JUMP',NE IMP2$	DEC.L	A3		; eions -> ions	JUMP	EXIT2$IMP2$:	COMP.B	(A3)-1,#'	JUMP,NE EXIT2$	LOAD.B	(A3)-1,#'c	; ions -> cions	JUMP	EXIT2$PAS$:				; PASSE SIMPLE =>	COMP.W	D4,#1		; tu ?	JUMP,EQ PAS8$		; oui => PAS8$	COMP.W	D4,#4		; nous/vous ?	JUMP,LO PAS3$		; non => PAS3$	COMP.B	(A3)-1,#'a	JUMP',NE PAS21$	LOAD.B	(A3)-1,#'	; ames -> mesPAS21$:	COMP.B	(A3)-1,#'i	JUMP',NE PAS22$	LOAD.B	(A3)-1,#'	; imes -> mesPAS22$:	COMP.B	(A3)-1,#'u	JUMP',NE PAS23$	LOAD.B	(A3)-1,#'	; umes -> mesPAS23$:	COMP.B	(A3)-1,#'n	JUMP',NE PAS24$	COMP.B	(A3)-2,#'i	JUMP',NE PAS24$	LOAD.B	(A3)-2,#'	; inmes -> nmesPAS24$:	JUMP'	PAS8$PAS3$:	COMP.B	(A3)-1,#'a	JUMP',NE PAS8$	COMP.W	D4,#2		; il ?	JUMP,EQ EXIT4$		; oui => EXIT4$	COMP.W	D4,#0		; je ?	JUMP',NE PAS4$		; non => PAS4$	LOAD.B	(A3+),#'i	JUMP	EXIT4$PAS4$:	COMP.W	D4,#3		; ils ?	JUMP',NE PAS8$		; non => PAS8$	COMP.B	(A3)-2,#'	JUMP',NE PAS42$	LOAD.B	(A3)-2,#'c	; plaa -> placrent	JUMP'	PAS46$PAS42$:	COMP.B	(A3)-2,#'e	JUMP',NE PAS46$	COMP.B	(A3)-3,#'g	JUMP',NE PAS46$	DEC.L	A3		; agrgea -> agrgrentPAS46$:	LOAD.B	(A3)-1,#'PAS8$:	LOAD.B	(A3+),(A2+)	; buffer <-- terminaison	JUMP,NE PAS8$	DEC.L	A3PAS9$:	COMP.W	D5,#5	JUMP,EQ SIMP$	JUMP	EXIT4$FUT$:				; FUTUR SIMPLE =>	JUMP	EXIT2$SPRES$:				; SUBJONCTIF PRESENT =>	JUMP	EXIT2$SIMP$:				; SUBJONCTIF IMPARFAIT =>	SWAP.W	D4		; D4 <-- vraie forme	COMP.W	D4,#2		; il	JUMP',NE SIMP1$	SUB.L	A3,#2		; vous ptes -> il pt	JUMP	EXIT4$SIMP1$:	LOAD.L	A2,#R16"T5$	LOAD.W	D3,D4		; D3 <-- formeSIMP2$:	DEC.W	D3	JUMP',NS SIMP4$SIMP3$:	TEST.B	(A2+)		; A2 <-- ^terminaison suivante	JUMP,NE SIMP3$	JUMP	SIMP2$SIMP4$:	JUMP	EXIT2$CPRES$:				; CONDITIONNEL PRESENT =>	LOAD.B	(A3+),(A2+)	; buffer <-- terminaison	JUMP,NE CPRES$	DEC.L	A3	SWAP.W	D4		; D4 <-- vraie forme	COMP.W	D4,#4	JUMP',LO CPRES2$	SUB.L	A3,#2		; pourrai -> pourrCPRES2$:	LOAD.L	A2,#R16"T6$	LOAD.W	D3,D4		; D3 <-- forme	JUMP	SIMP2$IPRES$:				; IMPERATIF PRESENT =>	LOAD.B	(A3+),(A2+)	; buffer <-- terminaison	JUMP,NE IPRES$	DEC.L	A3	SWAP.W	D4		; D4 <-- vraie forme	COMP.W	D4,#1		; tu ?	JUMP,NE EXIT4$	COMP.B	(A3)-1,#'e	JUMP,EQ EXIT4$	COMP.B	(A3)-1,#'s	JUMP,EQ EXIT4$	COMP.B	(A3)-1,#'x	JUMP,EQ EXIT4$	LOAD.L	A2,(A6)+OCJPT	; A2 <-- ^type	COMP.B	(A2+),#'0	JUMP',NE IPRES5$	COMP.B	(A2+),#'0	JUMP',NE IPRES5$	COMP.B	(A2+),#'2	; type 002 (verbe "aller") ?	JUMP,EQ EXIT4$		; oui => EXIT4$IPRES5$:	LOAD.B	(A3+),#'s	JUMP	EXIT4$PART$:				; PARTICIPES =>	LOAD.B	(A3+),(A2+)	; buffer <-- terminaison	JUMP,NE PART$	DEC.L	A3	SWAP.W	D4		; D4 <-- vraie forme	COMP.W	D4,#2		; masculin pluriel ?	JUMP',EQ PART2$	COMP.W	D4,#4		; fminin pluriel ?	JUMP,NE EXIT4$PART2$:	COMP.B	(A3)-1,#'s	JUMP,EQ EXIT4$	LOAD.B	(A3+),#'s	JUMP	EXIT4$ERRCO$:	CLR.B	(A1)	LOAD.W	D7,#ERDICO	; D7 <-- erreur dans le dico	JUMP'	EXIT9$ERREX$:	CLR.B	(A1)	LOAD.W	D7,#ERDIEX	JUMP'	EXIT9$EXIT2$:	COMP.B	(A3)-1,#'-	JUMP',NE EXIT3$	DEC.L	A3	INC.L	A2EXIT3$:	LOAD.B	(A3+),(A2+)	; buffer <-- terminaison	JUMP,NE EXIT3$EXIT4$:	CLR.B	(A3)		; buffer <-- terminateur	CLR.W	D7		; D7 <-- okEXIT9$:	POPM.L	D0..D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETT0$:				; indicatif prsent	.ASCIZ	""		; je	.ASCIZ	"s"		; tu	.ASCIZ	""		; il	.ASCIZ	"nt"		; ils	.ASCIZ	"ons"		; nous	.ASCIZ	"ez"		; vousT1$:				; indicatif imparfait	.ASCIZ	"ais"		; je	.ASCIZ	"ais"		; tu	.ASCIZ	"ait"		; il	.ASCIZ	"aient"		; ils	.ASCIZ	"ions"		; nous	.ASCIZ	"iez"		; vousT2$:				; indicatif pass simple	.ASCIZ	"s"		; je	.ASCIZ	"s"		; tu	.ASCIZ	"t"		; il	.ASCIZ	"rent"		; ils	.ASCIZ	"mes"		; nous	.ASCIZ	"tes"		; vousT3$:				; indicatif futur simple	.ASCIZ	"rai"		; je	.ASCIZ	"ras"		; tu	.ASCIZ	"ra"		; il	.ASCIZ	"ront"		; ils	.ASCIZ	"rons"		; nous	.ASCIZ	"rez"		; vousT4$:				; subjonctif prsent	.ASCIZ	""		; je	.ASCIZ	"s"		; tu	.ASCIZ	""		; il	.ASCIZ	"nt"		; ils	.ASCIZ	"ions"		; nous	.ASCIZ	"iez"		; vousT5$:				; subjonctif imparfait	.ASCIZ	"se"		; je	.ASCIZ	"ses"		; tu	.ASCIZ	"se"		; il	.ASCIZ	"sent"		; ils	.ASCIZ	"sions"		; nous	.ASCIZ	"siez"		; vousT6$:				; conditionnel prsent	.ASCIZ	"s"		; je	.ASCIZ	"s"		; tu	.ASCIZ	"t"		; il	.ASCIZ	"ent"		; ils	.ASCIZ	"ions"		; nous	.ASCIZ	"iez"		; vousT7$:				; impratif prsent	.ASCIZ	""		; tu	.ASCIZ	"ons"		; nous	.ASCIZ	"ez"		; vousT8$:				; participes	.ASCIZ	"ant"		; prsent	.ASCIZ	""		; pass (M)	.ASCIZ	""		; pass (F)	.EVEN;------------\\; CONJRADICAL >;------------/; Cherche les longueurs des radicaux (parties diffrentes).;	(A4)+	-->	 satisfaire	D0=5;	(A5)+	-->	contrefaire	D1=6; in	A4.L	^verbe (infinitif trouv dans le dictionnaire);	A5.L	^rgles de conjugaisons; out	D0.W	lg radical du verbe  conjuger;	D1.W	lg radical du verble modle; mod	D0.L, D1.L, D7.WCONJRADICAL:	PUSHM.L	D2..D4,A4,A5	INC.L	A4	LOAD.W	D0,#-120$:	INC.W	D0		; D0 <-- lg verbe  conjuguer	LOAD.B	D3,(A4+)	JUMP',EQ 22$	COMP.B	D3,#',	JUMP',EQ 22$	COMP.B	D3,#'0	JUMP,LO 20$	COMP.B	D3,#'9	JUMP,HI 20$22$:	DEC.L	A4		; A4 <-- ^fin verbe  conjuguer	LOAD.W	D1,#-130$:	INC.W	D1		; D1 <-- lg verbe modle	TEST.B	(A5+)	JUMP,NE 30$	DEC.L	A5		; A5 <-- ^fin verbe modle	LOAD.W	D2,D0	COMP.W	D2,D1	JUMP',LS 40$	LOAD.W	D2,D1		; D2 <-- lg la plus petite40$:	CLR.W	D4	DEC.W	D242$:	LOAD.B	D3,(-A4)	COMP.B	D3,(-A5)	JUMP',NE 44$	INC.W	D4	DECJ.W,NMO D2,42$44$:	SUB.W	D0,D4	SUB.W	D1,D4	POPM.L	D2..D4,A4,A5	RET;-----------\\; CONJGROUPE >;-----------/; Cherche les rgles de conjugaisons.; in	A4.L	^verbe (infinitif trouv dans le dictionnaire); out	A5.L	^rgles de conjugaisons;	D7.W	erreur; mod	D7.W, A5.LCONJGROUPE:	PUSHM.L	D3,A3,A4	LOAD.W	D7,#ERDICO	; D7 <-- erreur dans le dico	LOAD.L	A3,#(A4)+1	; A3 <-- ^infinitif (saute le type)10$:	LOAD.B	D3,(A3+)	JUMP',EQ 12$	COMP.B	D3,#',	JUMP',EQ 12$	COMP.B	D3,#'0	JUMP,LO 10$	COMP.B	D3,#'9	JUMP,HI 10$	DEC.L	A3		; A3 <-- ^numro	JUMP'	20$12$:	COMP.B	(A3)-2,#'r	JUMP,NE 90$	LOAD.B	D3,(A3)-3	LOAD.L	A3,#R16"ER$	COMP.B	D3,#'e		; verbe termin par "er" ?	JUMP',EQ 20$	LOAD.L	A3,#R16"IR$	COMP.B	D3,#'i		; verbe termin par "ir" ?	JUMP,NE 90$20$:	LOAD.L	(A6)+OCJPT,A3	; OCJPT <-- ^type	LOAD.B	D3,(A3+)	SUB.B	D3,#'0	JUMP,LO 90$	LOAD.L	A5,#R16"TVERBES0-4	DEC.B	D3	JUMP',NS 30$	LOAD.L	A5,#R16"TVERBES1-4	DEC.B	D3	JUMP',NS 30$	LOAD.L	A5,#R16"TVERBES2-4	DEC.B	D3	JUMP',NS 30$	LOAD.L	A5,#R16"TVERBES3-4	DEC.B	D3	JUMP',NC 90$30$:	LOAD.B	D3,(A3+)	SL.W	D3,#8	LOAD.B	D3,(A3)32$:	ADD.L	A5,#4	TEST.W	(A5)	JUMP',EQ 90$	COMP.W	D3,(A5)	JUMP,NE 32$	CLR.L	D3	LOAD.W	D3,(A5)+2	LOAD.L	A5,#R16"DEBUT	ADD.L	A5,D3	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RETER$:	.ASCIZ	"001"IR$:	.ASCIZ	"11A"	.EVEN;--------\\; DECOMOT >;========/; Dcode un mot.; Cette routine doit tre trs rapide !; in	A3.L	^mot cod <0>;	A4.L	^buffer pour mot en clair <0>; out	-; mod	D7.WDECOMOT:	PUSHM.L	D3,A2..A4	LOAD.B	(A4+),(A3+)	LOAD.L	A2,#R16"TACODE-256 ; A2 <-- ^couples de lettres20$:	LOAD.B	(A4+),(A3+)	JUMP',EQ 90$	JUMP,NC 20$	CLR.W	D3	LOAD.B	D3,(-A4)	; D3 <-- byte cod (128..255)	SL.W	D3,#1	LOAD.B	(A4+),(A2)+(D3.W)	LOAD.B	(A4+),(A2)+(D3.W)+1	JUMP	20$90$:	POPM.L	D3,A2..A4	RET;--------\\; MAJMIN  >;========/; in	D3.B	caractre; out	D3.B	caractre minuscule; mod	D3.BMAJMIN:	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'Z	JUMP',HI 90$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule90$:	RET;-------\\; MINMAJ >;=======/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMINMAJ:	COMP.B	D3,#'		; lettre accentue ?	JUMP',LS 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+TACCENT$ ; D3 <-- lettre majuscule	POP.W	D0	RETTACCENT$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN;---------\\; NOACCENT >;=========/; in	D3.B	caractre; out	D3.B	caractre non accentu; mod	D3.BNOACCENT:	COMP.B	D3,#'	JUMP',LO 90$	COMP.B	D3,#'		; lettre accentue ?	JUMP',HI 90$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+TACCENT$ ; D3 <-- lettre non accentue	POP.W	D090$:	RETTACCENT$:	.B	'u 'a 'a 'e 'e 'e 'e 'i 'i 'o 'u 'u 'a 'o 'c	.EVEN; Cette table donne les 128 couples de lettres les plus; utilises en franais, dans l'ordre.TACODE:	.ASCII	"erntonenretimeleteisinanriraatem"	.ASCII	"ousecourioeuiearuelineitchssilqu"	.ASCII	"trlaroirtastlloralaigecaagncsiic"	.ASCII	"desadimacenieslonapaabprblolvepo"	.ASCII	"tocietacnnmiaspendomussoelauuliq"	.ASCII	"utoiuihemoimotpimphansviapbotutt"	.ASCII	"fictrtgramcrbaignovaiasurdbigapl"	.ASCII	"currocosbrecnghigiadivschophogfa"	.EVEN	.END