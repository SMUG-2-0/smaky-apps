	.SBTTL	DICODBOX.ASI;---------\\; DBOXWHAT >;=========/; Choix de quelques dfinitions gnrales.; in	-; out	D3.L	dernire touche (F1/F0);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXWHAT:	PUSHM.L	D1,D2,D5,A1..A4	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	LIB	?BUZZ		; fait un grand bruit !	LOAD.L	A2,#R16"TDBOX_WHAT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,#B'01	; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...;	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_WHAT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ OK$	COMP.W	D3,#F0	JUMP',EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$OK$:END$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_WHAT:	.W	10$-TDBOX_WHAT	.W	20$-TDBOX_WHAT	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix du dictionnaire de base  charger : "	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,0	.ASCIZ	" 250'000 mots (dictionnaire standard)"	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" 500'000 mots (dictionnaire spcialis)"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" CHARGE "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Charge"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_WHAT:	.W	F1,F2,F3,0		DOKF1-TKEY_WHAT	.W	F0,F13,F14,F15,0	DOKF0-TKEY_WHAT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_WHAT	.W	0;--------\\; AFFMOT  >;--------/; Affiche le mot dans la dbox.; in	D2.W	label dbox; out	-; mod	D7.WAFFMOT:	PUSHM.L	D1..D4,A3	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.B	AFTOUT	.B	'"	.B	0	.EVEN	LOAD.L	A3,(A6)+OSRCPM	; A3 <-- ^mot	LOAD.L	D4,(A6)+OSRCLM	; D4 <-- nb de cractres	JUMP',EQ 50$	LOAD.L	D2,(A6)+OSRCB0	; D2 <-- bits pour les majuscules	CLR.W	D1		; D1 <-- rang du caractre30$:	LOAD.B	D3,(A3+)	; D3 <-- caractre minuscule	TEST.L	D2:D1		; tait-ce une majuscule ?	JUMP',BC 40$		; non => 40$	CALL	MINMAJ		; D3 <-- caractre majuscule40$:	LIB	?AFCAR		; affiche un caractre	INC.W	D1		; D1 <-- rang suivant	DEC.L	D4		; encore un caractre ?	JUMP,NE 30$		; oui => 30$50$:	LIB	?AFTIM	.B	'"	.B	AFNORM	.B	0	.EVEN	POPM.L	D1..D4,A3	RET;--------\\; AFFBOX  >;========/; Affiche un texte dans une dbox.; in	D2.W	label dbox;	A3/D3	^texte/lg; out	-; mod	D7.WAFFBOX:	PUSHM.L	D2..D4	PUSH.W	D3	DBOX_	GETCO	SUB.W	D4,D3	LIB	?SETCURS	POP.W	D3	AND.L	D4,#H'FFFF	DIV.WU	D4,(A0)+ODFCX	LIB	?AFSPACE	DEC.W	D4	COMP.W	D3,D4	JUMP',LS 30$	LOAD.W	D3,D430$:	LIB	?STRING		; affiche le texte	SUB.W	D4,D3	JUMP',EQ 90$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin90$:	POPM.L	D2..D4	RET;-----------\\; DBOXPHDRAW >;===========/; Affiche la phrase contenant le mot incorrect.; in	-; out	D7.W	erreur; mod	D7.WDBOXPHDRAW:	PUSHM.L	D3,D4,A4,A5	LOAD.L	A4,(A6)+OSRCPP	LOAD.L	D4,(A6)+OSRCLP	LOAD.L	D3,(A6)+OSRCPM	SUB.L	D3,#500	COMP.L	A4,D3	JUMP',HS 10$	ADD.L	D4,A4	SUB.L	D4,D3	LOAD.L	A4,D310$:	LOAD.L	D3,(A6)+OSRCPM	ADD.L	D3,(A6)+OSRCLM	ADD.L	D3,#500	SUB.L	D3,A4	COMP.L	D4,D3	JUMP',LS 12$	LOAD.L	D4,D312$:	LOAD.L	(A6)+OSRCPC,A4	LOAD.L	(A6)+OSRCLC,D4	LOAD.L	A5,#(A6)+OSLVAR1 ; A5 <-- ^variables scroll-liste et ascenseur	CLR.W	(A5)+OSCHTV	CLR.W	(A5)+OSCPOSV	CLR.L	D3	LOAD.W	D3,(A5)+OSLNBX	; D3 <-- nb caractres/ligne	LOAD.L	D4,(A6)+OSRCLC	ADD.L	D4,D3	DEC.L	D4	DIV.WU	D4,D3		; D4 <-- nb de lignes ncessaires	SUB.W	D4,#3		; 3 lignes ou moins ?	JUMP',LE 30$		; oui => 30$	INC.W	D4	LOAD.W	(A5)+OSCHTV,D4	LOAD.L	D4,(A6)+OSRCPM	SUB.L	D4,(A6)+OSRCPC	; D4 <-- offset mot faux	DIV.WU	D4,(A5)+OSLNBX	JUMP',EQ 20$	DEC.W	D4	COMP.W	D4,(A5)+OSCHTV	JUMP',LO 20$	LOAD.W	D4,(A5)+OSCHTV	DEC.W	D420$:	LOAD.W	(A5)+OSCPOSV,D4	SCROLL_	UPDATE		; met  jour la cabine de l'ascenseur30$:	CALL	DBOXPHUPDATE	; affiche le contenu	POPM.L	D3,D4,A4,A5	RET;-----------\\; DBOXPHMOVE >;===========/; Dplace la scroll-liste du contexte.; in	D4.L	position de la souris (y;x); out	-; mod	D7.WDBOXPHMOVE:	PUSHM.L	D3,D4,A5	LOAD.L	A5,#(A6)+OSLVAR1 ; A5 <-- ^variables scroll-liste et ascenseur	LOAD.W	D7,#1	TEST.W	(A5)+OSCHTV	; ascenseur actif ?	JUMP',EQ 90$		; non => 90$	PUSH.L	D4	LOAD.W	(A5)+OSCINC,#1	SCROLL_	MOVE		; dplace l'ascenseur ...	POPM.L	D4	JUMP',EQ 50$		; ok => 50$	LOAD.W	D3,(A5)+OSLPOS+2	COMP.W	D4,D3		; trop  gauche ?	JUMP',LO 90$		; oui => 90$	ADD.W	D3,(A5)+OSLDIM+2	COMP.W	D4,D3		; trop  droite ?	JUMP',HS 90$		; oui => 90$	SWAP.W	D4	LOAD.W	D3,(A5)+OSLPOS+0	COMP.W	D4,D3		; trop en haut ?	JUMP',LO 90$		; oui => 90$	ADD.W	D3,(A5)+OSLDIM+0	COMP.W	D4,D3		; trop en bas ?	JUMP',HS 90$		; oui => 90$	LOAD.L	D4,(A6)+OSRCPM	SUB.L	D4,(A6)+OSRCPC	; D4 <-- offset mot faux	DIV.WU	D4,(A5)+OSLNBX	JUMP',EQ 40$	DEC.W	D4	COMP.W	D4,(A5)+OSCHTV	JUMP',LO 40$	LOAD.W	D4,(A5)+OSCHTV	DEC.W	D440$:	LOAD.W	(A5)+OSCPOSV,D4	SCROLL_	UPDATE		; dplace l'ascenseur50$:	CALL	DBOXPHUPDATE	; affiche le contenu	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A5	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DBOXPHUPDATE >;=============/; Affiche le contenu de la scroll-liste du contexte.; in	-; out	-; mod	D7.WDBOXPHUPDATE:	PUSHM.L	D2,D3,A5	LOAD.L	A5,#(A6)+OSLVAR1 ; A5 <-- ^variables scroll-liste et ascenseur	LOAD.W	D2,(A5)+OSCPOSV	LOAD.W	D3,(A5)+OSLNBY20$:	CALL	DBOXPHLINE	; affiche une ligne	INC.W	D2	DEC.W	D3	JUMP,NE 20$	POPM.L	D2,D3,A5	RET;-----------\\; DBOXPHLINE >;-----------/; Affiche une ligne allant dans la scroll-liste du contexte.; in	D2.W	rang de la case (0..n); out	-; mod	D7.WDBOXPHLINE:	PUSHM.L	D0..D4,A3	LOAD.W	D1,D2	SUB.W	D2,(A5)+OSCPOSV	JUMP,LO 90$	COMP.W	D2,(A5)+OSLNBY	JUMP,HS 90$	LOAD.L	D3,(A5)+OSLPOS	SWAP.W	D3	INC.W	D3	MUL.WU	D2,(A5)+OSLCAR+0	ADD.W	D3,D2	SWAP.W	D3	ADD.W	D3,#LGSCROLL	; D3 <-- position coin sup/gauche	LOAD.L	D0,D3	SWAP.W	D3	ADD.W	D3,(A5)+OSLC1Y	; D3 <-- sur la ligne de base	SWAP.W	D3	ADD.W	D3,(A5)+OSLC1X	; D3 <-- tient compte de la rfrence gauche	LIB	?SETCURS	; positionne sur la ligne de base	LOAD.B	D3,#AFTOUT	LIB	?AFCAR	LOAD.L	A3,(A6)+OSRCPC	; A3 <-- ^phrase	LOAD.L	D3,(A6)+OSRCLC	; D3 <-- lg phrase	LOAD.W	D4,(A5)+OSLNBX	MUL.WU	D1,D4		; D1 <-- offset premier caractre  afficher	ADD.L	A3,D1	SUB.W	D3,D1	JUMP',LE 40$	COMP.W	D4,D3	JUMP',LS 30$	LOAD.W	D4,D330$:	LOAD.W	D3,D4	LIB	?STRING		; affiche une ligne de contexte	LOAD.W	D4,(A5)+OSLNBX	SUB.W	D4,D3	JUMP',EQ 40$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin de la ligne40$:	LOAD.B	D3,#AFNORM	LIB	?AFCAR	LOAD.L	D2,(A6)+OSRCPM	SUB.L	D2,(A6)+OSRCPC	; D2 <-- offset mot faux	LOAD.L	D4,(A6)+OSRCLM	; D4 <-- lg mot faux	LOAD.W	D3,D1	ADD.W	D3,(A5)+OSLNBX	COMP.W	D2,D3		; mot faux plus loin ?	JUMP',HS 90$		; oui => 90$	LOAD.W	D3,D2	ADD.W	D3,D4	COMP.W	D3,D1		; mot faux moins loin ?	JUMP',LS 90$		; oui => 90$	SUB.W	D2,D1		; D2 <-- offset mot faux dans la ligne	JUMP',NC 50$	ADD.W	D4,D2	CLR.W	D250$:	LOAD.W	D1,(A5)+OSLNBX	SUB.W	D1,D2		; D1 <-- lg max	COMP.W	D4,D1		; mot faux dpasse  droite ?	JUMP',LS 52$		; non => 52$	LOAD.W	D4,D1		; D4 <-- lg max52$:	MUL.WU	D2,(A5)+OSLCAR+2	LOAD.L	D3,D0	ADD.W	D3,D2		; D3 <-- position (y;x)	MUL.WU	D4,(A5)+OSLCAR+2 ; D4 <-- largeur	SWAP.W	D4	LOAD.W	D4,(A5)+OSLCAR+0 ; D4 <-- hauteur	SWAP.W	D4	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse le mot faux90$:	POPM.L	D0..D4,A3	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs LIB,?EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>90$:	POP.L	A3	RET;-----------\\; DBOXSLDRAW >;===========/; Dessine une scroll-liste vide.; in	A5.L	^variables;	D2.W	label initial;	A3.L	^texte pour case <vide> (si OSLVID=1); out	-; mod	D7.WDBOXSLDRAW:	PUSHM.L	D2..D4	DBOX_	GETCO	ADD.W	D3,#3	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,#4	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	PUSH.L	D3	INC.W	D2	DBOX_	GETCO	POP.L	D4	ADD.W	D3,#3	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A5)+OSLDIM,D3	SCROLL_	LDRAW		; dessine la scroll-liste vide	POPM.L	D2..D4	RET;----------\\; DBOXHLINE >;==========/; Trace une ligne horizontale dans une dbox.; in	D2.W	rang de l'objet; out	-; mod	D7.WDBOXHLINE:	PUSHM.L	D2..D4	DBOX_	GETCO	CLR.W	D3	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2..D4	RET;--------\\; DBOXRSK >;========/; Refait les soft-keys.; in	A2.L	^table DBOX; out	-; mod	D7.WDBOXRSK:	PUSHM.L	D3,A3	LOAD.W	D3,(A2)+2	LOAD.L	A3,#(A2)+(D3.W)	LIB	?AFMENU		; refait les soft-keys	POPM.L	D3,A3	RET;--------\\; DOK...  >;========/DOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RET	.END