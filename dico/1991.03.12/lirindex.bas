15000 -- *********************************************************************15010 -- Module de lecture des positions-fichiers dans l'en-tte d'un DICO15020 --15030 -- Deux paramtres : NOMDICO$ > '25000' ou '50000'15040 --                   @NOREVI$ > retourne le numro de rvision du DICO15050 --15060 -- Le nombre de positionnements est retourn dans MAX% (environ 330)15070 -- Retourne la liste des initiales dans POSIT$(MAX%)15080 -- Retourne la liste des positions des initiales dans POSIT(MAX%)15090 --15100 -- ATTENTION ! POSIT(MAX%) & POSIT$(MAX%) sont dimensionns ici !15110 --             Passage de paramtres de type tableau impossible !15120 --             Le fichier DICO demeure ouvert : numro de canal 115130 --15140 -- *********************************************************************15150 --15160 Label_LIRINDEX (NOMDICO$, @NOREVI$)15170   Let NOMDICO$ = NOMDICO$ + '.dico' 15180   Open File(1), NOMDICO$, 215190   Input Line File(1), LIGNE$15200   Input Line File(1), LIGNE$15210   Let ITER% = Len(LIGNE$)15220   Loop15230     Dec ITER%15240     Exit If Mid$(LIGNE$, ITER%, 1) = Chr$(32)15250   End Loop15260   Let @NOREVI$ = Right$(LIGNE$, Len(LIGNE$) - ITER%)15270   Input Line File(1), LIGNE$ 15280   Input Line File(1), LIGNE$15290   Let MAX% = Val(LIGNE$)15300   Dim POSIT$(MAX%), POSIT(MAX%)15310   For ITER% = 1 To MAX%15320     Input File(1), POSIT$(ITER%)15330     Input File(1), POSIT(ITER%)15340   Next ITER%15350 Return