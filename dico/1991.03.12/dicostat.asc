	.TITLE	DICOSTAT.ASC	.PROC	M680002	.REF	SMAKY	.LOC	0OPDICO:	.BLKB	4		; ^dictionnaireOCHDIS:	.BLKB	2OCHFIL:	.BLKB	2OBSTAT:	.BLKB	26*26*4LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LIB	?GCHDIS	LOAD.W	(A6)+OCHDIS,D6	LOAD.L	A3,#R16"NMDICO	CALL	DICOLOAD	JUMP,NE ERFAT	LOAD.L	(A6)+OPDICO,A4	LOAD.L	A3,#(A6)+OBSTAT	LOAD.B	D3,#'a20$:	LOAD.B	D4,#'a22$:	PUSH.L	D3	LIB	?IFCAR	POPM.L	D3	JUMP,EQ 40$	CALL	DICOCNT	LOAD.B	(A3+),D3	LOAD.B	(A3+),D4	LOAD.W	(A3+),D1	CALL	DICOAFF	INC.B	D4	COMP.B	D4,#'z	JUMP,LS 22$	INC.B	D3	COMP.B	D3,#'z	JUMP,LS 20$40$:	LIB	?AFTIM	.ASCIZ	"----------------------------------<CR>"	.EVEN	LOAD.L	A3,#R16"NMSTAT	FOS	?DELETE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	LOAD.W	(A6)+OCHFIL,D6	LOAD.W	D3,#12842$:	CALL	MAX	DEC.W	D3	JUMP,NE 42$	LOAD.W	D6,(A6)+OCHFIL	FOS	?CLOSE	LIB	?GETCARFIN:	TEST.L	(A6)+OPDICO	JUMP,EQ 20$	LOAD.L	A4,(A6)+OPDICO	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPDICO20$:ERFAT:	EXIT;--------\\; MAX     >;========/; ; in	; out	; mod	MAX:	PUSHM.L	D1..D4,D6,A3,A4	LOAD.L	A3,#(A6)+OBSTAT	LOAD.W	D3,#26*26	CLR.W	D220$:	COMP.W	D2,(A3)+2	JUMP',HS 30$	LOAD.W	D2,(A3)+2	LOAD.L	A4,A330$:	ADD.L	A3,#4	DEC.W	D3	JUMP,NE 20$	LOAD.B	D3,(A4)+0	LOAD.B	D4,(A4)+1	LOAD.W	D1,(A4)+2	CALL	DICOAFF	LOAD.W	D6,(A6)+OCHFIL	LIB	?PCHDIS	CALL	DICOAFF	LOAD.W	D6,(A6)+OCHDIS	LIB	?PCHDIS	CLR.W	(A4)+290$:	POPM.L	D1..D4,D6,A3,A4	RET;--------\\; DICOAFF >;========/; ; in	D3.B	premire lettre;	D4.B	deuxime lettre;	D1.W	nombre de mots; out	; mod	DICOAFF:	PUSHM.L	D1..D4	LIB	?AFCAR	EX.L	D3,D4	LIB	?AFCAR	EX.L	D3,D4	LIB	?AFTIM	.ASCIZ	" = "	.EVEN	CLR.L	D4	LOAD.W	D4,D1	LOAD.W	D3,#8	CLR.W	D2	LIB	?AFDEC	LIB	?AFCR90$:	POPM.L	D1..D4	RET;--------\\; DICOCNT >;========/; ; in	D3.B	premire lettre;	D4.B	deuxime lettre; out	D1.W	nombre de mots; mod	DICOCNT:	PUSHM.L	D0,D2,A4	LOAD.L	A4,(A6)+OPDICO	CLR.W	D1	LOAD.B	D0,#CR20$:	TEST.B	(A4+)	JUMP,EQ 90$30$:	LOAD.B	D2,(A4+)	COMP.B	D2,D0	JUMP,EQ 20$	COMP.B	D3,D2	JUMP,NE 30$	COMP.B	D4,(A4)	JUMP,NE 30$	INC.W	D1	JUMP	30$90$:	POPM.L	D0,D2,A4	RET;---------\\; DICOLOAD >;=========/; Charge un dictionnaire en mmoire.; in	A3.L	^nom du dictionnaire; out	A4.L	^dictionnaire termin par <0>;	D7.W	erreur; mod	D7.W, A4.LDICOLOAD:	PUSHM.L	D1,D3,D4,D6	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre le dictionnaire	JUMP,NE 90$	LOAD.L	D4,#-1	LOAD.B	D3,D4	FOS	?SPOS		; D4 <-- longueur du fichier	PUSH.L	D4	CLR.L	D4	CLR.B	D3	FOS	?SPOS		; revient au dbut	POP.L	D4	INC.L	D4		; D4 <-- place pour <0> terminateur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer pour le fichier dictionnaire	JUMP',NE 82$	DEC.L	D4	FOS	?RDBYTE		; lit tout le fichier dictionnaire	JUMP',NE 80$	CLR.B	(A4)+(D4.L)	; met le <0> terminateur	JUMP'	82$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire du dictionnaire	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme le dictionnaire	POP.W	D790$:	POPM.L	D1,D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; MAJMIN  >;========/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMAJMIN:	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'Z	JUMP',HI 90$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule90$:	RET;-------\\; MINMAJ >;=======/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMINMAJ:	COMP.B	D3,#'		; lettre accentue ?	JUMP',LS 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+TACCENT$ ; D3 <-- lettre majuscule	POP.W	D0	RETTACCENT$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN;---------\\; NOACCENT >;=========/; in	D3.B	caractre; out	D3.B	caractre non accentu; mod	D3.BNOACCENT:	COMP.B	D3,#'	JUMP',LO 90$	COMP.B	D3,#'		; lettre accentue ?	JUMP',HI 90$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+TACCENT$ ; D3 <-- lettre non accentue	POP.W	D090$:	RETTACCENT$:	.B	'u 'a 'a 'e 'e 'e 'e 'i 'i 'o 'u 'u 'a 'o 'c	.EVENNMDICO:	.ASCIZ	"ESSAI.DICO"NMSTAT:	.ASCIZ	"DICOSTAT.TEXT"	.EVENVAR:	.FILLB	LGVAR,0	.END	START