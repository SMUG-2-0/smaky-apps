	.TITLE	CHIFFRE.ASC	.PROC	M680002	.REF	SMAKYLCHBUF	=	100LBULINE	=	50	.LOC	0OBULINE:.BLKB	LBULINEOCHBIN:	.BLKB	LCHBUFOCHBUF:	.BLKB	LCHBUFOCHREG:	.BLKB	1		; rgion (V,S,F)	.EVENLGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VARLOOP:	LIB	?AFTIM	.ASCIZE	"Chiffre : "	LOAD.L	A3,#(A6)+OBULINE	LOAD.W	D3,#LBULINE	LIB	?GETLINE	COMP.W	D3,#CR	JUMP,NE FINI	LOAD.B	(A6)+OCHREG,#'V	LOAD.L	A3,#(A6)+OBULINE	LOAD.L	D3,#LBULINE	LOAD.L	A4,#(A6)+OCHBUF	LOAD.L	D4,#LCHBUF	CALL	CHCONV	JUMP,NE ERROR	LIB	?AFTIM	.ASCIZE	/V: "/	LOAD.L	A3,A4	LOAD.L	D3,D4	LIB	?STRING	LIB	?AFTIM	.ASCIZE	/"<CR>/	LOAD.B	(A6)+OCHREG,#'S	LOAD.L	A3,#(A6)+OBULINE	LOAD.L	D3,#LBULINE	LOAD.L	A4,#(A6)+OCHBUF	LOAD.L	D4,#LCHBUF	CALL	CHCONV	JUMP,NE ERROR	LIB	?AFTIM	.ASCIZE	/S: "/	LOAD.L	A3,A4	LOAD.L	D3,D4	LIB	?STRING	LIB	?AFTIM	.ASCIZE	/"<CR>/	LOAD.B	(A6)+OCHREG,#'F	LOAD.L	A3,#(A6)+OBULINE	LOAD.L	D3,#LBULINE	LOAD.L	A4,#(A6)+OCHBUF	LOAD.L	D4,#LCHBUF	CALL	CHCONV	JUMP,NE ERROR	LIB	?AFTIM	.ASCIZE	/F: "/	LOAD.L	A3,A4	LOAD.L	D3,D4	LIB	?STRING	LIB	?AFTIM	.ASCIZE	/"<CR>/	JUMP	LOOPERROR:	LIB	?AFERROR	LIB	?AFCR	JUMP	LOOPFINI:	EXIT;--------\\; CHCONV  >;========/; ; in	A3/D3.L	^chiffre/lg sous forme de nombres;	A4/D4.L	^buffer/lg pour chiffre en lettres; out	A4/D4.L	^chiffre/lg;	D7.W	erreur; mod	D4.L, D7.WCHCONV:	PUSHM.L	D1..D3,A2..A5	LOAD.L	A5,A4	TEST.L	D3	JUMP,EQ 90$	LOAD.L	A2,#R16"PLUS$	COMP.B	(A3),#'+	JUMP',EQ 20$	LOAD.L	A2,#R16"MOINS$	COMP.B	(A3),#'-	JUMP',NE 22$20$:	DEC.L	D3	INC.L	A3	CALL	CHCONVINS	; buffer <-- "plus " ou "moins "	JUMP,NE 90$22$:	CALL	CHCONVINT	; buffer <-- partie entire	JUMP,NE 90$30$:	DEC.L	D3	JUMP,NS 90$	LOAD.B	D1,(A3+)	JUMP,EQ 90$	COMP.B	D1,#'%	JUMP',EQ 62$	COMP.B	D1,#'.	JUMP',EQ 32$	COMP.B	D1,#',	JUMP,NE 30$32$:	LOAD.L	A2,#R16"FRAC$	CALL	CHCONVINS	; buffer <-- " virgule "	JUMP,NE 90$34$:	TEST.L	D3	JUMP,EQ 90$	COMP.B	(A3),#'0	JUMP',NE 36$	DEC.L	D3	INC.L	A3	LOAD.L	A2,#R16"ZERO$	CALL	CHCONVINS	; buffer <-- "zro "	JUMP,NE 90$	JUMP	34$36$:	CALL	CHCONVINT	; buffer <-- partie fractionnaire	JUMP',NE 90$60$:	DEC.L	D3	JUMP',NS 90$	LOAD.B	D1,(A3+)	JUMP',EQ 90$	COMP.B	D1,#'%	JUMP,NE 60$62$:	LOAD.L	A2,#R16"PCENT$	CALL	CHCONVINS	; buffer <-- " virgule "	JUMP,NE 90$90$:	LOAD.L	D4,A4	SUB.L	D4,A5		; D4 <-- lg	POPM.L	D1..D3,A2..A5	TEST.W	D7		; retour EQ/NE	RETPLUS$:	.ASCIZ	"plus "MOINS$:	.ASCIZ	"moins "FRAC$:	.ASCIZ	" virgule "ZERO$:	.ASCIZ	"zro "PCENT$:	.ASCIZ	" pour cent"	.EVEN;----------\\; CHCONVINT >;----------/; Converti la partie entire d'un nombre.; in	A3/D3.L	^chiffre/lg sous forme de nombres;	A4/D4.L	^buffer/lg pour chiffre en lettres; out	A4/D4.L	^buffer/lg;	D7.W	erreur; mod	D4.L, D7.W, A4.LCHCONVINT:	PUSHM.L	D0..D3,A2,A3	LOAD.L	A2,#(A6)+OCHBIN	LOAD.B	D1,#'0	LOAD.B	(A2+),D1	LOAD.B	(A2+),D1	LOAD.B	(A2+),D1; Met tous les chiffres de la partie entire.	CLR.W	D0		; D0 <-- nb de chiffres20$:	DEC.L	D3	JUMP,NS 40$	LOAD.B	D1,(A3+)	JUMP,EQ 40$	COMP.B	D1,#'.	JUMP,EQ 40$	COMP.B	D1,#',	JUMP,EQ 40$	COMP.B	D1,#'O	JUMP',EQ 24$	COMP.B	D1,#'o	JUMP',EQ 24$	COMP.B	D1,#'L	JUMP',EQ 25$	COMP.B	D1,#'l	JUMP',EQ 25$	COMP.B	D1,#'0	JUMP,LO 20$	COMP.B	D1,#'9	JUMP,HI 20$23$:	INC.W	D0		; D0 <-- un chiffre de plus	LOAD.B	(A2+),D1	; OCHBIN <-- un chiffre	JUMP	20$24$:	LOAD.B	D1,#'0	JUMP	23$25$:	LOAD.B	D1,#'1	JUMP	23$; Gnre la partie entire.40$:	CLR.B	(A2)	LOAD.L	A3,#(A6)+OCHBIN	CLR.L	D1	LOAD.W	D1,D0	DIV.WU	D1,#3	SWAP.W	D1		; D1 <-- 0..2	TEST.W	D1	JUMP',NE 42$	LOAD.W	D1,#342$:	ADD.W	A3,D1	CLR.L	D3	LOAD.W	D3,D0	ADD.W	D3,#2	DIV.WU	D3,#3		; D3 <-- nb de tranches de 3 chiffres	JUMP,EQ 60$	COMP.B	D3,#1	JUMP',NE 50$	COMP.B	(A3)+0,#'0	JUMP',NE 50$	COMP.B	(A3)+1,#'0	JUMP',NE 50$	COMP.B	(A3)+2,#'0	JUMP',NE 50$	ADD.L	A3,#3	JUMP	60$50$:	COMP.B	D3,#2		; mille ?	JUMP',NE 52$		; non => 52$	COMP.B	(A3)+0,#'0	JUMP',NE 52$	COMP.B	(A3)+1,#'0	JUMP',NE 52$	COMP.B	(A3)+2,#'1	JUMP',NE 52$	ADD.L	A3,#3		; A3 <-- ^tranche suivante	JUMP'	56$52$:	LOAD.L	A2,A4	CALL	CHCONVPART	; converti une tranche de 3 chiffres	JUMP',NE 90$	ADD.L	A3,#3		; A3 <-- ^tranche suivante	COMP.L	A2,A4		; gnr qq chose ?	JUMP',EQ 58$		; non => 58$	COMP.B	D3,#1	JUMP',EQ 90$	LOAD.L	A2,#R16"SPACE$	CALL	CHCONVINS	; buffer <-- " "	JUMP',NE 90$56$:	LOAD.L	A2,#R16"TACH1000	CALL	CHCONVSEARCH	JUMP',NE 90$	CALL	CHCONVINS	; buffer <-- "mille".."billion"	JUMP',NE 90$	LOAD.L	A2,A3	CALL	CHCONVIFNUL	; est-ce que tout ce qui reste est nul ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	A2,#R16"SPACE$	CALL	CHCONVINS	; buffer <-- " "	JUMP',NE 90$58$:	DEC.B	D3	JUMP,NE 50$	JUMP'	90$60$:	LOAD.L	A2,#R16"ZERO$	CALL	CHCONVINS	; buffer <-- "zro";	JUMP',NE 90$90$:	POPM.L	D0..D3,A2,A3	TEST.W	D7		; retour EQ/NE	RETSPACE$:	.ASCIZ	" "ZERO$:	.ASCIZ	"zro"	.EVEN;-----------\\; CHCONVPART >;-----------/; Converti une tranche de 3 chiffres (centaine, dizaine et unit).; in	A3.L	^centaine,dizaine,unit;	A4/D4.L	^buffer/lg; out	A4/D4.L	^buffer/lg;	D7.W	erreur; mod	D4.L, D7.W, A4.LCHCONVPART:	PUSHM.L	D3,A2	CLR.W	D7		; D7 <-- ok; Traite les centaines.	LOAD.B	D3,(A3)+0	; D3 <-- centaine	SUB.B	D3,#'0	JUMP',EQ 30$	COMP.B	D3,#1	JUMP',EQ 20$	LOAD.L	A2,#R16"TACH0119	CALL	CHCONVSEARCH	JUMP,NE 90$	CALL	CHCONVINS	; buffer <-- "deux".."neuf" (cent)	JUMP,NE 90$	LOAD.L	A2,#R16"SPACE$	CALL	CHCONVINS	; buffer <-- " "	JUMP,NE 90$20$:	LOAD.L	A2,#R16"CENT$	CALL	CHCONVINS	; buffer <-- "cent"	JUMP,NE 90$	LOAD.L	A2,#(A3)+1	CALL	CHCONVIFNUL	; tout le reste nul ?	JUMP',NE 22$		; non => 22$	COMP.B	D3,#1		; chiffre 100 ?	JUMP,EQ 90$		; oui => 90$	TEST.B	(A3)+3	JUMP,NE 90$	LOAD.L	A2,#R16"PLUR$	CALL	CHCONVINS	; buffer <-- "s"	JUMP	90$22$:	LOAD.L	A2,#R16"SPACE$	CALL	CHCONVINS	; buffer <-- " "	JUMP,NE 90$; Traites les dizaines.30$:	COMP.B	(A6)+OCHREG,#'F	; rgion franaise ?	JUMP',NE 33$		; non => 33$	COMP.B	(A3)+1,#'7	; dizaine = soixante-dix ?	JUMP',EQ 32$		; oui => 32$	COMP.B	(A3)+1,#'9	; dizaine = quatre-vingt-dix ?	JUMP',NE 33$32$:	DEC.B	(A3)+1		; dizaine <-- -10	ADD.B	(A3)+2,#10	; unit <-- +1033$:	CLR.W	D3	LOAD.B	D3,(A3)+1	; D3 <-- dizaine	SUB.B	D3,#'0	JUMP,EQ 60$	MUL.WU	D3,#10	COMP.B	D3,#10	JUMP',NE 40$				; 10..19 =>	ADD.B	D3,(A3)+2	; D3 <-- dizaine*10 + unit	SUB.B	D3,#'0	LOAD.L	A2,#R16"TACH0119	CALL	CHCONVSEARCH	JUMP,NE 90$	CALL	CHCONVINS	; buffer <-- "dix".."dix-neuf"	JUMP	90$40$:				; 20..99 =>	LOAD.L	A2,#R16"TACH2090V	COMP.B	(A6)+OCHREG,#'V	JUMP',EQ 42$	LOAD.L	A2,#R16"TACH2090S42$:	CALL	CHCONVSEARCH	JUMP,NE 90$	CALL	CHCONVINS	; buffer <-- "vingt".."nonante"	JUMP,NE 90$	LOAD.B	D3,(A3)+2	; D3 <-- unit	SUB.B	D3,#'0	JUMP',EQ 50$	LOAD.L	A2,#R16"TIRET$	COMP.B	D3,#1	JUMP',NE 44$	LOAD.L	A2,#R16"ET$44$:	COMP.B	D3,#11	JUMP',NE 45$	COMP.B	(A3)+1,#'6	; soixante et onze ?	JUMP',NE 45$		; non => 45$	LOAD.L	A2,#R16"ET$45$:	COMP.B	(A6)+OCHREG,#'V	; rgion vaudoise ?	JUMP',EQ 46$		; oui => 46$	COMP.B	(A3)+1,#'8	; dizaine = quatre-vingt ?	JUMP',NE 46$		; non => 46$	LOAD.L	A2,#R16"TIRET$	; oui => toujours "-"46$:	CALL	CHCONVINS	; buffer <-- " et " ou "-"	JUMP,NE 90$	JUMP'	60$50$:	COMP.B	(A6)+OCHREG,#'V	; rgion vaudoise ?	JUMP',EQ 90$		; oui => 90$	COMP.B	(A3)+1,#'8	; dizaine = quatre-vingt ?	JUMP',NE 90$		; non => 90$	LOAD.L	A2,#R16"PLUR$	CALL	CHCONVINS	; buffer <-- "s"	JUMP	90$; Traite les units.60$:	LOAD.B	D3,(A3)+2	; D3 <-- unit	SUB.B	D3,#'0	JUMP',EQ 90$	LOAD.L	A2,#R16"TACH0119	CALL	CHCONVSEARCH	JUMP',NE 90$	CALL	CHCONVINS	; buffer <-- "un".."neuf";	JUMP',NE 90$90$:	POPM.L	D3,A2	TEST.W	D7		; retour EQ/NE	RETCENT$:	.ASCIZ	"cent"ET$:	.ASCIZ	" et "TIRET$:	.ASCIZ	"-"PLUR$:	.ASCIZ	"s"SPACE$:	.ASCIZ	" "	.EVEN;------------\\; CHCONVIFNUL >;------------/; Regarde si la fin d'un nombre est nulle.; in	A2.L	^reste d'un chiffre; out	EQ	tout le reste est nul; mod	-CHCONVIFNUL:	PUSHM.L	D3,A220$:	LOAD.B	D3,(A2+)	JUMP',EQ 90$	COMP.B	D3,#'0	JUMP,EQ 20$90$:	POPM.L	D3,A2	RET;----------\\; CHCONVINS >;----------/; Insre une chane  la fin du buffer.; in	A2.L	^chane  insrer <0>;	A4/D4.L	^buffer/lg; out	A4/D4.L	^buffer/lg;	D7.W	erreur; mod	D4.L, D7.W, A4.LCHCONVINS:	PUSH.L	A2	CLR.W	D720$:	TEST.B	(A2)	JUMP',EQ 90$	TEST.L	D4	JUMP',EQ 80$	DEC.L	D4	LOAD.B	(A4+),(A2+)	JUMP	20$80$:	LOAD.W	D7,#290$:	POP.L	A2	TEST.W	D7		; retour EQ/NE	RET;-------------\\; CHCONVSEARCH >;-------------/; Cherche un nombre en toute lettre.; in	D3.B	nombre cherch (1..99);	A2.L	^table o chercher; out	A2.L	^texte <0>;	D7.W	erreur; mod	D7.W, A2.LCHCONVSEARCH:	LOAD.W	D7,#120$:	TEST.B	(A2)	JUMP',EQ 90$	COMP.B	D3,(A2+)	JUMP',EQ 80$30$:	TEST.B	(A2+)	JUMP,NE 30$	JUMP	20$80$:	CLR.W	D7		; D7 <-- trouv90$:	TEST.W	D7		; retour EQ/NE	RETTACH0119:	.B	1	.ASCIZ	"un"	.B	2	.ASCIZ	"deux"	.B	3	.ASCIZ	"trois"	.B	4	.ASCIZ	"quatre"	.B	5	.ASCIZ	"cinq"	.B	6	.ASCIZ	"six"	.B	7	.ASCIZ	"sept"	.B	8	.ASCIZ	"huit"	.B	9	.ASCIZ	"neuf"	.B	10	.ASCIZ	"dix"	.B	11	.ASCIZ	"onze"	.B	12	.ASCIZ	"douze"	.B	13	.ASCIZ	"treize"	.B	14	.ASCIZ	"quatorze"	.B	15	.ASCIZ	"quinze"	.B	16	.ASCIZ	"seize"	.B	17	.ASCIZ	"dix-sept"	.B	18	.ASCIZ	"dix-huit"	.B	19	.ASCIZ	"dix-neuf"	.B	0TACH2090V:			; version vaudoise =>	.B	20	.ASCIZ	"vingt"	.B	30	.ASCIZ	"trente"	.B	40	.ASCIZ	"quarante"	.B	50	.ASCIZ	"cinquante"	.B	60	.ASCIZ	"soixante"	.B	70	.ASCIZ	"septante"	.B	80	.ASCIZ	"huitante"	.B	90	.ASCIZ	"nonante"	.B	0TACH2090S:			; version suisse =>	.B	20	.ASCIZ	"vingt"	.B	30	.ASCIZ	"trente"	.B	40	.ASCIZ	"quarante"	.B	50	.ASCIZ	"cinquante"	.B	60	.ASCIZ	"soixante"	.B	70	.ASCIZ	"septante"	.B	80	.ASCIZ	"quatre-vingt"	.B	90	.ASCIZ	"nonante"	.B	0TACH1000:	.B	2	.ASCIZ	"mille"	.B	3	.ASCIZ	"million"	.B	4	.ASCIZ	"milliard"	.B	5	.ASCIZ	"billion"	.EVENVAR:	.FILLB	LGVAR,0	.END	START