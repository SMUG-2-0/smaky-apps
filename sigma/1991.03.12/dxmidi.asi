	.SBTTL	DXMIDI; Routines MIDI; -------------;----------\\; PROGRAMME >;==========/; Slectionne un programme.; in	D3.B	numro du programme (0..127); out	D7.W	erreur; mod	D7.WPROGRAMME:	PUSHM.L	D2,D4,D5,A4	TEST.B	(A6)+OFLAGS:#BSAJ ; synth  jour ?	JUMP,BS 10$		; oui => 10$				; non =>	CALL	WAITMOUSE	; met le sablier	LOAD.W	D4,#2	NTREL	?DELMS		; attend de voir le sablier !	CALL	SEND32		; envoie 32 timbres au synth ...	CALL	NORMMOUSE	; remet la flche10$:	LOAD.W	(A6)+ONOPROG,D3	; mm dernier programme slectionn	LOAD.L	A4,#(A6)+OBMIDI	LOAD.B	(A4)+0,#0	LOAD.B	(A4)+1,#2	LOAD.W	D2,(A6)+OCHMIDI	OR.B	D2,#H'C0	; programm change + canal	LOAD.B	(A4)+2,D2	LOAD.B	(A4)+3,D3	CLR.L	D5	LOAD.W	D5,(A4)	ADD.W	D5,#2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DWRITE		; crit tout a	POPM.L	D2,D4,D5,A4	TEST.W	D7		; retour EQ/NE	RET	.IF	DX7!DX100;----------\\; LPRESSDX  >;==========/; Presse sur une liste de boutons.; in	A3.L	^liste (-1 terminateur); out	D7.W	erreur; mod	D7.WLPRESSDX:	PUSHM.L	D3,A310$:	LOAD.B	D3,(A3+)	COMP.B	D3,#-1	JUMP,EQ 90$	CALL	PRESSDX	JUMP,EQ 10$90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; PRESSDX  >;=========/; Presse et relche un bouton du DX  distance.; in	D3.B	numro du bouton; out	D7.W	erreur; mod	D7.WPRESSDX:	CALL	PUSHDX		; presse	JUMP,NE 90$	CALL	POPDX		; puis relche90$:	RET;--------\\; PUSHDX  >;========/; Presse sur un bouton du DX  distance.; in	D3.B	numro du bouton; out	D7.W	erreur; mod	D7.WPUSHDX:	PUSHM.L	D2,D4,D5,A4	LOAD.L	A4,#(A6)+OBMIDI	LOAD.B	(A4)+0,#0	LOAD.B	(A4)+1,#7	LOAD.B	(A4)+2,#H'F0	; system exclusive	LOAD.B	(A4)+3,#H'43	; ID Yamaha	LOAD.W	D2,(A6)+OCHMIDI	OR.B	D2,#H'10	LOAD.B	(A4)+4,D2	; canal	LOAD.B	(A4)+5,#H'08	LOAD.B	(A4)+6,D3	; bouton	LOAD.B	(A4)+7,#1	; press	LOAD.B	(A4)+8,#H'F7	; EOX	CLR.L	D5	LOAD.W	D5,(A4)	ADD.W	D5,#2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DWRITE		; crit tout a	POPM.L	D2,D4,D5,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; POPDX  >;=======/; Relche un bouton du DX  distance.; in	D3.B	numro du bouton; out	D7.W	erreur; mod	D7.WPOPDX:	PUSHM.L	D2,D4,D5,A4	LOAD.L	A4,#(A6)+OBMIDI	LOAD.B	(A4)+0,#0	LOAD.B	(A4)+1,#7	LOAD.B	(A4)+2,#H'F0	; system exclusive	LOAD.B	(A4)+3,#H'43	; ID Yamaha	LOAD.W	D2,(A6)+OCHMIDI	OR.B	D2,#H'10	LOAD.B	(A4)+4,D2	; canal	LOAD.B	(A4)+5,#H'08	LOAD.B	(A4)+6,D3	; bouton	LOAD.B	(A4)+7,#0	; relch	LOAD.B	(A4)+8,#H'F7	; EOX	CLR.L	D5	LOAD.W	D5,(A4)	ADD.W	D5,#2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DWRITE		; crit tout a	LOAD.W	D4,#2	NTREL	?DELMS		; et oh, mol !	POPM.L	D2,D4,D5,A4	TEST.W	D7		; retour EQ/NE	RET	.ENDIF;---------\\; MODPARAM >;=========/; Modifie un paramtre.; in	D3.W	numro du paramtre;	D4.B	valeur du paramtre; out	D7.W	erreur; mod	D7.WMODPARAM:	PUSHM.L	D2..D5,A4	LOAD.L	A4,#(A6)+OBMIDI	.IF	DX7	LOAD.B	(A4)+0,#0	LOAD.B	(A4)+1,#7	LOAD.B	(A4)+2,#H'F0	; system exclusive	LOAD.B	(A4)+3,#H'43	; ID Yamaha	LOAD.W	D2,(A6)+OCHMIDI	OR.B	D2,#H'10	LOAD.B	(A4)+4,D2	; canal	LOAD.W	D2,D3	SR.W	D2,#7	LOAD.B	(A4)+5,D2	; 0ggggghh	AND.B	D3,#H'7F	LOAD.B	(A4)+6,D3	; 0ppppppp	LOAD.B	(A4)+7,D4	; valeur	LOAD.B	(A4)+8,#H'F7	; EOX	.ENDIF	.IF	DX100	LOAD.B	(A4)+0,#0	LOAD.B	(A4)+1,#7	LOAD.B	(A4)+2,#H'F0	; system exclusive	LOAD.B	(A4)+3,#H'43	; ID Yamaha	LOAD.W	D2,(A6)+OCHMIDI	OR.B	D2,#H'10	LOAD.B	(A4)+4,D2	; canal	LOAD.B	(A4)+5,#H'12	; groupe de paramtres	AND.B	D3,#H'7F	LOAD.B	(A4)+6,D3	; 0ppppppp	LOAD.B	(A4)+7,D4	; valeur	LOAD.B	(A4)+8,#H'F7	; EOX	.ENDIF	.IF	FB01	LOAD.B	(A4)+0,#0	LOAD.B	(A4)+1,#8	LOAD.B	(A4)+2,#H'F0	; system exclusive	LOAD.B	(A4)+3,#H'43	; ID Yamaha	LOAD.B	(A4)+4,#H'75	; sous-status	LOAD.W	D2,(A6)+OCHMIDI	LOAD.B	(A4)+5,D2	; canal systme	AND.L	D3,#H'FFFF	SUB.W	D3,#H'20	DIV.WU	D3,#H'10	ADD.B	D3,#H'18	LOAD.B	(A4)+6,D3	; instrument	SWAP.W	D3	LOAD.B	(A4)+7,D3	; 0ppppppp	LOAD.B	(A4)+8,D4	; valeur	LOAD.B	(A4)+9,#H'F7	; EOX	.ENDIF	CLR.L	D5	LOAD.W	D5,(A4)	ADD.W	D5,#2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DWRITE		; crit tout a	LOAD.W	D4,#2	NTREL	?DELMS		; et oh, mol !	POPM.L	D2..D5,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SEND32  >;========/; Envoie les 32 timbres.; in	-; out	D7.W	erreur; mod	D7.WSEND32:	PUSHM.L	D2,D5,A3,A4	.IF	DX7!DX100	LOAD.L	A3,#R16"TDXIECRIT	CALL	LPRESSDX	; "SYS INFO AVAIL"	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUF	LOAD.W	D2,(A6)+OCHMIDI	LOAD.B	(A4)+4,D2	; canal	LOAD.L	D5,#LFDX	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DWRITE		; envoie les 32 timbres ...	JUMP,NE 90$	LOAD.L	A3,#R16"TDXOECRIT	CALL	LPRESSDX	; "SYS INFO UNAVAIL"	JUMP,NE 90$	TSET.B	(A6)+OFLAGS:#BSAJ ; synth  jour	.ENDIF	.IF	FB01	LOAD.L	A4,#(A6)+OBUF+11	LOAD.W	D2,#H'A0-1	CLR.B	D510$:	ADD.B	D5,(A4+)	; D5 <-- checksum	DECJ.W,NMO D2,10$	NEG.B	D5		; D5 <-- complment  deux	TCLR.L	D5:#7	LOAD.B	(A4+),D5	LOAD.B	(A4+),#H'F7	LOAD.L	A4,#(A6)+OBUF	LOAD.W	D2,(A6)+OCHMIDI	LOAD.B	(A4)+5,D2	; canal systme	LOAD.L	D5,#LFDX+2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DWRITE		; envoie la configuration ...	JUMP,NE 90$	TSET.B	(A6)+OFLAGS:#BSAJ ; synth  jour	.ENDIF90$:	POPM.L	D2,D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WAIT32  >;========/; Attend l'envoi de 32 timbres.; in	-; out	D7.W	erreur; mod	D7.WWAIT32:	PUSHM.L	D2..D5,A3..A5	.IF	DX7	LOAD.L	A3,#R16"TDXILIT	CALL	LPRESSDX	; "MIDI TRANSMIT ?"	JUMP,NE 90$	TSET.B	(A6)+OFLAGS:#BWAIT32	NTREL	?GETPRIO	; D4 <-- priorit	DEC.W	D4	LOAD.L	D5,#600		; D5 <-- lg stack	LOAD.L	A5,#R16"PWAIT32	; A5 <-- ^start	LOAD.L	A3,#R16"NWAIT32	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre la rception	JUMP,NE 90$30$:	LIB	?IFCAR		; vide le fifo du clavier !	JUMP,EQ 30$	LOAD.W	D4,#50/4	NTREL	?DELMS		; attend un peu ...	LOAD.B	D3,#KDX7ON	CALL	PRESSDX		; "YES"	LOAD.W	D2,#10*2	; D2 <-- attend 2 secondes maximum40$:	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLAGS:#BWAIT32	JUMP,BC 45$	LIB	?IFCAR		; touche presse ?	JUMP,EQ 44$		; oui => 44$	LOAD.W	D4,#50/10	NTREL	?DELMS		; attend un peu ...	DEC.W	D2	JUMP,NE 40$44$:	LOAD.W	D7,#ERUNCO	; D7 <-- unit pas connecte45$:	PUSH.W	D7	CALL	STOPMIDI	; stoppe tout	POP.W	D7	JUMP,NE 90$	LOAD.W	D7,#ERUNCO	; D7 <-- unit pas (ou mal) connecte	LOAD.L	A4,#(A6)+OBUF	; A4 <-- ^data reu	LOAD.L	D4,(A6)+OLWAIT	; D4 <-- lg data reu50$:	TEST.L	D4		; reste qq chose ?	JUMP,LE 90$		; non => 90$	CLR.L	D3	LOAD.B	D3,(A4)+0	SL.W	D3,#8	LOAD.B	D3,(A4)+1	TEST.W	D3		; temps ?	JUMP,NE 52$		; non => 52$				; oui =>	LOAD.W	D3,#2		; D3 <-- lg pour un temps	JUMP	55$52$:				; objet ?	COMP.W	D3,#LFDX+2-2	JUMP,NE 55$	COMP.B	(A4)+2,#H'F0	; status	JUMP,NE 55$	COMP.B	(A4)+3,#H'43	; ID de Yamaha	JUMP,NE 55$	COMP.B	(A4)+5,#H'09	; format	JUMP,NE 55$	COMP.B	(A4)+6,#H'20	; lg-high	JUMP,NE 55$	COMP.B	(A4)+7,#H'00	; lg-low	JUMP,EQ 60$55$:	ADD.W	D3,#2	ADD.L	A4,D3		; A4 <-- saute objet/temps	SUB.L	D4,D3	JUMP	50$60$:	COMP.L	D4,#LFDX	; est-ce que tout est l ?	JUMP,LO 90$		; non => 90$	LOAD.L	A3,#(A6)+OBUF	; A3 <-- ^dbut du buffer	LOAD.W	D4,#LFDX-170$:	LOAD.B	(A3+),(A4+)	; remonte au dbut du buffer	DECJ.W,NMO D4,70$	CLR.B	(A6)+OBUNAME	; y'a plus de nom !	TSET.B	(A6)+OFLAGS:#BSAJ ; synth  jour	CLR.W	D7		; D7 <-- ok90$:	PUSH.W	D7	LOAD.L	A3,#R16"TDXOLIT	CALL	LPRESSDX	; "SYS INFO UNAVAIL"	POP.W	D7	.ENDIF	.IF	DX100	TSET.B	(A6)+OFLAGS:#BWAIT32	NTREL	?GETPRIO	; D4 <-- priorit	DEC.W	D4	LOAD.L	D5,#600		; D5 <-- lg stack	LOAD.L	A5,#R16"PWAIT32	; A5 <-- ^start	LOAD.L	A3,#R16"NWAIT32	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre la rception	JUMP,NE 90$30$:	LIB	?IFCAR		; vide le fifo du clavier !	JUMP,EQ 30$	LOAD.L	A4,#(A6)+OBMIDI	LOAD.B	(A4)+0,#0	LOAD.B	(A4)+1,#5	LOAD.B	(A4)+2,#H'F0	; system exclusive	LOAD.B	(A4)+3,#H'43	; ID Yamaha	LOAD.W	D2,(A6)+OCHMIDI	OR.B	D2,#H'20	LOAD.B	(A4)+4,D2	; canal	LOAD.B	(A4)+5,#4	; demande 32 sons	LOAD.B	(A4)+6,#H'F7	; EOX	CLR.L	D5	LOAD.W	D5,(A4)	ADD.W	D5,#2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DWRITE		; crit la demande de vidage	JUMP,NE 90$	LOAD.W	D2,#10*2	; D2 <-- attend 2 secondes maximum40$:	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLAGS:#BWAIT32	JUMP,BC 45$	LIB	?IFCAR		; touche presse ?	JUMP,EQ 44$		; oui => 44$	LOAD.W	D4,#50/10	NTREL	?DELMS		; attend un peu ...	DEC.W	D2	JUMP,NE 40$44$:	LOAD.W	D7,#ERUNCO	; D7 <-- unit pas connecte45$:	PUSH.W	D7	CALL	STOPMIDI	; stoppe tout	POP.W	D7	JUMP,NE 90$	LOAD.W	D7,#ERUNCO	; D7 <-- unit pas (ou mal) connecte	LOAD.L	A4,#(A6)+OBUF	; A4 <-- ^data reu	LOAD.L	D4,(A6)+OLWAIT	; D4 <-- lg data reu50$:	TEST.L	D4		; reste qq chose ?	JUMP,LE 90$		; non => 90$	CLR.L	D3	LOAD.B	D3,(A4)+0	SL.W	D3,#8	LOAD.B	D3,(A4)+1	TEST.W	D3		; temps ?	JUMP,NE 52$		; non => 52$				; oui =>	LOAD.W	D3,#2		; D3 <-- lg pour un temps	JUMP	55$52$:				; objet ?	COMP.W	D3,#LFDX+2-2	JUMP,NE 55$	COMP.B	(A4)+2,#H'F0	; status	JUMP,NE 55$	COMP.B	(A4)+3,#H'43	; ID de Yamaha	JUMP,NE 55$	COMP.B	(A4)+5,#H'04	; format	JUMP,NE 55$	COMP.B	(A4)+6,#H'20	; lg-high	JUMP,NE 55$	COMP.B	(A4)+7,#H'00	; lg-low	JUMP,EQ 60$55$:	ADD.W	D3,#2	ADD.L	A4,D3		; A4 <-- saute objet/temps	SUB.L	D4,D3	JUMP	50$60$:	COMP.L	D4,#LFDX	; est-ce que tout est l ?	JUMP,LO 90$		; non => 90$	LOAD.L	A3,#(A6)+OBUF	; A3 <-- ^dbut du buffer	LOAD.W	D4,#LFDX-170$:	LOAD.B	(A3+),(A4+)	; remonte au dbut du buffer	DECJ.W,NMO D4,70$	CLR.B	(A6)+OBUNAME	; y'a plus de nom !	TSET.B	(A6)+OFLAGS:#BSAJ ; synth  jour	CLR.W	D7		; D7 <-- ok90$:	.ENDIF	.IF	FB01	TSET.B	(A6)+OFLAGS:#BWAIT32	NTREL	?GETPRIO	; D4 <-- priorit	DEC.W	D4	LOAD.L	D5,#600		; D5 <-- lg stack	LOAD.L	A5,#R16"PWAIT8	; A5 <-- ^start	LOAD.L	A3,#R16"NWAIT8	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre la rception	JUMP,NE 90$;;?52$:;;?	LIB	?IFCAR		; vide le fifo du clavier !;;?	JUMP,EQ 52$	LOAD.L	A4,#(A6)+OBMIDI	LOAD.B	(A4)+0,#0	LOAD.B	(A4)+1,#8	LOAD.B	(A4)+2,#H'F0	; system exclusive	LOAD.B	(A4)+3,#H'43	; ID Yamaha	LOAD.B	(A4)+4,#H'75	LOAD.W	D2,(A6)+OCHMIDI	LOAD.B	(A4)+5,D2	; canal systme	LOAD.B	(A4)+6,#H'20	LOAD.B	(A4)+7,#H'01	LOAD.B	(A4)+8,#H'00	LOAD.B	(A4)+9,#H'F7	; EOX	CLR.L	D5	LOAD.W	D5,(A4)	ADD.W	D5,#2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DWRITE		; crit la demande de vidage	JUMP,NE 90$;;?	LOAD.W	D2,#10*2	; D2 <-- attend 2 secondes maximum;;?60$:;;?	CLR.W	D7		; D7 <-- ok;;?	TEST.B	(A6)+OFLAGS:#BWAIT32;;?	JUMP,BC 65$;;?	LIB	?IFCAR		; touche presse ?;;?	JUMP,EQ 64$		; oui => 64$;;?	LOAD.W	D4,#50/10;;?	NTREL	?DELMS		; attend un peu ...;;?	DEC.W	D2;;?	JUMP,NE 60$;;?64$:;;?	LOAD.W	D7,#ERUNCO	; D7 <-- unit pas connecte;;?65$:	LOAD.W	D4,#50/2	NTREL	?DELMS		; attend 0.5 seconde (pour 171 bytes) ...	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLAGS:#BWAIT32	JUMP,BC 65$	LOAD.W	D7,#ERUNCO	; D7 <-- unit pas connecte65$:	PUSH.W	D7	CALL	STOPMIDI	; stoppe toutNTREL ?WFABDESC	; attend la fin des processus fils ;;???????????????????????????	POP.W	D7	JUMP,NE 90$	LOAD.W	D7,#ERUNCO	; D7 <-- unit pas (ou mal) connecte	LOAD.L	A4,#(A6)+OBUF	; A4 <-- ^data reu	LOAD.L	D4,(A6)+OLWAIT	; D4 <-- lg data reu70$:	TEST.L	D4		; reste qq chose ?	JUMP,LE 90$		; non => 90$	CLR.L	D3	LOAD.B	D3,(A4)+0	SL.W	D3,#8	LOAD.B	D3,(A4)+1	TEST.W	D3		; temps ?	JUMP,NE 72$		; non => 72$				; oui =>	LOAD.W	D3,#2		; D3 <-- lg pour un temps	JUMP	75$72$:				; objet ?	COMP.W	D3,#LFDX+2-2	JUMP,NE 75$	COMP.B	(A4)+2,#H'F0	; status	JUMP,NE 75$	COMP.B	(A4)+3,#H'43	; ID de Yamaha	JUMP,NE 75$	COMP.B	(A4)+4,#H'75	JUMP,NE 75$	COMP.B	(A4)+7,#H'01	JUMP,NE 75$	COMP.B	(A4)+9,#H'01	; lg-high	JUMP,NE 75$	COMP.B	(A4)+10,#H'20	; lg-low	JUMP,EQ 80$75$:	ADD.W	D3,#2	ADD.L	A4,D3		; A4 <-- saute objet/temps	SUB.L	D4,D3	JUMP	70$80$:	COMP.L	D4,#LFDX	; est-ce que tout est l ?	JUMP,LO 90$		; non => 90$	LOAD.L	A3,#(A6)+OBUF	; A3 <-- ^dbut du buffer	LOAD.W	D4,#LFDX-182$:	LOAD.B	(A3+),(A4+)	; remonte au dbut du buffer	DECJ.W,NMO D4,82$	LOAD.L	A3,#(A6)+OBUF+11+H'00	LOAD.L	A4,#R16"00$	LOAD.W	D4,#8-184$:	LOAD.B	(A3+),(A4+)	; buffer <-- toujours le nom SMAKY	DECJ.W,NMO D4,84$	CLR.W	D7		; D7 <-- ok90$:	.ENDIF	POPM.L	D2..D5,A3..A5	TEST.W	D7		; retour EQ/NE	RET	.IF	FB0100$:	.ASCII	"  SMAKY "	; nom de la configuration	.EVEN	.ENDIF	.IF	DX7;;;;;;;;;;;;;;;    WAIT    ;;;;;;;;;;;;;;;NWAIT32:.ASCIZ	"MIDI_WAIT32"	.EVENPWAIT32:	LOAD.L	A4,#(A6)+OBUF	LOAD.L	D5,#LFDX+13+2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DREAD	LOAD.L	(A6)+OLWAIT,D5	TCLR.B	(A6)+OFLAGS:#BWAIT32	NTREL	?ABORT	.ENDIF	.IF	DX100;;;;;;;;;;;;;;;    WAIT    ;;;;;;;;;;;;;;;NWAIT32:.ASCIZ	"MIDI_WAIT32"	.EVENPWAIT32:	LOAD.L	A4,#(A6)+OBUF	LOAD.L	D5,#LFDX+4+2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DREAD	LOAD.L	(A6)+OLWAIT,D5	TCLR.B	(A6)+OFLAGS:#BWAIT32	NTREL	?ABORT	.ENDIF	.IF	FB01;;;;;;;;;;;;;;;    WAIT    ;;;;;;;;;;;;;;;NWAIT8:	.ASCIZ	"MIDI_WAIT8"	.EVENPWAIT8:	LOAD.L	A4,#(A6)+OBUF	LOAD.L	D5,#LFDX+4+2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DREAD	LOAD.L	(A6)+OLWAIT,D5	TCLR.B	(A6)+OFLAGS:#BWAIT32	NTREL	?ABORT	.ENDIF;-----------\\; DEFCOMMAND >;===========/; Envoie une commande au driver MIDI pour que les canaux; soient effectivement 1..16 !; in	-; out	D7.W	erreur; mod	D7.WDEFCOMMAND:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,#(A6)+OBUCOM	LOAD.B	(A4)+0,#'M	; <midi>	LOAD.L	A3,#(A4)+1	CLR.B	D3	LOAD.W	D4,#16-110$:	LOAD.B	(A3+),D3	INC.B	D3	DECJ.W,NMO D4,10$	CLR.B	(A4)+16+1	CALL	COMMAND		; commande les canaux midi	JUMP',NE 90$	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'C	; <canaux>	LOAD.W	(A4)+1,#-1	CLR.B	(A4)+3	CALL	COMMAND		; crit tous les canaux90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; COMMAND >;========/; Envoie une commande  MIDI.; in	A4.L	^commande; out	D7.W	erreur; mod	D7.WCOMMAND:	PUSHM.L	D1,D2	LOAD.W	D1,#TYPIO	; D1 <-- type	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DCOMMAND	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; STOPMIDI >;=========/; Stoppe compltement MIDI.; in	-; out	-; mod	D7.WSTOPMIDI:	PUSH.L	D2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DAVOTR		; avort lecture/criture	POP.L	D2	RET;--------\\; OPEMIDI >;========/; Ouvre le driver MIDI.; in	-; out	D7.W	erreur; mod	D7.WOPEMIDI:	PUSHM.L	D2,D3,A2..A4	LOAD.L	A3,#R16"DMIDI	FOS	?UNAMDRIV	; D2 <-- numro de driver	JUMP,NE	90$	LOAD.W	(A6)+ONDMIDI,D2	90$:	POPM.L	D2,D3,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOMIDI >;========/; Ferme le driver MIDI.; in	-; out	-; mod	D7.WCLOMIDI:	RET	.END