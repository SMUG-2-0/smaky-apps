	.SBTTL	PARTDBOX;----------\\; DBOXIMAGE >;==========/; Edite un nom d'image en sortie.; in	A3.L	^nom de l'image; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXIMAGE:	PUSHM.L	D1,D2,D4,A1..A5	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A1,#R16"TICO_IMAGE	LOAD.L	A3,#R16"TDBOX_IOIM	LOAD.L	A4,#R16"TEXIMA	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_EXTRAIT; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOICO	DBOX_	EXTEND		; dbox: attend la rponse ...90$:	POPM.L	D1,D2,D4,A1..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITO:	PUSHM.L	D1,D2,A1..A5	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A1,#R16"TICO_SAUVE	LOAD.L	A2,#R16"TDBOX_SAUVE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXPART	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXT1!2^BDBIOICO	DBOX_	EXTEND		; dbox: attend la rponse ...90$:	POPM.L	D1,D2,A1..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,D4,A1..A5	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A1,#R16"TICO_PREND	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXPART	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOICO	DBOX_	EXTEND		; dbox: attend la rponse ...90$:	POPM.L	D1,D2,D4,A1..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITA >;==========/; Edite un nom de fichier  ajouter.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXEDITA:	PUSHM.L	D1,D2,D4,A1..A5	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A1,#R16"TICO_AJOUTE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXPART	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOICO	DBOX_	EXTEND		; dbox: attend la rponse ...90$:	POPM.L	D1,D2,D4,A1..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande si l'on veut quitter SIGMAP.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXQUITTE:	PUSHM.L	D1,D2,D4,A1..A5	CLR.L	D4		; D4 <-- fanions	LOAD.L	A1,#R16"TICO_QUITTE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#2^BDBIOICO	DBOX_	EXTEND		; dbox: attend la rponse ...90$:	POPM.L	D1,D2,D4,A1..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer la partition.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXEFFACE:	PUSHM.L	D1,D2,D4,A1..A5	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,#(A6)+OBUFILE ; A5 <-- ^nom du fichier	LOAD.L	A1,#R16"TICO_EFFACE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#2^BDBIOICO	DBOX_	EXTEND		; dbox: attend la rponse ...	POPM.L	D1,D2,D4,A1..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXPLAY  >;==========/; Choix de l'coute.; in	-; out	D3.W	dernire touche (F1/F4 coute/mmorise);	D7.W	erreur; mod	D3.L, D7.WDBOXPLAY:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	D4,(A6)+OFAPLAY	LOAD.L	A2,#R16"TDBOX_PLAY	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	CALL	DBOXSCROLL	; affiche l'ascenseur-vitesse	LOAD.W	D2,#2		; D2 <-- ODBCLINE slectionn05$:	PUSH.W	D2	LOAD.L	A2,#R16"00$	CLR.W	D110$:	LOAD.W	D2,(A2+)	; D2 <-- rang	JUMP',EQ 15$	PUSH.L	D4	DBOX_	GETCO	POP.L	D4	LIB	?SETCURS	LOAD.W	D2,D1	CALL	DBPLAYGLI	LIB	?AFTEXT		; affiche le contenu d'un ODBCLINE	INC.W	D1	JUMP	10$15$:	POP.W	D220$:	LOAD.W	D3,D2	DBOX_	MEDIT		; slectionne le bon ODBCLINE	CALL	DBPLAYGLI	; A3/A4 <-- ^ligne  diter	DBOX_	EDIT		; attend une action ...	CALL	DBPLAYPLI	; mj ligne  diter	LOAD.L	A1,#R16"TKEY_PLAY	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#KEYMGP	JUMP,EQ 70$	COMP.W	D3,#KEYDBOX+BFANME+1	JUMP,EQ 40$	COMP.W	D3,#KEYDBOX+BFANME+2	JUMP,EQ 41$	COMP.W	D3,#KEYDBOX+BFAPLAY+0	JUMP,LO 24$	COMP.W	D3,#KEYDBOX+BFAPLAY+6	JUMP,LO 42$24$:	COMP.W	D3,#CR	JUMP,EQ 43$	COMP.W	D3,#KEYDBOX+BFA1VPP	JUMP,EQ 50$	COMP.W	D3,#KEYDBOX+BFA2VPP	JUMP,EQ 51$	COMP.W	D3,#KEYDBOX+BFA1ME	JUMP,EQ 52$	COMP.W	D3,#KEYDBOX+BFANME	JUMP,EQ 53$	COMP.W	D3,#KEYDBOX+BFARME	JUMP,EQ 54$	COMP.W	D3,#KEYDBOX+BFASYNT	JUMP,EQ 60$	COMP.W	D3,#F1		; (ECOUTE) ?	JUMP,EQ 80$	COMP.W	D3,#F4		; (MEMORISE) ?	JUMP,EQ 80$30$:				; touche inconnue =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:	CLR.W	D2		; D2 <-- rang ODBCLINE (mesure de ..)	TEST.L	D4:#BFANME	JUMP,BS 20$	TCLR.L	D4:#BFA1ME	TCLR.L	D4:#BFARME	TSET.L	D4:#BFANME	JUMP	05$41$:	LOAD.W	D2,#1		; D2 <-- rang ODBCLINE (mesure  ..)	TEST.L	D4:#BFANME	JUMP,BS 20$	TCLR.L	D4:#BFA1ME	TCLR.L	D4:#BFARME	TSET.L	D4:#BFANME	JUMP	05$42$:	SUB.W	D3,#KEYDBOX-2	LOAD.W	D2,D3		; D2 <-- rang ODBCLINE (canal MIDI)	JUMP	20$43$:	INC.W	D2		; D2 <-- rang ODBCLINE suivant	COMP.W	D2,#2+6	JUMP,LO 20$	LOAD.W	D2,#2	TEST.L	D4:#BFANME	JUMP,BC 20$	CLR.W	D2	JUMP	20$50$:	TCLR.L	D4:#BFA2VPP	TSET.L	D4:#BFA1VPP	JUMP	20$51$:	TCLR.L	D4:#BFA1VPP	TSET.L	D4:#BFA2VPP	JUMP	20$52$:	TCLR.L	D4:#BFANME	TCLR.L	D4:#BFARME	TSET.L	D4:#BFA1ME	COMP.W	D2,#2	JUMP,HS 05$	LOAD.W	D2,#2	JUMP	05$53$:	TCLR.L	D4:#BFA1ME	TCLR.L	D4:#BFARME	TSET.L	D4:#BFANME	CLR.W	D2		; D2 <-- rang ODBCLINE (mesure de ..)	JUMP	05$54$:	TCLR.L	D4:#BFANME	TCLR.L	D4:#BFA1ME	TSET.L	D4:#BFARME	COMP.W	D2,#2	JUMP,HS 05$	LOAD.W	D2,#2	JUMP	05$60$:	CLR.W	D3		; D3 <-- canal 1 si synth	TEST.L	D4:#BFASYNT	JUMP',BS 61$	LOAD.W	D3,#16-1	; D3 <-- canal S si Smaky61$:	LOAD.L	A4,#(A6)+OTRACK	LOAD.W	D1,#NBTRACK-162$:	LOAD.W	(A4)+OTMIDI,D3	LOAD.L	A4,#(A4)+LT	DECJ.W,NMO D1,62$	JUMP	05$		; mj l'affichage des canaux MIDI70$:	PUSH.L	D4	LIB	?IFMOUSE	LOAD.L	D3,D4	POP.L	D4	TEST.W	D7	JUMP,NE 30$	SUB.W	D3,(A0)+ODFFX	JUMP,LO 30$	SWAP.W	D3	SUB.W	D3,(A0)+ODFFY	; D3 <-- position souris dans swdo	JUMP,LO 30$	SWAP.W	D3	PUSHM.L	D4,A5	LOAD.L	D4,D3	LOAD.L	A5,#(A6)+OASVIT	; A5 <-- ^variables ascenseur-vitesse	LOAD.W	(A5)+OSCINC,#2*MAXVIT/10	SCROLL_	MOVE		; dplace la cabine de l'ascenseur	POPM.L	D4,A5	JUMP,NE 30$	JUMP	20$80$:	LOAD.L	(A6)+OFAPLAY,D4	DBOX_	CLOSE		; ferme la DBOX	CALL	STARTSTOPREAD	; start/stop processus de lecture MIDI90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET00$:				; rangs des ODBCLINEs :	.W	6,8,14,16,19,21,24,26,0;----------\\; DBPLAYGLI >;----------/; Construit la chane  diter.; in	D2.W	rang de la ligne  diter;	D4.L	fanions; out	A3.L	^dbut de la ligne;	A4.L	^fin de la ligne; mod	D7.W, A3.L, A4.LDBPLAYGLI:	PUSHM.L	D2..D4	COMP.W	D2,#2	JUMP',HS 05$	TEST.L	D4:#BFANME	JUMP,BC 60$05$:	CLR.L	D4	LOAD.W	D4,(A6)+OPLPME	COMP.W	D2,#0	JUMP',EQ 10$	LOAD.W	D4,(A6)+OPLDME	COMP.W	D2,#1	JUMP',EQ 10$	SUB.W	D2,#2	MUL.WU	D2,#LT	LOAD.L	A4,#(A6)+OTRACK	LOAD.W	D4,(A4)+(D2.W)+OTMIDI	LOAD.W	D2,#210$:	LOAD.L	A4,#(A6)+OBUNUM	INC.W	D4		; D4 <-- 1..n	COMP.W	D2,#2	JUMP',LO 15$	COMP.W	D4,#16	JUMP',NE 15$	LOAD.B	(A4+),#'S	JUMP	80$15$:	LIB	?BINBCD		; D4 <-- nombre en BCD	LOAD.L	D2,#8-1		; D2 <-- nb max de digits20$:	RL.L	D4,#4	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- digit 0..9	JUMP',NE 30$	TEST.W	D2		; dernier digit ?	JUMP',EQ 30$		; oui => 30$	TEST.L	D2:#16	JUMP',BC 50$30$:	ADD.B	D3,#'0	LOAD.B	(A4+),D3	TSET.L	D2:#1650$:	DECJ.W,NMO D2,20$	JUMP'	80$60$:	LOAD.L	A4,#(A6)+OBUNUM	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE80$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUNUM	POPM.L	D2..D4	RET;----------\\; DBPLAYPLI >;----------/; Met  jour la chane dite.; in	D2.W	rang de la ligne  diter;	A3.L	^dbut de la ligne; mod	D7.WDBPLAYPLI:	PUSHM.L	D2..D4,A3	CLR.L	D410$:	CLR.W	D3	LOAD.B	D3,(A3+)	JUMP',EQ 40$	COMP.B	D3,#CR	JUMP',EQ 40$	COMP.B	D3,#'S	JUMP',EQ 30$	COMP.B	D3,#'s	JUMP',EQ 30$	COMP.B	D3,#'0	JUMP,LO 90$	COMP.B	D3,#'9	JUMP,HI 90$	SUB.B	D3,#'0	MUL.WU	D4,#10	ADD.W	D4,D3	JUMP	10$30$:	LOAD.W	D4,#16		; D4 <-- no de canal du Smaky40$:	LOAD.L	A3,#(A6)+OPLPME	COMP.W	D2,#0	JUMP',EQ 50$	LOAD.L	A3,#(A6)+OPLDME	COMP.W	D2,#1	JUMP',EQ 50$	SUB.W	D2,#2	MUL.WU	D2,#LT	LOAD.L	A3,#(A6)+OTRACK+OTMIDI	ADD.L	A3,D250$:	TEST.W	D4	JUMP',EQ 60$	DEC.W	D4		; D4 <-- 0..n60$:	LOAD.W	(A3),D4		; mj le nombre90$:	POPM.L	D2..D4,A3	RET;-----------\\; DBOXSCROLL >;-----------/; Affiche l'ascenseur pour le contrle de la vitesse.; in	-; out	-; mod	D7.WDBOXSCROLL:	PUSHM.L	D3..D5,A3,A5	LOAD.L	A5,#(A6)+OASVIT	; A5 <-- ^variables ascenseur-vitesse	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#1	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#62	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A0)+ODFFDY	SUB.W	D4,(A0)+ODFCY	SUB.W	D4,(A0)+ODFCY	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCMARK	SCROLL_	DRAW		; dessine la cage de l'ascenseur	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur	LOAD.L	A3,#R16"TXSCALE	; A3 <-- ^textes	LOAD.W	D4,#10		; D4 <-- longueur	LOAD.W	D3,#2		; D3 <-- nombre	SCROLL_	SCALE	LOAD.L	A3,#0		; A3 <-- pas de textes	LOAD.W	D4,#3		; D4 <-- longueur	LOAD.W	D3,#10		; D3 <-- nombre	SCROLL_	SCALE	POPM.L	D3..D5,A3,A5	RET;----------\\; DBOXPRINT >;==========/; Choix de l'impression.; in	-; out	D3.W	dernire touche (F1/F4/F0 imprime/vrifie/annule);	D7.W	erreur; mod	D3.L, D7.WDBOXPRINT:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	D4,(A6)+OFAPRI	LOAD.L	A2,#R16"TDBOX_PRINT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	CLR.W	D2		; D2 <-- ODBCLINE slectionn10$:	PUSH.W	D2	CLR.W	D212$:	CALL	DBPRINTALI	; affiche une ligne ditable	INC.W	D2	COMP.W	D2,#3+2	JUMP,LO 12$	POP.W	D220$:	CALL	DBPRINTGLI	; A3/A4 <-- ^ligne  diter22$:	LOAD.W	D3,D2	DBOX_	MEDIT		; slectionne le bon ODBCLINE	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_PRINT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	22$		; oui => 22$	COMP.W	D3,#F1		; (IMPRIME) ?	JUMP,EQ 80$	COMP.W	D3,#F4		; (VERIFIE) ?	JUMP,EQ 80$	COMP.W	D3,#F7		; (CHOIX) ?	JUMP,EQ 80$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP,EQ 80$	COMP.W	D3,#CR	JUMP,EQ 45$	COMP.W	D3,#UNDO	JUMP,EQ 50$	COMP.W	D3,#KEYDBOX+BFAITOUT	JUMP,EQ 46$	COMP.W	D3,#KEYDBOX+BFAIDEA	JUMP,EQ 47$	COMP.W	D3,#KEYDBOX+BFAIFULL	JUMP,EQ 60$	COMP.W	D3,#KEYDBOX+BFAIJUD	JUMP,EQ 62$	COMP.W	D3,#KEYDBOX+100	JUMP',LO 30$	COMP.W	D3,#KEYDBOX+104	JUMP',LS 40$30$:				; touche inconnue =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	22$40$:	CALL	DBPRINTPLI	; mj ligne  diter	CALL	DBPRINTALI	; affiche la ligne	AND.W	D3,#H'FF	SUB.W	D3,#100	LOAD.W	D2,D3		; D2 <-- nouveau rang ODBCLINE42$:	COMP.W	D2,#3	JUMP,LO 20$	COMP.W	D2,#4	JUMP,HI 20$				; de ...  ... =>	TCLR.L	D4:#BFAITOUT	TSET.L	D4:#BFAIDEA	JUMP,BC 10$		; si bit chang => raffiche	JUMP	20$45$:				; RETURN =>	CALL	DBPRINTPLI	; mj ligne  diter	CALL	DBPRINTALI	; affiche la ligne	INC.W	D2		; D2 <-- rang ODBCLINE suivant	COMP.W	D2,#3+2	JUMP,LO 42$	CLR.W	D2	JUMP	42$46$:	COMP.W	D2,#3	JUMP,LO 22$	COMP.W	D2,#4	JUMP,HI 22$	CALL	DBPRINTPLI	; mj ligne  diter	CALL	DBPRINTALI	; affiche la ligne	CLR.W	D2		; D2 <-- rang ODBCLINE (titre)	JUMP	10$47$:	CALL	DBPRINTPLI	; mj ligne  diter	CALL	DBPRINTALI	; affiche la ligne	LOAD.W	D2,#3		; D2 <-- rang ODBCLINE (mesure de ..)	JUMP	10$50$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A3)	JUMP	22$60$:				; dernire porte complte =>	TCLR.L	D4:#BFAIJUD	JUMP	22$62$:				; justifie la dernire ligne =>	TCLR.L	D4:#BFAIFULL	JUMP	22$80$:				; D'ACCORD/ANNULE =>	CALL	DBPRINTPLI	; mj ligne  diter	CALL	DBPRINTALI	; affiche la ligne	LOAD.L	(A6)+OFAPRI,D4	DBOX_	CLOSE		; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBPRINTALI >;-----------/; Affiche la chane dite.; in	D2.W	rang de la ligne  diter;	D4.L	fanions; out	-; mod	D7.WDBPRINTALI:	PUSHM.L	D0..D4,A3,A4	CALL	DBPRINTGLI	; A3 <-- ^chane	LOAD.L	D0,D4		; D0 <-- fanions	LOAD.W	D1,D2		; D1 <-- rang de la ligne	TSET.L	D2:#BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D4,#32		; D4 <-- lg max	COMP.W	D1,#3	JUMP',LO 20$	LOAD.W	D4,#5		; D4 <-- lg max20$:	LOAD.L	A4,#(A6)+OBDIS	LOAD.W	D2,D4	COMP.W	D1,#3	JUMP',LO 30$	COMP.W	D1,#4	JUMP',HI 30$	TEST.L	D0:#BFAIDEA	; fanion "de ..  .." allum ?	JUMP',BC 40$		; non => 40$30$:	LOAD.B	D3,(A3+)	JUMP',EQ 40$	COMP.B	D3,#CR	JUMP',EQ 40$	LOAD.B	(A4+),D3	; buffer <-- chane	DEC.W	D2	JUMP,NE 30$	JUMP'	50$40$:	LOAD.B	(A4+),#SPACE	; buffer <-- bourre la fin d'espaces	DEC.W	D2	JUMP,NE 40$50$:	LOAD.L	A3,#(A6)+OBDIS	LOAD.W	D3,D4	LIB	?STRING		; affiche la chane	POPM.L	D0..D4,A3,A4	RET;-----------\\; DBPRINTGLI >;-----------/; Construit la chane  diter.; in	D2.W	rang de la ligne  diter;	D4.L	fanions; out	A3.L	^dbut de la ligne;	A4.L	^fin de la ligne; mod	D7.W, A3.L, A4.LDBPRINTGLI:	PUSHM.L	D2..D4	LOAD.L	A4,#(A6)+OBUNUM	LOAD.L	A3,#(A6)+OIMTM	; A3 <-- titre	TEST.W	D2	JUMP,EQ 70$	LOAD.L	A3,#(A6)+OIMEM	; A3 <-- diteur	COMP.W	D2,#1	JUMP,EQ 70$	LOAD.L	A3,#(A6)+OIMAM	; A3 <-- auteur	COMP.W	D2,#2	JUMP,EQ 70$	LOAD.W	D4,(A6)+OIMFM	COMP.W	D2,#3	JUMP',EQ 10$	LOAD.W	D4,(A6)+OIMLM10$:	AND.L	D4,#H'FFFF	LIB	?BINBCD		; D4 <-- nombre en BCD	LOAD.L	D2,#8-1		; D2 <-- nb max de digits20$:	RL.L	D4,#4	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- digit 0..9	JUMP',NE 30$	TEST.W	D2		; dernier digit ?	JUMP',EQ 30$		; oui => 30$	TEST.L	D2:#16	JUMP',BC 50$30$:	ADD.B	D3,#'0	LOAD.B	(A4+),D3	TSET.L	D2:#1650$:	DECJ.W,NMO D2,20$	JUMP'	80$70$:	LOAD.B	D3,(A3+)	JUMP',EQ 80$	COMP.B	D3,#CR	JUMP',EQ 80$	LOAD.B	(A4+),D3	JUMP	70$80$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUNUM	POPM.L	D2..D4	RET;-----------\\; DBPRINTPLI >;-----------/; Met  jour la chane dite.; in	D2.W	rang de la ligne  diter;	A3.L	^dbut de la ligne; mod	D7.WDBPRINTPLI:	PUSHM.L	D0..D4,A3,A4	LOAD.L	A4,#(A6)+OIMTM	; A4 <-- ^buffer pour titre	TEST.W	D2	JUMP,EQ 60$	LOAD.L	A4,#(A6)+OIMEM	; A4 <-- ^buffer pour diteur	COMP.W	D2,#1	JUMP,EQ 60$	LOAD.L	A4,#(A6)+OIMAM	; A4 <-- ^buffer pour auteur	COMP.W	D2,#2	JUMP,EQ 60$	CLR.L	D410$:	CLR.W	D3	LOAD.B	D3,(A3+)	JUMP',EQ 20$	COMP.B	D3,#CR	JUMP',EQ 20$	COMP.B	D3,#'0	JUMP,LO 90$	COMP.B	D3,#'9	JUMP,HI 90$	SUB.B	D3,#'0	MUL.WU	D4,#10	ADD.W	D4,D3	JUMP	10$20$:	LOAD.W	D0,#1		; D0 <-- min	LOAD.W	D1,#999		; D1 <-- max	LOAD.L	A3,#(A6)+OIMFM	COMP.W	D2,#3	JUMP',EQ 40$;	LOAD.W	D0,#1;	LOAD.W	D1,#999	LOAD.L	A3,#(A6)+OIMLM40$:	COMP.W	D4,D0		; trop petit ?	JUMP',HS 42$	LOAD.W	D4,D042$:	COMP.W	D4,D1		; trop grand ?	JUMP',LS 44$	LOAD.W	D4,D144$:	LOAD.W	(A3),D4		; mj le nombre	JUMP'	90$60$:	LOAD.B	D3,(A3+)	JUMP',EQ 65$	COMP.B	D3,#CR	JUMP',EQ 65$	LOAD.B	(A4+),D3	; mj la chane	JUMP	60$65$:	CLR.B	(A4)90$:	POPM.L	D0..D4,A3,A4	RET;---------\\; DBOXCOPY >;=========/; Choix de la copie.; in	-; out	D3.W	dernire touche (F1/F0 d'accord/annule);	D7.W	erreur; mod	D3.L, D7.WDBOXCOPY:	PUSHM.L	D1,D2,D4,D5,A1..A4	TEST.W	(A6)+OCPMDE	JUMP',NE 01$	INC.W	(A6)+OCPMDE01$:	TEST.W	(A6)+OCPMA	JUMP',NE 02$	INC.W	(A6)+OCPMA02$:	TEST.W	(A6)+OCPMOU	JUMP',NE 03$	INC.W	(A6)+OCPMOU03$:	LOAD.L	D4,(A6)+OFACOP	; D4 <-- fanions	JUMP',NE 04$	TSET.L	D4:#BFACDUP	TSET.L	D4:#BFACMOU	; D4 <-- fanion par dfaut04$:	LOAD.L	A2,#R16"TDBOX_COPY	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	CLR.W	D2		; D2 <-- ODBCLINE slectionn05$:	PUSH.W	D2	LOAD.L	A2,#R16"00$	CLR.W	D110$:	LOAD.W	D2,(A2+)	; D2 <-- rang	JUMP',EQ 15$	PUSH.L	D4	DBOX_	GETCO	POP.L	D4	LIB	?SETCURS	LOAD.W	D2,D1	CALL	DBCOPYGLI	LIB	?AFTEXT		; affiche le contenu d'un ODBCLINE	INC.W	D1	JUMP	10$15$:	POP.W	D2	CALL	DBCOPYDDD	; affiche dtruit/dplace/duplique20$:	LOAD.W	D3,D2	DBOX_	MEDIT		; slectionne le bon ODBCLINE	CALL	DBCOPYGLI	; A3/A4 <-- ^ligne  diter	DBOX_	EDIT		; attend une action ...	CALL	DBCOPYPLI	; mj ligne  diter	LOAD.L	A1,#R16"TKEY_COPY	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; (D'ACCORD) ?	JUMP,EQ 70$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP,EQ 80$	COMP.W	D3,#CR	JUMP,EQ 42$	COMP.W	D3,#UNDO	JUMP,EQ 48$	COMP.W	D3,#KEYDBOX+BFACDET	JUMP,EQ 50$	COMP.W	D3,#KEYDBOX+BFACDEP	JUMP,EQ 52$	COMP.W	D3,#KEYDBOX+BFACDUP	JUMP,EQ 52$	COMP.W	D3,#KEYDBOX+BFACMOU	JUMP,EQ 54$	COMP.W	D3,#KEYDBOX+BFACDEB	JUMP,EQ 56$	COMP.W	D3,#KEYDBOX+BFACFIN	JUMP,EQ 56$	COMP.W	D3,#KEYDBOX+100+0	JUMP',LO 30$	COMP.W	D3,#KEYDBOX+100+2	JUMP',LS 40$30$:				; touche inconnue =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; KEYDBOX =>	AND.W	D3,#H'FF	SUB.W	D3,#100	LOAD.W	D2,D3		; D2 <-- nouveau rang ODBCLINE	JUMP'	44$42$:				; RETURN =>	INC.W	D2		; D2 <-- rang ODBCLINE suivant	COMP.W	D2,#3	JUMP',LO 44$	CLR.W	D244$:	COMP.W	D2,#2	JUMP,EQ 54$	JUMP	20$48$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A3)	CALL	DBCOPYPLI	; mj ligne  diter	JUMP	20$50$:				; fanion dtruit =>	TSET.L	D4:#BFACDET	TCLR.L	D4:#BFACDEP	TCLR.L	D4:#BFACDUP	TCLR.L	D4:#BFACMOU	TCLR.L	D4:#BFACDEB	TCLR.L	D4:#BFACFIN	COMP.W	D2,#2	JUMP,NE 05$	CLR.W	D2	JUMP	05$52$:				; fanion dplace/duplique =>	TCLR.L	D4:#BFACDET	TCLR.L	D4:#BFACDEP	TCLR.L	D4:#BFACDUP	TSET.L	D4:D3	TEST.L	D4:#BFACMOU	JUMP,BS 05$	TEST.L	D4:#BFACDEB	JUMP,BS 05$	TEST.L	D4:#BFACFIN	JUMP,BS 05$	TSET.L	D4:#BFACMOU	LOAD.W	D2,#2	JUMP	05$54$:				; fanion avant =>	TSET.L	D4:#BFACMOU	TCLR.L	D4:#BFACDEB	TCLR.L	D4:#BFACFIN	LOAD.W	D2,#2	JUMP'	58$56$:				; fanion dbut/fin =>	TCLR.L	D4:#BFACMOU	TCLR.L	D4:#BFACDEB	TCLR.L	D4:#BFACFIN	TSET.L	D4:D3	COMP.W	D2,#2	JUMP',NE 58$	CLR.W	D258$:	TCLR.L	D4:#BFACDET	; dtruit ?	JUMP,BC 05$		; non => 05$	TSET.L	D4:#BFACDUP	; oui => met duplique !	JUMP	05$70$:				; D'ACCORD =>	LOAD.W	D1,(A6)+OCPMA	COMP.W	D1,(A6)+OCPMDE	JUMP,LO 30$	COMP.W	D1,(A6)+OMESM	JUMP,HI 30$	TEST.L	D4:#BFACDET	; dtruit ?	JUMP',BS 75$		; oui => 75$	TEST.L	D4:#BFACMOU	; avant la mesure .. ?	JUMP',BC 75$		; non => 75$	LOAD.W	D1,(A6)+OCPMOU	COMP.W	D1,(A6)+OCPMDE	JUMP',LS 75$	COMP.W	D1,(A6)+OCPMA	JUMP,LS 30$75$:	LOAD.L	(A6)+OFACOP,D480$:				; ANNULE =>	DBOX_	CLOSE		; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET00$:				; rangs des ODBCLINEs :	.W	1,3,6,0;----------\\; DBCOPYGLI >;----------/; Construit la chane  diter.; in	D2.W	rang de la ligne  diter;	D4.L	fanions; out	A3.L	^dbut de la ligne;	A4.L	^fin de la ligne; mod	D7.W, A3.L, A4.LDBCOPYGLI:	PUSHM.L	D2..D4	LOAD.L	A4,#(A6)+OBUNUM	COMP.W	D2,#2	JUMP',NE 05$	TEST.L	D4:#BFACDET	JUMP,BS 60$	TEST.L	D4:#BFACDEB	JUMP,BS 60$	TEST.L	D4:#BFACFIN	JUMP,BS 60$05$:	CLR.L	D4	LOAD.W	D4,(A6)+OCPMDE	TEST.W	D2	JUMP',EQ 10$	LOAD.W	D4,(A6)+OCPMA	DEC.W	D2	JUMP',EQ 10$	LOAD.W	D4,(A6)+OCPMOU10$:	LIB	?BINBCD		; D4 <-- nombre en BCD	LOAD.L	D2,#8-1		; D2 <-- nb max de digits20$:	RL.L	D4,#4	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- digit 0..9	JUMP',NE 30$	TEST.W	D2		; dernier digit ?	JUMP',EQ 30$		; oui => 30$	TEST.L	D2:#16	JUMP',BC 50$30$:	ADD.B	D3,#'0	LOAD.B	(A4+),D3	TSET.L	D2:#1650$:	DECJ.W,NMO D2,20$	JUMP'	80$60$:	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE80$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUNUM	POPM.L	D2..D4	RET;----------\\; DBCOPYPLI >;----------/; Met  jour la chane dite.; in	D2.W	rang de la ligne  diter;	A3.L	^dbut de la ligne; mod	D7.WDBCOPYPLI:	PUSHM.L	D2..D4,A3	CLR.L	D410$:	CLR.W	D3	LOAD.B	D3,(A3+)	JUMP',EQ 40$	COMP.B	D3,#CR	JUMP',EQ 40$	COMP.B	D3,#'0	JUMP,LO 90$	COMP.B	D3,#'9	JUMP,HI 90$	SUB.B	D3,#'0	MUL.WU	D4,#10	ADD.W	D4,D3	JUMP	10$40$:	LOAD.L	A3,#(A6)+OCPMDE	TEST.W	D2	JUMP',EQ 50$	LOAD.L	A3,#(A6)+OCPMA	DEC.W	D2	JUMP',EQ 50$	LOAD.L	A3,#(A6)+OCPMOU50$:	LOAD.W	(A3),D4		; mj le nombre90$:	POPM.L	D2..D4,A3	RET;----------\\; DBCOPYDDD >;----------/; Affiche dtruit/dplace ou duplique.; in	D4.L	fanions; out	-; mod	D7.WDBCOPYDDD:	PUSHM.L	D2..D4,A3	LOAD.L	A3,#R16"01$	TEST.L	D4:#BFACDET	JUMP',BS 20$	LOAD.L	A3,#R16"02$	TEST.L	D4:#BFACDEP	JUMP',BS 20$	LOAD.L	A3,#R16"03$20$:	LOAD.W	D2,#0	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; ddd la mesure ..  ..	LOAD.W	D2,#11	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; DDD dans D'ACCORD	POPM.L	D2..D4,A3	RET01$:	.ASCIZ	" Dtruit"	.ASCIZ	" DETRUIT  "02$:	.ASCIZ	" Dplace"	.ASCIZ	" DEPLACE  "03$:	.ASCIZ	"Duplique"	.ASCIZ	" DUPLIQUE "	.EVEN;----------\\; DBOXTRANS >;==========/; Choix de la transposition.; in	-; out	D3.W	dernire touche (F1/F0 d'accord/annule);	D7.W	erreur; mod	D3.L, D7.WDBOXTRANS:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	D4,(A6)+OFATRA	; D4 <-- fanions	JUMP',NE 02$	TSET.L	D4:#BFATUP	TSET.L	D4:#BFAT0	TSET.L	D4:#BFATIDEM	TSET.L	D4:#BFATBEMOL	; D4 <-- fanions par dfaut02$:	LOAD.L	(A6)+OFATRA,D4	LOAD.L	A2,#R16"TDBOX_TRANS	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$10$:	CALL	DBTRAFAL	; affiche le nb de "#" ou "b"	CALL	DBTRAFDT	; affiche le nb de demi-tons20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_TRANS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; (D'ACCORD) ?	JUMP,EQ 80$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP,EQ 80$	COMP.W	D3,#'0		; chiffre ?	JUMP',LO 30$	COMP.W	D3,#'7	JUMP,LS 50$	LOAD.L	D2,#H'FFFFFF00	COMP.W	D3,#KEYDBOX+BFAT0	JUMP',LO 30$	COMP.W	D3,#KEYDBOX+BFAT7	JUMP',LS 40$	LOAD.L	D2,#H'FFFF00FF	COMP.W	D3,#KEYDBOX+BFATUP	JUMP',LO 30$	COMP.W	D3,#KEYDBOX+BFATDOWN	JUMP',LS 40$	LOAD.L	D2,#H'FF00FFFF	COMP.W	D3,#KEYDBOX+BFATIDEM	JUMP',LO 30$	COMP.W	D3,#KEYDBOX+BFATM1	JUMP',LS 40$	LOAD.L	D2,#H'00FFFFFF	COMP.W	D3,#KEYDBOX+BFATDIESE	JUMP',LO 30$	COMP.W	D3,#KEYDBOX+BFATBEMOL	JUMP',LS 40$30$:				; touche inconnue =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; cercle =>	AND.L	D4,D2		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon	LOAD.L	(A6)+OFATRA,D4	JUMP	10$50$:				; chiffre =>	SUB.W	D3,#'0	LOAD.W	(A6)+OFATNB,D3	; mj. nb de "#" ou "b"	JUMP	10$80$:				; D'ACCORD/ANNULE =>	DBOX_	CLOSE		; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBTRAFAL >;---------/; Affiche l'altration.; in	D5.L	canal DBOX; out	-; mod	D7.WDBTRAFAL:	PUSHM.L	D2..D4	LOAD.W	D2,#20	DBOX_	GETCO	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A6)+OFATNB	LOAD.W	D3,#2	CLR.W	D2	LIB	?AFDEC		; affiche le nombre	POPM.L	D2..D4	RET;---------\\; DBTRAFDT >;---------/; Affiche le nombre de demi-tons.; in	D5.L	canal DBOX; out	-; mod	D7.WDBTRAFDT:	PUSHM.L	D2..D5	LOAD.W	D2,#4	DBOX_	GETCO	LIB	?SETCURS	CALL	GETDBOXTRANS	; D2..D5 <-- paramtres	CALL	AFDEC2N	POPM.L	D2..D5	RET;----------\\; DBOXTONAL >;==========/; Choix de la transposition selon une tonalit.; in	-; out	D3.W	dernire touche (F1/F0 d'accord/annule);	D7.W	erreur; mod	D3.L, D7.WDBOXTONAL:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	D4,(A6)+OFATON	; D4 <-- fanions	JUMP',NE 05$	LOAD.L	D4,#1		; D4 <-- tonalit "do" par dfaut05$:	LOAD.L	A2,#R16"TDBOX_TONAL	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	PUSH.L	D4	LOAD.W	D2,#1	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LOAD.B	D2,(A4)+OMETA	; D2 <-- #/b	LOAD.B	D3,(A4)+OMENA	; D3 <-- 0..7	CALL	GETTONAL	; A3 <-- ^nom de la tonalit	LIB	?AFTEXT		; affiche la tonalit actuelle	POP.L	D410$:	CALL	DBTOMAJ	CALL	DBTOAFF		; affiche le nb de demi-tons20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_TONAL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; (D'ACCORD) ?	JUMP,EQ 70$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP,EQ 80$	COMP.W	D3,#KEYDBOX+0	JUMP',LO 30$	COMP.W	D3,#KEYDBOX+24	JUMP',LO 40$	COMP.W	D3,#KEYDBOX+BFATOP1	JUMP',EQ 50$	COMP.W	D3,#KEYDBOX+BFATOM1	JUMP',EQ 52$30$:				; touche inconnue =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; cercle tonalit =>	AND.L	D4,#H'FF000000	TSET.L	D4:D3	JUMP	10$50$:				; carr + une octave =>	TCLR.L	D4:#BFATOM1	JUMP	10$52$:				; carr - une octave =>	TCLR.L	D4:#BFATOP1	JUMP	10$70$:				; D'ACCORD =>	CALL	DBTOMAJ80$:				; ANNULE =>	DBOX_	CLOSE		; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBTOMAJ >;--------/; Met  jour en fonction des fanions.; in	A4.L		fanions; out	(A6)+OTOTA.B	#/b;	(A6)+OTONA.B	0..7;	(A6)+OFATON.L	fanions; mod	D7.WDBTOMAJ:	PUSHM.L	D4,A4	LOAD.L	(A6)+OFATON,D4	LOAD.L	A4,#R16"TABLE_TONAL-220$:	ADD.L	A4,#2	RR.L	D4,#1	JUMP,CC 20$	LOAD.B	(A6)+OTOTA,(A4+)	LOAD.B	(A6)+OTONA,(A4+)	POPM.L	D4,A4	RET;--------\\; DBTOAFF >;--------/; Affiche le nombre de demi-tons.; in	-; out	-; mod	D7.WDBTOAFF:	PUSHM.L	D2..D5	LOAD.W	D2,#16	DBOX_	GETCO	LIB	?SETCURS	CALL	GETDBOXTONAL	; D2..D5 <-- paramtres	CALL	AFDEC2N	POPM.L	D2..D5	RET;------------\\; DBOXREPRISE >;============/; Choix des signes de reprise.; in	D4.L	signes de reprise; out	D3.W	dernire touche (F1/F0 d'accord/annule);	D4.L	signes de reprise;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXREPRISE:	PUSHM.L	D0..D2,D5,A1..A4	LOAD.L	D0,D4		; D0 <-- fanions	LOAD.L	A2,#R16"TDBOX_REPRISE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.W	D2,#16	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#26	DBOX_	GETCO	LOAD.L	D4,D3	POP.L	D3	SUB.W	D3,(A0)+ODFCX	ADD.W	D4,(A0)+ODFCX	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,#6	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#3	SUB.W	D4,D3	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine rectangle autour de "saute" et "ici"	LOAD.W	D1,(A0)+ODFCX	MUL.WU	D1,#3		; D1 <-- dcalage  droite pour les icnes	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT2,0	.EVEN	LOAD.L	A3,#R16"TAICO_REPRISE-210$:	ADD.L	A3,#2	CLR.W	D2	LOAD.B	D2,(A3)+0	; D2 <-- rang dans DBOX	COMP.B	D2,#-1		; fin de la table ?	JUMP',EQ 15$		; oui => 15$	DBOX_	GETCO	ADD.W	D3,D1	LIB	?SETCURS	LOAD.B	D3,(A3)+1	; D3 <-- code de l'icne	LIB	?AFCAR		; affiche l'icne	JUMP	10$15$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0	.EVEN	LOAD.L	D4,D0		; D4 <-- fanions20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_REPRISE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; (D'ACCORD) ?	JUMP,EQ 80$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP,EQ 80$	COMP.W	D3,#KEYDBOX+BREPDBP	JUMP,EQ 40$	COMP.W	D3,#KEYDBOX+BREPDB	JUMP,EQ 41$	COMP.W	D3,#KEYDBOX+BREPBDP	JUMP,EQ 42$	COMP.W	D3,#KEYDBOX+BREPBD	JUMP,EQ 43$	COMP.W	D3,#KEYDBOX+BREPBB	JUMP,EQ 44$	COMP.W	D3,#KEYDBOX+BREPRENVOI1	JUMP,EQ 50$	COMP.W	D3,#KEYDBOX+BREPRENVOI2	JUMP,EQ 51$	COMP.W	D3,#KEYDBOX+BREPCODA1	JUMP,EQ 52$	COMP.W	D3,#KEYDBOX+BREPCODA2	JUMP,EQ 53$	COMP.W	D3,#KEYDBOX+BREPDC	JUMP,EQ 54$	COMP.W	D3,#KEYDBOX+BREPFIN	JUMP,EQ 55$	COMP.W	D3,#KEYDBOX+BREPPART1	JUMP,EQ 60$	COMP.W	D3,#KEYDBOX+BREPPART2	JUMP,EQ 61$	COMP.W	D3,#KEYDBOX+BREPPART3	JUMP,EQ 62$	COMP.W	D3,#KEYDBOX+BREPPARTM	JUMP,EQ 63$	COMP.W	D3,#KEYDBOX+BREPPARTF	JUMP,EQ 64$	COMP.W	D3,#KEYDBOX+BREPLABEL	JUMP,EQ 70$	COMP.W	D3,#KEYDBOX+BREPGOTO	JUMP,EQ 71$	COMP.W	D3,#KEYDBOX+BREP_1X	JUMP,EQ 72$	COMP.W	D3,#KEYDBOX+BREP_2X	JUMP,EQ 73$	COMP.W	D3,#KEYDBOX+BREP_3X	JUMP,EQ 74$	COMP.W	D3,#KEYDBOX+BREP_4X	JUMP,EQ 75$30$:				; touche inconnue =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				;  |!:	TCLR.L	D4:#BREPDB	JUMP	20$41$:				;  |!	TCLR.L	D4:#BREPDBP	JUMP	20$42$:				; :!|	TCLR.L	D4:#BREPBD	TCLR.L	D4:#BREPBB	JUMP	20$43$:				;  !|	TCLR.L	D4:#BREPBDP	TCLR.L	D4:#BREPBB	JUMP	20$44$:				;  !!	TCLR.L	D4:#BREPBDP	TCLR.L	D4:#BREPBD	JUMP	20$50$:				; renvoi au dbut	TCLR.L	D4:#BREPRENVOI2	TCLR.L	D4:#BREPCODA1	JUMP	20$51$:				; renvoi  la fin	TCLR.L	D4:#BREPRENVOI1	TCLR.L	D4:#BREPCODA2	TCLR.L	D4:#BREPDC	TCLR.L	D4:#BREPFIN	JUMP	20$52$:				; coda au dbut	TCLR.L	D4:#BREPCODA2	TCLR.L	D4:#BREPRENVOI1	JUMP	20$53$:				; coda  la fin	TCLR.L	D4:#BREPCODA1	TCLR.L	D4:#BREPRENVOI2	TCLR.L	D4:#BREPDC	TCLR.L	D4:#BREPFIN	JUMP	20$54$:				; D.C.	TCLR.L	D4:#BREPRENVOI2	TCLR.L	D4:#BREPCODA2	TCLR.L	D4:#BREPFIN	JUMP	20$55$:				; FIN	TCLR.L	D4:#BREPRENVOI2	TCLR.L	D4:#BREPCODA2	TCLR.L	D4:#BREPDC	JUMP	20$60$:				; partie 1.	TCLR.L	D4:#BREPPART2	TCLR.L	D4:#BREPPART3	JUMP	20$61$:				; partie 2.	TCLR.L	D4:#BREPPART1	TCLR.L	D4:#BREPPART3	JUMP	20$62$:				; partie 3.	TCLR.L	D4:#BREPPART1	TCLR.L	D4:#BREPPART2	JUMP	20$63$:				; partie milieu	JUMP	20$64$:				; partie fin	JUMP	20$70$:				; label71$:				; goto	TEST.L	D4:#BREP_1X	JUMP,BS 20$	TEST.L	D4:#BREP_2X	JUMP,BS 20$	TEST.L	D4:#BREP_3X	JUMP,BS 20$	TEST.L	D4:#BREP_4X	JUMP,BS 20$	TSET.L	D4:#BREP_1X	JUMP	20$72$:				; 1X	TCLR.L	D4:#BREP_2X	TCLR.L	D4:#BREP_3X	TCLR.L	D4:#BREP_4X	JUMP'	76$73$:				; 2X	TCLR.L	D4:#BREP_1X	TCLR.L	D4:#BREP_3X	TCLR.L	D4:#BREP_4X	JUMP'	76$74$:				; 3X	TCLR.L	D4:#BREP_1X	TCLR.L	D4:#BREP_2X	TCLR.L	D4:#BREP_4X	JUMP'	76$75$:				; 4X	TCLR.L	D4:#BREP_1X	TCLR.L	D4:#BREP_2X	TCLR.L	D4:#BREP_3X;	JUMP'	76$76$:	TEST.L	D4:#BREP_1X	JUMP',BS 77$	TEST.L	D4:#BREP_2X	JUMP',BS 77$	TEST.L	D4:#BREP_3X	JUMP',BS 77$	TEST.L	D4:#BREP_4X	JUMP',BS 77$	TCLR.L	D4:#BREPLABEL	TCLR.L	D4:#BREPGOTO	JUMP	20$77$:	TEST.L	D4:#BREPLABEL	JUMP,BS 20$	TEST.L	D4:#BREPGOTO	JUMP,BS 20$	TSET.L	D4:#BREPGOTO	JUMP	20$80$:				; D'ACCORD/ANNULE =>	DBOX_	CLOSE		; ferme la DBOX90$:	POPM.L	D0..D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; AFDEC2N >;========/; Affiche un nombre dcimal sign de 2 digits.; in	D4.W	+/- nombre; out	-; mod	D7.WAFDEC2N:	PUSHM.L	D2..D4	LOAD.B	D2,#'+	TEST.W	D4	JUMP',NC 20$	NEG.W	D4	LOAD.B	D2,#'-20$:	AND.L	D4,#H'FFFF	DIV.WU	D4,#10	TEST.B	D4		; D3 <-- dizaines	JUMP',NE 40$	LIB	?AFSPACE	; affiche espace  la place des dizaines	LOAD.B	D3,D2	LIB	?AFCAR		; affiche +/-	JUMP'	60$40$:	LOAD.B	D3,D2	LIB	?AFCAR		; affiche +/-	LOAD.B	D3,D4	ADD.B	D3,#'0	LIB	?AFCAR		; affiche les dizaines60$:	SWAP.W	D4	LOAD.B	D3,D4	ADD.B	D3,#'0	LIB	?AFCAR		; affiche les units	POPM.L	D2..D4	RET; Tables; ------TICO_PREND:TICO_AJOUTE:	.B	4+16			; <lg>	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL1	.B	ICOPREND,ICOFLOPPY,ICOVIDE	.B	ICOVIDE,ICOVIDE,ICOVIDE	.B	ICOLISTE,ICOLISTE,ICOLISTE	.B	0,0,0	.B	ICOANNULE,ICOANNULE,ICOANNULE	.EVENTDBOX_SAUVE:	.B	LDBOX_SAUVE	.B	ODBSQUARE,BOUTPART	.ASCIZ	" sauve la partition (.PART)"	.B	ODBCR	.B	ODBSQUARE,BOUTMIDI	.ASCIZ	" sauve le morceau   (.MIDI)"	.B	ODBCRLDBOX_SAUVE	=	.-TDBOX_SAUVE-1TICO_SAUVE:	.B	4+16			; <lg>	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL1	.B	ICOVIDE,ICOFLOPPY,ICOSAUVE	.B	ICOVIDE,ICOFLOPPY,ICOSAUVE	.B	0,0,0	.B	0,0,0	.B	ICOANNULE,ICOANNULE,ICOANNULE	.EVENTICO_IMAGE:	.B	4+16			; <lg>	.B	USEGC,GCICF,GCICS,GCIC