  100 --  110 -- #############################################################  120 --  130 -- Initialise quelques constantes utiles.  140 --  150 UT=0 : RE=2 : MI=4 : FA=5 : SOL=7 : LA=9 : SI=11 : OCTAVE=12  160 DIESE=+1 : BEMOL=-1  170 --  180 -- #############################################################  190 --  200 -- Dbut du programme principal.  210 --  220 Let CANAL=1 -- canal MIDI numro 1  230 Let FRAPPE=127/2 -- mi-fort  240 Let DUREE=64/4 -- 1/4 de seconde  250 --  260 -- #############################################################  270 --  280 -- Joue une gamme (do r mi fa sol la si do).  290 --  300 Let NOTE=OCTAVE*5+UT  310 Gosub Label_NOTE  320 Let NOTE=OCTAVE*5+RE  330 Gosub Label_NOTE  340 Let NOTE=OCTAVE*5+MI  350 Gosub Label_NOTE  360 Let NOTE=OCTAVE*5+FA  370 Gosub Label_NOTE  380 Let NOTE=OCTAVE*5+SOL  390 Gosub Label_NOTE  400 Let NOTE=OCTAVE*5+LA  410 Gosub Label_NOTE  420 Let NOTE=OCTAVE*5+SI  430 Gosub Label_NOTE  440 Let NOTE=OCTAVE*6+UT  450 Gosub Label_NOTE  460 End10000 --10010 -- ***************10020 -- *    NOTE     *10030 -- ***************10040 -- 10050 -- Joue une note quelconque.10060 -- 10070 -- in	NOTE	numro de la note (0..127)10075 --	DUREE	dure de la note (64 = une seconde)10080 --	FRAPPE	force de frappe (1..127)10090 --	CANAL	canal MIDI (1..16)10100 -- out	-10110 -- 10120 Label_NOTE10130 Open File(1),"#midi",410140 Gosub Label_PRESSE10150 Gosub Label_ATTEND10160 Gosub Label_RELACHE10170 Close File(1)10180 Return10190 --10200 -- ***************10210 -- *   ACCORD    *10220 -- ***************10230 -- 10240 -- Joue un accord de cinq notes au maximum (-1 si silence).10250 -- 10260 -- in	NOTE1	numro de la premire  note (-1, 0..127)10270 --	NOTE2	numro de la deuxime  note (-1, 0..127)10280 --	NOTE3	numro de la troisime note (-1, 0..127)10290 --	NOTE4	numro de la quatrime note (-1, 0..127)10300 --	NOTE5	numro de la cinquime note (-1, 0..127)10305 --	DUREE	dure de l'accord (64 = une seconde)10310 --	FRAPPE	force de frappe (1..127)10320 --	CANAL	canal MIDI (1..16)10330 -- out	-10340 -- 10350 Label_ACCORD10360 Push NOTE10370 Open File(1),"#midi",410380 Let NOTE=NOTE1 : Gosub Label_PRESSE10390 Let NOTE=NOTE2 : Gosub Label_PRESSE10400 Let NOTE=NOTE3 : Gosub Label_PRESSE10410 Let NOTE=NOTE4 : Gosub Label_PRESSE10420 Let NOTE=NOTE5 : Gosub Label_PRESSE10430 Gosub Label_ATTEND10440 Let NOTE=NOTE1 : Gosub Label_RELACHE10450 Let NOTE=NOTE2 : Gosub Label_RELACHE10460 Let NOTE=NOTE3 : Gosub Label_RELACHE10470 Let NOTE=NOTE4 : Gosub Label_RELACHE10480 Let NOTE=NOTE5 : Gosub Label_RELACHE10490 Close File(1)10500 Pop NOTE10510 Return10520 --10530 -- ***************10540 -- *   PRESSE    *10550 -- ***************10560 -- 10570 -- Presse une note quelconque (-1 ne fait rien).10580 -- 10590 -- in	NOTE	numro de la note  presser (-1, 0..127)10600 --	FRAPPE	force de frappe (1..127)10610 --	CANAL	canal MIDI (1..16)10620 -- out	-10630 -- 10640 Label_PRESSE10650 If NOTE=-1 Then Goto 1067010660 Print File(1),Chr$(0);Chr$(3);Chr$(H'90+CANAL-1);Chr$(NOTE);Chr$(FRAPPE);10670 Return10680 --10690 -- ***************10700 -- *   ATTEND    *10710 -- ***************10720 -- 10730 -- Attend un peu. DUREE=64 attend une seconde (une unit = 15.625ms).10740 -- 10750 -- in	DUREE	dure  attendre (1..n)10760 -- out	-10770 -- 10780 Label_ATTEND10790 Print File(1),Chr$(0);Chr$(0);Chr$(High(DUREE));Chr$(Low(DUREE));10800 Return10810 --10820 -- ***************10830 -- *   RELACHE   *10840 -- ***************10850 -- 10860 -- Relche une note quelconque (-1 ne fait rien).10870 -- 10880 -- in	NOTE	numro de la note  relcher (-1, 0..127)10890 --	CANAL	canal MIDI (1..16)10900 -- out	-10910 -- 10920 Label_RELACHE10930 If NOTE=-1 Then Goto 1095010940 Print File(1),Chr$(0);Chr$(3);Chr$(H'90+CANAL-1);Chr$(NOTE);Chr$(0);10950 Return