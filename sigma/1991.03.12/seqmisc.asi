	.SBTTL	SEQMISC;--------\\; PUTNUM  >;========/; Met un nombre dans un buffer en ASCII.; in	A4.L	^buffer;	D4.W	nombre; out	A4.L	^plus loin; mod	A4.LPUTNUM:	PUSH.L	D4	AND.L	D4,#H'FFFF	DIV.WU	D4,#10	TEST.W	D4	JUMP,EQ 40$	ADD.B	D4,#'0	LOAD.B	(A4+),D4	; buffer <-- dizaines40$:	SWAP.W	D4	ADD.B	D4,#'0	LOAD.B	(A4+),D4	; buffer <-- units	POP.L	D4	RET;--------\\; GETNUM  >;========/; Lit un nombre en ASCII dans un buffer.; in	A4.L	^nombre; out	D4.W	nombre;	A4.L	^plus loin; mod	D4.L, A4.LGETNUM:	PUSH.L	D3	CLR.W	D410$:	CLR.W	D3	LOAD.B	D3,(A4)	COMP.B	D3,#'0	JUMP,LO 90$	COMP.B	D3,#'9	JUMP,HI 90$	INC.L	A4	MUL.WU	D4,#10	SUB.B	D3,#'0	ADD.W	D4,D3	JUMP	10$90$:	POP.L	D3	RET;--------\\; AFINFO  >;========/; Affiche les informations tout en haut.; in	-; out	-; mod	D7.WAFINFO:	PUSHM.L	D3..D5,A3,A4	LIB	?GETWDO		; D5 <-- no swdo utilise	LOAD.W	D4,D5	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.W	D5,D4	CLR.L	D3	LIB	?SETCURS	; positionne en tout en haut  gauche	LIB	?AFTIM	.B	AFINV		; en inverse vido	.B	SPACE		; toujours un espace	.ASCII	"SIGMA rev "	.B	MAJREV+'0	.B	'.	.B	MINREV+'0	.ASCII	"    "	.B	0	.EVEN	LOAD.L	A3,#(A6)+OBDIS	LOAD.L	A4,#(A6)+OBUFILE	LOAD.W	D4,#20		; D4 <-- nb max de caractres affichables20$:	LOAD.B	D3,(A4+)	JUMP,EQ 25$	COMP.B	D3,#CR	JUMP,EQ 25$	COMP.B	D3,#'.		; faire mieux pour "@nanet.12:tralala.midi" !!!	JUMP,EQ 25$	LIB	?MINMAJ	LOAD.B	(A3+),D3	DEC.W	D4	JUMP,NE 20$25$:	INC.B	D4	LOAD.B	(A3+),#MSPACE	LOAD.B	(A3+),D4	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBDIS	LIB	?AFTEXT		; affiche le nom puis des espaces	LIB	?AFTIM	.ASCII	"  "	.ASCII	"|slectionne|           |  modifie  |"		 ;           ;           ;           ;	.B	AFDIR		; remet vido normale	.B	0	.EVEN	LIB	?USEWDO		; utilise swdo initiale	POPM.L	D3..D5,A3,A4	RET;--------\\; MMENU   >;========/; Appel quivalent  LIB,?MMENU, mais restitue la swdo.; in	A3.L	^mmenu;	D3.W	case initiale; out	D3.W	case choisie;	D7.W	erreur; mod	D3.L, D7.WMMENU:	PUSH.L	D5	PUSHM.L	D3,D4	LIB	?GETWDO		; D5 <-- no swdo utilise	POPM.L	D3,D4	LIB	?MMENU		; attend selon souris ...	PUSH.W	D7	LIB	?USEWDO		; remet swdo initiale	POP.W	D7	POP.L	D5	TEST.W	D7		; retour EQ/NE	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; AFMENU  >;========/; Remet les soft-keys standards.; in	-; out	-; mod	-AFMENU:	PUSHM.L	D7,A3,A4	LOAD.L	A3,#R16"TICOBASE	LOAD.L	A4,#0	DBOX_	ICOAFF		; met les icones dans les "soft-keys"	LOAD.L	A3,#R16"TMENUBASE	LIB	?AFMENU	POPM.L	D7,A3,A4	RET;----------\\; METRONOME >;==========/; Fait entendre un "tic" de mtronome dans le haut-parleur du Smaky.; in	-; out	-; mod	D7.WMETRONOME:	PUSHM.L	D3..D6	LOAD.W	D3,#OCTAVE*7	LOAD.W	D4,#OCTAVE*8	LOAD.W	D5,#BRUIT+4	LOAD.W	D6,#H'100*2+0	LIB	?ACCORD	POPM.L	D3..D6	RET	.END