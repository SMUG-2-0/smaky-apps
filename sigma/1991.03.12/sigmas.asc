	.TITLE	SIGMAS.ASC;	--------------------------------------;		(C) 1985 - Daniel Roux;	--------------------------------------;	Date		Amliorations; -----------------------------------------------------------------------; 1.3	18.02.88	(F14) = (Mode);			synchronisation interne (gnre par le SMAKY);			enregistre les pressions (after touch); 1.2	17.12.87	enregistre ou non les synchros; 1.1			?; 1.0			SIGMAS 50%/M possible (LIB,?GTRSMM);			ok, mme si driver MIDI dj install; 0.8			nom fichier .MIDI dans la ligne de commande;			d-installe le driver d'usart;			Prend: en cas d'erreur, dbox pour l'afficher;			demande 8/16 (au lieu de 9/16) de la mmoire	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	RYTHMMAJREV	=	1		; rvisionMINREV	=	3		; version	.REV	MAJREV,MINREV	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'R,'F,09	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------NNPS	=	64		; 64 notes par secondesOFNOTE	=	4		; offset pour le dbut d'un rythmeGCICF	=	'I		; fonte des icnesGCICS	=	'S		; style/chasse des icnesGCICT	=	24		; taille des icnesGCTXF	=	'N		; fonte du texteGCTXS	=	'R!2^7		; style/chasse du texteGCTXT	=	09		; taille du texteRYTRACK	=	7		; piste pour le rythmeNBTRACK	=	8		; nb de pistesBFAPLAY	=	0		; fanion 1re piste en lectureBFAREC	=	8		; fanion 1re piste en critureBFAMET	=	16		; fanion 1er mtronomeBFASYNT	=	24		; synthtiseur rel prsentBMODSNO	=	0		; fanion mode: pas de synchroBMODSINT=	1		; fanion mode: synchro interneBMODSEXT=	2		; fanion mode: synchro externeBMODAFTER=	8		; fanion mode: after touchBMODRECALL=	9		; fanion mode: enregistre toutBMODINOUT=	10		; fanion mode: in --> outBFAFDN	=	0		; fanion filtre: dbut noteBFAFFN	=	1		; fanion filtre: fin noteBFAF1	=	8		; fanion filtre: rondeBFAF2	=	9		; fanion filtre: blancheBFAF4	=	10		; fanion filtre: noireBFAF8	=	11		; fanion filtre: crocheBFAF16	=	12		; fanion filtre: double-crocheBFAF32	=	13		; fanion filtre: triple-crocheBFAFPI	=	16		; fanion filtre: pisteKEYDBOX	=	H'7E00		; "touche" super-shift pour dboxSSCIRCLE=	H'7E		; "touche" super-shift pour cerclesKPLAY	=	(NBTRACK*2)+10	; offset touche PLAY dans dboxKSTOP	=	(NBTRACK*2)+11	;    "KRECORD	=	(NBTRACK*2)+12	;    "LBUFILE	=	32		; lg max d'un nom de fichierMGTRK	=	5		; marges gauche/droite dans rectangle des pistesMAXVIT	=	100		; vitesse maximalePRIOMET	=	4		; priorit du processus mtronome	.INS	ICONE24.ASI	; icnes de ISP24; Configuration; -------------	.LOC	0OCFNOM:	.BLKB	8		; nom du synthtiseurOCFMOD:	.BLKB	2		; numro du module lib	.BLKB	16		; rserveOCFCH:	.BLKB	2		; canal du module libOCFPV:	.BLKB	4		; ^variables du moduleOCFAOPEN:.BLKB	4		; ^routine OPENOCFAEDIT:.BLKB	4		; ^routine EDITOCFACLOSE:.BLKB	4		; ^routine CLOSEOCFAUSE:.BLKB	4		; ^routine USEOCFAGET:.BLKB	4		; ^routine GETLCF:; Variables pour une piste (nouveau); ----------------------------------	.LOC	0OTMIDI:	.BLKB	2		; canal midi (0..15)OTOCT:	.BLKB	2		; octave (-5..+5)OTDMT:	.BLKB	2		; demi-ton (0..12)OTAMP:	.BLKB	2		; amplitude (-127..+127)OTDYN:	.BLKB	2		; dynamique (-127..+127)	.BLKB	2*4		; rserve	.BLKB	8		; rserveOTSNA:	.BLKB	16		; nom de la banque de son (100_son.synth)OTSNO:	.BLKB	2		; numro du son dans la banque	.BLKB	10		; rserveLT:; En-tte d'un fichier .midi (nouveau); ------------------------------------	.LOC	0OHID:	.BLKB	2		; toujours -1OHREV:	.BLKB	1		; revisionOHVERS:	.BLKB	1		; version	.BLKB	4		; rserveOHCHA:	.BLKB	1		; canaux utiliss (bits)	.BLKB	1		; rserveOHVIT:	.BLKB	2		; vitesse (-MAXVIT..+MAXVIT)OHMET:	.BLKB	1		; mtronome	.BLKB	1		; rserveOHLG:	.BLKB	4		; longueur sans l'en-tte	.BLKB	6		; rserveOHTRK:	.BLKB	NBTRACK*LT	; paramtres des pistesLHEAD	=	512		; lg header fichiers; Variables pour une piste (ancien); ---------------------------------	.LOC	0OOTMIDI:.BLKB	2		; canal midi (0..15)OOTOCT:	.BLKB	2		; octave (-5..+5)OOTDMT:	.BLKB	2		; demi-ton (0..12)OOTAMP:	.BLKB	2		; amplitude (-127..+127)OOTDYN:	.BLKB	2		; dynamique (-127..+127)	.BLKB	2*5		; rserveLOT:; En-tte d'un fichier .midi (ancien); -----------------------------------	.LOC	0OOHCHA:	.BLKB	1		; canaux utiliss (bits)OOHID:	.BLKB	1		; toujours 0OOHVIT:	.BLKB	2		; vitesse (-MAXVIT..+MAXVIT)OOHMET:	.BLKB	1		; mtronome	.BLKB	1		; rserveOOHLG:	.BLKB	4		; longueur sans l'en-tte	.BLKB	6		; rserveOOHTRK:	.BLKB	NBTRACK*LOT	; paramtres des pistesOOHNAME:.BLKB	16		; nom du fichier de timbreOOHPROG:.BLKB	2		; numro du timbreLOHEAD	=	256		; lg header fichiers; Variables; ---------	.LOC	0OPLCOM:	.BLKB	4		; ^ligne de commandeOCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCRO:.BLKB	2		; canal module SCROLLOCHRYTHM:.BLKB	2		; canal module RYTHMOPRYTHM:.BLKB	4		; ^variables du module RYTHMONDMIDI:.BLKB	2		; no du driver MIDIONIMIDI:.BLKB	1		; 1 => driver MIDI pas install ici	.EVENOPDDIS:	.BLKB	4		; ^descripteur de la fentreOQXDOT:	.BLKB	4		; adresse de GRA_QXDOTONOWDO:	.BLKB	2		; no swdo pour la dbox principaleOBDIS:	.BLKB	100		; buffer write displayODBOXD5:.BLKB	4		; canal dboxOFANION:.BLKB	4		; fanions dboxOFAMODE:.BLKB	4		; fanions du modeOPORECT:.BLKB	4		; poition rectangle des pistesODIRECT:.BLKB	4		; dimensions rectangle des pistesOTRKAX:	.BLKB	2		; position de l'avanceOTRKFM:	.BLKB	2		; facteur de multiplicationOTRKFD:	.BLKB	2		; facteur de divisionOTRKUS:	.BLKB	1		; pistes utilises (bits)	.EVENOASVIT:	.BLKB	LSCVAR		; ascenseur pour la vitesseOFLAGS:	.BLKB	1		; flags divers BPLAY	=  0			;  lecture en cours BREC	=  1			;  enregistrement en cours BAX	=  2			;  avance en X dessine BDETECTE= 3			;  dtecte au lieu de dessiner BFIRST	=  4			;  premire note  dessiner BNEW	=  5			;  cration d'une note BWIMA	=  6			;  laisse l'image affiche	.EVENOLASTM:	.BLKB	2		; temps du dernier "tic" de mtronomeOLASTT:	.BLKB	2		; dernier temps lu par processus METROOPMBUF:	.BLKB	4		; ^master bufferOMMBUF:	.BLKB	4		; lg max master bufferOLMBUF:	.BLKB	4		; lg master bufferOPRBUF:	.BLKB	4		; ^record bufferOLRBUF:	.BLKB	4		; lg record bufferOBUCOM:	.BLKB	20		; commandes midiOBUNAME:.BLKB	LBUFILE		; nom temporaireOBUFILE:.BLKB	LBUFILE		; nom du fichierOHEAD:	.BLKB	LHEAD		; header nouveaux fichiers .MIDIOOHEAD:	.BLKB	LOHEAD		; header anciens fichiers .MIDIOASHOR:	.BLKB	LSCVAR		; ascenseur horizontalOASVER:	.BLKB	LSCVAR		; ascenseur verticalOEDITY:	.BLKB	2		; hauteur pour l'ditionOEDITX:	.BLKB	2		; largeur pour l'ditionOEDITA:	.BLKB	2		; position de l'avance (barre verticale)ONBNOY:	.BLKB	2		; nb de notes verticalementOPMOUSE:.BLKB	4		; position de la souris (y;x)OEPNOT:	.BLKB	4		; position d'une note (y;x)OEDNOT:	.BLKB	4		; dimensions d'une note (dy;dx)OENOPI:	.BLKB	2		; no piste des notes cresOENOTR:	.BLKB	2		; no trame des notes cresOCONFIG:.BLKB	16*LCF		; configuration MIDIOTRACK:	.BLKB	NBTRACK*LT	; variables pour chaque pisteOASOCT:	.BLKB	LSCVAR		; ascenseur octaveOASDMT:	.BLKB	LSCVAR		; ascenseur demi-tonOASAMP:	.BLKB	LSCVAR		; ascenseur amplitudeOASDYN:	.BLKB	LSCVAR		; ascenseur dynamiqueOFIFA:	.BLKB	4		; filtre: fanionsOFIPN:	.BLKB	2		; filtre: premire noteOFIDN:	.BLKB	2		; filtre: dernire noteOFIPI:	.BLKB	2		; filtre: piste (0..7)LGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	LIB	?AFTIM	.B	NOCURS	.B	0	.EVEN	LOAD.W	D3,#3	LIB	?MOUSE	CALL	WAITMOUSE	LOAD.L	A2,A3		; A2 <-- ^ligne de commande	LOAD.L	A3,#R16"TXERFATMEM	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.W	D4	JUMP,NE 10$	LOAD.L	(A6)+OPLCOM,A2	; mm ^ligne de commande; Initialise l'environnement par dfaut.	LOAD.L	(A6)+OFANION,#2^BFAPLAY!2^BFAREC!2^BFAMET	LOAD.L	(A6)+OFAMODE,#2^BMODSNO	LOAD.W	(A6)+OASVIT+OSCHTV,#2*MAXVIT	LOAD.W	(A6)+OASVIT+OSCPOSV,#MAXVIT	LOAD.L	(A6)+OFIFA,#2^BFAFDN!2^BFAF32;	LOAD.W	(A6)+OFIPN,#0	LOAD.W	(A6)+OFIDN,#(12*10)-1	LOAD.L	A3,#R16"TXERFATDIS	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	(A3+),#LOADGC	LOAD.B	(A3+),#GCICF	LOAD.B	(A3+),#GCICS	LOAD.B	(A3+),#GCICT	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBDIS	SUB.L	D3,A3	LIB	?STRING	LOAD.L	A3,#R16"TXERFATICO	TEST.W	D7	JUMP,NE ERFAT	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OQXDOT,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCRO	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHSCRO,D1	LOAD.L	A3,#R16"TXERFATMIDI	CALL	OPEMIDI	JUMP,NE ERFAT	LOAD.L	A3,#R16"NMRYTHM	LOAD.W	D3,#RYTH_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHRYTHM,D1	.W	RYTH_OPEN	; initialise le module RYTHM	JUMP,NE ERFAT		; non => ERFAT	LOAD.L	(A6)+OPRYTHM,A4	CALL	READCONFIG	; lit la configuration midi	CALL	MODCONFIG	; charge/libre les modules synth	CALL	CLRTRACK	; met les pistes par dfaut	LOAD.L	A2,#R16"TXERFATMEM	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ligne de commande	LOAD.W	D3,#5		; D3 <-- demande les 5/16mes	LOAD.L	D4,#1000	; D4 <-- minimum	LOAD.L	D5,#-1		; D5 <-- maximum	LOAD.W	D1,#MTYPCP	LIB	?GTRSMM		; demande mmoire pour partition	JUMP,NE ERFAT2	LOAD.L	(A6)+OPMBUF,A4	LOAD.L	(A6)+OMMBUF,D4	LIB	?BUZZ		; signal que l'on est prt	TCLR.B	(A6)+OFLAGS:#BWIMA	JUMP,BC REDBOX70$:	LIB	?IFCAR		; vide le fifo du clavier	JUMP,EQ 70$	LIB	?GETCAR		; attend une touche ...REDBOX:	CALL	WAITMOUSE	; met le sablier	TCLR.B	(A6)+OFLAGS:#BAX ; avance en X efface	LOAD.L	A3,#R16"TICOBASE	LOAD.L	A4,#0	DBOX_	ICOCADRE	; dessine le cadre autour	CALL	AFINFO		; affiche les informations	LOAD.L	A3,#R16"TXERFATDBOX	LOAD.L	A2,#R16"TDBOX_PANEL	LOAD.W	D2,#2^BDBNOC	; D2 <-- mode sans cadre	LOAD.L	D4,(A6)+OFANION	DBOX_	OPEN		; ouvre la dbox principale	JUMP,NE ERFAT	LOAD.L	(A6)+ODBOXD5,D5	; sauve canal dbox	LOAD.B	D3,#NOCURS	LIB	?AFCAR	LOAD.W	D2,#1	DBOX_	GETCO	SWAP.W	D3	ADD.W	D3,(A0)+ODFC2Y	SUB.W	D3,(A0)+ODFCY	SWAP.W	D3	LOAD.L	(A6)+OPORECT,D3	LOAD.W	D1,D3	LOAD.W	D2,#(NBTRACK*2)+6	DBOX_	GETCO	SUB.W	D3,D1	LOAD.W	(A6)+ODIRECT+2,D3	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#NBTRACK	LOAD.W	(A6)+ODIRECT+0,D3	CALL	DBOXTRACK	; affiche le contenu des pistes	CALL	DBOXMIDI	; affiche les canaux midi	CALL	DBOXSCROLL	; affiche l'ascenseur-vitesse	CALL	DBOXFULL	; affiche la jauge	LOAD.W	D2,#KSTOP	CALL	DBOXINV		; allume la touche STOP	LIB	?GETWDO	LOAD.W	(A6)+ONOWDO,D5	; mm. no swdo pour dbox; Prend le fichier donn dans la ligne de commande.	TEST.L	(A6)+OPLCOM	JUMP,EQ LOOP	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ligne de commande	CLR.L	(A6)+OPLCOM	LIB	?SKPNAM	JUMP,NE LOOP	LOAD.L	A4,#(A6)+OBUFILE70$:	LOAD.B	D3,(A3+)	JUMP',EQ 75$	COMP.B	D3,#CR	JUMP',EQ 75$	COMP.B	D3,#SPACE	JUMP',EQ 75$	COMP.B	D3,#TAB	JUMP',EQ 75$	COMP.B	D3,#'/	JUMP',EQ 75$	LOAD.B	(A4+),D3	; OBUFIN <-- nom du fichier	JUMP	70$75$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUFILE	LOAD.L	A4,#R16"TXEXT	; A4 <-- ^extension	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension .MIDI	LOAD.W	D0,#F1		; D0 <-- (PREND), et non (JOUE)	JUMP	DOPRENDF; Boucle principale du programme.LOOP:	CALL	NORMMOUSE	; remet la flche10$:	LOAD.L	D4,(A6)+OFANION	LOAD.L	D5,(A6)+ODBOXD5	; D5 <-- canal dbox	DBOX_	EDIT		; attend action ...	LOAD.W	D2,D3	SR.W	D2,#8	COMP.W	D2,#SSCIRCLE	JUMP,EQ 50$	LOAD.L	(A6)+OFANION,D4	LOAD.L	A1,#R16"TKEY_PANEL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP		; oui => LOOP	COMP.W	D3,#F0	JUMP,EQ FINI	COMP.W	D3,#TAB	JUMP,EQ DOBEGIN	COMP.W	D3,#CR	JUMP,EQ DOPLAY	COMP.W	D3,#SPACE	JUMP,EQ DORECORD	COMP.W	D3,#F1	JUMP,EQ DOPREND	COMP.W	D3,#H'100*(2^BSHOW)+DEFINE	JUMP,EQ DOPREND	COMP.W	D3,#F3	JUMP,EQ DOSAUVE	COMP.W	D3,#H'100*(2^BCOPY)+DEFINE	JUMP,EQ DOSAUVE	COMP.W	D3,#H'100*(2^BPROGRA)+'D	JUMP,EQ DODEBUG	COMP.W	D3,#H'100*(2^BPROGRA)+'d	JUMP,EQ DODEBUG	COMP.W	D3,#F4	JUMP,EQ DOEDITE	COMP.W	D3,#F7	JUMP,EQ DORYTHM	COMP.W	D3,#F10	JUMP,EQ DOPARAM	COMP.W	D3,#F11	JUMP,EQ DOSON	COMP.W	D3,#F12	JUMP,EQ DOFILTRE	COMP.W	D3,#F13	JUMP,EQ DOCONFIG	COMP.W	D3,#F14	JUMP,EQ DOMODE	COMP.W	D3,#F15	JUMP,EQ DOEFFACE	COMP.W	D3,#KEYMGP	JUMP,EQ DOCLIC	COMP.W	D3,#KEYMMP	JUMP,EQ DOASCENSEUR	COMP.W	D3,#KEYMDP	JUMP,EQ DOMODIF	JUMP	BIP50$:				; clic dans cercle =>	COMP.B	D3,#BFASYNT	JUMP,EQ 70$	COMP.B	D3,#BFAMET	JUMP,HS 60$	AND.L	D4,#H'FFFF00FF	; fanions <-- teint les cercles "canal"	TSET.L	D4:D3		; fanions <-- allume le bon cercle	LOAD.L	(A6)+OFANION,D4	JUMP	10$60$:	AND.L	D4,#H'FFF0FFFF	; fanions <-- teint les cercles "mtronome"	TSET.L	D4:D3		; fanions <-- allume le bon cercle	LOAD.L	(A6)+OFANION,D4	JUMP	10$70$:	LOAD.L	(A6)+OFANION,D4	CALL	CLRTRACK	; remet les pistes par dfaut	CALL	DBOXMIDI	; affiche les canaux midi	JUMP	10$BIP:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPDOPLAY:				; PLAY =>	TEST.L	(A6)+OLMBUF	; qq chose dans master buffer ?	JUMP,EQ BIP		; non => BIP	CALL	SELPTRACK	; slectionne les pistes d'coute	JUMP,NE ERROR;;?	.W	NTREL,?GETPRIO	; D4 <-- priorit	LOAD.L	D4,#PRIOMET-1	; D4 <-- super-prioritaire !	LOAD.L	D5,#600		; D5 <-- lg stack	LOAD.L	A5,#R16"PPLAY	; A5 <-- ^start	LOAD.L	A3,#R16"NPLAY	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre l'coute	JUMP,NE ERROR	TSET.B	(A6)+OFLAGS:#BPLAY	LOAD.L	D4,#PRIOMET	; D4 <-- trs prioritaire	LOAD.L	D5,#600		; D5 <-- lg stack	LOAD.L	A5,#R16"PMETRO	; A5 <-- ^start	LOAD.L	A3,#R16"NMETRO	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre le mtronome	LOAD.W	D2,#KSTOP	CALL	DBOXINV		; teint la touche STOP	LOAD.W	D2,#KPLAY	CALL	DBOXINV		; allume la touche PLAY	LOAD.W	D4,#50/10	NTREL	?SETTIM		; met un petit timeout40$:	CALL	DBOXMAJA	; mj l'avance dans les pistes	CLR.W	D3		; D3 <-- fin rencontre	TEST.B	(A6)+OFLAGS:#BPLAY	JUMP,BC 50$	LIB	?GETCAR		; attend clavier/souris ...	JUMP,NE 40$50$:	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet un timeout infini	LOAD.W	D2,#KPLAY	CALL	DBOXINV		; teint la touche PLAY	LOAD.W	D2,#KSTOP	CALL	DBOXINV		; allume la touche STOP	CALL	STOPMIDI	; "all-note-off"	TEST.W	D3		; fin rencontre ?	JUMP,NE LOOP		; non => LOOP	JUMP	DOBEGIN		; oui => revient au dbutDORECORD:			; RECORD =>	CALL	SELPTRACK	; slectionne les pistes d'coute	JUMP,NE ERROR	TEST.L	(A6)+OLMBUF	; qq chose dans master buffer ?	JUMP,EQ 20$		; non => 20$	NTREL	?GETPRIO	; D4 <-- priorit	DEC.W	D4	LOAD.L	D5,#600		; D5 <-- lg stack	LOAD.L	A5,#R16"PPLAY	; A5 <-- ^start	LOAD.L	A3,#R16"NPLAY	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre l'coute	JUMP,NE ERROR	TSET.B	(A6)+OFLAGS:#BPLAY20$:	NTREL	?GETPRIO	; D4 <-- priorit	LOAD.L	D5,#600		; D5 <-- lg stack	LOAD.L	A5,#R16"PREC	; A5 <-- ^start	LOAD.L	A3,#R16"NREC	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre l'enregistrement	JUMP,NE ERROR	TSET.B	(A6)+OFLAGS:#BREC	LOAD.L	D4,#PRIOMET	; D4 <-- trs prioritaire	LOAD.L	D5,#600		; D5 <-- lg stack	LOAD.L	A5,#R16"PMETRO	; A5 <-- ^start	LOAD.L	A3,#R16"NMETRO	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre le mtronome	LOAD.W	D2,#KSTOP	CALL	DBOXINV		; teint la touche STOP	LOAD.W	D2,#KRECORD	CALL	DBOXINV		; allume la touche RECORD	LOAD.W	D4,#50/10	NTREL	?SETTIM		; met un petit timeout40$:	CALL	DBOXMAJA	; mj l'avance dans les pistes;;?	TEST.B	(A6)+OFLAGS:#BREC;;?	JUMP,BC 50$	LIB	?GETCAR		; attend clavier/souris ...	JUMP,NE 40$50$:	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet un timeout infini	LOAD.W	D2,#KRECORD	CALL	DBOXINV		; teint la touche RECORD	LOAD.W	D2,#KSTOP	CALL	DBOXINV		; allume la touche STOP	CALL	GETRTRACK	; D5 <-- piste d'enregistrement	LOAD.L	D4,(A6)+OFANION	ADD.W	D5,#BFAPLAY	TSET.L	D4:D5		; met en lecture la piste d'enregistrement	LOAD.L	(A6)+OFANION,D4	CALL	WAITMOUSE	; met le sablier	CALL	STOPMIDI	; "all-note-off"	TEST.B	(A6)+OFAMODE+2:#BMODRECALL-8 ; enregistre tout ?	JUMP,BS 80$		; oui => 80$	CALL	GETRTRACK	; D5 <-- piste d'enregistrement	CALL	MAJRTRACK	; record buffer <-- canal d'enregistrement80$:	CALL	FUSION		; master buffer <-- record buffer	CALL	COMPACT		; master buffer <-- compactifie un peu	CALL	DBOXTRACK	; affiche le contenu des pistes	CALL	DBOXFULL	; affiche la jauge	CALL	NORMMOUSE	; remet la flche	JUMP	DOBEGINDOBEGIN:	LOAD.W	D4,(A6)+OTRKAX	CALL	DBOXINVA	; efface l'ancienne position	CLR.W	D4	CALL	DBOXINVA	; dessine la nouvelle position au dbut	CLR.W	(A6)+OTRKAX	; revient au dbut	JUMP	LOOPDOEFFACE:			; EFFACE =>	TEST.L	(A6)+OLMBUF	JUMP,EQ 20$	CALL	DBOXSURE	; tes-vous sr ?	COMP.W	D3,#F1	JUMP,NE LOOP20$:;;?	CALL	CLRTRACK	; remet les pistes par dfaut	CLR.L	(A6)+OLMBUF	; efface tout le master buffer	CLR.B	(A6)+OBUFILE	; efface le nom du morceau	CALL	DBOXTRACK	; affiche le contenu des pistes	CALL	DBOXMIDI	; affiche les canaux midi	CALL	DBOXFULL	; affiche la jauge	CALL	AFINFO		; affiche les informations tout en haut;;?	LOAD.W	(A6)+OASVIT+OSCPOSV,#MAXVIT;;?	LOAD.L	A5,#(A6)+OASVIT	; A5 <-- ^variables ascenseur-vitesse;;?	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur	LOAD.L	A4,(A6)+OPRYTHM	; A4 <-- ^variables du module RYTHM	.W	RYTH_CLEAR	; efface le rythme	JUMP	LOOPDOCLIC:	LIB	?IFMOUSE	; D4 <-- position de la souris	CALL	GETPMT	JUMP,NE DOASCENSEUR	JUMP	20$10$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 50$		; non => 50$	LIB	?IFMOUSE	; D4 <-- position de la souris	CALL	GETPMT20$:	COMP.W	D4,(A6)+OTRKAX	; position change ?	JUMP,EQ 10$		; non => 10$				; oui =>	PUSH.W	D4	LOAD.W	D4,(A6)+OTRKAX	CALL	DBOXINVA	; efface l'ancienne position	POP.W	D4	CALL	DBOXINVA	; dessine la nouvelle position	LOAD.W	(A6)+OTRKAX,D4	JUMP	10$50$:	JUMP	LOOPDOMODIF:	LIB	?IFMOUSE	; D4 <-- position de la souris	CALL	GETPMT	JUMP,NE DOASCENSEUR	SWAP.W	D4	COMP.W	D4,#-1	JUMP,EQ BIP	LOAD.W	D5,#-1		; D5 <-- pas encore de piste allume	JUMP	12$10$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 15$		; non => 15$	LIB	?IFMOUSE	; D4 <-- position de la souris	CALL	GETPMT	SWAP.W	D4	COMP.W	D4,#-1	JUMP,NE 12$	CLR.W	D412$:	COMP.W	D4,D5		; position change ?	JUMP,EQ 10$		; non => 10$				; oui =>	SWAP.W	D4	SWAP.W	D5	EX.L	D4,D5	CALL	DBOXINVT	; teint l'ancienne piste	LOAD.L	D4,D5	CALL	DBOXINVT	; allume la nouvelle piste	SWAP.W	D5	SWAP.W	D4	JUMP	10$15$:	LOAD.W	D3,D4	SWAP.W	D4	LOAD.B	D2,(A6)+OTRKUS	TEST.L	D2:D3		; est-on dans une piste utilise ?	JUMP,BS 17$		; oui => 17$				; non =>	CALL	DBOXINVT	; teint toute la piste	JUMP	BIP17$:	LOAD.L	A3,#R16"MDMENU	CLR.W	D3	CALL	MMENU		; attend selon souris ...	JUMP,NE 90$	COMP.W	D3,#1	JUMP,EQ 20$	COMP.W	D3,#2	JUMP,EQ 30$	COMP.W	D3,#3	JUMP,EQ 40$	CALL	DBOXINVT	; teint la piste slectionne	JUMP	LOOP20$:				; dtruit =>	CALL	DBOXINVT	; teint la piste slectionne	SWAP.W	D4		; D4 <-- piste slectionne	CALL	WAITMOUSE	; met le sablier	CALL	DETRUIT		; master buffer <-- enlve une piste	CALL	COMPACT		; master buffer <-- compactifie un peu	CALL	DBOXTRACK	; affiche le contenu des pistes	CALL	DBOXFULL	; affiche la jauge	CALL	NORMMOUSE	; remet la flche	JUMP	LOOP30$:				; dplace =>	CALL	DBOXINVT	; teint la piste slectionne	SWAP.W	D4		; D4 <-- piste slectionne	CALL	GETRTRACK	; D5 <-- piste d'enregistrement	COMP.W	D4,D5	JUMP,EQ BIP	CALL	WAITMOUSE	; met le sablier	CALL	DEPLACE		; master buffer <-- change de piste	CALL	DBOXTRACK	; affiche le contenu des pistes	JUMP	LOOP40$:				; duplique =>	CALL	DBOXINVT	; teint la piste slectionne	SWAP.W	D4		; D4 <-- piste slectionne	CALL	GETRTRACK	; D5 <-- piste d'enregistrement	COMP.W	D4,D5	JUMP,EQ BIP	CALL	WAITMOUSE	; met le sablier	CALL	DUPLIQUE	; master buffer <-- duplique une piste	CALL	DBOXTRACK	; affiche le contenu des pistes	CALL	DBOXFULL	; affiche la jauge	JUMP	LOOP90$:	CALL	DBOXINVT	; teint la piste slectionne	JUMP	BIPDOASCENSEUR:	TEST.B	(A6)+OFAMODE+3:#BMODSINT-0	JUMP',BC 10$	TEST.L	(A6)+OLMBUF	; qq chose de dj enregistr ?	JUMP,NE BIP		; oui => BIP10$:	LIB	?IFMOUSE	; D4 <-- position de la souris	SUB.W	D4,(A0)+ODFFX	JUMP,LO BIP	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP,LO BIP	SWAP.W	D4	LOAD.L	A5,#(A6)+OASVIT	; A5 <-- ^variables ascenseur-vitesse	LOAD.W	(A5)+OSCINC,#2*MAXVIT/10	SCROLL_	MOVE		; dplace la cabine de l'ascenseur	JUMP,NE	BIP	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'V	; <vitesse>	LOAD.W	D4,#MAXVIT	SUB.W	D4,(A6)+OASVIT+OSCPOSV ; D4 <-- vitesse (-MAXVIT..+MAXVIT)	LOAD.W	(A4)+1,D4	CLR.B	(A4)+3	CALL	COMMAND		; commande la bonne vitesse	JUMP,NE BIP	JUMP	LOOPDODEBUG:			; DEBUG =>	LOAD.L	D5,(A6)+ODBOXD5	; D5 <-- canal dbox	DBOX_	CLOSE		; ferme la dbox	CALL	DEBUG	JUMP	REDBOXDOEDITE:			; EDITE =>	LOAD.L	D5,(A6)+ODBOXD5	; D5 <-- canal dbox	DBOX_	CLOSE		; ferme la dbox	CALL	EDITE	JUMP	REDBOXDOPARAM:			; PARAM =>	CLR.W	D5	LIB	?USEWDO	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve le contenu de tout l'cran	JUMP,NE 50$		; pas assez de mmoire => 50$	CALL	PARAM	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue le contenu de tout l'cran	LOAD.W	D5,(A6)+ONOWDO	LIB	?USEWDO		; utilise swdo de la dbox !	CALL	DBOXMIDI	; affiche les canaux midi	CALL	AFMENU		; puis refait juste les soft-keys	JUMP	LOOP50$:	LOAD.L	D5,(A6)+ODBOXD5	; D5 <-- canal dbox	DBOX_	CLOSE		; ferme la dbox	CALL	PARAM	JUMP	REDBOXDOSON:				; SON =>	CALL	GETRTRACK	; D5 <-- piste d'enregistrement	LOAD.W	D4,D5	CALL	IFSYNTEDIT	; dition possible ?	JUMP,NE BIP		; non => BIP	CLR.W	D5	LIB	?USEWDO	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve le contenu de tout l'cran	JUMP,NE 50$		; pas assez de mmoire => 50$	CALL	GETRTRACK	; D5 <-- piste d'enregistrement	LOAD.W	D4,D5	CALL	SYNTEDIT	; dite ...	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue le contenu de tout l'cran	CALL	AFMENU		; puis refait juste les soft-keys	JUMP	LOOP50$:	LOAD.L	D5,(A6)+ODBOXD5	; D5 <-- canal dbox	DBOX_	CLOSE		; ferme la dbox	CALL	GETRTRACK	; D5 <-- piste d'enregistrement	LOAD.W	D4,D5	CALL	SYNTEDIT	; dite ...	JUMP	REDBOXDOFILTRE:			; FILTRE =>	CALL	DBOXFILTRE	JUMP,NE LOOP	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	FILTRE		; filtre selon choix dbox	JUMP	LOOPDOCONFIG:			; CONFIGURATION =>	CALL	DBOXCONFIG	JUMP	LOOPDOMODE:				; MODE MIDI =>	CALL	DBOXMODE	JUMP,NE LOOP	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	SELPTRACK	; met  jour le driver MIDI	JUMP,NE ERROR	JUMP	LOOPDORYTHM:			; RYTHME =>	LOAD.L	D5,(A6)+ODBOXD5	; D5 <-- canal dbox	DBOX_	CLOSE		; ferme la dbox	LOAD.W	D2,(A6)+OTRACK+RYTRACK*LT+OTMIDI ; D2 <-- canal MIDI pour rythme	LOAD.W	D3,(A6)+OTRKAX	MUL.WU	D3,(A6)+OTRKFD	DIV.WU	D3,(A6)+OTRKFM	; D3 <-- temps	LOAD.W	D4,#MAXVIT	SUB.W	D4,(A6)+OASVIT+OSCPOSV ; D4 <-- vitesse (-MAXVIT..+MAXVIT)	LOAD.L	A4,(A6)+OPRYTHM	; A4 <-- ^variables du module RYTHM	.W	RYTH_EDIT	; dite ...	SUB.W	D4,#MAXVIT	NEG.W	D4	LOAD.W	(A6)+OASVIT+OSCPOSV,D4	CALL	WAITMOUSE	; met le sablier	LOAD.W	D4,#RYTRACK	CALL	DETRUIT		; master buffer <-- enlve l'ancien rythme	CALL	COMPACT		; master buffer <-- compactifie un peu	LOAD.L	A4,(A6)+OPMBUF	; A4 <-- ^dbut master buffer	LOAD.L	D4,(A6)+OLMBUF	; D4 <-- lg master buffer	LOAD.L	D5,(A6)+OMMBUF	; D4 <-- max master buffer	LOAD.L	A3,(A6)+OPRYTHM	; A3 <-- ^variables du module RYTHM	.W	RYTH_FUSION	; master buffer <-- nouveau rythme	LOAD.L	(A6)+OLMBUF,D4;;?	CALL	COMPACT		; master buffer <-- compactifie un peu50$:	LOAD.L	D4,(A6)+OFANION	TSET.L	D4:#BFAPLAY+RYTRACK ; met en lecture la piste du rythme	LOAD.L	(A6)+OFANION,D4	CALL	SCALETRACK	; recalcul OTRKFM/D	MUL.WU	D3,(A6)+OTRKFM	DIV.WU	D3,(A6)+OTRKFD	LOAD.W	(A6)+OTRKAX,D3	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface tout	JUMP	REDBOXERROR:	PUSH.W	D7	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	AFMENU		; remet les soft-keys	JUMP	LOOPFINI:	CALL	DBOXSURE	; tes-vous sr ?	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.L	D5,(A6)+ODBOXD5	; D5 <-- canal dbox	DBOX_	CLOSE		; ferme la dbox	CALL	CLOMIDI	JUMP	RETOURERFAT2:	LOAD.L	A3,A2ERFAT:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT	LIB	?AFCR	POP.W	D7	LIB	?AFERROR	LIB	?AFCR	LIB	?GETCAR		; attend une touche ...RETOUR:	CALL	STOPMIDI	; stoppe tout	CALL	CLEARCONFIG	; libre tous les modules synth	LOAD.L	D4,(A6)+OPRYTHM	JUMP,EQ 30$	LOAD.L	A4,D4	.W	RYTH_CLOSE	; ferme le module RYTHM30$:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCRO	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHRYTHM	LIB_	CLOSE	LIB	?CLOLIB	FOS	?STOP;;;;;;;;;;;;;;;    PLAY    ;;;;;;;;;;;;;;;NPLAY:	.ASCIZ	"MIDI_PLAY"	.EVENPPLAY:	LOAD.L	A4,(A6)+OPMBUF	LOAD.L	D5,(A6)+OLMBUF	JUMP,EQ 90$	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DWRITE90$:	TCLR.B	(A6)+OFLAGS:#BPLAY	NTREL	?ABORT;;;;;;;;;;;;;;    REC    ;;;;;;;;;;;;;;NREC:	.ASCIZ	"MIDI_REC"	.EVENPREC:	LOAD.L	A4,(A6)+OPMBUF	ADD.L	A4,(A6)+OLMBUF	LOAD.L	(A6)+OPRBUF,A4	LOAD.L	D5,(A6)+OMMBUF	SUB.L	D5,(A6)+OLMBUF	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DREAD	LOAD.L	(A6)+OLRBUF,D5	TCLR.B	(A6)+OFLAGS:#BREC	NTREL	?ABORT;;;;;;;;;;;;;;;;    METRO    ;;;;;;;;;;;;;;;;NMETRO:	.ASCIZ	"MIDI_METRO"	.EVENPMETRO:	CLR.W	(A6)+OLASTM10$:	TEST.B	(A6)+OFLAGS:#BPLAY	JUMP,BS 20$	TEST.B	(A6)+OFLAGS:#BREC	JUMP,BC 90$20$:	CALL	MIDITIME	; D4 <-- temps	JUMP,NE 50$	LOAD.W	(A6)+OLASTT,D4	; donne le temps aux autres processus	CLR.L	D2	LOAD.W	D2,D4	LOAD.L	D4,(A6)+OFANION	LOAD.W	D3,#NNPS/1	TEST.L	D4:#BFAMET+1	; mtronome ?	JUMP,BS 40$		; oui => 40$	LOAD.W	D3,#NNPS/2	TEST.L	D4:#BFAMET+2	; mtronome ?	JUMP,BC 50$		; non => 50$40$:				; oui =>	SUB.L	D2,#OFNOTE	; tient compte du dbut des rythmes	JUMP,LO 50$	DIV.WU	D2,D3	COMP.W	D2,(A6)+OLASTM	JUMP,EQ 50$	LOAD.W	(A6)+OLASTM,D2	SR.W	D3,#2	SWAP.W	D2	COMP.W	D2,D3		; est-on dans le premier quart du temps ?	JUMP,HS 50$		; non => 50$	CALL	METRONOME	; fait un "tic" !50$:	LOAD.W	D4,#1	NTREL	?DELMS		; attend un tout p'tit peu ...	JUMP	10$90$:	NTREL	?ABORT;---------\\; CLRTRACK >;=========/; Remet les pistes par dfaut.; in	-; out	-; mod	D7.WCLRTRACK:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OTRACK	LOAD.W	D4,#NBTRACK-130$:	CLR.W	(A4)+OTMIDI	CLR.W	(A4)+OTOCT	CLR.W	(A4)+OTDMT	CLR.W	(A4)+OTAMP	CLR.W	(A4)+OTDYN	LOAD.L	A4,#(A4)+LT	DECJ.W,NMO D4,30$	LOAD.W	(A6)+OTRACK+LT*RYTRACK+OTMIDI,#10-1 ; rythme sur la piste "R"	CALL	SMAKYTRACK	; si pas de synth => met pistes sur le Smaky	POPM.L	D4,A4	RET;-----------\\; SMAKYTRACK >;===========/; Si le "vrai" synthtiseur n'est pas branch, met toutes; les pistes sur le canal 16 du Smaky.; in	-; out	-; mod	D7.WSMAKYTRACK:	PUSHM.L	D4,A4	LOAD.L	D4,(A6)+OFANION	TEST.L	D4:#BFASYNT	; synthtiseur prsent ?	JUMP,BS 90$		; oui => 90$				; non =>	LOAD.L	A4,#(A6)+OTRACK	LOAD.W	D4,#NBTRACK-130$:	LOAD.W	(A4)+OTMIDI,#16-1	LOAD.L	A4,#(A4)+LT	DECJ.W,NMO D4,30$90$:	POPM.L	D4,A4	RET	.INS	SEQIO.ASI	.INS	SEQOPER.ASI	.INS	SEQDBOX.ASI	.INS	SEQDEBUG.ASI	.INS	SEQEDIT.ASI	.INS	SEQPARAM.ASI	.INS	SEQFILTRE.ASI	.INS	SEQCONFIG.ASI	.INS	SEQMISC.ASI	.INS	SEQMIDI.ASI	.INS	SEQTABLE.ASI	.END	START