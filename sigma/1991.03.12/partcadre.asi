	.SBTTL	PARTCADRE;--------\\; AFINFO  >;========/; Affiche les informations tout en haut, dans le cadre.; in	-; out	-; mod	D7.WAFINFO:	PUSHM.L	D0..D5,A3	CALL	AFSIGMA	LIB	?AFTIM	.ASCIZ	"Mes:"	.EVEN	LOAD.W	D2,#2^BAFDCM!2^BAFDSP	LOAD.W	D3,#6	CLR.L	D4	LOAD.W	D4,(A6)+OMESC	INC.W	D4		; la premire mesure est la UNE !	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"-"	.EVEN	LOAD.W	D4,(A6)+OMESM	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"  Symb:"	.EVEN	LOAD.W	D4,(A6)+ONBOBJ	LIB	?AFDEC	LOAD.L	D1,(A6)+OPDT	SUB.L	D1,(A6)+OPDB	LOAD.L	D0,(A6)+OPFB	SUB.L	D0,(A6)+OPFT	ADD.L	D1,D0		; D1 <-- utilis	LOAD.L	D0,(A6)+OPFT	SUB.L	D0,(A6)+OPDT	; D0 <-- reste	LIB	?AFSPACE	ADD.L	D0,D1		; D0 <-- U+R, D1 <-- U	CLR.W	D2	COMP.L	D0,#10000	JUMP',LO 50$		;	  0 ..   9'999 => /1	LOAD.W	D2,#3		;    10'000 ..  99'999 => /8	COMP.L	D0,#100000	;   100'000 .. 999'999 => /64	JUMP',LO 50$		; 1'000'000 .. infini  => /512	LOAD.W	D2,#6	COMP.L	D0,#1000000	JUMP',LO 50$	LOAD.W	D2,#950$:	SR.L	D0,D2		; D0 <-- R/1 ou R/8 ou R/64	SR.L	D1,D2		; D1 <-- U/1 ou U/8 ou U/64	MUL.WU	D1,#100	DIV.WU	D1,D0		; D1 <-- (U*100)/(U+R)	CLR.L	D4	LOAD.W	D4,D1		; D4 <-- utilis en %;;?	JUMP',EQ 60$		; si 0% => n'affiche rien !	LOAD.B	D3,#3		; D3 <-- 3 digits au maximum	LOAD.B	D2,#2^BAFDCM	; D2 <-- compact sans '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	"%"	.EVEN60$:	LIB	?NOBUCAR	; remet le mode normal	LOAD.W	D4,#((LXMOUSE+1)*3)+2	MUL.WU	D4,(A0)+ODFCX	SUB.W	D4,(A0)+ODFDX	NEG.W	D4		; D4 <-- position pour 3 boutons souris	SUB.W	D4,(A0)+ODFPX	DIV.WU	D4,(A0)+ODFCX	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin de la ligne	LOAD.W	D3,#((LXMOUSE+1)*3)+2	MUL.WU	D3,(A0)+ODFCX	SUB.W	D3,(A0)+ODFDX	NEG.W	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCII	"|         |         |         |"	.B	AFDIR	.B	0	.EVEN	LOAD.W	D5,(A6)+OWDOCA	LIB	?USEWDO		; utilise swdo dans le cadre	LOAD.L	A3,(A6)+OPTXM+0	CALL	AFMOUSE	LOAD.L	A3,(A6)+OPTXM+4	CALL	AFMOUSE	LOAD.L	A3,(A6)+OPTXM+8	CALL	AFMOUSE	POPM.L	D0..D5,A3	RET;---------\\; AFNOMES  >;=========/; Affiche le numro de la mesure courante (pour l'coute).; in	-; out	-; mod	D7.WAFNOMES:	PUSHM.L	D2..D5	CALL	AFSIGMA	LIB	?AFTIM	.ASCIZ	"        [  Mesure = "	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OMESC	INC.W	D4		; la premire mesure est la UNE !	LOAD.W	D2,#2^BAFDCM!2^BAFDSP	LOAD.W	D3,#6	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"  ]"	.EVEN	LIB	?AFTIM	.B	MSPACE,40	; efface la fin de la ligne	.B	AFDIR	.B	0	.EVEN	LIB	?NOBUCAR	; remet le mode normal	LOAD.W	D5,(A6)+OWDOCA	LIB	?USEWDO		; utilise swdo dans le cadre	POPM.L	D2..D5	RET;---------\\; AFCOMPTE >;=========/; Affiche le nombre d'objets trouvs.; in	D2.W	nb d'objets; out	-; mod	D7.WAFCOMPTE:	PUSHM.L	D2..D5	CALL	AFSIGMA	LIB	?AFTIM	.ASCIZ	"        ***  "	.EVEN	CLR.L	D4	LOAD.W	D4,D2	LOAD.W	D2,#2^BAFDCM!2^BAFDSP	LOAD.W	D3,#6	LIB	?AFDEC	COMP.W	D4,#2	JUMP',HS 20$	LIB	?AFTIM	.ASCIZ	" objet trouv  ***"	.EVEN	JUMP'	30$20$:	LIB	?AFTIM	.ASCIZ	" objets trouvs  ***"	.EVEN30$:	LIB	?AFTIM	.B	MSPACE,40	; efface la fin de la ligne	.B	AFDIR	.B	0	.EVEN	LIB	?NOBUCAR	; remet le mode normal	LOAD.W	D5,(A6)+OWDOCA	LIB	?USEWDO		; utilise swdo dans le cadre	POPM.L	D2..D5	RET;--------\\; AFSIGMA >;--------/; Affiche "SIGMA machin...".; in	-; out	-; mod	D3.L, D5.L, D7.WAFSIGMA:	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LIB	?BUCAR		; mode super-rapide (hum)	CLR.L	D3	LIB	?SETCURS	; position en haut  gauche	LIB	?AFTIM	.B	NOCURS	.B	AFINV	.ASCII	" SIGMA "	.B	MAJREV+'0	.B	'.	.B	MINREV+'0	.ASCIZ	"       "	.EVEN	RET;----------\\; AFNOMNOTE >;==========/; Affiche le nom de la note.; in	(A6)+ONNMIDI.W	nom de la note; out	-; mod	D7.WAFNOMNOTE:	PUSHM.L	D3,A3	LOAD.W	D3,(A6)+ONNMIDI	COMP.W	D3,#-1	JUMP',EQ 90$	LOAD.L	A3,#R16"TXMNOMNOTE10$:	TEST.W	D3	JUMP',EQ 40$15$:	TEST.B	(A3+)		; A3 <-- ^nom suivant	JUMP,NE 15$	DEC.W	D3	JUMP	10$40$:	CALL	AFMOUSE		; affiche le nom de la note90$:	POPM.L	D3,A3	RET;--------\\; AFMOUSE >;========/; Affiche un texte d'aide pour la souris.; in	A3.L	^<1..3>texte; out	-; mod	D7.WAFMOUSE:	PUSHM.L	D3..D5,A3,A4	LOAD.L	D3,A3		; A3 = ^nil ?	JUMP,EQ 90$		; oui => 90$	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.L	A4,#(A6)+OPTXM	CLR.W	D3	LOAD.B	D3,(A3)		; D3 <-- 1..3	DEC.B	D3		; D3 <-- 0..2	SL.W	D3,#2		; D3 <-- *4 car table de .L	LOAD.L	(A4)+(D3.W),A3	; mm le ^	LOAD.W	D4,#((LXMOUSE+1)*3)+1	MUL.WU	D4,(A0)+ODFCX	SUB.W	D4,(A0)+ODFDX	NEG.W	D4		; D4 <-- position pour 1er texte	CLR.W	D3	LOAD.B	D3,(A3+)	DEC.B	D3	MUL.WU	D3,#LXMOUSE+1	MUL.WU	D3,(A0)+ODFCX	ADD.W	D3,D4	LIB	?SETCURS	; positionne le curseur au dbut	LOAD.L	A4,A3	LOAD.W	D3,#-120$:	INC.W	D3		; D3 <-- nb de caractres	TEST.B	(A4+)	JUMP,NE 20$	SUB.W	D3,#LXMOUSE	NEG.W	D3		; D3 <-- reste gauche/droite	JUMP',NC 30$	CLR.W	D3		; D3 <-- reste rien si dborde30$:	SR.W	D3,#1		; D3 <-- la moiti de chaque ct	LOAD.L	A4,#(A6)+OBDIS	LOAD.W	D4,#LXMOUSE	LOAD.B	(A4+),#AFINV40$:	TEST.W	D3	JUMP',EQ 45$	DEC.W	D3	LOAD.B	(A4+),#SPACE	; buffer <-- marge gauche	DEC.W	D4	JUMP,NE 40$	JUMP'	60$45$:	LOAD.B	(A4),(A3+)	; buffer <-- texte	JUMP',EQ 50$	INC.L	A4	DEC.W	D4	JUMP,NE 45$	JUMP'	60$50$:	LOAD.B	(A4+),#SPACE	; buffer <-- marge droite	DEC.W	D4	JUMP,NE 50$60$:	LOAD.B	(A4+),#AFDIR	CLR.B	(A4)		; buffer <-- terminateur	LOAD.L	A3,#(A6)+OBDIS	LIB	?AFTEXT		; affiche le texte	LOAD.W	D5,(A6)+OWDOCA	LIB	?USEWDO		; utilise swdo dans le cadre90$:	POPM.L	D3..D5,A3,A4	RET;--------\\; CADRE   >;========/; Dessine le cadre, et cre une swdo  l'intrieur.; in	-; out	-; mod	D7.WCADRE:	PUSHM.L	D3..D5,A3..A5	LOAD.L	A3,#R16"TICOHNOTE	LOAD.L	A4,#R16"TICOMENU	DBOX_	ICOCADRE	LOAD.L	A5,#(A6)+OASC	; A5 <-- ^ascenseur	LOAD.W	D5,D3	DEC.W	D5	LOAD.W	(A5)+OSCDEBO,D5	; ascenseur <-- dbut //	LOAD.W	D5,D4	ADD.W	D5,#2	LOAD.W	(A5)+OSCHTR,D5	; ascenseur <-- longueur relle	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,#LGSCROLL	; D4 <-- enlve place pour ascenseur	LOAD.W	D5,D3	ADD.W	D5,D4	LOAD.W	(A5)+OSCDEBL,D5	; ascenseur <-- dbut |-	SWAP.W	D4	SWAP.W	D3	SET.B	(A5)+OSCHOR	; ascenseur <-- horizontal	CLR.B	(A5)+OSCPAGE	; ascenseur <-- pas de pages	SCROLL_	DRAW		; dessine la cage de l'ascenseur	LIB	?CREWDO	LIB	?USEWDO	LOAD.W	(A6)+OWDOCA,D5	POPM.L	D3..D5,A3..A5	RET;--------\\; AFMENU  >;========/; Met  jour les "soft-keys".; in	D0.W	"soft-keys" allumes;	D1.W	niveau (icne verticale allume); out	-; mod	D7.WAFMENU:	PUSHM.L	A3..A5	LOAD.L	A5,(A6)+OPN	LOAD.W	(A5),D0		; mmorise les "soft-keys" allumes	LOAD.L	A3,#R16"TICOHNOTE	LOAD.L	A4,#R16"TMENUHNOTE	LOAD.L	A5,#(A6)+ONNOTE	COMP.W	D1,#NHAUTNOTE	JUMP,EQ 10$	LOAD.L	A3,#R16"TICOBNOTE	LOAD.L	A4,#R16"TMENUBNOTE	LOAD.L	A5,#(A6)+ONNOTE	COMP.W	D1,#NBASNOTE	JUMP,EQ 10$	LOAD.L	A3,#R16"TICOHSILENCE	LOAD.L	A4,#R16"TMENUHSILENCE	LOAD.L	A5,#(A6)+ONSIL	COMP.W	D1,#NHAUTSILENCE	JUMP,EQ 10$	LOAD.L	A3,#R16"TICOBSILENCE	LOAD.L	A4,#R16"TMENUBSILENCE	LOAD.L	A5,#(A6)+ONSIL	COMP.W	D1,#NBASSILENCE	JUMP,EQ 10$	LOAD.L	A3,#R16"TICOGRAPHIQUE	LOAD.L	A4,#R16"TMENUGRAPHIQUE	LOAD.L	A5,#(A6)+ONGRA	COMP.W	D1,#NGRAPHIQUE	JUMP,EQ 10$	LOAD.L	A3,#R16"TICOCLEF	LOAD.L	A4,#R16"TMENUCLEF	LOAD.L	A5,#(A6)+ONCLEF  	COMP.W	D1,#NCLEF	JUMP,EQ 10$	LOAD.L	A3,#R16"TICOFLOPPY	LOAD.L	A4,#R16"TMENUFLOPPY	LOAD.L	A5,#(A6)+ONFLO  	COMP.W	D1,#NFLOPPY	JUMP,EQ 10$	LOAD.L	A3,#R16"TICODIVERS1	LOAD.L	A4,#R16"TMENUDIVERS1	LOAD.L	A5,#(A6)+ONDIV1	COMP.W	D1,#NDIVERS1	JUMP,EQ 10$	LOAD.L	A3,#R16"TICODIVERS2	LOAD.L	A4,#R16"TMENUDIVERS2	LOAD.L	A5,#(A6)+ONDIV2;	COMP.W	D1,#NDIVERS2;	JUMP,EQ 10$10$:	LOAD.L	(A6)+OPN,A5	LOAD.W	D0,(A5)		; D0 <-- "soft-keys"  allumer	PUSH.L	A4	LOAD.L	A4,#R16"TICOMENU	LOAD.L	(A6)+OPICOH,A3	; mm ^icnes horizontaux	LOAD.L	(A6)+OPICOV,A4	; mm ^icnes verticaux	DBOX_	ICOAFF		; dessine les "soft-keys"	CALL	ALLSOFTKEY	; allume les "soft-keys" ncessaires	CALL	MAJSOFTKEY	; mj "soft-keys" si ncessaire	POP.L	A3	LIB	?AFMENU		; affiche les textes des soft-keys	POPM.L	A3..A5	RET	.END