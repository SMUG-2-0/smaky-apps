	.SBTTL	SEQDEBUGDEBUG:	PUSHM.L	D0..D6,A0..A5	LIB	?AFTIM	.B	EOP	.B	TRUNC	.B	ROLL	.B	0	.EVEN	LOAD.W	D3,#-1	LIB	?DISWKEY	LOAD.L	A5,(A6)+OPMBUF	; A5 <-- ^master buffer	LOAD.L	D5,(A6)+OLMBUF	; D5 <-- lg master buffer10$:	CLR.L	D1	LOAD.B	D1,(A5+)	SL.W	D1,#8	LOAD.B	D1,(A5+)	TEST.W	D1	JUMP,EQ 40$	SUB.L	D5,#2	SUB.L	D5,D1	LOAD.B	D3,(A5+)	CALL	DBGAFSTATUS	; affiche le status20$:	DEC.W	D1	JUMP,EQ 50$	CLR.L	D4	LOAD.B	D4,(A5+)	LOAD.W	D3,#4	CLR.W	D2	LIB	?AFDEC	LIB	?AFSPACE	JUMP	20$40$:	SUB.L	D5,#4	LIB	?AFTIM	.ASCIZ	"         Time ="	.EVEN	CLR.L	D4	LOAD.B	D4,(A5+)	SL.W	D4,#8	LOAD.B	D4,(A5+)	LOAD.W	D3,#4	CLR.W	D2	LIB	?AFDEC50$:	LIB	?AFCR	JUMP,NS 80$	TEST.L	D5	JUMP,GT 10$	LIB	?GETCAR80$:	CLR.W	D3	LIB	?DISWKEY	POPM.L	D0..D6,A0..A5	RET;------------\\; DBGAFSTATUS >;============/; Affiche en clair le premier byte de status.; in	D3.B	byte de status; out	-; mod	D7.WDBGAFSTATUS:	PUSHM.L	D2..D4,A3	COMP.B	D3,#H'F0	JUMP,HS 50$	LOAD.B	D4,D3	SR.B	D4,#4	CALL	AFB4	PUSH.W	D3	LIB	?AFTIM	.ASCIZ	"("	.EVEN	CLR.L	D4	LOAD.B	D4,D3	AND.B	D4,#H'0F	INC.B	D4	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDALL	LIB	?AFDEC		; affiche le canal midi (01..16)	LIB	?AFTIM	.ASCIZ	") "	.EVEN	POP.W	D3	LOAD.L	A3,#R16"00$	AND.B	D3,#H'F020$:	TEST.B	(A3)		; fin de la table ?	JUMP,EQ 30$		; oui => 30$	COMP.B	D3,(A3+)	JUMP,EQ 25$22$:	TEST.B	(A3+)		; A3 <-- saute .ASCIZ	JUMP,NE 22$	JUMP	20$25$:	LIB	?AFTEXT	JUMP	80$30$:	LOAD.B	D4,D3	LIB	?AFB8	LIB	?AFTIM	.ASCIZ	"??? "	.EVEN	JUMP	80$50$:	LOAD.B	D4,D3	LIB	?AFB8	LIB	?AFSPACE	LOAD.L	A3,#R16"01$60$:	TEST.B	(A3)		; fin de la table ?	JUMP,EQ 65$		; oui => 65$	COMP.B	D3,(A3+)	JUMP,EQ 65$62$:	TEST.B	(A3+)		; A3 <-- saute .ASCIZ	JUMP,NE 62$	JUMP	60$65$:	LIB	?AFTEXT80$:	POPM.L	D2..D4,A3	RET00$:	.B	H'80	.ASCIZ	"Note off         "	.B	H'90	.ASCIZ	"Note on/off      "	.B	H'A0	.ASCIZ	"Polyphonic key   "	.B	H'B0	.ASCIZ	"Control change   "	.B	H'C0	.ASCIZ	"Program change   "	.B	H'D0	.ASCIZ	"Channel pressure "	.B	H'E0	.ASCIZ	"Pitch bend       "	.B	001$:	.B	H'F0	.ASCIZ	"System exclusive "	.B	H'F2	.ASCIZ	"Song position    "	.B	H'F3	.ASCIZ	"Song select      "	.B	H'F6	.ASCIZ	"Tune request     "	.B	H'F7	.ASCIZ	"EOX              "	.B	H'F8	.ASCIZ	"Timing clock     "	.B	H'FA	.ASCIZ	"Start            "	.B	H'FB	.ASCIZ	"Continue         "	.B	H'FC	.ASCIZ	"Stop             "	.B	H'FE	.ASCIZ	"Active sensing   "	.B	H'FF	.ASCIZ	"System reset     "	.B	0	.B	AFINV	.ASCII	"Undefined        "	.B	AFDIR,0	.EVEN;--------\\; AFB4    >;========/; Affiche les 4 premiers bits de D4 en binaire.; in	D4.B; out	-; mod	D7.WAFB4:	PUSHM.L	D2..D4	LOAD.W	D2,#4-110$:	LOAD.B	D3,#'0	TEST.L	D4:#3	JUMP,BC 20$	INC.B	D320$:	LIB	?AFCAR	RL.B	D4,#1	DECJ.W,NMO D2,10$	POPM.L	D2..D4	RET	.END