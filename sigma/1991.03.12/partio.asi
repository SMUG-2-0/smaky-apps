	.SBTTL	PARTIODOPREND:	CLR.B	(A6)+OBUFILEDOPRENDL:	LOAD.L	A3,#(A6)+OBUFILE	CALL	DBOXEDITI	JUMP,NE IOERROR	COMP.W	D3,#F0	JUMP,EQ MAINDOPRENDF:	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXPART	CALL	ADDEXT		; A3 <-- ^nom du fichier .PART	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier	JUMP',EQ 20$	PUSH.W	D7	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	DOPRENDL20$:	CALL	RDOPEN	CALL	RDENTETE	; lit l'entte	JUMP',NE 80$	LOAD.L	(A6)+OPDT,(A6)+OPDB	LOAD.L	(A6)+OPFT,(A6)+OPFB	CLR.W	(A6)+ONBOBJ	CLR.W	(A6)+OMESM	CLR.W	(A6)+OMESC	CLR.W	D240$:	CALL	RDOBJET		; lit un objet	JUMP',NE 80$	CALL	INSERT		; insert l'objet	JUMP',NE 80$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP,NE 40$	INC.W	D2		; D2 <-- une mesure de plus	JUMP	40$80$:	PUSH.W	D7	CALL	RDCLOSE	POP.W	D7	COMP.W	D7,#EROUTF	JUMP,NE IOERROR	CALL	GETENTETE	; mj variables selon le header .PART lu	CALL	GETHEAD		; mj variables selon le header .MIDI lu82$:	CALL	PMESURE		; revient dans la premire mesure	JUMP,EQ 82$	CLR.W	(A6)+OMESC	CALL	INIPMES		; init OPMES	CALL	REFAIT		; refait le dessin de la mesure	JUMP	MAINDOAJOUTE:	CLR.B	(A6)+OBUFILE10$:	LOAD.L	A3,#(A6)+OBUFILE	CALL	DBOXEDITA	JUMP,NE IOERROR	COMP.W	D3,#F0	JUMP,EQ MAIN	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXPART	CALL	ADDEXT		; A3 <-- ^nom du fichier .PART	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier	JUMP',EQ 20$	PUSH.W	D7	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	10$20$:	CALL	RDOPEN	CALL	RDENTETE	; lit l'entte	JUMP',NE 80$	CLR.W	D240$:	CALL	RDOBJET		; lit un objet	JUMP',NE 80$	CALL	INSERT		; insert l'objet	JUMP',NE 80$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP,NE 40$	INC.W	D2		; D2 <-- une mesure de plus	JUMP	40$80$:	PUSH.W	D7	CALL	RDCLOSE	POP.W	D7	COMP.W	D7,#EROUTF	JUMP,NE IOERROR85$:	CALL	PMESURE		; revient dans la premire mesure lue	JUMP',NE 86$	DEC.W	D2	JUMP,NE 85$	CALL	NMESURE86$:	INC.W	(A6)+OMESC	CALL	INIPMES		; init OPMES	CALL	REFAIT		; refait le dessin de la mesure	JUMP	MAINDOSAUVE:	CALL	PUTENTETE	; OENTETE <-- mj selon les variables	CALL	PUTHEAD		; OHEAD <-- mj selon les variables	LOAD.L	D5,#2^BOUTPART10$:	LOAD.L	A3,#(A6)+OBUFILE	LOAD.L	D4,D5		; D4 <-- fanions	CALL	DBOXEDITO	JUMP,NE IOERROR	COMP.W	D3,#F0	JUMP,EQ MAIN	LOAD.L	D5,D4		; D5 <-- fanions	TEST.L	D5:#BOUTPART	; sauve le fichier .PART ?	JUMP,BC 50$		; non => 50$				; oui =>	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXPART	CALL	ADDEXT		; A3 <-- ^nom du fichier .PART20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	FOS	?CREATE		; cre le fichier	JUMP',EQ 30$		; ok => 30$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	IOERROR		; non => IOERROR				; oui =>	CALL	NORMMOUSE	; remet la flche	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	JUMP,NE IOERROR	COMP.W	D3,#'O	JUMP,NE 10$	FOS	?DELETE		; dtruit le fichier	JUMP,NE IOERROR	JUMP	20$30$:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP,NE IOERROR	CALL	WROPEN	LOAD.L	A4,#(A6)+OENTETE	LOAD.W	D4,#LENTETE	CALL	WRMANY		; crit l'en-tte .PART	JUMP',NE 45$	LOAD.L	A4,#(A6)+OHEAD	LOAD.W	D4,#LHEAD	CALL	WRMANY		; crit l'en-tte .MIDI	JUMP',NE 45$	LOAD.L	A4,(A6)+OPDB	ADD.L	A4,#2		; A4 <-- ^premier objet40$:	CALL	WROBJET		; crit un objet	JUMP',NE 45$	CALL	NVISU		; A4 <-- ^objet suivant	JUMP,EQ 40$	CLR.W	D745$:	CALL	WRCLOSE	JUMP,NE IOERROR50$:	LOAD.L	A3,#(A6)+OBUFILE	TEST.L	D5:#BOUTMIDI	; sauve le fichier .MIDI ?	JUMP,BC MAIN		; non => MAIN				; oui =>	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXMIDI	CALL	ADDEXT		; A3 <-- ^nom du fichier .MIDI60$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	FOS	?CREATE		; cre le fichier	JUMP',EQ 65$		; ok => 65$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	IOERROR		; non => IOERROR				; oui =>	CALL	NORMMOUSE	; remet la flche	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	JUMP,NE IOERROR	COMP.W	D3,#'O	JUMP,NE MAIN	FOS	?DELETE		; dtruit le fichier	JUMP,NE IOERROR	JUMP	60$65$:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP,NE IOERROR	CALL	WROPEN	LOAD.L	A4,#(A6)+OHEAD	LOAD.W	D4,#LHEAD	CALL	WRMANY		; crit l'en-tte .MIDI	JUMP,NE 90$	LOAD.W	D2,(A6)+OMESC	; D2 <-- mesure actuelle	CALL	REPINIT		; init pour les reprises	LOAD.W	(A6)+OTMMIDI,#OFNOTE75$:	CALL	MIDIMESURE	; OBUMIDI <-- notes de la mesure	JUMP',NE 80$	ADD.W	(A6)+OTMMIDI,D5	LOAD.L	A4,#(A6)+OBUMIDI	LOAD.W	D4,(A6)+OPTMIDI	CALL	WRMANY		; crit les commandes MIDI d'une mesure	JUMP',NE 80$	CALL	REPNEXT		; mesure suivante selon les reprises	JUMP,EQ 75$	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	LOAD.W	D4,D2		; D4 <-- mesure initiale	CALL	GOMESURE	; retourne dans la mesure initiale	POP.W	D790$:	CALL	WRCLOSE	PUSH.W	D7	CALL	REFAIT		; refait le dessin de la mesure	POP.W	D7	JUMP,NE IOERROR	JUMP	MAIN; in	A4.L	^objet rectangle dlimiteurDOIMAGE:	LOAD.L	A5,A4		; A5 <-- ^objet rectangle10$:	LOAD.L	A3,#(A6)+OBUFIMA	CALL	DBOXIMAGE	JUMP,NE IOERROR	COMP.W	D3,#F0	JUMP,EQ MAIN	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXIMA	CALL	ADDEXT		; A3 <-- ^nom du fichier .IMAGE20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	FOS	?CREATE		; cre le fichier image	JUMP',EQ 30$		; ok => 30$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	IOERROR		; non => IOERROR				; oui =>	CALL	NORMMOUSE	; remet la flche	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	JUMP,NE IOERROR	COMP.W	D3,#'O	JUMP,NE 10$	FOS	?DELETE		; dtruit le fichier	JUMP,NE IOERROR	JUMP	20$30$:	CALL	WAITMOUSE	; met le sablier	PUSH.W	D1	LOAD.W	D1,(A6)+ONCLEF	TCLR.L	D1:#SKCGRILLE	; grille visible ?	JUMP',BC 35$		; non => 35$	LOAD.W	(A6)+ONCLEF,D1	CALL	REFAIT		; refait tout sans grille	TSET.L	D1:#SKCGRILLE35$:	LIB	?GETWDO	LOAD.W	D2,D5		; D2 <-- swdo actuelle	LOAD.L	D3,(A5)+OGRPN1	LOAD.L	D4,(A5)+OGRPN2	CALL	ORDONNE		; D3 < D4	AND.L	D3,#H'FFFEFFF8	SUB.W	D4,D3		; D4 <-- largeur	ADD.W	D4,#8-1	AND.B	D4,#B'11111000	ADD.W	D3,(A0)+ODFFX	; D3 <-- origine en X	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur	ADD.W	D4,#1-1	AND.B	D4,#B'11111110	ADD.W	D3,(A0)+ODFFY	; D3 <-- origine en Y	SWAP.W	D3	SWAP.W	D4	LIB	?CREWDO	LIB	?USEWDO	CALL	CCMO		; enlve la souris	CLR.W	D3		; D3 <-- la swdo utilise	LIB	?PFDUMP		; crit le fichier image ...	PUSH.W	D7	CALL	SCMO		; remet la souris	PUSH.W	D5	LOAD.W	D5,D2	LIB	?USEWDO		; rutilise swdo originale	POP.W	D5	LIB	?KILWDO		; dtruit swdo pour l'image	TEST.L	D1:#SKCGRILLE	; grille tait visible ?	JUMP',BC 80$		; non => 80$	LOAD.W	(A6)+ONCLEF,D1	CALL	DESPORTEES	; refait juste les portes avec la grille80$:	POP.W	D7	POP.W	D1	TEST.W	D7	JUMP,NE IOERROR	JUMP	MAINDOEFFACE:	CALL	DBOXEFFACE	; Etes-vous sr ?	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE MAIN	JUMP	EFFACEIOERROR:	PUSH.W	D7	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	MAIN;---------\\; RDENTETE >;---------/; Lit l'entte du fichier .PART; in	-; out	D7.W	erreur; mod	D7.WRDENTETE:	PUSHM.L	D3,D4,A4	LOAD.L	A4,#(A6)+OENTETE	LOAD.W	D4,#LENTETE-121$:	CLR.B	(A4+)		; en-tte .PART <-- tout  zro !	DECJ.W,NMO D4,21$	LOAD.L	A4,#(A6)+OENTETE	LOAD.W	D4,#256-122$:	CALL	RDONE		; lit l'en-tte .PART (antrieure  1.0)	JUMP,NE 90$	LOAD.B	(A4+),D3	DECJ.W,NMO D4,22$	CALL	IFENTETE	; est-ce un bon fichier .PART ?	JUMP,NE 90$		; non => 90$	TEST.B	(A6)+OENTETE+OEREV ; rvision antrieure  1.0 ?	JUMP',EQ 25$		; oui => 25$	LOAD.W	D4,#LENTETE-256-123$:	CALL	RDONE		; lit la suite de l'en-tte .PART	JUMP',NE 90$	LOAD.B	(A4+),D3	DECJ.W,NMO D4,23$25$:	LOAD.L	A4,#(A6)+OHEAD	CALL	RDONE		; lit l'en-tte .MIDI	JUMP',NE 90$	LOAD.B	(A4+),D3	CALL	RDONE		; lit l'en-tte .MIDI	JUMP',NE 90$	LOAD.B	(A4+),D3	LOAD.W	D4,#LHEAD-2-1	COMP.W	(A6)+OHEAD+OHID,#-1	JUMP',EQ 26$	LOAD.W	D4,#256-2-126$:	CALL	RDONE		; lit la suite de l'en-tte .MIDI	JUMP',NE 90$	LOAD.B	(A4+),D3	DECJ.W,NMO D4,26$90$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; IFENTETE >;---------/; Vrifie si le fichier .PART est compatible avec ce programme.; in	-; out	D7.W	erreur; mod	D7.WIFENTETE:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OENTETE	LOAD.W	D7,#ERSYNT	; D7 <-- fichier incompatible !	COMP.W	(A4)+OEID,#-1	JUMP',NE 90$; La rvision-version du fichier ne doit pas tre suprieure ; la rvision-version du programme.	COMP.B	(A4)+OEREV,#MAJREV	JUMP',LO 50$	JUMP',HI 90$	COMP.B	(A4)+OEVERS,#MINREV	JUMP',HI 90$50$:	CLR.W	D7		; D7 <-- fichier compatible90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; GETENTETE >;----------/; Met  jour les variables en fonction du header .PART lu sur disque.; in	-; out	-; mod	D7.WGETENTETE:	PUSHM.L	D3,D4,A1..A4	LOAD.L	A4,#(A6)+OENTETE	LOAD.L	(A6)+ONOB,(A4)+OENOB	LOAD.B	(A6)+OFAPLAY+2,(A4)+OEPLAY	LOAD.W	D3,(A4)+OELXPOR	JUMP',NE 20$	LOAD.W	D3,#LXPORTEE20$:	LOAD.W	(A6)+OLXPORT,D3; Charge ou libre les gencars selon l'en-tte.	LOAD.L	A1,#(A4)+OEGC	LOAD.L	A2,#(A6)+OBUGC	LOAD.W	D4,#MAXGC-140$:	PUSHM.L	D4,A1,A2	LOAD.L	A1,#(A1)+4	LOAD.L	A2,#(A2)+OGCTIT	LOAD.W	D4,#LGTGC-141$:	LOAD.B	(A2+),(A1+)	; transfert le titre du gencar	DECJ.W,NMO D4,41$	POPM.L	D4,A1,A2	TEST.L	(A1)+0	JUMP',EQ 45$	CLR.B	(A1)+0	CLR.B	(A2)+OGCCOD	LOAD.L	D3,(A1)+0	COMP.L	D3,(A2)+OGCCOD	; mme gencar ?	JUMP',EQ 48$		; oui => 48$				; non =>	PUSHM.L	D4,A2..A4	LOAD.L	(A2)+OGCCOD,D3	LOAD.L	A4,A2		; A4 <-- ^gencar	LOAD.L	A3,#(A6)+OBUGC	; A3 <-- ^buffer des gencars	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A2,A0		; A2 <-- ^description de la fentre	DGENC_	NEW		; charge le nouveau gencar	POPM.L	D4,A2..A4	JUMP'	48$45$:	TEST.B	(A2)+OGCFLG:#BGCUSE	JUMP',BC 48$	PUSHM.L	D4,A2..A4	LOAD.L	A4,A2		; A4 <-- ^gencar	LOAD.L	A3,#(A6)+OBUGC	; A3 <-- ^buffer des gencars	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A2,A0		; A2 <-- ^description de la fentre	DGENC_	KILL		; libre le gencar inutile	POPM.L	D4,A2..A448$:	LOAD.L	A1,#(A1)+4+LGTGC	LOAD.L	A2,#(A2)+LGGC	DECJ.W,NMO D4,40$; Met  jour les variables pour l'impression.	TEST.L	(A4)+OEFAPRI	JUMP,EQ 90$	LOAD.L	(A6)+OFAPRI,(A4)+OEFAPRI	LOAD.W	(A6)+OIMFM,(A4)+OEIMFM	LOAD.W	(A6)+OIMLM,(A4)+OEIMLM	LOAD.L	A3,#(A4)+OETIT	LOAD.L	A2,#(A6)+OIMTM60$:	LOAD.B	(A2+),(A3+)	; OIMTM <-- titre	JUMP,NE 60$	LOAD.L	A3,#(A4)+OEEDI	LOAD.L	A2,#(A6)+OIMEM61$:	LOAD.B	(A2+),(A3+)	; OIMTM <-- diteur	JUMP,NE 61$	LOAD.L	A3,#(A4)+OEAUT	LOAD.L	A2,#(A6)+OIMAM62$:	LOAD.B	(A2+),(A3+)	; OIMTM <-- auteur	JUMP,NE 62$	LOAD.L	A3,#(A4)+OENPRES	LOAD.L	A2,#(A6)+ONPRES64$:	LOAD.B	(A2+),(A3+)	; ONPRES <-- nom de la prsentation	JUMP,NE 64$90$:	POPM.L	D3,D4,A1..A4	RET;----------\\; PUTENTETE >;----------/; Construit le header .PART en vue de la sauver sur disque.; in	-; out	-; mod	D7.WPUTENTETE:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A4,#(A6)+OENTETE	LOAD.W	D4,#LENTETE-110$:	CLR.B	(A4+)		; en-tte <-- rempli de zro	DECJ.W,NMO D4,10$	LOAD.L	A4,#(A6)+OENTETE	LOAD.W	(A4)+OEID,#-1	LOAD.B	(A4)+OEREV,#MAJREV	LOAD.B	(A4)+OEVERS,#MINREV	LOAD.L	(A4)+OENOB,(A6)+ONOB	LOAD.B	(A4)+OEPLAY,(A6)+OFAPLAY+2	LOAD.W	(A4)+OELXPOR,(A6)+OLXPORT; Met  jour les gnrateurs de caractres.	LOAD.L	A3,#(A6)+OBUGC	LOAD.L	A4,#(A4)+OEGC	LOAD.W	D4,#MAXGC-140$:	TEST.B	(A3)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BC 48$		    ; non => 48$	LOAD.L	(A4)+0,(A3)+OGCCOD ; en-tte <-- fst	PUSHM.L	D4,A3,A4	LOAD.L	A3,#(A3)+OGCTIT	LOAD.L	A4,#(A4)+4	LOAD.W	D4,#LGTGC-142$:	LOAD.B	(A4+),(A3+)	; en-tte <-- titre du gencar	DECJ.W,NMO D4,42$	POPM.L	D4,A3,A448$:	LOAD.L	A3,#(A3)+LGGC	LOAD.L	A4,#(A4)+4+LGTGC	DECJ.W,NMO D4,40$; Met  jour les variables pour l'impression.	LOAD.L	A4,#(A6)+OENTETE	LOAD.L	(A4)+OEFAPRI,(A6)+OFAPRI	LOAD.W	(A4)+OEIMFM,(A6)+OIMFM	LOAD.W	(A4)+OEIMLM,(A6)+OIMLM	LOAD.L	A3,#(A4)+OETIT	LOAD.L	A2,#(A6)+OIMTM60$:	LOAD.B	(A3+),(A2+)	; OETIT <-- titre	JUMP,NE 60$	LOAD.L	A3,#(A4)+OEEDI	LOAD.L	A2,#(A6)+OIMEM61$:	LOAD.B	(A3+),(A2+)	; OEEDI <-- diteur	JUMP,NE 61$	LOAD.L	A3,#(A4)+OEAUT	LOAD.L	A2,#(A6)+OIMAM62$:	LOAD.B	(A3+),(A2+)	; OEAUT <-- auteur	JUMP,NE 62$	LOAD.L	A3,#(A4)+OENPRES	LOAD.L	A2,#(A6)+ONPRES64$:	LOAD.B	(A3+),(A2+)	; OENPRES <-- nom de la prsentation	JUMP,NE 64$	POPM.L	D3,D4,A2..A4	RET;--------\\; GETHEAD >;--------/; Met  jour les variables en fonction du header .MIDI lu sur disque.; in	-; out	-; mod	D7.WGETHEAD:	PUSHM.L	D3,D4,A3,A4	COMP.W	(A6)+OHEAD+OHID,#-1	JUMP,NE 90$	LOAD.B	(A6)+OFAPLAY+3,(A6)+OHEAD+OHCHA	LOAD.W	D4,#MAXVIT	SUB.W	D4,(A6)+OHEAD+OHVIT	LOAD.W	(A6)+OASVIT+OSCPOSV,D4	LOAD.L	A4,#(A6)+OHEAD+OHTRK	LOAD.L	A3,#(A6)+OTRACK	LOAD.W	D4,#(NBTRACK*LT)-160$:	LOAD.B	(A3+),(A4+)	; OTRACK <-- selon header	DECJ.W,NMO D4,60$	CALL	SMAKYTRACK	; si pas de synth => met pistes sur le Smaky90$:	POPM.L	D3,D4,A3,A4	RET;--------\\; PUTHEAD >;--------/; Construit le header .MIDI en vue de la sauver sur disque.; in	-; out	-; mod	D7.WPUTHEAD:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,#(A6)+OHEAD	LOAD.W	D4,#LHEAD-110$:	CLR.B	(A4+)		; header <-- rempli de zro	DECJ.W,NMO D4,10$	LOAD.L	A4,#(A6)+OHEAD	LOAD.W	(A4)+OHID,#-1	LOAD.B	(A4)+OHREV,#MAJREV	LOAD.B	(A4)+OHVERS,#MINREV	LOAD.B	(A4)+OHCHA,(A6)+OFAPLAY+3	LOAD.W	D4,#MAXVIT	SUB.W	D4,(A6)+OASVIT+OSCPOSV ; D4 <-- vitesse (-MAXVIT..+MAXVIT)	LOAD.W	(A4)+OHVIT,D4	LOAD.L	A4,#(A6)+OHEAD+OHTRK	LOAD.L	A3,#(A6)+OTRACK	LOAD.W	D4,#(NBTRACK*LT)-140$:	LOAD.B	(A4+),(A3+)	; header <-- OTRACK	DECJ.W,NMO D4,40$	POPM.L	D3,D4,A3,A4	RET;--------\\; ADDEXT  >;========/; Transfert le nom de fichier dans OBXFILE et force une extension.; in	A3.L	^nom sans extension;	A4.L	^extension  ajouter; out	A3.L	^nom avec extension (dans OBXFILE); mod	D7.W, A3.LADDEXT:	PUSHM.L	D3,A2	LOAD.L	A2,#(A6)+OBXFILE10$:	LOAD.B	(A2+),(A3+)	; OBXFILE <-- nom du fichier	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBXFILE	TEST.B	(A3)	JUMP',EQ 90$	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension90$:	POPM.L	D3,A2	RET;--------\; RDOPEN  >;========/; Ouvre le fichier en entre.; in	D6.W	canal; out	-; mod	-RDOPEN:	LOAD.W	(A6)+OCHIO,D6	; mm. canal	LOAD.W	(A6)+OPTIO,#LTMIO	RET;--------\\; RDOBJET >;========/; Lit un objet dans le fichier d'entre.; in	-; out	A4.L	^objet;	D4.W	longueur de l'objet;	D7.W	erreur; mod	D4.L, D7.W, A4.LRDOBJET:	PUSHM.L	D2,D3,A3	CALL	RDONE		; D3 <-- lg (high)	JUMP,NE 90$	LOAD.B	D4,D3	SL.W	D4,#8	CALL	RDONE		; D3 <-- lg (low)	JUMP,NE 90$	LOAD.W	D4,D3		; D4 <-- lg	LOAD.W	D2,D3	LOAD.L	A4,#(A6)+OOBIO10$:	CALL	RDONE	JUMP,NE 90$	LOAD.B	(A4+),D3	; lit tous les bytes de l'objet	DEC.W	D2	JUMP,NE 10$50$:	LOAD.B	D3,(A6)+OOBIO+OOBJC ; D3 <-- code de l'objet lu	LOAD.L	A3,#R16"TAINLG-455$:	ADD.L	A3,#4	COMP.W	(A3),#-1	; fin de la table ?	JUMP,EQ 70$		; oui => 70$	COMP.B	D3,(A3)+0	JUMP,LO 55$	COMP.B	D3,(A3)+1	JUMP,HS 55$	COMP.W	D4,(A3)+2	; lg conforme ?	JUMP,HS 70$		; oui => 70$				; non =>	LOAD.W	D2,(A3)+2	SUB.W	D2,D4		; D2 <-- lg manquante60$:	CLR.B	(A4+)		; complte par des zro !	DEC.W	D2	JUMP,NE 60$	LOAD.W	D4,(A3)+2	; D4 <-- nouvelle longueur70$:	LOAD.L	A4,#(A6)+OOBIO	; A4 <-- ^objet lu90$:	POPM.L	D2,D3,A3	TEST.W	D7		; retour EQ/NE	RETTAINLG:	.BBW	0,ICODROITE		LSY	.BBW	ICODROITE,ICOTEXTE	LGR	.BBW	OBJMES,OBJMES+1		LME	.W	-1;--------\; RDONE   >;========/; Lit un byte dans le fichier d'entre.; in	-; out	D3.B	byte lu;	D7.W	erreur; mod	D3.L, D7.WRDONE:	PUSHM.L	D4,D6,A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^buffer tampon	COMP.W	(A6)+OPTIO,#LTMIO ; reste qq chose ?	JUMP',LO 50$		; oui => 50$				; non =>	LOAD.L	D4,#LTMIO	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?RDBYTE		; lit tout le buffer	LOAD.W	(A6)+ONBIO,#-1	CLR.W	(A6)+OPTIO	; buffer vide	TEST.W	D7		; lecture ok ?	JUMP',EQ 50$		; oui => 50$	COMP.W	D7,#EROUTF	; fin du fichier ?	JUMP',NE 90$		; non => 90$	CLR.W	D7		; D7 <-- ok pour l'instant	LOAD.W	(A6)+ONBIO,D4	; mm. lg dernire tranche50$:	TEST.W	(A6)+ONBIO	; reste qq chose ?	JUMP',NE 60$		; oui => 60$	LOAD.W	D7,#EROUTF	; D7 <-- fin du fichier	JUMP'	90$60$:	LOAD.W	D4,(A6)+OPTIO	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- un byte du buffer	INC.W	(A6)+OPTIO	; avance "pointeur"	DEC.W	(A6)+ONBIO	; diminue reste90$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; RDCLOSE >;========/; Ferme le fichier en entre.; in	-; out	D7.W	erreur; mod	D7.WRDCLOSE:	PUSH.L	D6	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?CLOSE		; ferme le fichier	POP.L	D6	TEST.W	D7		; retour EQ/NE	RET;--------\; WROPEN  >;========/; Ouvre le fichier en sortie.; in	D6.W	canal; out	-; mod	-WROPEN:	LOAD.W	(A6)+OCHIO,D6	; mm. canal	CLR.W	(A6)+OPTIO	; buffer vide	RET;--------\\; WROBJET >;========/; Ecrit un objet dans le fichier en sortie.; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WWROBJET:	PUSHM.L	D4,A4	SUB.L	A4,#2	LOAD.W	D4,(A4)	ADD.W	D4,#2		; D4 <-- lg pour <<lg>><bytes..>	CALL	WRMANY		; crit un objet	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; WRMANY  >;========/; Ecrit plusieurs bytes dans le fichier de sortie.; in	A4.L	^bytes  crire;	D4.W	nombre de bytes  crire; out	D7.W	erreur; mod	D7.WWRMANY:	PUSHM.L	D3,D4,D6,A3,A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A3,A4		; A3 <-- ^bytes  crire	LOAD.W	D3,D4		; D3 <-- nombre	JUMP,EQ 90$10$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OPTIO	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer20$:	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4+),(A3+)	; buffer <-- un byte	INC.W	D4		; D4 <-- un byte de plus	DEC.W	D3	JUMP,NE	20$	LOAD.W	(A6)+OPTIO,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OPTIO	; signal buffer vide	JUMP	10$90$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; WRONE   >;========/; Ecrit un byte dans le fichier de sortie.; in	D3.B	byte  crire; out	D7.W	erreur; mod	D7.WWRONE:	PUSHM.L	D4,D6,A410$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OPTIO	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4),D3		; buffer <-- le byte	INC.W	D4		; D4 <-- un byte de plus	LOAD.W	(A6)+OPTIO,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OPTIO	; signal buffer vide	JUMP	10$90$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; WRCLOSE >;========/; Ecrit le reste du fichier de sortie, puis ferme.; in	D7.W	ok/erreur; out	D7.W	erreur; mod	D7.WWRCLOSE:	PUSHM.L	D4..D6,A4	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	LOAD.W	D5,D7		; D5 <-- ok/erreur	JUMP',NE 50$		; erreur => 50$				; ok =>	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^buffer tampon	CLR.L	D4	LOAD.W	D4,(A6)+OPTIO	; D4 <-- nb bytes dans buffer	JUMP',EQ 50$		; si vide => 50$				; si reste qq chose =>	FOS	?WRBYTE		; crit tout le buffer50$:	FOS	?CLOSE		; ferme le fichier	COMP.W	D7,D5	JUMP',HS 90$	LOAD.W	D7,D5		; D7 <-- erreur la plus grve !90$:	POPM.L	D4..D6,A4	TEST.W	D7		; retour EQ/NE	RET; Textes; ------TEXPART:.ASCIZ	".part"		; extension pour les partitionsTEXMIDI:.ASCIZ	".midi"		; extension pour les morceauxTEXIMA:	.ASCIZ	".image"	; extension pour les images	.EVEN	.END