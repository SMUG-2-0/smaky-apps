	.SBTTL	DXEG; Constantes; ----------	.IF	DX7EGNBX	=	3		; nb d'enveloppe en XEGNBY	=	2		; nb d'enveloppe en YEGLGX	=	176		; largeur d'une enveloppe (divisible par 8)EGLGY	=	100		; hauteur d'une enveloppeEGMARGE	=	8		; marges gauche/droite/sup/infLXKEYON	=	24		; longueur du palier "key-on"	.ENDIF	.IF	DX100EGNBX	=	2		; nb d'enveloppe en XEGNBY	=	2		; nb d'enveloppe en YEGLGX	=	280		; largeur d'une enveloppe (divisible par 8)EGLGY	=	100		; hauteur d'une enveloppeEGMARGE	=	8		; marges gauche/droite/sup/infLXKEYON	=	0		; longueur du palier "key-on"	.ENDIF	.IF	FB01EGNBX	=	2		; nb d'enveloppe en XEGNBY	=	2		; nb d'enveloppe en YEGLGX	=	280		; largeur d'une enveloppe (divisible par 8)EGLGY	=	100		; hauteur d'une enveloppeEGMARGE	=	8		; marges gauche/droite/sup/infLXKEYON	=	0		; longueur du palier "key-on"	.ENDIF;--------\\; EGEDIT  >;========/; in	A2.L	^timbre  diter;	D1.B	GDSEG/GDSEGP; out	-; mod	D7.WEGEDIT:	PUSHM.L	D1..D5,A3,A4	LOAD.B	(A6)+OEGTYP,D1	.IF	DX7	LOAD.W	(A6)+OEGSCA,#+1	.ENDIF	.IF	DX100	LOAD.W	(A6)+OEGSCA,#-1	.ENDIF	.IF	FB01	LOAD.W	(A6)+OEGSCA,#-1	.ENDIF	CALL	EGCADRES	; dessine les cadres	CALL	EGALLCOURBES	; dessine toutes les courbesEGLOOP:	LIB	?GETCAR		; attend clavier souris ...	COMP.W	D3,#KEYMGR	JUMP,EQ EGLOOP	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ EGLOOP		; oui => EGLOOP	COMP.W	D3,#KEYMDR	JUMP,EQ EGLOOP	LOAD.L	A3,#R16"TICOEG	LOAD.L	A4,#0	DBOX_	ICODET		; dtecte o est la souris	JUMP,EQ EGSOFTKEY	COMP.W	D3,#KEYMGP	JUMP,EQ EGGAUCHE	COMP.W	D3,#UNDO	JUMP,EQ EGUNDOEGBIP:				; touche incorrecte =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	EGLOOPEGSOFTKEY:	TEST.W	D2	JUMP,EQ	EGFINI	COMP.W	D2,#1	JUMP,EQ 20$	COMP.W	D2,#4	JUMP,EQ 30$	JUMP	EGBIP20$:				; diminue l'chelle =>	COMP.W	(A6)+OEGSCA,#+1	JUMP,EQ EGBIP	CALL	EGALLCOURBES	; efface toutes les courbes	INC.W	(A6)+OEGSCA	CALL	EGALLCOURBES	; redessine toutes les courbes	JUMP	EGLOOP30$:				; augmente l'chelle =>	COMP.W	(A6)+OEGSCA,#-2	JUMP,EQ EGBIP	CALL	EGALLCOURBES	; efface toutes les courbes	DEC.W	(A6)+OEGSCA	CALL	EGALLCOURBES	; redessine toutes les courbes	JUMP	EGLOOPEGUNDO:				; UNDO =>	CALL	WAITMOUSE	; met le sablier	CALL	EGALLCOURBES	; efface toutes les courbes	LOAD.L	A1,#R16"TDSDX71	LOAD.B	D1,(A6)+OEGTYP20$:	COMP.B	D1,(A1)+ODSGRA	; bonne reprsentation graphique ?	JUMP,NE 40$		; non => 40$	PUSH.L	A2	LOAD.L	A2,#(A6)+OBUE	CALL	DSGETNUM	; D4 <-- valeur initiale	POP.L	A2	CALL	DSPUTNUM	; remet la valeur initiale40$:	CALL	DSNEXT		; A1 <-- ^objet suivant	JUMP,EQ 20$	CALL	EGALLCOURBES	; redessine toutes les courbes	CALL	NORMMOUSE	; remet la flche	JUMP	EGLOOPEGGAUCHE:			; [GAUCHE] =>	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE EGBIP	SUB.W	D4,(A0)+ODFFX	JUMP,LO EGBIP	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP,LO EGBIP	SWAP.W	D4	CALL	EGDETECTE	; D2 <-- courbe;point o est la souris	JUMP,NE EGBIP20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP,NE 30$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	SUB.W	D4,(A0)+ODFFX	JUMP,LO 20$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP,LO 20$	SWAP.W	D4	CALL	EGINVCOURBE	; efface la courbe	LOAD.L	D3,D4	CALL	EGPUTPOINT	CALL	EGINVCOURBE	; dessine la nouvelle courbe	JUMP	20$30$:	.IF	DX7	CALL	EGGETNIVTAU	; D3 <-- niveau;taux	LOAD.L	D4,D3		; D4 <-- niveau;taux	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..5,6)	COMP.W	D3,#EGNBX*EGNBY	JUMP,EQ 32$	MUL.WU	D3,#21	JUMP	35$32$:	LOAD.W	D3,#12635$:	ADD.W	D3,D2	SUB.W	D4,#99	NEG.W	D4	CALL	MODPARAM	; modifie le taux dans le DX7	ADD.W	D3,#4	SWAP.W	D4	SUB.W	D4,#99	NEG.W	D4	CALL	MODPARAM	; modifie le niveau dans le DX7	JUMP	EGLOOP	.ENDIF	.IF	DX100	LOAD.L	A3,A2	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..3)	MUL.WU	D3,#10	ADD.L	A3,D3		; A3 <-- ^le bon oprateur	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..3)	MUL.WU	D3,#13	LOAD.W	D2,#5-1		; D2 <-- 5 paramtres (AR, D1R, D2R, RR et D1L)40$:	CLR.W	D4	LOAD.B	D4,(A3+)	CALL	MODPARAM	; modifie l'un des 5 paramtres	INC.W	D3	DECJ.W,NMO D2,40$	JUMP	EGLOOP	.ENDIF	.IF	FB01	LOAD.L	A3,A2	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..3)	MUL.WU	D3,#10	ADD.L	A3,D3		; A3 <-- ^le bon oprateur	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..3)	MUL.WU	D3,#13	LOAD.W	D2,#5-1		; D2 <-- 5 paramtres (AR, D1R, D2R, RR et D1L)40$:	CLR.W	D4	LOAD.B	D4,(A3+)	CALL	MODPARAM	; modifie l'un des 5 paramtres	INC.W	D3	DECJ.W,NMO D2,40$	JUMP	EGLOOP	.ENDIFEGFINI:	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.W	D5,(A6)+OEGWDO	LIB	?KILWDO		; puis dtruit swdo dans le cadre	POPM.L	D1..D5,A3,A4	RET;---------\\; EGCADRES >;=========/; Dessine les cadres pour toutes les enveloppes.; in	-; out	-; mod	D7.WEGCADRES:	PUSHM.L	D0..D5,A3,A4	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	EOP		; efface tout	.B	MAPTT	.B	B'01010101	; <map>	.B	1		; <chelle>	.B	0	.EVEN	LOAD.L	A3,#R16"TICOEG	LOAD.L	A4,#0	DBOX_	ICOCADRE	; dessine le cadre autour	DBOX_	ICOAFF		; dessine les soft-keys	PUSHM.L	D3,D4	LOAD.L	A3,#R16"TMENUEG	LIB	?AFMENU	CLR.L	D3	LIB	?SETCURS	; positionne en tout en haut  gauche	LIB	?AFTIM	.B	AFINV		; en inverse vido	.B	SPACE		; toujours un espace	.B	0	.EVEN	COMP.B	(A6)+OEGTYP,#GDSEGP	JUMP,EQ 10$	LIB	?AFTIM	.ASCIZ	"Edite les enveloppes               "	.EVEN	JUMP	15$10$:	LIB	?AFTIM	.ASCIZ	"Edite l'enveloppe de la frquence  "	.EVEN15$:	LIB	?AFTIM	.ASCII	"     "	.ASCII	"| positionne|           |           |"		 ;           ;           ;           ;	.B	AFDIR		; remet vido normale	.B	0	.EVEN	POPM.L	D3,D4	LIB	?CREWDO		; cre swdo dans le cadre	LIB	?USEWDO		; utilise swdo	LOAD.W	(A6)+OEGWDO,D5	CALL	EGINIT		; init les variables	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit une trame pleine	LIB	?BUCAR	LOAD.L	A3,#(A6)+OTAEG	; A3 <-- ^table des enveloppes	LOAD.W	D0,#EGNBX*EGNBY	COMP.B	(A6)+OEGTYP,#GDSEGP	JUMP,NE 18$	LOAD.L	A3,#(A3)+LEG*6	; A3 <-- ^table de l'enveloppe de la hauteur	LOAD.W	D0,#118$:	LOAD.W	D5,(A0)+ODFC1Y	ADD.W	D5,(A0)+ODFC2Y	ADD.W	D5,#3		; D5 <-- hauteur pour ligne de texte; Dessine le rectangle ombr autour de l'enveloppe.20$:	LOAD.L	D3,(A3)+OEGPOS	SUB.W	D3,#EGMARGE	SWAP.W	D3	SUB.W	D3,#EGMARGE	SUB.W	D3,D5	SWAP.W	D3	LOAD.L	D4,(A3)+OEGDIM	ADD.W	D4,#(EGMARGE*2)-1	SWAP.W	D4	ADD.W	D4,#(EGMARGE*2)-1	ADD.W	D4,D5	SWAP.W	D4	LOAD.W	D2,#SETDOT	LOAD.W	D1,#3		; D1 <-- paisseur de l'ombre	LIB	?DRRECTO	; dessine un rectangle ombr	SWAP.W	D3	ADD.W	D3,D5	SWAP.W	D3	AND.L	D4,#H'FFFF	PUSH.L	D3	LIB	?DRSEG		; dessine une ligne verticale de sparation	POP.L	D3	ADD.W	D3,#EGMARGE	SWAP.W	D3	SUB.W	D3,(A0)+ODFC2Y	DEC.W	D3	SWAP.W	D3	LIB	?SETCURS	COMP.B	(A6)+OEGTYP,#GDSEGP	JUMP,EQ 23$	LIB	?AFTIM	.ASCIZ	"Oprateur "	.EVEN	LOAD.B	D3,D0	.IF	DX100	COMP.B	D3,#2	JUMP,LO 22$	COMP.B	D3,#3	JUMP,HI 22$	TNOT.L	D3:#0		; 2 <--> 322$:	.ENDIF	.IF	FB01	COMP.B	D3,#2	JUMP,LO 22$	COMP.B	D3,#3	JUMP,HI 22$	TNOT.L	D3:#0		; 2 <--> 322$:	.ENDIF	ADD.W	D3,#'0		; D3 <-- 6..1	LIB	?AFCAR	JUMP	25$23$:	LIB	?AFTIM	.ASCIZ	"Frquence"	.EVEN; Dessine les lignes pointilles horizontales.25$:	LOAD.L	D3,(A3)+OEGPOS	DEC.W	D3	CLR.L	D4	LOAD.W	D4,(A3)+OEGDIM+2	INC.W	D4	LOAD.W	D2,#SETDOT!TTTDOT	LOAD.W	D1,#2+130$:	PUSH.L	D3	LIB	?DRSEG		; dessine une ligne horizontale pointille	POP.L	D3	SWAP.W	D3	ADD.W	D3,#EGLGY/2	SWAP.W	D3	DEC.W	D1	JUMP,NE 30$; Dessine les lignes pointilles verticales.	LOAD.L	D3,(A3)+OEGPOS	DEC.W	D3	LOAD.W	D4,(A3)+OEGDIM+0	INC.W	D4	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT!TTTDOT	LOAD.W	D1,#4+140$:	PUSH.L	D3	LIB	?DRSEG		; dessine une ligne verticale pointille	POP.L	D3	ADD.W	D3,#EGLGX/4	DEC.W	D1	JUMP,NE 40$	LOAD.L	A3,#(A3)+LEG	; A3 <-- ^enveloppe suivante	DEC.W	D0	JUMP,NE 20$	LIB	?NOBUCAR	POPM.L	D0..D5,A3,A4	RET;--------\\; EGINIT  >;--------/; Initialise la table pour les enveloppes.; in	-; out	D7.W	erreur; mod	D7.WEGINIT:	PUSHM.L	D0..D5,A3	LOAD.W	D7,#1		; D7 <-- impossible (trop petit)	CLR.L	D1	LOAD.W	D1,(A0)+ODFFDX	DIV.WU	D1,#EGNBX	LOAD.W	D0,D1	SUB.W	D0,#EGLGX+EGMARGE*3	JUMP,LO 90$	SR.W	D0,#1	ADD.W	D0,#EGMARGE	LOAD.W	D5,(A0)+ODFC1Y	ADD.W	D5,(A0)+ODFC2Y	ADD.W	D5,#3		; D5 <-- hauteur pour ligne de texte	CLR.L	D3	LOAD.W	D3,(A0)+ODFFDY	DIV.WU	D3,#EGNBY	LOAD.W	D2,D3	SUB.W	D2,D5	SUB.W	D2,#EGLGY+EGMARGE*2	JUMP,LO 90$	SR.W	D2,#1	ADD.W	D2,#EGMARGE;;?	SR.W	D5,#1	ADD.W	D2,D5	LOAD.L	A3,#(A6)+OTAEG	; A3 <-- ^table des enveloppes	LOAD.W	D4,#EGNBY20$:	PUSH.W	D0	LOAD.W	D5,#EGNBX30$:	LOAD.W	(A3)+OEGPOS+2,D0	LOAD.W	(A3)+OEGPOS+0,D2	LOAD.W	(A3)+OEGDIM+2,#EGLGX	LOAD.W	(A3)+OEGDIM+0,#EGLGY	ADD.W	D0,D1	LOAD.L	A3,#(A3)+LEG	; A3 <-- ^enveloppe suivante	DEC.W	D5	JUMP,NE 30$	POP.W	D0	ADD.W	D2,D3	DEC.W	D4	JUMP,NE 20$; Initialise pour l'enveloppe de hauteur.	LOAD.W	D0,(A0)+ODFFDX	SR.W	D0,#1	SUB.W	D0,#(EGLGX+EGMARGE*2)/2	ADD.W	D0,#EGMARGE	LOAD.W	(A3)+OEGPOS+2,D0	LOAD.W	D0,(A0)+ODFFDY	SR.W	D0,#1	SUB.W	D0,#(EGLGY+EGMARGE*2)/2	ADD.W	D0,#EGMARGE	LOAD.W	(A3)+OEGPOS+0,D0	LOAD.W	(A3)+OEGDIM+2,#EGLGX	LOAD.W	(A3)+OEGDIM+0,#EGLGY	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D5,A3	TEST.W	D7		; retour EQ/NE	RET;-------------\\; EGALLCOURBES >;=============/; Inverse toutes les courbes.; in	A2.L	^timbre; out	-; mod	D7.WEGALLCOURBES:	PUSH.L	D2	COMP.B	(A6)+OEGTYP,#GDSEGP	JUMP,EQ 50$	CLR.W	D220$:	SWAP.W	D2	CALL	EGINVCOURBE	; dessine toutes les courbes	SWAP.W	D2	INC.W	D2	COMP.W	D2,#EGNBX*EGNBY	JUMP,LO 20$	JUMP	90$50$:	LOAD.W	D2,#EGNBX*EGNBY	SWAP.W	D2	CALL	EGINVCOURBE	; dessine la courbe de hauteur90$:	POP.L	D2	RET;-------------\\; EGINVCOURBE  >;=============/; Inverse toute la courbe d'une enveloppe.; in	A2.L	^timbre;	D2.L	courbe;rien (0..5,6;--); out	-; mod	D7.WEGINVCOURBE:	PUSHM.L	D0..D4,A3	LIB	?BUCAR	LOAD.L	A3,#(A6)+OTAEG	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..5,6)	MUL.WU	D3,#LEG	ADD.L	A3,D3		; A3 <-- ^dans OTAEG	LOAD.L	D4,(A3)+OEGPOS	SWAP.W	D4	ADD.W	D4,#EGLGY-1	SWAP.W	D4		; D4 <-- point initial	COMP.B	(A6)+OEGTYP,#GDSEGP	JUMP,NE 10$	LOAD.L	D4,(A3)+OEGPOS	SWAP.W	D4	ADD.W	D4,#(EGLGY/2)-1	SWAP.W	D4		; D4 <-- point initial10$:	LOAD.W	D1,(A3)+OEGPOS+2	ADD.W	D1,(A3)+OEGDIM+2 ; D1 <-- position  l'extrme droite	CLR.W	D2		; D2 <-- no des points (0..3)20$:	COMP.B	(A6)+OEGTYP,#GDSEGP	JUMP,EQ 30$	COMP.W	D2,#3	JUMP,NE 30$	LOAD.L	D3,D4	ADD.W	D3,#LXKEYON	; D3 <-- point au bout du palier "key-on"	LIB	?AFTIM	.B	MAPTT	.B	B'00110011	; <map>	.B	1		; <chelle>	.B	0	.EVEN	COMP.W	D3,D1		; dpasse  droite ?	JUMP,HI 51$		; oui => 51$	PUSHM.L	D1..D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	EX.L	D3,D4	LOAD.W	D2,#INVDOT!TTTDOT ; D2 <-- mode de dessin	LOAD.W	D1,#2		; D1 <-- paisseur	CALL	EGDRSEG		; dessine le palier horizontal "key-on"	POPM.L	D1..D4	LOAD.L	D4,D330$:	CALL	EGGETPOINT	; D3 <-- coordonne d'un point	COMP.W	D3,D1		; dpasse  droite ?	JUMP,HI 50$		; oui => 50$	PUSHM.L	D1..D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	EX.L	D3,D4	LOAD.W	D2,#INVDOT	; D2 <-- mode de dessin	LOAD.W	D1,#2		; D1 <-- paisseur	CALL	EGDRSEG		; dessine un segment de droite	POPM.L	D1..D4	PUSHM.L	D2..D4	COMP.W	D2,#3	JUMP,EQ 46$	COMP.W	D2,#2	JUMP,EQ 44$	COMP.W	D2,#1	JUMP,EQ 42$				; point 1 =>	LOAD.W	D4,#6		; D4 <-- rayon	LOAD.W	D2,#INVDOT	; D2 <-- mode de dessin	LIB	?DRCERCLE	; dessine un cercle	JUMP	48$42$:				; point 2 =>	SUB.W	D3,#6/2+1	SWAP.W	D3	SUB.W	D3,#6/2+1	SWAP.W	D3	LOAD.W	D4,#6+1+2	SWAP.W	D4	LOAD.W	D4,#6+1+2	LOAD.W	D2,#INVDOT	; D2 <-- mode de dessin	LIB	?DRRECT		; dessine un carr vide	JUMP	48$44$:				; point 3 =>	SUB.W	D3,#6/2	SWAP.W	D3	SUB.W	D3,#6/2	SWAP.W	D3	LOAD.W	D4,#6+1	SWAP.W	D4	LOAD.W	D4,#6+1	LOAD.W	D2,#INVDOT	; D2 <-- mode de dessin	LIB	?DRRECT		; dessine un carr vide	JUMP	48$46$:				; point 4 =>	SUB.W	D3,#6/2	SWAP.W	D3	SUB.W	D3,#6/2	SWAP.W	D3	LOAD.W	D4,#6+1+1	SWAP.W	D4	LOAD.W	D4,#6+1+1	LOAD.W	D2,#INVDOT	; D2 <-- mode de dessin	LIB	?DRMATRIX	; dessine un carr plein48$:	POPM.L	D2..D4	LOAD.L	D4,D3	INC.W	D2	COMP.W	D2,#4	JUMP,LO 20$	JUMP	80$; Dessine un dernier segment tronqu  droite.50$:	LOAD.W	D2,#INVDOT	; D2 <-- mode de dessin	JUMP	52$51$:	LOAD.W	D2,#INVDOT!TTTDOT ; D2 <-- mode de dessin52$:	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	EX.L	D3,D4	SUB.W	D1,D3	LOAD.W	D0,D1		; D0 <-- dx	SWAP.W	D4	MUL.WA	D1,D4	SWAP.W	D4	DIV.WA	D1,D4		; D1 <-- (dx*D4y)/D4x	LOAD.W	D4,D1		; D4 <-- dy	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dx	LOAD.W	D1,#2		; D1 <-- paisseur	CALL	EGDRSEG		; dessine un dernier segment de droite80$:	LIB	?NOBUCAR	POPM.L	D0..D4,A3	RET;--------\\; EGDRSEG >;========/; Dessine une ligne d'paisseur quelconque.; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode;	D1.W	paisseur (1..n); out	-; mod	D7.WEGDRSEG:	PUSHM.L	D0..D5	LOAD.W	D5,D1		; D5 <-- paisseur20$:	PUSH.L	D3	LIB	?DRSEG		; dessine une droite	POP.L	D3	LOAD.W	D0,D4	JUMP,NC 40$	NEG.W	D0		; D0 <-- |dx|40$:	LOAD.L	D1,D4	SWAP.W	D1	TEST.W	D1	JUMP,NC 45$	NEG.W	D1		; D1 <-- |dy|45$:	INC.W	D3		; D3 <-- pousse  droite	COMP.W	D0,D1	JUMP,LS 50$	DEC.W	D3	SWAP.W	D3	INC.W	D3		; D3 <-- pousse en bas	SWAP.W	D350$:	DEC.W	D5	JUMP,NE 20$	POPM.L	D0..D5	RET;----------\\; EGDETECTE >;==========/; Dtecte dans quel point est la souris.; in	D4.L	position de la souris (y;x); out	D2.L	courbe;point (0..5,6;0..3);	D7.W	erreur; mod	D2.L, D7.WEGDETECTE:	PUSHM.L	D3..D5	LOAD.W	D5,D4		; D5 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	LOAD.W	D2,#(EGNBX*EGNBY)-1	COMP.B	(A6)+OEGTYP,#GDSEGP	JUMP,NE 05$	INC.W	D205$:	SWAP.W	D210$:	LOAD.W	D2,#4-120$:	CALL	EGGETPOINT	; D3 <-- coordonne du point	CLR.W	D7		; D7 <-- ok	SUB.W	D3,#6/2	COMP.W	D5,D3		; trop  gauche ?	JUMP,LO 50$	ADD.W	D3,#6+1	COMP.W	D5,D3		; trop  droite ?	JUMP,HS 50$	SWAP.W	D3	SUB.W	D3,#6/2	COMP.W	D4,D3		; trop en haut ?	JUMP,LO 50$	ADD.W	D3,#6+1	COMP.W	D4,D3		; trop en bas ?	JUMP,LO 90$50$:	DEC.W	D2		; D2 <-- point prcdent	JUMP,NC 20$	COMP.B	(A6)+OEGTYP,#GDSEGP	JUMP,EQ 80$	SWAP.W	D2	DEC.W	D2		; D2 <-- courbe prcdente	LOAD.W	D3,D2	SWAP.W	D2	TEST.W	D3	JUMP,NC 10$80$:	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POPM.L	D3..D5	TEST.W	D7		; retour EQ/NE	RET	.IF	DX7;-----------\\; EGGETPOINT >;===========/; Donne les coordonnes graphiques d'un point.; in	A2.L	^timbre;	D2.L	courbe;point (0..5,6;0..3); out	D3.L	coordonne du point (y;x); mod	D3.LEGGETPOINT:	PUSHM.L	D1,D2,D4,A3	LOAD.L	A3,#(A6)+OTAEG	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..5,6)	MUL.WU	D3,#LEG	ADD.L	A3,D3		; A3 <-- ^dans OTAEG	CALL	EGGETNIVTAU	; D3 <-- niveau;taux	LOAD.L	D4,D3	LOAD.W	D1,D210$:	DEC.W	D2	JUMP,NS 20$	CALL	EGGETNIVTAU	; D3 <-- niveau;taux	ADD.W	D4,D3		; D4 <-- ajoute les points prcdents	JUMP	10$20$:	LOAD.L	D3,D4	SWAP.W	D3	ADD.W	D3,(A3)+OEGPOS+0	SWAP.W	D3	LOAD.W	D2,(A6)+OEGSCA	JUMP,EQ 56$	JUMP,NS 54$	SR.W	D3,D2	JUMP	56$54$:	NEG.W	D2	SL.W	D3,D256$:	COMP.B	(A6)+OEGTYP,#GDSEGP	JUMP,EQ 60$	COMP.W	D1,#3	JUMP,NE 60$	ADD.W	D3,#LXKEYON	; D4 <-- ajoute le palier "key-on"60$:	ADD.W	D3,(A3)+OEGPOS+2	POPM.L	D1,D2,D4,A3	RET;------------\\; EGGETNIVTAU >;------------/; Donne le niveau;taux d'un point.; in	A2.L	^timbre;	D2.L	courbe;point (0..5,6;0..3); out	D3.L	niveau;taux (0..99;0..99); mod	D3.LEGGETNIVTAU:	PUSHM.L	D2,A2	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..5,6)	COMP.W	D3,#EGNBX*EGNBY	; courbe de hauteur ?	JUMP,EQ 15$	MUL.WU	D3,#17	ADD.L	A2,D3		; A2 <-- ^le bon oprateur	JUMP	20$15$:	LOAD.L	A2,#(A2)+102	; A2 <-- ^la courbe de hauteur20$:	CLR.W	D3	LOAD.B	D3,(A2)+(D2.W)+4 ; D3 <-- niveau EG 1..4 (0..99)	SUB.W	D3,#99	NEG.W	D3	SWAP.W	D3	CLR.W	D3	LOAD.B	D3,(A2)+(D2.W)+0 ; D3 <-- taux EG 1..4 (0..99)	SUB.W	D3,#99	NEG.W	D3	POPM.L	D2,A2	RET;-----------\\; EGPUTPOINT >;===========/; Met  jour les coordonnes graphiques d'un point.; En cas d'erreur, on met  jour quand mme le point; le plus proche !; in	A2.L	^timbre;	D2.L	courbe;point (0..5,6;0..3);	D3.L	coordonne du point (y;x); out	D7.W	erreur; mod	D7.WEGPUTPOINT:	PUSHM.L	D1..D4,A3	CLR.W	D7		; D7 <-- ok,  priori	LOAD.L	D4,D3	LOAD.L	A3,#(A6)+OTAEG	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..5,6)	MUL.WU	D3,#LEG	ADD.L	A3,D3		; A3 <-- ^dans OTAEG	SWAP.W	D4	SUB.W	D4,(A3)+OEGPOS+0	JUMP,HS 20$	CLR.W	D4	LOAD.W	D7,#1		; D7 <-- impossible20$:	SWAP.W	D4	SUB.W	D4,(A3)+OEGPOS+2	JUMP,HS 25$	CLR.W	D4	LOAD.W	D7,#1		; D7 <-- impossible25$:	COMP.B	(A6)+OEGTYP,#GDSEGP	JUMP,EQ 30$	COMP.W	D2,#3	JUMP,NE 30$	SUB.W	D4,#LXKEYON	; D4 <-- soustrait le palier "key-on"	JUMP,HS 30$	CLR.W	D4	LOAD.W	D7,#1		; D7 <-- impossible30$:	LOAD.W	D1,(A6)+OEGSCA	JUMP,EQ 36$	JUMP,NS 34$	SL.W	D4,D1	JUMP	36$34$:	NEG.W	D1	SR.W	D4,D136$:	LOAD.W	D1,D240$:	DEC.W	D2	JUMP,NS 50$	CALL	EGGETNIVTAU	; D3 <-- niveau;taux	SUB.W	D4,D3		; D4 <-- soustrait les points prcdents	JUMP,HS 40$	CLR.W	D4	LOAD.W	D7,#1		; D7 <-- impossible50$:	LOAD.W	D2,D1	LOAD.L	D3,D4	COMP.W	D3,#99	JUMP,LS 70$	LOAD.W	D3,#99	LOAD.W	D7,#1		; D7 <-- impossible70$:	SWAP.W	D3	COMP.W	D3,#99	JUMP,LS 75$	LOAD.W	D3,#99	LOAD.W	D7,#1		; D7 <-- impossible75$:	SWAP.W	D3	CALL	EGPUTNIVTAU	; mj le niveau;taux	POPM.L	D1..D4,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; EGPUTNIVTAU >;------------/; Met  jour le niveau;taux d'un point.; in	A2.L	^timbre;	D2.L	courbe;point (0..5,6;0..3);	D3.L	niveau;taux (0..99;0..99); out	-; mod	-EGPUTNIVTAU:	PUSHM.L	D2..D4,A2	LOAD.L	D4,D3		; D4 <-- niveau;taux	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..5,6)	COMP.W	D3,#EGNBX*EGNBY	; courbe de hauteur ?	JUMP,EQ 15$	MUL.WU	D3,#17	ADD.L	A2,D3		; A2 <-- ^le bon oprateur	JUMP	20$15$:	LOAD.L	A2,#(A2)+102	; A2 <-- ^la courbe de hauteur20$:	SUB.W	D4,#99	NEG.W	D4	LOAD.B	(A2)+(D2.W)+0,D4 ; mj taux EG 1..4 (0..99)	SWAP.W	D4	SUB.W	D4,#99	NEG.W	D4	LOAD.B	(A2)+(D2.W)+4,D4 ; mj niveau EG 1..4 (0..99)	POPM.L	D2..D4,A2	RET	.ENDIF	.IF	DX100!FB01;-----------\\; EGGETPOINT >;===========/; Donne les coordonnes graphiques d'un point.; in	A2.L	^timbre;	D2.L	courbe;point (0..3;0..3); out	D3.L	coordonne du point (y;x); mod	D3.LEGGETPOINT:	PUSHM.L	D2,D4,A3	LOAD.L	A3,#(A6)+OTAEG	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..3)	MUL.WU	D3,#LEG	ADD.L	A3,D3		; A3 <-- ^dans OTAEG	CALL	EGGETNIVTAU	; D3 <-- niveau;taux	SWAP.W	D3	LOAD.W	D2,D3	MUL.WU	D2,#EGLGY-1	DIV.WU	D2,#31	LOAD.W	D3,D2		; D3 <-- D3*99/31	ADD.W	D3,(A3)+OEGPOS+0	SWAP.W	D3	LOAD.W	D2,(A6)+OEGSCA	JUMP,EQ 56$	JUMP,NS 54$	SR.W	D3,D2	JUMP	56$54$:	NEG.W	D2	SL.W	D3,D256$:	ADD.W	D3,(A3)+OEGPOS+2	POPM.L	D2,D4,A3	RET;------------\\; EGGETNIVTAU >;------------/; Donne le niveau;taux d'un point.; in	A2.L	^timbre;	D2.L	courbe;point (0..3;0..3); out	D3.L	niveau;taux (0..31;0..31); mod	D3.LEGGETNIVTAU:	PUSHM.L	D2,A2	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..3)	MUL.WU	D3,#10	ADD.L	A2,D3		; A2 <-- ^le bon oprateur	COMP.W	D2,#3	JUMP,EQ 60$	COMP.W	D2,#2	JUMP,EQ 50$	COMP.W	D2,#1	JUMP,EQ 40$				; point 0 =>	CALL	EGGETP0		; D3 <-- niveau;taux	JUMP	90$40$:				; point 1 =>	CALL	EGGETP1		; D3 <-- niveau;taux	JUMP	90$50$:				; point 2 =>	CALL	EGGETP2		; D3 <-- niveau;taux	JUMP	90$60$:				; point 3 =>	CALL	EGGETP3		; D3 <-- niveau;taux90$:	POPM.L	D2,A2	RET;--------\\; EGGETP0 >;--------/; Donne le point 0.; in	A2.L	^oprateur; out	D3.L	niveau;taux; mod	D3.LEGGETP0:	CLR.W	D3	SWAP.W	D3	CLR.W	D3	LOAD.B	D3,(A2)+0	; D3 <-- AR (0..31)	SUB.W	D3,#31	NEG.W	D3	RET;--------\\; EGGETP1 >;--------/; Donne le point 1.; in	A2.L	^oprateur; out	D3.L	niveau;taux; mod	D3.LEGGETP1:	PUSH.L	D4	CALL	EGGETP0	LOAD.L	D4,D3	CLR.W	D3	LOAD.B	D3,(A2)+4	; D3 <-- D1L (0..15)	SUB.W	D3,#15	NEG.W	D3	SL.W	D3,#1	SWAP.W	D3	CLR.W	D3	LOAD.B	D3,(A2)+1	; D3 <-- D1R (0..31)	SUB.W	D3,#31	NEG.W	D3	ADD.W	D3,D4	POP.L	D4	RET;--------\\; EGGETP2 >;--------/; Donne le point 2.; in	A2.L	^oprateur; out	D3.L	niveau;taux; mod	D3.LEGGETP2:	PUSH.L	D4	CALL	EGGETP1	LOAD.L	D4,D3	SWAP.W	D4	LOAD.W	D3,#31	SUB.W	D3,D4	SR.W	D3,#1	ADD.W	D3,D4	SWAP.W	D4	SWAP.W	D3	CLR.W	D3	LOAD.B	D3,(A2)+2	; D1 <-- D2R (0..31)	SUB.W	D3,#31	NEG.W	D3	ADD.W	D3,D4	POP.L	D4	RET;--------\\; EGGETP3 >;--------/; Donne le point 3.; in	A2.L	^oprateur; out	D3.L	niveau;taux; mod	D3.LEGGETP3:	PUSH.L	D4	CALL	EGGETP2	LOAD.L	D4,D3	LOAD.W	D3,#31	SWAP.W	D3	CLR.W	D3	LOAD.B	D3,(A2)+3	; D1 <-- RR (0..15)	SUB.W	D3,#15	NEG.W	D3	SL.W	D3,#1	ADD.W	D3,D4	POP.L	D4	RET;-----------\\; EGPUTPOINT >;===========/; Met  jour les coordonnes graphiques d'un point.; En cas d'erreur, on met  jour quand mme le point; le plus proche !; in	A2.L	^timbre;	D2.L	courbe;point (0..3;0..3);	D3.L	coordonne du point (y;x); out	D7.W	erreur; mod	D7.WEGPUTPOINT:	PUSHM.L	D1..D4,A3	CLR.W	D7		; D7 <-- ok,  priori	LOAD.L	D4,D3	LOAD.L	A3,#(A6)+OTAEG	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..3)	MUL.WU	D3,#LEG	ADD.L	A3,D3		; A3 <-- ^dans OTAEG	SWAP.W	D4	SUB.W	D4,(A3)+OEGPOS+0	JUMP,HS 20$	CLR.W	D4	LOAD.W	D7,#1		; D7 <-- impossible20$:	LOAD.W	D3,D4	MUL.WU	D3,#31	DIV.WU	D3,#EGLGY-1	LOAD.W	D4,D3		; D4 <-- D4*31/99	SWAP.W	D4	SUB.W	D4,(A3)+OEGPOS+2	JUMP,HS 25$	CLR.W	D4	LOAD.W	D7,#1		; D7 <-- impossible25$:	LOAD.W	D1,(A6)+OEGSCA	JUMP,EQ 36$	JUMP,NS 34$	SL.W	D4,D1	JUMP	36$34$:	NEG.W	D1	SR.W	D4,D136$:	LOAD.W	D1,D2	DEC.W	D2	JUMP,NS 50$	CALL	EGGETNIVTAU	; D3 <-- niveau;taux	SUB.W	D4,D3		; D4 <-- soustrait les points prcdents	JUMP,HS 44$	CLR.W	D4	LOAD.W	D7,#1		; D7 <-- impossible44$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- soustrait les points prcdents	JUMP,HS 46$	CLR.W	D4	LOAD.W	D7,#1		; D7 <-- impossible46$:	SWAP.W	D3	SWAP.W	D450$:	LOAD.W	D2,D1	LOAD.L	D3,D4	COMP.W	D3,#31	JUMP,LE 70$	LOAD.W	D3,#31	LOAD.W	D7,#1		; D7 <-- impossible70$:	SWAP.W	D3	COMP.W	D3,#31	JUMP,LE 75$	LOAD.W	D3,#31	LOAD.W	D7,#1		; D7 <-- impossible75$:	SWAP.W	D3	CALL	EGPUTNIVTAU	; mj le niveau;taux	POPM.L	D1..D4,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; EGPUTNIVTAU >;------------/; Met  jour le niveau;taux d'un point.; in	A2.L	^timbre;	D2.L	courbe;point (0..3;0..3);	D3.L	niveau;taux (0..31;0..31); out	-; mod	-EGPUTNIVTAU:	PUSHM.L	D2..D4,A2	LOAD.L	D4,D3		; D4 <-- niveau;taux	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- courbe (0..3)	MUL.WU	D3,#10	ADD.L	A2,D3		; A2 <-- ^le bon oprateur	COMP.W	D2,#3	JUMP,EQ 60$	COMP.W	D2,#2	JUMP,EQ 50$	COMP.W	D2,#1	JUMP,EQ 40$				; point 0 =>	SUB.W	D4,#31	NEG.W	D4	LOAD.B	(A2)+0,D4	; mj AR (0..31)	JUMP	90$40$:				; point 1 =>	SWAP.W	D4	SR.W	D4,#1	SUB.W	D4,#15	NEG.W	D4	LOAD.B	(A2)+4,D4	; mj D1L (0..15)	SWAP.W	D4	SUB.W	D4,#31	NEG.W	D4	LOAD.B	(A2)+1,D4	; mj D1R (0..31)	JUMP	90$50$:				; point 2 =>	SUB.W	D4,#31	NEG.W	D4	LOAD.B	(A2)+2,D4	; mj D2R (0..31)	JUMP	90$60$:				; point 3 =>	SR.W	D4,#1	SUB.W	D4,#15	NEG.W	D4	LOAD.B	(A2)+3,D4	; mj RR (0..15)90$:	POPM.L	D2..D4,A2	RET	.ENDIF; Tables; ------TICOEG:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+3	.B	ICOEGMX,ICOEGMX,ICOEGMX	.B	ICOEGPX,ICOEGPX,ICOEGPX	.B	0,0,0	.B	0,0,0	.B	0,0,0TMENUEG:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"Diminue"	.ASCIZ	"l'chelle"		;     ;     ;     ;	.ASCIZ	"Augmente"	.ASCIZ	"l'chelle"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN	.END