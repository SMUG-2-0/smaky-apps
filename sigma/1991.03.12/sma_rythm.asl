	.TITLE	SMA_RYTHM.ASL;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	DOLIB	.REF	RYTHMMAJREV	=	1		; rvisionMINREV	=	2		; version	.REV	MAJREV,MINREV	.CODE	800,11,B'1111,20,2000,20,2000,2,'N,'R,'F,09; Constantes; ----------MAXINST	=	16		; nb max d'instruments (en Y)MAXPAS	=	16		; nb max de pas (en X)LGPAS	=	24		; largeur d'un pasLBUFILE	=	32		; lg max d'un nom de fichier;;?NBCCOL=	4		; nb case en colonnesNBCCOL	=	3		; nb case en colonnesMAXVIT	=	100		; vitesse maximalePRIOPLAY=	3		; priorit du processus d'couteRYTRACK	=	7		; piste pour le rythmeFORCE1	=	1		; forces de frappe des notesFORCE2	=	64FORCE3	=	127PAS1	=	8		; pas de dessin des notesPAS2	=	4PAS4	=	2PAS8	=	1COOCAR	=	H'FFFF0000	; (-1;0) coordonne case "rpte"GCICF	=	'I		; fonte des icnesGCICS	=	'S		; style/chasse des icnesGCICT	=	24		; taille des icnesGCICB	=	8		; ligne de baseGCTXF	=	'N		; fonte du texteGCTXS	=	'R!2^7		; style/chasse du texteGCTXT	=	09		; taille du texteGCPTF	=	'N		; fonte petiteGCPTS	=	'E!2^7		; style/chasse petitGCPTT	=	07		; taille petite	.INS	ICONE24.ASI	; icnes de ISP24; Descripteur d'un instrument; ---------------------------LRINAME	=	14	.LOC	0ORINAME:.BLKB	LRINAME		; nom de l'instrument	.BLKB	2		; rserveORIMIDI:.BLKB	2		; canal MIDIORINOTA:.BLKB	2		; note aORINOTB:.BLKB	2		; note b	.BLKB	8		; rserveLRI:; Descripteur d'une note; ----------------------	.LOC	0	.BLKB	1		; rserveONFORC:	.BLKB	1		; force de frappe (1..3)ONINST:	.BLKB	1		; instrument (0..31) BNNOTEB=  8+0			;  note a/bONPOSX:	.BLKB	1		; position dans le temps (0..127)LNOTE:; Descripteur d'une mesure; ------------------------	.LOC	0ORML:	.BLKB	4		; longueurORMI:	.BLKB	LRI*MAXINST	; table des instrumentsORMN:	.BLKB	2		; nb de mesuresORMR:	.BLKB	2		; nb de rptitionsORMT:	.BLKB	2		; temps (2..9)	.BLKB	12		; rserveORMB:				; notes...				; longueur; En-tte d'un fichier .RYTHME; ----------------------------	.LOC	0OHREV:	.BLKB	1		; rvisionOHVERS:	.BLKB	1		; versionOHLG:	.BLKB	4		; nb total de bytes (sans l'en-tte)OHNMES:	.BLKB	2		; nb de mesuresOHVIT:	.BLKB	2		; vitesseOHTRACK:.BLKB	2		; piste pour le rythmeOHUNITE:.BLKB	2		; unit				; rserveLHEAD	=	256; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHMIDI:.BLKB	2		; canal MIDI pour le rythmeONDMIDI:.BLKB	2		; no du driver MIDIOBUCOM:	.BLKB	20		; commandes MIDIOPSEM:	.BLKB	4		; ^smaphore d'exclusionOPDDIS:	.BLKB	4		; ^descripteur de la fentreOQXDOT:	.BLKB	4		; adresse de GRA_QXDOTONOWDO:	.BLKB	2		; no de la swdoOBDIS:	.BLKB	100		; buffer write displayOBMIDI:	.BLKB	100		; buffer write midiOBUFILE:.BLKB	LBUFILE		; nom de fichierOBUNUM:	.BLKB	LBUFILE		; nom d'un chiffreOBUHEAD:.BLKB	LHEAD		; en-tte de fichierOPDB:	.BLKB	4		; ^dbut bufferOPDT:	.BLKB	4		; ^dbut trouOPFT:	.BLKB	4		; ^fin trouOPFB:	.BLKB	4		; ^fin bufferOUNITE:	.BLKB	2		; unit du temps (64 par dfaut)ONMES:	.BLKB	2		; nb de mesures (1..n)OCMES:	.BLKB	2		; no de la mesure courante (0..n-1)ONOTE:	.BLKB	1		; note a/bOFORCE:	.BLKB	1		; force de frappe des notes (1..3)OPAS:	.BLKB	1		; pas de dessin des notesOMAJ:	.BLKB	1		; rythme  jourOPLAY:	.BLKB	1		; coute en cours	.EVENORYPCY:	.BLKB	2		; coin rectangle extrieurORYPCX:	.BLKB	2ORYLCY:	.BLKB	2		; dimensions rectangle extrieurORYLCX:	.BLKB	2ORYPIY:	.BLKB	2		; coin rectangle rythmeORYPIX:	.BLKB	2ORYHT:	.BLKB	2		; hauteur d'une "ligne"OASC:	.BLKB	LSCVAR		; variables de l'ascenseur pour les mesuresOASVIT:	.BLKB	LSCVAR		; variables de l'ascenseur pour la vitesseOCAPOS:	.BLKB	4		; position case en ditionOCAPTL:	.BLKB	4		; ^dans OCALINEOCALGL:	.BLKB	2		; longueur de la ligneOCALINE:.BLKB	20		; texte case en ditionLGVAR:; En-tte du module LIB; ---------------------	.LOC	0	.W	RYTH_FIRST	; code du premier appel	.W	RYTH_LAST	; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	MAJREV,MINREV	; rvision.version	.W	0,END_RYTH	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"RYTHM"		; nom du module	.FILLB	(LGHLIB-.),0	.W	_RYTH_OPEN	.W	_RYTH_EDIT	.W	_RYTH_CLOSE	.W	_RYTH_FUSION	.W	_RYTH_WRITE	.W	_RYTH_READ	.W	_RYTH_CLEAR; Codes des appels; ----------------;-----------\\; _RYTH_OPEN >;===========/; Initialise tout ce qu'il faut.; in	-; out	A4.L	^variables;	D7.W	erreur;		ERUNCO => synthtiseur pas connect; mod	D7.W, A4.L_RYTH_OPEN:	PUSHM.L	D0..D6,A0..A3,A5,A6	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE 90$	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.W	D4	JUMP,NE 10$; Initialise les variables les plus importantes.	LOAD.W	(A6)+OUNITE,#64;	CLR.B	(A6)+ONOTE	LOAD.B	(A6)+OFORCE,#2	LOAD.B	(A6)+OPAS,#PAS1	SET.B	(A6)+OMAJ	; rythme  jour	LOAD.L	(A6)+OCAPOS,#-1	LOAD.W	(A6)+OASVIT+OSCHTV,#2*MAXVIT	LOAD.W	(A6)+OASVIT+OSCPOSV,#MAXVIT	LOAD.W	D3,#10		; D3 <-- 10/16	LOAD.L	D4,#ORMB+100*2	; D4 <-- lg min	LOAD.L	D5,#-1		; D5 <-- lg max	LOAD.W	D1,#MTYPCP	GESMEM	?GETPMEM	; demande mmoire pour rythmes	JUMP,NE 90$	LOAD.L	(A6)+OPDB,A4	ADD.L	A4,D4	LOAD.L	(A6)+OPFB,A4	CALL	INIMESURE	; met une premire mesure vide	LOAD.W	D4,#1	NTREL	?CRESEM		; cre le smaphore d'exclusion	JUMP,NE 90$	LOAD.L	(A6)+OPSEM,A5; Demande le pointeur permanant au descripteur de la fentre.	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE 90$	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	(A3+),#LOADGC	LOAD.B	(A3+),#GCICF	LOAD.B	(A3+),#GCICS	LOAD.B	(A3+),#GCICT	LOAD.B	(A3+),#LOADGC	LOAD.B	(A3+),#GCPTF	LOAD.B	(A3+),#GCPTS	LOAD.B	(A3+),#GCPTT	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBDIS	SUB.L	D3,A3	LIB	?STRING	JUMP,NE 90$	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE 90$	LOAD.L	(A6)+OQXDOT,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE 90$	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE 90$	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE 90$	LOAD.W	(A6)+OCHSCROLL,D1	CALL	OPEMIDI		; ouvre le driver midi	JUMP,NE 90$	LOAD.L	A4,A6		; A4 <-- ^variables90$:	POPM.L	D0..D6,A0..A3,A5,A6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; _RYTH_EDIT >;===========/; Permet de changer de son, d'diter, etc.; in	A4.L	^variables;	D2.W	canal MIDI  utiliser;	D3.W	temps;	D4.W	vitesse (-MAXVIT..+MAXVIT); out	D3.W	temps;	D4.W	vitesse (-MAXVIT..+MAXVIT); mod	D3.L, D4.L, D7.W_RYTH_EDIT:	PUSHM.L	D0..D2,D5,D6,A0..A6	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LOAD.W	(A6)+OCHMIDI,D2	SUB.W	D4,#MAXVIT	NEG.W	D4	LOAD.W	(A6)+OASVIT+OSCPOSV,D4	LOAD.L	A5,(A6)+OPDT	COMP.L	A5,(A6)+OPDB	JUMP,EQ 20$	LOAD.L	D4,(A5)-4	SUB.L	A5,D4		; A5 <-- ^mesure courante <<PERMANANT>>20$:	CALL	GOTIME		; va dans la mesure du temps donn	CALL	DESCADRE	; fait tout beau le cadre	CALL	DESMESURE	; dessine la mesure o l'on est	SET.B	(A6)+OMAJ	; rythme  jourLOOP:	CALL	NORMMOUSE	; remet la flche10$:	COMP.L	(A6)+OCAPOS,#-1	JUMP,NE 12$	LIB	?GETCAR		; attend clavier/souris ...	JUMP	15$12$:	LOAD.L	D3,(A6)+OCAPOS	CALL	RYTHPOSC	; D3/D4 <-- position/dimensions	LOAD.W	D2,(A0)+ODFCX	SR.W	D2,#1	ADD.W	D3,D2	SWAP.W	D3	ADD.W	D3,(A0)+ODFC1Y	INC.W	D3	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A3,#(A6)+OCALINE	LOAD.L	A4,(A6)+OCAPTL	LOAD.L	A2,#R16"TKEDIT	LOAD.W	D3,(A6)+OCALGL	LIB	?EDIT		; attend clavier/souris ...	LOAD.L	(A6)+OCAPTL,A4	PUSH.W	D3	LOAD.B	D3,#NOCURS	LIB	?AFCAR		; enlve le curseur	POP.W	D315$:	COMP.W	D3,#F0+SHIFT	JUMP,LO 20$	COMP.W	D3,#F15+SHIFT	JUMP,HI 20$	SUB.W	D3,#SHIFT20$:	COMP.W	D3,#KEYMGR	JUMP,EQ 10$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ 10$		; oui => 10$	COMP.W	D3,#KEYMDR	JUMP,EQ 10$	COMP.W	D3,#TAB	JUMP,EQ NEXTX	COMP.W	D3,#CR	JUMP,EQ NEXTY	COMP.W	D3,#KEYMGP	JUMP,EQ 40$	COMP.W	D3,#KEYMMP	JUMP,EQ 40$	COMP.W	D3,#KEYMDP	JUMP,NE 50$40$:	PUSH.L	D3	CALL	IFMOUSE		; D4 <-- position de la souris (y;x)	POPM.L	D3	JUMP,NE 50$	LOAD.L	D0,D3	CALL	RYTHDETM	; souris dans une mesure ?	JUMP,EQ CLICMESURE	CALL	RYTHDETN	; souris dans une note ?	JUMP,EQ CLICNOTE	CALL	RYTHDETC	; souris dans une case ?	JUMP,EQ CLICCASE	PUSHM.L	D4,A5	LOAD.L	A5,#(A6)+OASC	LOAD.W	(A5)+OSCINC,#1	SCROLL_	MOVE		; dplace l'ascenseur ?	POPM.L	D4,A5	JUMP,EQ CLICASCENSEUR	LOAD.L	D3,D050$:	LOAD.L	A3,#R16"TICOBASE	LOAD.L	A4,#0	DBOX_	ICODET		; dans "soft-key" ?	JUMP,EQ SOFTKEY		; oui => SOFTKEYBIP:	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPCLICCASE:	LOAD.L	D1,D3	CALL	RYTHINVC	; dessine la premire case20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 50$		; non => 50$	CALL	IFMOUSE	JUMP,NE 20$	CALL	RYTHDETC	; D3 <-- position (y;x)	COMP.L	D3,D1		; souris dplace ?	JUMP,EQ 20$		; non => 20$				; oui =>	EX.L	D3,D1	CALL	RYTHINVC	; efface l'ancienne case	LOAD.L	D3,D1	CALL	RYTHINVC	; dessine la nouvelle case	JUMP	20$50$:	LOAD.L	D3,D1	CALL	RYTHINVC	; efface la dernire case	CALL	RYTHTAKEC	; prend la case en dition	JUMP	LOOPCLICNOTE:	COMP.W	D0,#KEYMDP	JUMP,EQ 70$	COMP.W	D0,#KEYMMP	JUMP,EQ BIP	LOAD.L	D1,D3	CALL	IFNOTE		; dj une note ici ?	JUMP,EQ BIP		; oui => BIP	LOAD.W	D2,#SETDOT	; non =>	CALL	RYTHINVN	; dessine la premire note20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 50$		; non => 50$	CALL	IFMOUSE	JUMP,NE 20$	CALL	RYTHDETN	; D3 <-- position (i;p)	COMP.L	D3,D1		; souris dplace ?	JUMP,EQ 20$		; non => 20$				; oui =>	CALL	IFNOTE		; dj une note ici ?	JUMP,EQ 20$		; oui => 20$				; non =>	EX.L	D3,D1	LOAD.W	D2,#CLRDOT	CALL	RYTHINVN	; efface l'ancienne note	LOAD.L	D3,D1	LOAD.W	D2,#SETDOT	CALL	RYTHINVN	; dessine la nouvelle note	JUMP	20$50$:	LOAD.L	D3,D1	CALL	NEWNOTE		; mj nouvelle note	JUMP,NE BIP	JUMP	LOOP70$:				; dtruit =>	CALL	KILNOTE		; supprime la note	JUMP,NE BIP	LOAD.W	D2,#CLRDOT	CALL	RYTHINVN	; efface la note	JUMP	LOOPCLICMESURE:	LOAD.W	D1,(A5)+ORMN	JUMP	30$20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 50$		; non => 50$	CALL	IFMOUSE	JUMP,NE 20$	CALL	RYTHDETM	; D3 <-- position (m)30$:	COMP.W	D3,D1		; souris dplace ?	JUMP,EQ 20$		; non => 20$				; oui =>	EX.L	D3,D1	LOAD.W	D2,#INVDOT	CALL	RYTHINVM	; efface l'ancienne marque	LOAD.L	D3,D1;	LOAD.W	D2,#INVDOT	CALL	RYTHINVM	; dessine la nouvelle marque	JUMP	20$50$:	LOAD.W	D3,D1	LOAD.W	(A5)+ORMN,D3	CALL	DESCHIFFRE	; redessine les chiffres	LOAD.W	D2,#SETDOT	CALL	RYTHINVM	; dessine la marque dfinitive	JUMP	LOOPCLICASCENSEUR:	CALL	RYTHMAJC	; mj case actuellement en dition	LOAD.W	D4,(A6)+OASC+OSCPOSV	SUB.W	D4,(A6)+OCMES	JUMP,EQ LOOP	JUMP,LO 40$20$:	CALL	AVANCE	JUMP,NE 80$	DEC.W	D4	JUMP,NE 20$	JUMP	80$40$:	CALL	RECULE	JUMP,NE 80$	INC.W	D4	JUMP,NE 40$80$:	CALL	DESMESURE	; dessine la nouvelle mesure	JUMP	LOOPSOFTKEY:	TEST.W	D2	JUMP,EQ FINI	COMP.W	D2,#1	JUMP,EQ DOPREND	COMP.W	D2,#3	JUMP,EQ DOSAUVE	COMP.W	D2,#4	JUMP,EQ DOECOUTE	COMP.W	D2,#7	JUMP,EQ DOMETRO	COMP.W	D2,#13	JUMP,EQ DOAJOUTE	COMP.W	D2,#14	JUMP,EQ DOCOPIE	COMP.W	D2,#15	JUMP,EQ DODETRUIT	LOAD.L	A3,#R16"TICOBASE	LOAD.L	A4,#0	COMP.B	D2,#10	JUMP,EQ 30$	COMP.B	D2,#11	JUMP,EQ 40$	COMP.B	D2,#12	JUMP,EQ 50$	JUMP	BIP30$:				; note =>	NOT.B	(A6)+ONOTE	CALL	AFFICONOTE	JUMP	LOOP40$:				; force =>	LOAD.B	D3,(A6)+OFORCE	INC.B	D3	COMP.B	D3,#4	JUMP,LO 45$	LOAD.B	D3,#145$:	LOAD.B	(A6)+OFORCE,D3	CALL	AFFICOFORCE	JUMP	LOOP50$:				; pas =>	LOAD.B	D2,(A6)+OPAS	LOAD.B	D3,#PAS2	COMP.B	D2,#PAS1	JUMP,EQ 55$	LOAD.B	D3,#PAS8	COMP.B	D2,#PAS2	JUMP,EQ 55$	LOAD.B	D3,#PAS1;	COMP.B	D2,#PAS8;	JUMP,EQ 55$55$:	LOAD.B	(A6)+OPAS,D3	CALL	AFFICOPAS	JUMP	LOOPNEXTX:	LOAD.L	D3,(A6)+OCAPOS	COMP.L	D3,#-1	JUMP,EQ BIP	INC.W	D3	COMP.W	D3,#NBCCOL	JUMP,LO 50$	CLR.W	D350$:	SWAP.W	D3	COMP.W	D3,#-1	JUMP,NE 60$	CLR.W	D360$:	SWAP.W	D3	CALL	RYTHTAKEC	JUMP	LOOPNEXTY:	LOAD.L	D3,(A6)+OCAPOS	COMP.L	D3,#-1	JUMP,EQ BIP	SWAP.W	D3	INC.W	D3	COMP.W	D3,#MAXINST	JUMP,LO 50$	CLR.W	D350$:	SWAP.W	D3	CALL	RYTHTAKEC	JUMP	LOOPDOECOUTE:	TEST.B	(A6)+OPLAY	JUMP,T	50$	CALL	RYTHSTART	; dmarre l'coute	JUMP,NE ERROR	JUMP	LOOP50$:	CALL	RYTHSTOP	; stoppe l'coute	JUMP	LOOPDOMETRO:	CALL	DBOXDEFINE	; attend choix ...	JUMP,NE BIP	JUMP	LOOPDOAJOUTE:	CALL	RYTHMAJC	; mj case actuellement en dition	CALL	INSERT	JUMP,NE ERROR	CALL	DESMESURE	; affiche la nouvelle mesure	JUMP	LOOPDOCOPIE:	CALL	RYTHMAJC	; mj case actuellement en dition	CALL	COPIE	JUMP,NE ERROR	CALL	DESMESURE	; affiche la nouvelle mesure	JUMP	LOOPDODETRUIT:	CALL	RYTHMAJC	; mj case actuellement en dition	CALL	DAVANCE	JUMP,NE ERROR	CALL	DESMESURE	; affiche la nouvelle mesure	JUMP	LOOPERROR:	PUSH.W	D7	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	AFMENU		; affiche les soft-keys	JUMP	LOOPFINI:	CLR.W	D2	LOAD.L	A3,#R16"TICOBASE	LOAD.L	A4,#0	DBOX_	ICOINV		; allume la soft-key (F0)	CALL	RYTHSTOP	; stoppe l'coute	CALL	RYTHMAJC	; mj case actuellement en dition	NTREL	?WFABDESC	; attend la fin de l'coute ...	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.W	D5,(A6)+ONOWDO	LIB	?KILWDO		; supprime la swdo !	CLR.W	(A6)+ONOWDO	LIB	?AFTIM	.B	NOCURS		; pas de curseur;;?	.B	EOP		; efface tout	.B	0	.EVEN	LOAD.W	D4,#MAXVIT	SUB.W	D4,(A6)+OASVIT+OSCPOSV ; D4 <-- vitesse (-MAXVIT..+MAXVIT)	CALL	GIVTIME		; D3 <-- temps	POPM.L	D0..D2,D5,D6,A0..A6	CLR.W	D7		; retour EQ	RET;------------\\; _RYTH_CLOSE >;============/; Ferme tout.; in	A4.L	^variables; out	-; mod	D7.W_RYTH_CLOSE:	PUSHM.L	D1,A0,A5,A6	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	CALL	CLOMIDI	TEST.L	(A6)+OPSEM	JUMP,EQ 20$	LOAD.L	A5,(A6)+OPSEM	NTREL	?KILLSEM	; dtruit le smaphore d'exclusion20$:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	POPM.L	D1,A0,A5,A6	CLR.W	D7		; retour EQ	RET;---------\\; RYTHDETC >;=========/; Dtecte dans quelle case est la souris.; in	D4.L	position de la souris (y;x); out	D3.L	position (y;x);	D7.W	erreur; mod	D3.L, D7.WRYTHDETC:	PUSHM.L	D2,D4	PUSH.L	D4	LOAD.L	D2,D4	LOAD.L	D3,#COOCAR	; D3 <-- (-1;0)	CALL	RYTHPOSC	; D3/D4 <-- pos/dim case "1x"	SUB.W	D2,D3	JUMP,LO 10$	COMP.W	D2,D4	JUMP,HS 10$	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SUB.W	D2,D3	JUMP,LO 10$	COMP.W	D2,D4	JUMP,HS 10$	LOAD.L	D3,#COOCAR	; D3 <-- (-1;0)	CLR.W	D7		; D7 <-- ok	POP.L	D4	JUMP	90$10$:	POP.L	D4	CLR.W	D7		; D7 <-- ok	SUB.W	D4,(A6)+ORYPCX	JUMP,HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites20$:	CLR.W	D3	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#LRINAME+1	SUB.W	D4,D2	JUMP,LO 40$	SUB.W	D4,#MAXPAS*LGPAS	JUMP,LO 40$;;?	INC.W	D3;;?	LOAD.W	D2,(A0)+ODFCX;;?	MUL.WU	D2,#2+1;;?	SUB.W	D4,D2;;?	JUMP,LO 40$	INC.W	D3	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#3+1	SUB.W	D4,D2	JUMP,LO 40$	INC.W	D3	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#3+1	SUB.W	D4,D2	JUMP,LO 40$	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites40$:	SWAP.W	D4	SUB.W	D4,(A6)+ORYPIY	JUMP,HS 42$	CLR.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites42$:	CLR.L	D2	LOAD.W	D2,D4	DIV.WU	D2,(A6)+ORYHT	COMP.W	D2,#MAXINST	JUMP,LO 45$	LOAD.W	D2,#MAXINST-1	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites45$:	SWAP.W	D3	LOAD.W	D3,D2	SWAP.W	D390$:	POPM.L	D2,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; RYTHDETN >;=========/; Dtecte dans quelle note et  quelle position est la souris.; in	D4.L	position de la souris (y;x); out	D3.L	position (-;f;i;p);	D7.W	erreur; mod	D3.L, D7.WRYTHDETN:	PUSHM.L	D2,D4	CLR.W	D7		; D7 <-- ok	SUB.W	D4,(A6)+ORYPIX	JUMP,HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites20$:	CLR.L	D3	LOAD.W	D3,D4	DIV.WU	D3,#LGPAS/8	AND.L	D3,#H'FFFF	LOAD.B	D2,(A6)+OPAS	COMP.B	D2,#PAS2	JUMP,EQ 30$	COMP.B	D2,#PAS1	JUMP,NE 35$	DIV.WU	D3,#8	MUL.WU	D3,#8	ADD.W	D3,#4	JUMP	35$30$:	ADD.W	D3,#2	DIV.WU	D3,#4	MUL.WU	D3,#435$:	COMP.W	D3,#MAXPAS*8	JUMP,LO 40$	LOAD.W	D3,#MAXPAS*8-1	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites40$:	SWAP.W	D4	SUB.W	D4,(A6)+ORYPIY	JUMP,HS 50$	CLR.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites50$:	CLR.L	D2	LOAD.W	D2,D4	DIV.WU	D2,(A6)+ORYHT	COMP.W	D2,#MAXINST	JUMP,LO 55$	LOAD.W	D2,#MAXINST-1	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites55$:	SL.B	D2,#1		; D2 <-- place pour bit a/b	RR.W	D3,#8	LOAD.B	D3,D2	RR.W	D3,#8	TEST.B	(A6)+ONOTE	JUMP,EQ 70$	TSET.L	D3:#BNNOTEB70$:	SWAP.W	D3	CLR.W	D3	LOAD.B	D3,(A6)+OFORCE	SWAP.W	D3	POPM.L	D2,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; RYTHDETM >;=========/; Dtecte dans quelle mesure est la souris.; in	D4.L	position de la souris (y;x); out	D3.W	mesure (2..16);	D7.W	erreur; mod	D3.L, D7.WRYTHDETM:	PUSHM.L	D2,D4	CLR.W	D7		; D7 <-- ok	SUB.W	D4,(A6)+ORYPIX	JUMP,HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites20$:	ADD.W	D4,#LGPAS/2	CLR.L	D3	LOAD.W	D3,D4	DIV.WU	D3,#LGPAS	COMP.W	D3,#2	JUMP,HS 23$	LOAD.W	D3,#2;;?	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites23$:	COMP.W	D3,#MAXPAS	JUMP,LS 25$	LOAD.W	D3,#MAXPAS	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites25$:	SWAP.W	D4	SUB.W	D4,(A6)+ORYPCY	JUMP,HS 40$	CLR.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites40$:	COMP.W	D4,(A6)+ORYHT	JUMP,LO 45$	LOAD.W	D7,#ERDIOUT	; D7 <-- hors limites45$:	POPM.L	D2,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; RYTHINVC >;=========/; Inverse une case quelconque.; in	D3.L	position (y;x); out	-; mod	D7.WRYTHINVC:	PUSHM.L	D2..D4	LOAD.L	D4,#-1	CALL	DRMDEF	CALL	RYTHPOSC	; D3/D4 <-- position dimensions	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	; inverse la case	POPM.L	D2..D4	RET;---------\\; RYTHPOSC >;=========/; Donne la position d'une case quelconque.; in	D3.L	position (y;x); out	D3.L	coin sup/gauche;	D4.L	dimensions; mod	D3.L, D4.L, D7.WRYTHPOSC:	PUSHM.L	D0..D2	LOAD.L	D2,D3	LOAD.W	D3,(A6)+ORYPCY	SWAP.W	D3	LOAD.W	D3,(A6)+ORYPCX	LOAD.W	D1,(A0)+ODFCX	MUL.WU	D1,#10	ADD.W	D3,D1	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#5	COMP.L	D2,#COOCAR	; (-1;0) ?	JUMP,EQ 70$	CLR.W	D0	LOAD.W	D1,#-2	LOAD.W	D3,(A6)+ORYPCX	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#LRINAME+1	DEC.W	D2	JUMP,NS 50$;;?	LOAD.W	D0,#1;;?	LOAD.W	D1,#-1;;?	ADD.W	D3,D4	ADD.W	D3,#MAXPAS*LGPAS;;?	LOAD.W	D4,(A0)+ODFCX;;?	MUL.WU	D4,#2+1;;?	DEC.W	D2;;?	JUMP,NS 50$	LOAD.W	D0,#1	LOAD.W	D1,#-1	ADD.W	D3,D4	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#3+1	DEC.W	D2	JUMP,NS 50$	CLR.W	D0	CLR.W	D1	ADD.W	D3,D4	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#3+1;	DEC.W	D2;	JUMP,NS 50$50$:	ADD.W	D3,D0	ADD.W	D4,D1	SWAP.W	D2	MUL.WU	D2,(A6)+ORYHT	ADD.W	D2,(A6)+ORYPIY	SWAP.W	D3	LOAD.W	D3,D2	SWAP.W	D370$:	SWAP.W	D4	LOAD.W	D4,(A6)+ORYHT	SWAP.W	D4	POPM.L	D0..D2	RET;---------\\; RYTHINVN >;=========/; Dessine une note quelconque.; in	D3.W	position (-;f;i;p);	D2.W	mode de dessin; out	-; mod	D7.WRYTHINVN:	PUSHM.L	D0..D4	LOAD.L	D0,D3	SWAP.W	D0	AND.W	D0,#H'FF	; D0 <-- force de frappe (1..3)	SUB.W	D0,#4	NEG.W	D0		; D0 <-- 3,2,1	SL.W	D0,#1		; D0 <-- 6,4,2	LOAD.W	D1,D3	CLR.W	D4	LOAD.B	D4,D3	SR.W	D3,#8		; D3 <-- instrument	SR.W	D3,#1		; D3 <-- instrument a/b	MUL.WU	D3,(A6)+ORYHT	ADD.W	D3,(A6)+ORYPIY	ADD.W	D3,D0		; D3 <-- <yy>	SWAP.W	D3	MUL.WU	D4,#LGPAS/8	ADD.W	D4,(A6)+ORYPIX	LOAD.W	D3,D4		; D3 <-- <xx>	LOAD.W	D4,(A6)+ORYHT	SUB.W	D4,D0	SUB.W	D4,D0		; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,#LGPAS/8-1	; D4 <-- <dxx>	COMP.W	D2,#CLRDOT	JUMP,EQ 50$				; dessine/inverse =>	LIB	?DRRECT	PUSH.L	D4	LOAD.L	D4,#-1		; D4 <-- note "a" pleine	TEST.L	D1:#BNNOTEB	JUMP,BC 40$	CLR.L	D4		; D4 <-- note "b" vide	LOAD.W	D2,#CLRDOT40$:	CALL	DRMDEF	POP.L	D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LIB	?DRMATRIX	; rempli/vide le rectangle	JUMP	90$50$:				; efface =>	PUSH.L	D4	CLR.L	D4	CALL	DRMDEF	POP.L	D4	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LIB	?DRMATRIX; Refait la grille efface dessous.	SWAP.W	D3	SUB.W	D3,D0	LOAD.W	D2,(A6)+ORYHT	SR.W	D2,#1	ADD.W	D3,D2		; D3 <-- <yy>	SWAP.W	D3	CLR.L	D4		; D4 <-- <dyy>	LOAD.W	D4,#LGPAS/8	; D4 <-- <dxx>	LOAD.W	D2,D3	SUB.W	D2,(A6)+ORYPIX	TEST.L	D2:#0	JUMP,BC 60$	DEC.W	D3	INC.W	D460$:	LOAD.W	D2,#SETDOT!TTTDOT	LIB	?DRSEG		; refait la grille horizontale	CLR.L	D2	LOAD.W	D2,D3	SUB.W	D2,(A6)+ORYPIX	DIV.WU	D2,#LGPAS	SWAP.W	D2;;?	COMP.W	D2,#LGPAS/8;;?	JUMP,HI 90$	COMP.W	D2,#LGPAS/2	JUMP,LO 90$	COMP.W	D2,#LGPAS/2+LGPAS/8	JUMP,HI 90$	CLR.L	D2	LOAD.W	D2,D3	SUB.W	D2,(A6)+ORYPIX	DIV.WU	D2,#LGPAS	CLR.L	D1	LOAD.W	D1,D2	MUL.WU	D2,#LGPAS;;?	JUMP,EQ 90$	ADD.W	D2 #LGPAS/2	ADD.W	D2,(A6)+ORYPIX	LOAD.W	D3,D2		; D3 <-- <xx>	SWAP.W	D3	LOAD.W	D2,(A6)+ORYHT	SR.W	D2,#1	SUB.W	D3,D2		; D3 <-- <yy>	LOAD.W	D2,D3	SUB.W	D2,(A6)+ORYPIY	TEST.L	D2:#0	JUMP,BC 65$	INC.W	D365$:	SWAP.W	D3	LOAD.W	D4,(A6)+ORYHT	; D4 <-- <dyy>	SWAP.W	D4	CLR.W	D4		; D4 <-- <dxx>	LOAD.W	D2,#SETDOT!TTTDOT	DIV.WU	D1,(A5)+ORMT	SWAP.W	D1	TEST.W	D1	JUMP,NE 70$	LOAD.W	D2,#SETDOT	; D2 <-- trait plein pour marquer le temps70$:	LIB	?DRSEG		; refait la grille verticale90$:	POPM.L	D0..D4	RET;---------\\; RYTHINVM >;=========/; Dessine une mesure quelconque.; in	D3.L	position (i;p);	D2.W	mode de dessin; out	-; mod	D7.WRYTHINVM:	PUSHM.L	D2..D4	COMP.W	D3,#MAXPAS	JUMP,HS 90$	LOAD.L	D4,#H'55AA55AA	CALL	DRMDEF	LOAD.W	D4,#MAXPAS	SUB.W	D4,D3	MUL.WU	D3,#LGPAS	ADD.W	D3,(A6)+ORYPIX	INC.W	D3		; D3 <-- <xx>	SWAP.W	D3	LOAD.W	D3,(A6)+ORYPCY	INC.W	D3		; D3 <-- <yy>	SWAP.W	D3	MUL.WU	D4,#LGPAS	DEC.W	D4		; D4 <-- <dxx>	SWAP.W	D4	LOAD.W	D4,(A6)+ORYHT	DEC.W	D4		; D4 <-- <dyy>	SWAP.W	D4	LIB	?DRMATRIX90$:	POPM.L	D2..D4	RET;----------\\; RYTHTAKEC >;==========/; Met une case dans le buffer d'dition.; in	D3.L	position case (y;x); out	-; mod	D7.WRYTHTAKEC:	PUSHM.L	D3,A3,A4	CALL	RYTHMAJC	; mj case actuellement en dition	LOAD.L	(A6)+OCAPOS,D3	CALL	RYTHPUTC	LOAD.L	(A6)+OCAPTL,A4	ADD.W	D3,#2		; D3 <-- place pour le curseur	LOAD.W	(A6)+OCALGL,D3	POPM.L	D3,A3,A4	RET;---------\\; RYTHPUTC >;=========/; Construit le texte d'une case dans le buffer d'dition.; in	D3.L	position case (y;x); out	A3.L	^dbut texte;	A4.L	^fin texte;	D3.W	longueur; mod	D3.L, D7.W, A3.L, A4.LRYTHPUTC:	PUSHM.L	D2,D4	LOAD.L	A3,#(A5)+ORMR	LOAD.W	D2,#3!2^15	COMP.L	D3,#COOCAR	; (-1;0) ?	JUMP,EQ 20$	LOAD.L	A4,#(A5)+ORMI	LOAD.L	D4,D3	SWAP.W	D4	MUL.WU	D4,#LRI	ADD.L	A4,D4		; A4 <-- ^variables de la ligne	LOAD.W	D4,D3	LOAD.L	A3,#(A4)+ORINAME	LOAD.W	D2,#LRINAME	DEC.W	D4	JUMP,NS 50$;;?	LOAD.L	A3,#(A4)+ORIMIDI;;?	LOAD.W	D2,#2!2^15;;?	DEC.W	D4;;?	JUMP,NS 20$	LOAD.L	A3,#(A4)+ORINOTA	LOAD.W	D2,#3!2^15	DEC.W	D4	JUMP,NS 20$	LOAD.L	A3,#(A4)+ORINOTB;	LOAD.W	D2,#3!2^1520$:				; nombre =>	LOAD.L	A4,#(A6)+OCALINE	LOAD.W	D4,(A3)		; D4 <-- nombre;;?	COMP.W	D3,#1		; canal MIDI ?;;?	JUMP,NE 30$		; non => 30$;;?	INC.W	D4		; oui => 1..16;;?	CALL	PUTANUM		; buffer <-- nombre;;?	JUMP	80$;;?30$:	TEST.W	D4	JUMP,EQ 35$	CALL	PUTANUM		; buffer <-- nombre	JUMP	80$35$:	LOAD.B	D4,D236$:	LOAD.B	(A4+),#SPACE	; buffer <-- espaces	DEC.B	D4	JUMP,NE 36$	JUMP	80$50$:				; texte =>	LOAD.L	A4,#(A6)+OCALINE55$:	LOAD.B	(A4+),(A3+)	; buffer <-- texte	JUMP,NE 55$	DEC.L	A480$:	CLR.B	(A4)		; buffer <-- terminateur	LOAD.L	A3,#(A6)+OCALINE	LOAD.W	D3,D2		; D3 <-- longueur	POPM.L	D2,D4	RET;---------\\; RYTHMAJC >;=========/; Met  jour le buffer d'dition dans une case.; in	-; out	-; mod	D7.WRYTHMAJC:	PUSHM.L	D0..D4,A2..A4	LOAD.L	D3,(A6)+OCAPOS	COMP.L	D3,#-1	JUMP,EQ 90$	LOAD.L	A2,#(A5)+ORMR	LOAD.W	D0,#1		; D0 <-- min	LOAD.W	D1,#1000	; D1 <-- max	COMP.L	D3,#COOCAR	; (-1;0) ?	JUMP,EQ 20$	LOAD.L	A4,#(A5)+ORMI	LOAD.L	D4,D3	SWAP.W	D4	MUL.WU	D4,#LRI	ADD.L	A4,D4		; A4 <-- ^variables de la ligne	LOAD.W	D4,D3	LOAD.L	A2,#(A4)+ORINAME	DEC.W	D4	JUMP,NS 50$;;?	LOAD.L	A2,#(A4)+ORIMIDI;;?	CLR.W	D0		; D0 <-- min;;?	LOAD.W	D1,#16		; D1 <-- max;;?	DEC.W	D4;;?	JUMP,NS 20$	LOAD.L	A2,#(A4)+ORINOTA	CLR.W	D0		; D0 <-- min	LOAD.W	D1,#128		; D1 <-- max	DEC.W	D4	JUMP,NS 20$	LOAD.L	A2,#(A4)+ORINOTB;	CLR.W	D0		; D0 <-- min;	LOAD.W	D1,#128		; D1 <-- max;	DEC.W	D4;	JUMP,NS 20$20$:				; nombre =>	LOAD.L	A4,#(A6)+OCALINE; A4 <-- ^nombre	CALL	GETANUM		; D4 <-- nombre;;?	COMP.W	D3,#1		; canal MIDI ?;;?	JUMP,NE 30$		; non => 30$;;?	DEC.W	D4		; oui => 0..15;;?30$:	COMP.W	D4,D0		; nombre trop petit ?	JUMP,GE 40$	LOAD.W	D4,D040$:	COMP.W	D4,D1		; nombre trop grand ?	JUMP,LT 45$	LOAD.W	D4,D1	DEC.W	D445$:	LOAD.W	(A2),D4		; mj le nombre	CALL	RYTHPUTC	; A3 <-- ^texte v. ajust	LIB	?AFTEXT		; raffiche le texte v. ajust	JUMP	80$50$:				; texte =>	LOAD.L	A4,#(A6)+OCALINE; A4 <-- ^texte55$:	LOAD.B	(A2+),(A4+)	; mj le texte	JUMP,EQ 58$	COMP.B	(A2)-1,#CR	JUMP,NE 55$58$:	CLR.B	(A2)-180$:	LOAD.L	(A6)+OCAPOS,#-190$:	POPM.L	D0..D4,A2..A4	RET;--------\\; PUTANUM >;--------/; Met un nombre dcimal dans un buffer.; in	D4.W	nombre;	D2.B	nb digits;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D1..D4	AND.L	D4,#H'FFFF	; D4 <-- nombre binaire	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D1,#8		; D1 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D1,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D1:#10		; zro significatif ?	JUMP',BS 40$		; oui => 40$	COMP.B	D1,D2	JUMP',HI 50$	LOAD.B	(A4+),#SPACE	JUMP'	50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D1:#1050$:	DEC.B	D1	JUMP,NE	10$	POPM.L	D1..D4	RET;--------\\; GETANUM >;--------/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSH.L	D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POP.L	D3	RET	.INS	RYTHIO.ASI	.INS	RYTHDBOX.ASI	.INS	RYTHBASE.ASI	.INS	RYTHMIDI.ASI	.INS	RYTHMISC.ASI; Tables; ------TKEDIT:	.B	0,TAB	.B	2^7	.EVEN; Textes; ------TICOBASE:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+1	.B	ICOPREND,ICOFLOPPY,ICOSAUVE	.B	ICORYTHME,ICORYTHME,ICORYTHME	.B	ICOMETRO,0,0	.B	ICONOTEA,ICOFORCE2,ICOPAS1	.B	ICOMINS,ICOMCOP,ICOMDELTMENUBASE:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Ecoute"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Temps            "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Note Force Espace"		;     ;     ;     ;	.ASCIZ	"      Copie      "	.ASCIZ	"Ajoute    Dtruit"TXSCALE:	.ASCIZ	"120"	.ASCIZ	"60"	.ASCIZ	"30"	.EVENNMDBOX:	.ASCIZ	"DBOX"NMLIST:	.ASCIZ	"LIST"NMSCROLL:.ASCIZ	"SCROLL"LMIDI:	.ASCIZ	"#MIDI:"PMIDI:	.ASCIZ	"$MIDI_0"DMIDI:	.ASCIZ	"MIDI_0"CMSYNC:	.ASCIZ	"S"		; commande de synchronisationTXEXT:	.ASCIZ	".rythm"	.EVENEND_RYTH:	.END