	.SBTTL	PARTSYMB;---------\\; PREPSYMB >;=========/; Met une note dans le symbole courant en fonction des soft-keys allumes.; in	D0.W	icnes allums en bas de l'cran;	D1.W	niveau (haut/bas/silence);	A4.L	^symbole courant; out	-; mod	D7.WPREPSYMB:	PUSHM.L	D0..D3,A3	CLR.B	(A4)+OSYFLG	CLR.B	(A4)+OSYALT	CLR.B	(A4)+OSYACC	CLR.B	(A4)+OSYFRAP	CLR.L	(A4)+OSYNOB	; pas de barre-croche	LOAD.L	A3,#R16"TICODIVERS1	COMP.W	D1,#NDIVERS1	JUMP,EQ 50$	LOAD.L	A3,#R16"TICODIVERS2	COMP.W	D1,#NDIVERS2	JUMP,EQ 60$	LOAD.B	D3,#ICOPAUSE-1	COMP.W	D1,#NHAUTSILENCE	JUMP',EQ 12$	LOAD.B	D3,#ICOPAUSE-1	COMP.W	D1,#NBASSILENCE	JUMP',EQ 10$	LOAD.B	D3,#ICOHRONDE-1	COMP.W	D1,#NHAUTNOTE	JUMP',EQ 12$	LOAD.B	D3,#ICOBRONDE-110$:	TSET.B	(A4)+OSYFLG:#BSYBAS12$:	LOAD.W	D2,D0	RR.W	D2,#SKNFIRST20$:	INC.W	D3		; D3 <-- code icne suivante	RR.W	D2,#1	JUMP,CC 20$	LOAD.B	(A4)+OOBJC,D3	; symbole <-- code icne	LOAD.W	D2,(A6)+ONPOINT	COMP.W	D2,#ICOPOINT	JUMP',NE 30$	TSET.B	(A4)+OSYFLG:#BSYPOINT30$:	COMP.W	D2,#ICODEUX	JUMP',NE 32$	TSET.B	(A4)+OSYFLG:#BSYDUOLET32$:	COMP.W	D2,#ICOTROIS	JUMP',NE 33$	TSET.B	(A4)+OSYFLG:#BSYTRIOLET33$:	COMP.W	D2,#ICOQUATRE	JUMP',NE 34$	TSET.B	(A4)+OSYFLG:#BSYDUOLET34$:	COMP.W	D2,#ICOCINQ	JUMP',NE 35$	TSET.B	(A4)+OSYFLG:#BSYQUINTOLET35$:	COMP.W	D2,#ICOSIX	JUMP',NE 36$	TSET.B	(A4)+OSYFLG:#BSYTRIOLET36$:	COMP.W	D2,#ICOSEPT	JUMP',NE 37$	TSET.B	(A4)+OSYFLG:#BSYSEPTOLET37$:	TEST.L	D0:#SKNNOQ	; sans queue ?	JUMP',BC 40$	TSET.B	(A4)+OSYFLG:#BSYNOQ40$:	COMP.W	D1,#NHAUTSILENCE	JUMP',EQ 90$	COMP.W	D1,#NBASSILENCE	JUMP',EQ 90$	LOAD.B	(A4)+OSYALT,(A6)+ONALT+1	LOAD.B	(A4)+OSYACC,(A6)+ONACC+1	LOAD.W	D3,(A6)+ONFRAP	SUB.W	D3,#(ICOSFRAPPE-1)!2^7 ; D3 <-- 1..5	LOAD.B	(A4)+OSYFRAP,D3	JUMP'	90$50$:				; divers zro =>	LOAD.W	D3,(A6)+ONCHI	TEST.L	D0:#SKDCHIFFRE	JUMP',BS 80$	LOAD.W	D3,(A6)+ONREP	TEST.L	D0:#SKDACCENT	JUMP',BS 80$60$:				; divers un =>	LOAD.W	D3,#-1	LOAD.W	D2,D065$:	INC.W	D3		; D3 <-- rang suivant	RR.W	D2,#1	JUMP,CC 65$	LOAD.B	D3,(A3)+(D3.W)+480$:	LOAD.B	(A4)+OOBJC,D3	; symbole <-- code icne90$:	POPM.L	D0..D3,A3	RET;----------\\; MOINSSYMB >;==========/; Diminue la dure d'un note ou d'un silence.; in	D0.W	icnes allums en bas de l'cran;	D1.W	niveau (haut/bas/silence);	A4.L	^symbole courant; out	D0.W	nouvelles icnes; mod	D0.W, D7.WMOINSSYMB:	PUSH.W	D2	LOAD.B	D2,(A4)+OOBJC	; D2 <-- code de l'objet	SUB.B	D2,#ICOHRONDE	JUMP',LO 90$	COMP.B	D2,#6-1	JUMP',LO 50$	LOAD.B	D2,(A4)+OOBJC	; D2 <-- code de l'objet	SUB.B	D2,#ICOBRONDE	JUMP',LO 90$	COMP.B	D2,#6-1	JUMP',LO 50$	LOAD.B	D2,(A4)+OOBJC	; D2 <-- code de l'objet	SUB.B	D2,#ICOPAUSE	JUMP',LO 90$	COMP.B	D2,#6-1	JUMP',HS 90$50$:	INC.B	(A4)+OOBJC	; diminue la dure	INC.B	D2	CALL	CLRSOFTKEY	; teint	INC.B	D2	CALL	SETSOFTKEY	; puis allume plus  droite90$:	POP.W	D2	RET;---------\\; PLUSSYMB >;=========/; Augmente la dure d'un note ou d'un silence.; in	D0.W	icnes allums en bas de l'cran;	D1.W	niveau (haut/bas/silence);	A4.L	^symbole courant; out	D0.W	nouvelles icnes; mod	D0.W, D7.WPLUSSYMB:	PUSH.W	D2	LOAD.B	D2,(A4)+OOBJC	; D2 <-- code de l'objet	SUB.B	D2,#ICOHRONDE+1	JUMP',LO 90$	COMP.B	D2,#6-1	JUMP',LO 50$	LOAD.B	D2,(A4)+OOBJC	; D2 <-- code de l'objet	SUB.B	D2,#ICOBRONDE+1	JUMP',LO 90$	COMP.B	D2,#6-1	JUMP',LO 50$	LOAD.B	D2,(A4)+OOBJC	; D2 <-- code de l'objet	SUB.B	D2,#ICOPAUSE+1	JUMP',LO 90$	COMP.B	D2,#6-1	JUMP',HS 90$50$:	DEC.B	(A4)+OOBJC	; augmente la dure	ADD.B	D2,#1+1	CALL	CLRSOFTKEY	; teint	DEC.B	D2	CALL	SETSOFTKEY	; puis allume plus  gauche90$:	POP.W	D2	RET;--------\\; DESSYMB >;========/; Dessine un symbole complet.; in	A4.L	^symbole;	D2.W	mode de dessin; out	-; mod	D7.WDESSYMB:	PUSHM.L	D0..D4	CALL	DESBARRES	; met p'tit bout de porte	JUMP,NE 90$		; si pas dans porte => 90$	LOAD.B	D3,(A4)+OOBJC	; D3 <-- code de l'icne	LOAD.W	D0,#1		; D0 <-- un si tourn contre en bas	COMP.B	D3,#ICOPAUSE	JUMP',HS 05$	COMP.B	D3,#ICOBRONDE	JUMP',HS 05$	DEC.W	D0		; D0 <-- zro si tourn contre en haut05$:	TEST.B	(A4)+OOBJF:#BGROUPE	JUMP',BC 10$	LOAD.L	D4,(A4)+OSYNOB	; D4 <-- no du groupe	LOAD.B	D3,#ICOHNOTE	; oui => ne dessine pas la queue	ADD.B	D3,D0		; D3 <-- ICO(H/B)NOTE	COMP.L	D4,#-1		; lie provisoirement ?	JUMP',EQ 15$		; oui => 15$	COMP.L	D4,(A6)+OBCLAST	; dj dessin cette barre dans la mesure ?	JUMP',EQ 15$		; oui => 15$	LOAD.L	(A6)+OBCLAST,D4	PUSH.L	A4	CALL	DESBC		; dessine la barre	POP.L	A4	JUMP'	15$10$:	TEST.B	(A4)+OSYFLG:#BSYNOQ	JUMP',BC 15$	LOAD.B	D1,D3		; D1 <-- code de la note	LOAD.B	D3,#ICOHRONDE	COMP.B	D1,#ICOHBLANCHE	JUMP',LS 15$	LOAD.B	D3,#ICOHNOTE	COMP.B	D1,#ICOHTCROCHE	JUMP',LS 15$	LOAD.B	D3,#ICOBRONDE	COMP.B	D1,#ICOBBLANCHE	JUMP',LS 15$	LOAD.B	D3,#ICOBNOTE	COMP.B	D1,#ICOBTCROCHE	JUMP',LS 15$	LOAD.B	D3,D115$:	LOAD.L	D4,(A4)+OSYPOS	; D4 <-- position du symbole	CALL	DESONESYMB	; dessine le symbole "principal"	TEST.B	(A4)+OSYFLG:#BSYPOINT	JUMP',BC 20$	LOAD.B	D3,#ICOPOINT	CALL	DESONESYMB	; pointe le symbole20$:	LOAD.B	D3,(A4)+OSYALT	JUMP',EQ 30$	CALL	DESONESYMB	; dessine l'altration30$:	LOAD.B	D3,(A4)+OSYACC	JUMP',EQ 40$	ADD.B	D3,D0		; D3 <-- utilise ICOH/ICOB.. selon	CALL	DESONESYMB	; dessine l'accentuation40$:;	...90$:	POPM.L	D0..D4	RET;----------\\; DESBARRES >;----------/; Si ncessaire, dessine un petit bout de porte sous une note; sous forme de plusieurs barres.; in	A4.L	^symbole;	D2.W	mode de dessin; out	D7.W	ERNOT	=> pas dans une porte; mod	D7.WDESBARRES:	PUSHM.L	D0..D4,A3	LOAD.L	A3,(A6)+OPMES	; A3 <-- ^mesure courante	LOAD.L	A3,#(A3)+OMELP	; A3 <-- ^table des portes	LOAD.W	D3,#MAXLP	LOAD.W	D4,(A4)+OSYPOS+0 ; D4 <-- position en Y de la note10$:	COMP.B	(A3)+OLPTYP,#ICOVIDE	JUMP',EQ 20$	COMP.W	D4,(A3)+OLPMIN	; dans cette porte ?	JUMP',LO 20$		; non => 20$	COMP.W	D4,(A3)+OLPMAX	JUMP',LO 30$		; oui => 30$20$:	LOAD.L	A3,#(A3)+LLP	; A4 <-- ^porte suivante	DEC.W	D3	JUMP,NE 10$	LOAD.W	D7,#ERSNOT	; D7 <-- pas dans une porte	JUMP	90$30$:	LOAD.B	D3,(A4)+OOBJC	; D3 <-- code de l'icne	COMP.B	D3,#ICOHRONDE	JUMP,LO 80$	COMP.B	D3,#ICOBTCROCHE	JUMP,HI 80$				; c'est une note =>	LOAD.W	D3,(A3)+OLPDY	SUB.W	D3,#LYPORTEE	; D3 <-- hauteur suprieure	COMP.W	D4,D3	JUMP',HI 40$				; on est dessus la porte =>	CLR.L	D0	LOAD.W	D0,D3	SUB.W	D0,D4	DIV.WU	D0,#LYPORTEE	LOAD.W	D1,#-LYPORTEE	JUMP'	50$40$:	ADD.W	D3,#LYPORTEE*(NPORTEE+1) ; D3 <-- hauteur infrieure	COMP.W	D4,D3	JUMP',LO 80$				; on est dessous la porte =>	CLR.L	D0	LOAD.W	D0,D4	SUB.W	D0,D3	DIV.WU	D0,#LYPORTEE	LOAD.W	D1,#+LYPORTEE50$:	SWAP.W	D3	LOAD.W	D3,(A4)+OSYPOS+2 ; D3 <-- position du symbole en X	SUB.W	D3,#8		; D3 <-- <xx>	CLR.L	D4		; D4 <-- <dyy>	LOAD.W	D4,#18		; D4 <-- <dxx>60$:	PUSH.L	D3	LIB	?DRSEG		; dessine un p'tit bout de porte	POP.L	D3	DEC.W	D0		; encore une ?	JUMP',NS 80$		; non => 80$				; oui =>	SWAP.W	D3	ADD.W	D3,D1		; D3 <-- <yy> monte/descend	SWAP.W	D3	JUMP	60$80$:	CLR.W	D7		; D7 <-- on est dans une porte90$:	POPM.L	D0..D4,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DESONESYMB >;-----------/; Dessine un symbole lmentaire (unique).; in	D3.B	code du symbole;		   0..127  =>  icne de ISP32;		 128..255  =>  icne de ISP33;	D4.L	coordonne (y;x);	D2.W	mode de dessin; out	D7.W	erreur; mod	D7.WDESONESYMB:	PUSHM.L	D4,A1	TEST.L	D3:#7		; icne de ISP33 ?	JUMP',BS 50$		; oui => 50$	CALL	SRCTSYMB	; A1 <-- ^descripteur du symbole	JUMP',NE 90$	SUB.W	D4,(A1)+OTSCX	SUB.W	D4,(A1)+OTSX	SWAP.W	D4	ADD.W	D4,(A1)+OTSCY	ADD.W	D4,(A1)+OTSY	SUB.W	D4,#GCICB	; tient compte de la ligne de base !	SWAP.W	D450$:	CALL	DESPOSSYMB	; dessine le symbole	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A1	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DESPOSSYMB >;-----------/; Dessine n'importe quel symbole comme un caracte.; Clip le symbole s'il dpasse !; in	D3.B	code du symbole;		   0..127  =>  icne de ISP32;		 128..255  =>  icne de ISP33;	D4.L	coordonne "centre" de l'icne (y;x);	D2.W	mode de dessin; out	-; mod	D7.WDESPOSSYMB:	PUSHM.L	D0..D4,A1..A3; Vrifie si l'icne peut tre dessin intgralement.; Si non, il sera dessin avec le "raster-op", appel un peu; plus lent.	LOAD.L	D1,D4	TEST.W	D1		; dpasse  gauche ?	JUMP,NS 40$		; oui => 40$	ADD.W	D1,#LXICONE	COMP.W	D1,(A0)+ODFFDX	; dpasse  droite ?	JUMP,HS 40$		; oui => 40$	SWAP.W	D1	SUB.W	D1,#GCICT-GCICB	; dpasse en haut ?	JUMP,NS 40$		; oui => 40$	ADD.W	D1,#GCICT	COMP.W	D1,(A0)+ODFFDY	; dpasse en bas ?	JUMP,HS 40$		; oui => 40$; Dessin rapidement l'icne, comme n'importe quel caractre.	LOAD.L	A3,#(A6)+OBDIS	; A3 <-- ^buffer d'criture	LOAD.L	(A3+),#H'1000000*USEGC+H'10000*GCICF+H'100*GCICS+H'1*GCICT	TCLR.L	D3:#7		; icne de ISP33 ?	JUMP',BC 20$		; non => 20$	LOAD.B	(A3)-1,#GCICT2	; oui => met la taille 3320$:	LOAD.B	(A3+),#MODCAR	TSET.L	D2:#BPENDOT	; D2 <-- nouveau mode	LOAD.B	(A3+),D2	LOAD.W	(A3+),#TYPOAX	LOAD.W	(A3+),D4	LOAD.W	(A3+),#TYPOAY	SWAP.W	D4	LOAD.W	(A3+),D4	LOAD.B	(A3+),#AFTOUT	LOAD.B	(A3+),D3	LOAD.B	(A3+),#AFNORM	CLR.B	(A3+)	LOAD.W	(A3+),#H'100*MODCAR+H'1*SETDOT	LOAD.L	(A3+),#H'1000000*USEGC+H'10000*GCTXF+H'100*GCTXS+H'1*GCTXT	LOAD.L	D3,A3		; D3 <-- ^fin du buffer	LOAD.L	A3,#(A6)+OBDIS	; A3 <-- ^dbut du buffer	SUB.L	D3,A3		; D3 <-- longueur	LIB	?STRING		; vide tout le buffer	JUMP	90$; Dessine l'icne avec le "raster-op", en grant le cliping de; tous les cts (pfff, c'est pas de la tarte !).40$:	CLR.W	D0	LOAD.B	D0,D3		; D0 <-- code du caractre	LOAD.L	A1,(A6)+OPGCIC	; A1 <-- ^gencar ISP32	TCLR.L	D0:#7		; icne de ISP33 ?	JUMP',BC 42$		; non => 42$	LOAD.L	A1,(A6)+OPGCIC2	; A1 <-- ^gencar ISP3342$:	LOAD.L	A3,#(A6)+OBDIS	; A3 <-- ^buffer d'criture	LOAD.W	(A3)+0,#DRAWRASTER	LOAD.L	A2,#(A1)+OGCWID+(3*128)	MUL.WU	D0,(A1)+OGCMSB	ADD.L	A2,D0		; A2 <-- ^matrice	LOAD.L	(A3)+6,A2	; source: <pppp>	LOAD.W	D1,#LXICONE	; D1 <-- largeur complte	LOAD.W	D0,D4	ADD.W	D0,D1	SUB.W	D0,(A0)+ODFFDX	; dpasse  droite ?	JUMP',LS 50$	SUB.W	D1,D0		; D1 <-- diminue la largeur50$:	LOAD.W	(A3)+22,D1	; <dxx>	LOAD.W	D1,#GCICT	; D1 <-- hauteur complte	LOAD.L	D0,D4	SWAP.W	D0	ADD.W	D0,#GCICB	SUB.W	D0,(A0)+ODFFDY	; dpasse en bas ?	JUMP',LS 52$	SUB.W	D1,D0		; D1 <-- diminue la hauteur52$:	LOAD.W	(A3)+24,D1	; <dyy>	CLR.W	D0	TEST.W	D4		; dpasse  gauche ?	JUMP',NC 54$	LOAD.W	D0,D4	NEG.W	D0	SUB.W	(A3)+22,D0	; <dxx> diminue la largeur	CLR.W	D454$:	LOAD.W	(A3)+2,D0	; source: <xx>	LOAD.W	(A3)+12,D4	; destination: <xx>	CLR.W	D0	SWAP.W	D4	SUB.W	D4,#GCICT-GCICB	; D4 <-- coordonne haut du caractre Y	JUMP',NC 56$		; dpasse en haut ?	LOAD.W	D0,D4	NEG.W	D0	SUB.W	(A3)+24,D0	; <dyy> diminue la hauteur	CLR.W	D456$:	LOAD.W	(A3)+4,D0	; source: <yy>	LOAD.W	(A3)+14,D4	; destination: <yy>	CLR.W	D0	LOAD.B	D0,(A1)+OGCMWB	; D0 <-- largeur en bytes	LOAD.W	(A3)+10,D0	; source: <ii>	CLR.L	(A3)+16		; destination: <pppp>	LOAD.B	(A3)+26,D2	; <mode>	CLR.B	(A3)+27	LOAD.W	D3,#28	LIB	?STRING		; vide tout le buffer90$:	POPM.L	D0..D4,A1..A3	RET;--------\\; DESBC   >;========/; Dessine les liaisons entre un groupe de croches.; in	D4.L	no de la barre;	D2.W	mode de dessin; out	D7.W	ok;	D7.W	il ne reste qu'une croche;	 A4.L	 ^croche solitaire; mod	D7.W, A4.LDESBC:	PUSHM.L	D0,D1,D3,D4,A2,A3; Met dans OBDLIST toutes les croches lies avec la mme barre,; et cherche s'il y en a plus tournes contre en haut ou contre en bas.	LOAD.L	A3,#(A6)+OBDLIST	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut mesure	CLR.W	D010$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 20$	LOAD.B	D3,(A4)+OOBJC	; D3 <-- objet	COMP.B	D3,#OBJMES	; dbut de la mesure suivante ?	JUMP',EQ 20$		; oui => 20$	CLR.W	D1		; D1 <-- clear flags divers	LOAD.B	D1,D3	SUB.B	D1,#ICOHCROCHE	; croche contre en haut ?	JUMP,LO 10$	COMP.B	D1,#ICOHTCROCHE-ICOHCROCHE	JUMP',LS 15$	LOAD.B	D1,D3	SUB.B	D1,#ICOBCROCHE	; croche contre en bas ?	JUMP,LO 10$	COMP.B	D1,#ICOBTCROCHE-ICOBCROCHE	JUMP,HI 10$	COMP.L	D4,(A4)+OSYNOB	; est-ce la mme barre ?	JUMP,NE 10$	DEC.W	D0		; D0 <-- -1 si contre en bas	LOAD.L	(A3+),(A4)+OSYPOS	LOAD.L	(A3+),A4	LOAD.B	(A3+),D1	; mm. 0..2 selon le type de croche	CLR.B	(A3+)	LOAD.L	A2,A4		; A2 <-- ^dernire croche	JUMP	10$15$:	COMP.L	D4,(A4)+OSYNOB	; est-ce la mme barre ?	JUMP,NE 10$	INC.W	D0		; D0 <-- +1 si contre en haut	LOAD.L	(A3+),(A4)+OSYPOS	LOAD.L	(A3+),A4	LOAD.B	(A3+),D1	; mm. 0..2 selon le type de croche	CLR.B	(A3+)	LOAD.L	A2,A4		; A2 <-- ^dernire croche	JUMP	10$20$:	CLR.L	(A3); S'il n'y a qu'une croche lie, supprime le reste de liaison.	LOAD.L	A3,#(A6)+OBDLIST	TEST.L	(A3)+LBD	; une seule croche ?	JUMP',NE 25$		; non => 25$				; oui =>	LOAD.L	A4,A2		; A4 <-- ^dernire croche (l'unique)	CLR.L	(A4)+OSYNOB	; supprime la liaison unique	TCLR.B	(A4)+OOBJF:#BGROUPE	LOAD.W	D7,#ERSNOT	JUMP	90$; Cherche le point le plus haut et le point le plus bas pour dterminer; la position en Y de la barre horizontale.25$:	CLR.W	D4		; D4 <-- point le plus bas	TEST.W	D0		; contre en bas ?	JUMP',NS 35$		; oui => 35$	LOAD.W	D4,#-1		; D4 <-- point le plus haut30$:				; contre en haut =>	CLR.W	D3	LOAD.B	D3,(A3)+OBDTYC	MUL.WU	D3,#LYPORTEE	ADD.W	D3,#HYBARRE	; D3 <-- longueur de la queue	SUB.W	D3,(A3)+OBDPOS+0	NEG.W	D3		; D3 <-- position	COMP.W	D4,D3	JUMP',LS 32$	LOAD.W	D4,D3		; D4 <-- point le plus haut32$:	ADD.L	A3,#LBD	TEST.L	(A3)		; fin de la liste ?	JUMP,NE 30$	LOAD.W	D1,#-HYBARRE	; D1 <-- contre en haut	JUMP'	40$35$:				; contre en bas =>	CLR.W	D3	LOAD.B	D3,(A3)+OBDTYC	MUL.WU	D3,#LYPORTEE	ADD.W	D3,#HYBARRE	; D3 <-- longueur de la queue	ADD.W	D3,(A3)+OBDPOS+0; D3 <-- position	COMP.W	D4,D3	JUMP',HS 37$	LOAD.W	D4,D3		; D4 <-- point le plus bas37$:	ADD.L	A3,#LBD	TEST.L	(A3)		; fin de la liste ?	JUMP,NE 35$	LOAD.W	D1,#+HYBARRE	; D1 <-- contre en bas40$:	CALL	CROTRIE		; trie les croches de gauche  droite	LIB	?BUCAR	LOAD.L	A3,#(A6)+OBDLIST45$:	CALL	CROVERTICAL	; dessine les barres verticales	ADD.L	A3,#LBD	TEST.L	(A3)		; fin de la liste ?	JUMP,NE 45$	TSET.B	(A3)-LBD+OBDFLG:#0 ; indique le dernier	LOAD.L	A3,#(A6)+OBDLIST; A3 <-- ^premire croche50$:	LOAD.L	A4,#(A3)+LBD	; A4 <-- ^suivante	TEST.L	(A4)		; suivante existe ?	JUMP',EQ 80$		; non => 80$	LOAD.B	D3,(A3)+OBDTYC	COMP.B	D3,(A4)+OBDTYC	JUMP',LO 60$	JUMP',HI 70$				; A=S :	LOAD.B	D0,(A3)+OBDTYC	; D0 <-- nb(A)	CALL	CROHORIZONTAL	; dessine barres horizontales compltes	LOAD.L	A3,A4		; A3 <-- ^S	TSET.B	(A3)+OBDFLG:#1	; "fait"	JUMP	50$60$:				; A<S :	LOAD.B	D0,(A3)+OBDTYC	; D0 <-- nb(A)	CALL	CROHORIZONTAL	; dessine barres horizontales compltes	TEST.B	(A4)+OBDFLG:#0	; S=dernier ?	JUMP',BS 65$		; oui => 65$	LOAD.L	A3,A4		; A3 <-- ^S;	TCLR.B	(A3)+OBDFLG:#1	; "incomplet"	JUMP	50$65$:	CALL	CROHORFIN	; dessine barres horizontales  la fin	LOAD.L	A3,A4		; A3 <-- ^S	JUMP	50$70$:				; A>S :	LOAD.B	D0,(A4)+OBDTYC	; D0 <-- nb(S)	CALL	CROHORIZONTAL	; dessine barres horizontales compltes	TEST.B	(A3)+OBDFLG:#1	; "fait"/"incomplet" ?	JUMP',BS 75$		; "fait" => 75$	CALL	CROHORDEBUT	; dessine barres horizontales au dbut75$:	LOAD.L	A3,A4		; A3 <-- ^S	TSET.B	(A3)+OBDFLG:#1	; "fait"	JUMP	50$; Met la position de la barre dans la premire croche, et met; zro dans toutes les croches suivantes.80$:	LOAD.L	A3,#(A6)+OBDLIST82$:	LOAD.L	A3,#(A3)+LBD	; A3 <-- ^croche suivante (saute la premire)	TEST.L	(A3)	JUMP',EQ 85$	LOAD.W	D3,(A3)+OBDPOS+2 ; D3 <-- position  l'extrme droite	LOAD.L	A4,(A3)+OBDPTC	; A4 <-- ^objet croche	CLR.L	(A4)+OSYPOB	JUMP	82$85$:	LOAD.L	A3,#(A6)+OBDLIST	SUB.W	D3,(A3)+OBDPOS+2	LOAD.L	A4,(A3)+OBDPTC	; A4 <-- ^objet croche	LOAD.W	(A4)+OSYPOB+0,D4 ; objet <-- position de la barre en Y	LOAD.W	(A4)+OSYPOB+2,D3 ; objet <-- longueur de la barre	LIB	?NOBUCAR	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1,D3,D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; CROTRIE >;--------/; Trie les croches dans la liste pour les mettres de; gauche  droite (bubble-sort) !; in	-; out	-; mod	D7.WCROTRIE:	PUSHM.L	D2..D4,A310$:	LOAD.L	A3,#(A6)+OBDLIST	CLR.W	D3		; D3 <-- nb de permutations20$:	TEST.L	(A3)+LBD	; croche suivante existe ?	JUMP',EQ 30$		; non => 30$	LOAD.W	D4,(A3)+OBDPOS+2	COMP.W	D4,(A3)+LBD+OBDPOS+2 ; avant le suivant ?	JUMP',LS 30$		; oui => 30$				; non => permute	PUSH.L	A3	LOAD.W	D2,#(LBD/2)-125$:	LOAD.W	D4,(A3)	LOAD.W	(A3),(A3)+LBD	LOAD.W	(A3)+LBD,D4	ADD.L	A3,#2	DECJ.W,NMO D2,25$	POP.L	A3	INC.W	D3		; D3 <-- une permutation de plus30$:	LOAD.L	A3,#(A3)+LBD	TEST.L	(A3)		; fin de la liste ?	JUMP,NE 20$	TEST.W	D3		; a-t-il fait qq chose ?	JUMP,NE 10$		; oui => on remet a !				; non => c'est bon	POPM.L	D2..D4,A3	RET;------------\\; CROVERTICAL >;------------/; Dessine la barre verticale d'une croche tourne contre; en haut ou contre en bas.; in	A3.L	^croche dans OBDLIST;	D4.W	hauteur de la barre (y);	D2.W	mode de dessin;	D1.W	- si contre en haut;		+ si contre en bas; out	-; mod	D7.WCROVERTICAL:	PUSHM.L	D3,D4	LOAD.W	D3,D4		; D3 <-- <yy>	SUB.W	D4,(A3)+OBDPOS+0	NEG.W	D4		; D4 <-- <dyy>	SWAP.W	D4	CLR.W	D4		; D4 <-- <dxx>	SWAP.W	D3	LOAD.W	D3,(A3)+OBDPOS+2 ; D3 <-- <xx> au centre de la croche	ADD.W	D3,#LXPORTEE/2	TEST.W	D1	JUMP',NS 20$	SUB.W	D3,#LXPORTEE20$:	LIB	?DRSEG		; trace une ligne verticale	POPM.L	D3,D4	RET;--------------\\; CROHORIZONTAL >;--------------/; Dessine une barre horizontale entre deux croches.; in	A3.L	^premire croche dans OBDLIST;	A4.L	^dernire croche dans OBDLIST;	D4.W	hauteur de la barre (y);	D2.W	mode de dessin;	D1.W	- si contre en haut;		+ si contre en bas;	D0.B	nb de barres -1 (0..2); out	-; mod	D7.WCROHORIZONTAL:	PUSHM.L	D0..D6	LOAD.W	D3,D4		; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D3,(A3)+OBDPOS+2 ; D3 <-- <xx> au centre de la croche	ADD.W	D3,#LXPORTEE/2	TEST.W	D1	JUMP',NS 20$	SUB.W	D3,#LXPORTEE20$:	INC.W	D3		; D3 <-- <xx>	CLR.L	D4		; D4 <-- <dyy>	LOAD.W	D4,(A4)+OBDPOS+2	SUB.W	D4,(A3)+OBDPOS+2 ; D4 <-- <dxx>	JUMP',EQ 90$	DEC.W	D4	INC.B	D0		; D0 <-- 1..3	LOAD.W	D5,#+1	LOAD.W	D6,#+(LYPORTEE-LYBARRE)	TEST.W	D1	JUMP',NS 40$	LOAD.W	D5,#-1	LOAD.W	D6,#-(LYPORTEE-LYBARRE)40$:	LOAD.W	D1,#LYBARRE	; D1 <-- paisseur50$:	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	SWAP.W	D3	ADD.W	D3,D5		; D3 <-- <yy> plus bas/haut	SWAP.W	D3	DEC.W	D1	JUMP,NE 50$	SWAP.W	D3	ADD.W	D3,D6		; D3 <-- <yy> barre suivante	SWAP.W	D3	DEC.B	D0	JUMP,NE 40$90$:	POPM.L	D0..D6	RET;------------\\; CROHORDEBUT >;------------/; Dessine une barre horizontale au dbut entre deux croches.; in	A3.L	^premire croche dans OBDLIST;	A4.L	^dernire croche dans OBDLIST;	D4.W	hauteur de la barre (y);	D2.W	mode de dessin;	D1.W	- si contre en haut;		+ si contre en bas; out	-; mod	D7.WCROHORDEBUT:	PUSHM.L	D0..D6	LOAD.W	D3,D4	LOAD.W	D6,#+LYPORTEE	TEST.W	D1	JUMP',NS 10$	LOAD.W	D6,#-LYPORTEE10$:	CLR.W	D0	LOAD.B	D0,(A4)+OBDTYC	; D0 <-- 0..2 (S)	INC.B	D0		; D0 <-- 1..3	MUL.WA	D6,D0	ADD.W	D3,D6		; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D3,(A3)+OBDPOS+2 ; D3 <-- <xx> au centre de la croche	ADD.W	D3,#LXPORTEE/2	TEST.W	D1	JUMP',NS 20$	SUB.W	D3,#LXPORTEE20$:	INC.W	D3		; D3 <-- <xx>	CLR.L	D4		; D4 <-- <dyy>	LOAD.W	D4,#LXBARRE	; D4 <-- <dxx>	LOAD.B	D0,(A3)+OBDTYC	SUB.B	D0,(A4)+OBDTYC	; D0 <-- A-S	LOAD.W	D5,#+1	LOAD.W	D6,#+(LYPORTEE-LYBARRE)	TEST.W	D1	JUMP',NS 40$	LOAD.W	D5,#-1	LOAD.W	D6,#-(LYPORTEE-LYBARRE)40$:	LOAD.W	D1,#LYBARRE	; D1 <-- paisseur50$:	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	SWAP.W	D3	ADD.W	D3,D5		; D3 <-- <yy> plus bas/haut	SWAP.W	D3	DEC.W	D1	JUMP,NE 50$	SWAP.W	D3	ADD.W	D3,D6		; D3 <-- <yy> barre suivante	SWAP.W	D3	DEC.B	D0	JUMP,NE 40$	POPM.L	D0..D6	RET;----------\\; CROHORFIN >;----------/; Dessine une barre horizontale  la fin entre deux croches.; in	A3.L	^premire croche dans OBDLIST;	A4.L	^dernire croche dans OBDLIST;	D4.W	hauteur de la barre (y);	D2.W	mode de dessin;	D1.W	- si contre en haut;		+ si contre en bas; out	-; mod	D7.WCROHORFIN:	PUSHM.L	D0..D6	LOAD.W	D3,D4	LOAD.W	D6,#+LYPORTEE	TEST.W	D1	JUMP',NS 10$	LOAD.W	D6,#-LYPORTEE10$:	CLR.W	D0	LOAD.B	D0,(A3)+OBDTYC	; D0 <-- 0..2 (A)	INC.B	D0		; D0 <-- 1..3	MUL.WA	D6,D0	ADD.W	D3,D6		; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D3,(A4)+OBDPOS+2 ; D3 <-- <xx> au centre de la croche	ADD.W	D3,#LXPORTEE/2	TEST.W	D1	JUMP',NS 20$	SUB.W	D3,#LXPORTEE20$:	DEC.W	D3		; D3 <-- <xx>	CLR.L	D4		; D4 <-- <dyy>	LOAD.W	D4,#-LXBARRE	; D4 <-- <dxx>	LOAD.B	D0,(A4)+OBDTYC	SUB.B	D0,(A3)+OBDTYC	; D0 <-- S-A	LOAD.W	D5,#+1	LOAD.W	D6,#+(LYPORTEE-LYBARRE)	TEST.W	D1	JUMP',NS 40$	LOAD.W	D5,#-1	LOAD.W	D6,#-(LYPORTEE-LYBARRE)40$:	LOAD.W	D1,#LYBARRE	; D1 <-- paisseur50$:	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	SWAP.W	D3	ADD.W	D3,D5		; D3 <-- <yy> plus bas/haut	SWAP.W	D3	DEC.W	D1	JUMP,NE 50$	SWAP.W	D3	ADD.W	D3,D6		; D3 <-- <yy> barre suivante	SWAP.W	D3	DEC.B	D0	JUMP,NE 40$	POPM.L	D0..D6	RET;---------\\; SRCTSYMB >;---------/; Cherche le descripteur d'un symbole.; in	D3.B	code du symbole; out	A1.L	^descripteur;	D7.W	ERNOT	=> pas trouv; mod	D7.W, A1.LSRCTSYMB:	PUSH.W	D3	LOAD.W	D7,#ERSNOT	; D7 <-- pas trouv	SUB.B	D3,#ICOFIRST	JUMP',LO 90$	COMP.B	D3,#(ESYMB-TSYMB)/LTS	JUMP',HS 90$	AND.W	D3,#H'FF	MUL.WU	D3,#LTS	LOAD.L	A1,#R16"TSYMB	ADD.W	A1,D3	CLR.W	D7		; D7 <-- trouv90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET	.END