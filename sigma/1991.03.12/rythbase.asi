	.SBTTL	RYTHBASE;----------\\; RYTHSTART >;==========/; Dmarre l'coute de la mesure du rythme.; in	-; out	D7.W	erreur; mod	D7.WRYTHSTART:	PUSHM.L	D2..D5,A3..A5	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OPLAY	JUMP,T	90$				; dmarre =>	SET.B	(A6)+OPLAY	LOAD.B	D3,#ICOSTOP	LOAD.W	D2,#4	CALL	AFFICONE	; dessine l'icne STOP	LOAD.L	D4,#PRIOPLAY	; D4 <-- super-prioritaire !	LOAD.L	D5,#600		; D5 <-- lg stack	LOAD.L	A5,#R16"PPLAY	; A5 <-- ^start	LOAD.L	A3,#R16"NPLAY	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre l'coute	JUMP,EQ 90$	PUSH.W	D7	CALL	RYTHSTOP	; stoppe en cas d'erreur	POP.W	D790$:	POPM.L	D2..D5,A3..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; RYTHSTOP >;=========/; Stoppe l'coute du rythme.; in	-; out	-; mod	D7.WRYTHSTOP:	PUSHM.L	D2,D3	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OPLAY	JUMP,F	90$				; stoppe =>	CLR.B	(A6)+OPLAY	LOAD.B	D3,#ICORYTHME	LOAD.W	D2,#4	CALL	AFFICONE	; dessine l'icne START90$:	POPM.L	D2,D3	RET;;;;;;;;;;;;;;;    PLAY    ;;;;;;;;;;;;;;;NPLAY:	.ASCIZ	"RYTHM_PLAY"	.EVENPPLAY:	LOAD.L	D4,#(4+5+5)*200	; D4 <-- 200 notes maximum par mesure !	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer pour commandes MIDI	JUMP,NE 90$	LOAD.L	D1,D4	CALL	SELPTRACK	; slectionne la bonne piste	JUMP,NE 80$20$:	TEST.B	(A6)+OPLAY	; coute en cours ?	JUMP,F	80$		; non => 80$				; oui =>	CALL	LOCK		; dbut de zone critique	CLR.W	D7	CLR.L	D4	LOAD.L	A5,(A6)+OPDT	COMP.L	A5,(A6)+OPDB	JUMP,EQ 40$	LOAD.L	D4,(A5)-4	SUB.L	A5,D4		; A5 <-- ^mesure courante	CLR.L	D4		; D4 <-- aucune commande MIDI	LOAD.L	D5,D1		; D5 <-- lg max	CALL	FUSION		; construit les commandes MIDI40$:	CALL	UNLOCK		; fin de zone critique	TEST.W	D7	JUMP,NE 80$	LOAD.L	D5,D4		; D5 <-- lg des commandes MIDI	JUMP,EQ 20$	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DWRITE		; fait entendre la mesure	JUMP,NE 80$	JUMP	20$80$:	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire des commandes MIDI90$:	CALL	STOPMIDI	; "all note off"	NTREL	?ABORT;--------------\\; _RYTH_FUSION  >;==============/; Transforme une mesure en commandes MIDI.; in	A3.L	^variables;	A4.L	^commandes MIDI;	D4.L	lg commandes MIDI;	D5.L	lg max buffer; out	D4.L	lg commandes MIDI;	D7.W	erreur; mod	D4.L, D7.W_RYTH_FUSION:	PUSHM.L	D2,D3,D6,A3..A6	LOAD.L	A6,A3		; A6 <-- ^variables	PUSH.L	A4; Pousse toutes les commandes MIDI existantes  la fin.	LOAD.L	A3,A4	ADD.L	A3,D5		; A3 <-- ^fin du buffer	ADD.L	A4,D4		; A4 <-- ^fin des commandes MIDI	LOAD.L	D3,D4	JUMP,EQ 15$10$:	LOAD.B	(-A3),(-A4)	; pousse les commandes MIDI  la fin	DEC.L	D3	JUMP,NE 10$; Transforme toutes les mesures du rythme.15$:	LOAD.L	A5,(A6)+OPDB	; A5 <-- ^premire mesure	CLR.W	D6		; D6 <-- temps initial20$:	LOAD.W	D2,(A5)+ORMR	; D2 <-- nb de rptitions	JUMP,NE 25$	INC.W	D225$:	CALL	PUTMESURE	; buffer MIDI <-- une mesure du rythme	JUMP,NE 80$	DEC.W	D2	JUMP,NE 25$	LOAD.L	D3,(A5)+ORML	ADD.L	A5,D3		; A5 <-- ^mesure suivante	COMP.L	A5,(A6)+OPDT	JUMP,NE 30$	LOAD.L	A5,(A6)+OPFT	; A5 <-- saute le trou30$:	COMP.L	A5,(A6)+OPFB	JUMP,NE 20$; Redescend le reste des commandes MIDI.80$:	TEST.L	D4	JUMP,EQ 85$82$:	LOAD.B	(A4+),(A3+)	DEC.L	D4	JUMP,NE 82$85$:	LOAD.L	D4,A4		; D4 <-- ^fin des commandes MIDI	POP.L	A4		; A4 <-- ^dbut des commandes MIDI	SUB.L	D4,A4		; D4 <-- lg des commandes MIDI	POPM.L	D2,D3,D6,A3..A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; FUSION  >;========/; Transforme une mesure en commandes MIDI.; in	A4.L	^commandes MIDI;	D4.L	lg commandes MIDI;	D5.L	lg max buffer;	A5.L	^mesure rythme; out	D4.L	lg commandes MIDI;	D7.W	erreur; mod	D4.L, D7.WFUSION:	PUSHM.L	D2,D3,D6,A2..A4	PUSH.L	A4; Pousse toutes les commandes MIDI existantes  la fin.	LOAD.L	A3,A4	ADD.L	A3,D5		; A3 <-- ^fin du buffer	ADD.L	A4,D4		; A4 <-- ^fin des commandes MIDI	LOAD.L	D3,D4	JUMP,EQ 15$10$:	LOAD.B	(-A3),(-A4)	; pousse les commandes MIDI  la fin	DEC.L	D3	JUMP,NE 10$15$:	CLR.W	D6		; D6 <-- temps initial	CALL	PUTMESURE; Redescend le reste des commandes MIDI.	TEST.L	D4	JUMP,EQ 85$82$:	LOAD.B	(A4+),(A3+)	DEC.L	D4	JUMP,NE 82$85$:	LOAD.L	D4,A4		; D4 <-- ^fin des commandes MIDI	POP.L	A4		; A4 <-- ^dbut des commandes MIDI	SUB.L	D4,A4		; D4 <-- lg des commandes MIDI	POPM.L	D2,D3,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; PUTMESURE >;----------/; Ajoute dans le buffer MIDI une nouvelle mesure du rythme.; Enlve les commandes prcdentes sur la meme piste.; in	D6.W	temps initial;	A3.L	^commandes MIDI pousses  la fin;	D4.L	lg des commandes MIDI;	A4.L	^o mettre les nouvelles commandes MIDI;	A5.L	^rythme; out	D6.W	nouveau temps;	A3.L	^plus loin;	D4.L	lg des commandes MIDI;	A4.L	^plus loin;	D7.W	erreur; mod	D4.L, D6.L, D7.W, A3.L, A4.LPUTMESURE:	PUSHM.L	D0..D3,D5,A1,A2	CALL	CLASSE		; trie la mesure	LOAD.W	D5,D6		; D5 <-- temps rythme initial	LOAD.W	D1,D6	LOAD.L	A2,#(A5)+ORMB	; A2 <-- ^premire note du rythme	LOAD.L	D2,(A5)+ORML	SUB.L	D2,#ORMB+4	SR.L	D2,#2		; D2 <-- nb notes dans le rythme	CLR.W	D0		; D0 <-- temps MIDI initial20$:	TEST.L	D4		; encore des commandes MIDI ?	JUMP,EQ 35$		; non => 35$				; oui =>	CLR.L	D3	LOAD.B	D3,(A3)+0	SL.W	D3,#8	LOAD.B	D3,(A3)+1	; D3 <-- lg	TEST.W	D3	JUMP,EQ 30$				; objet =>	ADD.W	D3,#2	SUB.L	D4,D3	COMP.B	(A3)+2,#H'90+RYTRACK	JUMP,EQ 25$22$:				; descend un objet =>	LOAD.B	(A4+),(A3+)	DEC.L	D3	JUMP,NE 22$	JUMP	20$25$:				; ignore un objet =>	ADD.L	A3,D3	JUMP	20$30$:				; temps =>	LOAD.B	D0,(A3)+2	SL.W	D0,#8	LOAD.B	D0,(A3)+3	; D0 <-- temps MIDI35$:	CLR.W	D7		; D7 <-- ok	TEST.L	D2		; encore une note dans le rythme ?	JUMP,NS 80$		; non => 80$	JUMP,EQ 37$	CLR.W	D1	LOAD.B	D1,(A2)+ONPOSX	; D1 <-- temps relatif rythme	JUMP	38$37$:	LOAD.W	D1,(A5)+ORMN	; D1 <-- nb de mesures	MUL.WU	D1,#8		; D1 <-- temps relatif fin mesure38$:	MUL.WU	D1,(A6)+OUNITE	DIV.WU	D1,#64		; D1 <-- converti selon unit	ADD.W	D1,D5		; D1 <-- temps absolu rythme	COMP.W	D1,D0	JUMP,LS 50$	TEST.L	D4		; encore des commandes MIDI ?	JUMP,EQ 50$		; non => 50$	LOAD.L	D3,#4	SUB.L	D4,D3	COMP.W	D0,D6	JUMP,LS 45$	LOAD.W	D6,D0		; D6 <-- temps somme = temps MIDI42$:				; descend un temps =>	LOAD.B	(A4+),(A3+)	DEC.L	D3	JUMP,NE 42$	JUMP	20$45$:				; ignore un temps =>	ADD.L	A3,D3	JUMP	20$; Ajoute une commande de temps.50$:	COMP.W	D1,D6	JUMP,LS 52$	LOAD.W	D7,#ERNEMEM	LOAD.L	D3,A3	SUB.L	D3,A4	COMP.L	D3,#4		; reste assez de place ?	JUMP,LO 80$		; non => 80$	CLR.B	(A4+)	CLR.B	(A4+)	RR.W	D1,#8	LOAD.B	(A4+),D1	RR.W	D1,#8	LOAD.B	(A4+),D1	LOAD.W	D6,D1		; D6 <-- temps somme = temps rythme; Ajoute une note presse puis relche.52$:	TEST.L	D2	JUMP,EQ 59$	LOAD.W	D7,#ERNEMEM	LOAD.L	D3,A3	SUB.L	D3,A4	COMP.L	D3,#(2+3)*2	; reste assez de place ?	JUMP,LO 80$		; non => 80$	LOAD.L	A1,#(A5)+ORMI	CLR.W	D3	LOAD.B	D3,(A2)+ONINST	SR.B	D3,#1		; D3 <-- ignote le bit note a/b	MUL.WU	D3,#LRI	ADD.L	A1,D3		; A1 <-- ^description de l'instrument	CLR.B	(A4+)	LOAD.B	(A4+),#3	LOAD.B	(A4+),#H'90+RYTRACK ; note on/off	LOAD.W	D3,(A1)+ORINOTA	; D3 <-- note a	TEST.B	(A2)+ONINST:#BNNOTEB-8	JUMP,BC 55$	LOAD.W	D3,(A1)+ORINOTB	; D3 <-- note b55$:	LOAD.B	(A4+),D3	PUSH.W	D3	LOAD.B	D3,#FORCE1	COMP.B	(A2)+ONFORC,#1	JUMP,EQ 56$	LOAD.B	D3,#FORCE2	COMP.B	(A2)+ONFORC,#2	JUMP,EQ 56$	LOAD.B	D3,#FORCE356$:	LOAD.B	(A4+),D3	; vlocit (note on)	POP.W	D3	CLR.B	(A4+)	LOAD.B	(A4+),#3	LOAD.B	(A4+),#H'90+RYTRACK ; note on/off	LOAD.B	(A4+),D3	CLR.B	(A4+)		; vlocit nulle (note off)	ADD.L	A2,#LNOTE	; A2 <-- ^note rythme suivante59$:	DEC.L	D2	JUMP	20$80$:	LOAD.W	D6,D1		; D6 <-- temps somme = temps rythme	POPM.L	D0..D3,D5,A1,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLASSE  >;--------/; Classe toutes les notes d'une mesure d'aprs leurs; positions horizontale (de gauche  droite).; in	A5.L	^mesure  classer; out	-; mod	D7.WCLASSE:	PUSHM.L	D1..D4,A4	LOAD.L	D4,(A5)+ORML	SUB.L	D4,#ORMB+4	SR.L	D4,#2		; D4 <-- nb notes	DEC.L	D4		; D4 <-- nb notes -1	JUMP,LE 90$20$:	LOAD.L	A4,#(A5)+ORMB	; A4 <-- premire note	LOAD.L	D2,D4		; D2 <-- nb notes -1	CLR.W	D1		; D1 <-- nb de permutations30$:	LOAD.B	D3,(A4)+ONPOSX	COMP.B	D3,(A4)+LNOTE+ONPOSX	JUMP,LS 50$	LOAD.L	D3,(A4)	LOAD.L	(A4),(A4)+LNOTE	; EX.L (A4),(A4)+LNOTE	LOAD.L	(A4)+LNOTE,D3	INC.W	D1		; D1 <-- une permutation de plus50$:	ADD.L	A4,#LNOTE	; A4 <-- ^note suivante	DEC.L	D2	JUMP,NE 30$	TEST.W	D1		; permutation(s) faite(s) ?	JUMP,NE 20$		; oui => 20$90$:	POPM.L	D1..D4,A4	RET;--------\\; IFNOTE  >;========/; Cherche une note existe d'aprs son instrument (a=b) et sa position.; in	D3.L	note cherche (-;f;i;p); out	D7.W	erreur; mod	D7.WIFNOTE:	PUSH.L	A3	CALL	LOCK		; dbut de zone critique	CALL	SRCNOTE		; note existe ?	CALL	UNLOCK		; fin de zone critique	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; NEWNOTE >;========/; Ajoute une nouvelle note. S'il en existe dj une  cet; endroit, effectue un remplacement.; in	D3.L	nouvelle note (-;f;i;p); out	D7.W	erreur; mod	D7.WNEWNOTE:	PUSH.L	A3	CALL	LOCK		; dbut de zone critique	CALL	SRCNOTE		; dj une note ici ?	JUMP,NE 50$		; non => 50$				; oui =>	LOAD.L	(A3),D3		; remplace par la nouvelle	CLR.B	(A6)+OMAJ	; rythme pas  jour	CLR.W	D7		; D7 <-- ok	JUMP	80$50$:	CALL	INSNOTE		; insre une nouvelle note	JUMP,NE 80$	CLR.B	(A6)+OMAJ	; rythme pas  jour80$:	CALL	UNLOCK		; fin de zone critique	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; KILNOTE >;========/; Supprime une note.; in	D3.L	note  supprimer (-;f;i;p); out	D3.L	note supprime (-;f;i;p);	D7.W	erreur (note n'existe pas); mod	D3.L, D7.WKILNOTE:	PUSHM.L	D4,A3,A4	CALL	LOCK		; dbut de zone critique	CALL	SRCNOTE		; A3 <-- ^note	JUMP,NE 80$	LOAD.L	D3,(A3)		; D3 <-- note qui sera supprime	LOAD.L	A4,(A6)+OPDT	SUB.L	A4,#LNOTE20$:	LOAD.L	(A3),(A3)+LNOTE	ADD.L	A3,#LNOTE	COMP.L	A3,A4	JUMP,NE 20$	LOAD.L	D4,A4	SUB.L	D4,A5	LOAD.L	(A5)+ORML,D4	LOAD.L	(A4)-4,D4	LOAD.L	(A6)+OPDT,A4	CLR.B	(A6)+OMAJ	; rythme pas  jour	CLR.W	D7		; D7 <-- ok, note supprime80$:	CALL	UNLOCK		; fin de zone critique	POPM.L	D4,A3,A4	RET;--------\\; SRCNOTE >;--------/; Cherche une note d'aprs son instrument (a=b) et sa position.; in	D3.L	note cherche (-;f;i;p); out	A3.L	note;	D7.W	erreur; mod	D7.W, A3.LSRCNOTE:	PUSHM.L	D2..D4	TCLR.L	D3:#BNNOTEB	CLR.W	D7		; D7 <-- trouv	LOAD.L	A3,#(A5)+ORMB	; A3 <-- ^premire note	LOAD.L	D4,(A5)+ORML	SUB.L	D4,#ORMB+4	JUMP,EQ 80$	SR.L	D4,#2		; D4 <-- nb de notes20$:	LOAD.L	D2,(A3)	TCLR.L	D2:#BNNOTEB	COMP.W	D3,D2		; note trouve ?	JUMP,EQ 90$		; oui => 90$	ADD.L	A3,#LNOTE	; A3 <-- note suivante	DEC.L	D4	JUMP,NE 20$80$:	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; INSNOTE >;--------/; Insre une note dans la mesure courante.; in	D3.L	note  insrer (-;f;i;p); out	D7.W	erreur; mod	D7.WINSNOTE:	PUSHM.L	D4,A4	LOAD.W	D7,#ERNEMEM	; D7 <-- pas assez de mmoire	LOAD.L	D4,(A6)+OPFT	SUB.L	D4,(A6)+OPDT	COMP.L	D4,#8		; reste assez de place ?	JUMP,LO 90$		; non => 90$				; oui =>	LOAD.L	A4,(A6)+OPDT	ADD.L	A4,#LNOTE	LOAD.L	(A4)-LNOTE-4,D3	; buffer <-- note	LOAD.L	D4,A4	SUB.L	D4,A5	LOAD.L	(A5)+ORML,D4	LOAD.L	(A4)-4,D4	LOAD.L	(A6)+OPDT,A4	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GOTIME  >;========/; Avance dans la mesure correspondant  un temps donn.; in	D3.W	temps;	A5.L	^mesure; out	A5.L	^mesure; mod	D7.W, A5.LGOTIME:	PUSHM.L	D2,D410$:	CALL	RECULE		; revient au dbut	JUMP,EQ 10$	CLR.W	D420$:	LOAD.W	D2,(A5)+ORMN	MUL.WU	D2,(A5)+ORMR	MUL.WU	D2,#8		; D2 <-- dure pour x fois la mesure	MUL.WU	D2,(A6)+OUNITE	DIV.WU	D2,#64		; D2 <-- converti selon unit	ADD.W	D4,D2		; D4 <-- temps jusqu'au dbut mesure suivante	COMP.W	D3,D4		; est-on dans cette mesure ?	JUMP,LO 90$		; oui => 90$				; non =>	CALL	AVANCE		; avance dans la mesure suivante	JUMP,EQ 20$90$:	POPM.L	D2,D4	RET;--------\\; GIVTIME >;========/; Donne le temps absolu du dbut de la mesure o l'on est.; in	A5.L	^mesure; out	A5.L	^mesure;	D3.W	temps dbut mesure; mod	D3.L, D7.W, A5.LGIVTIME:	PUSHM.L	D1,D2	LOAD.W	D1,#-110$:	INC.W	D1	CALL	RECULE		; revient au dbut	JUMP,EQ 10$	CLR.W	D320$:	TEST.W	D1	JUMP,EQ 90$	DEC.W	D1	LOAD.W	D2,(A5)+ORMN	MUL.WU	D2,(A5)+ORMR	MUL.WU	D2,#8		; D2 <-- dure pour x fois la mesure	MUL.WU	D2,(A6)+OUNITE	DIV.WU	D2,#64		; D2 <-- converti selon unit	ADD.W	D3,D2		; D3 <-- temps jusqu'au dbut mesure suivante	CALL	AVANCE		; avance dans la mesure suivante	JUMP,EQ 20$90$:	POPM.L	D1,D2	RET;--------\\; INSERT  >;========/; Insre une mesure vide avec une en-tte identique;  la mesure actuelle.; in	-; out	A5.L	^nouvelle mesure;	D7.W	erreur; mod	D7.W, A5.LINSERT:	PUSHM.L	D4,A4	CALL	LOCK		; dbut de zone critique	LOAD.W	D7,#ERNEMEM	; D7 <-- pas assez de mmoire	LOAD.L	D4,(A6)+OPFT	SUB.L	D4,(A6)+OPDT	COMP.L	D4,#ORMB+LNOTE*10+4 ; reste assez de place ?	JUMP,LO 90$		; non => 90$				; oui =>	LOAD.L	A4,(A6)+OPDT	LOAD.L	D4,#(ORMB+4)/220$:	LOAD.W	(A4+),(A5+)	DEC.L	D4	JUMP,NE 20$	LOAD.L	A5,(A6)+OPDT	; A5 <-- ^nouvelle mesure	LOAD.L	(A6)+OPDT,A4	LOAD.L	(A5)+ORML,#ORMB+4	LOAD.L	(A5)+ORMB,#ORMB+4	INC.W	(A6)+ONMES	INC.W	(A6)+OCMES	CLR.B	(A6)+OMAJ	; rythme pas  jour	CLR.W	D7		; D7 <-- ok90$:	CALL	UNLOCK		; fin de zone critique	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; COPIE   >;========/; Insre une mesure identique  la mesure actuelle.; in	-; out	A5.L	^nouvelle mesure;	D7.W	erreur; mod	D7.W, A5.LCOPIE:	PUSHM.L	D4,A4	CALL	LOCK		; dbut de zone critique	LOAD.W	D7,#ERNEMEM	; D7 <-- pas assez de mmoire	LOAD.L	D4,(A6)+OPFT	SUB.L	D4,(A6)+OPDT	SUB.L	D4,#4	COMP.L	D4,(A5)+ORML	; reste assez de place ?	JUMP,LO 90$		; non => 90$				; oui =>	LOAD.L	A4,(A6)+OPDT	LOAD.L	D4,(A5)+ORML	SR.L	D4,#120$:	LOAD.W	(A4+),(A5+)	DEC.L	D4	JUMP,NE 20$	LOAD.L	A5,(A6)+OPDT	; A5 <-- ^nouvelle mesure	LOAD.L	(A6)+OPDT,A4	INC.W	(A6)+ONMES	INC.W	(A6)+OCMES	CLR.B	(A6)+OMAJ	; rythme pas  jour	CLR.W	D7		; D7 <-- ok90$:	CALL	UNLOCK		; fin de zone critique	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DAVANCE >;========/; Dtruit la mesure courante et va dans la suivante.; in	-; out	D7.W	erreur; mod	D7.WDAVANCE:	PUSH.L	A4	LOAD.W	D7,#1	LOAD.L	A4,(A6)+OPFT	COMP.L	A4,(A6)+OPFB	; y'a-t-il un mesure aprs ?	JUMP,EQ 90$		; non => 90$	DEC.W	(A6)+ONMES	PUSH.W	(A6)+OCMES	LOAD.L	(A6)+OPDT,A5	CALL	AVANCE	POP.W	(A6)+OCMES	CLR.B	(A6)+OMAJ	; rythme pas  jour90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; AVANCE  >;========/; Avance dans la mesure suivante.; in	-; out	A5.L	^mesure suivante;	D7.W	erreur; mod	D7.W, A5.LAVANCE:	PUSHM.L	D4,A3,A4	CALL	LOCK		; dbut de zone critique	LOAD.W	D7,#1	LOAD.L	A4,(A6)+OPFT	COMP.L	A4,(A6)+OPFB	; est-on tout  la fin ?	JUMP,EQ 90$		; oui => 90$				; non =>	LOAD.L	A3,(A6)+OPDT	LOAD.L	A5,A3		; A5 <-- ^mesure	LOAD.L	D4,(A4)+ORML	SR.L	D4,#120$:	LOAD.W	(A3+),(A4+)	DEC.L	D4	JUMP,NE 20$	LOAD.L	(A6)+OPDT,A3	LOAD.L	(A6)+OPFT,A4	INC.W	(A6)+OCMES	CLR.W	D7		; D7 <-- ok90$:	CALL	UNLOCK		; fin de zone critique	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RECULE  >;========/; Recule dans la mesure prcdente.; in	-; out	A5.L	^mesure prcdente;	D7.W	erreur; mod	D7.W, A5.LRECULE:	PUSHM.L	D4,A3,A4	CALL	LOCK		; dbut de zone critique	LOAD.W	D7,#1	COMP.L	A5,(A6)+OPDB	; est-on tout au dbut ?	JUMP,EQ 90$		; oui => 90$				; non =>	LOAD.L	A4,(A6)+OPDT	LOAD.L	A3,(A6)+OPFT	LOAD.L	D4,(A4)-4	SR.L	D4,#120$:	LOAD.W	(-A3),(-A4)	DEC.L	D4	JUMP,NE 20$	LOAD.L	(A6)+OPFT,A3	LOAD.L	(A6)+OPDT,A4	LOAD.L	A5,A4	SUB.L	A5,(A4)-4	; A5 <-- ^mesure	DEC.W	(A6)+OCMES	CLR.W	D7		; D7 <-- ok90$:	CALL	UNLOCK		; fin de zone critique	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; LOCK    >;--------/; Dbut de zone critique.; in	-; out	-; mod	-LOCK:	PUSHM.L	D7,A5	LOAD.L	A5,(A6)+OPSEM	NTREL	?LOCK	POPM.L	D7,A5	RET;--------\\; UNLOCK  >;--------/; Fin de zone critique.; in	-; out	-; mod	-UNLOCK:	PUSHM.L	D7,A5	LOAD.L	A5,(A6)+OPSEM	NTREL	?UNLOCK	POPM.L	D7,A5	RET;------------\\; _RYTH_CLEAR >;============/; Efface compltement le rythme.; in	A4.L	^variables; out	-; mod	D7.W_RYTH_CLEAR:	PUSHM.L	A5,A6	LOAD.L	A6,A4		; A6 <-- ^variables	CALL	INIMESURE	POPM.L	A5,A6	CLR.W	D7		; retour EQ	RET;----------\\; INIMESURE >;==========/; Initialise une premire mesure vide.; in	-; out	A5.L	^mesure; mod	D7.W, A5.LINIMESURE:	PUSHM.L	D4,A4	LOAD.L	A4,(A6)+OPDB	LOAD.W	D4,#ORMB-120$:	CLR.B	(A4+)	DECJ.W,NMO D4,20$	LOAD.L	A5,(A6)+OPDB	; A5 <-- ^mesure courante <<PERMANANT>>	LOAD.L	(A5)+ORML,#ORMB+4	LOAD.W	(A5)+ORMN,#MAXPAS ; 16 pas par dfaut	LOAD.W	(A5)+ORMR,#1	; rpte 1x par dfaut	LOAD.W	(A5)+ORMT,#4	; 4 temps par dfaut	LOAD.L	(A5)+ORMB,#ORMB+4	LOAD.L	A4,#(A5)+ORMB+4	LOAD.L	(A6)+OPDT,A4	LOAD.L	(A6)+OPFT,(A6)+OPFB	CLR.W	(A6)+OCMES	LOAD.W	(A6)+ONMES,#1	POPM.L	D4,A4	RET	.END