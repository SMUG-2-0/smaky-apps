	.SBTTL	DXEDIT; Constantes; ----------DEBCY	=	3		; petite correction pour dbut en Y	.IF	DX7POSYL1	=	1		; dbut premire partie en Y [car]POSYL2	=	POSYL1+10	; dbut deuxime partie en Y [car]	.ENDIF	.IF	DX100POSYL1	=	1		; dbut premire partie en Y [car]POSYL2	=	POSYL1+8	; dbut deuxime partie en Y [car]POSYL3	=	POSYL2+8	; dbut troisime partie en Y [car]	.ENDIF	.IF	FB01POSYL1	=	6+2		; dbut premire partie en Y [car]	.ENDIFBRDGV	=	7		; virgule dans le nombreBRDGS	=	6		; signe moins dans le nombre	.IF	DX7BFFIX	=	31		; frquence fixe en Hz	.ENDIF	.IF	FB01;---------\\; GETMIDI  >;=========/; Donne le numro de canal MIDI  en fonction de l'instrument slectionn.; in	(A6)+OINSTR.W	instrument (1..8); out	D3.W		nb de notes (0..8);	D4.W		canal MIDI (1..16); mod	D3.L, D4.L, D7.WGETMIDI:	PUSH.L	A4	LOAD.L	A4,#(A6)+OBUF+11+H'20	LOAD.W	D4,(A6)+OINSTR	DEC.W	D4		; D4 <-- 0..7	MUL.WU	D4,#H'10	ADD.L	A4,D4	CLR.W	D3	LOAD.B	D3,(A4)+H'00	; D3 <-- nb de notes	CLR.W	D4	LOAD.B	D4,(A4)+H'01	INC.W	D4		; D4 <-- canal MIDI	POP.L	A4	RET;---------\\; GETSOUND >;=========/; Donne un numro de banque/son en fonction de l'instrument slectionn.; in	(A6)+OINSTR.W	instrument (1..8); out	D3.W		banque (3..7);	D4.W		son (1..48); mod	D3.L, D4.L, D7.WGETSOUND:	PUSH.L	A4	LOAD.L	A4,#(A6)+OBUF+11+H'20	LOAD.W	D4,(A6)+OINSTR	DEC.W	D4		; D4 <-- 0..7	MUL.WU	D4,#H'10	ADD.L	A4,D4	CLR.W	D3	LOAD.B	D3,(A4)+H'04	INC.W	D3		; D3 <-- banque	CLR.W	D4	LOAD.B	D4,(A4)+H'05	INC.W	D4		; D4 <-- son	POP.L	A4	RET;---------\\; PUTSOUND >;=========/; Donne un numro de banque/son en fonction de l'instrument slectionn.; in	(A6)+OINSTR.W	instrument (1..8);	D3.W		banque (3..7);	D4.W		son (1..48); out	-; mod	D7.WPUTSOUND:	PUSHM.L	D2..D4,A4	LOAD.L	A4,#(A6)+OBUF+11+H'20	LOAD.W	D2,(A6)+OINSTR	DEC.W	D2		; D2 <-- 0..7	MUL.WU	D2,#H'10	ADD.L	A4,D2	DEC.W	D3	LOAD.B	(A4)+H'04,D3	; mj. banque	DEC.W	D4	LOAD.B	(A4)+H'05,D4	; mj. son	POPM.L	D2..D4,A4	RET	.ENDIF;--------\\; DSEDIT  >;========/; in	A2.L	^timbre  diter; out	-; mod	D7.WDSEDIT:	PUSHM.L	D0..D6,A0..A5	CALL	DSCADRE		; dessine le cadre	LOAD.L	A3,#(A6)+OBUU	LOAD.L	A4,A2	LOAD.W	D4,#LTIMBRE-120$:	LOAD.B	(A3+),(A4+)	; OBUU <-- tout le timbre	DECJ.W,NMO D4,20$DSLOOP:	CLR.W	(A6)+ODSRDGDSLOOPD:	LIB	?GETCAR		; attend clavier/souris ...	COMP.W	D3,#KEYMGR	JUMP,EQ DSLOOP	COMP.W	D3,#KEYMMR	JUMP,EQ DSLOOP	COMP.W	D3,#KEYMDR	JUMP,EQ DSLOOP	COMP.W	D3,#BS	JUMP,EQ DSDELETE	COMP.W	D3,#DEL	JUMP,EQ DSDELETE	COMP.W	D3,#DELETE	JUMP,EQ DSDELETE	COMP.W	D3,#CLEAR	JUMP,EQ DSCLEAR	COMP.W	D3,#UNDO	JUMP,EQ DSUNDO	COMP.W	D3,#UNDO+SHIFT	JUMP,EQ DSSHIFTUNDO	PUSH.W	D3	CLR.W	D3	TEST.L	(A6)+ODSCASE	JUMP,EQ 45$	LOAD.L	A1,(A6)+ODSCASE	LOAD.B	D3,(A1)+ODSSTY	; D3 <-- sous-type45$:	CALL	DSPTMENU	; A3/A4 <-- ^s	POP.W	D3	LOAD.L	A3,A4	LOAD.L	A4,#0	DBOX_	ICODET		; dtecte o est la souris	JUMP,EQ DSSOFTKEY	COMP.W	D3,#KEYMGP	JUMP,EQ DSGAUCHE	.IF	DX7!DX100	COMP.W	D3,#KEYMDP	JUMP,EQ DSDROITE	.ENDIF	LIB	?MINMAJ	COMP.W	D3,#CR	JUMP,EQ DSDOWN	COMP.W	D3,#ENTER	JUMP,EQ DSDOWN	COMP.W	D3,#H'100*(2^BCURSOR)+'C	JUMP,EQ DSDOWN	COMP.W	D3,#EOP	JUMP,EQ DSUP	COMP.W	D3,#H'100*(2^BCURSOR)+'R	JUMP,EQ DSUP	COMP.W	D3,#TAB	JUMP,EQ DSRIGHT	COMP.W	D3,#H'100*(2^BCURSOR)+'F	JUMP,EQ DSRIGHT	COMP.W	D3,#STAB	JUMP,EQ DSLEFT	COMP.W	D3,#H'100*(2^BCURSOR)+'D	JUMP,EQ DSLEFT	COMP.W	D3,#'.	JUMP,EQ DSPOINT	COMP.W	D3,#',	JUMP,EQ DSPOINT	COMP.W	D3,#POINT	JUMP,EQ DSPOINT	COMP.W	D3,#'-	JUMP,EQ DSMOINS	COMP.W	D3,#'0	JUMP,LO DSBIP	COMP.W	D3,#'9	JUMP,LS DSDIGIT	COMP.W	D3,#'A	JUMP,LO DSBIP	COMP.W	D3,#'Z	JUMP,LS DSLETTREDSBIP:				; erreur =>	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	DSLOOPDSPOINT:	TEST.L	(A6)+ODSCASE	JUMP,EQ DSBIP	LOAD.L	A1,(A6)+ODSCASE	COMP.B	(A1)+ODSSTY,#TDSFREQH	JUMP,NE DSBIP	TSET.B	(A6)+ODSRDG:#BRDGV	JUMP,BS DSBIP	CALL	DSGETNUM	; D4 <-- frquence (mode-high-low)	.IF	DX7	TEST.L	D4:#BFFIX	JUMP,BS 40$	.ENDIF	CLR.B	(A6)+ODSRDG+1	JUMP	DSLOOPD	.IF	DX740$:	SWAP.W	D4	LOAD.B	D4,(A6)+ODSRDG+1	DEC.B	D4		; D4 <-- virgule (0..3)	JUMP,NS DSBIP	SWAP.W	D4	CALL	DSPUTNUM	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOPD	.ENDIFDSMOINS:	TEST.L	(A6)+ODSCASE	JUMP,EQ DSBIP	LOAD.L	A1,(A6)+ODSCASE	COMP.B	(A1)+ODSTYP,#TDSNUMS	JUMP,EQ 20$	COMP.B	(A1)+ODSTYP,#TDSNUM2	JUMP,NE DSBIP20$:	TSET.B	(A6)+ODSRDG:#BRDGS	JUMP,BS DSBIP	JUMP	DSLOOPDDSDIGIT:	TEST.L	(A6)+ODSCASE	JUMP,EQ DSBIP	LOAD.L	A1,(A6)+ODSCASE	COMP.B	(A1)+ODSSTY,#TDSFREQH	JUMP,EQ 40$	COMP.B	(A1)+ODSSTY,#TDSNOTE	JUMP,EQ 80$	CLR.L	D4	TEST.B	(A6)+ODSRDG+1	JUMP,EQ 20$	CALL	DSGETNUM	; D4 <-- paramtre	TEST.B	(A6)+ODSRDG:#BRDGS	JUMP,BC 20$	NEG.W	D4		; D4 <-- ngatif si signe -20$:	INC.B	(A6)+ODSRDG+1	SUB.W	D3,#'0	MUL.WU	D4,#10	ADD.W	D4,D3	TEST.B	(A6)+ODSRDG:#BRDGS	JUMP,BC 25$	NEG.W	D4		; D4 <-- ngatif si signe -25$:	CALL	DSPUTNUM	; mj le paramtre	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOPD40$:				; frquence =>	CALL	DSGETNUM	; D4 <-- frquence (mode-high-low)	CALL	DSCONV2FREQ	; D4 <-- frquence (mode-*100)	.IF	DX7	TEST.L	D4:#BFFIX	JUMP,BS 60$	.ENDIF	TEST.B	(A6)+ODSRDG:#BRDGV	JUMP,BS 50$	TEST.B	(A6)+ODSRDG+1	JUMP,NE 45$	CLR.L	D445$:	INC.B	(A6)+ODSRDG+1	SUB.W	D3,#'0	MUL.WU	D3,#100	MUL.WU	D4,#10	ADD.W	D4,D3	CALL	DSCONVFREQ2	; D4 <-- frquence (high-low)	CALL	DSPUTNUM	; mj la frquence (high-low)	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOPD50$:	COMP.B	(A6)+ODSRDG+1,#2	JUMP,HS DSBIP	SUB.W	D3,#'0	TEST.B	(A6)+ODSRDG+1	JUMP,NE 53$				; premire dcimale =>	DIV.WU	D4,#100	MUL.WU	D4,#100	MUL.WU	D3,#10	JUMP	55$53$:				; deuxime dcimale =>	DIV.WU	D4,#10	MUL.WU	D4,#1055$:	ADD.W	D4,D3	INC.B	(A6)+ODSRDG+1	CALL	DSCONVFREQ2	; D4 <-- frquence (high-low)	CALL	DSPUTNUM	; mj la frquence (high-low)	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOPD	.IF	DX760$:				; frquence en hertz =>	TEST.B	(A6)+ODSRDG+1	JUMP,NE 62$	LOAD.L	D4,#(H'10000*3)!(2^BFFIX)62$:	LOAD.B	D1,(A6)+ODSRDG+1	LOAD.W	D2,#1000	TEST.B	D1	JUMP,EQ 64$	LOAD.W	D2,#100	DEC.B	D1	JUMP,EQ 64$	LOAD.W	D2,#10	DEC.B	D1	JUMP,EQ 64$	LOAD.W	D2,#1	DEC.B	D1	JUMP,NE DSBIP64$:	INC.B	(A6)+ODSRDG+1	LOAD.L	D5,D4	SUB.W	D3,#'0	MUL.WU	D3,D2	MUL.WU	D2,#10	AND.L	D4,#H'FFFF	DIV.WU	D4,D2	MUL.WU	D4,D2	ADD.W	D4,D3	SWAP.W	D5	SWAP.W	D4	LOAD.W	D4,D5	SWAP.W	D4	CALL	DSCONVFREQ2	; D4 <-- frquence (high-low)	CALL	DSPUTNUM	; mj la frquence (high-low)	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOPD	.ENDIF80$:				; note =>	CALL	DSGETNUM	; D4 <-- paramtre	DIV.WU	D4,#12	SWAP.W	D4	SUB.W	D3,#'0	MUL.WU	D3,#12	ADD.W	D3,#12*2	; ignore les octaves -2 et -1 !	ADD.W	D4,D3	CALL	DSPUTNUM	; mj le paramtre	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOPDSLETTRE:	TEST.L	(A6)+ODSCASE	JUMP,EQ DSBIP	LOAD.L	A1,(A6)+ODSCASE	COMP.B	(A1)+ODSSTY,#TDSNOTE	JUMP,NE DSBIP	LOAD.W	D4,#0	COMP.W	D3,#'C		; do ?	JUMP,EQ 40$	LOAD.W	D4,#2	COMP.W	D3,#'D		; r ?	JUMP,EQ 40$	LOAD.W	D4,#4	COMP.W	D3,#'E		; mi ?	JUMP,EQ 40$	LOAD.W	D4,#5	COMP.W	D3,#'F		; fa ?	JUMP,EQ 40$	LOAD.W	D4,#7	COMP.W	D3,#'G		; sol ?	JUMP,EQ 40$	LOAD.W	D4,#9	COMP.W	D3,#'A		; la ?	JUMP,EQ 40$	LOAD.W	D4,#11	COMP.W	D3,#'B		; si ?	JUMP,NE DSBIP40$:	LOAD.W	D3,D4	CALL	DSGETNUM	; D4 <-- paramtre	DIV.WU	D4,#12	MUL.WU	D4,#12	ADD.W	D4,D3	CALL	DSPUTNUM	; mj le paramtre	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOPDSDELETE:			; annule le dernier digit =>	TEST.L	(A6)+ODSCASE	JUMP,EQ DSBIP	LOAD.L	A1,(A6)+ODSCASE	LOAD.B	D1,(A1)+ODSSTY	COMP.B	D1,#TDSNOTE	JUMP,EQ DSBIP	COMP.B	D1,#TDSFREQH	JUMP,EQ DSCLEAR	CALL	DSGETNUM	; D4 <-- paramtre	DIV.WU	D4,#10	CALL	DSPUTNUM	; mj le paramtre	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOPDDSCLEAR:			; met le paramtre  zro =>	TEST.L	(A6)+ODSCASE	JUMP,EQ DSBIP	LOAD.L	A1,(A6)+ODSCASE	LOAD.B	D1,(A1)+ODSSTY	COMP.B	D1,#TDSNOTE	JUMP,EQ DSBIP	COMP.B	D1,#TDSFREQH	JUMP,EQ 40$	CLR.W	D4	CALL	DSPUTNUM	; mj le paramtre	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOP40$:	CALL	DSGETNUM	; D4 <-- frquence (mode-high-low)	.IF	DX7	TEST.L	D4:#BFFIX	JUMP,BS 50$	.ENDIF	LOAD.L	D4,#(H'10000*1)+0 ; D4 <-- 1.00	.IF	DX7	JUMP	55$50$:	LOAD.L	D4,#(H'10000*0)+0+(2^BFFIX) ; D4 <-- 1.000 Hz55$:	.ENDIF	CALL	DSPUTNUM	; mj la frquence (high-low)	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOPDSUNDO:				; (UNDO) =>	TEST.L	(A6)+ODSCASE	JUMP,EQ DSBIP	LOAD.L	A1,(A6)+ODSCASE	PUSH.L	A2	LOAD.L	A2,#(A6)+OBUU	CALL	DSGETNUM	; D4 <-- valeur initiale	POP.L	A2	CALL	DSPUTNUM	; remet la valeur initiale	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOPDSSHIFTUNDO:			; (SHIFT-UNDO) =>	TEST.L	(A6)+ODSCASE	JUMP,EQ 10$	LOAD.L	A1,(A6)+ODSCASE	CALL	DSINVCASE	; efface la case	CLR.L	(A6)+ODSCASE	; plus de case slectionne10$:	CALL	WAITMOUSE	; met le sablier	LOAD.L	A1,#R16"TDSDX7120$:	CALL	DSGETNUM	LOAD.W	D5,D4		; D5 <-- valeur actuelle	PUSH.L	A2	LOAD.L	A2,#(A6)+OBUU	CALL	DSGETNUM	; D4 <-- valeur initiale	POP.L	A2	COMP.W	D4,D5		; valeur modifie ?	JUMP,EQ 40$		; non => 40$	CALL	DSPUTNUM	; remet la valeur initiale	CALL	DSAFONE		; mj l'affichage40$:	CALL	DSONEXT		; A1 <-- ^objet suivant	JUMP,EQ 20$	CALL	NORMMOUSE	; remet la flche	JUMP	DSLOOPDSDOWN:				; descend =>	CALL	DSONEXT	JUMP,NE DSBIP	CALL	DSMOVECASE	; dplace la case	JUMP	DSLOOPDSUP:				; monte =>	CALL	DSOPREV	JUMP,NE DSBIP	CALL	DSMOVECASE	; dplace la case	JUMP	DSLOOPDSRIGHT:			;  droite =>	TEST.L	(A6)+ODSCASE	JUMP,EQ DSBIP	LOAD.L	A1,(A6)+ODSCASE	LOAD.W	D1,(A1)+ODSPOS+0	LOAD.W	D2,(A1)+ODSPOS+220$:	CALL	DSONEXT	JUMP,NE DSBIP	COMP.W	D2,(A1)+ODSPOS+2	JUMP,EQ 20$	CALL	DSHORIZON	CALL	DSMOVECASE	; dplace la case	JUMP	DSLOOPDSLEFT:				;  gauche =>	TEST.L	(A6)+ODSCASE	JUMP,EQ DSBIP	LOAD.L	A1,(A6)+ODSCASE	LOAD.W	D1,(A1)+ODSPOS+0	LOAD.W	D2,(A1)+ODSPOS+220$:	CALL	DSOPREV	JUMP,NE DSBIP	COMP.W	D2,(A1)+ODSPOS+2	JUMP,EQ 20$	CALL	DSHORIZON	CALL	DSMOVECASE	; dplace la case	JUMP	DSLOOPDSSOFTKEY:	TEST.W	D2	JUMP,EQ DSFINI	TEST.L	(A6)+ODSCASE	; une case slectionne ?	JUMP,EQ DSBIP		; non => DSBIP	LOAD.L	A1,(A6)+ODSCASE	LOAD.B	D1,(A1)+ODSSTY	; D1 <-- sous-type	COMP.B	D1,#TDSWAVE	JUMP,EQ 40$	COMP.B	D1,#TDSLCURVE	JUMP,EQ 45$	COMP.B	D1,#TDSRCURVE	JUMP,EQ 45$	COMP.B	D1,#TDSNOTE	JUMP,EQ 50$	COMP.B	D1,#TDSONOFF	JUMP,EQ 60$	COMP.B	D1,#TDSSTEREO	JUMP,EQ 65$	.IF	DX100	COMP.B	D1,#TDS01	JUMP,EQ 60$	COMP.B	D1,#TDSPOLYMONO	JUMP,EQ 60$	COMP.B	D1,#TDSFULLFING	JUMP,EQ 60$	.ENDIF	COMP.B	D1,#TDSFREQH	JUMP,EQ 70$20$:				; + - MIN MOYEN MAX =>	COMP.W	D2,#3	JUMP,EQ 22$	COMP.W	D2,#4	JUMP,EQ 24$	COMP.W	D2,#2	JUMP,EQ 30$	COMP.W	D2,#5	JUMP,EQ 32$	COMP.W	D2,#7	JUMP,EQ 26$	COMP.W	D2,#8	JUMP,EQ 27$	COMP.W	D2,#9	JUMP,EQ 28$	JUMP	DSBIP22$:				; (-1) =>	CALL	DSGETBNUM	; D4 <-- paramtre	DEC.W	D423$:	CALL	DSPUTBNUM	; mj le paramtre	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOP24$:				; (+1) =>	CALL	DSGETBNUM	; D4 <-- paramtre	INC.W	D4	JUMP	23$26$:				; (MIN) =>	LOAD.W	D4,(A1)+ODSLII	ADD.W	D4,(A1)+ODSADD	JUMP	23$27$:				; (MOYEN) =>	LOAD.W	D4,(A1)+ODSLIS;;?	INC.W	D4	SUB.W	D4,(A1)+ODSLII	ASR.W	D4,#1	ADD.W	D4,(A1)+ODSLII	ADD.W	D4,(A1)+ODSADD	JUMP	23$28$:				; (MAX) =>	LOAD.W	D4,(A1)+ODSLIS	ADD.W	D4,(A1)+ODSADD	JUMP	23$30$:				; (-10) =>	CALL	DSGETBNUM	; D4 <-- paramtre	LOAD.W	D3,(A1)+ODSLII	ADD.W	D3,(A1)+ODSADD	COMP.W	D4,D3	JUMP,EQ DSBIP	SUB.W	D4,#10	COMP.W	D4,D3	JUMP,GE 23$	LOAD.W	D4,D3	JUMP	23$32$:				; (+10) =>	CALL	DSGETBNUM	; D4 <-- paramtre	LOAD.W	D3,(A1)+ODSLIS	ADD.W	D3,(A1)+ODSADD	COMP.W	D4,D3	JUMP,EQ DSBIP	ADD.W	D4,#10	COMP.W	D4,D3	JUMP,LE 23$	LOAD.W	D4,D3	JUMP	23$40$:				; WAVE =>	LOAD.W	D4,D2	DEC.W	D4		; D4 <-- 0..n	.IF	DX100	AND.L	D4,#H'FFFF	DIV.WU	D4,#3	.ENDIF42$:	CALL	DSPUTBNUM	; mj le paramtre	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOP45$:				; CURVE =>	LOAD.W	D4,D2	SUB.W	D4,#2		; D4 <-- 0..n	JUMP	42$50$:				; NOTE =>	COMP.W	D2,#1	JUMP,EQ 22$	COMP.W	D2,#3	JUMP,EQ 24$	COMP.W	D2,#13	JUMP,EQ 56$	COMP.W	D2,#15	JUMP,EQ 58$	SUB.W	D2,#4	JUMP,LO DSBIP	COMP.W	D2,#7	JUMP,HS DSBIP	LOAD.L	A3,#R16"TDSDMT	CLR.W	D3	LOAD.B	D3,(A3)+(D2.W)	CALL	DSGETBNUM	; D4 <-- paramtre	DIV.WU	D4,#12	MUL.WU	D4,#12	ADD.W	D4,D3	JUMP	23$56$:	CALL	DSGETBNUM	; D4 <-- paramtre	SUB.W	D4,#12	JUMP	23$58$:	CALL	DSGETBNUM	; D4 <-- paramtre	ADD.W	D4,#12	JUMP	23$60$:				; ON/OFF =>	COMP.W	D2,#1	JUMP,EQ 62$	COMP.W	D2,#2	JUMP,EQ 62$	COMP.W	D2,#3	JUMP,EQ 62$	COMP.W	D2,#4	JUMP,EQ 64$	COMP.W	D2,#5	JUMP,EQ 64$	COMP.W	D2,#6	JUMP,EQ 64$	JUMP	DSBIP62$:				; off =>	CLR.W	D4	CALL	DSPUTBNUM	; mj le paramtre	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOP64$:				; on =>	LOAD.W	D4,#1	CALL	DSPUTBNUM	; mj le paramtre	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOP65$:				; stro =>	CLR.W	D4	COMP.W	D2,#1	JUMP,EQ 66$	INC.W	D4	COMP.W	D2,#2	JUMP,EQ 66$	INC.W	D466$:	CALL	DSPUTBNUM	; mj le paramtre	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOP70$:				; FREQUENCE =>	.IF	DX7	COMP.W	D2,#3	JUMP,EQ 72$	COMP.W	D2,#4	JUMP,EQ 74$	COMP.W	D2,#2	JUMP,EQ 22$	COMP.W	D2,#5	JUMP,EQ 24$	COMP.W	D2,#7	JUMP,EQ 76$	COMP.W	D2,#9	JUMP,EQ 77$	.ENDIF	.IF	DX100	COMP.W	D2,#1	JUMP,EQ 22$	COMP.W	D2,#2	JUMP,EQ 22$	COMP.W	D2,#3	JUMP,EQ 22$	COMP.W	D2,#4	JUMP,EQ 24$	COMP.W	D2,#5	JUMP,EQ 24$	COMP.W	D2,#6	JUMP,EQ 24$	.ENDIF	JUMP	DSBIP72$:	PUSH.L	A1	CALL	DSNEXT		; A1 <-- ^descripteur frquence low	CALL	DSGETBNUM	; D4 <-- paramtre	DEC.W	D4	CALL	DSPUTBNUM	; mj le paramtre	POPM.L	A1	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOP74$:	PUSH.L	A1	CALL	DSNEXT		; A1 <-- ^descripteur frquence low	CALL	DSGETBNUM	; D4 <-- paramtre	INC.W	D4	CALL	DSPUTBNUM	; mj le paramtre	POPM.L	A1	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOP	.IF	DX776$:	CALL	DSGETNUM	; D4 <-- frquence (mode-high-low)	TCLR.L	D4:#BFFIX	JUMP,BC DSLOOP	LOAD.L	D4,#(H'10000*1)+0 ; D4 <-- 1.00	CALL	DSPUTNUM	; mj la frquence	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOP77$:	CALL	DSGETNUM	; D4 <-- frquence (mode-high-low)	TSET.L	D4:#BFFIX	JUMP,BS DSLOOP	LOAD.L	D4,#(H'10000*0)+0+(2^BFFIX) ; D4 <-- 1.000 Hz	CALL	DSPUTNUM	; mj la frquence	JUMP,NE DSBIP	CALL	DSAFIONE	; mj l'affichage	JUMP	DSLOOP	.ENDIFDSGAUCHE:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE DSBIP	LOAD.L	A1,#R16"TDSDX71	CALL	DSDETECTE	; A1 <-- ^descripteur o est la souris	JUMP,EQ 25$	.IF	DX7!DX100	SWAP.W	D4	COMP.W	D4,(A0)+ODFCY	; dans la premire ligne de l'cran ?	JUMP,HS DSBIP	SWAP.W	D4	SUB.W	D4,(A6)+ODSPOT+2 ; trop  gauche ?	JUMP,LO DSBIP	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#10	COMP.W	D4,D3		; trop  droite ?	JUMP,HS DSBIP	CALL	DSEDTITRE	; dite le titre du timbre ...	JUMP	DSLOOP	.ENDIF	.IF	FB01	JUMP	DSBIP	.ENDIF20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP,NE 40$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	LOAD.L	A1,#R16"TDSDX71	CALL	DSDETECTE	; A1 <-- ^descripteur o est la souris	JUMP,NE 20$25$:	COMP.L	A1,(A6)+ODSCASE	; case dj slectionne ?	JUMP,EQ 20$		; oui => 20$				; non =>	PUSH.L	A1	LOAD.L	A1,(A6)+ODSCASE	CALL	DSINVCASE	; efface l'ancienne	POP.L	A1	CALL	DSINVCASE	; allume la nouvelle	LOAD.L	(A6)+ODSCASE,A1	CALL	DSAFHELP	; affiche le texte d'aide	JUMP	20$40$:	CALL	DSAFMENU	; affiche les soft-keys	JUMP	DSLOOP	.IF	DX7!DX100DSDROITE:	TEST.L	(A6)+ODSCASE	JUMP,EQ 10$	LOAD.L	A1,(A6)+ODSCASE	CALL	DSINVCASE	; efface la case10$:	CLR.L	(A6)+ODSCASE	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE DSBIP	LOAD.L	A1,#R16"TDSDX71	CALL	DSDETECTE	; A1 <-- ^descripteur o est la souris	JUMP,NE DSBIP	TEST.B	(A1)+ODSGRA	; reprsentation graphique possible ?	JUMP,EQ DSBIP		; non => DSBIP	CLR.B	D1	JUMP	25$20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP,NE 40$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	LOAD.L	A1,#R16"TDSDX71	CALL	DSDETECTE	; A1 <-- ^descripteur o est la souris	JUMP,NE 20$25$:	COMP.B	D1,(A1)+ODSGRA	; groupe de cases dj slectionn ?	JUMP,EQ 20$		; oui => 20$				; non =>	PUSH.L	A1	LOAD.L	A1,(A6)+ODSCASE	CALL	DSINVGCASE	; efface l'ancien groupe	POP.L	A1	CALL	DSINVGCASE	; allume le nouveau groupe	LOAD.L	(A6)+ODSCASE,A1	LOAD.B	D1,(A1)+ODSGRA	; D1 <-- reprsentation graphique	JUMP	20$40$:	TEST.L	(A6)+ODSCASE	JUMP,EQ DSBIP	LOAD.L	A1,(A6)+ODSCASE	CALL	DSINVGCASE	; efface l'ancien groupe	CLR.L	(A6)+ODSCASE	LOAD.B	D1,(A1)+ODSGRA	; D1 <-- type de reprsentation graphique	COMP.B	D1,#GDSEG	JUMP,EQ 50$	COMP.B	D1,#GDSEGP	JUMP,EQ 50$	COMP.B	D1,#GDSALGO	JUMP,EQ 60$	JUMP	DSBIP50$:				; dite les enveloppes =>	LOAD.L	A3,#(A6)+OBUE	LOAD.L	A4,A2	LOAD.W	D4,#LTIMBRE-152$:	LOAD.B	(A3+),(A4+)	; OBUE <-- tout le timbre	DECJ.W,NMO D4,52$	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve le contenu de tout l'cran	JUMP,NE 55$		; pas assez de mmoire => 55$	CALL	EGEDIT		; edite les enveloppes ...	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue le contenu de tout l'cran	CALL	DSREFAIT	; redessine les paramtres modifis	CALL	DSPTMENU	; A3/A4 <-- ^s	LIB	?AFMENU		; redessine juste les soft-keys	JUMP	DSLOOP55$:	CALL	EGEDIT		; edite les enveloppes ...	CALL	DSCADRE		; redessine tout !	JUMP	DSLOOP60$:				; dite l'algorithme =>	TEST.W	(A6)+OALERR	; image des algorithmes prsente ?	JUMP,NE DSBIP		; non => DSBIP	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve le contenu de tout l'cran	JUMP,NE 65$		; pas assez de mmoire => 65$	CALL	ALEDIT		; edite l'algorithme ...	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue le contenu de tout l'cran	CALL	DSREFAIT	; redessine les paramtres modifis	CALL	DSPTMENU	; A3/A4 <-- ^s	LIB	?AFMENU		; redessine juste les soft-keys	JUMP	DSLOOP65$:	CALL	ALEDIT		; edite l'algorithme ...	CALL	DSCADRE		; redessine tout !	JUMP	DSLOOP	.ENDIFDSFINI:	POPM.L	D0..D6,A0..A5	RET	.IF	DX7!DX100;----------\\; DSEDTITRE >;==========/; Edite le titre du morceau.; in	A2.L	^timbre; out	-; mod	D7.WDSEDTITRE:	PUSHM.L	D3,D4,A1..A5	TEST.L	(A6)+ODSCASE	JUMP,EQ 05$	LOAD.L	A1,(A6)+ODSCASE	CALL	DSINVCASE	; efface la case; Affiche d'autres soft-keys pendant l'dition.05$:	LOAD.L	A3,#R16"TMENUTITRE	LIB	?AFMENU	LOAD.L	A3,#R16"TICOTITRE	LOAD.L	A4,#0	DBOX_	ICOAFF		; dessine les icnes	LOAD.L	D3,(A6)+ODSPOT	; D3 <-- position du titre en haut	SUB.W	D3,(A0)+ODFCX	LIB	?SETCURS	LIB	?AFTIM	.B	MSPACE,1+10+2,0	; efface l'emplacement du titre (noir)	.EVEN	LOAD.L	D3,(A6)+ODSPOT	; D3 <-- position du titre en haut	LIB	?SETCURS; Transfert le nom du titre dans un buffer d'dition.	LOAD.L	A5,#(A2)+PDXNAME; A5 <-- ^titre	LOAD.L	A3,#(A6)+ODSNAME	LOAD.L	A4,A3	LOAD.W	D4,#1010$:	LOAD.B	(A3+),(A5+)	; ODSNAME <-- titre du timbre	COMP.B	(A3)-1,#SPACE	JUMP,EQ 12$	LOAD.L	A4,A3		; A4 <-- ^dernier caractre12$:	DEC.W	D4	JUMP,NE 10$	CLR.B	(A4)		; ODSNAME <-- terminateur sur dernier espace	LOAD.L	A5,A2		; A5 <-- ^timbre	LOAD.L	A3,#(A6)+ODSNAME	LOAD.L	A2,#R16"00$	; A2 <-- ^terminateurs20$:	LOAD.W	D3,#10+2	; D3 <-- lg max	LIB	?EDIT		; dite le nom ...	COMP.W	D3,#KEYMGR	JUMP,EQ 20$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ 20$		; oui => 20$	COMP.W	D3,#KEYMDR	JUMP,EQ 20$	COMP.W	D3,#UNDO	JUMP,EQ 50$	COMP.W	D3,#CR	JUMP,EQ 80$	COMP.W	D3,#END	JUMP,EQ 80$	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#F0+SHIFT	JUMP,EQ 80$40$:				; touche incorrecte =>	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	20$; Transfert le buffer d'dition dans le titre du timbre.80$:	LOAD.L	A2,A5		; A2 <-- ^timbre	LOAD.L	A4,#(A2)+PDXNAME; A4 <-- ^titre	LOAD.W	D4,#1082$:	LOAD.B	D3,(A3+)	JUMP,EQ 84$	COMP.B	D3,#CR	JUMP,EQ 84$	COMP.B	D3,#'		; lettre accentue ?	JUMP,LO 83$		; non => 83$	COMP.B	D3,#'	JUMP,HI 83$	LIB	?MINMAJ		; D3 <-- majuscule	ADD.B	D3,#'a-'A	; D3 <-- minuscule83$:	LOAD.B	(A4+),D3	; timbre <-- nouveau titre	DEC.W	D4	JUMP,NE 82$84$:	DEC.W	D4	JUMP,NS 86$	LOAD.B	(A4+),#SPACE	; timbre <-- bourre la fin avec des espaces	JUMP	84$; Envoie des commandes au DX7 pour lui donner le nouveau titre.86$:	LOAD.L	A4,#(A2)+PDXNAME; A4 <-- ^titre	.IF	DX7	LOAD.W	D3,#145	.ENDIF	.IF	DX100	LOAD.W	D3,#77	.ENDIF	.IF	FB01	LOAD.W	D3,#H'00	.ENDIF88$:	LOAD.B	D4,(A4+)	CALL	MODPARAM	; indique une lettre modifie au DX7	INC.W	D3	.IF	DX7	COMP.W	D3,#145+10	.ENDIF	.IF	DX100	COMP.W	D3,#77+10	.ENDIF	.IF	FB01	COMP.W	D3,#H'00+7	.ENDIF	JUMP,LO 88$; Refait l'cran tout joli comme avant.	CALL	DSINFO		; refait la ligne tout en haut	LOAD.B	(A6)+ODSMENU,#-1	CALL	DSAFMENU	; redessine les soft-keys	TEST.L	(A6)+ODSCASE	JUMP,EQ 95$	LOAD.L	A1,(A6)+ODSCASE	CALL	DSINVCASE	; rallume la case95$:	POPM.L	D3,D4,A1..A5	RET00$:	.B	2^7	.EVEN	.ENDIF;---------\\; DSREFAIT >;=========/; Redessine les paramtres graphiques modifis.; in	D1.B	type de reprsentation graphique; out	-; mod	D7.WDSREFAIT:	PUSHM.L	D4,D5,A1	CALL	WAITMOUSE	; met le sablier	LOAD.L	A1,#R16"TDSDX7120$:	COMP.B	D1,(A1)+ODSGRA	; bonne reprsentation graphique ?	JUMP,NE 40$		; non => 40$				; oui =>	CALL	DSGETNUM	LOAD.W	D5,D4		; D5 <-- valeur actuelle	PUSH.L	A2	LOAD.L	A2,#(A6)+OBUE	CALL	DSGETNUM	; D4 <-- valeur initiale	POP.L	A2	COMP.W	D4,D5		; valeur modifie ?	JUMP,EQ 40$		; non => 40$				; oui =>	CALL	DSAFONE		; mj l'affichage40$:	CALL	DSONEXT		; A1 <-- ^objet suivant	JUMP,EQ 20$	CALL	NORMMOUSE	; remet la flche	POPM.L	D4,D5,A1	RET;-----------\\; DSMOVECASE >;===========/; Dplace dans une nouvelle case.; in	A1.L	^descripteur nouvelle case; out	-; mod	D7.WDSMOVECASE:	PUSH.L	A1	LOAD.L	A1,(A6)+ODSCASE	CALL	DSINVCASE	; efface la case	POP.L	A1	CALL	DSINVCASE	; allume la nouvelle	LOAD.L	(A6)+ODSCASE,A1	CALL	DSAFHELP	; affiche le texte d'aide	CALL	DSAFMENU	; affiche les soft-keys	RET;--------\\; DSCADRE >;========/; Dessine le cadre pour l'dition d'un timbre.; in	A2.L	^timbre; out	-; mod	D7.WDSCADRE:	PUSHM.L	D3,D4,A1,A3,A4	CALL	WAITMOUSE	; met le sablier	CLR.L	(A6)+ODSCASE	; pas de case slectionne	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	EOP		; efface tout	.B	TRUNC		; tronque si trop long	.B	0	.EVEN	LOAD.L	A3,#R16"TICOEDIT	LOAD.L	A4,#0	DBOX_	ICOCADRE	; dessine le cadre autour	CALL	DSINFO		; affiche la ligne suprieure	LOAD.B	(A6)+ODSMENU,#-1	CALL	DSAFMENU	; affiche les soft-keys	LOAD.W	D4,(A0)+ODFCX	INC.W	D4	LOAD.W	(A6)+OPASX,D4	SR.W	D4,#1	LOAD.W	(A6)+OPASX12,D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	INC.W	D4	LOAD.W	(A6)+OPASY,D4	SUB.W	D4,(A0)+ODFC2Y	LOAD.W	(A6)+OPASLB,D4	.IF	DX7!DX100	LOAD.W	D3,#POSYL1	MUL.WU	D3,(A6)+OPASY	ADD.W	D3,#DEBCY	; D3 <-- <yy>	SWAP.W	D3	CLR.W	D3	CALL	DSAF654321	; affiche 6..1	LOAD.W	D3,#POSYL2	MUL.WU	D3,(A6)+OPASY	ADD.W	D3,#DEBCY	; D3 <-- <yy>	SWAP.W	D3	CLR.W	D3	CALL	DSAF654321	; affiche 6..1	.ENDIF	LOAD.L	A1,#R16"TDSDX71	CALL	DSAFALL	CALL	NORMMOUSE	; remet la flche	POPM.L	D3,D4,A1,A3,A4	RET;--------\\; DSINFO  >;--------/; Affiche la ligne d'information tout en haut.; in	A2.L	^timbre; out	-; mod	D7.WDSINFO:	PUSHM.L	D3,A3,A4	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	0	.EVEN	CLR.L	D3	LIB	?SETCURS	; positionne en tout en haut  gauche	LIB	?AFTIM	.B	AFINV		; en inverse vido	.B	SPACE		; toujours un espace	.IF	DX7!DX100	.ASCII	"Edite le timbre   "	.ENDIF	.IF	FB01	.ASCII	"Edite la configuration "	.ENDIF	.B	0	.EVEN	LIB	?GETCURS	LOAD.L	(A6)+ODSPOT,D3	; mm. la position du titre	.IF	DX7!DX100	LOAD.L	A3,#(A2)+PDXNAME; A3 <-- ^nom	LOAD.W	D3,#10		; D3 <-- longueur	LIB	?STRING		; affiche le nom du son	.ENDIF	LIB	?AFTIM	.IF	DX7!DX100	.ASCII	"            "	.ASCII	"|slectionne|           | graphique |"	.ENDIF	.IF	FB01	.ASCII	"                 "	.ASCII	"|slectionne|           |           |"	.ENDIF		 ;           ;           ;           ;	.B	AFDIR		; remet vido normale	.B	0	.EVEN	POPM.L	D3,A3,A4	RET	.IF	DX7!DX100;-----------\\; DSAF654321 >;-----------/; Affiche les numro d'oprateurs dans le cadre.; in	D3.L	position initiale; out	-; mod	D7.WDSAF654321:	PUSHM.L	D2..D4	SWAP.W	D3	ADD.W	D3,(A6)+OPASLB	; D3 <-- descend sur la ligne de base	SWAP.W	D3	LOAD.L	D2,D3	LOAD.B	D3,#AFINV	LIB	?AFCAR		; met vido inverse	.IF	DX7	LOAD.B	D4,#'6	.ENDIF	.IF	DX100	LOAD.B	D4,#'4	.ENDIF20$:	LOAD.L	D3,D2	LIB	?SETCURS	; positionne	LOAD.B	D3,D4	LIB	?AFCAR		; affiche 6..1	SWAP.W	D2	ADD.W	D2,(A6)+OPASY	; D2 <-- en dessous	SWAP.W	D2	DEC.B	D4		; D4 <-- numro suivant	COMP.B	D4,#'1	JUMP,HS 20$	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; remet vido normale	POPM.L	D2..D4	RET	.ENDIF;---------\\; DSAFMENU >;=========/; Affiche les soft-keys et les icnes.; in	-; out	-; mod	D7.WDSAFMENU:	PUSHM.L	D3,A1,A3,A4	CLR.W	D3	TEST.L	(A6)+ODSCASE	; case slectionne existe ?	JUMP,EQ 20$		; non => 20$	LOAD.L	A1,(A6)+ODSCASE	; A1 <-- ^case slectionne	LOAD.B	D3,(A1)+ODSSTY	; D3 <-- sous-type20$:	COMP.B	D3,(A6)+ODSMENU	; soft-key dj  jour ?	JUMP,EQ 70$		; oui => 70$	LOAD.B	(A6)+ODSMENU,D3	CALL	DSPTMENU	; A3/A4 <-- ^s	LIB	?AFMENU		; dessine les soft-keys	LOAD.L	A3,A4	LOAD.L	A4,#0	DBOX_	ICOAFF		; dessine les icnes	CLR.W	(A6)+ODSINVS	; toutes les icnes teintes70$:	CALL	DSINVMENU	; allume l'icne slectionne90$:	POPM.L	D3,A1,A3,A4	RET;---------\\; DSPTMENU >;=========/; Donne les pointeur pour les soft-keys et les icnes.; in	D3.B	sous-type; out	A3.L	^pour LIB,?AFMENU;	A4.L	^pour DBOX_ICO..; mod	A3.L, A4.LDSPTMENU:	LOAD.L	A3,#R16"TMENUONOFF	LOAD.L	A4,#R16"TICOONOFF	COMP.B	D3,#TDSONOFF	JUMP,EQ 50$	LOAD.L	A3,#R16"TMENUSTEREO	LOAD.L	A4,#R16"TICOSTEREO	COMP.B	D3,#TDSSTEREO	JUMP,EQ 50$	.IF	DX100	LOAD.L	A3,#R16"TMENUONOFF	LOAD.L	A4,#R16"TICOONOFF	COMP.B	D3,#TDS01	JUMP,EQ 50$	LOAD.L	A3,#R16"TMENUPOLYMONO	LOAD.L	A4,#R16"TICOPOLYMONO	COMP.B	D3,#TDSPOLYMONO	JUMP,EQ 50$	LOAD.L	A3,#R16"TMENUFULLFING	LOAD.L	A4,#R16"TICOFULLFING	COMP.B	D3,#TDSFULLFING	JUMP,EQ 50$	.ENDIF	.IF	FB01	LOAD.L	A3,#R16"TMENUPOLYMONO	LOAD.L	A4,#R16"TICOPOLYMONO	COMP.B	D3,#TDSPOLYMONO	JUMP,EQ 50$	.ENDIF	LOAD.L	A3,#R16"TMENUWAVE	LOAD.L	A4,#R16"TICOWAVE	COMP.B	D3,#TDSWAVE	JUMP,EQ 50$	LOAD.L	A3,#R16"TMENULCURVE	LOAD.L	A4,#R16"TICOLCURVE	COMP.B	D3,#TDSLCURVE	JUMP,EQ 50$	LOAD.L	A3,#R16"TMENURCURVE	LOAD.L	A4,#R16"TICORCURVE	COMP.B	D3,#TDSRCURVE	JUMP,EQ 50$	LOAD.L	A3,#R16"TMENUNOTE	LOAD.L	A4,#R16"TICONOTE	COMP.B	D3,#TDSNOTE	JUMP,EQ 50$	LOAD.L	A3,#R16"TMENUFREQ	LOAD.L	A4,#R16"TICOFREQ	COMP.B	D3,#TDSFREQH	JUMP,EQ 50$	LOAD.L	A3,#R16"TMENUEDIT	LOAD.L	A4,#R16"TICOEDIT50$:	RET;----------\\; DSINVMENU >;==========/; Si ncessaire, allume une icne dans les soft-keys.; in	-; out	-; mod	D7.WDSINVMENU:	PUSHM.L	D2..D4,A1,A3,A4	TEST.L	(A6)+ODSCASE	; case slectionne existe ?	JUMP,EQ 90$		; non => 90$	LOAD.L	A1,(A6)+ODSCASE	; A1 <-- ^case slectionne	LOAD.B	D3,(A1)+ODSSTY	; D3 <-- sous-type	CALL	DSPTMENU	; A3/A4 <-- ^s	LOAD.L	A3,A4	LOAD.L	A4,#0	COMP.B	D3,#TDSONOFF	JUMP,EQ 20$	COMP.B	D3,#TDSSTEREO	JUMP,EQ 25$	.IF	DX100	COMP.B	D3,#TDS01	JUMP,EQ 20$	COMP.B	D3,#TDSPOLYMONO	JUMP,EQ 20$	COMP.B	D3,#TDSFULLFING	JUMP,EQ 20$	.ENDIF	.IF	FB01	COMP.B	D3,#TDSPOLYMONO	JUMP,EQ 20$	.ENDIF	COMP.B	D3,#TDSWAVE	JUMP,EQ 30$	COMP.B	D3,#TDSLCURVE	JUMP,EQ 40$	COMP.B	D3,#TDSRCURVE	JUMP,EQ 40$	COMP.B	D3,#TDSNOTE	JUMP,EQ 50$	.IF	DX7	COMP.B	D3,#TDSFREQH	JUMP,EQ 60$	.ENDIF	CLR.W	D2		; D2 <-- teint tout	JUMP	70$20$:				; on/off =>	CALL	DSGETNUM	; D4 <-- paramtre	LOAD.W	D2,#1	TEST.W	D4	JUMP,EQ 70$	LOAD.W	D2,#4	JUMP	70$25$:				; stro =>	CALL	DSGETNUM	; D4 <-- paramtre	LOAD.W	D2,#1	TEST.W	D4	JUMP,EQ 70$	INC.W	D2	COMP.W	D4,#1	JUMP,EQ 70$	INC.W	D2	JUMP	70$30$:				; wave =>	CALL	DSGETNUM	; D4 <-- paramtre	.IF	DX100	MUL.WU	D4,#3	.ENDIF	INC.W	D4	LOAD.W	D2,D4	JUMP	70$40$:				; curve =>	CALL	DSGETNUM	; D4 <-- paramtre	ADD.W	D4,#2	LOAD.W	D2,D4	JUMP	70$50$:				; note =>	CALL	DSGETNUM	; D4 <-- paramtre	DIV.WU	D4,#12	SWAP.W	D4		; D4 <-- 0..11	LOAD.W	D2,#4+0	COMP.W	D4,#2	JUMP,LO 70$	LOAD.W	D2,#4+1	COMP.W	D4,#4	JUMP,LO 70$	LOAD.W	D2,#4+2	COMP.W	D4,#5	JUMP,LO 70$	LOAD.W	D2,#4+3	COMP.W	D4,#7	JUMP,LO 70$	LOAD.W	D2,#4+4	COMP.W	D4,#9	JUMP,LO 70$	LOAD.W	D2,#4+5	COMP.W	D4,#11	JUMP,LO 70$	LOAD.W	D2,#4+6	JUMP	70$	.IF	DX760$:				; frquence =>	CALL	DSGETNUM	; D4 <-- frquence (mode-high-low)	LOAD.W	D2,#7	TEST.L	D4:#BFFIX	JUMP,BC 70$	LOAD.W	D2,#9	JUMP	70$	.ENDIF70$:	COMP.W	D2,(A6)+ODSINVS	; icne dj allume ?	JUMP,EQ 90$		; oui => 90$				; non =>	PUSH.W	D2	LOAD.W	D2,(A6)+ODSINVS	JUMP,EQ 74$	DBOX_	ICOINV		; teint l'icne allume74$:	POP.W	D2	TEST.W	D2	JUMP,EQ 76$	DBOX_	ICOINV		; allume une icne76$:	LOAD.W	(A6)+ODSINVS,D290$:	POPM.L	D2..D4,A1,A3,A4	RET;----------\\; DSDETECTE >;==========/; Dtecte dans quelle case est la souris.; in	D4.L	position de la souris (y;x);	A1.L	^descripteur; out	A1.L	^descripteur de la case;	D7.W	erreur; mod	D7.W, A1.LDSDETECTE:	PUSHM.L	D1..D4	LOAD.W	D3,D4		; D3 <-- x	SWAP.W	D4		; D4 <-- y10$:	LOAD.W	D2,(A1)+ODSPOS+0	MUL.WU	D2,(A6)+OPASY	ADD.W	D2,#DEBCY	; D2 <-- <yy>	COMP.W	D4,D2		; souris trop aute ?	JUMP,LO 50$	CLR.W	D1	LOAD.B	D1,(A1)+ODSLGY	MUL.WU	D1,(A6)+OPASY	; D1 <-- <dyy>	ADD.W	D2,D1	COMP.W	D4,D2		; souris trop basse ?	JUMP,HS 50$	LOAD.W	D2,(A1)+ODSPOS+2	MUL.WU	D2,(A6)+OPASX	; D2 <-- <xx>	COMP.W	D3,D2		; souris trop  gauche ?	JUMP,LO 50$	CLR.W	D1	LOAD.B	D1,(A1)+ODSLGX	; D1 <-- nb de caractres	INC.W	D1	MUL.WU	D1,(A6)+OPASX	; D1 <-- <dxx>	ADD.W	D2,D1	COMP.W	D3,D2		; souris trop  droite ?	JUMP,HS 50$	TEST.B	(A1)+ODSTYP:#BDSINFO	JUMP,BS 50$	CLR.W	D7	JUMP	90$50$:	CALL	DSONEXT		; A1 <-- ^descripteur suivant	JUMP,EQ	10$90$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET	.IF	DX7!DX100;-----------\\; DSINVGCASE >;===========/; Inverse un ensemble de case pour une reprsentation graphique.; in	A1.L	^descripteur de la case/^nil; out	-; mod	D7.WDSINVGCASE:	PUSHM.L	D1..D6,A1	LOAD.L	D1,A1		; A1=^nil ?	JUMP,EQ 90$		; oui => 90$	LOAD.B	D1,(A1)+ODSGRA	; D1 <-- type de reprsentation graphique	JUMP,EQ 90$	LOAD.L	A1,#R16"TDSDX71	LOAD.L	D5,#-1		; D5 <-- min	CLR.L	D6		; D6 <-- max20$:	COMP.B	D1,(A1)+ODSGRA	; mme reprsentation ?	JUMP,NE 50$		; non => 50$				; oui =>	CALL	DSDIMCASE	; D3 <-- pos et D4 <-- dim de la case	COMP.W	D5,D3	JUMP,LS 30$	LOAD.W	D5,D330$:	ADD.W	D4,D3	COMP.W	D6,D4	JUMP,HS 32$	LOAD.W	D6,D432$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	COMP.W	D5,D3	JUMP,LS 34$	LOAD.W	D5,D334$:	ADD.W	D4,D3	COMP.W	D6,D4	JUMP,HS 36$	LOAD.W	D6,D436$:	SWAP.W	D6	SWAP.W	D550$:	CALL	DSONEXT		; A1 <-- ^descripteur suivant	JUMP,EQ 20$	COMP.L	D5,#-1	JUMP,EQ 90$	TEST.L	D6	JUMP,EQ 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit une trame blanche	LOAD.L	D3,D5	LOAD.L	D4,D6	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	; inverse un grand rectangle90$:	POPM.L	D1..D6,A1	RET	.ENDIF;----------\\; DSINVCASE >;==========/; Inverse une case.; in	A1.L	^descripteur de la case/^nil; out	-; mod	D7.WDSINVCASE:	PUSHM.L	D2..D4	LOAD.L	D2,A1		; A1=^nil ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit une trame blanche	CALL	DSDIMCASE	; D3 <-- pos et D4 <-- dim	LOAD.W	D2,#INVDOT	; D2 <-- mode	LIB	?DRMATRIX	; inverse la case90$:	POPM.L	D2..D4	RET;----------\\; DSDIMCASE >;==========/; Donne les dimensions d'une case.; in	A1.L	^descripteur de la case; out	D3.L	position (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.LDSDIMCASE:	PUSH.L	D2	LOAD.W	D3,(A1)+ODSPOS+0	MUL.WU	D3,(A6)+OPASY	ADD.W	D3,#DEBCY+1	; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D2,(A1)+ODSPOS+2	MUL.WU	D2,(A6)+OPASX	LOAD.W	D3,D2	INC.W	D3		; D3 <-- <xx>	CLR.W	D4	LOAD.B	D4,(A1)+ODSLGY	MUL.WU	D4,(A6)+OPASY	DEC.W	D4		; D4 <-- <dyy>	SWAP.W	D4	CLR.W	D2	LOAD.B	D2,(A1)+ODSLGX	; D2 <-- nb de caractres	INC.W	D2	MUL.WU	D2,(A6)+OPASX	LOAD.W	D4,D2	DEC.W	D4		; D4 <-- <dxx>	POP.L	D2	RET;---------\\; DSAFHELP >;=========/; Affiche le texte d'aide d'une case.; in	A1.L	^descripteur de la case/^nil; out	-; mod	D7.WDSAFHELP:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#R16"00$	LOAD.L	D3,A1		; ^nil ?	JUMP,EQ 30$		; oui => 30$	LOAD.L	A3,#(A1)+ODSTXT	; A3 <-- ^texte d'aide	COMP.B	(A1)+ODSTYP,#TDSLIST	JUMP,NE 30$	LOAD.W	D3,(A1)+ODSLIS20$:	COMP.B	(A3+),#TAB	JUMP,NE 20$	DECJ.W,NMO D3,20$30$:	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#2	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,#GCICT+12	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A4,A3	LIB	?AFTEXT		; affiche le texte	LOAD.L	D3,A3	SUB.L	D3,A4	DEC.W	D3		; D3 <-- longueur du texte	CLR.L	D4	LOAD.W	D4,(A0)+ODFDX	DIV.WU	D4,(A0)+ODFCX	SUB.W	D4,#2+2	SUB.W	D4,D3	LOAD.B	D3,#MSPACE	LIB	?AFCAR		; efface la fin de la ligne	LOAD.B	D3,D4	LIB	?AFCAR90$:	POPM.L	D3,D4,A3,A4	RET00$:	.ASCIZ	""	.EVEN	.INS	DXBASE.ASI	.IF	DX7!DX100	.INS	DXEG.ASI	.INS	DXALGO.ASI	.ENDIF; Tables; ------TDSDMT:	.B	0,2,4,5,7,9,11	.EVENTICOEDIT:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+2	.B	0,ICOM10,ICOM1	.B	ICOP1,ICOP10,0	.B	ICOMIN,ICOMOY,ICOMAX	.B	0,0,0	.B	0,0,0TMENUEDIT:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"       -10   -1  "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" +1    +10       "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" Min  Moyen  Max "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""TICOFREQ:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+2	.IF	DX7	.B	0,ICOM10,ICOM1	.B	ICOP1,ICOP10,0	.B	ICORAPPORT,ICOVIDE,ICOFIXE	.B	0,0,0	.B	0,0,0	.ENDIF	.IF	DX100	.B	ICOM10,ICOM10,ICOM10	.B	ICOP10,ICOP10,ICOP10	.B	0,0,0	.B	0,0,0	.B	0,0,0	.ENDIFTMENUFREQ:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.IF	DX7	.ASCIZ	""	.ASCIZ	"       -1   -0.n "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"+0.n   +1        "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Rapport     Fixe "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.ENDIF	.IF	DX100	.ASCIZ	""	.ASCIZ	"Diminue"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Augmente"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.ENDIFTICOONOFF:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+2	.B	ICOOFF,ICOOFF,ICOOFF	.B	ICOON,ICOON,ICOON	.B	0,0,0	.B	0,0,0	.B	0,0,0TMENUONOFF:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"OFF"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"ON"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""TICOSTEREO:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+2	.B	ICOLEFT,ICOMIDDLE,ICORIGHT	.B	0,0,0	.B	0,0,0	.B	0,0,0	.B	0,0,0TMENUSTEREO:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"     Milieu      "	.ASCIZ	"Gauche     Droite"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""TICOWAVE:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+2	.IF	DX7	.B	ICOWAVE+0,ICOWAVE+1,ICOWAVE+2	.B	ICOWAVE+3,ICOWAVE+4,ICOWAVE+5	.B	0,0,0	.B	0,0,0	.B	0,0,0	.ENDIF	.IF	DX100	.B	ICOWAVE+2,ICOWAVE+2,ICOWAVE+2	.B	ICOWAVE+3,ICOWAVE+3,ICOWAVE+3	.B	ICOWAVE+0,ICOWAVE+0,ICOWAVE+0	.B	ICOWAVE+5,ICOWAVE+5,ICOWAVE+5	.B	0,0,0	.ENDIFTMENUWAVE:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.IF	DX7	.ASCIZ	""	.ASCIZ	"Triangle Rampe   "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Carr Sinus Ala."		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.ENDIF	.IF	DX100	.ASCIZ	""	.ASCIZ	"Rampe"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Carr"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Triangle"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Alatoire"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.ENDIFTICOLCURVE:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+2	.B	0,ICOLCURVE+0,ICOLCURVE+1	.B	ICOLCURVE+2,ICOLCURVE+3,0	.B	0,0,0	.B	0,0,0	.B	0,0,0TICORCURVE:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+2	.B	0,ICORCURVE+0,ICORCURVE+1	.B	ICORCURVE+2,ICORCURVE+3,0	.B	0,0,0	.B	0,0,0	.B	0,0,0TMENULCURVE:TMENURCURVE:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"      -LIN  -EXP "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"+EXP  +LIN       "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""TICONOTE:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+2	.B	ICOM1,ICOVIDE,ICOP1	.B	ICONOTE+0,ICONOTE+1,ICONOTE+2	.B	ICONOTE+3,ICONOTE+4,ICONOTE+5	.B	ICONOTE+6,0,0	.B	ICOMOCTAVE,0,ICOPOCTAVETMENUNOTE:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Descend     Monte"		;     ;     ;     ;	.ASCIZ	"  C     D     E  "	.ASCIZ	" Do    R    Mi  "		;     ;     ;     ;	.ASCIZ	"  F     G     A  "	.ASCIZ	" Fa    Sol   La  "		;     ;     ;     ;	.ASCIZ	"  B              "	.ASCIZ	" Si              "		;     ;     ;     ;	.ASCIZ	"Octave"	.ASCIZ	" -1          +1  "	.IF	DX100!FB01TICOPOLYMONO:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+2	.B	ICOPOLY,ICOPOLY,ICOPOLY	.B	ICOMONO,ICOMONO,ICOMONO	.B	0,0,0	.B	0,0,0	.B	0,0,0TMENUPOLYMONO:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Polyphonique"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Monophonique"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""TICOFULLFING:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+2	.B	ICOFULL,ICOFULL,ICOFULL	.B	ICOFING,ICOFING,ICOFING	.B	0,0,0	.B	0,0,0	.B	0,0,0TMENUFULLFING:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Full time porta"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Fingered porta"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.ENDIFTICOTITRE:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+3	.B	0,0,0	.B	0,0,0	.B	0,0,0	.B	0,0,0	.B	0,0,0TMENUTITRE:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN	.END