	.SBTTL	SEQPARAM;--------\\; PARAM   >;========/; Modifie les paramtres de la piste d'enregistrement.PARAM:	CALL	GETRTRACK	; D5 <-- piste d'enregistrement	LOAD.W	D1,D5	MUL.WU	D5,#LT	LOAD.L	A1,#(A6)+OTRACK	ADD.W	A1,D5		; A1 <-- ^variables de la piste	LOAD.L	A3,#R16"TICOPARAM	LOAD.L	A4,#0	DBOX_	ICOCADRE	; dessine le cadre autour	DBOX_	ICOAFF		; dessine les "soft-keys"	LOAD.L	A3,#R16"TMENUPARAM	LIB	?AFMENU	CLR.W	D0		; D0 <-- premire fois05$:	CALL	PAFMIDI		; affiche le canal midi	CALL	PAFINFO		; affiche les informations	CALL	GETPARAM	LIB	?BUCAR	LOAD.L	A5,#(A6)+OASOCT	LOAD.L	A4,#R16"TPAOCT	CALL	PAFASC	LOAD.L	A5,#(A6)+OASDMT	LOAD.L	A4,#R16"TPADMT	CALL	PAFASC	LOAD.L	A5,#(A6)+OASAMP	LOAD.L	A4,#R16"TPAAMP	CALL	PAFASC	LOAD.L	A5,#(A6)+OASDYN	LOAD.L	A4,#R16"TPADYN	CALL	PAFASC	LIB	?NOBUCAR10$:	LIB	?GETCAR		; attend clavier/souris ...	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	10$		; oui => 10$	LOAD.L	A3,#R16"TICOPARAM	LOAD.L	A4,#0	DBOX_	ICODET		; dans une "soft-key" ?	JUMP,EQ 15$		; oui => 15$	COMP.W	D7,#ERDIOUT	; clic ailleurs ?	JUMP,EQ 30$		; oui => 30$	JUMP	20$15$:	TEST.W	D2	JUMP,EQ 80$	COMP.W	D2,#1	JUMP,EQ 40$	COMP.W	D2,#3	JUMP,EQ 44$	COMP.W	D2,#4	JUMP,EQ 47$	COMP.W	D2,#5	JUMP,EQ 48$	COMP.W	D2,#6	JUMP,EQ 49$	COMP.W	D2,#10	JUMP,EQ 50$	COMP.W	D2,#13	JUMP,EQ 55$20$:				; erreur =>	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	10$30$:				; clic =>	LIB	?IFMOUSE	; D4 <-- position de la souris	SUB.W	D4,(A0)+ODFFX	JUMP,LO 20$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP,LO 20$	SWAP.W	D4	LOAD.L	D2,D4	LOAD.L	A5,#(A6)+OASOCT	LOAD.L	D4,D2	SCROLL_	MOVE		; dplace la cabine de l'ascenseur	JUMP,EQ 10$	LOAD.L	A5,#(A6)+OASDMT	LOAD.L	D4,D2	SCROLL_	MOVE		; dplace la cabine de l'ascenseur	JUMP,EQ 10$	LOAD.L	A5,#(A6)+OASAMP	LOAD.L	D4,D2	SCROLL_	MOVE		; dplace la cabine de l'ascenseur	JUMP,EQ 10$	LOAD.L	A5,#(A6)+OASDYN	LOAD.L	D4,D2	SCROLL_	MOVE		; dplace la cabine de l'ascenseur	JUMP,EQ 10$	JUMP	20$40$:				; (-) =>	TEST.W	(A1)+OTMIDI	JUMP,NE 41$	LOAD.W	(A1)+OTMIDI,#1641$:	DEC.W	(A1)+OTMIDI	CALL	PAFMIDI		; affiche le canal midi	CALL	PAFINFO		; affiche les informations	JUMP	10$44$:				; (+) =>	COMP.W	(A1)+OTMIDI,#15	JUMP,NE 45$	LOAD.W	(A1)+OTMIDI,#-145$:	INC.W	(A1)+OTMIDI	CALL	PAFMIDI		; affiche le canal midi	CALL	PAFINFO		; affiche les informations	JUMP	10$47$:				; (SYNTHE) =>	LOAD.W	(A1)+OTMIDI,#1-1	CALL	PAFMIDI		; affiche le canal midi	CALL	PAFINFO		; affiche les informations	JUMP	10$48$:				; (RYTHME) =>	LOAD.W	(A1)+OTMIDI,#10-1	CALL	PAFMIDI		; affiche le canal midi	CALL	PAFINFO		; affiche les informations	JUMP	10$49$:				; (SMAKY) =>	LOAD.W	(A1)+OTMIDI,#16-1	CALL	PAFMIDI		; affiche le canal midi	CALL	PAFINFO		; affiche les informations	JUMP	10$50$:				; (PRECEDENT) =>	TEST.W	D1	JUMP,EQ 20$	CALL	PUTPARAM	DEC.W	D1	LOAD.L	A1,#(A1)-LT	; A1 <-- ^variables piste prcdente	INC.W	D0		; D0 <-- n ime fois	JUMP	05$55$:				; (SUIVANT) =>	COMP.W	D1,#NBTRACK-1	JUMP,EQ 20$	CALL	PUTPARAM	INC.W	D1	LOAD.L	A1,#(A1)+LT	; A1 <-- ^variables piste suivante	INC.W	D0		; D0 <-- n ime fois	JUMP	05$80$:				; (FIN) =>	CALL	PUTPARAM	RET;---------\\; GETPARAM >;=========/; Met  jour les ascenseurs en fonction de la piste.; in	A1.L	^variables de la piste; out	-; mod	-GETPARAM:	PUSH.L	D4; Met les cabines des ascenseurs  la bonne place.	LOAD.W	D4,(A1)+OTOCT	SUB.W	D4,#5	NEG.W	D4	LOAD.W	(A6)+OASOCT+OSCPOSV,D4	LOAD.W	D4,(A1)+OTDMT	SUB.W	D4,#12	NEG.W	D4	LOAD.W	(A6)+OASDMT+OSCPOSV,D4	LOAD.W	D4,(A1)+OTAMP	SUB.W	D4,#128	NEG.W	D4	LOAD.W	(A6)+OASAMP+OSCPOSV,D4	LOAD.W	D4,(A1)+OTDYN	SUB.W	D4,#128	NEG.W	D4	LOAD.W	(A6)+OASDYN+OSCPOSV,D4	POP.L	D4	RET;---------\\; PUTPARAM >;=========/; Met  jour une piste en fonction des ascenseurs.; in	A1.L	^variables de la piste; out	-; mod	-PUTPARAM:	PUSH.L	D4	LOAD.W	D4,(A6)+OASOCT+OSCPOSV	NEG.W	D4	ADD.W	D4,#5	LOAD.W	(A1)+OTOCT,D4	LOAD.W	D4,(A6)+OASDMT+OSCPOSV	NEG.W	D4	ADD.W	D4,#12	LOAD.W	(A1)+OTDMT,D4	LOAD.W	D4,(A6)+OASAMP+OSCPOSV	NEG.W	D4	ADD.W	D4,#128	LOAD.W	(A1)+OTAMP,D4	LOAD.W	D4,(A6)+OASDYN+OSCPOSV	NEG.W	D4	ADD.W	D4,#128	LOAD.W	(A1)+OTDYN,D4	POP.L	D4	RET;--------\\; PAFASC  >;--------/; Affiche un ascenseur vertical avec graduation.; in	A5.L	^ascenseur;	A4.L	^table (TPA...);	D0.W	zro => premire fois; out	-; mod	D7.WPAFASC:	PUSHM.L	D3,D4,A3,A4	LOAD.W	D4,(A4+)	; D4 <-- position en X (car)	MUL.WU	D4,(A0)+ODFCX	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#12	LOAD.W	(A5)+OSCHTR,D4	TEST.W	D0	JUMP,NE 30$	SET.B	(A5)+OSCMARK	SCROLL_	DRAW		; dessine la cage de l'ascenseur30$:	LOAD.W	(A5)+OSCHTV,(A4+)	LOAD.W	(A5)+OSCINC,(A4+)	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur50$:	LOAD.W	D4,(A4+)	; D4 <-- longueur	LOAD.W	D3,(A4+)	; D3 <-- nombre	LOAD.L	A3,#0	TEST.W	(A4)	JUMP,NE 60$	LOAD.L	A3,#(A4)+2	; A3 <-- ^textes60$:	TEST.W	D0	JUMP,NE 65$	SCROLL_	SCALE		; affiche la graduation65$:	TEST.W	(A4)	JUMP,NE 50$	LOAD.W	D3,(A3)-4	; D3 <-- nombre;	ADD.W	D3,#1-1		; D3 <-- -1  cause NMO70$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE 70$	DECJ.W,NMO D3,70$	TEST.W	D0	JUMP,NE 90$	LOAD.W	D3,(A5)+OSCDEBO	SUB.W	D3,(A0)+ODFCY	SWAP.W	D3	LOAD.W	D3,(A5)+OSCDEBL	LIB	?SETCURS	LIB	?AFTEXT		; affiche le "titre" de l'ascenseur90$:	POPM.L	D3,D4,A3,A4	RET;--------\\; PAFMIDI >;========/; Affiche le numro de canal midi dans les "soft-keys".; in	A1.L	^variables de la piste; out	-; mod	D7.WPAFMIDI:	PUSHM.L	D2..D4,A3,A4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	A3,#R16"TICOPARAM	LOAD.L	A4,#0	LOAD.W	D2,#2		; D2 <-- rang pour (F2)	DBOX_	ICOPOS		; D3/D4 <-- position/dimensions	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; efface le numro prcdent	CLR.L	D2	LOAD.W	D2,(A1)+OTMIDI	INC.W	D2		; D2 <-- 1..16	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- au milieu en X	LOAD.W	D4,(A0)+ODFCX	COMP.W	D2,#10	JUMP,HS 35$	SR.W	D4,#135$:	SUB.W	D3,D4	INC.W	D3	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- au milieu en Y	LOAD.W	D4,(A0)+ODFC1Y	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	LIB	?SETCURS	LOAD.B	D3,#AFINV	LIB	?AFCAR	LOAD.L	D4,D2		; D4 <-- numro	LOAD.W	D3,#2		; D3 <-- nb max digits	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode	LIB	?AFDEC		; affiche le numro 1..16	LOAD.B	D3,#AFDIR	LIB	?AFCAR	POPM.L	D2..D4,A3,A4	RET;--------\\; PAFINFO >;========/; Affiche les informations tout en haut.; in	D1.W	numro de la piste; out	-; mod	D7.WPAFINFO:	PUSHM.L	D2..D5,A4	LIB	?GETWDO		; D5 <-- no swdo utilise	LOAD.W	D4,D5	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.W	D5,D4	CLR.L	D3	LIB	?SETCURS	; positionne en tout en haut  gauche	LIB	?AFTIM	.B	AFINV		; en inverse vido	.B	SPACE		; toujours un espace	.ASCII	"Paramtres de la piste "	.B	0	.EVEN	CLR.L	D4	LOAD.W	D4,D1		; D4 <-- numro de la piste (0..7)	INC.W	D4		; D4 <-- numro de la piste (1..8)	LOAD.W	D3,#1		; D3 <-- nb digits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC		; affiche le numro de piste	LIB	?AFTIM	.ASCIZ	"   - "	.EVEN	LOAD.L	A4,#(A6)+OTRACK	LOAD.W	D4,D1	MUL.WU	D4,#LT	ADD.L	A4,D4	CLR.L	D4	LOAD.W	D4,(A4)+OTMIDI	; D4 <-- canal MIDI	INC.W	D4		; D4 <-- 1..16	LOAD.W	D3,#2		; D3 <-- nb digits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC		; affiche le canal MIDI	LIB	?AFSPACE	DEC.W	D4	CALL	AFCFNOM		; affiche le nom du synthtiseur	LIB	?AFTIM	.ASCII	"   "	.ASCII	"|           |           |  modifie  |"		 ;           ;           ;           ;	.B	AFDIR		; remet vido normale	.B	0	.EVEN	LIB	?USEWDO		; utilise swdo initiale	POPM.L	D2..D5,A4	RET; Tables; ------TICOPARAM:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLEVEL+1	.B	ICOMOINS,ICOVIDE,ICOPLUS	.B	ICOSYNTHE,ICORYTHME,ICOSMAKY	.B	0,0,0	.B	ICOPREV,ICOPREV,ICOPREV	.B	ICONEXT,ICONEXT,ICONEXTTMENUPARAM:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Canal MIDI"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Synth.Rythm.Smaky"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Piste prcdente"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Piste suivante"	.EVENTPAOCT:				; TRANSPOSITION/OCTAVE :	.W	10		; position en X (car)	.W	5+1+5,1		; hauteur virtuelle et incrment	.W	10,10		; barres: lg et nb	.W	0		; barres: texte pour chelle	.ASCIZ	"+5"	.ASCIZ	"+4"	.ASCIZ	"+3"	.ASCIZ	"+2"	.ASCIZ	"+1"	.ASCIZ	"normal"	.ASCIZ	"-1"	.ASCIZ	"-2"	.ASCIZ	"-3"	.ASCIZ	"-4"	.ASCIZ	"-5"	.ASCIZ	"___Transposition___"	.EVENTPADMT:				; TRANSPOSITION/DEMI-TON :	.W	22		; position en X (car)	.W	12+1,1		; hauteur virtuelle et incrment	.W	10,12		; barres: lg et nb	.W	0		; barres: texte pour chelle	.ASCIZ	"do"	.ASCIZ	"si"	.ASCIZ	""	.ASCIZ	"la"	.ASCIZ	""	.ASCIZ	"sol"	.ASCIZ	""	.ASCIZ	"fa"	.ASCIZ	"mi"	.ASCIZ	""	.ASCIZ	"r"	.ASCIZ	""	.ASCIZ	"do"	.ASCIZ	""	.EVENTPAAMP:				; AMPLITUDE :	.W	42		; position en X (car)	.W	256,16		; hauteur virtuelle et incrment	.W	4,16		; barres: lg et nb	.W	10,2		; barres: lg et nb	.W	0		; barres: texte pour chelle	.ASCIZ	"max"	.ASCIZ	"normal"	.ASCIZ	"min"	.ASCIZ	"Amplitude"	.EVENTPADYN:				; DYNAMIQUE :	.W	54		; position en X (car)	.W	256,16		; hauteur virtuelle et incrment	.W	4,16		; barres: lg et nb	.W	10,2		; barres: lg et nb	.W	0		; barres: texte pour chelle	.ASCIZ	"max"	.ASCIZ	"normal"	.ASCIZ	"min"	.ASCIZ	"Dynamique"	.EVEN	.END