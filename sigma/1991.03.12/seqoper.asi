	.SBTTL	SEQOPER;----------\\; SELPTRACK >;==========/; Slectionne le temps  sauter au dbut et les pistes;  couter selon les fanions.; in	-; out	D7.W	erreur; mod	D7.WSELPTRACK:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A4,#(A6)+OBUCOM	LOAD.B	(A4)+0,#'M	; <midi>	LOAD.L	A3,#(A6)+OTRACK	LOAD.L	A2,#(A4)+1	LOAD.W	D4,#NBTRACK-110$:	LOAD.B	(A2+),(A3)+OTMIDI+1	LOAD.L	A3,#(A3)+LT	DECJ.W,NMO D4,10$	LOAD.W	D4,#NBTRACK-111$:	CLR.B	(A2+)	DECJ.W,NMO D4,11$	CLR.B	(A4)+NBTRACK+1	CALL	COMMAND		; commande les canaux midi	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM	LOAD.B	(A4)+0,#'O	; <offset>	LOAD.L	A3,#(A6)+OTRACK	LOAD.L	A2,#(A4)+1	LOAD.W	D4,#NBTRACK-120$:	LOAD.W	D3,(A3)+OTOCT	MUL.WA	D3,#12	ADD.W	D3,(A3)+OTDMT	LOAD.B	(A2+),D3	LOAD.L	A3,#(A3)+LT	DECJ.W,NMO D4,20$	LOAD.W	D4,#NBTRACK-121$:	CLR.B	(A2+)	DECJ.W,NMO D4,21$	CLR.B	(A4)+NBTRACK+1	CALL	COMMAND		; commande les transpositions	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM	LOAD.B	(A4)+0,#'A	; <amplitude>	LOAD.L	A3,#(A6)+OTRACK	LOAD.L	A2,#(A4)+1	LOAD.W	D4,#NBTRACK-130$:	LOAD.B	(A2+),(A3)+OTAMP+1	LOAD.L	A3,#(A3)+LT	DECJ.W,NMO D4,30$	LOAD.W	D4,#NBTRACK-131$:	CLR.B	(A2+)	DECJ.W,NMO D4,31$	CLR.B	(A4)+NBTRACK+1	CALL	COMMAND		; commande les amplitudes	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM	LOAD.B	(A4)+0,#'D	; <dynamique>	LOAD.L	A3,#(A6)+OTRACK	LOAD.L	A2,#(A4)+1	LOAD.W	D4,#NBTRACK-140$:	LOAD.B	(A2+),(A3)+OTDYN+1	LOAD.L	A3,#(A3)+LT	DECJ.W,NMO D4,40$	LOAD.W	D4,#NBTRACK-141$:	CLR.B	(A2+)	DECJ.W,NMO D4,41$	CLR.B	(A4)+NBTRACK+1	CALL	COMMAND		; commande la dynamique	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'V	; <vitesse>	LOAD.W	D4,#MAXVIT	SUB.W	D4,(A6)+OASVIT+OSCPOSV ; D4 <-- vitesse (-MAXVIT..+MAXVIT)	LOAD.W	(A4)+1,D4	CLR.B	(A4)+3	CALL	COMMAND		; commande la bonne vitesse	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'E	; <cho>	LOAD.B	(A4)+1,#'N	; <no>	TEST.B	(A6)+OFAMODE+2:#BMODINOUT-8	JUMP',BC 50$	LOAD.B	(A4)+1,#'Y	; <yes>50$:	CLR.B	(A4)+2	CALL	COMMAND		; commande l'cho	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'S	; <synchro>	LOAD.B	(A4)+1,#'N	; <no>	TEST.B	(A6)+OFAMODE+3:#BMODSEXT-0	JUMP',BC 52$	LOAD.B	(A4)+1,#'Y	; <yes>52$:	CLR.B	(A4)+2	CALL	COMMAND		; commande la synchro	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'K	; <clock>	LOAD.B	(A4)+1,#'N	; <no>	TEST.B	(A6)+OFAMODE+3:#BMODSINT-0	JUMP',BC 54$	LOAD.B	(A4)+1,#'Y	; <yes>54$:	CLR.B	(A4)+2	CALL	COMMAND		; commande le clock	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'P	; <pression>	LOAD.B	(A4)+1,#'N	; <no>	TEST.B	(A6)+OFAMODE+2:#BMODAFTER-8	JUMP',BC 56$	LOAD.B	(A4)+1,#'Y	; <yes>56$:	CLR.B	(A4)+2	CALL	COMMAND		; commande l'after touch	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.W	D4,(A6)+OTRKAX	JUMP',EQ 60$	MUL.WU	D4,(A6)+OTRKFD	DIV.WU	D4,(A6)+OTRKFM	LOAD.B	(A4)+0,#'T	; <time>	LOAD.W	(A4)+1,D4	; <<n>>	CLR.B	(A4)+3	CALL	COMMAND		; saute jusqu' l'avance	JUMP',NE 90$60$:	LOAD.L	D4,(A6)+OFANION;	RR.L	D4,#BFAPLAY	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'C	; <canal>	CLR.B	(A4)+1		; <bits>	LOAD.B	(A4)+2,D4	; <bits>	CLR.B	(A4)+3	CALL	COMMAND		; n'coute que les canaux choisis90$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; MAJRTRACK >;==========/; Met le canal d'enregistrement dans tout le record buffer; selon les fanions.; in	D5.W	piste d'enregistrement; out	-; mod	D7.WMAJRTRACK:	PUSHM.L	D2..D5,A4	LOAD.L	A4,(A6)+OPMBUF	ADD.L	A4,(A6)+OLMBUF	; A4 <-- ^dbut record buffer	LOAD.L	D4,(A6)+OLRBUF	; D4 <-- lg record buffer20$:	TEST.L	D4	JUMP,EQ 90$	CLR.L	D3	LOAD.B	D3,(A4)+0	SL.W	D3,#8	LOAD.B	D3,(A4)+1	; D3 <-- lg	TEST.W	D3	JUMP',NE 40$				; temps =>	ADD.L	A4,#4		; A4 <-- saute le temps	SUB.L	D4,#4	JUMP	20$40$:				; objet =>	LOAD.B	D2,(A4)+2	; D2 <-- status de la commande	COMP.B	D2,#H'80	JUMP',LO 45$	COMP.B	D2,#H'F0	JUMP',HS 45$	AND.B	D2,#H'F0	; D2 <-- masque le canal	OR.B	D2,D5		; D2 <-- force le canal d'enregistrement	LOAD.B	(A4)+2,D245$:	ADD.W	D3,#2	ADD.L	A4,D3	SUB.L	D4,D3	JUMP	20$90$:	POPM.L	D2..D5,A4	RET;--------\\; FUSION  >;========/; Fusionne le record buffer dans le master buffer.; in	-; out	-; mod	D7.WFUSION:	PUSHM.L	D0..D4,A2..A4	TEST.L	(A6)+OLRBUF	JUMP,EQ 90$	LOAD.L	D4,(A6)+OMMBUF	SUB.L	D4,(A6)+OLMBUF	SUB.L	D4,(A6)+OLRBUF	; D4 <-- place restante	COMP.L	D4,(A6)+OLRBUF	; reste assez de place ?	JUMP,LO 90$		; non => 90$ !!!; Pousse le master buffer et le record buffer tout  la fin.	LOAD.L	A3,(A6)+OPMBUF	LOAD.L	A4,A3	ADD.L	A3,(A6)+OMMBUF	; A3 <-- ^fin grand buffer	LOAD.L	D4,(A6)+OLMBUF	ADD.L	D4,(A6)+OLRBUF	; D4 <-- lg master + record buffers	ADD.L	A4,D4		; A4 <-- ^fin record buffer10$:	LOAD.B	(-A3),(-A4)	DEC.L	D4	JUMP,NE 10$; Initialise les registres suivants :; A2	^dbut master buffer; A3/D3	^/lg master buffer; A4/D4	^/lg record buffer	LOAD.L	A2,(A6)+OPMBUF	; A2 <-- ^tout dbut	LOAD.L	A4,A3	ADD.L	A4,(A6)+OLMBUF	; A4 <-- ^record buffer	LOAD.L	D4,(A6)+OLRBUF	; D4 <-- lg record buffer	LOAD.L	D3,(A6)+OLMBUF	; D3 <-- lg master buffer	JUMP'	30$20$:	TEST.L	D3		; reste qq chose dans master buffer ?	JUMP,EQ 80$		; non => 80$	TEST.L	D4		; reste qq chose dans record buffer ?	JUMP,EQ 70$		; non => 70$	LOAD.B	D1,(A3)+2	SL.W	D1,#8	LOAD.B	D1,(A3)+3	; D1 <-- temps master buffer	LOAD.B	D2,(A4)+2	SL.W	D2,#8	LOAD.B	D2,(A4)+3	; D2 <-- temps record buffer	LOAD.L	D0,#4		; D0 <-- lg pour temps	COMP.W	D1,D2		; compare temps (master,record)	JUMP,HS 60$	JUMP'	40$; Descend le(s) objet(s) du master buffer au dbut.30$:	TEST.L	D3		; reste qq chose dans master buffer ?	JUMP,EQ 20$		; non => 20$	CLR.L	D0	LOAD.B	D0,(A3)+0	SL.W	D0,#8	LOAD.B	D0,(A3)+1	; D0 <-- lg master buffer	TEST.W	D0	JUMP,EQ 20$		; temps => 20$				; objet =>	ADD.W	D0,#240$:	SUB.L	D3,D042$:	LOAD.B	(A2+),(A3+)	; dbut <-- temps/objet	DEC.L	D0	JUMP,NE 42$	JUMP	30$; Descend le(s) objet(s) du record buffer au dbut.50$:	TEST.L	D4		; reste qq chose dans record buffer ?	JUMP,EQ 20$		; non => 20$	CLR.L	D0	LOAD.B	D0,(A4)+0	SL.W	D0,#8	LOAD.B	D0,(A4)+1	; D0 <-- lg record buffer	TEST.W	D0	JUMP,EQ 20$		; temps suivant => 20$				; objet =>	ADD.W	D0,#260$:	SUB.L	D4,D062$:	LOAD.B	(A2+),(A4+)	; dbut <-- temps/objet	DEC.L	D0	JUMP,NE 62$	JUMP	50$; Met le reste du master buffer au dbut.70$:	LOAD.L	D4,D3	LOAD.L	A4,A3; Met le reste du record buffer au dbut.80$:	TEST.L	D4	JUMP',EQ 85$82$:	LOAD.B	(A2+),(A4+)	DEC.L	D4	JUMP,NE 82$; Met  jour la nouvelle longueur du master buffer.85$:	SUB.L	A2,(A6)+OPMBUF	LOAD.L	(A6)+OLMBUF,A2	CLR.L	(A6)+OLRBUF	; le record buffer est maintenant vide90$:	POPM.L	D0..D4,A2..A4	RET;--------\\; DETRUIT >;========/; Efface compltement une piste dans le master buffer.; in	D4.W	no piste  dtruire; out	-; mod	D7.WDETRUIT:	PUSHM.L	D2..D5,A3,A4	LOAD.W	D5,D4		; D5 <-- piste  dtruire	LOAD.L	A4,(A6)+OPMBUF	; A4 <-- ^dbut master buffer	LOAD.L	D4,(A6)+OLMBUF	; D4 <-- lg master buffer	LOAD.L	A3,A4		; A3 <-- ^idem ou en arrire20$:	TEST.L	D4		; reste qq chose ?	JUMP,EQ 80$		; non => 80$	CLR.L	D3	LOAD.B	D3,(A4)+0	SL.W	D3,#8	LOAD.B	D3,(A4)+1	; D3 <-- lg	TEST.W	D3	JUMP',NE 30$				; temps =>	LOAD.L	D3,#4		; D3 <-- lg pour le temps	JUMP'	50$30$:				; objet =>	ADD.L	D3,#2	LOAD.B	D2,(A4)+2	; D2 <-- status de la commande	AND.B	D2,#H'F0	; D2 <-- masque le canal	COMP.B	D2,#H'80	JUMP',LO 50$	COMP.B	D2,#H'F0	JUMP',HS 50$	LOAD.B	D2,(A4)+2	; D2 <-- status de la commande	AND.B	D2,#H'0F	; D2 <-- juste le canal	COMP.B	D2,D5		; canal  effacer ?	JUMP',NE 50$		; non => 50$				; oui =>	ADD.L	A4,D3		; A4 <-- saute l'objet, sans bouger A3	SUB.L	D4,D3	JUMP	20$50$:	SUB.L	D4,D355$:	LOAD.B	(A3+),(A4+)	DEC.L	D3	JUMP,NE 55$	JUMP	20$80$:	SUB.L	A3,(A6)+OPMBUF	LOAD.L	(A6)+OLMBUF,A3	; mj la longueur (plus courte)	POPM.L	D2..D5,A3,A4	RET;--------\\; DEPLACE >;========/; Dplace une piste.; in	D4.W	no piste  dplacer;	D5.W	nouveau numro; out	-; mod	D7.WDEPLACE:	PUSHM.L	D2..D6,A4	LOAD.W	D6,D4		; D6 <-- piste  dplacer	LOAD.L	A4,(A6)+OPMBUF	; A4 <-- ^dbut master buffer	LOAD.L	D4,(A6)+OLMBUF	; D4 <-- lg master buffer20$:	TEST.L	D4		; reste qq chose ?	JUMP,EQ 80$		; non => 80$	CLR.L	D3	LOAD.B	D3,(A4)+0	SL.W	D3,#8	LOAD.B	D3,(A4)+1	; D3 <-- lg	TEST.W	D3	JUMP',NE 30$				; temps =>	LOAD.L	D3,#4		; D3 <-- lg pour le temps	JUMP'	50$30$:				; objet =>	ADD.L	D3,#2	LOAD.B	D2,(A4)+2	; D2 <-- status de la commande	AND.B	D2,#H'F0	; D2 <-- masque le canal	COMP.B	D2,#H'80	JUMP',LO 50$	COMP.B	D2,#H'F0	JUMP',HS 50$	LOAD.B	D2,(A4)+2	; D2 <-- status de la commande	AND.B	D2,#H'0F	; D2 <-- juste le canal	COMP.B	D2,D6		; canal  dplacer ?	JUMP',NE 50$		; non => 50$				; oui =>	LOAD.B	D2,(A4)+2	; D2 <-- status de la commande	AND.B	D2,#H'F0	; D2 <-- masque le canal	OR.B	D2,D5		; D2 <-- met le nouveau canal	LOAD.B	(A4)+2,D250$:	ADD.L	A4,D3		; A4 <-- saute objet/temps	SUB.L	D4,D3	JUMP	20$80$:	POPM.L	D2..D6,A4	RET;---------\\; DUPLIQUE >;=========/; Duplique une piste.; in	D4.W	no piste  dplacer;	D5.W	nouveau numro; out	-; mod	D7.WDUPLIQUE:	PUSHM.L	D2..D6,A1..A4	LOAD.W	D6,D4		; D6 <-- piste  dupliquer; Pousse le master buffer tout  la fin.	LOAD.L	A3,(A6)+OPMBUF	LOAD.L	A4,A3	ADD.L	A3,(A6)+OMMBUF	; A3 <-- ^fin grand buffer	LOAD.L	D4,(A6)+OLMBUF	; D4 <-- lg master buffer	JUMP,EQ 90$	ADD.L	A4,D4		; A4 <-- ^fin master buffer10$:	LOAD.B	(-A3),(-A4)	DEC.L	D4	JUMP,NE 10$	LOAD.L	A4,A3		; A4 <-- ^dbut master buffer pouss	LOAD.L	A3,(A6)+OPMBUF	LOAD.L	D4,(A6)+OLMBUF	; D4 <-- lg master buffer20$:	TEST.L	D4		; reste qq chose ?	JUMP,EQ 80$		; non => 80$	CLR.L	D3	LOAD.B	D3,(A4)+0	SL.W	D3,#8	LOAD.B	D3,(A4)+1	; D3 <-- lg	TEST.W	D3	JUMP',NE 30$				; temps =>	LOAD.L	D3,#4		; D3 <-- lg pour le temps	JUMP	50$30$:				; objet =>	ADD.L	D3,#2	LOAD.B	D2,(A4)+2	; D2 <-- status de la commande	AND.B	D2,#H'F0	; D2 <-- masque le canal	COMP.B	D2,#H'80	JUMP',LO 50$	COMP.B	D2,#H'F0	JUMP',HS 50$	LOAD.B	D2,(A4)+2	; D2 <-- status de la commande	AND.B	D2,#H'0F	; D2 <-- juste le canal	COMP.B	D2,D6		; canal  dupliquer ?	JUMP',NE 50$		; non => 50$				; oui =>	LOAD.L	A2,A4	LOAD.L	A1,A3	LOAD.L	D2,D340$:	LOAD.B	(A3+),(A2+)	; master buffer <-- un double	DEC.L	D2	JUMP,NE 40$	LOAD.B	D2,(A1)+2	; D2 <-- status de la commande	AND.B	D2,#H'F0	; D2 <-- masque le canal	OR.B	D2,D5		; D2 <-- met le nouveau canal	LOAD.B	(A1)+2,D250$:	SUB.L	D4,D355$:	LOAD.B	(A3+),(A4+)	; master buffer <-- un objet	DEC.L	D3	JUMP,NE 55$	JUMP	20$80$:	SUB.L	A3,(A6)+OPMBUF	LOAD.L	(A6)+OLMBUF,A3	; mj lg master buffer90$:	POPM.L	D2..D6,A1..A4	RET;--------\\; COMPACT >;========/; Compactifie le master buffer, pour supprimer les commandes; de temps inutiles.; in	-; out	-; mod	D7.WCOMPACT:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,(A6)+OPMBUF	; A4 <-- ^dbut master buffer	LOAD.L	D4,(A6)+OLMBUF	; D4 <-- lg master buffer	LOAD.L	A3,A4		; A3 <-- ^idem ou en arrire20$:	TEST.L	D4		; reste qq chose ?	JUMP,EQ 80$		; non => 80$	CLR.L	D3	LOAD.B	D3,(A4)+0	SL.W	D3,#8	LOAD.B	D3,(A4)+1	; D3 <-- lg	TEST.W	D3	JUMP',EQ 30$				; objet =>	ADD.W	D3,#2		; D3 <-- lg pour l'objet	JUMP'	50$30$:				; temps =>	LOAD.W	D3,#4		; D3 <-- lg pour temps	COMP.L	D4,#4		; temps tout  la fin ?	JUMP',EQ 40$		; oui => 40$ (supprime)	LOAD.B	D2,(A4)+4+0	SL.W	D2,#8	LOAD.B	D2,(A4)+4+1	; D2 <-- lg	TEST.W	D2		; deuxime commande de temps juste aprs ?	JUMP',NE 50$		; non => 50$40$:				; oui =>	ADD.L	A4,D3		; A4 <-- saute le temps, sans bouger A3	SUB.L	D4,D3	JUMP	20$50$:	SUB.L	D4,D355$:	LOAD.B	(A3+),(A4+)	DEC.L	D3	JUMP,NE 55$	JUMP	20$80$:	SUB.L	A3,(A6)+OPMBUF	LOAD.L	(A6)+OLMBUF,A3	; mj la longueur (plus courte)	CALL	DEDOUBLE	; voir juste ci-dessous	POPM.L	D2..D4,A3,A4	RET;---------\\; DEDOUBLE >;---------/; Dbouble les commandes "note on/off" qui contiennent plus; d'une note.; in	-; out	-; mod	D7.WDEDOUBLE:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,(A6)+OPMBUF	; A4 <-- ^dbut master buffer	LOAD.L	A3,A4	ADD.L	A3,(A6)+OLMBUF	; A3 <-- ^fin master buffer	ADD.L	A4,(A6)+OMMBUF	; A4 <-- ^max maxter buffer	LOAD.L	D4,(A6)+OLMBUF	JUMP,EQ 90$10$:	LOAD.B	(-A4),(-A3)	; pousse le master buffer  la fin	DEC.L	D4	JUMP,NE 10$	LOAD.L	D4,(A6)+OLMBUF20$:	TEST.L	D4		; reste qq chose ?	JUMP,EQ 80$		; non => 80$	CLR.L	D3	LOAD.B	D3,(A4)+0	SL.W	D3,#8	LOAD.B	D3,(A4)+1	; D3 <-- <<lg>>	TEST.W	D3	JUMP,EQ 50$				; objet =>	ADD.W	D3,#2		; D3 <-- lg pour l'objet	LOAD.B	D2,(A4)+2	AND.B	D2,#H'F0	COMP.B	D2,#H'90	; note on/off ?	JUMP',NE 60$		; non => 60$	LOAD.W	D2,D3	SUB.W	D2,#2+1	SR.W	D2,#1		; D2 <-- nb de notes "colles"	COMP.W	D2,#1		; plus d'une note ?	JUMP',LS 60$		; non => 60$				; oui =>	SUB.L	D4,D3	ADD.L	A4,#2+1		; A4 <-- saute <<lg>> et <note on/off>40$:	CLR.B	(A3+)	LOAD.B	(A3+),#3	; A3 <-- <<lg>>	LOAD.B	(A3+),#H'90	; A3 <-- <note on/off>	LOAD.B	(A3+),(A4+)	; A3 <-- <touche>	LOAD.B	(A3+),(A4+)	; A3 <-- <vlocit>	DEC.W	D2	JUMP,NE 40$	JUMP	20$50$:				; temps =>	LOAD.W	D3,#4		; D3 <-- lg pour temps60$:	SUB.L	D4,D365$:	LOAD.B	(A3+),(A4+)	; A3 <-- commande complte	DEC.L	D3	JUMP,NE 65$	JUMP	20$80$:	SUB.L	A3,(A6)+OPMBUF	LOAD.L	(A6)+OLMBUF,A3	; mj la longueur (plus longue)90$:	POPM.L	D2..D4,A3,A4	RET;----------\\; GETRTRACK >;==========/; Donne le numro de piste d'enregistrement selon les fanions.; in	-; out	D5.W	piste d'enregistrement; mod	D5.WGETRTRACK:	PUSH.L	D4	LOAD.L	D4,(A6)+OFANION	; D4 <-- fanions	CLR.W	D5		; D5 <-- no canal d'enregistrement10$:	TEST.L	D4:#BFAREC	JUMP',BS 90$	RR.L	D4,#1	INC.W	D5	JUMP	10$90$:	POP.L	D4	RET	.END