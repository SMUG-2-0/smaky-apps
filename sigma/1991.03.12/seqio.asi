	.SBTTL	SEQIODOPREND:			; PREND =>	LOAD.L	A3,#(A6)+OBUFILE	CLR.B	(A3)DOPRENDL:	CALL	DBOXEDITI	; dite le nom ...	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ LOOP	LOAD.W	D0,D3		; D0 <-- prend/joueDOPRENDF:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,EQ 20$	PUSH.W	D7	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	DOPRENDL20$:	CALL	READHEAD	; lit le header	JUMP,NE 90$	LOAD.L	D4,(A6)+OHEAD+OHLG	JUMP,EQ 30$				; lit si longueur connue =>	LOAD.L	A4,(A6)+OPMBUF	FOS	?RDBYTE		; lit le data	JUMP,NE 90$	LOAD.L	(A6)+OLMBUF,D4	LOAD.L	A4,(A6)+OPRYTHM	; A4 <-- ^variables du module RYTHM	.W	RYTH_READ	; lit le rythme	JUMP,NE 90$	JUMP	40$30$:				; lit si longueur inconnue =>	LOAD.L	A4,(A6)+OPMBUF	LOAD.L	D4,(A6)+OMMBUF	; D4 <-- lg maximale	FOS	?RDBYTE		; lit le data	JUMP,EQ 80$	COMP.W	D7,#EROUTF	JUMP,NE 90$	LOAD.L	(A6)+OLMBUF,D440$:	FOS	?CLOSE	JUMP,NE 90$	CALL	GETHEAD		; variables <-- en-tte	CALL	DBOXTRACK	; affiche le contenu des pistes	CALL	DBOXMIDI	; affiche les canaux midi	LOAD.L	A5,#(A6)+OASVIT	; A5 <-- ^variables ascenseur-vitesse	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur	CALL	DBOXFULL	; affiche la jauge	CALL	AFINFO		; affiche les informations tout en haut	COMP.W	D0,#F4		; joue ?	JUMP,EQ 70$		; oui => 70$	JUMP	DOBEGIN70$:	LOAD.W	D4,(A6)+OTRKAX	CALL	DBOXINVA	; efface l'ancienne position	CLR.W	D4	CALL	DBOXINVA	; dessine la nouvelle position au dbut	CLR.W	(A6)+OTRKAX	; revient au dbut	CALL	NORMMOUSE	; remet la flche	JUMP	DOPLAY80$:	LOAD.W	D7,#ERNEMEM90$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	CLR.L	(A6)+OLMBUF	; annule ce qui a t lu	JUMP	ERRORDOSAUVE:			; SAUVE =>	TEST.L	(A6)+OLMBUF	; master buffer vide ?	JUMP,EQ BIP		; oui => BIP	LOAD.L	A3,#(A6)+OBUFILE10$:	CALL	NORMMOUSE	; remet la flche	CALL	DBOXEDITO	; dite le nom ...	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ LOOP	LOAD.W	D1,D3		; D1 <-- F1/F4	LOAD.L	D0,D4		; D0 <-- fanions	CALL	WAITMOUSE	; met le sablier20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	FOS	?CREATE		; cre le fichier	JUMP,EQ	30$		; ok => 30$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	ERROR		; non => ERROR				; oui =>	CALL	NORMMOUSE	; remet la flche	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	CALL	AFMENU		; refait les soft-keys	TEST.W	D7	JUMP,NE ERROR	COMP.W	D3,#'O	JUMP,NE 10$	FOS	?DELETE		; dtruit le fichier	JUMP,NE ERROR	JUMP	20$30$:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP,NE 95$	CALL	PUTHEAD		; en-tte <-- variables	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	D4,#LHEAD	FOS	?WRBYTE		; crit le header	JUMP,NE 90$	LOAD.L	A4,(A6)+OPMBUF	LOAD.L	D4,(A6)+OLMBUF	FOS	?WRBYTE		; crit le data	JUMP,NE 90$	LOAD.L	A4,(A6)+OPRYTHM	; A4 <-- ^variables du module RYTHM	.W	RYTH_WRITE	; crit le rythme	JUMP,NE 90$	FOS	?CLOSE	JUMP,NE 95$	JUMP	LOOP90$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D795$:	JUMP	ERROR;---------\\; READHEAD >;---------/; Lit l'en-tte, avec conversion pour les anciens fichiers.; in	D6.W	canal; out	D7.W	erreur; mod	D7.WREADHEAD:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	D4,#2	FOS	?RDBYTE		; lit juste les 2 premiers bytes	JUMP,NE 90$	TEST.B	(A4)+OOHID	JUMP',EQ 30$				; nouveau =>	ADD.L	A4,#2	LOAD.L	D4,#LHEAD-2	FOS	?RDBYTE		; lit le nouvel header	JUMP	90$30$:				; ancien =>	LOAD.L	A4,#(A6)+OOHEAD	LOAD.W	(A4+),(A6)+OHEAD	LOAD.L	D4,#LOHEAD-2	FOS	?RDBYTE		; lit l'ancien header	JUMP,NE 90$	LOAD.L	A4,#(A6)+OHEAD	LOAD.W	D4,#LHEAD-135$:	CLR.B	(A4+)		; header <-- rempli de zro	DECJ.W,NMO D4,35$	LOAD.B	(A6)+OHEAD+OHCHA,(A6)+OOHEAD+OOHCHA	LOAD.W	(A6)+OHEAD+OHVIT,(A6)+OOHEAD+OOHVIT	LOAD.B	(A6)+OHEAD+OHMET,(A6)+OOHEAD+OOHMET	LOAD.L	(A6)+OHEAD+OHLG,(A6)+OOHEAD+OOHLG	LOAD.L	A4,#(A6)+OHEAD+OHTRK	LOAD.L	A3,#(A6)+OOHEAD+OOHTRK	LOAD.W	D4,#NBTRACK-150$:	LOAD.W	(A4)+OTMIDI,(A3)+OOTMIDI	LOAD.W	(A4)+OTOCT,(A3)+OOTOCT	LOAD.W	(A4)+OTDMT,(A3)+OOTDMT	LOAD.W	(A4)+OTAMP,(A3)+OOTAMP	LOAD.W	(A4)+OTDYN,(A3)+OOTDYN	LOAD.L	A4,#(A4)+LT	LOAD.L	A3,#(A3)+LOT	DECJ.W,NMO D4,50$	LOAD.L	A4,#(A6)+OHEAD+OHTRK+OTSNA	LOAD.L	A3,#(A6)+OOHEAD+OOHNAME60$:	LOAD.B	(A4+),(A3+)	JUMP,NE 60$	LOAD.W	(A6)+OHEAD+OHTRK+OTSNO,(A6)+OOHEAD+OOHPROG	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETHEAD >;--------/; Met  jour les variables en fonction de l'en-tte lue.; in	A3.L	^nom du fichier; out	-; mod	D7.WGETHEAD:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A2,A3		; A2 <-- ^nom du fichier	LOAD.L	A4,#(A6)+OHEAD	LOAD.B	(A6)+OFANION+3,(A4)+OHCHA	LOAD.B	D4,(A4)+OHMET	SL.B	D4,#1	JUMP,NE 50$	LOAD.B	D4,#150$:	LOAD.B	(A6)+OFANION+1,D4	LOAD.B	(A6)+OFANION+2,#1	LOAD.W	D4,#MAXVIT	SUB.W	D4,(A4)+OHVIT	LOAD.W	(A6)+OASVIT+OSCPOSV,D4	PUSH.L	A4	LOAD.L	A4,#(A4)+OHTRK	LOAD.L	A3,#(A6)+OTRACK	LOAD.W	D4,#(NBTRACK*LT)-160$:	LOAD.B	(A3+),(A4+)	; OTRACK <-- selon header	DECJ.W,NMO D4,60$	POP.L	A4	CALL	SMAKYTRACK	; si pas de synth => met pistes sur le Smaky	LOAD.L	A4,#(A4)+OHTRK	CLR.W	D470$:	LOAD.L	A3,#(A4)+OTSNA	; A3 <-- ^nom des timbres	TEST.B	(A3)		; nom des timbres existe ?	JUMP',EQ 75$		; non => 75$	PUSH.L	A4	LOAD.L	A4,#(A6)+OBUFILE	CALL	AJREP		; A3 <-- ^rp:nom	POP.L	A4	LOAD.W	D3,(A4)+OTSNO	CALL	SYNTUSE		; slectionne le bon timbre75$:	LOAD.L	A4,#(A4)+LT	INC.W	D4	COMP.W	D4,#NBTRACK	JUMP,LO 70$90$:	POPM.L	D3,D4,A2..A4	RET;--------\\; PUTHEAD >;--------/; Met  jour l'en-tte pour pouvoir l'crire sur disque.; in	A3.L	^nom du fichier; out	-; mod	D7.WPUTHEAD:	PUSHM.L	D4,A1..A4	LOAD.L	A2,A3		; A2 <-- ^nom du fichier	LOAD.L	A4,#(A6)+OHEAD+LHEAD	LOAD.W	D4,#LHEAD-110$:	CLR.B	(-A4)		; header <-- rempli de zro	DECJ.W,NMO D4,10$	LOAD.W	(A4)+OHID,#-1	LOAD.B	(A4)+OHREV,#MAJREV	LOAD.B	(A4)+OHVERS,#MINREV	LOAD.B	(A4)+OHCHA,(A6)+OFANION+3	LOAD.B	D4,(A6)+OFANION+1	SR.B	D4,#1	LOAD.B	(A4)+OHMET,D4	LOAD.L	(A4)+OHLG,(A6)+OLMBUF	LOAD.W	D4,#MAXVIT	SUB.W	D4,(A6)+OASVIT+OSCPOSV ; D4 <-- vitesse (-MAXVIT..+MAXVIT)	LOAD.W	(A4)+OHVIT,D4	LOAD.L	A4,#(A6)+OHEAD+OHTRK	LOAD.L	A3,#(A6)+OTRACK	LOAD.W	D4,#(NBTRACK*LT)-142$:	LOAD.B	(A4+),(A3+)	; header <-- OTRACK	DECJ.W,NMO D4,42$	LOAD.L	A4,#(A6)+OHEAD+OHTRK	CLR.W	D470$:	CALL	SYNTGET		; A3 <-- ^nom et D3 <-- numro	LOAD.W	(A4)+OTSNO,D3	LOAD.L	A1,#(A4)+OTSNA	LOAD.W	D3,#16-175$:	LOAD.B	(A1+),(A3+)	; header <-- nom des timbres	DECJ.W,NMO D3,75$	LOAD.L	A4,#(A4)+LT	INC.W	D4	COMP.W	D4,#NBTRACK	JUMP,LO 70$	POPM.L	D4,A1..A4	RET;--------\\; AJREP   >;--------/; Ajoute un ventuel nom de rpertoire.; in	A4.L	^nom avec rpertoire (#mm1:boogie.midi);	A3.L	^nom sans rpertoire (orgues.dx); out	A3.L	^nom construit       (#mm1:orgues.dx); mod	D7.W, A3.LAJREP:	PUSHM.L	D3,D4,A1,A2,A4	LOAD.L	A2,#(A6)+OBUNAME; Cherche s'il existe un nom de rpertoire dans le nom en (A4).	LOAD.L	A1,A4	CLR.L	D410$:	LOAD.B	D3,(A4+)	JUMP',EQ 15$	COMP.B	D3,#CR	JUMP',EQ 15$	COMP.B	D3,#':	JUMP,NE 10$	LOAD.L	D4,A4		; D4 <-- ^aprs dernier rep:	JUMP	10$15$:	TEST.L	D4		; trouv ":" dans le nom ?	JUMP',EQ 50$		; non => 50$; Met les rpertoires trouvs dans le buffer.30$:	LOAD.B	(A2+),(A1+)	; buffer <-- rpertoire(s)	COMP.L	A1,D4	JUMP,NE 30$; Met le nom dans le buffer.50$:	LOAD.B	D3,(A3+)	JUMP',EQ 55$	COMP.B	D3,#CR	JUMP',EQ 55$	LOAD.B	(A2+),D3	; buffer <-- nom	JUMP	50$55$:	CLR.B	(A2)		; buffer <-- terminateur	LOAD.L	A3,#(A6)+OBUNAME	POPM.L	D3,D4,A1,A2,A4	RET	.END