	.SBTTL	PARTPORTEE;-----------\\; MOVPORTEES >;===========/; Dplace la largeur des porte, ou les frontires entre; les portes.; in	-; out	-; mod	D7.WMOVPORTEES:	PUSHM.L	D0..D4,A2..A4	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LIB	?IFMOUSE	JUMP,NE 85$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP,LO 85$	LOAD.L	A3,#(A4)+OMELP	; A3 <-- ^premire porte	LOAD.W	D2,#MAXLP10$:	COMP.B	(A3)+OLPTYP,#ICOVIDE	JUMP',EQ 15$	LOAD.W	D1,(A3)+OLPDY	COMP.W	D4,D1		; est-on dans la porte ?	JUMP',LO 15$		; non => 15$	ADD.W	D1,#LYPORTEE*(NPORTEE-1)	COMP.W	D4,D1	JUMP',LS 20$		; oui => 20$	LOAD.W	D1,(A3)+OLPMAX	SUB.W	D1,#LYPORTEE/4	SUB.W	D1,#6	COMP.W	D4,D1		; est-on dans la flche ?	JUMP',LO 15$		; non => 15$	ADD.W	D1,#6+6	COMP.W	D4,D1	JUMP,LS 50$		; oui => 50$15$:	LOAD.L	A3,#(A3)+LLP	DEC.W	D2	JUMP,NE 10$	JUMP	85$; On est au bout de la porte et on modifie sa largeur.20$:	CALL	LMAXPORTEE	LOAD.W	D0,D4		; D4 <-- largeur minimale	CLR.L	D1	LOAD.W	D1,(A0)+ODFFDX	SUB.W	D1,#MXPORTEE*2	DIV.WU	D1,#LXPORTEE	MUL.WU	D1,#LXPORTEE	; D1 <-- largeur maximale30$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP,NE 40$		; non => 40$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 30$	SUB.W	D4,(A0)+ODFFX	; D4 <-- idem, dans la swdo	JUMP,LO 30$	SUB.W	D4,#MXPORTEE	JUMP,LO 30$	AND.L	D4,#H'FFFF	DIV.WU	D4,#LXPORTEE	MUL.WU	D4,#LXPORTEE	COMP.W	D4,D0	JUMP',HS 35$	LOAD.W	D4,D0		; D4 <-- minimum35$:	COMP.W	D4,D1	JUMP',LS 36$	LOAD.W	D4,D1		; D4 <-- maximum36$:	COMP.W	D4,(A4)+OMELG	; nouvelle largeur ?	JUMP,EQ 30$		; non => 30$				; oui =>	CALL	INVPORTEES	; efface les portes	LOAD.W	(A4)+OMELG,D4	CALL	INVPORTEES	; redessine les portes	JUMP	30$40$:;;?	LOAD.W	D0,(A6)+ONCLEF;;?	TEST.L	D0:#SKCGRILLE	; grille visible ?;;?	JUMP,BC 90$		; non => 90$	CALL	REDESSINE	; oui => redessine la mesure	JUMP	90$; Dplace la frontire infrieure d'une porte.50$:	LOAD.W	D0,(A3)+OLPDY	ADD.W	D0,#LYPORTEE*(NPORTEE-1)+LYPORTEE	LOAD.W	D1,#LYPORTEE*33	LOAD.L	A2,A355$:	LOAD.L	A2,#(A2)+LLP	; A2 <-- ^porte suivante	DEC.W	D2	JUMP',EQ 60$	COMP.B	(A2)+OLPTYP,#ICOVIDE	JUMP,EQ 55$	LOAD.W	D1,(A2)+OLPDY	SUB.W	D1,#LYPORTEE/260$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP,NE 70$		; non => 70$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 60$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- idem, dans la swdo	JUMP,LO 60$	ADD.W	D4,#LYPORTEE/4	AND.L	D4,#H'FFFF	DIV.WU	D4,#LYPORTEE/2	MUL.WU	D4,#LYPORTEE/2	COMP.W	D4,D0	JUMP',HS 65$	LOAD.W	D4,D0		; D4 <-- minimum65$:	COMP.W	D4,D1	JUMP',LS 66$	LOAD.W	D4,D1		; D4 <-- maximum66$:	COMP.W	D4,(A3)+OLPMAX	; nouvelle frontire ?	JUMP,EQ 60$		; non => 60$				; oui =>	PUSH.W	D2	LIB	?BUCAR		; mode rapide	LOAD.W	D2,#CLRDOT	; D2 <-- mode de dessin	CALL	SEPPORTEE	; efface la flche	LOAD.W	(A3)+OLPMAX,D4	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CALL	SEPPORTEE	; redessine la flche	LIB	?NOBUCAR	; remet mode normal	POP.W	D2	JUMP	60$70$:	LOAD.W	D4,(A3)+OLPMAX	TEST.W	D2		; dernire mesure ?	JUMP',EQ 75$		; oui => 75$	LOAD.W	(A2)+OLPMIN,D4	; mj minimum porte suivante	JUMP'	80$75$:	LOAD.W	(A4)+OMEMAX,D4	; mj maximum gnral80$:	CALL	REDESSINE	; redessine la mesure	JUMP'	90$85$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit90$:	POPM.L	D0..D4,A2..A4	RET;-----------\\; LMAXPORTEE >;===========/; Cherche la largeur maximale d'une porte.; in	-; out	D4.W	largeur maximale; mod	D4.L, D7.WLMAXPORTEE:	PUSHM.L	D2,D3,A4	CALL	PUTTEXTE	; texte en dition --> mesure courante (si ncessaire)	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	CLR.W	D2		; D2 <-- largeur maximale20$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 80$	LOAD.B	D3,(A4)		; D3 <-- code	COMP.B	D3,#OBJMES	; dbut mesure suivante ?	JUMP',EQ 80$		; oui => 80$				; non =>	CALL	DIMOBJET	; D3 <-- P1 et D4 <-- P2	JUMP,NE 20$	SUB.W	D4,#MXPORTEE	; D4 <-- maximum depuis le dbut	JUMP,LO 20$	COMP.W	D2,D4	JUMP,HS 20$	LOAD.W	D2,D4		; D2 <-- largeur maximale	JUMP	20$80$:	CLR.L	D4	LOAD.W	D4,D2	ADD.W	D4,#LXPORTEE*2	; D4 <-- petite marge	DIV.WU	D4,#LXPORTEE	MUL.WU	D4,#LXPORTEE	; D4 <-- arrondi	COMP.W	D4,#MXFIXE+LXPORTEE*4 ; trop peu ?	JUMP',HS 85$	LOAD.W	D4,#MXFIXE+LXPORTEE*4 ; D4 <-- largeur minimale85$:	CLR.L	D3	LOAD.W	D3,(A0)+ODFFDX	SUB.W	D3,#MXPORTEE*2	DIV.WU	D3,#LXPORTEE	MUL.WU	D3,#LXPORTEE	; D3 <-- largeur maximale	COMP.W	D4,D3		; trop ?	JUMP',LS 90$		; non => 90$	LOAD.W	D4,D3		; D4 <-- largeur maximale90$:	POPM.L	D2,D3,A4	RET;-----------\\; DESPORTEES >;===========/; Dessine toutes les portes.; in	-; out	-; mod	D7.WDESPORTEES:	PUSHM.L	D1..D3,A3,A4	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LOAD.L	A3,#(A4)+OMELP	; A3 <-- ^table des portes	LOAD.W	D1,#MAXLP10$:	CALL	ONEPORTEE	; dessine une porte complte	LOAD.L	A3,#(A3)+LLP	; A4 <-- ^porte suivante	DEC.W	D1	JUMP,NE 10$	CALL	PARPORTEE	; dessine les parties 1. 2. ou 3.	POPM.L	D1..D3,A3,A4	RET;-----------\\; INVPORTEES >;===========/; Inverse toutes les lignes dans les portes.; in	-; out	-; mod	D7.WINVPORTEES:	PUSHM.L	D1..D4,A3,A4	LIB	?BUCAR		; mode rapide	LOAD.W	D2,#INVDOT	; D2 <-- mode de dessin	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LOAD.L	A3,#(A4)+OMELP	; A3 <-- ^table des portes	LOAD.W	D1,#MAXLP10$:	COMP.B	(A3)+OLPTYP,#ICOVIDE ; porte existe ?	JUMP',EQ 50$		; non => 50$				; oui =>	LOAD.W	D4,(A3)+OLPDY	CALL	UNEPORTEE	; inverse la porte vide50$:	LOAD.L	A3,#(A3)+LLP	; A4 <-- ^porte suivante	DEC.W	D1	JUMP,NE 10$	LIB	?NOBUCAR	; remet le mode normal	POPM.L	D1..D4,A3,A4	RET;----------\\; ONEPORTEE >;==========/; Dessine une porte complte.; in	A3.L	^description de la porte;	A4.L	^description de la mesure;	D2.W	mode de dessin; out	-; mod	D7.WONEPORTEE:	PUSHM.L	D0,D3,D4	COMP.B	(A3)+OLPTYP,#ICOVIDE ; porte existe ?	JUMP',EQ 90$		; non => 90$				; oui =>	LOAD.W	D4,(A3)+OLPDY	CALL	UNEPORTEE	; dessine la porte vide	LOAD.W	D0,(A6)+ONCLEF	TEST.L	D0:#SKCGRILLE	; grille visible ?	JUMP',BC 20$		; non => 20$	CALL	GRILLE		; oui => dessine la grille de points20$:	SWAP.W	D4		; D4 <-- <yy>	LOAD.W	D4,#MXPORTEE	; D4 <-- <xx>	COMP.B	(A3)+OLPTYP,#ICOPSOL	JUMP',NE 30$				; clef de sol =>	LOAD.B	D3,#ICOSOLH	CALL	DESONESYMB	LOAD.B	D3,#ICOSOLB	CALL	DESONESYMB	JUMP'	90$30$:				; clef de fa =>	LOAD.B	D3,#ICOFA	CALL	DESONESYMB90$:	POPM.L	D0,D3,D4	RET;----------\\; REPPORTEE >;----------/; Dessine les signes de reprise sur le dessus de la premire porte.; in	A4.L	^description de la mesure;	D2.W	mode de dessin; out	-; mod	D7.WREPPORTEE:	PUSHM.L	D1..D4	COMP.B	D2,#SETDOT	JUMP,NE 90$	LOAD.L	D1,(A4)+OMEREP	; D1 <-- signes de reprise; Dessine le dbut de la reprise.	LOAD.B	D3,#ICOSPART1	TEST.L	D1:#BREPPART1	JUMP',BS 10$	LOAD.B	D3,#ICOSPART2	TEST.L	D1:#BREPPART2	JUMP',BS 10$	LOAD.B	D3,#ICOSPART3	TEST.L	D1:#BREPPART3	JUMP',BC 40$10$:	LOAD.W	D4,#GCICT-GCICB+2	SWAP.W	D4	LOAD.W	D4,#MXPORTEE+MXFIXE-LXPORTEE-5+4	TSET.L	D3:#7		; D3 <-- icne dans ISP33	CALL	DESONESYMB; Dessine le signe au dbut de la mesure.40$:	LOAD.B	D3,#ICOSRENVOI	TEST.L	D1:#BREPRENVOI1	JUMP',BS 42$	LOAD.B	D3,#ICOSCODA	TEST.L	D1:#BREPCODA1	JUMP',BC 50$42$:	LOAD.W	D4,(A4)+OMELP+OLPDY	SUB.W	D4,#GCICB	SWAP.W	D4	LOAD.W	D4,#MXPORTEE+MXFIXE-LXPORTEE-5+16	TSET.L	D3:#7		; D3 <-- icne dans ISP33	CALL	DESONESYMB; Dessine le signe  la fin de la mesure.50$:	LOAD.B	D3,#ICOSRENVOI	TEST.L	D1:#BREPRENVOI2	JUMP',BS 52$	LOAD.B	D3,#ICOSCODA	TEST.L	D1:#BREPCODA2	JUMP',BS 52$	LOAD.B	D3,#ICOSDC	TEST.L	D1:#BREPDC	JUMP',BS 52$	LOAD.B	D3,#ICOSFIN	TEST.L	D1:#BREPFIN	JUMP',BC 60$52$:	LOAD.W	D4,(A4)+OMELP+OLPDY	SUB.W	D4,#GCICB	SWAP.W	D4	LOAD.W	D4,(A4)+OMELG	ADD.W	D4,#MXPORTEE-LXICONE-16	TSET.L	D3:#7		; D3 <-- icne dans ISP33	CALL	DESONESYMB; Dessine les indications saute/ici A..D.60$:	TEST.B	(A6)+OFLAGS:#BPRINT ; impression en cours ?	JUMP,BS 70$		; oui => 70$	LOAD.B	D4,#'1	TEST.L	D1:#BREP_1X	JUMP',BS 62$	LOAD.B	D4,#'2	TEST.L	D1:#BREP_2X	JUMP',BS 62$	LOAD.B	D4,#'3	TEST.L	D1:#BREP_3X	JUMP',BS 62$	LOAD.B	D4,#'4	TEST.L	D1:#BREP_4X	JUMP,BC 70$62$:	CLR.L	D3	LIB	?SETCURS	TEST.L	D1:#BREPGOTO	JUMP',BS 64$	LIB	?AFTIM	.ASCIZ	" Ici = "	.EVEN	JUMP'	66$64$:	LIB	?AFTIM	.ASCIZ	" Saute  "	.EVEN66$:	LOAD.B	D3,D4	LIB	?AFCAR		; affiche "1".."4"	LOAD.B	D3,#'x	LIB	?AFCAR70$:90$:	POPM.L	D1..D4	RET;----------\\; PARPORTEE >;----------/; Dessine les barres des parties 1. 2. ou 3. (sans les chiffres).; in	A4.L	^description de la mesure;	D2.W	mode de dessin; out	-; mod	D7.WPARPORTEE:	PUSHM.L	D0..D4	CLR.B	D0	LOAD.L	D1,(A4)+OMEREP	; D1 <-- signes de reprise; Dessine le dbut de la reprise.	LOAD.B	D3,#ICOSPART1	TEST.L	D1:#BREPPART1	JUMP',BS 10$	LOAD.B	D3,#ICOSPART2	TEST.L	D1:#BREPPART2	JUMP',BS 10$	LOAD.B	D3,#ICOSPART3	TEST.L	D1:#BREPPART3	JUMP',BC 20$10$:	LOAD.W	D3,#2+4	LOAD.W	D4,(A4)+OMELP+OLPDY	SUB.W	D4,#4	SUB.W	D4,D3	JUMP',LE 18$	SWAP.W	D4	SWAP.W	D3	LOAD.W	D3,#MXPORTEE+MXFIXE-LXPORTEE-5+4	CLR.W	D4	LIB	?DRSEG18$:	TSET.L	D1:#BREPPARTM	; D1 <-- faudra dessiner le milieu !	TSET.L	D0:#0		; D0 <-- dbut dessin; Dessine la fin de la reprise.20$:	LOAD.B	D3,#ICOSPARTF	TEST.L	D1:#BREPPARTF	JUMP',BC 30$	LOAD.W	D3,#2+4	LOAD.W	D4,(A4)+OMELP+OLPDY	SUB.W	D4,#4	SUB.W	D4,D3	JUMP',LE 28$	SWAP.W	D4	SWAP.W	D3	LOAD.W	D3,(A4)+OMELG	ADD.W	D3,#MXPORTEE-LXICONE-4	ADD.W	D3,#LXICONE-1	CLR.W	D4	LIB	?DRSEG28$:	TSET.L	D1:#BREPPARTM	; D1 <-- faudra dessiner le milieu !	TSET.L	D0:#1		; D0 <-- fin dessine; Dessine le milieu de la reprise.30$:	TEST.L	D1:#BREPPARTM	JUMP',BC 40$	LOAD.W	D3,#2+4	SWAP.W	D3	LOAD.W	D3,#MXPORTEE+MXFIXE-LXPORTEE-5+4	CLR.L	D4	LOAD.W	D4,(A4)+OMELG	ADD.W	D4,#MXPORTEE-4	SUB.W	D4,D3	TEST.L	D0:#0		; D0 <-- dbut dessin	JUMP',BS 34$		; oui => 34$	SUB.W	D3,#4	ADD.W	D4,#4		; D3/D4 <-- allonge vers la gauche34$:	TEST.L	D0:#1		; D0 <-- fin dessine	JUMP',BS 35$		; oui => 35$	ADD.W	D4,#4		; D3/D4 <-- allonge vers la droite35$:	LIB	?DRSEG40$:90$:	POPM.L	D0..D4	RET;----------\\; UNEPORTEE >;----------/; Dessine une porte avec deux lignes verticales au dbut; et  la fin.; in	A3.L	^description de la porte;	A4.L	^description de la mesure;	D2.W	mode de dessin; out	-; mod	D7.WUNEPORTEE:	PUSHM.L	D0..D4; Dessine les 5 lignes horizontales principales de la porte.	LOAD.W	D3,(A3)+OLPDY	; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D3,#MXPORTEE	; D3 <-- <xx>	LOAD.L	D0,D3	CLR.L	D4		; D4 <-- <dyy>	LOAD.W	D4,(A4)+OMELG	; D4 <-- <dxx>	LOAD.W	D1,#NPORTEE-1	; D1 <-- -1  cause NMO20$:	PUSH.L	D3	LIB	?DRSEG		; dessine 5 lignes -----	POP.L	D3	SWAP.W	D3	ADD.W	D3,#LYPORTEE	SWAP.W	D3	DECJ.W,NMO D1,20$; Dessine les lignes verticales, ventuellement paisses s'il; y a des signes de reprise.	LOAD.L	D1,(A4)+OMEREP	; D1 <-- signes de reprise	CALL	HTYPORTEE	; D4 <-- dimensions des traits verticaux	LOAD.L	D3,D0	PUSH.L	D3	LIB	?DRSEG		; dessine ligne | tout  gauche	POP.L	D3	SWAP.W	D2	LOAD.B	D2,#B'11110001	LOAD.B	D0,#ICOSDBP	TEST.L	D1:#BREPDBP	JUMP',BS 30$	CLR.B	D0	TEST.L	D1:#BREPDB	JUMP',BS 30$	LOAD.B	D2,#B'00001000	TEST.L	D1:#BREPB	JUMP',BC 35$30$:	SWAP.W	D2	LOAD.W	D3,#MXPORTEE+MXFIXE-LXPORTEE-5	PUSH.L	D3	CALL	LIVPORTEE	; dessine ligne |  gauche	POP.L	D3	SWAP.W	D235$:;	SWAP.W	D2;	SWAP.W	D2	LOAD.B	D2,#B'10001111	LOAD.B	D0,#ICOSBDP	TEST.L	D1:#BREPBDP	JUMP',BS 40$	CLR.B	D0	TEST.L	D1:#BREPBD	JUMP',BS 40$	LOAD.B	D2,#B'00100001	TEST.L	D1:#BREPBB	JUMP',BS 40$	LOAD.B	D2,#B'0000000140$:	SWAP.W	D2	LOAD.W	D3,(A4)+OMELG	ADD.W	D3,#MXPORTEE-7	CALL	LIVPORTEE	; dessine ligne |  droite; Dessine la frontire infrieure.	CALL	SEPPORTEE	POPM.L	D0..D4	RET;----------\\; HTYPORTEE >;----------/; Calcul la hauteur pour les barres verticales. Si la porte; en dessous existe, et qu'il faut lier jusque l, calcul la; hauteur correctement.; in	A3.L	^description de la porte;	A4.L	^description de la mesure; out	D4.L	dimensions (dy;dx); mod	D4.L, D7.WHTYPORTEE:	PUSHM.L	D2,D3,A3,A4	LOAD.W	D4,#(LYPORTEE*(NPORTEE-1))+1	TEST.B	(A3)+OLPLIE	; li  la porte en dessous ?	JUMP,F	80$		; non => 80$	LOAD.L	A4,#(A4)+OMELP	; A4 <-- ^premire porte	LOAD.L	D3,A3	SUB.L	D3,A4	DIV.WU	D3,#LLP		; D3 <-- rang porte (0..2)	LOAD.W	D2,(A3)+OLPDY20$:	LOAD.L	A3,#(A3)+LLP	; A3 <-- ^porte suivante	INC.W	D3	COMP.W	D3,#MAXLP	JUMP',EQ 80$	COMP.B	(A3)+OLPTYP,#ICOVIDE	JUMP,EQ 20$	LOAD.W	D4,(A3)+OLPDY	SUB.W	D4,D2		; D4 <-- hauteur jusqu' la porte suivante80$:	SWAP.W	D4	CLR.W	D4		; D4 <-- largeur (nulle car vertical)	POPM.L	D2,D3,A3,A4	RET;----------\\; SEPPORTEE >;----------/; Dessine le sparateur infrieur, c'est--dire jusqu'; la porte en dessous sous la forme d'une flche "<--".; in	A3.L	^description de la porte;	A4.L	^description de la mesure;	D2.W	mode de dessin; out	-; mod	D7.WSEPPORTEE:	PUSHM.L	D3,D4,A2..A4	LOAD.W	D3,(A3)+OLPMAX	SUB.W	D3,#LYPORTEE/4	SWAP.W	D3	LOAD.W	D3,#MXPORTEE+1	ADD.W	D3,(A4)+OMELG	LOAD.L	A4,#(A4)+OMELP	LOAD.L	D4,A3	SUB.L	D4,A4	DIV.WU	D4,#LLP		; D4 <-- rang porte (0..MAXLP-1)	LOAD.L	A2,#R16"TAFLLEFTH30$:	INC.W	D4	COMP.W	D4,#MAXLP	; encore une porte aprs ?	JUMP',EQ 50$		; non => 50$	LOAD.L	A3,#(A3)+LLP	COMP.B	(A3)+OLPTYP,#ICOVIDE ; encore une porte utilise ?	JUMP,EQ 30$		; non => 30$				; oui =>	LOAD.L	A2,#R16"TAFLLEFT50$:	LOAD.L	A3,A2		; A3 <-- ^motif  dessiner	CALL	DESMOTIF	; dessine une flche  gauche	POPM.L	D3,D4,A2..A4	RET;----------\\; LIVPORTEE >;----------/; Dessine une ligne verticale, ventuellement paisse.;	        |-------|-------|-------|-------|;	D2.L    |       |  map  |       |  mode |;	        |-------|-------|-------|-------|;	                 |     |;	              gauche droite; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D2.L	map/mode;	D0.B	icne du signe/zro; out	D3.L	nouvelle origine; mod	D3.L, D7.WLIVPORTEE:	PUSHM.L	D1,D5	LOAD.W	D5,#8-1		; D5 <-- -1  cause NMO	LOAD.L	D1,D2	SWAP.W	D1		; D1 <-- map10$:	RL.B	D1,#1	JUMP',CC 20$	PUSH.L	D3	LIB	?DRSEG		; dessine un trait	POP.L	D320$:	INC.W	D3	DECJ.W,NMO D5,10$	SUB.W	D3,#8	TEST.B	D0		; faut-il dessiner une icne ?	JUMP',EQ 40$		; non => 40$				; oui =>	COMP.B	D2,#SETDOT	JUMP',NE 40$	PUSHM.L	D3,D4	LOAD.L	D4,D3	ADD.W	D4,#-12	SWAP.W	D4	ADD.W	D4,#GCICT-GCICB+1	SWAP.W	D4	LOAD.B	D3,D0	TSET.L	D3:#7		; D3 <-- icne dans ISP33	CALL	DESONESYMB	; dessine l'icne	POPM.L	D3,D440$:	ADD.W	D3,D4		; D3 <-- origine suivante en X	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- origine suivante en Y	SWAP.W	D3	SWAP.W	D4	POPM.L	D1,D5	RET;--------\\; GRILLE  >;========/; Affiche une grille de points ratachs  une porte.; in	A3.L	^description de la porte;	A4.L	^description de la mesure; out	-; mod	D7.WGRILLE:	PUSHM.L	D0..D4,A0..A2	CALL	CCMO		; enlve la souris	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADQDOT	; A1 <-- adresse de GRA_QXDOT	CLR.L	D3	LOAD.W	D3,(A4)+OMELG	; D3 <-- largeur de la mesure	SUB.W	D3,#MXFIXE	DIV.WU	D3,(A6)+OLXPORT;;?	INC.W	D3		; D3 <-- nb de points horizontalement	CLR.L	D4	LOAD.W	D4,(A3)+OLPMIN	ADD.W	D4,#LYPORTEE/2	DIV.WU	D4,#LYPORTEE	MUL.WU	D4,#LYPORTEE	; D4 <-- arrondi au demi-pas suprieur	SWAP.W	D4	LOAD.W	D4,#MXPORTEE+MXFIXE	SWAP.W	D4	CLR.L	D2	LOAD.W	D2,D4	SUB.W	D2,(A3)+OLPDY	NEG.W	D2	DIV.WU	D2,#LYPORTEE	TEST.W	D2	JUMP',LE 29$20$:	PUSHM.L	D3,D4	SWAP.W	D4		; D4 <-- coordonne habituelle (y;x)	DEC.W	D3		;  cause du test NMO25$:	CALL	(A1)		; appel de GRA_QXDOT	TSET.B	(A0):D0		; allume un point	ADD.W	D4,(A6)+OLXPORT	DECJ.W,NMO D3,25$	POPM.L	D3,D4	ADD.W	D4,#LYPORTEE	DEC.W	D2	JUMP,NE 20$29$:	LOAD.W	D4,#MXPORTEE+MXFIXE	SWAP.W	D4	LOAD.W	D4,(A3)+OLPDY	ADD.W	D4,#LYPORTEE*NPORTEE	CLR.L	D2	LOAD.W	D2,D4	SUB.W	D2,(A3)+OLPMAX	NEG.W	D2	DIV.WU	D2,#LYPORTEE	LOAD.L	D1,D2	SWAP.W	D1	TEST.W	D1		; reste qq chose ?	JUMP',EQ 45$		; non => 45$	INC.W	D2		; oui => arrondi suprieur45$:	TEST.W	D2	JUMP',LE 59$50$:	PUSHM.L	D3,D4	SWAP.W	D4		; D4 <-- coordonne habituelle (y;x)	DEC.W	D3		;  cause du test NMO55$:	CALL	(A1)		; appel de GRA_QXDOT	TSET.B	(A0):D0		; allume un point	ADD.W	D4,(A6)+OLXPORT	DECJ.W,NMO D3,55$	POPM.L	D3,D4	ADD.W	D4,#LYPORTEE	DEC.W	D2	JUMP,NE 50$59$:	CALL	SCMO		; remet la souris	POPM.L	D0..D4,A0..A2	RET;------------\\; ALTERATIONS >;============/; Dessine toutes les altrations.; in	D2.W	mode de dessin; out	-; mod	D7.WALTERATIONS:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LOAD.L	A3,#(A4)+OMELP	; A3 <-- ^table des portes	LOAD.W	D3,#MAXLP10$:	COMP.B	(A3)+OLPTYP,#ICOVIDE ; porte existe ?	JUMP',EQ 50$		; non => 50$				; oui =>	CALL	ALTPORTEE50$:	LOAD.L	A3,#(A3)+LLP	; A4 <-- ^porte suivante	DEC.W	D3	JUMP,NE 10$	POPM.L	D3,D4,A3,A4	RET;----------\\; ALTPORTEE >;----------/; Dessine l'altration d'une porte.; in	A3.L	^description de la porte;	A4.L	^description de la mesure;	D2.W	mode de dessin; out	-; mod	D7.WALTPORTEE:	PUSHM.L	D0..D4,A4	LOAD.B	D0,(A4)+OMETA	; D0 <-- #/b	LOAD.B	D1,(A4)+OMENA	; D1 <-- 0..7	JUMP,EQ 90$	LOAD.L	A4,#R16"TALTBSOL ; A4 <-- ^si b/sol	COMP.B	D0,#ICOBEMOL	JUMP',EQ 10$	LOAD.L	A4,#R16"TALTDSOL ; A4 <-- ^si #/sol10$:	COMP.B	(A3)+OLPTYP,#ICOPSOL	JUMP',EQ 20$	LOAD.L	A4,#R16"TALTBFA ; A4 <-- ^si b/fa	COMP.B	D0,#ICOBEMOL	JUMP',EQ 20$	LOAD.L	A4,#R16"TALTDFA ; A4 <-- ^si #/fa20$:	LOAD.B	D3,D0		; D3 <-- ICOBEMOL/ICODIESE	LOAD.W	D4,(A3)+OLPDY	; D4 <-- <yy>	SWAP.W	D4	LOAD.W	D4,#MXPORTEE+12+LXICONE+16 ; D4 <-- <xx>40$:	TEST.B	D1		; encore une altration ?	JUMP',EQ 90$		; non => 90$				; oui =>	PUSH.L	D4	LOAD.W	D0,(A4+)	; D0 <-- distance contre en bas	MUL.WA	D0,#LYPORTEE/2	SWAP.W	D4	ADD.W	D4,D0		; D4 <-- <yy> de l'altration	SWAP.W	D4	CALL	DESONESYMB	; dessine un #/b	POP.L	D4	ADD.W	D4,#10		; D4 <-- <xx> suivant	DEC.B	D1	JUMP	40$90$:	POPM.L	D0..D4,A4	RET; Ces tables donnent la distance contre en bas depuis le haut; de chaque clef :TALTBSOL:			; b/sol :	.W	4,1,5,2,6,3,7	; si-mi-la-r-sol-do-faTALTBFA:			; b/fa :	.W	6,3,7,4,8,5,2	; si-mi-la-r-sol-do-faTALTDSOL:			; #/sol :	.W	0,3,-1,2,5,1,4	; fa-do-sol-r-la-mi-siTALTDFA:			; #/fa :	.W	2,5,1,4,7,3,6	; fa-do-sol-r-la-mi-si;-----------\\; FRONTIERES >;===========/; Recalcul les frontires entre toutes les portes.; in	A4.L	^description de la porte; out	-; mod	D7.WFRONTIERES:	PUSHM.L	D3,D4,A2,A3	LOAD.L	A3,#(A4)+OMELP	; A3 <-- ^premire mesure	LOAD.W	D4,#MAXLP	; D4 <-- nb max de mesures10$:	COMP.B	(A3)+OLPTYP,#ICOVIDE ; mesure existe ?	JUMP',NE 15$		; oui => 15$	LOAD.L	A3,#(A3)+LLP	; A3 <-- ^mesure suivante	DEC.W	D4	JUMP,NE 10$	JUMP'	90$		; si aucune mesure => 90$15$:	LOAD.W	(A3)+OLPMIN,(A4)+OMEMIN30$:	LOAD.L	A2,A335$:	DEC.W	D4	JUMP',EQ 60$	LOAD.L	A2,#(A2)+LLP	; A2 <-- ^mesure suivante	COMP.B	(A2)+OLPTYP,#ICOVIDE ; mesure suivante existe ?	JUMP,EQ 35$		; non => 35$				; oui =>	CLR.L	D3	LOAD.W	D3,(A2)+OLPDY	SUB.W	D3,(A3)+OLPDY	; D3 <-- distance jusqu' la porte suivante	SUB.W	D3,#(NPORTEE-1)*LYPORTEE	SR.W	D3,#1	ADD.W	D3,#(NPORTEE-1)*LYPORTEE	ADD.W	D3,(A3)+OLPDY	DIV.WU	D3,#LYPORTEE	MUL.WU	D3,#LYPORTEE	LOAD.W	(A3)+OLPMAX,D3	LOAD.W	(A2)+OLPMIN,D3	LOAD.L	A3,A2		; A3 <-- ^mesure suivante	JUMP	30$60$:	LOAD.W	(A3)+OLPMAX,(A4)+OMEMAX90$:	POPM.L	D3,D4,A2,A3	RET	.END