	.TITLE	ACCORD.ASC;	--------------------------------------;		(C) 1988 - Daniel Roux;	--------------------------------------;	Date		Amliorations; -----------------------------------------------------------------------	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULESMAJREV	=	1		; rvisionMINREV	=	2		; version	.REV	MAJREV,MINREV	.CODE	800,11,B'1111,600,2000,300,2000,2,'I,'A,'F,09	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------PXNOTE	=	24		; position pour les notesPYNOTE	=	30		; position pour les notesDXNOTEB	=	24		; largeur d'une note blancheDYNOTEB	=	100		; hauteur d'une note blancheDXNOTEN	=	15		; largeur d'une note noireDYNOTEN	=	60		; hauteur d'une note noireDXNOTEC	=	3		; dcalage pour les noiresNBOCTAVE=	3		; nb d'octavesNBNOTES	=	NBOCTAVE*12	; nb de notesKEYDBOX	=	H'7E00		; "touche" pour dbox; Caractres IAF09; ----------------CARMITAL=	34		; m italiqueCARDIESE=	35		; #CARBEMOL=	36		; bCARCINQ	=	37		; 5CARSIX	=	38		; 6CARSEPT	=	39		; 7CARNEUF	=	40		; 9CARPLUS	=	41		; +CARMOINS=	42		; -; Fanions; -------BFADO	=	0		; doBFADORE	=	1		; BFARE	=	2		; rBFAREMI	=	3		; BFAMI	=	4		; miBFAFA	=	5		; faBFAFASOL=	6		; BFASOL	=	7		; solBFASOLLA=	8		; BFALA	=	9		; laBFALASI	=	10		; BFASI	=	11		; siBFAMIN	=	12		; mineurBFA5AUG	=	13		; 5 augBFA6EME	=	14		; 6BFA7DIM	=	15		; 7 dimBFA7EME	=	16		; 7BFA7MAJ	=	17		; 7 MAJBFA9EME	=	18		; 9BFADIESE=	19		; #BFABEMOL=	20		; bBFAFRENCH=	21		; DOBFAENGLISH=	22		; CBFAR0	=	23		; RBFAR1	=	24		; 1BFAR2	=	25		; 2BFAR3	=	26		; 3BFASILENCE=	27		; silenceBFAACCORD=	28		; accordBFAARPEGE=	29		; arpge; Variables; ---------	.LOC	0OPLCOM:	.BLKB	4		; ^ligne de commandeOCHDBOX:.BLKB	2		; canal module DBOXOPDDIS:	.BLKB	4		; ^descripteur de la fentreOQXDOT:	.BLKB	4		; adresse de GRA_QXDOTONOWDO:	.BLKB	2		; no swdo pour la dbox principaleOBUDIS:	.BLKB	100		; buffer write displayOBUPLAY:.BLKB	8*10		; buffer write synthesizerONOTE1:	.BLKB	2		; ONOTE2:	.BLKB	2		; ONOTE3:	.BLKB	2		; ONOTE4:	.BLKB	2		; ONOTE5:	.BLKB	2		; OLAST1:	.BLKB	2		; OLAST2:	.BLKB	2		; OLAST3:	.BLKB	2		; OLAST4:	.BLKB	2		; OLAST5:	.BLKB	2		; LGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	LIB	?AFTIM	.B	NOCURS	.B	0	.EVEN	LOAD.W	D3,#3	LIB	?MOUSE	LOAD.L	A2,A3		; A2 <-- ^ligne de commande	LOAD.L	A3,#R16"TXERFATMEM	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.W	D4	JUMP,NE 10$	LOAD.L	(A6)+OPLCOM,A2	; mm ^ligne de commande; Initialise l'environnement par dfaut.	LOAD.L	A3,#R16"TXERFATDIS	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OQXDOT,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHDBOX,D1	LOAD.W	D4,#50*4	NTREL	?DELMS		; laisse admirer l'image ...	LOAD.B	D3,#EOP	LIB	?AFCAR	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise toute la fentre	LOAD.B	D3,#VSPACE	LIB	?AFCAR	LOAD.W	D3,(A0)+ODFCY	SR.W	D3,#1	NEG.W	D3	LIB	?AFCAR		; diminue l'interligne	LOAD.L	A2,#R16"TDBOX_PRINC	CLR.W	D2	LOAD.L	D4,#2^BFADO!2^BFADIESE!2^BFAFRENCH!2^BFAR0!2^BFAACCORD	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	ERFAT	CALL	DESNOTES	; dessine toutes les notes	CALL	AFFNOTES	; dessine les noms des notes	LOAD.W	D2,#200	LOAD.W	D1,#7*2	LOAD.L	A3,#R16"TXACC	CALL	DESRECT	LOAD.W	D2,#202	LOAD.W	D1,#7*2	LOAD.L	A3,#R16"TXTEN	CALL	DESRECT	LOAD.W	D2,#204	LOAD.W	D1,#4*2	LOAD.L	A3,#R16"TXREN	CALL	DESRECT	LOAD.W	D2,#206	LOAD.W	D1,#7*2	LOAD.L	A3,#R16"TXMOD	CALL	DESRECT	LOAD.W	(A6)+OLAST1,#-1000	LOAD.W	(A6)+OLAST2,#-1000	LOAD.W	(A6)+OLAST3,#-1000	LOAD.W	(A6)+OLAST4,#-1000	LOAD.W	(A6)+OLAST5,#-1000	LOAD.L	D0,D4	CALL	DESACCORD	CALL	AFFACCORDLOOP:	COMP.L	D4,D0		; accord chang ?	JUMP,EQ 10$		; non => 10$				; oui =>	LOAD.L	D0,D4	CALL	DESACCORD	; dessine le nouvel accord	CALL	AFFACCORD	CALL	PLAYACCORD10$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_PRINC	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP		; oui => LOOP	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC	COMP.W	D3,#END	JUMP,EQ QUITTE	COMP.W	D3,#CLEAR	JUMP,EQ EFFACE	COMP.W	D3,#SPACE	JUMP,EQ PLAY	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ MODIFBIP:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPCLIC:	PUSH.L	D4	CALL	IFMOUSE	JUMP,NE 90$	CALL	DETNOTES	; D2 <-- note o est la souris	JUMP,NE 90$	CALL	INVNOTE		; allume la premire note	LOAD.W	D1,D210$:	LIB	?GETKEY	COMP.W	D3,#KEYMPO	JUMP,NE 50$	CALL	IFMOUSE	JUMP,NE 10$	CALL	DETNOTES	; D2 <-- note o est la souris	COMP.W	D2,D1	JUMP,EQ 10$	EX.L	D1,D2	CALL	INVNOTE		; teint l'ancienne note	LOAD.W	D2,D1	CALL	INVNOTE		; allume la nouvelle note	JUMP	10$50$:	LOAD.W	D2,D1	CALL	INVNOTE		; teint la dernire note	POP.L	D4	TEST.W	D2	JUMP,NS LOOP	AND.L	D2,#H'FFFF	DIV.WU	D2,#12	SWAP.W	D2		; D2 <-- 0..11	AND.L	D4,#H'FFFFF000	TSET.L	D4:D2	JUMP	LOOP90$:	POP.L	D4	JUMP	BIPPLAY:	CALL	PLAYACCORD	JUMP	LOOPEFFACE:	TCLR.L	D4:#BFAMIN	TCLR.L	D4:#BFA5AUG	TCLR.L	D4:#BFA6EME	TCLR.L	D4:#BFA7DIM	TCLR.L	D4:#BFA7EME	TCLR.L	D4:#BFA7MAJ	TCLR.L	D4:#BFA9EME	TSET.L	D4:#BFAR0	TCLR.L	D4:#BFAR1	TCLR.L	D4:#BFAR2	TCLR.L	D4:#BFAR3	JUMP	LOOPMODIF:	COMP.B	D3,#BFAMIN	JUMP,EQ 70$	COMP.B	D3,#BFASI	JUMP,LS 10$	COMP.B	D3,#BFA9EME	JUMP,LS 20$	COMP.B	D3,#BFABEMOL	JUMP,LS 30$	COMP.B	D3,#BFAENGLISH	JUMP,LS 40$	COMP.B	D3,#BFAR3	JUMP,LS 50$	COMP.B	D3,#BFAARPEGE	JUMP,LS 60$	JUMP	LOOP10$:	AND.L	D4,#H'FFFFF000	TSET.L	D4:D3	JUMP	LOOP20$:	TCLR.L	D4:D3	JUMP,BC LOOP	AND.L	D4,#-1-2^BFA5AUG-2^BFA6EME-2^BFA7DIM-2^BFA7EME-2^BFA7MAJ-2^BFA9EME	TSET.L	D4:D3	JUMP	LOOP30$:	AND.L	D4,#-1-2^BFADIESE-2^BFABEMOL	TSET.L	D4:D3	CALL	AFFNOTES	; dessine les noms des notes	JUMP	LOOP40$:	AND.L	D4,#-1-2^BFAFRENCH-2^BFAENGLISH	TSET.L	D4:D3	CALL	AFFNOTES	; dessine les noms des notes	JUMP	LOOP50$:	AND.L	D4,#-1-2^BFAR0-2^BFAR1-2^BFAR2-2^BFAR3	TSET.L	D4:D3	CALL	AFFNOTES	; dessine les noms des notes	JUMP	LOOP60$:	AND.L	D4,#-1-2^BFASILENCE-2^BFAACCORD-2^BFAARPEGE	TSET.L	D4:D3	JUMP	LOOP70$:	JUMP	LOOPQUITTE:	DBOX_	CLOSE		; ferme la DBOX	JUMP	RETOURERFAT2:	LOAD.L	A3,A2ERFAT:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT	LIB	?AFCR	POP.W	D7	LIB	?AFERROR	LIB	?AFCR	LIB	?GETCAR		; attend une touche ...RETOUR:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LIB	?CLOLIB	FOS	?STOP;--------\\; DESRECT >;========/; Dessine un rectangle englobant qq boutons.; in	D2.W	rang du premier objet;	D1.W	nb de lignes;	A3.L	^texte; out	-; mod	D7.WDESRECT:	PUSHM.L	D2..D4,A3,A4	TSET.L	D2:#BDBGCLABEL	DBOX_	GETCO	PUSH.L	D3	INC.W	D2	DBOX_	GETCO	LOAD.L	D4,D3	POP.L	D3	SUB.W	D4,D3	ADD.W	D1,#2	MUL.WU	D1,(A0)+ODFCY	SWAP.W	D4	LOAD.W	D4,D1	SWAP.W	D4	PUSHM.L	D3,D4	SUB.W	D3,#4	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	ADD.W	D4,#4+4	LOAD.W	D2,#SETDOT	LIB	?DRRECT	POPM.L	D3,D4	LOAD.L	A4,A3	LOAD.W	D2,#-140$:	INC.W	D2		; D2 <-- nb de caractres	TEST.B	(A4+)	JUMP,NE 40$	MUL.WU	D2,(A0)+ODFCX	SR.W	D2,#1	SR.W	D4,#1	ADD.W	D3,D4	SUB.W	D3,D2	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LIB	?SETCURS	PUSH.L	A3	LIB	?AFTEXT	POP.L	A3	LIB	?AFTIM	.B	MODCAR,SETDOT!PENDOT	.B	0	.EVEN	INC.W	D3	LIB	?SETCURS	LIB	?AFTEXT	LIB	?AFTIM	.B	MODCAR,SETDOT	.B	0	.EVEN	POPM.L	D2..D4,A3,A4	RET;---------\\; AFFNOTES >;=========/; Affiche tous les noms de notes.; in	D4.L	fanions; out	-; mod	D7.WAFFNOTES:	PUSHM.L	D1..D4,A3	LIB	?BUCAR	TEST.L	D4:#BFAFRENCH	JUMP,BC 10$	LOAD.L	A3,#R16"01$	TEST.L	D4:#BFADIESE	JUMP,BS 20$	LOAD.L	A3,#R16"02$	JUMP	20$10$:	LOAD.L	A3,#R16"03$	TEST.L	D4:#BFADIESE	JUMP,BS 20$	LOAD.L	A3,#R16"04$;	JUMP	20$20$:	LOAD.W	D1,#12	LOAD.W	D2,#BFADO!2^BDBGCLABEL30$:	DBOX_	GETCO	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	LIB	?SETCURS	LIB	?AFTEXT	INC.W	D2	DEC.W	D1	JUMP,NE 30$	LIB	?NOBUCAR	POPM.L	D1..D4,A3	RET01$:	.ASCIZ	"Do "	.ASCIZ	"Do<CARDIESE> "	.ASCIZ	"R "	.ASCIZ	"R<CARDIESE> "	.ASCIZ	"Mi "	.ASCIZ	"Fa "	.ASCIZ	"Fa<CARDIESE> "	.ASCIZ	"Sol"	.ASCIZ	"Sol<CARDIESE>"	.ASCIZ	"La "	.ASCIZ	"La<CARDIESE> "	.ASCIZ	"Si "02$:	.ASCIZ	"Do "	.ASCIZ	"R<CARBEMOL> "	.ASCIZ	"R "	.ASCIZ	"Mi<CARBEMOL> "	.ASCIZ	"Mi "	.ASCIZ	"Fa "	.ASCIZ	"Sol<CARBEMOL>"	.ASCIZ	"Sol"	.ASCIZ	"La<CARBEMOL> "	.ASCIZ	"La "	.ASCIZ	"Si<CARBEMOL> "	.ASCIZ	"Si "03$:	.ASCIZ	"C  "	.ASCIZ	"C<CARDIESE>  "	.ASCIZ	"D  "	.ASCIZ	"D<CARDIESE>  "	.ASCIZ	"E  "	.ASCIZ	"F  "	.ASCIZ	"F<CARDIESE>  "	.ASCIZ	"G  "	.ASCIZ	"G<CARDIESE>  "	.ASCIZ	"A  "	.ASCIZ	"A<CARDIESE>  "	.ASCIZ	"B  "04$:	.ASCIZ	"C  "	.ASCIZ	"D<CARBEMOL>  "	.ASCIZ	"D  "	.ASCIZ	"E<CARBEMOL>  "	.ASCIZ	"E  "	.ASCIZ	"F  "	.ASCIZ	"G<CARBEMOL>  "	.ASCIZ	"G  "	.ASCIZ	"A<CARBEMOL>  "	.ASCIZ	"A  "	.ASCIZ	"B<CARBEMOL>  "	.ASCIZ	"B  "	.EVEN;----------\\; AFFACCORD >;==========/; Affiche le nom de l'accord.; in	D4.L	fanions; out	-; mod	D7.WAFFACCORD:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D3,#1405$:	LOAD.B	(A3+),#SPACE	DEC.W	D3	JUMP,NE 05$	CLR.L	(A3)	LOAD.L	A3,#(A6)+OBUDIS+3	TEST.L	D4:#BFAFRENCH	JUMP,BC 10$	LOAD.L	A4,#R16"01$	TEST.L	D4:#BFADIESE	JUMP,BS 20$	LOAD.L	A4,#R16"02$	JUMP	20$10$:	LOAD.L	A4,#R16"03$	TEST.L	D4:#BFADIESE	JUMP,BS 20$	LOAD.L	A4,#R16"04$;	JUMP	20$20$:	LOAD.W	D3,D422$:	RR.W	D3,#1	JUMP,CS 25$23$:	TEST.B	(A4+)	JUMP,NE 23$	JUMP	22$25$:	LOAD.B	D3,(A4+)	JUMP,EQ 26$	LOAD.B	(A3+),D3	JUMP	25$26$:	TEST.L	D4:#BFAMIN	JUMP,BC 30$	LOAD.B	(A3+),#CARMITAL30$:	TEST.L	D4:#BFA5AUG	JUMP,BC 31$	LOAD.B	(A3+),#CARCINQ	LOAD.B	(A3+),#'a	LOAD.B	(A3+),#'u	LOAD.B	(A3+),#'g31$:	TEST.L	D4:#BFA6EME	JUMP,BC 32$	LOAD.B	(A3+),#CARSIX32$:	TEST.L	D4:#BFA7DIM	JUMP,BC 33$	LOAD.B	(A3+),#CARSEPT	LOAD.B	(A3+),#'d	LOAD.B	(A3+),#'i	LOAD.B	(A3+),#'m33$:	TEST.L	D4:#BFA7EME	JUMP,BC 34$	LOAD.B	(A3+),#CARSEPT34$:	TEST.L	D4:#BFA7MAJ	JUMP,BC 35$	LOAD.B	(A3+),#CARSEPT	LOAD.B	(A3+),#'M	LOAD.B	(A3+),#'A	LOAD.B	(A3+),#'J35$:	TEST.L	D4:#BFA9EME	JUMP,BC 36$	LOAD.B	(A3+),#CARNEUF36$:	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS	LIB	?AFTEXT	POPM.L	D2..D4,A3,A4	RET01$:	.ASCIZ	"Do"	.ASCIZ	"Do<CARDIESE>"	.ASCIZ	"R"	.ASCIZ	"R<CARDIESE>"	.ASCIZ	"Mi"	.ASCIZ	"Fa"	.ASCIZ	"Fa<CARDIESE>"	.ASCIZ	"Sol"	.ASCIZ	"Sol<CARDIESE>"	.ASCIZ	"La"	.ASCIZ	"La<CARDIESE>"	.ASCIZ	"Si"02$:	.ASCIZ	"Do"	.ASCIZ	"R<CARBEMOL>"	.ASCIZ	"R"	.ASCIZ	"Mi<CARBEMOL>"	.ASCIZ	"Mi"	.ASCIZ	"Fa"	.ASCIZ	"Sol<CARBEMOL>"	.ASCIZ	"Sol"	.ASCIZ	"La<CARBEMOL>"	.ASCIZ	"La"	.ASCIZ	"Si<CARBEMOL>"	.ASCIZ	"Si"03$:	.ASCIZ	"C"	.ASCIZ	"C<CARDIESE>"	.ASCIZ	"D"	.ASCIZ	"D<CARDIESE>"	.ASCIZ	"E"	.ASCIZ	"F"	.ASCIZ	"F<CARDIESE>"	.ASCIZ	"G"	.ASCIZ	"G<CARDIESE>"	.ASCIZ	"A"	.ASCIZ	"A<CARDIESE>"	.ASCIZ	"B"04$:	.ASCIZ	"C"	.ASCIZ	"D<CARBEMOL>"	.ASCIZ	"D"	.ASCIZ	"E<CARBEMOL>"	.ASCIZ	"E"	.ASCIZ	"F"	.ASCIZ	"G<CARBEMOL>"	.ASCIZ	"G"	.ASCIZ	"A<CARBEMOL>"	.ASCIZ	"A"	.ASCIZ	"B<CARBEMOL>"	.ASCIZ	"B"	.EVEN;----------\\; DESACCORD >;==========/; Dessine l'accord sur le clavier.; in	D4.L	fanions; out	-; mod	D7.WDESACCORD:	PUSHM.L	D2,D3	LIB	?BUCAR	LOAD.W	(A6)+ONOTE1,#-1000	LOAD.W	(A6)+ONOTE2,#-1000	LOAD.W	(A6)+ONOTE3,#-1000	LOAD.W	(A6)+ONOTE4,#-1000	LOAD.W	(A6)+ONOTE5,#-1000	LOAD.W	D3,D4	LOAD.W	D2,#-110$:	INC.W	D2	RR.W	D3,#1	JUMP,CC 10$	LOAD.W	D3,D2	TEST.L	D4:#BFAMIN	JUMP,BS 20$				; majeur =>	LOAD.W	(A6)+ONOTE1,D2	ADD.W	D2,#4	LOAD.W	(A6)+ONOTE2,D2	ADD.W	D2,#3	LOAD.W	(A6)+ONOTE3,D2	JUMP	40$20$:				; mineur =>	LOAD.W	(A6)+ONOTE1,D2	ADD.W	D2,#3	LOAD.W	(A6)+ONOTE2,D2	ADD.W	D2,#4	LOAD.W	(A6)+ONOTE3,D240$:	TEST.L	D4:#BFA5AUG	; 5 aug	JUMP,BC 50$	INC.W	(A6)+ONOTE350$:	TEST.L	D4:#BFA6EME	; 6	JUMP,BC 52$	LOAD.W	D2,D3	ADD.W	D2,#9	LOAD.W	(A6)+ONOTE4,D252$:	TEST.L	D4:#BFA7DIM	; 7 dim	JUMP,BC 54$	LOAD.W	D2,D3	ADD.W	D2,#10	LOAD.W	(A6)+ONOTE4,D254$:	TEST.L	D4:#BFA7EME	; 7	JUMP,BC 55$	LOAD.W	D2,D3	ADD.W	D2,#10	LOAD.W	(A6)+ONOTE4,D255$:	TEST.L	D4:#BFA7MAJ	; 7 MAJ	JUMP,BC 56$	LOAD.W	D2,D3	ADD.W	D2,#11	LOAD.W	(A6)+ONOTE4,D256$:	TEST.L	D4:#BFA9EME	; 9	JUMP,BC 58$	LOAD.W	D2,D3	ADD.W	D2,#10	LOAD.W	(A6)+ONOTE4,D2	LOAD.W	D2,D3	ADD.W	D2,#14	LOAD.W	(A6)+ONOTE5,D258$:	TEST.L	D4:#BFA7DIM	JUMP,BC 65$	TEST.L	D4:#BFAMIN	JUMP,BS 60$	DEC.W	(A6)+ONOTE260$:	DEC.W	(A6)+ONOTE3	DEC.W	(A6)+ONOTE4	DEC.W	(A6)+ONOTE565$:	TEST.L	D4:#BFAR0	JUMP,BS 73$	TEST.L	D4:#BFAR1	JUMP,BS 72$	TEST.L	D4:#BFAR2	JUMP,BS 71$	ADD.W	(A6)+ONOTE3,#1271$:	ADD.W	(A6)+ONOTE2,#1272$:	ADD.W	(A6)+ONOTE1,#1273$:	LOAD.W	D2,(A6)+ONOTE1	CALL	SETACCORD	LOAD.W	D2,(A6)+ONOTE2	CALL	SETACCORD	LOAD.W	D2,(A6)+ONOTE3	CALL	SETACCORD	LOAD.W	D2,(A6)+ONOTE4	CALL	SETACCORD	LOAD.W	D2,(A6)+ONOTE5	CALL	SETACCORD	LOAD.W	D2,(A6)+OLAST1	CALL	CLRACCORD	LOAD.W	D2,(A6)+OLAST2	CALL	CLRACCORD	LOAD.W	D2,(A6)+OLAST3	CALL	CLRACCORD	LOAD.W	D2,(A6)+OLAST4	CALL	CLRACCORD	LOAD.W	D2,(A6)+OLAST5	CALL	CLRACCORD	LOAD.W	(A6)+OLAST1,(A6)+ONOTE1	LOAD.W	(A6)+OLAST2,(A6)+ONOTE2	LOAD.W	(A6)+OLAST3,(A6)+ONOTE3	LOAD.W	(A6)+OLAST4,(A6)+ONOTE4	LOAD.W	(A6)+OLAST5,(A6)+ONOTE5	LIB	?NOBUCAR	POPM.L	D2,D3	RET;----------\\; SETACCORD >;----------/; Allume une note.; in	D2.W	note (0..23); out	-; mod	D7.WSETACCORD:	COMP.W	D2,(A6)+OLAST1	JUMP,EQ 90$	COMP.W	D2,(A6)+OLAST2	JUMP,EQ 90$	COMP.W	D2,(A6)+OLAST3	JUMP,EQ 90$	COMP.W	D2,(A6)+OLAST4	JUMP,EQ 90$	COMP.W	D2,(A6)+OLAST5	JUMP,EQ 90$	CALL	GREYNOTE	; allume une note90$:	RET;----------\\; CLRACCORD >;----------/; Eteint une note.; in	D2.W	note (0..23); out	-; mod	D7.WCLRACCORD:	COMP.W	D2,(A6)+ONOTE1	JUMP,EQ 90$	COMP.W	D2,(A6)+ONOTE2	JUMP,EQ 90$	COMP.W	D2,(A6)+ONOTE3	JUMP,EQ 90$	COMP.W	D2,(A6)+ONOTE4	JUMP,EQ 90$	COMP.W	D2,(A6)+ONOTE5	JUMP,EQ 90$	CALL	GREYNOTE	; teint une note90$:	RET;-----------\\; PLAYACCORD >;===========/; Fait entendre un accord.; in	D4.L	fanions; out	-; mod	D7.WPLAYACCORD:	PUSHM.L	D3..D6,A3,A4	TEST.L	D4:#BFASILENCE	JUMP,BS 90$	TEST.L	D4:#BFAARPEGE	JUMP,BS 50$				; accord =>	LOAD.W	D3,(A6)+OLAST1	LOAD.W	D4,(A6)+OLAST2	LOAD.W	D5,(A6)+OLAST3	TEST.W	(A6)+OLAST4	JUMP,NS 20$	LOAD.W	D5,(A6)+OLAST420$:	TEST.W	(A6)+OLAST5	JUMP,NS 22$	LOAD.W	D5,(A6)+OLAST522$:	ADD.W	D3,#12*3	ADD.W	D4,#12*3	ADD.W	D5,#12*3	LOAD.W	D6,#H'100*50+0	LIB	?ACCORD	JUMP	90$50$:				; arpge =>	CALL	SORTNOTES	LOAD.L	A4,#(A6)+OBUPLAY	LOAD.L	A3,#(A6)+OLAST1	LOAD.W	D3,#552$:	LOAD.W	D4,(A3+)	JUMP,NS 56$	ADD.W	D4,#NOTE+12*3	LOAD.W	(A4+),D4	LOAD.W	(A4+),#SILENCE	LOAD.W	(A4+),#SILENCE	LOAD.B	(A4+),#20	LOAD.B	(A4+),#1056$:	DEC.W	D3	JUMP,NE 52$	CLR.W	(A4)	LOAD.L	A4,#(A6)+OBUPLAY	LIB	?PLAY90$:	POPM.L	D3..D6,A3,A4	RET;----------\\; SORTNOTES >;----------/; Trie toutes les notes.; in	-; out	-; mod	D7.WSORTNOTES:	PUSHM.L	D2..D4,A410$:	LOAD.L	A4,#(A6)+OLAST1	LOAD.W	D4,#5-1	CLR.W	D220$:	LOAD.W	D3,(A4)+0	COMP.W	D3,(A4)+2	JUMP,LS 30$	LOAD.W	(A4)+0,(A4)+2	; EX.W (A4)+0,(A4)+2	LOAD.W	(A4)+2,D3	INC.W	D2		; D2 <-- une permutation de plus30$:	ADD.L	A4,#2	DEC.W	D4	JUMP,NE 20$	TEST.W	D2		; y a-t-il eu des permutations ?	JUMP,NE 10$		; oui => 10$	POPM.L	D2..D4,A4	RET;---------\\; DETNOTES >;=========/; Dtecte dans quelle note est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	note (0..23);	D7.W	erreur; mod	D2.L, D7.WDETNOTES:	PUSHM.L	D0,D1,D3..D6	LOAD.W	D0,D4		; D0 <-- position en X	LOAD.L	D1,D4	SWAP.W	D1		; D1 <-- position en Y	CLR.W	D210$:	CALL	POSNOTE	CLR.W	D7	COMP.W	D0,D3	JUMP,LO 50$	ADD.W	D3,D4	COMP.W	D0,D3	JUMP,HS 50$	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,D3	JUMP,LO 20$	ADD.W	D3,D4	COMP.W	D1,D3	JUMP,LS 90$20$:	TEST.L	D6	JUMP,EQ 50$	COMP.W	D0,D5	JUMP,LO 50$	ADD.W	D5,D6	COMP.W	D0,D5	JUMP,HS 50$	SWAP.W	D5	SWAP.W	D6	COMP.W	D1,D5	JUMP,LO 50$	ADD.W	D5,D6	COMP.W	D1,D5	JUMP,LS 90$50$:	INC.W	D2	COMP.W	D2,#NBNOTES	JUMP,LO 10$	LOAD.W	D2,#-1000	LOAD.W	D7,#1		; D7 <-- pas dans une note90$:	POPM.L	D0,D1,D3..D6	TEST.W	D7		; retour EQ/NE	RET;---------\\; DESNOTES >;=========/; Dessine toutes les notes.; in	-; out	-; mod	D7.WDESNOTES:	PUSHM.L	D2..D4	LIB	?BUCAR	CLR.W	D210$:	CALL	DESNOTE	INC.W	D2	COMP.W	D2,#NBNOTES	JUMP,LO 10$	TEST.B	(A0)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP,BS 90$		; oui => 90$				; non =>	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.W	D3,#PYNOTE-1	SWAP.W	D3	LOAD.W	D3,#PXNOTE	LOAD.W	D4,#DYNOTEB+3	SWAP.W	D4	LOAD.W	D4,#(DXNOTEB*NBOCTAVE*7)+1	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX90$:	LIB	?NOBUCAR	POPM.L	D2..D4	RET;--------\\; DESNOTE >;========/; Dessine une note.;	       6;	     |---|;	     |   |;	    8|   |7;	     |   |;	    1|   |2;	   |-|   |-|;	   |       |;	  5|       |3;	   |       |;	   |-------|;	       4; in	D2.W	note (0..23); out	-; mod	D7.WDESNOTE:	PUSHM.L	D2..D6	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	POSNOTE	LOAD.W	D2,#INVDOT	TEST.L	D6	JUMP,EQ 50$	PUSHM.L	D3,D4	LOAD.W	D4,D5	SUB.W	D4,D3	INC.W	D4	AND.L	D4,#H'FFFF	LIB	?DRSEG		; (1)	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D4,D3	SUB.W	D4,D5	SUB.W	D4,D6	INC.W	D4	LOAD.W	D3,D5	ADD.W	D3,D6	AND.L	D4,#H'FFFF	LIB	?DRSEG		; (2)	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,D4	CLR.W	D4	SWAP.W	D3	SWAP.W	D4	INC.W	D3	DEC.W	D4	SWAP.W	D4	SWAP.W	D3	LIB	?DRSEG		; (3)	POPM.L	D3,D4	PUSHM.L	D3,D4	INC.W	D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	CLR.W	D4	SWAP.W	D4	SWAP.W	D3	LIB	?DRSEG		; (4)	POPM.L	D3,D4	PUSHM.L	D3,D4	CLR.W	D4	SWAP.W	D3	SWAP.W	D4	INC.W	D3	DEC.W	D4	SWAP.W	D4	SWAP.W	D3	LIB	?DRSEG		; (5)	POPM.L	D3,D4	LOAD.L	D3,D5	LOAD.L	D4,D6	PUSHM.L	D3,D4	INC.W	D4	AND.L	D4,#H'FFFF	LIB	?DRSEG		; (6)	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,D4	CLR.W	D4	SWAP.W	D3	SWAP.W	D4	INC.W	D3	DEC.W	D4	SWAP.W	D4	SWAP.W	D3	LIB	?DRSEG		; (7)	POPM.L	D3,D4	PUSHM.L	D3,D4	CLR.W	D4	SWAP.W	D3	SWAP.W	D4	INC.W	D3	DEC.W	D4	SWAP.W	D4	SWAP.W	D3	LIB	?DRSEG		; (8)	POPM.L	D3,D4	JUMP	90$50$:	INC.W	D4	LIB	?DRMATRIX	INC.W	D3	SUB.W	D4,#2	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	LOAD.W	D4,#1	SWAP.W	D4	SWAP.W	D3	LIB	?DRMATRIX90$:	POPM.L	D2..D6	RET;---------\\; GREYNOTE >;=========/; Grise une note.; in	D2.W	note (0..23); out	-; mod	D7.WGREYNOTE:	PUSHM.L	D2..D6	TEST.W	D2	JUMP,NS 90$	CALL	POSNOTE	LOAD.W	D2,#INVDOT	PUSHM.L	D3,D4	LOAD.L	D3,#H'11441144	TEST.L	D6	JUMP,NE 20$	NOT.L	D320$:	TEST.B	(A0)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP,BS 22$		; oui => 22$	NOT.L	D322$:	LOAD.L	D4,D3	LIB	?DRMDEF	POPM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LIB	?DRMATRIX	LOAD.L	D3,D5	LOAD.L	D4,D6	JUMP,EQ 90$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	LIB	?DRMATRIX90$:	POPM.L	D2..D6	RET;--------\\; INVNOTE >;========/; Inverse une note.; in	D2.W	note (0..23); out	-; mod	D7.WINVNOTE:	PUSHM.L	D2..D6	TEST.W	D2	JUMP,NS 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	POSNOTE	LOAD.W	D2,#INVDOT	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LIB	?DRMATRIX	LOAD.L	D3,D5	LOAD.L	D4,D6	JUMP,EQ 90$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	LIB	?DRMATRIX90$:	POPM.L	D2..D6	RET;--------\\; POSNOTE >;--------/; Donne la position et les dimensions d'un ou deux rectangles; qui dlimitent la note.; in	D2.W	note (0..23); out	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D5.L	origine (y;x);	D6.L	dimensions (dy;dx); mod	D3.L, D4.L, D5.L, D6.LPOSNOTE:	PUSHM.L	D1,D2,A4	CLR.L	D1	LOAD.W	D1,D2	DIV.WU	D1,#12	SWAP.W	D1		; D1 <-- octave/reste	LOAD.L	A4,#R16"TANOTES	LOAD.W	D2,D1	MUL.WU	D2,#8	ADD.L	A4,D2	LOAD.L	D3,(A4)+0	LOAD.L	D4,(A4)+4	CLR.L	D5	CLR.L	D6	COMP.W	(A4)+4,#DYNOTEN	; est une noire ?	JUMP,EQ 50$		; oui => 50$	LOAD.L	D5,D3	LOAD.L	D6,D4	SWAP.W	D3	LOAD.W	D3,#DYNOTEN+2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,#DYNOTEB-DYNOTEN-2	SWAP.W	D4;	SWAP.W	D5;	LOAD.W	D5,#0;	SWAP.W	D5	SWAP.W	D6	LOAD.W	D6,#DYNOTEN+2	SWAP.W	D6	COMP.W	(A4)-8+4,#DYNOTEN ; noire juste  gauche ?	JUMP,NE 30$		; non => 30$				; oui =>	LOAD.W	D2,(A4)-8+2	ADD.W	D2,(A4)-8+6	SUB.W	D2,(A4)+2	ADD.W	D5,D2	SUB.W	D6,D230$:	COMP.W	(A4)+8+4,#DYNOTEN ; noire juste  droite ?	JUMP,NE 50$		; non => 50$				; oui =>	LOAD.W	D2,(A4)+2	ADD.W	D2,(A4)+6	SUB.W	D2,(A4)+8+2	SUB.W	D6,D250$:	SWAP.W	D1		; D1 <-- octave	MUL.WU	D1,#DXNOTEB*7	ADD.W	D3,D1	ADD.W	D5,D1	INC.W	D3	SUB.W	D4,#2	TEST.L	D6	JUMP,EQ 60$	INC.W	D5	SUB.W	D6,#260$:	ADD.W	D3,#PXNOTE	SWAP.W	D3	ADD.W	D3,#PYNOTE	SWAP.W	D3	ADD.W	D5,#PXNOTE	SWAP.W	D5	ADD.W	D5,#PYNOTE	SWAP.W	D5	POPM.L	D1,D2,A4	RET				; si	.W	0,-DXNOTEB	.W	DYNOTEB,DXNOTEBTANOTES:			; do	.W	0,DXNOTEB*0	.W	DYNOTEB,DXNOTEB				; do #	.W	0,(DXNOTEB*1)-(DXNOTEN/2)-DXNOTEC	.W	DYNOTEN,DXNOTEN				; r	.W	0,DXNOTEB*1	.W	DYNOTEB,DXNOTEB				; r #	.W	0,(DXNOTEB*2)-(DXNOTEN/2)+DXNOTEC	.W	DYNOTEN,DXNOTEN				; mi	.W	0,DXNOTEB*2	.W	DYNOTEB,DXNOTEB				; fa	.W	0,DXNOTEB*3	.W	DYNOTEB,DXNOTEB				; fa #	.W	0,(DXNOTEB*4)-(DXNOTEN/2)-DXNOTEC	.W	DYNOTEN,DXNOTEN				; sol	.W	0,DXNOTEB*4	.W	DYNOTEB,DXNOTEB				; sol #	.W	0,(DXNOTEB*5)-(DXNOTEN/2)+0	.W	DYNOTEN,DXNOTEN				; la	.W	0,DXNOTEB*5	.W	DYNOTEB,DXNOTEB				; la #	.W	0,(DXNOTEB*6)-(DXNOTEN/2)+DXNOTEC	.W	DYNOTEN,DXNOTEN				; si	.W	0,DXNOTEB*6	.W	DYNOTEB,DXNOTEB				; do 2	.W	0,DXNOTEB*7	.W	DYNOTEB,DXNOTEB;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET; DBOX principale; ---------------TDBOX_PRINC:	.W	10$-TDBOX_PRINC	.W	20$-TDBOX_PRINC	.W	0,010$:	.B	ODBTITLE	.ASCIZ	"ACCORD"	.B	ODBTABX,67	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,2	.B	ODBLABEL,200	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,2+16	.B	ODBLABEL,201	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,21	.B	ODBLABEL,202	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,21+10	.B	ODBLABEL,203	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,34	.B	ODBLABEL,204	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,34+14	.B	ODBLABEL,205	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,51	.B	ODBLABEL,206	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,51+12	.B	ODBLABEL,207	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR	.B	ODBTABX,2	.B	ODBLABEL,BFASI	.B	ODBLCIRCLE,BFASI!2^7!2^6,KEYDBOX/H'100,BFASI	.ASCIZ	"     "	.B	ODBTABX,21	.B	ODBSQUARE,BFAMIN!2^7!2^6,KEYDBOX/H'100,BFAMIN	.ASCIZ	" mineur"	.B	ODBTABX,34	.B	ODBLCIRCLE,BFAR0!2^7!2^6,KEYDBOX/H'100,BFAR0	.ASCIZ	" initial"	.B	ODBTABX,51	.B	ODBLCIRCLE,BFADIESE!2^7!2^6,KEYDBOX/H'100,BFADIESE	.ASCIZ	" <CARDIESE>"	.B	ODBTABX,57	.B	ODBLCIRCLE,BFAFRENCH!2^7!2^6,KEYDBOX/H'100,BFAFRENCH	.ASCIZ	" Do"	.B	ODBCR	.B	ODBTABX,2+7	.B	ODBLABEL,BFALASI	.B	ODBLCIRCLE,BFALASI!2^7!2^6,KEYDBOX/H'100,BFALASI	.ASCIZ	"     "	.B	ODBCR	.B	ODBTABX,2	.B	ODBLABEL,BFALA	.B	ODBLCIRCLE,BFALA!2^7!2^6,KEYDBOX/H'100,BFALA	.ASCIZ	"     "	.B	ODBTABX,21	.B	ODBLCIRCLE,BFA5AUG!2^7!2^6,KEYDBOX/H'100,BFA5AUG	.ASCIZ	" 5 aug"	.B	ODBTABX,34	.B	ODBLCIRCLE,BFAR1!2^7!2^6,KEYDBOX/H'100,BFAR1	.ASCIZ	" 1er"	.B	ODBTABX,51	.B	ODBLCIRCLE,BFABEMOL!2^7!2^6,KEYDBOX/H'100,BFABEMOL	.ASCIZ	" <CARBEMOL>"	.B	ODBTABX,57	.B	ODBLCIRCLE,BFAENGLISH!2^7!2^6,KEYDBOX/H'100,BFAENGLISH	.ASCIZ	" C"	.B	ODBCR	.B	ODBTABX,2+7	.B	ODBLABEL,BFASOLLA	.B	ODBLCIRCLE,BFASOLLA!2^7!2^6,KEYDBOX/H'100,BFASOLLA	.ASCIZ	"     "	.B	ODBCR	.B	ODBTABX,2	.B	ODBLABEL,BFASOL	.B	ODBLCIRCLE,BFASOL!2^7!2^6,KEYDBOX/H'100,BFASOL	.ASCIZ	"     "	.B	ODBTABX,21	.B	ODBLCIRCLE,BFA6EME!2^7!2^6,KEYDBOX/H'100,BFA6EME	.ASCIZ	" 6"	.B	ODBTABX,34	.B	ODBLCIRCLE,BFAR2!2^7!2^6,KEYDBOX/H'100,BFAR2	.ASCIZ	" 2me"	.B	ODBCR	.B	ODBTABX,2+7	.B	ODBLABEL,BFAFASOL	.B	ODBLCIRCLE,BFAFASOL!2^7!2^6,KEYDBOX/H'100,BFAFASOL	.ASCIZ	"     "	.B	ODBCR	.B	ODBTABX,2	.B	ODBLABEL,BFAFA	.B	ODBLCIRCLE,BFAFA!2^7!2^6,KEYDBOX/H'100,BFAFA	.ASCIZ	"     "	.B	ODBTABX,21	.B	ODBLCIRCLE,BFA7DIM!2^7!2^6,KEYDBOX/H'100,BFA7DIM	.ASCIZ	" 7 dim"	.B	ODBTABX,34	.B	ODBLCIRCLE,BFAR3!2^7!2^6,KEYDBOX/H'100,BFAR3	.ASCIZ	" 3me"	.B	ODBTABX,51	.B	ODBLCIRCLE,BFASILENCE!2^7!2^6,KEYDBOX/H'100,BFASILENCE	.ASCIZ	" silence"	.B	ODBCR	.B	ODBCR	.B	ODBTABX,2	.B	ODBLABEL,BFAMI	.B	ODBLCIRCLE,BFAMI!2^7!2^6,KEYDBOX/H'100,BFAMI	.ASCIZ	"     "	.B	ODBTABX,21	.B	ODBLCIRCLE,BFA7EME!2^7!2^6,KEYDBOX/H'100,BFA7EME	.ASCIZ	" 7"	.B	ODBTABX,51	.B	ODBLCIRCLE,BFAACCORD!2^7!2^6,KEYDBOX/H'100,BFAACCORD	.ASCIZ	" accord"	.B	ODBCR	.B	ODBTABX,2+7	.B	ODBLABEL,BFAREMI	.B	ODBLCIRCLE,BFAREMI!2^7!2^6,KEYDBOX/H'100,BFAREMI	.ASCIZ	"     "	.B	ODBCR	.B	ODBTABX,2	.B	ODBLABEL,BFARE	.B	ODBLCIRCLE,BFARE!2^7!2^6,KEYDBOX/H'100,BFARE	.ASCIZ	"     "	.B	ODBTABX,21	.B	ODBLCIRCLE,BFA7MAJ!2^7!2^6,KEYDBOX/H'100,BFA7MAJ	.ASCIZ	" 7 MAJ"	.B	ODBTABX,51	.B	ODBLCIRCLE,BFAARPEGE!2^7!2^6,KEYDBOX/H'100,BFAARPEGE	.ASCIZ	" arpge"	.B	ODBCR	.B	ODBTABX,2+7	.B	ODBLABEL,BFADORE	.B	ODBLCIRCLE,BFADORE!2^7!2^6,KEYDBOX/H'100,BFADORE	.ASCIZ	"     "	.B	ODBCR	.B	ODBTABX,2	.B	ODBLABEL,BFADO	.B	ODBLCIRCLE,BFADO!2^7!2^6,KEYDBOX/H'100,BFADO	.ASCIZ	"     "	.B	ODBTABX,21	.B	ODBLCIRCLE,BFA9EME!2^7!2^6,KEYDBOX/H'100,BFA9EME	.ASCIZ	" 9"	.B	ODBTABX,34-1	.B	ODBLABEL,100	.B	ODBBOX,0,CLEAR,TDBOMBRE	.ASCIZ	"              "	.B	ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_PRINC:	.W	F0,END,0		DOKEND-TKEY_PRINC	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_PRINC	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_PRINC	.W	0DOKEND:	LOAD.W	D3,#END	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RET; Erreurs fatales; ---------------TXERFATMEM:	.ASCIZ	"Problme avec la mmoire"TXERFATDIS:	.ASCIZ	"Driver d'cran incompatible"; Textes; ------NMDBOX:	.ASCIZ	"DBOX"TXACC:	.ASCIZ	"Accord"TXTEN:	.ASCIZ	"Tension"TXREN:	.ASCIZ	"Renversement"TXMOD:	.ASCIZ	"Mode"	.EVEN	.END	START