0		; diteurOEAUT:	.BLKB	40		; auteurOENPRES:.BLKB	16		; nom de la prsentationLENTETE	=	512; (*)	Supprim depuis l'adaptation au module PRINTA/PRINTB !; Variables pour une piste; ------------------------NBTRACK	=	8		; nb de pistes	.LOC	0OTMIDI:	.BLKB	2		; canal midi (0..15)OTOCT:	.BLKB	2		; octave (-5..+5)OTDMT:	.BLKB	2		; demi-ton (0..12)OTAMP:	.BLKB	2		; amplitude (-127..+127)OTDYN:	.BLKB	2		; dynamique (-127..+127)	.BLKB	2*4		; rserveOTSYNT:	.BLKB	8		; nom du synthtiseur (100_synth.LIB)OTSNA:	.BLKB	16		; nom de la banque de son (100_son.synth)OTSNO:	.BLKB	2		; numro du son dans la banque	.BLKB	10		; rserveLT:; En-tte d'un fichier .midi; --------------------------	.LOC	0OHID:	.BLKB	2		; toujours -1OHREV:	.BLKB	1		; revisionOHVERS:	.BLKB	1		; version	.BLKB	4		; rserveOHCHA:	.BLKB	1		; canaux utiliss (bits)	.BLKB	1		; rserveOHVIT:	.BLKB	2		; vitesse (-MAXVIT..+MAXVIT)OHMET:	.BLKB	1		; mtronome	.BLKB	1		; rserveOHLG:	.BLKB	4		; longueur sans l'en-tte	.BLKB	6		; rserveOHTRK:	.BLKB	NBTRACK*LT	; paramtres des pistesLHEAD	=	512		; lg header fichiers; Erreurs; -------ERSEOB		=	1	; fin du bufferERSBOB		=	2	; dbut du bufferERSPDP		=	3	; plus de placeERSNOT		=	4	; pas trouv; Niveaux des soft-keys dans D1; -----------------------------NHAUTNOTE	=	1NBASNOTE	=	2NHAUTSILENCE	=	3NBASSILENCE	=	4NDIVERS1	=	5NDIVERS2	=	6NGRAPHIQUE	=	7NCLEF		=	8NFLOPPY		=	9; Soft-keys pour le dessin d'une note ou d'un silence; ---------------------------------------------------SKNFIRST	=	1	; premire note (ronde)SKNDEF		=	3	; note par dfaut (noire)SKNLAST		=	6	; dernire note (triple-croche)SKNPOINT	=	7	; note pointeSKNNOQ		=	8	; note sans queueSKNHAUTBAS	=	9	; haut <--> basSKNALTER	=	10	; altrationsSKNACCENT	=	11	; accentsSKNFRAPPE	=	12	; force de frappeSKNBARRE	=	13	; barres pour croches; Soft-keys pour le dessin de symboles divers; -------------------------------------------SKDCHIFFRE	=	1	;