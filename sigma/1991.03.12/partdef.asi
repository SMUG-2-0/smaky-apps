esureOMEMIN:	.BLKB	2		; note la plus haute en YOMEMAX:	.BLKB	2		; note la plus basse en YOMELP:	.BLKB	LLP*MAXLP	; liste des portesOMEREP:	.BLKB	4		; signes de repriseOMENPA:	.BLKB	1		; nb de passages pour les reprisesOMENPX:	.BLKB	1		; nb de passages pour les 1x, 2x, etc.	.EVENLME:; Description d'un objet "symbole"; --------------------------------	.LOC	0	.BLKB	LOBJ		; partie commune  tous les objetsOSYFLG:	.BLKB	1		; flags: BSYPOINT	= 0		;  point (* 1.5) BSYNOQ		= 1		;  note sans queue BSYBAS		= 2		;  contre en bas BSYTRIOLET	= 3		;  triolet (* 2/3) BSYDUOLET	= 4		;  duolet (* 1.5) BSYQUINTOLET	= 5		;  quintolet (* 4/5) BSYSEPTOLET	= 6		;  septolet (* 8/7)OSYALT:	.BLKB	1		; altrationOSYACC:	.BLKB	1		; accentuationOSYVOIX:.BLKB	1		; voixOSYINST:.BLKB	1		; instrumentOSYFRAP:.BLKB	1		; force de frappe (1..5)	.EVENOSYPOS:	.BLKB	4		; position (y;x)OSYNOB:	.BLKB	4		; no barre crocheOSYPOB:	.BLKB	4		; position barre croche (y,dx)OSYNOT:	.BLKB	1		; hauteur de la note (en demi-tons)	.EVENLSY:; Description d'un objet "graphique"; ----------------------------------	.LOC	0	.BLKB	LOBJ		; partie commune  tous les objetsOGRPN1:	.BLKB	4		; premier paramtre numriqueOGRPN2:	.BLKB	4		; deuxime paramtre numriqueOGREP:	.BLKB	1		; paisseur du trait (1,2,4)OGRTT:	.BLKB	1		; traitillLGR:; Description d'un objet "texte"; ------------------------------MAXTX	=	80		; lg max d'un texte	.LOC	0	.BLKB	LOBJ		; partie commune  tous les objetsOTXPN1:	.BLKB	4		; = OGRPN1 (coordonne coin inf/gauche)OTXPN2:	.BLKB	4		; = OGRPN2 (coordonne coin sup/droite)OTXPGC:	.BLKB	4		; ^gencarOTXBLI:	.BLKB	2		; position de la ligne de baseOTXCUR:	.BLKB	2		; offset o est le curseur	.BLKB	8		; rserveOTXFST:	.BLKB	4		; <usegc><f><s><t>OTXCAR:				; texte<0>; Contenu de OBDLIST; ------------------	.LOC	0OBDPOS:	.BLKB	4		; position de la croche (y;x)OBDPTC:	.BLKB	4		; ^objet crocheOBDTYC:	.BLKB	1		; type (0..2)OBDFLG:	.BLKB	1		; flagsLBD:; Contenu de TSYMB; ----------------	.LOC	0OTSCODE:.BLKB	1		; code de l'icne	.BLKB	1OTSX:	.BLKB	2		; offset depuis la gaucheOTSY:	.BLKB	2		; offset depuis le basOTSDX:	.BLKB	2		; largeurOTSDY:	.BLKB	2		; hauteurOTSCX:	.BLKB	2		; centre depuis la gaucheOTSCY:	.BLKB	2		; centre depuis le basLTS:; En-tte d'un fichier "image"; ----------------------------	.LOC	0OIMTYP:	.BLKB	1		; H'01 = indique type imageOIMCOD:	.BLKB	1		; H'00 = indique pas de codageOIMBIP:	.BLKB	1		; H'01 = 1 bit par pointOIMDIR:	.BLKB	1		; H'02 = coord. X-Y comme cranOIMDLX:	.BLKB	2		; largeur image en pointsOIMDLY:	.BLKB	2		; hauteur image en pointsOIMNBB:	.BLKB	4		; nb de byte pour l'image	.BLKB	20		; rserveLGHIMA:; Variables; ---------	.LOC	0OPLCOM:	.BLKB	4		; ^ligne de commandeOCHDBOX:.BLKB	2		; canal du module dboxOCHDGENC:.BLKB	2		; canal du module dgencOCHLIST:.BLKB	2		; canal du module listOCHSCROLL:.BLKB	2		; canal du module scrollOCHPRINTA:.BLKB	2		; canal du module PRINTAOCAPRINT:.BLKB	4		; canal interne de PRINTOCHMOU:	.BLKB	2		; canal de la sourisOADQDOT:.BLKB	4		; adresse de GRA_QXDOTOPDDIS:	.BLKB	4		; ^description de la fentreOPGCIC:	.BLKB	4		; ^gencar ISP32OPGCIC2:.BLKB	4		; ^gencar ISP33OWDOCA:	.BLKB	2		; no swdo dans le cadreOBDIS:	.BLKB	200		; buffer write displayOFLAGS:	.BLKB	1		; flags divers BPLAY	=  0			;  lecture en cours BPRINT	=  1			;  impression en cours	.EVENOMPOB:	.BLKB	4		; position de la souris brutteOMPOW:	.BLKB	4		; position de la souris dans swdoOASC:	.BLKB	LSCVAR		; variables de l'ascenseur des mesuresOASVIT:	.BLKB	LSCVAR		; variables de l'ascenseur pour la vitesseOPTXM:	.BLKB	4*3		; ^trois textes boutons sourisOPDB:	.BLKB	4		; ^DB (dbut du buffer)OPDT:	.BLKB	4		; ^DT (dbut du trou)OPFT:	.BLKB	4		; ^FT (fin du trou)OPFB:	.BLKB	4		; ^FB (fin du buffer)OPMES:	.BLKB	4		; ^dbut mesure couranteOKEY:	.BLKB	2		; touche "brute"OPICOH:	.BLKB	4		; ^liste des icnes horizontauxOPICOV:	.BLKB	4		; ^liste des icnes verticauxOPN:	.BLKB	4		; ^l'une des variables suivante:ONNOTE:	.BLKB	2		; soft-keys allumes pour les notesONPOINT:.BLKB	2		; icne point/triolet selon mmenuONALT:	.BLKB	2		; icne altration selon mmenuONACC:	.BLKB	2		; icne accent selon mmenuONFRAP:	.BLKB	2		; icne de force de frappeONSIL:	.BLKB	2		; soft-keys allumes pour les silencesONGRA:	.BLKB	2		; soft-keys allumes pour les graphiquesONEP:	.BLKB	2		; icne paisseur selon mmenuONCLEF:	.BLKB	2		; soft-keys allumes pour les clefsONDIV1:	.BLKB	2		; soft-keys allumes pour les divers unONDIV2:	.BLKB	2		; soft-keys allumes pour les divers deuxONCHI:	.BLKB	2		; icne chiffre selon mmenuONREP:	.BLKB	2		; icne reprise selon mmenuONFLO:	.BLKB	2		; soft-keys allumes pour le floppyOLXPORT:.BLKB	2		; distance minimale entre deux symboles (=LXPORTEE)ONBOBJ:	.BLKB	2		; nb d'objetsOMESM:	.BLKB	2		; nb max de mesuresOMESC:	.BLKB	2		; mesure couranteOGCNTN:	.BLKB	2		; GCOMPTE: nombre de notesOGCNTC:	.BLKB	2		; GCOMPTE: nombre de crochesOGCNTL:	.BLKB	2		; GCOMPTE: nombre de croches liesONOB:	.BLKB	4		; dlivre les no de barres crochesOBCLAST:.BLKB	4		; dernire barre dessineOBCLIST:.BLKB	LSY*(MBCLIST+1)	; liste des croches  lierOBDLIST:.BLKB	LBD*(MBCLIST+1)	; liste des croches lies  dessinerOME:	.BLKB	LME		; mesureOSYMB:	.BLKB	LSY		; symboleOGRA:	.BLKB	LGR		; objet graphiqueOTEXTE:	.BLKB	OTXCAR+MAXTX+2	; ligne de texte en ditionOFRAPPE:.BLKB	MAXSFRAPPE	; forces de frappe des notes	.EVENOTRACK:	.BLKB	NBTRACK*LT	; variables pour chaque pisteOBUFILE:.BLKB	LBUFILE		; nom du fichierOBUFIMA:.BLKB	LBUFILE		; nom du fichier imageOBXFILE:.BLKB	LBUFILE		; nom du fichier avec extensionOBUFPRI:.BLKB	LBUFILE		; nom du fichier en sortie pour PRINTOCHIO:	.BLKB	2		; canal pour entre/sortieOENTETE:.BLKB	LENTETE		; en-tte .partOHEAD:	.BLKB	LHEAD		; en-tte .midiOTMIO:	.BLKB	LTMIO		; buffer tamponOOBIO:	.BLKB	200		; buffer pour un objetOPTIO:	.BLKB	2		; ^relatif dans OTMIOONBIO:	.BLKB	2		; reste dans OTMIOOPTMIDI:.BLKB	2		; ^relatif dans OBUMIDIOBUMIDI:.BLKB	LBUMIDI		; buffer de commandes MIDIOTMMIDI:.BLKB	2		; temps au dbut de la mesureOTNMIDI:.BLKB	2		; temps au dbut de la noteONNMIDI:.BLKB	2		; nom de la note (-1,0..6)ONDMIDI:.BLKB	2		; no du driver MIDIONIMIDI:.BLKB	1		; 1 => driver MIDI pas install ici	.EVENOBUCOM:	.BLKB	20		; commandes midiOPFREAD:.BLKB	1		; 1 => processus fils existe	.EVENOBURST:	.BLKB	2+128		; buffer pour lecture status MIDIODJP:	.BLKB	128		; notes dj cresOBUGC:	.BLKB	LGGC*MAXGC	; table des gnrateurs de caractresOGCLIST:.BLKB	MAXGENC*3	; liste des gencars contenus sur disqueOFAGC:	.BLKB	4		; fanions pour dbox des gencarsOFAPLAY:.BLKB	4		; fanions "play"OPLPME:	.BLKB	2		; premire mesure  couterOPLDME:	.BLKB	2		; dernire mesure  couterOBUNUM:	.BLKB	100		; buffer pour diter un nombreOFAPRI:	.BLKB	4		; fanions "print"OIMTM:	.BLKB	100		; titre  imprimerOIMEM:	.BLKB	100		; diteur  imprimerOIMAM:	.BLKB	100		; auteur  imprimerOIMFM:	.BLKB	2		; premire mesure  imprimerOIMLM:	.BLKB	2		; dernire mesure  imprimerOIMNM:	.BLKB	2		; nb de mesure(s)  imprimerOIMZM:	.BLKB	2		; facteur de zoomOFACOP:	.BLKB	4		; fanions "copy"OCPMDE:	.BLKB	2		; mesures de ...OCPMA:	.BLKB	2		;  ...OCPMOU:	.BLKB	2		; aprs la mesure ...OFATRA:	.BLKB	4		; fanions "transpose"OFATNB:	.BLKB	2		; nb de "#" ou "b"OFATON:	.BLKB	4		; fanions "tonalit"OTOTA:	.BLKB	1		; tonalit: #/bOTONA:	.BLKB	1		; tonalit: 0..7	.EVENOIMST:	.BLKB	LGPRI1		; imprimante: statusOIMPT:	.BLKB	4		; imprimante: ^zone mmoire tamponOIMPY:	.BLKB	2		; imprimante: hauteur de la pageOIMLY:	.BLKB	2		; imprimante: hauteur d'une porteOIMLX:	.BLKB	2		; imprimante: largeur de la pageOIMTY:	.BLKB	2		; imprimante: hauteur totale d'une porteOIMTX:	.BLKB	2		; imprimante: largeur totale de la pageOIMIX:	.BLKB	2		; imprimante: largeur de la page en bytesOIMMXG:	.BLKB	2		; imprimante: marge gaucheOIMMXD:	.BLKB	2		; imprimante: marge droiteOIMMYS:	.BLKB	2		; imprimante: marge suprieureOIMMYI:	.BLKB	2		; imprimante: marge infrieureOIMCX:	.BLKB	2		; imprimante: largeur d'une caleOIMCXR:	.BLKB	2		; imprimante: reste de la divisionOIMPN:	.BLKB	2		; imprimante: compteur de pagesOIMPV:	.BLKB	2		; imprimante: position verticaleOIMOM:	.BLKB	2		; imprimante: ancien mapOVERIF:	.BLKB	1		; 1 => mode de vrificationOVEFLAG:.BLKB	1		; vrifie: flags BVECALE	=  0		;  montre les cales	.EVENOVENBY:	.BLKB	2		; vrifie: nb de pages en YOVENBX:	.BLKB	2		; vrifie: nb de pages en XOVEPOSY:.BLKB	2		; vrifie: position premire page en YOVEPOSX:.BLKB	2		; vrifie: position premire page en XOVEDIMY:.BLKB	2		; vrifie: hauteur d'une pageOVEDIMX:.BLKB	2		; vrifie: largeur d'une pageOVEECAY:.BLKB	2		; vrifie: distance entre deux pages en YOVEECAX:.BLKB	2		; vrifie: distance entre deux pages en XOVEFACY:.BLKB	2		; vrifie: facteur de rduction en YOVEFACX:.BLKB	2		; vrifie: facteur de rduction en XOVENUMY:.BLKB	2		; vrifie: ancienne position numro en YOSTPLX:	.BLKB	2		; largeur du papier [pg]OSTPLY:	.BLKB	2		; hauteur du papier [pg]OSTPMG:	.BLKB	2		; marge gauche [pg]OSTPMD:	.BLKB	2		; marge droite [pg]OSTPMS:	.BLKB	2		; marge suprieure [pg]OSTPMI:	.BLKB	2		; marge infrieure [pg]ONPRES:	.BLKB	16		; nom de la prsentationLGVAR:	.END