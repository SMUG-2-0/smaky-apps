	.SBTTL	RYTHMISC;---------\\; DESCADRE >;=========/; Dessine le cadre principal.; in	-; out	D7.W	erreur; mod	D7.WDESCADRE:	PUSHM.L	D0..D5,A3,A4	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.W	D5,(A6)+ONOWDO	JUMP,EQ 10$	LIB	?KILWDO		; supprime la swdo !	CLR.W	(A6)+ONOWDO10$:	LIB	?AFTIM	.B	NOCURS,GCURS	.B	EOP	.B	0	.EVEN	LOAD.L	A3,#R16"TICOBASE	LOAD.L	A4,#0	DBOX_	ICOCADRE	; dessine le cadre autour	PUSH.L	D3	CLR.L	D3	LIB	?SETCURS	; positionne en tout en haut  gauche	LIB	?AFTIM	.B	AFINV		; en inverse vido	.B	SPACE		; toujours un espace	.ASCII	"RYTHME rev "	.B	MAJREV+'0	.B	'.	.B	MINREV+'0	.ASCII	"                                 "	.ASCII	"| dessine |         | dtruit |"		 ;         ;         ;         ;	.B	AFDIR		; remet vido normale	.B	0	.EVEN	POP.L	D3	LIB	?CREWDO		; cre la swdo	LOAD.W	(A6)+ONOWDO,D5	LIB	?USEWDO		; utilise la swdo (toujours)	CALL	AFMENU		; affiche les soft-keys	LOAD.W	D7,#ERDIOUT	; D7 <-- fentre trop petite; Calcul qq variables verticales.	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	INC.W	D4	LOAD.W	(A6)+ORYHT,D4	MUL.WU	D4,#MAXINST+1	LOAD.W	(A6)+ORYLCY,D4	ADD.W	D4,#LGSCROLL	LOAD.W	D3,(A0)+ODFFDY	SUB.W	D3,D4	JUMP,LS 90$	SR.W	D3,#1	LOAD.W	(A6)+ORYPCY,D3	ADD.W	D3,(A6)+ORYHT	LOAD.W	(A6)+ORYPIY,D3; Calcul qq variables horizontales.	LOAD.W	D4,(A0)+ODFCX;;?	MUL.WU	D4,#LRINAME+1+2+1+3+1+3+1	MUL.WU	D4,#LRINAME+1+3+1+3+1	ADD.W	D4,#MAXPAS*LGPAS	LOAD.W	(A6)+ORYLCX,D4	LOAD.W	D3,(A0)+ODFFDX	SUB.W	D3,D4	JUMP,LS 90$	SR.W	D3,#1	LOAD.W	(A6)+ORYPCX,D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#1+LRINAME	ADD.W	D3,D4	LOAD.W	(A6)+ORYPIX,D3; Dessine les cadres rectangulaires.	LOAD.W	D2,#SETDOT	; D2 <-- mode	LOAD.L	D3,(A6)+ORYPCY	LOAD.L	D4,(A6)+ORYLCY	SWAP.W	D4	ADD.W	D4,#LGSCROLL-1	SWAP.W	D4	LOAD.W	D1,#10	LIB	?DRRECT		; rectangle extrieur	LOAD.L	D3,(A6)+ORYPCY	SWAP.W	D3	ADD.W	D3,(A6)+ORYHT	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A6)+ORYLCX	LIB	?DRSEG		; ligne horizontale suprieure	LOAD.W	D4,(A6)+ORYHT	SWAP.W	D4	CLR.W	D4	LOAD.L	D3,(A6)+ORYPCY	LOAD.W	D1,(A0)+ODFCX	MUL.WU	D1,#10	ADD.W	D3,D1	LIB	?DRSEG		; segment vertical	LOAD.W	D4,(A6)+ORYLCY	SWAP.W	D4	CLR.W	D4	LOAD.L	D3,(A6)+ORYPCY	LOAD.W	D1,(A0)+ODFCX	MUL.WU	D1,#LRINAME+1	ADD.W	D3,D1	PUSH.L	D3	DEC.W	D3	LIB	?DRSEG		; segment vertical	POP.L	D3	ADD.W	D3,#MAXPAS*LGPAS	PUSH.L	D3	LIB	?DRSEG		; segment vertical	POP.L	D3;;?	LOAD.W	D1,(A0)+ODFCX;;?	MUL.WU	D1,#2+1;;?	ADD.W	D3,D1;;?	PUSH.L	D3;;?	.W	LIB,?DRSEG	; segment vertical;;?	POP.L	D3	LOAD.W	D1,(A0)+ODFCX	MUL.WU	D1,#3+1	ADD.W	D3,D1	PUSH.L	D3	LIB	?DRSEG		; segment vertical	POP.L	D3	LOAD.L	D3,(A6)+ORYPIY	SUB.W	D3,#2	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.W	D4,(A6)+ORYHT	MUL.WU	D4,#MAXINST	SUB.W	D4,#2	SWAP.W	D4	LOAD.W	D4,#MAXPAS*LGPAS+3	LIB	?DRRECT		; double l'paisseur du cadre des rythmes; Dessine la cage de l'ascenseur.	PUSH.L	A5	LOAD.L	A5,#(A6)+OASC	LOAD.W	(A5)+OSCDEBO,(A6)+ORYPCX	LOAD.W	D4,(A6)+ORYPCY	ADD.W	D4,(A6)+ORYLCY	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+ORYLCX	INC.W	D4	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCHOR	SCROLL_	DRAW		; dessine la cage de l'ascenseur	POP.L	A5; Dessine le type des notes (a/b).	LOAD.L	D4,#-1	CALL	DRMDEF	LOAD.W	D3,(A0)+ODFCX;;?	MUL.WU	D3,#LRINAME+1+2+3	MUL.WU	D3,#LRINAME+3	ADD.W	D3,#MAXPAS*LGPAS	ADD.W	D3,(A6)+ORYPCX	; D3 <-- <xx>	SWAP.W	D3	LOAD.W	D3,(A6)+ORYPCY	ADD.W	D3,#2		; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D4,(A6)+ORYHT	SUB.W	D4,#3		; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,#3		; D4 <-- <dxx>	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; dessine note a	LOAD.W	D3,(A0)+ODFCX;;?	MUL.WU	D3,#LRINAME+1+2+1+3+3	MUL.WU	D3,#LRINAME+1+3+3	ADD.W	D3,#MAXPAS*LGPAS	ADD.W	D3,(A6)+ORYPCX	; D3 <-- <xx>	SWAP.W	D3	LOAD.W	D3,(A6)+ORYPCY	ADD.W	D3,#2		; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D4,(A6)+ORYHT	SUB.W	D4,#4		; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,#2		; D4 <-- <dxx>;	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine note b	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DESMESURE >;==========/; Dessine le contenu d'une mesure.; in	-; out	-; mod	D7.WDESMESURE:	PUSHM.L	D0..D4,A3,A4; Dessine la cage et la cabine de l'ascenseur.	PUSH.L	A5	LOAD.L	A5,#(A6)+OASC	LOAD.W	(A5)+OSCHTV,(A6)+ONMES	LOAD.W	(A5)+OSCPOSV,(A6)+OCMES	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur	POP.L	A5; Dessine le quadrillage dans le rythme.	CLR.L	D4	CALL	DRMDEF	LOAD.L	D3,(A6)+ORYPIY	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	LOAD.W	D4,(A6)+ORYHT	MUL.WU	D4,#MAXINST	SUB.W	D4,#3	SWAP.W	D4	LOAD.W	D4,#MAXPAS*LGPAS	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface le quadrillage et toutes les notes	LIB	?AFTIM	.B	MAPTT	.B	B'01010101	.B	1	.B	0	.EVEN	LOAD.L	D3,(A6)+ORYPIY	LOAD.W	D4,(A6)+ORYHT	SR.W	D4,#1	SWAP.W	D3	ADD.W	D3,D4	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,#MAXPAS*LGPAS	LOAD.W	D1,#MAXINST-130$:	LOAD.W	D2,#SETDOT!TTTDOT	PUSH.L	D3	LIB	?DRSEG		; lignes horizontales	POP.L	D3	SWAP.W	D3	ADD.W	D3,(A6)+ORYHT	SWAP.W	D3	DECJ.W,NMO D1,30$	TEST.W	(A5)+ORMT	JUMP,NE 38$	LOAD.W	(A5)+ORMT,#4	; 4 temps par dfaut38$:	LOAD.L	D3,(A6)+ORYPIY;;?	ADD.W	D3,#LGPAS	ADD.W	D3,#LGPAS/2	LOAD.W	D4,(A6)+ORYHT	MUL.WU	D4,#MAXINST	SWAP.W	D4	CLR.W	D4;;?	LOAD.W	D1,#MAXPAS-1-1	LOAD.W	D1,#MAXPAS-1	LOAD.W	D0,#140$:	LOAD.W	D2,#SETDOT!TTTDOT	DEC.W	D0	JUMP,NE 45$	LOAD.W	D0,(A5)+ORMT	LOAD.W	D2,#SETDOT	; D2 <-- trait plein pour marquer le temps45$:	PUSH.L	D3	LIB	?DRSEG		; lignes verticales	POP.L	D3	ADD.W	D3,#LGPAS	DECJ.W,NMO D1,40$; Dessine toutes les notes de la mesure.	LOAD.L	A3,#(A5)+ORMB	; A3 <-- ^premire note	LOAD.L	D4,(A5)+ORML	SUB.L	D4,#ORMB+4	SR.L	D4,#2	JUMP,EQ 60$50$:	LOAD.L	D3,(A3+)	; D3 <-- position note	LOAD.W	D2,#SETDOT	CALL	RYTHINVN	; dessine la note	DEC.L	D4	JUMP,NE 50$; Dessine les chiffres tout en haut.60$:	CALL	DESCHIFFRE	; dessine les chiffres	LOAD.W	D3,(A5)+ORMN	CALL	RYTHINVM; Dessine le numro de la mesure et le nombre de rptitions.	LOAD.W	D3,(A6)+ORYPIY	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LOAD.W	D3,(A0)+ODFCX	SR.W	D3,#1	ADD.W	D3,(A6)+ORYPCX	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Mesure "	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OCMES	INC.W	D4		; D4 <-- 1..n	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	COMP.W	D4,#10	JUMP,HS 65$	LIB	?AFSPACE65$:; Dessine le contenu de toutes les cases.	LOAD.L	D3,#COOCAR	; D3 <-- (-1;0)	CALL	AFFCASE		; affiche le contenu de la case	LOAD.B	D3,#'x	LIB	?AFCAR		; affiche "999x"	CLR.W	D3		; D3 <-- X initial70$:	AND.L	D3,#H'FFFF	; D3 <-- Y initial75$:	CALL	AFFCASE		; affiche le contenu de la case	SWAP.W	D3	INC.W	D3		; D3 <-- suivant en Y	LOAD.W	D2,D3	SWAP.W	D3	COMP.W	D2,#MAXINST	JUMP,LO 75$	INC.W	D3		; D3 <-- suivant en X	COMP.W	D3,#NBCCOL	JUMP,LO 70$	POPM.L	D0..D4,A3,A4	RET;--------\\; AFFCASE >;--------/; Affiche le contenu d'une case quelconque.; in	D3.L	coordonne; out	-; mod	D7.WAFFCASE:	PUSHM.L	D1..D3,A3	LOAD.L	D1,D3	CALL	RYTHPOSC	; D3/D4 <-- position/dimensions	LOAD.W	D2,(A0)+ODFCX	SR.W	D2,#1	ADD.W	D3,D2		; D3 <--  gauche du caractre	SWAP.W	D3	ADD.W	D3,(A0)+ODFC1Y	INC.W	D3		; D3 <-- sur la ligne de base	SWAP.W	D3	LIB	?SETCURS	LOAD.L	D3,D1	CALL	RYTHPUTC	; A3 <-- ^texte	LIB	?AFTEXT		; affiche le texte	POPM.L	D1..D3,A3	RET;-----------\\; DESCHIFFRE >;===========/; Dessine les chiffres des mesures 0..15.; in	-; out	-; mod	D7.WDESCHIFFRE:	PUSHM.L	D1..D4	CLR.L	D4	CALL	DRMDEF	LOAD.W	D3,(A6)+ORYPCY	INC.W	D3	SWAP.W	D3	LOAD.W	D3,(A6)+ORYPIX	LOAD.W	D4,(A6)+ORYHT	DEC.W	D4	SWAP.W	D4	LOAD.W	D4,#MAXPAS*LGPAS	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface les anciens chiffres	LOAD.L	D3,(A6)+ORYPIY	ADD.W	D3,#LGPAS/2	LOAD.W	D4,(A6)+ORYHT	MUL.WU	D4,#MAXINST	SWAP.W	D4	CLR.W	D4	CLR.W	D120$:	COMP.W	D1,(A5)+ORMN	JUMP,HS 90$	PUSHM.L	D3,D4	LOAD.W	D2,(A0)+ODFCX	COMP.W	D1,#9	JUMP,HS 30$	SR.W	D2,#130$:	SUB.W	D3,D2	SWAP.W	D3	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,D1	INC.W	D4	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche 0..15	POPM.L	D3,D4	ADD.W	D3,#LGPAS	INC.W	D1	COMP.W	D1,#MAXPAS	JUMP,LO 20$90$:	POPM.L	D1..D4	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; ATTENTION:	Le fait d'crire directement dans le descripteur;		de la fentre fait que la trame est inverse;		entre le Smaky 8 et 100 (gauche <--> droite) !;		Il ne faut donc utiliser que des trames simples;		(pas de hachures par exemple).; ATTENTION:	Ne pas utiliser en mode ?BUCAR !!!; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	RET;--------\\; AFMENU  >;========/; Remet les soft-keys standards.; in	-; out	-; mod	-AFMENU:	PUSHM.L	D2,D3,D7,A3,A4	LOAD.L	A3,#R16"TICOBASE	LOAD.L	A4,#0	DBOX_	ICOAFF		; affiche les icnes en bas	LOAD.L	A3,#R16"TMENUBASE	LIB	?AFMENU	TEST.B	(A6)+OPLAY	; coute en cours ?	JUMP,F	40$		; non => 40$	LOAD.B	D3,#ICOSTOP	; oui =>	LOAD.W	D2,#4	CALL	AFFICONE	; dessine l'icne STOP40$:	CALL	AFFICONOTE	CALL	AFFICOFORCE	CALL	AFFICOPAS	POPM.L	D2,D3,D7,A3,A4	RET;-----------\\; AFFICONOTE >;===========/; Affiche la note choisie dans les soft-keys.; in	-; out	-; mod	D7.WAFFICONOTE:	PUSHM.L	D2,D3	LOAD.B	D3,#ICONOTEA	TEST.B	(A6)+ONOTE	JUMP,EQ 50$	LOAD.B	D3,#ICONOTEB50$:	LOAD.W	D2,#10		; D2 <-- dans (F10)	CALL	AFFICONE	POPM.L	D2,D3	RET;------------\\; AFFICOFORCE >;============/; Affiche la force choisie dans les soft-keys.; in	-; out	-; mod	D7.WAFFICOFORCE:	PUSHM.L	D2,D3	LOAD.B	D2,(A6)+OFORCE	LOAD.B	D3,#ICOFORCE1	COMP.B	D2,#1	JUMP,EQ 50$	LOAD.B	D3,#ICOFORCE2	COMP.B	D2,#2	JUMP,EQ 50$	LOAD.B	D3,#ICOFORCE3;	COMP.B	D2,#3;	JUMP,EQ 50$50$:	LOAD.W	D2,#11		; D2 <-- dans (F11)	CALL	AFFICONE	POPM.L	D2,D3	RET;----------\\; AFFICOPAS >;==========/; Affiche le pas choisi dans les soft-keys.; in	-; out	-; mod	D7.WAFFICOPAS:	PUSHM.L	D2,D3	LOAD.B	D2,(A6)+OPAS	LOAD.B	D3,#ICOPAS1	COMP.B	D2,#PAS1	JUMP,EQ 50$	LOAD.B	D3,#ICOPAS2	COMP.B	D2,#PAS2	JUMP,EQ 50$	LOAD.B	D3,#ICOPAS4	COMP.B	D2,#PAS4	JUMP,EQ 50$	LOAD.B	D3,#ICOPAS8;	COMP.B	D2,#PAS8;	JUMP,EQ 50$50$:	LOAD.W	D2,#12		; D2 <-- dans (F12)	CALL	AFFICONE	POPM.L	D2,D3	RET;---------\\; AFFICONE >;---------/; Affiche une icne dans les soft-keys.; in	D2.W	rang (1..15);	D3.B	code de l'icne; out	-; mod	D7.WAFFICONE:	PUSHM.L	D1..D5,A3,A4	LOAD.B	D1,D3		; D1 <-- code de l'icne	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.L	A3,#R16"TICOBASE	LOAD.L	A4,#0	LOAD.W	D3,#4	LIB	?STRING		; utilise le gencar des icnes	DBOX_	ICOPOS		; D3/D4 <-- pos/dim	JUMP,NE 80$	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- centre en X	SUB.W	D3,#LXICONE/2	; D3 <--  gauche de l'icne	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- centre en Y	ADD.W	D3,#GCICT/2-GCICB ; D3 <-- sur la ligne de base de l'icne	SWAP.W	D3;	SWAP.W	D4	LIB	?SETCURS	LOAD.B	D3,#AFINV	LIB	?AFCAR	LOAD.B	D3,D1		; D3 <-- code de l'icne	LIB	?AFCODE		; affiche l'icne	LOAD.B	D3,#AFDIR	LIB	?AFCAR80$:	LOAD.L	A3,#(A6)+OBDIS	LOAD.L	(A3),#H'1000000*USEGC+H'10000*GCTXF+H'100*GCTXS+H'1*GCTXT	LOAD.W	D3,#4	LIB	?STRING		; remet le gencar initial	LOAD.W	D5,(A6)+ONOWDO	LIB	?USEWDO		; utilise swdo dans cadre	POPM.L	D1..D5,A3,A4	RET;--------\\; IFMOUSE >;========/; Comme LIB,?IFMOUSE, mais ok dans swdo !; in	-; out	D4.L	position;	D3.W	boutons;	D7.W	erreur; mod	D3.L, D4.L, D7.WIFMOUSE:	LIB	?IFMOUSE	JUMP,NE 90$	LOAD.W	D7,#ERDIOUT	SUB.W	D4,(A0)+ODFFX	; dpasse  gauche ?	JUMP,LO 90$	COMP.W	D4,(A0)+ODFFDX	; dpasse  droite ?	JUMP,HS 90$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; dpasse en haut ?	JUMP,LO 90$	COMP.W	D4,(A0)+ODFFDY	; dpasse en bas ?	JUMP,HS 90$	SWAP.W	D4	CLR.W	D7		; D7 <-- ok90$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET	.END