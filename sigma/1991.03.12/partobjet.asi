	.SBTTL	PARTOBJET;--------\\; REFAIT  >;========/; Dessine compltement la mesure actuelle et les soft-keys.; in	D1.W	niveau; out	-; mod	D7.WREFAIT:	CALL	REDESSINE	CALL	MAJSOFTKEY	; mj "soft-keys" si ncessaire	RET;----------\\; REDESSINE >;==========/; Dessine compltement la mesure actuelle.; in	D1.W	niveau; out	-; mod	D7.WREDESSINE:	CALL	DESDEBUT	; efface tout	CALL	DESPORTEES	; dessine les portes	CALL	DESRESTE	; dessine le reste	CALL	DESNOTES	; dessine les notes	CALL	AFINFO		; mj les infos en haut	CALL	SCROLLUPDATE	; mj l'ascenseur	RET;---------\\; DESDEBUT >;=========/; Efface tout avant de commencer le dessin.; in	-; out	-; mod	D7.WDESDEBUT:	LIB	?AFTIM	.B	EOP		; efface tout	.B	PCURS,NOCURS	; si ncessaire, petit curseur	.B	MODGRA,GRACLIP	; mode graphique avec "clipping"	.B	0	.EVEN	RET;---------\\; DESRESTE >;=========/; Dessine le reste aprs DESPORTEE, c'est--dire l'altration;  la clef et les signes de reprise.; in	-; out	-; mod	D7.WDESRESTE:	PUSHM.L	D2,A4	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CALL	REPPORTEE	; dessine les signes de reprise	CALL	ALTERATIONS	; dessine les altrations  la clef	POPM.L	D2,A4	RET;----------\\; DESNOTES  >;==========/; Dessine toutes les notes de la mesure actuelle.; in	D1.W	niveau; out	-; mod	D7.WDESNOTES:	PUSHM.L	D2..D4,A4	CLR.L	(A6)+OBCLAST	; plus de barre dessine	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure20$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 80$	LOAD.B	D3,(A4)		; D3 <-- code	COMP.B	D3,#OBJMES	; dbut mesure suivante ?	JUMP',EQ 80$		; oui => 80$				; non =>	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CALL	DESQOBJET	; dessine un objet (ne rpte pas les barres)	JUMP	20$80$:	POPM.L	D2..D4,A4	RET;----------\\; IFHAUTBAS >;==========/; Test si deux symboles sont l'un en haut et l'autre en bas; (et vice-vera rciproquement entre eux l'un l'autre !).; in	A4.L	^symbole;	A3.L	^symbole; out	D7.W	zro	=> symboles croiss haut/bas;	D7.W	ERNOT	=> symboles pas croiss; mod	D7.WIFHAUTBAS:	PUSHM.L	D0,D3,D4	LOAD.W	D7,#ERSNOT	LOAD.B	D0,(A4)+OOBJC	COMP.B	D0,#ICOHRONDE	JUMP',LO 90$	COMP.B	D0,#ICOHSOUPIR	JUMP',HI 90$	LOAD.B	D4,(A4)+OSYFLG	LOAD.B	D0,(A3)+OOBJC	COMP.B	D0,#ICOHRONDE	JUMP',LO 90$	COMP.B	D0,#ICOHSOUPIR	JUMP',HI 90$	LOAD.B	D3,(A3)+OSYFLG	XOR.B	D3,D4	TEST.L	D3:#BSYBAS	JUMP',BC 90$	CLR.W	D7		; D7 <-- crois haut/bas90$:	POPM.L	D0,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DETRUIT >;========/; Supprime un objet quelconque dans la mesure courante.; in	A4.L	^objet  supprimer; out	-; mod	D7.WDETRUIT:	PUSHM.L	A3,A4	LOAD.L	A3,A4		; A3 <-- ^objet  dtruire20$:	CALL	RECULE	JUMP',NE 30$	COMP.L	A3,(A6)+OPDT	JUMP,LO 20$	CALL	DAVANCE		; dtruit l'objet30$:	CALL	GOMEND		; retourne  la fin de la mesure	POPM.L	A3,A4	RET;--------\\; GCOMPTE >;========/; Compte et marque les objets inclus dans la zone de modification; pour un groupe.; in	A4.L		^objet spcial (rectangle englobant); out	D2.W		nombre d'objets;	(A6)+OGCNTN.W	nombre de notes;	(A6)+OGCNTC.W	nombre de croches;	(A6)+OGCNTL.W	nombre de croches lies; mod	D2.L, D7.WGCOMPTE:	PUSHM.L	D0,D1,D3..D6,A3,A4	CLR.W	(A6)+OGCNTN	CLR.W	(A6)+OGCNTC	CLR.W	(A6)+OGCNTL	LOAD.L	D3,(A4)+OGRPN1	LOAD.L	D4,(A4)+OGRPN2	CALL	ORDONNE		; D3 < D4	LOAD.L	D0,D3	LOAD.L	D1,D4	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	CLR.W	D2		; D2 <- nb d'objets10$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP,NE 90$	LOAD.B	D3,(A4)+OOBJC	; D3 <-- code de l'objet	COMP.B	D3,#OBJMES	JUMP,EQ 90$	TEST.B	(A4)+OOBJF:#BGROUPE	JUMP,BS 30$	TCLR.B	(A4)+OOBJF:#BTAKE	CALL	GDETECTE	; inclu dans le rectangle ?	JUMP,NE 10$		; non => 10$	TSET.B	(A4)+OOBJF:#BTAKE	INC.W	D2		; D2 <-- un objet de plus	COMP.B	D3,#ICOBTCROCHE	JUMP,HI 10$	INC.W	(A6)+OGCNTN	; une note de plus	COMP.B	D3,#ICOHCROCHE	JUMP,LO 10$	COMP.B	D3,#ICOHTCROCHE	JUMP',LS 20$	COMP.B	D3,#ICOBCROCHE	JUMP,LO 10$;	COMP.B	D3,#ICOBTCROCHE;	JUMP,HI 10$20$:	INC.W	(A6)+OGCNTC	; une croche de plus	JUMP	10$30$:				; groupe de croches =>	LOAD.L	D4,(A4)+OSYNOB	; D4 <-- no du groupe	LOAD.L	A3,A4	CLR.W	D6		; D6 <-- nb total	CLR.W	D5		; D5 <-- nb inclu40$:	INC.W	D6		; D6 <-- un objet de plus	TCLR.B	(A4)+OOBJF:#BTAKE	CALL	GDETECTE	; inclu dans le rectangle ?	JUMP',NE 45$		; non => 45$	INC.W	D5		; D5 <-- un inclu de plus45$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 65$	LOAD.B	D3,(A4)+OOBJC	; D3 <-- code de l'objet	COMP.B	D3,#OBJMES	JUMP',EQ 60$	TEST.B	(A4)+OOBJF:#BGROUPE	JUMP',BC 60$	COMP.L	D4,(A4)+OSYNOB	; mme groupe ?	JUMP',EQ 40$60$:	CALL	PVISU		; recule l'objet avanc en trop65$:	COMP.W	D6,D5		; toutes les croches incluses ?	JUMP,NE 10$		; non => 10$				; oui =>	INC.W	(A6)+OGCNTN	; une note de plus	INC.W	(A6)+OGCNTC	; une croche de plus	INC.W	(A6)+OGCNTL	; une croche lie de plus	LOAD.L	A4,A3		; A4 <-- ^premire croche lie70$:	TSET.B	(A4)+OOBJF:#BTAKE	INC.W	D2		; D2 <-- un objet de plus	DEC.W	D6	JUMP,EQ 10$	CALL	NVISU		; A4 <-- ^objet suivant	JUMP	70$90$:	POPM.L	D0,D1,D3..D6,A3,A4	RET;---------\\; GDETECTE >;---------/; Dtecte si un objet est inclu dans un rectangle.; in	A4.L	^objet;	D0.L	coin sup/gauche (y;x);	D1.L	coin inf/droite (y;x); out	D7.W	inclu/ou pas; mod	D7.WGDETECTE:	PUSHM.L	D0,D1,D3,D4	CALL	DIMOBJET	; D3 <-- P1 et D4 <-- P2	JUMP',NE 90$	LOAD.W	D7,#ERSNOT	; D7 <-- pas inclu	COMP.W	D3,D0	JUMP',LO 90$	COMP.W	D3,D1	JUMP',HS 90$	COMP.W	D4,D0	JUMP',LO 90$	COMP.W	D4,D1	JUMP',HS 90$	SWAP.W	D0	SWAP.W	D1	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D0	JUMP',LO 90$	COMP.W	D3,D1	JUMP',HS 90$	COMP.W	D4,D0	JUMP',LO 90$	COMP.W	D4,D1	JUMP',HS 90$	CLR.W	D7		; D7 <-- inclu90$:	POPM.L	D0,D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GNOTAKE >;========/; Enlve tous les flags BTAKE dans la mesure.; in	-; out	-; mod	D7.WGNOTAKE:	PUSH.L	A4	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure10$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 90$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP',EQ 90$	TCLR.B	(A4)+OOBJF:#BTAKE	TCLR.B	(A4)+OOBJF:#BNEW	JUMP	10$90$:	POP.L	A4	RET;---------\\; GDETRUIT >;=========/; Dtruit tous les objets d'un groupe.; in	-; out	-; mod	D7.WGDETRUIT:	PUSHM.L	A4	CALL	GOMBEGIN	; revient au dbut de la mesure10$:	CALL	AVANCE	JUMP',NE 90$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP',EQ 80$	TEST.B	(A4)+OOBJF:#BTAKE	JUMP,BC 10$	CALL	TAKEOBJET	; efface l'objet	CALL	DRECULE		; dtruit l'objet	JUMP	10$80$:	CALL	RECULE		; recule sur le dbut de la mesure90$:	CALL	DESPORTEES	; refait les portes	POPM.L	A4	RET;----------\\; GDUPLIQUE >;==========/; Duplique tous les objets d'un groupe.; in	A4.L	^objet spcial rectangle englobant; out	-; mod	D7.WGDUPLIQUE:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,A4		; A3 <-- ^objet rectangle	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	CLR.W	D3		; D3 <-- nb d'objets dupliqus10$:	CALL	NVISU	JUMP',NE 30$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP',EQ 30$	TEST.B	(A4)+OOBJF:#BNEW	JUMP',BS 30$	TEST.B	(A4)+OOBJF:#BTAKE	JUMP,BC 10$	TSET.B	(A4)+OOBJF:#BNEW	LOAD.W	D4,(A4)-2	; D4 <-- longueur	CALL	INSERT		; duplique un objet	JUMP',NE 20$	TCLR.B	(A4)+OOBJF:#BTAKE	TCLR.B	(A4)+OOBJF:#BNEW	INC.W	D3		; D3 <-- un objet cre de plus	JUMP	10$20$:				; plus de place =>	TEST.W	D3	JUMP',EQ 25$	DEC.W	D3	PUSH.W	D7	CALL	DRECULE		; dtruit les qq objets crs	POP.W	D7	JUMP	20$25$:	PUSH.W	D7	CALL	GNOTAKE		; enlve tous les bits BTAKE	POP.W	D7	JUMP'	90$30$:	LOAD.L	A4,A3		; A4 <-- ^objet rectangle	CALL	GDEPLACE	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; GDEPLACE >;=========/; Dplace tous les objets d'un groupe.; in	A4.L	^objet spcial rectangle englobant; out	-; mod	D7.WGDEPLACE:	PUSHM.L	D0..D5,A3,A4	CALL	CCMO		; cache la souris; Efface tous les objets  dplacer.	LOAD.L	A3,A4		; A3 <-- ^objet rectangle	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure10$:	CALL	NVISU	JUMP',NE 12$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP',EQ 12$	TEST.B	(A4)+OOBJF:#BTAKE	JUMP,BC 10$	CALL	TAKEOBJET	; efface l'objet	JUMP	10$12$:	EX.L	A4,A3	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface le rectangle	CALL	DESPORTEES	; refait les portes	CALL	DESOBJET	; redessine le rectangle	EX.L	A3,A4	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure; Redessine tous les objets  dplacer en mode inverse.	CLR.L	(A6)+OBCLAST	; plus de barre dessine13$:	CALL	NVISU	JUMP',NE 15$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP',EQ 15$	TEST.B	(A4)+OOBJF:#BTAKE	JUMP,BC 13$	LOAD.W	D2,#INVDOT	CALL	DESQOBJET	; puis redessine-le en inverse	JUMP	13$15$:	LOAD.L	D4,(A3)+OGRPN2	; D4 <-- coin mobile du rectangle	PUSH.L	D4	ADD.W	D4,(A0)+ODFFX	SWAP.W	D4	ADD.W	D4,(A0)+ODFFY	SWAP.W	D4	CALL	PMOUSE		; remet la souris o elle tait	POP.L	D4;;?	CALL	IFMOUSE	CALL	RNDOBJET	; D4 <-- arrondi la position de la souris	LOAD.L	D5,D4		; D5 <-- position souris initiale	CALL	PRNDOBJET	LOAD.L	D1,D4		; D1 <-- position arrondie spcialement20$:	LIB	?GETKEY		; attend souris...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 50$	CALL	IFMOUSE		; D4 <-- position de la souris	CALL	RNDOBJET	; D4 <-- arrondi la position de la souris	COMP.L	D4,D5		; autre position ?	JUMP,EQ 20$		; non => 20$	LOAD.L	D0,D4	CALL	PRNDOBJET	; D0 <-- arrondi pour qq symboles spciaux	EX.L	D0,D4	PUSH.L	D4	SUB.W	D4,D5		; D4 <-- dplacement en X	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D5		; D4 <-- dplacement en Y	SWAP.W	D4	POP.L	D5	PUSH.L	D0	SUB.W	D0,D1		; D0 <-- dplacement en X	SWAP.W	D0	SWAP.W	D1	SUB.W	D0,D1		; D0 <-- dplacement en Y	SWAP.W	D0	POP.L	D1	EX.L	A4,A3	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface l'ancien rectangle	ADD.W	(A4)+OGRPN1+2,D4	SWAP.W	D4	ADD.W	(A4)+OGRPN1+0,D4	SWAP.W	D4	ADD.W	(A4)+OGRPN2+2,D4	SWAP.W	D4	ADD.W	(A4)+OGRPN2+0,D4	SWAP.W	D4	CALL	DESOBJET	; dessine le nouveau rectangle	EX.L	A3,A4; Dplace et redessine tous les objets.30$:	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	CALL	NVISU		; A4 <-- ^aprs l'objet mesure32$:	COMP.B	(A4)+OOBJC,#OBJMES	JUMP,EQ 20$	TEST.B	(A4)+OOBJF:#BTAKE	JUMP',BC 35$	LOAD.W	D2,#INVDOT	CALL	DESGOBJET	; efface l'ancien objet/groupe	CALL	DPLGOBJET	; dplace l'objet/groupe	CALL	DESGOBJET	; dessine le nouvel objet/groupe35$:	CALL	GNVISU		; A4 <-- ^objet/groupe suivant	JUMP,NE 20$	JUMP	32$; Redessine tous les objets dplacs en mode "or".50$:	CLR.L	(A6)+OBCLAST	; plus de barre dessine	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure60$:	CALL	NVISU	JUMP',NE 90$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP',EQ 90$	TEST.B	(A4)+OOBJF:#BTAKE	JUMP,BC 60$	LOAD.W	D2,#SETDOT	CALL	DESQOBJET	; redessine tous les objets correctement	JUMP	60$90$:	LOAD.L	A4,A3		; A4 <-- ^objet rectangle	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface le dernier rectangle	CALL	SCMO		; remet la souris	CALL	GNOTAKE		; enlve tous les bits BTAKE	POPM.L	D0..D5,A3,A4	RET;----------\\; DPLGOBJET >;----------/; Dplace un objet ou un groupe.; in	A4.L	^objet/groupe;	D4.L	dplacement +/- (dy;dx);	D0.L	dplacement +/- (dy;dx) avec arrondi spcial; out	-; mod	D7.WDPLGOBJET:	PUSHM.L	D2,D3,A4	TEST.B	(A4)+OOBJF:#BGROUPE	JUMP',BC 80$				; groupe de croches =>	LOAD.L	D2,(A4)+OSYNOB	; D2 <-- no du groupe20$:				; oui =>	CALL	DPLOBJET	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 90$	TEST.B	(A4)+OOBJF:#BGROUPE	JUMP',BC 90$	COMP.L	D2,(A4)+OSYNOB	; mme groupe ?	JUMP',EQ 20$		; oui => 20$	JUMP'	90$80$:	CALL	DPLOBJET	; dplace l'objet90$:	POPM.L	D2,D3,A4	RET;---------\\; DPLOBJET >;---------/; Dplace un objet.; in	A4.L	^objet;	D4.L	dplacement +/- (dy;dx);	D0.L	dplacement +/- (dy;dx) avec arrondi spcial; out	-; mod	D7.WDPLOBJET:	PUSHM.L	D3,D4	LOAD.B	D3,(A4)+OOBJC	; D3 <-- code de l'objet	COMP.B	D3,#H'80	JUMP',HS 90$	COMP.B	D3,#ICODROITE	JUMP',HS 40$				; symbole musical =>	CALL	IFRNDOBJET	; arrondi ncessaire ?	JUMP',NE 20$		; non => 20$	LOAD.L	D4,D0		; oui => arrondi selon D0 !20$:	ADD.W	(A4)+OSYPOS+2,D4	SWAP.W	D4	ADD.W	(A4)+OSYPOS+0,D4	SWAP.W	D4	JUMP'	90$40$:	ADD.W	(A4)+OGRPN1+2,D4	SWAP.W	D4	ADD.W	(A4)+OGRPN1+0,D4	SWAP.W	D4	COMP.B	D3,#ICOCERCLE	JUMP',EQ 90$	ADD.W	(A4)+OGRPN2+2,D4	SWAP.W	D4	ADD.W	(A4)+OGRPN2+0,D4	SWAP.W	D490$:	POPM.L	D3,D4	RET;---------\\; GFRAPPE  >;=========/; Modifie la force de frappe de tous les objets d'un groupe.; in	D3.W	nouvelle force de frappe (mmenu: 1..5); out	-; mod	D7.WGFRAPPE:	PUSHM.L	D3,A3,A4	LOAD.L	A3,#(A6)+OFRAPPE	SUB.W	D3,#MAXSFRAPPE	NEG.W	D3		; D3 <-- 0..n	LOAD.B	D3,(A3)+(D3.W)	CALL	GOMBEGIN	; revient au dbut de la mesure10$:	CALL	AVANCE	JUMP',NE 90$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP',EQ 80$	TEST.B	(A4)+OOBJF:#BTAKE	JUMP,BC 10$	COMP.B	(A4)+OOBJC,#ICOBRONDE ; est-ce une note ?	JUMP,HS 10$		; non => 10$				; oui =>	LOAD.B	(A4)+OSYFRAP,D3	; mj. nouvelle force de frappe	JUMP	10$80$:	CALL	RECULE		; recule sur le dbut de la mesure90$:	POPM.L	D3,A3,A4	RET;--------\\; GBARRE  >;========/; Lie toutes les croches d'un groupe d'objets.; in	-; out	-; mod	D7.WGBARRE:	PUSHM.L	D4,D5,A3,A4	CALL	BARRENEW	; lie une nouvelle srie de croches10$:	CALL	GOMBEGIN	; revient au dbut de la mesure	CLR.W	D4		; D4 <-- rien trouv20$:	CALL	AVANCE	JUMP',NE 50$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP',EQ 40$	TEST.B	(A4)+OOBJF:#BTAKE	JUMP,BC 20$	CALL	BARREONE	; lie une croche	JUMP,NE 20$	INC.W	D4		; D4 <-- trouv une croche de plus	JUMP	20$40$:	CALL	RECULE		; recule sur le dbut de la mesure50$:	TEST.W	D4		; trouv une ou plusieures croches ?	JUMP,NE 10$		; oui => 10$				; non =>	CALL	BARREMAKE	; lie toutes les croches choisies	POPM.L	D4,D5,A3,A4	RET;--------\\; DETECTE >;========/; Dtecte dans quel symbole est la souris, sans se dplacer; dans le buffer.; Coins trouvs dans D2.W :;	D2.W	(y;x)	1=PN1 et 2=PN2;	1	(1;1);	2	(2;2);	3	(1;2);	4	(2;1);	-1	tous; in	D4.L	position de la souris; out	A4.L	^symbole trouv;	D2.W	zro	=> symbole musical;		autre	=> coins trouvs;	D7.W	ERNOT	=> pas trouv; mod	D2.L, D7.W, A4.LDETECTE:	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure10$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 20$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP',EQ 20$	CALL	DETECTE1	; est-on au centre de cet objet ?	JUMP',EQ 90$		; oui => 90$	JUMP	10$20$:	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure30$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 40$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP',EQ 40$	CALL	DETECTE2	; est-on dans cet objet ?	JUMP',EQ 90$		; oui => 90$	JUMP	30$40$:	LOAD.W	D7,#ERSNOT	; D7 <-- pas trouv90$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; DETECTE1 >;---------/; Dtecte dans quel extrmit d'objet est la souris.; Coins trouvs dans D2.W :;	D2.W	(y;x)	1=PN1 et 2=PN2;	1	(1;1);	2	(2;2);	3	(1;2);	4	(2;1); in	A4.L	^objet;	D4.L	position de la souris; out	D2.W	zro	=> symbole musical;		autre	=> coins trouvs;	D7.W	ERNOT	=> pas trouv; mod	D2.L, D7.W, A4.LDETECTE1:	PUSHM.L	D3..D5	LOAD.L	D5,D4		; D4 <-- position souris en X	SWAP.W	D5		; D5 <-- position souris en Y	LOAD.W	D7,#ERSNOT	; D7 <-- on est pas dedans	LOAD.B	D3,(A4)		; D3 <-- code du symbole	COMP.B	D3,#H'80	; symbole spcial ?	JUMP,HS 90$		; oui => 90$	COMP.B	D3,#ICODROITE	JUMP',HS 30$				; symbole musical =>	CLR.W	D2		; D2 <-- symbole musical	LOAD.L	D3,(A4)+OSYPOS	; D3 <-- position du symbole	CALL	DETPOINT	; est-on sur ce point ?	JUMP	90$30$:				; objet graphique =>	COMP.B	D3,#ICOTEXTE	JUMP',EQ 90$	LOAD.W	D2,#1	COMP.B	D3,#ICORECTANGLE	JUMP',EQ 40$	COMP.B	D3,#ICOCERCLE	JUMP',EQ 50$				; droite =>	LOAD.L	D3,(A4)+OGRPN1	CALL	DETPOINT	; est-on sur ce point ?	JUMP',EQ 90$		; oui => 90$	INC.W	D2	LOAD.L	D3,(A4)+OGRPN2	CALL	DETPOINT	; est-on sur ce point ?	JUMP'	90$		; oui => 90$40$:				; rectangle =>				; D2 <-- un: (1,1)	LOAD.L	D3,(A4)+OGRPN1	CALL	DETPOINT	; est-on sur ce point ?	JUMP',EQ 90$		; oui => 90$	INC.W	D2		; D2 <-- deux: (2,2)	LOAD.L	D3,(A4)+OGRPN2	CALL	DETPOINT	; est-on sur ce point ?	JUMP',EQ 90$		; oui => 90$	INC.W	D2		; D2 <-- trois: (1,2)	LOAD.W	D3,(A4)+OGRPN1+0	SWAP.W	D3	LOAD.W	D3,(A4)+OGRPN2+2	CALL	DETPOINT	; est-on sur ce point ?	JUMP',EQ 90$		; oui => 90$	INC.W	D2		; D2 <-- quatre: (2,1)	LOAD.W	D3,(A4)+OGRPN2+0	SWAP.W	D3	LOAD.W	D3,(A4)+OGRPN1+2	CALL	DETPOINT	; est-on sur ce point ?	JUMP'	90$		; oui => 90$50$:				; cercle =>	LOAD.L	D3,(A4)+OGRPN1	CALL	DETPOINT	; est-on sur le centre ?;	JUMP'	90$		; oui => 90$90$:	POPM.L	D3..D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DETECTE2 >;---------/; Dtecte dans quel plein d'objet est la souris.; in	A4.L	^objet;	D4.L	position de la souris; out	D2.W	zro	=> symbole musical;		-1	=> objet graphique;	D7.W	ERNOT	=> pas trouv; mod	D2.L, D7.W, A4.LDETECTE2:	PUSHM.L	D3..D5	LOAD.L	D5,D4		; D5 <-- position de la souris	CALL	DIMOBJET	; D3 <-- P1 et D4 <-- P2	JUMP',NE 90$	LOAD.W	D7,#ERSNOT	; D7 <-- pas trouv	COMP.W	D5,D3		; souris trop  gauche ?	JUMP',LO 90$	COMP.W	D5,D4		; souris trop  droite ?	JUMP',HS 90$	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	COMP.W	D5,D3		; souris trop en haut ?	JUMP',LO 90$	COMP.W	D5,D4		; souris trop en bas ?	JUMP',HS 90$	CLR.W	D2		; D2 <-- symbole musical	COMP.B	(A4)+OOBJC,#ICODROITE	JUMP',LO 80$	LOAD.W	D2,#-1		; D2 <-- objet graphique80$:	CLR.W	D7		; D7 <-- on est dans cet objet90$:	POPM.L	D3..D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DIMOBJET >;---------/; Donne les dimensions d'un objet quelconque.; in	A4.L	^objet; out	D3.L	P1(y;x) en haut  gauche;	D4.L	P2(y;x) en bas  droite;	D7.W	erreur; mod	D3.L, D4.L, D7.WDIMOBJET:	PUSHM.L	D2,A1	LOAD.W	D7,#ERSNOT	; D7 <-- pas un objet	LOAD.B	D3,(A4)		; D3 <-- code du symbole	COMP.B	D3,#H'80	; symbole spcial ?	JUMP,HS 90$		; oui => 90$	COMP.B	D3,#ICODROITE	JUMP',HS 30$				; symbole musical =>	TEST.B	(A4)+OOBJF:#BGROUPE ; croche lie ?	JUMP',BC 20$		; non => 20$	LOAD.B	D3,#ICOHNOTE	; oui => prend croche sans queue20$:	TEST.B	(A4)+OSYFLG:#BSYNOQ ; note sans queue ?	JUMP',BC 25$		; non => 25$	LOAD.B	D3,#ICOHNOTE	; oui => prend croche sans queue25$:	CALL	SRCTSYMB	; A1 <-- ^descripteur du symbole	JUMP,NE 90$	LOAD.W	D4,(A4)+OSYPOS+0	ADD.W	D4,(A1)+OTSCY	; D4 <-- <yy> en bas	LOAD.W	D3,D4	SUB.W	D3,(A1)+OTSDY	; D3 <-- <yy> en haut	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A4)+OSYPOS+2	SUB.W	D3,(A1)+OTSCX	; D3 <-- <xx>  gauche	LOAD.W	D4,D3	ADD.W	D4,(A1)+OTSDX	; D4 <-- <xx>  droite	JUMP	80$30$:				; objet graphique =>	LOAD.B	D2,D3		; D2 <-- code de l'objet	LOAD.L	D3,(A4)+OGRPN1	LOAD.L	D4,(A4)+OGRPN2	COMP.B	D2,#ICODROITE	JUMP',EQ 40$	COMP.B	D2,#ICOHCOURBE	JUMP',EQ 50$	COMP.B	D2,#ICOBCOURBE	JUMP',EQ 55$	COMP.B	D2,#ICOCERCLE	JUMP',NE 80$				; cercle =>	LOAD.W	D2,D4		; D2 <-- rayon	LOAD.L	D4,D3	SUB.W	D3,D2	ADD.W	D4,D2	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D2	ADD.W	D4,D2	SWAP.W	D3	SWAP.W	D4	JUMP'	80$40$:				; droite =>	CLR.W	D2	LOAD.B	D2,(A4)+OGREP	; D2 <-- paisseur du trait	ADD.W	D4,D2	SWAP.W	D4	ADD.W	D4,D2	SWAP.W	D4	JUMP'	80$50$:				; courbe haute =>	CALL	ORDONNE	SWAP.W	D4	ADD.W	D4,#LYCOURBE	SWAP.W	D4	JUMP'	57$55$:				; courbe basse =>	CALL	ORDONNE	SWAP.W	D3	SUB.W	D3,#LYCOURBE	SWAP.W	D357$:	CLR.W	D2	LOAD.B	D2,(A4)+OGREP	; D2 <-- paisseur du trait	SWAP.W	D4	ADD.W	D4,D2	SWAP.W	D4	JUMP'	85$80$:	CALL	ORDONNE		; D3 < D485$:	CLR.W	D7		; D7 <-- objet existe90$:	POPM.L	D2,A1	TEST.W	D7		; retour EQ/NE	RET;--------\\; ORDONNE >;--------/; Met le point P1 en haut  gauche de P2.; in	D3.L	P1(y;x);	D4.L	P2(y;x); out	D3.L	P1(y;x) < P2;	D4.L	P2(y;x); mod	D3.L, D4.LORDONNE:	PUSH.W	D2	COMP.W	D3,D4	JUMP',LS 10$	LOAD.W	D2,D3	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D210$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',LS 20$	LOAD.W	D2,D3	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D220$:	SWAP.W	D3	SWAP.W	D4	POP.W	D2	RET;---------\\; DETPOINT >;---------/; Dtecte si la souris est sur un point donn, avec une; petite marge tout autour.; in	D3.L	point (y;x);	D4.L	souris (y;x); out	D7.W	erreur; mod	D7.WDETPOINT:	PUSHM.L	D3,D4	LOAD.W	D7,#ERSNOT	; D7 <-- pas trouv	SUB.W	D3,#MDETECTE	COMP.W	D4,D3		; souris trop  gauche ?	JUMP',LO 90$		; oui => 90$	ADD.W	D3,#MDETECTE*2	COMP.W	D4,D3		; souris trop  droite ?	JUMP',HS 90$		; oui => 90$	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#MDETECTE	COMP.W	D4,D3		; souris trop haute ?	JUMP',LO 90$		; oui => 90$	ADD.W	D3,#MDETECTE*2	COMP.W	D4,D3		; souris trop basse ?	JUMP',HS 90$		; oui => 90$	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; GETPOINT >;=========/; Donne le point concern d'un objet.; in	A4.L	^objet;	D2.W	coins; out	D3.L	point (y;x); mod	D3.LGETPOINT:	LOAD.L	D3,(A4)+OSYPOS	TEST.W	D2	JUMP',EQ 90$	LOAD.L	D3,(A4)+OGRPN1	COMP.W	D2,#1	JUMP',EQ 90$	LOAD.L	D3,(A4)+OGRPN2	COMP.W	D2,#2	JUMP',EQ 90$	LOAD.W	D3,(A4)+OGRPN1+0	SWAP.W	D3	LOAD.W	D3,(A4)+OGRPN2+2	COMP.W	D2,#3	JUMP',EQ 90$	LOAD.W	D3,(A4)+OGRPN2+0	SWAP.W	D3	LOAD.W	D3,(A4)+OGRPN1+2	COMP.W	D2,#4	JUMP',EQ 90$	LOAD.L	D3,(A4)+OGRPN190$:	RET;---------\\; PUTPOINT >;=========/; Met le point concern dans un objet.; in	A4.L	^objet;	D2.W	coins;	D3.L	point (y;x); out	-; mod	-PUTPOINT:	PUSHM.L	D3,D4	TEST.W	D2	JUMP',EQ 20$	COMP.W	D2,#1	JUMP',EQ 30$	COMP.W	D2,#2	JUMP',EQ 40$	COMP.W	D2,#3	JUMP',EQ 50$	COMP.W	D2,#4	JUMP',EQ 60$	LOAD.L	D4,(A4)+OGRPN1	LOAD.L	(A4)+OGRPN1,D3	COMP.B	(A4)+OOBJC,#ICOCERCLE	JUMP',EQ 90$	SUB.W	D3,D4	ADD.W	(A4)+OGRPN2+2,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	ADD.W	(A4)+OGRPN2+0,D3	SWAP.W	D3	SWAP.W	D4	JUMP'	90$20$:	LOAD.L	(A4)+OSYPOS,D3	JUMP'	90$30$:	LOAD.L	(A4)+OGRPN1,D3	JUMP'	90$40$:	LOAD.L	(A4)+OGRPN2,D3	JUMP'	90$50$:	SWAP.W	D3	LOAD.W	(A4)+OGRPN1+0,D3	SWAP.W	D3	LOAD.W	(A4)+OGRPN2+2,D3	JUMP'	90$60$:	SWAP.W	D3	LOAD.W	(A4)+OGRPN2+0,D3	SWAP.W	D3	LOAD.W	(A4)+OGRPN1+2,D3;	JUMP'	90$90$:	POPM.L	D3,D4	RET;----------\\; TAKEOBJET >;==========/; Efface un objet pour le dplacer ou pour le dtruire.; Il faut encore redessiner les portes !; in	A4.L	^objet  prendre; out	-; mod	D7.WTAKEOBJET:	PUSHM.L	D0..D4,A3,A4	LOAD.W	D2,#CLRDOT	CALL	DESOBJET	; efface l'objet  prendre	CALL	DIMOBJET	; D3,D4 <-- dimensions de l'objet  prendre	LOAD.L	D0,D3		; D0 <-- P1(y;x)	LOAD.L	D1,D4		; D1 <-- P2(y;x)	LOAD.L	A3,A4		; A3 <-- ^objet  prendre	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut mesure10$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 50$	COMP.B	(A4)+OOBJC,#OBJMES ; dbut de la mesure suivante ?	JUMP',EQ 50$		; oui => 50$	COMP.L	A4,A3		; objet  prendre ?	JUMP,EQ 10$		; oui => 10$	TEST.B	(A4)+OOBJF:#BTAKE	JUMP,BS 10$	CALL	DIMOBJET	; D3,D4 <-- dimension de l'objet	JUMP,NE 10$	COMP.W	D4,D0	JUMP,LO 10$	COMP.W	D3,D1	JUMP,HI 10$	SWAP.W	D0	SWAP.W	D1	SWAP.W	D3	SWAP.W	D4	COMP.W	D4,D0	JUMP',LO 30$	COMP.W	D3,D1	JUMP',HI 30$	SWAP.W	D1	SWAP.W	D0	LOAD.W	D2,#SETDOT	CALL	DESOBJET	; refait un objet partiellement effac	JUMP	10$30$:	SWAP.W	D1	SWAP.W	D0	JUMP	10$50$:	POPM.L	D0..D4,A3,A4	RET;----------\\; DESGOBJET >;==========/; Dessine un objet quelconque. Si cet objet fait partie d'un; groupe, dessine tout le groupe.; in	A4.L	^objet quelconque;	D2.W	mode de dessin; out	-; mod	D7.WDESGOBJET:	PUSHM.L	D4,A4	TEST.B	(A4)+OOBJF:#BGROUPE	JUMP',BC 80$	LOAD.L	D4,(A4)+OSYNOB	; D4 <-- no du groupe	CLR.L	(A6)+OBCLAST	; plus de barre dessine20$:	CALL	DESQOBJET	; dessine une croche lie	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 90$	TEST.B	(A4)+OOBJF:#BGROUPE	JUMP',BC 90$	COMP.L	D4,(A4)+OSYNOB	; mme groupe ?	JUMP',EQ 20$		; oui => 20$	JUMP'	90$80$:	CALL	DESOBJET	; dessine un objet unique90$:	POPM.L	D4,A4	RET;---------\\; DESOBJET >;=========/; Dessine un objet quelconque.; in	A4.L	^objet quelconque;	D2.W	mode de dessin; out	-; mod	D7.WDESOBJET:	CLR.L	(A6)+OBCLAST	; plus de barre dessineDESQOBJET:	COMP.B	(A4)+OOBJC,#ICOTEXTE	JUMP',EQ 70$	COMP.B	(A4)+OOBJC,#ICODROITE	JUMP',HS 50$	JUMP	DESSYMB		; dessine un symbole musical50$:	JUMP	DESGRA		; dessine un objet graphique70$:	JUMP	DESTEXTE	; dessine une ligne de texte	.END