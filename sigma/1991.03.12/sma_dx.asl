  ;     ;	.ASCIZ	"(1..8)"	.ASCIZ	"Instrument"		;     ;     ;     ;	.ASCIZ	"Accs  la"	.ASCIZ	"configuration"	.ENDIFNMDBOX:	.ASCIZ	"DBOX"NMLIST:	.ASCIZ	"LIST"LMIDI:	.ASCIZ	"#MIDI:"PMIDI:	.ASCIZ	"$MIDI_0"DMIDI:	.ASCIZ	"MIDI_0"CMSYNC:	.ASCIZ	"S"		; commande de synchronisation	.IF	DX7TXEXT:	.ASCIZ	".dx"	.ENDIF	.IF	DX100TXEXT:	.ASCIZ	".dx100"	.ENDIF	.IF	FB01TXCEXT:	.ASCIZ	".cfb1"		; pas plus de 4 lettres (.part) !	.ENDIF	.EVENEND_DX:	.END