	.TITLE	SMA_DX.ASL;	--------------------------------------;		(C) 1985 - Daniel Roux;	--------------------------------------;	Source des parties dpendantes d'un;	synthtiseur donn.;	Ce fichier permet de gnrer les modules;	pour les synthtiseurs suivants :;		Yamaha DX7;		Yamaha DX100 ou DX27;		Yamaha FB01	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES; Assemblage conditionnel; -----------------------DX7	=	0		; Yamaha DX7DX100	=	0		; Yamaha DX27 et DX100FB01	=	1		; Yamaha FB01MAJREV	=	1		; rvisionMINREV	=	2		; version	.REV	MAJREV,MINREV; Numros des appels; ------------------	.IF	DX7NMBASE	=	H'A8E0	.ENDIF	.IF	DX100NMBASE	=	H'AA00	.ENDIF	.IF	FB01NMBASE	=	H'AA10	.ENDIFDX_ID	=	NMBASE+0	; identificateurDX_OPEN	=	NMBASE+1	; ouvreDX_EDIT	=	NMBASE+2	; dite ...DX_CLOSE=	NMBASE+3	; fermeDX_USE	=	NMBASE+4	; utilise un sonDX_GET	=	NMBASE+5	; donne le son utilisDX_FIRST=	DX_IDDX_LAST=	DX_GET; En-tte d'un fichier .IMAGE; ---------------------------	.LOC	0OIMTYP:	.BLKB	1		; H'01 = indique type imageOIMCOD:	.BLKB	1		; H'00 = indique pas de codageOIMBIP:	.BLKB	1		; H'01 = 1 bit par pointOIMDIR:	.BLKB	1		; H'02 = coord. X-Y comme cranOIMDLX:	.BLKB	2		; largeur image en pointsOIMDLY:	.BLKB	2		; hauteur image en pointsOIMNBB:	.BLKB	4		; nb de byte pour l'image	.BLKB	20		; rserveLGHIMA:; Constantes; ----------GCICF	=	'I		; fonte des icnesGCICS	=	'S		; style/chasse des icnesGCICT	=	24		; taille des icnesGCTXF	=	'N		; fonte du texteGCTXS	=	'R!2^7		; style/chasse du texteGCTXT	=	09		; taille du texteGCPTF	=	'N		; fonte petiteGCPTS	=	'E!2^7		; style/chasse petitGCPTT	=	07		; taille petiteNBCOL	=	4		; nb de colonnes	.IF	DX7NBLI	=	8		; nb de lignes (zone principale)NBLJ	=	5		; nb de lignes (zone secondaire)	.ENDIF	.IF	DX100NBLI	=	6		; nb de lignes (zone principale)NBLJ	=	6		; nb de lignes (zone secondaire)	.ENDIF	.IF	FB01NBLI	=	12		; nb de lignes (zone principale)NBLJ	=	0		; nb de lignes (zone secondaire)	.ENDIF	.IF	DX7PDXNAME	=	118		; offset o trouver le nom d'un timbreLDXNAME	=	10		; lg d'un nom de timbreLTIMBRE	=	128		; lg d'un timbreLFDX	=	8+(32*LTIMBRE)	; lg d'un fichier .DXLBUF	=	LFDX+20		; lg buffer pour dataLBUG	=	NBCOL*NBLJ*LTIMBRE ; lg buffer secondaire	.ENDIF	.IF	DX100PDXNAME	=	57		; offset o trouver le nom d'un timbreLDXNAME	=	10		; lg d'un nom de timbreLTIMBRE	=	128		; lg d'un timbreLFDX	=	8+(32*LTIMBRE)	; lg d'un fichier .DX100LBUF	=	LFDX+20		; lg buffer pour dataLBUG	=	NBCOL*NBLJ*LTIMBRE ; lg buffer secondaire	.ENDIF	.IF	FB01PDXNAME	=	0		; offset o trouver le nom d'un timbreLDXNAME	=	7		; lg d'un nom de timbreLTIMBRE	=	H'10		; lg d'une configurationLFDX	=	11+H'20+LTIMBRE*8 ; lg d'un fichier .FB01LBUF	=	LFDX+20		; lg buffer pour data configurations	.ENDIFLBUFILE	=	32		; lg max d'un nom de fichier	.INS	ICONE24.ASI	; icnes de ISP24	.IF	DX7; Boutons du DX7; --------------KDX7NUM		=	-1	; 1 .. 32KDX7STORE	=	32	; STOREKDX7PINT	=	33	; MEMORY PROTECT: INTERNALKDX7PCART	=	34	; MEMORY PROTECT: CARTRIDGEKDX7OPS		=	35	; OPERATOR SELECTKDX7EDIT	=	36	; EDIT/COMPAREKDX7SINT	=	37	; MEMORY SELECT: INTERNALKDX7SCART	=	38	; MEMORY SELECT: CARTRIDGEKDX7FUNC	=	39	; FUNCTIONKDX7OFF		=	40	; -1  NO   OFFKDX7ON		=	41	; +1  YES  ON	.ENDIF	.IF	DX100; Boutons du DX100; ----------------KDX100NUM	=	-1	; 1 .. 24KDX100OPS	=	32	; OPERATOR SELECTKDX100SHIFT	=	33	; KEY SHIFTKDX100OFF	=	34	; -1  NO   OFFKDX100ON	=	35	; +1  YES  ONKDX100STORE	=	24	; STOREKDX100FUNC	=	25	; FUNCTIONKDX100EDIT	=	26	; EDIT/COMPAREKDX100INT	=	27	; INTERNALKDX100BANKA	=	28	; BANK AKDX100BANKB	=	29	; BANK BKDX100BANKC	=	30	; BANK CKDX100BANKD	=	31	; BANK D	.ENDIF; Descripteur d'un paramtre de timbre; ------------------------------------BDSINFO	=	7		; informationTDSTEXT	=	1!2^BDSINFO	; type texte fixeTDSNUM	=	2		; type numriqueTDSNUMS	=	3		; type numrique signTDSNUM2	=	4		; type numrique sign en complment  deux	.IF	DX7TDSFREQH=	5		; type frquence DX7 highTDSFREQL=	6!2^BDSINFO	; type frquence DX7 lowTDSFREQM=	7!2^BDSINFO	; type frquence DX7 mode	.ENDIF	.IF	DX100TDSFREQH=	5		; type frquence DX100	.ENDIF	.IF	FB01TDSFREQH=	5		; type frquence FB01	.ENDIFTDSLIST	=	8		; type listeTDSNOTE	=	9		; type noteTDSALGO	=	10		; type algorithme	.IF	FB01TDSSON	=	11!2^BDSINFO	; type son dans une banque	.ENDIFTDSONOFF=	12		; sous-type on/offTDSWAVE	=	13		; sous-type forme d'ondeTDSLCURVE=	14		; sous-type courbe gaucheTDSRCURVE=	15		; sous-type courbe droiteTDS01	=	16		; sous-type 0/1TDSPOLYMONO=	17		; sous-type poly/monoTDSFULLFING=	18		; sous-type full/fingTDSSTEREO=	19		; sous-type stroTDSMAXCOL=	20		; sous-type maximum-colonneGDSEG	=	1		; graphique des enveloppesGDSEGP	=	2		; graphique de l'enveloppe de la hauteurGDSALGO	=	3		; graphique des algorithmes	.LOC	0ODSOFF:	.BLKB	2		; offset du paramtreODSMSK:	.BLKB	2		; masqueODSSHF:	.BLKB	2		; nb de "shift right"ODSADD:	.BLKB	2		; +/- constante  ajouterODSLII:	.BLKB	2		; limite infrieureODSLIS:	.BLKB	2		; limite suprieureODSTYP:	.BLKB	1		; type de reprsentationODSLGX:	.BLKB	1		; largeur [car]ODSLGY:	.BLKB	1		; hauteur [car]ODSSTY:	.BLKB	1		; sous-typeODSGRA:	.BLKB	1		; type de reprsentation graphique	.BLKB	1		; rserveODSPOS:	.BLKB	4		; position  l'cran (y;x) unit: [car]ODSMOD:	.BLKB	2		; rang pour modificationODSTXT:				; <1>texte<0>; Description d'une enveloppe; ---------------------------	.LOC	0OEGPOS:	.BLKB	4		; position du coin suprieur/gauche (y;x)OEGDIM:	.BLKB	4		; dimensions (dy;dx)LEG:; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTONDMIDI:.BLKB	2		; no du driver MIDIOCHMIDI:.BLKB	2		; canal MIDI du synthtiseurOBUCOM:	.BLKB	20		; commandes midiOPDDIS:	.BLKB	4		; ^descripteur de la fentreOQXDOT:	.BLKB	4		; adresse de GRA_QXDOTONOWDO:	.BLKB	2		; no de la swdoOPOMIDI:.BLKB	4		; position pour afficher le canal MIDIOBDIS:	.BLKB	100		; buffer write displayOBMIDI:	.BLKB	100		; buffer write midiOFLAGS:	.BLKB	1		; flags divers BSAJ	=  0			;  timbres du synth  jours BWAIT32=  1			;  attend 32 timbres	.EVEN	.IF	FB01OBANK:	.BLKB	2		; banque (3..7)OINSTR:	.BLKB	2		; instrument (1..8)	.ENDIFOBUFILE:.BLKB	LBUFILE		; nom de fichierOBUNAME:.BLKB	LBUFILE		; nom des timbres visibles	.IF	FB01OBUCONF:.BLKB	LBUFILE		; nom du fichier de configuration	.ENDIF	.IF	DX7!DX100OBUF:	.BLKB	LBUF		; buffer pour data timbres principauxOBUG:	.BLKB	LBUG		; buffer pour data timbres secondairesOBUU:	.BLKB	LTIMBRE		; buffer pour undo gnralOBUE:	.BLKB	LTIMBRE		; buffer pour undo enveloppe	.ENDIF	.IF	FB01	.BLKB	1OBUF:	.BLKB	LBUF		; buffer pour data configurationsOBUU:	.BLKB	LTIMBRE		; buffer pour undo gnralOBUE:	.BLKB	LTIMBRE		; buffer pour undo enveloppeOBULF:	.BLKB	LBUF		; dernier data luOBULN:	.BLKB	LBUFILE		; dernier nom de fichier lu	.EVEN	.ENDIFOLWAIT:	.BLKB	4		; lg reueONOPROG:.BLKB	2		; dernier programme slectionnONOCASE:.BLKB	2		; no de la case slectionneOLSTAF:	.BLKB	NBCOL*(NBLI+NBLJ)*LDXNAMEOUNDON:	.BLKB	2		; no de la case modifieOUNDOT:	.BLKB	LTIMBRE		; timbre modifiODSCASE:.BLKB	4		; ^descripteur case slectionneODSINVS:.BLKB	2		; icne "soft-keys" allume (0=teint ou 1..15)ODSMENU:.BLKB	1		; sous-type du menu affichODSAFI:	.BLKB	1		; affiche la case en inverse	.EVENODSRDG:	.BLKB	2		; rang du digit frappODSPOT:	.BLKB	4		; position du titre du timbreODSNAME:.BLKB	10+4		; titre du timbre en ditionOPASY:	.BLKB	2		; pas de la grille en YOPASX:	.BLKB	2		; pas de la grille en XOPASX12:.BLKB	2		; 1/2 de OPASXOPASLB:	.BLKB	2		; position de la ligne de baseOTAEG:	.BLKB	(6+1)*LEG	; table les enveloppesOEGWDO:	.BLKB	2		; no swdo pour diter les enveloppesOEGSCA:	.BLKB	2		; chelleOEGTYP:	.BLKB	1		; type GDSEG/GDSEGP	.EVENOALPIM:	.BLKB	4		; ^image des tous les algorithmesOALERR:	.BLKB	2		; ok/erreur de lecture de l'imageOALNUM:	.BLKB	2		; algorithme slectionnOALUNDO:.BLKB	2		; algorithme initialLGVAR:; En-tte du module LIB; ---------------------	.LOC	0	.W	DX_FIRST	; code du premier appel	.W	DX_LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	MAJREV,MINREV	; rvision.version	.W	0,END_DX	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.IF	DX7	.ASCII	"DX7"		; nom du module	.ENDIF	.IF	DX100	.ASCII	"DX100"		; nom du module	.ENDIF	.IF	FB01	.ASCII	"FB01"		; nom du module	.ENDIF	.FILLB	(LGHLIB-.),0	.W	_DX_ID	.W	_DX_OPEN	.W	_DX_EDIT	.W	_DX_CLOSE	.W	_DX_USE	.W	_DX_GET; Codes des appels; ----------------_DX_ID:	.W	H'1234,H'5678	; c'est bien un module synth !;----------\\; _DX_OPEN  >;==========/; Initialise tout ce qu'il faut.; in	D4.W	canal MIDI  utiliser; out	A4.L	^variables;	D7.W	erreur;		ERUNCO => synthtiseur pas connect; mod	D7.W, A4.L_DX_OPEN:	PUSHM.L	D0..D6,A0..A3,A6	LOAD.W	D0,D4		; D0 <-- canal MIDI	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE 90$	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.W	D4	JUMP,NE 10$; Initialise les variables les plus importantes.	LOAD.W	(A6)+OCHMIDI,D0	; mm. canal MIDI	LOAD.W	(A6)+OUNDON,#-1	; (UNDO) ne rcupre encore rien !	LOAD.W	(A6)+ONOPROG,#-1	.IF	DX7!DX100	LOAD.L	A3,#(A6)+OBUG	LOAD.W	D3,#(NBCOL*NBLJ)-120$:	LOAD.L	A4,#R16"TVOICEINIT	LOAD.W	D4,#LTIMBRE-122$:	LOAD.B	(A3+),(A4+)	; OBUG <-- met un timbre comme "VOICE INIT"	DECJ.W,NMO D4,22$	DECJ.W,NMO D3,20$	.ENDIF	.IF	FB01	LOAD.W	(A6)+OBANK,#3	LOAD.W	(A6)+OINSTR,#1	.ENDIF; Demande le pointeur permanant au descripteur de la fentre.	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE 90$	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	(A3+),#LOADGC	LOAD.B	(A3+),#GCICF	LOAD.B	(A3+),#GCICS	LOAD.B	(A3+),#GCICT	LOAD.B	(A3+),#LOADGC	LOAD.B	(A3+),#GCPTF	LOAD.B	(A3+),#GCPTS	LOAD.B	(A3+),#GCPTT	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBDIS	SUB.L	D3,A3	LIB	?STRING	JUMP,NE 90$	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE 90$	LOAD.L	(A6)+OQXDOT,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE 90$	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE 90$	LOAD.W	(A6)+OCHLIST,D1	CALL	OPEMIDI		; ouvre le driver midi	JUMP,NE 90$	CALL	DEFCOMMAND	; utilise les canaux 1..16	JUMP,NE 90$	TEST.W	(A6)+OCHMIDI	; canal MIDI numro 1 ?	JUMP,NE 80$		; non => 80$	CALL	WAIT32		; oui => lit les 32 timbres ...80$:	LOAD.L	A4,A6		; A4 <-- ^variables90$:	POPM.L	D0..D6,A0..A3,A6	TEST.W	D7		; retour EQ/NE	RET;----------\\; _DX_EDIT  >;==========/; Permet de changer de son, d'diter, etc.; in	A4.L	^variables; out	-; mod	D7.W_DX_EDIT:	PUSHM.L	D0..D6,A0..A6	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	CALL	CADRE		; fait tout beau	.IF	FB01	CALL	GETSOUND	; D3/D4 <-- banque/son	LOAD.W	(A6)+OBANK,D3	DEC.W	D4	LOAD.W	(A6)+ONOPROG,D4	CALL	AFMENU		; raffiche les soft-keys	CALL	AFMIDI		; affiche le canal MIDI	.ENDIF	CALL	AFLIST		; affiche la liste des sons	CALL	DEFCOMMAND	; utilise les canaux 1..16	JUMP,NE ERRORLOOP:	CALL	NORMMOUSE	; remet la flche10$:	LIB	?GETCAR		; attend clavier/souris ...	COMP.W	D3,#F0+SHIFT	JUMP,LO 20$	COMP.W	D3,#F15+SHIFT	JUMP,HI 20$	SUB.W	D3,#SHIFT20$:	COMP.W	D3,#KEYMGR	JUMP,EQ 10$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ 10$		; oui => 10$	COMP.W	D3,#KEYMDR	JUMP,EQ 10$	COMP.W	D3,#UNDO	JUMP,EQ DOUNDO	COMP.W	D3,#KEYMGP	JUMP,EQ 40$	COMP.W	D3,#KEYMMP	JUMP,EQ 40$	COMP.W	D3,#KEYMDP	JUMP,NE 50$40$:	PUSH.L	D3	LIB	?IFMOUSE	; D4 <-- position de la souris (y;x)	POPM.L	D3	JUMP,NE 50$	CALL	DETCASE		; D2 <-- case o est la souris	JUMP,EQ DOCASE50$:	LOAD.L	A3,#R16"TICOBASE	LOAD.L	A4,#0	DBOX_	ICODET		; dans "soft-key" ?	JUMP,EQ SOFTKEY		; oui => SOFTKEYBIP:	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPDOUNDO:				; (UNDO) =>	.IF	DX7!DX100	LOAD.W	D1,(A6)+OUNDON	COMP.W	D1,#-1	JUMP,EQ BIP	CALL	CALPTC		; A1 <-- ^timbre  rgnrer	LOAD.L	A2,#(A6)+OUNDOT	LOAD.W	D1,#LTIMBRE-120$:	LOAD.B	(A1+),(A2+)	; timbre <-- buffer undo	DECJ.W,NMO D1,20$	LOAD.W	(A6)+OUNDON,#-1	; y'a plus rien  rcuprer	CALL	AFLIST	JUMP	LOOP	.ELSE	JUMP	BIP	.ENDIFDOCASE:	COMP.W	D3,#KEYMGP	JUMP,EQ DOPROGRAMME	.IF	DX7!DX100	COMP.W	D3,#KEYMDP	JUMP,EQ DODUPLIQUE	.ENDIF	JUMP	BIPDOPROGRAMME:			; bouton de gauche =>	JUMP	30$20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 40$		; non => 				; oui =>	LIB	?IFMOUSE	; D4 <-- position de la souris (y;x)	JUMP,NE 20$	CALL	DETCASE		; D2 <-- case o est la souris	JUMP,NE 20$30$:	COMP.W	D2,(A6)+ONOCASE	; est-on toujours dans la mme ?	JUMP,EQ 20$		; oui => 20$				; non =>	PUSH.W	D2	LOAD.W	D2,(A6)+ONOCASE	CALL	INVCASE		; efface l'ancienne	POP.W	D2	CALL	INVCASE		; allume la nouvelle	LOAD.W	(A6)+ONOCASE,D2	JUMP	20$40$:	LOAD.W	D3,(A6)+ONOCASE	COMP.W	D3,#NBCOL*NBLI	; dans zone secondaire ?	JUMP,HS BIP		; oui => BIP	.IF	DX7!DX100	CALL	PROGRAMME	; change de programme	.ENDIF	.IF	FB01	CALL	GETSOUND	; D3/D4 <-- banque/son	LOAD.W	D4,(A6)+ONOCASE	INC.W	D4	CALL	PUTSOUND	; mj. un nouveau son	CALL	SEND32		; envoie au synth ...	.ENDIF	JUMP	LOOP	.IF	DX7!DX100DODUPLIQUE:			; bouton de droite =>	LOAD.W	D0,D2		; D0 <-- case initiale (source)	LOAD.W	D2,(A6)+ONOCASE	CALL	INVCASE		; efface l'ancienne	LOAD.W	D2,D0	CALL	BIFCASE		; biffe la nouvelle	LOAD.W	(A6)+ONOCASE,D2	CLR.L	D5	JUMP	30$20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 40$		; non => 				; oui =>	LIB	?IFMOUSE	; D4 <-- position de la souris (y;x)	JUMP,NE 20$	CALL	DETCASE		; D2 <-- case o est la souris	JUMP,NE 20$30$:	COMP.W	D2,(A6)+ONOCASE	; est-on toujours dans la mme ?	JUMP,EQ 20$		; oui => 20$				; non =>	TEST.L	D5	JUMP,NE 34$	PUSH.W	D2	LOAD.W	D2,(A6)+ONOCASE	CALL	BIFCASE		; efface l'ancienne	CALL	DIMCASE		; D1 <-- milieu de la case	LOAD.L	D5,D1	POP.W	D2	JUMP	36$34$:	PUSH.W	D2	LOAD.W	D2,(A6)+ONOCASE	CALL	INVCASE		; efface l'ancienne	CALL	DIMCASE		; D1 <-- milieu de la case	CALL	INVLIEN		; efface le lien	POP.W	D236$:	CALL	INVCASE		; allume la nouvelle	CALL	DIMCASE		; D1 <-- milieu de la case	CALL	INVLIEN		; dessine le lien	LOAD.W	(A6)+ONOCASE,D2	JUMP	20$40$:	TEST.L	D5		; a-t-on boug ?	JUMP,NE 60$		; oui => 60$				; non =>	LOAD.W	D2,D0	CALL	BIFCASE		; efface la case biffe	LOAD.W	(A6)+ONOCASE,#-1	CALL	DETRUIT	CALL	AFLIST	JUMP	LOOP60$:	LOAD.W	D2,(A6)+ONOCASE	; D2 <-- case destination	CALL	INVCASE		; efface l'ancienne	CALL	DIMCASE		; D1 <-- milieu de la case	CALL	INVLIEN		; efface le lien	LOAD.W	(A6)+ONOCASE,#-1	LOAD.W	D1,D0		; D1 <-- case source	COMP.W	D1,D2	JUMP,EQ BIP	CALL	DUPLIQUE	; "D1" --> "D2"	JUMP,NE BIP	CALL	AFLIST	JUMP	LOOP	.ENDIFSOFTKEY:	TEST.W	D2	JUMP,EQ FINI	.IF	DX7!DX100	COMP.W	D2,#1	JUMP,EQ DOPREND	COMP.W	D2,#3	JUMP,EQ DOSAUVE	COMP.W	D2,#4	JUMP,EQ DOLIT	COMP.W	D2,#6	JUMP,EQ DOECRIT	COMP.W	D2,#10	JUMP,EQ DOEDITE	.ENDIF	.IF	FB01	COMP.W	D2,#4	JUMP,EQ DOLIT	COMP.W	D2,#6	JUMP,EQ DOECRIT	COMP.W	D2,#7	JUMP,EQ DOMBANK	COMP.W	D2,#9	JUMP,EQ DOPBANK	COMP.W	D2,#10	JUMP,EQ DOMINSTR	COMP.W	D2,#12	JUMP,EQ DOPINSTR	COMP.W	D2,#13	JUMP,EQ DOEDITE	.ENDIF	JUMP	BIPDOLIT:				; synth --> mmoire	CALL	WAITMOUSE	; met le sablier	CALL	WAIT32		; lit les 32 timbres ...	JUMP,NE ERROR	CALL	NORMMOUSE	; remet la flche	.IF	FB01	CALL	GETSOUND	; D3/D4 <-- banque/son	LOAD.W	(A6)+OBANK,D3	DEC.W	D4	LOAD.W	(A6)+ONOPROG,D4	CALL	AFMIDI		; affiche le canal MIDI	.ENDIF	CALL	AFLIST	JUMP	LOOPDOECRIT:			; mmoire --> synth	CALL	WAITMOUSE	; met le sablier	LOAD.W	D4,#2	NTREL	?DELMS		; attend de voir le sablier !	CALL	SEND32		; envoie les 32 timbres ...	.IF	DX7!DX100	LOAD.W	D2,(A6)+ONOCASE	CALL	INVCASE		; efface l'ancienne case	CLR.W	D2	CALL	INVCASE		; allume la nouvelle case	LOAD.W	(A6)+ONOCASE,D2	LOAD.W	D3,D2	CALL	PROGRAMME	; slectionne le programme	.ENDIF	CALL	NORMMOUSE	; remet la flche	JUMP	LOOP	.IF	DX7!DX100DOSAUVE:			; mmoire --> disque	LOAD.L	A3,#(A6)+OBUFILE10$:	CALL	NORMMOUSE	; remet la flche	CALL	DBOXEDITO	; dite le nom ...	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ LOOP	LOAD.W	D1,D3		; D1 <-- F1/F4	LOAD.L	D0,D4		; D0 <-- fanions	CALL	WAITMOUSE	; met le sablier20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	FOS	?CREATE		; cre le fichier	JUMP,EQ	30$		; ok => 30$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	ERROR		; non => ERROR				; oui =>	CALL	NORMMOUSE	; remet la flche	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	CALL	AFMENU		; refait les soft-keys	TEST.W	D7	JUMP,NE ERROR	COMP.W	D3,#'O	JUMP,NE 10$	FOS	?DELETE		; dtruit le fichier	JUMP,NE ERROR	JUMP	20$30$:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP,NE 95$	LOAD.L	A4,#(A6)+OBUF	LOAD.L	D4,#LFDX	FOS	?WRBYTE		; crit tout le data	JUMP,NE 90$	FOS	?CLOSE		; ferme le fichier	JUMP,NE 95$	CALL	AFLIST	JUMP	LOOP90$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D795$:	JUMP	ERROR	.ENDIF	.IF	DX7!DX100DOPREND:			; disque --> mmoire	LOAD.L	A3,#(A6)+OBUFILE	CLR.B	(A3)10$:	CALL	DBOXEDITI	; dite le nom ...	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ LOOP	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier	JUMP,EQ 30$				; erreur =>	PUSH.W	D7	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	10$30$:	LOAD.L	A4,#(A6)+OBUF	LOAD.L	D4,#LFDX	FOS	?RDBYTE		; lit le data	JUMP,NE 90$	FOS	?CLOSE	JUMP,NE 95$	LOAD.L	A3,#(A6)+OBUFILE	LOAD.L	A4,#(A6)+OBUNAME	LOAD.W	D3,#LBUFILE-150$:	LOAD.B	(A4+),(A3+)	; OBUNAME <-- OBUFILE	DECJ.W,NMO D3,50$	LOAD.W	D2,(A6)+ONOCASE	CALL	INVCASE		; efface la case slectionne	LOAD.W	(A6)+ONOCASE,#-1	LOAD.W	(A6)+ONOPROG,#-1	TCLR.B	(A6)+OFLAGS:#BSAJ ; synth plus  jour !	CALL	AFLIST	JUMP	LOOP90$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D795$:	JUMP	ERROR	.ENDIF	.IF	FB01DOMBANK:			; (-) banque =>	LOAD.W	D4,(A6)+OBANK	DEC.W	D4	COMP.W	D4,#3	JUMP,LO BIP	LOAD.W	(A6)+OBANK,D4	JUMP	DOBANKDOPBANK:			; (+) banque =>	LOAD.W	D4,(A6)+OBANK	INC.W	D4	COMP.W	D4,#7	JUMP,HI BIP	LOAD.W	(A6)+OBANK,D4DOBANK:	LOAD.W	D2,#8	CALL	AFNBSOFTKEY	CALL	GETSOUND	; D3/D4 <-- banque/son	LOAD.W	D3,(A6)+OBANK	CALL	PUTSOUND	; mj. banque/son	CALL	SEND32		; envoie au synth ...	DEC.W	D4	LOAD.W	(A6)+ONOPROG,D4	CALL	AFLIST		; affiche les nouveaux sons	JUMP	LOOPDOMINSTR:			; (-) instrument =>	LOAD.W	D2,(A6)+OINSTR	; D2 <-- instrument initial10$:	LOAD.W	D4,(A6)+OINSTR	DEC.W	D4		; D4 <-- instrument prcdent	COMP.W	D4,#1	JUMP,LO 90$	LOAD.W	(A6)+OINSTR,D4	CALL	GETMIDI		; D3/D4 <-- nb notes/canal MIDI	TEST.W	D3		; au moins une note ?	JUMP,EQ 10$		; non => 10$	JUMP	DOINSTR90$:	LOAD.W	(A6)+OINSTR,D2	; remet la valeur initiale	JUMP	BIPDOPINSTR:			; (+) instrument =>	LOAD.W	D2,(A6)+OINSTR	; D2 <-- instrument initial10$:	LOAD.W	D4,(A6)+OINSTR	INC.W	D4		; D4 <-- instrument suivant	COMP.W	D4,#8	JUMP,HI 90$	LOAD.W	(A6)+OINSTR,D4	CALL	GETMIDI		; D3/D4 <-- nb notes/canal MIDI	TEST.W	D3		; au moins une note ?	JUMP,EQ 10$		; non => 10$	JUMP	DOINSTR90$:	LOAD.W	(A6)+OINSTR,D2	; remet la valeur initiale	JUMP	BIPDOINSTR:	LOAD.W	D4,(A6)+OINSTR	LOAD.W	D2,#11	CALL	AFNBSOFTKEY	CALL	GETSOUND	; D3/D4 <-- banque/son	LOAD.W	(A6)+OBANK,D3	DEC.W	D4	LOAD.W	(A6)+ONOPROG,D4	CALL	AFLIST		; affiche les nouveaux sons	CALL	AFMIDI		; affiche le nouveau canal MIDI	LOAD.W	D4,(A6)+OBANK	LOAD.W	D2,#8	CALL	AFNBSOFTKEY	; affiche le nouveau numro de banque	JUMP	LOOP	.ENDIFDOEDITE:	LOAD.W	D2,(A6)+ONOPROG	COMP.W	D2,#-1	JUMP,EQ BIP	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.W	D5,(A6)+ONOWDO	LIB	?KILWDO		; supprime la swdo !	.IF	DX7!DX100	LOAD.L	A3,#R16"TDXIEDIT	CALL	LPRESSDX	; "SYS INFO AVAIL"	.ENDIF	.IF	DX7!DX100	LOAD.L	A2,#(A6)+OBUF+8	MUL.WU	D2,#LTIMBRE	ADD.L	A2,D2		; A2 <-- ^timbre slectionn	.ENDIF	.IF	FB01	LOAD.L	A2,#(A6)+OBUF+11	.ENDIF	CALL	DSEDIT		; dite le timbre ...	.IF	DX7	LOAD.B	D3,#KDX7SINT	CALL	PRESSDX		; presse [SELECT:INTERNAL]	LOAD.B	D3,#KDX7STORE	CALL	PUSHDX		; presse [STORE]	LOAD.W	D3,(A6)+ONOPROG	ADD.B	D3,#1+KDX7NUM	CALL	PRESSDX		; slectionne [1..32]	LOAD.B	D3,#KDX7STORE	CALL	POPDX		; relche [STORE]	.ENDIF	.IF	DX100	LOAD.B	D3,#KDX100INT	CALL	PRESSDX		; presse [INTERNAL]	LOAD.B	D3,#KDX100STORE	CALL	PUSHDX		; presse [STORE]	LOAD.W	D3,(A6)+ONOPROG	ADD.B	D3,#1+KDX100NUM	CALL	PRESSDX		; slectionne [1..32]	LOAD.B	D3,#KDX100STORE	CALL	POPDX		; relche [STORE]	.ENDIF	.IF	DX7!DX100	LOAD.L	A3,#R16"TDXOEDIT	CALL	LPRESSDX	; "SYS INFO UNAVAIL"	.ENDIF	.IF	FB01	CALL	GETSOUND	; D3/D4 <-- banque/son	LOAD.W	(A6)+OBANK,D3	DEC.W	D4	LOAD.W	(A6)+ONOPROG,D4	.ENDIF	CALL	CADRE		; fait tout beau	.IF	FB01	CALL	AFMIDI		; affiche le canal MIDI	.ENDIF	CALL	AFLIST		; affiche la liste des sons	JUMP	LOOPERROR:	PUSH.W	D7	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	AFMENU		; affiche les soft-keys	JUMP	LOOPFINI:	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.W	D5,(A6)+ONOWDO	LIB	?KILWDO		; supprime la swdo !	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	EOP		; efface tout	.B	0	.EVEN	POPM.L	D0..D6,A0..A6	CLR.W	D7		; retour EQ	RET;-----------\\; _DX_CLOSE  >;===========/; Ferme tout.; in	A4.L	^variables; out	-; mod	D7.W_DX_CLOSE:	PUSHM.L	D1,A0,A6	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	CALL	CLOMIDI	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	POPM.L	D1,A0,A6	CLR.W	D7		; retour EQ	RET;---------\\; _DX_GET  >;=========/; Donne le son utilis.; in	A4.L	^variables;	A2.L	^nom du fichier (.part); out	A3.L	^nom du fichier .DX;	D3.W	numro du son 0..127; mod	D3.L, D7.W, A3.L_DX_GET:	PUSHM.L	A0,A6	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	.IF	FB01	CALL	WRCONF		; crit le fichier de configuration	.ENDIF	LOAD.L	A3,#(A6)+OBUNAME	LOAD.W	D3,(A6)+ONOPROG	.IF	FB01	TEST.B	(A3)		; nom existe ?	JUMP,NE 90$		; oui => 90$				; non =>	LOAD.B	(A3)+0,#'B	LOAD.B	(A3)+1,#'A	; redonne le nom "BANK" !	LOAD.B	(A3)+2,#'N	LOAD.B	(A3)+3,#'K	CLR.B	(A3)+4	.ENDIF90$:	POPM.L	A0,A6	CLR.W	D7		; retour EQ	RET;---------\\; _DX_USE  >;=========/; Utilise un son quelconque.; in	A4.L	^variables;	A2.L	^nom du fichier (.part);	A3.L	^nom du fichier .DX;	D3.W	numro du son 0..127; out	D7.W	erreur; mod	D7.W_DX_USE:	PUSHM.L	D2..D6,A0..A4,A6	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	CALL	DEFCOMMAND	; utilise les canaux 1..16	JUMP,NE 90$	.IF	DX7!DX100	LOAD.W	D2,D3		; D2 <-- programme	LOAD.L	A4,#(A6)+OBUNAME	LOAD.L	A2,#R16"00$	LIB	?CPSTRING	; 32 timbres dj l ?	JUMP,EQ 60$		; oui => 60$				; non =>	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUF	LOAD.L	D4,#LFDX	FOS	?RDBYTE		; lit le data	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUNAME	LOAD.W	D3,#LBUFILE-130$:	LOAD.B	(A4+),(A3+)	; OBUNAME <-- OBUFILE	DECJ.W,NMO D3,30$	CALL	SEND32		; envoie au synth ...60$:	LOAD.W	D3,D2		; D3 <-- programme	CALL	PROGRAMME	; slectionne le programme	.ENDIF	.IF	FB01	CALL	RDCONF		; lit le fichier de configuration	JUMP,NE 90$	CALL	SEND32		; envoie au synth ...	.ENDIF90$:	POPM.L	D2..D6,A0..A4,A6	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0,CR,'.,-1	; terminateurs pour LIB,?CPSTRING	.EVEN	.IF	FB01;--------\\; RDCONF  >;========/; Lit le fichier de configuration.; in	A2.L	^nom du fichier (.part); out	D7.W	erreur; mod	D7.WRDCONF:	PUSHM.L	D3,D4,D6,A2..A4	CALL	NAMECONF	; A3 <-- ^nom du fichier; Regarde si l'on ne vient pas de lire dj exactement le mme; nom de fichier.	LOAD.L	A4,A3	LOAD.L	A2,#(A6)+OBULN15$:	TEST.B	(A4)	JUMP,EQ 16$	COMP.B	(A4+),(A2+)	; est-ce le mme nom ?	JUMP,NE 20$		; non => 20$	JUMP	15$16$:	TEST.B	(A2)	JUMP,NE 20$	CLR.W	D7		; D7 <-- ok, et on ne fait rien !	JUMP	90$; Lit le nouveau fichier sur disque.20$:	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUF	LOAD.L	D4,#LFDX	FOS	?RDBYTE		; lit le data	JUMP,NE 80$; Mmorise le data et le nom du fichier qui vient d'tre lu.	LOAD.L	A2,#(A6)+OBULF40$:	LOAD.B	(A2+),(A4+)	; OBULF <-- data du fichier	DEC.W	D4	JUMP,NE 40$	LOAD.L	A2,#(A6)+OBULN45$:	LOAD.B	(A2+),(A3+)	; OBULN <-- nom du fichier	JUMP,NE 45$; Ferme le fichier, sans tester l'erreur.80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRCONF  >;========/; Cre et crit le fichier de configuration.; in	A2.L	^nom du fichier (.part); out	D7.W	erreur; mod	D7.WWRCONF:	PUSHM.L	D3,D4,D6,A2..A4	CALL	NAMECONF	; A3 <-- ^nom du fichier; Regarde si l'on ne vient pas d'crire dj exactement le mme; data, avec le mme nom de fichier.	LOAD.L	A4,#(A6)+OBUF	LOAD.L	A2,#(A6)+OBULF	LOAD.W	D4,#LFDX-110$:	COMP.B	(A4+),(A2+)	; est-ce le mme data ?	JUMP,NE 20$		; non => 20$	DECJ.W,NMO D4,10$	LOAD.L	A4,A3	LOAD.L	A2,#(A6)+OBULN15$:	TEST.B	(A4)	JUMP,EQ 16$	COMP.B	(A4+),(A2+)	; est-ce le mme nom ?	JUMP,NE 20$		; non => 20$	JUMP	15$16$:	TEST.B	(A2)	JUMP,NE 20$	CLR.W	D7		; D7 <-- ok, et on ne fait rien !	JUMP	90$; Cre et crit le nouveau fichier sur disque.20$:	FOS	?DELETE		; dtruit froidement s'il existe dj	LOAD.L	D3,#DEFATT	TCLR.L	D3:#BATTL	; D3 <-- fichier invisible !	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre (ou re-cre)	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUF	LOAD.L	D4,#LFDX	FOS	?WRBYTE		; crit le data	JUMP,NE 80$; Mmorise le data et le nom du fichier qui vient d'tre cr.	LOAD.L	A2,#(A6)+OBULF40$:	LOAD.B	(A2+),(A4+)	; OBULF <-- data du fichier	DEC.W	D4	JUMP,NE 40$	LOAD.L	A2,#(A6)+OBULN45$:	LOAD.B	(A2+),(A3+)	; OBULN <-- nom du fichier	JUMP,NE 45$; Ferme le fichier, sans tester l'erreur.80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; NAMECONF >;---------/; Prpare le nom du fichier de configuration.; in	A2.L	^nom du fichier (.part); out	A3.L	^nom du fichier (.cfb01); mod	D7.W, A3.LNAMECONF:	PUSHM.L	D3,A2,A4	LOAD.L	A3,#(A6)+OBUCONF10$:	LOAD.B	D3,(A2+)	JUMP,EQ 15$	COMP.B	D3,#CR	JUMP,EQ 15$	LOAD.B	(A3+),D3	; OBUCONF <-- nom	JUMP	10$15$:	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBUCONF	LOAD.L	A4,#R16"TXCEXT	LOAD.W	D3,#1		; D3 <-- force	LIB	?ADDEXT	POPM.L	D3,A2,A4	RET	.ENDIF	.IF	DX7!DX100;---------\\; DETRUIT  >;=========/; Dtruit un timbre.; in	D2.W	no case  dtruire; out	D7.W	erreur; mod	D7.WDETRUIT:	PUSHM.L	D1,A1,A2	LOAD.W	D1,D2	CALL	CALPTC		; A1 <-- ^case	JUMP,NE 90$	LOAD.L	A2,A1	CALL	SVUNDO		; buffer undo <-- le timbre	LOAD.L	A2,#R16"TVOICEINIT	LOAD.W	D1,#LTIMBRE-140$:	LOAD.B	(A1+),(A2+)	; vide la case	DECJ.W,NMO D1,40$90$:	POPM.L	D1,A1,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; DUPLIQUE >;=========/; Duplique un timbre.; in	D1.W	no case source;	D2.W	no case destination; out	D7.W	erreur; mod	D7.WDUPLIQUE:	PUSHM.L	D1,D2,A1,A2	CALL	CALPTC		; A1 <-- ^source	JUMP,NE 90$	LOAD.W	D1,D2	LOAD.L	A2,A1	CALL	CALPTC		; A2 <-- ^destination	JUMP,NE 90$	EX.L	A1,A2	CALL	SVUNDO		; buffer undo <-- le timbre	LOAD.W	D1,#LTIMBRE-140$:	LOAD.B	(A2+),(A1+)	; destination <-- source	DECJ.W,NMO D1,40$90$:	POPM.L	D1,D2,A1,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; SVUNDO  >;--------/; Sauve le timbre qui va tre dtruit ou cras.; in	D2.W	numro de la case;	A2.L	^timbre; out	-; mod	-SVUNDO:	PUSHM.L	D1,A1,A2	LOAD.W	(A6)+OUNDON,D2	LOAD.L	A1,#(A6)+OUNDOT	LOAD.W	D1,#LTIMBRE-120$:	LOAD.B	(A1+),(A2+)	; buffer undo <-- le timbre	DECJ.W,NMO D1,20$	POPM.L	D1,A1,A2	RET;--------\\; CALPTC  >;--------/; Donne le pointeur  un timbre selon son numro.; in	D1.W	numro de case; out	A1.L	^timbre;	D7.W	erreur; mod	D7.W, A1.LCALPTC:	PUSH.L	D1	LOAD.W	D7,#1		; D7 <-- impossible	COMP.W	D1,#NBCOL*NBLI	JUMP,HS 40$				; zone principale =>	LOAD.L	A1,#(A6)+OBUF+8	MUL.WU	D1,#LTIMBRE	ADD.L	A1,D1	CLR.W	D7	JUMP	90$40$:				; zone secondaire =>	SUB.W	D1,#NBCOL*NBLI	COMP.W	D1,#NBCOL*NBLJ	JUMP,HS 40$	LOAD.L	A1,#(A6)+OBUG	MUL.WU	D1,#LTIMBRE	ADD.L	A1,D1	CLR.W	D790$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET	.ENDIF	.IF	DX7!DX100;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F4/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITO:	PUSHM.L	D1,D2,D5,A1..A4	CLR.L	D4	LOAD.L	A2,#R16"TDBOX_OUTPUT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A4,A3		; A4 <-- ^dbut du nom10$:	TEST.B	(A4+)		; A4 <-- ^fin du nom	JUMP',EQ 12$	COMP.B	(A4)-1,#CR	JUMP,NE	10$12$:	DEC.L	A420$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUTPUT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; SAUVE ?	JUMP,EQ	60$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	80$	COMP.W	D3,#UNDO	JUMP',EQ 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$60$:				; SAUVE =>	TEST.B	(A3)		; nom existe ?	JUMP,EQ	30$		; non => 30$	COMP.B	(A3),#CR	JUMP,EQ	30$	LOAD.L	A4,#R16"TXEXT	; A4 <-- ^extension	PUSH.W	D3	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	POP.W	D380$:	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys90$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.ENDIF	.IF	DX7!DX100;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F4/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,D5,A1..A4	CLR.L	D405$:	LOAD.L	A2,#R16"TDBOX_INPUT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A4,A3		; A4 <-- ^dbut du nom10$:	TEST.B	(A4+)		; A4 <-- ^fin du nom	JUMP',EQ 12$	COMP.B	(A4)-1,#CR	JUMP,NE	10$12$:	DEC.L	A420$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_INPUT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; PREND ?	JUMP,EQ	60$;;?	COMP.W	D3,#F4		; AJOUTE ?;;?	JUMP,EQ	60$	COMP.W	D3,#F7		; LISTE ?	JUMP,EQ	50$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	80$	COMP.W	D3,#UNDO	JUMP',EQ 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$50$:				; LISTE =>	DBOX_	CLOSE		; ferme la DBOX	PUSH.L	D4	LOAD.L	A4,A3		; A4 <-- ^buffer pour nom	LOAD.L	A3,#R16"TXEXT	; A3 <-- ^critre de recherche (extension)	CLR.L	D4	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode (avec sauvetage)	LIST_	DBOX		; liste puis choix selon dbox ...	POPM.L	D4	JUMP,NE 90$	LOAD.L	A3,A4		; A3 <-- ^nom du fichier	JUMP	05$60$:				; PREND/AJOUTE =>	TEST.B	(A3)		; nom existe ?	JUMP,EQ	30$		; non => 30$	COMP.B	(A3),#CR	JUMP,EQ	30$	LOAD.L	A4,#R16"TXEXT	; A4 <-- ^extension	PUSH.W	D3	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	POP.W	D380$:	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys90$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.ENDIF;--------\\; DETCASE >;========/; Dtecte dans quelle case est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	numro de la case (0..n);	D7.W	erreur; mod	D2.L, D7.WDETCASE:	PUSHM.L	D3,D4	LOAD.W	D7,#1		; D7 <-- pas trouv	SUB.W	D4,(A0)+ODFFX	JUMP,LO 90$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP,LO 90$	SWAP.W	D4	CLR.L	D3	LOAD.W	D3,D4	LOAD.W	D2,(A0)+ODFFDX	SR.W	D2,#2		; D2 <-- largeur d'une colonne	DIV.WU	D3,D2	CLR.W	D4	SWAP.W	D4	LOAD.W	D2,(A0)+ODFCY	ADD.W	D2,#2		; D2 <-- hauteur d'une colonne	DIV.WU	D4,D2	DEC.W	D4	JUMP,NS 90$	COMP.W	D4,#NBLI	JUMP,LO 70$	JUMP,EQ 90$	DEC.W	D4	COMP.W	D4,#NBLI+NBLJ	JUMP,HS 90$70$:	MUL.WU	D4,#NBCOL	LOAD.W	D2,D4	ADD.W	D2,D3	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; INVLIEN >;========/; Inverse le lien entre deux cases.; in	D5.L	origine;	D1.L	arrive; out	-; mod	D7.WINVLIEN:	PUSHM.L	D0..D4	LOAD.L	D3,D5		; D3 <-- <yy>/<xx> origine	LOAD.L	D4,D1	SUB.W	D4,D3		; D4 <-- <dxx>	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- <dyy>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	; D2 <-- <mode>	PUSH.L	D3	LIB	?DRSEG		; dessine le lien	POP.L	D3	LOAD.W	D0,D4	JUMP,NC 40$	NEG.W	D0		; D0 <-- |dx|40$:	LOAD.L	D1,D4	SWAP.W	D1	TEST.W	D1	JUMP,NC 45$	NEG.W	D1		; D0 <-- |dy|45$:	INC.W	D3		; D3 <-- pousse  droite	COMP.W	D0,D1	JUMP,LS 50$	DEC.W	D3	SWAP.W	D3	INC.W	D3		; D3 <-- pousse en bas	SWAP.W	D350$:	LIB	?DRSEG		; double l'paisseur	POPM.L	D0..D4	RET;--------\\; BIFCASE >;========/; Biffe une case.; in	D2.W	numro de la case (0..n); out	-; mod	D7.WBIFCASE:	PUSHM.L	D1..D4	COMP.W	D2,#-1	JUMP,EQ 90$	CALL	DIMCASE		; D3/D4 <-- pos/dim de la case	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#INVDOT	; D2 <-- <mode>	PUSH.L	D3	LIB	?DRSEG		; inverse une diagonale	POP.L	D3	ADD.W	D3,D4	NEG.W	D4	LIB	?DRSEG		; inverse l'autre diagonale90$:	POPM.L	D1..D4	RET;--------\\; INVCASE >;========/; Inverse une case.; in	D2.W	numro de la case (0..n); out	-; mod	D7.WINVCASE:	PUSHM.L	D1..D4	COMP.W	D2,#-1	JUMP,EQ 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit une trame pleine	CALL	DIMCASE		; D3/D4 <-- pos/dim de la case	LOAD.W	D2,#INVDOT	; D2 <-- <mode>	LIB	?DRMATRIX	; inverse la case90$:	POPM.L	D1..D4	RET;--------\\; DIMCASE >;========/; Donne les dimensions d'une case.; in	D2.W	numro de la case (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D1.L	point milieu (y;x); mod	D1.L, D3.L, D4.L, D7.WDIMCASE:	PUSH.L	D2	COMP.W	D2,#NBCOL*NBLI	JUMP,LO 10$	ADD.W	D2,#NBCOL10$:	AND.L	D2,#H'FFFF	DIV.WU	D2,#NBCOL	; D2 <-- position (x;y)	LOAD.W	D3,D2	INC.W	D3	LOAD.W	D4,(A0)+ODFCY	ADD.W	D4,#2		; D4 <-- <dyy>	MUL.WU	D3,D4		; D3 <-- <yy>	INC.W	D3	DEC.W	D4	TEST.W	D2	JUMP,EQ 20$	COMP.W	D2,#NBLI+1	JUMP,NE 25$20$:	INC.W	D3	DEC.W	D425$:	SWAP.W	D4	SWAP.W	D3	SWAP.W	D2	LOAD.W	D1,D2	LOAD.W	D4,(A0)+ODFFDX	SR.W	D4,#2		; D4 <-- <dxx>	MUL.WU	D2,D4	LOAD.W	D3,D2		; D3 <-- <xx>	TEST.W	D1	JUMP,EQ 40$	ADD.W	D3,#2	SUB.W	D4,#240$:	LOAD.L	D1,D3	LOAD.L	D2,D4	SR.W	D2,#1	ADD.W	D1,D2		; D1 <-- au milieu de la case en X	SWAP.W	D1	SWAP.W	D2	SR.W	D2,#1	ADD.W	D1,D2		; D1 <-- au milieu de la case en Y	SWAP.W	D190$:	POP.L	D2	RET;--------\\; AFLIST  >;========/; Affiche la liste des noms de sons.; in	-; out	-; mod	D7.WAFLIST:	PUSHM.L	D0..D4,A2..A4	LIB	?BUCAR	LOAD.W	D2,(A6)+ONOCASE	CALL	INVCASE		; efface la case slectionne	LOAD.W	(A6)+ONOCASE,#-1	.IF	DX7!DX100	LOAD.L	A4,#(A6)+OBUF+8	; A4 <-- ^premier timbre	.ENDIF	.IF	FB01	LOAD.W	D4,(A6)+OBANK	LOAD.L	A3,#R16"NBANK3	LOAD.L	A4,#R16"TBANK3	COMP.W	D4,#3	JUMP,EQ 10$	LOAD.L	A3,#R16"NBANK4	LOAD.L	A4,#R16"TBANK4	COMP.W	D4,#4	JUMP,EQ 10$	LOAD.L	A3,#R16"NBANK5	LOAD.L	A4,#R16"TBANK5	COMP.W	D4,#5	JUMP,EQ 10$	LOAD.L	A3,#R16"NBANK6	LOAD.L	A4,#R16"TBANK6	COMP.W	D4,#6	JUMP,EQ 10$	LOAD.L	A3,#R16"NBANK7	LOAD.L	A4,#R16"TBANK710$:	LOAD.L	A2,#(A6)+OBUNAME12$:	LOAD.B	(A2+),(A3+)	; OBUNAME <-- titre de la banque	JUMP,NE 12$	.ENDIF; Affiche le titre des timbres (copie du nom du fichier).	LOAD.W	D3,(A0)+ODFCY	INC.W	D3	SUB.W	D3,(A0)+ODFC2Y	; D3 <-- <yy> initial	SWAP.W	D3	LOAD.W	D3,(A0)+ODFFDX	SR.W	D3,#2	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUNAME	TEST.B	(A3)	JUMP,EQ 20$	COMP.B	(A3),#CR	JUMP,EQ 20$	LIB	?AFTIM	.B	LOADGC,GCTXF!2^7,2^BGCLARG!2^BGCFIX,GCTXT	.B	USEGC,GCTXF!2^7,2^BGCLARG!2^BGCFIX,GCTXT	.B	'<	.B	SPACE	.B	0	.EVEN	LIB	?AFFILE		; affiche le nom	LIB	?AFTIM	.B	SPACE	.B	'>	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN20$:	LOAD.B	D3,#EFLI	LIB	?AFCAR		; efface la fin de la ligne; Affiche la liste des timbres principaux.	LOAD.L	A2,#(A6)+OLSTAF	LOAD.W	D0,#NBLI40$:	LOAD.W	D1,#NBCOL	CLR.W	D3		; D3 <-- <xx> initial	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	ADD.W	D3,#2		; D3 <-- <yy> suivant	SWAP.W	D350$:	CALL	AFONELIST	; affiche le nom	LOAD.W	D2,(A0)+ODFFDX	SR.W	D2,#2	ADD.W	D3,D2		; D3 <-- <xx> suivant	.IF	DX7!DX100	LOAD.L	A4,#(A4)+LTIMBRE ; A4 <-- ^timbre suivant	.ENDIF	.IF	FB01	LOAD.L	A4,#(A4)+LDXNAME ; A4 <-- ^timbre suivant	.ENDIF	DEC.W	D1	JUMP,NE 50$	DEC.W	D0	JUMP,NE 40$; Affiche la liste des timbres secondaires.	.IF	DX7!DX100	LOAD.L	A4,#(A6)+OBUG	; A4 <-- ^premier timbre	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	ADD.W	D3,#2		; D3 <-- <yy> suivant	SWAP.W	D3	LOAD.W	D0,#NBLJ60$:	LOAD.W	D1,#NBCOL	CLR.W	D3		; D3 <-- <xx> initial	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	ADD.W	D3,#2		; D3 <-- <yy> suivant	SWAP.W	D370$:	CALL	AFONELIST	; affiche le nom	LOAD.W	D2,(A0)+ODFFDX	SR.W	D2,#2	ADD.W	D3,D2		; D3 <-- <xx> suivant	LOAD.L	A4,#(A4)+LTIMBRE ; A4 <-- ^timbre suivant	DEC.W	D1	JUMP,NE 70$	DEC.W	D0	JUMP,NE 60$	.ENDIF	LOAD.W	D2,(A6)+ONOPROG	CALL	INVCASE		; allume la case slectionne	LOAD.W	(A6)+ONOCASE,D2	LIB	?NOBUCAR	POPM.L	D0..D4,A2..A4	RET;----------\\; AFONELIST >;----------/; Affiche un nom de timbre sans son numro.; in	A4.L	^timbre;	D3.L	position (y;x);	A2.L	^dernier nom; out	A2.L	^plus loin; mod	D7.W, A2.LAFONELIST:	PUSHM.L	D1..D3,A1,A3	LOAD.L	A3,#(A4)+PDXNAME; A3 <-- ^nom  afficher	LOAD.L	A1,A2		; A1 <-- ^dernier nom affich	LOAD.W	D1,#LDXNAME-110$:	COMP.B	(A1+),(A3+)	; une diffrence ?	JUMP,NE 12$		; oui => 12$	DECJ.W,NMO D1,10$	JUMP	80$12$:	LOAD.L	A3,#(A4)+PDXNAME; A3 <-- ^nom  afficher	LOAD.L	A1,A2	LOAD.W	D1,#LDXNAME-114$:	LOAD.B	(A1+),(A3+)	; OLSTAF <-- dernier nom	DECJ.W,NMO D1,14$	LOAD.W	D1,(A0)+ODFCX	MUL.WU	D1,#5	ADD.W	D3,D1	LIB	?SETCURS	LOAD.L	A3,#(A4)+PDXNAME; A3 <-- ^nom  afficher	TEST.B	(A3)	JUMP,EQ 50$	LOAD.W	D3,#LDXNAME	; D3 <-- lg nom	LIB	?STRING		; affiche le nom	JUMP	80$50$:	LIB	?AFTIM	.B	MSPACE,LDXNAME	; efface le nom	.B	0	.EVEN80$:	LOAD.L	A2,#(A2)+LDXNAME ; A2 <-- ^plus loin	POPM.L	D1..D3,A1,A3	RET;--------\\; CADRE   >;========/; Dessine tout le cadre.; in	-; out	-; mod	D7.WCADRE:	PUSHM.L	D2..D5,A3,A4	LIB	?AFTIM	.B	NOCURS		; plus de curseur	.B	EOP		; efface tout	.B	0	.EVEN	LOAD.W	(A6)+ONOCASE,#-1	LOAD.L	A3,#R16"TICOBASE	LOAD.L	A4,#0	DBOX_	ICOCADRE	; dessine le cadre autour	PUSHM.L	D3,D4	CLR.L	D3	LIB	?SETCURS	; positionne en tout en haut  gauche	LIB	?AFTIM	.B	AFINV		; en inverse vido	.B	SPACE		; toujours un espace	.IF	DX7	.ASCII	"DX7 rev "	.ENDIF	.IF	DX100	.ASCII	"DX100 rev "	.ENDIF	.IF	FB01	.ASCII	"FB01 rev "	.ENDIF	.B	MAJREV+'0	.B	'.	.B	MINREV+'0	.IF	DX7	.ASCII	"  "	.ENDIF	.ASCIZ	"   Canal MIDI numro "	.EVEN	LIB	?GETCURS	LOAD.L	(A6)+OPOMIDI,D3	CLR.L	D4	LOAD.W	D4,(A6)+OCHMIDI	INC.W	D4		; D4 <-- 1..16	LOAD.W	D3,#2		; D3 <-- nb dgits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC		; affiche le numro	LIB	?AFTIM	.ASCII	"    "	.IF	DX7!DX100	.ASCII	"|slectionne|           |  modifie  |"	.ENDIF	.IF	FB01	.ASCII	"|slectionne|           |           |"	.ENDIF		 ;           ;           ;           ;	.B	AFDIR		; remet vido normale	.B	0	.EVEN	POPM.L	D3,D4	LIB	?CREWDO		; cre la swdo	LOAD.W	(A6)+ONOWDO,D5	LIB	?USEWDO		; utilise la swdo (toujours)	CALL	AFMENU		; affiche les soft-keys; Affiche les lignes horizontales et verticales.	LOAD.W	D3,#1	LOAD.W	D4,#1+NBLI	CALL	TABLEAU		; dessine le tableau suprieur	.IF	DX7!DX100	LOAD.W	D3,#1+NBLI+1	LOAD.W	D4,#1+NBLI+1+NBLJ	CALL	TABLEAU		; dessine le tableau infrieur	.ENDIF	LOAD.L	A3,#(A6)+OLSTAF	LOAD.W	D3,#(NBCOL*(NBLI+NBLJ)*LDXNAME)-150$:	LOAD.B	(A3+),#SPACE	; OLSTAF <-- rempli d'espaces	DECJ.W,NMO D3,50$; Affiche les numros des timbres dans les cases.	LIB	?BUCAR	LOAD.W	D3,(A0)+ODFCY	INC.W	D3	SUB.W	D3,(A0)+ODFC2Y	; D3 <-- <yy> initial	SWAP.W	D3	CLR.L	D4	LOAD.W	D0,#NBLI60$:	LOAD.W	D1,#NBCOL	CLR.W	D3		; D3 <-- <xx> initial	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	ADD.W	D3,#2		; D3 <-- <yy> suivant	SWAP.W	D370$:	INC.W	D4		; D4 <-- no suivant	PUSH.L	D3	ADD.W	D3,#4	LIB	?SETCURS	LOAD.W	D3,#2		; D3 <-- nb dgits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC		; affiche le numro	POP.L	D3	LOAD.W	D2,(A0)+ODFFDX	SR.W	D2,#2	ADD.W	D3,D2		; D3 <-- <xx> suivant	DEC.W	D1	JUMP,NE 70$	DEC.W	D0	JUMP,NE 60$	LIB	?NOBUCAR	POPM.L	D2..D5,A3,A4	RET	.IF	FB01;--------\\; AFMIDI  >;--------/; Affiche le numro de canal MIDI.; in	-; out	-; mod	D7.WAFMIDI:	PUSHM.L	D2..D5	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.L	D3,(A6)+OPOMIDI	LIB	?SETCURS	LOAD.B	D3,#AFINV	LIB	?AFCAR	CALL	GETMIDI		; D3/D4 <-- nb notes/canal MIDI	AND.L	D4,#H'FFFF	LOAD.W	D3,#2		; D3 <-- nb dgits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC		; affiche le numro	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LOAD.W	D5,(A6)+ONOWDO	LIB	?USEWDO		; rutilise swdo initiale	POPM.L	D2..D5	RET	.ENDIF;--------\\; TABLEAU >;--------/; Dessine des lignes horizontales et verticales de sparation.; in	D3.W	premire case (0..n);	D4.W	dernire case (D3+1..n); out	-; mod 	D7.WTABLEAU:	PUSHM.L	D0..D6	LOAD.W	D5,D3		; D5 <-- premire case	LOAD.W	D6,D4		; D6 <-- dernire case	LIB	?BUCAR; Dessine les lignes horizontales.	CLR.L	D3	CLR.L	D4		; D4 <-- <dyy>	LOAD.W	D4,(A0)+ODFFDX	; D4 <-- <dxx>	LOAD.W	D2,#SETDOT	; D2 <-- mode	CLR.W	D140$:	COMP.W	D1,D5	JUMP,LO 45$	PUSH.L	D3	PUSH.L	D3	SWAP.W	D3	LIB	?DRSEG		; dessine une ligne horizontale	POP.L	D3	COMP.W	D1,D5	JUMP,EQ 42$	COMP.W	D1,D6	JUMP,NE 44$42$:	INC.W	D3	PUSH.L	D3	SWAP.W	D3	LIB	?DRSEG		; double paisseur si premire/dernire	POP.L	D344$:	POP.L	D345$:	ADD.W	D3,(A0)+ODFCY	ADD.W	D3,#2	INC.W	D1	COMP.W	D1,D6	JUMP,LS 40$; Dessine les lignes verticales.	LOAD.W	D1,(A0)+ODFCY	ADD.W	D1,#2	LOAD.W	D3,D1		; D3 <-- <yy>	MUL.WU	D3,D5	SWAP.W	D3	CLR.W	D3		; D3 <-- <xx>	LOAD.W	D4,D1	SUB.W	D6,D5	MUL.WU	D4,D6		; D4 <-- <dyy>	SWAP.W	D4	CLR.W	D4		; D4 <-- <dxx>	LOAD.W	D0,(A0)+ODFFDX	SR.W	D0,#2		; D0 <-- largeur d'une colonne	LOAD.W	D1,(A0)+ODFCX	SL.W	D1,#1	ADD.W	D1,#5		; D1 <-- largeur pour numros	LOAD.W	D3,D1	PUSH.L	D3	LIB	?DRSEG		; dessine une ligne verticale	POP.L	D3	LOAD.W	D3,D0	PUSH.L	D3	LIB	?DRSEG		; dessine une ligne verticale	POP.L	D3	PUSH.L	D3	INC.W	D3	LIB	?DRSEG		; double l'paisseur	POP.L	D3	ADD.W	D3,D1	PUSH.L	D3	LIB	?DRSEG		; dessine une ligne verticale	POP.L	D3	LOAD.W	D3,D0	ADD.W	D3,D0	PUSH.L	D3	LIB	?DRSEG		; dessine une ligne verticale	POP.L	D3	PUSH.L	D3	INC.W	D3	LIB	?DRSEG		; double l'paisseur	POP.L	D3	ADD.W	D3,D1	PUSH.L	D3	LIB	?DRSEG		; dessine une ligne verticale	POP.L	D3	LOAD.W	D3,D0	ADD.W	D3,D0	ADD.W	D3,D0	PUSH.L	D3	LIB	?DRSEG		; dessine une ligne verticale	POP.L	D3	PUSH.L	D3	INC.W	D3	LIB	?DRSEG		; double l'paisseur	POP.L	D3	ADD.W	D3,D1	PUSH.L	D3	LIB	?DRSEG		; dessine une ligne verticale	POP.L	D3	LIB	?NOBUCAR	POPM.L	D0..D6	RET;------------\\; AFNBSOFTKEY >;============/; Affiche le numro de canal midi dans les "soft-keys".; in	D2.W	rang de la soft-key;	D4.W	nombre  afficher (0..99); out	-; mod	D7.WAFNBSOFTKEY:	PUSHM.L	D1..D5,A3,A4	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	CLR.L	D1	LOAD.W	D1,D4		; D1 <-- nombre  afficher	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	A3,#R16"TICOBASE	LOAD.L	A4,#0	DBOX_	ICOPOS		; D3/D4 <-- position/dimensions	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; efface le numro prcdent	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- au milieu en X	LOAD.W	D4,(A0)+ODFCX	COMP.W	D1,#10	JUMP,HS 35$	SR.W	D4,#135$:	SUB.W	D3,D4	INC.W	D3	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- au milieu en Y	LOAD.W	D4,(A0)+ODFC1Y	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	LIB	?SETCURS	LOAD.B	D3,#AFINV	LIB	?AFCAR	LOAD.L	D4,D1		; D4 <-- nombre  afficher	LOAD.W	D3,#2		; D3 <-- nb max digits	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode	LIB	?AFDEC		; affiche le numro 1..16	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LOAD.W	D5,(A6)+ONOWDO	LIB	?USEWDO		; rutilise swdo initiale	POPM.L	D1..D5,A3,A4	RET;--------\\; AFMENU  >;========/; Remet les soft-keys standards.; in	-; out	-; mod	-AFMENU:	PUSHM.L	D2,D4,D7,A3,A4	LOAD.L	A3,#R16"TICOBASE	LOAD.L	A4,#0	DBOX_	ICOAFF		; affiche les icnes en bas	.IF	FB01	LOAD.W	D4,(A6)+OBANK	LOAD.W	D2,#8	CALL	AFNBSOFTKEY	; affiche le numro de banque	LOAD.W	D4,(A6)+OINSTR	LOAD.W	D2,#11	CALL	AFNBSOFTKEY	; affiche le numro d'instrument	.ENDIF	LOAD.L	A3,#R16"TMENUBASE	LIB	?AFMENU	POPM.L	D2,D4,D7,A3,A4	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET	.INS	DXEDIT.ASI	.INS	DXMIDI.ASI	.IF	DX7	.INS	DX7TABLE.ASI	.ENDIF	.IF	DX100	.INS	DX100TABLE.ASI	.ENDIF	.IF	FB01	.INS	FB01TABLE.ASI	.ENDIF; Tables; ------TDBOX_INPUT:	.W	10$-TDBOX_INPUT	.W	20$-TDBOX_INPUT	.W	30$-TDBOX_INPUT	.W	010$:	.B	ODBTEXT	.ASCIZ	" Nom des timbres  prendre :"	.B	ODBCR,ODBCR	.B	ODBFILE,LBUFILE	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	"LISTE"	.B	ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" PREND  "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Liste"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"30$:	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.B	ICOPREND,ICOFLOPPY,ICOVIDE	.B	0,0,0	.B	ICOLISTE,ICOLISTE,ICOLISTE	.B	0,0,0	.B	ICOANNULE,ICOANNULE,ICOANNULE	.EVENTKEY_INPUT:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_INPUT	.W	CR,F1,F2,F3,0		DOKF1-TKEY_INPUT	.W	F7,F8,F9,0		DOKF7-TKEY_INPUT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_INPUT	.W	0TDBOX_OUTPUT:	.W	10$-TDBOX_OUTPUT	.W	20$-TDBOX_OUTPUT	.W	30$-TDBOX_OUTPUT	.W	010$:	.B	ODBTEXT	.ASCIZ	" Nom des timbres  sauver :"	.B	ODBCR,ODBCR	.B	ODBFILE,LBUFILE	.B	ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" SAUVE "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"30$:	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.B	ICOVIDE,ICOFLOPPY,ICOSAUVE	.B	0,0,0	.B	0,0,0	.B	0,0,0	.B	ICOANNULE,ICOANNULE,ICOANNULE	.EVENTKEY_OUTPUT:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_OUTPUT	.W	CR,F1,F2,F3,0		DOKF1-TKEY_OUTPUT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_OUTPUT	.W	0DOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF13:	LOAD.W	D3,#F13	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RET; Listes de touches pour le DX; ----------------------------TDXIECRIT:	.IF	DX7	.B	KDX7PINT,KDX7OFF	.B	KDX7FUNC,KDX7NUM+1,KDX7NUM+8,KDX7NUM+8,KDX7ON	.ENDIF	.IF	DX100	.B	KDX100FUNC,KDX100NUM+12,KDX100OFF	.ENDIF	.B	-1TDXOECRIT:	.IF	DX7	.B	KDX7FUNC,KDX7NUM+1,KDX7NUM+8,KDX7NUM+8,KDX7OFF	.B	KDX7PINT,KDX7ON	.B	KDX7SINT,KDX7NUM+1	.ENDIF	.IF	DX100	.B	KDX100FUNC,KDX100NUM+12,KDX100ON	.B	KDX100INT,KDX100NUM+1	.ENDIF	.B	-1TDXILIT:	.IF	DX7	.B	KDX7FUNC,KDX7NUM+1,KDX7NUM+8,KDX7NUM+8,KDX7ON	.B	KDX7NUM+8	.ENDIF	.B	-1TDXOLIT:	.IF	DX7	.B	KDX7FUNC,KDX7NUM+1,KDX7NUM+8,KDX7NUM+8,KDX7OFF	.B	KDX7SINT	.ENDIF	.B	-1TDXIEDIT:	.IF	DX7	.B	KDX7PINT,KDX7OFF	.B	KDX7FUNC,KDX7NUM+1,KDX7NUM+8,KDX7NUM+8,KDX7ON	.B	KDX7SINT	.ENDIF	.IF	DX100	.B	KDX100FUNC,KDX100NUM+12,KDX100OFF	.B	KDX100INT	.ENDIF	.B	-1TDXOEDIT:	.IF	DX7	.B	KDX7FUNC,KDX7NUM+1,KDX7NUM+8,KDX7NUM+8,KDX7OFF	.B	KDX7PINT,KDX7ON	.B	KDX7SINT	.ENDIF	.IF	DX100	.B	KDX100FUNC,KDX100NUM+12,KDX100ON	.B	KDX100INT	.ENDIF	.B	-1TVOICEINIT:	.IF	DX7	.B	99,99,99,99,99,99,99,0	.B	0,0,0,0,56,0,0,2	.B	0,99,99,99,99,99,99,99	.B	0,0,0,0,0,56,0,0	.B	2,0,99,99,99,99,99,99	.B	99,0,0,0,0,0,56,0	.B	0,2,0,99,99,99,99,99	.B	99,99,0,0,0,0,0,56	.B	0,0,2,0,99,99,99,99	.B	99,99,99,0,0,0,0,0	.B	56,0,0,2,0,99,99,99	.B	99,99,99,99,0,0,0,0	.B	0,56,0,99,2,0,99,99	.B	99,99,50,50,50,50,0,8	.B	35,0,0,0,49,24,32,32	.B	32,32,32,32,32,32,32,32	.ENDIF	.IF	DX100	.B	H'1F,H'1F,H'00,H'0F,H'0F,H'00,H'00,H'00	.B	H'04,H'03,H'1F,H'1F,H'00,H'0F,H'0F,H'00	.B	H'00,H'00,H'04,H'03,H'1F,H'1F,H'00,H'0F	.B	H'0F,H'00,H'00,H'00,H'04,H'03,H'1F,H'1F	.B	H'00,H'0F,H'0F,H'00,H'00,H'5A,H'04,H'03	.B	H'00,H'23,H'00,H'00,H'00,H'62,H'18,H'04	.B	H'04,H'00,H'63,H'32,H'00,H'00,H'00,H'32	.B	H'00,H'20,H'20,H'20,H'20,H'20,H'20,H'20	.B	H'20,H'20,H'20,H'63,H'63,H'63,H'32,H'32	.B	H'32,H'00,H'00,H'00,H'00,H'00,H'00,H'00	.B	H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00	.B	H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00	.B	H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00	.B	H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00	.B	H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00	.B	H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00	.ENDIF	.IF	FB01NBANK3:	.ASCIZ	"BANK3"NBANK4:	.ASCIZ	"BANK4"NBANK5:	.ASCIZ	"BANK5"NBANK6:	.ASCIZ	"BANK6"NBANK7:	.ASCIZ	"BANK7"TBANK3:	.ASCII	"Brass  "	.ASCII	"Horn   "	.ASCII	"Trumpet"	.ASCII	"LoStrig"	.ASCII	"Strings"	.ASCII	"Piano  "	.ASCII	"NewEP  "	.ASCII	"EGrand "	.ASCII	"Jazz Gt"	.ASCII	"EBass  "	.ASCII	"WodBass"	.ASCII	"EOrgan1"	.ASCII	"EOrgan2"	.ASCII	"Porgan1"	.ASCII	"Porgan2"	.ASCII	"Flute  "	.ASCII	"Picolo "	.ASCII	"Oboe   "	.ASCII	"Clarine"	.ASCII	"Glocken"	.ASCII	"Vibes  "	.ASCII	"Xylophn"	.ASCII	"Koto   "	.ASCII	"Zither "	.ASCII	"Clav   "	.ASCII	"Harpsic"	.ASCII	"Bells  "	.ASCII	"Harp   "	.ASCII	"SmadSyn"	.ASCII	"Harmoni"	.ASCII	"SteelDr"	.ASCII	"Timpani"	.ASCII	"LoStrg2"	.ASCII	"Horn Lo"	.ASCII	"Whistle"	.ASCII	"ZingPlp"	.ASCII	"Metal  "	.ASCII	"Heavy  "	.ASCII	"FunkSyn"	.ASCII	"Voices "	.ASCII	"Marimba"	.ASCII	"EBass2 "	.ASCII	"SnareDr"	.ASCII	"RD Cymb"	.ASCII	"Tom Tom"	.ASCII	"Mars to"	.ASCII	"Storm  "	.ASCII	"Windbel"TBANK4:	.ASCII	"UpPiano"	.ASCII	"SPiano "	.ASCII	"Piano2 "	.ASCII	"Piano3 "	.ASCII	"Piano4 "	.ASCII	"Piano5 "	.ASCII	"PhGrand"	.ASCII	"Grand  "	.ASCII	"DpGrand"	.ASCII	"LPiano1"	.ASCII	"LPiano2"	.ASCII	"EGrand2"	.ASCII	"Honkey1"	.ASCII	"Honkey2"	.ASCII	"Pfbell "	.ASCII	"PfVibe "	.ASCII	"NewEP2 "	.ASCII	"NewEP3 "	.ASCII	"NewEP4 "	.ASCII	"NewEP5 "	.ASCII	"EPiano1"	.ASCII	"EPiano2"	.ASCII	"EPiano3"	.ASCII	"EPiano4"	.ASCII	"EPiano5"	.ASCII	"HighTin"	.ASCII	"H