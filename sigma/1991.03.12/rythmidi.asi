	.SBTTL	RYTHMIDI; Routines MIDI; -------------;----------\\; SELPTRACK >;==========/; Slectionne le temps  sauter au dbut et les pistes;  couter selon les fanions.; in	-; out	D7.W	erreur; mod	D7.WSELPTRACK:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A4,#(A6)+OBUCOM+20	LOAD.W	D4,#20-110$:	CLR.B	(-A4)	DECJ.W,NMO D4,10$	LOAD.B	(A4)+0,#'M	; <midi>	LOAD.B	(A4)+1+RYTRACK,(A6)+OCHMIDI+1	CALL	COMMAND		; commande les canaux midi	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM+20	LOAD.W	D4,#20-120$:	CLR.B	(-A4)	DECJ.W,NMO D4,20$	LOAD.B	(A4)+0,#'O	; <offset>	CALL	COMMAND		; commande les transpositions	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM+20	LOAD.W	D4,#20-130$:	CLR.B	(-A4)	DECJ.W,NMO D4,30$	LOAD.B	(A4)+0,#'A	; <amplitude>	CALL	COMMAND		; commande les amplitudes	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM+20	LOAD.W	D4,#20-140$:	CLR.B	(-A4)	DECJ.W,NMO D4,40$	LOAD.B	(A4)+0,#'D	; <dynamique>	CALL	COMMAND		; commande les dynamiques	JUMP,NE 90$	LOAD.W	D4,(A6)+OASVIT+OSCPOSV ; D4 <-- vitesse	CALL	VITESSE		; commande la bonne vitesse	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'C	; <canal>	LOAD.B	(A4)+1,#-1	; <bits>	LOAD.B	(A4)+2,#-1	; <bits>	CLR.B	(A4)+3	CALL	COMMAND		; coute tous les canaux90$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; VITESSE >;========/; Donne une nouvelle consigne de vitesse.; in	D4.W	nouvelle vitesse; out	D7.W	erreur; mod	D7.WVITESSE:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'V	; <vitesse>	SUB.W	D4,#MAXVIT	NEG.W	D4		; D4 <-- vitesse (-MAXVIT..+MAXVIT)	LOAD.W	(A4)+1,D4	CLR.B	(A4)+3	CALL	COMMAND		; commande la bonne vitesse	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; COMMAND >;========/; Envoie une commande  MIDI.; in	A4.L	^commande; out	D7.W	erreur; mod	D7.WCOMMAND:	PUSHM.L	D1,D2	LOAD.W	D1,#TYPIO	; D1 <-- type	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DCOMMAND	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; STOPMIDI >;=========/; Stoppe compltement MIDI.; in	-; out	-; mod	D7.WSTOPMIDI:	PUSH.L	D2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DAVOTR		; avort lecture/criture	POP.L	D2	RET;--------\\; OPEMIDI >;========/; Ouvre le driver MIDI.; in	-; out	D7.W	erreur; mod	D7.WOPEMIDI:	PUSHM.L	D2,D3,A2..A4	LOAD.L	A3,#R16"DMIDI	FOS	?UNAMDRIV	; D2 <-- numro de driver	JUMP,NE	90$	LOAD.W	(A6)+ONDMIDI,D2	90$:	POPM.L	D2,D3,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOMIDI >;========/; Ferme le driver MIDI.; in	-; out	-; mod	D7.WCLOMIDI:	RET	.END