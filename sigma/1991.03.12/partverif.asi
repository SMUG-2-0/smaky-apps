	.SBTTL	PARTVERIF;---------\\; ALLVERIF >;=========/; Vrifie la mise en page avant impression ...; in	-; out	D7.W	erreur; mod	D7.WALLVERIF:	PUSHM.L	D0..D5,A1..A4	CALL	_WAITMOUSE	; souris: met le sablier	SET.B	(A6)+OVERIF	CALL	OPEPRINT	; ouvre l'imprimante	JUMP,NE 90$	CALL	CLOPRINT	; ferme l'imprimante	LOAD.L	A2,#R16"TDBOX_VERIF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.W	D0,#110$:	CALL	_WAITMOUSE	; souris: met le sablier	CALL	DIMVERIF	; calcul qq dimensions	JUMP,NE 80$	CALL	PAGEVERIF	; dessine les pages vides	SET.B	(A6)+OVERIF	LOAD.B	(A6)+OVEFLAG,D4	CLR.W	(A6)+OVENUMY	CALL	ALLPRINT	; affiche toutes les pages	CALL	_NORMMOUSE	; souris: enlve le sablier20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_PRINT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; (VU) ?	JUMP,EQ 80$	COMP.W	D3,#'+	JUMP',EQ 40$	COMP.W	D3,#'-	JUMP',EQ 45$	COMP.W	D3,#KEYDBOX+BVECALE	JUMP,EQ 10$30$:				; touche inconnue =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; (+) =>	COMP.W	D0,#4	JUMP,EQ 30$	INC.W	D0	JUMP	10$45$:				; (-) =>	COMP.W	D0,#1	JUMP,EQ 30$	DEC.W	D0	JUMP	10$80$:	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D790$:	POPM.L	D0..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DIMVERIF >;---------/; Calcul les dimensions en fonction du nombre de pages demandes.; in	D0.W		nombre de pages verticalement (1..n);	D5.L		canal DBOX; out	(A6)+OVENBX,Y	nombre de pages (1..n);	(A6)+OVEPOSX,Y	position premire page;	(A6)+OVEDIMX,Y	dimensions d'une page;	(A6)+OVEECAX,Y	cartement entre les pages;	(A6)+OVEFACX,Y	facteur de rduction;	D7.W		erreur; mod	D7.WDIMVERIF:	PUSHM.L	D0..D4	LOAD.W	D2,#1	DBOX_	GETCO		; D3 <-- coin inf/droite dans DBOX	PUSH.L	D3	CLR.W	D2	DBOX_	GETCO		; D4 <-- coin sup/gauche dans DBOX	LOAD.L	(A6)+OVEPOSY,D3	POP.L	D4	SUB.W	D4,D3		; D4 <-- largeur dans DBOX	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur dans DBOX	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#1		; D7 <-- impossible; Calcul d'abord le facteur pour permettre de caser le nombre de pages; demandes en Y.	LOAD.L	D3,D4	CLR.W	D3	SWAP.W	D3		; D3 <-- hauteur [p]	DIV.WU	D3,D0	SUB.W	D3,#10	CLR.L	D2	LOAD.W	D2,(A6)+OIMPY	ADD.W	D2,(A6)+OIMMYS	ADD.W	D2,(A6)+OIMMYI	; D2 <-- hauteur d'une page [pi]	DIV.WU	D2,D3	JUMP,EQ 90$	INC.W	D2	LOAD.W	(A6)+OVEFACY,D2	LOAD.W	(A6)+OVEFACX,D2; Calcule toutes les variables verticales.	LOAD.W	D3,#10		; D3 <-- rserve	CLR.L	D2	LOAD.W	D2,(A6)+OIMPY	ADD.W	D2,(A6)+OIMMYS	ADD.W	D2,(A6)+OIMMYI	DIV.WU	D2,(A6)+OVEFACY	LOAD.W	(A6)+OVEDIMY,D2	ADD.W	D2,D3	LOAD.W	(A6)+OVEECAY,D2	LOAD.L	D3,D4	CLR.W	D3	SWAP.W	D3		; D3 <-- hauteur [p]	DIV.WU	D3,D2	JUMP,EQ 90$	LOAD.W	(A6)+OVENBY,D3; Calcule toutes les variables horizontales.	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#4	ADD.W	(A6)+OVEPOSX,D3	ADD.W	D3,(A0)+ODFCX	; D3 <-- rserve	CLR.L	D2	LOAD.W	D2,(A6)+OIMLX	ADD.W	D2,(A6)+OIMMXG	ADD.W	D2,(A6)+OIMMXD	DIV.WU	D2,(A6)+OVEFACX	LOAD.W	(A6)+OVEDIMX,D2	ADD.W	D2,D3	LOAD.W	(A6)+OVEECAX,D2	CLR.L	D3	LOAD.W	D3,D4		; D3 <-- largeur [p]	DIV.WU	D3,D2	JUMP,EQ 90$	LOAD.W	(A6)+OVENBX,D3	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; PAGEVERIF >;==========/; Efface l'emplacement et dessine toutes les pages vides.; in	-; out	-; mod	D7.WPAGEVERIF:	PUSHM.L	D0..D5	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.W	D2,#1	DBOX_	GETCO		; D3 <-- coin inf/droite	PUSH.L	D3	CLR.W	D2	DBOX_	GETCO		; D4 <-- coin sup/gauche	POP.L	D4	SUB.W	D4,D3		; D4 <-- largeur	ADD.W	D4,#3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur	ADD.W	D4,#3	SWAP.W	D3	SWAP.W	D4	CLR.W	D3	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface tout l'emplacement	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit trame pour ombre rectangles	LOAD.L	D3,(A6)+OVEPOSY	LOAD.W	D0,(A6)+OVENBY	; D0 <-- compteur en Y20$:	LOAD.W	D3,(A6)+OVEPOSX	LOAD.W	D5,(A6)+OVENBX	; D5 <-- compteur en X30$:	LOAD.L	D4,(A6)+OVEDIMY	LOAD.W	D2,#SETDOT	LOAD.W	D1,#3	LIB	?DRRECTO	; dessine una page vide	ADD.W	D3,(A6)+OVEECAX	DEC.W	D5	JUMP,NE 30$	SWAP.W	D3	ADD.W	D3,(A6)+OVEECAY	SWAP.W	D3	DEC.W	D0	JUMP,NE 20$	POPM.L	D0..D5	RET;---------\\; DESVERIF >;=========/; Dessine une partie de mesure en mignature.; in	D3.L	coin sup/gauche; 	D4.L	dimensions;	D5.W	tranche verticale; out	-; mod	D7.WDESVERIF:	PUSHM.L	D2..D4,A4	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	TEST.L	D5:#BIMTITRE	JUMP,BS 10$	TEST.L	D5:#BIMDEBUT	JUMP,BS 15$	TEST.L	D5:#BIMTRAIT	JUMP,BS 20$	TEST.L	D5:#BIMCLEF	JUMP,BS 25$	TEST.L	D5:#BIMALT	JUMP,BS 30$	TEST.L	D5:#BIMCALE	JUMP,BS 35$	TEST.L	D5:#BIMBARREG	JUMP,BS 40$	TEST.L	D5:#BIMNOTE	JUMP,BS 45$	TEST.L	D5:#BIMBARRED	JUMP,BS 50$	TEST.L	D5:#BIMFIN	JUMP,BS 55$	JUMP	90$10$:				; titre =>	PUSHM.L	D3,D4	LOAD.L	D3,#H'55AA55AA	LOAD.L	D4,D3	LIB	?DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	JUMP	90$15$:				; dbut de la ligne =>	CALL	DESDEBVERIF	JUMP	90$20$:				; trait =>	CALL	DESVERTVERIF	JUMP	90$25$:				; clef =>	CALL	DESPORTVERIF	JUMP	90$30$:				; altration =>	CALL	DESPORTVERIF	ADD.W	D3,D4	DEC.W	D3	CALL	DESVERTVERIF	JUMP	90$35$:				; cale =>	TEST.B	(A6)+OVEFLAG:#BVECALE	JUMP,BS 90$	CALL	DESPORTVERIF	JUMP	90$40$:				; barre  gauche =>	TEST.B	(A6)+OVEFLAG:#BVECALE	JUMP,BS 90$	CALL	DESPORTVERIF	JUMP	90$45$:				; notes =>	CALL	DESPORTVERIF	JUMP	90$50$:				; barre  droite =>	TEST.B	(A6)+OVEFLAG:#BVECALE	JUMP,BS 90$	CALL	DESPORTVERIF	JUMP	90$55$:				; fin de la mesure =>	CALL	DESVERTVERIF;	JUMP	90$90$:	POPM.L	D2..D4,A4	RET;-------------\\; DESVERTVERIF >;-------------/; Dessine un trait vertical pour lier les portes.; in	D3.L	coin sup/gauche; 	D4.L	dimensions;	A4.L	^mesure; out	-; mod	D7.WDESVERTVERIF:	PUSHM.L	D0..D4,A3	LOAD.L	A3,#(A4)+OMELP	; A3 <-- ^premire porte	LOAD.W	D2,#MAXLP	LOAD.W	D0,#-1		; D0 <-- min	CLR.W	D1		; D1 <-- max10$:	COMP.B	(A3)+OLPTYP,#ICOVIDE	JUMP',EQ 20$	COMP.W	D0,(A3)+OLPDY	JUMP',LS 15$	LOAD.W	D0,(A3)+OLPDY	; D0 <-- min15$:	COMP.W	D1,(A3)+OLPDY	JUMP',HS 20$	LOAD.W	D1,(A3)+OLPDY	; D1 <-- max20$:	LOAD.L	A3,#(A3)+LLP	DEC.W	D2	JUMP,NE 10$	ADD.W	D1,#LYPORTEE*(NPORTEE-1)	SUB.W	D1,D0		; D1 <-- hauteur	CALL	SCALEVERIF	SWAP.W	D3	ADD.W	D3,D0		; D3 <-- position en Y	DEC.W	D3	SWAP.W	D3	LOAD.W	D0,D1	CALL	SCALEVERIF	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- hauteur	ADD.W	D4,#2	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; dessine une barre verticale	POPM.L	D0..D4,A3	RET;-------------\\; DESPORTVERIF >;-------------/; Dessine une partie de portes.; in	D3.L	coin sup/gauche; 	D4.L	dimensions;	A4.L	^mesure; out	-; mod	D7.WDESPORTVERIF:	PUSHM.L	D0..D4,A3	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	POPM.L	D3,D4	LOAD.L	A3,#(A4)+OMELP	; A3 <-- ^premire porte	LOAD.W	D1,#MAXLP10$:	COMP.B	(A3)+OLPTYP,#ICOVIDE	JUMP',EQ 40$	PUSHM.L	D3,D4	LOAD.W	D0,(A3)+OLPDY	CALL	SCALEVERIF	SWAP.W	D3	ADD.W	D3,D0		; D3 <-- position en Y	SWAP.W	D3	LOAD.W	D0,#LYPORTEE*(NPORTEE-1)	CALL	SCALEVERIF	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- paisseur	JUMP',NE 30$	INC.W	D4		; D4 <-- au moins un !30$:	SWAP.W	D4	INC.W	D4		; D4 <-- longueur	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; dessine une porte	POPM.L	D3,D440$:	LOAD.L	A3,#(A3)+LLP	DEC.W	D1	JUMP,NE 10$	POPM.L	D0..D4,A3	RET;------------\\; DESDEBVERIF >;------------/; Dessine le numro de la premire mesure de la ligne.; in	D3.L	coin sup/gauche; 	D4.L	dimensions;	A4.L	^mesure; out	-; mod	D7.WDESDEBVERIF:	PUSHM.L	D1..D4	CLR.L	D1	LOAD.W	D1,(A6)+OMESC	; D1 <-- numro de la mesure	INC.W	D1		; D1 <-- on commence  1 !	CLR.L	D2	LOAD.W	D2,(A6)+OIMMXG	DIV.WU	D2,(A6)+OVEFACX	SUB.W	D3,D2	DEC.W	D3	LOAD.W	D4,(A0)+ODFCX	COMP.W	D1,#10	JUMP',LO 20$	SL.W	D4,#120$:	ADD.W	D4,(A0)+ODFCX	ADD.W	D4,(A0)+ODFCX	SUB.W	D3,D4		; D3 <-- position en X	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	LOAD.W	D4,(A0)+ODFC1Y;;?	ADD.W	D4,(A0)+ODFC2Y	SR.W	D4,#1	SUB.W	D3,D4	ADD.W	D3,(A0)+ODFC1Y	; D3 <-- position en Y	LOAD.W	D2,D3	SUB.W	D2,(A6)+OVENUMY	JUMP',LO 40$	COMP.W	D2,(A0)+ODFC1Y	; trop proche du numro prcdent ?	JUMP',LS 90$		; oui => 90$40$:	LOAD.W	(A6)+OVENUMY,D3	SWAP.W	D3	LIB	?SETCURS	; positionne le curseur	LOAD.L	D4,D1		; D4 <-- numro (1..n)	LOAD.W	D3,#2		; D3 <-- 2 digits	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode	LIB	?AFDEC		; affiche le numro de mesure	LIB	?AFSPACE	LOAD.B	D3,#9	LIB	?AFCODE		; affiche flche "->"90$:	POPM.L	D1..D4	RET;-----------\\; SCALEVERIF >;-----------/; Rduit des dimensions pour le dessin en mignature.; in	D0.L	dimensions (dy;dx); out	D0.L	dimensions rduites; mod	D0.LSCALEVERIF:	PUSH.L	D1	CLR.L	D1	LOAD.W	D1,D0	DIV.WU	D1,(A6)+OVEFACX	LOAD.W	D0,D1		; D0 <-- largeur rduite	SWAP.W	D0	CLR.L	D1	LOAD.W	D1,D0	DIV.WU	D1,(A6)+OVEFACY	LOAD.W	D0,D1		; D0 <-- hauteur rduite	SWAP.W	D0	POP.L	D1	RET	.END