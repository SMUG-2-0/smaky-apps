	.SBTTL	SEQCONFIG;-----------\\; DBOXCONFIG >;===========/; Choix de la configuration du systme.; in	-; out	D7.W	erreur; mod	D7.WDBOXCONFIG:	PUSHM.L	D0..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_CONFIG	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	CLR.W	D210$:	CALL	DBCFGETN	; A3 <-- ^nom	CALL	DBCFAFFN	; affiche le nom	INC.W	D2	COMP.W	D2,#16	JUMP,LO 10$	CLR.W	D220$:	CALL	DBCFGETN	; A3/A4 <-- ^dbut/fin nom	LOAD.W	D3,D2		; D3 <-- rang (0..15)	DBOX_	MEDIT	DBOX_	EDIT		; attend une action ...	CALL	DBCFPUTN	LOAD.L	A1,#R16"TKEY_CONFIG	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	60$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	80$	COMP.W	D3,#UNDO	JUMP',EQ 40$	COMP.W	D3,#CR	JUMP',EQ 50$	COMP.W	D3,#KEYDBOX+0	JUMP',LO 30$	COMP.W	D3,#KEYDBOX+16-1	JUMP',LO 45$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; (UNDO) =>	LOAD.L	A4,A3	CLR.B	(A3)	CALL	DBCFPUTN	JUMP	20$45$:				; clic =>	SUB.W	D3,#KEYDBOX	LOAD.W	D2,D3	JUMP	20$50$:				; (RETURN) =>	INC.W	D2	COMP.W	D2,#16-1	JUMP,LO 20$	CLR.W	D2	JUMP	20$60$:				; (D'ACCORD) =>	CALL	WAITMOUSE	CALL	WRITECONFIG	; mj sur disque la configuration	CALL	MODCONFIG	; charge/libre les modules synth	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys	CALL	DBOXMIDI	; affiche les canaux midi	CALL	NORMMOUSE	JUMP'	90$80$:				; (ANNULE) =>	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys90$:	POPM.L	D0..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBCFGETN >;---------/; Cherche un nom d'aprs son rang.; in	D2.W	rang (0..15); out	A3.L	^dbut nom;	A4.L	^fin nom; mod	D7.W, A3.L, A4.LDBCFGETN:	PUSH.L	D2	LOAD.L	A3,#(A6)+OCONFIG+OCFNOM	MUL.WU	D2,#LCF	ADD.L	A3,D2	LOAD.L	A4,#(A6)+OBUNAME20$:	LOAD.B	(A4+),(A3+)	JUMP,NE 20$	DEC.L	A4		; A4 <-- ^fin du nom	LOAD.L	A3,#(A6)+OBUNAME	POP.L	D2	RET;---------\\; DBCFPUTN >;---------/; Met  jour un nom d'aprs son rang.; in	D2.W	rang (0..15);	A3.L	^dbut nom; out	-; mod	D7.WDBCFPUTN:	PUSHM.L	D2,A3,A4	LOAD.L	A4,#(A6)+OCONFIG+OCFNOM	MUL.WU	D2,#LCF	ADD.L	A4,D2		; A4 <-- ^place o mettre le nom20$:	LOAD.B	(A4+),(A3+)	JUMP',EQ 90$	COMP.B	(A4)-1,#CR	JUMP,NE 20$	CLR.B	(A4)-190$:	POPM.L	D2,A3,A4	RET;---------\\; DBCFAFFN >;---------/; Affiche un nom d'aprs son rang.; in	D2.W	rang (0..15);	A3.L	^dbut nom; out	-; mod	D7.WDBCFAFFN:	PUSHM.L	D2..D4,A3	SL.W	D2,#1	INC.W	D2		; D2 <-- (rang*2)+1	DBOX_	GETCO	JUMP',NE 90$	LIB	?SETCURS	LIB	?AFTEXT90$:	POPM.L	D2..D4,A3	RET;------------\\; WRITECONFIG >;============/; Met  jour sur disque la configuration.; in	-; out	D7.W	erreur; mod	D7.WWRITECONFIG:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	A3,#(A6)+OCONFIG+OCFNOM	LOAD.W	D4,#16-110$:	LOAD.W	D3,#8-115$:	LOAD.B	(A4+),(A3+)	DECJ.W,NMO D3,15$	LOAD.L	A3,#(A3)+LCF-8	DECJ.W,NMO D4,10$	LOAD.L	A3,#R16"NFCONF	FOS	?DELETE	LOAD.L	D3,#DEFATT-(2^BATTL)	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE 90$	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	D4,#8*16	FOS	?WRBYTE	JUMP',NE 80$	FOS	?CLOSE	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; READCONFIG >;===========/; Lit sur disque la configuration.; in	-; out	-; mod	D7.WREADCONFIG:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A4,#(A6)+OCONFIG	LOAD.W	D4,#(LCF*16)-110$:	CLR.B	(A4+)	DECJ.W,NMO D4,10$	LOAD.L	A3,#R16"NFCONF	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE 85$	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	D4,#8*16	FOS	?RDBYTE	JUMP',NE 80$	FOS	?CLOSE	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	A3,#(A6)+OCONFIG+OCFNOM	LOAD.W	D4,#16-140$:	LOAD.W	D3,#8-145$:	LOAD.B	(A3+),(A4+)	DECJ.W,NMO D3,45$	LOAD.L	A3,#(A3)+LCF-8	DECJ.W,NMO D4,40$	JUMP'	90$80$:	FOS	?CLOSE85$:	CALL	DEFCONFIG	; met la configuration par dfaut90$:	POPM.L	D3,D4,D6,A3,A4	RET;----------\\; DEFCONFIG >;----------/; Initialise la configuration par dfaut.; in	-; out	-; mod	D7.WDEFCONFIG:	PUSHM.L	D4,A3,A4	LOAD.L	A4,#(A6)+OCONFIG	LOAD.W	D4,#(LCF*16)-110$:	CLR.B	(A4+)	DECJ.W,NMO D4,10$	LOAD.L	A3,#R16"00$20$:	CLR.W	D3	LOAD.B	D3,(A3+)	; D3 <-- canal midi (0..15)	JUMP',NS 90$	MUL.WU	D3,#LCF	LOAD.L	A4,#(A6)+OCONFIG+OCFNOM	ADD.L	A4,D330$:	LOAD.B	(A4+),(A3+)	JUMP,NE 30$	JUMP	20$90$:	POPM.L	D4,A3,A4	RET00$:		      ;     ;   <-- lg max	.ASCIZ	"<01-1>DX100"	.ASCIZ	"<02-1>DX100"	.ASCIZ	"<03-1>DX7"	.ASCIZ	"<04-1>DX7"	.ASCIZ	"<10-1>Rythm"	.ASCIZ	"<16-1>Smaky"	.B	-1	.EVEN;------------\\; CLEARCONFIG >;============/; Libre tous les modules des synthtiseurs.; in	-; out	-; mod	D7.WCLEARCONFIG:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OCONFIG	LOAD.W	D4,#16-110$:	CLR.B	(A4)+OCFNOM	; supprime tous les noms	LOAD.L	A4,#(A4)+LCF	DECJ.W,NMO D4,10$	CALL	MODCONFIG	POPM.L	D4,A4	RET;----------\\; MODCONFIG >;==========/; Charge tous les modules lib des synthtiseurs ncessaires; selon la configuration.; Ceux qui ne sont plus ncessaires sont librs !; in	-; out	-; mod	D7.WMODCONFIG:	PUSHM.L	D1,D3..D5,A3..A5	LOAD.L	A5,#(A6)+OCONFIG	CLR.W	D510$:	LOAD.L	A3,#(A5)+OCFNOM	CALL	NOCONFIG	; D3 <-- cherche le numro du nouveau module	COMP.W	D3,(A5)+OCFMOD	; toujours le mme module ?	JUMP,EQ 80$		; oui => 80$; Libre le module actuellement utilis.	TEST.W	(A5)+OCFMOD	; module existe ?	JUMP',EQ 20$		; non => 20$	LOAD.L	A4,(A5)+OCFPV	; A4 <-- ^variables du module	LOAD.L	A3,(A5)+OCFACLOSE	CALL	(A3)		; ferme le module synth	LOAD.W	D1,(A5)+OCFCH	LIB_	CLOSE		; libre le module synth20$:	LOAD.W	(A5)+OCFMOD,D3	JUMP,EQ 80$; Charge le nouveau module demand et initialise tout ce qu'il; lui faut.	LIB_	OPEN		; charge le module synth	JUMP,NE 70$	LOAD.W	(A5)+OCFCH,D1	LIB_	GETAD		; A3 <-- ^identificateur	JUMP,NE 60$	COMP.L	(A3),#H'12345678	JUMP,NE 60$	INC.W	D3	LIB_	GETAD		; A3 <-- ^routine OPEN	JUMP,NE 60$	LOAD.L	(A5)+OCFAOPEN,A3	INC.W	D3	LIB_	GETAD		; A3 <-- ^routine EDIT	JUMP,NE 60$	LOAD.L	(A5)+OCFAEDIT,A3	INC.W	D3	LIB_	GETAD		; A3 <-- ^routine CLOSE	JUMP,NE 60$	LOAD.L	(A5)+OCFACLOSE,A3	INC.W	D3	LIB_	GETAD		; A3 <-- ^routine USE	JUMP,NE 60$	LOAD.L	(A5)+OCFAUSE,A3	INC.W	D3	LIB_	GETAD		; A3 <-- ^routine GET	JUMP,NE 60$	LOAD.L	(A5)+OCFAGET,A3	TEST.W	D5	JUMP,NE 30$	LOAD.L	D4,(A6)+OFANION	TSET.L	D4:#BFASYNT	; synthtiseur prsent	LOAD.L	(A6)+OFANION,D430$:	LOAD.W	D4,D5		; D4 <-- canal MIDI  utiliser	LOAD.L	A4,(A5)+OCFAOPEN	CALL	(A4)		; ouvre le module synth	JUMP,EQ 40$	COMP.W	D7,#ERUNCO	; synthtiseur pas connect ?	JUMP,NE 60$		; non => 60$				; oui =>	TEST.W	D5	JUMP,NE 40$	LOAD.L	D4,(A6)+OFANION	TCLR.L	D4:#BFASYNT	; synthtiseur absent	LOAD.L	(A6)+OFANION,D440$:	LOAD.L	(A5)+OCFPV,A4	JUMP	80$60$:	LIB_	CLOSE		; ferme le module synth70$:	CLR.W	(A5)+OCFMOD	; y'a pas de module synth !	TEST.W	D5	JUMP,NE 80$	LOAD.L	D4,(A6)+OFANION	TCLR.L	D4:#BFASYNT	; synthtiseur absent	LOAD.L	(A6)+OFANION,D480$:	LOAD.L	A5,#(A5)+LCF	INC.W	D5	COMP.W	D5,#16	JUMP,LO 10$	POPM.L	D1,D3..D5,A3..A5	RET;---------\\; NOCONFIG >;---------/; Cherche le numro du module lib.; in	A3.L	^nom; out	D3.W	numro du module lib; mod	D3.L, D7.WNOCONFIG:	PUSHM.L	D4,D6,A2..A4	TEST.B	(A3)		; nom existe ?	JUMP,EQ 80$		; non => 80$	LOAD.L	A4,A3	LOAD.L	A2,#R16"00$	LOAD.L	A3,#R16"01$10$:	TEST.B	(A3)	JUMP',EQ 20$	LIB	?CPSTRING	; est-ce un non-module ?	JUMP,NC 80$15$:	TEST.B	(A3+)	JUMP,NE 15$	JUMP	10$20$:	LOAD.L	A3,#R16"02$22$:	LOAD.W	D3,(A3+)	JUMP',EQ 50$	LIB	?CPSTRING	; est un module connu ?	JUMP,NC 90$30$:	TEST.B	(A3+)	JUMP,NE 30$	EX.L	D3,A3	INC.L	D3	TCLR.L	D3:#0	EX.L	A3,D3	JUMP	22$50$:	CALL	GETNMOD		; A3 <-- ^100_xxx.LIB	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le module	JUMP,NE 80$	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute l'en-tte binaire	JUMP,NE 70$	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	D4,#2	FOS	?RDBYTE		; lit juste le numro	JUMP,NE 70$	FOS	?CLOSE	LOAD.W	D3,(A4)		; D3 <-- numro trouv dans le fichier	LOAD.W	D4,D3	AND.W	D4,#H'F000	COMP.W	D4,#H'A000	; est-ce un numro de module ?	JUMP,NE 80$		; non => 80$	JUMP	90$70$:	FOS	?CLOSE80$:	CLR.W	D3		; D3 <-- module introuvable90$:	POPM.L	D4,D6,A2..A4	RET00$:	.B	0,-101$:				; liste des non-modules :	.ASCIZ	"Rythm"	.ASCIZ	"Smaky"	.B	0	.EVEN02$:				; liste des modules connus :	.W	H'A8E0	.ASCIZ	"DX7"	.EVEN	.W	H'AA00	.ASCIZ	"DX100"	.EVEN	.W	H'AA10	.ASCIZ	"FB01"	.EVEN	.W	0;--------\\; GETNMOD >;--------/; Construit le nom d'un module lib.; in	A4.L	^nom brut; out	A3.L	^nom fichier; mod	D7.W, A3.LGETNMOD:	PUSHM.L	D3,D4,A2,A4	NTREL	?GETMACHINE	LOAD.L	A2,#(A6)+OBUNAME10$:	LOAD.B	(A2+),(A3+)	; nom <-- SYS/100	JUMP,NE 10$	LOAD.B	(A2)-1,#'_20$:	LOAD.B	(A2+),(A4+)	; nom <-- DX7, etc.	JUMP,NE 20$	DEC.L	A2	LOAD.L	A4,#R16"00$30$:	LOAD.B	(A2+),(A4+)	; nom <-- .LIB	JUMP,NE 30$	LOAD.L	A3,#(A6)+OBUNAME	POPM.L	D3,D4,A2,A4	RET00$:	.ASCIZ	".lib"	.EVEN;-----------\\; IFSYNTEDIT >;===========/; Vrifie d'il est possible d'diter les sons d'un synthtiseur.; in	D4.W	numro de la piste; out	D7.W	erreur; mod	D7.WIFSYNTEDIT:	PUSHM.L	D0,A0	LOAD.W	D0,D4	LOAD.L	A0,#(A6)+OTRACK	MUL.WU	D0,#LT	ADD.L	A0,D0	LOAD.W	D0,(A0)+OTMIDI	; D0 <-- canal MIDI (0..15)	LOAD.L	A0,#(A6)+OCONFIG	MUL.WU	D0,#LCF	ADD.L	A0,D0	LOAD.W	D7,#ERFDNE	TEST.W	(A0)+OCFMOD	JUMP,EQ 90$	CLR.W	D790$:	POPM.L	D0,A0	TEST.W	D7		; retour EQ/NE	RET;---------\\; SYNTEDIT >;=========/; Edite les sons d'un synthtiseur.; in	D4.W	numro de la piste; out	D7.W	erreur; mod	D7.WSYNTEDIT:	PUSHM.L	D0,A0,A4	LOAD.W	D0,D4	LOAD.L	A0,#(A6)+OTRACK	MUL.WU	D0,#LT	ADD.L	A0,D0	LOAD.W	D0,(A0)+OTMIDI	; D0 <-- canal MIDI (0..15)	LOAD.L	A0,#(A6)+OCONFIG	MUL.WU	D0,#LCF	ADD.L	A0,D0	LOAD.W	D7,#ERFDNE	TEST.W	(A0)+OCFMOD	JUMP,EQ 90$	LOAD.L	A4,(A0)+OCFPV	; A4 <-- ^variables	LOAD.L	A0,(A0)+OCFAEDIT	CALL	(A0)		; appel le module ...90$:	POPM.L	D0,A0,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SYNTUSE >;========/; Donne l'ordre  un synhtiseur d'utiliser un son.; in	D4.W	numro de la piste;	A2.L	^nom du fichier (.part);	A3.L	^nom;	D3.W	numro; out	D7.W	erreur; mod	D7.WSYNTUSE:	PUSHM.L	D0,A0,A4	LOAD.W	D0,D4	LOAD.L	A0,#(A6)+OTRACK	MUL.WU	D0,#LT	ADD.L	A0,D0	LOAD.W	D0,(A0)+OTMIDI	; D0 <-- canal MIDI (0..15)	LOAD.L	A0,#(A6)+OCONFIG	MUL.WU	D0,#LCF	ADD.L	A0,D0	LOAD.W	D7,#ERFDNE	TEST.W	(A0)+OCFMOD	JUMP,EQ 90$	LOAD.L	A4,(A0)+OCFPV	; A4 <-- ^variables	LOAD.L	A0,(A0)+OCFAUSE	CALL	(A0)		; appel le module ...90$:	POPM.L	D0,A0,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SYNTGET >;========/; Donne le son d'un synthtiseur.; in	D4.W	numro de la piste;	A2.L	^nom du fichier (.part); out	A3.L	^nom;	D3.W	numro;	D7.W	erreur; mod	D3.L, D7.W, A3.LSYNTGET:	PUSHM.L	D0,A0,A4	LOAD.W	D0,D4	LOAD.L	A0,#(A6)+OTRACK	MUL.WU	D0,#LT	ADD.L	A0,D0	LOAD.W	D0,(A0)+OTMIDI	; D0 <-- canal MIDI (0..15)	LOAD.L	A0,#(A6)+OCONFIG	MUL.WU	D0,#LCF	ADD.L	A0,D0	LOAD.L	A3,#(A6)+OBUNAME	CLR.B	(A3)	CLR.W	D3	LOAD.W	D7,#ERFDNE	TEST.W	(A0)+OCFMOD	JUMP,EQ 90$	LOAD.L	A4,(A0)+OCFPV	; A4 <-- ^variables	LOAD.L	A0,(A0)+OCFAGET	CALL	(A0)		; appel le module ...90$:	POPM.L	D0,A0,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; AFCFNOM >;========/; Affiche le nom du synthtiseur sous forme de 5 caractres.; in	D4.W	canal MIDI (0..15); out	-; mod	D7.WAFCFNOM:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OCONFIG+OCFNOM	MUL.WU	D4,#LCF	ADD.L	A3,D4	LOAD.L	D3,A3	LIB	?AFTEXT		; affiche le nom du synth	DEC.L	A3	SUB.L	A3,D3	LOAD.W	D3,A3		; D3 <-- nb de caractres affichs	LOAD.W	D4,#5	SUB.W	D4,D3	JUMP',LE 90$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin du nom90$:	POPM.L	D3,D4,A3	RET	.END