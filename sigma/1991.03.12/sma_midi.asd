	.TITLE	SMA_MIDI.ASD;	--------------------------------------;		(C) 1985 - Daniel Roux;	--------------------------------------;	Driver MIDI pour Smaky 100 (100_MIDI.DRIV),;	avec le mme numro que 100_USART.DRIV qui ne;	doit pas tre install en mme temps.;	--------------------------------------;	Le canal 16 correspond le mieux possible au;	synthtiseur interne du Smaky 100 !	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	SM100HARD	.REF	SHIDRIV100	.REF	BIOSDRIV; Format des donnes .MIDI; ------------------------;	|---------|;	|         |;	|-   0   -|;	|         |;	|---------|;	|         |      temps absolu depuis le dbut;	|- temps -|      (l'unit est de 15.625ms = 1/64);	|         |      maximum possible de 17 minutes;	|---------|;;;	|---------|;	|         |;	|-   lg  -|      1..n;	|         |;	|---------|---------;	|1 status |     /|\;	|0 ...    |      |;	|0        |      | lg     donnes MIDI;	|0        |      |;	|0        |     \|/;	|---------|---------; Constantes; ----------REV	=	0VERS	=	8CHPSG	=	16-1			; canal midi "interne"MAXVIT	=	100			; vitesse maximaleNBMIN	=	4+2+3			; nombre min de byteLSTAMP	=	4+2			; longueur du stampLBURALL	=	100			; lg de OBURALL; Units pour la mesure du temps; ------------------------------; Les fichiers .MIDI contiennent des temps dont l'unit est; 1/64me de seconde (donc 15.625ms).; La lecture du temps systme s'obtient avec NTREL,?GETSYTIME en 128us.; Lors de l'enregistrement (read), il faut donc diviser le temps; systme par MVITESSE pour obtenir des 15.625ms.; Lors de la reproduction (write), il faut convertir les 128us; en 50us pour pouvoir utiliser NTREL,?DELUS.UNITE	=	128			; unit de base de 128usMVITESSE=	15625/UNITE		; conversion 15.625ms <--> 128us; Control register 6850; ---------------------MIDIMOD	=	B'00010110		; divise le clock par 64 					; 8 bits 1 stop bitBUSTINT=	B'00100000		; interrupt disable transmitERCVINT=	B'10000000		; interrupt disable receiveMASTRST	=	B'00000011		; soft reset; Status register 6850; --------------------OKJACK	=	2^BUSFUL!2^BUSRDY!2^BUSIREQ;BUSFUL		=	0		; Receive data full.;BUSRDY		=	1		; Transmit data empty.;BUSDCD		=	2		; Data carrier detect.;BUSCTS		=	3		; Clear to send.;BUSFERR	=	4		; Framing error.;BUSOERR	=	5		; Overrun error.;BUSPERR	=	6		; Parity error.;BUSIREQ	=	7		; Interrupt request.; Vecteur d'interruption usarts Smaky 100; ---------------------------------------VECTINT	=	D'29			; Numro vecteur d'interrupt.ADVINT	=	4*VECTINT		; Adresse du vecteur d'interrupt.; Adresses acia 6850; ------------------MIDI1	=	ACIA0+2			; Usart 6850 no 1 DATA.SMIDI1	=	ACIA0			; Usart 6850 no 1 CONTROL-STATUSMIDI2	=	ACIA1+2			; Usart 6850 no 2 DATA.SMIDI2	=	ACIA1			; Usart 6850 no 2 CONTROL-STATUS; Table pour un oscillateur interne; ---------------------------------PSGADR	=	SGADR			; $ pour les adressesPSGDATA	=	SGDATA			; $ pour les datasNBPSG	=	3			; nb d'oscillateurs internes	.LOC	0OPSGF:	.BLKB	1			; flags BPSGUSE=  0				;  oscillateur utilis BPSGATT=  1				;  oscillateur en attaqueOPSGN:	.BLKB	1			; note (0..127)OPSGT:	.BLKB	2			; temps debut le dbutOPSGR:	.BLKB	2			; temps de "release"LPSG:; Variables; ---------	.LOC	0OFLAGS:	.BLKB	1			; flags divers : BREAD	=  0				;  tat lecture BWRITE	=  1				;  tat criture BABORT	=  2				;  abort lecture et criture BIGNORE=  3				;  ignore une commande BSKIP	=  4				;  saute jusqu' OTIME BNOMIDI=  5				;  synth midi absent BFFILS	=  6				;  fin du processus fils BIOF	=  7				;  interrupt disableOFECHO:	.BLKB	1			; flags pour l'cho : BECHOON=  0				;  fait l'cho des notes lues BECHO	=  1				;  cho pour cette commande BSYNCHRO= 2				;  enregistre les synchros (H'F8) BAFTER	=  3				;  enregistre les after touch (H'Dn) BCLOCK	=  4				;  envoie les timing clock (H'F8)	.EVENOCECHO:	.BLKB	2			; compteur pour choOTMPR:	.BLKB	4			; temps absolu de dpart (read)  [128us]OTMPW:	.BLKB	4			; temps absolu de dpart (write) [128us]OCANAL:	.BLKB	2			; canaux midi  crireOTIME:	.BLKB	2			; temps  sauter au dbut [20ms]OVITESSE:.BLKB	2			; vitesseOMVIT:	.BLKB	2			; facteur correctifOMIDI:	.BLKB	16			; canaux midiOTRAN:	.BLKB	16			; transpositionsOAMPL:	.BLKB	16			; amplitudesODYNA:	.BLKB	16			; dynamiquesOCKVIT:	.BLKB	2			; clock: vitesseOCKCNT:	.BLKB	2			; clock: compteurOCKINC:	.BLKB	2			; clock: incrmentOCKADD:	.BLKB	2			; clock: total des incrmentsOCKLST:	.BLKB	2			; clock: dernire valeurOCKTIM:	.BLKB	2			; clock: mesure du tempsOCKAJU:	.BLKB	2			; clock: petite correctionOPSEMA:	.BLKB	4			; ^smaphoreOPSEMP:	.BLKB	4			; ^smaphoreOPSEMX:	.BLKB	4			; ^smaphoreOPFIFO:	.BLKB	4			; ^fifoOSVECT:	.BLKB	4			; sauve le vecteur d'interruption					; variables d'interruption :OINBB:	.BLKB	4			; nombre de byte  transfrerOIPTB:	.BLKB	4			; pointeur au buffer de lectureOJNBB:	.BLKB	4			; nombre de byte  transfrer initialOJPTB:	.BLKB	4			; pointeur au dbut du buffer initialOILCOM:	.BLKB	2			; compteur de byte dernire commandeOIERR:	.BLKB	1			; flag d'erreur d'interruption	.EVENOBUTMP:	.BLKB	4			; buffer temporaire pour une commandeOBUECHO:.BLKB	100			; buffer pour faire l'choOBUFIFO:.BLKB	4			; buffer pour le write du fifoOTAPSG:	.BLKB	NBPSG*LPSG		; table des oscillateurs internesONOTE:	.BLKB	4			; une note  envoyer directementOWLIST:	.BLKB	128			; liste des touches presses en critureORLIST:	.BLKB	128			; liste des touches presses en lectureOBURALL:.BLKB	LBURALL			; buffer de lecture spcialLGVAR:	.REV	REV,VERS	.CODE	0,4,0,0,0,0,0,0,0,0,0;	 lg stack,prio,units,window; Table rsume des drivers du fichier-driver; -------------------------------------------	.LOC	0DRIVERS:	.W	0,MBASE	.W	2^7; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;			DRIVER $MIDI_0		No H'80; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=MID:	.W	-1			; OPEN Adresse routines	.W	MCOMMAND-MBASE	.W	MRSTATUS-MBASE	.W	MREAD-MBASE	.W	MWRITE-MBASE	.W	-1			; CLOSE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	MAVORT-MBASE	.W	-1			; RAUX1	.W	-1			; RAUX2	.W	MRESET-MBASE	.W	MKILL-MBASE	.W	-1			; RSTRT	.W	-1			; RTSTRT	.W	-1			; RSTARTMNAB:	.ASCII	/MIDI_0/		; Nom driverMNAF:	.FILLB	LGDNAM-(MNAF-MNAB) 0	.B	H'80			; Numro driver	.B	TYPIO			; Type: Streamer	.B	REV,VERS		; Rvision - version	.B	4,0			; Priorit	.B	0			; Attribut 1	.B	2^BDRDOK!2^BDWROK	; Attribut 0	.FILLB	LGDDESC-(.-MID) 0	; Le reste.MBASE:;-------\\; MRESET >;=======/; Routine d'initialisation du driver.; in	-; out	D7.W	erreur; mod	D0..A1, D7.WMRESET:	PUSHM.L	D2,D4,D5,A3..A6	LOAD.L	A6,#R16"VAR		; A6 <-- ^variables	LOAD.W	(A6)+OCANAL,#-1		; crit tous les canaux midi	CLR.W	(A6)+OVITESSE		; met la vitesse moyenne	CALL	INIMVIT			; calcul OMVIT	LOAD.L	A4,#(A6)+OMIDI	CLR.B	D410$:	LOAD.B	(A4+),D4	INC.B	D4	COMP.B	D4,#16	JUMP,LO 10$	LOAD.L	A4,#(A6)+OAMPL	LOAD.W	D4,#16-120$:	LOAD.B	(A4+),#128/2	DECJ.W,NMO D4,20$	LOAD.L	A4,#(A6)+ODYNA	LOAD.W	D4,#16-125$:	LOAD.B	(A4+),#128/2	DECJ.W,NMO D4,25$	TSET.B	(A6)+OFLAGS:#BIOF	; interrupt disable	LOAD.B	SMIDI1,#MASTRST		; reset 6850 SOFT	LOAD.B	SMIDI1,#MIDIMOD		; mode de transfert MIDI	LOAD.L	(A6)+OSVECT,ADVINT	; sauve le vecteur d'int	LOAD.L	A0,#R16"ROUTINT	LOAD.L	ADVINT,A0		; initialise la routine d'int	LOAD.W	D4,#0			; smaphore de synchro	NTREL	?CRESEM	JUMP,NE	90$	LOAD.L	(A6)+OPSEMA,A5	LOAD.W	D4,#1			; smaphore d'exclusion	NTREL	?CRESEM	JUMP,NE	90$	LOAD.L	(A6)+OPSEMP,A5	LOAD.W	D4,#1			; smaphore d'exclusion	NTREL	?CRESEM	JUMP,NE	90$	LOAD.L	(A6)+OPSEMX,A5	LOAD.W	D0,#3			; D0 <-- lg d'un lment	LOAD.W	D2,#100			; D2 <-- lg max d'lments	LOAD.W	D1,#MTYPBD		; D1 <-- type driver BIOS	LOAD.L	A1,#R16"MBASE		; A1 <-- ^base du driver	CALLA	_INIFIFO		; initialise fifo	JUMP,NE 90$	LOAD.L	(A6)+OPFIFO,A0		; mm. ^fifo	TCLR.B	(A6)+OFLAGS:#BFFILS	; pas encore la fin du processus fils	LOAD.L	D4,#4			; D4 <-- priorit	TSET.L	D4:#BTPROG	TSET.L	D4:#BTNCHD	LOAD.L	D5,#400			; D5 <-- lg stack	LOAD.L	A5,#R16"PPSG		; A5 <-- ^start	LOAD.L	A3,#R16"NPSG		; A3 <-- ^nom	NTREL	?CRETASK		; dmarre le processus fils "psg"	JUMP',NE 90$	LOAD.L	D4,#4			; D4 <-- priorit	TSET.L	D4:#BTPROG	TSET.L	D4:#BTNCHD	LOAD.L	D5,#400			; D5 <-- lg stack	LOAD.L	A5,#R16"PWRITE		; A5 <-- ^start	LOAD.L	A3,#R16"NWRITE		; A3 <-- ^nom	NTREL	?CRETASK		; dmarre le processus fils "write"90$:	POPM.L	D2,D4,D5,A3..A6	RET;-------\\; MOPEN  >;=======/; Routine d'ouverture du driver.; in	-; out	D7.W	erreur; mod	D0..A1, D7.WMOPEN:	RET;----------\\; MCOMMAND  >;==========/; Routine de commande du driver.; Les commandes actuellement reconnues sont :;;	V[n.W]		vitesse (-MAXVIT..0..+MAXVIT);	T[n.W]		dure  sauter au dbut;	C[n.W]		canaux midi  entendre (en criture);	M[n.B][n.B]..	canaux midi  utiliser (0..15);	O[n.B][n.B]..	transposition (+/-0..n);	A[n.B][n.B]..	amplitude (-128..0..+128);	D[n.B][n.B]..	dynamique (-128..0..+128);	E(N/Y)		fait l'cho de toutes les notes lues;	S(N/Y)		enregistre les synchros (timing clock = H'F8);	P(N/Y)		enregistre les pressions (after touch = H'Dn);	K(N/Y)		envoie les synchros selon la vitesse;; Remarque:	.. indique 16 fois les paramtres entre [];		(N/Y) indique N ou Y; Pour synchroniser un enregistrement (read) sur une coute (write),; il suffit de dmarrer d'abord l'coute.; in	A4.L	^commandes termines par zro; out	D7.W	erreur; mod	D0..A1, D7.WMCOMMAND:	PUSHM.L	D4,A4..A6	LOAD.L	A6,#R16"VAR		; A6 <-- ^variablesLOOP$:	CLR.W	D7			; D7 <-- ok	LOAD.B	D4,(A4+)	JUMP,EQ EXIT$	COMP.B	D4,#'C	JUMP,EQ CHPLAY$	COMP.B	D4,#'T	JUMP,EQ TIME$	COMP.B	D4,#'V	JUMP,EQ SPEED$	COMP.B	D4,#'M	JUMP,EQ CHUSE$	COMP.B	D4,#'O	JUMP,EQ TRANS$	COMP.B	D4,#'A	JUMP,EQ AMPL$	COMP.B	D4,#'D	JUMP,EQ DYNA$	COMP.B	D4,#'E	JUMP,EQ ECHO$	COMP.B	D4,#'S	JUMP,EQ SYNCHRO$	COMP.B	D4,#'P	JUMP,EQ AFTER$	COMP.B	D4,#'K	JUMP,EQ CLOCK$	LOAD.W	D7,#ERILLO		; D7 <-- commande illgale	JUMP	EXIT$CHPLAY$:				; canal =>	LOAD.B	D4,(A4+)	SL.W	D4,#8	LOAD.B	D4,(A4+)	LOAD.W	(A6)+OCANAL,D4	JUMP	LOOP$TIME$:					; time =>	LOAD.B	D4,(A4+)	SL.W	D4,#8	LOAD.B	D4,(A4+)	LOAD.W	(A6)+OTIME,D4	JUMP	LOOP$SPEED$:					; vitesse =>	LOAD.B	D4,(A4+)	SL.W	D4,#8	LOAD.B	D4,(A4+)	LOAD.W	(A6)+OVITESSE,D4	CALL	INIMVIT			; calcul OMVIT	JUMP	LOOP$CHUSE$:					; canaux =>	LOAD.L	A5,#(A6)+OMIDI	LOAD.W	D4,#16-1CHUSE1$:	LOAD.B	(A5+),(A4+)	DECJ.W,NMO D4,CHUSE1$	JUMP	LOOP$TRANS$:					; transposition =>	LOAD.L	A5,#(A6)+OTRAN	LOAD.W	D4,#16-1TRANS1$:	LOAD.B	(A5+),(A4+)	DECJ.W,NMO D4,TRANS1$	JUMP	LOOP$AMPL$:					; amplitude =>	LOAD.L	A5,#(A6)+OAMPL	LOAD.W	D4,#16-1AMPL1$:	LOAD.B	(A5+),(A4+)	DECJ.W,NMO D4,AMPL1$	JUMP	LOOP$DYNA$:					; dynamique =>	LOAD.L	A5,#(A6)+ODYNA	LOAD.W	D4,#16-1DYNA1$:	LOAD.B	(A5+),(A4+)	DECJ.W,NMO D4,DYNA1$	JUMP	LOOP$ECHO$:					; cho =>	LOAD.B	D4,(A4+)		; D4 <-- (Y)es ou (N)o	TCLR.B	(A6)+OFECHO:#BECHOON	COMP.B	D4,#'Y	JUMP,NE LOOP$	TSET.B	(A6)+OFECHO:#BECHOON	JUMP	LOOP$SYNCHRO$:				; synchro =>	LOAD.B	D4,(A4+)		; D4 <-- (Y)es ou (N)o	TCLR.B	(A6)+OFECHO:#BSYNCHRO	COMP.B	D4,#'Y	JUMP,NE LOOP$	TSET.B	(A6)+OFECHO:#BSYNCHRO	JUMP	LOOP$AFTER$:					; after touch =>	LOAD.B	D4,(A4+)		; D4 <-- (Y)es ou (N)o	TCLR.B	(A6)+OFECHO:#BAFTER	COMP.B	D4,#'Y	JUMP,NE LOOP$	TSET.B	(A6)+OFECHO:#BAFTER	JUMP	LOOP$CLOCK$:					; timing clock =>	LOAD.B	D4,(A4+)		; D4 <-- (Y)es ou (N)o	TCLR.B	(A6)+OFECHO:#BCLOCK	COMP.B	D4,#'Y	JUMP,NE LOOP$	TSET.B	(A6)+OFECHO:#BCLOCK	JUMP	LOOP$EXIT$:	POPM.L	D4,A4..A6	RET;---------\; MRSTATUS >;=========/; Lecture du status.; in	A4.L	^buffer;	D4.L	longueur buffer; out	D4.L	longueur rendue effectivement;	D7.W	erreur; mod	D0..A1, D4.L, D7.WMRSTATUS:	PUSHM.L	D3,D4,A3,A4,A6	LOAD.L	A6,#R16"VAR		; A6 <-- ^variables	LOAD.L	A0,#R16"00$	CALLA	_CNVLGS	JUMP,NE 90$	LOAD.L	D3,D4	CALL	GETTIME			; D4 <-- temps actuel [128us]	TEST.B	(A6)+OFLAGS:#BWRITE	; criture dj en cours ?	JUMP',BC 20$			; non => 20$	SUB.L	D4,(A6)+OTMPW		; D4 <-- temps depuis le dpart	JUMP'	25$20$:	SUB.L	D4,(A6)+OTMPR		; D4 <-- temps depuis le dpart25$:	DIV.WU	D4,(A6)+OMVIT		; D4 <-- idem, mais en ms	ADD.W	D4,(A6)+OTIME		; D4 <-- tient compte offset dpart	LOAD.W	(A4+),D4		; buffer <-- temps	COMP.L	D3,#2+128	JUMP',NE 80$	LOAD.L	A3,#(A6)+ORLIST	LOAD.W	D4,#(128/4)-140$:	LOAD.L	(A4+),(A3+)		; buffer <-- liste des touches presses	DECJ.W,NMO D4,40$80$:	CLR.W	D7			; D7 <-- ok90$:	POPM.L	D3,D4,A3,A4,A6	RET00$:					; table pour CNVLGS :	.W	2	.W	2+128	.W	0;-------\\; MREAD  >;=======/; Routine de lecture MIDI.; in	A4.L	^buffer;	D5.L	nombre de bytes  lire (-1 si lit tout); out	D5.L	nombre de bytes lus;	D7.W	erreur; mod	D0..A1, D5.L, D7.WMREAD:	PUSHM.L	D4,A4..A6	LOAD.L	A6,#R16"VAR		; A6 <-- ^variables	LOAD.L	D4,D5	COMP.L	D4,#NBMIN		; buffer demand trop petit ?	JUMP',HS 10$			; non => 10$	CLR.L	D4			; oui => 90$	JUMP	90$10$:	TCLR.B	(A6)+OFLAGS:#BABORT	; pas d'abort	TCLR.B	(A6)+OFLAGS:#BIGNORE	CLR.B	(A6)+OIERR		; pas d'erreur	TSET.B	(A6)+OFLAGS:#BREAD	; tat lecture	COMP.L	D4,#-1	JUMP',NE 20$	LOAD.L	A4,#(A6)+OBURALL+4	; A4 <-- ^buffer spcial20$:	LOAD.L	(A6)+OJPTB,A4		; mj ^buffer	LOAD.L	(A6)+OIPTB,A4		; mj ^buffer	LOAD.L	(A6)+OJNBB,D4		; mj nb bytes  lire	LOAD.L	(A6)+OINBB,D4		; mj nb bytes  lire	PUSH.L	D4	CALL	GETTIME			; D4 <-- temps actuel [128us]	LOAD.L	(A6)+OTMPR,D4		; OTMPR <-- temps absolu de dpart	POP.L	D4	TEST.B	(A6)+OFLAGS:#BWRITE	; criture dj en cours ?	JUMP',BC 40$			; non => 40$	LOAD.L	(A6)+OTMPR,(A6)+OTMPW	; oui => synchronise "record" selon "play"40$:	CLR.W	(A6)+OCKTIM	CLR.W	(A6)+OILCOM		; longueur de commande = 0	TCLR.B	(A6)+OFLAGS:#BIOF	; interrupt enable	LOAD.B	SMIDI1,#MASTRST		; reset de l'usart	LOAD.B	SMIDI1,#MIDIMOD!ERCVINT	; active l'interrupt	LOAD.L	A5,(A6)+OPSEMA	NTREL	?WAITEV			; attend que la lecture soit faite...	LOAD.B	SMIDI1,#MIDIMOD		; dactive l'interrupt	TSET.B	(A6)+OFLAGS:#BIOF	; interrupt disable	CALL	METDERL			; met la longueur dernire commande	SUB.L	D4,(A6)+OINBB		; D4 <-- nombre de byte lu	CALL	ERR			; traite une ventuelle erreur	JUMP',NE 90$	TEST.B	(A6)+OFLAGS:#BABORT	; opration aborte ?	JUMP',BC 90$			; non => 90$	LOAD.W	D7,#ERTRAV		; oui => transfert abort90$:	TCLR.B	(A6)+OFLAGS:#BREAD	; plus dans l'tat lecture	CLR.W	(A6)+OTIME		; plus rien  sauter au dbut	LOAD.L	D5,D4	POPM.L	D4,A4..A6	RET;--------\\; MWRITE  >;========/; Routine d'ecriture sur le rseau MIDI.; in	A4.L	^byte  crire;	D5.L	nombre de bytes; out	D5.L	nombre de bytes crits;	D7.W	erreur; mod	D0..A1, D5.L, D7.WMWRITE:	PUSHM.L	D3,D4,A4,A6	LOAD.L	A6,#R16"VAR		; A6 <-- ^variables	LOAD.L	D4,D5	JUMP,EQ	90$			; pas de transfert => 90$	PUSH.L	D4	CALL	GETTIME			; D4 <-- temps actuel [128us]	LOAD.L	(A6)+OTMPW,D4		; OTMPW <-- temps absolu de dpart	POP.L	D4	CLR.W	(A6)+OCKTIM	TCLR.B	(A6)+OFLAGS:#BABORT	; pas d'abort	TCLR.B	(A6)+OFLAGS:#BIGNORE	TSET.B	(A6)+OFLAGS:#BWRITE	; tat criture	TCLR.B	(A6)+OFLAGS:#BNOMIDI	; synth midi pas absent	LOAD.L	A0,#(A6)+OTAPSG	CLR.B	D003$:	CLR.B	(A0)+OPSGF		; tous les oscillateurs internes  zro	LOAD.L	A0,#(A0)+LPSG	INC.B	D0	COMP.B	D0,#NBPSG	JUMP,LO 03$	TEST.W	(A6)+OTIME		; faut-il sauter au dbut ?	JUMP',EQ 05$			; non => 05$	TSET.B	(A6)+OFLAGS:#BSKIP	; oui => signal saut ncessaire05$:	LOAD.L	A0,A4	ADD.L	A0,D4			; A0 <-- ^fin du buffer10$:	LOAD.B	D0,(A4+)	SL.W	D0,#8	LOAD.B	D0,(A4+)		; D0 <-- word description	TEST.W	D0			; donnes ou dure ?	JUMP',EQ 20$			; dure => 20$					; donnes =>	TEST.B	(A6)+OFLAGS:#BSKIP	; faut-il sauter ?	JUMP',BS 15$			; oui => 15$	CALL	WRBLOC			; crit les donnes	JUMP,NE 45$	JUMP	30$15$:	ADD.W	A4,D0			; A4 <-- saute les donnes	JUMP'	30$20$:					; dure =>	CALL	WAIT			; attend ...	JUMP',NE 40$	ADD.L	A4,#2			; A4 <-- saute le temps30$:	TEST.B	(A6)+OFLAGS:#BABORT	; transfert abort ?	JUMP',BS 40$			; oui => 40$	COMP.L	A4,A0			; fin du transfert ?	JUMP,LO	10$			; non => 10$ (on continue)	CLR.W	D7			; D7 <-- ok	JUMP'	90$40$:	LOAD.W	D7,#ERTRAV		; D7 <-- erreur avort45$:	SUB.L	A0,A4			; A0 <-- nombre de byte pas transfr	SUB.L	D4,A0			; D4 <-- nombre de bytes transfr90$:	TCLR.B	(A6)+OFLAGS:#BWRITE	; plus dans l'tat criture	TEST.B	(A6)+OFLAGS:#BREAD	; lecture en cours ?	JUMP',BS 92$			; oui => 92$	CLR.W	(A6)+OTIME		; non => plus rien  sauter au dbut92$:	LOAD.L	D5,D4			; D5 <-- nb de bytes crits	POPM.L	D3,D4,A4,A6	RET;-------\\; MKILL  >;=======/; Routine de fermeture du driver.; in	-; out	D7.W	erreur; mod	D0..A1, D7.WMKILL:	PUSHM.L	D4,A5,A6	LOAD.L	A6,#R16"VAR		; A6 <-- ^variables	TSET.B	(A6)+OFLAGS:#BFFILS	; signal la fin au processus fils	LOAD.W	D4,#2	NTREL	?DELMS			; attend sa mort (!)	LOAD.L	A0,(A6)+OPFIFO		; A0 <-- ^fifo	LOAD.W	D1,#MTYPBD		; D1 <-- type driver BIOS	LOAD.L	A1,#R16"MBASE		; A1 <-- ^base du driver	CALLA	_KILLFIFO		; dtruit le fifo	LOAD.L	A5,(A6)+OPSEMA	NTREL	?KILLSEM		; dtruit le smaphore	LOAD.L	A5,(A6)+OPSEMP	NTREL	?KILLSEM		; dtruit le smaphore	LOAD.L	A5,(A6)+OPSEMX	NTREL	?KILLSEM		; dtruit le smaphore	LOAD.L	ADVINT,(A6)+OSVECT	; remet l'ancien pointeur90$:	POPM.L	D4,A5,A6	RET;-------\\; MAVORT >;=======/; Abort l'criture et la lecture.; in	-; out	D7.W	erreur; mod	D0..A1, D7.WMAVORT:	PUSHM.L	D2..D4,A3..A6	LOAD.L	A6,#R16"VAR		; A6 <-- ^variables	LOAD.L	A3,#(A6)+OWLIST		; A3 <-- ^liste des touches presses en criture	CLR.W	D3			; D3 <-- numro des touches (0..127)20$:	LOAD.B	D2,(A3)+(D3.W)		; D2 <-- nb de pressions	JUMP,EQ 50$30$:	CLR.B	(A3)+(D3.W)	LOAD.B	D1,#H'90		; D1 <-- commande + canal (0..15)40$:	LOAD.L	A4,#(A6)+ONOTE	LOAD.B	(A4)+0,D1		; <note-on/off>	LOAD.B	(A4)+1,D3		; <touche>	CLR.B	(A4)+2			; <vlocit> zro => touche relche	LOAD.W	D0,#3	CALL	WRBASE			; relche une touche	INC.B	D1			; D1 <-- canal suivant	COMP.B	D1,#H'90+16	JUMP,LO 40$	DEC.B	D2			; encore une pression  relcher ?	JUMP,NE 30$			; oui => 30$50$:	INC.W	D3			; D3 <-- touche suivante	COMP.W	D3,#128	JUMP,LO 20$	LOAD.L	A3,#(A6)+ORLIST		; A3 <-- ^liste des touches presses en lecture	LOAD.W	D3,#(128/4)-155$:	CLR.L	(A3+)	DECJ.W,NMO D3,55$	LOAD.L	A4,#R16"00$	LOAD.W	D0,#(15*3)+1	TCLR.L	D0:#16			; D0 <-- pas d'envoi si abort	CALL	WRHARD			; all notes off + stop	CLR.B	D0	CLR.B	D160$:	CALL	PSGAMP			; tous les oscillateurs internes  zro	INC.B	D0	COMP.B	D0,#NBPSG	JUMP,LO 60$	TSET.B	(A6)+OFLAGS:#BABORT	; met le flag d'avortement	TEST.B	(A6)+OFLAGS:#BREAD	; lecture ?	JUMP',BC 90$			; non => 90$					; oui =>	LOAD.L	A5,(A6)+OPSEMA		; A5 <-- ^smaphore	NTREL	?SIGNEV			; libre le WAITEV de MREAD90$:	POPM.L	D2..D4,A3..A6	RET00$:	.B	H'B0,123,0		; all notes off	.B	H'B1,123,0		; all notes off	.B	H'B2,123,0		; all notes off	.B	H'B3,123,0		; all notes off	.B	H'B4,123,0		; all notes off	.B	H'B5,123,0		; all notes off	.B	H'B6,123,0		; all notes off	.B	H'B7,123,0		; all notes off	.B	H'B8,123,0		; all notes off	.B	H'B9,123,0		; all notes off	.B	H'BA,123,0		; all notes off	.B	H'BB,123,0		; all notes off	.B	H'BC,123,0		; all notes off	.B	H'BD,123,0		; all notes off	.B	H'BE,123,0		; all notes off	.B	H'FC			; stop	.EVEN;--------\\; MCLOSE  >;========/; Routine dactivation du driver.; in	-; out	D7.W	erreur; mod	D0..A1, D7.WMCLOSE:	RET;-------\\; WRBLOC >;-------/; Ecrit une commande midi complte.; in	A4.L	^bytes  crire;	D0.W	nombre de bytes; out	A4.L	^plus loin;	D7.W	erreur; mod	D0.W, D7.W, A4.LWRBLOC:	PUSHM.L	D1,D2,A3	LOAD.B	D1,(A4)			; D1 <-- status de la commande	COMP.B	D1,#H'80	JUMP',LO 20$	COMP.B	D1,#H'F0	JUMP',HS 20$	AND.B	D1,#H'0F		; D1 <-- canal	LOAD.W	D2,(A6)+OCANAL	TEST.L	D2:D1			; faut-il crire ce canal ?	JUMP',BS 20$			; oui => 20$					; non =>	ADD.W	A4,D0			; A4 <-- saute la commande	CLR.W	D7			; D7 <-- ok	JUMP	90$20$:	LOAD.B	D2,D1			; D2 <-- canal	LOAD.L	A3,#(A6)+OWLIST		; A3 <-- ^liste des touches presses en criture	LOAD.B	D1,(A4)			; D1 <-- status de la commande	AND.B	D1,#H'F0		; D1 <-- masque le canal	COMP.B	D1,#H'80		; touche relche ?	JUMP',EQ 35$			; oui => 35$	COMP.B	D1,#H'90		; touche presse/relche ?	JUMP,NE 50$	TEST.B	(A4)+2			; si vlocit zro => relche	JUMP',EQ 35$					; touche presse =>	CLR.W	D1	LOAD.B	D1,(A4)+1	COMP.B	D2,#CHPSG		; canal "interne" ?	JUMP',EQ 50$			; oui => 50$	INC.B	(A3)+(D1.W)		; une pression de plus	JUMP'	50$35$:					; touche relche =>	CLR.W	D1	LOAD.B	D1,(A4)+1	COMP.B	D2,#CHPSG		; canal "interne" ?	JUMP',EQ 50$			; oui => 50$	TEST.B	(A3)+(D1.W)	JUMP',EQ 50$	DEC.B	(A3)+(D1.W)		; une pression de moins50$:	CALL	WRBASE			; crit la commande90$:	POPM.L	D1,D2,A3	TEST.W	D7			; retour EQ/NE	RET;-------\\; WRBASE >;-------/; Ecrit une commande midi, en tenant compte des commandes; de transposition, amplitude, etc.; in	A4.L	^bytes  crire;	D0.W	nombre de bytes; out	A4.L	^plus loin;	D7.W	erreur; mod	D0.W, D7.W, A4.LWRBASE:	PUSHM.L	D1..D4,A2,A3	COMP.W	D0,#3	JUMP,HI 80$	LOAD.B	D1,(A4)+0		; D1 <-- status commande	COMP.B	D1,#H'80	JUMP,LO 80$	COMP.B	D1,#H'F0	JUMP,HS 80$; Met toute la commande dans un buffer temporaire, pour permettre; de la modifier sans problme !	LOAD.L	A3,#(A6)+OBUTMP	LOAD.W	D1,D010$:	LOAD.B	(A3+),(A4+)		; OBUTMP <-- commande	DEC.W	D1	JUMP,NE 10$	LOAD.L	A3,A4	LOAD.L	A4,#(A6)+OBUTMP; Modifie le canal midi selon la commande M[..].	LOAD.B	D4,(A4)+0	LOAD.B	D3,D4	AND.B	D4,#H'F0		; D4 <-- seulement la commande	AND.W	D3,#H'0F		; D3 <-- seulement le canal midi	LOAD.L	A2,#(A6)+OMIDI	OR.B	D4,(A2)+(D3.W)		; D4 <-- nouveau canal	LOAD.B	(A4)+0,D4; Regarde s'il s'agit d'une touche presse/relche pour la transposer; selon la commande O[..].	AND.B	D4,#H'F0		; D4 <-- masque le canal	COMP.B	D4,#H'80	JUMP',EQ 30$	COMP.B	D4,#H'90	JUMP,NE 70$30$:	LOAD.B	D4,(A4)+1	LOAD.L	A2,#(A6)+OTRAN	ADD.B	D4,(A2)+(D3.W)		; D4 <-- transpose32$:	TEST.B	D4	JUMP',NC 34$	ADD.B	D4,#12	JUMP	32$34$:	COMP.B	D4,#128	JUMP',LO 36$	SUB.B	D4,#12	JUMP	34$36$:	LOAD.B	(A4)+1,D4; Tient compte de la dynamique et de l'amplitude pour une touche presse; selon les commandes D[..] et A[..].	LOAD.B	D4,(A4)+0	AND.B	D4,#H'F0		; D4 <-- masque le canal	COMP.B	D4,#H'90	JUMP,NE 70$	CLR.W	D4	LOAD.B	D4,(A4)+2		; D4 <-- vlocit actuelle	JUMP,EQ 70$	LOAD.L	A2,#(A6)+ODYNA	CLR.W	D2	LOAD.B	D2,(A2)+(D3.W)		; D2 <-- dynamique (+/- 0..128)	JUMP',EQ 44$	JUMP',NS 42$	LOAD.W	D1,D4	MUL.WU	D1,D2	DIV.WU	D1,#128	ADD.W	D4,D1	JUMP'	44$42$:	NEG.B	D2	LOAD.W	D1,D4	MUL.WU	D1,D2	DIV.WU	D1,#128	SUB.W	D4,D144$:	LOAD.L	A2,#(A6)+OAMPL	CLR.W	D2	LOAD.B	D2,(A2)+(D3.W)		; D2 <-- amplitude (+/- 0..128)	CONV.WA.BA D2	ADD.W	D4,D2	COMP.W	D4,#1	JUMP',GE 46$	LOAD.W	D4,#146$:	COMP.W	D4,#128	JUMP',LO 48$	LOAD.W	D4,#128-148$:	LOAD.B	(A4)+2,D4; Ecrit la commande construite dans le buffer temporaire.70$:	TCLR.L	D0:#16			; D0 <-- pas d'envoi si abort	CALL	WRHARD	LOAD.L	A4,A3			; A4 <-- ^plus loin, buffer utilisateur	JUMP'	90$80$:	TCLR.L	D0:#16			; D0 <-- pas d'envoi si abort	CALL	WRHARD90$:	POPM.L	D1..D4,A2,A3	TEST.W	D7			; retour EQ/NE	RET;-------\\; WAIT   >;-------/; Attend le temps dfinit par le word point par A4.; in	A4.L	^word du retard; out	D7.W	erreur; mod	D7.WWAIT:	PUSHM.L	D2..D4	LOAD.B	D4,(A4)+0	SL.L	D4,#8	LOAD.B	D4,(A4)+1		; D4 <-- temps jusqu'o attendre [20ms]	LOAD.W	D3,D4	MUL.WU	D3,(A6)+OMVIT		; D3 <-- temps en 128us10$:	LOAD.W	D7,#ERTRAV		; D7 <-- erreur avort	TEST.B	(A6)+OFLAGS:#BABORT	; transfert abort ?	JUMP,BS 90$			; oui => 90$	CALL	GETTIME			; D4 <-- temps actuel [128us]	SUB.L	D4,(A6)+OTMPW		; D4 <-- temps depuis le dpart	LOAD.W	D2,(A6)+OTIME		; D2 <-- offset dpart [20ms]	MUL.WU	D2,(A6)+OMVIT		; D2 <-- offset dpart [128us]	ADD.L	D4,D2			; D4 <-- tient compte offset dpart	CLR.W	D7			; D7 <-- ok	LOAD.L	D2,D3	SUB.L	D2,D4			; D2 <-- reste  attendre [128us]	JUMP,LE	90$			; on a du retard => 90$					; oui =>	TCLR.B	(A6)+OFLAGS:#BSKIP	; on a plus besoin de sauter	LOAD.L	D4,#1000000/UNITE	COMP.L	D2,D4			; attend plus d'une seconde ?	JUMP',LS 60$			; non => 60$					; oui =>	SUB.L	D4,#100	CALL	WAIT128US		; attend une petite seconde ...	JUMP	10$60$:	TCLR.B	(A6)+OFLAGS:#BSKIP	; on a plus besoin de sauter	LOAD.L	D4,D2	CALL	WAIT128US		; attend juste s'qui faut ...	CLR.W	D7			; D7 <-- ok90$:	POPM.L	D2..D4	TEST.W	D7			; retour EQ/NE	RET;----------\\; WAIT128US >;----------/; Attend avec une unit de 128us.; in	D4.W	attente [128us]; out	-; mod	D7.WWAIT128US:	PUSH.L	D4	MUL.WU	D4,#64	DIV.WU	D4,#50*64/UNITE		; D4 <-- dure [50us]	NTREL	?DELUS	POP.L	D4	RET;	********************;	*	WRITE      *;	********************NWRITE:	.ASCIZ	"MIDI_WRITE"		; nom du processus fils	.EVEN; Ce processus lit toutes les notes mises dans le fifo par la; routine d'interruption, pour les jouer avec WRHARD (protg; par le smaphore OPSEMX).; Ceci est utile uniquement lorsque la routine d'interruption; doit faire l'cho des notes reues (in --> out) !; Ce processus s'occupe galement d'envoyer les "timing clock",; lors de la commande "KY" (clocK Yes).PWRITE:	LOAD.L	A1,H'80	LOAD.L	A0,#R16"05$	LOAD.L	H'80,A0	TRAP	#0		; passe en mode "superviseur", voir (*)05$:	LOAD.L	H'80,A1; (*)	Cela est ncessaire  cause du CALL GETTIME !10$:	TEST.B	(A6)+OFLAGS:#BFFILS	JUMP,BS 90$	LOAD.L	A0,(A6)+OPFIFO		; A0 <-- ^fifo	CALLA	_RDFIFO			; lit le fifo	JUMP',NE 20$	SL.L	D0,#8	LOAD.L	A4,#(A6)+OBUFIFO	LOAD.L	(A4),D0	LOAD.W	D0,#3	TCLR.L	D0:#16			; D0 <-- pas d'envoi si abort	CALL	WRHARD			; joue la note pesse/relche	JUMP	10$20$:	LOAD.W	D4,#1	TEST.W	(A6)+OCKVIT	JUMP',NC 21$	INC.W	D421$:	NTREL	?DELMS			; attend un p'tit peu ...	TEST.B	(A6)+OFECHO:#BCLOCK	; envoie les timing clock ?	JUMP,BC 10$			; non => 10$; Cette partie trs subtile s'occupe de compenser les ventuels; dcalages entre la mesure du temps avec GETTIME (le temps du; systme) et le nombre de clock effectivement envoys.; La variable OCKAJU contient le nombre de clock  ajouter ou ; enlever durant la prochaine demi-seconde.	TEST.B	(A6)+OFLAGS:#BABORT	; transfert abort ?	JUMP,BS 39$			; oui => 39$	CLR.L	D4	LOAD.W	D4,(A6)+OCKTIM	DIV.WU	D4,#50/2	SWAP.W	D4	TEST.W	D4			; s'est-il dj coul une demi-seconde ?	JUMP,NE 39$			; non => 39$	CALL	GETTIME			; D4 <-- temps actuel [128us]	TEST.B	(A6)+OFLAGS:#BWRITE	; criture dj en cours ?	JUMP',BC 30$			; non => 30$	SUB.L	D4,(A6)+OTMPW		; D4 <-- temps depuis le dpart	JUMP'	35$30$:	SUB.L	D4,(A6)+OTMPR		; D4 <-- temps depuis le dpart35$:	DIV.WU	D4,(A6)+OMVIT		; D4 <-- idem, mais en 15.625ms	ADD.W	D4,(A6)+OTIME		; D4 <-- tient compte offset dpart	AND.L	D4,#H'FFFF	MUL.WU	D4,#50	DIV.WU	D4,#64			; D4 <-- temps systme [20ms]	SUB.W	D4,(A6)+OCKTIM	NEG.W	D4			; D4 <-- dcalage (+/-) dcouvert	CLR.W	(A6)+OCKAJU	COMP.W	D4,#+10	JUMP',HS 38$	LOAD.W	(A6)+OCKAJU,D438$:	COMP.W	D4,#-10	JUMP',LO 39$	LOAD.W	(A6)+OCKAJU,D439$:; Calcule le nombre de coups de clock  envoyer.	LOAD.W	D3,(A6)+OVITESSE	COMP.W	D3,(A6)+OCKVIT		; vitesse change ?	JUMP',EQ 60$			; non => 60$					; oui =>	LOAD.W	(A6)+OCKVIT,D3	JUMP',NC 56$	ADD.W	D3,#MAXVIT56$:	LOAD.W	D4,D3	MUL.WU	D4,#MAXVIT/2	SR.W	D3,#1	SUB.W	D3,#MAXVIT	NEG.W	D3	DIV.WU	D4,D3	LOAD.W	(A6)+OCKINC,D4		; OCKINC <-- V*(MAXVIT/2) / (MAXVIT-(V/2))	LOAD.W	(A6)+OCKCNT,#160$:	DEC.W	(A6)+OCKCNT	JUMP',NE 62$	CLR.W	(A6)+OCKADD	LOAD.W	(A6)+OCKLST,#-1	LOAD.W	(A6)+OCKCNT,#MAXVIT62$:	LOAD.W	D0,#1			; D0 <-- un clock de toute faon	CLR.L	D4	LOAD.W	D4,(A6)+OCKADD	DIV.WU	D4,#MAXVIT	COMP.W	D4,(A6)+OCKLST	JUMP',EQ 64$	LOAD.W	(A6)+OCKLST,D4	INC.W	D0			; D0 <-- un clock de plus64$:	LOAD.W	D4,(A6)+OCKINC	ADD.W	(A6)+OCKADD,D4; Tient compte de la correction dans OCKAJU calcule plus haut,; toute les demi-secondes.	TEST.W	(A6)+OCKAJU		; encore une petite correction  faire ?	JUMP',EQ 68$			; non => 68$	JUMP',NS 67$	DEC.W	(A6)+OCKAJU	DEC.W	D0			; D0 <-- petite correction (-)	JUMP'	68$67$:	INC.W	(A6)+OCKAJU	INC.W	D0			; D0 <-- petite correction (+)68$:	TEST.W	D0	JUMP,EQ 10$	ADD.W	(A6)+OCKTIM,D0		; OCKTIM <-- temps de l'horloge	LOAD.L	A4,#R16"00$	TSET.L	D0:#16			; D0 <-- envoi mme si abort	CALL	WRHARD			; crit qq "timing clock"	JUMP	10$90$:	NTREL	?ABORT00$:	.B	H'F8			; timing clock	.B	H'F8			; timing clock	.B	H'F8			; timing clock	.B	H'F8			; timing clock	.EVEN;-------\\; WRHARD >;-------/; Ecrit un bloc de x bytes par pooling sur midi.; in	A4.L	^bytes  crire;	D0.W	nombre de bytes;		 2^16=1 --> envoi mme si abort !; out	A4.L	^plus loin;	D7.W	erreur; mod	D0.W, D7.W, A4.LWRHARD:	PUSHM.L	D1,D2,A5	LOAD.L	A5,(A6)+OPSEMX	NTREL	?LOCK	JUMP,NE 95$	LOAD.B	D1,(A4)	JUMP',NC 50$			; si pas un status => 50$	AND.B	D1,#H'0F		; D1 <-- canal midi	COMP.B	D1,#CHPSG		; canal "interne" ?	JUMP',NE 50$			; non => 50$					; oui =>	CALL	WRPSG			; crit sur le synth interne	JUMP	90$50$:	LOAD.W	D7,#ERUNCO		; D7 <-- unit pas connecte	TEST.B	(A6)+OFLAGS:#BNOMIDI	; synth midi absent ?	JUMP,BS 90$			; oui => 90$	DEC.W	D0			; D0 <-- -1  cause du test NMO60$:	LOAD.L	D2,#50			; D2 <-- timeout (20=ko et 30=ok)65$:	TEST.L	D0:#16			; envoi mme si abort ?	JUMP',BS 70$			; oui => 70$	TEST.B	(A6)+OFLAGS:#BABORT	; abort ?	JUMP',BC 70$			; non => 70$	LOAD.W	D7,#ERTRAV		; D7 <-- transfert avort	JUMP	90$70$:	LOAD.B	D1,SMIDI1	TEST.L	D1:#BUSRDY		; registre vide ?	JUMP',BS 80$			; oui => 80$	DEC.L	D2	JUMP,NE 65$	TSET.B	(A6)+OFLAGS:#BNOMIDI	; synth midi absent	LOAD.W	D7,#ERUNCO		; D7 <-- unit pas connecte	JUMP'	90$80$:	LOAD.B	MIDI1,(A4+)		; crit un byte	DECJ.W,NMO D0,60$	CLR.W	D7			; D7 <-- ok90$:	PUSH.W	D7;	LOAD.L	A5,(A6)+OPSEMX	NTREL	?UNLOCK	POP.W	D795$:	POPM.L	D1,D2,A5	TEST.W	D7			; retour EQ/NE	RET;------\\; ERR   >;------/; Traitement des erreurs de lecture.; in	-; out	D7.W	erreur; mod	D7.WERR:	PUSH.W	D0	LOAD.B	D0,(A6)+OIERR		; D0 <-- erreur ventuelle	CLR.W	D7			; D7 <-- ok	TEST.L	D0:#BUSPERR		; erreur de parit?	JUMP',BC 10$			; non => 10$	LOAD.W	D7,#ERHREAD10$:	TEST.L	D0:#BUSFERR		; framing erreur?	JUMP',BC 20$			; non => 20$	LOAD.W	D7,#ERHREAD20$:	TEST.L	D0:#BUSOERR		; overrun erreur?	JUMP',BC 90$			; non => 90$	LOAD.W	D7,#ERHREAD90$:	POP.W	D0	TEST.W	D7	RET;--------\\; METDERL >;--------/; Met le nombre de byte dans la dernire commande.; in	-; out	-; mod	-METDERL:	PUSHM.L	D0,D1,A4	LOAD.W	D0,(A6)+OILCOM		; D0 <-- nb byte dernire commande	JUMP',EQ 90$			; zro => 90$	LOAD.W	D1,D0			; D1 <-- sauve D0	NEG.W	D1	LOAD.L	A4,(A6)+OIPTB	LOAD.B	(A4)+(D1)-1,D0		; D0 <-- LSB du compteur	SR.W	D0,#8	LOAD.B	(A4)+(D1)-2,D0		; D0 <-- MSB du compteur90$:	POPM.L	D0,D1,A4	RET;--------\\; ROUTINT >;--------/; Routine d'interruption lit MIDI et signal lorsque le nombre; de byte dsir est atteint.; in	-; out	-; mod	-ROUTINT:;;?	OR.W	SF,#H'700		; IOF (?)	PUSHM.L	D0..D4,D7,A0,A1,A6	LOAD.L	A6,#R16"VAR		;  A6 <-- ^variables	TEST.B	(A6)+OFLAGS:#BIOF	; interrupt disable ?	JUMP,BS 99$			; oui => 99$	TEST.B	(A6)+OFLAGS:#BABORT	; lecture aborte ?	JUMP',BS 06$			; oui => 06$	LOAD.B	D0,SMIDI1		; D0 <-- lit le status	TEST.L	D0:#BUSIREQ		; interrupt request ?	JUMP',BC 07$			; non => 07$	LOAD.B	D1,D0	AND.B	D1,#2^BUSFERR!2^BUSOERR!2^BUSPERR	JUMP',EQ 10$	LOAD.B	(A6)+OIERR,D0	LOAD.B	D0,MIDI1		; D0 <-- lit le byte	JUMP	80$			; signal avec erreur => 80$06$:	LOAD.B	D0,SMIDI1		; D0 <-- lit le status07$:	LOAD.B	D0,MIDI1		; D0 <-- lit le byte	JUMP	90$10$:	LOAD.B	D0,MIDI1		; D0 <-- lit le byte	TEST.L	D0:#7			; status byte ?	JUMP,BC	40$			; non => 40$					; oui =>	TCLR.B	(A6)+OFLAGS:#BIGNORE	TCLR.B	(A6)+OFECHO:#BECHO	COMP.B	D0,#H'F8		; byte insignifiant (timing clock) ?	JUMP',NE 15$	TEST.B	(A6)+OFECHO:#BSYNCHRO	; enregistre les synchros ?	JUMP,BC 90$			; non => 90$15$:	COMP.B	D0,#H'FE		; byte insignifiant (active sensing) ?	JUMP,EQ	90$			; oui => 90$	LOAD.B	D1,D0	AND.B	D1,#H'F0		; D1 <-- masque le canal	TEST.B	(A6)+OFECHO:#BAFTER	; enregistre les after touch ?	JUMP',BS 17$			; oui => 17$	COMP.B	D1,#H'D0		; pression (after touch) ?	JUMP,EQ 30$			; oui => 30$17$:	COMP.B	D0,#H'F7		; terminateur de message (EOX) ?	JUMP,EQ	40$			; oui => 40$					; non =>	COMP.B	D1,#H'80	JUMP',EQ 20$	COMP.B	D1,#H'90		; note presse/relche ?	JUMP',NE 25$			; non => 25$20$:					; oui =>	TEST.B	(A6)+OFECHO:#BECHOON	JUMP',BC 25$	TSET.B	(A6)+OFECHO:#BECHO	CLR.W	(A6)+OCECHO25$:	CALL	METSTAMP		; met l'espace temps	JUMP,NE	80$			; pas assez de place => 80$	JUMP'	40$30$:	TSET.B	(A6)+OFLAGS:#BIGNORE	JUMP	90$40$:	TEST.B	(A6)+OFLAGS:#BIGNORE	JUMP,BS 90$	TEST.B	(A6)+OFECHO:#BECHO	; fait l'cho ?	JUMP',BC 50$			; non => 50$	PUSHM.L	D0,A4			; oui =>	LOAD.L	A4,#(A6)+OBUECHO	LOAD.W	D1,(A6)+OCECHO	LOAD.B	(A4)+(D1.W),D0		; OBUECHO <-- la commande	INC.W	D1	LOAD.W	(A6)+OCECHO,D1	COMP.W	D1,#3	JUMP',NE 47$	LOAD.L	D0,(A4)	SR.L	D0,#8	LOAD.L	A0,(A6)+OPFIFO		; A0 <-- ^fifo	CALLA	_WRFIFO			; fifo <-- note presse/relche (*)47$:	POPM.L	D0,A450$:	COMP.W	(A6)+OILCOM,#3	JUMP',NE 60$	LOAD.L	A0,(A6)+OIPTB		; A0 <-- ^buffer de data	LOAD.B	D1,(A0)-3	LOAD.B	D2,D1	AND.B	D1,#H'F0	COMP.B	D1,#H'90		; commande H'9n ?	JUMP',NE 60$					; liste avec plus d'une note =>	PUSH.W	D2	CALL	METSTAMP		; met l'espace temps	POPM.W	D2	JUMP,NE	80$			; pas assez de place => 80$	LOAD.L	A0,(A6)+OIPTB		; A0 <-- ^buffer de data	LOAD.B	(A0+),D2		; buffer <-- remet H'9n	LOAD.L	(A6)+OIPTB,A0		; mj ^buffer de data	INC.W	(A6)+OILCOM		; longueur dernire commande reue		DEC.L	(A6)+OINBB		; nombre de byte	JUMP,EQ 80$60$:	LOAD.L	A0,(A6)+OIPTB		; A0 <-- ^buffer de data	LOAD.B	(A0+),D0		; buffer <-- le byte	LOAD.L	(A6)+OIPTB,A0		; mj ^buffer de data	INC.W	(A6)+OILCOM		; longueur dernire commande reue	DEC.L	(A6)+OINBB		; nombre de byte	JUMP,EQ 80$			; si dernier => 80$	COMP.W	(A6)+OILCOM,#3	JUMP',NE 90$	LOAD.B	D1,(A0)-3+0	AND.B	D1,#H'F0		; D1 <-- masque le canal	COMP.B	D1,#H'80		; touche relche ?	JUMP',EQ 70$			; oui => 70$	COMP.B	D1,#H'90		; touche presse/relche ?	JUMP',NE 90$	TEST.B	(A0)-3+2		; si vlocit zro => relche	JUMP',EQ 70$					; touche presse =>	CLR.W	D1	LOAD.B	D1,(A0)-3+1	LOAD.L	A1,#(A6)+ORLIST	INC.B	(A1)+(D1.W)		; une pression de plus	JUMP'	90$70$:					; touche relche =>	CLR.W	D1	LOAD.B	D1,(A0)-3+1	LOAD.L	A1,#(A6)+ORLIST	TEST.B	(A1)+(D1.W)	JUMP',EQ 90$	DEC.B	(A1)+(D1.W)		; une pression de moins	JUMP'	90$80$:					; signal la fin =>	LOAD.L	A1,(A6)+OPSEMA		; A1 <-- ^smaphore	CLR.W	D0			; D0 <-- 0=usart et 1=floppy	LOAD.W	D1,#1			; D1 <-- valeur maximale de "e"	LOAD.L	A0,_INDSHI		; A0 <-- ^routines du SHI	CALL	(A0)+_SPINT		; appel de SPINT (comme ISIGNAL), voir (**);;?	CALLA	_ISIGNAL		; envoie un signal;;?	JUMP',NE 99$90$:	POPM.L	D0..D4,D7,A0,A1,A6	RETSF99$:	.W	H'A042	.ASCIZ	"SIGMA: Erreur d'interruption avec le NTREL !<CR>"	.EVEN	TRAP	#1; (*)	Le routine d'interruption ne peut pas crire directement dans;	l'usart (avec WRHARD), car il y a conflict avec l'criture;	normale, et les trois bytes des notes se mlangent !; (**)	Ceci semble supprimer les "stack error" qui sont toujours;	rests mystrieux ...;---------\\; METSTAMP >;---------/; Met l'espace temps et rserve la place pour la longueur.; in	-; out	NE	plus assez de place; mod	D1.L, D2.L, D3.L, D4.L, D7.W, A0.L, A1.LMETSTAMP:	COMP.L	(A6)+OINBB,#LSTAMP	; assez de place dans le buffer ?	JUMP,LO	90$			; non => 90$					; oui =>	SUB.L	(A6)+OINBB,#LSTAMP	; met  jour le compteur data	LOAD.L	A0,(A6)+OIPTB		; A0 <-- ^buffer	LOAD.W	D2,(A6)+OILCOM		; D2 <-- longueur dernire commande	JUMP',EQ 50$			; zro => 50$ (ne fait rien)	LOAD.W	D1,D2			; D1 <-- sauve D2	NEG.W	D2	LOAD.B	(A0)+(D2)-1,D1		; LSB du compteur	SR.W	D1,#8	LOAD.B	(A0)+(D2)-2,D1		; MSB du compteur	CLR.W	(A6)+OILCOM		; compteur longueur data = 050$:	PUSHM.L	D0,D5,A0	CALLA	_IARGSYTIME		; D4 <-- 32 bits de poids faible	POPM.L	D0,D5,A0	SUB.L	D4,(A6)+OTMPR		; D4 <-- remps relatif depuis le dpart	DIV.WU	D4,(A6)+OMVIT		; D4 <-- temps relatif 20ms	ADD.W	D4,(A6)+OTIME		; D4 <-- ajoute temps  sauter	CLR.B	(A0+)			; crit la dure depuis le status byte	CLR.B	(A0+)	LOAD.B	(A0)+1,D4		; MSB espace temps en ms	SR.W	D4,#8	LOAD.B	(A0)+0,D4		; LSB espace temps en ms	ADD.L	A0,#2	CLR.B	(A0+)			; prpare la place pour la longueur des datas	CLR.B	(A0+)	COMP.L	(A6)+OJNBB,#-1		; lit tout ?	JUMP',NE 80$			; non => 80$	LOAD.L	(A6)+OINBB,#-1	LOAD.L	A0,#(A6)+OBURALL+480$:	LOAD.L	(A6)+OIPTB,A0		; remet  jour le pointeur de lecture	SETZ				; retour EQ90$:	RET;--------\\; INIMVIT >;========/; Initialise le facteur de correction en fonction de la vitesse.; in	-; out	-; mod	D7.WINIMVIT:	PUSH.L	D4	LOAD.W	D4,(A6)+OVITESSE	NEG.W	D4	JUMP',NS 50$	MUL.WA	D4,#MVITESSE	DIV.WA	D4,#MAXVIT	ADD.W	D4,#MVITESSE	JUMP'	80$50$:	MUL.WA	D4,#MVITESSE	DIV.WA	D4,#MAXVIT*2	ADD.W	D4,#MVITESSE80$:	LOAD.W	(A6)+OMVIT,D4	POP.L	D4	RET;--------\\; GETTIME >;========/; Donne le temps absolu en unit de 128us.; in	-; out	D4.L	temps [128us]; mod	D4.L, D7.WGETTIME:	PUSHM.L	D0..D3,D5,A0,A1	CALLA	_IARGSYTIME		; D4 <-- 32 bits de poids faible	POPM.L	D0..D3,D5,A0,A1	RET;	******************;	*	PSG      *;	******************NPSG:	.ASCIZ	"MIDI_PSG"		; nom du processus fils	.EVENPPSG:10$:	TEST.B	(A6)+OFLAGS:#BFFILS	JUMP,BS 90$	LOAD.W	D4,#1	NTREL	?DELMS			; attend un p'tit peu ...	LOAD.L	A5,(A6)+OPSEMP	NTREL	?LOCK	LOAD.L	A0,#(A6)+OTAPSG	CLR.B	D020$:	TEST.B	(A0)+OPSGF:#BPSGUSE	JUMP',BC 40$	INC.W	(A0)+OPSGT	TEST.B	(A0)+OPSGF:#BPSGATT	JUMP',BS 40$	INC.W	(A0)+OPSGR	LOAD.W	D1,(A0)+OPSGR	COMP.W	D1,#16	JUMP',HS 30$	SUB.W	D1,#16	NEG.W	D1	CALL	PSGAMP			; diminue progressivement	JUMP'	40$30$:	CLR.B	D1	CALL	PSGAMP			; silence total	TCLR.B	(A0)+OPSGF:#BPSGUSE	; libre l'oscillateur40$:	LOAD.L	A0,#(A0)+LPSG	INC.B	D0	COMP.B	D0,#NBPSG	JUMP,LO 20$	LOAD.L	A5,(A6)+OPSEMP	NTREL	?UNLOCK	JUMP	10$90$:	NTREL	?ABORT;-------\\; WRPSG  >;-------/; Ecrit un bloc de x bytes dans le circuit synthtiseur.; in	A4.L	^bytes  crire;	D0.W	nombre de bytes; out	A4.L	^plus loin;	D7.W	erreur; mod	D0.W, D7.W, A4.LWRPSG:	PUSHM.L	D0,D1,D4,A0,A1,A5	LOAD.B	D4,(A4)+0		; D4 <-- commande midi	AND.B	D4,#H'F0		; D4 <-- masque le canal	COMP.B	D4,#H'80	JUMP,EQ 50$	COMP.B	D4,#H'90	JUMP,NE 90$	TEST.B	(A4)+2	JUMP,EQ 50$					; presse une touche =>	LOAD.L	A5,(A6)+OPSEMP	NTREL	?LOCK; Cherche un gnrateur libre.	LOAD.L	A0,#(A6)+OTAPSG	CLR.B	D020$:	TSET.B	(A0)+OPSGF:#BPSGUSE	JUMP,BC 30$	LOAD.L	A0,#(A0)+LPSG	INC.B	D0	COMP.B	D0,#NBPSG	JUMP,LO 20$; Cherche un gnrateur en "release" (note relche).	LOAD.L	A0,#(A6)+OTAPSG	CLR.B	D022$:	TEST.B	(A0)+OPSGF:#BPSGATT	JUMP,BC 30$	LOAD.L	A0,#(A0)+LPSG	INC.B	D0	COMP.B	D0,#NBPSG	JUMP,LO 22$; Cherche le gnrateur utilis depuis le plus de temps.	LOAD.L	A0,#(A6)+OTAPSG	CLR.B	D0	CLR.W	D424$:	COMP.W	D4,(A0)+OPSGT	JUMP',HS 25$	LOAD.W	D4,(A0)+OPSGT	LOAD.B	D1,D0	LOAD.L	A1,A025$:	LOAD.L	A0,#(A0)+LPSG	INC.B	D0	COMP.B	D0,#NBPSG	JUMP,LO 24$	LOAD.B	D0,D1	LOAD.L	A0,A1	TEST.W	D4	JUMP,EQ 80$		; en dsespoir de cause, oublie la note !30$:	TSET.B	(A0)+OPSGF:#BPSGUSE	TSET.B	(A0)+OPSGF:#BPSGATT	CLR.W	(A0)+OPSGT	CLR.W	(A0)+OPSGR	LOAD.B	PSGADR,#SGRMIX	LOAD.B	PSGDATA,#B'00111000	LOAD.B	D1,(A4)+1	LOAD.B	(A0)+OPSGN,D1	CALL	PSGNOT	CALL	PSGPER	LOAD.B	D1,#15	CALL	PSGAMP	JUMP	80$50$:					; relche une touche =>	LOAD.B	D1,(A4)+1	LOAD.L	A5,(A6)+OPSEMP	NTREL	?LOCK	LOAD.L	A0,#(A6)+OTAPSG	CLR.B	D052$:	TEST.B	(A0)+OPSGF:#BPSGUSE	JUMP',BC 53$	TEST.B	(A0)+OPSGF:#BPSGATT	JUMP',BC 53$	COMP.B	D1,(A0)+OPSGN	JUMP',EQ 60$53$:	LOAD.L	A0,#(A0)+LPSG	INC.B	D0	COMP.B	D0,#NBPSG	JUMP,LO 52$	JUMP'	80$60$:	TCLR.B	(A0)+OPSGF:#BPSGATT	; signal la fin de l'attaque80$:	LOAD.L	A5,(A6)+OPSEMP	NTREL	?UNLOCK90$:	POPM.L	D0,D1,D4,A0,A1,A5	ADD.W	A4,D0			; A4 <-- ^plus loin	CLR.W	D7			; D7 <-- toujours ok	RET;--------\\; PSGAMP  >;--------/; Donne une amplitude  un gnrateur.; in	D0.B	numro du gnrateur (0..2);	D1.B	amplitude (1+4 bits); out	-; mod	-PSGAMP:	PUSH.W	D0	ADD.B	D0,#SGRA0		; D0 <-- registre amplitude	LOAD.B	PSGADR,D0	LOAD.B	PSGDATA,D1		; crit l'amplitude	POP.W	D0	RET;--------\\; PSGNOT  >;--------/; Calcul la priode correspondant  une note donne.; in	D1.B	note (0..143); out	D1.W	priode correspondante (12 bits); mod	D1.WPSGNOT:	COMP.B	D1,#12	JUMP',LO 20$	SUB.B	D1,#12			; D1 <-- descend tout d'une octave20$:	COMP.B	D1,#12	JUMP',LO 30$	SUB.B	D1,#12			; D1 <-- descend tout d'une octave30$:	AND.L	D1,#H'FF	SL.W	D1,#1	LOAD.W	D1,(PC)+(D1)+50$	RET; Table des priodes pour les notes de la gamme tempre :50$:	.W	3822.	3608.	3405.	3214.	3034.	2864.	.W	2703.	2551.	2408.	2273.	2145.	2025.	.W	1911.	1804.	1703.	1607.	1517.	1432.	.W	1351.	1276.	1204.	1136.	1073.	1012.	.W	956.	902.	851.	804.	758.	716.	.W	676.	638.	602.	568.	536.	506.	.W	478.	451.	426.	402.	379.	358.	.W	338.	319.	301.	284.	268.	253.	.W	239.	225.	213.	201.	190.	179.	.W	169.	159.	150.	142.	134.	127.	.W	119.	113.	106.	100.	95.	89.	.W	84.	80.	75.	71.	67.	63.	.W	60.	56.	53.	50.	47.	45.	.W	42.	40.	38.	36.	34.	32.	.W	30.	28.	27.	25.	24.	22.	.W	21.	20.	19.	18.	17.	16.	.W	15.	14.	13.	13.	12.	11.	.W	11.	10.	9.	9.	8.	8.	.W	7.	7.	7.	6.	6.	6.	.W	5.	5.	5.	4.	4.	4.	.W	4.	4.	3.	3.	3.	3.	.W	3.	2.	2.	2.	2.	2.	.W	2.	2.	2.	2.	1.	1.	.W	1.	1.	1.	1.	1.	1.	.W	1.	1.	1.	1.	1.	1.	.W	1.	1.	1.	1.	1.	1.;--------\\; PSGPER  >;--------/; Donne une priode  un gnrateur.; in	D0.B	numro du gnrateur (0..2);	D1.W	priode (12 bits); out	-; mod	-PSGPER:	PUSH.W	D0	PUSH.W	D1;	ADD.B	D0,#SGRT0	SL.B	D0,#1			; D0 <-- registre priode low	LOAD.B	PSGADR,D0	LOAD.B	PSGDATA,D1		; crit 8 bits de poids faibles	INC.B	D0			; D0 <-- registre priode high	SR.W	D1,#8	LOAD.B	PSGADR,D0	LOAD.B	PSGDATA,D1		; crit 4 bits de poids forts	POP.W	D1	POP.W	D0	RET; Variables; ---------VAR:	.FILLB	LGVAR,0			; variables du programme	.END