	.SBTTL	SEQFILTRE;-----------\\; DBOXFILTRE >;===========/; Demande quel filtre effectuer.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXFILTRE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	D4,(A6)+OFIFA	; D4 <-- fanions	LOAD.L	A2,#R16"TDBOX_FILTRE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.W	D2,#13	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D2,#2	CALL	GETDBFIL	; A3 <-- ^nom	LIB	?AFTEXT	LOAD.W	D2,#3	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D2,#1	CALL	GETDBFIL	; A3 <-- ^nom	LIB	?AFTEXT	LOAD.L	D4,(A6)+OFIFA	; D4 <-- fanions	CLR.W	D2		; D2 <-- rang initial10$:	CALL	GETDBFIL	; A3/A4 <-- ^dbut/fin nom20$:	LOAD.W	D3,D2		; D2 <-- rang	DBOX_	MEDIT	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_FILTRE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; FILTRE ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$	COMP.W	D3,#CR	JUMP,EQ 40$	LOAD.W	D1,D3	CLR.B	D1	COMP.W	D1,#KEYDBOX	JUMP,EQ 50$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; RETURN =>	CALL	PUTDBFIL	JUMP,NE 30$	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,#3	JUMP,LO 10$	CLR.W	D2	JUMP	10$50$:				; KEYDBOX =>	CALL	PUTDBFIL	JUMP,NE 30$	AND.W	D3,#H'FF	LOAD.W	D2,D3		; D2 <-- nouveau rang	JUMP	10$80$:				; FILTRE =>	CALL	PUTDBFIL	JUMP,NE 30$	LOAD.L	(A6)+OFIFA,D485$:				; ANNULE =>	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; GETDBFIL >;---------/; Donne le texte  diter.; in	D2.W	rang; out	A3.L	^dbut nom;	A4.L	^fin nom; mod	D7.W, A3.L, A4.LGETDBFIL:	PUSH.L	D3	LOAD.L	A3,#(A6)+OBUNAME	LOAD.L	A4,A3	COMP.W	D2,#2	JUMP,EQ 40$	LOAD.W	D3,(A6)+OFIDN	COMP.W	D2,#1	JUMP,EQ 20$	LOAD.W	D3,(A6)+OFIPN20$:	CALL	CONVNT		; buffer <-- nom de la note	JUMP	70$40$:				; numro de piste =>	LOAD.W	D3,(A6)+OFIPI	ADD.B	D3,#'0+1	LOAD.B	(A3),D3		; buffer <-- 1..8	CLR.B	(A3)+170$:	TEST.B	(A4+)	JUMP,NE 70$	DEC.L	A4		; A4 <-- ^fin du nom	LOAD.L	A3,#(A6)+OBUNAME	POP.L	D3	RET;---------\\; PUTDBFIL >;---------/; Met  jour le texte  diter.; in	D2.W	rang;	A3.L	^nom; out	D7.W	erreur; mod	D7.WPUTDBFIL:	PUSHM.L	D3,A3	COMP.W	D2,#2	JUMP,EQ 40$	CALL	CONVTN		; D3 <-- numro de la note	JUMP,NE 90$	COMP.W	D2,#1	JUMP,EQ 20$	LOAD.W	(A6)+OFIPN,D3	JUMP	90$20$:	LOAD.W	(A6)+OFIDN,D3	JUMP	90$40$:				; numro de piste =>	LOAD.W	D7,#ERSYNT	CLR.W	D3	LOAD.B	D3,(A3+)	COMP.B	D3,#'1	JUMP,LO 90$	COMP.B	D3,#'8	JUMP,HI 90$	TEST.B	(A3)	JUMP,EQ 50$	COMP.B	(A3),#CR	JUMP,NE 90$50$:	SUB.B	D3,#'1		; D3 <-- 0..7	LOAD.W	(A6)+OFIPI,D3	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; CONVTN  >;--------/; Converti un texte en un numro de note.; in	A3.L	^nom de note; out	D3.W	numro de la note;	D7.W	erreur; mod	D3.L, D7.WCONVTN:	PUSHM.L	D4,A2..A4	LOAD.W	D7,#ERSYNT	; D7 <-- erreur de syntaxe	LOAD.L	A4,#R16"00$10$:	TEST.B	(A4)		; fin de la table ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A2,A315$:	TEST.B	(A4)		; fin du nom ?	JUMP,EQ 30$		; oui => 30$	LOAD.B	D3,(A2+)	LIB	?MINMAJ	COMP.B	D3,(A4+)	JUMP,EQ 15$20$:	TEST.B	(A4+)		; A4 <-- ^nom suivant	JUMP,NE 20$	INC.L	A4	JUMP	10$30$:	CLR.W	D3	LOAD.B	D3,(A4)+1	; D3 <-- rang de la note	LOAD.B	D4,#+1	COMP.B	(A2),#'#	JUMP,EQ 40$	COMP.B	(A2),#'D	JUMP,EQ 40$	COMP.B	(A2),#'d	JUMP,EQ 40$	COMP.B	(A2),#'+	JUMP,EQ 40$	LOAD.B	D4,#-1	COMP.B	(A2),#'B	JUMP,EQ 40$	COMP.B	(A2),#'b	JUMP,EQ 40$	COMP.B	(A2),#'-	JUMP,NE 50$40$:	ADD.B	D3,D4		; D3 <-- +/- 1	INC.L	A250$:	CLR.W	D4	LOAD.B	D4,(A2+)	COMP.B	D4,#'0	JUMP,LO 90$	COMP.B	D4,#'9	JUMP,HI 90$	SUB.B	D4,#'0	MUL.WU	D4,#12	ADD.W	D3,D4		; D3 <-- ajoute octave	TEST.B	(A2)	JUMP,EQ 80$	COMP.B	(A2),#CR	JUMP,NE 90$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.ASCIZ	"DO"	.B	0	.ASCIZ	"RE"	.B	2	.ASCIZ	"MI"	.B	4	.ASCIZ	"FA"	.B	5	.ASCIZ	"SOL"	.B	7	.ASCIZ	"LA"	.B	9	.ASCIZ	"SI"	.B	11	.B	0	.EVEN;--------\\; CONVNT  >;--------/; Converti un numro de note en un texte.; in	D3.B	numro de note (0..127);	A3.L	^buffer; out	A3.L	^nom de la note; mod	D7.WCONVNT:	PUSHM.L	D3,A3,A4	AND.L	D3,#H'7F	DIV.WU	D3,#12		; D3 <-- note/octave	SWAP.W	D3		; D3 <-- octave/note	LOAD.L	A4,#R16"00$20$:	DEC.W	D3	JUMP,NS 30$25$:	TEST.B	(A4+)		; A4 <-- ^nom de la note suivante	JUMP,NE 25$	JUMP	20$30$:	LOAD.B	(A3+),(A4+)	; buffer <-- nom de la note	JUMP,NE 30$	DEC.L	A3	SWAP.W	D3		; D3 <-- octave	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- rang de l'octave	CLR.B	(A3)	POPM.L	D3,A3,A4	RET00$:	.ASCIZ	"do"	.ASCIZ	"do#"	.ASCIZ	"r"	.ASCIZ	"r#"	.ASCIZ	"mi"	.ASCIZ	"fa"	.ASCIZ	"fa#"	.ASCIZ	"sol"	.ASCIZ	"sol#"	.ASCIZ	"la"	.ASCIZ	"la#"	.ASCIZ	"si"	.EVEN;--------\\; FILTRE  >;========/; Filtre en fonction du choix de la dbox.; in	-; out	-; mod	D7.WFILTRE:	CALL	WAITMOUSE	; souris: met le sablier	CALL	TAKEFILTRE	; record buffer <-- notes  filtrer	CALL	EXECFILTRE	; record buffer <-- transforme	CALL	FUSION		; master buffer <-- record buffer	CALL	COMPACT		; master buffer <-- compactifie un peu	CALL	DBOXTRACK	; affiche le contenu des pistes	CALL	DBOXFULL	; affiche la jauge	RET;-----------\\; TAKEFILTRE >;-----------/; Met dans le record buffer toutes les notes  filtrer.; in	-; out	-; mod	D7.WTAKEFILTRE:	PUSHM.L	D0..D5,A2..A4	CALL	GETRTRACK	; D5 <-- no piste d'enregistrement	LOAD.L	A2,(A6)+OPMBUF	; A2 <-- ^dbut master buffer	LOAD.L	A3,A2		; A3 <-- ^dbut master buffer	LOAD.L	D3,(A6)+OLMBUF	; D3 <-- lg master buffer	LOAD.L	A4,A2	ADD.L	A4,D3		; A4 <-- ^dbut record buffer	CLR.L	D4		; D4 <-- lg record buffer	CLR.W	D2		; D2 <-- temps courant10$:	TEST.L	D3		; reste qq chose ?	JUMP,EQ 40$		; non => 40$				; oui =>	CLR.L	D1	LOAD.B	D1,(A3)+0	SL.W	D1,#8	LOAD.B	D1,(A3)+1	; D1 <-- lg	TEST.W	D1	JUMP,NE 20$				; temps =>	LOAD.B	D2,(A3)+2	SL.W	D2,#8	LOAD.B	D2,(A3)+3	; D2 <-- temps	LOAD.W	D1,#2	JUMP	30$20$:				; objet =>	LOAD.B	D0,(A3)+2	AND.B	D0,#H'F0;;?	COMP.B	D0,#H'80;;?	JUMP,EQ 21$	COMP.B	D0,#H'90	; note presse/relche ?	JUMP,NE 30$		; non => 30$21$:	LOAD.B	D0,(A3)+2	AND.B	D0,#H'0F	COMP.B	D0,D5		; est-ce la bonne piste ?	JUMP,NE 30$		; non => 30$	LOAD.B	D0,(A3)+3	COMP.B	D0,(A6)+OFIPN+1	; avant la premire note ?	JUMP,LO 30$	COMP.B	D0,(A6)+OFIDN+1	; aprs la dernire note ?	JUMP,HI 30$	CLR.B	(A4+)	CLR.B	(A4+)	RR.W	D2,#8	LOAD.B	(A4+),D2	; record buffer <-- temps	RR.W	D2,#8	LOAD.B	(A4+),D2	ADD.L	D4,#4	ADD.W	D1,#2	SUB.L	D3,D1	ADD.L	D4,D125$:	LOAD.B	(A4+),(A3+)	; record buffer <-- objet	DEC.L	D1	JUMP,NE 25$	JUMP	10$30$:	ADD.W	D1,#2	SUB.L	D3,D132$:	LOAD.B	(A2+),(A3+)	; master buffer <-- temps/objet	DEC.L	D1	JUMP,NE 32$	JUMP	10$40$:	SUB.L	A2,(A6)+OPMBUF	LOAD.L	(A6)+OLMBUF,A2	LOAD.L	(A6)+OLRBUF,D4	JUMP,EQ 90$	COMP.L	A2,A3	JUMP,EQ 90$	LOAD.L	A2,(A6)+OPMBUF	ADD.L	A2,(A6)+OLMBUF50$:	LOAD.B	(A2+),(A3+)	; record buffer <-- juste aprs master buffer	DEC.L	D4	JUMP,NE 50$90$:	POPM.L	D0..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; EXECFILTRE >;-----------/; Transforme toutes les notes du "record buffer" selon le filtre.; in	-; out	-; mod	D7.WEXECFILTRE:	PUSHM.L	D0..D5,A2..A4	LOAD.L	A3,(A6)+OPMBUF	ADD.L	A3,(A6)+OLMBUF	; A3 <-- ^record buffer	LOAD.L	A2,A3		; A2 <-- ^record buffer	LOAD.L	D3,(A6)+OLRBUF	; D3 <-- lg record buffer	LOAD.L	D2,(A6)+OFIFA	; D2 <-- fanions	LOAD.W	D4,#128	TEST.L	D2:#BFAF1	JUMP,BS 08$	LOAD.W	D4,#64	TEST.L	D2:#BFAF2	JUMP,BS 08$	LOAD.W	D4,#32	TEST.L	D2:#BFAF4	JUMP,BS 08$	LOAD.W	D4,#16	TEST.L	D2:#BFAF8	JUMP,BS 08$	LOAD.W	D4,#8	TEST.L	D2:#BFAF16	JUMP,BS 08$	LOAD.W	D4,#408$:	LOAD.W	D5,D4	SR.W	D5,#110$:	TEST.L	D3		; reste qq chose ?	JUMP,EQ 80$		; non => 80$				; oui =>	TEST.B	(A3)+4+2	; note relche  supprimer ?	JUMP,EQ 38$		; oui => 38$	TEST.L	D2:#BFAFPI	; transforme la piste ?	JUMP,BC 20$		; non => 20$				; oui =>	LOAD.B	D1,(A3)+4+2	AND.B	D1,#H'F0	OR.B	D1,(A6)+OFIPI+1	LOAD.B	(A3)+4+2,D120$:	TEST.L	D2:#BFAFDN	; transforme la dure ?	JUMP,BS 22$		; oui => 22$	TEST.L	D2:#BFAFFN	JUMP,BC 50$		; non => 50$22$:	TEST.B	(A3)+4+4	; note relche ?	JUMP,EQ 50$		; oui => 50$	CALL	CHNRFILTRE	; A4 <-- ^note relche correspondante	CLR.L	D0	LOAD.B	D0,(A3)+2	SL.W	D0,#8	LOAD.B	D0,(A3)+3	; D0 <-- temps note presse	CLR.L	D1	LOAD.B	D1,(A4)+2	SL.W	D1,#8	LOAD.B	D1,(A4)+3	; D1 <-- temps note relche	TEST.L	D2:#BFAFDN	JUMP,BC 30$	COMP.W	D0,#OFNOTE	JUMP,LO 30$	SUB.W	D0,#OFNOTE	ADD.W	D0,D5	DIV.WU	D0,D4		; arrondi temps note presse	MUL.WU	D0,D4	ADD.W	D0,#OFNOTE30$:	TEST.L	D2:#BFAFFN	JUMP,BC 35$	COMP.W	D1,#OFNOTE	JUMP,LO 35$	SUB.W	D1,#OFNOTE	ADD.W	D1,D5	DIV.WU	D1,D4		; arrondi temps note relche	MUL.WU	D1,D4	ADD.W	D1,#OFNOTE35$:	COMP.W	D0,D1		; note devenue nulle ou ngative ?	JUMP,LO 40$		; non => 40$				; oui =>	CLR.B	(A4)+4+2	; faudra supprimer la note relche38$:	LOAD.L	A3,#(A3)+4+5	SUB.L	D3,#4+5	JUMP	10$40$:	RR.W	D0,#8	LOAD.B	(A3)+2,D0	RR.W	D0,#8	LOAD.B	(A3)+3,D0	; mj temps note presse	RR.W	D1,#8	LOAD.B	(A4)+2,D1	RR.W	D1,#8	LOAD.B	(A4)+3,D1	; mj temps note relche50$:	SUB.L	D3,#4+5	LOAD.W	D1,#4+5-152$:	LOAD.B	(A2+),(A3+)	; record buffer <-- temps-note	DECJ.W,NMO D1,52$	JUMP	10$80$:	SUB.L	A2,(A6)+OPMBUF	SUB.L	A2,(A6)+OLMBUF	LOAD.L	(A6)+OLRBUF,A2	; mj nouvelle longueur du record buffer	POPM.L	D0..D5,A2..A4	RET;-----------\\; CHNRFILTRE >;-----------/; Cherche la note relche correspondant  une note presse.; in	A3.L	^temps-note presse; out	A4.L	^temps-note relche; mod	A4.LCHNRFILTRE:	PUSH.W	D3	LOAD.B	D3,(A3)+4+3	; D3 <-- note cherche	LOAD.L	A4,A310$:	LOAD.L	A4,#(A4)+4+5	; A4 <-- ^temps-note suivant	TEST.B	(A4)+4+4	; note relche ?	JUMP,NE 10$		; non => 10$	COMP.B	D3,(A4)+4+3	; note trouve ?	JUMP,NE 10$		; non => 10$	POP.W	D3	RET	.END