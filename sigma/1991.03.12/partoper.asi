	.SBTTL	PARTOPERDOCOPY:	CALL	DBOXCOPY	; demande que et comment copier ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE MAIN	CALL	COPYMESURE	; dtruit, dplace ou duplique	PUSH.W	D7	CALL	REFAIT		; dessine la mesure	POP.W	D7	JUMP,NE IOERROR	JUMP	MAINDOTRANS:	CALL	DBOXTRANS	; demande comment transposer ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE MAIN	CALL	GETDBOXTRANS	; D2..D5 <-- paramtres	JUMP'	TRANSPOSEDOTONAL:	CALL	DBOXTONAL	; demande comment transposer ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE MAIN	CALL	GETDBOXTONAL	; D2..D5 <-- paramtres;	JUMP	TRANSPOSETRANSPOSE:	CALL	WAITMOUSE	; souris: met le sablier	PUSH.W	(A6)+OMESC	; stack <-- mesure courante	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LOAD.W	D6,(A4)+OMETA	; D6 <-- type de l'altration10$:	CALL	PMESURE		; recule dans la mesure prcdente	JUMP',NE 20$	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	COMP.W	D6,(A4)+OMETA	; mme type d'altration ?	JUMP,EQ 10$		; oui => 10$	CALL	NMESURE20$:	CALL	TRANSMESURE	; transpose la mesure	CALL	NMESURE		; avance dans la mesure suivante	JUMP',NE 30$	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	COMP.W	D6,(A4)+OMETA	; mme type d'altration ?	JUMP,EQ 20$		; oui => 20$30$:	POP.W	D4	CALL	GOMESURE	; revient dans la mesure initiale	CALL	REFAIT		; redessine la mesure courante	JUMP	MAIN;-----------\\; COPYMESURE >;===========/; Dtruit, dplace ou duplique quelques mesures.; in	(A6)+OFACOP.L	fanions (BFAC...);	(A6)+OCPMDE.W	mesure de ..;	(A6)+OCPMA.W	 ..;	(A6)+OCPMOU.W	avant la mesure ..; out	D7.W		erreur; mod	D7.WCOPYMESURE:	PUSHM.L	D2..D4,A4	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	D3,(A6)+OFACOP	; D3 <-- fanions; Duplique toutes les mesures de ..  ..	TEST.L	D3:#BFACDET	; dtruit ?	JUMP,BS 50$		; oui => 50$	TEST.L	D3:#BFACDEB	JUMP',BS 20$	TEST.L	D3:#BFACFIN	JUMP',BS 25$				; avant la mesure .. =>	LOAD.W	D4,(A6)+OCPMOU	SUB.W	D4,#2	JUMP',LO 20$	CALL	GOMESURE	; va AVANT la mesure destination	JUMP'	30$20$:				; au dbut =>	CALL	RECULE	JUMP,EQ 20$	LOAD.L	A4,(A6)+OPDB	ADD.L	A4,#2	LOAD.L	(A6)+OPMES,A4	CLR.W	(A6)+OMESC	JUMP'	30$25$:				;  la fin =>	CALL	NMESURE	JUMP,EQ 25$;	JUMP'	30$30$:	LOAD.W	D4,(A6)+OCPMDE	; D4 <-- mesures de ..	DEC.W	D4	CALL	GOVISU		; A4 <-- ^premire mesure source	JUMP,NE 80$	LOAD.W	D2,(A6)+OCPMA	SUB.W	D2,(A6)+OCPMDE	INC.W	D2		; D2 <-- nb de mesures  dupliquer40$:	LOAD.W	D4,(A4)-2	CALL	INSERT		; insre un objet	JUMP,NE 80$	CALL	NVISU		; A4 <-- ^objet suivant	JUMP,NE 80$	COMP.B	(A4)+OOBJC,#OBJMES ; dbut mesure suivante ?	JUMP,NE 40$	INC.W	(A6)+OMESC	; mj le numro de mesure courante	DEC.W	D2		; encore une mesure ?	JUMP,NE 40$		; oui => 40$; Dtruit toutes les mesures de ..  ..50$:	TEST.L	D3:#BFACDUP	; duplique ?	JUMP,BS 80$		; oui => 80$	LOAD.W	D2,(A6)+OCPMA	SUB.W	D2,(A6)+OCPMDE	INC.W	D2		; D2 <-- nb de mesures  supprimer	LOAD.W	D4,(A6)+OCPMA	TEST.L	D3:#BFACDET	; dtruit ?	JUMP',BS 55$		; oui => 55$	COMP.W	D4,(A6)+OCPMOU	JUMP',LO 55$	ADD.W	D4,D2		; D4 <-- ajoute le nb de mesures dupliques55$:	DEC.W	D4	CALL	GOMESURE60$:	CALL	DRECULE		; dtruit un objet en arrire	JUMP',NE 70$	COMP.B	(A4)+OOBJC,#OBJMES ; dbut mesure  dtruire ?	JUMP,NE 60$	DEC.W	(A6)+OMESM	; une mesure de moins	DEC.W	(A6)+OMESC	; mj le numro de mesure courante	DEC.W	D2		; encore une mesure ?	JUMP,NE 60$		; oui => 60$	JUMP'	80$70$:	CALL	NMESURE; Rinitialise le pointeur  la mesure courante OPMES.80$:	PUSH.W	D7	CALL	INIPMES		; init OPMES	POP.W	D7	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; TRANSMESURE >;============/; Transpose la mesure courante.; in	D2.B	nouvelle altration #/b (ICODIESE/ICOBEMOL);	D3.B	nouvelle altration nb (0..7);	D4.W	nb de demi-tons (+/- 0..n);	D5.W	dplacement vertical (+/- 0..n); out	-; mod	D7.WTRANSMESURE:	PUSHM.L	D1..D4,A4	LOAD.W	D1,D3		; D1 <-- nb de #/b (0..7)	CALL	MESTRIE		; trie toutes les notes de la mesure; Met  jour, dans toutes les notes, la hauteur actuelle en demi-tons.	LOAD.L	A4,(A6)+OPMES10$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 20$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP',EQ 20$	CALL	DEMITON		; D3 <-- rang de la note	JUMP,NE 10$	LOAD.B	(A4)+OSYNOT,D3	; mj. la hauteur en demi-tons	JUMP	10$; Modifie l'altration  la clef pour mettre la nouvelle demande.20$:	LOAD.L	A4,(A6)+OPMES	LOAD.B	(A4)+OMETA,D2	; mj. #/b	LOAD.B	(A4)+OMENA,D1	; mj. 0..7	CALL	TRANSFRONTMES	; dplace les frontires; Modifie toutes les notes pour les transposer.40$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP,NE 90$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP,EQ 90$	COMP.B	(A4)+OOBJC,#ICOHCOURBE	JUMP,EQ 60$	COMP.B	(A4)+OOBJC,#ICOBCOURBE	JUMP,EQ 60$	COMP.B	(A4)+OOBJC,#ICOHSOUPIR ; est-ce une note ou un silence ?	JUMP,HI 40$		; non => 40$				; oui =>	ADD.W	(A4)+OSYPOS+0,D5 ; dplace note/silence verticalement	COMP.B	(A4)+OOBJC,#ICOPAUSE ; est-ce une note ?	JUMP,HS 40$		; non => 40$				; oui =>	CLR.B	(A4)+OSYALT	CALL	DEMITON	SUB.W	D3,D4	COMP.B	D3,(A4)+OSYNOT	JUMP,EQ 40$	LOAD.B	(A4)+OSYALT,#ICODIESE	CALL	DEMITON	SUB.W	D3,D4	COMP.B	D3,(A4)+OSYNOT	JUMP,EQ 40$	LOAD.B	(A4)+OSYALT,#ICOBEMOL	CALL	DEMITON	SUB.W	D3,D4	COMP.B	D3,(A4)+OSYNOT	JUMP,EQ 40$	LOAD.B	(A4)+OSYALT,#ICOBECARRE	CALL	DEMITON	SUB.W	D3,D4	COMP.B	D3,(A4)+OSYNOT	JUMP,EQ 40$	LOAD.B	(A4)+OSYALT,#ICODDIESE	CALL	DEMITON	SUB.W	D3,D4	COMP.B	D3,(A4)+OSYNOT	JUMP,EQ 40$	LOAD.B	(A4)+OSYALT,#ICODBEMOL	CALL	DEMITON	SUB.W	D3,D4	COMP.B	D3,(A4)+OSYNOT	JUMP,EQ 40$	CLR.B	(A4)+OSYALT	; impossible !!!	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; petit bruit !!!	JUMP	40$60$:				; liaison =>	ADD.W	(A4)+OGRPN1+0,D5 ; dplace la liaison verticalement	ADD.W	(A4)+OGRPN2+0,D5 ; dplace la liaison verticalement	JUMP	40$90$:	POPM.L	D1..D4,A4	RET;--------------\\; TRANSFRONTMES >;--------------/; Dplace la frontire entre les mesures.; in	D5.W	dplacement vertical (+/- 0..n); out	-; mod	D7.WTRANSFRONTMES:	PUSHM.L	D0..D4,A2..A4	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LOAD.L	A3,#(A4)+OMELP	; A3 <-- ^premire mesure	LOAD.W	D3,#MAXLP	; D3 <-- nb de mesures10$:	COMP.B	(A3)+OLPTYP,#ICOVIDE ; porte existe ?	JUMP,EQ 50$		; non => 50$	LOAD.W	D0,(A3)+OLPDY	ADD.W	D0,#LYPORTEE*(NPORTEE-1)+LYPORTEE ; D0 <-- min	LOAD.W	D1,#LYPORTEE*33	; D1 <-- max	LOAD.L	A2,A3	LOAD.W	D2,D330$:	LOAD.L	A2,#(A2)+LLP	; A2 <-- ^porte suivante	DEC.W	D2	JUMP',EQ 35$	COMP.B	(A2)+OLPTYP,#ICOVIDE	JUMP,EQ 30$	LOAD.W	D1,(A2)+OLPDY	SUB.W	D1,#LYPORTEE/2	; D1 <-- max35$:	LOAD.W	D4,(A3)+OLPMAX	ADD.W	D4,D5		; D4 <-- monte/descend la frontire	COMP.W	D4,D0	JUMP',HS 40$	LOAD.W	D4,D040$:	COMP.W	D4,D1	JUMP',LS 41$	LOAD.W	D4,D141$:	LOAD.W	(A3)+OLPMAX,D4	TEST.W	D2		; porte en desous existe ?	JUMP',EQ 50$		; non => 50$	LOAD.W	D4,(A2)+OLPMIN	ADD.W	D4,D5		; D4 <-- monte/descend la frontire	COMP.W	D4,D0	JUMP',HS 44$	LOAD.W	D4,D044$:	COMP.W	D4,D1	JUMP',LS 45$	LOAD.W	D4,D145$:	LOAD.W	(A2)+OLPMIN,D450$:	LOAD.L	A3,#(A3)+LLP	; A3 <-- ^porte suivante	DEC.W	D3	JUMP,NE 10$	POPM.L	D0..D4,A2..A4	RET;-------------\\; GETDBOXTRANS >;=============/; Donne les paramtres ncessaires pour une transposition.; in	(A6)+OFATRA.L	fanions;	(A6)+OFATNB.W	nb 0..7; out	D2.B		nouvelle altration #/b (ICODIESE/ICOBEMOL);	D3.B		nouvelle altration nb (0..7);	D4.W		nb de demi-tons (+/- 0..n);	D5.W		dplacement vertical (+/- 0..n); mod	D2.L, D3.L, D4.L, D5.L, D7.WGETDBOXTRANS:	PUSH.L	D1	LOAD.L	D1,(A6)+OFATRA	; D1 <-- fanions des transpositions	LOAD.B	D2,#ICODIESE	; D2 <-- #	TEST.L	D1:#BFATDIESE	JUMP',BS 10$	LOAD.B	D2,#ICOBEMOL	; D2 <-- b10$:	LOAD.W	D3,(A6)+OFATNB	; D3 <-- 0..7	CLR.W	D5	CLR.W	D4	TEST.L	D1:#BFAT0	JUMP',BS 20$	DEC.W	D5	LOAD.W	D4,#2	TEST.L	D1:#BFAT1	JUMP',BS 20$	DEC.W	D5	LOAD.W	D4,#4	TEST.L	D1:#BFAT2	JUMP',BS 20$	DEC.W	D5	LOAD.W	D4,#5	TEST.L	D1:#BFAT3	JUMP',BS 20$	DEC.W	D5	LOAD.W	D4,#7	TEST.L	D1:#BFAT4	JUMP',BS 20$	DEC.W	D5	LOAD.W	D4,#9	TEST.L	D1:#BFAT5	JUMP',BS 20$	DEC.W	D5	LOAD.W	D4,#11	TEST.L	D1:#BFAT6	JUMP',BS 20$	DEC.W	D5	LOAD.W	D4,#1220$:	TEST.L	D1:#BFATP12	JUMP',BC 40$	INC.W	D4		; D4 <-- +1 demi-ton40$:	TEST.L	D1:#BFATM12	JUMP',BC 42$	DEC.W	D4		; D4 <-- -1 demi-ton42$:	TEST.L	D1:#BFATP1	JUMP',BC 44$	ADD.W	D4,#2		; D4 <-- +1 ton44$:	TEST.L	D1:#BFATM1	JUMP',BC 46$	SUB.W	D4,#2		; D4 <-- -1 ton46$:	TEST.L	D1:#BFATDOWN	JUMP',BC 60$	NEG.W	D5		; D5 <-- positif si on descend	NEG.W	D4		; D4 <-- ngatif si on descend60$:	MUL.WA	D5,#LYPORTEE/2	; D5 <-- en points graphiques	POP.L	D1	RET;-------------\\; GETDBOXTONAL >;=============/; Donne les paramtres ncessaires pour une transposition.; in	(A6)+OTOTA.B	#/b;	(A6)+OTONA.B	0..7;	(A6)+OFATON.L	fanions; out	D2.B		nouvelle altration #/b (ICODIESE/ICOBEMOL);	D3.B		nouvelle altration nb (0..7);	D4.W		nb de demi-tons (+/- 0..n);	D5.W		dplacement vertical (+/- 0..n); mod	D2.L, D3.L, D4.L, D5.L, D7.WGETDBOXTONAL:	PUSHM.L	D1,A3,A4	LOAD.B	D2,(A6)+OTOTA	; D2 <-- #/b	LOAD.B	D3,(A6)+OTONA	; D3 <-- 0..7	CALL	GETTONAL	; D2/D3 <-- rang/altration (destination)	LOAD.W	D4,D2	LOAD.W	D5,D3		; D4/D5 <-- rang/altration (destination)	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LOAD.B	D2,(A4)+OMETA	; D2 <-- #/b	LOAD.B	D3,(A4)+OMENA	; D3 <-- 0..7	CALL	GETTONAL	; D2/D3 <-- rang/altration (source)	LOAD.W	D1,D2	SUB.W	D1,D4		; D1 <-- dplacement en demi-interlignes	LOAD.L	A3,#R16"00$	LOAD.B	D2,(A3)+(D2.W)	ADD.B	D2,D3	LOAD.B	D4,(A3)+(D4.W)	ADD.B	D4,D5	SUB.W	D4,D2		; D4 <-- nb de demi-tons	LOAD.B	D2,(A6)+OTOTA	; D2 <-- #/b	LOAD.B	D3,(A6)+OTONA	; D3 <-- 0..7	LOAD.W	D5,D1		; D5 <-- dplacement en demi-interlignes	LOAD.L	D1,(A6)+OFATON	; D1 <-- fanions	TEST.L	D1:#BFATOP1	JUMP',BC 70$	ADD.W	D4,#12		; D4 <-- +12 demi-tons	SUB.W	D5,#7		; D5 <-- monte de 7 demi-interlignes70$:	TEST.L	D1:#BFATOM1	JUMP',BC 75$	SUB.W	D4,#12		; D4 <-- -12 demi-tons	ADD.W	D5,#7		; D5 <-- descend de 7 demi-interlignes75$:	MUL.WA	D5,#LYPORTEE/2	; D5 <-- dplacement en points	POPM.L	D1,A3,A4	RET00$:	.B	0,2,4,5,7,9,11,12	.EVEN;---------\\; GETTONAL >;---------/; Donne les caractristiques d'une tonalit majeure quelconque.; in	D2.B	#/b (ICODIESE/ICOBEMOL);	D3.B	nb (0..7); out	D2.W	rang de la tonalit (0..7);	D3.W	altration (-1,0,+1);	A3.L	^nom de la tonalit; mod	D2.L, D3.L, D7.W, A3.LGETTONAL:	LOAD.L	A3,#R16"TATONAL-(2+2+6)10$:	LOAD.L	A3,#(A3)+(2+2+6) ; A3 <-- ^tonalit suivante	TEST.W	(A3)		; fin de la table ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D2,(A3)+0	JUMP,NE 10$	COMP.B	D3,(A3)+1	JUMP,NE 10$50$:	CLR.W	D2	LOAD.B	D2,(A3)+2	; D2 <-- rang (0..12)	CLR.W	D3	LOAD.B	D3,(A3)+3	; D3 <-- altration (-1,0,+1)	LOAD.L	A3,#(A3)+(2+2)	; A3 <-- ^nom de la tonalit	RETTATONAL:	.B	ICODIESE,0	.B	0,0	.ASCIZ	"Do   "	.B	ICOBEMOL,0	.B	0,0	.ASCIZ	"Do   "	.B	ICODIESE,7	.B	0,+1	.ASCIZ	"Do # "	.B	ICOBEMOL,5	.B	1,-1	.ASCIZ	"R b "	.B	ICODIESE,2	.B	1,0	.ASCIZ	"R   "	.B	ICOBEMOL,3	.B	2,-1	.ASCIZ	"Mi b "	.B	ICODIESE,4	.B	2,0	.ASCIZ	"Mi   "	.B	ICOBEMOL,1	.B	3,0	.ASCIZ	"Fa   "	.B	ICODIESE,6	.B	3,+1	.ASCIZ	"Fa # "	.B	ICOBEMOL,6	.B	4,-1	.ASCIZ	"Sol b"	.B	ICODIESE,1	.B	4,0	.ASCIZ	"Sol  "	.B	ICOBEMOL,4	.B	5,-1	.ASCIZ	"La b "	.B	ICODIESE,3	.B	5,0	.ASCIZ	"La   "	.B	ICOBEMOL,2	.B	6,-1	.ASCIZ	"Si b "	.B	ICODIESE,5	.B	6,0	.ASCIZ	"Si   "	.B	ICOBEMOL,7	.B	7,-1	.ASCIZ	"Do b "	.B	0,0	.B	0,0	.ASCIZ	"?    "	.EVEN	.END