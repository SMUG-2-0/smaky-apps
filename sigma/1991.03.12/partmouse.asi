	.SBTTL	PARTMOUSE;--------\\; IFMOUSE >;========/; Donne la position relative de la souris.; in	-; out	D7.W	ok;	 D4.L	 position de la souris dans la swdo;	D7.W	ERNOT;	 D4.L	 position la plus proche dans la swdo; mod	D4.L, D7.WIFMOUSE:	PUSHM.L	D0,D3,A3	LOAD.L	A3,(A6)+OPMES	; A3 <-- ^mesure courante	LIB	?IFMOUSE	; D4 <-- position "brutte";;?	JUMP,NE 90$	LOAD.L	(A6)+OMPOB,D4	; OMPOB <-- position BRUTTE	CLR.W	D7		; D7 <-- ok,  priori	SUB.W	D4,(A0)+ODFFX	; trop  gauche ?	JUMP',HS 10$	CLR.W	D4	LOAD.W	D7,#ERSNOT	; D7 <-- pas dans swdo10$:	COMP.W	D4,(A0)+ODFFDX	; trop  droite ?	JUMP',LO 12$	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D7,#ERSNOT	; D7 <-- pas dans swdo12$:	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; trop en haut ?	JUMP',HS 14$	CLR.W	D4	LOAD.W	D7,#ERSNOT	; D7 <-- pas dans swdo14$:	COMP.W	D4,(A0)+ODFFDY	; trop en bas ?	JUMP',LO 16$	LOAD.W	D4,(A0)+ODFFDY	LOAD.W	D7,#ERSNOT	; D7 <-- pas dans swdo16$:	SWAP.W	D4	LOAD.L	(A6)+OMPOW,D4	; OMPOW <-- position dans SWDO	LOAD.W	D3,#MXPORTEE+MXFIXE	COMP.W	D4,D3		; trop  gauche ?	JUMP',HS 20$	LOAD.W	D4,D3	LOAD.W	D7,#ERSNOT	; D7 <-- pas dans swdo20$:	LOAD.W	D3,#MXPORTEE	ADD.W	D3,(A3)+OMELG	COMP.W	D4,D3		; trop  droite ?	JUMP',LO 22$	LOAD.W	D4,D3	LOAD.W	D7,#ERSNOT	; D7 <-- pas dans swdo22$:	SWAP.W	D4	COMP.W	D4,(A3)+OMEMIN	; trop haut ?	JUMP',HS 24$	LOAD.W	D4,(A3)+OMEMIN	LOAD.W	D7,#ERSNOT	; D7 <-- pas dans swdo24$:	COMP.W	D4,(A3)+OMEMAX	; trop bas ?	JUMP',LO 26$	LOAD.W	D4,(A3)+OMEMAX	SUB.W	D4,#LYPORTEE/2	LOAD.W	D7,#ERSNOT	; D7 <-- pas dans swdo26$:	SWAP.W	D490$:	POPM.L	D0,D3,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; RNDOBJET >;=========/; Arrondi la position de la souris pour tre sur une porte,; ou entre deux lignes.; in	D0.W	"soft-keys" allumes;	D1.W	niveau;	D4.L	position souris (y;x); out	D4.L	position arrondie (y;x); mod	D4.LRNDOBJET:	PUSH.L	D3	COMP.W	D1,#NGRAPHIQUE	; dessin d'objets graphiques ?	JUMP',EQ 20$		; oui => 20$				; non =>	LOAD.W	D3,(A6)+ONGRA	TEST.L	D3:#SKGPAS	; align sur le pas ?	JUMP',BC 50$		; non => 50$	JUMP'	40$		; oui => 40$20$:	TEST.L	D0:#SKGPAS	; align sur le pas ?	JUMP',BC 90$		; non => 90$40$:				; oui =>	SUB.W	D4,#MXPORTEE+MXFIXE	CLR.L	D3	LOAD.W	D3,(A6)+OLXPORT	SR.W	D3,#1	ADD.W	D3,D4	DIV.WA	D3,(A6)+OLXPORT	MUL.WA	D3,(A6)+OLXPORT	LOAD.W	D4,D3	ADD.W	D4,#MXPORTEE+MXFIXE50$:	SWAP.W	D4	CLR.L	D3	LOAD.W	D3,D4	ADD.W	D3,#LYPORTEE/4	DIV.WU	D3,#LYPORTEE/2	MUL.WU	D3,#LYPORTEE/2	LOAD.W	D4,D3	SWAP.W	D490$:	POP.L	D3	RET;----------\\; SRNDOBJET >;==========/; Arrondi la position de la souris pour quelques symboles spcifiques,; comme les pauses qui ne peuvent pas tre entre deux lignes.; in	A4.L	^symbole;	D4.L	position souris (y;x); out	D4.L	nouvelle position (y;x); mod	D4.LSRNDOBJET:	CALL	IFRNDOBJET	; arrondi ncessaire ?	JUMP',NE 90$		; non => 90$	CALL	PRNDOBJET	; oui => et bien, fait-le !90$:	RET;-----------\\; IFRNDOBJET >;===========/; Regarde s'il s'agit d'un symbole spcial (pause, chiffre, etc.) devant; tre obligatoirement sur une ligne de la porte.; in	A4.L	^symbole; out	D7.W	EQ => il faut arrondir; mod	D7.WIFRNDOBJET:	PUSH.W	D3	LOAD.W	D7,#ERSNOT	; D7 <-- arrondi pas ncessaire	LOAD.B	D3,(A4)+OOBJC	; D3 <-- code de l'icne	COMP.B	D3,#ICODROITE	; objet graphique ?	JUMP',HS 90$		; oui => 90$				; non =>	COMP.B	D3,#ICOPAUSE	JUMP',LO 90$	COMP.B	D3,#ICOHSOUPIR	JUMP',LS 50$	COMP.B	D3,#ICOZERO	JUMP',LO 90$	COMP.B	D3,#ICOCB	JUMP',LS 50$	COMP.B	D3,#ICOTR	JUMP',EQ 50$	COMP.B	D3,#ICOTRILLE	JUMP',EQ 50$	COMP.B	D3,#ICOIDEM1	JUMP',EQ 50$	COMP.B	D3,#ICOIDEM2	JUMP',NE 90$50$:				; silence (ou qq. divers) =>	CLR.W	D7		; D7 <-- il faut arrondir90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; PRNDOBJET >;==========/; Arrondi la position de la souris pour s'aligner sur la porte,; mais pas entre deux lignes.; in	D4.L	position souris (y;x); out	D4.L	nouvelle position (y;x); mod	D4.LPRNDOBJET:	PUSH.L	D3	SWAP.W	D4	CLR.L	D3	LOAD.W	D3,D4		; D3 <-- hauteur	DIV.WU	D3,#LYPORTEE	MUL.WU	D3,#LYPORTEE	ADD.W	D3,#LYPORTEE/2	; toujours entre 2 lignes de porte !	LOAD.W	D4,D3	SWAP.W	D4	POP.L	D3	RET	.END