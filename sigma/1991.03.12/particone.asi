	.SBTTL	PARTICONE;-----------\\; MAJSOFTKEY >;===========/; Met  jour les "soft-keys" selon le niveau comme suit :;   Note:	Affiche l'altration;   Note:	Affiche l'accentuation;   Graphique:	Affiche l'paisseur des traits;   Divers:	Affiche le chiffre (0..9, 12, 16, C ou CB);   Divers:	Affiche le signe d'accentuation;   Clef:	Affiche #/b;   Clef:	Affiche les trois clefs sol/fa/rien; in	D0.W	"soft-keys" allumes;	D1.W	niveau; out	-; mod	D7.WMAJSOFTKEY:	PUSHM.L	D2..D6,A2..A4	LOAD.L	A3,(A6)+OPICOH	; A3 <-- ^icnes horizontaux	LOAD.L	A4,(A6)+OPICOV	; A4 <-- ^icnes verticaux	COMP.W	D1,#NCLEF	JUMP,EQ 60$	COMP.W	D1,#NDIVERS1	JUMP,EQ 40$	COMP.W	D1,#NGRAPHIQUE	JUMP,EQ 30$	COMP.W	D1,#NHAUTSILENCE	JUMP',EQ 10$	COMP.W	D1,#NBASSILENCE	JUMP',EQ 10$	CLR.W	D6	COMP.W	D1,#NHAUTNOTE	JUMP',EQ 10$	INC.W	D6	COMP.W	D1,#NBASNOTE	JUMP,NE 90$10$:	CLR.W	D5	LIB	?USEWDO		; utilise la swdo principale	LOAD.W	D3,(A6)+ONPOINT	JUMP',NE 20$	LOAD.B	D3,#ICOVIDE20$:	LOAD.W	D2,#SKNPOINT	; D2 <-- rang de la "soft-key"	CALL	MAJONESOFTKEY	COMP.W	D1,#NHAUTSILENCE	JUMP',EQ 28$	COMP.W	D1,#NBASSILENCE	JUMP',EQ 28$	LOAD.W	D3,(A6)+ONALT	JUMP',NE 22$	LOAD.B	D3,#ICOVIDE22$:	LOAD.W	D2,#SKNALTER	; D2 <-- rang de la "soft-key"	CALL	MAJONESOFTKEY	LOAD.W	D3,(A6)+ONACC	JUMP',NE 25$	LOAD.B	D3,#ICOVIDE	CLR.W	D625$:	ADD.W	D3,D6		; D3 <-- utilise ICOH/ICOB.. selon	LOAD.W	D2,#SKNACCENT	; D2 <-- rang de la "soft-key"	CALL	MAJONESOFTKEY	LOAD.W	D3,(A6)+ONFRAP	LOAD.W	D2,#SKNFRAPPE	; D2 <-- rang de la "soft-key"	CALL	MAJONESOFTKEY28$:	LOAD.W	D5,(A6)+OWDOCA	LIB	?USEWDO		; utilise swdo dans le cadre	JUMP	90$30$:	CLR.W	D5	LIB	?USEWDO		; utilise la swdo principale	LOAD.W	D3,(A6)+ONEP	LOAD.W	D2,#SKGEPAISSEUR ; D2 <-- rang de la "soft-key"	CALL	MAJONESOFTKEY	LOAD.W	D5,(A6)+OWDOCA	LIB	?USEWDO		; utilise swdo dans le cadre	JUMP	90$40$:				; divers =>	CLR.W	D5	LIB	?USEWDO		; utilise la swdo principale	LOAD.W	D3,(A6)+ONCHI	JUMP',NE 50$	LOAD.B	D3,#ICOVIDE50$:	LOAD.W	D2,#SKDCHIFFRE	; D2 <-- rang de la "soft-key"	CALL	MAJONESOFTKEY	LOAD.W	D3,(A6)+ONREP	JUMP',NE 55$	LOAD.B	D3,#ICOVIDE55$:	LOAD.W	D2,#SKDACCENT	; D2 <-- rang de la "soft-key"	CALL	MAJONESOFTKEY	LOAD.W	D5,(A6)+OWDOCA	LIB	?USEWDO		; utilise swdo dans le cadre	JUMP	90$60$:				; clef =>	CLR.W	D5	LIB	?USEWDO		; utilise la swdo principale	LOAD.L	A2,(A6)+OPMES	; A2 <-- ^dbut de la mesure	LOAD.B	D3,(A2)+OMETA	; D3 <-- #/b	LOAD.W	D2,#SKCALTER	; D2 <-- rang de la "soft-key"	CALL	MAJONESOFTKEY	LOAD.L	A2,#(A2)+OMELP	; A2 <-- ^premire porte	LOAD.W	D2,#SKCCLEF62$:	LOAD.B	D3,(A2)+OLPTYP	; D3 <-- ICOPSOL/PFA/VIDE	CALL	MAJONESOFTKEY	LOAD.L	A2,#(A2)+LLP	; A2 <-- ^porte suivante	INC.W	D2	COMP.W	D2,#SKCCLEF+3	JUMP,LO 62$	LOAD.L	A2,(A6)+OPMES	; A2 <-- ^dbut de la mesure	TCLR.L	D0:#16		; D0 <-- "soft-key" lie n'existe pas	LOAD.B	D3,#ICOVIDE	TEST.L	D0:#SKCCLEF+2	JUMP',BS 68$	TEST.L	D0:#SKCCLEF+1	JUMP',BS 64$	COMP.B	(A2)+OMELP+(LLP*0)+OLPTYP,#ICOVIDE	JUMP',EQ 68$	COMP.B	(A2)+OMELP+(LLP*1)+OLPTYP,#ICOVIDE	JUMP',NE 67$	COMP.B	(A2)+OMELP+(LLP*2)+OLPTYP,#ICOVIDE	JUMP',NE 67$	JUMP'	68$64$:	COMP.B	(A2)+OMELP+(LLP*1)+OLPTYP,#ICOVIDE	JUMP',EQ 68$	COMP.B	(A2)+OMELP+(LLP*2)+OLPTYP,#ICOVIDE	JUMP',NE 67$	JUMP'	68$67$:	TSET.L	D0:#16		; D0 <-- "soft-key" lie existe	LOAD.B	D3,#ICOLIE68$:	LOAD.W	D2,#SKCLIE	; D2 <-- rang de la "soft-key"	CALL	MAJONESOFTKEY	LOAD.W	D5,(A6)+OWDOCA	LIB	?USEWDO		; utilise swdo dans le cadre90$:	POPM.L	D2..D6,A2..A4	RET;--------------\\; MAJONESOFTKEY >;--------------/; in	D0.W	"soft-keys" allumes;	D2.W	rang de la "soft-key" (0..15);	D3.B	code de l'icne  mettre;	A3.L	^icnes horizontaux;	A4.L	^icnes verticaux; out	-; mod	D7.WMAJONESOFTKEY:	PUSHM.L	D1..D5	LOAD.B	D5,D3		; D5 <-- code de l'icne	LOAD.W	D1,#SETDOT	LOAD.L	D3,#-1	LOAD.L	D4,D3	TEST.L	D0:D2		; "soft-key" allume ?	JUMP',BC 10$		; non => 10$	LOAD.W	D1,#CLRDOT	CLR.L	D3	CLR.L	D410$:	LIB	?DRMDEF		; dfinit une trame blanche/noire	DBOX_	ICOPOS		; D3/D4 <-- position/dimensions	LOAD.W	D2,D1	LIB	?DRMATRIX	; rempli de blanc/noir	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- au milieu	SUB.W	D3,#LXICONE/2	; D3 <--  gauche de l'icne	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- en bas	SUB.W	D3,#GCICB	; D3 <-- remonte sur la ligne de base;	SWAP.W	D4	SWAP.W	D3	LOAD.L	D4,D3		; D4 <-- position	LOAD.B	D3,D5		; D3 <-- code de l'icne	LOAD.W	D2,#INVDOT	; D2 <-- mode de dessin	CALL	DESPOSSYMB	; dessine une icne	POPM.L	D1..D5	RET;-----------\\; POSSOFTKEY >;===========/; Donne la position et les dimensions d'une icne d'une soft-key.; in	D2.W	rang de la "soft-key" (0..15); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WPOSSOFTKEY:	PUSHM.L	A3,A4	LOAD.L	A3,(A6)+OPICOH	; A3 <-- ^icnes horizontaux	LOAD.L	A4,(A6)+OPICOV	; A4 <-- ^icnes verticaux	DBOX_	ICOPOS		; D3/D4 <-- position/dimensions	POPM.L	A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ALLSOFTKEY >;===========/; Allume toutes les icnes ncessaires en bas de l'cran,; et une icne "verticale" en fonction du niveau.; in	D0.W	icnes  allumer;	D1.W	niveau; out	-; mod	D7.WALLSOFTKEY:	PUSHM.L D0,D2,A3,A4	LOAD.L	A3,(A6)+OPICOH	; A3 <-- ^icnes horizontaux	LOAD.L	A4,(A6)+OPICOV	; A4 <-- ^icnes verticaux	CLR.W	D210$:	RR.L	D0,#1	JUMP',CC 20$	DBOX_	ICOINV20$:	INC.W	D2	COMP.W	D2,#NBICONE	JUMP,LO 10$	LOAD.W	D2,#NBICONE	COMP.W	D1,#NHAUTNOTE	JUMP',EQ 50$	COMP.W	D1,#NBASNOTE	JUMP',EQ 50$	INC.W	D2	COMP.W	D1,#NHAUTSILENCE	JUMP',EQ 50$	COMP.W	D1,#NBASSILENCE	JUMP',EQ 50$	INC.W	D2	COMP.W	D1,#NDIVERS1	JUMP',EQ 50$	COMP.W	D1,#NDIVERS2	JUMP',EQ 50$	INC.W	D2	COMP.W	D1,#NGRAPHIQUE	JUMP',EQ 50$	INC.W	D2	COMP.W	D1,#NCLEF	JUMP',EQ 50$	INC.W	D2	COMP.W	D1,#NFLOPPY	JUMP',EQ 50$	INC.W	D250$:	DBOX_	ICOINV		; inverse une icne "verticale"	POPM.L	D0,D2,A3,A4	RET;--------------\\; CLRALLSOFTKEY >;==============/; Eteint toutes les icnes en bas de l'cran.; in	D2.W	rang icne (0..15);	D0.W	icne allumes; out	D0.W	icne allumes; mod	D0.WCLRALLSOFTKEY:	PUSH.W	D2	CLR.W	D210$:	CALL	CLRSOFTKEY	INC.W	D2	COMP.W	D2,#NBICONE	JUMP,LO 10$	POP.W	D2	RET;-----------\\; INVSOFTKEY >;===========/; Inverse une icne en bas de l'cran.; in	D2.W	rang icne (0..15);	D0.W	icne allumes; out	D0.W	icne allumes; mod	D0.WINVSOFTKEY:	PUSHM.L	A3,A4	LOAD.L	A3,(A6)+OPICOH	; A3 <-- ^icnes horizontaux	LOAD.L	A4,(A6)+OPICOV	; A4 <-- ^icnes verticaux	TNOT.L	D0:D2	DBOX_	ICOINV	POPM.L	A3,A4	RET;-----------\\; SETSOFTKEY >;===========/; Allume une icne en bas de l'cran.; in	D2.W	rang icne (0..15);	D0.W	icne allumes; out	D0.W	icne allumes; mod	D0.WSETSOFTKEY:	PUSHM.L	A3,A4	LOAD.L	A3,(A6)+OPICOH	; A3 <-- ^icnes horizontaux	LOAD.L	A4,(A6)+OPICOV	; A4 <-- ^icnes verticaux	TSET.L	D0:D2	JUMP',BS 90$	DBOX_	ICOINV90$:	POPM.L	A3,A4	RET;-----------\\; CLRSOFTKEY >;===========/; Eteint une icne en bas de l'cran.; in	D2.W	rang icne (0..15);	D0.W	icne allumes; out	D0.W	icne allumes; mod	D0.WCLRSOFTKEY:	PUSHM.L	A3,A4	LOAD.L	A3,(A6)+OPICOH	; A3 <-- ^icnes horizontaux	LOAD.L	A4,(A6)+OPICOV	; A4 <-- ^icnes verticaux	TCLR.L	D0:D2	JUMP',BC 90$	DBOX_	ICOINV90$:	POPM.L	A3,A4	RET;---------\\; MAJMOUSE >;=========/; Met  jour l'affichage des trois boutons de la souris.; in	D0.W	icnes allumes;	D1.W	niveau; out	-; mod	D7.WMAJMOUSE:	PUSHM.L	D0,D3,A3	LOAD.L	A3,#R16"TXMNOTE	COMP.W	D1,#NHAUTNOTE	JUMP',EQ 20$	COMP.W	D1,#NBASNOTE	JUMP',EQ 20$	LOAD.L	A3,#R16"TXMSILENCE	COMP.W	D1,#NHAUTSILENCE	JUMP',EQ 20$	COMP.W	D1,#NBASSILENCE	JUMP',EQ 20$	LOAD.L	A3,#R16"TXMDIVERS1	COMP.W	D1,#NDIVERS1	JUMP',EQ 20$	LOAD.L	A3,#R16"TXMDIVERS2	COMP.W	D1,#NDIVERS2	JUMP',EQ 20$	LOAD.L	A3,#R16"TXMGRAPHIQUE	COMP.W	D1,#NGRAPHIQUE	JUMP',EQ 20$	LOAD.L	A3,#R16"TXMVIDEG	CALL	AFMOUSE		; affiche le bouton de gauche	JUMP'	40$20$:				; note/silence/symbole/graphique =>	CALL	MAJONEMOUSE	; affiche le bouton de gauche40$:	LOAD.L	A3,#R16"TXMDROITE	CALL	AFMOUSE		; affiche le bouton de droite	LOAD.L	A3,#R16"TXMVIDEM	CALL	AFMOUSE		; affiche le bouton du milieu	POPM.L	D0,D3,A3	RET;------------\\; MAJONEMOUSE >;------------/; Affiche l'un des trois bouton de la souris.; in	A3.L	^liste de <n>textes;	D0.W	icnes allumes; out	A3.L	^texte choisit; mod	D7.W, A3.LMAJONEMOUSE:	PUSH.W	D020$:	TEST.L	D0:#1	JUMP',BS 30$	RR.W	D0,#122$:	TEST.B	(A3+)	JUMP,NE 22$	JUMP	20$30$:	CALL	AFMOUSE		; affiche tout en haut	POP.W	D0	RET	.END