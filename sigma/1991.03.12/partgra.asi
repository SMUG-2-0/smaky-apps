	.SBTTL	PARTGRA;---------\\; PREPGRA  >;=========/; Met un objet graphique en fonction des soft-keys allumes.; in	D0.W	icnes allums en bas de l'cran;	A4.L	^objet graphique; out	-; mod	D7.WPREPGRA:	PUSH.W	D3	LOAD.B	D3,#ICODROITE	TEST.L	D0:#SKGDROITE	JUMP',BS 10$	LOAD.B	D3,#ICOHCOURBE	TEST.L	D0:#SKGHCOURBE	JUMP',BS 10$	LOAD.B	D3,#ICOBCOURBE	TEST.L	D0:#SKGBCOURBE	JUMP',BS 10$	LOAD.B	D3,#ICORECTANGLE	TEST.L	D0:#SKGRECTANGLE	JUMP',BS 10$	LOAD.B	D3,#ICOCERCLE	TEST.L	D0:#SKGCERCLE	JUMP',BS 10$	LOAD.B	D3,#ICOTEXTE	TEST.L	D0:#SKGTEXTE;	JUMP',BS 10$10$:	LOAD.B	(A4)+OOBJC,D3	; objet <-- code icne	LOAD.W	D3,(A6)+ONEP	LOAD.B	(A4)+OGREP,#1	LOAD.B	(A4)+OGRTT,#B'11110000	COMP.B	D3,#ICOEPTT	JUMP',EQ 50$	LOAD.B	(A4)+OGREP,#4	CLR.B	(A4)+OGRTT	COMP.B	D3,#ICOEP4	JUMP',EQ 50$	LOAD.B	(A4)+OGREP,#2	CLR.B	(A4)+OGRTT	COMP.B	D3,#ICOEP2	JUMP',EQ 50$	LOAD.B	(A4)+OGREP,#1	CLR.B	(A4)+OGRTT50$:	POP.W	D3	RET;--------\\; CALCGRA >;========/; Calcul des paramtres pour des objets graphiques spciaux.; Cercle:	calcul le rayon; in	A4.L	^objet graphique; out	-; mod	D7.WCALCGRA:	PUSHM.L	D1..D4	LOAD.L	D3,(A4)+OGRPN1	; D3 <-- position "fixe" de l'objet	LOAD.L	D4,(A4)+OGRPN2	; D4 <-- position "libre" de l'objet	JUMP',EQ 90$		; si inconnu => 90$	LOAD.B	D1,(A4)+OOBJC	; D1 <-- code de l'icne	COMP.B	D1,#ICOCERCLE	JUMP',NE 90$				; cercle =>	SUB.W	D4,D3	JUMP',NC 51$	NEG.W	D451$:	LOAD.W	D1,D4		; D1 <-- |distance en X|	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',NC 52$	NEG.W	D452$:				; D4 <-- |distance en Y|	SWAP.W	D3	COMP.W	D4,D1	JUMP',HS 54$	LOAD.W	D4,D1		; D4 <-- plus grande distance54$:	LOAD.W	(A4)+OGRPN2+2,D4	CLR.W	(A4)+OGRPN2+090$:	POPM.L	D1..D4	RET;--------\\; DESGRA  >;========/; Dessine un objet graphique complet.; in	A4.L	^objet graphique;	D2.W	mode de dessin; out	-; mod	D7.WDESGRA:	PUSHM.L	D0..D4,D6,A3	LIB	?BUCAR		; mode rapide	LOAD.B	D3,(A4)+OGRTT	; D3 <-- traitill	JUMP',EQ 10$	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	(A3)+0,#MAPTT	; <maptt>	LOAD.B	(A3)+1,D3	; <m>	LOAD.B	(A3)+2,#1	; <e>	LOAD.W	D3,#3	LIB	?STRING	OR.W	D2,#TTTDOT	; D2 <-- mode de dessin avec traitill10$:	LOAD.L	D3,(A4)+OGRPN1	; D3 <-- position "fixe" de l'objet	LOAD.L	D4,(A4)+OGRPN2	; D4 <-- position "libre" de l'objet	JUMP,EQ 90$		; si inconnu => 90$	LOAD.B	D0,(A4)+OGREP	; D0 <-- paisseur des traits	LOAD.B	D1,(A4)+OOBJC	; D1 <-- code de l'icne	COMP.B	D1,#ICOHCOURBE	JUMP',EQ 20$	COMP.B	D1,#ICOBCOURBE	JUMP',EQ 25$	COMP.B	D1,#ICODROITE	JUMP,EQ 30$	COMP.B	D1,#ICORECTANGLE	JUMP,EQ 40$	COMP.B	D1,#ICOCERCLE	JUMP,EQ 50$	JUMP	90$20$:				; courbe =>	TCLR.L	D2:#BTTTDOT	CALL	HCOURBE	JUMP	90$25$:				; courbe =>	TCLR.L	D2:#BTTTDOT	CALL	BCOURBE	JUMP	90$30$:				; droite =>	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D432$:	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	PUSH.W	D4	LOAD.L	D1,D4	SWAP.W	D1	TEST.W	D1	JUMP',NC 34$	NEG.W	D1		; D1 <-- |dY|34$:	TEST.W	D4	JUMP',NC 35$	NEG.W	D4		; D4 <-- |dX|35$:	INC.W	D3		; D3 <-- descend origine en Y	COMP.W	D4,D1	JUMP',LS 36$	DEC.W	D3	SWAP.W	D3	INC.W	D3		; D3 <--  droite origine en X	SWAP.W	D336$:	POP.W	D4	DEC.B	D0	JUMP,NE 32$	JUMP'	90$40$:				; rectangle =>	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D442$:	LIB	?DRRECT	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	DEC.B	D0	JUMP,NE 42$	JUMP'	90$50$:				; cercle =>	LIB	?DRCERCLE	DEC.W	D4	DEC.B	D0	JUMP,NE 50$;	JUMP'	90$90$:	LIB	?NOBUCAR	; remet le mode normal	POPM.L	D0..D4,D6,A3	RET;--------\\; BCOURBE >;--------/; Dessine une courbe incurve contre en haut (comme un "^").; in	A4.L	^objet;	D3.L	dpart de la courbe (y;x);	D4.L	arrive de la courbe (y;x); out	-; mod	D7.W;	       Pi;	       o----------------;	      /|\         |   |;	     / | \        b   |;	    /  |  \       |   b';	D3 o---|   \ -------  |;	   |   |    \         |;	   |   |-----o D4  -----;	   <-a->     |;	   <----l---->;; La courbe doit passer par les trois points D3-Pi-D4.; La formule suivante permet de trouver le point Pi :;;	        l;	a = ---------        et       b = LYCOURBE;	      b';	     --- + 1;	      bBCOURBE:	PUSHM.L	D0..D5,A3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D3		; D1 <-- sommet de la courbe	COMP.W	D1,D4	JUMP',HS 40$	SUB.W	D1,#LYCOURBE	; D1 <-- Pi(y)	LOAD.W	D0,D4	SUB.W	D0,D3	ADD.W	D0,#LYCOURBE	; D0 <-- b' (hauteur de la courbe)	SWAP.W	D4	SWAP.W	D3	SWAP.W	D1	MUL.WU	D0,#100	DIV.WU	D0,#LYCOURBE	ADD.W	D0,#100		; D0 <-- (b'/b)+1	LOAD.W	D5,D4	SUB.W	D5,D3		; D5 <-- l	MUL.WA	D5,#100	DIV.WA	D5,D0		; D5 <-- l / (b'/b)+1	LOAD.W	D1,D3	ADD.W	D1,D5		; D1 <-- Pi(x)	JUMP'	60$40$:				; arrive plus haute que le dpart =>	LOAD.W	D1,D4		; D1 <-- sommet de la courbe	SUB.W	D1,#LYCOURBE	; D1 <-- Pi(y)	LOAD.W	D0,D3	SUB.W	D0,D4	ADD.W	D0,#LYCOURBE	; D0 <-- b' (hauteur de la courbe)	SWAP.W	D4	SWAP.W	D3	SWAP.W	D1	LOAD.L	D5,#LYCOURBE*100	DIV.WU	D5,D0	ADD.W	D5,#100		; D5 <-- (b'/b)+1	LOAD.W	D0,D4	SUB.W	D0,D3		; D0 <-- l	MUL.WA	D0,#100	DIV.WA	D0,D5		; D5 <-- l / (b'/b)+1	LOAD.W	D1,D3	ADD.W	D1,D0		; D1 <-- <xx> intermdiaire60$:	LOAD.L	A3,#R16"TDCOURBE	EX.L	D4,D1	CALL	QCOURBE	LOAD.L	A3,#R16"TFCOURBE	LOAD.L	D3,D4	LOAD.L	D4,D1	CALL	QCOURBE	POPM.L	D0..D5,A3	RET;--------\\; HCOURBE >;--------/; Dessine une courbe incurve contre en bas (comme un "u").; in	A4.L	^objet;	D3.L	dpart de la courbe (y;x);	D4.L	arrive de la courbe (y;x); out	-; mod	D7.WHCOURBE:	PUSHM.L	D0..D5,A3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D3		; D1 <-- sommet de la courbe	COMP.W	D1,D4	JUMP',LO 40$	ADD.W	D1,#LYCOURBE	; D1 <-- Pi(y)	LOAD.W	D0,D3	SUB.W	D0,D4	ADD.W	D0,#LYCOURBE	; D0 <-- b' (hauteur de la courbe)	SWAP.W	D4	SWAP.W	D3	SWAP.W	D1	MUL.WU	D0,#100	DIV.WU	D0,#LYCOURBE	ADD.W	D0,#100		; D0 <-- (b'/b)+1	LOAD.W	D5,D4	SUB.W	D5,D3		; D5 <-- l	MUL.WA	D5,#100	DIV.WA	D5,D0		; D5 <-- l / (b'/b)+1	LOAD.W	D1,D3	ADD.W	D1,D5		; D1 <-- Pi(x)	JUMP'	60$40$:				; arrive plus haute que le dpart =>	LOAD.W	D1,D4		; D1 <-- sommet de la courbe	ADD.W	D1,#LYCOURBE	; D1 <-- Pi(y)	LOAD.W	D0,D4	SUB.W	D0,D3	ADD.W	D0,#LYCOURBE	; D0 <-- hauteur de la courbe	SWAP.W	D4	SWAP.W	D3	SWAP.W	D1	LOAD.L	D5,#LYCOURBE*100	DIV.WU	D5,D0	ADD.W	D5,#100		; D5 <-- (b'/b)+1	LOAD.W	D0,D4	SUB.W	D0,D3		; D0 <-- l	MUL.WA	D0,#100	DIV.WA	D0,D5		; D5 <-- l / (b'/b)+1	LOAD.W	D1,D3	ADD.W	D1,D0		; D1 <-- <xx> intermdiaire60$:	LOAD.L	A3,#R16"TDCOURBE	EX.L	D4,D1	CALL	QCOURBE	LOAD.L	A3,#R16"TFCOURBE	LOAD.L	D3,D4	LOAD.L	D4,D1	CALL	QCOURBE	POPM.L	D0..D5,A3	RET;--------\\; QCOURBE >;--------/; Trace une portion de courbe selon un table de points.; in	A4.L	^objet;	D3.L	dbut courbe (y;x);	D4.L	fin courbe (y;x);	D2.W	mode de dessin;	A3.L	^table; out	-; mod	D7.W, A3.LQCOURBE:	PUSHM.L	D0..D6	LOAD.L	D6,D3		; D6 <-- origine	LOAD.W	D0,D4	SUB.W	D0,D3		; D0 <-- dX	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D4	SUB.W	D1,D3		; D1 <-- dY	SWAP.W	D310$:	TEST.L	(A3)	JUMP',EQ 90$	LOAD.W	D4,(A3+)	MUL.WA	D4,D1	DIV.WA	D4,#100	SWAP.W	D4	LOAD.W	D5,(A3+)	MUL.WA	D5,D0	DIV.WA	D5,#100	LOAD.W	D4,D5	SUB.W	D4,D3	ADD.W	D4,D6	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	SUB.W	D4,D3	ADD.W	D4,D6	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	CALL	LCOURBE		; dessine un segment de droite	JUMP	10$90$:	POPM.L	D0..D6	RET;--------\\; LCOURBE >;--------/; Trace un segment de droite pour une courbe en tenant compte; de l'paisseur des traits.; in	A4.L	^objet;	D3.L	dpart (y;x);	D4.L	longueurs (dy;dx); out	D3.L	suite; mod	D3.L, D7.WLCOURBE:	PUSHM.L	D0,D1	LOAD.L	D0,D3	LIB	?DRSEG	LOAD.B	D1,(A4)+OGREP	; D1 <-- paisseur	DEC.B	D1	JUMP',EQ 90$	EX.L	D0,D320$:	SWAP.W	D3	INC.W	D3	SWAP.W	D3	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	DEC.B	D1	JUMP,NE 20$	LOAD.L	D3,D090$:	POPM.L	D0,D1	RET;	.W	pY,pX;	-------------------TDCOURBE:	.W	20,10	.W	37,20	.W	52,30	.W	65,40	.W	76,50	.W	85,60	.W	91,70	.W	96,80	.W	99,90	.W	100,100	.W	0,0TFCOURBE:	.W	100-99,10	.W	100-96,20	.W	100-91,30	.W	100-85,40	.W	100-76,50	.W	100-65,60	.W	100-52,70	.W	100-37,80	.W	100-20,90	.W	100-0,100	.W	0,0	.END