	.PROC	Z80; Definition of the Z80 peripherals;----------------------------------; PIO definitionPINPMD = 117	; Input modePOUTMD = 017	; Output modePBIDMD = 217	; Bidirectional modePCTRMD = 317	; Control modePINTEN = 207	; Interrupt enablePINTDS = 007	; Interrupt disablePAND   = 107	; AND functionPOR    = 007	; OR functionPHIGH  = 047	; Active highPLOW   = 007	; Active lowPMFOL  = 027	; Mask followPRPINT = 027	; Reset pending int.; CTC definitionCINTDS = 001	; Interrupt disableCINTEN = 201	; Interrupt enableCNTMD  = 101	; Counter modeCTMD   = 001	; Timer modeCP256  = 041	; Prescaler factor = 256CP016  = 001	; Prescaler factor = 16CPSLP  = 021	; Positive edgeCNSLP  = 001	; Negative edgeCEXTR  = 011	; External triggerCNXTR  = 001	; No external triggerCLDCS  = 005	; Load time constantCRSET  = 003	; Reset;	SIO DEFINITION;	==============; WRITE REGISTER 0	R0    = 0	RSEXI = 20	; RESET EXTERNAL INTERRUPTS	RSCHL = 30	; RESET CHANNEL	RSRCVI= 40	; RESET RECEIVER INTERRUPTS	RSTBMT= 50	; RESET XMIT BUFFER EMPTY INT.	RSEROR= 60	; RESET ERROR	RETIA = 70	; RETURN FROM INT. (CH. A ONLY); WRITE REGISTER 1 (INTERRUPT CONTROL)	R1     = 1	EXTIE  = 1	; EXT INT. ENABLE (DCD,CTS)	TRSIE  = 2	; XMIT INTERRUPT ENABLE	STAVEC = 4	; STATUS AFECTS VECTOR	RIDIS  = 0	; RCV. INTERRUPT DISABLE	RCVIM1 = 10	; INT. ON FIRST CHAR.	RCVIM2 = 20	; ALL CHAR. INT (WITH PAR. AFF. VEC)	RCVIM3 = 30	;  "   "     " (WITHOUT "   "    " ); WRITE REGISTER 2 LOADED ONLY INTO CHANNEL B	R2     = 2; = INTERRUPT VECTOR; WRITE REGISTER 3 (XRCV MODE ONLY)	R3    = 3	RX5B  = 0	; 5 BITS/CHAR.	RX6B  = 200	; 6 BITS/CHAR.	RX7B  = 100	; 7 BITS/CHAR.	RX8B  = 300	; 8 BITS/CHAR. 	AUTEN = 40	; ENABLE CONTROL OF DCD AND CTS	RCVEN = 1	; RECEIVER ENABLE; WRITE REGISTER 4 (XMIT/XRCV MODE)	R4     = 4	X1     = 0	; DIVIDE CLOCK BY 1	X16    = 100	;    "     "   "  16	X32    = 200	;    "     "   "  32	X64    = 300	;    "     "    " 64	SB1    = 4	; NUMBER OF STOP BITS 1	SB15   = 10	;   "    "    "   "   1.5	SB2    = 14	;   "    "    "   "   2	SYNCMD = 0	; SYNCHRONOUS MODE	PAREN  = 1	; PARITY ENABLE	PEVEN  = 2	; PARITY EVEN; WRITE REGISTER 5 (XMIT MODE ONLY)	R5     = 5	TX5B   = 0	; 5 BITS/CHAR.	TX6B   = 100	; 6 BITS/CHAR.	TX7B   = 40	; 7 BITS/CHAR.	TX8B   = 140	; 8 BITS/CHAR.	RTS    = 2	; RTS CONTROL	TRSEN  = 10	; TRANSMITTER ENABLE	DTR    = 200	; DTR CONTROL; WRITE REGISTER 6 (USED FOR SYNCHRONOUS MODE ONLY);   "	   "	 7 (  "	  "	"	  "	" ); END OF SIO DEFINITIONS	.END