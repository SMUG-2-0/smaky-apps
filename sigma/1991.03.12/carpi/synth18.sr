.TITLE SYNTH17.PROC Z80.OCT.RDX 8..LINES 60.;	DEFFINITION DES CONSTANTES;	--------------------------	PROGRAM	= 00000	STACK	= 41377	FIFO	= 41400		; FIFO INIT POSITION	RAM	= 40000		; FIRST RAM ADRESS	RAMLG	= 1024.	PATTERN	= 6000		; INTO DEBUG ROM	NBPAT	= 5		; NOMBRE DE PATTERNES	RUN	= 40100		; RAM BALAYEE	RUNLG	= 64.		; 64. BYTES BALAYES	DELAY	= 10000		; FOR BC COUNT	CMAX	= 11.		; NB OF LEGAL COMM.+1	PATMAX	= 9.		; NB OF PATTERN+1	NOTMAX	= 203		; PLUS GRAND NO DE NOTE	DOM2	= 6600		; ADD DO0	DO0	= 6740		; ADD DO1	ENVPAR	= 5600		; ADD PARAMETRES ENVELOPE;	PERIFERAL ADRESS, MEMORY;	------------------------	LO	= 100000	; DIVIDER LO BYTE	HI	= LO+1		; DIVIDER HI BYTE	FIL	= HI+1		; FILTER 	ENV	= FIL+1		; ENVELOPE SHAPER;	PERIFERAL ADRESS, I/O;	---------------------	SW	= 202		; SWITCHES ADR. INPUT	LED	= 202		; LED ADR. OUTPUT	STAT	= 203		; STATUS SW	CTC	= 10		; CTC BASE ADD	CTC0	= CTC		; CHANNEL 0	CTC1	= CTC0+1	; CHANNEL 1	CTC2	= CTC1+1	; CHANNEL 2	CTC3	= CTC2+1	; CHANNEL 3	PIO	= 20 		; BASE ADD	PIAD	= PIO	PIBD	= PIAD+1	PIAC	= PIBD+1	PIBC	= PIAC+1.PAGE;;	RAM SAVE POSITIONS;	------------------	SAVNNO	= RAM+300		;B/ NO DE NOTE	SAVENV	= SAVNNO+1		;B/ VAL. ENVELOPE	SAVFIL	= SAVENV+1		;B/ VAL. FILTRE	SAVPAT	= SAVFIL+1		;B/ NO DE PATTERNE	SAVTPS	= SAVPAT+1		;B/ VAL. TEMPS EXECURION	SAVCNT	= SAVTPS+1		;B/ VAL. COMPTEUR BYTES	SAVCOM	= SAVCNT+1		;B/ NO DE COMMANDE+STAT.	SAVFON	= SAVCOM+1		;B/ FILTRE ON/OFF	SAVPER	= SAVFON+1		;W/ VAL. PERIODE	SAVPEV	= SAVPER+2		;W/ VAL. PER. VIBRATO	FILCRT 	= SAVPEV+2		;B/ VAL. FILTRE REEL	VIBCRT	= FILCRT+1		;B/ VAL. VIBRATO REEL	VIBPDS	= VIBCRT+1		;B/ POIDS VIBRATO (+/-8)	ADDPAT	= VIBPDS+1		;W/ PATT. ADD. FOR SLIDE	HEAD	= ADDPAT+2		;W/ FIFO HEAD SAVE POS.	TAIL	= HEAD+2		;W/ FIFO TAIL SAVE POS	SAVPAS	= TAIL+2		;B/ NB. DE PASSES POUR SLIDE	SAVSTP	= SAVPAS+1		;B/ VALEUR DU STEP COM6	SAVFLG	= SAVSTP+1		;B/ FLAG NOUVELLE PASSE	SAVT	= SAVFLG+1		;W/ TEMPS D'EXECUTION T	SAVINT	= SAVT+2		;W/ INTERVAL TEMPS IT	COM6FO	= SAVINT+2		;B/ FLAG COMM6 ON	COM6FR	= COM6FO+1		;B/ FLAG COMM6 RUN	COM6CT	= COM6FR+1		;W/ COMPTEUR IT (INT. ROUT.)	COM6FL	= COM6CT+2		;B/ FLAG PASSE A FAIRE		;	TABLE DES FORMES D'ONDES;	------------------------;	ROM;	---	SINET	= 6000			; SINE TABLE	RAMPT   = SINET+100		; RAMP TABLE	PENTT	= RAMPT+100		; PENT TABLE	SQUAT	= PENTT+100		; SQUA TABLE	TRIAT   = SQUAT+100		; TRIA TABLE;	RAM;	---	RAMT0	= 40200			; RAMM TABLE #0	RAMT1	= RAMT0+100		; RAMM TABLE #1	RAMT2	= RAMT1+100		; RAMM TABLE #2	RAMT3	= RAMT2+100		; RAMM TABLE #3.PAGE;;____________________________________________________________;	LISTE DES COMMANDES;	-------------------;	1.	JOUE LA NOTE NO....;		/0/1/NO.../;	2.	VALEUR ENVELOPE;		/0/2/VAL..(0-64log)/;	3.	VALEUR FILTRE;		/0/3/VAL.../;		    /0->AUTOMATIQUE/;	4.	STOCKE PATTERNE;		/0/4/No TABLE (5  8) /BYTES...(64)/;	5.	TRANSFERE PATTERNE EN RAM BALAYEE;		/0/5/0->SINUS/;		    /1->RAMPE/;		    /2->PENTE/;		    /3->CARRE/;		    /4->TRIANGLE/;		    /5->PATTERNE RAM #0/;		    /6->	 RAM #1/;		    /7-> 	 RAM #2/;		    /8-> 	 RAM #3/;	6.	GLISSE DE LA PATTERNE JOUEE;		A LA NOUVELLE PATTERNE;		/0/6/(COMME EN 5.)/TEMPS...(4=0,1sec)/;	7. 	JOUE UNE NOTE DE PERIODE... ...;		/0/7/PERIODE LO...HI.../;	8.	JOUE UN VIBRATO DE VALEUR...;		/0/8/VALEUR... (+8  -8);	9.	REPOND PRESENT A L'APPEL (PIO DATA 0);		/0/9/;      10.	GLISSE DE LA NOTE COURANTE ;		A LA NOTE NO;		/0/10/NOTE.../TEMPS...(4=0,1sec)/;      11.	MET SYNCHRO-ON;		/0/11/;      12.	MET SYNCHRO-OFF;		/0/12/;____________________________________________________________.SBTTL MAIN	.LOC	PROGRAMMMAIN:	IOF		IM2	LOAD 	SP,#STACK	LOAD	A,#1			; init div. avant call	LOAD	HI,A	LOAD	A,#267	LOAD	LO,A			; do#4	LOAD	A,#33	LOAD	FIL,A	CALL	INIT			; init i/o	LOAD	A,$PIAD			; init handshake	LOAD	A,#252	LOAD 	$LED,A			; affiche	LOAD	A,#377	LOAD	SAVENV,A	LOAD	ENV,A	XOR	A,A	LOAD	SAVFIL,A	LOAD	COM6FL,A		; flag passe a faire	ION	LOAD	HL,#SINET	JUMP	COMM52	;NOP	MLOOP:	;NOP; attend un 0 synchro	LOAD	A,COM6FL		; lit flag passe a faire	OR	A,A	CALL,NE COM680			; fait une passe slide	CALL	RDFIFO			; lit fifo	JUMP,CC	MLOOP			; fifo vide	;NOP	OR	A,A			; est,ce un 0 ?	JUMP,NE	MLOOP			; non -> relit fifo; la synchro est arrivee, attend no de commandeMLOOP0:	CALL	RDFIFO			; lit fifo	JUMP,CC	MLOOP0			; relit si vide	;NOP	OR	A,A			; est ce un 0 ?	JUMP,EQ	MLOOP0			; oui -> relit	COMP	A,#CMAX			; comm valide ?	JUMP,LO	MLOOP1			; oui	XOR	A,A			; comm #0MLOOP1:	;NOP	LOAD	HL,#JTABLE	ADD	A,A			; deplacement*2	ADD	A,A			;	LOAD	C,A			;	LOAD	B,#0			;	ADD	HL,BC			; pointe add de saut	;NOP	JUMP	(HL)			; saute dans routine; adresses de saut dans les routinesJTABLE:	JUMP	ERR			; commande non valide	NOP	JUMP	COMM1	NOP	JUMP	COMM2	NOP	JUMP	COMM3	NOP	JUMP	COMM4	NOP	JUMP	COMM5	NOP	JUMP	COMM6	NOP	JUMP	COMM7	NOP		JUMP	COMM8	NOP	JUMP	COMM9	NOP	JUMP	COMM10.SBTTL COMM1;START___________COMMANDE 1___________________________________; joue la note noCOMM1:	;NOPCOMM11:	CALL	RDFIFO			; lit fifo	JUMP,CC	COMM11			; relit si vide; contrle si note valide	COMP	A,#NOTMAX+1		; no de note max.	JUMP,LO	COMM12	LOAD	A,#NOTMAX	; xcuteCOMM12:	LOAD	SAVNNO,A		; sauve no de note	;LOAD	$LED,A			; affiche	LOAD	HL,#DOM2		; pointe table notes	LOAD	D,#0	LOAD	E,A			; no de note	ADD	HL,DE	ADD	HL,DE	ADD	HL,DE	ADD	HL,DE			; offset->note *4	LOAD	A,(HL)			; lo byte	INC	HL			; point next	LOAD	SAVPER,A		; sauve lo byte	LOAD	A,(HL)			; hi byte	LOAD	SAVPER+1,A		; save hi byte	OR	A,A	IOF				; iof	JUMP,EQ	COMM13			; saute si #0	LOAD	HI,A	LOAD	A,SAVPER	LOAD	LO,A			; charge lo byte	JUMP 	COMM15COMM13:	LOAD	A,SAVPER	COMP	A,#13.	JUMP,HS	COMM14	LOAD	A,#13.COMM14:	LOAD	LO,A			; charge lo byte	LOAD	A,SAVPER+1	LOAD	HI,A			; charge hi byteCOMM15:	ION				; ion	LOAD	A,SAVFIL	OR	A,A			; filter = 0 (auto)	INC	HL			; point filter byte	JUMP,NE	COMM16			; no	LOAD	A,(HL)	LOAD	FIL,A			; write filter	LOAD	FILCRT,A		; sauve fitreCOMM16:	INC	HL			; point vivrato byte	LOAD	A,(HL)			; read it	LOAD	VIBCRT,A		; sauve vibrato reel	JUMP	MLOOP	.SBTTL COMM2;START____________COMMANDE 2___________________________________; met une valeur dans l'envelopeCOMM2:	;NOPCOMM21:	CALL	RDFIFO			; attend vecteur	JUMP,CC	COMM21; test vecteur valide	COMP	A,#65.	JUMP,LO	COMM22	LOAD	A,#64COMM22:	LOAD	HL,#ENVPAR		; table parametres	LOAD	D,#0	LOAD	E,A			; deplacement	ADD	HL,DE			; addresse data	LOAD	A,(HL)			; read data		LOAD	SAVENV,A		; sauve envelope	LOAD	ENV,A	;LOAD	$LED,A			; affiche	JUMP	MLOOP.SBTTL COMM3;START___________COMMANDE 3____________________________________; met une valeur dans filtreCOMM3:	;NOPCOMM31:	CALL	RDFIFO			; attend vecteur	JUMP,CC	COMM31	LOAD	SAVFIL,A		; sauve filtre	OR	A,A	JUMP,EQ	COMM32	LOAD	FIL,A	LOAD	FILCRT,A		; sauve filtre reelCOMM32:	;LOAD	$LED,A			; affiche	JUMP	MLOOP.SBTTL COMM4;START____________COMMANDE 4___________________________________; charge une patterne en ramCOMM4:	;NOPCOMM40:	CALL	RDFIFO			; attend no patterne	JUMP,CC	COMM40	LOAD	B,#RUNLG		; long patterne		LOAD	DE,#RAMT0		; pattern #5	COMP	A,#5	JUMP,EQ	COMM41	LOAD	DE,#RAMT1		; #6	COMP	A,#6	JUMP,EQ	COMM41	LOAD	DE,#RAMT2		; #7	COMP	A,#7	JUMP,EQ COMM41	LOAD	DE,#RAMT3		; #8COMM41:	CALL	RDFIFO			; attend data	JUMP,CC	COMM41	LOAD	(DE),A			; sauve byte	INC	DE	;LOAD	A,B	;LOAD	$LED,A			; affiche solde cycles	DECJ,NE	B,COMM41		; nouveau cycle	JUMP	MLOOP.SBTTL COMM5;START___________COMMANDE 5____________________________________; transfere patterne en ram balayeeCOMM5:	;NOPCOMM51:	CALL	RDFIFO			; attend no de patterne	JUMP,CC	COMM51	;LOAD	$LED,A			; affiche	COMP	A,#PATMAX		; valide?	JUMP,HS	ERR5			; non	LOAD	SAVPAT,A		; sauve patterne crt; cherche l'addresse de la patterne	LOAD 	HL,#PATTAB		; table patternes	LOAD	D,#0	ADD	A,A			; offset no patt*2	LOAD	E,A			; in de offset	ADD	HL,DE			; add in hl	LOAD	E,(HL)			; lo byte	INC	HL	LOAD	D,(HL)			; hi byte	EX	DE,HL			; add pattern in hl	COMM52:	LOAD	DE,#RUN			; transfere en "run"	LOAD	BC,#RUNLG	LDIRCOMM53:	JUMP	MLOOPERR5:	;LOAD	A,#375			; affiche erreur de no	;LOAD	$LED,A	JUMP	COMM53.SBTTL COMM6;START__________COMMANDE 6_____________________________________; glisse de la patterne  run a une nouvelle patterne dans; un temps donne; attend le no de patterneCOMM6:	;NOPCOMM61:	CALL	RDFIFO			; attend no de patterne	JUMP,CC	COMM61	;LOAD	$LED,A	COMP	A,#PATMAX		; data ok	JUMP,HS	ERR6			; no; cherche l'addresse de la patterne	LOAD 	HL,#PATTAB		; table patternes	LOAD	D,#0	ADD	A,A			; offset no patt*2	LOAD	E,A			; in de offset	ADD	HL,DE			; add in hl	LOAD	E,(HL)			; lo byte	INC	HL	LOAD	D,(HL)			; hi byte	EX	DE,HL			; add pattern in hl	COMM62:	LOAD	SAVPAT,A		; sauve no de patterne	LOAD	ADDPAT,HL		; sauve add. patterne; attend le parametre tempsCOMM63:	CALL	RDFIFO			; attend byte temps	JUMP,CC	COMM63	OR	A,A	JUMP,NE COM630	INC	A			; a=1COM630:	LOAD	SAVTPS,A		; sauve temps; calcule les parametres et lance la commande #6; ----------------------------------------------; calcule le nombre de passes a effectuer pour un; step de valeur 1 et le sauve dans savpasCOM640: LOAD	HL,#RUN			; ram balayee	LOAD	DE,ADDPAT		; patterne destination	LOAD	B,#RUNLG		; longueur patt.	XOR	A,A	;LOAD	$LED,A	LOAD	SAVPAS,A		; #0COM641:	;NOP	LOAD	A,(DE)			; read byte	COMP	A,(HL)			; difference	JUMP,EQ	COM644			; a=(hl)	JUMP,LO	COM642			; a<(hl)	;NOP	SUB	A,(HL)			; a>(hl) -> difference	JUMP	COM643COM642:	;NOP	LOAD	C,A			; sauve a	LOAD	A,(HL)			; lit (hl)	SUB	A,C			; difference!!!COM643:	LOAD	C,A			; save a	LOAD	A,SAVPAS		; passages a effectuer	COMP	A,C			; plus de passages?	JUMP,HS COM644			; non	LOAD	A,C	LOAD	SAVPAS,A		; nouvelle valeur	;LOAD	$LED,ACOM644: INC	HL			; adj. pointers	INC	DE	DECJ,NE B,COM641		; end of pass ?	;NOP				; yes; calcule le temps a disposition; formule-> t = savint * 24.COM650:	LOAD	HL,#24.			; milisecondes	LOAD	A,SAVTPS		; interval	CALL	MUL			; temps total "t" in hl	LOAD	SAVT,HL			; sauve hl "t"	;NOP		; calcule le step theorique; formule-> s = (itmin * p1)/tCOM651:	LOAD	A,SAVPAS		; # de passes a step 1	LOAD	HL,#4			; itmin	CALL	MUL	;NOP				; resultat dans hl	EX	DE,HL			; res. in de	LOAD	BC,SAVT			; var. t	CALL	DIV			; calcule step	;NOP				; step dans de; prend le step reelCOM652:	INC 	E			; step 8 bits dans e	LOAD	A,E	LOAD	SAVSTP,A		; sauve val. step; calcul l'interval de temps reel; formule: it = (t * s)/p1 COM653:	LOAD	HL,SAVT			; temps passage	LOAD	A,SAVSTP		; step	CALL	MUL	;NOP				; resultat in hl		EX	DE,HL			; res. in de	LOAD	B,#0	LOAD	A,SAVPAS	LOAD	C,A			; p1 in bc	CALL	DIV	LOAD	SAVINT,DE		; sauve dans savint	;NOP				; it in de; lance la commande #6; --------------------	LOAD	HL,SAVINT		; interval it	LOAD	COM6CT,HL		; initialise compt. it	XOR	A,A	LOAD	COM6FL,A		; clear flag passe	LOAD	A,#201	LOAD	$CTC0,A			; set timer ion	CALL	COM680			; effectue 1ere passe	JUMP	MLOOP			; retour au main; COM680 / call; -------------; glisse de la patterne run a la patterne destination; par increments de valeur "step" et tue la tache lors; de la derniere passe; initialiseCOM680:	PUSH	AF			; sauve les registres	PUSH	BC	PUSH	DE	PUSH	HL	XOR	A,A	LOAD	COM6FL,A		; clear flag passe	LOAD	IX,#SAVFLG		; flag fini	LOAD	(IX),#0	LOAD	HL,ADDPAT		; add patterne dest.	LOAD	DE,#RUN			; add. run	LOAD	B,#RUNLG	LOAD	A,SAVSTP		; step	LOAD	C,A; teste run<>= destinationCOM681:	PUSH	BC	LOAD	A,(DE)			; a=run	LOAD	B,(HL)			; b=dest	COMP	A,B	JUMP,EQ	COM685			; next	LOAD	(IX),#377	JUMP,LO	COM683			; run < que dest.; run > que destinationCOM682:	SUB	A,B			; run >	COMP	A,C			; diff > step ?	JUMP,LO	COM684			; non -> egalise	LOAD	A,(DE)			; lit run	SUB	A,C			; run - step	LOAD	(DE),A			; ajuste run	JUMP	COM685			; next byte; run < que destinationCOM683:	LOAD	B,A			; run dans b	LOAD	A,(HL)			; dest. dans a	SUB	A,B	COMP	A,C			; diff > que step ?	JUMP,LO	COM684			; non -> egalise	LOAD	A,B			; run dans a	ADD	A,C			; run + step	LOAD	(DE),A			; ajuste run	JUMP	COM685			; next byte; diff.run/dest < step -> egaliseCOM684:	LOAD	A,(HL)			; lit destination	LOAD	(DE),A			; ajuste run; teste si fin du passage	COM685:	POP	BC	INC	HL	INC	DE	DECJ,NE	B,COM681			; next byte; fin de com680 ?	LOAD	A,(IX)	OR	A,A			; derniere passe ?	;LOAD	$LED,A	JUMP,NE COM686			; non-> retour cc	LOAD	A,#1			; met ctc iof	LOAD	$CTC0,A	XOR	A,A	LOAD	COM6FL,A		; clear flag passeCOM686: POP	HL			; restitue les registres	POP	DE	POP	BC	POP	AF	RET				; end of comm6ERR6:	;LOAD	A,#376	;LOAD	$LED,A	JUMP	MLOOP.SBTTL COMM7	;START_________COMMANDE 7______________________________________; ecrit une note de priode .../...COMM7:	;NOPCOMM71:	CALL	RDFIFO			; attend lo byte	JUMP,CC	COMM71	LOAD	SAVPER,A		; sauve data lo	;LOAD	$LED,A		COMM72:	CALL	RDFIFO			; attend hi byte	JUMP,CC	COMM72	LOAD	SAVPER+1,A		; save data hi	;LOAD	$LED,A	OR	A,A	IOF				; iof	JUMP,EQ	COMM73			; saute si #0	LOAD	HI,A	LOAD	A,SAVPER	LOAD	LO,A			; charge lo byte	JUMP 	MLOOPCOMM73:	LOAD	A,SAVPER	COMP	A,#13.	JUMP,HS	COMM74	LOAD	A,#20COMM74:	LOAD	LO,A			; charge lo byte	LOAD	A,SAVPER+1	LOAD	HI,A			; charge hi byte	ION				; ion	JUMP	MLOOP.SBTTL COMM8;START__________COMMANDE 8_____________________________________; joue un vibrato d'amplitude +/-8 (8=1/2 ton)COMM8:	;NOPCOMM81:	CALL	RDFIFO			; attend vibrato	JUMP,CC	COMM81	OR	A,A			; vibrato arrive	JUMP,EQ	COMM84			; c'est #0	COMP	A,#9.	JUMP,LO	COMM82			; c'est positif	COMP	A,#-8.	JUMP,HS	COMM83			; c'est negatif	JUMP	ERR8; vibrato positifCOMM82:	;NOP	LOAD	VIBPDS,A		; sauve poids vib.	CALL	COM8V1			; calcule vibrato	LOAD	HL,SAVPER		; periode	OR	A,A			; carry clear	SUBC	HL,DE			; + vibrato	LOAD	SAVPEV,HL		; sauve periode vib.	JUMP	COMM85; vibrato negatifCOMM83:	;NOP	LOAD	B,A	LOAD	A,#0	SUB	A,B			; val. absolue vib.	LOAD	VIBPDS,A		; sauve poids vib.	CALL	COM8V1			; calcule vib.	LOAD	HL,SAVPER	ADD	HL,DE	LOAD	SAVPEV,HL		; sauve periode vib.	JUMP	COMM85; vibrato nulCOMM84:	;NOP	LOAD	HL,SAVPER	LOAD	SAVPEV,HL		; sauve periode vib.; ecrit la nouvelle periodeCOMM85:	;NOP	LOAD	A,SAVPEV+1		; hi byte periode	OR	A,A	JUMP,EQ	COMM86			; saute si #0	IOF	LOAD	HI,A	LOAD	A,SAVPEV	LOAD	LO,A			; charge lo byte	JUMP 	COMM88COMM86:	;NOP	LOAD	A,SAVPEV	COMP	A,#13.	JUMP,HS	COMM87	LOAD	A,#13.COMM87:	LOAD	LO,A			; charge lo byte	LOAD	A,SAVPEV+1	LOAD	HI,A			; charge hi byteCOMM88:	ION	JUMP 	MLOOP			; ret to main; calcule la nouvelle periode en fonction du vibratoCOM8V1:	;NOP	LOAD	A,VIBCRT		; read vibrato	LOAD	HL,#0	LOAD	D,#0	LOAD	E,A			; init de	LOAD	A,VIBPDS		; poids vib.	LOAD	B,A			; init compteurCOM8V2:	ADD	HL,DE	DECJ,NE	B,COM8V2		; add. poids initial	;NOP	SRC	H			; divise par 2	RRC	L	EX	DE,HL	;NOP	RET				; vibrato in deERR8:	JUMP	MLOOP.SBTTL COMM9;START__________COMMANDE 9_____________________________________; repond present  l'appelCOMM9:	LOAD	A,#376			; bit #0 clear	LOAD	$PIBD,A			; write into pio	LOAD	A,#17			; output mode	LOAD 	$PIBC,A			; set data in output	CALL	DELY			; O,1 sec	LOAD	A,#117			; input mode	LOAD	$PIBC,A			; return input mode	JUMP 	MLOOPDELY:	LOAD 	BC,#17000		; delais 50 milisec.DELY1:	DEC	BC	LOAD	A,B	OR	A,C	JUMP,NE	DELY1	RET.SBTTL COMM10;START_________COMM10__________________________________________; incremente de 1 toute la patterneCOMM10:	LOAD	HL,#RUN	LOAD	B,#RUNLGCOM101: INC	(HL)	INC	HL	DECJ,NE	B,COM101	JUMP	MLOOP.SBTTL TABLES;START_________TABLES__________________________________________; table des addresses des patternesPATTAB:	.W	SINET,RAMPT,PENTT,SQUAT,TRIAT	.W	RAMT0,RAMT1,RAMT2,RAMT3.SBTTL GENERAL;START________GENERAL__________________________________________ERR:	;LOAD	A,#370	;LOAD	$LED,A	JUMP	MLOOPINIT:	LOAD	A,#IVTAB/400	LOAD	I,A	LOAD	A,#3			; ctc channel reset	LOAD	$CTC0,A			; reset all four ch.	LOAD	$CTC1,A	LOAD	$CTC2,A	LOAD	$CTC3,A	LOAD	A,#CTCIV&376	LOAD	$CTC0,A			; ctc int. vector	LOAD	A,#5			; tim. pres.16 load tc.	LOAD	$CTC0,A			; ctc iof	LOAD	A,#230.			; time constant	LOAD	$CTC0,A			; timer 1 milisec	LOAD	A,#117	LOAD	$PIAC,A			; input mode	LOAD	A,#PIOIV&376	LOAD	$PIAC,A			; pio int vector	LOAD	A,#207	LOAD	$PIAC,A			; int enable	CALL 	INIFIFO			; vide fifo	RETI				; clear iei/ieo ;--------\ ; INIFIFO >;========/; Vide compltement le fifo.; in	-; out	-; mod	HLINIFIFO:	IOF	LOAD	HL,#FIFO	; HL <-- ^dbut du fifo	LOAD	HEAD,HL		; init ^tte	LOAD	TAIL,HL		; init ^queue	ION	RET;**********; RDFIFO  *;**********; Lit un caractre du fifo. Si celui-ci est vide, revient CC; et ne lit rien.; ATTENTION: pour tre plus rapide, la condition CC/CS est; inverse par rapport  la logique standard (CS=ok) !; in	-; out	CS	ok;	 A	byte lu;	CC	fifo vide;	 A	n'importe quoi; mod	AF,HLRDFIFO:	IOF			; trs important ...	LOAD	HL,TAIL		; HL <-- ^queue	LOAD	A,HEAD		; A  <-- ^tte (low byte)	COMP	A,L		; ^tte = ^queue ?	JUMP.,EQ 90$		; oui => retour CC	LOAD	A,(HL)		; A  <-- byte lu	INC	L		; avance le ^queue	LOAD	TAIL,HL		; met  jour le ^queue	SETC			; retour CS	ION	RET90$:	ION	LOAD	A,COM6FL	; flag passe a faire	OR	A,A	CALL,NE	COM680		; oui	OR	A,A		; carry clear	RET			; end rdfifo;*******; DIV  *;*******;;; division 16 bits par 16 bits;; input  de->nombre;	 bc-> diviseur; output de->resultat;	 hl-> resteDIV:	LOAD	HL,#0DPDIV:	LOAD	A,#16.DIV2:	SETC	RLC	E	RLC	D	RLC	L	RLC	H	RET,CS	SUBC	HL,BC	JUMP.,HS DIV4	ADD	HL,BC	CLR	E:0DIV4:	DEC	A	JUMP,NE	DIV2	OR	A,A	RET;*******; MUL  *;*******;; multiplication 16 bits par 8 bits dans 24 bits;; input:  hl -> premier nombre; 	  a  -> deuxieme nombre; output: hl -> lo bytes; 	  a  -> hi byteMUL:	LOAD	B,#8.	EX	DE,HL	LOAD	HL,#0MUL1:	ADD	HL,HL	RLC	A	JUMP,CC	MUL2	ADD	HL,DE	ADDC	A,#0MUL2:	DECJ,NE	B,MUL1	RET; routines d'interruptions.ALIGN 100IVTAB:CTCIV:	.W	CT0ISR	.W	CT0ISR	.W	CT0ISR	.W	CT0ISRPIOIV:	.W	PIAISR; lit le byte et ecrit dans le fifo si pas plein; Teste si le fifo est plein.PIAISR:	;NOP	EX	AF		; Block #1	EX	BL	LOAD	HL,HEAD		; HL <-- ^tte	LOAD	A,TAIL		; A  <-- ^queue (low byte)	DEC	A	COMP	A,L		; retour EQ si plein	JUMP,EQ	PIAIS1		; retour direct	LOAD	A,$PIAD		; Read PIO	LOAD	(HL),A		; met le byte dans le fifo	INC	L		; avance le ^tte	LOAD	HEAD,HL		; met  jour le ^tte	EX	AF		; Block #0	EX	BL	ION	RETIPIAIS1:	LOAD	A,$PIAD		; Read PIO	EX	AF		; Block #0	EX	BL	ION	RETICT0ISR: PUSH	AF	PUSH	HL	LOAD	HL,COM6CT	; lit compteur it	DEC	HL	LOAD	A,H	OR	A,L		; vaut 0 ?	JUMP,EQ	CT0IS1		; oui	LOAD	COM6CT,HL	; non->ajuste compt.	POP	HL	POP	AF	ION 	RETICT0IS1:	LOAD	HL,SAVINT	; interval it	LOAD	COM6CT,HL	; charge compteur	LOAD	A,#377	LOAD	COM6FL,A	; flag passe a faire	POP	HL	POP	AF	ION	RETI.END