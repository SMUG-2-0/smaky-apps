.TITLE BIDON.PROC Z80.LINES 60..OCT.RDX 8.; PROGRAMME DE TEST ET MODELE DES PERIPHERIQUES Z80; POUR DANIEL ROUX (MIDI); BIENNE, LE 07.06.86  R. CARPI;	SWITCH POUR ASSEMBLAGE;	----------------------	EPROM	= 0.IF	EPROM;	MEMORY AREAS;	------------	ROMM		= 0	IVTAB		= ROMM+10	RAMM		= 40200	STACK		= 40777	FIFBEG  	= 41001	FIFEND		= 43776.ELSE;	MEMORY AREAS;	------------	ROMM		= 41000	IVTAB		= ROMM+10	RAMM		= 43000	STACK		= 43777	FIFBEG  	= 43200	FIFEND		= 43500.ENDIF.SBTTL	Definitions;	MEMORY SAVE POSITION;	--------------------	DUMMY	= RAMM	TFIN	= DUMMY+2;	PROGRAMM CONSTANT;	-----------------	FLGON	= 377	FLGOFF	= 000.LIST 0	; 	SIO address	SIO   = 300	; SIO Base add.	SIAD  = SIO	; Ch. A Data	SIBD  = SIAD+1	; Ch. B Data	SIAC  = SIBD+1	; Ch. A Control	SIBC  = SIAC+1  ; Ch. B Control; 	PIO  address	PIO   = 314	PIAD  = PIO+0	; PIO 1 A data	PIAC  = PIO+2	; PIO 1 A command	PIBD  = PIO+1	; PIO 1 B data	PIBC  = PIO+3	; PIO 1 B command		; PIO CARTE PER	PPIO   = 310	PPIAD  = PPIO+0	; PPIO 1 A data	PPIAC  = PPIO+2	; PPIO 1 A command	PPIBD  = PPIO+1	; PPIO 1 B data	PPIBC  = PPIO+3	; PPIO 1 B command; 	CTC address		CTC   = 304	; CTC per.adr.	CTC0  = CTC+0	; CTC channel 0	CTC1  = CTC+1	; CTC channel 1	CTC2  = CTC+2	; CTC channel 2	CTC3  = CTC+3	; CTC channel 3; 	Console address	CONSOLE	= 200		; DISPLAY BASE ADRESS	SW	= CONSOLE+2	; DATA SW (READ)	LED	= SW		; DATA LED (WRITE);; 	Definition of the Z80 peripherals; 	PIO definition	PINPMD = 117	; Input mode	POUTMD = 017	; Output mode	PBIDMD = 217	; Bidirectional mode	PCTRMD = 317	; Control mode		PINTEN = 207	; Interrupt enable	PINTDS = 007	; Interrupt disable	PAND   = 107	; AND function	POR    = 007	; OR function	PHIGH  = 047	; Active high	PLOW   = 007	; Active low	PMFOL  = 027	; Mask follow	PRPINT = 027	; Reset pending int..LOC	ROMM	START:	IOF	IM2	JUMP MAIN; /INIT/INIT:	LOAD	A,#IVTAB/400	LOAD	I,A		; load high IV	LOAD	HL,#PTAB0	CALL	EXCIT	RETI; PIO POUR EXEMPLEPTAB0:	.B      PIAD,1	.B	377	.B	PIAC,3	.B	PCTRMD,000,PINTDS	; all outputs	.B   	PIBD,1	.B	0	.B	PIBC,3	.B	PCTRMD,000,PINTDS	; all inputs	.B	PPIAC,3	.B	PCTRMD,377,PINTDS	; all outputs	.B	PPIBD,1	.B	252	.B	PPIBC,3	.B	PCTRMD,000,PINTDS	; all inputs	.B	0	; Execute a peripheral instruction table; HL= table ptr. A=modifiedEXCIT:	PUSH	BCEXCT1:	LOAD	C,(HL)	; per.adr.	INC	HL	LOAD	B,(HL)	; # of I/O	INC	HL	; HL -> first I/O	OUTIR	LOAD	A,(HL)	OR	A,A	; last per?	JUMP.,NE EXCT1	; no	POP	BC	RET; end of ROUTINES D'INITIALISATION; MAINMAIN:	LOAD	SP,#STACK	CALL	INITMAIN1:	CALL	IFRDY	LOAD	A,#0	LOAD	$PIBD,A	CALL	STR		CALL	IFRDY	LOAD	A,#1	LOAD	$PIBD,A	CALL	STR		CALL	IFRDY	LOAD	A,#24.	LOAD	$PIBD,A	CALL	STR	CALL	IFRDY	LOAD	A,#0	LOAD	$PIBD,A	CALL	STR		.B	367	CALL	IFRDY	LOAD	A,#1	LOAD	$PIBD,A	CALL	STR		CALL	IFRDY	LOAD	A,#36.	LOAD	$PIBD,A	CALL	STR	.B	367	JUMP	MAIN1	STR:	XOR	A,A	LOAD	$PIAD,A	DEC	A	LOAD	$PIAD,A	RET	IFRDY:	LOAD 	B,#010$:	INC	B	LOAD	A,$PPIAD	TEST	A:7	JUMP,NE	10$	LOAD	A,B	LOAD	$PPIBD,A	RET.END