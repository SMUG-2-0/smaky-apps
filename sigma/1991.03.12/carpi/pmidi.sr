.TITLE PMIDI.SR.PROC Z80.LINES 60..OCT.RDX 8.; PROGRAMME DE TEST ET MODELE DES PERIPHERIQUES Z80; POUR DANIEL ROUX (MIDI); BIENNE, LE 07.06.86  R. CARPI;	SWITCH POUR ASSEMBLAGE;	----------------------	EPROM	= 0.IF	EPROM;	MEMORY AREAS;	------------	ROMM		= 0	IVTAB		= ROMM+10	RAMM		= 40200	STACK		= 40777	FIFBEG  	= 41001	FIFEND		= 43776.ELSE;	MEMORY AREAS;	------------	ROMM		= 40100	IVTAB		= ROMM+10	RAMM		= 43000	STACK		= 43777	FIFBEG  	= 43200	FIFEND		= 43500.ENDIF.SBTTL	Definitions;	MEMORY SAVE POSITION;	--------------------	DUMMY	= RAMM	TFIN	= DUMMY+2;	PROGRAMM CONSTANT;	-----------------	FLGON	= 377	FLGOFF	= 000.LIST 0	; 	SIO address	SIO   = 300	; SIO Base add.	SIAD  = SIO	; Ch. A Data	SIBD  = SIAD+1	; Ch. B Data	SIAC  = SIBD+1	; Ch. A Control	SIBC  = SIAC+1  ; Ch. B Control; 	PIO  address	PIO   = 314	PIAD  = PIO+0	; PIO 1 A data	PIAC  = PIO+2	; PIO 1 A command	PIBD  = PIO+1	; PIO 1 B data	PIBC  = PIO+3	; PIO 1 B command; 	CTC address		CTC   = 304	; CTC per.adr.	CTC0  = CTC+0	; CTC channel 0	CTC1  = CTC+1	; CTC channel 1	CTC2  = CTC+2	; CTC channel 2	CTC3  = CTC+3	; CTC channel 3; 	Console address	CONSOLE	= 200		; DISPLAY BASE ADRESS	SW	= CONSOLE+2	; DATA SW (READ)	LED	= SW		; DATA LED (WRITE);; 	Definition of the Z80 peripherals; 	PIO definition	PINPMD = 117	; Input mode	POUTMD = 017	; Output mode	PBIDMD = 217	; Bidirectional mode	PCTRMD = 317	; Control mode		PINTEN = 207	; Interrupt enable	PINTDS = 007	; Interrupt disable	PAND   = 107	; AND function	POR    = 007	; OR function	PHIGH  = 047	; Active high	PLOW   = 007	; Active low	PMFOL  = 027	; Mask follow	PRPINT = 027	; Reset pending int.; 	CTC definition	CINTDS = 001	; Interrupt disable	CINTEN = 201	; Interrupt enable	CNTMD  = 101	; Counter mode	CTMD   = 001	; Timer mode	CP256  = 041	; Prescaler factor = 256	CP016  = 001	; Prescaler factor = 16	CPSLP  = 021	; Positive edge	CNSLP  = 001	; Negative edge	CEXTR  = 011	; External trigger	CNXTR  = 001	; No external trigger	CLDCS  = 005	; Load time constant	CRSET  = 003	; Reset;	SIO definition; write register 0	R0    = 0	RSEXI = 20	; RESET EXTERNAL INTERRUPTS	RSCHL = 30	; RESET CHANNEL	RSRCVI= 40	; RESET RECEIVER INTERRUPTS	RSTBMT= 50	; RESET XMIT BUFFER EMPTY INT.	RSEROR= 60	; RESET ERROR	RETIA = 70	; RETURN FROM INT. (CH. A ONLY); write register 1 (interrupt control)	R1     = 1	EXTIE  = 1	; EXT INT. ENABLE (DCD,CTS)	TRSIE  = 2	; XMIT INTERRUPT ENABLE	STAVEC = 4	; STATUS AFECTS VECTOR	RIDIS  = 0	; RCV. INTERRUPT DISABLE	RCVIM1 = 10	; INT. ON FIRST CHAR.	RCVIM2 = 20	; ALL CHAR. INT (WITH PAR. AFF. VEC)	RCVIM3 = 30	;  "   "     " (WITHOUT "   "    " ); write register 2 loaded only into channel B	R2     = 2; = INTERRUPT VECTOR; write register 3 (xrcv mode only)	R3    = 3	RX5B  = 0	; 5 BITS/CHAR.	RX6B  = 200	; 6 BITS/CHAR.	RX7B  = 100	; 7 BITS/CHAR.	RX8B  = 300	; 8 BITS/CHAR. 	AUTEN = 40	; ENABLE CONTROL OF DCD AND CTS	RCVEN = 1	; RECEIVER ENABLE; write register 4 (xmit/xrcv mode)	R4     = 4	X1     = 0	; DIVIDE CLOCK BY 1	X16    = 100	;    "     "   "  16	X32    = 200	;    "     "   "  32	X64    = 300	;    "     "    " 64	SB1    = 4	; NUMBER OF STOP BITS 1	SB15   = 10	;   "    "    "   "   1.5	SB2    = 14	;   "    "    "   "   2	SYNCMD = 0	; SYNCHRONOUS MODE	PAREN  = 1	; PARITY ENABLE	PEVEN  = 2	; PARITY EVEN; write register 5 (xmit mode only)	R5     = 5	TX5B   = 0	; 5 BITS/CHAR.	TX6B   = 100	; 6 BITS/CHAR.	TX7B   = 40	; 7 BITS/CHAR.	TX8B   = 140	; 8 BITS/CHAR.	RTS    = 2	; RTS CONTROL	TRSEN  = 10	; TRANSMITTER ENABLE	DTR    = 200	; DTR CONTROL; write register 6 (used for synchronous mode only);   "	   "	 7 (  "	  "	"	  "	" ).LIST 1.LOC	ROMM	START:	IOF	IM2	JUMP MAIN.LOC	IVTAB; Interrupt service routines address tableCTCIV:	.W	CISR0	.W	CISR1	.W	CISR2	.W	CISR3.ALIGN 20SIOIV:	.W	SBISR1	.W	SBISR2	.W	SBISR3	.W	SBISR4	.W	SAISR1	.W	SAISR2	.W	SAISR3	.W	SAISR4; Interrupt service routines for SIO; REGISTRE DE SORTIE VIDE ; NOTE POUR DANIEL: aprs l'envoi d'un caractre le SIO gnre;		    continuellement des interrupts jusqu' ;		    l'criture d'un nouveau caractre dans le;		    registre de sortie (SIBD). Lorsque le der-;		    nier caractre  t envoy il faut reseter;		    l'interrupt dans le registre #0 du SIO.		    SBISR1:	PUSH	AF	NOP	LOAD	A,DUMMY	SRC	A	LOAD	DUMMY,A	LOAD	$SIBD,A		; NOUVEAU DATA	OR	A,A	JUMP,NE	SBIS10	LOAD	A,#RSTBMT	LOAD	$SIBC,ASBIS10:	POP	AF	ION	RETISBISR2:	NOP	ION	RETI; RECU CARACTERE ; LIT ET AFFICHE SUR LES LEDSBISR3:	NOP	PUSH	AF	LOAD	A,$SIBD		; LIT SIO	AND	A,#177	LOAD	$LED,A		; ENVOIE AUX LEDS	OR	A,A	JUMP,NE	SBIS31	LOAD	A,#FLGON	LOAD	TFIN,ASBIS31:	POP	AF	ION	RETISBISR4:	NOP	ION	RETISAISR1:	NOP	ION	RETISAISR2:	NOP	ION	RETISAISR3:	NOP	ION	RETISAISR4:	NOP	ION	RETICISR0:	NOP	ION	RETICISR1:	NOP	ION	RETICISR2:	NOP	ION	RETICISR3:	NOP	ION	RETI; /INIT/INIT:	LOAD	A,#IVTAB/400	LOAD	I,A		; load high IV	LOAD	HL,#CTAB0	CALL	EXCIT		; init CTC	LOAD	A,#377	LOAD	$PIAD,A		; all bits to 1	LOAD	HL,#PTAB0	CALL	EXCIT	LOAD	HL,#STAB0	CALL	EXCIT	ION	RETI; POUR EXEMPLE!!! (NON UTILIS); INITIALISE LE CTC CANAL 0 POUR VECTEUR D'INTERRUPT; ET CANAL 2 POUR BAUDRATE ; QUARZ 3.6864Mhz 2400=1536->prescaler*SIO=16*16, diviseur=6CTAB0:	.B	CTC0,1	.B	CTCIV&370	.B	CTC2,2	.B	CINTDS!CTMD!CNSLP!CP016!CLDCS!CRSET	.B	255.	.B	0; PIO POUR EXEMPLE (NON UTILISPTAB0:	.B	PIAC,3	.B	PCTRMD,000,PINTDS	; all outputs	.B	PIBC,3	.B	PCTRMD,377,PINTDS	; all inputs	.B	0; INITIALISE SIO; BAUDRATE= 4Mhz/31250=128/div 8=16->X16STAB0:	.B	SIBC,L2-L1L1:	.B	R0,RSCHL	.B	R2,SIOIV&376	.B	R1,STAVEC!RCVIM2!TRSIE	.B	R4,X16!SB1		; NO PARITY	.B	R3,RX7B!RCVEN	.B	R5,TX7B!TRSENL2:	.B	0	; Execute a peripheral instruction table; HL= table ptr. A=modifiedEXCIT:	PUSH	BCEXCT1:	LOAD	C,(HL)	; per.adr.	INC	HL	LOAD	B,(HL)	; # of I/O	INC	HL	; HL -> first I/O	OUTIR	LOAD	A,(HL)	OR	A,A	; last per?	JUMP.,NE EXCT1	; no	POP	BC	RET; end of ROUTINES D'INITIALISATION; MAIN; POUR DANIEL; TESTE LA TRANSMISSION EN ENVOYANT UN BYTE INITIAL "377"; LA ROUT. D'INTERRUPT EN SORTIE "SRC" LE BYTE ET LE RENVOIE; TANT QU,IL NE VAUT PAS ZERO.; LA ROUTINE D'INT. EN ENTREE ENVOIE LA VALEUR SUR LES LEDSMAIN:	LOAD	SP,#STACK	CALL	INIT	LOAD	A,#FLGOFF	LOAD	TFIN,A	LOAD	A,#252	LOAD	$LED,A	LOAD	A,#377	LOAD	DUMMY,A	LOAD	$SIBD,AMAIN1:	LOAD	A,TFIN	OR	A,A	JUMP,EQ	MAIN1	.B	367			; (TRAP POUR DBG)	JUMP	MAIN.END