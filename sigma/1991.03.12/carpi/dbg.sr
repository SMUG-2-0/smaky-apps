; PROGRAMME DE DEBUG POUR RCB MP1 (SMACKY RAM 64K); DEBUGGER	A.DROZ	5.26.79/1.6.81/3.1.82	.TITLE	DBG	.PROC	Z80	.REF	FLO	DBGADR = 25000	.LOC	DBGADR+200; VALEURS DE CERTAINES ADRESSES DANS LE; MONITEUR.;	LAMODI	= 42577	SAVMODI	= 42511	SAVHEX	= 42512	SAVI	= 42453	SAVLOP	= 42504	SC134   = 7750; POSITIONS MEMOIRES DE L'ESCLAVE	BRAM	= 40000		; DEBUT RAM BANK 0 ESCLAVE	?SAVPC	= BRAM+30	?SAVSP	= BRAM+32	?MONSAV	= BRAM+3; POSITIONS MEMOIRES DU MAITRE	STACK	= DBGADR+200	ADDEB   = DBGADR	ADFIN	= ADDEB+2	ADLOD	= ADFIN+2	IPERAD	= ADLOD+2	OPERAD	= IPERAD+1; ! ATTENTION: 	SIMSER SIMULE L'ENVOI D'UN CARACTERE;	       	A L'ENCLENCHEMENT OU AU DECLENCHEMENT;		DE LA TENSION D'ALIMENTATION DE L'ESCLAVE.DBGST:	LOAD	SP,#STACK	; real start adr.	LOAD	A,LAMODI	; for debugger	LOAD	SAVMODI,A	LOAD	HL,#DBGST	; when NMI then goto	.W	?IADNMI		; DGBST.	LOAD	BC,#20.+0*400	.W	?IDICAR	.W	?CLEAR	.W	?IALPHA	LOAD	A,#'*	.W	?IPOINTER	XOR	A,A	LOAD	SAVHEX,A	.W	?BUZZ	LOAD	HL,#TXDBG	.W	?DITEXZDEB2:	IOF	LOAD	HL,#SAVMODI	SET	(HL):0	.W	?RETURNDEB3:	.W	?INMON	LOAD	DE,#OTABLE	.W	?JUMPCAR	JUMP	ERR1; N'EST PAS DANS OTABLE, ALORS C'EST; PEUT-ETRE UN REGISTREMODREG:	.W	?DEL	.W	?TEXTIM	.ASCIZ	/REG: /	LOAD	BC,#0*400+SPACE	LOAD	DE,#(SPACE+1)*400+400-1	.W	?GETLBCDE		; LIT LE NOM DU REG.	PUSH	HL	LOAD	E,#(EREGTB-REGTAB)/7	LOAD	IX,#REGTAB	PUSH	IXMODRE1:	LOAD	B,#4MODRE2:	LOAD	A,(IX)	INC	IX	COMP	A,(HL)	INC	HL	JUMP.,NE MODRE3	OR	A,A		; FIN CHAINE A CHERCHER ?	JUMP.,EQ MODRE4		; OUI...YOUPPIYE	DECJ,NE B,MODRE2	; 4 BYTES COMPARE ?	POP	HL	POP	HL		; CORRIGE STACK	JUMP	ERROR		; OUI -> COUILLONMODRE3:	POP	IX	POP	HL	DEC	E		; FIN TABLE ?	JUMP,EQ	ERR1		; OUI -> N'EXISTE PAS	LOAD	BC,#7	ADD	IX,BC	PUSH	HL	PUSH	IX	JUMP.	MODRE1MODRE4:	POP	IX	POP	HL	.W	?INMON		; LIT LA NOUVELLE VALEUR	COMP	A,#15	JUMP,NE	ERROR	LOAD	C,(IX)+4	LOAD	B,(IX)+5	; BC = ADR. REG. DANS ESCLAVE	LOAD	E,(IX)+6	; E = NB. OCTETS DANS REG.	LOAD	A,L	CALL	WRITE	; MODIFIE LOW BYTE	DEC	E	JUMP,EQ	AFREG	LOAD	A,H	INC	BC	CALL	WRITE	; MODIFIE HIGH BYTE	JUMP	AFREGERROR:	LOAD	HL,#TERROR	JUMP.	ERR2ERR1:	LOAD	HL,#TERR1ERR2:	.W	?DITEXZ	JUMP	DEB3TERROR:	.ASCIZ	/ ERRONEOUS DATA -> STUPID OPERATOR<15>/TERR1:	.ASCIZ	/ DOES NOT EXIST<15>/TXDBG:	.ASCIZ	/DEBUG 1-1    January 3. 1982    hny/OTABLE:	.BW	' ,DOSE		; SEPARATOR	.BW	'\,DOPE		; OPEN	.BW	15,DOCR		; CLOSE	.BW	'],DONEXT	; NEXT	.BW	'[,DOPREV	; PREVIOUS	.BW	'G,DOG		; GO	.BW	'K,DOG2		; CONTINUE	.BW	'I,DOINP	; INPUT FROM A PERIPHERAL	.BW	'O,DOOUT	; OUTPUT TO A PERIPHERAL	.BW	'R,AFREG	; DISPLAY REGISTERS	.BW	'E,MODREG	; MODIFY A REGISTER	.BW	'Z,SMILE	.BW	'N,RSYS	.BW	'M,DOMOV	.B	0REGTAB:	.ASCII	/IY<0><0>/	.WB	BRAM+4,2	.ASCII	/IX<0><0>/	.WB	BRAM+6,2	.ASCII	/HL'<0>/	.WB	BRAM+10,2	.ASCII	/DE'<0>/	.WB	BRAM+12,2	.ASCII	/BC'<0>/	.WB	BRAM+14,2	.ASCII	/HL<0><0>/	.WB	BRAM+20,2	.ASCII	/DE<0><0>/	.WB	BRAM+22,2	.ASCII	/BC<0><0>/	.WB	BRAM+24,2	.ASCII	/SP<0><0>/	.WB	BRAM+32,2	.ASCII	/A'<0><0>/	.WB	BRAM+17,1	.ASCII	/F'<0><0>/	.WB	BRAM+16,1	.ASCII	/B'<0><0>/	.WB	BRAM+15,1 	.ASCII	/C'<0><0>/	.WB	BRAM+14,1	.ASCII	/D'<0><0>/	.WB	BRAM+13,1	.ASCII	/E'<0><0>/	.WB	BRAM+12,1	.ASCII	/H'<0><0>/	.WB	BRAM+11,1	.ASCII	/L'<0><0>/	.WB	BRAM+10,1	.ASCII	/A<0><0><0>/	.WB	BRAM+27,1	.ASCII	/F<0><0><0>/	.WB	BRAM+26,1	.ASCII	/B<0><0><0>/	.WB	BRAM+25,1	.ASCII	/C<0><0><0>/	.WB	BRAM+24,1	.ASCII	/D<0><0><0>/	.WB	BRAM+23,1	.ASCII	/E<0><0><0>/	.WB	BRAM+22,1	.ASCII	/H<0><0><0>/	.WB	BRAM+21,1	.ASCII	/L<0><0><0>/	.WB	BRAM+20,1	.ASCII	/I<0><0><0>/	.WB	BRAM+3,1EREGTB:; TRAITE LA COMMANDE SEPARATEURDOSE:	PUSH	HL		; SAUVE 1ER NB.	.W	?INMON	POP	DE		; 1ER NB. DANS DE	COMP	A,#'O		; EST-CE UN ENVOI VERS PERIPHR.	JUMP,EQ	DOOUT1	COMP	A,#' 		; EST-CE UN SEP.	JUMP,NE ERROR		; NON, ERREUR	PUSH	HL		; SAUVE LE 2EME	.W	?INMON		; LIT LE 3EME	LOAD	B,H	LOAD	C,L		; 3EME NB. DANS BC	POP	HL		; 2EME NB. DANS HL	COMP	A,#'T		; TRANSFERT ?	JUMP,EQ	DOTRANS		; OUI EFFECTUER UN TRANSFERT	COMP	A,#'M		; EST UN MOVE ?	JUMP,NE	ERROR		; NON, ERREUR	LOAD	ADDEB,DE	; SAUVE PARAMETRES...	LOAD	ADFIN,HL	; POUR LE PROCHAIN...	LOAD	ADLOD,BC	; MOVE.DOMOV1:	LOAD	DE,ADDEB	LOAD	HL,ADFIN	LOAD	BC,ADLOD	LOAD	A,B	OR	A,C	JUMP,EQ	ERROR	OR	A,A		; CARRY=0	SUBC	HL,DE		; HL>=DE ?	JUMP,LO	ERROR		; OUI, MAUVAISES DONNEES	JUMP,EQ ERROR	LOAD	A,#3	.W	?WPP		; <3> = COMMAND WRITE	XOR	A,A	.W	?WPP		; <0>	LOAD	A,C	.W	?WPP		; <LOW ADR>	LOAD	A,B	.W	?WPP		; <HIGH ADR>	LOAD	A,L	.W	?WPP		; <LOW BYTE COUNT>	LOAD	A,H	.W	?WPP		; <HIGH BYTE COUNT>DOMOV2:	LOAD	A,(DE)	INC	DE	.W	?WPP		; ECRIT UN BYTE...	DEC	HL		; CHEZ L'ESCLAVE	LOAD	A,H	OR	A,L		; ENCORE ?	JUMP.,NE DOMOV2		; OUI	JUMP.	NEXTLIDOMOV:	LOAD	HL,#0	.W	?GETCURS	; AFFICHONS	LOAD	L,#0	.W	?SETCURS	; POINTEUR AU DEBUT LIGNE	LOAD	HL,ADDEB	.W	?AFOHL		; AFF. ADR. DEBUT DU MOVE	.W	?SPACE	LOAD	HL,ADFIN	.W	?AFOHL		; AFF. ADR. FIN DU MOVE	.W	?SPACE	LOAD	HL,ADLOD	.W	?AFOHL		; AFF. ADR. DEST. DU MOVE	.W	?SPACE	LOAD	A,#'M	.W	?DICAR	LOAD	A,C	OR	A,A		; M SEULEMENT ?				; NON, EFFECTUONS LE...	JUMP.,NE DOMOV1		; MOVE AVEC LES ANCIENS...				; PARAMETRES DU MOVE.	JUMP.	NEXTLI		; OUI, ON NE MOVE PASDOTRANS:EX	DE,HL	CALL	RDESCNEXTLI:	.W	?RETURN	JUMP	DEB3; HL= ADR. DEBUT; DE= ADR. DE FIN; BC= ADR. TRANSFERT DANS SMACKYRDESC:	PUSH	HL	OR	A,A	SUBC	HL,DE	POP	HL	RET,CC	CALL	READ	LOAD	(BC),A	INC	BC	INC	HL	JUMP	RDESC; ENVOI VERS PERIPHERIQUEDOOUT:	LOAD	A,OPERAD	; LIT PERIPHERIQUE PRECEDENT	LOAD	E,ADOOUT1:	LOAD	A,E	LOAD	OPERAD,A	.W	?DEL	LOAD	A,#5		; <5> COMMAND BYTE	.W	?WPP	XOR	A,A		; <0>	.W	?WPP	LOAD	A,E		; <OUT.PER>	.W	?WPP	LOAD	A,L		; <BYTE TO WRITE>	.W	?WPP	.W	?WPP		; <ANYTHING>	.W	?SPACE	LOAD	A,#'O	.W	?DICAR	JUMP	NEXTLI; LECTURE D'UN PERIPHERIQUEDOINP:	.W	?DEL	LOAD	A,C	OR	A,A		; ADR. PER. DONNE ?	JUMP.,EQ DOINP1		; NON	.W	?SPACE	JUMP.	DOINP2DOINP1:	LOAD	A,IPERAD	; NON, ALORS ON PREND...	LOAD	L,A		; LA PRECEDENTE UTILISEEDOINP2:	LOAD	A,L	LOAD	IPERAD,A	; SAUVE L'ADR. DU PER.	LOAD	A,#6		; <6> COMMAND BYTE	.W	?WPP	XOR	A,A		; <0>	.W	?WPP	LOAD	A,L		; <INPUT PER.ADR>	.W	?WPP	.W	?WPP		; <ANYTHING>	.W	?WPP		; <ANYTHING>DOINP3:	.W	?RPR		; LECTURE DE LA REPONSE	COMP	A,#6	JUMP.,NE DOINP3	.W	?RPR		; BYTE LU	.W	?AFMONA	.W	?SPACE	LOAD	A,#'I	.W	?DICAR	JUMP	NEXTLIDOG:	JUMP,EQ	DOG2	LOAD	BC,#?SAVPC	LOAD	A,L	CALL	WRITE	INC	BC	LOAD	A,H	CALL	WRITEDOG2:	LOAD	A,#4	.W	?WPP	XOR	A,A	.W	?WPPDOG3:	.W	?RPR		; ATTEND L'ESCLAVE	COMP	A,#367	JUMP,NE	DOG3AFREG:	CALL	AFR	JUMP	DEB3AFR:	LOAD	HL,#?MONSAV	LOAD	DE,#?MONSAV+31	LOAD	BC,#SAVI	CALL	RDESC	.W	?PRSTAT	RETDOPE:	JUMP,NE	DOPE3	LOAD	HL,SAVLOPDOPE3:	.W	?RETURNDOPE33:	.W	?AFMOHL	LOAD	A,#':	.W	?DICARDOPE4:	LOAD	SAVLOP,HL	CALL	READ	.W	?AFMONA	.W	?SPACE	JUMP	DEB3DONEXT:	.W	?RETURN	EX	DE,HL	LOAD	HL,SAVLOP	JUMP,EQ	DONEX4	LOAD	BC,SAVLOP	LOAD	A,E	CALL	WRITEDONEX4:	INC	HL	JUMP.	DOPE33DOPREV:	.W	?RETURN	EX	DE,HL	LOAD	HL,SAVLOP	JUMP.,EQ DOPRV4	LOAD	BC,SAVLOP	LOAD	A,E	CALL	WRITEDOPRV4:	DEC	HL	JUMP	DOPE33DOCR:	EX	DE,HL	LOAD	HL,SAVLOP	JUMP.,EQ DOCR2	LOAD	A,E	LOAD	BC,SAVLOP	CALL	WRITEDOCR2:	JUMP	DEB3; SAUTE AU PROGRAMME SMILE SI; ON LE TROUVE (Z)SMILE:	LOAD	HL,SAVS	PUSH	HL	RET;SAUTE AU MONITEUR SI ON PRESSE M;MON:	LOAD	HL,#TMON;	.W 	?BRANCH;	PUSH 	DE;	RETTMON: 	.ASCII	/MON/;SAUTE AU SYSTEME SI ON PRESSE NRSYS:	LOAD	HL,#TSYS	.W	?BRANCH	PUSH	DE	RETTSYS:	.ASCII	/SYS/; WRITE => ECRIT UN BYTE;  <3><0><reg C><reg B><1><0><reg A>WRITE:	PUSH	AF	LOAD	A,#3	.W	?WPP	XOR	A,A	.W	?WPP	LOAD	A,C	.W	?WPP	LOAD	A,B	.W	?WPP	LOAD	A,#1	.W	?WPP	XOR	A,A	.W	?WPP	POP	AF	.W	?WPP	RET; ENVOIE <2><0><reg L><reg H><0>; RECOIT <2><byte lu>READ:	LOAD	A,#2	.W	?WPP	XOR	A,A	.W	?WPP	LOAD	A,L	.W	?WPP	LOAD	A,H	.W	?WPP	.W	?WPPREAD1:	.W	?RPR	COMP	A,#2	JUMP,NE	READ1	.W	?RPR	RETDEB:	LOAD	HL,#DBGST	; debugger starting	LOAD	SC134,HL	; replace MON starting				; adr. when the system				; call 134 (?MON) is done	.W	?RTN		; Return to CLI	.END	DEB