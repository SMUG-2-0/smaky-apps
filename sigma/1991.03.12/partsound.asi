	.SBTTL	PARTSOUNDDOPLAY:	CALL	DBOXPLAY	; choix de l'coute ...	COMP.W	D3,#F1		; coute ?	JUMP,NE	MAIN	CALL	AFMENU		; mj les "soft-keys"DOECHO:				; (DEFINE) =>	CALL	WAITMOUSE	; souris: met le sablier	LOAD.W	D6,(A6)+OMESC	; D6 <-- mesure actuelle	LOAD.L	D4,(A6)+OFAPLAY	TEST.L	D4:#BFARME	; tout avec les reprises ?	JUMP',BS 05$		; oui => 05$	TEST.L	D4:#BFANME	; mesures de ..  .. ?	JUMP',BC 10$		; non => 10$	LOAD.W	D4,(A6)+OPLPME	CALL	GOMESURE	; va dans la premire mesure  couter	JUMP'	10$05$:	CALL	REPINIT		; init pour les reprises10$:	COMP.W	D1,#NFLOPPY	JUMP',NE 20$	LOAD.L	A3,(A6)+OPICOH	; A3 <-- ^icnes horizontaux	LOAD.L	A4,(A6)+OPICOV	; A4 <-- ^icnes verticaux	LOAD.W	D2,#SKFPLAY	DBOX_	ICOINV		; allume les "soft-keys" play20$:	LOAD.L	D4,(A6)+OFAPLAY	TEST.L	D4:#BFA1ME	; une seule mesure ?	JUMP',BS 25$		; oui => 25$	CALL	AFNOMES		; affiche le numro de la mesure coute25$:	CLR.W	(A6)+OTMMIDI	CALL	MIDIMESURE	; OBUMIDI <-- notes de la mesure	JUMP,NE 50$	CALL	SELPTRACK	; slectionne les pistes d'coute	JUMP,NE 50$	NTREL	?GETPRIO	; D4 <-- priorit	LOAD.L	D5,#600		; D5 <-- lg stack	LOAD.L	A5,#R16"PPLAY	; A5 <-- ^start	LOAD.L	A3,#R16"NPLAY	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre l'coute	JUMP,NE 50$	TSET.B	(A6)+OFLAGS:#BPLAY40$:	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLAGS:#BPLAY	JUMP',BC 50$	LOAD.W	D4,#50/10	NTREL	?DELMS	LIB	?IFCAR		; clavier/souris actionn ?	JUMP,NE 40$		; non => 40$	COMP.W	D3,#KEYMGR	JUMP,EQ 40$	COMP.W	D3,#KEYMMR	; bouton souris relch ?	JUMP,EQ 40$		; oui => 40$	COMP.W	D3,#KEYMDR	JUMP,EQ 40$	LOAD.W	D7,#1		; D7 <-- l'utilisateur a stopp50$:	TEST.W	D7	JUMP',NE 80$	LOAD.L	D4,(A6)+OFAPLAY	TEST.L	D4:#BFARME	; tout avec les reprises ?	JUMP',BS 70$		; oui => 70$	TEST.L	D4:#BFANME	; mesures de ..  .. ?	JUMP',BC 80$		; non => 80$	LOAD.W	D4,(A6)+OMESC	COMP.W	D4,(A6)+OPLDME	; est-on arriv  la dernire mesure ?	JUMP',HS 80$		; oui => 80$	CALL	NMESURE		; non => coute la mesure suivante	JUMP,EQ 20$	CLR.W	D7	JUMP'	80$70$:	CALL	REPNEXT		; mesure suivante selon les reprises	JUMP,EQ 20$	CLR.W	D780$:	PUSH.W	D7	CALL	STOPMIDI	; "all-note-off"	LOAD.W	D4,D6		; D4 <-- mesure initiale	CALL	GOMESURE	; retourne dans la mesure initiale	CALL	NORMMOUSE	; souris: remet la flche	COMP.W	D1,#NFLOPPY	JUMP',NE 85$	LOAD.L	A3,(A6)+OPICOH	; A3 <-- ^icnes horizontaux	LOAD.L	A4,(A6)+OPICOV	; A4 <-- ^icnes verticaux	LOAD.W	D2,#SKFPLAY	DBOX_	ICOINV		; teint les "soft-keys" play85$:	LOAD.L	D4,(A6)+OFAPLAY	TEST.L	D4:#BFA1ME	; une seule mesure ?	JUMP',BS 86$		; oui => 86$	CALL	AFINFO		; efface le numro de mesure coute86$:	POP.W	D7	JUMP,EQ LOOP	COMP.W	D7,#1	JUMP,EQ LOOP	JUMP	ERROR;--------\\; ECHO    >;========/; Fait l'cho sonore d'une note.; in	A4.L	^symbole; out	-; mod	D7.WECHO:	PUSHM.L	D2..D6,A3..A5	CLR.B	D2		; D2 <-- canal MIDI	CALL	DEMITON		; D3 <-- rang	JUMP',NE 90$	LOAD.L	A3,#(A6)+OFRAPPE	CLR.W	D4	LOAD.B	D4,(A4)+OSYFRAP	; D4 <-- 1..5 (0 si ancien)	DEC.B	D4		; D4 <-- 0..4	JUMP',NC 10$	LOAD.B	D4,#2		; si ancien fichier => force moyenne (mf)10$:	LOAD.B	D4,(A3)+(D4.W)	; D4 <-- force de frappe (0..127)	CLR.W	D5		; D5 <-- temps note presse	LOAD.W	D6,#50/2	; D6 <-- temps note relche	CALL	CLRMIDI	CALL	INSMIDI		; met juste une note	TEST.B	(A6)+OFLAGS:#BPLAY	JUMP',BC 50$	CALL	STOPMIDI	; "all-note-off"50$:	CALL	SELPTRACK	; slectionne les pistes d'coute	NTREL	?GETPRIO	; D4 <-- priorit	LOAD.L	D5,#600		; D5 <-- lg stack	LOAD.L	A5,#R16"PPLAY	; A5 <-- ^start	LOAD.L	A3,#R16"NPLAY	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre l'coute	TSET.B	(A6)+OFLAGS:#BPLAY90$:	POPM.L	D2..D6,A3..A5	RET;;;;;;;;;;;;;;;    PLAY    ;;;;;;;;;;;;;;;NPLAY:	.ASCIZ	"MIDI_PLAY"	.EVENPPLAY:	LOAD.L	A4,#(A6)+OBUMIDI	CLR.L	D5	LOAD.W	D5,(A6)+OPTMIDI	JUMP,EQ 90$	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DWRITE90$:	TCLR.B	(A6)+OFLAGS:#BPLAY	NTREL	?ABORT;-----------\\; MIDIMESURE >;===========/; Transforme toute une mesure en commandes MIDI.; in	-; out	D5.W	dure de la mesure;	D7.W	erreur; mod	D5.L, D7.WMIDIMESURE:	PUSHM.L	D3,D4	CALL	MESTRIE		; trie toutes les notes de la mesure	CALL	CLRMIDI		; vide le buffer MIDI	CLR.W	D3		; D3 <-- no de la porte	CLR.W	D4		; D4 <-- dure maximale10$:	CALL	MIDIVOIX	JUMP',NE 90$	COMP.W	D4,D5	JUMP',HS 40$	LOAD.W	D4,D5		; D4 <-- dure maximale40$:	INC.W	D3	COMP.W	D3,#MAXLP*2	JUMP,LO 10$	LOAD.W	D5,D4		; D5 <-- dure maximale	CALL	TRIMIDI		; trie toutes les commandes MIDI	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MIDIVOIX >;---------/; Transforme en commandes MIDI toutes les notes d'une voix.; in	D3.W	numro de la voix (0..5); out	D5.W	dure de la mesure;	D7.W	erreur; mod	D5.L, D7.WMIDIVOIX:	PUSHM.L	D0..D4,D6,A2..A4	LOAD.W	(A6)+OTNMIDI,(A6)+OTMMIDI	CLR.W	D1		; D1 <-- dure de la dernire note	LOAD.B	D2,D3		; D2 <-- canal MIDI	LOAD.L	D4,(A6)+OFAPLAY	TEST.L	D4:#BFA2VPP	; deux voix par porte ?	JUMP',BS 10$		; oui => 10$	TEST.L	D2:#0		; voix impaire ?	JUMP,BS 80$		; oui => 80$10$:	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	LOAD.L	A3,#(A4)+OMELP	; A3 <-- ^description 1re porte	SR.W	D3,#1		; D3 <-- numro de la porte (0..2)	MUL.WU	D3,#LLP	ADD.L	A3,D3	COMP.B	(A3)+OLPTYP,#ICOVIDE	JUMP,EQ 80$	LOAD.W	D0,#-1		; D0 <-- dernire position en X20$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP,NE 80$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP,EQ 80$	COMP.B	(A4)+OOBJC,#ICODROITE	JUMP,HS 20$	LOAD.W	D3,(A4)+OSYPOS+0	COMP.W	D3,(A3)+OLPMIN	; note trop haute ?	JUMP,LO 20$		; oui => 20$	COMP.W	D3,(A3)+OLPMAX	; note trop basse ?	JUMP,HS 20$		; oui => 20$	LOAD.L	D3,(A6)+OFAPLAY	TEST.L	D3:#BFA2VPP	; deux voix par porte ?	JUMP',BC 35$		; non => 35$	TEST.B	(A4)+OSYFLG:#BSYBAS	JUMP',BS 30$;;?	COMP.B	(A4)+OOBJC,#ICOPAUSE ; silence ?;;?	JUMP',HS 35$		; oui => 35$;;?	COMP.B	(A4)+OOBJC,#ICOBRONDE;;?	JUMP',HS 30$				; note tourne contre en haut =>	TEST.L	D2:#0	JUMP,BS 20$	JUMP'	35$30$:				; note tourne contre en bas =>	TEST.L	D2:#0	JUMP,BC 20$35$:	CALL	DUREE		; D4 <-- dure	JUMP,NE 20$	CALL	DEMITON		; D3 <-- rang (D7=erreur si silence)	COMP.W	D0,(A4)+OSYPOS+2 ; mme position horizontale ?	JUMP',EQ 40$	ADD.W	(A6)+OTNMIDI,D1	; saute la note dans le temps	LOAD.W	D0,(A4)+OSYPOS+2 ; D0 <-- dernire position en X	CLR.W	D140$:	COMP.W	D1,D4	JUMP',HS 42$	LOAD.W	D1,D4		; D1 <-- dure la plus grande42$:	TEST.W	D7		; silence ?	JUMP,NE 20$		; oui => 20$				; non => note	LOAD.W	D5,(A6)+OTNMIDI	; D5 <-- temps pour note presse	COMP.B	(A4)+OSYACC,#ICOHDETACHE	JUMP',NE 44$	SR.W	D4,#144$:	COMP.B	(A4)+OSYACC,#ICOHPIQUE	JUMP',NE 46$	SR.W	D4,#246$:	LOAD.W	D6,D5	SR.W	D4,#1	ADD.W	D6,D4	SR.W	D4,#1	ADD.W	D6,D4		; D6 <-- temps pour note relche	LOAD.L	A2,#(A6)+OFRAPPE	CLR.W	D4	LOAD.B	D4,(A4)+OSYFRAP	; D4 <-- 1..5 (0 si ancien)	DEC.B	D4		; D4 <-- 0..4	JUMP',NC 50$	LOAD.B	D4,#2		; si ancien fichier => force moyenne (mf)50$:	LOAD.B	D4,(A2)+(D4.W)	; D4 <-- force de frappe (0..127)	COMP.B	(A4)+OSYACC,#ICOHFORTE	JUMP',NE 52$	ADD.B	D4,#4052$:	COMP.B	(A4)+OSYACC,#ICOHACCENT	JUMP',NE 54$	ADD.B	D4,#2054$:	COMP.B	D4,#127	JUMP',LS 56$	LOAD.B	D4,#12756$:	CALL	INSMIDI		; OBUMIDI <-- une note de plus	JUMP,NE 90$	JUMP	20$80$:	ADD.W	(A6)+OTNMIDI,D1	; saute la dernire note dans le temps	LOAD.W	D5,(A6)+OTNMIDI	SUB.W	D5,(A6)+OTMMIDI	; D5 <-- dure de la mesure	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DUREE   >;========/; Donne la dure d'un symbole, note ou silence.; Tient compte des liaisons entre les notes.; in	A4.L	^symbole; out	D4.W	dure;	D7.W	erreur (pas une note ou un silence); mod	D4.L, D7.WDUREE:	PUSHM.L	D3,A3,A4	LOAD.W	D7,#1	TEST.B	(A4)+OOBJF:#BTAKE	JUMP,BC 90$	CALL	SYDUREE		; D4 <-- dure	JUMP,NE 90$	CALL	LLDUREE		; A3 <-- cherche note lie	JUMP,NE 80$	LOAD.W	D3,D4	LOAD.L	A4,A3	CALL	SYDUREE		; D4 <-- dure note lie	JUMP,NE 80$	ADD.W	D4,D3		; D4 <-- somme des deux dures	TCLR.B	(A4)+OOBJF:#BTAKE80$:	CLR.W	D7		; D7 <-- c'est une note ou un silence90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SYDUREE >;--------/; Donne la dure d'un symbole, note ou silence.; in	A4.L	^symbole; out	D4.W	dure;	D7.W	erreur (pas une note ou un silence); mod	D4.L, D7.WSYDUREE:	PUSHM.L	D2,D3,A3	LOAD.W	D7,#ERSNOT	; D7 <-- pas une note ou un silence	CLR.L	D3	LOAD.B	D3,(A4)+OOBJC	; D3 <-- code du symbole	SUB.B	D3,#ICOHRONDE	JUMP,LO 90$	DIV.WU	D3,#ICOBRONDE-ICOHRONDE	COMP.W	D3,#3		; note haute, note basse ou silence ?	JUMP,HS 90$		; non => 90$	TEST.B	(A4)+OSYFLG:#BSYNOQ ; note sans queue ?	JUMP,BS 90$		; oui => 90$	SWAP.W	D3	SL.W	D3,#1		; D3 <-- *2 car table de .W	LOAD.L	A3,#R16"00$	LOAD.W	D4,(A3)+(D3.W)	; D4 <-- dure	LOAD.W	D2,#3	LOAD.W	D3,#2	TEST.B	(A4)+OSYFLG:#BSYPOINT	JUMP',BS 50$;	LOAD.W	D2,#3;	LOAD.W	D3,#2	TEST.B	(A4)+OSYFLG:#BSYDUOLET	JUMP',BS 50$	LOAD.W	D2,#2	LOAD.W	D3,#3	TEST.B	(A4)+OSYFLG:#BSYTRIOLET	JUMP',BS 50$	LOAD.W	D2,#4	LOAD.W	D3,#5	TEST.B	(A4)+OSYFLG:#BSYQUINTOLET	JUMP',BS 50$	LOAD.W	D2,#8	LOAD.W	D3,#7	TEST.B	(A4)+OSYFLG:#BSYSEPTOLET	JUMP',BC 60$50$:	MUL.WU	D4,D2	DIV.WU	D4,D360$:	CALL	LNDUREE		; traite le cas d'une noire sous une croche	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2,D3,A3	TEST.W	D7		; retour EQ/NE	RET00$:				; dures de base pour notes/silences :	.W	128		; ronde	.W	64		; blanche	.W	32		; noire	.W	16		; croche	.W	8		; double-croche	.W	4		; triple-croche;;?	.W	3*32		; ronde;;?	.W	3*16		; blanche;;?	.W	3*8		; noire;;?	.W	3*4		; croche;;?	.W	3*2		; double-croche;;?	.W	3*1		; triple-croche;--------\\; LNDUREE >;--------/; S'il s'agit d'une noire, vrifie s'il existe une croche juste en dessus.; Si oui, prend la duree de la croche !; Remarque: si la note est tourne contre en bas, tout s'inverse.; in	A4.L	^symbole;	D4.W	dure; out	D4.W	dure; mod	D4.L, D7.WLNDUREE:	PUSHM.L	D0..D3,A4	LOAD.B	D3,(A4)+OOBJC	; D3 <-- code du symbole	COMP.B	D3,#ICOBNOIRE	; noire contre en bas ?	JUMP,EQ 50$	COMP.B	D3,#ICOHNOIRE	; noire contre en haut ?	JUMP,NE 90$	LOAD.B	D1,(A4)+OSYVOIX	; D1 <-- voix	LOAD.L	D2,(A4)+OSYPOS	; D2 <-- position noire (y;x)20$:	CALL	PVISU		; A4 <-- ^symbole en dessus	JUMP,NE 90$	LOAD.B	D3,(A4)+OOBJC	COMP.B	D3,#OBJMES	JUMP,EQ 90$	COMP.B	D3,#ICOHCROCHE	JUMP,LO 20$	COMP.B	D3,#ICOHTCROCHE	JUMP,HI 20$	COMP.B	D1,(A4)+OSYVOIX	; D1 <-- mme voix	JUMP,NE 90$	COMP.W	D2,(A4)+OSYPOS+2 ; D2 <-- mme position en X	JUMP,NE 90$	SWAP.W	D2	SUB.W	D2,(A4)+OSYPOS+0 ; D2 <-- distance entre les notes	COMP.W	D2,#LYPORTEE*4	JUMP,HS 90$	SUB.B	D3,#ICOHCROCHE-1 ; D3 <-- 1..3	SR.W	D4,D3		; D4 <-- divise la dure par 2, 4 ou 8	JUMP	90$50$:	LOAD.B	D1,(A4)+OSYVOIX	; D1 <-- voix	LOAD.L	D2,(A4)+OSYPOS	; D2 <-- position noire (y;x)60$:	CALL	NVISU		; A4 <-- ^symbole en dessous	JUMP,NE 90$	LOAD.B	D3,(A4)+OOBJC	COMP.B	D3,#OBJMES	JUMP,EQ 90$	COMP.B	D3,#ICOBCROCHE	JUMP,LO 60$	COMP.B	D3,#ICOBTCROCHE	JUMP,HI 60$	COMP.B	D1,(A4)+OSYVOIX	; D1 <-- mme voix	JUMP,NE 90$	COMP.W	D2,(A4)+OSYPOS+2 ; D2 <-- mme position en X	JUMP,NE 90$	SWAP.W	D2	SUB.W	D2,(A4)+OSYPOS+0 ; D2 <-- distance entre les notes	NEG.W	D2	COMP.W	D2,#LYPORTEE*4	JUMP,HS 90$	SUB.B	D3,#ICOBCROCHE-1 ; D3 <-- 1..3	SR.W	D4,D3		; D4 <-- divise la dure par 2, 4 ou 890$:	POPM.L	D0..D3,A4	RET;--------\\; LLDUREE >;--------/; Cherche si une note est lie  une autre.; in	A4.L	^symbole; out	A3.L	^note lie;	D7.W	ok/pas trouv; mod	D7.W, A3.LLLDUREE:	PUSHM.L	D2..D4,A2,A4	LOAD.W	D7,#1	LOAD.B	D4,(A4)+OOBJC	COMP.B	D4,#ICOHRONDE	; est-ce une note ?	JUMP,LO 90$		; non => 90$	COMP.B	D4,#ICOBTCROCHE	JUMP,HI 90$; Cherche une liaison dans la mesure.	LOAD.L	A3,A4		; A3 <-- ^symbole	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure10$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP,NE 90$	LOAD.W	D7,#1	LOAD.B	D4,(A4)+OOBJC	COMP.B	D4,#OBJMES	JUMP,EQ 90$	LOAD.W	D3,#-LYPORTEE	; D3 <-- la liaison est en dessous	COMP.B	D4,#ICOHCOURBE	JUMP,EQ 20$	NEG.W	D3		; D3 <-- la liaison est en dessus	COMP.B	D4,#ICOBCOURBE	JUMP,NE 10$; Cherche  quelle porte se ratache la liaison trouve.20$:	LOAD.L	A2,(A6)+OPMES	LOAD.L	A2,#(A2)+OMELP	; A2 <-- ^description 1re porte	LOAD.W	D2,#MAXLP-1	ADD.W	D3,(A4)+OGRPN1+022$:	COMP.W	D3,(A2)+OLPMIN	JUMP,LO 25$	COMP.W	D3,(A2)+OLPMAX	JUMP,LO 30$25$:	LOAD.L	A2,#(A2)+LLP	; A2 <-- ^description porte suivante	DECJ.W,NMO,D2,22$	JUMP	10$; Vrifie si la note est dans la mme porte.30$:	LOAD.W	D3,(A3)+OSYPOS+0	COMP.W	D3,(A2)+OLPMIN	JUMP,LO 10$	COMP.W	D3,(A2)+OLPMAX	JUMP,HS 10$; Vrifie si la note correspond bien au dbut de la liaison.	LOAD.L	D3,(A4)+OGRPN1	LOAD.L	D4,(A4)+OGRPN2	COMP.W	D3,D4	JUMP,LO 40$	EX.L	D3,D4		; D3 <-- dbut et D4 <-- fin40$:	AND.L	D3,#H'FFFF	DIV.WU	D3,#LXPORTEE	MUL.WU	D3,#LXPORTEE	; D3 <-- arrondi le dbut en X	COMP.W	D3,(A3)+OSYPOS+2	JUMP,NE 10$	CLR.L	D3	LOAD.W	D3,D4	DIV.WU	D3,#LXPORTEE	MUL.WU	D3,#LXPORTEE	; D3 <-- arrondi la fin en X; Cherche s'il existe une note  la fin de la liaison.	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure50$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP,NE 90$	LOAD.W	D7,#ERSEOB	LOAD.B	D4,(A4)+OOBJC	COMP.B	D4,#OBJMES	JUMP,EQ 90$	COMP.B	D4,#ICOHRONDE	JUMP,LO 50$	COMP.B	D4,#ICOBTCROCHE	JUMP,HI 50$	COMP.W	D3,(A4)+OSYPOS+2	JUMP,NE 50$	LOAD.W	D2,(A3)+OSYPOS+0	COMP.W	D2,(A4)+OSYPOS+0 ; note  la mme hauteur ?	JUMP,NE 50$	LOAD.L	A3,A4	CLR.W	D7		; D7 <-- trouv, pfff90$:	POPM.L	D2..D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SRCNPOS >;========/; Cherche une position (dans la porte o est la souris) en fonction; d'un numro de note MIDI.; in	D3.B	numro de note MIDI (0..127);	A4.L	^symbole; out	D7.W	erreur; mod	D7.WSRCNPOS:	PUSHM.L	D0..D4,A1..A3	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 90$	CALL	RNDOBJET	; D4 <-- arrondi la position de la souris; Cherche la porte dans laquelle se trouve la souris.	LOAD.L	A3,(A6)+OPMES	; A3 <-- ^mesure courante	LOAD.L	A3,#(A3)+OMELP	; A3 <-- ^table des portes	LOAD.W	D2,#MAXLP	LOAD.L	D1,D4	SWAP.W	D1		; D1 <-- position en Y de la souris10$:	COMP.B	(A3)+OLPTYP,#ICOVIDE	JUMP',EQ 20$	COMP.W	D1,(A3)+OLPMIN	; dans cette porte ?	JUMP',LO 20$		; non => 20$	COMP.W	D1,(A3)+OLPMAX	JUMP',LO 30$		; oui => 30$20$:	LOAD.L	A3,#(A3)+LLP	; A3 <-- ^porte suivante	DEC.W	D2	JUMP,NE 10$	LOAD.W	D7,#ERSNOT	JUMP	90$		; pas dans une porte => 90$30$:	CLR.L	D2	LOAD.B	D2,D3	DIV.WU	D2,#12	LOAD.W	D1,D2		; D1 <-- octave (0..n)	SWAP.W	D2		; D2 <-- note (0..11)	LOAD.L	A1,(A6)+OPMES	; A1 <-- ^mesure courante	LOAD.L	A2,#R16"01$	; A2 <-- ^table si "#"	COMP.B	(A1)+OMETA,#ICODIESE	JUMP',EQ 40$	LOAD.L	A2,#R16"02$	; A2 <-- ^table si "b"40$:	LOAD.B	D2,(A2)+(D2.W)	; D2 <-- note (0..7)	LOAD.B	D0,#ICODIESE	TCLR.L	D2:#7	JUMP',BS 42$	LOAD.B	D0,#ICOBEMOL	TCLR.L	D2:#6	JUMP',BS 42$	LOAD.B	D0,#ICOBECARRE42$:	LOAD.B	(A4)+OSYALT,D0	MUL.WU	D1,#7	ADD.W	D2,D1		; D2 <-- note	MUL.WU	D2,#LYPORTEE/2	LOAD.W	D1,(A3)+OLPDY	LOAD.W	D0,#(7*(4+2))+3	; D0 <-- haut clef = FA octave no 4	COMP.B	(A3)+OLPTYP,#ICOPSOL	JUMP',EQ 50$	LOAD.W	D0,#(7*(2+2))+5	; D0 <-- haut clef = LA octave no 250$:	MUL.WU	D0,#LYPORTEE/2	ADD.W	D1,D0		; D1 <-- position du DO octave no 0	SUB.W	D1,D2	LOAD.W	D7,#ERSNOT	COMP.W	D1,(A3)+OLPMIN	JUMP',LO 90$	COMP.W	D1,(A3)+OLPMAX	JUMP',HS 90$	SWAP.W	D4	LOAD.W	D4,D1		; D4 <-- position (y;x)	SWAP.W	D4	LOAD.L	(A4)+OSYPOS,D4	CALL	DEMITON		; D3 <-- demi-ton de la note avec altration	JUMP',NE 80$	LOAD.W	D2,D3	PUSH.B	(A4)+OSYALT	CLR.B	(A4)+OSYALT	; enlve son altration	CALL	DEMITON		; D3 <-- demi-ton de la note sans altration	POP.B	(A4)+OSYALT	COMP.W	D2,D3		; mme demi-ton sans altration ?	JUMP',NE 80$		; non => 80$ (laisse)	CLR.B	(A4)+OSYALT	; oui => enlve dfinitivement80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D4,A1..A3	TEST.W	D7		; retour EQ/NE	RET	;	    x       x         x       x       x		; <-- touches noires	;	x       x       x x       x       x       x	; <-- touches blanches01$:	.B	0,0!2^7,1,1!2^7,2,3,3!2^7,4,4!2^7,5,5!2^7,6	; si "#"02$:	.B	0,1!2^6,1,2!2^6,2,3,4!2^6,4,5!2^6,5,6!2^6,6	; si "b"	.EVEN;--------\\; DEMITON >;========/; Donne le demi-ton d'une note, en tenant compte des altrations;  la clef, des altrations des notes prcdentes, et tout et tout !; in	A4.L		^symbole; out	D3.W		demi-ton de la note;	(A6)+ONNMIDI.W	nom de la note (-1,0..6);	D7.W		ERNOT	=> pas une note; mod	D3.L, D7.WDEMITON:	PUSHM.L	D0..D2,D4,A3	LOAD.W	(A6)+ONNMIDI,#-1	LOAD.W	D7,#ERSNOT	; D7 <-- pas une note	LOAD.B	D4,(A4)+OOBJC	; D4 <-- code du symbole	COMP.B	D4,#ICOPAUSE	; silence ?	JUMP,HS 90$		; oui => 90$; Cherche la porte dans laquelle se trouve la note, pour pouvoir; calculer sa hauteur.	LOAD.L	A3,(A6)+OPMES	; A3 <-- ^mesure courante	LOAD.L	A3,#(A3)+OMELP	; A3 <-- ^table des portes	LOAD.W	D4,#MAXLP	CLR.L	D3	LOAD.W	D3,(A4)+OSYPOS+0 ; D3 <-- position en Y de la note10$:	COMP.B	(A3)+OLPTYP,#ICOVIDE	JUMP',EQ 20$	COMP.W	D3,(A3)+OLPMIN	; dans cette porte ?	JUMP',LO 20$		; non => 20$	COMP.W	D3,(A3)+OLPMAX	JUMP',LO 30$		; oui => 30$20$:	LOAD.L	A3,#(A3)+LLP	; A3 <-- ^porte suivante	DEC.W	D4	JUMP,NE 10$	JUMP	90$		; pas dans une porte => 90$; Calcule la hauteur de la note en fonction du type de la; clef (sol ou fa).30$:	SUB.W	D3,(A3)+OLPDY	NEG.W	D3	CONV.LA.WA D3	DIV.WA	D3,#LYPORTEE/2	LOAD.W	D4,#(7*(4+2))+3	; D4 <-- haut clef = FA octave no 4	COMP.B	(A3)+OLPTYP,#ICOPSOL	JUMP',EQ 40$	LOAD.W	D4,#(7*(2+2))+5	; D4 <-- haut clef = LA octave no 240$:	ADD.W	D3,D4		; D3 <-- rang depuis DO octave no 0	LOAD.L	A3,#R16"00$	AND.L	D3,#H'FFFF	DIV.WU	D3,#7	LOAD.W	D4,D3		; D4 <-- octave (0..n)	SWAP.W	D3		; D3 <-- rang (0..6)	LOAD.W	(A6)+ONNMIDI,D3	LOAD.W	D1,D3	LOAD.B	D3,(A3)+(D3.W)	; D3 <-- demi-ton (0..11)	MUL.WU	D4,#12		; D4 <-- demi-ton de l'octave (0,12,24,36,etc)	ADD.W	D3,D4		; D3 <-- demi-ton de la note; Si la note est directement altre, prend cette altration en compte.	LOAD.B	D4,(A4)+OSYALT	; D4 <-- altration	JUMP',EQ 50$	LOAD.W	D2,#-1		; D2 <-- -1/2 ton	COMP.B	D4,#ICOBEMOL	JUMP,EQ 80$	DEC.W	D2		; D2 <-- -1 ton	COMP.B	D4,#ICODBEMOL	JUMP,EQ 80$	LOAD.W	D2,#+1		; D2 <-- +1/2 ton	COMP.B	D4,#ICODIESE	JUMP,EQ 80$	INC.W	D2		; D2 <-- +1 ton	COMP.B	D4,#ICODDIESE	JUMP,EQ 80$	CLR.W	D2		; D2 <-- pas d'altration	JUMP	80$; Si la note n'est pas directement altre, cherche si une note;  sa gauche l'est (dans la meme mesure).50$:				; note pas altre =>	CALL	SRCNALTER	; une note prcdente altre ?	JUMP,EQ 80$		; oui => 80$; Cherche si la note est altre  la clef.	LOAD.L	A3,(A6)+OPMES	; A3 <-- ^mesure courante	LOAD.B	D0,(A3)+OMENA	; D0 <-- 0..7	JUMP',EQ 85$	LOAD.B	D4,(A3)+OMETA	; D4 <-- b/#	COMP.B	D4,#ICODIESE	JUMP',EQ 55$	COMP.B	D4,#ICOBEMOL	JUMP',NE 85$	LOAD.L	A3,#R16"01$	; A3 <-- ^table des bmols	LOAD.W	D2,#-1	JUMP'	60$55$:	LOAD.L	A3,#R16"02$	; A3 <-- ^table des dises	LOAD.W	D2,#+160$:	COMP.B	D1,(A3+)	; note altre  la clef ?	JUMP',EQ 80$		; oui => 80$	DEC.B	D0	JUMP,NE 60$	JUMP'	85$80$:	ADD.W	D3,D2		; D3 <-- altre la note85$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2,D4,A3	TEST.W	D7		; retour EQ/NE	RET00$:				; rangs des notes :	.B	0		; do	.B	2		; r	.B	4		; mi	.B	5		; fa	.B	7		; sol	.B	9		; la	.B	11		; si01$:				; bmols :	.B	6,2,5,1,4,0,3	; si-mi-la-r-sol-do-fa02$:				; dises :	.B	3,0,4,1,5,2,6	; fa-do-sol-r-la-mi-si	.EVEN;----------\\; SRCNALTER >;----------/; Cherche s'il existe une note altre  la mme hauteur; et dans la mme mesure.; Si le symbole n'est pas dans le buffer, ne l'altre pas !; Par exemple :;                    A4;                    |;   o   #o   o   o   o      <-- notes;; Rend # (donc +1) dans D2.; in	A4.L	^symbole; out	D2.W	altration (+/-n);	D7.W	erreur (pas trouv d'altration); mod	D2.L, D7.WSRCNALTER:	PUSHM.L	D3,D4,A4	LOAD.W	D7,#ERSNOT	COMP.L	A4,(A6)+OPDB	; symbole dans le buffer ?	JUMP,LO 90$		; non => 90$	COMP.L	A4,(A6)+OPFB	JUMP,HS 90$	LOAD.W	D4,(A4)+OSYPOS+0	CLR.W	D2		; D2 <-- pas d'altration20$:	CALL	PVISU		; A4 <-- ^objet prcdent	JUMP,NE 90$	LOAD.W	D7,#ERSNOT	COMP.B	(A4)+OOBJC,#OBJMES	JUMP,EQ 90$	COMP.B	(A4)+OOBJC,#ICODROITE	JUMP,HS 20$				; symbole =>	COMP.W	D4,(A4)+OSYPOS+0 ;  la mme hauteur ?	JUMP,NE 20$		; non => 20$				; oui =>	LOAD.B	D3,(A4)+OSYALT	; D3 <-- altration	JUMP,EQ 20$	LOAD.W	D2,#-1		; D2 <-- -1/2 ton	COMP.B	D3,#ICOBEMOL	JUMP',EQ 80$	DEC.W	D2		; D2 <-- -1 ton	COMP.B	D3,#ICODBEMOL	JUMP',EQ 80$	LOAD.W	D2,#+1		; D2 <-- +1/2 ton	COMP.B	D3,#ICODIESE	JUMP',EQ 80$	INC.W	D2		; D2 <-- +1 ton	COMP.B	D3,#ICODDIESE	JUMP',EQ 80$	CLR.W	D2		; D2 <-- pas d'altration80$:	CLR.W	D7		; D7 <-- altration trouve90$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLRMIDI >;========/; Vide le contenu du buffer des commandes MIDI.; in	-; out	-; mod	D7.WCLRMIDI:	CLR.W	(A6)+OPTMIDI	RET;--------\\; INSMIDI >;========/; Insre une note presse puis relache dans le buffer MIDI.; in	D2.B	canal MIDI (0..15);	D3.B	rang de la note (0..127);	D4.B	force de frappe (0..127);	D5.W	temps o la note est presse;	D6.W	temps o la note est relche; out	D7.W	erreur; mod	D7.WINSMIDI:	PUSHM.L	D4,D5	TEST.B	D4	JUMP',NE 20$	INC.B	D4		; D4 <-- 1..127 pour "press"20$:	CALL	INS1MIDI	; insre une note presse	JUMP',NE 90$	CLR.B	D4		; D4 <-- 0 pour "relch"	LOAD.W	D5,D6		; D5 <-- temps relch	CALL	INS1MIDI	; insre une note relche	JUMP',EQ 90$	SUB.W	(A6)+OPTMIDI,#4+5 ; supprime la note presse !90$:	POPM.L	D4,D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; INS1MIDI >;---------/; Insre une note presse ou relache dans le buffer MIDI.; in	D2.B	canal MIDI (0..15);	D3.B	rang de la note (0..127);	D4.B	force de frappe (1..127=press et 0=relch);	D5.W	temps; out	D7.W	erreur; mod	D7.WINS1MIDI:	PUSHM.L	D1,D2,A2	LOAD.W	D7,#ERSPDP	; D7 <-- plus de place	LOAD.L	A2,#(A6)+OBUMIDI	LOAD.W	D1,(A6)+OPTMIDI	ADD.W	A2,D1		; A2 <-- ^dans OBUMIDI	ADD.W	D1,#4+5	COMP.W	D1,#LBUMIDI	; buffer MIDI trop plein ?	JUMP',HS 90$		; oui => 90$	CLR.B	(A2+)	CLR.B	(A2+)	RR.W	D5,#8	LOAD.B	(A2+),D5	; OBUMIDI <-- temps	RR.W	D5,#8	LOAD.B	(A2+),D5	CLR.B	(A2+)	LOAD.B	(A2+),#3	OR.B	D2,#H'90	LOAD.B	(A2+),D2	; OBUMIDI <-- note presse/relche	LOAD.B	(A2+),D3	LOAD.B	(A2+),D4	LOAD.W	(A6)+OPTMIDI,D1	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D2,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; TRIMIDI >;========/; Trie toutes les touches presses/relches dans le buffer MIDI; pour les mettre d'aprs le temps.; Le buffer est constitu d'lments de 4+5 bytes de long (temps+note).; in	-; out	-; mod	D7.WTRIMIDI:	PUSHM.L	D2..D4,A2..A410$:	LOAD.L	A4,#(A6)+OBUMIDI	CLR.W	D4	CLR.W	D2		; D2 <-- pas de permutation20$:	LOAD.L	A3,A4		; A3 <-- ^lment prcdent	LOAD.L	A4,#(A4)+4+5	; A4 <-- ^lment suivant	ADD.W	D4,#4+5	COMP.W	D4,(A6)+OPTMIDI	; est-on  la fin du buffer ?	JUMP,HS 80$		; oui => 80$	LOAD.B	D3,(A3)+2+0	COMP.B	D3,(A4)+2+0	JUMP,LO 20$	JUMP,HI 30$	LOAD.B	D3,(A3)+2+1	COMP.B	D3,(A4)+2+1	; prcdent avant suivant ?	JUMP,LS 20$		; oui => 20$30$:				; non =>	LOAD.L	A2,A4	LOAD.W	D2,#(4+5)-140$:	LOAD.B	D3,(A3)	LOAD.B	(A3+),(A2)	; EX.B (A3+),(A2+)	LOAD.B	(A2+),D3	DECJ.W,NMO D2,40$	LOAD.W	D2,#1		; D2 <-- une permutation	JUMP	20$80$:	TEST.W	D2		; au moins une permutation ?	JUMP,NE 10$		; oui => 10$	POPM.L	D2..D4,A2..A4	RET;--------\\; MESTRIE >;========/; Trie la mesure courante pour mettre les notes de gauche  droite,; et de haut en bas en cas d'galit.; Les objets qui ne sont pas des symboles musicaux ne sont; pas touchs.; Les bits BTAKE sont mis partout !; in	-; out	-; mod	D7.WMESTRIE:	PUSHM.L	D2..D4,A2..A410$:	LOAD.L	A4,(A6)+OPMES	CLR.W	D2		; D2 <-- clear flags20$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 60$	COMP.B	(A4)+OOBJC,#OBJMES	JUMP',EQ 60$	TSET.B	(A4)+OOBJF:#BTAKE	COMP.B	(A4)+OOBJC,#ICODROITE	JUMP,HS 20$				; symbole =>	TSET.L	D2:#0		; prcdent dj trouv ?	JUMP',BC 50$		; non => 50$				; oui =>	LOAD.W	D4,(A3)+OSYPOS+2	COMP.W	D4,(A4)+OSYPOS+2	JUMP',LO 50$	JUMP',HI 25$	LOAD.W	D4,(A3)+OSYPOS+0	COMP.W	D4,(A4)+OSYPOS+0	JUMP',LS 50$25$:	LOAD.L	A2,A4	LOAD.W	D4,#(LSY/2)-130$:	LOAD.W	D3,(A3)	LOAD.W	(A3+),(A2)	; EX.W (A2+),(A3+)	LOAD.W	(A2+),D3	DECJ.W,NMO D4,30$	TSET.L	D2:#1		; D2 <-- une permutation faite50$:	LOAD.L	A3,A4		; A3 <-- ^objet prcdent	JUMP	20$60$:	TEST.L	D2:#1		; au moins une permutation faite ?	JUMP,BS 10$		; oui => 10$	POPM.L	D2..D4,A2..A4	RET	.END