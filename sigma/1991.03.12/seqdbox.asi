	.SBTTL	SEQDBOX;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F4/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITO:	PUSHM.L	D1,D2,D5,A1..A4	LOAD.L	D4,(A6)+OFANION	LOAD.L	A2,#R16"TDBOX_OUTPUT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A4,A3		; A4 <-- ^dbut du nom10$:	TEST.B	(A4+)		; A4 <-- ^fin du nom	JUMP',EQ 12$	COMP.B	(A4)-1,#CR	JUMP,NE	10$12$:	DEC.L	A420$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUTPUT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; SAUVE ?	JUMP,EQ	60$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	80$	COMP.W	D3,#UNDO	JUMP',EQ 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$60$:				; SAUVE =>	TEST.B	(A3)		; nom existe ?	JUMP,EQ	30$		; non => 30$	COMP.B	(A3),#CR	JUMP,EQ	30$	LOAD.L	A4,#R16"TXEXT	; A4 <-- ^extension	PUSH.W	D3	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	POP.W	D380$:	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys90$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F4/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,D5,A1..A4	LOAD.L	D4,(A6)+OFANION05$:	LOAD.L	A2,#R16"TDBOX_INPUT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A4,A3		; A4 <-- ^dbut du nom10$:	TEST.B	(A4+)		; A4 <-- ^fin du nom	JUMP',EQ 12$	COMP.B	(A4)-1,#CR	JUMP,NE	10$12$:	DEC.L	A420$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_INPUT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; PREND ?	JUMP,EQ	60$	COMP.W	D3,#F4		; AJOUTE ?	JUMP,EQ	60$	COMP.W	D3,#F7		; LISTE ?	JUMP,EQ	50$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	80$	COMP.W	D3,#UNDO	JUMP',EQ 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$50$:				; LISTE =>	DBOX_	CLOSE		; ferme la DBOX	PUSH.L	D4	LOAD.L	A4,A3		; A4 <-- ^buffer pour nom	LOAD.L	A3,#R16"TXEXT	; A3 <-- ^critre de recherche (extension)	CLR.L	D4	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode (avec sauvetage)	LIST_	DBOX		; liste puis choix selon dbox ...	POPM.L	D4	JUMP,NE 90$	LOAD.L	A3,A4		; A3 <-- ^nom du fichier	JUMP	05$60$:				; PREND/AJOUTE =>	TEST.B	(A3)		; nom existe ?	JUMP,EQ	30$		; non => 30$	COMP.B	(A3),#CR	JUMP,EQ	30$	LOAD.L	A4,#R16"TXEXT	; A4 <-- ^extension	PUSH.W	D3	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	POP.W	D380$:	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys90$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXSURE >;=========/; Demande "Etes-vous sr ?", OUI ou NON.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXSURE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_OUINON	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUINON	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; OUI ?	JUMP',EQ 80$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXMODE >;=========/; Demande le mode.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXMODE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_MODE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OFAMODE	; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_MODE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP',EQ 70$	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:	LOAD.L	(A6)+OFAMODE,D480$:	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXTRACK >;==========/; Affiche le contenu des pistes.; in	-; out	-; mod	D7.WDBOXTRACK:	PUSHM.L	D0..D6,A0..A4	TSET.B	(A6)+OFLAGS:#BAX	JUMP,BC 02$	LOAD.W	D4,(A6)+OTRKAX	CALL	DBOXINVA	; efface l'indicateur d'avance02$:	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfini une trame vide	LOAD.L	D3,(A6)+OPORECT	LOAD.L	D4,(A6)+ODIRECT	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface tout	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; met rectangle autour	LOAD.W	D1,#NBTRACK-1	AND.L	D4,#H'FFFF10$:	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	SWAP.W	D3	PUSH.L	D3	LIB	?DRSEG		; met ligne horizontale	POP.L	D3	DEC.W	D1	JUMP,NE 10$	CALL	SCALETRACK	LOAD.W	D1,(A6)+OTRKFM	LOAD.W	D2,(A6)+OTRKFD	LOAD.L	D3,#H'44114411	LOAD.L	D4,D3	LIB	?DRMDEF		; dfini une trame claire	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la flche de la souris	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OQXDOT	; A1 <-- ^routine GRA_QXDOT	LOAD.W	D5,(A6)+OPORECT+0	INC.W	D5		; D5 <-- origine Y	CLR.L	D6		; D6 <-- piste/flags30$:	LOAD.L	A4,(A6)+OPMBUF	LOAD.L	D0,(A6)+OLMBUF40$:	TEST.L	D0		; reste qq chose ?	JUMP,EQ 70$		; non => 70$	PUSH.L	D0	CLR.L	D3	LOAD.B	D3,(A4)+0	SL.W	D3,#8	LOAD.B	D3,(A4)+1	TEST.W	D3		; temps ?	JUMP,NE 50$		; non => 50$	LOAD.B	D4,(A4)+2	SL.W	D4,#8	LOAD.B	D4,(A4)+3	; D4 <-- temps	LOAD.W	D3,#2		; D3 <-- lg pour temps	JUMP	60$50$:				; objet =>	LOAD.B	D0,(A4)+2	AND.B	D0,#H'F0	; D0 <-- masque le canal	COMP.B	D0,#H'C0	; changement de programme ?	JUMP,EQ 55$		; oui => 55$	COMP.B	D0,#H'90	; note on/off ?	JUMP,NE 60$		; non => 60$	TEST.B	(A4)+4		; note relche ?	JUMP,EQ 60$		; oui => 60$	LOAD.B	D0,(A4)+2	AND.B	D0,#H'0F	; D0 <-- juste le canal	COMP.B	D0,D6		; est-ce le bon canal ?	JUMP,NE 60$		; non => 60$	PUSH.W	D4	MUL.WU	D4,D1	DIV.WU	D4,D2	ADD.W	D4,(A6)+OPORECT+2	ADD.W	D4,#MGTRK	SWAP.W	D4	CLR.W	D4	LOAD.B	D4,(A4)+3	; D4 <-- note (0..127)	SR.W	D4,#3		; D4 <-- note (0..15)	SUB.W	D4,#16	NEG.W	D4	ADD.W	D4,D5	SWAP.W	D4	CALL	(A1)		; appel GRA_QXDOT	TSET.B	(A0):D0		; met un point dans le rectangle	TSET.L	D6:#24	POP.W	D4	JUMP	60$55$:				; changement de programme =>	LOAD.B	D0,(A4)+2	AND.B	D0,#H'0F	; D0 <-- juste le canal	COMP.B	D0,D6		; est-ce le bon canal ?	JUMP,NE 60$		; non => 60$	PUSHM.L	D2..D4	LOAD.W	D3,D4	MUL.WU	D3,D1	DIV.WU	D3,D2	ADD.W	D3,(A6)+OPORECT+2	ADD.W	D3,#MGTRK	; D3 <-- <xx>	SWAP.W	D3	LOAD.W	D3,D5		; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D4,(A2)+ODFCY	; D4 <-- <dyy>	SWAP.W	D4	CLR.W	D4		; D4 <-- <dxx>	LOAD.W	D2,#SETDOT	; D2 <-- <mode>	LIB	?DRSEG		; trace une ligne verticale	POPM.L	D2..D4	TSET.L	D6:#2460$:	POP.L	D0	ADD.W	D3,#2	ADD.L	A4,D3		; A4 <-- avance	SUB.L	D0,D3	JUMP	40$70$:	TEST.L	D6:#24		; au moins une note ?	JUMP,BS 80$		; oui => 80$				; non =>	PUSHM.L	D2..D4	LOAD.W	D3,D5	DEC.W	D3	SWAP.W	D3	LOAD.W	D3,(A6)+OPORECT+2	LOAD.W	D4,(A2)+ODFCY	SWAP.W	D4	LOAD.W	D4,(A6)+ODIRECT+2	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise toute la piste	POPM.L	D2..D480$:	SWAP.W	D6	SR.W	D6,#1	SWAP.W	D6	ADD.W	D5,(A2)+ODFCY	; D5 <-- dbut Y suivant	INC.W	D6	COMP.W	D6,#NBTRACK	JUMP,LO 30$	SWAP.W	D6	LOAD.B	(A6)+OTRKUS,D6	LOAD.L	A0,A2		; A0 <-- ^descripteur de la fentre	LOAD.W	D4,(A6)+OTRKAX	CALL	DBOXINVA	; remet l'indicateur d'avance	LOAD.B	D3,#AFSCMO	LIB	?AFCAR		; remet la flche de la souris	POPM.L	D0..D6,A0..A4	RET;-----------\\; SCALETRACK >;===========/; Cherche les facteurs d'chelle en fonction de la dure; totale du morceau.; in	-; out	(A6)+OTRKFM.W;	(A6)+OTRKFD.W; mod	D7.WSCALETRACK:	PUSHM.L	D1..D4,A4; Cherche depuis la fin du master buffer la dernire commande; de temps pour dterminer l'chelle.	LOAD.W	D1,#1	LOAD.W	D2,#1	LOAD.L	A4,(A6)+OPMBUF	LOAD.L	D4,(A6)+OLMBUF	ADD.L	A4,D420$:	TEST.L	D4	JUMP,LE 25$	TEST.B	(A4)-4	JUMP,NE 22$	TEST.B	(A4)-3	JUMP,NE 22$				; temps =>	LOAD.B	D2,(A4)-2	SL.W	D2,#8	LOAD.B	D2,(A4)-1	; D2 <-- temps maximum	LOAD.W	D1,(A6)+ODIRECT+2	SUB.W	D1,#2*MGTRK	; D1 <-- largeur maximum	JUMP	25$22$:				; objet =>	DEC.L	D4	TEST.B	(-A4):#7	JUMP,BC 22$	SUB.L	D4,#2	SUB.L	A4,#2	JUMP	20$25$:	LOAD.W	(A6)+OTRKFM,D1	LOAD.W	(A6)+OTRKFD,D2	POPM.L	D1..D4,A4	RET;---------\\; DBOXINVT >;=========/; Inverse une piste complte.; in	D4.L	coordonne (np,x); out	-; mod	D7.WDBOXINVT:	PUSHM.L	D2..D4	LOAD.L	D2,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfini une trame pleine	SWAP.W	D2	COMP.W	D2,#-1	JUMP,EQ 90$	LOAD.W	D3,D2	MUL.WU	D3,(A0)+ODFCY	ADD.W	D3,(A6)+OPORECT+0	INC.W	D3		; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D3,(A6)+OPORECT+2	INC.W	D3		; D3 <-- <xx>	LOAD.W	D4,(A0)+ODFCY	DEC.W	D4		; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,(A6)+ODIRECT+2	DEC.W	D4		; D4 <-- <dxx>	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	; inverse toute la piste90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXMAJA >;=========/; Met  jour l'avance dans les pistes, et fait entendre; le mtronome si ncessaire.; in	-; out	-; mod	D7.WDBOXMAJA:	PUSHM.L	D3,D4	LOAD.W	D4,(A6)+OLASTT	; D4 <-- temps donn par le processus METRO	MUL.WU	D4,(A6)+OTRKFM	DIV.WU	D4,(A6)+OTRKFD	COMP.W	D4,(A6)+OTRKAX	JUMP,EQ 90$	LOAD.W	D3,D4	LOAD.W	D4,(A6)+OTRKAX	CALL	DBOXINVA	; efface l'ancienne	LOAD.W	D4,D3	CALL	DBOXINVA	; dessine la nouvelle	LOAD.W	(A6)+OTRKAX,D490$:	POPM.L	D3,D4	RET;---------\\; DBOXINVA >;=========/; Inverse l'indicateur d'avance dans les pistes.; in	D4.W	coordonne en X; out	-; mod	D7.WDBOXINVA:	PUSHM.L	D0..D4	LIB	?BUCAR	LOAD.W	D3,(A6)+ODIRECT+2	SUB.W	D3,#2*MGTRK	COMP.W	D4,D3		; est-on trop  gauche ?	JUMP,LO 10$		; non => 10$	LOAD.W	D4,D3		; oui => met le maximum10$:	LOAD.W	D3,(A6)+OPORECT+0	INC.W	D3	SWAP.W	D3	LOAD.W	D3,D4	ADD.W	D3,(A6)+OPORECT+2	ADD.W	D3,#MGTRK	PUSH.L	D3	LOAD.W	D4,(A0)+ODFCY	DEC.W	D4	SWAP.W	D4	CLR.W	D4	CLR.W	D0	LOAD.B	D1,(A6)+OTRKUS	LOAD.W	D2,#INVDOT20$:	TEST.L	D1:D0		; piste utilise ?	JUMP,BC 30$		; non => 30$	PUSH.L	D3	LIB	?DRSEG		; dessine une ligne verticale	POP.L	D330$:	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	SWAP.W	D3	INC.W	D0	COMP.W	D0,#NBTRACK	JUMP,LO 20$; Dessine une flche en haut du rectangle.	POP.L	D3	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LOAD.W	D4,#-8	SWAP.W	D4	CLR.W	D4	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	LOAD.W	D4,#-4	SWAP.W	D4	LOAD.W	D4,#-4	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	LOAD.W	D4,#-4	SWAP.W	D4	LOAD.W	D4,#+4;	PUSH.L	D3	LIB	?DRSEG;	POP.L	D3	LIB	?NOBUCAR	POPM.L	D0..D4	RET;--------\\; GETPMT  >;========/; Donne la position de la souris dans une piste.; in	D4.L	position de la souris; out	D4.L	position dans la piste (y;x);		x:	0..n;		y:	-1 ou 0..7;	D7.W	erreur; mod	D4.L, D7.WGETPMT:	PUSHM.L	D3,D5	CLR.W	D7		; D7 <-- ok	LOAD.W	D5,D4		; D5 <-- position en X	CLR.W	D4	SWAP.W	D4		; D4 <-- position en Y	LOAD.W	D3,(A6)+OPORECT+0	SUB.W	D3,(A0)+ODFCY	ADD.W	D3,(A0)+ODFFY	SUB.W	D4,D3		; trop haut ?	JUMP,HS 10$	CLR.W	D4	LOAD.W	D7,#ERDIOUT10$:	DIV.WU	D4,(A0)+ODFCY	COMP.W	D4,#NBTRACK+1	; trop bas ?	JUMP,LO 15$	LOAD.W	D4,#NBTRACK	LOAD.W	D7,#ERDIOUT15$:	DEC.W	D4		; D4 <-- piste -1 ou 0..7	SWAP.W	D4	LOAD.W	D3,(A6)+OPORECT+2	ADD.W	D3,(A0)+ODFFX	ADD.W	D3,#MGTRK	SUB.W	D5,D3		; trop  gauche ?	JUMP,HS 20$	CLR.W	D5	LOAD.W	D7,#ERDIOUT20$:	LOAD.W	D3,(A6)+ODIRECT+2	SUB.W	D3,#2*MGTRK	COMP.W	D5,D3		; trop  droite ?	JUMP,LO 25$	LOAD.W	D5,D3	LOAD.W	D7,#ERDIOUT25$:	LOAD.W	D4,D5		; D4 <-- position en X	POPM.L	D3,D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXMIDI >;=========/; Affiche les canaux midi  droite des fanions d'enregistrement.; in	-; out	-; mod	D7.WDBOXMIDI:	PUSHM.L	D0..D5,A3,A4	LIB	?BUCAR	LOAD.L	A3,#R16"TAPFREC	LOAD.L	A4,#(A6)+OTRACK	LOAD.W	D0,#NBTRACK	LOAD.L	D5,(A6)+ODBOXD5	; D5 <-- canal de la dbox20$:	LOAD.W	D2,(A3+)	DBOX_	GETCO	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#2	ADD.W	D3,D2	LIB	?SETCURS	; positionne aprs le cercle	CLR.L	D3	LOAD.W	D3,(A4)+OTMIDI	INC.W	D3		; D3 <-- 1..16	DIV.WU	D3,#10	LOAD.B	D2,#SPACE	TEST.W	D3	JUMP,EQ 30$	ADD.B	D3,#'0	LOAD.B	D2,D330$:	LOAD.B	D3,D2	LIB	?AFCAR		; affiche les dizaines	SWAP.W	D3	ADD.B	D3,#'0	LIB	?AFCAR		; affiche les units	LIB	?AFSPACE	LOAD.W	D4,(A4)+OTMIDI	; D4 <-- canal MIDI (0..15)	CALL	AFCFNOM		; affiche le nom du synth	LOAD.L	A4,#(A4)+LT	DEC.W	D0	JUMP,NE 20$	LIB	?NOBUCAR	POPM.L	D0..D5,A3,A4	RET;-----------\\; DBOXSCROLL >;===========/; Affiche l'ascenseur pour le contrle de la vitesse.; in	-; out	-; mod	D7.WDBOXSCROLL:	PUSHM.L	D3..D5,A3,A5	LOAD.L	A5,#(A6)+OASVIT	; A5 <-- ^variables ascenseur-vitesse	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#1	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#45	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#8+5	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCMARK	SCROLL_	DRAW		; dessine la cage de l'ascenseur	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur	LOAD.L	A3,#R16"TXSCALE	; A3 <-- ^textes	LOAD.W	D4,#10		; D4 <-- longueur	LOAD.W	D3,#2		; D3 <-- nombre	SCROLL_	SCALE	LOAD.L	A3,#0		; A3 <-- pas de textes	LOAD.W	D4,#3		; D4 <-- longueur	LOAD.W	D3,#10		; D3 <-- nombre	SCROLL_	SCALE	POPM.L	D3..D5,A3,A5	RET;---------\\; DBOXFULL >;=========/; Affiche la place utilise par le master buffer.; in	-; out	-; mod	D7.WDBOXFULL:	PUSHM.L	D2..D5	LOAD.L	D5,(A6)+ODBOXD5	; D5 <-- canal de la dbox	LOAD.W	D2,#4	DBOX_	GETCO		; D3 <-- coordonne dbut	JUMP,NE 90$	LIB	?BUCAR	LOAD.W	D2,(A0)+ODFCX	SR.W	D2,#1	SUB.W	D3,D2	INC.W	D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#10	ADD.W	D4,D2	ADD.W	D4,D2	DEC.W	D4		; D4 <-- <dxx>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A0)+ODFC2Y	ADD.W	D2,#2	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,D2	INC.W	D3	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,D2	ADD.W	D4,D2	DEC.W	D4		; D4 <-- <dyy>	SWAP.W	D4	SWAP.W	D3	LOAD.W	D5,D4	LOAD.L	D2,(A6)+OLMBUF	SR.L	D2,#4	MUL.WU	D5,D2	LOAD.L	D2,(A6)+OMMBUF	SR.L	D2,#4	DIV.WU	D5,D2		; D5 <-- lg relative utilise	PUSHM.L	D3,D4	LOAD.L	D3,#H'DD77DD77	LOAD.L	D4,D3	LIB	?DRMDEF		; dfini une trame fonce	POPM.L	D3,D4	PUSH.W	D4	LOAD.W	D4,D5	LOAD.W	D2,#SETDOT	; D2 <-- mode	LIB	?DRMATRIX	; marque la partie remplie	POP.W	D4	PUSHM.L	D3,D4	LOAD.L	D3,#H'44114411	LOAD.L	D4,D3	LIB	?DRMDEF		; dfini une trame claire	POPM.L	D3,D4	ADD.W	D3,D5	SUB.W	D4,D5	LOAD.W	D2,#SETDOT	; D2 <-- mode	LIB	?DRMATRIX	; marque la partie vide	LOAD.W	D2,#CLRDOT	; D2 <-- mode	LIB	?DRMATRIX	; marque la partie vide	LIB	?NOBUCAR90$:	POPM.L	D2..D5	RET;--------\\; DBOXINV >;========/; Inverse une touche dans une dbox.; in	D2.W	rang ODBBOX  inverser; out	-; mod	D7.WDBOXINV:	PUSHM.L	D2..D5	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfini une trame pleine	LOAD.L	D5,(A6)+ODBOXD5	; D5 <-- canal de la dbox	DBOX_	GETCO		; D3 <-- coordonne dbut	JUMP,NE 90$	LOAD.W	D2,(A0)+ODFCX	SR.W	D2,#1	SUB.W	D3,D2	INC.W	D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#8	ADD.W	D4,D2	ADD.W	D4,D2	DEC.W	D4		; D4 <-- <dxx>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A0)+ODFC2Y	ADD.W	D2,#2	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,D2	INC.W	D3	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,D2	ADD.W	D4,D2	DEC.W	D4		; D4 <-- <dyy>	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,#INVDOT	; D2 <-- mode	LIB	?DRMATRIX	; inverse la touche90$:	POPM.L	D2..D5	RET	.END