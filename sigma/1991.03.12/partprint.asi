	.SBTTL	PARTPRINT; Bits pour les tranches verticales  imprimer; --------------------------------------------BIMTITRE=	0		; imprime le titreBIMDEBUT=	1		; dbut d'une ligneBIMTRAIT=	2		; imprime les traits verticaux tout  gaucheBIMCLEF	=	3		; imprime les clefsBIMALT	=	4		; imprime les altrationsBIMCALE	=	5		; imprime les calesBIMBARREG=	6		; imprime les barres de gaucheBIMNOTE	=	7		; imprime les notesBIMBARRED=	8		; imprime les barres de droiteBIMFIN	=	9		; fin de l'impressionDOPRINT:	TEST.L	(A6)+OCAPRINT	; module PRINT charg ?	JUMP,EQ ERROR		; non => ERROR	CALL	PUTTEXTE	; texte en dition --> mesure courante	CALL	_WAITMOUSE	; souris: met le sablier	CALL	_NORMMOUSE	; souris: remet la flcheLOOP$:	CALL	DBOXPRINT	; choix de l'impression ...	JUMP,NE ERROR	COMP.W	D3,#F7		; choix ?	JUMP',EQ CHOIX$	COMP.W	D3,#F4		; vrifie ?	JUMP',EQ VERIF$	COMP.W	D3,#F1		; imprime ?	JUMP,NE MAINPRINT$:	CALL	STATUSPRINT	; lit le status de l'imprimante	JUMP,NE IOERROR	CLR.B	(A6)+OVERIF	CALL	ALLPRINT	; imprime ...	JUMP,NE IOERROR	JUMP	MAINVERIF$:	CALL	STATUSPRINT	; lit le status de l'imprimante	JUMP,NE IOERROR	CALL	ALLVERIF	; hop, on vrifie ..	JUMP,EQ LOOP$	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit !	JUMP	LOOP$CHOIX$:	CLR.L	D3		; D3 <-- mode	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	SELECTION	; slection pour l'imprimante ...	JUMP,NE	IOERROR	LOAD.L	A4,#(A6)+ONPRES	; A4 <-- ^buffer pour nom prsentation	PRINTAX_ GETPRES	; ONPRES <-- prsentation choisie	JUMP	MAIN;---------\\; ALLPRINT >;=========/; Imprime toute la partition.; in	-; out	D7.W	erreur; mod	D7.WALLPRINT:	PUSHM.L	D2..D4	TSET.B	(A6)+OFLAGS:#BPRINT ; signal impression en cours	CALL	_WAITMOUSE	; souris: met le sablier	CALL	OPEPRINT	; ouvre l'imprimante	JUMP,NE 99$	PUSHM.L	D0,D1	PUSH.W	(A6)+ONCLEF	LOAD.W	D0,(A6)+ONCLEF	TCLR.L	D0:#SKCGRILLE	; cache la grille pendant l'impression	LOAD.W	(A6)+ONCLEF,D0	CLR.W	D0		; D0 <-- dbut si imprime tout	LOAD.W	D1,#999		; D1 <-- fin si imprime tout	LOAD.L	D4,(A6)+OFAPRI	TEST.L	D4:#BFAIDEA	JUMP',BC 10$	LOAD.W	D0,(A6)+OIMFM	; D0 <-- de ...	LOAD.W	D1,(A6)+OIMLM	; D1 <--   ...	DEC.W	D0	DEC.W	D110$:	LOAD.W	D2,(A6)+OMESC	; D2 <-- no mesure o l'on est	LOAD.W	D4,D0	CALL	GOMESURE	; va dans la premire mesure	INC.W	D1		; D1 <-- le "" est non compris !	SUB.W	D1,D0		; D1 <-- nb de mesure(s)  imprimer	JUMP',LS 90$	LOAD.W	(A6)+OIMNM,D1	; mj nb de mesure(s)  imprimer	CLR.W	(A6)+OIMPN	; init le compteur de pages	CLR.W	(A6)+OIMPV	; init position verticale dans page	CALL	TITLEPRINT	; imprime le titre	JUMP',NE 90$	CALL	SBTTLPRINT	; imprime le sous-titre	JUMP',NE 90$20$:	CALL	LINEPRINT	; imprime une ligne	JUMP,EQ 20$	COMP.W	D7,#ERSEOB	; fini ?	JUMP',NE 90$		; non => 90$	CLR.W	D7		; oui => ok90$:	POP.W	(A6)+ONCLEF	; remet la grille comme avant	POPM.L	D0,D1	PUSH.W	D7	CALL	CLOPRINT	; ferme l'imprimante	LOAD.W	D4,D2	CALL	GOMESURE	; retourne dans la mesure initiale	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	97$		; oui => 97$	CALL	REFAIT		; puis redessine-la97$:	POP.W	D799$:	TCLR.B	(A6)+OFLAGS:#BPRINT ; impression termine	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TITLEPRINT >;-----------/; Imprime le titre ventuel.; in	(A6)+OIMPV.W	position verticale dans page; out	(A6)+OIMPV.W	nouvelle position;	D7.W		erreur; mod	D7.WTITLEPRINT:	PUSHM.L	D0..D4,A2..A4	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OIMTM	; titre existe ?	JUMP,EQ 90$		; non => 90$				; oui =>	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	15$		; oui => 15$	CALL	_CCMO		; enlve la souris	LOAD.L	A4,(A6)+OIMPT	LOAD.L	A4,#(A4)+LGHIMA	LOAD.W	D4,(A6)+OIMIX	MUL.WU	D4,(A6)+OIMTY	; D4 <-- nb bytes pour une ligne10$:	CLR.B	(A4+)		; buffer image <-- tout blanc	DEC.L	D4	JUMP,NE 10$15$:	LOAD.L	A3,#(A6)+OIMTM	; A3 <-- ^titre	LOAD.L	A4,#R16"00$	; A4 <-- ^nom du gencar	LOAD.W	D3,#2		; D3 <-- centr	CALL	TEXTPRINT	; buffer image <-- titre	TEST.B	(A6)+OIMEM	; diteur existe ?	JUMP',NE 30$		; oui => 30$	TEST.B	(A6)+OIMAM	; auteur existe ?	JUMP',EQ 32$		; non => 32$30$:				; oui =>	ADD.W	D1,#10		; D1 <-- p'tite place entre titre et sous-titre32$:	ADD.W	(A6)+OIMPV,D1	; init nouvelle position verticale	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	90$		; oui => 90$	LOAD.L	A4,(A6)+OIMPT	CALL	ZOOMPRINT	LOAD.W	(A4)+OIMDLX,(A6)+OIMTX	LOAD.W	(A4)+OIMDLY,D1	LOAD.W	D4,D1	MUL.WU	D4,(A6)+OIMIX	LOAD.L	(A4)+OIMNBB,D4	ADD.L	D4,#LGHIMA	; D4 <-- ajoute place pour en-tte	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	WRPRINT		; imprime le titre90$:	POPM.L	D0..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.ASCIZ	"Titre"		; nom du gencar	.EVEN;-----------\\; SBTTLPRINT >;-----------/; Imprime le sous-titre ventuel (diteur et auteur).; in	(A6)+OIMPV.W	position verticale dans page; out	(A6)+OIMPV.W	nouvelle position;	D7.W		erreur; mod	D7.WSBTTLPRINT:	PUSHM.L	D0..D4,A2..A4	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OIMEM	; diteur existe ?	JUMP',NE 05$		; oui => 05$	TEST.B	(A6)+OIMAM	; auteur existe ?	JUMP,EQ 90$		; non => 90$05$:				; oui =>	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	15$		; oui => 15$	CALL	_CCMO		; enlve la souris	LOAD.L	A4,(A6)+OIMPT	LOAD.L	A4,#(A4)+LGHIMA	LOAD.W	D4,(A6)+OIMIX	MUL.WU	D4,(A6)+OIMTY	; D4 <-- nb bytes pour une ligne10$:	CLR.B	(A4+)		; buffer image <-- tout blanc	DEC.L	D4	JUMP,NE 10$15$:	LOAD.L	A3,#(A6)+OIMEM	; A3 <-- ^diteur	LOAD.L	A4,#R16"00$	; A4 <-- ^nom du gencar	LOAD.W	D3,#1		; D3 <--  gauche	CALL	TEXTPRINT	; buffer image <-- diteur	LOAD.W	D2,D1	LOAD.L	A3,#(A6)+OIMAM	; A3 <-- ^auteur	LOAD.L	A4,#R16"01$	; A4 <-- ^nom du gencar	LOAD.W	D3,#3		; D3 <--  droite	CALL	TEXTPRINT	; buffer image <-- auteur	COMP.W	D1,D2	JUMP',HS 30$	LOAD.W	D1,D2		; D1 <-- hauteur du plus haut des deux30$:	ADD.W	(A6)+OIMPV,D1	; init nouvelle position verticale	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	90$		; oui => 90$	LOAD.L	A4,(A6)+OIMPT	CALL	ZOOMPRINT	LOAD.W	(A4)+OIMDLX,(A6)+OIMTX	LOAD.W	(A4)+OIMDLY,D1	LOAD.W	D4,D1	MUL.WU	D4,(A6)+OIMIX	LOAD.L	(A4)+OIMNBB,D4	ADD.L	D4,#LGHIMA	; D4 <-- ajoute place pour en-tte	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	WRPRINT		; imprime le sous-titre90$:	POPM.L	D0..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.ASCIZ	"Editeur"	; nom du gencar01$:	.ASCIZ	"Auteur"	; nom du gencar	.EVEN;----------\\; TEXTPRINT >;----------/; Imprime un texte du titre ou du sous-titre.; in	A3.L	^texte <0>;	A4.L	^nom du gencar <0> (Titre, Auteur, etc.);	D3.W	justification (1=gauche, 2=centr et 3=droite); out	D1.W	hauteur minimale ncessaire;	D7.W	erreur; mod	D1.L, D7.WTEXTPRINT:	PUSHM.L	D0,D2..D5,A2..A4	LOAD.L	A2,A3		; A2 <-- ^texte	LOAD.W	D5,D3		; D5 <-- justification	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	10$		; oui => 10$	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface la swdo10$:	LOAD.L	A3,A4		; A3 <-- ^nom du gencar	LOAD.L	A4,#(A6)+OBUGC	DGENC_	SEARCH		; cherche le gencar "Editeur"	JUMP',EQ 20$		; ok => 20$	LOAD.L	A4,#(A6)+OBUGC	; pas trouv => prend "Fond"20$:	LOAD.L	D0,(A0)+ODFGCF	; D0 <-- "fst-" initial	LOAD.L	A3,#(A4)+OGCCOD	LOAD.B	(A3),#USEGC	LOAD.W	D3,#4	LIB	?STRING		; utilise le gencar du texte	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	25$		; oui => 25$	CLR.L	D3	LIB	?SETCURS	LOAD.L	A3,A2		; A3 <-- ^texte	LIB	?AFTEXT		; affiche le texte25$:	LOAD.L	A3,A2		; A3 <-- ^texte	CLR.W	D230$:	LOAD.B	D3,(A3+)	JUMP',EQ 32$	LIB	?LGXCAR		; D4 <-- largeur du caractre	ADD.W	D2,D4		; D2 <-- largeur du texte	JUMP	30$32$:	LOAD.W	D1,(A0)+ODFCY	; D1 <-- hauteur de la ligne	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- hauteur	SWAP.W	D2	CLR.W	D3		; D3 <-- position dans l'cran	CLR.W	D4		; D4 <-- position pour caler  gauche	COMP.W	D5,#1		; cal  gauche ?	JUMP',EQ 40$	LOAD.W	D4,(A6)+OIMLX	SUB.W	D4,D2		; D4 <-- position pour caler  droite	COMP.W	D5,#3		; cal  droite ?	JUMP',EQ 40$	SR.W	D4,#1		; D4 <-- position pour centrer40$:	LOAD.W	D5,#2^BIMTITRE	CALL	XFERPRINT	; buffer image <-- texte	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	D0,#USEGC	RR.L	D0,#8		; D0 <-- "<usegc>fst"	LOAD.L	(A3)+0,D0	LOAD.W	D3,#4	LIB	?STRING		; remet le gencar initial	CALL	_SCMO		; remet la souris	POPM.L	D0,D2..D5,A2..A4	RET;----------\\; LINEPRINT >;----------/; Imprime toute une ligne, avec un maximum de mesures.; in	(A6)+OIMPV.W	position verticale dans page; out	(A6)+OIMPV.W	nouvelle position;	D7.W		erreur (EREOB si fini); mod	D7.WLINEPRINT:	PUSHM.L	D0..D5,A2..A4	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	05$		; oui => 05$	LOAD.L	A4,(A6)+OIMPT	LOAD.L	A4,#(A4)+LGHIMA	LOAD.W	D4,(A6)+OIMIX	MUL.WU	D4,(A6)+OIMTY	; D4 <-- nb bytes pour une ligne04$:	CLR.B	(A4+)		; buffer image <-- tout blanc	DEC.L	D4	JUMP,NE 04$05$:	CALL	JUQQPRINT	; OIMCX <-- largeur des cales				; D1 <-- hauteur maximale	LOAD.W	D7,#ERSEOB	; D7 <-- c'est fini	TEST.W	D1		; qq chose  imprimer ?	JUMP,EQ 90$		; non => 90$	LOAD.W	D3,(A6)+OIMPV	; D3 <-- position verticale	ADD.W	D3,D1		; D3 <-- nouvelle position verticale	COMP.W	D3,(A6)+OIMPY	; page pleine ?	JUMP',LO 10$		; non => 10$				; oui =>	CLR.W	(A6)+OIMPV	; on est de nouveau tout en haut	INC.W	(A6)+OIMPN	; incrmente le compteur de pages	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	10$		; oui => 10$	LOAD.L	A4,#(A6)+OBDIS	LOAD.L	D4,#1	LOAD.B	(A4),#EOP	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	WRPRINT		; jecte la page (zoupppp...)	JUMP,NE 90$10$:	PUSH.W	D1		; stack <-- hauteur imprime	CLR.W	D0		; D0 <-- position dans la ligne	CLR.W	D1		; D1 <-- hauteur maximale	LOAD.L	D2,#-1		; D2 <-- anciennes clefs	LOAD.L	D3,D2		; D3 <-- anciennes altrations	CLR.W	(A6)+OIMOM	; old map <-- rien20$:	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	LOAD.L	A3,#(A4)+OMELP	; A3 <-- ^table des portes	CLR.W	D5		; D5 <-- encore aucune partie  imprimer	LOAD.L	D4,D2		; D4 <-- anciennes clefs	CALL	GETCPRINT	; D2 <-- nouvelles clefs	COMP.L	D4,D2		; clefs changes ?	JUMP',EQ 30$		; non => 30$	TSET.L	D5:#BIMCLEF	; D5 <-- imprime les clefs	TSET.L	D5:#BIMALT	; D5 <-- imprime les altrations30$:	LOAD.L	D4,D3		; D4 <-- anciennes altrations	CALL	GETAPRINT	; D3 <-- nouvelles altrations	COMP.L	D4,D3		; altrations changes ?	JUMP',EQ 35$		; non => 35$	TSET.L	D5:#BIMALT	; D5 <-- imprime les altrations35$:	TSET.L	D5:#BIMNOTE	; D5 <-- imprime les notes	CALL	IFBAPRINT	; D5 <-- avec/sans barres gauche/droite	CALL	XFQQPRINT	; buffer image <-- mesure	LOAD.W	(A6)+OIMOM,D5	; old map <-- ancien map	TEST.W	D7	JUMP',EQ 50$	LOAD.W	D7,#ERSEOB	DEC.W	(A6)+OIMNM	; encore une mesure  imprimer ?	JUMP',EQ 50$		; non => 50$	CALL	NMESURE		; avance  la mesure suivante	JUMP,EQ 20$50$:	LOAD.W	D5,D7		; D5 <-- ok/fini	LOAD.W	D2,(A6)+OIMLX	SUB.W	D2,D0		; D2 <-- place inutilise  droite	TEST.B	(A6)+OFAPRI:#BFAIFULL-24 ; dernires portes compltes ?	JUMP',BS 60$		; oui => 60$	TEST.W	D5		; fini ?	JUMP',EQ 60$		; non => 60$	CLR.W	D2		; oui => termine tout de suite60$:	POP.W	D1		; D1 <-- hauteur imprime	CALL	XFFFPRINT	; buffer image <-- fin	ADD.W	(A6)+OIMPV,D1	; voil, on descend dans la page	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	85$		; oui => 85$	LOAD.L	A4,(A6)+OIMPT	CALL	ZOOMPRINT	LOAD.W	(A4)+OIMDLX,(A6)+OIMTX	LOAD.W	(A4)+OIMDLY,D1	LOAD.W	D4,D1	MUL.WU	D4,(A6)+OIMIX	LOAD.L	(A4)+OIMNBB,D4	ADD.L	D4,#LGHIMA	; D4 <-- ajoute place pour en-tte	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	WRPRINT		; imprime la ligne	JUMP',NE 90$85$:	LOAD.W	D7,D5		; D7 <-- ok/fini90$:	POPM.L	D0..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; GETCPRINT >;----------/; Donne toutes les clefs d'une mesure dans un registre.; in	A4.L	^dbut de la mesure;	A3.L	^table des portes; out	D2.L	clefs; mod	D2.LGETCPRINT:	PUSHM.L	D3,A3	CLR.L	D2	LOAD.W	D3,#MAXLP-110$:	SL.L	D2,#8	LOAD.B	D2,(A3)+OLPTYP	; D2 <-- ICOPSOL/PFA/VIDE	LOAD.L	A3,#(A3)+LLP	DECJ.W,NMO D3,10$	POPM.L	D3,A3	RET;----------\\; GETAPRINT >;----------/; Donne l'altration d'une mesure dans un registre.; in	A4.L	^dbut de la mesure;	A3.L	^table des portes; out	D3.L	altrations; mod	D3.LGETAPRINT:	CLR.L	D3	LOAD.B	D3,(A4)+OMENA	; D3 <-- 0..7	SL.W	D3,#8	JUMP',EQ 90$	LOAD.B	D3,(A4)+OMETA	; D3 <-- #/b90$:	RET;----------\\; JUQQPRINT >;----------/; Calcul les cales  ajouter pour justifier une ligne de mesures,; et la hauteur maximale parmi toutes les mesures.; in	A4.L		^dbut de la mesure;	A3.L		^table des portes; out	(A6)+OIMCX.W	largeur des cales  mettre avant et aprs;	(A6)+OIMCXR.W	reste de la division;	D1.W		hauteur maximale; mod	D1.L, D7.WJUQQPRINT:	PUSHM.L	D0,D2..D6,A3,A4	CLR.W	(A6)+OIMCX	; pas encore de cale !	CLR.W	(A6)+OIMCXR	CLR.W	D0		; D0 <-- position dans la ligne	CLR.L	D1		; D1 <-- nb de mesures	CLR.W	D6		; D6 <-- hauteur maximale	LOAD.L	D2,#-1		; D2 <-- anciennes clefs	LOAD.L	D3,D2		; D3 <-- anciennes altrations20$:	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	LOAD.L	A3,#(A4)+OMELP	; A3 <-- ^table des portes	CLR.W	D5		; D5 <-- encore aucune partie  imprimer	LOAD.L	D4,D2		; D4 <-- anciennes clefs	CALL	GETCPRINT	; D2 <-- nouvelles clefs	COMP.L	D4,D2		; clefs changes ?	JUMP',EQ 30$		; non => 30$	TSET.L	D5:#BIMCLEF	; D5 <-- imprime les clefs	TSET.L	D5:#BIMALT	; D5 <-- imprime les altrations30$:	LOAD.L	D4,D3		; D4 <-- anciennes altrations	CALL	GETAPRINT	; D3 <-- nouvelles altrations	COMP.L	D4,D3		; altrations changes ?	JUMP',EQ 35$		; non => 35$	TSET.L	D5:#BIMALT	; D5 <-- imprime les altrations35$:	TSET.L	D5:#BIMNOTE	; D5 <-- imprime les notes	CALL	IFBAPRINT	; D5 <-- avec/sans barres gauche/droite	CALL	LGQQPRINT	; D4 <-- largeur de la mesure	ADD.W	D4,D0	COMP.W	D4,(A6)+OIMLX	; ligne pleine ?	JUMP',HS 50$		; oui => 50$				; non =>	LOAD.W	D0,D4		; D0 <-- position pour nouvelle mesure	LOAD.W	D4,(A4)+OMEMAX;;?	ADD.W	D4,#LYPORTEE	; D4 <-- hauteur de la porte	COMP.W	D4,(A0)+ODFFDY	JUMP',LS 40$	LOAD.W	D4,(A0)+ODFFDY40$:	COMP.W	D6,D4	JUMP',HS 42$	LOAD.W	D6,D4		; D6 <-- hauteur maximale42$:	INC.W	D1		; D1 <-- une mesure de plus	LOAD.L	A3,(A6)+OPFT	COMP.L	A3,(A6)+OPFB	; encore une mesure juste aprs ?	JUMP',EQ 46$		; non => 46$	CALL	NMESURE	JUMP	20$46$:	TSET.L	D1:#16	TEST.B	(A6)+OFAPRI:#BFAIJUD-24 ; justifie la dernire ligne ?	JUMP',BC 70$		; non => 70$50$:	CLR.L	D4	LOAD.W	D4,(A6)+OIMLX	SUB.W	D4,D0		; D4 <-- place en trop	LOAD.W	D0,D1	JUMP',EQ 70$	SL.W	D0,#1		; D0 <-- nb mesures *2 (cales avant et aprs)	DIV.WU	D4,D0	LOAD.W	(A6)+OIMCX,D4	SWAP.W	D4	LOAD.W	(A6)+OIMCXR,D470$:	TEST.L	D1:#16	JUMP',BC 80$	DEC.W	D180$:	TEST.W	D1	JUMP',EQ 90$	CALL	PMESURE		; recule les mesures avances	DEC.W	D1	JUMP	80$90$:	LOAD.W	D1,D6		; D1 <-- hauteur maximale	POPM.L	D0,D2..D6,A3,A4	RET;----------\\; IFBAPRINT >;----------/; Regarde s'il faut imprimer les barres gauche et/ou droite; en fonction des signes de reprise de la mesure courante.; in	D5.B	map des tranches  dessiner; out	D5.B	map des tranches  dessiner avec/sans barres gauche/droite; mod	D5.L, D7.WIFBAPRINT:	PUSHM.L	D4,A4	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	LOAD.L	D4,(A4)+OMEREP	; D4 <-- signes de reprise	TCLR.L	D5:#BIMTRAIT	; D5 <-- pas de traits verticaux	TSET.L	D5:#BIMBARREG	; D5 <-- imprime les barres  gauche	TEST.L	D4:#BREPDBP	JUMP',BS 20$	TEST.L	D4:#BREPDB	JUMP',BS 20$	TEST.L	D4:#BREPPART1	JUMP',BS 20$	TEST.L	D4:#BREPPART2	JUMP',BS 20$	TEST.L	D4:#BREPPART3	JUMP',BS 20$	TEST.L	D4:#BREPPARTM	JUMP',BS 20$	TEST.L	D4:#BREPPARTF	JUMP',BS 20$	TSET.L	D5:#BIMTRAIT	; D5 <-- imprime les traits verticaux	TCLR.L	D5:#BIMBARREG	; D5 <-- pas de barres  gauche20$:	TSET.L	D5:#BIMBARRED	; D5 <-- imprime les barres  droite	TEST.L	D4:#BREPBDP	JUMP',BS 40$	TEST.L	D4:#BREPBD	JUMP',BS 40$	TEST.L	D4:#BREPBB	JUMP',BS 40$	TEST.L	D4:#BREPPARTF	JUMP',BS 40$	TCLR.L	D5:#BIMBARRED	; D5 <-- pas de barre  droite40$:	TEST.L	D5:#BIMCLEF	; imprime les clefs ?	JUMP',BS 50$	TEST.L	D5:#BIMALT	; imprime les altrations ?	JUMP',BC 90$50$:	TSET.L	D5:#BIMTRAIT	; D5 <-- imprime les traits verticaux90$:	POPM.L	D4,A4	RET;----------\\; XFQQPRINT >;----------/; Transfert dans le buffer image diffrentes tranches; verticales de la mesure.; in	A4.L	^dbut de la mesure;	A3.L	^table des portes;	D0.W	position X;	D5.B	map des tranches  dessiner; out	D0.W	position suivante X;	D7.W	ok => y'a plus la place; mod	D0.L, D7.WXFQQPRINT:	PUSHM.L	D1..D4	PUSH.L	(A4)+OMEREP	; sauve les signes de reprise originaux	CALL	LGQQPRINT	; D4 <-- largeur de la mesure	ADD.W	D4,(A6)+OIMCX	ADD.W	D4,(A6)+OIMCX	; D4 <-- largeur avec les cales	ADD.W	D4,(A6)+OIMCXR	CLR.W	D7		; D7 <-- y'a plus la place	ADD.W	D4,D0	COMP.W	D4,(A6)+OIMLX	; ligne pleine ?	JUMP,HI 90$		; oui => 90$; Si la mesure contient une partie de reprise (1. 2. 3. M ou F), regarde; s'il faut imprimer une barre toute simple au dbut de la mesure.	LOAD.L	D4,(A4)+OMEREP	; D4 <-- signes de reprise	TCLR.L	D4:#BREPB	TEST.L	D4:#BREPPART1	; partie de reprise ?	JUMP',BS 04$		; oui => 04$	TEST.L	D4:#BREPPART2	JUMP',BS 04$	TEST.L	D4:#BREPPART3	JUMP',BS 04$	TEST.L	D4:#BREPPARTM	JUMP',BS 04$	TEST.L	D4:#BREPPARTF	JUMP',BC 05$04$:	TEST.W	(A6)+OIMOM	; premire mesure de la ligne ?	JUMP',EQ 05$		; oui => 05$	TEST.L	D4:#BREPDBP	; dj une grosse barre ?	JUMP',BS 05$		; oui => 05$	TEST.L	D4:#BREPDB	JUMP',BS 05$	LOAD.W	D3,(A6)+OIMOM	TEST.L	D3:#BIMBARRED	; barre  droite dans mesure prcdente ?	JUMP',BS 05$		; oui => 05$				; non =>	TSET.L	D4:#BREPB	; D4 <-- met une barre toute simple au dbut05$:	LOAD.L	(A4)+OMEREP,D4	; mj. les signes de reprise	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	07$		; oui => 07$	CALL	_CCMO		; enlve la souris	CALL	DESDEBUT	; efface tout	CALL	DESPORTEES	; dessine les portes de la mesure	CALL	DESRESTE	; dessine l'altration  la clef07$:	LOAD.W	D1,(A4)+OMEMAX;;?	ADD.W	D1,#LYPORTEE	; D1 <-- hauteur de la porte	COMP.W	D1,(A0)+ODFFDY	JUMP',LS 10$	LOAD.W	D1,(A0)+ODFFDY10$:	TEST.W	(A6)+OIMOM	; premire mesure de la ligne ?	JUMP',NE 15$		; non => 15$	CALL	GLTPRINT	; D2/D3 <-- largeur/position traits verticaux	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- hauteur	SWAP.W	D2	LOAD.W	D4,D0		; D4 <-- dbut dans buffer	PUSH.W	D5	LOAD.W	D5,#2^BIMDEBUT	CALL	XFERPRINT	; buffer image <-- signal dbut de la ligne	POP.W	D515$:	TEST.L	D5:#BIMTRAIT	JUMP',BC 20$	CALL	GLTPRINT	; D2/D3 <-- largeur/position traits verticaux	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- hauteur	SWAP.W	D2	LOAD.W	D4,D0		; D4 <-- dbut dans buffer	PUSH.W	D5	LOAD.W	D5,#2^BIMTRAIT	CALL	XFERPRINT	; buffer image <-- traits verticaux	POP.W	D5	ADD.W	D0,D2		; D0 <-- position suivante20$:	TEST.L	D5:#BIMCLEF	JUMP',BC 30$	CALL	GLCPRINT	; D2/D3 <-- largeur/position clefs	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- hauteur	SWAP.W	D2	LOAD.W	D4,D0		; D4 <-- dbut dans buffer	PUSH.W	D5	LOAD.W	D5,#2^BIMCLEF	CALL	XFERPRINT	; buffer image <-- clefs	POP.W	D5	ADD.W	D0,D2		; D0 <-- position suivante30$:	TEST.L	D5:#BIMALT	JUMP',BC 40$	CALL	GLAPRINT	; D2/D3 <-- largeur/position altrations	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- hauteur	SWAP.W	D2	LOAD.W	D4,D0		; D4 <-- dbut dans buffer	PUSH.W	D5	LOAD.W	D5,#2^BIMALT	CALL	XFERPRINT	; buffer image <-- altrations	POP.W	D5	ADD.W	D0,D2		; D0 <-- position suivante40$:	TEST.L	D5:#BIMBARREG	JUMP',BC 50$	CALL	GLGPRINT	; D2/D3 <-- largeur/position barres de gauche	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- hauteur	SWAP.W	D2	LOAD.W	D4,D0		; D4 <-- dbut dans buffer	PUSH.W	D5	LOAD.W	D5,#2^BIMBARREG	CALL	XFERPRINT	; buffer image <-- barres de gauche	POP.W	D5	ADD.W	D0,D2		; D0 <-- position suivante50$:	CALL	XFCAPRINT	; buffer image <-- cale	TEST.L	D5:#BIMNOTE	JUMP',BC 60$	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	52$		; oui => 52$	CALL	DESNOTES	; dessine les notes de la mesure52$:	CALL	GLNPRINT	; D2/D3 <-- largeur/position notes	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- hauteur	SWAP.W	D2	LOAD.W	D4,D0		; D4 <-- dbut dans buffer	PUSH.W	D5	LOAD.W	D5,#2^BIMNOTE	CALL	XFERPRINT	; buffer image <-- notes	POP.W	D5	ADD.W	D0,D2		; D0 <-- position suivante60$:	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	62$		; oui => 62$	CALL	DESDEBUT	; efface tout	CALL	DESPORTEES	; dessine les portes de la mesure62$:	CALL	XFCAPRINT	; buffer image <-- cale	TEST.L	D5:#BIMBARRED	JUMP',BC 70$	CALL	GLDPRINT	; D2/D3 <-- largeur/position barres de droite	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- hauteur	SWAP.W	D2	LOAD.W	D4,D0		; D4 <-- dbut dans buffer	PUSH.W	D5	LOAD.W	D5,#2^BIMBARRED	CALL	XFERPRINT	; buffer image <-- barres de droite	POP.W	D5	ADD.W	D0,D2		; D0 <-- position suivante70$:	CALL	GLTPRINT	; D2/D3 <-- largeur/position traits verticaux	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- hauteur	SWAP.W	D2	LOAD.W	D4,D0		; D4 <-- dbut dans buffer	PUSH.W	D5	LOAD.W	D5,#2^BIMFIN	CALL	XFERPRINT	; buffer image <-- signal la fin de la mesure	POP.W	D5	CALL	_SCMO		; remet la souris	LOAD.W	D7,#1		; D7 <-- y'a la place90$:	POP.L	(A4)+OMEREP	; reprend les signes de reprise originaux	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; LGQQPRINT >;----------/; Calcul la largeur des diffrentes tranches verticales de la mesure.; in	A4.L	^dbut de la mesure;	A3.L	^table des portes;	D5.B	map des tranches  dessiner; out	D4.W	largeur des tranches de la mesure; mod	D4.L, D7.WLGQQPRINT:	PUSHM.L	D2,D3	CLR.W	D4	TEST.L	D5:#BIMTRAIT	JUMP',BC 10$	CALL	GLTPRINT	; D2 <-- largeur traits verticaux	ADD.W	D4,D210$:	TEST.L	D5:#BIMCLEF	JUMP',BC 11$	CALL	GLCPRINT	; D2 <-- largeur clefs	ADD.W	D4,D211$:	TEST.L	D5:#BIMALT	JUMP',BC 12$	CALL	GLAPRINT	; D2 <-- largeur altrations	ADD.W	D4,D212$:	TEST.L	D5:#BIMBARREG	JUMP',BC 13$	CALL	GLGPRINT	; D2 <-- largeur barres de gauche	ADD.W	D4,D213$:	TEST.L	D5:#BIMNOTE	JUMP',BC 14$	CALL	GLNPRINT	; D2 <-- largeur notes	ADD.W	D4,D214$:	TEST.L	D5:#BIMBARRED	JUMP',BC 15$	CALL	GLDPRINT	; D2 <-- largeur barres de droite	ADD.W	D4,D215$:	POPM.L	D2,D3	RET;----------\\; XFCAPRINT >;----------/; Transfert une cale dans le buffer image sous la forme de portes vides.; in	A4.L	^dbut de la mesure;	A3.L	^table des portes;	D0.W	position X;	D1.W	hauteur maximale; out	D0.W	position X suivante; mod	D0.L, D7.WXFCAPRINT:	PUSHM.L	D1..D5	LOAD.W	D2,(A6)+OIMCX	; D2 <-- largeur	ADD.W	D2,(A6)+OIMCXR	; D2 <-- ajoute le reste	JUMP,EQ 90$	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- hauteur	SWAP.W	D2	LOAD.W	D4,D0		; D4 <-- dbut dans buffer	LOAD.W	D1,D2		; D1 <-- largeur  prolonger	LOAD.W	D2,(A4)+OMELG	SUB.W	D2,#MXFIXE+1+16+16 ; D2 <-- longueur maximale dessinable20$:	COMP.W	D2,D1	JUMP',LS 30$	LOAD.W	D2,D130$:	LOAD.W	D3,#MXPORTEE+MXFIXE+16	LOAD.W	D5,#2^BIMCALE	CALL	XFERPRINT	; buffer image <-- prolonge les portes	ADD.W	D4,D2	SUB.W	D1,D2		; D1 <-- largeur restante	JUMP,NE 20$	ADD.W	D0,(A6)+OIMCX	; D0 <-- position suivante	ADD.W	D0,(A6)+OIMCXR	CLR.W	(A6)+OIMCXR	; voil, le reste a t pris en compte !90$:	POPM.L	D1..D5	RET;----------\\; XFFFPRINT >;----------/; Transfert dans le buffer image la fin de la ligne; sous la forme de portes vides.; in	A4.L	^dbut de la mesure;	A3.L	^table des portes;	D0.W	position X;	D1.W	hauteur maximale;	D2.W	longueur; out	-; mod	D7.WXFFFPRINT:	PUSHM.L	D0..D5,A4	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	10$		; oui => 10$	CALL	_CCMO		; enlve la souris	CALL	DESDEBUT	; efface tout	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	PUSH.L	(A4)+OMEREP	CLR.L	(A4)+OMEREP	; ne dessine pas les parties de reprises !	CALL	DESPORTEES	; dessine les portes de la mesure	POP.L	(A4)+OMEREP10$:	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- hauteur	SWAP.W	D2	LOAD.W	D4,D0		; D4 <-- dbut dans buffer	LOAD.W	D1,D2		; D1 <-- largeur  prolonger	JUMP',EQ 50$	LOAD.W	D2,(A4)+OMELG	SUB.W	D2,#MXFIXE+1+16	; D2 <-- longueur maximale dessinable20$:	COMP.W	D2,D1	JUMP',LS 30$	LOAD.W	D2,D130$:	LOAD.W	D3,#MXPORTEE+MXFIXE	LOAD.W	D5,#2^BIMCALE	CALL	XFERPRINT	; buffer image <-- prolonge les portes	ADD.W	D4,D2	SUB.W	D1,D2		; D1 <-- largeur restante	JUMP,NE 20$50$:	LOAD.W	D2,#1	LOAD.W	D3,#MXPORTEE	DEC.W	D4	LOAD.W	D5,#2^BIMCALE	CALL	XFERPRINT	; buffer image <-- traits verticaux	CALL	_SCMO		; remet la souris	POPM.L	D0..D5,A4	RET;---------\\; GLTPRINT >;---------/; Donne la largeur des traits verticaux au dbut.; in	A4.L	^dbut de la mesure;	A3.L	^table des portes;	D5.B	map des tranches  dessiner; out	D2.W	largeur;	D3.W	position; mod	D2.L, D3.L, D7.WGLTPRINT:	LOAD.W	D2,#5	LOAD.W	D3,#MXPORTEE	RET;---------\\; GLCPRINT >;---------/; Donne la largeur des clefs.; in	A4.L	^dbut de la mesure;	A3.L	^table des portes;	D5.B	map des tranches  dessiner; out	D2.W	largeur;	D3.W	position; mod	D2.L, D3.L, D7.WGLCPRINT:	LOAD.W	D2,#LXICONE+5	LOAD.W	D3,#MXPORTEE+4	RET;---------\\; GLAPRINT >;---------/; Donne la largeur des altrations  la clef.; in	A4.L	^dbut de la mesure;	A3.L	^table des portes;	D5.B	map des tranches  dessiner; out	D2.W	largeur;	D3.W	position; mod	D2.L, D3.L, D7.WGLAPRINT:	CLR.W	D2	LOAD.B	D2,(A4)+OMENA	JUMP',EQ 90$	MUL.WU	D2,#10	LOAD.W	D3,#MXPORTEE+12+LXICONE-390$:	RET;---------\\; GLGPRINT >;---------/; Donne la largeur des barres de gauche.; in	A4.L	^dbut de la mesure;	A3.L	^table des portes;	D5.B	map des tranches  dessiner; out	D2.W	largeur;	D3.W	position; mod	D2.L, D3.L, D7.WGLGPRINT:	CLR.W	D2	TEST.L	D5:#BIMBARREG	JUMP',BC 90$	LOAD.W	D2,#16	LOAD.W	D3,#MXPORTEE+MXFIXE-LXPORTEE-590$:	RET;---------\\; GLNPRINT >;---------/; Donne la largeur des notes.; in	A4.L	^dbut de la mesure;	A3.L	^table des portes;	D5.B	map des tranches  dessiner; out	D2.W	largeur;	D3.W	position; mod	D2.L, D3.L, D7.WGLNPRINT:	LOAD.W	D2,(A4)+OMELG	SUB.W	D2,#MXFIXE-LXPORTEE-5	LOAD.W	D3,#MXPORTEE+MXFIXE-LXPORTEE-5	TEST.L	D5:#BIMBARREG	JUMP',BC 30$	ADD.W	D3,#16	SUB.W	D2,#1630$:	TEST.L	D5:#BIMBARRED	JUMP',BC 40$	SUB.W	D2,#1640$:	RET;---------\\; GLDPRINT >;---------/; Donne la largeur des barres de droite.; in	A4.L	^dbut de la mesure;	A3.L	^table des portes;	D5.B	map des tranches  dessiner; out	D2.W	largeur;	D3.W	position; mod	D2.L, D3.L, D7.WGLDPRINT:	CLR.W	D2	TEST.L	D5:#BIMBARRED	JUMP',BC 90$	LOAD.W	D2,#16	LOAD.W	D3,(A4)+OMELG	ADD.W	D3,#MXPORTEE-1690$:	RET;----------\\; XFERPRINT >;----------/; Transfert la mesure visible dans l'cran dans le buffer "image".; >>> NE PAS OUBLIER D'ENLEVER LA SOURIS ! <<<; in	D3.W	position source dans l'cran (x);	D4.W	position destination dans buffer (x);	D2.L	dimensions (dy;dx);	D5.W	tranche verticale imprime; out	-; mod	D7.WXFERPRINT:	PUSHM.L	D2..D4,A3,A4	TEST.W	D2		; largeur nulle ?	JUMP,EQ 90$		; oui => 90$	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	50$		; oui => 50$	TEST.L	D5:#BIMDEBUT	; signal de dbut de ligne ?	JUMP,BS 90$		; oui => 90$ (ignore)	TEST.L	D5:#BIMFIN	; signal de fin ?	JUMP,BS 90$		; oui => 90$ (ignore)	LOAD.L	A3,#(A6)+OBDIS	LOAD.W	(A3)+0,#DRAWRASTER	LOAD.W	(A3)+2,D3	; source: <xx>	CLR.W	(A3)+4		; source: <yy>	CLR.L	(A3)+6		; source: <pppp>	CLR.W	(A3)+10		; source: <ii>	LOAD.W	(A3)+12,D4	; destination: <xx>	CLR.W	(A3)+14		; destination: <yy>	LOAD.L	A4,(A6)+OIMPT	LOAD.L	A4,#(A4)+LGHIMA	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,(A6)+OIMIX ; destination: <ii>	SWAP.W	D2	LOAD.L	(A3)+22,D2	; <dxx> et <dyy>	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; buffer <-- image de la mesure	JUMP	90$50$:				; mode de vrification =>	LOAD.W	D3,(A6)+OIMPV	SWAP.W	D3	LOAD.W	D3,D4		; D3 <-- position	LOAD.L	D4,D2		; D4 <-- dimensions	CLR.L	D2	LOAD.W	D2,D3	ADD.W	D2,(A6)+OIMMXG	DIV.WU	D2,(A6)+OVEFACX	ADD.W	D2,(A6)+OVEPOSX	LOAD.W	D3,D2		; D3 <-- origine en X	SWAP.W	D3	CLR.L	D2	LOAD.W	D2,D3	ADD.W	D2,(A6)+OIMMYS	DIV.WU	D2,(A6)+OVEFACY	ADD.W	D2,(A6)+OVEPOSY	LOAD.W	D3,D2		; D3 <-- origine en Y	SWAP.W	D3	CLR.L	D2	LOAD.W	D2,D4	DIV.WU	D2,(A6)+OVEFACX	LOAD.W	D4,D2		; D4 <-- largeur	SWAP.W	D4	CLR.L	D2	LOAD.W	D2,D4	DIV.WU	D2,(A6)+OVEFACY	LOAD.W	D4,D2		; D4 <-- hauteur	SWAP.W	D4	CLR.L	D2	LOAD.W	D2,(A6)+OIMPN	DIV.WU	D2,(A6)+OVENBX	SWAP.W	D2	MUL.WU	D2,(A6)+OVEECAX	ADD.W	D3,D2		; D3 <-- dans la bonne page en X	SWAP.W	D3	CLR.L	D2	LOAD.W	D2,(A6)+OIMPN	DIV.WU	D2,(A6)+OVENBX	COMP.W	D2,(A6)+OVENBY	JUMP',HS 90$	MUL.WU	D2,(A6)+OVEECAY	ADD.W	D3,D2		; D3 <-- dans la bonne page en Y	SWAP.W	D3	CALL	DESVERIF	; dessine en mignature !90$:	POPM.L	D2..D4,A3,A4	RET;------------\\; STATUSPRINT >;============/; Lit le status de l'imprimante pour connatre les dimensions; du papier, des marges, etc. en points graphiques [pg] et en; supposant un zoom de un.; in	-; out	;	(A6)+OSTPLX.W	largeur du papier [pg];	(A6)+OSTPLY.W	hauteur du papier;	(A6)+OSTPMG.W	marge gauche;	(A6)+OSTPMD.W	marge droite;	(A6)+OSTPMS.W	marge suprieure;	(A6)+OSTPMI.W	marge infrieure;	D7.W		erreur; mod	D7.WSTATUSPRINT:	PUSHM.L	D0..D4,A2..A4	LOAD.L	A2,(A6)+OCAPRINT	LOAD.L	A3,#(A6)+ONPRES	; A3 <-- ^nom de la prsentation	TEST.B	(A3)		; nom existe ?	JUMP',EQ 20$		; non => 20$	PRINTAX_ PUTPRES	; utilise cette prsentation	JUMP,NE 90$20$:	LOAD.L	D4,#LGPRI1	; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OIMST	; A4 <-- ^buffer	PRINTA_	RSTATUS		; OIMST <-- status de l'imprimante	JUMP,NE 90$; Lit les facteurs de conversions et ajuste la valeur si le zoom; est de 2 pour simuler toujours un zoom de 1.;	[status] --> *8 --> /OPRGLX --> [pg]	CLR.L	D0	LOAD.W	D0,(A4)+OPRGLX	CLR.L	D1	LOAD.W	D1,(A4)+OPRGLY	LOAD.W	D7,#ERPRIN	; D7 <-- erreur avec l'imprimante	LOAD.W	D4,(A4)+OPRZ	; D4 <-- facteur de zoom (1..n)	JUMP,EQ 90$	DIV.WU	D0,D4		; D0 <-- facteur en X	DIV.WU	D1,D4		; D1 <-- facteur en Y; Lit les dimensions ncessaires.	LOAD.W	D4,(A4)+OPRLGPH	MUL.WU	D4,#8	DIV.WU	D4,D0	LOAD.W	(A6)+OSTPLX,D4	; mj. largeur du papier	LOAD.W	D4,(A4)+OPRMGG	MUL.WU	D4,#8	DIV.WU	D4,D0	LOAD.W	(A6)+OSTPMG,D4	; mj. marge gauche;;?	LOAD.W	D4,(A4)+OPRMGD;;?	TEST.W	(A4)+OPRBOA;;?	JUMP',EQ 30$	LOAD.W	D4,(A4)+OPRLGPH	SUB.W	D4,(A4)+OPRLGP	SUB.W	D4,(A4)+OPRMGG30$:	MUL.WU	D4,#8	DIV.WU	D4,D0	LOAD.W	(A6)+OSTPMD,D4	; mj. marge droite	LOAD.W	D4,(A4)+OPRHTP	MUL.WU	D4,#8	DIV.WU	D4,D1	LOAD.W	(A6)+OSTPLY,D4	; mj. hauteur du papier	LOAD.W	D4,(A4)+OPRMGS	MUL.WU	D4,#8	DIV.WU	D4,D1	LOAD.W	(A6)+OSTPMS,D4	; mj. marge suprieure	LOAD.W	D4,(A4)+OPRMGI	MUL.WU	D4,#8	DIV.WU	D4,D1	LOAD.W	(A6)+OSTPMI,D4	; mj. marge infrieure	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; OPEPRINT >;---------/; Ouvre l'imprimante et rserve un buffer pour une ligne.; in	-; out	D7.W	erreur; mod	D7.WOPEPRINT:	PUSHM.L	D0,D1,D3,D4,D6,A2..A4	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T 20$		; oui => 20$	CLR.L	D3		; D3 <-- mode	TSET.L	D3:#BPRSILENCE	; D3 <-- n'affiche pas boites commentaires	LOAD.L	A3,#(A6)+OBUFILE; A3 <-- ^nom du fichier	LOAD.L	A4,#(A6)+ONPRES	; A4 <-- ^nom de la prsentation	LOAD.L	A5,#R16"01$	; A5 <-- ^nom du logiciel	LOAD.L	A1,#(A6)+OBUFPRI; A1 <-- ^nom du fichier en sortie	CLR.L	D2		; D2 <-- longueur du document (!)	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	OPPRINT		; ouvre l'impression	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE 90$; Initialise les variables pour les dimensions imprimables.20$:	LOAD.W	D0,#1	LOAD.W	D1,D0	TEST.B	(A6)+OFAPRI:#BFAIZ15-24 ; zoom de 1.5 ?	JUMP',BC 30$	LOAD.W	D0,#2	LOAD.W	D1,#330$:	LOAD.W	D4,(A6)+OSTPLX	SUB.W	D4,(A6)+OSTPMG	SUB.W	D4,(A6)+OSTPMD	; D4 <-- largeur imprimable dans la page	MUL.WU	D4,D0	DIV.WU	D4,D1	SUB.W	D4,#8	LOAD.W	(A6)+OIMLX,D4	LOAD.W	D7,#ERPRIN	; D7 <-- erreur avec l'imprimante (laquelle ??)	COMP.W	D4,(A0)+ODFFDX	; page trop troite ?	JUMP,LO 80$	MUL.WU	D4,D1	DIV.WU	D4,D0	SR.W	D4,#3	INC.W	D4	LOAD.W	(A6)+OIMIX,D4	SL.W	D4,#3	LOAD.W	(A6)+OIMTX,D4	LOAD.W	D4,(A6)+OSTPLY	; D4 <-- hauteur totale de la page	SUB.W	D4,(A6)+OSTPMS	; D4 <-- enlve la marge suprieure	SUB.W	D4,(A6)+OSTPMI	; D4 <-- enlve la marge infrieure	MUL.WU	D4,D0	DIV.WU	D4,D1	LOAD.W	(A6)+OIMPY,D4	COMP.W	D4,(A0)+ODFFDY	; page pas assez haute ?	JUMP,LO 80$	LOAD.W	D4,(A0)+ODFFDY	LOAD.W	(A6)+OIMLY,D4	MUL.WU	D4,D1	DIV.WU	D4,D0	LOAD.W	(A6)+OIMTY,D4	LOAD.W	D4,(A6)+OSTPMG	MUL.WU	D4,D0	DIV.WU	D4,D1	LOAD.W	(A6)+OIMMXG,D4	LOAD.W	D4,(A6)+OSTPMD	MUL.WU	D4,D0	DIV.WU	D4,D1	LOAD.W	(A6)+OIMMXD,D4	LOAD.W	D4,(A6)+OSTPMS	MUL.WU	D4,D0	DIV.WU	D4,D1	LOAD.W	(A6)+OIMMYS,D4	LOAD.W	D4,(A6)+OSTPMI	MUL.WU	D4,D0	DIV.WU	D4,D1	LOAD.W	(A6)+OIMMYI,D4	CLR.W	D7		; 7 <-- ok	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP,T	90$		; oui => 90$	LOAD.W	D4,(A6)+OIMIX	MUL.WU	D4,(A6)+OIMTY	; D4 <-- nb bytes pour une ligne	ADD.L	D4,#LGHIMA	; D4 <-- ajoute place pour en-tte	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour une ligne	JUMP',NE 80$	LOAD.L	(A6)+OIMPT,A4	LOAD.L	A3,A4	LOAD.W	D4,#LGHIMA-160$:	CLR.B	(A3+)		; en-tte <-- met tout  zro	DECJ.W,NMO D4,60$	LOAD.B	(A4)+OIMTYP,#H'81	LOAD.B	(A4)+OIMCOD,#H'00	LOAD.B	(A4)+OIMBIP,#H'01	LOAD.B	(A4)+OIMDIR,#H'02	JUMP'	90$80$:	TEST.B	(A6)+OVERIF	; mode de vrification ?	JUMP',T	90$		; oui => 90$	PUSH.W	D7	CALL	CLOPRINT	; ferme tout	POP.W	D790$:	POPM.L	D0,D1,D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	"SIGMAP"	; nom du logiciel	.EVEN;---------\\; CLOPRINT >;---------/; Libre le buffer et ferme l'imprimante.; in	-; out	-; mod	D7.WCLOPRINT:	PUSHM.L	D1,A2,A4	TEST.L	(A6)+OIMPT	JUMP',EQ 20$	LOAD.L	A4,(A6)+OIMPT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend mmoire pour une ligne	CLR.L	(A6)+OIMPT20$:	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	CLPRINT		; ferme l'imprimante	POPM.L	D1,A2,A4	RET;----------\\; ZOOMPRINT >;----------/; Zoom l'image si ncessaire avant d'imprimer.; in	A4.L	^image;	D1.W	hauteur; out	D1.W	hauteur zoome; mod	D1.L, D7.WZOOMPRINT:	PUSHM.L	D3,A3	TEST.B	(A6)+OFAPRI:#BFAIZ15-24 ; zoom de 1.5 ?	JUMP',BC 90$	MUL.WU	D1,#3	DIV.WU	D1,#2	LOAD.L	A3,#(A4)+LGHIMA	; A3 <-- ^bitmap	LOAD.W	D3,D1		; D3 <-- hauteur	SWAP.W	D3	LOAD.W	D3,(A6)+OIMTX	; D3 <-- largeur	CALL	ZOOM15		; agrandi de 1.590$:	POPM.L	D3,A3	RET	.INS	ZOOM15.ASI	.END