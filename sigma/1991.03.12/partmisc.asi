	.SBTTL	PARTMISC;---------\\; DESMOTIF >;---------/; Dessine un motif constitu de lignes droites.; in	D3.L	coordonne initiale;	D2.W	mode;	A3.L	^table (dy;dx); out	-; mod	D7.WDESMOTIF:	PUSHM.L	D3,D4,A3	SWAP.W	D3	ADD.W	D3,(A3+)	; saute au dpart	SWAP.W	D3	ADD.W	D3,(A3+)10$:	LOAD.L	D4,(A3+)	JUMP',EQ 90$	LIB	?DRSEG	JUMP	10$90$:	POPM.L	D3,D4,A3	RETTAFLLEFT:			; flche  gauche	.W	0,0	.W	-6,6	.W	3,0	.W	0,4	.W	6,0	.W	0,-4	.W	3,0	.W	-6,-6	.W	0,0TAFLLEFTH:			; demi-flche  gauche	.W	0,0	.W	-6,6	.W	3,0	.W	0,4	.W	3,0	.W	0,-10	.W	0,0;--------\\; MTMMENU >;========/; Affiche un mmenu pour choisir une icne avec la souris.; in	A3.L	^mmenu;	A4.L	^table des icnes;	D3.W	icne slectionne; out	D3.W	icne slectionne;	D7.W	erreur; mod	D3.L, D7.WMTMMENU:	PUSHM.L	D4,A2	LOAD.L	A2,A4		; A2 <-- ^table des icnes	LOAD.L	D4,#1		; D4 <-- case inactive10$:	SL.L	D4,#1		; D4 <-- case inactive suivante	TEST.B	(A2)		; fin de la table ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D3,(A2+)	; icne trouve ?	JUMP,NE 10$		; non => 10$20$:				; oui =>	LOAD.W	D3,#2^15	; D3 <-- signal D4 en entre	CALL	MMENU		; attend selon mmenu ...	JUMP',NE 90$	TEST.W	D3		; dans la case vide ?	JUMP',EQ 90$		; oui => 90$				; non =>	DEC.W	D3	LOAD.B	D3,(A4)+(D3.W)	; D3 <-- icne90$:	POPM.L	D4,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; MMENU   >;========/; Affiche un mmenu pour la souris.; in	A3.L	^mmenu;	D3.W	case initiale;	D4.L	cases inactives (si D3:#15=1); out	D3.W	case slectionne;	D7.W	erreur; mod	D3.L, D7.WMMENU:	PUSHM.L	D0..D2,D4,D5	LOAD.W	D0,D3		; D0 <-- case initiale	LOAD.L	D1,D4		; D1 <-- cases inactives	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 90$	LOAD.L	D2,D4	LOAD.W	D3,D0		; D3 <-- case initiale	LOAD.L	D4,D1		; D4 <-- cases inactives	LIB	?MMENU		; attend selon mmenu ...	JUMP',NE 90$	LOAD.L	D4,D2		; D4 <-- position de la souris	CALL	PMOUSE		; remet la souris o elle tait	LOAD.W	D5,(A6)+OWDOCA	LIB	?USEWDO		; utilise swdo dans le cadre	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2,D4,D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMOUSE  >;--------/; Positionne la souris en (y;x).; in	D4.L	nouvelle position (y;x); out	-; mod	D7.WPMOUSE:	PUSHM.L	D3,D4,D6,A4	ADD.W	D4,(A0)+ODFX	SWAP.W	D4	ADD.W	D4,(A0)+ODFY	SWAP.W	D4		; D4 <-- position dans $DIS_0 !	LOAD.L	A4,#(A6)+OBDIS+1	LOAD.B	(A4)+0,#'P	; <P>	LOAD.L	(A4)+1,D4	; <yy> <xx>	CLR.B	(A4)+5	LOAD.W	D3,#TYPIO	; D3 <-- type du driver souris	LOAD.W	D6,(A6)+OCHMOU	; D6 <-- canal souris	FOS	?COMMAND	POPM.L	D3,D4,D6,A4	RET;----------\\; WAITMOUSE >;==========/WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; CCMO    >;========/CCMO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	POPM.L	D3,D7	RET;--------\\; SCMO    >;========/SCMO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	POPM.L	D3,D7	RET;-----------\\; SCROLLMOVE >;===========/; Dplace l'ascenseur.; in	-; out	A5.L	^ascenseur;	D3.W	touche presse ou bouton press/relch;	D4.W	bouton press SCROLL(F/P)(UP/DOWN);		zro => souris pas dans un bouton;	D7.W	erreur (souris pas dans l'ascenseur); mod	D3.L, D4.L, D7.WSCROLLMOVE:	PUSH.W	D5	CLR.W	D5	LIB	?USEWDO		; utilise la swdo principale	LOAD.L	A5,#(A6)+OASC	; A5 <-- ^ascenseur	LIB	?IFMOUSE	; D4 <-- position de la souris	LOAD.W	(A5)+OSCHTV,(A6)+OMESM	LOAD.W	(A5)+OSCPOSV,(A6)+OMESC	SCROLL_	MOVE		; dplace l'ascenseur ...	PUSH.W	D7	LOAD.W	D5,(A6)+OWDOCA	LIB	?USEWDO		; utilise swdo dans le cadre	POP.W	D7	POP.W	D5	TEST.W	D7		; retour EQ/NE	RET;------------\\; SCROLLPRESS >;============/; Inverse un bouton.; in	A5.L	^variables de l'ascenseur;	D4.W	bouton press SCROLL(F/P)(UP/DOWN); out	-; mod	D7.WSCROLLPRESS:	PUSH.W	D5	CLR.W	D5	LIB	?USEWDO		; utilise la swdo principale	SCROLL_	PRESS		; inverse un bouton	LOAD.W	D5,(A6)+OWDOCA	LIB	?USEWDO		; utilise swdo dans le cadre	POP.W	D5	RET;------------\\; SCROLLUPDATE >;============/; Met  jour l'ascenseur.; in	-; out	-; mod	D7.WSCROLLUPDATE:	PUSHM.L	D5,A5	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.L	A5,#(A6)+OASC	; A5 <-- ^ascenseur	LOAD.W	(A5)+OSCHTV,(A6)+OMESM	LOAD.W	(A5)+OSCPOSV,(A6)+OMESC	SCROLL_	UPDATE	LOAD.W	D5,(A6)+OWDOCA	LIB	?USEWDO		; utilise swdo dans le cadre	POPM.L	D5,A5	RET	.END