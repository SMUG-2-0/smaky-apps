	.SBTTL	RYTHDBOX;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F4/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITO:	PUSHM.L	D1,D2,D5,A1..A4	LOAD.L	D4,#1	LOAD.L	A2,#R16"TDBOX_OUTPUT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A4,A3		; A4 <-- ^dbut du nom10$:	TEST.B	(A4+)		; A4 <-- ^fin du nom	JUMP',EQ 12$	COMP.B	(A4)-1,#CR	JUMP,NE	10$12$:	DEC.L	A420$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUTPUT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; SAUVE ?	JUMP,EQ	60$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	80$	COMP.W	D3,#UNDO	JUMP',EQ 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$60$:				; SAUVE =>	TEST.B	(A3)		; nom existe ?	JUMP,EQ	30$		; non => 30$	COMP.B	(A3),#CR	JUMP,EQ	30$	LOAD.L	A4,#R16"TXEXT	; A4 <-- ^extension	PUSH.W	D3	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	POP.W	D380$:	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys90$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F4/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,D5,A1..A4	CLR.L	D405$:	LOAD.L	A2,#R16"TDBOX_INPUT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A4,A3		; A4 <-- ^dbut du nom10$:	TEST.B	(A4+)		; A4 <-- ^fin du nom	JUMP',EQ 12$	COMP.B	(A4)-1,#CR	JUMP,NE	10$12$:	DEC.L	A420$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_INPUT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; PREND ?	JUMP,EQ	60$	COMP.W	D3,#F4		; AJOUTE ?	JUMP,EQ	60$	COMP.W	D3,#F7		; LISTE ?	JUMP,EQ	50$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	80$	COMP.W	D3,#UNDO	JUMP',EQ 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$50$:				; LISTE =>	DBOX_	CLOSE		; ferme la DBOX	PUSH.L	D4	LOAD.L	A4,A3		; A4 <-- ^buffer pour nom	LOAD.L	A3,#R16"TXEXT	; A3 <-- ^critre de recherche (extension)	CLR.L	D4	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode (avec sauvetage)	LIST_	DBOX		; liste puis choix selon dbox ...	POPM.L	D4	JUMP,NE 90$	LOAD.L	A3,A4		; A3 <-- ^nom du fichier	JUMP	05$60$:				; PREND/AJOUTE =>	TEST.B	(A3)		; nom existe ?	JUMP,EQ	30$		; non => 30$	COMP.B	(A3),#CR	JUMP,EQ	30$	LOAD.L	A4,#R16"TXEXT	; A4 <-- ^extension	PUSH.W	D3	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	POP.W	D380$:	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys90$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXDEFINE >;===========/; Choix de la vitesse et du nombre de temps.; in	-; out	D7.W	erreur; mod	D7.WDBOXDEFINE:	PUSHM.L	D0..D5,A1..A4	LOAD.L	D0,#1	LOAD.W	D1,(A5)+ORMT	; D1 <-- 2..9	SL.L	D0,D1		; D0 <-- fanions	LOAD.L	D4,D0	LOAD.L	A2,#R16"TDBOX_DEFINE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	CALL	DBOXSCROLL	; affiche l'ascenseur-vitesse	LOAD.L	A4,#(A6)+OBUNUM	LOAD.W	D4,(A6)+OUNITE	CALL	PUTANUM	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUNUM20$:	LOAD.L	D4,D0		; D4 <-- fanions	DBOX_	EDIT		; attend une action ...	LOAD.L	D0,D4		; D0 <-- fanions	LOAD.L	A1,#R16"TKEY_DEFINE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; (D'ACCORD) ?	JUMP,EQ 60$;;?	COMP.W	D3,#F0		; (ANNULE) ?;;?	JUMP,EQ 80$	COMP.W	D3,#KEYMGP	; bouton souris press ?	JUMP,EQ 40$	COMP.W	D3,#KEYMMP	JUMP,EQ 40$	COMP.W	D3,#KEYMDP	JUMP,EQ 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:	LIB	?IFMOUSE	JUMP,NE 30$	SUB.W	D4,(A0)+ODFFX	JUMP,LO 30$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- position souris dans swdo	JUMP,LO 30$	SWAP.W	D4	PUSH.L	A5	LOAD.L	A5,#(A6)+OASVIT	; A5 <-- ^variables ascenseur-vitesse	LOAD.W	(A5)+OSCINC,#2*MAXVIT/10	SCROLL_	MOVE		; dplace la cabine de l'ascenseur	POPM.L	A5	JUMP,NE 30$	LOAD.W	D4,(A6)+OASVIT+OSCPOSV ; D4 <-- vitesse	CALL	VITESSE		; commande la bonne vitesse	JUMP,NE 30$	JUMP	20$60$:				; d'accord =>	LOAD.L	A4,#(A6)+OBUNUM	CALL	GETANUM	LOAD.W	(A6)+OUNITE,D4	LOAD.W	D1,#-162$:	INC.W	D1	SR.L	D0,#1	JUMP,CC 62$	COMP.W	D1,(A5)+ORMT	; nb temps chang ?	JUMP,EQ 80$		; non => 80$	LOAD.W	(A5)+ORMT,D1	LOAD.L	A1,#R16"00$	SL.W	D1,#1	LOAD.W	(A5)+ORMN,(A1)+(D1.W)	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys	CALL	DESMESURE	; redessine la mesure	JUMP	90$80$:				; annule =>	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys90$:	POPM.L	D0..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.W	MAXPAS-0	.W	MAXPAS-0	.W	MAXPAS-0	; 2 temps	.W	MAXPAS-1	; 3 temps	.W	MAXPAS-0	; 4 temps	.W	MAXPAS-1	; 5 temps	.W	MAXPAS-4	; 6 temps	.W	MAXPAS-2	; 7 temps	.W	MAXPAS-0	; 8 temps	.W	MAXPAS-7	; 9 temps;-----------\\; DBOXSCROLL >;-----------/; Affiche l'ascenseur pour le contrle de la vitesse.; in	-; out	-; mod	D7.WDBOXSCROLL:	PUSHM.L	D3..D5,A3,A5	LOAD.L	A5,#(A6)+OASVIT	; A5 <-- ^variables ascenseur-vitesse	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#1	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#30	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A0)+ODFFDY	SUB.W	D4,(A0)+ODFCY	SUB.W	D4,(A0)+ODFCY	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCMARK	SCROLL_	DRAW		; dessine la cage de l'ascenseur	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur	LOAD.L	A3,#R16"TXSCALE	; A3 <-- ^textes	LOAD.W	D4,#10		; D4 <-- longueur	LOAD.W	D3,#2		; D3 <-- nombre	SCROLL_	SCALE	LOAD.L	A3,#0		; A3 <-- pas de textes	LOAD.W	D4,#3		; D4 <-- longueur	LOAD.W	D3,#10		; D3 <-- nombre	SCROLL_	SCALE	POPM.L	D3..D5,A3,A5	RET; Tables; ------TDBOX_INPUT:	.W	10$-TDBOX_INPUT	.W	20$-TDBOX_INPUT	.W	30$-TDBOX_INPUT	.W	010$:	.B	ODBTEXT	.ASCIZ	" Nom du rythme  prendre :"	.B	ODBCR,ODBCR	.B	ODBFILE,LBUFILE	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	"LISTE"	.B	ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" PREND  "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" AJOUTE "	.B	ODBTEXT	.ASCIZ	"       "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Ajoute"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Liste"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"30$:	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.B	ICOPREND,ICOFLOPPY,ICOVIDE	.B	ICOPREND,ICOFLOPPY,ICOVIDE	.B	ICOLISTE,ICOLISTE,ICOLISTE	.B	0,0,0	.B	ICOANNULE,ICOANNULE,ICOANNULE	.EVENTKEY_INPUT:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_INPUT	.W	F1,F2,F3,0		DOKF1-TKEY_INPUT	.W	F4,F5,F6,0		DOKF4-TKEY_INPUT	.W	F7,F8,F9,0		DOKF7-TKEY_INPUT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_INPUT	.W	0TDBOX_OUTPUT:	.W	10$-TDBOX_OUTPUT	.W	20$-TDBOX_OUTPUT	.W	30$-TDBOX_OUTPUT	.W	010$:	.B	ODBTEXT	.ASCIZ	" Nom du rythme  sauver :"	.B	ODBCR,ODBCR	.B	ODBFILE,LBUFILE	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,0	.ASCIZ	" toutes les mesures"	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" seulement la mesure courante"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" SAUVE "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"30$:	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.B	ICOVIDE,ICOFLOPPY,ICOSAUVE	.B	0,0,0	.B	0,0,0	.B	0,0,0	.B	ICOANNULE,ICOANNULE,ICOANNULE	.EVENTKEY_OUTPUT:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_OUTPUT	.W	CR,F1,F2,F3,0		DOKF1-TKEY_OUTPUT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_OUTPUT	.W	0TDBOX_DEFINE:	.W	10$-TDBOX_DEFINE	.W	20$-TDBOX_DEFINE	.W	30$-TDBOX_DEFINE	.W	010$:	.B	ODBTEXT	.ASCIZ	"Temps :"	.B	ODBTABX,40	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,2	.ASCIZ	" 2"	.B	ODBTABX,10	.B	ODBLCIRCLE,6	.ASCIZ	" 6"	.B	ODBCR	.B	ODBLCIRCLE,3	.ASCIZ	" 3"	.B	ODBTABX,10	.B	ODBLCIRCLE,7	.ASCIZ	" 7"	.B	ODBCR	.B	ODBLCIRCLE,4	.ASCIZ	" 4"	.B	ODBTABX,10	.B	ODBLCIRCLE,8	.ASCIZ	" 8"	.B	ODBCR	.B	ODBLCIRCLE,5	.ASCIZ	" 5"	.B	ODBTABX,10	.B	ODBLCIRCLE,9	.ASCIZ	" 9"	.B	ODBCR	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Unit: "	.B	ODBCLINE,3+2	.B	ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""30$:	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.B	ICOVIDE,ICOVIDE,ICOVIDE	.B	0,0,0	.B	0,0,0	.B	0,0,0	.B	0,0,0	.EVENTKEY_DEFINE:	.W	CR,F1,F2,F3,0		DOKF1-TKEY_DEFINE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEFINE	.W	0DOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF13:	LOAD.W	D3,#F13	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RET	.END