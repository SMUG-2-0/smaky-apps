	.SBTTL	DXBASE;--------\\; DSAFALL >;========/; Affiche compltement un descripteur de timbre.; in	A1.L	^descripteur;	A2.L	^timbre; out	-; mod	D7.WDSAFALL:	PUSH.L	A1	LIB	?BUCAR10$:	CALL	DSAFONE		; affiche un paramtre	CALL	DSNEXT		; A1 <-- ^descripteur suivant	JUMP,EQ 10$	LIB	?NOBUCAR	POP.L	A1	RET;---------\\; DSAFIONE >;=========/; Affiche un paramtre de timbre dans la case slectionne.; in	A1.L	^descripteur;	A2.L	^timbre; out	-; mod	D7.WDSAFIONE:	PUSH.L	D3	LOAD.B	D3,#AFINV	LIB	?AFCAR	SET.B	(A6)+ODSAFI	CALL	DSAFONE		; mj l'affichage	CLR.B	(A6)+ODSAFI	LOAD.B	D3,#AFDIR	LIB	?AFCAR	CALL	DSINVMENU	; allume l'icne slectionne	POP.L	D3	RET;--------\\; DSAFONE >;--------/; Affiche un paramtre de timbre.; in	A1.L	^descripteur;	A2.L	^timbre; out	-; mod	D7.WDSAFONE:	PUSHM.L	D1..D6,A3,A4	LOAD.B	D1,(A1)+ODSSTY	; D1 <-- sous-type	.IF	DX7	COMP.B	D1,#TDSFREQL	JUMP,EQ 90$	COMP.B	D1,#TDSFREQM	JUMP,EQ 90$	.ENDIF	CALL	DSGETNUM	; D4 <-- paramtre	PUSH.L	D4; Dessine un rectangle autour de l'objet.	LOAD.W	D3,(A1)+ODSPOS+0	LOAD.W	D2,D3	MUL.WU	D3,(A6)+OPASY	ADD.W	D3,#DEBCY	; D3 <-- <yy>	.IF	DX7	COMP.W	D2,#POSYL1+6	JUMP,LO 12$	COMP.W	D2,#POSYL2	JUMP,LO 10$	COMP.W	D2,#POSYL2+6	JUMP,LO 12$	.ENDIF	.IF	DX100	COMP.W	D2,#POSYL1+4	JUMP,LO 12$	COMP.W	D2,#POSYL2	JUMP,LO 10$	COMP.W	D2,#POSYL2+4	JUMP,LO 12$	COMP.W	D2,#POSYL3	JUMP,LO 10$	COMP.W	D2,#POSYL3+1	JUMP,LO 12$	.ENDIF	.IF	FB01	DEC.W	D3	COMP.W	D2,#POSYL1	JUMP,LO 12$	.ENDIF10$:	INC.W	D312$:	SWAP.W	D3	LOAD.W	D2,(A1)+ODSPOS+2	MUL.WU	D2,(A6)+OPASX	LOAD.W	D3,D2		; D3 <-- <xx>	CLR.W	D4	LOAD.B	D4,(A1)+ODSLGY	MUL.WU	D4,(A6)+OPASY	; D4 <-- <dyy>	SWAP.W	D4	CLR.W	D2	LOAD.B	D2,(A1)+ODSLGX	; D2 <-- nb de caractres	INC.W	D2	MUL.WU	D2,(A6)+OPASX	LOAD.W	D4,D2		; D4 <-- <dxx>	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine rectangle autour	LOAD.L	D5,D3	LOAD.L	D6,D4; Calcul les positions suivantes :;	D3.L	Y: au milieu	X:  gauche;	D2.L	Y: en haut	Y:  gauche	SWAP.W	D3	ADD.W	D3,(A6)+OPASLB	; D3 <-- descend sur la ligne de base	LOAD.W	D2,D3	SWAP.W	D4	SUB.W	D4,(A6)+OPASY	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D2	LOAD.W	D2,D3	CLR.W	D4	LOAD.B	D4,(A1)+ODSLGX	; D4 <-- nb de caractres	LOAD.W	D1,D4	INC.W	D4	MUL.WU	D4,(A6)+OPASX	; D4 <-- largeur totale	MUL.WU	D1,(A0)+ODFCX	; D1 <-- largeur dans la case	SUB.W	D4,D1	SR.W	D4,#1	INC.W	D4	ADD.W	D3,D4	POP.L	D4; Dbranchement selon le type de l'objet.	LOAD.B	D1,(A1)+ODSTYP	; D1 <-- type	COMP.B	D1,#TDSNUM	JUMP,EQ 30$	COMP.B	D1,#TDSNUMS	JUMP,EQ 35$	COMP.B	D1,#TDSNUM2	JUMP,EQ 35$	COMP.B	D1,#TDSLIST	JUMP,EQ 40$	COMP.B	D1,#TDSTEXT	JUMP,EQ 50$	COMP.B	D1,#TDSNOTE	JUMP,EQ 60$	COMP.B	D1,#TDSFREQH	JUMP,EQ 70$	COMP.B	D1,#TDSALGO	JUMP,EQ 80$	.IF	FB01	COMP.B	D1,#TDSSON	JUMP,EQ 82$	.ENDIF;	...	JUMP	90$; Objet de type numrique non sign.30$:	LIB	?SETCURS	CLR.W	D3	LOAD.B	D3,(A1)+ODSLGX	; D3 <-- nb de digits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC	.IF	FB01	COMP.B	(A1)+ODSSTY,#TDSSON	JUMP,NE 90$	PUSH.L	A1	LOAD.W	D2,(A1)+ODSPOS+031$:	CALL	DSNEXT	JUMP,NE 34$	COMP.B	(A1)+ODSTYP,#TDSSON	JUMP,NE 31$32$:	COMP.W	D2,(A1)+ODSPOS+0	JUMP,EQ 33$	CALL	DSNEXT	JUMP,NE 34$	COMP.B	(A1)+ODSTYP,#TDSSON	JUMP,EQ 32$	JUMP	34$33$:	CALL	DSAFONE		; affiche le nom du son34$:	POP.L	A1	.ENDIF	JUMP	90$; Objet de type numrique sign (+/-).35$:	LIB	?SETCURS	LOAD.B	D3,#SPACE	TEST.W	D4	JUMP,EQ 37$	LOAD.B	D3,#'+	TEST.W	D4	JUMP,NC 37$	LOAD.B	D3,#'-	NEG.W	D437$:	LIB	?AFCAR		; affiche le signe	CLR.W	D3	LOAD.B	D3,(A1)+ODSLGX	; D3 <-- nb de digits	DEC.B	D3		; D3 <-- un de moins  cause du signe	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC	JUMP	90$; Objet de type liste.40$:	LIB	?SETCURS	LOAD.L	A3,#(A1)+ODSTXT+142$:	TEST.W	D4	JUMP,EQ 46$44$:	COMP.B	(A3+),#TAB	JUMP,NE 44$	DEC.W	D4	JUMP	42$46$:	TEST.B	(A3):#7		; valeurs dans la liste ?	JUMP,BC 47$		; non => 47$	INC.L	A3		; oui => saute la valeur47$:	CLR.W	D3	LOAD.B	D3,(A1)+ODSLGX	; D3 <-- nb de caractres	LIB	?STRING	JUMP	90$; Objet de type texte fixe.50$:	LIB	?AFTIM	.B	USEGC,GCPTF,GCPTS,GCPTT	.B	0	.EVEN	LIB	?FLUSH		; pour mettre  jour (A0)+ODF..	ADD.W	D2,#2	LOAD.L	A3,#(A1)+ODSTXT+151$:	LOAD.L	A4,A3	CLR.W	D352$:	TEST.B	(A4)	JUMP,EQ 53$	COMP.B	(A4+),#CR	JUMP,EQ 53$	INC.W	D3		; D3 <-- nb de caractres	JUMP	52$53$:	PUSH.L	D3	CLR.W	D4	LOAD.B	D4,(A1)+ODSLGX	; D4 <-- largeur maximale [car]	INC.B	D4	MUL.WU	D4,(A6)+OPASX	; D4 <-- largeur maximale [pts]	MUL.WU	D3,(A0)+ODFCX	; D3 <-- largeur du texte [pts]	SUB.W	D4,D3		; D4 <-- marges gauche/droite	JUMP,NC 54$	CLR.W	D454$:	SR.W	D4,#1		; D4 <-- marge gauche	LOAD.L	D3,D2	TEST.W	D4	ADD.W	D3,D4	LIB	?SETCURS	POP.L	D3	LIB	?STRING		; affiche une "ligne"	TEST.B	(A4)		; encore une ligne ?	JUMP,EQ 59$		; non => 59$	LOAD.L	A3,A4		; A3 <-- ^dbut ligne suivante	SWAP.W	D2	ADD.W	D2,(A6)+OPASY	; D2 <-- descend en dessous	SWAP.W	D2	JUMP	51$59$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	LIB	?FLUSH		; pour mettre  jour (A0)+ODF..	JUMP	90$; Objet de type note.60$:	LIB	?SETCURS	CALL	DSAFNOTE	; affiche le nom de la note	JUMP	90$; Objet de type frquence DX7.70$:	LIB	?SETCURS	CALL	DSCONV2FREQ	; D4 <-- frquence (mode-*100)	.IF	DX7	TCLR.L	D4:#BFFIX	JUMP,BS 72$	.ENDIF	DIV.WU	D4,#100	LOAD.L	D5,D4	CLR.W	D5	SWAP.W	D5		; D5 <-- partie fractionnaire (00.99)	AND.L	D4,#H'FFFF	; D4 <-- partie entire (1..61)	LOAD.W	D3,#2		; D3 <-- nb de digits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC	LOAD.B	D3,#'.	LIB	?AFCAR	LOAD.L	D4,D5	LOAD.W	D3,#2		; D3 <-- nb de digits	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode	LIB	?AFDEC	.IF	DX7	LIB	?AFTIM	.ASCIZ	"   "		; affiche le mode "rapport"	.EVEN	.ENDIF	JUMP	90$	.IF	DX772$:	SWAP.W	D4	LOAD.W	D3,D4	INC.W	D3		; D3 <-- nb digits partie entire (1..4)	LOAD.W	D2,#1000	TEST.W	D4	JUMP,EQ 74$	LOAD.W	D2,#100	DEC.W	D4	JUMP,EQ 74$	LOAD.W	D2,#10	DEC.W	D4	JUMP,EQ 74$	LOAD.W	D2,#174$:	CLR.W	D4	SWAP.W	D4	DIV.WU	D4,D2	LOAD.L	D5,D4	CLR.W	D5	SWAP.W	D5		; D5 <-- partie fractionnaire	AND.L	D4,#H'FFFF	; D4 <-- partie entire	LOAD.W	D2,#2^BAFDALL	LIB	?AFDEC		; affiche la partie entire	SUB.W	D3,#4	NEG.W	D3		; D3 <-- nb digits partie fractionnaire (0..3)	JUMP,EQ 76$	LIB	?AFTIM	.ASCIZ	"."	.EVEN	LOAD.L	D4,D5	LIB	?AFDEC		; affiche la partie fractionnaire	JUMP	78$76$:	LIB	?AFSPACE78$:	LIB	?AFTIM	.ASCIZ	" Hz"		; affiche le mode "Hz"	.EVEN	JUMP	90$	.ENDIF; Objet de type algorithme DX7.80$:	.IF	DX7!DX100	CALL	ALAFONE		; affiche l'image de l'algorithme	JUMP,NE 30$		; si image ko => affiche comme un nombre	JUMP	90$	.ENDIF	.IF	FB01	JUMP	30$	.ENDIF	.IF	FB01; Objet de type son dans une banque.82$:	LIB	?SETCURS	LOAD.B	D3,#AFDIR	LIB	?AFCAR	PUSH.L	A1	LOAD.W	D2,#8+1-183$:	CALL	DSPREV	DECJ.W,NMO D2,83$	CALL	DSGETNUM	; D4 <-- no son (1..48)	DEC.W	D4	LOAD.W	D3,D4	LOAD.W	D2,#8+1-184$:	CALL	DSPREV	DECJ.W,NMO D2,84$	CALL	DSGETNUM	; D4 <-- no banque (1..6)	POP.L	A1	LOAD.L	A3,#R16"TBANK7	COMP.W	D4,#7	JUMP,EQ 85$	LOAD.L	A3,#R16"TBANK6	COMP.W	D4,#6	JUMP,EQ 85$	LOAD.L	A3,#R16"TBANK5	COMP.W	D4,#5	JUMP,EQ 85$	LOAD.L	A3,#R16"TBANK4	COMP.W	D4,#4	JUMP,EQ 85$	LOAD.L	A3,#R16"TBANK385$:	MUL.WU	D3,#LDXNAME	ADD.L	A3,D3	LOAD.W	D3,#LDXNAME	LIB	?STRING	JUMP	90$	.ENDIF90$:	POPM.L	D1..D6,A3,A4	RET;---------\\; DSAFNOTE >;=========/; Affiche un nom de note en clair, sous forme de 5 caractres.; Notation anglo-saxone !;	  0  -->  C-2;	 12  -->  C-1;	 24  -->  C 0;	120  -->  C 8;	127  -->  G 8; in	D4.B	rang de la note; out	-; mod	D7.WDSAFNOTE:	PUSHM.L	D3,D4,A3	AND.L	D4,#H'FF	DIV.WU	D4,#12	SWAP.W	D4		; D4 <-- 0..11	LOAD.L	A3,#R16"00$10$:	DEC.W	D4	JUMP,NS 15$12$:	TEST.B	(A3+)		; A3 <-- saute .ASCIZ	JUMP,NE 12$	JUMP	10$15$:	LIB	?AFSPACE	; un blanc au dbut pour faire 5 caractres	LIB	?AFTEXT		; affiche le nom de la note	SWAP.W	D4		; D4 <-- numro de l'octave	SUB.W	D4,#2	JUMP,NS 40$	LOAD.B	D3,D4	ADD.B	D3,#'0	LIB	?AFCAR	LIB	?AFSPACE	JUMP	90$40$:	LOAD.B	D3,#'-	LIB	?AFCAR	NEG.W	D4	LOAD.B	D3,D4	ADD.W	D3,#'0	LIB	?AFCAR90$:	POPM.L	D3,D4,A3	RET00$:	.ASCIZ	"C "		; do	.ASCIZ	"C#"	.ASCIZ	"D "		; r	.ASCIZ	"D#"	.ASCIZ	"E "		; mi	.ASCIZ	"F "		; fa	.ASCIZ	"F#"	.ASCIZ	"G "		; sol	.ASCIZ	"G#"	.ASCIZ	"A "		; la	.ASCIZ	"A#"	.ASCIZ	"B "		; si	.EVEN;------------\\; DSCONV2FREQ >;============/; Convertit les 2 paramtres de frquence (mode-high-low) en; un seul paramtre.; in	D4.L	frquence (mode-high-low); out	D4.L	frquence (mode-*100); mod	D4.LDSCONV2FREQ:	PUSHM.L	D5,A3	.IF	DX7	TEST.L	D4:#BFFIX	; frquence en Hz ?	JUMP,BS 50$		; oui => 50$	LOAD.L	D5,D4	SWAP.W	D5		; D5 <-- frquence high	AND.L	D4,#H'FFFF	; D4 <-- frquence low	TEST.W	D5	JUMP,NE 30$	ADD.W	D4,#100	SR.W	D4,#1		; D4 <-- frquence (50..99)	JUMP	90$30$:	ADD.W	D4,#100	MUL.WU	D4,D5		; D4 <-- frquence (100..6169)	JUMP	90$50$:	LOAD.L	A3,#R16"TAFFIX	SL.W	D4,#1	LOAD.W	D4,(A3)+(D4.W)	; D4 <-- frquence (1000..9999)	.ENDIF	.IF	DX100	LOAD.L	A3,#R16"TAFRAPPORT	SL.W	D4,#1	LOAD.W	D4,(A3)+(D4.W)	; D4 <-- rapport (0.50  25.95)	.ENDIF90$:	POPM.L	D5,A3	RET;------------\\; DSCONVFREQ2 >;============/; Convertit le paramtre de frquence en 2 paramtres (high-low).; Cherche le meilleur rapport possible. Par exemple :;	D3 = 308	(pour 3.08);		----------------------------------;		high:	3;		low:	8/3 = 2.67 --> mauvais;		----------------------------------;		high:	2;		low:	108/2 = 54 --> parfait;		----------------------------------;		Donc =>	308 donne 2|54 (high|low); in	D4.L	frquence (mode-*100); out	D4.L	frquence (mode-high-low); mod	D4.LDSCONVFREQ2:	PUSHM.L	D1..D3,D5,A3	.IF	DX7	TEST.L	D4:#BFFIX	; frquence en Hz ?	JUMP,BS 50$		; oui => 50$	AND.L	D4,#H'FFFF	DIV.WU	D4,#100	LOAD.L	D5,D4	CLR.W	D5	SWAP.W	D5		; D5 <-- partie fractionnaire (00..99)	AND.L	D4,#H'FFFF	; D4 <-- partie entire (0..61)	JUMP,NE 20$	SL.W	D5,#1		; D5 <-- 100..198	SUB.W	D5,#100		; D5 <-- 0..98	JUMP,HS 40$	CLR.W	D5	JUMP	40$20$:	LOAD.L	D1,D5	LOAD.L	D2,D425$:	LOAD.L	D3,D5	DIV.WU	D3,D4		; D3 <-- frac/int	COMP.W	D3,#100	JUMP,HS 30$	SWAP.W	D3	TEST.W	D3		; reste qq chose ?	JUMP,EQ 35$		; non => 35$	COMP.W	D4,#1	JUMP,EQ 30$	DEC.W	D4	ADD.W	D5,#100	JUMP	25$30$:	LOAD.L	D5,D1	LOAD.L	D4,D235$:	DIV.WU	D5,D440$:	SWAP.W	D4		; D4 <-- frquence high	LOAD.W	D4,D5		; D4 <-- frquence low	TCLR.L	D4:#BFFIX	JUMP	90$50$:	LOAD.L	A3,#R16"TAFFIX	LOAD.W	D5,D4	CLR.W	D460$:	COMP.W	D5,(A3+)	JUMP,LS 70$	INC.W	D4	COMP.W	D4,#100	JUMP,LO 60$	DEC.W	D470$:	TSET.L	D4:#BFFIX	.ENDIF	.IF	DX100	LOAD.L	A3,#R16"TAFRAPPORT	LOAD.W	D5,D4	CLR.W	D460$:	COMP.W	D5,(A3+)	JUMP,LS 90$	INC.W	D4	COMP.W	D4,#64	JUMP,LO 60$	DEC.W	D4	.ENDIF90$:	POPM.L	D1..D3,D5,A3	RET	.IF	DX7TAFFIX:	.W	1000,1023,1047,1072,1096,1122,1148,1175,1202,1230	.W	1259,1288,1318,1349,1380,1413,1445,1479,1514,1549	.W	1585,1622,1660,1698,1738,1778,1820,1862,1905,1950	.W	1995,2042,2089,2138,2188,2239,2291,2344,2399,2455	.W	2512,2570,2630,2692,2716,2818,2884,2951,3020,3090	.W	3162,3226,3311,3388,3467,3548,3631,3715,3802,3890	.W	3981,4074,4169,4266,4365,4767,4571,4677,4786,4898	.W	5012,5129,5248,5370,5495,5623,5754,5888,6026,6166	.W	6310,6457,6607,6761,6918,7079,7244,7413,7586,7762	.W	7943,8128,8318,8511,8718,8913,9120,9333,9550,9772	.ENDIF	.IF	DX100TAFRAPPORT:	.W	0050,0071,0078,0087,0100,0141,0157,0173	.W	0200,0282,0300,0314,0346,0400,0424,0471	.W	0500,0519,0565,0600,0628,0692,0700,0707	.W	0785,0800,0848,0865,0900,0942,0989,1000	.W	1038,1099,1100,1130,1200,1211,1256,1272	.W	1300,1384,1400,1410,1413,1500,1555,1557	.W	1570,1696,1727,1730,1837,1884,1903,1978	.W	2041,2076,2120,2198,2249,2355,2422,2595	.ENDIF;---------\\; DSGETNUM >;=========/; Prend un paramtre dans le timbre.; in	A1.L	^description;	A2.L	^timbre; out	D4.L	paramtre;		si frquence:	|0  high   |   low   |;				    0..31     0..99;;				|1 virgule |  frq   |;				    0..3      0..99; mod	D4.LDSGETNUM:	PUSHM.L	D5,A1	.IF	DX7	COMP.B	(A1)+ODSTYP,#TDSFREQH	JUMP,EQ 40$	.ENDIF	CALL	DSGETBNUM	; D4 <-- paramtre	JUMP	90$	.IF	DX740$:	CALL	DSGETBNUM	; D4 <-- frquence high	LOAD.L	D5,D4		; D5 <-- frquence high	CALL	DSNEXT		; A1 <-- ^descripteur frquence low	CALL	DSGETBNUM	; D4 <-- frquence low	SWAP.W	D5	LOAD.W	D5,D4	CALL	DSNEXT		; A1 <-- ^descripteur mode	CALL	DSGETBNUM	; D4 <-- mode	TEST.B	D4	JUMP,EQ 60$	SWAP.W	D5	CLR.L	D4	LOAD.W	D4,D5	DIV.WU	D4,#4	SWAP.W	D4	LOAD.W	D5,D4	SWAP.W	D5	TSET.L	D5:#BFFIX60$:	LOAD.L	D4,D5		; D4 <-- frquence (mode-high-low)	.ENDIF90$:	POPM.L	D5,A1	RET;----------\\; DSGETBNUM >;----------/; Prend un paramtre dans le timbre.; in	A1.L	^description;	A2.L	^timbre; out	D4.L	paramtre; mod	D4.LDSGETBNUM:	PUSHM.L	D3,A3	LOAD.W	D3,(A1)+ODSOFF	; D3 <-- offset	CLR.L	D4	LOAD.B	D4,(A2)+(D3.W)	; D4 <-- paramtre	AND.W	D4,(A1)+ODSMSK	; D4 <-- masque	LOAD.W	D3,(A1)+ODSSHF	JUMP,EQ 10$	SR.W	D4,D3		; D4 <-- shift10$:	ADD.W	D4,(A1)+ODSADD	COMP.B	(A1)+ODSTYP,#TDSLIST	JUMP,NE 25$	LOAD.L	A3,#(A1)+ODSTXT+1	TEST.B	(A3):#7		; valeurs dans la liste ?	JUMP,BC 25$		; non => 25$	LOAD.B	D3,D4	TSET.L	D3:#7	CLR.W	D420$:	COMP.B	D3,(A3+)	JUMP,LS 25$	INC.B	D422$:	COMP.B	(A3+),#TAB	JUMP,NE 22$	COMP.B	D4,(A1)+ODSLIS+1	JUMP,LS	20$25$:	COMP.B	(A1)+ODSTYP,#TDSNUM2	JUMP,NE 90$	TEST.L	D4:#6	JUMP,BC 90$	OR.W	D4,#H'FF8090$:	POPM.L	D3,A3	RET;---------\\; DSPUTNUM >;=========/; Met un paramtre dans le timbre.; in	A1.L	^description;	A2.L	^timbre;	D4.L	paramtre; out	D7.W	erreur; mod	D7.WDSPUTNUM:	PUSHM.L	D4,D5,A1	.IF	DX7	COMP.B	(A1)+ODSTYP,#TDSFREQH	JUMP,EQ 40$	.ENDIF	CALL	DSPUTBNUM	; mj le paramtre	JUMP	90$	.IF	DX740$:	LOAD.L	D5,D4	TCLR.L	D4:#BFFIX	SWAP.W	D4	CALL	DSPUTBNUM	; mj la frquence high	JUMP,NE 90$	CALL	DSNEXT		; A1 <-- ^descripteur frquence low	SWAP.W	D4	CALL	DSPUTBNUM	; mj la frquence low	LOAD.L	D4,D5	RL.L	D4,#1	AND.W	D4,#H'1		; D4 <-- 0/1	CALL	DSNEXT		; A1 <-- ^descripteur mode de la frquence	CALL	DSPUTBNUM	; mj le mode de la frquence	CLR.W	D7	.ENDIF90$:	POPM.L	D4,D5,A1	TEST.W	D7		; retour EQ/NE	RET;----------\\; DSPUTBNUM >;----------/; Met un paramtre dans le timbre.; in	A1.L	^description;	A2.L	^timbre;	D4.W	paramtre; out	D7.W	erreur; mod	D7.WDSPUTBNUM:	PUSHM.L	D1..D4,A3	LOAD.W	D7,#1		; D7 <-- valeur impossible	COMP.B	(A1)+ODSTYP,#TDSNUM2	JUMP,EQ 10$	SUB.W	D4,(A1)+ODSADD	JUMP,NS 90$10$:	COMP.B	(A1)+ODSSTY,#TDSMAXCOL	JUMP,EQ 12$	COMP.W	D4,(A1)+ODSLII	; trop petit ?	JUMP,LT 90$	COMP.W	D4,(A1)+ODSLIS	; trop grand ?	JUMP,GT 90$	JUMP	15$12$:	CALL	DSGETBMAX	; D3 <-- somme de la colonne	SUB.W	D3,(A1)+ODSLIS	NEG.W	D3	COMP.W	D4,D3		; trop grand ?	JUMP,GT 90$15$:	COMP.B	(A1)+ODSTYP,#TDSLIST	JUMP,NE 25$	LOAD.L	A3,#(A1)+ODSTXT+1	TEST.B	(A3):#7		; valeurs dans la liste ?	JUMP,BC 25$		; non => 25$20$:	DEC.B	D4	JUMP,NS 22$21$:	COMP.B	(A3+),#TAB	JUMP,NE 21$	JUMP	20$22$:	LOAD.B	D4,(A3)		; D4 <-- valeur25$:	TCLR.L	D4:#7		; D4 <-- 0ppppppp	LOAD.W	D3,(A1)+ODSMOD	CALL	MODPARAM	; modifie paramtre dans le DX7	LOAD.W	D3,(A1)+ODSSHF	JUMP,EQ 40$	SL.W	D4,D3		; D4 <-- shift40$:	LOAD.W	D2,(A1)+ODSOFF	; D2 <-- offset	LOAD.W	D3,(A1)+ODSMSK	; D3 <-- masque	LOAD.B	D1,(A2)+(D2.W)	; D1 <-- paramtre initial	NOT.B	D3	AND.B	D1,D3	NOT.B	D3	AND.B	D4,D3	OR.B	D1,D4	LOAD.B	(A2)+(D2.W),D1	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; DSGETBMAX >;----------/; Donne la somme des nombres d'une colonne.; L'objet lui-mme n'est pas compt !; in	A1.L	^description; out	D3.W	somme de la colonne; mod	D3.LDSGETBMAX:	PUSHM.L	D4,D7,A0,A1	LOAD.L	A0,A110$:	CALL	DSPREV		; remonte en haut de la colonne	JUMP,NE 20$	COMP.B	(A1)+ODSSTY,#TDSMAXCOL	JUMP,EQ 10$	CALL	DSNEXT20$:	CLR.W	D3		; D3 <-- somme de la colonne30$:	COMP.B	(A1)+ODSSTY,#TDSMAXCOL	JUMP,NE 90$	COMP.L	A1,A0		; est-ce lui mme ?	JUMP,EQ 40$	CALL	DSGETBNUM	; D4 <-- valeur de la colonne	ADD.W	D3,D4		; D3 <-- somme des max40$:	CALL	DSNEXT	JUMP,EQ 30$90$:	POPM.L	D4,D7,A0,A1	RET;-----------\\; DSVHORIZON >;===========/; Cherche  atteindre une position horizontale donne.; in	D1.W	position cherche en Y;	A1.L	^description; out	A1.L	^description; mod	D7.W, A1.LDSHORIZON:	PUSHM.L	D2,A3	LOAD.L	A3,A1	LOAD.W	D2,(A1)+ODSPOS+2 ; D2 <-- position en X10$:	COMP.W	D1,(A1)+ODSPOS+0	JUMP,EQ 90$	CALL	DSONEXT	JUMP,NE 30$	COMP.W	D2,(A1)+ODSPOS+2 ; dans la mme colonne ?	JUMP,EQ 10$		; oui => 10$30$:	LOAD.L	A1,A340$:	COMP.W	D1,(A1)+ODSPOS+0	JUMP,EQ 90$	CALL	DSOPREV	JUMP,NE 70$	COMP.W	D2,(A1)+ODSPOS+2 ; dans la mme colonne ?	JUMP,EQ 40$		; oui => 40$70$:	LOAD.L	A1,A3		; A1 <-- on ne bouge pas !90$:	POPM.L	D2,A3	RET;--------\\; DSONEXT >;========/; Cherche le descripteur d'objet ditable suivant.; in	A1.L	^descripteur; out	A1.L	^descripteur suivant;	D7.W	erreur; mod	D7.W, A1.LDSONEXT:10$:	CALL	DSNEXT	JUMP,NE 90$	TEST.B	(A1)+ODSTYP:#BDSINFO	JUMP,BS 10$90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; DSOPREV >;========/; Cherche le descripteur d'objet ditable prcdent.; in	A1.L	^descripteur; out	A1.L	^descripteur prcdent;	D7.W	erreur; mod	D7.W, A1.LDSOPREV:10$:	CALL	DSPREV	JUMP,NE 90$	TEST.B	(A1)+ODSTYP:#BDSINFO	JUMP,BS 10$90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; DSNEXT  >;========/; Cherche le descripteur suivant.; in	A1.L	^descripteur; out	A1.L	^descripteur suivant;	D7.W	erreur; mod	D7.W, A1.LDSNEXT:	PUSH.L	A2	LOAD.W	D7,#1		; D7 <-- pas possible	LOAD.L	A2,#(A1)+ODSTXT	INC.L	A2		; A2 <-- saute .B 020$:	TEST.B	(A2+)		; A2 <-- saute .ASCIZ	JUMP,NE 20$	EX.L	D2,A2	INC.L	D2	TCLR.L	D2:#0		; A2 <-- saute .EVEN	EX.L	A2,D2	COMP.W	(A2),#-1	JUMP,EQ 90$	LOAD.L	A1,A2	CLR.W	D7		; D7 <-- ok90$:	POP.L	A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; DSPREV  >;========/; Cherche le descripteur prcdent.; in	A1.L	^descripteur; out	A1.L	^descripteur prcdent;	D7.W	erreur; mod	D7.W, A1.LDSPREV:	PUSH.L	A2	LOAD.W	D7,#1		; D7 <-- pas possible	COMP.W	(A1)-2,#-1	JUMP,EQ 90$	LOAD.L	A2,#(A1)-120$:	COMP.B	(-A2),#1	; A2 <-- saute .ASCIZ	JUMP,NE 20$	LOAD.L	A2,#(A2)-ODSTXT	LOAD.L	A1,A2	CLR.W	D7		; D7 <-- ok90$:	POP.L	A2	TEST.W	D7		; retour EQ/NE	RET	.END