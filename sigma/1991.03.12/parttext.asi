	.SBTTL	PARTTEXT;-----------\\; DBOXGENCAR >;===========/; Dialogue pour la DBOX des gencars.; in	-; out	D7.W	erreur; mod	D7.WDBOXGENCAR:	PUSHM.L	D0..D5,A0..A510$:	LOAD.L	D4,(A6)+OFAGC	; D4 <-- fanions	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A5,#(A6)+OGCLIST; A5 <-- ^liste des gencars sur disque	LOAD.W	D5,#MAXGENC*3	; D5 <-- lg pour la liste	LOAD.L	D1,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	DGENC_	MODIF		; modifie un/qq gencar(s) ...	JUMP',NE 90$	LOAD.L	(A6)+OFAGC,D4	; mm. derniers fanions utiliss	COMP.W	D3,#F1		; MODIFIE ?	JUMP,EQ 10$	COMP.W	D3,#F4		; SUPPRIME ?	JUMP',NE 90$	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	KILL		; libre le gencar	JUMP	10$90$:	POPM.L	D0..D5,A0..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DEFGENCAR >;==========/; Utilise tous les gencars par dfaut.; in	-; out	-; mod	D7.WDEFGENCAR:	PUSHM.L	D3,D4,A2..A5	LOAD.L	A5,#R16"TGDEF	LOAD.L	A4,#(A6)+OBUGC	LOAD.B	D3,#2^BGCPROT20$:	TEST.B	(A5)		; fin de la table ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	A3,#(A4)+OGCTIT30$:	LOAD.B	(A3+),(A5+)	; OBUGC <-- titre	JUMP,NE 30$	LOAD.B	(A4)+OGCFLG,D3	LOAD.B	(A4)+OGCF,(A5+)	; OBUGC <-- fonte	LOAD.B	(A4)+OGCS,(A5+)	; OBUGC <-- style	LOAD.B	(A4)+OGCT,(A5+)	; OBUGC <-- taille	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	NEW	LOAD.L	A4,#(A4)+LGGC	; A4 <-- suivant dans OBUGC	CLR.B	D3		; D3 <-- protection seulement pour 1er	JUMP	20$90$:	POPM.L	D3,D4,A2..A5	RET;---------\\; GETTEXTE >;=========/; Prend une ligne de texte dans le buffer d'dition.; in	A4.L	^objet texte;	D4.L	position de la souris; out	-; mod	D7.WGETTEXTE:	PUSHM.L	D3,A3,A4	LOAD.L	A3,A4		; A3 <-- ^objet  prendre20$:	CALL	RECULE	JUMP',NE 80$	COMP.L	A3,(A6)+OPDT	JUMP,LO 20$	LOAD.L	A4,#(A6)+OTEXTE	LOAD.W	D3,#OTXCAR-130$:	LOAD.B	(A4+),(A3+)	; OTEXTE <-- tout ce qui est fixe	DECJ.W,NMO D3,30$35$:	LOAD.B	(A4+),(A3+)	; OTEXTE <-- texte<0>	JUMP,NE 35$	CALL	DAVANCE		; dtruit l'objet	LOAD.L	A4,#(A6)+OTEXTE	CALL	POSTEXTE	; mj OTXCUR selon la position de la souris80$:	CALL	GOMEND		; retourne  la fin de la mesure	POPM.L	D3,A3,A4	RET;---------\\; POSTEXTE >;---------/; Positionne le curseur dans le texte o est la souris.; in	A4.L	^objet texte;	D4.L	position de la souris; out	-; mod	D7.WPOSTEXTE:	PUSHM.L	D3,D4,A1..A4	LOAD.L	A3,(A4)+OTXPGC	; A3 <-- ^gencar	LOAD.L	A2,#(A3)+OGCWID	; A2 <-- ^table des largeurs	LOAD.L	A1,#(A4)+OTXCAR	; A1 <-- ^texte<0>	SUB.W	D4,(A4)+OTXPN1+2	CLR.W	(A4)+OTXCUR30$:	CLR.W	D3	LOAD.B	D3,(A1+)	; D3 <-- un caractre	JUMP',EQ 90$	COMP.B	D3,(A3)+OGCLCA	; trop grand ?	JUMP,HI 30$	SUB.B	D3,(A3)+OGCFCA	; trop petit ?	JUMP,LO 30$	LOAD.B	D3,(A2)+(D3.W)	; D3 <-- largeur du caractre	SUB.W	D4,D3	JUMP',NS 90$	INC.W	(A4)+OTXCUR	JUMP	30$90$:	POPM.L	D3,D4,A1..A4	RET;---------\\; PUTTEXTE >;=========/; Remet la ligne de texte du buffer d'dition dans la mesure.; in	-; out	D7.W	ERPDP; mod	D7.WPUTTEXTE:	PUSHM.L	D4,A4	CLR.W	D7		; D7 <-- ok	TEST.L	(A6)+OTEXTE+OTXPN1	JUMP,EQ 90$	LOAD.L	A4,#(A6)+OTEXTE	CALL	DIMTEXTE	; mj les dimensions du texte	LOAD.L	A4,#(A6)+OTEXTE+OTXCAR	CLR.W	D410$:	INC.W	D4		; D4 <-- longueur du texte	COMP.B	(A4+),#CR	JUMP',EQ 15$	TEST.B	(A4)-1	JUMP,NE 10$15$:	CLR.B	(A4)-1		; remplace <cr> par <0>	CLR.W	D7		; D7 <-- ok	COMP.W	D4,#1		; texte vide ?	JUMP',EQ 90$		; oui => 90$	INC.W	D4	TCLR.L	D4:#0		; D4 <-- arrondi au multiple de 2 sup.	ADD.W	D4,#OTXCAR	; D4 <-- longueur totale de l'objet	LOAD.L	A4,#(A6)+OTEXTE	; A4 <-- ^dbut de l'objet	LOAD.B	(A4)+OOBJC,#ICOTEXTE	CLR.B	(A4)+OOBJF	CALL	INSERT		; remet le texte  la fin de la mesure90$:	CLR.L	(A6)+OTEXTE+OTXPN1	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DIMTEXTE >;---------/; Calcule les dimensions occupes par un texte, en tenant; compte des caractres  chasses variables.; in	A4.L	^objet texte; out	-; mod	D7.WDIMTEXTE:	PUSHM.L	D3,D4,A1..A4	LOAD.L	A3,(A4)+OTXPGC	; A3 <-- ^gencar	LOAD.L	A2,#(A3)+OGCWID	; A2 <-- ^table des largeurs	LOAD.L	A1,#(A4)+OTXCAR	; A1 <-- ^texte<0>	CLR.W	D430$:	CLR.W	D3	LOAD.B	D3,(A1+)	; D3 <-- un caractre	JUMP',EQ 40$	COMP.B	D3,(A3)+OGCLCA	; trop grand ?	JUMP,HI 30$	SUB.B	D3,(A3)+OGCFCA	; trop petit ?	JUMP,LO 30$	LOAD.B	D3,(A2)+(D3.W)	; D3 <-- largeur du caractre	ADD.W	D4,D3		; D4 <-- somme des largeurs	JUMP	30$40$:	LOAD.W	D3,(A4)+OTXPN1+2	ADD.W	D3,D4	LOAD.W	(A4)+OTXPN2+2,D3	LOAD.W	D3,(A4)+OTXPN1+0	SUB.W	D3,(A3)+OGCMH2	SUB.W	D3,(A3)+OGCMH1	LOAD.W	(A4)+OTXPN2+0,D3	POPM.L	D3,D4,A1..A4	RET;---------\\; DESTEXTE >;=========/; Dessine une ligne de texte complte.; in	A4.L	^objet graphique;	D2.W	mode de dessin; out	-; mod	D7.WDESTEXTE:	PUSHM.L	D2..D4,A3	LOAD.L	D4,(A0)+ODFGCF	; D4 <-- "fst-" gencar initial	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	(A3)+0,#MODCAR	TSET.L	D2:#BPENDOT	LOAD.B	(A3)+1,D2	LOAD.W	D3,#2	LIB	?STRING		; met le bon mode	LOAD.L	D3,(A4)+OTXPN1	SWAP.W	D3	SUB.W	D3,(A4)+OTXBLI	SWAP.W	D3	LIB	?SETCURS	; positionne le curseur au dbut	LOAD.L	A3,#(A4)+OTXFST	; A3 <-- ^<usegc><f><s><t>	LOAD.W	D3,#4	LIB	?STRING		; utilise le bon gencar	LOAD.L	(A4)+OTXPGC,(A0)+ODFPGC	LOAD.L	A3,#(A4)+OTXCAR	; A3 <-- ^texte<0>	LIB	?AFTEXT		; affiche le texte avec le bon gencar	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	D4,#USEGC	RR.L	D4,#8		; D4 <-- "<usegc>fst"	LOAD.L	(A3)+0,D4	LOAD.B	(A3)+4,#MODCAR	LOAD.B	(A3)+5,#SETDOT	LOAD.W	D3,#4+2	LIB	?STRING		; remet gencar et mode initiaux	POPM.L	D2..D4,A3	RET;--------\\; GETPGC  >;========/; Donne le pointeur dans OBUGC au gencar actullement utilis.; in	-; out	A4.L	^dans OBUGC; mod	A4.LGETPGC:	PUSHM.L	D3,D4	LOAD.L	D4,(A6)+OFAGC	; D4 <-- fanions dbox gencar	JUMP',EQ 50$	LOAD.W	D3,#-120$:	INC.W	D3		; D3 <-- compte le rang du bit dans D4	RR.L	D4	JUMP,CC 20$	LOAD.L	A4,#(A6)+OBUGC	MUL.WU	D3,#LGGC	ADD.L	A4,D3	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BS 90$		; oui => 90$50$:	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- prend "Fond"90$:	POPM.L	D3,D4	RET	.END