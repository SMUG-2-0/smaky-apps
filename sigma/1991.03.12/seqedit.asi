	.SBTTL	SEQEDIT; Constantes; ----------LXNONO	=	50		; largeur pour une noteLXNOOC	=	10		; place pour le numro d'octaveLYNONO	=	7		; distance entre deux notesLYNOCL	=	12		; distance entre deux touches blanchesMXCADRE	=	8		; marge gauche/droite dans le cadreLXPARA	=	40		; largeur pour les paramtresNETRAME	=	8		; nb de trames pour les 0..127 vlocits;--------\\; EDITE   >;========/EDITE:	CALL	WAITMOUSE	; met le sablier	CALL	ECADRE		; dessine le cadre	CALL	EAFINFO		; affiche les infos en haut07$:	CALL	EAFNONO		; met les noms des notes08$:	CALL	EEFNOTES	; efface toutes les notes09$:	CALL	WAITMOUSE	; met le sablier	CALL	EMENOTES	; affiche le mtronome	CALL	EAANOTES	; affiche toutes les notes10$:	CALL	NORMMOUSE	; remet la flche	LIB	?GETCAR		; attend clavier/souris ...	COMP.W	D3,#F0+SHIFT	JUMP,LO 12$	COMP.W	D3,#F15+SHIFT	JUMP,HI 12$	SUB.W	D3,#SHIFT	; D3 <-- enlve le (SHIFT)12$:	COMP.W	D3,#END	JUMP,EQ 90$	COMP.W	D3,#F0	JUMP,EQ 90$	COMP.W	D3,#KEYMGP	; bouton souris press ?	JUMP,EQ 30$	COMP.W	D3,#KEYMMP	JUMP,EQ 30$	COMP.W	D3,#KEYMDP	JUMP,EQ 30$	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ 10$	COMP.W	D3,#KEYMMR	JUMP,EQ 10$	COMP.W	D3,#KEYMDR	JUMP,EQ 10$	COMP.W	D3,#F1		; (PLAY) ?	JUMP,EQ 70$	COMP.W	D3,#F2	JUMP,EQ 70$	COMP.W	D3,#F3	JUMP,EQ 70$	COMP.W	D3,#F4		; (STOP) ?	JUMP,EQ 10$	COMP.W	D3,#F5	JUMP,EQ 10$	COMP.W	D3,#F6	JUMP,EQ 10$	COMP.W	D3,#F8		; (F8)..(F15) ?	JUMP,LO 20$	COMP.W	D3,#F15	JUMP,LS 60$20$:				; erreur =>	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; fait un p'tit bruit	JUMP	10$30$:				; bouton press =>	LOAD.W	D2,D3		; D2 <-- bouton press	LIB	?IFMOUSE	LOAD.L	D5,D4	LOAD.L	A5,#(A6)+OASVER	SCROLL_	MOVE		; ascenseur vertical ?	JUMP,EQ 07$		; oui => 07$	LOAD.L	D4,D5	LOAD.L	A5,#(A6)+OASHOR	SCROLL_	MOVE		; ascenseur horizontal ?	JUMP,EQ 08$		; oui => 08$	LOAD.L	D4,D5	CALL	EDETCASE	; est-on dans une case  droite ?	JUMP,EQ 40$		; oui => 40$	COMP.W	D2,#KEYMGP	JUMP,EQ 35$	COMP.W	D2,#KEYMDP	JUMP,NE 20$				; bouton de droite =>	TSET.B	(A6)+OFLAGS:#BDETECTE	LOAD.L	D4,D5	CALL	EAANOTES	; est-on dans une note ?	JUMP,NE 20$		; non => 20$				; oui =>	CALL	EMODNOTE	; prend note pour la modifier	TCLR.B	(A6)+OFLAGS:#BNEW	CALL	EMOVNOTE	; dplace la note	JUMP	10$35$:				; bouton de gauche =>	CALL	ECRENOTE	; cre une note	JUMP,NE 20$	TSET.B	(A6)+OFLAGS:#BNEW	CALL	EMOVNOTE	; dplace la note	JUMP	10$40$:				; dans case  droite =>	DEC.W	D3	JUMP,NS 45$	COMP.W	D3,#NETRAME	JUMP,HS 20$	LOAD.W	D4,D3	LOAD.W	D3,(A6)+OENOTR	INC.W	D3	CALL	EINVCASE	; efface l'ancienne trame	LOAD.W	D3,D4	LOAD.W	(A6)+OENOTR,D3	INC.W	D3	CALL	EINVCASE	; allume la nouvelle trame	JUMP	10$45$:	CLR.W	D3	CALL	EINVCASE	; allume	LOAD.W	D4,#50/20	NTREL	?DELMS	CALL	EINVCASE	; puis teint trs rapidement	LOAD.W	D4,(A6)+OENOPI	LOAD.L	D3,(A6)+OFANION46$:	INC.W	D4	COMP.W	D4,#NBTRACK	JUMP,LO 47$	CLR.W	D4		; 8 --> 047$:	TEST.L	D3:D4		; piste visible ?	JUMP,BC 46$		; non => 46$	LOAD.W	(A6)+OENOPI,D4	CALL	EAFTCASE	; affiche le nouveau numro de piste	JUMP	10$60$:				; affiche/cache une piste =>	SUB.W	D3,#F8		; D3 <-- 0..7	LOAD.B	D4,(A6)+OFANION+3	TNOT.L	D4:D3	TEST.B	D4		; reste au moins une piste ?	JUMP,EQ 20$		; non => 20$	LOAD.W	D2,(A6)+OENOPI	TEST.L	D4:D2		; piste dans premire case visible ?	JUMP,BS 65$		; oui => 65$62$:	INC.W	D2	COMP.W	D2,#NBTRACK	JUMP,LO 63$	CLR.W	D2		; 8 --> 063$:	TEST.L	D4:D2		; piste visible ?	JUMP,BC 62$		; non => 62$	LOAD.W	(A6)+OENOPI,D2	CALL	EAFTCASE	; affiche nouvelle piste de dessin65$:	ADD.W	D3,#8	LIB	?INVBARRE	SUB.W	D3,#8		; D3 <-- 0..7	TNOT.B	(A6)+OFANION+3:D3	JUMP,BC 09$		; si ajoute une piste => redessine par dessus	JUMP	08$		; si enlve une piste => redessine tout70$:				; PLAY =>	LOAD.W	D4,(A6)+OASHOR+OSCPOSV	MUL.WU	D4,(A6)+OTRKFM	DIV.WU	D4,(A6)+OTRKFD	LOAD.W	(A6)+OTRKAX,D4	; mj la position dans les pistes	CALL	SELPTRACK	; slectionne les pistes d'coute	JUMP,NE 20$;;?	.W	NTREL,?GETPRIO	; D4 <-- priorit	LOAD.L	D4,#PRIOMET-1	; D4 <-- super-prioritaire !	LOAD.L	D5,#400		; D5 <-- lg stack	LOAD.L	A5,#R16"PPLAY	; A5 <-- ^start	LOAD.L	A3,#R16"NPLAY	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre l'coute	JUMP,NE 20$	TSET.B	(A6)+OFLAGS:#BPLAY	LOAD.L	D4,#PRIOMET	; D4 <-- trs prioritaire	LOAD.L	D5,#400		; D5 <-- lg stack	LOAD.L	A5,#R16"PMETRO	; A5 <-- ^start	LOAD.L	A3,#R16"NMETRO	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre le mtronome	LOAD.W	D3,#4	LIB	?CLRBARRE	; teint STOP	INC.W	D3	LIB	?CLRBARRE	INC.W	D3	LIB	?CLRBARRE	LOAD.W	D3,#1	LIB	?SETBARRE	; allume PLAY	INC.W	D3	LIB	?SETBARRE	INC.W	D3	LIB	?SETBARRE	LOAD.W	D4,#50/10	NTREL	?SETTIM		; met un petit timeout72$:	CALL	EDITMAJA	; mj l'avance dans les pistes	TEST.B	(A6)+OFLAGS:#BPLAY	JUMP,BC 75$	LIB	?GETCAR		; attend clavier/souris ...	JUMP,NE 72$75$:	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet un timeout infini	LOAD.W	D3,#1	LIB	?CLRBARRE	; teint PLAY	INC.W	D3	LIB	?CLRBARRE	INC.W	D3	LIB	?CLRBARRE	LOAD.W	D3,#4	LIB	?SETBARRE	; allume STOP	INC.W	D3	LIB	?SETBARRE	INC.W	D3	LIB	?SETBARRE	LOAD.W	D4,(A6)+OEDITA	CALL	EDITINVA	; efface le marqueur d'avance	LOAD.W	(A6)+OEDITA,#-1	CALL	STOPMIDI	; "all-note-off"	JUMP	10$90$:	LOAD.W	D4,(A6)+OASHOR+OSCPOSV	MUL.WU	D4,(A6)+OTRKFM	DIV.WU	D4,(A6)+OTRKFD	LOAD.W	(A6)+OTRKAX,D4	; mj la position dans les pistes	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface tout	RET;---------\\; ECRENOTE >;=========/; Cre une nouvelle note.;	note --> record buffer; in	D5.L		position initiale de la souris (y;x); out	(A6)+OEPNOT.L	position de la note (y;x);	(A6)+OEDNOT.L	dimensions de la note (dy;dx);	D7.W		erreur; mod	D7.WECRENOTE:	PUSHM.L	D2..D5,A1..A4	LOAD.W	D7,#1			; impossible	LOAD.L	(A6)+OPMOUSE,D5	LOAD.L	D3,D5	CLR.W	D3	SWAP.W	D3	SUB.W	D3,(A0)+ODFCY	JUMP,LO 90$	DIV.WU	D3,#LYNONO	COMP.W	D3,(A6)+ONBNOY	JUMP,HS 90$	INC.W	D3	SUB.W	D3,(A6)+ONBNOY	NEG.W	D3	LOAD.W	D4,(A6)+OASVER+OSCHTV	DEC.W	D4	SUB.W	D4,(A6)+OASVER+OSCPOSV ; D4 <-- note la plus basse affiche	ADD.W	D3,D4		; D3 <-- note (0..127)	LOAD.W	D4,D5	SUB.W	D4,#MXCADRE+LGSCROLL+LXNONO	JUMP,LO 90$	COMP.W	D4,(A6)+OEDITX	JUMP,HS 90$	ADD.W	D4,(A6)+OASHOR+OSCPOSV ; D4 <-- temps absolu	LOAD.W	D5,(A6)+OENOPI	OR.B	D5,#H'90	; D5 <-- status commande + canal	LOAD.W	D2,#NETRAME-1	SUB.W	D2,(A6)+OENOTR	; D2 <-- 0..7	SL.W	D2,#4		; D2 <-- 0..127	JUMP,NE 40$	INC.W	D2		; D2 <-- 1 au minimum (sinon relch) !40$:	LOAD.L	A4,(A6)+OPMBUF	ADD.L	A4,(A6)+OLMBUF	LOAD.L	(A6)+OPRBUF,A4	CLR.B	(A4)+0		; temps touche presse	CLR.B	(A4)+1	RR.W	D4,#8	LOAD.B	(A4)+2,D4	RR.W	D4,#8	LOAD.B	(A4)+3,D4	CLR.B	(A4)+4	LOAD.B	(A4)+5,#3	LOAD.B	(A4)+6,D5	LOAD.B	(A4)+7,D3	LOAD.B	(A4)+8,D2	INC.W	D4	CLR.B	(A4)+9		; temps touche relche	CLR.B	(A4)+10	RR.W	D4,#8	LOAD.B	(A4)+11,D4	RR.W	D4,#8	LOAD.B	(A4)+12,D4	CLR.B	(A4)+13	LOAD.B	(A4)+14,#3	LOAD.B	(A4)+15,D5	LOAD.B	(A4)+16,D3	CLR.B	(A4)+17	LOAD.L	(A6)+OLRBUF,#4+5+4+5	LOAD.W	D3,D4		; D3 <-- temps touche presse	ADD.L	A4,#4		; A4 <-- ^touche presse	LOAD.L	D4,#5+4+5	; D4 <-- reste dans record buffer	TSET.B	(A6)+OFLAGS:#BDETECTE	CALL	EAFNOTE		; dtecte la note dans le record buffer	TCLR.B	(A6)+OFLAGS:#BDETECTE	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EMODNOTE >;=========/; Prend une note pour la modifier, et efface-la.;	note --> record buffer; in	A4.L		^touche presse;	A3.L		^touche relache;	A2.L		^temps press;	A1.L		^temps relch;	D5.L		position initiale de la souris (y;x); out	(A6)+OEPNOT.L	position de la note (y;x);	(A6)+OEDNOT.L	dimensions de la note (dy;dx); mod	D7.WEMODNOTE:	PUSHM.L	D2..D5,A1..A4	PUSH.L	A2	LOAD.L	A2,(A6)+OPMBUF	ADD.L	A2,(A6)+OLMBUF	LOAD.L	(A6)+OPRBUF,A2	; record buffer <-- vide tout	CLR.L	(A6)+OLRBUF	POP.L	A2	EX.L	A2,A4	CALL	EXFNOTE		; record buffer <-- temps press	LOAD.L	A4,A2	LOAD.B	D4,(A4)+0	SL.W	D4,#8	LOAD.B	D4,(A4)+1	ADD.W	D4,#2	CALL	EXFNOTE		; record buffer <-- touche presse	SUB.W	A1,D4	SUB.W	A3,D4	LOAD.L	A4,A1	CALL	EXFNOTE		; record buffer <-- temps relch	LOAD.L	A4,A3	CALL	EXFNOTE		; record buffer <-- touche relche	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A6)+OEPNOT	LOAD.L	D4,(A6)+OEDNOT	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface toute la note90$:	POPM.L	D2..D5,A1..A4	RET;---------\\; EMOVNOTE >;=========/; Dplace la note dans le record buffer.; in	D5.L		position initiale de la souris (y;x);	(A6)+OEPNOT.L	position de la note (y;x);	(A6)+OEDNOT.L	dimensions de la note (dy;dx);	(A6)+OFLAGS:#BNEW; out	-; mod	D7.WEMOVNOTE:	PUSHM.L	D0..D6,A4;;?	LOAD.B	D3,#AFCCMO;;?	.W	LIB,?AFCAR	; cache la flche de la souris	SWAP.W	D5	CLR.L	D4	LOAD.W	D4,D5	SUB.W	D4,(A0)+ODFCY	DIV.WU	D4,#LYNONO	MUL.WU	D4,#LYNONO	ADD.W	D4,(A0)+ODFCY	LOAD.W	D5,D4		; D5 <-- position Y en haut de la note	SWAP.W	D5	TSET.B	(A6)+OFLAGS:#BFIRST	LOAD.L	D1,(A6)+OEPNOT	LOAD.L	D2,(A6)+OEDNOT20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 50$		; non => 50$				; oui =>	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	LOAD.L	D6,D4	LOAD.L	D3,(A6)+OEPNOT	LOAD.L	D4,(A6)+OEDNOT	SUB.W	D6,D5		; D6 <-- avance +/- en X	TEST.B	(A6)+OFLAGS:#BNEW	JUMP,BS 32$	COMP.W	D4,#4+4		; note trs courte ?	JUMP,LO 30$		; oui => 30$	LOAD.W	D0,D3	ADD.W	D0,#4	COMP.W	D5,D0		; est-on au bout  gauche ?	JUMP,LO 31$		; oui => 31$	LOAD.W	D0,D3	ADD.W	D0,D4	SUB.W	D0,#4	COMP.W	D5,D0		; est-on au bout  droite ?	JUMP,HS 32$		; oui => 32$30$:	ADD.W	D3,D6		; dplace le tout en X	JUMP	33$31$:	ADD.W	D3,D6		; dplace le bout  gauche	SUB.W	D4,D6	JUMP	33$32$:	ADD.W	D4,D6		; dplace le bout  droite33$:	COMP.W	D4,#1	JUMP,GE 35$	LOAD.W	D4,#135$:	LOAD.W	D7,D3	SUB.W	D7,#MXCADRE+LGSCROLL+LXNONO	JUMP,LO 20$	ADD.W	D7,D4	COMP.W	D7,(A6)+OEDITX	JUMP,HS 20$	SWAP.W	D5	CLR.W	D6	SWAP.W	D6	SUB.W	D6,D5		; D6 <-- avance +/- en Y	JUMP,LO 37$	DIV.WU	D6,#LYNONO	MUL.WU	D6,#LYNONO	JUMP	38$37$:	NEG.W	D6	DIV.WU	D6,#LYNONO	INC.W	D6	MUL.WU	D6,#LYNONO	NEG.W	D638$:	SWAP.W	D3	ADD.W	D3,D6		; dplace le tout en Y	SWAP.W	D5	LOAD.W	D7,D3	SUB.W	D7,(A0)+ODFCY	JUMP,LO 20$	COMP.W	D7,(A6)+OEDITY	JUMP,HS 20$	SWAP.W	D3	COMP.L	D3,D1		; mme position ?	JUMP,NE 40$	COMP.L	D4,D2		; mme dimensions ?	JUMP,EQ 20$40$:	EX.L	D1,D3	EX.L	D2,D4	TCLR.B	(A6)+OFLAGS:#BFIRST	JUMP,BS 42$	PUSH.W	D2	LOAD.W	D2,#INVDOT	LIB	?DRRECT		; efface l'ancienne note	POP.W	D2	CALL	EINVNONO	; efface l'ancienne marque42$:	LOAD.L	D3,D1	LOAD.L	D4,D2	PUSH.W	D2	LOAD.W	D2,#INVDOT	LIB	?DRRECT		; dessine ls nouvelle note	POP.W	D2	CALL	EINVNONO	; dessine la nouvelle marque	JUMP	20$50$:;;?	LOAD.B	D3,#AFSCMO;;?	.W	LIB,?AFCAR	; remet la flche de la souris	TEST.B	(A6)+OFLAGS:#BFIRST ; dtruit (clic sans bouger) ?	JUMP,BC 60$		; non => 60$				; oui =>	CALL	EMENOTES	; affiche simplement le mtronome	CALL	COMPACT		; master buffer <-- compactifie un peu	JUMP	90$60$:	LOAD.L	D3,D1	LOAD.L	D4,D2	CALL	EINVNONO	; efface la dernire marque	LOAD.L	A4,(A6)+OPRBUF	; A4 <-- ^record buffer; Met  jour les temps o la touche est presse puis relche.	SUB.W	D1,#MXCADRE+LGSCROLL+LXNONO	ADD.W	D1,(A6)+OASHOR+OSCPOSV	LOAD.B	(A4)+3,D1	RR.W	D1,#8	LOAD.B	(A4)+2,D1	RR.W	D1,#8	ADD.W	D1,D2	INC.W	D1	LOAD.B	(A4)+4+5+3,D1	RR.W	D1,#8	LOAD.B	(A4)+4+5+2,D1; Met  jour la hauteur des touches presses et relches.	CLR.W	D1	SWAP.W	D1	SUB.W	D1,(A0)+ODFCY	DIV.WU	D1,#LYNONO	INC.W	D1	SUB.W	D1,(A6)+ONBNOY	NEG.W	D1	LOAD.W	D2,(A6)+OASVER+OSCHTV	DEC.W	D2	SUB.W	D2,(A6)+OASVER+OSCPOSV ; D2 <-- note la plus basse affiche	ADD.W	D1,D2	LOAD.B	(A4)+4+3,D1	LOAD.B	(A4)+4+5+4+3,D1	ADD.L	A4,#4		; A4 <-- ^touche presse	CALL	EONENOTE	; affiche dfinitivement la note	CALL	FUSION		; master buffer <-- record buffer	CALL	COMPACT		; master buffer <-- compactifie un peu	TEST.B	(A6)+OFLAGS:#BNEW	JUMP,BS 90$	CALL	EMENOTES	; affiche le mtronome;;?	CALL	EAANOTES	; affiche toutes les notes90$:	POPM.L	D0..D6,A4	RET;---------\\; EDITMAJA >;=========/; Met  jour l'avance dans les pistes.; in	-; out	-; mod	D7.WEDITMAJA:	PUSHM.L	D3,D4	LOAD.W	D4,(A6)+OLASTT	; D4 <-- temps donn par le processus METRO	SUB.W	D4,(A6)+OASHOR+OSCPOSV	JUMP,LO 90$	COMP.W	D4,(A6)+OEDITX	; est-on arriv trop  droite ?	JUMP,LO 20$		; non => 20$				; oui =>	TCLR.B	(A6)+OFLAGS:#BPLAY	JUMP	90$20$:	COMP.W	D4,(A6)+OEDITA	JUMP,EQ 90$	LOAD.W	D3,D4	LOAD.W	D4,(A6)+OEDITA	CALL	EDITINVA	; efface l'ancienne	LOAD.W	D4,D3	CALL	EDITINVA	; dessine la nouvelle	LOAD.W	(A6)+OEDITA,D490$:	POPM.L	D3,D4	RET;---------\\; EDITINVA >;---------/; Inverse l'indicateur d'avance dans les pistes.; in	D4.W	coordonne en X; out	-; mod	D7.WEDITINVA:	PUSHM.L	D2..D4	COMP.W	D4,#-1	JUMP,EQ 90$	LOAD.W	D3,(A0)+ODFCY	SWAP.W	D3	LOAD.W	D3,#MXCADRE+LGSCROLL+LXNONO	ADD.W	D3,D4	LOAD.W	D4,(A6)+OEDITY	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRSEG		; dessine ligne verticale90$:	POPM.L	D2..D4	RET;---------\\; EEFNOTES >;=========/; Efface toutes les notes, et dessine la grille.; in	-; out	-; mod	D7.WEEFNOTES:	PUSHM.L	D0..D4	LIB	?BUCAR	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.W	D3,(A0)+ODFCY	SWAP.W	D3	LOAD.W	D3,#MXCADRE+LGSCROLL+LXNONO	LOAD.W	D4,(A6)+OEDITY	SWAP.W	D4	LOAD.W	D4,(A6)+OEDITX	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface tout	LOAD.W	(A6)+OEDITA,#-1	; on a effac la barre verticale d'avance; Dessine des lignes horizontales pointilles entre si-do et mi-fa.	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	; <map>	.B	1		; <chelle>	.B	0	.EVEN	LOAD.W	D2,#SETDOT!TTTDOT	LOAD.W	D3,(A0)+ODFCY	ADD.W	D3,(A6)+OEDITY	SWAP.W	D3	LOAD.W	D3,#MXCADRE+LGSCROLL+LXNONO	CLR.L	D4	LOAD.W	D4,(A6)+OEDITX	LOAD.W	D1,(A6)+ONBNOY	; D1 <-- nb de notes verticalement	DEC.W	D1		; D1 <-- y'a une ligne de moins	LOAD.W	D0,(A6)+OASVER+OSCHTV	DEC.W	D0	SUB.W	D0,(A6)+OASVER+OSCPOSV	DIV.WU	D0,#12	SWAP.W	D0		; D0 <-- 0..1130$:	INC.W	D0	COMP.W	D0,#12	JUMP,LO 35$	CLR.W	D035$:	SWAP.W	D3	SUB.W	D3,#LYNONO	; D3 <-- une note plus haute	SWAP.W	D3	TEST.W	D0	JUMP,EQ 40$	COMP.W	D0,#5	JUMP,NE 45$40$:	PUSH.L	D3	LIB	?DRSEG		; met une ligne horizontale traitille	POP.L	D345$:	DEC.W	D1	JUMP,NE 30$	LIB	?NOBUCAR	POPM.L	D0..D4	RET;---------\\; EMENOTES >;=========/; Dessine les barres verticales du mtronome.; in	-; out	-; mod	D7.WEMENOTES:	PUSHM.L	D0..D4	LIB	?BUCAR; Dessine des lignes verticales  chaque "top" du mtronome.	LOAD.L	D4,(A6)+OFANION	LOAD.W	D1,#NNPS/1	TEST.L	D4:#BFAMET+1	; mtronome ?	JUMP,BS 50$		; oui => 50$	LOAD.W	D1,#NNPS/2	TEST.L	D4:#BFAMET+2	; mtronome ?	JUMP,BC 80$		; non => 80$50$:				; oui =>	LOAD.W	D2,#SETDOT	CLR.L	D3	LOAD.W	D3,(A6)+OASHOR+OSCPOSV	DIV.WU	D3,D1	LOAD.W	D3,(A0)+ODFCY	SWAP.W	D3	SUB.W	D3,D1	NEG.W	D3	ADD.W	D3,#OFNOTE	; tient compte du dbut des rythmes	LOAD.W	D4,(A6)+OEDITY	SWAP.W	D4	CLR.W	D455$:	PUSH.L	D3	ADD.W	D3,#MXCADRE+LGSCROLL+LXNONO	LIB	?DRSEG		; met une ligne verticale pleine	POP.L	D3	ADD.W	D3,D1		; D3 <-- sur le "top" suivant	COMP.W	D3,(A6)+OEDITX	; est-on trop  droite ?	JUMP,LO 55$		; non => 55$80$:	LIB	?NOBUCAR	POPM.L	D0..D4	RET;---------\\; EAANOTES >;=========/; Affiche toutes les notes, ou dtecte o est la souris.; in	(A6)+OFLAGS:#BDETECTE;	D4.L		position de la souris; out	A4.L		^touche presse  o est la souris <<lg>> <s><t><v>;	A3.L		^touche relche o est la souris <<lg>> <s><t><v>;	A2.L		^temps press;	A1.L		^temps relch;	(A6)+OEPNOT.L	position de la note (y;x);	(A6)+OEDNOT.L	dimensions de la note (dy;dx);	D7.W		erreur; mod	D7.W, A1.L, A2.L, A3.L, A4.LEAANOTES:	PUSHM.L	D1..D4	LOAD.L	(A6)+OPMOUSE,D4	LOAD.L	A4,(A6)+OPMBUF	LOAD.L	D4,(A6)+OLMBUF20$:	LOAD.W	D7,#1		; D7 <-- on a pas trouv	TEST.L	D4		; reste qq chose ?	JUMP,EQ 90$		; non => 90$	CLR.L	D2	LOAD.B	D2,(A4)+0	SL.W	D2,#8	LOAD.B	D2,(A4)+1	TEST.W	D2	JUMP,NE 30$				; temps =>	LOAD.L	A2,A4		; A2 <-- ^temps press	LOAD.B	D3,(A4)+2	SL.W	D3,#8	LOAD.B	D3,(A4)+3	; D3 <-- dernier temps	LOAD.W	D2,#2	JUMP	50$30$:				; objet =>	LOAD.B	D1,(A4)+2+0	; D1 <-- status commande	AND.B	D1,#H'F0	; D1 <-- masque le canal	COMP.B	D1,#H'90	JUMP,NE 50$	TEST.B	(A4)+2+2	JUMP,EQ 50$				; touche presse =>	LOAD.B	D1,(A4)+2+0	; D1 <-- status commande	AND.B	D1,#H'0F	; D1 <-- juste le canal	TEST.B	(A6)+OFANION+3:D1 ; faut-il montrer ce canal ?	JUMP,BC 50$		; non => 50$				; oui =>	COMP.W	D3,(A6)+OASHOR+OSCPOSV ; trop tt ?	JUMP,LO 50$		; oui => 50$	CALL	EAFNOTE		; affiche/dtecte une note	TEST.B	(A6)+OFLAGS:#BDETECTE	JUMP,BC 50$	TEST.W	D7		; est-on dans cette note ?	JUMP,EQ 90$		; oui => 90$50$:	ADD.W	D2,#2	ADD.L	A4,D2	SUB.L	D4,D2	JUMP	20$90$:	TCLR.B	(A6)+OFLAGS:#BDETECTE	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; EAFNOTE >;========/; Affiche une note si elle entre dans la fentre de visualisation,; ou dtecte si la souris est dedans.; in	A4.L		^touche presse: <<lg>> <s><t><v>;	D4.L		reste dans master buffer;	D3.W		temps;	(A6)+OPMOUSE.L	position de la souris (y;x); out	A3.L		^touche relche: <<lg>> <s><t><v>;	A1.L		^temps relch;	(A6)+OEPNOT.L	position de la note (y;x);	(A6)+OEDNOT.L	dimensions de la note (dy;dx);	D7.W		erreur si souris pas dedans; mod	D7.W, A1.L, A3.LEAFNOTE:	PUSHM.L	D0..D6,A4	LOAD.L	A3,A4		; A3 <-- ^dans master buffer	LOAD.W	D5,D3	SUB.W	D3,(A6)+OASHOR+OSCPOSV ; trop tt ?	JUMP,LO 90$		; oui => 90$	COMP.W	D3,(A6)+OEDITX	; trop tard ?	JUMP,HS 90$		; oui => 90$	LOAD.W	D1,(A6)+OASVER+OSCHTV	DEC.W	D1	SUB.W	D1,(A6)+OASVER+OSCPOSV ; D1 <-- note la plus basse affiche	CLR.W	D2	LOAD.B	D2,(A3)+2+1	; D2 <-- note (0..127)	SUB.W	D2,D1		; note trop basse ?	JUMP,LO 90$		; oui => 90$	COMP.W	D2,(A6)+ONBNOY	; note trop haute ?	JUMP,HS 90$		; oui => 90$	LOAD.B	D0,(A3)+2+1	; D0 <-- no note presse20$:	TEST.L	D4		; reste qq chose ?	JUMP,EQ 90$		; non => 90$	CLR.L	D1	LOAD.B	D1,(A3)+0	SL.W	D1,#8	LOAD.B	D1,(A3)+1	TEST.W	D1	JUMP,NE 30$				; temps =>	LOAD.L	A1,A3		; A1 <-- ^temps relch	LOAD.B	D5,(A3)+2	SL.W	D5,#8	LOAD.B	D5,(A3)+3	; D5 <-- dernier temps	LOAD.W	D1,#2	JUMP	50$30$:				; objet =>	LOAD.B	D6,(A3)+2+0	; D6 <-- status commande	AND.B	D6,#H'F0	; D6 <-- masque le canal	COMP.B	D6,#H'80	JUMP,EQ 35$	COMP.B	D6,#H'90	JUMP,NE 50$	TEST.B	(A3)+2+2	JUMP,NE 50$35$:				; note relche =>	COMP.B	D0,(A3)+2+1	; est-ce la bonne ?	JUMP,NE 50$		; non => 50$				; oui =>	LOAD.B	D6,(A3)+2+0	; D6 <-- status commande	AND.B	D6,#H'0F	; D6 <-- juste le canal	LOAD.B	D7,(A4)+2+0	; D7 <-- status commande touche presse	AND.B	D7,#H'0F	; D7 <-- juste le canal	COMP.B	D6,D7		; est-ce le mme canal press/relch ?	JUMP,EQ 60$		; oui => 60$50$:	ADD.W	D1,#2	ADD.L	A3,D1	SUB.L	D4,D1	JUMP	20$60$:	SUB.W	D5,(A6)+OASHOR+OSCPOSV	JUMP,LO 90$	COMP.W	D5,(A6)+OEDITX	; dpasse  droite ?	JUMP,LO 65$		; non => 65$	LOAD.W	D5,(A6)+OEDITX	; oui => met le maximum65$:	SUB.W	D5,D3		; D5 <-- longueur de la note	SWAP.W	D3	LOAD.W	D3,(A0)+ODFCY	ADD.W	D3,(A6)+OEDITY	INC.W	D2	MUL.WU	D2,#LYNONO	SUB.W	D3,D2	INC.W	D3		; D3 <-- <yy>	SWAP.W	D3	ADD.W	D3,#MXCADRE+LGSCROLL+LXNONO ; D3 <-- <xx>	LOAD.W	D4,#LYNONO-2	; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,D5	DEC.W	D4		; D4 <-- <dxx>	TEST.B	(A6)+OFLAGS:#BDETECTE	JUMP,BS 70$	CALL	EONENOTE	; affiche une note	JUMP	90$70$:				; dtecte =>	COMP.W	D4,#2	JUMP,GE 72$	LOAD.W	D4,#2		; D4 <-- largeur minimale72$:	LOAD.L	(A6)+OEPNOT,D3	LOAD.L	(A6)+OEDNOT,D4	LOAD.B	D2,(A4)+2+0	; D2 <-- status commande touche presse	AND.W	D2,#H'0F	; D2 <-- juste le canal	COMP.W	D2,(A6)+OENOPI	JUMP,NE 90$	LOAD.L	D2,(A6)+OPMOUSE	; D2 <-- position de la souris	COMP.W	D2,D3		; souris trop  gauche ?	JUMP,LO 90$	ADD.W	D3,D4	COMP.W	D2,D3		; souris trop  droite ?	JUMP,HI 90$	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	COMP.W	D2,D3		; souris trop en haut ?	JUMP,LO 90$	ADD.W	D3,D4	COMP.W	D2,D3		; souris trop en bas ?	JUMP,HI 90$	CLR.W	D7		; D7 <-- youpie, on a trouv	JUMP	95$90$:	LOAD.W	D7,#1		; D7 <-- souris pas dedans95$:	POPM.L	D0..D6,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EONENOTE >;=========/; Affiche juste une note.; in	D3.L	position;	D4.L	dimensions;	A4.L	^touche presse; out	-; mod	D7.WEONENOTE:	PUSHM.L	D2,A4	PUSHM.L	D3,D4	CLR.W	D4	LOAD.B	D4,(A4)+2+2	; D4 <-- vlocit touche presse	LOAD.L	A4,#R16"TETRAME	SR.W	D4,#4		; D4 <-- 0..7	SL.W	D4,#2		; D4 <-- *4 car table de double .W	LOAD.L	D3,(A4)+(D4.W)	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit une trame +/- grise	POPM.L	D3,D4	COMP.W	D4,#2	JUMP,GE 60$	LOAD.W	D4,#260$:	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	LIB	?DRMATRIX	; dessine une note	LIB	?DRRECT		; met un rectangle autour	POPM.L	D2,A4	RET;--------\\; EXFNOTE >;========/; Transfert une note n'importe o dans le master buffer;  la fin du record buffer.; Une note est dplace, alors qu'un temps est dupliqu !; in	A4.L	^note <<lg>> <..>; out	-; mod	D7.WEXFNOTE:	PUSHM.L	D2..D4,A2..A4	CLR.L	D4	LOAD.B	D4,(A4)+0	SL.W	D4,#8	LOAD.B	D4,(A4)+1	; D4 <-- longueur note	LOAD.W	D2,D4		; temps ?	JUMP,NE 10$		; non => 10$	LOAD.W	D4,#2		; oui => met lg correcte10$:	ADD.W	D4,#2	LOAD.L	A3,(A6)+OPRBUF	ADD.L	A3,(A6)+OLRBUF	; A3 <-- ^fin du record buffer	LOAD.W	D3,D4	LOAD.L	A2,A420$:	LOAD.B	(A3+),(A2+)	; record buffer <-- la note	DEC.W	D3	JUMP,NE 20$	ADD.L	(A6)+OLRBUF,D4	TEST.W	D2		; temps ?	JUMP,EQ 90$		; oui => 90$; Bouche le trou, pour DEPLACER la note.	LOAD.L	A3,A4	ADD.L	A3,D4	LOAD.L	D3,(A6)+OPRBUF	ADD.L	D3,(A6)+OLRBUF	SUB.L	D3,A340$:	LOAD.B	(A4+),(A3+)	; master buffer <-- bouche le "trou"	DEC.L	D3	JUMP,NE 40$	SUB.L	(A6)+OLMBUF,D4	SUB.L	(A6)+OPRBUF,D490$:	POPM.L	D2..D4,A2..A4	RET;--------\\; EAFNONO >;========/; Dessine un joli clavier vertical  gauche (pfff).; in	-; out	-; mod	D7.WEAFNONO:	PUSHM.L	D2..D5,A3	LIB	?BUCAR	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; met trame blanche	LOAD.W	D3,(A0)+ODFCY	INC.W	D3	SWAP.W	D3	LOAD.W	D3,#MXCADRE+LGSCROLL+LXNOOC	LOAD.W	D4,(A6)+OEDITY	SUB.W	D4,#2	SWAP.W	D4	LOAD.W	D4,#LXNONO-LXNOOC	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; fait toutes les touches blanches	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; met trame noire	LOAD.W	D3,(A0)+ODFCY	SWAP.W	D3	LOAD.W	D3,#MXCADRE+LGSCROLL	LOAD.W	D4,(A6)+OEDITY	SWAP.W	D4	LOAD.W	D4,#LXNOOC-1	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface tous les numros d'octave	LOAD.W	D3,(A0)+ODFCY	ADD.W	D3,(A6)+OEDITY	SWAP.W	D3	LOAD.W	D3,#MXCADRE+LGSCROLL+LXNOOC	LOAD.L	A3,#R16"00$	CLR.L	D5	LOAD.W	D5,(A6)+OASVER+OSCHTV	DEC.W	D5	SUB.W	D5,(A6)+OASVER+OSCPOSV	DIV.WU	D5,#12	SWAP.W	D5		; D5 <-- 0..11	SL.W	D5,#2		; D5 <-- *4 car table de double .W	ADD.W	A3,D5		; A3 <-- ^la note initiale	SWAP.W	D5		; D5 <-- no de l'octave	LOAD.W	D2,(A6)+ONBNOY	; D2 <-- nb notes visibles40$:	PUSHM.L	D2,D3	TEST.W	(A3)	JUMP,NE 45$	INC.W	D5	LOAD.L	A3,#R16"00$45$:	COMP.W	(A3)+0,#4	JUMP,EQ 60$				; blanche =>	PUSH.L	D3	SWAP.W	D3	SUB.W	D3,(A3)+2	COMP.W	D3,(A0)+ODFCY	JUMP,LT 69$	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,#LXNONO-LXNOOC	LOAD.W	D2,#CLRDOT	LIB	?DRSEG	POP.L	D3	COMP.W	(A3)+0,#2	JUMP,EQ 55$	COMP.W	(A3)+0,#3	JUMP,NE 70$				; indique le numro d'octave =>	COMP.W	D5,#10	JUMP,HS 70$	SUB.W	D3,#LXNOOC-1	SWAP.W	D3	SUB.W	D3,#LYNONO/2	LOAD.W	D2,D3	SUB.W	D2,(A0)+ODFC1Y	COMP.W	D2,(A0)+ODFCY	JUMP,LT 70$	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,D5	ADD.B	D3,#'0	LIB	?AFCAR	JUMP	70$55$:				; sparation entre octaves =>	SUB.W	D3,#LXNOOC	CLR.L	D4	LOAD.W	D4,#LXNOOC	LOAD.W	D2,#SETDOT	LIB	?DRSEG	JUMP	70$60$:				; noire =>	SWAP.W	D3	SUB.W	D3,#LYNONO	COMP.W	D3,(A0)+ODFCY	JUMP,LT 70$	SWAP.W	D3	LOAD.W	D4,#LYNONO	SWAP.W	D4	LOAD.W	D4,#(LXNONO-LXNOOC)*3/5	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	JUMP	70$69$:	POP.L	D370$:	POPM.L	D2,D3	ADD.L	A3,#4	SWAP.W	D3	SUB.W	D3,#LYNONO	; D3 <-- juste en dessus	SWAP.W	D3	DEC.W	D2	JUMP,NE 40$	LIB	?NOBUCAR	POPM.L	D2..D5,A3	RET00$:	.W	2,(LYNOCL*1)-(LYNONO*0)	.W	4,0	.W	1,(LYNOCL*2)-(LYNONO*2)	.W	4,0	.W	1,(LYNOCL*3)-(LYNONO*4)	.W	3,(LYNOCL*4)-(LYNONO*5)	.W	4,0	.W	1,(LYNOCL*5)-(LYNONO*7)	.W	4,0	.W	1,(LYNOCL*6)-(LYNONO*9)	.W	4,0	.W	1,(LYNOCL*7)-(LYNONO*11)	.W	0;---------\\; EINVNONO >;=========/; Inverse une note pour montrer o est la souris.; in	D3.L	position de la souris; out	-; mod	D7.WEINVNONO:	PUSHM.L	D2..D4,A3	LOAD.L	D4,D3	CLR.W	D4	SWAP.W	D4	SUB.W	D4,(A0)+ODFCY	JUMP,LO 90$	SUB.W	D4,(A6)+OEDITY	JUMP,HS 90$	NEG.W	D4	DIV.WU	D4,#LYNONO	CLR.L	D3	LOAD.W	D3,(A6)+OASVER+OSCHTV	DEC.W	D3	SUB.W	D3,(A6)+OASVER+OSCPOSV	DIV.WU	D3,#12	SWAP.W	D3		; D3 <-- 0..11	LOAD.L	A3,#R16"00$	CLR.L	D2	LOAD.W	D2,D4	ADD.W	D2,D3	DIV.WU	D2,#12	SWAP.W	D2	SL.W	D2,#1	LOAD.W	D2,(A3)+(D2.W)	COMP.W	D2,#100	JUMP,EQ 50$				; blanche =>	LOAD.W	D3,D4	MUL.WU	D3,#LYNONO	ADD.W	D3,#LYNONO/2+1	ADD.W	D3,D2	SUB.W	D3,(A6)+OEDITY	NEG.W	D3	ADD.W	D3,(A0)+ODFCY	SWAP.W	D3	LOAD.W	D3,#MXCADRE+LGSCROLL+LXNONO-7	LOAD.W	D4,#4	LOAD.W	D2,#INVDOT	LIB	?DRCERCLE	JUMP	90$50$:				; noire =>	LOAD.W	D3,D4	MUL.WU	D3,#LYNONO	ADD.W	D3,#LYNONO/2+1	SUB.W	D3,(A6)+OEDITY	NEG.W	D3	ADD.W	D3,(A0)+ODFCY	SWAP.W	D3	LOAD.W	D3,#MXCADRE+LGSCROLL+LXNOOC+((LXNONO-LXNOOC)*3/5)-7	LOAD.W	D4,#3	LOAD.W	D2,#INVDOT	LIB	?DRCERCLE	INC.W	D4	LIB	?DRCERCLE90$:	POPM.L	D2..D4,A3	RET00$:	.W	+2	.W	100	.W	0	.W	100	.W	-2	.W	+3	.W	100	.W	+1	.W	100	.W	-1	.W	100	.W	-3;--------\\; ECADRE  >;========/; Dessine le cadre d'dition avec les ascenseurs.; in	-; out	-; mod	D7.WECADRE:	PUSHM.L	D0..D5,A3..A5	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	EOP		; efface tout	.B	0	.EVEN; Affiche les touches programmables.	LOAD.L	A3,#R16"TXEMENU	LIB	?AFMENU		; affiche les soft-keys	LOAD.W	D3,#4	LIB	?SETBARRE	; allume STOP	INC.W	D3	LIB	?SETBARRE	INC.W	D3	LIB	?SETBARRE	LOAD.B	D4,(A6)+OFANION+3 ; D4 <-- canaux en lecture	OR.B	D4,(A6)+OFANION+2 ; D4 <-- met le canal d'enregistrement	LOAD.B	(A6)+OFANION+3,D4	LOAD.W	D3,#16-810$:	RR.B	D4,#1	JUMP,CC 12$	LIB	?SETBARRE	; allume les canaux visibles12$:	INC.W	D3	COMP.W	D3,#16	JUMP,LO 10$; Calcul les dimensions de la fentre d'dition.	LOAD.W	D4,(A0)+ODFDX	SUB.W	D4,#MXCADRE+LGSCROLL+LXNONO+LXPARA+MXCADRE	LOAD.W	(A6)+OEDITX,D4	CLR.L	D4	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,(A0)+ODFCY	SUB.W	D4,#LGSCROLL+2	DIV.WU	D4,#LYNONO	LOAD.W	(A6)+ONBNOY,D4	MUL.WU	D4,#LYNONO	LOAD.W	(A6)+OEDITY,D4; Dessine le cadre en peu spcial tout autour de la fentre.	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit une trame pleine	LOAD.W	D2,#SETDOT	; D2 <-- <mode>	CLR.L	D3	LOAD.W	D4,(A0)+ODFCY	SWAP.W	D4	LOAD.W	D4,(A0)+ODFDX	LIB	?DRMATRIX	; trame suprieure	LOAD.W	D3,(A0)+ODFCY	SWAP.W	D3	CLR.W	D3	LOAD.W	D4,(A6)+OEDITY	SWAP.W	D4	LOAD.W	D4,#MXCADRE+LGSCROLL	LIB	?DRMATRIX	; trame gauche	LOAD.W	D4,#MXCADRE/2	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,D4	LIB	?DRMATRIX	; trame droite	SUB.W	D3,#LXPARA+(MXCADRE/2)	INC.W	D4	LIB	?DRMATRIX	; trame droite	LOAD.W	D3,(A0)+ODFCY	ADD.W	D3,(A6)+OEDITY	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CLR.W	D3	LOAD.W	D4,(A0)+ODFDX	LIB	?DRMATRIX	; trame gauche	LOAD.W	D3,(A0)+ODFCY	SWAP.W	D3	LOAD.W	D3,#MXCADRE+LGSCROLL+LXNOOC-1	LOAD.W	D4,(A6)+OEDITY	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; sparateur vertical; Initialise et dessine les ascenseurs  gauche et en bas dans le cadre.	LOAD.L	A5,#(A6)+OASVER	; A5 <-- ^variables ascenseur vertical	LOAD.W	D4,(A0)+ODFCY	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	(A5)+OSCDEBL,#MXCADRE	LOAD.W	D4,(A6)+OEDITY	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	CLR.B	(A5)+OSCHOR	SCROLL_	DRAW		; dessine l'ascenseur vertical	LOAD.W	D4,#128	SUB.W	D4,(A6)+ONBNOY	LOAD.W	(A5)+OSCHTV,D4	DEC.W	D4	SUB.W	D4,#12*4	; D4 <-- met DO4 tout en bas	LOAD.W	(A5)+OSCPOSV,D4	SCROLL_	UPDATE	LOAD.W	(A5)+OSCINC,#12	; flches verticales => +/- 1 octave	LOAD.L	A5,#(A6)+OASHOR	; A5 <-- ^variables ascenseur horizontal	LOAD.W	(A5)+OSCDEBO,#MXCADRE+LGSCROLL+LXNONO-1	LOAD.W	D4,(A0)+ODFCY	ADD.W	D4,(A6)+OEDITY	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OEDITX	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCHOR	SCROLL_	DRAW		; dessine l'ascenseur horizontal	LOAD.W	D4,(A6)+ODIRECT+2	SUB.W	D4,#2*MGTRK	MUL.WU	D4,(A6)+OTRKFD	DIV.WU	D4,(A6)+OTRKFM	LOAD.W	D3,(A6)+OEDITX	SR.W	D3,#1	SUB.W	D4,D3	COMP.W	D4,(A6)+OEDITX	JUMP,GE 30$	LOAD.W	D4,(A6)+OEDITX30$:	LOAD.W	(A5)+OSCHTV,D4	LOAD.W	D4,(A6)+OTRKAX	MUL.WU	D4,(A6)+OTRKFD	DIV.WU	D4,(A6)+OTRKFM	LOAD.W	(A5)+OSCPOSV,D4	SCROLL_	UPDATE	LOAD.W	(A5)+OSCINC,#NNPS*5 ; flches horizontales => +/- 5 secondes; Dessine les sparateurs entre les cases tout  droite.	LIB	?BUCAR	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,#LXPARA+(MXCADRE/2) ; D3 <-- <xx>	SWAP.W	D3	LOAD.W	D3,(A0)+ODFCY	; D3 <-- <yy>	CLR.L	D4		; D4 <-- <dyy>	LOAD.W	D4,#LXPARA	; D4 <-- <dxx>	LOAD.W	D2,#SETDOT	; D2 <-- <mode>	LOAD.W	D1,(A0)+ODFCY	ADD.W	D1,(A6)+OEDITY	; D1 <-- point le plus bas40$:	PUSH.L	D3	SWAP.W	D3	LIB	?DRSEG		; dessine une ligne horizontale	POP.L	D3	ADD.W	D3,(A0)+ODFCY	; D3 <-- <yy> suivant (en dessous)	COMP.W	D3,D1		; est-on trop bas ?	JUMP,LO 40$		; non => 40$; Dessine le numro de piste dans la premire case.	CALL	GETRTRACK	; D5 <-- piste d'enregistrement	LOAD.L	D4,(A6)+OFANION	TEST.L	D4:D5		; piste aussi en lecture ?	JUMP,BS 45$		; oui => 45$	CLR.W	D543$:	TEST.L	D4:D5		; D5 <-- prend la premire piste en lecture	JUMP,BS 45$	INC.W	D5	COMP.W	D5,#NBTRACK	JUMP,LO 43$	CALL	GETRTRACK	; D5 <-- piste d'enregistrement45$:	LOAD.W	(A6)+OENOPI,D5	CALL	EAFTCASE; Dessine les trames pour les vlocits tout  droite.	LOAD.L	A4,#R16"TETRAME+(NETRAME*4)	LOAD.W	D3,(A0)+ODFCY	; D3 <-- <yy>	ADD.W	D3,(A0)+ODFCY	; D3 <-- saute la premire case	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,#LXPARA+(MXCADRE/2) ; D3 <-- <xx>	LOAD.W	D4,(A0)+ODFCY	; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,#LXPARA	; D4 <-- <dxx>	LOAD.W	D2,#SETDOT	; D2 <-- <mode>	LOAD.W	D1,#NETRAME50$:	PUSHM.L	D3,D4	LOAD.L	D3,(-A4)	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit la trame	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,#3	SWAP.W	D3	ADD.W	D3,#3	SWAP.W	D3	SUB.W	D4,#5	SWAP.W	D4	SUB.W	D4,#5	SWAP.W	D4	LIB	?DRMATRIX	; dessine une trame	POPM.L	D3,D4	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	; D3 <-- <yy> suivant (en dessous)	SWAP.W	D3	DEC.W	D1	JUMP,NE 50$	LOAD.W	D3,#NETRAME/2	; D3 <-- trame par dfaut	LOAD.W	(A6)+OENOTR,D3	INC.W	D3	CALL	EINVCASE	; allume la trame par dfaut	LIB	?NOBUCAR	POPM.L	D0..D5,A3..A5	RET;--------\\; EAFINFO >;========/; Affiche les informations dans le haut du cadre.; in	-; out	-; mod	D7.WEAFINFO:	PUSHM.L	D3,D4,A3,A4	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	AFINV		; en inverse vido	.B	SPACE		; toujours un espace	.ASCII	"Edite        "	;	"SIGMA rev x.y"	.ASCII	"    "	.B	0	.EVEN	LOAD.L	A3,#(A6)+OBDIS	LOAD.L	A4,#(A6)+OBUFILE	LOAD.W	D4,#20		; D4 <-- nb max de caractres affichables20$:	LOAD.B	D3,(A4+)	JUMP,EQ 25$	COMP.B	D3,#CR	JUMP,EQ 25$	COMP.B	D3,#'.		; faire mieux pour "@nanet.12:tralala.midi" !!!	JUMP,EQ 25$	LIB	?MINMAJ	LOAD.B	(A3+),D3	DEC.W	D4	JUMP,NE 20$25$:	INC.B	D4	LOAD.B	(A3+),#MSPACE	LOAD.B	(A3+),D4	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBDIS	LIB	?AFTEXT		; affiche le nom puis des espaces	LIB	?AFTIM	.ASCII	"  "	.ASCII	"|   cre    |           |  modifie  |"		 ;           ;           ;           ;	.B	AFDIR		; remet vido normale	.B	0	.EVEN	POPM.L	D3,D4,A3,A4	RET;---------\\; EDETCASE >;=========/; Dtecte dans quelle case  droite est la souris.; in	D4.L	position de la souris (y;x); out	D3.W	numro case (0..n);	D7.W	erreur; mod	D3.L, D7.WEDETCASE:	PUSH.L	D4	LOAD.W	D7,#1		; D7 <-- on est ailleurs	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,#MXCADRE/2	COMP.W	D4,D3		; trop  droite ?	JUMP,HS 90$	SUB.W	D3,#LXPARA	COMP.W	D4,D3		; trop  gauche ?	JUMP,LO 90$	CLR.W	D4	SWAP.W	D4	SUB.W	D4,(A0)+ODFCY	; trop haut ?	JUMP,LO 90$	DIV.WU	D4,(A0)+ODFCY	LOAD.W	D3,D4	CLR.W	D7		; D7 <-- on est dedans90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EINVCASE >;=========/; Inverse une case  droite.; in	D3.W	case  inverser (0..n); out	-; mod	D7.WEINVCASE:	PUSHM.L	D1..D4	MUL.WU	D3,(A0)+ODFCY	ADD.W	D3,(A0)+ODFCY	; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,#LXPARA+(MXCADRE/2) ; D3 <-- <xx>	LOAD.W	D4,(A0)+ODFCY	; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,#LXPARA	; D4 <-- <dxx>	LOAD.W	D2,#INVDOT	; D2 <-- <mode>	LOAD.W	D1,#2		; D1 <-- paisseur50$:	ADD.W	D3,#1	SWAP.W	D3	ADD.W	D3,#1	SWAP.W	D3	SUB.W	D4,#1+1	SWAP.W	D4	SUB.W	D4,#1+1	SWAP.W	D4	LIB	?DRRECT		; dessine un rectangle	DEC.W	D1	JUMP,NE 50$	POPM.L	D1..D4	RET;---------\\; EAFTCASE >;=========/; Affiche le numro de piste dans la premire case  droite.; in	-; out	-; mod	D7.WEAFTCASE:	PUSHM.L	D3,D4	LOAD.W	D3,(A0)+ODFCY	ADD.W	D3,(A0)+ODFCY	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,#(LXPARA/2)+(MXCADRE/2)	LOAD.W	D4,(A0)+ODFCX	SR.W	D4,#1	SUB.W	D3,D4	LIB	?SETCURS	; positionne le curseur	LOAD.W	D3,(A6)+OENOPI	; D3 <-- no piste	ADD.B	D3,#'1		; D1 <-- 1..8	LIB	?AFCAR		; affiche le numro de piste	POPM.L	D3,D4	RET; Tables; ------TXEMENU:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"PLAY"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"STOP"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"        1     2  "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"  3     4     5  "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"  6     7     8  "	.EVENTETRAME:	.W	H'8800,H'0000	.W	H'8800,H'2200	.W	H'AA00,H'5500	.W	H'AA55,H'AA55	.W	H'55FF,H'AAFF	.W	H'77FF,H'DDFF	.W	H'77FF,H'FFFF	.W	H'FFFF,H'FFFF	.END