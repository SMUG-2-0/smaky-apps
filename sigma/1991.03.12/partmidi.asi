	.SBTTL	PARTMIDI;-----------\\; SMAKYTRACK >;===========/; Si le "vrai" synthtiseur n'est pas branch, met toutes; les pistes sur le canal 16 du Smaky.; in	-; out	-; mod	D7.WSMAKYTRACK:	PUSHM.L	D4,A4	LOAD.L	D4,(A6)+OFAPLAY	TEST.L	D4:#BFASYNT	; synthtiseur prsent ?	JUMP',BS 90$		; oui => 90$				; non =>	LOAD.L	A4,#(A6)+OTRACK	LOAD.W	D4,#NBTRACK-130$:	LOAD.W	(A4)+OTMIDI,#16-1	LOAD.L	A4,#(A4)+LT	DECJ.W,NMO D4,30$90$:	POPM.L	D4,A4	RET;------------\\; SYNTHETRACK >;============/; Si le "vrai" synthtiseur est branch, met toutes; les pistes sur le canal 1.; in	-; out	-; mod	D7.WSYNTHETRACK:	PUSHM.L	D4,A4	LOAD.L	D4,(A6)+OFAPLAY	TEST.L	D4:#BFASYNT	; synthtiseur prsent ?	JUMP',BC 90$		; non => 90$				; oui =>	LOAD.L	A4,#(A6)+OTRACK	LOAD.W	D4,#NBTRACK-130$:	CLR.W	(A4)+OTMIDI	LOAD.L	A4,#(A4)+LT	DECJ.W,NMO D4,30$90$:	POPM.L	D4,A4	RET;----------\\; SELPTRACK >;==========/; Slectionne le temps  sauter au dbut et les pistes;  couter selon les fanions.; in	-; out	D7.W	erreur; mod	D7.WSELPTRACK:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A4,#(A6)+OBUCOM	LOAD.B	(A4)+0,#'M	; <midi>	LOAD.L	A3,#(A6)+OTRACK	LOAD.L	A2,#(A4)+1	LOAD.W	D4,#NBTRACK-110$:	LOAD.B	(A2+),(A3)+OTMIDI+1	LOAD.L	A3,#(A3)+LT	DECJ.W,NMO D4,10$	LOAD.W	D4,#NBTRACK-111$:	CLR.B	(A2+)	DECJ.W,NMO D4,11$	CLR.B	(A4)+NBTRACK+1	CALL	COMMAND		; commande les canaux midi	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM	LOAD.B	(A4)+0,#'O	; <offset>	LOAD.L	A3,#(A6)+OTRACK	LOAD.L	A2,#(A4)+1	LOAD.W	D4,#NBTRACK-120$:	LOAD.W	D3,(A3)+OTOCT	MUL.WA	D3,#12	ADD.W	D3,(A3)+OTDMT	LOAD.B	(A2+),D3	LOAD.L	A3,#(A3)+LT	DECJ.W,NMO D4,20$	LOAD.W	D4,#NBTRACK-121$:	CLR.B	(A2+)	DECJ.W,NMO D4,21$	CLR.B	(A4)+NBTRACK+1	CALL	COMMAND		; commande les transpositions	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM	LOAD.B	(A4)+0,#'A	; <amplitude>	LOAD.L	A3,#(A6)+OTRACK	LOAD.L	A2,#(A4)+1	LOAD.W	D4,#NBTRACK-130$:	LOAD.B	(A2+),(A3)+OTAMP+1	LOAD.L	A3,#(A3)+LT	DECJ.W,NMO D4,30$	LOAD.W	D4,#NBTRACK-131$:	CLR.B	(A2+)	DECJ.W,NMO D4,31$	CLR.B	(A4)+NBTRACK+1	CALL	COMMAND		; commande les amplitudes	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM	LOAD.B	(A4)+0,#'D	; <dynamique>	LOAD.L	A3,#(A6)+OTRACK	LOAD.L	A2,#(A4)+1	LOAD.W	D4,#NBTRACK-140$:	LOAD.B	(A2+),(A3)+OTDYN+1	LOAD.L	A3,#(A3)+LT	DECJ.W,NMO D4,40$	LOAD.W	D4,#NBTRACK-141$:	CLR.B	(A2+)	DECJ.W,NMO D4,41$	CLR.B	(A4)+NBTRACK+1	CALL	COMMAND		; commande la dynamique	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'V	; <vitesse>	LOAD.W	D4,#MAXVIT	SUB.W	D4,(A6)+OASVIT+OSCPOSV ; D4 <-- vitesse (-MAXVIT..+MAXVIT)	LOAD.W	(A4)+1,D4	CLR.B	(A4)+3	CALL	COMMAND		; commande la bonne vitesse	JUMP,NE 90$	LOAD.L	D4,(A6)+OFAPLAY;	RR.L	D4,#BFAPLAY	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'C	; <canal>	CLR.B	(A4)+1		; <bits>	LOAD.B	(A4)+2,D4	; <bits>	CLR.B	(A4)+3	CALL	COMMAND		; n'coute que les canaux choisis90$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------------\\; STARTSTOPREAD >;==============/; Dmarre ou stoppe le processus fils de lecture des notes joues.; in	-; out	-; mod	D7.WSTARTSTOPREAD:	PUSHM.L	D4,D5,A3..A5	LOAD.L	D4,(A6)+OFAPLAY	TEST.L	D4:#BFASYNT	; synthtiseur "MIDI" ?	JUMP',BC 70$		; non => 70$				; oui =>	TEST.B	(A6)+OPFREAD	; processus fils existe ?	JUMP',T 90$		; oui => 90$	NTREL	?GETPRIO	; D4 <-- priorit de START	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP'	90$70$:	CALL	STOPMIDI	; stoppe compltement MIDI90$:	POPM.L	D4,D5,A3..A5	RET; Processus fils de lecture; -------------------------NFILS1:	.ASCIZ	"SIGMAP_READ"	.EVENPFILS1:	SET.B	(A6)+OPFREAD	; processus fils existe	LOAD.L	D5,#-1		; D5 <-- lecture seulement pour RSTATUS	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DREAD		; lit MIDI ...	CLR.B	(A6)+OPFREAD	; processus fils n'existe plus	NTREL	?ABORT;----------\\; MIDIPRESS >;==========/; Lit les touches presses sur le clavier MIDI.; in	-; out	A4.L	^table de touches presses.;	D7.W	erreur; mod	D7.W, A4.LMIDIPRESS:	PUSHM.L	D1,D2,D4	LOAD.L	A4,#(A6)+OBURST	; A4 <-- ^buffer	LOAD.L	D4,#2+128	; D4 <-- lg demande	LOAD.W	D1,#TYPIO	; D1 <-- type	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DRSTATUS	JUMP',NE 90$	ADD.L	A4,#2		; A4 <-- ^table des touches presses90$:	POPM.L	D1,D2,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MIDITIME >;=========/; Lit le temps propre  MIDI.; in	-; out	D4.W	temps (en ms);	D7.W	erreur; mod	D4.L, D7.WMIDITIME:	PUSHM.L	D1,D2,A4	LOAD.L	A4,#(A6)+OBUCOM	; A4 <-- ^buffer	LOAD.L	D4,#2		; D4 <-- lg demande	LOAD.W	D1,#TYPIO	; D1 <-- type	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DRSTATUS	LOAD.W	D4,(A4)		; D4 <-- temps	POPM.L	D1,D2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; COMMAND >;========/; Envoie une commande  MIDI.; in	A4.L	^commande; out	D7.W	erreur; mod	D7.WCOMMAND:	PUSHM.L	D1,D2	LOAD.W	D1,#TYPIO	; D1 <-- type	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DCOMMAND	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; STOPMIDI >;=========/; Stoppe compltement MIDI.; in	-; out	-; mod	D7.WSTOPMIDI:	PUSHM.L	D2,D410$:	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DAVOTR		; avort lecture/criture	LOAD.W	D4,#50/2	NTREL	?SETTIM	NTREL	?WFABDESC	; attend la fin des processus fils	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE 10$	POPM.L	D2,D4	RET;--------\\; OPEMIDI >;========/; Ouvre le driver MIDI.; in	-; out	D7.W	erreur; mod	D7.WOPEMIDI:	PUSHM.L	D2,D3,A2..A4; Dinstalle l'usart en utilisant les noms #PR, #PP, #MI et #MO.	LOAD.L	A3,#R16"LUSART0	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL	LOAD.L	A3,#R16"LUSART1;	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL	LOAD.L	A3,#R16"LUSART2;	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL	LOAD.L	A3,#R16"LUSART3;	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL; Installe le driver MIDI  la place de l'usart.	CLR.B	(A6)+ONIMIDI	; driver MIDI install ici	LOAD.L	A3,#R16"LMIDI	; A3 <-- ^nom logique	LOAD.L	A4,#R16"PMIDI	; A4 <-- ^nom physique	LOAD.L	A2,#0		; A2 <-- ^paramtres;	CLR.W	D3		; D3 <-- pour tous	FOS	?INSTALL	; install le driver	JUMP',EQ 50$	COMP.W	D7,#ERUUSE	; dj install ?	JUMP',NE 90$		; non => 90$				; oui =>	SET.B	(A6)+ONIMIDI	; driver MIDI pas install ici50$:	LOAD.L	A3,#R16"DMIDI	FOS	?UNAMDRIV	; D2 <-- numro de driver	JUMP,NE	90$	LOAD.W	(A6)+ONDMIDI,D2	90$:	POPM.L	D2,D3,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOMIDI >;========/; Ferme le driver MIDI.; in	-; out	-; mod	D7.WCLOMIDI:	PUSHM.L	D3,A3	TEST.B	(A6)+ONIMIDI	; driver MIDI install ici ?	JUMP,T	90$		; non => 90$	LOAD.L	A3,#R16"LMIDI	; A3 <-- ^nom logique	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL	; dinstall le driver90$:	POPM.L	D3,A3	RET; Textes; ------LUSART0:.ASCIZ	"#PR"LUSART1:.ASCIZ	"#PP"LUSART2:.ASCIZ	"#MI"LUSART3:.ASCIZ	"#MO"LMIDI:	.ASCIZ	"#MIDI:"PMIDI:	.ASCIZ	"$MIDI_0"DMIDI:	.ASCIZ	"MIDI_0"	.EVEN	.END