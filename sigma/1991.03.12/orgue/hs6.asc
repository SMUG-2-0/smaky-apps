	.TITLE	HS6.ASC;	--------------------------------------;		(C) 1987 - Daniel Roux;	--------------------------------------	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULESHSREV	=	1		; rvisionHSVERS	=	0		; version	.REV	HSREV,HSVERS	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LBREAD	=	1024*(32+1)LBWRITE	=	100SLPOS	=	4SLDIM	=	20TXPOS	=	SLPOS+SLDIM+10TXDIM	=	30LBUFILE	=	50; En-tte des fichiers .HS6; -------------------------LHSTXT	=	256	.LOC	0OHSFAN:	.BLKB	4		; type	.BLKB	60		; rserveOHSTXT:	.BLKB	LHSTXT		; texte d'identificationLHS:; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHEPRO:.BLKB	2		; canal module EPROOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOPDDIS:	.BLKB	4		; ^descripteur de la fentreOBUDIS:	.BLKB	400		; buffer write-displayOTXPOS:	.BLKB	4OTXDIM:	.BLKB	4OSLVAR:	.BLKB	LSLVAR		; variables de la scroll-listeOBUFILE:.BLKB	LBUFILE		; buffer pour un nom de fichierONFILE:	.BLKB	2		; nb de fichiersOBFILE:	.BLKB	4		; ^noms des fichiersOHEAD:	.BLKB	LHS		; en-tteONDMIDI:.BLKB	2		; no du driver MIDIONIMIDI:.BLKB	1		; 1 => driver MIDI pas install ici	.EVENOFLAGS:	.BLKB	1 BWAIT   = 0	.EVENOLWAIT:	.BLKB	4OBWRITE:.BLKB	LBWRITEOBREAD:	.BLKB	LBREADLGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables	SR.L	D4,#110$:	CLR.W	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT2	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	NOEFLI	.B	0	.EVEN	LOAD.L	D3,#H'005500AA	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise toute la fentre	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMEPRO	LOAD.W	D3,#EPRO_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHEPRO,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	CALL	OPEMIDI		; ouvre le driver MIDI	JUMP,NE ERFAT2LOOP:	CALL	DBOXLISTE	; dialogue ...ERFAT:	CALL	CLOMIDI		; ferme le driver MIDI	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHEPRO	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSEERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT;----------\\; DBOXLISTE >;==========/; DBOX principale.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7W.DBOXLISTE:	PUSHM.L	D1,D2,D4,D5,A1..A5	CLR.L	D4	LOAD.L	A2,#R16"TDBOX_LISTE	CLR.W	D2	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$RELISTE$:	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^descripteur scroll-list	CALL	DBLISTDSL	; dessine la scroll-list vide	CALL	DBLISTDTX	; dessine le rectangle pour le texte	CALL	GETLIST		; fait la liste ...	JUMP,NE REFAIT$	LOAD.W	(A5)+OSLCYS,#-1	; dans la case vide	CALL	DBLISTUSL	; dessine le contenuREFAIT$:	CALL	DBLISTTAKE	CALL	DBLISTATX	; dessine le texteLOOP$:	CALL	NORMMOUSE	; souris: enlve le sablier	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_LISTE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ PREND$	COMP.W	D3,#F3	JUMP,EQ SAUVE$	COMP.W	D3,#F7	JUMP,EQ EDITE$	COMP.W	D3,#F10	JUMP,EQ SUPPRIME$	COMP.W	D3,#F0	JUMP,EQ TERMINE$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ERROR$:	PUSH.W	D7	CALL	NORMMOUSE	; remet la flche	POP.W	D7	TEST.W	D7	JUMP,EQ LOOP$	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP$	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	AFMENU		; refait les soft-keys	JUMP	LOOP$CLIC$:				; CLIC =>	CALL	DBLISTMSL	; dplace scroll-list ...	JUMP,NE BIP$	JUMP	REFAIT$PREND$:	CALL	PREND		; envoie  l'orgue ...	JUMP,NE ERROR$	JUMP	LOOP$SAUVE$:	CALL	SAUVE		; lit l'orgue puis sauve sur disque ...	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP	RELISTE$EDITE$:	CALL	EDITE		; dite le texte d'accompagnement ...	JUMP,NE ERROR$	JUMP	REFAIT$SUPPRIME$:	CALL	SUPPRIME	; supprime un fichier ...	JUMP,NE ERROR$	JUMP	RELISTE$TERMINE$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:                                           	POPM.L	D1,D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBLISTTAKE >;-----------/; Modifie le contenu des touches selon la scroll-list.; in	A5.L	^description scroll-list; out	-; mod	D7.WDBLISTTAKE:	PUSHM.L	D2..D4	LOAD.W	D2,#1!2^BDBGCLABEL!2^BDBGCFULL	TEST.W	(A5)+OSLCYS	JUMP',NC 20$	LOAD.W	D2,#1!2^BDBGCLABEL!2^BDBGCGREY20$:	DBOX_	GETCO		; grise/dgrise la touche	LOAD.W	D2,#3!2^BDBGCLABEL!2^BDBGCFULL	TEST.W	(A5)+OSLCYS	JUMP',NC 30$	LOAD.W	D2,#3!2^BDBGCLABEL!2^BDBGCGREY30$:	DBOX_	GETCO		; grise/dgrise la touche	LOAD.W	D2,#4!2^BDBGCLABEL!2^BDBGCFULL	TEST.W	(A5)+OSLCYS	JUMP',NC 40$	LOAD.W	D2,#4!2^BDBGCLABEL!2^BDBGCGREY40$:	DBOX_	GETCO		; grise/dgrise la touche	POPM.L	D2..D4	RET;----------\\; DBLISTDTX >;----------/; Dessine le rectangle pour le texte.; in	-; out	-; mod	D7.WDBLISTDTX:	PUSHM.L	D2..D4	LOAD.W	D2,#21!2^BDBGCLABEL	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO	POP.L	D4	SUB.W	D3,#8	ADD.W	D4,#8	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OSLVAR+OSLPOS+0	LOAD.W	D4,(A6)+OSLVAR+OSLDIM+0	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OTXPOS,D3	LOAD.L	(A6)+OTXDIM,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	AND.L	D4,#H'FFFF	LIB	?DRSEG	POPM.L	D2..D4	RET;----------\\; DBLISTATX >;----------/; Dessine le texte contenu dans le rectangle.; in	-; out	-; mod	D7.WDBLISTATX:	PUSHM.L	D1..D6,A3,A4	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A6)+OTXPOS	LOAD.L	D4,(A6)+OTXDIM	INC.W	D3	DEC.W	D4	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	ADD.W	D3,(A0)+ODFCY	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,(A0)+ODFCY	SUB.W	D4,(A0)+ODFCY	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface tout	LIB	?GETWDO	LOAD.W	D1,D5		; D1 <-- no swdo	LOAD.L	D3,(A6)+OTXPOS	LOAD.L	D4,(A6)+OTXDIM	ADD.W	D3,(A0)+ODFFX	ADD.W	D3,#8	SUB.W	D4,#8+8	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,(A0)+ODFFY	ADD.W	D3,#4	SUB.W	D4,#4+4	SWAP.W	D3	SWAP.W	D4	LIB	?CREWDO	LIB	?USEWDO	LOAD.B	D3,#EFLI	LIB	?AFCAR		; efface la premire ligne	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	JUMP,NS 80$	MUL.WU	D3,#16	LOAD.L	A3,(A6)+OBFILE	ADD.L	A3,D3		; A3 <-- ^nom	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPRD	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL	POPM.L	D0	JUMP,NE 80$	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	D4,#LHS	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 70$	LOAD.L	D4,(A4)+OHSFAN	CALL	FANTYP		; D3 <-- type	LOAD.L	A3,#R16"01$20$:	TEST.B	(A3)	JUMP,EQ 28$	COMP.B	D3,(A3+)	JUMP,EQ 24$22$:	TEST.B	(A3+)	JUMP,NE 22$	JUMP	20$24$:	LIB	?AFTEXT28$:	LIB	?AFCR	LIB	?AFCR	LIB	?BUCAR	LOAD.L	A3,#(A4)+OHSTXT	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDY	ADD.W	D4,(A0)+ODFC1Y	SUB.W	D4,(A0)+ODFPY	DIV.WU	D4,(A0)+ODFCY	; D4 <-- nb max de lignes30$:	LOAD.B	D3,(A3+)	JUMP,EQ 38$	COMP.B	D3,#CR	JUMP,EQ 35$	LIB	?AFCAR	JUMP	30$35$:	DEC.W	D4	JUMP,EQ 38$	LIB	?AFCR	JUMP	30$38$:	LIB	?NOBUCAR70$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D780$:	EX.L	D5,D1	LIB	?USEWDO	LOAD.W	D5,D1	LIB	?KILWDO	POPM.L	D1..D6,A3,A4	RET01$:	.ASCIZ	"<H'10>M. Tout les paramtres"	.ASCIZ	"<H'11>M. Seulement les boutons"	.ASCIZ	"<H'12>C.S.P. / R.S.P."	.ASCIZ	"<H'13>F.M.P."	.ASCIZ	"<H'14>Motifs USER 1"	.ASCIZ	"<H'15>Motifs USER 2"	.ASCIZ	"<H'16>Voix USER 1.2.3.4"	.B	0	.EVEN;----------\\; DBLISTDSL >;----------/; Dessine la scroll-list vide.; in	A5.L	^description scroll-list; out	-; mod	D7.WDBLISTDSL:	PUSHM.L	D2..D4,A3	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	LOAD.W	D2,#11!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A5)+OSLPOS+2	LOAD.W	(A5)+OSLDIM+2,D3	SWAP.W	D3	SUB.W	D3,(A5)+OSLPOS+0	ADD.W	D3,(A0)+ODFC2Y	LOAD.W	(A5)+OSLDIM+0,D3	SET.B	(A5)+OSLVID	; case vide en haut	LOAD.L	A3,#R16"00$	; A3 <-- ^texte pour case vide	SCROLL_	LDRAW		; dessine la scroll-list	POPM.L	D2..D4,A3	RET00$:	.ASCIZ	"<'<>nouveau<'>>"	.EVEN;----------\\; DBLISTUSL >;----------/; Met  jour le contenu de la scroll-list.; in	A5.L	^description scroll-list; out	-; mod	D7.WDBLISTUSL:	PUSH.L	A3	LOAD.W	(A5)+OSLCYN,(A6)+ONFILE	LOAD.L	A3,#R16"DBLISTGSL	LOAD.L	(A5)+OSLADL,A3	SCROLL_	LUPDATE		; mj. le contenu	POP.L	A3	RET;----------\\; DBLISTGSL >;----------/; Donne le contenu d'une case.; Cette routine est appele directement depuis SCROLL_LUPDATE.; in	D3.W	rang de la case; out	D3.W	zro;	A3.L	^contenu de la case;	D7.W	erreur si la case est vide; mod	D3.L, D7.W, A3.LDBLISTGSL:	PUSH.L	A4	LOAD.L	A3,(A6)+OBFILE	MUL.WU	D3,#16	ADD.L	A3,D3	LOAD.L	A4,#(A6)+OBUDIS20$:	LOAD.B	D3,(A3+)	JUMP,EQ 30$	COMP.B	D3,#'.	JUMP,EQ 30$	LOAD.B	(A4+),D3	JUMP	20$30$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^nom sans extension	CLR.W	D3		; D3 <-- retourne toujours zro	POP.L	A4	CLR.W	D7		; retour EQ	RET;----------\\; DBLISTMSL >;----------/; Dplace la scroll-list.; in	A5.L	^description scroll-list; out	D7.W	erreur; mod	D7.WDBLISTMSL:	PUSH.L	D4	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 90$	LOAD.W	D7,#1	SUB.W	D4,(A0)+ODFFX	; D4 <-- position relative dans swdo	JUMP',LO 90$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',LO 90$	SWAP.W	D4	SCROLL_	LMOVE		; mj. le contenu90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RETTDBOX_LISTE:	.W	10$-TDBOX_LISTE	.W	TMENU_LISTE-TDBOX_LISTE	.W	0,010$:	.B	ODBTITLE	.ASCIZ	"SMAKY 100 / YAMAHA HS-6"	.B	ODBTABX,SLPOS	.B	ODBLABEL,10	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,TXPOS	.B	ODBLABEL,20	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR	.B	ODBCR	.B	ODBCR	.B	ODBCR	.B	ODBCR	.B	ODBCR	.B	ODBCR	.B	ODBCR	.B	ODBCR	.B	ODBCR	.B	ODBCR	.B	ODBTABX,SLPOS+SLDIM	.B	ODBLABEL,11	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,TXPOS+TXDIM	.B	ODBLABEL,21	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,TXPOS+TXDIM+5	.B	ODBCR,ODBCR	.B	ODBTABX,SLPOS	.B	ODBLABEL,1	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" PREND "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBLABEL,2	.B	ODBBOX,0,F3,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBTABX,TXPOS	.B	ODBLABEL,3	.B	ODBBOX,0,F7,TDBMEV	.ASCIZ	" EDITE "	.B	ODBTEXT	.ASCIZ	"         "	.B	ODBLABEL,4	.B	ODBBOX,0,F10,TDBNORM	.ASCIZ	" SUPPRIME "	.B	0TMENU_LISTE:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Edite"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Supprime"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_LISTE:	.W	F1,0			DOKF1-TKEY_LISTE	.W	F3,0			DOKF3-TKEY_LISTE	.W	F7,F8,F9,0		DOKF7-TKEY_LISTE	.W	F10,F11,F12,0		DOKF10-TKEY_LISTE	.W	F0,END,0		DOKF0-TKEY_LISTE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_LISTE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_LISTE	.W	0;----------\\; DBOXSAUVE >;==========/; Demande que et comment sauver.; in	-; out	D4.L	fanions;	D3.W	dernire touche;	D7.W	erreur; mod	D4.L, D3.L, D7.WDBOXSAUVE:	PUSHM.L	D1,D2,A2..A5	CALL	NORMMOUSE	; enlve le sablier	LOAD.L	D4,#1		; D4 <-- fanions	LOAD.L	A4,#(A6)+OBUFILE	CLR.B	(A4)	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	JUMP,NS 20$	LOAD.L	D4,(A6)+OHEAD+OHSFAN ; D4 <-- fanions	MUL.WU	D3,#16	LOAD.L	A3,(A6)+OBFILE	ADD.L	A3,D3		; A3 <-- ^nom10$:	LOAD.B	(A4+),(A3+)	JUMP,NE 10$20$:	LOAD.L	A5,#(A6)+OBUFILE	LOAD.L	A4,#R16"TXEXT+1	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A2,#R16"TDBOX_SAUVE	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXT1	TEST.W	(A6)+OSLVAR+OSLCYS	JUMP,NC 30$	TSET.L	D3:#BDBIONMAJ30$:	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_SAUVE	DBOX_	EXTEND		; dialogue ...	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	POPM.L	D1,D2,A2..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_SAUVE:	.B	LDBOX_SAUVE	.B	ODBLCIRCLE,0	.ASCIZ	" tout"	.B	ODBTABX,20	.B	ODBLCIRCLE,4	.ASCIZ	" motifs USER 1"	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" boutons"	.B	ODBTABX,20	.B	ODBLCIRCLE,5	.ASCIZ	" motifs USER 2"	.B	ODBCR	.B	ODBLCIRCLE,2	.ASCIZ	" C.S.P. / R.S.P."	.B	ODBTABX,20	.B	ODBLCIRCLE,6	.ASCIZ	" voix USER"	.B	ODBCR	.B	ODBLCIRCLE,3	.ASCIZ	" F.M.P."	.B	ODBCRLDBOX_SAUVE	=	.-TDBOX_SAUVE-1	.EVENTDBOX_IO:	.ASCIZ	"HS6"	.ASCIZ	"Fbanque de son"	.ASCIZ	""	.B	0	.EVEN;--------\\; PREND   >;========/; Envoie des sons  l'orgue.; in	-; out	D7.W	erreur; mod	D7.WPREND:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.W	D7,#ERKSTO	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	JUMP,NS 90$	MUL.WU	D3,#16	LOAD.L	A3,(A6)+OBFILE	ADD.L	A3,D3	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPRD	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL	POPM.L	D0	JUMP,NE 90$	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	D4,#LHS	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 80$	LOAD.L	A4,#(A6)+OBREAD	LOAD.L	D4,#LBREAD	FOS	?RDBYTE		; lit le data	COMP.W	D7,#EROUTF	JUMP,NE 80$	LOAD.L	D4,(A6)+OHEAD+OHSFAN	CALL	FANTYP		; D3 <-- type	CALL	SENDMSG		; envoie  l'orgue ...	PUSH.W	D7	LIB	?BUZZ		; c'est prt !	POP.W	D780$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SAUVE   >;========/; Lit sur l'orgue puis sauve sur disque un fichier .HS6; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WSAUVE:	PUSHM.L	D0..D2,D6,A1,A3,A4	CALL	DBOXSAUVE	; demande le nom et le mode ...	JUMP,NE 90$	COMP.W	D3,#F0	JUMP,EQ 90$	LOAD.W	D0,D3		; D0 <-- F1/F4	LOAD.L	A3,#(A6)+OBUFILE	LOAD.L	A4,#R16"TXEXT+1	LOAD.W	D3,#1	LIB	?ADDEXT	CALL	WAITMOUSE	; met le sablier	LOAD.L	D2,D4		; D2 <-- fanions	CALL	FANTYP		; D3 <-- type	CALL	WAITMSG	PUSH.W	D7	LIB	?BUZZ		; c'est prt !	POP.W	D7	LOAD.L	A1,A4	LOAD.L	D1,D4	LOAD.W	D7,#ERTIMO	COMP.L	D1,#10	JUMP,LO 90$	TEST.W	(A6)+OSLVAR+OSLCYS	JUMP,NC 50$10$:	LOAD.L	A3,#(A6)+OBUFILE	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	PUSH.L	D0	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL	POPM.L	D0	JUMP,EQ 15$		; ok => 15$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	COMP.W	D0,#F4		; touche (MET A JOUR) ?	JUMP,EQ 12$		; oui => 12$				; non =>	CALL	NORMMOUSE	; remet la flche	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE 90$	COMP.W	D3,#'O	JUMP,NE 90$12$:	PUSH.L	D0	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL	POPM.L	D0	JUMP,NE 90$	JUMP	10$15$:	CALL	WAITMOUSE	; met le sablier	LOAD.L	A3,#(A6)+OBUFILE	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE 90$	LOAD.L	A3,#(A6)+OHEAD	LOAD.W	D3,#LHS-120$:	CLR.B	(A3+)	DECJ.W,NMO D3,20$	LOAD.L	(A6)+OHEAD+OHSFAN,D2	LOAD.L	A3,#(A6)+OHEAD+OHSTXT	LOAD.L	A4,#R16"00$	LOAD.L	D4,D2	CALL	FANTYP		; D3 <-- type22$:	TEST.B	(A4)	JUMP,EQ 30$	COMP.B	D3,(A4+)	JUMP,EQ 26$24$:	TEST.B	(A4+)	JUMP,NE 24$	JUMP	22$26$:	LOAD.B	(A3+),(A4+)	JUMP,NE 26$30$:	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	D4,#LHS	FOS	?WRBYTE		; crit l'en-tte	JUMP,NE 80$	LOAD.L	A4,A1	LOAD.L	D4,D1	FOS	?WRBYTE		; crit le data	JUMP,NE 80$	JUMP	70$50$:	CALL	WAITMOUSE	; met le sablier	LOAD.L	A3,#(A6)+OBUFILE	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE 10$	LOAD.L	(A6)+OHEAD+OHSFAN,D2	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	D4,#OHSTXT	FOS	?WRBYTE		; crit le dbut de l'en-tte	JUMP,NE 80$	CLR.W	D3	LOAD.L	D4,#LHS	FOS	?SPOS		; positionne aprs l'en-tte	JUMP,NE 80$	LOAD.L	A4,A1	LOAD.L	D4,D1	FOS	?WRBYTE		; crit le data	JUMP,NE 80$70$:	LOAD.W	D3,#F180$:	PUSH.W	D7	FOS	?TRUNC	FOS	?CLOSE	POP.W	D790$:	POPM.L	D0..D2,D6,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	H'10	.ASCII	"1. <CR>"	.ASCII	"2. <CR>"	.ASCII	"3. <CR>"	.ASCII	"4. <CR>"	.ASCII	"5. <CR>"	.ASCII	"6. <CR>"	.ASCII	"7. <CR>"	.ASCII	"8. <CR>"	.B	0	.B	H'11	.ASCII	"1. <CR>"	.ASCII	"2. <CR>"	.ASCII	"3. <CR>"	.ASCII	"4. <CR>"	.ASCII	"5. <CR>"	.ASCII	"6. <CR>"	.ASCII	"7. <CR>"	.ASCII	"8. <CR>"	.B	0	.B	H'12	.ASCII	"CSP-1. <CR>"	.ASCII	"CSP-2. <CR>"	.ASCII	"CSP-3. <CR>"	.ASCII	"CSP-4. <CR>"	.ASCII	"RSP-1. <CR>"	.ASCII	"RSP-2. <CR>"	.ASCII	"RSP-3. <CR>"	.ASCII	"RSP-4. <CR>"	.B	0	.B	H'13	.ASCII	"FMP. <CR>"	.B	0	.B	H'14	.ASCII	"ARPEG-1. <CR>"	.ASCII	"RYTHM-1. <CR>"	.B	0	.B	H'15	.ASCII	"ARGEG-2. <CR>"	.ASCII	"RYTHM-2. <CR>"	.B	0	.B	H'16	.ASCII	"VOICE-1. <CR>"	.ASCII	"VOICE-2. <CR>"	.ASCII	"VOICE-3. <CR>"	.ASCII	"VOICE-4. <CR>"	.B	0	.B	0	.EVEN;--------\\; EDITE   >;========/; Edite le texte d'accompagnement.; in	-; out	D7.W	erreur; mod	D7.WEDITE:	PUSHM.L	D3..D6,A3,A4	LOAD.W	D7,#ERKSTO	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	JUMP,NS 95$	LOAD.B	D3,#SAVWDO	LIB	?AFCAR	LIB	?GETWDO		; D5 <-- swdo actuelle	LOAD.L	A3,#R16"02$	LIB	?AFMENU	LOAD.L	A3,#(A6)+OHEAD+OHSTXT	LOAD.L	A4,A3	LOAD.L	D3,#LHSTXT-2	; D3 <-- lg max	LOAD.W	D4,#2^BEPRONI	; D4 <-- pas d'informations	EPRO_	OPEN	JUMP,NE 90$	CALL	NORMMOUSE	; enlve le sablier10$:	LOAD.L	A4,#R16"01$	; A4 <-- ^touches terminatrices	EPRO_	MAIN		; dite ...	COMP.W	D3,#END	JUMP,EQ 20$	COMP.W	D3,#F0	JUMP,EQ 20$	COMP.W	D3,#F0+SHIFT	JUMP,EQ 20$	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	10$20$:	EPRO_	CLOSE	CALL	WAITMOUSE	; met le sablier	LOAD.W	D7,#ERKSTO	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	MUL.WU	D3,#16	LOAD.L	A3,(A6)+OBFILE	ADD.L	A3,D3	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL	POPM.L	D0	JUMP,NE 90$	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	D4,#LHS	FOS	?WRBYTE		; met  jour l'en-tte	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	PUSH.W	D7	LIB	?USEWDO		; rutilise la swdo originale	LOAD.B	D3,#GETWDO	LIB	?AFCAR	CALL	AFMENU		; refait les soft-keys	POP.W	D795$:	POPM.L	D3..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET01$:	.W	002$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN;---------\\; SUPPRIME >;=========/; Demande s'il faut supprimer un fichier.; in	-; out	D7.W	erreur; mod	D7.WSUPPRIME:	PUSHM.L	D2,D3,A3	LOAD.W	D7,#ERKSTO	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	JUMP,NS 90$	MUL.WU	D3,#16	LOAD.L	A3,(A6)+OBFILE	ADD.L	A3,D3	LOAD.W	D2,#2^BDBSAV	LIST_	DELETE		; demande s'il faut dtruire ...	JUMP,NE 90$	COMP.W	D3,#'O	JUMP,EQ 50$	LOAD.W	D7,#ERKSTO	JUMP	90$50$:	FOS	?DELETE		; dtruit le fichier90$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	POPM.L	D2,D3,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETLIST >;========/; Lit la liste des fichiers .HS6; in	-; out	D7.W	erreur; mod	D7.WGETLIST:	PUSHM.L	D1,D2,D4,D6,A2..A4	CALL	WAITMOUSE	; souris: met le sablier	TEST.L	(A6)+OBFILE	JUMP,EQ 10$	LOAD.L	A4,(A6)+OBFILE	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend l'ancienne liste	CLR.L	(A6)+OBFILE10$:	LOAD.L	A3,#R16"TXEXT	LIST_	OPEN		; D6 <-- canal de la liste	JUMP,NE 90$	LIST_	NBMAX		; D4 <-- nb de fichiers	LOAD.W	(A6)+ONFILE,D4	INC.W	D4	MUL.WU	D4,#16	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour nouvelle liste	JUMP,NE 80$	LOAD.L	(A6)+OBFILE,A4	LOAD.L	A2,A420$:	LIST_	NEXT		; A3/A4 <-- ^nom/^arguments	JUMP,NE 80$	LOAD.L	(A2+),(A3+)	LOAD.L	(A2+),(A3+)	LOAD.L	(A2+),(A3+)	LOAD.L	(A2+),(A3+)	; OBFILE <-- un nom	JUMP	20$80$:	PUSH.W	D7	LIST_	CLOSE	POP.W	D7	COMP.W	D7,#EROUTF	JUMP,NE 90$	CLR.W	D790$:	POPM.L	D1,D2,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET	.SBTTL	HS6MIDI;--------\\; FANTYP  >;========/; Donne le type en fonction des fanions.; in	D4.L	fanions; out	D3.B	type; mod	D3.B, D7.WFANTYP:	PUSHM.L	D4	LOAD.B	D3,#H'1010$:	RR.W	D4,#1	JUMP,CS 90$	INC.B	D3	JUMP	10$90$:	POPM.L	D4	RET;--------\\; WAITMSG >;========/; Demande quelque chose, et attend la rponse.; in	D3.B	message  envoyer; out	A4.L	^data reu;	D4.L	lg data reu;	D7.W	erreur; mod	D4.L, D7.W, A4.LWAITMSG:	PUSHM.L	D2,D3,D5,A3,A5	LOAD.B	D2,D3		; D2 <-- message	TSET.B	(A6)+OFLAGS:#BWAIT	NTREL	?GETPRIO	; D4 <-- priorit	DEC.W	D4	LOAD.L	D5,#600		; D5 <-- lg stack	LOAD.L	A5,#R16"PWAIT	; A5 <-- ^start	LOAD.L	A3,#R16"NWAIT	; A3 <-- ^nom	NTREL	?CRETASK	; dmarre la rception	JUMP,NE 90$30$:	LIB	?IFCAR		; vide le fifo du clavier !	JUMP,EQ 30$	LOAD.L	A4,#(A6)+OBWRITE	LOAD.B	(A4)+0,#0	LOAD.B	(A4)+1,#6	LOAD.B	(A4)+2,#H'F0	LOAD.B	(A4)+3,#H'43	LOAD.B	(A4)+4,#H'70	LOAD.B	(A4)+5,#H'70	LOAD.B	(A4)+6,D2	LOAD.B	(A4)+7,#H'F7	CALL	WRMIDI	LOAD.W	D2,#10*10	; D2 <-- attend 10 secondes maximum40$:	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLAGS:#BWAIT	JUMP,BC 45$	LIB	?IFCAR		; touche presse ?	JUMP,EQ 44$		; oui => 44$	LOAD.W	D4,#50/10	NTREL	?DELMS		; attend un peu ...	DEC.W	D2	JUMP,NE 40$44$:	LOAD.W	D7,#ERUNCO	; D7 <-- unit pas connecte45$:	PUSH.W	D7	CALL	STOPMIDI	; stoppe tout	POP.W	D7	LOAD.L	A4,#(A6)+OBREAD	; A4 <-- ^data reu	LOAD.L	D4,(A6)+OLWAIT	; D4 <-- lg data reu50$:	COMP.L	D4,#4	JUMP,LO 90$	TEST.W	(A4)		; indication de temps ?	JUMP,NE 90$		; non => 90$				; oui =>	ADD.L	A4,#4		; A4 <-- saute le temps	SUB.L	D4,#4	JUMP	50$90$:	POPM.L	D2,D3,D5,A3,A5	TEST.W	D7		; retour EQ/NE	RET;;;;;;;;;;;;;;;    WAIT    ;;;;;;;;;;;;;;;NWAIT:	.ASCIZ	"MIDI_WAIT"	.EVENPWAIT:	LOAD.L	A4,#(A6)+OBREAD	LOAD.L	D5,#LBREAD-10	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DREAD	LOAD.L	(A6)+OLWAIT,D5	TCLR.B	(A6)+OFLAGS:#BWAIT	NTREL	?ABORT;--------\\; SENDMSG >;========/; Envoie un message.; in	D3.B	message;	A4.L	^data; out	D7.W	erreur; mod	D7.WSENDMSG:	PUSHM.L	D3,D4,A4	AND.B	D3,#H'0F	OR.B	D3,#H'20	PUSH.L	A4	LOAD.L	A4,#(A6)+OBWRITE	LOAD.B	(A4)+0,#0	LOAD.B	(A4)+1,#6	LOAD.B	(A4)+2,#H'F0	LOAD.B	(A4)+3,#H'43	LOAD.B	(A4)+4,#H'70	LOAD.B	(A4)+5,#H'70	LOAD.B	(A4)+6,D3	LOAD.B	(A4)+7,#H'F7	CALL	WRMIDI	POP.L	A4;;?	LOAD.B	(A4)+5,#H'70	LOAD.B	(A4)+6,#H'00	CALL	WRMIDI	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRMIDI  >;========/; Ecrit plusieurs bytes sur MIDI.; in	A4.L	^<<lg>>data; out	D7.W	erreur; mod	D7.WWRMIDI:	PUSHM.L	D2,D5	CLR.L	D5	LOAD.W	D5,(A4)	ADD.W	D5,#2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DWRITE		; crit tout a	POPM.L	D2,D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; COMMAND >;========/; Envoie une commande  MIDI.; in	A4.L	^commande; out	D7.W	erreur; mod	D7.WCOMMAND:	PUSHM.L	D1,D2	LOAD.W	D1,#TYPIO	; D1 <-- type	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DCOMMAND	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; STOPMIDI >;=========/; Stoppe compltement MIDI.; in	-; out	-; mod	D7.WSTOPMIDI:	PUSH.L	D2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DAVOTR		; avort lecture/criture;;?	NTREL	?WFABDESC	; attend la fin des processus fils	POP.L	D2	RET;--------\\; OPEMIDI >;========/; Ouvre le driver MIDI.; in	-; out	D7.W	erreur; mod	D7.WOPEMIDI:	PUSHM.L	D2,D3,A2..A4; Dinstalle l'usart en utilisant les noms #PR, #PP, #MI et #MO.	LOAD.L	A3,#R16"LUSART0	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL	LOAD.L	A3,#R16"LUSART1;	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL	LOAD.L	A3,#R16"LUSART2;	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL	LOAD.L	A3,#R16"LUSART3;	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL; Installe le driver MIDI  la place de l'usart.	CLR.B	(A6)+ONIMIDI	; driver MIDI install ici	LOAD.L	A3,#R16"LMIDI	; A3 <-- ^nom logique	LOAD.L	A4,#R16"PMIDI	; A4 <-- ^nom physique	LOAD.L	A2,#0		; A2 <-- ^paramtres;	CLR.W	D3		; D3 <-- pour tous	FOS	?INSTALL	; install le driver	JUMP,EQ 50$	COMP.W	D7,#ERUUSE	; dj install ?	JUMP,NE	90$		; non => 90$				; oui =>	SET.B	(A6)+ONIMIDI	; driver MIDI pas install ici50$:	LOAD.L	A3,#R16"DMIDI	FOS	?UNAMDRIV	; D2 <-- numro de driver	JUMP,NE	90$	LOAD.W	(A6)+ONDMIDI,D2	90$:	POPM.L	D2,D3,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOMIDI >;========/; Ferme le driver MIDI.; in	-; out	-; mod	D7.WCLOMIDI:	PUSHM.L	D3,A3	TEST.B	(A6)+ONIMIDI	; driver MIDI install ici ?	JUMP,T	90$		; non => 90$	LOAD.L	A3,#R16"LMIDI	; A3 <-- ^nom logique	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL	; dinstall le driver90$:	POPM.L	D3,A3	RET	.SBTTL	HS6MISC;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; AFMENU  >;========/; Refait les soft-keys.; in	-; out	-; mod	D7.WAFMENU:	PUSH.L	A3	LOAD.L	A3,#R16"TMENU_LISTE	LIB	?AFMENU	POP.L	A3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF10:	LOAD.W	D3,#F10	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RET	.SBTTL	HS6TABLE; Textes; ------TXEXT:	.ASCIZ	"*.HS6"LUSART0:.ASCIZ	"#PR"LUSART1:.ASCIZ	"#PP"LUSART2:.ASCIZ	"#MI"LUSART3:.ASCIZ	"#MO"LMIDI:	.ASCIZ	"#MIDI:"PMIDI:	.ASCIZ	"$MIDI_0"DMIDI:	.ASCIZ	"MIDI_0"; Noms des modules; ----------------NMDBOX:	.ASCIZ	"DBOX"NMEPRO:	.ASCIZ	"EPRO"NMLIST:	.ASCIZ	"LIST"NMSCROLL:.ASCIZ	"SCROLL"	.EVEN	.END	START