	.TITLE	CLAVIER;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------;	Source pour EPROM 2732 du processeur HD63P01	.PROC	M6801		; mmes instructions que le M6801; Principales adresses mmoires; -----------------------------REG	=	16'0000		; registres internesRAM	=	16'0080		; dbut de la RAM interneLRAM	=	16'0080		; lg de la RAM interneROM	=	16'F000		; dbut de l'EPROM 2732LROM	=	16'1000		; lg de l'EPROM 2732; Internal register area; ----------------------	.LOC	REGDDIR1:	.BLK.8	1		; port1: directionDDIR2:	.BLK.8	1		; port2: directionDATA1:	.BLK.8	1		; port1: dataDATA2:	.BLK.8	1		; port2: dataDDIR3:	.BLK.8	1		; port3: directionDDIR4:	.BLK.8	1		; port4: directionDATA3:	.BLK.8	1		; port3: dataDATA4:	.BLK.8	1		; port4: dataTIMER:	.BLK.8	1		; timer: control and statusCOUNTH:	.BLK.8	1		; counter (high)COUNTL:	.BLK.8	1		; counter (low)COMPH:	.BLK.8	1		; compare (high)COMPL:	.BLK.8	1		; compare (low)CAPTH:	.BLK.8	1		; capture (high)CAPTL:	.BLK.8	1		; capture (low)CTRL3:	.BLK.8	1		; port3: controlRATE:	.BLK.8	1		; rate and modeTRSTA:	.BLK.8	1		; transmit/receive statusRDATA:	.BLK.8	1		; receive: dataTDATA:	.BLK.8	1		; transmit: dataRAMCR:	.BLK.8	1		; RAM control; Priphriques; -------------; Les [] indiquent l'tat de repos (inactif) !; N.C. = not connected; DATA1 bit0	-->	[1] data out; DATA1 bit1	-->	[1] data out; DATA1 bit2	-->	[1] data out; DATA1 bit3	-->	[1] data out; DATA1 bit4	-->	[1] data out; DATA1 bit5	-->	[1] data out; DATA1 bit6	-->	[1] data out; DATA1 bit7	-->	[1] data out; DATA2 bit0	<--	N.C.; DATA2 bit1	<--	N.C.; DATA2 bit2	<--	N.C.; DATA2 bit3	<--	N.C.; DATA2 bit4	-->	midi out; DATA3 bit0	<--	[0] p'tit bouton; DATA3 bit1	-->	[0] p'tite led; DATA3 bit2	<--	N.C.; DATA3 bit3	<--	N.C.; DATA3 bit4	<--	N.C.; DATA3 bit5	<--	N.C.; DATA3 bit6	<--	N.C.; DATA3 bit7	<--	N.C.; DATA4 bit0	<--	[1] data in; DATA4 bit1	<--	[1] data in; DATA4 bit2	<--	[1] data in; DATA4 bit3	<--	[1] data in; DATA4 bit4	<--	[1] data in; DATA4 bit5	<--	[1] data in; DATA4 bit6	<--	[1] data in; DATA4 bit7	<--	[1] data in; Variables; ---------	.LOC	RAMCLA1:	.BLK.8	1		; tat du clavierCLA2:	.BLK.8	1		; tat du clavierCLA3:	.BLK.8	1		; tat du clavierCLA4:	.BLK.8	1		; tat du clavierCLA5:	.BLK.8	1		; tat du clavierCLA6:	.BLK.8	1		; tat du clavierCLA7:	.BLK.8	1		; tat du clavierLIMIT:	.BLK.8	1CANB:	.BLK.8	1CANH:	.BLK.8	1OFBASB:	.BLK.8	1OFBASH:	.BLK.8	1OFCLA:	.BLK.8	1OFNOTE:	.BLK.8	1TOTO:	.BLK.8	1; Dbut de l'EPROM 2732; ---------------------	.LOC	ROMSTART:	MOVE	#RAM+LRAM-1,SP	MOVE	#TAINIT,IX	CALL	INIPER	MOVE	#2'11111111,A	MOVE	A,CLA1	MOVE	A,CLA2	MOVE	A,CLA3	MOVE	A,CLA4	MOVE	A,CLA5	MOVE	A,CLA6	MOVE	A,CLA7	MOVE	#12*2,A	MOVE	A,LIMIT	MOVE	#16'90,A	MOVE	A,CANB	MOVE	A,CANH	MOVE	#12*3,A	MOVE	A,OFBASB	MOVE	A,OFBASH	MOVE	#0,A	MOVE	A,TOTOLOOP:	MOVE	DATA3,A	RRC	A		; p'tit bouton press ?	JUMP,CC NON$		; non => NON$				; oui =>	CALL	MODPAR		; moteur ...NON$:	CALL	IFCLA	MOVE	TOTO,A	COMP	#0,A	JUMP,EQ OFF$	CALL	LEDON	JUMP	LOOPOFF$:	CALL	LEDOFF	JUMP	LOOP;--------\\; MODPAR  >;========/; Paramtrise le clavier.; in	-; out	-; mod	toutMODPAR:	CALL	LEDON		; allume la LED	CALL	GETCAR		; A <-- touche presse	MOVE	#OFBASB,IX	COMP	#0,A	JUMP,EQ TON$	MOVE	#OFBASH,IX	COMP	#2,A	JUMP,EQ TON$	MOVE	#CANB,IX	COMP	#1,A	JUMP,EQ CAN$	MOVE	#CANH,IX	COMP	#3,A	JUMP,EQ CAN$	COMP	#4,A	JUMP,EQ LIMIT$	JUMP	EXIT$TON$:	CALL	GETCAR		; A <-- touche presse	ADD	#12,A	MOVE	A,{IX}	JUMP	EXIT$CAN$:	CALL	GETCAR		; A <-- touche presse	MOVE	#16'90,B	COMP	#0,A		; do ?	JUMP,EQ CANX$	DEC	A		; noire ?	JUMP,EQ EXIT$	INC	B	DEC	A		; r ?	JUMP,EQ CANX$	DEC	A		; noire ?	JUMP,EQ EXIT$	INC	B	DEC	A		; mi ?	JUMP,EQ CANX$	INC	B	DEC	A		; fa ?	JUMP,EQ CANX$	DEC	A		; noire ?	JUMP,EQ EXIT$	INC	B	DEC	A		; sol ?	JUMP,EQ CANX$	DEC	A		; noire ?	JUMP,EQ EXIT$	INC	B	DEC	A		; la ?	JUMP,EQ CANX$	DEC	A		; noire ?	JUMP,EQ EXIT$	INC	B	DEC	A		; si ?	JUMP,EQ CANX$	INC	B	DEC	A		; do ?	JUMP,EQ CANX$	DEC	A		; noire ?	JUMP,EQ EXIT$	INC	B	DEC	A		; r ?	JUMP,EQ CANX$	DEC	A		; noire ?	JUMP,EQ EXIT$	INC	B	DEC	A		; mi ?	JUMP,EQ CANX$	INC	B	DEC	A		; fa ?	JUMP,EQ CANX$	DEC	A		; noire ?	JUMP,EQ EXIT$	INC	B	DEC	A		; sol ?	JUMP,EQ CANX$	DEC	A		; noire ?	JUMP,EQ EXIT$	INC	B	DEC	A		; la ?	JUMP,EQ CANX$	DEC	A		; noire ?	JUMP,EQ EXIT$	INC	B	DEC	A		; si ?	JUMP,EQ CANX$	INC	B	DEC	A		; do ?	JUMP,EQ CANX$	DEC	A		; noire ?	JUMP,EQ EXIT$	INC	B	DEC	A		; r ?	JUMP,EQ CANX$	JUMP	EXIT$CANX$:	MOVE	B,{IX}	JUMP	EXIT$LIMIT$:	CALL	GETCAR		; A <-- touche presse	MOVE	A,LIMIT;	JUMP	EXIT$EXIT$:	CALL	LEDOFF		; teint la LED	RET;--------\\; IFCLA   >;========/; ; in	-; out	-; mod	FIFCLA:	PUSH	A	PUSH	B	PUSH	IX	MOVE	#0,A	MOVE	A,OFCLA	MOVE	#CLA1,IX	; IX <-- ^ancien tat	MOVE	#2'11111110,BLOOP$:	MOVE	B,DATA1		; slectionne une colonne	CALL	BALCO	INC	IX		; IX <-- ^suivant	MOVE	OFCLA,A	ADD	#8,A	MOVE	A,OFCLA		; OFCLA <-- +8 notes	SETC	RLC	B	COMP	#2'01111111,B	JUMP,NE LOOP$	MOVE	#2'11111111,A	MOVE	A,DATA1	POP	IX	POP	B	POP	A	RET;--------\\; BALCO   >;--------/; ; in	IX	^tat; out	{IX}	nouvel tat; mod	FBALCO:	PUSH	A	PUSH	B	MOVE	#0,A	MOVE	A,OFNOTE	MOVE	DATA4,A		; A4 <-- lit une colonne	MOVE	A,B	XOR	{IX},A	JUMP,EQ EXIT$	MOVE	B,{IX}	CALL	TELEG	CALL	TELEG	CALL	TELEG	CALL	TELEG	CALL	TELEG	CALL	TELEG	CALL	TELEG	CALL	TELEGEXIT$:	POP	B	POP	A	RET;--------\\; TELEG   >;--------/; ; in	A	changements;	B	tat; out	A	changements;	B	tat; mod	F,A,BTELEG:	RRC	A	JUMP,CC	EXIT$	PUSH	A	MOVE	OFCLA,A	ADD	OFNOTE,A	COMP	LIMIT,A	JUMP,HS HIGH$				; moiti du bas =>	MOVE	CANB,A	CALL	PUTMIDI	MOVE	OFBASB,A	ADD	OFCLA,A	ADD	OFNOTE,A	CALL	PUTMIDI	JUMP	NEXT$HIGH$:				; moiti du haut =>	MOVE	CANH,A	CALL	PUTMIDI	MOVE	OFBASH,A	ADD	OFCLA,A	ADD	OFNOTE,A	CALL	PUTMIDINEXT$:	MOVE	B,A	RRC	A	JUMP,CS REL$				; press =>	MOVE	#64,A	CALL	PUTMIDI	MOVE	TOTO,A	INC	A	MOVE	A,TOTO	JUMP	OUT$REL$:				; relch =>	MOVE	#0,A	CALL	PUTMIDI	MOVE	TOTO,A	DEC	A	MOVE	A,TOTOOUT$:	POP	AEXIT$:	RRC	B	INC	OFNOTE	RET;--------\\; PUTMIDI >;========/; Envoie un byte sur MIDI.; in	A	byte  envoyer; out	-; mod	FPUTMIDI:	PUSH	BBEGIN$:	MOVE	TRSTA,B	RLC	B	RLC	B	RLC	B	JUMP,CC BEGIN$		; transmit data ready ?	MOVE	A,TDATA	POP	B	RET;--------\\; LEDON   >;========/; Allume la p'tite lampe.; in	-; out	-; mod	FLEDON:	PUSH	A	MOVE	#2'00000010,A	MOVE	A,DATA3	POP	A	RET;--------\\; LEDOFF  >;========/; Eteint la p'tite lampe.; in	-; out	-; mod	FLEDOFF:	PUSH	A	MOVE	#2'00000000,A	MOVE	A,DATA3	POP	A	RET;--------\\; GETCAR  >;========/; Attend une touche du clavier.; in	-; out	A	touche presse; mod	F,AGETCAR:	PUSH	BPRESS$:	CALL	BALCLA		; A <-- touche presse	COMP	#0,A		; une touche presse ?	JUMP,EQ PRESS$		; non => PRESS$	MOVE	A,B		; B <-- touche presseDEPR$:	CALL	BALCLA		; A <-- touche presse	COMP	#0,A		; une touche presse ?	JUMP,NE DEPR$		; oui => DEPR$	MOVE	B,A		; A <-- touche presse (1..n)	DEC	A		; A <-- touche presse (0..n)	POP	B	RET;--------\\; BALCLA  >;========/; Balaie le clavier.; in	-; out	A	touche presse +1 (0 si rien); mod	F,ABALCLA:	PUSH	B	PUSH	IX	MOVE	#0,IX	MOVE	#2'11111110,BLOOP$:	MOVE	B,DATA1		; slectionne une colonne	MOVE	DATA4,A		; A <-- lit une ligne	INC	IX	RRC	A	JUMP,CC END$	INC	IX	RRC	A	JUMP,CC END$	INC	IX	RRC	A	JUMP,CC END$	INC	IX	RRC	A	JUMP,CC END$	INC	IX	RRC	A	JUMP,CC END$	INC	IX	RRC	A	JUMP,CC END$	INC	IX	RRC	A	JUMP,CC END$	INC	IX	RRC	A	JUMP,CC END$	SETC	RLC	B	COMP	#2'01111111,B	JUMP,NE LOOP$	MOVE	#0,IXEND$:	PUSH	IX	INC	SP	POP	A		; A <-- IX	POP	IX	POP	B	RET; Initialisation; --------------;--------\\; INIPER  >;========/; in	IX	^table; out	-; mod	F,A,B,IXINIPER:LOOP$:	MOVE	{IX}+0,B	; B <-- adresse	COMP	#-1,B	JUMP,EQ EXIT$	MOVE	{IX}+1,A	; A <-- data	PUSH	IX	MOVE	#REG,IX	ADD	B,IX		; IX <-- adresse	MOVE	A,{IX}		; (adresse) <-- data	POP	IX	INC	IX	INC	IX	JUMP	LOOP$EXIT$:	RET; Dans le deuxime byte: 0=input 1=outputTAINIT:	.8	DDIR1,2'11111111	; clavier out	.8	DDIR2,2'00010100	; srie	.8	DDIR3,2'00000010	; led + bouton	.8	DDIR4,2'00000000	; clavier in	.8	DATA1,2'11111111	; data clavier out	.8	DATA3,2'00000000	; led teinte	.8	RATE,2'00000100		; internal clock + xtal /16	.8	TRSTA,2'00000010	; transmit enable	.8	-1			; fin de la table; Vecteurs  la fin de la mmoire; -------------------------------	.LOC	ROM+LROM-16'10	.16	START		; SCI	.16	START		; TOF	.16	START		; OCF	.16	START		; ICF	.16	START		; IRQ	.16	START		; SWI	.16	START		; NMI	.16	START		; RESET	.START	START