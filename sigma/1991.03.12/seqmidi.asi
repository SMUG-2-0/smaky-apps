	.SBTTL	SEQMIDI;---------\\; MIDITIME >;=========/; Lit le temps propre  MIDI.; in	-; out	D4.W	temps (en ms);	D7.W	erreur; mod	D4.L, D7.WMIDITIME:	PUSHM.L	D1,D2,A4	LOAD.L	A4,#(A6)+OBUCOM	; A4 <-- ^buffer	LOAD.L	D4,#2		; D4 <-- lg demande	LOAD.W	D1,#TYPIO	; D1 <-- type	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DRSTATUS	LOAD.W	D4,(A4)		; D4 <-- temps	POPM.L	D1,D2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; COMMAND >;========/; Envoie une commande  MIDI.; in	A4.L	^commande; out	D7.W	erreur; mod	D7.WCOMMAND:	PUSHM.L	D1,D2	LOAD.W	D1,#TYPIO	; D1 <-- type	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DCOMMAND	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; STOPMIDI >;=========/; Stoppe compltement MIDI.; in	-; out	-; mod	D7.WSTOPMIDI:	PUSH.L	D2	LOAD.W	D2,(A6)+ONDMIDI	BIOS	?DAVOTR		; avort lecture/criture	NTREL	?WFABDESC	; attend la fin des processus fils	POP.L	D2	RET;--------\\; OPEMIDI >;========/; Ouvre le driver MIDI.; in	-; out	D7.W	erreur; mod	D7.WOPEMIDI:	PUSHM.L	D2,D3,A2..A4; Dinstalle l'usart en utilisant les noms #PR, #PP, #MI et #MO.	LOAD.L	A3,#R16"LUSART0	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL	LOAD.L	A3,#R16"LUSART1;	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL	LOAD.L	A3,#R16"LUSART2;	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL	LOAD.L	A3,#R16"LUSART3;	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL; Installe le driver MIDI  la place de l'usart.	CLR.B	(A6)+ONIMIDI	; driver MIDI install ici	LOAD.L	A3,#R16"LMIDI	; A3 <-- ^nom logique	LOAD.L	A4,#R16"PMIDI	; A4 <-- ^nom physique	LOAD.L	A2,#0		; A2 <-- ^paramtres;	CLR.W	D3		; D3 <-- pour tous	FOS	?INSTALL	; install le driver	JUMP,EQ 50$	COMP.W	D7,#ERUUSE	; dj install ?	JUMP,NE	90$		; non => 90$				; oui =>	SET.B	(A6)+ONIMIDI	; driver MIDI pas install ici50$:	LOAD.L	A3,#R16"DMIDI	FOS	?UNAMDRIV	; D2 <-- numro de driver	JUMP,NE	90$	LOAD.W	(A6)+ONDMIDI,D2	90$:	POPM.L	D2,D3,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOMIDI >;========/; Ferme le driver MIDI.; in	-; out	-; mod	D7.WCLOMIDI:	PUSHM.L	D3,A3	TEST.B	(A6)+ONIMIDI	; driver MIDI install ici ?	JUMP,T	90$		; non => 90$	LOAD.L	A3,#R16"LMIDI	; A3 <-- ^nom logique	CLR.W	D3		; D3 <-- pour tous	FOS	?DEINSTALL	; dinstall le driver90$:	POPM.L	D3,A3	RET; Textes; ------LUSART0:.ASCIZ	"#PR"LUSART1:.ASCIZ	"#PP"LUSART2:.ASCIZ	"#MI"LUSART3:.ASCIZ	"#MO"LMIDI:	.ASCIZ	"#MIDI:"PMIDI:	.ASCIZ	"$MIDI_0"DMIDI:	.ASCIZ	"MIDI_0"	.EVEN	.END