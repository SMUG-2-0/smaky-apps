	.SBTTL	PARTREP.ASM;---------\\; REPINIT  >;=========/; Dbut d'une recherche de la mesure suivante selon; les reprises.; in	-; out	-; mod	D7.WREPINIT:	PUSH.L	A4	CALL	REPBEGIN	; revient dans la premire mesure20$:	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	CLR.B	(A4)+OMENPA	; on n'a pas encore pass par l !	CLR.B	(A4)+OMENPX	; idem	CALL	NMESURE		; mesure suivante	JUMP,EQ 20$	CALL	REPBEGIN	; revient dans la premire mesure	POP.L	A4	RET;---------\\; REPNEXT  >;=========/; Cherche la mesure suivante selon les reprises.; in	-; out	D7.W	ok/erreur; mod	D7.WREPNEXT:	PUSHM.L	D2..D4,A4	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LOAD.B	D3,(A4)+OMENPA	; D3 <-- nb de passages	INC.B	(A4)+OMENPA	; un passage de plus, si si	LOAD.L	D4,(A4)+OMEREP	; D4 <-- signes de reprise	LOAD.B	D2,#1	TEST.L	D4:#BREP_1X	JUMP',BS 20$	INC.B	D2	TEST.L	D4:#BREP_2X	JUMP',BS 20$	INC.B	D2	TEST.L	D4:#BREP_3X	JUMP',BS 20$	INC.B	D2	TEST.L	D4:#BREP_4X	JUMP',BS 20$10$:	TEST.L	D4:#BREPBDP	JUMP,BS 30$	TEST.L	D4:#BREPDC	JUMP,BS 32$	TEST.L	D4:#BREPRENVOI2	JUMP,BS 34$	TEST.L	D4:#BREPCODA2	JUMP,BS 40$	TEST.L	D4:#BREPFIN	JUMP,BS 60$	TEST.L	D4:#BREPBD	JUMP,BS 60$	TEST.L	D4:#BREPPARTF	JUMP,BS 50$	JUMP	70$20$:				; 1x, 2x, 3x ou 4x =>	TEST.L	D4:#BREPGOTO	JUMP,BC 10$	INC.B	(A4)+OMENPX	; une fois de plus	COMP.B	D2,(A4)+OMENPX	; a-t-on dj assez "boucl" ?	JUMP,LO 10$		; oui => 10$				; non =>	AND.L	D4,#2^BREP_1X!2^BREP_2X!2^BREP_3X!2^BREP_4X	TSET.L	D4:#BREPLABEL	CALL	REPBEGIN	; revient dans la premire mesure	CALL	REPNSEARCH	; cherche le bon label ...	JUMP,NE 90$	JUMP	80$30$:				; :!| =>	TEST.B	D3		; a-t-on dj pass par l ?	JUMP,NE 70$		; oui => 70$	LOAD.L	D4,#2^BREPDBP	CALL	REPPSEARCH	; cherche |!: en arrire	CLR.W	D7	JUMP	80$32$:				; D.C. =>	CALL	REPBEGIN	CLR.W	D7	JUMP	80$34$:				; renvoi  la fin =>	TEST.B	D3		; a-t-on dj pass par l ?	JUMP,NE 70$		; oui => 70$	LOAD.L	D4,#2^BREPRENVOI1	CALL	REPPSEARCH	; cherche renvoi en arrire	CLR.W	D7	JUMP	80$40$:				; coda  la fin =>	TEST.L	D3:#0		; a-t-on dj pass par l ?	JUMP,BC 70$		; non => 70$	LOAD.L	D4,#2^BREPCODA1	CALL	REPNSEARCH	; cherche un coda au dbut ...	JUMP,NE 90$	JUMP	80$50$:				; fin d'une partie =>	CALL	NMESURE		; mesure suivante ...	JUMP,NE 90$	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure suivante	LOAD.L	D4,(A4)+OMEREP	TEST.L	D4:#BREPPART1	JUMP',BS 52$	TEST.L	D4:#BREPPART2	JUMP',BS 52$	TEST.L	D4:#BREPPART3	JUMP,BC 90$52$:	LOAD.L	D4,#2^BREPPARTF	CALL	REPNSEARCH	; cherche la fin de la partie ...	JUMP,NE 90$	JUMP	50$60$:				; FIN =>	LOAD.W	D7,#ERSEOB	; D7 <-- c'est fini	TEST.B	D3		; a-t-on dj pass par l ?	JUMP,NE	90$		; oui => 90$	TEST.L	D4:#BREPPART1	JUMP,BS 90$	TEST.L	D4:#BREPPART2	JUMP,BS 90$	TEST.L	D4:#BREPPART3	JUMP,BS 90$	TEST.L	D4:#BREPPARTM	JUMP,BS 90$	TEST.L	D4:#BREPPARTF	JUMP,BS 90$	JUMP	70$70$:	CALL	NMESURE		; btement la mesure suivante ...	JUMP,NE 90$80$:	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure suivante	LOAD.L	D4,(A4)+OMEREP	TEST.L	D4:#BREPPART1	JUMP',BS 82$	TEST.L	D4:#BREPPART2	JUMP',BS 82$	TEST.L	D4:#BREPPART3	JUMP',BC 90$82$:				; partie 1. 2. ou 3. =>	TEST.B	(A4)+OMENPA	; a-t-on dj pass par l ?	JUMP',EQ 90$		; non => 90$	LOAD.L	D4,#2^BREPPARTF	CALL	REPNSEARCH	; cherche la fin de la partie ...	JUMP',NE 90$	JUMP	70$90$:	TEST.W	D7	JUMP',NE 95$	LOAD.W	D7,#ERSEOB	COMP.B	(A4)+OMENPA,#10	; plus de 10 passages ici ?	JUMP',HS 95$		; oui => stop !!!	CLR.W	D795$:	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; REPBEGIN >;---------/; Revient au tout dbut.; in	-; out	-; mod	D7.WREPBEGIN:10$:	CALL	PMESURE		; revient dans la premire mesure	JUMP,EQ 10$	RET;-----------\\; REPNSEARCH >;-----------/; Cherche en avant.; in	D4.L	bits cherchs; out	D7.W	ok/erreur; mod	D7.WREPNSEARCH:	PUSHM.L	D3,A410$:	CLR.W	D7		; D7 <-- trouv	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LOAD.L	D3,D4	AND.L	D3,(A4)+OMEREP	COMP.L	D3,D4		; tous les bits prsents ?	JUMP',EQ 90$		; oui => 90$	CALL	NMESURE		; mesure suivante	JUMP,EQ 10$90$:	POPM.L	D3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; REPPSEARCH >;-----------/; Cherche en arrire.; in	D4.L	bits cherchs; out	D7.W	ok/erreur; mod	D7.WREPPSEARCH:	PUSHM.L	D3,A410$:	CLR.W	D7		; D7 <-- trouv	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LOAD.L	D3,D4	AND.L	D3,(A4)+OMEREP	COMP.L	D3,D4		; tous les bits prsents ?	JUMP',EQ 90$		; oui => 90$	CALL	PMESURE		; mesure prcdente	JUMP,EQ 10$90$:	POPM.L	D3,A4	TEST.W	D7		; retour EQ/NE	RET	.END