	.SBTTL	DXALGO; Constantes de DX7_ALGO.IMAGE; ----------------------------ALGOOX	=	32		; offset en XALGOOY	=	8		; offset en YALGOLX	=	64		; largeurALGOLY	=	72		; hauteurALGODX	=	ALGOLX+8	; distance en XALGODY	=	ALGOLY+8	; distance en Y	.IF	DX7ALGONX	=	8		; nb d'algorithmes en XALGONY	=	4		; nb d'algorithmes en Y	.ENDIF	.IF	DX100!FB01ALGONX	=	8		; nb d'algorithmes en XALGONY	=	1		; nb d'algorithmes en Y	.ENDIF;--------\\; ALEDIT  >;========/; in	A1.L	^description de l'algorithme;	A2.L	^timbre  diter; out	-; mod	D7.WALEDIT:	PUSHM.L	D1..D5,A3,A4	LOAD.B	D3,#EOP	LIB	?AFCAR	CLR.L	D2	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	CALL	ALAFIMA		; affiche tous les algorithmes	JUMP,NE ALFINI	LOAD.L	A3,#R16"TMENUALGO	LIB	?AFMENU	CALL	DSGETNUM	; D4 <-- algorithme (1..32)	LOAD.W	D2,D4	DEC.W	D2		; D2 <-- algorithme (0..31)	CALL	ALINVCASE	; allume l'algorithme slectionn	LOAD.W	(A6)+OALNUM,D2	LOAD.W	(A6)+OALUNDO,D2ALLOOP:	LIB	?GETCAR		; attend clavier/souris ...	COMP.W	D3,#KEYMGR	JUMP,EQ ALLOOP	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ ALLOOP		; oui => ALLOOP	COMP.W	D3,#KEYMDR	JUMP,EQ ALLOOP	COMP.W	D3,#END	JUMP,EQ ALFINI	COMP.W	D3,#F0	JUMP,EQ ALFINI	COMP.W	D3,#F0+SHIFT	JUMP,EQ ALFINI	COMP.W	D3,#UNDO	JUMP,EQ ALUNDO	COMP.W	D3,#KEYMGP	JUMP,EQ ALGAUCHE	COMP.W	D3,#KEYMMP	JUMP,EQ ALGAUCHE	COMP.W	D3,#KEYMDP	JUMP,EQ ALGAUCHE	LIB	?MINMAJ	.IF	DX7	COMP.B	D3,#'R	JUMP,EQ ALGOUP	COMP.B	D3,#'C	JUMP,EQ ALGODOWN	.ENDIF	COMP.B	D3,#'D	JUMP,EQ ALGOLEFT	COMP.B	D3,#'F	JUMP,EQ ALGORIGHTALBIP:				; touche incorrecte =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	ALLOOPALGORIGHT:	LOAD.W	D2,(A6)+OALNUM	LOAD.L	D1,D2	INC.W	D1	COMP.W	D1,#ALGONX*ALGONY	JUMP,HS ALBIP	JUMP	ALMOVEALGOLEFT:	LOAD.W	D2,(A6)+OALNUM	LOAD.L	D1,D2	DEC.W	D1	JUMP,NS ALBIP	JUMP	ALMOVE	.IF	DX7ALGODOWN:	LOAD.W	D2,(A6)+OALNUM	LOAD.L	D1,D2	ADD.W	D1,#ALGONX	COMP.W	D1,#ALGONX*ALGONY	JUMP,HS ALBIP	JUMP	ALMOVEALGOUP:	LOAD.W	D2,(A6)+OALNUM	LOAD.L	D1,D2	SUB.W	D1,#ALGONX	JUMP,NS ALBIP	JUMP	ALMOVE	.ENDIFALUNDO:	LOAD.W	D2,(A6)+OALNUM	LOAD.W	D1,(A6)+OALUNDO;	JUMP	ALMOVEALMOVE:	CALL	ALINVCASE	; efface l'ancienne case	LOAD.W	D2,D1	CALL	ALINVCASE	; allume la nouvelle case	LOAD.W	(A6)+OALNUM,D2	LOAD.W	D4,D2	INC.W	D4		; D4 <-- algorithme (1.32)	CALL	DSPUTNUM	; met  jour le nouvel algorithme	JUMP	ALLOOPALGAUCHE:			; [GAUCHE] =>	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE ALBIP	CALL	ALDETECTE	; D2 <-- algorithme o est la souris	JUMP,NE ALBIP	JUMP	30$20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP,NE 50$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	ALDETECTE	; D2 <-- algorithme o est la souris	JUMP,NE 20$30$:	COMP.W	D2,(A6)+OALNUM	; algorithme dj slectionn ?	JUMP,EQ 20$		; oui => 20$	PUSH.W	D2	LOAD.W	D2,(A6)+OALNUM	CALL	ALINVCASE	; efface la case	POP.W	D2	CALL	ALINVCASE	; allume la nouvelle case	LOAD.W	(A6)+OALNUM,D2	JUMP	20$50$:	LOAD.W	D4,(A6)+OALNUM	INC.W	D4		; D4 <-- algorithme (1.32)	CALL	DSPUTNUM	; met  jour le nouvel algorithme;	JUMP	ALFINIALFINI:	POPM.L	D1..D5,A3,A4	RET;----------\\; ALDETECTE >;==========/; Dtecte dans quelle algorithme est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	rang (0..31);	D7.W	erreur; mod	D2.L, D7.WALDETECTE:	PUSHM.L	D0,D1,D3,D4	CLR.W	D7	LOAD.W	D0,D4		; D0 <-- souris X	LOAD.L	D1,D4	SWAP.W	D1		; D1 <-- souris Y	CLR.W	D210$:	CALL	ALGETDIM	COMP.W	D0,D3		; trop  gauche ?	JUMP,LO 50$	ADD.W	D3,D4	COMP.W	D0,D3		; trop  droite ?	JUMP,HS 50$	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,D3		; trop haut ?	JUMP,LO 50$	ADD.W	D3,D4	COMP.W	D1,D3		; trop bas ?	JUMP,LO 90$50$:	INC.W	D2	COMP.W	D2,#ALGONX*ALGONY	JUMP,LO 10$	LOAD.W	D7,#190$:	POPM.L	D0,D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; ALINVCASE >;==========/; Inverse un algorithme.; in	D2.W	rang (0..31); out	-; mod	D7.WALINVCASE:	PUSHM.L	D2..D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	ALGETDIM	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	POPM.L	D2..D4	RET;---------\\; ALGETDIM >;---------/; Donne la position et les dimensions d'un algorithme.; in	D2.W	rang (0..31); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WALGETDIM:	PUSH.L	D2	AND.L	D2,#H'FFFF	DIV.WU	D2,#ALGONX	LOAD.W	D3,D2		; D3 <-- rang en Y (0..3)	SWAP.W	D2		; D2 <-- rang en X (0..7)	MUL.WU	D3,#ALGODY	ADD.W	D3,#ALGOOY	SWAP.W	D3	MUL.WU	D2,#ALGODX	ADD.W	D2,#ALGOOX	LOAD.W	D3,D2	LOAD.L	D4,#H'10000*ALGOLY+ALGOLX	POP.L	D2	RET;--------\\; ALAFONE >;========/; Affiche juste un algorithme.; in	D4.W	algorithme (1..32);	D5.L	position;	D6.L	dimensions; out	D7.W	erreur; mod	D7.WALAFONE:	PUSHM.L	D1..D6	LOAD.W	D7,(A6)+OALERR	; D7 <-- dernire erreur	JUMP,NE 90$	LOAD.W	D1,D4		; D1 <-- algorithme	CLR.L	D3	CLR.L	D4	LOAD.W	D2,#CLRDOT	TEST.B	(A6)+ODSAFI	JUMP,F	10$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LOAD.W	D2,#SETDOT10$:	LIB	?DRMDEF	LOAD.L	D3,D5	LOAD.L	D4,D6	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LIB	?DRMATRIX	; efface toute la surface	LOAD.W	D2,D1	DEC.W	D2		; D2 <-- algorithme (0..31)	CALL	ALGETDIM	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	D2,D5		; D2 <-- position dans l'cran	LOAD.W	D1,D6	SUB.W	D1,D4	SR.W	D1,#1	ADD.W	D2,D1	SWAP.W	D2	SWAP.W	D4	SWAP.W	D6	LOAD.W	D1,D6	SUB.W	D1,D4	SR.W	D1,#1	ADD.W	D2,D1	SWAP.W	D2	SWAP.W	D4	SWAP.W	D6	CALL	ALAFIMA		; affiche juste un algorithme90$:	POPM.L	D1..D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; ALAFIMA >;========/; Affiche une partie de l'image des algorithmes.; Il ne faut pas oublier d'effacer la surface rceptrice avant !; in	D2.L	position dans l'cran (y;x);	D3.L	position dans l'image (y;x);	D4.L	dimensions (dy;dx); out	D7.W	erreur; mod	D7.WALAFIMA:	PUSHM.L	D1,D3,D4,D6,A2..A4	LOAD.W	D7,(A6)+OALERR	; D7 <-- dernire erreur	JUMP,NE 90$	TEST.L	(A6)+OALPIM	; image dj lue ?	JUMP,NE 50$		; oui => 50$				; non =>	PUSHM.L	D3,D4	LOAD.W	D4,(A0)+ODFDX	SR.W	D4,#3	MUL.WU	D4,(A0)+ODFDY	ADD.L	D4,#LGHIMA+IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un grand buffer pour l'image	JUMP,NE 40$	LOAD.L	A3,#R16"NIALGO	LOAD.W	D3,#2^BOPRD!2^BOPSYS	FOS	?OPEN		; ouvre l'image	JUMP,NE 40$	LOAD.L	A2,A4		; A2 <-- ^en-tte de l'image	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 30$	LOAD.W	D7,#ERDIOUT	LOAD.W	D4,(A2)+OIMDLX	; D4 <-- largeur de l'image	COMP.W	D4,(A0)+ODFDX	JUMP,NE 30$	LOAD.W	D4,(A2)+OIMDLY	; D4 <-- hauteur de l'image	COMP.W	D4,(A0)+ODFDY	JUMP,NE 30$	TEST.B	(A2)+OIMCOD	; image code ?	JUMP,NE 20$		; oui => 20$				; non =>	LOAD.L	A4,#(A2)+LGHIMA+IMLBUF	LOAD.L	D4,(A2)+OIMNBB	FOS	?RDBYTE		; lit toute l'image dcode	JUMP	30$20$:				; image code =>	LOAD.L	A4,#(A2)+LGHIMA	LOAD.L	D4,(A2)+OIMNBB	FOS	?RDBYTE		; lit toute l'image code	JUMP,NE	30$	LOAD.L	A3,#(A2)+LGHIMA+IMLBUF	GRA_	DECOIMA		; dcode l'image ...30$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D740$:	POPM.L	D3,D4	LOAD.W	(A6)+OALERR,D7	TEST.W	D7		; lecture de l'image ok ?	JUMP,NE 90$		; non => 90$	LOAD.L	A4,#(A2)+LGHIMA+IMLBUF	LOAD.L	(A6)+OALPIM,A450$:	LOAD.L	A3,#(A6)+OBDIS	SWAP.W	D2	LOAD.L	(A3)+12,D2	SWAP.W	D3	LOAD.L	(A3)+2,D3	SWAP.W	D4	LOAD.L	(A3)+22,D4	LOAD.W	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+6,(A6)+OALPIM	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#3	LOAD.W	(A3)+10,D3	CLR.L	(A3)+16	CLR.W	(A3)+20	LOAD.B	(A3)+26,#INVDOT	LOAD.W	D3,#1+26	LIB	?STRING		; affiche l'image	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET; Tables; ------TMENUALGO:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.IF	DX7NIALGO:	.ASCIZ	"DX7_algo.image"	.ENDIF	.IF	DX100NIALGO:	.ASCIZ	"DX100_alg.image"	.ENDIF	.IF	FB01NIALGO:	.ASCIZ	"FB01_alg.image"	.ENDIF	.EVEN	.END