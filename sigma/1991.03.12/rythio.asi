	.SBTTL	RYTHIODOSAUVE:			; mmoire --> disque	CALL	RYTHSTOP	; stoppe l'coute	CALL	RYTHMAJC	; mj case actuellement en dition	LOAD.L	A3,#(A6)+OBUFILE10$:	CALL	NORMMOUSE	; remet la flche	CALL	DBOXEDITO	; dite le nom ...	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ LOOP	LOAD.W	D1,D3		; D1 <-- F1/F4	LOAD.L	D0,D4		; D0 <-- fanions	CALL	WAITMOUSE	; met le sablier20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	FOS	?CREATE		; cre le fichier	JUMP,EQ	30$		; ok => 30$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	ERROR		; non => ERROR				; oui =>	CALL	NORMMOUSE	; remet la flche	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	CALL	AFMENU		; refait les soft-keys	TEST.W	D7	JUMP,NE ERROR	COMP.W	D3,#'O	JUMP,NE 10$	FOS	?DELETE		; dtruit le fichier	JUMP,NE ERROR	JUMP	20$30$:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP,NE 95$	TEST.L	D0:#1	JUMP,BS 60$				; toutes les mesures =>	LOAD.L	A4,A6		; A4 <-- variables	CALL	_RYTH_WRITE	; crit toutes les mesures	JUMP,NE 90$	JUMP	80$60$:				; seulement la mesure courante =>	CALL	PUTHEAD		; prpare l'en-tte	LOAD.L	D4,(A6)+OPDT	SUB.L	D4,A5	LOAD.L	(A6)+OBUHEAD+OHLG,D4	LOAD.W	(A6)+OBUHEAD+OHNMES,#1	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D4,#LHEAD	FOS	?WRBYTE		; crit l'en-tte	JUMP,NE 90$	LOAD.L	A4,A5	LOAD.L	D4,(A6)+OPDT	SUB.L	D4,A4	FOS	?WRBYTE		; crit juste la mesure courante	JUMP,NE 90$80$:	FOS	?CLOSE		; ferme le fichier	JUMP,NE 95$	JUMP	LOOP90$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D795$:	JUMP	ERRORDOPREND:			; disque --> mmoire	CALL	RYTHSTOP	; stoppe l'coute	CALL	RYTHMAJC	; mj case actuellement en dition	LOAD.L	A3,#(A6)+OBUFILE	CLR.B	(A3)10$:	CALL	DBOXEDITI	; dite le nom ...	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ LOOP	LOAD.W	D2,D3		; D2 <-- PREND/AJOUTE	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier	JUMP,EQ 30$				; erreur =>	PUSH.W	D7	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	10$30$:	COMP.W	D2,#F4	JUMP,EQ 60$				; PREND =>	LOAD.L	A4,A6		; A4 <-- variables	CALL	_RYTH_READ	; lit toutes les mesures	LOAD.L	A5,(A6)+OPDT	LOAD.L	D4,(A5)-4	SUB.L	A5,D4		; A5 <-- ^mesure courante	TEST.W	D7	JUMP,NE 90$	FOS	?CLOSE	JUMP,NE 95$	CALL	DESMESURE	; montre la premire mesure	SET.B	(A6)+OMAJ	; rythme  jour	JUMP	LOOP60$:				; AJOUTE =>	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D4,#LHEAD	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 90$	LOAD.L	A4,(A6)+OPDT	LOAD.L	D4,(A6)+OPFT	SUB.L	D4,A4	FOS	?RDBYTE		; lit les rythmes dans le trou	COMP.W	D7,#EROUTF	JUMP,EQ 65$	TEST.W	D7	JUMP,NE 90$	LOAD.W	D7,#ERNEMEM	JUMP	90$65$:	FOS	?CLOSE	JUMP,NE 95$	ADD.L	A4,D4	LOAD.L	(A6)+OPDT,A4	LOAD.L	A5,A4	LOAD.L	D4,(A5)-4	SUB.L	A5,D4		; A5 <-- ^mesure courante	LOAD.W	D4,(A6)+OBUHEAD+OHNMES ; D4 <-- nb de mesures ajoutes	ADD.W	(A6)+ONMES,D4	ADD.W	(A6)+OCMES,D470$:	DEC.W	D4	JUMP,EQ 75$	CALL	RECULE		; revient dans la premire mesure ajoute	JUMP,EQ 70$75$:	CALL	DESMESURE	; montre la premire mesure ajoute	CLR.B	(A6)+OMAJ	; rythme pas  jour	JUMP	LOOP90$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D795$:	JUMP	ERROR;------------\\; _RYTH_WRITE >;============/; Ecrit toutes les mesures sur un canal donn.; Le fichier n'est ni ouvert ni ferm !; in	A4.L	^variables;	D6.W	canal FOS; out	D7.W	erreur; mod	D7.W_RYTH_WRITE:	PUSHM.L	D4,A4,A6	LOAD.L	A6,A4		; A6 <-- ^variables	CALL	PUTHEAD		; prpare l'en-tte	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D4,#LHEAD	FOS	?WRBYTE		; crit l'en-tte	JUMP,NE 90$	LOAD.L	A4,(A6)+OPDB	LOAD.L	D4,(A6)+OPDT	SUB.L	D4,A4	JUMP,EQ 40$	FOS	?WRBYTE		; crit avant le trou	JUMP,NE 90$40$:	LOAD.L	A4,(A6)+OPFT	LOAD.L	D4,(A6)+OPFB	SUB.L	D4,A4	JUMP,EQ 90$	FOS	?WRBYTE		; crit aprs le trou90$:	POPM.L	D4,A4,A6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; _RYTH_READ >;===========/; Lit toutes les mesures sur un canal donn.; Le fichier n'est ni ouvert ni ferm !; in	A4.L	^variables;	D6.W	canal; out	D7.W	erreur; mod	D7.W_RYTH_READ:	PUSHM.L	D3,D4,A4..A6	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D4,#LHEAD	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 90$	LOAD.L	A4,(A6)+OPDB	LOAD.L	D3,(A6)+OPFB	SUB.L	D3,A4		; D3 <-- lg max possible	LOAD.L	D4,(A6)+OBUHEAD+OHLG ; D4 <-- longueur  lire	JUMP,EQ 30$	LOAD.W	D7,#ERNEMEM	COMP.L	D4,D3		; y a-t-il assez de place ?	JUMP,HS 90$		; non => 90$				; lit si longueur connue =>	FOS	?RDBYTE		; lit les rythmes	JUMP,NE 90$	JUMP	40$30$:				; lit si longueur inconnue =>	LOAD.L	D4,D3	FOS	?RDBYTE		; lit les rythmes	COMP.W	D7,#EROUTF	JUMP,EQ 40$	TEST.W	D7	JUMP,NE 85$	LOAD.W	D7,#ERNEMEM	JUMP	85$40$:	ADD.L	A4,D4	LOAD.L	(A6)+OPDT,A4	LOAD.L	(A6)+OPFT,(A6)+OPFB	LOAD.L	A5,A4	LOAD.L	D4,(A5)-4	SUB.L	A5,D4		; A5 <-- ^mesure courante	LOAD.W	(A6)+OCMES,#999	CLR.W	(A6)+ONMES50$:	INC.W	(A6)+ONMES	CALL	RECULE		; revient dans la premire mesure	JUMP,EQ 50$	CLR.W	(A6)+OCMES	CALL	GETHEAD		; mj variables selon en-tte	CLR.W	D7		; D7 <-- ok	JUMP	90$85$:	PUSH.W	D7	CALL	INIMESURE	; met juste une premire mesure vide	POP.W	D790$:	POPM.L	D3,D4,A4..A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; PUTHEAD >;========/; Prpare l'en-tte pour pouvoir l'crire.; in	-; out	-; mod	D7.WPUTHEAD:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OBUHEAD+LHEAD	LOAD.W	D4,#LHEAD-110$:	CLR.B	(-A4)	DECJ.W,NMO D4,10$	LOAD.B	(A4)+OHREV,#MAJREV	LOAD.B	(A4)+OHVERS,#MINREV	LOAD.L	D4,(A6)+OPDT	SUB.L	D4,(A6)+OPDB	ADD.L	D4,(A6)+OPFB	SUB.L	D4,(A6)+OPFT		; D4 <-- lg totale	LOAD.L	(A4)+OHLG,D4	LOAD.W	(A4)+OHNMES,(A6)+ONMES	LOAD.W	(A4)+OHTRACK,#RYTRACK	LOAD.W	(A4)+OHUNITE,(A6)+OUNITE	LOAD.W	D4,#MAXVIT	SUB.W	D4,(A6)+OASVIT+OSCPOSV ; D4 <-- vitesse (-MAXVIT..+MAXVIT)	LOAD.W	(A4)+OHVIT,D4	POPM.L	D4,A4	RET;--------\\; GETHEAD >;========/; Met  jour les variables en fonction de l'en-tte lue.; in	-; out	-; mod	D7.WGETHEAD:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OBUHEAD;;?	LOAD.W	(A6)+ONMES,(A4)+OHNMES	LOAD.W	D4,(A4)+OHUNITE	JUMP,NE 40$	LOAD.W	D4,#6440$:	LOAD.W	(A6)+OUNITE,D4	LOAD.W	D4,#MAXVIT	SUB.W	D4,(A4)+OHVIT	LOAD.W	(A6)+OASVIT+OSCPOSV,D4	POPM.L	D4,A4	RET	.END