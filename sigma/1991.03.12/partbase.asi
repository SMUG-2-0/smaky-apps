	.SBTTL	PARTBASE; Dplacements dans les mesures; -----------------------------;---------\\; GOMESURE >;=========/; Va directement dans n'importe quelle mesure.; in	D4.W	mesure o aller (0..n); out	D7.W	erreur; mod	D7.WGOMESURE:	PUSH.L	D4	CLR.W	D7		; D7 <-- ok	SUB.W	D4,(A6)+OMESC	JUMP',EQ 90$		; on y est dj => 90$	JUMP',HS 40$20$:	CALL	PMESURE		; recule	JUMP',NE 90$	INC.W	D4	JUMP,NE 20$	JUMP	90$40$:	CALL	NMESURE		; avance	JUMP',NE 90$	DEC.W	D4	JUMP,NE 40$90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; NIMESURE >;=========/; Presque comme NMESURE, mais si on arrive  la fin, ; on cre une nouvelle mesure vide identique  la prcdente.; Si l'actuelle dernire mesure est vide, on ne cre pas; une nouvelle mesure, de faon  ce qu'il n'y ai jamais plus; d'une mesure vide tout  la fin !; in	-; out	(A6)+OPMES.L	^objet mesure;	D7.W		EREOB	=> dernire mesure dj vide;			ERPDP; mod	D7.WNIMESURE:	PUSHM.L	D4,A3,A4	CALL	NMESURE		; avance  la mesure suivante	JUMP',EQ 90$		; ok => 90$				; n'existe pas =>	CALL	RECULE	LOAD.B	D4,(A4)		; D4 <-- dernier objet	CALL	AVANCE	LOAD.W	D7,#ERSEOB	; D7 <-- on est vraiment  la fin	COMP.B	D4,#OBJMES	; dernire mesure vide ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	A3,(A6)+OPDT	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure actuelle	LOAD.W	D4,#LME	CALL	INSERT		; insre une mesure identique  la prcdente	JUMP',NE 90$	ADD.W	A3,#2	LOAD.L	(A6)+OPMES,A3;;?	CLR.L	D4;;?	LOAD.W	D4,(A0)+ODFFDX;;?	SUB.W	D4,#MXPORTEE*2	; D4 <-- largeur maximale;;?	DIV.WU	D4,#LXPORTEE;;?	MUL.WU	D4,#LXPORTEE	; D4 <-- aligne la largeur sur la grille;;?	LOAD.W	(A3)+OMELG,D4	; remet la largeur maximale	CLR.L	(A3)+OMEREP	; supprime les signes de reprise	INC.W	(A6)+OMESC	; mj le numro de mesure courante90$:	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; NMESURE >;========/; Avance  la fin de la mesure suivante.; in	-; out	(A6)+OPMES.L	^objet mesure;	D7.W		EREOB; mod	D7.WNMESURE:	PUSHM.L	A3,A4	CALL	PUTTEXTE	; texte en dition --> mesure courante	CALL	GOMEND		; va  la fin de la mesure	LOAD.L	A3,(A6)+OPDT	CALL	AVANCE		; saute le dbut de mesure suivante	JUMP',NE 90$	ADD.W	A3,#2	LOAD.L	(A6)+OPMES,A3	CALL	GOMEND		; va  la fin de la mesure suivante	INC.W	(A6)+OMESC	; mj le numro de mesure courante	CLR.W	D7		; D7 <-- ok90$:	POPM.L	A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMESURE >;========/; Recule  la fin de la mesure prcdente.; in	-; out	(A6)+OPMES.L	^objet mesure;	D7.W		ERBOB; mod	D7.WPMESURE:	PUSHM.L	A3,A4	CALL	PUTTEXTE	; texte en dition --> mesure courante	CALL	GOMBEGIN	; va au dbut de la mesure	CALL	RECULE		; saute le dbut de la mesure	LOAD.L	A4,(A6)+OPDT	COMP.L	A4,(A6)+OPDB	; est-on tout au dbut ?	JUMP',NE 40$		; non => 40$				; oui =>	CALL	AVANCE		; re-saute le dbut de la mesure	CALL	GOMEND		; va  la fin o on tait avant	LOAD.W	D7,#ERSBOB	JUMP'	90$40$:	CALL	GOMBEGIN	; va au dbut de la mesure prcdente	CALL	RECULE		; recule le dbut	LOAD.L	A3,(A6)+OPDT	CALL	AVANCE		; avance le dbut	CALL	GOMEND		; va  la fin de la mesure prcdente	ADD.W	A3,#2	LOAD.L	(A6)+OPMES,A3	DEC.W	(A6)+OMESC	; mj le numro de mesure courante	CLR.W	D7		; D7 <-- ok90$:	POPM.L	A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; INIPMES >;========/; Rinitialise OPMES en fonction de la mesure courante.; in	-; out	-; mod	D7.WINIPMES:	PUSHM.L	D4,A4	LOAD.L	A4,(A6)+OPFT	ADD.L	A4,#210$:	CALL	PVISU		; recule	JUMP',NE 20$	COMP.B	(A4)+OOBJC,#OBJMES ; dbut de la mesure ?	JUMP,NE 10$		; non => 10$20$:	LOAD.L	(A6)+OPMES,A4	POPM.L	D4,A4	RET;--------\\; GOMEND  >;========/; Avance  la fin de la mesure, entre le dernier objet et; le dbut de la mesure suivante.; in	-; out	-; mod	D7.WGOMEND:	PUSH.L	A410$:	CALL	AVANCE		; A4 <-- ^objet suivant	JUMP',NE 90$	COMP.B	(A4)+OOBJC,#OBJMES ; dbut mesure suivante ?	JUMP,NE 10$		; non => 10$	CALL	RECULE		; oui => recule juste avant90$:	POP.L	A4	RET;---------\\; GOMBEGIN >;=========/; Avance au dbut de la mesure, entre le dbut de la mesure et; le premier objet.; in	-; out	-; mod	D7.WGOMBEGIN:	PUSH.L	A410$:	CALL	RECULE		; A4 <-- ^objet prcdent	JUMP',NE 90$	COMP.B	(A4)+OOBJC,#OBJMES ; dbut de cette mesure ?	JUMP,NE 10$		; non => 10$	CALL	AVANCE		; oui => avance juste aprs90$:	POP.L	A4	RET; Gestion du buffer des symboles; ------------------------------;	<<l1>>objet1<<l1>><<l2>>objet2<<l2>> ..trou.. <<l3>>objet3<<l3>>;	^                                   ^         ^                 ^;	DB                                  DT        FT                FB;--------\\; GOVISU  >;========/; Donne le pointeur directement dans n'importe quelle mesure; (sans y aller).; in	D4.W	mesure (0..n); out	A4.L	^mesure;	D7.W	erreur; mod	D7.W, A4.LGOVISU:	PUSH.L	D4	LOAD.L	A4,(A6)+OPDB	ADD.L	A4,#2		; A4 <-- ^tout premier objet20$:	CLR.W	D7		; D7 <-- ok	TEST.W	D4		; est-on dans la bonne mesure ?	JUMP',EQ 90$		; oui => 90$30$:	CALL	NVISU		; avance	JUMP',NE 90$	COMP.B	(A4)+OOBJC,#OBJMES ; dbut mesure suivante ?	JUMP,NE 30$		; non => 30$				; oui =>	DEC.W	D4		; D4 <-- une mesure de plus avance	JUMP	20$90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GNVISU  >;========/; Avance sur l'objet suivant, en sautant d'un coup les groupes.; in	A4.L	^objet/groupe; out	A4.L	^objet/groupe suivant;	D7.W	EREOB; mod	D7.W, A4.LGNVISU:	PUSH.L	D4	TEST.B	(A4)+OOBJF:#BGROUPE	JUMP',BC 80$	LOAD.L	D4,(A4)+OSYNOB	; D4 <-- no groupe20$:	CALL	NVISU		; A4 <-- ^objet suivant	JUMP',NE 90$	TEST.B	(A4)+OOBJF:#BGROUPE	JUMP',BC 90$	COMP.L	D4,(A4)+OSYNOB	; mme groupe ?	JUMP',EQ 20$		; oui => 20$	JUMP'	90$80$:	CALL	NVISU		; A4 <-- ^objet suivant90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; NVISU   >;========/; Avance sur l'objet suivant.; in	A4.L	^objet; out	A4.L	^objet suivant;	D7.W	EREOB; mod	D7.W, A4.LNVISU:	PUSHM.L	D4,A3	LOAD.L	A3,#(A4)-2	LOAD.W	D4,(A3)		; D4 <-- longueur de l'objet	ADD.W	A3,D4	ADD.W	A3,#4	COMP.L	A3,(A6)+OPDT	; est-on au dbut du trou ?	JUMP',NE 50$		; non => 50$	LOAD.L	A3,(A6)+OPFT	; oui => saute le trou50$:	LOAD.W	D7,#ERSEOB	COMP.L	A3,(A6)+OPFB	; est-on tout  la fin ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	A4,#(A3)+2	; A4 <-- ^objet suivant	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PVISU   >;========/; Recule sur l'objet prcdent.; in	A4.L	^objet; out	A4.L	^objet prcdent;	D7.W	ERBOB; mod	D7.W, A4.LPVISU:	PUSHM.L	D4,A3	LOAD.L	A3,#(A4)-2	COMP.L	A3,(A6)+OPFT	; est-on  la fin du trou ?	JUMP',NE 50$		; non => 50$	LOAD.L	A3,(A6)+OPDT	; oui => saute le trou50$:	LOAD.W	D7,#ERSBOB	COMP.L	A3,(A6)+OPDB	; est-on tout au dbut ?	JUMP',EQ 90$		; oui => 90$	LOAD.W	D4,(A3)-2	; D4 <-- longueur de l'objet	SUB.W	A3,D4	SUB.W	A3,#4	LOAD.L	A4,#(A3)+2	; A4 <-- ^objet prcdent	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; AVANCE  >;========/; Avance d'un objet.; in	-; out	A4.L	^objet avanc;	D7.W	EREOB; mod	D7.W, A4.LAVANCE:	PUSHM.L	D4,A2,A3	LOAD.W	D7,#ERSEOB	LOAD.L	A2,(A6)+OPFT	COMP.L	A2,(A6)+OPFB	; est-on dj  la fin ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	A3,(A6)+OPDT	LOAD.L	A4,#(A3)+2	; A4 <-- ^objet qui sera avanc	LOAD.W	D4,(A2)	SR.W	D4,#1		; D4 <-- /2 car transfert par .W	ADD.W	D4,#2-1		; D4 <-- -1  cause du test NMO !20$:	LOAD.W	(A3+),(A2+)	DECJ.W,NMO D4,20$	LOAD.L	(A6)+OPFT,A2	LOAD.L	(A6)+OPDT,A3	CLR.W	D7		; D7 <-- on a avanc90$:	POPM.L	D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; RECULE  >;========/; Recule d'un objet.; in	-; out	A4.L	^objet recul;	D7.W	ERBOB; mod	D7.W, A4.LRECULE:	PUSHM.L	D4,A2,A3	LOAD.W	D7,#ERSBOB	LOAD.L	A2,(A6)+OPDT	COMP.L	A2,(A6)+OPDB	; est-on dj au dbut ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	A3,(A6)+OPFT	LOAD.W	D4,(A2)-2	SR.W	D4,#1		; D4 <-- /2 car transfert par .W	ADD.W	D4,#2-1		; D4 <-- -1  cause du test NMO !20$:	LOAD.W	(-A3),(-A2)	DECJ.W,NMO D4,20$	LOAD.L	A4,#(A3)+2	; A4 <-- ^objet recul	LOAD.L	(A6)+OPDT,A2	LOAD.L	(A6)+OPFT,A3	CLR.W	D7		; D7 <-- on a recul90$:	POPM.L	D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; DAVANCE >;========/; Dtruit un objet en avant.; in	-; out	A4.L	^objet dtruit en avant;	D7.W	EREOB; mod	D7.W, A4.LDAVANCE:	PUSHM.L	D4,A2	LOAD.W	D7,#ERSEOB	LOAD.L	A2,(A6)+OPFT	COMP.L	A2,(A6)+OPFB	; est-on dj  la fin ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	A4,#(A2)+2	; A4 <-- ^objet qui sera dtruit	LOAD.W	D4,(A2)	ADD.W	D4,#4	ADD.W	A2,D4	LOAD.L	(A6)+OPFT,A2	DEC.W	(A6)+ONBOBJ	; un objet de moins	CLR.W	D7		; D7 <-- on a dtruit90$:	POPM.L	D4,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; DRECULE >;========/; Dtruit un objet en arrire.; in	-; out	A4.L	^objet dtruit en arrire;	D7.W	ERBOB; mod	D7.W, A4.LDRECULE:	PUSHM.L	D4,A2	LOAD.W	D7,#ERSBOB	LOAD.L	A2,(A6)+OPDT	COMP.L	A2,(A6)+OPDB	; est-on dj au dbut ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.W	D4,(A2)-2	ADD.W	D4,#4	SUB.W	A2,D4	LOAD.L	(A6)+OPDT,A2	LOAD.L	A4,#(A2)+2	; A4 <-- ^objet qui a t dtruit	DEC.W	(A6)+ONBOBJ	; un objet de moins	CLR.W	D7		; D7 <-- on a dtruit90$:	POPM.L	D4,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; INSERT  >;========/; Insre un objet d'une longueur quelconque.; in	A4.L	^objet  insrer;	D4.W	longueur de l'objet; out	D7.W	ERPDP; mod	D7.WINSERT:	PUSHM.L	D3,D4,A2,A3	LOAD.L	D3,(A6)+OPFT	SUB.L	D3,(A6)+OPDT	; D3 <-- longueur du trou	SUB.L	D3,#4		; D3 <-- place pour 2x <<lg>>	LOAD.W	D7,#ERSPDP	; D7 <-- plus de place	AND.L	D4,#H'FFFF	COMP.L	D4,D3		; reste assez de place ?	JUMP',GE 90$		; non => 90$				; oui =>	LOAD.L	A2,(A6)+OPDT	LOAD.W	(A2+),D4	; buffer <-- <<lg>>	LOAD.W	D3,D4	SR.W	D3,#1		; D3 <-- /2 car transfert par .W	DEC.W	D3		; D3 <-- -1  cause du test NMO	LOAD.L	A3,A420$:	LOAD.W	(A2+),(A3+)	; buffer <-- objet	DECJ.W,NMO D3,20$	LOAD.W	(A2+),D4	; buffer <-- <<lg>>	LOAD.L	(A6)+OPDT,A2	COMP.B	(A4)+OOBJC,#OBJMES	JUMP,NE 80$	INC.W	(A6)+OMESM	; une mesure de plus80$:	INC.W	(A6)+ONBOBJ	; un objet de plus	CLR.W	D7		; D7 <-- insertion ok90$:	POPM.L	D3,D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET	.END