	.SBTTL	PARTMAIN; Noms des modules; ----------------	.LOC	0	JUMP	STARTNMDBOX:	.ASCIZ	"DBOX"NMDGENC:.ASCIZ	"DGENC"NMLIST:	.ASCIZ	"LIST"NMSCROLL:.ASCIZ	"SCROLL"NMPRINTA:.ASCIZ	"PRINTA"	.EVENTTEDIT:	.B	0,UNDO	.B	2^7	.EVENTDSBTTL:.ASCIZ	"Logiciel SIGMA sur SMAKY"	.EVEN; Programme; ---------; Les registres suivants sont permanants, c'est--dire qu'ils; gardent leurs contenus tout au long du programme :;----------------------------------------------------------------;	D0.W	"soft-keys" allumes;	D1.W	niveau (icne verticale allume);;	A0.L	^description relle de la fentre;	A6.L	^variables;----------------------------------------------------------------START:	LIB	?OPELIB	LOAD.W	D3,#3	LIB	?MOUSE	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.B	D3,#NOCURS	LIB	?AFCAR		; pas de curseur	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT	LOAD.L	A6,A4		; A6 <-- ^variables05$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.W	D4	JUMP,NE 05$	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	LOAD.B	(A6)+OGCLIST,#-1	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMDGENC	LOAD.W	D3,#DGENC_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHDGENC,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMPRINTA	LOAD.W	D3,#PRINTA_FIRST	LIB_	OPEN	JUMP',NE 30$	LOAD.W	(A6)+OCHPRINTA,D1	CLR.L	D3	PRINTA_	OPEN	JUMP,NE ERFAT	LOAD.L	(A6)+OCAPRINT,A230$:	CALL	_OPEMIDI	JUMP,NE ERFAT	CALL	_SMAKYTRACK	; si pas de synth => met pistes sur le Smaky; Demande les adresses des routines graphiques rapides.	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADQDOT,A3	LIB	?GCHMOU	JUMP,NE ERFAT	LOAD.W	(A6)+OCHMOU,D6	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	(A3+),#LOADGC	LOAD.B	(A3+),#GCICF	LOAD.B	(A3+),#GCICS	LOAD.B	(A3+),#GCICT	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCICF	LOAD.B	(A3+),#GCICS	LOAD.B	(A3+),#GCICT	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBDIS	SUB.L	D3,A3	LIB	?STRING		; charge le gencar ISP32	JUMP,NE ERFAT	LOAD.L	(A6)+OPGCIC,(A0)+ODFPGC	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	(A3+),#LOADGC	LOAD.B	(A3+),#GCICF	LOAD.B	(A3+),#GCICS	LOAD.B	(A3+),#GCICT2	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCICF	LOAD.B	(A3+),#GCICS	LOAD.B	(A3+),#GCICT2	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBDIS	SUB.L	D3,A3	LIB	?STRING		; charge le gencar ISP33	JUMP,NE ERFAT	LOAD.L	(A6)+OPGCIC2,(A0)+ODFPGC	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCTXF	LOAD.B	(A3+),#GCTXS	LOAD.B	(A3+),#GCTXT	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBDIS	SUB.L	D3,A3	LIB	?STRING		; utilise le gencar du texte	JUMP,NE ERFAT	CALL	DEFGENCAR	; charge qq gencar	CALL	STATUSPRINT	; lit le status de l'imprimante;	JUMP,NE ERFAT		; ne teste volontairement pas l'erreur !	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ligne de commande	LOAD.W	D3,#5		; D3 <-- demande les 5/16mes	LOAD.L	D4,#1000	; D4 <-- minimum	LOAD.L	D5,#100000	; D5 <-- maximum	LOAD.W	D1,#MTYPCP	LIB	?GTRSMM		; demande mmoire pour partition	JUMP,NE ERFAT	LOAD.L	(A6)+OPDB,A4	TCLR.L	D4:#0		; D4 <-- doit tre pair !	ADD.L	A4,D4	LOAD.L	(A6)+OPFB,A4	CALL	CADRE		; dessine le cadreEFFACE:	LOAD.L	(A6)+OPDT,(A6)+OPDB	LOAD.L	(A6)+OPFT,(A6)+OPFB	CLR.W	(A6)+ONBOBJ	CLR.W	(A6)+OMESM	CLR.W	(A6)+OMESC	LOAD.W	(A6)+OLXPORT,#LXPORTEE	LOAD.L	D4,(A6)+OFAPLAY	AND.L	D4,#2^BFASYNT	OR.L	D4,#2^BFA1ME!2^BFA2VPP	TSET.L	D4:#BFAPLAY+0	; coute toutes les voix	TSET.L	D4:#BFAPLAY+1	TSET.L	D4:#BFAPLAY+2	TSET.L	D4:#BFAPLAY+3	TSET.L	D4:#BFAPLAY+4	TSET.L	D4:#BFAPLAY+5	LOAD.L	(A6)+OFAPLAY,D4	LOAD.W	(A6)+OASVIT+OSCHTV,#2*MAXVIT	LOAD.W	(A6)+OASVIT+OSCPOSV,#MAXVIT	LOAD.W	(A6)+OPLPME,#1-1   ; de ...	LOAD.W	(A6)+OPLDME,#999-1 ;   ...	LOAD.L	(A6)+OFAPRI,#2^BFAITOUT	LOAD.W	(A6)+OIMFM,#1	; de ...	LOAD.W	(A6)+OIMLM,#999	;   ...	LOAD.W	(A6)+OIMZM,#1	; zoom	LOAD.L	A3,#R16"TDSBTTL	LOAD.L	A4,#(A6)+OIMEM20$:	LOAD.B	(A4+),(A3+)	; diteur	JUMP,NE 20$	CLR.B	(A6)+OIMTM	; titre	CLR.B	(A6)+OIMAM	; auteur	CLR.W	(A6)+OSTPMG	; marge gauche	CLR.W	(A6)+OSTPMD	; marge droite	CLR.W	(A6)+OSTPMS	; marge suprieure	CLR.W	(A6)+OSTPMI	; marge infrieure	CLR.L	(A6)+OTEXTE+OTXPN1	LOAD.B	(A6)+OME+OOBJC,#OBJMES	LOAD.B	(A6)+OME+OMETA,#ICOBEMOL;	LOAD.B	(A6)+OME+OMENA,#0	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,#MXPORTEE*2	; D4 <-- largeur maximale	DIV.WU	D4,#LXPORTEE	MUL.WU	D4,#LXPORTEE	; D4 <-- aligne la largeur sur la grille	LOAD.W	(A6)+OME+OMELG,D4	LOAD.W	(A6)+OME+OMEMIN,#LYPORTEE*1	LOAD.W	(A6)+OME+OMEMAX,#LYPORTEE*33	LOAD.W	(A6)+OME+OMELP+(LLP*0)+OLPDY,#LYPORTEE*5	LOAD.W	(A6)+OME+OMELP+(LLP*0)+OLPMIN,#LYPORTEE*1	LOAD.W	(A6)+OME+OMELP+(LLP*0)+OLPMAX,#LYPORTEE*12	LOAD.B	(A6)+OME+OMELP+(LLP*0)+OLPTYP,#ICOPSOL	LOAD.W	(A6)+OME+OMELP+(LLP*1)+OLPDY,#LYPORTEE*15	LOAD.W	(A6)+OME+OMELP+(LLP*1)+OLPMIN,#LYPORTEE*12	LOAD.W	(A6)+OME+OMELP+(LLP*1)+OLPMAX,#LYPORTEE*22	LOAD.B	(A6)+OME+OMELP+(LLP*1)+OLPTYP,#ICOPSOL	LOAD.W	(A6)+OME+OMELP+(LLP*2)+OLPDY,#LYPORTEE*25	LOAD.W	(A6)+OME+OMELP+(LLP*2)+OLPMIN,#LYPORTEE*22	LOAD.W	(A6)+OME+OMELP+(LLP*2)+OLPMAX,#LYPORTEE*33	LOAD.B	(A6)+OME+OMELP+(LLP*2)+OLPTYP,#ICOPFA	LOAD.L	A4,(A6)+OPDT	ADD.W	A4,#2	LOAD.L	(A6)+OPMES,A4	LOAD.L	A4,#(A6)+OME	LOAD.W	D4,#LME	CALL	_INSERT	JUMP	BASEFINI:	CALL	DBOXQUITTE	; Etes-vous sr ?	JUMP,NE ERFAT	COMP.W	D3,#F1	JUMP,NE MAINERFAT:	CALL	_STOPMIDI	CALL	_CLOMIDI	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	(A3+),#KILLGC	LOAD.B	(A3+),#GCICF	LOAD.B	(A3+),#GCICS	LOAD.B	(A3+),#GCICT	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBDIS	SUB.L	D3,A3	LIB	?STRING	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	(A3+),#KILLGC	LOAD.B	(A3+),#GCICF	LOAD.B	(A3+),#GCICS	LOAD.B	(A3+),#GCICT2	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBDIS	SUB.L	D3,A3	LIB	?STRING	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDGENC	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	TEST.L	(A6)+OCAPRINT	JUMP',EQ 50$	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	CLOSE	LOAD.W	D1,(A6)+OCHPRINTA	LIB_	CLOSE50$:	CLR.W	D5	LIB	?USEWDO		; utilise la swdo principale	LIB	?CLOLIB	FOS	?STOP; Programme principal; -------------------BASE:	LOAD.W	(A6)+ONNOTE,#2^SKNDEF	LOAD.W	(A6)+ONSIL,#2^SKNDEF	LOAD.W	(A6)+ONFRAP,#(ICOSFRAPPE+2)!2^7	LOAD.W	(A6)+ONGRA,#2^SKGDEF!2^SKGPAS	LOAD.W	(A6)+ONEP,#ICOEP1	LOAD.W	(A6)+ONCLEF,#2^SKCDEF!2^SKCCLEF	LOAD.W	(A6)+ONDIV1,#2^SKDDEF1	LOAD.W	(A6)+ONDIV2,#2^SKDDEF2	LOAD.B	(A6)+OFRAPPE+0,#7	LOAD.B	(A6)+OFRAPPE+1,#37	LOAD.B	(A6)+OFRAPPE+2,#67	LOAD.B	(A6)+OFRAPPE+3,#97	LOAD.B	(A6)+OFRAPPE+4,#127	LOAD.W	D1,#NHAUTNOTE	; D1 <-- notes en haut	LOAD.L	A5,#(A6)+ONNOTE	LOAD.L	(A6)+OPN,A5	LOAD.W	D0,(A5)	CALL	AFMENU		; mj les soft-keys	CALL	REFAIT		; dessine la mesure; Prend le fichier donn dans la ligne de commande.	TEST.L	(A6)+OPLCOM	JUMP,EQ LOOP	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ligne de commande	LOAD.B	D3,#'M	LIB	?IFSWITCH	; SIGMA/M ?	JUMP',NE 60$		; non => 60$	LOAD.L	D4,(A6)+OFAPLAY	; oui =>	TSET.L	D4:#BFASYNT	; met le synthtiseur "MIDI" !	LOAD.L	(A6)+OFAPLAY,D4	CALL	_SYNTHETRACK	; si synth => met pistes sur le canal 1	CALL	_STARTSTOPREAD	; start/stop processus de lecture MIDI60$:	CLR.L	(A6)+OPLCOM	LIB	?SKPNAM	JUMP,NE LOOP	LOAD.L	A4,#(A6)+OBUFILE70$:	LOAD.B	D3,(A3+)	JUMP',EQ 75$	COMP.B	D3,#CR	JUMP',EQ 75$	COMP.B	D3,#SPACE	JUMP',EQ 75$	COMP.B	D3,#TAB	JUMP',EQ 75$	COMP.B	D3,#'/	JUMP',EQ 75$	LOAD.B	(A4+),D3	; OBUFIN <-- nom du fichier	JUMP	70$75$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUFILE	LOAD.W	D5,#F1		; D5 <-- (PREND), et non (AJOUTE)	JUMP	DOPRENDFMAIN:	CALL	AFMENU		; mj les soft-keysLOOP:	CALL	_NORMMOUSE	; souris: enlve le sablier	CALL	MAJMOUSE	; mj trois boutons souris10$:	LOAD.L	D3,(A6)+OTEXTE+OTXPN1	JUMP',NE 17$	COMP.W	D1,#NHAUTNOTE	JUMP',EQ 11$	COMP.W	D1,#NBASNOTE	JUMP',NE 12$11$:	LOAD.L	D4,(A6)+OFAPLAY	TEST.L	D4:#BFASYNT	; synthtiseur "MIDI" ?	JUMP',BS 14$		; oui => 14$12$:				; non =>	LIB	?GETCAR		; attend clavier/souris ...	JUMP	20$14$:	TEST.B	(A6)+OPFREAD	; processus fils existe ?	JUMP',T 15$		; oui => 15$	CALL	_STARTSTOPREAD	; non => start processus de lecture MIDI15$:	LOAD.W	D4,#4	NTREL	?SETTIM	LIB	?GETCAR		; attend clavier/souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,EQ 20$	CALL	_MIDIPRESS	; A4 <-- ^touches presses	JUMP,NE 14$	CALL	PRESSNOTE	; ajoute une note dans une porte	JUMP	14$17$:	SWAP.W	D3	SUB.W	D3,(A6)+OTEXTE+OTXBLI	SWAP.W	D3	LIB	?SETCURS	LOAD.L	D4,(A0)+ODFGCF	; D4 <-- "fst-" initial	LOAD.L	A3,#(A6)+OTEXTE+OTXFST ; A3 <-- ^<usegc><f><s><t>	LOAD.W	D3,#4	LIB	?STRING		; utilise le bon gencar	LOAD.L	A3,#(A6)+OTEXTE+OTXCAR	LOAD.L	A4,A3	ADD.W	A4,(A6)+OTEXTE+OTXCUR	LOAD.L	A2,#R16"TTEDIT	LOAD.W	D3,#MAXTX	LIB	?EDIT		; attend ligne/souris ...	SUB.L	A4,A3	LOAD.W	(A6)+OTEXTE+OTXCUR,A4	PUSH.L	D3	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	D4,#USEGC	RR.L	D4,#8		; D4 <-- "<usegc>fst"	LOAD.L	(A3)+0,D4	LOAD.B	(A3)+4,#NOCURS	LOAD.W	D3,#4+1	LIB	?STRING		; remet gencar et enlve le curseur	POP.L	D320$:	LOAD.W	(A6)+OKEY,D3	; OKEY <-- touche "brute"	COMP.W	D3,#KEYMGR	JUMP,EQ 10$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ 10$		; oui => ignore	COMP.W	D3,#KEYMDR	JUMP,EQ 10$	COMP.W	D3,#CR	JUMP,EQ 70$	COMP.W	D3,#ENTER	JUMP,EQ 70$	COMP.W	D3,#SCR	JUMP,EQ	75$	COMP.W	D3,#H'100*(2^BCOPY)+DEFINE	JUMP,EQ DOSAUVE	COMP.W	D3,#H'100*(2^BSHOW)+DEFINE	JUMP,EQ DOPREND	COMP.W	D3,#DEFINE	JUMP,EQ DOECHO	COMP.W	D3,#H'100*(2^BPROGRA)+'E	JUMP,EQ DOECHO	COMP.W	D3,#H'100*(2^BPROGRA)+'e	JUMP,EQ DOECHO	LOAD.W	D5,D3		; D5 <-- touche/bouton press	LOAD.L	A3,(A6)+OPICOH	; A3 <-- ^icnes horizontaux	LOAD.L	A4,(A6)+OPICOV	; A4 <-- ^icnes verticaux	DBOX_	ICODET		; dans "soft-key" ?	JUMP,EQ SOFTKEY		; oui => SOFTKEY	COMP.W	D7,#ERDIOUT	JUMP,NE ERROR	CALL	_SCROLLMOVE	; dplace l'ascenseur ...	JUMP,NE CLIC		; si on tait ailleur => gre autre CLIC	COMP.W	D4,#SCROLLFUP	; flche  gauche ?	JUMP',EQ 50$	COMP.W	D4,#SCROLLFDOWN	; flche  droite ?	JUMP',EQ 60$				; dplacement =>	LOAD.W	D4,(A5)+OSCPOSV	; D4 <-- mesure  atteindre	SUB.W	D4,(A6)+OMESC	JUMP,EQ LOOP	JUMP',HI 40$30$:				; recule =>	CALL	_PMESURE	INC.W	D4	JUMP,NE	30$	CALL	REFAIT		; refait le dessin de la mesure	JUMP	LOOP40$:				; avance =>	CALL	_NMESURE	DEC.W	D4	JUMP,NE	40$	CALL	REFAIT		; refait le dessin de la mesure	JUMP	LOOP50$:				; -1 mesure =>	LOAD.W	D5,D4	CALL	_SCROLLPRESS	; presse la flche52$:	CALL	_PMESURE	; recule	JUMP',NE 54$	CALL	REFAIT		; et montre	LIB	?IFMOUSE	; D3 <-- bouton(s) press(s)	TEST.B	D3		; encore un bouton press ?	JUMP,NE 52$		; oui => 52$54$:	LOAD.W	D4,D5	CALL	_SCROLLPRESS	; relche la flche	JUMP	LOOP60$:				; +1 mesure =>	LOAD.W	D5,D4	CALL	_SCROLLPRESS	; presse la flche62$:	CALL	_NIMESURE	; avance	JUMP',NE 64$	CALL	REFAIT		; et montre	LIB	?IFMOUSE	; D3 <-- bouton(s) press(s)	TEST.B	D3		; encore un bouton press ?	JUMP,NE 62$		; oui => 62$64$:	LOAD.W	D4,D5	CALL	_SCROLLPRESS	; relche la flche	JUMP	LOOP70$:				; (RETURN) =>	CALL	_NIMESURE	; avance dans la mesure suivante	JUMP,NE ERROR	CALL	REFAIT		; refait le dessin de la mesure	JUMP	LOOP75$:				; (SHIFT-RETURN) =>	CALL	_PMESURE	; recule dans la mesure prcdente	JUMP,NE ERROR	CALL	REFAIT		; refait le dessin de la mesure	JUMP	LOOPERROR:	CALL	_NORMMOUSE	; souris: enlve le sablier	CALL	_SCMO		; remet la flche de la souris	CALL	AFINFO		; mj les infos tout en haut	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; fait un p'tit bruit	JUMP	LOOPSOFTKEY:	COMP.W	D2,#-1	JUMP,EQ ERROR	TEST.W	D2	JUMP,EQ FINI	COMP.W	D2,#NBICONE+0	; dans les "soft-keys" verticales ?	JUMP',EQ 30$	COMP.W	D2,#NBICONE+1	JUMP',EQ 31$	COMP.W	D2,#NBICONE+2	JUMP',EQ 32$	COMP.W	D2,#NBICONE+3	JUMP',EQ 33$	COMP.W	D2,#NBICONE+4	JUMP',EQ 34$	COMP.W	D2,#NBICONE+5	JUMP',EQ 35$	COMP.W	D1,#NHAUTNOTE	JUMP,EQ SHAUTNOTE	COMP.W	D1,#NBASNOTE	JUMP,EQ SBASNOTE	COMP.W	D1,#NHAUTSILENCE	JUMP,EQ SHAUTSILENCE	COMP.W	D1,#NBASSILENCE	JUMP,EQ SBASSILENCE	COMP.W	D1,#NGRAPHIQUE	JUMP,EQ SGRAPHIQUE	COMP.W	D1,#NCLEF	JUMP,EQ SCLEF	COMP.W	D1,#NFLOPPY	JUMP,EQ SFLOPPY	COMP.W	D1,#NDIVERS1	JUMP,EQ SDIVERS1	COMP.W	D1,#NDIVERS2	JUMP,EQ SDIVERS2	JUMP	ERROR30$:	LOAD.W	D1,#NHAUTNOTE	; D1 <-- notes en haut	JUMP	MAIN31$:	LOAD.W	D1,#NHAUTSILENCE ; D1 <-- silences en haut	JUMP	MAIN32$:	LOAD.W	D1,#NDIVERS1	; D1 <-- divers	JUMP	MAIN33$:	LOAD.W	D1,#NGRAPHIQUE	; D1 <-- mode graphique	JUMP	MAIN34$:	LOAD.W	D1,#NCLEF	; D1 <-- clef	JUMP	MAIN35$:	LOAD.W	D1,#NFLOPPY	; D1 <-- floppy	JUMP	MAINSHAUTNOTE:SBASNOTE:SHAUTSILENCE:SBASSILENCE:	COMP.W	D2,#SKNFIRST	JUMP,LO ERROR	COMP.W	D2,#SKNLAST	; note ?	JUMP',LS NOTE$	COMP.W	D2,#SKNPOINT	; point ?	JUMP,EQ POINTE$	COMP.W	D2,#SKNNOQ	; avec/sans queue ?	JUMP,EQ QUEUE$	COMP.W	D2,#SKNHAUTBAS	; haut <--> bas ?	JUMP,EQ HAUTBAS$	COMP.W	D2,#SKNALTER	; altrations ?	JUMP,EQ ALTER$	COMP.W	D2,#SKNACCENT	; accents ?	JUMP,EQ ACCENT$	COMP.W	D2,#SKNFRAPPE	; frappe ?	JUMP,EQ FRAPPE$	COMP.W	D2,#SKNBARRE	; barre ?	JUMP,EQ BARRE$	JUMP	ERRORNOTE$:				; note =>	TEST.L	D0:D2		; note dj allume ?	JUMP,BS ERROR		; oui => ERROR	PUSH.W	D2	LOAD.W	D2,#SKNFIRSTNOTE1$:	CALL	CLRSOFTKEY	; teint toutes les notes	INC.W	D2	COMP.W	D2,#SKNLAST	JUMP,LS NOTE1$	POP.W	D2	CALL	INVSOFTKEY	; allume la nouvelle note	JUMP	LOOPPOINTE$:			; point/triolet/etc. =>	LOAD.L	A3,#R16"MMPOINTE	LOAD.L	A4,#R16"MTPOINTE	LOAD.W	D3,(A6)+ONPOINT	CALL	_MTMMENU	; attend dans mmenu selon souris...	JUMP,NE ERROR	LOAD.W	(A6)+ONPOINT,D3	CALL	MAJSOFTKEY	; mj "soft-keys"	CALL	CLRSOFTKEY	LOAD.W	D4,(A6)+ONNOTE	TCLR.L	D4:D2	LOAD.W	(A6)+ONNOTE,D4	LOAD.W	D4,(A6)+ONSIL	TCLR.L	D4:D2	LOAD.W	(A6)+ONSIL,D4	TEST.W	D3	JUMP,EQ LOOP	CALL	SETSOFTKEY	LOAD.W	D4,(A6)+ONNOTE	TSET.L	D4:D2	LOAD.W	(A6)+ONNOTE,D4	LOAD.W	D4,(A6)+ONSIL	TSET.L	D4:D2	LOAD.W	(A6)+ONSIL,D4	JUMP	LOOPQUEUE$:				; avec/sans queue =>	CALL	INVSOFTKEY	; inverse l'icne	JUMP	LOOPHAUTBAS$:			; haut <--> bas	LOAD.W	D2,D1	LOAD.W	D1,#NBASNOTE	COMP.W	D2,#NHAUTNOTE	JUMP,EQ MAIN	LOAD.W	D1,#NHAUTNOTE	COMP.W	D2,#NBASNOTE	JUMP,EQ MAIN	LOAD.W	D1,#NBASSILENCE	COMP.W	D2,#NHAUTSILENCE	JUMP,EQ MAIN	LOAD.W	D1,#NHAUTSILENCE;	COMP.W	D2,#NBASSILENCE	JUMP	MAINALTER$:				; altrations =>	COMP.W	D1,#NHAUTSILENCE; silence ?	JUMP,EQ ERROR		; oui => erreur	COMP.W	D1,#NBASSILENCE	JUMP,EQ ERROR	LOAD.L	A3,#R16"MMALTER	LOAD.L	A4,#R16"MTALTER	LOAD.W	D3,(A6)+ONALT	CALL	_MTMMENU	; attend dans mmenu selon souris...	JUMP,NE ERROR	LOAD.W	(A6)+ONALT,D3	CALL	MAJSOFTKEY	; mj "soft-keys"	CALL	CLRSOFTKEY	TEST.W	D3	JUMP,EQ LOOP	CALL	SETSOFTKEY	JUMP	LOOPACCENT$:			; accents =>	COMP.W	D1,#NHAUTSILENCE; silence ?	JUMP,EQ ERROR		; oui => erreur	COMP.W	D1,#NBASSILENCE	JUMP,EQ ERROR	LOAD.L	A3,#R16"MMACCENT	LOAD.L	A4,#R16"MTACCENT	LOAD.W	D3,(A6)+ONACC	CALL	_MTMMENU	; attend dans mmenu selon souris...	JUMP,NE ERROR	LOAD.W	(A6)+ONACC,D3	CALL	MAJSOFTKEY	; mj "soft-keys"	CALL	CLRSOFTKEY	TEST.W	D3	JUMP,EQ LOOP	CALL	SETSOFTKEY	JUMP	LOOPFRAPPE$:			; force de frappe =>	COMP.W	D1,#NHAUTSILENCE; silence ?	JUMP,EQ ERROR		; oui => erreur	COMP.W	D1,#NBASSILENCE	JUMP,EQ ERROR	COMP.W	(A6)+OKEY,#F0	JUMP',LO FRAPPECLIC$	COMP.W	(A6)+OKEY,#F15	JUMP,LS FRAPPEDOWN$	COMP.W	(A6)+OKEY,#F0+SHIFT	JUMP',LO FRAPPECLIC$	COMP.W	(A6)+OKEY,#F15+SHIFT	JUMP,LS FRAPPEUP$FRAPPECLIC$:	LIB	?IFMOUSE	JUMP',NE FRAPPEUP$	LOAD.L	D5,D4		; D5 <-- position de la souris	CALL	POSSOFTKEY	; D3/D4 <-- pos/dim de l'icne	JUMP',NE FRAPPEUP$	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SR.W	D4,#1	ADD.W	D3,D4	COMP.W	D5,D3		; souris dans la moiti suprieure ?	JUMP',LO FRAPPEUP$	; oui => "up"FRAPPEDOWN$:			; diminue la force de frappe =>	LOAD.W	D3,(A6)+ONFRAP	; D3 <-- force de frappe actuelle	COMP.W	D3,#ICOSFRAPPE!2^7	JUMP,EQ ERROR	DEC.W	D3	JUMP'	FRAPPEMAJ$FRAPPEUP$:			; augmente la force de frappe =>	LOAD.W	D3,(A6)+ONFRAP	; D3 <-- force de frappe actuelle	COMP.W	D3,#(ICOSFRAPPE+MAXSFRAPPE-1)!2^7	JUMP,EQ ERROR	INC.W	D3FRAPPEMAJ$:	LOAD.W	(A6)+ONFRAP,D3	CALL	MAJSOFTKEY	; mj "soft-keys"	JUMP	LOOPBARRE$:				; barres croches =>	JUMP	BARRESSGRAPHIQUE:	COMP.W	D2,#SKGGENCAR	JUMP',EQ 20$	COMP.W	D2,#SKGEPAISSEUR	JUMP',EQ 30$	COMP.W	D2,#SKGPAS	JUMP,EQ 40$	COMP.W	D2,#SKGGENCAR	JUMP,EQ ERROR	LOAD.L	A4,#R16"TICOGRAPHIQUE	TEST.B	(A4)+(D2.W)+4	; icne existe ?	JUMP,EQ ERROR		; non => ERROR				; choix d'un objet graphique =>	PUSH.W	D2	LOAD.W	D2,#SKGDROITE	CALL	CLRSOFTKEY	LOAD.W	D2,#SKGHCOURBE	CALL	CLRSOFTKEY	LOAD.W	D2,#SKGBCOURBE	CALL	CLRSOFTKEY	LOAD.W	D2,#SKGRECTANGLE	CALL	CLRSOFTKEY	LOAD.W	D2,#SKGCERCLE	CALL	CLRSOFTKEY	LOAD.W	D2,#SKGTEXTE	CALL	CLRSOFTKEY	POP.W	D2	CALL	SETSOFTKEY	; allume la nouvelle	JUMP	LOOP20$:				; choix d'un gencar =>	CALL	DBOXGENCAR	JUMP	MAIN30$:				; choix d'une paisseur =>	LOAD.L	A3,#R16"MMEPAISSEUR	LOAD.L	A4,#R16"MTEPAISSEUR	LOAD.W	D3,(A6)+ONEP	CALL	_MTMMENU	; attend dans mmenu selon souris...	JUMP,NE ERROR	TEST.B	D3	JUMP,EQ LOOP	LOAD.W	(A6)+ONEP,D3	CALL	MAJSOFTKEY	; mj "soft-keys"	JUMP	LOOP40$:	CALL	INVSOFTKEY	; inverse le pas	JUMP	LOOPSCLEF:	COMP.W	D2,#SKCMOINS	JUMP,EQ 10$	COMP.W	D2,#SKCALTER	JUMP,EQ 30$	COMP.W	D2,#SKCPLUS	JUMP,EQ 20$	COMP.W	D2,#SKCREPRISE	JUMP,EQ 70$	COMP.W	D2,#SKCGRILLE	JUMP,EQ 80$	COMP.W	D2,#SKCGMOINS	JUMP,EQ 85$	COMP.W	D2,#SKCTRONQUE	JUMP,EQ 90$	COMP.W	D2,#SKCMONTE	JUMP,EQ 50$	COMP.W	D2,#SKCDESCEND	JUMP,EQ 55$	COMP.W	D2,#SKCLIE	JUMP,EQ 60$	COMP.W	D2,#SKCCLEF+0	JUMP,LO ERROR	COMP.W	D2,#SKCCLEF+3	JUMP,LO 40$	JUMP	ERROR10$:				; moins =>	LOAD.W	D2,#CLRDOT	CALL	ALTERATIONS	; enlve les altrations  la clef	CALL	DESPORTEES	; refait les portes	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	TEST.B	(A4)+OMENA	JUMP',EQ 12$	DEC.B	(A4)+OMENA12$:	LOAD.W	D2,#SETDOT	CALL	ALTERATIONS	; remet les altrations  la clef	JUMP	LOOP20$:				; plus =>	LOAD.W	D2,#CLRDOT	CALL	ALTERATIONS	; enlve les altrations  la clef	CALL	DESPORTEES	; refait les portes	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	COMP.B	(A4)+OMENA,#7	JUMP',EQ 22$	INC.B	(A4)+OMENA22$:	LOAD.W	D2,#SETDOT	CALL	ALTERATIONS	; remet les altrations  la clef	JUMP	LOOP30$:				; altration =>	LOAD.W	D2,#CLRDOT	CALL	ALTERATIONS	; enlve les altrations  la clef	CALL	DESPORTEES	; refait les portes	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	LOAD.B	D3,(A4)+OMETA	LOAD.B	(A4)+OMETA,#ICODIESE	COMP.B	D3,#ICOBEMOL	JUMP',EQ 32$	LOAD.B	(A4)+OMETA,#ICOBEMOL32$:	CALL	MAJSOFTKEY	; affiche #/b dans les "soft-keys"	LOAD.W	D2,#SETDOT	CALL	ALTERATIONS	; remet les altrations  la clef	JUMP	LOOP40$:				; clef =>	TEST.L	D0:D2		; clef dj allume ?	JUMP',BS 44$		; oui => 44$				; non =>	PUSH.W	D2	LOAD.W	D2,#SKCCLEF+0	CALL	CLRSOFTKEY	LOAD.W	D2,#SKCCLEF+1	CALL	CLRSOFTKEY	LOAD.W	D2,#SKCCLEF+2	CALL	CLRSOFTKEY	POP.W	D2	CALL	SETSOFTKEY	; allume la nouvelle clef	LOAD.W	D2,#SKCLIE	CALL	GTPPORTEE	; A4 <-- ^mesure, A3 <-- ^porte	JUMP',NE 42$	TEST.B	(A3)+OLPLIE	JUMP',F 42$	CALL	SETSOFTKEY	JUMP'	43$42$:	CALL	CLRSOFTKEY43$:	CALL	MAJSOFTKEY	; mj "soft-keys"	JUMP	LOOP44$:	CALL	GTPPORTEE	; A4 <-- ^mesure, A3 <-- ^porte	JUMP,NE ERROR	COMP.B	(A3)+OLPTYP,#ICOVIDE	JUMP',EQ 48$	COMP.B	(A3)+OLPTYP,#ICOPSOL	JUMP',EQ 46$				; supprime une porte en clef de fa =>	LOAD.B	(A3)+OLPTYP,#ICOVIDE	CALL	FRONTIERES	CALL	MAJSOFTKEY	; mj "soft-keys"	CALL	REFAIT	JUMP	LOOP46$:				; transforme clef de sol en clef de fa =>	LOAD.W	D2,#CLRDOT	CALL	ONEPORTEE	CALL	ALTPORTEE	LOAD.B	(A3)+OLPTYP,#ICOPFA	LOAD.W	D2,#SETDOT	CALL	ONEPORTEE	CALL	ALTPORTEE	CALL	MAJSOFTKEY	; mj "soft-keys"	JUMP	LOOP48$:				; ajoute porte en clef de sol =>	LOAD.B	(A3)+OLPTYP,#ICOPSOL	CALL	FRONTIERES	CALL	MAJSOFTKEY	; mj "soft-keys"	CALL	REFAIT	JUMP	LOOP50$:				; monte =>	CALL	GTPPORTEE	; A4 <-- ^mesure, A3 <-- ^porte	JUMP,NE ERROR	COMP.B	(A3)+OLPTYP,#ICOVIDE	JUMP,EQ ERROR	LOAD.W	D3,(A3)+OLPMIN	ADD.W	D3,#LYPORTEE	; D3 <-- position la plus haute possible	COMP.W	D3,(A3)+OLPDY	; est-on assez haut ?	JUMP,EQ ERROR		; oui => ERROR	LOAD.W	D2,#CLRDOT	CALL	ONEPORTEE	SUB.W	(A3)+OLPDY,#LYPORTEE	CALL	FRONTIERES	CALL	REFAIT	JUMP	LOOP55$:				; descend =>	CALL	GTPPORTEE	; A4 <-- ^mesure, A3 <-- ^porte	JUMP,NE ERROR	COMP.B	(A3)+OLPTYP,#ICOVIDE	JUMP,EQ ERROR	LOAD.W	D3,(A3)+OLPMAX	SUB.W	D3,#(NPORTEE+1)*LYPORTEE ; D3 <-- position la plus basse possible	COMP.W	D3,(A3)+OLPDY	; est-on assez bas ?	JUMP,EQ ERROR		; oui => ERROR	LOAD.W	D2,#CLRDOT	CALL	ONEPORTEE	ADD.W	(A3)+OLPDY,#LYPORTEE	CALL	FRONTIERES	CALL	REFAIT	JUMP	LOOP60$:				; lie =>	TEST.L	D0:#16		; D0 <-- "soft-key" lie existe ?	JUMP,BC ERROR		; non => ERROR	CALL	GTPPORTEE	; A4 <-- ^mesure, A3 <-- ^porte	JUMP,NE ERROR	LOAD.W	D2,#CLRDOT	CALL	ONEPORTEE	LOAD.W	D2,#SKCLIE	TEST.B	(A3)+OLPLIE	JUMP',F 62$	CLR.B	(A3)+OLPLIE	CALL	CLRSOFTKEY	; teint la liaison	JUMP'	64$62$:	SET.B	(A3)+OLPLIE	CALL	SETSOFTKEY	; allume la liaison64$:	LOAD.W	D2,#SETDOT	CALL	ONEPORTEE	JUMP	LOOP70$:				; reprise =>	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	LOAD.L	D4,(A4)+OMEREP	; D4 <-- signes de reprise	CALL	DBOXREPRISE	; choix du signe de reprise	COMP.W	D3,#F1		; d'accord ?	JUMP,NE	MAIN	LOAD.L	(A4)+OMEREP,D4	CALL	AFMENU		; mj les "soft-keys"	CALL	REFAIT		; redessine la mesure	JUMP	LOOP80$:				; grille =>	CALL	INVSOFTKEY	; inverse	LOAD.L	A5,(A6)+OPN	LOAD.W	(A5),D0		; mmorise les "soft-keys" allumes	TEST.L	D0:#SKCGRILLE	JUMP',BC 82$	CALL	DESPORTEES	; refait juste les portes	JUMP	LOOP82$:	CALL	REFAIT		; refait tout	JUMP	LOOP85$:				; + serr =>	LOAD.W	D4,(A6)+OLXPORT	DEC.W	D4	COMP.W	D4,#LXPORTEE-4	JUMP',HI 86$	LOAD.W	D4,#LXPORTEE86$:	LOAD.W	(A6)+OLXPORT,D4	CALL	REFAIT		; refait tout	JUMP	LOOP90$:				; tronque =>	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	CALL	LMAXPORTEE	; D4 <-- largeur maximale	COMP.W	D4,(A4)+OMELG	; largeur change ?	JUMP,EQ LOOP		; non => LOOP	LOAD.W	(A4)+OMELG,D4	; oui =>	CALL	REFAIT		; dessine la mesure	JUMP	LOOP;----------\\; GTPPORTEE >;----------/; Donne le pointeur  la porte concerne selon les icnes en bas.; in	D0.W	"soft-keys" allumes; out	A4.L	^mesure courante;	A3.L	^porte concerne;	D7.W	erreur; mod	D7.W, A3.L, A4.LGTPPORTEE:	CLR.W	D7	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LOAD.L	A3,#(A4)+OMELP	; A3 <-- ^table des portes	TEST.L	D0:#SKCCLEF+0	JUMP',BS 90$	LOAD.L	A3,#(A3)+LLP	TEST.L	D0:#SKCCLEF+1	JUMP',BS 90$	LOAD.L	A3,#(A3)+LLP	TEST.L	D0:#SKCCLEF+2	JUMP',BS 90$	LOAD.W	D7,#ERSNOT	; D7 <-- bizzard, bizzard90$:	TEST.W	D7		; retour EQ/NE	RETSFLOPPY:	COMP.W	D2,#SKFPREND	JUMP,EQ DOPREND	COMP.W	D2,#SKFAJOUTE	JUMP,EQ DOAJOUTE	COMP.W	D2,#SKFSAUVE	JUMP,EQ DOSAUVE	COMP.W	D2,#SKFPLAY	JUMP,EQ DOPLAY	COMP.W	D2,#SKFCOPY	JUMP,EQ DOCOPY	COMP.W	D2,#SKFTRANS	JUMP,EQ DOTRANS	COMP.W	D2,#SKFTONAL	JUMP,EQ DOTONAL	COMP.W	D2,#SKFPRINT	JUMP,EQ DOPRINT	COMP.W	D2,#SKFEFFACE	JUMP,EQ DOEFFACE	JUMP	ERRORSDIVERS1:	COMP.W	D2,#SKDCHIFFRE	JUMP,EQ 50$	COMP.W	D2,#SKDACCENT	JUMP',EQ 60$	COMP.W	D2,#SKDNEXT	JUMP',EQ 20$	LOAD.L	A4,#R16"TICODIVERS1	TEST.B	(A4)+(D2.W)+4	; icne existe ?	JUMP,EQ ERROR		; non => ERROR	CALL	CLRALLSOFTKEY	; teint toutes les "soft-keys"	CALL	SETSOFTKEY	; puis allume la nouvelle	JUMP	LOOP20$:	LOAD.W	D1,#NDIVERS2	; D1 <-- divers deux	JUMP	MAIN50$:				; chiffre =>	LOAD.L	A3,#R16"MMCHIFFRE	LOAD.L	A4,#R16"MTCHIFFRE	LOAD.W	D3,(A6)+ONCHI	CALL	_MTMMENU	; attend dans mmenu selon souris...	JUMP,NE ERROR	TEST.W	D3		; est-on dans la case vide ?	JUMP,EQ LOOP		; oui => LOOP	LOAD.W	(A6)+ONCHI,D3	CALL	CLRALLSOFTKEY	; teint toutes les "soft-keys"	CALL	MAJSOFTKEY	; mj "soft-keys"	CALL	SETSOFTKEY	; puis allume la nouvelle	JUMP	LOOP60$:				; accent seul =>	LOAD.L	A3,#R16"MMACCENTSEUL	LOAD.L	A4,#R16"MTACCENTSEUL	LOAD.W	D3,(A6)+ONREP	CALL	_MTMMENU	; attend dans mmenu selon souris...	JUMP,NE ERROR	TEST.W	D3		; est-on dans la case vide ?	JUMP,EQ LOOP		; oui => LOOP	LOAD.W	(A6)+ONREP,D3	CALL	CLRALLSOFTKEY	; teint toutes les "soft-keys"	CALL	MAJSOFTKEY	; mj "soft-keys"	CALL	SETSOFTKEY	; puis allume la nouvelle	JUMP	LOOPSDIVERS2:	COMP.W	D2,#SKDPREV	JUMP',EQ 20$	LOAD.L	A4,#R16"TICODIVERS2	TEST.B	(A4)+(D2.W)+4	; icne existe ?	JUMP,EQ ERROR		; non => ERROR	CALL	CLRALLSOFTKEY	; teint toutes les "soft-keys"	CALL	SETSOFTKEY	; puis allume la nouvelle	JUMP	LOOP20$:	LOAD.W	D1,#NDIVERS1	; D1 <-- divers un	JUMP	MAINPRESSNOTE:	LOAD.L	A3,#(A6)+ODJP	LOAD.W	D3,#(128/4)-105$:	CLR.L	(A3+)	DECJ.W,NMO D3,05$	LOAD.L	A3,#(A6)+ODJP	CLR.W	D3	LOAD.W	D4,#128-110$:	TEST.B	(A4+)		; une touche presse ?	JUMP',NE 20$		; oui => 20$	INC.W	D3		; D3 <-- touche suivante	DECJ.W,NMO D4,10$	JUMP	90$20$:	LOAD.L	A4,#(A6)+OSYMB	; A4 <-- ^symbole courant	CALL	PREPSYMB	; prpare la note	CALL	SRCNPOS		; D4 <-- position (y;x)	JUMP,NE 90$	LOAD.W	D4,#LSY	CALL	_INSERT	JUMP,NE 90$	LOAD.W	D2,#SETDOT	CALL	DESOBJET	; dessine la note	LOAD.B	(A3)+(D3.W),#-1	; signal note cre	LOAD.L	D4,(A4)+OSYPOS	ADD.W	D4,(A0)+ODFFX	SWAP.W	D4	ADD.W	D4,(A0)+ODFFY	SWAP.W	D4	CALL	_PMOUSE		; avance la souris80$:	CALL	_MIDIPRESS	; A4 <-- ^touches presses	CLR.W	D2	CLR.W	D3	LOAD.W	D4,#128-182$:	TEST.B	(A4+)		; encore une touche presse ?	JUMP',EQ 84$		; non => 84$	TEST.B	(A3)+(D3.W)	; note dj cre ?	JUMP,EQ 20$		; non => 20$	INC.W	D2		; D2 <-- une note presse de plus84$:	INC.W	D3	DECJ.W,NMO D4,82$	TEST.W	D2		; y a-t-il des notes presses ?	JUMP,NE 80$		; oui => 80$	LOAD.L	A4,#(A6)+OSYMB	; A4 <-- ^symbole courant	LOAD.L	D4,(A4)+OSYPOS	LOAD.W	D3,(A6)+OLXPORT	MUL.WU	D3,#3		; D3 <-- LXPORTEE*3	ADD.W	D4,D3	ADD.W	D4,(A0)+ODFFX	SWAP.W	D4	ADD.W	D4,(A0)+ODFFY	SWAP.W	D4	CALL	_PMOUSE		; avance la souris90$:	RETDJPCLEAR:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+ODJP	LOAD.W	D4,#(128/4)-110$:	CLR.L	(A4+)	DECJ.W,NMO D4,10$	POPM.L	D4,A4	RETDJPADD:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+ODJP	LOAD.W	D4,#(128/4)-110$:	CLR.L	(A4+)	DECJ.W,NMO D4,10$	POPM.L	D4,A4	RETCLIC:	COMP.W	D5,#KEYMMP	; bouton du milieu press ?	JUMP,EQ MILIEU		; oui => MILIEU	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^mesure courante	LIB	?IFMOUSE	JUMP',NE 50$	SUB.W	D4,(A0)+ODFFX	JUMP',LO 50$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',LO 50$	SWAP.W	D4	LOAD.W	D3,#MXPORTEE-4	ADD.W	D3,(A4)+OMELG	COMP.W	D4,D3		; est-on au bout des portes ?	JUMP',LO 50$		; non => 50$	ADD.W	D3,#4+MXPORTEE	COMP.W	D4,D3	JUMP',HS 50$				; oui =>	CALL	MOVPORTEES	; dplace portes/frontires	JUMP	LOOP50$:	LOAD.W	D3,D5		; D3 <-- touche/bouton press	COMP.W	D3,#KEYMDP	; bouton de droite press ?	JUMP,EQ DROITE		; oui => DROITE	COMP.W	D1,#NHAUTNOTE	JUMP',EQ GAUCHE_SYMB	COMP.W	D1,#NBASNOTE	JUMP',EQ GAUCHE_SYMB	COMP.W	D1,#NHAUTSILENCE	JUMP',EQ GAUCHE_SYMB	COMP.W	D1,#NBASSILENCE	JUMP',EQ GAUCHE_SYMB	COMP.W	D1,#NDIVERS1	JUMP',EQ GAUCHE_SYMB	COMP.W	D1,#NDIVERS2	JUMP',EQ GAUCHE_SYMB	COMP.W	D1,#NGRAPHIQUE	JUMP,EQ GAUCHE_GRA	JUMP	ERRORGAUCHE_SYMB:			; insre un symbole =>	CALL	IFMOUSE		; D4 <-- position	JUMP,NE ERROR	LOAD.L	A4,#(A6)+OSYMB	; A4 <-- ^symbole courant	CALL	PREPSYMB	; prpare la note	CALL	RNDOBJET	; D4 <-- arrondi la position de la souris	CALL	SRNDOBJET	; D4 <-- arrondi spcial pour qq symboles	LOAD.L	(A4)+OSYPOS,D4	CALL	_CCMO	LOAD.L	A3,#R16"TXMPOSEM	CALL	AFMOUSE	LOAD.L	A3,#R16"TXMPOSED	CALL	AFMOUSE	CALL	ECHO		; musique...	CALL	AFNOMNOTE	; affiche le nom de la note	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; inverse le symbole dans l'cranLOOP$:	LIB	?GETKEY		; attend clavier/souris ...	TEST.L	D3:#BKPSEUDO	JUMP,BS LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMP	; augmente ?	JUMP',EQ PLUS$	COMP.W	D3,#KEYMDP	; diminue ?	JUMP',EQ MOINS$	COMP.W	D3,#H'7F	; caractre frapp ?	JUMP',LO KEY$	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP,NE END$		; non => END$	CALL	IFMOUSE		; D4 <-- nouvelle position	CALL	RNDOBJET	; D4 <-- arrondi la position de la souris	CALL	SRNDOBJET	; D4 <-- arrondi spcial pour qq symboles	COMP.L	D4,(A4)+OSYPOS	; position change ?	JUMP,EQ LOOP$		; non => LOOP$				; oui =>	CALL	DESOBJET	; efface l'ancienne note	LOAD.W	D3,(A4)+OSYPOS+0	LOAD.L	(A4)+OSYPOS,D4	SWAP.W	D4	COMP.W	D4,D3		; mme hauteur ?	JUMP',EQ LOOP8$		; oui => LOOP8$	CALL	ECHO		; musique...	CALL	AFNOMNOTE	; affiche le nom de la noteLOOP8$:	CALL	DESOBJET	; dessine la nouvelle note	JUMP	LOOP$PLUS$:				; augmente dure =>	CALL	DESOBJET	; efface l'ancienne note	CALL	PLUSSYMB	CALL	DESOBJET	; dessine la nouvelle note	JUMP	LOOP$MOINS$:				; diminue dure =>	CALL	DESOBJET	; efface l'ancienne note	CALL	MOINSSYMB	CALL	DESOBJET	; dessine la nouvelle note	JUMP	LOOP$KEY$:				; caractre frapp =>	COMP.B	(A4)+OOBJC,#ICOHSOUPIR	JUMP,HI BIP$		LIB	?MINMAJ		; D3 <-- lettre majuscule	LOAD.B	D4,#ICOBEMOL	COMP.B	D3,#'B	JUMP,EQ ALTER$	LOAD.B	D4,#ICODIESE	COMP.B	D3,#'D	JUMP,EQ ALTER$	COMP.B	D3,#'#	JUMP,EQ ALTER$	COMP.B	D3,#'\	JUMP,EQ ALTER$	LOAD.B	D4,#ICOBECARRE	COMP.B	D3,#'A	JUMP,EQ ALTER$	COMP.B	D3,#'0	JUMP,EQ ALTER$	CLR.B	D4	COMP.B	D3,#SPACE	JUMP,EQ ALTER$	LOAD.B	D4,#ICOHACCENT	COMP.B	D3,#'V	JUMP,EQ ACCENT$	LOAD.B	D4,#ICOHDETACHE	COMP.B	D3,#'.	JUMP,EQ ACCENT$	LOAD.B	D4,#ICOHPIQUE	COMP.B	D3,#',	JUMP,EQ ACCENT$	LOAD.B	D4,#BSYPOINT	COMP.B	D3,#'P	JUMP,EQ POINTE$	LOAD.B	D4,#BSYDUOLET	COMP.B	D3,#'2	JUMP,EQ POINTE$	COMP.B	D3,#'4	JUMP,EQ POINTE$	LOAD.B	D4,#BSYTRIOLET	COMP.B	D3,#'3	JUMP,EQ POINTE$	COMP.B	D3,#'6	JUMP,EQ POINTE$	LOAD.B	D4,#BSYQUINTOLET	COMP.B	D3,#'5	JUMP,EQ POINTE$	LOAD.B	D4,#BSYSEPTOLET	COMP.B	D3,#'7	JUMP,EQ POINTE$	COMP.B	D3,#'[	JUMP,EQ FRAPPEDOWN$	COMP.B	D3,#']	JUMP,EQ FRAPPEUP$BIP$:				; touche inconnue =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ALTER$:	CALL	DESOBJET	; efface l'ancienne note	COMP.B	D4,(A4)+OSYALT	JUMP',NE ALTER1$	CLR.B	D4		; D4 <-- enlve l'altrationALTER1$:	LOAD.B	(A4)+OSYALT,D4	CALL	ECHO		; musique...	CALL	DESOBJET	; dessine la nouvelle note	JUMP	LOOP$ACCENT$:	CALL	DESOBJET	; efface l'ancienne note	COMP.B	D4,(A4)+OSYACC	JUMP',NE ACCENT1$	CLR.B	D4		; D4 <-- enlve l'accentACCENT1$:	LOAD.B	(A4)+OSYACC,D4	CALL	ECHO		; musique...	CALL	DESOBJET	; dessine la nouvelle note	JUMP	LOOP$POINTE$:	CALL	DESOBJET	; efface l'ancienne note	TNOT.B	(A4)+OSYFLG:D4	CALL	DESOBJET	; dessine la nouvelle note	JUMP	LOOP$FRAPPEUP$:	LOAD.W	D3,(A6)+ONFRAP	; D3 <-- force de frappe actuelle	COMP.W	D3,#(ICOSFRAPPE+MAXSFRAPPE-1)!2^7	JUMP,EQ BIP$	INC.W	D3	JUMP'	FRAPPEMAJ$FRAPPEDOWN$:	LOAD.W	D3,(A6)+ONFRAP	; D3 <-- force de frappe actuelle	COMP.W	D3,#ICOSFRAPPE!2^7	JUMP,EQ BIP$	DEC.W	D3FRAPPEMAJ$:	LOAD.W	(A6)+ONFRAP,D3	CALL	MAJSOFTKEY	; mj "soft-keys";	LOAD.W	D3,(A6)+ONFRAP	SUB.W	D3,#(ICOSFRAPPE-1)!2^7 ; D3 <-- 1..5	LOAD.B	(A4)+OSYFRAP,D3	JUMP	LOOP$END$:;;?	CALL	MAJMOUSE	; remet les boutons normaux	CALL	_SCMO	LOAD.L	D4,(A4)+OSYPOS	; D4 <-- position du symbole	LOAD.L	A3,A4	CALL	DETECTE		; dj qq chose ici ?	EX.L	A4,A3		; A3 <-- ^qq chose	JUMP',NE INSERT$	; non => INSERT$	COMP.B	(A4)+OOBJC,#ICOHSOUPIR ; est-ce un symbole musical ?	JUMP',HI INSERT$	; non => INSERT$;;?	TEST.W	D2		; est-ce un symbole musical ?;;?	JUMP',NE INSERT$	; non => INSERT$	COMP.L	D4,(A3)+OSYPOS	; exactement la mme position ?	JUMP',NE INSERT$	; non => INSERT$	LOAD.B	D3,(A4)+OOBJC	CALL	IFHAUTBAS	; l'un en haut et l'autre en bas ?	JUMP',NE CHANGE$	; non => CHANGE$INSERT$:			; oui => accepte la superposition	LOAD.W	D4,#LSY	CALL	_INSERT	JUMP',NE CLEAR$	LOAD.W	D2,#SETDOT	CALL	DESOBJET	; dessine la note dfinitive	CALL	AFINFO		; mj les infos tout en haut	JUMP	LOOPCHANGE$:			; remplace par la nouvelle note =>	TEST.B	(A3)+OOBJF:#BGROUPE	JUMP',BS CLEAR$	EX.L	A3,A4	CALL	TAKEOBJET	; efface l'objet	CALL	DESPORTEES	; refait les portes	CALL	DETRUIT		; supprime l'objet	LOAD.L	A4,A3	JUMP	INSERT$CLEAR$:	PUSH.W	D7	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface la note	POP.W	D7	JUMP	ERRORGAUCHE_GRA:	CALL	IFMOUSE		; D4 <-- position	JUMP,NE ERROR	TEST.L	D0:#SKGTEXTE	; objet trs spcial "texte" ?	JUMP,BS 70$		; oui => 70$	LOAD.L	A4,#(A6)+OGRA	; A4 <-- ^objet graphique	CALL	PREPGRA		; prpare l'objet	CALL	RNDOBJET	; D4 <-- arrondi la position de la souris	LOAD.L	(A4)+OGRPN1,D4	; objet <-- "attache" dj une extrmit	CLR.L	(A4)+OGRPN2	; objet <-- pas encore connu	LOAD.B	D3,(A4)+OOBJC	; D3 <-- code icne	COMP.B	D3,#ICOCERCLE	; dessine un cercle ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D3,#ICOHCOURBE	; dessine une courbe ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D3,#ICOBCOURBE	; dessine une courbe ?	JUMP',EQ 20$		; oui => 20$	CALL	_CCMO		; non => enlve la flche de la souris20$:	CALL	CALCGRA		; calcul v. qq paramtres	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; inverse l'objet dans l'cran30$:	LIB	?GETKEY	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE 40$		; non => 40$	CALL	IFMOUSE		; D4 <-- nouvelle position	CALL	RNDOBJET	; D4 <-- arrondi la position de la souris	LOAD.L	D5,(A4)+OGRPN2	; D5 <-- ancien	LOAD.L	(A4)+OGRPN2,D4	CALL	CALCGRA		; calcul v. qq paramtres	COMP.L	D5,(A4)+OGRPN2	; position change ?	JUMP,EQ 30$		; non => 30$				; oui =>	LOAD.L	D4,(A4)+OGRPN2	; D4 <-- nouveau	LOAD.L	(A4)+OGRPN2,D5	CALL	DESOBJET	; efface l'ancien objet	LOAD.L	(A4)+OGRPN2,D4	CALL	DESOBJET	; dessine le nouvel objet	JUMP	30$40$:	CALL	_SCMO	TEST.L	(A4)+OGRPN2	JUMP,EQ LOOP	LOAD.W	D4,#LGR	CALL	_INSERT	JUMP',NE 50$	LOAD.W	D2,#SETDOT	CALL	DESOBJET	; dessine l'objet dfinitif	CALL	AFINFO		; mj les infos tout en haut	JUMP	LOOP50$:	PUSH.W	D7	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface l'objet	POP.W	D7	JUMP	ERROR70$:				; texte =>	CALL	RNDOBJET	; D4 <-- arrondi la position de la souris	CALL	PUTTEXTE	; texte en dition --> mesure courante	CALL	DETECTE		; A4 <-- ^objet o est la souris	JUMP',NE 80$	COMP.B	(A4)+OOBJC,#ICOTEXTE	JUMP',NE 80$	CALL	GETTEXTE	; A4 --> texte en dition	CALL	AFINFO		; mj les infos tout en haut	JUMP	LOOP80$:	SWAP.W	D4	ADD.W	D4,(A6)+OTEXTE+OTXBLI	SWAP.W	D4	LOAD.L	(A6)+OTEXTE+OTXPN1,D4	CALL	GETPGC		; A4 <-- ^dans OBUGC	LOAD.L	(A6)+OTEXTE+OTXFST,(A4)+OGCCOD	LOAD.B	(A6)+OTEXTE+OTXFST,#USEGC	LOAD.L	D2,(A0)+ODFGCF	; D2 <-- "fst-" initial	LOAD.L	A3,#(A6)+OTEXTE+OTXFST	LOAD.W	D3,#4	LIB	?STRING		; utilise gencar du texte	LOAD.L	(A6)+OTEXTE+OTXPGC,(A0)+ODFPGC	LOAD.W	(A6)+OTEXTE+OTXBLI,(A0)+ODFC2Y	LOAD.L	A3,#(A6)+OBDIS	LOAD.B	D2,#USEGC	RR.L	D2,#8		; D2 <-- "<usegc>fst"	LOAD.L	(A3),D2	LOAD.W	D3,#4	LIB	?STRING		; remet gencar initial	CLR.W	(A6)+OTEXTE+OTXCUR	CLR.B	(A6)+OTEXTE+OTXCAR	CALL	AFINFO		; mj les infos tout en haut	JUMP	LOOPMILIEU:	CALL	PUTTEXTE	; texte en dition --> mesure courante	CLR.L	D4		; D4 <-- toutes les cases	COMP.W	(A6)+ONBOBJ,#1	JUMP',HI 20$	TSET.L	D4:#4		; D4 <-- plus de case "coute"	TSET.L	D4:#5		; D4 <-- plus de case "imprime"	TSET.L	D4:#6		; D4 <-- plus de case "copie"	TSET.L	D4:#7		; D4 <-- plus de case "dtruit"20$:	LOAD.W	D3,(A6)+OMESC	INC.W	D3	COMP.W	D3,(A6)+OMESM	; est-on dans la dernire mesure ?	JUMP',LO 22$	TSET.L	D4:#7		; D4 <-- plus de case "dtruit"22$:	TEST.L	(A6)+OCAPRINT	; module PRINT charg ?	JUMP',NE 24$		; oui => 24$	TSET.L	D4:#5		; D4 <-- plus de case "imprime"24$:	LOAD.L	A3,#R16"MMMILIEU	LOAD.W	D3,#2^15	; D3 <-- signal D4 en entre	CALL	_MMENU		; attend dans mmenu selon souris...	JUMP,NE ERROR	TEST.W	D3	JUMP,EQ LOOP	COMP.W	D3,#1	JUMP,EQ DOPREND	COMP.W	D3,#2	JUMP,EQ DOAJOUTE	COMP.W	D3,#3	JUMP,EQ DOSAUVE	COMP.W	D3,#4	JUMP,EQ DOECHO	COMP.W	D3,#5	JUMP,EQ DOPRINT	COMP.W	D3,#6	JUMP,EQ MICOPIE	COMP.W	D3,#7	JUMP,EQ MIDETRUIT	JUMP	ERRORMICOPIE:	LOAD.L	A3,(A6)+OPDT	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	LOAD.W	D4,(A4)-2	CALL	_INSERT	JUMP,NE ERROR	ADD.L	A3,#2	LOAD.L	(A6)+OPMES,A3	INC.W	(A6)+OMESC	; mj le numro de mesure courante20$:	CALL	_NVISU		; A4 <-- ^objet suivant	JUMP,NE 80$	COMP.B	(A4)+OOBJC,#OBJMES ; dbut mesure suivante ?	JUMP,EQ 80$	LOAD.W	D4,(A4)-2	CALL	_INSERT	JUMP,NE ERROR	JUMP	20$80$:	CALL	AFINFO		; mj les infos tout en haut	CALL	_SCROLLUPDATE	; mj l'ascenseur	JUMP	LOOPMIDETRUIT:	LOAD.L	A4,(A6)+OPFT	COMP.L	A4,(A6)+OPFB	; encore une mesure aprs ?	JUMP,EQ 50$		; non => 50$20$:	CALL	_DRECULE	COMP.B	(A4)+OOBJC,#OBJMES ; dbut mesure  dtruire ?	JUMP,NE 20$	DEC.W	(A6)+OMESM	; une mesure de moins	DEC.W	(A6)+OMESC	; mj le numro de mesure courante	CALL	_NMESURE	; avance  la mesure suivante	JUMP	80$50$:	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure	CALL	_PVISU	JUMP,NE ERROR55$:	COMP.B	(A4)+OOBJC,#OBJMES ; dbut mesure suivante ?	JUMP,EQ 60$	CALL	_PVISU	JUMP,EQ 55$60$:	LOAD.L	(A6)+OPMES,A4	DEC.W	(A6)+OMESC	; mj le numro de mesure courante65$:	CALL	_DRECULE	COMP.B	(A4)+OOBJC,#OBJMES ; dbut mesure  dtruire ?	JUMP,NE 65$	DEC.W	(A6)+OMESM	; une mesure de moins80$:	CALL	REFAIT		; dessine la mesure	JUMP	LOOPDROITE:				; modifie un symbole =>	CALL	PUTTEXTE	; texte en dition --> mesure courante (si ncessaire)	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE ERROR	CALL	RNDOBJET	; D4 <-- arrondi la position de la souris	CALL	DETECTE		; A4 <-- ^objet o est la souris	JUMP,NE GROUPE				; dtruit/dplace =>	LOAD.L	A3,#R16"TXMDETRUIT	CALL	AFMOUSE		; affiche le bouton de droite	CALL	_CCMO	CALL	TAKEOBJET	; efface l'objet	CALL	DESPORTEES	; refait les portes	CALL	GETPOINT	; D3 <-- coordonne	CALL	SRNDOBJET	; D4 <-- arrondi spcial pour qq symboles	LOAD.L	D5,D4	SWAP.W	D3	SWAP.W	D5	SUB.W	D5,D3		; D5 <-- correction en X	SWAP.W	D3	SWAP.W	D5	SUB.W	D5,D3		; D5 <-- correction en Y	CLR.W	D6		; D6 <-- souris pas encore bouge20$:	LIB	?GETKEY	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE 30$		; non => 30$	CALL	IFMOUSE		; D4 <-- nouvelle position	CALL	RNDOBJET	; D4 <-- arrondi la position de la souris	CALL	SRNDOBJET	; D4 <-- arrondi spcial pour qq symboles	SUB.W	D4,D5		; D4 <-- corrige en X	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D5		; D4 <-- corrige en Y	SWAP.W	D4	SWAP.W	D5	CALL	GETPOINT	; D3 <-- coordonne	COMP.L	D4,D3		; position change ?	JUMP,EQ 20$		; non => 20$				; oui =>	TEST.W	D6		; souris dj bouge ?	JUMP',EQ 24$		; non => 24$	PUSH.W	D2	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface l'ancien objet	POP.W	D2	JUMP'	25$24$:	LOAD.L	A3,#R16"TXMDEPLACE	CALL	AFMOUSE		; affiche le bouton de droite25$:	INC.W	D6		; D6 <-- souris bouge	LOAD.L	D3,D4	CALL	PUTPOINT	; objet <-- met le point	CALL	ECHO		; musique...	CALL	AFNOMNOTE	; affiche le nom de la note	PUSH.W	D2	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; dessine le nouvel objet	POP.W	D2	JUMP	20$30$:	TEST.W	D6		; souris bouge ?	JUMP',EQ 50$		; non => 50$ (dtruit)				; oui => dplace	LOAD.W	D2,#SETDOT	CALL	DESOBJET	; dessine l'objet dfinitif	CALL	_SCMO	JUMP	LOOP50$:				; dtruit =>	CALL	_SCMO	TEST.B	(A4)+OOBJF:#BGROUPE	JUMP',BC 80$				; groupe de croches =>	LOAD.L	D4,(A4)+OSYNOB	; D4 <-- no du groupe	CALL	DETRUIT		; supprime l'objet	LOAD.W	D2,#SETDOT	CALL	DESBC		; puis re-dessine la barre	JUMP',EQ 90$		; reste 2..n croches => 90$	CALL	DESOBJET	; reste qu'une => redessine avec la queue	JUMP'	90$80$:	CALL	DETRUIT		; supprime l'objet90$:	CALL	AFINFO		; mj les infos tout en haut	JUMP	LOOPGROUPE:	LOAD.L	A3,#R16"TXMGROUPE	CALL	AFMOUSE		; affiche le bouton de droite	CALL	IFMOUSE		; D4 <-- position de la souris	LOAD.L	D4,(A6)+OMPOW	; D4 <-- position souris dans swdo, sans arrondi	CALL	_CCMO	LOAD.L	A4,#(A6)+OGRA	; A4 <-- ^objet graphique "bidon"	LOAD.B	(A4)+OOBJC,#ICORECTANGLE	LOAD.L	(A4)+OGRPN1,D4	LOAD.L	(A4)+OGRPN2,D4	LOAD.B	(A4)+OGREP,#1	LOAD.B	(A4)+OGRTT,#B'01010101LOOP$:	LIB	?GETKEY	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE OK$		; non => OK$	CALL	IFMOUSE	LOAD.L	D4,(A6)+OMPOW	; D4 <-- position souris dans swdo, sans arrondi	COMP.L	D4,(A4)+OGRPN2	; position change ?	JUMP,EQ LOOP$		; non => LOOP$				; oui =>	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface l'ancien rectangle	LOAD.L	(A4)+OGRPN2,D4	CALL	DESOBJET	; dessine le nouveau rectangle	JUMP	LOOP$OK$:	CALL	_SCMO	CALL	GCOMPTE		; D2 <-- nb d'objets inclus	TEST.W	D2		; au moins un objet inclu ?	JUMP',NE 14$		; oui => 14$				; non =>	LOAD.W	D4,(A4)+OGRPN1+2	SUB.W	D4,(A4)+OGRPN2+2	JUMP',NC 10$	NEG.W	D4		; D4 <-- |largeur du rectangle|10$:	COMP.W	D4,#4	JUMP',HS 14$	LOAD.W	D4,(A4)+OGRPN1+0	SUB.W	D4,(A4)+OGRPN2+0	JUMP',NC 12$	NEG.W	D4		; D4 <-- |hauteur du rectangle|12$:	COMP.W	D4,#4	JUMP,LO ERROR$14$:	CALL	AFCOMPTE	; affiche le nombre d'objets trouvs	CLR.L	D4		; D4 <-- toutes les cases	TEST.W	D2		; au moins un objet ?	JUMP',NE 20$		; oui => 20$	OR.B	D4,#B'00111110	; non => plus de cases "ddd, nuances, lie"20$:	TEST.W	(A6)+OGCNTN	; au moins une note ?	JUMP',NE 22$		; oui => 22$	TSET.L	D4:#4		; non => plus de case "nuances"22$:	COMP.W	(A6)+OGCNTC,#2	; au moins deux croches ?	JUMP',HS 24$		; oui => 24$	TSET.L	D4:#5		; non => plus de case "lie les croches"24$:	TEST.W	(A6)+OGCNTL	; une ou plusieurs croches lies ?	JUMP',EQ 26$		; non => 26$	TSET.L	D4:#3		; oui => plus de case "duplique"26$:	LOAD.L	A3,#R16"MMGROUPE	LOAD.W	D3,#2^15	; D3 <-- signal D4 en entre	CALL	_MMENU		; attend dans mmenu selon souris...	JUMP,NE ERROR$	LOAD.L	D4,(A4)+OGRPN2	; D4 <-- coin mobile du rectangle	ADD.W	D4,(A0)+ODFFX	SWAP.W	D4	ADD.W	D4,(A0)+ODFFY	SWAP.W	D4	CALL	_PMOUSE		; remet la souris o elle tait	COMP.W	D3,#1	JUMP',EQ DETRUIT$	COMP.W	D3,#2	JUMP',EQ DEPLACE$	COMP.W	D3,#3	JUMP',EQ DUPLIQUE$	COMP.W	D3,#4	JUMP,EQ FRAPPE$	COMP.W	D3,#5	JUMP,EQ BARRE$	COMP.W	D3,#6	JUMP,EQ IMAGE$	JUMP	ERROR$DETRUIT$:			; dtruit =>	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface le dernier rectangle	CALL	GDETRUIT	; dtruit tout le groupe	CALL	AFINFO		; mj les infos tout en haut	JUMP	LOOPDEPLACE$:			; dplace =>	CALL	GDEPLACE	; dplace tout le groupe	CALL	AFINFO		; mj les infos tout en haut	JUMP	LOOPDUPLIQUE$:			; duplique =>	CALL	GDUPLIQUE	; duplique tout le groupe	JUMP,NE ERROR	CALL	AFINFO		; mj les infos tout en haut	JUMP	LOOPFRAPPE$:			; force de frappe =>	LOAD.L	A3,#R16"MMFRAPPE	CLR.W	D3	CALL	_MMENU		; attend dans mmenu selon souris...	JUMP,NE ERROR$	TEST.W	D3	JUMP,EQ ERROR$	CALL	GFRAPPE		; modifie la force de frappe du groupe	CLR.W	D7		; D7 <-- ok	JUMP	ERROR$BARRE$:				; lie les croches =>	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface le dernier rectangle	CALL	GBARRE		; lie toutes les croches du groupe	CALL	GNOTAKE		; enlve tous les bits BTAKE	CALL	AFINFO		; mj les infos tout en haut	JUMP	LOOPIMAGE$:				; image =>	CALL	GNOTAKE		; enlve tous les bits BTAKE	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface le dernier rectangle	CALL	AFINFO		; mj les infos tout en haut	JUMP	DOIMAGE		; sauve l'image ...ERROR$:				; erreur =>	PUSH.W	D7	CALL	GNOTAKE		; enlve tous les bits BTAKE	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface le dernier rectangle	CALL	AFINFO		; mj les infos tout en haut	POP.W	D7	JUMP,NE	ERROR	JUMP	LOOP;********\\; BARRES  >;********/; Met les barres  un groupe de croches.BARRES:	LOAD.L	A3,#R16"TICOBARRE	LOAD.L	A4,#R16"TICOVNIL	DBOX_	ICOAFF		; dessine les "soft-keys"	LOAD.L	A3,#R16"TMENUBARRE	LIB	?AFMENU; Affiche les textes d'aide pour les trois boutons de la souris.	LOAD.L	A3,#R16"TXMBARREG	CALL	AFMOUSE	LOAD.L	A3,#R16"TXMVIDEM	CALL	AFMOUSE	LOAD.L	A3,#R16"TXMBARRED	CALL	AFMOUSE	CALL	BARRENEW	; lie une nouvelle srie de croches10$:	LIB	?GETCAR		; attend bouton souris...	COMP.W	D3,#KEYMGR	JUMP,EQ 10$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ 10$		; oui => 10$	COMP.W	D3,#KEYMDR	JUMP,EQ 10$	COMP.W	D3,#KEYMGP	; lie ?	JUMP',EQ 20$	COMP.W	D3,#KEYMDP	; termine ?	JUMP,EQ 50$	COMP.W	D3,#KEYMMP	JUMP,NE 40$15$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	10$; Si le symbole montr est une croche, ajoute-la dans OBCLIST.20$:				; lie =>	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 15$	CALL	RNDOBJET	; D4 <-- arrondi la position de la souris	CALL	DETECTE		; A4 <-- ^objet o est la souris	JUMP,NE 15$	TEST.W	D2		; symbole musical ?	JUMP,NE 15$		; non => 15$				; oui =>	CALL	BARREONE	; lie une croche	JUMP,NE 15$	JUMP	10$; S'il y a plus d'une croche  lier, met une jolie barre.40$:	CLR.W	D5		; D5 <-- annule50$:	CALL	BARREMAKE	; lie toutes les croches choisies	JUMP	MAIN;---------\\; BARRENEW >;=========/; Lie une nouvelle srie de barres.; in	-; out	A3.L	^dans buffer OBCLIST;	D5.W	nb de croches lies; mod	D5.L, D7.W, A3.LBARRENEW:	LOAD.L	A3,#(A6)+OBCLIST	CLR.B	(A3)+OOBJC	; OBCLIST <-- terminateur	CLR.W	D5		; D5 <-- nb de croches lies	RET;---------\\; BARREONE >;=========/; Prend une croche pour la lier.; in	A4.L	^symbole;	A3.L	^dans buffer OBCLIST;	D5.W	nb de croches lies; out	A3.L	^plus loin;	D5.L	nb de croches lies;	D7.W	erreur; mod	D5.L, D7.W, A3.LBARREONE:	PUSHM.L	D3,D4,A2,A4; Si le symbole est une croche solitaire, ajoute-la dans OBCLIST.	CALL	IFCROCHE	; est une croche ?	JUMP,NE 80$		; non => 80$	TEST.B	(A4)+OOBJF:#BGROUPE ; fait dj partie d'un groupe ?	JUMP',BS 30$		; oui => 30$	INC.W	D5		; D5 <-- un croche lie de plus	COMP.W	D5,#MBCLIST	; buffer OBCLIST plein ?	JUMP,HS 80$		; oui => 80$				; non =>	LOAD.W	D3,#1		; D3 <-- juste une croche	CALL	BARREGET	; OBCLIST <-- une croche	CLR.W	D7		; D7 <-- ok	JUMP	90$; Si le symbole montr est un groupe de croches, regarde s'il est possible; d'ajouter tout le groupe dans OBCLIST.30$:	LOAD.L	D4,(A4)+OSYNOB	; D4 <-- no du groupe	LOAD.L	A4,(A6)+OPMES	; A4 <-- ^dbut de la mesure35$:	CALL	_NVISU		; A4 <-- ^objet suivant	JUMP,NE 80$	COMP.B	(A4)+OOBJC,#OBJMES ; dbut mesure suivante ?	JUMP,EQ 80$		; oui => 80$				; non =>	CALL	IFCROCHE	; est une croche ?	JUMP,NE 35$	COMP.L	D4,(A4)+OSYNOB	JUMP,NE 35$	LOAD.L	A2,A4		; A2 <-- ^premire croche du groupe	CLR.W	D340$:	INC.W	D3		; D3 <-- une croche de plus	CALL	_NVISU		; A4 <-- ^objet suivant	JUMP',NE 45$	COMP.B	(A4)+OOBJC,#OBJMES ; dbut mesure suivante ?	JUMP',EQ 45$		; oui => 45$				; non =>	CALL	IFCROCHE	; est une croche ?	JUMP',NE 45$	COMP.L	D4,(A4)+OSYNOB	JUMP,EQ 40$45$:	ADD.W	D5,D3		; D5 <-- tout un groupe de plus	COMP.W	D5,#MBCLIST	; buffer OBCLIST plein ?	JUMP',HS 80$		; oui => 80$				; non =>	LOAD.L	A4,A2		; A4 <-- ^premire croche du groupe	CALL	BARREGET	; OBCLIST <-- toutes les croches du groupe	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	LOAD.W	D7,#1		; D7 <-- erreur90$:	POPM.L	D3,D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; BARREMAKE >;==========/; Lie toutes les croches slectionne par BARREONE.; in	D5.W	nb de croches lies; out	-; mod	D7.WBARREMAKE:	PUSHM.L	D2..D4,A4	COMP.W	D5,#2		; au moins deux croches lies ?	JUMP',LO 50$		; non => 50$	INC.L	(A6)+ONOB	; dlivre un nouveau numro de barre	LOAD.L	A4,#(A6)+OBCLIST20$:	TEST.B	(A4)+OOBJC	; fin de OBCLIST ?	JUMP',EQ 30$		; oui => 30$	LOAD.L	(A4)+OSYNOB,(A6)+ONOB	TSET.B	(A4)+OOBJF:#BGROUPE	LOAD.W	D4,#LSY	CALL	_INSERT		; insert la croche	ADD.W	A4,D4		; A4 <-- ^croche suivante	JUMP	20$30$:	LOAD.L	D4,(A6)+ONOB	; D4 <-- no de la barre	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CALL	DESBC		; dessine la barre	JUMP	80$; En cas d'erreur, vide OBCLIST et remet tout son contenu dans; la mesure courante.50$:				; erreur =>	LOAD.L	A4,#(A6)+OBCLIST52$:	TEST.B	(A4)+OOBJC	; fin de OBCLIST ?	JUMP',EQ 80$		; oui => 80$	CLR.L	(A4)+OSYNOB	; supprime la barre provisoire	TCLR.B	(A4)+OOBJF:#BGROUPE	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CALL	DESOBJET	; re-dessine la croche avec une queue	LOAD.W	D4,#LSY	CALL	_INSERT		; insert la croche	ADD.W	A4,D4		; A4 <-- ^croche suivante	JUMP	52$80$:	CALL	AFINFO		; mj les infos tout en haut	POPM.L	D2..D4,A4	RET;---------\\; BARREGET >;---------/; Prend une croche ou un groupe de croches pour les lier plus tard.; Elle est redessine sans la queue, et supprime de la mesure.; in	A4.L	^croche(s);	A3.L	^dans buffer OBCLIST;	D3.W	nb de croches (1..n); out	A3.L	^plus loin; mod	D7.W, A3.LBARREGET:	PUSHM.L	D2..D4,A2,A4	LOAD.L	A2,A4		; A2 <-- ^objet  dtruire10$:	CALL	_RECULE	JUMP',NE 60$	COMP.L	A2,(A6)+OPDT	JUMP,LO 10$	LOAD.L	A4,(A6)+OPFT	ADD.L	A4,#2		; A4 <-- ^objet  dtruire	CALL	TAKEOBJET	; efface l'objet	LOAD.L	(A4)+OSYNOB,#-1	; fait une barre provisoire	TSET.B	(A4)+OOBJF:#BGROUPE	LOAD.W	D2,#SETDOT	CALL	DESOBJET	; re-dessine la croche sans la queue30$:	LOAD.L	A4,(A6)+OPFT	ADD.L	A4,#2		; A4 <-- ^objet  dtruire	PUSH.L	A4	LOAD.W	D4,#(LSY/2)-1	; /2 car .W, et -1  cause NMO40$:	LOAD.W	(A3+),(A4+)	; OBCLIST <-- une croche	DECJ.W,NMO D4,40$	POP.L	A4	CALL	_DAVANCE	; dtruit l'objet	DEC.W	D3	JUMP,NE 30$60$:	CLR.B	(A3)+OOBJC	; OBCLIST <-- terminateur	CALL	DESPORTEES	; refait les portes	CALL	_GOMEND		; retourne  la fin de la mesure	POPM.L	D2..D4,A2,A4	RET;---------\\; IFCROCHE >;=========/; Vrifie si l'objet est une croche.; in	A4.L	^objet; out	D7.W	zro	=> c'est une croche;		ERNOT	=> c'est autre chose; mod	D7.WIFCROCHE:	PUSH.W	D3	LOAD.W	D7,#ERSNOT	LOAD.B	D3,(A4)+OOBJC	; D3 <-- code de l'objet	COMP.B	D3,#ICOHCROCHE	JUMP',LO 90$	COMP.B	D3,#ICOHTCROCHE	JUMP',LS 80$	COMP.B	D3,#ICOBCROCHE	JUMP',LO 90$	COMP.B	D3,#ICOBTCROCHE	JUMP',HI 90$80$:	CLR.W	D7		; D7 <-- c'est une croche90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET	.END