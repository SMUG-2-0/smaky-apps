		.SBTTL	PLANIMAGE	; 18 aot 87 Sp.BUG	=	0		; debuggingOVERLAP	=	24		; recouvrement des crans dcals	.EVEN;------- IMAOUT:;-------;; Sauve une image sur disque de taille plus grande que l'cran, mais; limite  la dimension d'une page pouvant tre imprime.; La mmoire pour construire l'image doit tre disponible.;; in	D3.L	un coin de l'image;	D4.L	l'autre coin de l'image;	D6	canal du fichier; out	D7.W	erreur; mod	D7.W	PUSHM.L	D0..D6,A0..A5				; tester si base vide	LOAD.W	D7,#ERPEM	COMP.W	(A6)+OPLANAV+OUBMEM,#4		; buffer vide (4 aumoins!)?	JUMP,LS	90$			; oui -->	CLR.W	D7	LOAD.W	(A6)+OCHIO,D6		; sauve le canal;;;	CALL	ORDONNE			; D3 <- coin inf-g	.W	PLANA_ORDONNE	LOAD.L	D0,D3			; D0 <- D3 inf-g.			; D4 ne doit pas dpasser OMWDO..	COMP.W	D4,(A6)+OPLANAV+OMWDOX	JUMP,LS	01$	LOAD.W	D4,(A6)+OPLANAV+OMWDOX01$:	SWAP.W	D4	COMP.W	D4,(A6)+OPLANAV+OMWDOY	JUMP,LS	02$	LOAD.W	D4,(A6)+OPLANAV+OMWDOY02$:	SWAP.W	D4	LOAD.L	D5,D4			; D5 <- D4 sup-d.;--------	CALL	TESTROT		; possible avec imprimante ?	JUMP,EQ	03$		; oui => 3$				; non =>	TCLR.B	(A6)+OFLIO:#BIMROT ; sans rotation;	LOAD.L	D2,D4		; dx,dy tel quel;	SUB.W	D2,D3;	SWAP.W	D2;	SWAP.W	D3;	SUB.W	D2,D3;	SWAP.W	D2;	SWAP.W	D3	CALL	DBOX_IMAGE	; demander confirmation	JUMP,NE	90$		; non, on ne veut pas03$:;--------;===============.IF	BUG	PUSHM.L	D0,D2,D3,D4	LOAD.L	D3,(A6)+OPLANAV+OMINY	LIB	?SETCURS	LOAD.L	D4,D0	CALL	AFFQQCH	LOAD.L	D4,D5	CALL	AFFQQCH	LOAD.L	D0,D2	CLR.L	D4	LOAD.W	D4,D2	LOAD.W	D2,#2^BAFDALL	LOAD.W	D3,#8	LIB	?AFTIM	.ASCIZE	"dimension en X: "	LIB	?AFDEC	LIB	?AFTIM	.ASCIZE	"<CR>dimension en Y: "	SWAP.W	D0	LOAD.W	D4,D0	LIB	?AFDEC.W	LIB,?BEEP.W	LIB,?GETCARCOMP.B	D3,#ENDJUMP,NE	06$	POPM.L	D0,D2,D3,D4	JUMP	90$06$:	POPM.L	D0,D2,D3,D4;===============.ENDIF	LOAD.L	A2,#(A6)+OBUIMA	; effacer OBUIMA p. entte	LOAD.W	D4,#LGHIMA05$:	CLR.B	(A2+)	DEC.W	D4	JUMP,NE	05$	LOAD.L	A2,#(A6)+OBUIMA	; A2 ^ entte				; calculer et demander mmoire	LOAD.L	D4,D2			; D4 <-- (dy;dx)	SWAP.W	D4			; D4.W <-- dy	ADD.W	D4,#2-1			; D4 <-- dy modulo 2	AND.B	D4,#B'11111110	LOAD.W	(A2)+OIMDLY,D4	; entte .image	ADD.W	D2,#8-1			; D2 <-- dx modulo 8	AND.B	D2,#B'11111000	LOAD.W	(A2)+OIMDLX,D2	; entte .image	SR.W	D2,#3			; dx/8	CLR.L	D6	LOAD.W	D6,D2			; D6 <-- Iy dest.	MUL.WU	D4,D2			; D4 <-- D4 * D2 (dx/8)*(dy)	LOAD.L	(A2)+OIMNBB,D4	; entte .image	ADD.L	D4,#IMLBUF		; ajoute rserve	LOAD.W	D1,#MTYPCP		; processus courant	GESMEM	?GETMEM			; A4 <-- ^mm.	JUMP,NE	90$			; pas assez de mmoire...	LOAD.L	A1,A4			; A1 <-- ^mm.	LOAD.B	(A2)+OIMTYP,#H'81 ; entte .image	LOAD.B	(A2)+OIMCOD,#H'00	LOAD.B	(A2)+OIMBIP,#H'01	LOAD.B	(A2)+OIMDIR,#H'02				; remplir la mmoire de 0	SR.L	D4,#2			; longueur/4	PUSH.L	A4			; sauve A410$:	CLR.L	(A4+)	DEC.L	D4	JUMP,NE	10$	POP.L	A4			; A4 ^mmoire				; ok. on va construire l'image	PUSH.L	(A6)+OPLANAV+OMWDOY		; sauve paramtres PLAN	PUSH.L	(A6)+OPLANAV+OOWDOY	PUSH.L	(A6)+OPLANAV+OSWDOY	PUSH.W	(A6)+OPLANAV+OSCALE	PUSH.W	(A6)+OPLANAV+OCOULEUR	PUSH.W	(A6)+OPAS	PUSH.B	(A6)+OFLMOD				; param. pour .image	LOAD.W	D1,(A6)+OPLANAV+OCOULEUR	; param. pour .image	TCLR.L	D1:#COUINVISI	LOAD.W	(A6)+OPLANAV+OCOULEUR,D1	; ignore 'invisible'!	TCLR.B	(A6)+OFLMOD:#BLAST	; pas de rf. dynamique !	LOAD.W	(A6)+OPAS,#0		; PAS 0	CALL	IRETICULE		; enlve v. le rticule	CALL	RELLAST			; enlve v. rf.dyn.	CALL	CCMO			; supprime flche souris	TEST.B	(A6)+OFLMOD:#BREGLE	; si regle, alors enlever	JUMP,BC	11$	CALL	INVREGLE11$:	LOAD.L	(A6)+OPLANAV+OOWDOY,D0		; origine fentre	LOAD.L	(A6)+OPLANAV+OMWDOY,D5		; max. PLAN	LOAD.W	(A6)+OPLANAV+OSCALE,#0		; chelle 1:1	CALL	NEWSCALE		; recalcule OSWDO.. X et Y				; pointeurs pour raster-op	ADD.L	A4,#IMLBUF		; A4 ^image non code	LOAD.L	A2,(A6)+OPLANAV+OPDDIS		; A2 ^description fentre	LOAD.L	A3,#0			; source cran -> 0					; D5 qcq si cran				; boucle de construction de l'image20$:	CALL	CADREIM			; fait le cadre (spcial)	CALL	INIPLAN			; met PLAN ...;;;	CALL	INUZONELOAD.W	(A6)+OPLANAV+OPLANA,#FINUZONE	.W	PLANA_FONC;;	CALL	GRILLE			; serait fausse car pas = 0 !;;	CALL	IOWAITTEST.B	(A6)+OFLIO:#BIMROTJUMP,BC	21$	CALL	AFCMES.ASCIZE	/ construction d'image tourne en cours ... /JUMP	19$21$:	CALL	AFCMES	.ASCIZE	/ construction d'image en cours ... /19$:	CALL	REFAIT			; refait le dessin	LOAD.B	D3,#AFCCMO		; pas de flche souris	LIB	?AFCAR				; calcul de dy et dx en v. trop				; (dsy;dsx)  l'cran (ddy;ddx) ds. PLAN	LOAD.W	D1,(A6)+OPLANAV+OOWDOY		; D1 <-- OOWDOY+OSWDOY-OMWDOY	ADD.W	D1,(A6)+OPLANAV+OSWDOY	SUB.W	D1,(A6)+OPLANAV+OMWDOY	JUMP,NC	22$	CLR.W	D1			; si inf. ddy=022$:	SWAP.W	D1	LOAD.W	D1,(A6)+OPLANAV+OOWDOX		; D1 <-- OOWDOX+OSWDOX-OMWDOX	ADD.W	D1,(A6)+OPLANAV+OSWDOX	SUB.W	D1,(A6)+OPLANAV+OMWDOX	JUMP,NC	23$			; si inf. ddx=0	CLR.W	D123$:	LOAD.L	D4,D1			; D1 (ddy;ddx);;;	CALL	D4SCALE			; D4 (dsy;dsx)	.W	PLANA_D4SCALE				; D3 <-- coordonne source	LOAD.L	D3,(A6)+OPLANAV+OMINY		; D3 <-- (OMINY+dsy;OMINX)	SWAP.W	D3	SWAP.W	D4			; D4 (dsx;dsy)	ADD.W	D3,D4	SWAP.W	D3				; D2 <-- hauteur/largeur	LOAD.L	D2,(A6)+OPLANAV+OLWDOY		; D2 <-- (OLWDOY-dsy;OLWDOX-dsx)	SWAP.W	D2	SUB.W	D2,D4	SWAP.W	D4			; D4 <-- (dsy;dsx)	SWAP.W	D2	SUB.W	D2,D4TEST.B	(A6)+OFLIO:#BIMROTJUMP,BS	29$				; D4 <-- coordonne destination				;   de haut en bas !!	LOAD.W	D4,(A6)+OPLANAV+OMWDOY		; D4 <-- OMWDOY+ddy-OOWDOY-OSWDOY	SWAP.W	D1	ADD.W	D4,D1			; +ddy	SUB.W	D4,(A6)+OPLANAV+OOWDOY	SUB.W	D4,(A6)+OPLANAV+OSWDOY	SWAP.W	D4	LOAD.W	D4,(A6)+OPLANAV+OOWDOX		; D4 <-- OOWDOX - D0(x)	SUB.W	D4,D0	LOAD.B	D1,#SETDOT	; mode;.IF	BUG;	CALL	DEBRASTER;.ELSE	GRA_	RASTER;.ENDIF25$:	LOAD.W	D4,(A6)+OPLANAV+OOWDOX	; dpassement  droite ?	ADD.W	D4,(A6)+OPLANAV+OSWDOX	COMP.W	D4,(A6)+OPLANAV+OMWDOX	JUMP,HS	28$		; oui ...	LOAD.W	D1,(A6)+OPLANAV+OOWDOX	; non, dcale  droite, Y stable	ADD.W	D1,(A6)+OPLANAV+OSWDOX	ADD.W	D1,#-OVERLAP	LOAD.W	(A6)+OPLANAV+OOWDOX,D1	JUMP	20$28$:				; oui, dpassement  droite, tester si	LOAD.W	D4,(A6)+OPLANAV+OOWDOY	; dpassement en haut ?	ADD.W	D4,(A6)+OPLANAV+OSWDOY	COMP.W	D4,(A6)+OPLANAV+OMWDOY	JUMP,HS	30$		; oui --> l'image est construit	LOAD.W	(A6)+OPLANAV+OOWDOX,D0	; non, dcale en haut, dbut X	LOAD.W	D1,(A6)+OPLANAV+OOWDOY	ADD.W	D1,(A6)+OPLANAV+OSWDOY	ADD.W	D1,#-OVERLAPand.w	d1,#B'1111111111111000 ;  cause des TRAMES !!!	LOAD.W	(A6)+OPLANAV+OOWDOY,D1	JUMP	20$29$:			; D4 <-- coord. dest image tourne	LOAD.W	D4,(A6)+OPLANAV+OMWDOX	; D4 <-- Y'= OMWDOX-OOWDOX	SUB.W	D4,(A6)+OPLANAV+OOWDOXDEC.W	D4		; correction en Y31$:	SWAP.W	D4	LOAD.W	D4,(A6)+OPLANAV+OMWDOY	; D4 <-- X'= OMWDOY-OOWDOY+D2(y)	SUB.W	D4,(A6)+OPLANAV+OOWDOY	SWAP.W	D2	SUB.W	D4,D2	SWAP.W	D2.IF	BUGCALL	DEBRASTER.ELSE	CALL	ROTIMA.ENDIF	JUMP	25$30$:				; remet tat initial et ...	LOAD.B	D3,#AFSCMO		; raffiche flche	LIB	?AFCAR	CALL	INILLAST		; remet v. rf.dyn.	CALL	SCMO			; remet flche souris	CALL	IRETICULE		; remet le rticule	POP.B	(A6)+OFLMOD	POP.W	(A6)+OPAS	POP.W	(A6)+OPLANAV+OCOULEUR	POP.W	(A6)+OPLANAV+OSCALE	POP.L	(A6)+OPLANAV+OSWDOY	POP.L	(A6)+OPLANAV+OOWDOY	POP.L	(A6)+OPLANAV+OMWDOY	TCLR.B	(A6)+OFLMOD:#BSCROLL	; on avait enlevs les ascenseurs!	TEST.B	(A6)+OFLMOD:#BREGLE	; si enleves, alors remettre	JUMP,BC	35$	TCLR.B	(A6)+OFLMOD:#BREGLE	CALL	INVREGLE35$:				; image code	LOAD.L	A2,#(A6)+OBUIMA	; A2 ^entte .image	LOAD.L	A3,A4			; A3 ^image dcode	SUB.L	A4,#IMLBUF		; A4 ^image code	GRA_	CODEIMA	JUMP,EQ	40$	LOAD.L	A4,A3			; A4 ^image dcode si erreur40$:				; crit l'entte	LOAD.W	D6,(A6)+OCHIO		; D6 <-- canal	PUSH.L	A4	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?WRBYTE	POP.L	A4				; crit l'image	LOAD.L	D4,(A6)+OBUIMA+OIMNBB	; longueur de l'image	FOS	?WRBYTE;;;	.W	FOS,?CLOSE		; fait aprs le retour !	PUSH.W	D7	CALL	MAJCADRE	; ... raffiche	CALL	REFAIT					; rend la mmoire	LOAD.L	A4,A1	LOAD.W	D1,#MTYPCP		; A4 ^ mm.	GESMEM	?GIVMEM	POP.W	D790$:	TCLR.B	(A6)+OFLIO:#BIMROT	; remet flag rotation  zro	POPM.L	D0..D6,A0..A5	TEST.W	D7	RETCADREIM:; Cadre spcial. Contourne la routine MODASC qui force; l'origine  zro si tout est visible.; ATTENTION: jump dans CADRE de PLANMISC !!!;	PUSHM.L	D1..D4,A3,A5	TCLR.B	(A6)+OFLMOD:#BSCROLL	JUMP,BC	CADRE0	LOAD.W	D4,#+LGSCROLL	CALL	MDDASC	JUMP	CADRE0;--------- TESTROT:;---------;; tester si plus petit que OPRIX et OPRIY et signaler v. BIMROT;; in:	D3.L, D4.L	coordonnes zone;; out:	D2.L	(dy,dx) de la zone, mais au max. OMWDO..;	OFLIO:#BIMROT	=1 --> image tourne;	D7.W	si plus petit que page D7 <-- ERIMP;; mod:	D7.W	PUSHM.L	D3;;;;;	LOAD.W	D7,#ERIMPLOAD.W	D7,#-1	LOAD.L	D2,D4			; D2 <-- sup.-d.	SUB.W	D2,D3			; D2 <-- dx	COMP.W	D2,(A6)+OPLANAV+OMWDOX	JUMP,LS	10$	LOAD.W	D2,(A6)+OPLANAV+OMWDOX		; au max. OMWDOX10$:	SUB.W	D2,#8			;  cause de l'arrondi mm<-->pg					; ... tolrance de 8pg	SWAP.W	D2			; D2(dx, )	SWAP.W	D3	SUB.W	D2,D3			; D2(dx,dy)	SWAP.W	D3	COMP.W	D2,(A6)+OPLANAV+OMWDOY	JUMP,LS	12$	LOAD.W	D2,(A6)+OPLANAV+OMWDOY		; au max. OMWDOY12$:	SUB.W	D2,#8			;  cause de l'arrondi mm<-->pg				; D2 (dx-8;dy-8)	COMP.W	D2,(A6)+OPRIY		; dy <= dim. page ?	JUMP,GT	50$			; non -->	SWAP.W	D2		; D2 (dy-8;dx-8)	COMP.W	D2,(A6)+OPRIX		; dx <= dim. page ?	JUMP,GT	40$	TCLR.B	(A6)+OFLIO:#BIMROT	CLR.W	D7	JUMP	80$40$:	SWAP.W	D2		; D2 (dx-8;dy-8)50$:	COMP.W	D2,(A6)+OPRIX;	JUMP,GT	90$JUMP,GT	70$	SWAP.W	D2	COMP.W	D2,(A6)+OPRIY;	JUMP,GT	90$JUMP,GT	80$;	SWAP.W	D2	TSET.B	(A6)+OFLIO:#BIMROT	CLR.W	D7;	JUMP	80$70$:	SWAP.W	D280$:			; correction +8	ADD.L	D2,#8*H'10000+890$:	POPM.L	D3	TEST.W	D7	RET;========= ROTIMA:;---------; transfre un cran en mmoire, tourn de 90 degrs;; in:	A2.L	^descripteur de la fenter;	D3.L	coord. cran (Y;X);;	D4.L	coord. mmoire (Y;X);	A4.L	^dbut mmoire image dcode;	D6.W	Iy mmoire;;	D2.L	hauteur/largeur cran (dy;dx);; out:	cran en mmoire, pnt. par pnt.;; mod:	D7.W	erreur;	PUSHM.L	D0..D6,A0,A1	EX.L	D3,D4		; D4 coord. cran, D3 coord. mmoire			; calculer A1 ^mmoire et D1 no. bit			; en fonction des coord. dest.	LOAD.L	A1,A4		; A1 <-- ^mmoire	LOAD.L	D1,D3		; D1 <-- coord.  mm.	SWAP.W	D1	MUL.WU	D1,D6		; D1 <-- (Y * Iy)	ADD.L	A1,D1		; A1 + (Ymm.*Iy)	LOAD.W	D1,D3		; D1 <-- coord. Xmm.	SWAP.W	D1	CLR.W	D1	SR.L	D1,#3		; (Xmm./8)	LOAD.W	D0,D1	SWAP.W	D1	AND.L	D1,#H'FFFF	ADD.L	A1,D1	LOAD.B	D1,#7	RL.W	D0,#3	SUB.B	D1,D0		; no. bit mmoire	GRA_	QXDOT		; A0 <-- ^byte cran, D0 <-- bit ds.cran	AND.B	D0,#B'00000111	; seulement 3 bits significatifs !!!!			; D2 <-- cran en bas  droite (X;Y)	ADD.W	D2,D4	SWAP.W	D2	SWAP.W	D4	ADD.W	D2,D4			; D4 <-- coord. spot sur cran (X;Y)	LOAD.L	D3,D4	;	commencer en haut  gauche			; D3 = cran en haut  gauche (X;Y)20$:	CALL	SCAN		; transfrer une ligne verticale21$:	ADD.L	D4,#H'10000	; inc Xcran	COMP.L	D4,D2		; limite droite ?	JUMP,HI	90$		; oui, FIN	SUB.L	A1,D6		; une ligne plus haute en mm.;;	DEC.B	D0		; bit cran suivant;;	JUMP,NC	20$		; ngatif ?;;	INC.L	A0		; oui, inc A0;;	LOAD.B	D0,#7		; D0:=7;;	JUMP	20$		; recommence	ADD.B	D0,(A6)+ONEPIX	JUMP,NS	30$	COMP.B	D0,#8	JUMP,HS	30$	JUMP	20$30$:	ADD.L	A0,(A6)+ODIX	LOAD.B	D0,(A6)+OLEPIX	JUMP	20$90$:	POPM.L	D0..D6,A0,A1	RET;------ SCAN:;------; descente du spot;; in	A0 ^byte cran;	D0 no. bit ds. byte cran;	D2 (Xmax;Ymax) en bas droite sur cran;	D4 coord. (X;Y) sur cran;;	A1 ^byte en mmoire;	D1 no. bit ds. byte mmoire;		PUSHM.L	D0,D1,D3,D4,A0,A120$:	LOAD.B	D3,(A0)	JUMP,EQ	25$	TEST.B	(A0):D0;;	TNOT.B	(A0):D0	JUMP',BC 25$		; non, suivant	TSET.B	(A1):D1		; oui, allume en mmoire25$:	INC.W	D4		; inc. Ycran	COMP.W	D4,D2		; limite basse ?	JUMP,GT	90$		; oui, remonte;;	ADD.L	A0,#128		; cran 1 plus bas	ADD.L	A0,(A6)+ODIY30$:	DEC.B	D1		; non, spot en mmoire  droite	JUMP,NC	20$		; max. ?	INC.L	A1		; oui, un byte plus loin ...	LOAD.B	D1,#7		; ... bit le plus  gauche	JUMP	20$90$:	POPM.L	D0,D1,D3,D4,A0,A1	RET;=======;========== IMAGE DE FOND;;;;;NAMSTRETCH:	.ASCIZ	"STRETCH"	; nom du module STRETCH		.EVEN;--------- IMAFOND:;---------;; libre mmoire et modules utiliss par image de fond;	PUSHM.L	D1,A4	LOAD.L	A4,(A6)+OMEMIM	COMP.W	A4,#0	JUMP,EQ	90$	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM			; rend mmoire image	CLR.L	(A6)+OMEMIM		; pointeur  zro	LOAD.L	A4,(A6)+OMEMFOND	COMP.L	A4,#0	JUMP,EQ	90$	GESMEM	?GIVMEM			; rend mmoire cran (image stretch)	CLR.L	(A6)+OMEMFOND;;;;;	LOAD.W	D1,(A6)+OCHSTRETCH;;;;;	JUMP,EQ	90$;;;;;	LIB_	CLOSE			; ferme le module STRETCH90$:	POPM.L	D1,A4	RET;---------- IINPUT:;----------;; charge une image utilise comme fond; pour repiquer des images scannes;;	PUSHM.L	D0..D6,A0..A4	LOAD.L	A4,(A6)+OMEMIM		; libre v. mmoire image	COMP.L	A4,#0	JUMP,EQ	00$	CALL	IMAFOND			; libre mmoire etc.	CALL	RELLAST	CALL	EFFACE	CALL	REFAIT	CALL	INILLAST	JUMP	90$00$:	LOAD.L	A3,#(A6)+OBUTEMP	; ^nom  diter	CLR.B	(A3)			; buffer vide01$:	LOAD.L	A4,#R16"TXIMAGE		; ^extension	CALL	DBOXEDITI	JUMP,NE	90$	COMP.W	D3,#F1	JUMP,NE	90$			; retour	CALL	CWMO	CALL	SRMO					; A3 ^nom avec extension	LOAD.W	D3,#2^BOPRD		; D3 <-- mode "lecture"	LOAD.L	D0,#FOS?OPEN		; ouvre image	CALL	ERCALL	JUMP,NE	01$	LOAD.L	A4,#(A6)+OBUIMF		; A4 <-- ^buffer pour entte	LOAD.L	D4,#LGHIMA		; D4 <-- lg entte image	FOS	?RDBYTE			; lit entte image	JUMP,NE	90$	COMP.B	(A4)+0,#H'82		; commence par entte binaire	JUMP,NE	20$			; non => 20$					; oui	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS			; saute l'entte binaire	JUMP,NE	90$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE			; lit l'entte de l'image	JUMP,NE	90$20$:	LOAD.L	A2,A4			; A2 <-- ^entte de l'image	LOAD.W	D4,(A2)+OIMDLX	MUL.WU	D4,(A2)+OIMDLY;ADD.W	D4,(A2)+OIMDLX	SR.L	D4,#3			; D4 <-- longueur pour l'image	ADD.L	D4,#IMLBUF		; D4 <-- rserve pour codage	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM			; demande mmoire pour l'image	JUMP,NE	90$	LOAD.L	A1,A4			; A1 ^zone mmoire	LOAD.L	A4,#(A4)+IMLBUF			; lit toute l'image et dcode v.	TEST.B	(A2)+OIMCOD		; image code ?	JUMP,NE	50$			; oui => 50$					; non	LOAD.L	D4,(A2)+OIMNBB	FOS	?RDBYTE			; lit toute l'image dcode	JUMP,NE	90$	JUMP	60$50$:	LOAD.L	A3,A4	LOAD.L	A4,#(A4)-IMLBUF	LOAD.L	D4,(A2)+OIMNBB	FOS	?RDBYTE			; lit toute l'image code	JUMP,NE	90$	GRA_	DECOIMA			; dcode l'image	JUMP,NE	90$60$:	FOS	?CLOSE	JUMP,NE	90$	LOAD.L	(A6)+OMEMIM,A1		; mmorise pointeur  l'image	LOAD.W	(A6)+OIMLX,(A2)+OIMDLX	; mmorise dim. en X	LOAD.W	(A6)+OIMLY,(A2)+OIMDLY	; mmorise dim. en X	LOAD.W	D4,(A6)+OPLANAV+ODWDOX	; mmoire pour ST_RECT	MUL.WU	D4,(A6)+OPLANAV+ODWDOY	SR.L	D4,#3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE	65$	LOAD.L	(A6)+OMEMFOND,A4;;;;;	LOAD.l	A3,#R16"NAMSTRETCH	; module STRETCH;;;;;	LOAD.W	D3,#ST_FIRST;;;;;	LIB_	OPEN;;;;;	JUMP,NE	65$;;;;;	LOAD.W	(A6)+OCHSTRETCH,D1	JUMP	70$65$:	CALL	IMAFOND70$:	CALL	AFFIMAGE		; affiche l'image	tclr.b	(a6)+OFLMOD:#BIMAFOND90$:	PUSH.W	D7	CALL	CRMO	POP.W	D7	POPM.L	D0..D6,A0..A4	TEST.W	D7	RET;--------- AFFIMAGE:;---------;; affiche l'image  l'origine du PLAN; in	-; out	-; mod	D7.W;	PUSHM.L	D0..D5,A0..A4	LOAD.L	A3,(A6)+OMEMIM		; A3 ^mmoire avec l'image	LOAD.L	A3,#(A3)+IMLBUF		; A3 ^l'image	LOAD.L	A2,(A6)+OPLANAV+OPDDIS	; A2 ^description de la fentre	LOAD.W	D5,(A6)+OIMLX		; D5 <-- Iy source	SR.W	D5,#3	LOAD.L	A4,#0			; dest. cran	LOAD.B	D1,#SETDOT		; opration				; D2 <-- hauteur / largeur	LOAD.L	D2,(A6)+OIMLY		; D2(y;x) <-- (OIMLY;OIMLX)	COMP.W	D2,(A6)+OPLANAV+OMWDOX	; OIMLX <= OMWDOX, au max. dim. PLAN	JUMP,LS	10$	LOAD.W	D2,(A6)+OPLANAV+OMWDOX10$:	SUB.W	D2,(A6)+OPLANAV+OOWDOX	; OIMLX - OOWDOX	JUMP,NS	90$			; hors de l'image	JUMP,ZS	90$	COMP.W	D2,(A6)+OPLANAV+OSWDOX	JUMP,LS	12$	LOAD.W	D2,(A6)+OPLANAV+OSWDOX12$:	SWAP.W	D2			; D2(x;y)	COMP.W	D2,(A6)+OPLANAV+OMWDOY	; OIMLY =< OMWDOY, au max. dim. PLAN	JUMP,LS	15$	LOAD.W	D2,(A6)+OPLANAV+OMWDOY15$:	SUB.W	D2,(A6)+OPLANAV+OOWDOY	; OIMLY - OOWDOY	JUMP,NS	90$			; hors de l'image	JUMP,ZS	90$	LOAD.W	D3,D2			; D3 <-- (OIMLY - OOWDOY) ...	COMP.W	D2,(A6)+OPLANAV+OSWDOY	JUMP,LS	17$	LOAD.W	D2,(A6)+OPLANAV+OSWDOY17$:				; D4 <-- coord. dest.	CLR.L	D4			; D4(y;x) <-- 0				; D3 <-- coord. source Y	SUB.W	D3,(A6)+OPLANAV+OSWDOY	; ... - OSWDOY	JUMP,NC	50$	NEG.W	D3	ADD.W	D4,D3			; si ng. alors gale coord. dest. Y	SWAP.W	D4	CLR.W	D3			;  et source Y = 050$:;;;	SWAP.W	D2			: D2(y;x) haut./larg.;;;	SWAP.W	D4			; D4(y;x) destination	SWAP.W	D3			; D3(y; ) source	LOAD.W	D3,(A6)+OPLANAV+OOWDOX	; D3( ,x) = OOWDOX	TEST.W	(A6)+OPLANAV+OSCALE	; chelle 1:1 ?	JUMP,NE	60$			; non, => stretch	ADD.W	D4,(A6)+OPLANAV+OMINX		; oui, ajuste coord. dest. pour RASTER	SWAP.W	D4	ADD.W	D4,(A6)+OPLANAV+OMINY	SWAP.W	D4	SWAP.W	D2			; D2(y;x)	JUMP	80$60$:	LOAD.L	A0,#(A6)+OBUIMF	; A0 ^ table param. transformation	LOAD.W	(A0)+OSTRTYP,#0		; init  zro	LOAD.W	(A0)+OSTROP,#0	LOAD.L	(A0)+OSTRSPT,A3		; ^matrice source	LOAD.W	(A0)+OSTRSDX,D5		; Iy source	LOAD.L	(A0)+OSTRS0,D3		; S0(y;x)	LOAD.L	(A0)+OSTRS2,D3		; S0(y;x)	ADD.W	(A0)+OSTRS2,D2	; +Y	SWAP.W	D2			; D2(y;x)	ADD.W	(A0)+OSTRS2+2,D2	; S2(y;x) = S0(y;x) +X	LOAD.L	A3,(A6)+OMEMFOND	; A3 ^matrice de dest.	LOAD.L	(A0)+OSTRDPT,A3		; ^matrice de dest.	LOAD.W	D0,(A6)+OPLANAV+OLWDOX	SR.W	D0,#3	LOAD.W	(A0)+OSTRDDX,D0	; Iy matrice de dest.	MUL.WU	D0,(A6)+OPLANAV+OLWDOY70$:	CLR.B	(A3+)			; efface destination	DEC.L	D0	JUMP,NE	70$;	SWAP.W	D4			; D4(y;x)	PLANA_	D4SCALE	LOAD.L	(A0)+OSTRD0,D4	LOAD.L	(A0)+OSTRD1,D4	LOAD.L	(A0)+OSTRD2,D4	LOAD.L	(A0)+OSTRD3,D4	LOAD.L	D4,D2	PLANA_	D4SCALE	LOAD.W	(A0)+OSTRD3,(A6)+OPLANAV+OLWDOY	LOAD.W	(A0)+OSTRD2,(A6)+OPLANAV+OLWDOYDEC.W	(A0)+OSTRD2DEC.W	(A0)+OSTRD3	COMP.W	D4,(A6)+OPLANAV+OLWDOX	JUMP,LS	75$	LOAD.W	D4,(A6)+OPLANAV+OLWDOX75$:	ADD.W	(A0)+OSTRD1+2,D4	; +X larg.	ADD.W	(A0)+OSTRD2+2,D4	; +X larg.	ST_	RECT			; STRETCH	JUMP,NE	90$	CLR.L	D3	LOAD.L	A3,(A0)+OSTRDPT	LOAD.L	A3,(A6)+OMEMFOND	LOAD.W	D5,(A0)+OSTRDDX	LOAD.L	D4,(A6)+OPLANAV+OMINY		; destination	LOAD.L	D2,(A6)+OPLANAV+OLWDOY80$:	CALL	CCMO	GRA_	RASTER			; RASTER	CALL	SCMO90$:	POPM.L	D0..D5,A0..A4	RET;============ fin image de fond.IF	BUGDEBRASTER:	PUSHM.L	D0..D4	LOAD.L	D0,D3	LOAD.L	D1,D4	LOAD.L	D3,(A6)+OPLANAV+OMINY	LIB	?SETCURS	LIB	?AFTIM	.ASCIZE	"D3 coord. source X/Y :   "	LOAD.L	D4,D0	CALL	AFFQQCH	LIB	?AFTIM	.ASCIZE	"D4 coord. destin.X/Y :   "	LOAD.L	D4,D1	CALL	AFFQQCH	LIB	?AFTIM	.ASCIZE	"D2 hauteur / largeur :   "	LOAD.L	D4,D2	CALL	AFFQQCH	LIB	?AFTIM	.ASCIZE	"D6 Iy destination    :   "	LOAD.L	D4,D6	SWAP.W	D4	CLR.W	D4	SWAP.W	D4	CALL	AFFQQCH	LIB	?AFTIM	.ASCIZE	"image  haut./largeur  :  "	LOAD.L	D4,(A6)+OBUIMA+OIMDLX	CALL	AFFQQCH	LIB	?AFTIM	.ASCIZE	"nombre de bytes pour image : "	LOAD.L	D4,(A6)+OBUIMA+OIMNBB	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDALL	LIB	?AFDEC	LIB	?AFCR	LIB	?AFTIM	.ASCIZE	"fentre en  X/Y  :   "	LOAD.L	D4,(A6)+OPLANAV+OOWDOY	CALL	AFFQQCH	LIB	?GETCAR	POPM.L	D0..D4	RETAFFQQCH:	PUSHM.L	D0..D4	LOAD.L	D0,D4	CLR.L	D4	LOAD.W	D4,D0	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDALL	LIB	?AFDEC	LIB	?AFTIM	.ASCIZE	" / "	LOAD.L	D4,D0	CLR.W	D4	SWAP.W	D4	LIB	?AFDEC	LIB	?AFCR	POPM.L	D0..D4	RET.ENDIF	.END