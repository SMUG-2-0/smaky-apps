		.SBTTL	PLANMISC	; 18 aot 87 Sp.PA1Y	=	7PA2Y	=	15;--------\; CHGPAS  >;========/; Change le pas et met  jour la grille dans la fentre.; in	D3.W	nouveau pas; out	EQ	ok;	NE	faut tout redessiner; mod	D7.WCHGPAS:	PUSH.L	D4	CLR.W	D7		; D7 <-- dessin ok	COMP.W	D3,(A6)+OPAS	; nouveau pas ?	JUMP',EQ 90$		; non => 90$				; oui =>	TEST.B	(A6)+OPLANAV+OFLAGS:#BGRILLE	JUMP',BC 20$	CALL	GRILLE		; efface grille provisoirement20$:	LOAD.W	(A6)+OPAS,D3	; change le pas30$:	COMP.W	(A6)+OPAS,#0	JUMP,NE	35$	TCLR.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS	JUMP	40$35$:	TSET.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS40$:	TEST.B	(A6)+OPLANAV+OFLAGS:#BGRILLE	JUMP',BC 50$	CALL	GRILLE		; refait la grille50$:	CLR.W	D7		; D7 <-- dessin ok	LOAD.L	D4,(A6)+OPLANAV+OOWDOY	CALL	AJOWDO		; ajuste OOWDOX,YCALL	AFMENU	COMP.L	D4,(A6)+OPLANAV+OOWDOY	; origines modifies ?	JUMP',EQ 90$		; non => 90$	LOAD.W	D7,#1		; D7 <-- faut tout redessiner90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\; ARRONDI >;========/; Arrondi une coordonne Y;X selon le pas.; in	D4.L	coordonne Y;X; out	D4.L	coordonne arrondie; mod	D4.LARRONDI:	PUSHM.L	D0,D3,D7	LOAD.L	D0,D4		; D0 <-- Y;X initial	TEST.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS	; PAS actif ?	JUMP,BC	80$	CALL	XARRONDI	; arrondi X	SWAP.W	D0	CALL	XARRONDI	; arrondi Y	SWAP.W	D080$:	LOAD.L	D4,D0		; D4 <-- Y;X arrondi90$:	POPM.L	D0,D3,D7	RET;---------\; XARRONDI >;=========/; Arrondi une coordonne unique X ou Y.; in	D0.W	coordonne  arrondir; out	D0.W	idem, mais arrondi; mod	D0.WXARRONDI:	PUSHM.L	D1,D2,D3	CALL	PASREEL		; D1 <-- pas rel	COMP.B	D1,#1		; pas "nul" ?	JUMP',EQ 90$		; oui => 90$	LOAD.W	D2,D1	SR.W	D2,#1		; D2 <-- 1/2 pas	ADD.W	D0,D2		; avance de 1/2 pas	CLR.L	D3	LOAD.W	D3,D0		; D3 <-- X	DIV.WU	D3,D1		; D3 <-- X/pas	SWAP.W	D3		; D3 <-- reste division	SUB.W	D0,D3		; arrondi X90$:	POPM.L	D1,D2,D3	RET;---------\; OARRONDI >;=========/; Arrondi un offset Y;X positif ou ngatif selon le pas.; in	D4.L	offset Y;X; out	D4.L	offset arrondi; mod	D4.LOARRONDI:	PUSHM.L	D0,D1,D3	TEST.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS	; pas actif ?	JUMP,BC	90$		; non	CALL	PASREEL		; D1 <-- pas rel	COMP.B	D1,#1		; pas "nul" ?	JUMP,EQ	90$		; oui => 90$	CLR.B	D3		; D3 <-- "+"	TEST.W	D4		; valeur ngative ?	JUMP',NC 20$		; non => 20$	NEG.W	D4		; D4 <-- valeur absolue	INC.B	D3		; D3 <-- "-"20$:	CLR.L	D0	LOAD.W	D0,D4		; D0 <-- X	DIV.WU	D0,D1		; D0 <-- X/pas	SWAP.W	D0		; D0 <-- reste division	SUB.W	D4,D0		; arrondi X	DEC.B	D3		; valeur tait ngative ?	JUMP',NE 30$		; non => 30$	NEG.W	D4		; D4 <-- valeur ngative30$:	SWAP.W	D4	CLR.B	D3		; D3 <-- "+"	TEST.W	D4		; valeur ngative ?	JUMP',NC 50$		; non => 50$	NEG.W	D4		; D4 <-- valeur absolue	INC.B	D3		; D3 <-- "-"50$:	CLR.L	D0	LOAD.W	D0,D4		; D0 <-- Y	DIV.WU	D0,D1		; D0 <-- Y/pas	SWAP.W	D0		; D0 <-- reste division	SUB.W	D4,D0		; arrondi Y	DEC.B	D3		; valeur tait ngative ?	JUMP',NE 60$		; non => 60$	NEG.W	D4		; D4 <-- valeur ngative60$:	SWAP.W	D490$:	POPM.L	D0,D1,D3	RET;--------\; PASREEL >;========/; Donne la pas rel en fonction du pas choisi.; in	-; out	D1.W	pas rel; mod	D1.WPASREEL:	PUSH.L	A3	LOAD.L	A3,#R16"00$	LOAD.W	D1,(A6)+OPAS	; D1 <-- pas pour le dessin	LOAD.B	D1,(A3)+(D1.W)	; D1 <-- pas rel	POP.L	A3	RET00$:;	.B	1,2,4,8,16,32,30	; pas rels selon OPAS	.B	1,2,4,8,16,32	.B	3,6,12,24	.B	5,10,15,20,25,30	.EVEN;--------\; AFMENU  >;========/; Affiche le menu principal, et remet ventuellement les; barres ncessaires.; in	-; out	-; mod	D7.WAFMENU:	PUSHM.L	D3,A3	LOAD.L	A3,#R16"TMENU	; A3 <-- ^menu	LIB	?AFMENU		; affiche les soft-keys	TEST.B	(A6)+OPLANAV+OFLAGS:#BGRILLE	JUMP',BC 50$	LOAD.B	D3,#11	LIB	?SETBARRE	; signal mode "grille"50$:	TEST.B	(A6)+OFLMOD:#BREGLE	JUMP',BC 60$	LOAD.B	D3,#10	LIB	?SETBARRE	; signal mode "rgles"60$:	TEST.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS	; signal mode actif/inhib du PAS	JUMP,BC	90$	LOAD.B	D3,#12	LIB	?SETBARRE90$:	POPM.L	D3,A3	RET;---------\; AFDMENU  >;=========/; Affiche le menu dessin et dplacement, et remet ventuellement les; barres ncessaires.; in	-; out	-; mod	D7.WAFDMENU:	PUSHM.L	D3,A3	LOAD.L	A3,#R16"TDMENU	; A3 <-- ^menu	LIB	?AFMENU		; affiche les soft-keys60$:	TEST.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS	; signal mode actif/inhib du PAS	JUMP,BC	90$	LOAD.B	D3,#12	LIB	?SETBARRE90$:	POPM.L	D3,A3	RET;---------\; MAJCADRE >;=========/; Met  jour le cadre, si possible sans tout effacer, et; efface la surface de dessin.; A utiliser  la place de EFFACE !; in	-; out	-; mod	D7.WMAJCADRE:	PUSHM.L	D2..D5	LOAD.B	D4,(A6)+OFLMOD	CALL	MODASC		; met/enlve les ascenseurs	TEST.L	D4:#BSCROLL	JUMP',BS 10$	TEST.B	(A6)+OFLMOD:#BSCROLL	JUMP',BC 30$	JUMP'	20$10$:	TEST.B	(A6)+OFLMOD:#BSCROLL	JUMP',BS 30$20$:	CALL	EFFACE		; refait tout si ascenseurs modifis	JUMP	90$30$:	CALL	MAJASC		; met  jour les ascenseurs	TEST.B	(A6)+OFLMOD:#BREGLE	JUMP',BC 50$	LOAD.L	D5,(A6)+OLDPOR	; D5 <-- ancienne position	CALL	RELRG50$:	CALL	REGLE		; dessine les rgles	LOAD.L	D3,(A6)+OPLANAV+OMINY	LOAD.L	D4,(A6)+OPLANAV+OLWDOY	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LIB	?CREWDO		; cre swdo dans surface de dessin	LIB	?USEWDO		; utilise swdo	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface la surface de dessin	LOAD.W	D4,D5	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.W	D5,D4	LIB	?KILWDO		; dtruit swdo cre; Il faut encore effacer deux petites bandes en bas et  droite d'une; largeur d'un point, car le dessin des objets graphiques peut dpasser; OMAXX et OMAXY d'un point (voir le module GRA) !; Il n'est pas possible d'effacer ces deux bandes avec le EOP utilis; ci-dessus  cause des dimensions modulo 8 (en x) en modulo 2 (en y); des sous-fentres (c'est la vie)...	LOAD.W	D3,(A6)+OPLANAV+OMAXY	SWAP.W	D3	LOAD.W	D3,(A6)+OPLANAV+OMINX	CLR.L	D4	LOAD.W	D4,(A6)+OPLANAV+OLWDOX	INC.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRSEG		; efface p'tite bande horizontale en bas !	LOAD.W	D3,(A6)+OPLANAV+OMINY	SWAP.W	D3	LOAD.W	D3,(A6)+OPLANAV+OMAXX	LOAD.W	D4,(A6)+OPLANAV+OLWDOY	SWAP.W	D4	CLR.W	D4;	LOAD.W	D2,#CLRDOT	LIB	?DRSEG		; efface p'tite bande verticale  droite !	TCLR.B	(A6)+OFLRET:#BRETDE ; le rticule est effac	CALL	AFFINV		; mode inverse	CALL	INIHAUT		; init le haut de l'cran	CALL	INIBAS		; init le bas de l'cran;;;	CALL	INUZONE		; trame les zones inutiles	LOAD.W	(A6)+OPLANAV+OPLANA,#FINUZONE	.W	PLANA_FONC	TEST.B	(A6)+OPLANAV+OFLAGS:#BGRILLE	JUMP',BC 90$	CALL	GRILLE		; refait la grille90$:	POPM.L	D2..D5	RET;--------\; EFFACE  >;========/; Efface toute la fentre, et initialise compltement les; lignes en haut et en bas.; in	-; out	-; mod	D7.WEFFACE:	CALL	CADRE		; fait le cadre;;;	CALL	INUZONE	LOAD.W	(A6)+OPLANAV+OPLANA,#FINUZONE	.W	PLANA_FONC	CALL	INIHAUT		; init le haut de l'cran	CALL	INIBAS		; init le bas de l'cran	TEST.B	(A6)+OPLANAV+OFLAGS:#BGRILLE	JUMP',BC 90$	CALL	GRILLE		; refait la grille90$:	RET;---------\; MAJASC   >;=========/; Met  jour les ascenseurs, sans tout effacer.; in	-; out	-; mod	D7.WMAJASC:	PUSHM.L	D4,A5	TEST.B	(A6)+OFLMOD:#BSCROLL ; ascenseurs ?	JUMP',BC 90$		; non => 90$				; oui =>	LOAD.L	A5,#(A6)+OASCV	; A5 <-- ^variables ascenseur vertical	LOAD.W	D4,(A6)+OPLANAV+OMWDOY	SUB.W	D4,(A6)+OPLANAV+OSWDOY	JUMP',LE 80$	LOAD.W	(A5)+OSCHTV,D4	SUB.W	D4,(A6)+OPLANAV+OOWDOY	; coordonne Y dans l'autre sens !	LOAD.W	(A5)+OSCPOSV,D4	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur80$:	LOAD.L	A5,#(A6)+OASCH	; A5 <-- ^variables ascenseur horizontal	LOAD.W	D4,(A6)+OPLANAV+OMWDOX	SUB.W	D4,(A6)+OPLANAV+OSWDOX	JUMP',LE 90$	LOAD.W	(A5)+OSCHTV,D4	LOAD.W	(A5)+OSCPOSV,(A6)+OPLANAV+OOWDOX	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur90$:	POPM.L	D4,A5	RET;--------\; CADRE   >;========/; Efface toute la fentre, et met un cadre autour.; in	-; out	-; mod	D7.WCADRE:	PUSHM.L	D1..D4,A3,A5	CALL	MODASC		; met/enlve les ascenseursCADRE0:	LIB	?AFTIM	.B	EOP		; efface la fentre	.B	NOROLL		; pas de roll	.B	TRUNC		; tronque lignes trop longues	.B	NOEFLI		; n'efface pas les lignes	.B	NOCURS		; pas de curseur	.B	0	.EVEN	CALL	AFFINV		; mode inverse	TCLR.B	(A6)+OFLRET:#BRETDE ; le rticule est effac	CLR.W	D1	TEST.B	(A6)+OFLMOD:#BREGLE	JUMP',BC 10$	LOAD.W	D1,#LGREGLE10$:	TEST.B	(A6)+OFLMOD:#BICADRE	JUMP,BC 50$	LOAD.L	D3,#-1		; D3 <-- trame "pleine"	LOAD.L	D4,D3		; D4 <-- trame "pleine"	LIB	?DRMDEF		; dfinit la trame	LOAD.B	D2,#SETDOT	; D2 <-- <mode>	CLR.L	D3		; D3 <-- <xx> et <yy>	LOAD.W	D4,(A6)+OPLANAV+OMINY	; D4 <-- <dyy>	SUB.W	D4,D1	SWAP.W	D4	LOAD.W	D4,(A6)+OPLANAV+OWDOX	; D4 <-- <dxx>	LIB	?DRMATRIX	; surface suprieure	LOAD.W	D3,(A6)+OPLANAV+OMAXY	; D3 <-- <yy>	INC.W	D3	SWAP.W	D3	CLR.W	D3		; D3 <-- <xx>	LOAD.W	D4,(A6)+OPLANAV+OWDOY	SUB.W	D4,(A6)+OPLANAV+OMAXY	; D4 <-- <dyy>	DEC.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OPLANAV+OWDOX	; D4 <-- <dxx>	LIB	?DRMATRIX	; surface infrieure	LOAD.W	D3,(A6)+OPLANAV+OMINY	; D3 <-- <yy>	SUB.W	D3,D1	SWAP.W	D3	CLR.W	D3		; D3 <-- <xx>	LOAD.W	D4,(A6)+OPLANAV+OLWDOY	; D4 <-- <dyy>	ADD.W	D4,D1	INC.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OPLANAV+OMINX	; D4 <-- <dxx>	LIB	?DRMATRIX	; surface gauche	LOAD.W	D3,(A6)+OPLANAV+OMINY	; D3 <-- <yy>	SUB.W	D3,D1	SWAP.W	D3	LOAD.W	D3,(A6)+OPLANAV+OMAXX	ADD.W	D3,D1		; D3 <-- <xx>	INC.W	D3	LOAD.W	D4,(A6)+OPLANAV+OLWDOY	; D4 <-- <dyy>	ADD.W	D4,D1	INC.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OPLANAV+OWDOX	SUB.W	D4,(A6)+OPLANAV+OMAXX	SUB.W	D4,D1		; D4 <-- <dxx>	DEC.W	D4	LIB	?DRMATRIX	; surface droite	JUMP'	70$50$:	LOAD.W	D3,(A6)+OPLANAV+OMINY	SUB.W	D3,D1	DEC.W	D3	SWAP.W	D3	LOAD.W	D3,(A6)+OPLANAV+OMINX	DEC.W	D3	LOAD.L	D4,(A6)+OPLANAV+OMAXY	; D4 <-- coin inf/droite	ADD.W	D4,D1	INC.W	D4	SUB.W	D4,D3		; D4 <-- largeur	SWAP.W	D3	SWAP.W	D4	INC.W	D4	SUB.W	D4,D3		; D4 <-- hauteur	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	; D2 <-- mode	LIB	?DRRECT		; juste un rectangle70$:	CALL	REGLE		; dessine les rgles	TEST.B	(A6)+OFLMOD:#BSCROLL ; ascenseurs ?	JUMP,BC 90$		; non => 90$				; oui =>	LOAD.L	A5,#(A6)+OASCV	; A5 <-- ^variables ascenseur vertical	LOAD.W	D4,(A6)+OPLANAV+OMINY	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OPLANAV+OMINX	SUB.W	D4,#LGSCROLL	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OPLANAV+OLWDOY	ADD.W	D4,#1+2	LOAD.W	(A5)+OSCHTR,D4	CLR.B	(A5)+OSCHOR	CLR.B	(A5)+OSCPAGE	SCROLL_	DRAW		; dessine la cage de l'ascenseur	LOAD.W	D4,(A6)+OPLANAV+OMWDOY	SUB.W	D4,(A6)+OPLANAV+OSWDOY	JUMP',LE 80$	LOAD.W	(A5)+OSCHTV,D4	SUB.W	D4,(A6)+OPLANAV+OOWDOY	; coordonne Y dans l'autre sens !	LOAD.W	(A5)+OSCPOSV,D4	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur80$:	LOAD.L	A5,#(A6)+OASCH	; A5 <-- ^variables ascenseur horizontal	LOAD.W	D4,(A6)+OPLANAV+OMINX	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OPLANAV+OMAXY	INC.W	D4	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OPLANAV+OLWDOX	ADD.W	D4,#1+2	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCHOR	CLR.B	(A5)+OSCPAGE	SCROLL_	DRAW		; dessine la cage de l'ascenseur	LOAD.W	D4,(A6)+OPLANAV+OMWDOX	SUB.W	D4,(A6)+OPLANAV+OSWDOX	JUMP',LE 90$	LOAD.W	(A5)+OSCHTV,D4	LOAD.W	(A5)+OSCPOSV,(A6)+OPLANAV+OOWDOX	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur; ******** met un dessin  l'intersection des ascenseurs	LOAD.W	D3,(A5)+OSCDEBL	; Y	INC.W	D3	INC.W	D3	SWAP.W	D3	LOAD.W	D3,(A5)+OSCDEBO	; X	SUB.W	D3,#LGSCROLL-1	LOAD.L	D4,#(LGSCROLL-2-1)*H'10000+LGSCROLL-2-1	LOAD.B	D2,#INVDOT	LIB	?DRRECT		; grand rect.	ADD.L	D3,#8*H'10000+4	LOAD.L	D4,#-5*H'10000+7	LIB	?DRRECT		; petit rect.	CLR.L	D4	LOAD.W	D4,#-5	PUSH.L	D3	LIB	?DRSEG		; droite  gauche	POP.L	D3	LOAD.L	D4,#6*H'10000	; droite en bas	LIB	?DRSEG; ***** fin90$:	POPM.L	D1..D4,A3,A5	RET;--------\; INIHAUT >;========/; Initialise le haut de l'cran.; in	-; out	-; mod	D7.WINIHAUT:	PUSHM.L	D2,D3,D4,A3CALL	CARCAD	CALL	INIPLAN		; met "PLAN rev"	LOAD.W	D3,#11		; D3 <-- pos. aprs PLAN rev.	CALL	LPOSAX		; positionne dans ligne	PUSHM.L	D0	LIB	?AFTIM	.ASCIZE	/Or<'<>/	CALL	USEPAGC	LIB	?GETCURS	LOAD.L	D0,D3			; mmorise le curseur	SWAP.W	D3	LOAD.W	D3,#PA1Y	SWAP.W	D3	LIB	?SETCURS	; .....	LIB	?AFTIM	.ASCIZE	/X=/	LIB	?GETCURS	LOAD.L	(A6)+OPOSOX,D3	LOAD.W	D4,(A6)+OPLANAV+OOWDOX	CALL	AFFPARX	EX.L	D3,D0			; change le curseur	SWAP.W	D3	LOAD.W	D3,#PA2Y			; 2*hauteur+1 du NRF04	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZE	/Y=/	LIB	?GETCURS	LOAD.L	(A6)+OPOSOY,D3	LOAD.W	D4,(A6)+OPLANAV+OOWDOY	CALL	AFFPARY	EX.L	D3,D0	LIB	?SETCURS	; remet curseur	CALL	_USEDGC		; utilise genc normal	POPM.L	D0	CALL	POSPAR		; positionne pour paramtres	TEST.B	(A6)+OFLMOD:#BLAST	JUMP,BC	10$	LIB	?AFTIM	.ASCIZE	/Rd<'<>/	CALL	INILLAST	JUMP	11$10$:	LIB	?AFTIM	.ASCIZE	/Co<'<>/11$:	LIB	?GETCURS	SWAP.W	D3	LOAD.W	D3,#PA1Y	SWAP.W	D3	LOAD.L	(A6)+OPOSAX,D3	SWAP.W	D3	LOAD.W	D3,#PA2Y	SWAP.W	D3	LOAD.L	(A6)+OPOSAY,D3	LIB	?AFTIM	.ASCIZE	/....../	LIB	?AFTIM	.ASCIZE	/    /	LOAD.L	A3,#(A6)+OBUMEMF	TEST.B	(A3)		; fichier de travail existe ?	JUMP',EQ 50$		; non => 50$	CALL	AFFFILE		; oui => affiche le fichier de travail50$:	LIB	?AFTIM	.ASCIZ	"   "	.EVEN	LIB	?GETCURS	LOAD.L	(A6)+OPOSAF,D3	LIB	?AFTIM	.ASCIZ	"<MSPACE><50>"	.EVEN	CALL	INIFREECALL	CARPLAN	POPM.L	D2,D3,D4,A3	RET;--------\; INIPLAN >;========/; Initialise le haut de l'cran, et met juste PLAN rev; ou le nom du fichier de travail.; in	-; out	-; mod	D7.WINIPLAN:	PUSHM.L	D2,D3,D4,A3	CLR.L	D3	LIB	?SETCURS	; positionne en haut  gauche	LIB	?AFTIM	.B	NOCURS,SPACE,0	.EVEN	LIB	?AFTIM	.ASCIZ	"PLAN "	.EVEN	LOAD.L	A3,(A6)+OSTART	; A3 <-- ^fin entte binaire	CLR.L	D4	LOAD.B	D4,(A3)-256+OBXREV	LOAD.B	D3,#3	LOAD.B	D2,#2^BAFDCM	LIB	?AFDEC		; affiche no rvision	LOAD.B	D3,#'.	LIB	?AFCAR	LOAD.B	D4,(A3)-256+OBXVER	LOAD.B	D3,#2	LOAD.B	D2,#2^BAFDALL	LIB	?AFDEC		; affiche no version	LIB	?AFTIM	.B	MSPACE,16,0	; efface la fin	.EVEN	POPM.L	D2,D3,D4,A3	RET;--------\; INIFREE >;========/; Affiche le nombre d'objets restants.; in	-; out	-; mod	D7.WINIFREE:	PUSHM.L	D0,D1,D2,D3,D4CALL	CARCAD	LOAD.L	D3,(A6)+OPOSAF	LIB	?SETCURS;;?	.W	LIB,?AFTIM;;?	.ASCIZ	"Reste: ";;?	.EVEN;;?;;?	CLR.L	D4;;?	LOAD.W	D4,(A6)+ONBMEM	; D4 <-- nb total;;?	SUB.W	D4,(A6)+OUBMEM	; soustrait nb utiliss;;?	LOAD.B	D3,#5;;?	LOAD.B	D2,#2^BAFDCM;;?	.W	LIB,?AFDEC	; affiche place restante;;?	LOAD.L	D0,D4		; D0 <-- reste	CLR.L	D0	LOAD.W	D0,(A6)+OPLANAV+ONBMEM	; D0 <-- nb total	SUB.W	D0,(A6)+OPLANAV+OUBMEM	; D0 <-- soustrait nb utiliss	LIB	?AFTIM	.ASCIZ	"Utilis: "	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OPLANAV+OUBMEM	; D4 <-- nb utiliss	SUB.W	D4,#4		; toujours 4 utiliss !	LOAD.B	D3,#5	LOAD.B	D2,#2^BAFDCM	LIB	?AFDEC		; affiche taille dessin	LOAD.L	D1,D4		; D1 <-- utilis	LIB	?AFSPACE	ADD.L	D0,D1		; D0 <-- U+R, D1 <-- U	MUL.WU	D1,#100	DIV.WU	D1,D0		; D1 <-- (U*100)/(U+R)	CLR.L	D4	LOAD.W	D4,D1		; D4 <-- utilis en %	JUMP',EQ 60$		; si 0% => n'affiche rien !	LOAD.B	D3,#3		; D3 <-- 3 digits au maximum	LOAD.B	D2,#2^BAFDCM	; D2 <-- compact sans '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	"%"	.EVEN60$:	LIB	?AFTIM	.ASCIZ	"<MSPACE><10>"	.EVENCALL	CARPLAN	POPM.L	D0,D1,D2,D3,D4	RET; modif 4.7;--------\; INIBAS  >;========/; Initialise le bas de l'cran.; in	-; out	-; mod	D7.WINIBAS:	PUSHM.L	D1,D2,D3,D4,A3CALL	CARCAD	CALL	INILLAST;;;;;	TEST.B	(A6)+OPLANAV+OFLAGS:#BTEMP;;;;;	JUMP,BS	80$	LOAD.W	D3,#-1		; D3 <-- Y max	SWAP.W	D3	CLR.W	D3		; D3 <-- X min	LIB	?SETCURS	; positionne en bas  gauche	LIB	?AFSPACE	LOAD.W	D3,(A6)+OMMACRO	JUMP,ZS	10$	JUMP,NS	10$	LIB	?AFTIM	.ASCIZE	/Macro/	CALL	AFFDIR	LIB	?AFCODE	CALL	AFFINV	JUMP	11$10$:	LIB	?AFTIM	.ASCIZE	/Choix:/11$:	LIB	?AFTIM	.ASCIZE	/| /	CALL	AFTOBJ		; affiche l'objet	LOAD.W	D3,(A6)+OTRAIT	CALL	_AFTRAIT	; affiche le trait	LIB	?AFTIM	.ASCIZ	"| "		; couleur	.EVEN	LOAD.L	A3,#R16"MMCOULEUR	; provisoire, modifier AFNTEXT !!!	LOAD.W	D3,(A6)+OMODE	; D3 <-- mode/couleur	SR.B	D3,#4		; D3 <-- couleur	INC.B	D3		; D3 <-- saute la case vide	CALL	AFNTEXT		; affiche la couleur	LIB	?AFTIM	.ASCIZ	"|"		; mode	.EVEN	LOAD.L	A3,#R16"MMODE	LOAD.W	D3,(A6)+OMODE	; D3 <-- mode/couleur	AND.B	D3,#H'0F	; D3 <-- mode	INC.B	D3		; D3 <-- saute la case vide	CALL	AFNTEXT		; affiche le mode	LIB	?AFTIM	.ASCIZ	"|  Pas="	.EVEN	CALL	PASREEL		; D1 <-- pas rel	CLR.L	D4	LOAD.B	D4,D1	LOAD.B	D3,#2;	LOAD.B	D2,#2^BAFDCMLOAD.B	D2,#0	LIB	?AFDEC		; affiche le pas	LIB	?AFTIM	.ASCIZ	"  Loupe="	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OPLANAV+OSCALE	JUMP',NS 40$	JUMP',NE 42$	INC.W	D4		; D4 <-- 1	JUMP'	42$40$:	NEG.W	D4		; D4 <-- 2..n	LIB	?AFTIM	.ASCIZ	"1:"		; si ngatif => 1:n	.EVEN42$:;	LOAD.B	D3,#3		; max 1/999 ou 999;	LOAD.B	D2,#2^BAFDCMLOAD.B	D3,#2LOAD.B	D2,#0	LIB	?AFDEC		; affiche l'chelle	TEST.W	(A6)+OPLANAV+OSCALE	JUMP',NS 44$	LIB	?AFTIM	.ASCIZ	":1"		; si positif => n:1	.EVEN44$:LIB	?GETCURSLOAD.W	D3,#65*8LIB	?SETCURS	LIB	?AFTIM;	.ASCIZ	"  Genc=";	.EVEN.ASCIZE	/  Genc=/	CALL	_AFFGC		; affiche le gencar pour texte	LIB	?AFTIM	.B	MSPACE,50	; efface la fin de la ligne	.B	NOCURS		; plus de curseur	.B	0	.EVEN	JUMP'	90$80$:	CALL	AFCMES		; affiche centr	.ASCIZ	"*** traits d'esquisse (seulement  l'cran) ***"	.EVEN90$:CALL	CARPLAN	POPM.L	D1,D2,D3,D4,A3	RET; anciennne version !;--------\; INIBAS  >;========/;; Initialise le bas de l'cran.;; in	-; out	-; mod	D7.W;;INIBAS:;	PUSHM.L	D1,D2,D3,D4,A3;;	TEST.B	(A6)+OPLANAV+OFLAGS:#BTEMP;	JUMP,BS	80$;;	LOAD.W	D3,#-1		; D3 <-- Y max;	SWAP.W	D3;	CLR.W	D3		; D3 <-- X min;	.W	LIB,?SETCURS	; positionne en bas  gauche;	.W	LIB,?AFSPACE;;	.W	LIB,?AFTIM;	.ASCIZ	"Objet=";	.EVEN;	CALL	AFTOBJ		; affiche l'objet;;	LOAD.W	D3,(A6)+OTRAIT;	CALL	_AFTRAIT	; affiche le trait;;	.W	LIB,?AFTIM;	.ASCIZ	"  Mode=";	.EVEN;	LOAD.L	A3,#R16"MMODE;	LOAD.W	D3,(A6)+OMODE	; D3 <-- mode/couleur;	AND.B	D3,#H'0F	; D3 <-- mode;	INC.B	D3		; D3 <-- saute la case vide;	CALL	AFNTEXT		; affiche le mode;;	.W	LIB,?AFTIM;	.ASCIZ	"  Pas=";	.EVEN;	CALL	PASREEL		; D1 <-- pas rel;	CLR.L	D4;	LOAD.B	D4,D1;	LOAD.B	D3,#2;	LOAD.B	D2,#2^BAFDCM;	.W	LIB,?AFDEC	; affiche le pas;;	.W	LIB,?AFTIM;	.ASCIZ	"  Echelle=";	.EVEN;	CLR.L	D4;	LOAD.W	D4,(A6)+OPLANAV+OSCALE;	JUMP',NS 40$;	JUMP',NE 42$;	INC.W	D4		; D4 <-- 1;	JUMP'	42$;40$:;	NEG.W	D4		; D4 <-- 2..n;	.W	LIB,?AFTIM;	.ASCIZ	"1:"		; si ngatif => 1:n;	.EVEN;42$:;	LOAD.B	D3,#2		; max 1/99 ou 99;	LOAD.B	D2,#2^BAFDCM;	.W	LIB,?AFDEC	; affiche l'chelle;	TEST.W	(A6)+OPLANAV+OSCALE;	JUMP',NS 44$;	.W	LIB,?AFTIM;	.ASCIZ	":1"		; si positif => n:1;	.EVEN;44$:;	.W	LIB,?AFTIM;	.ASCIZ	"  Gencar=";	.EVEN;	CALL	_AFFGC		; affiche le gencar pour texte;;	.W	LIB,?AFTIM;	.ASCIZ	"  Couleur=";	.EVEN;	LOAD.L	A3,#R16"MCOULEUR;	LOAD.W	D3,(A6)+OMODE	; D3 <-- mode/couleur;	SR.B	D3,#4		; D3 <-- couleur;	INC.B	D3		; D3 <-- saute la case vide;	CALL	AFNTEXT		; affiche la couleur;;	.W	LIB,?AFTIM;	.B	MSPACE,50	; efface la fin de la ligne;	.B	NOCURS		; plus de curseur;	.B	0;	.EVEN;	JUMP'	90$;;80$:;	CALL	AFCMES		; affiche centr;	.ASCIZ	"*** traits de constructions ***";	.EVEN;90$:;	POPM.L	D1,D2,D3,D4,A3;	RET; Sp.;--------\; AFTOBJ  >;--------/; Affiche l'objet slectionn.; in	-; out	-; mod	D7.WAFTOBJ:	PUSHM.L	D3,A3	LOAD.W	D3,(A6)+OOBJET	; D3 <-- objet courant	COMP.B	D3,#OBJSURF	JUMP',EQ 40$	COMP.B	D3,#OBJTEXT	JUMP',EQ 50$	COMP.B	D3,#OBJARC	JUMP',EQ 60$	COMP.B	D3,#OBJARCELL	JUMP',EQ 70$	COMP.B	D3,#OBJRECT	JUMP,EQ	80$	LOAD.L	A3,#R16"NOBJET	CALL	AFNTEXT		; affiche l'objet	COMP.B	D3,#OBJFILL	; objet "rempli" ?	JUMP',NE 90$		; non => 90$40$:				; surface =>	CALL	_AFTRAME	; affiche le type de trame	JUMP'	90$50$:				; texte  =>	CALL	_AFFGC		; affiche le gencar	JUMP'	90$60$:				; arc de cercle =>	LOAD.L	A3,#R16"MARC	LOAD.W	D3,(A6)+OARC	INC.B	D3		; D3 <-- saute la case vide	CALL	AFNTEXT		; affiche le type d'arc	JUMP'	90$70$:				; arc d'ellipse =>	LOAD.L	A3,#R16"MARC	LOAD.W	D3,(A6)+OARC	ADD.B	D3,#1+4		; D3 <-- saute case vide + arcs de cercle	CALL	AFNTEXT		; affiche le type d'arc	JUMP'	90$80$:				; rectangle =>	LOAD.L	A3,#R16"MRECT	LOAD.W	D3,(A6)+ORRECT	SR.W	D3,#2		; D3 <-- 0..4 <= 0,4,8,12,16	INC.W	D3		; D3 <-- saute case vide	CALL	AFNTEXT		; affiche le type d'arc;	JUMP'	90$90$:	POPM.L	D3,A3	RET;--------\; AFOBJET >;========/; Affiche un objet sous forme d'une ligne de texte.; in	D0..D4	objet; out	-; mod	D7.WAFOBJET:	PUSHM.L	D2..D6,A3CALL	CARCAD	LOAD.L	D5,D3	LOAD.L	D6,D4	LIB	?AFTIM	.ASCIZ	"Trouv:| "	.EVEN	COMP.B	D0,#OBJSURF	JUMP,EQ	20$	COMP.B	D0,#OBJDUGROUPE	JUMP,EQ	80$	COMP.B	D0,#OBJDSGROUPE	JUMP,EQ	80$	LOAD.L	A3,#R16"NOBJET	LOAD.W	D3,D0	CALL	AFNTEXT		; affiche l'objet	LIB	?AFTIM	.ASCIZE	/|/	COMP.B	D0,#OBJTEXT	JUMP',EQ 30$	LOAD.W	D3,D1	CALL	_AFTRAIT	; affiche le trait	LIB	?AFTIM	.ASCIZ	/ |/	.EVEN	JUMP	30$20$:				; surface =>	PUSH.W	(A6)+OTRAME	LOAD.W	(A6)+OTRAME,D1	CALL	_AFTRAME	; affiche le type de trame	POP.W	(A6)+OTRAME	LIB	?AFTIM	.ASCIZ	/ |/	.EVEN30$:	LOAD.L	A3,#R16"MMCOULEUR	; provisoire, modifier AFNTEXT !!!	LOAD.B	D3,D2		; D3 <-- mode/couleur	SR.B	D3,#4		; D3 <-- couleur	INC.B	D3		; D3 <-- saute la case vide	CALL	AFNTEXT		; affiche la couleur	LIB	?AFTIM	.ASCIZ	/|/	.EVEN	LOAD.L	A3,#R16"MMODE	LOAD.B	D3,D2		; D3 <-- mode/couleur	AND.B	D3,#H'0F	; D3 <-- mode	INC.B	D3		; D3 <-- saute la case vide	CALL	AFNTEXT		; affiche le mode	LIB	?AFTIM	.ASCIZE	/|  P1<'<>/	CALL	USEPAGC	LIB	?GETCURS	PUSH.L	D3	SUB.L	D3,#(PA1Y-1)*H'10000	LIB	?SETCURS	LIB	?AFTIM	.ASCIZE	/X=/	CLR.L	D4	LOAD.W	D4,D6	CALL	AFFPARX	POP.L	D3	ADD.L	D3,#1*H'10000	LIB	?SETCURS	LIB	?AFTIM	.ASCIZE	/Y=/	LOAD.L	D4,D6	CLR.W	D4	SWAP.W	D4	CALL	AFFPARY	LIB	?GETCURS	SUB.L	D3,#1*H'10000	LIB	?SETCURS	CALL	_USEDGC	COMP.B	D0,#OBJCERCLE	JUMP,EQ 60$	COMP.B	D0,#OBJARC	JUMP,EQ 60$	COMP.B	D0,#OBJELLIPSE	JUMP,EQ 65$	COMP.B	D0,#OBJARCELL	JUMP,EQ 65$	COMP.B	D0,#OBJTEXT	JUMP,NE	70$				; caractre =>	LIB	?AFTIM	.ASCIZ	"  Car= "	.EVEN	LOAD.B	D3,D5	LIB	?AFCODE	LIB	?AFTIM	.ASCIZE	/  Genc=/	CALL	AFFGCP	JUMP	90$60$:				; cercle et arc de cercle =>	LIB	?AFTIM	.ASCIZ	"  R="	.EVEN	CLR.L	D4	LOAD.W	D4,D5	CALL	AFFPARX	JUMP	90$65$:	LIB	?AFTIM	.ASCIZE	"  R<'<>"	JUMP'	72$70$:	LIB	?AFTIM	.ASCIZE	/  P2<'<>/72$:	CLR.L	D4	LOAD.W	D4,D5	CALL	USEPAGC	LIB	?GETCURS	PUSH.L	D3	SUB.L	D3,#(PA1Y-1)*H'10000	LIB	?SETCURS	LIB	?AFTIM	.ASCIZE	/X=/	CALL	AFFPARX	POP.L	D3	ADD.L	D3,#1*H'10000	LIB	?SETCURS	LIB	?AFTIM	.ASCIZE	/Y=/	LOAD.L	D4,D5	CLR.W	D4	SWAP.W	D4	CALL	AFFPARY	LIB	?GETCURS	SUB.L	D3,#1*H'10000	LIB	?SETCURS	CALL	_USEDGC	JUMP'	90$80$:				; dbut d'un groupe =>	LIB	?AFTIM	.ASCIZ	" groupe "	.EVEN	LOAD.L	A3,#R16"MGROUPE	LOAD.W	D2,#1		; D2 <-- groupe utilisateur	COMP.B	D0,#OBJDUGROUPE	JUMP',EQ 85$	LOAD.W	D2,#3		; D2 <-- groupe systme85$:	LOAD.W	D3,D2		; D3 <-- rang de l'icne	CALL	AFNTEXT		; affiche l'objet90$:CALL	CARPLAN	POPM.L	D2..D6,A3	RET;------- AFFGCP:;-------;; affiche un genc physique;; in	D5.L	"fst-"; out	-; mod	-;	PUSHM.L	D2..D5	LOAD.L	D3,D5	SWAP.W	D3	SR.L	D3,#8		; fonte	AND.B	D3,#H'7F	LIB	?AFCODE	TEST.L	D5:#31		; laser ? f bit 2^7=0	JUMP,BS	30$		; non => 30$	LOAD.L	D3,D5		; oui, genc laser XYZnn	SWAP.W	D3		; <-- .B = s	TCLR.L	D3:#7	LIB	?AFCODE	LOAD.B	D3,#'F	TEST.L	D5:#23	JUMP,BS	10$	LOAD.B	D3,#'P10$:	LIB	?AFCODE	JUMP	50$30$:				; genc matriciel X(yz)nn	LIB	?AFTIM	.ASCIZE	/(/	TEST.L	D5:#BGCBOLD+16	JUMP,BC	41$	LIB	?AFTIM	.ASCIZE	/b/41$:	TEST.L	D5:#BGCITAL+16	JUMP,BC	42$	LIB	?AFTIM	.ASCIZE	/i/42$:	TEST.L	D5:#BGCOUTL+16	JUMP,BC	43$	LIB	?AFTIM	.ASCIZE	/o/43$:	TEST.L	D5:#BGCSHAD+16	JUMP,BC	44$	LIB	?AFTIM	.ASCIZE	/s/44$:	TEST.L	D5:#BGCLARG+16	JUMP,BC	45$	LIB	?AFTIM	.ASCIZE	/l/45$:	TEST.L	D5:#BGCFIX+16	JUMP,BC	46$	LIB	?AFTIM	.ASCIZE	/f/	JUMP	47$46$:	LIB	?AFTIM	.ASCIZE	/p/47$:	LIB	?AFTIM	.ASCIZE	/)/50$:	LOAD.L	D3,D5	SR.W	D3,#8	CLR.L	D4	LOAD.W	D4,D3	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDALL	LIB	?AFDEC	POPM.L	D2..D5	RET;--------\; INIXY   >;========/; Initialise le haut de l'cran pour affichier X= et Y=.; in	-; out	-; mod	D7.WINIXY:	PUSHM.L	D2,D3,D4,A3CALL	CARCAD	CALL	POSPAR		; positionne pour paramtres	LIB	?AFTIM	.ASCIZE	/Po<'<>/	LIB	?GETCURS	SWAP.W	D3	LOAD.W	D3,#PA1Y	SWAP.W	D3	LOAD.L	(A6)+OPOSAX,D3	SWAP.W	D3	LOAD.W	D3,#PA2Y	SWAP.W	D3	LOAD.L	(A6)+OPOSAY,D3	LIB	?AFTIM	.ASCIZE	/.../	LIB	?AFTIM	.ASCIZ	"....<MSPACE><50>"	.EVENCALL	CARPLAN	POPM.L	D2,D3,D4,A3	RET;--------\; INIDXY  >;========/; Initialise le haut de l'cran pour affichier dX= et dY=.; in	-; out	-; mod	D7.WINIDXY:	PUSHM.L	D2,D3,D4,A3CALL	CARCAD	CALL	POSPAR		; positionne pour paramtres	LIB	?AFTIM	.ASCIZE	/Di<'<>/	LIB	?GETCURS	SWAP.W	D3	LOAD.W	D3,#PA1Y	SWAP.W	D3	LOAD.L	(A6)+OPOSAX,D3	SWAP.W	D3	LOAD.W	D3,#PA2Y	SWAP.W	D3	LOAD.L	(A6)+OPOSAY,D3	LIB	?AFTIM	.ASCIZE	/.../	LIB	?AFTIM	.ASCIZ	"....<MSPACE><50>"	.EVENCALL	CARPLAN	POPM.L	D2,D3,D4,A3	RET;--------\; INIRXY  >;========/; Initialise le haut de l'cran pour affichier rX= et rY=.; in	-; out	-; mod	D7.WINIRXY:	PUSHM.L	D2,D3,D4,A3CALL	CARCAD	CALL	POSPAR		; positionne pour paramtres	LIB	?AFTIM	.ASCIZE	/Ra<'<>/	LIB	?GETCURS	SWAP.W	D3	LOAD.W	D3,#PA1Y	SWAP.W	D3	LOAD.L	(A6)+OPOSAX,D3	SWAP.W	D3	LOAD.W	D3,#PA2Y	SWAP.W	D3	LOAD.L	(A6)+OPOSAY,D3	LIB	?AFTIM	.ASCIZ	"....<MSPACE><50>"	.EVENCALL	CARPLAN	POPM.L	D2,D3,D4,A3	RET;--------\; INIR    >;========/; Initialise le haut de l'cran pour affichier R=.; in	-; out	-; mod	D7.WINIR:	PUSHM.L	D2,D3,D4,A3CALL	CARCAD	CALL	POSPAR		; positionne pour paramtres	LIB	?AFTIM	.ASCIZ	"R="	.EVEN	LIB	?GETCURS	SWAP.W	D3	LOAD.W	D3,#PA2Y-3		;-PA1Y	SWAP.W	D3	LOAD.L	(A6)+OPOSAX,D3	LIB	?AFTIM	.ASCIZ	"....<MSPACE><50>"	.EVENCALL	CARPLAN	POPM.L	D2,D3,D4,A3	RET;--------\; POSPAR  >;========/; Positionne le curseur pour les paramtres dans la ligne; tout en haut de la fentre.; in	-; out	-; mod	D7.WPOSPAR:	PUSH.L	D3	LOAD.W	D3,(A6)+OPLANAV+OCARX	; D3 <-- largeur d'un caractreJUMP,NE	10$LOAD.W	D3,#010$:	MUL.WU	D3,#25		; D3 <-- <xx> (anciennement 32,resp.27)	SWAP.W	D3	CLR.W	D3		; D3 <-- <yy>	SWAP.W	D3	LIB	?SETCURS	POP.L	D3	RET;--------\; INIQUES >;========/; Initialise la fentre du bas pour afficher une question.; in	-; out	-; mod	-INIQUES:	PUSHM.L	D3,D7CALL	CARCAD	LOAD.W	D3,#-1		; D3 <-- Y max	SWAP.W	D3	CLR.W	D3		; D3 <-- X min	LIB	?SETCURS	; positionne en bas  gauche	CALL	AFFINV	LIB	?AFTIM	.B	NOCURS		; plus de curseur	.B	MSPACE,100	; rempli d'espaces inverss	.B	0	.EVEN	LOAD.W	D3,#-1		; D3 <-- Y max	SWAP.W	D3	CLR.W	D3		; D3 <-- X min	LIB	?SETCURS	; positionne en bas  gauche	LIB	?AFSPACECALL	CARPLAN	POPM.L	D3,D7	RET;--------\; AFNTEXT >		EXISTE AUSSI DANS PPLANFLECHE (LIB);========/; Affiche un texte quelconque dans une liste pour m-menu.; in	A3.L	^textes pour m-menu;	D3.B	rang  afficher; out	D7.W	erreur; mod	D7.WAFNTEXT:	PUSHM.L	D3,A310$:	TEST.B	(A3)		; fin des textes ?	JUMP,EQ	90$		; oui => 90$	TEST.B	D3		; texte trouv ?	JUMP',EQ 50$		; oui => 50$20$:				; non =>	TEST.B	(A3+)		; A3 <-- saute .ASCIZ	JUMP,NE	20$	DEC.B	D3	JUMP	10$50$:	COMP.B	(A3+),#SPACE	; A3 <-- saute SPACE(s)	JUMP,EQ	50$	DEC.L	A3	COMP.B	(A3),#-1	; trait horizontal de sparation ?	JUMP',NE 70$		; non => 70$	INC.L	A3		; oui => saute le .B -170$:	COMP.B	(A3),#USEGC	; icne dans m-menu ?	JUMP',NE 80$		; non => 80$				; oui =>	LOAD.B	(A6)+OPLANAV+OBWRITE+5,(A3)+4+1 ; saute <usegc><f><s><t> et <7>	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE	LOAD.B	(A3)+0,#USEGC	LOAD.B	(A3)+1,#GCICF	LOAD.B	(A3)+2,#GCICS	LOAD.B	(A3)+3,#GCICT	LOAD.B	(A3)+4,#AFTOUT;	LOAD.B	(A3)+5,#code	LOAD.B	(A3)+6,#AFNORM	LOAD.B	(A3)+7,#USEGC	LOAD.B	(A3)+8,#GCTXF	LOAD.B	(A3)+9,#GCTXS	LOAD.B	(A3)+10,#GCTXT	LOAD.W	D3,#11	LIB	?STRING		; affiche icne graphique	JUMP'	90$80$:	COMP.B	(A3+),#SPACE	; A3 <-- saute les espaces au dbut	JUMP,EQ 80$	DEC.L	A3	LIB	?AFTEXT		; affiche le .ASCIZ90$:	POPM.L	D3,A3	RET;--------\\; AFCMES  >;========/; Affiche un message centr en bas de l'cran.; Evalue largeur en pg, mme si diffrents genc utiliss.; in	texte suivant l'appel; out	-; mod	D7.WAFCMES:	PUSHM.L	D0,D3,D4,A3,A4	CALL	INIQUES		; positionne tout en bas	LOAD.L	A4,(SP)+5*4	; A4 <-- ^texte	LOAD.L	A3,A410$:	TEST.B	(A4+)		; A3 <-- saute .ASCIZ	JUMP,NE	10$	LOAD.L	D4,A4		; D4 <-- ^fin des textes	INC.L	D4	TCLR.L	D4:#0		; D4 <-- saute .EVEN	LOAD.L	(SP)+5*4,D4	; ajuste l'adresse de retour	PUSH.L	A3	CLR.L	D0		; init longuer en pg	LOAD.L	A4,A3		; A4 <-- ^le bon texte30$:	COMP.B	(A4),#USEGC	; si un autre genc	JUMP,NE	32$	LOAD.L	A3,A4	ADD.L	A4,#4	LOAD.W	D3,#4	LIB	?STRING32$:	LOAD.B	D3,(A4+)	JUMP,EQ	33$	LIB	?LGXCAR	JUMP,NE	30$		; car sans largeur	ADD.W	D0,D4	JUMP	30$33$:;;	TEST.B	(A4+);;	JUMP,NE	30$;	MUL.WU	D4,(A6)+OPLANAV+OCARX	; D4 <-- largeur totale du texte	LOAD.W	D4,D0		; D4 <-- largeur totale du texte en pg	ADD.W	D4,(A6)+OPLANAV+OCARX	; ajoute largeur de deux espaces	ADD.W	D4,(A6)+OPLANAV+OCARX	POP.L	A3	SUB.W	D4,(A6)+OPLANAV+OWDOX	JUMP',HS 50$	NEG.W	D4		; D4 <-- reste gauche/droite	SR.W	D4,#1		; D4 <-- reste gauche (1/2)	AND.L	D4,#H'FFFF	DIV.WU	D4,(A6)+OPLANAV+OCARX	; D4 <-- reste en nb de caractres	TEST.W	D4	JUMP',EQ 50$CALL	CARCAD	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR50$:	CALL	AFFDIR	LIB	?AFSPACE	LIB	?AFTEXT		; affiche le texte	LIB	?AFSPACE	CALL	AFFINV	LIB	?AFTIM	.B	MSPACE,20,0	.EVENCALL	CARPLAN	POPM.L	D0,D3,D4,A3,A4	RET;--------\; LPOSAX  >;========/; Effectue un positionnement absolu dans une ligne.; in	D3.W	position  atteindre (caractre); out	-; mod	D7.WLPOSAX:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE+1	LOAD.B	(A3)+0,#TYPOAX	; <TYPOAX>	MUL.WU	D3,(A6)+OPLANAV+OCARX	LOAD.W	(A3)+1,D3	; <xx>	LOAD.W	D3,#3		; D3 <-- longueur	LIB	?STRING		; positionnement absolu en X	POPM.L	D3,A3	RET;--------\; KCLEAR  >;========/; Vide le fifo du clavier.; in	-; out	-; mod	D7.WKCLEAR:	PUSHM.L	D3,D6,A4	LIB	?GCHKEY		; D6 <-- canal du clavier	LOAD.L	A4,#(A6)+OPLANAV+OBWRITE	LOAD.B	(A4)+0,#KEYCLF	CLR.B	(A4)+1	LOAD.W	D3,#TYPKEY	; D3 <-- type du clavier	FOS	?COMMAND	; envoie la commande	POPM.L	D3,D6,A4	RET;--------\\; MAJMIN  >;========/; Effectue une conversion MAJUSCULE --> minuscule.; in	D3.B	caractre; out	D3.B	caractre; mod	D3.BMAJMIN:	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'Z	JUMP',HI 90$	ADD.B	D3,#'a-'A90$:	RET;--------- CARPLAN:	; met le mode selon BICADRE pour afficher des car.;---------	PUSH.L	D7	TEST.B	(A6)+OFLMOD:#BICADRE	JUMP,BC	90$	LIB	?AFTIM	.B	AFDIR	.B	0	.EVEN90$:	POP.L	D7	RET;-------- CARCAD:	; met le mode selon BICADRE pour afficher des car.;--------	PUSH.L	D7	TEST.B	(A6)+OFLMOD:#BICADRE	JUMP,BC	90$	LIB	?AFTIM	.B	AFINV	.B	0	.EVEN90$:	POP.L	D7	RET;--------\\; AFFDIR  >;========/; Passe en vido directe.; in	-; out	-; mod	D7.WAFFDIR:	TNOT.B	(A6)+OFLMOD:#BICADRE	CALL	AFFINV	TNOT.B	(A6)+OFLMOD:#BICADRE	RET;--------\\; AFFINV  >;========/; Passe en vido inverse.; in	-; out	-; mod	D7.WAFFINV:	PUSH.W	D3	LOAD.B	D3,#AFINV	TEST.B	(A6)+OFLMOD:#BICADRE	JUMP',BS 20$	LOAD.B	D3,#AFDIR20$:	LIB	?AFCAR	POP.W	D3	RET;--------\\; MODASC  >;========/; Cette routine doit tre appele chaque fois qu'on modifie; la dimensions de la partie visible ou de tout le plan pour; dcider s'il faut afficher les ascenseurs ou pas.; Essaye  tout prix de ne pas mettre les ascenseurs !; in	-; out	-; mod	-MODASC:	PUSHM.L	D0,D4	TCLR.B	(A6)+OFLMOD:#BSCROLL	JUMP',BC 10$				; enlve les ascenseurs =>	LOAD.W	D4,#+LGSCROLL	; D4 <-- agrandi surface de dessin	CALL	MDDASC		; modifie les dimensions10$:	LOAD.W	D4,(A6)+OPLANAV+OSWDOX	COMP.W	D4,(A6)+OPLANAV+OMWDOX	JUMP',LO 20$	LOAD.W	D4,(A6)+OPLANAV+OSWDOY	COMP.W	D4,(A6)+OPLANAV+OMWDOY	JUMP',HS 50$20$:	TSET.B	(A6)+OFLMOD:#BSCROLL	LOAD.W	D4,#-LGSCROLL	; D4 <-- diminue surface de dessin	CALL	MDDASC		; modifie les dimensions50$:	LOAD.W	D0,(A6)+OPLANAV+OSWDOX	COMP.W	D0,(A6)+OPLANAV+OMWDOX	; peut-on tout voir ?	JUMP',LO 60$		; non => 60$	CLR.W	(A6)+OPLANAV+OOWDOX	; oui => cale  gauche60$:	LOAD.W	D0,(A6)+OPLANAV+OSWDOY	COMP.W	D0,(A6)+OPLANAV+OMWDOY	; peut-on tout voir ?	JUMP',LO 70$		; non => 70$	CLR.W	(A6)+OPLANAV+OOWDOY	; oui => cale en bas70$:	POPM.L	D0,D4	RET;--------\\; MDDASC  >;--------/; Modifie les dimensions selon D4; p.ex. pour mettre/enlever les ascenseurs et les rgles.; in	D4.W	dimension (+/-); out	-; mod	D4.LMDDASC:	SUB.W	(A6)+OPLANAV+OMINX,D4	ADD.W	(A6)+OPLANAV+OMAXY,D4	ADD.W	(A6)+OPLANAV+OLWDOX,D4	ADD.W	(A6)+OPLANAV+OLWDOY,D4	LOAD.L	D4,(A6)+OPLANAV+OLWDOY	; D4 <-- dim fentre physique	PUSH.W	(A6)+OPLANAV+OSCALE	NEG.W	(A6)+OPLANAV+OSCALE	; selon l'inverse de l'chelle;;	CALL	D4SCALE	.W	PLANA_D4SCALE	POP.W	(A6)+OPLANAV+OSCALE	LOAD.L	(A6)+OPLANAV+OSWDOY,D4	; mj dim selon l'chelle	RETNOBJET:	.B	USEGC,GCICF,GCICS,GCICT	.B	7,1,7				; TML	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,11,7				; Droite rigide	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,12,7				; idem h/v	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,13,7				; lastique	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,14,7				; idem h/v	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,15,7				; cercle	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,4,7				; rect	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,5,7				; surf	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,6,7				; ABC...	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,16,7				; 1/2 cercle	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,65,7				; ellipse	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,40,7				; 1/2 ellipse	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,54,7				; flche	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,55,7				; idem h/v	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,48,7				; bloc-notes	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,63,7				; rempli (surfaces)	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,66,7				; spline ouvert	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,67,7				; ferm	.B	USEGC,GCTXF,GCTXS,GCTXT 	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,86,7				; pol ouvert	.B	USEGC,GCTXF,GCTXS,GCTXT 	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,87,7				; pol ferm	.B	USEGC,GCTXF,GCTXS,GCTXT 	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,88,7				; pol h/v	.B	USEGC,GCTXF,GCTXS,GCTXT 	.ASCIZ	"";;	.B	USEGC,GCICF,GCICS,GCICT;;	.B	7,89,7				; cercle: centre et rayon;;	.B	USEGC,GCTXF,GCTXS,GCTXT ;;	.ASCIZ	"";;	.B	USEGC,GCICF,GCICS,GCICT;;	.B	7,90,7				; idem diamtre;;	.B	USEGC,GCTXF,GCTXS,GCTXT ;;	.ASCIZ	""; - Sp.	.B	0	.EVEN	.END