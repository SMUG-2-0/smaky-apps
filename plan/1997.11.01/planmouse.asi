		.SBTTL	PLANMOUSE		; 28 juin 87 Sp.;--------\; CREZONE >;========/; Cre une zone rectangulaire jusqu' ce que les boutons; de la souris soient tous relachs.; Le rectangle dlimitant la zone n'est pas effac !; in	D4.L	position d'origine de la souris; out	D3.L	coordonne coin rectangle;	D4.L	coordonne coin rectangle;	D2.B	mode;	D1.B	mode de trait; mod	D1.W, D2.W, D3.L, D4.L, D7.WCREZONE:	PUSHM.L	D5,D0	CALL	INIDXY		; pour afficher dX= et dY=	LOAD.L	D0,#OBJRECT	LOAD.L	(A6)+ORIPOS,D4	; mm. position d'origine	TSET.B	(A6)+OPLANAV+OFLAGS:#BFIRST	LOAD.B	D2,#MODINV	; D2 <-- mode inverse	or.b	d2,#H'F0	; sans test visible	CLR.W	D1		; D1 <-- type de trait fin10$:	LOAD.L	D5,D4		; D5 <-- ancienne position	CALL	RDMOUSE		; lit la souris	TEST.B	D3		; bouton(s) press(s) ?	JUMP',EQ 50$		; non => 50$				; oui =>	LOAD.L	D3,(A6)+ORIPOS	; D3 <-- coordonne dpart	PUSH.L	D4	LOAD.L	D4,D5		; D4 <-- ancienne arrive	TCLR.B	(A6)+OPLANAV+OFLAGS:#BFIRST	JUMP',BS 20$;;;	CALL	RECTANGLE	; efface ancien rectangle	.W	PLANA_DESSINE20$:	POP.L	D4;;;	CALL	_RECTANGLE	; dessine nouveau rectangle	.W	PLANA_DESSINE	CALL	AFFDXY		; affiche dX= et dY=	JUMP	10$50$:	LOAD.L	D3,(A6)+ORIPOS	; D3 <-- coordonne dpart	LOAD.L	D4,D5		; D4 <-- coordonne arrive	LOAD.L	(A6)+ORIPOS,D4	; coord. de rfrence	POPM.L	D5,D0	RET;--------\; MOVZONE >;========/; Dplace/duplifie une zone rectangulaire jusqu' ce que les; boutons de la souris soient tous relachs.; Le rectangle dlimitant la zone doit exister si l'on attend; un bouton press (clic).; Le rectangle dlimitant la zone est effac !; in	D3.L			coordonne coin rectangle;	D4.L			coordonne coin rectangle;	(A6)+OFLAGF:#BMPDES	0/1 => dplace/duplifie;	(A6)+OMOVOP.W		0/1 => attend bouton relach/press; out	D0.L			offset +/-; mod	D0.L, D7.WMOVZONE:	PUSHM.L	D1,D2,D3,D4,D5,D6,A3,A4,A5	CALL	INIDXY		; pour afficher X= et Y=	CALL	CCMO		; enlve flche souris	LOAD.L	(A6)+ORIZO1,D3	LOAD.L	(A6)+ORIZO2,D4	TSET.B	(A6)+OPLANAV+OFLAGS:#BFIRST ; 1er rectangle n'existe pas	TEST.W	(A6)+OMOVOP	; attend bouton press/relach ?	JUMP',EQ 05$		; relach => 05$	TEST.B	(A6)+OPLANAV+OFLMOD1:#BPOLYC	JUMP',BS 05$		; polycopies, 1er rectangle n'existe pas	TCLR.B	(A6)+OPLANAV+OFLAGS:#BFIRST ; 1er rectangle existe dj05$:load.w	d2,(A6)+OMODE	; d2 <-- mode/couleur	LOAD.B	D2,#MODINV	; D2 <-- force mode inverse	CLR.W	D1		; D1 <-- type de trait fin	CLR.L	D0		; D0 <-- offset	LOAD.L	(A6)+OFFSET,D0	TCLR.B	(A6)+OFLAGF:#BAPDES ; pas encore fin du proc.	PUSHM.L	D4,A5	NTREL	?GETPRIO	; D4 <-- priorit du pre	INC.W	D4		; fils MOINS prioritaire	LOAD.L	A5,#R16"PFILS2	LOAD.L	A3,#R16"NFILS2	LOAD.L	D5,#300		; D5 <-- lg stack	NTREL	?CRETASK	; cre processus fils	POPM.L	D4,A5	JUMP,NE 95$	PUSH.B	(A6)+OFLMOD	    ; il ne faut plus afficher les marqueurs	TCLR.B	(A6)+OFLMOD:#BREGLE ; de position dans les rgles !10$:	LOAD.L	D5,D3		; D5 <-- ancienne position	LOAD.L	D6,D4		; D6 <-- ancienne position	CALL	RDMOUSE		; lit la souris	LOAD.L	A5,(A6)+OPSEMA	NTREL	?LOCK		; dbut zone d'exclusion	LOAD.L	A5,#(A6)+OPLANAV	TEST.L	D3:#BMORIGHT	; bouton droite press => on sort (polygones etc.)	JUMP,BS	50$	TEST.W	(A6)+OMOVOP	; attend bouton press/relach ?	JUMP',NE 13$				; ATTEND BOUTON RELACHE	TEST.L	D3:#BMOLEFT	; bouton gauche relach ?	JUMP,BC	50$		; oui => 50$	JUMP	15$		; non => 15$13$:				; ATTEND BOUTON PRESSE	TEST.L	D3:#BMOLEFT	; bouton gauche press ?	JUMP,BS	50$		; press => 50$15$:	PUSH.L	D4	LOAD.L	D3,D5		; D3 <-- ancienne arrive	LOAD.L	D4,D6		; D4 <-- ancienne arrive	TCLR.B	(A6)+OPLANAV+OFLAGS:#BFIRST	JUMP',BS 20$	CALL	TRECTANGLE	; efface ancien rectangle20$:	POP.L	D4	SUB.W	D4,(A6)+ORIZO2+OXX	SWAP.W	D4	SUB.W	D4,(A6)+ORIZO2+OYY	SWAP.W	D4	LOAD.L	D0,D4		; D0 <-- offset provisoire	LOAD.L	D3,(A6)+ORIZO1	LOAD.L	D4,(A6)+ORIZO2	ADD.W	D3,D0		; corrige X	ADD.W	D4,D0		; corrige X	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D0		; corrige Y	ADD.W	D4,D0		; corrige Y	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	CALL	TRECTANGLE	; dessine nouveau rectangle	PUSH.L	D4	SUB.W	D4,(A6)+ORIZO2+OXX	SWAP.W	D4	SUB.W	D4,(A6)+ORIZO2+OYY	SWAP.W	D4		; D4 <-- offset dfinitif	CALL	OARRONDI	; D4 <-- arrondi selon le pas	LOAD.L	D0,D4		; D0 <-- offset	POP.L	D4	COMP.L	D0,(A6)+OFFSET	; offset identique ?	JUMP',EQ 40$		; oui => 40$	LOAD.L	(A6)+OFFSET,D0	; passe offset au proc. fils	PUSHM.L	D3,D4		; affiche dX= et dY	LOAD.L	D3,(A6)+ORIPOS	CALL	AFFDXY	POPM.L	D3,D4	LOAD.L	A5,(A6)+OPSEMS	; A5 <-- ^smaphore de synchro	NTREL	?RACSEM	NTREL	?SSIGNAL	; "single" signal	NTREL	?RLASEM;	LOAD.L	A5,#(A6)+OPLANAV40$:	LOAD.L	A5,(A6)+OPSEMA	NTREL	?UNLOCK		; fin zone d'exclusion	LOAD.L	A5,#(A6)+OPLANAV	JUMP	10$50$:	LOAD.L	D3,D5		; D3 <-- ancienne arrive	LOAD.L	D4,D6		; D4 <-- ancienne arrive	TCLR.B	(A6)+OPLANAV+OFLAGS:#BFIRST	JUMP',BS 90$	CALL	TRECTANGLE	; efface dernier rectangle90$:	POP.B	(A6)+OFLMOD	; !!! ATTENTION !!!	CALL	SWMO		; met la souris "en attente"	CALL	SCMO		; remet flche souris	LOAD.L	A5,(A6)+OPSEMA	NTREL	?UNLOCK		; fin zone d'exclusion	TSET.B	(A6)+OFLAGF:#BAPDES	LOAD.L	A5,(A6)+OPSEMS	; A5 <-- ^smaphore de synchro	NTREL	?RACSEM	NTREL	?SIGNAL		; signal (surtout pas SSIGNAL)	NTREL	?RLASEM	NTREL	?WFABDESC	; attend la fin du fils	LOAD.L	A5,#(A6)+OPLANAV95$:	CALL	CWMO		; remet la souris normale	CALL	SCMO		; remet flche souris	POPM.L	D1,D2,D3,D4,D5,D6,A3,A4,A5	RET;------------\\ TRECTANGLE: ;>;------------/	PUSH.L	D0	LOAD.W	D0,#OBJTRECT	.W	PLANA_DESSINE	POP.L	D0	RET;----------\\; WAITMOUSE >;==========/;; Attend que tous les boutons de la souris ; et du clavier soient relachs.;; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D3,D4,D710$:	CALL	IFMOUSE		; D3 <-- boutons	TEST.B	D3		; boutons relachs ?	JUMP',EQ 90$		; oui => 90$				; non =>	LIB	?GETCAR		; attend clavier/souris ...	JUMP	10$30$:	LIB	?IFCAR		; une autre touche ?	JUMP,NE	90$		; non => 90$40$:	LIB	?GETCAR		; oui, attend relach	TEST.L	D3:#BKPSEUDO	JUMP,BS	90$	JUMP	30$90$:	POPM.L	D3,D4,D7	RET;--------\\; CONVCMO >;--------/; Converti la position de la souris dans la fentre; en une coordonne dans le plan.; in	D4.L	position de la souris; out	D7.W	ok;	 D4.L	 coordonnes dans le plan;	D7.W	erreur;	 D4.L	 coordonnes les meilleures; mod	D4.L, D7.WCONVCMO:	PUSH.L	D3	CLR.W	D7		; D7 <-- ok	COMP.W	D4,(A6)+OPLANAV+OMAXX	JUMP',LT 10$	LOAD.W	D4,(A6)+OPLANAV+OMAXX	DEC.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la fentre10$:	SUB.W	D4,(A6)+OPLANAV+OMINX	; D4 <-- pos. X relative	JUMP',GE 12$	CLR.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la fentre12$:	SWAP.W	D4	COMP.W	D4,(A6)+OPLANAV+OMAXY;	JUMP',LT 14$; essai ...JUMP',LE	14$	LOAD.W	D4,(A6)+OPLANAV+OMAXY	DEC.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la fentre14$:	SUB.W	D4,(A6)+OPLANAV+OMINY	; D4 <-- pos. Y relative	JUMP',GE 16$	CLR.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la fentre16$:	SWAP.W	D4;;;	CALL	_YINVERSE	; D4 <-- inverse le sens de Y	.W	PLANA_YINVERSE	LOAD.W	D3,(A6)+OPLANAV+OSCALE	; chelle 2:1 .. n:1 ?	JUMP',LE 50$		; non => 50$	SR.W	D3,#1		; D3 <-- 1/2 chelle	ADD.W	D4,D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D450$:	PUSH.W	(A6)+OPLANAV+OSCALE	; sauve l'chelle normale	NEG.W	(A6)+OPLANAV+OSCALE	; utilise l'inverse de l'chelle;;;	CALL	_D4SCALE		; modifie  l'inverse de l'chelle.W	PLANA_D4SCALE	POP.W	(A6)+OPLANAV+OSCALE	; remet l'chelle normale	LOAD.L	D3,D4	ADD.W	D3,(A6)+OPLANAV+OOWDOX	SWAP.W	D3	ADD.W	D3,(A6)+OPLANAV+OOWDOY	SWAP.W	D3	LOAD.L	(A6)+ONAPOS,D3	; mm. position non arrondie	CALL	ARRONDI		; D4 <-- arrondi selon le pas	ADD.W	D4,(A6)+OPLANAV+OOWDOX	COMP.W	D4,(A6)+OPLANAV+OMWDOX	; dpasse dans zone interdite ?	JUMP',LO 70$		; non => 70$	LOAD.W	D4,(A6)+OPLANAV+OMWDOX	DEC.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la fentre70$:	SWAP.W	D4	ADD.W	D4,(A6)+OPLANAV+OOWDOY	COMP.W	D4,(A6)+OPLANAV+OMWDOY	; dpasse dans zone interdite ?	JUMP',LO 75$		; non => 75$	LOAD.W	D4,(A6)+OPLANAV+OMWDOY	DEC.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la fentre75$:	SWAP.W	D4	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\ RDMOUSE: ;>;---------/;; lit la souris et vrifie s'il y dbordement; (X) => coord. X = OPDEP+OXX; (Y) => coord. Y = OPDEP+OYY; (F12) => OKEYPR:#BPAS	active ou desactive le pas; KEYMPR idem; (CURSOR()F) => inc X; (CURSOR()D) => dec X; (CURSOR()R) => inc Y; (CURSOR()C) => dec Y; (CURSOR()G) => add X,#10; (CURSOR()S) => sub X,#10; (CURSOR()E) => add Y,#10; (CURSOR()X) => sub Y,#10; (COPY()D)   => copie le dernier point significatif;; in	-; out	D4.L	coord. PLAN (Y;X);	D3.B	boutons de la souris; mod	D3.L,D4.L,D7.W;	PUSHM.L	D1,D2,D5	CLR.B	(A6)+OKEYPR		; initialise flags boutons10$:	LIB	?GETKEY			; attend clavier/souris ...	LOAD.L	D2,D3			; D2 <-- MAJ, D3 <-- min/MAJ	LIB	?MINMAJ	EX.L	D2,D3	TEST.L	D3:#BKPSEUDO    	JUMP,BC	20$		; BKPSEUDO = 0, touche presse	TEST.L	D3:#BKRELEAS	; BKPSEUDO = 1 et	JUMP,BC	10$		; BKRELEAS = 0, changement super-shift ignor				; BKPSEUDO = 1 et BKRELEAS = 1, touche relache	CLR.B	(A6)+OKEYPR		; remise  zro signaux pour touches X,Y,P	JUMP	40$20$:				; BKPSEUDO = 0, TOUCHE PRESSEE	COMP.W	D3,#KEYMPO		; souris boug ?	JUMP,EQ	40$			; oui => 40$;	COMP.W	D3,#KEYMGR		; bouton gauche relach ?;	JUMP,EQ	40$			; oui => 40$	COMP.W	D2,#(2^BCOPY)*H'100+'X	jump,eq	vert$	COMP.W	D2,#(2^BCOPY)*H'100+'V	jump,eq	vert$	comp.w	d2,#'V	jump,eq	vert$	COMP.W	D2,#'X			; X gel ?	JUMP,NE	21$vert$:	TSET.B	(A6)+OKEYPR:#BXFIX	JUMP	40$21$:	comp.w	d2,#'H	jump,eq	horiz$	COMP.W	D2,#(2^BCOPY)*H'100+'H	jump,eq	horiz$	COMP.W	D2,#(2^BCOPY)*H'100+'Y	jump,eq	horiz$	COMP.W	D2,#'Y			; Y gel ?	JUMP,NE	22$horiz$:	TSET.B	(A6)+OKEYPR:#BYFIX	JUMP	40$22$:	COMP.W	D3,#F12	JUMP,EQ	25$23$:	COMP.W	D3,#KEYMMP		; pas inhib, bouton du milieu press ?	JUMP,NE	24$25$:	COMP.W	(A6)+OPAS,#0	JUMP,NE	26$	TCLR.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS	JUMP	27$26$:	TNOT.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS27$:	CALL	AFDMENU	JUMP	40$24$:	COMP.W	D3,#KEYMMR		; ... relach ?	JUMP,NE	30$	JUMP	25$30$:					; suite touches presses ...	LOAD.L	D5,#1			; initialise D5	COMP.W	D2,#(2^BCURSOR)*H'100+'F	JUMP,EQ	33$	COMP.W	D3,#F3	JUMP,EQ	33$	LOAD.L	D5,#-1	AND.L	D5,#H'FFFF	COMP.W	D2,#(2^BCURSOR)*H'100+'D	JUMP,EQ	33$	COMP.W	D3,#F1	JUMP,EQ	33$	LOAD.L	D5,#10	COMP.W	D2,#(2^BCURSOR)*H'100+'G	JUMP,EQ	33$	COMP.W	D3,#F3+SHIFT	JUMP,EQ	33$	LOAD.L	D5,#-10	AND.L	D5,#H'FFFF	COMP.W	D2,#(2^BCURSOR)*H'100+'S	JUMP,EQ	33$	COMP.W	D3,#F1+SHIFT	JUMP,EQ	33$	LOAD.L	D5,#1*H'10000+0	COMP.W	D2,#(2^BCURSOR)*H'100+'R	JUMP,EQ	33$	COMP.W	D3,#F6	JUMP,EQ	33$	LOAD.L	D5,#-1*H'10000	COMP.W	D2,#(2^BCURSOR)*H'100+'C	JUMP,EQ	33$	COMP.W	D3,#F4	JUMP,EQ	33$	LOAD.L	D5,#10*H'10000	COMP.W	D2,#(2^BCURSOR)*H'100+'E	JUMP,EQ	33$	COMP.W	D3,#F6+SHIFT	JUMP,EQ	33$	LOAD.L	D5,#-10*H'10000	COMP.W	D2,#(2^BCURSOR)*H'100+'X	JUMP,EQ	33$	COMP.W	D3,#F4+SHIFT	JUMP,EQ	33$	LOAD.L	D4,(A6)+OMLLAST	COMP.W	D2,#(2^BCOPY)*H'100+'D	JUMP,EQ	35$	COMP.W	D3,#F7	JUMP,EQ	35$	COMP.W	D3,#F8	JUMP,EQ	35$	COMP.W	D3,#F9	JUMP,EQ	35$	COMP.W	D3,#F2	JUMP,NE	31$	TSET.B	(A6)+OKEYPR:#BYFIX	JUMP	40$31$:	COMP.W	D3,#F5	JUMP,NE	40$	TSET.B	(A6)+OKEYPR:#BXFIX	JUMP	40$32$:	LOAD.B	D3,#BIPLIT		; dpassement bip ...	LIB	?BEEP	JUMP	10$					; dplacement avec CURSOR ...33$:						; D5 <-- offset +/-	TEST.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS	JUMP,BC	34$	CALL	PASREEL	LOAD.L	D2,D5	SWAP.W	D2	MUL.WA	D5,D1	MUL.WA	D2,D1	SWAP.W	D5	LOAD.W	D5,D2	SWAP.W	D534$:	LOAD.L	D4,(A6)+OLDPOS	ADD.W	D4,D5	JUMP,NS	32$				; X trop petit	COMP.W	D4,(A6)+OPLANAV+OMWDOX	JUMP,HS	32$				; X trop grand	SWAP.W	D4	SWAP.W	D5	ADD.W	D4,D5	JUMP,NS	32$				; Y trop petit	COMP.W	D4,(A6)+OPLANAV+OMWDOY	JUMP,HS	32$				; Y trop grand	SWAP.W	D4	SWAP.W	D535$:	LOAD.L	D3,D4;;;	CALL	IPOINT			; ds. la fentre	.W	PLANA_IPOINT	;JUMP,NE	10$	JUMP,NE	32$;;;	CALL	D4CLIP;;;	CALL	D4SCALE;;;	CALL	YINVERSE	.W	PLANA_D4CLIP	.W	PLANA_D4SCALE	.W	PLANA_YINVERSE	ADD.W	D4,(A6)+OPLANAV+OMINX	SWAP.W	D4	ADD.W	D4,(A6)+OPLANAV+OMINY	SWAP.W	D4	CALL	PMOUSE	LOAD.L	D5,D4			; D5 <-- coord. cran	LOAD.L	D4,D3			; D4 <-- coord. PLAN	CALL	POSREGLE	LOAD.B	D3,(A6)+OLDBOU		; D3 <-- boutons idem avant	COMP.L	D4,(A6)+OLDPOS	JUMP,EQ	90$	JUMP	80$40$:					; SOURIS BOUGE OU BOUTON GAUCHE RELACHE	LIB	?IFMOUSE	JUMP,NE	10$	TSET.B	(A6)+OPLANAV+OFLAGS:#BPRISON	CALL	MOURET?				; affiche flche ou rticule	LOAD.L	D5,D4	CALL	CONVCMO				; convertit en coord. PLAN;;;	JUMP,NE	10$	TEST.B	(A6)+OKEYPR:#BXFIX	JUMP,BC	41$	LOAD.W	D4,(A6)+ORIPOS+OXX		; X = pos d'origine	JUMP	35$41$:	TEST.B	(A6)+OKEYPR:#BYFIX	JUMP,BC	42$	SWAP.W	D4	LOAD.W	D4,(A6)+ORIPOS+OYY	SWAP.W	D4	JUMP	35$42$:	70$:	CALL	POSREGLE		; affiche marqueurs ds. rgle	COMP.L	D5,(A6)+OPOCU		; pos. cran chang ?	JUMP,NE	80$;;	COMP.L	D4,(A6)+OLDPOS		; position PLAN chang ?;;	JUMP,NE	80$;;75$:	COMP.B	D3,(A6)+OLDBOU		; boutons changs ?	JUMP,EQ	10$80$:	LOAD.L	(A6)+OPOCU,D5		; pos. cran	LOAD.L	(A6)+OLDPOS,D4		; pos. PLAN	LOAD.B	(A6)+OLDBOU,D3		; boutons90$:	POPM.L	D1,D2,D5	RET;----------\; AFFCOMPTE >;==========/; Affiche le nombre d'objets trouvs dans la zone de; recherche.; in	D3.L	coordonne coin zone; in	D4.L	coordonne coin zone; out	NE	si rien trouv; mod	D7.WAFFCOMPTE:	PUSHM.L	D0,D2,D3,D4CALL	CARCAD;;;	CALL	COMPTE		; D0 <-- nb d'objets	LOAD.W	(A6)+OPLANAV+OPLANA,#FCOMPTE	.W	PLANA_FONC	CALL	POSPAR		; positionne pour paramtres	LOAD.L	D4,D0		; D4 <-- nb  afficher	LOAD.B	D3,#8		; D3 <-- nb digits	LOAD.B	D2,#2^BAFDCM	; D2 <-- mode	LIB	?AFDEC		; affiche nb trouv	COMP.L	D4,#1	JUMP',HI 40$	LIB	?AFTIM		; si 0..1 =>	.ASCIZ	/ objet trouv<MSPACE><50>/	.EVEN	JUMP'	50$40$:	LIB	?AFTIM		; si 2..n =>	.ASCIZ	/ objets trouvs<MSPACE><50>/	.EVEN50$:	CLR.W	D7		; D7 <-- ok	TEST.L	D4		; trouv qq chose ?	JUMP',NE 90$		; oui => 90$	LOAD.W	D7,#1		; D7 <-- erreur90$:CALL	CARPLAN	POPM.L	D0,D2,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------- USEPAGC:		; utilise le genc pour les paramtres;---------	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE	LOAD.B	(A3)+0,#USEGC	LOAD.B	(A3)+1,#GCPAF	LOAD.B	(A3)+2,#GCPAS	LOAD.B	(A3)+3,#GCPAT	LOAD.W	D3,#4	LIB	?STRING	POPM.L	D3,A3	RET;--------\; AFFR    >;========/; Affiche les valeurs pour R= en mode cration de cercle.; in	D3.W	rayon; out	-; mod	D7.WAFFR:	PUSHM.L	D0,D2,D3,D4CALL	CARCAD;;;;;;;;;CALL	PLOT;;;;;;;;;;	LOAD.W	D0,D3	CALL	USEPAGC	LOAD.L	D3,(A6)+OPOSAX	LIB	?SETCURS	; positionne pour R=...	CLR.L	D4	LOAD.W	D4,D0	CALL	AFFPARX	CALL	USEDGCCALL	CARPLAN	POPM.L	D0,D2,D3,D4	RET;--------\; AFFDXY  >;========/; Affiche les valeurs pour dX= et dY= en mode cration d'une; zone rectangulaire.; in	D3.L	coordonne d'un coin;	D4.L	coordonne de l'autre coin; out	-; mod	D7.WAFFDXY:	PUSHM.L	D0,D2,D3,D4CALL	CARCAD;;;;;;;;;;CALL	PLOT;;;;;;;;;;	SUB.W	D4,D3	JUMP',NC 10$	NEG.W	D4		; D4 <-- |X|10$:	SWAP.W	D4	SWAP.W	D3	SUB.W	D4,D3	JUMP',NC 20$	NEG.W	D4		; D4 <-- |Y|20$:	SWAP.W	D4	SWAP.W	D3	LOAD.L	D0,D4	CALL	USEPAGC	LOAD.L	D3,(A6)+OPOSAX	LIB	?SETCURS	; positionne pour dX=...	LIB	?AFTIM	.ASCIZE	/dX=/	CALL	AFFPARX	SWAP.W	D0	LOAD.L	D3,(A6)+OPOSAY	LIB	?SETCURS	; positionne pour dY=...	CLR.L	D4	LOAD.W	D4,D0	LIB	?AFTIM	.ASCIZE	/dY=/	CALL	AFFPARY	CALL	USEDGCCALL	CARPLAN	POPM.L	D0,D2,D3,D4	RET;--------\; AFFXY   >;========/; Affiche les valeurs pour X= et Y= en mode dplacement.; in	D4.L	position de la souris; out	-; mod	D7.WAFFXY:CALL	CARCAD	TEST.B	(A6)+OFLMOD:#BLAST ; par rap.  la dernire pos. significative ?	JUMP,BC	00$		; non ...	PUSH.L	D3	LOAD.L	D3,(A6)+OMLAST	CALL	AFFDXY		; affiche par rap. rf. dynamiqueCALL	CARPLAN	POP.L	D3	RET00$:	PUSHM.L	D0,D2,D3,D4;;;;;;;;CALL PLOT;;;;;;;;	LOAD.L	D0,D4	CALL	USEPAGC	LOAD.L	D3,(A6)+OPOSAX	LIB	?SETCURS	; positionne pour X=...	LIB	?AFTIM	.ASCIZE	/X=/	CALL	AFFPARX	SWAP.W	D0	LOAD.L	D3,(A6)+OPOSAY	LIB	?SETCURS	; positionne pour Y=...	CLR.L	D4;;?	LOAD.W	D4,(A6)+OPLANAV+OMWDOY	; fait comme si l'axe Y allait;;?	SUB.W	D4,D0		; de bas en haut !;;?	DEC.W	D4		; D4 <-- 0..OLWDOY-1	LOAD.W	D4,D0	LIB	?AFTIM	.ASCIZE	/Y=/	CALL	AFFPARY	CALL	USEDGCCALL	CARPLAN	POPM.L	D0,D2,D3,D4	RET;-------- AFFPARX:;--------; convertir pg en mm si ncessaire	PUSH.L	D0	LOAD.W	D0,(A6)+OF64X	JUMP,NE	10$	LOAD.W	D0,#226			; valeur par dfaut10$:	JUMP	AFFP0;-------- AFFPARY:;--------; convertir pg en mm si ncessaire	PUSH.L	D0	LOAD.W	D0,(A6)+OF64Y	JUMP,NE	AFFP0	LOAD.W	D0,#226			; valeur par dfautAFFP0:	PUSHM.L	D3,D4	TEST.B	(A6)+OFLMOD:#BENMM	; mm ?	JUMP,BC	80$			; non --> 80$	MUL.WU	D4,#64			; oui, D4*64	DIV.WU	D4,D0			; D4/OF64X ou Y	LOAD.L	D3,D4			; D3 <-- D4	MUL.WU	D4,#10			; D4*10	SWAP.W	D3	MUL.WU	D3,#10			; reste *10	DIV.WU	D3,D0			; reste/OF64X ouY	SWAP.W	D3			; v. arrondi	SL.W	D3	COMP.W	D3,D0	JUMP',LO 70$	ADD.L	D3,#H'1000070$:	SWAP.W	D3	AND.L	D3,#H'FFFF	ADD.L	D4,D3			; D4 + D380$:	CALL	AFFPAR1090$:	POPM.L	D3,D4	POP.L	D0	RET;---------- AFFPAR10:;----------; Affiche un paramtre numrique en pg ou en mm*10 (1 dcimale);; in	D4.W	valeur numrique; out	D7.W	erreur; mod	D7.W	PUSHM.L	D2,D3,D4	TEST.B	(A6)+OFLMOD:#BENMM	; mm ?	JUMP,BC	80$			; non --> 80$	LIB	?BUCAR	LIB	?BINBCD	LOAD.B	D2,#8		; D2 <-- nb max de digits20$:	LOAD.L	D3,D4	SWAP.W	D3	SR.W	D3,#8	SR.W	D3,#4	TEST.B	D3		; digit nul ?	JUMP,NE	30$		; non => 30$	COMP.B	D2,#6+1		; 6 digits au max.	JUMP,HS	21$	LOAD.B	D3,#SPACE	; oui, met des espaces	LIB	?AFCAR21$:	SL.L	D4,#4		; D4 <-- digit suivant	DEC.B	D2	JUMP,NE	20$	JUMP	70$		; 0.030$:	COMP.B	D2,#1		;;; pour 10 mettre 1, 2=100	JUMP,NE	40$	LOAD.B	D3,#BS	LIB	?AFCAR	LOAD.B	D3,#'0		; ne met pas .5 mais 0.5 !	LIB	?AFCAR40$:	COMP.B	D2,#1		;;; cf. ci-dessus	JUMP,NE	50$	LOAD.B	D3,#'.		; met la "virgule"	LIB	?AFCAR50$:	LOAD.L	D3,D4	SWAP.W	D3	SR.W	D3,#8	SR.W	D3,#4	ADD.B	D3,#'0	LIB	?AFCAR	SL.L	D4,#4		; D4 <-- digit suivant	DEC.B	D2	JUMP,NE	40$60$:	LIB	?AFTIM	.ASCIZE	/mm /	JUMP	90$70$:	LIB	?AFTIM	.ASCIZE	/<BS><BS>0.0/	JUMP	60$80$:		; affiche en pg 5 digits	AND.L	D4,#H'FFFF	LOAD.B	D3,#5	LOAD.B	D2,#2^BAFDALL	LIB	?AFDEC		; affiche Oy	LIB	?AFTIM	.ASCIZE	/ pg/90$:	LIB	?NOBUCAR	POPM.L	D2,D3,D4	RET;--------\\; MENUGC  >;========/; Dialogue avec un m-menu pour choisir un gencar.; in	-; out	D7.W	erreur; mod	D7.WMENUGC:	PUSHM.L	D3,D4,D6,A2..A4	LOAD.L	A4,#(A6)+OPLANAV+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE; A3 <-- ^buffer pour m-menu	LOAD.L	A2,(A6)+OPLANAV+OPDDIS	; A2 <-- ^description de la fentre	DGENC_	MENU		; construit le m-menu	LOAD.L	A4,#R16"00$10$:	LOAD.B	(A3+),(A4+)	; m-menu <-- "autre..."	JUMP,NE 10$	CLR.B	(A3)	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE; A3 <-- ^buffer pour m-menu	LOAD.L	A4,#(A6)+OCASTXT; A4 <-- ^variable de mmorisationclr.w	d3	CALL	MMENU		; attend choix selon menu ...	JUMP',NE 90$	DEC.W	D3	JUMP',NS 90$	COMP.W	D3,#MAXGC	JUMP',HS 50$	LOAD.L	A4,#(A6)+OPLANAV+OBUGC	; A4 <-- ^buffer des gencars	LOAD.W	D4,D3	MUL.WU	D4,#LGGC	ADD.L	A4,D4		; A4 <-- ^gencar choisi	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BC 50$		; non => 50$				; oui =>	LOAD.W	(A6)+OTEXTE,D3	CALL	INIBAS		; mj ligne en bas fentre	JUMP'	90$50$:	CALL	ASKGC		; demande un gencar;CALL	SRMO;	LOAD.W	(A6)+OPLANAV+OPLANA,#FDBGENC;	.W	PLANA_FONC;	LOAD.W	(A6)+OTEXTE,D6;CALL	CRMO90$:;	CALL	INIBAS		; mj ligne du bas	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	-1		; ligne horizontale de sparation	.ASCIZ	" autre..."	.EVEN;------- ASKGC:;-------; demande un gencar;	PUSHM.L	D6	CALL	SRMO	LOAD.W	(A6)+OPLANAV+OPLANA,#FDBGENC	.W	PLANA_FONC	LOAD.W	(A6)+OTEXTE,D6	CALL	CRMO	CALL	INIBAS	POPM.L	D6	RET;--------\; MMENU   >;========/; Excute l'appel ?MMENU en mode non invers.; in	A3.L	^textes .ASCIZ termins par zro;	D3.W	choix par dfaut;	D4.L	cases grises;	A4.L	^variable de mmorisation; out	D3.W	choix effectu (0..n);	D7.W	erreur; mod	D3.L, D7.WMMENU:	CALL	SRMO		; remet la flche relle (plus le rticule)	PUSH.W	D3	LOAD.B	D3,#AFDIR	LIB	?AFCAR	POP.W	D3;;;;;	CLR.W	D3		; D3 <-- case en haut par dfaut;rlx.w	d3;clr.w	d3;rrx.w	d3	TEST.B	(A6)+OPLANAV+OFLAGS:#BMEMCAS	JUMP',BC 20$;;;;	LOAD.W	D3,(A4)		; D3 <-- dernire caseor.w	d3,(a4)20$:	LIB	?MMENU	JUMP',NE 60$	LOAD.W	(A4),D3		; mmorise dernire case60$:	CALL	USEDGC		; utilise gencar par dfaut	TEST.W	D7	JUMP',NC 70$		; ok => 70$				; erreur =>	PUSH.W	D7	LOAD.B	D3,#BIPERR	LIB	?BEEP		; bruit pas sympa	LOAD.W	D3,#-1		; D3 <-- choix impossible	POP.W	D770$:	PUSH.W	D7	CALL	AFFINV	CALL	CRMO		; enlve la flche relle (met le rticule)	POP.W	D7	RET;--------\; SMMENU  >;========/; Cherche le byte correspondant  un choix dans un m-menu.; in	A3.L	^liste de bytes;	D3.W	choix selon m-menu (0..n); out	D7.W	zro;	 D3.W	 byte correspondant;	D7.W	erreur;	 D3.W	 inchang; mod	D3.W, D7.W, A3.LSMMENU:	PUSH.W	D0	LOAD.B	D0,D3	INC.B	D0		; D0 <-- 1..n+1	LOAD.W	D7,#1		; D7 <-- pas trouv10$:	COMP.B	(A3+),#-1	; fin de la table ?	JUMP',EQ 90$		; oui => 	DEC.B	D0		; trouv ?	JUMP,NE	10$		; non => 10$	CLR.W	D3	LOAD.B	D3,(A3)-1	; D3 <-- byte trouv	CLR.W	D7		; D7 <--- trouv90$:	POP.W	D0	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFMOUSE >;========/; Identique  LIB,?IFMOUSE avec l'affichage du rticule en; plus si c'est ncessaire.; in	-; out	D3.B	boutons;	D4.L	position;	D7.W	erreur; mod	D3.L, D4.L, D7.WIFMOUSE:	LIB	?IFMOUSE	; D3 <-- boutons, D4 <-- position	JUMP,NE 90$	CALL	MOURET?		; rticule si ncessaire90$:	TEST.W	D7	RET;-------- MOURET?:;--------;; affiche le rticule si ncessaire;; in	D4.L	position cran; out	-; mod	-;	PUSH.L	D5	TEST.B	(A6)+OPLANAV+OFLAGS:#BPRISON	JUMP',BC 05$				; souris prisonnire =>	COMP.W	D4,(A6)+OPLANAV+OMINX	JUMP',HS 01$	LOAD.W	D4,(A6)+OPLANAV+OMINX01$:	COMP.W	D4,(A6)+OPLANAV+OMAXX	JUMP',LO 02$	LOAD.W	D4,(A6)+OPLANAV+OMAXX	DEC.W	D402$:	SWAP.W	D4	COMP.W	D4,(A6)+OPLANAV+OMINY	JUMP',HS 03$	LOAD.W	D4,(A6)+OPLANAV+OMINY03$:	COMP.W	D4,(A6)+OPLANAV+OMAXY	JUMP',LO 04$	LOAD.W	D4,(A6)+OPLANAV+OMAXY	DEC.W	D404$:	SWAP.W	D405$:	TEST.B	(A6)+OFLRET:#BRETICULE	JUMP',BC 16$	COMP.W	D4,(A6)+OPLANAV+OMINX	; trop  gauche ?	JUMP',LO 10$	COMP.W	D4,(A6)+OPLANAV+OMAXX	; trop  droite ?	JUMP',HS 10$	LOAD.L	D5,D4	SWAP.W	D5	COMP.W	D5,(A6)+OPLANAV+OMINY	; trop en haut ?	JUMP',LO 10$	COMP.W	D5,(A6)+OPLANAV+OMAXY	; trop en bas ?	JUMP',LO 15$10$:				; souris dans le cadre =>	TSET.B	(A6)+OFLRET:#BRETFL	JUMP,BS 90$	PUSH.W	D3	LOAD.B	D3,#AFSCMO	LIB	?AFCAR		; montre la flche de la souris	POP.W	D3	JUMP	90$15$:	TCLR.B	(A6)+OFLRET:#BRETFL	JUMP',BC 16$	PUSH.W	D3	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; cache la flche de la souris	POP.W	D316$:	LOAD.L	D5,(A6)+OLDPOX	; D5 <-- ancienne position du rticule	TEST.B	(A6)+OFLRET:#BRETICULE	JUMP',BC 20$	TEST.B	(A6)+OFLRET:#BRETCA ; rticule cach ?	JUMP',BS 20$		; oui => 20$	TSET.B	(A6)+OFLRET:#BRETDE ; rticule dessin ?	JUMP',BC 40$		; non => dessine le premier	JUMP'	50$		; oui => dplace20$:	TCLR.B	(A6)+OFLRET:#BRETDE ; rticule dessin ?	JUMP',BS 60$		; oui => efface le dernier	JUMP'	80$		; non => ne fait rien40$:				; dessine le premier =>	CALL	IRETICULEV	CALL	IRETICULEH	JUMP	80$50$:				; dplace =>	COMP.W	D4,D5		; position en X change ?	JUMP',EQ 52$		; non => 52$	CALL	IRETICULEV	; dessine le nouveau	EX.L	D4,D5	CALL	IRETICULEV	; efface l'ancien	EX.L	D5,D452$:	SWAP.W	D4	SWAP.W	D5	COMP.W	D4,D5		; position en Y change ?	PUSH.W	F	SWAP.W	D5	SWAP.W	D4	POP.W	F	JUMP',EQ 80$		; non => 80$	CALL	IRETICULEH	; dessine le nouveau	EX.L	D4,D5	CALL	IRETICULEH	; efface l'ancien	EX.L	D5,D4	JUMP'	80$60$:				; efface le dernier =>	EX.L	D4,D5	CALL	IRETICULEV	CALL	IRETICULEH	EX.L	D5,D480$:	LOAD.L	(A6)+OLDPOX,D490$:	TCLR.B	(A6)+OPLANAV+OFLAGS:#BPRISON	POP.L	D5	TEST.W	D7		; retour EQ/NE	RET;----------\\; IRETICULE >;==========/; Inverse le rticule si c'est ncessaire.; Il faut toujours faire IRETICULE-action-IRETICULE, et "action" doit; tre court et sans IFMOUSE !; Utilis par exemple pour le remplissage d'une trame avec DRAWFILLO,; ou pendant LIB,?PDUMP.; in	-; out	-; mod	D7.WIRETICULE:	PUSH.L	D4	TEST.B	(A6)+OFLRET:#BRETICULE	JUMP',BC 90$	TEST.B	(A6)+OFLRET:#BRETDE ; rticule dessin ?	JUMP',BC 90$		; non => 90$				; oui =>	LOAD.L	D4,(A6)+OLDPOX	; D4 <-- ancienne position	CALL	IRETICULEV	CALL	IRETICULEH90$:	POP.L	D4	RET;-----------\\; IRETICULEV >;-----------/; Inverse le rticule selon X.; in	D4.L	coordonne; out	-; mod	D7.WIRETICULEV:	PUSHM.L	D1,D3,D4,A1,A2	TEST.L	D4		; D4 <-- <xx>	JUMP',EQ 90$	SWAP.W	D4	LOAD.W	D4,(A6)+OPLANAV+OMINY	; D4 <-- <yy>	SWAP.W	D4	LOAD.W	D3,(A6)+OPLANAV+OLWDOY	; D3 <-- <dyy>	INC.W	D3	SWAP.W	D3	CLR.W	D3		; D3 <-- <dxx>	LOAD.W	D1,#INVDOT	; D1 <-- mode	LOAD.L	A2,(A6)+OPLANAV+OPDDIS	; A2 <-- ^descrition de la fentre	LOAD.L	A1,(A6)+OADLINE	CALL	(A1)		; appel de GRA_LINE90$:	POPM.L	D1,D3,D4,A1,A2	RET;-----------\\; IRETICULEH >;-----------/; Inverse le rticule selon Y.; in	D4.L	coordonne; out	-; mod	D7.WIRETICULEH:	PUSHM.L	D1,D3,D4,A1,A2	TEST.L	D4		; D4 <-- <yy>	JUMP',EQ 90$	LOAD.W	D4,(A6)+OPLANAV+OMINX	; D4 <-- <xx>	CLR.L	D3		; D3 <-- <dyy>	LOAD.W	D3,(A6)+OPLANAV+OLWDOX	; D3 <-- <dxx>	INC.W	D3	LOAD.W	D1,#INVDOT	; D1 <-- mode	LOAD.L	A2,(A6)+OPLANAV+OPDDIS	; A2 <-- ^descrition de la fentre	LOAD.L	A1,(A6)+OADLINE	CALL	(A1)		; appel de GRA_LINE90$:	POPM.L	D1,D3,D4,A1,A2	RET;--------- INILLAST:		; initialise lutin rfrence;---------	PUSHM.L	D0,D3,D4,D6,D7,A2,A3,A4	TEST.B	(A6)+OFLMOD:#BLAST	; BLAST ?	JUMP,BC	90$			; non ...	LOAD.L	D4,(A6)+OMLAST	LOAD.L	D3,D4;;;	CALL	_IPOINT			; ds. fentre virtuelle ?	.W	PLANA_IPOINT	JUMP,NE	90$			; non	CALL	CCMOO			; enlve flche souris;;;	CALL	_D4CLIP			; calcul de (yy;xx);;;	CALL	_D4SCALE;;;	CALL	_YINVERSE	.W	PLANA_D4CLIP	.W	PLANA_D4SCALE	.W	PLANA_YINVERSE	ADD.W	D4,(A6)+OPLANAV+OMINX	SUB.W	D4,#DLLAST/2	JUMP,NS	80$	SWAP.W	D4	ADD.W	D4,(A6)+OPLANAV+OMINY	SUB.W	D4,#DLLAST/2	JUMP,NS	80$	SWAP.W	D4	LOAD.L	D3,#DLLAST*H'10000+DLLAST ; dimension du lutin	LOAD.L	A2,(A6)+OPLANAV+OPDDIS		; pointeur fentre	LOAD.W	D6,#NLLAST		; no. lutin	LOAD.L	A4,#R16"LLASTP		; trame lutin pos.	LOAD.L	A3,#0	;R16"LLASTN	; trame lutin ngatif, v. =0	LOAD.L	A3,#0			; = fond automatique	LOAD.W	D0,#SPRITE_OPEN		; oprationCALL	IRETICULE	GRA_	SPRITECALL	IRETICULE;	JUMP,NE	erreur80$:	CALL	SCMO			; remet flche souris90$:	POPM.L	D0,D3,D4,D6,D7,A2,A3,A4	RET;-------- RELLAST:		; libre lutin rfrence;--------	PUSHM.L	D0,D6,A2	CALL	CCMOO			; enlve flche souris	LOAD.L	A2,(A6)+OPLANAV+OPDDIS	LOAD.W	D6,#NLLAST	LOAD.W	D0,#SPRITE_CLOSE	GRA_	SPRITE;	JUMP,NE	erreur	CALL	SCMO			; remet flche souris	POPM.L	D0,D6,A2	RETLLASTP:					; chaire du lutin dyn.	.B	B'00000000,B'00000000	.B	B'00000011,B'11000000	.B	B'00001111,B'00110000	.B	B'00011111,B'00001000	.B	B'00111111,B'00000100	.B	B'00111111,B'00000100	.B	B'01111111,B'00000010	.B	B'01111111,B'00000010	.B	B'01000000,B'11111110	.B	B'01000000,B'11111110	.B	B'00100000,B'11111100	.B	B'00100000,B'11111100	.B	B'00010000,B'11111000	.B	B'00001100,B'11110000	.B	B'00000011,B'11000000	.B	B'00000000,B'00000000	.EVEN;--------\; SWMO    >;========/; Met la flche de la souris et attente.; in	-; out	-; mod	-SWMO:	PUSHM.L	D4,D7	TSET.B	(A6)+OPLANAV+OFLAGS:#BWMOUSE	JUMP',BS 90$	CLR.W	D4	LIB	?WAITMOUSE90$:	POPM.L	D4,D7	RET;--------\; CWMO    >;========/; Remet la flche normale de la souris.; in	-; out	-; mod	-CWMO:	PUSHM.L	D4,D7	TCLR.B	(A6)+OPLANAV+OFLAGS:#BWMOUSE	JUMP',BC 90$	LOAD.W	D4,#1	LIB	?WAITMOUSE90$:	POPM.L	D4,D7	RET;--------\\; SRMO    >;========/; Remet la flche relle de la souris.; Utile pendant MMENU ou DBOX !; in	-; out	-; mod	-SRMO:	PUSHM.L	D3,D7	TEST.B	(A6)+OFLRET:#BRETICULE	JUMP',BC 90$	LOAD.B	D3,#AFSCMO	LIB	?AFCAR		; remet la flche normale	TSET.B	(A6)+OFLRET:#BRETFL90$:	POPM.L	D3,D7	RET;--------\\; CRMO    >;========/; Enlve la flche relle de la souris, v. rticule.; in	-; out	-; mod	-CRMO:	PUSHM.L	D3,D7	TEST.B	(A6)+OFLRET:#BRETICULE	JUMP',BC 90$	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la flche normale	TCLR.B	(A6)+OFLRET:#BRETFL90$:	POPM.L	D3,D7	RET;--------\; CCMOO   >;========/; Supprime la flche de la souris pendant le dessin d'un objet.; in	-; out	-; mod	-CCMOO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	TCLR.B	(A6)+OFLRET:#BRETFL	POPM.L	D3,D7	RET;--------\; CCMO    >;========/; Supprime la flche de la souris.; in	-; out	-; mod	-CCMO:	PUSHM.L	D3,D7	TEST.B	(A6)+OFLRET:#BRETICULE	JUMP',BS 50$	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	TCLR.B	(A6)+OFLRET:#BRETFL	JUMP'	90$50$:	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	TCLR.B	(A6)+OFLRET:#BRETFL	TSET.B	(A6)+OFLRET:#BRETCA ; rticule cach90$:	POPM.L	D3,D7	RET;--------\; SCMO    >;========/; Remet la flche de la souris.; in	-; out	-; mod	-SCMO:	PUSHM.L	D3,D7	TEST.B	(A6)+OFLRET:#BRETICULE	JUMP',BS 50$	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	TSET.B	(A6)+OFLRET:#BRETFL	JUMP'	90$50$:	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	TCLR.B	(A6)+OFLRET:#BRETFL	TCLR.B	(A6)+OFLRET:#BRETCA ; rticule visible90$:	POPM.L	D3,D7	RET;--------\\; PMOUSE  >;========/; Positionne la souris en (y;x).; in	D4.L	nouvelle position y;x; out	-; mod	D7.WPMOUSE:	PUSHM.L	D4	LIB	?PMOUSE			; tient compte de 2 crans (couleur)	POPM.L	D4	TEST.W	D7	RET;	PUSHM.L	D3,D4,D6,A4;;	LOAD.L	A4,(A6)+OPLANAV+OPDDIS	; A4 <-- ^descripteur de la fentre;	ADD.W	D4,(A4)+ODFX;	SWAP.W	D4;	ADD.W	D4,(A4)+ODFY;	SWAP.W	D4		; D4 <-- position dans $DIS_0 !;;;;	LOAD.L	A4,#(A6)+OPLANAV+OBWRITE+1;LOAD.L	A4,#(A6)+OBCOMM+1;	LOAD.B	(A4)+0,#'P	; <P>;	LOAD.L	(A4)+1,D4	; <yy> <xx>;	CLR.B	(A4)+5;	LOAD.W	D3,#TYPIO	; D3 <-- type du driver souris;	LOAD.W	D6,(A6)+OCHMOU	; D6 <-- canal souris;	FOS	?COMMAND;;	POPM.L	D3,D4,D6,A4;	RET	.END