		.SBTTL	PLANERROR	; 18 aot 87 Sp.;--------\; MOERROR >;========/; Affiche une erreur faite avec la souris.; in	D7.W	erreur; out	-; mod	-MOERROR:	PUSH.W	D2	LOAD.W	D2,#2^BDBMOU	; D2 <-- centre selon souris	CALL	QQERROR		; affiche l'erreur	POP.W	D2	RET;--------\; IOERROR >;========/; Affiche une erreur faite avec un fichier.; in	D7.W	erreur;	A3.L	^nom du fichier (facultatif); out	-; mod	-IOERROR:	PUSH.W	D2	CLR.W	D2		; D2 <-- au milieu de la fentre	CALL	QQERROR		; affiche l'erreur	POP.W	D2	RET;--------\\; QQERROR >;--------/; Affiche une erreur quelconque.; in	D7.W	erreur;	A3.L	^nom du fichier (facultatif);	D2.W	mode; out	-; mod	-QQERROR:	PUSHM.L	D3,D4,D7,A3	LOAD.W	D4,D7		; D4 <-- code de l'erreur	COMP.W	D4,#H'10	; erreur grave ?	JUMP,LO	90$		; non => 90$	COMP.W	D7,#ERKSTO	; ANNULE de ERCALL !!	JUMP,EQ	90$				; oui =>	LOAD.B	D3,#BIPERR	LIB	?BEEP		; fait un "mauvais" bruit	LOAD.W	D3,D4	SR.W	D3,#8	COMP.B	D3,#ERPFU/H'100	; erreur interne  PLAN ?	JUMP,NE	50$		; non => 50$				; oui =>	LOAD.L	A3,#R16"TAERR20$:	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- saute comme .EVEN	LOAD.L	A3,D3	TEST.W	(A3+)		; fin de la table ?	JUMP',EQ 40$		; oui => 40$	COMP.W	D4,(A3)-2	; erreur trouve ?	JUMP',EQ 40$		; oui => 40$30$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE	30$	JUMP	20$40$:	CALL	CWMO		; remet la souris normale	CALL	SRMO		; remet la flche normale (plus de rticule)	TSET.L	D2:#BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur	JUMP',EQ 80$	TCLR.L	D2:#BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur	JUMP'	80$50$:	CALL	CWMO		; remet la souris normale	CALL	SRMO		; remet la flche normale (plus de rticule)	TSET.L	D2:#BDBSAV	; D2 <-- mode	LOAD.W	D7,D4		; D7 <-- no de l'erreur	DBOX_	MERROR		; affiche l'erreur PSos	JUMP',EQ 80$	TCLR.L	D2:#BDBSAV	; D2 <-- mode	LOAD.W	D7,D4		; D7 <-- no de l'erreur	DBOX_	MERROR		; affiche l'erreur PSos80$:	CALL	DBOXREFAIT	; remet les soft-keys90$:	POPM.L	D3,D4,D7,A3	RETTAERR:	.W	ERPFU	.ASCIZ	/ Base de donns pleine ! /	.EVEN	.W	ERPEM	.ASCIZ	/ Base de donnes vide ! /	.EVEN	.W	ERPTB	.ASCIZ	/ Dbordement de la fentre ! /	.EVEN	.W	ERPNF	.ASCIZ	/ Pas trouv ! /	.EVEN	.W	ERPZV	.ASCIZ	/ Zone vide ! /	.EVEN	.W	ERTGC	.ASCIZ	/ Trop de caractres diffrents ! /	.EVEN	.W	ERPBN	.ASCIZ	/ Bloc-notes vide ! /	.EVEN	.W	ERPLI	.ASCIZ	/ Limite atteinte ! /	.EVEN	.W	ERSCA	.ASCIZ	/ Seulement avec loupe 1:1 ! /	.EVEN	.W	ERFIT	.ASCIZ	/ Il y a un trou ... /	.EVEN	.W	ERFIM	.ASCIZ	/ Forme trop complique ! /	.EVEN	.W	ERSPL	.ASCIZ	/ Pas assez de points ! /	.EVEN	.W	ERMDC	.ASCIZ	/ Impossible en mode efface ! /	.EVEN	.W	ERBGC	.ASCII	/ Un ou plusieurs caractres  <CR>/	.ASCIZ	/ n'ont pas pu tre chargs ! /	.EVEN	.W	ERPLO	.ASCIZE	/ Le plotter n'est pas prt ! /	.W	ERRSYS	.ASCIZE	/ Systme trop ancien ! /	.W	0		; <-- terminateur	.ASCIZ	/ numro inconnu ! /	.EVEN	.END