	.SBTTL	PLANAGENC	; 23 juillet 87 Sp.;OGCFLG	devrait tre ds. DGENC BGCAJ	=	7	; bit nouveau: lors de 'ajoute' lit d'abord			; tous les genc et teste ensuite si pas utilis			; pour l'effacer si tel est le cas;*************** _PLANA_DBGENC:;***************;--------\; ASKGC   >;========/;; Demande un gnrateur de caractre;; in	D6.W	no. genc actuel; out	D6.W	no. genc nouveau;	D7.W	erreur; mod	D7.WASKGC:	PUSHM.L	D0..D5,A0..A510$:;;;	CALL	SRMO		; remet la flche relle (plus le rticule)	LOAD.L	D4,(A5)+OFAGC	; D4 <-- fanions	LOAD.L	A4,#(A5)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A2,(A5)+OPDDIS	; A2 <-- ^descripteur de la fentre;;;PUSH.L	A5;;;CLR.L	D1;;;LOAD.W	D1,#OGCLIST;;;ADD.L	A5,D1	LOAD.L	A1,#(A5)+OGCLISTPUSH.L	A5	LOAD.L	A5,A1;;;	LOAD.L	A5,#(A6)+OGCLIST; A5 <-- ^liste des gencars sur disque	LOAD.W	D5,#MAXGENC*3	; D5 <-- lg pour la liste	LOAD.L	D1,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DGENC_	MODIF		; modifie un/qq gencar(s) ...POP.L	A5	JUMP,NE 90$	LOAD.L	(A5)+OFAGC,D4	; mm. derniers fanions utiliss	COMP.W	D3,#F1	JUMP',EQ 30$	COMP.W	D3,#F4	JUMP',EQ 50$	JUMP'	80$30$:				; MODIFIE =>	SL.L	D2,#8		; D2 <-- ancien "fst-"	LOAD.L	A0,A4		; A0 <-- ^nouveau gencar	CALL	MODGENCAR	; modifie partout	JUMP	10$50$:				; SUPPRIME =>	LOAD.L	D2,(A4)+OGCCOD	SL.L	D2,#8		; D2 <-- ancien "fst-"	LOAD.L	A0,A4	CALL	DBOXGCOKAN	; demande confirmation si utilis	JUMP,NE	10$	COMP.W	D3,#F4		; ds. liste	JUMP,EQ	52$	COMP.W	D3,#F7		; ds. liste et PLAN	JUMP,EQ	51$	COMP.W	D3,#F1		; ds. PLAN	JUMP,NE	10$	CALL	KILGENCAR	JUMP	10$51$:	CALL	KILGENCAR	; supprime partout ds. PLAN52$:	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A5)+OBUGC	DGENC_	KILL		; libre le gencar	JUMP',NE 90$	TCLR.B	(A4)+OGCFLG:#BGCUSE ; signal gencar libre	JUMP	10$; Modifie le caractre frapp en fonction du fanion allum.80$:	TEST.L	D4		; un fanion allum ?;	JUMP',EQ 90$		; non => 90$jump',eq	85$	LOAD.W	D3,#-182$:	INC.W	D3		; D3 <-- compte le rang du bit dans D4	RR.L	D4	JUMP,CC 82$	LOAD.W	D4,D3	LOAD.L	A0,#(A5)+OBUGC	MUL.WU	D4,#LGGC	ADD.L	A0,D4	TEST.B	(A0)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BS 85$		; oui => 85$	CALL	GGETPGC		; A0 <-- ^gencar actuel	TEST.B	(A0)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BS 90$		; oui => 90$	CLR.W	D3		; D3 <-- frappe avec "Fond"85$:;;;	LOAD.W	(A6)+OTEXTE,D3LOAD.W	D6,D390$:	PUSH.W	D7	TCLR.B	(A5)+OFLAGS:#BMDBOXLOAD.L	A0,(A5)+OADBREF;;;	CALL	DBOXREFAIT	; remet les soft-keysCALL	(A0)	LIB	?AFTIM	.B	NOCURS,0	; plus de curseur	.EVEN;;;	CALL	INIBAS		; refait le bas;;;	CALL	CRMO		; enlve la flche relle (met le rticule)	POP.W	D7	POPM.L	D0..D5,A0..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; GGETPGC  >;=========/; Donne le ^au gencar choisi dans le buffer des gencars.; in	D6.W	no. genc; out	A0.L	^gencar; mod	A0.LGGETPGC:	PUSH.L	D6	LOAD.L	A0,#(A5)+OBUGC;;;	LOAD.W	D0,(A6)+OTEXTE	MUL.WU	D6,#LGGC	ADD.L	A0,D6	POP.L	D6	RET;--- pour DBOX_GCOKANBGCUNIQUE	= 8BGCLISTE	= 0BGCPLAN		= 1;-----;-----------\\; DBOXGCOKAN >;===========/; Demande confirmation pour suppression de genc utilis.; in	D2.L	genc  supprimer "fst-";	A0.L	^genc  supprimer; out	D3.W	rponse F1=ds. PLAN;			F4=ds. liste;			F7=ds. PLAN et liste;	D7.W	erreur et rien du tout; mod	D3.L, D7.WDBOXGCOKAN:	PUSHM.L	D0..D2,D4..D6,A0..A5	PUSH.L	D2			; Y a-t-il des caractres ds PLAN ?	LOAD.L	D6,D2		; D6 <-- "fstx"  modifier	CLR.B	D6		; D6 <-- "fst-"  modifier	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP,NE	6$1$:	LOAD.L	A3,A4		; A3 <-- ^lment actuel	CALL	NXTBASE		; A4 <-- ^lment suivant	EX.L	A3,A4		; A4 <-- ^act, A3 <-- ^suivant	PUSH.W	D7	CALL	PREND		; registres <-- objet	COMP.B	D0,#OBJTEXT	; caractre ?	JUMP',NE 4$		; non => 4$	LOAD.L	D5,D3	CLR.B	D5	COMP.L	D5,D6		; est-ce l'ancien gencar ?	JUMP',NE 4$		; non => 4$				; oui =>	POP.W	D7		; objet trouv	LOAD.W	D7,#-1	JUMP	9$		; => demander confirmation4$:	POP.W	D7	LOAD.L	A4,A3		; A4 <-- ^lment suivant	TEST.W	D7	JUMP,EQ	1$6$:	CLR.W	D7		; pas de car trouvs, supprimer	LOAD.W	D3,#F4	POP.L	D0		; bidon !	JUMP	90$		; il n'y a pas de caractres9$:			; il en a, demander confirmation; DBOXGCOKAN		; vrifie si genc phys. existe plusieurs fois	LOAD.L	D4,#3		; flags PLAN et LISTE	PUSH.L	A0	TCLR.B	(A0)+OGCFLG:#BGCUSE	; simule inexistant	LOAD.L	D3,(A0)+OGCCOD	; D3 <-- "fst-"	SL.L	D3,#8	CALL	SRCPGC1	JUMP,EQ	19$		; trouv un autre	TSET.L	D4:#BGCUNIQUE	; pas trouv d'autre, unique !19$:	POP.L	A0	TSET.B	(A0)+OGCFLG:#BGCUSE	; remet en ordre flag	LIB	?BUZZ		; signal qq chose de spcial	LOAD.L	A2,#R16"TDBOX_GCOKAN	LOAD.W	D2,#2^BDBSAV	; D2 <-- modeLOAD.L	A0,(A5)+OADBOPEN;;;	CALL	DBOXOPEN	; ouvre la DBOXCALL	(A0)	JUMP,NE 95$	PUSH.L	D4	LOAD.W	D2,#2	DBOX_	GETCO	JUMP,NE	95$	LIB	?SETCURS	POP.L	D4	POP.L	D2		; "fst-"	EX.L	D5,D2		; D5 <-- "fst-"	CALL	AFFGCP		; affiche genc phys.	EX.L	D5,D2				; EDITE DBOX20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_GCOKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#END	JUMP',EQ 50$	COMP.W	D3,#CR	JUMP',EQ 40$	COMP.B	D3,#201		; flags ok.	JUMP,EQ	20$;	COMP.B	D3,#200		; fait bip et rdite	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; OK, supprime les caractres	DBOX_	CLOSE	CLR.W	D7	COMP.B	D4,#1	JUMP,NE	41$	LOAD.W	D3,#F4		; ds. liste	JUMP	90$41$:	COMP.B	D4,#2	JUMP,NE	42$	LOAD.W	D3,#F1		; ds. PLAN	JUMP	90$42$:	COMP.B	D4,#3	JUMP,NE	89$	LOAD.W	D3,#F7		; ds. liste et PLAN	JUMP	90$50$:				; ANNULE;;;	CALL	DBOXCLOSE	; ferme la DBOXLOAD.L	A0,(A5)+OADBCLOSECALL	(A0)89$:	LOAD.W	D7,#-1		; rien du tout90$:	POPM.L	D0..D2,D4..D6,A0..A5	TEST.W	D7		; retour EQ/NE	RET95$:	POP.L	D0		; bidon !;;;	CALL	IOERROR		; affiche v. erreur	JUMP	90$AFFGCP:;; affiche genc fst- en clair; in	D5.L	fst-; out	-; mod	D7.W;	PUSHM.L	D4,A3	LOAD.L	D4,D5	SR.L	D4,#8	LOAD.L	A3,#(A5)+OBWRITE	DGENC_	PUT	LIB	?AFTEXT	POPM.L	D4,A3	RETDOKGC:	COMP.B	D4,#1		; suppression ds. liste seulement?	JUMP,NE	90$			; non --> 90$				; oui	TEST.L	D4:#BGCUNIQUE	; seul genc phys. ds. liste?	JUMP,BC	90$			; non --> 90$	TCLR.L	D4:#BGCLISTE		; oui, efface flag	CLR.W	D3	RET			; retour avec D3 <-- 0 pour refus (bip)90$:	LOAD.B	D3,#201		; retour avec D3 <-- 201 pour ok.	RETTDBOX_GCOKAN:	.W	10$-TDBOX_GCOKAN	.W	MENU_OKAN-TDBOX_GCOKAN	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Il y a des caractres crit avec"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"     le gnrateur "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCR,ODBCR	.B	ODBSQUARE,BGCPLAN!2^7!2^6,0,201	.ASCIZ	" supprime les car. dans PLAN"	.B	ODBCR	.B	ODBSQUARE,BGCLISTE!2^6!2^7,0,200	.ASCIZ	" supprime dans la liste"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"        "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	0	.EVEN;----------\; MODGENCAR >;==========/; Modifie tous les caractres d'un gencar.; in	D2.L	gencars  modifier "fst-";	A0.L	^nouveau gencar; out	-; mod	D7.WMODGENCAR:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A4,A0	LOAD.L	D6,D2		; D6 <-- "fstx"  modifier	CLR.B	D6		; D6 <-- "fst-"  modifier	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP,NE	90$	CALL	SWMO		; met la souris "en attente"	PUSH.W	#0		; pas encore d'objets modifis10$:	CALL	PREND		; registres <-- objet	COMP.B	D0,#OBJTEXT	; caractre ?	JUMP',NE 50$		; non => 50$	LOAD.L	D5,D3	CLR.B	D5	COMP.L	D5,D6		; est-ce l'ancien gencar ?	JUMP',NE 50$		; non => 50$				; oui =>	LOAD.B	D5,D3		; D5 <-- code du caractre	LOAD.L	D3,(A0)+OGCCOD	; D3 <-- nouveau "-fst"	SL.L	D3,#8		; D3 <-- nouveau "fst-"	LOAD.B	D3,D5		; D3 <-- nouveau "fstc"	CALL	MET		; objet <-- registres	INC.W	(SP)		; un objet modifi50$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$	POP.W	D0		; objet(s) modifi(s) ?	JUMP',EQ 90$		; non => 90$PUSH.B	(A5)+OFLAGSTSET.B	(A5)+OFLAGS:#BMDBOX	; forcer pour effacer et refaireLOAD.L	A0,(A5)+OADBREFCALL	(A0)POP.B	(A5)+OFLAGS;;	CALL	EFFACE		; efface tout;;	CALL	REFAIT		; puis refait tout proprement90$:	CALL	CWMO		; remet la souris normale	POPM.L	D0,D1,D2,D3,D4,D5,D6,A4,A0	RET;----------\; KILGENCAR >;==========/; Dtruit tous les caractres d'un gencar.; in	D2.L	gencars  supprimer "fst-"; out	-; mod	D7.WKILGENCAR:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4,A0	LOAD.L	D6,D2		; D6 <-- "fstx"  modifier	CLR.B	D6		; D6 <-- "fst-"  modifier	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP,NE	90$	CALL	SWMO		; met la souris "en attente"	PUSH.W	#0		; pas encore d'objets supprims10$:	LOAD.L	A3,A4		; A3 <-- ^lment actuel	CALL	NXTBASE		; A4 <-- ^lment suivant	EX.L	A3,A4		; A4 <-- ^act, A3 <-- ^suivant	PUSH.W	D7	CALL	PREND		; registres <-- objet	COMP.B	D0,#OBJTEXT	; caractre ?	JUMP',NE 50$		; non => 50$	LOAD.L	D5,D3	CLR.B	D5	COMP.L	D5,D6		; est-ce l'ancien gencar ?	JUMP',NE 50$		; non => 50$				; oui =>	CALL	CLOBASE		; supprime l'objet	INC.W	(SP)+2		; un objet supprim50$:	POP.W	D7	LOAD.L	A4,A3		; A4 <-- ^lment suivant	TEST.W	D7	JUMP,EQ	10$	POP.W	D0		; objet(s) supprim(s) ?	JUMP',EQ 90$		; non => 90$PUSH.B	(A5)+OFLAGSTSET.B	(A5)+OFLAGS:#BMDBOX	; forcer pour effacer et refaireLOAD.L	A0,(A5)+OADBREFCALL	(A0)POP.B	(A5)+OFLAGS;;	CALL	EFFACE		; efface tout;;	CALL	REFAIT		; puis refait tout proprement90$:	CALL	CWMO		; remet la souris normale	POPM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4,A0	RETTKEY_GCOKAN:	.W	200,201,0		DOKGC-TKEY_GCOKAN	.W	END,F0,F13,F14,F15,0	DOKANNULE-TKEY_GCOKAN	.W	CR,F1,F2,F3,0		DOKOK-TKEY_GCOKAN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_GCOKAN	.W	0	.END