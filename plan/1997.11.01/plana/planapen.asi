		.SBTTL	PLANAPEN		; 12 juillet 87 Sp.;*************** _PLANA_DBPEN:;***************;---------- DBOXPEN:;----------;; Choix d'un pinceaux.;; in	D1.W	no. du trait;; out	D1.W	no. du trait;	NE	modif. pas visible ds. fentre;	EQ	modif. visible ds. fentre, refaire cran;; mod	D1.W,D7.W	PUSHM.L	D0,D2..D4,A0..A4;;;	CALL	_CWMO		; remet souris normale;;;	CALL	_SRMO		; remet la flche			; sauver les traits actuels			; pour comparaison par la suite	LOAD.W	D0,#PENMAX	LOAD.L	A3,#(A5)+OBUPEN	LOAD.L	A4,#(A5)+OBUPENS5$:	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	LOAD.W	(A4+),(A3+)	DEC.W	D0	JUMP',NE 5$	LOAD.L	D2,#2^BDBSAV		; D2 <-- fanions	JUMP,NE	6$	TSET.L	D2:#BMATX16$:	TCLR.B	(A5)+OFLAGS:#BMDBOX	; initialise flag DBOX dmoli;;;	LOAD.W	D4,(A6)+OTRAIT		; D4 <-- no. de trait	LOAD.W	D4,D1	SR.W	D4,#2	LOAD.L	A0,(A5)+OPDDIS		; A0 ^descripteur de fentre	LOAD.L	A2,#0			; pas d'icnes	LOAD.L	A3,#R16"TPTEXTE		; A3 ^textes des ODBCIRCLE	LOAD.L	A4,#(A5)+OBUPEN		; A4 ^traits	JUMP	10$8$:	TCLR.L	D2:#BDBSAV	TSET.B	(A5)+OFLAGS:#BMDBOX	; signal DBOX a dmoli	.W	DESSIN_DEDIT	JUMP,EQ	11$	JUMP	95$10$:	TSET.L	D2:#BMATX1	.W	DESSIN_DEDIT			; dition des traits	COMP.W	D7,#ERNEMEM	JUMP,EQ	8$11$:	COMP.B	D3,#F0			; ANNULE ?	JUMP,EQ	90$			; oui => 90$	COMP.B	D3,#F1			; D'ACCORD ?	JUMP,EQ	20$			; oui => 20$35$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	10$			; redite ...20$:				; D'ACCORD	LOAD.W	D3,D4			; D3 <-- no. trait	MUL.WU	D3,#8+2			; ... dplacement	TEST.L	D2:#BMATX2		; trait rapide ?	JUMP,BC	80$	COMP.B	(A4)+(D3)+8,#H'FF	; traitill ?	JUMP,NE	36$			; oui ...	CLR.L	D1			; init D1;	COMP.L	(A4)+(D3),#0		; trait rapid 1 ?;	JUMP,NE	25$;	COMP.L	(A4)+(D3)+4,#H'08000000;	JUMP,NE	25$;	COMP.B	(A4)+(D3)+8,#H'FF;	JUMP,EQ	70$25$:	INC.B	D1	COMP.L	(A4)+(D3),#H'00000018	; trait rapid 2 ?	JUMP,NE	30$	COMP.L	(A4)+(D3)+4,#H'18000000	JUMP,EQ	60$;	JUMP,NE	30$;	COMP.B	(A4)+(D3)+8,#H'FF;	JUMP,EQ	60$30$:	INC.B	D1	COMP.L	(A4)+(D3),#H'00001C3E	; trait rapid 5 ?	JUMP,NE	36$	COMP.L	(A4)+(D3)+4,#H'3E3E1C00	JUMP,EQ	60$;	JUMP,NE	35$;	COMP.B	(A4)+(D3)+8,#H'FF;	JUMP,EQ	50$36$:	CLR.L	D2	JUMP	35$			; retour  la DBOX !50$:				; trait rapide 560$:				; trait rapide 2;;;	LOAD.W	(A6)+OTRAIT,D1	JUMP	90$80$:	TEST.L	(A4)+(D3)		; le bon trait, teste si vide	JUMP,NE	85$			; non => 85$	TEST.L	(A4)+(D3)+4		; oui, suite aussi vide ?	JUMP,EQ	90$			; oui => 90$85$:	TEST.B	(A4)+(D3)+8		; MAPTT vide ?	JUMP,EQ	90$			; oui --> 90$	CLR.L	D1			; toujours tester si rapid 1	COMP.B	(A4)+(D3)+8,#H'FF	JUMP,NE	86$			; non traitill	COMP.L	(A4)+(D3),#0		; bonne matrice ?	JUMP,NE	86$			; non	COMP.L	(A4)+(D3)+4,#H'08000000	JUMP,EQ	70$			; oui86$:	LOAD.W	D1,D4	SL.W	D1,#2	OR.B	D1,#B'11		; D2 <-- bits: mode <1><1>70$:;;;	LOAD.W	(A6)+OTRAIT,D1		; sauve no. trait				; trait modifi ?	LOAD.L	A4,#(A5)+OBUPEN		; A4 ^traits	LOAD.L	A3,#(A5)+OBUPENS	; A3 ^traits sauvs	ADD.L	A3,D3	ADD.L	A4,D3	COMP.L	(A3+),(A4+)	; le mme ?	JUMP,NE	87$		; non ...	COMP.L	(A3+),(A4+)	JUMP,NE	87$		; oui, le mme	COMP.W	(A3+),(A4+)	JUMP,EQ	90$87$:				; oui, trait modifi, dans la fentre?	SR.B	D1,#2		; D1 <-- no. trait	LOAD.L	D3,(A5)+OOWDOY	; D3 <-- coin inf/gauche visible	LOAD.L	D4,D3	ADD.W	D4,(A5)+OSWDOX	SWAP.W	D4	ADD.W	D4,(A5)+OSWDOY	; D4 <-- coin sup/droite visible	SWAP.W	D4	CALL	IFPEN	JUMP,NE	90$		; pas dans la fentre	TSET.B	(A5)+OFLAGS:#BMDBOX	; dans la fentre ...				; trait non-modifi90$:LOAD.W	D7,#-1	TEST.B	(A5)+OFLAGS:#BMDBOX	JUMP,BC	95$CLR.W	D7;;;	CALL	_MAJCADRE;;;	CALL	REFAIT95$:PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,0	.EVEN;;;	CALL	_AFMENU		; menu standard;;;	CALL	_CRMO		; met v. rticule;;;	CLR.W	D7POP.W	D7	POPM.L	D0,D2..D4,A0..A4TEST.W	D7	RET; *** prov. _PLANA_IIPEN:; *************;--------\\; IIPEN   >;========/; Initialise une translation nulle avant la lecture; d'un plan.; in	-; out	-; mod	-IIPEN:	PUSHM.L	D2,A4	LOAD.L	A4,#(A5)+OUSPEN	CLR.W	D2		; D2 <-- numro 1er10$:	LOAD.B	(A4+),D2	; met 0,1,2,3 ...	INC.W	D2		; D2 <-- numro suivant	COMP.W	D2,#PENMAX	JUMP,LO	10$	POPM.L	D2,A4	RET; ** prov._PLANA_IMPEN:;************;--------\\; IMPEN   >;========/; Mmorise une ventuelle translation de numro de pinceau; lors de la lecture d'un plan.; in	D3/4.L	pinceau;	D5.W	chelle/map;	D1.B	numro; out	-; mod	-IMPEN:	PUSHM.L	D1,D2,D3,D4,A4	CALL	SRCPEN		; D2 <-- pinceau existe dj ?	JUMP',EQ 50$		; oui => 50$				; non =>	PUSHM.L	D3,D4	CLR.L	D3		; D3 <-- coin inf/gauche plan	LOAD.L	D4,(A5)+OMWDOY	; D4 <-- coin sup/droite plan	CALL	IFPEN		; pinceau utilise dans plan ?	POPM.L	D3,D4	JUMP',EQ 30$		; oui => 30$				; non =>	LOAD.B	D2,D1		; D2 <-- no du mme	CLR.W	D7		; D7 <-- ok	JUMP'	50$30$:	PUSHM.L	D3,D4,D5	CLR.L	D3	CLR.L	D4	CLR.W	D5	CALL	SRCPEN		; D2 <-- cherche pinceau vide	POPM.L	D3,D4,D5	JUMP',EQ 50$		; ok => 50$				; tout plein =>	LOAD.W	D2,#PENDEF	; D2 <-- pinceau par dfaut !50$:	LOAD.L	A4,#(A5)+OUSPEN	AND.W	D1,#H'FF	LOAD.B	(A4)+(D1.W),D2	TEST.W	D7		; emplacement trouv ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A4,#(A5)+OBUPEN	; A4 <-- ^pinceaux	MUL.WU	D2,#8+2	ADD.L	A4,D2	LOAD.L	(A4)+0,D3	; met nouveau pinceau	LOAD.L	(A4)+4,D4	LOAD.W	(A4)+8,D5	; met chelle/map90$:	POPM.L	D1,D2,D3,D4,A4	RET;--------\\; ITPEN   >;========/; Translate un numro de pinceau lors de la lecture d'un plan.; in	D0.W	objet;	D1.B	trait actuel; out	D1.B	nouveau trait; mod	D1.WITPEN:	PUSH.L	A4	COMP.B	D0,#OBJSURF	; objet surface ?	JUMP',EQ 90$		; oui => 90$	COMP.B	D0,#OBJTEXT	; objet texte ?	JUMP',EQ 90$		; oui => 90$	COMP.B	D1,#3		; trait standard ?	JUMP',LO 90$		; oui => 90$	LOAD.L	A4,#(A5)+OUSPEN	SR.B	D1,#2	AND.W	D1,#H'FF	LOAD.B	D1,(A4)+(D1.W)	; D1 <-- nouveau numro	SL.B	D1,#2	OR.B	D1,#B'1190$:	POP.L	A4	RET;--------\\; SRCPEN  >;--------/; Cherche si un pinceau existe dj.; in	D3/4.L	pinceau;	D5.W	chelle/map (si zro => trouve tout); out	D2.W	numro;	D7.W	erreur; mod	D2.W, D7.WSRCPEN:	PUSH.L	A3	CLR.W	D7		; D7 <-- trouv	LOAD.L	A3,#(A5)+OBUPEN	; A3 <-- ^pinceaux	CLR.W	D2		; D2 <-- numro 1er10$:	COMP.L	D3,(A3)+0	JUMP',NE 20$	COMP.L	D4,(A3)+4	JUMP',NE 20$	TEST.W	D5		; trouve n'importe quel map ?	JUMP',EQ 90$		; oui => 90$	COMP.W	D5,(A3)+8	JUMP',EQ 90$20$:	LOAD.L	A3,#(A3)+8+2	; A3 <-- ^pinceau suivant	INC.W	D2		; D2 <-- numro suivant	COMP.W	D2,#PENMAX	JUMP,LO	10$	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;--------\; IFPEN   >;========/; Cherche si un pinceau est utilise dans une zone.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D1.B	numro pinceau cherch; out	D7.W	trouv ou pas; mod	D7.WIFPEN:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A4	LOAD.B	D6,D1		; D6 <-- no pinceau	CALL	ORDONNE	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP',NE 90$10$:	CALL	FDETECTE	; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	PUSHM.L	D3,D4	CALL	PREND		; registres <-- objet	POPM.L	D3,D4	COMP.B	D0,#OBJSURF	; objet trame ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D0,#OBJTEXT	; objet texte ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D1,#3		; trait avec le pinceau ?	JUMP',LO 20$		; non => 20$	SR.B	D1,#2		; D1 <-- no pinceau	COMP.B	D1,D6		; bon pinceau ?	JUMP',EQ 90$		; oui => 90$20$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$90$:	POPM.L	D0,D1,D2,D3,D4,D5,D6,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DEFPEN   >;=========/; Remet tous les pinceaux par dfaut.; in	-; out	-; mod	-DEFPEN:	PUSHM.L	D3,A3,A4	LOAD.L	A4,#R16"TPENS	LOAD.L	A3,#(A5)+OBUPEN	LOAD.W	D3,#PENMAX*(8+2)10$:	LOAD.B	(A3+),(A4+)	DEC.W	D3	JUMP,NE	10$	POPM.L	D3,A3,A4	RETTPTEXTE:	.ASCIZ	/<BS>pinceaux/	.ASCIZ	/<BS>__2, __5/	.ASCIZ	//	.EVEN; Pinceaux; --------TPENS:				; 0	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'11111111	.B	2				; 1	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001111	.B	2				; 2	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000011	.B	2				; 3	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00010001	.B	1				; 4	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00100111	.B	2				; 5	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00011000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'11111111	.B	2				; 6	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00011000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001111	.B	2				; 7	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00011000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000011	.B	2				; 8	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00011000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00010001	.B	1				; 9	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00011000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00100111	.B	2				; 10	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00111100	.B	B'00111100	.B	B'00011000	.B	B'00000000	.B	B'00000000	.B	B'11111111	.B	2				; 11	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00111100	.B	B'00111100	.B	B'00011000	.B	B'00000000	.B	B'00000000	.B	B'00001111	.B	2				; 12	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00111100	.B	B'00111100	.B	B'00011000	.B	B'00000000	.B	B'00000000	.B	B'00000011	.B	2				; 13	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00111100	.B	B'00111100	.B	B'00011000	.B	B'00000000	.B	B'00000000	.B	B'00000001	.B	1				; 14	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00111100	.B	B'00111100	.B	B'00011000	.B	B'00000000	.B	B'00000000	.B	B'00100111	.B	2				; 15	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'01111110	.B	B'00111100	.B	B'11111111	.B	4				; 16	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'01111110	.B	B'00111100	.B	B'00001111	.B	4				; 17	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'01111110	.B	B'00111100	.B	B'00000011	.B	4				; 18	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'01111110	.B	B'00111100	.B	B'00000001	.B	2				; 19	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'01111110	.B	B'00111100	.B	B'00100111	.B	4				; 20	.B	B'00000000	.B	B'00011000	.B	B'00011000	.B	B'01111110	.B	B'01111110	.B	B'00011000	.B	B'00011000	.B	B'00000000	.B	B'00000001	.B	1				; 21	.B	B'00111000	.B	B'01000100	.B	B'10000010	.B	B'10000010	.B	B'10000010	.B	B'01000100	.B	B'00111000	.B	B'00000000	.B	B'00000001	.B	1				; 22	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00101010	.B	B'00011100	.B	B'00101010	.B	B'00001000	.B	B'00000000	.B	B'00000001	.B	1				; 23	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	1				; 24	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	1	.B	B'00000000	; 25	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	1	.B	B'00000000	; 26	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	1	.B	B'00000000	; 27	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	1	.EVEN	.END