		.SBTTL	PLANAGRA		; 28 juin 87 Sp.;CCC	=	modifications pour; affichage couleur 18 avril 1988; routines PUSHCOLOR, SETCOLOR, POPCOLOR; codes driver utiliss:; COLORSR; COLOROP; COLOROPPUSH; COLOROPPOP;CCC;----------- PUSHCOLOR:;-----------; sauve la couleur sur stack;	PUSHM.L	D3,A3	LOAD.L	A3,#(A5)+OBWRITE	LOAD.B	(A3)+0,#COLOROP		LOAD.B	(A3)+1,#COLOROPPUSH	load.b	(a3)+2,#modgra	load.b	(a3)+3,#graclip2	load.w	d3,#4;	LOAD.W	D3,#2		; nbr de bytes	CALL	WRDIS		; envoi rapide	POPM.L	D3,A3	RET;CCC;---------- SETCOLOR:;----------; met la couleur selon D2.W bits 4..7 !;	PUSHM.L	D2,D3,A3	AND.L	D2,#H'FF	SR.L	D2,#4	INC.L	D2		; noir ds. PLAN = 0, driver = 1	ADD.L	D2,#COLOR_PLBASE	;H'40*H'100	; code H'4000		LOAD.L	A3,#(A5)+OBWRITE+1	LOAD.B	(A3)+0,#COLORSR	LOAD.L	(A3)+1,D2	LOAD.W	D3,#5		; D3 <-- nbr de bytes	CALL	WRDIS		; envoi rapide	POPM.L	D2,D3,A3	RET;CCC;---------- POPCOLOR:;----------; remet la couleur sur 'stack';	PUSHM.L	D3,A3	LOAD.L	A3,#(A5)+OBWRITE	LOAD.B	(A3)+0,#COLOROP	LOAD.B	(A3)+1,#COLOROPPOP	load.b	(a3)+2,#modgra	load.b	(a3)+3,#graclip	load.w	d3,#4;	LOAD.W	D3,#2		; nbr de bytes	CALL	WRDIS		; envoi rapide	POPM.L	D3,A3	RET;---------------- _PLANA_DESSINE:;================;*);--------\; DESSINE >;========/; Dessine un objet quelconque.; in	D0.W	type de l'objet;	D3.L	premier paramtre;	D4.L	deuxime paramtre;	D2.W	mode/couleur de dessin;	D1.W	mode de trait;	A5.L	^variables PLANA; out	D7.W	erreur; mod	D7.W et D4.L pour ..HV uniquementDESSINE:	COMP.B	D0,#OBJTRECT	JUMP,EQ	TRECTANGLE	PUSHM.L	D3,D4,D5,D6;CCC	CALL	PUSHCOLOR	CLR.W	D7		; D7 <-- ok	LOAD.B	D5,D2	SR.B	D5,#4		; D5 <-- couleur	comp.b	d5,#H'F		; sans test visibilit	jump,eq	01$	LOAD.W	D6,(A5)+OCOULEUR	TEST.L	D6:D5		; couleur visible ?	JUMP,BC	90$		; non => 90$01$:;CCC	CALL	SETCOLOR	COMP.B	D0,#OBJLIGNE	JUMP',EQ 10$	COMP.B	D0,#OBJDROITE	JUMP',EQ 20$	COMP.B	D0,#OBJDHV	JUMP',EQ 30$	COMP.B	D0,#OBJELASTIQUE	JUMP',EQ 20$	COMP.B	D0,#OBJEHV	JUMP',EQ 30$	COMP.B	D0,#OBJFLECHE	JUMP',EQ 20$	COMP.B	D0,#OBJFHV	JUMP',EQ 30$	COMP.B	D0,#OBJCERCLE	JUMP',EQ 40$	COMP.B	D0,#OBJARC	JUMP',EQ 45$	COMP.B	D0,#OBJELLIPSE	JUMP',EQ 47$	COMP.B	D0,#OBJARCELL	JUMP',EQ 48$	COMP.B	D0,#OBJRECT	JUMP',EQ 50$	COMP.B	D0,#OBJSURF	JUMP',EQ 60$	COMP.B	D0,#OBJTEXT	JUMP',EQ 70$	JUMP'	90$10$:				; ligne =>	CALL	LIGNE	JUMP'	90$20$:				; droite =>	CALL	DROITE	JUMP'	90$30$:				; hor-vert =>	CALL	DHV	LOAD.L	(SP)+4,D4	; corriger l'arrive pour ...HV	JUMP'	90$40$:				; cercle =>	CALL	CERCLE	JUMP'	90$45$:				; arc de cercle =>	CALL	ARC8	JUMP'	90$47$:				; ellipse =>	CALL	ELLIPSE	JUMP'	90$48$:				; arc d'ellipse =>	CALL	ARCELL	JUMP'	90$50$:				; rectangle =>	CALL	RRECTANGLE	JUMP'	90$60$:				; surface =>	CALL	SURFACE	JUMP'	90$70$:				; texte =>	CALL	TEXTE;	JUMP'	90$90$:;CCC	CALL	POPCOLOR	POPM.L	D3,D4,D5,D6	TEST.W	D7		; retour EQ/NE	RET;--------\; DHV     >;========/; Dessine une ligne horizontale ou verticale.; in	D3.L	coordonne point de dpart;	D4.L	coordonne point d'arrive;	D2.B	mode de dessin;	D1.B	mode du trait;	D0.W	objet; out	D4.L	arrive corrige;	D7.W	erreur; mod	D4.L, D7.WDHV:	PUSHM.L	D5,D6	LOAD.W	D5,D3	SUB.W	D5,D4	JUMP',NC 10$	NEG.W	D5		; D5 <-- |dxx|10$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D6,D3	SUB.W	D6,D4	JUMP',NC 20$	NEG.W	D6		; D6 <-- |dyy|20$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D5,D6		; comp |dxx| , |dyy|	JUMP',LO 30$				; horizontale =>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- Y arrive := Y dpart	SWAP.W	D4	SWAP.W	D3	JUMP'	40$30$:				; verticale =>	LOAD.W	D4,D3		; D4 <-- X arrive := X dpart40$:	CALL	DROITE		; dessine une ligne	POPM.L	D5,D6	RET;--------\; LIGNE   >;========/; Dessine une ligne depuis le point de dpart jusqu'au; point d'arrive. Le dernier point (sur l'arrive) n'est; jamais dessin.; in	D3.L	coordonne point de dpart;	D4.L	coordonne point d'arrive;	D2.B	mode de dessin;	D1.B	mode du trait;	D0.W	objet; out	D7.W	erreur; mod	D7.WLIGNE:	PUSHM.L	D0,D3,D4	CALL	CLIPSEG		; clipping ?	JUMP',NE 90$	CALL	SCASEG		; agrandi/diminue	CALL	YINVERSE	; D4 <-- inverse le sens de Y	EX.L	D3,D4	CALL	YINVERSE	; D3 <-- inverse le sens de Y	EX.L	D4,D3	CALL	SEGMENT		; trace un segment de droite90$:	POPM.L	D0,D3,D4	RET;--------\; DROITE  >;========/; Dessine une droite, toujours dans la mme orientation,; quelques soient les points de dpart et d'arrive.; in	D3.L	coordonne point de dpart;	D4.L	coordonne point d'arrive;	D2.B	mode de dessin;	D1.B	mode du trait;	D0.W	objet; out	D7.W	erreur; mod	D7.WDROITE:	PUSHM.L	D0,D3..D6	COMP.B	D0,#OBJFLECHE	; flche ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D0,#OBJFHV	JUMP',EQ 50$	CALL	CLIPSEG		; clipping ?	JUMP,NE 90$	CALL	SCASEG		; agrandi/diminue	CALL	YINVERSE	; D4 <-- inverse le sens de Y	EX.L	D3,D4	CALL	YINVERSE	; D3 <-- inverse le sens de Y	EX.L	D4,D3	COMP.L	D3,D4		; orientation standard ?	JUMP',LO 20$		; oui => 20$	EX.L	D3,D4		; non => change20$:	CALL	SEGMENT		; trace un segment de droite	JUMP'	90$50$:				; flche =>	CALL	CLIPFLECHE	; clipping ?	JUMP',NE 90$	CALL	SCASEG		; agrandi/diminue	CALL	YINVERSE	; D4 <-- inverse le sens de Y	EX.L	D3,D4	CALL	YINVERSE	; D3 <-- inverse le sens de Y	EX.L	D4,D3;	CALL	OPWDOG		; utilise la swdo graphique	CALL	FLECHE		; dessine une jolie flche;	CALL	CLWDOG		; libre la swdo graphique90$:	POPM.L	D0,D3..D6	RET;--------\; SEGMENT >;--------/; Dessine un segment de droite d'aprs les coordonnes; physiques dans la fentre.; in	D3.L	coordonne physique point de dpart;	D4.L	coordonne physique point d'arrive;	D2.B	mode de dessin;	D1.B	mode du trait;	A5.L	^variables PLANA; out	D7.W	erreur; mod	D7.WSEGMENT:	PUSHM.L	D1,D2,D3,D4,D5,A3	LOAD.L	D5,D4		; D5 <-- coordonne d'arrive	CALL	CONVMD		; D2 <-- INV/SET/CLRDOT	CALL	CONVLT		; D1 <-- paisseur du trait	CALL	OPWDOG		; utilise la swdo graphique	LOAD.L	A3,#(A5)+OBWRITE+1	LOAD.B	(A3)+0,#DRAWSEG	LOAD.W	(A3)+1,D3	; <xx>	SWAP.W	D3	LOAD.W	(A3)+3,D3	; <yy>	SWAP.W	D3	SUB.W	D4,D3	LOAD.W	(A3)+5,D4	; <dxx>	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	LOAD.W	(A3)+7,D4	; <dyy>	LOAD.B	(A3)+9,D2	; <mode>	LOAD.W	D3,#10		; D3 <-- lg sans le dernier point	COMP.B	D1,#1	JUMP',NE 15$	COMP.B	D2,#SETDOT	; mode SETDOT/CLRDOT sans pinceau ?	JUMP',EQ 10$		; oui => 10$	COMP.B	D2,#CLRDOT	JUMP',NE 15$10$:	LOAD.B	(A3)+10,#DRAWDOT	LOAD.W	(A3)+11,D5	; <xx>	SWAP.W	D5	LOAD.W	(A3)+13,D5	; <yy>	LOAD.B	(A3)+15,D2	; <mode>	ADD.W	D3,#6		; D3 <-- ajoute lg pour dernier point15$:	CALL	WRDIS		; dessine une droite (et v. dernier point)	DEC.B	D1	JUMP,EQ 90$20$:	LOAD.W	D3,(A3)+5	; D3 <-- dX	TEST.W	D3	JUMP',PL 30$	NEG.W	D3		; D3 <-- !dX!30$:	LOAD.W	D4,(A3)+7	; D4 <-- dY	TEST.W	D4	JUMP',PL 35$	NEG.W	D4		; D4 <-- !dY!35$:	INC.W	(A3)+1		; descend origine en X	COMP.W	D3,D4		; compare !dX! et !dY!	JUMP',LS 50$	DEC.W	(A3)+1		; remonte origine en X	INC.W	(A3)+3		; descend origine en Y50$:	LOAD.W	D3,#1+8+1	CALL	WRDIS		; dessine deuxime droite	DEC.B	D1	JUMP,NE 20$90$:	CALL	CLWDOG		; libre la swdo graphique	POPM.L	D1,D2,D3,D4,D5,A3	RET;--------\\; FLECHE  >;========/; Dessine une flche. Le changement d'chelle et le clipping; sont dj faits !; in	D3.L	coordonne point de dpart (relle);	D4.L	coordonne point d'arrive (relle);	D2.B	mode de dessin;	D1.B	mode du trait;	D0.W	objet;	A5.L	^variables PLANA; out	-; mod	D7.WFLECHE:	PUSHM.L	D0,D3..D6,A4	LOAD.L	A4,#(A5)+OBUFLE	; A4 <-- ^flches	SR.W	D0,#8		; D0 <-- no de la flche	MUL.WU	D0,#4	ADD.L	A4,D0		; A4 <-- ^la bonne flche	TEST.B	(A4)+OFLEXT:#BFLEXT	JUMP,BS 50$				; FLECHE INTERIEURE =>	TEST.B	(A4)+OFLFOR:#BFLTRI	JUMP',BS 30$				; flche  deux droites (forme en "V") =>	CALL	SEGMENT		; trace ligne de base	TEST.B	(A4)+OFLEXT:#BFLD3	JUMP',BC 20$	PUSH.L	D4	CALL	CALIFLECHE	LOAD.L	D4,D5	CALL	SEGMENT	LOAD.L	D4,D6	CALL	SEGMENT	POP.L	D420$:	TEST.B	(A4)+OFLEXT:#BFLD4	JUMP,BC 90$	EX.L	D3,D4	CALL	CALIFLECHE	LOAD.L	D4,D5	CALL	SEGMENT	LOAD.L	D4,D6	CALL	SEGMENT	JUMP	90$30$:				; flche  3 droites (triangle) =>	PUSH.L	D3	PUSH.L	D4	TEST.B	(A4)+OFLEXT:#BFLD3	JUMP',BC 40$	PUSHM.L	D3,D4	CALL	CALIFLECHE	LOAD.L	(SP)+8+4,D7	; stack <-- modifie D3	LOAD.L	D4,D5	CALL	SEGMENT	LOAD.L	D4,D6	CALL	SEGMENT	LOAD.L	D3,D5	CALL	SEGMENT	POPM.L	D3,D440$:	TEST.B	(A4)+OFLEXT:#BFLD4	JUMP',BC 45$	EX.L	D3,D4	CALL	CALIFLECHE	LOAD.L	(SP)+0,D7	; stack <-- modifie D4	LOAD.L	D4,D5	CALL	SEGMENT	LOAD.L	D4,D6	CALL	SEGMENT	LOAD.L	D3,D5	CALL	SEGMENT45$:	POP.L	D4	POP.L	D3	CALL	SEGMENT		; trace ligne de base	JUMP	90$50$:				; FLECHE EXTERIEURE =>	TEST.B	(A4)+OFLFOR:#BFLTRI	JUMP',BS 70$				; flche  deux droites (forme en "V") =>	PUSH.L	D3	PUSH.L	D4	TEST.B	(A4)+OFLEXT:#BFLD3	JUMP',BC 60$	PUSHM.L	D3,D4	CALL	CALEFLECHE	LOAD.L	(SP)+8+4,D0	; stack <-- modifie D3	LOAD.L	D4,D5	CALL	SEGMENT	LOAD.L	D4,D6	CALL	SEGMENT	POPM.L	D3,D460$:	TEST.B	(A4)+OFLEXT:#BFLD4	JUMP',BC 65$	EX.L	D3,D4	CALL	CALEFLECHE	LOAD.L	(SP)+0,D0	; stack <-- modifie D4	LOAD.L	D4,D5	CALL	SEGMENT	LOAD.L	D4,D6	CALL	SEGMENT65$:	POP.L	D4	POP.L	D3	CALL	SEGMENT		; trace ligne de base	JUMP	90$70$:				; flche  3 droites (triangle) =>	CALL	SEGMENT		; trace ligne de base	TEST.B	(A4)+OFLEXT:#BFLD3	JUMP',BC 80$	PUSHM.L	D3,D4	CALL	CALEFLECHE	PUSH.L	D7	LOAD.L	D4,D5	CALL	SEGMENT	LOAD.L	D4,D6	CALL	SEGMENT	LOAD.L	D3,D5	CALL	SEGMENT	POP.L	D3	LOAD.L	D4,D0	CALL	SEGMENT	POPM.L	D3,D480$:	TEST.B	(A4)+OFLEXT:#BFLD4	JUMP',BC 90$	EX.L	D3,D4	CALL	CALEFLECHE	PUSH.L	D7	LOAD.L	D4,D5	CALL	SEGMENT	LOAD.L	D4,D6	CALL	SEGMENT	LOAD.L	D3,D5	CALL	SEGMENT	POP.L	D3	LOAD.L	D4,D0	CALL	SEGMENT;	JUMP	90$90$:	POPM.L	D0,D3..D6,A4	RET;------------------ _PLANA_CALIFLECHE:;------------------;*)		PLACE	[PLANOPBASE];-----------\\; CALIFLECHE >;-----------/; Calcul les coordonnes des trois points D5-D6-D7; pour une flche intrieure.;	               D5;	               |\;	               | \;	               |  \;	D4 +-----------+---> D3;	             D7|  //;	               | //;	               |//;	               D6; in	A4.L	^flche;	D3.L	point o mettre la flche (y;x);	D4.L	autre extrmit (y;x); out	D5.L	une extrmit;	D6.L	l'autre extrmit;	D7.L	point intermdiaire; mod	D5.L, D6.L, D7.LCALIFLECHE:	PUSHM.L	D0..D4	LOAD.W	D1,D4	SUB.W	D1,D3		; D1 <-- dx	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- dy	SWAP.W	D3	CLR.W	D4	LOAD.B	D4,(A4)+OFLLG	; D4 <-- longueur de la flche	CALL	D4SCALE		; D4 <-- tient compte de l'chelle	LOAD.W	D0,D4	CALL	PYTHAGORE	LOAD.L	D7,D3	ADD.W	D7,D1	SWAP.W	D7	ADD.W	D7,D2	SWAP.W	D7		; D7 <-- P7(y;x)	LOAD.B	D0,(A4)+OFLANG	; D0 <-- angle de la flche (0..3)	ASR.W	D1,D0	ASR.W	D2,D0	LOAD.L	D5,D7	SUB.W	D5,D2	SWAP.W	D5	ADD.W	D5,D1	SWAP.W	D5	LOAD.L	D6,D7	ADD.W	D6,D2	SWAP.W	D6	SUB.W	D6,D1	SWAP.W	D6	POPM.L	D0..D4	RET;------------------ _PLANA_CALEFLECHE:;------------------;*)		PLACE	[PLANOPBASE];-----------\\; CALEFLECHE >;-----------/; Calcul les coordonnes des quatre points D5-D6-D7-D0; pour une flche extrieure.;	                  D5;	                 //|;	                // |;	               //  |;	D4 +-----------+---+---+;	             D3 \  |D7  D0;	                 \ |;	                  \|;	                  D6; in	A4.L	^flche;	D3.L	point o mettre la flche (y;x);	D4.L	autre extrmit (y;x); out	D5.L	une extrmit;	D6.L	l'autre extrmit;	D7.L	point intermdiaire;	D0.L	3me extrmit; mod	D5.L, D6.L, D7.LCALEFLECHE:	PUSHM.L	D1..D4	LOAD.W	D1,D4	SUB.W	D1,D3	NEG.W	D1		; D1 <-- dx	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,D4	SUB.W	D2,D3	NEG.W	D2		; D2 <-- dy	SWAP.W	D3	CLR.W	D4	LOAD.B	D4,(A4)+OFLLG	; D4 <-- longueur de la flche	CALL	D4SCALE		; D4 <-- tient compte de l'chelle	LOAD.W	D0,D4	CALL	PYTHAGORE	LOAD.L	D7,D3	ADD.W	D7,D1	SWAP.W	D7	ADD.W	D7,D2	SWAP.W	D7		; D7 <-- P7(y;x)	ADD.W	D3,D1	ADD.W	D3,D1	SWAP.W	D3	ADD.W	D3,D2	ADD.W	D3,D2	SWAP.W	D3		; D3 <-- P0(y;x)	LOAD.B	D0,(A4)+OFLANG	; D0 <-- angle de la flche (0..3)	ASR.W	D1,D0	ASR.W	D2,D0	LOAD.L	D5,D7	SUB.W	D5,D2	SWAP.W	D5	ADD.W	D5,D1	SWAP.W	D5	LOAD.L	D6,D7	ADD.W	D6,D2	SWAP.W	D6	SUB.W	D6,D1	SWAP.W	D6	LOAD.L	D0,D3		; D0 <-- P0(y;x)	POPM.L	D1..D4	RET;----------\\; PYTHAGORE >;----------/; Calcul les coordonnes du point P7(x;y) en fonction du point P4(x;y); et de la longueur l sur l'hypotnuse.;		         o P4(x;y);		        /|;		       / |;		      /  |;		     /   |;		    o P7(x;y);		   /|    |;		l / |    |;		 /  |    |;		o---------;	     P3(x;y)  l'origine, donc (0;0); in	D0.W	+   l;	D1.W	+/- P4(x);	D2.W	+/- P4(y); out	D1.W	+/- P7(x);	D2.W	+/- P7(y); mod	D1.L, D2.LPYTHAGORE:	PUSHM.L	D0,D3..D7	CLR.W	D7		; D7 <-- clear flags	TEST.W	D1	JUMP',NC 10$	NEG.W	D1		; D1 <-- |P4(x)|	TSET.L	D7:#110$:	TEST.W	D2	JUMP',NC 15$	NEG.W	D2		; D2 <-- |P4(y)|	TSET.L	D7:#215$:	TEST.W	D1	JUMP',EQ 50$	TEST.W	D2	JUMP',EQ 55$	LOAD.W	D5,D0		; D5 <-- P7(x) suppos (trop grand)	MUL.WA	D0,D0		; D0 <-- l^2	COMP.W	D1,D2	JUMP',HS 20$	EX.L	D1,D2		; D1 > D2	TSET.L	D7:#020$:	LOAD.W	D6,D5	MUL.WU	D6,D2	DIV.WU	D6,D1		; D6 <-- P7(y) selon P4	LOAD.W	D3,D5	MUL.WU	D3,D3		; D3 <-- P7(x)^2	LOAD.W	D4,D6	MUL.WU	D4,D4		; D4 <-- P7(y)^2	ADD.W	D3,D4		; D3 <-- P7(x)^2 + P7(y)^2	COMP.W	D3,D0		; mme carr que le carr de "l" ?	JUMP',LS 30$		; oui => 30$				; encore trop grand =>	DEC.W	D5		; diminue P7(x) suppos	JUMP,NE	20$		; et recommence si non nul30$:	TEST.L	D7:#0	JUMP',BC 60$	EX.L	D5,D6	JUMP'	60$50$:				; "l" vertical =>	CLR.W	D5		; D5 <-- P7(x)	LOAD.W	D6,D0		; D6 <-- P7(y)	JUMP'	60$55$:				; "l" horizontal =>	LOAD.W	D5,D0		; D5 <-- P7(x)	CLR.W	D6		; D6 <-- P7(y)60$:	LOAD.W	D1,D5	LOAD.W	D2,D6	TEST.L	D7:#1	JUMP',BC 80$	NEG.W	D180$:	TEST.L	D7:#2	JUMP',BC 85$	NEG.W	D285$:	POPM.L	D0,D3..D7	RET;--------\; CERCLE  >;========/; Dessine un cercle complet.; in	D4.L	coordonne centre;	D3.W	rayon;	D2.B	mode de dessin;	D1.B	mode du trait; out	D7.W	erreur; mod	D7.WCERCLE:	PUSH.L	D3	SWAP.W	D3	LOAD.B	D3,#B'11111111	; arc = tout le cercle	SWAP.W	D3	CALL	ARC8		; dessine un cercle complet	POP.L	D3	RET;--------\; ARC8    >;========/; Dessine un ou plusieurs arcs par 1/8me de cercle.;	|---|---|---|---|---|---|---|---|; arcs	| 7 | 6 | 5 | 4 | 3 | 2 | 1 | 0 |;	|---|---|---|---|---|---|---|---|;;			^   y;		      2	| 1;			|;		  3	|     0;		--------O-------->  x;		  4	|     7;			|;		      5	| 6; in	D4.L	coordonne centre;	D3.L	rayon et arcs  dessiner;	D2.B	mode de dessin;	D1.B	mode du trait;	A5.L	^variables PLANA; out	D7.W	erreur; mod	D7.WARC8:	PUSHM.L	D1,D2,D3,D4,A3	CALL	CLIPARC		; clipping ?	JUMP,NE	95$	CALL	SCACERCLE	; agrandi/diminue	CALL	YINVERSE	; D4 <-- inverse le sens de Y	EX.L	D3,D4		; D3 <-- centre, D4 <-- rayon	TEST.W	D4		; rayon nul ?	JUMP,EQ	95$		; oui => 95$				; non =>	CALL	CONVMD		; D2 <-- INV/SET/CLRDOT	CALL	CONVLT		; D1 <-- paisseur du trait	CALL	OPWDOG		; utilise la swdo graphique	LOAD.L	A3,#(A5)+OBWRITE+1	LOAD.B	(A3)+0,#DRAWARC	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	SWAP.W	D4	LOAD.L	(A3)+5,D4	; <rayon> et <aa>	LOAD.B	(A3)+9,D2	; <mode>	LOAD.W	D3,#10	CALL	WRDIS		; dessine un cercle	DEC.B	D1	JUMP',EQ 90$20$:	INC.W	(A3)+5		; augmente <rayon>	LOAD.W	D3,#10	CALL	WRDIS		; dessine un cercle	DEC.B	D1	JUMP,NE 20$90$:	CALL	CLWDOG		; libre la swdo graphique95$:	POPM.L	D1,D2,D3,D4,A3	RET;--------\; ARCELL  >;========/; Dessine un arc d'ellipse.; in	D4.L	coordonne centre;	D3.L	rayons;	D2.B	mode de dessin;	D1.B	mode du trait;	D0.W	objet / arcs;	A5.L	^variables PLANA; out	D7.W	erreur; mod	D7.WARCELL:	PUSHM.L	D0,D1,D2,D3,D4,A3	CALL	CLIPELLIPSE	; clipping ?	JUMP,NE	95$	CALL	SCAELLIPSE	; agrandi/diminue	CALL	YINVERSE	; D4 <-- inverse le sens de Y	EX.L	D3,D4		; D3 <-- centre, D4 <-- rayons	TEST.L	D4		; rayons nuls ?	JUMP,EQ	95$		; oui => 95$				; non =>	CALL	CONVMD		; D2 <-- INV/SET/CLRDOT	CALL	CONVLT		; D1 <-- paisseur du trait	CALL	OPWDOG		; utilise la swdo graphique	LOAD.L	A3,#(A5)+OBWRITE+1	LOAD.B	(A3)+0,#DRAWELLIPSE	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	SWAP.W	D4	LOAD.L	(A3)+5,D4	; <rxx> et <ryy>	SR.W	D0,#8	LOAD.W	(A3)+9,D0	; <aa>	LOAD.B	(A3)+11,D2	; <mode>	LOAD.W	D3,#12	CALL	WRDIS		; dessine une ellipse	DEC.B	D1	JUMP',EQ 90$20$:	INC.W	(A3)+5		; augmente <rxx>	INC.W	(A3)+7		; augmente <ryy>	LOAD.W	D3,#12	CALL	WRDIS		; dessine une ellipse	DEC.B	D1	JUMP,NE 20$90$:	CALL	CLWDOG		; libre la swdo graphique95$:	POPM.L	D0,D1,D2,D3,D4,A3	RET;--------\; ELLIPSE >;========/; Dessine une ellipse.; in	D4.L	coordonne centre;	D3.L	rayons;	D2.B	mode de dessin;	D1.B	mode du trait;	A5.L	^variables PLANA; out	D7.W	erreur; mod	D7.WELLIPSE:	PUSHM.L	D1,D2,D3,D4,A3	CALL	CLIPELLIPSE	; clipping ?	JUMP,NE	95$	CALL	SCAELLIPSE	; agrandi/diminue	CALL	YINVERSE	; D4 <-- inverse le sens de Y	EX.L	D3,D4		; D3 <-- centre, D4 <-- rayons	TEST.L	D4		; rayons nuls ?	JUMP,EQ	95$		; oui => 95$				; non =>	CALL	CONVMD		; D2 <-- INV/SET/CLRDOT	CALL	CONVLT		; D1 <-- paisseur du trait	CALL	OPWDOG		; utilise la swdo graphique	LOAD.L	A3,#(A5)+OBWRITE+1	LOAD.B	(A3)+0,#DRAWELLIPSE	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	SWAP.W	D4	LOAD.L	(A3)+5,D4	; <rxx> et <ryy>	LOAD.W	(A3)+9,#-1	; <aa>	LOAD.B	(A3)+11,D2	; <mode>	LOAD.W	D3,#12	CALL	WRDIS		; dessine une ellipse	DEC.B	D1	JUMP',EQ 90$20$:	INC.W	(A3)+5		; augmente <rxx>	INC.W	(A3)+7		; augmente <ryy>	LOAD.W	D3,#12	CALL	WRDIS		; dessine une ellipse	DEC.B	D1	JUMP,NE 20$90$:	CALL	CLWDOG		; libre la swdo graphique95$:	POPM.L	D1,D2,D3,D4,A3	RET;-----------\; RRECTANGLE >;===========/; Dessine un rectangle aux coins arrondis.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D1.B	mode du trait;	D0.W	objet/rayon;	A5.L	^variables PLANA; out	-; mod	D7.WRRECTANGLE:	PUSHM.L	D0,D1,D2,D3,D4,D5,A3	SR.W	D0,#8		; D0 <-- rayon	EX.L	D4,D0	CALL	D4SCALE		; D0 <-- rayon selon chelle	EX.L	D0,D4	TEST.W	D0	JUMP',NE 10$	CALL	RECTANGLE	JUMP	95$10$:	CALL	CLIPRECT	; clipping	CALL	SCASURF		; agrandi/diminue	CALL	YINVERSE	; D4 <-- inverse le sens de Y	EX.L	D4,D3	CALL	YINVERSE	; D3 <-- inverse le sens de Y	EX.L	D3,D4; Arrange D3 et D4 pour que D3 (x;y) soit toujours plus petit que; D4 (x;y). On ne peut pas utiliser ORDONNE car les coordonnes; peuvent tre +/- !	COMP.W	D3,D4		; D3 < D4 ?	JUMP',LT 20$		; oui => 20$	LOAD.W	D5,D3		; non =>	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D520$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4		; D3 < D4 ?	JUMP',LT 25$		; oui => 25$	LOAD.W	D5,D3		; non =>	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D525$:	SWAP.W	D3	SWAP.W	D4	CALL	CONVMD		; D2 <-- INV/SET/CLRDOT	CALL	CONVLT		; D1 <-- paisseur du trait	CALL	OPWDOG		; utilise la swdo graphique	LOAD.W	D5,D4	SUB.W	D5,D3	SR.W	D5,#1		; D5 <-- 1/2 largeur	COMP.W	D0,D5		; rayon trop grand ?	JUMP',LS 30$		; non => 30$	LOAD.W	D0,D5		; oui => diminue30$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SWAP.W	D4	SWAP.W	D3	SR.W	D5,#1		; D5 <-- 1/2 hauteur	COMP.W	D0,D5		; rayon trop grand ?	JUMP',LS 40$		; non => 40$	LOAD.W	D0,D5		; oui => diminue40$:	LOAD.L	A3,#(A5)+OBWRITE+1	TCLR.L	D2:#BNCTDOT	; rz des traitills	LOAD.B	(A3+),#DRAWSEG	; en haut	LOAD.W	D5,D3	ADD.W	D5,D0	INC.W	D5	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D3	LOAD.W	(A3+),D3	; <yy>	SWAP.W	D3	LOAD.W	D5,D4	SUB.W	D5,D3	SUB.W	D5,D0	SUB.W	D5,D0	LOAD.W	(A3+),D5	; <dxx>	CLR.W	(A3+)		; <dyy>	LOAD.B	(A3+),D2	; <mode>	TSET.L	D2:#BNCTDOT	; plus de rz des traitills	LOAD.B	(A3+),#DRAWARC	; en haut  droite	LOAD.W	D5,D4	SUB.W	D5,D0	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D3	LOAD.W	D5,D3	ADD.W	D5,D0	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D3	LOAD.W	(A3+),D0	; <rr>	LOAD.W	(A3+),#B'00000011	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWSEG	;  droite	LOAD.W	(A3+),D4	; <xx>	SWAP.W	D3	LOAD.W	D5,D3	ADD.W	D5,D0	INC.W	D5	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D3	CLR.W	(A3+)		; <dxx>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SUB.W	D5,D0	SUB.W	D5,D0	LOAD.W	(A3+),D5	; <dyy>	SWAP.W	D4	SWAP.W	D3	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWARC	; en bas  droite	LOAD.W	D5,D4	SUB.W	D5,D0	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D0	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D4	LOAD.W	(A3+),D0	; <rr>	LOAD.W	(A3+),#B'11000000	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWSEG	; en bas	LOAD.W	D5,D4	SUB.W	D5,D0	DEC.W	D5	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D4	LOAD.W	(A3+),D4	; <yy>	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SUB.W	D5,D0	SUB.W	D5,D0	NEG.W	D5	LOAD.W	(A3+),D5	; <dxx>	CLR.W	(A3+)		; <dyy>	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWARC	; en bas  gauche	LOAD.W	D5,D3	ADD.W	D5,D0	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D0	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D4	LOAD.W	(A3+),D0	; <rr>	LOAD.W	(A3+),#B'00110000	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWSEG	;  gauche	LOAD.W	(A3+),D3	; <xx>	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D0	DEC.W	D5	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D4	CLR.W	(A3+)		; <dxx>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SUB.W	D5,D0	SUB.W	D5,D0	NEG.W	D5	LOAD.W	(A3+),D5	; <dyy>	SWAP.W	D4	SWAP.W	D3	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWARC	; en haut  gauche	LOAD.W	D5,D3	ADD.W	D5,D0	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D3	LOAD.W	D5,D3	ADD.W	D5,D0	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D3	LOAD.W	(A3+),D0	; <rr>	LOAD.W	(A3+),#B'00001100	LOAD.B	(A3+),D2	; <mode>	PUSH.L	D3	LOAD.L	D3,A3	LOAD.L	A3,#(A5)+OBWRITE+1	SUB.L	D3,A3		; D3 <-- longueur	CALL	WRDIS	POP.L	D3	DEC.B	D1	JUMP',EQ 90$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	JUMP	40$90$:	CALL	CLWDOG		; libre la swdo graphique95$:	POPM.L	D0,D1,D2,D3,D4,D5,A3	RET;------------------ _PLANA_TRECTANGLE:;------------------;*);-----------\; TRECTANGLE >;===========/; Sp. 28 avril 87; Dessine un rectangle lors des dplacements, sans dborder du PLAN,; mais v. de la fentre !;; in	D3.L	coordonnes 1er point;	D4.L	coordonnes 2e point;	D2.B	mode de dessin;	D1.B	mode du trait;	A5.L	^variables PLANA; out	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos; mod	D3.L, D4.L, D7.WTRECTANGLE:	PUSH.L	D0	TEST.W	D3		; trop  gauche ?	JUMP',NC	05$		; non => 05$	SUB.W	D4,D3		; oui, ajuste l'autre ...	CLR.W	D3		; ...et met min.05$:	TEST.W	D4		; trop  gauche ?	JUMP',NC	10$		; non => 10$	SUB.W	D3,D4		; oui, ajuste l'autre ...	CLR.W	D4		; ... et met min.10$:	LOAD.W	D0,D3		; D0 <-- D3x				; trop  droite ?	SUB.W	D0,(A5)+OMWDOX	; x > OMWDOX ?	JUMP',NS	20$		; non => 20$	SUB.W	D4,D0		; oui, ajuste l'autre	LOAD.W	D3,(A5)+OMWDOX20$:	LOAD.W	D0,D4		; D0 <-- D4x				; trop  droite ?	SUB.W	D0,(A5)+OMWDOX	; x > OMWDOX ?	JUMP',NS	30$		; non => 30$	SUB.W	D3,D0		; oui, ajuste l'autre	LOAD.W	D4,(A5)+OMWDOX30$:	SWAP.W	D3	SWAP.W	D4	TEST.W	D3		; trop en bas ?	JUMP',NC	35$		; non => 35$	SUB.W	D4,D3		; oui, ajuste l'autre ...	CLR.W	D3		; ... et met min.35$:	TEST.W	D4		; trop en bas ?	JUMP',NC	40$		; non => 40$	SUB.W	D3,D4		; oui, ajuste l'autre ...	CLR.W	D4		; ... et met min.40$:	LOAD.W	D0,D3		; D0 <-- D3y				; trop en haut :	SUB.W	D0,(A5)+OMWDOY	; y < OMWDOY ?	JUMP',NS	50$		; non => 40$	SUB.W	D4,D0		; oui, ajuste l'autre	LOAD.W	D3,(A5)+OMWDOY50$:	LOAD.W	D0,D4		; D0 <-- D4y				; trop en haut :	SUB.W	D0,(A5)+OMWDOY	; y , OMWDOY ?	JUMP',NS	60$		; non => 50$	SUB.W	D3,D0		; oui, ajuste l'autre	LOAD.W	D4,(A5)+OMWDOY60$:	SWAP.W	D3	SWAP.W	D4PUSHM.L	D2..D4	CALL	D4CLIP	CALL	D4SCALE	CALL	YINVERSE	ADD.W	D4,(A5)+OMINX	SWAP.W	D4	ADD.W	D4,(A5)+OMINY	SWAP.W	D4	LOAD.L	D3,D4	LOAD.W	D4,#RSPLINE	LOAD.W	D2,#INVDOT	LIB	?DRCERCLEPOPM.L	D2..D4	POP.L	D0;	JUMP	RECTANGLE;----------\; RECTANGLE >;==========/; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D1.B	mode du trait;	A5.L	^variables PLANA; out	D7.W	erreur; mod	D7.WRECTANGLE:	PUSHM.L	D0,D1,D2,D3,D4,A3	CALL	CONVMD		; D2 <-- INV/SET/CLRDOT	CALL	CONVLT		; D1 <-- paisseur du trait	DEC.W	D1		; D1 <-- paisseur -1 (0..n)	CALL	OPWDOG		; utilise la swdo graphique	COMP.W	D3,D4	JUMP',LO 10$	LOAD.W	D0,D3	LOAD.W	D3,D4	LOAD.W	D4,D010$:	SUB.W	D4,D3		; D4 <-- <dxx>	ADD.W	D4,D1		; D4 <-- correction paisseur	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',LO 20$	LOAD.W	D0,D3	LOAD.W	D3,D4	LOAD.W	D4,D020$:	SUB.W	D4,D3		; D4 <-- <dyy>	ADD.W	D4,D1		; D4 <-- correction paisseur	SWAP.W	D4	SWAP.W	D3	CALL	DRRECT		; dessine un rectangle	TEST.B	D1	JUMP',EQ 90$	TEST.W	(A5)+OSCALE	; chelle existe ?	JUMP',NE 90$		; oui => 90$50$:	INC.W	D3		; <xx> <-- +1	SUB.W	D4,#2		; <dxx> <-- -2	JUMP',LS 90$	SWAP.W	D3	SWAP.W	D4	INC.W	D3		; <yy> <-- +1	SUB.W	D4,#2		; <dyy> <-- -2	JUMP',LS 90$	SWAP.W	D4	SWAP.W	D3	CALL	DRRECT		; dessine un rectangle suppl.	DEC.B	D1	JUMP,NE	50$90$:	CALL	CLWDOG		; libre la swdo graphique	POPM.L	D0,D1,D2,D3,D4,A3	RET;--------\; DRRECT  >;--------/; Trace un rectangle avec "clipping" ventuel.; in	D3.L	origine coin suprieur gauche y;x;	D4.L	dimensions dy;dx;	D2.B	mode; out	D7.W	erreur; mod	D7.WDRRECT:	PUSHM.L	D3,D4,D5	LOAD.L	D5,D4		; D5 <-- dimensions dy;dx	AND.L	D4,#H'FFFF	CALL	DRSEG		; trace ligne suprieure	LOAD.L	D4,D5	CLR.W	D4	CALL	DRSEG		; trace ligne de droite	LOAD.L	D4,D5	AND.L	D4,#H'FFFF	NEG.W	D4	CALL	DRSEG		; trace ligne infrieure	LOAD.L	D4,D5	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DRSEG		; trace ligne de gauche	POPM.L	D3,D4,D5	RET;--------\; DRSEG   >;--------/; Trace une ligne quelconque.; in	D3.L	origine ligne y;x;	D4.L	dimensions ligne dy;dx;	D2.B	mode;	A5.L	^variables PLANA; out	D3.L	origine ligne suivante;	D7.W	erreur; mod	D3.L, D7.WDRSEG:	PUSHM.L	D0,D1,D4,A3	ADD.W	D4,D3		; D4 <-- arrive X	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3		; D4 <-- arrive Y	SWAP.W	D3	SWAP.W	D4	LOAD.L	D1,D4		; D1 <-- (y;x) arrive	CALL	CLIPSEG		; clipping ?	JUMP',NE 80$		; oui => 80$	CALL	SCASEG		; agrandi/diminue	CALL	YINVERSE	; D4 <-- inverse le sens de Y	EX.L	D3,D4	CALL	YINVERSE	; D3 <-- inverse le sens de Y	EX.L	D4,D3	SUB.W	D4,D3		; D4 <-- longueur X	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- longueur Y	SWAP.W	D3	SWAP.W	D4	LOAD.L	A3,#(A5)+OBWRITE+1	LOAD.B	(A3)+0,#DRAWSEG	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	SWAP.W	D4	LOAD.L	(A3)+5,D4	; <dxx> et <dyy>	LOAD.B	(A3)+9,D2	; <mode>	LOAD.W	D3,#1+8+1	CALL	WRDIS		; dessine une ligne80$:	LOAD.L	D3,D1		; D3 <-- (y;x) arrive	POPM.L	D0,D1,D4,A3	RET;----------\; SURFACE   >;==========/; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D1.B	type de trame;	A5.L	^variables PLANA; out	D7.W	erreur; mod	D7.WSURFACE:	PUSHM.L	D0,D1,D2,D3,D4,A3	CALL	CLIPSURF	; clipping ?	JUMP,NE	95$	CALL	SCASURF		; agrandi/diminue	CALL	YINVERSE	; D4 <-- inverse le sens de Y	EX.L	D4,D3	CALL	YINVERSE	; D3 <-- inverse le sens de Y	EX.L	D3,D4	CALL	CONVMD		; D2 <-- INV/SET/CLRDOT	CALL	OPWDOG		; utilise la swdo graphique	PUSHM.L	D3,D4	LOAD.L	A3,#(A5)+OBUTRA	; A3 <-- ^trames	AND.W	D1,#H'FF	MUL.WU	D1,#8	ADD.L	A3,D1		; A3 <-- ^la bonne trame	LOAD.L	D3,(A3)+0	; D3 <-- 1re partie trame	LOAD.L	D4,(A3)+4	; D4 <-- 2me partie trame	COMP.B	D2,#CLRDOT	; mode efface ?	JUMP',NE 30$		; non => 30$	NOT.L	D3		; oui => compense une erreur	NOT.L	D4		; du driver cran !!!30$:	CALL	DRMDEF		; dfinit la trame	POPM.L	D3,D4	LOAD.L	A3,(A5)+OPDDIS	; A3 <-- ^descripteur de la fentre	COMP.W	D3,D4	JUMP',LO 50$	LOAD.W	D0,D3	LOAD.W	D3,D4	LOAD.W	D4,D050$:	COMP.W	D4,(A3)+ODFFDX	; dpasse  droite ?	JUMP',LS 55$		; non => 55$	LOAD.W	D4,(A3)+ODFFDX	; oui => met le maximum55$:	SUB.W	D4,D3		; D4 <-- <dxx>	JUMP,EQ	90$	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',LO 60$	LOAD.W	D0,D3	LOAD.W	D3,D4	LOAD.W	D4,D060$:	COMP.W	D4,(A3)+ODFFDY	; dpasse en bas ?	JUMP',LS 65$		; non => 65$	LOAD.W	D4,(A3)+ODFFDY	; oui => met le maximum65$:	SUB.W	D4,D3		; D4 <-- <dyy>	JUMP,EQ	90$	SWAP.W	D4	SWAP.W	D3	CALL	DRMATRIX	; dessine une zone trame90$:	CALL	CLWDOG		; libre la swdo graphique95$:	POPM.L	D0,D1,D2,D3,D4,A3	RET;--------\; TEXTE   >;========/; Dessine un caractre ASCII.; in	D3.L	gnrateur + caractre	| 'N | 'R | 12 | code |;	D4.L	coordonne du "centre";	D2.B	mode de dessin;	D1.B	mode du trait;	A5.L	^variables PLANA; out	D7.W	erreur; mod	D7.WTEXTE:	PUSHM.L	D0,D1,D2,D3,D4,A3,A0	TEST.W	(A5)+OSCALE	; chelle 1:1 ?	JUMP',EQ 10$		; oui => 10$	CALL	BOXTEXT		; non => met bote autour10$:	TEST.W	(A5)+OSCALE	; chelle ngative ?	JUMP,NS	95$		; oui => 95$ (rien d'autre)				; non =>;	CALL	CLIPTEXT	; clipping ?;	JUMP,NE	95$call	d4clip;	CALL	SCATEXT		; agrandi/diminuecall	d4scale	CALL	YINVERSE	; D4 <-- inverse le sens de Y	LOAD.L	D0,D3		; D0 <-- gencar + caractre	CALL	OPWDOG		; utilise la swdo graphique	CALL	CONVMD		; D2 <-- INV/SET/CLRDOT	LOAD.L	A3,#(A5)+OBWRITE ; buffer pour driver cran	COMP.B	D2,#SETDOT	JUMP',EQ 50$	LOAD.B	(A3+),#MODCAR	LOAD.B	(A3+),#INVDOT	; mode de dessin "inverse"50$:;	LOAD.B	(A3+),#NUL;	LOAD.B	(A3+),#TYPOAX;	LOAD.W	(A3+),D4	; <xx>;;	LOAD.B	(A3+),#NUL;	LOAD.B	(A3+),#TYPOAY;	SWAP.W	D4;	LOAD.W	(A3+),D4	; <yy>	LOAD.B	(A3+),#NUL	LOAD.B	(A3+),#USEGC	; <usegc>	CALL	SRCPGC		; genc ?	JUMP,NE	52$				; oui, prend	LOAD.L	(A3+),D0	; <fst?>	JUMP	56$52$:				; non, prend genc par dfaut	LOAD.L	(A3+),(A5)+ODEFGC56$:	CLR.B	(A3)-1;;;**	TEST.B	(A6)+OFLMOD:#BICADRE;;;**	JUMP',BC 60$;;;**	LOAD.B	(A3+),#AFDIR60$:				; met curseur typo	LOAD.B	(A3+),#NUL	LOAD.B	(A3+),#TYPOAX	LOAD.W	(A3+),D4	; <xx>	LOAD.B	(A3+),#NUL	LOAD.B	(A3+),#TYPOAY	SWAP.W	D4	LOAD.W	(A3+),D4	; <yy>	LOAD.B	(A3+),#AFTOUT	LOAD.B	(A3+),D0	; <caractre>	LOAD.B	(A3+),#AFNORM;;;**	TEST.B	(A6)+OFLMOD:#BICADRE;;;**	JUMP',BC 65$;;;**	LOAD.B	(A3+),#AFINV65$:	LOAD.B	(A3+),#USEGC	; <usegc>	LOAD.L	(A3+),(A5)+ODEFGC ; gencar par dfaut	CLR.B	(A3)-1	COMP.B	D2,#SETDOT	JUMP',EQ 70$	LOAD.B	(A3+),#MODCAR	LOAD.B	(A3+),#SETDOT	; remet mode de dessin standard70$:	LOAD.L	D3,A3	LOAD.L	A3,#(A5)+OBWRITE	SUB.L	D3,A3		; D3 <-- longueur	CALL	WRDIS		; crit tout a90$:	CALL	CLWDOG		; libre la swdo graphique95$:	POPM.L	D0,D1,D2,D3,D4,A3,A0	RET;--------\\; BOXTEXT >;--------/; Dessine une bote autour d'un caractre.; in	D3.L	gnrateur + caractre	| 'N | 'R | 12 | code |;	D4.L	coordonne du "centre";	D2.B	mode de dessin; out	-; mod	D7.WBOXTEXT:	PUSHM.L	D1,D2,D3,D4,A0	CALL	SRCPGC		; A0 <-- ^table du gencar;;;	JUMP,NE	90$	JUMP,EQ	70$		; trouv, normal	LOAD.L	A0,(A5)+OPDDIS	; pas trouv, prend car par dfaut;	LOAD.W	D1,(A0)+ODFCX	; D1 <-- largeur car. par dfaut	load.w	d1,(a0)+odfc1x		; D1 <-- largeur car. par dfaut	add.w	d1,(a0)+odfc2x	LOAD.L	D3,D4	SUB.W	D3,(A0)+ODFC1X	DEC.W	D3	SWAP.W	D3	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LOAD.W	D4,D3	ADD.W	D4,D1	SWAP.W	D4	SUB.W	D4,(A0)+ODFC2Y	SWAP.W	D4	JUMP	80$		; dessine rectangle70$:	PUSH.L	D4	CALL	LGCGC	LOAD.W	D1,D4		; D1 <-- largeur du caractre	POP.L	D4	LOAD.L	D3,D4	SUB.W	D3,(A0)+OGC1X	DEC.W	D3	SWAP.W	D3	ADD.W	D3,(A0)+OGC1Y	SWAP.W	D3	LOAD.W	D4,D3	ADD.W	D4,D1	SWAP.W	D4	SUB.W	D4,(A0)+OGC2Y	SWAP.W	D480$:	LOAD.W	D2,#MODINV	; D2 <-- mode inverse	CLR.W	D1		; D1 <-- type de trait fin	CALL	RECTANGLE	; dessine rectangle "autour"90$:	POPM.L	D1,D2,D3,D4,A0	RET;--------------- _PLANA_INUZONE:;---------------;*);--------\\; INUZONE >;========/; Trame les parties inutiles de la fentre.; in	-;	A5.L	^variables PLANA; out	-; mod	D7.WINUZONE:	PUSHM.L	D0..D5,A3NTREL	?GETMACHINERL.L	D4,#8		; D4 <-- type de la machine	LOAD.L	D3,#H'22228888	; D3 <-- trame pour cran entrelac	COMP.B	D4,#SMAKY8;COMP.B	(A6)+OMACHINE,#SMAKY8	JUMP',EQ 10$	LOAD.L	D3,#H'22008800	; D3 <-- trame pour cran bien foutu10$:	LOAD.L	D4,D3	CALL	DRMDEF		; dfini une trame +/- grise	CLR.L	D1		; D1 <-- pas de trame  droite	LOAD.W	D5,(A5)+OLWDOX	; D5 <-- largeur restante sans trame	LOAD.W	D4,(A5)+OOWDOX	ADD.W	D4,(A5)+OSWDOX	SUB.W	D4,(A5)+OMWDOX	; D4 <-- largeur en trop	JUMP',LS 50$	CALL	D4SCALE		; D4 <-- dX	LOAD.W	D3,(A5)+OMINY	; D3 <-- Y	SWAP.W	D3	LOAD.W	D3,D4	SUB.W	D3,(A5)+OLWDOX	NEG.W	D3	LOAD.W	D5,D3		; D5 <-- largeur restante avec trame	ADD.W	D3,(A5)+OMINX	; D3 <-- X	SWAP.W	D4	LOAD.W	D4,(A5)+OLWDOY	; D4 <-- dY	INC.W	D4	SWAP.W	D4	INC.W	D4	LOAD.L	D0,D3		; D0 <-- pos. trame  droite	LOAD.L	D1,D4		; D1 <-- dim. trame  droite50$:	LOAD.W	D4,(A5)+OOWDOY	ADD.W	D4,(A5)+OSWDOY	SUB.W	D4,(A5)+OMWDOY	; D4 <-- hauteur en trop	JUMP',LS 80$	CALL	D4SCALE		; D4 <-- dY	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- dX	LOAD.W	D3,(A5)+OMINY	; D3 <-- Y	SWAP.W	D3	LOAD.W	D3,(A5)+OMINX	; D3 <-- X	LOAD.W	D2,#SETDOT	CALL	DRMATRIX	; met trame en haut80$:	LOAD.L	D3,D0	LOAD.L	D4,D1	JUMP',EQ 90$	LOAD.W	D2,#SETDOT	CALL	DRMATRIX	; met trame  droite90$:	POPM.L	D0..D5,A3	RET;---------------- _PLANA_YINVERSE:;----------------;*)		 faire identique dans le source de PLAN !!!!;---------\; YINVERSE >;=========/; Inverse le sens de la coordonne Y.; in	D4.L	coordonne (Y;X);	A5.L	^variables PLANA; out	D4.L	coordonne (Y;X); mod	D4.LYINVERSE:	SWAP.W	D4		; D4 <-- X;Y	SUB.W	D4,(A5)+OLWDOY	; saustrait hauteur fentre	NEG.W	D4		; D4 <-- 0..n;;?	DEC.W	D4; pour la coordonne c'est ok (0) mais pas pour le clipping !!	SWAP.W	D4		; D4 <-- Y;X	RET;--------\; DRMDEF  >;========/; Dfinit une trame quelconque.; in	D3.L	1re partie trame;	D4.L	2me partie trame;	A5.L	^variables PLANA; out	D7.W	erreur; mod	D7.WDRMDEF:	PUSHM.L	D3,A3	LOAD.L	A3,#(A5)+OBWRITE+1	LOAD.B	(A3)+0,#TRAME	LOAD.L	(A3)+1,D3	LOAD.L	(A3)+5,D4	LOAD.W	D3,#1+8	CALL	WRDIS		; dfinit la trame	POPM.L	D3,A3	RET;----------\; DRMATRIX  >;==========/; Rempli une zone rectangulaire avec une matrice.; in	D3.L	origine coin suprieur gauche y;x;	D4.L	dimensions dy;dx;	D2.B	mode;	A5.L	^variables PLANA; out	D7.W	erreur; mod	D7.WDRMATRIX:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A5)+OBWRITE+1	LOAD.B	(A3)+0,#DRAWTRAME	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	TEST.W	D4	JUMP',EQ 90$	SWAP.W	D4	TEST.W	D4	JUMP',EQ 90$	LOAD.L	(A3)+5,D4	; <dxx> et <dyy>	LOAD.B	(A3)+9,D2	; <mode>	LOAD.W	D3,#1+8+1	CALL	WRDIS		; rempli avec la trame90$:	POPM.L	D3,D4,A3	RET;--------\\; OPWDOG  >;========/; Utilise la swdo graphique.; in	-;	A5.L	^variables PLANA; out	-; mod	D7.W;OPWDOG:	PUSHM.L	D3,A3	TEST.W	(A5)+ONWDOG	JUMP',NE 50$	LOAD.L	A3,#(A5)+OBWRITE+1	LOAD.B	(A3)+0,#DIMWDO	LOAD.W	(A3)+1,(A5)+OMINX	LOAD.W	(A3)+3,(A5)+OMINY	LOAD.W	(A3)+5,(A5)+OLWDOXINC.W	(A3)+5; essai	LOAD.W	(A3)+7,(A5)+OLWDOY;;?	INC.W	(A3)+7	LOAD.W	D3,#9	CALL	WRDIS		; dimensionne la swdo graphique50$:	INC.W	(A5)+ONWDOG	POPM.L	D3,A3	RET;--------\\; CLWDOG  >;========/; Libre la swdo graphique.; in	-;	A5.L	^variables PLANA; out	-; mod	D7.W;CLWDOG:	PUSHM.L	D3,A3	DEC.W	(A5)+ONWDOG	JUMP',NE 90$	LOAD.L	A3,#(A5)+OBWRITE+1	LOAD.B	(A3)+0,#DIMWDO	CLR.L	(A3)+1	LOAD.W	(A3)+5,(A5)+OWDOX	LOAD.W	(A3)+7,(A5)+OWDOY	LOAD.W	D3,#9	CALL	WRDIS		; remet la swdo globale90$:	POPM.L	D3,A3	RET;--------\; WRDIS   >;========/; Envoye qq bytes  l'cran, rapidement.; in	A3.L	^bytes  envoyer;	D3.W	nombre;	A5.L	^variables PLANA; out	-; mod	D7.WWRDIS:	PUSHM.L	D2,D5,A1,A4	LOAD.L	A4,A3		; A4 <-- ^bytes	CLR.L	D5	LOAD.W	D5,D3		; D5 <-- longueur	LOAD.W	D2,(A5)+ONODIS	; D2 <-- no driver cran	LOAD.L	A1,#0		; A1 <-- pas de liste de term.	BIOS	?DWRITE	POPM.L	D2,D5,A1,A4	RET;--------\; CONVMD  >;========/; Converti un type de dessin en un byte INV/SET/CLRDOT.; in	D2.W	mode de dessin; out	D2.W	INV/SET/CLRDOT; mod	D2.WCONVMD:	PUSH.W	D0	LOAD.B	D0,D2		; D0 <-- type de dessin	AND.B	D0,#H'0F	LOAD.W	D2,#INVDOT	COMP.B	D0,#MODINV	JUMP',EQ 90$	LOAD.W	D2,#SETDOT	COMP.B	D0,#MODSET	JUMP',EQ 90$	LOAD.W	D2,#CLRDOT	COMP.B	D0,#MODCLR	JUMP',EQ 90$	LOAD.W	D2,#INVDOT90$:	POP.W	D0	RET;-------------- _PLANA_CONVLT:;--------------;*)		utilis par PLACE et PPLACE [PLANOPBASE];--------\; CONVLT  >;========/; Converti un type de trait en une largeur.; in	D1.W	mode de trait;	D2.B	mode INV/SET/CLRDOT;	A5.L	^variables PLANA; out	D1.W	largeur;	D2.B	mode pinceau si ncessaire; mod	D1.L, D2.BCONVLT:	PUSHM.L	D3,A4	COMP.B	D1,#3		; trait avec le pinceau ?	JUMP',HS 50$		; oui => 50$	LOAD.B	D3,D1		; D3 <-- type de trait	LOAD.W	D1,#1		; D1 <-- fin	TEST.W	(A5)+OSCALE	; vue d'ensemble 1:n ?	JUMP',NS 90$		; oui => 90$	COMP.B	D3,#TRAFIN	JUMP',EQ 90$	LOAD.W	D1,#2		; D1 <-- moyen	COMP.B	D3,#TRAMOYEN	JUMP',EQ 90$	LOAD.W	D1,#5		; D1 <-- pais	COMP.B	D3,#TRAGRAS	JUMP',EQ 90$	LOAD.W	D1,#1	JUMP'	90$50$:	LOAD.L	A4,#(A5)+OBUPEN	; A4 <-- ^pinceaux	SR.B	D1,#2	AND.W	D1,#H'FF	MUL.WU	D1,#8+2	ADD.L	A4,D1		; A4 <-- ^le bon pinceau	CALL	DEFTRAIT	; dfini le pinceau	TSET.L	D2:#BPENDOT	; D2 <-- mode pinceau !	TSET.L	D2:#BTTTDOT	; D2 <-- mode  - - -	LOAD.W	D1,#1		; D1 <-- comme si paisseur 190$:	POPM.L	D3,A4	RET;---------------- _PLANA_DEFTRAIT:;----------------;*);---------\; DEFTRAIT >;---------/; Dfini le bon pinceau pour tracer une ligne.; in	A4.L	^pinceau;	A5.L	^variables PLANA; out	-; mod	D7.WDEFTRAIT:	PUSHM.L	D3,A3	LOAD.L	A3,#(A5)+OBWRITE+1	LOAD.B	(A3)+0,#PEN	; <pen>	LOAD.L	(A3)+1,(A4)+0	LOAD.L	(A3)+5,(A4)+4	LOAD.B	(A3)+9,#MAPTT	; <maptt>	LOAD.B	(A3)+10,(A4)+8	; <m>	LOAD.B	(A3)+11,(A4)+9	; <e>	LOAD.W	D3,#9+3	LIB	?STRING		; dfini le pinceau	POPM.L	D3,A3	RET;-------------- _PLANA_SRCPGC:;--------------;*);--------\\; SRCPGC  >;========/; Cherche un gencar d'aprs "fst-".; in	D3.L	gencar cherch "fst-"; out	A0.L	^gencar;	D7.W	erreur; mod	D7.W, A0.LSRCPGC:	PUSHM.L	D3,D4	CALL	SRCPGC1		; cherche le gencar tel quel	JUMP',EQ 90$	TEST.L	D3:#31		; fonte soft ?	JUMP',BS 90$		; oui => 90$	LOAD.L	D4,D3	SWAP.W	D4		; D4 <-- style	TCLR.L	D4:#7	COMP.B	D4,#'R		; style Roman ?	JUMP',NE 90$		; non => 90$	TSET.L	D3:#31		; D3 <-- met fonte soft	AND.L	D3,#H'FF80FFFF	; D3 <-- annule tous les styles (sauf chasse)	CALL	SRCPGC1		; A0 <-- ^gencar90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------------- _PLANA_SPGC1:;---------------;* v. appel depuis l'extrieur ????;--------\\; SRCPGC1 >;--------/; Cherche un gencar d'aprs "fst-".; in	D3.L	gencar cherch "fst-";	A5.L	^variables PLANA; out	A0.L	^gencar;	D7.W	erreur; mod	D7.W, A0.LSRCPGC1:	PUSHM.L	D0,D1,D3	SR.L	D3,#8		; D3 <-- "-fst"	LOAD.L	A0,#(A5)+OBUGC	; A0 <-- ^buffer des gencars	LOAD.W	D0,#MAXGC	CLR.W	D7		; D7 <-- trouv10$:	TEST.B	(A0)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BC 30$		; non => 30$				; oui =>	LOAD.L	D1,(A0)+OGCCOD	AND.L	D1,#H'FFFFFF	COMP.L	D1,D3		; gencar trouv ?	JUMP',EQ 90$		; oui => 90$30$:				; non =>	LOAD.L	A0,#(A0)+LGGC	; A0 <-- ^suivant	DEC.W	D0	JUMP,NE	10$	LOAD.W	D7,#ERDIGC	; D7 <-- pas trouv90$:	POPM.L	D0,D1,D3	TEST.W	D7		; retour EQ/NE	RET;------------- _PLANA_LGCGC:;-------------;*);--------\\; LGCGC   >;========/; Donne la largeur d'un caractre, en tenant compte; de la chasse variable.; in	A0.L	^gencar;	D3.B	caractre; out	D4.W	largeur; mod	D4.LLGCGC:	PUSHM.L	D3,A3	LOAD.L	A3,(A0)+OGCPT	; A3 <-- ^dbut gencar	SUB.B	D3,(A3)+OGCFCA	LOAD.L	A3,#(A3)+OGCWID	AND.W	D3,#H'FF	CLR.W	D4	LOAD.B	D4,(A3)+(D3.W)	; D4 <-- largeur	POPM.L	D3,A3	RET	.EVEN	.END