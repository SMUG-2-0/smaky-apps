		.SBTTL	PLANAFLECHE		; 12 juillet 87 Sp.;****************** _PLANA_DBFLECHE:;******************;-----------\\; DBOXFLECHE >;===========/;; Choix d'une flche, la DBOX s'affiche  la coordonne Y=188;X=265 !?;; in	(A5)+OADBOPEN	adr. routine qui ouvre une DBOX;	(A5)+OADCLOSE	adr. routine qui ferme une DBOX;	(A5)+OADREF	adr. routine qui refait l'cran si DBOX a dmoli;; out	D0.L	31..16: no. flche;;		 0..15: OBJFLECHE, OBJFHV ou -1 si inexistant;	NE	modification pas visible ds. fentre;	EQ	modification visible ds. fentre, refaire cran;		 et redessiner si pas dj fait par DBOXCLOSE;; mod	D0.L, D7.WDBOXFLECHE:	PUSHM.L	D1..D5,A2..A4,A0	LOAD.W	D2,#2^BDBSAV!2^BDBCAS	; centre sur l'cran05$:	LOAD.L	A2,#R16"TDBOX_FLECHE	LOAD.L	D4,(A5)+OFAFLE	AND.B	D4,#B'11111100	OR.L	D4,#B'01	; D4 <-- fanion "utilise";;;	CALL	DBOXOPEN	; ouvre la DBOXLOAD.L	A0,(A5)+OADBOPENCALL	(A0)	JUMP,NE	90$	CLR.W	D2		; D2 <-- no 1re flche	LOAD.W	D1,#MODSET	; D1 <-- mode de dessin10$:	CALL	DBOXAFF		; affiche une flche	INC.W	D2	COMP.W	D2,#FLEMAX	JUMP,LO	10$20$:	DBOX_	EDIT		; attend une action ...	COMP.W	D3,#2^7+0	JUMP',LO 30$	COMP.W	D3,#2^7+FLEMAX	JUMP',LO 40$	COMP.W	D3,#KEYMGR	JUMP,EQ	20$	COMP.W	D3,#KEYMMR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#KEYMDR	JUMP,EQ	20$30$:	LOAD.B	D3,#BIPLIT	; non =>	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; FLECHE =>	LOAD.L	(A5)+OFAFLE,D4	; mj les fanions;;;	CALL	DBOXCLOSE	; ferme la DBOXLOAD.L	A0,(A5)+OADBCLOSECALL	(A0)	SUB.W	D3,#2^7		; D3 <-- numro flche	LOAD.W	D2,D3		; D2 <-- no flche	LOAD.L	A3,#(A5)+OBUFLE	; A3 <-- ^flches	MUL.WU	D3,#4	ADD.L	A3,D3		; A3 <-- ^la bonne flcheLOAD.W	D7,#-1		; simule pas de modif. visible	TEST.L	D4:#1		; fanion "modifie" ?	JUMP,BC	80$		; non => 80$	LOAD.L	A4,#(A5)+OBUFLE+(FLEMAX*4) ; A4 <-- ^flche de travail	LOAD.L	(A4)+0,(A3)+0	; travail <-- flche	CALL	DBOXFDEF	; modifie la flche ...	COMP.W	D3,#CR		; termin par OK ?	JUMP',NE 50$		; non => 50$	LOAD.L	(A3)+0,(A4)+0	; travail --> flche50$:;;;	CALL	DBOXREFAIT	; refait si dmoli par DBOXLOAD.L	A0,(A5)+OADBREFCALL	(A0)	COMP.W	D3,#CR		; termin par OK ?	JUMP',EQ 70$		; oui => 70$	LOAD.W	D2,#2^BDBSAV!2^BDBCAS	JUMP	05$70$:	PUSH.L	D4	LOAD.L	D3,(A5)+OOWDOY	; D3 <-- coin inf/gauche visible	LOAD.L	D4,D3	ADD.W	D4,(A5)+OSWDOX	SWAP.W	D4	ADD.W	D4,(A5)+OSWDOY	; D4 <-- coin sup/droite visible	SWAP.W	D4	LOAD.B	D1,D2		; D1 <-- no flche modifie	CALL	IFFLECHE	; flche visible dans la fentre ?	POPM.L	D4;;;	JUMP',NE 80$		; non => 80$;;;	TEST.B	(A5)+OFLAGS:#BMDBOX ; dj refait ?;;;	JUMP',BS 80$		; oui => 80$;;;	CALL	_EFFACE		; efface tout;;;	CALL	REFAIT		; puis redessine tout;	JUMP'	80$80$:LOAD.W	D0,D2SWAP.W	D0LOAD.W	D0,#-1	TEST.L	(A3)		; flche existe ?	JUMP',EQ 90$		; non => 90$				; oui =>;;;	LOAD.W	(A5)+OFLECHE,D2	; utilise la nouvelle flche;;;	LOAD.W	(A5)+OOBJET,#OBJFLECHELOAD.W	D0,#OBJFLECHE	TEST.L	D4:#2	JUMP',BC 90$;;;	LOAD.W	(A6)+OOBJET,#OBJFHVLOAD.W	D0,#OBJFHV90$:	POPM.L	D1..D5,A2..A4,A0TEST.W	D7	RET;--------\\; DBOXAFF >;--------/; Dessine une flche dans la DBOX.; in	A2.L	^table DBOX;	D5.L	canal;	D2.W	rang flche;	D1.W	mode de dessin; out	-; mod	D7.WDBOXAFF:	PUSHM.L	D0..D4,A4	LOAD.L	A4,#(A5)+OBUFLE	; A4 <-- ^flches	LOAD.W	D0,D2	MUL.WU	D0,#4	ADD.L	A4,D0		; A4 <-- ^la bonne flche	TEST.L	(A4)		; flche existe ?	JUMP,EQ 90$		; non => 90$	LOAD.W	D0,D2	SL.W	D0,#8	COMP.W	D2,#FLEMAX	JUMP',LO 10$	LOAD.W	D2,#1000	; D2 <-- rang du dernier objet10$:	ADD.W	D2,#2+2+2	; D2 <-- saute 2x cercles + carr	DBOX_	GETCO		; D3 <-- dbut, D4 <-- fin	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A5)+OCAR1Y	SR.W	D2,#1		; D2 <-- petite correction	SUB.W	D3,D2		; D3 <-- remonte un peu Y	SUB.W	D4,D2		; D4 <-- remonte un peu Y	SWAP.W	D4	SWAP.W	D3	TEST.B	(A4)+OFLEXT:#BFLEXT	JUMP',BC 50$				; flche extrieure =>	CLR.W	D2	LOAD.B	D2,(A4)+OFLLG	SL.W	D2,#1		; D2 <-- 2x longueur de la flche	COMP.W	D2,#32	JUMP',LS 40$	LOAD.W	D2,#3240$:	TEST.B	(A4)+OFLEXT:#BFLD3	JUMP',BC 45$	ADD.W	D3,D245$:	TEST.B	(A4)+OFLEXT:#BFLD4	JUMP',BC 50$	SUB.W	D4,D250$:	PUSH.W	(A5)+OSCALE	CLR.W	(A5)+OSCALE	INC.W	(A5)+ONWDOG	; ATTENTION: ne change pas de swdo !	LOAD.B	D0,#OBJFLECHE	LOAD.W	D2,D1		; D2 <-- mode de dessin	LOAD.W	D1,#TRAFIN	; D1 <-- mode du trait	CALL	FLECHE		; dessine une flche	DEC.W	(A5)+ONWDOG	; ATTENTION: restitue ONWDOG	POP.W	(A5)+OSCALE90$:	POPM.L	D0..D4,A4	RET; prov._PLANA_IIFLECHE:;***************;---------\\; IIFLECHE >;=========/; Initialise une translation nulle avant la lecture; d'un plan.; in	-; out	-; mod	-IIFLECHE:	PUSHM.L	D2,A4	LOAD.L	A4,#(A5)+OUSFLE	CLR.W	D2		; D2 <-- numro 1er10$:	LOAD.B	(A4+),D2	; met 0,1,2,3 ...	INC.W	D2		; D2 <-- numro suivant	COMP.W	D2,#FLEMAX	JUMP,LO	10$	POPM.L	D2,A4	RET; *** prov._PLANA_IMFLECHE:;***************;---------\\; IMFLECHE >;=========/; Mmorise une ventuelle translation de numro de flche; lors de la lecture d'un plan.; in	D3.L	flche;	D1.B	numro; out	-; mod	-IMFLECHE:	PUSHM.L	D1,D2,D3,D4,A4	CALL	SRCFLECHE	; D2 <-- flche existe dj ?	JUMP',EQ 50$		; oui => 50$				; non =>	PUSH.L	D3	CLR.L	D3		; D3 <-- coin inf/gauche plan	LOAD.L	D4,(A5)+OMWDOY	; D4 <-- coin sup/droite plan	CALL	IFFLECHE	; flche utilise dans plan ?	POPM.L	D3	JUMP',EQ 30$		; oui => 30$				; non =>	LOAD.B	D2,D1		; D2 <-- no du mme	CLR.W	D7		; D7 <-- ok	JUMP'	50$30$:	PUSH.L	D3	CLR.L	D3	CALL	SRCFLECHE	; D2 <-- cherche flche vide	POPM.L	D3	JUMP',EQ 50$		; ok => 50$				; tout plein =>	LOAD.W	D2,#FLEDEF	; D2 <-- flche par dfaut !50$:	LOAD.L	A4,#(A5)+OUSFLE	AND.W	D1,#H'FF	LOAD.B	(A4)+(D1.W),D2	TEST.W	D7		; emplacement trouv ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A4,#(A5)+OBUFLE	; A4 <-- ^flches	MUL.WU	D2,#4	ADD.L	A4,D2	LOAD.L	(A4)+0,D3	; met nouvelle flche90$:	POPM.L	D1,D2,D3,D4,A4	RET;---------\; IFFLECHE >;=========/; Cherche si une flche est utilise dans une zone.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D1.B	numro flche cherche; out	D7.W	trouv ou pas; mod	D7.WIFFLECHE:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A4	LOAD.B	D6,D1		; D6 <-- no flche	CALL	ORDONNE	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP',NE 90$10$:	CALL	FDETECTE	; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	PUSHM.L	D3,D4	CALL	PREND		; registres <-- objet	POPM.L	D3,D4	COMP.B	D0,#OBJFLECHE	; objet flche ?	JUMP',EQ 15$		; oui => 15$	COMP.B	D0,#OBJFHV	JUMP',NE 20$15$:	LOAD.W	D1,D0	SR.W	D1,#8	COMP.B	D1,D6		; bonne flche ?	JUMP',EQ 90$		; oui => 90$20$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$90$:	POPM.L	D0,D1,D2,D3,D4,D5,D6,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; ITFLECHE >;=========/; Translate un numro de flche lors de la lecture d'un plan.; in	D0.W	objet; out	D0.W	nouvel objet; mod	D0.WITFLECHE:	PUSHM.L	D1,A4	COMP.B	D0,#OBJFLECHE	; objet flche ?	JUMP',EQ 10$		; oui => 10$	COMP.B	D0,#OBJFHV	JUMP',NE 90$10$:	RR.W	D0,#8	LOAD.L	A4,#(A5)+OUSFLE	CLR.W	D1	LOAD.B	D1,D0	LOAD.B	D0,(A4)+(D1.W)	; D1 <-- nouveau numro	RR.W	D0,#890$:	POPM.L	D1,A4	RET;----------\\; SRCFLECHE >;----------/; Cherche si une flche existe dj.; in	D3.L	flche; out	D2.W	numro;	D7.W	erreur; mod	D2.W, D7.WSRCFLECHE:	PUSH.L	A3	CLR.W	D7		; D7 <-- trouv	LOAD.L	A3,#(A5)+OBUFLE	; A3 <-- ^flches	CLR.W	D2		; D2 <-- numro 1er10$:	COMP.L	D3,(A3+)	JUMP',EQ 90$	INC.W	D2		; D2 <-- numro suivant	COMP.W	D2,#FLEMAX	JUMP,LO	10$	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; DEFFLECHE >;==========/; Remet toutes les flches par dfaut.; in	-; out	-; mod	-DEFFLECHE:	PUSHM.L	D3,A3,A4	LOAD.L	A4,#R16"TFLECHES	LOAD.L	A3,#(A5)+OBUFLE	LOAD.W	D3,#FLEMAX*410$:	LOAD.B	(A3+),(A4+)	DEC.W	D3	JUMP,NE	10$	POPM.L	D3,A3,A4	RET;---------\\; DBOXFDEF >;=========/; Demande le type de flche  utiliser.; in	A4.L	^flche  modifier; out	D3.W	dernire touche (CR/END);	D7.W	erreur; mod	D3.L, D7.WDBOXFDEF:	PUSHM.L	D0..D2,D4,D5,A0..A4	LOAD.L	A0,A4		; A0 <-- ^flche  modifier	LOAD.L	A2,#R16"TDBOX_FDEF	LOAD.W	D2,#2^BDBSAV!2^BDBCAS!2^BDBMOU	CLR.L	D4		; D4 <-- fanions;;;	CALL	DBOXOPEN	; ouvre la DBOXPUSH.L	A0LOAD.L	A0,(A5)+OADBOPENCALL	(A0)POP.L	A0	JUMP,NE 90$	LOAD.L	A3,#R16"TFLECHE	LOAD.L	A2,#R16"00$	CLR.W	D105$:	CLR.W	D2	LOAD.B	D2,(A2+)	; D2 <-- rang dans dbox	JUMP',EQ 07$	DBOX_	GETCO	LOAD.L	D3,D4	LIB	?SETCURS	LOAD.W	D3,D1	CALL	AFNTEXT	; affiche une icne flche	INC.W	D1	JUMP	05$07$:	CALL	DBFLGFA		; D4 <-- fanions	LOAD.W	D2,#FLEMAX	; D2 <-- rang	LOAD.W	D1,#MODSET	; D1 <-- mode de dessin	CALL	DBOXAFF		; affiche la flche relle20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; OK ?	JUMP,EQ 80$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 85$	LOAD.W	D1,D3	SR.W	D1,#8	COMP.B	D1,#H'6F	JUMP',EQ 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:	COMP.B	D3,#24	JUMP',HS 46$	COMP.B	D3,#16	JUMP',HS 44$	COMP.B	D3,#8	JUMP',HS 42$				; clic dans bouton "extrmit" =>	CLR.B	D4	JUMP'	48$42$:				; clic dans bouton "longueur" =>	AND.W	D4,#H'00FF	JUMP'	48$44$:				; clic dans bouton "angle" =>	AND.L	D4,#H'FF00FFFF	JUMP'	48$46$:				; clic dans bouton "type" =>	AND.L	D4,#H'00FFFFFF48$:	TSET.L	D4:D3		; D4 <-- ajoute nouveau	LOAD.W	D2,#FLEMAX	; D2 <-- rang	LOAD.W	D1,#MODCLR	; D1 <-- mode de dessin	CALL	DBOXAFF		; efface la flche relle	CALL	DBFLPFA		; (A0) <-- type de la flche	LOAD.W	D1,#MODSET	; D1 <-- mode de dessin	CALL	DBOXAFF		; dessine la flche relle	JUMP	20$80$:				; OK =>	CALL	DBFLPFA		; (A0) <-- type de la flche85$:				; ANNULE =>;;;	CALL	DBOXCLOSE	; ferme la DBOXLOAD.L	A0,(A5)+OADBCLOSECALL	(A0)90$:	POPM.L	D0..D2,D4,D5,A0..A4	TEST.W	D7		; retour EQ/NE	RET00$:				; rangs des objets dans dbox :	.B	4,8,12,15	; extrmits	.B	5,9,13,16	; dimensions	.B	6,10,14,17	; angles	.B	7,11		; types	.B	0	.EVEN;--------\; AFNTEXT >		EXISTE AUSSI DANS PLANMISC;========/; Affiche un texte quelconque dans une liste pour m-menu.; in	A3.L	^textes pour m-menu;	D3.B	rang  afficher; out	D7.W	erreur; mod	D7.WAFNTEXT:	PUSHM.L	D3,A310$:	TEST.B	(A3)		; fin des textes ?	JUMP,EQ	90$		; oui => 90$	TEST.B	D3		; texte trouv ?	JUMP',EQ 50$		; oui => 50$20$:				; non =>	TEST.B	(A3+)		; A3 <-- saute .ASCIZ	JUMP,NE	20$	DEC.B	D3	JUMP	10$50$:	COMP.B	(A3+),#SPACE	; A3 <-- saute SPACE(s)	JUMP,EQ	50$	DEC.L	A3	COMP.B	(A3),#-1	; trait horizontal de sparation ?	JUMP',NE 70$		; non => 70$	INC.L	A3		; oui => saute le .B -170$:	COMP.B	(A3),#USEGC	; icne dans m-menu ?	JUMP',NE 80$		; non => 80$				; oui =>	LOAD.B	(A5)+OBWRITE+5,(A3)+4+1 ; saute <usegc><f><s><t> et <7>	LOAD.L	A3,#(A5)+OBWRITE	LOAD.B	(A3)+0,#USEGC	LOAD.B	(A3)+1,#GCICF	LOAD.B	(A3)+2,#GCICS	LOAD.B	(A3)+3,#GCICT	LOAD.B	(A3)+4,#AFTOUT;	LOAD.B	(A3)+5,#code	LOAD.B	(A3)+6,#AFNORM	LOAD.B	(A3)+7,#USEGC	LOAD.B	(A3)+8,#GCTXF	LOAD.B	(A3)+9,#GCTXS	LOAD.B	(A3)+10,#GCTXT	LOAD.W	D3,#11	LIB	?STRING		; affiche icne graphique	JUMP'	90$80$:	COMP.B	(A3+),#SPACE	; A3 <-- saute les espaces au dbut	JUMP,EQ 80$	DEC.L	A3	LIB	?AFTEXT		; affiche le .ASCIZ90$:	POPM.L	D3,A3	RET;--------\\; DBFLGFA >;--------/; Transforme (A0) --> D4 (fanions pour dbox).; in	A0.L	^flche; out	D4.L	fanions; mod	D4.LDBFLGFA:	PUSHM.L	D1,A1	CLR.L	D4	LOAD.B	D1,(A0)+OFLEXT	LOAD.B	D4,#B'0001	COMP.B	D1,#2^BFLD3!2^BFLD4	JUMP',EQ 10$	LOAD.B	D4,#B'0010	COMP.B	D1,#2^BFLD4	JUMP',EQ 10$	LOAD.B	D4,#B'0100	COMP.B	D1,#2^BFLD3!2^BFLD4!2^BFLEXT	JUMP',EQ 10$	LOAD.B	D4,#B'1000	COMP.B	D1,#2^BFLD4!2^BFLEXT	JUMP',EQ 10$	CLR.B	D410$:	CLR.W	D1	LOAD.B	D1,(A0)+OFLLG	; D0 <-- longueur (4, 8, 16 ou 32)	SL.W	D1,#8-2	OR.W	D4,D1		; D4 <-- bit 8..11 pour longueur	LOAD.B	D1,(A0)+OFLANG	ADD.B	D1,#16	TSET.L	D4:D1		; D4 <-- bit 16..19 pour angle	LOAD.B	D1,(A0)+OFLFOR	AND.B	D1,#B'1	ADD.B	D1,#24	TSET.L	D4:D1		; D4 <-- bit 24..25 pour forme	POPM.L	D1,A1	RET;--------\\; DBFLPFA >;--------/; Transforme D4 --> (A0).; in	D4.L	fanions; out	A0.L	^flche; mod	-DBFLPFA:	PUSHM.L	D1,A1	CLR.B	D1	TEST.L	D4:#0	JUMP',BC 10$	LOAD.B	D1,#2^BFLD3!2^BFLD410$:	TEST.L	D4:#1	JUMP',BC 11$	LOAD.B	D1,#2^BFLD411$:	TEST.L	D4:#2	JUMP',BC 12$	LOAD.B	D1,#2^BFLD3!2^BFLD4!2^BFLEXT12$:	TEST.L	D4:#3	JUMP',BC 13$	LOAD.B	D1,#2^BFLD4!2^BFLEXT13$:	LOAD.B	(A0)+OFLEXT,D1	LOAD.W	D1,D4	SR.W	D1,#8	SL.B	D1,#2	LOAD.B	(A0)+OFLLG,D1	CLR.B	D1	TEST.L	D4:#17	JUMP',BC 30$	LOAD.B	D1,#B'0130$:	TEST.L	D4:#18	JUMP',BC 31$	LOAD.B	D1,#B'1031$:	TEST.L	D4:#19	JUMP',BC 32$	LOAD.B	D1,#B'1132$:	LOAD.B	(A0)+OFLANG,D1	CLR.B	D1	TEST.L	D4:#25	JUMP',BC 40$	LOAD.B	D1,#2^BFLTRI40$:	LOAD.B	(A0)+OFLFOR,D1	POPM.L	D1,A1	RETDOKOK:	LOAD.W	D3,#CR	RETDOKANNULE:	LOAD.W	D3,#END	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RET; Flches; -------TFLECHES:			; 0	.B	2^BFLD3!2^BFLD4	.B	8	.B	1	.B	0				; 1	.B	2^BFLD3!2^BFLD4	.B	16	.B	2	.B	0				; 2	.B	2^BFLD3!2^BFLD4	.B	8	.B	0	.B	0				; 3	.B	2^BFLD3!2^BFLD4	.B	16	.B	2	.B	2^BFLTRI				; 4	.B	2^BFLD3!2^BFLD4	.B	16	.B	1	.B	2^BFLTRI				; 5	.B	2^BFLD4	.B	8	.B	1	.B	0				; 6	.B	2^BFLD4	.B	16	.B	2	.B	0				; 7	.B	2^BFLD4	.B	8	.B	0	.B	0				; 8	.B	2^BFLD4	.B	16	.B	2	.B	2^BFLTRI				; 9	.B	2^BFLD4	.B	16	.B	1	.B	2^BFLTRI				; 10	.B	2^BFLD3!2^BFLD4!2^BFLEXT	.B	8	.B	1	.B	0				; 11	.B	2^BFLD3!2^BFLD4!2^BFLEXT	.B	16	.B	2	.B	0				; 12	.B	2^BFLD3!2^BFLD4!2^BFLEXT	.B	8	.B	0	.B	0				; 13	.B	2^BFLD3!2^BFLD4!2^BFLEXT	.B	16	.B	2	.B	2^BFLTRI				; 14	.B	2^BFLD3!2^BFLD4!2^BFLEXT	.B	16	.B	1	.B	2^BFLTRI				; 15	.B	2^BFLD4!2^BFLEXT	.B	8	.B	1	.B	0				; 16	.B	2^BFLD4!2^BFLEXT	.B	16	.B	2	.B	0				; 17	.B	2^BFLD4!2^BFLEXT	.B	8	.B	0	.B	0				; 18	.B	2^BFLD4!2^BFLEXT	.B	16	.B	2	.B	2^BFLTRI				; 19	.B	2^BFLD4!2^BFLEXT	.B	16	.B	1	.B	2^BFLTRI				; 20	.B	0	.B	0	.B	0	.B	0				; 21	.B	0	.B	0	.B	0	.B	0				; 22	.B	0	.B	0	.B	0	.B	0				; 23	.B	0	.B	0	.B	0	.B	0				; 24	.B	0	.B	0	.B	0	.B	0	.EVENTDBOX_FLECHE:	.W	10$-TDBOX_FLECHE	.W	0	.W	0,010$:	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCIRCLE,0	.ASCIZ	" utilise"	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBCIRCLE,1	.ASCIZ	" modifie"	.B	ODBTEXT	.ASCIZ	"          "	.B	ODBSQUARE,2	.ASCIZ	" horizontal/vertical"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,2^7+0,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+1,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+2,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+3,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+4,TDBSCAD	.ASCIZ	"         "	.B	ODBCR,ODBCR	.B	ODBBOX,0,2^7+5,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+6,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+7,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+8,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+9,TDBSCAD	.ASCIZ	"         "	.B	ODBCR,ODBCR	.B	ODBBOX,0,2^7+10,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+11,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+12,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+13,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+14,TDBSCAD	.ASCIZ	"         "	.B	ODBCR,ODBCR	.B	ODBBOX,0,2^7+15,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+16,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+17,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+18,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+19,TDBSCAD	.ASCIZ	"         "	.B	ODBCR,ODBCR	.B	ODBBOX,0,2^7+20,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+21,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+22,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+23,TDBSCAD	.ASCIZ	"         "	.B	ODBBOX,0,2^7+24,TDBSCAD	.ASCIZ	"         "	.B	0	.EVENMENU_OKAN:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_OKAN:	.W	END,F0,F13,F14,F15,0	DOKANNULE-TKEY_OKAN	.W	CR,F1,F2,F3,0		DOKOK-TKEY_OKAN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_OKAN	.W	0TDBOX_FDEF:	.W	10$-TDBOX_FDEF	.W	MENU_OKAN-TDBOX_FDEF	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Extrmits"	.B	ODBTABX,14	.B	ODBTEXT	.ASCIZ	"Longueur"	.B	ODBTABX,28	.B	ODBTEXT	.ASCIZ	"Angle"	.B	ODBTABX,42	.B	ODBTEXT	.ASCIZ	"Forme"	.B	ODBTABX,56	.B	ODBCR,ODBCR	.B	ODBCIRCLE,0!2^7!2^6,H'6F,0	.ASCIZ	" "	.B	ODBTABX,14	.B	ODBCIRCLE,8!2^7!2^6,H'6F,8	.ASCIZ	" "	.B	ODBTABX,28	.B	ODBCIRCLE,16!2^7!2^6,H'6F,16	.ASCIZ	" "	.B	ODBTABX,42	.B	ODBCIRCLE,24!2^7!2^6,H'6F,24	.ASCIZ	" "	.B	ODBCR,ODBCR	.B	ODBCIRCLE,1!2^7!2^6,H'6F,1	.ASCIZ	" "	.B	ODBTABX,14	.B	ODBCIRCLE,9!2^7!2^6,H'6F,9	.ASCIZ	" "	.B	ODBTABX,28	.B	ODBCIRCLE,17!2^7!2^6,H'6F,17	.ASCIZ	" "	.B	ODBTABX,42	.B	ODBCIRCLE,25!2^7!2^6,H'6F,25	.ASCIZ	" "	.B	ODBCR,ODBCR	.B	ODBCIRCLE,2!2^7!2^6,H'6F,2	.ASCIZ	" "	.B	ODBTABX,14	.B	ODBCIRCLE,10!2^7!2^6,H'6F,10	.ASCIZ	" "	.B	ODBTABX,28	.B	ODBCIRCLE,18!2^7!2^6,H'6F,18	.ASCIZ	" "	.B	ODBCR,ODBCR	.B	ODBCIRCLE,3!2^7!2^6,H'6F,3	.ASCIZ	" "	.B	ODBTABX,14	.B	ODBCIRCLE,11!2^7!2^6,H'6F,11	.ASCIZ	" "	.B	ODBTABX,28	.B	ODBCIRCLE,19!2^7!2^6,H'6F,19	.ASCIZ	" "	.B	ODBCR,ODBCR	.B	ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	ODBTEXT	.ASCIZ	"      "	.B	ODBTEXT	.ASCIZ	"            "	; affiche ici la flche relle	.B	0	.EVENTFLECHE:	.B	USEGC,GCICF,GCICS,GCICT	.B	7,72,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,73,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,74,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,75,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,76,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,77,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,78,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,79,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,80,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,81,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,82,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,83,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,84,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	USEGC,GCICF,GCICS,GCICT	.B	7,85,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	""	.B	0	.EVEN	.END