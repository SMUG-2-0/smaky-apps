	.SBTTL	PLANAALIGNE		; 12 juillet 87 Sp.;--------\; ALIGNE  >;========/;; Aligne tous les objets dans une zone de recherche selon choix D6.B;; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D0.L	coordonn d'alignement;	D6.B	choix; out	-; mod	D7.WALIGNE:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4LOAD.B	D5,D6	LOAD.L	D6,D0		; D6 <-- coord. d'alignement	JUMP,EQ	90$		; si zro => 90$	CALL	ORDONNE	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP,NE	90$	CALL	SWMO		; met la souris "en attente"10$:	CALL	DETECTE		; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A3,A4		; A3 <-- ^lment actuel	CALL	NXTBASE		; A4 <-- ^lment suivant	EX.L	A3,A4		; A4 <-- ^act, A3 <-- ^suivant	PUSHM.L	D3,D4,D6,D7	CALL	PREND		; registres <-- objet	PUSH.W	D2	LOAD.B	D2,#MODINV	CALL	DESSINE		; efface l'objet	POP.W	D2	CALL	CLOBASE		; supprime l'objet	CALL	OPEBASE		; A4 <-- ^nouvel lment	CALL	OALIGNE		; ajuste objet par objet	CALL	MET		; objet <-- registres	TSET.B	(A4)+OMFLAGS:#BMNEW	CALL	DESSINE		; redessine l'objet	POPM.L	D3,D4,D6,D7	LOAD.L	A4,A3		; A4 <-- ^lment suivant	TEST.W	D7	JUMP,EQ	10$	JUMP'	80$20$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$80$:	CALL	CLRNEW		; ote les bits BMNEW90$:	CALL	CWMO		; remet la souris normale	POPM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	RET;---------\; OALIGNE  >;---------/;; Aligne les paramtres d'un objet sur le haut, bas, centr h/b, gauche, droite, centr g/d;; in	D0.B	objet;	D3.L	paramtre;	D4.L	paramtre;	D5.B	choix H-B-H/B-G-D-G/D;	D6.L	coord. d'alignement;	D6.L	offset +/-; out	D3.L	paramtre ajust;	D4.L	paramtre ajust; mod	D3.L, D4.LOALIGNE:	PUSHM.L	D1,D2,D5,D6	TEST.B	(A5)+OFLDET:#BDETGR	JUMP,BC	05$	CALL	ALIGROUPE	JUMP,EQ	90$	JUMP	85$05$:	COMP.B	D5,#0		; HAUT	JUMP,NE	10$	CALL	ALIHAUT	JUMP	80$10$:	COMP.B	D5,#1		; centr H/B	JUMP,NE	20$	CALL	ALIHB	JUMP	80$20$:	COMP.B	D5,#2		; BAS	JUMP,NE	30$	CALL	ALIBAS	JUMP	80$30$:	COMP.B	D5,#3		; GAUCHE	JUMP,NE	40$	CALL	ALIGAUCHE	JUMP	80$40$:	COMP.B	D5,#4		; centr G/D	JUMP,NE	50$	CALL	ALIGD	JUMP	80$50$:	COMP.B	D5,#5	JUMP,NE	80$	CALL	ALIDROITE;	JUMP	80$80$:	CALL	DSPLAN?		; dans le PLAN ?	JUMP,EQ	90$		; oui85$:	PUSH.L	D3		; non, erreur	LOAD.B	D3,#BIPLIT	LIB	?BEEP	POP.L	D390$:	CLR.W	D7	POPM.L	D1,D2,D5,D6	RET;--------- DSPLAN?:;---------;; teste si objet dans plan, sinon ajuste les paramtres et signale erreur par bip;; in	D0.B	objet;	D3.L	paramtre;	D4.L	paramtre;	D6.L	coord. d'alignement; out	D3.L	paramtre ajust;	D4.L	paramtre ajust; mod	D1,D2,D3.L, D4.L,D7.W;	CLR.W	D7	COMP.B	D0,#OBJCERCLE	JUMP,EQ	10$	COMP.B	D0,#OBJARC	JUMP,EQ	50$	COMP.B	D0,#OBJELLIPSE	JUMP,EQ	20$	COMP.B	D0,#OBJARCELL	JUMP,EQ	60$	COMP.B	D0,#OBJTEXT	JUMP,EQ	80$05$:				; reste des objets	CALL	30$	CALL	40$	JUMP	90$10$:				; CERCLE	CALL	11$	CALL	12$	CALL	13$	CALL	14$	JUMP	90$13$:	SUB.W	D4,D3		; gauche	CALL	40$	ADD.W	D4,D3	RET11$:	ADD.W	D4,D3		; droite	CALL	40$	SUB.W	D4,D3	RET14$:	SWAP.W	D4	SUB.W	D4,D3		; bas	SWAP.W	D4	CALL	40$	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D4	RET12$:	SWAP.W	D4	ADD.W	D4,D3		; haut	SWAP.W	D4	CALL	40$	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D4	RET20$:				; ELLIPSE	CALL	11$	CALL	22$	CALL	13$	CALL	24$	JUMP	90$;23$:;	SUB.W	D4,D3		; gauche;	CALL	40$;	ADD.W	D4,D3;	RET;21$:;	ADD.W	D4,D3		; droite;	CALL	40$;	SUB.W	D4,D3;	RET24$:	SWAP.W	D3		; bas	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D4	CALL	40$	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D4	SWAP.W	D3	RET22$:	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3		; haut	SWAP.W	D4	CALL	40$	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D4	SWAP.W	D3	RET	50$:					; ARCS	LOAD.W	D1,D3	SR.W	D1,#8	COMP.B	D1,#B'00000001	JUMP,EQ	56$	COMP.B	D1,#B'00000010	JUMP,EQ	56$	COMP.B	D1,#B'00000100	JUMP,EQ	57$	COMP.B	D1,#B'00001000	JUMP,EQ	57$	COMP.B	D1,#B'00010000	JUMP,EQ	58$	COMP.B	D1,#B'00100000	JUMP,EQ	58$	COMP.B	D1,#B'01000000	JUMP,EQ	59$	COMP.B	D1,#B'10000000	JUMP,EQ	59$	JUMP	90$56$:	CALL	11$	CALL	12$	CALL	40$	JUMP	90$57$:	CALL	12$	CALL	13$	CALL	40$	JUMP	90$58$:	CALL	13$	CALL	14$	CALL	40$	JUMP	90$59$:	CALL	14$	CALL	11$	CALL	40$	JUMP	90$60$:				; ARCELL	LOAD.W	D1,D0	SR.W	D1,#8	COMP.B	D1,#B'00000001	JUMP,EQ	66$	COMP.B	D1,#B'00000010	JUMP,EQ	66$	COMP.B	D1,#B'00000100	JUMP,EQ	67$	COMP.B	D1,#B'00001000	JUMP,EQ	67$	COMP.B	D1,#B'00010000	JUMP,EQ	68$	COMP.B	D1,#B'00100000	JUMP,EQ	68$	COMP.B	D1,#B'01000000	JUMP,EQ	69$	COMP.B	D1,#B'10000000	JUMP,EQ	69$	JUMP	90$66$:	CALL	11$	CALL	22$	CALL	40$	JUMP	90$67$:	CALL	22$	CALL	13$	CALL	40$	JUMP	90$68$:	CALL	13$	CALL	24$	CALL	40$	JUMP	90$69$:	CALL	24$	CALL	11$	CALL	40$	JUMP	90$30$:		COMP.W	D3,#1			; D3 ?	JUMP,GE	31$	DEC.W	D7	LOAD.W	D3,#131$:	COMP.W	D3,(A5)+OMWDOX;	JUMP,LE	32$	JUMP,LO	32$	DEC.W	D7	LOAD.W	D3,(A5)+OMWDOX	DEC.W	D332$:	SWAP.W	D3	COMP.W	D3,#1	JUMP,GE	33$	DEC.W	D7	LOAD.W	D3,#133$:	COMP.W	D3,(A5)+OMWDOY;	JUMP,LE	34$	JUMP,LO	34$	DEC.W	D7	LOAD.W	D3,(A5)+OMWDOY	DEC.W	D334$:	SWAP.W	D3	RET40$:;	COMP.W	D4,#1			; D4 ?;	JUMP,GE	41$TEST.W	D4JUMP,NC	41$	DEC.W	D7	LOAD.W	D4,#141$:	COMP.W	D4,(A5)+OMWDOX;	JUMP,LE	42$	JUMP,LO	42$	DEC.W	D7	LOAD.W	D4,(A5)+OMWDOX	DEC.W	D442$:	SWAP.W	D4;	COMP.W	D4,#1;	JUMP,GE	43$TEST.W	D4JUMP,NC	43$	DEC.W	D7	LOAD.W	D4,#143$:	COMP.W	D4,(A5)+OMWDOY;	JUMP,LE	44$	JUMP,LO	44$	DEC.W	D7	LOAD.W	D4,(A5)+OMWDOY	DEC.W	D444$:	SWAP.W	D4	RET80$:					; TEXTE	CALL	40$	LOAD.W	D1,D0	SR.W	D1,#8	LOAD.W	D2,D3	SR.W	D2,#8	ADD.W	D4,D1	SWAP.W	D4	ADD.W	D4,D2	SWAP.W	D4	CALL	40$	SUB.W	D4,D1	SWAP.W	D4	SUB.W	D4,D2	SWAP.W	D4;	JUMP	90$90$:	TEST.W	D7	RET;----------- ALIGROUPE:;-----------;; dplace un groupe pour aligner;; in	D0.B	objet;	D3.L	paramtre;	D4.L	paramtre;	D6.L	coord. d'alignement; out	D3.L	paramtre ajust;	D4.L	paramtre ajust; mod	D1,D2,D3.L, D4.L,D7.W;	PUSH.L	D6	CLR.W	D7	COMP.B	D5,#0		; HAUT	JUMP,NE	10$	CLR.W	D6		; X fixe	SWAP.W	D6		; Y =>	SUB.W	D6,(A5)+OGRHD+OYY	LOAD.W	D1,D6	ADD.W	D1,(A5)+OGRBG+OYY	JUMP,NC	05$	DEC.W	D7	SUB.W	D6,D105$:	SWAP.W	D6	JUMP	80$		; ajuste10$:	COMP.B	D5,#1		; centr H/B	JUMP,NE	20$	CLR.W	D6		; X offset nul	SWAP.W	D6		; Y =>	LOAD.W	D1,(A5)+OGRHD+OYY	SUB.W	D1,(A5)+OGRBG+OYY	SR.W	D1	ADD.W	D1,(A5)+OGRBG+OYY	SUB.W	D6,D1	LOAD.W	D2,(A5)+OGRBG+OYY	ADD.W	D2,D6	JUMP,NC	15$	DEC.W	D7	SUB.W	D6,D215$:	LOAD.W	D2,(A5)+OGRHD+OYY	ADD.W	D2,D6INC.W	D2		; correction Y max.	SUB.W	D2,(A5)+OMWDOY	JUMP,NS	16$	DEC.W	D7	SUB.W	D6,D216$:	SWAP.W	D6	JUMP	80$20$:	COMP.B	D5,#2		; BAS	JUMP,NE	30$	CLR.W	D6	SWAP.W	D6	SUB.W	D6,(A5)+OGRBG+OYY	LOAD.W	D1,(A5)+OGRHD	ADD.W	D1,D6	SUB.W	D1,(A5)+OMWDOY	JUMP,NS	25$	DEC.W	D7	SUB.W	D6,D125$:	SWAP.W	D6	JUMP	80$30$:	COMP.B	D5,#3		; GAUCHE	JUMP,NE	40$	SWAP.W	D6	CLR.W	D6	SWAP.W	D6	SUB.W	D6,(A5)+OGRBG+OXX	LOAD.W	D1,D6	ADD.W	D1,(A5)+OGRHD+OXX	SUB.W	D1,(A5)+OMWDOX	JUMP,NS	80$	JUMP	75$40$:	COMP.B	D5,#4		; centr G/D	JUMP,NE	50$	SWAP.W	D6	CLR.W	D6		; Y fixe	SWAP.W	D6		; X =>	LOAD.W	D2,(A5)+OGRHD+OXX	SUB.W	D2,(A5)+OGRBG+OXX	SR.W	D2	ADD.W	D2,(A5)+OGRBG+OXX	SUB.W	D6,D2	LOAD.W	D1,D6	ADD.W	D1,(A5)+OGRBG+OXX	JUMP,NC	45$	DEC.W	D7	SUB.W	D6,D145$:	LOAD.W	D1,(A5)+OGRHD+OXX	ADD.W	D1,D6	SUB.W	D1,(A5)+OMWDOX	JUMP,NS	80$	JUMP	75$50$:				; DROITE	COMP.B	D5,#5	JUMP,NE	80$	SWAP.W	D6	CLR.W	D6	SWAP.W	D6	SUB.W	D6,(A5)+OGRHD+OXX	LOAD.W	D1,D6	ADD.W	D1,(A5)+OGRBG+OXX	JUMP,NC	80$;	JUMP	75$75$:	DEC.W	D7	SUB.W	D6,D180$:	CALL	AJUSTE	POP.L	D6	TEST.W	D7	RET;----------- ALIDROITE:;-----------;; in	D0.B	objet;	D3.L	paramtre;	D4.L	paramtre;	D6.L	coord. d'alignement; out	D3.L	paramtre ajust;	D4.L	paramtre ajust; mod	D1,D2,D3.L, D4.L,D7.W;	COMP.B	D0,#OBJRECT	JUMP,EQ	20$	COMP.B	D0,#OBJSURF	JUMP,EQ	20$	COMP.B	D0,#OBJLIGNE	JUMP,EQ	30$	COMP.B	D0,#OBJELASTIQUE	JUMP,EQ	30$	COMP.B	D0,#OBJEHV	JUMP,EQ	40$	COMP.B	D0,#OBJFLECHE	JUMP,EQ	30$	COMP.B	D0,#OBJFHV	JUMP,EQ	40$	COMP.B	D0,#OBJCERCLE	JUMP,EQ	60$	COMP.B	D0,#OBJARC	JUMP,EQ	70$	COMP.B	D0,#OBJELLIPSE	JUMP,EQ	60$	COMP.B	D0,#OBJARCELL	JUMP,EQ	50$	COMP.B	D0,#OBJTEXT	JUMP,EQ	80$				; objet rectangulaire =>10$:				; translate coins D3 et D4	LOAD.W	D1,D6	LOAD.W	D2,D6	SUB.W	D1,D3	SUB.W	D2,D4	COMP.W	D1,D2	JUMP,GT	15$	ADD.W	D3,D1	ADD.W	D4,D1	JUMP	90$15$:	ADD.W	D3,D2	ADD.W	D4,D2	JUMP	90$20$:				; rectangle lastique =>	CALL	ORDONNE		LOAD.W	D1,D4	SUB.W	D1,D3		; D1 <-- delta x	TEST.B	(A5)+ORCOIN:#0	; coin X1 trouv ?	JUMP',BC 22$		; non => 22$				; oui =>	LOAD.W	D3,D6		; aligne X122$:	TEST.B	(A5)+ORCOIN:#2	; coin X2 trouv ?	JUMP',BC 24$		; non => 26$				; oui =>	LOAD.W	D4,D6		; aligne X224$:	COMP.W	D4,D6		; D4 > limite ?	JUMP,LS	26$	LOAD.W	D4,D626$:	COMP.W	D3,D6		; D3 > limite ?	JUMP,LS	28$	LOAD.W	D3,D628$:	CALL	ORDONNE	COMP.W	D3,D4		; D3 = D4 ?	JUMP,NE	90$		; non	SUB.W	D3,D1		; D3  gauche de la limite de delta x	JUMP	90$30$:				; ELASTIQUE =>	TEST.B	(A5)+ORCOIN:#0	; coin D3 trouv ?	JUMP',BC 32$		; non => 32$				; oui =>	COMP.W	D4,D6		; D4 < D6	JUMP,HI	10$		; non => 10$				; oui =>	TEST.B	(A5)+ORCOIN:#1	; coin D4 trouv ?	JUMP,BS	10$		; oui => 10$	LOAD.W	D3,D6		; non, aligne D3 en X	JUMP	90$32$:				; coin D3 pas trouv, alors coin D4	COMP.W	D3,D6		; D3 < D6	JUMP,HI	10$		; non => 10$	LOAD.W	D4,D6		; aligne D4 en X	JUMP	90$40$:				; ELASTIQUE HOR. OU VERT. =>	COMP.W	D3,D4		; verticale ?	JUMP,NE	30$		; non, horiz. => 30$				; verticale =>	LOAD.W	D3,D6		; aligne X	LOAD.W	D4,D6		; aligne X	JUMP	90$50$:				; arcell	TEST.L	D0:#0+8	JUMP,BS	60$	TEST.L	D0:#7+8	JUMP,BS 60$	LOAD.W	D4,D6		; aligne sur centre	JUMP	90$60$:				; CERCLE/ELLIPSE	LOAD.W	D4,D6		; centre = D6 - rayon	SUB.W	D4,D3	JUMP	90$70$:				; ARCS	TEST.L	D3:#0+16	JUMP,BS	60$	TEST.L	D3:#7+16	JUMP,BS 60$	LOAD.W	D4,D6		; aligne sur centre	TEST.L	D3:#2+16	JUMP,BS	90$	TEST.L	D3:#5+16	JUMP,BS	90$	LOAD.W	D2,D3		; D2 rayon	MUL.WU	D2,#707		; D2 * sin(45)*1000	DIV.WU	D2,#1000	; D2 * sin(45)	TEST.L	D3:#1+16	JUMP,BS	72$	TEST.L	D3:#6+16	JUMP,BS	72$		; 3		; 474$:	ADD.W	D4,D2	JUMP	90$72$:	SUB.W	D4,D2	JUMP	90$80$:				; texte	LOAD.W	D4,D6	LOAD.W	D1,D0	SR.W	D1,#8	AND.W	D1,#H'FF	SUB.W	D4,D1	SWAP.W	D0;	JUMP	90$90$:	RET;-------- ALIBAS:;--------;; in	D0.B	objet;	D3.L	paramtre;	D4.L	paramtre;	D6.L	coord. d'alignement; out	D3.L	paramtre ajust;	D4.L	paramtre ajust; mod	D1,D2,D3.L, D4.L,D7.W;	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	COMP.B	D0,#OBJRECT	JUMP,EQ	20$	COMP.B	D0,#OBJCERCLE	JUMP,EQ	60$	COMP.B	D0,#OBJARC	JUMP,EQ	70$	COMP.B	D0,#OBJELLIPSE	JUMP,EQ	55$	COMP.B	D0,#OBJARCELL	JUMP,EQ	50$	COMP.B	D0,#OBJTEXT	JUMP,EQ	80$	CALL	ALIGAUCHE	JUMP	90$20$:				; rectangle lastique =>	SWAP.W	D3	SWAP.W	D4	CALL	ORDONNE	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D4	SUB.W	D1,D3		; D1 <-- delta x	TEST.B	(A5)+ORCOIN:#3	; coin Y1 trouv ?	JUMP',BC 22$		; non => 22$				; oui =>	LOAD.W	D4,D6		; aligne Y122$:	TEST.B	(A5)+ORCOIN:#1	; coin Y2 trouv ?	JUMP',BC 24$		; non => 26$				; oui =>	LOAD.W	D3,D6		; aligne Y224$:	COMP.W	D4,D6		; D4 > limite ?	JUMP,HS	26$	LOAD.W	D4,D626$:	COMP.W	D3,D6		; D3 > limite ?	JUMP,HS	28$	LOAD.W	D3,D628$:	SWAP.W	D3	SWAP.W	D4	CALL	ORDONNE	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4		; D3 = D4 ?	JUMP,NE	90$		; non	ADD.W	D4,D1		; D3  gauche de la limite de delta x	JUMP	90$50$:				; ARCELL =>	TEST.L	D0:#5+8	JUMP,BS	55$	TEST.L	D0:#6+8	JUMP,BS 55$	LOAD.W	D4,D6		; aligne sur centre	JUMP	90$55$:				; ELLIPSE =>	LOAD.W	D4,D6	ADD.W	D4,D3	JUMP	90$60$:				; CERCLE =>	SWAP.W	D3	LOAD.W	D4,D6		; centre = D6 + rayon	ADD.W	D4,D3	SWAP.W	D3	JUMP	90$70$:				; ARCS	TEST.L	D3:#5	JUMP,BS	60$	TEST.L	D3:#6	JUMP,BS 60$	LOAD.W	D4,D6		; aligne sur centre	TEST.L	D3:#3	JUMP,BS	90$	TEST.L	D3:#0	JUMP,BS	90$	LOAD.L	D2,D3		; D2 rayon	SWAP.W	D2	MUL.WU	D2,#707		; D2 * sin(45)*1000	DIV.WU	D2,#1000	; D2 * sin(45)	TEST.L	D3:#4	JUMP,BS	72$	TEST.L	D3:#7	JUMP,BS	72$		; 1		; 2	SUB.W	D4,D2	JUMP	90$72$:	ADD.W	D4,D2	JUMP	90$80$:				; TEXTE =>	LOAD.W	D4,D6;	JUMP	90$90$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	RET;----------- ALIGAUCHE:;-----------;; in	D0.B	objet;	D3.L	paramtre;	D4.L	paramtre;	D6.L	coord. d'alignement; out	D3.L	paramtre ajust;	D4.L	paramtre ajust; mod	D1,D2,D3.L, D4.L,D7.W;	COMP.B	D0,#OBJRECT	JUMP,EQ	20$	COMP.B	D0,#OBJSURF	JUMP,EQ	20$	COMP.B	D0,#OBJLIGNE	JUMP,EQ	30$	COMP.B	D0,#OBJELASTIQUE	JUMP,EQ	30$	COMP.B	D0,#OBJEHV	JUMP,EQ	40$	COMP.B	D0,#OBJFLECHE	JUMP,EQ	30$	COMP.B	D0,#OBJFHV	JUMP,EQ	40$	COMP.B	D0,#OBJCERCLE	JUMP,EQ	60$	COMP.B	D0,#OBJARC	JUMP,EQ	70$	COMP.B	D0,#OBJELLIPSE	JUMP,EQ	60$	COMP.B	D0,#OBJARCELL	JUMP,EQ	50$	COMP.B	D0,#OBJTEXT	JUMP,EQ	80$				; objet rectangulaire =>10$:				; translate coins D3 et D4	LOAD.W	D1,D6	LOAD.W	D2,D6	SUB.W	D1,D3	SUB.W	D2,D4	COMP.W	D1,D2	JUMP,LT	15$	ADD.W	D3,D1	ADD.W	D4,D1	JUMP	90$15$:	ADD.W	D3,D2	ADD.W	D4,D2	JUMP	90$20$:				; rectangle lastique =>	CALL	ORDONNE	LOAD.W	D1,D4	SUB.W	D1,D3		; D1 <-- delta x	TEST.B	(A5)+ORCOIN:#2	; coin X1 trouv ?	JUMP',BC 22$		; non => 22$				; oui =>	LOAD.W	D4,D6		; aligne X122$:	TEST.B	(A5)+ORCOIN:#0	; coin X2 trouv ?	JUMP',BC 24$		; non => 26$				; oui =>	LOAD.W	D3,D6		; aligne X224$:	COMP.W	D4,D6		; D4 > limite ?	JUMP,HS	26$	LOAD.W	D4,D626$:	COMP.W	D3,D6		; D3 > limite ?	JUMP,HS	28$	LOAD.W	D3,D628$:	CALL	ORDONNE	COMP.W	D3,D4		; D3 = D4 ?	JUMP,NE	90$		; non	ADD.W	D4,D1		; D3  gauche de la limite de delta x	JUMP	90$30$:				; ELASTIQUE =>	TEST.B	(A5)+ORCOIN:#0	; coin D3 trouv ?	JUMP',BC 32$		; non => 32$				; oui =>	COMP.W	D4,D6		; D4 > D6	JUMP,LO	10$		; non => 10$				; oui =>	TEST.B	(A5)+ORCOIN:#1	; coin D4 trouv ?	JUMP,BS	10$		; oui => 10$	LOAD.W	D3,D6		; non, aligne D3 en X	JUMP	90$32$:				; coin D3 pas trouv, alors coin D4	COMP.W	D3,D6		; D3 > D6	JUMP,LO	10$		; non => 10$	LOAD.W	D4,D6		; aligne D4 en X	JUMP	90$40$:				; ELASTIQUE HOR. OU VERT. =>	COMP.W	D3,D4		; verticale ?	JUMP,NE	30$		; non, horiz. => 30$				; verticale =>	LOAD.W	D3,D6		; aligne X	LOAD.W	D4,D6		; aligne X	JUMP	90$50$:				; arcell	TEST.L	D0:#3+8	JUMP,BS	60$	TEST.L	D0:#4+8	JUMP,BS 60$	LOAD.W	D4,D6		; aligne sur centre	JUMP	90$60$:				; CERCLE/ELLIPSE	LOAD.W	D4,D6		; centre = D6 - rayon	ADD.W	D4,D3	JUMP	90$70$:				; ARCS	TEST.L	D3:#3+16	JUMP,BS	60$	TEST.L	D3:#4+16	JUMP,BS 60$	LOAD.W	D4,D6		; aligne sur centre	TEST.L	D3:#1+16	JUMP,BS	90$	TEST.L	D3:#6+16	JUMP,BS	90$	LOAD.W	D2,D3		; D2 rayon	MUL.WU	D2,#707		; D2 * sin(45)*1000	DIV.WU	D2,#1000	; D2 * sin(45)	TEST.L	D3:#2+16	JUMP,BS	72$	TEST.L	D3:#5+16	JUMP,BS	72$		; 3		; 474$:	SUB.W	D4,D2	JUMP	90$72$:	ADD.W	D4,D2	JUMP	90$80$:				; texte	LOAD.W	D4,D6;	JUMP	90$90$:	RET;---------- ALIHAUT:;----------;; in	D0.B	objet;	D3.L	paramtre;	D4.L	paramtre;	D6.L	coord. d'alignement; out	D3.L	paramtre ajust;	D4.L	paramtre ajust; mod	D1,D2,D3.L, D4.L,D7.W;	SWAP.W	D6	SWAP.W	D3	SWAP.W	D4	COMP.B	D0,#OBJRECT	JUMP,EQ	20$	COMP.B	D0,#OBJCERCLE	JUMP,EQ	60$	COMP.B	D0,#OBJARC	JUMP,EQ	70$	COMP.B	D0,#OBJELLIPSE	JUMP,EQ	55$	COMP.B	D0,#OBJARCELL	JUMP,EQ	50$	COMP.B	D0,#OBJTEXT	JUMP,EQ	80$10$:	CALL	ALIDROITE	JUMP	90$20$:				; rectangle lastique =>	SWAP.W	D3	SWAP.W	D4	CALL	ORDONNE	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D4	SUB.W	D1,D3		; D1 <-- delta x	TEST.B	(A5)+ORCOIN:#1	; coin X1 trouv ?	JUMP',BC 22$		; non => 22$				; oui =>	LOAD.W	D3,D6		; aligne X122$:	TEST.B	(A5)+ORCOIN:#3	; coin X2 trouv ?	JUMP',BC 24$		; non => 26$				; oui =>	LOAD.W	D4,D6		; aligne X224$:	COMP.W	D4,D6		; D4 > limite ?	JUMP,LS	26$	LOAD.W	D4,D626$:	COMP.W	D3,D6		; D3 > limite ?	JUMP,LS	28$	LOAD.W	D3,D628$:	SWAP.W	D3	SWAP.W	D4	CALL	ORDONNE	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4		; D3 = D4 ?	JUMP,NE	90$		; non	SUB.W	D3,D1		; D3  gauche de la limite de delta x	JUMP	90$50$:				; ARCELL =>	TEST.L	D0:#1+8	JUMP,BS	55$	TEST.L	D0:#2+8	JUMP,BS 55$	LOAD.W	D4,D6		; aligne sur centre	JUMP	90$55$:				; ELLIPSE =>	LOAD.W	D4,D6	SUB.W	D4,D3	JUMP	90$60$:				; CERCLE =>	SWAP.W	D3	LOAD.W	D4,D6		; centre = D6 - rayon	SUB.W	D4,D3	SWAP.W	D3	JUMP	90$70$:				; ARCS	TEST.L	D3:#1	JUMP,BS	60$	TEST.L	D3:#2	JUMP,BS 60$	LOAD.W	D4,D6		; aligne sur centre	TEST.L	D3:#4	JUMP,BS	90$	TEST.L	D3:#7	JUMP,BS	90$	LOAD.L	D2,D3		; D2 rayon	SWAP.W	D2	MUL.WU	D2,#707		; D2 * sin(45)*1000	DIV.WU	D2,#1000	; D2 * sin(45)	TEST.L	D3:#0	JUMP,BS	72$	TEST.L	D3:#3	JUMP,BS	72$		; 5		; 6	ADD.W	D4,D2	JUMP	90$72$:	SUB.W	D4,D2	JUMP	90$80$:				; TEXTE =>	LOAD.L	D2,D3	SWAP.W	D2	SR.W	D2,#8	AND.W	D2,#H'FF	LOAD.W	D4,D6	SUB.W	D4,D2;	JUMP	90$90$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	RET;------- ALIGD:;-------;; in	D0.B	objet;	D3.L	paramtre;	D4.L	paramtre;	D6.L	coord. d'alignement; out	D3.L	paramtre ajust;	D4.L	paramtre ajust; mod	D1,D2,D3.L, D4.L,D7.W;	COMP.B	D0,#OBJRECT	JUMP,EQ	20$	COMP.B	D0,#OBJSURF	JUMP,EQ	20$	COMP.B	D0,#OBJLIGNE	JUMP,EQ	30$	COMP.B	D0,#OBJELASTIQUE	JUMP,EQ	30$	COMP.B	D0,#OBJEHV	JUMP,EQ	40$	COMP.B	D0,#OBJFLECHE	JUMP,EQ	30$	COMP.B	D0,#OBJFHV	JUMP,EQ	40$	COMP.B	D0,#OBJCERCLE	JUMP,EQ	60$	COMP.B	D0,#OBJARC	JUMP,EQ	70$	COMP.B	D0,#OBJELLIPSE	JUMP,EQ	60$	COMP.B	D0,#OBJARCELL	JUMP,EQ	50$	COMP.B	D0,#OBJTEXT	JUMP,EQ	80$				; objet rectangulaire =>10$:				; translate coins D3 et D4	LOAD.W	D1,D4	SUB.W	D1,D3	JUMP,NC	11$	NEG.W	D111$:	SR.W	D1	COMP.W	D3,D4	JUMP,GT	15$	LOAD.W	D3,D6	SUB.W	D3,D1	LOAD.W	D4,D6	ADD.W	D4,D1	JUMP	90$15$:	LOAD.W	D3,D6	ADD.W	D3,D1	LOAD.W	D4,D6	SUB.W	D4,D1	JUMP	90$20$:				; rectangle lastique =>	CALL	ORDONNE	LOAD.W	D1,D6	TEST.B	(A5)+ORCOIN:#0	; coin X1 trouv ?	JUMP',BC 22$		; non => 22$				; oui =>	TEST.B	(A5)+ORCOIN:#2	JUMP,BS	10$		; trouv les deux	SUB.W	D1,D4	LOAD.W	D3,D6	ADD.W	D3,D1	CALL	ORDONNE	JUMP	90$22$:	SUB.W	D1,D3	LOAD.W	D4,D6	ADD.W	D4,D1	CALL	ORDONNE	JUMP	90$30$:				; ELASTIQUE =>	LOAD.W	D1,D6	TEST.B	(A5)+ORCOIN:#0	; coin D3 trouv ?	JUMP',BC 32$		; non => 32$				; oui =>	TEST.B	(A5)+ORCOIN:#1	JUMP,BS	10$	SUB.W	D1,D4	LOAD.W	D3,D6	ADD.W	D3,D1	JUMP	90$32$:	SUB.W	D1,D3	LOAD.W	D4,D6	ADD.W	D4,D1	JUMP	90$40$:				; ELASTIQUE HOR. OU VERT. =>	COMP.W	D3,D4		; verticale ?	JUMP,NE	30$		; non, horiz. => 30$				; verticale =>	LOAD.W	D3,D6		; aligne X	LOAD.W	D4,D6		; aligne X	JUMP	90$50$:				; ARCELL G/D	LOAD.W	D1,D0	SR.W	D1,#8	LOAD.W	D4,D6	LOAD.W	D2,D3	SR.W	D2	COMP.B	D1,#B'00001111	JUMP,EQ	90$	COMP.B	D1,#B'11110000	JUMP,EQ	90$	COMP.B	D1,#B'00000011	JUMP,EQ	78$	COMP.B	D1,#B'11000000	JUMP,EQ	78$	COMP.B	D1,#B'11000011	JUMP,EQ	78$	COMP.B	D1,#B'00001100	JUMP,EQ	77$	COMP.B	D1,#B'00110000	JUMP,EQ	77$	COMP.B	D1,#B'00111100	JUMP,EQ	77$	JUMP	90$60$:				; CERCLE/ELLIPSE	LOAD.W	D4,D6		; centre = D6	JUMP	90$70$:				; ARCS	SWAP.W	D3	LOAD.W	D1,D3		; D1 <-- arcs	SWAP.W	D3	LOAD.W	D4,D6	COMP.B	D1,#B'00001111	JUMP,EQ	90$	COMP.B	D1,#B'11110000	JUMP,EQ	90$	LOAD.W	D2,D3	SR.W	D2	LOAD.W	D4,D6	COMP.B	D1,#B'00000011	JUMP,EQ	78$	COMP.B	D1,#B'11000000	JUMP,EQ	78$	COMP.B	D1,#B'00001100	JUMP,EQ	77$	COMP.B	D1,#B'00110000	JUMP,EQ	77$	COMP.B	D1,#B'11000011	JUMP,EQ	78$	COMP.B	D1,#B'00111100	JUMP,EQ	77$	LOAD.W	D2,D3	MUL.WU	D2,#924	DIV.WU	D2,#1000	COMP.B	D1,#B'00000001	JUMP,EQ	78$	COMP.B	D1,#B'10000000	JUMP,EQ	78$	COMP.B	D1,#B'00001000	JUMP,EQ	77$	COMP.B	D1,#B'00010000	JUMP,EQ	77$	LOAD.W	D2,D3	MUL.WU	D2,#383	DIV.WU	D2,#1000	COMP.B	D1,#B'00000010	JUMP,EQ	78$	COMP.B	D1,#B'01000000	JUMP,EQ	78$	COMP.B	D1,#B'00000100	JUMP,EQ	77$	COMP.W	D1,#B'00100000	JUMP,EQ	77$	JUMP	90$77$:	ADD.W	D4,D2	JUMP	90$78$:	SUB.W	D4,D2	JUMP	90$80$:				; texte	LOAD.W	D4,D6	LOAD.W	D1,D0	SR.W	D1,#8	AND.W	D1,#H'FF	SR.W	D1	SUB.W	D4,D1	SWAP.W	D0;	JUMP	90$90$:	RET;---------- ALIHB:;----------;; in	D0.B	objet;	D3.L	paramtre;	D4.L	paramtre;	D6.L	coord. d'alignement; out	D3.L	paramtre ajust;	D4.L	paramtre ajust; mod	D1,D2,D3.L, D4.L,D7.W;	SWAP.W	D6	SWAP.W	D3	SWAP.W	D4	COMP.B	D0,#OBJRECT	JUMP,EQ	20$	COMP.B	D0,#OBJCERCLE	JUMP,EQ	60$	COMP.B	D0,#OBJARC	JUMP,EQ	70$	COMP.B	D0,#OBJELLIPSE	JUMP,EQ	60$	COMP.B	D0,#OBJARCELL	JUMP,EQ	50$	COMP.B	D0,#OBJTEXT	JUMP,EQ	80$10$:	CALL	ALIGD	JUMP	90$20$:				; rectangle lastique =>	SWAP.W	D3	SWAP.W	D4	CALL	ORDONNE	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D6	TEST.B	(A5)+ORCOIN:#1	; coin X1 trouv ?	JUMP',BC 22$		; non => 22$				; oui =>	TEST.B	(A5)+ORCOIN:#3	JUMP,BS	10$		; trouv les deux	SUB.W	D1,D4	LOAD.W	D3,D6	ADD.W	D3,D1	SWAP.W	D3	SWAP.W	D4	CALL	ORDONNE	SWAP.W	D3	SWAP.W	D4	JUMP	90$22$:	SUB.W	D1,D3	LOAD.W	D4,D6	ADD.W	D4,D1	SWAP.W	D3	SWAP.W	D4	CALL	ORDONNE	SWAP.W	D3	SWAP.W	D4	JUMP	90$50$:				; ARCELL G/D	LOAD.W	D1,D0	SR.W	D1,#8	LOAD.W	D4,D6	LOAD.W	D2,D3	SR.W	D2	COMP.B	D1,#B'11000011	JUMP,EQ	90$	COMP.B	D1,#B'00111100	JUMP,EQ	90$	COMP.B	D1,#B'00001100	JUMP,EQ	78$	COMP.B	D1,#B'00000011	JUMP,EQ	78$	COMP.B	D1,#B'00001111	JUMP,EQ	78$	COMP.B	D1,#B'11000000	JUMP,EQ	77$	COMP.B	D1,#B'00110000	JUMP,EQ	77$	COMP.B	D1,#B'11110000	JUMP,EQ	77$	JUMP	90$60$:				; CERCLE/ELLIPSE	LOAD.W	D4,D6		; centre = D6	JUMP	90$70$:				; ARCS;;;	SWAP.W	D3	LOAD.W	D1,D3		; D1 <-- arcs;;;	SWAP.W	D3	LOAD.W	D4,D6	COMP.B	D1,#B'11000011	JUMP,EQ	90$	COMP.B	D1,#B'00111100	JUMP,EQ	90$	LOAD.L	D2,D3	SWAP.W	D2	SR.W	D2	LOAD.W	D4,D6	COMP.B	D1,#B'00001100	JUMP,EQ	78$	COMP.B	D1,#B'00000011	JUMP,EQ	78$	COMP.B	D1,#B'11000000	JUMP,EQ	77$	COMP.B	D1,#B'00110000	JUMP,EQ	77$	COMP.B	D1,#B'00111100	JUMP,EQ	78$	COMP.B	D1,#B'11000011	JUMP,EQ	77$	LOAD.L	D2,D3	SWAP.W	D2	MUL.WU	D2,#924	DIV.WU	D2,#1000	COMP.B	D1,#B'00000010	JUMP,EQ	78$	COMP.B	D1,#B'00000100	JUMP,EQ	78$	COMP.B	D1,#B'00100000	JUMP,EQ	77$	COMP.B	D1,#B'01000000	JUMP,EQ	77$	LOAD.L	D2,D3	SWAP.W	D2	MUL.WU	D2,#383	DIV.WU	D2,#1000	COMP.B	D1,#B'00000001	JUMP,EQ	78$	COMP.B	D1,#B'00001000	JUMP,EQ	78$	COMP.B	D1,#B'00010000	JUMP,EQ	77$	COMP.W	D1,#B'10000000	JUMP,EQ	77$	JUMP	90$77$:	ADD.W	D4,D2	JUMP	90$78$:	SUB.W	D4,D2	JUMP	90$80$:				; texte	LOAD.W	D2,D3	SWAP.W	D2	SR.W	D2,#8	AND.W	D2,#H'FF	SR.W	D2	LOAD.W	D4,D6	SUB.W	D4,D2;	JUMP	90$90$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	RET	.END