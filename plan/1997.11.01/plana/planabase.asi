	.SBTTL	PLANABASE		12 juillet 87;************** _PLANA_REDESS:;**************;--------\; REFAIT  >;========/; Refait tout le dessin.; in	-; out	-; mod	D7.WREFAIT:	PUSHM.L	D0,D1,D2,D3,D4,D5,A4;;;	CALL	RELLAST	CALL	OPWDOG		; utilise la swdo graphique	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP',NE 90$;;;	CALL	SWMO		; met la souris "en attente"10$:	CALL	PREND		; registres <-- objet	CALL	DESSINE		; refait l'objet	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$;;;	CALL	CWMO		; remet la souris normale90$:	CALL	CLWDOG		; libre la swdo graphique;;;	CALL	AFMENU		; r-affiche les soft-keys;;;	CALL	INILLAST	POPM.L	D0,D1,D2,D3,D4,D5,A4	RET;************** _PLANA_AJOUTE:;**************;--------\; AJOUTE  >;========/; Ajoute un objet dans la "base de donnes".; in	D0.W	objet;	D3.L	premier paramtre;	D4.L	deuxime paramtre;	D2.B	mode;	D1.B	mode de trait; out	D7.W	erreur; mod	D7.WAJOUTE:	PUSH.L	A4	CLR.W	D7		; D7 <-- ok;;;;;	TEST.B	(A5)+OFLAGS:#BTEMP ; trait de construction ?;;;;;	JUMP',BS 90$		; oui => 90$				; non =>	CALL	OPEBASE		; A4 <-- ^nouvel lment	JUMP',NE 90$	CALL	MET		; lment <-- paramtres90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;************* _PLANA_TDEL:;*************;--------\; IAJOUTE >;========/; Supprime le dernier objet ajout.; in	-; out	D0..4	objet enlev;	D7.W	erreur; mod	D0..4, D7.WIAJOUTE:	PUSH.L	A4	CALL	IOPEBASE	; A4 <-- ^lment enlev	JUMP',NE 90$	CALL	PREND		; registres <-- objet	CALL	INVMODE		; D2 <-- mode inverse	CALL	DESSINE		; efface l'objet	CALL	INVMODE		; D2 <-- mode normal	CLR.W	D7		; D7 <-- ok90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;************* _PLANA_TUNDO:;*************;--------\; IENLEVE >;========/; Restitue le dernier objet dtruit.; in	-; out	D0..4	objet enlev;	D7.W	erreur; mod	D0..4, D7.WIENLEVE:	PUSH.L	A4	CALL	ICLOBASE	; A4 <-- ^lment repris	JUMP',NE 90$	CALL	PREND		; registres <-- objet	CALL	DESSINE		; dessine l'objet	CLR.W	D7		; D7 <-- ok90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;*************** _PLANA_PREMIER:;***************;--------\; FIRBASE >;========/; Cherche le premier lment.; in	-; out	A4.L	^premier lment;	D7.W	erreur; mod	D7.W, A4.LFIRBASE:	TCLR.B	(A5)+OFLDET:#BDETGR ; on est pas dans un groupe	LOAD.L	A4,(A5)+OPEBUL	; A4 <-- ^begin use list;	JUMP	NXTBASE;************** _PLANA_SUIVANT:;**************;--------\; NXTBASE >;========/; Cherche l'lment suivant.; in	A4.L	^lment; out	A4.L	^lment suivant;	D7.W	erreur; mod	D7.W, A4.LNXTBASE:	PUSHM.L	D0,A0	LOAD.W	D7,#ERPNF	; D7 <-- erreur	LOAD.W	D0,(A4)+OMNEXT	MUL.WU	D0,#LGMEM	ADD.L	D0,(A5)+OPBMEM	LOAD.L	A0,D0		; A0 <-- ^lment suivant	COMP.W	(A0)+OMNEXT,#-1	; suivant = lment spcial ?	JUMP,EQ	90$		; oui => 90$ (erreur)				; non	LOAD.L	A4,A0		; A4 <-- ^lment suivant	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,A0	TEST.W	D7		; retour EQ/NE	RET;************* _PLANA_LIBRE:;*************;--------\; OPEBASE >;========/; Cherche un lment libre dans la base de donne.;	begin free list	 -->  end use list; in	-; out	A4.L	^place pour lment;	D7.W	erreur; mod	D7.W, A4.LOPEBASE:	PUSHM.L	D0,A0,A1	TSET.B	(A5)+OFLAGS:#BMODIF ; plan en mmoire modifi	LOAD.W	D7,#ERPFU	; D7 <-- erreur "tout plein"	LOAD.L	A0,(A5)+OPEBFL	; A0 <-- ^begin free list	LOAD.W	D0,(A0)+OMNEXT	MUL.WU	D0,#LGMEM	ADD.L	D0,(A5)+OPBMEM	LOAD.L	A0,D0		; A0 <-- ^lment suivant	COMP.W	(A0)+OMNEXT,#-1	; reste juste 2 lments ?	JUMP,EQ	90$		; oui => 90$ (erreur)				; non =>	CALL	OTBASE		; enlve de la "free list"	LOAD.L	A1,(A5)+OPEEUL	; A1 <-- ^end use list	LOAD.W	D0,(A1)+OMPREV	MUL.WU	D0,#LGMEM	ADD.L	D0,(A5)+OPBMEM	LOAD.L	A1,D0		; A1 <-- ^lment prcdent	CALL	AJBASE		; ajoute dans la "use list"	LOAD.L	A4,A0		; A4 <-- ^nouvel lment	CLR.W	(A4)+OMOBJET	; occupe l'lment	CLR.B	(A4)+OMFLAGS	INC.W	(A5)+OUBMEM	; +1 lment utilis	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,A0,A1	TEST.W	D7		; retour EQ/NE	RET;---------\; IOPEBASE >;=========/; Dtruit le dernier lment cr dans la base de donnes.;	end use list  -->  begin free list; in	-; out	A4.L	^lment libr;	D7.W	erreur; mod	D7.W, A4.LIOPEBASE:	PUSHM.L	D0,A0,A1	TSET.B	(A5)+OFLAGS:#BMODIF ; plan en mmoire modifi	LOAD.W	D7,#ERPEM	; D7 <-- erreur "tout vide"	LOAD.L	A0,(A5)+OPEEUL	; A0 <-- ^end use list	LOAD.W	D0,(A0)+OMPREV	MUL.WU	D0,#LGMEM	ADD.L	D0,(A5)+OPBMEM	LOAD.L	A0,D0		; A0 <-- ^lment prcdent	COMP.W	(A0)+OMPREV,#-1	; reste juste 2 lments ?	JUMP,EQ	90$		; oui => 90$ (erreur)				; non =>	CALL	OTBASE		; enlve de la "use list"	LOAD.L	A1,(A5)+OPEBFL	; A1 <-- ^begin free list	TSET.B	(A0)+OMFLAGS:#BMOLD	CALL	AJBASE		; ajoute dans la "free list"	LOAD.L	A4,A0	DEC.W	(A5)+OUBMEM	; -1 lment utilis	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,A0,A1	TEST.W	D7		; retour EQ/NE	RET;**************** _PLANA_SUPPRIME:;****************;--------\; CLOBASE >;========/; Libre un lment dans la base de donnes.;	x  -->  begin free list; in	A4.L	^lment  librer; out	-; mod	-CLOBASE:	PUSHM.L	D0,A0,A1	TSET.B	(A5)+OFLAGS:#BMODIF ; plan en mmoire modifi	LOAD.L	A0,A4	CALL	OTBASE		; enlve de la "use list"	LOAD.L	A1,(A5)+OPEBFL	; A1 <-- ^begin free list	TSET.B	(A0)+OMFLAGS:#BMOLD	CALL	AJBASE		; ajoute dans la "free list"	DEC.W	(A5)+OUBMEM	; -1 lment utilis	POPM.L	D0,A0,A1	RET;***************** _PLANA_PSUPPRIME:;*****************;---------\; PCLOBASE >;=========/; Libre un lment dans la base de donnes, sans possibilit; de le rcuprer avec (UNDO) !;	x  -->  end free list; in	A4.L	^lment  librer; out	-; mod	-PCLOBASE:	PUSHM.L	D0,A0,A1	TSET.B	(A5)+OFLAGS:#BMODIF ; plan en mmoire modifi	LOAD.L	A0,A4	CALL	OTBASE		; enlve de la "use list"	LOAD.L	A1,(A5)+OPEEFL	; A1 <-- ^end free list	LOAD.W	D0,(A1)+OMPREV	MUL.WU	D0,#LGMEM	ADD.L	D0,(A5)+OPBMEM	LOAD.L	A1,D0		; A1 <-- ^lment prcdent	TCLR.B	(A0)+OMFLAGS:#BMOLD	CALL	AJBASE		; ajoute dans la "free list"	DEC.W	(A5)+OUBMEM	; -1 lment utilis	POPM.L	D0,A0,A1	RET;***************** _PLANA_DSUPPRIME:;*****************;---------\; DCLOBASE >;=========/; Libre un lment dans la base de donnes, et ajoute-le dans; la liste des libres APRES le dernier lment dtruit.;	x  -->  free list (last); in	A4.L	^lment  librer;	A2.L	^nil/^dernier lment dtruit; out	A2.L	^lment dtruit; mod	A2.LDCLOBASE:	PUSHM.L	D0,A0,A1	TSET.B	(A5)+OFLAGS:#BMODIF ; plan en mmoire modifi	LOAD.L	A0,A4	CALL	OTBASE		; enlve de la "use list"	LOAD.L	A1,(A5)+OPEBFL	; A1 <-- ^begin free list	LOAD.L	D0,A2		; A2 = ^nil ?	JUMP',EQ 30$		; oui => 30$	LOAD.L	A1,A2		; A1 <-- ^dernier lment dtruit30$:	TSET.B	(A0)+OMFLAGS:#BMOLD	CALL	AJBASE		; ajoute dans la "free list"	DEC.W	(A5)+OUBMEM	; -1 lment utilis	LOAD.L	A2,A4		; A2 <-- ^lment dtruit	POPM.L	D0,A0,A1	RET;---------\; ICLOBASE >;=========/; Reprend le dernier lment libr dans la base de donnes.;	begin free list  -->  end use list; in	-; out	A4.L	^lment repris;	D7.W	erreur; mod	D7.W, A4.LICLOBASE:	PUSHM.L	D0,A0,A1	TSET.B	(A5)+OFLAGS:#BMODIF ; plan en mmoire modifi	LOAD.W	D7,#ERPEM	; D7 <-- erreur "plus rien"	LOAD.L	A0,(A5)+OPEBFL	; A0 <-- ^begin free list	LOAD.W	D0,(A0)+OMNEXT	MUL.WU	D0,#LGMEM	ADD.L	D0,(A5)+OPBMEM	LOAD.L	A0,D0		; A0 <-- ^lment suivant	COMP.W	(A0)+OMNEXT,#-1	; reste juste 2 lments ?	JUMP,EQ	90$		; oui => 90$ (erreur)				; non =>	TEST.B	(A0)+OMFLAGS:#BMOLD ; lment existait ?	JUMP,BC	90$		; non => 90$				; oui =>	CALL	OTBASE		; enlve de la "free list"	LOAD.L	A1,(A5)+OPEEUL	; A1 <-- ^end use list	LOAD.W	D0,(A1)+OMPREV	MUL.WU	D0,#LGMEM	ADD.L	D0,(A5)+OPBMEM	LOAD.L	A1,D0		; A1 <-- ^lment prcdent	CALL	AJBASE		; ajoute dans la "use list"	LOAD.L	A4,A0		; A4 <-- ^lment repris	CLR.B	(A4)+OMFLAGS	INC.W	(A5)+OUBMEM	; +1 lment utilis	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,A0,A1	TEST.W	D7		; retour EQ/NE	RET;--------\; AJBASE  >;--------/; Ajoute un lment n'importe o dans une chane d'lments.; in	A0.L	^lment  ajouter;	A1.L	^lment aprs lequel ajouter; out	-; mod	-AJBASE:	PUSHM.L	D0,A0,A1,A2	COMP.W	(A1)+OMNEXT,#-1	; lment suivant existe ?	JUMP,EQ	90$		; non => 90$				; oui =>	LOAD.W	D0,(A1)+OMNEXT	MUL.WU	D0,#LGMEM	ADD.L	D0,(A5)+OPBMEM	LOAD.L	A2,D0		; A2 <-- ^lment suivant				; A1 <-- ^lment prcdent	LOAD.L	D0,A0	SUB.L	D0,(A5)+OPBMEM	; D0 <-- ^relatif nouveau	DIV.WU	D0,#LGMEM	LOAD.W	(A1)+OMNEXT,D0	LOAD.W	(A2)+OMPREV,D0	LOAD.L	D0,A2	SUB.L	D0,(A5)+OPBMEM	; D0 <-- ^relatif suivant	DIV.WU	D0,#LGMEM	LOAD.W	(A0)+OMNEXT,D0	LOAD.L	D0,A1	SUB.L	D0,(A5)+OPBMEM	; D0 <-- ^relatif prcdent	DIV.WU	D0,#LGMEM	LOAD.W	(A0)+OMPREV,D090$:	POPM.L	D0,A0,A1,A2	RET;--------\; OTBASE  >;--------/; Ote un lment n'importe o dans une chane d'lments.; in	A0.L	^lment  oter; out	-; mod	-OTBASE:	PUSHM.L	D0,A0,A1,A2	COMP.W	(A0)+OMPREV,#-1	; lment prcdent existe ?	JUMP,EQ	90$		; non => 90$	LOAD.W	D0,(A0)+OMPREV	MUL.WU	D0,#LGMEM	ADD.L	D0,(A5)+OPBMEM	LOAD.L	A1,D0		; A1 <-- ^lment prcdent	COMP.W	(A0)+OMNEXT,#-1	; lment suivant existe ?	JUMP,EQ	90$		; non => 90$	LOAD.W	D0,(A0)+OMNEXT	MUL.WU	D0,#LGMEM	ADD.L	D0,(A5)+OPBMEM	LOAD.L	A2,D0		; A2 <-- ^lment suivant	LOAD.L	D0,A2	SUB.L	D0,(A5)+OPBMEM	; D0 <-- ^relatif suivant	DIV.WU	D0,#LGMEM	LOAD.W	(A1)+OMNEXT,D0	LOAD.L	D0,A1	SUB.L	D0,(A5)+OPBMEM	; D0 <-- ^relatif prcdent	DIV.WU	D0,#LGMEM	LOAD.W	(A2)+OMPREV,D090$:	POPM.L	D0,A0,A1,A2	RET;************ _PLANA_VIDE:;************;--------\; CLRBASE >;========/; Vide compltement la base de donne.; in	-; out	-; mod	-CLRBASE:	PUSHM.L	D0,D1,D4,A4	TCLR.B	(A5)+OFLAGS:#BMODIF ; plan en mmoire  jour	LOAD.L	A4,(A5)+OPBMEM	; A4 <-- ^buffer mm.	LOAD.W	D4,(A5)+ONBMEM	; D4 <-- nb lments	LOAD.W	D0,#-1		; D0 <-- ^relatif prcdent	LOAD.W	D1,#+1	; D1 <-- ^relatif suivant	LOAD.L	(A5)+OPEBFL,A4	; init ^begin free list	LOAD.W	(A4)+OMPREV,#-1	LOAD.W	(A4)+OMNEXT,D1	INC.W	D0		; D0 <-- ^relatif prcdent	INC.W	D1		; D1 <-- ^relatif suivant	LOAD.L	A4,#(A4)+LGMEM	; A4 <-- ^lment suivant	SUB.W	D4,#4		; 4 lments spciaux20$:	CLR.B	(A4)+OMFLAGS	LOAD.W	(A4)+OMPREV,D0	LOAD.W	(A4)+OMNEXT,D1	INC.W	D0		; D0 <-- ^relatif prcdent	INC.W	D1		; D1 <-- ^relatif suivant	LOAD.L	A4,#(A4)+LGMEM	; A4 <-- ^lment suivant	DEC.W	D4	JUMP,NE	20$	LOAD.L	(A5)+OPEEFL,A4	; init ^end free list	LOAD.W	(A4)+OMPREV,D0	LOAD.W	(A4)+OMNEXT,#-1	INC.W	D0		; D0 <-- ^relatif prcdent	INC.W	D1		; D1 <-- ^relatif suivant	LOAD.L	A4,#(A4)+LGMEM	; A4 <-- ^lment suivant	LOAD.L	(A5)+OPEBUL,A4	; init ^begin use list	LOAD.W	(A4)+OMPREV,#-1	LOAD.W	(A4)+OMNEXT,D1	INC.W	D0		; D0 <-- ^relatif prcdent	INC.W	D1		; D1 <-- ^relatif suivant	LOAD.L	A4,#(A4)+LGMEM	; A4 <-- ^lment suivant	LOAD.L	(A5)+OPEEUL,A4	; init ^end use list	LOAD.W	(A4)+OMPREV,D0	LOAD.W	(A4)+OMNEXT,#-1	LOAD.W	(A5)+OUBMEM,#4	; 4 lments utiliss	POPM.L	D0,D1,D4,A4	RET;************* _PLANA_ECRIT:;*************;--------\; MET     >;========/; Prend les paramtres d'un objet dans les registres.; in	A4.L	^lment;	D0.W	type de l'objet;	D3.L	premier paramtre;	D4.L	deuxime paramtre;	D2.W	mode;	D1.W	mode de trait; out	-; mod	-MET:	LOAD.W	(A4)+OMOBJET,D0	LOAD.L	(A4)+OMPAR1,D3	LOAD.L	(A4)+OMPAR2,D4	LOAD.B	(A4)+OMMODE,D2	LOAD.B	(A4)+OMTRAI,D1	CLR.L	(A4)+OMRES	; clear la rserve	RET;*********** _PLANA_LIT:;***********;--------\; PREND   >;========/; Prend les paramtres d'un objet dans les registres.; in	A4.L	^lment; out	D0.W	type de l'objet;	D3.L	premier paramtre;	D4.L	deuxime paramtre;	D2.W	mode;	D1.W	mode de trait; mod	D0.W, D1.W, D2.W, D3.L, D4,LPREND:	LOAD.W	D0,(A4)+OMOBJET	LOAD.L	D3,(A4)+OMPAR1	LOAD.L	D4,(A4)+OMPAR2	CLR.W	D2	LOAD.B	D2,(A4)+OMMODE	CLR.W	D1	LOAD.B	D1,(A4)+OMTRAI	RET;*************** _PLANA_COMPTE:;***************;--------\\; COMPTE  >;========/; Compte tous les objets dans une zone de recherche.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche; out	D0.L	nombre d'objets trouvs; mod	D0.L, D7.WCOMPTE:	PUSHM.L	D1..D4,A4	CALL	ORDONNE	CLR.L	D0		; D0 <-- nb d'objets trouvs	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP',NE 90$10$:	CALL	DETECTE		; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	INC.W	D0		; D0 <-- un trouv de plus	CLR.W	D2		; D2 <-- nb de fin de groupe attendues	LOAD.W	D1,(A4)+OMOBJET	COMP.B	D1,#OBJDUGROUPE	; dbut d'un groupe ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D1,#OBJDSGROUPE	JUMP',EQ 50$20$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$	JUMP'	90$; Saute tous les objets faisant partie d'un mme groupe, pour; ne compter qu'un seul objet !50$:	INC.W	D2		; D2 <-- une fin de groupe de plus attendues60$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP',NE 90$	LOAD.W	D1,(A4)+OMOBJET	COMP.B	D1,#OBJDUGROUPE	; dbut d'un groupe ?	JUMP,EQ 50$		; oui => 50$	COMP.B	D1,#OBJDSGROUPE	JUMP,EQ 50$	COMP.B	D1,#OBJFUGROUPE	; fin d'un groupe ?	JUMP',EQ 70$		; oui => 70$	COMP.B	D1,#OBJFSGROUPE	JUMP,NE 60$70$:	DEC.W	D2		; fin de groupe imbrique ?	JUMP,NE 60$		; oui => 60$				; non =>	TCLR.B	(A5)+OFLDET:#BDETGR ; on est plus dans un groupe	JUMP	20$90$:	POPM.L	D1..D4,A4	RET;--------\; INVMODE >		EXISTE AUSSI DANS PLAN.CODE;========/; Inverse le mode de dessin.; in	D2.B	mode de dessin; out	D2.B	mode inverse; mod	D2.BINVMODE:	PUSH.W	D1	LOAD.W	D1,D2		; D1 <-- mode/couleur	AND.B	D1,#H'0F	; D1 <-- mode actuel	AND.B	D2,#H'F0	; D2 <-- couleur actuelle	OR.B	D2,#MODCLR	COMP.B	D1,#MODSET	; SET --> CLR	JUMP',EQ 90$	AND.B	D2,#H'F0	; D2 <-- couleur actuelle	OR.B	D2,#MODSET	COMP.B	D1,#MODCLR	; CLR --> SET	JUMP',EQ 90$	AND.B	D2,#H'F0	; D2 <-- couleur actuelle	OR.B	D2,#MODINV	; non => INV90$:	POP.W	D1	RET;**************** _PLANA_CLRNEW:;****************;--------\; CLRNEW  >;========/; Supprime les bits BMNEW  tous les objets.; in	-; out	-; mod	D7.WCLRNEW:	PUSHM.L	D4,A4	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP,NE	90$10$:	TCLR.B	(A4)+OMFLAGS:#BMNEW	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$90$:	POPM.L	D4,A4	RET	.EVEN	.END