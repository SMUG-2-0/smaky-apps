	.SBTTL	PLANASTART		; 8 septembre 1987 Sp.;***************************************; appel rserv exclusivement  START !!!!;************** _PLANA_AFPLAN:;**************;; affiche le PLAN en mmoire point par A4 selon le mode demand; dans la (sous-)fentre;;  utiliser par START p.ex.;; in	A4	^zone mmoire contenant le fichier.PLAN;	D0.L	nombre de bytes de la zone mmoire (fichier.PLAN);	D3.L	coord. d'un sommet (y;x) zone d'affichage dans la fentre;	D4.L	coord. sommet oppos (y;x) zone d'affichage dans la fentre;	D2.L	mode:;			BPLTOUT	=	0	; chelle automatique *);		   ; chelle 1:1;			BPLBAS	=	1	; bas;			BPLCENV	=	2	; centr haut/bas *);			BPLHAUT	=	3	; haut;;			BPLGCHE	=	4	; gauche;			BPLCENH	=	5	; centr gauche/droite *);			BPLDROI	=	6	; droite;		   ; avec en plus;			BCARCRT	=	7	; BS = car. df. (sans DGENC) *);						; BC = car. PLAN (avec DGENC);;		*)  = mode par dfaut;		si BPLTOUT tous les autres flags sont ignors sauf BCARCRT;;	A3.L	position pour afficher "Dimension: xxxxx.x / xxxxx.x  Loupe= xx:xx";		si = 0 pas d'affichage;; out:	D3.L	= 0 si pas de touche presse, sinon la touche;	D4.L	dimensions du plan (dy;dx);	D5.W	chelle +/-;	D6.L	(OF64Y/OF64Y);	D7.W	erreur;; mod:	D7.L;	PUSHM.L	D0,D1,D2,A0..A5	pushm.L	D3,D4,D5	LIB	?GETWDO	jump,ne	pfat	LOAD.L	A1,D5			; A1 <-- canal (sous-)fentre	popm.L	D3,D4,D5	LOAD.L	A0,A4			; A0 ^zone mm. avec fichier.PLAN	LOAD.L	D5,D3			; coord. sommet zone d'affichage	LOAD.L	D6,D4			; coord. sommet zone d'affichage	LOAD.W	D1,#MTYPCP		; mmoire pour variables PLANA	LOAD.L	D4,#LPLANAV	GESMEM	?GETMEM	JUMP,NE	PFATER	LOAD.L	A5,A4			; A5 ^variables PLANA00$:	CLR.B	(A4+)			; clear variables	DEC.W	D4	JUMP,NE	00$	CALL	DEFPTF			; met trames, pinceaux et flches					; par dfaut	LOAD.L	D3,D5	LOAD.L	D4,D6	LOAD.L	(A5)+RESERVE+2,D2	; sauve les flags	CALL	ORDONNE	AND.B	D3,#B'11111000		; modulo 8	LOAD.W	(A5)+OMINX,D3	SWAP.W	D3	AND.B	D3,#B'11111110		; modulo 2	LOAD.W	(A5)+OMINY,D3	AND.B	D4,#B'11111000		; modulo 8	LOAD.W	(A5)+OMAXX,D4	SWAP.W	D4	AND.B	D4,#B'11111110		; modulo 2	LOAD.W	(A5)+OMAXY,D4	SUB.W	D4,D3			; hauteur	LOAD.W	(A5)+OLWDOY,D4	SWAP.W	D4	SWAP.W	D3	SUB.W	D4,D3			; largeur	LOAD.W	(A5)+OLWDOX,D4	LOAD.L	(A5)+ODWDOY,(A5)+OLWDOY	CLR.W	(A5)+OOWDOX	; origine par dfaut	CLR.W	(A5)+OOWDOY	TEST.B	(A5)+RESERVE+2+3:#BCARCRT	; DGENC ?	JUMP,BS	5$				; non	PUSH.L	A3	LOAD.L	A3,#R16"NAMDGENC	; lib DGENC	LOAD.W	D3,#DGENC_FIRST	LIB_	OPEN	POP.L	A3	JUMP,NE	PFATER2	LOAD.W	(A5)+RESERVE,D15$:;; Lit le status de la fentre pour prendre les autres; informations ncessaires.;	LIB	?GCHDIS		; D6 <-- canal	LOAD.W	(A5)+OCHDIS,D6	; mm. canal de l'cran	FOS	?GETTYPE	LOAD.W	(A5)+ONODIS,D2	; mm. no driver de l'cran	LOAD.L	A4,#(A5)+OPDDIS	; A4 <-- ^buffer pour ^	LOAD.L	D4,#4		; D4 <-- longueur .L	LOAD.W	D3,#TYPWDO	; D3 <-- type	FOS	?RSTATUS	; lit ^status fentre	JUMP,NE	PFATER2	LOAD.L	A4,(A4)		; A4 <-- ^descripteur de la fentre	LOAD.L	(A5)+ODEFGC,(A4)+ODFGCF	LOAD.W	(A5)+OCARX,(A4)+ODFCX	; mm. largeur max. car.	LOAD.W	D4,(A4)+ODFC1Y	LOAD.W	(A5)+OCAR1Y,D4		; mm. hauteur dessus ligne de base	ADD.W	D4,(A4)+ODFC2Y	LOAD.W	(A5)+OCARY,D4		; mm. hauteur effective car.	LOAD.W	(A5)+OCAR2Y,(A4)+ODFC2Y	LIB	?GETDIM		; dimension de la fentre	LOAD.L	(A5)+OWDOY,D4;; Met le driver d'cran dans le bon mode.;	LIB	?AFTIM	.B	MODGRA,GRACLIP	; cliping pour graphique	.B	NOCURS		; plus de curseur	.B	0	.EVEN	LOAD.L	D6,D0			; D6 <-- nbr. d'objets	ADD.L	D6,#LGELEMENT	LOAD.L	A4,A0			; A4 ^mmoire avec fichier.PLAN	SUB.L	A4,#LGELEMENT	LOAD.W	D5,#100;; lire l'objet de dfinitions (dimensions);	CALL	RDOBJET			; registres <-- valeurs	JUMP,NE	PERREUR	LOAD.L	(A5)+OMWDOY,D4	; dimensions du plan	CLR.L	D3	CALL	XMSCALE			; calcul chelle max.;;;;;; tester si chelle 1:1 (D4=0);;;;;	TEST.B	(A5)+RESERVE+2+3:#BPLTOUT	; tout ?	JUMP,BS	50$				; oui	LOAD.L	(A5)+OSWDOY,(A5)+OMWDOY	; met wdo dim plan pour centrer	LOAD.W	D4,#0				; non centre ...	CALL	XCENSCALE	TEST.B	(A5)+RESERVE+2+3:#BPLGCHE	; gauche ?	JUMP,BC	10$				; non	LOAD.W	(A5)+OOWDOX,#0			; oui, gauche	JUMP	30$10$:	TEST.B	(A5)+RESERVE+2+3:#BPLDROI	; droite ?	JUMP,BC	30$				; non	LOAD.W	(A5)+OOWDOX,(A5)+OMWDOX		; oui, droite30$:	TEST.B	(A5)+RESERVE+2+3:#BPLHAUT	; haut ?	JUMP,BC	40$				; non	LOAD.W	(A5)+OOWDOY,(A5)+OMWDOY		; oui, haut	JUMP	45$40$:	TEST.B	(A5)+RESERVE+2+3:#BPLBAS	; bas ?	JUMP,BC	45$				; non	LOAD.W	(A5)+OOWDOY,#0			; oui, bas45$:	CALL	XAJOWDO				; ajuste origine (voir un bout)50$:	CALL	INUZONE		; griser la zone cran inutilise; lire les dfinitions des trames, pinceaux, genc et flches (buffers PLANA)	CALL	RDTPGF	JUMP,NE	PERREUR;; ignorer les macros et lire l'objet EDEF s'il existe;	LOAD.W	(A5)+OCOULEUR,#H'FF	; par dfaut tout visible	JUMP	66$60$:	TEST.B	D0			; dj un objet  dessiner ?;;	JUMP,NC	DESOBJ			; oui	JUMP,NC	69$65$:	CALL	RDOBJET	JUMP,NE	PERREUR66$:	COMP.B	D0,#OBJEDEF	JUMP,NE	60$; lire couleurs visibles dans EDEF	LOAD.W	(A5)+OCOULEUR,D3	LOAD.L	(A5)+RESERVE+2+4,(A4)+OMRES69$:	CALL	AFDIMECH; tester flag affiche que dim, si BS PFIN !!!! pour DR	JUMP	DESOBJ; boucle de lecture et de dessin des objets graphiques;BOUCLE:	CALL	RDOBJET			; registres <-- objet	JUMP,NE	PFIN			; fin du fichierDESOBJ:	TEST.W	D0	JUMP,NS	BOUCLE			; ignorer objets de dfinition10$:	CALL	DESSINE			; dessine selon registres;;	JUMP,NE	PERREUR			; tantpis ...	JUMP	BOUCLEPFIN:					; fin ok.	COMP.W	D7,#EROUTF	JUMP,NE	10$	CLR.L	D3	JUMP	15$10$:	COMP.W	D7,#-1			; touche presse ?	JUMP,NE	20$			; non15$:	CLR.L	D7			; oui20$:					; D3.L	v. touche presse	LOAD.L	D4,(A5)+OMWDOY		; D4.L <-- dimensions du PLAN	LOAD.W	D5,(A5)+OSCALE		; D5.W <-- chelle	LOAD.W	D6,(A5)+RESERVE+2+4	; D6.W <-- OF64X;	JUMP	PFATER2            PERREUR:;	.W	LIB,?AFERROR		; afficher PERREUR;	LOAD.B	D3,#BIPERR;	.W	LIB,?BEEPPFATER2:	PUSH.W	D7	TEST.B	(A5)+RESERVE+2+3:#BCARCRT	; DGENC ?	JUMP,BS	5$				; non	LOAD.W	D1,(A5)+RESERVE			; oui	LIB_	CLOSE			; libre DGENC5$:	LOAD.L	A4,A5			; rend la mmoire PLANA	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	POP.W	D7PFATER:	load.L	D5,A1			; D5 <-- canal de la fentre initiale	LIB	?USEWDOpfat:	POPM.L	D0,D1,D2,A0..A5	TEST.W	D7	RET;---------- pour AFPLAN uniquement AFDIMECH:;----------; affiche dimension et chelle selon A3	PUSHM.L	D0,D2,D3,D4	LOAD.L	D3,A3	JUMP,EQ	90$		; si A3 = 0 ne fait rien	LIB	?SETCURS	LIB	?AFTIM	.ASCIZE	/Dimensions: X= /	LOAD.W	D4,(A5)+OMWDOX	LOAD.W	D0,(A5)+RESERVE+2+4+2	CALL	AFFP0	LIB	?AFTIM	.ASCIZE	/  Y= /	LOAD.W	D4,(A5)+OMWDOY	LOAD.W	D0,(A5)+RESERVE+2+4	CALL	AFFP0	LIB	?AFTIM	.ASCIZ	"    Loupe="	.EVEN	CLR.L	D4	LOAD.W	D4,(A5)+OSCALE	JUMP',NS 40$	JUMP',NE 42$	INC.W	D4		; D4 <-- 1	JUMP'	42$40$:	NEG.W	D4		; D4 <-- 2..n	LIB	?AFTIM	.ASCIZ	"1:"		; si ngatif => 1:n	.EVEN42$:;	LOAD.B	D3,#3		; max 1/999 ou 999	LOAD.B	D2,#2^BAFDCM	LOAD.B	D3,#2	LIB	?AFDEC		; affiche l'chelle	TEST.W	(A5)+OSCALE	JUMP',NS 44$	LIB	?AFTIM	.ASCIZ	":1"		; si positif => n:1	.EVEN44$:90$:	POPM.L	D0,D2,D3,D4	RET;------- pour AFPLAN uniquement AFFP0:;-------	PUSHM.L	D3,D4;;;	TEST.B	(A6)+OFLMOD:#BENMM	; mm ?;;;	JUMP,BC	80$			; non --> 80$TEST.W	(A5)+RESERVE+2+4+2JUMP,EQ	80$	MUL.WU	D4,#64			; oui, D4*64	DIV.WU	D4,D0			; D4/OF64X ou Y	LOAD.L	D3,D4			; D3 <-- D4	MUL.WU	D4,#10			; D4*10	SWAP.W	D3	MUL.WU	D3,#10			; reste *10	DIV.WU	D3,D0			; reste/OF64X ouY	SWAP.W	D3			; v. arrondi	SL.W	D3	COMP.W	D3,D0	JUMP',LO 70$	ADD.L	D3,#H'1000070$:	SWAP.W	D3	AND.L	D3,#H'FFFF	ADD.L	D4,D3			; D4 + D380$:	CALL	AFFPAR1090$:	POPM.L	D3,D4;;;	POP.L	D0	RET;---------- pour AFPLAN uniquement AFFPAR10:;----------; Affiche un paramtre numrique en pg ou en mm*10 (1 dcimale);; in	D4.W	valeur numrique; out	D7.W	erreur; mod	D7.W	PUSHM.L	D2,D3,D4;;;	TEST.B	(A6)+OFLMOD:#BENMM	; mm ?;;;	JUMP,BC	80$			; non --> 80$TEST.W	(A5)+RESERVE+2+4JUMP,EQ	80$	LIB	?BUCAR	LIB	?BINBCD	LOAD.B	D2,#8		; D2 <-- nb max de digits20$:	LOAD.L	D3,D4	SWAP.W	D3	SR.W	D3,#8	SR.W	D3,#4	TEST.B	D3		; digit nul ?	JUMP,NE	30$		; non => 30$	COMP.B	D2,#6+1		; 6 digits au max.	JUMP,HS	21$	LOAD.B	D3,#SPACE	; oui, met des espaces	LIB	?AFCAR21$:	SL.L	D4,#4		; D4 <-- digit suivant	DEC.B	D2	JUMP,NE	20$	JUMP	70$		; 0.030$:	COMP.B	D2,#1		;;; pour 10 mettre 1, 2=100	JUMP,NE	40$	LOAD.B	D3,#BS	LIB	?AFCAR	LOAD.B	D3,#'0		; ne met pas .5 mais 0.5 !	LIB	?AFCAR40$:	COMP.B	D2,#1		;;; cf. ci-dessus	JUMP,NE	50$	LOAD.B	D3,#'.		; met la "virgule"	LIB	?AFCAR50$:	LOAD.L	D3,D4	SWAP.W	D3	SR.W	D3,#8	SR.W	D3,#4	ADD.B	D3,#'0	LIB	?AFCAR	SL.L	D4,#4		; D4 <-- digit suivant	DEC.B	D2	JUMP,NE	40$60$:	LIB	?AFTIM	.ASCIZE	/mm /	JUMP	90$70$:	LIB	?AFTIM	.ASCIZE	/<BS><BS>0.0/	JUMP	60$80$:		; affiche en pg 5 digits	AND.L	D4,#H'FFFF	LOAD.B	D3,#5	LOAD.B	D2,#2^BAFDALL	LIB	?AFDEC		; affiche Oy	LIB	?AFTIM	.ASCIZE	/ pg/90$:	LIB	?NOBUCAR	POPM.L	D2,D3,D4	RET;--------- pour AFPLAN uniquement RDOBJET:;---------; lit un objet dans le buffer BUELEM; in	A4.L	^buffer de lecture pour un lment;	D6.L	nbr de bytes;	D5.W	compteur; out	registres <-- objet si ok;	sinon D7=-1; mod	D0,D1,D2,D3,D4,D5,D7.W, F	LOAD.W	D7,#EROUTF	ADD.L	A4,#LGELEMENT	SUB.L	D6,#LGELEMENT	JUMP,NS	90$	JUMP,ZS	90$	DEC.W	D5		; dec compteur lecture clavier	JUMP,NE	60$	LOAD.W	D5,#50		; rinitialise compteur	LIB	?IFCAR	JUMP,NE	60$	LOAD.W	D7,#-1	JUMP	90$60$:	CLR.W	D7			; ok;;;	LOAD.W	(A5)+OPLANA,#BPREND	; met dans les registres;;;	.W	PLANA_BASE	CALL	PREND90$:	TEST.W	D7	RET;-------- pour AFPLAN uniquement RDTPGF:;--------; lit les dfinitions des trames, pinceaux, genc et flches;	PUSHM.L	D5,A0,A1,A2,A3,A5	CLR.W	D7	CALL	RDOBJET	JUMP,NE	90$; trames;TRAM$:	COMP.B	D0,#OBJTDEF	JUMP,NE	PINC$	LOAD.L	A0,#(A5)+OBUTRA	LOAD.W	D5,#TRAMAXTRAM1$:	LOAD.L	(A0+),D3	LOAD.L	(A0+),D4	DEC.W	D5;	JUMP,EQ	PINC$	CALL	RDOBJET	JUMP,NE	90$	COMP.B	D0,#OBJTDEF	JUMP,EQ	TRAM1$; pinceaux;PINC$:	COMP.B	D0,#OBJPDEF	JUMP,NE	GENC$	LOAD.L	A0,#(A5)+OBUPEN	LOAD.W	D5,#PENMAXPINC1$:	LOAD.L	(A0+),D3	LOAD.L	(A0+),D4	LOAD.W	(A0+),(A4)+OMRES	DEC.W	D5;	JUMP,EQ	GENC$	CALL	RDOBJET	JUMP,NE	90$	COMP.B	D0,#OBJPDEF	JUMP,EQ	PINC1$; genc;GENC$:	COMP.B	D0,#OBJGDEF	JUMP,NE	FLE$	TEST.B	(A5)+RESERVE+2+3:#BCARCRT	; DGENC ?	JUMP,BS	5$				; non	LOAD.L	A0,A4				; oui	LOAD.L	A1,A5	LOAD.L	A5,A4			; A5 <-- ^objet	LOAD.L	A4,#(A1)+OBUGC	DGENC_	FREE			; A4 <-- libre	JUMP,NE	90$	LOAD.L	D3,(A0)+OMPAR1		; D3 <-- "fst-"	SR.L	D3,#8			; D3 <-- "-fst"	LOAD.L	(A4)+OGCCOD,D3		; OBUGC <-- fst	LOAD.L	D4,#GCTXF*H'10000+GCTXS*H'100+GCTXT	LOAD.L	A2,(A1)+OPDDIS	LOAD.L	A3,#(A1)+OBUGC	DGENC_	NEW;;	JUMP,NE	90$	LOAD.L	A5,A1	LOAD.L	A4,A05$:	CALL	RDOBJET	JUMP,NE	90$	JUMP	GENC$; flches;FLE$:	COMP.B	D0,#OBJFDEF	JUMP,NE	90$	LOAD.L	A0,#(A5)+OBUFLE	LOAD.W	D5,#FLEMAXFLE1$:	LOAD.L	(A0+),D3	DEC.W	D5;	JUMP,EQ	90$	CALL	RDOBJET	JUMP,NE	90$	COMP.B	D0,#OBJFDEF	JUMP,EQ	FLE1$90$:	POPM.L	D5,A0,A1,A2,A3,A5	TEST.W	D7	RETNAMDGENC:	.ASCIZE	/DGENC/	.END	; PPLANSTART