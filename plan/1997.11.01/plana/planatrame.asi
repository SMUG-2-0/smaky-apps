	.SBTTL	PLANATRAME		; 12 juillet 87 Sp.;***************** _PLANA_DBTRAME:;*****************;---------- DBOXTRAME:;----------;; Choix d'une trame.;; in	D1.L	31..16: OBJSURF; 15..0 no. trame;; out	D1.W	31..16:OBJFILL ou OBJSURF; 15..0: no. de trame; mod	D1.L, D7.W	PUSHM.L	D0,D2..D4,A0..A4;;;	CALL	_CWMO		; remet souris normale;;;	CALL	_SRMO		; remet la flche			; sauver les trames actuelles			; pour comparaison par la suite	LOAD.W	D0,#TRMMAX	LOAD.L	A3,#(A5)+OBUTRA	LOAD.L	A4,#(A5)+OBUTRAS5$:	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	DEC.W	D0	JUMP',NE 5$	LOAD.L	D2,(A5)+OFTRAME		; D2 <-- fanions	JUMP,NE	6$	TSET.L	D2:#BMATX16$:	TSET.L	D2:#BDBSAV		; ... + sauver dessous	TCLR.B	(A5)+OFLAGS:#BMDBOX	; initialise flag DBOX dmoli;	LOAD.W	D4,(A6)+OTRAME		; D4 <-- no. de trameLOAD.W	D4,D1	LOAD.L	A0,(A5)+OPDDIS		; A0 ^descripteur de fentre	LOAD.L	A2,#0			; pas d'icnes	LOAD.L	A3,#R16"TTTEXTE		; A3 ^textes des ODBCIRCLE	LOAD.L	A4,#(A5)+OBUTRA		; A4 ^trames	JUMP	10$8$:	TCLR.L	D2:#BDBSAV	TSET.B	(A5)+OFLAGS:#BMDBOX	; signal DBOX a dmoli	.W	DESSIN_TEDIT	JUMP,EQ	11$	JUMP	95$10$:	.W	DESSIN_TEDIT			; dition des trames	COMP.W	D7,#ERNEMEM	JUMP,EQ	8$11$:	LOAD.W	D1,#-1	COMP.B	D3,#F0			; ANNULE ?	JUMP,EQ	90$			; oui => 90$	COMP.B	D3,#F1			; D'ACCORD ?	JUMP,EQ	20$			; oui => 20$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	10$			; redite ...20$:				; D'ACCORD	TCLR.L	D2:#BMATX3	TEST.L	D2:#BMATX2	JUMP,BS	21$	TSET.L	D2:#BMATX121$:	LOAD.W	D3,D4			; D3 <-- no. trame	MUL.WU	D3,#8			; ... dplacement	TEST.L	(A4)+(D3)		; la bonne trame, teste si vide	JUMP,NE	85$			; non => 85$	TEST.L	(A4)+(D3)+4		; oui, suite aussi vide ?	JUMP,EQ	90$			; oui => 90$85$:	TCLR.L	D2:#BDBSAV		; enlve mode DBOX	LOAD.L	(A5)+OFTRAME,D2		; sauve fanions;	LOAD.W	(A5)+OTRAME,D4		; sauve no. trameLOAD.W	D1,D4				; trame modifie ?	LOAD.L	A4,#(A5)+OBUTRA		; A4 ^trames	LOAD.L	A3,#(A5)+OBUTRAS	; A3 ^trames sauves	ADD.L	A3,D3	ADD.L	A4,D3	COMP.L	(A3+),(A4+)	; la mme ?	JUMP,NE	87$		; non ...	COMP.L	(A3+),(A4+)	JUMP,EQ	89$		; oui, la mme87$:				; oui trame modifie, dans la fentre?	LOAD.B	D1,D4			; D1 <-- no. trame	LOAD.L	D3,(A5)+OOWDOY	; D3 <-- coin inf/gauche visible	LOAD.L	D4,D3	ADD.W	D4,(A5)+OSWDOX	SWAP.W	D4	ADD.W	D4,(A5)+OSWDOY	; D4 <-- coin sup/droite visible	SWAP.W	D4	CALL	IFTRAME	JUMP,NE	89$		; pas dans la fentre	TSET.B	(A5)+OFLAGS:#BMDBOX	; dans la fentre ...89$:				; trame non-modifi	TEST.L	D2:#BMATX2		; fill ?	JUMP,BC	90$			; non => 90$;	LOAD.W	(A6)+OOBJET,#OBJFILL	; oui ...SWAP.W	D1LOAD.W	D1,#OBJFILLSWAP.W	D190$:LOAD.W	D7,#-1	TEST.B	(A5)+OFLAGS:#BMDBOX	JUMP,BC	95$CLR.W	D7;;;	CALL	_MAJCADRE;;;	CALL	REFAIT95$:PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,0	.EVEN;;;	CALL	_AFMENU		; menu standard;;;	CALL	_CRMO		; met v. rticule;;;	CLR.W	D7POP.W	D7	POPM.L	D0,D2..D4,A0..A4TEST.W	D7	RET;*** prov._PLANA_IITRAME:;***************;--------\\; IITRAME >;========/; Initialise une translation nulle avant la lecture; d'un plan.; in	-; out	-; mod	-IITRAME:	PUSHM.L	D2,A4	LOAD.L	A4,#(A5)+OUSTRA	CLR.W	D2		; D2 <-- numro 1re10$:	LOAD.B	(A4+),D2	; met 0,1,2,3 ...	INC.W	D2		; D2 <-- numro suivant	COMP.W	D2,#TRMMAX	JUMP,LO	10$	POPM.L	D2,A4	RET;*** prov._PLANA_IMTRAME:;**************;--------\\; IMTRAME >;========/; Mmorise une ventuelle translation de numro de trame; lors de la lecture d'un plan.; in	D3/4.L	trame;	D1.B	numro; out	-; mod	-IMTRAME:	PUSHM.L	D1,D2,D3,D4,A4	CALL	SRCTRA		; D2 <-- trame existe dj ?	JUMP',EQ 50$		; oui => 50$				; non =>	PUSHM.L	D3,D4	CLR.L	D3		; D3 <-- coin inf/gauche plan	LOAD.L	D4,(A5)+OMWDOY	; D4 <-- coin sup/droite plan	CALL	IFTRAME		; trame utilise dans plan ?	POPM.L	D3,D4	JUMP',EQ 30$		; oui => 30$				; non =>	LOAD.B	D2,D1		; D2 <-- no de la mme	CLR.W	D7		; D7 <-- ok	JUMP'	50$30$:	PUSHM.L	D3,D4	CLR.L	D3	CLR.L	D4	CALL	SRCTRA		; D2 <-- cherche trame vide	POPM.L	D3,D4	JUMP',EQ 50$		; ok => 50$				; tout plein =>	LOAD.W	D2,#TRMDEF	; D2 <-- trame par dfaut !50$:	LOAD.L	A4,#(A5)+OUSTRA	AND.W	D1,#H'FF	LOAD.B	(A4)+(D1.W),D2	TEST.W	D7		; emplacement trouv ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A4,#(A5)+OBUTRA	; A4 <-- ^trames	MUL.WU	D2,#8	ADD.L	A4,D2	LOAD.L	(A4)+0,D3	; met nouvelle trame	LOAD.L	(A4)+4,D490$:	POPM.L	D1,D2,D3,D4,A4	RET;--------\\; ITTRAME >;========/; Translate un numro de trame lors de la lecture d'un plan.; in	D0.W	objet;	D1.B	numro actuel; out	D1.B	nouveau numro; mod	D1.WITTRAME:	PUSH.L	A4	COMP.B	D0,#OBJSURF	; objet trame ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A4,#(A5)+OUSTRA	AND.W	D1,#H'FF	LOAD.B	D1,(A4)+(D1.W)	; D1 <-- nouveau numro90$:	POP.L	A4	RET;--------\\; SRCTRA  >;--------/; Cherche si une trame existe dj.; in	D3/4.L	trame; out	D2.W	numro;	D7.W	erreur; mod	D2.W, D7.WSRCTRA:	PUSH.L	A3	CLR.W	D7		; D7 <-- trouv	LOAD.L	A3,#(A5)+OBUTRA	; A3 <-- ^trames	CLR.W	D2		; D2 <-- numro 1re10$:	COMP.L	D3,(A3)+0	JUMP',NE 20$	COMP.L	D4,(A3)+4	JUMP',EQ 90$20$:	ADD.L	A3,#8		; A3 <-- ^trame suivante	INC.W	D2		; D2 <-- numro suivant	COMP.W	D2,#TRMMAX	JUMP,LO	10$	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;--------\; IFTRAME >;========/; Cherche si une trame est utilise dans une zone.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D1.B	numro trame cherche; out	D7.W	trouv ou pas; mod	D7.WIFTRAME:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A4	LOAD.B	D6,D1		; D6 <-- no trame	CALL	ORDONNE	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP',NE 90$10$:	CALL	FDETECTE	; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	PUSHM.L	D3,D4	CALL	PREND		; registres <-- objet	POPM.L	D3,D4	COMP.B	D0,#OBJSURF	; objet trame ?	JUMP',NE 20$		; non => 20$	COMP.B	D1,D6		; bonne trame ?	JUMP',EQ 90$		; oui => 90$20$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$90$:	POPM.L	D0,D1,D2,D3,D4,D5,D6,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DEFTRAME >;=========/; Remet toutes les trames par dfaut.; in	-; out	-; mod	-DEFTRAME:	PUSHM.L	D3,A3,A4	LOAD.L	A4,#R16"TTRAMES	LOAD.L	A3,#(A5)+OBUTRA	LOAD.W	D3,#TRMMAX*810$:	LOAD.B	(A3+),(A4+)	DEC.W	D3	JUMP,NE	10$	POPM.L	D3,A3,A4	RETTTTEXTE:	.ASCIZ	/surface/	.ASCIZ	/remplit/	.ASCIZ	//	.EVEN; Trames; ------TTRAMES:				; 0	.B	B'10001000	.B	B'00000000	.B	B'00100010	.B	B'00000000	.B	B'10001000	.B	B'00000000	.B	B'00100010	.B	B'00000000				; 1	.B	B'10001000	.B	B'10001000	.B	B'00100010	.B	B'00100010	.B	B'10001000	.B	B'10001000	.B	B'00100010	.B	B'00100010				; 2	.B	B'10101010	.B	B'10101010	.B	B'01010101	.B	B'01010101	.B	B'10101010	.B	B'10101010	.B	B'01010101	.B	B'01010101				; 3	.B	B'11101110	.B	B'11101110	.B	B'10111011	.B	B'10111011	.B	B'11101110	.B	B'11101110	.B	B'10111011	.B	B'10111011				; 4	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111				; 5	.B	B'00000011	.B	B'00000110	.B	B'00001100	.B	B'00011000	.B	B'00110000	.B	B'01100000	.B	B'11000000	.B	B'10000001				; 6	.B	B'11001100	.B	B'10011001	.B	B'00110011	.B	B'01100110	.B	B'11001100	.B	B'10011001	.B	B'00110011	.B	B'01100110				; 7	.B	B'11000000	.B	B'01100000	.B	B'00110000	.B	B'00011000	.B	B'00001100	.B	B'00000110	.B	B'00000011	.B	B'10000001				; 8	.B	B'00110011	.B	B'10011001	.B	B'11001100	.B	B'01100110	.B	B'00110011	.B	B'10011001	.B	B'11001100	.B	B'01100110				; 9	.B	B'11111111	.B	B'10000000	.B	B'10000000	.B	B'10000000	.B	B'11111111	.B	B'00001000	.B	B'00001000	.B	B'00001000				; 10	.B	B'10000011	.B	B'00000001	.B	B'10000000	.B	B'01000000	.B	B'00100000	.B	B'00010000	.B	B'00111000	.B	B'01000100				; 11	.B	B'11111000	.B	B'01110100	.B	B'00100010	.B	B'01000111	.B	B'10001111	.B	B'00010111	.B	B'00100010	.B	B'01110001				; 12	.B	B'11111101	.B	B'00000000	.B	B'11111101	.B	B'11111101	.B	B'00001101	.B	B'00001101	.B	B'00001101	.B	B'00001101				; 13	.B	B'01110111	.B	B'10001111	.B	B'10001111	.B	B'10001111	.B	B'01110111	.B	B'11111000	.B	B'11111000	.B	B'11111000				; 14	.B	B'00000000	.B	B'00001000	.B	B'00010100	.B	B'00101010	.B	B'01010101	.B	B'00101010	.B	B'00010100	.B	B'00001000				; 15	.B	B'10000000	.B	B'00010000	.B	B'00000010	.B	B'00100000	.B	B'00000001	.B	B'00001000	.B	B'01000000	.B	B'00000100				; 16	.B	B'10110001	.B	B'00110000	.B	B'00000011	.B	B'00011011	.B	B'11011000	.B	B'11000000	.B	B'00001100	.B	B'10001101				; 17	.B	B'10000000	.B	B'10000000	.B	B'01000001	.B	B'00111110	.B	B'00001000	.B	B'00001000	.B	B'00010100	.B	B'11100011				; 18	.B	B'10000000	.B	B'01000000	.B	B'00100000	.B	B'00000000	.B	B'00000010	.B	B'00000100	.B	B'00001000	.B	B'00000000				; 19	.B	B'00000011	.B	B'10000100	.B	B'01001000	.B	B'00110000	.B	B'00001100	.B	B'00000010	.B	B'00000001	.B	B'00000001				; 20	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000				; 21	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000				; 22	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000				; 23	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000				; 24	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000				; 25	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000				; 26	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000				; 27	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.EVEN	.END