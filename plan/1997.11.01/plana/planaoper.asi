	.SBTTL	PLANAOPER		; 12 juillet 87 Sp.GROUPETX = 0;**************** _PLANA_OPER:;****************	COMP.B	D5,#0		; dtruit ?	JUMP,EQ	DETRUIT	COMP.B	D5,#1		; dplace ?	JUMP,EQ	DEPLACE	COMP.B	D5,#2		; duplifie ?	JUMP,EQ	DUPLIFIE;;	COMP.B	D5,#3		; polycopie ?;;	JUMP,EQ	POLYCOPIE	COMP.B	D5,#4		; aligne ?	JUMP,EQ	ALIGNE	COMP.B	D5,#3+2		; zoom ?	JUMP,EQ	ZOOM	COMP.B	D5,#4+2		; tourne ?	JUMP,EQ	TOURNE	COMP.B	D5,#5+2		; miroir ?	JUMP,EQ	MIROIR	COMP.B	D5,#6+2		; groupe ?	JUMP,EQ	GROUPE;	COMP.B	D5,#7+2		; stocke ?;	JUMP,EQ	STOCKE;	COMP.B	D5,#8+2		; filtre ?;	JUMP,EQ	FILTRE;	COMP.B	D5,#9+2		; modifie ?;	JUMP,EQ	MODIFIE;;;	COMP.B	D5,#10+2	; chelle ?;;;	JUMP,EQ	75$		; oui => 75$;;;	COMP.B	D5,#11+2	; sauve ?;;;	JUMP,EQ	77$		; oui => 77$;;;	JUMP	85$	LOAD.W	D7,#-1	TEST.W	D7	RET;-------- GROUPE:;--------; in	D0 =	0 => assemble utilisateur;	D0 =	1 => spare utilisateur;	D0 =	2 => colle systme;	D0 =	3 => coupe systme;	SR.B	D0,#1	JUMP',CS 20$	JUMP	LIE20$:	JUMP	DELIE;--------\; DETRUIT >;========/; Dtruit tous les objets dans une zone de recherche.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche; out	-; mod	-DETRUIT:	PUSHM.L	D0,D1,D2,D3,D4,D5,A3,A4,A2	CALL	ORDONNE	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP,NE 90$	CALL	SWMO		; met la souris "en attente"	LOAD.L	A2,#0		; A2 <-- pas de dernier lment dtruit;;;;PLANA , avant A5 !!!10$:	CALL	DETECTE		; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A3,A4		; A3 <-- ^lment actuel	CALL	NXTBASE		; A4 <-- ^lment suivant	EX.L	A3,A4		; A4 <-- ^act, A3 <-- ^suivant	PUSHM.L	D3,D4,D7	CALL	PREND		; registres <-- objet	CALL	INVMODE		; D2 <-- mode inverse	CALL	DESSINE		; efface l'objet	CALL	INVMODE		; D2 <-- mode normal	CALL	MET		; objet <-- registres	CALL	DCLOBASE	; supprime l'objet (A2 ^dernier)	POPM.L	D3,D4,D7	LOAD.L	A4,A3		; A4 <-- ^lment suivant	TEST.W	D7	JUMP,EQ	10$	JUMP'	90$20$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$90$:	CALL	CWMO		; remet la souris normale	POPM.L	D0,D1,D2,D3,D4,D5,A3,A4,A2	RET;--------\; DEPLACE >;========/; Dplace tous les objets dans une zone de recherche.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D0.L	offset +/-; out	-; mod	D7.WDEPLACE:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	LOAD.L	D6,D0		; D6 <-- offset +/-	JUMP,EQ	90$		; si zro => 90$	CALL	ORDONNE	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP,NE	90$	CALL	SWMO		; met la souris "en attente"10$:	CALL	DETECTE		; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A3,A4		; A3 <-- ^lment actuel	CALL	NXTBASE		; A4 <-- ^lment suivant	EX.L	A3,A4		; A4 <-- ^act, A3 <-- ^suivant	PUSHM.L	D3,D4,D7	CALL	PREND		; registres <-- objet;	CALL	INVMODE		; D2 <-- mode inverse;	CALL	DESSINE		; efface l'objet;	CALL	INVMODE		; D2 <-- mode normal;	CALL	MET		; objet <-- registres	CALL	CLOBASE		; supprime l'objet	CALL	OPEBASE		; A4 <-- ^nouvel lment	CALL	AJUSTE		; ajuste selon l'offset;	CALL	INVMODE		; D2 <-- mode normal	CALL	MET		; objet <-- registres	TSET.B	(A4)+OMFLAGS:#BMNEW;	CALL	DESSINE		; redessine l'objet	POPM.L	D3,D4,D7	LOAD.L	A4,A3		; A4 <-- ^lment suivant	TEST.W	D7	JUMP,EQ	10$	JUMP'	80$20$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$80$:	CALL	CLRNEW		; ote les bits BMNEW90$:	CALL	CWMO		; remet la souris normale	POPM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	RET;---------\; DUPLIFIE >;=========/; Duplifie tous les objets dans une zone de recherche.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D0.L	offset +/-; out	-; mod	D7.WDUPLIFIE:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A4	LOAD.L	D6,D0		; D6 <-- offset +/-	JUMP,EQ	90$		; si zro => 90$	CALL	ORDONNE	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP,NE	90$	CALL	SWMO		; met la souris "en attente"10$:	CALL	DETECTE		; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	PUSHM.L	D3,D4,A4	CALL	PREND		; registres <-- objet	CALL	AJUSTE		; ajuste selon l'offset	CALL	OPEBASE		; A4 <-- ^lment duplifi	JUMP',NE 80$		; si plus de place => 80$	CALL	MET		; lment <-- paramtres	TSET.B	(A4)+OMFLAGS:#BMNEW	TEST.B	(A5)+OFLMOD1:#BDUPDESS	JUMP',BC 19$	CALL	DESSINE		; dessine le nouvel objet19$:	POPM.L	D3,D4,A420$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$	JUMP'	85$80$:	POPM.L	D3,D4,A4	LOAD.B	D3,#BIPERR	LIB	?BEEP		; fait un grand bruit85$:	TEST.B	(A5)+OFLMOD1:#BPOLYC	JUMP',BS 90$		; n'ote pas les bits BMNEW	CALL	CLRNEW		; ote les bits BMNEW90$:	CALL	CWMO		; remet la souris normale	POPM.L	D0,D1,D2,D3,D4,D5,D6,A4	RET;--------\; MIROIR  >;========/; Reflte horizontalement ou verticalement une zone rectangulaire.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D0.B	0=vertical et 1=horizontal; out	D7.W	erreur; mod	D7.WMIROIR:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	CALL	ORDONNE	LOAD.L	D5,D3		; D5 <-- zone de recherche	LOAD.L	D6,D4		; D6 <-- idem	LOAD.B	(A5)+ONMIROIR,D0	LOAD.B	(A5)+ONTOUR,#2	CLR.W	(A5)+OMTOUR05$:	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP,NE	90$	CALL	SWMO		; met la souris "en attente"10$:	CALL	DETECTE		; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A3,A4		; A3 <-- ^lment actuel	CALL	NXTBASE		; A4 <-- ^lment suivant	EX.L	A3,A4		; A4 <-- ^act, A3 <-- ^suivant	PUSHM.L	D3,D4,D7	CALL	PREND		; registres <-- objet	CALL	INVMODE		; D2 <-- mode inverse	CALL	DESSINE		; efface l'objet	CALL	INVMODE		; D2 <-- mode normal	CALL	MET		; objet <-- registres	CALL	CLOBASE		; supprime l'objet	CALL	OPEBASE		; A4 <-- ^nouvel lment	CALL	OMIROIR		; fait un miroir de l'objet	CALL	MET		; objet <-- registres	TSET.B	(A4)+OMFLAGS:#BMNEW	CALL	DESSINE		; redessine l'objet	POPM.L	D3,D4,D7	LOAD.L	A4,A3		; A4 <-- ^lment suivant	TEST.W	D7	JUMP,EQ	10$	JUMP'	80$20$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$80$:	CALL	CLRNEW		; ote les bits BMNEW	CLR.W	D7		; D7 <-- ok90$:	CALL	CWMO		; remet la souris normale	POPM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; TOURNE  >;========/; Tourne de n fois +90 degrs tous les objets dans une zone; de recherche.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D0.B	nb de quarts de tours (1..3), si autre => tourne selon OMTOUR; out	D7.W	erreur (rotation impossible); mod	D7.WTOURNE:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	CALL	ORDONNE	LOAD.W	D7,#ERPTB	; D7 <-- "accs hors fentre"	LOAD.L	D5,D3		; D5 <-- zone de recherche	LOAD.L	D6,D4		; D6 <-- idem	TEST.B	D0		; zro quart de tours ?	JUMP,EQ	90$		; oui => 90$	LOAD.B	(A5)+ONTOUR,D0	COMP.B	D0,#4	JUMP',EQ 02$	CLR.W	(A5)+OMTOUR	; pas de rotation spciale02$:	COMP.B	D0,#2		; un demi tour ?	JUMP,EQ	05$		; oui => 05$				; non => +1/4 ou -1/4;	LOAD.L	D3,D5	CALL	PTOURNE		; tourne le coin D3	TEST.W	D3		; X trop petit ?	JUMP,NS	90$		; oui => 90$	COMP.W	D3,(A5)+OMWDOX	; X trop grand ?	JUMP,HS	90$		; oui => 90$	SWAP.W	D3	TEST.W	D3		; Y trop petit ?	JUMP,NS	90$		; oui => 90$	COMP.W	D3,(A5)+OMWDOY	; Y trop grand ?	JUMP,HS	90$		; oui => 90$	LOAD.L	D3,D6	CALL	PTOURNE		; tourne le coin D4	TEST.W	D3		; X trop petit ?	JUMP,NS	90$		; oui => 90$	COMP.W	D3,(A5)+OMWDOX	; X trop grand ?	JUMP,HS	90$		; oui => 90$	SWAP.W	D3	TEST.W	D3		; Y trop petit ?	JUMP,NS	90$		; oui => 90$	COMP.W	D3,(A5)+OMWDOY	; Y trop grand ?	JUMP,HS	90$		; oui => 90$	LOAD.L	D3,D6	LOAD.W	D3,D5	CALL	PTOURNE		; tourne le coin D3/D4	TEST.W	D3		; X trop petit ?	JUMP,NS	90$		; oui => 90$	COMP.W	D3,(A5)+OMWDOX	; X trop grand ?	JUMP,HS	90$		; oui => 90$	SWAP.W	D3	TEST.W	D3		; Y trop petit ?	JUMP,NS	90$		; oui => 90$	COMP.W	D3,(A5)+OMWDOY	; Y trop grand ?	JUMP,HS	90$		; oui => 90$	LOAD.L	D3,D5	LOAD.W	D3,D6	CALL	PTOURNE		; tourne le coin D4/D3	TEST.W	D3		; X trop petit ?	JUMP,NS	90$		; oui => 90$	COMP.W	D3,(A5)+OMWDOX	; X trop grand ?	JUMP,HS	90$		; oui => 90$	SWAP.W	D3	TEST.W	D3		; Y trop petit ?	JUMP,NS	90$		; oui => 90$	COMP.W	D3,(A5)+OMWDOY	; Y trop grand ?	JUMP,HS	90$		; oui => 90$	LOAD.L	D3,D5		; D3 <-- zone de recherche05$:	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP,NE	90$	CALL	SWMO		; met la souris "en attente"10$:	CALL	DETECTE		; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A3,A4		; A3 <-- ^lment actuel	CALL	NXTBASE		; A4 <-- ^lment suivant	EX.L	A3,A4		; A4 <-- ^act, A3 <-- ^suivant	PUSHM.L	D3,D4,D7	CALL	PREND		; registres <-- objet	CALL	INVMODE		; D2 <-- mode inverse	CALL	DESSINE		; efface l'objet	CALL	INVMODE		; D2 <-- mode normal	CALL	MET		; objet <-- registres	CALL	CLOBASE		; supprime l'objet	CALL	OPEBASE		; A4 <-- ^nouvel lment	CALL	OTOURNE		; registres <-- tourne	CALL	MET		; objet <-- registres	TSET.B	(A4)+OMFLAGS:#BMNEW	CALL	DESSINE		; redessine l'objet	POPM.L	D3,D4,D7	LOAD.L	A4,A3		; A4 <-- ^lment suivant	TEST.W	D7	JUMP,EQ	10$	JUMP'	80$20$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$80$:	CALL	CLRNEW		; ote les bits BMNEW	CLR.W	D7		; D7 <-- ok90$:	CALL	CWMO		; remet la souris normale	POPM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; ZOOM    >;========/; Agrandi ou diminue tous les objets dans une zone; de recherche.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D0.B	type de zoom (1..4), si autre => zoom selon O(X,Y)ZOOM; out	D7.W	erreur (zoom impossible); mod	D7.WZOOM:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	CALL	ORDONNE	LOAD.W	D7,#ERPTB	; D7 <-- "accs hors fentre"	LOAD.L	D5,D3		; D5 <-- zone de recherche	LOAD.L	D6,D4		; D6 <-- idem	LOAD.B	(A5)+ONZOOM,#+2	COMP.B	D0,#1	JUMP',EQ 02$	LOAD.B	(A5)+ONZOOM,#+1	COMP.B	D0,#2	JUMP',EQ 02$	LOAD.B	(A5)+ONZOOM,#-1	COMP.B	D0,#3	JUMP',EQ 02$	LOAD.B	(A5)+ONZOOM,#-2	COMP.B	D0,#4	JUMP',EQ 02$	COMP.B	D0,#0	JUMP',EQ 01$	JUMP'	03$01$:	CLR.L	D5	CLR.L	D6	JUMP	09$02$:	CLR.W	(A5)+OXZOOM	; indique zoom standard en X	CLR.W	(A5)+OYZOOM	; indique zoom standard en Y03$:	CALL	PZOOM		; zoom le coin D3	TEST.W	D3		; X trop petit ?	JUMP,NS	90$		; oui => 90$	COMP.W	D3,(A5)+OMWDOX	; X trop grand ?	JUMP,HS	90$		; oui => 90$	SWAP.W	D3	TEST.W	D3		; Y trop petit ?	JUMP,NS	90$		; oui => 90$	COMP.W	D3,(A5)+OMWDOY	; Y trop grand ?	JUMP,HS	90$		; oui => 90$	LOAD.L	D3,D4	CALL	PZOOM		; zoom le coin D4	TEST.W	D3		; X trop petit ?	JUMP,NS	90$		; oui => 90$	COMP.W	D3,(A5)+OMWDOX	; X trop grand ?	JUMP,HS	90$		; oui => 90$	SWAP.W	D3	TEST.W	D3		; Y trop petit ?	JUMP,NS	90$		; oui => 90$	COMP.W	D3,(A5)+OMWDOY	; Y trop grand ?	JUMP,HS	90$		; oui => 90$	LOAD.L	D3,D5		; D3 <-- zone de recherche09$:	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP,NE	90$	CALL	SWMO		; met la souris "en attente"10$:	CALL	DETECTE		; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A3,A4		; A3 <-- ^lment actuel	CALL	NXTBASE		; A4 <-- ^lment suivant	EX.L	A3,A4		; A4 <-- ^act, A3 <-- ^suivant	PUSHM.L	D3,D4,D7	CALL	PREND		; registres <-- objet	CALL	INVMODE		; D2 <-- mode inverse	CALL	DESSINE		; efface l'objet	CALL	INVMODE		; D2 <-- mode normal	CALL	MET		; objet <-- registres	CALL	CLOBASE		; supprime l'objet	CALL	OPEBASE		; A4 <-- ^nouvel lment	CALL	OZOOM		; registres <-- zoom	CALL	MET		; objet <-- registres	TSET.B	(A4)+OMFLAGS:#BMNEW	CALL	DESSINE		; redessine l'objet	POPM.L	D3,D4,D7	LOAD.L	A4,A3		; A4 <-- ^lment suivant	TEST.W	D7	JUMP,EQ	10$	JUMP'	80$20$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$80$:	CALL	CLRNEW		; ote les bits BMNEW	CLR.W	D7		; D7 <-- ok90$:	CALL	CWMO		; remet la souris normale	POPM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;**************** _PLANA_AJUSTE:;****************;--------\; AJUSTE  >;========/; Ajuste les paramtres d'un objet lors d'un dplacement.; in	D0.B	objet;	D3.L	paramtre;	D4.L	paramtre;	D6.L	offset +/-; out	D3.L	paramtre ajust;	D4.L	paramtre ajust; mod	D3.L, D4.LAJUSTE:	COMP.B	D0,#OBJRECT	JUMP',EQ 20$	COMP.B	D0,#OBJSURF	JUMP',EQ 20$	COMP.B	D0,#OBJLIGNE	JUMP,EQ	30$	COMP.B	D0,#OBJELASTIQUE	JUMP,EQ	30$	COMP.B	D0,#OBJEHV	JUMP,EQ	40$	COMP.B	D0,#OBJFLECHE	JUMP,EQ	30$	COMP.B	D0,#OBJFHV	JUMP,EQ	40$	COMP.B	D0,#OBJCERCLE	JUMP,EQ	60$	COMP.B	D0,#OBJARC	JUMP,EQ	60$	COMP.B	D0,#OBJELLIPSE	JUMP,EQ	60$	COMP.B	D0,#OBJARCELL	JUMP,EQ	60$	COMP.B	D0,#OBJTEXT	JUMP,EQ	60$				; objet rectangulaire =>	ADD.W	D3,D6		; ajuste X	ADD.W	D4,D6		; ajuste X	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	ADD.W	D3,D6		; ajuste Y	ADD.W	D4,D6		; ajuste Y	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	JUMP	90$20$:				; rectangle lastique =>	TEST.B	(A5)+ORCOIN:#0	; coin X1 trouv ?	JUMP',BC 22$		; non => 22$				; oui =>	ADD.W	D3,D6		; ajuste X122$:	TEST.B	(A5)+ORCOIN:#1	; coin Y1 trouv ?	JUMP',BC 24$		; non => 24$				; oui =>	SWAP.W	D3	SWAP.W	D6	ADD.W	D3,D6		; ajuste Y1	SWAP.W	D3	SWAP.W	D624$:	TEST.B	(A5)+ORCOIN:#2	; coin X2 trouv ?	JUMP',BC 26$		; non => 26$				; oui =>	ADD.W	D4,D6		; ajuste X226$:	TEST.B	(A5)+ORCOIN:#3	; coin Y2 trouv ?	JUMP',BC 28$		; non => 28$				; oui =>	SWAP.W	D4	SWAP.W	D6	ADD.W	D4,D6		; ajuste Y2	SWAP.W	D4	SWAP.W	D628$:	JUMP	90$30$:				; lastique =>	TEST.B	(A5)+ORCOIN:#0	; coin D3 trouv ?	JUMP',BC 35$		; non => 35$				; oui =>	ADD.W	D3,D6		; ajuste X	SWAP.W	D3	SWAP.W	D6	ADD.W	D3,D6		; ajuste Y	SWAP.W	D3	SWAP.W	D635$:	TEST.B	(A5)+ORCOIN:#1	; coin D4 trouv ?	JUMP,BC	90$		; non => 90$				; oui =>	ADD.W	D4,D6		; ajuste X	SWAP.W	D4	SWAP.W	D6	ADD.W	D4,D6		; ajuste Y	SWAP.W	D4	SWAP.W	D6	JUMP	90$40$:				; lastique hor. ou vert. =>	COMP.W	D3,D4		; verticale ?	JUMP,EQ 45$		; oui => 45$				; non => horizontale	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	ADD.W	D3,D6		; ajuste Y	ADD.W	D4,D6		; ajuste Y	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	TEST.B	(A5)+ORCOIN:#0	; coin D3 trouv ?	JUMP',BC 42$		; non => 42$				; oui =>	ADD.W	D3,D6		; ajuste X42$:	TEST.B	(A5)+ORCOIN:#1	; coin D4 trouv ?	JUMP,BC	90$		; non => 90$				; oui =>	ADD.W	D4,D6		; ajuste X	JUMP	90$45$:				; verticale =>	ADD.W	D3,D6		; ajuste X	ADD.W	D4,D6		; ajuste X	TEST.B	(A5)+ORCOIN:#0	; coin D3 trouv ?	JUMP',BC 47$		; non => 47$				; oui =>	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	ADD.W	D3,D6		; ajuste Y	SWAP.W	D3	SWAP.W	D4	SWAP.W	D647$:	TEST.B	(A5)+ORCOIN:#1	; coin D4 trouv ?	JUMP',BC 90$		; non => 90$				; oui =>	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	ADD.W	D4,D6		; ajuste Y	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	JUMP'	90$60$:				; cercle/arc/texte =>	ADD.W	D4,D6		; ajuste X	SWAP.W	D4	SWAP.W	D6	ADD.W	D4,D6		; ajuste Y	SWAP.W	D4	SWAP.W	D690$:	RET;--------\; OMIROIR >;========/; Fait un miroir horizontal ou vertical d'un objet.; in	D0.W	objet;	D3.L	paramtre;	D4.L	paramtre;	D5.L	coordonne coin suprieur gauche;	D6.L	coordonne coin infrieur droite; out	D0.W	objet ajust;	D3.L	paramtre ajust;	D4.L	paramtre ajust; mod	D0.L, D3.L, D4.LOMIROIR:	PUSHM.L	D1,D2	TEST.B	(A5)+ONMIROIR	; h/v ?	JUMP',NE 50$				; vertical =>	COMP.B	D0,#OBJARC	JUMP',EQ 20$	COMP.B	D0,#OBJARCELL	JUMP',EQ 30$	PUSH.W	D3	PUSH.W	D4	CALL	OTOURNE		; registres <-- tourne	POP.W	D4	POP.W	D3	JUMP	90$20$:				; arcs de cercle =>	PUSH.L	D3	PUSH.W	D4	CALL	OTOURNE		; registres <-- tourne	POP.W	D4	POP.L	D3	SWAP.W	D3	LOAD.W	D2,#8-125$:	SR.B	D3,#1	RLX.B	D1,#1	DECJ.W,NMO D2,25$	LOAD.B	D3,D1	SWAP.W	D3	JUMP	90$30$:				; arcs d'ellipse =>	PUSH.W	D0	PUSH.L	D3	PUSH.W	D4	CALL	OTOURNE		; registres <-- tourne	POP.W	D4	POP.L	D3	POP.W	D0	RR.W	D0,#8	LOAD.W	D2,#8-135$:	SR.B	D0,#1	RLX.B	D1,#1	DECJ.W,NMO D2,35$	LOAD.B	D0,D1	RR.W	D0,#8	JUMP	90$50$:				; horizontal =>	COMP.B	D0,#OBJARCELL	JUMP',EQ 70$	SWAP.W	D3	PUSH.W	D3	SWAP.W	D3	SWAP.W	D4	PUSH.W	D4	SWAP.W	D4	CALL	OTOURNE		; registres <-- tourne	SWAP.W	D4	POP.W	D4	SWAP.W	D4	SWAP.W	D3	POP.W	D3	SWAP.W	D3	COMP.B	D0,#OBJARC	JUMP',NE 90$				; arcs de cercle =>	SWAP.W	D3	RR.B	D3,#4	LOAD.W	D2,#8-160$:	SR.B	D3,#1	RLX.B	D1,#1	DECJ.W,NMO D2,60$	LOAD.B	D3,D1	SWAP.W	D3	JUMP'	90$70$:				; arcs d'ellipse =>	PUSH.W	D0	PUSH.L	D3	SWAP.W	D4	PUSH.W	D4	SWAP.W	D4	CALL	OTOURNE		; registres <-- tourne	SWAP.W	D4	POP.W	D4	SWAP.W	D4	POP.L	D3	POP.W	D0	RR.W	D0,#8	RR.B	D0,#4	LOAD.W	D2,#8-175$:	SR.B	D0,#1	RLX.B	D1,#1	DECJ.W,NMO D2,75$	LOAD.B	D0,D1	RR.W	D0,#890$:	POPM.L	D1,D2	RET;--------\; OTOURNE >;========/; Tourne un objet de n fois +90 degrs.; in	D0.W	objet;	D3.L	paramtre;	D4.L	paramtre;	D5.L	coordonne coin suprieur gauche;	D6.L	coordonne coin infrieur droite; out	D0.W	objet ajust;	D3.L	paramtre ajust;	D4.L	paramtre ajust; mod	D0.W, D3.L, D4.LOTOURNE:	PUSH.W	D1	COMP.B	D0,#OBJRECT	JUMP,EQ	35$	COMP.B	D0,#OBJSURF	JUMP,EQ	35$	COMP.B	D0,#OBJLIGNE	JUMP,EQ	30$	COMP.B	D0,#OBJELASTIQUE	JUMP,EQ	30$	COMP.B	D0,#OBJEHV	JUMP,EQ	30$	COMP.B	D0,#OBJFLECHE	JUMP,EQ	30$	COMP.B	D0,#OBJFHV	JUMP,EQ	30$	COMP.B	D0,#OBJCERCLE	JUMP,EQ	20$	COMP.B	D0,#OBJARC	JUMP,EQ	40$	COMP.B	D0,#OBJELLIPSE	JUMP,EQ	50$	COMP.B	D0,#OBJARCELL	JUMP,EQ	60$	COMP.B	D0,#OBJTEXT	JUMP',EQ 20$10$:				; objet rectangulaire =>	CALL	PTOURNE		; D3 <-- tourne point20$:	EX.L	D3,D4	CALL	PTOURNE		; D4 <-- tourne point	EX.L	D4,D3	COMP.B	D0,#OBJSURF	; surface ?	JUMP,NE	90$		; non => 90$				; oui =>	CALL	ATOURNE		; D3 <-- ajuste point	EX.L	D3,D4	CALL	ATOURNE		; D4 <-- ajuste point	EX.L	D4,D3	JUMP	90$30$:				; lastique =>	LOAD.B	D1,(A5)+ORCOIN	AND.B	D1,#B'11	COMP.B	D1,#B'11	; 2 coins trouvs ?	JUMP',NE 90$		; non => 90$	JUMP	10$35$:				; rectangle =>	LOAD.B	D1,(A5)+ORCOIN	AND.B	D1,#B'1111	COMP.B	D1,#B'1111	; 4 coins trouvs ?	JUMP',NE 90$		; non => 90$	JUMP	10$40$:				; arc de cercle =>	LOAD.B	D1,(A5)+ONTOUR	; D1 <-- nb 1/4 de tours (1..3)	SWAP.W	D345$:	RL.B	D3,#2		; tourne les arcs de +90 degrs	DEC.B	D1	JUMP,NE	45$	SWAP.W	D3	JUMP	20$50$:				; ellipse =>	COMP.B	(A5)+ONTOUR,#2	; 1/2 tour ?	JUMP,EQ	20$		; oui => 20$	SWAP.W	D3		; non => permute les rayons X <--> Y	JUMP	20$60$:				; arc d'ellipse =>	LOAD.B	D1,(A5)+ONTOUR	; D1 <-- nb 1/4 de tours (1..3)	RR.W	D0,#8		; D0 <-- arcs65$:	RL.B	D0,#2		; tourne les arcs de +90 degrs	DEC.B	D1	JUMP,NE	65$	RR.W	D0,#8	COMP.B	(A5)+ONTOUR,#2	; 1/2 tour ?	JUMP,EQ	20$		; oui => 20$	SWAP.W	D3		; non => permute les rayons X <--> Y	JUMP	20$90$:	POP.W	D1	RET;--------\; PTOURNE >;========/; Tourne un point de n fois +90 degrs  l'aide de la formule :;	Py = D1 + D2 - Px;	Px = D1 - D2 + Py; avec :;	D1 = (X6-X5)/2 + X5;	D2 = (Y6-Y5)/2 + Y5; in	D5.L	coordonne coin suprieur gauche;	D6.L	coordonne coin infrieur droite;	D3.L	coordonne  tourner; out	D3.L	coordonne tourne; mod	D3.LPTOURNE:	PUSHM.L	D0,D1,D2,D7	TEST.W	(A5)+OMTOUR	; rotation spciale ?	JUMP',NE 50$		; oui => 50$	LOAD.B	D7,(A5)+ONTOUR	; D7 <-- nb de 1/4 de tours	NEG.B	D7	ADD.B	D7,#4		; 1 -> 3  /  2 -> 2  /  3 -> 110$:	LOAD.W	D0,D6	SUB.W	D0,D5	SR.W	D0,#1	ADD.W	D0,D5		; D0 <-- (X6-X5)/2 + X5;;;?	CALL	XARRONDI	LOAD.W	D1,D0		; D1 <-- idem, mais arrondi	SWAP.W	D5	SWAP.W	D6	LOAD.W	D0,D6	SUB.W	D0,D5	SR.W	D0,#1	ADD.W	D0,D5		; D0 <-- (Y6-Y5)/2 + Y5;;;?	CALL	XARRONDI	LOAD.W	D2,D0		; D2 <-- idem, mais arrondi	SWAP.W	D5	SWAP.W	D6	LOAD.W	D0,D1	ADD.W	D0,D2	SUB.W	D0,D3		; D0 <-- D1 + D2 - Px	SWAP.W	D0	SWAP.W	D3	LOAD.W	D0,D1	SUB.W	D0,D2	ADD.W	D0,D3		; D0 <-- D1 - D2 + Py	LOAD.L	D3,D0		; D3 <-- coordonne tourne	DEC.B	D7		; encore 1/4 de tour ?	JUMP,NE	10$		; oui => 10$	JUMP'	90$50$:	LOAD.W	D0,D6	SUB.W	D0,D5	SR.W	D0,#1	ADD.W	D0,D5		; D0 <-- (X6-X5)/2 + X5;;;?	CALL	XARRONDI	SUB.W	D3,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D5	SWAP.W	D6	LOAD.W	D0,D6	SUB.W	D0,D5	SR.W	D0,#1	ADD.W	D0,D5		; D0 <-- (Y6-Y5)/2 + Y5;;;?	CALL	XARRONDI	SUB.W	D3,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D5	SWAP.W	D6	CALL	QTOURNE		; tourne le point  l'origine	ADD.W	D3,D0	SWAP.W	D0	SWAP.W	D3	ADD.W	D3,D0	SWAP.W	D0	SWAP.W	D390$:	POPM.L	D0,D1,D2,D7	RET;--------\; ATOURNE >;========/; Ajuste un point tourn de n fois +90 degrs.; Ceci est utile pour les surfaces trames dessines avec l'option; "remplit" qui doivent rester exactement incluses dans un trait; d'paisseur un.; in	D3.L	coordonne  ajuster; out	D3.L	coordonne ajuste; mod	D3.LATOURNE:	PUSH.W	D0	TEST.W	(A5)+OMTOUR	; rotation spciale ?	JUMP',NE 90$		; oui => 90$	LOAD.B	D0,(A5)+ONTOUR	; D0 <-- nb de 1/4 de tours	DEC.B	D0	JUMP',EQ 40$	DEC.B	D0	JUMP',EQ 20$				; 3/4 de tour =>	INC.W	D3		; +x	JUMP'	90$20$:				; 2/4 de tour =>	INC.W	D3		; +x puis -y40$:				; 1/4 de tour =>	SWAP.W	D3	DEC.W	D3		; -y	SWAP.W	D390$:	POP.W	D0	RET;--------\\; QTOURNE >;--------/; Tourne un point d'un angle quelconque selon la; formule magique suivante :;;	x' = x*cos(a) - y*sin(a);	y' = x*sin(a) + y*cos(a); in	D3.L	coordonne (y;x); out	D3.L	coordonne (y;x); mod	D3.LQTOURNE:	PUSHM.L	D0,D1,D2,D4,D5,A0	LOAD.L	A0,#R16"TSINUS	; A0 <-- ^table des sinus de 0..90 degrs	LOAD.W	D0,(A5)+OMTOUR	; D0 <-- angle	LOAD.W	D2,D3		; D2 <-- X	SWAP.W	D3		; D3 <-- Y	LOAD.W	D4,D2	CALL	COSINUS		; D4 <-- x*cos(a)	LOAD.W	D1,D4	LOAD.W	D4,D3	CALL	SINUS		; D4 <-- y*sin(a)	SUB.W	D1,D4	LOAD.W	D4,D2	CALL	SINUS		; D4 <-- x*sin(a)	LOAD.W	D5,D4	LOAD.W	D4,D3	CALL	COSINUS		; D4 <-- y*cos(a)	ADD.W	D5,D4	LOAD.W	D3,D5	SWAP.W	D3	LOAD.W	D3,D1	POPM.L	D0,D1,D2,D4,D5,A0	RET;**************** _PLANA_COSINUS:;****************;--------\\; COSINUS >;--------/; in	D4.W	valeur;	D0.W	angle en degrs;	A0.L	^table des sinus; out	D4.W	cosinus de la valeur; mod	D4.WCOSINUS:	PUSHM.L	D0..D2	AND.L	D0,#H'FFFF	DIV.WU	D0,#90	LOAD.W	D1,D0		; D1 <-- octant (0..3)	SWAP.W	D0		; D0 <-- angle (0..90-1)	COMP.B	D1,#0	JUMP',EQ 20$	COMP.B	D1,#2	JUMP',NE 30$				;   0..90  =>20$:				; 180..270 =>	SUB.W	D0,#90	NEG.W	D030$:	LOAD.W	D2,D4	SL.W	D0,#1		; D0 <-- *2 car table de .W	MUL.WA	D2,(A0)+(D0.W)	DIV.WA	D2,#1000	LOAD.W	D4,D2	COMP.B	D1,#1	JUMP',EQ 50$	COMP.B	D1,#2	JUMP',NE 90$				;  90..180 =>50$:				; 180..270 =>	NEG.W	D490$:	POPM.L	D0..D2	RET;************** _PLANA_SINUS:;**************;--------\\; SINUS   >;--------/; in	D4.W	valeur;	D0.W	angle en degrs;	A0.L	^table des sinus; out	D4.W	sinus de la valeur; mod	D4.WSINUS:	PUSHM.L	D0..D2	AND.L	D0,#H'FFFF	DIV.WU	D0,#90	LOAD.W	D1,D0		; D1 <-- octant (0..3)	SWAP.W	D0		; D0 <-- angle (0..90-1)	COMP.B	D1,#1	JUMP',EQ 20$	COMP.B	D1,#3	JUMP',NE 30$				;  90..180 =>20$:				; 270..360 =>	SUB.W	D0,#90	NEG.W	D030$:	LOAD.W	D2,D4	SL.W	D0,#1		; D0 <-- *2 car table de .W	MUL.WA	D2,(A0)+(D0.W)	DIV.WA	D2,#1000	LOAD.W	D4,D2	COMP.B	D1,#2	JUMP',EQ 50$	COMP.B	D1,#3	JUMP',NE 90$				; 180..270 =>50$:				; 270..360 =>	NEG.W	D490$:	POPM.L	D0..D2	RET; Table des sinus *1000 de 0  90 degrs :TSINUS:	.W	0,17,35,52,70,87,105,122,139,156		; 0..9	.W	174,191,208,225,242,259,276,292,309,326		; 10..19	.W	342,358,375,391,407,423,438,454,469,485		; 20..29	.W	500,515,530,545,559,574,588,602,616,629		; 30..39	.W	643,656,669,682,695,707,719,731,743,755		; 40..49	.W	766,777,788,799,809,819,829,839,848,857		; 50..59	.W	866,875,883,891,899,906,914,921,927,934		; 60..69	.W	940,946,951,956,961,966,970,974,978,982		; 70..79	.W	985,988,990,993,995,996,998,999,999,1000	; 80..89	.W	1000						; 90;--------\; OZOOM   >;========/; Zoom un objet.; in	D0.B	objet;	D3.L	paramtre;	D4.L	paramtre;	D5.L	coordonne coin suprieur gauche;	D6.L	coordonne coin infrieur droite; out	D0.B	nouvel objet;	D3.L	paramtre zoom;	D4.L	paramtre zoom; mod	D0.W, D3.L, D4.LOZOOM:	PUSH.L	D1	COMP.B	D0,#OBJRECT	JUMP,EQ	30$	COMP.B	D0,#OBJSURF	JUMP,EQ	30$	COMP.B	D0,#OBJLIGNE	JUMP,EQ	30$	COMP.B	D0,#OBJELASTIQUE	JUMP,EQ	30$	COMP.B	D0,#OBJEHV	JUMP,EQ	30$	COMP.B	D0,#OBJFLECHE	JUMP,EQ	30$	COMP.B	D0,#OBJFHV	JUMP,EQ	30$	COMP.B	D0,#OBJCERCLE	JUMP,EQ	40$	COMP.B	D0,#OBJARC	JUMP,EQ	40$	COMP.B	D0,#OBJARCELL	JUMP,EQ	50$	COMP.B	D0,#OBJELLIPSE	JUMP,EQ	50$	COMP.B	D0,#OBJTEXT	JUMP',EQ 20$10$:				; objet rectangulaire =>	CALL	PZOOM		; D3 <-- zoom point20$:	EX.L	D3,D4	CALL	PZOOM		; D4 <-- zoom point	EX.L	D4,D3	JUMP'	90$30$:				; lastique =>	TEST.B	(A5)+ORCOIN:#0	; coin D3 trouv ?	JUMP',BC 90$		; non => 90$	TEST.B	(A5)+ORCOIN:#1	; coin D4 trouv ?	JUMP',BC 90$		; non => 90$	JUMP	10$40$:				; cercle/arc =>	LOAD.W	D1,(A5)+OXZOOM	COMP.W	D1,(A5)+OYZOOM	; dformation ?	JUMP',NE 45$		; oui => 45$	CALL	XZOOM		; D3 <-- zoom rayon	JUMP	20$45$:	COMP.B	D0,#OBJARC	JUMP',EQ 47$				; dformation d'un cercle =>	LOAD.B	D0,#OBJELLIPSE	JUMP'	48$47$:				; dformation d'un arc de cercle =>	SWAP.W	D3	LOAD.B	D0,D3	SL.W	D0,#8	SWAP.W	D3	LOAD.B	D0,#OBJARCELL	; D0 <-- arc/objet48$:	LOAD.W	D1,D3	SWAP.W	D3	LOAD.W	D3,D1		; D3 <-- rayons (ry;rx)	SWAP.W	D350$:				; ellipse =>	SWAP.W	D3	CALL	YZOOM		; D3 <-- zoom rayon Y	SWAP.W	D3	CALL	XZOOM		; D3 <-- zoom rayon X	JUMP	20$90$:	POP.L	D1	RET;--------\; PZOOM   >;========/; Zoom un point.; in	D5.L	coordonne coin suprieur gauche;	D6.L	coordonne coin infrieur droite;	D3.L	coordonne  zoomer; out	D3.L	coordonne zoome; mod	D3.LPZOOM:	PUSHM.L	D0,D1,D2	LOAD.W	D0,D6	SUB.W	D0,D5	SR.W	D0,#1	ADD.W	D0,D5		; D0 <-- (X6-X5)/2 + X5;;;?	CALL	XARRONDI	LOAD.W	D1,D0		; D1 <-- idem, mais arrondi	SWAP.W	D5	SWAP.W	D6	LOAD.W	D0,D6	SUB.W	D0,D5	SR.W	D0,#1	ADD.W	D0,D5		; D0 <-- (Y6-Y5)/2 + Y5;;;?	CALL	XARRONDI	LOAD.W	D2,D0		; D2 <-- idem, mais arrondi	SWAP.W	D5	SWAP.W	D6	SUB.W	D3,D1		; D3 <-- Px relatif au centre	CALL	XZOOM		; D3 <-- zoom	ADD.W	D3,D1		; D3 <-- Px absolu	SWAP.W	D3	SUB.W	D3,D2		; D3 <-- Py relatif au centre	CALL	YZOOM		; D3 <-- zoom	ADD.W	D3,D2		; D3 <-- Py absolu	SWAP.W	D3	POPM.L	D0,D1,D2	RET;--------\; XZOOM   >;========/; Multiplie ou divise une valeur par 2 ou 4.; in	D3.W	valeur  zoomer; out	D3.W	valeur zoome; mod	D3.WXZOOM:	PUSH.L	D0	TEST.W	(A5)+OXZOOM	JUMP',NE 70$	LOAD.B	D0,(A5)+ONZOOM	; D0 <-- facteur zoom	JUMP',NS 50$		; diminue => 50$				; agrandi =>	ASL.W	D3,D0		; D3 <-- multiplie par 2 ou 4	JUMP'	90$50$:				; diminue =>	NEG.B	D0		; D0 <-- 1 ou 2	ASR.W	D3,D0		; D3 <-- divise par 2 ou 4	JUMP'	90$70$:				; zoom quelconque =>	LOAD.W	D0,D3	MUL.WA	D0,(A5)+OXZOOM	DIV.WA	D0,#1000	LOAD.W	D3,D090$:	POP.L	D0	RET;--------\; YZOOM   >;========/; Multiplie ou divise une valeur par 2 ou 4.; in	D3.W	valeur  zoomer; out	D3.W	valeur zoome; mod	D3.WYZOOM:	PUSH.L	D0	TEST.W	(A5)+OYZOOM	JUMP',NE 70$	LOAD.B	D0,(A5)+ONZOOM	; D0 <-- facteur zoom	JUMP',NS 50$		; diminue => 50$				; agrandi =>	ASL.W	D3,D0		; D3 <-- multiplie par 2 ou 4	JUMP'	90$50$:				; diminue =>	NEG.B	D0		; D0 <-- 1 ou 2	ASR.W	D3,D0		; D3 <-- divise par 2 ou 4	JUMP'	90$70$:				; zoom quelconque =>	LOAD.W	D0,D3	MUL.WA	D0,(A5)+OYZOOM	DIV.WA	D0,#1000	LOAD.W	D3,D090$:	POP.L	D0	RET;***************** _PLANA_FDETECTE:;*****************;---------\; FDETECTE >;=========/; Dtecte si un lment est dans la zone de recherche.; Prend mme les objets filtrs !; in	A4.L		^lment;	D3.L		coordonne coin zone de recherche;	D4.L		coordonne coin zone de recherche;	(A5)+OFLDET.B	flags;	(A5)+ODETNN.W	niveau d'imbrication; out	(A5)+OFLDET.B	flags;	(A5)+ODETNN.W	niveau d'imbrication;	(A5)+ORCOIN.B	coins trouvs;	D7.W		trouv ou pas; mod	D7.WFDETECTE:	PUSH.B	(A4)+OMFLAGS	TCLR.B	(A4)+OMFLAGS:#BMNOT ; objet pas "filtr" !	CALL	DETECTE	POP.B	(A4)+OMFLAGS	TEST.W	D7		; retour EQ/NE	RET;**************** _PLANA_DETECTE:;****************;---------\; DETECTE  >;=========/; Dtecte si un lment est dans la zone de recherche,; en tenant compte des groupes. Pour qu'un groupe soit pris,; il faut qu'il soit entirement inclu dans la zone de recherche.; Si le premier objet d'un groupe est "filtr", ne prend pas; tout le groupe !; Les dbut/fin de groupes peuvent tre imbriqus comme suit :;;	 |------------------------------|;	 |      |----|     |----|       |;	 |      |    |     |    |       |;	<DU>   <DS> <FS>  <DS> <FS>    <FU>;	    <------------------------->;	          tous ces objets;	        doivent tre inclus; in	A4.L		^lment;	D3.L		coordonne coin zone de recherche;	D4.L		coordonne coin zone de recherche;	(A5)+OFLDET.B	flags;	(A5)+ODETNN.W	niveau d'imbrication; out	(A5)+OFLDET.B	flags;	(A5)+ODETNN.W	niveau d'imbrication;	(A5)+ORCOIN.B	coins trouvs;	D7.W		trouv ou pas; mod	D7.WDETECTE:	PUSHM.L	D0..D2,D5,A4	TEST.B	(A5)+OFLDET:#BDETGR ; est-on dans un groupe ?	JUMP,BS 50$		; oui => 50$	LOAD.W	D5,(A4)+OMOBJET	COMP.B	D5,#OBJDUGROUPE	; dbut d'un groupe utilisateur ?	JUMP',EQ 30$		; oui => 30$	COMP.B	D5,#OBJDSGROUPE	; dbut d'un groupe systme ?	JUMP',EQ 30$		; oui => 30$20$:	CALL	ODETECTE	; D7 <-- trouv ou pas	JUMP,NE 90$		; pas dans la zone => 90$	TEST.B	(A4)+OMFLAGS:#BMNOT ; objet "filtr" ?	JUMP,BC 90$		; non => 90$	LOAD.W	D7,#ERPNF	; oui => "pas trouv"	JUMP	90$30$:				; dbut d'un groupe =>	TEST.B	(A4)+OMFLAGS:#BMNEW	JUMP,BS	20$	CLR.W	D0		; D0 <-- nb d'objets inclus	CLR.W	D1		; D1 <-- nb d'objets total	LOAD.W	D2,#1		; D2 <-- une fin de groupe attendue	TEST.B	(A4)+OMFLAGS:#BMNOT ; objet "filtr" ?	JUMP,BS 42$		; oui => 42$ (ne prend pas le groupe)	LOAD.L	(A5)+OGRBG,#-1	CLR.L	(A5)+OGRHD	CALL	NXTBASE		; A4 <-- saute objet de dbut de groupe35$:	LOAD.W	D5,(A4)+OMOBJET	COMP.B	D5,#OBJDUGROUPE	; dbut d'un groupe imbriqu ?	JUMP',EQ 38$		; oui => 38$	COMP.B	D5,#OBJDSGROUPE	JUMP',EQ 38$	COMP.B	D5,#OBJFUGROUPE	; fin d'un groupe ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D5,#OBJFSGROUPE	JUMP',EQ 40$	INC.W	D1		; D1 <-- un objet de plus	CALL	ODETECTE	; dans zone de recherche ?	JUMP',NE 37$		; non => 37$	INC.W	D0		; D0 <-- un objet de plus inclu37$:	CALL	NXTBASE		; A4 <-- ^objet suivant	JUMP,EQ	35$	JUMP'	42$38$:				; dbut d'un groupe imbriqu =>	INC.W	D2		; D2 <-- une fin de groupe de plus attendue	JUMP	37$40$:				; fin d'un groupe =>	DEC.W	D2	JUMP,NE 37$42$:	LOAD.W	(A5)+ODETNN,#1	; attend UNE fin de groupe	TSET.B	(A5)+OFLDET:#BDETGR	TCLR.B	(A5)+OFLDET:#BDETOK ; ne prend pas le groupe	TEST.W	D0		; au moins un objet inclu ?	JUMP',EQ 70$		; non => 70$	COMP.W	D0,D1		; tous les objets inclus ?	JUMP',NE 70$		; non => 70$	TSET.B	(A5)+OFLDET:#BDETOK ; prend tout le groupe	JUMP'	70$50$:				; on est dans un groupe =>	LOAD.W	D5,(A4)+OMOBJET	COMP.B	D5,#OBJDUGROUPE	; dbut d'un groupe imbriqu ?	JUMP',EQ 57$		; oui => 57$	COMP.B	D5,#OBJDSGROUPE	JUMP',EQ 57$	COMP.B	D5,#OBJFUGROUPE	; fin du groupe ?	JUMP',EQ 55$		; oui => 55$	COMP.B	D5,#OBJFSGROUPE	JUMP',NE 70$55$:	DEC.W	(A5)+ODETNN	; fin imbrique ?	JUMP',NE 70$		; oui => 70$	TCLR.B	(A5)+OFLDET:#BDETGR	JUMP'	70$57$:	INC.W	(A5)+ODETNN	; une fin de groupe de plus attendue70$:	LOAD.W	D7,#ERPNF	; D7 <-- ne prend pas	TEST.B	(A5)+OFLDET:#BDETOK	JUMP',BC 90$	LOAD.B	(A5)+ORCOIN,#-1	; tous les coins trouvs !	CLR.W	D7		; D7 <-- prend90$:	POPM.L	D0..D2,D5,A4	TEST.W	D7		; retour EQ/NE	RET;---------\; ODETECTE >;---------/; Dtecte si un lment est dans la zone de recherche.; Tous les objets sont pris en compte.; Trouve toujours les dbut/fin de groupes !; Ne jamais utiliser directement, prfrer FDETECTE !; in	A4.L		^lment;	D3.L		coordonne coin zone de recherche;	D4.L		coordonne coin zone de recherche; out	(A5)+ORCOIN.B	coins trouvs;	D7.W		trouv ou pas; mod	D7.WODETECTE:	PUSHM.L	D1,D2,D3,D4,D5,D6	LOAD.W	D7,#ERPNF	; D7 <-- pas trouv	TEST.B	(A4)+OMFLAGS:#BMNEW	JUMP,BS	90$	CLR.W	D7		; D7 <-- trouv	LOAD.W	D1,(A4)+OMOBJET	; D1 <-- objet	COMP.B	D1,#OBJDUGROUPE	JUMP,EQ 90$	COMP.B	D1,#OBJFUGROUPE	JUMP,EQ 90$	COMP.B	D1,#OBJDSGROUPE	JUMP,EQ 90$	COMP.B	D1,#OBJFSGROUPE	JUMP,EQ 90$	LOAD.W	D7,#ERPNF	; D7 <-- pas trouv	LOAD.B	D5,(A4)+OMMODE	; D5 <-- couleur/mode	SR.B	D5,#4		; D5 <-- couleur	LOAD.W	D6,(A5)+OCOULEUR	TEST.L	D6:D5		; couleur visible ?	JUMP,BC	90$		; non => 90$	LOAD.L	D5,D3		; D3 <-- X1	SWAP.W	D5		; D5 <-- Y1	LOAD.L	D6,D4		; D4 <-- X2	SWAP.W	D6		; D6 <-- Y2	COMP.B	D1,#OBJRECT	JUMP,EQ	20$	COMP.B	D1,#OBJSURF	JUMP,EQ	20$	COMP.B	D1,#OBJLIGNE	JUMP,EQ	30$	COMP.B	D1,#OBJELASTIQUE	JUMP,EQ	30$	COMP.B	D1,#OBJEHV	JUMP,EQ	30$	COMP.B	D1,#OBJFLECHE	JUMP,EQ	30$	COMP.B	D1,#OBJFHV	JUMP,EQ	30$	COMP.B	D1,#OBJCERCLE	JUMP,EQ	40$	COMP.B	D1,#OBJELLIPSE	JUMP,EQ	45$	COMP.B	D1,#OBJARC	JUMP,EQ	50$	COMP.B	D1,#OBJARCELL	JUMP,EQ	60$	COMP.B	D1,#OBJTEXT	JUMP,EQ	70$				; objet rectangulaire =>	COMP.W	D3,(A4)+OMPAR1+OXX	JUMP,HI	90$	COMP.W	D4,(A4)+OMPAR1+OXX	JUMP,LO	90$	COMP.W	D5,(A4)+OMPAR1+OYY	JUMP,HI	90$	COMP.W	D6,(A4)+OMPAR1+OYY	JUMP,LO	90$	COMP.W	D3,(A4)+OMPAR2+OXX	JUMP,HI	90$	COMP.W	D4,(A4)+OMPAR2+OXX	JUMP,LO	90$	COMP.W	D5,(A4)+OMPAR2+OYY	JUMP,HI	90$	COMP.W	D6,(A4)+OMPAR2+OYY	JUMP,LO	90$15$:	CLR.W	D7		; D7 <-- trouv	JUMP	90$20$:				; rectangle lastique =>	CLR.B	(A5)+ORCOIN	; pas de coins trouvs	COMP.W	D3,(A4)+OMPAR1+OXX	JUMP',HI 22$	COMP.W	D4,(A4)+OMPAR1+OXX	JUMP',LO 22$	COMP.W	D5,(A4)+OMPAR1+OYY	JUMP',HI 22$	COMP.W	D6,(A4)+OMPAR1+OYY	JUMP',LO 22$	TSET.B	(A5)+ORCOIN:#0	; coin sup/gauche trouv	TSET.B	(A5)+ORCOIN:#122$:	COMP.W	D3,(A4)+OMPAR1+OXX	JUMP',HI 23$	COMP.W	D4,(A4)+OMPAR1+OXX	JUMP',LO 23$	COMP.W	D5,(A4)+OMPAR2+OYY	JUMP',HI 23$	COMP.W	D6,(A4)+OMPAR2+OYY	JUMP',LO 23$	TSET.B	(A5)+ORCOIN:#0	; coin inf/gauche trouv	TSET.B	(A5)+ORCOIN:#323$:	COMP.W	D3,(A4)+OMPAR2+OXX	JUMP',HI 24$	COMP.W	D4,(A4)+OMPAR2+OXX	JUMP',LO 24$	COMP.W	D5,(A4)+OMPAR2+OYY	JUMP',HI 24$	COMP.W	D6,(A4)+OMPAR2+OYY	JUMP',LO 24$	TSET.B	(A5)+ORCOIN:#2	; coin inf/droite trouv	TSET.B	(A5)+ORCOIN:#324$:	COMP.W	D3,(A4)+OMPAR2+OXX	JUMP',HI 25$	COMP.W	D4,(A4)+OMPAR2+OXX	JUMP',LO 25$	COMP.W	D5,(A4)+OMPAR1+OYY	JUMP',HI 25$	COMP.W	D6,(A4)+OMPAR1+OYY	JUMP',LO 25$	TSET.B	(A5)+ORCOIN:#2	; coin sup/droite trouv	TSET.B	(A5)+ORCOIN:#125$:	TEST.B	(A5)+ORCOIN	; coin(s) trouv(s) ?	JUMP,EQ	90$		; non => 90$	CLR.W	D7		; D7 <-- trouv	JUMP	90$30$:				; lastique =>	CLR.B	(A5)+ORCOIN	; pas de coins trouvs	COMP.W	D3,(A4)+OMPAR1+OXX	JUMP',HI 32$	COMP.W	D4,(A4)+OMPAR1+OXX	JUMP',LO 32$	COMP.W	D5,(A4)+OMPAR1+OYY	JUMP',HI 32$	COMP.W	D6,(A4)+OMPAR1+OYY	JUMP',LO 32$	TSET.B	(A5)+ORCOIN:#0	; coin D3 trouv32$:	COMP.W	D3,(A4)+OMPAR2+OXX	JUMP',HI 34$	COMP.W	D4,(A4)+OMPAR2+OXX	JUMP',LO 34$	COMP.W	D5,(A4)+OMPAR2+OYY	JUMP',HI 34$	COMP.W	D6,(A4)+OMPAR2+OYY	JUMP',LO 34$	TSET.B	(A5)+ORCOIN:#1	; coin D4 trouv34$:	TEST.B	(A5)+ORCOIN	; coin(s) trouv(s) ?	JUMP,EQ	90$		; non => 90$	CLR.W	D7		; D7 <-- trouv	JUMP	90$40$:				; cercle =>	LOAD.W	D2,(A4)+OMPAR2+OXX	SUB.W	D2,(A4)+OMPAR1+OXX ; soustrait rayon	COMP.W	D3,D2	JUMP,HI	90$	COMP.W	D4,D2	JUMP,LO	90$	LOAD.W	D2,(A4)+OMPAR2+OYY	SUB.W	D2,(A4)+OMPAR1+OXX ; soustrait rayon	COMP.W	D5,D2	JUMP,HI	90$	COMP.W	D6,D2	JUMP,LO	90$	LOAD.W	D2,(A4)+OMPAR2+OXX	ADD.W	D2,(A4)+OMPAR1+OXX ; ajoute rayon	COMP.W	D3,D2	JUMP,HI	90$	COMP.W	D4,D2	JUMP,LO	90$	LOAD.W	D2,(A4)+OMPAR2+OYY	ADD.W	D2,(A4)+OMPAR1+OXX ; ajoute rayon	COMP.W	D5,D2	JUMP,HI	90$	COMP.W	D6,D2	JUMP,LO	90$	CLR.W	D7		; D7 <-- trouv	JUMP	90$45$:				; ellipse =>	LOAD.W	D2,(A4)+OMPAR2+OXX	SUB.W	D2,(A4)+OMPAR1+OXX ; soustrait rayon X	COMP.W	D3,D2	JUMP,HI	90$	COMP.W	D4,D2	JUMP,LO	90$	LOAD.W	D2,(A4)+OMPAR2+OYY	SUB.W	D2,(A4)+OMPAR1+OYY ; soustrait rayon Y	COMP.W	D5,D2	JUMP,HI	90$	COMP.W	D6,D2	JUMP,LO	90$	LOAD.W	D2,(A4)+OMPAR2+OXX	ADD.W	D2,(A4)+OMPAR1+OXX ; ajoute rayon X	COMP.W	D3,D2	JUMP,HI	90$	COMP.W	D4,D2	JUMP,LO	90$	LOAD.W	D2,(A4)+OMPAR2+OYY	ADD.W	D2,(A4)+OMPAR1+OYY ; ajoute rayon Y	COMP.W	D5,D2	JUMP,HI	90$	COMP.W	D6,D2	JUMP,LO	90$	CLR.W	D7		; D7 <-- trouv	JUMP	90$50$:				; arc de cercle =>	LOAD.B	D1,(A4)+OMPAR1+1	COMP.W	D3,(A4)+OMPAR2+OXX	JUMP,HI	90$	COMP.W	D4,(A4)+OMPAR2+OXX	JUMP,LO	90$	COMP.W	D5,(A4)+OMPAR2+OYY	JUMP,HI	90$	COMP.W	D6,(A4)+OMPAR2+OYY	JUMP,LO	90$	TEST.L	D1:#7	JUMP',BS 51$	TEST.L	D1:#6	JUMP',BS 51$	TEST.L	D1:#5	JUMP',BS 51$	TEST.L	D1:#4	JUMP',BC 52$51$:	LOAD.W	D2,(A4)+OMPAR2+OYY	SUB.W	D2,(A4)+OMPAR1+OXX ; D2 <-- Y min cercle	COMP.W	D5,D2	JUMP,HI	90$	COMP.W	D6,D2	JUMP,LO	90$52$:	TEST.L	D1:#5	JUMP',BS 53$	TEST.L	D1:#4	JUMP',BS 53$	TEST.L	D1:#3	JUMP',BS 53$	TEST.L	D1:#2	JUMP',BC 54$53$:	LOAD.W	D2,(A4)+OMPAR2+OXX	SUB.W	D2,(A4)+OMPAR1+OXX ; D2 <-- X min cercle	COMP.W	D3,D2	JUMP,HI	90$	COMP.W	D4,D2	JUMP,LO	90$54$:	TEST.L	D1:#3	JUMP',BS 55$	TEST.L	D1:#2	JUMP',BS 55$	TEST.L	D1:#1	JUMP',BS 55$	TEST.L	D1:#0	JUMP',BC 56$55$:	LOAD.W	D2,(A4)+OMPAR2+OYY	ADD.W	D2,(A4)+OMPAR1+OXX ; D2 <-- Y max cercle	COMP.W	D5,D2	JUMP,HI	90$	COMP.W	D6,D2	JUMP,LO	90$56$:	TEST.L	D1:#1	JUMP',BS 57$	TEST.L	D1:#0	JUMP',BS 57$	TEST.L	D1:#7	JUMP',BS 57$	TEST.L	D1:#6	JUMP',BC 58$57$:	LOAD.W	D2,(A4)+OMPAR2+OXX	ADD.W	D2,(A4)+OMPAR1+OXX ; D2 <-- X max cercle	COMP.W	D3,D2	JUMP,HI 90$	COMP.W	D4,D2	JUMP,LO 90$58$:	CLR.W	D7		; D7 <-- trouv	JUMP	90$60$:				; arc d'ellipse =>	LOAD.B	D1,(A4)+OMOBJET+0	COMP.W	D3,(A4)+OMPAR2+OXX	JUMP,HI	90$	COMP.W	D4,(A4)+OMPAR2+OXX	JUMP,LO	90$	COMP.W	D5,(A4)+OMPAR2+OYY	JUMP,HI	90$	COMP.W	D6,(A4)+OMPAR2+OYY	JUMP,LO	90$	TEST.L	D1:#7	JUMP',BS 61$	TEST.L	D1:#6	JUMP',BS 61$	TEST.L	D1:#5	JUMP',BS 61$	TEST.L	D1:#4	JUMP',BC 62$61$:	LOAD.W	D2,(A4)+OMPAR2+OYY	SUB.W	D2,(A4)+OMPAR1+OYY ; D2 <-- Y min cercle	COMP.W	D5,D2	JUMP,HI	90$	COMP.W	D6,D2	JUMP,LO	90$62$:	TEST.L	D1:#5	JUMP',BS 63$	TEST.L	D1:#4	JUMP',BS 63$	TEST.L	D1:#3	JUMP',BS 63$	TEST.L	D1:#2	JUMP',BC 64$63$:	LOAD.W	D2,(A4)+OMPAR2+OXX	SUB.W	D2,(A4)+OMPAR1+OXX ; D2 <-- X min cercle	COMP.W	D3,D2	JUMP,HI	90$	COMP.W	D4,D2	JUMP,LO	90$64$:	TEST.L	D1:#3	JUMP',BS 65$	TEST.L	D1:#2	JUMP',BS 65$	TEST.L	D1:#1	JUMP',BS 65$	TEST.L	D1:#0	JUMP',BC 66$65$:	LOAD.W	D2,(A4)+OMPAR2+OYY	ADD.W	D2,(A4)+OMPAR1+OYY ; D2 <-- Y max cercle	COMP.W	D5,D2	JUMP,HI	90$	COMP.W	D6,D2	JUMP,LO	90$66$:	TEST.L	D1:#1	JUMP',BS 67$	TEST.L	D1:#0	JUMP',BS 67$	TEST.L	D1:#7	JUMP',BS 67$	TEST.L	D1:#6	JUMP',BC 68$67$:	LOAD.W	D2,(A4)+OMPAR2+OXX	ADD.W	D2,(A4)+OMPAR1+OXX ; D2 <-- X max cercle	COMP.W	D3,D2	JUMP',HI 90$	COMP.W	D4,D2	JUMP',LO 90$68$:	CLR.W	D7		; D7 <-- trouv	JUMP'	90$70$:				; texte =>	COMP.W	D3,(A4)+OMPAR2+OXX	JUMP',HI 90$	COMP.W	D4,(A4)+OMPAR2+OXX	JUMP',LO 90$	COMP.W	D5,(A4)+OMPAR2+OYY	JUMP',HI 90$	COMP.W	D6,(A4)+OMPAR2+OYY	JUMP',LO 90$	CLR.W	D7		; D7 <-- trouv90$:	TEST.W	D7	JUMP,NE	99$	LOAD.L	D1,(A5)+OGRBG	LOAD.L	D2,(A5)+OGRHD	CALL	PLACE	JUMP,NE	99$	CALL	PLMINMAX	LOAD.L	(A5)+OGRBG,D1	LOAD.L	(A5)+OGRHD,D299$:	POPM.L	D1,D2,D3,D4,D5,D6	TEST.W	D7		; retour EQ/NE	RET;vv=================== routines donnant la place occupe par le PLAN;************* _PLANA_PLACE:;*************;--------\\; PPLACE  >;========/; Donne la place occupe par tout le plan.; in	-; out	D3.L	coin du dessin;	D4.L	autre coin du dessin;	D7.W	erreur; mod	D3.L, D4.L, D7.WPPLACE:	PUSHM.L	D1,D2,A4	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP',NE 90$	LOAD.L	D1,#-1	CLR.L	D210$:	CALL	PLACE		; D3/D4 <-- place occup	JUMP',NE 50$	CALL	PLMINMAX	; D1 <-- min, D2 <-- max50$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$	LOAD.W	D7,#ERPNF	; D7 <-- pas trouv	TEST.L	D2	JUMP',EQ 90$	LOAD.L	D3,D1	LOAD.L	D4,D2	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D2,A4	TEST.W	D7		; retour EQ/NE	RET;--------- PLMINMAX:;-------------------------v; in	D1	minimum avant;	D2	maximum avant;	D3	inf. gauche;	D4	sup. droit; out	D1	minimum aprs;	D2	maximum aprs; mod	D1, D2, F;	COMP.W	D1,D3	JUMP',LS 20$	LOAD.W	D1,D320$:	SWAP.W	D1	SWAP.W	D3	COMP.W	D1,D3	JUMP',LS 21$	LOAD.W	D1,D321$:	SWAP.W	D1	SWAP.W	D3	COMP.W	D2,D4	JUMP',HS 22$	LOAD.W	D2,D422$:	SWAP.W	D2	SWAP.W	D4	COMP.W	D2,D4	JUMP',HS 23$	LOAD.W	D2,D423$:	SWAP.W	D2	SWAP.W	D4	RET;-----------------------^;--------\\; PLACE   >;========/; Donne la place occupe par un objet.; in	A4.L	^lment; out	D3.L	coordonne coin;	D4.L	coordonne coin oppos;	D7.W	erreur; mod	D3.L, D4.L, D7.WPLACE:	PUSHM.L	D0..D2,A0	LOAD.W	D7,#ERPNF	; D7 <-- pas trouv	LOAD.W	D1,(A4)+OMOBJET	; D1 <-- objet; Vrifie s'il s'agit d'un objet spcial, sans dimensions.	COMP.B	D1,#OBJDUGROUPE	JUMP,EQ 90$	COMP.B	D1,#OBJFUGROUPE	JUMP,EQ 90$	COMP.B	D1,#OBJDSGROUPE	JUMP,EQ 90$	COMP.B	D1,#OBJFSGROUPE	JUMP,EQ 90$; Vrifie s'il s'agit d'un objet autre que (y1;x1) et (y2;x2).	LOAD.L	D4,(A4)+OMPAR2	; D4 <-- toujours (y2;x2)	COMP.B	D1,#OBJFLECHE	; nouveau depuis 5.11	JUMP',EQ 20$	COMP.B	D1,#OBJFHV	JUMP',EQ 20$	COMP.B	D1,#OBJCERCLE	JUMP',EQ 30$	COMP.B	D1,#OBJARC	JUMP',EQ 35$	COMP.B	D1,#OBJTEXT	JUMP',EQ 50$	COMP.B	D1,#OBJELLIPSE	JUMP',EQ 40$	COMP.B	D1,#OBJARCELL	JUMP',EQ 45$; Objets standards. Prend simplement l'autre point.	LOAD.L	D3,(A4)+OMPAR1	; D3 <-- (y1;x1)	COMP.B	D1,#OBJSURF	JUMP,EQ 85$	JUMP	80$; Objets spciaux...20$:				;  flche =>	LOAD.L	D3,(A4)+OMPAR1	; D3 <-- (y1;x1)	CALL	PLFLECHE	JUMP	80$30$:				; cercle =>	LOAD.B	D1,#-1	LOAD.W	D2,(A4)+OMPAR1+OXX	SWAP.W	D2	LOAD.W	D2,(A4)+OMPAR1+OXX	JUMP'	60$35$:				; arc de cercle =>	LOAD.B	D1,(A4)+OMPAR1+1	LOAD.W	D2,(A4)+OMPAR1+OXX	SWAP.W	D2	LOAD.W	D2,(A4)+OMPAR1+OXX	JUMP'	60$40$:				; ellipse =>	LOAD.B	D1,#-1	LOAD.L	D2,(A4)+OMPAR1	JUMP'	60$45$:				; arc d'ellipse =>	SR.W	D1,#8	LOAD.L	D2,(A4)+OMPAR1	JUMP'	60$50$:				; caractre =>	LOAD.L	D3,(A4)+OMPAR1	CALL	SRCPGC		; A0 <-- ^gencar;;;	JUMP,NE 90$	JUMP,EQ	55$	LOAD.L	A0,(A5)+OPDDIS	; car. par dfaut	LOAD.L	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,(A0)+ODFC1Y	SUB.W	D4,(A0)+ODFC2Y	SWAP.W	D4	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1X	ADD.W	D4,(A0)+ODFC2X	JUMP	85$55$:	LOAD.L	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,(A0)+OGC1Y	SUB.W	D4,(A0)+OGC2Y	SWAP.W	D4	SWAP.W	D3	SUB.W	D3,(A0)+OGC1X	ADD.W	D4,(A0)+OGC2X	JUMP	85$; Traite ici le cas de l'objet circulaire le plus complxe,; c'est--dire d'un arc d'ellipse.; in	D1.B	arcs;	D2.L	rayons (ry;rx)60$:	LOAD.L	D3,D4	TEST.L	D1:#4	JUMP',BS 61$	TEST.L	D1:#5	JUMP',BS 61$	TEST.L	D1:#6	JUMP',BS 61$	TEST.L	D1:#7	JUMP',BC 62$61$:	SWAP.W	D2	SWAP.W	D3	SUB.W	D3,D2		; D3 <-- en bas	SWAP.W	D3	SWAP.W	D262$:	TEST.L	D1:#0	JUMP',BS 63$	TEST.L	D1:#1	JUMP',BS 63$	TEST.L	D1:#2	JUMP',BS 63$	TEST.L	D1:#3	JUMP',BC 64$63$:	SWAP.W	D2	SWAP.W	D4	ADD.W	D4,D2		; D4 <-- en haut	SWAP.W	D4	SWAP.W	D264$:	TEST.L	D1:#2	JUMP',BS 65$	TEST.L	D1:#3	JUMP',BS 65$	TEST.L	D1:#4	JUMP',BS 65$	TEST.L	D1:#5	JUMP',BC 66$65$:	SUB.W	D3,D2		; D3 <--  gauche66$:	TEST.L	D1:#0	JUMP',BS 67$	TEST.L	D1:#1	JUMP',BS 67$	TEST.L	D1:#6	JUMP',BS 67$	TEST.L	D1:#7	JUMP',BC 68$67$:	ADD.W	D4,D2		; D4 <--  droite68$:; Tient compte de l'paisseur des traits.80$:	CALL	ORDONNE		; D3 plus petit que D4	LOAD.B	D1,(A4)+OMTRAI	COMP.B	D1,#TRAMAX	JUMP',HS 82$	CALL	CONVLT		; D1 <-- paisseur relle	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	ADD.W	D4,D1	JUMP'	85$82$:				; pinceau =>	SUB.W	D3,#4	ADD.W	D4,#4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#4+1		; correction pour .image (pinceau pas dessin)	ADD.W	D4,#4	SWAP.W	D3	SWAP.W	D485$:	CALL	ORDONNE		; D3 plus petit que D4	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2,A0	TEST.W	D7		; retour EQ/NE	RET;---------- Sp. mai 87 PLFLECHE:;----------;; donne la place occupe par une flche;; in	D3.L	coordonne point de dpart (relle);	D4.L	coordonne point d'arrive (relle);	D1.W	objet; out	D3,D4	place occupe (Ymin;Xmin) et (Ymax;Xmax); mod	D7.W;	PUSHM.L	D0..D2,D5,D6,A4	LOAD.L	A4,#(A5)+OBUFLE	; A4 <-- ^flches	SR.W	D1,#8		; D0 <-- no de la flche	MUL.WU	D1,#4	ADD.L	A4,D1		; A4 <-- ^la bonne flche	LOAD.L	D1,#-1		; initialise pour minimum	CLR.L	D2		; initialise pour maximum	TEST.B	(A4)+OFLEXT:#BFLEXT	JUMP,BS 50$				; FLECHE INTERIEURE =>				; flche  deux droites (forme en "V" ou triangle) =>	TEST.B	(A4)+OFLEXT:#BFLD3	; flche en D3 ?	JUMP',BC 20$			; non	PUSHM.L	D3,D4			; oui	CALL	CALIFLECHE	PUSH.L	D4	LOAD.L	D3,D5	CALL	ORDONNE	CALL	PLMINMAX	POP.L	D4	LOAD.L	D3,D6	CALL	ORDONNE	CALL	PLMINMAX	POPM.L	D3,D420$:	TEST.B	(A4)+OFLEXT:#BFLD4	; flche en D4	JUMP,BC 90$			; non	EX.L	D3,D4			; oui	CALL	CALIFLECHE	EX.L	D3,D4	PUSH.L	D3	LOAD.L	D4,D5	CALL	ORDONNE	CALL	PLMINMAX	POP.L	D3	LOAD.L	D4,D6	CALL	ORDONNE	CALL	PLMINMAX	JUMP	90$50$:				; FLECHE EXTERIEURE =>				; flche  deux droites (forme en "V") =>				; ou  trois droites (forme en triangle)	TEST.B	(A4)+OFLEXT:#BFLD3	JUMP',BC 60$	PUSHM.L	D3,D4	CALL	CALEFLECHE	PUSH.L	D4	LOAD.L	D3,D5	CALL	ORDONNE	CALL	PLMINMAX	POP.L	D4	PUSH.L	D4	LOAD.L	D3,D6	CALL	ORDONNE	CALL	PLMINMAX	POP.L	D4	LOAD.L	D3,D0	CALL	ORDONNE	CALL	PLMINMAX	POPM.L	D3,D460$:	TEST.B	(A4)+OFLEXT:#BFLD4	JUMP',BC 90$	EX.L	D3,D4	CALL	CALEFLECHE	EX.L	D3,D4	PUSH.L	D3	LOAD.L	D4,D5	CALL	ORDONNE	CALL	PLMINMAX	POP.L	D3	PUSH.L	D3	LOAD.L	D4,D6	CALL	ORDONNE	CALL	PLMINMAX	POP.L	D3	LOAD.L	D4,D0	CALL	ORDONNE	CALL	PLMINMAX90$:	LOAD.L	D3,D1		; D3 <-- (Ymin;Xmin)	LOAD.L	D4,D2		; D4 <-- (Ymax;Xmax)	CLR.W	D7	POPM.L	D0..D2,D5,D6,A4	RET;^^=================== fin routines donnant la place occupe par le PLAN;--------\; SWMO    >;========/; Met la flche de la souris et attente.; in	-; out	-; mod	-SWMO:	PUSHM.L	D4,D7	TSET.B	(A5)+OFLAGS:#BWMOUSE	JUMP',BS 90$	CLR.W	D4	LIB	?WAITMOUSE90$:	POPM.L	D4,D7	RET;--------\; CWMO    >;========/; Remet la flche normale de la souris.; in	-; out	-; mod	-CWMO:	PUSHM.L	D4,D7	TCLR.B	(A5)+OFLAGS:#BWMOUSE	JUMP',BC 90$	LOAD.W	D4,#1	LIB	?WAITMOUSE90$:	POPM.L	D4,D7	RET	.END