		.SBTTL	PLANASCALE		; 28 juin 87 Sp.						; 4 appels;--------\\; SCASEG  >;========/;--------\\; SCASURF >;========/;-----------\\; SCAELLIPSE >;===========/; Modifie l'chelle d'un segment de droite, rectangle, etc.; in	D3.L	coordonne de dpart;	D4.L	coordonne d'arrive; out	D3.L	coordonne de dpart;	D4.L	coordonne d'arrive; mod	D3.L, D4.LSCASEG:SCASURF:SCAELLIPSE:	CALL	D4SCALE		; D4 <-- modifie selon l'chelle	EX.L	D4,D3	CALL	D4SCALE		; D3 <-- modifie selon l'chelle	EX.L	D3,D4	RET;----------\\; SCACERCLE >;==========/; Modifie l'chelle d'un cercle ou d'un arc de cercle.; in	D3.W	rayon;	D4.L	coordonne centre; out	D3.W	rayon;	D4.L	coordonne centre; mod	D3.W, D4.LSCACERCLE:	SWAP.W	D3	PUSH.W	D3		; stack <-- arcs	SWAP.W	D3	EX.L	D4,D3	CALL	D4SCALE		; D3 <-- modifie selon l'chelle	EX.L	D3,D4	SWAP.W	D3	POP.W	D3		; D3 <-- remet arcs idem	SWAP.W	D3	CALL	D4SCALE		; D4 <-- modifie selon l'chelle	RET;--------\\; SCATEXT >;========/; Modifie l'chelle d'un caractre.; in	D4.L	coordonne centre; out	D4.L	coordonne centre; mod	D4.L;SCATEXT:;	CALL	D4SCALE		; D4 <-- modifie selon l'chelle;	RET;--------------- _PLANA_D4SCALE:;---------------;*);--------\\; D4SCALE >;--------/; Ajuste un couple (Y;X) selon l'chelle.; in	D4.L	couple (Y;X);	A5.L	^variables PLANA; out	D4.L	couple (Y;X) selon l'chelle; mod	D4.LD4SCALE:	PUSHM.L	D2,D3	LOAD.W	D2,(A5)+OSCALE	; D2 <-- chelle	JUMP',EQ 90$		; pas d'chelle => 90$	JUMP',NS 50$		; chelle ngative => 50$				; chelle positive =>	LOAD.L	D3,D4	MUL.WA	D4,D2		; D4 <-- X selon l'chelle	SWAP.W	D3	MUL.WA	D3,D2		; D3 <-- Y selon l'chelle	JUMP'	60$50$:	NEG.W	D2		; D2 <-- |chelle|	LOAD.W	D3,D4	CONV.LA.WA D3		; D3 <-- tend le signe	DIV.WA	D3,D2		; D3 <-- X selon l'chelle	EX.L	D4,D3	SWAP.W	D3	CONV.LA.WA D3		; D3 <-- tend le signe	DIV.WA	D3,D2		; D3 <-- Y selon l'chelle60$:	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- couple (Y;X)	SWAP.W	D490$:	POPM.L	D2,D3	RET; Gestion du "clipping" des objets graphiques; -------------------------------------------;--------\; CLIPARC >;========/; Vrifie si une partie risque d'tre visible.; in	D4.L	coordonne centre;	D3.L	rayon et arcs  dessiner;	D1.B	mode du trait; out	D4.L	coordonne centre;	D7.W	clipping total; mod	D4.L, D7.WCLIPARC:	PUSHM.L	D2,D3	LOAD.W	D2,D3	SWAP.W	D3	LOAD.W	D3,D2		; D3 <-- rayons (2x le mme)	CALL	CLIPELLIPSE	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RET;------------\; CLIPELLIPSE >;============/; Vrifie si une ellipse risque d'tre visible.; in	D4.L	coordonne centre;	D3.L	rayons;	D1.B	mode du trait;	A5.L	^variables PLANA; out	D4.L	coordonne centre;	D7.W	clipping total; mod	D4.L, D7.WCLIPELLIPSE:	PUSHM.L	D0,D1,D3	LOAD.W	D7,#1		; D7 <-- hors fentre	LOAD.L	D0,D4		; D0 <-- centre X	ADD.W	D0,D3		; D0 <-- extrme droite cercle	LOAD.W	D1,(A5)+OOWDOX	; D1 <-- extrme gauche fentre	COMP.W	D1,D0	JUMP',GE 90$	SUB.W	D0,D3	SUB.W	D0,D3		; D0 <-- extrme gauche cercle	ADD.W	D1,(A5)+OSWDOX	; D1 <-- extrme droite fentre	JUMP',LT 90$	SWAP.W	D0		; D0 <-- centre Y	SWAP.W	D3		; D3 <-- rayon Y	ADD.W	D0,D3		; D0 <-- extrme haut cercle	LOAD.W	D1,(A5)+OOWDOY	; D1 <-- extrme bas fentre	COMP.W	D1,D0	JUMP',GE 90$	SUB.W	D0,D3	SUB.W	D0,D3		; D0 <-- extrme bas cercle	ADD.W	D1,(A5)+OSWDOY	; D1 <-- extrme haut fentre	JUMP',LT 90$	CALL	D4CLIP	CLR.W	D7		; D7 <-- qq chose dans fentre90$:	POPM.L	D0,D1,D3	TEST.W	D7		; retour EQ/NE	RET;----------\; CLIPRECT  >;==========/; Cadre un rectangle pour qu'il entre dans la fentre virtuelle.; Ne le diminue pas  cause des coins arrondis !; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos; out	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D7.W	clipping total; mod	D3.L, D4.L, D7.WCLIPRECT:	CALL	ORDONNE		; D3 <-- min,  D4 <-- max	CALL	D4CLIP	EX.L	D4,D3	CALL	D4CLIP	EX.L	D3,D4	CLR.W	D7		; D7 <-- qq chose dans fentre	RET;----------\; CLIPSURF  >;==========/; Diminue ventuellement une surface pour qu'elle entre; dans la fentre virtuelle.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	A5.L	^variables PLANA; out	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D7.W	clipping total; mod	D3.L, D4.L, D7.WCLIPSURF:	PUSHM.L	D0,D1,D2	CALL	ORDONNE		; D3 <-- min,  D4 <-- max	LOAD.W	D0,(A5)+OOWDOX	; D0 <-- bas fentre	COMP.W	D3,D0		; coin inf. trop bas ?	JUMP',HS 10$		; non => 10$	LOAD.W	D3,D0		; oui => remonte10$:	ADD.W	D0,(A5)+OSWDOX	; D0 <-- haut fentre	COMP.W	D4,D0		; coin sup. trop haut ?	JUMP',LO 15$		; non => 15$	LOAD.W	D4,D0		; oui => descend15$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,(A5)+OOWDOY	; D0 <-- gauche fentre	COMP.W	D3,D0		; coin inf. trop  gauche ?	JUMP',HS 20$		; non => 20$	LOAD.W	D3,D0		; oui => avance20$:	ADD.W	D0,(A5)+OSWDOY	; D0 <-- droite fentre	COMP.W	D4,D0		; coin sup. trop  droite ?	JUMP',LO 25$		; non => 25$	LOAD.W	D4,D0		; oui => recule25$:	SWAP.W	D4	SWAP.W	D3	LOAD.W	D7,#1		; D7 <-- clipping total	COMP.W	D3,D4		; D3  gauche de D4 ?	JUMP',GE 90$		; non => 90$	LOAD.L	D1,D3	LOAD.L	D2,D4	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,D2		; D3 en dessous de D4 ?	JUMP',GE 90$		; non => 90$	CALL	D4CLIP	EX.L	D4,D3	CALL	D4CLIP	EX.L	D3,D4	CLR.W	D7		; D7 <-- qq chose dans fentre90$:	POPM.L	D0,D1,D2	TEST.W	D7		; retour EQ/NE	RET;----------\; CLIPTEXT  >;==========/;; Vrifie si un caractre entre dans la fentre virtuelle.; S'il doit tre tronqu (mme un p'tit peu), on ne dessine; rien du tout.;; in	D3.L	gnrateur + caractre	| 'N | 'R | 12 | code |;	D4.L	coordonne du "centre"; out	D4.L	coordonne du "centre";	D7.W	clipping total; mod	D4.L, D7.W;;CLIPTEXT:;	PUSHM.L	D3,A0;;	CALL	SRCPGC		; tente utilisation gencar.;;;;	JUMP',NE 90$		; si pas possible => 90$;	JUMP,EQ	70$;;	LOAD.L	A0,(A5)+OPDDIS	; si pas possible genc par dfaut;	LOAD.L	D3,D4		; D3 <-- "centre" caractre;	SUB.W	D3,(A0)+ODFC1X;	SWAP.W	D3;	SUB.W	D3,(A0)+ODFC2Y	; D3 <-- "coin" inf. gauche;	SWAP.W	D3;	CALL	IPOINT		; coin dans fentre ?;	JUMP,NE	90$		; non => 90$;				; oui =>;	LOAD.L	D3,D4		; D3 <-- "centre" caractre;	ADD.W	D3,(A0)+ODFC2X;	SWAP.W	D3;	ADD.W	D3,(A0)+ODFC1Y	; D3 <-- "coin" sup. droite;	SWAP.W	D3;	CALL	IPOINT		; coin dans fentre ?;	JUMP,NE	90$		; non => 90$;				; oui =>;	CALL	D4CLIP;	JUMP	90$;;70$:				; ok =>;	LOAD.L	D3,D4		; D3 <-- "centre" caractre;	SUB.W	D3,(A0)+OGC1X;	SWAP.W	D3;	SUB.W	D3,(A0)+OGC2Y	; D3 <-- "coin" inf. gauche;	SWAP.W	D3;	CALL	IPOINT		; coin dans fentre ?;	JUMP,NE	90$		; non => 90$;				; oui =>;	LOAD.L	D3,D4		; D3 <-- "centre" caractre;	ADD.W	D3,(A0)+OGC2X;	SWAP.W	D3;	ADD.W	D3,(A0)+OGC1Y	; D3 <-- "coin" sup. droite;	SWAP.W	D3;	CALL	IPOINT		; coin dans fentre ?;	JUMP,NE	90$		; non => 90$;				; oui =>;	CALL	D4CLIP;90$:;	POPM.L	D3,A0;	TEST.W	D7		; retour EQ/NE;	RET;-----------\; CLIPFLECHE >;===========/; Met une flche dans la fentre virtuelle.; in	D3.L	P(y;x) droite;	D4.L	P(y;x) droite;	D1.B	mode du trait; out	D3.L	P(y;x) droite;	D4.L	P(y;x) droite;	D7.W	clipping total; mod	D3.L, D4,L, D7.WCLIPFLECHE:	CALL	D4CLIP	EX.L	D4,D3	CALL	D4CLIP	EX.L	D3,D4	CLR.W	D7	RET;--------\; CLIPSEG >;========/; Raccourci ventuellement les deux extrmits d'une droite; pour qu'elle entre dans la fentre virtuelle.; in	D3.L	P(y;x) droite;	D4.L	P(y;x) droite;	D1.B	mode du trait; out	D3.L	P(y;x) droite;	D4.L	P(y;x) droite;	D7.W	clipping total; mod	D3.L, D4,L, D7.WCLIPSEG:	PUSHM.L	D1,D2	EX.L	D4,D3	CALL	IPOINT		; D4 dans fentre ?	EX.L	D3,D4	JUMP',NE 50$		; non => 50$				; oui =>	CALL	IPOINT		; D3 dans fentre ?	JUMP',EQ 90$		; oui => 90$				; non => D3-hors et D4-dans	CALL	ISEGZO	LOAD.L	D3,D1		; D3 <-- sur le cadre	JUMP'	90$50$:	CALL	IPOINT		; D3 dans fentre ?	JUMP',NE 70$		; non => 70$				; oui => D3-dans et D4-hors	CALL	ISEGZO	LOAD.L	D4,D1		; D4 <-- sur le cadre	JUMP'	90$70$:				; D3-hors et D4-hors :	CALL	ISEGZO	LOAD.L	D3,D1		; D3 <-- sur le cadre	LOAD.L	D4,D2		; D4 <-- sur le cadre90$:	CALL	D4CLIP	EX.L	D4,D3	CALL	D4CLIP	EX.L	D3,D4	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;--------\; ISEGZO  >;--------/; Calcul les points d'intersections (0, 1 ou 2) entre une; droite et la fentre virtuelle constitue de deux segments; horizontaux et deux verticaux (rectangle).; in	D3.L	P(y;x) droite quelconque;	D4.L	P(y;x) droite quelconque;	A5.L	^variables PLANA; out	D1.L	P(y;x) 1re intersection (zro si rien);	D2.L	P(y;x) 2me intersection (zro si rien);	D7.W	zro  =>  trouv un ou deux points;		autre =>  rien trouv; mod	D1.L, D2.L, D7.WISEGZO:	PUSHM.L	D0,D5	LOAD.W	D1,(A5)+OOWDOY	LOAD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	LOAD.W	D1,(A5)+OOWDOX	LOAD.W	D2,D1	ADD.W	D2,(A5)+OSWDOX	PUSH.L	#0	CALL	ISEGHO		; coupe ligne suprieure ?	JUMP',NE 10$		; non => 10$	LOAD.L	(SP),D010$:	LOAD.W	D1,(A5)+OOWDOY	ADD.W	D1,(A5)+OSWDOY	LOAD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	LOAD.W	D1,(A5)+OOWDOX	LOAD.W	D2,D1	ADD.W	D2,(A5)+OSWDOX	PUSH.L	#0	CALL	ISEGHO		; coupe ligne infrieure ?	JUMP',NE 20$		; non => 20$	LOAD.L	(SP),D020$:	LOAD.W	D1,(A5)+OOWDOY	LOAD.W	D2,D1	ADD.W	D2,(A5)+OSWDOY	SWAP.W	D1	SWAP.W	D2	LOAD.W	D1,(A5)+OOWDOX	LOAD.W	D2,D1	PUSH.L	#0	CALL	ISEGVE		; coupe ligne gauche ?	JUMP',NE 30$		; non => 30$	LOAD.L	(SP),D030$:	LOAD.W	D1,(A5)+OOWDOY	LOAD.W	D2,D1	ADD.W	D2,(A5)+OSWDOY	SWAP.W	D1	SWAP.W	D2	LOAD.W	D1,(A5)+OOWDOX	ADD.W	D1,(A5)+OSWDOX	LOAD.W	D2,D1	PUSH.L	#0	CALL	ISEGVE		; coupe ligne droite ?	JUMP',NE 40$		; non => 40$	LOAD.L	(SP),D040$:	CLR.L	D1	CLR.L	D2	LOAD.B	D5,#4+1		; 4 x PUSH.L	LOAD.W	D7,#1		; D7 <-- rien trouv50$:	DEC.B	D5	JUMP',EQ 90$	POP.L	D1		; D1 <-- 1er point valide	JUMP,EQ	50$	CLR.W	D7		; D7 <-- trouv qq chose60$:	DEC.B	D5	JUMP',EQ 90$	POP.L	D2		; D2 <-- 2me point valide	JUMP,EQ	60$70$:	DEC.B	D5	JUMP',EQ 90$	POP.L	D0		; POP.L bidon	JUMP	70$90$:	POPM.L	D0,D5	TEST.W	D7		; retour EQ/NE	RET;--------\; ISEGVE  >;--------/; Test si un segment de droite quelconque interrompt un; segment de droite vertical.; in	D1.L	P1(y;x) droite verticale;	D2.L	P2(y;x) droite verticale;	D3.L	P3(y;x) droite quelconque;	D4.L	P4(y;x) droite quelconque; out	D0.L	P(y;x) intersection;	D7.W	zro  => intersection;		autre => pas d'intersection; mod	D0.L, D7.WISEGVE:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	CALL	ISEGHO		; intersection segment horiz.	SWAP.W	D4	SWAP.W	D3	SWAP.W	D2	SWAP.W	D1	SWAP.W	D0	TEST.W	D7		; retour EQ/NE	RET;--------\; ISEGHO  >;--------/; Test si un segment de droite quelconque interrompt un; segment de droite horizontal.; La formule suivante donne le point d'intersection en X :;;	    (Y1-Y3)*(X3-X4);	X = --------------- + X3;	        (Y3-Y4); in	D1.L	P1(y;x) droite horizontale;	D2.L	P2(y;x) droite horizontale;	D3.L	P3(y;x) droite quelconque;	D4.L	P4(y;x) droite quelconque; out	D0.L	P(y;x) intersection;	D7.W	zro  => intersection;		autre => pas d'intersection; mod	D0.L, D7.WISEGHO:	PUSHM.L	D1,D2,D3,D4,D5	LOAD.W	D7,#1		; D7 <-- pas d'intersection	COMP.W	D1,D2		; P1  gauche de P2 ?	JUMP',LO 10$		; oui => 10$	EX.L	D1,D2		; met  P1 X-----------X P210$:	LOAD.W	D0,D3	SUB.W	D0,D4		; D0 <-- (X3-X4)	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4		; P3 en dessous de P4 ?	JUMP',LO 20$		; oui => 20$	EX.L	D3,D4		; met P3 en dessous de P4	NEG.W	D0		; ajuste (X3-X4) !20$:	COMP.W	D1,D3		; horizontale trop basse ?	JUMP',LO 90$		; oui => 90$	COMP.W	D2,D4		; horizontale trop haute ?	JUMP',HI 90$		; oui => 90$	LOAD.W	D5,D1	SUB.W	D5,D3		; D5 <-- (Y1-Y3)	MUL.WA	D5,D0		; D5 <-- (a) = (Y1-Y3)*(X3-X4)	LOAD.W	D0,D3	SUB.W	D0,D4		; D0 <-- (Y3-Y4)	JUMP',EQ 90$	DIV.WA	D5,D0		; D5 <-- (a)/(Y3-Y4)	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	ADD.W	D5,D3		; D5 <-- X = (a)/(Y3-Y4)+X3	COMP.W	D5,D1		; horizontale  droite ?	JUMP',LO 90$		; oui => 90$	COMP.W	D5,D2		; horizontale  gauche ?	JUMP',HI 90$		; oui => 90$	SWAP.W	D1	SWAP.W	D5	LOAD.W	D5,D1	SWAP.W	D5	LOAD.L	D0,D5		; D0 <-- point d'intersection	CLR.W	D7		; D7 <-- intersection90$:	POPM.L	D1,D2,D3,D4,D5	TEST.W	D7		; retour EQ/NE	RET;-------------- _PLANA_IPOINT:;--------------;*);--------\; IPOINT  >;--------/; Test si un point est dans la fentre virtuelle.; in	D3.L	P(y;x) quelconque;	A5.L	^variables PLANA; out	D7.W	zro  => dans fentre;		autre => hors fentre; mod	D7.WIPOINT:	PUSHM.L	D0,D3	LOAD.W	D7,#1		; D7 <-- hors fentre	LOAD.W	D0,(A5)+OOWDOX	; D0 <-- bas fentre	COMP.W	D3,D0	JUMP',LO 90$	ADD.W	D0,(A5)+OSWDOX	; D0 <-- haut fentre	COMP.W	D3,D0	JUMP',HI 90$	SWAP.W	D3	LOAD.W	D0,(A5)+OOWDOY	; D0 <-- gauche fentre	COMP.W	D3,D0	JUMP',LO 90$	ADD.W	D0,(A5)+OSWDOY	; D0 <-- droite fentre	COMP.W	D3,D0	JUMP',HI 90$	CLR.W	D7		; D7 <-- dans fentre90$:	POPM.L	D0,D3	TEST.W	D7		; retour EQ/NE	RET;-------------- _PLANA_D4CLIP:;--------------;*);--------\; D4CLIP  >;--------/; Ramne dans la fentre juste un point.; in	D4.L	coordonne (y;x);	A5.L	^variables PLANA; out	D4.L	coordonne (y;x); mod	D4.LD4CLIP:	SUB.W	D4,(A5)+OOWDOX	SWAP.W	D4	SUB.W	D4,(A5)+OOWDOY	SWAP.W	D4	RET;--------------- _PLANA_ORDONNE:;---------------;*);--------\; ORDONNE >;========/; Ordonne D3.L et D4.L pour les dtections.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche; out	D3.L	coordonne coin suprieur gauche (inf. gauche);	D4.L	coordonne coin infrieur droite (sup. droite); mod	D3.L, D4.LORDONNE:	PUSH.W	D0	COMP.W	D3,D4		; D3 < D4 ?	JUMP',LO 20$		; oui => 20$	LOAD.W	D0,D3		; non =>	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D020$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4		; D3 < D4 ?	JUMP',LO 40$		; oui => 40$	LOAD.W	D0,D3		; non =>	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D040$:	SWAP.W	D3	SWAP.W	D4	POP.W	D0	RET;--------\\; XMSCALE  >;========/; Change l'chelle en fonction de la zone montre avec; la souris.; in	D3.L	coordonne d'un coin;	D4.L	coordonne autre coin; out	-; mod	D7.WXMSCALE:	PUSHM.L	D1,D2,D3,D4	CALL	ORDONNE		; D3 <-- coin inf/gauche	SUB.W	D4,D3		; D4 <-- largeur	JUMP,EQ	90$	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur	JUMP,EQ	90$	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A5)+OOWDOY,D3	; init nouvelle origine	COMP.W	D4,(A5)+OLWDOX	JUMP',HI 20$	CLR.L	D1	LOAD.W	D1,(A5)+OLWDOX	DIV.WU	D1,D4		; D1 <-- chelle n:1 en X	JUMP'	22$20$:	CLR.L	D1	LOAD.W	D1,D4	DIV.WU	D1,(A5)+OLWDOX	INC.W	D1	NEG.W	D1		; D1 <-- chelle 1:n en X22$:	SWAP.W	D4	COMP.W	D4,(A5)+OLWDOY	JUMP',HI 25$	CLR.L	D2	LOAD.W	D2,(A5)+OLWDOY	DIV.WU	D2,D4		; D2 <-- chelle n:1 en Y	JUMP'	27$25$:	CLR.L	D2	LOAD.W	D2,D4	DIV.WU	D2,(A5)+OLWDOY	INC.W	D2	NEG.W	D2		; D2 <-- chelle 1:n en Y27$:	SWAP.W	D4	COMP.W	D2,D1	JUMP',LE 30$	LOAD.W	D2,D1		; D2 <-- agrandissement le plus petit30$:	CLR.W	D1		; D1 <-- 1:1	COMP.W	D2,#+1	JUMP',EQ 35$	COMP.W	D2,#-1	JUMP',EQ 35$	LOAD.W	D1,D2		; D1 <-- n:1 ou 1:n35$:	LOAD.W	(A5)+OSCALE,D1	CALL	XNEWSCALE	; nouvelle chelle	LOAD.W	D3,(A5)+OSWDOX	; D3 <-- largeur visible	SUB.W	D3,D4		; D3 <-- largeur "en trop"	JUMP',NS 40$	SR.W	D3,#1		; D3 <-- 1/2  gauche et 1/2  droite	SUB.W	(A5)+OOWDOX,D3	; centre soigneusement en X	JUMP',NC 40$	CLR.W	(A5)+OOWDOX40$:	SWAP.W	D4	LOAD.W	D3,(A5)+OSWDOY	; D3 <-- hauteur visible	SUB.W	D3,D4		; D3 <-- hauteur "en trop"	JUMP',NS 45$	SR.W	D3,#1		; D3 <-- 1/2 en haut et 1/2 en bas	SUB.W	(A5)+OOWDOY,D3	; centre soigneusement en Y	JUMP',NC 45$	CLR.W	(A5)+OOWDOY45$:	CALL	XAJOWDO		; ajuste origine visible;;;;	CALL	EFFACE		; efface tout;;;;	CALL	REFAIT		; puis redessine90$:	POPM.L	D1,D2,D3,D4	RET;---------\\; XNEWSCALE >;=========/; On doit appeler cette routine chaque fois que l'chelle; a t change.; in	-; out	-; mod	-XNEWSCALE:	PUSH.L	D4	LOAD.W	D4,(A5)+OSCALE	COMP.W	D4,#MAXSCALE	; chelle trop grande ?	JUMP',LE 10$	LOAD.W	D4,#MAXSCALE10$:	COMP.W	D4,#-MAXSCALE	; chelle trop petite ?	JUMP',GE 20$	LOAD.W	D4,#-MAXSCALE20$:	LOAD.W	(A5)+OSCALE,D4	LOAD.L	D4,(A5)+OLWDOY	; D4 <-- dim fentre physique	PUSH.W	(A5)+OSCALE	NEG.W	(A5)+OSCALE	; selon l'inverse de l'chelle	CALL	D4SCALE	POP.W	(A5)+OSCALE	LOAD.L	(A5)+OSWDOY,D4	; mj dim selon l'chelle	POP.L	D4	RET;---------\\; XCENSCALE >;=========/; Change l'chelle et centre la fentre par-rapport;  l'ancienne chelle.; in	D4.W	nouvelle chelle; out	-; mod	-XCENSCALE:	PUSHM.L	D0,D1	LOAD.W	D0,(A5)+OSWDOX	LOAD.W	D1,(A5)+OSWDOY	LOAD.W	(A5)+OSCALE,D4	; mj nouvelle chelle	CALL	XNEWSCALE	; calcul nouvelles valeurs	SUB.W	D0,(A5)+OSWDOX	; D0 <-- (old-new)	ASR.W	D0,#1		; D0 <-- (old-new)/2	ADD.W	(A5)+OOWDOX,D0	; avance/recule origine	JUMP',NC 40$	CLR.W	(A5)+OOWDOX40$:	SUB.W	D1,(A5)+OSWDOY	; D1 <-- (old-new)	ASR.W	D1,#1		; D1 <-- (old-new)/2	ADD.W	(A5)+OOWDOY,D1	; avance/recule origine	JUMP',NC 60$	CLR.W	(A5)+OOWDOY60$:	CALL	XAJOWDO		; ajuste origine visible	POPM.L	D0,D1	RET;--------\; XAJMWDO  >;========/; Ajuste les minimums OMWDOX et OMWDOY, afin d'tre; pas trop petits.; in	-; out	-; mod	-XAJMWDO:	COMP.W	(A5)+OMWDOX,#MINWDOX	JUMP',HS 50$	LOAD.W	(A5)+OMWDOX,#MINWDOX50$:	COMP.W	(A5)+OMWDOY,#MINWDOY	JUMP',HS 90$	LOAD.W	(A5)+OMWDOY,#MINWDOY90$:;	CALL	XAJOWDO		; ajuste origine visible;	RET;--------\\; XAJOWDO  >;========/; Ajuste l'origine de la partie visible afin de voir; au moins un bout.; in	-; out	-; mod	-XAJOWDO:	PUSH.L	D4	LOAD.W	D4,(A5)+OMWDOX	SUB.W	D4,(A5)+OSWDOX	JUMP',NC 40$	CLR.W	(A5)+OOWDOX	JUMP'	45$40$:	COMP.W	D4,(A5)+OOWDOX	; origine trop  droite ?	JUMP',GE 45$	LOAD.W	(A5)+OOWDOX,D445$:	LOAD.W	D4,(A5)+OMWDOY	SUB.W	D4,(A5)+OSWDOY	JUMP',NC 60$	CLR.W	(A5)+OOWDOY	JUMP'	65$60$:	COMP.W	D4,(A5)+OOWDOY	; origine trop haute ?	JUMP',GE 65$	LOAD.W	(A5)+OOWDOY,D465$:	LOAD.L	D4,(A5)+OOWDOY;;;;;	CALL	ARRONDI		; arrondi l'origine selon le pas	LOAD.L	(A5)+OOWDOY,D4	POP.L	D4	RET	.END