	.TITLE	PLANA		12 juillet 87 Sp.	; module pour PLAN	.PROC	M680002			; mnmonics CALM 2	.RADIX	10.			; base 10 par dfaut	.HEX				; listing en hexadcima	.REF	SMAKY	.REF	MODULES	.REF	DESSIN	.REF	DOLIB	.REF	PLANA; modifications;; 0.1	- AFPLAN pour START; 0.2	- correction PLANA_DESSINE avec objet horiz./vert.;						rend D4.L ajust !!;	- met trames, pinceaux, flches par dfaut;				avant affichage par AFPLAN (p. START);	- affichage Loupe ngative ds. AFPLAN corrig;	- appel PPLACE PLANA_FONC de nouveau correct; 0.3	- conflict entre OBJTRECT et ARCELL corrig;	- clipping pour Y (p.ex. droite verticale) corrige; 0.4	- DBFLECHE au centre de la fentre;; 0.5	- dcalage caractres dans les bords (CLIPTEXT ds. PLANASCALE) prov.; 0.6	- test couleur visible dans PLANAGRA, dessin avec coul. invisible, rect. zone etc.;	- dcalage car. dans les bords rsolu dfinitivement; 0.7	- 300 genc dans liste du disque; 0.8	- ASKGENC (PLANAGENC): termine avec nouveau genc dans D6;	- _PLANA_AFPLAN (PLANASTART): sauve no. de fentre et restitue  la fin; 0.9	- clipping par driver d'cran depuis systme 5.4;MAJREV	=	0MINREV	=	9	.Rev	MAJREV,MINREV	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; En-tte du module LIB; ---------------------	.LOC	0	PLANA_	FIRST		; code du premier appel	PLANA_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	MAJREV,MINREV	; rvision.version	.W	0,END_PLANA	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"PLANA"		; nom du module	.FILLB	(LGHLIB-.),0	.W	_PLANA_DESSINE		; aiguille selon D0	.W	_PLANA_OPER		; aiguille selon D5	.W	_PLANA_BASE		; aiguille selon OPLANA	.W	_PLANA_FONC		; aiguille selon OPLANA	.W	_PLANA_YINVERSE		; inverse coord. Y	.W	_PLANA_D4SCALE		; rend D4 'scaled'	.W	_PLANA_IPOINT		; teste si point ds. zone	.W	_PLANA_D4CLIP		; 'clipping' de D4	.W	_PLANA_ORDONNE		; ordonne D4, D3	.W	_PLANA_AFPLAN		; spcial pour START	.INS	PLANAGRA.ASI	; affichage d'objets	.INS	PLANASCALE.ASI	; scaling & clipping	.INS	PLANAFLECHE.ASI	; flches	.INS	PLANAPEN.ASI	; pinceaux	.INS	PLANATRAME.ASI	; trames	.INS	PLANAGENC.ASI	; genc	.INS	PLANAGCONV.ASI	; car. 100% trame	.INS	PLANABASE.ASI	; base de donnes	.INS	PLANAOPER.ASI	; modifications	.INS	PLANAGROUPE.ASI	; groupe	.INS	PLANAALIGNE.ASI	; aligne	.INS	PLANASTART.ASI	; appel spcial pour START;-------- DEFPTF:;--------; met pinceaux, flches et trames par dfaut; ds. OBUPEN,OBUFLE et OBUTRA;	CALL	DEFFLECHE	CALL	DEFPEN	CALL	DEFTRAME	RET;-------- PROVISOIRE jusqu' l'intgration de PLANIO (?) ITRPTF:;--------	CALL	ITTRAME	CALL	ITPEN	CALL	ITFLECHE	RET;************* _PLANA_BASE:	; aiguille sur les appels de la BASE DE DONNEES;*************	COMP.W	(A5)+OPLANA,#H'8	JUMP',HS GE8$	COMP.W	(A5)+OPLANA,#BFIRBASE	; 0	JUMP,EQ	FIRBASE	COMP.W	(A5)+OPLANA,#BNXTBASE	; 1	JUMP,EQ	NXTBASE	COMP.W	(A5)+OPLANA,#BOPEBASE	; 2	JUMP,EQ	OPEBASE	COMP.W	(A5)+OPLANA,#BCLOBASE	; 3	JUMP,EQ	CLOBASE	COMP.W	(A5)+OPLANA,#BPCLOBASE	; 4	JUMP,EQ	PCLOBASE	COMP.W	(A5)+OPLANA,#BDCLOBASE	; 5	JUMP,EQ	DCLOBASE	COMP.W	(A5)+OPLANA,#BOPMATRIX	; 6	JUMP,EQ	OPMATRIX	COMP.W	(A5)+OPLANA,#BADMATRIX	; 7	JUMP,EQ	ADMATRIX	RETGE8$:	COMP.W	(A5)+OPLANA,#H'8+8	JUMP',HS GE16$	COMP.W	(A5)+OPLANA,#BPREND	; 8+0	JUMP,EQ	PREND	COMP.W	(A5)+OPLANA,#BMET	; 8+1	JUMP,EQ	MET	COMP.W	(A5)+OPLANA,#BAJOUTE	; 8+2	JUMP,EQ	AJOUTE	COMP.W	(A5)+OPLANA,#BIAJOUTE	; 8+3	JUMP,EQ	IAJOUTE	COMP.W	(A5)+OPLANA,#BIENLEVE	; 8+4	JUMP,EQ	IENLEVE	COMP.W	(A5)+OPLANA,#BCLRBASE	; 8+5	JUMP,EQ	CLRBASE	COMP.W	(A5)+OPLANA,#BCLRNEW	; 8+6	JUMP,EQ	CLRNEW	COMP.W	(A5)+OPLANA,#BFDETECTE	; 8+7	JUMP,EQ	FDETECTE	RETGE16$:	COMP.W	(A5)+OPLANA,#BDETECTE	; 8+8+0	JUMP,EQ	DETECTE	COMP.W	(A5)+OPLANA,#BAJDU	; 8+8+1	JUMP,EQ	AJOUTEDU	COMP.W	(A5)+OPLANA,#BAJFU	; 8+8+2	JUMP,EQ	AJOUTEFS	COMP.W	(A5)+OPLANA,#BAJDS	; 8+8+3	JUMP,EQ	AJOUTEDS	COMP.W	(A5)+OPLANA,#BAJFS	; 8+8+4	JUMP,EQ	AJOUTEFS	RET;************* _PLANA_FONC:	; aiguille sur les appels dit de FONCTION;*************	COMP.W	(A5)+OPLANA,#H'8	JUMP',HS GE8$	COMP.W	(A5)+OPLANA,#FCOMPTE	; 0	JUMP,EQ	COMPTE	COMP.W	(A5)+OPLANA,#FAJUSTE	; 1	JUMP,EQ	AJUSTE	COMP.W	(A5)+OPLANA,#FPLACE	; 2	JUMP,EQ	PPLACE	COMP.W	(A5)+OPLANA,#FDBFLECHE	; 3	JUMP,EQ	DBOXFLECHE	COMP.W	(A5)+OPLANA,#FDBPEN	; 4	JUMP,EQ	DBOXPEN	COMP.W	(A5)+OPLANA,#FDBTRAME	; 5	JUMP,EQ	DBOXTRAME	COMP.W	(A5)+OPLANA,#FDBGENC	; 6	JUMP,EQ	ASKGC	COMP.W	(A5)+OPLANA,#FDEFPTF	; 7	JUMP,EQ	DEFPTF	RETGE8$:	COMP.W	(A5)+OPLANA,#H'8+8	JUMP',HS GE16$	COMP.W	(A5)+OPLANA,#FLGCGC	; 8+0	JUMP,EQ	LGCGC	COMP.W	(A5)+OPLANA,#FSRCPGC	; 8+1	JUMP,EQ	SRCPGC	COMP.W	(A5)+OPLANA,#FSPGC1	; 8+2	JUMP,EQ	SRCPGC1	COMP.W	(A5)+OPLANA,#FDEFTRAIT	; 8+3	JUMP,EQ	DEFTRAIT	COMP.W	(A5)+OPLANA,#FREFAIT	; 8+4	JUMP,EQ	REFAIT	COMP.W	(A5)+OPLANA,#FINUZONE	; 8+5	JUMP,EQ	INUZONE;	COMP.W	(A5)+OPLANA,#F		; 8+6;	JUMP,EQ	;	COMP.W	(A5)+OPLANA,#F		; 8+7;	JUMP,EQ	RETGE16$:	COMP.W	(A5)+OPLANA,#H'8+8+8	JUMP',HS GE24$	COMP.W	(A5)+OPLANA,#FIMFLECHE	; 8+8+0	JUMP,EQ	IMFLECHE	COMP.W	(A5)+OPLANA,#FIMPEN	; 8+8+1	JUMP,EQ	IMPEN	COMP.W	(A5)+OPLANA,#FIMTRAME	; 8+8+2	JUMP,EQ	IMTRAME	COMP.W	(A5)+OPLANA,#FIIFLECHE	; 8+8+3	JUMP,EQ	IIFLECHE	COMP.W	(A5)+OPLANA,#FIIPEN	; 8+8+4	JUMP,EQ	IIPEN	COMP.W	(A5)+OPLANA,#FIITRAME	; 8+8+5	JUMP,EQ	IITRAME	COMP.W	(A5)+OPLANA,#FITRPTF	; 8+8+6	JUMP,EQ	ITRPTF;	COMP.W	(A5)+OPLANA,#		; 8+8+6;	JUMP,EQ;	COMP.W	(A5)+OPLANA,#		; 8+8+7;	JUMP,EQ	RETGE24$:	COMP.W	(A5)+OPLANA,#FXNEWSCALE	; 8+8+8+0	JUMP,EQ	XNEWSCALE	COMP.W	(A5)+OPLANA,#FXMSCALE	; 8+8+8+1	JUMP,EQ	XMSCALE	COMP.W	(A5)+OPLANA,#FXCENSCALE	; 8+8+8+2	JUMP,EQ	XCENSCALE	COMP.W	(A5)+OPLANA,#FXAJMWDO	; 8+8+8+3	JUMP,EQ	XAJMWDO	COMP.W	(A5)+OPLANA,#FXAJOWDO	; 8+8+8+4	JUMP,EQ	XAJOWDO	COMP.W	(A5)+OPLANA,#FIFTRAME	; 8+8+8+5	JUMP,EQ	IFTRAME	COMP.W	(A5)+OPLANA,#FIFPEN	; 8+8+8+6	JUMP,EQ	IFPEN	COMP.W	(A5)+OPLANA,#FIFFLECHE	; 8+8+8+7	JUMP,EQ IFFLECHE	RETEND_PLANA:	.END