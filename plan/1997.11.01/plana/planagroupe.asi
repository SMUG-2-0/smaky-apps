	.SBTTL	PLANAGROUPE		; 12 juillet 87 Sp.;--------\; LIE     >;========/; Lie tous les objets dans une zone de recherche.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D0.B	0=utilisateur et 1=systme; out	-; mod	D7.WLIE:	PUSHM.L	D0..D6,A0,A3,A4	LOAD.B	D6,D0		; D6 <-- 0/1 = utilisateur/systme	CALL	ORDONNE	CALL	OPEBASE		; A4 <-- ^nouvel lment	JUMP,NE 90$	LOAD.W	D0,#OBJDUGROUPE	; D0 <-- dbut d'un groupe utilisateur	TEST.B	D6	JUMP,EQ 05$.IF	GROUPETX	COMP.B	D6,#2	JUMP,NE	04$	LOAD.L	A0,#(A5)+OBUTEMP	; A0 ^texte	CALL	GRTEXTE			; crit D0.W + 14 car. depuis ^A0	JUMP	06$04$:.ENDIF	LOAD.W	D0,#OBJDSGROUPE	; D0 <-- dbut d'un groupe systme05$:	PUSHM.L	D3,D4	CLR.W	D1	CLR.W	D2	CLR.L	D3	CLR.L	D4	CALL	MET		; objet <-- dbut de groupe	POPM.L	D3,D4.IF	GROUPETX06$:.ENDIF	TSET.B	(A4)+OMFLAGS:#BMNEW	CALL	FIRBASE		; A4 <-- ^premier lment	CALL	SWMO		; met la souris "en attente"10$:	CALL	DETECTE		; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A3,A4		; A3 <-- ^lment actuel	CALL	NXTBASE		; A4 <-- ^lment suivant	EX.L	A3,A4		; A4 <-- ^act, A3 <-- ^suivant	PUSHM.L	D3,D4,D7	CALL	PREND		; registres <-- objet	CALL	INVMODE		; D2 <-- mode inverse	CALL	DESSINE		; efface l'objet	CALL	INVMODE		; D2 <-- mode normal	CALL	MET		; objet <-- registres	COMP.B	D0,#OBJDUGROUPE	JUMP',EQ 13$		; supprime les dbut/fin de groupes utilisateur	COMP.B	D0,#OBJFUGROUPE	JUMP',EQ 13$	COMP.B	D0,#OBJDSGROUPE	JUMP',EQ 12$		; supprime les dbut/fin de groupes systmes	COMP.B	D0,#OBJFSGROUPE	JUMP',NE 14$12$:	TEST.B	D6		; lie un groupe utilisateur ?	JUMP',EQ 14$		; oui => 14$ (laisse les groupes systmes)13$:.IF	GROUPETX	COMP.B	D6,#2	JUMP,EQ	14$.ENDIF	CALL	PCLOBASE	; supprime l'objet dfinitivement	JUMP'	15$14$:	CALL	CLOBASE		; supprime l'objet	CALL	OPEBASE		; A4 <-- ^nouvel lment	CALL	MET		; objet <-- registres	TSET.B	(A4)+OMFLAGS:#BMNEW	CALL	DESSINE		; redessine l'objet15$:	POPM.L	D3,D4,D7	LOAD.L	A4,A3		; A4 <-- ^lment suivant	TEST.W	D7	JUMP,EQ	10$	JUMP'	80$20$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$80$:	TEST.B	D6	JUMP',NE 82$	CALL	AJOUTEFU	; met une fin de groupe utilisateur	JUMP'	85$82$:.IF	GROUPETX	COMP.B	D6,#2		; avec texte ?	JUMP,NE	84$	CALL	OPEBASE		; A4 ^nouvel lment;;	JUMP,NE	90$	LOAD.W	D0,#OBJFUGROUPE	CALL	GRTEXTE	JUMP	85$	84$:.ENDIF	CALL	AJOUTEFS	; met une fin de groupe systme85$:	CALL	CLRNEW		; ote les bits BMNEW90$:	CALL	CWMO		; remet la souris normale	POPM.L	D0..D6,A0,A3,A4	RET;--------\; DELIE   >;========/; Dlie tous les objets dans une zone de recherche.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D0.B	0=utilisateur et 1=systme; out	-; mod	D7.WDELIE:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	LOAD.B	D6,D0		; D6 <-- 0/1 = utilisateur/systme	CALL	ORDONNE	CALL	FIRBASE		; A4 <-- ^premier lment	JUMP,NE 90$	CALL	SWMO		; met la souris "en attente"10$:	CALL	DETECTE		; dans zone de recherche ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A3,A4		; A3 <-- ^lment actuel	CALL	NXTBASE		; A4 <-- ^lment suivant	EX.L	A3,A4		; A4 <-- ^act, A3 <-- ^suivant	PUSHM.L	D3,D4,D7	CALL	PREND		; registres <-- objet	COMP.B	D0,#OBJDUGROUPE	JUMP',EQ 14$		; supprime les dbut/fin de groupes utilisateur	COMP.B	D0,#OBJFUGROUPE	JUMP',EQ 14$	TEST.B	D6		; dlie un groupe utilisateur ?	JUMP',EQ 15$		; oui => 15$ (laisse les groupes systmes)	COMP.B	D0,#OBJDSGROUPE	JUMP',EQ 14$		; supprime les dbut/fin de groupes systmes	COMP.B	D0,#OBJFSGROUPE	JUMP',NE 15$14$:	CALL	PCLOBASE	; supprime dfinitivement le dbut/fin de groupe15$:	POPM.L	D3,D4,D7	LOAD.L	A4,A3		; A4 <-- ^lment suivant	TEST.W	D7	JUMP,EQ	10$	JUMP'	90$20$:	CALL	NXTBASE		; A4 <-- ^lment suivant	JUMP,EQ	10$90$:	CALL	CWMO		; remet la souris normale	POPM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	RET;---------\\; AJOUTEDU >;=========/; Ajoute un objet de dbut de groupe utilisateur.; in	-; out	D7.W	erreur; mod	D7.WAJOUTEDU:	PUSHM.L	D0..D4	LOAD.W	D0,#OBJDUGROUPE	JUMP'	AJOUTEDFUS;---------\\; AJOUTEFU >;=========/; Ajoute un objet de fin de groupe utilisateur.; in	-; out	D7.W	erreur; mod	D7.WAJOUTEFU:	PUSHM.L	D0..D4	LOAD.W	D0,#OBJFUGROUPE	JUMP'	AJOUTEDFUS;---------\\; AJOUTEDS >;=========/; Ajoute un objet de dbut de groupe systme.; in	-; out	D7.W	erreur; mod	D7.WAJOUTEDS:	PUSHM.L	D0..D4	LOAD.W	D0,#OBJDSGROUPE	JUMP'	AJOUTEDFUS;---------\\; AJOUTEFS >;=========/; Ajoute un objet de fin de groupe.; in	-; out	D7.W	erreur; mod	D7.WAJOUTEFS:	PUSHM.L	D0..D4	LOAD.W	D0,#OBJFSGROUPE;	JUMP'	AJOUTEDFUSAJOUTEDFUS:	CLR.W	D1	CLR.W	D2	CLR.L	D3	CLR.L	D4	CALL	AJOUTE	POPM.L	D0..D4	TEST.W	D7		; retour EQ/NE	RET	.END