	.SBTTL	PLANAGCONV		; 19 juillet 87 Sp.; Dfinition de l'entte d'un gnrateur de caractres; ----------------------------------------------------; OGCNBR	=	H'00		; total number of records; OGCFSN	=	H'02		; font set number; OGCFN		=	H'03		; font number; OGCMSB	=	H'04		; matrix size in bytes; OGCMHD	=	H'06		; matrix height in dots; OGCMWB	=	H'08		; matrix width in bytes; OGCPSI	=	H'09		; point size; OGCFCA	=	H'0A		; ASCII code of first character; OGCLCA	=	H'0B		; ASCII code of last character; OGCLMA	=	H'0C		; left margin of matrix; OGCBLI	=	H'0E		; bottom of matrix to baseline; OGCMH1	=	H'10		; max heigth above baseline; OGCMH2	=	H'12		; max extension under baseline; OGCMWI	=	H'14		; max width (for fixed spacing); OGCISP	=	H'16		; interline space in dots; OGCVSP	=	H'18		; variable spaced; OGCDAT	=	H'1A		; date en BCD jjmmyyyy; OGCPWI	=	H'1E		; ^width; OGCPH1	=	H'20		; ^h1; OGCPH2	=	H'22		; ^h2; OGCPMX	=	H'24		; ^matrix; OGCIDE	=	H'26		; text identifier; OGCTXT	=	H'80		; text; OGCWID	=	H'100		; width;***************** _PLANA_OPMATRIX:;*****************;---------\\; OPMATRIX >;=========/; Cherche les paramtres d'une matrice d'un caractre; sous forme de "points".; in	D4.B		code du caractre;	D6.W	no. genc; out	(A5)+OLGMA.L	dimensions de la matrice (dy;dx);	(A5)+OMAPGC.L	^dbut du gencar;	D7.W		erreur; mod	D7.WOPMATRIX:	PUSHM.L	D2,D3,D4,A0,A1,A2,A3	LOAD.L	A3,#(A5)+OBWRITE	CALL	GGETPGC		; A0 <-- ^gencar	LOAD.L	(A3)+0,(A0)+OGCCOD	LOAD.B	(A3)+0,#USEGC	LOAD.W	D3,#4	LIB	?STRING		; utilise le gencar	JUMP,NE 90$	LOAD.L	A1,(A5)+OPDDIS	; A1 <-- ^descripteur de la fentre	LOAD.L	A1,(A1)+ODFPGC	; A1 <-- ^dbut du gencar	LOAD.W	D7,#ERILCA	; D7 <-- caractre illgal	COMP.B	D4,(A1)+OGCLCA	JUMP',HI 90$	SUB.B	D4,(A1)+OGCFCA	JUMP',LO 90$	AND.W	D4,#H'FF	; D4 <-- offset du caractre	LOAD.W	(A5)+OLGMAY,(A1)+OGCMHD	LOAD.L	A2,#(A1)+OGCWID	; A2 <-- saute header	CLR.W	D2	LOAD.B	D2,(A2)+(D4.W)	; D2 <-- largeur du caractre	LOAD.W	(A5)+OLGMAX,D2	CLR.W	D2	LOAD.B	D2,(A1)+OGCLCA	SUB.B	D2,(A1)+OGCFCA	INC.B	D2		; D2 <-- nb de caractres	ADD.W	A2,D2		; A2 <-- saute largeurs	ADD.W	A2,D2		; A2 <-- saute h1	ADD.W	A2,D2		; A2 <-- saute h2	MUL.WU	D4,(A1)+OGCMSB	ADD.L	A2,D4		; A2 <-- ^matrice du caractre; Transfert la matrice dans OTMIO, car les points qui la constitue; doivent pouvoir tre effacs !	LOAD.W	D7,#ERMFUL	; D7 <-- erreur "mmoire pleine"	LOAD.W	D2,(A1)+OGCMSB	; D2 <-- lg de la matrice	COMP.W	D2,#LTMIO	; matrice trop grande ?	JUMP',HI 90$		; oui => 90$	LOAD.L	A3,#(A5)+OTMIO50$:	LOAD.B	(A3+),(A2+)	DEC.W	D2	JUMP,NE	50$	LOAD.L	(A5)+OMAPGC,A1	; mm. ^dbut du gencar	CLR.W	D7		; D7 <-- ok90$:;;;	CALL	USEDGC		; utilise gencar par dfaut	POPM.L	D2,D3,D4,A0,A1,A2,A3	TEST.W	D7		; retour EQ/NE	RET;***************** _PLANA_ADMATRIX:;*****************;---------\; ADMATRIX >;=========/; Transforme toute une matrice en "points".; in	D6.L	+/- offset;	D2	mode; out	D7.W	erreur; mod	D7.WADMATRIX:	PUSHM.L	D0,D1,D3,D4,A1,A2	CALL	AJOUTEDS	; met un dbut de groupe systme	LOAD.L	A1,(A5)+OMAPGC	; A1 <-- ^gencar	LOAD.L	A2,#(A5)+OTMIO	; A2 <-- ^matrice; Cherche dans l'ordre croissant des surfaces les points.10$:	CALL	MAXBIGDOT	; cherche plus grande surface	JUMP',NE 20$		; pas trouv => 20$	CALL	WRBIGDOT	; crit la surface trouve	JUMP,NE	90$	JUMP	10$; Cherche un par un les points isols (surface=1).20$:	CLR.L	D3		; D3 <-- dbut (Y;X)	LOAD.W	D0,(A5)+OLGMAY	; D0 <-- hauteur en points30$:	LOAD.W	D1,(A5)+OLGMAX	; D1 <-- largeur en points40$:	CALL	TSTMATRIX	JUMP',BC 50$	LOAD.W	D4,#1	SWAP.W	D4	LOAD.W	D4,#1	CALL	WRPDOT	JUMP,NE	90$50$:	INC.W	D3		; avance en X	DEC.W	D1	JUMP,NE	40$	CLR.W	D3		; revient  gauche en X	SWAP.W	D3	INC.W	D3		; descend en Y	SWAP.W	D3	DEC.W	D0	JUMP,NE	30$	CALL	AJOUTEFS	; met une fin de groupe systme	JUMP',NE 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1,D3,D4,A1,A2	TEST.W	D7		; retour EQ/NE	RET;----------\; MAXBIGDOT >;==========/; Cherche la plus grande surface dans toute la matrice.; Les points isols (surface=1) ne sont pas considrs.; in	A1.L	^gencar;	A2.L	^matrice; out	D3.L	coordonne la meilleure;	D4.L	dimensions;	D7.W	erreur (pas trouv); mod	D3.L, D4.L, D7.WMAXBIGDOT:	PUSHM.L	D0,D1,D2,D5,D6	LOAD.L	D2,#1		; D2 <-- maximum trouv	CLR.L	D3		; D3 <-- dbut (Y;X)	LOAD.W	D5,(A5)+OLGMAY	; D5 <-- hauteur en points10$:	LOAD.W	D4,(A5)+OLGMAX	; D4 <-- largeur en points20$:	CALL	TSTMATRIX	JUMP',BC 30$	CALL	SRCBIGDOT	; D0 <-- largeur et D1 <-- hauteur	SWAP.W	D0	LOAD.W	D0,D1		; D0 <-- dimensions (Y;X)	SWAP.W	D0	MUL.WU	D1,D0		; D1 <-- surface	COMP.W	D1,D2		; plus grand que la dernire ?	JUMP',LS 30$		; non => 30$				; oui =>	LOAD.L	D2,D1		; D2 <-- surface maximale	LOAD.L	D6,D3		; D6 <-- coordonne la meilleure	LOAD.L	D7,D0		; D7 <-- dimensions les meilleures30$:	INC.W	D3		; avance en X	DEC.W	D4	JUMP,NE	20$	CLR.W	D3		; revient  gauche en X	SWAP.W	D3	INC.W	D3		; descend en Y	SWAP.W	D3	DEC.W	D5	JUMP,NE	10$	LOAD.L	D3,D6		; D3 <-- meilleure coordonne	LOAD.L	D4,D7		; D4 <-- dimensions	LOAD.W	D7,#1		; D7 <-- pas trouv	DEC.L	D2		; trouv plus d'un seul point ?	JUMP',EQ 90$		; non => 90$				; oui =>	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1,D2,D5,D6	TEST.W	D7		; retour EQ/NE	RET;---------\; WRBIGDOT >;=========/; Essaye de rassembler tous les points d'une zone rectangulaire; en un seul objet graphique.; in	D3.L	coordonne coin suprieur gauche;	D4.L	dimensions;	D6.L	+/- offset;	A1.L	^gencar;	A2.L	^matrice; out	D7.W	erreur; mod	D7.WWRBIGDOT:	PUSHM.L	D0,D1,D2,D3,D4	CALL	WRPDOT		; crit un grand "point"	JUMP,NE	90$; Met  zro tous les "points" trouvs dans la matrice.	LOAD.W	D0,D4		; D0 <-- largeur	SWAP.W	D4	LOAD.W	D1,D4		; D1 <-- hauteur50$:	PUSHM.L	D0,D360$:	CALL	CLRMATRIX	INC.W	D3		; D3 <-- colonne suivante en X	DEC.W	D0	JUMP,NE	60$	POPM.L	D0,D3	SWAP.W	D3	INC.W	D3		; D3 <-- ligne suivante en Y	SWAP.W	D3	DEC.W	D1	JUMP,NE	50$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1,D2,D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\; SRCBIGDOT >;==========/; Essaye de rassembler tous les points d'une zone rectangulaire; en un seul objet graphique.; in	D3.L	coordonne coin suprieur gauche;	A1.L	^gencar;	A2.L	^matrice; out	D0.W	largeur;	D1.W	hauteur; mod	D0.L, D1.LSRCBIGDOT:	PUSHM.L	D2,D3,D4,D5,D6; Calcul le nombre de points allum horizontalement vers la; droite dans D0.W.	CALL	LGLMATRIX	; D0 <-- longueur ligne  droite; Calcul le nombre de ligne de longueur quivalentes allumes; en dessous dans D1.W.	CLR.L	D4		; D4 <-- surface maximale30$:	CALL	LGRMATRIX	; D1 <-- hauteur surface dessous	LOAD.W	D2,D0	MUL.WU	D2,D1		; D2 <-- surface trouve	COMP.L	D2,D4		; plus grande que la dernire ?	JUMP',LO 50$		; non => 50$				; oui =>	LOAD.L	D4,D2		; D4 <-- surface maximale	LOAD.W	D5,D0		; D5 <-- largeur optimale	LOAD.W	D6,D1		; D6 <-- hauteur optimale50$:	DEC.W	D0	JUMP,NE	30$	LOAD.W	D0,D5		; D0 <-- largeur optimale	LOAD.W	D1,D6		; D1 <-- hauteur optimale90$:	POPM.L	D2,D3,D4,D5,D6	RET;----------\; LGRMATRIX >;==========/; Calcul la hauteur d'une surface verticalement vers le bas.; N'utilise pas LGLMATRIX pour tre plus rapide !; in	D3.L	coordonne (Y;X);	D0.W	longueur horizontale;	A1.L	^gencar;	A2.L	^matrice; out	D1.W	hauteur verticale; mod	D1.LLGRMATRIX:	PUSHM.L	D0,D2,D3,D4,D5	LOAD.B	D1,D3	AND.B	D1,#B'111	SUB.B	D1,#8-1	NEG.B	D1		; D1 <-- bit  tester dans byte	SR.W	D3,#3		; D3 <-- X byte	LOAD.W	D2,D3		; D2 <-- offset byte pour X	SWAP.W	D3		; D3 <-- Y	LOAD.W	D5,(A5)+OLGMAY	SUB.W	D5,D3		; D5 <-- hauteur maximale	CLR.W	D4	LOAD.B	D4,(A1)+OGCMWB	MUL.WU	D3,D4		; D3 <-- offset byte pour Y	ADD.W	D2,D3		; D2 <-- offset byte pour X et Y	CLR.W	D3		; D3 <-- calcul la hauteur40$:	PUSHM.W	D0,D1,D250$:	TEST.B	(A2)+(D2.W):D1	; point allum ?	JUMP',BC 60$		; non => 60$	DEC.B	D1		; D1 <-- bit suivant dans byte	JUMP',HS 55$		; si dans mme byte => 55$	LOAD.B	D1,#8-1		; si autre byte =>	INC.W	D2		; D2 <-- offset byte suivant55$:	DEC.W	D0		; fin de la ligne ?	JUMP,NE	50$		; non => 50$	CLRZ			; met BS60$:	POPM.W	D0,D1,D2	JUMP',BC 80$		; si ligne pas toute allume => 80$	ADD.W	D2,D4		; D2 <-- offset dbut ligne suivante	INC.W	D3		; D3 <-- augmente la hauteur trouve	DEC.W	D5		; est-on tout en bas ?	JUMP,NE	40$		; non => 40$80$:	LOAD.W	D1,D3		; D1 <-- hauteur surface	POPM.L	D0,D2,D3,D4,D5	RET;----------\; LGLMATRIX >;==========/; Calcul la longueur d'une ligne horizontalement vers la droite.; N'utilise pas TSTMATRIX pour tre plus rapide !; in	D3.L	coordonne (Y;X);	A1.L	^gencar;	A2.L	^matrice; out	D0.W	longueur de la ligne; mod	D0.LLGLMATRIX:	PUSHM.L	D1,D2,D3,D4,D5	LOAD.W	D5,(A5)+OLGMAX	; D5 <-- largeur matrice	SUB.W	D5,D3		; D5 <-- lg maximale ligne	LOAD.B	D1,D3	AND.B	D1,#B'111	SUB.B	D1,#8-1	NEG.B	D1		; D1 <-- bit  tester dans byte	SR.W	D3,#3		; D3 <-- X byte	LOAD.W	D2,D3		; D2 <-- offset byte pour X	SWAP.W	D3		; D3 <-- Y	CLR.W	D4	LOAD.B	D4,(A1)+OGCMWB	MUL.WU	D3,D4		; D3 <-- offset byte pour Y	ADD.W	D2,D3		; D2 <-- offset byte pour X et Y	CLR.W	D0		; D0 <-- calcul de la longueur50$:	TEST.B	(A2)+(D2.W):D1	; point allum ?	JUMP',BC 90$		; non => 90$	INC.W	D0		; D0 <-- un point allum de plus	DEC.B	D1		; D1 <-- bit suivant dans byte	JUMP',HS 60$		; si dans mme byte => 60$	LOAD.B	D1,#8-1		; si autre byte =>	INC.W	D2		; D2 <-- offset byte suivant60$:	DEC.W	D5		; fin de la ligne ?	JUMP,NE	50$		; non => 50$90$:	POPM.L	D1,D2,D3,D4,D5	RET;----------\; TSTMATRIX >;==========/; Test un point dans la matrice.; in	D3.L	coordonne (Y;X);	A1.L	^gencar;	A2.L	^matrice; out	BS/BC	tat du point; mod	-TSTMATRIX:	PUSHM.L	D0,D1,D3,D4	LOAD.B	D1,D3	AND.B	D1,#B'111	SUB.B	D1,#8-1	NEG.B	D1		; D1 <-- bit  tester dans byte	SR.W	D3,#3		; D3 <-- X byte	LOAD.W	D0,D3		; D0 <-- offset byte pour X	SWAP.W	D3		; D3 <-- Y	CLR.W	D4	LOAD.B	D4,(A1)+OGCMWB	MUL.WU	D3,D4		; D3 <-- offset byte pour Y	ADD.W	D0,D3		; D0 <-- offset byte pour X et Y	TEST.B	(A2)+(D0.W):D1	POPM.L	D0,D1,D3,D4	RET;----------\; CLRMATRIX >;==========/; Enlve un point dans la matrice.; in	D3.L	coordonne (Y;X);	A1.L	^gencar;	A2.L	^matrice; out	-; mod	-CLRMATRIX:	PUSHM.L	D0,D1,D3,D4	LOAD.B	D1,D3	AND.B	D1,#B'111	SUB.B	D1,#8-1	NEG.B	D1		; D1 <-- bit  tester dans byte	SR.W	D3,#3		; D3 <-- X byte	LOAD.W	D0,D3		; D0 <-- offset byte pour X	SWAP.W	D3		; D3 <-- Y	CLR.W	D4	LOAD.B	D4,(A1)+OGCMWB	MUL.WU	D3,D4		; D3 <-- offset byte pour Y	ADD.W	D0,D3		; D0 <-- offset byte pour X et Y	TCLR.B	(A2)+(D0.W):D1	POPM.L	D0,D1,D3,D4	RET;--------\; WRPDOT  >;========/; Ecrit un "point" sous la forme d'une trame  100%.; in	D3.L	coin suprieur gauche (Y;X);	D4.L	dimensions (dY;dX);	D6.L	+/- offset; out	D7.W	erreur; mod	D7.WWRPDOT:	PUSHM.L	D0,D1,D2,D3,D4	LOAD.W	D0,#OBJSURF	; D0 <-- objet surface;;;?;	LOAD.W	D2,(A5)+OMODE	; D2 <-- mode/couleur de dessin	LOAD.B	D1,#TRM100	; D1 <-- trame 100%	ADD.W	D4,D3		; D4 <-- arrive X	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3		; D4 <-- arrive Y	SUB.W	D3,(A5)+OLGMAY	NEG.W	D3		; D3 <-- inverse le sens de Y	SUB.W	D4,(A5)+OLGMAY	NEG.W	D4		; D4 <-- inverse le sens de Y	SWAP.W	D3	SWAP.W	D4	CALL	AJUSTE		; ajuste selon l'offset	CALL	AJOUTE		; ajoute dans base de donne	JUMP',NE 90$	CALL	DESSINE		; montre l'objet ajout90$:	POPM.L	D0,D1,D2,D3,D4	TEST.W	D7		; retour EQ/NE	RET	.END