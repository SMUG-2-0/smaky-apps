	.SBTTL	PLANINFO;.PROC	M680002;.REF	SMAKY;.REF	MODULES;.REF	PLANA;.REF	PLANB;.REF	MATH32; routines pour afficher des informations selon les objets; dans une fentre dynamique;;FP_RADEG =	H'8EF34D3B	; 1 deg = 0.01745 rad pour MATH32 (INFO);FP_RAGRAD =	H'80A7C63B	; 1 grad = 0.015705 rad;FP_10	=	H'A0000044	; 10 FP;FP_100	=	H'C8000047	; 100 FP;FP_1000=	H'FA00004A	; 1000 FP;FP_10EN3 =	H'83126F37	; 1/1000;FP_10EN2 =	H'A3D70A3A	; 1/100;FP_10EN1 =	H'CCCCCD3D	; 1/10;FP_25	=	H'C8000045	; 25 FP;; OFLINFO:	.BLKB	1	; flag 'INFO' (fentre informations);  BINFO  =	0		;  1= afficher 'INFO' (flag dfinitions);  BINFOR =	1		;  1= afficher 'INFO' (bouton gauche et droite);  BINFOA =	2		;  1= 'INFO' allume;OUNITE:		.BLKB	1	; no. units longueur bits 0..3, angle 4..7; UPG	=	0	; longueurs; UMM	=	1; UCM	=	2; UM	=	3; UDEG	=	0	; angles; URAD	=	1; UGRA	=	2; UPCNT	=	3;	.EVEN;OECHELLE:	.BLKW	1	; chelle *1000;OREF:		.BLKB	1	; point de rfrence pour INFO;	.EVEN;OTYPO1:	.BLKB	4;OTYPO2:	.BLKB	4;OLDPOS:	.BLKB	4;; exemple; DROITE:;  WHILE bouton droite press DO;	IF bouton droite THEN BINFOR = 1 ELSE BINFOR = 0;	 IF BINFO = 1 THEN BINFOR = 1;		IF NOT BFIRST THEN;			- I_INFO (effacer v.);			- effacer ancien objet;		ELSE;			- dessine nouvel objet;			- I_INFO (rafficher ou bouger);			- afficher paramtres;		ENDIF;	 ENDIF;	ENDIF;  END WHILE;;	- BINFOR = 0;	- I_INFO (effacer);	- efface ancien objet;	- ajoute objet ds. la base;	- dessine objet dfinitif; FIN DROITE;;;======== I_INFO:;========; IF BINFOR = 1 AND BINFOA = 0 THEN M_INFO	(si pas affich, alors affiche); EXIT; ENDIF; IF BINFOR = 1 AND BINFOA = 1 THEN T_INFO?	(si affich ...;	IF BTOUCH = 1 THEN C_INFO ENDIF		... et touch, alors effacer...;	IF BTOUCH = 0 THEN M_INFO ENDIF		... sinon bouger); EXIT; ENDIF; IF BINFOR = 0 AND BINFOA = 1 THEN C_INFO	( si affich et pas demand, alors teindre); EXIT; ENDIF; IF BINFOR = 0 AND BINFOA = 0 THEN EXIT; ENDIF; END I_INFO;; in	D3.L,D4.L	coord. point dpart, point arrive (PLAN);	OFLINFO		flags de 'INFO'; out	fentre ou pas fentre, c'est la question; mod;	PUSHM.L	D3,D4,D7test.b	(a6)+OPLANAV+OFLAGS:#BINFOD	; affichage dynamique BINFO ?JUMP,BC	90$				; non					; oui	TEST.B	(A6)+OFLINFO:#BINFOR	; 'INFO' demand ?	JUMP,BC	50$			; non => 50$	TEST.B	(A6)+OFLINFO:#BINFOA	; 'INFO' allume ?	JUMP',BS 30$			; oui => 30$20$:call	ccmo	CALL	M_INFO			; bouger ...call	info_droite	JUMP'	90$30$:				; objet touch ?	CALL	T_INFO	JUMP',NE 20$			; non => 20$;	JUMP'	50$50$:				; effacer si allum	TEST.B	(A6)+OFLINFO:#BINFOA	JUMP,BC	90$	CALL	C_INFOcall	scmo;	JUMP	90$90$:	POPM.L	D3,D4,D7	RET;------ M_INFO:;------; move 'INFO'; bouge et affiche selon objet;; affiche la 'fentre' INFO et calcule les curseurs pour afficher l'information;; in:	D4	coordonnes plan yy;xx ; out:	OTYPO1, OTYPO2, 'fentre' INFO; mod:	D7.W; BPPX	= 0 BPPY	= 1;	PUSHM.L	D0,D1,D2,D3,D4,D6,A2	SUB.W	D4,(A6)+OPLANAV+OOWDOX	; clip	SWAP.W	D4	SUB.W	D4,(A6)+OPLANAV+OOWDOY	SWAP.W	D4	PLANA_	D4SCALE			; scale	PLANA_	YINVERSE		; inverse Y	ADD.W	D4,(A6)+OPLANAV+OMINX	; offset X	SWAP.W	D4	ADD.W	D4,(a6)+OPLANAV+OMINY	; offset Y	SWAP.W	D4add.l	D4,#1*H'10000+1				; initialisations	LOAD.L	A2,(A6)+OPLANAV+OPDDIS		; descripteur de la fentre	CLR.L	D1			; no. du lutin INFO	LOAD.L	D3,(A6)+OPLANAV+OMAXY	SUB.L	D3,#DY_INFO*H'10000+DX_INFO	; Ymax./Xmax. admissible				; dterminer sommet de rfrence;;;??	SUB.W	D4,(A6)+OPLANAV+OOWDOX		; coordonnes physiques xx	COMP.W	D4,D3			; plus petit que max. X	JUMP,LO	5$			; oui --> 5$	TSET.L	D1:#BPPX		; non... HD ou BDLOAD.W	D4,(A6)+OPLANAV+OMAXX		; D4 <-- X max.5$:	SWAP.W	D4	SWAP.W	D3;;;??	SUB.W	D4,(A6)+OPLANAV+OOWDOY		; coordonnes physiques yy	COMP.W	D4,D3			; plus petit que max. Y	JUMP,LO	10$			; oui --> 10$	TSET.L	D1:#BPPY		; non... BG ou BDLOAD.W	D4,(A6)+OPLANAV+OMAXY		; D4 <-- Y max.10$:	COMP.B	D1,(A6)+OREF		; mme sommet qu'avant ?	JUMP,EQ	20$			; oui --> 20$	LOAD.B	D6,(A6)+OREF		; non...	LOAD.W	D0,#SPRITE_CLEAR	; ...effacer l'ancien	.W	GRA_SPRITE;;	CALL	ERREUR	LOAD.B	(A6)+OREF,D1		; sauver le nouveau REF20$:				; calculer les coordonnes selon OREF	SWAP.W	D4	LOAD.B	D0,D1	JUMP',EQ 60$			; --> REF_HG	COMP.B	D1,#REF_HD		; REF_HD ?	JUMP',NE 30$	SUB.W	D4,#DX_INFO		; oui ...	JUMP'	60$30$:	SUB.L	D4,#DY_INFO*H'10000	COMP.B	D1,#REF_BG		; REF_BG ?	JUMP',EQ 60$			; oui ...	SUB.W	D4,#DX_INFO		; REF_BD;	JUMP'	60$60$:	LOAD.W	D6,D1			; no. du lutin REF_x	LOAD.W	D0,#SPRITE_MOVE	.W	GRA_SPRITE;;	CALL	ERREUREX.L	D3,D4				; dessine un rectangle autourLOAD.L	D4,#(DY_INFO-2)*H'10000+(DX_INFO-2)LOAD.W	D2,#INVDOTLIB	?DRRECTEX.L	D3,D4				; pos. OTYPO1	ADD.L	D4,#10*H'10000+7	; (yy+13;xx+4)	LOAD.L	(A6)+OTYPO1,D4				; pos. OTYPO2	ADD.L	D4,#8*H'10000		; (yy+13+8;xx+4)	LOAD.L	(A6)+OTYPO2,D4	TSET.B	(A6)+OFLINFO:#BINFOA	; met 'allum'	POPM.L	D0,D1,D2,D3,D4,D6,A2	RET;------ C_INFO:;------; clear 'INFO'; efface; in	-; mod	-; out	D7	PUSHM.L	D0,D6,A2	LOAD.L	A2,(A6)+OPLANAV+OPDDIS		; descripteur de la fentre	LOAD.B	D6,(A6)+OREF		; no. du lutin en cours	JUMP,NS	90$	LOAD.W	D0,#SPRITE_CLEAR	; efface	.W	GRA_SPRITE;;	CALL	ERREUR90$:	TCLR.B	(A6)+OFLINFO:#BINFOA	; met 'teint'	POPM.L	D0,D6,A2	TEST.W	D7	RET;------ T_INFO:;------; touch 'INFO' ?; teste si objet touch ?	LOAD.W	D7,#1	TEST.W	D7	RET;--------- REL_INFO:;---------;  la fin: libre les lutins pour la 'fentre' INFO; in	-; mod	-; out	D7	PUSHM.L	D0,D6,A2	TEST.B	(A6)+OREF	JUMP,NS	90$	LOAD.L	A2,(A6)+OPLANAV+OPDDIS		; descripteur de la fentre	LOAD.W	D0,#SPRITE_CLOSE	LOAD.B	D6,#REF_HG10$:	.W	GRA_SPRITE	INC.B	D6	COMP.B	D6,#REF_BG+1	JUMP,NE	10$	LOAD.B	(A6)+OREF,#-1		; plus de lutin90$:	POPM.L	D0,D6,A2	TEST.W	D7	RET;---------- INIT_INFO:;----------; initialise les lutins pour affichage de l'information  la saisie; (les lutins sont initialiss et enlev immdiatement); REF_HG	= 0	; no. coin en haut  gauche REF_HD	= 1 REF_BG	= 2 REF_BD	= 3 DX_INFO	= 10*8+1	; dimensions des lutins INFO DY_INFO	= 22+1;; in	D4	position souris yy;xx; out	-; mod	D7	PUSHM.L	D0,D3,D4,D6,A2,A3,A4	LOAD.L	D4,#0;;;;	LOAD.B	(A6)+OREF,#-1	LOAD.L	A2,(A6)+OPLANAV+OPDDIS		; descripteur de la fentre	LOAD.L	D3,#(DY_INFO-1)*H'10000+(DX_INFO-1) ; dimension du lutin;;;;	LOAD.L	A3,#R16"FREF		; fond partout identiqueload.l	A3,#0	LOAD.W	D6,#REF_HG		; no. HG;;;??	LOAD.L	A4,#R16"TREF_HG		; trame positive du lutinload.l	a4,#r16"FREF	CALL	80$	LOAD.W	D6,#REF_HD		; no. HD;;;??	LOAD.L	A4,#R16"TREF_HD		; trame positive du lutin	CALL	80$	LOAD.W	D6,#REF_BG		; no. BG;;;??	LOAD.L	A4,#R16"TREF_BG		; trame positive du lutin	CALL	80$	LOAD.W	D6,#REF_BD		; no. BD;;;??	LOAD.L	A4,#R16"TREF_BD		; trame positive du lutin	CALL	80$	POPM.L	D0,D3,D4,D6,A2,A3,A4	TEST.W	D7	RET80$:	LOAD.W	D0,#SPRITE_OPEN	GRA_	SPRITE			;;	CALL	ERREUR	LOAD.W	D0,#SPRITE_CLEAR	GRA_	SPRITE			;;	CALL	ERREUR	RETNICHT = 1.IF	~NICHT; --- rect. avec ref HGTREF_HG:;TINFO:	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00	.B	H'7F H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00	.B	H'40 H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'41 H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'43 H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'47 H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'4F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'5F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00.EVENTREF_HD:	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'FE	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'02	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'82	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'C2	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'E2	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'F2	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FA	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00.EVENTREF_BD:	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FA	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'F2	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'E2	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'C2	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'82	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'02	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'FE	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00.EVENTREF_BG:	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'3F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'5F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'4F H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'47 H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'43 H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'41 H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'40 H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FC	.B	H'7F H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00	.B	H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00 H'00.EVENLREF:;FTINFO:;	.B	H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF	.B	