 H'FF H'FF H'FF H'FF	.B	H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF	.B	H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF	.B	H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF	.B	H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF	.B	H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF	.B	H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF	.B	H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF	.B	H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF H'FF.EVEN;---------- fin;???????????????????????????;--------AFF_INFO:		;  faire en fonction des objets !!!!;--------; affiche les informations dans 'fentre' INFO en fonction de l'objet; in	D3.L	paramtre;	D4.L	paramtre; out	-; mod	D7	erreur	PUSHM.L	D0,D2,D3,D4	LOAD.L	D3,(A6)+OLDPOS	; a-t-on boug ?	test	COMP.L	D3,D4		;			test	JUMP,EQ	80$		; non ...		test	LOAD.L	(A6)+OLDPOS,D4	;			test;?????	CALL	MOVE_INFO	; oui, affiche nouvelle INFO	LIB	?IFMOUSE	LOAD.L	D3,(A6)+OLDPOS	; bouge-t-on encore ?	test	COMP.L	D3,D4		;			test	JUMP,NE	80$		; oui ...		test	LOAD.L	(A6)+OLDPOS,D4	;			test;LOAD.L	D3,#339*H'10000+638;LOAD.L	D3,#170*H'10000+320CLR.L	D3	CALL	INFO_DROITE	; longueur et angle80$:	POPM.L	D0,D2,D3,D4	TEST.W	D7	RET;??????????????????;------------ INFO_DROITE:;------------; calcule et affiche la longueur et l'angle d'une droite;; in	D3.L	point de dpart;	D4.L	point d'arrive; out	- affiche longueur [SQR(dxx^2+dyy^2)]  la position OTYPO1;	- affiche l'angle  la position OTYPO2; mod	D7	PUSHM.L	D1..D6CALL	USEPAGClib	?Aftim.B	AFINV.B	0.EVENPLANA_	ORDONNE		; D3 <-- coin sup. gauche; D4 inf. droite			; longueur	SUB.W	D4,D3		; D4 <-- dxx	LOAD.W	D1,D4		; D1 <-- dxx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dyy	LOAD.W	D2,D4		; D2 <-- dyy	AND.L	D4,#H'0000FFFF	.W	MATH32_IFP	; D4 <-- dyy FP;;	ERREUR	LOAD.L	D2,D4		; D2 <-- dyy FP	LOAD.L	D4,D1		; D4 <-- dxx	AND.L	D4,#H'0000FFFF	.W	MATH32_IFP	; D4 <-- dxx FP;;	ERREUR	LOAD.L	D1,D4		; D1 <-- dxx FP	LOAD.L	D3,D4		; D3 <-- dxx FP	.W	MATH32_MUL	; D4 <-- dxx^2 FP;;	ERREUR	LOAD.L	D5,D4		; D5 <-- dxx^2 FP	LOAD.L	D3,D2		; D3 <-- dyy FP	LOAD.L	D4,D2		; D4 <-- dyy FP	.W	MATH32_MUL	; D4 <-- dyy^2 FP;;	ERREUR	LOAD.L	D3,D5		; D3 <-- dxx^2 FP	.W	MATH32_ADD	; D4 <-- dxx^2+dyy^2 FP;;	ERREUR	.W	MATH32_SQR	; D4 <-- SQR(dxx^2+dyy^2) FP;;	ERREUR	LOAD.L	D3,(A6)+OTYPO1	CALL	AFFP_LONG	; affiche  la pos. OTYPO1	LOAD.L	D3,(A6)+OTYPO2	CALL	AFFP_ANGLE	; affiche angle  la pos. OTYPO2CALL	USEDGClib	?aftim.B	AFDIR.B	0.EVENCALL	_CARCAD	POPM.L	D1..D6	TEST.W	D7	RET;------------ AFFP_ANGLE:;------------; affiche l'angle selon units slctionnes; in	D1.L	dxx;	D2.L	dyy;	D3.L	curseur typographique; out	-; mod	D7	PUSHM.L	D0..D5,A3,A4	LOAD.L	D0,D3		; sauve curseur typo	LOAD.B	D5,(A6)+OUNITE	SR.B	D5,#4	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE	LOAD.L	A4,A3			; angle D1 <-- dxx FP; D2 <-- Dyy FP	LOAD.L	D3,D1		; D3 <-- dxx FP	LOAD.L	D4,D2		; D4 <-- dyy FP	.W	MATH32_DIV	; D4 <-- dxx/dyy;;	ERREUR	COMP.B	D5,#UPCNT	; pourcents ?	JUMP,NE	5$		; non --> 5$	COMP.L	D1,#0	JUMP,NE	0$	LOAD.L	A3,#R16"TINFINI	JUMP	70$0$:	LOAD.L	D3,#FP_100	.W	MATH32_MUL;;	ERREUR	JUMP	11$5$:	COMP.L	D2,#0		; si ddy=0 alors afficher 0	JUMP',NE 6$	LOAD.L	A3,#R16"TZERO	JUMP	70$6$:	.W	MATH32_ARCTAN	; D4 <-- angle en radians;;	ERREUR	COMP.B	D5,#URAD	; radians ?	JUMP,EQ	60$		; oui --> 60$	LOAD.L	D3,#FP_RADEG	COMP.B	D5,#UGRA	; grad ?	JUMP,NE	10$		; non ...	LOAD.L	D3,#FP_RAGRAD	; oui10$:	.W	MATH32_DIV	; D4 <-- degrs ou grad;;	ERREUR11$:	.W	MATH32_FPA;;	ERREUR	LOAD.L	D3,#-2	.W	MATH32_ARND;;	ERREUR	.W	MATH32_INGUS;;	ERREUR	CLR.L	D3	LOAD.B	D3,#1		; 1 dcimales	SWAP.W	D3		; bits 16..23	LOAD.B	D3,#7		; 8 signes en sortie	TSET.L	D3:#BMAPRO	; arrondi mathmatique	.W	MATH32_FORM;;	ERREUR70$:	LOAD.L	D3,D0	LIB	?SETCURS	; affiche  OTYPO2	LIB	?AFTEXT	COMP.B	D5,#URAD	JUMP,NE	45$	LIB	?AFTIM	.ASCIZE	/ rad/	JUMP	90$45$:	COMP.B	D5,#UDEG	JUMP,NE	40$	LIB	?AFTIM	.ASCIZE	/ deg/	JUMP	90$40$:	COMP.B	D5,#UPCNT	JUMP,NE	55$	LIB	?AFTIM	.ASCIZE	/  %/	JUMP	90$55$:				; grad	LIB	?AFTIM	.ASCIZE	/grad/90$:	POPM.L	D0..D5,A3,A4	RET60$:	.W	MATH32_FPA	; radians;;	ERREUR;	LOAD.L	D3,#-2;	.W	MATH32_ARND;;	ERREUR	.W	MATH32_INGUS;;	ERREUR	CLR.L	D3	LOAD.B	D3,#3		; 7 dcimales	SWAP.W	D3		; bits 16..23	LOAD.B	D3,#7		; 9 signes en sortie	TSET.L	D3:#BMAPRO	; arrondi mathmatique	.W	MATH32_FORM;;	ERREUR	JUMP	70$TINFINI:	.ASCIZE	/ infini/TZERO:	.ASCIZE	/    0.0/;---------- AFFP_LONG:;----------; affiche la longueur selon chelle et unit slctionne; in	D4	FP en units pg;	D3	curseur typographique; out	-; mod	D7	erreur	PUSHM.L	D1,D3,D4,D5,A3,A4,A5	LOAD.L	D1,D3	LOAD.B	D5,(A6)+OUNITE	; ajuster  l'unit	AND.B	D5,#H'0F	LOAD.L	A5,#R16"TUPG	LOAD.W	D3,#-2		; magnitude	COMP.B	D5,#UPG		; pg ?	JUMP,EQ	50$		; oui --> PG$LOAD.L	D3,#FP_64MATH32_	MULLOAD.L	D3,D4LOAD.W	D4,(A6)+OF64XAND.L	D4,#H'FFFFMATH32_	IFPEX.L	D3,D4MATH32_	DIV;???	LOAD.L	D3,#FP_25		; non --> D4*25;???	.W	MATH32_MUL	; * rsolution;;	ERREUR	LOAD.L	D3,D4	LOAD.W	D4,(A6)+OECHELLE	; D4 <-- D4*Echelle	AND.L	D4,#H'0000FFFF	.W	MATH32_IFP;;	ERREUR	EX.L	D3,D4	.W	MATH32_DIV;;	ERREUR	LOAD.L	D3,#FP_1000	; correction pour rsolution et chelle	.W	MATH32_MUL	; * 1000/1000;	.W	MATH32_DIV	LOAD.L	A5,#R16"TUMM	LOAD.W	D3,#-4	COMP.B	D5,#UMM		; mm ?	JUMP,EQ	50$		; oui --> 50$	LOAD.L	A5,#R16"TUCM	; non ...	LOAD.L	D3,#FP_10	.W	MATH32_DIV;;	ERREUR	LOAD.W	D3,#-4		; magnitude pour arrondi	COMP.B	D5,#UCM		; cm ?	JUMP,EQ	50$		; oui --> 50$	LOAD.L	A5,#R16"TUM	; non, alors m	LOAD.L	D3,#FP_100	.W	MATH32_DIV;;	ERREUR	LOAD.L	D3,#-4		; magnitude pour arrondi50$:	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE	LOAD.L	A4,A3	.W	MATH32_FPA;;	ERREUR	.W	MATH32_ARND;;	ERREUR	.W	MATH32_INGUS;;	ERREUR	CLR.L	D3	LOAD.L	D3,#1		; 1 dcimale pour pg	COMP.B	D5,#UPG	JUMP,EQ	60$	LOAD.L	D3,#3		; 3 dcimales pour mm, cm, m60$:	SWAP.W	D3		; bits 16..23	LOAD.B	D3,#9		; max. 9 signes en sortie	TSET.L	D3:#BMAPRO	; arrondi mathmatique	.W	MATH32_FORM;;	ERREUR	LOAD.L	D3,D1	LIB	?SETCURS	; affiche ...	LIB	?AFTEXT	LOAD.L	A3,A5	LOAD.W	D3,#2	LIB	?STRING	POPM.L	D1,D3,D4,D5,A3,A4,A5	RETTUPG:	.ASCIZE	/pg/TUMM:	.ASCIZE	/mm/TUCM:	.ASCIZE	/cm/TUM:	.ASCIZE	/m /	.END