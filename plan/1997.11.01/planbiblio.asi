 	.SBTTL	PLANBIBLIO	; utilisation de bibliothques de symboles avec PLAN	; janvier 1988 Sp.;--------- BOUTPUT:;=========;; sauve une zone de recherche dans une BIBLIO;;	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche; out	D7.W	erreur; mod	D7.W;	PUSHM.L	D0..D6,A0..A5				; SAUVE UNE ZONE ds. BIBLIO =>	LOAD.W	(A6)+OCHIO,(A6)+OPLANBV+OBCHBIB ; init pour criture (WROPEN)	CLR.W	(A6)+OPLANAV+OPTIO;;;	CALL	ORDONNE		; D3 <-- sup-g.  D4 <-- inf-d.	.W	PLANA_ORDONNE	LOAD.L	D6,D3		; D6 <-- offset correctif	NEG.W	D6	SWAP.W	D6	NEG.W	D6	SWAP.W	D6	EX.L	D4,D6	CALL	OARRONDI	; arrondi l'offset	EX.L	D6,D4	LOAD.W	D0,D4	SUB.W	D0,D3		; D0 <-- <dxx>	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,D4	SUB.W	D0,D3		; D0 <-- <dyy>	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	CALL	DBOUTPUT	; crit le premier objet BIBLIO	JUMP,NE	90$	CALL	BTOUTPUT	; crit des dfinitions de trames utilises	JUMP,NE	90$	CALL	BPOUTPUT	; crit des dfinitions de pinceaux utiliss	JUMP,NE	90$	CALL	BGOUTPUT	; crit des dfinitions de gencars utiliss	JUMP,NE	90$	CALL	BFOUTPUT	; crit des dfinitions de flches utilises	JUMP,NE	90$20$:;;;	CALL	FIRBASE		; A4 <-- ^premier lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE	.W	PLANA_BASE	JUMP',NE 45$30$:;;;	CALL	DETECTE		; dans zone de recherche ?	LOAD.W	(A6)+OPLANAV+OPLANA,#BDETECTE	.W	PLANA_BASE	JUMP,NE 40$		; non => 40$				; oui =>	PUSHM.L	D3,D4,A4	CALL	COPYBT		; A4 <-- ^objet dans buf. temp.;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	LOAD.B	(A6)+OPLANAV+ORCOIN,#-1	; tous les coins trouvs;;;	CALL	AJUSTE		; ajuste selon l'offset	LOAD.W	(A6)+OPLANAV+OPLANA,#FAJUSTE	.W	PLANA_FONC;;;	CALL	MET		; objet <-- registres	LOAD.W	(A6)+OPLANAV+OPLANA,#BMET	.W	PLANA_BASE	CALL	OUTPUT		; crit un objet	POPM.L	D3,D4,A4	JUMP,NE	90$40$:;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP,EQ	30$45$:				; crire la fin BIBLIO	CALL	FBOUTPUT	JUMP,NE	90$				; ferme fichier de sortie	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	LOAD.L	A4,#(A6)+OPLANAV+OTMIO	; A4 <-- ^buffer tampon	CLR.L	D4	LOAD.W	D4,(A6)+OPLANAV+OPTIO	; D4 <-- nb bytes dans buffer	JUMP',EQ 60$		; si vide => 50$				; si reste qq chose =>	FOS	?WRBYTE		; crit tout le solde du buffer60$:;;;?	FOS	?CLOSE		; ne ferme pas le fichier !!!90$:	CALL	CWMO		; remet la souris normale	CALL	IOERROR		; affiche erreur si ncessaire	POPM.L	D0..D6,A0..A5	TEST.W	D7		; retour EQ/NE	RET;---------- BGOUTPUT:;----------;; Ecrit les dfinitions des gencars utiliss.;; in	-; out	D7.W	erreur; mod	D7.W;	PUSHM.L	D0,D2,D3,D4,A0	LOAD.L	A0,#(A6)+OPLANAV+OBUGC	; A0 <-- ^buffer des gencars	LOAD.W	D0,#MAXGC	CLR.W	D7		; D7 <-- ok10$:	TEST.B	(A0)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BC 30$		; non => 30$				; oui =>	LOAD.L	D2,(A0)+OGCCOD	; D2 <-- "fst-"	SL.L	D2,#8	CALL	IFGENC		; utilise ?	JUMP,NE	30$		; non				; oui	CALL	G1OUTPUT	; crit df. gencar	JUMP',NE 90$30$:	LOAD.L	A0,#(A0)+LGGC	; A0 <-- ^suivant	DEC.W	D0	JUMP,NE	10$	CLR.W	D790$:	POPM.L	D0,D2,D3,D4,A0	TEST.W	D7		; retour EQ/NE	RET;-------- IFGENC:;========;; Cherche si un genc est utilis dans une zone.;; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D1.B	numro trame cherche; out	D7.W	trouv ou pas; mod	D7.W;	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A4	LOAD.L	D6,D2		; D6 <-- genc "fst-"	PLANA_	ORDONNE;;;	CALL	FIRBASE		; A4 <-- ^premier lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE	.W	PLANA_BASE	JUMP,NE	90$10$:;;;	CALL	FDETECTE		; dans zone de recherche ?	LOAD.W	(A6)+OPLANAV+OPLANA,#BFDETECTE	.W	PLANA_BASE	JUMP',NE 20$		; non => 20$				; oui =>	PUSHM.L	D3,D4;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	POPM.L	D3,D4	COMP.B	D0,#OBJTEXT	; caractre ?	JUMP',NE 20$		; non => 20$	LOAD.L	D5,(A4)+OMPAR1	CLR.B	D5	COMP.L	D5,D6		; est-ce le gencar ?	JUMP',EQ 90$		; oui => 90$20$:;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP,EQ	10$90$:	POPM.L	D0,D1,D2,D3,D4,D5,D6,A4	TEST.W	D7		; retour EQ/NE	RET;---------- FBOUTPUT:;==========;; Ecrit l'objet fin de groupe BIBLIO;; in	D0.L	dimensions du plan (dy;dx); out	D7.W	erreur; mod	D7.W;	PUSHM.L	D1,A4	LOAD.L	A4,#(A6)+OBUIO+LGELEMENT	LOAD.B	D1,#LGELEMENT20$:	CLR.B	(-A4)		; OBUIO <-- rempli de zro	DEC.B	D1	JUMP,NE	20$	LOAD.B	(A4)+OMOBJET+1,#OBJFBIBLIO90$:	CALL	OUTPUT		; crit le premier objet	POPM.L	D1,A4	TEST.W	D7		; retour EQ/NE	RET;---------- DBOUTPUT:;==========;; Ecrit l'objet dbut de groupe BIBLIO;; in	D0.L	dimensions du plan (dy;dx); out	D7.W	erreur; mod	D7.W;	PUSHM.L	D1,A4	LOAD.L	A4,#(A6)+OBUIO+LGELEMENT	LOAD.B	D1,#LGELEMENT20$:	CLR.B	(-A4)		; OBUIO <-- rempli de zro	DEC.B	D1	JUMP,NE	20$	LOAD.B	(A4)+OMOBJET+1,#OBJDBIBLIO	LOAD.L	(A4)+OMRES,(A6)+OF64Y	LOAD.L	(A4)+OMPAR2,D090$:	CALL	OUTPUT		; crit le premier objet	POPM.L	D1,A4	TEST.W	D7		; retour EQ/NE	RET;---------- BTOUTPUT:;----------;; crit les dfinitons des trames utilises;;	PUSHM.L	D1,D2	CLR.W	D1			; <-- trame20$:	COMP.W	D1,#TRMMAX		; max. ?	JUMP,EQ	90$			; oui => 90$	LOAD.W	(A6)+OPLANAV+OPLANA,#FIFTRAME ; trame utilise	PLANA_	FONC	JUMP,NE	30$			; non ...	LOAD.W	D2,D1	CALL	T1OUTPUT	JUMP,NE	90$30$:	INC.W	D1			; ... suivante	JUMP	20$90$:	POPM.L	D1,D2	RET;---------- BPOUTPUT:;----------;; crit les dfinitons des pinceaux utilises;;	PUSHM.L	D1,D2	CLR.W	D1			; <-- pinceau20$:	COMP.W	D1,#PENMAX		; max. ?	JUMP,EQ	90$			; oui => 90$	LOAD.W	(A6)+OPLANAV+OPLANA,#FIFPEN ; pinceau utilis	PLANA_	FONC	JUMP,NE	30$			; non ...	LOAD.W	D2,D1	CALL	P1OUTPUT	JUMP,NE	90$30$:	INC.W	D1			; ... suivante	JUMP	20$90$:	POPM.L	D1,D2	RET;---------- BFOUTPUT:;----------;; crit les dfinitons des trames utilises;;	PUSHM.L	D1,D2	CLR.W	D1			; <-- flche20$:	COMP.W	D1,#FLEMAX		; max. ?	JUMP,EQ	90$			; oui => 90$	LOAD.W	(A6)+OPLANAV+OPLANA,#FIFFLECHE ; flche utilise	PLANA_	FONC	JUMP,NE	30$			; non ...	LOAD.W	D2,D1	CALL	F1OUTPUT	JUMP,NE	90$30$:	INC.W	D1			; ... suivante	JUMP	20$90$:	POPM.L	D1,D2	RET;----------- BIBAJOUTE:;-----------;; ajoute un lment de la BIBLIO au PLAN;	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	TCLR.B	(a6)+OFLIO:#BIOBGC		; init	LOAD.W	(A6)+OCHIO,(A6)+OPLANBV+OBCHBIB ; init pour lecture	LOAD.W	(A6)+OPLANAV+OPTIO,#LTMIO	LOAD.L	A4,#(A6)+OBUIO	CALL	INPUT		; lit le premier objet;;;??	JUMP,NE	41$	LOAD.W	D7,#ERPLI	LOAD.L	D4,(A4)+OMPAR2	COMP.W	D4,(A6)+OPLANAV+OMWDOX	; plus grand que PLAN ?	JUMP,HS	90$	SWAP.W	D4	COMP.W	D4,(A6)+OPLANAV+OMWDOY	JUMP,HS	90$	CLR.W	D7; Ajoute le plan  une position variable en fonction de la souris.52$:	LIB	?IFMOUSE	; D4 <-- position de la souris	CALL	CONVCMO		; D4 <-- position dans le plan	LOAD.L	D3,D4		; D3 <-- coin inf/gauche	ADD.W	D3,(A4)+OMPAR2+OXX	SWAP.W	D3	ADD.W	D3,(A4)+OMPAR2+OYY	SWAP.W	D3	LOAD.B	D2,#MODINV	; D2 <-- mode inverse	CLR.W	D1		; D1 <-- type de trait fin	CALL	TRECTANGLE	; dessine le rectangle dlimiteur	LOAD.L	D6,D4		; D6 <-- offset coin sup/droite	LOAD.L	D5,D3		; D5 <-- offset coin inf/gauche	CALL	SETFILTRE	; filtre tout ce qui existe dj	CALL	CWMO		; remet la souris normale	CALL	CCMO		; supprime flche souris	CALL	IOWAIT		; affiche "attendez..."	CALL	TINPUT		; lit dfinitions de trames	JUMP,NE	70$	CALL	PINPUT		; lit dfinitions de pinceaux	JUMP,NE	70$	CALL	GINPUT		; lit dfinitions de gencars	JUMP,NE	70$		; continue, mme si inexistant etc.	CALL	FINPUT		; lit dfinitions de flches	JUMP',NE 70$	JUMP'	65$60$:	LOAD.L	A4,#(A6)+OBUIO	; A4 <-- ^buffer temporaire	CALL	INPUT		; lit un objet	JUMP',NE 70$;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	comp.b	d0,#OBJDBIBLIO	; fini ?	jump,eq	70$		; oui	comp.b	d0,#OBJFBIBLIO	jump,eq	70$		; oui65$:	COMP.B	(A4)+OMOBJET,#-1 ; ignore objets de df.	JUMP',EQ 60$	COMP.B	D0,#OBJDBIBLIO	JUMP,EQ	70$	COMP.B	D0,#OBJFBIBLIO	JUMP,EQ	70$	CALL	IFLDGC		; charge gencar si ncessaire	LOAD.B	(A6)+OPLANAV+ORCOIN,#-1	; tous les coins trouvs;;;	CALL	AJUSTE		; ajuste selon l'offset	LOAD.W	(A6)+OPLANAV+OPLANA,#FAJUSTE	.W	PLANA_FONC;;;	CALL	ITTRAME		; translate si trame;;;	CALL	ITPEN		; translate si pinceau;;;	CALL	ITFLECHE	; translate si flche	LOAD.W	(A6)+OPLANAV+OPLANA,#FITRPTF	.W	PLANA_FONC;;;	CALL	MET		; objet <-- registres	LOAD.W	(A6)+OPLANAV+OPLANA,#BMET	.W	PLANA_BASE;;;	CALL	OPEBASE		; A4 <-- ^nouvel lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BOPEBASE	.W	PLANA_BASE	JUMP',NE 70$	CALL	COPYTB		; base donne <-- buffer temp.;;;	CALL	DESSINE		; dessine l'objet	.W	PLANA_DESSINE	JUMP,NC	60$70$:	CALL	SCMO		; remet flche souris;;;;;;	COMP.W	D7,#EROUTF		??????!!!!!!!!!!!!!!!!;;;;;;	JUMP,NE	90$	CALL	AFCMES		; affiche centr	.ASCII	" "	.B	USEGC,GCICF,GCICS,GCICT	.B	7,96,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" place |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,97,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" met/enlve PAS |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,98,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZE	" inactif "	LOAD.L	D4,D6		; D4 <-- coin inf/gauche	LOAD.L	D3,D5		; D3 <-- coin sup/droite;;;;;;;	CALL	XINLIE		; lie/dlie selon D1	TCLR.B	(A6)+OFLAGF:#BMPDES	LOAD.W	(A6)+OMOVOP,#1	; attend bouton press	CALL	MOVZONE		; dplace zone rectangulaire;;;	CALL	DEPLACE		; dplace la surface	PUSH.B	D5	LOAD.B	D5,#1	.W	PLANA_OPER	POP.B	D5	LOAD.W	D7,#ERBGC	TEST.B	(A6)+OFLIO:#BIOBGC ; mauvais gencar lu ?	JUMP',BS 90$		; oui => 90$	CLR.W	D790$:95$:	CALL	CWMO		; remet la souris normale;	CALL	IOERROR		; affiche erreur si ncessaire96$:;	PUSH.L	D7;	CALL	INIFREE		; affiche le reste;	POP.L	D7	POPM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;=========== INIBIBLIO:;===========;; initialise toutes les variables pour BIBLIO;	PUSHM.L	A3							; routines	LOAD.L	A3,#R16"PMOUSE	; PMOUSE	LOAD.L	(A6)+OPLANBV+OBADPMOUSE,A3	; adresse PMOUSE	LOAD.L	A3,#R16"BOUTPUT	LOAD.L	(A6)+OPLANBV+OBADBOUTPUT,A3	; adresse BOUTPUT;;;;;;	TSET.B	(A6)+OPLANBV+OBFLAGS:#BUTILISE	LOAD.L	A3,(A6)+OSTART	LOAD.B	(A6)+OPLANBV+OBPLANREV,(A3)-256+OBXREV	LOAD.B	(A6)+OPLANBV+OBPLANVER,(A3)-256+OBXVER	POPM.L	A3	RET;========== FCBIBLIO:;==========; charge une biblio, si existante, depuis la ligne de commande; in	A3	^nom dans ligne de commande;	PUSHM.L	D0..D6,A0..A5	call	biblio?	jump,eq	90$	LOAD.L	A4,#(A6)+OBUTEMP	; ^nom BIBLIO	PUSHM.L	A4,A310$:					; copie du nom dans OBUTEMP	comp.b	(a3),#cr	jump,eq	20$	comp.b	(a3),#0	jump,eq	20$	comp.b	(a3),#'/	jump,eq	20$	comp.b	(a3),#SPACE	jump,eq	20$	load.b	(a4+),(A3+)	comp.b	(a3),#CR	jump,eq	20$	load.b	(a4+),(A3+)	jump	10$20$:	load.b	(a4),#0	POPM.L	A4,A3	load.l	a3,a4	load.l	a4,#R16"TEXBIBLIO	load.w	d3,#1	lib	?addext	LOAD.L	A0,#(A6)+OPLANBV	; A0 ^variables PLANB	TCLR.B	(A6)+OPLANBV+OBFLAGS:#BMODIFIE	; flags	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL	JUMP,EQ	40$	CALL	IOERROR	jump	90$40$:	LOAD.W	(A6)+OPLANBV+OBCHBIB,D6		; mmorise le canal	CALL	KILEXT				; enlve extension	LOAD.L	A4,#(A6)+OPLANBV+OBMEMFIO	; mmorise le nom complet sans extension	PUSH.L	A350$:	LOAD.B	(A4+),(A3+)	JUMP,NE	50$	POP.L	A462$:	COMP.L	A3,A4	JUMP,EQ	64$	COMP.B	(-A3),#':			; remonte au ':	JUMP,NE	62$64$:	LOAD.L	A4,#(A6)+OPLANBV+OBMEMF		; mmorise nom p. affichage66$:	LOAD.B	(A4+),(A3+)	JUMP,NE	66$	PLANB_	OUVRE		; initialise BIBLIO90$:	POPM.L	D0..D6,A0..A5	RET;========== BIBLIO:		; APPEL dans PLAN ;==========;; touche (SHIFT()F2):; accs  la bibliothque en mode utilisation ou modification; si inexistant demande le nom;; in:	-; out:	-; mod:	-;	PUSHM.L	D0..D6,A0..A5	CALL	SRMO		; met souris relle, plus le rticule	LOAD.L	A0,#(A6)+OPLANBV	; A0 ^variables PLANB	CALL	BIBLIO?		; y a-t-il une BIBLIO courante ?	JUMP,EQ	20$		; oui => 20$				; non, demander nom BIBLIO et initialiser tout	CALL	BIBLIOIN	JUMP,NE	90$	PLANB_	OUVRE		; initialise BIBLIO20$:call	srmo	PLANB_	BIBLIO		; oui, entrer en dialogue avec BIBLIO	JUMP,NE	90$	TEST.B	(A6)+OPLANBV+OBFLAGS:#BCHARGE ; qqch.  ajouter ?	JUMP,BC	90$		; non => 90$	CALL	AFDMENU		; menu dplacement	CALL	BIBAJOUTE	; oui, fait90$:	PUSH.W	D7	CALL	AFFINV		; remet tout a ...	POP.W	D7	CALL	IOERROR	CALL	INIHAUT	CALL	INIBAS	CALL	AFMENU		; affiche menu-softkeys PLAN	CALL	CRMO		; remet souris ou rticule	POPM.L	D0..D6,A0..A5	RET;============ PUSHBIBLIO:		; APPEL dans PLAN;============;; METTRE un lment dans la bibliothque; zone de slction et MMENU modif avec BIBLIO dans PLAN;; in	D3.L	coord. un coin;	D4.L	coord. autre coin; out:; mod:	PUSHM.L	D0..D6,A0..A5	LOAD.L	(A6)+OPLANBV+OBD3ZONE,D3 ; sauve zone slctionne	LOAD.L	(A6)+OPLANBV+OBD4ZONE,D4	CALL	SRMO			; souris relle	LOAD.L	A0,#(A6)+OPLANBV	; A0 ^variables PLANBcall	ireticule	CALL	ZPAVE			; mettre la zone dans le pav	JUMP,NE	90$call	ireticule	TEST.W	(A6)+OPLANAV+OSCALE	; chelle 1:1 seulement !	JUMP,EQ	10$	LOAD.W	D7,#ERSCA	JUMP	90$10$:	TSET.B	(A6)+OPLANBV+OBFLAGS:#BINSCRIT	; inscription nouvelle	CALL	BIBLIO?			; BIBLIO prsente ?	JUMP,NE	90$20$:	TEST.B	(A6)+OPLANBV+OBFLAGS:#BMODIFIE	; ouvert en mode modifie ?	JUMP,BS	30$			; oui => 30$	TCLR.B	(A6)+OPLANBV+OBFLAGS:#BINSCRIT ; non, annule ...	JUMP	90$30$:	PLANB_	BIBLIO			; entrer en dialogue avec BIBLIO35$:	TCLR.B	(A6)+OPLANBV+OBFLAGS:#BINSCRIT	; fin inscription nouvelle	TEST.W	D7	JUMP,NE	90$	TEST.B	(A6)+OPLANBV+OBFLAGS:#BCHARGE	; qqch.  ajouter ?	JUMP,BC	90$			; non => 90$	CALL	BIBAJOUTE		; oui90$:	CALL	IOERROR	CALL	AFFINV		; remet tout a ...	CALL	INIHAUT	CALL	INIBAS	CALL	CRMO		; rticule ou flche	CALL	AFMENU		; menu softkeys PLAN	POPM.L	D0..D6,A0..A5	RET;------- ZPAVE:;-------;; met la zone slctionne en pav pour BIBLIO, chelle 1:1 seulement !!!; - demander mmoire pour copie zone; - copie zone --> mmoire; - stretch mm --> pav; - librer mmoire zone; in	D3.L	coin;	D4.L	autre coin; out; mod	D7.W	PUSHM.L	D0..D5,A0..A4					; D3.L, D4.L coord. cran	SUB.W	D4,(A6)+OPLANAV+OOWDOX	SWAP.W	D4	SUB.W	D4,(A6)+OPLANAV+OOWDOY	SWAP.W	D4	SUB.W	D3,(A6)+OPLANAV+OOWDOX	SWAP.W	D3	SUB.W	D3,(A6)+OPLANAV+OOWDOY	SWAP.W	D3	PLANA_	YINVERSE	EX.L	D3,D4	PLANA_	YINVERSE	EX.L	D3,D4	ADD.L	D3,(A6)+OPLANAV+OMINY	; correction offset origine	ADD.L	D4,(A6)+OPLANAV+OMINY	PLANA_	ORDONNE			; D3 <-- min., D4 <-- max.	LOAD.L	D2,D4			; D2 <-- dy,dx	SUB.W	D2,D3	SWAP.W	D3	SWAP.W	D2	SUB.W	D2,D3	SWAP.W	D2	SWAP.W	D3				; DEMANDE MEMOIRE	PUSHM.L	D4	LOAD.W	D4,D2			; D4 <-- dx	ADD.W	D4,#7			; D4 <-- dx+7	SR.W	D4,#3			; D4 <-- nb. bytes en X	LOAD.W	D5,D4			; D5 <-- Iy destination	SWAP.W	D2			; D2 <-- (dx,dy)	MUL.WU	D4,D2			; D4 fois Y	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM			; A4 ^mmoire	POPM.L	D4	JUMP,NE	90$				; ZONE --> EN MEMOIRE	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE	LOAD.B	(A3)+0,#NUL	LOAD.B	(A3)+1,#DRAWRASTER	SWAP.W	D3	LOAD.L	(A3)+2,D3		; xx,yy source	SWAP.W	D3	CLR.L	(A3)+6			; cran = 0	CLR.W	(A3)+10			; incr. cran	CLR.L	(A3)+12			; xx,yy dest.	LOAD.L	(A3)+16,A4		; ^dest.;CLR.L	(a3)+16	LOAD.W	(A3)+20,D5		; Iy dest.;CLR.W	(A3)+20	LOAD.L	(A3)+22,D2		; (dx,dy)	LOAD.B	(A3)+26,#LOADDOT	; mode	PUSHM.L	D3	LOAD.W	D3,#27	LIB	?STRING	POPM.L	D3				; MEMOIRE --> MEMOIRE PAVE (STRETCH)	LOAD.L	A0,#(A6)+OBUIMF		; A0 ^ table param. transformation	LOAD.W	(A0)+OSTRTYP,#0		; init  zro	LOAD.W	(A0)+OSTROP,#0	LOAD.L	(A0)+OSTRSPT,A4		; ^matrice source	LOAD.W	(A0)+OSTRSDX,D5		; Iy source	CLR.L	(A0)+OSTRS0	SWAP.W	D2	LOAD.L	(A0)+OSTRS2,D2		; D2(dy;dx)	LOAD.L	A3,#(A6)+OPLANBV+OBMPAVE ; A3 ^matrice de dest.	LOAD.L	(A0)+OSTRDPT,A3		; ^matrice de dest.;	LOAD.B	(A6)+OPLANBV+OBDXMP,#(LBWDOX/8)-4;	LOAD.B	(A6)+OPLANBV+OBDYMP,#((LBWDOY-HBTIT)/4)-4	LOAD.B	(A6)+OPLANBV+OBDXMP,#BDXPAVE	LOAD.B	(A6)+OPLANBV+OBDYMP,#BDYPAVE	LOAD.W	(A0)+OSTRDDX,#LBWDOX/(8*8)	; Iy dest.	LOAD.L	D0,#(LBWDOX/(8*8))*((LBWDOY-HBTIT)/4)70$:	CLR.B	(A3+)			; efface destination (pav)	DEC.L	D0	JUMP,NE	70$					; calcul de facteur max. ( dx, dy max 1000!!!);	LOAD.L	D0,#(LBWDOX/8)-4	LOAD.L	D0,#BDXPAVE	SL.L	D0,#8;	LOAD.L	D1,#((LBWDOY-HBTIT)/4)-4	LOAD.L	D1,#BDYPAVE	SL.L	D1,#8	DIV.WU	D0,D2	SWAP.W	D2	DIV.WU	D1,D2	COMP.W	D0,D1			; le plus petit facteur	JUMP,HS	72$	LOAD.W	D1,D2	MUL.WU	D1,D0	SR.L	D1,#8	LOAD.W	D2,D1	SWAP.W	D2	LOAD.W	D1,D2	MUL.WU	D1,D0	SR.L	D1,#8	LOAD.W	D2,D1	JUMP	74$72$:	LOAD.W	D0,D2	MUL.WU	D0,D1	SR.L	D0,#8	LOAD.W	D2,D0	SWAP.W	D2	LOAD.W	D0,D2	MUL.WU	D0,D1	SR.L	D0,#8	LOAD.W	D2,D074$:					; centrer dans le pav;	LOAD.L	D0,#((((LBWDOY-HBTIT)/4)-4)*H'10000)+((LBWDOX/8)-4)	LOAD.L	D0,#BDYPAVE*H'10000+BDXPAVE	SUB.W	D0,D2	SR.W	D0	SWAP.W	D0	SWAP.W	D2	SUB.W	D0,D2	SR.W	D0	SWAP.W	D0	SWAP.W	D2	LOAD.L	(A0)+OSTRD0,D0		; coord. dest.	LOAD.L	(A0)+OSTRD1,D0	LOAD.L	(A0)+OSTRD2,D0	LOAD.L	(A0)+OSTRD3,D0	ADD.W	(A0)+OSTRD2+2,D2	SWAP.W	D2	ADD.W	(A0)+OSTRD2,D2	LOAD.W	(A0)+OSTRD1+2,(A0)+OSTRD2+2	LOAD.W	(A0)+OSTRD3,(A0)+OSTRD2	ST_	RECT			; STRETCH;;;	JUMP,NE	90$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP		; rend la mmoire	GESMEM	?GIVMEM			; A4 ^mmoire	POP.W	D7					; inverser la matrice	LOAD.L	A3,#(A6)+OPLANBV+OBMPAVE ; A3 ^matrice de dest.	LOAD.W	D0,#(LBWDOX/(8*8))*((LBWDOY-HBTIT)/4)85$:	XOR.B	(A3+),#H'FF			; efface destination (pav)	DECJ.W,NMO D0,85$90$:	POPM.L	D0..D5,A0..A4	TEST.W	D7	RET;-------- BIBLIO?:		; APPEL dans PLAN;--------; y a-t-il une bibliothque courante ( teste si nom );; in:	-; out:	EQ -> oui;	NE -> non; mod:	D7.W	PUSH.L	A4	LOAD.W	D7,#1	TEST.B	(A6)+OPLANBV+OBMEMF	JUMP,EQ	90$80$:	CLR.W	D790$:	POP.L	A4	TEST.W	D7	RET;----------- BIBLIOIN:;-----------;; DBOX ...; - demander nom BIBLIO; - ouvre fichier selon mode et sauve canal; - mmorise le nom de la BIBLIO;; in	-; out	-; mod	D7.W;	PUSHM.L	D1,D3,D4,D6,A0..A5		; demander nom BIBLIO	LOAD.L	A3,#(A6)+OBUTEMP	; ^nom  diter	CLR.B	(A3)			; buffer vide	CLR.L	D4	TSET.L	D4:#1			; UTILISE toujours par dfaut !	TCLR.L	D4:#BMODIFIE00$:	LOAD.L	A4,#R16"TEXBIBLIO	; ^extension	CALL	DBOXEDITB	JUMP,NE	90$	COMP.W	D3,#F1			; prend	JUMP,EQ	10$	LOAD.W	D7,#1			; sinon => 90$	JUMP	90$					; A3 ^nom avec extension10$:	TEST.L	D4:#BMODIFIE	JUMP,BC	12$	TSET.B	(A6)+OPLANBV+OBFLAGS:#BMODIFIE	JUMP	11$12$:	TCLR.B	(A6)+OPLANBV+OBFLAGS:#BMODIFIE	; flags11$:	LOAD.W	D3,#2^BOPRD	TEST.B	(A6)+OPLANBV+OBFLAGS:#BMODIFIE	; mode modifie ?	JUMP,BC	05$				; non, ...	LOAD.W	D3,#2^BOPRD!2^BOPWR!2^BOPEXCL	; non, modifie05$:	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL	JUMP,EQ	40$	COMP.W	D7,#ERFDNE	JUMP,EQ	20$06$:	CALL	IOERROR	JUMP	00$20$:	TEST.B	(A6)+OPLANBV+OBFLAGS:#BMODIFIE	JUMP,BC	90$					; n'existe pas => crer			; v. DBOX pour demander !!!!!	CALL	DBOX_CREBIB	JUMP,NE	90$	CLR.W	D7	PUSH.W	D4	LOAD.W	D4,#TYPRAND	LOAD.W	D3,#DEFATT	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL	POP.W	D4	TEST.W	D7	JUMP,NE	06$	TSET.B	(A6)+OPLANBV+OBFLAGS:#BININEW	; met les flags	JUMP	11$			; ... et ouvrir40$:	LOAD.W	(A6)+OPLANBV+OBCHBIB,D6		; mmorise le canal	CALL	KILEXT				; enlve extension	LOAD.L	A4,#(A6)+OPLANBV+OBMEMFIO	; mmorise le nom complet sans extension	PUSH.L	A350$:	LOAD.B	(A4+),(A3+)	JUMP,NE	50$	POP.L	A462$:	COMP.L	A3,A4	JUMP,EQ	64$	COMP.B	(-A3),#':			; remante au ':	JUMP,NE	62$64$:	LOAD.L	A4,#(A6)+OPLANBV+OBMEMF		; mmorise nom p. affichage66$:	LOAD.B	(A4+),(A3+)	JUMP,NE	66$	CLR.W	D790$:	POPM.L	D1,D3,D4,D6,A0..A5	TEST.W	D7	RET;  mettre avec nomsTEXBIBLIO:	.ASCIZE	".BBPLAN";----------\\; DBOXEDITB >;==========/; Edite un nom de bibliothque en entre (.BPLAN); in	A3.L	^nom actuel;	A4.L	^extension; out	D3.W	dernire touche (RETURN/END);	A3.L	^nouveau nom;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITB:	PUSHM.L	D1,D2,A2..A5	CALL	CWMO	CALL	SRMO	LOAD.L	A5,A3		; A5 ^nom de fichier	LOAD.L	A4,#R16"TEXBIBLIO	CLR.L	D2	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	A3,#R16"TDBOX_BIO	; BIBLIO	LOAD.L	A2,#R16"TOBJ_BIBLIO	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOOBJ	TEST.B	(A6)+OPLANBV+OBFLAGS:#BINSCRIT	JUMP,BC	10$	TCLR.L	D3:#BDBIOOBJ10$:	LOAD.W	D1,#DBOX_PREND30$:	DBOX_	EXTEND	PUSH.W	D7	CALL	DBOXREFAIT	POP.W	D790$:	POPM.L	D1,D2,A2..A5	TEST.W	D7	RET;-------------\\; DBOX_CREBIB  >;=============/; Demande confirmation pour crer BIBLIO.; in	-; out	D7.W	EQ oui;		NE non; mod	D3.L, D7.WDBOX_CREBIB:	PUSHM.L	D1,D2,D3,D4,D5,A1,A2,A3,A4	CALL	CWMO	CALL	SRMO	LIB	?BUZZ		; signal qq chose de spcial	LOAD.L	A2,#R16"TDBOX_CREBIB	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE 90$	LOAD.W	D2,#1		; affiche le nom du fichier	DBOX_	GETCO	LIB	?SETCURS	DBOX_	AFFILE	LOAD.B	D3,#'?	LIB	?AFCAR20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUINON	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#'O	JUMP',EQ 50$	COMP.W	D3,#'N	JUMP',EQ 40$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; NON ...	CALL	DBOXCLOSE	LOAD.W	D7,#1	JUMP	90$50$:				; OUI ...	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D3,D4,D5,A1,A2,A3,A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CREBIB:	.W	10$-TDBOX_CREBIB	.W	MENU_OUINON-TDBOX_CREBIB	.W	0,010$:	.B	ODBTEXT	.ASCIZ	/ Voulez-vous crer la bibliothque /	.B	ODBCR,ODBCR,ODBTABX,2	.B	ODBTEXT	.ASCIZ	/                                   /	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,'O,TDBMEV	.ASCIZ	"   OUI   "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,'N,TDBNORM	.ASCIZ	"   NON   "	.B	0	.EVENTDBOX_BIO:	.ASCIZ	"BIBLIO"	.ASCIZ	"Fbibliothque"	.ASCIZ	""	.EVENTOBJ_BIBLIO:	.B	LBOBJ_BIBLIO	.B	ODBTABX,4	.B	ODBLCIRCLE,1			; UTILISE	.ASCIZ	" utilisation"	.B	ODBCR,ODBTABX,4	.B	ODBLCIRCLE,BMODIFIE	.ASCIZ	" modification (ou cration)"	.B	ODBCRLBOBJ_BIBLIO=	.-TOBJ_BIBLIO-1	.EVEN	.END