	.SBTTL	PLANSPLINE		; 18 aot 87 Sp.; modif 4.7; n'ajoute plus DS et FS si seulement 2 points; Sp.DELTA	=	0.IF	DELTA; en cas de spline ferm ?; en cas de modif des points ?deltaxy:		; veille  ce que deltaX et deltaY < 4096	PUSH.L	(A0)-4	PUSH.L	D4	clr.w	d7	comp.w	d4,(a0)-2	jump,lo	10$	sub.w	d4,(a0)-2	comp.w	d4,#4096	jump,hs	80$	jump	20$10$:	sub.w	(a0)-2,d4	comp.w	(a0)-2,#4096	jump,hs	80$20$:	swap.w	d4	comp.w	d4,(a0)-4	jump,lo	30$	sub.w	d4,(a0)-4	comp.w	d4,#4096	jump,hs	80$	jump	90$30$:	sub.w	(a0)-4,d4	comp.w	(a0)-4,#4096	jump,lo	90$80$:	load.w	d7,#-190$:	POP.L	D4	POP.L	(A0)-4	test.w	d7	ret.ENDIFDOSPLINE:	CALL	_INIXY	CALL	_AFCMES;	.ASCIZ	"GAUCHE: met un point   DROITE: fin"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,96,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" met un point |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,97,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" met/enlve PAS |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,98,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZE	" FIN "	LOAD.L	A0,#(A6)+OSPLPT	LOAD.W	D0,#MAXSPLINE-2.IF	DELTAjump	16$:.else	JUMP'	15$		; met dj le premier point.endif10$:	CALL	AFFXY		; affiche X= et Y=	CALL	RDMOUSE		; lit la souris	TEST.B	D3	JUMP',EQ 10$	TEST.L	D3:#BMOCENT	JUMP',BS 18$	TEST.L	D3:#BMOLEFT	JUMP',BC 30$15$:	TEST.W	D0		; encore de la place ?	JUMP',EQ 18$		; non => 18$.IF	DELTAcall	deltaxyjump,ne	18$.ENDIF16$:	LOAD.L	(A0+),D4	; OSPLPT <-- un point	DEC.W	D0	CALL	SPLINVP		; montre le point	JUMP'	20$18$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; signal que a va plus !20$:	CALL	RDMOUSE		; lit la souris	TEST.B	D3		; encore un bouton press ?	JUMP,NE	20$		; oui => 20$	JUMP	10$		; non => 10$30$:	LOAD.L	(A0),#-1	; termine la table des points	LOAD.W	(A6)+OSPLMD,#MODINV	or.w	(a6)+osplmd,#H'00F0	; sans test visible	LOAD.W	(A6)+OSPLTR,#TRAFIN	CALL	SWMO		; met la souris "en attente"	CALL	SPLOPEN		; A4 <-- ^table des droites, D6 <-- canal	JUMP,NE	97$	CLR.W	D0	CALL	SPLMI		; montre le spline	JUMP,NE	95$;	CALL	SPLCLOSE	; libre la table des droites	CALL	CWMO		; remet la souris normale;	CALL	INIBAS		; refait le bas de l'cran;	CALL	DBOXSPLINE	; modifie le spline ?;	CALL	SWMO		; met la souris "en attente";	CALL	SPLOPEN		; re-calcul la mme table;	JUMP',EQ 35$		; ok => 35$;	PUSH.W	D7;	CLR.W	D0;	CALL	SPLMI		; efface le spline;	POP.W	D7;	JUMP	97$;35$:;	CALL	CWMO		; remet la souris normale;	COMP.W	D3,#'N;	JUMP,EQ	80$		; NON => 80$;	COMP.W	D3,#UNDO;	JUMP,EQ	85$		; EFFACE => 85$;				; OUI =>	LIB	?BUZZ	CALL	_AFCMES;	.ASCIZ	"GAUCHE: dplace un point   MILIEU: supprime un point   DROITE: fin"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,96,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" dplace un point |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,97,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" supprime un point |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,98,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZE	" FIN "	JUMP'	45$40$:	CALL	SWMO		; met la souris "en attente"	CALL	SPLOPEN		; A4 <-- ^table des droites, D6 <-- canal	JUMP,NE	97$	CLR.W	D0	CALL	SPLMI		; montre le spline	JUMP,NE	95$	CALL	CWMO		; remet la souris normale45$:	CALL	AFFXY		; affiche X= et Y=	CALL	RDMOUSE		; lit la souris	TEST.B	D3	JUMP',EQ 45$	TEST.L	D3:#BMOCENT	JUMP,BS 70$	TEST.L	D3:#BMOLEFT	JUMP',BC 80$	CALL	SPLDET		; cherche le point montr	JUMP',EQ 50$		; trouv => 50$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	45$50$:	LOAD.L	D5,(A0)		; D5 <-- ancien point52$:	CALL	AFFXY		; affiche X= et Y=	CALL	RDMOUSE		; lit la souris	TEST.B	D3		; bouton encore press ?	JUMP',EQ 60$		; non => 60$				; oui =>	CALL	SPLINVP		; dessine le nouveau point	EX.L	D4,D5	CALL	SPLINVP		; efface l'ancien point	JUMP	52$60$:	CALL	SWMO		; met la souris "en attente"	CLR.W	D0	CALL	SPLMI		; efface le spline	CALL	SPLCLOSE	; libre la table des droites	LOAD.L	(A0),D5		; modifie juste le point	JUMP	40$70$:				; SUPPRIME =>	CALL	SPLDET		; cherche le point montr	JUMP',EQ 72$		; trouv => 72$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	45$72$:	CALL	SWMO		; met la souris "en attente"	CLR.W	D0	CALL	SPLMI		; efface le spline	CALL	SPLCLOSE	; libre la table des droites	LOAD.L	D4,(A0)	CALL	SPLINVP		; efface le point	CALL	SPLKILL		; supprime juste le point	JUMP	40$80$:				; INSERT =>	CALL	SWMO		; met la souris "en attente"	CLR.W	D0	CALL	SPLMI		; efface le spline provisoire	CALL	SPLINVC		; efface tous les points montrs	LOAD.W	(A6)+OSPLMD,(A6)+OMODE	LOAD.W	(A6)+OSPLTR,(A6)+OTRAIT	COMP.L	(A4)+8,#-1	; 2 points ?	JUMP',EQ 86$		; oui --> pas de groupe systme;;;	CALL	AJOUTEDS	; met un dbut de groupe systme	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJDS	.W	PLANA_BASE	JUMP',NE 81$86$:	LOAD.W	D0,#1	CALL	SPLMI		; montre et insre le spline dfinitif	JUMP',NE 81$	COMP.L	(A4)+8,#-1	; 2 points ?	JUMP',EQ 81$		; oui --> pas de groupe systme;;;	CALL	AJOUTEFS	; met une fin de groupe systme	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJFS	.W	PLANA_BASE81$:	PUSH.W	D7	CALL	SPLCLOSE	; ferme la table des droites	POP.W	D7	JUMP,NE	DFERROR82$:	CALL	_INIHAUT	; refait le haut de la fentre	CALL	_INIBAS		; refait le bas de la fentre	CALL	_AFMENU	JUMP	LOOP85$:				; EFFACE =>	CALL	SWMO		; met la souris "en attente"	CLR.W	D0	CALL	SPLMI		; efface le spline provisoire	CALL	SPLINVC		; efface tous les points montrs	CALL	SPLCLOSE	; ferme la table des droites	JUMP	82$95$:				; ERREUR =>	PUSH.W	D7	CALL	SPLCLOSE	; ferme la table des droites	POP.W	D797$:	PUSH.W	D7	CALL	SPLINVC		; efface tous les points montrs	POP.W	D7	JUMP	DFERROR;--------\; SPLOPEN >;========/; Calcul les segments de droites pour suivre le spline.; in	(A6)+OSPLPT	table des points; out	A4.L		^table des droites;	D6.L		canal spline;	D7.W		erreur; mod	D6.L, D7.W, A4.LSPLOPEN:	PUSHM.L	D1,D3,A0,A3	COMP.W	(A6)+OOBJET,#OBJSPLO ; spline ouvert ?	JUMP',NE 05$		; non => 05$				; oui =>	CLR.W	D7		; D7 <-- ok	CLR.L	D6		; D6 <-- "canal" impossible	LOAD.L	A4,#(A6)+OSPLPT	; A4 <-- ^table des points	COMP.L	(A4)+8,#-1	; seulement 2 points ?	JUMP,EQ	90$		; oui => 90$05$:	TEST.W	(A6)+OCHSPLINE	; module SPLINE dj ouvert ?	JUMP',NE 10$		; oui => 10$	LOAD.L	A3,#R16"NAMSPLINE	LOAD.W	D3,#SPLINE_FIRST	LIB_	OPEN		; ouvre le module SPLINE	JUMP,NE	90$	LOAD.W	(A6)+OCHSPLINE,D110$:	COMP.W	(A6)+OOBJET,#OBJSPLC ; spline ferm ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A0,#(A6)+OSPLPT	; A0 <-- ^table des points15$:	COMP.L	(A0+),#-1	JUMP,NE	15$	LOAD.L	(A0)-4,(A6)+OSPLPT ; ferme la boucle	LOAD.L	(A0)+0,#-1	; et remet le terminateur20$:	LOAD.L	A3,#(A6)+OSPLPT	; A3 <-- ^table des points;;?	CALL	PASREEL		; D1 <-- pas rel (1,2,4,etc);;?	LOAD.W	D3,#4		; D3 <-- arrondi de base !;;?	MUL.WU	D3,D1		; D3 <-- tient compte du pas;;?	COMP.W	D3,#8		; au moins un minimum ?;;?	JUMP',HS 50$		; oui => 50$;;?	LOAD.W	D3,#8		; non => met le minimum;;?50$:	LOAD.W	D3,#8		; D3 <-- prend un point sur huit !	SPLINE_	OPEN		; A4 <-- ^points, D6 <-- canal	COMP.W	(A6)+OOBJET,#OBJSPLC ; spline ferm ?	JUMP',NE 90$		; non => 90$	LOAD.L	(A0)-4,#-1	; oui => r-ouvre la boucle90$:	POPM.L	D1,D3,A0,A3	TEST.W	D7		; retour EQ/NE	RET;--------\; SPLMI   >;========/; Montre/insre les segments de droites pour suivre le spline.; in	A4.L		^table des droites;	D0.W		0 => montre, autre => insre et montre;	(A6)+OSPLMD.W	mode;	(A6)+OSPLTR.W	trait; out	D7.W		erreur; mod	D7.WSPLMI:	PUSHM.L	D1,D2,D3,D4,D5,A4	LOAD.W	D7,#ERSPL	; D7 <-- erreur (pas assez de points)	LOAD.L	D4,(A4+)	COMP.L	D4,#-1	JUMP',EQ 90$	LOAD.L	D3,D4		; D3 <-- 1er point	LOAD.L	D4,(A4+)	COMP.L	D4,#-1	JUMP',EQ 90$	JUMP'	50$30$:	LOAD.L	D5,(A4+)	; D5 <-- 3me point	COMP.L	D5,#-1	JUMP',EQ 60$	PUSHM.L	D3,D4	LOAD.L	D3,D4	LOAD.L	D4,D5	CALL	SPLPENTE	; D2 <-- nouvelle pente	POPM.L	D3,D4	COMP.W	D2,D1		; toujours la mme pente ?	JUMP',NE 40$		; non => 40$	LOAD.L	D4,D5		; D4 <-- avance le 2me point	JUMP	30$40$:	CALL	SPLMIEL		; montre/insre lastique dans base	JUMP',NE 90$	LOAD.L	D3,D4		; D3 <-- 1er point	LOAD.L	D4,D5		; D4 <-- 2me point50$:	CALL	SPLPENTE	LOAD.W	D1,D2		; D1 <-- pente de dpart	JUMP	30$60$:	CALL	SPLMIEL		; montre/insre dernire lastique90$:	POPM.L	D1,D2,D3,D4,D5,A4	TEST.W	D7		; retour EQ/NE	RET;---------\; SPLCLOSE >;=========/; Ferme la table des droites.; in	D6.L	canal spline; out	-; mod	D7.WSPLCLOSE:	TEST.L	D6		; "canal" spcial ?	JUMP',EQ 90$		; oui => 90$	SPLINE_	CLOSE		; non => libre mmoire pour spline90$:	RET;---------\; SPLPENTE >;---------/; Calcul un coeficient proportionnel  la pente d'une droite.; in	D3.L	dpart;	D4.L	arrive; out	D2.W	"pente"; mod	D2.WSPLPENTE:	PUSHM.L	D1,D3	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- dx	LOAD.L	D1,D4	SWAP.W	D1	SWAP.W	D3	SUB.W	D1,D3		; D1 <-- dy	SL.W	D1,#1		; D1 <-- dy*2	JUMP',NE 50$	INC.W	D150$:	MUL.WA	D2,#64	DIV.WA	D2,D1		; D2 <-- pente*32	POPM.L	D1,D3	RET;---------\; SPLMIEL  >;---------/; Montre/insre une lastique.; in	D3.L		coordonne (y;x) dpart;	D4.L		coordonne (y;x) arrive;	D0.W		0 => montre, autre => insre et montre;	(A6)+OSPLMD.W	mode;	(A6)+OSPLTR.W	trait; out	D7.W	erreur; mod	D7.WSPLMIEL:	PUSHM.L	D0..D4	COMP.L	D3,D4		; droite de longueur nulle ?	JUMP',EQ 80$		; oui => 80$	CALL	SPLCLIP		; dans la fentre virtuelle ?	JUMP',NE 80$		; non => 80$	EX.L	D3,D4	CALL	SPLCLIP		; dans la fentre virtuelle ?	JUMP',NE 80$		; non => 80$	EX.L	D4,D3	CLR.W	D7		; D7 <-- ok	LOAD.W	D2,(A6)+OSPLMD	; D2 <-- mode/couleur de dessin	LOAD.W	D1,(A6)+OSPLTR	; D1 <-- type du trait	TEST.W	D0		; montre ?	JUMP',EQ 50$		; oui => 50$				; non => insre	LOAD.W	D0,#OBJLIGNE	; D0 <-- type de l'objet;;;	CALL	_AJOUTE		; ajoute dans base de donne	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE	JUMP',NE 90$50$:;;;	CALL	_LIGNE		; dessine une ligne droite	.W	PLANA_DESSINE80$:	CLR.W	D7		; D7 <-- ok	LOAD.L	(A6)+OMLAST,D490$:	POPM.L	D0..D4	TEST.W	D7		; retour EQ/NE	RET;--------\; SPLCLIP >;--------/; Vrifie si un point est dans la fentre virtuelle.; in	D4.L	coordonne; out	D7.W	erreur; mod	D7.WSPLCLIP:	PUSH.L	D4	LOAD.W	D7,#ERPLI	; D4 <-- erreur "hors limites"	TEST.W	D4	JUMP',NS 90$	COMP.W	D4,(A6)+OPLANAV+OMWDOX	JUMP',HS 90$	SWAP.W	D4	TEST.W	D4	JUMP',NS 90$	COMP.W	D4,(A6)+OPLANAV+OMWDOY	JUMP',HS 90$	CLR.W	D7		; D7 <-- ok90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\; SPLDET  >;========/; Cherche le point montr par la souris.; in	D4.L	position de la souris; out	A0.L	^point dtect;	D7.W	erreur; mod	D7.W, A0.LSPLDET:	PUSHM.L	D0,D3	LOAD.L	D3,D4		; D4 <-- x souris	SWAP.W	D3		; D3 <-- y souris	LOAD.L	A0,#(A6)+OSPLPT-4	LOAD.W	D7,#ERPZV10$:	ADD.L	A0,#4		; A0 <-- ^point suivant	COMP.L	(A0),#-1	; fin de la table ?	JUMP',EQ 90$		; oui => 90$	LOAD.W	D0,(A0)+2	; D0 <-- x point	SUB.W	D0,#RSPLINE+1	COMP.W	D4,D0	JUMP,LO	10$	ADD.W	D0,#(RSPLINE+1)*2	COMP.W	D4,D0	JUMP,HS	10$	LOAD.W	D0,(A0)+0	; D0 <-- y point	SUB.W	D0,#RSPLINE+1	COMP.W	D3,D0	JUMP,LO	10$	ADD.W	D0,#(RSPLINE+1)*2	COMP.W	D3,D0	JUMP,HS	10$	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D0,D3	TEST.W	D7		; retour EQ/NE	RET;--------\; SPLKILL >;========/; Supprime le point montr par la souris.; in	A0.L	^point  supprimer; out	-; mod	-SPLKILL:	PUSH.L	A010$:	LOAD.L	(A0)+0,(A0)+4	ADD.L	A0,#4	COMP.L	(A0),#-1	JUMP,NE	10$	POP.L	A0	RET;--------\; SPLINVC >;========/; Inverse tous les points avant le dessin d'un spline.; in	-; out	-; mod	D7.WSPLINVC:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OSPLPT10$:	COMP.L	(A4),#-1	; dernier point ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	D4,(A4+)	; D4 <-- coordonne d'un point	CALL	SPLINVP		; inverse le point	JUMP	10$90$:	POPM.L	D4,A4	RET;--------\; SPLINVP >;========/; Inverse un point avant le dessin d'un spline.; in	D4.L	coordonne (y;x) dans le plan; out	-; mod	D7.WSPLINVP:	PUSHM.L	D2,D3,D4;;;	CALL	_D4CLIP		; D4 <-- dans la fentre;;;	CALL	_D4SCALE	; D4 <-- tient compte de l'chelle;;;	CALL	_YINVERSE	; D4 <-- inverse le sens de Y	.W	PLANA_D4CLIP	.W	PLANA_D4SCALE	.W	PLANA_YINVERSE	ADD.W	D4,(A6)+OPLANAV+OMINX	SWAP.W	D4	ADD.W	D4,(A6)+OPLANAV+OMINY	SWAP.W	D4	LOAD.L	D3,D4		; D3 <-- coordonne centre	LOAD.W	D4,#RSPLINE	; D4 <-- rayon	LOAD.W	D2,#INVDOT	; D2 <-- mode	LIB	?DRCERCLE	POPM.L	D2,D3,D4	RET	.END