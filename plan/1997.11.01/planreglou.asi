	.SBTTL	PLANREGLOU	; 13 septembre 1987; REGLE; GRILLE; LOUPE;;;;;;;;;; REGLE;;;;;;;;;;---------\\; INVREGLE >;=========/; Met/enlve les rgles.; in	-; out	-; mod	D7.WINVREGLE:	TEST.B	(A6)+OFLMOD:#BREGLE	JUMP,BS CLRREGLE;	JUMP	SETREGLE;---------\\; SETREGLE >;=========/; Met les rgles.; in	-; out	-; mod	D7.WSETREGLE:	PUSH.L	D4	TSET.B	(A6)+OFLMOD:#BREGLE	JUMP',BS 90$	LOAD.W	D4,#-LGREGLE	CALL	MDDREG	PUSH.L	A5	LOAD.L	A5,#(A6)+ORGVAR		; efface variables rgle	LOAD.W	D4,#LRGVAR		; LRGVAR/4	SR.W	D4	SR.W	D4	DEC.W	D4			; -110$:	CLR.L	(A5+)	DECJ.W,NMO D4,10$	POP.L	A590$:	POP.L	D4	RET;---------\\; CLRREGLE >;=========/; Enlve les rgles.; in	-; out	-; mod	D7.WCLRREGLE:	PUSH.L	D4	TCLR.B	(A6)+OFLMOD:#BREGLE	JUMP',BC 90$	CALL	RELRG	LOAD.W	D4,#+LGREGLE	CALL	MDDREG90$:	POP.L	D4	RET;------ RELRG:;------; efface les flches ds. les rgles	PUSHM.L	D4,A0,A5	CLR.L	D4	LOAD.L	A0,#(A6)+OPLANAV+OPDDIS	LOAD.L	A5,#(A6)+ORGVAR	SCROLL_	RMOUSE	POPM.L	D4,A0,A5	RET;--------\\; MDDREG  >;--------/; Modifie les dimensions pour mettre/enlever les rgles.; in	D4.W	dimension (+/-); out	-; mod	D4.L;MDDREG:	ADD.W	(A6)+OPLANAV+OMAXX,D4	SUB.W	(A6)+OPLANAV+OMINY,D4	ADD.W	(A6)+OPLANAV+OLWDOX,D4	ADD.W	(A6)+OPLANAV+OLWDOY,D4	LOAD.L	D4,(A6)+OPLANAV+OLWDOY	; D4 <-- dim fentre physique	PUSH.W	(A6)+OPLANAV+OSCALE	NEG.W	(A6)+OPLANAV+OSCALE	; selon l'inverse de l'chelle;;;	CALL	D4SCALE	.W	PLANA_D4SCALE	POP.W	(A6)+OPLANAV+OSCALE	LOAD.L	(A6)+OPLANAV+OSWDOY,D4	; mj dim selon l'chelle	RET;----------\\; POSREGLE  >;==========/; Dplace la position de la souris dans les rgles.; in	D5.L	position (absolue) de la souris; out	-; mod	D7.WPOSREGLE:	PUSHM.L	D4,A0,A5	TEST.B	(A6)+OFLMOD:#BREGLE	JUMP',BC 90$	TEST.B	(A6)+OFLRET:#BRETICULE ; rticule ?	JUMP',BC 10$			; non ...	CALL	RELRG			; efface les flches	JUMP	90$10$:	LOAD.L	A0,#(A6)+OPLANAV+OPDDIS	LOAD.L	A5,#(A6)+ORGVAR	LOAD.L	D4,D5	SCROLL_	RMOUSE90$:	POPM.L	D4,A0,A5	RET;--------\\; REGLE   >;========/; Dessine les rgles avec les chelles.; in	-; out	-; mod	D7.WREGLE:	PUSHM.L	D4,A0,A5	TEST.B	(A6)+OFLMOD:#BREGLE	JUMP,BC 90$	LOAD.L	A5,#(A6)+ORGVAR		; A5^ variables des rgles				; rgle en haut;	LOAD.L	(A5)+ORGHPO,...		; (y;x) coin sup. gauche	LOAD.W	(A5)+ORGHPO,(A6)+OPLANAV+OMINY	SUB.W	(A5)+ORGHPO,#LGREGLE	LOAD.W	(A5)+ORGHPO+2,(A6)+OPLANAV+OMINX	LOAD.W	(A5)+ORGHLG,(A6)+OPLANAV+OLWDOX	; largeur (dx)	INC.W	(A5)+ORGHLG	INC.W	(A5)+ORGHLG	LOAD.W	(A5)+ORGHPA,(A6)+OF64X	;D4; pas (nb. points par mm * 64)	LOAD.W	(A5)+ORGHOR,(A6)+OPLANAV+OOWDOX	; origine (points)	LOAD.W	(A5)+ORGHSC,(A6)+OPLANAV+OSCALE	; chelle	LOAD.B	(A5)+ORGHMI,#0		; rgle en bas				; rgle  droite;	LOAD.L	(A5)+ORGVPO,...		; (y;x) coin sup. gauche	LOAD.W	(A5)+ORGVPO,(A6)+OPLANAV+OMINY	; (y;..)	LOAD.W	(A5)+ORGVPO+2,(A6)+OPLANAV+OMAXX ; (..;x)	INC.W	(A5)+ORGVPO+2	INC.W	(A5)+ORGVPO+2	LOAD.W	(A5)+ORGVLG,(A6)+OPLANAV+OLWDOY	; hauteur (dy)	INC.W	(A5)+ORGVLG	INC.W	(A5)+ORGVLG	LOAD.W	(A5)+ORGVPA,(A6)+OF64Y	; pas (nb. points par mm * 64)	LOAD.W	(A5)+ORGVOR,(A6)+OPLANAV+OOWDOY	; origine (points)	LOAD.W	(A5)+ORGVSC,(A6)+OPLANAV+OSCALE	; chelle	LOAD.B	(A5)+ORGVMI,#0		; rgle  gauche	LOAD.B	(A5)+ORGVHB,#0		; graduation de bas en haut	LOAD.L	A0,(A6)+OPLANAV+OPDDIS		; ^pointeur fentre	SCROLL_	RUPDATE	LIB	?AFTIM			; remet mode normal	.B	MODCAR	.B	SETDOT	.B	0	.EVEN	CALL	AFFINV			; remet vido inverse90$:	POPM.L	D4,A0,A5	RET;--------\; GRILLE  >;========/; Dessine la grille en fonction du pas.; in	-; out	-; mod	D7.WGRILLE:	PUSHM.L	D0..D4,A3	CALL	CCMO		; enlve la souris	LOAD.L	A3,#R16"00$	; A3 <-- ^table	CLR.L	D3	LOAD.W	D3,(A6)+OPAS	; D3 <-- 1/2 pas rel	SL.W	D3,#2		; table de .WW	ADD.L	A3,D3		; A3 <-- ^pas	LOAD.W	D4,(A3)+0	; D4 <-- pas pour la grille;;;	CALL	D4SCALE		; modifie selon l'chelle	.W	PLANA_D4SCALE.IF	CARPI	COMP.W	D4,#4		; pas assez grand ?.ELSECOMP.W	D4,(A3)+2.ENDIF	JUMP',HS 10$		; oui => 10$.IF	CARPI	LOAD.W	D4,#4		; D4 <-- met le pas minimum.ELSELOAD.W	D4,(A3)+2.ENDIF10$:	LOAD.W	D0,D4		; D0 <-- pas selon l'chelle	LOAD.W	D4,(A6)+OPLANAV+OOWDOY;;;	CALL	D4SCALE	.W	PLANA_D4SCALE	AND.L	D4,#H'FFFF	DIV.WU	D4,D0	SWAP.W	D4	TEST.W	D4	JUMP',EQ 15$	SUB.W	D4,D0	NEG.W	D4		; D4 <-- dcalage jusqu'au premier point15$:	CLR.L	D3		; D3 <-- coordonne initiale en Y	LOAD.W	D3,D4		; D3 <-- coordonne initiale en X	CLR.W	D4	SWAP.W	D4	DIV.WU	D4,(A3)+2	SWAP.W	D4	SUB.W	D4,(A3)+2	NEG.W	D4	INC.W	D4	COMP.W	D4,(A3)+2	JUMP',LS 20$	LOAD.W	D4,#120$:	DEC.W	D4		; marque super-grille ?	JUMP',NE 30$		; non => 30$				; fait ligne dense =>	LOAD.W	D4,(A3)+2	; D4 <-- pas super-grille	LOAD.W	D2,D0		; D2 <-- pas	JUMP'	40$30$:				; fait ligne are =>	LOAD.W	D2,D0		; D2 <-- pas	MUL.WU	D2,(A3)+2	; D2 <-- points plus espacs40$:	CALL	LGRILLE		; dessine une "ligne"	SWAP.W	D3	ADD.W	D3,D0		; D3 <-- ligne suivante	LOAD.W	D2,D3	SWAP.W	D3	COMP.W	D2,(A6)+OPLANAV+OLWDOY	; encore une ligne horizontale ?	JUMP,LO 20$		; oui => 20$	CALL	SCMO		; remet la souris	POPM.L	D0..D4,A3	RET00$:.if	carpi	.WW	1,5.else	.WW	1,4		; pas = 1.endif	.WW	2,4		; pas = 2	.WW	4,4		; pas = 4	.WW	8,4		; pas = 8	.WW	16,4		; pas = 16	.WW	32,4		; pas = 32	.WW	3,6	.WW	6,6	.WW	12,6	.WW	24,6	.WW	5,5	.WW	10,5	.WW	15,5	.WW	20,5	.WW	25,5	.WW	30,5	.EVEN;--------\; LGRILLE >;--------/; Dessine une ligne de points pour la grille.; in	D3.L	coordonne Y;X dbut ligne;	D2.W	espacement entre les points; out	-; mod	D7.WLGRILLE:	PUSHM.L	D2..D4,A0,A2	LOAD.W	D4,(A6)+OPLANAV+OOWDOX;;;	CALL	D4SCALE	.W	PLANA_D4SCALE	AND.L	D4,#H'FFFF	DIV.WU	D4,D2	SWAP.W	D4	TEST.W	D4	JUMP',EQ 10$	SUB.W	D4,D2	NEG.W	D4		; D4 <-- dcalage jusqu'au premier point	ADD.W	D3,D410$:	LOAD.L	D4,D3;;;	CALL	YINVERSE	; D4 <-- inverse le sens de Y	.W	PLANA_YINVERSE	ADD.W	D4,(A6)+OPLANAV+OMINX	SWAP.W	D4	ADD.W	D4,(A6)+OPLANAV+OMINY	SWAP.W	D4	LOAD.W	D3,(A6)+OPLANAV+OMAXX	; D3 <-- maximum  ne pas dpasser	LOAD.L	A2,(A6)+OPLANAV+OPDDIS	; A2 <-- ^description de la fentre	LOAD.L	A0,(A6)+OADQDOT40$:	CALL	(A0)		; appel de GRA_QIDOT	ADD.W	D4,D2		; D4 <-- colonne suivante	COMP.W	D4,D3		; maximum atteint ?	JUMP,LO 40$		; non => 40$				; oui =>	POPM.L	D2..D4,A0,A2	RET;--------\; SGRILLE >;========/; Met la grille (si ce n'est pas dj fait).; in	-; out	-; mod	D7.WSGRILLE:	TEST.B	(A6)+OPLANAV+OFLAGS:#BGRILLE	JUMP',BS 90$	CALL	IGRILLE		; met la grille90$:	RET;--------\; CGRILLE >;========/; Enlve la grille (si ce n'est pas dj fait).; in	-; out	-; mod	D7.WCGRILLE:	TEST.B	(A6)+OPLANAV+OFLAGS:#BGRILLE	JUMP',BC 90$	CALL	IGRILLE		; enlve la grille90$:	RET;--------\; IGRILLE >;========/; Met/enlve la grille.; in	-; out	-; mod	D7.WIGRILLE:	PUSH.L	D3	LOAD.B	D3,#11	LIB	?INVBARRE	CALL	GRILLE		; met/enlve la grille	TNOT.B	(A6)+OPLANAV+OFLAGS:#BGRILLE	POP.L	D3	RET;;;;;;;;;; LOUPE;;;;;;;;;;---------\\; CHGSCALE >;=========/; Change l'chelle selon le sous-menu de la souris. LOUPE !; in	D3.B	nouvelle chelle (0..n); out	-; mod	D7.WCHGSCALE:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#R16"TASCALE	AND.W	D3,#H'FF	SL.W	D3,#1	LOAD.W	D4,(A3)+(D3.W)	; D4 <-- nouvelle chelle	CALL	CENSCALE	; centre selon nouvelle chelle	POPM.L	D3,D4,A3	RETTASCALE:	.W	-8		; 1:8	.W	-4		; 1:4	.W	-2		; 1:2	.W	 0		; 1:1	.W	+2		; 2:1	.W	+4		; 4:1	.W	+8		; 8:1nbtscale = 7; remarque: les routines suivantes ont t mises dans PLANA;	sous le mme nom, prcd de X...;	ceci tait malheureusement ncessaire, parceque ARRONDI;	ne doit pas se trouver dans PLANA (!?);---------- ARROOWDO:;----------; arrondi l'origine de la fentre sur le pas	PUSH.L	D4	LOAD.L	D4,(A6)+OPLANAV+OOWDOY	CALL	ARRONDI	LOAD.L	(A6)+OPLANAV+OOWDOY,D4	POP.L	D4	RET;--------\\; MSCALE  >;========/; Change l'chelle en fonction de la zone montre avec; la souris.; in	D3.L	coordonne d'un coin;	D4.L	coordonne autre coin; out	-; mod	D7.WMSCALE:	LOAD.W	(A6)+OPLANAV+OPLANA,#FXMSCALE	.W	PLANA_FONC	CALL	ARROOWDO	CALL	EFFACE	CALL	REFAIT	RET;---------\\; CENSCALE >;=========/; Change l'chelle et centre la fentre par-rapport;  l'ancienne chelle.; in	D4.W	nouvelle chelle; out	-; mod	-CENSCALE:	LOAD.W	(A6)+OPLANAV+OPLANA,#FXCENSCALE	.W	PLANA_FONC	CALL	ARROOWDO	RET;---------\\; NEWSCALE >;=========/; On doit appeler cette routine chaque fois que l'chelle; a t change.; in	-; out	-; mod	-NEWSCALE:	LOAD.W	(A6)+OPLANAV+OPLANA,#FXNEWSCALE	.W	PLANA_FONC	RET;--------\; AJMWDO  >;========/; Ajuste les minimums OMWDOX et OMWDOY, afin d'tre; pas trop petits.; in	-; out	-; mod	-AJMWDO:	LOAD.W	(A6)+OPLANAV+OPLANA,#FXAJMWDO	.W	PLANA_FONC	CALL	ARROOWDO	RET;--------\\; AJOWDO  >;========/; Ajuste l'origine de la partie visible afin de voir; au moins un bout.; in	-; out	-; mod	-AJOWDO:	LOAD.W	(A6)+OPLANAV+OPLANA,#FXAJOWDO	.W	PLANA_FONC	CALL	ARROOWDO	RET	.END