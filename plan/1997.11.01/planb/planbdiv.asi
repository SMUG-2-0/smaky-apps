	.SBTTL	PLANBDIV;************** _PLANB_OUVRE:;**************;; initialise BIBLIO; - sauver cran PLAN; - charger image gnrique ou par dfaut BBPLAN.IMAGE;   (pour dire: il y a quelque chose en cours!); - lire les images; - afficher image courante;; in	A0.L	^ variables PLANB;	A5.L	^ variables PLANA;; out	variables; mod	D7.W	erreur;	PUSHM.L	D1,D2,D4,A3,A4	LOAD.W	(A0)+OBNOIMA,#0	CLR.L	(A0)+OBPENT		; pour premier INIHAUTB !	CALL	PUSHECRPLAN		; sauver cran PLAN	JUMP,NE	90$	LOAD.W	D4,#0			; souris = sablier	LIB	?WAITMOUSE					; image gnrique utilisateur ?	LOAD.L	A3,#(A0)+OBMEMFIO	; lire image 'VIDE'	LOAD.L	A4,#(A0)+OBBTEMP05$:	LOAD.B	(A4+),(A3+)		; copie le nom complet	JUMP,NE	05$	LOAD.L	A3,#(A0)+OBBTEMP	LOAD.W	D1,#1	LOAD.L	A4,#R16"TXIMAGE	LIB	?ADDEXT	CALL	RDIMA	JUMP,NE	08$			; non => 08$					; oui ...	LOAD.L	D4,#0*H'10000+HBTIT;;	LOAD.L	D2,(A2)+OIMDLX		; D2 <-- larg./haut	LOAD.L	D2,#LBWDOX*H'10000+(LBWDOY-HBTIT) ; dim maximales	CALL	AFFIMA			; ... affiche	JUMP,NE	90$	LOAD.L	A4,A1			; rendre mmoire	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	JUMP,NE	90$	jump	10$			; suite en 10$08$:					; image gnrique par dfaut	LOAD.L	A3,#R16"TXBPLANI	CALL	RDIMA	JUMP,NE	10$					; non, affiche #:BBPLAN.IMAGE	LOAD.L	D4,#0*H'10000+HBTIT;	LOAD.L	D2,(A2)+OIMDLX		; D2 <-- larg./haut	LOAD.L	D2,#LBWDOX*H'10000+(LBWDOY-HBTIT)	CALL	AFFIMA	JUMP,NE	90$	LOAD.L	A4,A1			; rendre mmoire	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	JUMP,NE	90$10$:	CALL	INIHAUTB		; ligne du haut					; lire image pour pav VIDE	LOAD.L	(A0)+OBPVIDE,#0	LOAD.L	A3,#R16"TXBPLANV	CALL	RDIMA	JUMP,NE	20$19$:	LOAD.L	(A0)+OBPVIDE,A1		; mmorise pointeur image 'vide'20$:	TEST.B	(A0)+OBFLAGS:#BININEW	; nlle BIBLIO  crer ?	JUMP,BC	30$	CALL	ININEWB			; oui, initialise le tout	JUMP,NE	90$	TCLR.B	(A0)+OBFLAGS:#BININEW	JUMP	40$30$:	CALL	RDENTETE		; lire l'entte de BBPLAN	JUMP,NE	90$	CALL	RDIMAGES		; lire toutes les images40$:	CALL	POPECRPLAN		; restitue cran PLAN90$:	LOAD.W	D4,#1			; souris = flche	LIB	?WAITMOUSE	POPM.L	D1,D2,D4,A3,A4	TEST.W	D7	RETTXBPLANI:	.ASCIZE	"#:BBPLAN.IMAGE"	; image gnrique par dfautTXBHELPM:	.ASCIZE	"#:BBPLAN_HM.IMAGE"	; image d'aide 'modification'TXBHELPU:	.ASCIZE	"#:BBPLAN_HU.IMAGE"	; image d'aide 'utilisation'TXBPLANV:	.ASCIZE	"#:BBPLAN_V.IMAGE"	; image 'vide'TXIMAGE:	.ASCIZE	".IMAGE"TXPLAN:	.ASCIZE	".BBPLAN"	.EVEN;*************** _PLANB_BIBLIO:;***************;; Interaction BIBLIO; - rend SPOS pointant le dbut de l'lment  prendre (DB...);   avec flag BCHARGE si choix;; in	A0.L	^ variables PLANB;	A5.L	^ variables PLANA;; out	SPOS	 l'lment avec BCHARGE;	en BMODIFIE BIBLIO modifie v.; mod	D7.W	erreur;	CALL	PUSHECRPLAN		; non, ...05$:	TEST.B	(A0)+OBFLAGS:#BINSCRIT	; si inscription, alors souris = matrice	JUMP,BC	10$	CALL	MOUSEMAT10$:	CALL	BAFFPAGE		; affiche page courante	JUMP,NE	90$					; attendre action ds. BIBLIO	TCLR.B	(A0)+OBFLAGS:#BCHARGE	; encore rien  charger	JUMP	BBOUCLE			; INTERACTION ============>>>>;;;;;;;;;;;;;;;; erreur90$:	TEST.W	D7	RET;************** _PLANB_FERME:;**************;; met  jour avant de quitter; 'modifie' => sauver l'entte et les images; 'utilise' => fermer et librer la mmoire;; in	A0.L	^ variables PLANB;	A5.L	^ variables PLANA;; out	-; mod	D7.W	erreur;DOBFIN:					; quitter BIBLIO, retour  PLAN	call	normouse	TEST.B	(A0)+OBFLAGS:#BMODIFIE	JUMP,BC	10$					; mettre  jour si ncessaire et ...	CALL	BIBLIOMAJ10$:	LOAD.W	D6,(A0)+OBCHBIB		; fermer le fichier	JUMP,EQ	20$	FOS	?CLOSE20$:					; librer toute la mmoire images	CLR.W	(A0)+OBNOIMA25$:	CALL	D2IMAGE	LOAD.L	A4,(A0)+OBPENT	TEST.B	(A4)+(D2.W)+OICRT	; utilis ?	JUMP,NS	26$			; non, suivant	LOAD.L	A4,(A4)+(D2.W)+OPIMEM	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM26$:	INC.W	(A0)+OBNOIMA	COMP.W	(A0)+OBNOIMA,#MAXIMA	JUMP,LO	25$	LOAD.W	D1,#MTYPCP		; rend mmoire entte	LOAD.L	A4,(A0)+OBPENT	GESMEM	?GIVMEM	TEST.L	(A0)+OBPVIDE		; pav 'VIDE'	jump,EQ	30$			; non ...	LOAD.L	A4,(A0)+OBPVIDE		; oui, rend mmoire	GESMEM	?GIVMEM30$:	CLR.L	(A0)+OBMEMF		; plus de BIBLIO	CLR.W	(A0)+OBNOIMA	LOAD.W	D3,#BIPDONE	LIB	?BEEP90$:	CALL	POPECRPLAN		; remet wdo PLAN	CLR.B	(A0)+OBFLAGS		; UTILISE, rinitialise flags;;;;;;	CLR.W	(A0)+OBNOIMA	RET;---------- BIBLIOMAJ:;----------;; met  jour la bibliothque;	LOAD.W	D4,#0		; souris = sablier	LIB	?WAITMOUSE	TEST.B	(A0)+OBFLAGS:#BSUPPRIME	; a-t-on supprim un lment ?	JUMP,BC	10$			; non				; oui, ...	CALL	MAJINDEX	; mj des index pavs, supprime les 'trous'10$:	CALL	WRENTETE	; crire l'entte	CALL	WRIMAGES	; crire les images	CALL	EXCLOUTB	; crer fichier!BBPLAN	LOAD.W	D4,#1		; souris = flche	LIB	?WAITMOUSE	RET;----------\\  EXCLOUTB: ;>;==========/;; crit le fichier "!" pour START;	PUSHM.L	D3,D4,D6,A2,A3	LOAD.L	A3,#(A0)+OBBTEMP	LOAD.L	A2,#(A0)+OBMEMFIO	LOAD.B	D3,(A2)	JUMP,EQ	90$		; pas de nom05$:	LOAD.B	(A3+),(A2+)	JUMP,NE	05$	LOAD.L	A3,#(A0)+OBBTEMP	LOAD.L	A4,#R16"TXPLAN	; A4 ^extension	LOAD.W	D3,#1		; force extension	LIB	?ADDEXT	LOAD.L	A2,A3	PUSH.L	A310$:	LOAD.B	D3,(A3)	COMP.B	D3,#':		; A2 ^':	JUMP,NE	11$	LOAD.L	A2,A3	INC.L	A2		; A2 ^aprs le ':11$:	LIB	?MINMAJ		; en MAJUSCULES svp.	LOAD.B	(A3+),D3	COMP.B	D3,#'.	JUMP,NE	10$		LOAD.B	(A3)-1,#'!	; trouv '. et mettre '!  la place	POP.L	A3	FOS	?DELETE		; dtruit le fichier sans pravis	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	TCLR.L	D3:#BATTX	;	-X	TCLR.L	D3:#BATTC	;	-C	TCLR.L	D3:#BATTL	;	-L	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	FOS	?CREATE		; cre fichier!PLAN	JUMP,NE	80$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouverture, D6 <-- canal	JUMP,NE	80$	LIB	?PCHDIS		; canal  LIB pour criture	LIB	?BUCAR	LOAD.L	A3,A2		; A3 ^aprs un v. ':	PUSH.L	A320$:	LOAD.B	D3,(A3+);;;;;	JUMP,EQ	90$		; pas trouv	COMP.B	D3,#'!	JUMP,NE	20$	LOAD.B	(A3)-1,#0	; trouv '! et mettre 0  la place	POP.L	A3;;;;;	LIB	?AFTIM;;;;;	.ASCII	/"gnrateurs de caractres"/;;;;;	.ASCII	"/1/E<CR>";;;;;	.ASCII	/"v. l'image du mme nom"/;;;;;	.ASCIZE	"/2/A<CR>"	PUSH.L	A3	LIB	?AFTEXT		; le nom suivi de !PLAN ...	POP.L	A3	LIB	?AFTIM	.ASCIZE	"!BBPLAN/D -CL<CR>"	PUSH.L	A3	LIB	?AFTEXT		; le nom suivi de .PLAN ...	POP.L	A3	LIB	?AFTIM	.ASCIZE	".BBPLAN/D -C+L<CR>"	PUSH.L	A3	LIB	?AFTEXT		; le nom suivi de .IMAGE ...	POP.L	A3	LIB	?AFTIM	.ASCIZE	".IMAGE/D/N -CL<CR>"	CALL	EXCLIMA		; crire les images utilises	LIB	?NOBUCAR	PUSH.W	D6	LOAD.W	D6,(A5)+OCHDIS	; redonne canal cran  LIB	LIB	?PCHDIS	POP.W	D6	FOS	?CLOSE		; ferme fichier80$:;;;;;	CALL	IOERROR90$:	POPM.L	D3,D4,D6,A2,A3	RET;--------- EXCLIMA:;---------;; crire les noms des images utilises;	PUSHM.L	D2,D3,A2,A3	PUSH.W	(A0)+OBNOIMA	CLR.W	(A0)+OBNOIMA		; init no. image	LOAD.L	A4,(A0)+OBPENT		; A4 ^ entte10$:	CALL	D2IMAGE			; D2 <-- offset	TEST.B	(A4)+(D2.W)+OICRT	; image utilise ?	JUMP,NS	20$			; non => 20$	CALL	NOMIMA			; oui, A3 ^nom	LOAD.L	A2,A3	PUSH.L	A315$:	LOAD.B	D3,(A3)			; en MAJUSCULES svp.	COMP.B	D3,#':	JUMP,NE	16$	LOAD.L	A2,#(A3)+1		; A2 ^ aprs v. ':16$:	LIB	?MINMAJ	LOAD.B	(A3+),D3	JUMP,NE	15$	POP.L	A3	LOAD.L	A3,A2	LIB	?AFTEXT			; crit ...	LIB	?AFTIM	.ASCIZE	"/D -CL<CR>"		; ... ajoute20$:	INC.W	(A0)+OBNOIMA		; image suivante	COMP.W	(A0)+OBNOIMA,#MAXIMA	; maximum ?	JUMP,NE	10$			; non => 10$	POP.W	(A0)+OBNOIMA	POPM.L	D2,D3,A2,A3	RET;---------- MAJINDEX:;----------;; compactage du fichier (limination des lments supprims); et mise  jour des index des pavs;	PUSHM.L	D3,D4,D6,A4	LOAD.W	D6,(A0)+OBCHBIB		; D6 <-- canal BIBLIO	LOAD.L	A4,#(A0)+OBBTEMP	; ^ buffer de l'lment	LOAD.W	D4,#MAXIMA		; MAXIMA	LOAD.W	D3,#MAXPAVE		; MAXPAVE	MUL.WU	D3,D4			; D3 <-- OMAXPAVE * OMAXIMA	MUL.WU	D3,#LGIPAVE		; D3 <-- ... * LGIPAVE	MUL.WU	D4,#LGIMAB		; D4 <-- OMAXIMA * LGIMAB	ADD.L	D4,D3			; D4 <-- D4 + D3	ADD.L	D4,#LGBPREM		; D4 <-- ... + LGBPREM	CLR.B	D3	LOAD.B	(A0)+OBRDD3,D3	LOAD.L	(A0)+OBRDD4,D4		; init pos. lecture	LOAD.B	(A0)+OBWRD3,D3	LOAD.L	(A0)+OBWRD4,D4		; init pos. criture	FOS	?SPOS			; pos  la fin d'entte	JUMP,NE	90$	JUMP	20$10$:					; non, index pas dans la liste	CALL	RDELEM$			; lit lment	JUMP,NE	90$	CALL	OBJFB$			; fin ?	JUMP,NE	10$			; non, continue					; oui, fin lu20$:	CALL	INDEXRD?	; l'index de lecture fait-t-il partie de la liste ?	JUMP,NE	10$30$:					; oui, index dans la liste	CALL	RDELEM$	JUMP,NE	90$	CALL	WRELEM$			; crit cet lment	JUMP,NE	90$	CALL	OBJFB$			; tait-ce fin ?	JUMP,NE	30$			; non, continue	JUMP	20$		; index suivant90$:	COMP.W	D7,#EROUTF	JUMP,NE	95$	LOAD.B	D3,(A0)+OBWRD3		; nlle. fin de fichier	LOAD.L	D4,(A0)+OBWRD4	FOS	?SPOS	jump,ne	95$	FOS	?TRUNC			; fin de fichier dtruit95$:	POPM.L	D3,D4,D6,A4	TEST.W	D7	RETRDELEM$:			; lit lment	LOAD.B	D3,(A0)+OBRDD3	LOAD.L	D4,(A0)+OBRDD4	FOS	?SPOS	JUMP,NE	RDEM9$	LOAD.L	D4,#LGELEMENT	FOS	?RDBYTE	JUMP,NE	RDEM9$	FOS	?GPOS	JUMP,NE	RDEM9$	LOAD.B	(A0)+OBRDD3,D3	LOAD.L	(A0)+OBRDD4,D4RDEM9$:	TEST.W	D7		RETWRELEM$:			; crit lment	LOAD.B	D3,(A0)+OBWRD3	LOAD.L	D4,(A0)+OBWRD4	FOS	?SPOS	JUMP,NE	WREM9$	LOAD.L	D4,#LGELEMENT	FOS	?WRBYTE	JUMP,NE	WREM9$	FOS	?GPOS	JUMP,NE	WREM9$	LOAD.B	(A0)+OBWRD3,D3	LOAD.L	(A0)+OBWRD4,D4WREM9$:	TEST.W	D7	RETOBJFB$:				; OBJFBIBLIO ?	LOAD.W	D7,#1	COMP.B	(A4)+OMOBJET+1,#OBJFBIBLIO	JUMP,NE	DB9$	CLR.W	D7DB9$:	TEST.W	D7	; NE = non; EQ = oui	RET;---------- INDEXRD?:;----------;; index de lecture dans la liste ?; si oui mettre index d'critue  la place; sinon D7 = 1;; NE = pas dans la liste; EQ = dans la liste;	PUSHM.L	D2,D3,D4,A4	PUSH.W	(A0)+OBNOIMA	PUSH.L	(A0)+OBNOPAV	LOAD.L	A4,(A0)+OBPENT		; A4 ^ entte	CLR.W	(A0)+OBNOIMA		; init image10$:	CLR.L	(A0)+OBNOPAV		; init pav	jump	65$60$:	INC.W	(A0)+OBNOPAV+2		; suivant	COMP.W	(A0)+OBNOPAV+2,#8	JUMP,LO	65$	CLR.W	(A0)+OBNOPAV+2	INC.W	(A0)+OBNOPAV65$:	COMP.L	(A0)+OBNOPAV,#3*H'10000+7			; max ?	JUMP,GT	70$			; oui => 70$	CALL	D2PAVE			; D2 <-- offset	LOAD.B	D3,(A0)+OBRDD3	COMP.B	D3,(A4)+(D2.W)+OSPOSH	; index high lecture  ?	jump,ne	60$			; non	LOAD.L	D4,(A0)+OBRDD4		; et index low lecture	COMP.L	D4,(A4)+(d2.W)+OSPOSL	jump,ne	60$			; non	TEST.B	(A4)+(d2.W)+OIPCRT	; pav valable ?	JUMP,NS	60$			; non	LOAD.B	(A4)+(d2.W)+OSPOSH,(A0)+OBWRD3 ; oui, mettre index criture  la place	LOAD.L	(A4)+(d2.W)+OSPOSL,(A0)+OBWRD4	CLR.W	D7	jump	90$70$:	INC.W	(A0)+OBNOIMA		; image suivante	COMP.W	(A0)+OBNOIMA,#MAXIMA	; max atteint ?	JUMP,NE	10$			; non	LOAD.W	D7,#190$:	POP.L	(A0)+OBNOPAV        POP.W	(A0)+OBNOIMA	POPM.L	D2,D3,D4,A4	TEST.W	D7	RET;--------- ININEWB:;---------;; initialise tout pour une nlle. BIBLIO  crer;	PUSHM.L	D1..D6,A3,A4	CLR.L	D3	CLR.L	D4	LOAD.B	D4,#MAXIMA	LOAD.B	D3,#MAXPAVE	MUL.WU	D3,D4			; D3 <-- OMAXPAVE * OMAXIMA	MUL.WU	D3,#LGIPAVE		; D3 <-- ... * LGIPAVE	MUL.WU	D4,#LGIMAB		; D4 <-- OMAXIMA * LGIMAB	ADD.L	D4,D3			; D4 <-- D4 + D3	ADD.L	D4,#LGBPREM		; D4 <-- ... + LGBPREM	LOAD.W	D1,#MTYPCP		; demande Mmoire	GESMEM	?GETMEM	JUMP,NE	90$	LOAD.L	(A0)+OBPENT,A4		; mmorise pointeur mmoire20$:	PUSHM.L	D4,A4	DEC.L	D421$:					; met le tout  zro	CLR.B	(A4+)	DECJ.W,NMO D4,21$	POPM.L	D4,A4					; initialisations	LOAD.B	(A4)+OMAXIMA,#MAXIMA		; entte ...	LOAD.B	(A4)+OMAXPAVE,#MAXPAVE;	LOAD.B	(A4)+OETAT,#;	LOAD.B	(A4)+ONBIMA,#0	LOAD.B	(A4)+OREVPLAN,(A0)+OBPLANREV	; revision PLAN	LOAD.B	(A4)+OVERPLAN,(A0)+OBPLANVER	; version PLAN					; boucle initialisation IMAGES	LOAD.W	D1,#030$:	LOAD.W	D2,#LGIMAB		; D2 <-- offset	MUL.WU	D2,D1	ADD.L	D2,#LGBPREM	LOAD.B	(A4)+(D2.W)+OIORDRE,D1	; <-- no. d'ordre	LOAD.B	(A4)+(D2.W)+OICRT,#-1	; <-- no courant	INC.W	D1			; suivant	COMP.W	D1,#MAXIMA		; maximum atteint	JUMP,LO	30$			; non, suivant					; boucle initialisation PAVES	LOAD.W	D3,#0			; no. image39$:	LOAD.W	D1,#0			; no. pav40$:	LOAD.W	D5,#LGIPAVE*MAXPAVE	MUL.WU	D5,D3	LOAD.W	D2,#LGIPAVE	MUL.WU	D2,D1	ADD.L	D2,D5	ADD.L	D2,#LGBPREM+(MAXIMA*LGIMAB)	LOAD.B	(A4)+(D2.W)+OIIORDRE,D3	LOAD.B	(A4)+(D2.W)+OIPORDRE,D1	LOAD.B	(A4)+(D2.W)+OIPCRT,#-1	INC.W	D1	COMP.W	D1,#MAXPAVE		; max. pavs atteint ?	JUMP,LO	40$			; non, suivant	INC.W	D3	COMP.W	D3,#MAXIMA		; max. image atteint ?	JUMP,LO	39$			; non, suivant					; crire  cause de SPOS !!	LOAD.W	D6,(A0)+OBCHBIB	FOS	?WRBYTE	JUMP,NE	80$	JUMP	90$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP		; erreur rend mmoire	GESMEM	?GIVMEM	POP.W	D7	JUMP	90$90$:	POPM.L	D1..D6,A3,A4	TEST.W	D7	RET;--------- INIHAUTB:;---------;; affiche la ligne du haut de l'cran; nom, no page etc.;	PUSHM.L	D2,D3,D4,A3;	TEST.B	(A0)+OBFLAGS:#BSECRP;	JUMP,BS	12$	LOAD.L	A3,#R16"BTXMENU	TEST.B	(A0)+OBFLAGS:#BMODIFIE		; utilisation ou modification ?	JUMP,BC	10$	LOAD.L	A3,#R16"BTXMENUM10$:	LIB	?AFMENU12$:	CALL	USEWDOB				; indispensable !!!	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	TRUNC,AFINV			; trunc et affinv	.EVEN	LOAD.L	A3,#(A5)+OBWRITE		; fond noir pour titre	LOAD.B	(A3)+0,#NUL	LOAD.B	(A3)+1,#TRAME	LOAD.L	(A3)+2,#H'FFFFFFFF	LOAD.L	(A3)+6,#H'FFFFFFFF	LOAD.B	(A3)+10,#NUL	LOAD.B	(A3)+11,#DRAWTRAME	LOAD.W	(A3)+12,D3	SWAP.W	D3	LOAD.W	(A3)+14,D3	SWAP.W	D3	LOAD.W	(A3)+16,#LBWDOX	LOAD.W	(A3)+18,(A5)+OCARY	INC.W	(A3)+18	INC.W	(A3)+18	LOAD.B	(A3)+20,#SETDOT	LOAD.W	D3,#21	LIB	?STRING;	JUMP,NE	...	CLR.L	D3	ADD.L	D3,#14*H'10000	LIB	?SETCURS	LIB	?AFTIM	.ASCIZE	" Bibliothque: "	LOAD.L	A3,#(A0)+OBMEMF			; nom de la bibliothque	LIB	?AFFILE	LOAD.W	D2,(A5)+OCARX	MUL.WU	D2,#(DENOM/8)+1	LOAD.W	D3,D2	LIB	?SETCURS	LIB	?AFTIM				; page ...	.ASCIZE	"page "	CLR.L	D4	LOAD.W	D4,(A0)+OBNOIMA	JUMP,NC	15$	LIB	?AFTIM	.ASCIZE	" "	JUMP	17$15$:	inc.l	d4	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDALL			; no. ...	LIB	?AFDEC	LIB	?AFTIM	.ASCIZE	": "	CALL	D2IMAGE	TEST.L	(A0)+OBPENT	JUMP,EQ	17$	LOAD.L	A3,(A0)+OBPENT	LOAD.L	A3,#(A3)+(D2.W)+OINOM		; et nom de la page	LIB	?AFTEXT17$:	CLR.L	D3	ADD.L	D3,#14*H'10000	LOAD.W	D2,(A5)+OCARX	MUL.WU	D2,#(ANOM/8)+3	LOAD.W	D3,D2	LIB	?SETCURS	TEST.B	(A0)+OBFLAGS:#BINSCRIT		; signification des boutons	JUMP,BC	18$	LIB	?AFTIM	.ASCIZE	" | place | page | "	JUMP	20$18$:	LIB	?AFTIM	.ASCIZE	" | choix | page | "19$:	TEST.B	(A0)+OBFLAGS:#BMODIFIE	JUMP,BC	20$	LIB	?AFTIM	.ASCIZE	"modifie |"	JUMP	30$20$:	LIB	?AFTIM	.ASCIZE	"        |"30$:90$:	POPM.L	D2,D3,D4,A3	RET;------------- PUSHECRPLAN:;-------------;; sauve fentre PLAN, cre et efface la sous-fentre BIBLIO;; in	-; out	-; mod	D7.W	erreur;	PUSHM.L	D3,D4,A3	TEST.B	(A0)+OBFLAGS:#BSECRP	JUMP,BS	90$	LIB	?BUZZ	LIB	?BUZZ	LOAD.W	D4,(A5)+OWDOX		; D4 <-- coord, sous-fentre centre	SUB.W	D4,#LBWDOX	SR.W	D4	SWAP.W	D4	LOAD.W	D4,(A5)+OWDOY	SUB.W	D4,#LBWDOY	SR.W	D4	LOAD.L	A3,#(A5)+OBWRITE	; sous-fentre	LOAD.B	(A3)+0,#NUL	LOAD.B	(A3)+1,#DIMWDO	LOAD.L	(A3)+2,D4	LOAD.W	(A3)+6,#LBWDOX	LOAD.W	(A3)+8,#LBWDOY	LOAD.B	(A3)+10,#SAVWDO		; sauve ...;	LOAD.B	(A3)+11,#EOP;	LOAD.W	D3,#12	load.w	d3,#11	LIB	?STRING;	JUMP,NE	90$	TSET.B	(A0)+OBFLAGS:#BSECRP90$:	POPM.L	D3,D4,A3	TEST.W	D7	RET;------------ POPECRPLAN:;------------;; restitue la fentre PLAN	PUSHM.L	D3,A3	TEST.B	(A0)+OBFLAGS:#BSECRP	; cran PLAN sauv ?	JUMP,BC	90$			; non	LOAD.L	A3,#(A5)+OBWRITE	; oui, restitue	LOAD.B	(A3)+0,#GETWDO	LOAD.B	(A3)+1,#DIMWDO	CLR.L	(A3)+2	LOAD.W	(A3)+6,(A5)+OWDOX	LOAD.W	(A3)+8,(A5)+OWDOY	LOAD.W	D3,#10	LIB	?STRING;	JUMP,NE	90$	TCLR.B	(A0)+OBFLAGS:#BSECRP	LIB	?BUZZ90$:	POPM.L	D3,A3	TEST.W	D7	RET;-------- AFFIMA:;--------;; affiche l'image;; in	A3	image en mmoire;	D4	coord. cran  xx,yy;	D2	larg./haut. de l'image; out	-; mod	D7.W;	PUSHM.L	D3,D5,A3	LOAD.L	D3,A3	LOAD.L	A3,#(A5)+OBWRITE	LOAD.L	D5,D2			; D5 <-- Iy image en mmoire	SWAP.W	D5	SR.W	D5,#3	LOAD.B	(A3)+0,#NUL	LOAD.B	(A3)+1,#DRAWRASTER	CLR.L	(A3)+2			; coord. source (x,y)	LOAD.L	(A3)+6,D3		; ^mm. image	LOAD.W	(A3)+10,D5		; Iy image en mm.	load.l	(a3)+12,d4		; coord. dest. (x,y)	CLR.L	(A3)+16			; ^nil p. cran	CLR.W	(A3)+20	load.l	(a3)+22,d2		; largeur, hauteur	LOAD.B	(A3)+26,#LOADDOT	; mode	LOAD.W	D3,#27	LIB	?STRING90$:	POPM.L	D3,D5,A3	TEST.W	D7	RET;--------- BAFFPAGE:;---------;; affiche la page courante de BIBLIO au centre de l'cran; si OBNOIMA = -1 afficher page vide;; in	OBNOIMA.W; out	-; mod	D7.W;	PUSHM.L	D0..D4,A3,A4					; no. image en cours	LOAD.W	D0,(A0)+OBNOIMA	JUMP,NS	40$	CALL	PINFOIMA		; D2 <-- offset, A4 <-- ^entte	JUMP,NE	40$	LOAD.L	A3,(A4)+(D2.W)+OPIMEM	; A3 ^ mmoire avec image	LOAD.L	A3,#(A3)+IMLBUF		; A3 ^ image en mmoire	LOAD.L	D4,#0*H'10000+HBTIT	LOAD.L	D2,#LBWDOX*H'10000+LBWDOY-HBTIT ; larg/haut	CALL	INIHAUTB	CALL	AFFIMA	JUMP	90$40$:					; afficher page vierge	LOAD.B	D3,#EOP			; efface	LIB	?AFCAR	CALL	INIHAUTB		; ligne du haut	LOAD.W	D0,#0			; dessine verticales	LOAD.L	A3,#(A5)+OBWRITE	LOAD.B	(A3)+0,#NUL	LOAD.B	(A3)+1,#DRAWSEG	LOAD.L	(A3)+6,#(LBWDOY-HBTIT)	LOAD.B	(A3)+10,#SETDOT	LOAD.W	D3,#11	LOAD.L	D4,#(HBTIT)	JUMP	46$45$:	ADD.L	D4,#(LBWDOX/8)*H'1000046$:	LOAD.L	(A3)+2,D4	LIB	?STRING	INC.W	D0	COMP.W	D0,#8-1	JUMP,LS	45$	ADD.L	D4,#((LBWDOX/8)-1)*H'10000 ; la dernire	LOAD.L	(A3)+2,D4	LIB	?STRING	LOAD.W	D0,#0			; dessine horizontales	LOAD.L	A3,#(A5)+OBWRITE	LOAD.B	(A3)+0,#NUL	LOAD.B	(A3)+1,#DRAWSEG	LOAD.L	(A3)+6,#(LBWDOX)*H'10000	LOAD.B	(A3)+10,#SETDOT	LOAD.W	D3,#11	LOAD.L	D4,#HBTIT	JUMP	51$50$:	ADD.L	D4,#(LBWDOY-HBTIT)/451$:	LOAD.L	(A3)+2,D4	LIB	?STRING	INC.W	D0	COMP.W	D0,#4-1	JUMP,LS	50$;	ADD.L	D4,#(LBWDOY-HBTIT/4)-2	load.l	d4,#lbwdoy-1		; la dernire	LOAD.L	(A3)+2,D4	LIB	?STRING					; pavs 'VIDE'	TEST.L	(A0)+OBPVIDE	JUMP,EQ	70$			; image inexistante	CLR.L	D1	LOAD.L	A3,(A0)+OBPVIDE	LOAD.L	A3,#(A3)+IMLBUF	jump	65$60$:	INC.W	D1	COMP.W	D1,#8	JUMP,LO	65$	CLR.W	D1	SWAP.W	D1	INC.W	D1	SWAP.W	D165$:	COMP.L	D1,#3*H'10000+7		; max ?	JUMP,GT	70$			; oui => 70$	CALL	CORPAVE			; D3 <-- coord. source	LOAD.L	D4,D3	SWAP.W	D4	ADD.L	D4,#2*H'10000+2	LOAD.L	D2,#72*H'10000+72	; BDXPAVE*H'10000+BDYPAVE	CALL	AFFIMA	JUMP,EQ	60$70$:90$:	POPM.L	D0..D4,A3,A4	TEST.W	D7	RET;-------- mouse?:;--------;; si hors de la fentre, alors flche; sinon matrice;	PUSHM.L	D3	TEST.B	(A0)+OBFLAGS:#BINSCRIT		; pour inscription seulement	JUMP,BC	90$	CALL	BIFMOUSE	JUMP,NE	20$	TEST.B	(A0)+OBFLAGS:#BMNORM	JUMP,BS	05$	ADD.L	D4,#(LBWDOX/(8*2))*H'10000+((LBWDOY-HBTIT)/(4*2)) ; centre pav05$:	CALL	BLIMITE				; ds. fentre ?	JUMP,EQ	40$				; oui => 40$20$:						; non =>	TEST.B	(A0)+OBFLAGS:#BMNORM	JUMP,BC	90$	CALL	NORMOUSE	JUMP	90$40$:	TEST.B	(A0)+OBFLAGS:#BMNORM	JUMP,BS	90$	CALL	MOUSEMAT90$:	POPM.L	D3	RET;=========================; BOUCLE principale BIBLIO;=========================;======= BBOUCLE:;=======;; attendre action ds. BIBLIO;;;;;;;;;	; F0	Shift id.	- mj. et ferme BIBLIO	; F3		- Sauve	- mj. et reste dans BIBLIO	; F4..F6		- suppr. toute la page	; F7..F9		- dplace la page	; F10..F12		- affiche page suiv., prc.	; F13..F14  Shift id.	- retour  PLAN	; KEYMOGP	- slctionne parmi 32 pavs	; KEYMOMP	- slction de la page	; KEYMORP	- MMENU modif (suppr.,dplace...);;;;;;;;;00$:	LIB	?GETKEY		; attend clavier/souris	TEST.L	D3:#BKPSEUDO	; pseudo code/touche relach ?	JUMP,BS	00$		; non	COMP.W	D3,#KEYMPO	; souris boug ?	JUMP,NE	1$	test.b	(a0)+OBFLAGS:#BINSCRIT	jump,bc	00$	call	mouse?1$: 	COMP.W	D3,#KEYMGP	JUMP,EQ	40$	COMP.W	D3,#KEYMMP	; bouton press ?	JUMP,EQ	60$	COMP.W	D3,#KEYMDP	JUMP,EQ	80$	COMP.W	D3,#KEYMGR	JUMP,EQ	00$	COMP.W	D3,#KEYMMR	; bouton relach ?	JUMP,EQ	00$	COMP.W	D3,#KEYMDR	JUMP,EQ	00$	LOAD.W	D2,D3	LIB	?MINMAJ		; D2 <-- car. en MAJ	EX.L	D2,D3	COMP.W	D3,#F0	JUMP,EQ	DOBFIN	COMP.W	D3,#SHIFT+F0	JUMP,EQ	DOBFIN				; CE QUI SUIT EN MODE MODIFIE SEULEMENT	TEST.B	(A0)+OBFLAGS:#BMODIFIE	JUMP,BC	01$	COMP.W	D3,#F3	JUMP,EQ	DOBMAJ	COMP.W	D3,#SHIFT+F3	JUMP,EQ	DOBMAJ	COMP.W	D3,#SHIFT+F4	JUMP,EQ	DOKILLP	COMP.W	D3,#F4	JUMP,EQ	DOKILLP	COMP.W	D3,#SHIFT+F5	JUMP,EQ	DOKILLP	COMP.W	D3,#F5	JUMP,EQ	DOKILLP	COMP.W	D3,#SHIFT+F6	JUMP,EQ	DOKILLP	COMP.W	D3,#F6	JUMP,EQ	DOKILLP	COMP.W	D3,#SHIFT+F7	JUMP,EQ	DOPREVM	COMP.W	D3,#F7	JUMP,EQ	DOPREVM	COMP.W	D3,#SHIFT+F8	JUMP,EQ	59$	COMP.W	D3,#F8	JUMP,EQ	59$	COMP.W	D3,#SHIFT+F9	JUMP,EQ	DONEXTM	COMP.W	D3,#F9	JUMP,EQ	DONEXTM					; EN MODE UTILISATION ET MODIFIE01$:	COMP.W	D3,#SHIFT+F10	JUMP,EQ	DOPREVP	COMP.W	D3,#F10	JUMP,EQ	DOPREVP	COMP.W	D3,#SHIFT+F11	JUMP,EQ	59$	COMP.W	D3,#F11	JUMP,EQ	59$	COMP.W	D3,#SHIFT+F12	JUMP,EQ	DONEXTP	COMP.W	D3,#F12	JUMP,EQ	DONEXTP	COMP.W	D3,#F13	JUMP,EQ	DOBRET	COMP.W	D3,#SHIFT+F13	JUMP,EQ	DOBRET	COMP.W	D3,#F14	JUMP,EQ	DOBRET	COMP.W	D3,#SHIFT+F14	JUMP,EQ	DOBRET	COMP.W	D3,#F15	JUMP,EQ	DOBRET	COMP.W	D3,#SHIFT+F15	JUMP,EQ	DOBRET	COMP.B	D2,#HELP	JUMP,EQ	20$59$:					; invalide, bip	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	00$20$:					; HELP	LOAD.L	A3,#R16"TXBHELPM	TEST.B	(A0)+OBFLAGS:#BMODIFIE	JUMP,BS	21$	LOAD.L	A3,#R16"TXBHELPU21$:	CALL	RDIMA	JUMP,EQ	22$	LOAD.W	D3,#BIPERR		; inexistant	LIB	?BEEP	JUMP	90$22$:					; non, affiche BBPLAN_H.IMAGE	LOAD.L	D4,#0*H'10000+HBTIT	LOAD.L	D2,(A2)+OIMDLX		; D2 <-- larg./haut	CALL	AFFIMA	JUMP,NE	90$	LOAD.L	A4,A1			; rendre mmoire	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	JUMP,NE	90$	LIB	?GETCAR			; attend touche	CALL	BAFFPAGE		; remet page courante	JUMP	00$40$:				; bouton GAUCHE press, SELECTIONNE pav	TEST.B	(A0)+OBFLAGS:#BINSCRIT	; nlle inscription ?	JUMP,BS	50$			; oui => 50$	CALL	BPDET			; dtecte et allume pav	JUMP,NE	00$	LIB	?BUZZ	LOAD.L	D1,(A0)+OBNOPAV	LOAD.W	D2,#INVDOT	CALL	BALLUME			; teint	CALL	NORMOUSE		; souris normale	CALL	POPECRPLAN		; remet cran PLAN	LOAD.L	A4,(A0)+OBPENT		; met SPOS sur lment  charger	CALL	D2PAVE	LOAD.B	D3,(A4)+(D2.W)+OSPOSH	LOAD.L	D4,(A4)+(D2.W)+OSPOSL	LOAD.W	D6,(a0)+OBCHBIB	FOS	?SPOS	TSET.B	(A0)+OBFLAGS:#BCHARGE	; signal charger l'lment  SPOS	TEST.W	D7	RET50$:				; PLACE pav ( seulement  un emplacement vide !)	CALL	BPDET			; dtecte	JUMP,NE	55$			; libre	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	89$			; occup55$:	CALL	BZPAVIMA		; libre, met pav dans l'image	LOAD.L	D1,(A0)+OBNOPAV		; utilis ...	LOAD.W	D2,#INVDOT	CALL	BALLUME			; ... teint	CALL	BIMAMEM			; cran --> mmoire	LOAD.W	D6,(A0)+OBCHBIB		; positionne  la fin du fichier	LOAD.B	D3,#-1	LOAD.L	D4,#-1	FOS	?SPOS	COMP.W	D7,#EROUTF	jump,ne	DOBRET			; ??????????? !!!!!!!!!!!	CALL	D2PAVE			; mj. index pav	LOAD.L	A4,(A0)+OBPENT	LOAD.B	(A4)+(D2.W)+OIIORDRE,(A0)+OBNOIMA+1	CLR.B	(A4)+(D2.W)+OIPCRT	LOAD.B	(A4)+(D2.W)+OSPOSH,D3	LOAD.L	(A4)+(D2.W)+OSPOSL,D4					; crit  la fin du fichier !!!!!	LOAD.W	D4,#0	LIB	?WAITMOUSE	LOAD.L	D3,(A0)+OBD3ZONE	; zone dans PLAN	LOAD.L	D4,(A0)+OBD4ZONE	PUSHM.L	A1			; BOUTPUT	LOAD.L	A1,(A0)+OBADBOUTPUT	CALL	(A1)	POPM.L	A1	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POP.W	D7	TEST.W	D7	jump,NE	DOBRET			; ????????? !!!!!!!!!!!	TCLR.B	(A0)+OBFLAGS:#BINSCRIT	; plus d'inscription	CALL	NORMOUSE		; souris normale	CALL	INIHAUTB	JUMP	90$60$:				; bouton MILIEU press: MMENU PAGE	test.b	(a0)+obflags:#BMNORM	jump,bc	61$	CALL	NORMOUSE	LOAD.W	D4,#10	NTREL	?DELMS61$:	LOAD.L	A3,#R16"MBPAGE	LOAD.W	D3,(A0)+OBNOIMA	INC.W	D3	TEST.B	(A0)+OBFLAGS:#BMODIFIE	; mode 'modifie'?	JUMP,BS	62$			; oui	TSET.L	D3:#15	CALL	PAGEVIDE		; D4 <-- pages vides grises62$:	CALL	BMMENU			; menu pages	JUMP,NE	00$	DEC.B	D3	JUMP,NS	90$	AND.W	D3,#H'F	COMP.W	D3,(A0)+OBNOIMA	JUMP,EQ	90$	LOAD.W	(A0)+OBNOIMA,D3	CALL	BAFFPAGE	JUMP	90$;************************* MODIFICATIONS65$:				; ANNOTE pav *******************	CALL	BTEXTPAVE		; DBOX annotation	JUMP,NE	89$	LOAD.L	D1,(A0)+OBNOPAV		; teint le pav	LOAD.W	D2,#INVDOT	CALL	BALLUME	CALL	BANNOTEPAVE		; inscrit le texte	CALL	BIMAMEM			; sauve page en mmoire	JUMP	90$67$:				; v. NOM de PAGE ?	CALL	NOMPAGE?	JUMP,NE	00$			; non, => 00$					; oui ...	CALL	INOMPAGE	CALL	BTEXTPAGE	JUMP,NE	69$	CALL	BNOMPAGE		; inscrit le texte de la page	CALL	BAFFPAGE	JUMP	90$69$:	CALL	INOMPAGE		; teint zone avec nom page	jump	59$;***************************************VVVVVVV70$:				; DEPLACE dans une autre page *************; si tout est occup n'est pas rsolu !!!!!!!!!!!!!!	LOAD.L	A3,#R16"MBPAGE	LOAD.W	D3,(A0)+OBNOIMA	TSET.L	D3:#15	CALL	PAGEPLEINE		; pages pleines inaccessibles	INC.W	D3			; page d'origine	CALL	BMMENU			; menu pages	DEC.B	D3	JUMP,NS	89$	AND.W	D3,#H'F	COMP.W	D3,(A0)+OBNOIMA		; mme page, alors rien	JUMP,EQ	89$	CALL	MOUPAVE	load.w	d0,d3			; D0 <-- nouvelle page	LOAD.L	D1,(A0)+OBNOPAV		; efface l'ancien pav	LOAD.W	D2,#SETDOT	CALL	BALLUME	LOAD.W	D2,#INVDOT	CALL	BALLUME	LOAD.L	A4,(A0)+OBPENT		; mmorise index pav origine	LOAD.L	A3,#(A0)+OBSIPAVE	LOAD.W	D3,#LGIPAVE-1	CALL	D2PAVE			; D2 <-- offset origine	PUSH.W	D271$:	LOAD.B	(A3+),(A4)+(D2.W)	INC.W	D2	DECJ.W,NMO D3,71$	POP.W	D2	LOAD.B	(A4)+(D2.W)+OIPCRT,#-1	; efface index pav d'origine	CLR.B	(A4)+(D2.W)+OSPOSH	CLR.L	(A4)+(D2.W)+OSPOSL;...	CALL	TSTPAVE		; encore un pav ?	JUMP,EQ	A70$		; oui => A70$	CALL	D2IMAGE		; non, libre mmoire et annule image	LOAD.L	A4,(A0)+OBPENT	LOAD.B	(A4)+(D2.W)+OICRT,#-1	LOAD.L	A3,(A4)+(D2.W)+OPIMEM	CLR.L	(A4)+(D2.W)+OPIMEM	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	JUMP	A71$A70$:	TEST.L	(A0)+OBPVIDE		; met 'VIDE'	JUMP,EQ	A71$	CALL	CORPAVE			; D3 <-- coord. source	LOAD.L	D4,D3	SWAP.W	D4	ADD.L	D4,#2*H'10000+2	LOAD.L	D2,#72*H'10000+72	; BDXPAVE*H'10000+BDYPAVE	LOAD.L	A3,(A0)+OBPVIDE	LOAD.L	A3,#(A3)+IMLBUF	CALL	AFFIMA	CALL	BIMAMEM			; sauve page d'origineA71$:;...	LOAD.W	(A0)+OBNOIMA,D0		; OBNOIMA <-- nlle. page	LOAD.W	D3,#AFCCMO		; enlve 'souris'	LIB	?AFCAR	CALL	BAFFPAGE		; affiche nlle. page	LOAD.W	D3,#AFSCMO	LIB	?AFCAR			; remet 'souris'72$:lib	?getKEY	CALL	BPMOUSE			; contrle si dans limites	TEST.L	D3:#BMOLEFT	; bouton gauche ?	JUMP,BC	72$		; non				; oui =>73$:				; D4 pos (y;x)	ADD.L	D4,#(LBWDOX/(8*2))*H'10000+((LBWDOY-HBTIT)/(4*2)) ; centre pav	CALL	BPAVE			; D1 <- ligne/colonne	LOAD.L	(A0)+OBNOPAV,D1	CALL	BPAVE?	jump,EQ	72$			; utilis => 72$	CALL	BZPAVIMA		; libre, met pav dans l'image	LOAD.B	D3,#AFCCMO		; enlve la souris pav	LIB	?AFCAR	LOAD.L	D1,(A0)+OBNOPAV		; teint nouveau pav	LOAD.W	D2,#INVDOT	CALL	BALLUME	CALL	BIMAMEM			; cran en mmoire	LOAD.L	A3,#(A0)+OBSIPAVE	; copie l'index original	CALL	D2PAVE			; mj. index pav	LOAD.L	A4,(A0)+OBPENT	CLR.B	(A4)+(D2.W)+OIPCRT	LOAD.B	(A4)+(D2.W)+OIIORDRE,(A0)+OBNOIMA+1	LOAD.B	(A4)+(D2.W)+OSPOSH,(A3)+OSPOSH	; copie des pointeurs sauvs	LOAD.L	(A4)+(D2.W)+OSPOSL,(A3)+OSPOSL	TSET.B	(A0)+OBFLAGS:#BMNORM	CALL	NORMOUSE		; souris normale	CALL	INIHAUTB	CALL	WAITMOUSE	; ?????	JUMP	90$;***************************^^^^^^^80$:				; bouton DROITE press : MODIFIE ***>>>	TEST.B	(A0)+OBFLAGS:#BMODIFIE	; en modif seulement	JUMP,BC	59$	TEST.B	(A0)+OBFLAGS:#BINSCRIT	; mais pas en inscription	JUMP,BS	59$	CALL	BPDET	JUMP,NE	67$	LOAD.L	A3,#R16"MBMODIF	CALL	BMMENU			; menu modification	JUMP,NE	89$	AND.W	D3,#H'F	DEC.B	D3	JUMP,NS	89$	COMP.B	D3,#0	JUMP,EQ	85$			; supprime	COMP.B	D3,#2	JUMP,EQ	65$			; annote	COMP.B	D3,#3	JUMP,EQ	70$			; dplace dans une autre page81$:				; DEPLACE **********************	CALL	MOUPAVE			; souris devient le pav	LOAD.L	D1,(A0)+OBNOPAV		; teint l'ancien	LOAD.W	D2,#SETDOT	CALL	BALLUME	LOAD.W	D2,#INVDOT	CALL	BALLUME	CALL	DEPLAPAVE		; dplace le pav	LOAD.L	(A0)+OBNOPAV,D1		; origine utilise ?	CALL	D2PAVE	LOAD.L	A4,(A0)+OBPENT	TEST.B	(A4)+(D2.W)+OIPCRT	JUMP,NC	82$			; oui => 82$					; non, mettre 'VIDE'	TEST.L	(A0)+OBPVIDE	JUMP,EQ	82$	CALL	CORPAVE			; D3 <-- coord. source	LOAD.L	D4,D3	SWAP.W	D4	ADD.L	D4,#2*H'10000+2	LOAD.L	D2,#72*H'10000+72	; BDXPAVE*H'10000+BDYPAVE	LOAD.L	A3,(A0)+OBPVIDE	LOAD.L	A3,#(A3)+IMLBUF	CALL	AFFIMA82$:	CALL	BIMAMEM			; image en mmoire	JUMP	90$				; SUPPRIME ******************85$:	LOAD.L	D1,(A0)+OBNOPAV	LOAD.W	D2,#SETDOT	CALL	BALLUME				; supprimer l'lment correspondant	CALL	D2PAVE	LOAD.L	A4,(A0)+OBPENT	LOAD.B	(A4)+(D2.W)+OIPCRT,#-1	; ... et mise  zro pav	CLR.L	(A4)+(D2.W)+OSPOSL	CLR.B	(A4)+(D2.W)+OSPOSH	TSET.B	(A0)+OBFLAGS:#BSUPPRIME	; signal suppression, donc mj index en quittant	CALL	TSTPAVE		; encore un pav ?	JUMP,EQ	86$		; oui => 86$	CALL	D2IMAGE		; non, libre mmoire et annule image	LOAD.L	A4,(A0)+OBPENT	LOAD.B	(A4)+(D2.W)+OICRT,#-1	LOAD.L	A3,(A4)+(D2.W)+OPIMEM	CLR.L	(A4)+(D2.W)+OPIMEM	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CALL	BAFFPAGE	JUMP	90$86$:				; teint pav	LOAD.L	D1,(A0)+OBNOPAV	LOAD.W	D2,#INVDOT	CALL	BALLUME				; met 'VIDE'	TEST.L	(A0)+OBPVIDE	JUMP,EQ	87$	CALL	CORPAVE			; D3 <-- coord. source	LOAD.L	D4,D3	SWAP.W	D4	ADD.L	D4,#2*H'10000+2	LOAD.L	D2,#72*H'10000+72	; BDXPAVE*H'10000+BDYPAVE	LOAD.L	A3,(A0)+OBPVIDE	LOAD.L	A3,#(A3)+IMLBUF	CALL	AFFIMA87$:	CALL	BIMAMEM		; image en mmoire	JUMP	90$89$:				; teint pav	LOAD.L	D1,(A0)+OBNOPAV	LOAD.W	D2,#INVDOT	CALL	BALLUME90$:	CALL	WAITMOUSE		; attend boutons relachs	jump	00$			; et boucleDOBRET:	TCLR.B	(A0)+OBFLAGS:#BCHARGE	call	normouse	CALL	POPECRPLAN	; remete wdo PLAN	CLR.W	D7	test.W	D7	RETDOKILLP:			; supprime la page	CALL	KILLPAPAVES	; annule index pavs	LOAD.L	A3,(A0)+OBPENT		; A3 ^ entte	CALL	D2IMAGE			; D2 <-- offset	LOAD.B	(A3)+(D2.W)+OICRT,#-1	; annule	LOAD.L	A4,(A3)+(D2.W)+OPIMEM	; A4 ^ mmoire de l'image	CLR.L	(A3)+(d2.W)+OPIMEM	; efface pointeur mmoire	LOAD.W	D1,#MTYPCP		; rend mmoire	GESMEM	?GIVMEM	CALL	BAFFPAGE		; affiche page vide	JUMP	BBOUCLEDOPREVM:			; DEPLACE PAGE EN ARRIERE	TEST.W	(A0)+OBNOIMA	JUMP,EQ	90$	LOAD.W	D1,(A0)+OBNOIMA	DEC.W	D1			; D1 <-- destination	CALL	PERMINDEX		; permute les index pages et pavs	CALL	BAFFPAGE	JUMP	BBOUCLE90$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	BBOUCLEDONEXTM:			; DEPLACE LA PAGE EN AVANT	COMP.W	(A0)+OBNOIMA,#MAXIMA-1	JUMP,EQ	90$	LOAD.W	D1,(A0)+OBNOIMA	INC.W	D1			; D1 <-- destination	CALL	PERMINDEX		; permute les index pages et pavs	CALL	BAFFPAGE	JUMP	BBOUCLE90$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	BBOUCLEDOPREVP:			; PAGE PRECEDENTE	LOAD.W	D0,(A0)+OBNOIMA	JUMP,NS	90$	JUMP,ZS	90$	DEC.W	(A0)+OBNOIMA	TEST.B	(A0)+OBFLAGS:#BMODIFIE	; mode modifie ?	JUMP,BS	20$			; oui => 20$10$:					; non, utilisation	CALL	D2IMAGE	LOAD.L	A4,(A0)+OBPENT	TEST.B	(A4)+(D2.W)+OICRT	; image utilise ?	JUMP,NC	20$			; oui, => 20$	DEC.W	(A0)+OBNOIMA		; non, prcdente	JUMP,NC	10$	LOAD.W	(A0)+OBNOIMA,D0		; il n'y en  plus, remet page de dpart20$:	CALL	BAFFPAGE	JUMP	BBOUCLE90$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	BBOUCLEDONEXTP:			; PAGE SUIVANTE	LOAD.W	D0,(A0)+OBNOIMA	COMP.W	D0,#MAXIMA-1	JUMP,HS	90$	INC.W	(A0)+OBNOIMA	TEST.B	(A0)+OBFLAGS:#BMODIFIE	; mode modifie ?	JUMP,BS	20$			; oui, => 20$10$:	CALL	D2IMAGE			; non, utilisation	LOAD.L	A4,(A0)+OBPENT	TEST.B	(A4)+(D2.W)+OICRT	; image utilise ?	JUMP,NC	20$			; oui, => 20$	INC.W	(A0)+OBNOIMA	COMP.W	(A0)+OBNOIMA,#MAXIMA-1	JUMP,LS	10$	LOAD.W	(A0)+OBNOIMA,D0		; il n'y en a plus, met l'image de dpart20$:	CALL	BAFFPAGE	JUMP	BBOUCLE90$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	BBOUCLEDOBMAJ:				; MAJ la biblio. actuel	CALL	BIBLIOMAJ	JUMP	BBOUCLE;------------ PAGEPLEINE:;------------; in	-; out	D4	met les bits pour pages pleines; mod	D4.L;	PUSHM.L	D2,A4	PUSH.W	(A0)+OBNOIMA	PUSH.L	(A0)+OBNOPAV	LOAD.L	A4,(A0)+OBPENT		; A4 ^ entte	LOAD.L	D4,#-1			; init D4	CLR.W	(A0)+OBNOIMA		; init image p. boucle10$:	CLR.L	(A0)+OBNOPAV		; init pav p. boucle	jump	65$60$:	INC.W	(A0)+OBNOPAV+2		; suivant	COMP.W	(A0)+OBNOPAV+2,#8	JUMP,LO	65$	CLR.W	(A0)+OBNOPAV+2	INC.W	(A0)+OBNOPAV65$:	COMP.L	(A0)+OBNOPAV,#3*H'10000+7			; max ?	JUMP,GT	70$			; oui => 70$	CALL	D2PAVE			; D2 <-- offset	TEST.B	(A4)+(d2.W)+OIPCRT	; pav utilis ?	JUMP,NC	60$			; oui					; non, aumoins un inutilis, mettre le bit ...	LOAD.W	D2,(A0)+OBNOIMA	INC.W	D2	TCLR.L	D4:D2			; et ...70$:	INC.W	(A0)+OBNOIMA		; image suivante	COMP.W	(A0)+OBNOIMA,#MAXIMA	; max atteint ?	JUMP,NE	10$			; non90$:	POP.L	(A0)+OBNOPAV        POP.W	(A0)+OBNOIMA	POPM.L	D2,A4	RET;---------- PAGEVIDE:;----------; in	-; out	D4	met les bits pour pages vides; mod	D4.L;	PUSHM.L	D2,A4	PUSH.W	(A0)+OBNOIMA	CLR.L	D4	CLR.W	(A0)+OBNOIMA	LOAD.L	A4,(A0)+OBPENT10$:	CALL	D2IMAGE		; D2 <-- offset image	TEST.B	(A4)+(D2.W)+OICRT	; image utilise ?	JUMP,NC	20$			; oui => 20$	LOAD.W	D2,(A0)+OBNOIMA	INC.W	D2	TSET.L	D4:D220$:	INC.W	(A0)+OBNOIMA	COMP.W	(A0)+OBNOIMA,#MAXIMA	JUMP,LS	10$	POP.W	(A0)+OBNOIMA	POPM.L	D2,A4	RET;----------- PERMINDEX:;-----------; permute les index pavs et pages;; in:	OBNOIMA	= origine;	D1 .W	= destination; out	pages et pavs permuts; mod	-;	PUSHM.L	D0..D4,A3,A4	PUSH.L	(A0)+OBNOPAV					; D1 <-- destination	LOAD.W	D0,(A0)+OBNOIMA		; D0 <-- origine					; PERMUTER IMAGES	LOAD.L	A4,(A0)+OBPENT		; A4 ^ entte	LOAD.l	A3,#(A0)+OBSIPAGE	LOAD.W	D3,#LGIMAB-1	CALL	D2IMAGE	PUSH.W	D205$:					; OBSIPAGE <-- origine	LOAD.B	(A3+),(A4)+(D2.W)	INC.W	D2	DECJ.W,NMO D3,05$	POP.W	D2	LOAD.L	A3,A4;	LOAD.L	A3,(A0)+OBPENT		; origine <-- dest;	LOAD.L	A4,A3	ADD.L	A3,D2			; A3 ^ origine	LOAD.W	(A0)+OBNOIMA,D1	CALL	D2IMAGE			; D2 <-- offset dest.	ADD.L	A4,D2	LOAD.W	D3,#LGIMAB-106$:	LOAD.B	(A3+),(A4+)	DECJ.W,NMO D3,06$					; dest <-- index sauv	LOAD.L	A4,(A0)+OBPENT	LOAD.L	A3,#(A0)+OBSIPAGE	LOAD.W	D3,#LGIMAB-107$:	LOAD.B	(A4)+(D2.W),(A3+)	INC.W	D2	DECJ.W,NMO D3,07$					; PERMUTER TOUS LES PAVES	CLR.L	(A0)+OBNOPAV		; init pav30$:	LOAD.W	(A0)+OBNOIMA,D0	LOAD.L	A4,(A0)+OBPENT		; sauve pav origine	LOAD.L	A3,#(A0)+OBSIPAVE	LOAD.W	D3,#LGIPAVE-1	CALL	D2PAVE			; D2 <-- offset origine	PUSH.W	D240$:	LOAD.B	(A3+),(A4)+(D2.W)	INC.W	D2	DECJ.W,NMO D3,40$	POP.W	D2	LOAD.L	A3,(A0)+OBPENT		; copie origine <-- dest	LOAD.L	A4,A3	ADD.L	A3,D2			; A3 ^ origine	LOAD.W	(A0)+OBNOIMA,D1	CALL	D2PAVE			; D2 <-- offset dest.	ADD.L	A4,D2	LOAD.W	D3,#LGIPAVE-142$:	LOAD.B	(A3+),(A4+)	DECJ.W,NMO D3,42$					; dest <-- index pav sauv	LOAD.L	A4,(A0)+OBPENT	LOAD.L	A3,#(A0)+OBSIPAVE	LOAD.W	D3,#LGIPAVE-145$:	LOAD.B	(A4)+(D2.W),(A3+)	INC.W	D2	DECJ.W,NMO D3,45$60$:	INC.W	(A0)+OBNOPAV+2		; pav suivant	COMP.W	(A0)+OBNOPAV+2,#8	JUMP,LO	65$	CLR.W	(A0)+OBNOPAV+2	INC.W	(A0)+OBNOPAV65$:	COMP.L	(A0)+OBNOPAV,#3*H'10000+7 ; max ?	JUMP,GT	70$			; oui => 70$	JUMP	30$70$:	LOAD.W	(A0)+OBNOIMA,D1		; met dest.	POP.L	(A0)+OBNOPAV	POPM.L	D0..D4,A3,A4	RET;------------- KILLPAPAVES:;-------------;; met  zro tous les pavs de l'image OBNOIMA;; in	OBNOIMA.W; out	pavs  zro; mod;	PUSHM.L	D2,A4	PUSH.L	(A0)+OBNOPAV	LOAD.L	A4,(A0)+OBPENT		; A4 ^ entte	CLR.L	(A0)+OBNOPAV		; init pav	jump	65$60$:	INC.W	(A0)+OBNOPAV+2		; suivant	COMP.W	(A0)+OBNOPAV+2,#8	JUMP,LO	65$	CLR.W	(A0)+OBNOPAV+2	INC.W	(A0)+OBNOPAV65$:	COMP.L	(A0)+OBNOPAV,#3*H'10000+7			; max ?	JUMP,GT	70$			; oui => 70$	CALL	D2PAVE	LOAD.B	(A4)+(D2.W)+OIPCRT,#-1	; met  zro index pav	CLR.B	(A4)+(D2.W)+OSPOSH	CLR.L	(A4)+(D2.W)+OSPOSL	jump	60$70$:	POP.L	(A0)+OBNOPAV	POPM.L	D2,A4	RET;----------\\; WAITMOUSE >;==========/;; Attend que tous les boutons de la souris ; et du clavier soient relachs.;; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D3,D4,D710$:	LIB	?IFMOUSE	; D3 <-- boutons	TEST.B	D3		; boutons relachs ?	JUMP',EQ 90$		; oui => 90$				; non =>	LIB	?GETCAR		; attend clavier/souris ...	JUMP	10$30$:	LIB	?IFCAR		; une autre touche ?	JUMP,NE	90$		; non => 90$40$:	LIB	?GETCAR		; oui, attend relach	TEST.L	D3:#BKPSEUDO	JUMP,BS	90$	JUMP	30$90$:	POPM.L	D3,D4,D7	RET;--------- BZPAVIMA:;---------;; met matrice dans l'image;	PUSHM.L	D1..D4,A3,A4	LOAD.L	D1,(A0)+OBNOPAV	CALL	CORPAVE			; D3 <-- coor; D4 <-- (dy;dx)	LOAD.L	A3,#(A5)+OBWRITE	; place pav au nouvel empl.	LOAD.B	(A3)+0,#0	LOAD.B	(A3)+1,#DRAWMATRIX	LOAD.W	(A3)+2,D3	SWAP.W	D3	LOAD.W	(A3)+4,D3	LOAD.L	A4,#(A0)+OBMPAVE	LOAD.L	(A3)+6,A4	DEC.L	(A3)+6	DEC.L	(A3)+6	LOAD.B	(A3)+10,#SETDOT	LOAD.W	D3,#11	LIB	?STRING;;;;	CALL	BIMAMEM			; cran --> mmoire					; mj. index pav;;;	CALL	D2PAVE;;;	LOAD.L	A4,(A0)+OBPENT;;;	LOAD.B	(A4)+(D2.W)+OIIORDRE,(A0)+OBNOIMA+1;;;	CLR.B	(A4)+(D2.W)+OIPCRT	POPM.L	D1..D4,A3,A4	TEST.W	D7	RET;--------- BIMAMEM:;---------;; sauve page  l'cran --> mmoire;	PUSHM.L	D1..D4,A3,A4					; mettre tables  jour	LOAD.L	A4,(A0)+OBPENT	CALL	D2IMAGE	TEST.B	(A4)+(D2.W)+OICRT	JUMP,NC	10$					; v. demander mmoire pour image	LOAD.W	D4,#LBWDOX	MUL.WU	D4,#LBWDOY	SR.L	D4,#3			; D4 <- longueur pour image	ADD.L	D4,#IMLBUF		; + rserve pour codage	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mm. pour image	JUMP,NE	90$	LOAD.L	D4,A4	LOAD.L	A4,(A0)+OBPENT	LOAD.L	(A4)+(D2.W)+OPIMEM,D4	; mmoriser ^mm.	CLR.B	(A4)+(D2.W)+OICRT	;?????10$:					; transfrer cran en mmoire	LOAD.L	D4,(A4)+(D2.W)+OPIMEM	ADD.L	D4,#IMLBUF	LOAD.L	A3,#(A5)+OBWRITE	LOAD.L	D2,#LBWDOX		 ; Iy en mmoire	SR.W	D2,#3	LOAD.B	(A3)+0,#AFCCMO	LOAD.B	(A3)+1,#DRAWRASTER	CLR.W	(A3)+2			; coord. source (x,y)	LOAD.W	(A3)+4,#HBTIT	CLR.L	(A3)+6			; ^nil p. cran	CLR.W	(A3)+10	CLR.L	(A3)+12			; coord. dest. (x,y)	LOAD.L	(A3)+16,D4		; ^mm.	LOAD.W	(A3)+20,D2		; Iy en mm.	LOAD.W	(A3)+22,#LBWDOX	LOAD.W	(A3)+24,#LBWDOY-HBTIT	LOAD.B	(A3)+26,#LOADDOT	LOAD.B	(A3)+27,#AFSCMO	LOAD.W	D3,#28	LIB	?STRING90$:	POPM.L	D1..D4,A3,A4	TEST.W	D7	RET;-------- BMMENU:;--------;; MMENU en gardant la wdo BIBLIO !;; in	D3.W	choix initial;	A3.L	^liste; out	D3.W	choix;	D7.W	erreur; mod	D3.W, D7.W;	PUSHM.L	D0	LOAD.W	D0,D3		; choix initial	LOAD.B	D3,#AFDIR	; affichage mode direct	LIB	?AFCAR	LOAD.W	D3,D0		; choix initial	LIB	?MMENU	PUSH.W	D7	CALL	USEWDOB		; utilise fentre BIBLIO !!!	POP.W	D7	POPM.L	D0	TEST.W	D7	RET;--------- MOUSEMAT:;---------;; matrice devient souris;	PUSHM.L	D3,A3,A4	test.B	(a0)+obflags:#BMNORM	jump,bs	90$	LOAD.L	A4,#(A0)+OBMPAVE	LOAD.L	A3,#(A5)+OBWRITE	LOAD.B	(A3)+0,#NUL		; rien	LOAD.B	(A3)+1,#DRAWPMOUSE	DEC.L	A4			; A4 ^ dx;dy ... matrice	DEC.L	A4	LOAD.L	(A3)+2,A4	LOAD.L	(A3)+6,#0		; ^ fond automatique	LOAD.W	D3,#10	LIB	?STRING	tset.b	(a0)+obflags:#BMNORM90$:	POPM.L	D3,A3,A4	RET;---------- NORMOUSE:;----------;; souris normale;	PUSHM.L	D3,A3	test.b	(a0)+obflags:#BMNORM	jump,bc	90$	LOAD.L	A3,#(A5)+OBWRITE	LOAD.B	(A3)+0,#NUL		; rien	LOAD.B	(A3)+1,#DRAWPMOUSE	CLR.L	(A3)+2	CLR.L	(A3)+6			; ^ fond automatique	LOAD.W	D3,#10	LIB	?STRING	tclr.B	(a0)+obflags:#BMNORM90$:	POPM.L	D3,A3	RET;--------- MOUPAVE:;---------;; souris devient le pav slctionn de la page;	PUSHM.L	D1,D3,D4,A1,A3,A4	LOAD.L	D1,(A0)+OBNOPAV	CALL	CORPAVE			; D3 <-- coord. source	PUSHM.L	D3,D4			; repositionne souris	LOAD.L	D4,D3	LOAD.W	D3,(A5)+OWDOY	SUB.W	D3,#LBWDOY	SR.W	D3	SWAP.W	D3	LOAD.W	D3,(A5)+OWDOX	SUB.W	D3,#LBWDOX	SR.W	D3	ADD.L	D4,D3	ADD.L	D4,#10*H'10000+10	LOAD.L	A1,(A0)+OBADPMOUSE	CALL	(A1)	POPM.L	D3,D4	LOAD.L	A4,#(A0)+OBMPAVE	; ^ mm. destination					; D4 <-- (dx;dy) en 2 bytes!	LOAD.B	(A0)+OBDYMP,D4		; 1er byte mm. <-- dy	SWAP.W	D4	LOAD.B	(A0)+OBDXMP,D4		; 2eme byte mm. <-- dx	LOAD.L	A3,#(A5)+OBWRITE	LOAD.B	(A3)+0,#AFCCMO		; enlve flche	LOAD.B	(A3)+1,#DRAWRASTER	SWAP.W	D3	LOAD.L	(A3)+2,D3		; (x;y) source	SWAP.W	D3	CLR.L	(A3)+6			; ^source	CLR.W	(A3)+10			; ii source	CLR.L	(A3)+12			; (x;y) dest.	LOAD.L	(A3)+16,A4		; ^dest.	LOAD.W	(A3)+20,#LBWDOX/(8*8)	; ii dest.	LOAD.L	(A3)+22,D4		; larg/haut	LOAD.B	(A3)+26,#LOADDOT	LOAD.B	(A3)+28,#NUL		; rien	LOAD.B	(A3)+29,#DRAWPMOUSE	DEC.L	A4			; A4 ^ dx;dy ... matrice	DEC.L	A4	LOAD.L	(A3)+30,A4	LOAD.L	(A3)+34,#0		; ^ fond automatique	LOAD.B	(A3)+38,#AFSCMO		; met pav comme souris	LOAD.W	D3,#39	LIB	?STRING;	JUMP,NE	90$90$:	POPM.L	D1,D3,D4,A1,A3,A4	RET;----------- DEPLAPAVE:;-----------;; place le pav dans une nlle. case;; in	OBNOPAV.L; out	-; mod	D7.W;	PUSHM.L	D0..D5,A2,A3,A400$:				; contrle si dans limiteslib	?getkey	CALL	BPMOUSE;	JUMP,NE	00$;;;;;	TEST.W	D3		; bouton relach ?	TEST.B	D3	JUMP,NE	00$		; non				; oui =>20$:	LOAD.B	D3,#AFCCMO		; enlve la souris pav	LIB	?AFCAR					; D4 pos (y;x)	ADD.L	D4,#(LBWDOX/(8*2))*H'10000+((LBWDOY-HBTIT)/(4*2)) ; centre pav	CALL	BPAVE			; D1 <- ligne/colonne	LOAD.L	D0,D1			; D0 <- nouvel empl.	LOAD.L	D1,(A0)+OBNOPAV		; D1 <- ancien empl.					; sauver index ancien pav ...	LOAD.L	A4,(A0)+OBPENT	LOAD.L	A3,#(A0)+OBSIPAVE	LOAD.W	D3,#LGIPAVE-1	CALL	D2PAVE	PUSH.W	D222$:	LOAD.B	(A3+),(A4)+(D2.W)	INC.W	D2	DECJ.W,NMO D3,22$	POP.W	D2	LOAD.B	(A4)+(D2.W)+OIPCRT,#-1	; ... et mise  zro	CLR.L	(A4)+(D2.W)+OSPOSL	CLR.B	(A4)+(D2.W)+OSPOSH	LOAD.L	(A0)+OBNOPAV,D0		; nouvel empl. vide ?	CALL	BPAVE?	JUMP,NE	70$			; non => 25$25$:	COMP.L	D0,D1			; nouvel empl. = ancien ?	JUMP,EQ	70$			; oui => 70$	JUMP,GT	40$			; non, plus loin30$:				; NOUVEAU < ANCIEN, COPIE EN ARRIERE	COMP.L	D1,(A0)+OBNOPAV		; chercher vide depuis le nouveau vers l'ancien	JUMP,EQ	32$			; ancien atteint => 32$	INC.W	(A0)+OBNOPAV+2	COMP.W	(A0)+OBNOPAV+2,#8	JUMP,LO	31$	CLR.W	(A0)+OBNOPAV+2	INC.W	(A0)+OBNOPAV31$:	CALL	BPAVE?			; vide ?	JUMP,EQ	30$			; non --> 30$32$:	LOAD.L	D1,(A0)+OBNOPAV		; D0 <-- ancien ou vide le plus proche33$:	CALL	CORPAVE	LOAD.L	D5,D3			; D5 <-- coord. destination	LOAD.L	(A0)+OBNOPAV,D1	CALL	D2PAVE			; D2 <-- offset destination	DEC.W	D1			; pav prcdent	JUMP,NC	35$	LOAD.W	D1,#7	SWAP.W	D1	DEC.W	D1	SWAP.W	D135$:	COMP.L	D1,D0			; nouvel empl. atteint ?	JUMP,LT	70$			; oui => 70$	CALL	CORPAVE			; D3 <-- coord. ancien empl.	CALL	80$			; dplace le pav ...	LOAD.L	A3,(A0)+OBPENT		; ... copie index pav ...	LOAD.L	A4,A3	ADD.L	A3,D2	LOAD.L	(A0)+OBNOPAV,D1	CALL	D2PAVE	ADD.L	A4,D2	LOAD.W	D3,#LGIPAVE-137$:	LOAD.B	(A3+),(A4+)	DECJ.W,NMO D3,37$	JUMP	33$			; ... et suivant40$:				; NOUVEAU > ANCIEN, COPIE EN AVANT	COMP.L	D1,(A0)+OBNOPAV		; chercher vide depuis le nouveau vers l'ancien	JUMP,EQ	42$			; ancien atteint => 42$	DEC.W	(A0)+OBNOPAV+2	JUMP,NC	41$	LOAD.W	(A0)+OBNOPAV+2,#7	DEC.W	(A0)+OBNOPAV41$:	CALL	BPAVE?			; vide ?	JUMP,EQ	40$			; non --> 40$42$:	LOAD.L	D1,(A0)+OBNOPAV		; D0 <-- ancien ou vide le plus proche43$:	CALL	CORPAVE	LOAD.L	D5,D3			; D5 <-- coord. dest.	LOAD.L	(A0)+OBNOPAV,D1	CALL	D2PAVE			; D2 <-- offset destination	INC.W	D1	COMP.W	D1,#8	JUMP,LO	45$	CLR.W	D1	SWAP.W	D1	INC.W	D1	SWAP.W	D145$:	COMP.L	D1,D0			; nouvel empl. atteint ?	JUMP,GT	70$			; oui => 70$	CALL	CORPAVE			; D3 <-- coord. source	CALL	80$			; dplace pav	LOAD.L	A3,(A0)+OBPENT		; copie index pav	LOAD.L	A4,A3	ADD.L	A3,D2	LOAD.L	(A0)+OBNOPAV,D1	CALL	D2PAVE	ADD.L	A4,D2	LOAD.W	D3,#LGIPAVE-147$:	LOAD.B	(A3+),(A4+)	DECJ.W,NMO D3,47$	JUMP	43$			; et suivant70$:					; place au nouvel emplacement	LOAD.L	D1,D0	CALL	CORPAVE			; D3 <-- coor; D4 <-- (dy;dx)	LOAD.L	A3,#(A5)+OBWRITE	; place pav sl. au nouvel empl.	LOAD.B	(A3)+0,#0	LOAD.B	(A3)+1,#DRAWMATRIX	LOAD.W	(A3)+2,D3	SWAP.W	D3	LOAD.W	(A3)+4,D3	LOAD.L	A2,#(A0)+OBMPAVE	LOAD.L	(A3)+6,A2	DEC.L	(A3)+6	DEC.L	(A3)+6	LOAD.B	(A3)+10,#SETDOT	LOAD.W	D3,#11	LIB	?STRING	LOAD.W	D2,#INVDOT	CALL	BALLUME			; teint le pav dest.	LOAD.L	(A0)+OBNOPAV,D1		; copie index pav	CALL	D2PAVE	LOAD.L	A4,(A0)+OBPENT	LOAD.L	A3,#(A0)+OBSIPAVE	LOAD.W	D3,#LGIPAVE-175$:	LOAD.B	(A4)+(D2.W),(A3+)	INC.W	D2	DECJ.W,NMO D3,75$;;;;	CALL	BIMAMEM			; image en mmoire	LOAD.W	D4,#15			; dlai d'attente pour viter scint.	NTREL	?DELMS;;;CALL	NORMOUSE	LOAD.L	A3,#(A5)+OBWRITE	; remet souris normale	LOAD.B	(A3)+0,#0	LOAD.B	(A3)+1,#DRAWPMOUSE	; H'D2	LOAD.L	(A3)+2,#0	LOAD.L	(A3)+6,#0	LOAD.W	D3,#10	LIB	?STRING;	LOAD.B	D3,#AFSCMO		; remet souris normale;	LIB	?AFCAR	LIB	?BUZZ	POPM.L	D0..D5,A2,A3,A4	RET80$:					; efface dest. et copie pav	LOAD.L	D4,D5			; D4 <-- coord. dest.	LOAD.L	A3,#(A5)+OBWRITE	LOAD.B	(A3)+0,#0	LOAD.B	(A3)+1,#DRAWRASTER	SWAP.W	D3	LOAD.L	(A3)+2,D3	SWAP.W	D3	CLR.L	(A3)+6	CLR.W	(A3)+10	SWAP.W	D4	LOAD.L	(A3)+12,D4	SWAP.W	D4	CLR.L	(A3)+16	CLR.W	(A3)+20;	LOAD.L	(A3)+22,#(((LBWDOY-HBTIT)/4)-4)*H'10000+(LBWDOX/8)-4	LOAD.L	(A3)+22,#BDYPAVE*H'10000+BDXPAVE	LOAD.B	(A3)+26,#LOADDOT	LOAD.W	D3,#27	LIB	?STRING	RET;--------- BPMOUSE:;---------;; repositionne la souris dans la fentre BIBLIO;; out	D3	boutons;	D4	souris dans la fentre	PUSHM.L	D0,D1,D2,A1	LOAD.L	D0,(A5)+OWDOY		; D0 coord. HG	SUB.W	D0,#LBWDOX	SR.W	D0	SWAP.W	D0	SUB.W	D0,#LBWDOY	SR.W	D0	SWAP.W	D0	LOAD.L	D1,D0	ADD.L	D0,#HBTIT*H'10000+0	ADD.L	D1,#LBWDOY*H'10000+LBWDOX ; D1 coord. BD;	SUB.L	D1,#(((LBWDOY-HBTIT)/4)-4)*H'10000+((LBWDOX/8)-4) ; - (dy;dx)	SUB.L	D1,#BDYPAVE*H'10000+BDXPAVE00$:	LIB	?IFMOUSE	LOAD.L	D2,D4	COMP.W	D4,D0			; X	JUMP,HS	10$	LOAD.W	D4,D010$:	SWAP.W	D4	SWAP.W	D0	COMP.W	D4,D0			; Y	JUMP,HS	11$	LOAD.W	D4,D011$:	SWAP.W	D0	SWAP.W	D1	COMP.W	D4,D1			; Y	JUMP,LO	12$	LOAD.W	D4,D112$:	SWAP.W	D1	SWAP.W	D4	COMP.W	D4,D1			; X	JUMP,LO	13$	LOAD.W	D4,D113$:	COMP.L	D4,D2	JUMP,EQ	80$	PUSHM.L	D3	LOAD.B	D3,#BIPLIT	LIB	?BEEP	POPM.L	D3;	CALL	PMOUSE			; repositionne	LOAD.L	A1,(A0)+OBADPMOUSE	CALL	(A1)80$:	SUB.L	D4,D090$:	POPM.L	D0,D1,D2,A1	RET;--------- USEWDOB:;---------;; dfinition de la wdo BIBLIO;	PUSHM.L	D4,D3	LOAD.W	D4,(A5)+OWDOX		; D4 <-- coord, sous-fentre	SUB.W	D4,#LBWDOX	SR.W	D4	SWAP.W	D4	LOAD.W	D4,(A5)+OWDOY	SUB.W	D4,#LBWDOY	SR.W	D4	LOAD.L	A3,#(A5)+OBWRITE	; sous-fentre	LOAD.B	(A3)+0,#NUL	LOAD.B	(A3)+1,#DIMWDO	LOAD.L	(A3)+2,D4	LOAD.W	(A3)+6,#LBWDOX	LOAD.W	(A3)+8,#LBWDOY	LOAD.W	D3,#10	LIB	?STRING;	JUMP,NE	90$	POPM.L	D4,D3	RET;------ BPDET:;------; inverse pav et attend bouton relachs;; in	; out	OPLANBV+OBNOPAV <-- no de ligne/colonne;	EQ	--> ds. la surface;	NE	--> pas ds. la surface et/ou vide; mod	D7;	PUSHM.L	D1,D3,D4	LOAD.L	(A0)+OBNOPAV,#-1	; init OBNOPAV;	JUMP	42$42$:;;;?	LIB	?IFMOUSE	; D4 pos. (y;x)	CALL	BIFMOUSE	JUMP,NE	42$	TEST.B	D3		; boutons relachs ?	JUMP,EQ	50$		; oui => 50$;;	TEST.L	D3:#BMOLEFT	; bouton relach ?;;	JUMP,BC	50$		; oui	CALL	BLIMITE		; ds. la surface ?	JUMP,NE	42$		; non	LOAD.L	D1,(A0)+OBNOPAV		; premier	JUMP,NS	45$			; oui	CALL	BPAVE			; D1 <- ligne/colonne	COMP.L	D1,(A0)+OBNOPAV		; le mme ?	JUMP,EQ	42$			; oui	LOAD.L	D1,(A0)+OBNOPAV		; non	LOAD.W	D2,#INVDOT	CALL	BALLUME			; teint45$:	CALL	BPAVE			; allume	LOAD.L	(A0)+OBNOPAV,D1	LOAD.W	D2,#INVDOT	CALL	BALLUME	JUMP	42$50$:			; bouton relach !	CALL	BLIMITE		; ds. la surface ?;;;;;	JUMP,EQ	90$	JUMP,NE	58$	CALL	BPAVE?		; utilis ?	JUMP,EQ	90$		; oui => 90$				; non, ou ...58$:				; pas dans la surface	LOAD.L	D1,(A0)+OBNOPAV	JUMP,NS	59$	LOAD.W	D2,#INVDOT	CALL	BALLUME		; teint59$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	LOAD.W	D7,#-1	JUMP	95$90$:	CLR.W	D795$:	POPM.L	D1,D3,D4	TEST.W	D7	RET;-------- BPAVE?:;--------;; pav utilis ?;; NE	vide; EQ	utilis;	PUSHM.L	D1,D2,A4	LOAD.W	D7,#-1	LOAD.L	A4,(A0)+OBPENT		; A4 ^entte	CALL	D2PAVE	TEST.B	(A4)+(D2.W)+OIPCRT	; -1 ?	JUMP,NS	90$	CLR.W	D790$:	POPM.L	D1,D2,A4	TEST.W	D7	RET;--------- TSTPAVE:;---------;; teste si encore un pav utilis dans l'image;; NE	vide; EQ	utilis;	PUSH.L	(A0)+OBNOPAV	CLR.L	(A0)+OBNOPAV	load.W	D7,#-110$:	COMP.L	(A0)+OBNOPAV,#(4-1)*H'10000+(8-1)	JUMP,EQ	90$	INC.W	(A0)+OBNOPAV+2	COMP.W	(A0)+OBNOPAV+2,#8	JUMP,LO	20$	CLR.W	(A0)+OBNOPAV+2	INC.W	(A0)+OBNOPAV20$:	CALL	BPAVE?			; vide ?	JUMP,NE	10$			; oui --> 10$90$:	POP.L	(A0)+OBNOPAV	TEST.W	D7	RET;-------- D2PAVE:;--------;; D2 <-- offset pour index pav selon OBNOIMA et OBNOPAV	PUSHM.L	D1	LOAD.W	D2,(A0)+OBNOPAV	; D2 <-- ligne	MUL.WU	D2,#8			; D2 * nb pavs en ligne	ADD.W	D2,(A0)+OBNOPAV+2	; D2 + colonne	MUL.WU	D2,#LGIPAVE		; D2 * LGIPAVE	LOAD.W	D1,(A0)+OBNOIMA		; D1 <-- no. image	MUL.WU	D1,#(LGIPAVE*32)	; D1 * NBPAVE+LGIPAVE	ADD.L	D1,#LGBPREM		; D1 + LGBPREM	ADD.L	D1,#LGIMAB*MAXIMA	ADD.L	D2,D1			; D2 <-- D2 + D1	POPM.L	D1	RET;--------- D2IMAGE:;---------;; D2 <-- offset image selon OBNOIMA;	CLR.L	D2	LOAD.W	D2,(A0)+OBNOIMA	MUL.WU	D2,#LGIMAB	ADD.L	D2,#LGBPREM	RET;---------- BIFMOUSE:;----------;; coord. de la souris  dans wdo BIBLIO;; out	D4.L	coord. BIBLIO;	D3	boutons;	PUSHM.L	D2	LIB	?IFMOUSE	JUMP,NE	90$	LOAD.W	D7,#-1test.b	(a0)+obflags:#BMNORMjump,bc	10$	ADD.L	D4,#(LBWDOX/(8*2))*H'10000+((LBWDOY-HBTIT)/(4*2)) ; centre pav10$:	LOAD.L	D2,(A5)+OWDOY		; offset ...	SUB.W	D2,#LBWDOX	SR.W	D2	SWAP.W	D2	SUB.W	D2,#LBWDOY	SR.W	D2	SWAP.W	D2	SUB.W	D4,D2			; coord. - origine WDO BIBLIO	JUMP,NS	90$jump,zs	90$	SWAP.W	D4	SWAP.W	D2	SUB.W	D4,D2	JUMP,NS	80$jump,zs	80$	CLR.W	D7			; ok.80$:	SWAP.W	D4	SWAP.W	D290$:	POPM.L	D2	TEST.W	D7	RET;-------- BLIMITE:;--------;; teste si dans la surface BIBLIO; in	D4.L	coord (y;x); out	EQ,NE; mod	D7.W;	PUSHM.L	D3	LOAD.W	D7,#-1	CLR.L	D3	COMP.W	D4,D3		; ds. la surface des pavs?	JUMP,LO	90$	ADD.W	D3,#LBWDOX	COMP.W	D4,D3	JUMP,GT	90$	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#HBTIT	COMP.W	D4,D3	JUMP,LO	80$	ADD.W	D3,#LBWDOY	COMP.W	D4,D3	JUMP,GT	80$	CLR.W	D780$:	SWAP.W	D490$:	POPM.L	D3	TEST.W	D7	RET;------ BPAVE:;------;; calculer ligne et colonne du pav;; in	D4.L	coord. (Y;X); out	D1.L	ligne/colonne; mod	D1.L;	PUSHM.L	D3,D4	SWAP.W	D4	LOAD.L	D3,D4	AND.L	D4,#H'FFFF	SUB.W	D4,#HBTIT	DIV.WU	D4,#(LBWDOY-HBTIT)/4	LOAD.W	D1,D4	SWAP.W	D3	AND.L	D3,#H'FFFF	DIV.WU	D3,#LBWDOX/8	SWAP.W	D1	LOAD.W	D1,D390$:	POPM.L	D3,D4	RET;-------- BALLUME:;--------;; allume le pav slctionn;; in	D1.L	no (ligne; colonne);	D2.W	mode (SETDOT, INVDOT, CLRDOT); out	-; mod	D7.W	PUSHM.L	D1..D4	LOAD.L	D3,#H'FFFFFFFF	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	CORPAVE;;	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	POPM.L	D1..D4	RET;-------- CORPAVE:;--------; rend les coordonnes haut-gauche d'un pav et (dy;dx);; in	D1	(ligne/colonne); out	D3	coord. (Y;X);	D4	(dy;dx); mod	D3,D4;	PUSHM.L	D0,D1	LOAD.L	D0,D1	CLR.L	D3	MUL.WU	D1,#LBWDOX/8	ADD.W	D3,D1;	ADD.W	D3,#2add.w	d3,#3	SWAP.W	D3	LOAD.L	D1,D0	SWAP.W	D1	MUL.WU	D1,#(LBWDOY-HBTIT)/4	ADD.W	D3,D1	ADD.W	D3,#HBTIT;	ADD.W	D3,#2add.w	d3,#3	SWAP.W	D3			; D3 <-- coord. origine;	LOAD.L	D4,#(((LBWDOY-HBTIT)/4)-4)*H'10000+((LBWDOX/8)-4) ; D4 <-- (dy;dx);	LOAD.L	D4,#(((LBWDOY-HBTIT)/4)-5)*H'10000+((LBWDOX/8)-5) ; D4 <-- (dy;dx)	LOAD.L	D4,#BDYPAVE*H'10000+BDXPAVE	POPM.L	D0,D1	RET;---------- WRENTETE:;----------;; crire l'entte;	PUSHM.L	D3,D4,D6,A4	LOAD.W	D6,(A0)+OBCHBIB	CLR.B	D3	CLR.L	D4	FOS	?SPOS			; ^au dbut du fichier	LOAD.W	D4,#MAXIMA		; MAXIMA	LOAD.W	D3,#MAXPAVE		; MAXPAVE	MUL.WU	D3,D4			; D3 <-- OMAXPAVE * OMAXIMA	MUL.WU	D3,#LGIPAVE		; D3 <-- ... * LGIPAVE	MUL.WU	D4,#LGIMAB		; D4 <-- OMAXIMA * LGIMAB	ADD.L	D4,D3			; D4 <-- D4 + D3	ADD.L	D4,#LGBPREM		; D4 <-- ... + LGBPREM	LOAD.L	A4,(A0)+OBPENT	FOS	?WRBYTE;;	JUMP,NE	POPM.L	D3,D4,D6,A4	TEST.W	D7	RET;----------- RDENTETE:;-----------;; demander mmoire et; lire l'entte,; mmoriser le pointeur  l'entte OBPENT;; in	canal; out	OBPENT; mod	D7.W	PUSHM.L	D1,D4,D6,A4	LOAD.W	D6,(A0)+OBCHBIB		; D6 <-- canal	LOAD.L	A4,#(A0)+OBBUIMA	; A4 <-- buffer	LOAD.L	D4, #LGBPREM		; longueur BPREMIER	FOS	?RDBYTE			; lecture pour valuer mmoire entte	JUMP,NE	90$	CLR.L	D3	CLR.L	D4	LOAD.B	D4,(A4)+OMAXIMA		; MAXIMA	LOAD.B	D3,(A4)+OMAXPAVE	; MAXPAVE	MUL.WU	D3,D4			; D3 <-- OMAXPAVE * OMAXIMA	MUL.WU	D3,#LGIPAVE		; D3 <-- ... * LGIPAVE	MUL.WU	D4,#LGIMAB		; D4 <-- OMAXIMA * LGIMAB	ADD.L	D4,D3			; D4 <-- D4 + D3	ADD.L	D4,#LGBPREM		; D4 <-- ... + LGBPREM	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE	90$	LOAD.L	(A0)+OBPENT,A4		; mmorise pointeur mmoire	PUSH.L	D4			; remet SPOS au dbut	CLR.L	D4	CLR.L	D3	FOS	?SPOS	POP.L	D4	FOS	?RDBYTE			; lecture entte	JUMP,EQ	90$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP		; erreur rend mmoire	GESMEM	?GIVMEM	POP.W	D790$:	POPM.L	D1,D4,D6,A4	TEST.W	D7	RET;---------- PINFOIMA:;----------;; in	D0	no. image; out	A4	^ entte;	D2.W	offset;	EQ	image existe;	NE	image pas valide; mod	D2.W;	LOAD.W	D7,#1	LOAD.L	A4,(A0)+OBPENT		; A4 <-- ^ entte	JUMP,EQ	50$	TEST.W	D0	JUMP,NS	50$	COMP.W	D0,#MAXIMA	JUMP,HS	50$	LOAD.L	D2,#LGIMAB		; D2 <-- offset de l'image en cours	MUL.WU	D2,D0	ADD.L	D2,#LGBPREM	TEST.B	(A4)+(D2.W)+OICRT	; valide ?	JUMP,NS	50$			; non, suivant	CLR.W	D7			; ok50$:	TEST.W	D7	RET;---------- WRIMAGES:;----------;; crit toutes les images;; in; out; mod;	PUSHM.L	D2,D3,D4,D6,A3,A4	PUSH.W	(A0)+OBNOIMA	LOAD.W	(A0)+OBNOIMA,#MAXIMA-1	; init  no. image	LOAD.L	A4,(A0)+OBPENT10$:	CALL	NOMIMA	JUMP,NE	90$		FOS	?DELETE			; efface toutes les images	DEC.W	(A0)+OBNOIMA	JUMP,NS	19$	JUMP	10$19$:	LOAD.W	(A0)+OBNOIMA,#MAXIMA-1	; init no. image20$:	CALL	D2IMAGE	TEST.B	(A4)+(D2.W)+OICRT	JUMP,NS	50$	CALL	NOMIMA			; A3 ^nom de l'image en cours	JUMP,NE	90$	LOAD.L	D3,#DEFATT	TCLR.L	D3:#BATTL	TCLR.L	D3:#BATTC	LOAD.W	D4,#TYPRAND	FOS	?CREATE			; cre	LOAD.B	D3,#2^BOPWR	FOS	?OPEN			; ouvre	LOAD.L	A3,(A4)+(D2.W)+OPIMEM	LOAD.L	A3,#(A3)+IMLBUF	CALL	WRIMA			; crit et code l'image	FOS	?CLOSE			; ferme50$:	DEC.W	(A0)+OBNOIMA	JUMP,NS	90$	JUMP	20$90$:	POP.W	(A0)+OBNOIMA	POPM.L	D2,D3,D4,D6,A3,A4	TEST.W	D7	RET;-------- NOMIMA:;--------;; in	-; out	A3	^nom de fichier image en cours; mod	A3.L,D7.W;	PUSHM.L	D1,D3,A4	LOAD.L	A3,#(A0)+OBMEMFIO	LOAD.L	A4,#(A0)+OBBTEMP10$:	LOAD.B	(A4+),(A3+)		; copie le nom complet	JUMP,NE	10$	LOAD.W	D1,(A0)+OBNOIMA		; ... + chiffre image en cours	ADD.B	D1,#'0	LOAD.B	(A4)-1,D1	CLR.B	(A4)	LOAD.L	A3,#(A0)+OBBTEMP	LOAD.W	D1,#1	LOAD.L	A4,#R16"TXIMAGE		; ... + extension	LIB	?ADDEXT	POPM.L	D1,D3,A4	TEST.W	D7	RET;------- WRIMA:;-------;; crit et code une image;; in	D6	canal;	A3	^ image dcode; out; mod	PUSHM.L	D4,A2,A3,A4	LOAD.L	A2,#(A0)+OBBUIMA+LGHIMA	LOAD.W	D4,#LGHIMA-110$:	CLR.B	(-A2)			; rempli de zro	DECJ.W,NMO D4,10$	LOAD.B	(A2)+OIMTYP,#H'81	LOAD.B	(A2)+OIMCOD,#H'00	LOAD.B	(A2)+OIMBIP,#H'01	LOAD.B	(A2)+OIMDIR,#H'02	LOAD.W	(A2)+OIMDLY,#LBWDOY-HBTIT	LOAD.W	(A2)+OIMDLX,#LBWDOX	LOAD.L	(A2)+OIMNBB,#(LBWDOX/8)*(LBWDOY-HBTIT)	LOAD.L	A4,#(A3)-IMLBUF	GRA_	CODEIMA	JUMP,EQ	20$	LOAD.L	A4,A3			; si erreur A4 ^ image dcode20$:	PUSH.L	A4			; crit l'entte	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?WRBYTE	POP.L	A4	LOAD.L	D4,(A2)+OIMNBB		; crit l'image code ou non	FOS	?WRBYTE					; redcode because 'MAJ'	TEST.B	(A2)+OIMCOD	JUMP,EQ	90$	LOAD.L	A4,A3	LOAD.L	A4,#(A4)-IMLBUF	GRA_	DECOIMA90$:	POPM.L	D4,A2,A3,A4	TEST.W	D7	RET;---------- RDIMAGES:;----------;; lire toutes les images;	PUSHM.L	D0,A1,A2,A3,A4	PUSH.W	(A0)+OBNOIMA	CLR.W	(A0)+OBNOIMA			; compteur d'images	LOAD.L	A4,(A0)+OBPENT		; A4 ^ entte en mmoire	LOAD.L	A3,#(A0)+OBBTEMP	; A3 ^buffer temp.10$:	CALL	D2IMAGE			; image ?	TEST.B	(A4)+(D2.W)+OICRT	JUMP,NS	50$			; non, suivante	CALL	NOMIMA			; oui, nom de l'image	JUMP,NE	90$20$:	CALL	RDIMA			; ... et lecture	JUMP,EQ	40$	LOAD.B	(A4)+(D2.W)+OICRT,#-1	; image pas trouv !	CLR.L	(A4)+(D2.W)+OPIMEM	CALL	KILLPAPAVES		; + met  zro tous les pavs !!!!	JUMP	50$40$:					; image trouv	LOAD.L	(A4)+(D2.W)+OPIMEM,A150$:	INC.W	(A0)+OBNOIMA	COMP.W	(A0)+OBNOIMA,#MAXIMA	; max. atteint ?	JUMP,LO	10$			; non90$:	POP.W	(A0)+OBNOIMA	POPM.L	D0,A1,A2,A3,A4	TEST.W	D7	RET;------ RDIMA:;------;; lire une image en mmoire;; in	A3	^nom image; out	A1	^ mmoire demande;	A2	^ entte image;	A3	^ image en mmoire; mod	D7.W,A3,A4	PUSHM.L	D1,D3,D4,D6,A4	LOAD.W	D3,#2^BOPRD		; mode lecture	FOS	?OPEN	JUMP,NE	95$	LOAD.L	A4,#(A0)+OBBUIMA		; A4 ^buffer entte	LOAD.L	D4,#LGHIMA		; D4 <- longueur entte	FOS	?RDBYTE			; lit entte/binaire	JUMP,NE	90$	COMP.B	(A4)+0,#H'82		; entte binaire ?	JUMP,NE	20$			; non => 20$					; oui	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute l'entte binaire	JUMP,NE	90$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit entte image	JUMP,NE	90$20$:	LOAD.L	A2,A4			; A2 <-- ^entte image	LOAD.W	D4,(A2)+OIMDLX	MUL.WU	D4,(A2)+OIMDLY	SR.L	D4,#3			; D4 <- longueur pour image	ADD.L	D4,#IMLBUF		; + rserve pour codage	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mm. pour image	JUMP,NE	90$	LOAD.L	A1,A4			; lit toute l'image, et dcode v.	TEST.B	(A2)+OIMCOD		; image code ?	JUMP,NE	50$			; oui => 50$					; non	LOAD.L	D4,(A2)+OIMNBB	FOS	?RDBYTE			; lit image dcode	JUMP,NE	90$	JUMP	60$50$:	LOAD.L	A3,#(A4)+IMLBUF	LOAD.L	D4,(A2)+OIMNBB	FOS	?RDBYTE		; lit image code	JUMP,NE	90$	GRA_	DECOIMA		; .. dcode image	JUMP,NE	90$	CLR.W	D760$:90$:	PUSH.W	D7			; conserve v. erreur	FOS	?CLOSE	POP.W	D795$:	POPM.L	D1,D3,D4,D6,A4	TEST.W	D7	RET;---------- NOMPAGE?:;----------; a-t-on cliqu dans nom de page ?; EQ = clic dans nom de page; NE = ailleurs;; in	-; out	EQ	oui;	NE	non; mod	D3,D4,D7;DENOM	=	27*8ANOM	=	48*8	CALL	BIFMOUSE	JUMP,NE	90$	LOAD.W	D7,#1	COMP.W	D4,#DENOM	JUMP,LS	90$	COMP.W	D4,#ANOM	JUMP,HS	90$	SWAP.W	D4	COMP.W	D4,#HBTIT	JUMP,HS	90$	CLR.W	D790$:	TEST.W	D7	RET;---------- BNOMPAGE:;----------;; inscrire nom dans page correspondante;	PUSHM.L	D2,A3,A4	LOAD.L	A3,#(A0)+OBBTEMP	; A3 ^buffer source	LOAD.L	A4,(A0)+OBPENT		; A4 ^entte	CALL	D2IMAGE			; D2 <-- offset10$:	COMP.B	(A3),#CR	JUMP,EQ	20$	LOAD.B	(A4)+(D2.W)+OINOM,(A3+)	; copie texte	JUMP,EQ	20$	INC.W	D2	JUMP	10$20$:	CLR.B	(A4)+(D2.W)+OINOM	POPM.L	D2,A3,A4	RET;---------- INOMPAGE:;----------;; inverse zone avec nom de la page;	PUSHM.L	D3,A3	LOAD.L	A3,#(A5)+OBWRITE	CLR.B	(A3)+0	LOAD.B	(A3)+1,#TRAME	LOAD.L	(A3)+2,#H'FFFFFFFF	LOAD.L	(A3)+6,#H'FFFFFFFF	CLR.B	(A3)+10	LOAD.B	(A3)+11,#DRAWTRAME	LOAD.W	(A3)+12,#DENOM	LOAD.W	(A3)+14,#2	LOAD.W	(A3)+16,#ANOM-DENOM	LOAD.W	(A3)+18,#HBTIT-6	LOAD.B	(A3)+20,#INVDOT	LOAD.W	D3,#21	LIB	?STRING	POPM.L	D3,A3	RET;------------- BANNOTEPAVE:;-------------; utilise IPP06 et crit le texte dans OBBTEMP centr dans le pav en bas;	LOAD.L	A3,#(A5)+OBWRITE	; petit caractre	LOAD.B	(A3)+0,#USEGC	LOAD.B	(A3)+1,#GCPAF	LOAD.B	(A3)+2,#GCPAS	LOAD.B	(A3)+3,#GCPAT;	LOAD.B	(A3)+4,#AFINV	LOAD.W	D3,#4	LIB	?STRING	CALL	CORPAVE	ADD.L	D3,#(BDYPAVE-1)*H'10000	PUSH.L	D3	DEC.W	D3	DEC.W	D3	LIB	?SETCURS	POP.L	D3	LIB	?AFTIM	.ASCIZE	"             "	INC.W	D3	INC.W	D3	LIB	?SETCURS	load.L	A3,#(A0)+OBBTEMP	LIB	?AFTEXT	LOAD.L	A3,#(A5)+OBWRITE	; caractre normal	LOAD.B	(A3)+0,#USEGC	LOAD.B	(A3)+1,#GCTXF	LOAD.B	(A3)+2,#GCTXS	LOAD.B	(A3)+3,#GCTXT;	LOAD.B	(A3)+4,#AFDIR	LOAD.W	D3,#4	LIB	?STRING	RET;----------- BTEXTPAGE:;-----------;; saisie du nom de page; in	-; out	EQ ok.		texte ds. OBBTEMP;	NE annule; mod	D7.W et OBBTEMP;	PUSH.L	A2	LOAD.L	A2,#R16"TDBOX_TXPAGE	CALL	BDBTEXT	POP.L	A2	TEST.W	D7	RET;----------- BTEXTPAVE:;-----------;; saisie du nom de page; in	-; out	EQ ok.		texte ds. OBBTEMP;	NE annule; mod	D7.W et OBBTEMP;	PUSH.L	A2	LOAD.L	A2,#R16"TDBOX_TXPAVE	CALL	BDBTEXT	POP.L	A2	TEST.W	D7	RETBDBTEXT:	PUSHM.L	D0..D5,A1..A4	LIB	?PUSHMENU	LOAD.L	D0,D5;;;;;	LOAD.L	A2,#R16"TDBOX_TXPAVE	LOAD.W	D2,#2^BDBSAV		;!2^BDBCAS	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A3,#(A0)+OBBTEMP10$:	LOAD.L	A4,A3	CLR.B	(A4)20$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR	JUMP,EQ 50$	COMP.W	D3,#END	JUMP,EQ	45$	COMP.W	D3,#UNDO	JUMP,EQ	10$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$;;40$:				; UNDO =>;;	LOAD.L	A4,A3;;	CLR.B	(A4)		; vide toute la ligne;;	JUMP	10$45$:				; ANNULE => (END)	DBOX_	CLOSE		; ferme la DBOX	LOAD.W	D7,#1	JUMP	90$		;    ... et fin50$:				; OK =>	DBOX_	CLOSE	CLR.W	D790$:	PUSH.W	D7	LOAD.L	D5,D0	LIB	?POPMENU	CALL	USEWDOB	POP.W	D7	POPM.L	D0..D5,A1..A4	TEST.W	D7	RETDOKOK:	LOAD.W	D3,#CR	RETDOKANNULE:	LOAD.W	D3,#END	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETTKEY_OKAN:	.W	END,F0,F13,F14,F15,0	DOKANNULE-TKEY_OKAN	.W	CR,F1,F2,F3,0		DOKOK-TKEY_OKAN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_OKAN	.W	0MENU_OKAN:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENMENU_OKANN:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	"";	.ASCIZ	"D'accord"	.ASCIZ	"Annote"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTDBOX_TXPAVE:	.W	10$-TDBOX_TXPAVE	.W	MENU_OKANN-TDBOX_TXPAVE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Annotation  mettre"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"avec cet lment : "	.B	ODBCR,ODBCR	.B	ODBLINE,12+2	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	"  ANNOTE  "	.B	ODBTABX,15	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	0	.EVENTDBOX_TXPAGE:	.W	10$-TDBOX_TXPAGE	.W	MENU_OKAN-TDBOX_TXPAGE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Nom de page  mettre :"	.B	ODBCR,ODBCR	.B	ODBLINE,LBNOMIM-1+2	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTABX,15	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	0	.EVENMBMODIF:	.ASCIZ	" "	.B	-1	.B	USEGC,GCICF,GCICS,GCICT	.B	7,110,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" supprime "	.B	USEGC,GCICF,GCICS,GCICT	.B	7,109,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" dplace "	.B	-1	.B	USEGC,GCICF,GCICS,GCICT	.B	7,112,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" annote "	.B	-1	.B	USEGC,GCICF,GCICS,GCICT	.B	7,111,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" transfre "	.B	0	.EVENMBPAGE:	.ASCIZ	" "	.B	-1	.ASCIZ	" page 01 "	.ASCIZ	" page 02 "	.ASCIZ	" page 03 "	.ASCIZ	" page 04 "	.ASCIZ	" page 05 "	.ASCIZ	" page 06 "	.ASCIZ	" page 07 "	.ASCIZ	" page 08 "	.ASCIZ	" page 09 "	.ASCIZ	" page 10 "	.B	0	.EVEN;===============================BTXMENU:				; menu 'utilise'		;.....|.....|.....|	.ASCIZ	"Ter-"	.ASCIZ	"mine"			; F0	.ASCIZ	""	.ASCIZ	""			; F1..F3	.ASCIZ	""			; F4..F6	.ASCIZ	""	.ASCIZ	""			; F7..F9	.ASCIZ	""	.ASCIZ	"Affiche"		; F10..F12	.ASCIZ	"  <'<>    Page   <'>>"	.ASCIZ	""			; F13..F15	.ASCIZ	"  Retour  PLAN"	.EVENBTXMENUM:				; menu 'modifie'		;.....|.....|.....|	.ASCIZ	"Ter-"	.ASCIZ	"mine"			; F0	.ASCIZ	"            Met "	.ASCIZ	"            jour"	; F1..F3	.ASCIZ	"Supprime"		; F4..F6	.ASCIZ	"toute la page"	.ASCIZ	"Dplace"		; F7..F9	.ASCIZ	"  <'<>  la page  <'>>"	.ASCIZ	"Affiche"		; F10..F12	.ASCIZ	"  <'<>    Page   <'>>"	.ASCIZ	""			; F13..F15	.ASCIZ	"  Retour  PLAN"	.EVEN	.END