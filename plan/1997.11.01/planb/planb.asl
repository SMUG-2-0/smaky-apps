	.TITLE	PLANB			; 1er janvier 88 Sp.					;	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	; module pour PLAN	; gestion d'lments graphiques pour PLAN	;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.PROC	M680002			; mnmonics CALM 2	.RADIX	10.			; base 10 par dfaut	.HEX				; listing en hexadcima	.REF	SMAKY	.REF	MODULES	.REF	DOLIB	.REF	PLANA	.REF	PLANB;LIB?PUSHMENU	=	LIB_BASE+119	; sauve ?AFMENU;LIB?POPMENU	=	LIB_BASE+120	; restitue ?AFMENU; --------------------------------------;; Contenu du fichier.BBPLAN:;;	<dfinitions gnrales>;;	<une dfinition par image>;;	<une dfinition par pav et image>;;	dbut lment BIBLIO:;	DB;		dfinitions TDEF,PDEF,GDEF,FDEF utilises;	 	objets;	 .;	 .;	FB;	fin lment BIBLIO;	 .;	DB;		objets;	FB;;	EOF;; -------------------------------------;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; --------------------------------------; 	MODIFICATIONS:;; 0.1	- page vide aprs suppression dernier lment, plus pav invers; 0.2	- en 'utilisation' les pages vides sont ou grises ou sautes par F10/F12;	- dplacement d'un pav d'une page  l'autre possible;	- la suppression des trous dans la BIBLIO (trs lente) n'est faite que si;	  rellement ncessaire (aprs suppression d'un lment); 0.3	- modif PLANB_OUVRE pour PLAN biblio/b ...;;  faire:;	- mise  jour plus rapide,  l'aide d'un buffer pour liminer les trous;	- ne pas agrandir si pav dans PLAN plus petit que pav BIBLIO;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;MAJREV	=	0MINREV	=	3	.Rev	MAJREV,MINREV	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; En-tte du module LIB; ---------------------	.LOC	0	PLANB_	FIRST			; code du premier appel	PLANB_	LAST			; code du dernier appel	.B	0			; nombre d'installations	.FILLB	(OHLREV-.),0	.B	MAJREV,MINREV			; rvision.version	.W	0,END_PLANB		; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF		; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"PLANB"			; nom du module	.FILLB	(LGHLIB-.),0	.W	_PLANB_OUVRE		; initialise une nlle BIBLIO	.W	_PLANB_BIBLIO		; utilise une BIBLIO	.W	_PLANB_FERME		; ferme et mj. une BIBLIO; DIVERS	.W	_PLANB_HELP		; affiche PLAN_H.IMAGE	.INS	PLANBDIV.ASI;************* _PLANB_HELP:;*************;; affiche image d'aide pour PLAN centr  l'cran; in	A0	variables PLANB;	PUSHM.L	D0..D6,A1..A4	CALL	PUSHECRPLAN		; sauver cran PLAN	JUMP,NE	90$	LOAD.L	A3,#R16"BTXHMENU	LIB	?AFMENU	LOAD.L	A3,#R16"TPLANH	CALL	RDIMA	JUMP,NE	90$			; non => 08$					; oui ...	LOAD.L	D4,#0	LOAD.L	D2,#LBWDOX*H'10000+LBWDOY ; dim maximales	CALL	AFFIMA			; ... affiche	JUMP,NE	80$	LOAD.L	A4,A1			; rendre mmoire	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	JUMP,NE	90$	LIB	?GETCAR	COMP.W	D3,#F0	JUMP,EQ	80$	COMP.W	D3,#END	JUMP,EQ	80$	LOAD.L	A3,#R16"TPLANH1		; 2e image	CALL	RDIMA	JUMP,NE	90$			; non => 08$					; oui ...	LOAD.L	D4,#0	LOAD.L	D2,#LBWDOX*H'10000+LBWDOY ; dim maximales	CALL	AFFIMA			; ... affiche	JUMP,NE	80$	LOAD.L	A4,A1			; rendre mmoire	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	JUMP,NE	90$	LIB	?GETCAR80$:	CALL	POPECRPLAN		; restitue cran PLAN90$:	POPM.L	D0..D6,A1..A4	TEST.W	D7	RETTPLANH:	.ASCIZE	"#:PLAN_H.IMAGE"TPLANH1:	.ASCIZE	"#:PLAN_H1.IMAGE"BTXHMENU:		;.....|.....|.....|	.ASCIZ	"Ter-"	.ASCIZ	"mine"			; F0	.ASCIZ	"  Suite des ..."	.ASCIZ	"  explications "	; F1..F3	.ASCIZ	""			; F4..F6	.ASCIZ	""	.ASCIZ	""			; F7..F9	.ASCIZ	""	.ASCIZ	""			; F10..F12	.ASCIZ	""	.ASCIZ	""			; F13..F15	.ASCIZ	""	.EVENEND_PLANB:	.END