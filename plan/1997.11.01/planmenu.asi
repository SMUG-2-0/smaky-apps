		.SBTTL	PLANMENU	; 18 ao 87 Sp.;------------\\; DBOXCOULEUR >;============/; Choix des couleurs  visualiser.; in	-; out	D7.W	erreur; mod	D7.WDBOXCOULEUR:	PUSHM.L	D1,D2,D3,D4,A1,A2,A3,A4	LOAD.L	A2,#R16"TDBOX_COULEUR	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4	LOAD.W	D4,(A6)+OPLANAV+OCOULEUR	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; ok ?	JUMP',EQ 50$	COMP.W	D3,#END		; annule ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:	COMP.W	D4,(A6)+OPLANAV+OCOULEUR ; couleur(s) change(s) ?	JUMP',EQ 80$		; non => 80$	LOAD.W	(A6)+OPLANAV+OCOULEUR,D4	TSET.B	(A6)+OPLANAV+OFLAGS:#BMDBOX ; comme si cran dtruit par DBOX80$:	CALL	DBOXCLOSE	; ferme la DBOX, et refait ventuellement90$:	POPM.L	D1,D2,D3,D4,A1,A2,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CHMENU  >;========/; Change le menu DEFINE.; in	-; out	-; mod	D7.WCHMENU:	PUSHM.L	D1,D2,D3,D4,D5,D6,A1,A2,A3,A4	LOAD.L	A2,#R16"TDBOX_DEFINE	LOAD.W	D2,#2^BDBSAV	CALL	GETFANIONS	; D4 <-- tats des fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A3,#(A6)+OBUTEMP	LOAD.W	D6,(A6)+OPLANAV+OMWDOY	; D6 <-- dimensions actuelles	SWAP.W	D6	LOAD.W	D6,(A6)+OPLANAV+OMWDOX10$:	CALL	PUTDIM		; met dans OBUTEMP20$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_DEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	10$		; oui => 10$	COMP.W	D3,#CR	JUMP,EQ 50$	COMP.W	D3,#END	JUMP,EQ	45$	COMP.W	D3,#DEFINE	JUMP,EQ	30$	COMP.W	D3,#FNCT	JUMP',EQ 25$	COMP.W	D3,#MACRO	JUMP,EQ	24$	COMP.W	D3,#UNDO	JUMP,EQ	40$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$24$:				; MACRO =>	CALL	_RSTATPRI	LOAD.L	D6,(A6)+OPRIY	; dim. page	SWAP.W	D6		; format horizontal	JUMP	10$25$:				; FNCT =>	CALL	_RSTATPRI	; lit le statut de l'imprimante	LOAD.L	D6,(A6)+OPRIY	; dim. page	JUMP	10$30$:				; DEF =>	LOAD.W	D6,(A6)+OPLANAV+ODWDOY	SWAP.W	D6	LOAD.W	D6,(A6)+OPLANAV+ODWDOX	JUMP	10$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne;;	CLR.L	D6	JUMP	20$45$:				; ANNULE => (END)	CALL	DBOXCLOSE	; ferme la DBOX	JUMP	90$		;    ... et fin50$:				; OK =>	DBOX_	CLOSE		; ferme la DBOX	CLR.W	D2		; D2 <-- initialise signal	TEST.B	(A6)+OPLANAV+OFLAGS:#BMDBOX	JUMP,BC	51$	INC.W	D251$:	CALL	GETDIM		; D6 <-- dimensions	LOAD.W	D0,(A6)+OPLANAV+OMWDOX	; D0 <-- ancien DX	COMP.W	D6,(A6)+OPLANAV+OMWDOX	; idem ?	JUMP,EQ	52$		; oui	INC.W	D2		; non, signal ...;;	LOAD.W	D0,(A6)+OPLANAV+OMWDOX	; D0 <-- ancien DX52$:	SWAP.W	D0	LOAD.W	D0,(A6)+OPLANAV+OMWDOY	; D0 <-- ancien DY	LOAD.W	(A6)+OPLANAV+OMWDOX,D6	SWAP.W	D6	COMP.W	D6,(A6)+OPLANAV+OMWDOY	JUMP,EQ	54$	INC.W	D2;;	SWAP.W	D0		; D0 <-- ancien DY;;	LOAD.W	D0,(A6)+OPLANAV+OMWDOY54$:	LOAD.W	(A6)+OPLANAV+OMWDOY,D6	CALL	PUTFANIONS	; mj les fanions	TEST.W	D2		; idem ?	JUMP',NE 80$		; non => 80$				; oui =>	CALL	DBOXREFAIT	; refait si DBOX a dmoli	CALL	INIBAS		; non => refait le bas	CALL	INIHAUT		; ... et le haut	JUMP'	90$80$:	TSET.B	(A6)+OPLANAV+OFLAGS:#BMODIF ; signal plan modifi	TEST.L	D4:#10		; zoom gnral ?	JUMP,BC	89$		; non --> 81$	LOAD.L	D4,D6		; D4 <-- coin sup. droit (idem nouvelle dim.)	MUL.WU	D6,#1000	; xx * 1000 ...	DIV.WU	D6,D0		; ... / ancienne dim.	LOAD.W	(A6)+OPLANAV+OXZOOM,D6	LOAD.L	D6,D4		; D6 <-- nouveau	SWAP.W	D6	SWAP.W	D0	MUL.WU	D6,#1000	; yy * 1000 ...	DIV.WU	D6,D0		; ... / ancienn dim.	COMP.W	D6,(A6)+OPLANAV+OXZOOM	; sans dformation prendre le facteur le plus petit	JUMP,HS	85$	LOAD.W	(A6)+OPLANAV+OXZOOM,D685$:	LOAD.W	(A6)+OPLANAV+OYZOOM,(A6)+OPLANAV+OXZOOM ; le mme sans dformation	CLR.L	(A6)+OPLANAV+OOWDOY	; force la fentre en 0	CLR.L	D3		; D3 <-- coin inf. gauche	LOAD.L	D4,D0		; D4 <-- ancienne dimension = coin sup. droit	CLR.B	D0		; D0 <-- 0 (par rapport  l'origine)				;	type de zoom;;;	CALL	ZOOM		; fait ZOOM	PUSH.B	D5	LOAD.B	D5,#3+2	.W	PLANA_OPER	POP.B	D5	JUMP,NE	95$		; affiche l'erreur89$:	CALL	EFFACE		; efface tout	CALL	REFAIT		; puis refait tout proprement90$:	POPM.L	D1,D2,D3,D4,D5,D6,A1,A2,A3,A4	RET95$:	CALL	MOERROR		; erreur ZOOM	JUMP	89$; nouveau !!!PUTDIM:; in	D6.L	dimension (yy;xx);	D4	fanions;	A3	^OBUTEMP; out	OBUTEMP contient l x h en ASCII; mod	A4	PUSHM.L	D0,D3,D4	LOAD.L	D3,D4	LOAD.L	A4,A3		; A4 ^OBUTEMP	LOAD.W	D4,D6		; D4 <-- D6 (xx)	TEST.L	D3:#8		; mm ?	JUMP,BC	10$		; non --> 10$	LOAD.W	D0,(A6)+OMMX	; oui, pg --> mm	MUL.WU	D0,(A6)+OFACX	; mm = (pg * OMMX * OFACX) / 10000	MUL.WU	D4,D0	DIV.WU	D4,#10000	SWAP.W	D4		; v. arrondi	COMP.W	D4,#10000/2	JUMP,LO	9$	ADD.L	D4,#H'100009$:	SWAP.W	D410$:	CALL	PUTANUM		; largeur --> OBUTEMP	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'/	; sparateur	LOAD.B	(A4+),#SPACE	SWAP.W	D6	LOAD.W	D4,D6		; D4 <-- D6 (yy)	SWAP.W	D6	TEST.L	D3:#8		; mm ?	JUMP,BC	20$		; non --> 10$	LOAD.W	D0,(A6)+OMMY	; oui, pg --> mm	MUL.WU	D0,(A6)+OFACY	; mm = (pg * OMMX * OFACX) / 10000	MUL.WU	D4,D0	DIV.WU	D4,#10000	SWAP.W	D4		; v. arrondi	COMP.W	D4,#10000/2	JUMP,LO	19$	ADD.L	D4,#H'1000019$:	SWAP.W	D420$:	CALL	PUTANUM		; hauteur --> OBUTEMP	CLR.B	(A4)		; terminateur	POPM.L	D0,D3,D4	RET; nouveau !!!GETDIM:; in	A3	^OBUTEMP contient l x h en ASCII;	D4	fanions; out	D6	dimension (yy;xx); mod	A4	PUSHM.L	D0,D3,D4	LOAD.L	D3,D4		; D3 <-- fanions	LOAD.L	A4,A3		; A4 <-- ^1er nombre	CALL	GETANUM		; D4 <-- largeur	TEST.L	D3:#9		; pg ?	JUMP,BS	10$		; oui ...	LOAD.W	D0,(A6)+OMMX	; non, mm --> pg	MUL.WU	D0,(A6)+OFACX	; pg = (mm * 10000) / OFACX * OMMX	MUL.WU	D4,#10000	DIV.WU	D4,D0	SWAP.W	D4		; v. arrondi	SR.W	D0,#1		; /2	COMP.W	D4,D0	JUMP,LO	9$	ADD.L	D4,#H'100009$:	SWAP.W	D410$:	TEST.L	D3:#31		; pas de min. ou max.	JUMP,BS	20$	COMP.W	D4,#MINWDOX	JUMP',HS 15$	LOAD.W	D4,#MINWDOX15$:	COMP.W	D4,#MAXWDOX+1	JUMP,LO	20$	LOAD.W	D4,#MAXWDOX20$:	LOAD.W	D6,D4		; D6 <-- D4 (xx)	CLR.L	D421$:	LOAD.B	D0,(A4+)	; D0 <-- sparateur	JUMP',EQ 30$	COMP.B	D0,#CR	JUMP',EQ 30$	COMP.B	D0,#'0	JUMP,LO	21$	COMP.B	D0,#'9	JUMP,HI	21$	DEC.L	A4		; A4 <-- ^2me nombre	CALL	GETANUM		; D4 <-- hauteur	TEST.L	D3:#9		; pg ?	JUMP,BS	30$		; oui ...	LOAD.W	D0,(A6)+OMMY	; non, mm --> pg	MUL.WU	D0,(A6)+OFACY	; pg = (mm * 10000) / OFACY * OMMY	MUL.WU	D4,#10000	DIV.WU	D4,D0	SWAP.W	D4		; v. arrondi	SR.W	D0,#1		; /2	COMP.W	D4,D0	JUMP,LO	29$	ADD.L	D4,#H'1000029$:	SWAP.W	D430$:	TEST.L	D3:#31		; pas de min. ou max.	JUMP,BS	40$	COMP.W	D4,#MINWDOY	; aumoins minimum ?	JUMP',HS 35$	LOAD.W	D4,#MINWDOY35$:	COMP.W	D4,#MAXWDOY+1	JUMP,LO	40$	LOAD.W	D4,#MAXWDOY40$:	SWAP.W	D6	LOAD.W	D6,D4		; D6 <-- D4 (yy)	SWAP.W	D6	POPM.L	D0,D3,D4	RET;-----------\\; GETFANIONS >;-----------/; Donne l'tat des fanions.; in	-; out	D4.L	tat des fanions; mod	D4.LGETFANIONS:	CLR.L	D4		; D4 <-- tat des fanions	test.b	(a6)+OFLMOD:#BIMAFOND	JUMP,BC	05$	TSET.L	D4:#305$:	TEST.B	(A6)+OFLMOD:#BLAST	JUMP',BC 10$	TSET.L	D4:#1110$:;;;;;	TEST.B	(A6)+OPLANAV+OFLAGS:#BTEMP	TEST.B	(A6)+OPLANAV+OFLAGS:#BINFOD	JUMP',BC 20$	TSET.L	D4:#120$:	TEST.B	(A6)+OFLMOD:#BMINGC	JUMP',BC 30$	TSET.L	D4:#230$:	TEST.B	(A6)+OFLMOD:#BICADRE	JUMP',BC 50$	TSET.L	D4:#450$:	TEST.B	(A6)+OPLANAV+OFLAGS:#BMEMCAS	JUMP',BC 70$	TSET.L	D4:#670$:	TEST.B	(A6)+OFLRET:#BRETICULE	JUMP',BC 80$	TSET.L	D4:#780$:	TEST.B	(A6)+OFLMOD:#BENMM	JUMP',BC 85$	TSET.L	D4:#8	JUMP'	90$85$:	TSET.L	D4:#990$:	RET;-----------\\; PUTFANIONS >;-----------/; Met  jour l'tat des fanions.; in	D4.L	tat des fanions;	D2.W	diffrent de zro --> faut tout redessiner; out	D2.W	diffrent de zro --> faut tout redessiner; mod	D2.WPUTFANIONS:	tclr.b	(a6)+OFLMOD:#BIMAFOND	TEST.L	D4:#3	JUMP,BC	05$	TSET.B	(A6)+OFLMOD:#BIMAFOND05$:	TCLR.B	(A6)+OFLMOD:#BLAST	TEST.L	D4:#11	JUMP',BC 10$	TSET.B	(A6)+OFLMOD:#BLAST10$:;;;;;	TCLR.B	(A6)+OPLANAV+OFLAGS:#BTEMP	TCLR.B	(A6)+OPLANAV+OFLAGS:#BINFOD	TEST.L	D4:#1	JUMP',BC 20$;;;;;	TSET.B	(A6)+OPLANAV+OFLAGS:#BTEMP	TSET.B	(A6)+OPLANAV+OFLAGS:#BINFOD20$:	TCLR.B	(A6)+OFLMOD:#BMINGC	TEST.L	D4:#2	JUMP',BC 30$	TSET.B	(A6)+OFLMOD:#BMINGC30$:	TEST.L	D4:#4	JUMP',BS 50$	TCLR.B	(A6)+OFLMOD:#BICADRE	JUMP',BC 55$	INC.W	D2		; D2 <-- faut tout redessiner	JUMP'	55$50$:	TSET.B	(A6)+OFLMOD:#BICADRE	JUMP',BS 55$	INC.W	D2		; D2 <-- faut tout redessiner55$:	TCLR.B	(A6)+OPLANAV+OFLAGS:#BMEMCAS	TEST.L	D4:#6	JUMP',BC 70$	TSET.B	(A6)+OPLANAV+OFLAGS:#BMEMCAS70$:	TCLR.B	(A6)+OFLRET:#BRETICULE	TEST.L	D4:#7	JUMP',BC 80$	TSET.B	(A6)+OFLRET:#BRETICULE80$:	TCLR.B	(A6)+OFLMOD:#BENMM	TEST.L	D4:#8	JUMP',BC 90$	TSET.B	(A6)+OFLMOD:#BENMM	INC.W	D290$:	RET;--------\\; PUTANUM >;--------/; Met un nombre dcimal dans un buffer.; in	D4.W	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	AND.L	D4,#H'FFFF	; D4 <-- nombre binaire	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;--------/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSH.L	D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POP.L	D3	RET;--------\\; CHWDO   >;========/; Change l'origine de la fentre; in	-; out	-; mod	D7.WCHWDO:	PUSHM.L	D1,D2,D3,D4,D5,D6,A1,A2,A3,A4	LOAD.L	A2,#R16"TDBOX_WDO	LOAD.W	D2,#2^BDBSAV!2^BDBCAS	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	LOAD.W	D2,#2	DBOX_	GETCO	JUMP,NE	90$	LIB	?SETCURS	LOAD.L	D4,#H'80000000	TEST.B	(A6)+OFLMOD:#BENMM	JUMP,BC	5$	LIB	?AFTIM	.ASCIZE	/  [mm]/	TSET.L	D4:#8	JUMP'	6$5$:	LIB	?AFTIM	.ASCIZE	/  [pg]/	TSET.L	D4:#96$:	LOAD.L	A3,#(A6)+OBUTEMP	LOAD.W	D6,(A6)+OPLANAV+OOWDOY	; D6 <-- origine actuelle	SWAP.W	D6	LOAD.W	D6,(A6)+OPLANAV+OOWDOX10$:	CALL	PUTDIM		; met dans OBUTEMP20$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	10$		; oui => 10$	COMP.W	D3,#CR	JUMP,EQ 50$	COMP.W	D3,#END	JUMP,EQ	45$	COMP.W	D3,#DEFINE	JUMP,EQ	30$	COMP.W	D3,#UNDO	JUMP,EQ	40$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$30$:				; DEF =>	CLR.L	D6;	LOAD.W	D6,#0;	SWAP.W	D6;	LOAD.W	D6,#0	JUMP	10$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$45$:				; ANNULE => (END)	CALL	DBOXCLOSE	; ferme la DBOX	JUMP	90$		;    ... et fin50$:				; OK =>	DBOX_	CLOSE		; ferme la DBOX	CLR.W	D2		; D2 <-- initialise signal	TEST.B	(A6)+OPLANAV+OFLAGS:#BMDBOX	JUMP,BC	51$	INC.W	D251$:	CALL	GETDIM		; D6 <-- dimensions	COMP.W	D6,(A6)+OPLANAV+OOWDOX	; idem ?	JUMP,EQ	52$		; oui	INC.W	D2		; non, signal ...52$:	LOAD.W	(A6)+OPLANAV+OOWDOX,D6	SWAP.W	D6	COMP.W	D6,(A6)+OPLANAV+OOWDOY	JUMP,EQ	54$	INC.W	D254$:	LOAD.W	(A6)+OPLANAV+OOWDOY,D6	TEST.W	D2		; idem ?	JUMP',NE 80$		; non => 80$				; oui =>	CALL	DBOXREFAIT	; refait si DBOX a dmoli	JUMP'	90$80$:	LOAD.W	D6,(A6)+OPLANAV+OMWDOY	; vrifier le max. autoris	SUB.W	D6,(A6)+OPLANAV+OSWDOY	COMP.W	D6,(A6)+OPLANAV+OOWDOY	JUMP,HS	83$	COMP.W	D6,#0	JUMP,NC	81$	CLR.W	D681$:	LOAD.W	(A6)+OPLANAV+OOWDOY,D683$:	LOAD.W	D6,(A6)+OPLANAV+OMWDOX	SUB.W	D6,(A6)+OPLANAV+OSWDOX	COMP.W	D6,(A6)+OPLANAV+OOWDOX	JUMP,HS	86$	COMP.W	D6,#0	JUMP,NC	84$	CLR.W	D684$:	LOAD.W	(A6)+OPLANAV+OOWDOX,D686$:	CALL	EFFACE		; efface tout	CALL	REFAIT		; puis refait90$:	POPM.L	D1,D2,D3,D4,D5,D6,A1,A2,A3,A4	RETTDBOX_WDO:	.W	10$-TDBOX_WDO	.W	MENU_OKAN-TDBOX_WDO	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Origine fentre (X / Y)"	.B	ODBCR,ODBCR,ODBTABX,8	.B	ODBLINE,13+2	.B	ODBTEXT	.ASCIZ	/      /	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTABX,20	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	0	.EVEN.IF	GROUPETX;-----------\\; DBOXGRTEXT >;===========/; saisie du texte  mettre avec un groupe utilisatur; in	-; out	texte ds. OBUTEMP; mod	D7.WDBOXGRTEXT:	PUSHM.L	D1..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_GRTEXTE	LOAD.W	D2,#2^BDBSAV!2^BDBCAS	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A3,#(A6)+OBUTEMP10$:	LOAD.L	A4,A3	CLR.B	(A4)20$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR	JUMP,EQ 50$	COMP.W	D3,#END	JUMP,EQ	45$	COMP.W	D3,#UNDO	JUMP,EQ	10$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$;;40$:				; UNDO =>;;	LOAD.L	A4,A3;;	CLR.B	(A4)		; vide toute la ligne;;	JUMP	10$45$:				; ANNULE => (END)	CALL	DBOXCLOSE	; ferme la DBOX	CLR.B	D0		; D0 <-- 0=utilisateur	JUMP	90$		;    ... et fin50$:				; OK =>	CALL	DBOXCLOSE	LOAD.L	D0,#2		; D0 <-- 2=utilisateur avec texte90$:	POPM.L	D1..D5,A1..A4	RETTDBOX_GRTEXTE:	.W	10$-TDBOX_GRTEXTE	.W	MENU_OKAN-TDBOX_GRTEXTE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Texte  mettre"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"  avec le groupe utilisateur:"	.B	ODBCR,ODBCR	.B	ODBLINE,28+2	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTABX,20	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	0	.EVEN.ENDIF	.END