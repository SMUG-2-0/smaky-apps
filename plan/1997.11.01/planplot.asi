		.SBTTL	PLANPLOT		; 18 aot 87 Sp.	; 29 fvrier 1988:	utilisation du module PLOT pour dragmode;---------\\; PLOT	   >;---------/; crit les coordonnes dans l'USART;; in:	D4.L	coordonnes y/x; out:; mod:PLOT:	PUSHM.L	D3,D4,D5	TEST.B	(A6)+OFLMOD:#BPLHP	; dragging ?	JUMP,BC	90$			; non	LOAD.L	D5,(A6)+OPLOTD5		; canal du module PLOT	PLOT_	DRAG90$:	POPM.L	D3,D4,D5	RET;----------\\; IPLOTHP:  >;----------/; ouvre et initialise ou ferme l'USART pour plotter HP, dragmode;; in:	; out:	; mod:	IPLOTHP:	PUSHM.L	D1,D2,D3,D4,D5,A3	LOAD.W	D4,#0	LIB	?WAITMOUSE	TEST.B	(A6)+OFLMOD:#BPLHP	; inverse le bit	jump,bs	20$			; si dj ouvert, alors fermer	CALL	_AFCMES	.ASCIZE	" un instant svp., initialisation du traceur en cours ..."	CALL	CWMO	CALL	SRMO	LOAD.L	A3,#R16"NAMPLOT		; charger module PLOT	LOAD.W	D3,#PLOT_FIRST	.W	LIB_OPEN	JUMP,NE	90$	LOAD.W	(A6)+OCHPLOT,D1		; mmorise canal	CLR.L	D2			; D2 <-- mode	PLOT_	OUVRE			; OUVRIR	JUMP,NE	80$	LOAD.L	(A6)+OPLOTD5,D5	TSET.B	(A6)+OFLMOD:#BPLHP	JUMP	90$20$:	LOAD.L	D5,(A6)+OPLOTD5		; FERMER	PLOT_	FERME	TCLR.B	(A6)+OFLMOD:#BPLHP80$:	PUSH.W	D7	LOAD.W	D1,(A6)+OCHPLOT		; librer module PLOT	.W	LIB_CLOSE	POP.W	D790$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POP.W	D7;;;;	CALL	DOERROR	CALL	_IOERROR	CALL	_INIBAS	CALL	CRMO	POPM.L	D1,D2,D3,D4,D5,A3	RET	.END