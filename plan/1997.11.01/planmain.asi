	.SBTTL	PLANMAIN		; 18 aot 87 Sp.;;;	.LOC	0START:	LIB	?OPELIB		; ouvre la librairie	JUMP,NE	FATER1	LOAD.W	D3,#3		; D3 <-- souris par le clavier + sablier manuel	LIB	?MOUSE		; signal souris utilise	LOAD.L	A6,#0		; A6 <-- pas encore ^variables;; Demande de la mmoire pour les variables et initialise; les plus faciles.;	LOAD.L	D4,#LGVAR	ADD.L	D4,#H'3	AND.L	D4,#H'FFFFFFFC	; modulo 4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE FATER1	LOAD.L	A6,A4		; A6 <-- ^variables	SR.L	D4,#2		; D4 / 410$:	CLR.L	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE	10$	LOAD.L	(A6)+OPTCOM,A3	; mm. ^ligne de commande	LOAD.L	A4,#R16"STARTC	LOAD.L	(A6)+OSTART,A4;;;	CALL	SWMO		; met la souris "en attente"	LOAD.B	(A6)+OREF,#-1	; initialise 'pas encore de lutin INFO'	LOAD.W	D4,#H'AAAA	; tester rvision systme	LIB	?GETREV	COMP.W	D4,#H'AAAA	JUMP,EQ	14$		; trop ancien	COMP.W	D4,#REVSYS	JUMP,HS	15$		; ok.14$:	LOAD.W	D3,#BIPFAT	; trop ancien	LIB	?BEEP	LOAD.W	D7,#ERRSYS	CALL	_IOERROR	JUMP	RETOUR115$:	CALL	SWMO		; met la souris "en attente";; Lit les modules ncessaires;	LOAD.L	A3,#R16"NAMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN		; ouvre le module SCROLL	JUMP,NE	FATER2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NAMDGENC	LOAD.W	D3,#DGENC_FIRST	LIB_	OPEN		; ouvre le module DGENC	JUMP,NE	FATER2	LOAD.W	(A6)+OCHDGENC,D1	LOAD.L	A3,#R16"NAMDBOX	LOAD.W	D3,#DBOX_OPEN	LIB_	OPEN		; ouvre le module DBOX	JUMP,NE	FATER2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NAMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN		; ouvre le module LIST	JUMP,NE	FATER2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NAMSPLINE	LOAD.W	D3,#SPLINE_FIRST	LIB_	OPEN		; ouvre le module SPLINE	JUMP,NE	FATER2	LOAD.W	(A6)+OCHSPLINE,D1	LOAD.L	A3,#R16"NAMDESS	LOAD.W	D3,#DESSIN_FIRST	LIB_	OPEN		; ouvre le module DESSIN	JUMP,NE	FATER2	LOAD.W	(A6)+OCHDESS,D1	LOAD.L	A3,#R16"NAMSTRETCH	LOAD.W	D3,#ST_FIRST	LIB_	OPEN		; ouvre le module STRETCH	JUMP,NE	FATER2	LOAD.W	(A6)+OCHSTRETCH,D1	LOAD.L	A3,#R16"NAMPLANA	LOAD.W	D3,#PLANA_FIRST	LIB_	OPEN		; ouvre le module PLANA	JUMP,NE	FATER2	LOAD.W	(A6)+OCHPLANA,D1	LOAD.L	A3,#R16"NAMPLANB	LOAD.W	D3,#PLANB_FIRST	LIB_	OPEN		; ouvre le module PLANB	JUMP,NE	FATER2	LOAD.W	(A6)+OCHPLANB,D1;;;;?????	LOAD.L	A3,#R16"NAMMATH32	LOAD.W	D3,#MATH32_AFP	LIB_	OPEN		; ouvre le module MATH32	JUMP,NE	FATER2	LOAD.W	(A6)+OCHMATH32,D1;;;;?????;;;;	LOAD.B	(A6)+OFLMOD,#2^BICADRE	; (cf. plus loin)	LOAD.L	(A6)+OLDPOS,#-1	LOAD.B	(A6)+OLDBOU,#-1	LOAD.L	(A6)+OPOCU,#-1	LOAD.B	(A6)+OPLANAV+OGCLIST,#-1 ; init liste des genc	LOAD.L	A3,(A6)+OPTCOM	; A3 <-- ^ligne de commande	LOAD.W	D3,#MPDIV*2/5	; prend les 2/5 de la mmoire	LOAD.L	D4,#LGMEM*10	; D4 <-- longueur minimale	LOAD.L	D5,#LGMEM*(2^16); D5 <-- longueur maximale	LOAD.W	D1,#MTYPCP	; D1 <-- processus courant	LIB	?GTRSMM		; cherche rservation mmoire	JUMP,NE FATER2	LOAD.L	(A6)+OPLANAV+OPBMEM,A4	; init ^buffer mm.	DIV.WU	D4,#LGMEM	LOAD.W	(A6)+OPLANAV+ONBMEM,D4	; init nb lments	LOAD.L	A5,#(A6)+OPLANAV ; A5 ^variables module PLANA	CALL	INIDEF		; objets par dfaut	CALL	_INIBIBLIO	; initialise variables BIBLIO	LOAD.W	(A6)+OPLANAV+OPLANA,#BCLRBASE	.W	PLANA_BASE	; vide la base de donnes;; Demande les adresses des routines graphiques rapides.;	LOAD.W	D3,#GRA_QIDOT	LIB_	GETAD	JUMP,NE FATER2	LOAD.L	(A6)+OADQDOT,A3	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	LOAD.L	(A6)+OADLINE,A3;; initialise les adresses pour les DBOX utilises par PLANA.LIB;	LOAD.L	A3,#R16"DBOXOPEN	LOAD.L	(A6)+OPLANAV+OADBOPEN,A3	; adr. DBOXOPEN	LOAD.L	A3,#R16"DBOXCLOSE	LOAD.L	(A6)+OPLANAV+OADBCLOSE,A3	; adr. DBOXCLOSE	LOAD.L	A3,#R16"DBOXREFAIT	LOAD.L	(A6)+OPLANAV+OADBREF,A3		; adr. DBOXREFAIT;;;;;	LOAD.L	(A6)+OPLANAV+OAPOSDBFLE,#188*H'10000+265 ; coord. d'affichage DBFLECHE;; Met le driver d'cran dans le bon mode.;	LIB	?AFTIM	.B	MODGRA,GRACLIP	; cliping pour graphique	.B	NOCURS		; plus de curseur	.B	MMODULO,01	; plus de modulo pour cran	.B	0	.EVEN;; Lit le status de l'imprimante;	CALL	RSTATPRI;; Vrifie si la souris est connecte.;	LIB	?GCHMOU		; D6 <-- canal de la souris	LOAD.W	(A6)+OCHMOU,D6;;?	TEST.W	D6		; souris existe ?;;?	JUMP,EQ	ERMOUSE		; non => ERMOUSE;; lit le type de la machine; et initialise les valeurs pour ROTIMA ds. PLANIMAGE;	NTREL	?GETMACHINE	JUMP,NE	FATER2	RL.L	D4,#8			; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4;@@@@ SMAKY8 modifi, cran idem SM100;	COMP.B	D4,#SMAKY8;	JUMP,NE	20$				; valeurs pour SMAKY8, cran entrelac !!!;	LOAD.B	(A6)+ONEPIX,#1;	LOAD.B	(A6)+OLEPIX,#0;;;;	LOAD.L	(A6)+ODIX,#1024	valeurs lues dans;;;;	LOAD.L	(A6)+ODIY,#1	status de l'cran (cf. plus loin);	JUMP	30$20$:				; valeurs pour SM100 etc.	LOAD.B	(A6)+ONEPIX,#-1	LOAD.B	(A6)+OLEPIX,#7;;;;	LOAD.L	(A6)+ODIX,#1	valeurs lues dans;;;;	LOAD.L	(A6)+ODIY,#128	status de l'cran (cf. plus loin)30$:	LOAD.W	D4,#1	NTREL	?CRESEM		; cre smaphore d'exclusion	JUMP,NE	FATER2	LOAD.L	(A6)+OPSEMA,A5	CLR.W	D4	NTREL	?CRESEM		; cre smaphore de synchro	JUMP,NE	FATER2	LOAD.L	(A6)+OPSEMS,A5	LOAD.L	A5,#(A6)+OPLANAV ; A5 ^variables du module PLANA;; Lit le status de la fentre pour prendre toutes les; informations ncessaires.;	LIB	?GCHDIS		; D6 <-- canal	LOAD.W	(A6)+OPLANAV+OCHDIS,D6	; mm. canal de l'cran	FOS	?GETTYPE	LOAD.W	(A6)+OPLANAV+ONODIS,D2	; mm. no driver de l'cran	LOAD.L	A4,#(A6)+OPLANAV+OPDDIS	; A4 <-- ^buffer pour ^	LOAD.L	D4,#4		; D4 <-- longueur .L	LOAD.W	D3,#TYPWDO	; D3 <-- type	FOS	?RSTATUS	; lit ^status fentre	JUMP,NE	FATER2	LOAD.L	A4,(A4)		; A4 <-- ^descripteur de la fentre	LOAD.L	(A6)+OPLANAV+ODEFGC,#H'1000000*GCTXF+H'10000*GCTXS+H'100*GCTXT	LOAD.W	(A6)+OPLANAV+OCARX,(A4)+ODFCX	; mm. largeur max. car.	LOAD.W	D4,(A4)+ODFC1Y	LOAD.W	(A6)+OPLANAV+OCAR1Y,D4		; mm. hauteur dessus ligne de base	ADD.W	D4,(A4)+ODFC2Y	LOAD.W	(A6)+OPLANAV+OCARY,D4		; mm. hauteur effective car.	LOAD.W	(A6)+OPLANAV+OCAR2Y,(A4)+ODFC2Y	LOAD.W	(A6)+ODIX+2,(A4)+ODFIIX		; utilis par PLANIMAGE	LOAD.W	(A6)+ODIY+2,(A4)+ODFIIY		; idem	LOAD.B	(A6)+OFLMOD,#2^BICADRE		; cadre invers	TEST.B	(A4)+ODFMOD:#BFBLANC		; si fond blanc, l'inverse ...	JUMP,BC	35$	TNOT.B	(A6)+OFLMOD:#BICADRE35$:;; Initialise les variables donnant les dimensions de la; partie utilise pour le dessin proprement dit.;	LIB	?GETDIM			; D3 <-- car,  D4 <-- fentre	LOAD.L	(A6)+OPLANAV+OWDOY,D4	; init OWDOX et OWDOY;;@@	AND.B	D3,#B'11111000		; arrondi X modulo 8;;@@	JUMP',NE 40$			; reste qq chose => 40$	LOAD.W	D3,#8			; reste rien => au moins 840$:	SWAP.W	D3;;@@	AND.B	D3,#B'11111110	; arrondi Y modulo 2	ADD.W	D3,#2		; marge si cadre (BICADRE=0)	SWAP.W	D3	LOAD.L	(A6)+OPLANAV+OMINY,D3	; init OMINX et OMINY	SUB.W	D4,D3	LOAD.W	(A6)+OPLANAV+OMAXX,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	LOAD.W	(A6)+OPLANAV+OMAXY,D4	LOAD.W	D3,(A6)+OPLANAV+OMAXX	SUB.W	D3,(A6)+OPLANAV+OMINX;;?	DEC.W	D3	LOAD.W	(A6)+OPLANAV+OLWDOX,D3	LOAD.W	D3,(A6)+OPLANAV+OMAXY	SUB.W	D3,(A6)+OPLANAV+OMINY;;?	DEC.W	D3	LOAD.W	(A6)+OPLANAV+OLWDOY,D3	LOAD.L	(A6)+OPLANAV+ODWDOY,(A6)+OPLANAV+OLWDOY;; Initialise la position de la fentre virtuelle.;	CLR.W	(A6)+OPLANAV+OOWDOX	CLR.W	(A6)+OPLANAV+OOWDOY	LOAD.W	(A6)+OPLANAV+OMWDOX,(A6)+OPLANAV+OLWDOX	LOAD.W	(A6)+OPLANAV+OMWDOY,(A6)+OPLANAV+OLWDOY	CALL	_AJMWDO		; ajuste OMWDOX,Y si trop petit	CALL	_NEWSCALE	; mj selon nouvelle chelle;; charge les gencars pour paramtres et icnes;	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE	LOAD.B	(A3)+0,#LOADGC	; charge	LOAD.B	(A3)+1,#GCPAF	; IPP06 (affichage des coordonnes)	LOAD.B	(A3)+2,#GCPAS	LOAD.B	(A3)+3,#GCPAT	LOAD.B	(A3)+4,#LOADGC	; charge et ...	LOAD.B	(A3)+5,#GCTXF	LOAD.B	(A3)+6,#GCTXS	LOAD.B	(A3)+7,#GCTXT	LOAD.B	(A3)+8,#USEGC	; ...utilise	LOAD.B	(A3)+9,#GCTXF	; NRF12	LOAD.B	(A3)+10,#GCTXS	LOAD.B	(A3)+11,#GCTXT	LOAD.B	(A3)+12,#LOADGC	; charge	LOAD.B	(A3)+13,#GCICF	; IPP16	LOAD.B	(A3)+14,#GCICS	LOAD.B	(A3)+15,#GCICT	LOAD.B	(A3)+16,#LOADGC	; charge	LOAD.B	(A3)+17,#GCIC1F	; IPP17	LOAD.B	(A3)+18,#GCIC1S	LOAD.B	(A3)+19,#GCIC1T	LOAD.W	D3,#20		; D3 <-- longueur	LIB	?STRING		; charge gencars	JUMP,NE FATER2;; efface cran avec PLAN.image;	LIB	?AFTIM		; efface cran avec .image	.B	EOP	.B	0	.EVEN	CALL	_CADRE		; fait le cadre	CALL	_INIHAUT	; init le haut de l'cran (provisoire)	CALL	_INIBAS	CALL	_AFMENU		; affiche le menu principal;;;;;?????CALL	INIT_INFOLOAD.B	(A6)+OUNITE,#UDEG*H'100+UMMLOAD.W	(A6)+OECHELLE,#1000	; chelle * 1000LOAD.B	(A6)+OFLINFO,#BINFO;;;;?????;; Lit un super-objet s'il a t donn dans la ligne; de commande.;	LOAD.L	A3,(A6)+OPTCOM	; A3 <-- ^ligne de commande	LIB	?SWITCH		; PLAN/.. ?	jump,ne	80$		; non	test.l	D3:#('X-'A)	; PLAN/X ?	jump,bc	80$		; non	tset.b	(a6)+Oflio:#BNOEXCL ; oui, pas de fichier!PLAN80$:	LIB	?SKPNAM		; A3 <-- cherche nom suivant	JUMP',NE 90$		; si rien => 90$	LIB	?SWITCH		; cherche le(s) switch(s)	JUMP,NE	80$		; erreur => 80$	TEST.L	D3		; switch(s) existe(nt) ?;	JUMP,NE	80$		; oui => 80$jump,ne	swb$				; non =>	CALL	FCINPUT		; lit un super-objet, dtruit Fond	JUMP	LOOPSWB$:	test.l	d3:#('B-'A)	; fichier/B ?	jump,bc	80$		; non	call	_fcbiblio	; charge BIBLIO	jump	80$90$:PNTPLAN:	LOAD.L	A3,#R16"NAMPLAN+2 ; lit PLAN.PLAN s'il existe,;;;	CALL	FCINPUT	LOAD.L	D4,#2^BPLANPLAN	CALL	XINPUT	JUMP,EQ	95$	LIB	?BUZZ		; signal ...	LOAD.L	A3,#R16"NAMPLAN	; si erreur essaie dans dossier systme	LOAD.L	D4,#0	CALL	XINPUT	JUMP,EQ	95$;; met aumoins un gnrateur s'il n'y a rien eu;	LOAD.W	D1,(A6)+OCHDGENC	; remet aumoins Fond 	LOAD.L	A4,#(A6)+OPLANAV+OBUGC;;	TSET.B	(A4)+OGCFLG:#BGCPROT	; Fond est supprimableLAMI	=	0.IF	LAMI	LOAD.B	(A4)+OGCF,#'U!2^7	LOAD.B	(A4)+OGCS,#0	LOAD.B	(A4)+OGCT,#16	LOAD.L	A3,#(A4)+OGCTIT	LOAD.B	(A3+),#'u	LOAD.B	(A3+),#'r	LOAD.B	(A3+),#'0	LOAD.B	(A3+),#'7.ELSE	LOAD.B	(A4)+OGCF,#GCTXF	LOAD.B	(A4)+OGCS,#GCTXS	LOAD.B	(A4)+OGCT,#GCTXT	LOAD.L	A3,#(A4)+OGCTIT	LOAD.B	(A3+),#'F	LOAD.B	(A3+),#'o	LOAD.B	(A3+),#'n	LOAD.B	(A3+),#'d.ENDIF	LOAD.L	A2,(A6)+OPLANAV+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OPLANAV+OBUGC	DGENC_	NEW	JUMP,NE	FATER2	; et fait semblant de ne pas exister,  lucider une fois ... ?	TCLR.B	(A4)+OGCFLG:#BGCUSE95$:	CALL	_INIHAUT	CALL	_INIBAS		; affiche ligne du bas;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;  B O U C L E  P R I N C I P A L E  du processus principal.  ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;LOOP:	CLR.B	(A6)+OKEYPR	; init flags boutons	CALL	CWMO		; remet la souris normale	LIB	?GETKEY		; attend clavier/souris ...	TEST.L	D3:#BKPSEUDO	; pseudo code/touche relache ?	JUMP,BS	LOOP		; oui => LOOP	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP,EQ	FILS		; oui => FILS	COMP.W	D3,#KEYMGP	JUMP,EQ	FILSCURSOR	COMP.W	D3,#KEYMMP	; bouton press ?	JUMP,EQ	FILS		; oui => FILS	COMP.W	D3,#KEYMDP	JUMP,EQ	FILS	COMP.W	D3,#KEYMGR	JUMP,EQ	LOOP	COMP.W	D3,#KEYMMR	; bouton relach ?	JUMP,EQ	LOOP		; oui => LOOP	COMP.W	D3,#KEYMDR	JUMP,EQ	LOOP	LOAD.W	D2,D3	LIB	?MINMAJ		; D2 <-- MAJ	EX.L	D2,D3		; D3 <-- min/MAJ	COMP.W	D3,#F0	JUMP,EQ DOEND	COMP.W	D3,#F0+SHIFT	JUMP,EQ DOEND	COMP.W	D3,#END	JUMP,EQ DOEND	COMP.W	D3,#(2^BPROGRA)*H'100+END	JUMP,EQ	RETOURcomp.w	d3,#(2^BPROGRA)*H'100+'Tjump,eq	dotest	COMP.W	D3,#(2^BSHOW)*H'100+DEFINE	JUMP,EQ	DOPREND	COMP.W	D3,#F1	JUMP,EQ	DOPREND	COMP.W	D3,#F1+SHIFT	JUMP,EQ	DOPREND	COMP.W	D3,#F2	JUMP,EQ	DOAJOUTE	COMP.W	D3,#F2+SHIFT	JUMP,EQ	DOBIBLIO	COMP.W	D3,#(2^BCOPY)*H'100+DEFINE	JUMP,EQ	DOSAUVE	COMP.W	D3,#F3	JUMP,EQ	DOSAUVE	COMP.W	D3,#F3+SHIFT	JUMP,EQ	DOSAUVE	COMP.W	D3,#F4	JUMP,EQ	DODEFINE	COMP.W	D3,#F4+SHIFT	JUMP,EQ	DOCOULEUR	COMP.W	D3,#F5	JUMP,EQ	DOASKGC	COMP.W	D3,#F5+SHIFT	JUMP,EQ	DOADDGC	COMP.W	D3,#DEL	JUMP,EQ	DODEL	COMP.W	D3,#UNDO	JUMP,EQ	DOUNDO	COMP.W	D3,#HELP	JUMP,EQ	DOHELP	COMP.W	D3,#F6	JUMP,EQ	DOCENTRE	COMP.W	D3,#F6+SHIFT	JUMP,EQ	DOCENTRE	COMP.W	D3,#DEFINE	JUMP,EQ	DODEFINE	COMP.W	D3,#F7	JUMP,EQ DOMECHELLE	COMP.W	D3,#F7+SHIFT	JUMP,EQ DOMECHELLE	COMP.W	D3,#F8	JUMP,EQ DO1ECHELLE	COMP.W	D3,#F8+SHIFT	JUMP,EQ DO1ECHELLE	COMP.W	D3,#F9	JUMP,EQ DOPECHELLE	COMP.W	D3,#F9+SHIFT	JUMP,EQ DOPECHELLE	COMP.W	D3,#F10	JUMP,EQ DOREGLE	COMP.W	D3,#F10+SHIFT	JUMP,EQ DOREGLE	COMP.W	D3,#F11	JUMP,EQ DOGRILLE	COMP.W	D3,#F11+SHIFT	JUMP,EQ DOGRILLE	COMP.W	D3,#F12;;;	JUMP,EQ DOREFAIT	JUMP,EQ	DOPASACTIF	COMP.W	D3,#F12+SHIFT;;;	JUMP,EQ DOREFAIT	JUMP,EQ	DOPASACTIF	COMP.W	D3,#F13	JUMP,EQ DOTOUT	COMP.W	D3,#F13+SHIFT	JUMP,EQ DOTOUT	COMP.W	D3,#F14;;;	JUMP,EQ DOEFFACE	JUMP,EQ	DOREFAIT	COMP.W	D3,#F14+SHIFT	JUMP,EQ DOEFFACE	COMP.W	D3,#F15	JUMP,EQ DOIMPLAN	COMP.W	D3,#F15+SHIFT	JUMP,EQ DOPLOT	COMP.W	D2,#(2^BPROGRA)*H'100+'I	JUMP,EQ	DOIMA	COMP.W	D2,#(2^BPROGRA)*H'100+'H	JUMP,EQ	DOPLOTHP;;;;;	COMP.W	D2,#(2^BPROGRA)*H'100+'S	; supprim pour 5.25;;;;;	JUMP,EQ	DOPLOTSH	CLR.L	D0	LOAD.W	D0,(A6)+OPLANAV+OLWDOX	SR.W	D0,#1		; D0 <-- +1/2 largeur fentre	COMP.W	D2,#(2^BSHOW)*H'100+'F	JUMP,EQ	DOSHOW	NEG.W	D0		; D0 <-- -1/2 largeur fentre	COMP.W	D2,#(2^BSHOW)*H'100+'D	JUMP,EQ	DOSHOW	LOAD.W	D0,(A6)+OPLANAV+OLWDOY	SR.W	D0,#1		; D0 <-- +1/2 hauteur fentre	SWAP.W	D0	CLR.W	D0	COMP.W	D2,#(2^BSHOW)*H'100+'R	JUMP,EQ	DOSHOW	SWAP.W	D0	NEG.W	D0		; D0 <-- -1/2 hauteur fentre	SWAP.W	D0	COMP.W	D2,#(2^BSHOW)*H'100+'C	JUMP,EQ	DOSHOW	CLR.L	D0	LOAD.W	D0,(A6)+OPLANAV+OMWDOX	; D0 <-- + largeur plan	COMP.W	D2,#(2^BSHOW)*H'100+'G	JUMP,EQ	DOSHOW	NEG.W	D0			; D0 <-- - largeur plan	COMP.W	D2,#(2^BSHOW)*H'100+'S	JUMP,EQ	DOSHOW	LOAD.W	D0,(A6)+OPLANAV+OMWDOY	; D0 <-- + hauteur plan	SWAP.W	D0	CLR.W	D0	COMP.W	D2,#(2^BSHOW)*H'100+'T	JUMP,EQ	DOSHOW	COMP.W	D2,#(2^BSHOW)*H'100+'E	JUMP,EQ	DOSHOW	SWAP.W	D0	NEG.W	D0		; D0 <-- - hauteur plan	SWAP.W	D0	COMP.W	D2,#(2^BSHOW)*H'100+'V	JUMP,EQ	DOSHOW	COMP.W	D2,#(2^BSHOW)*H'100+'X	JUMP,EQ	DOSHOW;---------------------------- CURSOR DANS PLAN	LOAD.L	D5,#1			; initialise D5	COMP.W	D2,#(2^BCURSOR)*H'100+'F	JUMP,EQ	DOCURSOR	LOAD.W	D5,#-1	AND.L	D5,#H'FFFF	COMP.W	D2,#(2^BCURSOR)*H'100+'D	JUMP,EQ	DOCURSOR	LOAD.L	D5,#10	COMP.W	D2,#(2^BCURSOR)*H'100+'G	JUMP,EQ	DOCURSOR	LOAD.L	D5,#-10	AND.L	D5,#H'FFFF	COMP.W	D2,#(2^BCURSOR)*H'100+'S	JUMP,EQ	DOCURSOR	LOAD.L	D5,#1*H'10000+0	COMP.W	D2,#(2^BCURSOR)*H'100+'R	JUMP,EQ	DOCURSOR	LOAD.L	D5,#-1*H'10000	COMP.W	D2,#(2^BCURSOR)*H'100+'C	JUMP,EQ	DOCURSOR	LOAD.L	D5,#10*H'10000	COMP.W	D2,#(2^BCURSOR)*H'100+'E	JUMP,EQ	DOCURSOR	LOAD.L	D5,#-10*H'10000	COMP.W	D2,#(2^BCURSOR)*H'100+'X	JUMP,EQ	DOCURSOR	COMP.W	D2,#(2^BCOPY)*H'100+'D	JUMP,EQ	DOLAST			;---------- MACROS	LOAD.W	D0,D2	SR.W	D0,#8	COMP.B	D0,#2^BSEARCH	; slction dans menu	JUMP,EQ	DOSEARCH	COMP.B	D0,#2^BCHANGE	; slction caractre	JUMP,EQ	DOCHANGE	COMP.B	D0,#2^BPROGRA	; mmorise macro-objet	JUMP,EQ	DOMPROGRA	COMP.B	D0,#2^BSHOW	; rappelle macro-objet	JUMP,EQ	DOMSHOW	COMP.W	D3,#H'80	JUMP,LO	DOTEXTE	LOAD.W	D0,D2	SR.W	D0,#8		; D0 <-- touche fonction	COMP.B	D0,#2^BPROGRA	; (PROGRA-xyz) ?	JUMP,NE	DOBIP		; non => DOBIP	TSET.L	D3:#7		; D3 <-- signal code spcial	JUMP	DOTEXTEDOBIP:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; signal touche incorrecte !;;;; GENCAR	CLR.W	D7	JUMP	LOOPDOERROR:	CALL	_IOERROR	; affiche erreur ...MAJBAS:	CALL	_INIBAS		; refait le bas	JUMP	LOOPBIPBAS:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; signal touche incorrecte !	JUMP	MAJBAS		; et met  jour le bas;-----------DOLAST:	LOAD.L	D4,(A6)+OMLAST	JUMP	DO_CCDOCURSOR:					; dplacement avec CURSOR ...;33$:						; D5 <-- offset +/-	TEST.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS	JUMP,BC	34$	CALL	_PASREEL	LOAD.L	D2,D5	SWAP.W	D2	MUL.WA	D5,D1	MUL.WA	D2,D1	SWAP.W	D5	LOAD.W	D5,D2	SWAP.W	D534$:	LOAD.L	D4,(A6)+OLDPOS	ADD.W	D4,D5;	JUMP,NS	32$				; X trop petit	JUMP,NS	DOBIP	COMP.W	D4,(A6)+OPLANAV+OMWDOX;	JUMP,HS	32$				; X trop grand	JUMP,HS	DOBIP	SWAP.W	D4	SWAP.W	D5	ADD.W	D4,D5;	JUMP,NS	32$				; Y trop petit	JUMP,NS	DOBIP	COMP.W	D4,(A6)+OPLANAV+OMWDOY;	JUMP,HS	32$				; Y trop grand	JUMP,HS	DOBIP	SWAP.W	D4	SWAP.W	D5DO_CC:;35$:	LOAD.L	D3,D4;;;	CALL	_IPOINT			; ds. la fentre	.W	PLANA_IPOINT	;JUMP,NE	10$;	JUMP,NE	32$	JUMP,NE	DOBIP;;;	CALL	_D4CLIP;;;	CALL	_D4SCALE;;;	CALL	_YINVERSE	.W	PLANA_D4CLIP	.W	PLANA_D4SCALE	.W	PLANA_YINVERSE	ADD.W	D4,(A6)+OPLANAV+OMINX	SWAP.W	D4	ADD.W	D4,(A6)+OPLANAV+OMINY	SWAP.W	D4	CALL	_PMOUSE	LOAD.L	D5,D4			; D5 <-- coord. cran	LOAD.L	D4,D3			; D4 <-- coord. PLAN	CALL	AFFXY	CALL	_POSREGLE;;;	LOAD.B	D3,(A6)+OLDBOU		; D3 <-- boutons idem avant;;;	COMP.L	D4,(A6)+OLDPOS;;;	JUMP,EQ	90$;;;	JUMP	80$80$:	LOAD.L	(A6)+OPOCU,D5		; pos. cran	LOAD.L	(A6)+OLDPOS,D4		; pos. PLAN;;;;	LOAD.B	(A6)+OLDBOU,D3		; boutons90$:	JUMP	LOOP;------ DOCURSORDODEL:				; (<-) =>;;;	CALL	_IAJOUTE	; supprime dernire crationLOAD.W	(A6)+OPLANAV+OPLANA,#BIAJOUTE.W	PLANA_BASE	JUMP,NE	DOERROR	LOAD.B	D5,#OBJFUGROUPE	COMP.B	D0,#OBJDUGROUPE	JUMP',EQ 20$	LOAD.B	D5,#OBJFSGROUPE	COMP.B	D0,#OBJDSGROUPE	JUMP',EQ 20$	LOAD.B	D5,#OBJDUGROUPE	COMP.B	D0,#OBJFUGROUPE	JUMP',EQ 20$	LOAD.B	D5,#OBJDSGROUPE	COMP.B	D0,#OBJFSGROUPE	JUMP',NE 50$20$:;;;	CALL	_IAJOUTE	; supprime tout le groupe	LOAD.W	(A6)+OPLANAV+OPLANA,#BIAJOUTE	.W	PLANA_BASE	JUMP,NE	DOERROR	COMP.B	D0,D5	JUMP,NE 20$50$:	CALL	_INIFREE	; mj nb d'objets restants	COMP.B	D0,#OBJTEXT	; caractre enlev ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	(A6)+OPOSALP,D4	; recule  la place de l'objet enlev	CLR.W	(A6)+ONALPHA	; indique OPOSALP valide90$:	JUMP	LOOPDOUNDO:				; (UNDO) =>	;;;	CALL	_IENLEVE	; annule dernire destruction	LOAD.W	(A6)+OPLANAV+OPLANA,#BIENLEVE	.W	PLANA_BASE	JUMP,NE	DOERROR	LOAD.B	D5,#OBJFUGROUPE	COMP.B	D0,#OBJDUGROUPE	JUMP',EQ 20$	LOAD.B	D5,#OBJFSGROUPE	COMP.B	D0,#OBJDSGROUPE	JUMP',EQ 20$	LOAD.B	D5,#OBJDUGROUPE	COMP.B	D0,#OBJFUGROUPE	JUMP',EQ 20$	LOAD.B	D5,#OBJDSGROUPE	COMP.B	D0,#OBJFSGROUPE	JUMP',NE 50$20$:	;;;	CALL	_IENLEVE	; annule tout le groupe	LOAD.W	(A6)+OPLANAV+OPLANA,#BIENLEVE	.W	PLANA_BASE	JUMP,NE	DOERROR	COMP.B	D0,D5	JUMP,NE 20$50$:	CALL	_INIFREE	; mj nb d'objets restants	JUMP	LOOPDOEFFACE:	CALL	DBOXEFFACE	; que faut-il effacer ?	COMP.W	D3,#F1		; TOUT ?	JUMP',EQ 50$	COMP.W	D3,#F4		; DESSIN ?	JUMP,NE	LOOP	CALL	RELLAST				; efface juste le dessin =>	CALL	_FLUSH		; tire la chasse d'eau !	CALL	_EFFACE		; efface l'cran	CALL	INILLAST	JUMP	LOOP50$:				; efface tout le dessin =>	CALL	RELLAST	CALL	INIDEF		; init objets par dfaut	CALL	KILLALLGC	; dtruit tous les gencars	CALL	_FLUSH		; tire la chasse d'eau !	CALL	_EFFACE		; efface l'cran;;	JUMP	LOOP	JUMP	PNTPLAN		; recharge PLAN.PLAN s'il existeDOPASACTIF:	CALL	INVPASACTIF	JUMP	LOOPINVPASACTIF:			; INVERSE flag PASACTIF	COMP.W	(A6)+OPAS,#0	JUMP,NE	20$	TCLR.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS	JUMP	30$20$:	TNOT.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS30$:	CALL	_AFMENU	RETDOIMA:	CALL	_IINPUT	JUMP,NE	DOERROR	JUMP	LOOP;--------\\; INIDEF  >;========/; Initialise les objets, les flches, les trames et les; paisseurs par dfaut.; in	-; out	-; mod	?INIDEF:;;; modif 5.07;;;	LOAD.W	(A6)+OOBJET,#OBJLIGNE	LOAD.W	(A6)+OOBJET,#OBJELASTIQUE;;;	LOAD.W	(A6)+OTRAIT,#TRAFIN	LOAD.W	(A6)+OMODE,#MODSET+COUNOIR*H'10	LOAD.W	(A6)+OTRAME,#TRMDEF	CLR.W	(A6)+OTEXTE	LOAD.W	(A6)+OPAS,#PASDEF	CLR.W	(A6)+OPLANAV+OSCALE	LOAD.W	(A6)+OARC,#ARCDEF	LOAD.W	(A6)+OPLANAV+OCOULEUR,#-1	CLR.W	(A6)+OFLECHE;;;	CLR.B	(A6)+OFLIO	AND.B	(a6)+OFLIO,#B'00000010	; garde trace de BNOEXCL	TSET.B	(A6)+OFLIO:#BOUTPLAN	TSET.B	(A6)+OFLIO:#BIMRIEN	LOAD.W	(A6)+OMMACRO,#-1;;;	CALL	DEFTRAME	; init les trames par dfaut;;;	CALL	DEFPEN		; init les pinceaux par dfaut;;;	CALL	DEFFLECHE	; init les flches par dfaut	LOAD.W	(A6)+OPLANAV+OPLANA,#FDEFPTF	.W	PLANA_FONC	RETDOIMPLAN:				; imprime directement dans #printer !!!!!!!!!!!!!!	load.l	a3,#R16"txprinter	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	LOAD.B	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	CLR.L	D3	LOAD.L	D4,(A6)+OPLANAV+OMWDOY	CALL	_IMAOUT	FOS	?CLOSE	CALL	_IOERROR	JUMP	loopDOIMPDESS:			; imprime le 'dessin' seulement	load.l	a3,#R16"txprinter	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	LOAD.B	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN;;;	CALL	PPLACE		; D3/D4 <- place occupe par dessin	LOAD.W	(A6)+OPLANAV+OPLANA,#FPLACE	.W	PLANA_FONC	JUMP,NE	90$	CALL	_IMAOUT90$:	FOS	?CLOSE	CALL	_IOERROR	JUMP	loopDOIMPECR:			; imprime la fentre PLAN	CALL	IOWAIT		; affiche "attendez ..."	CALL	RELLAST	CALL	IRETICULE	; enlve le rticule si ncessaire	CALL	CCMO		; enlve flche souris	LOAD.L	D3,(A6)+OPLANAV+OMINY	LOAD.L	D4,(A6)+OPLANAV+OLWDOY	LIB	?CREWDO		; cre sous-fentre sans cadre	LIB	?USEWDO		; utilise sous-fentre	LOAD.W	D0,D5		; D0 <-- no sous-fentre	CLR.W	D3		; D3 <-- dump fentre utilise	LIB	?PDUMP		; imprime la fentre	PUSH.W	D7	CLR.W	D5	LIB	?USEWDO		; r-utilise fentre principale	LOAD.W	D5,D0		; D5 <-- no sous-fentre	LIB	?KILWDO		; dtruit sous-fentre	CALL	SCMO		; remet flche souris	CALL	IRETICULE	; remet le rticule si ncessaire	CALL	_INIBAS		; refait le bas de l'cran	POP.W	D7	JUMP,NE	DOERROR	JUMP	LOOPDOPLOT:	CALL	PLOTOUT		; trace le plan en cours sur plotter	JUMP,NE	DOERROR	JUMP	LOOPDOREFAIT:	CALL	RELLAST	CALL	_EFFACE		; efface tout	CALL	_REFAIT		; puis refait tout proprement	CALL	INILLAST	JUMP	LOOPDOTOUT:	CALL	RELLAST	CLR.L	D3	LOAD.L	D4,(A6)+OPLANAV+OMWDOY	CALL	_MSCALE		; montre tout	JUMP	LOOPDOGRILLE:	CALL	RELLAST	CALL	_IGRILLE	; met/enlve la grille	CALL	INILLAST	JUMP	LOOPDOREGLE:			; met/enlve les rgles	CALL	RELLAST	CALL	_INVREGLE	CALL	_EFFACE		; efface tout	CALL	RELLAST	CALL	_REFAIT		; puis refait tout proprement	CALL	INILLAST	JUMP	LOOPDOMECHELLE:	LOAD.W	D4,(A6)+OPLANAV+OSCALE10$:	DEC.W	D4	COMP.W	D4,#-1	JUMP,EQ	10$	COMP.W	D4,#+1	JUMP,EQ	10$	CALL	_CENSCALE	; centre selon nouvelle chelle	JUMP	DOMREFAITDO1ECHELLE:	LOAD.W	D4,(A6)+OPLANAV+OSCALE	CLR.W	D4	CALL	RELLAST	CALL	_CENSCALE	; centre selon nouvelle chelle	JUMP	DOMREFAITDOPECHELLE:	LOAD.W	D4,(A6)+OPLANAV+OSCALE10$:	INC.W	D4	COMP.W	D4,#+1	JUMP,EQ	10$	COMP.W	D4,#-1	JUMP,EQ	10$	CALL	_CENSCALE	; centre selon nouvelle chelle	JUMP	DOMREFAITDOTEXTE:	TEST.B	(A6)+OFLMOD:#BMINGC	JUMP,BS	DOGENCAR	CALL	GETPGC		; A0 <-- ^gencar;;;; GENCAR	COMP.B	(A0)+0,#0	JUMP,EQ	DOBIP	LOAD.L	D0,(A0)+OGCCOD	; D0 <-- "-fst"	SL.L	D0,#8		; D0 <-- "fst-"	comp.b	d3,#'		; touche (^) = '^	jump,ne	10$	load.b	d3,#'^10$:	LOAD.B	D0,D3		; D0 <-- "fstc" (c=code)	LOAD.L	D4,(A6)+OPOSALP	; D4 <-- dernire pos. alpha	COMP.W	(A6)+ONALPHA,#4	; souris beaucoup bouge ?	JUMP',LO 30$		; non => 30$				; oui =>	CALL	IFMOUSE		; D4 <-- coordonne souris	JUMP,NE	DOBIP		; souris hors fentre => bip	CALL	CONVCMO		; D4 <-- coor. dans le plan	JUMP,NE	DOBIP	LOAD.L	(A6)+OORIALP,D4	; mm. origine alphabtique	LOAD.L	(A6)+OPOSALP,D430$:	CLR.W	(A6)+ONALPHA	; signal frappe alpha en cours	LOAD.L	D3,D0		; D3 <-- gencar + caractre	COMP.B	D3,#CR		; passe  la ligne ?	JUMP,EQ	50$		; oui => 50$	TCLR.L	D3:#7		; D3 <-- masque si code spcial;	LOAD.W	D0,(A6)+OPLANAV+OOWDOX	; D0 <-- origine partie visible;	ADD.W	D0,(A6)+OPLANAV+OSWDOX	; D0 <-- coor.  l'extrme droite;	SUB.W	D0,(A0)+OGC2X		; D0 <-- laisse place pour caractre;	COMP.W	D4,D0			; caractre trop  droite ?;	JUMP,HS	DOBIP			; oui => DOBIPload.w	d0,(a6)+OPLANAV+OMWDOX	; D0 <-- coord. max. plansub.w	d0,(a0)+ogc2x		; D0 <-- moins largeur car.comp.w	d4,d0			; caractre dans plan ?jump,hs	dobip			; non => DOBIPload.w	d0,(a0)+ogc1x	; trop  gauche ?comp.w	d4,d0jump,ls	dobip	SWAP.W	D4;	LOAD.W	D0,(A6)+OPLANAV+OOWDOY	; D0 <-- origine partie visible;	ADD.W	D0,(A0)+OGC2Y		; D0 <-- laisse place pour caractre;	COMP.W	D4,D0			; caractre trop en bas ?;	JUMP,LS	DOBIP			; oui => DOBIPload.w	d0,(a6)+oplanav+omwdoy	; trop en haut ?sub.w	d0,(a0)+ogc1ycomp.w	d4,d0jump,hs	dobipload.w	d0,(a0)+ogc2ycomp.w	d4,d0jump,ls	dobip	SWAP.W	D4; modif. pour sauver largeur du car. ds. EXT (byte 0)	PUSH.L	D4;;;	CALL	_LGCGC		; D4 <-- largeur car.	LOAD.W	(A6)+OPLANAV+OPLANA,#FLGCGC	.W	PLANA_FONC	LOAD.W	D5,D4		; D5 <-- D4	POP.L	D4	LOAD.W	D0,D5		; D0 <-- D5 (largeur car.)	SL.L	D0,#8	LOAD.B	D0,#OBJTEXT; fin modif. pour sauver largeur du car.	comp.b	(a6)+ocaralp,#'^ ; pour touche (^) !	jump,ne	40$	comp.b	d3,#'a	jump,ne	32$	load.b	d3,#'	jump	39$32$:	comp.b	d3,#'e	jump,ne	33$	load.b	d3,#'	jump	39$33$:	comp.b	d3,#'i	jump,ne	34$	load.b	d3,#'	jump	39$34$:	comp.b	d3,#'o	jump,ne	35$	load.b	d3,#'	jump	39$35$:	comp.b	d3,#'u	jump,ne	40$	load.b	d3,#'	jump	39$39$:		; enlve le dernier et met nouveau  la place	push.b	d3	load.w	(a6)+oplanav+oplana,#biajoute	.w	plana_base	jump,ne	doerror	pop.b	d3	load.l	(a6)+oposalp,d4	; mm. coord. '^40$:;;;	LOAD.W	D0,#OBJTEXT	; D0 <-- objet texte	CLR.W	D1		; D1 <-- mode de trait	LOAD.W	D2,(A6)+OMODE	; D2 <-- mode/couleur de dessin;;;	CALL	_AJOUTE		; ajoute dans base de donne	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE	JUMP,NE	DOERROR		; si pleine => DOERROR;;;	CALL	_TEXTE		; affiche le caractre	.W	PLANA_DESSINE;;;	CALL	_LGCGC		; D4 <-- largeur du caractre	LOAD.W	(A6)+OPLANAV+OPLANA,#FLGCGC	.W	PLANA_FONC	ADD.W	(A6)+OPOSALP+OXX,D4	load.b	(a6)+ocaralp,d3	; mm. car.	CALL	_INIFREE	; mj nb d'objets restants	JUMP	LOOP50$:					; (RETURN) =>clr.b	(a6)+ocaralp		; efface car. mm.	LOAD.L	D4,(A6)+OORIALP		; D4 <-- origine ligne	SWAP.W	D4	SUB.W	D4,(A0)+OGCITL		; passe  la ligne suivante	JUMP,NS	DOBIP			; si trop bas => DOBIP	LOAD.W	D0,(A6)+OPLANAV+OOWDOY	; D0 <-- origine partie visible	ADD.W	D0,(A0)+OGC2Y		; D0 <-- laisse place pour caractre	COMP.W	D4,D0			; dans partie cache ?	JUMP,LS	DOBIP			; oui => DOBIP	SWAP.W	D4	LOAD.L	(A6)+OORIALP,D4	LOAD.L	(A6)+OPOSALP,D4	JUMP	LOOPDOGENCAR:	LOAD.B	D0,D3		; D0 <-- caractre	LOAD.L	D4,(A6)+OPOSALP	; D4 <-- dernire pos. alpha	COMP.W	(A6)+ONALPHA,#4	; souris beaucoup bouge ?	JUMP',LO 30$		; non => 30$				; oui =>	CALL	IFMOUSE		; D4 <-- coordonne souris	JUMP,NE	DOBIP		; souris hors fentre => bip	CALL	CONVCMO		; D4 <-- coor. dans le plan	JUMP,NE	DOBIP	LOAD.L	(A6)+OORIALP,D4	; mm. origine alphabtique	LOAD.L	(A6)+OPOSALP,D430$:	CLR.W	(A6)+ONALPHA	; signal frappe alpha en cours;;@	LOAD.W	D1,(A6)+OPLANAV+OOWDOX	; D1 <-- origine partie visible;;@	ADD.W	D1,(A6)+OPLANAV+OSWDOX	; D1 <-- coor.  l'extrme droite;;@	SUB.W	D1,(A6)+OPLANAV+OLGMAX		; D1 <-- laisse place pour matrice;;@	COMP.W	D4,D1			; caractre trop  droite ?;;@	JUMP,HS	DOBIP			; oui => DOBIP;;@	SWAP.W	D4;;@	COMP.W	D4,(A6)+OPLANAV+OOWDOY	; caractre trop en bas ?;;@	JUMP,LS	DOBIP			; oui => DOBIP;;@	SWAP.W	D4	LOAD.L	D6,D4		; D6 <-- offset	LOAD.B	D4,D0		; D4 <-- caractre frapp	COMP.B	D4,#CR		; passe  la ligne ?	JUMP',EQ 70$		; oui => 70$	TCLR.L	D4:#7	PUSH.L	D6	LOAD.W	D6,(A6)+OTEXTE;;;	CALL	OPMATRIX	; ouvre la matrice	LOAD.W	(A6)+OPLANAV+OPLANA,#BOPMATRIX	.W	PLANA_BASE	CALL	USEDGC	POP.L	D6	TEST.W	D7	JUMP,NE DOERROR	LOAD.B	(A6)+OPLANAV+ORCOIN,#-1	; tous les coins trouvs	LOAD.W	D2,(A6)+OMODE;;;	CALL	ADMATRIX	; converti toute la matrice	LOAD.W	(A6)+OPLANAV+OPLANA,#BADMATRIX	.W	PLANA_BASE	JUMP,NE	DOERROR	LOAD.W	D3,(A6)+OPOSALP+OXX	ADD.W	D3,(A6)+OPLANAV+OLGMAX	; ajoute largeur matrice	LOAD.W	(A6)+OPOSALP+OXX,D3 ; mm. position suivante	CALL	_INIFREE	; mj nb d'objets restants	JUMP	LOOP70$:					; (RETURN) =>	LOAD.L	D4,(A6)+OORIALP		; D4 <-- origine ligne	SWAP.W	D4	SUB.W	D4,(A6)+OPLANAV+OLGMAY		; passe  la ligne suivante	JUMP,NS	DOBIP			; si trop bas => DOBIP	COMP.W	D4,(A6)+OPLANAV+OOWDOY	; dans partie cache ?	JUMP,LS	DOBIP			; oui => DOBIP	SWAP.W	D4	LOAD.L	(A6)+OORIALP,D4	LOAD.L	(A6)+OPOSALP,D4	JUMP	LOOP;-----------;; touche F6 ;;-----------;DOCENTRE:	CALL	IFMOUSE		; D4 <-- coordonne souris	JUMP,NE	DOBIP		; souris hors fentre => bip;;;	CALL	_YINVERSE	; D4 <-- inverse le sens de Y	.W	PLANA_YINVERSE	LOAD.W	D0,(A6)+OPLANAV+OLWDOX	SR.W	D0,#1		; D0 <-- milieu fentre	SUB.W	D0,D4		; D0 <-- correction +/- (x)	NEG.W	D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D0,(A6)+OPLANAV+OLWDOY	SR.W	D0,#1		; D0 <-- milieu fentre	SUB.W	D0,D4		; D0 <-- correction +/- (y)	NEG.W	D0	SWAP.W	D0DOSHOW:	CALL	MOVWDV		; dplace fentre virtuelle	JUMP,NE	DOERROR		; impossible => DOERRORDOMREFAIT:	CALL	_MAJCADRE	; met  jour le cadre	CALL	_REFAIT		; puis refait tout proprement	JUMP	LOOP;-------------;; touche HELP ;;-------------;DOHELP:	CALL	RELLAST	CALL	IOHELP		; affiche le help ...	CALL	INILLAST	JUMP	LOOP;------------;; touche F0  ;; touche END ;;------------;DOEND:	TEST.B	(A6)+OFLPLOT:#BPLOTON	JUMP,BC	30$	CALL	DBOX_PLOT	; PLOT en cours ...	JUMP,NE	DOERROR	COMP.W	D3,#'O		; oui, arrte	JUMP,EQ	10$	JUMP	LOOP		; non, ==> LOOP;	COMP.W	D3,#'N		; non, ==> LOOP;	JUMP,NE	DOERROR10$:				;  ARRETER	TEST.B	(A6)+OFLPLOT:#BPLOTON	; fini entretemps ?	JUMP,BC	LOOP			; oui, ...	PUSH.L	A5			; non, ...	LOAD.L	A5,(A5)+OPLOTD5		; A5 ^variables PLOT	TSET.B	(A5)+OTFLMOD+3:#BABORT	; signale fin  PLOTFILS	POP.L	A5	JUMP	LOOP			; ... et LOOP30$:	CLR.W	D0		; D0 <-- avant de quitter	CALL	DBOXSAVE	; sauve le plan actuel ...	JUMP,NE	LOOP	CALL	DBOXQUITTE	; demande s'il faut quitter ...	COMP.W	D3,#F1	JUMP,NE	LOOP		; non, on reste ...	JUMP	RETOUR;-----------;; touche F1 ;;-----------;DOPREND:	CALL	APREND		; prend un fichier.PLAN	JUMP	LOOP;-----------;; touche F2 ;;-----------;DOAJOUTE:	CALL	AAJOUTE		; ajoute un fichier.PLAN	JUMP	LOOP;--------------------;; touche (SHIFT()F2) ;;____________________;DOBIBLIO:	CALL	BIBLIO		; bibliothque	JUMP	LOOP;-----------;; touche F3 ;;-----------;DOSAUVE:	CLR.L	D4	LOAD.B	D4,(A6)+OFLIO	; D4 <-- fanions	tset.L	D4:#BOUTPLAN	; toujours un .PLAN	CLR.L	D2		; D2 <-- mode manuel	CALL	AOUTPUT		; crit un super-objet	JUMP	LOOP;-----------;; touche F4 ;;-----------;DODEFINE:	CALL	_CHMENU		; change menu ...	JUMP	LOOP;--------------------;; touche (SHIFT()F4) ;;--------------------;DOCOULEUR:	CALL	_DBOXCOULEUR	; change les couleurs visibles ...	JUMP	LOOP;-----------;; touche F5 ;;-----------;DOASKGC:	CALL	ASKGC	JUMP	LOOP;	CALL	SRMO;	LOAD.W	D6,(A6)+OTEXTE;;;	CALL	ASKGC		; demande un gencar;	LOAD.W	(A6)+OPLANAV+OPLANA,#FDBGENC;	.W	PLANA_FONC;	LOAD.W	(A6)+OTEXTE,D6;	CALL	_INIBAS;	CALL	CRMO;	JUMP,NE	DOERROR	; si erreur => DOERROR;	JUMP	LOOP;--------------------;; touche (SHIFT()F5) ;;--------------------;DOADDGC:	CALL	GCINPUT		; ajoute un gencar spcial	JUMP	LOOPDOPLOTHP:	CALL	IPLOTHP	JUMP	LOOP;;;;;DOPLOTSH:			; supprim pour 5.25;;;;;	CALL	IPLOTSH;;;;;	JUMP	LOOP;;?ERMOUSE:;;?	LOAD.B	D3,#BIPFAT;;?	.W	LIB,?BEEP	; fait un bruit terrible !;;?;;?	.W	LIB,?AFTIM;;?	.B	EOP,NOCURS,CR,CR,CR,CR,AFINV,0;;?	.EVEN;;?;;?	.W	LIB,?AFTIM;;?	.ASCIZ	/La souris n'est pas connecte/;;?	.EVEN;;?	JUMP	ERWAITFATER2:	PUSH.W	D7	LOAD.B	D3,#BIPFAT	LIB	?BEEP		; fait un bruit terrible !	LIB	?AFTIM	.B	EOP,NOCURS,CR,CR,CR,CR,AFINV,0	.EVEN	POP.W	D7	LIB	?AFERROR	LOAD.W	D4,#10*50	NTREL	?SETTIM		; init timeout de 10 secondes	LIB	?GETCAR		; attend une touche ...	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	JUMP	RETOUR1RETOUR:	CALL	BIBLIO?		; BIBLIO ouverte	JUMP,NE	05$		; NON	LOAD.L	A0,#(A6)+OPLANBV ; oui, sauve et ferme	PLANB_	FERME05$:	TEST.B	(A6)+OFLMOD:#BPLHP	; draging du plotter ?	JUMP,BC	20$			; non	CALL	IPLOTHP			; oui, ferme USART etc.20$:	CALL	_IMAFOND	; libre mmoire image de fondRETOUR1:	LOAD.L	D6,A6		; A6 ^variables ?	JUMP,EQ	50$		; non => 50$				; oui =>	PUSH.L	A5	LOAD.L	A5,(A6)+OPSEMA	NTREL	?KILLSEM	; dtruit smaphore d'exclusion	LOAD.L	A5,(A6)+OPSEMS	NTREL	?KILLSEM	; dtruit smaphore de synchro	POP.L	A5	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE		; ferme le module DBOX	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE		; ferme le module LIST	LOAD.W	D1,(A6)+OCHSPLINE	LIB_	CLOSE		; ferme le module SPLINE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE		; ferme le module SCROLL	LOAD.W	D1,(A6)+OCHDGENC	LIB_	CLOSE		; ferme le module DGENC	LOAD.W	D1,(A6)+OCHDESS	LIB_	CLOSE		; ferme le module DESSIN	LOAD.W	D1,(A6)+OCHSTRETCH	LIB_	CLOSE		; ferme le module STRETCH	LOAD.W	D1,(A6)+OCHPLANA	LIB_	CLOSE		; ferme le module PLANA	LOAD.W	D1,(A6)+OCHPLANB	LIB_	CLOSE		; ferme le module PLANB;;;;;;;?????????CALL	REL_INFO	LOAD.W	D1,(A6)+OCHMATH32	LIB_	CLOSE		; ferme le module MATH32;;;;;;;??????????;;;;;;	TEST.B	(A6)+OFLMOD:#BPLHP;;;;;;	JUMP,BS	10$		; supprim 5.25;;;;;;	TEST.B	(A6)+OFLMOD:#BPLSH;;;;;;	JUMP,BC	20$;;;;;;10$:	CALL	CLMOMI;;;;;;	JUMP,EQ	20$;;;;;;	LIB	?AFERROR;;;;;;20$:50$:	LIB	?AFTIM	.B	EOP		; efface toute la fentre	.B	AFSCMO		; remet la flche de la souris	.B	0	.EVEN;	CALL	_IMAFOND	; libre mmoire et modules image de fond				; cf. PLANIMAGE	LIB	?CLOLIB		; ferme la librairieFATER1:	FOS	?STOP		; stoppe le processus;--------\; MOVWDV  >;========/; Dplace la fentre virtuelle dans n'importe quel sens.; in	D0.L	+/- dplacement (y;x); out	D7.W	zro  =>  dplacement;		autre =>  pas boug (limite atteinte); mod	D7.WMOVWDV:	PUSHM.L	D0,D1,D2	LOAD.W	D7,#ERPLI	; D7 <-- limite atteinte	EX.L	D4,D0	PUSH.W	(A6)+OPLANAV+OSCALE	NEG.W	(A6)+OPLANAV+OSCALE;;;	CALL	D4SCALE		; D0 <-- +/- dpl. selon chelle	.W	PLANA_D4SCALE	POP.W	(A6)+OPLANAV+OSCALE	EX.L	D0,D4	LOAD.W	D1,(A6)+OPLANAV+OOWDOX	TEST.W	D0			; avance/recule ?	JUMP,EQ	50$			; reste l => 50$	JUMP',NS 20$			; recule => 20$					; avance =>	LOAD.W	D2,(A6)+OPLANAV+OMWDOX	ADD.W	D2,#MRGWDOX		; D2 <-- accepte p'tit dbordement	SUB.W	D2,(A6)+OPLANAV+OSWDOX	; D2 <-- max vers la gauche	JUMP,LO	50$	COMP.W	D1,D2			; max dj atteint ?	JUMP,HS	50$			; oui => 50$	ADD.W	D1,D0			; D1 <-- avance (x)	COMP.W	D1,D2			; dpassement ?	JUMP',LO 40$			; non => 40$	LOAD.W	D1,D2			; D1 <-- pos. extrme droite	JUMP'	40$20$:				; recule =>	TEST.W	D1		; min dj atteint ?	JUMP',EQ 50$		; oui => 50$	ADD.W	D1,D0		; D1 <-- recule (x)	JUMP',NC 40$		; ok => 40$	CLR.W	D1		; D1 <-- pos. extrme gauche40$:	LOAD.W	D0,D1	CALL	_XARRONDI		; arrondi selon le pas	LOAD.W	(A6)+OPLANAV+OOWDOX,D0	; mj position X	CLR.W	D7			; D7 <-- ok50$:	SWAP.W	D0	LOAD.W	D1,(A6)+OPLANAV+OOWDOY	TEST.W	D0			; monte/descend ?	JUMP,EQ	90$			; reste l => 90$	JUMP',NS 60$			; descend => 60$					; monte =>	LOAD.W	D2,(A6)+OPLANAV+OMWDOY	ADD.W	D2,#MRGWDOY		; D2 <-- accepte p'tit dbordement	SUB.W	D2,(A6)+OPLANAV+OSWDOY	; D2 <-- max vers le haut	JUMP,LO	90$	COMP.W	D1,D2			; max dj atteint ?	JUMP,HS	90$			; oui => 90$	ADD.W	D1,D0			; D1 <-- monte (x)	COMP.W	D1,D2			; dpassement ?	JUMP',LO 70$			; non => 70$	LOAD.W	D1,D2			; D1 <-- pos. extrme haut	JUMP'	70$60$:				; descend =>	TEST.W	D1		; min dj atteint ?	JUMP,EQ	90$		; oui => 90$	ADD.W	D1,D0		; D1 <-- descend (x)	JUMP',NC 70$		; ok => 70$	CLR.W	D1		; D1 <-- pos. extrme bas70$:	LOAD.W	D0,D1	CALL	_XARRONDI		; arrondi selon le pas	LOAD.W	(A6)+OPLANAV+OOWDOY,D0	; mj position Y	CLR.W	D7			; D7 <-- ok90$:	POPM.L	D0,D1,D2	TEST.W	D7		; retour EQ/NE	RET;--------- RSTATPRI:;---------; Lit le status de l'imprimante.; in	A6 ^variables; out	variables initialises; mod	D7 et variables;	PUSHM.L	D3,D4,D6,A3,A4				; valeurs par dfaut (LQ800)	LOAD.W	(A6)+OFACY,#4	LOAD.W	(A6)+OFACX,#4	LOAD.W	(A6)+OMMX,#706	LOAD.W	(A6)+OMMY,#706	LOAD.L	(A6)+OPRIY,(A6)+OPLANAV+OLWDOY	; OPRIY et OPRIX	LOAD.L	A3,#R16"TXPRINT			; printer install ?	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN				; ouvre l'imprimante	JUMP,NE 80$				; non ...	LOAD.W	D3,#TYPPRI	; D3 <-- type imprimante	LOAD.L	D4,#LGPRI1	; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OSTPRI	; A4 <-- ^buffer	FOS	?RSTATUS	JUMP,NE	70$		; ferme l'imprimante	LOAD.W	D4,(A4)+OPRGLX	SR.W	D4,#3	LOAD.W	(A6)+OFACX,D4	LOAD.W	D4,(A4)+OPRGLY	SR.W	D4,#3	LOAD.W	(A6)+OFACY,D4	LOAD.W	(A6)+OMMX,(A4)+OPRUMX+2	LOAD.W	(A6)+OMMY,(A4)+OPRUMY+2	LOAD.W	D4,(A4)+OPRHTP		; hauteur	SUB.W	D4,(A4)+OPRMGS		; - marge sup.	SUB.W	D4,(A4)+OPRMGI		; - marge inf.	MUL.WU	D4,#8			; *8	DIV.WU	D4,(A4)+OPRGLY		; /haut. 8pts gra	LOAD.W	(A6)+OPRIY,D4	LOAD.W	D4,(A4)+OPRLGP		; largeur;;	COMP.W	(A4)+OPRBOA,#1		; boa ver 1 ?	COMP.W	(A4)+LGPRI0,#1	JUMP,EQ	10$			; oui --> 10$	SUB.W	D4,(A4)+OPRMGG		; - marge gauche	SUB.W	D4,(A4)+OPRMGD		; - marge droite10$:	MUL.WU	D4,#8			; *8	DIV.WU	D4,(A4)+OPRGLX		; /larg. 8 pts. gra	LOAD.W	(A6)+OPRIX,D470$:	FOS	?CLOSE			; ferme l'imprimante80$:	LOAD.L	D4,#10000*64	DIV.WU	D4,(A6)+OMMX	AND.L	D4,#H'FFFF	DIV.WU	D4,(A6)+OFACX	LOAD.W	(A6)+OF64X,D4		; OF64X := pas * 64	LOAD.L	D4,#10000*64	DIV.WU	D4,(A6)+OMMY	AND.L	D4,#H'FFFF	DIV.WU	D4,(A6)+OFACY	LOAD.W	(A6)+OF64Y,D4		; OF64Y := pas * 6490$:	POPM.L	D3,D4,D6,A3,A4	RET; Noms des modules; ----------------NAMDBOX:	.ASCIZ	"DBOX"		; nom du module DBOXNAMLIST:	.ASCIZ	"LIST"		; nom du module LISTNAMSPLINE:	.ASCIZ	"SPLINE"	; nom du module SPLINENAMSCROLL:	.ASCIZ 	"SCROLL"	; nom du module SCROLLNAMDGENC:	.ASCIZ	"DGENC"		; nom du module DGENCNAMDESS:	.ASCIZ	"DESSIN"	; nom du module DESSINNAMSTRETCH:	.ASCIZ	"STRETCH"	; nom du module STRETCHNAMPLANA:	.ASCIZ	"PLANA"		; nom du module PLANANAMPLOT:	.ASCIZ	"PLOT"		; nom du module PLOTNAMPLANB:	.ASCIZ	"PLANB"		; nom du module PLANB;;;;????NAMMATH32:	.ASCIZ	"MATH32"	; nom module MATH32;;;;????NAMPLAN:	.ASCIZ	"#:PLAN.PLAN"	; nom rservTXPRINT:	.ASCIZ	"#PRINTER"	; nom de l'imprimante	.EVEN;;;;;;;;; MACRO	;;;;;;;;; touches SUPER-SHIFT pour accs direct aux menus et genc.; ds rvision 4.7DOMPROGRA:			; mmorise PROGRA-0..9	CALL	PMACRO	JUMP,NE	DOBIP	LOAD.B	(A4+),#-1		; 0	LOAD.B	(A4+),#-5		; 1	LOAD.B	(A4+),#H'80		; 2 signal macro	LOAD.B	(A4+),(A6)+OOBJET+1	; 3	LOAD.B	(A4+),(A6)+OPLANAV+OCOULEUR+1	; 4	LOAD.B	(A4+),(A6)+OMODE+1	; 5	LOAD.B	(A4+),(A6)+OTRAIT+1	; 6	LOAD.B	(A4+),(A6)+OARC+1	; 7	LOAD.B	(A4+),(A6)+ORRECT+1	; 8	LOAD.B	(A4+),(A6)+OTRAME+1	; 9	LOAD.B	(A4+),(A6)+OFLECHE+1	; 10	LOAD.B	(A4+),#0		; 11 rien !	LOAD.W	(A4+),(A6)+OSTKP1	; 12,13	LOAD.W	(A4+),(A6)+OSTKP2	; 14,15	LOAD.W	(A6)+OMMACRO,D2		; mmorise no. macro	JUMP	MAJBASDOMSHOW:			; rappelle SHOW-0..9	CALL	PMACRO	JUMP,NE	DOBIP	COMP.W	(A4)+2,#0		; signal macro ?	JUMP,EQ	DOBIP			; non --> vide ...	LOAD.B	(A6)+OOBJET+1,(A4+)	; 0 (-1) sauter les deux ...	LOAD.B	(A6)+OOBJET+1,(A4+)	; 1 (-5)	LOAD.B	(A6)+OOBJET+1,(A4+)	; 2 (H'80)	LOAD.B	(A6)+OOBJET+1,(A4+)	; 3	LOAD.B	(A6)+OPLANAV+OCOULEUR+1,(A4+)	; 4	LOAD.B	(A6)+OMODE+1,(A4+)	; 5	LOAD.B	(A6)+OTRAIT+1,(A4+)	; 6	LOAD.B	(A6)+OARC+1,(A4+)	; 7	LOAD.B	(A6)+ORRECT+1,(A4+)	; 8	LOAD.B	(A6)+OTRAME+1,(A4+)	; 9	LOAD.B	(A6)+OFLECHE+1,(A4+)	; 10	LOAD.B	(A6)+OSTKP1+1,(A4+)	; 11 rien !	LOAD.W	(A6)+OSTKP1,(A4+)	; 12,13	LOAD.W	(A6)+OSTKP2,(A4+)	; 14,15LOAD.W	(A6)+OMMACRO,D2		; mmorise no. macro	JUMP	MAJBASDOSEARCH:			; accs rapide aux objets	LOAD.B	D2,D399$:	LIB	?GETKEY	TEST.L	D3:#BKRELEAS	JUMP,BC	99$		; touche pas relache	COMP.B	D2,#'0	JUMP,EQ	00$	JUMP,LO	DOBIP	COMP.B	D2,#'1	JUMP,EQ	10$	COMP.B	D2,#'2	JUMP,EQ	20$		; FLECHE --> directement	COMP.B	D2,#'3	JUMP,EQ	30$	COMP.B	D2,#'4	JUMP,EQ	40$	COMP.B	D2,#'5	JUMP,EQ	50$	COMP.B	D2,#'6	JUMP,EQ	60$		; SURFACE --> directement	JUMP	DOBIP		; max. '6 !00$:		CALL	_AFCMES.ASCIZE	/ LIGNES  0: trait  main leve  1: courbe ouverte  2: courbe ferme /	LIB	?GETCAR		; 2me choix	COMP.B	D3,#'0	JUMP,NE	01$	LOAD.W	(A6)+OOBJET,#OBJLIGNE	JUMP	MAJBAS01$:	COMP.B	D3,#'1	JUMP,NE	02$	LOAD.W	(A6)+OOBJET,#OBJSPLO	JUMP	MAJBAS02$:	COMP.B	D3,#'2	JUMP,NE	BIPBAS	LOAD.W	(A6)+OOBJET,#OBJSPLC	JUMP	MAJBAS10$:	CALL	_AFCMES.ASCIZE	" DROITE  0: rigide  1: rigide h/v  2: lastique  3: lastique h/v "	LIB	?GETCAR		; 2me choix	COMP.B	D2,#'1			; DROITE	JUMP,NE	30$	COMP.B	D3,#'0	JUMP,NE	11$	LOAD.W	(A6)+OOBJET,#OBJDROITE	JUMP	MAJBAS11$:	COMP.B	D3,#'1	JUMP,NE	12$	LOAD.W	(A6)+OOBJET,#OBJDHV	JUMP	MAJBAS12$:	COMP.B	D3,#'2	JUMP,NE	13$	LOAD.W	(A6)+OOBJET,#OBJELASTIQUE	JUMP	MAJBAS13$:	COMP.B	D3,#'3	JUMP,NE	BIPBAS	LOAD.W	(A6)+OOBJET,#OBJEHV	JUMP	MAJBAS20$:					; FLECHE	CALL	_AFCMES.ASCIZE	/ FLECHES:  cliquez avec la souris svp. /;;;	CALL	DBOXFLECHELOAD.W	(A6)+OPLANAV+OPLANA,#FDBFLECHE.W	PLANA_FONC	JUMP	MAJBAS30$:	CALL	_AFCMES.ASCIZE	/ 0: CERCLE  1: demi  2: quart  3: 8ime  4: ELLIPSE  5: demi  6: quart /	LIB	?GETCAR		; 2me choix	COMP.B	D2,#'3			; CERCLE	JUMP,NE	40$	COMP.B	D3,#'0	JUMP,NE	31$	LOAD.W	(A6)+OOBJET,#OBJCERCLE	LOAD.W	(A6)+OARC,#0	JUMP	MAJBAS31$:	COMP.B	D3,#'1	JUMP,NE	32$	LOAD.W	(A6)+OOBJET,#OBJARC	LOAD.W	(A6)+OARC,#1	JUMP	MAJBAS32$:	COMP.B	D3,#'2	JUMP,NE	33$	LOAD.W	(A6)+OOBJET,#OBJARC	LOAD.W	(A6)+OARC,#2	JUMP	MAJBAS33$:	COMP.B	D3,#'3	JUMP,NE	34$	LOAD.W	(A6)+OOBJET,#OBJARC	LOAD.W	(A6)+OARC,#3	JUMP	MAJBAS34$:	COMP.B	D3,#'4	JUMP,NE	35$	LOAD.W	(A6)+OOBJET,#OBJELLIPSE	LOAD.W	(A6)+OARC,#0	JUMP	MAJBAS35$:	COMP.B	D3,#'5	JUMP,NE	36$	LOAD.W	(A6)+OOBJET,#OBJARCELL	LOAD.W	(A6)+OARC,#1	JUMP	MAJBAS36$:	COMP.B	D3,#'6	JUMP,NE	BIPBAS	LOAD.W	(A6)+OOBJET,#OBJARCELL	LOAD.W	(A6)+OARC,#2	JUMP	MAJBAS40$:	CALL	_AFCMES.ASCIZE	/ 0: RECTANGLE  1: r=4  2: r=8  3: r=12  4: r=16 /	LIB	?GETCAR		; 2me choix	COMP.B	D2,#'4	JUMP,NE	50$	COMP.B	D3,#'0	JUMP,NE	41$	LOAD.W	(A6)+OOBJET,#OBJRECT	CLR.W	(A6)+ORRECT	JUMP	MAJBAS41$:	COMP.B	D3,#'1	JUMP,NE	42$	LOAD.W	(A6)+OOBJET,#OBJRECT	LOAD.W	(A6)+ORRECT,#4	JUMP	MAJBAS42$:	COMP.B	D3,#'2	JUMP,NE	43$	LOAD.W	(A6)+OOBJET,#OBJRECT	LOAD.W	(A6)+ORRECT,#8	JUMP	MAJBAS43$:	COMP.B	D3,#'3	JUMP,NE	44$	LOAD.W	(A6)+OOBJET,#OBJRECT	LOAD.W	(A6)+ORRECT,#12	JUMP	MAJBAS44$:	COMP.B	D3,#'4	JUMP,NE	BIPBAS	LOAD.W	(A6)+OOBJET,#OBJRECT	LOAD.W	(A6)+ORRECT,#16	JUMP	MAJBAS50$:	CALL	_AFCMES.ASCIZE	" POLYGONE  0: ouvert  1: ferm  2: horiz./vert. "	LIB	?GETCAR		; 2me choix	COMP.B	D2,#'5	JUMP,NE	BIPBAS	COMP.B	D3,#'0	JUMP,NE	51$	LOAD.W	(A6)+OOBJET,#OBJPOLO	JUMP	MAJBAS51$:	COMP.B	D3,#'1	JUMP,NE	52$	LOAD.W	(A6)+OOBJET,#OBJPOLC	JUMP	MAJBAS52$:	COMP.B	D3,#'2	JUMP,NE	BIPBAS	LOAD.W	(A6)+OOBJET,#OBJPOLHV	JUMP	MAJBAS60$:				; menu SURFACE	CALL	_AFCMES.ASCIZE	/ TRAMES:  cliquez avec la souris svp. /	LOAD.W	D4,(A6)+OOBJET	LOAD.W	(A6)+OOBJET,#OBJSURF;;;	CALL	DBOXTRAMELOAD.W	(A6)+OPLANAV+OPLANA,#FDBTRAME.W	PLANA_FONC	JUMP,NE	69$	JUMP	MAJBAS69$:	LOAD.W	(A6)+OOBJET,D4	JUMP	LOOPDOCHANGE:			; accs rapide aux genc	AND.W	D3,#H'00FF	SUB.W	D3,#'0	COMP.W	D3,#MAXGC	JUMP,HS	DOBIP	LOAD.L	A4,#(A6)+OPLANAV+OBUGC	LOAD.W	D4,D3	MUL.WU	D4,#LGGC	ADD.L	A4,D4	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP,BC	DOBIP	LOAD.W	(A6)+OTEXTE,D3	JUMP	MAJBAS; routines pour sauvetage et lecture des macro 'PREND' seulement; cf. aussi PLANIO;-------PMACRO:;-------; rend le pointeur A4 dans OBMACRO en fonction du no. ASCII dans D2; in	D2.B	no ASCII; out	A4^ dans OBMACRO; mod	D7.W	PUSHM.L	D0,D2,D4	LOAD.W	D7,#-1	COMP.B	D2,#'9+1		; '0..'9 ?	JUMP,HS	90$	COMP.B	D2,#'0	JUMP,LO	90$	LOAD.W	D0,D2			; oui ...	AND.W	D0,#H'00FF	SUB.W	D0,#'0	LOAD.L	A4,#(A6)+OBMACRO-LMACRO	LOAD.L	D4,A41$:	ADD.L	D4,#LMACRO	DECJ.W,NMO D0,1$	LOAD.L	A4,D4	CLR.W	D790$:	POPM.L	D0,D2,D4	TEST.W	D7	RET;--------\\; MOUTPUT >;--------/; Ecrit les MACROS mmorises ventuellement; in	-; out	D7.W	erreur; mod	D7.WMOUTPUT:	PUSH.L	D2	CLR.W	D2		; D2 <-- 1er numro de flche10$:	CALL	M1OUTPUT	; crit MACRO	JUMP',NE 90$	INC.W	D2		; D2 <-- numro suivant	COMP.W	D2,#MACROMAX	JUMP,LO	10$90$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; M1OUTPUT >;---------/; Ecrit une dfinition de MACRO.; in	D2.W	numro de la MACRO; out	D7.W	erreur; mod	D7.WM1OUTPUT:	PUSHM.L	D2,A4	ADD.W	D2,#'0	AND.W	D2,#H'00FF	CALL	PMACRO		; A4^ la macro  sortir	JUMP,NE	90$	TEST.B	(A4)+2:#7	JUMP,BC	90$	TSET.L	D2:#7	LOAD.B	(A4)+2,D2	CALL	OUTPUT90$:	POPM.L	D2,A4	TEST.W	D7	RET;--------; MINPUT:;--------; lit les macros v. dans OBMACRO; in	A4.L	^ objet dj lu; out	A4.L	^ objet;		si macro, alors dans buffer macros; mod	D7.W	erreurMINPUT:	PUSHM.L	A3	PUSHM.L	A4	LOAD.L	A4,#(A6)+OBMACRO+(LMACRO*MACROMAX)	LOAD.W	D2,#LMACRO*MACROMAX00$:	CLR.B	(-A4)		; OBMACRO <-- plein de zro	DEC.W	D2	JUMP,NE	00$	POPM.L	A4	CLR.W	D4		; init pour nbr max  lire	JUMP	15$10$:	LOAD.L	A4,#(A6)+OBUIO	; A4^ lment lu	CALL	INPUT	JUMP,NE	90$15$:	COMP.B	(A4)+1,#OBJMDEF	; macro ?	JUMP,NE	90$		; non --> fin	LOAD.W	(A6)+OMMACRO,#'0 ; en tout cas 1 MACRO lue	LOAD.L	A3,A4		; oui, A3^ objet lu	LOAD.B	D2,(A3)+2;;	AND.W	D2,#H'00FF	TCLR.L	D2:#7	CALL	PMACRO		; A4^ emplacement ds. OBMACRO	CLR.W	D2		; init nbr bytes20$:	LOAD.B	(A4+),(A3+)	; inscrit ds. OBMACRO	INC.W	D2	COMP.W	D2,#LGELEMENT	JUMP,LO	20$	INC.W	D4			; lu MACROMAX ?	COMP.W	D4,#MACROMAX+1	JUMP,LO	10$			; non, continue ...90$:;;;	CALL	_PREND			; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	POPM.L	A3	TEST.W	D7	RETdotest:	call	wr_var_st	jump	loop; crit dans un fichier 1K du buffer STRETCHwr_var_st:	PUSHM.L	D0..D6,A3,A4	LOAD.l	A3,#R16"TXSTVAR	FOS	?DELETE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	LOAD.B	D3,#2^BOPWR	FOS	?OPEN	LOAD.L	A4,#(A6)+OBUIMF	LOAD.L	D4,#256*5	FOS	?WRBYTE	FOS	?CLOSE	POPM.L	D0..D6,A3,A4	RETTXSTVAR:	.ASCIZE	"#MM0:ST_VAR.TST"	.END