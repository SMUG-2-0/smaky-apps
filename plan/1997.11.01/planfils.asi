		.SBTTL	PLANFILS	; 18 aot 87 Sp.; processus FILS  purer  l'occasion !!!ROLLWDO	=	0	; roll de la fentre (problmes ... ???); Gestion de la souris; --------------------FILSCURSOR:	LOAD.L	D4,(A6)+OLDPOS	LOAD.L	D5,(A6)+OPOCU	JUMP,EQ	MOUPLAN;;;	JUMP	MOUPLANFILS:	CALL	IFMOUSE		; D3 <-- boutons, D4 <-- position	JUMP,NE	LOOP	LOAD.L	D5,D4		; D5 <-- position souris	CALL	CONVCMO		; D4 <-- coordonne dans le plan;	JUMP,EQ	70$		; dans le plan => 70$	JUMP,EQ	MOUPLAN				; hors du plan =>	CALL	RELRG		; efface les flches ds. rgles	TEST.B	D3		; bouton(s) press(s) ?	JUMP,EQ	LOOP		; non => LOOP				; oui =>	CALL	RELLAST		; enlve rf. dynamique				; LIGNE DU BAS ?	LOAD.W	D0,(A6)+OPLANAV+OWDOY	SUB.W	D0,(A6)+OPLANAV+OCARY	SWAP.W	D0	LOAD.W	D0,(A6)+OPLANAV+OWDOX	COMP.L	D5,D0	JUMP,LO	15$		; non --> 15$	CLR.L	D1		; init D1	JUMP	BAS		; oui, => BAS15$:				; LIGNE DU HAUT ?	LOAD.W	D0,(A6)+OPLANAV+OCARY	; OMINY	SWAP.W	D0	LOAD.W	D0,(A6)+OPLANAV+OWDOX	COMP.L	D5,D0	JUMP,HS	16$		; non --> 16$	CLR.L	D2		; init D2	JUMP	HAUT16$:				; ASCENSEURS ?	TEST.B	(A6)+OFLMOD:#BSCROLL	JUMP,BC LOOP		; non => LOOP	LOAD.L	D4,D5		; D4 <-- position souris	PUSH.L	A5		; ATTENTION !!!	LOAD.L	A5,#(A6)+OASCH	; A5 ^variables asc. horiz.		LOAD.W	D0,(A6)+OPLANAV+OSWDOX	SR.W	D0,#1		; D0 <-- 1/2 largeur fentre	LOAD.W	(A5)+OSCINC,D0	; ascenseur horizontal	LOAD.W	D0,(A6)+OPLANAV+OSWDOY	SR.W	D0,#1		; D0 <-- 1/2 hauteur fentre	LOAD.W	(A5)+OSCINC+LSCVAR,D0	; ascenseur vertical	SCROLL_	MOVE.IF	ROLLWDO	JUMP,EQ	50$.ELSE	JUMP,EQ	25$		; on tait dans l'asc. horiz..ENDIF	LOAD.L	D4,D5	PUSH.L	A5	ADD.L	A5,#LSCVAR	; A5 ^variables asc. vert.	SCROLL_	MOVE	POP.L	A5	INC.W	(A5)+OSCPOSV+LSCVAR ; inverse de Y !	TEST.W	D7.IF	ROLLWDO	JUMP,EQ	60$.ELSE	JUMP,EQ	20$		; on tait dans l'asc. vert.ENDIF	LOAD.L	D4,D5	CALL	DMOVE		; ventuellement les deux ?	JUMP,NE	40$20$:				; ascenseur vert.	LOAD.W	D0,(A5)+OSCHTV+LSCVAR	SUB.W	D0,(A5)+OSCPOSV+LSCVAR;;;	DEC.W	D0		; Y dans l'autre sens !!	CALL	XARRONDI	COMP.W	D0,(A6)+OPLANAV+OOWDOY	; a-t-on boug verticalement ?	JUMP,EQ	25$		; non => 25$	LOAD.W	(A6)+OPLANAV+OOWDOY,D0	; oui ...	LOAD.W	D0,(A5)+OSCPOSV	; ... et horiz. ?	CALL	XARRONDI	COMP.W	D0,(A6)+OPLANAV+OOWDOX	; a-t-on boug horizontalement ?	JUMP,EQ	30$		; non => 30$, seulement vert.	LOAD.W	(A6)+OPLANAV+OOWDOX,D0	; oui	JUMP	30$25$:				; pas vert., seulement horiz. ?	LOAD.W	D0,(A5)+OSCPOSV	CALL	XARRONDI	COMP.W	D0,(A6)+OPLANAV+OOWDOX	; a-t-on boug horizontalement ?	JUMP,EQ	40$		; non => 40$	LOAD.W	(A6)+OPLANAV+OOWDOX,D0	; oui;	JUMP	30$30$:	POP.L	A5		; ATTENTION !!!	CALL	MAJCADRE	; refait le cadre	CALL	REFAIT		; puis refait tout proprement	JUMP	LOOP40$:				; remet v. rf. dynamique	POP.L	A5		; ATTENTION !!!	CALL	INILLAST	JUMP	LOOP.IF	ROLLWDO50$:			; asc. horiz	LOAD.W	D0,(A6)+OASCH+OSCPOSV	CALL	XARRONDI	COMP.W	D0,(A6)+OPLANAV+OOWDOX	; a-t-on boug horizontalement ?	JUMP,EQ	40$		; non => 40$lib	?aftim.ascize	"<CR><CR><CR>BOUGE HORIZONTALEMENT"	LOAD.W	D1,(A6)+OPLANAV+OOWDOX	; D1 <-- anciennne origine fentre	LOAD.W	(A6)+OPLANAV+OOWDOX,D0	; OOWDOX <-- nlle origine	SUB.W	D0,D1		; nlle. - ancienne	JUMP,NS	52$lib	?aftim.ascize	" positif"	LOAD.W	D1,(A6)+OPLANAV+OSWDOX	SR.W	D1,#1	COMP.W	D0,D1	JUMP,HS	30$		; plus de la moiti !	LOAD.W	D4,D0;;;	CALL	_D4SCALE	PLANA_	D4SCALE;;;; problme avec OPWDOG dans PLANA !!!!!;??;	CALL	OPWDOG	LOAD.B	D3,#ROLLLEFT	; ROLLLEFT	LIB	?AFCAR	LOAD.W	D3,D4SR.W	D3,#8	LIB	?AFCARLOAD.W	D3,D4	LIB	?AFCAR;;;problme avec CLOWDOG dans PLANA !!!!!;??;	CALL	CLWDOGlib	?aftim.ascize	" ROLLLEFT"	PUSH.W	(A6)+OPLANAV+OMINX	PUSH.W	(A6)+OPLANAV+OLWDOX	PUSH.W	(A6)+OPLANAV+OSWDOX	PUSH.W	(A6)+OPLANAV+OOWDOX	LOAD.W	D1,(A6)+OPLANAV+OOWDOX	ADD.W	D1,(A6)+OPLANAV+OSWDOX	SUB.W	D1,D0	LOAD.W	(A6)+OPLANAV+OOWDOX,D1	LOAD.W	D1,(A6)+OPLANAV+OSWDOX	SUB.W	D1,D0	LOAD.W	(A6)+OPLANAV+OSWDOX,D1	LOAD.W	D1,(A6)+OPLANAV+OMAXX	SUB.W	D1,D4	LOAD.W	(A6)+OPLANAV+OMINX,D1	LOAD.W	(A6)+OPLANAV+OLWDOX,D4lib	?aftim.ascize	" REFAIT"	CALL	REFAIT	POP.W	(A6)+OPLANAV+OOWDOX	POP.W	(A6)+OPLANAV+OSWDOX	POP.W	(A6)+OPLANAV+OLWDOX	POP.W	(A6)+OPLANAV+OMINX	CALL	_INIHAUT	JUMP	40$52$:				; reculer, ancienne plus grande que nouvelle originelib	?aftim.ascize	" ngatif"	NEG.W	D0	LOAD.W	D1,(A6)+OPLANAV+OSWDOX	SR.W	D1,#1	COMP.W	D0,D1	JUMP,HS	30$		; plus de la moiti !	LOAD.W	D4,D0;;;	CALL	_D4SCALE	.W	PLANA_D4SCALE;;; problme avec OPWDOG dans PLANA !!!!;??;	CALL	OPWDOG;LOAD.B	D3,#ROLL;	LIB	?AFCAR	LOAD.B	D3,#ROLLRIGHT	; ROLLRIGHT	LIB	?AFCAR	LOAD.W	D3,D4SR.W	D3,#8	LIB	?AFCARLOAD.W	D3,D4	LIB	?AFCAR;;;problme avec CLWDOG dans PLANA !!!!;??;	CALL	CLWDOGlib	?aftim.ascize	" ROLLRIGHT"	PUSH.W	(A6)+OPLANAV+OMAXX	PUSH.W	(A6)+OPLANAV+OLWDOX	PUSH.W	(A6)+OPLANAV+OSWDOX	LOAD.W	D1,(A6)+OPLANAV+OSWDOX	SUB.W	D1,D0	LOAD.W	(A6)+OPLANAV+OSWDOX,D1	LOAD.W	D1,(A6)+OPLANAV+OMINX	ADD.W	D1,D4	LOAD.W	(A6)+OPLANAV+OMAXX,D1	LOAD.W	(A6)+OPLANAV+OLWDOX,D4	CALL	REFAIT	POP.W	(A6)+OPLANAV+OSWDOX	POP.W	(A6)+OPLANAV+OLWDOX	POP.W	(A6)+OPLANAV+OMAXX	CALL	_INIHAUT	JUMP	40$60$:			; asc. vert.	LOAD.W	D0,(A5)+OSCHTV+LSCVAR	SUB.W	D0,(A5)+OSCPOSV+LSCVAR;;;	DEC.W	D0		; Y dans l'autre sens !!	CALL	XARRONDI	COMP.W	D0,(A6)+OPLANAV+OOWDOY	; a-t-on boug verticalement ?	JUMP,EQ	40$		; non => 40$	LOAD.W	(A6)+OPLANAV+OOWDOY,D0; reste  faireJUMP	30$.ENDIF	; rollwdoMOUPLAN:	LOAD.L	(A6)+OLDPOS,D4	; sauve coord. ds. PLAN;70$:			; SOURIS DANS LE PLAN	INC.W	(A6)+ONALPHA	; signal souris bouge	CALL	AFFXY		; affiche X= et Y=	CALL	POSREGLE	; affiche les marqueurs dans les rgles	TEST.B	D3		; bouton(s) press(s) ?	JUMP,EQ	LOOP		; non => LOOP	TEST.L	D3:#BMOLEFT	JUMP,BS	DODESSINE	; GAUCHE => dessine	TEST.L	D3:#BMOCENT	JUMP,BS	DOMENU		; MILIEU => menu	TEST.L	D3:#BMORIGHT	JUMP,BS	DOMODIFIE	; DROITE => modifie	JUMP	LOOP;------ SOURIS dans la ligne du HAUTHAUT:	LOAD.W	D2,#1		; init D2	COMP.W	D5,#77		; 'PLAN X.Y'	JUMP,HS	1$	JUMP	20$1$:	INC.W	D2	COMP.W	D5,#190		; Or ...	JUMP,HS	2$	JUMP	20$2$:	INC.W	D2	COMP.W	D5,#304		; Co, Po, Di ...	JUMP,HS	3$	JUMP	20$3$:	INC.W	D2;	JUMP	20$20$:	LOAD.W	D0,D2	SWAP.W	D2	COMP.W	D0,D2		; le mme ?	JUMP,EQ	21$		; oui	CALL	HLIGHTEN	; non, teindre l'ancien	SWAP.W	D2		; allumer le nouveau	CALL	HLIGHTEN21$:	CALL	IFMOUSE		; D3 <-- boutons, D4 <-- position	JUMP,NE	85$		; hors de la fentre ...				; ...teindre et FILS	LOAD.L	D5,D4		; D5 <-- pos. souris				; ligne du haut ?	LOAD.W	D0,(A6)+OPLANAV+OCARY	SWAP.W	D0	LOAD.W	D0,(A6)+OPLANAV+OWDOX	COMP.L	D5,D0	JUMP,HS	22$		; non, teindre et LOOP				; oui et ...	TEST.B	D3		; ... bouton(s) relach(s)	JUMP,EQ	30$		; oui --> 30$	SWAP.W	D2		; non sauver l'ancien	JUMP	HAUT		; ... et recommencer22$:	CALL	HLIGHTEN	CLR.L	D2	TEST.B	D3	JUMP,NE	21$	JUMP	LOOP		; hors ligne du haut, teindre30$:				; oui ... saut selon	CALL	HLIGHTEN	; ... teindre et saut dans le menu	COMP.W	D2,#1		; 'PLAN X.Y'	JUMP,EQ	DODEFINE	COMP.W	D2,#2			; Or ...	JUMP,NE	43$	CALL	_CHWDO	JUMP	LOOP43$:	COMP.W	D2,#3		; Co, Po, Di ...	JUMP,NE	46$	TNOT.B	(A6)+OFLMOD:#BLAST	; inverse	TEST.B	(A6)+OFLMOD:#BLAST	JUMP,BS	44$	CALL	RELLAST44$:	CALL	_INIHAUT		; remet  jour le haut	JUMP	LOOP46$:85$:	CALL	HLIGHTEN	; teindre ce qui est allum et ...	JUMP	LOOPHLIGHTEN:	COMP.W	D2,#0	JUMP,EQ	90$	COMP.W	D2,#3	JUMP,HI	90$	PUSHM.L	D0,D2,D3,D4	LOAD.L	D3,#H'FFFFFFFF	; dfinir la trame	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D1,D2	CLR.L	D2	LOAD.W	D2,(A6)+OPLANAV+OCARX	; D2.W <-- largeur car.	LOAD.W	D0,D2	LOAD.W	D3,#1		; D3.L <-- yy/..	SWAP.W	D3	LOAD.W	D4,(A6)+OPLANAV+OCARY	; D4.L <-- dyy/..	DEC.W	D4	SWAP.W	D4	COMP.W	D1,#1	JUMP,NE	2$	MUL.WU	D2,#9		; D2.W <-- ../dxx	JUMP	80$2$:	COMP.W	D1,#2	JUMP,NE	3$	MUL.WU	D0,#10	MUL.WU	D2,#14	JUMP	80$3$:	COMP.W	D1,#3	JUMP,NE	85$	MUL.WU	D0,#24	MUL.WU	D2,#14;	JUMP	80$80$:	LOAD.W	D3,D0		; D3.L <-- xx,yy	LOAD.W	D4,D2		; D4.L <-- dxx,dyy	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX85$:	POPM.L	D0,D2,D3,D490$:	RET;------- SOURIS dans la ligne du BASBAS:	LOAD.W	D1,#1		; init D1	COMP.W	D5,#61		; 'objet'	JUMP,HS	1$	JUMP	20$1$:	INC.W	D1	COMP.W	D5,#132		;124		; objet	JUMP,HS	2$	JUMP	20$2$:	INC.W	D1	COMP.W	D5,#204		; trait	JUMP,HS	3$	JUMP	20$3$:	INC.W	D1	COMP.W	D5,#300		; couleur	JUMP,HS	4$	JUMP	20$4$:	INC.W	D1	COMP.W	D5,#356		; mode	JUMP,HS	5$	JUMP	20$5$:	INC.W	D1	COMP.W	D5,#430		; pas	JUMP,HS	6$	JUMP	20$6$:	INC.W	D1	COMP.W	D5,#526		; gencar	JUMP,HS	7$	JUMP	20$7$:	INC.W	D1;	JUMP	20$20$:	LOAD.W	D0,D1	SWAP.W	D1	COMP.W	D0,D1		; le mme ?	JUMP,EQ	21$		; oui	CALL	BLIGHTEN	; non, teindre l'ancien	SWAP.W	D1		; allumer le nouveau	CALL	BLIGHTEN21$:	CALL	IFMOUSE		; D3 <-- boutons, D4 <-- position	JUMP,NE	85$		; hors de la fentre ...				; ...teindre et FILS	LOAD.L	D5,D4		; D5 <-- pos. souris				; ligne du bas ?	LOAD.W	D0,(A6)+OPLANAV+OWDOY	SUB.W	D0,(A6)+OPLANAV+OCARY	SWAP.W	D0	LOAD.W	D0,(A6)+OPLANAV+OWDOX	COMP.L	D5,D0	JUMP,LO	22$		; non, teindre et LOOP				; oui et ...	TEST.B	D3		; ... bouton(s) relach(s)	JUMP,EQ	30$		; oui --> 30$	SWAP.W	D1		; non sauver l'ancien	JUMP	BAS		; ... et recommencer22$:	CALL	BLIGHTEN	CLR.L	D1	TEST.B	D3	JUMP,NE	21$	JUMP	LOOP		; hors ligne du bas, teindre30$:				; oui ... saut selon	CALL	BLIGHTEN	; ... teindre et saut dans le menu	COMP.W	D1,#1		; 'objet'	JUMP,EQ	DOMENUMACRO	COMP.W	D1,#2			; objet	JUMP,NE	43$	JUMP	DOMOBJET43$:	COMP.W	D1,#3		; trait	JUMP,NE	44$	JUMP	DOMTRAI44$:	COMP.W	D1,#4		; couleur	JUMP,EQ	DOMCOULB	COMP.W	D1,#5		; mode	JUMP,EQ	DOMMODE	COMP.W	D1,#6		; pas	JUMP,EQ	DOMPASB	COMP.W	D1,#7		; loupe	JUMP,EQ	DOMLOUPEB	JUMP	DOMTEX		; gencar85$:	CALL	BLIGHTEN	; teindre ce qui est allum et ...	JUMP	LOOPBLIGHTEN:	COMP.W	D1,#0	JUMP,EQ	90$	PUSHM.L	D0,D2,D3,D4	LOAD.L	D3,#H'FFFFFFFF	; dfinir la trame	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.W	D2,(A6)+OPLANAV+OCARX	; D2.W <-- largeur car.	LOAD.W	D0,D2	LOAD.W	D3,(A6)+OPLANAV+OWDOY	; D3.L <-- yy/..	SUB.W	D3,(A6)+OPLANAV+OCARY;;	INC.W	D3	SWAP.W	D3	LOAD.W	D4,(A6)+OPLANAV+OCARY	; D4.L <-- dyy/..	DEC.W	D4;;	DEC.W	D4	SWAP.W	D4	COMP.W	D1,#1	JUMP,NE	2$;	LOAD.W	D0,D2		; D0.W <-- ../xx	MUL.WU	D2,#6		; D2.W <-- ../dxx	JUMP	80$2$:	COMP.W	D1,#2	JUMP,NE	3$	MUL.WU	D0,#8	MUL.WU	D2,#8	JUMP	80$3$:	COMP.W	D1,#3	JUMP,NE	4$	MUL.WU	D0,#17	MUL.WU	D2,#8	JUMP	80$4$:	COMP.W	D1,#4	JUMP,NE	5$	MUL.WU	D0,#26	MUL.WU	D2,#11	JUMP	80$5$:	COMP.W	D1,#5	JUMP,NE	6$	MUL.WU	D0,#38	MUL.WU	D2,#6	JUMP	80$6$:	COMP.W	D1,#6	JUMP,NE	7$	MUL.WU	D0,#46	MUL.WU	D2,#8	JUMP	80$7$:	COMP.W	D1,#7	JUMP,NE	8$	MUL.WU	D0,#54	MUL.WU	D2,#12	JUMP	80$8$:	COMP.W	D1,#8	JUMP,NE	85$	MUL.WU	D0,#66	MUL.WU	D2,#1380$:	LOAD.W	D3,D0		; D3.L <-- xx,yy	LOAD.W	D4,D2		; D4.L <-- dxx,dyy	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX85$:	POPM.L	D0,D2,D3,D490$:	RET;------ MENU avec tous les objets trs rapideDOMOBJET:LOAD.L	D3,(A6)+OPLANAV+ODWDOYSUB.W	D3,#67SWAP.W	D3LOAD.W	D3,#265;	LOAD.L	D3,#187*H'10000+265	; valeurs exprimentales	LOAD.W	D2,#2^BDBSAV!2^BDBPOS!2^BDBCAS	LOAD.L	A2,#R16"TDBOX_MOBJET	CLR.L	D4	CALL	DBOXOPEN	JUMP,NE	LOOP	JUMP	20$10$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP20$:	DBOX_	EDIT		COMP.W	D3,#KEYMGR	JUMP,EQ	20$	COMP.W	D3,#KEYMMR	JUMP,EQ	20$	COMP.W	D3,#KEYMDR	JUMP,EQ	20$	COMP.W	D3,#H'7F00+1	JUMP,HS	10$	COMP.W	D3,#END			; annule	JUMP,EQ	90$	LOAD.W	(A6)+OARC,#0		; pour cercle et ellipse	COMP.B	D3,#OBJARC	JUMP,NE	31$	SR.W	D3,#8			; arc	AND.W	D3,#H'00FF	LOAD.W	(A6)+OARC,D3	LOAD.W	D3,#OBJARC	JUMP	80$31$:	COMP.B	D3,#OBJARCELL	JUMP,NE	32$	SR.W	D3,#8			; ellipse	AND.W	D3,#H'00FF	LOAD.W	(A6)+OARC,D3	LOAD.W	D3,#OBJARCELL	JUMP	80$32$:	COMP.B	D3,#OBJRECT	JUMP,NE	33$	SR.W	D3,#8			; rectangle	AND.W	D3,#H'00FF	SL.W	D3,#2	LOAD.W	(A6)+ORRECT,D3	LOAD.W	D3,#OBJRECT	JUMP	80$33$:	COMP.W	D3,#OBJSURF	JUMP,NE	34$	CALL	DBOXCLOSE		; surface	JUMP	DOMSURF34$:	COMP.W	D3,#OBJFLECHE	JUMP,NE	35$	CALL	DBOXCLOSE		; flche;	JUMP	DOMFLE	call	domfle;	jump	loop	jump	domrelm35$:	COMP.W	D3,#OBJSTOCK	JUMP,NE	36$	CALL	DBOXCLOSE		; bloc-notes	JUMP	DOMSTO36$:80$:	COMP.W	D3,#0	JUMP,LO	10$	COMP.W	D3,#20+1	JUMP,HS	10$	LOAD.W	(A6)+OOBJET,D3		; le reste ...	CALL	DBOXCLOSE	JUMP	DOMRELM90$:	CALL	DBOXCLOSE	JUMP	LOOP;======= DMOVE:;=======; teste si dans carr d'intersection des ascenseurs,; si oui permet de faire bouger les deux ascenseurs  la fois;; in	A5.L	^variables ascenseur horiz. suivies des var. asc. vert.;	D4.L	position souris  l'cran;; mod	D3,D4,D7;			; est-on  l'intersection des deux asc.	PUSHM.L	D3..D6	LOAD.W	D7,#-1			; D7 <-- -1 pour signaler qu'on y est pas	COMP.W	D4,(A5)+OSCDEBL+LSCVAR	; X < Xmin	JUMP,LO	90$			; oui => 90$	COMP.W	D4,(A5)+OSCDEBO		; X > Xmax. ?	JUMP,GT	90$			; oui => 90$	SWAP.W	D4	COMP.W	D4,(A5)+OSCDEBL		; Y < Ymin. ?	JUMP,LO	90$			; oui => 90$	SUB.W	D4,#LGSCROLL	COMP.W	D4,(A5)+OSCDEBL		; Y > Ymax. ? (Y-LGSCROLL > Ymin.)	JUMP,GT	90$	ADD.W	D4,#LGSCROLL			; on est  l'intersection des deux asc.	CALL	95$			; inverse le carr d'intersection				; calculer les bornes inf. et sup.  l'cran				; Y inf.	LOAD.W	D4,(A5)+OSCDEBL		; D4 <-- Y dbut asc. horiz.	SUB.W	D4,#LGSCROLL+LGSCROLL/2	; dduit flche et demi-asc.	TEST.B	(A5)+LSCVAR+OSCPAGE	; avance par page asc. vert. ?	JUMP,EQ	1$			; non	SUB.W	D4,#LGSCROLL		; oui, dduit page1$:	SWAP.W	D4				; X inf.	LOAD.W	D4,(A5)+OSCDEBO		; D4 <-- dbut asc. horiz.	ADD.W	D4,#LGSCROLL+LGSCROLL/2	; ajoute flche et demi-asc.	TEST.B	(A5)+OSCPAGE		; avance par page ?	JUMP,EQ	2$			; non	ADD.W	D4,#LGSCROLL		; oui, ajoute page2$:	LOAD.L	(A6)+OASCBINF,D4	; OASCBINF <-- (Yinf;Xinf)				; Y sup.	LOAD.W	D4,(A5)+LSCVAR+OSCDEBO	; D4 <-- dbut asc. vert.	ADD.W	D4,#LGSCROLL+LGSCROLL/2	; ajoute flche et demi-asc.	TEST.B	(A5)+LSCVAR+OSCPAGE	; avance par page ?	JUMP,EQ	3$			; non	ADD.W	D4,#LGSCROLL		; oui, ajoute page3$:	SWAP.W	D4		; X sup.	LOAD.W	D4,(A5)+OSCDEBO		; D4 <-- dbut asc. horiz.	ADD.W	D4,(A5)+OSCHTR		; ajoute 'hauteur' relle	SUB.W	D4,#LGSCROLL+LGSCROLL/2	; dduit flche et demi-asc.	TEST.B	(A5)+OSCPAGE		; avance par page ?	JUMP,EQ	4$			; non	SUB.W	D4,#LGSCROLL		; oui, dduit page4$:	LOAD.L	(A6)+OASCBSUP,D4;	JUMP	10$				; commencer  la pos. actuelle des asc.	LOAD.W	D4,(A5)+LSCVAR+OSCPOSR	ADD.W	D4,(A6)+OASCBSUP		; ajoute Y borne sup.	SWAP.W	D4	LOAD.W	D4,(A5)+OSCPOSR	ADD.W	D4,(A6)+OASCBINF+2	; ajoute X borne inf.	CALL	PMOUSE			; positionne la souris	LOAD.L	D5,D4	CALL	97$			; dessine droites	CALL	USEPAGC; boucle principale de lecture souris et affichage des droites10$:	LIB	?GETKEY			; attend que souris bouge	TEST.L	D3:#BKPSEUDO	JUMP,BS	10$	LIB	?IFMOUSE	TEST.B	D3			; bouton relach ?	JUMP,EQ	60$			; oui => 60$				; rester dans les bornes !	COMP.L	D4,(A6)+OASCBINF	JUMP,LO	11$	SWAP.W	D4	LOAD.W	D4,(A6)+OASCBINF	SWAP.W	D411$:	COMP.W	D4,(A6)+OASCBINF+2	JUMP,GT	12$	LOAD.W	D4,(A6)+OASCBINF+212$:	COMP.L	D4,(A6)+OASCBSUP	JUMP,GT	13$	SWAP.W	D4	LOAD.W	D4,(A6)+OASCBSUP	SWAP.W	D413$:	COMP.W	D4,(A6)+OASCBSUP+2	JUMP,LO	14$	LOAD.W	D4,(A6)+OASCBSUP+214$:	PUSH.L	D4	LOAD.L	D4,D5			; non, effacer les anciennes droites	CALL	97$	POP.L	D420$:	LOAD.L	D5,D4	CALL	97$			; dessiner les droites	PUSH.L	D4	LOAD.W	D6,(A6)+OASCBSUP+2	; D6 <-- delta X des bornes  l'cran	SUB.W	D6,(A6)+OASCBINF+2	SUB.W	D4,(A6)+OASCBINF+2	; D4 <-- X - X borne inf.	MUL.WU	D4,#1000		; D4 <-- D4 * 1000	DIV.WU	D4,D6			; D4 <-- D4 / D6	MUL.WU	D4,(A5)+OSCHTV		; D4 <-- D4 * hauteur relle	DIV.WU	D4,#1000		; D4 <-- D4 / 1000	LOAD.W	(A5)+OSCPOSV,D4		; bouger asc. horiz.	SCROLL_	UPDATE	POP.L	D4	SWAP.W	D4	LOAD.W	D6,(A6)+OASCBINF	; D6 <-- delta Y des bornes  l'cran	SUB.W	D6,(A6)+OASCBSUP	SUB.W	D4,(A6)+OASCBSUP	; D4 <-- Y - Y borne sup.	MUL.WU	D4,#1000		; D4 <-- D4 * 1000	DIV.WU	D4,D6			; D4 <-- D4 / D6	MUL.WU	D4,(A5)+LSCVAR+OSCHTV	; D4 <-- D4 * hauteur relle	DIV.WU	D4,#1000		; D4 <-- D4 / 1000	LOAD.W	(A5)+LSCVAR+OSCPOSV,D4	; bouger asc. vert.	PUSH.L	A5	ADD.L	A5,#LSCVAR	SCROLL_	UPDATE	POP.L	A5				; afficher l'origine ligne du haut	LOAD.W	D0,(A5)+OSCHTV+LSCVAR	SUB.W	D0,(A5)+OSCPOSV+LSCVAR;;;	DEC.W	D0		; Y dans l'autre sens !!	CALL	XARRONDI	SWAP.W	D0	LOAD.W	D0,(A5)+OSCPOSV	; X	CALL	XARRONDI	LOAD.L	D3,(A6)+OPOSOX	LIB	?SETCURS	LOAD.W	D4,D0	CALL	AFFPARX	LOAD.L	D3,(A6)+OPOSOY	LIB	?SETCURS	SWAP.W	D0	LOAD.W	D4,D0	CALL	AFFPARY	JUMP	10$		; et finalement recommencer ...60$:				; BOUTON relach	LOAD.L	D4,D5	CALL	97$			; efface droites	CALL	95$			; remet le carr d'intersection	CLR.W	D7			; ok.	CALL	USEDGC90$:	POPM.L	D3..D6	TEST.W	D7	RET; ******** inverse le carr d'intersection95$:	PUSHM.L	D3,D4,A2	LOAD.L	D3,#AFCCMO	; enlve flche souris	LIB	?AFCAR	LOAD.L	A2,(A6)+OPLANAV+OPDDIS	; A2 ^description fentre	LOAD.W	D4,(A5)+OSCDEBL	ADD.W	D4,#3	SWAP.W	D4	LOAD.W	D4,(A5)+OSCDEBO	SUB.W	D4,#LGSCROLL-2	LOAD.L	D3,#(LGSCROLL-4)*H'10000+LGSCROLL-4	GRA_	INV;	JUMP,NE	...	LOAD.B	D3,#AFSCMO	; remet flche souris	LIB	?AFCAR	POPM.L	D3,D4,A2	RET; ******** dessine les droites97$:	PUSHM.L	D2,D3,D4,D5	LOAD.L	D5,D4	LOAD.L	D3,D4	LOAD.W	D2,#INVDOT	SWAP.W	D3	LOAD.W	D4,(A5)+OSCDEBL	; dy jusqu' l'asc. horiz.	SUB.W	D4,D3	JUMP,NS	99$	SWAP.W	D3	SWAP.W	D4	CLR.W	D4		; dy = 0	LIB	?DRSEG	JUMP,NE	99$	LOAD.L	D3,D5	CLR.L	D4	LOAD.W	D4,(A5)+OSCDEBO	SUB.W	D4,D3	JUMP,NC	99$	LIB	?DRSEG	JUMP,NE	99$98$:	POPM.L	D2,D3,D4,D5	RET99$:	LOAD.B	D3,#BIPLIT	LIB	?AFCAR	JUMP	98$; fin DMOVEDFERROR:	CALL	CWMO		; remet la souris normale	CALL	SCMO		; remet flche souris	CALL	_MOERROR	; affiche erreur	CALL	INIHAUT		; mj fentre du haut	CALL	INIBAS		; mj fentre du bas	JUMP	LOOP;********** DODESSINE:;**********CALL	AFDMENU	CALL	RELLAST	LOAD.W	D0,(A6)+OOBJET	; D0<-- objet  dessiner	COMP.B	D0,#OBJSTOCK	; bloc-notes ne modifie pas pos.	JUMP,EQ	DOSTOCK	COMP.B	D0,#OBJFILL	; fill non-plus	JUMP,EQ	DOFILL	LOAD.L	D1,(A6)+OMLAST	; sauve dernire pos. significative	LOAD.L	(A6)+OMLLAST,D1	;   pour RDMOUSE lors du DESSIN	LOAD.L	(A6)+OMLAST,D4	; mmorise dernire pos.(clic unique)	LOAD.L	(A6)+ORIPOS,D4	; mm. position d'origine	TSET.B	(A6)+OPLANAV+OFLAGS:#BFIRST	LOAD.W	D2,(A6)+OMODE	; D2 <-- mode/couleur de dessin	LOAD.W	D1,(A6)+OTRAIT	; D1 <-- type du trait	COMP.W	D1,#3		; trait avec pinceau ?	JUMP',LO 20$		; non => 20$	LOAD.W	D1,#TRAFIN	; oui => fait comme si trait fin !20$:	COMP.B	D0,#OBJLIGNE	JUMP,EQ	DOLIGNE	COMP.B	D0,#OBJSPLO	JUMP,EQ	DOSPLINE	COMP.B	D0,#OBJSPLC	JUMP,EQ	DOSPLINE	COMP.B	D0,#OBJPOLO	JUMP,EQ	DOPOLYGO	COMP.B	D0,#OBJPOLC	JUMP,EQ	DOPOLYGO	COMP.B	D0,#OBJPOLHV	JUMP,EQ	DOPOLHV	COMP.B	D0,#OBJDROITE	JUMP,EQ	DODROITE	COMP.B	D0,#OBJDHV	JUMP,EQ	DODHV	COMP.B	D0,#OBJELASTIQUE	JUMP,EQ	DODROITE	COMP.B	D0,#OBJEHV	JUMP,EQ	DODHV	COMP.B	D0,#OBJFLECHE	JUMP,EQ	DOFLECHE	COMP.B	D0,#OBJFHV	JUMP,EQ	DOFHV	COMP.B	D0,#OBJCERCLE	JUMP,EQ	DOARC	COMP.B	D0,#OBJARC	JUMP,EQ	DOARC	COMP.B	D0,#OBJELLIPSE	JUMP,EQ	DOELLIPSE	COMP.B	D0,#OBJARCELL	JUMP,EQ	DOARCELL	COMP.B	D0,#OBJRECT	JUMP,EQ	DORECT	COMP.B	D0,#OBJSURF	JUMP,EQ	DOSURFCALL	AFMENU	JUMP	LOOPDOLIGNE:	CALL	_INIXY		; pour afficher X= et Y=;	CALL	CCMOO		; enlve flche souris;;;	CALL	AJOUTEDS	; met dbut de groupe systme	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJDS	.W	PLANA_BASE10$:	LOAD.L	D5,D4		; D5 <-- ancienne position20$:	CALL	RDMOUSE		; lit la souris	TEST.B	D3	JUMP',EQ 80$	LOAD.L	(A6)+OMLAST,D4	; mmorise la dermire pos.	PUSH.L	D4	LOAD.L	D3,D5		; D3 <-- ancienne position;;;	CALL	ORDONNE		; D3 < D4	.W	PLANA_ORDONNE	SUB.W	D4,D3		; D4 <-- dX	COMP.W	D4,#INCMAIN	JUMP',HS 40$	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dY	COMP.W	D4,#INCMAIN40$:	POPM.L	D4		; au moins INCMAIN dans une direction ?	JUMP,LO	20$		; non => 20$	LOAD.L	D3,D5		; D3 <-- ancienne position	LOAD.W	D1,(A6)+OTRAIT	; D1 <-- type du trait;;;	CALL	AJOUTE		; ajoute dans base de donne	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE	JUMP,NE	DFERROR		; si plein => DFERROR	CALL	IRETICULE;;;	CALL	LIGNE		; dessine ligne depuis prcd..W	PLANA_DESSINE	CALL	IRETICULE	CALL	AFFXY		; affiche X= et Y=	JUMP	10$80$:;;;	CALL	AJOUTEFS	; met fin de groupe systme	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJFS	.W	PLANA_BASE	CALL	SCMO		; remet flche souris	CALL	_INIHAUT	; refait le haut de la fentreCALL	AFMENU	JUMP	LOOPDOFLECHE:	RR.W	D0,#8	LOAD.B	D0,(A6)+OFLECHE+1	RR.W	D0,#8DODROITE:	TSET.B	(A6)+OFLINFO:#BINFOR ; met flag pour pav information	CALL	_INIDXY		; pour afficher dX= et dY=	CALL	CCMOO		; enlve flche souris	LOAD.W	D2,#MODINV	; D2 <-- mode inverse	or.b	D2,#H'F0	; sans test visible10$:	LOAD.L	D5,D4		; D5 <-- ancienne position	CALL	RDMOUSE		; lit la souris	TEST.B	D3	JUMP',EQ 80$	CALL	CLDDR	JUMP	10$80$:	CALL	AJDR	JUMP	EXDR; modif 4.7 routines communes aux droites et polygonesCLDDR:				; efface et dessine une droite ou flche	LOAD.L	D3,(A6)+ORIPOS	; D3 <-- coordonne dpart	PUSH.L	D4	LOAD.L	D4,D5		; D4 <-- ancienne arrive	TCLR.B	(A6)+OPLANAV+OFLAGS:#BFIRST	JUMP',BS 50$	CALL	I_INFO;;;	CALL	DROITE		; efface ancienne droite	.W	PLANA_DESSINE50$:	POP.L	D4	CALL	I_INFO;;;	CALL	DROITE		; dessine nouvelle droite	.W	PLANA_DESSINE	CALL	AFFDXY		; affiche dX= et dY=	RETAJDR:				; ajoute droite ou flche dans la base	LOAD.L	D3,(A6)+ORIPOS	; D3 <-- coordonne dpart	LOAD.L	D4,D5		; D4 <-- ancienne arrive	COMP.L	D3,D4		; objet nul ?	JUMP',EQ 90$		; oui => 90$;;;	CALL	DROITE		; efface ancienne droite	.W	PLANA_DESSINE	LOAD.W	D2,(A6)+OMODE	; D2 <-- mode/couleur de dessin	LOAD.W	D1,(A6)+OTRAIT	; D1 <-- type du trait;;;	CALL	AJOUTE		; ajoute dans base de donne	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE	JUMP,NE	DFERROR		; si plein => DFERROR	CALL	IRETICULE	TCLR.B	(A6)+OFLINFO:#BINFOR ; fin affichage pav information	CALL	I_INFO;;;	CALL	DROITE		; dessine droite dfinitive	.W	PLANA_DESSINE	LOAD.L	(A6)+OMLAST,D4	; mmorise dernire pos. significative	CALL	IRETICULE90$:	RETEXDR:				; retour	CALL	SCMO		; remet flche sourisEXDRMO:	CALL	INIHAUT	; refait le haut de la fentre	CALL	AFMENU	JUMP	LOOP; fin routines communes droites et polygonesDOPOLYGO:	CALL	MESPOL	CALL	_INIDXY		; POUR AFFICHER dX et dY	CALL	CCMOO		; enlve flche souris;;;	CALL	AJOUTEDS	; met dbut groupe systme	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJDS	.W	PLANA_BASE	LOAD.L	(A6)+OSPLPT,D4	; mmorise le point de dpart10$:	TSET.B	(A6)+OFLINFO:#BINFOR ; met flag pour pav information	LOAD.W	D2,#MODINV	; D2 <-- mode inverse	or.b	D2,#H'F0	; sans test visible	LOAD.W	D1,#TRAFIN	; D1 <-- trait fin	LOAD.L	D5,D4		; D5 <-- ancienne position	CALL	RDMOUSE		; lit la souris	TEST.L	D3:#BMORIGHT	; bouton de droite	JUMP,BS	80$		; oui => brise et nlle. droite	TEST.L	D3:#BMOLEFT	; bouton de gauche relach ?	JUMP,BC	90$		; oui => fin	PUSH.L	D0	LOAD.L	D0,#OBJELASTIQUE	CALL	CLDDR	POP.L	D0	JUMP	10$80$:	PUSHM.L	D0	LOAD.W	D0,#OBJELASTIQUE	CALL	AJDR	POPM.L	D0	TSET.B	(A6)+OPLANAV+OFLAGS:#BFIRST	; nlle droite	LOAD.L	(A6)+ORIPOS,D4		; arrive = nouveau dpart	JUMP	10$90$:	PUSHM.L	D0	LOAD.W	D0,#OBJELASTIQUE	CALL	AJDR	POPM.L	D0	COMP.B	D0,#OBJPOLC	; polygone ferm ?	JUMP',NE 91$		; non --> 91$	LOAD.L	D3,(A6)+OSPLPT	; point dpart polygone	LOAD.L	(A6)+OMLAST,D3	; mmorise dernier pnt. significatif	COMP.L	D3,D4		; objet nul ?	JUMP',EQ 91$		; oui --> 91$	LOAD.W	D2,(A6)+OMODE	; mode	LOAD.W	D1,(A6)+OTRAIT	; trait	LOAD.W	D0,#OBJELASTIQUE	; objet;;;	CALL	AJOUTE		; ajoute dans la base de donnees	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE	CALL	IRETICULE;;;	CALL	DROITE		; dessine droite dfinitive	.W	PLANA_DESSINE	CALL	IRETICULE91$:;;;	CALL	AJOUTEFS	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJFS	.W	PLANA_BASE	CALL	WAITMOUSE	; attend souris	CALL	INIBAS		; mj fentre du bas	JUMP	EXDR; Sp.DOFHV:	RR.W	D0,#8	LOAD.B	D0,(A6)+OFLECHE+1	RR.W	D0,#8DODHV:	CALL	INIDXY		; pour afficher dX= et dY=;;	CALL	CCMOO		; enlve flche souris	LOAD.W	D2,#MODINV	; D2 <-- mode inverse	or.b	D2,#H'F0	; sans test visible10$:	LOAD.L	D5,D4		; D5 <-- ancienne position	CALL	RDMOUSE		; lit la souris	TEST.B	D3	JUMP',EQ 80$	CALL	CLDDRHV	JUMP	10$80$:	CALL	AJDRHV	JUMP	EXDRMO		; sans remettre flche souris; modif 4.7 routines communes aux droites et polygonesCLDDRHV:				; efface et dessine une droite ou flche	LOAD.L	D3,(A6)+ORIPOS	; D3 <-- coordonne dpart	PUSH.L	D4	LOAD.L	D4,D5		; D4 <-- ancienne arrive	TCLR.B	(A6)+OPLANAV+OFLAGS:#BFIRST	JUMP',BS 50$;;;	CALL	DHV		; efface ancienne droite	.W	PLANA_DESSINE50$:	POP.L	D4;;;	CALL	DHV		; dessine nouvelle droite	.W	PLANA_DESSINE	CALL	AFFDXY		; affiche dX= et dY=	RETAJDRHV:				; ajoute droite ou flche dans la base	LOAD.L	D3,(A6)+ORIPOS	; D3 <-- coordonne dpart	LOAD.L	D4,D5		; D4 <-- ancienne arrive	COMP.L	D3,D4		; objet nul ?	JUMP',EQ 90$		; oui => 90$;;;	CALL	DHV		; efface ancienne droite	.W	PLANA_DESSINE	LOAD.W	D2,(A6)+OMODE	; D2 <-- mode/couleur de dessin	LOAD.W	D1,(A6)+OTRAIT	; D1 <-- type du trait;;;	CALL	AJOUTE		; ajoute dans base de donne	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE	JUMP,NE	DFERROR		; si plein => DFERROR	CALL	IRETICULE;;;	CALL	DHV		; dessine droite dfinitive	.W	PLANA_DESSINE	LOAD.L	(A6)+OMLAST,D4	; mmorise la dernire pos. significative	CALL	IRETICULE90$:	RET; Sp. fin routines communes droites et polygones;----------MESPOL:			; message centr en bas pour polygones	CALL	_AFCMES;;.ASCIZE	"polygone --> press  GAUCHE: dessine   'clic'  DROITE: brise"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,96,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" press |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,101,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" met/enlve PAS |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,98,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZE	" 'clic': brise "	RET;--------DOPOLHV:	CALL	MESPOL	CALL	INIDXY		; pour afficher dX= et dY=;;;	CALL	CCMOO		; enlve flche souris;;;	CALL	AJOUTEDS	; met dbut groupe systme	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJDS	.W	PLANA_BASE10$:	LOAD.W	D2,#MODINV	; D2 <-- mode inverse	or.b	D2,#H'F0	; sans test visible	LOAD.W	D1,#TRAFIN	; D1 <-- trait fin	LOAD.L	D5,D4		; D5 <-- ancienne position	CALL	RDMOUSE		; lit la souris	TEST.L	D3:#BMORIGHT	; bouton de droite	JUMP,BS	80$		; oui => brise et nlle. droite	TEST.L	D3:#BMOLEFT	; bouton de gauche relach ?	JUMP,BC	90$		; oui => fin	PUSH.L	D0	LOAD.L	D0,#OBJEHV	CALL	CLDDRHV	POP.L	D0	JUMP	10$80$:	PUSHM.L	D0	LOAD.W	D0,#OBJEHV	CALL	AJDRHV	POPM.L	D0	TSET.B	(A6)+OPLANAV+OFLAGS:#BFIRST	; nlle droite	LOAD.L	(A6)+ORIPOS,D4		; arrive = nouveau dpart	JUMP	10$90$:	PUSHM.L	D0	LOAD.W	D0,#OBJEHV	CALL	AJDRHV	POPM.L	D0;;;	CALL	AJOUTEFS	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJFS	.W	PLANA_BASE	CALL	WAITMOUSE	; attend souris	CALL	INIBAS		; mj fentre du bas	JUMP	EXDRMO		; sans remettre flche souris; Sp.DOARC:	CALL	INIR		; pour afficher R=;	CALL	CCMOO		; enlve flche souris	LOAD.W	D2,#MODINV	; D2 <-- mode inverse	or.b	D2,#H'F0	; sans test visible10$:	LOAD.L	D5,D4		; D5 <-- ancienne position	CALL	RDMOUSE		; lit la souris	TEST.B	D3	JUMP',EQ 80$	PUSH.L	D4	LOAD.L	D4,D5	CALL	RARC8		; D3 <-- rayon cercle / arc	LOAD.L	D4,(A6)+ORIPOS	; D4 <-- coordonne centre	TCLR.B	(A6)+OPLANAV+OFLAGS:#BFIRST	JUMP',BS 50$;;;	CALL	ARC8		; efface ancien cercle	.W	PLANA_DESSINE50$:	POP.L	D4	CALL	RARC8		; D3 <-- rayon cercle / arc	PUSH.L	D4	LOAD.L	D4,(A6)+ORIPOS	; D4 <-- coordonne centre;;;	CALL	ARC8		; dessine nouveau cercle	.W	PLANA_DESSINE	POP.L	D4	CALL	AFFR		; affiche R=	JUMP	10$80$:	LOAD.L	D4,D5	CALL	RARC8		; D3 <-- rayon cercle / arc	TEST.W	D3		; objet nul ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	D4,(A6)+ORIPOS	; D4 <-- coordonne centre;;;	CALL	ARC8		; efface ancien cercle	.W	PLANA_DESSINE	LOAD.W	D2,(A6)+OMODE	; D2 <-- mode/couleur de dessin	LOAD.W	D1,(A6)+OTRAIT	; D1 <-- type du trait;;;	CALL	AJOUTE		; ajoute dans base de donne	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE	JUMP,NE	DFERROR		; si plein => DFERROR	CALL	IRETICULE;;;	CALL	ARC8		; dessine cercle dfinitif	.W	PLANA_DESSINE	CALL	IRETICULE90$:;	CALL	SCMO		; remet flche souris	CALL	INIHAUT		; refait le haut de la fentreCALL	AFMENU	JUMP	LOOPDOARCELL:	CALL	INIRXY		; pour afficher Rx,y=;	CALL	CCMOO		; enlve flche souris	LOAD.W	D2,#MODINV	; D2 <-- mode inverse	or.b	D2,#H'F0	; sans test visible	LOAD.W	D1,#TRAFIN	; D1 <-- d'abord avec un trait fin !10$:	LOAD.L	D5,D4		; D5 <-- ancienne position	CALL	RDMOUSE		; lit la souris	TEST.B	D3	JUMP',EQ 80$	PUSH.L	D4	LOAD.L	D4,D5	CALL	RARCELL		; D3 <-- rayons / arcs	LOAD.L	D4,(A6)+ORIPOS	; D4 <-- coordonne centre	TCLR.B	(A6)+OPLANAV+OFLAGS:#BFIRST	JUMP',BS 50$;;;	CALL	ARCELL		; efface ancienne ellipse	.W	PLANA_DESSINE50$:	POP.L	D4	CALL	RARCELL		; D3 <-- rayons / arcs	PUSH.L	D4	LOAD.L	D4,(A6)+ORIPOS	; D4 <-- coordonne centre;;;	CALL	ARCELL		; dessine nouvelle ellipse	.W	PLANA_DESSINE	POP.L	D4	EX.L	D3,D4	CALL	AFFXY		; affiche Rx,y=	EX.L	D4,D3	JUMP	10$80$:	LOAD.L	D4,D5	CALL	RARCELL		; D3 <-- rayons / arcs;;;;	TEST.L	D3		; objet nul ?;;;;	JUMP',EQ 90$		; oui => 90$	LOAD.L	D4,(A6)+ORIPOS	; D4 <-- coordonne centre;;;	CALL	ARCELL		; efface ancienne ellipse	.W	PLANA_DESSINE	TEST.W	D3		; Rx nul ?	JUMP',EQ	90$	COMP.L	D3,#H'FFFF	; Ry nul ?	JUMP,LS	90$	LOAD.W	D2,(A6)+OMODE	; D2 <-- mode/couleur de dessin	LOAD.W	D1,(A6)+OTRAIT	; D1 <-- type du trait;;;	CALL	AJOUTE		; ajoute dans base de donne	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE	JUMP,NE	DFERROR		; si plein => DFERROR	CALL	IRETICULE;;;	CALL	ARCELL		; dessine ellipse dfinitive	.W	PLANA_DESSINE	CALL	IRETICULE90$:;	CALL	SCMO		; remet flche souris	CALL	INIHAUT	; refait le haut de la fentreCALL	AFMENU	JUMP	LOOPDOELLIPSE:	CALL	INIRXY		; pour afficher Rx,y=;	CALL	CCMOO		; enlve flche souris	LOAD.W	D2,#MODINV	; D2 <-- mode inverse	or.b	D2,#H'F0	; sans test visible	LOAD.W	D1,#TRAFIN	; D1 <-- d'abord avec un trait fin !10$:	LOAD.L	D5,D4		; D5 <-- ancienne position	CALL	RDMOUSE		; lit la souris	TEST.B	D3	JUMP',EQ 80$	PUSH.L	D4	LOAD.L	D4,D5	CALL	RELLIPSE	; D3 <-- rayons	LOAD.L	D4,(A6)+ORIPOS	; D4 <-- coordonne centre	TCLR.B	(A6)+OPLANAV+OFLAGS:#BFIRST	JUMP',BS 50$;;;	CALL	ELLIPSE		; efface ancienne ellipse	.W	PLANA_DESSINE50$:	POP.L	D4	CALL	RELLIPSE	; D3 <-- rayons	PUSH.L	D4	LOAD.L	D4,(A6)+ORIPOS	; D4 <-- coordonne centre;;;	CALL	ELLIPSE		; dessine nouvelle ellipse	.W	PLANA_DESSINE	POP.L	D4	EX.L	D3,D4	CALL	AFFXY		; affiche Rx,y=	EX.L	D4,D3	JUMP	10$80$:	LOAD.L	D4,D5	CALL	RELLIPSE	; D3 <-- rayons	TEST.L	D3		; objet nul ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	D4,(A6)+ORIPOS	; D4 <-- coordonne centre;;;	CALL	ELLIPSE		; efface ancienne ellipse	.W	PLANA_DESSINE	LOAD.W	D2,(A6)+OMODE	; D2 <-- mode/couleur de dessin	LOAD.W	D1,(A6)+OTRAIT	; D1 <-- type du trait;;;	CALL	AJOUTE		; ajoute dans base de donne	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE	JUMP,NE	DFERROR		; si plein => DFERROR	CALL	IRETICULE;;;	CALL	ELLIPSE		; dessine ellipse dfinitive	.W	PLANA_DESSINE	CALL	IRETICULE90$:;	CALL	SCMO		; remet flche souris	CALL	INIHAUT	; refait le haut de la fentreCALL	AFMENU	JUMP	LOOPDORECT:	RR.W	D0,#8	LOAD.B	D0,(A6)+ORRECT+1	RR.W	D0,#8	CALL	INIDXY		; pour afficher dX= et dY=	CALL	CCMOO		; enlve flche souris	LOAD.W	D2,#MODINV	; D2 <-- mode inverse	or.b	D2,#H'F0	; sans test visible10$:	LOAD.L	D5,D4		; D5 <-- ancienne position	CALL	RDMOUSE		; lit la souris	TEST.B	D3	JUMP',EQ 80$	LOAD.L	(A6)+OMLAST,D4	; mmorise la dernire pos. significative	LOAD.L	D3,(A6)+ORIPOS	; D3 <-- coordonne dpart	PUSH.L	D4	LOAD.L	D4,D5		; D4 <-- ancienne arrive	TCLR.B	(A6)+OPLANAV+OFLAGS:#BFIRST	JUMP',BS 50$;;;	CALL	RRECTANGLE	; efface ancien rectangle	.W	PLANA_DESSINE50$:	POP.L	D4;;;	CALL	RRECTANGLE	; dessine nouveau rectangle	.W	PLANA_DESSINE	CALL	AFFDXY		; affiche dX= et dY=	JUMP	10$80$:	LOAD.L	D3,(A6)+ORIPOS	; D3 <-- coordonne dpart	LOAD.L	D4,D5		; D4 <-- ancienne arrive	COMP.L	D3,D4		; objet nul ?	JUMP',EQ 90$		; oui => 90$;;;	CALL	RRECTANGLE	; efface ancien rectangle	.W	PLANA_DESSINE; 5.11 refuse largeur ou hauteur nulleCOMP.W	D3,D4		; largeur nulle ?JUMP',EQ 90$		; oui => 90$SWAP.W	D3SWAP.W	D4COMP.W	D3,D4		; hauteur nulle ?JUMP',EQ 90$SWAP.W	D3SWAP.W	D4.W	PLANA_ORDONNE	LOAD.W	D2,(A6)+OMODE	; D2 <-- mode/couleur de dessin	LOAD.W	D1,(A6)+OTRAIT	; D1 <-- type du trait;;;	CALL	AJOUTE		; ajoute dans base de donne	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE	JUMP,NE	DFERROR		; si plein => DFERROR	CALL	IRETICULE;;;	CALL	RRECTANGLE	; dessine rectangle dfinitif	.W	PLANA_DESSINE	CALL	IRETICULE90$:	CALL	SCMO		; remet flche souris	CALL	INIHAUT	; refait le haut de la fentreCALL	AFMENU	JUMP	LOOPDOSURF:	CALL	CCMOO		; enlve flche souris	CALL	CREZONE		; dplace zone rectangulaire	COMP.L	D3,D4		; objet nul ?	JUMP',EQ 90$		; oui => 90$PUSH.L	D0LOAD.L	D0,#OBJRECT;;;	CALL	RECTANGLE	; efface ancien rectangle.W	PLANA_DESSINEPOP.L	D0; 5.11 refuse largeur ou hauteur nulleCOMP.W	D3,D4		; largeur nulle ?JUMP',EQ 90$		; oui => 90$SWAP.W	D3SWAP.W	D4COMP.W	D3,D4		; hauteur nulle ?JUMP',EQ 90$SWAP.W	D3SWAP.W	D4	LOAD.W	D1,(A6)+OTRAME	; D1 <-- type de trame	LOAD.W	D2,(A6)+OMODE	; D2 <-- mode/couleur de dessin;;;	CALL	AJOUTE		; ajoute dans base de donne	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE	JUMP,NE	DFERROR		; si plein => DFERROR	CALL	IRETICULE;;;	CALL	_SURFACE	; dessine surface dfinitive	.W	PLANA_DESSINE	CALL	IRETICULE	LOAD.L	(A6)+OMLAST,D4	; mmorise dernier pnt. significatif90$:	CALL	SCMO		; remet flche souris	CALL	INIHAUT		; refait le haut de la fentreCALL	AFMENU	JUMP	LOOPDOFILL:	LOAD.W	D7,#ERSCA	TEST.W	(A6)+OPLANAV+OSCALE	; chelle 1:1 ?	JUMP,NE	DFERROR		; non => DFERROR	LOAD.W	D7,#ERMDC	COMP.W	(A6)+OMODE,#MODCLR ; mode "efface" ?	JUMP,EQ	DFERROR		; oui => DFERROR	LOAD.L	A3,#(A6)+OPLANAV+OBUTRA	; A3 <-- ^trames	LOAD.W	D1,(A6)+OTRAME	MUL.WU	D1,#8	LOAD.L	D3,(A3)+(D1.W)+0 ; D3 <-- 1re partie trame	LOAD.L	D4,(A3)+(D1.W)+4 ; D4 <-- 2me partie trame	LIB	?DRMDEF		; dfini la bonne trame	CALL	IFMOUSE		; D4 <-- position PHYSIQUE de la souris	LOAD.L	D2,D4	CALL	IRETICULE	; enlve le rticule si ncessaire	TEST.B	(A6)+OPLANAV+OFLAGS:#BGRILLE	JUMP',BC 40$	CALL	GRILLE		; efface grille provisoirement40$:	LOAD.L	D3,(A6)+OPLANAV+OMINY	; D3 <-- coin sup/gauche	LOAD.L	D4,(A6)+OPLANAV+OMAXY	; D4 <-- coin inf/droite	SUB.W	D4,D3		; D4 <-- largeur swdo	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur swdo	SWAP.W	D3	SWAP.W	D4	LIB	?CREWDO		; cre swdo temporaire	LIB	?USEWDO		; utilise swdo temporaire	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE+1	LOAD.B	(A3)+0,#DRAWFILLO	SUB.W	D2,(A6)+OPLANAV+OMINX	LOAD.W	(A3)+1,D2	; <xx>	SWAP.W	D2	SUB.W	D2,(A6)+OPLANAV+OMINY	LOAD.W	(A3)+3,D2	; <yy>	LOAD.L	D3,#1+4	LIB	?STRING		; donne l'ordre de remplir	JUMP',NE 50$		; si erreur => 50$	LOAD.L	A4,(A6)+OPLANAV+OPDDIS	; A4 <-- ^descripteur de la fentre	LOAD.L	A4,(A4)+ODFFIP	; A4 <-- ^table des surfaces	CALL	CREFILL		; cre trames rectangulaires50$:	PUSH.W	D7	LOAD.B	D3,#DRAWFILLC	LIB	?AFCAR		; libre la mmoire	PUSH.W	D5	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	POP.W	D5	LIB	?KILWDO		; dtruit swdo temporaire	TEST.B	(A6)+OPLANAV+OFLAGS:#BGRILLE	JUMP',BC 60$	CALL	GRILLE		; refait la grille60$:	CALL	IRETICULE	; remet le rticule si ncessaire	POP.W	D7	JUMP',EQ 80$	LOAD.W	D4,#ERFIT	; D4 <-- y'a un trou	COMP.W	D7,#ERDIOUT	JUMP',EQ 70$	LOAD.W	D4,#ERFIM	; D4 <-- trop compliqu	COMP.W	D7,#ERNEMEM	JUMP',EQ 70$	LOAD.W	D4,D7		; D4 <-- autre erreur70$:	LOAD.W	D7,D4		; D7 <-- no erreur	JUMP	DFERROR		; affiche l'erreur80$:	CALL	INIHAUT	; refait le haut de la fentreCALL	AFMENU	JUMP	LOOPDOSTOCK:	LOAD.W	D7,#ERPBN	; D7 <-- "bloc-notes vide"	LOAD.L	D3,(A6)+OSTKP1	LOAD.L	D4,(A6)+OSTKP2	JUMP,EQ	DFERROR	TSET.B	(A6)+OFLAGF:#BMPDES	CLR.W	(A6)+OMOVOP	; attend bouton relach	CALL	MOVZONE		; dplace zone rectangulaire;;;	CALL	DUPLIFIE	; duplifie une surface	LOAD.B	D5,#2	.W	PLANA_OPER; 5.06	CALL	WAITMOUSE	; attend bouton(s) relch(s);	CALL	INIHAUT	; refait le haut de la fentreCALL	AFMENU	JUMP	LOOP;------------- DOMENUMACRO:			; menu MACRO;-------------	TEST.W	(A6)+OMMACRO	JUMP,NS	DOMENU	LOAD.L	A3,#R16"MMACRO	LOAD.L	D3,#0		; D3 <-- choix initial	LOAD.W	D3,(A6)+OMMACRO	JUMP,ZS	10$	INC.W	D3	SUB.L	D3,#'010$:	LIB	?MMENU	DEC.B	D3	JUMP,NS	DOMEXIT	ADD.W	D3,#'0	LOAD.W	D2,D3		; D2 <-- no. MACRO en ASCII svp.	JUMP	DOMSHOW;********; DOMENU:	cf. PLANMMENU;********;***********; DOMODIFIE:	cf. PLANMMENU;***********; Processus de dessin lors des modifications; ------------------------------------------NFILS2:	.ASCIZ	/PLAN_DESSIN/	; nom du processus fils	.EVENPFILS2:	TCLR.B	(A6)+OFLAGF:#BEPDES ; pas encore dernier tour	CLR.L	D6		; D6 <-- offset de dpart	LOAD.L	D3,(A6)+ORIZO1	; D3 <-- coin zone de dpart	LOAD.L	D4,(A6)+ORIZO2	; D4 <-- coin zone de dpart;;;	CALL	ORDONNELOAD.L	A5,#(A6)+OPLANAV.W	PLANA_ORDONNE	LOAD.W	D2,#-1		; D2 <-- tout  effacer	TEST.B	(A6)+OFLAGF:#BMPDES ; dplace/duplifie ?	JUMP',BC 05$		; dplace => 05$	CLR.W	D2		; D2 <-- rien  effacer05$:	CALL	WSIGNAL		; attend un signal ...	JUMP	35$; Dessine tous les objets possibles jusqu' la rception; d'un signal.10$:	CLR.W	D2		; D2 <-- nb objets dessins	LOAD.L	D6,(A6)+OFFSET	; D6 <-- offset +/-	LOAD.L	D3,(A6)+ORIZO1	; D3 <-- coin zone de dpart	LOAD.L	D4,(A6)+ORIZO2	; D4 <-- coin zone de dpart;;;	CALL	ORDONNELOAD.L	A5,#(A6)+OPLANAV.W	PLANA_ORDONNE;;;	CALL	FIRBASE		; A4 <-- ^premier lmentLOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE.W	PLANA_BASE	JUMP',NE 30$20$:LOAD.L	A5,#(A6)+OPLANAV;;;	CALL	DETECTE		; dans zone de recherche ?LOAD.W	(A6)+OPLANAV+OPLANA,#BDETECTE.W	PLANA_BASE	JUMP',NE 25$		; non => 25$				; oui =>	TEST.B	(A6)+OFLAGF:#BEPDES ; dernier tour ?	JUMP',BS 22$		; oui => 22$	CALL	IFSIGNAL	; reu un signal ?	JUMP',EQ 35$		; oui => 35$22$:				; non =>	LOAD.L	A5,(A6)+OPSEMA	NTREL	?LOCK		; dbut zone d'exclusion;;;PLANA A5	PUSHM.L	D0,D1,D2,D3,D4LOAD.L	A5,#(A6)+OPLANAV;;;	CALL	PREND		; registres <-- objetLOAD.W	(A6)+OPLANAV+OPLANA,#BPREND.W	PLANA_BASE;;;	CALL	AJUSTE		; ajuste selon l'offsetLOAD.W	(A6)+OPLANAV+OPLANA,#FAJUSTE.W	PLANA_FONC;;;	CALL	DESSINE		; dessine nouvel objet.W	PLANA_DESSINE	POPM.L	D0,D1,D2,D3,D4;;;PLANA A5	LOAD.L	A5,(A6)+OPSEMA	NTREL	?UNLOCK		; fin zone d'exclusion	INC.W	D2		; D2 <-- un objet de plus25$:;;;	CALL	NXTBASE		; A4 <-- ^lment suivantLOAD.L	A5,#(A6)+OPLANAVLOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE.W	PLANA_BASE	JUMP,EQ	20$30$:	TEST.B	(A6)+OFLAGF:#BEPDES ; dernier tour ?	JUMP,BS	90$		; oui => c'est fini	LOAD.W	D2,#-1		; D2 <-- tout est dessin	CALL	WSIGNAL		; attend un signal ...; Efface tous les objets dessins.35$:	TEST.B	(A6)+OFLAGF:#BAPDES ; fin du processus ?	JUMP,BS	60$		; oui => 60$38$:;;;	CALL	FIRBASE		; A4 <-- ^premier lmentLOAD.L	A5,#(A6)+OPLANAVLOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE.W	PLANA_BASE	JUMP',NE 50$40$:LOAD.L	A5,#(A6)+OPLANAV;;;	CALL	DETECTE		; dans zone de recherche ?LOAD.W	(A6)+OPLANAV+OPLANA,#BDETECTE.W	PLANA_BASE	JUMP',NE 45$		; non => 45$				; oui =>	TEST.W	D2		; encore un objet  effacer ?	JUMP',EQ 50$		; non => 50$				; oui =>	LOAD.L	A5,(A6)+OPSEMA	NTREL	?LOCK		; dbut zone d'exclusion;;;PLANA A5	PUSHM.L	D0,D1,D2,D3,D4LOAD.L	A5,#(A6)+OPLANAV;;;	CALL	PREND		; registres <-- objetLOAD.W	(A6)+OPLANAV+OPLANA,#BPREND.W	PLANA_BASE;;;	CALL	AJUSTE		; ajuste selon l'offsetLOAD.W	(A6)+OPLANAV+OPLANA,#FAJUSTE.W	PLANA_FONC	CALL	INVMODE		; mode inverse;;;	CALL	DESSINE		; efface l'objet.W	PLANA_DESSINE	POPM.L	D0,D1,D2,D3,D4;;;PLANA A5	LOAD.L	A5,(A6)+OPSEMA	NTREL	?UNLOCK		; fin zone d'exclusion	DEC.W	D2		; D2 <-- un objet de moins45$:;;;	CALL	NXTBASE		; A4 <-- ^lment suivantLOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASELOAD.L	A5,#(A6)+OPLANAV.W	PLANA_BASE	JUMP,EQ	40$50$:	JUMP	10$; Termine le dessin pour que tout soit  jour correctement.60$:	TSET.B	(A6)+OFLAGF:#BEPDES ; une dernire fois !	COMP.L	D6,(A6)+OFFSET	; dessin avec le bon offset ?	JUMP,NE	38$		; non => efface puis dessine	COMP.W	D2,#-1		; tout est dessin ?	JUMP,NE	22$		; non => termine dessin90$:	NTREL	?ABORT		; c'est fini ...;---------\; IFSIGNAL >;=========/; Test sans attendre si le pre  fait un signal.; in	-; out	EQ	reu signal du pre;	NE	rien reu (timeout); mod	D7.W, A5.LIFSIGNAL:	PUSH.L	D4	CLR.W	D4	NTREL	?SETTIM		; init timeout nul	CALL	WSIGNAL	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\; WSIGNAL >;========/; Attend un signal du pre.; in	-; out	D7.W	erreur (timeout); mod	D7.WWSIGNAL:	PUSH.L	A5	LOAD.L	A5,(A6)+OPSEMS	; A5 <-- ^smaphore de synchro	NTREL	?WAITEV		; attend ...	POP.L	A5	RET;--------\; RARC8   >;========/; Calcul le rayon d'un cercle et les arcs  dessiner.; in	D4.L	coordonne de la flche; out	D3.L	rayon (0..n) et arc; mod	D3.L, D7.WRARC8:	PUSHM.L	D0,D1,D2,D4,D5,A0	LOAD.B	D0,#B'11111111	; D0 <-- cercle complet	LOAD.B	D1,#B'11000011	; D1 <-- demi-cercle droite	SUB.W	D4,(A6)+ORIPOS+OXX	JUMP',GE 10$	NOT.B	D1		; D1 <-- demi-cercle gauche	NEG.W	D410$:	AND.B	D0,D1		; D0 <-- reste 4 arcs	LOAD.L	D5,D4	SWAP.W	D5	LOAD.B	D1,#B'00001111	; D1 <-- demi-cercle inf.	SUB.W	D5,(A6)+ORIPOS+OYY	JUMP',GE 20$	NOT.B	D1		; D1 <-- demi-cercle sup.	NEG.W	D520$:	AND.B	D0,D1		; D0 <-- reste 2 arcs	LOAD.B	D1,#B'10011001	; D1 <-- arcs touchant axe X	COMP.W	D4,D5		; dX > dY ?	JUMP',HS 30$		; oui => 30$	NOT.B	D1		; D1 <-- arcs touchant axe Y30$:	AND.B	D0,D1		; D0 <-- reste 1 seul arc	LOAD.B	D1,D0		; D1 <-- un seul arc	LOAD.W	D2,(A6)+OARC	; D2 <-- type d'arcs	LOAD.L	A0,#R16"01$	TEST.B	D2		; tout ?	JUMP',EQ 40$	LOAD.L	A0,#R16"02$	COMP.B	D2,#1		; 1/2 ?	JUMP',EQ 40$	LOAD.L	A0,#R16"03$	COMP.B	D2,#2		; 1/4 ?	JUMP',NE 50$40$:	TEST.L	D1:#0		; arc trouv ?	JUMP',BS 45$		; oui => 45$	SR.B	D1,#1		; non =>	INC.L	A0		; A0 <-- ^arc  ajouter suivant	JUMP	40$45$:	OR.B	D0,(A0)		; D0 <-- ajoute d'autres arcs50$:	COMP.W	D5,D4		; dy > dx ?	JUMP',HS 55$		; oui => 55$	LOAD.W	D5,D4		; non => prend le plus grand55$:	TEST.L	D0:#2	JUMP',BS 61$	TEST.L	D0:#3	JUMP',BS 61$	TEST.L	D0:#4	JUMP',BS 61$	TEST.L	D0:#5	JUMP',BC 62$61$:	LOAD.W	D4,(A6)+ORIPOS+OXX	COMP.W	D4,D5		; cercle dpasse  gauche ?	JUMP',GE 62$		; non => 62$	LOAD.W	D5,(A6)+ORIPOS+OXX	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit62$:	TEST.L	D0:#6	JUMP',BS 63$	TEST.L	D0:#7	JUMP',BS 63$	TEST.L	D0:#0	JUMP',BS 63$	TEST.L	D0:#1	JUMP',BC 64$63$:	LOAD.W	D4,(A6)+ORIPOS+OXX	ADD.W	D4,D5		; D4 <-- avance rayon	COMP.W	D4,(A6)+OPLANAV+OMWDOX	; cercle dpasse  droite ?	JUMP',LT 64$		; non => 64$	LOAD.W	D5,(A6)+OPLANAV+OMWDOX	SUB.W	D5,(A6)+ORIPOS+OXX	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit64$:	TEST.L	D0:#4	JUMP',BS 65$	TEST.L	D0:#5	JUMP',BS 65$	TEST.L	D0:#6	JUMP',BS 65$	TEST.L	D0:#7	JUMP',BC 66$65$:	LOAD.W	D4,(A6)+ORIPOS+OYY	COMP.W	D4,D5		; cercle dpasse en haut ?	JUMP',GE 66$		; non => 66$	LOAD.W	D5,(A6)+ORIPOS+OYY	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit66$:	TEST.L	D0:#0	JUMP',BS 67$	TEST.L	D0:#1	JUMP',BS 67$	TEST.L	D0:#2	JUMP',BS 67$	TEST.L	D0:#3	JUMP',BC 68$67$:	LOAD.W	D4,(A6)+ORIPOS+OYY	ADD.W	D4,D5		; D4 <-- avance rayon	COMP.W	D4,(A6)+OPLANAV+OMWDOY	; cercle dpasse en bas ?	JUMP',LT 68$		; non => 68$	LOAD.W	D5,(A6)+OPLANAV+OMWDOY	SUB.W	D5,(A6)+ORIPOS+OYY	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit68$:	LOAD.W	D3,D0		; D3 <-- arc	SWAP.W	D3	LOAD.W	D3,D5		; D3 <-- rayon	POPM.L	D0,D1,D2,D4,D5,A0	RET01$:				; tout le cercle	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'1111111102$:				; 1/2 cercle	.B	B'11000011	.B	B'00001111	.B	B'00001111	.B	B'00111100	.B	B'00111100	.B	B'11110000	.B	B'11110000	.B	B'1100001103$:				; 1/4 cercle	.B	B'00000011	.B	B'00000011	.B	B'00001100	.B	B'00001100	.B	B'00110000	.B	B'00110000	.B	B'11000000	.B	B'11000000	.EVEN;---------\; RARCELL  >;=========/; Calcul les rayons X et Y d'une ellipse  dessiner.; in	D4.L	coordonne de la flche; out	D3.L	rayons (Y;X);	D0.W	objet / arcs; mod	D0.W, D3.L, D7.WRARCELL:	PUSHM.L	D1,D2,D4,D5,A0	LOAD.B	D0,#B'11111111	; D0 <-- ellipse complte	LOAD.B	D1,#B'11000011	; D1 <-- demi-ellipse droite	SUB.W	D4,(A6)+ORIPOS+OXX	JUMP',GE 10$	NOT.B	D1		; D1 <-- demi-ellipse gauche	NEG.W	D410$:	AND.B	D0,D1		; D0 <-- reste 4 arcs	LOAD.L	D5,D4	SWAP.W	D5	LOAD.B	D1,#B'00001111	; D1 <-- demi-ellipse inf.	SUB.W	D5,(A6)+ORIPOS+OYY	JUMP',GE 20$	NOT.B	D1		; D1 <-- demi-ellipse sup.	NEG.W	D520$:	AND.B	D0,D1		; D0 <-- reste 2 arcs	LOAD.B	D1,#B'10011001	; D1 <-- arcs touchant axe X	COMP.W	D4,D5		; dX > dY ?	JUMP',HS 30$		; oui => 30$	NOT.B	D1		; D1 <-- arcs touchant axe Y30$:	AND.B	D0,D1		; D0 <-- reste 1 seul arc	LOAD.B	D1,D0		; D1 <-- un seul arc	LOAD.W	D2,(A6)+OARC	; D2 <-- type d'arcs	LOAD.L	A0,#R16"01$	TEST.B	D2		; tout ?	JUMP',EQ 40$	LOAD.L	A0,#R16"02$	COMP.B	D2,#1		; 1/2 ?	JUMP',EQ 40$	LOAD.L	A0,#R16"03$	COMP.B	D2,#2		; 1/4 ?	JUMP',NE 50$40$:	TEST.L	D1:#0		; arc trouv ?	JUMP',BS 45$		; oui => 45$	SR.B	D1,#1		; non =>	INC.L	A0		; A0 <-- ^arc  ajouter suivant	JUMP	40$45$:	OR.B	D0,(A0)		; D0 <-- ajoute d'autres arcs50$:	TEST.L	D0:#2	JUMP',BS 61$	TEST.L	D0:#3	JUMP',BS 61$	TEST.L	D0:#4	JUMP',BS 61$	TEST.L	D0:#5	JUMP',BC 62$61$:	LOAD.W	D2,(A6)+ORIPOS+OXX	COMP.W	D2,D4		; ellipse dpasse  gauche ?	JUMP',GE 62$		; non => 62$	LOAD.W	D4,(A6)+ORIPOS+OXX	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit62$:	TEST.L	D0:#6	JUMP',BS 63$	TEST.L	D0:#7	JUMP',BS 63$	TEST.L	D0:#0	JUMP',BS 63$	TEST.L	D0:#1	JUMP',BC 64$63$:	LOAD.W	D2,(A6)+ORIPOS+OXX	ADD.W	D2,D4		; D2 <-- avance rayon	COMP.W	D2,(A6)+OPLANAV+OMWDOX	; ellipse dpasse  droite ?	JUMP',LT 64$		; non => 64$	LOAD.W	D4,(A6)+OPLANAV+OMWDOX	SUB.W	D4,(A6)+ORIPOS+OXX	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit64$:	TEST.L	D0:#4	JUMP',BS 65$	TEST.L	D0:#5	JUMP',BS 65$	TEST.L	D0:#6	JUMP',BS 65$	TEST.L	D0:#7	JUMP',BC 66$65$:	LOAD.W	D2,(A6)+ORIPOS+OYY	COMP.W	D2,D5		; ellipse dpasse en haut ?	JUMP',GE 66$		; non => 66$	LOAD.W	D5,(A6)+ORIPOS+OYY	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit66$:	TEST.L	D0:#0	JUMP',BS 67$	TEST.L	D0:#1	JUMP',BS 67$	TEST.L	D0:#2	JUMP',BS 67$	TEST.L	D0:#3	JUMP',BC 68$67$:	LOAD.W	D2,(A6)+ORIPOS+OYY	ADD.W	D2,D5		; D2 <-- avance rayon	COMP.W	D2,(A6)+OPLANAV+OMWDOY	; ellipse dpasse en bas ?	JUMP',LT 68$		; non => 68$	LOAD.W	D5,(A6)+OPLANAV+OMWDOY	SUB.W	D5,(A6)+ORIPOS+OYY	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit68$:	SL.W	D0,#8		; D0 <-- arcs	LOAD.B	D0,#OBJARCELL	; D0 <-- objet	LOAD.W	D3,D5		; D3 <-- rayon Y	SWAP.W	D3	LOAD.W	D3,D4		; D3 <-- rayon X	POPM.L	D1,D2,D4,D5,A0	RET01$:				; toute l'ellipse	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'1111111102$:				; 1/2 ellipse	.B	B'00001111	.B	B'00001111	.B	B'00111100	.B	B'00111100	.B	B'11110000	.B	B'11110000	.B	B'11000011	.B	B'1100001103$:				; 1/4 ellipse	.B	B'00000011	.B	B'00000011	.B	B'00001100	.B	B'00001100	.B	B'00110000	.B	B'00110000	.B	B'11000000	.B	B'11000000	.EVEN;---------\; RELLIPSE >;=========/; Calcul les rayons X et Y d'une ellipse  dessiner.; in	D4.L	coordonne de la flche; out	D3.L	rayons (Y;X); mod	D3.L, D7.WRELLIPSE:	PUSHM.L	D0,D1,D2	LOAD.W	D0,D4		; D0 <-- coordonne x	SUB.W	D0,(A6)+ORIPOS+OXX	JUMP',GE 10$	NEG.W	D0		; D0 <-- rayon x10$:	LOAD.L	D1,D4	SWAP.W	D1		; D1 <-- coordonne y	SUB.W	D1,(A6)+ORIPOS+OYY	JUMP',GE 20$	NEG.W	D1		; D1 <-- rayon y20$:	COMP.W	D0,(A6)+ORIPOS+OXX ; ellipse dpasse  gauche ?	JUMP',LT 62$		; non => 62$	LOAD.W	D0,(A6)+ORIPOS+OXX	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit62$:	LOAD.W	D2,(A6)+ORIPOS+OXX	ADD.W	D2,D0		; D2 <-- avance rayon x	COMP.W	D2,(A6)+OPLANAV+OMWDOX	; ellipse dpasse  droite ?	JUMP',LT 64$		; non => 64$	LOAD.W	D0,(A6)+OPLANAV+OMWDOX	SUB.W	D0,(A6)+ORIPOS+OXX	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit64$:	COMP.W	D1,(A6)+ORIPOS+OYY ; ellipse dpasse en haut ?	JUMP',LT 66$		; non => 66$	LOAD.W	D1,(A6)+ORIPOS+OYY	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit66$:	LOAD.W	D2,(A6)+ORIPOS+OYY	ADD.W	D2,D1		; D2 <-- avance rayon y	COMP.W	D2,(A6)+OPLANAV+OMWDOY	; ellipse dpasse en bas ?	JUMP',LT 68$		; non => 68$	LOAD.W	D1,(A6)+OPLANAV+OMWDOY	SUB.W	D1,(A6)+ORIPOS+OYY	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit68$:	LOAD.W	D3,D1		; D3 <-- rayon y	SWAP.W	D3	LOAD.W	D3,D0		; D3 <-- rayon x	POPM.L	D0,D1,D2	RET.IF	ROLLWDO;;;; OPWDOG, CLOWDOG et WRDIS existent aussi dans PLANA.LIB !!!;--------\\; OPWDOG  >;========/;; Utilise la swdo graphique.;; in	-; out	-; mod	D7.WOPWDOG:	PUSHM.L	D3,A3	TEST.W	(A6)+OPLANAV+ONWDOG	JUMP',NE 50$	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE+1	LOAD.B	(A3)+0,#DIMWDO	LOAD.W	(A3)+1,(A6)+OPLANAV+OMINX	LOAD.W	(A3)+3,(A6)+OPLANAV+OMINY	LOAD.W	(A3)+5,(A6)+OPLANAV+OLWDOXINC.W	(A3)+5; essai	LOAD.W	(A3)+7,(A6)+OPLANAV+OLWDOY;;?	INC.W	(A3)+7	LOAD.W	D3,#9	CALL	WRDIS		; dimensionne la swdo graphique50$:	INC.W	(A6)+OPLANAV+ONWDOG	POPM.L	D3,A3	RET;--------\\; CLWDOG  >;========/;; Libre la swdo graphique.;; in	-; out	-; mod	D7.WCLWDOG:	PUSHM.L	D3,A3	DEC.W	(A6)+OPLANAV+ONWDOG	JUMP',NE 90$	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE+1	LOAD.B	(A3)+0,#DIMWDO	CLR.L	(A3)+1	LOAD.W	(A3)+5,(A6)+OPLANAV+OWDOX	LOAD.W	(A3)+7,(A6)+OPLANAV+OWDOY	LOAD.W	D3,#9	CALL	WRDIS		; remet la swdo globale90$:	POPM.L	D3,A3	RET;--------\; WRDIS   >;========/; Envoye qq bytes  l'cran, rapidement.; in	A3.L	^bytes  envoyer;	D3.W	nombre;	A5.L	^variables PLANA; out	-; mod	D7.WWRDIS:	PUSHM.L	D2,D5,A1,A4	LOAD.L	A4,A3		; A4 <-- ^bytes	CLR.L	D5	LOAD.W	D5,D3		; D5 <-- longueur	LOAD.W	D2,(A6)+OPLANAV+ONODIS	; D2 <-- no driver cran	LOAD.L	A1,#0		; A1 <-- pas de liste de term.	BIOS	?DWRITE	POPM.L	D2,D5,A1,A4	RET.ENDIF	.END