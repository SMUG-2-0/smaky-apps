	.SBTTL	PLANPITRGC		; 13 septembre 87 Sp.;--------\\; AFTPEN  >;--------/; Affiche un trait horizontal avec le pinceau.; in	D3.L	coordonne (y;x) dans l'cran;	D4.L	longueur (dx);	D2.W	numro du pinceau;	D1.W	mode; out	-; mod	D7.WAFTPEN:	PUSHM.L	D2,D3,D4,A4	LOAD.L	A4,#(A6)+OPLANAV+OBUPEN	; A4 <-- ^pinceaux	MUL.WU	D2,#8+2	ADD.L	A4,D2		; A4 <-- ^le bon pinceau;;;	CALL	DEFTRAIT	; dfinit le type de trait	LOAD.W	(A6)+OPLANAV+OPLANA,#FDEFTRAIT	.W	PLANA_FONC	SWAP.W	D3	LOAD.W	D2,(A6)+OPLANAV+OCAR1Y	SR.W	D2,#1		; D2 <-- petite correction	SUB.W	D3,D2		; D3 <-- remonte un peu Y	SWAP.W	D3	AND.L	D4,#H'FFFF	; D4 <-- dy=0	LOAD.W	D2,D1		; D2 <-- mode	LIB	?DRSEG		; affiche un trait	POPM.L	D2,D3,D4,A4	RET;--------\\; AFTRAME >;--------/; Affiche la trame dans la ligne en bas de l'cran.; in	-; out	-; mod	D7.WAFTRAME:	PUSHM.L	D1,D2,D3,D4,A3	LOAD.B	D3,#TRAME	LIB	?AFCAR	LOAD.L	A3,#(A6)+OPLANAV+OBUTRA	; A3 <-- ^trames	LOAD.W	D3,(A6)+OTRAME	MUL.WU	D3,#8	ADD.L	A3,D3		; A3 <-- ^la bonne trame	LOAD.W	D3,#8	LIB	?STRING		; dfinit la trame	LIB	?GETCURS	; D3 <-- position actuelle	LIB	?AFTIM	.ASCIZ	"      "	; 6x espaces pour effacer	.EVEN	LOAD.L	D1,D3	SWAP.W	D3	SUB.W	D3,(A6)+OPLANAV+OCAR1Y	INC.W	D3		; D3 <-- laisse marge suprieure	SWAP.W	D3	LOAD.W	D4,(A6)+OPLANAV+OCARX	MUL.WU	D4,#6		; D4 <-- longueur; modif 4.7	COMP.W	(A6)+OOBJET,#OBJFILL	; v. dduire car. 'remplit'	JUMP,NE	10$	SUB.W	D4,#20.10$:; Sp.	ADD.W	D1,D4	SWAP.W	D4	LOAD.W	D4,(A6)+OPLANAV+OCARY	; D4 <-- hauteur	SUB.W	D4,#2		; D4 <-- laisse marge infrieure	SWAP.W	D4	LOAD.W	D2,#INVDOT	; D2 <-- mode	LIB	?DRMATRIX	; inverse qq points	LOAD.L	D3,D1	LIB	?SETCURS	; positionne aprs	POPM.L	D1,D2,D3,D4,A3	RET;--------\\; AFTRAIT >;========/; Affiche le type de trait utilis.; in	D3.W	type du trait; out	-; mod	D7.WAFTRAIT:	PUSHM.L	D1,D2,D3,D4,A3	COMP.B	D3,#3		; trait spcial ?	JUMP',HS 50$		; oui => 50$				; non =>	LIB	?AFTIM;;	.ASCIZ	/  Epaisseur=/	.ASCIZ	/ |  /	.EVEN	LOAD.L	A3,#R16"MTRAIT	INC.B	D3		; D3 <-- saute la case vide	CALL	_AFNTEXT	; affiche le trait	JUMP'	90$50$:	LIB	?AFTIM;;	.ASCIZ	/  Pinceau=/	.ASCIZ	/ | /	.EVEN	LOAD.W	D2,D3	SR.W	D2,#2		; D2 <-- numro du pinceau	LIB	?GETCURS	; D3 <-- coordonne actuelle	LIB	?AFTIM	.B	MSPACE,1+5+1,0	; efface trait prcdent	.EVEN	LOAD.W	D4,(A6)+OPLANAV+OCARX	ADD.W	D3,D4		; D3 <-- laisse un blanc devant	MUL.WU	D4,#5		; D4 <-- largeur de 5 caractres	LOAD.W	D1,#INVDOT!PENDOT!TTTDOT	CALL	AFTPEN		; affiche trait avec pinceau90$:	POPM.L	D1,D2,D3,D4,A3	RET;;;;;;;;; GENC;;;;;;;;;--------\; AFFGC   >;========/; Affiche le gnrateur utilis.; in	-; out	-; mod	D7.WAFFGC:	PUSHM.L	A0,A3	CALL	GETPGC		; A0 <-- ^gencar	LOAD.L	A3,#R16"TGCDEF	; A3 <-- ^ texte par dfaut	TEST.B	(A0)+OGCFLG:#BGCUSE	; utilis ?	JUMP',BC 20$		; non => 20$				; oui	LOAD.L	A3,#(A0)+OGCTIT	; A3 <-- ^titre du gencar20$:	LIB	?AFTEXT		; affiche le titre	POPM.L	A0,A3	RETTGCDEF:	.ASCIZE	"???";--------\; USEDGC  >;========/; Utilise le gencar. par dfaut.; in	-; out	-; mod	-USEDGC:	PUSHM.L	D3,D7,A3	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE+1	LOAD.B	(A3)+0,#USEGC	; <usegc>	LOAD.L	(A3)+1,(A6)+OPLANAV+ODEFGC ; gencar par dfaut	LOAD.W	D3,#1+3		; D3 <-- longueur	LIB	?STRING		; crit tout a	POPM.L	D3,D7,A3	RET;--------\\; GETPGC  >;========/; Donne le ^au gencar choisi dans le buffer des gencars.; in	-; out	A0.L	^gencar; mod	A0.LGETPGC:	PUSH.L	D0	LOAD.L	A0,#(A6)+OPLANAV+OBUGC	LOAD.W	D0,(A6)+OTEXTE	MUL.WU	D0,#LGGC	ADD.L	A0,D0	POP.L	D0	RET;--------- KILLGCAJ:;=========;; Teste les genc 'ajouts' et supprime si pas utiliss;; in	BGCAJ=1 de OGCFLG si genc 'ajout'; out	OBUGC ne contient que les genc utiliss; mod	D7.W	PUSHM.L	D0,D2,D4,A2,A3,A4	LOAD.L	A4,#(A6)+OPLANAV+OBUGC	; A4 <-- ^buffer des gencars	LOAD.W	D0,#MAXGC	CLR.W	D7		; D7 <-- ok10$:	TEST.B	(A4)+OGCFLG:#BGCAJ ; gencar 'ajout' ?	JUMP',BC 30$		; non => 30$				; oui =>	TCLR.B	(A4)+OGCFLG:#BGCAJ	LOAD.L	D2,(A4)+OGCCOD				; ne dtruit pas les genc utilis par PLAN	COMP.L	D2,#GCPAF*H'10000+GCPAS*H'100+GCPAT	JUMP,EQ	29$	COMP.L	D2,#GCICF*H'10000+GCICS*H'100+GCICT	JUMP,EQ	29$	COMP.L	D2,#GCTXF*H'10000+GCTXS*H'100+GCTXT	JUMP,EQ	29$	SL.L	D2,#8		; D2 <-- "fst-"	CALL	TSTGCAJ		; genc 'ajout' utilis ?	JUMP',EQ 30$		; oui, utilis20$:				; non, efface	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A2,(A6)+OPLANAV+OPDDIS	LOAD.L	A3,#(A6)+OPLANAV+OBUGC	DGENC_	KILL;	JUMP',NE 90$29$:	TCLR.B	(A4)+OGCFLG:#BGCUSE	; non, signal genc libre;	JUMP'	30$30$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^suivant	DEC.W	D0	JUMP,NE	10$90$:	POPM.L	D0,D2,D4,A2,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------- TSTGCAJ:;--------;; Teste si genc utilis ds. base.;; in	D2.L	gencars  tester "fst-"; out	-; mod	D7.W	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	LOAD.L	D6,D2		; D6 <-- "fstx"  modifier	CLR.B	D6		; D6 <-- "fst-"  modifier;;;	CALL	FIRBASE		; A4 <-- ^premier lmentLOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE.W	PLANA_BASE	JUMP,NE	90$10$:	LOAD.L	A3,A4		; A3 <-- ^lment actuel;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	EX.L	A3,A4		; A4 <-- ^act, A3 <-- ^suivant	PUSH.W	D7;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	COMP.B	D0,#OBJTEXT	; caractre ?	JUMP',NE 50$		; non => 50$	LOAD.L	D5,D3	CLR.B	D5	COMP.L	D5,D6		; est-ce le gencar ?	JUMP',NE 50$		; non => 50$				; oui =>	POP.W	D7	CLR.W	D7		; EQ --> trouv	JUMP'	90$50$:	POP.W	D7	LOAD.L	A4,A3		; A4 <-- ^lment suivant	TEST.W	D7	JUMP,EQ	10$;	LOAD.W	D7,#-1		; NE --> pas trouv90$:	POPM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	TEST.W	D7	RET;----------\\; KILLALLGC >;==========/; Dtruit tous les gencars utiliss.; in	-; out	-; mod	D7.WKILLALLGC:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,#(A6)+OPLANAV+OBUGC	; A4 <-- ^buffer des gencars	LOAD.W	D3,#MAXGC10$:	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BC 30$		; non => 30$				; oui =>	TEST.B	(A4)+OGCFLG:#BGCPROT ; gencar protg ?	JUMP',BS 30$		; oui => 30$				; non =>	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OPLANAV+OBUGC	DGENC_	KILL		; libre le gencar30$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^suivant	DEC.W	D3	JUMP,NE	10$	POPM.L	D3,D4,A3,A4	RET;-------- CLBGCAJ:;--------;; efface les bits BGCAJ des genc 'ajouts';; in	BGCAJ=1 de OGCFLG si genc 'ajout'; out	OBUGC ne contient tous les genc; mod	D7.W	PUSHM.L	D0,D2,D4,A2,A3,A4	LOAD.L	A4,#(A6)+OPLANAV+OBUGC	; A4 <-- ^buffer des gencars	LOAD.W	D0,#MAXGC	CLR.W	D7		; D7 <-- ok10$:	TEST.B	(A4)+OGCFLG:#BGCAJ ; gencar 'ajout' ?	JUMP',BC 30$		; non => 30$				; oui =>	TCLR.B	(A4)+OGCFLG:#BGCAJ30$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^suivant	DEC.W	D0	JUMP,NE	10$90$:	POPM.L	D0,D2,D4,A2,A3,A4	TEST.W	D7		; retour EQ/NE	RET	.END