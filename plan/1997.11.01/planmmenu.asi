	.SBTTL	PLANMMENU		; juin 88 Sp.; DOMODIFIE; DOMENU; ligne du bas;;;;;;;;;;;;;;;;; BOUTON DROITE;;;;;;;;;;;;;;;;;;*********** DOMODIFIE:;***********CALL	AFDMENU	CALL	RELLAST	CALL	CCMO		; enlve flche souris	CALL	CREZONE		; dplace zone rectangulaire	CALL	SCMO		; remet flche souris	PUSHM.L	D3,D4	CALL	IFMOUSE	LOAD.L	D6,D4		; D6 <-- position avant le m-menu	POPM.L	D3,D4	CALL	CLRFILTRE	; pas encore de filtre	clr.l	(a6)+OMMENUR+OMMINA+lmm*0	; dgrise tout05$:	load.l	a4,#(a6)+ommenur	; A4 ^variables mmenu bouton de droite	load.l	a3,#r16"mMODIF	; A3 ^textes mmenu;;	clr.l	(a4)+ommina+lmm*0 ; dgrise tout	clr.l	d5	test.b	(a6)+OPLANAV+OFLAGS:#BMEMCAS	; mmorise ?	jump,bs	06$				; oui	clr.w	(a4)+OMMSEL+lmm*0		; non06$:	LOAD.L	D0,D3		; D0 <-- coordonne coin	LOAD.L	D1,D4		; D1 <-- coordonne coin;;;;	load.l	a4,#(A6)+OMMENUR ; A4 ^variables mmenu;;;;	load.l	a3,#r16"mMODIF	; A3 ^textes mmenu;;;;	clr.l	d5	load.l	(A4)+ommina+lmm*8,#B'100100000 ; polygone, bloc-notes toujours griss !!!	CALL	AFFCOMPTE	; affiche nb d'objets trouvs	JUMP',EQ 10$		; si trouv 1..n => 10$				; si rien trouv =>; un delta 4 environ dtctera l'lment  modifier	test.l	(a6)+OMEMIM	; suite si image prsente ...	jump,eq	07$	load.l	(a4)+ommina+lmm*0,#B'1101111111111110 ; cases grises sauf loupe	load.w	(A4)+ommsel+lmm*0,#13	; sur loupe;	lib	?mmenus;	load.w	d5,(a4)+ommsel+lmm*0;	jump	12$	jump	11$07$:	LOAD.B	D2,#MODINV	; D2 <-- mode inverse	or.b	D2,#H'F0	; sans test visible	CLR.W	D1		; D1 <-- type de trait fin;;;	CALL	_RECTANGLE	; efface ancien rectangle	PUSH.L	D0	LOAD.L	D0,#OBJRECT	.W	PLANA_DESSINE	POP.L	D0	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	90$		; ne fait plus "zone vide", grrr !10$:	or.l	(a4)+ommina+lmm*0,#B'1000000000000000	call	biblio?		; bibliothque ?	jump,ne	11$		; non	test.b	(a6)+OPLANBV+OBFLAGS:#BMODIFIE ; mode 'modification' ?	jump,bc	11$		; non	load.l	(A4)+ommina+lmm*0,#011$:call	ireticulecall	srmo	lib	?mmenus	load.w	d5,(a4)+ommsel+lmm*0call	ireticule12$:	LOAD.L	D3,D0		; D3 <-- coordonne coin	LOAD.L	D4,D1		; D4 <-- coordonne coin	LOAD.B	D2,#MODINV	; D2 <-- mode inverse	or.b	D2,#H'F0		; sans test visible;;;	CALL	_RECTANGLE	; efface ancien rectangle	PUSHM.L	D0,D1	CLR.W	D1		; D1 <-- type de trait fin	LOAD.L	D0,#OBJRECT	.W	PLANA_DESSINE	POPM.L	D0,D1	DEC.B	D5	JUMP,NS 85$	COMP.B	D5,#0		; dtruit ?	JUMP,EQ	40$		; oui => 40$	COMP.B	D5,#1		; dplace ?	JUMP,EQ	50$		; oui => 50$	COMP.B	D5,#2		; duplifie ?	JUMP,EQ	60$		; oui => 60$	COMP.B	D5,#3		; polycopie ?	JUMP,EQ	21$		; oui => 21$	; 1	COMP.B	D5,#4		; aligne ?	JUMP,EQ	41$		; oui => 41$	; 2	COMP.B	D5,#5		; zoom ?	JUMP,EQ	35$		; oui => 35$	; 3	COMP.B	D5,#6		; tourne ?	JUMP,EQ	30$		; oui => 30$	; 4	COMP.B	D5,#7		; miroir ?	JUMP,EQ	32$		; oui => 32$	; 5	COMP.B	D5,#8		; groupe ?	JUMP,EQ	65$		; oui => 65$	; 6	COMP.B	D5,#9		; stocke ?	JUMP,EQ	80$		; oui => 80$	COMP.B	D5,#10		; filtre ?	JUMP,EQ	28$		; oui => 28$	; 7 & 8 .. 13	COMP.B	D5,#11		; modifie ?	JUMP,EQ	70$		; oui => 70$	; 14 & 15 .. 17	COMP.B	D5,#12		; loupe ?	JUMP,EQ	75$		; oui => 75$	COMP.B	D5,#13		; sauve ?	JUMP,EQ	77$		; oui => 77$	COMP.B	D5,#14		; oui => 15$	JUMP,EQ	15$	JUMP	85$15$:				; mise en BIBLIO	CALL	PUSHBIBLIO	JUMP	85$21$:				; POLYCOPIE =>	load.w	d2,(a4)+OMMSEL+lmm*1				; polycopie selon souris	CALL	AFCMES	.ASCII	"polycopie: "	.B	USEGC,GCICF,GCICS,GCICT	.B	7,96,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" 'clic' place |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,97,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" met/enlve PAS |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,98,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZE	" FIN "	EX.L	D4,D6	CALL	PMOUSE		; positionne la souris comme avant MMENU	EX.L	D4,D6	LOAD.L	D5,D3		; D5 <-- coord. coin	LOAD.L	D6,D4		; D6 <-- coord. autre coin	TSET.B	(A6)+OPLANAV+OFLMOD1:#BPOLYC	; flag polycopie pour DUPLIFIE	COMP.B	D2,#1		; choix 2 ?	JUMP,EQ	25$		; oui => quidistant22$:	call	waitmouse	TSET.B	(A6)+OFLAGF:#BMPDES	LOAD.W	(A6)+OMOVOP,#1	; attend bouton gauche press	LOAD.L	D3,D5		; D3 <-- coord. coin 1re slection	LOAD.L	D4,D6		; D4 <-- coord. coin 1re slection	CALL	MOVZONE		; dplace zone rectangulaire				; D3,D4 coord. coin et D0 +/- offset	PUSH.L	D5	LOAD.W	D5,#2;;;	CALL	DUPLIFIE	; duplifie une surface	.W	PLANA_OPER	POP.L	D523$:	LIB	?IFMOUSE	TEST.L	D3:#BMORIGHT	; bouton de droite => fin	JUMP,BS	24$	CALL	RDMOUSE	TEST.L	D3:#BMOLEFT	; gauche relach ?	JUMP,BS	23$	TEST.L	D3:#BMORIGHT	JUMP,BS	24$	JUMP	22$		; replace pour copie suivante19$:	LOAD.L	D3,#BIPLIT	LIB	?BEEP24$:	TCLR.B	(A6)+OPLANAV+OFLMOD1:#BPOLYC	; plus de polycopies	TCLR.B	(A6)+OPLANAV+OFLMOD1:#BDUPDESS	; plus de dessin dans DUPLIFIE;;;	CALL	CLRNEW			; ote les bits BMNEW	LOAD.W	(A6)+OPLANAV+OPLANA,#BCLRNEW	.W	PLANA_BASE	CALL	INIBAS			; refait ligne du bas	JUMP	85$25$:					; POLYCOPIE EQUIDISTANTE =>	call	waitmouse	TSET.B	(A6)+OFLAGF:#BMPDES	LOAD.W	(A6)+OMOVOP,#1	; attend bouton gauche press	LOAD.L	D3,D5		; D3 <-- coord. coin 1re slection	LOAD.L	D4,D6		; D4 <-- coord. coin 1re slection	CALL	MOVZONE		; dplace zone rectangulaire				; D3,D4 coord. coin et d0 +/- offset	CALL	AFCMES	.ASCII	"polycopie: "	.B	USEGC,GCICF,GCICS,GCICT	.B	7,96,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" 'clic': quidistant |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,97,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" inactif |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,98,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZE	" FIN "	LOAD.L	D1,D0		; pour quidistant	CLR.L	D0		; 	"	TSET.B	(A6)+OPLANAV+OFLMOD1:#BDUPDESS	; DUPLIFIE dessine les objets26$:	ADD.W	D0,D1		; ajoute offset  chaque passage	SWAP.W	D0	SWAP.W	D1	ADD.W	D0,D1	SWAP.W	D0	SWAP.W	D1	LOAD.L	D3,D5		; D3 <-- coord. coin 1re slection	LOAD.L	D4,D6		; D4 <-- coord. coin 1re slection;;;	CALL	ORDONNE		; dans les limites de PLAN ?	.W	PLANA_ORDONNE	ADD.W	D3,D0	ADD.W	D4,D0	COMP.W	D3,#0	JUMP,LT	19$	COMP.W	D4,(A6)+OPLANAV+OMWDOX	JUMP,GT	19$	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D0	ADD.W	D4,D0	COMP.W	D3,#0	JUMP,LT	19$	COMP.W	D4,(A6)+OPLANAV+OMWDOY	JUMP,GT	19$	SWAP.W	D0	LOAD.L	D3,D5		; D3 <-- coord. coin 1re slection	LOAD.L	D4,D6		; D4 <-- coord. coin 1re slection	PUSH.L	D5	LOAD.W	D5,#2;;;	CALL	DUPLIFIE	; duplifie une surface	.W	PLANA_OPER	POP.L	D527$:	CALL	RDMOUSE	TEST.L	D3:#BMORIGHT	JUMP,BS	24$	TEST.L	D3:#BMOLEFT	JUMP,BC	27$	JUMP	26$28$:				; FILTRE =>	load.w	d0,(a4)+ommsel+lmm*7	load.l	(a4)+ommina+lmm*0,#B'100000000000	; grise 'filtre' pour suite	clr.w	(a4)+ommsel+lmm*0	comp.w	d0,#2		; accs  la modif des objets avant filtrage ?	jump,ne	fil$		; non, ...	call	objfiltre	; oui, ...	jump	fil1$fil$:	CALL	FILTRE		; filtre les objets en trop ...fil1$:	LOAD.B	D2,#MODINV	; D2 <-- mode inverse	or.b	D2,#H'F0	; sans test visible	CLR.W	D1		; D1 <-- type de trait fin	PUSH.L	D0	LOAD.L	D0,#OBJRECT;;;	CALL	RECTANGLE	; re-dessine rectangle	.W	PLANA_DESSINE	POP.L	D0	PUSHM.L	D3,D4	CALL	IFMOUSE		; souris dans fentre ?	JUMP',EQ 29$		; oui => 28$	CALL	RDMOUSE		; attend souris dans fentre29$:	POPM.L	D3,D4	CALL	AFDMENU		; met le menu dplacementcall	inibas	call	waitmouse	; attend boutons relachs	JUMP	05$30$:				; TOURNE =>	load.w	d0,(a4)+ommsel+lmm*4	COMP.B	D0,#3;	JUMP,HI	90$	JUMP',NE 31$	CALL	DBOXTOURNE	; OMTOUR <-- demande facteur spcial	JUMP,NE 90$31$:	INC.B	D0		; D0 <-- 1..3 ou 4;;;	CALL	TOURNE		; tourne une surface	.W	PLANA_OPER	JUMP,NE	95$		; erreur => 95$	JUMP	90$		; ok => 90$32$:				; MIROIR =>	load.w	d0,(a4)+ommsel+lmm*5;;;	CALL	MIROIR		; reflte une surface	.W	PLANA_OPER	JUMP,NE	95$		; erreur => 95$	JUMP	90$		; ok => 90$35$:				; ZOOM =>	load.w	d0,(a4)+ommsel+lmm*3	COMP.B	D0,#4;	JUMP,HI	90$	JUMP',NE 36$	CALL	DBOXZOOM	; OMZOOM <-- demande facteur spcial	JUMP,NE 90$36$:	INC.B	D0		; D0 <-- 1..4 ou 5	;;;	CALL	ZOOM		; zoom une surface	.W	PLANA_OPER	JUMP,NE	95$		; erreur => 95$	JUMP	90$		; ok => 90$40$:				; DETRUIT =>CALL	CARPLAN;;;	CALL	DETRUIT		; dtruit une surface	.W	PLANA_OPER	JUMP	85$41$:				; ALIGNE =>	load.w	d6,(a4)+ommsel+lmm*2comp.w	d6,#6jump,eq	43$	CALL	WAITMOUSE	; attend boutons relachs	CALL	GALIGNE		; saisie coord. d'alignement	JUMP,NE	42$;;;	CALL	_ALIGNE		; aligne selon coord. saisie	.W	PLANA_OPER42$:	CALL	INIBAS	JUMP	85$43$:				; aligne sur le PAS choisi	load.w	d0,#3	call	modifie	jump	85$50$:				; DEPLACE =>	EX.L	D4,D6	CALL	PMOUSE		; positionne la souris comme avant m-menu	EX.L	D4,D6	TCLR.B	(A6)+OFLAGF:#BMPDES	CLR.W	(A6)+OMOVOP	; attend bouton relach	CALL	MOVZONE		; dplace zone rectangulaire;;;	CALL	DEPLACE		; dplace une surface	.W	PLANA_OPER	JUMP	85$60$:				; DUPLIFIE =>	EX.L	D4,D6	CALL	PMOUSE		; positionne la souris comme avant m-menu	EX.L	D4,D6	TSET.B	(A6)+OFLAGF:#BMPDES	CLR.W	(A6)+OMOVOP	; attend bouton relach	CALL	MOVZONE		; dplace zone rectangulaire;;;	CALL	DUPLIFIE	; duplifie une surface	.W	PLANA_OPER	JUMP	85$65$:				; GROUPE =>	load.w	d0,(a4)+ommsel+lmm*6;;;;.IF	GROUPETX;;;;	COMP.B	D0,#5;;;;.ELSE	COMP.B	D0,#4;;;;.ENDIF	JUMP',HS 90$;;;;	SR.B	D0,#1;;;;	JUMP',CS 67$;;;;.IF	GROUPETX;;;;	COMP.B	D0,#2;;;;	JUMP,NE	66$;;;;	CALL	DBOXGRTEXT;;;;66$:;;;;.ENDIF;;;;;;;;;;;;;;;;;;;;;;;.W	PLANA_OPER;;;;;;;;;;;;;;;;;;;;;;;;;;;	CALL	LIE;;;;	JUMP'	90$;;;;67$:;;;;	CALL	DELIE	JUMP	90$70$:				; MODIFIE =>	load.w	d0,(A4)+ommsel+lmm*14	jump,ne	71$	call	modifie	jump	90$71$:	dec.w	d0	call	alterobj	JUMP'	90$75$:				; ECHELLE =>	CALL	MSCALE		; change l'chelle	JUMP'	85$77$:				; SAUVE =>	CALL	SOUTPUT		; sauve une surface	JUMP'	85$80$:				; STOCKE =>	CALL	STOCKE	LOAD.W	(A6)+OOBJET,#OBJSTOCK	CALL	INIBAS;	JUMP	85$85$:	CALL	RDMOUSE		; met/enlve PAS	TEST.B	D3	JUMP,NE	85$	CALL	WAITMOUSE	; attend bouton(s) relach(s) ...90$:	CALL	KCLEAR		; vide le fifo du clavier	CALL	INIHAUT		; mj ligne suprieureCALL	AFMENU	JUMP	LOOP95$:				; erreur =>	CALL	MOERROR	; affiche l'erreur	JUMP	90$;----------- alterobj:;-----------; modifie selon choix;	push.w	(a6)+oobjet	push.w	(a6)+otrait	push.w	(a6)+omode	push.w	(a6)+opas	push.w	(a6)+otrame	push.w	(a6)+otexte	push.w	(a6)+oarc	PUSHM.L	D0,D1,D3,D4	comp.w	d0,#0	jump,ne	1$				; trait	LOAD.W	D1,(A6)+OTRAIT;;;	CALL	DBOXPEN		; attend choix selon DBOX ...	LOAD.W	(A6)+OPLANAV+OPLANA,#FDBPEN	.W	PLANA_FONC	LOAD.W	(A6)+OTRAIT,D1	jump	80$1$:	comp.w	d0,#1		; couleur	jump,ne	2$	load.w	d3,(a4)+ommsel+lmm*15	call	domcoul	jump	80$2$:	comp.w	d0,#2		; mode	jump,ne	3$	load.w	d3,(a4)+ommsel+lmm*16	call	dommodeh	jump	80$3$:	comp.w	d0,#3		; PAS	jump,ne	4$	load.w	(a6)+OPAS,(a4)+ommsel+lmm*17	jump	80$4$:	comp.w	d0,#4		; rigide <--> lastique	jump,eq	80$	comp.w	d0,#5	jump,eq	80$	comp.w	d0,#6	jump,ne	7$				; trame	LOAD.W	(A6)+OOBJET,#OBJSURF	LOAD.W	D1,(A6)+OOBJET	SWAP.W	D1	LOAD.W	D1,(A6)+OTRAME;;;	CALL	DBOXTRAME	; attend choix selon DBOX ...	LOAD.W	(A6)+OPLANAV+OPLANA,#FDBTRAME	.W	PLANA_FONC	TEST.W	D1	JUMP,NS	80$	LOAD.W	(A6)+OTRAME,D1	SWAP.W	D1	LOAD.W	(A6)+OOBJET,D1	jump	80$7$:	comp.w	d0,#7	jump,hi	80$				; texte	call	askgc		; menugc	load.w	(a6)+oobjet,#objtext;	jump	80$80$:	POPM.L	D0,D1,D3,D4	CALL	MODIFIE		; modifie une surface	pop.w	(a6)+oarc	pop.w	(a6)+otexte	pop.w	(a6)+otrame	pop.w	(a6)+opas	pop.w	(a6)+omode	pop.w	(a6)+otrait	pop.w	(a6)+oobjet	ret;------------ objfiltre:;------------; permet de choisir un objet avant filtrage;;	push.w	(a6)+oobjet	; sauve moi tout a ...	push.w	(a6)+ofleche	push.w	(a6)+oarc	push.w	(a6)+orrect	push.w	(A6)+otexte	push.w	(a6)+oarc;	push.w	(a6)+otrame;	push.w	(a6)+otexte;	push.w	(a6)+otrait;	push.w	(a6)+omode	PUSHM.L	D0,D1,D3,D4		; SAUVE COORD. DS. D3mOBJET$:	LOAD.W	d3,(A4)+OMMSEL+LMM*8	JUMP,EQ	mLIGNE$	DEC.W	d3	JUMP,EQ	mDROITE$	DEC.W	d3	JUMP,EQ	mFLE$	DEC.W	d3	JUMP,EQ	mCERCLE$	DEC.W	d3	JUMP,EQ	mRECT$	DEC.W	d3		; cases grises ...;	JUMP,EQ	mPOLY$	DEC.W	D3	JUMP,EQ	mSURF$	DEC.W	D3	JUMP,EQ	mTEXT$;	DEC.W	D3;	JUMP,EQ	mBLOC$	JUMP	dofiltre$mTEXT$:	call	askgc		;menugc	load.w	(a6)+oobjet,#objtext	jump	dofiltre$mSURF$:	LOAD.W	(A6)+OOBJET,#OBJSURF	LOAD.W	D1,(A6)+OOBJET	SWAP.W	D1	LOAD.W	D1,(A6)+OTRAME;;;	CALL	DBOXTRAME	; attend choix selon DBOX ...	LOAD.W	(A6)+OPLANAV+OPLANA,#FDBTRAME	.W	PLANA_FONC	TEST.W	D1	JUMP,NS	dofiltre$	LOAD.W	(A6)+OTRAME,D1	SWAP.W	D1	LOAD.W	(A6)+OOBJET,D1	jump	dofiltre$mFLE$:	call	domfle	jump	dofiltre$mLIGNE$:	LOAD.W	D3,(A4)+OMMSEL+LMM*9	call	domlig	jump	dofiltre$mDROITE$:	LOAD.W	D3,(A4)+OMMSEL+LMM*10	call	domdroi	jump	dofiltre$mCERCLE$:	LOAD.W	D3,(A4)+OMMSEL+LMM*11	call	domcer	jump	dofiltre$mRECT$:	LOAD.W	D3,(A4)+OMMSEL+LMM*12	call	domrect;	jump	dofiltre$dofiltre$:	POPM.L	D0,D1,D3,D4		; restitue coord. ds. D3 et D4	call	waitmouse	call	kclear	dec.w	d0		; fait comme si objet choisi, eh oui	call	filtre;	pop.w	(a6)+omode	; remet moi tout a ...;	pop.w	(a6)+otrait;	pop.w	(a6)+otexte;	pop.w	(a6)+otrame	pop.w	(a6)+oarc	pop.w	(a6)+otexte	pop.w	(a6)+orrect	pop.w	(a6)+oarc	pop.w	(a6)+ofleche	pop.w	(a6)+oobjet	ret;;;;;;;;;;;;;;;;;;;;;;; cliqu ligne du bas;;;;;;;;;;;;;;;;;;;;;;DOMCOULB:			; couleur =>        call	coulmmh			; met bit et slction	load.l	a3,#r16"mcouleur	load.l	a4,#(a6)+OMMENUM+lmm*14 ; mmorisation ds. table	clr.l	d5	LIB	?MMENUS			; choix MMENU	JUMP,NE	domrel	load.w	d3,(a4)+ommsel;;;	JUMP	DOMCOUL	call	domcoul	jump	domrelmcoulmmh:	load.w	d3,(a6)+omode		; met OMMSEL et OMMINA	sr.w	d3,#4	clr.l	d4	tset.l	d4:d3	load.l	(a6)+ommenum+lmm*14+ommina,d4	load.w	(a6)+ommenum+lmm*14+ommsel,d3	retDOMMODE:			; mode =>	call	modemmh	LOAD.L	A3,#R16"mMODEh	load.l	a4,#(a6)+OMMENUM+LMM*15	clr.l	d5	lib	?mmenus	jump,ne	domrel	load.w	d3,(a4)+ommsel;;;	JUMP	DOMMODEH	call	dommodeh	jump	domrelmmodemmh:	load.w	d3,(a6)+omode		; met OMMSEL et OMMINA	and.w	d3,#H'0F	clr.l	d4	tset.l	d4:d3	load.l	(a6)+ommenum+lmm*15+ommina,d4	load.w	(a6)+ommenum+lmm*15+ommsel,d3	retDOMPASB:			; pas =>	call	pasmmh	load.l	a3,#r16"mpas	load.l	a4,#(a6)+ommenum+lmm*6	clr.l	d5	lib	?mmenus	jump,ne	domrel	load.w	d3,(a4)+ommsel	JUMP	DOMPASpasmmh:	load.w	d3,(a6)+opas	clr.l	d4	tset.l	d4:d3	load.l	(a6)+ommenum+lmm*6+ommina,d4	load.w	(a6)+ommenum+lmm*6+ommsel,d3	retDOMLOUPEB:			; chelle =>	call	loupemmh	load.l	a3,#r16"mloupe	load.l	a4,#(a6)+ommenum+lmm*5	clr.l	d5	lib	?mmenus	jump,ne	domrel	load.w	d3,(a4)+ommsel	JUMP	DOLOUPE	loupemmh:	PUSHM.L	D0,D3,D4,A3	load.l	a3,#r16"TASCALE			; met OMMSEL et OMMINA	load.w	d0,(a6)+OPLANAV+OSCALE	clr.l	(a6)+ommenum+lmm*5+ommina	load.w	d3,#-110$:	inc.w	d3	comp.w	d3,#nbtscale	jump,hi	90$	comp.w	d0,(a3+)	jump,ne	10$	clr.l	d4	tset.l	d4:d3	load.l	(a6)+ommenum+lmm*5+ommina,d4	load.w	(a6)+ommenum+lmm*5+ommsel,d390$:	POPM.L	D0,D3,D4,A3	ret;;;;;;;;;;;;;;;;; BOUTON MILIEU;;;;;;;;;;;;;;;;;******** DOMENU:;********	call	coulmmh	call	modemmh	call	loupemmh	call	pasmmh	LOAD.L	A3,#R16"mMILIEU	; A3.L	^m-menus hirarchiques	LOAD.L	A4,#(A6)+OMMENUM ; A4.L	^table pour les paramtres (in+out)	clr.l	d5		; flags (BMSPOSx)	test.b	(a6)+OPLANAV+OFLAGS:#BMEMCAS ; mmorise ?	jump,bs	06$			; oui	clr.l	(a4)+ommsel+lmm*0	; non06$:call	ireticulecall	srmo	LIB	?MMENUS;;	JUMP,NE	DOMRELcall	ireticule	LOAD.W	d3,(A4)+OMMSEL	; D3 <-- choix	JUMP,EQ	DOMREL	DEC.W	D3	JUMP,EQ	mFICH$	DEC.W	D3	JUMP,EQ	mEDIT$	DEC.W	D3	JUMP,EQ	mVU$	DEC.W	D3	JUMP,EQ	mOBJET$	DEC.W	D3	JUMP,EQ	mBIBLI$	DEC.W	D3	JUMP,EQ	mPARA$	DEC.W	D3	JUMP,EQ	mDEF$	JUMP	DOMRELmFICH$:	LOAD.W	D3,(A4)+OMMSEL+LMM*1	JUMP,EQ	DOPREND	DEC.W	D3	JUMP,EQ	DOAJOUTE	DEC.W	D3	JUMP,EQ	DOSAUVE	DEC.W	D3	JUMP,EQ	mIMPR$	DEC.W	D3	JUMP,EQ	DOPLOT	DEC.W	D3	JUMP,EQ	DOIMA	DEC.W	D3	JUMP,EQ	DOEND	JUMP	DOMRELmIMPR$:	LOAD.W	D3,(A4)+OMMSEL+LMM*2	jump,EQ	DOIMPECR	DEC.W	D3	JUMP,EQ	DOIMPDESS	DEC.W	D3	JUMP,EQ	DOIMPLAN	JUMP	DOMRELmEDIT$:	LOAD.W	D3,(A4)+OMMSEL+LMM*3	JUMP,EQ	DODEL	DEC.W	D3	JUMP,EQ	DOUNDO	DEC.W	D3	JUMP,EQ	DOEFFACE	DEC.W	D3	JUMP,EQ	DOHELP	JUMP	DOMRELmVU$:	LOAD.W	D3,(A4)+OMMSEL+LMM*4	JUMP,EQ	DOTOUT	DEC.W	D3	JUMP,EQ	mLOUP$	DEC.W	D3	JUMP,EQ	mPAS$	DEC.W	D3	JUMP,EQ	DOCOULEUR	DEC.W	D3	JUMP,EQ	DOREGLE	DEC.W	D3	JUMP,EQ	DOGRILLE	JUMP	DOMRELmLOUP$:	LOAD.W	D3,(A4)+OMMSEL+LMM*5	JUMP	DOLOUPEmPAS$:	LOAD.W	D3,(A4)+OMMSEL+LMM*6	JUMP	DOMPASmOBJET$:	LOAD.W	D3,(A4)+OMMSEL+LMM*7	JUMP,EQ	mLIGNE$	DEC.W	D3	JUMP,EQ	mDROITE$	DEC.W	D3	JUMP,EQ	mFLE$	DEC.W	D3	JUMP,EQ	mCERCLE$	DEC.W	D3	JUMP,EQ	mRECT$	DEC.W	D3	JUMP,EQ	mPOLY$	DEC.W	D3	JUMP,EQ	mSURF$	DEC.W	D3	JUMP,EQ	DOTEX	DEC.W	D3	JUMP,EQ	mBLOC$	JUMP	DOMRELmFLE$:	call	domfle	jump	domrelmmSURF$:	jump	domsurf;;;;;	call	domsurf;;;;;	jump	domrelmmLIGNE$:	LOAD.W	D3,(A4)+OMMSEL+LMM*8	call	domlig	jump	domrelm;;;	JUMP	DOMLIGmDROITE$:	LOAD.W	D3,(A4)+OMMSEL+LMM*9;;;	JUMP	DOMDROI	call	domdroi	jump	domrelmmCERCLE$:	LOAD.W	D3,(A4)+OMMSEL+LMM*10;;;	JUMP	DOMCER	call	domcer	jump	domrelmmRECT$:	LOAD.W	D3,(A4)+OMMSEL+LMM*11;;;	JUMP	DOMRECT	call	domrect	jump	domrelmmPOLY$:;;;;	LOAD.W	D3,(A4)+OMMSEL+LMM*12;;;	JUMP	DOMPOL	call	dompol	jump	domrelmmBLOC$:	LOAD.W	D3,(A4)+OMMSEL+LMM*13		; plusieurs bloc-notes  venir	JUMP	DOMBLOCmBIBLI$:	JUMP	DOBIBLIOmPARA$:	LOAD.W	D3,(A4)+OMMSEL+LMM*13		;14	JUMP,EQ	mTRAI$	DEC.W	D3	JUMP,EQ	mCOULEUR$	DEC.W	D3	JUMP,EQ	mODEH$	JUMP	DOMRELmTRAI$:	jump	domtraimDEF$:	JUMP	DODEFINEmCOULEUR$:	LOAD.W	D3,(A4)+OMMSEL+LMM*14		;15;;;	JUMP	DOMCOUL	call	domcoul	jump	domrelmmODEH$:	LOAD.W	D3,(A4)+OMMSEL+LMM*15		;16;;;	JUMP	DOMMODEH	call	dommodeh	jump	domrelmmLOUPE$:;	0..6	LOAD.W	D3,(A4)+OMMSEL+LMM*5	jump	DOMREL;...;DOEND:		cf. PLANMAIN;DOIMPPLAN:	cf. PLANMAIN;DOIMPECR:	cf. PLANMAIN;DOIMPDESS:	cf. PLANMAIN;DOREGLE:	cf. PLANMAIN;DOGRILLE:	cf. PLANMAINDOMPAS:	CALL	CHGPAS	JUMP,NE	DOMREF		; redessine tout	CALL	INIBAS	JUMP	DOMRELDOLOUPE:	LOAD.W	D4,(A6)+OPLANAV+OSCALE	; D4 <-- chelle actuelle	CALL	CHGSCALE	; change l'chelle	COMP.W	D4,(A6)+OPLANAV+OSCALE	; chelle change ?	JUMP',EQ DOMREL		; non => DOMRELDOMREF:	CALL	EFFACE		; efface tout	CALL	REFAIT		; puis refait tout proprementDOMREL:	CALL	WAITMOUSE	; attend bouton(s) relach(s) ...DOMEXIT:	CALL	KCLEAR		; vide le fifo du clavier	JUMP	LOOPDOMRELM:	CLR.W	(A6)+OMMACRO	; mise  zro no. macroDOMRELM1:	CALL	INIBAS		; mj la ligne du bas	JUMP	DOMRELDOMCOUL:;	clr.l	d4		; met case grise;	tset.l	d4:d3;	load.l	(a4)+OMMINA+LMM*14,d4;	LOAD.L	A3,#R16"TCOULEUR;	CALL	SMMENU		; D3 <-- mode;	JUMP,NE	DOMEXIT	LOAD.W	D4,(A6)+OMODE	; D4 <-- mode/couleur	AND.B	D4,#H'0F	; D4 <-- mode	SL.B	D3,#4	OR.B	D4,D3		; D4 <-- mode/nouvelle couleur	LOAD.W	(A6)+OMODE,D4;;;	JUMP	DOMRELM	RETDOMTRAI:			; paisseur/pinceau =>	CALL	CWMO		; remet souris normale	CALL	SRMO		; remet la flche	LOAD.W	D1,(A6)+OTRAIT;;;	CALL	DBOXPEN		; attend choix selon DBOX ...	LOAD.W	(A6)+OPLANAV+OPLANA,#FDBPEN	.W	PLANA_FONC	JUMP,NE	10$;	TEST.B	(A6)+OPLANAV+OFLAGS:#BMDBOX;	JUMP,BC	10$	CALL	MAJCADRE	CALL	REFAIT10$:	CALL	AFMENU		; menu standard	CALL	CRMO		; met v. rticule	LOAD.W	(A6)+OTRAIT,D1	COMP.W	(A6)+OTRAIT,#3	JUMP',LO 52$	LOAD.W	D4,(A6)+OMODE	; D4 <-- couleur/mode	AND.B	D4,#H'0F	; D4 <-- mode	COMP.B	D4,#MODINV	; mode inverse ?	JUMP',NE 52$		; non => 52$	LOAD.W	D4,(A6)+OMODE	; D4 <-- couleur/mode	AND.B	D4,#H'F0	; D4 <-- couleur	OR.B	D4,#MODSET	; oui => force le mode ajoute !	LOAD.W	(A6)+OMODE,D452$:	JUMP	DOMRELM;;;	RETDOMMODEH:;	LOAD.L	A3,#R16"TMODE;	CALL	SMMENU		; D3 <-- mode;	JUMP,NE	DOMEXIT	LOAD.W	D4,(A6)+OMODE	; D4 <-- couleur/mode	AND.B	D4,#H'F0	; D4 <-- couleur	OR.B	D4,D3		; D4 <-- couleur/nouveau mode	LOAD.W	(A6)+OMODE,D4;;;	JUMP	DOMRELM	RET;DOTOUT:	cf. PLANMAIN;DOPREND:	.;DOAJOUTE:	.;DOSAUVE:	.;DOPLOT:;DOIMA:;DODEFINE:;DOBIBLIO:;DODEL:;DOUNDO:;DOEFFACE:;DOHELP:;;;;;;;;; choix des OBJETSDOMLIG:	LOAD.L	A3,#R16"TTML	CALL	SMMENU		; D3 <-- type de ligne/spline	JUMP,NE	DOMREL	LOAD.W	(A6)+OOBJET,D3;;;	JUMP	DOMRELM	RETDOMDROI:				; droite =>	LOAD.L	A3,#R16"TDROITE	CALL	SMMENU		; D3 <-- type de droite	JUMP,NE	DOMREL	LOAD.W	(A6)+OOBJET,D3;;;	JUMP	DOMRELM	RETDOMFLE:				; flche =>PUSH.L	D0;;;	CALL	DBOXFLECHE	LOAD.W	(A6)+OPLANAV+OPLANA,#FDBFLECHE	.W	PLANA_FONC	JUMP,NE	80$;lib	?aftim;.ascize	"plana flche ok";lib	?getcar	TEST.B	(A6)+OPLANAV+OFLAGS:#BMDBOX	JUMP,BS	80$	CALL	EFFACE	CALL	REFAIT80$:	TEST.W	D0	JUMP,NS	90$	LOAD.W	(A6)+OOBJET,D0	SWAP.W	D0	LOAD.W	(A6)+OFLECHE,D090$:	POP.L	D0;;;	JUMP	DOMRELM	RETDOMCER:	COMP.B	D3,#7	JUMP',HS 47$	COMP.B	D3,#4		; ellipse ?	JUMP',HS 48$		; oui => 48$	LOAD.W	(A6)+OOBJET,#OBJCERCLE	LOAD.W	(A6)+OARC,D3	TEST.B	D3		; cercle complet ?	JUMP',EQ 47$		; oui => 47$	LOAD.W	(A6)+OOBJET,#OBJARC47$:;;;	JUMP	DOMRELM	RET48$:	LOAD.W	(A6)+OOBJET,#OBJELLIPSE	SUB.W	D3,#4	LOAD.W	(A6)+OARC,D3	TEST.B	D3		; ellipse complte ?	JUMP',EQ 47$		; oui => 47$	LOAD.W	(A6)+OOBJET,#OBJARCELL	JUMP	47$DOMRECT:	SL.W	D3,#2		; D3 <-- rayon (0, 4, 8, 12 ou 16)	LOAD.W	(A6)+ORRECT,D3	LOAD.W	(A6)+OOBJET,#OBJRECT;;;	JUMP	DOMRELM	RETDOMPOL:	LOAD.L	A3,#R16"TPOL	CALL	SMMENU		; D3 <-- type de polygone;;;	JUMP,NE	DOMREL	JUMP,NE	90$	LOAD.W	(A6)+OOBJET,D3;;;	JUMP	DOMRELM90$:	RETDOMSURF:				; surface =>	LOAD.W	D4,(A6)+OOBJET	; D4 <-- ancien objet;;;;	LOAD.W	(A6)+OOBJET,D3	; mm. objet surface	LOAD.W	(A6)+OOBJET,#OBJSURF	CALL	CWMO		; remet souris normale	CALL	SRMO		; remet la flche	LOAD.W	D1,(A6)+OOBJET	SWAP.W	D1	LOAD.W	D1,(A6)+OTRAME;;;	CALL	DBOXTRAME	; attend choix selon DBOX ...	LOAD.W	(A6)+OPLANAV+OPLANA,#FDBTRAME	.W	PLANA_FONC;;;	JUMP',NE 26$		; annule => 26$	JUMP,NE	10$;	TEST.B	(A6)+OPLANAV+OFLAGS:#BMDBOX;	JUMP,BC	10$	CALL	MAJCADRE	CALL	REFAIT10$:	CALL	AFMENU		; menu standard	CALL	CRMO		; met v. rticule	TEST.W	D1	JUMP,NS	26$	LOAD.W	(A6)+OTRAME,D1	SWAP.W	D1	LOAD.W	(A6)+OOBJET,D1	JUMP	DOMRELM;;;;;;	RET26$:	LOAD.W	(A6)+OOBJET,D4	; remet l'ancien objet	JUMP	DOMREL;;;;;;	RETDOMBLOC:DOMSTO:				; bloc-notes =>	LOAD.W	D7,#ERPBN	; D7 <-- "bloc-notes vide"	TEST.L	(A6)+OSTKP2	JUMP,EQ	DFERROR;;;;	LOAD.W	(A6)+OOBJET,D3	; mm. nouvel objet	LOAD.W	(A6)+OOBJET,#OBJSTOCK	JUMP	DOMRELMDOTEX:	CALL	ASKGC	JUMP,NE	LOOP	JUMP	DOMEXITDOMTEX:				; texte =>	CALL	MENUGC		; ASKGC	JUMP,NE LOOP	JUMP	DOMEXIT;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; MMENU MILIEU ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; Choix dans un m-menu hirarchique avec la souris.;mMILIEU:	.ASCIZ	" "	.B	-1	.BW	-2,mFICHIER-mMILIEU	.B	USEGC,GCICF,GCICS,GCICT	.B	7,122			;,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" fichier "			; > suite en mFICHIER	.BW	-2,mEDITION-mMILIEU	.B	USEGC,GCICF,GCICS,GCICT	.B	7,121			;,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" dition "			; > suite en mEDITION	.BW	-2,mVUE-mMILIEU	.B	USEGC,GCICF,GCICS,GCICT	.B	7,120			;,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" vue "				; > suite en mmVUE	.B	-1	.BW	-2,mOBJET-mMILIEU	.B	USEGC,GCICF,GCICS,GCICT	.B	7,118			;,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" objets "			; > suite en mOBJET	.B	USEGC,GCICF,GCICS,GCICT	.B	7,117			;,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" bibliothque .."	.B	-1	.BW	-2,mPARAM-mMILIEU		; > suite en mPARAM (attributs);	.B	USEGC,GCICF,GCICS,GCICT;	.B	7,119,7;	.B	USEGC,GCTXF,GCTXS,GCTXT;	.ASCIZ	" paramtres "		.B	USEGC,GCICF,GCICS,GCICT		.B	7,8		;,7		.B	7,52		;,7		.B	7,9		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.B	0	.B	-1	.B	USEGC,GCICF,GCICS,GCICT	.B	7,123			;,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" dfinitions  .."	.B	0	.EVEN	mOBJET:		.BW	-2,mTML-mOBJET		.B	USEGC,GCICF,GCICS,GCICT		.B	7,1		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" ligne"		; > suite en mTML		.BW	-2,mDROITE-mOBJET		.B	USEGC,GCICF,GCICS,GCICT		.B	7,2		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" droite"		; > suite en mDROITE		.B	USEGC,GCICF,GCICS,GCICT		.B	7,71		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" flche  .."		.BW	-2,mARCh-mOBJET		.B	USEGC,GCICF,GCICS,GCICT		.B	7,3		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" cercle"		; > suite en mCRECLE		.BW	-2,mRECTh-mOBJET		.B	USEGC,GCICF,GCICS,GCICT		.B	7,4		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" rectangle "		; > suite en mRECTh		.BW	-2,mPOLY-mOBJET		.B	USEGC,GCICF,GCICS,GCICT		.B	7,86		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" polygone"		; > suite en mPOLY		.B	USEGC,GCICF,GCICS,GCICT		.B	7,5		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" surface .."		.B	USEGC,GCICF,GCICS,GCICT		.B	7,6		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" texte   ..";;;;;;		.BW	-2,mBLOCNOTEh-mOBJET		.B	USEGC,GCICF,GCICS,GCICT		.B	7,48		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" bloc-notes"		; > suite en mBLOCNOTEh		.B	0		.EVEN	mPARAM:		.B	USEGC,GCICF,GCICS,GCICT		.B	7,8		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" pinceau .. "		.BW	-2,mCOULEUR-mPARAM		.B	USEGC,GCICF,GCICS,GCICT		.B	7,52		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" couleur "			; > suite en mCOULEUR		.BW	-2,mMODEH-mPARAM		.B	USEGC,GCICF,GCICS,GCICT		.B	7,9		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" mode"				; > suite en mMODEH		.B	0		.EVEN	mFICHIER:		.B	USEGC,GCICF,GCICS,GCICT		.B	7,115		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" prend  .. "		.B	USEGC,GCICF,GCICS,GCICT		.B	7,116		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" ajoute .. "		.B	USEGC,GCICF,GCICS,GCICT		.B	7,32		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" sauve  .. "		.B	-1		.BW	-2,mIMPRIME-mFICHIER		.B	USEGC,GCICF,GCICS,GCICT		.B	7,114		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" imprime "			; > suite en mIMPRIME		.B	USEGC,GCICF,GCICS,GCICT		.B	7,125		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" trace  .. ";		.B	-1		.ASCIZ	" .image  fond   .. "		.B	-1		.B	USEGC,GCICF,GCICS,GCICT		.B	7,95		;,7		.B	USEGC,GCTXF,GCTXS,GCTXT		.ASCIZ	" quitte .. "		.B	0		.EVEN	mEDITION:		.B	USEGC,