		.SBTTL	PLANOPER	; 18 aot 87 Sp.;--------\; REFAIT  >;========/; Refait tout le dessin.; in	-; out	-; mod	D7.WREFAIT:	CALL	SWMO		; "souris" en attente	CALL	RELLAST		; enlve v. rf. dynamique	TEST.L	(A6)+OMEMIM	; si image en mmoire alors affiche	JUMP,EQ	10$	test.B	(A6)+OFLMOD:#BIMAFOND ; image cache ?	JUMP,BS	10$		; oui ...	CALL	AFFIMAGE	; non, affiche10$:	LOAD.W	(A6)+OPLANAV+OPLANA,#FREFAIT	.W	PLANA_FONC	; redessine tout	CALL	AFMENU		; remet les soft-keys	CALL	INILLAST	; remet v. rf. dynamique	CALL	CWMO		; remet souris	RET;--------\; MODIFIE >;========/; Modifie tous les objets dans une zone de recherche.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D0.B	altration  effectuer; out	-; mod	D7.WMODIFIE:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	LOAD.B	D6,D0		; D6 <-- type d'altration;;;	CALL	ORDONNE.W	PLANA_ORDONNE	LOAD.L	(A6)+OALTPO,#-1;;;	CALL	FIRBASE		; A4 <-- ^premier lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE	.W	PLANA_BASE	JUMP,NE	90$	CALL	SWMO		; met la souris "en attente"10$:;;;	CALL	DETECTE		; dans zone de recherche ?	LOAD.W	(A6)+OPLANAV+OPLANA,#BDETECTE	.W	PLANA_BASE	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A3,A4		; A3 <-- ^lment actuel;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	EX.L	A3,A4		; A4 <-- ^act, A3 <-- ^suivant	PUSHM.L	D3,D4,D7;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	CALL	INVMODE		; D2 <-- mode inverse;;;	CALL	DESSINE		; efface l'objet	.W	PLANA_DESSINE	CALL	INVMODE		; D2 <-- mode normal;;;	CALL	MET		; objet <-- registres	LOAD.W	(A6)+OPLANAV+OPLANA,#BMET	.W	PLANA_BASE;;;	CALL	CLOBASE		; supprime l'objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BCLOBASE	.W	PLANA_BASEcomp.b	d0,#8		; transforme text en tramejump,eq	40$;;;	CALL	OPEBASE		; A4 <-- ^nouvel lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BOPEBASE	.W	PLANA_BASE	CALL	ALTER		; registres <-- modification;;;	CALL	MET		; objet <-- registres	LOAD.W	(A6)+OPLANAV+OPLANA,#BMET	.W	PLANA_BASE	TSET.B	(A4)+OMFLAGS:#BMNEW;;;	CALL	DESSINE		; redessine l'objet	.W	PLANA_DESSINE	POPM.L	D3,D4,D715$:	LOAD.L	A4,A3		; A4 <-- ^lment suivant	TEST.W	D7	JUMP,EQ	10$	JUMP'	80$20$:;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP,EQ	10$80$:;;;	CALL	CLRNEW		; ote les bits BMNEW	LOAD.W	(A6)+OPLANAV+OPLANA,#BCLRNEW	.W	PLANA_BASE90$:	CALL	CWMO		; remet la souris normale	POPM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	RET40$:	call	ALTTXTR		; transforme en trames !!!	POPM.L	D3,D4,D7	; ATTENTION !!!!	jump	15$;--------\; ALTER   >;========/; Modifie les paramtres d'un objet en fonction d'une; opration d'altration  effectuer.; in	D0.W	objet;	D2.B	mode;	D1.B	mode de trait;	D3.L	premier paramtre;	D4.L	deuxime paramtre;	D6.B	type d'altration; out	D2.B	mode;	D1.B	mode de trait;	D3.L	premier paramtre;	D4.L	deuxime paramtre; mod	D1.W, D2.W, D3.L, D4.LALTER:	PUSH.L	D5	TEST.B	D6		; paisseur ?	JUMP,EQ	20$	COMP.B	D6,#1		; couleur ?	JUMP,EQ	30$	COMP.B	D6,#2		; mode ?	JUMP,EQ	40$	COMP.B	D6,#3		; pas ?	JUMP,EQ	50$	COMP.B	D6,#4		; lastique ?	JUMP,EQ	60$	COMP.B	D6,#5		; rigide ?	JUMP,EQ	70$	COMP.B	D6,#6		; surface ?	JUMP,EQ	80$	COMP.B	D6,#7		; texte ?	JUMP,EQ	85$	JUMP	90$20$:				; EPAISSEUR =>	COMP.B	D0,#OBJSURF	; surface ?	JUMP,EQ	90$		; oui => 90$	LOAD.W	D1,(A6)+OTRAIT	; D1 <-- paisseur trait	JUMP	90$30$:				; COULEUR =>	LOAD.W	D5,(A6)+OMODE	; D5 <-- couleur/mode de dessin	AND.B	D5,#H'F0	; D5 <-- couleur de dessin	AND.B	D2,#H'0F	; D2 <-- mode actuel	OR.B	D2,D5		; D2 <-- nouvelle couleur	JUMP	90$40$:				; MODE =>	LOAD.W	D5,(A6)+OMODE	; D5 <-- mode/couleur de dessin	AND.B	D5,#H'0F	; D5 <-- mode de dessin	AND.B	D2,#H'F0	; D2 <-- couleur actuelle	OR.B	D2,D5		; D2 <-- nouveau mode	JUMP	90$50$:				; PAS =>	CALL	ALTPAS		; modifie le pas	JUMP	90$60$:				; ELASTIQUE =>	LOAD.B	D5,#OBJELASTIQUE	COMP.B	D0,#OBJDROITE	JUMP',EQ 75$	LOAD.B	D5,#OBJEHV	COMP.B	D0,#OBJDHV	JUMP',EQ 75$	JUMP'	90$70$:				; RIGIDE =>	LOAD.B	D5,#OBJDROITE	COMP.B	D0,#OBJELASTIQUE	JUMP',EQ 75$	LOAD.B	D5,#OBJDHV	COMP.B	D0,#OBJEHV	JUMP',NE 90$75$:	LOAD.B	D0,D5		; D0 <-- nouveau type d'objet	JUMP'	90$80$:				; SURFACE =>	COMP.B	D0,#OBJSURF	; surface ?	JUMP',NE 90$		; non => 90$	LOAD.W	D1,(A6)+OTRAME	; met nouveau type de trame	JUMP'	90$85$:				; TEXTE =>	COMP.B	D0,#OBJTEXT	; caractre ?	JUMP',NE 90$		; non => 90$	CALL	ALTTEXT90$:	POP.L	D5	RET;--------\; ALTPAS  >;--------/; Modifie les paramtres d'un objet en fonction du pas,; afin d'aligner l'objet sur le pas de la grille.; in	D0.W	objet;	D3.L	premier paramtre;	D4.L	deuxime paramtre; out	D3.L	premier paramtre;	D4.L	deuxime paramtre; mod	D3.L, D4.LALTPAS:	PUSH.L	D0	COMP.B	D0,#OBJRECT	JUMP',EQ 20$	COMP.B	D0,#OBJSURF	JUMP',EQ 20$	COMP.B	D0,#OBJLIGNE	JUMP,EQ 30$	COMP.B	D0,#OBJELASTIQUE	JUMP,EQ 30$	COMP.B	D0,#OBJEHV	JUMP,EQ	40$	COMP.B	D0,#OBJFLECHE	JUMP,EQ 30$	COMP.B	D0,#OBJFHV	JUMP,EQ	40$	COMP.B	D0,#OBJCERCLE	JUMP,EQ	60$	COMP.B	D0,#OBJARC	JUMP,EQ	60$	COMP.B	D0,#OBJTEXT	JUMP,EQ	70$				; objet rectangulaire =>	CALL	ARRONDI		; D4 <-- arrondi selon pas	EX.L	D3,D4	CALL	ARRONDI		; D3 <-- arrondi selon pas	EX.L	D4,D3	JUMP	90$20$:				; rectangle lastique =>	TEST.B	(A6)+OPLANAV+ORCOIN:#0	; coin X1 trouv ?	JUMP',BC 22$		; non => 22$				; oui =>	LOAD.W	D0,D3	CALL	XARRONDI	; arrondi X1	LOAD.W	D3,D022$:	TEST.B	(A6)+OPLANAV+ORCOIN:#1	; coin Y1 trouv ?	JUMP',BC 24$		; non => 24$				; oui =>	SWAP.W	D3	LOAD.W	D0,D3	CALL	XARRONDI	; arrondi Y1	LOAD.W	D3,D0	SWAP.W	D324$:	TEST.B	(A6)+OPLANAV+ORCOIN:#2	; coin X2 trouv ?	JUMP',BC 26$		; non => 26$				; oui =>	LOAD.W	D0,D4	CALL	XARRONDI	; arrondi X2	LOAD.W	D4,D026$:	TEST.B	(A6)+OPLANAV+ORCOIN:#3	; coin Y2 trouv ?	JUMP',BC 28$		; non => 28$				; oui =>	SWAP.W	D4	LOAD.W	D0,D4	CALL	XARRONDI	; arrondi Y2	LOAD.W	D4,D0	SWAP.W	D428$:	JUMP	90$30$:				; lastique =>	TEST.B	(A6)+OPLANAV+ORCOIN:#0	; coin D3 trouv ?	JUMP',BC 35$		; non => 35$				; oui =>	EX.L	D3,D4	CALL	ARRONDI		; D3 <-- arrondi selon pas	EX.L	D4,D335$:	TEST.B	(A6)+OPLANAV+ORCOIN:#1	; coin D4 trouv ?	JUMP,BC	90$		; non => 90$				; oui =>	CALL	ARRONDI		; D4 <-- arrondi selon pas	JUMP	90$40$:				; lastique hor. ou vert. =>	COMP.W	D3,D4		; verticale ?	JUMP,EQ	45$		; oui => 45$				; non => horizontale	SWAP.W	D3	LOAD.W	D0,D3	CALL	XARRONDI	; arrondi Y	LOAD.W	D3,D0	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,D4	CALL	XARRONDI	; arrondi Y	LOAD.W	D4,D0	SWAP.W	D4	TEST.B	(A6)+OPLANAV+ORCOIN:#0	; coin D3 trouv ?	JUMP',BC 42$		; non => 42$				; oui =>	LOAD.W	D0,D3	CALL	XARRONDI	; arrondi X	LOAD.W	D3,D042$:	TEST.B	(A6)+OPLANAV+ORCOIN:#1	; coin D4 trouv ?	JUMP,BC	90$		; non => 90$				; oui =>	LOAD.W	D0,D4	CALL	XARRONDI	; arrondi X	LOAD.W	D4,D0	JUMP	90$45$:				; verticale =>	LOAD.W	D0,D3	CALL	XARRONDI	; arrondi X	LOAD.W	D3,D0	LOAD.W	D0,D4	CALL	XARRONDI	; arrondi X	LOAD.W	D4,D0	TEST.B	(A6)+OPLANAV+ORCOIN:#0	; coin D3 trouv ?	JUMP',BC 47$		; non => 47$				; oui =>	SWAP.W	D3	LOAD.W	D0,D3	CALL	XARRONDI	; arrondi Y	LOAD.W	D3,D0	SWAP.W	D347$:	TEST.B	(A6)+OPLANAV+ORCOIN:#1	; coin D4 trouv ?	JUMP,BC	90$		; non => 90$				; oui =>	SWAP.W	D4	LOAD.W	D0,D4	CALL	XARRONDI	; arrondi Y	LOAD.W	D4,D0	SWAP.W	D4	JUMP'	90$60$:				; cercle/arc =>	CALL	ARRONDI		; D4 <-- arrondi le centre	LOAD.W	D0,D3		; D0 <-- rayon	CALL	XARRONDI	; arrondi la rayon	LOAD.W	D3,D0		; D3 <-- rayon (arc inchang)	JUMP'	90$70$:				; texte =>	SWAP.W	D4		; D4 <-- X;Y	LOAD.W	D0,D4		; D0 <-- Y	CALL	XARRONDI	; arrondi seulement Y (!)	LOAD.W	D4,D0		; D4 <-- Y arrondi	SWAP.W	D4		; D4 <-- Y;X90$:	POP.L	D0	RET;--------- ALTTXTR:;---------; transforme un caractre en trame; in	D0.W	objet;	D3.L	premier paramtre (fstc);	D4.L	deuxime paramtre (coordonnes); out	caractre en trame 100%; mod	D7.W; OPMATRIX; in	D4.B		code du caractre;	D6.W	no. genc; out	(A5)+OLGMA.L	dimensions de la matrice (dy;dx);	(A5)+OMAPGC.L	^dbut du gencar;	D7.W		erreur; mod	D7.W;; ADMATRIX; in	D6.L	+/- offset;	D2	mode; out	D7.W	erreur; mod	D7.W	PUSHM.L	D0..D6,A0..A6	LOAD.L	D6,D4		; D6 <-- coordonnes	LOAD.B	D4,D3		; D4 <-- caractre	comp.b	d4,#space	; espace ne fait rien	jump,eq	70$;	TCLR.L	D4:#7push.l	d6				; chercher no. genc	load.w	d6,#MAXGC-1	sr.l	d3,#8		; "-fst"	load.l	a0,#(a6)+oplanav+obugc	add.l	a0,#(maxgc-1)*lggc10$:	and.l	(a0)+ogccod,#H'00FFFFFF	comp.l	d3,(a0)+ogccod	jump,eq	20$;	sub.l	a0,#lggc	load.l	a0,#(a0)-lggc;	dec.w	d6;	jump,ne	10$	decj.w,nmo d6,10$20$:;	LOAD.W	D6,(A6)+OTEXTE;;;	CALL	OPMATRIX	; ouvre la matrice	LOAD.W	(A6)+OPLANAV+OPLANA,#BOPMATRIX	.W	PLANA_BASE	CALL	USEDGCpop.l	d6	TEST.W	D7	JUMP,NE 90$	; DOERROR	LOAD.B	(A6)+OPLANAV+ORCOIN,#-1	; tous les coins trouvs;	LOAD.W	D2,(A6)+OMODE;;;	CALL	ADMATRIX	; converti toute la matrice	LOAD.W	(A6)+OPLANAV+OPLANA,#BADMATRIX	.W	PLANA_BASE	JUMP,NE	90$	;DOERROR70$:90$:	POPM.L	D0..D6,A0..A6	test.w	d7	RET;--------\; ALTTEXT >;--------/; Modifie les paramtres d'un caractre pour changer; la fonte et le style.; in	D0.W	objet;	D3.L	premier paramtre;	D4.L	deuxime paramtre; out	D3.L	premier paramtre;	D4.L	deuxime paramtre; mod	D3.L, D4.LALTTEXT:	PUSHM.L	D5,A0;;;	CALL	SRCPGC		; A0 <-- ^gencar	LOAD.W	(A6)+OPLANAV+OPLANA,#FSRCPGC	.W	PLANA_FONC	JUMP,NE 90$	LOAD.L	D5,D4		; D5 <-- position actuelle	COMP.L	D5,(A6)+OALTPO	; caractre  la suite ?	JUMP',EQ 30$		; oui => 30$				; non =>	SWAP.W	D4	ADD.W	D4,(A0)+OGCITL	SWAP.W	D4	COMP.L	D4,(A6)+OALTPD	; dbut de la ligne suivante ?	JUMP',NE 20$		; non => 20$	LOAD.W	D4,(A6)+OALTPI	; D4 <-- interligne nouveau gencar	SUB.W	(A6)+OALTPN+0,D4; descend d'une ligne	LOAD.W	(A6)+OALTPN+2,D5; revient au dbut de la ligne	LOAD.L	(A6)+OALTPD,D5	; mm. position dbut ligne	JUMP'	30$20$:	LOAD.L	(A6)+OALTPN,D5	; repart  la position actuelle	LOAD.L	(A6)+OALTPD,D5	; mm. position dbut ligne30$:;;;	CALL	LGCGC		; D4 <-- largeur	LOAD.W	(A6)+OPLANAV+OPLANA,#FLGCGC	.W	PLANA_FONC	ADD.W	D5,D4		; D5 <-- position suivante	LOAD.L	(A6)+OALTPO,D5	; mm. nouvelle position suppose	CALL	GETPGC		; A0 <-- ^nouveau gencar	LOAD.B	D5,D3		; D5 <-- juste le caractre	LOAD.L	D3,(A0)+OGCCOD	; D3 <-- "-fst"	SL.L	D3,#8		; D3 <-- "fst-"	LOAD.B	D3,D5		; D3 <-- gencar + caractre	LOAD.L	D5,(A6)+OALTPN;;;	CALL	LGCGC		; D4 <-- largeur	LOAD.W	(A6)+OPLANAV+OPLANA,#FLGCGC	.W	PLANA_FONC	ADD.W	(A6)+OALTPN+2,D4	LOAD.L	D4,D5		; D4 <-- nouvelle position	LOAD.W	(A6)+OALTPI,(A0)+OGCITL ; mm. interligne nouveau gencar	ADD.W	D5,(A0)+OGC2X	COMP.W	D5,(A6)+OPLANAV+OMWDOX	; dpasse vers la droite ?	JUMP',LO 80$		; non => 80$				; oui =>	LOAD.W	D4,(A6)+OPLANAV+OMWDOX	SUB.W	D4,(A0)+OGC2X	; D4 <-- met au maximum  droite80$:	SWAP.W	D5	COMP.W	D5,(A0)+OGC2Y	; dpasse vers le bas ?	JUMP',GE 90$		; non => 90$				; oui =>	SWAP.W	D4	LOAD.W	D4,(A0)+OGC2Y	; D4 <-- met au maximum en bas	SWAP.W	D490$:	POPM.L	D5,A0	RET;--------\; FILTRE  >;========/; Passe en revue tous les objets dans une zone de recherche.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche;	D0.W	type d'opration (0..1); out	-; mod	-FILTRE:	PUSHM.L	D0,D1,D2,D3,D4,D5,A3,A4	CALL	SETFILTRE	; filtre tout par dfaut;;;	CALL	ORDONNE		; D3 <-- plus petit, D4 <-- plus grand	.W	PLANA_ORDONNE	TEST.B	D0		; quelle opration ?	JUMP,EQ 20$; Filtre tous les objets qui ne sont pas l'objet slectionn; en bas de l'cran.;;;	CALL	FIRBASE		; A4 <-- ^premier lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE	.W	PLANA_BASE	JUMP,NE	90$10$:	TCLR.B	(A6)+OPLANAV+OFLDET:#BDETGR ; on est plus dans un groupe;;;	CALL	FDETECTE	; dans zone de recherche ?	LOAD.W	(A6)+OPLANAV+OPLANA,#BFDETECTE;;;;;;	.W	PLANA_FONC	.W	PLANA_BASE	JUMP',NE 18$		; non => 18$				; oui =>	PUSHM.L	D3,D4	CALL	GPREND		; registres <-- objet	CALL	IFOBJSEL	; objet slectionn ?	POPM.L	D3,D4	JUMP',NE 18$		; non => 18$	TCLR.B	(A4)+OMFLAGS:#BMNOT18$:	CALL	GNXTBASE	; A4 <-- ^lment suivant	JUMP,EQ	10$	JUMP	90$; Propose tous les objets contenus dans la zone, un par un.20$:	PUSH.W	D3	LOAD.B	D3,#BIPYES	LIB	?BEEP		; p'tit bruit oui/non	POP.W	D3	LOAD.L	A3,#R16"TMYES	; A3 <-- ^menu	LIB	?AFMENU		; affiche les soft-keys; Passe en revue tous les objets contenus dans la zone, en; posant chaque fois la question  l'utilisateur.;;;	CALL	FIRBASE		; A4 <-- ^premier lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE	.W	PLANA_BASE	JUMP,NE	90$22$:	TCLR.B	(A6)+OPLANAV+OFLDET:#BDETGR ; on est plus dans un groupe;;;	CALL	FDETECTE	; dans zone de recherche ?	LOAD.W	(A6)+OPLANAV+OPLANA,#BFDETECTE	.W	PLANA_BASE	JUMP,NE	40$		; non => 40$				; oui =>	CALL	INIQUES		; positionne en bas	PUSHM.L	D3,D4	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; tout p'tit bruit	CALL	GPREND		; registres <-- objet/groupe	CALL	AFOBJET		; affiche l'objet concern	POPM.L	D3,D425$:	LOAD.W	D2,#1	CALL	GDESSINE	; enlve objet/groupe provisoirement	TCLR.B	(A4)+OMFLAGS:#BMNOT	CALL	FYESNO		; attend rponse ...	JUMP',EQ 30$		; oui => 30$	TSET.B	(A4)+OMFLAGS:#BMNOT30$:	PUSH.W	D7	CLR.W	D2	CALL	GDESSINE	; remet objet/groupe	POP.W	D7	COMP.W	D7,#2		; "prend le reste" ?	JUMP,EQ	50$		; oui => 50$	COMP.W	D7,#3		; "ignore le reste" ?	JUMP,EQ	60$		; oui => 60$	TEST.W	D7		; timeout survenu ?	JUMP,NC	40$		; non => 40$				; oui =>	TCLR.B	(A4)+OMFLAGS:#BMNOT	CALL	FYESNO		; attend rponse ...	JUMP',EQ 35$		; oui => 35$	TSET.B	(A4)+OMFLAGS:#BMNOT35$:	COMP.W	D7,#2		; "prend le reste" ?	JUMP',EQ 50$		; oui => 50$	COMP.W	D7,#3		; "ignore le reste" ?	JUMP',EQ 60$		; oui => 60$	TEST.W	D7		; timeout survenu ?	JUMP,NS	25$		; oui => 25$40$:	CALL	GNXTBASE	; A4 <-- ^lment/groupe suivant	JUMP,EQ	22$	JUMP	90$; Prend tous les objets restants, puis stoppe les questions.50$:	TCLR.B	(A4)+OMFLAGS:#BMNOT52$:	TCLR.B	(A6)+OPLANAV+OFLDET:#BDETGR ; on est plus dans un groupe;;;	CALL	FDETECTE	; dans zone de recherche ?	LOAD.W	(A6)+OPLANAV+OPLANA,#BFDETECTE	.W	PLANA_BASE	JUMP',NE 55$		; non => 55$				; oui =>	TCLR.B	(A4)+OMFLAGS:#BMNOT55$:	CALL	GNXTBASE	; A4 <-- ^lment/groupe suivant	JUMP,EQ	52$	JUMP'	90$; Ignore tous les objets restants, puis stoppe les questions.60$:	TSET.B	(A4)+OMFLAGS:#BMNOT62$:	TCLR.B	(A6)+OPLANAV+OFLDET:#BDETGR ; on est plus dans un groupe;;;	CALL	FDETECTE	; dans zone de recherche ?	LOAD.W	(A6)+OPLANAV+OPLANA,#BFDETECTE	.W	PLANA_BASE	JUMP',NE 65$		; non => 65$				; oui =>	TSET.B	(A4)+OMFLAGS:#BMNOT65$:	CALL	GNXTBASE	; A4 <-- ^lment/groupe suivant	JUMP,EQ	62$90$:	CALL	AFMENU		; remet menu "standard";;;	CALL	INIBAS		; refait le bas	POPM.L	D0,D1,D2,D3,D4,D5,A3,A4	RET;---------\\; IFOBJSEL >;---------/; Vrifie si l'objet dans les registres correspond  l'objet slectionn.; in	D0..D4	objet; out	D7.W	oui/non; mod	D7.WIFOBJSEL:	PUSHM.L	D2..D4	LOAD.W	D7,#ERPNF	; D7 <-- "pas trouv"	LOAD.W	D2,(A6)+OOBJET	; D2 <-- objet slectionn	LOAD.W	D4,#OBJSURF	COMP.B	D2,#OBJFILL	; trame remplie ?	JUMP',EQ 20$	LOAD.W	D4,#OBJLIGNE	COMP.B	D2,#OBJSPLO	; spline ouvert ?	JUMP',EQ 20$	COMP.B	D2,#OBJSPLC	; spline ferm ?	JUMP',EQ 20$	LOAD.W	D4,D220$:	COMP.B	D0,D4		; mme objet que slectionn ?	JUMP',NE 90$		; non => 90$				; oui =>	comp.b	d0,#objtext	jump,ne	22$	call	ifobjgc	jump,eq	80$	jump	90$22$:	LOAD.L	D2,D3	SWAP.W	D2		; D2 <-- arcs de cercles	COMP.B	D0,#OBJARC	JUMP',EQ 50$	LOAD.W	D2,D0	SR.W	D2,#8		; D2 <-- arcs d'ellipse	COMP.B	D0,#OBJARCELL	JUMP',EQ 50$	COMP.B	D0,#OBJSURF	JUMP',NE 80$	COMP.W	D1,(A6)+OTRAME	; mme type de trame ?	JUMP',NE 90$		; non => 90$	JUMP'	80$50$:				; arc de cercle ou d'ellipse =>	LOAD.W	D3,#4	LOAD.W	D4,#8-152$:	SR.B	D2,#1	JUMP',CC 55$	DEC.W	D3		; D3 <-- compte le nb de 1/8 d'arc55$:	DECJ.W,NMO D4,52$	TEST.W	D3		; D3=3 --> 1/8	JUMP',NE 57$		; D3=2 --> 1/4	INC.W	D3		; D3=1 --> 1/257$:	COMP.W	D3,(A6)+OARC	; mme fraction d'arc ?	JUMP',NE 90$		; non => 90$80$:	CLR.W	D7		; D7 <-- "trouv"90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------- IFOBJGC:;---------; est-ce le mme genc ?;; in	D0..D4	objet; out	EQ	trouv;	NE	pas trouv; mod	D7;	PUSHM.L	D2,D3,A0	call	getpgc		; A0 ^genc	clr.b	d3		; D3 <-- "fst-"	load.l	d2,(a0)+ogccod	; D2 <-- "fst-"	sl.l	d2,#8	comp.l	d3,d2	jump,ne	90$80$:	clr.w	d7		; oui90$:	POPM.L	D2,D3,A0	RET;--------\; FYESNO  >;--------/; Attend une rponse avec timeout.; in	-; out	D7.W	NC (0..3)	rponse correcte;		NS		timeout survenu; mod	D7.WFYESNO:	PUSHM.L	D3,D410$:	LOAD.W	D4,#5		; D4 <-- trs court (!)	NTREL	?SETTIM		; modifie le timeout	LIB	?GETCAR		; attend une touche ...	JUMP,NS	80$		; si timeout => 80$	LIB	?MINMAJ		; D3 <-- touche MAJUSCULE	COMP.W	D3,#F0+SHIFT	JUMP',LO 20$	COMP.W	D3,#F15+SHIFT	JUMP',HI 20$	SUB.W	D3,#SHIFT20$:	CLR.W	D7		; D7 <-- "prend"	COMP.W	D3,#F1	JUMP',EQ 80$	COMP.W	D3,#F2	JUMP',EQ 80$	COMP.W	D3,#F3	JUMP',EQ 80$	INC.W	D7		; D7 <-- "ignore"	COMP.W	D3,#F4	JUMP',EQ 80$	COMP.W	D3,#F5	JUMP',EQ 80$	COMP.W	D3,#F6	JUMP',EQ 80$	INC.W	D7		; D7 <-- "prend le reste"	COMP.W	D3,#F10	JUMP',EQ 80$	COMP.W	D3,#F11	JUMP',EQ 80$	COMP.W	D3,#F12	JUMP',EQ 80$	INC.W	D7		; D7 <-- "ignore le reste"	COMP.W	D3,#F13	JUMP',EQ 80$	COMP.W	D3,#F14	JUMP',EQ 80$	COMP.W	D3,#F15	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	10$		; puis attend autre chose ...80$:	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	POPM.L	D3,D4	TEST.W	D7	RET;--------\\; GPREND  >;========/; Prend les paramtres d'un objet ou d'un groupe dans les registres.; Si tous les objets du groupe sont identiques, rend le premier objet; du groupe. Autrement, rend l'objet OBJDUGROUPE ou OBJDSGROUPE.; in	A4.L	^lment; out	D0.W	type de l'objet;		OBJD?GROUPE => D1..D4 sans signification;	D3.L	premier paramtre;	D4.L	deuxime paramtre;	D2.W	mode;	D1.W	mode de trait; mod	D0.W, D1.W, D2.W, D3.L, D4,L, D7.WGPREND:	PUSHM.L	D5,D6,A0,A4;;;	CALL	PREND		; D0..D4 <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	COMP.B	D0,#OBJDUGROUPE	JUMP',EQ 20$	COMP.B	D0,#OBJDSGROUPE	JUMP',NE 90$20$:				; dbut d'un groupe =>	LOAD.W	A0,D0		; A0 <-- OBJD?GROUPE;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP',NE 90$;;;	CALL	PREND		; D0..D4 <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	LOAD.W	D5,D0		; D5 <-- premier objet du groupe	CLR.W	D625$:	INC.W	D6		; D6 <-- une fin de groupe de plus attendue30$:;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP',NE 90$	LOAD.W	D0,(A4)+OMOBJET	COMP.B	D0,#OBJDUGROUPE	; dbut d'un groupe imbriqu ?	JUMP,EQ 25$		; oui => 25$	COMP.B	D0,#OBJDSGROUPE	JUMP,EQ 25$	COMP.B	D0,#OBJFUGROUPE	; fin d'un groupe ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D0,#OBJFSGROUPE	JUMP',EQ 50$	COMP.B	D0,D5		; encore un mme objet ?	JUMP',NE 40$	COMP.B	D1,(A4)+OMTRAI	JUMP',NE 40$	COMP.B	D2,(A4)+OMMODE	JUMP,EQ 30$		; oui => 30$40$:				; non =>	LOAD.W	D0,A0		; D0 <-- OBJD?GROUPE	JUMP'	90$50$:	DEC.W	D6		; fin de groupe imbrique ?	JUMP,NE 30$		; oui => 30$	LOAD.W	D0,D5		; D0 <-- premier objet du groupe90$:	POPM.L	D5,D6,A0,A4	RET;---------\\; GDESSINE >;=========/; Dessine un objet, ou un groupe d'objets.; in	A4.L	^lment/groupe;	D2.W	0/1 => normal/inverse; out	-; mod	D7.WGDESSINE:	PUSHM.L	D0..D6,A4	LOAD.W	D6,D2		; D6 <-- normal/inverse;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	TEST.W	D6	JUMP',EQ 10$	CALL	INVMODE		; D2 <-- mode inverse10$:;;;	CALL	DESSINE		; dessine/efface l'objet	.W	PLANA_DESSINE	COMP.B	D0,#OBJDUGROUPE	JUMP',EQ 20$	COMP.B	D0,#OBJDSGROUPE	JUMP',NE 90$20$:				; dbut d'un groupe =>;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP',NE 90$	CLR.W	D125$:	INC.W	D1		; D1 <-- une fin de groupe de plus attendue30$:	PUSH.W	D1;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	TEST.W	D6	JUMP',EQ 35$	CALL	INVMODE		; D2 <-- mode inverse35$:;;;	CALL	DESSINE		; dessine/efface l'objet	.W	PLANA_DESSINE	POP.W	D1;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP',NE 90$	LOAD.W	D0,(A4)+OMOBJET	COMP.B	D0,#OBJDUGROUPE	; dbut d'un groupe imbriqu ?	JUMP,EQ 25$		; oui => 25$	COMP.B	D0,#OBJDSGROUPE	JUMP,EQ 25$	COMP.B	D0,#OBJFUGROUPE	; fin d'un groupe ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D0,#OBJFSGROUPE	; non => 30$	JUMP,NE 30$50$:	DEC.W	D1		; fin de groupe imbrique ?	JUMP,NE 30$		; oui => 30$90$:	POPM.L	D0..D6,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; GNXTBASE >;=========/; Cherche l'lment suivant.; Un groupe compte ici comme UN lment.; in	A4.L	^lment; out	A4.L	^lment suivant;	D7.W	erreur; mod	D7.W, A4.LGNXTBASE:	PUSHM.L	D0,D1	LOAD.W	D0,(A4)+OMOBJET	COMP.B	D0,#OBJDUGROUPE	JUMP',EQ 20$	COMP.B	D0,#OBJDSGROUPE	JUMP',NE 80$20$:				; dbut d'un groupe =>	CLR.W	D125$:	INC.W	D1		; D1 <-- une fin de groupe de plus attendue30$:;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP',NE 90$	LOAD.W	D0,(A4)+OMOBJET	COMP.B	D0,#OBJDUGROUPE	; dbut d'un groupe imbriqu ?	JUMP,EQ 25$		; oui => 25$	COMP.B	D0,#OBJDSGROUPE	JUMP,EQ 25$	COMP.B	D0,#OBJFUGROUPE	; fin d'un groupe ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D0,#OBJFSGROUPE	; non => 30$	JUMP,NE 30$50$:	DEC.W	D1		; fin de groupe imbrique ?	JUMP,NE 30$		; oui => 30$80$:				; non =>;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE90$:	POPM.L	D0,D1	TEST.W	D7		; retour EQ/NE	RET;--------\; STOCKE  >;========/; Stocke les paramtres d'une zone de recherche dans le; bloc-notes.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche; out	D7.W	erreur; mod	D7.WSTOCKE:	LOAD.L	(A6)+OSTKP1,D3	LOAD.L	(A6)+OSTKP2,D4	CLR.W	D7		; D7 <-- ok	RET;--------\; ISTOCKE >;========/; Vide le bloc-notes.; in	-; out	D7.W	erreur; mod	D7.WISTOCKE:	CLR.L	(A6)+OSTKP1	CLR.L	(A6)+OSTKP2	CLR.W	D7		; D7 <-- ok	RET;--------\\; CREFILL >;========/; Cre plusieurs trames rectangulaires pour remplir une; surface quelconque.; Les trames cres ne sont pas dessines, car c'est dj; fait par GRA_FILLO !; in	A4.L	^table rendue par GRA_FILLO; out	D7.W	erreur; mod	D7.WCREFILL:	PUSHM.L	D2,D3,D4,A4	PUSH.W	(A6)+OPAS	; sauve le pas	CLR.W	(A6)+OPAS	; met pas=1	CLR.W	D7		; D7 <-- ok;;;;;	TEST.B	(A6)+OPLANAV+OFLAGS:#BTEMP ; trait de construction ?;;;;;	JUMP,BS	90$		; oui => 90$				; non =>;;;	CALL	AJOUTEDS	; cre un dbut de groupe systme	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJDS	.W	PLANA_BASE	LOAD.W	(A6)+OFMINX,#-1	; rien encore  crer10$:	ADD.L	A4,#LGRAF	; A4 <-- ^trame suivante	COMP.W	(A4),#-1	; fin de la table ?	JUMP,EQ	80$		; oui => 80$	LOAD.W	D3,(A4)+OGRAFY	; D3 <-- Y dbut	ADD.W	D3,(A6)+OPLANAV+OMINY	LOAD.W	D4,D3	SWAP.W	D3	INC.W	D4		; D4 <-- Y fin	SWAP.W	D4	LOAD.W	D3,(A4)+OGRAFXD	; D3 <-- X dbut	ADD.W	D3,(A6)+OPLANAV+OMINX	LOAD.W	D4,(A4)+OGRAFXF	ADD.W	D4,(A6)+OPLANAV+OMINX	INC.W	D4		; D4 <-- X fin	CALL	CONVCMO	EX.L	D4,D3	CALL	CONVCMO;	EX.L	D3,D4;;;	CALL	ORDONNE		; D3 <-- plus petit, D4 <-- plus grand	.W	PLANA_ORDONNE	COMP.W	D3,(A6)+OFMINX	JUMP',NE 50$	COMP.W	D4,(A6)+OFMAXX	JUMP',NE 50$	LOAD.L	D2,D3	SWAP.W	D2		; D2 <-- Y dbut (fin = +1)	INC.W	D2	COMP.W	D2,(A6)+OFMINY	; juste en bas ?	JUMP',EQ 40$		; oui => 40$	DEC.W	D2	COMP.W	D2,(A6)+OFMAXY	; juste en haut ?	JUMP',EQ 42$		; oui => 42$	JUMP'	50$40$:	DEC.W	(A6)+OFMINY	; descend le bas	JUMP	10$42$:	INC.W	(A6)+OFMAXY	; monte le haut	JUMP	10$50$:	CALL	CROFILL		; cre un objet	JUMP',NE 90$		; si plein => 90$	LOAD.L	(A6)+OFMIN,D3	; mm. coordonne coin	LOAD.L	(A6)+OFMAX,D4	; mm. coordonne coin	JUMP	10$80$:	CALL	CROFILL		; cre un objet	JUMP',NE 90$;;;	CALL	AJOUTEFS	; cre une fin de groupe systme	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJFS	.W	PLANA_BASE90$:	POP.W	(A6)+OPAS	; reprend le pas initial	POPM.L	D2,D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CROFILL >;--------/; Cre une trame pour remplir une surface.; in	(A6)+OFMIN.L;	(A6)+OFMAX.L; out	D7.W	erreur; mod	D7.WCROFILL:	PUSHM.L	D0,D1,D2,D3,D4,A4	CLR.W	D7		; D7 <-- ok	COMP.W	(A6)+OFMINX,#-1	; qq chose  crer ?	JUMP',EQ 90$		; non => 90$	LOAD.W	D0,#OBJSURF	; D0 <-- objet surface	LOAD.W	D1,(A6)+OTRAME	; D1 <-- type de trame	LOAD.W	D2,(A6)+OMODE	; D2 <-- mode de dessin	LOAD.L	D3,(A6)+OFMIN	; D3 <-- coordonne coin	LOAD.L	D4,(A6)+OFMAX	; D4 <-- coordonne coin;;;	CALL	AJOUTE		; ajoute l'lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE90$:	POPM.L	D0,D1,D2,D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; FLUSH   >;========/; Vide tout le plan en mmoire.; in	-; out	-; mod	D7.WFLUSH:	CLR.W	(A6)+OPLANAV+OOWDOX	; remet fentre virtuelle	CLR.W	(A6)+OPLANAV+OOWDOY	; en haut  gauche.	CLR.W	(A6)+OPLANAV+OSCALE	; plus d'chelle	CALL	NEWSCALE	; signal nouvelle chelle	CLR.B	(A6)+OBUMEMF	; plus de nom de fichier;;;	CALL	CLRBASE		; vide la base de donnes	LOAD.W	(A6)+OPLANAV+OPLANA,#BCLRBASE	.W	PLANA_BASE	CALL	ISTOCKE		; vide le bloc-notes	RET;----------\; CLRFILTRE >;==========/; Supprime les bits BMNOT  tous les objets.; in	-; out	-; mod	D7.WCLRFILTRE:	PUSHM.L	D4,A4;;;	CALL	FIRBASE		; A4 <-- ^premier lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE	.W	PLANA_BASE	JUMP,NE	90$10$:	TCLR.B	(A4)+OMFLAGS:#BMNOT;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP,EQ	10$90$:	POPM.L	D4,A4	RET;----------\; SETFILTRE >;==========/; Met les bits BMNOT  tous les objets.; in	-; out	-; mod	D7.WSETFILTRE:	PUSHM.L	D4,A4;;;	CALL	FIRBASE		; A4 <-- ^premier lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE	.W	PLANA_BASE	JUMP,NE	90$10$:	TSET.B	(A4)+OMFLAGS:#BMNOT;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP,EQ	10$90$:	POPM.L	D4,A4	RET;;;;		.SBTTL	PLANOPBASE		; 28 juin 87 Sp.;--------\; INVMODE >		EXISTE AUSSI DANS PLANA.LIB !!!!;========/; Inverse le mode de dessin.; in	D2.B	mode de dessin; out	D2.B	mode inverse; mod	D2.BINVMODE:	PUSH.W	D1	LOAD.W	D1,D2		; D1 <-- mode/couleur	AND.B	D1,#H'0F	; D1 <-- mode actuel	AND.B	D2,#H'F0	; D2 <-- couleur actuelle	OR.B	D2,#MODCLR	COMP.B	D1,#MODSET	; SET --> CLR	JUMP',EQ 90$	AND.B	D2,#H'F0	; D2 <-- couleur actuelle	OR.B	D2,#MODSET	COMP.B	D1,#MODCLR	; CLR --> SET	JUMP',EQ 90$	AND.B	D2,#H'F0	; D2 <-- couleur actuelle	OR.B	D2,#MODINV	; non => INV90$:	POP.W	D1	RET;;;;	.END;;;;;;;;;; ALIGNE;;;;;;;;;;-------- GALIGNE:;--------;; permet de saisir la coordonne d'alignement;; in:	D6.B	choix pour aligner; out:	D0.L	coordonn d'alignement; mod:	D0.L, D7.W;	PUSHM.L	D2,D3,D4,D5,D6,A3,A4	CALL	IRETICULE	TCLR.B	(A6)+OFLRET:#BRETDE	CALL	SRMO	CALL	INIDXY	CALL	AFCMES	.B	USEGC,GCICF,GCICS,GCICT	.B	7,96,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" 'clic' aligne |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,97,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" inhibe le pas |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,98,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZE	" annule "	LOAD.L	D2,#+1*H'10000+0	; D2 <-- correction pour matrice	LOAD.L	A4,#R16"MALIH	COMP.B	D6,#0	JUMP',EQ 10$	LOAD.L	D2,#+7*H'10000+0	LOAD.L	A4,#R16"MALIHB	COMP.B	D6,#1	JUMP',EQ 10$	LOAD.L	D2,#+15*H'10000+0	LOAD.L	A4,#R16"MALIB	COMP.B	D6,#2	JUMP',EQ 10$	LOAD.L	D2,#1	LOAD.L	A4,#R16"MALIG	COMP.B	D6,#3	JUMP',EQ 10$	LOAD.L	D2,#7	LOAD.L	A4,#R16"MALIGD	COMP.B	D6,#4	JUMP',EQ 10$	LOAD.L	D2,#15	LOAD.L	A4,#R16"MALID	COMP.B	D6,#5	JUMP,NE	90$10$:	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE	LOAD.B	(A3)+0,#NUL	LOAD.B	(A3)+1,#DRAWPMOUSE	LOAD.L	(A3)+2,A4	CLR.L	(A3)+6	LOAD.B	(A3)+10,#AFSCMO	LOAD.W	D3,#11	LIB	?STRING20$:	LIB	?GETKEY	TEST.L	D3:#BKPSEUDO	JUMP,BS	20$	LIB	?IFMOUSE	ADD.W	D4,D2	SWAP.W	D4	SWAP.W	D2	ADD.W	D4,D2	SWAP.W	D4	SWAP.W	D2	LOAD.L	D5,D4				; ds. la fentre	COMP.W	D4,(A6)+OPLANAV+OMINX	JUMP,HS	21$	LOAD.W	D4,(A6)+OPLANAV+OMINX21$:	COMP.W	D4,(A6)+OPLANAV+OMAXX	JUMP,LO	22$	LOAD.W	D4,(A6)+OPLANAV+OMAXX	DEC.W	D422$:	SWAP.W	D4	COMP.W	D4,(A6)+OPLANAV+OMINY	JUMP,HS	23$	LOAD.W	D4,(A6)+OPLANAV+OMINY23$:	COMP.W	D4,(A6)+OPLANAV+OMAXY	JUMP,LO	24$	LOAD.W	D4,(A6)+OPLANAV+OMAXY	DEC.W	D424$:	SWAP.W	D4	COMP.L	D4,D5	JUMP,EQ	26$25$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	20$26$:;;;	LOAD.L	D5,D4	CALL	CONVCMO	JUMP,NE	25$	CALL	POSREGLE	CALL	_AFFXY	TEST.L	D3:#BMORIGHT		; bouton de droite annule	JUMP,BS	89$	TEST.L	D3:#BMOLEFT	JUMP,BC	20$35$:	TEST.L	D3:#BMOCENT	; bouton milieu inhibe le pas	JUMP',BS 40$	CALL	OARRONDI	; aligner sur le pas40$:	LOAD.L	D0,D4	JUMP	90$89$:	LOAD.W	D7,#-1	JUMP	91$90$:	CLR.W	D791$:PUSH.W	D7	LOAD.B	(A3)+0,#NUL		; remet matrice flche	LOAD.B	(A3)+1,#DRAWPMOUSE	CLR.L	(A3)+2	CLR.L	(A3)+6;;;	LOAD.B	(A3)+10,#AFCCMO	LOAD.W	D3,#10	LIB	?STRING;;	CALL	SCMOCALL	CRMOPOP.W	D7	POPM.L	D2,D3,D4,D5,D6,A3,A4	TEST.W	D7	RETMALIH:	.B 16 16	.B	B'00000000 B'00000000	.B	B'11111111 B'11111111	.B	B'00000001 B'10000000	.B	B'00000010 B'01000000	.B	B'00000100 B'00100000	.B	B'00001001 B'10010000	.B	B'00010011 B'11001000	.B	B'00100111 B'11100100	.B	B'01001111 B'11110010	.B	B'00011111 B'11111000	.B	B'00000001 B'10000000	.B	B'00000001 B'10000000	.B	B'00000001 B'10000000	.B	B'00000001 B'10000000	.B	B'00000001 B'10000000	.B	B'00000000 B'00000000	.EVENMALIB:	.B	16 16	.B	B'00000000 B'00000000	.B	B'00000001 B'10000000	.B	B'00000001 B'10000000	.B	B'00000001 B'10000000	.B	B'00000001 B'10000000	.B	B'00000001 B'10000000	.B	B'00011111 B'11111000	.B	B'01001111 B'11110010	.B	B'00100111 B'11100100	.B	B'00010011 B'11001000	.B	B'00001001 B'10010000	.B	B'00000100 B'00100000	.B	B'00000010 B'01000000	.B	B'00000001 B'10000000	.B	B'11111111 B'11111111	.B	B'00000000 B'00000000	.EVENMALIG:	.B	16 16	.B	B'01000000 B'00000000	.B	B'01000000 B'10000000	.B	B'01000001 B'00000000	.B	B'01000010 B'01000000	.B	B'01000100 B'11000000	.B	B'01001001 B'11000000	.B	B'01010011 B'11000000	.B	B'01100111 B'11111110	.B	B'01100111 B'11111110	.B	B'01010011 B'11000000	.B	B'01001001 B'11000000	.B	B'01000100 B'11000000	.B	B'01000010 B'01000000	.B	B'01000001 B'00000000	.B	B'01000000 B'10000000	.B	B'01000000 B'00000000	.EVENMALID:	.B	16 16	.B	B'00000000 B'00000010	.B	B'00000001 B'00000010	.B	B'00000000 B'10000010	.B	B'00000010 B'01000010	.B	B'00000011 B'00100010	.B	B'00000011 B'10010010	.B	B'00000011 B'11001010	.B	B'01111111 B'11100110	.B	B'01111111 B'11100110	.B	B'00000011 B'11001010	.B	B'00000011 B'10010010	.B	B'00000011 B'00100010	.B	B'00000010 B'01000010	.B	B'00000000 B'10000010	.B	B'00000001 B'00000010	.B	B'00000000 B'00000010	.EVENMALIGD:	.B	16 16	.B	B'00000001 B'00000000	.B	B'01000000 B'00000100	.B	B'00100001 B'00001000	.B	B'00010001 B'00010000	.B	B'01001001 B'00100100	.B	B'01100101 B'01001100	.B	B'01110001 B'00011100	.B	B'01111011 B'10111100	.B	B'01111011 B'10111100	.B	B'01110001 B'00011100	.B	B'01100101 B'01001100	.B	B'01001001 B'00100100	.B	B'00010001 B'00010000	.B	B'00100001 B'00001000	.B	B'01000000 B'00000100	.B	B'00000001 B'00000000	.EVENMALIHB:	.B	16 16	.B	B'00000000 B'00000000	.B	B'01001111 B'11110010	.B	B'00100111 B'11100100	.B	B'00010011 B'11001000	.B	B'00001001 B'10010000	.B	B'00000100 B'00100000	.B	B'00000001 B'10000000	.B	B'10111111 B'11111101	.B	B'00000001 B'10000000	.B	B'00000100 B'00100000	.B	B'00001001 B'10010000	.B	B'00010011 B'11001000	.B	B'00100111 B'11100100	.B	B'01001111 B'11110010	.B	B'00000000 B'00000000	.B	B'00000000 B'00000000	.EVEN;.END	ALIGNE.IF	GROUPETX;-------- GRTEXTE:;--------; in	D0.W	dbut ou fin de groupe;	A0	^buffer avec les car.  crire termin par 0;	A4	^nouvel lment; out	-; mod	-	PUSHM.L	D0,A4	LOAD.W	(A4+),D0		; dbut utilisateur	LOAD.W	D0,#(LGELEMENT-2)-1	; compteur01$:	COMP.B	(A0),#0			; copie 14 car. max. ou jusqu' 0	JUMP,EQ	02$	COMP.B	(A0),#CR	JUMP,EQ	02$	LOAD.B	(A4+),(A0+)	DECJ.W,NMO D0,01$02$:	POPM.L	D0,A4	RET.ENDIF	.END