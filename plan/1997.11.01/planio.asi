		.SBTTL	PLANIO		; 28 novembre 87 Sp.GCSF	=	1	; lors de 'ajoute' lit df. genc seulement			;     si police phys. inexistante;OGCFLG	devrait tre ds. DGENC BGCAJ	=	7	; bit nouveau: lors de 'ajoute' lit d'abord			; tous les genc et teste ensuite si pas utilis			; pour l'effacer si tel est le casBINPREND	=	0BINAJOUTE	=	1BINIDEM		=	2BINULIE		=	3BINSLIE		=	4BINUDELIE	=	5BINSDELIE	=	6BPLANPLAN	=	7	; PLAN.PLAN	.EVEN;--------\; IOHELP  >;========/; Affiche le fichier d'aide.; in	-; out	-; mod	D7.WIOHELP:	PUSH.L	A0	LOAD.L	A0,#(A6)+OPLANBV	; A0 ^ variables PLANB	PLANB_	HELP	CALL	AFMENU	POP.L	A0	RET;---------\\; PLOTOUT: >;---------/;; sort le plan en cours sur le traceur;; in	-; out	D7.W	erreur; mod	D7.W;PLOTOUT:	PUSHM.L	D0..D6,A0..A5	CALL	AFCMES	.ASCIZE	" un instant svp., initialisation du traceur en cours ..."	CALL	CWMO	CALL	SRMO	TEST.B	(A6)+OFLPLOT:#BPLOTON	; traage en cours ?	JUMP,BC	10$			; non, on y va ...					; oui	CALL	AFCMES	.ASCIZE	"arrt = finir les objets dj reus."	CALL	DBOX_PLOT		; PLOT en cours, faut-il arrter	JUMP,NE	90$	COMP.W	D3,#'N			; non, ==> 90$	JUMP,EQ	90$	COMP.W	D3,#'O			; oui, arrter	JUMP,NE	90$					; ARRETER	LOAD.W	D4,#1*50/2		; temporise un peu ...	NTREL	?DELMS	TEST.B	(A6)+OFLPLOT:#BPLOTON	; si fini entretemps ...	JUMP,BC	90$	PUSH.L	A5	LOAD.L	A5,(A6)+OPLOTD5		; A5 ^variables PLOT	TSET.B	(A5)+OTFLMOD+3:#BABORT	; signale fin au fils	POP.L	A5	JUMP	90$			; retour dans PLAN10$:	LOAD.W	D7,#ERPEM	COMP.W	(A6)+OPLANAV+OUBMEM,#4	JUMP,LS	90$			; rien dans la base !	LOAD.L	A3,#R16"NAMPLOT		; module PLOT	LOAD.W	D3,#PLOT_FIRST	.W	LIB_OPEN	JUMP,NE	90$	LOAD.W	(A6)+OCHPLOT,D120$:			; PLOT_OUVRE	CLR.L	D2			; D2 <-- mode	PLOT_	OUVRE	JUMP,NE	80$	LOAD.L	(A6)+OPLOTD5,D5		; mmorise 'canal'			; mmoire pour le PLAN en cours					; calcul de place ncessaire	CALL	NBTEMP			; D4 <-- nb. d'objets	COMP.W	D7,#ERPNF	JUMP,NE	70$	ADD.L	D4,#2			; ajoute nb. dfinitions	MUL.WU	D4,#LGELEMENT		; nb * 16 = nb bytes	LOAD.W	D1,#MTYPCP		; demande mmoire PLAN en cours	GESMEM	?GETMEM	JUMP,NE	70$	PUSHM.L	D4,A430$:	CLR.B	(A4+)			; met  zro buffer temp.	DEC.L	D4	JUMP,NE	30$	POPM.L	D4,A4	CALL	PLANTEMP		; transfert ds. buffer temp.	COMP.W	D7,#ERPNF	JUMP,NE	60$			; CREER PLOTFILS					; registres transmis au fils	LOAD.L	A1,A4			; A4 ^mmoire avec fichier.PLAN	LOAD.L	D1,D4			; D1.L <-- nbr. de bytes	CLR.L	D4	NTREL	?GETPRIO		; priorit infrieur  pre	INC.B	D4	AND.W	D4,#H'F	LOAD.L	A5,#R16"PFILSPLOT	; A5 <-- adresse de start	LOAD.L	A3,#R16"NFILSPLOT	; A3 <-- ^nom de PLOTFILS	LOAD.L	D5,#400			; lg. stack	NTREL	?CRETASK		; cre proc. fils	JUMP,NE	60$	LOAD.L	A0,(A6)+OPLOTD5		; l'initilaisation est longue,	TSET.B	(A0)+OTFLOPT+3:#BOPTION	; passe par dessus ... (?)40$:			; attend que le fils ait fini avec DBOX_OPTIONS	LOAD.W	D4,#1*50		; t'occupe un peu ...	NTREL	?DELMS	LOAD.L	A0,(A6)+OPLOTD5	TEST.B	(A0)+OTFLOPT+3:#BOPTION	; fini avec DBOX_OPTIONS	JUMP,BS	40$			; non, ==> 40$	CLR.W	D7	JUMP	90$; ERREURS ...60$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM			; libre mmoire temporaire	POP.W	D770$:					; fermer (PLOT_FERME)	PUSH.W	D7	LOAD.L	D5,(A6)+OPLOTD5	PLOT_	FERME	POP.W	D780$:	PUSH.W	D7	LOAD.W	D1,(A6)+OCHPLOT		; libre PLOT	.W	LIB_CLOSE	POP.W	D790$:	PUSH.W	D7	CALL	INIBAS	CALL	CRMO	POP.W	D7	POPM.L	D0..D6,A0..A5	TEST.W	D7	RET;**********************; PROCESSUS FILS PLOT ***;**********************NFILSPLOT:	.ASCIZE	/MODULE.PLOT/PFILSPLOT:	TSET.B	(A6)+OFLPLOT:#BPLOTON	; signale PLOT en cours					; registres transmis	LOAD.L	A4,A3			; A4 ^mm. fichier.PLAN	LOAD.L	D0,D7			; D0 longueur	LOAD.L	A0,(A6)+OPLOTD5	TCLR.B	(A0)+OTFLMOD+3:#BABORT	; initialise BABORT	LOAD.L	D5,(A6)+OPLOTD5		; D5 <-- canal	CLR.L	D2	TSET.L	D2:#BOPTION		; D2 <-- mode	PLOT_	TRACE	COMP.W	D7,#EROUTF		; si tout est ok.	JUMP,NE	FERR2FIN:	LOAD.B	D3,#BIPDONE		; signal sonore, c'est fait	LIB	?BEEPFERR2:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM			; rend mmoire fichier.PLAN					; v. erreur pas traite !!!	POP.W	D7FERR1:	PUSH.W	D7	LOAD.L	D5,(A6)+OPLOTD5	PLOT_	FERME	POP.W	D7	LOAD.W	(A6)+OERRPLOT,D0	; SAUVE POUR TRAITEMENT...					; ...en temps opportun par pre	LOAD.W	(A6)+Oerplot,D7		; ? pas fait pour l'instant ?80$:	LOAD.W	D1,(A6)+OCHPLOT		; ferme librairie PLOT	.W	LIB_CLOSE10$:	TCLR.B	(A6)+OFLPLOT:#BPLOTON	; signal PLOT termin	NTREL	?ABORT; *** fin de PLOTFILS; ******************.EVEN;---------\\; PLANTEMP >;---------/;; crit le PLAN dans un buffer temporaire;; in	A4.L	^zone mmoire;; out	D7.W	ereur;; mod	D7.W;PLANTEMP:	PUSHM.L	D1,D2,D5,A3,A4	LOAD.L	A3,A4			; A3 ^buffer temp. 'premier'	LOAD.L	(A3)+OMPAR2,(A6)+OPLANAV+OMWDOY	; dim. du PLAN	ADD.L	A3,#LGELEMENT		; A3 ^2e lment 'EDEF'	LOAD.B	(A3)+OMOBJET+1,#OBJEDEF		; 1	LOAD.B	(A3)+OMOBJET+0,#-1		; 0	LOAD.L	(A3)+OMRES,(A6)+OF64Y		; 12/13/14/15	LOAD.W	(A3)+OMPAR1,(A6)+OPLANAV+OCOULEUR	; 2/3	TEST.B	(A6)+OFLMOD:#BENMM	JUMP,BC	06$	TSET.B	(A3)+OMMODE:#1	JUMP	07$06$:	TSET.B	(A3)+OMMODE:#007$:					; les objets graphiques	ADD.L	A3,#LGELEMENT		; A3 ^3e lment;;;	CALL	FIRBASE		; A4 <-- ^premier lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE	.W	PLANA_BASE	JUMP',NE 40$					; initialiser couleurs	LOAD.W	D5,(A6)+OPLANAV+OCOULEUR ; D5 <-- flags des coul. visibles	TCLR.L	D5:#COUINVISI		; sauf couleur invisible30$:	LOAD.B	D2,(A4)+OMMODE		; D2 <-- couleur	SR.B	D2,#4	TEST.L	D5:D2			; couleur visible ?	JUMP,BC	35$			; non, suivant	COMP.B	(A4)+OMOBJET+1,#OBJDUGROUPE ; ignore groupes (100 et plus)	JUMP,HS	35$	PUSH.L	A4	LOAD.B	D1,#LGELEMENT		; copie de l'lment32$:	LOAD.B	(A3+),(A4+)	DEC.B	D1	JUMP,NE	32$	POP.L	A435$:;;;	CALL	NXTBASE			; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP,EQ	30$				; FIN de la BASE40$:			; SORTIE DE LA BOUCLE90$:	POPM.L	D1,D2,D5,A3,A4	TEST.W	D7	RET;-------\\; NBTEMP >;-------/;; donne le nb. d'objets  crire ds. buffer temporaire pour PLOT;; in	-; out	D4.L	nb.; mod	D4.L, D7.W;NBTEMP:	PUSHM.L	D2,D5,A4	CLR.L	D4	PUSH.L	D4;;;	CALL	FIRBASE			; A4 <-- ^premier lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE	.W	PLANA_BASE	JUMP',NE 40$	LOAD.W	D5,(A6)+OPLANAV+OCOULEUR ; D5 <-- flags couleurs visibles	TCLR.L	D5:#COUINVISI		; sauf couleur invisible30$:	LOAD.B	D2,(A4)+OMMODE		; D2 <-- couleur	SR.B	D2,#4	TEST.L	D5:D2			; couleur visible ?	JUMP,BC	35$			; non, suivant	COMP.B	(A4)+OMOBJET+1,#OBJDUGROUPE ; ignore les groupes (100 et plus)	JUMP,HS	35$	INC.L	(SP)35$:;;;	CALL	NXTBASE			; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP,EQ	30$				; FIN de la BASE40$:			; SORTIE DE LA BOUCLE	POP.L	D4	; rcuprer compteur sur stack90$:	POPM.L	D2,D5,A4	TEST.W	D7	RET;--------\; AOUTPUT >;========/; Sauve sur disque tout le dessin.; in	D4.L	fanions;	D2.W	mode	(0 pour F3 et; out	D7.W	erreur; mod	D7.WAOUTPUT:	PUSHM.L	D0..D6,A2..A5	CLR.W	(A6)+ONBOB	; aucun objet crit	CLR.B	(A6)+OBUTEMP	LOAD.L	A3,#(A6)+OBUTEMP	CALL	RCLFILE		; prend nom si existe	PUSH.L	A5		; stack <-- A5	CALL	DBOX_F3		; cre le fichier	POP.L	A5		; stack --> A5	JUMP,NE	90$	LOAD.W	D7,#1		; D7 <-- (END)	COMP.W	D3,#F1	JUMP,NE	90$	CALL	IOWAIT		; affiche "attendez..."	TEST.L	D4:#BOUTPLAN	; format "plan" ?	JUMP,BC 60$		; non => 60$				; SAUVE UN PLAN =>	PUSHM.L	D4,A3	CALL	SWMO		; met la souris "en attente"	CALL	WROPEN		; init pour criture	LOAD.L	D0,(A6)+OPLANAV+OMWDOY	; D0 <-- dimensions du plan (dy;dx)	CALL	DOUTPUT		; crit le premier objet	JUMP,NE	50$	CALL	TOUTPUT		; crit des dfinitions de trames	JUMP,NE	50$	CALL	POUTPUT		; crit des dfinitions de pinceaux	JUMP,NE	50$	CALL	GOUTPUT		; crit des dfinitions de gencars	JUMP,NE	50$	CALL	FOUTPUT		; crit des dfinitions de flches	JUMP,NE	50$	CALL	MOUTPUT		; crit des macros v. mmorises	JUMP,NE	50$	CALL	EOUTPUT		; crit facteurs et flags divers	JUMP,NE	50$;;;	CALL	FIRBASE		; A4 <-- ^premier lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE	.W	PLANA_BASE	JUMP,NE 40$30$:	CALL	OUTPUT		; crit un objet	JUMP',NE 50$	INC.W	(A6)+ONBOB	; un objet crit de plus;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP,EQ	30$40$:	CALL	WRCLOSE		; ferme fichier de sortie	POPM.L	D4,A3	JUMP,NE 90$	LOAD.L	D0,D4		; D0 <-- fanions pour fichier'!	TEST.L	D4:#BIMRIEN	; format "image" ?	JUMP,BS	90$		; non => 90$;;;	LOAD.L	A4,A5		; A4 <-- ^extension fanion 1	LOAD.L	A4,#R16"TXIMAGE	; extension .IMAGE	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	PUSH.L	D0	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier image (sans pravis !)	POP.L	D0	PUSH.L	D4	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	PUSH.L	D0	LOAD.L	D0,#FOS?CREATE	; cre le fichier.image	CALL	ERCALL	POP.L	D0	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL	POP.L	D0	POP.L	D4	TEST.W	D7	JUMP,NE 98$	JUMP'	65$50$:	PUSH.W	D7	CALL	WRCLOSE		; ferme fichier de sortie	POP.W	D7	POPM.L	D4,A3	JUMP	90$60$:				; SAUVE UNE IMAGE =>	CLR.W	D7		; D7 <-- ok	TEST.L	D4:#BIMRIEN	; format "image" ?	JUMP,BS	98$		; non => 98$65$:	LOAD.L	D0,D4		; D0 <-- fanions pour "!"	TEST.L	D4:#BIMDESS	; sans marges ?	JUMP,BC	96$;;;	CALL	PPLACE		; D3/D4 <- place occupe par dessin	LOAD.W	(A6)+OPLANAV+OPLANA,#FPLACE	.W	PLANA_FONC	JUMP,NE	98$	CALL	IMAOUT98$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	CALL	CWMO		; remet la souris normale	CALL	IOERROR		; affiche erreur si ncessaire;;;	TEST.W	(A6)+ONBOB	; un/qq objet(s) crit(s) ?;;;	JUMP',EQ 92$		; non => 92$;;;	CALL	STOFILE		; oui => mm nom si ok92$:	TSET.B	(A6)+OPLANAV+OFLAGS:#BMODIF ; plan en mmoire pas  jour	TEST.W	D7	JUMP,NE	95$		; si, ...	TCLR.B	(A6)+OPLANAV+OFLAGS:#BMODIF ; et plan en mmoire  jour	TEST.L	D0:#BOUTPLAN	; a-t-on sauv un plan ?	JUMP,BC	95$		; non ...	TEST.W	(A6)+ONBOB	; un qc/objet crit ?	JUMP',EQ 95$		; non => 95$				; oui =>	CALL	STOFILE		; mmorise le nom	LOAD.L	A4,#R16"TXPLAN	; A4 ^extension	LOAD.W	D3,#1		; force extension	LIB	?ADDEXT	CALL	EXCLOUT		; et crer fichier "!"95$:	PUSH.W	D7	CALL	INIHAUT	; refait le haut	CALL	INIBAS		; refait le bas	POP.W	D7	POPM.L	D0..D6,A2..A5	TEST.W	D7		; retour EQ/NE	RET96$:	TEST.L	D4:#BIMECR	; image de l'cran ?	JUMP,BC	97$		; non ...	LOAD.W	D3,(A6)+OPLANAV+OOWDOY	; oui	SWAP.W	D3	LOAD.W	D3,(A6)+OPLANAV+OOWDOX	LOAD.L	D4,D3	ADD.W	D4,(A6)+OPLANAV+OSWDOX	SWAP.W	D4	ADD.W	D4,(A6)+OPLANAV+OSWDOY	SWAP.W	D4	FOS	?CLOSE		; fichier de lg nulle existe	CALL	IOUTPUT	JUMP	90$97$:	TEST.L	D4:#BIMPLAN	JUMP,BC	98$	CLR.L	D3	LOAD.L	D4,(A6)+OPLANAV+OMWDOY	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	CALL	IMAOUT	JUMP	98$;-------------- fichier!PLAN;----------\\  EXCLOUT: ;>;==========/; crit le fichier "!" pour START;; in 	A3 ^nom de fichier avec extension svp.;;	PUSHM.L	D3,D4,D6,A2,A3;;;	LOAD.L	A4,#R16"TXPLAN	; A4 ^extension;;;	LOAD.W	D3,#1		; force extension;;;	LIB	?ADDEXT	LOAD.B	D3,(A3)	JUMP,EQ	90$		; pas de nom	LOAD.L	A2,A3	PUSH.L	A310$:	LOAD.B	D3,(A3)	COMP.B	D3,#':		; A2 ^':	JUMP,NE	11$	LOAD.L	A2,A3	INC.L	A2		; A2 ^aprs le ':11$:	LIB	?MINMAJ		; en MAJUSCULES svp.	LOAD.B	(A3+),D3	COMP.B	D3,#'.	JUMP,NE	10$		LOAD.B	(A3)-1,#'!	; trouv '. et mettre '!  la place	POP.L	A3	FOS	?DELETE		; dtruit le fichier sans pravis	test.b	(a6)+Oflio:#BNOEXCL	JUMP,BS	90$	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	TCLR.L	D3:#BATTX	;	-X	TCLR.L	D3:#BATTC	;	-C	TCLR.L	D3:#BATTL	;	-L	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	FOS	?CREATE		; cre fichier!PLAN	JUMP,NE	80$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouverture, D6 <-- canal	JUMP,NE	80$	LIB	?PCHDIS		; canal  LIB pour criture	LIB	?BUCAR	LOAD.L	A3,A2		; A3 ^aprs un v. ':	PUSH.L	A320$:	LOAD.B	D3,(A3+);;;;;	JUMP,EQ	90$		; pas trouv	COMP.B	D3,#'!	JUMP,NE	20$		LOAD.B	(A3)-1,#0	; trouv '! et mettre 0  la place	POP.L	A3	LIB	?AFTIM	.ASCII	/"gnrateurs de caractres"/	.ASCII	"/1/E<CR>"	.ASCII	/"v. l'image du mme nom"/	.ASCIZE	"/2/A<CR>"	PUSH.L	A3	LIB	?AFTEXT		; le nom suivi de !PLAN ...	POP.L	A3	LIB	?AFTIM	.ASCIZE	"!PLAN/D -CL<CR>"	PUSH.L	A3	LIB	?AFTEXT		; le nom suivi de .PLAN ...	POP.L	A3	LIB	?AFTIM	.ASCIZE	".PLAN/D -C+L<CR>"	PUSH.L	A3	LIB	?AFTEXT		; le nom suivi de .IMAGE ...	POP.L	A3	LIB	?AFTIM	.ASCIZE	".IMAGE/D/N/2 -C+L<CR>"	CALL	EXCLGENC	; crire les genc	LIB	?NOBUCAR	PUSH.W	D6	LOAD.W	D6,(A6)+OPLANAV+OCHDIS	; redonne canal cran  LIB	LIB	?PCHDIS	POP.W	D6	FOS	?CLOSE		; ferme fichier80$:	CALL	IOERROR90$:	POPM.L	D3,D4,D6,A2,A3	RET;--------- EXCLGENC:;---------; 'affiche' (crit ds. fichier) les genc	PUSHM.L	D0,D4,D6,A3,A4	LOAD.L	A4,#(A6)+OPLANAV+OBUGC	; A4 ^buffer genc	LOAD.W	D0,#MAXGC	CLR.L	(A6)+OSPLPT		; buffer quelconque pour GCEXISTE	LOAD.L	A3,#(A6)+OPLANAV+OBWRITE ; A3 ^buffer criture10$:	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP,BC	40$	LOAD.L	D4,(A4)+OGCCOD		; D4 <-- "-fst"	AND.L	D4,#H'00FFFFFF	TCLR.L	D4:#16+7		; met 'laser'	JUMP,BC	11$	AND.W	D4,#H'80FF		; calcul, met "roman"	OR.W	D4,#H'100*'R11$:	CALL	GCEXIST			; dj rencontr ?	JUMP,EQ	40$			; oui, suivant	DGENC_	PUT			; OBWRITE <-- "fsctt"	PUSH.L	A313$:	LOAD.B	D3,(A3)	LIB	?MINMAJ	LOAD.B	(A3+),D3		; en MAJUSCULES svp.	JUMP,NE 13$	POP.L	A3;;	JUMP,NE	40$	LIB	?AFTIM	.ASCIZE	"SMA_"	LIB	?AFTEXT	LIB	?AFTIM	.ASCIZE	".GENC/N/1<CR>"40$:	LOAD.L	A4,#(A4)+LGGC		; A4 ^suivant	DEC.W	D0	JUMP,NE	10$	POPM.L	D0,D4,D6,A3,A4	RET;--------; GCEXIST;--------; Regarde si le gencar a dj t rencontr une fois.; in	D4.L	"-fst"; out	D7.W	EQ si existe dj; mod	D7.WGCEXIST:	PUSH.L	A4	LOAD.L	A4,#(A6)+OSPLPT	; buffer quelconque taille min. 11*410$:	TEST.L	(A4)		; fin ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.L	D4,(A4+)	; gencar trouv ?	JUMP,NE 10$		; non => 10$				; oui =>	CLR.W	D7		; D7 <-- gencar trouv	JUMP'	90$50$:	LOAD.L	(A4+),D4	; OBUDIS <-- gencar	CLR.L	(A4)		; OBUDIS <-- terminateur	LOAD.W	D7,#1		; D7 <-- gencar n'existe pas90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;----- fin fichier!PLAN;--------\; SOUTPUT >;========/; Sauve sur disque le contenu d'une zone de recherche; sous forme d'un plan ou d'une image.; in	D3.L	coordonne coin zone de recherche;	D4.L	coordonne coin zone de recherche; out	D7.W	erreur; mod	D7.WSOUTPUT:	PUSHM.L	D0..D6,A2..A5	LOAD.L	D0,D3	LOAD.L	D1,D4	LOAD.L	A3,#(A6)+OBUTEMP1	CLR.B	(A3)	LOAD.L	D4,#2^BOUTPLAN;	LOAD.W	D2,#2^BDBMOU	; D2 <-- centre DBOX selon souris	CLR.L	D2	PUSH.L	A5	CALL	DBOX_MSAUVE	; cre le(s) fichier(s)	POP.L	A5	JUMP,NE	90$	COMP.W	D3,#F1	JUMP,NE	90$	CALL	IOWAIT		; affiche "attendez..."	TEST.L	D4:#BOUTPLAN	; format "plan" ?	JUMP,BC	60$		; non => 60$				; SAUVE UN PLAN =>	PUSHM.L	D0,D1,D4,A3	CALL	SWMO		; met la souris "en attente"	CALL	WROPEN		; init pour criture	LOAD.L	D3,D0	LOAD.L	D4,D1;;;	CALL	ORDONNE		; D3 <-- sup-g.  D4 <-- inf-d.	.W	PLANA_ORDONNE	LOAD.L	D6,D3		; D6 <-- offset correctif	NEG.W	D6	SWAP.W	D6	NEG.W	D6	SWAP.W	D6	EX.L	D4,D6	CALL	OARRONDI	; arrondi l'offset	EX.L	D6,D4	LOAD.W	D0,D4	SUB.W	D0,D3		; D0 <-- <dxx>	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,D4	SUB.W	D0,D3		; D0 <-- <dyy>	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	CALL	DOUTPUT		; crit le premier objet	JUMP,NE	50$	CALL	TOUTPUT		; crit des dfinitions de trames	JUMP,NE	50$	CALL	POUTPUT		; crit des dfinitions de pinceaux	JUMP,NE	50$	CALL	GOUTPUT		; crit des dfinitions de gencars	JUMP,NE	50$	CALL	FOUTPUT		; crit des dfinitions de flches	JUMP,NE	50$	CALL	MOUTPUT		; crit macros v. mmorises	JUMP,NE	50$	CALL	EOUTPUT		; crit dimensions et flags	JUMP,NE	50$;;;	CALL	FIRBASE		; A4 <-- ^premier lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BFIRBASE	.W	PLANA_BASE	JUMP',NE 45$30$:;;;	CALL	DETECTE		; dans zone de recherche ?	LOAD.W	(A6)+OPLANAV+OPLANA,#BDETECTE	.W	PLANA_BASE	JUMP,NE 40$		; non => 40$				; oui =>	PUSHM.L	D3,D4,A4	CALL	COPYBT		; A4 <-- ^objet dans buf. temp.;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	LOAD.B	(A6)+OPLANAV+ORCOIN,#-1	; tous les coins trouvs;;;	CALL	AJUSTE		; ajuste selon l'offset	LOAD.W	(A6)+OPLANAV+OPLANA,#FAJUSTE	.W	PLANA_FONC;;;	CALL	MET		; objet <-- registres	LOAD.W	(A6)+OPLANAV+OPLANA,#BMET	.W	PLANA_BASE	CALL	OUTPUT		; crit un objet	POPM.L	D3,D4,A4	JUMP,NE 50$40$:;;;	CALL	NXTBASE		; A4 <-- ^lment suivant	LOAD.W	(A6)+OPLANAV+OPLANA,#BNXTBASE	.W	PLANA_BASE	JUMP,EQ	30$45$:	CALL	WRCLOSE		; ferme fichier de sortie	POPM.L	D0,D1,D4,A3	JUMP,NE 90$	TEST.L	D4:#BIMDESS	JUMP,BC	90$		; non => 90$;;;	LOAD.L	A4,A5		; A4 <-- ^extension fanion 1	LOAD.L	A4,#R16"TXIMAGE	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	PUSH.L	D0	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier image (sans pravis !);;;	POP.L	D0;;;	PUSH.L	D0	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier.image	POP.L	D0;;;	JUMP,NE 90$	JUMP'	65$50$:	PUSH.W	D7	CALL	WRCLOSE		; ferme fichier de sortie	POP.W	D7	POPM.L	D0,D1,D4,A3	JUMP	90$60$:				; SAUVE UNE IMAGE =>	FOS	?CLOSE		; fichier de lg nulle existe	CLR.W	D7		; D7 <-- ok	TEST.L	D4:#BIMDESS	JUMP,BC	90$		; non => 90$65$:	LOAD.L	D3,D0	LOAD.L	D4,D1	CALL	IOUTPUT		; sauve l'image90$:	CALL	CWMO		; remet la souris normale	CALL	IOERROR		; affiche erreur si ncessaire	PUSH.W	D7	CALL	INIBAS		; refait le bas	POP.W	D7	POPM.L	D0..D6,A2..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOUTPUT >;========/; Sauve une image sur disque.; in	D3.L	un coin de l'image;	D4.L	l'autre coin de l'image;	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WIOUTPUT:	PUSHM.L	D2..D5;;;	CALL	ORDONNE		; D3 <-- sup-g.  D4 <-- inf-d.	.W	PLANA_ORDONNE; Si les dimensions du dessin dpassent la partie visible, tronque pour; ne jamais dpasser la partie visible.	LOAD.W	D2,(A6)+OPLANAV+OOWDOX	COMP.W	D3,D2	JUMP',HS 20$	LOAD.W	D3,D2		; D3 <-- tronque  gauche20$:	ADD.W	D2,(A6)+OPLANAV+OSWDOX	COMP.W	D4,D2	JUMP',LO 21$	LOAD.W	D4,D2		; D4 <-- tronque  droite21$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A6)+OPLANAV+OOWDOY	COMP.W	D3,D2	JUMP',HS 22$	LOAD.W	D3,D2		; D3 <-- tronque en haut22$:	ADD.W	D2,(A6)+OPLANAV+OSWDOY	COMP.W	D4,D2	JUMP',LO 23$	LOAD.W	D4,D2		; D4 <-- tronque en bas23$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- largeur	SUB.W	D3,(A6)+OPLANAV+OOWDOX	; D3 <-- origine relative X	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur	SUB.W	D3,(A6)+OPLANAV+OOWDOY	; D3 <-- origine relative Y	ADD.W	D3,D4		; D3 <-- coin en haut !	SWAP.W	D3	SWAP.W	D4;;;	CALL	D4SCALE		; D4 <-- tient compte de l'chelle	.W	PLANA_D4SCALE	EX.L	D4,D3;;;	CALL	D4SCALE		; D3 <-- tient compte de l'chelle	.W	PLANA_D4SCALE;;;	CALL	YINVERSE	; D4 <-- inverse le sens de Y	.W	PLANA_YINVERSE	EX.L	D3,D4; Tient compte des modulos 8 en X et 2 en Y, pour ventuellement augmenter; l'image, mais jamais la diminuer !	LOAD.W	D2,D3	AND.W	D2,#B'111	; D2 <-- lg  reculer  gauche	SUB.W	D3,D2	ADD.W	D4,D2	ADD.W	D4,#8-1	AND.B	D4,#B'11111000	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,D3	AND.W	D2,#B'1		; D2 <-- lg  remonter en haut	SUB.W	D3,D2	ADD.W	D4,D2	ADD.W	D4,#2-1	AND.B	D4,#B'11111110	SWAP.W	D3	SWAP.W	D4; Tient compte du cadre de PLAN.	ADD.W	D3,(A6)+OPLANAV+OMINX	SWAP.W	D3	ADD.W	D3,(A6)+OPLANAV+OMINY	SWAP.W	D3	PUSHM.L	D3,D4	LIB	?GETWDO	POPM.L	D3,D4	LOAD.W	D2,D5		; D2 <-- s-wdo actuelle	CALL	IRETICULE	; enlve le rticule si ncessaire	CALL	CCMO		; supprime flche de la souris	LIB	?CREWDO		; cre s-wdo temporaire	JUMP',NE 85$	LIB	?USEWDO		; utilise s-wdo temporaire	JUMP',NE 80$	CLR.W	D3		; D3 <-- s-wdo utilise	LIB	?PFDUMP		; cre un fichier dump ...80$:	PUSH.W	D7	EX.L	D5,D2	LIB	?USEWDO		; r-utilise s-wdo originale	LOAD.W	D5,D2	LIB	?KILWDO		; dtruit s-wdo temporaire	POP.W	D785$:	PUSH.W	D7	CALL	SCMO		; remet flche de la souris	CALL	IRETICULE	; remet le rticule si ncessaire	POP.W	D790$:	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DOUTPUT >;========/; Ecrit le premier objet des dfinitions.; in	D0.L	dimensions du plan (dy;dx); out	D7.W	erreur; mod	D7.WDOUTPUT:	PUSHM.L	D1,A2,A4	LOAD.L	A4,#(A6)+OBUIO+LGELEMENT	LOAD.B	D1,#LGELEMENT20$:	CLR.B	(-A4)		; OBUIO <-- rempli de zro	DEC.B	D1	JUMP,NE	20$	LOAD.B	(A4)+OMOBJET+1,(A6)+OOBJET+1	LOAD.B	(A4)+OMOBJET+0,(A6)+OFLECHE+1	LOAD.B	(A4)+OMTRAI,(A6)+OTRAIT+1	LOAD.B	(A4)+OMMODE,(A6)+OMODE+1	LOAD.B	(A4)+OMPAR1+3,(A6)+OPAS+1	LOAD.B	(A4)+OMPAR1+2,(A6)+OTEXTE+1	TEST.B	(A6)+OPLANAV+OFLAGS:#BGRILLE	JUMP',BC 30$	TSET.B	(A4)+OMPAR1+1:#030$:	TEST.B	(A6)+OPLANAV+OFLAGS:#BMEMCAS	JUMP',BC 40$	TSET.B	(A4)+OMPAR1+1:#240$:	TEST.B	(A6)+OFLRET:#BRETICULE	JUMP',BC 50$	TSET.B	(A4)+OMPAR1+1:#350$:	TEST.B	(A6)+OFLMOD:#BICADRE	JUMP',BC 60$	TSET.B	(A4)+OMPAR1+1:#460$:	TEST.B	(A6)+OFLMOD:#BMINGC	JUMP',BC 70$	TSET.B	(A4)+OMPAR1+1:#570$:	TEST.B	(A6)+OFLMOD:#BREGLE	JUMP',BC 80$	TSET.B	(A4)+OMPAR1+1:#680$:	TSET.B	(A4)+OMPAR1+1:#1 ; coordonne Y inverse !;	TSET.B	(A4)+OMPAR1+1:#7 ; bits 2..6 valides	TEST.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS	JUMP,BC	85$	TSET.B	(A4)+OMPAR1+1:#785$:	LOAD.L	(A4)+OMPAR2,D0	LOAD.L	A2,(A6)+OPLANAV+OPDDIS		; fond blanc: l'inverse p. cadre	TEST.B	(A2)+ODFMOD:#BFBLANC	JUMP,BC	90$	TNOT.B	(A4)+OMPAR1+1:#490$:	CALL	OUTPUT		; crit le premier objet	POPM.L	D1,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TOUTPUT >;--------/; Ecrit les dfinitions de toutes les trames.; in	-; out	D7.W	erreur; mod	D7.WTOUTPUT:	PUSH.L	D2	CLR.W	D2		; D2 <-- 1er numro de trame10$:	CALL	T1OUTPUT	; crit df. trame	JUMP',NE 90$	INC.W	D2		; D2 <-- numro suivant	COMP.W	D2,#TRMMAX	JUMP,LO	10$90$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; T1OUTPUT >;---------/; Ecrit une dfinition de trame.; in	D2.W	numro de la trame; out	D7.W	erreur; mod	D7.WT1OUTPUT:	PUSHM.L	D2,D4,A3	LOAD.L	A4,#(A6)+OBUIO+LGELEMENT	LOAD.W	D4,#LGELEMENT10$:	CLR.B	(-A4)		; OBUIO <-- plein de zro	DEC.W	D4	JUMP,NE	10$	LOAD.B	(A4)+OMTRAI,D2	LOAD.L	A3,#(A6)+OPLANAV+OBUTRA	; A3 <-- ^trames	MUL.WU	D2,#8	ADD.L	A3,D2		; A3 <-- ^la bonne trame	CLR.W	D7		; D7 <-- ok	TEST.L	(A3)+0		; trame vide ?	JUMP',NE 50$		; non => 50$	TEST.L	(A3)+4		; oui => 90$	JUMP',EQ 90$50$:	LOAD.W	(A4)+OMOBJET,#OBJTDEF	LOAD.L	(A4)+OMPAR1,(A3)+0	LOAD.L	(A4)+OMPAR2,(A3)+4	CALL	OUTPUT		; crit sur disque90$:	POPM.L	D2,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; POUTPUT >;--------/; Ecrit les dfinitions de tous les pinceaux.; in	-; out	D7.W	erreur; mod	D7.WPOUTPUT:	PUSH.L	D2	CLR.W	D2		; D2 <-- 1er numro de pinceau10$:	CALL	P1OUTPUT	; crit df. pinceau	JUMP',NE 90$	INC.W	D2		; D2 <-- numro suivant	COMP.W	D2,#PENMAX	JUMP,LO	10$90$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; P1OUTPUT >;---------/; Ecrit une dfinition de pInceau.; in	D2.W	numro du pinceau; out	D7.W	erreur; mod	D7.WP1OUTPUT:	PUSHM.L	D2,D4,A3	LOAD.L	A4,#(A6)+OBUIO+LGELEMENT	LOAD.W	D4,#LGELEMENT10$:	CLR.B	(-A4)		; OBUIO <-- plein de zro	DEC.W	D4	JUMP,NE	10$	LOAD.B	(A4)+OMTRAI,D2	LOAD.L	A3,#(A6)+OPLANAV+OBUPEN	; A3 <-- ^pinceaux	MUL.WU	D2,#8+2	ADD.L	A3,D2		; A3 <-- ^le bon pinceau	CLR.W	D7		; D7 <-- ok	TEST.L	(A3)+0		; pinceau vide ?	JUMP',NE 50$		; non => 50$	TEST.L	(A3)+4		; oui => 90$	JUMP',EQ 90$50$:	LOAD.W	(A4)+OMOBJET,#OBJPDEF	LOAD.L	(A4)+OMPAR1,(A3)+0	LOAD.L	(A4)+OMPAR2,(A3)+4	LOAD.W	(A4)+OMRES,(A3)+8 ; <e> et <m>	CALL	OUTPUT		; crit sur disque90$:	POPM.L	D2,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; FOUTPUT >;--------/; Ecrit les dfinitions de toutes les flches.; in	-; out	D7.W	erreur; mod	D7.WFOUTPUT:	PUSH.L	D2	CLR.W	D2		; D2 <-- 1er numro de flche10$:	CALL	F1OUTPUT	; crit df. flche	JUMP',NE 90$	INC.W	D2		; D2 <-- numro suivant	COMP.W	D2,#FLEMAX	JUMP,LO	10$90$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; F1OUTPUT >;---------/; Ecrit une dfinition de flche.; in	D2.W	numro de la flche; out	D7.W	erreur; mod	D7.WF1OUTPUT:	PUSHM.L	D2,D4,A3	LOAD.L	A4,#(A6)+OBUIO+LGELEMENT	LOAD.W	D4,#LGELEMENT10$:	CLR.B	(-A4)		; OBUIO <-- plein de zro	DEC.W	D4	JUMP,NE	10$	LOAD.B	(A4)+OMTRAI,D2	LOAD.L	A3,#(A6)+OPLANAV+OBUFLE	; A3 <-- ^flches	MUL.WU	D2,#4	ADD.L	A3,D2		; A3 <-- ^la bonne flche	CLR.W	D7		; D7 <-- ok	TEST.L	(A3)		; flche vide ?	JUMP',EQ 90$		; oui => 90$	LOAD.W	(A4)+OMOBJET,#OBJFDEF	LOAD.L	(A4)+OMPAR1,(A3)	CALL	OUTPUT		; crit sur disque90$:	POPM.L	D2,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; GOUTPUT >;--------/; Ecrit les dfinitions de tous les gencars.; in	-; out	D7.W	erreur; mod	D7.WGOUTPUT:	PUSHM.L	D0,A0	LOAD.L	A0,#(A6)+OPLANAV+OBUGC	; A0 <-- ^buffer des gencars	LOAD.W	D0,#MAXGC	CLR.W	D7		; D7 <-- ok10$:	TEST.B	(A0)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BC 30$		; non => 30$				; oui =>	CALL	G1OUTPUT	; crit df. gencar	JUMP',NE 90$30$:	LOAD.L	A0,#(A0)+LGGC	; A0 <-- ^suivant	DEC.W	D0	JUMP,NE	10$90$:	POPM.L	D0,A0	TEST.W	D7		; retour EQ/NE	RET;---------\\; G1OUTPUT >;---------/; Ecrit une dfinition de gencar.; in	A0.L	^gencar; out	D7.W	erreur; mod	D7.WG1OUTPUT:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A4,#(A6)+OBUIO+LGELEMENT	LOAD.W	D4,#LGELEMENT10$:	CLR.B	(-A4)		; OBUIO <-- plein de zro	DEC.W	D4	JUMP,NE	10$	LOAD.W	(A4)+OMOBJET,#OBJGDEF	LOAD.L	D3,(A0)+OGCCOD	; D3 <-- "-fst"	SL.L	D3,#8		; D3 <-- "fst-"	LOAD.L	(A4)+OMPAR1,D3	; <f> <s> <t> <0>	LOAD.L	A2,#(A0)+OGCTIT	; A2 <-- ^titre du gencar	LOAD.L	A3,#(A4)+OMPAR2	LOAD.W	D3,#LGELEMENT-OMPAR240$:	DEC.W	D3	JUMP',EQ 50$	LOAD.B	(A3+),(A2+)	JUMP,NE 40$50$:	CLR.B	(A3)	CALL	OUTPUT		; crit sur disque90$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------  EOUTPUT:;---------; Ecrit un objet avec 'dimensions' et flags; in	-; out	D7.W	erreur; mod	D7.W	PUSHM.L	A4	LOAD.L	A4,#(A6)+OBUIO+LGELEMENT	LOAD.B	D1,#LGELEMENT20$:	CLR.B	(-A4)		; OBUIO <-- rempli de zro	DEC.B	D1	JUMP,NE	20$	LOAD.B	(A4)+OMOBJET+1,#OBJEDEF		; 1	LOAD.B	(A4)+OMOBJET+0,#-1		; 0	LOAD.L	(A4)+OMRES,(A6)+OF64Y		; 12/13/14/15	LOAD.W	(A4)+OMPAR1,(A6)+OPLANAV+OCOULEUR	; 2/3	TEST.B	(A6)+OFLIO:#BOUTPLAN	JUMP,BC	30$	TSET.B	(A4)+OMPAR1+3:#0	; 530$:	TEST.B	(A6)+OFLIO:#BIMRIEN	JUMP,BC	31$	TSET.B	(A4)+OMPAR1+3:#131$:	TEST.B	(A6)+OFLIO:#BIMECR	JUMP,BC	32$	TSET.B	(A4)+OMPAR1+3:#232$:	TEST.B	(A6)+OFLIO:#BIMPLAN	JUMP,BC	33$	TSET.B	(A4)+OMPAR1+3:#333$:	TEST.B	(A6)+OFLIO:#BIMDESS	JUMP,BC	34$	TSET.B	(A4)+OMPAR1+3:#434$:35$:	TEST.B	(A6)+OFLMOD:#BENMM	JUMP,BC	36$	TSET.B	(A4)+OMMODE:#1	JUMP	37$36$:	TSET.B	(A4)+OMMODE:#037$:	CALL	OUTPUT		; crit l'objet	POPM.L	A4	TEST.W	D7		; retour EQ/NE	RET;--------\\ APREND: ;>;--------/; prend un fichier.PLAN avec sauvetage de l'existant si ncessaire; met  jour les dfinitions en fonction du premier objet lu; in	-; out	-; mod	D7.W;	PUSHM.L	D2,D3,D4,A2,A3,A4,A510$:;;	LOAD.L	A2,#R16"TDBOX_PREND	LOAD.L	A3,#(A6)+OBUINPF	CLR.B	(A3)		; efface un nom en mmoire;;	CLR.L	D4;;	TSET.L	D4:#BINPREND	; met fanion prend	LOAD.L	D4,#2^BINPREND!BINIDEM11$:	LOAD.L	A4,#R16"TXPLAN	; A4 <-- ^extension	CLR.W	D2		; D2 <-- DBOX au milieu fentre	CALL	DBOXEDITI	; attend un nom de fichier	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$				; PREND =>	LOAD.W	D0,#1		; D0 <-- avant de reprendre	CALL	DBOXSAVE	; sauve plan actuel si ncessaire	JUMP',NE 90$		; l'utilisateur veut pas => 90$	call	inidef		; initialise objets par dfaut	call	killallgc	; dtruit tous les gencars	CALL	FLUSH		; vide tout en mmoire	CALL	EFFACE		; efface l'cran;;	CLR.L	D4;;	TSET.L	D4:#BINPREND	; force mode prend pour srLOAD.L	D4,#2^BINPREND!2^BINIDEMLOAD.L	A5,#(A6)+OPLANAV	CALL	XINPUT		; lit le super-objet	JUMP',EQ 30$	TEST.L	D7:#16		; erreur lors de l'ouverture ?	JUMP,BS 11$		; oui => 10$	JUMP'	90$		; non => 90$30$:	TCLR.B	(A6)+OPLANAV+OFLAGS:#BMODIF;	JUMP'	90$90$:	PUSH.W	D7	CALL	INIHAUT		; refait le haut	CALL	INIBAS		; refait le bas	POP.W	D7	POPM.L	D2,D3,D4,A2,A3,A4,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\ AAJOUTE: ;>;---------/; ajoute un fichier.PLAN;; in	-; out	D7.W; mod	D7.W;	PUSHM.L	D2,D3,D4,A2,A3,A4,A510$:;;;	LOAD.L	A2,#R16"TDBOX_AJOUTE	LOAD.L	A3,#(A6)+OBUINPF	CLR.B	(A3)	CLR.L	D4;;	TSET.L	D4:#BINAJOUTE	; D4 <-- fanions ajoute	TSET.L	D4:#BINIDEM	;		et idem par dfaut;10$:	LOAD.L	A4,#R16"TXPLAN	; A4 <-- ^extension	CLR.W	D2		; D2 <-- DBOX au milieu fentre	CALL	DBOXEDITA	; attend un nom de fichier	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	TCLR.L	D4:#BINPREND	; pour tre sr	TSET.L	D4:#BINAJOUTE50$:				; AJOUTE =>	CALL	XINPUT		; lit le super-objet	JUMP',EQ 90$	TEST.L	D7:#16		; erreur lors de l'ouverture ?	JUMP,BS 10$		; oui => 10$90$:	PUSH.W	D7	CALL	INIHAUT		; refait le haut	CALL	INIBAS		; refait le bas	POP.W	D7	POPM.L	D2,D3,D4,A2,A3,A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\; FCINPUT >;========/; Lit un super-objet au milieu du plan de dessin.; Met  jour les paramtres en fonction du premier objet lu.; Cette routine est utilise pour lire le plan donn dans; la ligne de commande.; in	A3.L	^nom de fichier brut; out	D7.W	erreur; mod	D7.WFCINPUT:	PUSHM.L	D3,A2,A3,A4	CALL	KILLALLGC	; il n' y aura que les gencars utilisateurs	LOAD.L	A4,#(A6)+OBUTEMP10$:	LOAD.B	D3,(A3+)	JUMP',EQ 20$	COMP.B	D3,#SPACE	; fin du nom ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D3,#CR	JUMP',EQ 20$	COMP.B	D3,#'.	JUMP',EQ 20$	LOAD.B	(A4+),D3	; buffer <-- un caractre	JUMP	10$20$:	CLR.B	(A4)		; buffer <-- terminateur	LOAD.L	A3,#(A6)+OBUTEMP	LOAD.L	A4,#R16"TXPLAN	; A4 <-- ^extension	LOAD.W	D3,#1		; D3 <-- force si dj ext.	LIB	?ADDEXT		; ajoute l'extension	JUMP',NE 90$	CLR.W	D4		; D4 <-- prend	CALL	XINPUT		; lit le super-objet	JUMP',NE 80$	TCLR.B	(A6)+OPLANAV+OFLAGS:#BMODIF80$:	PUSH.W	D7	CALL	INIHAUT		; refait le haut	CALL	INIBAS		; refait le bas	POP.W	D790$:	POPM.L	D3,A2,A3,A4	RET;--------\; XINPUT  >;========/; Lit un super-objet au milieu du plan de dessin.; Met  jour les paramtres en fonction du premier objet lu.; in	A3.L	^nom de fichier (avec extension);	D4.W	fanions; out	D7.W	erreur;	D7:#16	erreur lors de l'ouverture; mod	D7.LXINPUT:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	CALL	SWMO		; met la souris "en attente"	TCLR.B	(A6)+OFLIO:#BIOBGC	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	POP.L	D0	TSET.L	D7:#16		; D7 <-- erreur lors de l'ouverture	TEST.W	D7	JUMP,NE	95$	CALL	RDOPEN		; init pour lecture	LOAD.L	A4,#(A6)+OBUIO	CALL	INPUT		; lit le premier objet	JUMP,NE	41$	LOAD.W	(A6)+OINVYL,(A4)+OMPAR2+OYY	LOAD.B	(A6)+OINVYF,(A4)+OMPAR1+1	LOAD.W	D3,(A4)+OMPAR2+OXX	COMP.W	D3,(A6)+OPLANAV+OMWDOX	; plus large que dimensions courantes ?	JUMP',HI 10$	LOAD.W	D3,(A4)+OMPAR2+OYY	COMP.W	D3,(A6)+OPLANAV+OMWDOY	; plus haut que dimensions courantes ?	JUMP',HI 10$	TEST.L	D4:#BINAJOUTE	JUMP,BS	50$; Ajoute le fichier cas dans le coin infrieur gauche du plan.10$:	PUSH.W	D4		; stack <-- FANIONS	CLR.W	(A6)+ONBOB	; aucun objet lu	LOAD.W	D7,#ERPTB	; D7 <-- dbordement	TEST.L	D4:#BINAJOUTE	; mode "ajoute" ?	JUMP,BS	40$		; oui => 40$				; non =>	LOAD.B	(A6)+OOBJET+1,(A4)+OMOBJET+1	LOAD.B	(A6)+OFLECHE+1,(A4)+OMOBJET+0	LOAD.B	(A6)+OTRAIT+1,(A4)+OMTRAI	LOAD.B	(A6)+OMODE+1,(A4)+OMMODE	LOAD.B	(A6)+OTEXTE+1,(A4)+OMPAR1+2	LOAD.W	(A6)+OPLANAV+OMWDOX,(A4)+OMPAR2+OXX	LOAD.W	(A6)+OPLANAV+OMWDOY,(A4)+OMPAR2+OYY	CALL	AJMWDO		; ajuste OMWDOX,Y si trop petit	CALL	DINPUT		; lit les dfinitions	LOAD.L	D6,(A6)+OPLANAV+OOWDOY	; D6 <-- offset correctif (Y;X)	CALL	IOWAIT		; affiche "attendez..."	CALL	TINPUT		; lit dfinitions de trames	JUMP',NE 40$	CALL	PINPUT		; lit dfinitions de pinceaux	JUMP',NE 40$	CALL	GINPUT		; lit dfinitions de gencars;;;	JUMP',NE 40$	; continue, mme si inexistant etc.	CALL	FINPUT		; lit dfinitions de flches	JUMP',NE 40$	CALL	MINPUT		; lit les MACROS v.	JUMP,NE	40$	CALL	EINPUT		; lit dimensions et flags	JUMP',NE 40$	JUMP'	25$20$:	LOAD.L	A4,#(A6)+OBUIO	; A4 <-- ^buffer temporaire	CALL	INPUT		; lit un objet	JUMP',NE 40$;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE25$:	COMP.B	(A4)+OMOBJET,#-1 ; ignore objet de df.	JUMP',EQ 20$	CALL	IFLDGC		; charge gencar si ncessaire	CALL	INVY		; inverse la coordonne Y	LOAD.B	(A6)+OPLANAV+ORCOIN,#-1	; tous les coins trouvs;;;	CALL	AJUSTE		; ajuste selon l'offset	LOAD.W	(A6)+OPLANAV+OPLANA,#FAJUSTE	.W	PLANA_FONC;;;	CALL	ITTRAME		; translate si trame;;;	CALL	ITPEN		; translate si pinceau;;;	CALL	ITFLECHE	; translate si flche	LOAD.W	(A6)+OPLANAV+OPLANA,#FITRPTF	.W	PLANA_FONC;;;	CALL	MET		; objet <-- registres	LOAD.W	(A6)+OPLANAV+OPLANA,#BMET	.W	PLANA_BASE;;;	CALL	OPEBASE		; A4 <-- ^nouvel lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BOPEBASE	.W	PLANA_BASE	JUMP',NE 40$	INC.W	(A6)+ONBOB	; un objet lu de plus	CALL	COPYTB		; base donne <-- buffer temp.;;;	CALL	DESSINE		; dessine l'objet	.W	PLANA_DESSINE	JUMP,NC	20$40$:	POP.W	D1		; D1 <-- FANIONS41$:	PUSH.W	D7	CALL	RDCLOSE		; ferme fichier en entre	POP.W	D7	COMP.W	D7,#EROUTF	JUMP,NE	90$	LOAD.W	D7,#ERBGC	TEST.B	(A6)+OFLIO:#BIOBGC ; mauvais gencar lu ?	JUMP,BS 90$		; oui => 90$	CLR.W	D7	TEST.B	(A6)+OBUMEMF	; dj un nom mmoris ?	JUMP,NE	90$		; oui => 90$	TEST.W	(A6)+ONBOB	; un/qq objet(s) lu(s) ?	JUMP,EQ 90$		; non => 90$	CALL	STOFILE		; oui => mm nom si ok	JUMP	90$; Ajoute le plan  une position variable en fonction de la souris.50$:	TEST.L	D4:#BINPREND	; mode "prend" ?	JUMP',BC 52$		; non => 52$				; oui =>	CALL	EFFACE		; efface tout	CALL	REFAIT		; puis refait tout proprement52$:	PUSH.W	D4		; stack <-- fanions	LIB	?IFMOUSE	; D4 <-- position de la souris	CALL	CONVCMO		; D4 <-- position dans le plan	LOAD.L	D3,D4		; D3 <-- coin inf/gauche	ADD.W	D3,(A4)+OMPAR2+OXX	SWAP.W	D3	ADD.W	D3,(A4)+OMPAR2+OYY	SWAP.W	D3	LOAD.B	D2,#MODINV	; D2 <-- mode inverse	CLR.W	D1		; D1 <-- type de trait fin	CALL	TRECTANGLE	; dessine le rectangle dlimiteur	LOAD.L	D6,D4		; D6 <-- offset coin sup/droite	LOAD.L	D5,D3		; D5 <-- offset coin inf/gauche	CALL	SETFILTRE	; filtre tout ce qui existe dj	CALL	CWMO		; remet la souris normale	CALL	CCMO		; supprime flche souris	CALL	IOWAIT		; affiche "attendez..."	CALL	TINPUT		; lit dfinitions de trames	JUMP',NE 70$	CALL	PINPUT		; lit dfinitions de pinceaux	JUMP',NE 70$.IF	GCSF	CALL	GINPUTSF	; lit df. genc si diff. de "fst-" exist..ELSE	CALL	GINPUT		; lit dfinitions de gencars.ENDIF;;;	JUMP',NE 70$	; continue, mme si inexistant etc.	CALL	FINPUT		; lit dfinitions de flches	JUMP',NE 70$;;;	CALL	MINPUT		; ne lit pas les macros v.;;;	JUMP,NE	70$;;;	CALL	EINPUT		; ne lit pas dimensions et flags;;;	JUMP,NE	70$	JUMP'	65$60$:	LOAD.L	A4,#(A6)+OBUIO	; A4 <-- ^buffer temporaire	CALL	INPUT		; lit un objet	JUMP',NE 70$;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE65$:	COMP.B	(A4)+OMOBJET,#-1 ; ignore objets de df.	JUMP',EQ 60$	CALL	IFLDGC		; charge gencar si ncessaire	CALL	INVY		; inverse la coordonne Y	LOAD.B	(A6)+OPLANAV+ORCOIN,#-1	; tous les coins trouvs;;;	CALL	AJUSTE		; ajuste selon l'offset	LOAD.W	(A6)+OPLANAV+OPLANA,#FAJUSTE	.W	PLANA_FONC;;;	CALL	ITTRAME		; translate si trame;;;	CALL	ITPEN		; translate si pinceau;;;	CALL	ITFLECHE	; translate si flche	LOAD.W	(A6)+OPLANAV+OPLANA,#FITRPTF	.W	PLANA_FONC;;;	CALL	MET		; objet <-- registres	LOAD.W	(A6)+OPLANAV+OPLANA,#BMET	.W	PLANA_BASE;;;	CALL	OPEBASE		; A4 <-- ^nouvel lment	LOAD.W	(A6)+OPLANAV+OPLANA,#BOPEBASE	.W	PLANA_BASE	JUMP',NE 70$	CALL	COPYTB		; base donne <-- buffer temp.;;;	CALL	DESSINE		; dessine l'objet	.W	PLANA_DESSINE	JUMP,NC	60$70$:	CALL	SCMO		; remet flche souris	PUSH.W	D7	CALL	RDCLOSE		; ferme fichier en entre	POP.W	D7	POP.W	D1		; D1 <-- fanions	COMP.W	D7,#EROUTF	JUMP,NE	90$	CALL	AFCMES		; affiche centr;;	.ASCIZE	"Dplacez puis cliquez un bouton de la souris";;	.ASCIZE	" SOURIS: | place | inhibe le pas |        | "	.ASCII	" "	.B	USEGC,GCICF,GCICS,GCICT	.B	7,96,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" place |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,97,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" met/enlve PAS |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,98,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZE	" inactif "	LOAD.L	D4,D6		; D4 <-- coin inf/gauche	LOAD.L	D3,D5		; D3 <-- coin sup/droite	CALL	XINLIE		; lie/dlie selon D1	TCLR.B	(A6)+OFLAGF:#BMPDES	LOAD.W	(A6)+OMOVOP,#1	; attend bouton press	CALL	MOVZONE		; dplace zone rectangulaire;;;	CALL	DEPLACE		; dplace la surface	PUSH.B	D5	LOAD.B	D5,#1	.W	PLANA_OPER	POP.B	D5.IF	GCSF	TEST.L	D1:#BINPREND	JUMP',BS 75$	CALL	KILLGCAJ	; supprime tous les genc 'ajouts' inutiles	JUMP'	76$75$:	CALL	CLBGCAJ		; supprimer les BGCAJ ds. OBUGC sans suppr.76$:.ENDIF	LOAD.W	D7,#ERBGC	TEST.B	(A6)+OFLIO:#BIOBGC ; mauvais gencar lu ?	JUMP',BS 90$		; oui => 90$	CLR.W	D790$:	TCLR.L	D7:#16		; D7 <-- pas une erreur lors de l'ouverture95$:	CALL	CWMO		; remet la souris normale	TEST.L	D4:#BPLANPLAN	; PLAN.PLAN ds. dossier courant	JUMP,BS	96$	CALL	IOERROR		; affiche erreur si ncessaire96$:	PUSH.L	D7	CALL	INIFREE		; affiche le reste	POP.L	D7	POPM.L	D0,D1,D2,D3,D4,D5,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DINPUT  >;--------/; Lit et initialise les dfinitions.; in	A4.L	^premier "objet"; out	-; mod	D7.WDINPUT:	PUSHM.L	D3,A2	CLR.W	D3; modification 5.10	LOAD.B	D3,(A4)+OMPAR1+3 ; D3 <-- nouveau pas	TCLR.B	(A6)+OPLANAV+OFLAGS:#BGRILLE	CALL	CHGPAS		; change le pas et la grille	LOAD.B	D3,(A4)+OMPAR1+1 ; D3 <-- "flags"	TEST.L	D3:#0	JUMP',BC 10$	TSET.B	(A6)+OPLANAV+OFLAGS:#BGRILLE10$:	TCLR.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS	TEST.L	D3:#7		; bits 2..6 valides ?	JUMP,BC	15$				; oui =>	COMP.W	(A6)+OPAS,#0	JUMP,EQ	15$	TSET.B	(A6)+OPLANAV+OFLMOD1:#BNOTPAS15$:	TCLR.B	(A6)+OPLANAV+OFLAGS:#BMEMCAS	TEST.L	D3:#2	JUMP',BC 20$	TSET.B	(A6)+OPLANAV+OFLAGS:#BMEMCAS20$:	TEST.L	D3:#3	JUMP',BS 30$	TCLR.B	(A6)+OFLRET:#BRETICULE	JUMP',BC 35$	CALL	SCMO		; remet la flche de la souris	JUMP'	35$30$:	TEST.B	(A6)+OFLRET:#BRETICULE	JUMP',BS 35$	CALL	CCMO		; enlve la flche de la souris	TSET.B	(A6)+OFLRET:#BRETICULE35$:	TCLR.B	(A6)+OFLMOD:#BICADRE	TEST.L	D3:#4	JUMP',BC 40$	TSET.B	(A6)+OFLMOD:#BICADRE40$:	TCLR.B	(A6)+OFLMOD:#BMINGC	TEST.L	D3:#5	JUMP',BC 50$	TSET.B	(A6)+OFLMOD:#BMINGC50$:	CALL	CLRREGLE	TEST.L	D3:#6	JUMP',BC 80$	CALL	SETREGLE80$:	LOAD.L	A2,(A6)+OPLANAV+OPDDIS		; fond blanc: l'inverse	TEST.B	(A2)+ODFMOD:#BFBLANC	JUMP,BC	90$	TNOT.B	(A6)+OFLMOD:#BICADRE90$:	CALL	EFFACE		; efface tout	CALL	REFAIT		; puis refait tout proprement	POPM.L	D3,A2	RET;--------\\; TINPUT  >;--------/; Lit toutes les dfinitions de trames.; Aprs a, le premier objet est lu !; in	-; out	A4.L	^objet;	D0..4	paramtres objet;	D7.W	erreur; mod	D0..4, D7.W, A4.LTINPUT:;;;	CALL	IITRAME		; init translation nulle	LOAD.W	(A6)+OPLANAV+OPLANA,#FIITRAME	.W	PLANA_FONC10$:	LOAD.L	A4,#(A6)+OBUIO	; A4 <-- ^buffer temporaire	CALL	INPUT		; lit un objet	JUMP',NE 90$;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	COMP.B	D0,#OBJTDEF	; dfinition d'une trame ?	JUMP',NE 90$		; non => 90$				; oui =>;;;	CALL	IMTRAME		; mmorise translation	LOAD.W	(A6)+OPLANAV+OPLANA,#FIMTRAME	.W	PLANA_FONC	JUMP	10$90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; PINPUT  >;--------/; Lit toutes les dfinitions de pinceaux.; Aprs a, le premier objet est lu !; in	A4.L	^objet dj lu; out	A4.L	^objet;	D0..4	paramtres objet;	D7.W	erreur; mod	D0..4, D7.W, A4.LPINPUT:	PUSH.L	D5;;;	CALL	IIPEN		; init translation nulle	LOAD.W	(A6)+OPLANAV+OPLANA,#FIIPEN	.W	PLANA_FONC	JUMP'	20$10$:	LOAD.L	A4,#(A6)+OBUIO	; A4 <-- ^buffer temporaire	CALL	INPUT		; lit un objet	JUMP',NE 90$20$:;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	LOAD.W	D5,(A4)+OMRES	; D5 <-- chelle/map	COMP.B	D0,#OBJPDEF	; dfinition d'un pinceau ?	JUMP',NE 90$		; non => 90$				; oui =>;;;	CALL	IMPEN		; mmorise translation	LOAD.W	(A6)+OPLANAV+OPLANA,#FIMPEN	.W	PLANA_FONC	JUMP	10$90$:	POP.L	D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; FINPUT  >;--------/; Lit toutes les dfinitions de flches.; Aprs a, le premier objet est lu !; in	A4.L	^objet dj lu; out	A4.L	^objet;	D0..4	paramtres objet;	D7.W	erreur; mod	D0..4, D7.W, A4.LFINPUT:;;;	CALL	IIFLECHE	; init translation nulle	LOAD.W	(A6)+OPLANAV+OPLANA,#FIIFLECHE	.W	PLANA_FONC	JUMP'	20$10$:	LOAD.L	A4,#(A6)+OBUIO	; A4 <-- ^buffer temporaire	CALL	INPUT		; lit un objet	JUMP',NE 90$20$:;;;	CALL	PREND		; registres <-- objet	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	COMP.B	D0,#OBJFDEF	; dfinition d'une flche ?	JUMP',NE 90$		; non => 90$				; oui =>;;;	CALL	IMFLECHE	; mmorise translation	LOAD.W	(A6)+OPLANAV+OPLANA,#FIMFLECHE	.W	PLANA_FONC	JUMP	10$90$:	TEST.W	D7		; retour EQ/NE	RET;-------- EINPUT:;--------; lit dimension et flags; in	A4.L	^ objet dj lu;	D0.B	objet; out	A4.L	^ objet; mod	D7.W	erreur	COMP.B	D0,#OBJEDEF	JUMP,NE	90$	LOAD.L	(A6)+OF64Y,(A4)+OMRES		; 12/13/14/15	LOAD.W	(A6)+OPLANAV+OCOULEUR,(A4)+OMPAR1	; 2/3;;;;;	AND.B	(A6)+OFLIO,#B'10000001	; sauf BIOBGC et bit 7 !!;;;;;	AND.B	(A6)+OFLIO,#B'00000001	; sauf BIOBGC	AND.B	(A6)+OFLIO,#B'00000011	; sauf BIOBGC et BNOEXCL	TEST.B	(A4)+OMPAR1+3:#0	JUMP,BC	30$	TSET.B	(A6)+OFLIO:#BOUTPLAN30$:	TEST.B	(A4)+OMPAR1+3:#1	JUMP,BC	31$	TSET.B	(A6)+OFLIO:#BIMRIEN31$:	TEST.B	(A4)+OMPAR1+3:#2	JUMP,BC	32$	TSET.B	(A6)+OFLIO:#BIMECR32$:	TEST.B	(A4)+OMPAR1+3:#3	JUMP,BC	33$	TSET.B	(A6)+OFLIO:#BIMPLAN33$:	TEST.B	(A4)+OMPAR1+3:#4	JUMP,BC	34$	TSET.B	(A6)+OFLIO:#BIMDESS34$:35$:	TEST.B	(A4)+OMMODE:#1	JUMP,BC	36$	TSET.B	(A6)+OFLMOD:#BENMM36$:	LOAD.L	A4,#(A6)+OBUIO	CALL	INPUT	JUMP',NE 90$;;;	CALL	_PRENDLOAD.W	(A6)+OPLANAV+OPLANA,#BPREND.W	PLANA_BASE90$:	TEST.W	D7	RET;--------\\; GINPUT  >;--------/; Lit toutes les dfinitions de gencars, sauf pour 'ajoute':;	ne prend pas si police "fst-" existe dj !;	et marque un genc ajout pour tester aprs; Aprs a, le premier objet est lu !; in	A4.L	^objet dj lu; out	A4.L	^objet;	D0..4	paramtres objet;	D7.W	erreur; mod	D0..4, D7.W, A4.L.IF	GCSFGINPUTSF:	PUSHM.L	D5,A0,A2,A3,A5	LOAD.L	D5,#1		; signal mode 'ajoute'	JUMP'	GIN.ENDIFGINPUT:.IF	GCSF	PUSHM.L	D5,A0,A2,A3,A5.ELSE	PUSHM.L	D5,A2,A3,A5.ENDIF.IF	GCSF	CLR.L	D5		; signal mode 'prend'	JUMP'	GIN.ELSE	JUMP'	20$.ENDIF.IF	GCSFGIN0:.ELSE10$:.ENDIF	LOAD.L	A4,#(A6)+OBUIO	; A4 <-- ^buffer temporaire	CALL	INPUT		; lit un objet.IF	GCSF	JUMP,NE	FGINGIN:.ELSE	JUMP,NE 90$20$:.ENDIF;;;	CALL	PREND		; registres <-- objet	LOAD.L	A5,#(A6)+OPLANAV ; A5 ^ variables PLANA	LOAD.W	(A6)+OPLANAV+OPLANA,#BPREND	.W	PLANA_BASE	COMP.B	D0,#OBJGDEF	; dfinition d'un gencar ?	JUMP,NE 90$		; non => 90$				; oui =>	LOAD.L	A5,A4		; A5 <-- ^objet25$:	LOAD.L	A4,#(A6)+OPLANAV+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A3,#(A5)+OMPAR2	; A3 <-- ^titre	DGENC_	SEARCH		; ce titre existe dj ?	JUMP',NE 50$		; non => 50$				; oui =>	LOAD.L	D4,(A4)+OGCCOD	; D4 <-- "-fst" gencar actuel	SL.L	D4,#8		; D4 <-- "fst-" gencar actuel	LOAD.L	D3,(A5)+OMPAR1	; D3 <-- "fstx" nouveau gencar	CLR.B	D3		; D3 <-- "fst-" nouveau gencar	COMP.L	D3,D4		; est-ce le mme gencar ?.IF	GCSF	JUMP,EQ	GIN0		; oui => GIN0.ELSE	JUMP,EQ 10$		; oui => 10$.ENDIF				; non =>	LOAD.L	A2,A330$:	TEST.B	(A2+)		; A2 <-- ^fin du titre	JUMP,NE 30$	LOAD.B	D3,(A2)-2	; D3 <-- dernier caractre du titre	COMP.B	D3,#'0	JUMP',LO 40$	COMP.B	D3,#'9		; titre termin par un chiffre ?	JUMP',HS 40$		; non => 40$	INC.B	(A2)-2		; oui => "toto3" devient "toto4"	JUMP	25$40$:	LOAD.B	(A2)-1,#'1	; "toto" devient "toto1"	CLR.B	(A2)	JUMP	25$50$:.IF	GCSF	TEST.B	D5	JUMP',EQ 51$	LOAD.L	D3,(A5)+OMPAR1	; D3 <-- "fst-";;;	CALL	SRCPGC1		; nom physique "fst-" existe ?	PUSH.L	A5	LOAD.L	A5,#(A6)+OPLANAV	LOAD.W	(A6)+OPLANAV+OPLANA,#FSPGC1	.W	PLANA_FONC	POP.L	A5	JUMP,EQ	GIN0		; oui ==> suivant51$:.ENDIF	LOAD.L	A4,#(A6)+OPLANAV+OBUGC	; A4 <-- ^buffer des gencars	DGENC_	FREE		; A4 <-- ^gencar libre	JUMP',NE 90$	LOAD.L	A2,#(A4)+OGCTIT	LOAD.L	A3,#(A5)+OMPAR255$:	LOAD.B	(A2+),(A3+)	; OBUGC <-- titre	JUMP,NE 55$	LOAD.L	D3,(A5)+OMPAR1	; D3 <-- "fst-"	SR.L	D3,#8		; D3 <-- "-fst"	LOAD.L	(A4)+OGCCOD,D3	; OBUGC <-- gencar	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A2,(A6)+OPLANAV+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A3,#(A6)+OPLANAV+OBUGC	DGENC_	NEW.IF	GCSF	JUMP,NE	56$		; erreur	TEST.B	D5		; 'ajoute' ?	JUMP,EQ	GIN0		; non ...	TSET.B	(A4)+OGCFLG:#BGCAJ	; marquer comme genc ajout	JUMP	GIN0;;	JUMP,EQ	GIN056$:.ELSE	JUMP,EQ 10$.ENDIF	TSET.B	(A6)+OFLIO:#BIOBGC ; erreur diffre !.IF	GCSF	JUMP	GIN0.ELSE	JUMP	10$.ENDIF90$:.IF	GCSFFGIN:	POPM.L	D5,A0,A2,A3,A5.ELSE	POPM.L	D5,A2,A3,A5.ENDIF	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFLDGC  >;--------/; Lors de la lecture d'un plan, charge les gencars non dfinis !; in	D0.W	type de l'objet;	D3.L	premier paramtre; out	D3.L	v. modifi; mod	D3.L, D7.WIFLDGC:	COMP.B	D0,#OBJTEXT	; caractre ?	JUMP',EQ 10$		; oui => 10$	RET			; non => rien  faire10$:	PUSHM.L	D2,D4,A0,A2..A4	LOAD.L	D2,D3		; D2 <-- premier paramtre initial	CLR.B	D3		; D3 <-- "fst-"	TEST.L	D3		; gencar par dfaut ?	JUMP',NE 20$		; non => 20$				; oui => met gencar standard	OR.L	D2,#H'1000000*GCTXF+H'10000*GCTXS+H'100*GCTXT	LOAD.L	D3,D2	CLR.B	D320$:;;;	CALL	SRCPGC		; A0 <-- ^gencar	LOAD.W	(A6)+OPLANAV+OPLANA,#FSRCPGC	.W	PLANA_FONC	JUMP',EQ 90$NOSEARCH	=	1	; n' essaye plus de charger genc, tant pis !.IF	NOSEARCH.ELSE	LOAD.L	A4,#(A6)+OPLANAV+OBUGC	; A4 <-- ^buffer des gencars	DGENC_	FREE		; A4 <-- ^gencar libre	JUMP',NE 80$	SR.L	D3,#8		; D3 <-- "-fst"	LOAD.L	(A4)+OGCCOD,D3	; OBUGC <-- gencar	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A2,(A6)+OPLANAV+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A3,#(A6)+OPLANAV+OBUGC	DGENC_	NEW	JUMP',NE 80$	LOAD.L	A2,#(A4)+OGCNAM	LOAD.L	A3,#(A4)+OGCTIT50$:	LOAD.B	(A3+),(A2+)	; titre <-- nom !	JUMP,NE 50$	JUMP'	90$.ENDIF80$:.IF	NOSEARCH.ELSE	LOAD.L	D3,(A6)+OPLANAV+OBUGC+OGCCOD ; D3 <-- "-fst" du gencar Fond	SL.L	D3,#8		; D3 <-- "fst-"	LOAD.B	D3,D2		; D3 <-- "fstc"	LOAD.L	D2,D3.ENDIF	TSET.B	(A6)+OFLIO:#BIOBGC ; erreur diffre !90$:	LOAD.L	D3,D2		; D3 <-- premier paramtre	POPM.L	D2,D4,A0,A2..A4	RET;--------\\; XINLIE  >;========/; Lie/dlie un plan lu.; in	D1.W	fanions;	D3.L	coordonne coin;	D4.L	coordonne coin; out	-; mod	D7.WXINLIE:	PUSHM.W	D0,D5	CLR.W	D0	TEST.L	D1:#BINULIE	JUMP',BS 40$	INC.W	D0	TEST.L	D1:#BINUDELIE	JUMP',BS 60$	INC.W	D0	TEST.L	D1:#BINSLIE	JUMP',BS 40$	INC.W	D0	TEST.L	D1:#BINSDELIE	JUMP',BS 60$	JUMP'	90$40$:60$:	LOAD.B	D5,#8	.W	PLANA_OPER90$:	POPM.W	D0,D5	RET;--------\; GCINPUT >;========/; Lit un gnrateur de caractres dans une zone dfinie avec; la souris.; in	-; out	D7.W	erreur; mod	D7.WGCINPUT:	PUSHM.L	D1,D2,D3,D4,A0,A3,A4	CALL	DBOXASCII	; D4 <-- attend le code ASCII	JUMP,NE	90$		; si (END) => 90$	TEST.L	D4:#8	JUMP,BC 30$				; TRAME 100% =>	CALL	SWMO		; met la souris "en attente";;;	CALL	OPMATRIX	; ouvre le fichier gencar	LOAD.W	(A6)+OPLANAV+OPLANA,#BOPMATRIX	.W	PLANA_BASE	JUMP,NE	80$	LIB	?IFMOUSE	; D4 <-- position de la souris	CALL	CONVCMO		; D4 <-- position dans le plan	LOAD.L	D3,D4		; D3 <-- coin inf/gauche	DEC.W	D3		; laisse une p'tite marge d'un	SWAP.W	D3		; point tout autour.	DEC.W	D3	SWAP.W	D3	ADD.W	D4,(A6)+OPLANAV+OLGMA+OXX	INC.W	D4	SWAP.W	D4	ADD.W	D4,(A6)+OPLANAV+OLGMA+OYY	INC.W	D4	SWAP.W	D4		; D4 <-- coin sup/droite	LOAD.B	D2,#MODINV	; D2 <-- mode inverse	CLR.W	D1		; D1 <-- type de trait fin	EX.L	D3,D4	CALL	TRECTANGLE	; dessine le rectangle dlimiteur;;;	.W	PLANA_TRECTANGLE	CALL	SETFILTRE	; filtre tout ce qui existe dj	CALL	IOWAIT		; affiche "attendez..."	LOAD.L	D6,D3		; D6 <-- offset	INC.W	D6	SWAP.W	D6	INC.W	D6	SWAP.W	D6	LOAD.B	(A6)+OPLANAV+ORCOIN,#-1	; tous les coins trouvs;;;	CALL	ADMATRIX	; converti toute la matrice	LOAD.W	(A6)+OPLANAV+OPLANA,#BADMATRIX	.W	PLANA_BASE	CALL	CWMO		; remet la souris normale	JUMP'	50$30$:				; PAS TRAME 100% =>	CALL	SETFILTRE	; filtre tout ce qui existe dj	LOAD.B	D2,D4		; D2 <-- caractre	LIB	?IFMOUSE	; D4 <-- position de la souris	CALL	CONVCMO		; D4 <-- position dans le plan	CALL	GETPGC		; A0 <-- ^gencar	ADD.W	D4,(A0)+OGC1X	SWAP.W	D4	ADD.W	D4,(A0)+OGC2Y	SWAP.W	D4	LOAD.L	D3,(A0)+OGCCOD	; D3 <-- "-fst"	SL.L	D3,#8		; D3 <-- "fst-"	LOAD.B	D3,D2		; D3 <-- "fstc"	LOAD.W	D2,(A6)+OMODE	; D2 <-- mode/couleur	CLR.W	D1		; D1 <-- trait	LOAD.W	D0,#OBJTEXT	; D0 <-- objet;;;	CALL	AJOUTE		; ajoute caractre dans base de donne	LOAD.W	(A6)+OPLANAV+OPLANA,#BAJOUTE	.W	PLANA_BASE	JUMP,NE 80$;;;	CALL	DESSINE		; dessine le caractre	.W	PLANA_DESSINE	LOAD.L	D3,D4	SUB.W	D3,(A0)+OGC1X	DEC.W	D3	ADD.W	D4,(A0)+OGC2X	INC.W	D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A0)+OGC2Y	DEC.W	D3	ADD.W	D4,(A0)+OGC1Y	INC.W	D4	SWAP.W	D4	SWAP.W	D3	LOAD.B	D2,#MODINV	; D2 <-- mode inverse	CLR.W	D1		; D1 <-- type de trait fin	EX.L	D3,D4	CALL	TRECTANGLE	; dessine le rectangle dlimiteur;;;	.W	PLANA_TRECTANGLE50$:	CALL	AFCMES		; affiche centr;;	.ASCIZE	"Dplacez puis cliquez un bouton de la souris";;	.ASCIZE	" SOURIS: | place | inhibe le pas |        | "	.ASCII	" "	.B	USEGC,GCICF,GCICS,GCICT	.B	7,96,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" place |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,97,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	" met/enlve PAS |"	.B	USEGC,GCICF,GCICS,GCICT	.B	7,98,7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZE	" inactif ";;	EX.L	D3,D4		; D4 <-- coin inf/gauche	TCLR.B	(A6)+OFLAGF:#BMPDES	LOAD.W	(A6)+OMOVOP,#1	; attend bouton press	CALL	MOVZONE		; dplace zone rectangulaire;;;	CALL	DEPLACE		; dplace la surface	PUSH.B	D5	LOAD.B	D5,#1	.W	PLANA_OPER	POP.B	D5	CLR.W	D7		; D7 <-- ok80$:	CALL	CWMO		; remet la souris normale	CALL	IOERROR		; affiche erreur si ncessaire90$:	PUSH.W	D7	CALL	INIFREE		; affiche le reste	CALL	INIBAS		; refait le bas	POP.W	D7	POPM.L	D1,D2,D3,D4,A0,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; IOWAIT  >;========/; Affiche "attendez un peu, enfin quoi ..."; in	-; out	-; mod	D7.WIOWAIT:	CALL	AFCMES		; affiche centr	.ASCIZ	" Attendez un instant ... "	.EVEN	RET;--------\; INVY    >;========/; Inverse la coordonne Y si ncessaire.; in	D0.B	objet;	D3.L	paramtre 1;	D4.L	paramtre 2; out	D3.L	paramtre 1;	D4.L	paramtre 2; mod	D3.L, D4.LINVY:	TEST.B	(A6)+OINVYF:#1	; coordonne dj inverse ?	JUMP',BS 90$		; oui => 90$				; non =>	SWAP.W	D4	SUB.W	D4,(A6)+OINVYL	NEG.W	D4	SWAP.W	D4	COMP.B	D0,#OBJCERCLE	JUMP',EQ 90$	COMP.B	D0,#OBJARC	JUMP',EQ 90$	COMP.B	D0,#OBJTEXT	JUMP',EQ 90$	SWAP.W	D3	SUB.W	D3,(A6)+OINVYL	NEG.W	D3	SWAP.W	D390$:	RET;--------\; COPYTB  >;========/; Copie l'objet dans le buffer temporaire --> base de donne.; in	A4.L	^dans base de donne; out	-; mod	-COPYTB:	PUSHM.L	D3,A3,A4	LOAD.L	A3,#(A6)+OBUIO	; A3 <-- ^buffer temporaire	LOAD.B	D3,#LGELEMENT	; D3 <-- lg10$:	LOAD.B	(A4+),(A3+)	; base de donne <-- temp	DEC.B	D3	JUMP,NE	10$	POPM.L	D3,A3,A4	RET;--------\; COPYBT  >;========/; Copie l'objet dans base de donne --> buffer temporaire.; in	A4.L	^dans base de donne; out	A4.L	^dans buffer temporaire; mod	A4.LCOPYBT:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUIO	; A3 <-- ^buffer temporaire	LOAD.B	D3,#LGELEMENT	; D3 <-- lg10$:	LOAD.B	(A3+),(A4+)	; temp <-- base de donne	DEC.B	D3	JUMP,NE	10$	LOAD.L	A4,#(A6)+OBUIO	; A3 <-- ^buffer temporaire	POPM.L	D3,A3	RET;--------\; OUTPUT  >;========/; Ecrit un objet sur disque.; in	A4.L	^objet  sortir; out	D7.W	erreur; mod	D7.WOUTPUT:	PUSH.L	D4	LOAD.L	D4,#LGELEMENT	; D4 <-- longueur	CALL	WRMANY		; crit la tranche	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\; INPUT   >;========/; Lit un objet sur disque.; in	A4.L	^place pour objet  lire; out	D7.W	erreur; mod	D7.WINPUT:	PUSHM.L	D3,D4,A4	LOAD.W	D4,#LGELEMENT	; D4 <-- longueur10$:	CALL	RDONE		; D3 <-- lit un byte	JUMP',NE 90$		; si erreur => 90$	LOAD.B	(A4+),D3	; buffer <-- byte lu	DEC.W	D4		; encore un ?	JUMP,NE	10$		; oui => 10$90$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; WROPEN  >;========/; Ouvre le fichier en sortie.; in	D6.W	canal; out	-; mod	-WROPEN:	LOAD.W	(A6)+OCHIO,D6	; mm. canal	CLR.W	(A6)+OPLANAV+OPTIO	; buffer vide	RET;--------\; WRMANY  >;========/; Ecrit plusieurs bytes dans le fichier de sortie.; in	A4.L	^bytes  crire;	D4.L	nombre de bytes  crire; out	D7.W	erreur; mod	D7.WWRMANY:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,A4		; A3 <-- ^bytes  crire	LOAD.W	D3,D4		; D3 <-- nombre10$:	LOAD.L	A4,#(A6)+OPLANAV+OTMIO	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OPLANAV+OPTIO	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer20$:	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4+),(A3+)	; buffer <-- un byte	INC.W	D4		; D4 <-- un byte de plus	DEC.W	D3	JUMP,NE	20$	LOAD.W	(A6)+OPLANAV+OPTIO,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OPLANAV+OTMIO	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NS 90$		; erreur => 90$	CLR.W	(A6)+OPLANAV+OPTIO	; signal buffer vide	JUMP	10$90$:	POPM.L	D3,D4,D6,A3,A4	RET;--------\; WRCLOSE >;========/; Ecrit le reste du fichier de sortie, puis ferme.; in	-; out	D7.W	erreur; mod	D7.WWRCLOSE:	PUSHM.L	D4,D6,A4	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	LOAD.L	A4,#(A6)+OPLANAV+OTMIO	; A4 <-- ^buffer tampon	CLR.L	D4	LOAD.W	D4,(A6)+OPLANAV+OPTIO	; D4 <-- nb bytes dans buffer	JUMP',EQ 50$		; si vide => 50$				; si reste qq chose =>	FOS	?WRBYTE		; crit tout le buffer50$:	FOS	?CLOSE		; ferme le fichier	CLR.W	(A6)+OCHIO	; plus de canal	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; RDOPEN  >;========/; Ouvre le fichier en entre.; in	D6.W	canal; out	-; mod	-RDOPEN:	LOAD.W	(A6)+OCHIO,D6	; mm. canal	LOAD.W	(A6)+OPLANAV+OPTIO,#LTMIO	RET;--------\; RDONE   >;========/; Lit un byte dans le fichier d'entre.; in	-; out	D3.B	byte lu;	D7.W	erreur; mod	D3.L, D7.WRDONE:	PUSHM.L	D4,D6,A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,#(A6)+OPLANAV+OTMIO	; A4 <-- ^buffer tampon	COMP.W	(A6)+OPLANAV+OPTIO,#LTMIO ; reste qq chose ?	JUMP',LO 50$		; oui => 50$				; non =>	LOAD.L	D4,#LTMIO	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?RDBYTE		; lit tout le buffer	LOAD.W	(A6)+OPLANAV+ONBIO,#-1	CLR.W	(A6)+OPLANAV+OPTIO	; buffer vide	TEST.W	D7		; lecture ok ?	JUMP',EQ 50$		; oui => 50$	COMP.W	D7,#EROUTF	; fin du fichier ?	JUMP',NE 90$		; non => 90$	CLR.W	D7		; D7 <-- ok pour l'instant	LOAD.W	(A6)+OPLANAV+ONBIO,D4	; mm. lg dernire tranche50$:	TEST.W	(A6)+OPLANAV+ONBIO	; reste qq chose ?	JUMP',NE 60$		; oui => 60$	LOAD.W	D7,#EROUTF	; D7 <-- fin du fichier	JUMP'	90$60$:	LOAD.W	D4,(A6)+OPLANAV+OPTIO	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- un byte du buffer	INC.W	(A6)+OPLANAV+OPTIO	; avance "pointeur"	DEC.W	(A6)+OPLANAV+ONBIO	; diminue reste90$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; RDCLOSE >;========/; Ferme le fichier en entre.; in	-; out	D7.W	erreur; mod	D7.WRDCLOSE:	PUSH.L	D6	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?CLOSE		; ferme le fichier	POP.L	D6	TEST.W	D7		; retour EQ/NE	RETTXHELP:	.ASCIZ	"plan_f.help"TXPLAN:	.ASCIZ	".plan"TXIMAGE:.ASCIZ	".image"TXGENC:	.ASCIZ	".genc"txprinter:	.ASCIZ	"#PRINTER"	.EVEN	.END