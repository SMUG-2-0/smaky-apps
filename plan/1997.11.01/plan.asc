	.TITLE	PLAN			; 28 novembre 87 Sp.;	--------------------------------------;		(C) 1985 - Daniel Roux;	--------------------------------------; PLAN	PSos	Amliorations; -----------------------------------------------------------------------; 5.0		NEWHAUT: affichage nouveau des paramtres en haut en mm !;			menu 'DEFINE' chang pour mm et formats;						ECRAN et PAGE;		Dimensions max. limites  2^15;				 (problme zone de slction!!);;		Couleur 'invisible' pour traits de construction p.ex;		(ces traits seront toujours ignors par plotter et printer);;		(bouton gauche + milieu) lors du dessin inhibe le pas;;		CLICHAUT:	- dfinitions du PLAN;				- saisie origine numrique en pg ou mm;				- affichage par rapport au;					dernier point significatif;					indiqu par un lutin;;				- rgles par SCROLL.LIB;;		PLAN.PLAN	nom rserv, (PLANDBOX, STOFILE);				donc ignor par 'PREND' et ligne;				de commande. Avantage: permet;					de reprendre son environnement;					sans modifier PLAN.PLAN;					par inadvertance.;;		Grille de 30 pts. (demande JDN);;			Le car. 'Fond' n'est plus protg,;			supprimable donc.;			Tout fichier charg  partir de la;			ligne de commande ou en son absence;			PLAN.PLAN lors de l'appel de PLAN;			aura les gnrateurs du fichier;			resp. de PLAN.PLAN.;			'Prend' par contre ajoute  ceux qui;			existent dj !;; 		.image de taille sup.  l'cran, options:;			- cran;			- plan (avec marges);			_ dessin (sans marges);				limit par mm. et par dim. imprimante;		- sauvetage des valeurs numriques de l'impimante;		  et des fanions de couleur visible et de sauvetage;		  lment de def. (-6).;; 5.1		- correction bug flags dans EDEF;		- valeurs par dfaut pour mm et rgles EPSON LQ800;		_ 'ajoute' et 'modif' --> souris |place|inhibe pas|   |;; 5.02		- correction erreur : .image plus grand que page imprimante;		- affichage version N.nn;; 5.03		- lors du filtre UN par UN correction de l'affichage,;		  cohrent avec Objet:... du cadre ( mm ou pg);		  et affichage de la police physique; 		- dbox de confirmation pour supprimer un genc utilis;		- lors d'un ajoute les noms de fonction pour les genc;		  sont ignors si la police physique existe dj;		  afin de ne pas polluer un environnement de travail!;		- affiche le no. de macro en cours;		- 'Efface'-'TOUT' prend PLAN.PLAN si existant;;; 5.04		- trames et pinceaux dfini comme DESSIN (n.LIB;		- correction affichage genc si laser; 		- .image tourn automatiquement si ncessaire;		- accepte RETURN ds. DBOX-PREND pour 'PREND' ;; 5.05		- erreurs corriges ds. ROTIMA;; 5.06;;		- corrig erreur avec zone de recherche et boutons de la souris;; 5.07;		- erreur ancienne slction d'objets OBJFILL et OBJSTOCK;			corrige;		- objet par dfaut = droite lastique pour contourner;			problme avec ligne lorsqu'on clique, ce qui;			crit des dbut et fins d'objet mme si vide !;		- si un genc est utilis;			'supprime' des genc offre le choix entre:;			o supprime ds. PLAN;			o supprime ds liste si existe aumoins une fois;			rem.: s'il n'existe qu'une fois dans liste;				qu'il est utilis dans PLAN,;				le genc ne peut pas tre supprim;; 5.08		- EDEF pouvait se trouver dans la base ce qui provoquait;			des erreurs videmment pour .images;			Tous les lments dfinition (-1) sont ignors;;		- clic bouton de droite avant sauvetage .image faisait;			planter  cause de D6 dans SCAN (PLANIMAGE);; 5.09		- 'ajoute' ignore les genc inutiliss;;		- pinceau en bas de la fentre pour .image corrig;; 5.10		- position du menu objets et flches amliores;		- 'aligne les modifications' est sauv ds. PREMIER;			tous les .PLAN  antrieur sont considrs;			comme sauv avec cette option;		- erreur flche et touches Fx corrig (dbox suppr. car.);		- la largeur du car. est inscrit ds. (largeur|OBJTEXT);			le plotter fera du proportionnel !;		- nouvelle appellation pour 'sauve';			pas d'image;			l'image visible  l'cran;			l'image cadr selon dessin;			l'image aux dimensions plan	(plus clair?);; 5.11		- corr. affichage dim. (l x h ) --> (l / h);		- rectangle et surface d'une dim. nulle rejet;		- si PLAN.PLAN inexistant pas de car. ds. liste !;			affiche ds. ligne du bas "GENC=???";		- propose  nouveau sauvetage avant de quitter si modif.;		- la zone de slection ne deborde plus de PLAN, mais;			la zone peut tre dplace en dehors de l'cran;				jusqu'au point de rfrence;		- 'ajoute' met premier genc de la liste s'il n'existe pas,;			sans chercher  chaque car. (problme rseau);		- 'ajoute' supprime les genc non utiliss sauf si pour PLAN;		- sauvetage image tient compte des flches;;; 5.12		- polycopies d'un ou plusieurs objets;			o selon position de la souris;			o quidistant;		- aligne d'un ou plusieurs objets;			o haut;			o centr haut/bas;			o bas;			o gauche;			o centr gauche/droite;			o droite;		  remarque:;			Un objet lastique n'est allong ou raccourci que si les sommets;			se trouvent en dea de la coordonn d'alignement.;		- affichage des fonctions de la souris en bas amlior;		- affiche dplacement zone de slection dX,dY lors des modifications;		- erreur avec rf. dynamique et 'tout' corrige;		- erreur coin de rf. 'ajoute' et car. spc. corrige;		- nouveau: PAS sur touche F12, met/enlve le PAS;			remarque: le flag aligne les modifs sur le PAS;				  est supprim. Si le PAS est mis,;				  l'alignement se fait sinon pas.;;; 5.13		- correction commandes USART pour plotter en Xon/Xoff:;			Command #mi: NFEXECYEW[400.W]V{9600.W];			Command #mo:   XEDYEW[200.W]V[9600.W]ORE;		- 'aligne' pour rectangles corrig;		- 'prend' pour PLAN de petite taille possible;		- 'ajoute' pour PLAN plus grand qu' cran possible;		- raffiche menu touches fonctions aprs SPLINE;		- nouveau: SMA_PLANA.LIB  tester srieusement !!!;; 5.14		- erreur 'zoom gnrale' corrige;		- erreur affichage du pinceau corrige;		- erreur 'dtruit' pour caractres corrige;		- le PAS ne devrait plus se perdre lors de modifications;		- lit le plan entier mme si gnrateur caractre;			inexistant, remplace par NRF12  l'affichage;			(le genc manquant peut tre lu avec filtre !);		- PLAN.PLAN dans dossier courant ou dossier systme (buzzer);		- si MACRO clic sur Objet/Macro dans ligne de bas;			 affiche un menu droulant pour choix Macro;		- 'Sauve' (F3) cre fichier "!";		- lire les valeurs du statut de l'cran pour PLANIMAGE;		- (F1-F2-F3) devient 'Prend/Ajoute/Sauve' (id. TEXT etc.);		- nouveaux PAS 1, 5, 10, 15, 20, 25, 30 en plus;; 5.15		- correction erreurs ds. PLANA.LIB;		- fichier "!" et sauvetage images de nouveau ok;		- (F1-F2-F3) devient 'Prend/Ajoute/sauve' (id. TEXT etc.);; 5.16		- nouveaux PAS modifis pour compatibilit avec ancien;		- caractres 100% trame corrigs;; 5.17		- 'filtre - objet choisi' fonctionne  nouveau;		- 'filtre - ... - modif ' affiche le bon menu F0..F15;		- arc (cercle et ellipse) refonctionne, les (arcs d')ellipse(s) sont ignors;		- aprs avoir fait 'PREND' puis 'LISTE, la;		  bote de dialogue contient directement 'PREND' ou 'ANNULE';		- aprs avoir fait 'AJOUTE' puis 'LISTE, la;		  bote de dialogue contient directement 'AJOUTE' ou 'ANNULE';		- (SHIFT()F15) trace sur plotter plume aprs plume;; 5.18		- touches (F0),(F1),(F2),(F3) et botes de dialogues associes conforme;		   la nouvelle philosophie EPSITEC;		- touche (SHIFT()F15) trace le plan en cours sur le traceur (!);		- PREND met tous les objets par dfaut et efface les genc;		- , , , ,  idem autres programmes;; 5.19		- erreurs fichier!plan et ERCALL F1 etc. corrige;; 5.20		- erreur images plus grandes que l'imprimante corrige;; 5.21		- ?;; 5.22		_ BIBLIOTHEQUE de symboles;		- corr. quitte avec refait avant;		- fichier!PLAN sans sauvetage avant marchait seulement avec image;		- erreur de dcalage lors des modifications corrige;		- dcalage des caractres lors de construction d'images corrig;; 5.23		- menu softkeys pour BIBAJOUTE;		- BIBLIO-LISTE-PREND pour bibliothque corrig;		- image d'aide pour PLAN;; 5.24		- dcalage des trames pour images (verticale);		- flag I/O obligatoirement .PLAN;; 5.25		- images d'aide;		- (PROGRA()H) pour saisie sur plotter HP seulement;		- (PROGRA()S) supprim pour SHARP;		- 300 genc au lieu de 150 pour liste du disque (PLANA 0.7);		- bote d'info optionnelle (Df) pour droites ( longueur et angle );		- erreur F3 corrige;;		- mj BIBLIO seulement si suppression en mode 'modification';		- les pages vides ne sont plus accessibles en mode 'utilisation';		- nlle image gnrique par dfaut dans BIBLIO;		- dplacement d'un lment dans une autre page de BIBLIO;; 5.26		- PLAN adapt pour cran couleurs;			PLANMOUSE[pmouse];			PLANDBOX[mmenu couler], PLANMISC[afntext];			PLANA.ASS, PLANGRA[dessine];		!!!  reste  modifier AFNTEXT dans PLANMISC pour supprimer MMCOULEUR dans PLANDBOX !!!;; 5.27	5.1	- mmenu 'sauve' erreur corrige ('canal incorrect');		- retour avec erreur fatale corrige;		- systme 5.1 et postrieur seulement;		- (F3) dessin  l'cran reste  nouveau;		- prendre un lment dans BIBLIO avec clr du flag BIOBGC;; 5.28		- boite de dialogue BIBLIO 'modification' complt avec '(cration)';		- problme rticule avec BIBLIO rsolu;		- boite de dialogue GENC: 'termine' avec nouveau genc;		- nouveaux menus droulants (hirarchiques) avec qqs. fonctions suppl.;		- 'filtre' avec choix aprs slction;		- 'aligne' sur le pas en cours;		- 'modifie' avec choix aprs slction;		- (F15) imprime le PLAN sur imprimante;; 5.29		- corrections esthtiques dans les menus;		- nouvelle option 'dfinitions': image de fond cache;; 5.30	5.4	- nouveau clipping du driver cran (car., pinceaux etc.);		- 'loupe' sans avoir trouv d'objet seulement si image prsente;		- l'option 'mmorise la dernire case' de nouveau disponible;		- images tournes sur SMAKY8 ok. (suppression des valeurs cran entrelacs);		- quelques erreurs mmenus corriges;; 5.31	5.5	- cran sans modulo avec MMODULO=H'D4; 01 (plus de modulo);		- erreur menu flche corrige;; 5.32		- flche se dessine de nouveau en bas;		- nouveau module SPLINE, contrle deltax et deltay (< 4096);; 5.33		- PLAN/X ne fait plus de fichier!PLAN (valable pour toute la session!);		- PLAN fichier/B fichier (charge la BIBLIO et le fichier);		- modification de caractres en 100% trams possible;;	???	- ROLL avec les ascenseurs ??? ROLLEFT, ROLLRIGHT ???;;  faire	- 'loupe' sans avoir trov d' objet seulement si image prsente; BIBLIO:	 faire: si entour plus petit que 80/80 alors ne pas agrandir;		 faire: si un objet n'est pas compltement entour, alors ignorer;		 faire: optimiser suppression des trous lors de suppr.!!;; *		- ROLL avec les ascenseurs;; *		_ "traits de construction" => "traits d'esquisse ...";			 supprimer; *		- inscription d'infos dans 'assemble'; *		- modifications objets 'colls' (systme);			avec TOOLBOX pour exploiter les infos;; *		- fentre INFO (droite: angle et longueur); *		- constructions de normales et tangentes etc.;MAJREV	=	5MINREV	=	33; ****************************;	  P L A N		*;  S O U R C E  C A L M  2   	  *;   (c) EPSITEC-system SA	*; ****************************	.PROC	M680002	.RADIX	10.	.HEX; Rfrences; ----------	.REF	SMAKY	.REF	MODULES	.REF	DESSIN;;;;?????.REF	MATH32;;;;?????	.REF	PLANA	.REF	PLOT	.REF	PLANB;LIB?MMENUS	=	LIB_BASE+137	; gestion d'un m-menu hirarchique;LIB?PMOUSE	=	LIB_BASE+145	; positionne la sourisREVSYS	=	H'100*5+4		; rvision systme; BFBLANC	=	7		; status de la fentre ODFMOD: fond blanc; Assemblage conditionnel; -----------------------CARPI	=	0	; grille spciale pour M. CARPI dans PLANREGLOU,GRILLE			; chose horrible  supprimer ds que GRILLE 'UTILISATEUR' !!!GROUPETX =	0	; groupe utilisateur avec texte; Entte; ------	.R