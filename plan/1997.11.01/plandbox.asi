		.SBTTL	PLANDBOX	; 28 novembre 87 Sp.;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2,D4	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...;PUSHM.L	D7,D0,D4;LOAD.L	D4,D0;LIB	?AFCR;LIB	?AFCR;LIB	?AFX4		; affiche appel;LIB	?AFSPACE;LOAD.L	D4,D6;LIB	?AFX8		; canal;LIB	?AFSPACE;LOAD.L	D4,D7;LIB	?AFX8		; erreur;POPM.L	D7,D0,D4	POPM.L	D1,D2,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXSAVE >		NOUVEAU nov. 87;=========/; Sauve le plan actuel selon le choix de l'utilisateur, touche F0 ou v. F1; in	D0.W	mode (0=quitte, 1=nouveau plan); out	D7.W	erreur (reste dans plan); mod	D7.WDBOXSAVE:	PUSHM.L	D1..D4,A0,A2..A5	CALL	CWMO	CALL	SRMO	LOAD.L	A0,A5		; sauve ^variables PLANA	TEST.B	(A6)+OPLANAV+OFLAGS:#BMODIF ; plan  jour ?	JUMP,BC	80$		; oui => 80$ (quitte, snif)	COMP.W	(A6)+OPLANAV+OUBMEM,#4	; qq objets dans le plan ?	JUMP,LS	80$		; non => 80$	TCLR.B	(A6)+OPLANAV+OFLAGS:#BMDBOX	; DBOX n'a pas dmoli !?	CLR.L	D4		; D4 <-- fanions	LOAD.B	D4,(A6)+OFLIO	TSET.L	D4:#BOUTPLAN	; dans tous les cas	CLR.L	D3	TEST.B	D0	JUMP,NE	25$	TSET.L	D3:#BDBIOQUIT25$:	LOAD.L	A5,#(A6)+OBUMEMF	; A5 ^nom du fichier	LOAD.L	A2,#R16"TOBJ_SAUVE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_MAJ	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	TSET.L	D3:#BDBIOOBJ	DBOX_	EXTEND	PUSH.W	D7	CALL	DBOXREFAIT	POP.W	D7	COMP.W	D3,#F0			; ANNULE ?	JUMP,EQ	85$	COMP.W	D3,#F4			; NON ?	JUMP,EQ	80$	CLR.L	D2	TEST.B	(A5)	JUMP,EQ	79$	TSET.L	D2:#BDBAUTO79$:	LOAD.L	A5,A0		; A5 ^variables PLANA	CALL	AOUTPUT		; sauve tout sur disque (in D2 et D4 !)	JUMP',NE 85$80$:	CLR.W	D7		; D7 <-- quitte PLAN	JUMP'	90$85$:	LOAD.W	D7,#1		; D7 <-- reste dans PLAN90$:	POPM.L	D1..D4,A0,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOX_MSAUVE >		NOUVEAU nov. 87;============/;; Cre et ouvre un fichier pour sauve ds. MMENU-modif.;; in	A3.L	^nom actuel;	D4.L	fanions; out	D6.W	canal;	D4.L	fanions;	D3.W	dernire touche (RETURN/END);	D7.W	erreur; mod	D4,D3,D6,D7DBOX_MSAUVE:	PUSHM.L	D0,D1,D2,D5,A2..A510$:	TCLR.B	(A6)+OPLANAV+OFLAGS:#BMDBOX	CALL	DBOXEDITOM		; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP,NE	90$	TEST.L	D4:#BOUTPLAN	JUMP,BS	20$	LOAD.L	A4,#R16"TXIMAGE	LOAD.W	D3,#1	LIB	?ADDEXT20$:;@@;PUSH.L	D7;LIB	?AFTIM;.ASCIZE	"<CR><CR>FOS?CREATE<CR>";POP.L	D7	PUSHM.L	D4	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL	POPM.L	D4	JUMP,EQ	70$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$;???;;;JUMP,NE	70$				; oui =>	CALL	CWMO		; remet la souris normale	CALL	SRMO		; remet la flche normale (plus de rticule)	TSET.L	D2:#BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	PUSH.W	D7	CALL	DBOXREFAIT	; refait les soft-keys	POP.W	D7	JUMP',NE 90$	COMP.W	D3,#'O	JUMP,NE 10$45$:;@@;PUSH.L	D7;LIB	?AFTIM;.ASCIZE	"FOS?DELETE<CR>";POP.L	D7	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier;	JUMP,NE	90$	JUMP	20$		; rdite le nom70$:;;@@;PUSH.L	D7;LIB	?AFTIM;.ASCIZE	"FOS?OPEN<CR>";POP.L	D7	LOAD.W	D3,#2^BOPWR!2^BOPEXCL;?	LOAD.L	D0,#FOS?OPEN;?	CALL	ERCALL		; ouvre le fichierFOS	?OPEN	JUMP,NE	90$;@@;PUSH.L	D7;LIB	?AFTIM;.ASCIZE	"tout est ok<CR>";POP.L	D7	LOAD.W	D3,#F1		; D3 <-- (F1) pour ok.90$:	POPM.L	D0,D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXEDITOM >		NOUVEAU nov. 87;------------/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut; out	D3.W	dernire touche (F1/F4/F0);	D4.L	fanions;	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXEDITOM:	PUSHM.L	D1,D2,A2..A5	CALL	CWMO	CALL	SRMO	LOAD.L	A5,A3	LOAD.L	A2,#R16"TOBJ_MSAUVE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TXPLAN	LOAD.W	D1,#DBOX_EXTRAIT	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND20$:	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXT1	DBOX_	EXTEND	COMP.W	D3,#F0		; annule => 30$	JUMP,EQ	30$	TEST.L	D4:#BOUTPLAN;;	JUMP,NE	30$	JUMP,BS	30$	TEST.L	D4:#BIMDESS	JUMP,BS	30$	TSET.L	D4:#BOUTPLAN	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	20$30$:	PUSH.W	D7	CALL	DBOXREFAIT	POP.W	D790$:	POPM.L	D1,D2,A2..A5	TEST.W	D7	RET;--------\\; DBOX_F3 >		NOUVEAU nov. 87;========/;; Cre et ouvre un fichier quelconque.;; in	A3.L	^nom actuel;	D4.L	fanions;	D2.W	mode; out	D6.W	canal;	D4.L	fanions;	D3.W	dernire touche (RETURN/END);	D7.W	erreur; mod	D4,D3,D6,D7DBOX_F3:	PUSHM.L	D0,D1,D2,D5,A2..A5	CALL	CWMO	CALL	SRMO	TCLR.B	(A6)+OPLANAV+OFLAGS:#BMDBOX	TEST.B	(A3)		; vide ?	JUMP,EQ	05$		; oui				; non	CALL	KILEXT		; enlve extension ( a pourrait tre .IMAGE)	LOAD.W	D3,#1		; et met .PLAN	LOAD.L	A4,#R16"TXPLAN	LIB	?ADDEXT05$:	TEST.B	(A6)+OPLANAV+OFLAGS:#BMODIF ; plan  jour ?	JUMP,BC	10$			; oui => 10$					; non	COMP.W	(A6)+OPLANAV+OUBMEM,#4	; qq objets dans le plan ?	JUMP,HI	11$		; non => 11$10$:	TSET.L	D2:#BDBNMAJ		; touche mj grise11$:;;;;;	LOAD.B	D4,(A6)+OFLIO		; D4 <-- fanions;;;;;	tset.L	D4:#BOUTPLAN		; toujours .PLAN !	CALL	DBOXEDITO		; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F0		; ANNULE, ne change pas OFLIO	JUMP,EQ	90$	COMP.W	D3,#F1		; SAUVE, change OFLIO	JUMP,EQ	19$;	COMP.W	D3,#F4;	JUMP,NE	10$				; MAJ, change OFLIO	TSET.L	D2:#BDBAUTO	; si F4  mj, alors automatique19$:				; SAUVE =>;;;;;	TSET.L	D4:#BOUTPLAN		; toujours .PLAN !	CORRECTION 22 mars 1988	LOAD.B	(A6)+OFLIO,D4	; sauve les fanions20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL	JUMP,EQ	70$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	TEST.L	D2:#BDBAUTO	; mode automatique ?	JUMP',BS 45$		; oui => 45$	CALL	CWMO		; remet la souris normale	CALL	SRMO		; remet la flche normale (plus de rticule)	TSET.L	D2:#BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	PUSH.W	D7	CALL	DBOXREFAIT	; refait les soft-keys	POP.W	D7	JUMP',NE 90$	COMP.W	D3,#'O	JUMP,NE 10$45$:	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE	90$	JUMP	20$		; rdite le nom70$:	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP,NE	90$	LOAD.W	D3,#F1		; D3 <-- (F1) pour ok.90$:	LOAD.B	D4,(A6)+OFLIO	; D4 <-- fanions	POPM.L	D0,D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut;	D2.W	mode; out	D3.W	dernire touche (F1/F4/F0);	D4.L	fanions;	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXEDITO:	PUSHM.L	D1,D2,A2..A5	CALL	CWMO	CALL	SRMO	LOAD.W	D3,#F1		; D3 <-- comme si (SAUVE)	TEST.L	D2:#BDBAUTO	; mode automatique ?	JUMP,BS	90$		; oui => 90$	LOAD.L	A4,#R16"TXPLAN	TEST.L	D4:#BOUTPLAN	JUMP,BS	10$	LOAD.L	A4,#R16"TXIMAGE10$:	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TOBJ_SAUVE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	TSET.L	D2:#BDBEXTEND	; D2 <-- sous-appel d'extension	TSET.L	D2:#BDBSAV	; D2 <-- sauve le fond	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXT1	TEST.L	D2:#BDBNMAJ	JUMP,BC 30$	TSET.L	D3:#BDBIONMAJ	; D3 <-- touche (MET A JOUR) grise30$:	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXREFAIT	POP.W	D790$:	POPM.L	D1,D2,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre (.PLAN, .IMAGE, .BPLAN); in	A3.L	^nom actuel;	A4.L	^extension; out	D3.W	dernire touche (RETURN/END);	A3.L	^nouveau nom;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,A2..A5	CALL	CWMO	CALL	SRMO	LOAD.L	A5,A3		; A5 ^nom de fichier	CLR.L	D2	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	LOAD.L	A3,#R16"TDBOX_IO	COMP.B	(A4)+1,#'P	; ext. PLAN	JUMP,EQ	10$		; oui => 10$	COMP.B	(A4)+1,#'p	JUMP,EQ	10$	LOAD.L	A3,#R16"TDBOX_IIO ; non, ext. image ?	COMP.B	(A4)+1,#'I	; image de fond	JUMP,EQ	10$	COMP.B	(A4)+1,#'i;	JUMP,EQ	10$	JUMP,NE	90$10$:	LOAD.W	D1,#DBOX_PREND30$:	DBOX_	EXTEND	PUSH.W	D7	CALL	DBOXREFAIT	POP.W	D790$:	POPM.L	D1,D2,A2..A5	TEST.W	D7	RET;----------\\; DBOXEDITA >;==========/; Edite un nom de fichier en entre (ajoute); in	D4.L	tats des fanions;	A3.L	^nom actuel; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	A3.L	^nouveau nom avec extension !;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITA:	PUSHM.L	D1,D2,A2..A5	CALL	CWMO	CALL	SRMO	LOAD.L	A5,A3		; A5 ^nom de fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TXPLAN	CLR.L	D2	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOOBJ	LOAD.W	D1,#DBOX_AJOUTE	LOAD.L	A2,#R16"TOBJ_AAJOUTE30$:	DBOX_	EXTEND	PUSH.W	D7	CALL	DBOXREFAIT	POP.W	D790$:	TEST.W	D7	POPM.L	D1,D2,A2..A5	RET;-----------\\; DBOXQUITTE >;-----------/;; demande s'il faut quitter le programme;; in	-; out	D3.W	dernire touche;	D7.W	erreurDBOXQUITTE:	PUSHM.L	D1,D2,D4,A2..A5	CALL	CWMO	CALL	SRMO	CLR.L	D4			; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	; textes	LOAD.W	D1,#DBOX_QUITTE		; code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND ; mode	CLR.L	D3	DBOX_	EXTEND			; attend rponse	PUSH.W	D7	CALL	DBOXREFAIT	POP.W	D790$:	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7	RET;-----------\\; DBOXSPLINE >;===========/; Demande s'il faut modifier un spline.; in	-; out	D3.W	rponse (O), (N) ou (UNDO); mod	D3.L, D7.WDBOXSPLINE:	PUSHM.L	D1,D2,D4,A1,A2,A3,A4	LIB	?BUZZ		; signal qq chose de spcial	LOAD.L	A2,#R16"TDBOX_SPLINE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUINONEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	JUMP',NE 40$	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	JUMP'	50$40$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,A1,A2,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXTOURNE >;===========/; Demande un angle de rotation spcial.; in	-; out	D7.W	erreur; mod	D7.WDBOXTOURNE:	PUSHM.L	D1..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_TOURNE	LOAD.W	D2,#2^BDBSAV!2^BDBMOU ; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$20$:	LOAD.L	A3,#(A6)+OBNTOUR	LOAD.L	A4,A323$:	TEST.B	(A4+)	JUMP',EQ 24$	COMP.B	(A4)-1,#CR	JUMP,NE 23$24$:	DEC.L	A4		; A4 <-- ^fin du dernier nombre25$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	25$		; oui => 25$	COMP.W	D3,#UNDO	JUMP',EQ 40$	COMP.W	D3,#CR		; (TOURNE) ?	JUMP',EQ 50$	LOAD.W	D7,#1	COMP.W	D3,#END		; (ANNULE) ?	JUMP,EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	25$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	25$50$:				; TOURNE =>	LOAD.L	A3,#(A6)+OBNTOUR	LOAD.L	A4,A3		; A4 <-- ^nombre prsum	CALL	TRDNUM		; D4 <-- nombre	JUMP,NE 30$	CONV.LA.WA D4	DIV.WA	D4,#360	SWAP.W	D4		; D4 <-- +/- 0..360-1	TEST.W	D4	JUMP',NC 70$	ADD.W	D4,#36070$:	LOAD.W	(A6)+OPLANAV+OMTOUR,D480$:				; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D790$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TRDNUM  >;--------/; Lit un angle en degrs, sans dcimales.; in	A4.L	^nombre prsum; out	A4.L	^plus loin;	D4.W	nombre (+/-);	D7.W	erreur; mod	D4.L, D7.W, A4.LTRDNUM:	PUSHM.L	D2,D3,A3	CLR.W	D2		; D2 <-- positif	COMP.B	(A4),#'-	; signe moins ?	JUMP',NE 05$		; non => 05$	INC.L	A4		; oui =>	INC.W	D2		; D2 <-- ngatif05$:	LOAD.W	D7,#ERSYNT	LOAD.L	A3,A4		; A3 <-- ^dbut du nombre	CLR.W	D4		; D4 <-- futur nombre10$:	CLR.W	D3	LOAD.B	D3,(A4+)	; D3 <-- caractre	COMP.B	D3,#'0		; est un digit ?	JUMP',LO 40$		; non => 40$	COMP.B	D3,#'9	JUMP',HI 40$	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.W	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$40$:	TEST.W	D2		; nombre positif ?	JUMP',EQ 45$		; oui => 45$	NEG.L	D4		; non => prend le complment45$:	TEST.B	D3	JUMP',EQ 50$	COMP.B	D3,#CR		; nombre termin ?	JUMP',NE 90$		; non => 90$50$:	DEC.L	A4	COMP.L	A4,A3		; au moins un digit ?	JUMP',EQ 90$		; non => 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2,D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXZOOM  >;==========/; Demande deux facteurs de zoom spciaux.; in	-; out	D7.W	erreur; mod	D7.WDBOXZOOM:	PUSHM.L	D1..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_ZOOM	LOAD.W	D2,#2^BDBSAV!2^BDBMOU ; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	LOAD.W	D2,#3	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBYZOOM	LIB	?AFTEXT		; affiche le facteur vertical	CLR.W	D2		; D2 <-- dans facteur en X20$:	LOAD.L	A3,#(A6)+OBXZOOM	TEST.W	D2	JUMP',EQ 22$	LOAD.L	A3,#(A6)+OBYZOOM22$:	LOAD.L	A4,A323$:	TEST.B	(A4+)	JUMP',EQ 24$	COMP.B	(A4)-1,#CR	JUMP,NE 23$24$:	DEC.L	A4		; A4 <-- ^fin du dernier nombre25$:	LOAD.W	D3,D2	DBOX_	MEDIT		; indique le facteur  diter	DBOX_	EDIT		; attend une action ...	COMP.W	D3,#CR	JUMP',EQ 47$	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	25$		; oui => 25$	COMP.W	D3,#UNDO	JUMP',EQ 40$	COMP.W	D3,#F4	JUMP',EQ 45$	COMP.W	D3,#F5	JUMP',EQ 45$	COMP.W	D3,#CR		; (ZOOM) ?	JUMP',EQ 50$	LOAD.W	D7,#1	COMP.W	D3,#END		; (ANNULE) ?	JUMP,EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	25$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	25$45$:				; change =>	SUB.W	D3,#F4	LOAD.W	D2,D3		; D2 <-- 0..1	JUMP	20$47$:				; suivant =>	INC.W	D2	COMP.W	D2,#2	JUMP,LO 20$	CLR.W	D2	JUMP	20$50$:				; ZOOM =>	CLR.W	D2	LOAD.L	A3,#(A6)+OBXZOOM	LOAD.L	A4,A3		; A4 <-- ^nombre prsum	CALL	ZRDNUM		; D4 <-- nombre *1000	JUMP,NE 30$	LOAD.W	(A6)+OPLANAV+OXZOOM,D4	INC.W	D2	LOAD.L	A3,#(A6)+OBYZOOM	LOAD.L	A4,A3		; A4 <-- ^nombre prsum	CALL	ZRDNUM		; D4 <-- nombre *1000	JUMP,NE 30$	LOAD.W	(A6)+OPLANAV+OYZOOM,D480$:				; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D790$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZRDNUM  >;--------/; Lit un nombre  trois dcimales, rendu 1000 fois plus grand.; S'il n'y a pas de nombre, rend 1 pour ne rien zoomer !; in	A4.L	^nombre prsum; out	A4.L	^plus loin;	D4.W	nombre (+/-);	D7.W	erreur; mod	D4.L, D7.W, A4.LZRDNUM:	PUSHM.L	D1..D3,A3	CLR.W	D1		; D1 <-- nb de dcimales	CLR.W	D2		; D2 <-- positif	COMP.B	(A4),#'-	; signe moins ?	JUMP',NE 05$		; non => 05$	INC.L	A4		; oui =>	INC.W	D2		; D2 <-- ngatif05$:	LOAD.W	D7,#ERSYNT	LOAD.L	A3,A4		; A3 <-- ^dbut du nombre	CLR.W	D4		; D4 <-- futur nombre10$:	CLR.W	D3	LOAD.B	D3,(A4+)	; D3 <-- caractre	COMP.B	D3,#'.	JUMP',EQ 30$	COMP.B	D3,#'0		; est un digit ?	JUMP',LO 40$		; non => 40$	COMP.B	D3,#'9	JUMP',HI 40$	TEST.L	D1:#15		; est-on dans les dcimales ?	JUMP',BC 20$		; non => 20$				; oui =>	COMP.B	D1,#3		; plus de 3 dcimales ?	JUMP,HS 10$		; oui => 10$ (ignore)	INC.B	D1		; non => une dcimale de plus20$:	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.W	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$30$:	TSET.L	D1:#15		; D1 <-- partie dcimale existe	JUMP,BS 90$		; si 2me point => 90$ (erreur)	JUMP	10$40$:	TEST.W	D2		; nombre positif ?	JUMP',EQ 45$		; oui => 45$	NEG.L	D4		; non => prend le complment45$:	TEST.B	D3	JUMP',EQ 50$	COMP.B	D3,#CR		; nombre termin ?	JUMP',NE 90$		; non => 90$50$:	DEC.L	A4	COMP.L	A4,A3		; au moins un digit ?	JUMP',NE 55$		; oui => 55$	LOAD.W	D4,#1		; non => pas de zoom, donc facteur 155$:	LOAD.W	D2,#1000	; D2 <-- aucune dcimale	TEST.B	D1	JUMP',EQ 60$	LOAD.W	D2,#100		; D2 <-- une dcimale	DEC.B	D1	JUMP',EQ 60$	LOAD.W	D2,#10		; D2 <-- deux dcimales	DEC.B	D1	JUMP',EQ 60$	LOAD.W	D2,#1		; D2 <-- trois dcimales60$:	MUL.WU	D4,D2		; D4 <-- simule les dcimales manquantes	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D3,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande confirmation pour "Efface".; in	-; out	D3.W	rponse (F1/F4/END);	D7.W	erreur; mod	D3.L, D7.WDBOXEFFACE:	PUSHM.L	D1,D2,D4,D5,A1,A2,A3,A4	LIB	?BUZZ		; signal qq chose de spcial	LOAD.L	A2,#R16"TDBOX_EFFACE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_EFFACE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP',EQ 50$	COMP.W	D3,#F4	JUMP',EQ 50$	COMP.W	D3,#END	JUMP',EQ 50$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1,A2,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXASCII >;==========/; Attend un caractre ASCII.; in	-; out	D4.B	code;	D4:#8	trames 100%;	D7.W	erreur (END); mod	D4.L, D7.WDBOXASCII:	PUSHM.L	D1,D2,D3,D5,A1,A2,A3,A4	LOAD.L	A2,#R16"TDBOX_ASCII	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	TEST.B	(A6)+OFLMOD:#BMINGC	JUMP',BC 10$	TSET.L	D4:#010$:	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	95$	LOAD.L	A3,#(A6)+OBUTEMP	LOAD.L	A4,A3	CLR.B	(A4)		; terminateur20$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR	JUMP',EQ 50$	LOAD.W	D7,#1		; D7 <-- (END)	COMP.W	D3,#END	JUMP,EQ	90$	COMP.W	D3,#UNDO	JUMP',EQ 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$50$:	LOAD.W	D3,D4		; D3 <-- fanion	PUSH.L	A4	LOAD.L	A4,A3	CALL	GETANUM		; D4 <-- code ASCII	POP.L	A4	COMP.W	D4,#128		; code trop grand ?	JUMP,HS	30$		; oui => 30$	SL.W	D3,#8	OR.W	D4,D3		; D4 <-- bit:#8 si trames 100%	CLR.W	D7		; D7 <-- ok90$:	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D795$:	POPM.L	D1,D2,D3,D5,A1,A2,A3,A4	RET;---------\\; DBOXOPEN >;=========/; Ouvre une DBOX en sauvant si possible le dessous.; in	voir DBOX_OPEN; out	idem; mod	idemDBOXOPEN:	PUSH.W	D2	CALL	CWMO		; remet la souris normale	CALL	SRMO		; remet la flche normale (plus de rticule)	TCLR.B	(A6)+OPLANAV+OFLAGS:#BMDBOX	DBOX_	OPEN		; ouvre la DBOX	JUMP',EQ 90$		; ok => 90$	TCLR.L	D2:#BDBSAV	; essaye sans sauver	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE 90$		; erreur => 90$	TSET.B	(A6)+OPLANAV+OFLAGS:#BMDBOX90$:	POP.W	D2	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXCLOSE >;==========/; Ferme une DBOX en redessinant tout l'cran si le dessous; n'a pas pu tre sauv.; in	voir DBOX_CLOSE; out	idem; mod	idemDBOXCLOSE:	TEST.L	D5		; dbox ouverte ?	JUMP',NE 50$		; oui => 50$	RET			; non => ne fait rien !50$:	DBOX_	CLOSE		; ferme la DBOXDBOXREFAIT:	TEST.B	(A6)+OPLANAV+OFLAGS:#BMDBOX	JUMP',BC DBOXREF	CALL	MAJCADRE	; redessine le cadre, et efface le dessin	CALL	REFAIT		; puis redessineDBOXREF:			; point d'entre pour DBOX_EXTEND !!!	LIB	?AFTIM	.B	NOCURS,0	; supprime le curseur	.EVEN	CALL	AFMENU		; remet les soft-keys standards	CALL	CRMO		; enlve la flche normale (met le rticule)	CLR.W	D7		; D7 <-- ok	RET;-----------\\; DBOX_PLOT  >;===========/; Demande confirmation pour "TRACE".; in	-; out	D3.W	rponse ('O, 'N);	D7.W	erreur; mod	D3.L, D7.WDBOX_PLOT:	PUSHM.L	D1,D2,D4,D5,A1,A2,A3,A4	CALL	CWMO	CALL	SRMO	LIB	?BUZZ		; signal qq chose de spcial	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_PLOT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUINON	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#'O	JUMP',EQ 50$	COMP.W	D3,#'N	JUMP',EQ 50$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1,A2,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOX_IMAGE  >;===========/; Demande confirmation pour "image".; in	-; out	D7.W	EQ oui;		NE non; mod	D3.L, D7.WDBOX_IMAGE:	PUSHM.L	D1,D2,D3,D4,D5,A1,A2,A3,A4	CALL	CWMO	CALL	SRMO	LIB	?BUZZ		; signal qq chose de spcial	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_IMAGE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUINON	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#'O	JUMP',EQ 50$	COMP.W	D3,#'N	JUMP',EQ 40$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; NON ...	CALL	DBOXCLOSE	LOAD.W	D7,#1	JUMP	90$50$:				; OUI ...	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D3,D4,D5,A1,A2,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; STOFILE >;========/; Mmorise le nom du fichier si D7.W gal  zro et nom <> PLAN.PLAN;; in	A3.L	^nom du fichier  mmoriser;	D7.W; out	-; mod	-STOFILE:	PUSHM.L	D3,D7,A2,A3,A4	TEST.W	D7		; ok ?	JUMP',NE 90$		; non => 90$	LOAD.L	A2,#R16"01$	; fichier PLAN.PLAN ?	LOAD.L	A4,#R16"00$	LIB	?CPSTRING	JUMP,EQ	90$		; oui --> 90$	LOAD.L	A4,#(A6)+OBUMEMF10$:	LOAD.B	D3,(A3+)	JUMP',EQ 50$	COMP.B	D3,#CR	JUMP',EQ 50$	LOAD.B	(A4+),D3	JUMP	10$50$:	CLR.B	(A4)90$:	POPM.L	D3,D7,A2,A3,A4	RET00$:	.ASCIZE	/PLAN.PLAN<CR>/01$:	.B	0,CR,-1	.EVEN;--------\\; RCLFILE >;========/; Rappel le nom du fichier.; in	A3.L	^buffer o rappeler le fichier; out	-; mod	-RCLFILE:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBUMEMF10$:	LOAD.B	(A3+),(A4+)	JUMP,NE	10$	POPM.L	A3,A4	RET;--------\\; AFFFILE >;========/; Affiche le nom d'un fichier, en minuscules et; avec deux guillemets (de part et d'autre).; in	A3.L	^nom du fichier; out	-; mod	D7.WAFFFILE:	PUSHM.L	D3,A3,A4	LOAD.L	A4,#(A6)+OBUAFFF10$:	LOAD.B	D3,(A3+)	JUMP',EQ 50$	COMP.B	D3,#CR	JUMP',EQ 50$	CALL	MAJMIN		; D3 <-- lettre minuscule	LOAD.B	(A4+),D3	JUMP	10$50$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUAFFF	CALL	KILEXT		; n'affiche pas l'extension	LOAD.B	D3,#'"	LIB	?AFCAR	LIB	?AFTEXT		; affiche le nom du fichier	LIB	?AFCAR	POPM.L	D3,A3,A4	RET;--------\\; KILEXT  >;========/; Supprime l'extension d'un fichier.; in	A3.L	^nom du fichier; out	-; mod	-KILEXT:	PUSHM.L	D3,A4	LOAD.L	A4,A310$:	TEST.B	(A4+)		; A4 <-- ^fin du nom	JUMP,NE	10$20$:	COMP.L	A4,A3		; dbut du nom ?	JUMP',EQ 90$		; ou => 90$	LOAD.B	D3,(-A4)	COMP.B	D3,#':	JUMP',EQ 90$	COMP.B	D3,#'.	JUMP,NE	20$	CLR.B	(A4)		; remplace "." par terminateur90$:	POPM.L	D3,A4	RET;--------\\; DOK...  >;========/DOKOUI:	LOAD.W	D3,#'O	RETDOKNON:	LOAD.W	D3,#'N	RETDOKOK:	LOAD.W	D3,#CR	RETDOKANNULE:	LOAD.W	D3,#END	RETDOKEFFACE:	LOAD.W	D3,#UNDO	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF13:	LOAD.W	D3,#F13	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOPGMM:; gre les flags mm et pg et relit l x h; pour TDBOX_DEFINE	COMP.W	D3,#209		; pg ?	JUMP,NE	20$		; non ...	TEST.L	D4:#8		; si l'autre => changer	JUMP,BS	70$	TSET.L	D4:#9		; remet	CALL	GETDIM		; le mme	JUMP	DOKMGR20$:;	COMP.W	D3,#208		; mm ?;	JUMP,NE	...		; non ...	TEST.L	D4:#9		; si l'autre => changer	JUMP,BS	80$	TSET.L	D4:#8		; remet	CALL	GETDIM	JUMP	DOKMGR		; le mme70$:	TNOT.L	D4:#8	JUMP	90$80$:	TNOT.L	D4:#9;	JUMP	90$90$:	TNOT.L	D4:#8	TNOT.L	D4:#9	CALL	GETDIM	TNOT.L	D4:#8	TNOT.L	D4:#9	JUMP	DOKMGR; Tables pour DBOX; ----------------TDBOX_IO:	.ASCIZ	"PLAN"	.ASCIZ	"Mplan"	.ASCIZ	""	.B	0	.EVENTDBOX_IIO:	.ASCIZ	"PLAN"	.ASCIZ	"Fimage"	.ASCIZ	""	.B	0	.EVENTOBJ_AAJOUTE:	.B	LTOBJ_AAJOUTE	.B	ODBCIRCLE,BINIDEM	.ASCIZ	" normal"	.B	ODBCR,ODBCR	.B	ODBCIRCLE,BINULIE	.ASCIZ	" assemble "	.B	ODBTABX,14	.B	ODBTEXT	.B	USEGC GCICF GCICS GCICT 44	.B	USEGC GCTXF GCTXS GCTXT 0	.B	ODBTABX,23	.B	ODBCIRCLE,BINSLIE	.ASCIZ	" colle "	.B	ODBTABX,34	.B	ODBTEXT	.B	USEGC GCICF GCICS GCICT 46	.B	USEGC GCTXF GCTXS GCTXT 0	.B	ODBCR,ODBCR	.B	ODBCIRCLE,BINUDELIE	.ASCIZ	" spare   "	.B	ODBTABX,14	.B	ODBTEXT	.B	USEGC GCICF GCICS GCICT 45	.B	USEGC GCTXF GCTXS GCTXT 0	.B	ODBTABX,23	.B	ODBCIRCLE,BINSDELIE	.ASCIZ	" coupe "	.B	ODBTABX,34	.B	ODBTEXT	.B	USEGC GCICF GCICS GCICT 47	.B	USEGC GCTXF GCTXS GCTXT 0	.B	ODBCRLTOBJ_AAJOUTE	=	.-TOBJ_AAJOUTE-1	.EVENTOBJ_SAUVE:	.B	LTOBJ_SAUVE;		.B	ODBSQUARE,BOUTPLAN;		.ASCIZ	" sauve le plan et ..."	.B	ODBTEXT	.ASCIZ	"   et en outre ..."	.B	ODBCR	.B	ODBCR,ODBTABX,4;	.B	ODBLCIRCLE,BIMRIEN		;!2^6!2^7,0,0.B	ODBLCIRCLE,BIMRIEN!2^7,0,0	.ASCIZ	/ pas d'image/	.B	ODBCR,ODBTABX,4;	.B	ODBLCIRCLE,BIMECR		;!2^6!2^7,0,0.B	ODBLCIRCLE,BIMECR!2^7,0,0	.ASCIZ	/ l'image  visible   l'cran/	.B	ODBCR,ODBTABX,4;	.B	ODBLCIRCLE,BIMDESS		;!2^6!2^7,0,0.B	ODBLCIRCLE,BIMDESS!2^7,0,0	.ASCIZ	/ l'image cadr  selon dessin/	.B	ODBCR,ODBTABX,4;	.B	ODBLCIRCLE,BIMPLAN		;!2^6!2^7,0,0.B	ODBLCIRCLE,BIMPLAN!2^7,0,0	.ASCIZ	/ l'image aux dimensions PLAN/	.B	ODBCRLTOBJ_SAUVE =	.-TOBJ_SAUVE-1	.EVENTOBJ_MSAUVE:	.B	LTOBJ_MSAUVE	.B	ODBTABX,1	.B	ODBSQUARE,BOUTPLAN	.ASCIZ	" sauve le plan"	.B	ODBCR	.B	ODBTABX,1	.B	ODBSQUARE,BIMDESS	.ASCIZ	" sauve l'image"	.B	ODBCR	LTOBJ_MSAUVE	=.-TOBJ_MSAUVE-1	.EVENTDBOX_DEFINE:	.W	10$-TDBOX_DEFINE	.W	MENU_OKAN-TDBOX_DEFINE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Dimensions"	.B	ODBLINE,13+2	.B	ODBBOX,0,DEFINE,TDBNORM	.ASCIZ	"ECRAN";;;;	.B	ODBTABX,40	.B	ODBTEXT	.ASCIZ	/page:/	.B	ODBBOX,0,FNCT,TDBNORM		; ???	.ASCIZ	/VERTI/	.B	ODBTABX,47	.B	ODBBOX,0,MACRO,TDBNORM	.ASCIZ	/HORIZ/	.B	ODBCR	.B	ODBTEXT	.ASCIZ	" (l / h)"	.B	ODBCR	.B	ODBTABX,4	.B	ODBSQUARE,10	.ASCIZ	/ zoom gnral/	.B	ODBTABX,26	.B	ODBTEXT	.ASCIZ	/units :  /	.B	ODBLCIRCLE,9!2^7!2^6,0,209	.ASCIZ	/[pg] /	.B	ODBLCIRCLE,8!2^7!2^6,0,208	.ASCIZ	/[mm]/	.B	ODBCR	.B	ODBTABX,8	.B	ODBTEXT	.ASCIZ	/si modifies/	.B	ODBTABX,37	.B	ODBTEXT	.ASCIZ	/<'<>  arrondi <'>>/	.B	ODBCR	.B	ODBTEXT	.ASCIZ	/______________________________________________________/;;;;;;	.B	ODBCR;;;;;;	.B	ODBSQUARE,1;;;;;;	.ASCIZ	" traits d'esquisse (seulement  l'cran)"	.B	ODBCR	.B	ODBSQUARE,2	.ASCIZ	" caractres sous formes de trames 100%"	.B	ODBCR	.B	ODBSQUARE,6	.ASCIZ	" mmorise la dernire case"	.B	ODBCR	.B	ODBSQUARE,4	.ASCIZ	" cadre invers"	.B	ODBCR	.B	ODBSQUARE,7	.ASCIZ	" rticule"	.B	ODBCR;;;*	.B	ODBSQUARE,5;;;*	.ASCIZ	" aligne les modifications";;;*	.B	ODBCR	.B	ODBSQUARE,11	.ASCIZ	" rfrence dynamique".B	ODBCR.B	ODBSQUARE,1.ASCIZ	" affichage dynamique d'informations "	.B	ODBCR	.B	ODBSQUARE,3	.ASCIZ	" image de fond cache (si prsent)"	.B	ODBCR,ODBCR	.B	ODBTABX,4	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTABX,36	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	0	.EVENTKEY_DEF:	.W	END,F0,F13,F14,F15,0	DOKANNULE-TKEY_DEF	.W	CR,F1,F2,F3,0		DOKOK-TKEY_DEF	.W	208,209,0		DOPGMM-TKEY_DEF	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEF	.W	0TDBOX_ASCII:	.W	10$-TDBOX_ASCII	.W	MENU_INAN-TDBOX_ASCII	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Code dcimal du caractre "	.B	ODBFILE,3+2	.B	ODBCR,ODBCR	.B	ODBSQUARE,0	.ASCIZ	" caractre sous forme de trames 100%"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" INSERE "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	" ANNULE "	.B	0	.EVENTDBOX_EFFACE:	.W	10$-TDBOX_EFFACE	.W	MENU_EFFACE-TDBOX_EFFACE	.W	0,010$:	.B	ODBTABX,14	.B	ODBTEXT	.ASCIZ	"Que faut-il effacer ?"	.B	ODBCR,ODBCR	.B	ODBTABX,14	.B	ODBTE