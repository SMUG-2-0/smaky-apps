	.SBTTL	DISTYPO;--------\; AFCODE  >;========/; Affiche un caractre sans tenir compte des caractres; spciaux.; in	D3.B	caractre  afficher;	A2.L	^description de la fentre; out	D7.W	erreur; mod	D7.WAFCODE:	.IF	TTY	PUSH.W	D3	COMP.B	(A2)+ODFNOW,#7	; fentre des soft-keys ?	JUMP,EQ 90$		; oui => 90$	COMP.B	(A2)+ODFNOW,#9	; fentre de l'horloge ?	JUMP,EQ 90$		; oui => 90$	COMP.B	(A2)+ODFNOW,#8	; fentre du C.L.E. ?	JUMP,NE 50$		; non => 50$				; oui =>	COMP.B	(A2)+ODFGCF,#'S	JUMP,NE 50$	COMP.B	(A2)+ODFGCS,#'N!2^7 ; gencar SNFxx ?	JUMP,NE 50$		; non => 50$				; oui =>	COMP.B	D3,#H'0C	JUMP,NE 90$	CLR.L	(A2)+ODFPY	CALL	POSTTY		; met le curseur en haut  gauche	LOAD.B	D3,#'*	CALL	WRTTY	JUMP	90$50$:	COMP.B	D3,#'	JUMP,LO 90$	COMP.B	D3,#H'7F	JUMP,HS 90$	CALL	NOACCENT	; D3 <-- enlve les accents	CALL	WRTTY	LOAD.W	D3,(A2)+ODFCX	; D3 <-- espace intercaractres	ADD.W	(A2)+ODFPX,D3	; ODFPX <-- nouvelle position en X90$:	POP.W	D3	CLR.W	D7		; D7 <-- ok	.ELSE	PUSHM.L	D0..D5,A3,A410$:	LOAD.L	A3,(A2)+ODFPGC	; A3 <-- ^GENCAR; Cherche quel est le caractre  afficher, d'aprs le premier caractre; contenu dans le gnrateur (OGCFCA).	CLR.W	D0	LOAD.B	D0,D3		; D0 <-- code du caractre	COMP.B	D0,(A3)+OGCLCA	; code caractre trop grand ?	JUMP,HI 90$		; oui => 90$	SUB.B	D0,(A3)+OGCFCA	; code caractre trop petit ?	JUMP,LO 90$		; oui => 90$; Calcule la position sup/gauche et les dimensions du pav contenant; le caractre. La largeur dpend du caractre.	LOAD.L	D4,(A2)+ODFPY	; D4 <-- coordonne (y;x)	SUB.W	D4,(A2)+ODFC1X	; D4 <-- coordonne  gauche	SWAP.W	D4	SUB.W	D4,(A2)+ODFC1Y	; D4 <-- coordonne en haut	SWAP.W	D4	LOAD.W	D2,(A2)+ODFC1Y	ADD.W	D2,(A2)+ODFC2Y	; D2 <-- hauteur du caractre	SWAP.W	D2	CLR.W	D2	LOAD.L	A4,#(A3)+OGCWID	; A4 <-- ^table des largeurs	LOAD.B	D2,(A4)+(D0.W)	; D2 <-- largeur du caractre; Vrifie si le caractre dborde sur la droite.	LOAD.W	D1,D4	ADD.W	D1,D2	COMP.W	D1,(A2)+ODFFDX	; dpasse  droite ?	JUMP',LO 20$		; non => 20$				; oui =>	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	TEST.B	(A2)+ODFMOD:#BFTRUNC	JUMP,NE 90$	CALL	DOCR		; passe  la ligne	JUMP	10$; Vrifie si le caractre recouvre la souris, sans utiliser ITCLUTIN; pour aller plus vite !20$:	LOAD.L	A4,(A0)+OLSTPD	; A4 <-- ^descripteur o est la souris	TEST.B	(A4)+ODFMFL:#BFMCLR ; lutin dj enlev ?	JUMP',BS 32$		; oui => 32$	LOAD.L	D5,D4	ADD.W	D5,(A2)+ODFWBX	ADD.W	D5,D2	LOAD.W	D1,(A4)+ODFMPO+2 ; D1 <-- X min	COMP.W	D5,D1	JUMP',LO 32$	SUB.W	D5,D2	ADD.W	D1,(A4)+ODFMDI+2 ; D1 <-- X max	COMP.W	D5,D1	JUMP',HS 32$	SWAP.W	D2	SWAP.W	D5	ADD.W	D5,(A2)+ODFWBY	ADD.W	D5,D2	LOAD.W	D1,(A4)+ODFMPO+0 ; D1 <-- Y min	COMP.W	D5,D1	JUMP',LO 30$	SUB.W	D5,D2	ADD.W	D1,(A4)+ODFMDI+0 ; D1 <-- Y max	COMP.W	D5,D1	JUMP',HS 30$	CALL	CLRLUTIN	; enlve le lutin de la souris30$:	SWAP.W	D2; Si l'image alphanumrique existe, ne le caractre dedans.32$:	TEST.B	(A2)+ODFFLG:#BFIMAA ; image alphanum. existe ?	JUMP',BC 40$		; non => 40$	CALL	OPIMA?		; image alphanum. existe ?	JUMP',NE 40$		; non => 40$				; oui =>	CALL	GPTIMA		; A4 <-- ^dans image	JUMP',NE 40$		; si erreur => 40$	LOAD.B	(A4),D3		; image <-- mm. caractre; Calcule les paramtres permettant d'appeler directement GRA_RASTER, et; non GRA_MATRIX, pour aller plus vite !40$:	CLR.L	D3		; D3 <-- position dans source	CLR.W	D5	LOAD.B	D5,(A3)+OGCMWB	; D5 <-- incrment Y ds GENCAR	CLR.L	D1	LOAD.B	D1,(A3)+OGCLCA	SUB.B	D1,(A3)+OGCFCA	INC.B	D1		; D1 <-- nb car dans gnrateur	LOAD.L	A4,#(A3)+OGCWID	; A4 <-- ^table des largeurs	ADD.L	A4,D1		; A4 <-- skip width(s)	ADD.L	A4,D1		; A4 <-- swip heigth(s) above baseline	ADD.L	A4,D1		; A4 <-- swip heigth(s) under baseline	MUL.WU	D0,(A3)+OGCMSB	; * matrix size (in bytes)	ADD.L	A4,D0		; A4 <-- ^matrix dans GENCAR	LOAD.L	A3,A4		; A3 <-- ^source	LOAD.L	A4,#0		; A4 <-- ^destination (dans l'cran)	LOAD.B	D1,(A2)+ODFMCA	; D1 <-- mode d'affichage	COMP.B	D1,#SETDOT	JUMP',NE 50$	LOAD.B	D1,#LOADDOT50$:	TCLR.L	D1:#BPENDOT	TEST.B	(A2)+ODFFLG:#BFVIDI ; vido inverse ?	JUMP',BC 52$	TSET.L	D1:#BCPLDOT52$:	TEST.B	(A2)+ODFFLG:#BFGREY ; affiche en gris ?	JUMP',BC 53$	TSET.L	D1:#BGREDOT53$:	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_RASTER-GRA_FIRST))	CALL	(A0)		; dessine un caractre ...	POP.L	A0; Avance la position du caractre plus loin vers la droite.	TEST.B	(A2)+ODFMOD:#BFCFIX ; chasse fixe ?	JUMP',EQ 70$		; non => 70$	LOAD.W	D2,(A2)+ODFCX	; D2 <-- espace intercaractres70$:	ADD.W	D2,(A2)+ODFPX	; D2 <-- nouvelle position en X	ADD.W	D2,(A2)+ODFCIX	; ajoute incrment +/-	LOAD.W	(A2)+ODFPX,D2	; mj mouvelle position en X90$:	POPM.L	D0..D5,A3,A4	.ENDIF	RET	.IF	TTY;---------\\; NOACCENT >;=========/; ; in	D3.B	; out	D3.B	; mod	D3.WNOACCENT:	COMP.B	D3,#'	JUMP',LO 90$	COMP.B	D3,#'	JUMP',HI 90$	SUB.B	D3,#'	AND.W	D3,#H'00FF	LOAD.B	D3,(PC)+(D3)+00$  ; D3 <-- lettre sans accent90$:	RET00$:	.B	'u 'a 'a 'e 'e 'e 'e 'i 'i 'o 'u 'u 'a 'o 'c	.EVEN	.ENDIF	.IF	TTY;--------\\; EOPTTY  >;========/; Efface le terminal.; in	-; out	-; mod	D7.WEOPTTY:	PUSH.W	D3	LOAD.B	D3,#H'9B	CALL	WRTTY		; <CSI>	LOAD.B	D3,#'2	CALL	WRTTY		; <2>	LOAD.B	D3,#'J	CALL	WRTTY		; <J>	POP.W	D3	RET	.ENDIF	.IF	TTY;--------\\; EOLTTY  >;========/; Efface la fin de la ligne.; in	-; out	-; mod	D7.WEOLTTY:	PUSH.W	D3	LOAD.B	D3,#H'9B	CALL	WRTTY		; <CSI>	LOAD.B	D3,#'K	CALL	WRTTY		; <K>	POP.W	D3	RET	.ENDIF	.IF	TTY;--------\\; ROLLTTY >;========/; Effectue un scroll d'une ligne vers le haut.; in	A2.L	^descripteur; out	-; mod	D7.WROLLTTY:	PUSHM.L	D3	COMP.B	(A2)+ODFNOW,#7	; fentre des soft-keys ?	JUMP,EQ 90$		; oui => 90$	COMP.B	(A2)+ODFNOW,#8	; fentre du C.L.E.  ?	JUMP,EQ 90$		; oui => 90$	COMP.B	(A2)+ODFNOW,#9	; fentre de l'horloge ?	JUMP,EQ 90$		; oui => 90$	PUSH.W	(A2)+ODFPY	LOAD.W	(A2)+ODFPY,#16*24	CALL	POSTTY		; met curseur sur dernire ligne	LOAD.B	D3,#H'1B	CALL	WRTTY		; <ESC>	LOAD.B	D3,#'D	CALL	WRTTY		; <D>	POP.W	(A2)+ODFPY	CALL	POSTTY		; remet curseur o il tait90$:	POPM.L	D3	RET	.ENDIF	.IF	TTY;--------\\; POSTTY  >;========/; Positionne le cursur sur ce bte de terminal.; in	A2.L	^descripteur; out	-; mod	D7.WPOSTTY:	PUSH.L	D3	COMP.B	(A2)+ODFNOW,#7	; fentre des soft-keys ?	JUMP,EQ 90$		; oui => 90$	COMP.B	(A2)+ODFNOW,#9	; fentre de l'horloge ?	JUMP,EQ 90$		; oui => 90$	LOAD.B	D3,#H'9B	CALL	WRTTY		; <CSI>	CLR.L	D3	LOAD.W	D3,(A2)+ODFPY	ADD.W	D3,(A2)+ODFFY	DIV.WU	D3,(A2)+ODFCY	CALL	WRNUM		; <Pl>	LOAD.B	D3,#';	CALL	WRTTY		; <;>	CLR.L	D3	LOAD.W	D3,(A2)+ODFPX	ADD.W	D3,(A2)+ODFFX	DIV.WU	D3,(A2)+ODFCX	CALL	WRNUM		; <Pc>	LOAD.B	D3,#'H	CALL	WRTTY		; <f>90$:	POP.L	D3	RET	.ENDIF	.IF	TTY;--------\\; WRNUM   >;========/; Ecrit un valeur binaire en dcimal.; in	D3.W	valeur; out	-; mod	D7.WWRNUM:	PUSH.L	D3	COMP.W	D3,#10	JUMP,LO 30$	COMP.W	D3,#100	JUMP,LO 20$	AND.L	D3,#H'FFFF	DIV.WU	D3,#100	ADD.B	D3,#'0	CALL	WRTTY	SWAP.W	D320$:	AND.L	D3,#H'FFFF	DIV.WU	D3,#10	ADD.B	D3,#'0	CALL	WRTTY	SWAP.W	D330$:	ADD.B	D3,#'0	CALL	WRTTY	POP.L	D3	RET	.ENDIF	.IF	TTY;--------\\; WRTTY   >;========/; Envoye un byte au teletype, yaaaahouhouhou ...; in	D3.B	caractre  envoyer; out	-; mod	D7.WWRTTY:	PUSHM.L	D4,D6,A0,A4	LOAD.L	A0,A6		; A0 <-- ^variables globales	LOAD.L	A4,#(A0)+OBYTTY	LOAD.B	(A4),D3	LOAD.L	D4,#1	LOAD.W	D6,(A0)+OCHTTY	FOS	?WRBYTE		; hop, affiche;;?	LOAD.W	D4,#1;;?	NTREL	?DELMS		; ???	POPM.L	D4,D6,A0,A4	RET	.ENDIF;--------\; AFEFEOS >;========/; Efface l'cran depuis la position actuelle du curseur; jusqu' la fin.; in	A2.L	^description fentre; out	-; mod	D7.WAFEFEOS:	.IF	~TTY	CALL	OPIMA?		; image alphanum. existe ?	JUMP',NE 10$		; non => 10$	CALL	EOSIMA		; rempli fin image de SPACEs10$:	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_EFEOS-GRA_FIRST))	CALL	(A0)		; appel de GRA_EFEOS	POP.L	A0	.ENDIF	RET;--------\; AFEFLI  >;========/; Efface une ligne depuis la position actuelle du curseur; jusqu' la fin.; in	A2.L	^description fentre; out	-; mod	D7.WAFEFLI:	.IF	~TTY	CALL	OPIMA?		; image alphanum. existe ?	JUMP',NE 10$		; non => 10$	CALL	EFLIMA		; oui => fait aussi dans image10$:	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_EFLI-GRA_FIRST))	CALL	(A0)		; appel de GRA_EFLI	POP.L	A0	.ENDIF	RET	.END