	.TITLE	DIS.ASD;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------;	Source des pilotes *_DIS.DRIV	.PROC	M680002	.LISTIF; Assemblage conditionnel; -----------------------TTY	=	1		; utilise un terminal VT100	.IF	~TTY	.REF	MACHINESM100	=	_SM100		; Smaky 100SM324	=	_SM324		; Smaky 324 SM324LIT =	 _SM324LIT	;   petit cran comme Smaky 100 SM324BIG =	 _SM324BIG	;   grand cran 80 MHz Smaky 324SM8	=	_SM8		; Smaky 8COLOR	=	0		; youpie, k's bBIGCOLOR=	0		; grand cran couleurCOLOR8	=	0		; seulement 8 couleurs (3 plans)	.IF	SM324BIGFONDBLANC=	1		; cran  fond blanc (si SM324BIG=1)	.ELSEFONDBLANC=	0		; cran  fond blanc (si SM324BIG=1)	.ENDIF	.ELSESM100	=	1		; Smaky 100SM324	=	0		; Smaky 324 SM324LIT =	 0		;   petit cran comme Smaky 100 SM324BIG =	 0		;   grand cran 80 MHz Smaky 324SM8	=	0		; Smaky 8COLOR	=	0		; youpie, k's bBIGCOLOR=	0		; grand cran couleurCOLOR8	=	0		; seulement 8 couleurs (3 plans)FONDBLANC=	0		; cran  fond blanc (si SM324BIG=1)	.ENDIFDISREV	=	5		; rvisionDISVERS	=	1		; version	.REV	DISREV,DISVERS	.CODE	0,0,0,0,0,0,0,0,'?,'?,'F,0	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Date		Rev	Amliorations; -------------------------------------------------------------------------------------; 02.05.88	5.1	AFFILLT/AFFILLA; 11.04.88	5.0	nouveaux: COLORxx; 09.03.88	4.8	LOADGC: ne bloque plus tous les accs cran; 14.12.87	4.7	$DIS_6 ayant 640x340 points (comme SMAKY100); 25.11.87	4.6	nouveau .INS DISSOFTKEY.ASI pour ODFPSK.L; 20.11.87	4.5	.IF SM324 repris selon BB; 02.03.87	4.4	commutation rapide de diapos selon 100_INFO; 04.04.87		BB: 1re adaptation Smaky 324; 19.04.87		BB: adaptation grand cran Smaky 324; 25.02.87	4.3	AFGREY/AFFULL; 11.02.87	4.2	pour GENCAR: clear bit 2'7 de la fonte (D3.B); 12.01.87	4.1	gencar 2x plus petits possibles;			nouveau: NEWGC o f ssss t; 12.12.86	4.0	nom des gencars: (SMA,100)_TRP14.GENC; 09.12.86		commande SCRPARAM rinitialise bien tout; 21.11.86		nouvelle commande SCRPARAM; 08.10.86		CLOBITMAP si gencar n'existe pas !; 24.09.86		SPRITEs laisse la souris (si possible); 29.05.86		PFIXGC uniquement pour fontes "D" et "Q"; 06.05.86		SMAKY100: 4 grands bitmaps; 16.04.86		utilise ?CLOAD/?CUNLOAD pour les gencars; 28.02.86		PFIXGC prfix pour les gnrateurs; 11.02.86		LGDIS6 pour peindre en mmoire !; 09.01.86		DRAWPMOUSE ssss,cccc: matrice(s) de la souris	.IF	SM8	.REF	SM8HARD	.ENDIF	.IF	SM324	.REF	SM324HARD	.ENDIF	.REF	SM8	.REF	M8SYS	.REF	NTREL	.REF	FOS	.REF	GESMEM	.REF	BIOS	.REF	BIOSDRIV	.REF	DRIVERS	.REF	DOLIB	.REF	GRA	.REF	GENCAR	.REF	COLORS	.RADIX	10.	.HEX; Dfinitions diverses; --------------------REGHOR1	=	3		; VDC: numro registre dcalage HREGHOR2	=	2		; VDC: numro registre dcalage HREGVERT	=	7		; VDC: numro registre dcalage VREGPOX	=	13		; VDC: numro registre position XREGPOY	=	12		; VDC: numro registre position YLTAVDC	=	14		; VDC: longueur de la table TAVDC	.IF	SM100	.REF	SHIDRIV100	; pour _SAVMECRVDC	=	H'FF9080VDCR	=	H'FF9082MODECR	=	H'FF9A20SCRNZONE=	H'093A		; donne l'adresse du premier bitmap cranSCVDC	=	H'094A		; ^table VDC standard	.ENDIF	.IF	SM324SCRNZONE=	H'093A		; donne l'adresse du premier bitmap cranSCVDC	=	H'094A		; ^table VDC standardVDC	=	ADVDCVDCR	=	ADVDCR	.ENDIF	.IF	COLORNOWDOC	=	20		; no fentre du bitmap couleur de baseADVME16	=	H'2000000	; adresse de base VME16M1MEGA	=	1024*1024	; 1 MgaADBCOUL	=	ADVME16+H'C0000000+10*M1MEGAADCVDC	=	ADBCOUL+0ADCVDCR	=	ADBCOUL+2ADCBITS	=	ADBCOUL+2*M1MEGAADCPIXELS=	ADBCOUL+3*M1MEGAADCLOGIC=	ADBCOUL+4*M1MEGAADCRAMDAC=	ADBCOUL+5*M1MEGALGBITS	=	128*1024	; lg entre deux plansMVDCZERO=	0		; mode  M <--  0MVDCAND1=	2		; mode  M <--  D &  MMVDCAND2=	4		; mode  M <-- ~D &  MMVDCNOP	=	6		; mode  M <--  MMVDCAND3=	8		; mode  M <--  D & ~MMVDCLOAD=	10		; mode  M <--  DMVDCXOR	=	12		; mode  M <-- ~D &  M  !   D & ~MMVDCOR1	=	14		; mode  M <--  D !  MMVDCNOR	=	16		; mode  M <-- ~D & ~MMVDCXNOR=	18		; mode  M <--  D &  M  !  ~D & ~MMVDCNOT1=	20		; mode  M <-- ~DMVDCOR2	=	22		; mode  M <-- ~D !  MMVDCNOT2=	24		; mode  M <-- ~MMVDCOR3	=	26		; mode  M <--  D ! ~MMVDCNAND=	28		; mode  M <-- ~D ! ~MMVDCONE	=	30		; mode  M <--  1	.ENDIF	.IF	SM100!SM324LITDEFTAILLE =	07		; taille par dfaut	.ELSEDEFTAILLE =	12		; taille par dfaut	.ENDIFNOBASE	=	H'20		; numro de base pour driver	.IF	COLOR; Table des couleurs relatives; ----------------------------	.LOC	0OCOLRN:	.BLKB	4		; numroOCOLRR:	.BLKB	1		; rouge   -->  |r|g|v|-|  (!)OCOLRG:	.BLKB	1		; vertOCOLRB:	.BLKB	1		; bleuOCOLRF:	.BLKB	1		; fausse couleurLCOLR:	.ENDIF	.IF	COLOR; Table des fausses couleurs; --------------------------	.LOC	0OCOLFR:	.BLKB	1		; rougeOCOLFG:	.BLKB	1		; vertOCOLFB:	.BLKB	1		; bleuLCOLF:	.ENDIF; Table de description d'une fentre; ----------------------------------MAXSAV	=	10		; nb max de SAVWDO/GETWDO imbriqus	.LOC	0	.BLKB	LGDIS7		; partie dfinie dans  .REF DRIVERSODFADR:	.BLKW	1		; adresse suite pour comm multiODFNXT:	.BLKW	1		; adresse routine aprs comm.ODFCPT:	.BLKW	1		; ^relatif dans commandeODFCCT:	.BLKW	1		; compteur pour commandeODFCOM:	.BLKB	30		; buffer d'une commandeODFMAP:	.BLKB	4		; map des gencar utilissODFPSV:	.BLKB	2		; "SP" dans ODFSSVODFSSV:	.BLKB	4*MAXSAV	; stack de ^zones sauvetage fentreODFNGC:	.BLKB	24		; nom du gnrateur de caractresLGDFEN:; Dfinitions du hardware; -----------------------	.IF	SM100!SM324LITLARGCX	=	6		; largeur caractre standardLARGCY	=	10		; hauteur caractre standard	.ELSELARGCX	=	8		; largeur caractre standardLARGCY	=	16		; hauteur caractre standard	.ENDIF	.IF	SM100!SM324LITPVIEWX	=	640		; nb points visibles en XPVIEWY	=	400		; nb points visibles en Y	.ENDIF	.IF	SM324BIGPVIEWX	=	864	;960	; nb points visibles en XPVIEWY	=	1024	;1280	; nb points visibles en Y	.ENDIF	.IF	COLOR	.IF	BIGCOLORPCVIEWX	=	928		; nb points visibles en XPCVIEWY	=	736		; nb points visibles en Y	.ELSEPCVIEWX	=	640		; nb points visibles en XPCVIEWY	=	480		; nb points visibles en Y	.ENDIF	.ENDIF	.IF	SM8LVIEWX	=	104		; nb caractres visibles en XLVIEWY	=	32		; nb caractres visibles en Y	.ELSELVIEWX	=	PVIEWX/LARGCX	; nb caractres visibles en XLVIEWY	=	PVIEWY/LARGCY	; nb caractres visibles en Y	.ENDIF	.IF	SM100!SM324LITSEPX89	=	LVIEWX-32	; sparation entre $DIS_8 et 9SEPY81	=	LARGCY+6	; sparation entre $DIS_8 et 1	.ENDIF	.IF	SM324BIGSEPX89	=	LVIEWX-32	; sparation entre $DIS_8 et 9SEPY81	=	LARGCY+7	; sparation entre $DIS_8 et 1SEPY17	=	PVIEWY-(LARGCY*4)-2 ; sparation entre $DIS_1 et 7	.ENDIF	.IF	SM8SEPX89	=	LVIEWX-32	; sparation entre $DIS_8 et 9SEPY81	=	LARGCY+(LARGCY/2) ; sparation entre $DIS_8 et 1	.ENDIF	.IF	SM8LARICOX	=	96/LARGCX	; largeur pour les icnes en car	.ELSELARICOX	=	204/LARGCX	; largeur pour les icnes en car	.ENDIF	.IF	SM100!SM324LITPOSIDLG	=	(PVIEWX/8)-1POSIDLD	=	(1024/8)-1	.ENDIF	.IF	SM324BIG;;?POSIDLG	=	((1024/8)*SEPY81)+(PVIEWX/8)-2POSIDLG	=	((1024/8)*3)+(PVIEWX/8)-2POSIDLD	=	POSIDLG	.ENDIF	.IF	SM8POSIDLE	=	H'80000+H'400*(LVIEWX-2)POSIDLX	=	H'400*(128-LVIEWX)POSIDLY	=	H'200	.ENDIF	.IF	SM324BIGPBIGY	=	SEPY81+1DBIGY	=	PVIEWY-(LARGCY*4)-2-PBIGYDLITX	=	424		; largeur d'une petite fentreDLITY	=	160+24		; hauteur d'une petite fentreTRAGRIS	=	H'11441144	; trame pour fentre inutilise	.ENDIF	.IF	SM100!SM324; Table pour un bitmap cran complet; ----------------------------------	.IF	COLORMAXBM	=	4+1		; nb max de grands bitmaps	.ELSEMAXBM	=	4		; nb max de grands bitmaps	.ENDIF	.LOC	0OBMABS:	.BLKB	4		; adresse absolue du bitmap	.IF	SM324BIGOBMWDO:	.BLKB	7		; numros des 7 fentres associes	.ELSEOBMWDO:	.BLKB	3		; numros des 3 fentres associes	.ENDIF	.EVENLBM:	.ENDIF; Table pour un gnrateur de caractres; --------------------------------------MAXGC	=	32		; nb max de gn. charg	.LOC	0OGCPT:	.BLKB	4		; ^absolu dbut gnrateurOGCUSE:	.BLKB	1		; 0 => lment libre (compteur)OGCF:	.BLKB	1		; fonteOGCS:	.BLKB	4		; styleOGCT:	.BLKB	1		; taille	.EVENLGGC:; Table d'une image alphanumrique; --------------------------------	.LOC	0OIMADX:	.BLKW	1		; nb de caractres/ligneOIMADY:	.BLKW	1		; nb de lignes/fentreOIMACX:	.BLKW	1		; largeur d'un caractreOIMACY:	.BLKW	1		; hauteur d'un caractreOIMAPX:	.BLKW	1		; position en X dans l'imageOIMAPY:	.BLKW	1		; position en Y dans l'imageOIMASX:	.BLKW	1		; dbut fentre en XOIMASY:	.BLKW	1		; dbut fentre en YOIMALX:	.BLKW	1		; largeur fentre en XOIMALY:	.BLKW	1		; hauteur fentre en YOIMAOY:	.BLKW	1		; offset ventuel en YLGIMA:; Dfinitions des variables globales; ----------------------------------	.LOC	0OSTART:	.BLKW	2		; adr absolue de dbut du codeOPDFEN:	.BLKB	32*4		; ^descripteurs des fentres	.IF	~TTYOADGRA:	.BLKB	4*(GRA_LAST-GRA_FIRST+1)	.ENDIFOWDBIG:	.BLKB	2		; grande fentre utilise ?OTAGC:	.BLKB	MAXGC*LGGC	; table pour les GENCARsOPINFO:	.BLKB	4		; ^informations dans SYS_INFOOTAEQG:	.BLKB	4		; ^table des quivalences dans SYS_INFOOSEMAX:	.BLKW	2		; ^smaphore d'exclusion	.IF	SM100!SM324OBITMAP:.BLKB	MAXBM*LBM	; table des bitmapsONOVBM:	.BLKB	2		; numro du bitmap visible (0..3,4)	.IF	COLORONOVBP:	.BLKB	2		; numro du bitmap principal visible (0..3)	.ENDIF	.ENDIF	.IF	SM324OBMUSE:	.BLKB	1		; bitmap des crans utilissOOREGX:	.BLKB	1		; offset pour l'utilisation Y du registre X du VDCOWDO23:	.BLKB	1		; fentre $DIS_2 et $DIS_3 existentOWDO45:	.BLKB	1		; fentre $DIS_4 et $DIS_5 existent	.ENDIFONBGCS:	.BLKW	1		; nb de gencar "soft" chargsOCHGCS:	.BLKW	1		; canal du module gencarOLSTPD:	.BLKB	4		; ^dernier descripteur de la fentre o est la souris	.IF	TTYOCHTTY:	.BLKB	2		; canal usart en sortieOBYTTY:	.BLKB	10		; bytes  envoyer	.ENDIFLGVAR:; Dbut du code du driver; -----------------------	.INS	DISHEAD.ASI; Points d'entres pour les routines de bases; -------------------------------------------;--------\; RESET   >;========/; in	A0.L	^base du driver;	A2.L	^paramtres pour la fentre; out	-; mod	D0..A1, D7.WD0RESET:	PUSHM.L	D2,D3,D4,A2,A3,A4,A5	.IF	TTY	LOAD.L	D4,#LGVAR	; D4 <-- longueur totale	LOAD.W	D1,#MTYPBD	; D1 <-- type driver bios	LOAD.L	A1,A0		; A1 <-- ^base du driver	GESMEM	?GETMEM		; demande mmoire pour variables globales	LOAD.L	A6,A4		; A6 <-- ^variables globales10$:	CLR.B	(A4+)	DEC.W	D4	JUMP,NE 10$	CALL	OPEDESC	LOAD.L	A0,#R16"TASOFTKEY	LOAD.L	(A2)+ODFPSK,A0	; mm. ^table pour soft-keys	LOAD.L	(A6)+OLSTPD,A2	; OLSTPD <-- ^descripteur o est la souris	LOAD.L	A1,#R16"START	LOAD.L	(A6)+OSTART,A1	LOAD.L	A3,#R16"NMLTTY	LOAD.L	A4,#R16"NMPTTY	LOAD.L	A2,#0	CLR.W	D3	FOS	?INSTALL	JUMP,NE FTTY1	PUSH.L	D6	LOAD.L	A3,#R16"NMLTTY	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre l'usart en sortie	JUMP,NE FTTY2	LOAD.W	(A6)+OCHTTY,D6	LOAD.L	A4,#R16"NMCTTY	LOAD.W	D3,#TYPIO	FOS	?COMMAND	JUMP,NE FTTY3	POP.L	D6	CALL	EOPTTY	CLR.W	D7		; D7 <-- ok	.ELSE	LOAD.L	A2,(A6)+OPDFEN+(4*0) ; A2 <-- ^description fentre	LOAD.L	(A2)+ODFBAS,A0	; mm. ^base du driver	.IF	FONDBLANC	TSET.B	(A2)+ODFMOD:#BFBLANC	.ENDIF	.IF	COLOR	LOAD.L	A1,#R16"TAFAUX	LOAD.L	(A2)+ODFCPF,A1	; ODFCPF <-- ^table des fausses couleurs	CALL	AFCVDCC		; initialise toutes les fausses couleurs	.ENDIF	CALL	COLDESC		; init la couleur dans le descripteur	LOAD.L	A0,#R16"TASOFTKEY	LOAD.L	(A2)+ODFPSK,A0	; mm. ^table pour soft-keys	.IF	SM100!SM324	LOAD.L	A0,SCVDC	; A0 <-- ^table VDC standard (20 KHz)	LOAD.L	A1,#R16"TA20KHZ	LOAD.W	D0,#LTAVDC-110$:	LOAD.B	(A1+),(A0+)	; TA20KHZ <-- valeur du moniteur	DECJ.W,NMO D0,10$	LOAD.L	A0,#R16"TA20KHZ	LOAD.L	A1,#R16"TAVDC	LOAD.W	D0,#LTAVDC-112$:	LOAD.B	(A1+),(A0+)	; TAVDC <-- valeur du moniteur	DECJ.W,NMO D0,12$	LOAD.L	A4,SCRNZONE	CALL	INIYBITMAP	.ENDIF	LOAD.L	A0,A6		; A0 <-- ^variables globales	LOAD.L	(A0)+OLSTPD,A2	; OLSTPD <-- ^descripteur o est la souris	.IF	SM324	LOAD.B	(A0)+OBMUSE,#B'00000001 ; init le bitmap 0 utilis	LOAD.L	A3,#R16"TAVDC	LOAD.B	(A0)+OOREGX,#0	; se rappelle de l'offset REGPOX	CLR.B	(A3)+REGPOX	LOAD.L	A3,#R16"TA20KHZ	CLR.B	(A3)+REGPOX	; c'est INIVDC qui ajoutera l'offset	.ENDIF	SM324	.IF	SM100!SM324LIT	LOAD.L	(A0)+OBITMAP+LBM*0+OBMABS,SCRNZONE	LOAD.B	(A0)+OBITMAP+LBM*0+OBMWDO+0,#1	LOAD.B	(A0)+OBITMAP+LBM*0+OBMWDO+1,#10	LOAD.B	(A0)+OBITMAP+LBM*0+OBMWDO+2,#11	LOAD.B	(A0)+OBITMAP+LBM*1+OBMWDO+0,#2	LOAD.B	(A0)+OBITMAP+LBM*1+OBMWDO+1,#12	LOAD.B	(A0)+OBITMAP+LBM*1+OBMWDO+2,#13	LOAD.B	(A0)+OBITMAP+LBM*2+OBMWDO+0,#3	LOAD.B	(A0)+OBITMAP+LBM*2+OBMWDO+1,#14	LOAD.B	(A0)+OBITMAP+LBM*2+OBMWDO+2,#15	LOAD.B	(A0)+OBITMAP+LBM*3+OBMWDO+0,#4	LOAD.B	(A0)+OBITMAP+LBM*3+OBMWDO+1,#16	LOAD.B	(A0)+OBITMAP+LBM*3+OBMWDO+2,#17	.IF	COLOR	LOAD.B	(A0)+OBITMAP+LBM*4+OBMWDO+0,#NOWDOC+1	LOAD.B	(A0)+OBITMAP+LBM*4+OBMWDO+1,#-1	LOAD.B	(A0)+OBITMAP+LBM*4+OBMWDO+2,#-1	LOAD.L	(A0)+OBITMAP+LBM*4+OBMABS,#ADCPIXELS	.ENDIF	LOAD.L	(A2)+ODFABS,SCRNZONE	LOAD.L	(A2)+ODFCAB,(A2)+ODFABS	LOAD.W	(A2)+ODFIIX,#1	LOAD.W	(A2)+ODFIIY,#H'80	.ENDIF	.IF	SM324BIG	LOAD.L	(A0)+OBITMAP+LBM*0+OBMABS,SCRNZONE	LOAD.B	(A0)+OBITMAP+LBM*0+OBMWDO+0,#1	LOAD.B	(A0)+OBITMAP+LBM*0+OBMWDO+1,#-1	LOAD.B	(A0)+OBITMAP+LBM*0+OBMWDO+2,#-1	LOAD.B	(A0)+OBITMAP+LBM*0+OBMWDO+3,#-1	LOAD.B	(A0)+OBITMAP+LBM*0+OBMWDO+4,#-1	LOAD.B	(A0)+OBITMAP+LBM*0+OBMWDO+5,#-1	LOAD.B	(A0)+OBITMAP+LBM*0+OBMWDO+6,#-1	LOAD.B	(A0)+OBITMAP+LBM*1+OBMWDO+0,#2	LOAD.B	(A0)+OBITMAP+LBM*1+OBMWDO+1,#3	LOAD.B	(A0)+OBITMAP+LBM*1+OBMWDO+2,#-1	LOAD.B	(A0)+OBITMAP+LBM*1+OBMWDO+3,#-1	LOAD.B	(A0)+OBITMAP+LBM*1+OBMWDO+4,#-1	LOAD.B	(A0)+OBITMAP+LBM*1+OBMWDO+5,#-1	LOAD.B	(A0)+OBITMAP+LBM*1+OBMWDO+6,#-1	LOAD.B	(A0)+OBITMAP+LBM*2+OBMWDO+0,#4	LOAD.B	(A0)+OBITMAP+LBM*2+OBMWDO+1,#5	LOAD.B	(A0)+OBITMAP+LBM*2+OBMWDO+2,#-1	LOAD.B	(A0)+OBITMAP+LBM*2+OBMWDO+3,#-1	LOAD.B	(A0)+OBITMAP+LBM*2+OBMWDO+4,#-1	LOAD.B	(A0)+OBITMAP+LBM*2+OBMWDO+5,#-1	LOAD.B	(A0)+OBITMAP+LBM*2+OBMWDO+6,#-1	LOAD.B	(A0)+OBITMAP+LBM*3+OBMWDO+0,#6	LOAD.B	(A0)+OBITMAP+LBM*3+OBMWDO+1,#10	LOAD.B	(A0)+OBITMAP+LBM*3+OBMWDO+2,#11	LOAD.B	(A0)+OBITMAP+LBM*3+OBMWDO+3,#12	LOAD.B	(A0)+OBITMAP+LBM*3+OBMWDO+4,#13	LOAD.B	(A0)+OBITMAP+LBM*3+OBMWDO+5,#14	LOAD.B	(A0)+OBITMAP+LBM*3+OBMWDO+6,#15	.IF	COLOR	LOAD.B	(A0)+OBITMAP+LBM*4+OBMWDO+0,#NOWDOC+1	LOAD.B	(A0)+OBITMAP+LBM*4+OBMWDO+1,#-1	LOAD.B	(A0)+OBITMAP+LBM*4+OBMWDO+2,#-1	LOAD.B	(A0)+OBITMAP+LBM*4+OBMWDO+3,#-1	LOAD.B	(A0)+OBITMAP+LBM*4+OBMWDO+4,#-1	LOAD.B	(A0)+OBITMAP+LBM*4+OBMWDO+5,#-1	LOAD.B	(A0)+OBITMAP+LBM*4+OBMWDO+6,#-1	LOAD.L	(A0)+OBITMAP+LBM*4+OBMABS,#ADCPIXELS	.ENDIF	LOAD.L	(A2)+ODFABS,SCRNZONE	LOAD.L	(A2)+ODFCAB,(A2)+ODFABS	LOAD.W	(A2)+ODFIIX,#1	LOAD.W	(A2)+ODFIIY,#H'80	.ENDIF	.IF	SM8	LOAD.L	(A2)+ODFABS,#H'80000	LOAD.L	(A2)+ODFCAB,(A2)+ODFABS	CLR.W	(A2)+ODFIIX	LOAD.W	(A2)+ODFIIY,#1	.ENDIF	LOAD.L	A3,#R16"NMGRA	; A3 <-- ^nom module graphique	LOAD.W	D3,#GRA_FIRST	; D3 <-- code du premier appel	LIB_	OPEN		; charge le module GRA	JUMP,NE 90$	LOAD.L	A1,#(A0)+OADGRA	; A1 <-- ^buffer pour les adresses	LOAD.W	D3,#GRA_FIRST	; D3 <-- premier code du module GRA	LOAD.W	D4,#(GRA_LAST-GRA_FIRST+1)-120$:	.W	H'A101		; appel de LIB_GETAD (pas de .REF LIB !)	LOAD.L	(A1+),A3	; mmorise l'adresse de la routine	INC.W	D3		; D3 <-- code de l'appel GRA suivant	DECJ.W,NMO D4,20$	LOAD.W	D4,#1	NTREL	?CRESEM		; cre smaphore d'exclusion	LOAD.L	(A0)+OSEMAX,A5	; init ^smaphore	LOAD.L	A1,#R16"START	LOAD.L	(A0)+OSTART,A1	CALL	GETEQG		; buffer <-- SYS_INFO	TEST.W	D7	JUMP,NE	90$	LOAD.L	(A2)+ODFFDY,(A2)+ODFDY	CALL	WMINMAX		; init min et max (sous-)fentre	LOAD.L	A4,#(A6)+OPDFEN	LOAD.L	(A4)+0,A2	; mm. ^descripteur $DIS_0	LOAD.L	(A2)+ODFPDE,A4	; mm. ^^descripteurs	.IF	SM100!SM324	LOAD.L	D0,SCRNZONE	; D0 <-- adresse de l'cran	ADD.L	D0,#POSIDLG	LOAD.L	_VINCIDL,D0	.ENDIF	.IF	SM8	LOAD.L	_VINCIDL,#POSIDLE	.ENDIF	CLR.B	D0		; D0 <-- fonte par dfaut	CLR.L	D1		; D1 <-- style par dfaut	CLR.B	D2		; D2 <-- taille par dfaut	CLR.L	(A2)+ODFMAP	; clear compltement le map	CALL	GCLOAD		; charge le gnrateur standard	TEST.W	D7	JUMP',NE 90$	CALL	GCUSE		; (A2)++ <-- paramtres	TEST.W	D7	JUMP',NE 90$	CALL	EFFACE		; efface tout (1024 x 1024)	CLR.W	D1		; D1 <-- bitmap principal	CALL	IDIS		; remet les sparations	CALL	INIVDC		; init le controleur d'cran	.IF	COLOR	CALL	INIVDCC		; init le controleur d'cran couleur	.ENDIF	LOAD.L	A0,A2		; A0 <-- ^descripteur $DIS_0	CALL	SHWMRK		; montre le cadrage !80$:	CLR.W	D7		; D7 <-- ok90$:	.ENDIF	POPM.L	D2,D3,D4,A2,A3,A4,A5	RET	.IF	TTYFTTY1:	.W	H'A042	.ASCIZ	"<CR>ERFAT-TTY #1<CR>"	.EVEN	TRAP	#1FTTY2:	.W	H'A042	.ASCIZ	"<CR>ERFAT-TTY #2<CR>"	.EVEN	TRAP	#1FTTY3:	.W	H'A042	.ASCIZ	"<CR>ERFAT-TTY #3<CR>"	.EVEN	TRAP	#1NMPTTY:	.ASCIZ	"$USART_1"NMLTTY:	.ASCIZ	"#PP"NMCTTY:	.ASCIZ	"N"	.ELSENMGRA:	.ASCIZ	"GRA"		; nom du module GRAphique	.ENDIF	.EVENDORESET:	PUSHM.L	D2,A2,A4,A5	.IF	TTY	PUSH.L	A0	LOAD.L	A0,#R16"D0BASE	CLR.L	D0	LOAD.L	A1,_INDNTR	CALL	(A1)+OIN_GETDRIVVAR ; A6 <-- ^variables de $DIS_0	POP.L	A0	CALL	OPEDESC		; A2 <-- ^descripteur	JUMP,NE 90$	LOAD.L	(A2)+ODFPY,(A2)+ODFC1Y	LOAD.L	(A2)+ODFFDY,(A2)+ODFDY	CALL	WMINMAX		; init min et max (sous-)fentre	LOAD.L	A4,#R16"THEADNEF11	LOAD.L	(A2)+ODFPGC,A4	LOAD.W	(A2)+ODFCX,#8	LOAD.W	(A2)+ODFC1X,#0	LOAD.W	(A2)+ODFC2X,#8	LOAD.W	(A2)+ODFCY,#16	LOAD.W	(A2)+ODFC1Y,#12	LOAD.W	(A2)+ODFC2Y,#4	TSET.B	(A2)+ODFFL2:#BFTTY	CALL	EOPTTY90$:	.ELSE	.IF	SM324BIG	LOAD.L	A1,A6		; A1 <-- ^variables globales	LOAD.W	D7,#ERDNTF	; D7 <-- erreur	COMP.B	(A0)+ODHNUM,#NOBASE+3 ; fentre $DIS_3 ?	JUMP',NE 10$		; non => 10$	TEST.B	(A1)+OWDO23	; fentres $DIS_2 et $DIS_3 ensemble ?	JUMP,EQ 99$		; non => 99$10$:	COMP.B	(A0)+ODHNUM,#NOBASE+5 ; fentre $DIS_5 ?	JUMP',NE 12$		; non => 12$	TEST.B	(A1)+OWDO45	; fentres $DIS_4 et $DIS_5 ensemble ?	JUMP,EQ 99$		; non => 99$12$:	.ENDIF	LOAD.L	A1,A2		; A1 <-- ^paramtres	CALL	OPEDESC		; A2 <-- ^descripteur	JUMP,NE	99$	LOAD.L	A0,A6		; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAX	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	.IF	SM100!SM324	LOAD.W	(A2)+ODFIIX,#1	LOAD.W	(A2)+ODFIIY,#H'80	.ELSE	LOAD.L	(A2)+ODFABS,#H'80000	LOAD.L	(A2)+ODFCAB,(A2)+ODFABS	CLR.W	(A2)+ODFIIX	LOAD.W	(A2)+ODFIIY,#1	.ENDIF	CALL	DIMOK?		; dimensions fentre ok ?	TEST.W	D7	JUMP',NE 90$		; non => 90$	.IF	SM100!SM324	CALL	OPEBITMAP	; A4 <-- ^bitmap	JUMP',NE 90$	LOAD.L	(A2)+ODFABS,A4	LOAD.L	(A2)+ODFCAB,A4	.ENDIF	CLR.L	(A2)+ODFMAP	; clear compltement le map	CALL	GCLOAD		; charge le gnrateur standard	TEST.W	D7	JUMP',NE 90$	CALL	GCUSE		; (A2)++ <-- paramtres	TEST.W	D7	JUMP',NE 90$	LOAD.L	(A2)+ODFPY,(A2)+ODFC1Y	LOAD.L	(A2)+ODFFDY,(A2)+ODFDY	CALL	WMINMAX		; init min et max (sous-)fentre	CALL	IMACURS0	; enlve le curseur souris	.IF	COLOR	COMP.B	(A2)+ODFNOW,#NOWDOC	JUMP',NE 70$	CALL	EFFACE		; efface la nouvelle fentre70$:	.ENDIF	CALL	IMACURS1	; remet le curseur souris	CLR.W	D7		; D7 <-- ok90$:	TEST.W	D7		; ok ?	JUMP',EQ 95$		; oui => 95$	.IF	SM100!SM324	PUSH.W	D7	CALL	CLOBITMAP	; libre le bitmap si ncessaire	POP.W	D7	.ENDIF	CALL	CLODESC		; rend le descripteur95$:	PUSH.W	D7	NTREL	?UNLOCK		; fin de zone critique	POP.W	D799$:	.ENDIF	POPM.L	D2,A2,A4,A5	RET;--------\; KILL    >;========/; in	A0.L	^base du driver; out	-; mod	D0..A1DOKILL:	PUSHM.L	D2,D3,A2,A5	.IF	TTY	CALL	SRCDESC		; A2 <-- ^descripteur fentre	CALL	EOPTTY	CALL	CLODESC		; libre le descripteur	.ELSE	CALL	SRCDESC		; A2 <-- ^descripteur fentre	LOAD.L	A0,A6		; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAX	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	CALL	IMACURS0	; enlve curseur souris	CALL	CLRCURS		; enlve le curseur	.IF	SM324BIG	CALL	GRISE		; grise la fentre !!!	.ENDIF	.IF	COLOR	COMP.B	(A2)+ODFNOW,#NOWDOC	JUMP',LO 30$	CALL	EFFACE		; efface la fentre30$:	.ENDIF	LOAD.B	D3,#NOCURS	CALL	AFCAR		; supprime un ventuel curseur	TEST.B	(A2)+ODFFLG:#BFIMAA ; image existe ?	JUMP',BC 50$		; non => 50$	CALL	KILIMA		; oui => libre mmoire50$:	CALL	WDOGET		; libre zone sauvetage fentre	.IF	SM100!SM324	CALL	CLOBITMAP	; libre le bitmap si ncessaire	.ENDIF	CALL	GCRESET		; supprime gencar(s) utilis(s)	CALL	SETCURS		; remet le curseur (!)	CALL	CLODESC		; libre le descripteur	CALL	IMACURS1	; remet curseur souris	NTREL	?UNLOCK		; fin de zone critique	.ENDIF	POPM.L	D2,D3,A2,A5	RET;--------\; COMMAND >;========/; in	A0.L	base du driver;	A4.L	^table des commandes termine par zro; out	D7.W	erreur; mod	D0..A1, D7.WDOCOMMAND:	.IF	TTY	CLR.W	D7		; D7 <-- ok	.ELSE	PUSHM.L	A2,A4,A5	CALL	SRCDESC		; A2 <-- ^description fentre	LOAD.L	A0,A6		; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAX	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	CALL	IMACURS0	; enlve curseur souris	CLR.W	D7		; D7 <-- ok10$:	TEST.B	(A4)		; fin de la table ?	JUMP',EQ 80$		; oui => 80$	CALL	WRONEC		; excute une commande	TEST.W	D7		; commande ok ?	JUMP',NE 80$		; non => 80$	JUMP	10$80$:	PUSH.W	D7	CALL	IMACURS1	; remet curseur souris	NTREL	?UNLOCK		; fin de zone critique	POP.W	D7	POPM.L	A2,A4,A5	.ENDIF	RET;--------\; RSTATUS >;========/; in	A0.L	^base du driver;	A4.L	^buffer;	D4.L	longueur buffer; out	D4.L	longueur rendue effectivement;	D7.W	erreur; mod	D0..A1, D4.L, D7.WDORSTATUS:	PUSHM.L	A2,A5	CALL	SRCDESC		; A2 <-- ^description fentre	LOAD.L	A0,A6		; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAX	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	LOAD.L	(A2)+ODFPST,A2	; met le ^au status rel	COMP.W	D4,#4		; profondeur = 4 ?	JUMP',NE 10$		; non => 10$				; oui =>	LOAD.L	(A4),A2		; rend juste le ^au status rel !	CLR.W	D7		; D7 <-- ok	JUMP	90$10$:	.IF	~TTY	LOAD.B	D0,R16"TAVDC+REGHOR1	.IF	SM8	SUB.B	D0,#CHSTAND1	.ENDIF	LOAD.B	(A2)+ODFCAH,D0	LOAD.B	D0,R16"TAVDC+REGVERT	.IF	SM8	SUB.B	D0,#CVSTAND	.ENDIF	LOAD.B	(A2)+ODFCAV,D0	.ENDIF	LOAD.L	A0,#R16"00$	CALLA	_CNVLGS	JUMP',NE 90$	LOAD.L	A0,A4		; A0 <-- ^buffer utilisateur	LOAD.W	D0,D420$:	LOAD.B	(A0+),(A2+)	; transfre chez l'utilisateur	DEC.W	D0	JUMP,NE 20$90$:	PUSH.W	D7	NTREL	?UNLOCK		; fin de zone critique	POP.W	D7	POPM.L	A2,A5	RET00$:				; table pour CNVLGS :	.W	LGDIS0	.W	LGDIS1	.W	LGDIS2	.W	LGDIS3	.W	LGDIS4	.W	LGDIS5	.W	LGDIS6	.W	LGDIS7	.W	0;--------\; WRITE   >;========/; in	A0.L	^base du driver;	A4.L	^buffer texte;	D5.L	lg maximale du texte; out	D5.L	lg effectivement crite;	D7.W	erreur; mod	D7.W, D5.LDOWRITE:	PUSHM.L	D3,D4,D6,A2,A4,A5	CALL	SRCDESC		; A2 <-- ^description fentre	LOAD.L	A0,A6		; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAX	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	.IF	~TTY	CALL	CLRCURS		; enlve le curseur	.ENDIF	CLR.W	D6		; D6 <-- mm dernire erreur	LOAD.L	D4,D5		; D4 <-- nb caractres  crire10$:	LOAD.B	D3,(A4+)	; D3 <-- caractre  afficher	DEC.L	D4	CALL	AFCAR		; "affiche" un caractre	TEST.W	D7		; erreur lors du AFCAR ?	JUMP',EQ 50$		; non => 50$	JUMP',NS 40$		; si erreur grave => 40$	TEST.W	D6		; dj mm. erreur grave ?	JUMP',NS 50$		; oui => 50$40$:	LOAD.W	D6,D7		; D6 <-- dernire erreur50$:	TEST.L	D4	JUMP,NE 10$	SUB.L	D5,D4		; D5 <-- nb caractres crits	.IF	~TTY	CALL	SETCURS		; remet le curseur	.ENDIF	NTREL	?UNLOCK		; fin de zone critique	LOAD.W	D7,D6		; D7 <-- dernire erreur90$:	POPM.L	D3,D4,D6,A2,A4,A5	RET;--------\; READ    >;========/; in	A0.L	^base du driver;	A4.L	^buffer texte;	D5.L	lg  lire;		2^31=1	--> nb points horizontaux (de gauche  droite);		2^30=1	--> nb points verticaux (de bas en haut); out	D5.L	lg effectivement lue;	D7.W	erreur; mod	D7.W, D5.LDOREAD:	PUSHM.L	D2,D3,D4,A3,A4,A5	.IF	TTY	LOAD.W	D7,#ERRDPR	; D7 <-- read protected driver	.ELSE	CALL	SRCDESC		; A2 <-- ^description fentre	LOAD.L	A0,A6		; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAX	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	TEST.L	D5:#31		; lecture graphique horizontale ?	JUMP,BS	40$		; oui => 40$	TEST.L	D5:#30		; lecture graphique verticale ?	JUMP,BS	40$		; oui => 40$				; non =>	LOAD.W	D4,D5		; D4 <-- lg  lire	CLR.L	D5		; D5 <-- rien d'encore lu	LOAD.W	D7,#ERRDPR	; D7 <-- read protected driver	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE 90$		; non => 90$ (erreur)	LOAD.L	A5,A4		; A5 <-- ^o mettre les cars.	CALL	GPTIMA		; A4 <-- ^dans image	JUMP,NE 90$		; si hors => 90$	LOAD.L	A3,(A2)+ODFPIM	; A3 <-- ^base de l'image	LOAD.W	D3,(A3)+OIMADX	MUL.WU	D3,(A3)+OIMADY	; D3 <-- lg utile de l'image	ADD.L	D3,#LGIMA	; D3 <-- ajoute les frais fixes	ADD.L	A3,D3		; A3 <-- ^max  ne pas dpasser	LOAD.W	D7,#EROUTF	; D7 <-- erreur si dpassement20$:	COMP.L	A4,A3		; image dpasse ?	JUMP,HS 90$		; oui => 90$	LOAD.B	(A5+),(A4+)	; buffer lecture <- image alpha	INC.L	D5		; D5 <-- un car. lu de plus	DEC.W	D4		; encore qq chose  lire ?	JUMP,NE	20$		; oui => 20$				; non =>	CLR.W	D7		; D7 <-- ok	JUMP	90$40$:				; lecture graphique h/v =>	LOAD.W	D0,D5		; D0 <-- lg  lire (points)	LOAD.W	D3,(A2)+ODFPGX	ADD.W	D3,(A2)+ODFWBX	; D3 <-- coordonne X absolue	LOAD.B	D2,D3	LOAD.W	D4,(A2)+ODFPGY	ADD.W	D4,(A2)+ODFWBY	; D3 <-- coordonne Y absolue	.IF	SM100!SM324	LOAD.L	A3,(A2)+ODFABS	; A3 <-- adresse dbut cran	AND.L	D3,#1024-1	; masque coordonne	SR.L	D3,#3	ADD.L	A3,D3		; A3 <-- ajoute offset X	AND.L	D4,#1024-1	; masque coordonne	SL.L	D4,#7	ADD.L	A3,D4		; A3 <-- ajoute offset Y	.ELSE	LOAD.L	A3,(A2)+ODFABS	; A3 <-- adresse dbut cran	AND.L   D4,#H'3FF	; bits significatifs de X	AND.L	D3,#H'3F8	; bits colonnes de Y	SL.L	D3,#7	OR.L	D4,D3	ADD.L	A3,D4		; A3 <-- adresse du byte	.ENDIF	TEST.L	D5:#30		; lecture verticale ?	JUMP,BS	60$		; oui => 60$; Lit une ligne graphique horizontale allant de gauche  droite.	SR.W	D0,#3		; D0 <-- nb bytes  lire45$:	.IF	SM100!SM324	LOAD.B	(A4+),(A3+)	; user <-- un byte graphique	.ELSE	LOAD.B	D4,(A3)		; D4 <-- byte non swap	LOAD.L	A3,#(A3)+H'400	LOAD.W	D2,#8-1		; -1  cause du test NMO !47$:	RLX.B	D4	RRX.B	D3	DECJ.W,NMO D2,47$	LOAD.B	(A4+),D3	; user <-- byte swap	.ENDIF	DEC.W	D0	JUMP,NE	45$	JUMP	80$; Lit une ligne graphique verticale allant de bas en haut.60$:	AND.B	D2,#B'111	; D2 <-- 0..7	INC.B	D2		; D2 <-- dcalage colonne (1..8)62$:	LOAD.W	D1,#8-1		; -1  cause du test NMO	COMP.W	D0,#8		; reste au moins 8 ?	JUMP',HS 65$		; oui => 65$	LOAD.W	D1,D0		; D1 <-- lg du reste	DEC.W	D1		; -1  cause du test NMO65$:	.IF	SM100!SM324	LOAD.B	D3,(A3)		; D3 <-- byte de l'cran	LOAD.L	A3,#(A3)-H'80	; A3 <-- ^plus haut dans l'cran	RLX.B	D3,D2		; "X" <-- un point	.ELSE	LOAD.B	D3,(A3)		; D3 <-- byte de l'cran	DEC.L	A3		; A3 <-- ^plus haut dans l'cran	RRX.B	D3,D2		; "X" <-- un point	.ENDIF	RLX.B	D4,#1		; D4 <-- met le point dans "X"	DECJ.W,NMO D1,65$	SUB.W	D0,#8		; D0 <-- 8 points lus	JUMP',LS 67$	LOAD.B	(A4+),D4	; buffer read <-- un byte	JUMP	62$67$:	NEG.W	D0	SL.B	D4,D0		; D4 <-- met qq zro (0..7)	LOAD.B	(A4),D4		; buffer read <-- dernier byte80$:	CLR.W	D7		; D7 <-- ok90$:	PUSH.W	D7	LOAD.L	A5,(A0)+OSEMAX	; A5 <-- ^smaphore	NTREL	?UNLOCK		; fin de zone critique	POP.W	D7	.ENDIF	POPM.L	D2,D3,D4,A3,A4,A5	RET;--------\; DIMOK?  >;========/; Vrifie si les dimensions d'une fentre sont comprises; entre les bornes donnes par l'utilisateur en (A1).; Rend dans D0-D1-D2 le gnrateur de caractres  utiliser.; Si la fonte est "?" "*" ou "-", rend le gnrateur NRF12 ou; NRF08 selon la largeur de la fentre.; in	A0.L	^variables globales;	A1.L	^paramtres;	A2.L	^description fentre; out	D0.B	fonte;	D1.L	style;	D2.B	taille;	D7.W	erreur; mod	D0.B, D1.L, D2.B, D7.WDIMOK?:	PUSH.L	D3	CLR.B	D0		; D0 <-- fonte par dfaut	CLR.L	D1		; D1 <-- style par dfaut	CLR.B	D2		; D2 <-- taille par dfaut	LOAD.L	D3,A1		; A1 = zro ?	JUMP,EQ 80$		; oui => 80$ (dimensions ok)				; non =>	COMP.L	(A1),#H'00FFFFFF ; paramtres valides ?	JUMP,EQ	80$		; non => 80$ (dimensions ok)				; oui =>	LOAD.B	D0,(A1)+OIDGCF	; D0 <-- fonte	LOAD.B	D1,(A1)+OIDGCS	; D1 <-- style	LOAD.B	D2,(A1)+OIDGCT	; D2 <-- taille	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	LOAD.W	D3,(A2)+ODFDY	; D3 <-- hauteur fentre	COMP.W	D3,(A1)+OIDYMIN	; trop petit ?	JUMP',LO 90$		; oui => 90$	COMP.W	D3,(A1)+OIDYMAX	; trop grand ?	JUMP',HI 90$		; oui => 90$	LOAD.W	D3,(A2)+ODFDX	; D3 <-- largeur fentre	COMP.W	D3,(A1)+OIDXMIN	; trop petit ?	JUMP',LO 90$		; oui => 90$	COMP.W	D3,(A1)+OIDXMAX	; trop grand ?	JUMP',HI 90$		; oui => 90$	COMP.B	D0,#'*		; fonte = "*"  ?	JUMP',EQ 40$	COMP.B	D0,#'?		; fonte = "?"  ?	JUMP',EQ 40$	COMP.B	D0,#'-		; fonte = "-"  ?	JUMP',NE 80$40$:	LOAD.B	D0,#'N		; fonte "normal"	LOAD.B	D1,#'R!2^7	; style/chasse "roman/fix"	LOAD.B	D2,#DEFTAILLE	; taille par dfaut (12)	.IF	SM8	COMP.W	D3,#500		; "grande" fentre ?	JUMP',HS 80$		; oui => 80$				; non =>	LOAD.B	D2,#DEFTAILLE/3*2 ; petite taille (08)	.ENDIF80$:	CLR.W	D7		; D7 <-- ok90$:	POP.L	D3	RET;--------\\; LOCK    >;========/; Dbut de zone critique pour l'cran.; in	A5.L	^smaphore; out	-; mod	D7.WLOCK:	PUSH.L	D4	NTREL	?LOCK		; dbut de zone critique	JUMP',EQ 90$		; ok => 90$	COMP.W	D7,#ERTIMO	; timeout ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.W	D4,#-1	NTREL	?MODTIM		; met timeout infini	NTREL	?LOCK		; dbut de zone critique	NTREL	?SETTIM		; remet timeout utilisateur90$:	POP.L	D4	RET; Gestion des variables pour les descripteurs de chaque driver; ------------------------------------------------------------;--------\; OPEDESC >;========/; Prend et initialise les variables pour le descripteur de; la fentre.; in	A0.L	^base du driver; out	A2.L	^descripteur;	D7.W	erreur; mod	D7.W, A2.LOPEDESC:	PUSHM.L	D1,D4,A1,A4	LOAD.L	D4,#LGDFEN	; D4 <-- longueur totale	LOAD.W	D1,#MTYPBD	; D1 <-- type driver bios	LOAD.L	A1,A0		; A1 <-- ^base du driver	GESMEM	?GETMEM		; demande mmoire pour descripteur	JUMP',NE 90$	LOAD.L	A2,A4		; A2 <-- ^descripteur	SR.W	D4,#1		; D4 <-- /2  cause .W	DEC.W	D4		; D4 <-- -1  cause NMO20$:	CLR.W	(A4+)		; rempli tout de zro	DECJ.W,NMO D4,20$	LOAD.L	A4,#(A6)+OPDFEN	CLR.W	D4	LOAD.B	D4,(A0)+ODHNUM	; D4 <-- numro du driver	SUB.W	D4,#NOBASE	; D4 <-- 0..n	SL.W	D4,#2		; *4 car .L	LOAD.L	(A4)+(D4.W),A2	; mm. ^descripteur	LOAD.L	(A2)+ODFBAS,A0	; mm. ^base du driver	LOAD.L	(A2)+ODFPDE,A4	; mm. ^^descripteurs	CALL	INIDESC		; init le reste du descripteur	CALL	COLDESC		; init la couleur dans le descripteur	JUMP',EQ 90$		; ok => 90$				; erreur =>	PUSH.W	D7	LOAD.L	A4,A2		; A4 <-- ^descripteur;	LOAD.W	D1,#MTYPBD	; D1 <-- type driver bios;	LOAD.L	A1,A0		; A1 <-- ^base du driver	GESMEM	?GIVMEM		; rend mmoire pour descripteur	POP.W	D790$:	POPM.L	D1,D4,A1,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; INIDESC >;--------/; Initialise le descripteur d'une fentre.; in	A2.L	^descripteur; out	-; mod	D7.WINIDESC:	PUSHM.L	A0,A1	LOAD.L	A0,A6		; A0 <-- ^variables globales	LOAD.L	A1,(A2)+ODFBAS	; A1 <-- ^base du driver	LOAD.L	(A2)+ODFY,(A1+)	LOAD.L	(A2)+ODFDY,(A1+)	LOAD.W	(A2)+ODFCAD,(A1+)	LOAD.B	(A2)+ODFNOW,(A1+)	LOAD.B	(A2)+ODFMOD,(A1+)	LOAD.B	(A2)+ODFMCA,(A1+)	.IF	SM324BIG	COMP.B	(A2)+ODFNOW,#2	JUMP',NE 20$	TEST.B	(A0)+OWDO23	; fentre $DIS_2 et $DIS_3 ensemble ?	JUMP',EQ 20$	LOAD.W	(A2)+ODFDY,#(DBIGY-10)/220$:	COMP.B	(A2)+ODFNOW,#4	JUMP',NE 30$	TEST.B	(A0)+OWDO45	; fentre $DIS_4 et $DIS_5 ensemble ?	JUMP',EQ 30$	LOAD.W	(A2)+ODFDY,#(DBIGY-10)/230$:	.ENDIF	LOAD.B	(A2)+ODFTTM,#B'11111111	LOAD.B	(A2)+ODFTTS,#1	LOAD.B	(A2)+ODFFLG,#2^BFWMOU	.IF	FONDBLANC	TSET.B	(A2)+ODFMOD:#BFBLANC	.ENDIF	LOAD.L	A1,#R16"TASOFTKEY	LOAD.L	(A2)+ODFPSK,A1	; mm. ^table pour soft-keys	POPM.L	A0,A1	RET;--------\\; COLDESC >;--------/; Initialise le descripteur d'une fentre en fonction de la couleur.; in	A0.L	^base du driver;	A2.L	^descripteur; out	D7.W	erreur; mod	D7.WCOLDESC:	PUSHM.L	D1,D4,A1,A4	.IF	COLOR	LOAD.L	A4,(A6)+OPDFEN+(4*0) ; A4 <-- ^descripteur $DIS_0	LOAD.L	(A2)+ODFCPF,(A4)+ODFCPF ; ODFCPF <-- ^table des fausses couleurs	LOAD.B	D1,(A2)+ODFNOW	; D1 <-- numro de la fentre	COMP.B	D1,#NOWDOC	; cran monochrome ?	JUMP,LO 85$		; oui => 85$	LOAD.W	D4,#100		; D4 <-- 100 couleurs si $DIS_20	COMP.B	D1,#NOWDOC	JUMP',EQ 20$	LOAD.W	D4,#20		; D4 <-- 20 couleurs si $DIS_21, etc.20$:	LOAD.W	(A2)+ODFCMR,D4	; ODFCMR <-- nb max de couleurs relatives	MUL.WU	D4,#LCOLR	; D4 <-- longueur totale	LOAD.W	D1,#MTYPBD	; D1 <-- type driver bios	LOAD.L	A1,A0		; A1 <-- ^base du driver	GESMEM	?GETMEM		; demande mmoire pour couleurs relatives	JUMP,NE 90$	LOAD.L	(A2)+ODFCPR,A4	; ODFCPR <-- ^table	LOAD.W	D4,#10		; D4 <-- nb max de PUSHs	LOAD.W	(A2)+ODFCMS,D4	; ODFCMS <-- nb max de PUSHs	MUL.WU	D4,#4*2		; D4 <-- longueur totale;	LOAD.W	D1,#MTYPBD	; D1 <-- type driver bios;	LOAD.L	A1,A0		; A1 <-- ^base du driver	GESMEM	?GETMEM		; demande mmoire pour stack des couleurs	JUMP',NE 80$	LOAD.L	(A2)+ODFCPS,A4	; ODFCPR <-- ^stack	LOAD.W	(A2)+ODFCNB,#256; ODFCNB <-- 256 couleurs	LOAD.B	(A2)+ODFCNP,#8	; ODFCNP <-- 8 plans	LOAD.B	(A2)+ODFCMD,#1	; ODFCMD <-- mode couleur	LOAD.L	(A2)+ODFCLG,#LGBITS ; ODFCLG <-- distance entre deux plans	LOAD.L	(A2)+ODFCOM,#COLOR_PPSET	CALL	DOCOSR		; init la couleur pour dessiner	LOAD.L	(A2)+ODFCOM,#COLOR_PPCLEAR	CALL	DOCOCR		; init la couleur pour effacer	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	A4,(A2)+ODFCPR	; A4 <-- ^table;	LOAD.W	D1,#MTYPBD	; D1 <-- type driver bios;	LOAD.L	A1,A0		; A1 <-- ^base du driver	GESMEM	?GIVMEM		; rend la mmoire pour couleurs relatives	CLR.L	(A2)+ODFCPR	POP.W	D7	JUMP'	90$	.ENDIF85$:	LOAD.W	(A2)+ODFCNB,#2	; ODFCNB <-- 2 niveaux de gris	LOAD.B	(A2)+ODFCNP,#1	; ODFCNP <-- 1 seul plan	CLR.B	(A2)+ODFCMD	; ODFCMD <-- mode noir et blanc (monochrome)	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D4,A1,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; SRCDESC >;========/; Cherche les variables pour le descripteur de la fentre.; in	A0.L	^base du driver; out	A2.L	^descripteur; mod	A2.LSRCDESC:	PUSH.W	D2		LOAD.L	A2,#(A6)+OPDFEN	CLR.W	D2	LOAD.B	D2,(A0)+ODHNUM	; D2 <-- numro du driver	SUB.W	D2,#NOBASE	; D2 <-- 0..n	SL.W	D2,#2		; *4 car .L	LOAD.L	A2,(A2)+(D2.W)	; A2 <-- ^descripteur	POP.W	D2	RET;--------\; IFDESC  >;========/; Cherche si les variables pour le descripteur de la fentre; existent.; in	D0.W	numro de la fentre (0..n); out	NE	descripteur existe;	EQ	descripteur n'existe pas; mod	-IFDESC:	PUSH.L	A2	CALL	GETDESC	POP.L	A2	RET;--------\; GETDESC >;========/; Cherche les variables pour le descripteur de la fentre.; in	D0.W	numro de la fentre (0..n); out	NE	descripteur existe;	 A2.L	 ^descripteur;	EQ	descripteur n'existe pas; mod	A2.LGETDESC:	PUSH.L	D0		LOAD.L	A2,#(A6)+OPDFEN	SL.W	D0,#2		; *4 car .L	LOAD.L	D0,(A2)+(D0.W)	; D0 <-- ^descripteur	JUMP',EQ 90$	LOAD.L	A2,D0		; A2 <-- ^descripteur90$:	POPM.L	D0	RET;--------\; CLODESC >;========/; Rend les variables pour le descripteur de la fentre.; in	A2.L	^descripteur; out	-; mod	-CLODESC:	PUSHM.L	D1,D7,A1,A4	LOAD.W	D1,#MTYPBD	; D1 <-- type driver bios	LOAD.L	A1,(A2)+ODFBAS	; A1 <-- ^base du driver	.IF	COLOR	TEST.L	(A2)+ODFCPR	JUMP',EQ 10$	LOAD.L	A4,(A2)+ODFCPR	; A4 <-- ^zone mmoire	GESMEM	?GIVMEM		; demande mmoire pour couleurs relatives	CLR.L	(A2)+ODFCPR10$:	TEST.L	(A2)+ODFCPS	JUMP',EQ 20$	LOAD.L	A4,(A2)+ODFCPS	; A4 <-- ^zone mmoire	GESMEM	?GIVMEM		; demande mmoire pour stack des couleurs	CLR.L	(A2)+ODFCPS20$:	.ENDIF	LOAD.L	A4,A2		; A4 <-- ^zone mmoire	GESMEM	?GIVMEM		; demande mmoire pour descripteur	LOAD.L	A4,#(A6)+OPDFEN	CLR.W	D1	LOAD.B	D1,(A1)+ODHNUM	; D1 <-- numro du driver	SUB.W	D1,#NOBASE	; D1 <-- 0..n	SL.W	D1,#2		; *4 car .L	CLR.L	(A4)+(D1.W)	; ^descripteur = ^nil	POPM.L	D1,D7,A1,A4	RET; Initialisation gnrale de $DIS_0; ---------------------------------;--------\; IDIS    >;========/; Met les traits de sparations entre les fentres.; in	D1.W	numro du bitmap (0..3); out	-; mod	D7.WIDIS:	.IF	TTY	RET	.ELSE	PUSHM.L	D0,D3,D4,A1,A2	LOAD.L	A2,(A6)+OPDFEN+(4*0) ; A2 <-- ^desc. cran complt	.IF	SM100!SM324LIT	LOAD.W	D3,#0		; D3 <-- X	LOAD.W	D4,#SEPY81	; D4 <-- Y	LOAD.W	D0,#1024	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS8,9	LOAD.W	D3,#PVIEWX+4	LOAD.W	D0,#PVIEWY-(LARGCY/2)-(LARGCY*5)	CALL	SEGVERT		; droite entre $DIS1 et $DIS2/3	LOAD.W	D4,#LARGCY*2+170	LOAD.W	D0,#1024-(PVIEWX+4)	CALL	SEGHOR		; droite entre $DIS2 et $DIS3	.ENDIF	.IF	SM324BIG	.IF	FONDBLANC	CALL	COINS		; arrondi les 4 coins	.ENDIF	LOAD.W	D3,#0		; D3 <-- X	LOAD.W	D4,#SEPY81	; D4 <-- Y	LOAD.W	D0,#PVIEWX	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS8,9	LOAD.W	D3,#0		; D3 <-- X	LOAD.W	D4,#SEPY17	; D4 <-- Y	LOAD.W	D0,#PVIEWX	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS1	TEST.W	D1	JUMP,EQ BITMAP1$	COMP.W	D1,#1	JUMP,EQ BITMAP2$	COMP.W	D1,#2	JUMP,EQ BITMAP3$	COMP.W	D1,#3	JUMP,EQ BITMAP4$	JUMP	90$BITMAP1$:	LOAD.L	A1,#R16"D1BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	CALL	TRARECT		; grise $DIS_1	JUMP	90$BITMAP2$:	TEST.B	(A0)+OWDO23	; fentre $DIS_2 et $DIS_3 ensemble ?	JUMP',NE BITMAP2B$	; oui => BITMAP2B$	LOAD.L	A1,#R16"D2BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	CALL	TRARECT		; grise $DIS_2	JUMP	90$BITMAP2B$:	LOAD.L	A1,#R16"D2BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	SWAP.W	D3	LOAD.W	D3,#(DBIGY-10)/2	SWAP.W	D3	CALL	TRARECT		; grise $DIS_2	LOAD.L	A1,#R16"D3BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	CALL	TRARECT		; grise $DIS_3	LOAD.W	D3,#0		; D3 <-- X	LOAD.W	D4,#PBIGY+((DBIGY-10)/2)+0 ; D4 <-- Y	LOAD.W	D0,#PVIEWX	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS_2	LOAD.W	D3,#0		; D3 <-- X	LOAD.W	D4,#PBIGY+((DBIGY-10)/2)+10-1 ; D4 <-- Y	LOAD.W	D0,#PVIEWX	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus $DIS_3	JUMP	90$BITMAP3$:	TEST.B	(A0)+OWDO45	; fentre $DIS_4 et $DIS_5 ensemble ?	JUMP',NE BITMAP3B$	; oui => BITMAP3B$	LOAD.L	A1,#R16"D4BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	CALL	TRARECT		; grise $DIS_4	JUMP	90$BITMAP3B$:	LOAD.L	A1,#R16"D4BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	SWAP.W	D3	LOAD.W	D3,#(DBIGY-10)/2	SWAP.W	D3	CALL	TRARECT		; grise $DIS_4	LOAD.L	A1,#R16"D5BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	CALL	TRARECT		; grise $DIS_5	LOAD.W	D3,#0		; D3 <-- X	LOAD.W	D4,#PBIGY+((DBIGY-10)/2)+0 ; D4 <-- Y	LOAD.W	D0,#PVIEWX	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS_4	LOAD.W	D3,#0		; D3 <-- X	LOAD.W	D4,#PBIGY+((DBIGY-10)/2)+10-1 ; D4 <-- Y	LOAD.W	D0,#PVIEWX	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus $DIS_5	JUMP	90$BITMAP4$:	LOAD.L	A1,#R16"D6BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	CALL	TRARECT		; grise $DIS_6	LOAD.L	A1,#R16"D10BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	CALL	TRARECT		; grise $DIS_10	LOAD.L	A1,#R16"D11BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	CALL	TRARECT		; grise $DIS_11	LOAD.L	A1,#R16"D12BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	CALL	TRARECT		; grise $DIS_12	LOAD.L	A1,#R16"D13BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	CALL	TRARECT		; grise $DIS_13	LOAD.L	A1,#R16"D14BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	CALL	TRARECT		; grise $DIS_14	LOAD.L	A1,#R16"D15BASE	LOAD.L	D4,(A1)+0	LOAD.L	D3,(A1)+4	CALL	TRARECT		; grise $DIS_15	LOAD.W	D3,#((PVIEWX-640)/2)-1 ; D3 <-- X	LOAD.W	D4,#PBIGY+8-1	; D4 <-- Y	LOAD.W	D0,#640+1	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus $DIS_6	LOAD.W	D3,#((PVIEWX-640)/2)-1 ; D3 <-- X	LOAD.W	D4,#PBIGY+8+340	; D4 <-- Y	LOAD.W	D0,#640+1	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessous $DIS_6	LOAD.W	D3,#((PVIEWX-640)/2)-1 ; D3 <-- X	LOAD.W	D4,#PBIGY+8-1	; D4 <-- Y	LOAD.W	D0,#340+1	; D0 <-- dY (hauteur)	CALL	SEGVERT		; droite  gauche $DIS_6	LOAD.W	D3,#((PVIEWX-640)/2)+640 ; D3 <-- X	LOAD.W	D4,#PBIGY+8-1	; D4 <-- Y	LOAD.W	D0,#340+1+1	; D0 <-- dY (hauteur)	CALL	SEGVERT		; droite  droite $DIS_6	LOAD.W	D4,#PBIGY+DBIGY-((8+DLITY)*3)-1	CALL	LITLEFT$	LOAD.W	D4,#PBIGY+DBIGY-((8+DLITY)*2)-1	CALL	LITLEFT$	LOAD.W	D4,#PBIGY+DBIGY-((8+DLITY)*1)-1	CALL	LITLEFT$	LOAD.W	D4,#PBIGY+DBIGY-((8+DLITY)*3)-1	CALL	LITRIGHT$	LOAD.W	D4,#PBIGY+DBIGY-((8+DLITY)*2)-1	CALL	LITRIGHT$	LOAD.W	D4,#PBIGY+DBIGY-((8+DLITY)*1)-1	CALL	LITRIGHT$	.ENDIF	.IF	SM8; UTILISER UNE FOIS LARGCX ET LARGCY AU LIEU DE 8 ET 16 !!!	LOAD.W	D3,#0		; D3 <-- X	LOAD.W	D4,#SEPY81	; D4 <-- Y	LOAD.W	D0,#1024-8	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS8,9,10	TEST.B	(A0)+OWDBIG	; grande fentre ?	JUMP,NE	90$		; oui => 90$				; non =>	LOAD.W	D3,#800-4	LOAD.W	D4,#32+160+8	LOAD.W	D0,#1024-(800-4)-8	CALL	SEGHOR		; droite entre $DIS2 et 3	LOAD.W	D4,#32+160+16+112+8	CALL	SEGHOR		; droite entre $DIS3 et 4	LOAD.W	D3,#800-4	LOAD.W	D4,#SEPY81	LOAD.W	D0,#8+160+16+112+16+112	CALL	SEGVERT		; droite entre $DIS1 et 2,3,4	LOAD.W	D3,#0		; D3 <-- X	LOAD.W	D4,#512+SEPY81	; D4 <-- Y	LOAD.W	D0,#1024-8	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS8,9,10	LOAD.W	D3,#800-4	LOAD.W	D4,#512+32+160+8	LOAD.W	D0,#1024-(800-4)-8	CALL	SEGHOR		; droite entre $DIS12 et 13	LOAD.W	D4,#512+32+160+16+112+8	CALL	SEGHOR		; droite entre $DIS13 et 14	LOAD.W	D3,#800-4	LOAD.W	D4,#512+SEPY81	LOAD.W	D0,#8+160+16+112+16+112	CALL	SEGVERT		; droite entre $DIS11 et 12,14	.ENDIF90$:	POPM.L	D0,D3,D4,A1,A2	RET	.IF	SM324BIGLITLEFT$:	LOAD.W	D3,#0		; D3 <-- X	LOAD.W	D0,#DLITX+1	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus	ADD.W	D4,#DLITY+1	CALL	SEGHOR		; droite dessous	SUB.W	D4,#DLITY+1	LOAD.W	D3,#DLITX	; D3 <-- X	LOAD.W	D0,#DLITY+1	; D0 <-- dY (hauteur)	CALL	SEGVERT		; droite  droite	RETLITRIGHT$:	LOAD.W	D3,#DLITX+16-1	; D3 <-- X	LOAD.W	D0,#DLITX+1	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus	ADD.W	D4,#DLITY+1	CALL	SEGHOR		; droite dessous	SUB.W	D4,#DLITY+1	LOAD.W	D0,#DLITY+1	; D0 <-- dY (hauteur)	CALL	SEGVERT		; droite  droite	RET	.ENDIF;--------\; SEGHOR  >;--------/; Trace un segment horizontal.; in	A2.L	^description de la fentre;	D3.W	coordonne X;	D4.W	coordonne Y;	D0.W	longueur; out	-; mod	D7.WSEGHOR:	PUSHM.L	D0,D1,D3,D4	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- coordonne (y;x)	CLR.L	D3	LOAD.W	D3,D0		; D3 <-- longueurs (dy;dx)	LOAD.W	D1,#SETDOT	; D1 <-- mode	GRA_	LINE		; dessine une ligne horizontale	.IF	SM8	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	GRA_	LINE		;  cause du mode entrelac	.ENDIF	POPM.L	D0,D1,D3,D4	RET;--------\; SEGVERT >;--------/; Trace un segment vertical.; in	A2.L	^description de la fentre;	D3.W	coordonne X;	D4.W	coordonne Y;	D0.W	longueur; out	-; mod	D7.WSEGVERT:	PUSHM.L	D0,D1,D3,D4	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- coordonne (y;x)	CLR.L	D3	LOAD.W	D3,D0	SWAP.W	D3		; D3 <-- longueurs (dy;dx)	LOAD.W	D1,#SETDOT	; D1 <-- mode	GRA_	LINE		; dessine une ligne verticale	.IF	SM8	DEC.W	D4	GRA_	LINE		;  cause du mode entrelac	.ENDIF	POPM.L	D0,D1,D3,D4	RET	.IF	SM324BIG;--------\\; TRARECT >;--------/; Dessine une trame grise rectangulaire.; in	D4.L	origine (y;x);	D3.L	dimensions (dy;dx); out	-; mod	D7.WTRARECT:	PUSHM.L	D1,A4	LOAD.W	D1,#SETDOT	; D1 <-- mode	LOAD.L	A4,#R16"00$	; A4 <-- ^trame	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_TRAME-GRA_FIRST))	CALL	(A0)		; appel de GRA_TRAME	POP.L	A0	POPM.L	D1,A4	RET00$:	.L	TRAGRIS	.L	TRAGRIS	.ENDIF	.ENDIF	.INS	DISCAR.ASI	.IF	COLOR	.INS	DISCOLOR.ASI	.ENDIF	.IF	TTY	.INS	DISNEF11.ASI	.ENDIF	.INS	DISTYPO.ASI	.INS	DISSOFTKEY.ASI	.INS	DISVAR.ASI	.END