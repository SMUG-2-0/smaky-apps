	.TITLE	DCOLOR	.PROC	M680002	.REF	SM8	.REF	LIB	.REF	DRIVERS	.REF	FOS	.REF	NTREL	.REF	GESMEM	.REF	COLORS	.LOC	0OBUDIS:	.BLKB	100LGVAR:	.LOC	0START:	LIB	?OPELIB	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LOAD.W	D3,#H'8000	LOAD.W	D4,#H'0000	LOAD.W	D5,#H'8000	LIB	?COLORCA	LIB	?AFTIM	.B	NOCURS,EOP	.B	PEN	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'01111110	.B	B'00111100	.B	0	.EVEN	LOAD.W	D3,#H'FFFF	LOAD.W	D4,#H'0000	LOAD.W	D5,#H'0000	LIB	?COLORSA	LOAD.L	D3,#H'10000*100+100	LOAD.L	D4,#H'10000*200+300	LOAD.W	D2,#SETDOT!PENDOT	LIB	?DRSEG	LOAD.W	D3,#H'0000	LOAD.W	D4,#H'FFFF	LOAD.W	D5,#H'0000	LIB	?COLORSA	LOAD.L	D3,#H'10000*100+150	LOAD.L	D4,#H'10000*200+300	LOAD.W	D2,#SETDOT!PENDOT	LIB	?DRSEG	LOAD.W	D3,#H'0000	LOAD.W	D4,#H'0000	LOAD.W	D5,#H'FFFF	LIB	?COLORSA	LOAD.L	D3,#H'10000*100+200	LOAD.L	D4,#H'10000*200+300	LOAD.W	D2,#SETDOT!PENDOT	LIB	?DRSEG	LOAD.L	D3,#H'10000*300+100	LOAD.L	D4,#H'10000*(-200)+300	LOAD.W	D2,#INVDOT	LIB	?DRSEG	LOAD.L	D3,#H'10000*300+150	LOAD.L	D4,#H'10000*(-200)+300	LOAD.W	D2,#INVDOT!PENDOT	LIB	?DRSEG; -------------------------------------------- caractres	LIB	?AFTIM	.B	LOADGC,'U,'R,09	.B	USEGC,'U,'R,09	.B	0	.EVEN	LOAD.W	D3,#H'FFFF	LOAD.W	D4,#H'0000	LOAD.W	D5,#H'0000	LIB	?COLORSA	LOAD.W	D3,#H'0000	LOAD.W	D4,#H'FFFF	LOAD.W	D5,#H'0000	LIB	?COLORCA	LOAD.L	D3,#H'10000*10+10	LIB	?SETCURS	LIB	?AFTIM	.B	MODCAR,SETDOT!PENDOT	.ASCII	"Rouge en mode SET    "	.B	MODCAR,SETDOT	.B	0	.EVEN	LIB	?AFTIM	.B	MODCAR,INVDOT!PENDOT	.ASCII	"Rouge en mode INV    "	.B	MODCAR,SETDOT	.B	0	.EVEN	LIB	?AFTIM	.B	MODCAR,SETDOT	.ASCII	"Rouge en mode LOAD    "	.B	MODCAR,SETDOT	.B	0	.EVENERFAT1:	LIB	?CLOLIB	FOS	?STOP	.END	START