	.SBTTL	GRACOLOR	.IF	COLORADVME16	=	H'2000000	; adresse de base VME16M1MEGA	=	1024*1024	; 1 MgaADBCOUL	=	ADVME16+H'C0000000+10*M1MEGAADCVDC	=	ADBCOUL+0ADCVDCR	=	ADBCOUL+2ADCBITS	=	ADBCOUL+2*M1MEGAADCPIXELS=	ADBCOUL+3*M1MEGAADCLOGIC=	ADBCOUL+4*M1MEGAADCRAMDAC=	ADBCOUL+5*M1MEGALGBITS	=	128*1024	; lg entre deux plansMVDCZERO=	0		; mode  M <--  0MVDCAND1=	2		; mode  M <--  D &  MMVDCAND2=	4		; mode  M <-- ~D &  MMVDCNOP	=	6		; mode  M <--  MMVDCAND3=	8		; mode  M <--  D & ~MMVDCLOAD=	10		; mode  M <--  DMVDCXOR	=	12		; mode  M <-- ~D &  M  !   D & ~MMVDCOR1	=	14		; mode  M <--  D !  MMVDCNOR	=	16		; mode  M <-- ~D & ~MMVDCXNOR=	18		; mode  M <--  D &  M  !  ~D & ~MMVDCNOT1=	20		; mode  M <-- ~DMVDCOR2	=	22		; mode  M <-- ~D !  MMVDCNOT2=	24		; mode  M <-- ~MMVDCOR3	=	26		; mode  M <--  D ! ~MMVDCNAND=	28		; mode  M <-- ~D ! ~MMVDCONE	=	30		; mode  M <--  1	.ENDIF;---------\\; MODVDCCP >;=========/; Donne un mode logique pour dessiner en couleur.;	mode = MVDCxxxx; in	A0.L	^table;		 (A0)+0    mode si C=0 et S=0;		 (A0)+2    mode si C=0 et S=1;		 (A0)+4    mode si C=1 et S=0;		 (A0)+6    mode si C=1 et S=1;		 (A0)+8    masque C;		 (A0)+10   masque S;	D5.W	masque dans un word; out	-; mod	D7.WMODVDCCP:	PUSHM.L	D1..D4,A1;;-	LOAD.L	A1,#ADCLOGIC	LOAD.L	D1,#ADCLOGIC	LOAD.L	A1,D1	LOAD.W	D2,(A0)+8	; D2 <-- masque C	LOAD.W	D3,(A0)+10	; D3 <-- masque S	LOAD.W	D1,#8-1		; D1 <-- nb de plans10$:	RR.L	D2,#1		; D2 <-- masque C suivant	JUMP',CS 14$	RR.L	D3,#1		; D3 <-- masque S suivant	JUMP',CS 12$	LOAD.W	D4,(A0)+0	; D4 <-- mode si C=0 et S=0	JUMP'	20$12$:	LOAD.W	D4,(A0)+2	; D4 <-- mode si C=0 et S=1	JUMP'	20$14$:	RR.L	D3,#1		; D3 <-- masque S suivant	JUMP',CS 16$	LOAD.W	D4,(A0)+4	; D4 <-- mode si C=1 et S=0	JUMP'	20$16$:	LOAD.W	D4,(A0)+6	; D4 <-- mode si C=1 et S=1;	JUMP'	20$20$:	COMP.W	D4,#MVDCNOP	JUMP',EQ 30$	LOAD.W	(A1)+(D4.W),D5	JUMP'	50$30$:	LOAD.W	(A1)+MVDCLOAD,#050$:	ADD.L	A1,#LGBITS	; A1 <-- ^plan suivant	DECJ.W,NMO D1,10$	POPM.L	D1..D4,A1	RET;--------\\; MODVDCC >;========/; Donne un mode logique pour dessiner en couleur.;	mode = MVDCxxxx; in	D0.L	mode si C=0 et S=1  |  mode si C=0 et S=0;	D1.L	mode si C=1 et S=1  |  mode si C=1 et S=0;	D2.L	masque C;	D3.L	masque S;	D4.W	masque dans un word; out	-; mod	D7.WMODVDCC:	PUSHM.L	D2..D6,A0;;-	LOAD.L	A0,#ADCLOGIC	LOAD.L	D6,#ADCLOGIC	LOAD.L	A0,D6	LOAD.W	D6,#8-1		; D6 <-- nb de plans10$:	LOAD.L	D5,D0	TEST.L	D2:#0		; masque C = 0  ?	JUMP',BC 12$	LOAD.L	D5,D112$:	TEST.L	D3:#0		; masque S = 1  ?	JUMP',BC 14$	SWAP.W	D514$:	COMP.W	D5,#MVDCNOP	JUMP',EQ 30$	LOAD.W	(A0)+(D5.W),D4	JUMP'	50$30$:	LOAD.W	(A0)+MVDCLOAD,#050$:	ADD.L	A0,#LGBITS	; A0 <-- ^plan suivant	RR.L	D2,#1		; D2 <-- masque C suivant	RR.L	D3,#1		; D3 <-- masque S suivant	DECJ.W,NMO D6,10$	POPM.L	D2..D6,A0	RET	.END