	.CHAP	DISCOMM; Routines pour ?COMMAND; ----------------------;--------\; WRONEC  >;========/; Effectue une commande en modifiant le contenu de la table; pour le controleur d'cran VDC.; in	A4.L	^commande;	A2.32	^description fentre; out	A4.L	^plus loin;	D7.16	erreur; mod	D0..A1, A4.L, D7.WWRONEC:	MOVE.8	{A4+},D0	; D0 <-- commandeWRONEX:	CLR.16	D7		; D7 <-- ok	MOVE.32	#R16^L00$-4,A1L10$:	ADD.32	#4,A1		; A1 <-- ^suivant dans table	TEST.8	{A1}+1		; fin de la table	JUMP,EQ	 R8^L80$	; oui => 80$	COMP.8	{A1}+1,D0	; commande trouve ?	JUMP,NE L10$		; non => 10$				; oui =>	CLR.32	D0	MOVE.16	{A1}+2,D0	; D0 <-- adresse relative	ADD.32	{A6}+OSTART,D0	; D0 <-- adresse absolue	PUSH.32	D0	.IF	SM300	.ELSE	MOVE.32	#{A6}+OTAVDC,A1	; A1 <-- ^table VDC	.ENDIF	SM300	RET			; JUMP (D0)L80$:	MOVE.16	#ERDIIL,D7	; D7 <-- "commande illgale"	RETL00$:	.16	SCRCADRE,DOCADRE	.16	SCRMVERT,DOMVERT	.16	SCRDVERT,DODVERT	.16	SCRGHOR,DOGHOR	.16	SCRDHOR,DODHOR	.16	SCRVERT,DOVERT	.16	SCRHOR,DOHOR	.16	SCRLEFT,DOCLEFT	.16	SCRRIGHT,DOCRIGHT	.16	SCRUP,DOCUP	.16	SCRDOWN,DOCDOWN	.16	SCRCENTRE,DOCENTRE	.16	SCRCOIN,DOCOIN	.16	SCRPOX,DOPOX	.16	SCRPOY,DOPOY	.16	SCRICONE,DOICONE	.16	SCRPARAM,DOPARAM	.16	SCRBITMAP+0,DOBITMAP0	.16	SCRBITMAP+1,DOBITMAP1	.IF	SM100.OR.SM324.OR.SM196.or.sm300	.16	SCRBITMAP+2,DOBITMAP2	.16	SCRBITMAP+3,DOBITMAP3	.IF	COLOR	.16	SCRBITMAP+4,DOBITMAP4	.ENDIF	COLOR	.ENDIF	SM100.OR.SM324.OR.SM196	.16	SCRVIDEO,DOVIDEO	.16	0; ---	SCRCADRE   ---; Remet le cadrage standard horizontalement et verticalement.DOCADRE:	.IF	SM300	RET	.ELSE	MOVE.8	{A6}+OSREGV,{A1}+REGVERT	MOVE.8	{A6}+OSREGH,{A1}+REGHOR1	JUMP	INIVDC		; init le contrleur d'cran	.ENDIF	SM300; ---	SCRMVERT   ---; Monte le cadrage vertical.DOMVERT:	.IF	SM300	RET	.ELSE	INC.8	{A1}+REGVERT	; modifie dans la table TAVDC	JUMP	INIVDC		; init le contrleur d'cran	.ENDIF	SM300; ---	SCRDVERT   ---; Descend le cadrage vertical.DODVERT:	.IF	SM300		RET	.ELSE	DEC.8	{A1}+REGVERT	; modifie dans la table TAVDC	JUMP	INIVDC		; init le contrleur d'cran	.ENDIF	SM300; ---	SCRGHOR   ---; Met le cadrage horizontal plus  gauche.DOGHOR:	.IF	SM300	RET	.ELSE	INC.8	{A1}+REGHOR1	; modifie dans la table TAVDC;;?	ADD.B	(A1)+REGHOR2,#2	JUMP	INIVDC		; init le contrleur d'cran	.ENDIF	SM300; ---	SCRDHOR   ---; Met le cadrage horizontal plus  droite.DODHOR:	.IF	SM300	RET	.ELSE	DEC.8	{A1}+REGHOR1	; modifie dans la table TAVDC;;?	SUB.B	(A1)+REGHOR2,#2	JUMP	INIVDC		; init le contrleur d'cran	.ENDIF	SM300; ---	SCRVERT   ---; Initialise le cadrage vertical en fonction du byte suivant; la commande (zro = standard).DOVERT:	.IF	SM300	RET	.ELSE	MOVE.8	{A4+},D0	; D0 <-- paramtre commande	ADD.8	{A6}+OSREGV,D0	MOVE.8	D0,{A1}+REGVERT	JUMP	INIVDC		; init le contrleur d'cran	.ENDIF	SM300; ---	SCRHOR   ---; Initialise le cadrage horizontal en fonction du byte suivant; la commande (zro = standard).DOHOR:	.IF	SM300	RET	.ELSE	MOVE.8	{A4+},D0	; D0 <-- paramtre commande	ADD.8	{A6}+OSREGH,D0	MOVE.8	D0,{A1}+REGHOR1	JUMP	INIVDC		; init le contrleur d'cran	.ENDIF	SM300; ---	SCRLEFT   ---; Montre la partie gauche de l'cran 1024 x 1024.DOCLEFT:	.IF	SM300	TEST.16	VideoSamInit+2	JUMP,EQ	R8^Out$		CALL	ShowLeft	CLR.16	VideoSamInit+2Out$:	RET	.ELSE	.IF	SM8.OR.SM100.OR.SM324LIT.OR.SM196	COMP.8	#16'00,{A1}+REGPOX	JUMP,EQ	 R8^L90$	CALL	SHOWLEFT	MOVE.8	#16'00,{A1}+REGPOXL90$:	.ENDIF	SM8.OR.SM100.OR.SM324LIT.OR.SM196	JUMP	INIVDC		; init le contrleur d'cran	.ENDIF	SM300; ---	SCRRIGHT   ---; Montre la partie droite de l'cran 1024 x 1024.DOCRIGHT:	.IF	SM300	TEST.16	VideoSamInit+2	JUMP,ne	R8^Out$	CALL	ShowRight.IF	Color300	COMP.16	#512,VideoInc	JUMP,LO	R8^BW$	MOVE.16	#48*4, VideoSamInit+2	JUMP	R8^Out$BW$:	MOVE.16	#48, VideoSamInit+2.ELSE	MOVE.16	#48, VideoSamInit+2.ENDIF	ELSE Color300Out$:	RET	.ELSE	.IF	SM8.OR.SM100.OR.SM324LIT.OR.SM196	COMP.8	#16'0C,{A1}+REGPOX	JUMP,EQ	 R8^L90$	CALL	SHOWRIGHT	MOVE.8	#16'0C,{A1}+REGPOXL90$:	.ENDIF	SM8.OR.SM100.OR.SM324LIT.OR.SM196	JUMP	INIVDC		; init le contrleur d'cran	.ENDIF	SM300; ---	SCRUP   ---; Montre la moiti suprieure de l'cran 1024 x 1024.DOCUP:	RET; ---	SCRDOWN   ---; Montre la moiti infrieure de l'cran 1024 x 1024.DOCDOWN:	RET; ---	SCRPOX   ---DOPOX:	MOVE.8	{A4+},D0	; D0 <-- paramtre high	SL.16	#8,D0	MOVE.8	{A4+},D0	; D0 <-- paramtre low	MOVE.16	D0,D1	SR.16	#4,D0		; D0 <-- <xx> /16	COMP.8	#16'0C,D0	JUMP,LO	 R8^L40$	MOVE.8	#16'0C,D0L40$:	COMP.8	#16'0C/2,D0	; plutt  gauche ?	JUMP,LO DOCLEFT		; oui => cale  gauche	JUMP	DOCRIGHT	; non => cale  droite; ---	SCRPOY   ---DOPOY:	MOVE.8	{A4+},D0	; D0 <-- paramtre high	SL.16	#8,D0	MOVE.8	{A4+},D0	; D0 <-- paramtre low	RET; ---	SCRCENTRE   ---; Centre l'cran pour que la fentre utilise soit visible.DOCENTRE:	MOVE.8	#"O",D0		; D0 <-- "O"pen	MOVE.16	{A6}+ONOVBM,D1	CALL	USEBITMAP	; bitmap occup ?	JUMP,NE	 R8^L10$	; oui => 10$	MOVE.8	#"C",D0		; D0 <-- "C"loseL10$:	ADD.8	#"1",D1		; D1 <-- "1..4"	CALL	AFICONE		; grise l'ancienne icne.IF	Color300	TEST.8	{A2}+ODFCMD	; Mode couleur ?	JUMP,F	R8^noCLUT$	CALL	SetCLUT		; Charge la nouvelle CLUTnoClut$:.ENDIF	Color300	MOVE.8	{A2}+ODFCAD+1,D0 ; 2me commande de centrage	JUMP,EQ	 R8^L20$	CALL	WRONEXL20$:	MOVE.8	{A2}+ODFCAD+0,D0 ; 1re commande de centrage	JUMP,EQ	 R8^L30$	CALL	WRONEXL30$:	MOVE.8	#"U",D0		; D0 <-- "U"se	MOVE.16	{A6}+ONOVBM,D1	CALL	USEBITMAP	; bitmap occup ?	JUMP,NE	 R8^L50$	; oui => 50$	MOVE.8	#"O",D0		; D0 <-- "O"penL50$:	ADD.8	#"1",D1		; D1 <-- "1..4"	CALL	AFICONE		; allume la nouvelle icne	CLR.16	D7		; D7 <-- ok	RET; ---	SCRBITMAP   ---; Change de bitmap principal.DOBITMAP0:	CLR.16	D1	JUMP	CHANBITMAP	; change de bitmapDOBITMAP1:	MOVE.16	#1,D1	JUMP	CHANBITMAP	; change de bitmapDOBITMAP2:	MOVE.16	#2,D1	JUMP	CHANBITMAP	; change de bitmapDOBITMAP3:	MOVE.16	#3,D1	JUMP	CHANBITMAP	; change de bitmapDOBITMAP4:	MOVE.16	#4,D1	JUMP	CHANBITMAP	; change de bitmap; ---	SCRVIDEO   ---; Change de standard vido.DOVIDEO:	.IF	SM300	RET	.ELSE	MOVE.8	{A4+},D0	; D0 <-- paramtre commande	CALL	NEWVDC	JUMP	INIVDC		; init le contrleur d'cran	.ENDIF	SM300; ---	SCRPARAM   ---; Redonne les paramtres comme  l'INSTALLDOPARAM:	PUSH.32	D2	MOVE.32	{A4+},A1	; A1 <-- pointeur paramtres	CALL	DIMOK?		; dimensions fentre ok ?	TEST.16	D7	JUMP,NE	 R8^L90$	; non => 90$	CALL	GCLOAD		; charge le gnrateur standard	TEST.16	D7	JUMP,NE	 R8^L90$	CALL	GCUSE		; (A2)++ <-- paramtres	TEST.16	D7	JUMP,NE	 R8^L90$	MOVE.32	{A2}+ODFC1Y,{A2}+ODFPY	CLR.32	{A2}+ODFPGY	CLR.32	{A2}+ODFFY	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	CLR.32	{A2}+ODFPMS	; remet la souris standard	CLR.32	{A2}+ODFPMC	CALL	INIDESC		; init le reste du descripteurL90$:	POP.32	D2	RET; ---	DOICONE   ---DOICONE:	MOVE.8	{A4+},D0	; D0 <-- floppy/clavier	MOVE.8	{A4+},D1	; D1 <-- paramtre;	JUMP	AFICONE.IF	Color300;--------\\; AFICONE >;========/; Affiche une icne tout en haut.; in	D0.8	floppy/clavier/bitmap;	D1.8	paramtre; out	-; mod	-AFICONE:	PUSHM.32 A1..A4|D1..D5	MOVE.32	#R16^TAICONE-6,A1L10$:	ADD.A16	#6,A1	; A1 <-- ^suivant dans TAICONE	TEST.8	{A1}		; fin de la table ?	JUMP,EQ L90$		; oui => 90$	COMP.8	{A1}+0,D0	JUMP,NE L10$	COMP.8	{A1}+1,D1	JUMP,NE L10$	MOVE.32	#R16^TaIcone,A3	ADD.A16	{A1}+2,A3	; A3 ^matrice source	MOVE.32	#16'10000,D4	; Coordonne Y destination	MOVE.16	{A1}+4,D4	; D4.32 <- coordonnes destination	MOVE.32	{A6}+OPDFEN+(4*0),A2 ; A2 <-- ^descripteur $DIS_0	COMP.8	#"R",{A2}+ODFCAD+1; fentre cadre  droite ?	JUMP,NE	 R8^L40$	; non => 40$	ADD.16	#1024-PViewX,D4	; Oui => on en tient compte.L40$:	MOVE.16	#LIcone,D2	SWAP.32	D2	CLR.16	D2	MOVE.8	{A3+},D2	MOVE.16	D2,D5		; D5.16 <- rowBytes source	ADD.16	D2,D2	ADD.16	D2,D2	ADD.16	D2,D2		; D2.32 <- dimensions du transfert	MOVE.32	#0,D3		; D3.32 <- coordonnes source	MOVE.32	#0,A4		; A4 <- ^nil (destination=cran)	MOVE.32	#LoadDot,D1	GRA2_	Raster		; Et on affiche.L90$:	POPM.32	A1..A4|D1..D5	RETTAICONE:	.8	"O","1"	.16		ICONESO-TaIcone,(SEPX89-LARICOX)*LARGCX+1*8	.8	"O","2"	.16		ICONESO-TaIcone,(SEPX89-LARICOX)*LARGCX+4*8	.8	"O","3"	.16		ICONESO-TaIcone,(SEPX89-LARICOX)*LARGCX+7*8	.8	"O","4"	.16		ICONESO-TaIcone,(SEPX89-LARICOX)*LARGCX+10*8	.8	"U","1"	.16		ICONES1-TaIcone,(SEPX89-LARICOX)*LARGCX+1*8	.8	"U","2"	.16		ICONES2-TaIcone,(SEPX89-LARICOX)*LARGCX+4*8	.8	"U","3"	.16		ICONES3-TaIcone,(SEPX89-LARICOX)*LARGCX+7*8	.8	"U","4"	.16		ICONES4-TaIcone,(SEPX89-LARICOX)*LARGCX+10*8	.8	"C","1"	.16		ICONESC-TaIcone,(SEPX89-LARICOX)*LARGCX+1*8	.8	"C","2"	.16		ICONESC-TaIcone,(SEPX89-LARICOX)*LARGCX+4*8	.8	"C","3"	.16		ICONESC-TaIcone,(SEPX89-LARICOX)*LARGCX+7*8	.8	"C","4"	.16		ICONESC-TaIcone,(SEPX89-LARICOX)*LARGCX+10*8	.8	"K","R"	.16		ICONE0-TaIcone,(SEPX89-LARICOX)*LARGCX+16*8	.8	"K","P"	.16		ICONEKP-TaIcone,(SEPX89-LARICOX)*LARGCX+16*8	.8	"F","0"	.16		ICONE0-TaIcone,(SEPX89-LARICOX)*LARGCX+19*8	.8	"F","1"	.16		ICONE0-TaIcone,(SEPX89-LARICOX)*LARGCX+21*8	.8	"F","2"	.16		ICONEF23-TaIcone,(SEPX89-LARICOX)*LARGCX+19*8	.8	"F","3"	.16		ICONEF23-TaIcone,(SEPX89-LARICOX)*LARGCX+21*8	.8	"F","4"	.16		ICONEF45-TaIcone,(SEPX89-LARICOX)*LARGCX+19*8	.8	"F","5"	.16		ICONEF45-TaIcone,(SEPX89-LARICOX)*LARGCX+21*8	.8	0.EVEN.ELSE	Color300;--------\\; AFICONE >;========/; Affiche une icne tout en haut.; in	D0.B	floppy/clavier/bitmap;	D1.8	paramtre; out	-; mod	-AFICONE:	PUSHM.32 D0|D1|A0..A2	.IF	SM324BIG	COMP.8	#"C",D0		; "C"lose ?	JUMP,NE	 R8^L05$	; non => 05$				; oui =>	COMP.8	#"2",D1		; bitmap pour $DIS_2 et $DIS_3 ?	JUMP,NE	 R8^L03$	; non => 03$	TEST.8	{A6}+OWDO23	JUMP,EQ	 R8^L03$	MOVE.8	#"D",D0		; D0 <-- "C"lose doubleL03$:	COMP.8	#"3",D1		; bitmap pour $DIS_4 et $DIS_5 ?	JUMP,NE	 R8^L05$	; non => 05$	TEST.8	{A6}+OWDO45	JUMP,EQ	 R8^L05$	MOVE.8	#"D",D0		; D0 <-- "C"lose doubleL05$:	.ENDIF	SM324BIG	MOVE.32	#R16^TAICONE-6,A1L10$:	MOVE.32	#{A1}+6,A1	; A1 <-- ^suivant dans TAICONE	TEST.8	{A1}		; fin de la table ?	JUMP,EQ L90$		; oui => 90$	COMP.8	{A1}+0,D0	JUMP,NE L10$	COMP.8	{A1}+1,D1	JUMP,NE L10$	CLR.32	D0	MOVE.16	{A1}+2,D0	; D0 <-- adresse relative	ADD.32	{A6}+OSTART,D0	; D0 <-- adresse absolue	MOVE.32	D0,A0		; A0 <-- ^icone	CLR.32	D0	MOVE.16	{A1}+4,D0	; D0 <-- offset dans l'cran	MOVE.32	{A6}+OPDFEN+(4*0),A2 ; A2 <-- ^descripteur $DIS_0	MOVE.32	{A2}+ODFABS,A1	; A1 <-- adresse dbut cran	ADD.32	D0,A1		; A1 <-- ajoute l'offset	.IF	SM324BIG	MOVE.32	#{A1}+1024*2/8,A1 ; A1 <-- 2 lignes en dessous	.ENDIF	SM324BIG	COMP.8	#"R",{A2}+ODFCAD+1; fentre cadre  droite ?	JUMP,NE	 R8^L40$	; non => 40$	MOVE.32	#{A1}+(1024-PVIEWX)/8,A1 ; oui => tient compte dcalageL40$:	MOVE.16	#LICONE-1,D0	; -1  cause du test NMO	COMP.8	#3,{A0+}	JUMP,EQ	 R8^L60$L50$:	MOVE.8	{A0+},{A1}+0	; met le byte de gauche	MOVE.8	{A0+},{A1}+1	; met le byte de droite	MOVE.32	#{A1}+16'80,A1	; A0 <-- ^byte en dessous	DJ.16,NMO  D0,L50$	JUMP	R8^L90$L60$:	MOVE.8	{A0+},{A1}+0	; met le byte de gauche	MOVE.8	{A0+},{A1}+1	; met le byte du milieu	MOVE.8	{A0+},{A1}+2	; met le byte de droite	MOVE.32	#{A1}+16'80,A1	; A0 <-- ^byte en dessous	DJ.16,NMO  D0,L60$L90$:	POPM.32	D0|D1|A0..A2	RETTAICONE:	.8	"O","1"	.16		ICONESO,(SEPX89-LARICOX)*LARGCX/8+1	.8	"O","2"	.16		ICONESO,(SEPX89-LARICOX)*LARGCX/8+4	.8	"O","3"	.16		ICONESO,(SEPX89-LARICOX)*LARGCX/8+7	.8	"O","4"	.16		ICONESO,(SEPX89-LARICOX)*LARGCX/8+10	.IF	COLOR	.8	"O","5"	.16		ICONESO,(SEPX89-LARICOX)*LARGCX/8+13	.ENDIF	COLOR	.8	"U","1"	.16		ICONES1,(SEPX89-LARICOX)*LARGCX/8+1	.8	"U","2"	.16		ICONES2,(SEPX89-LARICOX)*LARGCX/8+4	.8	"U","3"	.16		ICONES3,(SEPX89-LARICOX)*LARGCX/8+7	.8	"U","4"	.16		ICONES4,(SEPX89-LARICOX)*LARGCX/8+10	.IF	COLOR	.8	"U","5"	.16		ICONES5,(SEPX89-LARICOX)*LARGCX/8+13	.ENDIF	COLOR	.IF	SM324BIG	.8	"C","1"	.16		ICONESS,(SEPX89-LARICOX)*LARGCX/8+1	.8	"C","2"	.16		ICONESS,(SEPX89-LARICOX)*LARGCX/8+4	.8	"C","3"	.16		ICONESS,(SEPX89-LARICOX)*LARGCX/8+7	.8	"C","4"	.16		ICONESM,(SEPX89-LARICOX)*LARGCX/8+10;	.B	'D,'1;	.W		ICONESD,(SEPX89-LARICOX)*LARGCX/8+1	.8	"D","2"	.16		ICONESD,(SEPX89-LARICOX)*LARGCX/8+4	.8	"D","3"	.16		ICONESD,(SEPX89-LARICOX)*LARGCX/8+7;	.B	'D,'4;	.W		ICONESM,(SEPX89-LARICOX)*LARGCX/8+10	.ELSE	.8	"C","1"	.16		ICONESC,(SEPX89-LARICOX)*LARGCX/8+1	.8	"C","2"	.16		ICONESC,(SEPX89-LARICOX)*LARGCX/8+4	.8	"C","3"	.16		ICONESC,(SEPX89-LARICOX)*LARGCX/8+7	.8	"C","4"	.16		ICONESC,(SEPX89-LARICOX)*LARGCX/8+10	.ENDIF	SM324BIG	.IF	COLOR	.8	"C","5"	.16		ICONESJ,(SEPX89-LARICOX)*LARGCX/8+13	.ENDIF	COLOR	.8	"K","R"	.16		ICONE0,(SEPX89-LARICOX)*LARGCX/8+16	.8	"K","P"	.16		ICONEKP,(SEPX89-LARICOX)*LARGCX/8+16	.8	"F","0"	.16		ICONE0,(SEPX89-LARICOX)*LARGCX/8+19	.8	"F","1"	.16		ICONE0,(SEPX89-LARICOX)*LARGCX/8+21	.8	"F","2"	.16		ICONEF23,(SEPX89-LARICOX)*LARGCX/8+19	.8	"F","3"	.16		ICONEF23,(SEPX89-LARICOX)*LARGCX/8+21	.8	"F","4"	.16		ICONEF45,(SEPX89-LARICOX)*LARGCX/8+19	.8	"F","5"	.16		ICONEF45,(SEPX89-LARICOX)*LARGCX/8+21	.8	0	.EVEN.ENDIF	ELSE Color300	.ODDICONE0:	.8	2	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000LICONE	= (APC-ICONE0)/2	.ODDICONEKP:	.8	2	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0110011001100011	.16	2'1000100101010100	.16	2'1000100101010100	.16	2'1000100101010010	.16	2'1000111101100001	.16	2'1000100101000001	.16	2'0110100101000110	.16	2'0000000000000000	.16	2'0000000000000000	