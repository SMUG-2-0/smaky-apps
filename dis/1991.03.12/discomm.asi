'11111111,2'11100000	.8	2'10000000,2'00000000,2'00010000	.8	2'10000000,2'00000000,2'00010000	.8	2'10000000,2'00000000,2'00010000	.8	2'10000000,2'00000000,2'00010000	.8	2'10000000,2'00000000,2'00010000	.8	2'10000000,2'00000000,2'00010000	.8	2'11111111,2'11111111,2'11110000	.8	2'10000000,2'00100000,2'00010000	.8	2'10000000,2'00100000,2'00010000	.8	2'11111111,2'11111111,2'11110000	.8	2'10000000,2'00100000,2'00010000	.8	2'10000000,2'00100000,2'00010000	.8	2'01111111,2'11111111,2'11100000	.ENDIF	SM324BIG	.IF	COLORICONESJ:	.8	3	.8	2'01111111,2'11111111,2'11100000	.8	2'10000000,2'00000000,2'00010000	.8	2'10000000,2'00000000,2'00010000	.8	2'10000000,2'00000000,2'00010000	.8	2'10000000,2'11110000,2'00010000	.8	2'10000001,2'00001000,2'00010000	.8	2'10000001,2'00000000,2'00010000	.8	2'10000001,2'00000000,2'00010000	.8	2'10000001,2'00001000,2'00010000	.8	2'10000000,2'11110000,2'00010000	.8	2'10000000,2'00000000,2'00010000	.8	2'10000000,2'00000000,2'00010000	.8	2'10000000,2'00000000,2'00010000	.8	2'01111111,2'11111111,2'11100000	.ENDIF	COLOR	.EVEN; ---	DOCOIN   ---DOCOIN:	CLR.16	D0	MOVE.8	{A4+},D0	; D0 <-- paramtre commande;	JUMP	ICOIN;--------\; ICOIN   >;========/; Efface tous les "coins", puis dessine celui demand.; in	D0.W	numro de la fentre o mettre un "coin"; out	-; mod	-ICOIN:	.IF	SM8.OR.SM100.OR.SM324LIT.OR.SM196.OR.SM300	RET	.ENDIF	SM8.OR.SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM324BIG	PUSHM.32 D0|D1|D2|A1|A2|A3|A4.if	modifjfg	move.32	#r16^Tacoin, a4	sub.32	#ltacoin, a4.else	MOVE.32	#R16^TACOIN-LTACOIN,A4.endif	ModifJFG	MOVE.32	A4,A1L30$:	MOVE.32	#{A1}+LTACOIN,A1 ; A1 <-- ^suivant dans TACOIN	COMP.16	#-1,{A1}	; fin de la table ?	JUMP,EQ	 R8^L50$	; oui => 50$	CALL	L00$		; calcul deuzoutroi bricoles	JUMP,NE L30$L40$:	MOVE.16	{A3+},D2	; D2 <-- motif	NOT.16	D2	AND.16	D2,{A2}		; efface un bout de "coin"	MOVE.32	#{A2}+(1024/8),A2	DJ.16,NMO  D1,L40$	JUMP	L30$L50$:	MOVE.32	A4,A1L55$:	MOVE.32	#{A1}+LTACOIN,A1 ; A1 <-- ^suivant dans TACOIN	COMP.16	#-1,{A1}	; fin de la table ?	JUMP,EQ	 R8^L90$	; oui => 90$	COMP.16	{A1}+0,D0	; "coin"  mettre trouv ?	JUMP,NE L55$		; non => 55$				; oui =>	CALL	L00$		; calcul deuzoutroi bricoles	JUMP,NE L55$L60$:	MOVE.16	{A3+},D2	; D2 <-- motif	OR.16	D2,{A2}		; dessine un bout de "coin"	MOVE.32	#{A2}+(1024/8),A2	DJ.16,NMO  D1,L60$	JUMP	L55$L90$:	POPM.32	D0|D1|D2|A1|A2|A3|A4	RET; in	A1.L	^dans TACOIN; out	A2.L	^dans l'cran;	A3.32	^motif;	D1.8	longueur du motif;	D7.16	erreurL00$:	MOVE.16	#1,D7	MOVE.16	{A1}+0,D2	; D2 <-- numro de la fentre	COMP.16	#2,D2	JUMP,EQ	 R8^L01$	COMP.16	#3,D2	JUMP,NE	 R8^L02$L01$:	TEST.8	{A6}+OWDO23	JUMP,EQ L09$L02$:	COMP.16	#4,D2	JUMP,EQ	 R8^L03$	COMP.16	#5,D2	JUMP,NE	 R8^L04$L03$:	TEST.8	{A6}+OWDO45	JUMP,EQ L09$L04$:	PUSH.32	A1	CALL	CHENBITMAP	; A1 <-- ^table du bitmap	MOVE.32	A1,A2	POP.32	A1	TEST.16	D7	JUMP,NE	 R8^L09$	MOVE.16	#1,D7	TEST.32	{A2}+OBMABS	; bitmap existe ?	JUMP,EQ	 R8^L09$	; non => 09$	MOVE.32	{A2}+OBMABS,A2	; A2 <-- adresse du bitmap	CLR.32	D1	MOVE.16	{A1}+2,D1	; D1 <-- ^relatif	ADD.32	{A6}+OSTART,D1	; D1 <-- ^absolu	MOVE.32	D1,A3		; A3 <-- ^motif  dessiner	MOVE.16	{A1}+4,D1	; D1 <-- X	SR.16	#3,D1	ADD.A16	D1,A2	CLR.32	D1	MOVE.16	{A1}+6,D1	; D2 <-- Y	SL.32	#7,D1	ADD.32	D1,A2	MOVE.16	#16-1,D1	; D1 <-- lg du motif	CLR.16	D7		; D7 <-- okL09$:	TEST.16	D7		; retour EQ/NE	RETLTACOIN	=	4*2TACOIN:	.16	2,CARCUP,16,PBIGY+((DBIGY-10)/2)	.16	3,CARCDOWN,16,PBIGY+((DBIGY-10)/2)	.16	4,CARCUP,16,PBIGY+((DBIGY-10)/2)	.16	5,CARCDOWN,16,PBIGY+((DBIGY-10)/2);;?	.W	6,CARCUPM	DLITX,PBIGY+DBIGY-((8+DLITY)*3)-8	.16	6,CARCUPM,DLITX,PBIGY+8+340	.16	10,CARCLEFT,DLITX,PBIGY+DBIGY-((8+DLITY)*3)+10	.16	11,CARCLEFT,DLITX,PBIGY+DBIGY-((8+DLITY)*2)+10	.16	12,CARCLEFT,DLITX,PBIGY+DBIGY-((8+DLITY)*1)+10	.16	13,CARCRIGHT,DLITX,PBIGY+DBIGY-((8+DLITY)*3)+10	.16	14,CARCRIGHT,DLITX,PBIGY+DBIGY-((8+DLITY)*2)+10	.16	15,CARCRIGHT,DLITX,PBIGY+DBIGY-((8+DLITY)*1)+10	.16	-1CARCUPM:	.16	2'0000000000000000	.16	2'0011111001111100	.16	2'0011110000111100	.16	2'0011100000011100	.16	2'0011000000001100	.16	2'0010000000000100	.16	2'0011110000111100	.16	2'0011110000111100	.16	2'0011110000111100	.16	2'0011110000111100	.16	2'0011111111111100	.16	2'0011111111111100	.16	2'0011111111111100	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000CARCUP:	.16	2'0000000000000000	.16	2'1111111011111110	.16	2'1111110001111110	.16	2'1111100000111110	.16	2'1111000000011110	.16	2'1110000000001110	.16	2'1111110001111110	.16	2'1111110001111110	.16	2'1111110001111110	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000CARCDOWN:	.16	2'0000000000000000	.16	2'1111110001111110	.16	2'1111110001111110	.16	2'1111110001111110	.16	2'1110000000001110	.16	2'1111000000011110	.16	2'1111100000111110	.16	2'1111110001111110	.16	2'1111111011111110	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000CARCLEFT:	.16	2'0111111111111110	.16	2'0111111111111110	.16	2'0111111111111110	.16	2'0111101111111110	.16	2'0111001111111110	.16	2'0110001111111110	.16	2'0100000000001110	.16	2'0000000000001110	.16	2'0100000000001110	.16	2'0110001111111110	.16	2'0111001111111110	.16	2'0111101111111110	.16	2'0111111111111110	.16	2'0111111111111110	.16	2'0111111111111110	.16	2'0000000000000000CARCRIGHT:	.16	2'0111111111111110	.16	2'0111111111111110	.16	2'0111111111111110	.16	2'0111111111011110	.16	2'0111111111001110	.16	2'0111111111000110	.16	2'0111000000000010	.16	2'0111000000000000	.16	2'0111000000000010	.16	2'0111111111000110	.16	2'0111111111001110	.16	2'0111111111011110	.16	2'0111111111111110	.16	2'0111111111111110	.16	2'0111111111111110	.16	2'0000000000000000	.ENDIF	SM324BIG.IF	.NOT.SM300;--------\; INIVDC  >;========/; Initialise le controleur d'cran en fonction de tous les; paramtres contenus dans TAVDC.	.IF	SM324; ainsi que de l'offset sur la position en X	.ENDIF	SM324; in	A2.L	^description fentre;	TAVDC	.IF	SM324;	OOREGX.B	.ENDIF; out	-; mod	-INIVDC:.if	sm196	MOVE.8		#REGPOX, AdVdc	MOVE.8		{A6}+OTaVdc+regpox, AdVdcr.else	PUSHM.32 D0|D1|A1		.IF	COLOR	TEST.8	{A2}+ODFCMD	; cran couleur ?	JUMP,NE L90$		; oui => 90$	.ENDIF	MOVE.32	#{A6}+OTAVDC,A1	; A1 <-- ^TAVDC	CLR.16	D0		; D0 <-- no premier registreL10$:	.IF	SM8.OR.SM100.or.sm196	MOVE.8	D0,ADVDC	; init numro registre	MOVE.8	{A1+},ADVDCR	; init contenu du registre	.ENDIF	SM8.OR.SM100.or.sm196	.IF	SM324	MOVE.8	D0,ADVDC	; init numro registre	MOVE.8	{A1+},D1	COMP.8	#REGPOX,D0	JUMP,NE	 R8^L20$	ADD.8	{A6}+OOREGX,D1L20$:	MOVE.8	D1,ADVDCR	; init contenu du registre	.ENDIF	SM324	INC.16	D0		; D0 <-- no registre suivant	COMP.16	#LTAVDC,D0	JUMP,NE L10$L90$:	POPM.32	D0|D1|A1.endif	sm196	RET;--------\\; NEWVDC  >;========/; Initialise le circuit VDC-6845e contrleur d'cran.; in	A2.L	^description fentre;	D0.8	no de standard vido (0..3); out	D7.W	erreur; mod	D7.WNEWVDC:	PUSHM.32 D3|A3|A4	MOVE.16	#ERDIIL,D7	; D7 <-- "commande illgale"	.IF	COLOR	TEST.8	{A2}+ODFCMD	; cran couleur ?	JUMP,NE L90$		; oui => 90$	.ENDIF	MOVE.32	#{A6}+OTBVDC,A3	; A3 <-- ^table VDC standard (20 KHz).IF	SM196.ELSE	TEST.8	D0;--dd--	JUMP,NE	L90$	JUMP,EQ	 R8^L10$	MOVE.32	#R16^TA16KHZ,A3	; A3 <-- ^table VDC spciale (16 KHz)	COMP.8	#1,D0	JUMP,EQ	 R8^L10$	MOVE.32	#R16^TAJMR,A3	; A3 <-- ^table VDC spciale (JMR)	COMP.8	#2,D0	JUMP,NE	 R8^L90$L10$:.ENDIF	SM196	MOVE.8	{A3}+REGHOR1,{A6}+OSREGH	MOVE.8	{A3}+REGVERT,{A6}+OSREGV	MOVE.32	#{A6}+OTAVDC,A4	MOVE.16	#LTAVDC-2-1,D3L20$:	MOVE.8	{A3+},{A4+}	; TAVDC <-- nouvelle table	DJ.16,NMO  D3,L20$	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D3|A3|A4	TEST.16	D7		; retour EQ/NE	RET.IF	SM196.ELSETA16KHZ:	.8	128/4-1	.8	80/4	.8	88/4+1	.8	5*16'10+5	.8	625/16-1	.8	625-(625/16)*16	.8	400/16	.8	560/16	.8	2'00000111	.8	16-1	.8	0	.8	0	.8	0	.8	0TAJMR:	.8	16'17	.8	16'14-1	.8	16'15-2	.8	16'82	.8	16'19	.8	0	.8	25	.8	25	.8	2'100	.8	16-1	.8	0	.8	0	.8	0	.8	0.ENDIF	SM196.ENDIF	.NOT.SM300	.END