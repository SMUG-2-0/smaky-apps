	.SBTTL	PALPAL.ASI;--------\\; PALDRAW >;========/; Affiche toute la palette.; in	-; out	-; mod	D7.WPALDRAW:	PUSHM.L	D1..D5	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D1LOOP$:	CALL	PALPOS		; D3/D4 <-- position/dimensions	LOAD.W	D2,#SETDOT	LIB	?DRRECT	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	PUSH.L	(A0)+ODFCSF	LOAD.L	(A0)+ODFCSF,D1	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	POP.L	(A0)+ODFCSF	INC.W	D1	COMP.W	D1,#NBCOUL	JUMP,LO LOOP$	POPM.L	D1..D5	RET;--------\\; PALGET  >;========/; Donne le rang de la fausse couleur choisie dans la scroll-liste.; in	-; out	D1.W	rang de la fausse couleur (0..n);	D3.W	rouge;	D4.W	vert;	D5.W	bleu; mod	D1.L, D3.L, D4.L, D5.L, D7.WPALGET:	PUSH.L	A3	LIB	?COLORPUSH	LOAD.L	A3,#R16"TABLE	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	MUL.WU	D3,#LTABLE	ADD.L	A3,D3	LOAD.W	D3,(A3)+4+0	LOAD.W	D4,(A3)+4+2	LOAD.W	D5,(A3)+4+4	LIB	?COLORSA	LOAD.L	D1,(A0)+ODFCSF	; D1 <-- rang fausse couleur actuelle	LIB	?COLORPOP	POP.L	A3	RET;--------\\; PALPUT  >;========/; Initialise la scroll-liste en fonction de la fausse couleur choisie.; in	D1.W	rang de la fausse couleur (0..n); out	-; mod	D7.WPALPUT:	PUSHM.L	D1..D5,A3,A4	LOAD.L	A4,(A0)+ODFCPF	MUL.WU	D1,#3	ADD.L	A4,D1	LOAD.B	D3,(A4+)	; D3 <-- rouge	SL.W	D3,#8	LOAD.B	D4,(A4+)	; D4 <-- vert	SL.W	D4,#8	LOAD.B	D5,(A4+)	; D5 <-- bleu	SL.W	D5,#8	LOAD.L	A3,#R16"TABLE	LOAD.W	D2,(A6)+OSLVAR+OSLCYS	MUL.WU	D2,#LTABLE	ADD.L	A3,D2	LOAD.W	(A3)+4+0,D3	LOAD.W	(A3)+4+2,D4	LOAD.W	(A3)+4+4,D5	LOAD.L	D2,(A3)+0	CALL	LINK	POPM.L	D1..D5,A3,A4	RET;--------\\; PALMOVE >;========/; Choix d'une couleur dans la palette.; in	D4.L	coordonne souris (y;x); out	D1.W	couleur choisie (0..n);	D7.W	erreur; mod	D1.L, D7.WPALMOVE:	PUSHM.L	D2..D4	CALL	PALDET		; D1 <-- rang o est la souris	JUMP,NE EXIT$	CALL	PALINV		; allume la premire	LOAD.W	D2,D1LOOP$:	LIB	?GETKEY		; attend dplacement ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	IFMOUSE	JUMP,NE LOOP$	CALL	PALDET		; D1 <-- rang o est la sourisMOVE$:	COMP.W	D1,D2	JUMP,EQ LOOP$	EX.L	D1,D2	CALL	PALINV		; teint l'ancienne	LOAD.W	D1,D2	CALL	PALINV		; allume la nouvelle	JUMP	LOOP$END$:	CALL	PALINV		; teint la dernire	LOAD.W	D7,#1	COMP.W	D1,#-1	JUMP',EQ EXIT$	CLR.W	D7EXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PALDET  >;--------/; Dtecte o est la souris dans la palette.; in	D4.L	coordonne souris (y;x); out	D1.W	rang;	D7.W	erreur; mod	D1.L, D7.WPALDET:	PUSHM.L	D2..D5	LOAD.L	D5,D4	CLR.W	D1	CLR.W	D7LOOP$:	CALL	PALPOS	LOAD.L	D2,D5	SUB.W	D2,D3	JUMP',LO NEXT$	COMP.W	D2,D4	JUMP',HS NEXT$	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SUB.W	D2,D3	JUMP',LO NEXT$	COMP.W	D2,D4	JUMP',LO EXIT$NEXT$:	INC.W	D1	COMP.W	D1,#NBCOUL	JUMP,LO LOOP$	LOAD.W	D1,#-1	LOAD.W	D7,#1EXIT$:	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; PALCROIX >;=========/; Met une croix dans une case de la palette.; in	D1.W	rang; out	-; mod	D7.WPALCROIX:	PUSHM.L	D2..D4	COMP.W	D1,#-1	JUMP,EQ EXIT$	LIB	?COLORPUSH	CALL	DEFGET		; D3/D4/D5 <-- rouge/vert/bleu	NOT.W	D3	CLR.B	D3	NOT.W	D4	CLR.B	D4	NOT.W	D5	CLR.B	D5	LIB	?COLORSA	CALL	PALPOS	LOAD.W	D2,#SETDOT	ADD.W	D3,#5	SWAP.W	D3	ADD.W	D3,#5	SWAP.W	D3	SUB.W	D4,#5+5-1	SWAP.W	D4	SUB.W	D4,#5+5-1	SWAP.W	D4	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	ADD.W	D3,D4	NEG.W	D4	LIB	?DRSEG	LIB	?COLORPOPEXIT$:	POPM.L	D2..D4	RET;--------\\; PALINV  >;========/; Met en vidence une case de la palette.; in	D1.W	rang; out	-; mod	D7.WPALINV:	PUSHM.L	D2..D4	COMP.W	D1,#-1	JUMP,EQ EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	PALPOS	LOAD.W	D2,#INVDOT	PUSHM.L	D3,D4	SUB.W	D3,#LPALINV	ADD.W	D4,#LPALINV+LPALINV+1	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#LPALINV	LOAD.W	D4,#LPALINV+1	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; haut	POPM.L	D3,D4	PUSHM.L	D3,D4	SUB.W	D3,#LPALINV	LOAD.W	D4,#LPALINV+1	SWAP.W	D3	SWAP.W	D4	INC.W	D3	DEC.W	D4	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; gauche	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,D4	LOAD.W	D4,#LPALINV+1	SWAP.W	D3	SWAP.W	D4	INC.W	D3	DEC.W	D4	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; droite	POPM.L	D3,D4	PUSHM.L	D3,D4	SUB.W	D3,#LPALINV	ADD.W	D4,#LPALINV+LPALINV+1	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	LOAD.W	D4,#LPALINV+1	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; bas	POPM.L	D3,D4EXIT$:	POPM.L	D2..D4	RET;--------\\; PALPOS  >;--------/; Donne la position et les dimensions d'une case de la palette.; in	D1.W	rang; out	D3.L	position (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WPALPOS:	PUSHM.L	D1,D2	AND.L	D1,#H'FFFF	.IF	COUL256	DIV.WU	D1,#16	.ELSE	DIV.WU	D1,#4	.ENDIF	LOAD.W	D2,(A6)+OSLVAR+OSLDIM+0	.IF	COUL256	SR.W	D2,#4		; D2 <-- dimensions	.ELSE	SR.W	D2,#2		; D2 <-- dimensions	.ENDIF	LOAD.W	D3,D1	MUL.WU	D3,D2	ADD.W	D3,#30	SWAP.W	D3	SWAP.W	D1	MUL.WU	D1,D2	ADD.W	D1,(A6)+OPALPX	LOAD.W	D3,D1	LOAD.W	D4,D2	SWAP.W	D4	LOAD.W	D4,D2	POPM.L	D1,D2	RET	.END