	.SBTTL	ICOLICONE.ASILICOINV	=	3		; largeur pour ICOINVE;--------\\; ICOMOVE >;========/; Choix d'une icne, tant que le bouton de la souris est maintenu press.; in	D4.L	coordonne souris (y;x);	A2.L	^routine ICOPOS (*); out	D1.W	rang choisi (0..n);	D7.W	erreur; mod	D1.L, D7.WICOMOVE:	PUSHM.L	D2..D4	CALL	ICODET		; D1 <-- rang o est la souris	JUMP',NE EXIT$	CALL	ICOINVE		; allume la premire	LOAD.W	D2,D1LOOP$:	LIB	?GETKEY		; attend dplacement ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	IFMOUSE	JUMP,NE LOOP$	CALL	ICODET		; D1 <-- rang o est la souris	COMP.W	D1,D2	JUMP,EQ LOOP$	EX.L	D1,D2	CALL	ICOINVE		; teint l'ancienne	LOAD.W	D1,D2	CALL	ICOINVE		; allume la nouvelle	JUMP	LOOP$END$:	CALL	ICOINVE		; teint la dernire	CALL	(A2)		; D7 <-- EQ/NEEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ICODET  >;--------/; Dtecte o est la souris dans une icne.; in	D4.L	coordonne souris (y;x);	A2.L	^routine ICOPOS (*); out	D1.W	rang (0..n);	D7.W	erreur; mod	D1.L, D7.WICODET:	PUSHM.L	D2..D5	LOAD.L	D5,D4	CLR.W	D1		; D1 <-- rang initialLOOP$:	CALL	(A2)		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	LOAD.L	D2,D5	SUB.W	D2,D3	JUMP',LO NEXT$	COMP.W	D2,D4	JUMP',HS NEXT$	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SUB.W	D2,D3	JUMP',LO NEXT$	COMP.W	D2,D4	JUMP',LO EXIT$NEXT$:	INC.W	D1		; D1 <-- rang suivant	JUMP	LOOP$EXIT$:	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; ICOCROIX >;=========/; Met une croix dans une icne.; in	D1.W	rang (0..n);	A2.L	^routine ICOPOS (*); out	-; mod	D7.WICOCROIX:	PUSHM.L	D2..D4	COMP.W	D1,#-1	JUMP',EQ EXIT$	CALL	(A2)		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	LOAD.W	D2,#SETDOT	ADD.W	D3,#5	SWAP.W	D3	ADD.W	D3,#5	SWAP.W	D3	SUB.W	D4,#5+5-1	SWAP.W	D4	SUB.W	D4,#5+5-1	SWAP.W	D4	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	ADD.W	D3,D4	NEG.W	D4	LIB	?DRSEGEXIT$:	POPM.L	D2..D4	RET;--------\\; ICOINVE >;========/; Met en vidence une icne, en inversant l'extrieur.; in	D1.W	rang (0..n);	A2.L	^routine ICOPOS (*); out	-; mod	D7.WICOINVE:	PUSHM.L	D2..D4	COMP.W	D1,#-1	JUMP,EQ EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	(A2)		; D3/D4 <-- position/dimensions	JUMP,NE EXIT$	LOAD.W	D2,#INVDOT	PUSHM.L	D3,D4	SUB.W	D3,#LICOINV	ADD.W	D4,#LICOINV+LICOINV+1	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#LICOINV	LOAD.W	D4,#LICOINV+1	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; haut	POPM.L	D3,D4	PUSHM.L	D3,D4	SUB.W	D3,#LICOINV	LOAD.W	D4,#LICOINV+1	SWAP.W	D3	SWAP.W	D4	INC.W	D3	DEC.W	D4	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; gauche	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,D4	LOAD.W	D4,#LICOINV+1	SWAP.W	D3	SWAP.W	D4	INC.W	D3	DEC.W	D4	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; droite	POPM.L	D3,D4	PUSHM.L	D3,D4	SUB.W	D3,#LICOINV	ADD.W	D4,#LICOINV+LICOINV+1	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	LOAD.W	D4,#LICOINV+1	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; bas	POPM.L	D3,D4EXIT$:	POPM.L	D2..D4	RET; (*)	Description d'une routine ICOPOS* :;--------\\; ICOPOS* >;--------/; Donne la position et les dimensions d'une icne.; D3/D4 correspondent exactement aux valeurs pour LIB,?DRRECT !; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.W	.END