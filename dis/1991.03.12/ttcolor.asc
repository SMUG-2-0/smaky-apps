	.TITLE	TTCOLOR.ASC	.PROC	M680002	.REF	SMAKY	.REF	TCOLOR	.LOC	0OCHTCOL:.BLKB	2		; canal module TCOLORORGB1:	.BLKB	6ORGB2:	.BLKB	6LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.L	A3,#R16"NMTCOL	LOAD.W	D3,#TCOL_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHTCOL,D1	LOAD.W	D4,#4	CLR.W	D3	TCOL_	OPEN	JUMP,NE FINI	LOAD.L	A3,#R16"TCLUT	LOAD.W	D3,#2^BTCTABLE	TCOL_	LOADCLUT	JUMP,NE ERROR	LOAD.L	A3,#R16"TCRET	LOAD.W	D3,#2^BTCTABLE	TCOL_	LOADCRET	JUMP,NE ERROR	CLR.W	D3	TCOL_	ADDCRET	JUMP,NE ERRORLOOP:	LIB	?AFTIM	.B	CR	.ASCIZ	"1=SRCCLUT, 2=PUTCLUT, 3=SRCCRET, 4=PUTCRET, END ? "	.EVEN	LIB	?GETCAR	LIB	?AFCODE	COMP.W	D3,#'1	JUMP,EQ SRCCLUT	COMP.W	D3,#'2	JUMP,EQ PUTCLUT	COMP.W	D3,#'3	JUMP,EQ SRCCRET	COMP.W	D3,#'4	JUMP,EQ PUTCRET	COMP.W	D3,#END	JUMP,EQ FINI	JUMP	LOOPSRCCLUT:	LOAD.L	A4,#(A6)+ORGB1	LOAD.L	A3,#(A6)+ORGB2	LIB	?AFTIM	.ASCIZ	"<CR>Rouge = "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.W	(A4)+OTCCR,D4	LIB	?AFTIM	.ASCIZ	"Vert = "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.W	(A4)+OTCCG,D4	LIB	?AFTIM	.ASCIZ	"Bleu = "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.W	(A4)+OTCCB,D4	LOAD.W	D3,#2^BTCGIVE	TCOL_	SRCCLUT	JUMP,NE LOOP	LIB	?AFTIM	.ASCIZE	"Fausse couleur="	LIB	?AFX8	LIB	?AFSPACE	LOAD.L	A4,A3	CALL	AFFRGB	JUMP	LOOPPUTCLUT:	LOAD.L	A4,#(A6)+ORGB1	LIB	?AFTIM	.ASCIZ	"<CR>Fausse couleur = "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.L	D2,D4	LIB	?AFTIM	.ASCIZ	"Rouge = "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.W	(A4)+OTCCR,D4	LIB	?AFTIM	.ASCIZ	"Vert = "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.W	(A4)+OTCCG,D4	LIB	?AFTIM	.ASCIZ	"Bleu = "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.W	(A4)+OTCCB,D4	LOAD.L	D4,D2	LOAD.W	D3,#2^BTCFORCE	TCOL_	PUTCLUT	JUMP	LOOPSRCCRET:	LOAD.L	A4,#(A6)+ORGB1	LOAD.L	A3,#(A6)+ORGB2	LIB	?AFTIM	.ASCIZ	"<CR>Couleur relative = "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.W	D3,#2^BTCGIVE	TCOL_	SRCCRET	JUMP,NE LOOP	LIB	?AFTIM	.ASCIZE	"Fausse couleur="	LIB	?AFX8	LIB	?AFTIM	.ASCIZE	"<CR>Nomm: "	CALL	AFFRGB	LIB	?AFTIM	.ASCIZE	"Exact: "	LOAD.L	A4,A3	CALL	AFFRGB	JUMP	LOOPPUTCRET:	LOAD.L	A4,#(A6)+ORGB1	LIB	?AFTIM	.ASCIZ	"<CR>Couleur relative = "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.L	D2,D4	LIB	?AFTIM	.ASCIZ	"Rouge = "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.W	(A4)+OTCCR,D4	LIB	?AFTIM	.ASCIZ	"Vert = "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.W	(A4)+OTCCG,D4	LIB	?AFTIM	.ASCIZ	"Bleu = "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.W	(A4)+OTCCB,D4	LOAD.L	D4,D2	CLR.W	D3	TCOL_	PUTCRET	JUMP	LOOPERROR:	LIB	?AFERROR	LIB	?GETCARFINI:	CLR.W	D3	TCOL_	CLOSE	LOAD.W	D1,(A6)+OCHTCOL	LIB_	CLOSEERFAT:	EXITAFFRGB:	LIB	?AFTIM	.ASCIZE	"Rouge="	LOAD.W	D4,(A4)+OTCCR	LIB	?AFX4	LIB	?AFTIM	.ASCIZE	" Vert="	LOAD.W	D4,(A4)+OTCCG	LIB	?AFX4	LIB	?AFTIM	.ASCIZE	" Bleu="	LOAD.W	D4,(A4)+OTCCB	LIB	?AFX4	LIB	?AFCR	RETNMTCOL:	.ASCIZ	"TCOLOR"	.EVENTCLUT:	.B	CLTYPE,0	.L	10*4	.W	4	.FILLB	24,0	.W	0,0,0,0,0	.W	0,1,H'2000,H'2000,H'2000	.W	0,2,H'4000,H'4000,H'4000	.W	0,3,H'E000,H'E000,H'E000TCRET:	.B	CRTYPE,0	.L	10*6	.W	6	.FILLB	24,0	.W	0,0,0,0,0	.W	0,1,H'5000,H'5000,H'5000	.W	0,2,0,0,0	.W	0,3,H'2000,H'2000,H'2000	.W	0,4,H'F000,H'F000,H'F000	.W	0,5,0,0,0VAR:	.FILLB	LGVAR,0	.END	START