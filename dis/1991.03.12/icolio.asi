	.SBTTL	ICOLIO.ASI;-----------\\; IOSAVECRET >;===========/; Sauve un fichier CRET.; in	A3.L	^nom;	D4.L	fanions; out	D7.W	erreur; mod	D7.WIOSAVECRET:	PUSHM.L	D3..D6	CALL	WAITMOUSE	; met le sablier	TEST.L	D4:#1		; sauve dans le dossier systme ?	JUMP',BC NAME$		; non => NAME$	LOAD.B	(-A3),#':	LOAD.B	(-A3),#'#	; met "#:" devant le nomNAME$:	FOS	?DELETE		; dtruit l'ancien fichier .CRET	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE EXIT$	LOAD.W	D4,D6		; D4 <-- canal FOS	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode	TSET.L	D3:#BTCCHFOS	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	SAVECLUT	; sauve un fichier CLUT	JUMP',NE CLOSE$;	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode;	TSET.L	D3:#BTCCHFOS	LOAD.L	D5,(A6)+OIDCRET	; D5 <-- id. CRET;	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	SAVECRET	; sauve un fichier CRETCLOSE$:	PUSH.W	D7	LOAD.W	D6,D4		; D6 <-- canal FOS	FOS	?CLOSE	POP.W	D7EXIT$:	CALL	NORMMOUSE	; enlve le sablier	POPM.L	D3..D6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IOLOADCLUT >;===========/; Charge une nouvelle CLUT.; in	A3.L	^nom; out	D7.W	erreur; mod	D7.WIOLOADCLUT:	PUSHM.L	D3,D6	CALL	WAITMOUSE	; met le sablier	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode	TSET.L	D3:#BTCNAME	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	LOADCLUT	; charge une nouvelle CLUT	CALL	NORMMOUSE	; enlve le sablier	POPM.L	D3,D6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IOSAVECLUT >;===========/; Sauve un fichier CLUT.; in	A3.L	^nom; out	D7.W	erreur; mod	D7.WIOSAVECLUT:	PUSHM.L	D3,D6	CALL	WAITMOUSE	; met le sablier	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode	TSET.L	D3:#BTCNAME	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	SAVECLUT	; sauve un fichier CLUT	CALL	NORMMOUSE	; enlve le sablier	POPM.L	D3,D6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IONAMECRET >;===========/; Construit le nom du fichier .CRET en fonction du nom du logiciel.; in	A3.L	^nom du logiciel; out	A3.L	^nom du fichier .CRET; mod	A3.LIONAMECRET:	PUSHM.L	A2,A4	LOAD.L	A4,#(A6)+OBUCRET	LOAD.L	A2,#R16"PREF$XPREF$:	LOAD.B	(A4+),(A2+)	; OININM <-- prfixe	JUMP,NE XPREF$	DEC.L	A4XNAME$:	LOAD.B	(A4+),(A3+)	; OININM <-- nom du logiciel	JUMP,NE XNAME$	DEC.L	A4	LOAD.L	A2,#R16"POST$XPOST$:	LOAD.B	(A4+),(A2+)	; OININM <-- extension .CRET	JUMP,NE XPOST$	LOAD.L	A3,#(A6)+OBUCRET	POPM.L	A2,A4	RETPREF$:	.ASCIZ	"(:,#:)"	; d'abord dans dossier courant puis dans systme !POST$:	.ASCIZ	".CRET"	.EVEN	.END