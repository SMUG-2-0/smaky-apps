	.SBTTL	PALDEG.ASI;--------\\; DEGDRAW >;========/; Affiche toute le dgrad.; in	D0.W	couleur de base (0..n); out	-; mod	D7.WDEGDRAW:	PUSHM.L	D1..D4	LIB	?COLORPUSH	CLR.W	D1LOOP$:	CALL	DEGPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	LOAD.L	(A0)+ODFCSF,#-1	; met rapidement le noir !	LOAD.W	D2,#SETDOT	LIB	?DRRECT	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	CALL	DEGDEFTRAME	; dfinition de la trame	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; dessine un chantillon	INC.W	D1	JUMP	LOOP$EXIT$:	LIB	?COLORPOP	POPM.L	D1..D4	RET;------------\\; DEGDEFTRAME >;------------/; Choix d'une trame d'un dgrad.; in	D0.W	couleur de base (0..n);	D1.W	dgrad (0..n); out	-; mod	D7.WDEGDEFTRAME:	PUSHM.L	D1,A4	AND.L	D1,#H'FFFF	DIV.WU	D1,#DEGNBX	CLR.W	(A0)+ODFCCF+0	LOAD.W	(A0)+ODFCCF+2,D0	COMP.W	D1,D0	JUMP',LO START$	INC.W	D1START$:	CLR.W	(A0)+ODFCSF+0	LOAD.W	(A0)+ODFCSF+2,D1	LOAD.L	A4,#R16"TRAMES$	SWAP.W	D1	SL.W	D1,#3	LOAD.L	(A0)+ODFTRA+0,(A4)+(D1.W)+0	LOAD.L	(A0)+ODFTRA+4,(A4)+(D1.W)+4	POPM.L	D1,A4	RETTRAMES$:				; 0	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000				; 1	.B	B'10000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'10000000	.B	B'00000000	.B	B'00001000	.B	B'00000000				; 2	.B	B'10001000	.B	B'00000000	.B	B'00100010	.B	B'00000000	.B	B'10001000	.B	B'00000000	.B	B'00100010	.B	B'00000000				; 3	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010				; 4	.B	B'10101010	.B	B'01010101	.B	B'10101010	.B	B'01010101	.B	B'10101010	.B	B'01010101	.B	B'10101010	.B	B'01010101				; 5	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101				; 6	.B	B'01110111	.B	B'11111111	.B	B'11011101	.B	B'11111111	.B	B'01110111	.B	B'11111111	.B	B'11011101	.B	B'11111111				; 7	.B	B'01111111	.B	B'11111111	.B	B'11110111	.B	B'11111111	.B	B'01111111	.B	B'11111111	.B	B'11110111	.B	B'11111111				; 8	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.EVEN;----------\\; DEGCALCUL >;==========/; Calcule la couleur rsultante d'un dgrad.; in	D0.W	couleur de base (0..n);	D1.W	dgrad choisi (0..n); out	D3.W	rouge;	D4.W	vert;	D5.W	bleu; mod	D3.L, D4.L, D5.LDEGCALCUL:	PUSHM.L	D0..D2,D6,D7	AND.L	D1,#H'FFFF	DIV.WU	D1,#DEGNBX	COMP.W	D1,D0	JUMP',LO START$	INC.W	D1START$:	LOAD.L	D6,D1	LOAD.L	A4,(A0)+ODFCPF	MUL.WU	D0,#3	ADD.L	A4,D0	CLR.W	D0	LOAD.B	D0,(A4+)	; D0 <-- rouge dpart	CLR.W	D1	LOAD.B	D1,(A4+)	; D1 <-- vert dpart	CLR.W	D2	LOAD.B	D2,(A4+)	; D2 <-- bleu dpart	LOAD.L	A4,(A0)+ODFCPF	LOAD.W	D7,D6	MUL.WU	D7,#3	ADD.L	A4,D7	CLR.W	D3	LOAD.B	D3,(A4+)	; D3 <-- rouge arrive	CLR.W	D4	LOAD.B	D4,(A4+)	; D4 <-- vert arrive	CLR.W	D5	LOAD.B	D5,(A4+)	; D5 <-- bleu arrive	SWAP.W	D6		; D6 <-- 0..8	SL.W	D6,#1	LOAD.W	D6,(PC)+(D6.W)+FACT$	SUB.W	D3,D0	MUL.WA	D3,D6	DIV.WA	D3,#64	ADD.W	D3,D0		; D3 <-- rouge rsultant	SL.W	D3,#8	SUB.W	D4,D1	MUL.WA	D4,D6	DIV.WA	D4,#64	ADD.W	D4,D1		; D4 <-- vert rsultant	SL.W	D4,#8	SUB.W	D5,D2	MUL.WA	D5,D6	DIV.WA	D5,#64	ADD.W	D5,D2		; D5 <-- bleu rsultant	SL.W	D5,#8	POPM.L	D0..D2,D6,D7	RETFACT$:	.W	0,4,8,16,32,48,56,60,64;--------\\; DEGMOVE >;========/; Choix d'une couleur dans le dgrad.; in	D4.L	coordonne souris (y;x); out	D1.W	dgrad choisi (0..n);	D7.W	erreur; mod	D1.L, D7.WDEGMOVE:	PUSHM.L	D2..D4	CALL	DEGDET		; D1 <-- rang o est la souris	JUMP,NE EXIT$	CALL	DEGINV		; allume la premire	LOAD.W	D2,D1LOOP$:	LIB	?GETKEY		; attend dplacement ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	IFMOUSE	JUMP,NE LOOP$	CALL	DEGDET		; D1 <-- rang o est la sourisMOVE$:	COMP.W	D1,D2	JUMP,EQ LOOP$	EX.L	D1,D2	CALL	DEGINV		; teint l'ancienne	LOAD.W	D1,D2	CALL	DEGINV		; allume la nouvelle	JUMP	LOOP$END$:	CALL	DEGINV		; teint la dernire	LOAD.W	D7,#1	COMP.W	D1,#-1	JUMP',EQ EXIT$	CLR.W	D7EXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DEGDET  >;--------/; Dtecte o est la souris dans le dgrad.; in	D4.L	coordonne souris (y;x); out	D1.W	rang;	D7.W	erreur; mod	D1.L, D7.WDEGDET:	PUSHM.L	D2..D5	LOAD.L	D5,D4	CLR.W	D1	CLR.W	D7LOOP$:	CALL	DEGPOS	JUMP',NE ERROR$	LOAD.L	D2,D5	SUB.W	D2,D3	JUMP',LO NEXT$	COMP.W	D2,D4	JUMP',HS NEXT$	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SUB.W	D2,D3	JUMP',LO NEXT$	COMP.W	D2,D4	JUMP',LO EXIT$NEXT$:	INC.W	D1	JUMP	LOOP$ERROR$:	LOAD.W	D1,#-1	LOAD.W	D7,#1EXIT$:	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DEGINV  >;========/; Met en vidence une case de le dgrad.; in	D1.W	rang; out	-; mod	D7.WDEGINV:	PUSHM.L	D2..D4	COMP.W	D1,#-1	JUMP,EQ EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	DEGPOS	LOAD.W	D2,#INVDOT	PUSHM.L	D3,D4	SUB.W	D3,#LPALINV	ADD.W	D4,#LPALINV+LPALINV+1	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#LPALINV	LOAD.W	D4,#LPALINV+1	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; haut	POPM.L	D3,D4	PUSHM.L	D3,D4	SUB.W	D3,#LPALINV	LOAD.W	D4,#LPALINV+1	SWAP.W	D3	SWAP.W	D4	INC.W	D3	DEC.W	D4	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; gauche	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,D4	LOAD.W	D4,#LPALINV+1	SWAP.W	D3	SWAP.W	D4	INC.W	D3	DEC.W	D4	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; droite	POPM.L	D3,D4	PUSHM.L	D3,D4	SUB.W	D3,#LPALINV	ADD.W	D4,#LPALINV+LPALINV+1	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	LOAD.W	D4,#LPALINV+1	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; bas	POPM.L	D3,D4EXIT$:	POPM.L	D2..D4	RET;--------\\; DEGPOS  >;--------/; Donne la position et les dimensions d'une case du dgrad.; in	D1.W	rang; out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WDEGPOS:	PUSHM.L	D1,D2	LOAD.W	D7,#1	COMP.W	D1,#DEGNBX*DEGNBY	JUMP,HS EXIT$	AND.L	D1,#H'FFFF	DIV.WU	D1,#DEGNBX	CLR.L	D4	LOAD.W	D4,(A6)+OSLVAR+OSLDIM+0	ADD.W	D4,#5	DIV.WU	D4,#DEGNBY	LOAD.W	D3,D1	MUL.WU	D3,D4	ADD.W	D3,#30	SWAP.W	D3	SWAP.W	D4	CLR.L	D2	LOAD.W	D2,(A6)+OSLVAR+OSLDIM+0	DIV.WU	D2,#DEGNBX	LOAD.W	D4,D2	SWAP.W	D1	MUL.WU	D1,D2	ADD.W	D1,#240	LOAD.W	D3,D1	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET	.END