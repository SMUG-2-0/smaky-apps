	.TITLE	GRA.ASL;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------;	Source des modules *_GRA.LIB	.PROC	M680002		; mnmonics CALM-2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal	.REF	SM8		; df diverses	.REF	NTREL		; df noyau temps rel	.REF	GESMEM		; df gestionnaire de mmoire	.REF	DRIVERS		; df drivers	.REF	DOLIB		; df modules LIB	.REF	GRA		; df module GRA	.REV	3,0; Assemblage conditionnel; -----------------------	.REF	MACHINE	.IF	_SM324;;?COLOR	=	1		; ooooh !COLOR	=	0		; bh ...	.ELSECOLOR	=	0		; bh ...	.ENDIF; Date		Rev	Amliorations; ------------------------------------------------------------------------------------------------; 19.12.88	3.0	trame selon XTRAME (ODFTxx);			pinceau selon XPEN (ODFPxx);			traitill selon XMAPTT (ODFPTx); 16.11.88	2.5	GRA_DECOIMA correction effectue par DD; 28.10.88	2.4	GRA_TRAME origine trame ok si ODFFX pas modulo 8;			GRA_ELLIPSE ok avec clipping;			GRA_LINE clipping  ODFFDX/Y (et non ODFFDX/Y +1 !);			GRA_MATRIX idem;			GRA_HVDOT nouvel appel pour les grilles;			clipping si pinceau et INVDOT ok; 23.08.88	2.3	GRA_TRAME fait du clipping (toujours); 08.08.88	2.2	GRA_DECOIMA correction selon DD; 02.05.88	2.1	GRA_FILL peut aller jusque dans les bords (ODFFLG:#BFFILA);			GRA_RASTER entirement refait;			GRA_RASTER utilis pour caractres/scrolls/SAVWDO;			GRA_TRAME entirement refait;			GRA_TRAME utilis par GRA_CLEAR/SET/INV;			GRA_TRAME supporte le mode LOADDOT;			plus de modulo 8 en X ni de modulo 2 en Y !;			ATTENTION: Iy multiple de 16 conseill !;			masque coordonne pour 2048x2048 sur toutes les machines;			GRA_RASTER fait du clipping (super);			pinceau avec "vrai" clipping; 15.04.88	2.0	vive la couleur ...; 25.02.88	1.12	GRA_LINE ultra-rapide si horizontal sans pinceau (6x plus rapide);			GRA_LINE rapide si vertical sans pinceau (2x plus rapide); 18.01.88	1.11	GRA_TRAME  possible en mmoire;			GRA_CIRCLE possible en mmoire; 22.12.87	1.10	GRA_MATRIX possible en mmoire; 14.12.87	1.9	GRA_QIDOT ok si hauteur > 512; 20.11.87	1.8	.IF PLUSBIG report selon BB; 30.07.87	1.7	GRA_MATRIX avec "gris" et "invers" ok; 25.02.87	1.6	GRA_MATRIX avec "gris"; 24.09.86	1.5	GRA_SPRITE avec opration SPRITE_GETPOS; 03.07.86	1.4	GRA_CODEIMA et GRA_DECOIMA; 17.04.86	1.3	GRA_RASTER ok dans bitmap 1000x1000; 15.02.86	1.2	GRA_ROLLLEFT et GRA_ROLLRIGHT; 12.02.86	1.1	GRA_FILL possible en mmoire;			GRA_LINE possible en mmoire;			GRA_DOT  possible en mmoire;			GRA_RASTER optimis si tout est modulo 8; 13.01.86	1.0	GRA_FILL tout refait (9 x plus rapide);			GRA_TRAME tout refait (2 x plus rapide); Constantes; ----------LGPENX	=	8		; largeur max du pinceauLGPENY	=	8		; hauteur max du pinceau; Variables dans ODFVAR; ---------------------	.LOC	0OVARCTR:			; copie de la trame pour FILL (8 bytes)OVARIP:	.BLKB	(1+8+1)*2	; zone pour pinceau en mode inverseOVAROY:	.BLKB	2		; ancien pinceau yOVAROX:	.BLKB	2		; ancien pinceau xOVARSP:	.BLKB	4		; SP initial si erreur; En-tte d'un fichier .IMAGE; ---------------------------	.LOC	0OIMTYP:	.BLKB	1		; H'01 = indique type imageOIMCOD:	.BLKB	1		; H'00 = pas de codage, H'04 = codageOIMBIP:	.BLKB	1		; H'01 = 1 bit par pointOIMDIR:	.BLKB	1		; H'02 = coord. X-Y comme cranOIMDLX:	.BLKB	2		; largeur image en pointsOIMDLY:	.BLKB	2		; hauteur image en pointsOIMNBB:	.BLKB	4		; nb de byte pour l'image	.BLKB	20		; rserveLGHIMA:; Table pour un lutin; -------------------MAXLU	=	16		; nb max de lutins	.LOC	0OLUUSE:	.BLKB	1		; 0/1 => lutin libre/ocupOLUSET:	.BLKB	1		; 0/1 => lutin teint/allumOLUMSK:	.BLKB	1		; 0/1 => lutin ailleur/masqu	.EVENOLUNUM:	.BLKB	2		; numro du lutinOLUPTS:	.BLKB	4		; ^matrice du lutinOLUPTC:	.BLKB	4		; ^matrice du fondOLUPTF:	.BLKB	4		; ^fond de l'cranOLUPTO:	.BLKB	4		; ^pour oprationsOLUOLD:	.BLKB	4		; ancienne positionOLUNEW:	.BLKB	4		; nouvelle positionOLUORI:	.BLKB	4		; origine du mouvementOLULGY:	.BLKB	2		; hauteur du lutinOLULGX:	.BLKB	2		; largeur du lutinOLUIYF:	.BLKB	2		; Iy pour OLUPTFOLUIYO:	.BLKB	2		; Iy pour OLUPTO	.IF	COLOROLUBYF:	.BLKB	4		; By pour OLUPTFOLUBYO:	.BLKB	4		; By pour OLUPTO	.ENDIFLGLU:; En-tte du module LIB; ---------------------	.LOC	0	GRA_	FIRST		; code du premier appel	GRA_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	3,0		; rvision.version	.W	0,END_GRA	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"GRA"		; nom du module	.FILLB	(LGHLIB-.),0	.W	_GRA_RASTER	.W	_GRA_MATRIX	.W	_GRA_TRAME	.W	_GRA_ROLLUP	.W	_GRA_ROLLDOWN	.W	_GRA_CLEAR	.W	_GRA_LINE	.W	_GRA_CIRCLE	.W	_GRA_FILLO	.W	_GRA_FILLC	.W	_GRA_SPRITE	.W	_GRA_DOT	.W	_GRA_ELLIPSE	.W	_GRA_EFLI	.W	_GRA_EFEOS	.W	_GRA_INV	.W	_GRA_QIDOT	.W	_GRA_QXDOT	.W	_GRA_SET	.W	_GRA_ROLLLEFT	.W	_GRA_ROLLRIGHT	.W	_GRA_CODEIMA	.W	_GRA_DECOIMA	.W	_GRA_HVDOT	.INS	GRACODIMA.ASI	; codage/dcodage d'une image	.INS	GRARASTER.ASI	; raster-op gnral	.INS	GRAMATRIX.ASI	; caractres	.INS	GRATRAME.ASI	; trames	.INS	GRAMOVE.ASI	; dplacement de zones	.INS	GRALINE.ASI	; lignes droites	.INS	GRACIRCLE.ASI	; cercles et arcs	.INS	GRAFILL.ASI	; remplissage	.INS	GRASPRITE.ASI	; lutins	.INS	GRADOT.ASI	; traitement d'un point	.IF	COLOR	.INS	GRACOLOR.ASI	; gestion de la couleur	.ENDIFEND_GRA:	.END