	.SBTTL	TCOLCRET.ASI;---------------\\; _TCOL_LOADCRET >;===============/; Charge une table des couleurs relatives (CRET).; in	D6.L	canal;	D3.L	mode (BTC*);		 BTCTABLE --> donne une table;		 BTCNAME  --> donne un nom de fichier;		 BTCCHFOS --> donne un canal FOS;	A3.L	^table (si D3:#BTCTABLE);	A3.L	^nom (si D3:#BTCNAME);	D4.W	canal FOS (si D3:#BTCCHFOS); out	D5.L	identificateur de CRET;	D7.W	erreur; mod	D5.L, D7.W_TCOL_LOADCRET:	PUSHM.L	D1..D4,D6,A1..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	D2,D3		; D2 <-- mode	LOAD.B	D1,#CRTYPE	; D1 <-- type attendu (CRET)	TEST.L	D2:#BTCTABLE	JUMP',BS TABLE$	TEST.L	D2:#BTCNAME	JUMP',BS NAME$	TEST.L	D2:#BTCCHFOS	JUMP',BS CHFOS$	LOAD.W	D7,#ERTCMODE	; D7 <-- mode incorrect	JUMP'	EXIT$TABLE$:	CALL	TABMLOAD	; A4 <-- ^table lue	JUMP',NE EXIT$	JUMP'	PUT$NAME$:	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE EXIT$	CALL	CRETFLOAD	; A4 <-- ^table lue	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	JUMP',NE EXIT$	JUMP'	PUT$CHFOS$:	LOAD.W	D6,D4		; D6 <-- canal FOS	CALL	CRETFLOAD	; A4 <-- ^table lue	JUMP',NE EXIT$PUT$:	LOAD.L	D5,A4		; D5 <-- identificateur de CRET	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,D6,A1..A6	TEST.W	D7		; retour EQ/NE	RET;----------\\; CRETFLOAD >;----------/; Charge une CRET. Si le fichier commence par une CLUT, celle-ci est; d'abord charge.; in	D6.W	canal FOS;	D2.L	mode; out	A4.L	^table;	D7.W	erreur; mod	D7.W, A4.LCRETFLOAD:	PUSH.W	D1	LOAD.B	D1,#CRTYPE	; D1 <-- type attendu (CRET)	CALL	TABFLOAD	; A4 <-- ^table lue	JUMP',EQ EXIT$	COMP.W	D7,#ERTCTYPE	; type incorrect ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.B	D1,#CLTYPE	; D1 <-- type attendu (CLUT)	CALL	TABFLOAD	; A4 <-- ^table lue	JUMP',NE EXIT$	CALL	CLUTMEM		; mmorise la nouvelle CLUT	LOAD.B	D1,#CRTYPE	; D1 <-- type attendu (CRET)	CALL	TABFLOAD	; A4 <-- ^table lueEXIT$:	POP.W	D1	TEST.W	D7		; retour EQ/NE	RET;---------------\\; _TCOL_SAVECRET >;===============/; Sauve une table des couleurs relatives (CRET).; in	D6.L	canal;	D5.L	identificateur de CRET;	D3.L	mode (BTC*);		 BTCTABLE --> donne une table;		 BTCNAME  --> donne un nom de fichier;		 BTCCHFOS --> donne un canal FOS;	A3.L	^buffer (si D3:#BTCTABLE);	A3.L	^nom (si D3:#BTCNAME);	D4.W	canal FOS (si D3:#BTCCHFOS); out	(A3)+	table;	D7.W	erreur; mod	D7.W_TCOL_SAVECRET:	PUSHM.L	D2..D4,D6,A2..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	D2,D3		; D2 <-- mode	LOAD.L	A4,D5		; A4 <-- ^CRET	TEST.L	D2:#BTCTABLE	JUMP',BS TABLE$	TEST.L	D2:#BTCNAME	JUMP',BS NAME$	TEST.L	D2:#BTCCHFOS	JUMP',BS CHFOS$ERROR$:	LOAD.W	D7,#ERTCMODE	; D7 <-- mode incorrect	JUMP'	EXIT$TABLE$:	CALL	TABMSAVE	; sauve la table	JUMP'	EXIT$NAME$:	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE EXIT$	CALL	TABFSAVE	; sauve la table	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	JUMP'	EXIT$CHFOS$:	LOAD.W	D6,D4		; D6 <-- canal FOS	CALL	TABFSAVE	; sauve la table;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4,D6,A2..A6	TEST.W	D7		; retour EQ/NE	RET;---------------\\; _TCOL_KILLCRET >;===============/; Libre une table des couleurs relatives (CRET).; in	D6.L	canal;	D5.L	identificateur de CRET;	D3.L	mode (zro); out	-; mod	D7.W_TCOL_KILLCRET:	PUSHM.L	A4..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	A4,D5		; A4 <-- ^CRET	CALL	TABKILL		; libre la CRET	POPM.L	A4..A6	RET;--------------\\; _TCOL_ADDCRET >;==============/; Donne une nouvelle CRET dans la liste courante.; in	D6.L	canal;	D5.L	identificateur de CRET;	D3.L	mode (BTC*);		 BTCGLOB --> si CRET globale; out	D7.W	erreur; mod	D7.W_TCOL_ADDCRET:	PUSHM.L	D2,D4,A4..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	D2,D3		; D2 <-- mode	LOAD.L	A4,#(A5)+OLPCRET ; A4 <-- ^liste des CRETs locales	LOAD.W	D4,#MAXLCRET-1	TEST.L	D2:#BTCGLOB	JUMP',BC LOCAL$	LOAD.L	A4,#(A6)+OGPCRET ; A4 <-- ^liste des CRETs globales	LOAD.W	D4,#MAXGCRET-1LOCAL$:LOOP$:	TEST.L	(A4+)		; emplacement libre ?	JUMP',EQ ADD$		; oui => ADD$	DECJ.W,NMO D4,LOOP$	LOAD.W	D7,#ERTCFULL	; D7 <-- y'a plus d'place	JUMP'	EXIT$ADD$:	LOAD.L	(-A4),D5	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D4,A4..A6	TEST.W	D7		; retour EQ/NE	RET;--------------\\; _TCOL_SUBCRET >;==============/; Enlve une CRET de la liste courante.; in	D6.L	canal;	D5.L	identificateur de CRET;	D3.L	mode (BTC*);		 BTCGLOB --> si CRET globale; out	D7.W	erreur; mod	D7.W_TCOL_SUBCRET:	PUSHM.L	D2,D4,A4..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	D2,D3		; D2 <-- mode	LOAD.L	A4,#(A5)+OLPCRET ; A4 <-- ^liste des CRETs locales	LOAD.W	D4,#MAXLCRET-1	TEST.L	D2:#BTCGLOB	JUMP',BC LOCAL$	LOAD.L	A4,#(A6)+OGPCRET ; A4 <-- ^liste des CRETs globales	LOAD.W	D4,#MAXGCRET-1LOCAL$:LOOP$:	COMP.L	D5,(A4+)	; CRET utilise ici ?	JUMP',EQ SUB$		; oui => SUB$	DECJ.W,NMO D4,LOOP$	LOAD.W	D7,#ERTCQQ	; D7 <-- CRET pas trouve	JUMP'	EXIT$SUB$:	CLR.L	(-A4)		; libre l'emplacement	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D4,A4..A6	TEST.W	D7		; retour EQ/NE	RET;--------------\\; _TCOL_SRCCRET >;==============/; Cherche une couleur relative.; in	D6.L	canal;	D3.L	mode (BTC*);		 BTCGIVE --> pour obtenir la couleur relle;	D4.L	numro de la couleur relative;	A4.L	^buffer pour couleur nomme (RGB);	A3.L	^buffer pour couleur relle (si D3:#BTCGIVE); out	(A4)+	RGB nomm;	(A3)+	RGB exact (si D3:#BTCGIVE);	D4.L	couleur de la palette (si D3:#BTCGIVE);	D7.W	erreur; mod	D4.L, D7.W_TCOL_SRCCRET:	PUSHM.L	D1..D3,A0..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	A0,A4		; A0 <-- ^buffer nomm	LOAD.L	A2,A3		; A2 <-- ^buffer rel	LOAD.L	D2,D3		; D2 <-- mode	LOAD.L	D3,D4		; D3 <-- nom cherch	LOAD.L	A1,#(A5)+OLPCRET ; A1 <-- ^liste des CRETs locales	LOAD.W	D1,#MAXLCRET-1LLOOP$:	TEST.L	(A1)		; CRET existe ?	JUMP',EQ LNEXT$		; non => LNEXT$	LOAD.L	A4,(A1)		; A4 <-- ^CRET	CALL	TABSRCN		; D4/A3 <-- index/RGB	JUMP',EQ FOUND$LNEXT$:	ADD.L	A1,#4		; A1 <-- ^^CRET suivante	DECJ.W,NMO D1,LLOOP$	LOAD.L	A1,#(A6)+OGPCRET ; A1 <-- ^liste des CRETs globales	LOAD.W	D1,#MAXGCRET-1GLOOP$:	TEST.L	(A1)		; CRET existe ?	JUMP',EQ GNEXT$		; non => GNEXT$	LOAD.L	A4,(A1)		; A4 <-- ^CRET	CALL	TABSRCN		; D4/A3 <-- index/RGB	JUMP',EQ FOUND$GNEXT$:	ADD.L	A1,#4		; A1 <-- ^^CRET suivante	DECJ.W,NMO D1,GLOOP$	LOAD.W	D7,#ERTCCDNE	; D7 <-- couleur n'existe pas	JUMP'	EXIT$FOUND$:	LOAD.W	(A0+),(A3+)	; buffer nomm <-- rouge	LOAD.W	(A0+),(A3+)	; buffer nomm <-- vert	LOAD.W	(A0+),(A3+)	; buffer nomm <-- bleu	TEST.L	D2:#BTCGIVE	JUMP',BC OK$	LOAD.L	A3,#(A3)-LTCC	; A3 <-- ^couleur cherche	LOAD.L	A4,(A5)+OLPCLUT	; A4 <-- ^CLUT locale	LOAD.L	D1,A4	JUMP',NE SRC$	LOAD.L	A4,(A6)+OGPCLUT	; A4 <-- ^CLUT globaleSRC$:	CALL	TABSRCCA	; D3/D4/A3 <-- nom/index/RGB approximatif	JUMP',NE EXIT$	LOAD.L	D4,D3		; D4 <-- couleur de la palette	LOAD.W	(A2+),(A3+)	; buffer rel <-- rouge	LOAD.W	(A2+),(A3+)	; buffer rel <-- vert	LOAD.W	(A2+),(A3+)	; buffer rel <-- bleuOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D3,A0..A6	TEST.W	D7		; retour EQ/NE	RET;--------------\\; _TCOL_PUTCRET >;==============/; Ajoute ou modifie une couleur relative.; in	D6.L	canal;	D5.L	identificateur de CRET;	D3.L	mode (zro);	D4.L	numro de la couleur relative;	A4.L	^nouvelle couleur (RGB); out	D5.L	identificateur de CRET (!);	D7.W	erreur; mod	D5.L, D7.W_TCOL_PUTCRET:	PUSHM.L	D3,D4,A1..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	A2,A4		; A2 <-- ^nouvelle couleur	LOAD.L	A4,D5		; A4 <-- ^CRET	LOAD.L	D3,D4		; D3 <-- nom	CALL	TABSRCN		; D4/A3 <-- index/^RGB	JUMP',NE NEW$	LOAD.L	A3,A2		; A3 <-- ^nouvelle couleur	CALL	TABREPL		; remplace dans la table	JUMP'	OK$NEW$:	LOAD.L	A3,A2		; A3 <-- ^nouvelle couleur	LOAD.L	D4,D3	CALL	TABADD		; ajoute dans la table	JUMP,NE EXIT$	COMP.L	A4,D5		; CRET dplace en mmoire ?	JUMP',EQ OK$		; non => OK$	LOAD.L	A1,#(A5)+OLPCRET ; A1 <-- ^liste des CRETs locales	LOAD.W	D1,#MAXLCRET-1LLOOP$:	COMP.L	D5,(A1+)	JUMP',NE LNEXT$	LOAD.L	(A1)-4,A4LNEXT$:	DECJ.W,NMO D1,LLOOP$	LOAD.L	A1,#(A6)+OGPCRET ; A1 <-- ^liste des CRETs globales	LOAD.W	D1,#MAXGCRET-1GLOOP$:	COMP.L	D5,(A1+)	JUMP',NE GNEXT$	LOAD.L	(A1)-4,A4GNEXT$:	DECJ.W,NMO D1,GLOOP$	LOAD.L	D5,A4		; D5 <-- identificateur de la CRETOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A1..A6	TEST.W	D7		; retour EQ/NE	RET;--------------\\; _TCOL_DELCRET >;==============/; Supprime une couleur relative.; in	D6.L	canal;	D5.L	identificateur de CRET;	D3.L	mode (zro);	D4.L	numro de la couleur relative; out	D7.W	erreur; mod	D7.W_TCOL_DELCRET:	PUSHM.L	D3,D4,A3..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	A4,D5		; A4 <-- ^CRET	LOAD.L	D3,D4		; D3 <-- nom	CALL	TABSRCN		; D4/A3 <-- index/^RGB	JUMP',NE EXIT$	CALL	TABSUB		; enlve de la tableEXIT$:	POPM.L	D3,D4,A3..A6	TEST.W	D7		; retour EQ/NE	RET;---------------\\; _TCOL_LISTCRET >;===============/; Donne la liste de tous les identificateurs de CRET utiliss.; in	D6.L	canal;	D3.L	mode (zro);	A4.L	^buffer;	D4.L	lg max buffer; out	(A4)++	identificateurs (.L), termins par zro;	D7.W	erreur; mod	D7.W_TCOL_LISTCRET:	PUSHM.L	D3,D4,A3..A5	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.W	D7,#ERTCFULL	; D7 <-- table pleine	LOAD.L	A3,#(A5)+OLPCRET ; A3 <-- ^liste des CRETs locales	LOAD.W	D3,#MAXLCRET-1LOOP$:	TEST.L	(A3+)		; emplacement libre ?	JUMP',EQ NEXT$		; oui => NEXT$	SUB.L	D4,#4	JUMP',LE EXIT$	LOAD.L	(A4+),(A3)-4	; buffer <-- identificateurNEXT$:	DECJ.W,NMO D3,LOOP$	SUB.L	D4,#4	JUMP',LE EXIT$	CLR.L	(A4+)		; buffer <-- terminateur	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A3..A5	TEST.W	D7		; retour EQ/NE	RET	.END