	.SBTTL	ICOLCHOIX.ASI;--------\\; RGBCPUT >;========/; Donne les trois couleurs aux trois ascenseurs.; in	(A6)+OCOL[R,G,B]; out	-; mod	D7.WRGBCPUT:	PUSH.W	D3	LOAD.W	D3,(A6)+OCOLR	SR.W	D3,#8	LOAD.W	(A6)+OSCVAR+(LSCVAR*0)+OSCPOSV,D3	LOAD.W	D3,(A6)+OCOLG	SR.W	D3,#8	LOAD.W	(A6)+OSCVAR+(LSCVAR*1)+OSCPOSV,D3	LOAD.W	D3,(A6)+OCOLB	SR.W	D3,#8	LOAD.W	(A6)+OSCVAR+(LSCVAR*2)+OSCPOSV,D3	POP.W	D3	RET;--------\\; RGBCGET >;========/; Prend les trois couleurs des trois ascenseurs.; in	-; out	(A6)+OCOL[R,G,B]; mod	D7.WRGBCGET:	LOAD.B	(A6)+OCOLR+0,(A6)+OSCVAR+(LSCVAR*0)+OSCPOSV+1	LOAD.B	(A6)+OCOLR+1,(A6)+OSCVAR+(LSCVAR*0)+OSCPOSV+1	LOAD.B	(A6)+OCOLG+0,(A6)+OSCVAR+(LSCVAR*1)+OSCPOSV+1	LOAD.B	(A6)+OCOLG+1,(A6)+OSCVAR+(LSCVAR*1)+OSCPOSV+1	LOAD.B	(A6)+OCOLB+0,(A6)+OSCVAR+(LSCVAR*2)+OSCPOSV+1	LOAD.B	(A6)+OCOLB+1,(A6)+OSCVAR+(LSCVAR*2)+OSCPOSV+1	RET;---------\\; RGBDRAWS >;=========/; Dessine les trois ascenseurs.; in	-; out	-; mod	D7.WRGBDRAWS:	PUSH.L	D1	CLR.W	D1LOOP$:	CALL	RGBDRAW	INC.W	D1	COMP.W	D1,#3	JUMP,LO LOOP$	POP.L	D1	RET;--------\\; RGBDRAW >;--------/; Dessine l'un des trois ascenseur.; in	D1.W	numro de l'ascenseur (0..2); out	-; mod	D7.WRGBDRAW:	PUSHM.L	D3,D4,A3..A5	CALL	RGBOPEN		; ascenseur: met les couleurs spciales	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D4,D1	MUL.WU	D4,#LSCVAR	ADD.L	A5,D4	LOAD.W	(A5)+OSCDEBO,(A6)+OCURPY	LOAD.W	D4,#26	MUL.WU	D4,D1	ADD.W	D4,(A6)+OCURPX	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	(A5)+OSCHTR,#194	SCROLL_	DRAW	COMP.W	D1,#2	JUMP,NE EXIT$	LOAD.W	D3,#10	LOAD.W	D4,#12	LOAD.L	A3,#R16"TEXT$	SCROLL_	SCALEEXIT$:	CALL	RGBCLOSE	; ascenseur: remet les couleurs normales	LOAD.L	A3,#R16"HELPR$	TEST.W	D1	JUMP',EQ HELP$	LOAD.L	A3,#R16"HELPG$	COMP.W	D1,#1	JUMP',EQ HELP$	LOAD.L	A3,#R16"HELPB$HELP$:	LOAD.W	D3,(A5)+OSCDEBO	SUB.W	D3,#8	SWAP.W	D3	LOAD.W	D3,(A5)+OSCDEBL	SUB.W	D3,#5	LIB	?SETCURS	LIB	?AFTEXT	POPM.L	D3,D4,A3..A5	RETTEXT$:	.ASCIZ	"fonc"	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	"moyen"	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	"clair"HELPR$:	.ASCIZ	" R "HELPG$:	.ASCIZ	" V "HELPB$:	.ASCIZ	" B "	.EVEN;-----------\\; RGBUPDATES >;===========/; Met  jour les trois ascenseurs.; in	-; out	-; mod	D7.WRGBUPDATES:	PUSHM.L	D1	CLR.W	D1LOOP$:	CALL	RGBUPDATE	; met  jour un ascenseur	INC.W	D1	COMP.W	D1,#3	JUMP,LO LOOP$	POPM.L	D1	RET;----------\\; RGBUPDATE >;----------/; Met  jour un ascenseur.; in	D1.W	numro de l'ascenseur (0..2); out	-; mod	D7.WRGBUPDATE:	PUSHM.L	D4,A5	CALL	RGBOPEN		; ascenseur: met les couleurs spciales	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D4,D1	MUL.WU	D4,#LSCVAR	ADD.L	A5,D4	LOAD.W	(A5)+OSCHTV,#256	LOAD.W	(A5)+OSCINC,#256/32	SET.B	(A5)+OSCMARK	SCROLL_	UPDATE	CALL	RGBCLOSE	; ascenseur: remet les couleurs normales	POPM.L	D4,A5	RET;---------\\; RGBMOVES >;=========/; Dplace l'un des trois ascenseurs.; in	D4.L	position de la souris;	A1.L	^routine mj.; out	D7.W	ok/erreur; mod	D7.WRGBMOVES:	PUSH.L	D1	CLR.W	D1LOOP$:	CALL	RGBMOVE		; dplace un ascenseur ?	JUMP',EQ EXIT$	INC.W	D1	COMP.W	D1,#3	JUMP,LO LOOP$EXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGBMOVE >;--------/; Dplace l'un des trois ascenseur.; in	D1.W	numro de l'ascenseur (0..2);	A1.L	^routine mj.;	D4.L	position de la souris; out	D7.W	ok/erreur; mod	D7.WRGBMOVE:	PUSHM.L	D2,D3,D4,D5,A5	CALL	RGBOPEN		; ascenseur: met les couleurs spciales	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D3,D1	MUL.WU	D3,#LSCVAR	ADD.L	A5,D3	SCROLL_	MOVE	JUMP,NE EXIT$	LOAD.W	D2,#-10	COMP.W	D4,#SCROLLFUP	JUMP',EQ INIT$	NEG.W	D2	COMP.W	D4,#SCROLLFDOWN	JUMP,NE OK$INIT$:	SCROLL_	PRESSLOOP$:	LIB	?IFCAR		; vnement ?	JUMP',NE MOVE$	COMP.W	D3,#KEYMGR	JUMP',EQ CLOSE$	COMP.W	D3,#KEYMMR	JUMP',EQ CLOSE$	COMP.W	D3,#KEYMDR	JUMP',EQ CLOSE$MOVE$:	LOAD.W	D5,(A5)+OSCPOSV	ADD.W	D5,D2	JUMP',NC MIN$	CLR.W	D5MIN$:	COMP.W	D5,(A5)+OSCHTV	JUMP',LO MAX$	LOAD.W	D5,(A5)+OSCHTV	DEC.W	D5MAX$:	LOAD.W	(A5)+OSCPOSV,D5	SCROLL_	UPDATE	CALL	(A1)		; mj. qq chose	PUSH.W	D4	LOAD.W	D4,#50/10	NTREL	?DELMS		; attend un poil ...	POP.W	D4	JUMP	LOOP$CLOSE$:	SCROLL_	PRESSOK$:	CALL	(A1)		; mj. qq chose	CLR.W	D7EXIT$:	CALL	RGBCLOSE	; ascenseur: remet les couleurs normales	POPM.L	D2,D3,D4,D5,A5	TEST.W	D7	RET;--------\\; RGBOPEN >;--------/; Ascenseur: met les couleurs spciales.; in	D1.W	numro de l'ascenseur (0..2); out	-; mod	D7.WRGBOPEN:	PUSHM.L	D1,D3,D5,D6,A3	LOAD.L	A3,#R16"TCRETR$	; A3 <-- ^CRET pour ascenseur rouge	DEC.W	D1	JUMP',NS CHANGE$	LOAD.L	A3,#R16"TCRETG$	; A3 <-- ^CRET pour ascenseur vert	DEC.W	D1	JUMP',NS CHANGE$	LOAD.L	A3,#R16"TCRETB$	; A3 <-- ^CRET pour ascenseur bleuCHANGE$:	LOAD.L	D3,#2^BTCTABLE	; D3 <-- mode (toujours local !)	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	LOADCRET	; D5 <-- identificateur CRET	JUMP',NE EXIT$	CLR.L	D3		; D3 <-- mode;	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	ADDCRET		; rend la CRET active	LOAD.L	(A6)+OIDCRET,D5EXIT$:	POPM.L	D1,D3,D5,D6,A3	RETTCRETR$:	.B	CRTYPE,0		; type CRET	.L	10*4			; lg des couleurs	.W	4			; nb de couleurs	.FILLB	24,0			; reste de l'en-tte	.W	0,COLOR_SCCLEAR,-1,0,0	; fond: rouge	.W	0,COLOR_SCSET,0,0,0	; contenu: noir	.W	0,COLOR_SCOBJ,0,0,0	; flches: noir	.W	0,COLOR_SCPOS,-1,-1,-1	; cabine: blancTCRETG$:	.B	CRTYPE,0		; type CRET	.L	10*4			; lg des couleurs	.W	4			; nb de couleurs	.FILLB	24,0			; reste de l'en-tte	.W	0,COLOR_SCCLEAR,0,-1,0	; fond: vert	.W	0,COLOR_SCSET,0,0,0	; contenu: noir	.W	0,COLOR_SCOBJ,0,0,0	; flches: noir	.W	0,COLOR_SCPOS,-1,-1,-1	; cabine: blancTCRETB$:	.B	CRTYPE,0		; type CRET	.L	10*4			; lg des couleurs	.W	4			; nb de couleurs	.FILLB	24,0			; reste de l'en-tte	.W	0,COLOR_SCCLEAR,0,0,-1	; fond: bleu	.W	0,COLOR_SCSET,0,0,0	; contenu: noir	.W	0,COLOR_SCOBJ,0,0,0	; flches: noir	.W	0,COLOR_SCPOS,-1,-1,-1	; cabine: blanc;---------\\; RGBCLOSE >;---------/; Ascenseur: remet les couleurs normales.; in	-; out	-; mod	-RGBCLOSE:	PUSHM.L	D3,D5..D7	LOAD.L	D5,(A6)+OIDCRET	; D5 <-- identificateur CRET	JUMP',EQ EXIT$	CLR.L	D3		; D3 <-- mode	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	SUBCRET		; dsactive la CRET;	CLR.L	D3		; D3 <-- mode;	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	KILLCRET	; libre la CRET	CLR.L	(A6)+OIDCRET	; y'a plus de CRET temporaireEXIT$:	POPM.L	D3,D5..D7	RET;--------\\; HSVCPUT >;========/; Donne les trois couleurs aux trois ascenseurs.; in	(A6)+OCOL[R,G,B]; out	-; mod	D7.WHSVCPUT:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OCOLR	LOAD.L	A3,#(A6)+OBUDIS	CALL	_ICOL_RGBHSV	LOAD.W	(A6)+OSCVAR+(LSCVAR*0)+OSCPOSV,(A3+)	LOAD.W	(A6)+OSCVAR+(LSCVAR*1)+OSCPOSV,(A3+)	LOAD.W	(A6)+OSCVAR+(LSCVAR*2)+OSCPOSV,(A3+)	POPM.L	A3,A4	RET;--------\\; HSVCGET >;========/; Prend les trois couleurs des trois ascenseurs.; in	-; out	(A6)+OCOL[R,G,B]; mod	D7.WHSVCGET:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	(A4)+0,(A6)+OSCVAR+(LSCVAR*0)+OSCPOSV	LOAD.W	(A4)+2,(A6)+OSCVAR+(LSCVAR*1)+OSCPOSV	LOAD.W	(A4)+4,(A6)+OSCVAR+(LSCVAR*2)+OSCPOSV	LOAD.L	A3,#(A6)+OCOLR	CALL	_ICOL_HSVRGB	POPM.L	A3,A4	RET;---------\\; HSVDRAWS >;=========/; Dessine les trois ascenseurs.; in	-; out	-; mod	D7.WHSVDRAWS:	PUSH.L	D1	CLR.W	D1LOOP$:	CALL	HSVDRAW	INC.W	D1	COMP.W	D1,#3	JUMP,LO LOOP$	POP.L	D1	RET;--------\\; HSVDRAW >;--------/; Dessine l'un des trois ascenseur.; in	D1.W	numro de l'ascenseur (0..2); out	-; mod	D7.WHSVDRAW:	PUSHM.L	D3,D4,A3..A5	CALL	HSVOPEN		; ascenseur: met les couleurs spciales	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D4,D1	MUL.WU	D4,#LSCVAR	ADD.L	A5,D4	LOAD.W	(A5)+OSCDEBO,(A6)+OCURPY	CLR.W	D4	TEST.W	D1	JUMP',EQ POSX$	LOAD.W	D4,#56	COMP.W	D1,#1	JUMP',EQ POSX$	LOAD.W	D4,#96POSX$:	ADD.W	D4,(A6)+OCURPX	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	(A5)+OSCHTR,#194	SCROLL_	DRAW	LOAD.L	A3,#R16"TEXTH$	LOAD.L	A4,#R16"HELPH$	TEST.W	D1	JUMP',EQ SCALE$	LOAD.L	A3,#R16"TEXTS$	LOAD.L	A4,#R16"HELPS$	COMP.W	D1,#1	JUMP',EQ SCALE$	LOAD.L	A3,#R16"TEXTV$	LOAD.L	A4,#R16"HELPV$SCALE$:	LOAD.W	D3,#6		; D3 <-- nb de divisions	LOAD.W	D4,#8		; D4 <-- lg divisions	SCROLL_	SCALE	CALL	HSVCLOSE	; ascenseur: remet les couleurs normales	LOAD.W	D3,(A5)+OSCDEBO	SUB.W	D3,#8	SWAP.W	D3	LOAD.W	D3,(A5)+OSCDEBL	SUB.W	D3,#8+5	LIB	?SETCURS	LOAD.L	A3,A4	LIB	?AFTEXT	POPM.L	D3,D4,A3..A5	RETTEXTH$:	.ASCIZ	"Rou"	.ASCIZ	"Jau"	.ASCIZ	"Ver"	.ASCIZ	"Cya"	.ASCIZ	"Ble"	.ASCIZ	"Mag"	.ASCIZ	"Rou"TEXTS$:	.ASCIZ	"B"	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	"T"TEXTV$:	.ASCIZ	"N"	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	"T"HELPH$:	.ASCIZ	"Teinte"HELPS$:	.ASCIZ	" Sat."HELPV$:	.ASCIZ	" Int."	.EVEN;-----------\\; HSVUPDATES >;===========/; Met  jour les trois ascenseurs.; in	-; out	-; mod	D7.WHSVUPDATES:	PUSHM.L	D1	CLR.W	D1LOOP$:	CALL	HSVUPDATE	; met  jour un ascenseur	INC.W	D1	COMP.W	D1,#3	JUMP,LO LOOP$	POPM.L	D1	RET;----------\\; HSVUPDATE >;----------/; Met  jour un ascenseur.; in	D1.W	numro de l'ascenseur (0..2); out	-; mod	D7.WHSVUPDATE:	PUSHM.L	D4,A5	CALL	HSVOPEN		; ascenseur: met les couleurs spciales	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D4,D1	MUL.WU	D4,#LSCVAR	ADD.L	A5,D4	LOAD.W	(A5)+OSCHTV,#360	LOAD.W	(A5)+OSCINC,#360/60	TEST.W	D1	JUMP',EQ UPD$	LOAD.W	(A5)+OSCHTV,#256	LOAD.W	(A5)+OSCINC,#256/32UPD$:	SET.B	(A5)+OSCMARK	SCROLL_	UPDATE	CALL	HSVCLOSE	; ascenseur: remet les couleurs normales	POPM.L	D4,A5	RET;---------\\; HSVMOVES >;=========/; Dplace l'un des trois ascenseurs.; in	D4.L	position de la souris;	A1.L	^routine mj.; out	D7.W	ok/erreur; mod	D7.WHSVMOVES:	PUSH.L	D1	CLR.W	D1LOOP$:	CALL	HSVMOVE		; dplace un ascenseur ?	JUMP',EQ EXIT$	INC.W	D1	COMP.W	D1,#3	JUMP,LO LOOP$EXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;--------\\; HSVMOVE >;--------/; Dplace l'un des trois ascenseur.; in	D1.W	numro de l'ascenseur (0..2);	A1.L	^routine mj.;	D4.L	position de la souris; out	D7.W	ok/erreur; mod	D7.WHSVMOVE:	PUSHM.L	D2,D3,D4,D5,A5	CALL	HSVOPEN		; ascenseur: met les couleurs spciales	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D3,D1	MUL.WU	D3,#LSCVAR	ADD.L	A5,D3	SCROLL_	MOVE	JUMP,NE EXIT$	LOAD.W	D2,#-10	COMP.W	D4,#SCROLLFUP	JUMP',EQ INIT$	NEG.W	D2	COMP.W	D4,#SCROLLFDOWN	JUMP,NE OK$INIT$:	SCROLL_	PRESSLOOP$:	LIB	?IFCAR		; vnement ?	JUMP',NE MOVE$	COMP.W	D3,#KEYMGR	JUMP',EQ CLOSE$	COMP.W	D3,#KEYMMR	JUMP',EQ CLOSE$	COMP.W	D3,#KEYMDR	JUMP',EQ CLOSE$MOVE$:	LOAD.W	D5,(A5)+OSCPOSV	ADD.W	D5,D2	JUMP',NC MIN$	CLR.W	D5MIN$:	COMP.W	D5,(A5)+OSCHTV	JUMP',LO MAX$	LOAD.W	D5,(A5)+OSCHTV	DEC.W	D5MAX$:	LOAD.W	(A5)+OSCPOSV,D5	SCROLL_	UPDATE	CALL	(A1)		; mj. qq chose	PUSH.W	D4	LOAD.W	D4,#50/10	NTREL	?DELMS		; attend un poil ...	POP.W	D4	JUMP	LOOP$CLOSE$:	SCROLL_	PRESSOK$:	CALL	(A1)		; mj. qq chose	CLR.W	D7EXIT$:	CALL	HSVCLOSE	; ascenseur: remet les couleurs normales	POPM.L	D2,D3,D4,D5,A5	TEST.W	D7	RET;--------\\; HSVOPEN >;--------/; Ascenseur: met les couleurs spciales.; in	D1.W	numro de l'ascenseur (0..2); out	-; mod	D7.WHSVOPEN:	PUSHM.L	D1,D3,D5,D6,A3	LOAD.L	A3,#R16"TCRETR$	; A3 <-- ^CRET pour ascenseur rouge	DEC.W	D1	JUMP',NS CHANGE$	LOAD.L	A3,#R16"TCRETG$	; A3 <-- ^CRET pour ascenseur vert	DEC.W	D1	JUMP',NS CHANGE$	LOAD.L	A3,#R16"TCRETB$	; A3 <-- ^CRET pour ascenseur bleuCHANGE$:	LOAD.L	D3,#2^BTCTABLE	; D3 <-- mode (toujours local !)	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	LOADCRET	; D5 <-- identificateur CRET	JUMP',NE EXIT$	CLR.L	D3		; D3 <-- mode;	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	ADDCRET		; rend la CRET active	LOAD.L	(A6)+OIDCRET,D5EXIT$:	POPM.L	D1,D3,D5,D6,A3	RETTCRETR$:	.B	CRTYPE,0		; type CRET	.L	10*4			; lg des couleurs	.W	4			; nb de couleurs	.FILLB	24,0			; reste de l'en-tte	.W	0,COLOR_SCCLEAR,0,-1,-1	; fond: cyan	.W	0,COLOR_SCSET,0,0,-1	; contenu: bleu	.W	0,COLOR_SCOBJ,-1,-1,0	; flches: jaune	.W	0,COLOR_SCPOS,-1,0,-1	; cabine: magentaTCRETG$:	.B	CRTYPE,0		; type CRET	.L	10*4			; lg des couleurs	.W	4			; nb de couleurs	.FILLB	24,0			; reste de l'en-tte	.W	0,COLOR_SCCLEAR,-1,-1,-1; fond: blanc	.W	0,COLOR_SCSET,0,0,0	; contenu: noir	.W	0,COLOR_SCOBJ,0,0,0	; flches: noir	.W	0,COLOR_SCPOS,-1,-1,-1	; cabine: blancTCRETB$:	.B	CRTYPE,0		; type CRET	.L	10*4			; lg des couleurs	.W	4			; nb de couleurs	.FILLB	24,0			; reste de l'en-tte	.W	0,COLOR_SCCLEAR,0,0,0	; fond: noir	.W	0,COLOR_SCSET,0,0,0	; contenu: noir	.W	0,COLOR_SCOBJ,-1,-1,-1	; flches: blanc	.W	0,COLOR_SCPOS,-1,-1,-1	; cabine: blanc;---------\\; HSVCLOSE >;---------/; Ascenseur: remet les couleurs normales.; in	-; out	-; mod	-HSVCLOSE:	PUSHM.L	D3,D5..D7	LOAD.L	D5,(A6)+OIDCRET	; D5 <-- identificateur CRET	JUMP',EQ EXIT$	CLR.L	D3		; D3 <-- mode	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	SUBCRET		; dsactive la CRET;	CLR.L	D3		; D3 <-- mode;	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	KILLCRET	; libre la CRET	CLR.L	(A6)+OIDCRET	; y'a plus de CRET temporaireEXIT$:	POPM.L	D3,D5..D7	RET;--------\\; PALMOVE >;========/; Choix d'une couleur dans la palette; in	D4.L	coordonne souris (y;x); out	D1.W	rang choisi (0..n);	D7.W	erreur; mod	D1.L, D7.WPALMOVE:	PUSH.L	A2	LOAD.L	A2,#R16"PALPOS	; A2 <-- ^routine comme ICOPOS	CALL	ICOMOVE		; choix ...	POP.L	A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; PALGET  >;========/; Donne le rang dans la palette de la fausse couleur choisie.; in	(A6)+OCOL[R,G,B]; out	D1.W	rang de la fausse couleur (0..n); mod	D1.L, D7.WPALGET:	PUSHM.L	D3,D4,D6,A4	LOAD.L	A4,#(A6)+OCOLR	; A4 <-- ^couleur cherche	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	SRCCLUT		; D4 <-- fausse couleur	LOAD.W	D1,D4EXIT$:	POPM.L	D3,D4,D6,A4	RET;--------\\; PALPUT  >;========/; Initialise la couleur en fonction de la fausse couleur choisie dans la palette.; in	D1.W	rang de la fausse couleur (0..n); out	(A6)+OCOL[R,G,B]; mod	D7.WPALPUT:	PUSHM.L	D3,D4,D6,A3	CLR.L	D4	LOAD.W	D4,D1		; D4 <-- fausse couleur cherche	LOAD.L	A3,#(A6)+OCOLR	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode	OR.L	D3,#2^BTCFORCE!2^BTCGIVE	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	SRCCLUT		; OCOLR <-- couleur relle	POPM.L	D3,D4,D6,A3	RET;--------\\; PALDRAW >;========/; Affiche toute la palette.; in	-; out	-; mod	D7.WPALDRAW:	PUSHM.L	D1..D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D1LOOP$:	CALL	PALPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	LOAD.W	D2,#SETDOT	LIB	?DRRECT	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	PUSH.L	(A0)+ODFCSF	LOAD.L	(A0)+ODFCSF,D1	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	POP.L	(A0)+ODFCSF	INC.W	D1	JUMP	LOOP$EXIT$:	POPM.L	D1..D4	RET;---------\\; PALCROIX >;=========/; Met une croix dans une couleur de la palette.; in	D1.W	rang (0..n); out	-; mod	D7.WPALCROIX:	PUSH.L	A2	LOAD.L	A2,#R16"PALPOS	; A2 <-- ^routine comme ICOPOS	CALL	ICOCROIX	; croix	POP.L	A2	RET;--------\\; PALINV  >;========/; Met en vidence une couleur de la palette.; in	D1.W	rang (0..n); out	-; mod	D7.WPALINV:	PUSH.L	A2	LOAD.L	A2,#R16"PALPOS	; A2 <-- ^routine comme ICOPOS	CALL	ICOINVE		; inverse	POP.L	A2	RET;--------\\; PALPOS  >;========/; Donne la position d'une icne de la palette.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WPALPOS:	PUSHM.L	D1,D2	LOAD.W	D7,#1	.IF	COUL256	COMP.W	D1,#256	.ELSE	COMP.W	D1,#16	.ENDIF	JUMP',HS EXIT$	AND.L	D1,#H'FFFF	.IF	COUL256	DIV.WU	D1,#16	.ELSE	DIV.WU	D1,#4	.ENDIF	LOAD.W	D2,#192	.IF	COUL256	SR.W	D2,#4		; D2 <-- dimensions	.ELSE	SR.W	D2,#2		; D2 <-- dimensions	.ENDIF	LOAD.W	D3,D1	MUL.WU	D3,D2	ADD.W	D3,(A6)+OPALPY	SWAP.W	D3	SWAP.W	D1	MUL.WU	D1,D2	ADD.W	D1,(A6)+OPALPX	LOAD.W	D3,D1	LOAD.W	D4,D2	SWAP.W	D4	LOAD.W	D4,D2	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET	.END