	.TITLE	TOVAL.ASC	.PROC	M68000	.REF	SMAKY	.REF	GRAMISC;================================================; PROGRAMME DE DEMOEXSMILE	=	1	.LOC	0OSRCRGNA:	.BLK.32	1OSRCRGNB:	.BLK.32	1ODSTRGN:	.BLK.32	1OPTSEEK:	.BLK.32	1OPTDIS:		.BLK.32	1OCHANGM:	.BLK.16	1OBITMAP:	.BLK.8	LGGBMAPLGVAR:.macro	dlib	?AFTIM.ascize	"(%1) "lib	?getcar.endmacro.macro	drpushm.32 d0..a7lib	?AFTIM.ascize	"(%1) "move.32	%2,d4lib	?AFX8,?afspace,?afspace;;lib	?getcarpopm.32 d0..a7.endmacro	.LOC	0	.START	STARTSTART:	.IF	EXSMILE	.ELSE	LIB	?OPELIB	MOVE.32	#LGVAR,D4	GESMEM	?GETMEM	.ENDIF	MOVE.32	A4,A6		; ^vars	MOVE.32	#R16^TXGRAMISC,A3	MOVE.16	#GMI_FIRST,D3	LIB_	OPEN	JUMP,NE	EROR$	MOVE.16	D1,{A6}+OCHANGM	MOVE.16	#0,D3	LIB	?MOUSE	MOVE.32	#{A6}+OPTDIS,A4	MOVE.32	#4,D4	LIB	?GCHDIS	FOS	?RSTATUS	JUMP,EQ	OK$	LIB	?AFERROROK$:	GMI_	NEWRGN	MOVE.32	A4,{A6}+OSRCRGNA	GMI_	NEWRGN	MOVE.32	A4,{A6}+OSRCRGNB	GMI_	NEWRGN	MOVE.32	A4,{A6}+ODSTRGN	CALL	DEFINEMOUSFINDEMO$:	MOVE.32	{A6}+OSRCRGNA,A4	GMI_	DISPOSERGN	MOVE.32	{A6}+OSRCRGNB,A4	GMI_	DISPOSERGN	MOVE.32	{A6}+ODSTRGN,A4	GMI_	DISPOSERGN	MOVE.16	{A6}+OCHANGM,D1	LIB_	CLOSEEROR$:	.IF	EXSMILE	EXIT	.ELSE	LIB	?CLOLIB	FOS	?STOP	.ENDIF; in	A4 ^rgion...DEFINEMOUS:	MOVE.16	#GFILLXOR,D3	GMI_	OPENRGNFIRSTPT$:	LIB	?IFMOUSE	TEST.8	D3	JUMP,EQ	FIRSTPT$DOOVAL$:		; D3 tats boutons	MOVE.32	#0,D5	MOVE.32	D4,D6NEXTOV$:	PUSH.16	D3	LIB	?IFMOUSE	POP.16	D1	PUSHM.32 D3|D4	PUSH.32	D4	MOVE.32	D6,D3	MOVE.32	D5,D4	MOVE.16	#INVDOT,D2	LIB	?DRRECT		; enlve le prcdent	POP.32	D4	MOVE.32	D6,D3	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	MOVE.32	D4,D5	LIB	?DRRECT		; affiche le nouveau	POPM.32	D3|D4	MOVE.16	D3,D7	XOR.16	D7,D1	AND.16	D1,D7		; D7 <= boutons appuys	TEST.32	D1:#BMOCENT	JUMP,BC	NEXTOV$	TEST.32	D3:#BMORIGHT	JUMP,BS	VRAIOVALE$	PUSH.32	D4	PUSH.32	D6	PUSH.32	A7	PUSH.16	#32	PUSH.16	#16	SUB.A16	#3*4,SP	CALL	PUTOVAL	ADD.32	#8,A7	JUMP	END$VRAIOVALE$:	PUSH.32	D4	PUSH.32	D6	PUSH.32	A7		; ^rect	PUSH.16	{A7}+4+6	; right	MOVE.16	{A7}+6+2,D0	SUB.16	D0,{A7}		; -left	PUSH.16	{A7}+6+4	; bottom	MOVE.16	{A7}+8+0,D0	SUB.16	D0,{A7}		; -top	SUB.A16	#3*4,SP	CALL	PUTOVAL	ADD.32	#8,A7WAITREL$:	LIB	?IFMOUSE	TEST.8	D3	JUMP,NE	WAITREL$	JUMP	END$END$:	RETPUTOVAL:;------------------------------------------------; PROCEDURE DRAWOVAL (r: Rect; ovalWidth,ovalHeight: INTEGER;;		      PtBitMap: POINTER; ClipRgn: RgnId; aux: ADDRESS;);DRAWOVAL:; PROCEDURE PUTOVALINT (r: Rect; ovalWidth,ovalHeight: INTEGER;;		        SavRgn: Handle; nbbyte,size : POINTER TO INTEGER);;	-36.16		dernier x  droite	init avec partie entire de (Rect.Right-OvalWidth/2+0.5);	-34.16		dernier x  gauche	init avec partie entire de (Rect.left+OvalWidth/2);	-32.16		rect.bottom-(OvalHeight-OvalHeight/2);	-30.16		rect.top+OvalHeight/2;	-2E.(2E bytes)	Variables pour INITOVAL/BUMPOVAL; A6 ^;	+8.32		^size.16 du Handle de RgnSave;	+C.32		^nbbytes.16 dans RgnSave;	+10.32		^rgnSaveHandle;	+14.16		OvalHeight;	+16.16		OvalWidth;	+18.32		^rect	LINK.32		A6,#-16'0036	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|D7|A1|A2|A3|A4|A5	MOVE.32		{A6}+16'0018,A0			; A0 ^rect	MOVE.32		#{A6}-16'002E,A1		; A1 ^variables pour le calcul de l'ovale	MOVE.16		{A6}+16'0016,D2			; D2 OvalWidth	MOVE.16		{A6}+16'0014,D1			; D1 OvalHeight	CALL		INITOVAL			; Init Var. de calcul	MOVE.16		{A6}-16'000C,{A6}-16'0034	; partie entire de (Rect.left+OvalWidth/2)	MOVE.16		{A6}-16'0008,{A6}-16'0036	; partie entire de (Rect.Right-OvalWidth/2+0.5)	MOVE.16		{A6}+16'0014,D0			; OvalHeight	ASR.16		#16'01,D0			; /2	ADD.16		{A6}-16'002E,D0			; +rect.top	MOVE.16		D0,{A6}-16'0030	MOVE.32		{A6}+16'0018,A0			; A0 ^rect	ADD.16		{A0}+4,D0			; +rect.bottom	SUB.16		{A0},D0				; -rect.top	SUB.16		{A6}+16'0014,D0			; -OvalHeight	MOVE.16		D0,{A6}-16'0032			; rect.bottom-(OvalHeight-OvalHeight/2)	MOVE.32		{A6}+16'0010,A0			; A0 ^bitmap	MOVE.32		{A6}+16'000C,A3			; Clip RgnId;;;	MOVE.32		{A6}+16'0008,A0			; aux...	ADD.A16		{A0},A1				; A1 ^fin	MOVE.16		{A6}-16'002E,D6			; y = rect.top	MOVE.16		{A6}-16'0034,D4			; x1 = rect.left+OvalWidth/2	MOVE.16		{A6}-16'0036,D5			; x2 = rect.right-OvalWidth/2+0.5 )	CALL		PUTOVSEGNEXTY$:	COMP.16		{A6}-16'0030,D6			; current y < rect.top+OvalHeight/2 ?	JUMP,LT		OVAL$				; oui => partie ovale	COMP.16		{A6}-16'0032,D6		; current y < rect.bottom-(OvalHeight-OvalHeigth/2) ?	JUMP,GE		OVAL$			; non => ovale du bas						; oui: partie verticale	MOVE.16		{A6}-16'0032,D5			; D6 y1 haut, D5 y2 bas	MOVE.16		{A6}-16'0034,D3			; x1 gauche	MOVE.16		{A6}-16'0036,D4			; x2 droite	DEC.16		D4				; coordonne droite lgrement intrieure	CALL		PUTOVVERTS	MOVE.16		{A6}-16'0032,D6		; current y <-- rect.bottom-(OvalHeight-OvalHeigth/2)	JUMP		MOREOVAL$OVAL$:	PUSHM.32	D6|A1|A2|A3	MOVE.32		#{A6}-16'002E,A3		; A3 ^variables (initialises par INITOVAL)	MOVE.16		D6,D0				; D0 = current y	CALL		BUMPOVAL			; calcule les 2 points suivants de l'ovale	POPM.32		D6|A1|A2|A3	MOVE.16		{A6}-16'000C,D4			; Oval.left.x	MOVE.16		{A6}-16'0034,D5			; Last Oval.left.x	COMP.16		D5,D4				; changement ?	JUMP,EQ		NONEWLEFT$			; non => trace verticale fine	CALL		PUTOVSEG			; (current y ; Oval.left.x, Last Oval.left.x)	MOVE.16		{A6}-16'000C,{A6}-16'0034	; mj Last Oval.left.x	JUMP		RIGHT$NONEWLEFT$:	CALL		PUTOVDOTRIGHT$:	MOVE.16		{A6}-16'0008,D4			; Oval.right.x	MOVE.16		{A6}-16'0036,D5			; Last Oval.right.x	COMP.16		D5,D4				; changement ?	JUMP,EQ		NONEWRIGHT$	CALL		PUTOVSEG			; (current y ; Oval.right.x, Last Oval.right.x)	MOVE.16		{A6}-16'0008,{A6}-16'0036	; mj Last Oval.right.x	JUMP		NOOVAL$NONEWRIGHT$:	DEC.16		D5	CALL		PUTOVDOTNOOVAL$:	INC.16		D6				; inc current yMOREOVAL$:	COMP.16		{A6}-16'002C,D6			; current y < rect.bottom ?	JUMP,LT		NEXTY$	MOVE.16		{A6}-16'0034,D4	MOVE.16		{A6}-16'0036,D5	COMP.16		D5,D4	JUMP,EQ		JOINED$	CALL		PUTOVSEG		; (rect.bottom;Last Oval.left.x,Last Oval.right.x)JOINED$:	POPM.32		D0|D1|D2|D3|D4|D5|D6|D7|A1|A2|A3|A4|A5	UNLINK.32	A6	POP.32		A0	ADD.A16		#16'0014,A7	JUMP		{A0};-----------\\; PUTOVDOT   >;===========/; dessine un point unique de l'ovale; in	D6.16	y;	D5.16	x;	A0	^?;	A3	^;	A4	^;	A6	^vars+params; out	A2	^;	A3	^;	A1	^; mod	A1,A2,A3,+pascals...PUTOVDOT:	PUSHM.32	D2..D4|D7	MOVE.16		D6,D3	SWAP.32		D3	MOVE.16		D5,D3	MOVE.32		#1,D4	MOVE.16		#INVDOT,D2	LIB		?DRSEG	POPM.32		D2..D4|D7	RET;-----------\\; PUTOVSEG   >;===========/; dessine un segment horizontal entre x1 et x2 (points entre les 2 coordonnes) de l'ovale; in	D6.16	y;	D4.16	x1;	D5.16	x2;	A0	^?;	A3	^;	A4	^;	A6	^vars+params; out	A2	^;	A3	^;	A1	^; mod	A1,A2,A3,+pascals...PUTOVSEG:	PUSHM.32	D2..D4|D7	MOVE.16		D6,D3	SWAP.32		D3	MOVE.16		D5,D3	AND.32		#16'FFFF,D4	COMP.16		D3,D4	JUMP,GE		POS$	MOVE.16		D3,D2	MOVE.16		D4,D3		; EX.16 D3,D4	MOVE.16		D2,D4POS$:	SUB.16		D3,D4	MOVE.16		#INVDOT,D2	LIB		?DRSEG	POPM.32		D2..D4|D7	RET;-------------\\; PUTOVVERTS   >;=============/; dessine deux segments verticaux entre (y1,x1)-(y2,x1) et (y2,x1)-(y2,x2); respectivement (points entre les 2 coordonnes) de l'ovale.; precisment: points en bas  droite des coordonnes (y1,...) jusqu'aux; points en haut  gauche de (y2,...).; in	D6.16	y1 haut;	D5.16	y2 bas;	D3.16	x1 gauche;	D4.16	x2 droite;	A0	^?;	A3	^;	A4	^;	A6	^vars+params; out	A2	^;	A3	^;	A1	^; mod	A1,A2,A3,+pascals...PUTOVVERTS:	PUSHM.32	D2..D4|D7	PUSH.16		D4	SWAP.32		D3	MOVE.16		D6,D3		; y1 hw	SWAP.32		D3		; x1 lw	MOVE.16		D5,D4	SUB.16		D6,D4		; y2-y1	SWAP.32		D4	CLR.16		D4	PUSH.32		D3	MOVE.16		#INVDOT,D2	LIB		?DRSEG	POP.32		D3	POP.16		D3		; x1 lw	LIB		?DRSEG	POPM.32		D2..D4|D7	RET;------------------------------------------------;---------\\; INITOVAL >;=========/; Prpare le calcul d'une ovale ou d'un rectangle  coins arrondis (1/4 ovales); in	A0	^rect;	A1	^variables de 16'2E bytes  initialiser;	D2.16	OvalWidth;	D1.16	OvalHeight; out	A1^:;	ORectTop:	.BLK.16	1	; 0000	rect.top;	ORectBottom:	.BLK.16	1	; 0002	rect.bottom;			.BLK.16	1	; 0004	1-OvalHeight;			.BLK.32	1	; 0006	2*OvalHeight-1;			.BLK.32	1	; 000A	0;			.BLK.32	1	; 000E	0;			.BLK.32	2	; 0012	64bits: (Fract(OvalHeight/OvalWidth))^2.if true;			.BLK.16	2	; 001A	center: (rect.top+OvalHeight/2, rect.left+OvalWidht/2);			.blk.16	2.else;			.BLK.32	2	; 001A	64bits.fract: 2*(OvalHeight/OvalWidth)^2.endif;	OOvalCentLeft:	.BLK.32	1	; 0022	fract: x courant left, init Rect.Left+OvalWidth/2;			.BLK.32	1	; 0026	fract: x courant right, init Rect.Right-OvalWidth/2+0.5;			.BLK.32	1	; 002A	0.5;	LG:				; 2E	bytes; mod	?INITOVAL:	MOVE.16		{A0},{A1}			; rect.top	MOVE.16		{A0}+4,{A1}+16'0002		; rect.bottom	TEST.16		D2				; OvalWidth < 0 ==> =0	JUMP,PL		WIDTH0$	CLR.16		D2WIDTH0$:	TEST.16		D1				; OvalHeight < 0 ==> =0	JUMP,PL		HEIGHT0$	CLR.16		D1HEIGHT0$:	MOVE.16		{A0}+6,D0			; rect.right	SUB.16		{A0}+2,D0			; - rect.left	COMP.16		D0,D2				; OvalWidth =< width(rect) ?	JUMP,LE		ROUNDWIDTH$	MOVE.16		D0,D2				; non => OvalWidth := width(rect)ROUNDWIDTH$:	MOVE.16		{A0}+4,D0			; rect.bottom	SUB.16		{A0},D0				; - rect.top	COMP.16		D0,D1				; OvalHeight =< height(rect) ?	JUMP,LE		ROUNDHEIGHT$	MOVE.16		D0,D1				; non => OvalHeight := height(rect)ROUNDHEIGHT$:	MOVE.16		{A0}+6,{A1}+16'0026		; rect.right	CLR.16		{A1}+16'0028	MOVE.16		{A0}+16'0002,{A1}+16'0022	; rect.left	CLR.16		{A1}+16'0024	MOVE.16		D2,D0	SWAP.32		D0	CLR.16		D0	SR.32		#1,D0				; D0.fract := OvalWidth /2	ADD.32		D0,{A1}+16'0022	SUB.32		D0,{A1}+16'0026	MOVE.32		#16'00008000,D0			; 0.5	MOVE.32		D0,{A1}+16'002A	ADD.32		D0,{A1}+16'0026	MOVE.32		#16'00000001,D0	SUB.16		D1,D0				; 1-OvalHeight	MOVE.16		D0,{A1}+16'0004	MOVE.16		D1,D0	CONV.A16.32	D0	ADD.32		D0,D0	DEC.32		D0	MOVE.32		D0,{A1}+16'0006			; 2*OvalHeight-1	CLR.32		{A1}+16'000A	CLR.32		{A1}+16'000E.if true	MOVE.16	D1,D0	SR.16	D0					; OvalHeight/2	ADD.16	{A0}+0,D0				; + rect.top	MOVE.16	D0,{A1}+16'001A	MOVE.16	D2,D0	SR.16	D0					; OvalWidth/2	ADD.16	{A0}+2,D0				; + rect.left	MOVE.16	D0,{A1}+16'001C.endif	CLR.32		{-A7}	PUSH.16		D1				; num: Heigh	PUSH.16		D2				; denom: Widht	CALL		R16^FixRatio			; {A7}.fract := OvalHeight / OvalWidth	PUSH.32		{A7}	PUSH.32		#{A1}+16'0012	CALL		R16^LongMul			; ** 2 ==> {A6}+16'12.64.if false	MOVE.32		{A1}+16'0016,D0			; Partie fractionnaire	ADD.32		D0,D0				; *2	MOVE.32		D0,{A1}+16'001E	MOVE.32		{A1}+16'0012,D0			; Partie entire	ADDX.32		D0,D0				; *2	MOVE.32		D0,{A1}+16'001A.endif false	RET;------------------------------------------------;----------\\; BUMPOVAL  >;==========/; in	A3	^variables (cf INITOVAL);	D0.16	= y courant; out	{A3}+22	nb fract. x left;	{A3}+26	nb fract. x droite; mod	A3,?BUMPOVAL:	COMP.16		{A3+},D0		; current y < rect.top ?	JUMP,LT		RTN$			; oui => fait rien	COMP.16		{A3+},D0		; current y > rect.bottom	JUMP,GE		RTN$			; oui => fait rien.if false	MOVE.16		{A3},D0			; 2*(y-y0) (init 1-OvalHeight).endif	ADD.16		#2,{A3+}	MOVEM.32	{A3},D1|D2|D3|D4|D5|D6|D7|A0|A1|A2						; D1 = 2*OvalHeight-1						; D2 = 0						; D3 = 0						; D4;D5 = (fract(OvalHeight/OvalWidth))^2.if true						; D6 = coord. centre.else						; D6;D7 = 2*(fract(OvalHeight/OvalWidth))^2.endif						; A0 fractionnaire: current x left						; A1 fractionnaire: current x right						; A2 fractionnaire: 0.5.if true	PUSHM.32 D0|D1|D2|D3;exitdr c,d6	MOVE.16	D0,D2	SWAP.32	D6	SUB.16	D6,D2				; y courant - y centre	SWAP.32	D6	SWAP.32	D2				; num: y1 - y0	MOVE.16	D6,D2	neg.32	d2	PUSH.32	D2				; sauve pour x1_right					; left:	MOVE.32	A0,D1	SWAP.32	D1	SUB.16	D6,D1	SWAP.32	D1				; denom: x1_left - x0	CALL	FIXDIV				; D0: pente left	MOVE.32	D0,D1	MOVE.32	D4,D2	MOVE.32	D5,D3	CALL	_GMI_FIXDIV64			; D0: (OvalHeight/OvalWidth)^2 / pente (p1-p0)	MOVE.32	#16'00010000,D2	MOVE.32	D0,D1	CALL	_GMI_FIXDIV			; D0: 1/pente tangente gauche	ADD.32	D0,A0				; add sur fractionnaire gauche courrant					; right:	POP.32	D2				; rcupre num: y1-y0;exitdr ox,a1dr dy,d2	MOVE.32	A1,D1	SWAP.32	D1	SUB.16	D6,D1	SWAP.32	D1				; denom: x1_right - x0dr dx,d1	CALL	FIXDIV				; D0: pente left	MOVE.32	D0,D1dr pd,d0	MOVE.32	D4,D2	MOVE.32	D5,D3	CALL	_GMI_FIXDIV64			; D0: (OvalHeight/OvalWidth)^2 / pente (p1-p0)dr p1p,d0	MOVE.32	#16'00010000,D2	MOVE.32	D0,D1	CALL	_GMI_FIXDIV			; D0: 1/pente tangente gauchedr p1pi,d0	ADD.32	D0,A1				; add sur fractionnaire droite courrantdr nx,a1lib ?afcr,?getcar	POPM.32	D0|D1|D2|D3.else true	JUMP		BEGCALC$ADDLOOP$:	ADD.32		A2,A1			; current x right :+ 0.5	SUB.32		A2,A0			; current x left  :- 0.5	ADD.32		D5,D3	ADDX.32		D4,D2			; add (2n+1)*((OvalHeight/OvalWidth)^2)	ADD.32		D7,D5			; add 2*(OvalHeight/OvalWidth)^2 to 2n+1...	ADDX.32		D6,D4BEGCALC$:	COMP.32		D1,D2			; INT(2n+1*((OvalHeight/OvalWidth)^2)) < 2*OvalHeight-1?	JUMP,LT		ADDLOOP$		; oui => recommence	JUMP		BEGSUB$SUBLOOP$:	SUB.32		A2,A1			; current x right :- 0.5	ADD.32		A2,A0			; current x left  :+ 0.5	SUB.32		D7,D5	SUBX.32		D6,D4			; sub 2*(OvalHeight/OvalWidth)^2 to 2n+1...	SUB.32		D5,D3	SUBX.32		D4,D2			; sub (2n+1)*((OvalHeight/OvalWidth)^2)BEGSUB$:	COMP.32		D1,D2			; INT(2n+1*((OvalHeight/OvalWidth)^2)) > 2*OvalHeight-1?	JUMP,GT		SUBLOOP$		; oui => soustrait	INC.16		D0			; non => inc 2*(y-y0) (devient init. 2-OvalHeight)	CONV.A16.32	D0	ASL.32		#2,D0			; * 4	SUB.32		D0,D1			; 2*OvalHeght-1 - 4*(2*(y-y0)+1).endif true	MOVEM.32	D1|D2|D3|D4|D5|D6|D7|A0|A1|A2,{A3}RTN$:	RET	.INS		GMIMATH.ASITXGRAMISC:	.ASCIZE	"TGRAMIS"	.END