	.CHAP	GMIMATH.ASI; Routines mathmatiques pour graphique.; ======================================;-------------------\\;   _GMI_RFixRatio    >;===================/; in	D1.16	nombre entier numrateur;	D2.32	nombre entier dnominateur; out	D0.32	nombre  virgule fixe rsultant; mod	D0.32_GMI_RFixRatio:	PUSHM.32 D1|D2|A0|A1	CLR.32	{-A7}	PUSH.16	D1	PUSH.16	D2	CALL	FIXRATIO	POP.32	D0	POPM.32	D1|D2|A0|A1	RET;-------------------\\;   _GMI_FixRatio    >;===================/; FixRatio (numer, denom: INTEGER): Fixed;	(Fixed: 32 bits: 16 bits entier, 16 bits fractionnaire);; Pour comprendre: voir FixDiv !; in	SP^;	+4.32	RESULT:		place pour rsultat;	+2.16		numer;	+0.16		denom; out	SP^;	+0.32	RESULT:	Fixed; mod	F_GMI_FixRatio:FIXRATIO:	LINK.32		A6,#+16'0000	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|A0|A1	MOVEM.A16	{A6}+16'0008,D1|D2	COMP.16		D1,D2	JUMP,EQ		RELFFB4$	CALL		RELFED4$	TEST.32		D1	JUMP,NE		RELFF9E$	MOVE.32		#16'FFFFFFFF,D0	SR.32		#16'01,D0	JUMP		RELFFAA$RELFF9E$:	DIV.A16		D1,D2	MOVE.16		D2,D0	SWAP.32		D0	CLR.16		D2	DIV.16		D1,D2	MOVE.16		D2,D0RELFFAA$:	TEST.8		D6	JUMP,EQ		RELFFB0$	NEG.32		D0RELFFB0$:	JUMP		RELFEAC$RELFFB4$:	MOVE.32		#16'00000001,D0	SWAP.32		D0;;;;	JUMP		RELFEAC$RELFEAC$:	MOVE.32		D0,{A6}+16'000C	POPM.32		D0|D1|D2|D3|D4|D5|D6|A0|A1	UNLINK.32	A6	POP.32		{SP}	RETRELFED4$:	TEST.32		D1	SET.8,MI	D6	JUMP,PL		RELFEDC$	NEG.32		D1RELFEDC$:	TEST.32		D2	JUMP,PL		RELFEE4$	NEG.32		D2	NOT.8		D6RELFEE4$:	RET;-----------------\\;   _GMI_FixMul    >;=================/; FONCTION FixMul (a, b: Fixed): Fixed;; in	SP^;	+8.32	RESULT:		place pour rsultat;	+4.32		a;	+0.32		b; out	SP^;	+0.32	RESULT:	Fixed; mod	F_GMI_FixMul:	PUSHM.32 D0|D1|D2	MOVE.32	{SP}+4*4+4,D1		; a	MOVE.32	{SP}+4*4+0,D2		; b	CALL	FIXMUL	MOVE.32	D0,{SP}+4*4+8		; RESULT.32	POPM.32	D0|D1|D2	MOVE.32	{SP},{SP}+8	ADD.32	#8,SP	RET;------------------\\;   _GMI_RFixMul    >;==================/;------------\\;   FIXMUL    >;============/; in	D1.32	nombre  virgule fixe no 1;	D2.32	nombre  virgule fixe no 2; out	D0.32	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.32_GMI_RFixMul:FIXMUL:	PUSHM.32	D1|D2|D6|D4|D5	CALL		TOPOSITIF	MOVE.32		#16'00010000,D4	COMP.32		D4,D1			; D1 = 1.0 ?	JUMP,NE		D1DIFF0$		; non => D2 = 1.0 ?	MOVE.32		D2,D1	JUMP		MUL10$D1DIFF0$:	COMP.32		D4,D2			; D2 = 1.0 ?	JUMP,NE		DIFFZERO$MUL10$:	MOVE.32		#16'00000000,D0	MOVE.32		#16'00000000,D4	MOVE.16		D1,D4	SWAP.32		D4	SWAP.32		D1	MOVE.16		D1,D0			; (D0;D4) = rsultat	JUMP		LONGTOFIX$DIFFZERO$:	MOVE.16		D2,D4	MUL.16		D1,D4			; D4: D1.fract * D2.fract	SWAP.32		D2	MOVE.16		D2,D5	MUL.16		D1,D5			; D5: D1.fract * D2.int	SWAP.32		D1	MOVE.16		D2,D0	MUL.16		D1,D0			; D0: D1.int * D2.int	SWAP.32		D2	MUL.16		D1,D2			; D2: D1.int * D2.fract	ADD.32		D5,D2			; mid	MOVE.32		#0,D5	MOVE.16		D2,D5	SWAP.32		D5			; mid * 2**16	MOVE.16		D5,D2			; #0	SWAP.32		D2	ADD.32		D5,D4			; + low	ADDX.32		D2,D0			; mid.31..16 + high + carry						; (D0;D4): rsultatLONGTOFIX$:	SWAP.32		D0	TEST.16		D0			; high word <> 0 ?	JUMP,NE		SETMAX$			; oui => met la val. maximum	SWAP.32		D4	MOVE.16		D4,D0			; low res. word	TEST.32		D4			; high bit reste = 0 ?	JUMP,PL		NOTROUND$	INC.32		D0			; inc res.fract	JUMP,CS		SETMAX$NOTROUND$:	TEST.32		D0			; bit de signe dj mis ?	JUMP,MI		SETMAX$			; ==> dbordement !	TEST.8		D6			; (VC)	JUMP,EQ		RTN$	NEG.32		D0			; met rsultat ngatif selon D1 et D2.in (VC)	JUMP		RTN$SETMAX$:	MOVE.32		#16'00000001,D0	RR.32		#16'01,D0	TEST.8		D6	JUMP,NE		RTNOV$	DEC.32		D0RTNOV$:	SETV					; met le bit overflowRTN$:	POPM.32	D1|D2|D6|D4|D5	RET;-------------------\\;   _GMI_FixDiv64    >;===================/; FONCTION FixDiv64 (Numer: Fixed64; Denom: Fixed): Fixed;; in	SP^;	+8.32	RESULT:		place pour rsultat;	+4.32		^Numer.64;	+0.32		Denom; out	SP^;	+0.32	RESULT:	Fixed; mod	F_GMI_FixDiv64:	PUSHM.32 D0|D1|D2|D3|A0	MOVE.32	{SP}+6*4+0,D1		; Denom	MOVE.32	{SP}+6*4+4,A0		; ^Numer	MOVE.32	{A0+},D2	MOVE.32	{A0},D3	CALL	FIXDIV64	MOVE.32	D0,{SP}+6*4+8		; RESULT.32	POPM.32	D0|D1|D2|D3|A0	MOVE.32	{SP},{SP}+8	ADD.32	#8,SP	RET;-------------------\\;   _GMI_RFixDiv64    >;===================/; in	D2.32	nombre  virgule fixe numrateur (partie entire);	D3.32	nombre  virgule fixe numrateur (partie fractionnaire);	D1.32	nombre  virgule fixe dnominateur; out	D0.32	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.32_GMI_RFixDiv64:FIXDIV64:	PUSHM.32	D1|D2|D6|D4|D5|D3|D7	MOVE.32		D3,D7	PUSH.32		D1	SWAP.32		D1	CONV.A16.32	D1	COMP.32		D1,D2	JUMP,NE		TEQEND$	MOVE.32		{SP},D1	SWAP.32		D3	COMP.16		D1,D3TEQEND$:	POPM.32		D1	JUMP,EQ		EQUAL$	CALL		TOPOSITIF64	TEST.32		D1			; /0 ?	JUMP,NE		DODIV$			; nonOVERFLOW$:	MOVE.32		#16'7FFFFFFF,D0	TEST.8		D6			; remet ngatif si l'tait	JUMP,EQ		POSOV$	INC.32		D0POSOV$:	SETV	JUMP		RTN$DODIV$:	MOVE.32		D1,D3			; Dnom * 2**-16	MOVE.32		D2,D1	MOVE.32		D7,D0			; Num *2**-32	CALL		DIV32			; Num/Denom: DIV.64 D3,(D1&D0) --> D4.32 reste D2.32	JUMP,VS		OVERFLOW$	MOVE.32		D4,D0	TEST.32		D0	JUMP,NS		OVERFLOW$PUTSIGN$:	TEST.8		D6			; remet ngatif si l'tait (VC)	JUMP,EQ		POS$	NEG.32		D0			; (VC)POS$:	JUMP		RTN$EQUAL$:	MOVE.32		#1,D0	SWAP.32		D0			; (VC)RTN$:	POPM.32		D1|D2|D6|D4|D5|D3|D7	RETTOPOSITIF64:	TEST.32		D1	SET.8,MI	D6	JUMP,PL		POS1$	NEG.32		D1POS1$:	TEST.32		D2	JUMP,PL		POS2$	NOT.32		D2	NOT.32		D7	INC.32		D7			; NEG = NOT + 1, ici pour NEG.64 (D2&D7)	JUMP,CC		OKINC$	INC.32		D2OKINC$:	NOT.8		D6POS2$:	RET;-------------------------\\;   _GMI_FixDivUnsigned    >;=========================/; FONCTION FixDivUnsigned (Numer, Denom: Fixed): Fixed;; in	SP^;	+8.32	RESULT:		place pour rsultat;	+4.32		Numer;	+0.32		Denom; out	SP^;	+0.32	RESULT:	Fixed; mod	F_GMI_FixDivUnsigned:	PUSHM.32 D0|D1|D2	MOVE.32	{SP}+4*4+0,D1		; Denom	MOVE.32	{SP}+4*4+4,D2		; Numer	CALL	FIXDIVUNSIGNED	MOVE.32	D0,{SP}+4*4+8		; RESULT.32	POPM.32	D0|D1|D2	MOVE.32	{SP},{SP}+8	ADD.32	#8,SP	RET;--------------------------\\;   _GMI_RFixDivUnsigned    >;==========================/; Division non-signe 32 bits  virgule fixe; in	D2.32	nombre  virgule fixe numrateur;	D1.32	nombre  virgule fixe dnominateur; out	D0.32	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.32_GMI_RFixDivUnsigned:FIXDIVUNSIGNED:	PUSHM.32	D1|D2|D6|D4|D5|D3	COMP.32		D1,D2	JUMP,EQ		EQUALDIVUFIX32	CLR.8		D6	JUMP		DIVUFIX32;-----------------\\;   _GMI_FixDiv    >;=================/; FONCTION FixDiv (Numer, Denom: Fixed): Fixed;; in	SP^;	+8.32	RESULT:		place pour rsultat;	+4.32		Numer;	+0.32		Denom; out	SP^;	+0.32	RESULT:	Fixed; mod	F_GMI_FixDiv:	PUSHM.32 D0|D1|D2	MOVE.32	{SP}+4*4+0,D1		; Denom	MOVE.32	{SP}+4*4+4,D2		; Numer	CALL	FIXDIV	MOVE.32	D0,{SP}+4*4+8		; RESULT.32	POPM.32	D0|D1|D2	MOVE.32	{SP},{SP}+8	ADD.32	#8,SP	RET;------------------\\;   _GMI_RFixDiv    >;==================/;------------\\;   FixDiv    >;============/; Division signe 32 bits  virgule fixe; in	D2.32	nombre  virgule fixe numrateur;	D1.32	nombre  virgule fixe dnominateur; out	D0.32	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.32_GMI_RFixDiv:FIXDIV:	PUSHM.32	D1|D2|D6|D4|D5|D3	COMP.32		D1,D2	JUMP,EQ		EQUALDIVUFIX32	CALL		TOPOSITIFDIVUFIX32:	TEST.32		D1			; /0 ?	JUMP,NE		DODIV$			; nonOVERFLOW$:	MOVE.32		#16'7FFFFFFF,D0	TEST.8		D6			; remet ngatif si l'tait	JUMP,EQ		POSOV$	INC.32		D0POSOV$:	SETV	JUMP		RTN$DODIV$:	MOVE.32		D1,D3			; Dnom	MOVE.32		#0,D1	MOVE.32		D2,D0			; Num	CALL		DIV32			; Num/Denom: DIV.64 D3,(D1&D0) --> D4.32 reste D2.32	JUMP,VS		OVERFLOW$	MOVE.16		D4,D5	SWAP.32		D5			; --> entier	CLR.32		D1			; reste * 2**16	SWAP.32		D2	MOVE.16		D2,D1	MOVE.32		D2,D0	CLR.16		D0	CALL		DIV32			; reste*2**16/ Denom	MOVE.16		D4,D5			; --> fraction	MOVE.32		D5,D0	TEST.32		D2	JUMP,PL		NOROUND$	INC.32		D5	JUMP,CS		OVERFLOW$NOROUND$:	TEST.32		D5	JUMP,NS		OVERFLOW$PUTSIGN$:	TEST.8		D6			; remet ngatif si l'tait (VC)	JUMP,EQ		POS$	NEG.32		D0			; (VC)POS$:RTN$:RTNDIVUFIX32:	POPM.32		D1|D2|D6|D4|D5|D3	RETEQUALDIVUFIX32:	MOVE.32		#1,D0	SWAP.32		D0			; (VC)	JUMP		RTNDIVUFIX32TOPOSITIF:	TEST.32		D1	SET.8,MI	D6	JUMP,PL		POS1$	NEG.32		D1POS1$:	TEST.32		D2	JUMP,PL		POS2$	NEG.32		D2	NOT.8		D6POS2$:	RET;------------------------------------------------,;            LongMul                              >;================================================'; FUNCTION (int1,int2: LONGINT): LONGINT64bits;LONGMUL:	LINK.32		A6,#+16'0000	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|A1	MOVEM.32	{A6}+16'000C,D1|D2		; D1 * D2 --> D0;D4	TEST.32		D1	SET.8,MI	D6	JUMP,PL		R8^RELFEDC$	NEG.32		D1RELFEDC$:	TEST.32		D2	JUMP,PL		R8^RELFE32$	NEG.32		D2	NOT.8		D6RELFE32$:	MOVE.32		#16'00010000,D4			; 16'10000 * D2 ?	COMP.32		D4,D1	JUMP,NE		R8^RELFE3E$	MOVE.32		D2,D1				; oui => rapide...	JUMP		R8^RELFE42$RELFE3E$:	COMP.32		D4,D2				; 16'10000 * D1 ?	JUMP,NE		R8^RELFE50$			; non => normalRELFE42$:	MOVE.32		#16'00000000,D0	MOVE.32		#16'00000000,D4	MOVE.16		D1,D4	SWAP.32		D4	SWAP.32		D1	MOVE.16		D1,D0				; 0000;D1.H;D1.L;0 --> D0;D4	JUMP		R8^RELFE74$RELFE50$:	MOVE.16		D2,D4	MUL.16		D1,D4				; L*L --> D4	SWAP.32		D2	MOVE.16		D2,D3	MUL.16		D1,D3				; L*H --> D3	SWAP.32		D1	MOVE.16		D2,D0	MUL.16		D1,D0				; H*H --> D0	SWAP.32		D2	MUL.16		D1,D2				; H*L --> D2 (+D3)	ADD.32		D3,D2	MOVE.32		#16'00000000,D3	MOVE.16		D2,D3	SWAP.32		D3				; H*L+L*H .LW --> D3.HW	MOVE.16		D3,D2	SWAP.32		D2				;         .HW --> D2.LW	ADD.32		D3,D4	ADDX.32		D2,D0RELFE74$:	TEST.8		D6	JUMP,PL		R8^RELFE0E$	NEG.32		D4	NEGX.32		D0RELFE0E$:	MOVE.32		{A6}+16'0008,A0	MOVE.32		D0,{A0+}	MOVE.32		D4,{A0}	MOVE.16		#16'000C,{A6}+16'0008	POPM.32		D0|D1|D2|D3|D4|D5|D6|A1	UNLINK.32	A6	POP.32		A0	ADD.A16		{A7},A7	JUMP		{A0};---------------\\;  _GMI_Mul32    >;===============/; FONCTION Mul32(a,b: LONGCARD): CARDINAL64;; module de multiplication 32*32-->64 bits; in	SP^;	+8.64	RESULT:		place pour rsultat;	+4.32		a;	+0.32		b; out	SP^;	+0.64	RESULT:	a*b; mod	F_GMI_Mul32:	PUSHM.32 D0|D1|D2|D3	MOVE.32	{SP}+5*4+0,D2		; a	MOVE.32	{SP}+5*4+4,D3		; b	CALL	MUL32	MOVE.32	D1,{SP}+5*4+8+0		; RESULT.64	MOVE.32	D0,{SP}+5*4+8+4	POPM.32	D0|D1|D2|D3	MOVE.32	{SP},{SP}+8	ADD.32	#8,SP	RET;----------------\\;  _GMI_RMUL32    >;================/;----------\\;  Mul32    >;==========/; module de multiplication 32*32-->64 bits: (D1&D0).64 = MUL.32 D2,D3; in	D2.32,D3.32	nombres  multiplier; out	D1.32,D0.32	rsultat; mod	D0.32,D1.32_GMI_RMUL32:MUL32:	PUSHM.32 D5|D7	MOVE.16	D3,D0	MUL.16	D2,D0			; low word * low word --> low longword D0	SWAP.32	D2	MOVE.16	D3,D7			; high word * low word --> mid longword D7	MUL.16	D2,D7	SWAP.32	D3	MOVE.16	D3,D1			; high word * high word --> high long D1	MUL.16	D2,D1	SWAP.32	D2	MOVE.16	D3,D5			; high word * low word --> mid long' D5	MUL.16	D2,D5	SWAP.32	D3	SWAP.32	D1	ADD.32	D7,D5			; ADD.32 D7,D5 avec report sur D1 si ncess.	CLR.16	D7	ADDX.16	D7,D1	SWAP.32	D1	ADDX.16	D7,D1	MOVE.16	D1,D7			; ADD.64 D5*(2**16),D1&D0	SWAP.32	D7	SWAP.32	D0	MOVE.16	D0,D7	ADD.32	D5,D7	MOVE.16	D7,D0	SWAP.32	D0	SWAP.32	D7	MOVE.16	D7,D1	SWAP.32	D1	CLR.32	D7	ADDX.32	D7,D1	SWAP.32	D1	POPM.32	D5|D7	RET;---------------\\;  _GMI_Div32    >;===============/; PROCEDURE Div32 (Numer: CARDINAL64; Denom: LONGCARD;;                  VAR Result, Remainder: LONGCARD; VAR Over: BOOLEAN);; division 64 bits-->32 bits reste 32 bits; in	SP^;	+16.32	^Numer;	+12.32	Denom;	+8.32	^Result;	+4.32	^Remainder;	+0.32	^Over; out	-;	Result,Remainder,Over; mod	F_GMI_Div32:	PUSHM.32 D0..D4|A0	MOVE.32	{SP}+7*4+10'16,A0	; ^Numer	MOVE.32	{A0+},D1	MOVE.32	{A0},D0	MOVE.32	{SP}+7*4+10'12,D3	CALL	DIV32	MOVE.32	{SP}+7*4+0,A0		; ^Over	SET.8,VS {A0}				; ?????????????????	MOVE.32	{SP}+7*4+8,A0		; ^Result	MOVE.32	D4,{A0}	MOVE.32	{SP}+7*4+4,A0		; ^Remainder	MOVE.32	D2,{A0}	POPM.32	D0..D4|A0	MOVE.32	{SP},{SP}+10'20	ADD.32	#10'20,SP	RET;----------------\\;  _GMI_RDIV32    >;================/;----------\\;  DIV32    >;==========/; appel de division 64 bits-->32 bits reste 32 bits:  DIV.64 D3,(D1&D0) --> D4.32 reste D2.32; in	(D1.32,D0.32),D3.32	nombres  diviser; out	D4.32			rsultat;	D2.32			reste;	VS			overflow; mod	D2.32,D4.32DIV32:	PUSHM.32 D0..D1|D6	MOVE.16	#32-1,D6		; D6 dcompteur de bouclesDIV2$:	SETX	RLX.32	D0	RLX.32	D1;;;;	JUMP,CS	RETERR$	JUMP,CS	OVER?$			; encore pas overflow si le sub suivant CS !	SUB.32	D3,D1	JUMP,HS	DIV4$	ADD.32	D3,D1	TCLR.32	D0:#0			; bit 0 si rtablissementDIV4$:	DJ.16,NMO D6,DIV2$	COMP.32	D3,D1			; reste >= diviseur ?	JUMP,HS RETERR$	MOVE.32	D0,D4			; D4 <-- quotient	MOVE.32	D1,D2			; D2 <-- reste,	  F:V=0RETOUR$:	POPM.32	D0..D1|D6	RETOVER?$:	SUB.32	D3,D1			; regarde si arrive  soustraire D3 de D1+2**31 ?	JUMP,CS	DIV4$			; overflow (LO) ==> on a pu compenser l'overflow prcdent !					; sinon: dfinitivement overflow.; en cas d'overflow:RETERR$:	SETV	JUMP	RETOUR$	.END