DEFINITION MODULE Gmi;(*$ Version 0.0 *)(* Module d'interface aux primitives de support pour graphique *)(* =========================================================== *)(* Beat Brunner, novembre 1989 *)FROM SYSTEM IMPORT ADDRESS, BYTE;TYPE  PsosError = CARDINAL;    Cardinal64 = RECORD                  Hi,Low : LONGCARD;               END;  Integer64 = RECORD                 Hi  : LONGINT;                Low : LONGCARD;              END;  (* Nombres  virgule fixe: *)  (* Format des nombres: 32 bits, dont 16 bits entiers, et 16 bits fractionnaires:	  15             0  -1               -16	 2              2  2                2	 -------------------------------------	 !   16 bits      !     16 bits      !	 -------------------------------------	 32768           1  1/2             1/65536	  partie entire    partie fractionnaire		 exemple:	1.0  =	16'00010000			0.5  =	16'00008000			8.0  =	16'00080000			8.75 =	16'0008C000  *)  Fixed = RECORD CASE: BOOLEAN OF              TRUE  : All: LONGINT;            | FALSE : Integer: INTEGER;                      Fract: CARDINAL;            END;          END;  Fixed64 = RECORD              Integer : LONGINT;              Fract   : LONGCARD;            END;  XYSelect = (y,x);  Point = RECORD CASE: BOOLEAN OF			(* Point en coordonnes entires *)              TRUE  : y,x : INTEGER;            | FALSE : yx: ARRAY(XYSelect) OF INTEGER;            END;          END;  RealPoint = RECORD					(* Point en coordonnes  virgule fixe *)                y,x : Fixed;              END;  Rect = RECORD CASE: BOOLEAN OF				(* Rectangle *)             TRUE  : Top, Left, Bottom, Right : INTEGER;           | FALSE : TopLeft, BottomRight : Point;           END;         END;  RgnId;						(* Rgion *)  Direction = (Positive, Negative);			(* sens de construction:							   positif: sens des aiguilles de montre,							   ngatif: dans l'autre sens.							*)  BitMap = RECORD					(* Descripteur de bitmap *)             BaseAddr : ADDRESS;             RowBytes : CARDINAL;             Bounds   : Rect;           END;  (* PixMap  prvoir *)  (* Modes de transfert *)  GraTransMode = (                  GMZero,    	(* 0                *)                  GMAnd,     	(* s*d              *)                  GMBic,     	(* /s*d             *)                  GMNop,     	(* d !!!!!          *)                  GMAndI,    	(* s*/d             *)                  GMCopy,    	(* s                *)                  GMXor,     	(* /s*d + s*/d      *)                  GMOr,      	(* s+d              *)                  GMOrInv,   	(* /(s+d)           *)                  GMNotXor,  	(* /s*/d + s*d      *)                  GMNotCopy, 	(* /s               *)                  GMNotOr,   	(* /s + d           *)                  GMInvD,    	(* /d !!!!!         *)                  GMInvOr,   	(* s + /d           *)                  GMNand,    	(* /s + /d = /(s*d) *)                  GMOne     	(* 1                *)		 );  (* Modes de remplissage *)CONST    (* Option 1: *)      GFillXor     = 0;		(* par comptage pair/impair du nombre de limites de rgion *)      GFillWinding = 1;		(* par comptage du nombre de segments dirigs. *)				(* direction positive: sens des aiguilles d'une montre. *)    (* Option 2: *)      GFillInterior = 0;	(* remplissage de l'intrieur uniquement *)      GFillRoundUp  = 2;	(* remplissage de l'intrieur et du pourtour *)  (* Oprations de calcul *)  GOpSect  = 0;			(* A intersection B *)  GOpUnion = 4;			(* A union B *)  GOpDiff  = 2;			(* A - B  (toute partie de A non-incluse dans B) *)  GOpXor   = 6;			(* A ou exclusif B *)(* Numros des appels *)CONSTGmiFirst = 0A470H;GmiLast  = GmiFirst+026H;(* ------------------------------------------------------------------------------------------- *)(* Procdures Mathmatiques *)(* ======================== *)  (* Calcul sur nombres entiers: *)  PROCEDURE GmiMul32 (a,b: LONGCARD): Cardinal64;	(* multiplication 32*32-->64 bits *)            CODE(GmiFirst+00H);  PROCEDURE GmiDiv32 (VAR Numer: Cardinal64; Denom: LONGCARD;                      VAR Result, Remainder: LONGCARD; VAR Over: BOOLEAN);            CODE(GmiFirst+01H);						(* division 64 bits-->32 bits reste 32 bits *)		(* VAR Numer par compatibilit *)  (* Calcul sur nombres  virgule fixe: *)  PROCEDURE GmiFixRatio (numer, denom: INTEGER): Fixed;		(* rapport sign *)            CODE(GmiFirst+02H);  PROCEDURE GmiFixMul (a, b: Fixed): Fixed;			(* multiplication signe *)            CODE(GmiFirst+03H);  PROCEDURE GmiFixDiv (Numer, Denom: Fixed): Fixed;		(* division signe *)            CODE(GmiFirst+04H);  PROCEDURE GmiFixDivUnsigned (Numer, Denom: Fixed): Fixed;	(* division non-signe *)            CODE(GmiFirst+05H);  PROCEDURE GmiFixDiv64 (VAR Numer: Fixed64; Denom: Fixed): Fixed;  (* division signe 64 bits *)            CODE(GmiFirst+06H);		(* VAR Numer par compatibilit *)(* ------------------------------------------------------------------------------------------- *)(* Manipulation de points *)(* ====================== *)  PROCEDURE GmiAddPt(PtA, PtB: Point): Point;            CODE(GmiFirst+07H);		(* Additionne les coordonnes de PtB  PtA et rend le rsultat.		*)  PROCEDURE GmiSubPt(PtA, PtB: Point): Point;            CODE(GmiFirst+08H);		(* Soustrait les coordonnes de PtB  PtA et rend le rsultat.		*)  PROCEDURE GmiPtInRect (Pt: Point; VAR r: Rect):BOOLEAN;            CODE(GmiFirst+09H);		(* VAR r par compatibilit *)		(* Teste si le point  droite et en-dessous du point donn		   est inclus dans le rectangle donn. Rend TRUE si le		   point se trouve  l'intrieur, FALSE sinon.		*)  PROCEDURE GmiMapPt (VAR Pt: Point; VAR srcRect,dstRect: Rect);            CODE(GmiFirst+0AH);		(* VAR srcRect, dstRect par compatibilit *)		(* On donne un point Pt dans SrcRect, et MapPt le repositionne		   relativement  DstRect (coordonnes absolues), selon le rapport		   des dimensions de DstRect relativement  SrcRect.		*)(* ------------------------------------------------------------------------------------------- *)(* Manipulation de rectangles *)(* ========================== *)  PROCEDURE GmiEmptyRect (VAR r: Rect): BOOLEAN;            CODE(GmiFirst+0BH);		(* VAR r par compatibilit *)		(* Rend si le rectangle est vide (TRUE=1) ou pas (FALSE=0).		   (comparaison par top<bottom et left<right)		*)  PROCEDURE GmiInsetRect (VAR r: Rect; dvBottom, dvTop, dhRight, dhLeft: INTEGER);            CODE(GmiFirst+0CH);		(* Extension (valeurs ngatives de dh ou dv) ou diminution (valeurs positives)		   d'un rectangle relativement  son centre.		   Les cots gauche et droite bougent chacun de dhLeft, resp. dhRight.		   Le haut et le bas bougent chacun de dvTop, resp. dvBottom.		   L'effet est que les dimensions du rectangle diminuent de dvTop+dvBottom, et		   de dhLeft+dhRight.		   Le rectangle peut devenir vide ( [(0,0),(0,0)] ).		   Un rectangle vide est agrandit uniquement autour de l'origine		*)  PROCEDURE GmiSectRect (VAR src1, src2: Rect; VAR dstRect: Rect) : BOOLEAN;            CODE(GmiFirst+0DH);		(* VAR src1, src2 par compatibilit *)		(* Calcule l'intersection de 2 rectangles et rend si les deux		   rectangles intersectent ou pas. Fonctionne aussi si le rectangle		   de destination est le meme que l'une des deux sources.		   Si intersection ensemble vide, rend le rectangle [(0,0)(0,0)].		*)  PROCEDURE GmiUnionRect (VAR src1,src2: Rect; VAR dstRect: Rect);            CODE(GmiFirst+0EH);		(* VAR src1, src2 par compatibilit *)		(* Calcule le plus petit rectangle englobant les 2 rectangles donns.		   Fonctionne aussi si le rectangle de destination est le meme que		   l'une des deux sources.		*)  PROCEDURE GmiPointsToRect (Pt1, Pt2: Point; VAR dstRect: Rect);            CODE(GmiFirst+0FH);		(* Calcule le plus petit rectangle englobant les 2 rectangles donns.		   Fonctionne aussi si le rectangle de destination est le meme que		   l'une des deux sources.		*)  PROCEDURE GmiMapRect (VAR r: Rect; VAR srcRect,dstRect: Rect);            CODE(GmiFirst+010H);		(* VAR src1, src2 par compatibilit *)		(* On donne un rectangle r dans SrcRect, et MapRect le proportionne		   relativement  DstRect, selon le rapport des dimensions de DstRect		   relativement  SrcRect. Il le fait en appellant MapPt pour le point		   en haut  gauche, puis pour le point en bas  droite.		*)(* ------------------------------------------------------------------------------------------- *)(* Manipulation de rgions *)(* ======================= *)  PROCEDURE GmiNewRgn (VAR Rgn: RgnId): PsosError;            CODE(GmiFirst+011H);		(* cre une nouvelle rgion (rend l'identificateur)		   Cette fonction cre une rgion vide rectangle [(0,0),(0,0)].,		   en allouant de la place extensible. Toutes les autres routines		   ne font que modifier la taille de la rgion.		*)  PROCEDURE GmiDisposeRgn (Rgn: RgnId): PsosError;            CODE(GmiFirst+012H);		(* rend un identificateur de rgion		   A utilis lorsqu'on a entirement fini avec une rgion temporaire.		*)  PROCEDURE GmiOpenRgn (BuildRgn: RgnId; Mode: CARDINAL; VAR ClipRect: Rect): PsosError;            CODE(GmiFirst+013H);		(* VAR ClipRect par compatibilit *)		(* Permet de dfinir analytiquement une rgion.		   Mmorise dans MemoBuild toutes les lignes et surfaces fermes		   dessinnes qui dtermineront la rgion  CloseRgn.		   La rgion rgn doit auparavant tre cre avec NewRgn. Aucun appel		   autre que PutLine, PutRLine, PutRect, PutRect, PutOval et CloseRgn		   ne peut tre appell sur la rgion aprs cet appel et avant le CloseRgn		   obligatoire, sauf erreur  l'OpenRgn.		   Le dessin n'est pas limit par la rgion de clipping ni au rectangle		   de cliping courant. Par contre ClipRect permet de limiter des tracs		   inutiliss par la suite (conomie de temps et de mmoire).		   Mode: combinaison de GFillXor/GFillWinding et GFillInterior/GFillRoundUp		  	Mode de remplissage		  	GFILLXOR:	pair/impair		    ou	GFILLWINDING:	segments dirigs uniquement			GFillInterrior:	Remplit l'intrieur		    ou	GFillRoundUp:	Remplit l'intrieur et arrondit au contour		*)  PROCEDURE GmiPutLine (BuildRgn: RgnId; p1,p2: Point): PsosError;            CODE(GmiFirst+014H);		(* ajoute une droite (dirige)  coordonnes entires  la rgion (ouverte)		*)  PROCEDURE GmiPutRLine (BuildRgn: RgnId; VAR p1,p2: RealPoint): PsosError;            CODE(GmiFirst+015H);		(* VAR p1,p2 par compatibilit *)		(* ajoute une droite (dirige)  coordonnes relles  la rgion (ouverte)		*)  PROCEDURE GmiPutRect (BuildRgn: RgnId; VAR r: Rect; Way: Direction): PsosError;            CODE(GmiFirst+016H);		(* VAR r par compatibilit *)		(* ajoute un rectangle (dirige)  coordonnes relles  la rgion (ouverte).		*)  PROCEDURE GmiPutOval (BuildRgn: RgnId; VAR r: Rect; ovalWidth, ovalHeight: INTEGER;                     Way: Direction): PsosError;            CODE(GmiFirst+017H);		(* VAR r par compatibilit *)		(* ajoute une ovale ou un rectangle  coins arrondis (dirigs) 		   coordonnes entires  la rgion (ouverte).		*)  PROCEDURE GmiPutRgn (BuildRgn: RgnId; SrcRgn: RgnId; Way: Direction): PsosError;            CODE(GmiFirst+018H);		(* ajoute la rgion SrcRgn ( laquelle on associe une direction) 		   coordonnes entires  la rgion (ouverte) BuildRgn.		*)  PROCEDURE GmiCloseRgn (BuildRgn: RgnId): PsosError;            CODE(GmiFirst+019H);		(* termine la dfinition d'une rgion (ferme)		   Arrte de collectioner les objets dessinns,		   forme la rgion rsultante, et la sauve dans BuildRgn.		   doit tre fait par le mme processus qui a fait l'OpenRgn.		*)  PROCEDURE GmiRgnBBox (Region: RgnId; VAR BBox: Rect): BOOLEAN;            CODE(GmiFirst+01AH);		(* rend le "bounding box" et la nature de la rgion: TRUE si complexe		*)  PROCEDURE GmiCopyRgn (SrcRgn,DstRgn: RgnId): PsosError;            CODE(GmiFirst+01BH);		(* Copie la rgion SrcRgn dans DstRgn.		*)  PROCEDURE GmiSetEmptyRgn (Rgn: RgnId);            CODE(GmiFirst+01CH);		(* Dtruit la rgion Rgn, et la met comme tant vide (rectangle [(0,0)(0,0)}).		*)  PROCEDURE GmiSetRectRgn (Rgn: RgnId; Left,Top,Right,Bottom: INTEGER);            CODE(GmiFirst+01DH);		(* (re-)dfinit la rgion Rgn comme tant le rectangle		   [(top,left)(bottom,right)}. Traite le cas des rectangles vides		   (top>bottom ou left>right).		*)  PROCEDURE GmiRectRgn (Rgn: RgnId; VAR r: Rect);            CODE(GmiFirst+01EH);		(* VAR r par compatibilit *)		(* Dfinit la rgion Rgn comme tant le rectangle r.		   traite le cas des rectangles vides (top>bottom ou left>right).		*)  PROCEDURE GmiOffsetRgn (Rgn: RgnId; dh,dv: INTEGER);            CODE(GmiFirst+01FH);		(* Dplace toute la rgion Rgn de dh vers la droite et de dv vers le bas.		   dh et dv peuvent tre ngatifs. N'affecte ni la taille ni la forme de		   la rgion.		*)  PROCEDURE GmiInsetRgn(Rgn: RgnId; dvBottom, dvTop, dhRight, dhLeft: INTEGER): PsosError;            CODE(GmiFirst+020H);		(* Re-proportionne la rgion Rgn relativement  son centre, poussant les		   bords haut et bas de dv vers le centre, et les bords gauche et droite		   de dh vers le centre.		   dv et dh peuvent tre ngatifs.		   Le cas d'une rgion rectangulaire se rapporte  InsetRect.		   Un bloc de mmoire de 2 fois la taille de la rgion peut tre pris		   temporairement.		*)  PROCEDURE GmiEmptyRgn (Rgn: RgnId): BOOLEAN;            CODE(GmiFirst+021H);		(* Vrifie si la rgion Rgn est vide (TRUE) ou pleine (FALSE).		*)  PROCEDURE GmiEqualRgn (RgnA,RgnB: RgnId): BOOLEAN;            CODE(GmiFirst+022H);		(* Vrifie si les rgions RgnA et RgnB sont egales (TRUE) ou pas (FALSE).		   2 rgions sont gales si leur taille, forme, et emplacement sont		   identiques.		   2 rgions vides quelquonques sont toujours considres gales.		*)  PROCEDURE GmiOperRgn (SrcRgnA, SrcRgnB, DstRgn: RgnId; operation: INTEGER): PsosError;            CODE(GmiFirst+023H);		(* Effectue une opration entre 2 rgions SrcRgnA et  SrcRgnB, et place		   le rsultat dans DstRgn. DstRgn peut tre une des sources.		   L'opration peut tre de la forme:		  	GOpSect		A intersection B		  	GOpUnion	A union B		  	GOpDiff		A - B  (toute partie de A non-incluse dans B)		  	GOpXor		A ou exclusif B		   Traite le cas des rgions vides:		  	Sect:		1 rgion vide donne une intersection vide.		  	Union:		2 rgions vides donnent une union vide.		  	Diff:		si la 1re est vide, la diffrence vide.		  	Xor:		si les 2 rgions sont identiques, le XOR est					une rgion vide.		   Un bloc de mmoire de 2 fois la taille de la rgion peut tre pris		   temporairement.		*)  PROCEDURE GmiPtInRgn (Pt: Point; Rgn: RgnId): BOOLEAN;            CODE(GmiFirst+024H);		(* Teste si le point en-dessous et  droite de la coordonne Pt se trouve		   dans la rgion Rgn (TRUE) ou pas (FALSE)		*)  PROCEDURE GmiRectInRgn (VAR r: Rect; Rgn: RgnId): BOOLEAN;            CODE(GmiFirst+025H);		(* VAR r par compatibilit *)		(* Teste si le rectangle r intersecte la rgion Rgn, et rend TRUE si		   au moins un pixel se trouve  l'intrieur, et FALSE s'il n'y en a pas.		*)  PROCEDURE GmiMapRgn (Rgn: RgnId; VAR SrcRect,DstRect: Rect): PsosError;            CODE(GmiFirst+026H);		(* VAR srcRect,dstRect par compatibilit *)		(* Effectue la similitude de la rgion Rgn, selon le rapport de dstRect		   par rapport  srcRect. La rgion sera aussi centre en dstRect, dans		   les mmes rapports qu'elle l'tait relativement  srcRect.		   Pour ce faire, appelle la procdure MapPt pour tous les points de la rgion.		*)  PROCEDURE GmiRgnToBitMap (Rgn: RgnId; VAR DstBits: BitMap; Mode: GraTransMode): PsosError;            CODE(GmiFirst+027H);		(* VAR dstBits par compatibilit *)		(* transforme une rgion en bitmap (mmoire) en effectuant		   l'opration selon le mode de transfert, et en limitant le dessin		   au rectangle de contour du bitmap		*)  CONST     LgBldRgn = 24+2+(1024 DIV 8)+8;	(* longueur vars pour INITSRGN, SEEKSRGN, RELSRGN *)  TYPE     ScanRgnVars = ARRAY[0..LgBldRgn-1] OF BYTE;     ScanRgnVarsPt = POINTER TO ScanRgnVars;          MaskRowPtr = ADDRESS;          SeekSRgnProc = PROCEDURE (ScanRgnVarsPt,INTEGER, VAR MaskRowPtr): INTEGER;					(* calcul de la ligne no y (INTEGER) dans une ligne bitmap					*)  PROCEDURE GmiInitSRgn (Region: RgnId; PtVars: ScanRgnVarsPt; 	                MinLeft, MaxRight, LeftmostBit: INTEGER; Way: Direction;	                VAR SEEKfuncPtr: SeekSRgnProc) : PsosError;            CODE(GmiFirst+028H);		(* initialise une ligne de bitmap vide.		   ATTENTION: ne marche que pour des rgions complexes !		*)  PROCEDURE GmiRelSRgn (PtVars: ScanRgnVarsPt): PsosError;            CODE(GmiFirst+029H);		(* rend les variables de la ligne de bitmap		   Attention: doit tre appell par le mme processus que celui qui a appel		   le INITSRGN correspondant.		   Peut tre appell mme si INITSRGN a rendu une erreur		*)END Gmi.