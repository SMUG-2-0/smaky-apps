	.TITLE	RGN.ASC	.PROC	M68000	.REF	SMAKY	.REF	GRAMISC;================================================; PROGRAMME DE DEMOEXSMILE	=	1	.LOC	0OSRCRGNA:	.BLK.32	1OSRCRGNB:	.BLK.32	1ODSTRGN:	.BLK.32	1OPTSEEK:	.BLK.32	1OPTDIS:		.BLK.32	1OCHANGM:	.BLK.16	1OBITMAP:	.BLK.8	LGGBMAPLGVAR:.macro	dlib	?AFTIM.ascize	"(%1) "lib	?getcar.endmacro	.LOC	0	.START	STARTSTART:	.IF	EXSMILE	.ELSE	LIB	?OPELIB	MOVE.32	#LGVAR,D4	GESMEM	?GETMEM	.ENDIF	MOVE.32	A4,A6		; ^vars	MOVE.32	#R16^TXGRAMISC,A3	MOVE.16	#GMI_FIRST,D3	LIB_	OPEN	JUMP,NE	EROR$	MOVE.16	D1,{A6}+OCHANGM	MOVE.16	#0,D3	LIB	?MOUSE	MOVE.32	#{A6}+OPTDIS,A4	MOVE.32	#4,D4	LIB	?GCHDIS	FOS	?RSTATUS	JUMP,EQ	OK$	LIB	?AFERROROK$:	GMI_	NEWRGN	MOVE.32	A4,{A6}+OSRCRGNA	GMI_	NEWRGN	MOVE.32	A4,{A6}+OSRCRGNB	GMI_	NEWRGN	MOVE.32	A4,{A6}+ODSTRGN.IF	0	PUSH.32	{A6}+OSRCRGNA	PUSH.16	#60		; left	PUSH.16	#30		; top	PUSH.16	#300		; right	PUSH.16	#200		; bottom	CALL	SETRECTRGN	PUSH.32	{A6}+OSRCRGNB	PUSH.16	#250		; left	PUSH.16	#100		; top	PUSH.16	#500		; right	PUSH.16	#300		; bottom	CALL	SETRECTRGN	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion A:"	MOVE.32	{A6}+OSRCRGNA,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion B:"	MOVE.32	{A6}+OSRCRGNB,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR.ENDIF 0OPER$:	SUB.32	#2,SP	PUSH.32	{A6}+OSRCRGNA	PUSH.32	{A6}+OSRCRGNB	PUSH.32	{A6}+ODSTRGN	PUSH.16	#GOpsect	GMI_	OPERRGN	POP.16	D7	JUMP,NE	EROR$	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion intersection:"	MOVE.32	{A6}+ODSTRGN,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR	SUB.32	#2,SP	PUSH.32	{A6}+OSRCRGNA	PUSH.32	{A6}+OSRCRGNB	PUSH.32	{A6}+ODSTRGN	PUSH.16	#GOpunion	GMI_	OPERRGN	POP.16	D7	JUMP,NE	EROR$	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion UNION:"	MOVE.32	{A6}+ODSTRGN,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR	SUB.32	#2,SP	PUSH.32	{A6}+OSRCRGNA	PUSH.32	{A6}+OSRCRGNB	PUSH.32	{A6}+ODSTRGN	PUSH.16	#GOpdiff	GMI_	OPERRGN	POP.16	D7	JUMP,NE	EROR$	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion diffrence A-B:"	MOVE.32	{A6}+ODSTRGN,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR	SUB.32	#2,SP	PUSH.32	{A6}+OSRCRGNA	PUSH.32	{A6}+OSRCRGNB	PUSH.32	{A6}+ODSTRGN	PUSH.16	#GOpxor	GMI_	OPERRGN	POP.16	D7	JUMP,NE	EROR$	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion OU-exclusif:"	MOVE.32	{A6}+ODSTRGN,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR.if 0	PUSH.32	{A6}+ODSTRGN	PUSH.16	#100	PUSH.16	#50	CALL	OFFSETRGN	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion OU-exclusif, OFFSETe de (100,50):"	MOVE.32	{A6}+ODSTRGN,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR	PUSH.32	{A6}+ODSTRGN	PUSH.16	#-10	PUSH.16	#-10	CALL	INSETRGN	LIB	?AFTIM	.ASCIZE	"<EOP>La mme rgion Insete de (-10,-10):"	MOVE.32	{A6}+ODSTRGN,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR.endif 0	LIB	?AFTIM	.ASCIZE	"<CR>Dtection de points (I)n (O)out: X"RETEST$:	LIB	?IFMOUSE	PUSH.16	#0	PUSH.32	D4	PUSH.32	{A6}+ODSTRGN	GMI_	PTINRGN	POP.16	D7	JUMP,EQ	NOTIN$	LIB	?AFTIM	.ASCIZE	"<BS>I"	JUMP	KEY$NOTIN$:		LIB	?AFTIM	.ASCIZE	"<BS>O"KEY$:	LIB	?IFCAR	JUMP,NE	RETEST$	LIB	?AFTIM	.ASCIZE	"<CR><CR>Voulez-vous encore dfinir des rgions quelconques ? "	LIB	?YESNO	JUMP,NE	FINDEMO$	LIB	?AFTIM	.ASCIZE	"<EOP>Dessinez une rgion A (GAUCHE: pose point, CENTRE: round-rect, DROITE: finit) "	MOVE.32	{A6}+OSRCRGNA,A4	CALL	DEFINEMOUS	LIB	?AFTIM	.ASCIZE	"<EOP>La rgion A, Dfinie:"	MOVE.32	{A6}+OSRCRGNA,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?AFTIM	.ASCIZE	"<CR>Dessinez une rgion B (GAUCHE: pose point, CENTRE: round-rect, DROITE: finit) "	MOVE.32	{A6}+OSRCRGNB,A4	CALL	DEFINEMOUS	LIB	?AFTIM	.ASCIZE	"<cr>La rgion B, Dfinie: (APPUIEZ SUR SPACE)"	MOVE.32	{A6}+OSRCRGNB,A1	MOVE.16	#GMOR,D2	CALL	AFRGN	LIB	?AFTIM	.ASCIZE	"La rgion B est de complexit: "	SUB.32	#8+2,SP	PUSH.32	{A6}+OSRCRGNB	PUSH.32	#{SP}+4+2	GMI_	RGNBBOX	POP.16	D4	LIB	?AFX4,?AFTIM	.ASCIZE	" et de BBox: "	MOVE.16	#4-1,D3LBBOX$:	POP.16	D4	LIB	?AFX4,?AFSPACE	DJ.16,NMO D3,LBBOX$	LIB	?AFCR,?GETCAR	LIB	?AFTIM	.ASCIZE	"<CR>La rgion B affiche avec INITSRGN,SEEKSRGN,RELSRGN:"	MOVE.32	{A6}+OSRCRGNB,A1	MOVE.16	#GMOR,D2	CALL	AFRGNSEEK	MOVE.32	{A6}+OSRCRGNB,A4	MOVE.32	#16'ffff0000,D3	MOVE.32	#16'0000ffff,D4	GMI_	INSETRGN	LIB	?AFTIM	.ASCIZE	"<cr>La mme rgion Insete de [(-1,0),(0,-1)]:"	MOVE.32	{A6}+OSRCRGNB,A1	MOVE.16	#GMXOR,D2	CALL	AFRGN	LIB	?GETCAR	JUMP	OPER$FINDEMO$:	MOVE.32	{A6}+OSRCRGNA,A4	GMI_	DISPOSERGN	MOVE.32	{A6}+OSRCRGNB,A4	GMI_	DISPOSERGN	MOVE.32	{A6}+ODSTRGN,A4	GMI_	DISPOSERGN	MOVE.16	{A6}+OCHANGM,D1	LIB_	CLOSEEROR$:	.IF	EXSMILE	EXIT	.ELSE	LIB	?CLOLIB	FOS	?STOP	.ENDIFAFRGN:	MOVE.32	A1,A4	MOVE.32	{A6}+OPTDIS,A2	MOVE.32	#0,{A6}+OBITMAP+OGBMAPRECT+OGRECTTL	MOVE.16	{A2}+ODFDY,D4	SWAP.32	D4	MOVE.16	{A2}+ODFDX,D4	MOVE.32	D4,{A6}+OBITMAP+OGBMAPRECT+OGRECTBR	MOVE.16	{A2}+ODFY,D0	MUL.16	{A2}+ODFIIY,D0	CLR.32	D1	MOVE.16	{A2}+ODFX,D1	SR.32	#3,D1			; /8 bits/byte	ADD.32	D1,D0	ADD.32	{A2}+ODFABS,D0	MOVE.32	D0,{A6}+OBITMAP+OGBMAPPT	MOVE.16	#10'1024/8,{A6}+OBITMAP+OGBMAPWIDTH	MOVE.32	#{A6}+OBITMAP,A2;;EXIT	GMI_	RGNTOBITMAP;;EXIT	RETAFRGNSEEK:	SUB.A16	#2+LGBLDRGN,SP	PUSH.32	A1	PUSH.32	#{SP}+4+2	PUSH.16	#0	PUSH.16	#10'864	PUSH.16	#0	PUSH.16	#-1	PUSH.32	#{A6}+OPTSEEK		      ^ symbol value undefined	GMI_	INITSRGN	POP.16	D4	LIB	?AFX4LIB ?GETCAR	MOVE.16	#10'700-1,D3	MOVE.32	{A6}+OPTDIS,A2	MOVE.16	{A2}+ODFY,D0	MUL.16	{A2}+ODFIIY,D0	CLR.32	D1	MOVE.16	{A2}+ODFX,D1	SR.32	#3,D1			; /8 bits/byte	ADD.32	D1,D0	ADD.32	{A2}+ODFABS,D0	ADD.32	#(10'1024/8)*(10'700-1),D0	MOVE.32	D0,A2SK$:	SUB.32	#2+4,SP	PUSH.32	#{SP}+2+4	PUSH.16	D3	PUSH.32	#{SP}+2+4+2	MOVE.32	{A6}+OPTSEEK,A0		     ^ symbol value undefined	CALL	{A0}			; SEEKSRGN	POP.16	D4	POP.32	A0	MOVE.16	#10'864/16-1,D0TR$:	MOVE.16	{A0+},{A2+}	DJ.16,NMO D0,TR$	ADD.A16	#-10'1024/8-10'864/8,A2	DEC.16	D3	JUMP,CC	SK$LIB ?AFSPACE,?AFX4LIB ?GETCAR	SUB.32	#2,SP	PUSH.32	#{SP}+2	GMI_	RELSRGN	POP.16	D4LIB ?AFSPACE,?AFX4,?GETCAR	ADD.A16	#LGBLDRGN,SP;;EXIT	RET; in	A4 ^rgion...DEFINEMOUS:	MOVE.16	#GFILLXOR,D3	GMI_	OPENRGNFIRSTPT$:	LIB	?IFMOUSE	TEST.8	D3	JUMP,EQ	FIRSTPT$	TEST.32	D3:#BMOCENT	JUMP,BS	DOOVAL$	TEST.32	D3:#BMORIGHT	JUMP,BS	ENDMOU$;;;	TEST.32	D3:#BMOLEFT	PUSH.32	D4		; D3 tats boutonsONEMORE$:	MOVE.32	#0,D5	MOVE.32	D4,D6NEXTPT$:	PUSH.16	D3	LIB	?IFMOUSE	POP.16	D1	PUSHM.32 D3|D4	PUSH.32	D4	MOVE.32	D6,D3	MOVE.32	D5,D4	MOVE.16	#INVDOT,D2	LIB	?DRSEG		; enlve le prcdent	POP.32	D4	MOVE.32	D6,D3	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	MOVE.32	D4,D5	LIB	?DRSEG		; affiche le nouveau	POPM.32	D3|D4	MOVE.16	D3,D7	XOR.16	D7,D1	AND.16	D1,D7		; D7 <= boutons appuys;;	TEST.32	D7:#BMOCENT;;	JUMP,BS	FIRSTPT$	TEST.32	D7:#BMORIGHT	JUMP,BS	ENDMOU$	TEST.32	D7:#BMOLEFT	JUMP,BC	NEXTPT$	PUSH.32	D3	MOVE.32	D6,D3	GMI_	PUTLINE			; D4 ^dj	POP.32	D3	JUMP	ONEMORE$DOOVAL$:		; D3 tats boutons	MOVE.32	#0,D5	MOVE.32	D4,D6NEXTOV$:	PUSH.16	D3	LIB	?IFMOUSE	POP.16	D1	PUSHM.32 D3|D4	PUSH.32	D4	MOVE.32	D6,D3	MOVE.32	D5,D4	MOVE.16	#INVDOT,D2	LIB	?DRRECT		; enlve le prcdent	POP.32	D4	MOVE.32	D6,D3	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	MOVE.32	D4,D5	LIB	?DRRECT		; affiche le nouveau	POPM.32	D3|D4	MOVE.16	D3,D7	XOR.16	D7,D1	AND.16	D1,D7		; D7 <= boutons appuys	TEST.32	D1:#BMOCENT	JUMP,BC	NEXTOV$	TEST.32	D3:#BMORIGHT	JUMP,BS	VRAIOVALE$.if	0	PUSH.32	D4	PUSH.32	D6	PUSH.32	A7	PUSH.16	#32	PUSH.16	#16	CALL	PUTOVAL	ADD.32	#8,A7.endif	JUMP	END$VRAIOVALE$:.if	0	PUSH.32	D4	PUSH.32	D6	PUSH.32	A7		; ^rect	PUSH.16	{A7}+4+6	; right	MOVE.16	{A7}+6+2,D0	SUB.16	D0,{A7}		; -left	PUSH.16	{A7}+6+4	; bottom	MOVE.16	{A7}+8+0,D0	SUB.16	D0,{A7}		; -top	CALL	PUTOVAL	ADD.32	#8,A7.endifWAITREL$:	LIB	?IFMOUSE	TEST.8	D3	JUMP,NE	WAITREL$	JUMP	END$ENDMOU$:	LIB	?IFMOUSE	TEST.8	D3	JUMP,NE	ENDMOU$	MOVE.32	D6,D3	POP.32	D4	GMI_	PUTLINEEND$:	GMI_	CLOSERGN	RETTXGRAMISC:	.ASCIZE	"TGRAMIS"	.END