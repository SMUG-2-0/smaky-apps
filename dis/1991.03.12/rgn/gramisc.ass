	.TITLE	GRAMISC.ASS	.PROC	M68000	.BASE	10'10		; base 10 par dfaut;;	.LAYOUT	HEX		; listing en hexadcima;-----------------------------------------------;;	Pour trouver tout ce qui est nouveau,	;;	cherchez -NEW- avec l'diteur !		;;-----------------------------------------------;; Constantes utiles; -----------------; Dfinition d'un point  coordonnes entires:		.LOC	0OGPTY:		.BLK.16	1	; coordonne yOGPTX:		.BLK.16	1	; et x ... du point en haut  gauche du pixelLGGPT:; Dfinition d'une coordonnes  virgule fixe:		.LOC	0OGPTRY:		.BLK.32	1	; coordonne yOGPTRX:		.BLK.32	1	; et xLGGPTR:; Dfinition d'un rectangle:		.LOC	0OGRECTTL:	.BLK.8	LGGPT	; (Top Left) Point en haut  gauche du rectangleOGRECTBR:	.BLK.8	LGGPT	; (Bottom Right) exceptionnnellement, le pixel est en haut  gaucheLGGRECT:; Dfinition d'un bitmap:		.LOC	0OGBMAPPT:	.BLK.32	1	; ^au bitmapOGBMAPWIDTH:	.BLK.16	1	; [cardinal, PAIR]: largeur du bitmap en bytesOGBMAPRECT:	.BLK.8	LGGRECT	; rectangle englobant (TL: origine, BR-TL: dimensions)LGGBMAP:; Modes de transfert:;	paires:	destination-source;	bits:	00 01 10 11GMZero		=	2'0000	; 0		-GMAnd		=	2'0001	; s*dGMBic		=	2'0010	; /s*dGMNop		=	2'0011	; d !!!!!	-GMAndI		=	2'0100	; s*/d		-GMCopy		=	2'0101	; sGMXor		=	2'0110	; /s*d + s*/dGMOr		=	2'0111	; s+dGMOrInv		=	2'1000	; /(s+d)	-GMNotXor	=	2'1001	; /s*/d + s*dGMNotCopy	=	2'1010	; /sGMNotOr		=	2'1011	; /s + dGMInvD		=	2'1100	; /d !!!!!	-GMInvOr		=	2'1101	; s + /d	-GMNand		=	2'1110	; /s + /d = /(s*d)	-GMOne		=	2'1111	; 1; Modes de remplissage:GFillXor	=	0	; par comptage pair/impair du nombre de limites de rgionGFillWinding	=	1	; par comptage du nombre de segments dirigs.				; direction positive: sens des aiguilles d'une montre.GFillInterior	=	0	; remplissage de l'intrieur uniquementGFillRoundUp	=	2	; remplissage de l'intrieur et du pourtour; Oprations de calcul:GOpSect		=	0	; A intersection BGOpUnion	=	4	; A union BGOpDiff		=	2	; A - B  (toute partie de A non-incluse dans B)GOpXor		=	6	; A ou exclusif B; Longueur pour INITSRGN:LgBldRgn	=	10'24+2+10'1024/8+8	; longueur vars pour INITSRGN, SEEKSRGN, RELSRGN; Numros des appels; ------------------GMI_FIRST	=	16'A440		; SMA_GRAMDIF.LIB avec A470 !!! (sinon A440)	.SYSCALL.16	GMI_GMI_Mul32	= GMI_FIRST+16'0	; multiplication 64 bitsGMI_Div32	= GMI_FIRST+16'1	; division 64 bitsGMI_FixRatio	= GMI_FIRST+16'2	; conversion entier --> virgule fixeGMI_FixMul	= GMI_FIRST+16'3	; multiplication  virgule fixeGMI_FixDiv	= GMI_FIRST+16'4	; division signe  virgule fixeGMI_FixDivUnsigned= GMI_FIRST+16'5	; division non-signe  virgule fixeGMI_FixDiv64	= GMI_FIRST+16'6	; division signe  virgule fixe d'un nombre 64 bits/32 bitsGMI_AddPt	= GMI_FIRST+16'7	; addition de 2 pointsGMI_SubPt	= GMI_FIRST+16'8	; soustraction de 2 pointsGMI_PtInRect	= GMI_FIRST+16'9	; test d'appartenance d'un point  un rectangleGMI_MapPt	= GMI_FIRST+16'A	; recalcule un point dans la similitude entre 2 rectanglesGMI_EmptyRect	= GMI_FIRST+16'B	; teste si un rectangle est videGMI_InsetRect	= GMI_FIRST+16'C	; Corrige les dimensions d'un rectangleGMI_SectRect	= GMI_FIRST+16'D	; Intersection entre 2 rectanglesGMI_UnionRect	= GMI_FIRST+16'E	; Union entre 2 rectanglesGMI_PointsToRect= GMI_FIRST+16'F	; Forme en rectangle de 2 pointsGMI_MapRect	= GMI_FIRST+16'10	; recalcule un rectangle dans la similitude entre 2 rectanglesGMI_NewRgn	= GMI_FIRST+16'11	; cre une nouvelle rgion (demande l'identificateur)GMI_DisposeRgn	= GMI_FIRST+16'12	; rend un identificateur de rgionGMI_OpenRgn	= GMI_FIRST+16'13	; dbute la dfinition d'une rgion (ouvre)GMI_PutLine	= GMI_FIRST+16'14	; ajoute une droite  la rgion (ouverte)GMI_PutRLine	= GMI_FIRST+16'15	; ajoute une droite en coord. relle  la rgion (ouverte)GMI_PutRect	= GMI_FIRST+16'16	; ajoute un rectangle  la rgion (ouverte)GMI_PutOval	= GMI_FIRST+16'17	; ajoute une elipse  la rgion (ouverte)GMI_PutRgn	= GMI_FIRST+16'18	; ajoute une rgion  la rgion (ouverte)GMI_CloseRgn	= GMI_FIRST+16'19	; termine la dfinition d'une rgion (ferme)GMI_RgnBBox	= GMI_FIRST+16'1A	; rend le "bounding box" et la nature de la rgionGMI_CopyRgn	= GMI_FIRST+16'1B	; Copie une rgion dans une autreGMI_SetEmptyRgn	= GMI_FIRST+16'1C	; Met une rgion comme videGMI_SetRectRgn	= GMI_FIRST+16'1D	; Met une rgion selon 4 coordonnes d'un rectangleGMI_RectRgn	= GMI_FIRST+16'1E	; Met une rgion selon un rectangleGMI_OffsetRgn	= GMI_FIRST+16'1F	; dplace une rgionGMI_InsetRgn	= GMI_FIRST+16'20	; dplace sparment les 4 frontires haut,gauche,bas,droiteGMI_EmptyRgn	= GMI_FIRST+16'21	; teste si une rgion est videGMI_EqualRgn	= GMI_FIRST+16'22	; teste si 2 rgions sont identiquesGMI_OperRgn	= GMI_FIRST+16'23	; effectue une opration entre 2 rgionsGMI_PtInRgn	= GMI_FIRST+16'24	; teste si le point se trouve dans la rgionGMI_RectInRgn	= GMI_FIRST+16'25	; teste si un rectangle est dans une rgionGMI_MapRgn	= GMI_FIRST+16'26	; recalcule une rgion dans la similitude entre 2 rectanglesGMI_RgnToBitMap	= GMI_FIRST+16'27	; transforme une rgion en bitmap (mmoire)GMI_InitSrgn	= GMI_FIRST+16'28	; initialise une ligne de bitmap videGMI_RelSRgn	= GMI_FIRST+16'29	; rend les variables de la ligne de bitmapGMI_LAST	=	GMI_RelSRgn;=============================================================================================;   D  E  S  C  R  I  P  T  I  O  N     D  E  S     A  P  P  E  L  S  .;=============================================================================================; Calculs sur nombres 64 bits; ---------------------------;---------------\\;  _GMI_Mul32    >;===============/; FONCTION Mul32(a,b: LONGCARD): CARDINAL64;; module de multiplication 32*32-->64 bits; in	SP^;	+8.64	RESULT:		place pour rsultat;	+4.32		a;	+0.32		b; out	SP^;	+0.64	RESULT:	a*b; mod	F;---------------\\;  _GMI_Div32    >;===============/; PROCEDURE Div32 (Numer: CARDINAL64; Denom: LONGCARD;;                  VAR Result, Remainder: LONGCARD; VAR Over: BOOLEAN);; division 64 bits-->32 bits reste 32 bits; in	SP^;	+16.32	^Numer;	+12.32	Denom;	+8.32	^Result;	+4.32	^Remainder;	+0.32	^Over; out	-;	Result,Remainder,Over; mod	F; Calculs sur nombres  virgule fixe; ----------------------------------; Format des nombres: 32 bits, dont 16 bits entiers, et 16 bits fractionnaires.;;  15             0  -1               -16; 2              2  2                2; -------------------------------------; !   16 bits      !     16 bits      !; -------------------------------------; 32768           1  1/2             1/65536;  partie entire    partie fractionnaire;; exemple:	1.0  =	16'00010000;		0.5  =	16'00008000;		8.0  =	16'00080000;		8.75 =	16'0008C000;-------------------\\;   _GMI_FixRatio    >;===================/; FixRatio (numer, denom: INTEGER): Fixed;	(Fixed: 32 bits: 16 bits entier, 16 bits fractionnaire); in	SP^;	+4.32	RESULT:		place pour rsultat;	+2.16		numer;	+0.16		denom; out	SP^;	+0.32	RESULT:	Fixed; mod	F;-----------------\\;   _GMI_FixMul    >;=================/; FONCTION FixMul (a, b: Fixed): Fixed;; in	SP^;	+8.32	RESULT:		place pour rsultat;	+4.32		a;	+0.32		b; out	SP^;	+0.32	RESULT:	Fixed; mod	F;-----------------\\;   _GMI_FixDiv    >;=================/; FONCTION FixDiv (Numer, Denom: Fixed): Fixed;; in	SP^;	+8.32	RESULT:		place pour rsultat;	+4.32		Numer;	+0.32		Denom; out	SP^;	+0.32	RESULT:	Fixed; mod	F;-------------------------\\;   _GMI_FixDivUnsigned    >;=========================/; FONCTION FixDivUnsigned (Numer, Denom: Fixed): Fixed;; in	SP^;	+8.32	RESULT:		place pour rsultat;	+4.32		Numer;	+0.32		Denom; out	SP^;	+0.32	RESULT:	Fixed; mod	F;-------------------\\;   _GMI_FixDiv64    >;===================/; FONCTION FixDiv64 (Numer: Fixed64; Denom: Fixed): Fixed;; in	SP^;	+8.32	RESULT:		place pour rsultat;	+4.32		^Numer.64;	+0.32		Denom; out	SP^;	+0.32	RESULT:	Fixed; mod	F; Manipulation de points; ----------------------;----------------\\;  _GMI_AddPt     >				-NEW-;================/; FUNCTION AddPt(PtA, PtB: Point): Point;; Additionne les coordonnes de PtB  PtA et rend le rsultat.; in	SP^;	+8.32	place pour rsultat;	+4.32	PtA;	+0.32	PtB; out	SP^;	+0.32	rsultat: PtA-PtB; mod	F;----------------\\;  _GMI_SubPt     >				-NEW-;================/; FUNCTION SubPt(PtA, PtB: Point): Point;; Soustrait les coordonnes de PtB  PtA et rend le rsultat.; in	SP^;	+8.32	place pour rsultat;	+4.32	PtA;	+0.32	PtB; out	SP^;	+0.32	rsultat: PtA-PtB; mod	F;-----------------\\;  _GMI_PtInRect   >;=================/; FUNCTION PtInRect (pt: Point; r: Rect):BOOLEAN;; Teste si le point  droite et en-dessous du point donn; est inclus dans le rectangle donn. Rend TRUE si le; point se trouve  l'intrieur, FALSE sinon.;; in	SP^;	+8.16	place pour BOOLEAN (rendu en retour);	+4.32	pt;	+0.32	^r; out	SP^;	+0.8	BOOLEAN (=1 TRUE, =0 FALSE); mod	F;-----------------\\;  _GMI_MapPt      >;=================/; PROCEDURE MapPt (VAR pt: Point; srcRect,dstRect: Rect);; On donne un point pt dans SrcRect, et MapPt le repositionne; relativement  DstRect (coordonnes absolues), selon le rapport; des dimensions de DstRect relativement  SrcRect.;; in	SP^;	+8.32	^pt	(rendu en retour);	+4.32	^srcRect;	+0.32	^dstRect; out	pt; mod	F; Manipulation de rectangles; --------------------------;-------------------\\;  _GMI_EmptyRect    >;===================/; FUNCTION EmptyRect (r: Rect): BOOLEAN;; Rend si le rectangle est vide (TRUE=1) ou pas (FALSE=0).; (comparaison par top<bottom et left<right); in	SP^;	+4.16	RESULT:		place pour rsultat;	+0.32	^Rect; out	SP^;	+0.16	RESULT:	BOOLEAN (dans byte de poids fort); mod	F;-------------------\\;  _GMI_InsetRect    >;===================/; PROCEDURE InsetRect (VAR r: Rect; dvBottom, dvTop, dhRight, dhLeft: INTEGER);; Extension (valeurs ngatives de dh ou dv) ou diminution (valeurs positives); d'un rectangle relativement  son centre; les cots gauche et droite bougent chacun de dhLeft, resp. dhRight.; le haut et le bas bougent chacun de dvTop, resp. dvBottom.; l'effet est que les dimensions du rectangle diminuent de dvTop+dvBottom, et; de dhLeft+dhRight; le rectangle peut devenir vide ( [(0,0),(0,0)] ).; Un rectangle vide est agrandit uniquement autour de l'origine; in	SP^;	+8.32	^rect;	+4.32	dvTop;dvBottom;	+0.32	dhLeft;dhRight; out	SP^	rien;	Result,Remainder,Over; mod	F;------------------\\;  _GMI_SectRect    >;==================/; FUNCTION SectRect (src1,src2: Rect; VAR dstRect: Rect) : BOOLEAN;;; Calcule l'intersection de 2 rectangles et rend si les deux; rectangles intersectent ou pas. Fonctionne aussi si le rectangle; de destination est le meme que l'une des deux sources.; Si intersection ensemble vide, rend le rectangle [(0,0)(0,0)].;; in	SP^;	+12.16	BOOLEAN	(TRUE=1 si intersection, FALSE=0 si ensemble vide);			(valeur boolenne dans bit zro) ( rendre);	+8.32	^src1Rect;	+4.32	^src2Rect;	+0.32	^dstRect; out	SP^;	+0.16	RESULT:	BOOLEAN (dans byte de poids fort); mod	F;-------------------\\;  _GMI_UnionRect    >;===================/; PROCEDURE UnionRect (src1,src2: Rect; VAR dstRect: Rect);;; Calcule le plus petit rectangle englobant les 2 rectangles donns.; Fonctionne aussi si le rectangle de destination est le meme que; l'une des deux sources.;; in	SP^;	+8.32	^src1Rect;	+4.32	^src2Rect;	+0.32	^dstRect; out	-; mod	F;----------------------\\;  _GMI_PointsToRect    >;======================/; PROCEDURE PointsToRect (pt1, pt2: Point; VAR dstRect: Rect);;; Calcule le plus petit rectangle englobant les 2 rectangles donns.; Fonctionne aussi si le rectangle de destination est le meme que; l'une des deux sources.;; in	SP^;	+8.32	pt1;	+4.32	pt2;	+0.32	^dstRect; out	-; mod	F;--------------------\\;  _GMI_MapRect       >;====================/; On donne un rectangle r dans SrcRect, et MapRect le proportionne; relativement  DstRect, selon le rapport des dimensions de DstRect; relativement  SrcRect. Il le fait en appellant MapPt pour le point; en haut  gauche, puis pour le point en bas  droite.;; PROCEDURE MapRect (VAR r: Rect; srcRect,dstRect: Rect);; in:	SP^;	+8.32	^r	(rempli en retour);	+4.32	^srcRect;	+0.32	^dstRect; out	r	mis  jour; mod	F; Manipulation de rgions; -----------------------;-----------------\\;  _GMI_NewRgn     >;=================/; FUNCTION NewRgn (VAR rgn: RgnHandle): PsosError; cre une nouvelle rgion (rend l'identificateur); Cette fonction cre une rgion vide rectangle [(0,0),(0,0)].,; en allouant de la place extensible. Toutes les autres routines; ne font que modifier la taille de la rgion.; in	SP^;	+4.16	Place pour PsosError;	+0.32	^VAR rgn; out	SP^;	+0.16	PsosError; mod	F;-------------------\\;  _GMI_DisposeRgn   >;===================/; FUNCTION DisposeRgn (rgn: RgnHandle): PsosError;; rend un identificateur de rgion; A utilis lorsqu'on a entirement fini avec une rgion temporaire.; in	SP^;	+4.16	Place pour PsosError;	+0.32	rgn; out	SP^;	+0.16	PsosError; mod	F;------------------\\;  _GMI_OPENRGN     >;==================/; FUNCTION OpenRgn ( rgn: rgnHandle; Mode: CARDINAL; ClipRect: Rect): PsosError;;; Permet de dfinir analytiquement une rgion.; Mmorise dans rgn toutes les lignes et surfaces fermes; dessinnes qui dtermineront la rgion  CloseRgn.; La rgion rgn doit auparavant tre cre avec NewRgn. Aucun appel; autre que PutLine, PutRLine, PutRect, PutRect, PutOval et CloseRgn; ne peut tre appell sur la rgion aprs cet appel et avant le CloseRgn; obligatoire, sauf erreur  l'OpenRgn.; Le dessin n'est pas limit par la rgion de clipping ni au rectangle; de cliping courant. Par contre ClipRect permet de limiter des tracs; inutiliss par la suite (conomie de temps et de mmoire).; Mode: combinaison de GFillXor/GFillWinding et GFillInterior/GFillRoundUp;	Mode de remplissage;	GFILLXOR:	pair/impair;	GFILLWINDING:	segments dirigs uniquement; in	SP^;	+10.16	place pour PsosError;	+6.32	rgn			-NEW-;	+4.16	Mode;	+0.32	^ClipRect; out	SP^;	+0.16	PsosError; mod	F;-----------------\\;  _GMI_PUTLINE    >;=================/; FUNCTION PutLine (rgn: RgnHandle; p1,p2: Point): PsosError;; ajoute une droite (dirige)  coordonnes entires  la rgion (ouverte); in	SP^;	+12.16	place pour PsosError;	+8.32	RgnHandle		-NEW-;	+4.32	p1;	+0.32	p2; out	SP^;	+0.16	PsosError; mod	F;-----------------\\;  _GMI_PutRLine   >;=================/; FUNCTION PutRLine (rgn: RgnHandle; p1,p2: RealPoint): PsosError;; ajoute une droite (dirige)  coordonnes relles  la rgion (ouverte); in	SP^;	+12.16	place pour PsosError;	+8.32	rgn			-NEW-;	+4.32	^p1 (push.32 x, push.32 y  =  y;x);	+0.32	^p2; out	SP^;	+0.16	PsosError; mod	F;-----------------\\;  _GMI_PutRect    >;=================/; FUNCTION PutRect (rgn: RgnHandle; r: Rect, Way: Direction): PsosError;; ajoute un rectangle (dirige)  coordonnes relles  la rgion (ouverte); in	SP^;	+10.16	place pour PsosError;	+6.32	rgn			-NEW-;	+2.32	^r;	+0.8	Way (0 positif, 1 negatif); out	SP^;	+0.16	PsosError; mod	F;-----------------\\;  _GMI_PutOval    >;=================/; FUNCTION PutOval (rgn: RgnHandle; r: Rect, ovalWidth, ovalHeight: INTEGER;;                   Way: Direction): PsosError;; ajoute une ovale ou un rectangle  coins arrondis (dirigs)  coordonnes entires;  la rgion (ouverte); in	SP^;	+14.16	place pour PsosError;	+10.32	rgn			-NEW-;	+6.32	^r;	+4.16	ovalWidth;	+2.16	ovalHeight;	+0.8	Way (0 positif, 1 negatif); out	SP^;	+0.16	PsosError; mod	F;-----------------\\;  _GMI_PutRgn     >;=================/; FUNCTION PutRgn (BuildingRgn: RgnHandle; srcRgn: RgnHandle, Way: Direction): PsosError;; ajoute une rgion ( laquelle on associe une direction)  coordonnes relles  la rgion (ouverte); in	SP^;	+10.16	place pour PsosError;	+6.32	BuildingRgn		-NEW-;	+2.32	srcRgn;	+0.8	Way (0 positif, 1 negatif); out	SP^;	+0.16	PsosError; mod	F;------------------\\;  _GMI_CLOSERGN    >;==================/; FUNCTION CloseRgn ( rgn: RgnHandle): PsosError;; termine la dfinition d'une rgion (ferme); Arrte de collectioner les objets dessinns,; forme la rgion rsultante, et la sauve dans dstRgn.; doit tre fait par le mme processus qui a fait l'OPENRGN.; in	SP^;	+4.16	place pour PsosError;	+0.32	dstRgn			-NEW-; out	SP^;	+0.16	PsosError; mod	F;-----------------\\;  _GMI_RgnBBox    >;=================/; RgnBBox (Region: RgnId, VAR BBox: Rectangle): BOOLEAN;;; rend le "bounding box" et la nature de la rgion; in	SP^:;	+8.16	RESULT:		place pour rsultat;	+4.32	Region		identificateur de rgion;	+0.32	BBox: VAR	^variable de 8 bytes de type Rectangle; out		{BBox}:		rectangle englobant la rgion: [(0,0);(0,0)] si rgion vide;	SP^:;	+0.8	RESULT:		=0  ==> rgion rectangulaire;				=1  ==> rgion complexe; mod	F;-----------------\\;  _GMI_CopyRgn    >;=================/; FONCTION CopyRgn (srcRgn,dstRgn: RgnHandle): PsosError;;; Copie la rgion srcRgn dans dstRgn.;; in	SP^;	+8.16	place pour PsosError;	+4.32	^srcRgn;	+0.32	^dstRgn; out	SP^;	+0.16	PsosError;----------------------\\;  _GMI_SetEmptyRgn     >;======================/; FUNCTION SetEmptyRgn (rgn: RgnHandle);;; Dtruit la rgion rgn, et la met comme tant vide (rectangle [(0,0)(0,0)}).;; in	SP^;	+4.32	^rgn; out	-; mod	F;-------------------\\;  _GMI_SetRectRgn   >;===================/; PROCEDURE SetRectRgn (rgn: RgnHandle; left,top,right,bottom: INTEGER);;; (re-)dfinit la rgion rgn comme tant le rectangle [(top,left)(bottom,right)}.; traite le cas des rectangles vides (top>bottom ou left>right).;; in	SP^;	+8.32	^rgn;	+6.16	^left;	+4