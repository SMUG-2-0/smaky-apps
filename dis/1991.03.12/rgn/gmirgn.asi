	.CHAP	GMIRGN.ASI; Traitement des rgions; =======================; Toutes les routines modifient D0,D1,D2,A0,A1,(A2??) !!!; @@@ INCOMPATIBILITE !!!; CHERCHER ;MODIF6;-----------------\\;  _GMI_NEWRGN     >;=================/; FUNCTION NewRgn (VAR rgn: RgnHandle): PsosError; cre une nouvelle rgion (rend l'identificateur); Cette fonction cre une rgion vide rectangle [(0,0),(0,0)].,; en allouant de la place extensible. Toutes les autres routines; ne font que modifier la taille de la rgion.; in	SP^;	+4.16	Place pour PsosError;	+0.32	^VAR rgn; out	SP^;	+0.16	PsosError; mod	F_GMI_NEWRGN:	PUSHM.32 D0|D1|D2|D3|D7|A0|A1|A2	CLR.32		{-A7}	PUSH.32		#LGrgnMin	CALL		R16^NEWHANDLELD7	; Aloue un handle (fixe)  une mmoire relogeable	POP.32		A0			; et agrandissable/diminuable.	MOVE.32		{SP}+9*4+0,A1	MOVE.32		A0,{A1}			; Rend le paramtre	MOVE.16		D7,{SP}+9*4+4		; Rend l'erreur	JUMP,NE		RTN$			; si erreur, pas d'initialisation !	MOVE.32		{A0},A0	MOVE.32		#LGrgnMin,{A0+}		; initialise la zone mmoire, d'abord OrgnSize	CLR.32		{A0+}			; puis OrgnBBox	CLR.32		{A0+}RTN$:	POPM.32	 D0|D1|D2|D3|D7|A0|A1|A2	POP.32		{SP}	RET;-------------------\\;  _GMI_DISPOSERGN   >;===================/; FUNCTION DisposeRgn (rgn: RgnHandle): PsosError;; rend un identificateur de rgion; Rend la mmoire associe  une rgion.; A utilis lorsqu'on a entirement fini avec une rgion temporaire.; in	SP^;	+4.16	Place pour PsosError;	+0.32	rgn; out	SP^;	+0.16	PsosError; mod	F_GMI_DISPOSERGN:	PUSHM.32 D0|D1|D2|D7|A0|A1	MOVE.32	{SP}+7*4+0,A0	CALL	DISPOSEHANDLED7		; Rend le Handle  la mmoire (et la mmoire)	MOVE.16	D7,{SP}+7*4+4		; rend l'erreur	POPM.32	 D0|D1|D2|D7|A0|A1	POP.32	{SP}	CLR.16	D7	RET;--------------------\\;  _GMI_RGNTOBITMAP   >;====================/; PROCEDURE RgnToBitMap ( rgn: RgnHandle; dstBits: BitMap; Mode: CARDINAL): PsosError;; (* Mode = GM... *); transforme une rgion en bitmap (mmoire) en effectuant; l'opration selon le mode de transfert, et en limitant le dessin; au rectangle de contour du bitmap; in	SP^;	+10.16	place pour PsosError;	+6.32	identificateur de la rgion;	+2.32	^descripteur du bitmap;	+0.8	mode de transfert (voir dfinitions plus haut); out	SP^;	+0.16	PsosError; mod	F_GMI_RGNTOBITMAP:	PUSHM.32 D2|D7|A2|A4	MOVE.32	{SP}+5*4+6,A4	; RgnHandle	MOVE.32	{SP}+5*4+2,A2	; Bitmap	CLR.16	D2	MOVE.8	{SP}+5*4+0,D2	; Mode	CALL	RRGNTOBITMAP	MOVE.16	D7,{SP}+5*4+10'10 ; PsosError	POPM.32 D2|D7|A2|A4	MOVE.32	{SP},{SP}+10'10	ADD.A16	#10'10,SP	RET;---------------\\;  RRGNTOBITMAP  >;===============/; transforme une rgion en bitmap (mmoire) en effectuant; l'opration selon le mode de transfert, et en limitant le dessin; au rectangle de contour du bitmap; in	A4	identificateur de la rgion;	A2	^descripteur du bitmap;	D2.16	mode de transfert (voir dfinitions plus haut); out	D7.16	erreur; mod	D7.16RRGNTOBITMAP:	PUSHM.32 D0..D6|A0..A6	MOVE.32	{A2}+OGBMAPPT,A3	; A3 ^bitmap	MOVE.32	A7,A6	MOVE.32	{A4},A0	COMP.32	#LGrgnMIN,{A0}+OrgnSIZE	JUMP,NE	COMPLEX$RECTANGLE$:	SUB.A16	#LGrgnMIN+2*(3+1+3+1+1),A7	MOVE.32	A7,A1	MOVE.16	#LGrgnMIN/2-1,D0CPLO$:	MOVE.16	{A0+},{A1+}	DJ.16,NMO D0,CPLO$	MOVE.16	#rgnENDLIST,D0	MOVE.32	{A4},A0	MOVE.32	{A0}+OrgnBbox+0,{A1+}	; top left	MOVE.16	{A0}+OrgnBbox+6,{A1+}	; right	MOVE.16	D0,{A1+}	MOVE.16	{A0}+OrgnBbox+4,{A1+}	; bottom	MOVE.16	{A0}+OrgnBbox+2,{A1+}	; left	MOVE.16	{A0}+OrgnBbox+6,{A1+}	; right	MOVE.16	D0,{A1+}	MOVE.16	D0,{A1+}	MOVE.32	A7,A0COMPLEX$:	SUB.A16	#10'24,A7	MOVE.32	A7,A1			; A1 ^vars internes	MOVE.32	{A2}+OGBMAPRECT+OGRECTTL,D3	MOVE.32	{A2}+OGBMAPRECT+OGRECTBR,D4	MOVE.16	{A2}+OGBMAPWIDTH,D6	CALL	CALCTRMOD		; D2.16 mode  ===> A2 ^routine de transfert	MOVE.16	D3,D0	MOVE.16	D4,D1	MOVE.16	D0,D2	CALL	INITRGN	MOVE.32	D4,D2	SWAP.32	D2	SWAP.32	D3	MOVE.16	D3,D0			; D0.16 = haut	SUB.16	D3,D2			; D2.16 = bas - haut	SWAP.32	D3	AND.32	#16'FFFF,D4	SUB.16	D3,D4			; droite - gauche bit	DIV.16	#10'16,D4NEXTLI$:	CALL	SEEKRGN	MOVE.32	{A1}+8,A5	PUSHM.32 D0|D1|D4|A3	DEC.16	D4	CALL	{A2}	MOVE.16	#1-1,D4			; D4.16 = 0 pour test du reste, et DJ,NMO de {A2}	TEST.32	D4	JUMP,EQ	NOROUND$		; pas de reste => pas de dernier word	MOVE.16	{A3},D1			; sauve dernier word	CALL	{A2}			; opre sur le word	SWAP.32	D4	SL.16	#1,D4	MOVE.32	#R16^MASKTAB,A5		; A5 ^masque 110000.. et {A5}+16*2 ^masque 00111..	MOVE.16	{A5}+A16^{D4},D0	AND.16	D0,{-A3}		; masque rsultat (gauche)	AND.16	{A5}+A16^{D4}+16*2,D1	; masque valeur prcdente (droite)	OR.16	D1,{A3}			; combine les deux.NOROUND$:	POPM.32	 D0|D1|D4|A3	ADD.A16	D6,A3	INC.16	D0	DEC.16	D2	JUMP,NE	NEXTLI$RETOUR$:	MOVE.32	A6,A7	POPM.32	 D0..D6|A0..A6	CLR.16	D7	RET;----------\; CALCTRMOD >;==========/; Calcule le mode de transfert; in	D2.16	mode de transfert; out	A2	^routine effectuant D4.16-1 fois XXX.16  {A5+},{A3+}CALCTRMOD:	MOVE.32	#R16^TABTR,A2	SL.16	#1,D2	ADD.A16	{A2}+A16^{D2},A2	RETTABTR:	.16	TR0-TABTR	.16	TR1-TABTR	.16	TR2-TABTR	.16	TR3-TABTR	.16	TR4-TABTR	.16	TR5-TABTR	.16	TR6-TABTR	.16	TR7-TABTR	.16	TR8-TABTR	.16	TR9-TABTR	.16	TR10-TABTR	.16	TR11-TABTR	.16	TR12-TABTR	.16	TR13-TABTR	.16	TR14-TABTR	.16	TR15-TABTR;----------\; TR(0..15) >;==========/; Transfre dans le mode GMxxx:;	loop$:;		xxx.16	{A5+},{A3+};		DJ.16,NMO D4,loop$; in	A5	^source;	A3	^destination;	D4.16	nombre de words -1; out	A5	^aprs source;	A3	^aprs destination;	D4.16, A3: imprvisibles; mod	D0.32, D4.16, A3, A5TR0:				; 0		-LOOP$:	ADD.A16	#2,A5	CLR.16	{A3+}	DJ.16,NMO D4,LOOP$	RETTR1:				; s*dLOOP$:	MOVE.16	{A5+},D0	AND.16	D0,{A3+}	DJ.16,NMO D4,LOOP$	RETTR2:				; /s*dLOOP$:	MOVE.16	{A5+},D0	NOT.16	D0	AND.16	D0,{A3+}	DJ.16,NMO D4,LOOP$	RETTR3:				; d !!!!!	-	SL.16	#1,D4	ADD.A16	D4,A3	ADD.A16	D4,A5	RETTR4:				; s*/d		-LOOP$:	MOVE.16	{A3},D0	NOT.16	D0	AND.16	{A5+},D0	MOVE.16	D0,{A3+}	DJ.16,NMO D4,LOOP$	RETTR5:				; sLOOP$:	MOVE.16	{A5+},{A3+}	DJ.16,NMO D4,LOOP$	RETTR6:				; /s*d + s*/dLOOP$:	MOVE.16	{A5+},D0	XOR.16	D0,{A3+}	DJ.16,NMO D4,LOOP$	RETTR7:				; s+dLOOP$:	MOVE.16	{A5+},D0	OR.16	D0,{A3+}	DJ.16,NMO D4,LOOP$	RETTR8:				; /(s+d)	-LOOP$:	MOVE.16	{A5+},D0	OR.16	D0,{A3}	NOT.16	{A3+}	DJ.16,NMO D4,LOOP$	RETTR9:				; /s*/d + s*dLOOP$:	NOT.16	{A3}	MOVE.16	{A5+},D0	XOR.16	D0,{A3+}	DJ.16,NMO D4,LOOP$	RETTR10:				; /sLOOP$:	MOVE.16	{A5+},{A3}	NOT.16	{A3+}	DJ.16,NMO D4,LOOP$	RETTR11:				; /s + dLOOP$:	MOVE.16	{A5+},D0	NOT.16	D0	OR.16	D0,{A3+}	DJ.16,NMO D4,LOOP$	RETTR12:				; /d !!!!!	-LOOP$:	ADD.A16	#2,A5	NOT.16	{A3+}	DJ.16,NMO D4,LOOP$	RETTR13:				; s + /d	-LOOP$:	NOT.16	{A3}	MOVE.16	{A5+},D0	OR.16	D0,{A3+}	DJ.16,NMO D4,LOOP$	RETTR14:				; /s + /d = /(s*d)	-LOOP$:	MOVE.16	{A5+},D0	AND.16	D0,{A3}	NOT.16	{A3+}	DJ.16,NMO D4,LOOP$	RETTR15:				; 1LOOP$:	ADD.A16	#2,A5	MOVE.16	#-1,{A3+}	DJ.16,NMO D4,LOOP$	RET;------------------\\;  _GMI_OPENRGN     >;==================/; FUNCTION OpenRgn ( rgn: rgnHandle; Mode: CARDINAL; ClipRect: Rect): PsosError;;; Permet de dfinir analytiquement une rgion.; Mmorise dans rgn toutes les lignes et surfaces fermes; dessinnes qui dtermineront la rgion  CloseRgn.; La rgion rgn doit auparavant tre cre avec NewRgn. Aucun appel; autre que PutLine, PutRLine, PutRect, PutOval et CloseRgn; ne peut tre appell sur la rgion aprs cet appel et avant le CloseRgn; obligatoire, sauf erreur  l'OpenRgn.; Le dessin n'est pas limit par la rgion de clipping ni au rectangle; de cliping courant. Par contre ClipRect permet de limiter des tracs; inutiliss par la suite (conomie de temps et de mmoire).; Mode: combinaison de GFillXor/GFillWinding et GFillInterior/GFillRoundUp;	Mode de remplissage;	GFILLXOR:	pair/impair;	GFILLWINDING:	segments dirigs uniquement; in	SP^;	+10.16	place pour PsosError;	+6.32	rgn;	+4.16	Mode;	+0.32	^ClipRect; out	SP^;	+0.16	PsosError; mod	F_GMI_OPENRGN:	PUSHM.32	D0|D1|D2|D4|D7|A0|A1|A4	MOVE.32		#LGSIMGRP,D4	MOVE.16		#MTYPCP,D1	GESMEM		?GETMEM	JUMP,NE		RTN$	CLR.32		{-A7}	PUSH.32		#16'0800	MOVE.32		{A7},{A4}+OsimgrpLG	; lg	CALL		R16^NEWHANDLELD7	POP.32		{A4}+OsimgrpPT		; Init ^RgnHandle dans RgnSave	TEST.16		D7	JUMP,NE		ER$	CLR.32		{A4}+OsimgrpNB		; lg utilise;;	MOVE.16		{SP}+9*4+4,{A4}+OsimgrpMODE ; mode de dfinition	MOVE.16		#GFILLXOR+GFILLINTERIOR,{A4}+OsimgrpMODE ; EN ATTENDANT...	MOVE.32		{SP}+9*4+0,A0	MOVE.32		{A0+},{A4}+OsimgrpCLIP+0 ; CLIPRECT...	MOVE.32		{A0},{A4}+OsimgrpCLIP+4	PUSH.32		#0	PUSH.32		{A0}-4	PUSH.32		{A0}	CALL		_GMI_SubPt		; Stack.32 <-- Clip.p2 - Clip.p1	POP.16		D0			; delta.Y	POP.16		D1			; delta X	COMP.16		D1,D0	JUMP,LO		YMIN$	MOVE.16		D1,D0YMIN$:	MOVE.16		D0,{A4}+OsimgrpCLIPmin	; min(deltaClipX, deltaClipY)	MOVE.32		{SP}+9*4+6,A0		; ^RgnHandle prcdent	PUSH.32		A0	CALL		_GMI_SetEmptyRgn	; Met le handle au minimum...	MOVE.32		{A0},{A4}+OsimgrpOLDRGN	MOVE.32		A4,{A0}			; met le ^Osimgrp dans RgnHandle !	JUMP		RTN$ER$:	PUSH.16		D7	MOVE.16		#MTYPCP,D1	GESMEM		?GIVMEM	JUMP,NE		FATHANDLERR	POP.16		D7RTN$:	MOVE.16		D7,{SP}+9*4+10'10	; PsosError	POPM.32		D0|D1|D2|D4|D7|A0|A1|A4	MOVE.32		{SP},{SP}+10'10	ADD.32		#10'10,SP	RET;------------------\\;  _GMI_CLOSERGN    >;==================/; FUNCTION CloseRgn ( rgn: RgnHandle): PsosError;; termine la dfinition d'une rgion (ferme); Arrte de collectioner les objets dessinns,; forme la rgion rsultante, et la sauve dans dstRgn.; doit tre fait par le mme processus qui a fait l'OPENRGN.; in	SP^;	+4.16	place pour PsosError;	+0.32	dstRgn; out	SP^;	+0.16	PsosError; mod	F_GMI_CLOSERGN:	LINK.32		A6,#-16'0004		; {A6}+8.32 ^(^dstRgn), {A6}-4.16 var. de 4 bytes	PUSHM.32	D0|D1|D2|D3|D5|D6|D7|A0|A1|A2|A3|A4|A5	MOVE.32		{A6}+8+0,A4		; ^rgnHandle	MOVE.32		{A4},A5			; ^Osimgrp...	MOVE.32		{A5}+OsimgrpOLDRGN,{A4}	; remet le rgnHandle initial	COMP.16		#GFILLXOR,{A5}+OsimgrpMODE	JUMP,NE		WINDING$	MOVE.32		{A5}+OsimgrpNB,D0	SR.32		#2,D0			; /4	MOVE.32		D0,{A6}-16'0004	MOVE.32		{A5}+OsimgrpPT,A3	; A3 ^RgnHandle pour les points sauvs.	SUB.32		#2,SP			; place pour erreur	PUSH.32		{A3}	PUSH.32		D0	CALL		R16^SORTPOINTS	POP.16		D7	JUMP,NE		DISPOSE$	PUSH.32		{A3}	PUSH.32		#{A6}-16'0004	CALL		R16^CULLPOINTS	SUB.32		#2,A7			; rserve place pour erreur	PUSH.32		A3	PUSH.32		{A6}-16'0004	PUSH.32		{A6}+8+0	CALL		R16^PACKRGN		; empaqute la rgion ^A3 dans dstRgn	POP.16		D7			; reprend l'erreur...	JUMP		DISPOSE$WINDING$:.if 0	CLR.32		D5	MOVE.16		{A5}+OsimgrpNB,D5	DIV.16		#6,D5	MOVE.32		D5,{A6}-16'0004	MOVE.32		{A5}+OsimgrpPT,A3	; A3 ^RgnHandle pour les points sauvs.	PUSH.32		{A3}	PUSH.16		{A6}-16'0002	CALL		R16^SORTDIRPOINTS	PUSH.32		{A3}	PUSH.32		#{A6}-16'0002	MOVE.16		#1,D6			; simplifie les points identiques avec direction	CALL		R16^CULLDIRPOINTS	PUSH.32		A3	PUSH.16		{A6}-16'0002	PUSH.32		{A6}+8+0	CALL		R16^PACKDIRRGN		; empaqute la rgion ^A3 dans dstRgn.endif 0DISPOSE$:	MOVE.32		A3,A0	CALL		DISPOSEHANDLE		; rend la rgion de sauvetageRETOUR$:	MOVE.16		D7,{A6}+8+4		; rend PsosError	MOVE.32		A5,A4	MOVE.16		#MTYPCP,D1	GESMEM		?GIVMEM	JUMP,NE		FATHANDLERR	POPM.32		D0|D1|D2|D3|D5|D6|D7|A0|A1|A2|A3|A4|A5	UNLINK.32	A6	POP.32		{A7}	RET;-----------------\\;  _GMI_PUTLINE    >;=================/; FUNCTION PutLine (rgn: RgnHandle; p1,p2: Point): PsosError;; ajoute une droite (dirige)  coordonnes entires  la rgion (ouverte); in	SP^;	+12.16	place pour PsosError;	+8.32	RgnHandle;	+4.32	p1;	+0.32	p2; out	SP^;	+0.16	PsosError; mod	F_GMI_PUTLINE:	LINK.32	A6,#-(8*2)		; place pour 2 RealPoint	PUSH.32	A0	MOVE.32	#{A6}-(8*2),A0	MOVE.16	{A6}+8+4+0,{A0+}	; p1.y	MOVE.16	#16'8000,{A0+}	MOVE.16	{A6}+8+4+2,{A0+}	; p1.x	MOVE.16	#16'8000,{A0+}	MOVE.16	{A6}+8+0+0,{A0+}	; p2.y	MOVE.16	#16'8000,{A0+}	MOVE.16	{A6}+8+0+2,{A0+}	; p2.x	MOVE.16	#16'8000,{A0}	POP.32	A0	SUB.32	#2,SP			; place pour erreur	PUSH.32	{A6}+8+8		; rgnHandle	PUSH.32	#{A6}-(8*2)		; p1	PUSH.32	#{A6}-8			; p2	CALL	PUTRLINE	POP.16	{A6}+8+10'12		; PsosError	UNLINK.32 A6	MOVE.32	{SP},{SP}+10'12	ADD.A16	#10'12,SP	RET;-----------------\\;  _GMI_PutRLine   >;=================/; FUNCTION PutRLine (rgn: RgnHandle; p1,p2: RealPoint): PsosError;; ajoute une droite (dirige)  coordonnes relles  la rgion (ouverte); in	SP^;	+12.16	place pour PsosError;	+8.32	rgn;	+4.32	^p1 (push.32 x, push.32 y  =  y;x);	+0.32	^p2; out	SP^;	+0.16	PsosError; mod	F_GMI_PUTRLINE:PUTRLINE:	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3|A4|A5	MOVE.32		{A7}+10'15*4+8,A5		; rgnHandle	MOVE.32		{A5},A5				; ^Osimgrp...	CLR.16		{A7}+10'15*4+10'12		; pas de PsosError par dfaut	COMP.16		#GFILLXOR,{A5}+OsimgrpMODE	; mode de remplissage xor ?	JUMP,NE		PUTWINDLINE			; non => winding, autre routine...	MOVE.32		{A7}+10'15*4+4,A2		; A2 ^p1	MOVE.32		{A7}+10'15*4+0,A4		; A4 ^p2	MOVE.32		{A2}+4,D2			; x1	MOVE.32		{A4}+4,D4			; x2	SWAP.32		D2	SWAP.32		D4	COMP.16		D2,D4	JUMP,EQ		RTN$				; x1 = x2 ==> ne fait rien	SWAP.32		D2	SWAP.32		D4	MOVE.32		D2,D0	SUB.32		D4,D0	JUMP,GE		XPOSITIF$	NEG.32		D0				; delta_x positif LONGCARDXPOSITIF$:	MOVE.32		{A2}+0,D1			; y1	SUB.32		{A4}+0,D1			; -y2	JUMP,GE		DYPOSITIF$	NEG.32		D1				; delta_y positif LONGCARDDYPOSITIF$:	COMP.32		D1,D0	JUMP,LS		LOWEST$				; prend le plus petit	MOVE.32		D1,D0LOWEST$:	CLR.16		D0	SWAP.32		D0	COMP.16		{A5}+OsimgrpCLIPmin,D0		; Clip plus petit encore ?	JUMP,LO		NOTMINCL$			; non => ok	MOVE.16		{A5}+OsimgrpCLIPmin,D0		; oui => prend clip dans D0.32NOTMINCL$:	ADD.32		#5,D0				; + points de dpart et arrive + SUB 32 bits...	SL.32		#3,D0				; * 8 (2 points)	MOVE.32		{A5}+OsimgrpPT,A3		; A3 ^handle courant	MOVE.32		{A5}+OsimgrpNB,D1	ADD.32		D1,D0	MOVE.32		#{A5}+OsimgrpLG,A0		; A0 ^nombre de bytes prvus.32	MOVE.32		{A0},D1	COMP.32		D1,D0	JUMP,LS		MEMSIZEOK$	ADD.32		#512,D0				; 64 paires de points supplmentaires...	PUSH.32		D2	MOVE.32		D0,{A0}	PUSH.32		A3	PUSH.32		D0	CALL		SETHSIZELD7	POP.32		D2				; x1 (D2 bouzill par SetHSize)	MOVE.16		D7,{A7}+10'15*4+10'12		; Met le rsultat dans PsosError	JUMP,EQ		MEMSIZEOK$			; on a pu attribuer ?  oui => ok	MOVE.32		#0,{A5}+OsimgrpNB	JUMP		RTN$MEMSIZEOK$:	MOVE.32		{A3},A3	ADD.32		{A5}+OsimgrpNB,A3	MOVE.32		{A2}+0,D1			; y1	MOVE.32		{A4}+0,D3			; y2	SWAP.32		D1	SWAP.32		D3	COMP.16		D1,D3				; y1 = y2 ?	JUMP,NE		NOTSAMEY$			; non.	SWAP.32		D2	SWAP.32		D4	MOVE.16		D1,{A3+}			; oui => 2 points triviaux y1	MOVE.16		D2,{A3+}			; x1	MOVE.16		D3,{A3+}			; y2	MOVE.16		D4,{A3+}			; x2	CALL		TESTLASTPT	JUMP		RTNADJ$NOTSAMEY$:	JUMP,GT		NOTSWAP$			; y2 > y1	EX.32		D3,D1	EX.32		D4,D2				; sinon inverseNOTSWAP$:	SWAP.32		D1	SWAP.32		D3	MOVE.32		D1,D6				; D6 = y1	PUSHM.32	D0|D1|D2|D3|D4	SUB.32		D2,D4				; x2-x1 (signed)	MOVE.32		D4,D2	SUB.32		D1,D3				; / y2-y1 (unsigned)	MOVE.32		D3,D1	TEST.32		D2	SET.8,MI	D3	JUMP,PL		POS1$				; D2 ngatif ? oui => rend positif et met D3=-1	NEG.32		D2POS1$:	CALL		FIXDIVUNSIGNED	TEST.8		D3				; remet ngatif si l'tait	JUMP,EQ		POS$	NEG.32		D0POS$:	MOVE.32		D0,D7				; D7 pente en fractionnaire	POPM.32		D0|D1|D2|D3|D4	PUSHM.32	D2|D3|D4|A0..A1	MOVE.32		D1,D4	CLR.16		D1	ADD.32		#16'10000,D1	SUB.32		D4,D1				; roundup(y1)-y1	MOVE.32		D7,D2				; * pente	CALL		FIXMUL				; = x1 dbut de la ligne suivant	MOVE.32		D0,D1	POPM.32		D2|D3|D4|A0..A1	ADD.32		D2,D1				; x1 + fraction restant en-haut.IF 0	MOVE.32		#16'00010000,D0			; 1.000	TEST.32		D7	JUMP,MI		NEGRATIO$			; ratio ngatif...	COMP.32		D0,D7				; ratio >= 1.00 ?	JUMP,GE		BIGRATIO$	ADD.32		D7,D1				; non => additionne ratio  D1	JUMP		BIGRATIO$NEGRATIO$:	COMP.32		#16'FFFF0000,D7			; ratio >= -1 ?	JUMP,GE		BIGRATIO$	ADD.32		D0,D1				; <   => additionne 1.00BIGRATIO$:.endif 0	SWAP.32		D2	MOVE.16		D2,D5				; x1	SWAP.32		D6	SWAP.32		D3	SWAP.32		D4NEXTPT$:	SWAP.32		D1	COMP.16		D1,D5				; x1 chang ?	JUMP,EQ		XNOTCHANGED$	MOVE.16		D6,{A3+}			; y1	MOVE.16		D5,{A3+}			; x1 original	MOVE.16		D1,D5				; change x1	MOVE.16		D6,{A3+}			; y1	MOVE.16		D5,{A3+}			; nouveau x1	CALL		TESTLASTPTXNOTCHANGED$:	SWAP.32		D1	INC.16		D6				; descend de 1 point	ADD.32		D7,D1				; additionne le ratio	COMP.16		D6,D3				; y1 courant = y2 ?	JUMP,NE		NEXTPT$				; non => traite l'y1 suivant	COMP.16		D4,D5				; x1 courant = x2 ?	JUMP,EQ		RTNADJ$	MOVE.16		D6,{A3+}			; non => met les derniers point !	MOVE.16		D5,{A3+}	MOVE.16		D6,{A3+}	MOVE.16		D4,{A3+}	CALL		TESTLASTPTRTNADJ$:	MOVE.32		{A5}+OsimgrpPT,A0	SUB.32		{A0},A3	MOVE.32		A3,{A5}+OsimgrpNBmove.32	{A5}+OsimgrpLG,D0COMP.32 D0,A3JUMP,LS RTN$MOVE.32	#16'12345678,D7TRAP #1RTN$:	POPM.32		D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3|A4|A5	MOVE.32		{A7},{A7}+10'12	ADD.A16		#10'12,A7	RET;-------------\\; TESTLASTPT   >;=============/; teste si les 2 derniers points ajouts sont:; -  l'intrieur de ClipRect: fait rien; - coupent ClipRest: Ajuste les x1 et x2; - sont en-dessus ou en-dessous: projette en enlevant le point si ncessaire; - sont  gauche ou  droite: enlve le point; ATTENTION: appelle depuis _GMI_PutRLine et _GMI_PutRgn; in	A5	^Osimgrp...;	A3	^aprs les 2 points ajouts; out	A3	^o ajouter le point suivant; mod	A3TESTLASTPT:	PUSHM.32 D0|A0			; D0 y clipp...	MOVE.16	{A5}+OsimgrpCLIP+0+0,D0	; clip.top	COMP.16	{A3}-8+0,D0		; clip.top > seg.y ?	JUMP,GT	FORCEY$			; oui ==> on force seg.y  clip.top	MOVE.16	{A5}+OsimgrpCLIP+4+0,D0	; clip.bottom	COMP.16	{A3}-8+0,D0		; clip.bottom < seg.y ?	JUMP,GE	SECTHORIZ$		; non ==>  l'intrieur verticalementFORCEY$:				; oui ==> on force seg.y  clip.bottom	MOVE.16	D0,{A3}-8+0+0		; seg.p1.y	MOVE.16	D0,{A3}-8+4+0		; seg.p2.ySECTHORIZ$:	MOVE.16	{A3}-8+0+2,D0		; seg.p1.x	COMP.16	{A5}+OsimgrpCLIP+0+2,D0	; seg.p1.x >= clip.left ?	JUMP,GE	OKP1L$			; oui => ok	MOVE.16	{A5}+OsimgrpCLIP+0+2,D0	; non => seg.p1.x := clip.left ?OKP1L$:	COMP.16	{A5}+OsimgrpCLIP+4+2,D0	; seg.p1.x <= clip.right ?	JUMP,LE	OKP1R$			; oui => ok	MOVE.16	{A5}+OsimgrpCLIP+4+2,D0	; non => seg.p1.x := clip.right ?OKP1R$:	MOVE.16	D0,{A3}-8+0+2		; remet seg.p1.x	MOVE.16	{A3}-8+4+2,D0		; seg.p2.x	COMP.16	{A5}+OsimgrpCLIP+0+2,D0	; seg.p2.x >= clip.left ?	JUMP,GE	OKP2L$			; oui => ok	MOVE.16	{A5}+OsimgrpCLIP+0+2,D0	; non => seg.p2.x := clip.left ?OKP2L$:	COMP.16	{A5}+OsimgrpCLIP+4+2,D0	; seg.p2.x <= clip.right ?	JUMP,LE	OKP2R$			; oui => ok	MOVE.16	{A5}+OsimgrpCLIP+4+2,D0	; non => seg.p2.x := clip.right ?OKP2R$:	MOVE.16	D0,{A3}-8+4+2		; remet seg.p2.x	COMP.16	{A3}-8+0+2,D0		; seg.p2.x = seg.p1.x ?	JUMP,EQ	SUPPRESS$	MOVE.32	#{A3}-8-8,A0		; A0 ^segment prcdent	COMP.32	{A5}+OsimgrpPT,A0	; existe ?	JUMP,LO	RTN$			; non => retour tel quel	MOVE.32	{A3}-8+0,D0		; seg.p1	COMP.32	{A0}+4,D0		; precseg.p2 = seg.p1 ?	JUMP,NE	RTN$			; non => fait rien	MOVE.32	{A3}-8+4,{A0}+4		; oui => met seg.p2 --> precseg.p2					;	 et... supprime le segmentSUPPRESS$:	SUB.32	#8,A3			; supprime le segmentRTN$:	POPM.32	D0|A0	RET;------------------------------------------------; PUTWINDLINE (p1,p2: Point);	EN PLUS: routine lgrement modifie;; in	A5	^pseudo-grafportPUTWINDLINE:.if 0;;;	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3|A4|A5	PUSH.32		A6	MOVE.16		{A7}+10'16*4+6,D2			; x1	MOVE.16		{A7}+10'16*4+2,D4			; x2	COMP.16		D2,D4	JUMP,EQ		RTN$				; x1 = x2 ==> ne fait rien	MOVE.A16	#-1,A6				; P1 (si x2<x1)	MOVE.A16	#1,A5				; P2 (idem)	MOVE.16		D2,D0	SUB.16		D4,D0	JUMP,GE		XPOSITIF$	; anc: PL	NEG.16		D0				; delta_x positif	EX.32		A5,A6				; sinon inverse la valeur de P1 et P2XPOSITIF$:	MOVE.16		{A7}+10'16*4+4,D1			; y1	SUB.16		{A7}+10'16*4+0,D1			; -y2	JUMP,GE		DYPOSITIF$	; anc: PL	NEG.16		D1				; delta_y positifDYPOSITIF$:	COMP.16		D1,D0	JUMP,LS		LOWEST$		; anc: LE	; prend le plus petit	MOVE.16		D1,D0LOWEST$:	INC.16		D0				; + points de dpart et arrive	MUL.16		#2*6,D0				; * 12 (2 points orients)	MOVE.32		{A5}+OsimgrpPT,A3		; A3 ^handle courant	MOVE.32		#{A5}+OsimgrpNB,A4		; A4 ^nombre de bytes	ADD.32		{A4},D0	MOVE.32		#{A5}+OsimgrpLG,A0		; A0 ^nombre de bytes prvus	COMP.32		{A0},D0	JUMP,LE		MEMSIZEOK$	ADD.32		#256*3,D0			; 64 paires de points supplmentaires...	MOVE.32		D0,{A0}	PUSH.32		A3	PUSH.16		D0	CALL		R16^SETHSIZE	MOVE.16		{A7}+10'16*4+6,D2			; x1 (D2 bouzill par SetHSize)MEMSIZEOK$:	MOVE.32		{A3},A3	ADD.32		{A4},A3	MOVE.16		{A7}+10'16*4+4,D1			; y1	MOVE.16		{A7}+10'16*4+0,D3			; y2	COMP.16		D1,D3				; y1 = y2 ?	JUMP,NE		NOTSAMEY$			; non.	MOVE.16		D1,{A3+}			; oui => 2 points triviaux y1	MOVE.16		D2,{A3+}			; x1	MOVE.16		A6,{A3+}			; P1	MOVE.16		D3,{A3+}			; y2	MOVE.16		D4,{A3+}			; x2	MOVE.16		A5,{A3+}			; P2	JUMP		RTNADJ$NOTSAMEY$:	JUMP,GT		NOTSWAP$			; y2 > y1	EX.32		D3,D1	EX.32		D4,D2				; sinon inverse	EX.32		A5,A6				; ainsi que valeur de P1 et P2 !NOTSWAP$:	MOVE.16		D1,D6				; D6 = y1	CLR.32		{-A7}				; place pour rsultat fractionnaire	PUSH.16		D4	SUB.16		D2,{A7}				; x2-x1	PUSH.16		D3	SUB.16		D1,{A7}				; / y2-y1	CALL		FIXRATIO	POP.32		D7				; D7 pente en fractionnaire	MOVE.16		D2,D1	SWAP.32		D1				; x1 --> partie entire	MOVE.16		#16'8000,D1			; 0.5 --> partie fractionnaire	MOVE.32		D7,D0	ASR.32		#1,D0				; ratio/2	ADD.32		D0,D1				; ratio/2 + x1 + 0.5	MOVE.32		#16'00010000,D0			; 1.000	TEST.32		D7	JUMP,MI		NEGRATIO$			; ratio ngatif...	COMP.32		D0,D7				; ratio >= 1.00 ?	JUMP,GE		BIGRATIO$	ADD.32		D7,D1				; non => additionne ratio  D1	JUMP		BIGRATIO$NEGRATIO$:	COMP.32		#16'FFFF0000,D7			; ratio >= -1 ?	JUMP,GE		BIGRATIO$	ADD.32		D0,D1				; <   => additionne 1.00BIGRATIO$:	MOVE.16		D2,D5				; x1NEXTPT$:	SWAP.32		D1	COMP.16		D1,D5				; x1 chang ?	JUMP,EQ		XNOTCHANGED$	MOVE.16		D6,{A3+}			; y1	MOVE.16		D5,{A3+}			; x1 original	MOVE.16		A6,{A3+}			; P1	MOVE.16		D1,D5				; change x1	MOVE.16		D6,{A3+}			; y1	MOVE.16		D5,{A3+}			; nouveau x1	MOVE.16		A5,{A3+}			; P2XNOTCHANGED$:	SWAP.32		D1	INC.16		D6				; descend de 1 point	ADD.32		D7,D1				; additionne le ratio	COMP.16		D6,D3				; y1 courant = y2 ?	JUMP,NE		NEXTPT$				; non => traite l'y1 suivant	COMP.16		D4,D5				; x1 courant = x2 ?	JUMP,EQ		RTNADJ$	MOVE.16		D6,{A3+}			; non => met les derniers point !	MOVE.16		D5,{A3+}	MOVE.16		A6,{A3+}			; P1	MOVE.16		D6,{A3+}	MOVE.16		D4,{A3+}	MOVE.16		A5,{A3+}			; P2RTNADJ$:	MOVE.32		{A5}+OsimgrpPT,A0	SUB.32		{A0},A3	MOVE.32		A3,{A4}RTN$:	POP.32		A6	POPM.32		D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3|A4|A5.endif 0	MOVE.32		{A7},{A7}+10'20	ADD.A16		#10'20,A7	RET;-----------------\\;  _GMI_PUTRECT    >;=================/; FUNCTION PutRect (rgn: RgnHandle; r: Rect, Way: Direction): PsosError;; ajoute un rectangle (dirige)  coordonnes relles  la rgion (ouverte); in	SP^;	+10.16	place pour PsosError;	+6.32	rgn;	+2.32	^r;	+0.8	Way (0 positif, 1 negatif); out	SP^;	+0.16	PsosError; mod	F_GMI_PUTRECT:	LINK.32		A6,#-8	PUSHM.32	D0|D1|D2|D7|A0|A1|A5	MOVE.32		{A6}+8+6,A5		; rgnHandle	MOVE.32		{A5},A5			; ^Osimgrp...	CLR.16		{A6}+8+10'10		; pas d'erreur  priori...	MOVE.32		#10'16,D0	ADD.32		{A5}+OsimgrpNB,D0	COMP.32		{A5}+OsimgrpLG,D0	JUMP,LE		SIZEOK$	ADD.32		#16'0400,{A5}+OsimgrpLG	PUSH.32		{A5}+OsimgrpPT		; ^rgnHandle	PUSH.32		{A5}+OsimgrpLG	CALL		R16^SETHSIZELD7	MOVE.16		D7,{A6}+8+10'10		; PsosError	JUMP,EQ		SIZEOK$	SUB.32		#16'0400,{A5}+OsimgrpLG	MOVE.32		#0,{A5}+OsimgrpNB	JUMP		RET$SIZEOK$:	PUSH.32		{A6}+8+2		; ^rectangle	PUSH.32		#{A5}+OsimgrpCLIP	; ^rectangle de clipping	PUSH.16		#2			; 2 rectangles	PUSH.32		#{A6}-8			; rectangle intersection	CALL		RSECT			; intersection ?	JUMP,EQ		RET$			; non => ajoute rien !	MOVE.32		{A5}+OsimgrpPT,A1	; A1 ^handle	MOVE.32		{A1},A1			; A1 ^dbut mmoire	ADD.32		{A5}+OsimgrpNB,A1	ADD.32		#10'16,{A5}+OsimgrpNB	; + 16 bytes	MOVE.32		#{A6}-8,A5		; A5 ^rectangle intersection	MOVE.32		{A5},{A1+}		; top;left	MOVE.16		{A5},{A1+}		; top	MOVE.16		{A5}+6,{A1+}		; right	MOVE.16		{A5}+4,{A1+}		; bottom	MOVE.16		{A5}+2,{A1+}		; left	MOVE.32		{A5}+4,{A1+}		; rightRET$:	POPM.32		D0|D1|D2|D7|A0|A1|A5	UNLINK.32	A6	MOVE.32		{A7},{A7}+10'10	ADD.A16		#10'10,A7	RET;-----------------\\;  _GMI_PUTOVAL   >;=================/; FUNCTION PutOval (rgn: RgnHandle; r: Rect, ovalWidth, ovalHeight: INTEGER;;                   Way: Direction): PsosError;; ajoute une ovale ou un rectangle  coins arrondis (dirigs)  coordonnes entires;  la rgion (ouverte); in	SP^;	+14.16	place pour PsosError;	+10.32	rgn;	+6.32	^r;	+4.16	ovalWidth;	+2.16	ovalHeight;	+0.8	Way (0 positif, 1 negatif); out	SP^;	+0.16	PsosError; mod	F; A6^variables locales:;	-36.16		dernier x  droite	init avec partie entire de (Rect.Right-OvalWidth/2+0.5);	-34.16		dernier x  gauche	init avec partie entire de (Rect.left+OvalWidth/2);	-32.16		rect.bottom-(OvalHeight-OvalHeight/2);	-30.16		rect.top+OvalHeight/2;	-2E.(2E bytes)	Variables pour INITOVAL/BUMPOVAL_GMI_PUTOVAL:PUTOVALINT:	LINK.32		A6,#-16'0036	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3|A4|A5	MOVE.32		{A6}+8+10'10,A5			; rgnHandle	MOVE.32		{A5},A5				; A5 ^Osimgrp...	CLR.16		{A6}+8+10'14			; pas de PsosError  priori	MOVE.32		{A6}+8+6,A0			; A0 ^rect	MOVE.32		#{A6}-16'002E,A1		; A1 ^variables pour le calcul de l'ovale	MOVE.16		{A6}+8+4,D2			; D2 OvalWidth	MOVE.16		{A6}+8+2,D1			; D1 OvalHeight	CALL		INITOVAL			; Init Var. de calcul	MOVE.16		{A6}-16'000C,{A6}-16'0034	; partie entire de (Rect.left+OvalWidth/2)	MOVE.16		{A6}-16'0008,{A6}-16'0036	; partie entire de (Rect.Right-OvalWidth/2+0.5)	MOVE.16		{A6}+8+2,D0			; OvalHeight	ASR.16		#16'01,D0			; /2	ADD.16		{A6}-16'002E,D0			; +rect.top	MOVE.16		D0,{A6}-16'0030	MOVE.32		{A6}+8+6,A0			; A0 ^rect	ADD.16		{A0}+4,D0			; +rect.bottom	SUB.16		{A0},D0				; -rect.top	SUB.16		{A6}+8+2,D0			; -OvalHeight	MOVE.16		D0,{A6}-16'0032			; rect.bottom-(OvalHeight-OvalHeight/2)	MOVE.32		{A5}+OsimgrpPT,A3		; ^rgnSaveHandle	MOVE.32		{A3},A3	MOVE.32		A3,A2				; A2 ^dbut	MOVE.32		#{A5}+OsimgrpNB,A0	ADD.32		{A0},A3				; A3 ^courant	MOVE.32		A2,A1	MOVE.32		#{A5}+OsimgrpLG,A0	ADD.32		{A0},A1				; A1 ^fin	MOVE.16		{A6}-16'002E,D6			; x = rect.top	MOVE.16		{A6}-16'0034,D4			; y = rect.left+OvalWidth/2;;	CALL		PUTOVPT				; ( rect.top ; rect.left+OvalWidth/2 )	MOVE.16		{A6}-16'0036,D5	CALL		PUTOV2PT			; ( rect.top ; rect.right-OvalWidth/2+0.5 )NEXTY$:	COMP.16		{A6}-16'0030,D6			; current y < rect.top+OvalHeight/2 ?	JUMP,LT		OVAL$				; oui => partie ovale	COMP.16		{A6}-16'0032,D6		; current y < rect.bottom-(OvalHeight-OvalHeigth/2) ?	JUMP,LT		NOOVAL$			; oui => pas d'ovaleOVAL$:	PUSHM.32	D6|A1|A2|A3	MOVE.32		#{A6}-16'002E,A3		; A3 ^variables (initialises par INITOVAL)	MOVE.16		D6,D0				; D0 = current y	CALL		BUMPOVAL			; calcule les 2 points suivants de l'ovale	POPM.32		D6|A1|A2|A3	MOVE.16		{A6}-16'000C,D4			; Oval.left.x	COMP.16		{A6}-16'0034,D4			; = Last Oval.left.x  ?	JUMP,EQ		NONEWLEFT$;;	CALL		PUTOVPT				; (current y ; Oval.left.x)	MOVE.16		{A6}-16'0034,D5	CALL		PUTOV2PT			; (current y ; Last Oval.left.x)	MOVE.16		{A6}-16'000C,{A6}-16'0034	; mj Last Oval.left.xNONEWLEFT$:	MOVE.16		{A6}-16'0008,D4			; Oval.right.x	COMP.16		{A6}-16'0036,D4	JUMP,EQ		NOOVAL$;;	CALL		PUTOVPT				; (current y ; Oval.right.x)	MOVE.16		{A6}-16'0036,D5	CALL		PUTOV2PT			; (current y ; Last Oval.right.x)	MOVE.16		{A6}-16'0008,{A6}-16'0036	; mj Last Oval.right.xNOOVAL$:	INC.16		D6				; inc current y	COMP.16		{A6}-16'002C,D6			; current y < rect.bottom ?	JUMP,LT		NEXTY$	MOVE.16		{A6}-16'0034,D4;;	CALL		PUTOVPT				; (rect.bottom ; Last Oval.left.x)	MOVE.16		{A6}-16'0036,D5	CALL		PUTOV2PT			; (rect.bottom ; Last Oval.right.x)	SUB.32		A2,A3				; A3 = nb bytes	MOVE.32		A3,{A5}+OsimgrpNB		; mj rgnSize	POPM.32		D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3|A4|A5	UNLINK.32	A6	MOVE.32		{A7},{A7}+10'14	ADD.A16		#10'14,A7	RET;-----------\; PUT2OVPT   >;===========/; met 2 points dans RgnSave, en agrandissant le Handle si ncessaire; in	D6.16	y;	D5.16	x2;	D4.16	x1;	A2	^dbut;	A3	^courant;	A1	^fin;	A5	^Osimgrp...;	A6	^vars+params; out	A2	^dbut (ev. chang);	A3	^nouveau courant;	A1	^fin (ev. chang); mod	A1,A2,A3,+pascals...: A0 en tout casPUTOV2PT:	COMP.16		D4,D5			; 2 points identiques ?	JUMP,EQ		RET$			; oui => retour	MOVE.32		#{A3}+8,A0	COMP.32		A1,A0	JUMP,LS		SIZEOK$	SUB.32		A2,A3	SUB.32		A2,A1		; A1 size	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3	PUSH.32		{A5}+OsimgrpPT		; ^rgnHandle	ADD.A16		#16'0400,A1	MOVE.32		A1,{A5}+OsimgrpLG	PUSH.32		A1			; size	CALL		R16^SETHSIZELD7	TEST.16		D7	JUMP,EQ		TAKOK$	SUB.32		#16'0400,{A5}+OsimgrpLG	MOVE.16		D7,{A6}+8+14		; Rend PsosErrorTAKOK$:	POPM.32		D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3	JUMP,NE		RET$			; erreur => ne met pas le point !	MOVE.32		{A5}+OsimgrpLG,A1	MOVE.32		{A5}+OsimgrpPT,A2	; ^handle	MOVE.32		{A2},A2			; A2 ^nouveau dbut	ADD.32		A2,A3			; nouveau ^courant	ADD.32		A2,A1			; A1 ^nouvelle finSIZEOK$:	MOVE.16	D6,D3	MOVE.16	{A5}+OsimgrpCLIP+0+0,D0	; clip.top	COMP.16	D3,D0			; clip.top > seg.y ?	JUMP,GT	FORCEY$			; oui ==> on force seg.y  clip.top	MOVE.16	{A5}+OsimgrpCLIP+4+0,D0	; clip.bottom	COMP.16	D3,D0			; clip.bottom < seg.y ?	JUMP,GE	SECTHORIZ$		; non ==>  l'intrieur verticalementFORCEY$:				; oui ==> on force seg.y  clip.bottom	MOVE.16	D0,D3			; seg.p1.ySECTHORIZ$:	MOVE.16	D4,D0			; seg.p1.x	COMP.16	{A5}+OsimgrpCLIP+0+2,D0	; seg.p1.x >= clip.left ?	JUMP,GE	OKP1L$			; oui => ok	MOVE.16	{A5}+OsimgrpCLIP+0+2,D0	; non => seg.p1.x := clip.left ?OKP1L$:	COMP.16	{A5}+OsimgrpCLIP+4+2,D0	; seg.p1.x <= clip.right ?	JUMP,LE	OKP1R$			; oui => ok	MOVE.16	{A5}+OsimgrpCLIP+4+2,D0	; non => seg.p1.x := clip.right ?OKP1R$:	MOVE.16	D0,D4			; remet seg.p1.x	MOVE.16	D5,D0			; seg.p2.x	COMP.16	{A5}+OsimgrpCLIP+0+2,D0	; seg.p2.x >= clip.left ?	JUMP,GE	OKP2L$			; oui => ok	MOVE.16	{A5}+OsimgrpCLIP+0+2,D0	; non => seg.p2.x := clip.left ?OKP2L$:	COMP.16	{A5}+OsimgrpCLIP+4+2,D0	; seg.p2.x <= clip.right ?	JUMP,LE	OKP2R$			; oui => ok	MOVE.16	{A5}+OsimgrpCLIP+4+2,D0	; non => seg.p2.x := clip.right ?OKP2R$:	MOVE.16	D0,D5			; remet seg.p2.x	COMP.16	D4,D5			; seg.p2.x = seg.p1.x ?	JUMP,EQ	RET$	COMP.32		A2,A3			; 1er point ?	JUMP,EQ		PUTPT1$			; oui => met le point	COMP.16		{A3}-2,D4	JUMP,NE		PUTPT1$			; non => points identique au prcdent ?	COMP.16		{A3}-4,D6	JUMP,NE		PUTPT1$			;	 non => met le point	SUB.A16		#16'04,A3		;	 oui => enlve le point prcdent	JUMP		PUTPT2$PUTPT1$:	MOVE.16		D3,{A3+}		; y clipp	MOVE.16		D4,{A3+}		; x1PUTPT2$:	MOVE.16		D3,{A3+}		; y clipp	MOVE.16		D5,{A3+}		; x2RET$:	RET;------------------------------------------------;---------\\; INITOVAL >;=========/; Prpare le calcul d'une ovale ou d'un rectangle  coins arrondis (1/4 ovales); in	A0	^rect;	A1	^variables de 16'2E bytes  initialiser;	D2.16	OvalWidth;	D1.16	OvalHeight; out	A1^:;	ORectTop:	.BLK.16	1	; 0000	rect.top;	ORectBottom:	.BLK.16	1	; 0002	rect.bottom;			.BLK.16	1	; 0004	1-OvalHeight;			.BLK.32	1	; 0006	2*OvalHeight-1;			.BLK.32	1	; 000A	0;			.BLK.32	1	; 000E	0;			.BLK.32	2	; 0012	64bits: (Fract(OvalHeight/OvalWidth))^2;			.BLK.32	2	; 001A	64bits.fract: 2*(OvalHeight/OvalWidth)^2;	OOvalCentLeft:	.BLK.32	1	; 0022	fract: x courant left, init Rect.Left+OvalWidth/2;			.BLK.32	1	; 0026	fract: x courant right, init Rect.Right-OvalWidth/2+0.5;			.BLK.32	1	; 002A	0.5;	LG:				; 2E	bytes; mod	?INITOVAL:	MOVE.16		{A0},{A1}			; rect.top	MOVE.16		{A0}+4,{A1}+16'0002		; rect.bottom	TEST.16		D2				; OvalWidth < 0 ==> =0	JUMP,PL		WIDTH0$	CLR.16		D2WIDTH0$:	TEST.16		D1				; OvalHeight < 0 ==> =0	JUMP,PL		HEIGHT0$	CLR.16		D1HEIGHT0$:	MOVE.16		{A0}+6,D0			; rect.right	SUB.16		{A0}+2,D0			; - rect.left	COMP.16		D0,D2				; OvalWidth =< width(rect) ?	JUMP,LE		ROUNDWIDTH$	MOVE.16		D0,D2				; non => OvalWidth := width(rect)ROUNDWIDTH$:	MOVE.16		{A0}+4,D0			; rect.bottom	SUB.16		{A0},D0				; - rect.top	COMP.16		D0,D1				; OvalHeight =< height(rect) ?	JUMP,LE		ROUNDHEIGHT$	MOVE.16		D0,D1				; non => OvalHeight := height(rect)ROUNDHEIGHT$:	MOVE.16		{A0}+6,{A1}+16'0026		; rect.right	CLR.16		{A1}+16'0028	MOVE.16		{A0}+16'0002,{A1}+16'0022	; rect.left	CLR.16		{A1}+16'0024	MOVE.16		D2,D0	SWAP.32		D0	CLR.16		D0	SR.32		#1,D0				; D0.fract := OvalWidth /2	ADD.32		D0,{A1}+16'0022	SUB.32		D0,{A1}+16'0026	MOVE.32		#16'00008000,D0			; 0.5	MOVE.32		D0,{A1}+16'002A	ADD.32		D0,{A1}+16'0026	MOVE.32		#16'00000001,D0	SUB.16		D1,D0				; 1-OvalHeight	MOVE.16		D0,{A1}+16'0004	MOVE.16		D1,D0	CONV.A16.32	D0	ADD.32		D0,D0	DEC.32		D0	MOVE.32		D0,{A1}+16'0006			; 2*OvalHeight-1	CLR.32		{A1}+16'000A	CLR.32		{A1}+16'000E	CLR.32		{-A7}	PUSH.16		D1				; num: Heigh	PUSH.16		D2				; denom: Widht	CALL		R16^FixRatio			; {A7}.fract := OvalHeight / OvalWidth	PUSH.32		{A7}	PUSH.32		#{A1}+16'0012	CALL		R16^LongMul			; ** 2 ==> {A6}+16'12.64	MOVE.32		{A1}+16'0016,D0			; Partie fractionnaire	ADD.32		D0,D0				; *2	MOVE.32		D0,{A1}+16'001E	MOVE.32		{A1}+16'0012,D0			; Partie entire	ADDX.32		D0,D0				; *2	MOVE.32		D0,{A1}+16'001A	RET;------------------------------------------------;----------\\; BUMPOVAL  >;==========/; in	A3	^variables (cf INITOVAL);	D0.16	= y courant; out	{A3}+22	nb fract. x left;	{A3}+26	nb fract. x droite; mod	A3,?BUMPOVAL:	COMP.16		{A3+},D0		; current y < rect.top ?	JUMP,LT		RTN$			; oui => fait rien	COMP.16		{A3+},D0		; current y > rect.bottom	JUMP,GE		RTN$			; oui => fait rien	MOVE.16		{A3},D0			; 2*(y-y0) (init 1-OvalHeight)	ADD.16		#2,{A3+}	MOVEM.32	{A3},D1|D2|D3|D4|D5|D6|D7|A0|A1|A2						; D1 = 2*OvalHeight-1						; D2 = 0						; D3 = 0						; D4;D5 = (fract(OvalHeight/OvalWidth))^2						; D6;D7 = 2*(fract(OvalHeight/OvalWidth))^2						; A0 fractionnaire: current x left						; A1 fractionnaire: current x right						; A2 fractionnaire: 0.5	JUMP		BEGCALC$ADDLOOP$:	ADD.32		A2,A1			; current x right :+ 0.5	SUB.32		A2,A0			; current x left  :- 0.5	ADD.32		D5,D3	ADDX.32		D4,D2			; add (2n+1)*((OvalHeight/OvalWidth)^2)	ADD.32		D7,D5			; add 2*(OvalHeight/OvalWidth)^2 to 2n+1...	ADDX.32		D6,D4BEGCALC$:	COMP.32		D1,D2			; INT(2n+1*((OvalHeight/OvalWidth)^2)) < 2*OvalHeight-1?	JUMP,LT		ADDLOOP$		; oui => recommence	JUMP		BEGSUB$SUBLOOP$:	SUB.32		A2,A1			; current x right :- 0.5	ADD.32		A2,A0			; current x left  :+ 0.5	SUB.32		D7,D5	SUBX.32		D6,D4			; sub 2*(OvalHeight/OvalWidth)^2 to 2n+1...	SUB.32		D5,D3	SUBX.32		D4,D2			; sub (2n+1)*((OvalHeight/OvalWidth)^2)BEGSUB$:	COMP.32		D1,D2			; INT(2n+1*((OvalHeight/OvalWidth)^2)) > 2*OvalHeight-1?	JUMP,GT		SUBLOOP$		; oui => soustrait	INC.16		D0			; non => inc 2*(y-y0) (devient init. 2-OvalHeight)	CONV.A16.32	D0	ASL.32		#2,D0			; * 4	SUB.32		D0,D1			; 2*OvalHeght-1 - 4*(2*(y-y0)+1)	MOVEM.32	D1|D2|D3|D4|D5|D6|D7|A0|A1|A2,{A3}RTN$:	RET;-----------------\\;  _GMI_PutRgn     >;=================/; FUNCTION PutRgn (BuildingRgn: RgnHandle; srcRgn: RgnHandle, Way: Direction): PsosError;; ajoute une rgion ( laquelle on associe une direction)  coordonnes relles  la rgion (ouverte); in	SP^;	+10.16	place pour PsosError;	+6.32	BuildingRgn;	+2.32	srcRgn;	+0.8	Way (0 positif, 1 negatif); out	SP^;	+0.16	PsosError; mod	F_GMI_PutRgn:	LINK.32	A6,#0	PUSHM.32 D0|D1|D2|A0|A1|A5	SUB.32	#2,A7			; place pour PsosError	PUSH.32	{A6}+8+2		; ^rgn	MOVE.32	{A6}+8+6,A0		; ^BuildingRgn	MOVE.32	{A0},A5			; ^Osimgrp...	PUSH.32	{A5}+OsimgrpPT	PUSH.32	#{A5}+OsimgrpNB	PUSH.32	#{A5}+OsimgrpLG	MOVE.32	#R16^TESTLASTPT,A1	CALL	PUTRGNINT	POP.16	{A6}+8+10'10		; PsosError	POPM.32	D0|D1|D2|A0|A1|A5	UNLINK.32 A6	MOVE.32	{A7},{A7}+10'10	ADD.32	#10'10,A7RETSIM:	RET;------------------------------------------------; ROUTINE INTERNE:; FONCTION PUTRGN (rgn: RgnHandle; Mem: Handle; VAR Offset_fin, MemLenght: Ptr to LONGINT): PsosError;;; Etablit la rgion rgn comme une liste de points (y,x) dans la mmoire.; agrandit le Handle si ncessaire, et rend la longueur de la mmoire, et celle; des donnes.; in;	{A7}+20.16	Place pour rsultat: PsosError;	{A7}+16.32	^rgn;	{A7}+12.32	Handle  la mmoire;	{A7}+8.32	^#0.32	(Offset fin);	{A7}+4.32	^longueur_mmoire.32; out	{A7}+4.16	Rsultat: PsosErrorPUTRGN:	MOVE.32		#R16^RETSIM,A1; en plus: A1 ^routine appelle comme TESTLASTPT, avec A5 pass et A3 ^juste aprs paire; de points ET que mod A3.PUTRGNINT:	LINK.32		A6,#-4	PUSHM.32	D6|D7|A2|A3|A4	MOVE.32		A1,{A6}-4		; sauve le ^routine de clipping	CLR.16		{A6}+16'0018		; pas d'erreur  priori	MOVE.32		{A6}+16'0010,A4		; Handle  la mmoire	MOVE.32		{A6}+16'0014,A1		; ^rgn	MOVE.32		{A6}+16'000C,A2		; ^#0.16	OsimgrpNB	MOVE.32		{A1},A0			; A0 ^rgn.VARS	MOVE.32		{A0}+OrgnSize,D6	; D6 taille	ADD.32		D6,D6			; *2	ADD.32		{A2},D6			; +OsimgrpNB	MOVE.32		{A6}+16'0008,A3		; ^longueur mmoire dj rserve	^OsimgrpLG	COMP.32		{A3},D6			; > 2*taille ?	JUMP,LE		NORESIZE$		; ok, pas de resizing...	ADD.32		#16'0100,D6		; additionne 256 bytes  la longueur...	PUSH.32		A1	PUSH.32		A4	PUSH.32		D6	CALL		R16^SETHSIZELD7		; change la taille du handle	POP.32		A1	MOVE.16		D7,{A6}+16'0018	JUMP,NE		RTNER$	MOVE.32		D6,{A3}			; mmorise la longueur rserve dans la long^	MOVE.32		{A1},A0			; A0 ^rgn.Vars	MOVE.32		{A6}+16'000C,A2		; ^OsimgrpNBNORESIZE$:	MOVE.32		{A6}-4,A1		; A1 ^routine ventuelle de clipping	MOVE.32		{A4},A3			; A3 ^mmoire	ADD.32		{A2},A3			; + OsimgrpNB	COMP.32		#LGrgnMin,{A0}+OrgnSize	JUMP,NE		NOTRECT$	ADD.A16		#OrgnBBox,A0		; A0 ^BBox	MOVE.32		{A0},{A3+}		; top;left --> mem	MOVE.16		{A0+},{A3+}		; top      --> mem	MOVE.16		{A0+},D0		; left	MOVE.32		{A0},D1			; bottom;right	MOVE.16		D1,{A3+}		; right    --> mem	CALL		{A1}	MOVE.16		{A0},{A3+}		; bottom   --> mem	MOVE.16		D0,{A3+}		; left     --> mem	MOVE.32		D1,{A3+}		; bottom;right --> mem	CALL		{A1}	JUMP		RTNLG$NOTRECT$:	MOVE.32		#{A0}+OrgnData,A0	; A0 ^structure en liste de la rgionNEXTY$:	MOVE.32		{A0+},D6		; new_y;beg_xNEXTX$:	MOVE.32		D6,{A3+}		; new_y;beg_x --> mem	MOVE.16		{A0+},D6		; end_x	MOVE.32		D6,{A3+}		; new_y;end_x --> mem	CALL		{A1}	MOVE.16		{A0+},D6		; beg_x/fin_liste_x	COMP.16		#rgnENDLIST,D6		; fin de liste en x ?	JUMP,NE		NEXTX$			; non => autre paire de points	COMP.16		#rgnENDLIST,{A0}	; fin de liste en y ?	JUMP,NE		NEXTY$			; non => liste y suivanteRTNLG$:	SUB.32		{A4},A3			; longueur finale	MOVE.32		A3,{A2}			; mise dans le +#0.16 initialRTNER$:	POPM.32		D6|D7|A2|A3|A4	UNLINK.32	A6	POP.32		A0	ADD.A16		#16'0010,A7	JUMP		{A0};-----------------\\;  _GMI_RGNBBOX    >;=================/; rend le "bounding box" et la nature de la rgion; GmiRgnBBox (Region: RgnId, VAR BBox: Rectangle): BOOLEAN;; in	SP^:;	+8.16	RESULT:		place pour rsultat;	+4.32	Region		identificateur de rgion;	+0.32	BBox: VAR	^variable de 8 bytes de type Rectangle; out		{BBox}:		rectangle englobant la rgion: [(0,0);(0,0)] si rgion vide;	SP^:;	+0.16	RESULT:		=0  ==> rgion rectangulaire;				<>0 ==> rgion complexe; mod	F, et ne modifie PAS D0..D2|A0|A1_GMI_RGNBBOX:	PUSHM.32 D0|D1|D2|A0|A1	MOVE.32	{SP}+4+5*4+4,A0		; A0 ^Rgion Id	MOVE.32	{A0},A0			; A0 ^Rgion.vars	CLR.16	{SP}+4+5*4+8		; suppose rgion rectangulaire...	COMP.32	#LGrgnMin,{A0}+OrgnSize	; si rgion minimale ?  ==> rectangulaire	JUMP,EQ	RECT$	NOT.16	{SP}+4+4*5+8		; sinon met complexe...RECT$:	ADD.32	#OrgnBBox,A0		; ^BBOX	MOVE.32	{SP}+4+5*4+0,A1		; ^VAR	MOVE.32	{A0+},{A1+}		; P1	MOVE.32	{A0},{A1}		; P2	POPM.32	D0|D1|D2|A0|A1	MOVE.32	{SP},{SP}+4+8-4	ADD.32	#4+8-4,SP	RET;-----------------\\;  _GMI_COPYRGN    >;=================/; FONCTION CopyRgn (srcRgn,dstRgn: RgnHandle): PsosError;;; Copie la rgion srcRgn dans dstRgn.;; in	SP^;	+8.16	place pour PsosError;	+4.32	^srcRgn;	+0.32	^dstRgn; out	SP^;	+0.16	PsosError;------------\\;  COPYRGN    >;============/_GMI_COPYRGN:COPYRGN:	LINK.32		A6,#+16'0000	PUSHM.32	D0|D1|D2|A0|A1	MOVE.32		{A6}+16'000C,A0		; A0 ^srcRgn	MOVE.32		{A6}+16'0008,A1		; A1 ^dstRgn	CLR.16		{A6}+16'0010		; par dfaut pas d'erreur	COMP.32		A0,A1			; rgions identiques ?	JUMP,EQ		RETOUR$	MOVE.32		{A0},A0			; A0 ^srcRgn variables	MOVE.32		{A1},A1			; A1 ^dstRgn variables	MOVE.32		{A0}+OrgnSize,D0	COMP.32		{A1}+OrgnSize,D0	; tailles dj identiques ?	JUMP,EQ		TAILLEOK$	PUSHM.32	D0|D7	PUSH.32		{A6}+16'0008		; ^dstRgn	PUSH.32		D0			; taille srcRgn	CALL		R16^SETHSIZELD7		; change la taille de la mmoire dstRgn	MOVE.16		D7,{A6}+16'0010		; rend l'erreur	POPM.32		D0|D7	JUMP,NE		RETOUR$	MOVE.32		{A6}+16'000C,A0	MOVE.32		{A6}+16'0008,A1	MOVE.32		{A0},A0			; reprend A0 ^srcRgn.vars	MOVE.32		{A1},A1			; A1 ^srcRgn.varsTAILLEOK$:	SR.16		#16'02,D0		; taille multiple de 4 ?	JUMP,CC		DECR$			; oui	MOVE.16		{A0+},{A1+}		; non => copie d'abord un word	JUMP		DECR$NEXTLONG$:	MOVE.32		{A0+},{A1+}		; puis uniquement des longwordsDECR$:	DJ.16,NMO	D0,NEXTLONG$RETOUR$:	POPM.32		D0|D1|D2|A0|A1	UNLINK.32	A6	MOVE.32		{A7},{A7}+8	ADD.A16		#8,A7	RET;----------------------\\;  _GMI_SetEmptyRgn     >;======================/; FUNCTION SetEmptyRgn (rgn: RgnHandle);;; Dtruit la rgion rgn, et la met comme tant vide (rectangle [(0,0)(0,0)}).;; in	SP^;	+4.32	^rgn; out	-; mod	F;------------------\\;   SetEmptyRgn     >;==================/_GMI_SetEmptyRgn:SETEMPTYRGN:	CLR.32		{-A7}			; fin rectangle (0,0)]	PUSH.32		{A7}+4			; dplace adresse de retour	CLR.32		{A7}+8			; dbut rectangle [(0,0);;;	JUMP		R16^SETRECTRGN		; force le rectangle [(0,0)(0,0)];-------------------\\;  _GMI_SetRectRgn   >;===================/; PROCEDURE SetRectRgn (rgn: RgnHandle; left,top,right,bottom: INTEGER);;; (re-)dfinit la rgion rgn comme tant le rectangle [(top,left)(bottom,right)}.; traite le cas des rectangles vides (top>bottom ou left>right).;; in	SP^;	+8.32	^rgn;	+6.16	^left;	+4.16	^top;	+2.16	^right;	+0.16	^bottom; out	-; mod	F;--------------\\;  SETRECTRGN   >;==============/_GMI_SETRECTRGN:SETRECTRGN:	LINK.32		A6,#+16'0000	PUSHM.32	D0|D1|D2|D3|A0|A1|A2	MOVE.32		{A6}+16'0010,A0		; A0 ^rgn	MOVE.32		{A0},A1			; A1 ^rgn.Vars	MOVE.32		#LGrgnMin,D0		; Rgion dj rectangulaire ?	COMP.32		{A1}+OrgnSize,D0	; Est-ce le cas ?	JUMP,EQ		SIZEOK$	PUSHM.32	D0|D7	PUSH.32		A0	PUSH.32		D0	CALL		R16^SETHSIZELD7		; Change la taille des variables	MOVE.32		{A6}+16'0010,A0	MOVE.32		{A0},A1			; reprend le ^rgn.Vars	MOVE.32		#LGrgnMin,{A1}+OrgnSize	; et met la nouvelle taille rectangulaire						; IGNORE l'erreur, La rgion ne peut tre plus petite!	POPM.32		D0|D7SIZEOK$:	MOVE.32		{A6}+16'000C,{A1}+OrgnBBox+0	; top,left	MOVE.32		{A6}+16'0008,{A1}+OrgnBBox+4	; bottom,right	----> rgnBBox	MOVE.16		{A1}+OrgnBBox+0+2,D0	COMP.16		{A1}+OrgnBBox+4+2,D0		; right=<left ?	JUMP,GE		NULLSIZE$			; oui => vide	MOVE.16		{A1}+OrgnBBox+0+0,D0	COMP.16		{A1}+OrgnBBox+4+0,D0	; et bottom>top ?	JUMP,LT		GOODSIZE$		; oui => pleinNULLSIZE$:	CLR.32		{A1}+OrgnBBox+0		; met un rectangle BBox vide	CLR.32		{A1}+OrgnBBox+4GOODSIZE$:	POPM.32		D0|D1|D2|D3|A0|A1|A2	UNLINK.32	A6	MOVE.32		{A7},{A7}+10'12	ADD.A16		#10'12,A7	RET;------------------\\;  _GMI_RectRgn     >;==================/; PROCEDURE RectRgn (rgn: RgnHandle; r: Rect);;; Dfinit la rgion rgn comme tant le rectangle r.; traite le cas des rectangles vides (top>bottom ou left>right).;; in	SP^;	+4.32	^rgn;	+0.32	^r; Out	-_GMI_RectRgn:RECTRGN:	PUSH.32		{A7}			; met une place de plus car lg(rect)=8,lg(^rect)=4.						; donc: adresse de retour dplace.	PUSH.32		A0	MOVE.32		{A7}+4+4+4,A0		; ^r	MOVE.32		{A0+},{A7}+4+4+4	; Top;Left	MOVE.32		{A0},{A7}+4+4		; Bottom;Right	POP.32		A0	JUMP		SETRECTRGN;-------------------\\;  _GMI_OffsetRgn    >;===================/; PROCEDURE OffsetRgn (rgn: RgnHandle; dh,dv: INTEGER);;; Dplace toute la rgion rgn de dh vers la droite et de dv vers le bas.; dh et dv peuvent tre ngatifs. N'affecte ni la taille ni la forme de; la rgion.; in	SP^;	+4.32	^rgn;	+2.16	dh;	+0.16	dv; out	-; mod	F_GMI_OFFSETRGN:	PUSHM.32	D0|D1|A0	MOVE.16		{A7}+4*4+0,D1		; dv	MOVE.16		{A7}+4*4+2,D0		; dh	MOVE.32		{A7}+4*4+4,A0		; rgn	MOVE.32		{A0},A0			; rgn.vars	ADD.A16		#OrgnBBox,A0	ADD.16		D1,{A0+}		; top + dv	ADD.16		D0,{A0+}		; left + dh	ADD.16		D1,{A0+}		; bottom + dv	ADD.16		D0,{A0+}		; right + dh	COMP.32		#LGrgnMin,{A0}-OrgnBBox-8+OrgnSize	; rgion rectangulaire ?	JUMP,EQ		RTN$			; c'est fait !NEXTY$:	ADD.16		D1,{A0+}		; newY + dvNEXTX$:	ADD.16		D0,{A0+}		; begX + dh	ADD.16		D0,{A0+}		; endX + dh	COMP.16		#rgnENDLIST,{A0}	; fin de liste X ?	JUMP,NE		NEXTX$	ADD.A16		#16'02,A0	COMP.16		#rgnENDLIST,{A0}	; fin de liste Y ?	JUMP,NE		NEXTY$RTN$:	POPM.32		D0|D1|A0	MOVE.32		{A7},{A7}+8	ADD.32		#8,A7	RET;------------------\\;  _GMI_InsetRgn    >;==================/; FUNCTION InSetRgn(rgn: RgnHandle; dvBottom, dvTop, dhRight, dhLeft: INTEGER): PsosError;; Re-proportionne la rgion rgn relativement  son centre, poussant les; bords haut et bas de dv vers le centre, et les bords gauche et droite; de dh vers le centre.; dv et dh peuvent tre ngatifs.; Le cas d'une rgion rectangulaire se rapporte  InsetRect.; Un bloc de mmoire de 2 fois la taille de la rgion peut tre pris temporairement.; in	SP^;	+12.16	place pour PsosError;	+8.32	^rgn;	+6.16	dvBottom;	+4.16	dvTop;	+2.16	dhRight;	+0.16	dhLeft; out	SP^;	+0.16	PsosError; mod	F_GMI_INSETRGN:	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3|A4	MOVE.32		{A7}+10'14*4+8,A4	; ^rgn	MOVE.32		{A7}+10'14*4+4,D3	; Top;Bottom	MOVE.32		{A7}+10'14*4+0,D4	; Left;Right	CLR.16		{A7}+10'14*4+10'12	;  priori pas d'erreur	TEST.32		D3	JUMP,NE		JOB$	TEST.32		D4	JUMP,EQ		RTN$			; dv = dh = 0 ? oui => rien  faireJOB$:	MOVE.32		{A4},A3			; A3 ^rgn.Vars	MOVE.32		{A3+},D6		; rgnSize	COMP.32		#LGrgnMin,D6		; uniquement un rectangle ?	JUMP,NE		NOTRECT$		; non						; oui => reproportionne le rectangle	CALL		InsetRect		; A3	^Rect rgnBBox						; D3,D4	dvTop;dvBottom,dhLeft,dhRight	JUMP		RTN$NOTRECT$:	ADD.32		D6,D6			; rgnSize * 2	CLR.32		{-A7}			; rserve place pour Handle	PUSH.32		D6			; taille...	CALL		R16^NEWHANDLELD7	POP.32		A3			; A3 ^Handle provisoire	MOVE.16		D7,{A7}+10'14*4+10'12	; PsosError	JUMP,NE		RTN$			; erreur => retour	CALL		SCALEXORY$	TEST.16		D7	JUMP,NE		DISPOSE$	EX.32		D3,D4	CALL		SCALEXORY$	JUMP		DISPOSE$		; et voil ! rend le Handle et retourSCALEXORY$:	CLR.32		{-A7}			; rserve place sur le stack	CLR.16		{-A7}	PUSH.32		#{A7}+2	PUSH.32		A4			; ^rgn	PUSH.32		A4	PUSH.32		A3			; ^place de 2*longueur du Handle	PUSH.32		D6			; place alloue (2*lg...)	PUSH.16		#16'0008		; opration no 8...	PUSH.32		D4			; d'abord dh (puis ce sera dv)	SET.8		{-A7}			; flag  1 (voir RFGNOP)	CALL		R16^RGNOP		; effectue l'opration	POP.16		D7	POP.32		D5			; nombre de boucles pour swaper des long	TEST.16		D7	JUMP,NE		RTNSC$	MOVE.32		{A3},A0			; A0 ^mmoire provisoire	MOVE.32		D5,D1	DEC.32		D1	JUMP		DJNMO$RESWAP$:	MOVE.32		{A0},D0	SWAP.32		D0			; swape la mmoire provisoire !	MOVE.32		D0,{A0+}		; en reswapant la 2me fois, on retombe sur ses pieds !DJNMO$:	DEC.32		D1	JUMP,NE		RESWAP$	SUB.32		#2,SP			; place pour erreur	PUSH.32		{A3}			; ^mmoire provisoire	PUSH.32		D5			; longueur en longwords	CALL		R16^SORTPOINTS	POP.16		D7			; rend l'erreur	JUMP,NE		RTNSC$	SUB.32		#2,A7			; rserve place pour erreur	PUSH.32		A3			; ^rgn provisoire	PUSH.32		D5			; longeur en longwords	PUSH.32		A4			; ^rgn	CALL		R16^PACKRGN		; compresse	POP.16		D7			; erreur ?RTNSC$:	RETDISPOSE$:	MOVE.16		D7,{A7}+10'14*4+10'12	; PsosError	MOVE.32		A3,A0	CALL		DISPOSEHANDLE		; rend le Handle provisoireRTN$:	POPM.32		D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3|A4	MOVE.32		{A7},{A7}+10'12	ADD.A16		#10'12,A7	RET;------------------\\;  _GMI_EmptyRgn    >;==================/; FUNCTION EmptyRgn (rgn: RgnHandle): BOOLEAN;;; Vrifie si la rgion rgn est vide (TRUE) ou pleine (FALSE).;; in	SP^;	+4.8	place pour BOOLEAN en retour;	+0.32	^rgn; out	SP^;	+0.8	BOOLEAN (TRUE <> 0, FALSE = 0); mod	F;--------------\\;   EmptyRgn    >;==============/_GMI_EMPTYRGN:EMPTYRGN:	PUSH.32		A1	MOVE.32		{A7}+4+4,A1		; ^rgn	MOVE.32		{A1},A1			; ^rgn.vars	ADD.32		#OrgnBBox,A1		; ^Rect englobant	MOVE.32		A1,{A7}+4+4	POP.32		A1	JUMP		EMPTYRECT		; teste juste sur le rectangle !;-------------------\\;  _GMI_EqualRgn     >;===================/; FUNCTION EqualRgn (rgnA,rgnB: RgnHandle): BOOLEAN;;; Vrifie si les rgions rgnA et rgnB sont egales (TRUE) ou pas (FALSE).; 2 rgions sont gales si leur taille, forme, et emplacement sont identiques.; 2 rgions vides quelquonques sont toujours considres gales.;; in	SP^;	+8.8	place pour BOOLEAN;	+4.32	^rgnA;	+0.32	^rgnB; out	SP^;	+0.8	Boolean (<> 0 TRUE, =0 FALSE); mod	F;---------------\\;   EqualRgn     >;===============/_GMI_EqualRgn:EQUALRGN:	PUSHM.32	D0|D1|A0|A1	MOVE.32		{A7}+5*4+0,A0		; A0 ^rgnB	MOVE.32		{A7}+5*4+4,A1		; A1 ^rgnA	COMP.32		A0,A1			; la mme rgion ?	JUMP,EQ		ISEQUAL$		; oui => bche tout de suite !	MOVE.32		{A0},A0			; A0 ^rgnB.Vars	MOVE.32		{A1},A1			; A1 ^rgnA.Vars	MOVE.32		{A0},D0			; D0 = rgnB.Vars.rgnSize	MOVE.32		D0,D1	SR.32		#16'02,D1		; D1 = D0/4CMP32$:	COMP.32		{A0+},{A1+}		; compare les longwords	JUMP,NE		NOTEQUAL$	DEC.32		D1	JUMP,NE		CMP32$	AND.16		#16'0003,D0		; et le reste...	JUMP,EQ		ISEQUAL$		; ...s'il y a quelque choseCMP8$:	COMP.8		{A0+},{A1+}		; compare les 1..3 bytes restants	JUMP,NE		NOTEQUAL$	DEC.16		D0	JUMP,NE		CMP8$ISEQUAL$:	MOVE.32		#1,D0			; Met TRUE	JUMP		RTN$NOTEQUAL$:	MOVE.32		#0,D0			; Met FALSERTN$:	MOVE.8		D0,{A7}+5*4+8		; Met BOOLEAN	POPM.32		D0|D1|A0|A1	MOVE.32		{A7},{A7}+8	ADD.A16		#8,A7	RET;------------------\\;   _GMI_OperRgn    >;==================/; FUNCTION OperRgn (srcRgnA, srcRgnB, dstRgn: rgnId; operation: INTEGER;): PsosError;; Effectue une opration entre 2 rgions srcRgnA et  srcRgnB, et place; le rsultat dans dstRgn. dstRgn peut tre une des sources.; Traite le cas des rgions vides, qui donnent par exemple une intersection vide.; Traite le cas des rgions vides:;	Sect:	1 rgion vide donne une intersection vide.;	Union:	2 rgions vides donnent une union vide.;	Diff:	si la 1re est vide, la diffrence vide.;	Xor:	si les 2 rginons sont identiques, le XOR est une rgion vide.; Un bloc de mmoire de 2 fois la taille de la rgion peut tre pris temporairement.; in	SP^;	+14.16	RESULT:		place pour rsultat;	+10.32	srcRgnA		identificateur de rgion;	+6.32	srcRgnB		identificateur de rgion;	+2.32	dstRgn		identificateur de rgion;	+0.16	opration:;		0	GOpSect		A intersection B;		4	GOpUnion	A union B;		2	GOpDiff		A - B  (toute partie de A non-incluse dans B);		6	GOpXor		A ou exclusif B; out	SP^;	+0.16	RESULT:		erreur; mod	F, et ne modifie PAS D0..D2|A0|A1_GMI_OperRgn:	LINK.32		A6,#-16'0008	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3|A4	MOVE.16		{A6}+16'0008,D5		; opration dans D5	MOVE.32		{A6}+16'0012,A2		; A2 ^srcRgnA	MOVE.32		{A6}+16'000E,A3		; A3 ^srcRgnB	MOVE.32		{A6}+16'000A,A4		; A4 ^dstRgn	CLR.16		{A6}+8+10'14		; PsosError=NoError Par dfaut.	MOVE.32		#2,D7			; masque d'oprations XOR et DIFF	CLR.8		{-A7}	PUSH.32		A2	PUSH.32		A3	CALL		R16^EQUALRGN		; srcRgnA = srcRgnB ?	TEST.8		{A7+}	JUMP,EQ		NOTEQUAL$	AND.16		D7,D5			; opration XOR ou DIFF ?	JUMP,NE		EMPTY$			; oui => rsultat vide (sinon SECT ou UNION: plein)COPY$:	PUSH.32		A2	PUSH.32		A4	CALL		R16^COPYRGN		; copie  srcRgnA --> dstRgn	JUMP		RTN$EMPTY$:	PUSH.32		A4	CALL		R16^SETEMPTYRGN		; met dstRgn = vide	JUMP		RTN$NOTEQUAL$:	MOVE.32		{A2},A0			; A0 ^srcRgnA.Vars	MOVE.32		{A3},A1			; A1 ^srcRgnB.Vars	COMP.16		D7,D5	JUMP,GT		UNIONXOR$		; opration UNION ou XOR	JUMP,LT		SECT$			; opration SECT						; opration DIFF:	MOVE.16		{A1}+OrgnBBox+2,D0	; srcRgnB.Vars.rgnBBox.left	COMP.16		{A1}+OrgnBBox+6,D0	; right=<left (rgion vide) ?	JUMP,GE		COPY$			; oui => copie srcRgnA --> dstRgnSECT$:	PUSH.32		#{A0}+OrgnBBox		; ^srcRgnA.Vars.rgnBBox	PUSH.32		#{A1}+OrgnBBox		; ^srcRgnB.Vars.rgnBBox	PUSH.16		D7			; valeur 2 (2 rectangles  intersecter)	PUSH.32		#{A6}-16'0008		; ^rect provisoire sur la pile	CALL		R16^RSECT		; calcule l'intersection des 2 rectangles	JUMP,NE		RSECTNOTEMPTY$	TEST.16		D5			; SECT (pas UNION ici) ?	JUMP,EQ		EMPTY$			; oui => rsultat vide	JUMP		COPY$			; non => rsultat = srcRgnARSECTNOTEMPTY$:	MOVE.32		{A2},A0			; A0 ^srcRgnA.Vars	MOVE.32		{A3},A1			; A1 ^srcRgnB.Vars	TEST.16		D5			; SECT ?	JUMP,NE		OPCOMPLEX$		; non	MOVE.32		#LGrgnMin,D0	COMP.32		{A0}+OrgnSize,D0	; rgion srcRgnA rectangulaire ?	JUMP,NE		OPCOMPLEX$		; non	COMP.32		{A1}+OrgnSize,D0	; rgion srcRgnB aussi rectangulaire ?	JUMP,NE		OPCOMPLEX$		; non	PUSH.32		A4			; dstRgn	PUSH.32		#{A6}-16'0008		; SectRect provisoire	CALL		R16^RECTRGN		; intersection rectangulaire selon SectRect	JUMP		RTN$UNIONXOR$:	MOVE.16		{A1}+OrgnBBox+2,D0	; srcRgnB.Vars.rgnBBox.left	COMP.16		{A1}+OrgnBBox+6,D0	; srcRgnB.Vars.rgnBBox.right =< left ?	JUMP,GE		COPY$			; oui => copie srcRgnA	MOVE.16		{A0}+OrgnBBox+2,D0	; srcRgnA.Vars.rgnBBox.left	COMP.16		{A0}+OrgnBBox+6,D0	; srcRgnA.Vars.rgnBBox.right > left	JUMP,LT		OPCOMPLEX$	MOVE.32		A3,A2			; non => copie srcRgnB	JUMP		COPY$OPCOMPLEX$:	MOVE.32		{A0}+OrgnSize,D4	; Size srcRgnA	ADD.32		{A1}+OrgnSize,D4	; + size srcRgnB	ADD.32		D4,D4			; *2	CLR.32		{-A7}	PUSH.32		D4	CALL		R16^NEWHANDLELD7 	; demande la mmoire pour...	POP.32		A3	MOVE.16		D7,{A6}+8+10'14		; erreur --> PsosError, Erreur ?	JUMP,NE		RTN$			; oui => n'effectue pas l'opration	CLR.32		{-A7}			; rsultat	CLR.16		{-A7}	PUSH.32		#{A7}+2	PUSH.32		{A6}+16'0012		; srcRgnA	PUSH.32		{A6}+16'000E		; srcRgnB	PUSH.32		A3			; ^mmoire provisoire	PUSH.32		D4			; taille mmoire provisoire	PUSH.16		D5			; opration (0=SECT,2=DIFF,4=UNION,6=XOR)	CLR.32		{-A7}			; LONGINT utilis seulement pour INSET	SET.8		{-A7}			; ?	CALL		R16^RGNOP		; effectue l'opration sur les rgions complexes	POP.16		D7	POP.32		D6	MOVE.16		D7,{A6}+8+10'14		; erreur --> PsosError, Erreur ?	JUMP,NE		DISP$	SUB.32		#2,A7			; rserve place pour erreur	PUSH.32		A3	PUSH.32		D6	PUSH.32		A4			; Rempaquette la rgion	CALL		R16^PACKRGN	POP.16		{A6}+8+10'14		; reprend l'erreur --> PsosErrorDISP$:	MOVE.32		A3,A0	CALL		DISPOSEHANDLERTN$:	POPM.32		D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3|A4	UNLINK.32	A6	MOVE.32		{SP},{SP}+4+2+3*4-4	ADD.A16		#4+2+3*4-4,SP	RET;--------------------\\;   _GMI_PtInRgn      >;====================/; FUNCTION PtInRgn (pt: Point; rgn: RgnHandle): BOOLEAN;; Teste si le point en-dessous et  droite de la coordonne pt se trouve; dans la rgion rgn (TRUE) ou pas (FALSE); in	SP^;	+8.16	RESULT:		place pour rsultat;	+4.32		Point (y.16,x.16);	+0.32		identificateur de rgion; out	SP^;	+0.16	RESULT:		BOOLEAN: bit 0 de high byte: =0 --> FALSE, =1 --> TRUE; mod	F_GMI_PTINRGN:	LINK.32		A6,#+16'0000	PUSHM.32	D0|D1|D2|D3|A0|A1	MOVE.16		{A6}+16'000E,D1		; D1 x	MOVE.16		{A6}+16'000C,D2		; D2 y	CLR.16		D3			; D3: BOOLEAN  retourner (FALSE par dfaut)	MOVE.32		{A6}+16'0008,A0		; ^rgn	MOVE.32		{A0},A0			; A0 ^rgn.Vars	COMP.16		{A0}+OrgnBBox+2,D1	; x < left ?	JUMP,LT		RTNBOOL$	COMP.16		{A0}+OrgnBBox+6,D1	; x >= right ?	JUMP,GE		RTNBOOL$	COMP.16		{A0}+OrgnBBox+0,D2	; y < top ?	JUMP,LT		RTNBOOL$	COMP.16		{A0}+OrgnBBox+4,D2	; y >= bottom ?	JUMP,GE		RTNBOOL$	COMP.32		#LGrgnMin,{A0}+OrgnSize	; rgion rectangulaire ?	JUMP,NE		NOTRECT$		; non	NOT.16		D3			; oui => c'est fini avec TRUE	JUMP		RTNBOOL$NOTRECT$:	MOVE.32		#{A0}+OrgnData,A0	; A0 ^structure de donnesNEXTY$:	COMP.16		{A0+},D2		; y < 1er y de la liste ? (ou fin de liste en y)	JUMP,LT		RTNBOOL$		; oui => rend FALSE et c'est finiNEXTX$:	MOVE.16		{A0+},D0		; nouveau beg_x/end_x	COMP.16		#rgnENDLIST,D0		; fin de liste en x ?	JUMP,EQ		NEXTY$			; oui => liste suivante en y	COMP.16		D1,D0			; x =< beg_x/end_x ?	JUMP,GT		NEXTX$			; oui => ne change pas le rsultat, x suivant !	NOT.16		D3			; non => change le rsultat (ok, car par paires)	JUMP		NEXTX$			; et x suivant !RTNBOOL$:	NEG.8		D3			; 0 --> 0 , 16'FF --> 1	MOVE.8		D3,{A6}+16'0010		; rend la valeur booleene	POPM.32		D0|D1|D2|D3|A0|A1	UNLINK.32	A6	MOVE.32		{SP},{SP}+4+8-4	ADD.A16		#4+8-4,A7	RET;-------------------\\;  _GMI_RectInRgn    >;===================/; FUNCTION RectInRgn (r: Rect; rgn: RgnHandle): BOOLEAN;;; Teste si le rectangle r intersecte la rgion rgn, et rend TRUE si; au moins un pixel se trouve  l'intrieur, et FALSE s'il n'y en a pas.;; in	SP^;	+8.8	place pour BOOLEAN;	+4.32	^r;	+0.32	^rgn; out	SP^;	+0.8	BOOLEAN (<>0 TRUE, =0 FALSE); mod	F_GMI_RectInRgn:	LINK.32		A6,#-16'0024		; 16'24 bytes de variables sur stack:				; -08.32:	rect	rectangle intersection (r,rgnBBox)				; -0C.32:	A7				; -24.32:	rgn ???	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3|A4|A5	MOVE.32		A7,{A6}-16'000C	CLR.8		{A6}+16'0010		; FALSE par dfaut	MOVE.32		{A6}+16'0008,A1		; A1 ^rgn	MOVE.32		{A1},A1			; A1 ^rgn.Vars	PUSH.32		{A6}+16'000C		; ^r	PUSH.32		#{A1}+OrgnBBox		; ^rgn.Vars.rgnBBox	PUSH.16		#2			; 2 rectangles  intersectionner	PUSH.32		#{A6}-16'0008		; rectangle rsultant	CALL		R16^RSECT	JUMP,EQ		RTN$			; pas d'intersection !	COMP.32		#LGrgnMin,{A1}+OrgnBBox	; rgion rectangulaire ?	JUMP,EQ		INTERSECT$		; oui => a intersectionne	MOVE.32		A1,A0	MOVE.32		#{A6}-16'0024,A1	MOVE.16		{A6}-16'0006,D0		; left	MOVE.16		{A6}-16'0002,D1		; right	MOVE.16		D0,D2	CALL		R16^INITRGN		; Initialise une ligne de bits vide sur le stack	MOVE.16		{A1}+16'000C,D5		; delta (right-left)/32 = nb_longwords sur stack -1	MOVE.16		{A6}-16'0008,D0		; intersectRect.Top => D0 (d'o on veut commencer)	CALL		R16^SEEKRGN		; construit une premire ligne bitmap	MOVE.16		{A6}-16'0004,D6		; D6 = bottomRETEST$:	MOVE.32		{A1}+16'0008,A0		; A0 ^ligne sur le stack	MOVE.16		D5,D0			; nombre de words --> D0=compteurTSTLI$:	TEST.32		{A0+}			; teste 1re occurence non-vide	SKIP,NE	DJ.16,NMO	D0,TSTLI$	JUMP,NE		INTERSECT$	MOVE.16		{A1}+16'0010,D0		; top courant	COMP.16		D0,D6			; bottom =< top courant ?	JUMP,LE		RTN$			; oui => pas d'intersection !	CALL		R16^SEEKRGN		; non => regarde la ligne suivante...	JUMP		RETEST$INTERSECT$:	INC.8		{A6}+16'0010		; met le boolean  TRUERTN$:	MOVE.32		{A6}-16'000C,A7		; rcupre le stack (et oublie la ligne prise)	POPM.32		D0|D1|D2|D3|D4|D5|D6|D7|A0|A1|A2|A3|A4|A5	UNLINK.32	A6	MOVE.32		{A7},{A7}+8	ADD.A16		#8,A7	RET	.if	false;------------------------------------------------TRIMRECT:					; ROUTINE PAS UTILISEE ICI	LINK.32		A6,#-16'002A	PUSHM.32	D0|D1|D2|A1	MOVE.32		#{A6}-16'0018,A0	MOVE.32		A0,{A6}-16'001C	MOVE.32		#{A6}-16'0026,A1	MOVE.32		A1,{A6}-16'002A	MOVE.16		#16'000A,{A1+}	MOVE.32		{A6}+16'0008,A0	MOVE.32		{A0+},{A1+}	MOVE.32		{A0+},{A1+}	CLR.32		{-A7}	CLR.16		{-A7}	PUSH.32		#{A7}+2	PUSH.32		{A6}+16'000C	PUSH.32		#{A6}-16'002A	PUSH.32		#{A6}-16'001C	PUSH.32		#16'0018	CLR.16		{-A7}			; opration	CLR.32		{-A7}			; longinteger pour INSET uniquement	CLR.8		{-A7}	CALL		R16^RGNOP	ADD.32		#2,A7			; ignore erreur ...	MOVE.32		{A6}+16'0008,A0	COMP.32		#16'0004,{A7+}	JUMP,NE		REL1697C	MOVE.32		{A6}-16'0018,{A0+}	MOVE.32		{A6}-16'000C,{A0+}	SUB.16		D0,D0REL1697C:	POPM.32		D0|D1|D2|A1	UNLINK.32	A6	POP.32		A0	ADD.A16		#16'08,A7	JUMP		{A0}	.endif	false;-----------------\;  _GMI_MapRgn     >;=================/; FONCTION MapRgn (rgn: RgnHandle; srcRect,dstRect: Rect): PsosError;;; Effectue la similitude de la rgion rgn, selon le rapport de dstRect; par rapport  srcRect. La rgion sera aussi centre en dstRect, dans; les mmes rapports qu'elle l'tait relativement  srcRect.; Pour ce faire, appelle la procdure MapPt pour tous les points de la rgion.;; in	SP^;	+12.16	Place pour PsosError;	+8.32	^rgn;	+4.32	^srcRect;	+0.32	^dstRect; Out	+0.16	PsosError_GMI_MapRgn:	LINK.32		A6,#-16'000C	PUSHM.32	D0|D1|D2|D3|D5|D6|D7|A0|A1|A2|A3|A4	MOVE.32		{A6}+16'000C,A0		; ^srcRect	MOVE.32		{A6}+16'0008,A1		; ^dstRect	COMP.32		{A0+},{A1+}		; rectangles identiques ?	JUMP,NE		DIFFRECT$	COMP.32		{A0+},{A1+}	JUMP,EQ		RTN$DIFFRECT$:	MOVE.32		{A6}+16'0010,A4		; ^rgn	MOVE.32		{A4},A0	COMP.32		#LGrgnMin,{A0}+OrgnSize	; rgion rectangulaire ?	JUMP,NE		NOTRECT$		; non	PUSH.32		#{A0}+OrgnBBox		; ^rgnBBox	PUSH.32		{A6}+16'000C		; ^srcRect	PUSH.32		{A6}+16'0008		; ^dstRect	CALL		R16^MAPRECT	JUMP		RTN$NOTRECT$:	CLR.32		{-A7}	PUSH.32		#16'0100		; Rserve 256 bytes de mmoire (pour petites	MOVE.32		{A7},{A6}-16'0008	; rgions), se rapelle en variable locale la lg).	CALL		R16^NEWHANDLELD7	POP.32		A3	MOVE.16		D7,{A6}+16'0014		; rend l'erreur	JUMP,NE		RTN$	CLR.32		{A6}-16'0004		; rien dans la mmoire => offset nul	PUSH.32		A4			; ^rgn	PUSH.32		A3			; ^handle	PUSH.32		#{A6}-16'0004		; ^offset.32 (=0)	PUSH.32		#{A6}-16'0008		; ^longueur.32	CALL		PUTRGN			; Dcompacte la rgion en suite de points (y,x)	MOVE.32		{A6}-16'0004,D5		; Longueur de la rgion, une fois dcompacte	SR.32		#16'02,D5		; /4 (c'est chaque fois un point (y,x) donc 32 bits	MOVE.32		D5,D6	INC.32		D6	MOVE.32		{A3},A2			; A2 ^mmoire de points	JUMP		FIRSTDEC$MAPLOOP$:	PUSH.32		A2			; ^Point	PUSH.32		{A6}+16'000C		; SrcRect	PUSH.32		{A6}+16'0008		; dstRect	CALL		R16^MAPPT		; re-Map le point	ADD.32		#16'04,A2		; ^point suivantFIRSTDEC$:	DEC.32		D6	JUMP,NE		MAPLOOP$	SUB.32		#2,SP			; place pour erreur	PUSH.32		{A3}			; ^mmoire de points	PUSH.32		D5			; nombre de points	CALL		R16^SORTPOINTS		; trie les points selon y et x.	POP.16		{A6}+16'0014		; rend l'erreur	JUMP,NE		DISPOSE$	PUSH.32		{A3}			; ^mmoire de points	MOVE.32		D5,{A6}-16'000A		; nombre de points en variable	PUSH.32		#{A6}-16'000A		; ^nombre de points.16	CALL		R16^CULLPOINTS		; supprime les paires de points identiques	SUB.32		#2,A7			; rserve place pour erreur	PUSH.32		A3			; ^(^mmoire de points)	PUSH.32		{A6}-16'000A		; VAR nombre de points	PUSH.32		A4			; ^rgn	CALL		R16^PACKRGN		; recompacte les points	POP.16		{A6}+16'0014		; reprend l'erreurDISPOSE$:	MOVE.32		A3,A0	CALL		DISPOSEHANDLE		; rend le Handle  la mmoire liste de pointsRTN$:	POPM.32		D0|D1|D2|D3|D5|D6|D7|A0|A1|A2|A3|A4	UNLINK.32	A6	MOVE.32		{A7},{A7}+10'12	ADD.A16		#10'12,A7	RET;-----------------\\;  _GMI_INITSRGN   >;=================/; GmiInitSRgn (Region: RgnId; PtVars: POINTER TO ARRAY[0..LgBldRgn-1] OF BYTE;; 	       MinLeft, MaxRight, LeftmostBit: INTEGER; Way: Direction;;	       VAR SEEKfuncptr: POINTER TO FUNCTION) : PsosError;;; initialise une ligne de bitmap vide. ATTENTION: ne marche que pour des rgions complexes !;; in	SP ^:;	+20.16	RESULT:		place pour rsultat;	+16.32	Region		identificateur de la rgion;	+12.32	PtVars		^zone libre de LgBldRgn bytes;	+10.16	MinLeft		masquage  gauche: peut tre Gmi_RgnBBox(Region).BBox.Left;	+8.16	MaxRight	masquage  droite: peut tre Gmi_RgnBBox(Region).BBox.Right;	+6.16	LeftmostBit	coord. x du bit de poids fort du 1er word dans la ligne bitmap;	+4.8	Way		sens du parcours (positif (=0): y croissants,;				negatif (=1): y dcroissants);	+0.32	SEEKfuncptr: VAR ^variable pour ^routine de SEEK; out	SP ^:;	+0.16	RESULT:		erreur selon format Psos_GMI_INITSRGN:	PUSHM.32 D0|D1|D2|A0|A1.if 0pushm.32 d0..d7|a0..a7lib ?aftim.ascize "(initsrgn) "move.16 {SP}+88+10'10,D4lib ?afx4,?afspacemove.16 {SP}+88+8,D4lib ?afx4,?afspacemove.16	{SP}+88+6,d4lib ?afx4,?afspacepopm.32 d0..d7|a0..a7.endif 0	MOVE.32	{SP}+4+5*4+10'12,A1	; PtVars	CLR.16	{SP}+4+5*4+10'20	; A priori pas d'erreur...	TEST.8	{SP}+4+5*4+4		; quel sens de parcours ?	JUMP,NE	NEGATIF$	MOVE.32	{SP}+4+5*4+10'16,A0	; ^rgn	MOVE.32	{A0},A0			; ^rgn.Vars	MOVE.32	A0,{A1}	MOVE.16	{A0}+OrgnBBox+0,{A1}+16'0010	MOVE.32	#{A0}+OrgnData,A0	MOVE.32	A0,{A1}+16'0004	MOVE.32	#R16^_SEEKPOS,A0	MOVE.16	#16'8001,{A1}+16'000E	JUMP	INITRGNCOMOONNEGATIF$:	MOVE.32	{SP}+4+5*4+10'16,A0	MOVE.32	{A0},A0			; ^rgn.Vars	MOVE.32	A0,{A1}	MOVE.16	{A0}+OrgnBBox+4,{A1}+16'0010	; y bottom --> next y	CLR.32	D1	MOVE.32	{A0}+OrgnSize,D1	ADD.32	D1,A0	SUB.32	#2+6-2,A0		; saute par-dessus les 2 derniers (fin y + fin x + x2 + x1)GOBACK$:	COMP.16	#rgnENDLIST,{-A0}	; il y a au minimum 2 lignes dans une rgion !	JUMP,NE	GOBACK$	ADD.32	#2,A0			; A0 ^y dernire ligne	MOVE.32	A0,{A1}+16'0004	MOVE.16	#16'7FFE,{A1}+16'000E	; current y very far....	MOVE.32	#R16^_SEEKNEG,A0INITRGNCOMOON:	MOVE.32	{SP}+4+5*4+0,A1	MOVE.32	A0,{A1}	MOVE.32	{SP}+4+5*4+10'12,A1	MOVE.16	{SP}+4+5*4+10'10,{A1}+16'0012	MOVE.16	{SP}+4+5*4+8,D1	MOVE.16	D1,{A1}+16'0014	MOVE.16	{SP}+4+5*4+6,D2	MOVE.16	D2,{A1}+16'0016	SUB.16	D2,D1			; delta(right-left")	SR.16	#5,D1			; delta/32	MOVE.16	#0,{A1}+16'000C		; par dfaut pas de morceau de mmoire	MOVE.32	#{A1}+16'0018,A0	; par dfaut ligne dans variables...	COMP.16	#(LgBldRgn-10'24)/4-2,D1 ; si ligne pas trop longue ?	JUMP,LO	OKINVAR$	PUSHM.32 D1|D4|D7|A4	CLR.32	D4	MOVE.16	D1,D4	INC.32	D4	SL.32	#2,D4	MOVE.16	#MTYPCP,D1	GESMEM	?GETMEM	MOVE.32	A4,A0	MOVE.16	D7,{SP}+4+4*4+5*4+10'20	POPM.32 D1|D4|D7|A4	JUMP,NE	RTN$OKINVAR$:	MOVE.16	D1,{A1}+16'000C		; mmorise le nombre de longwords	MOVE.32	A0,{A1}+16'0008		; ainsi que le ^dbutLOOP$:	CLR.32	{A0+}	DJ.16,NMO D1,LOOP$RTN$:	POPM.32	 D0|D1|D2|A0|A1	MOVE.32	{SP},{SP}+4+10'20-4	ADD.A16	#4+10'20-4,SP	RET;------------------------------------------------; ROUTINE INTERNE:; Sous-ROUTINE INITRGN;; Initialise une ligne vide en bitmap sur le stack;; in	A0		^rgn.Vars;	A1		^10'24 bytes de libre;		+ 0.32		= A0 in (^rgn.Vars);		+ 4.32		= ^rgn.Vars.rgnData;		+ 8.32		= ^ligne sur le stack;		+ 16'C.16	= delta(right-left)/32 (nb longwords sur stack -1);		+ 16'E.16	= 16'8001;		+ 16'10.16	= rgn.Vars.rgnBBox.top qui deviendra top courant;		+ 16'12.16	= D0 in	(left);		+ 16'14.16	= D1 in (right);		+ 16'16.16	= D2 in (left");	D0.16		left: pour masquage de la rgion (peut tre rgnBBox.left ou autre);	D1.16		right: pour masquage de la rgion (peut tre rgnBBox.right ou autre);	D2.16		left: coord. x du bit de poids fort du 1er word dans le masque;; out	A7	boug, pointant le stack, contenant une ligne en points ( 0) de la rgionINITRGN:	MOVE.16		D0,{A1}+16'0012	MOVE.16		D1,{A1}+16'0014	MOVE.16		D2,{A1}+16'0016	MOVE.32		A0,{A1}	MOVE.16		#16'8001,{A1}+16'000E	MOVE.16		{A0}+OrgnBBox+0,{A1}+16'0010	MOVE.32		#{A0}+OrgnData,A0	MOVE.32		A0,{A1}+16'0004	POP.32		A0	SUB.16		D2,D1			; delta(right-left")	SR.16		#5,D1			; delta/32	MOVE.16		D1,{A1}+16'000CLOOP$:	CLR.32		{-A7}	DJ.16,NMO	D1,LOOP$	MOVE.32		A7,{A1}+16'0008	JUMP		{A0};-----------------\\;  _GMI_RELSRGN    >;=================/; FUNCTION GmiRelSRgn (PtVars: POINTER TO ARRAY[0..LgBldRgn-1] OF BYTE): PsosError;;; rend les variables de la ligne de bitmap; Attention: doit tre appell par le mme processus que celui qui a appel; le INITSRGN correspondant.; Peut tre appell mme si INITSRGN a rendu une erreur;; in	SP ^:;	+4.16	RESULT:		place pour rsultat;	+0.32	PtVars		^zone de variables initialise par INITSRGN; out	SP ^:;	+0.16	RESULT:		erreur selon format Psos; mod	F, et ne modifie PAS D0..D2|A0|A1_GMI_RELSRGN:	PUSHM.32 D0|D1|D2|A0|A1	CLR.16	{SP}+4+5*4+4		; A priori pas d'erreur...	MOVE.32	{SP}+4+5*4+0,A1	COMP.16	#(LgBldRgn-10'24)/4-2,{A1}+16'000C ; variables dans VARs ou GESMEM ?	JUMP,LO	OKINVAR$			   ; dans VAR => rien  faire	PUSHM.32 D1|D4|D7|A1	MOVE.32	{A1}+16'0008,A4		; ^dbut	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM	MOVE.16	D7,{SP}+4+4*4+5*4+4	POPM.32 D1|D4|D7|A1OKINVAR$:	CLR.16	{A1}+16'000C		; nombre de longwords  1...si jamais 2eme RELSRGNRTN$:	POPM.32	 D0|D1|D2|A0|A1	POP.32	{SP}	RET;-----------------\\;  _SEEKPOS        >;=================/; GmiSeekSRgn (PtVars: POINTER TO ARRAY[0..LgBldRgn-1] OF BYTE, currenty: INTEGER,;	       VAR PtMaskRow: POINTER): INTEGER;;; calcule la ligne no y dans la ligne bitmap;; in	SP^:;	+10.16	RESULT:		place pour rsultat;	+6.32	PtVars		^zone de variables initialise par INITSRGN;	+4.16	currenty	y courant (coordonne en dessus de la ligne de pixels);	+0.32	PtMaskRow: VAR	^variable de 32 bits de type POINTER; out		{PtMaskRow}:	^masque (nombre de longword arrondi par exces);				les bits  1 sont pour des pixels appartenant  la rgion.;	SP^:;	+0.16	RESULT:		Prochain y pour lequel il y aurra un changement; mod	F, et ne modifie PAS D0..D2|A0|A1_SEEKPOS:	PUSHM.32 D0|D1|D2|A0|A1.if 0pushm.32 d0..d7|a0..a7lib ?aftim.ascize "(seekpos) "move.32 {SP}+88+6,D4lib ?afx8,?afspacemove.16	{SP}+88+4,d4lib ?afx4,?afspacepopm.32 d0..d7|a0..a7.endif 0	MOVE.32	{SP}+4+5*4+6,A1	MOVE.16	{SP}+4+5*4+4,D0	CALL	SEEKRGN	MOVE.16	{A1}+16'0010,{SP}+4+5*4+10'10	; next y o il y a changement	MOVE.32	{SP}+4+5*4+0,A0			; ^VAR	MOVE.32	{A1}+16'0008,{A0}		; met ^dbut ligne dans VARRTN$:	POPM.32	 D0|D1|D2|A0|A1	MOVE.32	{SP},{SP}+4+10'10-4	ADD.A16	#4+10'10-4,SP	RET;------------------------------------------------; ROUTINE INTERNE:; Sous-ROUTINE SEEKRGN;; Met une ligne en bitmap de la rgion sur le stack;; in	A1		^24 bytes initialiss par INITRGN;		+ 0.32		= ^rgn.Vars;		+ 4.32		= ^rgn.Vars.rgnData;		+ 8.32		= ^ligne sur le stack;		+ 16'C.16	= delta(right-left)/32 (nb longwords sur stack -1);		+ 16'E.16	= y rgn courant;		+ 16'10.16	= next y rgn;		+ 16'12.16	= left';		+ 16'14.16	= right;		+ 16'16.16	= left";	D0.16		current y; out	D1.16	=0	masque inchang, =1 masque chang.; mod	F,D1,A0SEEKRGN:	COMP.16		{A1}+16'0010,D0		; current y >= next y rgn	JUMP,GE		YTOPOK$			; oui	COMP.16		{A1}+16'000E,D0		; current y < current y rgn	JUMP,LT		REBUILD$		; oui	CLR.16		D1			; non => retour D1=0, masque inchang...	RETREBUILD$:	MOVE.32		{A1}+16'0008,A0		; A0 ^ligne sur stack	MOVE.16		{A1}+16'000C,D1		; nb_longwords sur stackCLRSTACK$:	CLR.32		{A0+}			; met  zro la zone sur le stack	DJ.16,NMO	D1,CLRSTACK$	MOVE.32		{A1},A0			; A0 ^rgn.Vars	MOVE.16		{A0}+OrgnBBox+0,{A1}+16'0010	; r-init rgn.Vars.rgnBBox.top dans next y rgn	MOVE.16		#16'8002,{A1}+16'000E		; r-init current y rgn  -max_neg+1	MOVE.32		#{A0}+OrgnData,A0	; ^structure complexe de la rgion	MOVE.32		A0,{A1}+16'0004		; rinit ^data	COMP.16		{A1}+16'0010,D0		; current y < next y rgn	JUMP,LT		RTND1SET$		; oui => retour, D1=1 (masque chang)YTOPOK$:	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|A2|A3	MOVE.16		D0,D2			; D2 = current y donn en entre	MOVE.32		{A1}+16'0004,A2		; A2 ^rgnDataNEXTY$:	MOVE.16		{A2+},{A1}+16'000E	; (re-)init y rgn courantNEXTX$:	MOVE.16		{A2+},D3		; D3 = beg_x	COMP.16		#16'7FFF,D3		; dernier x ?	JUMP,EQ		FINY$	MOVE.16		{A2+},D4		; D4 = end_x	COMP.16		{A1}+16'0012,D4		; end_x =< left' ?	JUMP,LE		NEXTX$	COMP.16		{A1}+16'0014,D3		; beg_x >= right ?	JUMP,GE		NEXTX$	COMP.16		{A1}+16'0012,D3		; beg_x >= left' ?	JUMP,GE		TAKEBEGX$		; >=  => on prend beg_x	MOVE.16		{A1}+16'0012,D3		; <   => on prend left'TAKEBEGX$:	COMP.16		{A1}+16'0014,D4		; end_x =< right ?	JUMP,LE		TAKEENDX$		; =<  => on prend end_x	MOVE.16		{A1}+16'0014,D4		; >   => on prend rightTAKEENDX$:	SUB.16		{A1}+16'0016,D3		; soustrait left" --> D3 delta_left	SUB.16		{A1}+16'0016,D4		; soustrait left" --> D4 delta_right	MOVE.32		#R16^MASKTAB,A0		; A0 ^table des masques dcals	MOVE.32		#16'F,D0		; D0 masque pour index dans 16 bits	MOVE.16		D3,D5	AND.16		D0,D5			; D5 = delta_left modulo 16	ADD.16		D5,D5			; *2	MOVE.16		{A0}+A16^{D5}+10'16*2,D5 ; ==> masque  droite pour delta_left	MOVE.16		D4,D6	AND.16		D0,D6	ADD.16		D6,D6	MOVE.16		{A0}+A16^{D6},D6	; D6 masque  gauche pour delta_right	SR.16		#4,D3			; delta_left / 16	MOVE.32		{A1}+16'0008,A3		; A3 ^ligne sur le stack	ADD.A16		D3,A3			; + (delta_left/16 * 2)	ADD.A16		D3,A3	SR.16		#4,D4			; delta_right / 16	SUB.16		D3,D4			; D4 = delta_right/16 - delta_left/16 = delta_words	JUMP,GT		MOREWORDS$		; > 0	AND.16		D5,D6			; =0 ==> un seul word ==> masque les 2 masques	XOR.16		D6,{A3}			; et complmente dans la ligne	JUMP		NEXTX$MOREWORDS$:	XOR.16		D5,{A3+}		; premier masque avec masque  droite delta_left	JUMP		DECTEST$CPLLGW$:	NOT.32		{A3+}DECTEST$:	SUB.16		#2,D4			; dcrmente d'un longword	JUMP,GT		CPLLGW$			; >0       => complmente un longword complet	JUMP,LT		MASKEND$		; <0 (=-1) => plus que le dernier word masqu	NOT.16		{A3+}			; =0       => complmente 1 word avant le masqueMASKEND$:	XOR.16		D6,{A3}			; complmente avec le masque gauche de delta_right	JUMP		NEXTX$FINY$:	MOVE.32		A2,{A1}+16'0004		; met  jour le ^rgnData dans vars ^A1	MOVE.16		{A2},{A1}+16'0010	; met  jour le next y rgn	COMP.16		{A1}+16'0010,D2		; y courant donn >= next y rgn ?	JUMP,GE		NEXTY$			; oui => on recommence  faire les complments	POPM.32		D0|D1|D2|D3|D4|D5|D6|A2|A3RTND1SET$:	MOVE.32		#1,D1	RET;-----------------\\;  _SEEKNEG        >;=================/; GmiSeekSRgn (PtVars: POINTER TO ARRAY[0..LgBldRgn-1] OF BYTE, currenty: INTEGER,;	       VAR PtMaskRow: POINTER): INTEGER;;; calcule la ligne no y dans la ligne bitmap;; in	SP^:;	+10.16	RESULT:		place pour rsultat;	+6.32	PtVars		^zone de variables initialise par INITSRGN;	+4.16	currenty	y courant (coordonne en dessus de la ligne de pixels);	+0.32	PtMaskRow: VAR	^variable de 32 bits de type POINTER; out		{PtMaskRow}:	^masque (nombre de longword arrondi par exces);				les bits  1 sont pour des pixels appartenant  la rgion.;	SP^:;	+0.16	RESULT:		Prochain y pour lequel il y aurra un changement; mod	F, et ne modifie PAS D0..D2|A0|A1_SEEKNEG:	PUSHM.32 D0|D1|D2|A0|A1.if 0pushm.32 d0..d7|a0..a7lib ?aftim.ascize "(seekneg) "move.32 {SP}+88+6,D4lib ?afx8,?afspacemove.16	{SP}+88+4,d4lib ?afx4,?afspacepopm.32 d0..d7|a0..a7.endif 0	MOVE.32	{SP}+4+5*4+6,A1	MOVE.16	{SP}+4+5*4+4,D0; in	A1		^24 bytes initialiss par INITRGN;		+ 0.32		= ^rgn.Vars;		+ 4.32		= ^rgn.Vars.rgnData;		+ 8.32		= ^ligne sur le stack;		+ 16'C.16	= delta(right-left)/32 (nb longwords sur stack -1);		+ 16'E.16	= y rgn courant;		+ 16'10.16	= next y rgn;		+ 16'12.16	= left';		+ 16'14.16	= right;		+ 16'16.16	= left";	D0.16		current y; out	D1.16	=0	masque inchang, =1 masque chang.; mod	F,D1,A0	COMP.16		{A1}+16'0010,D0		; current y < next y rgn	JUMP,LT		YTOPOK$			; oui	COMP.16		{A1}+16'000E,D0		; current y >= current y rgn	JUMP,LT		RETOUR$			; nonREBUILD$:	MOVE.32		{A1}+16'0008,A0		; A0 ^ligne sur stack	MOVE.16		{A1}+16'000C,D1		; nb_longwords sur stackCLRSTACK$:	CLR.32		{A0+}			; met  zro la zone sur le stack	DJ.16,NMO	D1,CLRSTACK$	MOVE.32		{A1},A0			; A0 ^rgn.Vars	MOVE.16		{A0}+OrgnBBox+4,{A1}+16'0010	; r-init rgn.Vars.rgnBBox.bottom dans next y	CLR.32	D1	MOVE.32	{A0}+OrgnSize,D1	ADD.32	D1,A0	SUB.32	#2+6-2,A0		; saute par-dessus les 2 derniers (fin y + fin x + x2 + x1)GOBACK$:	COMP.16	#rgnENDLIST,{-A0}	; il y a au minimum 2 lignes dans une rgion !	JUMP,NE	GOBACK$	ADD.32	#2,A0			; A0 ^y dernire ligne	MOVE.32	A0,{A1}+16'0004	MOVE.16	#16'7FFE,{A1}+16'000E	COMP.16		{A1}+16'0010,D0		; current y >= next y rgn	JUMP,GE		RTND1SET$		; oui => retour, D1=1 (masque chang)YTOPOK$:	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|A2|A3	MOVE.16		D0,D2			; D2 = current y donn en entre	MOVE.32		{A1}+16'0004,A2		; A2 ^rgnDataNEXTY$:	MOVE.16		{A2+},{A1}+16'000E	; (re-)init y rgn courantNEXTX$:	MOVE.16		{A2+},D3		; D3 = beg_x	COMP.16		#16'7FFF,D3		; dernier x ?	JUMP,EQ		FINY$	MOVE.16		{A2+},D4		; D4 = end_x	COMP.16		{A1}+16'0012,D4		; end_x =< left' ?	JUMP,LE		NEXTX$	COMP.16		{A1}+16'0014,D3		; beg_x >= right ?	JUMP,GE		NEXTX$	COMP.16		{A1}+16'0012,D3		; beg_x >= left' ?	JUMP,GE		TAKEBEGX$		; >=  => on prend beg_x	MOVE.16		{A1}+16'0012,D3		; <   => on prend left'TAKEBEGX$:	COMP.16		{A1}+16'0014,D4		; end_x =< right ?	JUMP,LE		TAKEENDX$		; =<  => on prend end_x	MOVE.16		{A1}+16'0014,D4		; >   => on prend rightTAKEENDX$:	SUB.16		{A1}+16'0016,D3		; soustrait left" --> D3 delta_left	SUB.16		{A1}+16'0016,D4		; soustrait left" --> D4 delta_right	MOVE.32		#R16^MASKTAB,A0		; A0 ^table des masques dcals	MOVE.32		#16'F,D0		; D0 masque pour index dans 16 bits	MOVE.16		D3,D5	AND.16		D0,D5			; D5 = delta_left modulo 16	ADD.16		D5,D5			; *2	MOVE.16		{A0}+A16^{D5}+10'16*2,D5 ; ==> masque  droite pour delta_left	MOVE.16		D4,D6	AND.16		D0,D6	ADD.16		D6,D6	MOVE.16		{A0}+A16^{D6},D6	; D6 masque  gauche pour delta_right	SR.16		#4,D3			; delta_left / 16	MOVE.32		{A1}+16'0008,A3		; A3 ^ligne sur le stack	ADD.A16		D3,A3			; + (delta_left/16 * 2)	ADD.A16		D3,A3	SR.16		#4,D4			; delta_right / 16	SUB.16		D3,D4			; D4 = delta_right/16 - delta_left/16 = delta_words	JUMP,GT		MOREWORDS$		; > 0	AND.16		D5,D6			; =0 ==> un seul word ==> masque les 2 masques	XOR.16		D6,{A3}			; et complmente dans la ligne	JUMP		NEXTX$MOREWORDS$:	XOR.16		D5,{A3+}		; premier masque avec masque  droite delta_left	JUMP		DECTEST$CPLLGW$:	NOT.32		{A3+}DECTEST$:	SUB.16		#2,D4			; dcrmente d'un longword	JUMP,GT		CPLLGW$			; >0       => complmente un longword complet	JUMP,LT		MASKEND$		; <0 (=-1) => plus que le dernier word masqu	NOT.16		{A3+}			; =0       => complmente 1 word avant le masqueMASKEND$:	XOR.16		D6,{A3}			; complmente avec le masque gauche de delta_right	JUMP		NEXTX$FINY$:	MOVE.32		{A1},A0			; A0 ^rgn.Vars	ADD.32		#OrgnData,A0		; A0 ^rgn.Vars.Data	MOVE.32		{A1}+16'0004,A2		; A2 ^dbut ligne	MOVE.16		#16'8002,{A1}+16'0010	; met next y rgn  min_INTEGER+1 (supposition)	COMP.32		A0,A2			; A2 ^rgnVars.data ?	JUMP,EQ		NOTINGBEFORE$	SUB.32		#6,A2			; saute le rgnENDLIST,x2, et x1 juste avantGOBACK2$:	COMP.32		A0,A2	JUMP,EQ		THEBEGIN$	COMP.16		#rgnENDLIST,{-A2}	JUMP,NE		GOBACK2$	ADD.32		#2,A2			; re ^aprs le rgnENDLIST (si pas 1er)THEBEGIN$:	MOVE.32		A2,{A1}+16'0004		; met  jour le ^rgnData dans vars ^A1	MOVE.16		{A2},{A1}+16'0010	; met  jour le next y rgn	COMP.16		{A1}+16'0010,D2		; y courant donn < next y rgn ?	JUMP,LT		NEXTY$			; oui => on recommence  faire les complmentsNOTINGBEFORE$:	POPM.32		D0|D1|D2|D3|D4|D5|D6|A2|A3RTND1SET$:RETOUR$:	MOVE.16	{A1}+16'0010,D0			; next y: changement au y d'avant !	DEC.16	D0	MOVE.16	D0,{SP}+4+5*4+10'10		; next y o il y a changement	MOVE.32	{SP}+4+5*4+0,A0			; ^VAR	MOVE.32	{A1}+16'0008,{A0}		; met ^dbut ligne dans VAR.if 0pushm.32 d0..d7|a0..a7lib ?aftim.ascize "(endseekneg) "move.16 {A1}+16'010,D4lib ?afx4,?afspacepopm.32 d0..d7|a0..a7.endif 0	POPM.32	 D0|D1|D2|A0|A1	MOVE.32	{SP},{SP}+4+10'10-4	ADD.A16	#4+10'10-4,SP	RET;------------------------------------------------; ROUTINE INTERNE:; FUNCTION RGNOP (NbPtRes: POINTER TO LONGINT; srcRgnA,srcRgnB: RgnHandle; MemPt: Handle;;                 MemSize: LONGINT; Oper: operation; Nb: LONGINT; Flag: BOOLEAN): PsosError;;; Effectue une opration entre deux rgions, et met le rsultat sous forme de liste; de points dans Mempt^. Cette liste devra tre CULLPOINTS, puis SORTPOINTS, puis PACKRGN$; pour obtenir  nouveau une rgion compacte.;; Les oprations connues sont les suivantes:;	Flag = 0	Oper = 0	SECT	intersection;	Flag = 0	Oper = 2	DIFF	diffrence A-B;	Flag = 0	Oper = 4	UNION	union;	Flag = 0	Oper = 6	XOR	union exclusive;	Flag = 1	Oper = 8	MAPcoord Comme Mappt, mais uniquement en vertical, Nb donne dv;	Flag = 0	Oper = 18	????	appell par TRIMRECT, non utilis ici.;; in	{A7}+...	Voir {A6} aprs link, en enlevant 4 pour trouver les offsets pour A7;			in.RGNOP:	LINK.32		A6,#-16'0056;; Structure pointe par A6:;;	+16'8	+8	BOOLEAN	flag;	+16'A	+10	LONGINTEGER: NB;	+16'E	+14	Operati	Oper;	+16'10	+16	.32	Taille mmoire provisoire;	+16'14	+20	.32	^mmoire provisoire;	+16'18	+24	.32	^srcRgnB;	+16'1C	+28	.32	'srcRgnA;	+16'20	+32	.32	^pour rsultat: nbre de points.32 dans mmoire provisoire;	+16'24	+36	.16	place pour rsultat: PsosError;;	-16'56	.32	A7  l'entre;	-16'52	.32	^routine de scan, parmi: (SECT,DIFF,UNION,XOR,INSET)SCAN;	-16'4E	2*22byt	^par A2 pour GIVRGNDATAPTR (pour simuler rgions rectangulaires par listes);	-16'22	.32	^fin mmoire provisoire;	-16'1E	.32	^courant mmoire provisoire;	-16'1A	.16	y courant dstRgn;	-16'18	.16	y courant srcRgnB;	-16'16	.16	y courant srcRgnA;	-16'14	.32	^5 zones d'une ligne compacte pour chasss croiss.;	-16'10	.32	";	-16'0C	.32	";	-16'08	.32	";	-16'04	.32	";	PUSHM.32	D3|D4|D5|D6|D7|A2|A3|A4;@@@	MOVE.32		A7,{A6}-16'0056	MOVE.32		#{A6}-16'004E,A2	; ^4 bytes local	MOVE.32		#{A6}+16'001C,A0	; srcRgnA	CALL		GIVRGNDATAPTR	MOVE.32		A0,A3			; A3 ^donnes de srcRgnA	MOVE.32		#{A6}+16'0018,A0	; srcRgnB	CALL		GIVRGNDATAPTR	MOVE.32		A0,A4			; A4 ^donnes de srcRgnB	MOVE.32		#R16^SECTSCAN,A0	MOVE.16		{A6}+16'000E,D0		; D0 <-- opration	JUMP,EQ		SELECT$			; 0 = SECT	MOVE.32		#R16^DIFFSCAN,A0	SUB.16		#16'02,D0	JUMP,EQ		SELECT$			; 2 = DIFF	MOVE.32		#R16^UNIONSCAN,A0	SUB.16		#16'02,D0	JUMP,EQ		SELECT$			; 4 = UNION	MOVE.32		#R16^XORSCAN,A0	SUB.16		#16'02,D0	JUMP,EQ		SELECT$			; 6 = XOR	MOVE.32		#R16^INSETSCAN,A0	; autre = INSET ou TRIMRECTSELECT$:	MOVE.32		A0,{A6}-16'0052		; mmorise ^routine de SCAN	PUSH.32	A4	MOVE.32	{A6}+16'0010,D4			; taille mmoire provisoire	MOVE.32	D4,D0	SL.32	#2,D4	ADD.32	D0,D4				; MUL.32 #5,D4	MOVE.16	#MTYPCP,D1	GESMEM	?GETMEM							; EN PLUS	MOVE.32	A4,{A6}-16'0004		; prend 5 lignes pour chasss-croiss  4 lignes	ADD.32	D0,A4	MOVE.32	A4,{A6}-16'0008	ADD.32	D0,A4	MOVE.32	A4,{A6}-16'000C					; EN PLUS	ADD.32	D0,A4	MOVE.32	A4,{A6}-16'0010	ADD.32	D0,A4	MOVE.32	A4,{A6}-16'0014	POP.32	A4	MOVE.16	D7,{A6}+16'0024	JUMP,NE	RTNERGETM	MOVE.32		{A6}+16'0014,A0		; A0 ^(^mmoire provisoire)	MOVE.32		{A0},A0	MOVE.32		A0,{A6}-16'001E		; ^mmoire provisoire	AND.16		#16'FFF8,{A6}+16'0010+2	; Taille mmoire provisoire mult. de 8	MOVE.32	{A6}+16'0010,D0	ADD.32	D0,A0	MOVE.32		A0,{A6}-16'0022		; ^fin mmoire provisoire	MOVE.32		{A6}-16'0004,A0		; met un marqueur de fin aux 3 premires rgions	MOVE.32		A0,D4	MOVE.16		#rgnENDLIST,D0	MOVE.16		D0,{A0}	MOVE.32		{A6}-16'0008,A0	MOVE.32		A0,D5	MOVE.16		D0,{A0}	MOVE.32		{A6}-16'000C,A0	MOVE.32		A0,D6	MOVE.16		D0,{A0}	MOVE.32		{A6}-16'0010,A0	MOVE.32		A0,D7	MOVE.16		{A3+},{A6}-16'0016	; Top srcRgnA --> y courant srcRgnA	MOVE.16		{A4+},{A6}-16'0018	; Top srcRgnB --> y courant srcRgnB	COMP.16		#16'0008,{A6}+16'000E	; InsetRgn operation ?	JUMP,NE		NOTINSET$	MOVE.16		D0,{A6}-16'0018		; met Top srcRgnB = pas de rgionNOTINSET$:	MOVE.16		{A6}-16'0016,D0		; D0 Top srcRgnA	COMP.16		{A6}-16'0018,D0		;    = Top srcRgnB ?	JUMP,EQ		BEGINIDENT$		; =  =>	JUMP,GT		BEGBIG$			; >  => prend une ligne y dans rgion B	CALL		SKIPRGNA$		; <  => prend une ligne y dans rgion A	JUMP		CALLSCAN$SKIPRGNA$:	MOVE.16		{A6}-16'0016,{A6}-16'001A ; y courant srcRgnA --> y courant dstRgn	MOVE.32		A3,A0	MOVE.32		D4,A1	MOVE.32		D7,A2	CALL		R16^XORSCAN		; calcule la ligne courante selon les XOR...	MOVE.32		A0,A3	MOVE.16		{A3+},{A6}-16'0016	; next Y --> y courant srcRgnA	EX.32		D7,D4			; D4 ^ligne courante complte srcRgnA	RETBEGINIDENT$:	COMP.16		#rgnENDLIST,D0		; rien en srcRgnA ?	JUMP,EQ		RTNCALCNBPTS		; oui => bche	CALL		SKIPRGNA$BEGBIG$:	MOVE.16		{A6}-16'0018,{A6}-16'001A ; y courant srcRgnB --> y courant dstRgn	MOVE.32		A4,A0	MOVE.32		D5,A1	MOVE.32		D7,A2	CALL		R16^XORSCAN		; calcule la ligne courante selon les XOR	MOVE.32		A0,A4	MOVE.16		{A4+},{A6}-16'0018	; next y --> y courant srcRgnB	EX.32		D7,D5			; D5 ^ligne courante complte srcRgnBCALLSCAN$:	MOVE.32		D4,A0	MOVE.32		D5,A1	MOVE.32		D7,A2	MOVE.32		{A6}+16'000A,D2		; Nb -> D2 (pour INSETSCAN)	PUSH.32		#R16^DIFFRESULT$	PUSH.32		{A6}-16'0052		; CALL xxxSCAN	RETDIFFRESULT$:	MOVE.32		D7,A0			; rsultat opration courante	MOVE.32		D6,A1			; rsultat opration prcdente	MOVE.32		{A6}-16'0014,A2	CALL		R16^XORSCAN	EX.32		D6,D7			; D6 ^rsultat opration courante (devient prcdente)	MOVE.32		{A6}-16'0014,A0		; A0 ^rsultat diffrentiel ligne courante dstRgn	MOVE.32		{A6}-16'001E,A1		; A1 ^courant mmoire provisoire	MOVE.32		{A6}-16'0022,A2		; A2 ^fin mmoire provisoire	MOVE.32		{A6}-16'001A,D0		; y courant dstRgn --> D0.HW	JUMP		FIRSTCOMP$NEXTEXPAND$:	MOVE.16		{A0+},D0		; met les paires de points sous forme de deux	MOVE.32		D0,{A1+}		; points (y,x1),(y,x2).	MOVE.16		{A0+},D0	MOVE.32		D0,{A1+}FIRSTCOMP$:	COMP.32		A2,A1	JUMP,LO		PROVMEMOK$	TEST.8		{A6}+16'0008	JUMP,EQ		R16^RTNSETNBPT	MOVE.32		A0,D1	MOVE.32		{A6}+16'001C,A0	SUB.32		{A0},A3	MOVE.32		{A6}+16'0018,A0	SUB.32		{A0},A4	MOVE.32		{A6}+16'0014,A0	SUB.32		{A0},A1	SUB.32		{A0},A2	ADD.A16		#16'0200,A2	PUSHM.32	D0|D1|D2|D7|A0|A1|A2	PUSH.32		A0	PUSH.32		A2	CALL		R16^SETHSIZELD7	MOVE.16		D7,{A6}+16'0024	POPM.32		D0|D1|D2|D7|A0|A1|A2	JUMP,NE		RTNDISPOS	MOVE.32		{A6}+16'001C,A0	ADD.32		{A0},A3	MOVE.32		{A6}+16'0018,A0	ADD.32		{A0},A4	MOVE.32		{A6}+16'0014,A0	ADD.32		{A0},A1	ADD.32		{A0},A2	MOVE.32		A2,{A6}-16'0022	MOVE.32		D1,A0PROVMEMOK$:	COMP.16		#rgnENDLIST,{A0}	JUMP,NE		NEXTEXPAND$	MOVE.32		A1,{A6}-16'001E	JUMP		NOTINSET$;----------; GIVRGNDATAPTR:; Sous-routine de RGNOP;; remplit un pseudo-rgnData si la rgion est seulement rectangulaire.;; in	A0	^rgn;	A2	^variables de 22 bytes pour simuler une rgion rectangulaire par liste; out	A0	^rgn.Vars.rgnData;	A2	^aprs les 22 bytes si utiliss...GIVRGNDATAPTR:	MOVE.32		{A0},A1	MOVE.32		{A1},A1			; A1 ^rgn.Vars	COMP.32		#LGrgnMin,{A1}+OrgnSize	; rgion rectangulaire ?	JUMP,NE		NOTRECT$		; non =>						; oui => simule une rgion !	MOVE.32		A2,{A0}			; A0 ^(^nouvelle rgion)	MOVE.32		#{A2}-OrgnData+4,A0	; -6: A0 ^pseudo-rgn dont uniquement rgnData rempli	MOVE.32		A0,{A2+}		; ancien pointeur	MOVE.32		{A1}+OrgnBBox+0,{A2+}	; top;left	MOVE.16		{A1}+OrgnBBox+6,{A2+}	; right	MOVE.16		#rgnENDLIST,D0	MOVE.16		D0,{A2+}		; marqueur de fin de liste x	MOVE.16		{A1}+OrgnBBox+4,{A2+}	; bottom	MOVE.16		{A1}+OrgnBBox+2,{A2+}	; left	MOVE.16		{A1}+OrgnBBox+6,{A2+}	; right	MOVE.16		D0,{A2+}		; fin de liste x	MOVE.16		D0,{A2+}		; fin de liste y	MOVE.32		A0,A1NOTRECT$:	MOVE.32		#{A1}+OrgnData,A0	RETRTNSETNBPT:	MOVE.32		A1,{A6}-16'001ERTNCALCNBPTS:	MOVE.32		{A6}-16'001E,D0		; ^courant mmoire provisoire	MOVE.32		{A6}+16'0014,A0		; ^(^mmoire provisoire)	SUB.32		{A0},D0	SR.32		#2,D0	MOVE.32		{A6}+16'0020,A0	MOVE.32		D0,{A0}			; retour: nombre de points mmoire prov.;@@@	MOVE.32		{A6}-16'0056,A7RTNDISPOS:	MOVE.32	{A6}-16'0004,A4		; rend les 5 lignes pour chasss-croiss  4 lignes	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM							; EN PLUS	JUMP,NE	FATHANDLERRRTNERGETM:	POPM.32		D3|D4|D5|D6|D7|A2|A3|A4	UNLINK.32	A6	POP.32		A0	ADD.A16		#16'001C,A7	JUMP		{A0};------------------------------------------------SECTSCAN:	CLR.16		D2	CLR.16		D3	JUMP		FROMSECT;------------------------------------------------DIFFSCAN:	CLR.16		D2	JUMP		FROMDIFF;------------------------------------------------UNIONSCAN:	MOVE.32		#-1,D2FROMDIFF:	MOVE.32		#-1,D3FROMSECT:	MOVE.16		{A0+},D0		; D0 x srcRgnA	MOVE.16		{A1+},D1		; D1 x srcRgnBCMPX$:	COMP.16		D1,D0			; x srcRgnA = x srcRgnB ?	JUMP,LT		AFIRST$			; <    => met x srcRgnA suivant D3	JUMP,GT		BFIRST$			; >    => met x srcRgnB suivant D2	COMP.16		#rgnENDLIST,D0		; =    => fin de liste ?	JUMP,EQ		ENDRGNX$		; 	oui => fin en {A2+}	COMP.16		D3,D2			; 	non => si D2=D3 ==> met x quand mme	JUMP,NE		NEXTBOTH$	MOVE.16		D0,{A2+}NEXTBOTH$:	MOVE.16		{A0+},D0	NOT.16		D2	MOVE.16		{A1+},D1	NOT.16		D3	JUMP		CMPX$AFIRST$:	TEST.16		D3			; SECT: les deux inhibs jusqu' les deux ON.	JUMP,EQ		AFIRSTBOF$	MOVE.16		D0,{A2+}AFIRSTBOF$:	MOVE.16		{A0+},D0	NOT.16		D2			; UNION: inhibe l'autre jusqu' de nouveau srcRgnA	JUMP		CMPX$BFIRST$:	TEST.16		D2			; DIFF: B inhib jusqu' A, puis le contraire	JUMP,EQ		BFIRSTBOF$	MOVE.16		D1,{A2+}BFIRSTBOF$:	MOVE.16		{A1+},D1	NOT.16		D3	JUMP		CMPX$ENDRGNX$:	MOVE.16		#rgnENDLIST,{A2+}	RET;------------------------------------------------INSETSCAN:	PUSHM.32	D3|A3	MOVE.32		A2,A3			; dest. prcdente	MOVE.16		D2,D3			; D3.16 dhRight ou dvBottom	SWAP.32		D2			; D2.16 dhLeft ou dvTop	MOVE.A16	#16'8001,A1		; #16'FFFF8001 -> A1	JUMP		TESTLAST$NEXTPTS$:	MOVE.16		{A0+},D0		; beg_x	MOVE.16		{A0+},D1		; end_x	ADD.16		D2,D0			; beg_x + dhLeft (ngatif)	SUB.16		D3,D1			; end_x - dhRight	COMP.16		A1,D0			; beg_x > min-nombre ?	JUMP,GT		PUTBOTHS$		; oui => met les 2 valeurs	COMP.32		A3,A2			; non => dj une valeur crite ?	JUMP,EQ		PUTBOTHS$		;	 non => crit les 2 valeurs	SUB.A16		#2,A2			; 	 oui => dcr A2, et r-crit dernire valeur	JUMP		PUTLAST$PUTBOTHS$:	COMP.16		D1,D0			; beg_x >= end_x ?	JUMP,GE		TESTLAST$		; oui => oublie les points	MOVE.16		D0,{A2+}PUTLAST$:	MOVE.16		D1,{A2+}	MOVE.A16	D1,A1			; nouvelle valeur minTESTLAST$:	COMP.16		#rgnENDLIST,{A0}	JUMP,NE		NEXTPTS$	POPM.32		D3|A3SCANENDMARK:					; (utilise depuis XORSCAN)	MOVE.16		#rgnENDLIST,{A2+}	RET;------------------------------------------------; ROUTINE INTERNE:; Sous-ROUTINE XORSCAN;; in	A0		^srcRgnA.Vars.rgnData+2 (point x);	A1		^srcRgnB.Vars.rgnData+2 (point x);	A2		^zone d'au moins 16'28 bytes; out	A0		^ligne suivante;	A1		idem;	A2		idem; mod	D0,D1SCANENDCP:	COMP.16		#rgnENDLIST,D0	JUMP,EQ		SCANENDMARKXORSCAN:	MOVE.16		{A0+},D0		; x rgnA	MOVE.16		{A1+},D1		; x rgnBLOOP$:	COMP.16		D1,D0			; x rgnA = x rgnB ?	JUMP,EQ		SCANENDCP		; =   => teste si morque de fin	JUMP,LT		RGNALTRGNB$		; <   => prend x rgnA	MOVE.16		D1,{A2+}		; >   => prend x rgnB	MOVE.16		{A1+},D1	JUMP		LOOP$RGNALTRGNB$:	MOVE.16		D0,{A2+}	MOVE.16		{A0+},D0	JUMP		LOOP$;------------------------------------------------; ROUTINE INTERNE:; PROCEDURE SORTPOINTS (Ptptr : Pointer to points; NbPoints: LONGINT): PsosError;;; Trie un champ de NbPoints points (y;x) en Ptptr.;; Routine plutt subtile, lgrement rcursive, mais srement efficace; commentaires  vrifier !;; in	{A7}+12.16	place pour rsultat;	{A7}+8.32	^mmoire de points;	{A7}+4.32	nombre de points; out	{A7}+4.16	rsultat: PsosErrorSORTPOINTS:	LINK.32		A6,#+16'0000	PUSHM.32	D3|D4|D5|A2|A3|A4|A5	MOVE.32		{A6}+16'000C,A3		; A3 ^mmoire points	MOVE.32		A3,D3	AND.32		#16'0003,D3	MOVE.32		{A6}+16'0008,D0		; D0 nombre de points	JUMP,LE		RTN$	SL.32		#2,D0			; taille en bytes	PUSHM.32	D1|D4|A4|D7	MOVE.16		#MTYPCP,D1	MOVE.32		D0,D4	SL.32		#1,D4	GESMEM		?GETMEM			; 2* la taille en bytes ?	MOVE.32		#{A4}+32^{D4},A5	MOVE.32		D4,D5	MOVE.16		D7,{A6}+16'0010		; rend l'erreur	POPM.32		D1|D4|A4|D7	JUMP,NE		RTN$	MOVE.32		A3,A4	ADD.32		D0,A4	SUB.A16		#4,A4			; A4 ^dernier point	MOVE.32		A5,D4	MOVEM.32	A3|A4,{-A5}REL16E40$:	MOVEM.32	{A5+},A3|A4REL16E44$:	MOVE.32		A3,A1			; A1 ^dbut liste	MOVE.32		A4,A2			; A2 ^dernier point	MOVE.32		A3,D0	ADD.32		A4,D0	RRX.32		#16'01,D0	AND.16		#16'FFFC,D0	OR.16		D3,D0	MOVE.32		D0,A0			; A0 ^au milieu de la liste	MOVE.16		{A0}+2,D1		; D1 x du milieu	MOVE.16		{A0},D2			; D2 y du milieuREL16E5C$:	JUMP		R8^REL16E60$REL16E5E$:	ADD.A16		#4,A1REL16E60$:	COMP.16		{A1},D2			; y mileu > y dbut ?	JUMP,GT		R8^REL16E5E$		; oui => ^ y dbut suivant	JUMP,LT		R8^REL16E6C$		; <   => compare relativement  la fin	COMP.16		{A1}+16'0002,D1		; =   => compare x milieu > x dbut	JUMP,GT		R8^REL16E5E$		; oui => ^dbut suivant						; non => compare milieu et finREL16E6C$:	JUMP		R8^REL16E70$REL16E6E$:	SUB.A16		#4,A2REL16E70$:	COMP.16		{A2},D2			; compare y milieu < y fin	JUMP,LT		R8^REL16E6E$		; <   => dc ^fin	JUMP,GT		R8^REL16E7C$		; >   => change si pointeurs toujours dans le bon ordre	COMP.16		{A2}+16'0002,D1		; =   => compare les x	JUMP,LT		R8^REL16E6E$		; x milieu < x fin => dc ^finREL16E7C$:	COMP.32		A2,A1			; ^dbut > ^fin ?	JUMP,GT		R8^REL16E8A$		; NORMALEMENT HI (nbrs. pas signs !!!)	MOVE.32		{A1},D0	MOVE.32		{A2},{A1}		; change les chantillons ^dbut et ^fin	MOVE.32		D0,{A2}	ADD.A16		#16'04,A1		; ^dbut ^suivant	SUB.A16		#16'04,A2		; ^fin ^prcdentREL16E8A$:	COMP.32		A2,A1			; ^dbut > ^fin ?	JUMP,LS		R8^REL16E5C$		; non => recommence	COMP.32		A4,A1			; ^dbut > le dernier point ?	JUMP,CC		R8^REL16E96$	MOVEM.32	A1|A4,{-A5}REL16E96$:	MOVE.32		A2,A4	COMP.32		A4,A3	JUMP,CS		R8^REL16E44$	COMP.32		D4,A5	JUMP,NE		R8^REL16E40$	PUSHM.32	D1|D4|A4|D7	MOVE.16		#MTYPCP,D1	MOVE.32		A5,A4	SUB.32		D5,A4	GESMEM		?GIVMEM	JUMP,EQ		T1$	TRAP	#1T1$:	POPM.32		D1|D4|A4|D7RTN$:	POPM.32		D3|D4|D5|A2|A3|A4|A5	UNLINK.32	A6	POP.32		A0	ADD.A16		#16'08,A7	JUMP		{A0};------------------------------------------------; ROUTINE INTERNE:; PROCEDURE CULLPOINTS (Ptptr : Pointer to points; VAR NbPoints: POINTER TO LONGINT);;; TO CULL = Cueillir; Supprime les paires de points identiques dans un champ de NbPoints; points (y;x) en Ptptr.;; in	{A7}+8.32	^mmoire de points;	{A7}+4.32	^nombre de points.32CULLPOINTS:	LINK.32		A6,#+16'0000	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|D7|A1|A2|A3|A4|A5	MOVE.32		{A6}+16'0008,A0		; A0 ^nombre de points	MOVE.32		{A0},D0			; D0 = nombre de points	JUMP,LE		RTN$	MOVE.32		{A6}+16'000C,A1		; A1 ^dbut mmoire de points	MOVE.32		A1,A3	SL.32		#2,D0			; *4 --> nb de bytes utiliss	ADD.32		D0,A3	SUB.A16		#4,A3			; A3 ^dernier point	MOVE.32		A1,D5	MOVE.32		A1,A2			; A2 ^dbut, puis ^ordre croissant	JUMP		TSTPTR$INCA1$:	ADD.A16		#4,A1			; ignore la paire de points identique !	JUMP		TSTPTR$CPPTS$:	MOVE.32		{A1+},D0		; compare les points ^dbut avec ^dbut.next	COMP.32		{A1},D0	JUMP,EQ		INCA1$			; =   => re-incr. ^dbut	MOVE.32		D0,{A2+}		; <>  => copie dans ^croissant+TSTPTR$:	COMP.32		A3,A1			; ^dbut < ^fin ?	JUMP,LT		CPPTS$			; oui => compare points au ^dbut	JUMP,GT		TOOFAR$			; >   => fini	MOVE.32		{A1+},{A2+}		; =   => finish !TOOFAR$:	MOVE.32		A2,D0	SUB.32		D5,D0	SR.32		#16'02,D0		; D0 = nb de points finalement	MOVE.32		{A6}+16'0008,A0	MOVE.32		D0,{A0}			; remet dans la VAR fournieRTN$:	POPM.32		D0|D1|D2|D3|D4|D5|D6|D7|A1|A2|A3|A4|A5	UNLINK.32	A6	POP.32		A0	ADD.A16		#16'08,A7	JUMP		{A0};------------------------------------------------; ROUTINE INTERNE:; PROCEDURE PACKRGN (PtPtptr : POINTER TO POINTER TO points; NbPoints: LONGINT;;                    rgn: RgnHandle): PsosError;;; Recompacte un champ tri par SORTPOINTS de NbPoints points en une rgion; avec les listes hierarchiques en y puis en x.;; in	{A7}+16.16	place pour erreur		{A6}+16'14;	{A7}+12.32	^(^mmoire de points)		{A6}+16'10;	{A7}+8.32	nombre de points		{A6}+C;	{A7}+4.32	^rgn				{A6}+8; out	{A7}+4.16	erreurPACKRGN:	LINK.32		A6,#-16'0008	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|D7|A1|A2|A3|A4	MOVE.32		{A6}+16'0010,A4		; A4 ^(^mmoire de points)	MOVE.32		{A6}+16'0008,A3		; A3 ^rgn	MOVE.32		{A6}+16'000C,D6		; D6.32 nombre de points	MOVE.32		{A3},A1			; A1 ^rgn.Vars	MOVE.32		{A1},D5			; D5.32 = rgn.Var.rgnSize	MOVE.32		{A4},A0			; A0 ^mmoire de points	MOVE.16		#0,{A6}+16'0014		; par dfaut pas d'erreur...	MOVE.32		#LGrgnMIN,D7		; si jamais FINISH$...	CLR.32		{A6}-16'0008	CLR.32		{A6}-16'0004	COMP.32		#4,D6			; 4 points (min. pour rgion rectangulaire) ?	JUMP,GT		COMPLRGN$		; >4   => rgion complexe	JUMP,LT		FINISH$			; <4   => rgion rect. nulle (Var-8 et -4)	MOVE.32		{A0},{A6}-16'0008	; 1er pt --> var-8 (top;left)	MOVE.32		{A0}+16'000C,{A6}-16'0004 ; 4me pt --> var-4 (bottom;right)	JUMP		FINISH$			; construit le rectangle rgnBBoxCOMPLRGN$:	MOVE.16		{A0},{A6}-16'0008	; initialise le rgnBBox.top (liste trie en y)	MOVE.16		{A0}+2,D1		; D1 =min_x	MOVE.16		D1,D2	MOVE.32		D6,D3			; D3 dcompteur de pointsNEXTPTX$:	DEC.16		D3	JUMP,LT		MEMOMAXS$		; dcompte de points fini	MOVE.32		{A0+},D0		; (new_y;new_x)	COMP.16		D1,D0			; new_x >= min_x ?	JUMP,GE		MAXX$			; oui => contrle max	MOVE.16		D0,D1			; non => new_x --> min_x	JUMP		NEXTPTX$MAXX$:	COMP.16		D2,D0			; new_x =< max_x ?	JUMP,LE		NEXTPTX$		; oui => point suivant	MOVE.16		D0,D2	JUMP		NEXTPTX$MEMOMAXS$:	MOVE.16		D1,{A6}-16'0006		; init rgnBBox.left	MOVE.16		D2,{A6}-16'0002		; init rgnBBox.right	MOVE.16		{A0}-16'0004,{A6}-16'0004 ; init rgnBBox.bottom avec last_y	MOVE.32		#LGrgnMIN/4+1,D5	ADD.32		D6,D5			; D5 = nb de points + 3 (pour l'en-tte de 10 bytes)	SL.32		#2,D5			; * 4	PUSH.32		A3			; ^rgn	PUSH.32		D5			; lg. env. nb_pt*4+10	CALL		R16^SETHSIZELD7		; change la taille du RgnHandle	TEST.16		D7	JUMP,NE		MEMER$	MOVE.32		{A4},A0			; A0 ^mmoire	MOVE.32		{A3},A1			; A1 ^rgn.Vars	ADD.A16		#LGrgnMin,A1		; D7=LGrgnMin=OrgnData ==> A1 ^rgn.rgnData	DEC.32		D6			; pour DJ.16,NMO	MOVE.16		{A0+},D0		; y_top	MOVE.16		#rgnENDLIST,D1	JUMP		PUTTHEY$TESTY$:	COMP.16		{A0+},D0		; mme y ?	JUMP,EQ		PUTTHEX$		; oui => met juste le x	MOVE.16		D1,{A1+}		; non => met rgnENDLIST	MOVE.16		{A0}-16'0002,D0		; reprend y et...PUTTHEY$:	MOVE.16		D0,{A1+}		; met le yPUTTHEX$:	MOVE.16		{A0+},{A1+}		; met le x	DJ.16,NMO	D6,TESTY$		; ceci pour tous les points	MOVE.16		D1,{A1+}		; fin de liste en x	MOVE.16		D1,{A1+}		; fin de liste en y	MOVE.32		{A3},A0			; A0 ^rgn.Vars	SUB.32		A0,A1	MOVE.32		A1,D7			; D7 = longueurFINISH$:	MOVE.32		{A3},A0			; A0 ^rgn.Vars	MOVE.32		D7,{A0+}		; mmorise OrgnSize	MOVE.32		{A6}-16'0008,{A0+} 	; init le vrai rgnBBox.top;left	MOVE.32		{A6}-16'0004,{A0+}	; init le vrai rgnBBox.bottom;right	COMP.32		D7,D5			; longueur du handle a chang ?	JUMP,EQ		RTN$	PUSH.32		A3			; oui => raccourcit la longueur du handle	PUSH.32		D7	CALL		R16^SETHSIZELD7	TEST.16		D7	JUMP,EQ		RTN$MEMER$:	MOVE.16		D7,{A6}+16'0014		; rend l'erreur...RTN$:	POPM.32		D0|D1|D2|D3|D4|D5|D6|D7|A1|A2|A3|A4	UNLINK.32	A6	POP.32		A0	ADD.A16		#16'000C,A7	JUMP		{A0};------------------------------------------------; ROUTINE INTERNE:; PROCEDURE SORTDIRPOINTS (Ptptr : Pointer to directed_points; NbPoints: INTEGER);;; Trie un champ de NbPoints points dirigs (y;x;dir)  en Ptptr.;; Routine plutt subtile, lgrement rcursive, mais srement efficace; commentaires  vrifier !;; in	{A7}+6.32	^mmoire de points et de direction;	{A7}+4.16	nombre de pointsSORTDIRPOINTS:.if 0	LINK.32		A6,#+16'0000	PUSHM.32	D3|D4|D7|A2|A3|A4	MOVE.32		{A6}+16'000A,A3		; A3 ^mmoire points	MOVE.16		A3,D3	AND.16		#16'0003,D3;;	MOVE.32		#0,D0	MOVE.16		{A6}+16'0008,D0		; D0 nombre de points	JUMP,LE		RTN$	MUL.16		#6,D0			; taille en bytes	MOVE.32		A3,A4	ADD.32		D0,A4	SUB.A16		#6,A4			; A4 ^dernier point	MOVE.32		A7,D4	PUSHM.32	A3|A4REL16E40$:	POPM.32		A3|A4REL16E44$:	MOVE.32		A3,A1			; A1 ^dbut liste	MOVE.32		A4,A2			; A2 ^dernier point	MOVE.32		A4,D0	SUB.32		A3,D0	SR.32		#1,D0	DIV.16		#6,D0	MUL.16		#6,D0	ADD.32		A3,D0	MOVE.32		D0,A0			; A0 ^au milieu de la liste	MOVE.16		{A0}+2,D1		; D1 x du milieu	MOVE.16		{A0},D2			; D2 y du milieuREL16E5C$:	JUMP		R8^REL16E60$REL16E5E$:	ADD.A16		#6,A1REL16E60$:	COMP.16		{A1},D2			; y mileu > y dbut ?	JUMP,GT		R8^REL16E5E$		; oui => ^ y dbut suivant	JUMP,LT		R8^REL16E6C$		; <   => compare relativement  la fin	COMP.16		{A1}+2,D1		; =   => compare x milieu > x dbut	JUMP,GT		R8^REL16E5E$		; oui => ^dbut suivant						; non => compare milieu et finREL16E6C$:	JUMP		R8^REL16E70$REL16E6E$:	SUB.A16		#6,A2REL16E70$:	COMP.16		{A2},D2			; compare y milieu < y fin	JUMP,LT		R8^REL16E6E$		; <   => dc ^fin	JUMP,GT		R8^REL16E7C$		; >   => change si pointeurs toujours dans le bon ordre	COMP.16		{A2}+2,D1		; =   => compare les x	JUMP,LT		R8^REL16E6E$		; x milieu < x fin => dc ^finREL16E7C$:	COMP.32		A2,A1			; ^dbut > ^fin ?	JUMP,GT		R8^REL16E8A$		; NORMALEMENT HI (nbrs. pas signs !!!)	MOVE.32		{A1},D0	MOVE.16		{A1}+4,D7	MOVE.32		{A2},{A1}		; change les chantillons ^dbut et ^fin	MOVE.16		{A2}+4,{A1}+4	MOVE.32		D0,{A2}	MOVE.16		D7,{A2}+4	ADD.A16		#6,A1			; ^dbut ^suivant	SUB.A16		#6,A2			; ^fin ^prcdentREL16E8A$:	COMP.32		A2,A1			; ^dbut > ^fin ?	JUMP,LS		R8^REL16E5C$		; non => recommence	COMP.32		A4,A1			; ^dbut > le dernier point ?	JUMP,CC		R8^REL16E96$	PUSHM.32	A1|A4REL16E96$:	MOVE.32		A2,A4	COMP.32		A4,A3	JUMP,CS		R8^REL16E44$	COMP.32		D4,A7	JUMP,NE		R8^REL16E40$RTN$:	POPM.32		D3|D4|D7|A2|A3|A4	UNLINK.32	A6	POP.32		A0	ADD.A16		#16'06,A7	JUMP		{A0}.endif 0;------------------------------------------------; ROUTINE INTERNE:; PROCEDURE CULLDIRPOINTS (Ptptr : Pointer to directed_points; VAR NbPoints: INTEGER);;; TO CULL = Cueillir; Somme la direction des points identiques dans un champ de NbPoints; points dirigs (y;x;dir) en Ptptr.;; in	{A7}+6.32	^mmoire de points;	{A7}+4.32	^nombre de points.16CULLDIRPOINTS:.if 0	LINK.32		A6,#+16'0000	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|D7|A1|A2|A3|A4|A5	MOVE.32		{A6}+16'0008,A0		; A0 ^nombre de points	MOVE.16		{A0},D0			; D0 = nombre de points	JUMP,LE		RTN$	MOVE.32		{A6}+16'000C,A1		; A1 ^dbut mmoire de points	MOVE.32		A1,A3	MUL.16		#6,D0			; *6 --> nb de bytes utiliss	ADD.32		D0,A3	SUB.A16		#6,A3			; A3 ^dernier point	MOVE.32		A1,D5			; D5 ^dbut	MOVE.32		A1,A2			; A2 ^dbut, puis ^ordre croissant	JUMP		NTSTPTR$		; init somme des directions du point D7=0CPPTS$:	MOVE.32		{A1+},D0		; compare les points ^dbut avec ^dbut.next	ADD.16		{A1+},D7	COMP.32		{A1},D0	JUMP,EQ		TSTPTR$			; =   => contrle si ^courant = ^dernierMOVE$:						; <>  => copie si somme directions <>0.	TEST.16		D7	JUMP,EQ		TSTPTR$	MOVE.32		D0,{A2+}		; <>  => copie dans ^croissant+	MOVE.16		D7,{A2+}NTSTPTR$:	CLR.16		D7TSTPTR$:	COMP.32		A3,A1			; ^dbut < ^fin ?	JUMP,LT		CPPTS$			; oui => compare points au ^dbut	JUMP,GT		TOOFAR$			; >   => fini (y.c. dernier round)	MOVE.32		{A1+},D0		; =   => prend dernier point et...	ADD.16		{A1+},D7	JUMP		MOVE$			; ...copie si D7<>0TOOFAR$:	MOVE.32		A2,D0	SUB.32		D5,D0	DIV.16		#6,D0			; D0 = nb de points finalement	MOVE.32		{A6}+16'0008,A0	MOVE.16		D0,{A0}			; remet dans la VAR fournieRTN$:	POPM.32		D0|D1|D2|D3|D4|D5|D6|D7|A1|A2|A3|A4|A5	UNLINK.32	A6	POP.32		A0	ADD.A16		#16'08,A7	JUMP		{A0}.endif 0;------------------------------------------------; ROUTINE INTERNE:; PROCEDURE PACKDIRRGN (PtPtptr :Pointer to Pointer to directed_points;;			 NbPoints: INTEGER; rgn: RgnHandle);;; Recompacte un champ tri par SORTPOINTS de NbPoints points dirigs en une rgion; avec les listes hierarchiques en y puis en x.;; in	{A7}+10.32	^(^mmoire de points);	{A7}+8.16	nombre de points;	{A7}+4.32	^rgnPACKDIRRGN:.if 0	LINK.32		A6,#-16'0008-10'12	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|D7|A1|A2|A3|A4|A5	MOVE.32		{A6}+16'000E,A4		; A4 ^(^mmoire de points)	MOVE.32		{A6}+16'0008,A3		; A3 ^rgn	MOVE.16		{A6}+16'000C,D6		; D6 nombre de points	MOVE.32		{A3},A1			; A1 ^rgn.Vars	MOVE.32		{A1},D5			; D5 = rgn.Var.rgnSize	MOVE.32		{A4},A0			; A0 ^mmoire de points	MOVE.32		#LGrgnMin,D7	CLR.32		{A6}-16'0008	CLR.32		{A6}-16'0004	COMP.16		#4,D6			; 4 points (min. pour rgion rectangulaire) ?	JUMP,GT		COMPLRGN$		; >4   => rgion complexe	JUMP,LT		FINISH$			; <4   => rgion rect. nulle (Var-8 et -4)	MOVE.32		{A0},{A6}-16'0008	; 1er pt --> var-8 (top;left)	MOVE.32		{A0}+3*6,{A6}-16'0004	; 4me pt --> var-4 (bottom;right)	JUMP		FINISH$			; construit le rectangle rgnBBoxCOMPLRGN$:	MOVE.16		{A0},{A6}-16'0008	; initialise le rgnBBox.top (liste trie en y)	MOVE.16		{A0}+2,D1		; D1 =min_x	MOVE.16		D1,D2	MOVE.16		D6,D3			; D3 dcompteur de pointsNEXTPTX$:	DEC.16		D3	JUMP,LT		MEMOMAXS$		; dcompte de points fini	MOVE.32		{A0},D0			; (new_y;new_x)	ADD.A16		#6,A0			; ^point suivant	COMP.16		D1,D0			; new_x >= min_x ?	JUMP,GE		MAXX$			; oui => contrle max	MOVE.16		D0,D1			; non => new_x --> min_x	JUMP		NEXTPTX$MAXX$:	COMP.16		D2,D0			; new_x =< max_x ?	JUMP,LE		NEXTPTX$		; oui => point suivant	MOVE.16		D0,D2	JUMP		NEXTPTX$MEMOMAXS$:	MOVE.16		D1,{A6}-16'0006		; init rgnBBox.left	MOVE.16		D2,{A6}-16'0002		; init rgnBBox.right	MOVE.16		{A0}-6,{A6}-16'0004	; init rgnBBox.bottom avec last_y	PUSHM.32	D0|D1|D4|D7	MOVE.16		D6,D4			; nombre de points	MUL.16		#2*4,D4		;2*3??	MOVE.16		#MTYPCP,D1	GESMEM		?GETMEM	JUMP,NE		FATHANDLERR	SR.32		#1,D4	MOVE.32		A4,{A6}-8-10'12		; ^mmoire	MOVE.32		A4,{A6}-8-4		; prend 2 lignes pour chasss-croiss  4 lignes	MOVE.16		#rgnENDLIST,D1	MOVE.16		D1,{A4}	ADD.32		D4,A4	MOVE.32		A4,{A6}-8-8		; ^zone 2	MOVE.16		D1,{A4}	POPM.32		D0|D1|D4|D7	MOVE.32		#3,D5	ADD.16		D6,D5			; D5 = nb de points + 3 (pour l'en-tte de 10 bytes)	SL.16		#3,D5			; * 8	PUSH.32		A3			; ^rgn	PUSH.16		D5			; lg. env. nb_pt*4+10	CALL		R16^SETHSIZE		; change la taille du RgnHandle	MOVE.32		{A6}+16'000E,A0		; A0 ^(^mmoire de points)	MOVE.32		{A0},A0			; A0 ^mmoire	MOVE.32		{A3},A1			; A1 ^rgn.Vars	ADD.A16		D7,A1			; D7=LGrgnMin=OrgnData ==> A1 ^rgn.rgnData	DEC.16		D6			; pour DJ.16,NMO	MOVE.16		{A0+},D0		; y_top	MOVE.16		#rgnENDLIST,D1	CLR.16		D4			; compteur de nb rgions d'intersection	PUSH.32		D5	JUMP		PUTTHEY$TESTY$:	COMP.16		{A0+},D0		; mme y ?	JUMP,EQ		PUTTHEX$		; oui => met juste le x	MOVE.16		D1,{A4+}		; met un terminateur  la ligne courante	CALL		CONVLINE$		; convertit la ligne en XOR rel. ligne prcdente	MOVE.16		{A0}-2,D0		; reprend y et...	CLR.16		D4PUTTHEY$:	MOVE.16		D0,{A1+}		; met le yPUTTHEX$:	TEST.16		D4	JUMP,EQ		PUTX$	PUSH.32		D4	ADD.16		{A0}+2,D4	POPM.32		D4	JUMP,EQ		NXTX$PUTX$:	MOVE.16		{A0},{A4+}		; met le xNXTX$:	ADD.16		{A0}+2,D4		; en x	ADD.A16		#2+2,A0			; ^y suivant	DJ.16,NMO	D6,TESTY$		; ceci pour tous les points	POP.32		D5	MOVE.32		{A6}-8-8,A4		; rsultat opration courante...	MOVE.16		D1,{A4+}		; ...met un terminateur  la ligne courante (dernire=vide)	CALL		CONVLINE$		; convertit la ligne en XOR rel. ligne prcdente	MOVE.16		D1,{A1+}		; fin de liste en y	PUSHM.32	D1|D7|A4	MOVE.32		{A6}-8-10'12,A4	MOVE.16		#MTYPCP,D1	GESMEM		?GIVMEM	JUMP,NE		FATHANDLERR	POPM.32		D1|D7|A4	MOVE.32		{A3},A0			; A0 ^rgn.Vars	SUB.32		A0,A1	MOVE.32		A1,D7			; D7 = longueurFINISH$:	MOVE.32		{A3},A0			; A0 ^rgn.Vars	MOVE.32		D7,{A0+}		; mmorise rgnSize	MOVE.32		{A6}-16'0008,{A0+} 	; init le vrai rgnBBox.top;left	MOVE.32		{A6}-16'0004,{A0+}	; init le vrai rgnBBox.bottom;right;;DS A0rgnVarD7lg	COMP.16		D7,D5			; longueur du handle a chang ?	JUMP,EQ		RTN$	PUSH.32		A3			; oui => raccourcit la longueur du handle	PUSH.16		D7	CALL		R16^SETHSIZERTN$:	POPM.32		D0|D1|D2|D3|D4|D5|D6|D7|A1|A2|A3|A4|A5	UNLINK.32	A6	POP.32		A0	ADD.A16		#16'000A,A7	JUMP		{A0}CONVLINE$:		; convertit la ligne en XOR rel. ligne prcdente			; in	A1	^buffer de sortie			;	{A6}-...			; out	A1	^aprs mise  jour			;		si ligne vide, SUB #2,A1 pour supprimer le no y			;	A4	^buffer pour rsultat ligne suivante			;	{A6}-...			; mod	A1,A4	PUSHM.32	D0|D1|A0|A2|A3	MOVE.32		A1,A3	MOVE.32		A1,A2			; rsultat relatif...	MOVE.32		{A6}-8-8,A0		; rsultat opration courante	MOVE.32		{A6}-8-4,A1		; rsultat opration prcdente	CALL		R16^XORSCAN	MOVE.32		A2,A1	SUB.32		A3,A2	COMP.32		#2,A2			; ligne contient que rgnENDLIST ?	JUMP,NE		FULLLINE$	SUB.32		#2+2,A1			; oui => enlve, ainsi que no prcdent le toutFULLLINE$:	MOVE.32		{A6}-8-4,A4		; rsultat opration courante	MOVE.32		{A6}-8-8,{A6}-8-4	; rsultat opration courante devient prcdente	MOVE.32		A4,{A6}-8-8	POPM.32		D0|D1|A0|A2|A3	RET.endif 0MASKTAB:	.16	16'0000	.16	16'8000	.16	16'C000	.16	16'E000	.16	16'F000	.16	16'F800	.16	16'FC00	.16	16'FE00	.16	16'FF00		; +8*2	.16	16'FF80	.16	16'FFC0	.16	16'FFE0	.16	16'FFF0	.16	16'FFF8	.16	16'FFFC	.16	16'FFFE	.16	16'FFFF		; +16*2	.16	16'7FFF	.16	16'3FFF	.16	16'1FFF	.16	16'0FFF	.16	16'07FF	.16	16'03FF	.16	16'01FF	.16	16'00FF	.16	16'007F	.16	16'003F	.16	16'001F	.16	16'000F	.16	16'0007	.16	16'0003	.16	16'0001		; +31*2	.16	16'8000	.16	16'4000	.16	16'2000	.16	16'1000	.16	16'0800	.16	16'0400	.16	16'0200	.16	16'0100	.16	16'0080	.16	16'0040	.16	16'0020	.16	16'0010	.16	16'0008	.16	16'0004	.16	16'0002	.16	16'0001;------------------------------------------------NEWHANDLELD7:	POP.32		A1	POP.32		D0	CALL		NH1	MOVE.32		A0,{A7}	JUMP		{A1}NH1:	PUSHM.32 D1|D4|D5|A4|A5		; EN PLUS:	MOVE.32	D0,D4	MOVE.16	#MTYPCP,D1	GESMEM	?GETMEM	JUMP,NE	STOPM	MOVE.32	D4,D5	MOVE.32	A4,A5	MOVE.32	#8,D4	GESMEM	?GETMEM	MOVE.32	A5,{A4}	MOVE.32	D5,{A4}+4	MOVE.32	A4,A0STOPM:	POPM.32	D1|D4|D5|A4|A5		; FIN EN PLUS	RETFATHANDLERR:	TRAP	#1			; EN PLUS;------------------------------------------------SETHSIZELD7:	POP.32		A1	POP.32		D0	POP.32		A0	CALL		SHS	JUMP		{A1}SHS:	PUSHM.32 D1|D4|D5|A4|A5		; EN PLUS:	MOVE.32	D0,D4	MOVE.16	#MTYPCP,D1	GESMEM	?GETMEM				; change la taille du Handle:	JUMP,NE	NOMEM$	MOVE.32	{A0},A5	MOVE.32	{A0}+4,D5			; ancienne mmoire	MOVE.32	A4,{A0}	MOVE.32	D4,{A0}+4	COMP.32	D4,D5	JUMP,LS	TRTOUT$				; choisit la plus petite	MOVE.32	D4,D5TRTOUT$:	SR.32	#1,D5	PUSH.32 A5LOOP$:	MOVE.16	{A5+},{A4+}			; transfre l'existant...	DEC.32	D5	JUMP,NE	LOOP$	POP.32	A4	GESMEM	?GIVMEM	JUMP,NE		FATHANDLERRNOMEM$:	POPM.32	D1|D4|D5|A4|A5			; FIN EN PLUS	RETDISPOSEHANDLE:					; EN PLUS:	PUSHM.32 D1|A4|D7	MOVE.16	#MTYPCP,D1	MOVE.32	{A0},A4	GESMEM	?GIVMEM	JUMP,NE		FATHANDLERR	MOVE.32	A0,A4	GESMEM	?GIVMEM	JUMP,NE		FATHANDLERR	POPM.32	D1|A4|D7	RET					; FIN EN PLUSDISPOSEHANDLED7:				; EN PLUS:	PUSHM.32 D1|A4	MOVE.16	#MTYPCP,D1	MOVE.32	{A0},A4	GESMEM	?GIVMEM	JUMP,NE	RTN$	MOVE.32	A0,A4	GESMEM	?GIVMEMRTN$:	POPM.32	D1|A4	RET					; FIN EN PLUS	.END