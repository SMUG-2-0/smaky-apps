	.SBTTL	ICOLCLUT.ASI;--------------\\; _ICOL_MODCLUT >;==============/; Modifie la palette des couleurs (CLUT).; in	A0.L	^descripteur fentre;	D4.L	mode (BTC*);		 BICMDEG --> dgrads;		 BICMRGB --> ascenseurs RGB;		 BICMHSV --> ascenseurs HSV;		 BTCGLOB --> si CLUT globale; out	D7.W	erreur; mod	D7.W_ICOL_MODCLUT:	PUSHM.L	D0..D5,A1..A4,A6	CALL	VAROPEN		; A6 <-- ^variables	JUMP,NE ERFAT$	LOAD.L	(A6)+OFAN,D4	LOAD.W	D0,#1	LOAD.L	A2,#R16"TDBOX_MODCLUT	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFAN	; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	(A6)+OPALPX,#20	LOAD.W	(A6)+OPALPY,#30	LOAD.W	(A6)+OCURPX,#250	LOAD.W	(A6)+OCURPY,#30	CALL	PALDRAW		; dessine la palette	PUSH.W	D5	LIB	?COLORPUSH	CLR.W	D3	CLR.W	D4	CLR.W	D5	LIB	?COLORSA	; couleur noire	CLR.W	D1	CALL	PALCROIX	; dessine une croix noire	LOAD.W	D3,#-1	LOAD.W	D4,D3	LOAD.W	D5,D3	LIB	?COLORSA	; couleur blanche	LOAD.W	D1,#NBCOUL-1	CALL	PALCROIX	; dessine une croix blanche	LIB	?COLORPOP	POP.W	D5	LOAD.W	D1,D0	CALL	PALINV		; allume la fausse couleur actuelleREFAIT$:	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_DBCLEAR	LIB	?COLORCR	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,#H'10000*(30-25)+230	LOAD.L	D4,#H'10000*(200+35)+220	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	LIB	?COLORPOPREFAITQ$:	CALL	CLGET		; OCOLR <-- RGB choisis	TEST.B	(A6)+OFAN+0:#BICMDEG-24	JUMP',BS DEG$	TEST.B	(A6)+OFAN+0:#BICMHSV-24	JUMP',BS HSV$	CALL	RGBCPUT		; init les ascenseurs selon les couleurs	CALL	RGBDRAWS	; dessine les trois ascenseurs	CALL	RGBUPDATES	; met  jour les trois ascenseurs	JUMP'	LOOP$HSV$:	CALL	HSVCPUT		; init les ascenseurs selon les couleurs	CALL	HSVDRAWS	; dessine les trois ascenseurs	CALL	HSVUPDATES	; met  jour les trois ascenseurs	JUMP'	LOOP$DEG$:	CALL	DEGDRAW		; dessine le dgrad;	JUMP'	LOOP$LOOP$:	LOAD.L	D4,(A6)+OFAN	DBOX_	EDIT		; attend action ...	LOAD.L	(A6)+OFAN,D4	LOAD.L	A1,#R16"TKEY_MODCLUT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	; bouton souris press ?	JUMP,EQ	CLIC$		; oui => CLIC$	COMP.W	D3,#F1	JUMP,EQ QUITTE$	COMP.W	D3,#DEFINE	JUMP,EQ COMPLEMENT$	COMP.W	D3,#F7	JUMP,EQ PREND$	COMP.W	D3,#F9	JUMP,EQ SAUVE$	COMP.W	D3,#F4	JUMP,EQ COPIE$	COMP.W	D3,#H'100*(2^BCOPY)+SPACE	JUMP,EQ COPIE$	COMP.W	D3,#F6	JUMP,EQ COLLE$	COMP.W	D3,#H'100*(2^BCURSOR)+SPACE	JUMP,EQ COLLE$	COMP.W	D3,#H'100*(2^BSHOW)+SPACE	JUMP,EQ CLASSEUR$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ERROR$:	CALL	DBOXERROR	; affiche une erreur ...	JUMP	LOOP$KEYDBOX$:	SUB.B	D3,#100	JUMP,LO REFAIT$	LOAD.L	A3,#R16"COLOR$	AND.W	D3,#H'00FF	MUL.WU	D3,#6	ADD.L	A3,D3	LOAD.W	(A6)+OCOLR,(A3+)	LOAD.W	(A6)+OCOLG,(A3+)	LOAD.W	(A6)+OCOLB,(A3+)	LOAD.W	D1,D0	CALL	CLPUT		; modifie une fausse couleur	JUMP	REFAITQ$COMPLEMENT$:	LOAD.W	D1,D0	CALL	CLGET		; OCOLR <-- RGB choisis	NOT.W	(A6)+OCOLR	NOT.W	(A6)+OCOLG	NOT.W	(A6)+OCOLB	CALL	CLPUT		; modifie une fausse couleur	JUMP	REFAITQ$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.W	D1,D0	CALL	PALINV		; teint la fausse couleur actuelle	CALL	PALMOVE		; choix d'une couleur dans la palette ...	JUMP',NE CLIC2$	LOAD.W	D0,D1		; D0 <-- nouvelle fausse couleur	CALL	PALINV		; allume la fausse couleur actuelle	JUMP	REFAITQ$CLIC2$:	LOAD.W	D1,D0	CALL	PALINV		; allume la fausse couleur actuelle	TEST.W	D0		; modifie le blanc ?	JUMP,EQ BIP$		; oui => BIP$	COMP.W	D0,#NBCOUL-1	; modifie le noir ?	JUMP,HS BIP$		; oui => BIP$	TEST.B	(A6)+OFAN+0:#BICMDEG-24	JUMP,BS CLICDEG$	TEST.B	(A6)+OFAN+0:#BICMHSV-24	JUMP,BS CLICHSV$CLICRGB$:	LOAD.L	A1,#R16"CRMAJ$	CALL	RGBMOVES	; dplace l'un des trois ascenseurs ?	JUMP,NE BIP$		; non => BIP$	JUMP	LOOP$CRMAJ$:	PUSH.W	D1	CALL	RGBCGET		; OCOLR <-- rouge/vert/bleu	LOAD.W	D1,D0	CALL	CLPUT		; modifie une fausse couleur	POP.W	D1	RETCLICHSV$:	LOAD.L	A1,#R16"CHMAJ$	CALL	HSVMOVES	; dplace l'un des trois ascenseurs ?	JUMP,NE BIP$		; non => BIP$	JUMP	LOOP$CHMAJ$:	PUSH.W	D1	CALL	HSVCGET		; OCOLR <-- rouge/vert/bleu	LOAD.W	D1,D0	CALL	CLPUT		; modifie une fausse couleur	POP.W	D1	RETCLICDEG$:	CALL	DEGMOVE		; choix d'un dgrad ?	JUMP,NE BIP$		; non => BIP$	CALL	DEGCALCUL	; OCOLR <-- rouge/vert/bleu	LOAD.W	D1,D0	CALL	CLPUT		; modifie une fausse couleur	CALL	DEGDRAW		; dessine le dgrad	JUMP	LOOP$COPIE$:	LOAD.W	D1,D0	CALL	CLGET		; OCOLR <-- RGB choisis	CALL	COPIE		; bloc-notes <-- couleur	JUMP,NE BIP$	JUMP	LOOP$COLLE$:	TEST.W	D0		; modifie le blanc ?	JUMP,EQ BIP$		; oui => BIP$	COMP.W	D0,#NBCOUL-1	; modifie le noir ?	JUMP,HS BIP$		; oui => BIP$	CALL	COLLE		; OCOLR <-- rouge/vert/bleu	JUMP,NE BIP$	LOAD.W	D1,D0	CALL	CLPUT		; modifie une fausse couleur	JUMP	REFAITQ$CLASSEUR$:	LOAD.W	D2,#2^BDBSAV	BLOC_	VISU		; accs au classeur ...	PUSH.W	D7	CALL	DBOXRSK		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP	COLLE$PREND$:	LOAD.L	A3,#(A6)+OBUCLUT	CALL	DBOXEDITIF	; demande nom .CLUT ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	IOLOADCLUT	; charge une nouvelle CLUT	JUMP,NE ERROR$	JUMP	REFAIT$SAUVE$:	LOAD.L	A3,#(A6)+OBUCLUT	CALL	DBOXEDITOF	; demande nom .CLUT ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$SAUVE2$:	CALL	IOSAVECLUT	; sauve la CLUT	JUMP,EQ LOOP$	COMP.W	D7,#ERFAEX	JUMP,NE ERROR$	CALL	DBOXDETRUIT	; faut-il dtruire ?	COMP.W	D3,#F1	JUMP,NE LOOP$	FOS	?DELETE	JUMP,NE ERROR$	JUMP	SAUVE2$QUITTE$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	CALL	VARCLOSE	; libre les variablesERFAT$:	POPM.L	D0..D5,A1..A4,A6	TEST.W	D7		; retour EQ/NE	RETCOLOR$:	.W	H'BBBB,H'BBBB,H'BBBB	; gris	.W	H'FFFF,H'FFFF,H'0000	; jaune	.W	H'FFFF,H'BBBB,H'0000	; orange	.W	H'FFFF,H'BBBB,H'FFFF	; rose	.W	H'FFFF,H'0000,H'FFFF	; magenta (violet)	.W	H'FFFF,H'0000,H'0000	; rouge	.W	H'0000,H'FFFF,H'FFFF	; cyan (bleu ciel)	.W	H'0000,H'0000,H'FFFF	; bleu (marine)	.W	H'0000,H'BBBB,H'0000	; vert (fonc)	.W	H'BBBB,H'0000,H'0000	; brunTDBOX_MODCLUT:	.W	10$-TDBOX_MODCLUT	.W	20$-TDBOX_MODCLUT	.W	0,010$:	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,100,TDBNORM	.ASCIZ	"   GRIS   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,101,TDBNORM	.ASCIZ	"  JAUNE   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,102,TDBNORM	.ASCIZ	"  ORANGE  "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,103,TDBNORM	.ASCIZ	"   ROSE   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,104,TDBNORM	.ASCIZ	" MAGENTA  "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,105,TDBNORM	.ASCIZ	"  ROUGE   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,106,TDBNORM	.ASCIZ	"   CYAN   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,107,TDBNORM	.ASCIZ	"   BLEU   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,108,TDBNORM	.ASCIZ	"   VERT   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,109,TDBNORM	.ASCIZ	"   BRUN   "	.B	ODBCR2	.B	ODBTABX,12	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	"COPIE"	.B	ODBBOX,0,F6,TDBNORM	.ASCIZ	"COLLE"	.B	ODBTABX,29	.B	ODBLCIRCLE,BICMDEG!2^7,KEYDBOX/H'100,BICMDEG	.ASCIZ	" dgrad"	.B	ODBCR	.B	ODBTABX,29	.B	ODBLCIRCLE,BICMHSV!2^7,KEYDBOX/H'100,BICMHSV	.ASCIZ	" TSI (HSV)"	.B	ODBCR	.B	ODBBOX,0,END,TDBMEV	.ASCIZ	" TERMINE "	.B	ODBTABX,12	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	"PREND"	.B	ODBBOX,0,F9,TDBNORM	.ASCIZ	"SAUVE"	.B	ODBTABX,29	.B	ODBLCIRCLE,BICMRGB!2^7,KEYDBOX/H'100,BICMRGB	.ASCIZ	" RVB (RGB)"	.B	ODBTABX,54	.B	ODBBOX,0,DEFINE,TDBOMBRE	.ASCIZ	"COMPLEMENT"	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Termine"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Copie       Colle"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_MODCLUT:	.W	F1,F2,F3,CR,END,0	DOKF1-TKEY_MODCLUT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MODCLUT	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_MODCLUT	.W	0;--------\\; CLGET   >;========/; Cherche la fausse couleur choisie.; in	D1.W	rang de la fausse couleur (0..n); out	(A6)+OCOL[R,G,B]; mod	D7.WCLGET:	PUSHM.L	D3,D4,D6,A3	CLR.L	D4	LOAD.W	D4,D1		; D4 <-- fausse couleur cherche	LOAD.L	A3,#(A6)+OCOLR	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode	OR.L	D3,#2^BTCFORCE!2^BTCGIVE	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	SRCCLUT		; OCOLR <-- couleur relle	POPM.L	D3,D4,D6,A3	RET;--------\\; CLPUT   >;========/; Modifie une fausse couleur.; in	D1.W	rang de la fausse couleur (0..n);	(A6)+OCOL[R,G,B]; out	-; mod	D7.WCLPUT:	PUSHM.L	D3,D4,D6,A4	CLR.L	D4	LOAD.W	D4,D1		; D4 <-- fausse couleur cherche	LOAD.L	A4,#(A6)+OCOLR	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode	TSET.L	D3:#BTCFORCE	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	PUTCLUT		; modifie une fausse couleur	POPM.L	D3,D4,D6,A4	RET;--------\\; DEGDRAW >;========/; Affiche toute le dgrad.; in	D0.W	couleur de base (0..n); out	-; mod	D7.WDEGDRAW:	PUSHM.L	D1..D4	LIB	?COLORPUSH	CLR.W	D1LOOP$:	CALL	DEGPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	LOAD.L	(A0)+ODFCSF,#-1	; met rapidement le noir !	LOAD.W	D2,#SETDOT	LIB	?DRRECT	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	CALL	DEGDEFTRAME	; dfinition de la trame	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; dessine un chantillon	INC.W	D1	JUMP	LOOP$EXIT$:	LIB	?COLORPOP	POPM.L	D1..D4	RET;------------\\; DEGDEFTRAME >;------------/; Choix d'une trame d'un dgrad.; in	D0.W	couleur de base (0..n);	D1.W	dgrad (0..n); out	-; mod	D7.WDEGDEFTRAME:	PUSHM.L	D1,A4	AND.L	D1,#H'FFFF	DIV.WU	D1,#DEGNBX	CLR.W	(A0)+ODFCCF+0	LOAD.W	(A0)+ODFCCF+2,D0	COMP.W	D1,D0	JUMP',LO START$	INC.W	D1START$:	CLR.W	(A0)+ODFCSF+0	LOAD.W	(A0)+ODFCSF+2,D1	LOAD.L	A4,#R16"TRAMES$	SWAP.W	D1	SL.W	D1,#3	LOAD.L	(A0)+ODFTRA+0,(A4)+(D1.W)+0	LOAD.L	(A0)+ODFTRA+4,(A4)+(D1.W)+4	POPM.L	D1,A4	RETTRAMES$:				; 0	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000				; 1	.B	B'10000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'10000000	.B	B'00000000	.B	B'00001000	.B	B'00000000				; 2	.B	B'10001000	.B	B'00000000	.B	B'00100010	.B	B'00000000	.B	B'10001000	.B	B'00000000	.B	B'00100010	.B	B'00000000				; 3	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010				; 4	.B	B'10101010	.B	B'01010101	.B	B'10101010	.B	B'01010101	.B	B'10101010	.B	B'01010101	.B	B'10101010	.B	B'01010101				; 5	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101				; 6	.B	B'01110111	.B	B'11111111	.B	B'11011101	.B	B'11111111	.B	B'01110111	.B	B'11111111	.B	B'11011101	.B	B'11111111				; 7	.B	B'01111111	.B	B'11111111	.B	B'11110111	.B	B'11111111	.B	B'01111111	.B	B'11111111	.B	B'11110111	.B	B'11111111				; 8	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.EVEN;----------\\; DEGCALCUL >;==========/; Calcule la couleur rsultante d'un dgrad.; in	D0.W	couleur de base (0..15);	D1.W	dgrad choisi (0..n); out	(A6)+OCOL[R,G,B]; mod	D7.WDEGCALCUL:	PUSHM.L	D0..D6	AND.L	D1,#H'FFFF	DIV.WU	D1,#DEGNBX	COMP.W	D1,D0	JUMP',LO START$	INC.W	D1START$:	LOAD.L	D6,D1	CALL	CLGET		; OCOLR <-- RGB arrive	LOAD.W	D3,(A6)+OCOLR	; D3 <-- rouge arrive	LOAD.W	D4,(A6)+OCOLG	; D4 <-- vert arrive	LOAD.W	D5,(A6)+OCOLB	; D5 <-- bleu arrive	SR.W	D3,#8	SR.W	D4,#8	SR.W	D5,#8	LOAD.W	D1,D0	CALL	CLGET		; OCOLR <-- RGB dpart	LOAD.W	D0,(A6)+OCOLR	; D0 <-- rouge dpart	LOAD.W	D1,(A6)+OCOLG	; D1 <-- vert dpart	LOAD.W	D2,(A6)+OCOLB	; D2 <-- bleu dpart	SR.W	D0,#8	SR.W	D1,#8	SR.W	D2,#8	SWAP.W	D6		; D6 <-- 0..8	SL.W	D6,#1	LOAD.W	D6,(PC)+(D6.W)+FACT$	SUB.W	D3,D0	MUL.WA	D3,D6	DIV.WA	D3,#64	ADD.W	D3,D0		; D3 <-- rouge rsultant	LOAD.B	(A6)+OCOLR+0,D3	LOAD.B	(A6)+OCOLR+1,D3	SUB.W	D4,D1	MUL.WA	D4,D6	DIV.WA	D4,#64	ADD.W	D4,D1		; D4 <-- vert rsultant	LOAD.B	(A6)+OCOLG+0,D4	LOAD.B	(A6)+OCOLG+1,D4	SUB.W	D5,D2	MUL.WA	D5,D6	DIV.WA	D5,#64	ADD.W	D5,D2		; D5 <-- bleu rsultant	LOAD.B	(A6)+OCOLB+0,D5	LOAD.B	(A6)+OCOLB+1,D5	POPM.L	D0..D6	RETFACT$:	.W	0,4,8,16,32,48,56,60,64;--------\\; DEGMOVE >;========/; Choix d'une couleur dans le dgrad.; in	D4.L	coordonne souris (y;x); out	D1.W	dgrad choisi (0..n);	D7.W	erreur; mod	D1.L, D7.WDEGMOVE:	PUSH.L	A2	LOAD.L	A2,#R16"DEGPOS	; A2 <-- ^routine comme ICOPOS	CALL	ICOMOVE		; choix ...	POP.L	A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; DEGPOS  >;--------/; Donne la position et les dimensions d'une case du dgrad.; in	D1.W	rang; out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WDEGPOS:	PUSH.L	D1	LOAD.W	D7,#1	COMP.W	D1,#DEGNBX*DEGNBY	JUMP',HS EXIT$	AND.L	D1,#H'FFFF	DIV.WU	D1,#DEGNBX	LOAD.W	D4,#195/DEGNBY	LOAD.W	D3,D1	MUL.WU	D3,D4	ADD.W	D3,(A6)+OCURPY	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,#189/DEGNBX	SWAP.W	D1	MUL.WU	D1,D4	ADD.W	D1,(A6)+OCURPX	LOAD.W	D3,D1	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;--------\\; COPIE   >;========/; Copie la couleur dans le bloc-notes.; in	(A6)+OCOL[R,G,B]; out	D7.W	erreur; mod	D7.WCOPIE:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#R16"NAME$ 	LOAD.L	D3,#H'1000000*'C+H'10000*'O+H'100*'L+H'1*'O	LOAD.L	D4,#6+20	BLOC_	WROPEN		; ouvre le bloc-notes	JUMP,NE EXIT$	LOAD.L	A4,#(A6)+OCOLR	LOAD.L	D4,#2+2+2 	LOAD.L	D3,#H'1000000*'C+H'10000*'O+H'100*'L+H'1*'O	BLOC_	WRDATA		; bloc-notes <-- RGB	JUMP',NE CLOSE$	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	A3,A4	CLR.L	D4	LOAD.W	D4,(A6)+OCOLR	CALL	PUTANUM	LOAD.B	(A4+),#',	LOAD.W	D4,(A6)+OCOLG	CALL	PUTANUM	LOAD.B	(A4+),#',	LOAD.W	D4,(A6)+OCOLB	CALL	PUTANUM	EX.L	A3,A4	LOAD.L	D4,A3	SUB.L	D4,A4 	LOAD.L	D3,#H'1000000*'T+H'10000*'E+H'100*'X+H'1*'T	BLOC_	WRDATA		; bloc-notes <-- R,G,BCLOSE$:	PUSH.W	D7	BLOC_	WRCLOSE		; ferme le bloc-notes	POP.W	D7EXIT$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RETNAME$:	.ASCIZE	"ICOLOR";--------\\; COLLE   >;========/; Prend la couleur dans le bloc-notes.; in	-; out	(A6)+OCOL[R,G,B];	D7.W	erreur; mod	D7.WCOLLE:	PUSHM.L	D3,D4,A3,A4 	LOAD.L	D3,#H'1000000*'C+H'10000*'O+H'100*'L+H'1*'O	BLOC_	RDOPEN		; ouvre le bloc-notes	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OCOLR	LOAD.L	D4,#2+2+2	BLOC_	RDDATACLOSE$:	PUSH.W	D7	BLOC_	RDCLOSE		; ferme le bloc-notes	POP.W	D7EXIT$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET	.END