	.SBTTL	ICOLDBOX.ASI;-----------\\; DBOXSVCRET >;===========/; Demande comment sauver une CRET.; in	A3.L	^nom du fichier;	A2.L	^table DBOX; out	D3.W	dernire touche (F1/F0);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXSVCRET:	PUSHM.L	D1,D2,D5,A1..A5	LOAD.L	A5,A2	LOAD.L	A2,#R16"TDBOX_SVCRET	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,#2^0		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	CALL	DBSVCNAME	; affiche le nom	TEST.B	(A6)+OFAN+3:#BTCGLOB-0	JUMP',BC LOOP$	LOAD.W	D2,#20!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.L	D4,#2^1		; D4 <-- fanionsLOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_SVCRET	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ TERMINE$	COMP.W	D3,#F0	JUMP',EQ TERMINE$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$TERMINE$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	LOAD.L	A2,A5	CALL	DBOXRSK		; refait les soft-keys	POPM.L	D1,D2,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_SVCRET:	.W	10$-TDBOX_SVCRET	.W	20$-TDBOX_SVCRET	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Mise  jour des couleurs du logiciel"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"dans le fichier "	.B	ODBLABEL,10	.B	ODBTEXT	.ASCIZ	"                    "	.B	ODBCR,ODBCR	.B	ODBLABEL,20	.B	ODBLCIRCLE,0	.ASCIZ	" dans le dossier courant (local)"	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" dans le dossier systme (global)"	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" MET A JOUR "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Met  jour"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_SVCRET:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_SVCRET	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_SVCRET	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_SVCRET	.W	0;----------\\; DBSVCNAME >;----------/; Affiche le nom rel d'un fichier.; in	A3.L	^nom; out	-; mod	D7.WDBSVCNAME:	PUSHM.L	D2..D6,A2..A4	LOAD.L	A2,#(A6)+OBUDIS	LOAD.L	D4,#50	CLR.W	D2	LOAD.L	D3,#2^BOPEXTEND!2^BOPNEXT!2^BOPNAME!2^BOPNDIR	FOS	?ARGSOPEN	; OBUDIS <-- nom rel	JUMP',NE EXIT$	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS	LIB	?AFTEXT		; affiche le nom du fichier	LIB	?AFTIM	.ASCIZE	" ?"EXIT$:	POPM.L	D2..D6,A2..A4	RET;-----------\\; DBOXEDITIF >;===========/; Edite un nom de fichier en entre (prend).; in	A3.L	^nom du fichier;	D4.L	fanions;	A2.L	^table DBOX; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITIF:	PUSHM.L	D1,D2,D5,A2..A5	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TFEXT	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXRSK		; refait les soft-keys	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEDITOF >;===========/; Edite un nom de fichier en sortie (sauve).; in	A3.L	^nom du fichier;	D4.L	fanions;	A2.L	^table DBOX; out	D3.W	dernire touche (F0/F1/F4);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITOF:	PUSHM.L	D1,D2,D5,A2..A5	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TFEXT	LOAD.W	D1,#DBOX_EXTRAIT ; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXRSK		; refait les soft-keys	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXDETRUIT >;============/; Demande s'il faut dtruire.; in	A3.L	^nom;	A2.L	^table DBOX; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDETRUIT:	PUSHM.L	D1,D2,D4,A2..A5	LOAD.L	A5,A3	LOAD.L	A4,#R16"TFEXT	LOAD.L	A3,#R16"TDBOX_IO	CLR.L	D3	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_DETRUIT	DBOX_	EXTEND	CALL	DBOXRSK		; refait les soft-keys	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXERROR >;==========/; Affiche une erreur.; in	D7.W	erreur;	A3.L	^nom du fichier;	A2.L	^table DBOX; out	-; mod	D7.WDBOXERROR:	DBOX_	ERROR	CALL	DBOXRSK		; refait les soft-keys	RETTFEXT:	.ASCIZ	".CLUT"TDBOX_IO:	.ASCIZ	"ICOLOR"		; nom du logiciel	.ASCIZ	"Fpalette des couleurs"	; [M,F] nom des lments manipuls	.ASCIZ	""			; [M,F] nom du contenant	.B	0	.EVEN	.END