	.SBTTL	GRAMATRIX;------------\; _GRA_MATRIX >;============/; Dessine la matrice d'un caractre typographique. Est aussi; utilis pour DRAWMATRIX (dessin d'un motif quelconque).; Primitive semblable au "raster-op", mais avec quelques petites; diffrences historiques :;   -	opration SETDOT faisant un "load" (chair + fond); in	A2.L	^description de la fentre;	D4.L	coordonne (y;x) dans la fentre;	D3.L	hauteur/largeur (dy;dx);	D2.B	opration d'inversion (0/-1);		 B'00000000 --> plein normal;		 B'11111111 --> plein invers;		 B'10101010 --> gris normal;		 B'01010101 --> gris invers;	D1.B	opration (SETDOT ou INVDOT);	A4.L	^matrice  dessiner;	D5.W	Iy (largeur en bytes); out	D7.W	erreur; mod	D7.W_GRA_MATRIX:;;?	.IF	COLOR;;?	TEST.B	(A2)+ODFCMD	; cran couleur ?;;?	JUMP,EQ __GRA_MATRIX	; non => __GRA_MATRIX;;?	PUSH.L	D0;;?	LOAD.L	D0,(A2)+ODFABS;;?	COMP.L	D0,(A2)+ODFCAB	; est-on dans l'cran couleur ?;;?	POPM.L	D0;;?	JUMP,NE __GRA_MATRIX	; non => __GRA_MATRIX;;?	PUSHM.L	D0..D6,A0..A6	; ATTENTION: comme _GRA_RASTERM !	CALL	CLIPGRA		; dans la fentre ?	JUMP,NE 90$		; non => 90$	COMP.B	D1,#SETDOT	JUMP',NE 20$	LOAD.B	D1,#LOADDOT20$:	TCLR.L	D1:#BPENDOT	COMP.B	D2,#B'11111111	JUMP',NE 30$	TSET.L	D1:#BCPLDOT	; D1 <-- inverse30$:	COMP.B	D2,#B'10101010	JUMP',NE 32$	TSET.L	D1:#BGREDOT	; D1 <-- gris32$:	COMP.B	D2,#B'01010101	JUMP',NE 34$	TSET.L	D1:#BCPLDOT	; D1 <-- inverse	TSET.L	D1:#BGREDOT	; D1 <-- gris34$:	LOAD.L	D2,D3		; D2 <-- dimensions	CLR.L	D3		; D3 <-- source: origine	LOAD.L	A3,A4		; A3 <-- source: ^	LOAD.L	A4,#0		; A4 <-- destination: ^ (dans l'cran)	JUMP	_GRA_RASTERP	; et vive le rasterop ...90$:	POPM.L	D0..D6,A0..A6	RET;;?	.ENDIF;;?.IF 0__GRA_MATRIX:	PUSHM.L	D0..D6,A0..A6	CALL	CLIPGRA		; dans la fentre ?	JUMP',NE 90$		; non => 90$	LOAD.L	A1,A4		; A1 <-- ^matrice	LOAD.W	D0,D5		; D0 <-- Iy	LOAD.W	D7,D3		; D7 <-- dx (largeur)	LOAD.L	D6,D3	SWAP.W	D6		; D6 <-- dy (hauteur)	LOAD.W	D3,D4		; D3 <-- x	SWAP.W	D4		; D4 <-- y	LOAD.W	A5,(A2)+ODFIIY	; A5 <-- Iy	COMP.B	D1,#LOADDOT!PENDOT	JUMP',EQ 30$	COMP.B	D1,#INVDOT!PENDOT	JUMP',EQ 40$	COMP.B	D1,#SETDOT!PENDOT	JUMP',EQ 50$	COMP.B	D1,#CLRDOT!PENDOT	JUMP',EQ 60$	COMP.B	D1,#SETDOT	JUMP',NE 40$30$:	TEST.B	D2	JUMP',EQ 35$	COMP.B	D2,#-1	JUMP',EQ 35$	TEST.L	D2:#0	JUMP',BS 32$	CLR.B	D2	CALL	GREYMATRIX	; si "gris" en normal	JUMP'	80$32$:	LOAD.B	D2,#-1	CALL	GREYMATRIX	; si "gris" en invers	JUMP'	80$35$:	CALL	LOADMATRIX	; si LOADDOT!PENDOT ou SETDOT	JUMP'	80$40$:	CALL	INVMATRIX	; si INVDOT!PENDOT ou INVDOT (ou CLRDOT)	JUMP'	80$50$:	CALL	SETMATRIX	; si SETDOT!PENDOT	JUMP'	80$60$:	CALL	CLRMATRIX	; si CLRDOT!PENDOT;	JUMP'	80$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D6,A0..A6	RET;-----------\; LOADMATRIX >;-----------/; Affiche une matrice de points sur l'cran. Gnralement,; il s'agit d'un caractre, mais il peut aussi s'agir d'une; matrice donne avec DRAWMATRIX.; in	D2.W	opration d'inversion (0 ou -1);	D3.W	x;	D4.W	y;	D6.W	hauteur matrice en points;	D7.W	largeur matrice en points;	A1.L	^matrice  dessiner;	D0.W	largeur en bytes (incrment y dans matrice); out	-; mod	D0..D7,A0..A6; use	D0	byte lu dans l'cran;	D1	byte lu dans GENCAR;	D2	opration d'inversion v. (0 ou -1);	D3	masques 11100000 (high) et 00000111 (low);	D4	l1;	D5	l2;	D6	compteur vertical (en points);	D7	compteur horizontal (en points);	A0	^dans l'cran;	A1	^dans GENCAR;	A3	incrment vertical dans GENCAR;	A5	Iy;	A7	SPLOADMATRIX:	LOAD.W	A3,D0		; A3 <-- incrment Y ds GENCAR	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit; Calcul l1 et l2, c'est--dire le dcalage horizontal par; rapport aux bytes dans l'cran, ainsi que les masques; correspondants.;	!      byte	!;	!---------------!		gnrateur caractres;    l1      l2;   <--> <-------->;  !---------------!---------------!	cran;  !      byte     !     byte      !	LOAD.W	D4,D0		; D4 <-- l1	LOAD.W	D5,#8.	SUB.W	D5,D4		; D5 <-- l2	DEC.W	D6		; -1  cause du test NMO !	LOAD.B	D3,(PC)+(D5.W)+02$	SWAP.W	D3	LOAD.B	D3,(PC)+(D4.W)+01$ ; D3 <-- 11111000 00000111; Calcul la valeur  ajouter dans le gnrateur de caractres; lorsque la coordonne Y augmente de 1.20$:	SUB.B	D7,D5		; D7 <-- D7 - l2	JUMP,LE 50$	SUB.B	D7,D4		; D7 <-- D7 - l1	JUMP,LE 60$	PUSHM.L	D6,A0,A1	TEST.B	D4		; l1 = zro ?	JUMP',EQ 35$		; oui => 35$30$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	OR.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	LOAD.B	D0,(A0)+1	; D0 <-- byte de l'cran	SWAP.W	D3	AND.B	D0,D3		; garde partie utile	SWAP.W	D3	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SL.B	D1,D5		; dcale selon l2	OR.B	D0,D1	LOAD.B	(A0)+1,D0	; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,30$	JUMP'	40$01$:	.B	B'00000000		; l1 = 0	.B	B'10000000		; l1 = 1	.B	B'11000000		; l1 = 2	.B	B'11100000		; l1 = 3	.B	B'11110000		; l1 = 4	.B	B'11111000		; l1 = 5	.B	B'11111100		; l1 = 6	.B	B'11111110		; l1 = 702$:	.B	B'00000000		; l2 = 0	.B	B'00000001		; l2 = 1	.B	B'00000011		; l2 = 2	.B	B'00000111		; l2 = 3	.B	B'00001111		; l2 = 4	.B	B'00011111		; l2 = 5	.B	B'00111111		; l2 = 6	.B	B'01111111		; l2 = 735$:	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	LOAD.B	(A0),D1		; met byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,35$40$:	POPM.L	D6,A0,A1	INC.L	A0		; A0 <-- ^ droite dans cran	INC.L	A1		; A1 <-- ^suivant dans GENCAR	JUMP	20$; Dessine la dernire tranche de droite au milieu d'un byte; dans l'cran.50$:	NEG.B	D7	LOAD.B	D5,(PC)+(D7.W)+02$	OR.B	D3,D5		; D3 <-- 11000111	JUMP',EQ 55$	NOT.B	D5		; D5 <-- 0011111152$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	AND.B	D1,D5		; masque partie de droite	OR.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,52$	JUMP	90$55$:	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	LOAD.B	(A0),D1		; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,55$	JUMP	90$; Dessine les deux dernires tranches de droite, la premire;  droite d'un byte de l'cran, et la deuxime  gauche d'un; byte de l'cran (mais plus troite).60$:	JUMP',EQ 62$	NEG.B	D7	SWAP.W	D361$:	SETX	RLX.B	D3,#1		; augmente masque	DEC.B	D7	JUMP,NE	61$	SWAP.W	D362$:	SWAP.W	D3	LOAD.B	D7,D3	NOT.B	D7		; D7 <-- masque pour caractre	SWAP.W	D365$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	OR.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	LOAD.B	D0,(A0)+1	; D0 <-- byte de l'cran	SWAP.W	D3	AND.B	D0,D3		; garde partie utile	SWAP.W	D3	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SL.B	D1,D5		; dcale selon l2	AND.B	D1,D7		; masque partie de droite	OR.B	D0,D1	LOAD.B	(A0)+1,D0	; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,65$90$:	RET;-----------\; GREYMATRIX >;-----------/; Affiche en "gris" une matrice de points sur l'cran.; in	D2.W	opration d'inversion (0 ou -1);	D3.W	x;	D4.W	y;	D6.W	hauteur matrice en points;	D7.W	largeur matrice en points;	A1.L	^matrice  dessiner;	D0.W	largeur en bytes (incrment y dans matrice); out	-; mod	D0..D7,A0..A6; use	D0	byte lu dans l'cran;	D1	byte lu dans GENCAR;	D2	opration d'inversion v. (0 ou -1);	D3	masques 11100000 (high) et 00000111 (low);	D4	l1;	D5	l2;	D6	compteur vertical (en points);	D7	compteur horizontal (en points);	A0	^dans l'cran;	A1	^dans GENCAR;	A3	incrment vertical dans GENCAR;	A5	Iy;	A7	SPGREYMATRIX:	LOAD.W	A3,D0		; A3 <-- incrment Y ds GENCAR	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit; Calcul l1 et l2, c'est--dire le dcalage horizontal par; rapport aux bytes dans l'cran, ainsi que les masques; correspondants.;	!      byte	!;	!---------------!		gnrateur caractres;    l1      l2;   <--> <-------->;  !---------------!---------------!	cran;  !      byte     !     byte      !	LOAD.W	D4,D0		; D4 <-- l1	LOAD.W	D5,#8.	SUB.W	D5,D4		; D5 <-- l2	DEC.W	D6		; -1  cause du test NMO !	LOAD.B	D3,(PC)+(D5.W)+02$	SWAP.W	D3	LOAD.B	D3,(PC)+(D4.W)+01$ ; D3 <-- 11111000 00000111; Calcul la valeur  ajouter dans le gnrateur de caractres; lorsque la coordonne Y augmente de 1.20$:	SWAP.W	D2	LOAD.B	D2,#B'10101010	; D2 <-- "gris" initial	SWAP.W	D2	SUB.B	D7,D5		; D7 <-- D7 - l2	JUMP,LE 50$	SUB.B	D7,D4		; D7 <-- D7 - l1	JUMP,LE 60$	PUSHM.L	D6,A0,A1	TEST.B	D4		; l1 = zro ?	JUMP',EQ 35$		; oui => 35$30$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	SWAP.W	D2	AND.B	D1,D2		; D1 <-- "grise"	SWAP.W	D2	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	OR.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	LOAD.B	D0,(A0)+1	; D0 <-- byte de l'cran	SWAP.W	D3	AND.B	D0,D3		; garde partie utile	SWAP.W	D3	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	SWAP.W	D2	AND.B	D1,D2		; D1 <-- "grise"	SWAP.W	D2	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SL.B	D1,D5		; dcale selon l2	OR.B	D0,D1	LOAD.B	(A0)+1,D0	; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	SWAP.W	D2	NOT.B	D2		; D2 <-- inverse le "gris"	SWAP.W	D2	DECJ.W,NMO D6,30$	JUMP'	40$01$:	.B	B'00000000		; l1 = 0	.B	B'10000000		; l1 = 1	.B	B'11000000		; l1 = 2	.B	B'11100000		; l1 = 3	.B	B'11110000		; l1 = 4	.B	B'11111000		; l1 = 5	.B	B'11111100		; l1 = 6	.B	B'11111110		; l1 = 702$:	.B	B'00000000		; l2 = 0	.B	B'00000001		; l2 = 1	.B	B'00000011		; l2 = 2	.B	B'00000111		; l2 = 3	.B	B'00001111		; l2 = 4	.B	B'00011111		; l2 = 5	.B	B'00111111		; l2 = 6	.B	B'01111111		; l2 = 735$:	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	SWAP.W	D2	AND.B	D1,D2		; D1 <-- "grise"	SWAP.W	D2	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	LOAD.B	(A0),D1		; met byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	SWAP.W	D2	NOT.B	D2		; D2 <-- inverse le "gris"	SWAP.W	D2	DECJ.W,NMO D6,35$40$:	POPM.L	D6,A0,A1	INC.L	A0		; A0 <-- ^ droite dans cran	INC.L	A1		; A1 <-- ^suivant dans GENCAR	JUMP	20$; Dessine la dernire tranche de droite au milieu d'un byte; dans l'cran.50$:	NEG.B	D7	LOAD.B	D5,(PC)+(D7.W)+02$	OR.B	D3,D5		; D3 <-- 11000111	JUMP',EQ 55$	NOT.B	D5		; D5 <-- 0011111152$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	SWAP.W	D2	AND.B	D1,D2		; D1 <-- "grise"	SWAP.W	D2	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	AND.B	D1,D5		; masque partie de droite	OR.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	SWAP.W	D2	NOT.B	D2		; D2 <-- inverse le "gris"	SWAP.W	D2	DECJ.W,NMO D6,52$	JUMP	90$55$:	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	SWAP.W	D2	AND.B	D1,D2		; D1 <-- "grise"	SWAP.W	D2	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	LOAD.B	(A0),D1		; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	SWAP.W	D2	NOT.B	D2		; D2 <-- inverse le "gris"	SWAP.W	D2	DECJ.W,NMO D6,55$	JUMP	90$; Dessine les deux dernires tranches de droite, la premire;  droite d'un byte de l'cran, et la deuxime  gauche d'un; byte de l'cran (mais plus troite).60$:	JUMP',EQ 62$	NEG.B	D7	SWAP.W	D361$:	SETX	RLX.B	D3,#1		; augmente masque	DEC.B	D7	JUMP,NE	61$	SWAP.W	D362$:	SWAP.W	D3	LOAD.B	D7,D3	NOT.B	D7		; D7 <-- masque pour caractre	SWAP.W	D365$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	SWAP.W	D2	AND.B	D1,D2		; D1 <-- "grise"	SWAP.W	D2	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	OR.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	LOAD.B	D0,(A0)+1	; D0 <-- byte de l'cran	SWAP.W	D3	AND.B	D0,D3		; garde partie utile	SWAP.W	D3	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	SWAP.W	D2	AND.B	D1,D2		; D1 <-- "grise"	SWAP.W	D2	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SL.B	D1,D5		; dcale selon l2	AND.B	D1,D7		; masque partie de droite	OR.B	D0,D1	LOAD.B	(A0)+1,D0	; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	SWAP.W	D2	NOT.B	D2		; D2 <-- inverse le "gris"	SWAP.W	D2	DECJ.W,NMO D6,65$90$:	RET;----------\; INVMATRIX >;==========/; Affiche une matrice de points sur l'cran. Gnralement,; il s'agit d'un caractre, mais il peut aussi s'agir d'une; matrice donne avec DRAWMATRIX.; in	D2.W	opration d'inversion (0 ou -1);	D3.W	x;	D4.W	y;	D6.W	hauteur matrice en points;	D7.W	largeur matrice en points;	A1.L	^matrice  dessiner;	D0.W	largeur en bytes (incrment y dans matrice); out	-; mod	D0..D7,A0..A6; use	D0	byte lu dans l'cran;	D1	byte lu dans GENCAR;	D2	opration d'inversion v. (0 ou -1);	D3	masques 11100000 (high) et 00000111 (low);	D4	l1;	D5	l2;	D6	compteur vertical (en points);	D7	compteur horizontal (en points);	A0	^dans l'cran;	A1	^dans GENCAR;	A3	incrment vertical dans GENCAR;	A5	Iy;	A7	SPINVMATRIX:	LOAD.W	A3,D0		; A3 <-- incrment Y ds GENCAR	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit; Calcul l1 et l2, c'est--dire le dcalage horizontal par; rapport aux bytes dans l'cran, ainsi que les masques; correspondants.;	!      byte	!;	!---------------!		gnrateur caractres;    l1      l2;   <--> <-------->;  !---------------!---------------!	cran;  !      byte     !     byte      !	LOAD.W	D4,D0		; D4 <-- l1	LOAD.W	D5,#8	SUB.W	D5,D4		; D5 <-- l2	DEC.W	D6		; -1  cause du test NMO !	LOAD.B	D3,(PC)+(D5.W)+02$	SWAP.W	D3	LOAD.B	D3,(PC)+(D4.W)+01$ ; D3 <-- 11100000 00000111; Calcul la valeur  ajouter dans le gnrateur de caractres; lorsque la coordonne Y augmente de 1.20$:	SUB.B	D7,D5		; D7 <-- D7 - l2	JUMP,LE 50$	SUB.B	D7,D4		; D7 <-- D7 - l1	JUMP,LE 60$	PUSHM.L	D6,A0,A1	TEST.B	D4		; l1 = zro ?	JUMP',EQ 35$		; oui => 35$30$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran;;	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	XOR.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	LOAD.B	D0,(A0)+1	; D0 <-- byte de l'cran	SWAP.W	D3;;	AND.B	D0,D3		; garde partie utile	SWAP.W	D3	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SL.B	D1,D5		; dcale selon l2	XOR.B	D0,D1	LOAD.B	(A0)+1,D0	; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,30$	JUMP'	40$01$:	.B	B'00000000		; l1 = 0	.B	B'10000000		; l1 = 1	.B	B'11000000		; l1 = 2	.B	B'11100000		; l1 = 3	.B	B'11110000		; l1 = 4	.B	B'11111000		; l1 = 5	.B	B'11111100		; l1 = 6	.B	B'11111110		; l1 = 702$:	.B	B'00000000		; l2 = 0	.B	B'00000001		; l2 = 1	.B	B'00000011		; l2 = 2	.B	B'00000111		; l2 = 3	.B	B'00001111		; l2 = 4	.B	B'00011111		; l2 = 5	.B	B'00111111		; l2 = 6	.B	B'01111111		; l2 = 735$:	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	XOR.B	(A0),D1		; inverse byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,35$40$:	POPM.L	D6,A0,A1	INC.L	A0		; A0 <-- ^ droite dans cran	INC.L	A1		; A1 <-- ^suivant dans GENCAR	JUMP	20$; Dessine la dernire tranche de droite au milieu d'un byte; dans l'cran.50$:	NEG.B	D7	LOAD.B	D5,(PC)+(D7.W)+02$	OR.B	D3,D5		; D3 <-- 11000111	JUMP',EQ 55$	NOT.B	D5		; D5 <-- 0011111152$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran;;	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	AND.B	D1,D5		; masque partie de droite	XOR.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,52$	JUMP	90$55$:	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	XOR.B	(A0),D1		; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,55$	JUMP	90$; Dessine les deux dernires tranches de droite, la premire;  droite d'un byte de l'cran, et la deuxime  gauche d'un; byte de l'cran (mais plus troite).60$:	JUMP',EQ 62$	NEG.B	D7	SWAP.W	D361$:	SETX	RLX.B	D3,#1		; augmente masque	DEC.B	D7	JUMP,NE	61$	SWAP.W	D362$:	SWAP.W	D3	LOAD.B	D7,D3	NOT.B	D7		; D7 <-- masque pour caractre	SWAP.W	D365$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran;;	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	XOR.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	LOAD.B	D0,(A0)+1	; D0 <-- byte de l'cran	SWAP.W	D3;;	AND.B	D0,D3		; garde partie utile	SWAP.W	D3	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SL.B	D1,D5		; dcale selon l2	AND.B	D1,D7		; masque partie de droite	XOR.B	D0,D1	LOAD.B	(A0)+1,D0	; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,65$90$:	RET;----------\; SETMATRIX >;==========/; Affiche une matrice de points sur l'cran. Gnralement,; il s'agit d'un caractre, mais il peut aussi s'agir d'une; matrice donne avec DRAWMATRIX.; in	D2.W	opration d'inversion (0 ou -1);	D3.W	x;	D4.W	y;	D6.W	hauteur matrice en points;	D7.W	largeur matrice en points;	A1.L	^matrice  dessiner;	D0.W	largeur en bytes (incrment y dans matrice); out	-; mod	D0..D7,A0..A6; use	D0	byte lu dans l'cran;	D1	byte lu dans GENCAR;	D2	opration d'inversion v. (0 ou -1);	D3	masques 11100000 (high) et 00000111 (low);	D4	l1;	D5	l2;	D6	compteur vertical (en points);	D7	compteur horizontal (en points);	A0	^dans l'cran;	A1	^dans GENCAR;	A3	incrment vertical dans GENCAR;	A5	Iy;	A7	SPSETMATRIX:	LOAD.W	A3,D0		; A3 <-- incrment Y ds GENCAR	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit; Calcul l1 et l2, c'est--dire le dcalage horizontal par; rapport aux bytes dans l'cran, ainsi que les masques; correspondants.;	!      byte	!;	!---------------!		gnrateur caractres;    l1      l2;   <--> <-------->;  !---------------!---------------!	cran;  !      byte     !     byte      !	LOAD.W	D4,D0		; D4 <-- l1	LOAD.W	D5,#8	SUB.W	D5,D4		; D5 <-- l2	DEC.W	D6		; -1  cause du test NMO !	LOAD.B	D3,(PC)+(D5.W)+02$	SWAP.W	D3	LOAD.B	D3,(PC)+(D4.W)+01$ ; D3 <-- 11100000 00000111; Calcul la valeur  ajouter dans le gnrateur de caractres; lorsque la coordonne Y augmente de 1.20$:	SUB.B	D7,D5		; D7 <-- D7 - l2	JUMP,LE 50$	SUB.B	D7,D4		; D7 <-- D7 - l1	JUMP,LE 60$	PUSHM.L	D6,A0,A1	TEST.B	D4		; l1 = zro ?	JUMP',EQ 35$		; oui => 35$30$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran;;	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	OR.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	LOAD.B	D0,(A0)+1	; D0 <-- byte de l'cran	SWAP.W	D3;;	AND.B	D0,D3		; garde partie utile	SWAP.W	D3	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SL.B	D1,D5		; dcale selon l2	OR.B	D0,D1	LOAD.B	(A0)+1,D0	; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,30$	JUMP'	40$01$:	.B	B'00000000		; l1 = 0	.B	B'10000000		; l1 = 1	.B	B'11000000		; l1 = 2	.B	B'11100000		; l1 = 3	.B	B'11110000		; l1 = 4	.B	B'11111000		; l1 = 5	.B	B'11111100		; l1 = 6	.B	B'11111110		; l1 = 702$:	.B	B'00000000		; l2 = 0	.B	B'00000001		; l2 = 1	.B	B'00000011		; l2 = 2	.B	B'00000111		; l2 = 3	.B	B'00001111		; l2 = 4	.B	B'00011111		; l2 = 5	.B	B'00111111		; l2 = 6	.B	B'01111111		; l2 = 735$:	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	OR.B	(A0),D1		; inverse byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,35$40$:	POPM.L	D6,A0,A1	INC.L	A0		; A0 <-- ^ droite dans cran	INC.L	A1		; A1 <-- ^suivant dans GENCAR	JUMP	20$; Dessine la dernire tranche de droite au milieu d'un byte; dans l'cran.50$:	NEG.B	D7	LOAD.B	D5,(PC)+(D7.W)+02$	OR.B	D3,D5		; D3 <-- 11000111	JUMP',EQ 55$	NOT.B	D5		; D5 <-- 0011111152$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran;;	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	AND.B	D1,D5		; masque partie de droite	OR.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,52$	JUMP	90$55$:	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	OR.B	(A0),D1		; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,55$	JUMP	90$; Dessine les deux dernires tranches de droite, la premire;  droite d'un byte de l'cran, et la deuxime  gauche d'un; byte de l'cran (mais plus troite).60$:	JUMP',EQ 62$	NEG.B	D7	SWAP.W	D361$:	SETX	RLX.B	D3,#1		; augmente masque	DEC.B	D7	JUMP,NE	61$	SWAP.W	D362$:	SWAP.W	D3	LOAD.B	D7,D3	NOT.B	D7		; D7 <-- masque pour caractre	SWAP.W	D365$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran;;	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	OR.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	LOAD.B	D0,(A0)+1	; D0 <-- byte de l'cran	SWAP.W	D3;;	AND.B	D0,D3		; garde partie utile	SWAP.W	D3	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SL.B	D1,D5		; dcale selon l2	AND.B	D1,D7		; masque partie de droite	OR.B	D0,D1	LOAD.B	(A0)+1,D0	; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,65$90$:	RET;----------\; CLRMATRIX >;==========/; Affiche une matrice de points sur l'cran. Gnralement,; il s'agit d'un caractre, mais il peut aussi s'agir d'une; matrice donne avec DRAWMATRIX.; in	D2.W	opration d'inversion (0 ou -1);	D3.W	x;	D4.W	y;	D6.W	hauteur matrice en points;	D7.W	largeur matrice en points;	A1.L	^matrice  dessiner;	D0.W	largeur en bytes (incrment y dans matrice); out	-; mod	D0..D7,A0..A6; use	D0	byte lu dans l'cran;	D1	byte lu dans GENCAR;	D2	opration d'inversion v. (0 ou -1);	D3	masques 11100000 (high) et 00000111 (low);	D4	l1;	D5	l2;	D6	compteur vertical (en points);	D7	compteur horizontal (en points);	A0	^dans l'cran;	A1	^dans GENCAR;	A3	incrment vertical dans GENCAR;	A5	Iy;	A7	SPCLRMATRIX:	LOAD.W	A3,D0		; A3 <-- incrment Y ds GENCAR	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit; Calcul l1 et l2, c'est--dire le dcalage horizontal par; rapport aux bytes dans l'cran, ainsi que les masques; correspondants.;	!      byte	!;	!---------------!		gnrateur caractres;    l1      l2;   <--> <-------->;  !---------------!---------------!	cran;  !      byte     !     byte      !	LOAD.W	D4,D0		; D4 <-- l1	LOAD.W	D5,#8	SUB.W	D5,D4		; D5 <-- l2	DEC.W	D6		; -1  cause du test NMO !	LOAD.B	D3,(PC)+(D5.W)+02$	SWAP.W	D3	LOAD.B	D3,(PC)+(D4.W)+01$ ; D3 <-- 11100000 00000111; Calcul la valeur  ajouter dans le gnrateur de caractres; lorsque la coordonne Y augmente de 1.20$:	SUB.B	D7,D5		; D7 <-- D7 - l2	JUMP,LE 50$	SUB.B	D7,D4		; D7 <-- D7 - l1	JUMP,LE 60$	PUSHM.L	D6,A0,A1	TEST.B	D4		; l1 = zro ?	JUMP',EQ 35$		; oui => 35$30$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran;;	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	NOT.B	D1	AND.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	LOAD.B	D0,(A0)+1	; D0 <-- byte de l'cran	SWAP.W	D3;;	AND.B	D0,D3		; garde partie utile	SWAP.W	D3	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SL.B	D1,D5		; dcale selon l2	NOT.B	D1	AND.B	D0,D1	LOAD.B	(A0)+1,D0	; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,30$	JUMP'	40$01$:	.B	B'00000000		; l1 = 0	.B	B'10000000		; l1 = 1	.B	B'11000000		; l1 = 2	.B	B'11100000		; l1 = 3	.B	B'11110000		; l1 = 4	.B	B'11111000		; l1 = 5	.B	B'11111100		; l1 = 6	.B	B'11111110		; l1 = 702$:	.B	B'00000000		; l2 = 0	.B	B'00000001		; l2 = 1	.B	B'00000011		; l2 = 2	.B	B'00000111		; l2 = 3	.B	B'00001111		; l2 = 4	.B	B'00011111		; l2 = 5	.B	B'00111111		; l2 = 6	.B	B'01111111		; l2 = 735$:	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	NOT.B	D1	AND.B	(A0),D1		; inverse byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,35$40$:	POPM.L	D6,A0,A1	INC.L	A0		; A0 <-- ^ droite dans cran	INC.L	A1		; A1 <-- ^suivant dans GENCAR	JUMP	20$; Dessine la dernire tranche de droite au milieu d'un byte; dans l'cran.50$:	NEG.B	D7	LOAD.B	D5,(PC)+(D7.W)+02$	OR.B	D3,D5		; D3 <-- 11000111	JUMP',EQ 55$	NOT.B	D5		; D5 <-- 0011111152$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran;;	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	AND.B	D1,D5		; masque partie de droite	NOT.B	D1	AND.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,52$	JUMP	90$55$:	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	NOT.B	D1	AND.B	(A0),D1		; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,55$	JUMP	90$; Dessine les deux dernires tranches de droite, la premire;  droite d'un byte de l'cran, et la deuxime  gauche d'un; byte de l'cran (mais plus troite).60$:	JUMP',EQ 62$	NEG.B	D7	SWAP.W	D361$:	SETX	RLX.B	D3,#1		; augmente masque	DEC.B	D7	JUMP,NE	61$	SWAP.W	D362$:	SWAP.W	D3	LOAD.B	D7,D3	NOT.B	D7		; D7 <-- masque pour caractre	SWAP.W	D365$:	LOAD.B	D0,(A0)		; D0 <-- byte de l'cran;;	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SR.B	D1,D4		; dcale selon l1	NOT.B	D1	AND.B	D0,D1	LOAD.B	(A0),D0		; remet byte dans l'cran	LOAD.B	D0,(A0)+1	; D0 <-- byte de l'cran	SWAP.W	D3;;	AND.B	D0,D3		; garde partie utile	SWAP.W	D3	LOAD.B	D1,(A1)		; D1 <-- byte de GENCAR	XOR.B	D1,D2		; D1 <-- inverse si ncessaire	SL.B	D1,D5		; dcale selon l2	AND.B	D1,D7		; masque partie de droite	NOT.B	D1	AND.B	D0,D1	LOAD.B	(A0)+1,D0	; remet byte dans l'cran	ADD.L	A0,A5		; A0 <-- ^plus bas dans cran	ADD.L	A1,A3		; A1 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,65$90$:	RET.ENDIF;;?	.END