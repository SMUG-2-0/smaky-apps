	.CHAP	DISCAR;--------\; AFCAR   >;========/; Affiche un caractre dans une fentre.; in	D3.B	caractre  afficher;	A2.32	^description de la fentre;	A4.32	^paramtres;	D4.32	nb de paramtres; out	A4.L	^plus loin;	D4.32	nb de paramtres restants;	D7.16	erreur; mod	D0..A1, D3.W, D4.L, D7.W, A4.LAFCAR:	CLR.16	D7		; D7 <-- ok	AND.16	#16'FF,D3	; D3.W <-- caractre	CLR.32	D0	MOVE.16	{A2}+ODFADR,D0	; D0 <-- adresse rel. routine	JUMP,EQ	 R8^L10$	; zro => 10$	ADD.32	{A6}+OSTART,D0	; D0 <-- adresse absolue	MOVE.32	D0,A1	JUMP	{A1}L10$:	COMP.8	#16'80,D3	; commande ?	JUMP,LO	 R8^L50$	; non => 50$				; oui =>	MOVE.32	#R16^TACOMM,A1	JUMP	EXROUTT		; excute une commandeL50$:	TEST.8	{A2}+ODFFLG:#BFTOUT ; affiche tout ?	JUMP,NE	 R8^L70$	; oui => 70$				; non =>	COMP.8	#NUL,D3		; caractre NUL ?	JUMP,EQ	 R8^L90$	; oui => ne fait rien				; non =>	COMP.8	#"",D3		; caractre spcial ?	JUMP,HS	 R8^L70$	; non => 70$				; oui =>	MOVE.32	#R16^TASPEC,A1	JUMP	EXROUT		; excute un car spcialL70$:	JUMP	AFCODE		; affiche un codeL90$:	RET;--------\; EXROUTT >;--------/; in	A1.L	^table de .WBB;	D3.8	caractre;	A2.32	^description de la fentre;	A4.32	^paramtres;	D4.32	nb de paramtres; out	A4.L	^plus loin;	D4.32	nb de paramtres restants;	D7.16	erreur; mod	D4.L, D7.W, A4.LEXROUTT:	PUSHM.32 D0..D3|A1	AND.16	#16'7F,D3	; D3 <-- 0..n	SL.16	#2,D3		; D3 <-- *4 car .WBB	ADD.A16	D3,A1		; A1 <-- ^.WBB concern	TEST.8	{A1}+3		; modifiera le contenu de la fentre ?	JUMP,NE	 R8^L20$	; non => 20$	CALL	CLRLUTIN	; oui => enlve le lutin de la sourisL20$:	CLR.16	D7		; D7 <-- ok	CLR.32	D1	MOVE.16	{A1}+0,D1	; D1 <-- adresse relative	JUMP,EQ	 R8^L80$	; si commande inconnue => 80$	CLR.32	D0	MOVE.8	{A1}+2,D0	; D0 <-- nb paramtres attendus	JUMP,EQ	 R8^L70$	; si aucun => 70$	COMP.32	D4,D0		; tous les paramtres dj l ?	JUMP,HI	 R8^L60$	; non => 60$				; oui =>	MOVE.32	#{A2}+ODFCOM,A1	; A1 <-- ^buffer pour les paramtres	SUB.32	D0,D4		; D4 <-- signal paramtres dj pris	DEC.16	D0		; D0 <-- -1  cause du test NMO !L40$:	MOVE.8	{A4+},{A1+}	; buffer <-- paramtres	DJ.16,NMO  D0,L40$	JUMP	R8^L70$L60$:	CALL	WAITCOM		; attend le(s) paramtre(s)	JUMP	R8^L90$L70$:	MOVE.32	D1,A1		; A1 <-- adresse relative	ADD.32	{A6}+OSTART,A1	; A1 <-- adresse absolue	CALL	{A1}		; excute une routine spciale	JUMP	R8^L90$L80$:	MOVE.16	#ERDIIL,D7	; D7 <-- "illegal command"L90$:	POPM.32	D0..D3|A1	RET;--------\; WAITCOM >;--------/; Attend une commande pouvant contenir un nombre quelconque; de bytes (maximum = MAXCOM).; in	D0.W	longueur de la commande;	D1.16	adresse relative routine  excuter lorsque;		la commande est termine; out	-; mod	-WAITCOM:	CLR.16	{A2}+ODFCPT	; rz ^relatif dans commande	MOVE.16	D0,{A2}+ODFCCT	; init compteur	MOVE.16	D1,{A2}+ODFNXT	; init routine lorsque fini	MOVE.16	#L10$,{A2}+ODFADR	RETL10$:	MOVE.16	{A2}+ODFCPT,D0	PUSH.32	A2	MOVE.32	#{A2}+ODFCOM,A2	MOVE.8	D3,{A2}+A16^{D0}; mmorise le byte reu	POP.32	A2	INC.16	{A2}+ODFCPT	; incrmente le pointeur	DEC.16	{A2}+ODFCCT	; dcrmente le compteur	JUMP,EQ	 R8^L20$	RETL20$:	MOVE.16	{A2}+ODFNXT,{A2}+ODFADR	JUMP	AFCAR		; effectue JUMP (A2),ODFADR;--------\; EXROUT  >;--------/; in	A1.L	^table de  .W car adr;	D3.8	caractre;	A2.32	^description de la fentre; out	D7.W	erreur; mod	D7.WEXROUT:	PUSHM.32 D0|D1|D2|D3|D4|A0|A1	AND.16	#16'FF,D3	MOVE.16	#ERDIIL,D7	; D7 <-- "illegal command"L10$:	ADD.32	#4,A1		; A1 <-- ^suivant dans table	TEST.16	{A1}-4		; fin de la table ?	JUMP,EQ	 R8^L80$	; oui => 80$ (CC)	COMP.8	{A1}-4,D3	; caractre trouv ?	JUMP,NE L10$		; non => 10$				; oui =>	TEST.8	{A1}-3		; modifiera le contenu de la fentre ?	JUMP,NE	 R8^L50$	; non => 50$	CALL	CLRLUTIN	; oui => enlve le lutin de la sourisL50$:	CLR.16	D7		; D7 <-- ok	CLR.32	D1	MOVE.16	{A1}-2,D1	MOVE.32	D1,A1		; A1 <-- adresse relative	ADD.32	{A6}+OSTART,A1	; A1 <-- adresse absolue	CALL	{A1}		; excute une routine spcialeL80$:	POPM.32	D0|D1|D2|D3|D4|A0|A1	RETTACOMM:	.16	DOCXY	.8		2,1	; H'80 = CARXY	.16	DOGXY	.8		4,1	; H'81 = GRAXY	.16	DOMSPA	.8		1,1	; H'82 = MSPACE	.16	0	.8		0,0	; H'83	.16	DOLEFT	.8		0,1	; H'84 = LEFT	.16	DORIGHT	.8		0,1	; H'85 = RIGHT	.16	DOUP	.8		0,1	; H'86 = UP	.16	DODOWN	.8		0,1	; H'87 = DOWN	.16	DOROLLU	.8		2,0	; H'88 = ROLLUP	.16	DOROLLD	.8		2,0	; H'89 = ROLLDOWN	.16	DOEFLI	.8		0,1	; H'8A = EFLI	.16	DOTRAM	.8		8,1	; H'8B = TRAME	.16	DOEFEOS	.8		0,0	; H'8C = EFEOS	.16	DOPEN	.8		8,1	; H'8D = PEN	.16	DOMAPT	.8		2,1	; H'8E = MAPTT	.16	0	.8		0,0	; H'8F	.16	DOADIR	.8		0,1	; H'90 = AFDIR	.16	DOAINV	.8		0,1	; H'91 = AFINV	.16	DONORM	.8		0,1	; H'92 = AFNORM	.16	DOTOUT	.8		0,1	; H'93 = AFTOUT	.16	DOROLL	.8		0,1	; H'94 = ROLL	.16	DONORO	.8		0,1	; H'95 = NOROLL	.16	DOTRUN	.8		0,1	; H'96 = TRUNC	.16	DOAUCR	.8		0,1	; H'97 = AUTOCR	.16	DOAUEF	.8		0,1	; H'98 = AUTOEFLI	.16	DONOEF	.8		0,1	; H'99 = NOEFLI	.16	DOGCUR	.8		0,1	; H'9A = GCURS	.16	DOPCUR	.8		0,1	; H'9B = PCURS	.16	DOCURS	.8		0,1	; H'9C = CURS	.16	DONOCU	.8		0,1	; H'9D = NOCURS	.16	DOPROC	.8		1,1	; H'9E = PROCURS	.16	0	.8		0,0	; H'9F	.16	DOUSGC	.8		3,1	; H'A0 = USEGC	.16	DOLOGC	.8		3,1	; H'A1 = LOADGC	.16	DOKIGC	.8		3,1	; H'A2 = KILLGC	.16	DOPFGC	.8		4,1	; H'A3 = PFIXGC	.16	DOCVAR	.8		0,1	; H'A4 = AFCVAR	.16	DOCFIX	.8		0,1	; H'A5 = AFCFIX	.16	DOSROL	.8		0,1	; H'A6 = SROLL	.16	DOMCAR	.8		1,1	; H'A7 = MODCAR	.16	DOCCMO	.8		0,0	; H'A8 = AFCCMO	.16	DOSCMO	.8		0,0	; H'A9 = AFSCMO	.16	DOIMAE	.8		0,1	; H'AA = IMAENA	.16	DOIMAD	.8		0,1	; H'AB = IMADIS	.16	DODIMW	.8		8,1	; H'AC = DIMWDO	.16	DOSAVW	.8		0,0	; H'AD = SAVWDO	.16	DOGETW	.8		0,0	; H'AE = GETWDO	.16	DOMGRA	.8		1,1	; H'AF = MODGRA	.16	DOTYAX	.8		2,1	; H'B0 = TYPOAX	.16	DOTYAY	.8		2,1	; H'B1 = TYPOAY	.16	DOTYRX	.8		1,1	; H'B2 = TYPORX	.16	DOTYRY	.8		1,1	; H'B3 = TYPORY	.16	DOHSPA	.8		1,1	; H'B4 = HSPACE	.16	DOVSPA	.8		1,1	; H'B5 = VSPACE	.16	DOFULL	.8		0,1	; H'B6 = AFFULL	.16	DOGREY	.8		0,1	; H'B7 = AFGREY	.16	DOCOSA	.8		6,1	; H'B8 = COLORSA	.16	DOCOCA	.8		6,1	; H'B9 = COLORCA	.16	DOCOSR	.8		4,1	; H'BA = COLORSR	.16	DOCOCR	.8		4,1	; H'BB = COLORCR	.16	DOCOLK	.8		10,1	; H'BC = COLORLINK	.16	DOCOUK	.8		4,1	; H'BD = COLORUNLINK	.16	DOCOOP	.8		1,1	; H'BE = COLOROP	.16	DOCOFA	.8		10,1	; H'BF = COLORFALSE	.16	DODRDO	.8		5,1	; H'C0 = DRAWDOT	.16	DODRLI	.8		5,1	; H'C1 = DRAWLINE	.16	DODRSE	.8		9,1	; H'C2 = DRAWSEG	.16	DODRCE	.8		3,1	; H'C3 = DRAWCERCLE	.16	DODRTR	.8		9,1	; H'C4 = DRAWTRAME	.16	DODRMX	.8		9,1	; H'C5 = DRAWMATRIX	.16	DODRAR	.8		9,1	; H'C6 = DRAWARC	.16	DODRFO	.8		4,0	; H'C7 = DRAWFILLO	.16	DODRFC	.8		0,0	; H'C8 = DRAWFILLC	.16	DODRRA	.8		25,1	; H'C9 = DRAWRASTER	.16	DODRMO	.8		13,1	; H'CA = DRAWMOUSE	.16	DODROS	.8		17,0	; H'CB = DRAWOSPRITE	.16	DODRMS	.8		5,1	; H'CC = DRAWMSPRITE	.16	DODRES	.8		1,0	; H'CD = DRAWESPRITE	.16	DODRCS	.8		1,0	; H'CE = DRAWCSPRITE	.16	DODREL	.8		11,1	; H'CF = DRAWELLIPSE	.16	DOASGC	.8		6,1	; H'D0 = ASSGC	.16	DOMEGC	.8		0,1	; H'D1 = MEMGC	.16	DODRPM	.8		8,1	; H'D2 = DRAWPMOUSE	.16	DONEGC	.8		7,1	; H'D3 = NEWGC	.16	DOMODU	.8		1,1	; H'D4 = MMODULO	.16	DOXPEN	.8		14,1	; H'D5 = XPEN	.16	DOXTRA	.8		18,1	; H'D6 = XTRAME	.16	DOXMAP	.8		18,1	; H'D7 = XMAPTT	.16	0	.8		0,0	; H'D8	.16	0	.8		0,0	; H'D9	.16	0	.8		0,0	; H'DA	.16	0	.8		0,0	; H'DB	.16	0	.8		0,0	; H'DC	.16	0	.8		0,0	; H'DD	.16	0	.8		0,0	; H'DE	.16	0	.8		0,0	; H'DF	.16	DOROLLL	.8		2,0	; H'E0 = ROLLLEFT	.16	DOROLLR	.8		2,0	; H'E1 = ROLLRIGHT	.16	DOFILT	.8		0,1	; H'E2 = AFFILLT	.16	DOFILA	.8		0,1	; H'E3 = AFFILLA	.16	0	.8		0,0	; H'E4	.16	0	.8		0,0	; H'E5	.16	0	.8		0,0	; H'E6	.16	0	.8		0,0	; H'E7	.16	0	.8		0,0	; H'E8	.16	0	.8		0,0	; H'E9	.16	0	.8		0,0	; H'EA	.16	0	.8		0,0	; H'EB	.16	0	.8		0,0	; H'EC	.16	0	.8		0,0	; H'ED	.16	0	.8		0,0	; H'EE	.16	0	.8		0,0	; H'EF	.16	0	.8		0,0	; H'F0	.16	0	.8		0,0	; H'F1	.16	0	.8		0,0	; H'F2	.16	0	.8		0,0	; H'F3	.16	0	.8		0,0	; H'F4	.16	0	.8		0,0	; H'F5	.16	0	.8		0,0	; H'F6	.16	0	.8		0,0	; H'F7	.16	0	.8		0,0	; H'F8	.16	0	.8		0,0	; H'F9	.16	0	.8		0,0	; H'FA	.16	0	.8		0,0	; H'FB	.16	0	.8		0,0	; H'FC	.16	0	.8		0,0	; H'FD	.16	0	.8		0,0	; H'FE	.16	0	.8		0,0	; H'FFTASPEC:	.8	CR,1	.16		DOCR	.8	TAB,1	.16		DOTAB	.8	BELL,1	.16		DOBELL	.8	BS,0	.16		DOBS	.8	LF,1	.16		DODOWN	.8	EOP,0	.16		DOEOP	.16	0; ---	CARXY   ---;	CARXY x y;	---------;	x,y:	nouvelle coordonne  atteindre (en caractres)DOCXY:	CLR.16	{A2}+ODFADR	; suite de bytes termines	CLR.16	D0	MOVE.8	{A2}+ODFCOM+0,D0 ; D0 <-- premier paramtre	MUL.16	{A2}+ODFCX,D0	; * largeur d'un caractre	ADD.16	{A2}+ODFC1X,D0	CALL	DOTYIX		; init coordonne X	CLR.16	D0	MOVE.8	{A2}+ODFCOM+1,D0 ; D0 <-- deuxime paramtre	MUL.16	{A2}+ODFCY,D0	; * hauteur d'un caractre	ADD.16	{A2}+ODFC1Y,D0	JUMP	DOTYIY		; init coordonne Y; ---	TYPOAX   ---;	TYPOAX xx;	---------;	xx:	coordonne absolue  atteindre (en points)DOTYAX:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	{A2}+ODFCOM+0,D0 ; D0 <-- coordonne X absolueDOTYIX:	COMP.8	#GRACLIP2,{A2}+ODFMGR	JUMP,EQ	 R8^L40$	MOVE.16	{A2}+ODFFDX,D1	SUB.16	{A2}+ODFC2X,D1	; D1 <-- coordonne max	COMP.16	D1,D0		; trop  droite ?	JUMP,LS	 R8^L20$	; non => 20$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	D1,D0		; D0 <-- coordonne X max	JUMP	R8^L40$L20$:	COMP.16	{A2}+ODFC1X,D0	; trop  gauche ?	JUMP,HS	 R8^L40$	; non => 40$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFC1X,D0	; D0 <-- coordonne X minL40$:	MOVE.16	D0,{A2}+ODFPX	; init nouvelle position en X	RET; ---	TYPOAY   ---;	TYPOAY yy;	---------;	yy:	coordonne absolue  atteindre (en points)DOTYAY:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	{A2}+ODFCOM+0,D0 ; D0 <-- coordonne Y absolueDOTYIY:	COMP.8	#GRACLIP2,{A2}+ODFMGR	JUMP,EQ	 R8^L40$	MOVE.16	{A2}+ODFFDY,D1	SUB.16	{A2}+ODFC2Y,D1	; D1 <-- coordonne max	COMP.16	D1,D0		; trop bas ?	JUMP,LS	 R8^L20$	; non => 20$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	D1,D0		; D0 <-- coordonne Y max	JUMP	R8^L40$L20$:	COMP.16	{A2}+ODFC1Y,D0	; trop haut ?	JUMP,HS	 R8^L40$	; non => 40$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFC1Y,D0	; D0 <-- coordonne Y minL40$:	MOVE.16	D0,{A2}+ODFPY	; init nouvelle position en Y	RET; ---	TYPORX   ---;	TYPORX x;	--------;	x:	coordonne relative positive ou ngativeDOTYRX:	CLR.16	{A2}+ODFADR	; suite de bytes termines	CLR.16	D1	MOVE.8	{A2}+ODFCOM+0,D1 ; D1 <-- coordonne X relative	JUMP,NC	 R8^L15$	; valeur ngative ?	OR.16	#16'FF00,D1	; oui => tend le signeL15$:	MOVE.16	{A2}+ODFPX,D0	ADD.16	D1,D0		; augmente/diminue coord. X	JUMP	DOTYIX		; init nouvelle coordonne; ---	TYPORY   ---;	TYPORY y;	--------;	y:	coordonne relative positive ou ngativeDOTYRY:	CLR.16	{A2}+ODFADR	; suite de bytes termines	CLR.16	D1	MOVE.8	{A2}+ODFCOM+0,D1 ; D1 <-- coordonne Y relative	JUMP,NC	 R8^L15$	; valeur ngative ?	OR.16	#16'FF00,D1	; oui => tend le signeL15$:	MOVE.16	{A2}+ODFPY,D0	ADD.16	D1,D0		; augmente/diminue coord. Y	JUMP	DOTYIY		; init nouvelle coordonne; ---	HSPACE   ---;	HSPACE x;	--------;	x:	modification de l'espace intercaractres;		positivement ou ngativementDOHSPA:	CLR.16	{A2}+ODFADR	; suite de bytes termines	CLR.16	D0	MOVE.8	{A2}+ODFCOM+0,D0 ; D0 <-- espacement H relatif	JUMP,NC	 R8^L15$	; valeur ngative ?	OR.16	#16'FF00,D0	; oui => tend le signeL15$:	MOVE.16	D0,{A2}+ODFCIX	; augmente/diminue espace H	RET; ---	VSPACE   ---;	VSPACE y;	--------;	y:	modification de l'espace interlignes;		positivement ou ngativementDOVSPA:	CLR.16	{A2}+ODFADR	; suite de bytes termines	CLR.16	D0	MOVE.8	{A2}+ODFCOM+0,D0 ; D0 <-- espacement V relatif	JUMP,NC	 R8^L15$	; valeur ngative ?	OR.16	#16'FF00,D0	; oui => tend le signeL15$:	ADD.16	D0,{A2}+ODFCY	; augmente/diminue espace V	RET; ---	MODCAR   ---;	MODCAR m;	--------;	m:	INVDOT ou SETDOTDOMCAR:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.8	{A2}+ODFCOM+0,{A2}+ODFMCA	RET; ---	MODGRA   ---;	MODGRA g;	--------;	g:	GRAWHOLE, GRACLIP ou GRAROUNDDOMGRA:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.8	{A2}+ODFCOM+0,{A2}+ODFMGR	RET; ---	ROLLUP   ---;	ROLLUP nn;	---------;	nn:	nb de points du dcalageDOROLLU:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D4	MOVE.16	{A2}+ODFCOM+0,D4	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_ROLLUP-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_ROLLUP	POP.32	A0	POP.16	D4	RET; ---	ROLLDOWN   ---;	ROLLDOWN nn;	-----------;	nn:	nb de points du dcalageDOROLLD:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D4	MOVE.16	{A2}+ODFCOM+0,D4	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_ROLLDOWN-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA_ROLLDOWN	POP.32	A0	POP.16	D4	RET; ---	ROLLDOLEFT   ---;	ROLLLEFT nn;	-----------;	nn:	nb de points du dcalageDOROLLL:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D4	MOVE.16	{A2}+ODFCOM+0,D4	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_ROLLLEFT-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA_ROLLLEFT	POP.32	A0	POP.16	D4	RET; ---	ROLLRIGHT   ---;	ROLLRIGHT nn;	------------;	nn:	nb de points du dcalageDOROLLR:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D4	MOVE.16	{A2}+ODFCOM+0,D4	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_ROLLRIGHT-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA_ROLLRIGHT	POP.32	A0	POP.16	D4	RET; ---	GRAXY   ---;	GRAXY xx yy;	-----------;	xx,yy:	nouvelle coordonne  atteindre (en points)DOGXY:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	{A2}+ODFCOM+0,D0 ; D0 <-- premier paramtre	COMP.16	{A2}+ODFFDX,D0	; dbordement ?	JUMP,LO	 R8^L15$	; non => 15$	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFFDX,D0	; D0 <-- coordonne X max	DEC.16	D0L15$:	MOVE.16	D0,{A2}+ODFPGX	; init nouvelle position en X	MOVE.16	{A2}+ODFCOM+2,D0 ; D0 <-- deuxime paramtre	COMP.16	{A2}+ODFFDY,D0	; dbordement ?	JUMP,LO	 R8^L25$	; non => 25$	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFFDY,D0	; D0 <-- coordonne Y max	DEC.16	D0L25$:	MOVE.16	D0,{A2}+ODFPGY	; init nouvelle position en Y	RET; ---	DRAWLINE   ---;	DRAWLINE xx yy m;	----------------;	xx:	arrive en x (high puis low);	yy:	arrive en y (high puis low);	m:	modeDODRLI:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D3|D4	MOVE.16	{A2}+ODFCOM+2,D4 ; D4 <-- Y	MOVE.16	{A2}+ODFPGY,D3	SUB.16	D4,D3		; D3 <-- longueur en Y	SWAP.32	D4	SWAP.32	D3	MOVE.16	{A2}+ODFCOM+0,D4 ; D4 <-- Y;X	MOVE.16	{A2}+ODFPGX,D3	SUB.16	D4,D3		; D3 <-- longueur en X	MOVE.8	{A2}+ODFCOM+4,D1 ; D1 <-- mode	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_LINE-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_LINE	POP.32	A0	TEST.16	D7		; dbordement ?	JUMP,NE	 R8^L90$	; oui => 90$				; non =>	MOVE.32	D4,{A2}+ODFPGY	; init nouvelle coor. graphiqueL90$:	POPM.32	D1|D3|D4	RET; ---	DRAWSEG   ---;	DRAWSEG xx yy dxx dyy m;	-----------------------;	xx:	origine en x (high puis low);	yy:	origine en y (high puis low);	dxx:	longueur en x (high puis low);	dyy:	longueur en y (high puis low);	m:	modeDODRSE:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D3|D4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- X;Y	SWAP.32	D4		; D4 <-- Y;X	MOVE.32	{A2}+ODFCOM+4,D3; D3 <-- dX;dY	SWAP.32	D3		; D3 <-- dY;dX	MOVE.8	{A2}+ODFCOM+8,D1; D1 <-- mode	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_LINE-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_LINE	POP.32	A0	POPM.32	D1|D3|D4	RET; ---	DRAWCERCLE   ---;	DRAWCERCLE rr m;	---------------;	rr:	rayon du cercle (high puis low);	m:	modeDODRCE:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D2|D3|D4	MOVE.16	{A2}+ODFCOM+0,D3; D3 <-- rayon du cercle	SWAP.32	D3	MOVE.16	{A2}+ODFCOM+0,D3; D3 <-- rayon du cercle	JUMP,EQ	 R8^L90$	; si rayon nul => 90$	MOVE.8	{A2}+ODFCOM+2,D1; D1 <-- mode	MOVE.32	{A2}+ODFPGY,D4	; D4 <-- coordonne centre (y;x)	MOVE.8	#2'11111111,D2	; D4 <-- dessine tout	CALL	ITELUTIN	; efface lutin-souris si ncessaire	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_CIRCLE-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_CIRCLE	POP.32	A0L90$:	POPM.32	D1|D2|D3|D4	RET; ---	DRAWARC   ---;	DRAWARC xx yy rr aa m;	---------------------;	xx:	centre en x (high puis low);	yy:	centre en y (high puis low);	rr:	rayon du cercle (high puis low);	aa:	octants  dessiner (high puis low);	m:	modeDODRAR:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D2|D3|D4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne centre X;Y	SWAP.32	D4		; D4 <-- coordonne centre Y;X	MOVE.16	{A2}+ODFCOM+4,D3; D3 <-- rayon du cercle	SWAP.32	D3	MOVE.16	{A2}+ODFCOM+4,D3; D3 <-- rayon du cercle	JUMP,EQ	 R8^L90$	; si rayon nul => 90$	MOVE.16	{A2}+ODFCOM+6,D2; D2 <-- octants  dessiner	MOVE.8	{A2}+ODFCOM+8,D1; D1 <-- mode	CALL	ITELUTIN	; efface lutin-souris si ncessaire	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_CIRCLE-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_CIRCLE	POP.32	A0L90$:	POPM.32	D1|D2|D3|D4	RET; ---	DRAWELLIPSE   ---;	DRAWELLIPSE xx yy rx ry aa m;	----------------------------;	xx:	centre en x (high puis low);	yy:	centre en y (high puis low);	rx:	rayon de l'ellipse en x (high puis low);	ry:	rayon de l'ellipse en y (high puis low);	aa:	octants  dessiner (high puis low);	m:	modeDODREL:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D2|D3|D4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne centre X;Y	SWAP.32	D4		; D4 <-- coordonne centre Y;X	MOVE.32	{A2}+ODFCOM+4,D3; D3 <-- rayons X;Y	SWAP.32	D3		; D3 <-- rayons Y;X	TEST.32	D3	JUMP,EQ	 R8^L90$	; si rayons nuls => 90$	MOVE.16	{A2}+ODFCOM+8,D2; D2 <-- octants  dessiner	MOVE.8	{A2}+ODFCOM+10,D1; D1 <-- mode	CALL	ITELUTIN	; efface lutin-souris si ncessaire	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_ELLIPSE-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_ELLIPSE	POP.32	A0L90$:	POPM.32	D1|D2|D3|D4	RET; ---	DRAWDOT   ---;	DRAWDOT xx yy m;	---------------;	xx:	coordonne x (high puis low);	yy:	coordonne y (high puis low);	m:	modeDODRDO:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D3|D4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne (x;y)	SWAP.32	D4		; D4 <-- coordonne (y;x)	MOVE.8	{A2}+ODFCOM+4,D1; D1 <-- mode	MOVE.32	#16'10000*1+1,D3; D3 <-- dimensions pour ITGLUTIN	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_DOT-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_DOT	POP.32	A0	POPM.32	D1|D3|D4	RET; ---	DRAWTRAME   ---;	DRAWTRAME xx yy dxx dyy m;	-------------------------;	xx:	coordonne x (high puis low);	yy:	coordonne y (high puis low);	dxx:	largeur x (high puis low);	dyy:	largeur y (high puis low);	m:	modeDODRTR:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D3|D4|A4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- X;Y	SWAP.32	D4		; D4 <-- Y;X	MOVE.32	{A2}+ODFCOM+4,D3; D3 <-- dX;dY	SWAP.32	D3		; D3 <-- dY;dX	MOVE.8	{A2}+ODFCOM+8,D1; D1 <-- mode	MOVE.32	#{A2}+ODFTRA,A4	; A4 <-- ^trame utilisateur	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_TRAME-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_TRAME	POP.32	A0	POPM.32	D1|D3|D4|A4	RET; ---	XTRAME   ---;	XTRAME xx yy pppp ii dx dy ox oy;	--------------------------------;	xx:	coordonne x gauche;	yy:	coordonne y suprieure;	pppp:	^matrice (^nil si 8x8 standard);	ii:	incrment ligne;	dx:	largeur;	dy:	hauteur;	ox:	origine motif;	oy:	origine motifDOXTRA:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	{A2}+ODFCOM+0,{A2}+ODFTPO+2	MOVE.16	{A2}+ODFCOM+2,{A2}+ODFTPO+0	MOVE.32	{A2}+ODFCOM+4,{A2}+ODFTPM	MOVE.16	{A2}+ODFCOM+8,{A2}+ODFTII	MOVE.16	{A2}+ODFCOM+10,{A2}+ODFTDI+2	MOVE.16	{A2}+ODFCOM+12,{A2}+ODFTDI+0	MOVE.16	{A2}+ODFCOM+14,{A2}+ODFTOR+2	MOVE.16	{A2}+ODFCOM+16,{A2}+ODFTOR+0	RET; ---	TRAME   ---;	TRAME n n n n n n n n;	---------------------;	n:	motif de la trameDOTRAM:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D0|D1|D2|A0|A1	MOVE.32	#{A2}+ODFTRA,A0	; A0 <-- ^destination	MOVE.32	#{A2}+ODFCOM,A1	; A1 <-- ^source	CLR.16	D0	MOVE.16	#8-1,D2		; -1  cause du test NMOL20$:	MOVE.8	{A1+},D0	; D0 <-- trame de la commande; Permute tous les bits de D0 dans D1. Pas de boucle pour tre; rapide, et pas de table de 256 bytes pour conomiser la RAM !	RLX.8	D0	RRX.8	D1		; D1 <-- bit 0	RLX.8	D0	RRX.8	D1		; D1 <-- bit 1	RLX.8	D0	RRX.8	D1		; D1 <-- bit 2	RLX.8	D0	RRX.8	D1		; D1 <-- bit 3	RLX.8	D0	RRX.8	D1		; D1 <-- bit 4	RLX.8	D0	RRX.8	D1		; D1 <-- bit 5	RLX.8	D0	RRX.8	D1		; D1 <-- bit 6	RLX.8	D0	RRX.8	D1		; D1 <-- bit 7	MOVE.8	D1,{A0+}	; stocke trame dans variables	DJ.16,NMO  D2,L20$	CLR.32	{A2}+ODFTPM	; annule XTRAME	POPM.32	D0|D1|D2|A0|A1	RET; ---	XPEN   ---;	XPEN xx yy pppp ii dx dy;	------------------------;	xx:	coordonne x gauche;	yy:	coordonne y suprieure;	pppp:	^matrice (^nil si 8x8 standard);	ii:	incrment ligne;	dx:	largeur;	dy:	hauteurDOXPEN:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	{A2}+ODFCOM+0,{A2}+ODFPPO+2	MOVE.16	{A2}+ODFCOM+2,{A2}+ODFPPO+0	MOVE.32	{A2}+ODFCOM+4,{A2}+ODFPPM	MOVE.16	{A2}+ODFCOM+8,{A2}+ODFPII	MOVE.16	{A2}+ODFCOM+10,{A2}+ODFPDI+2	MOVE.16	{A2}+ODFCOM+12,{A2}+ODFPDI+0	RET; ---	PEN   ---;	PEN n n n n n n n n;	-------------------;	n:	motif du pinceauDOPEN:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.32	{A2}+ODFCOM+0,{A2}+ODFPEN+0 ; stocke le pinceau	MOVE.32	{A2}+ODFCOM+4,{A2}+ODFPEN+4 ; dans les var.	CLR.32	{A2}+ODFPPM	; annule XPEN	RET; ---	XMAPTT   ---;	XMAPTT oo p1 v1 p2 v2 p3 v3 p4 v4;	---------------------------------;	oo:	origine traitill;	pn:	longueur pleine;	vn:	longueur videDOXMAP:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	{A2}+ODFCOM+0,{A2}+ODFPTO	MOVE.32	{A2}+ODFCOM+2,{A2}+ODFPT1	MOVE.32	{A2}+ODFCOM+6,{A2}+ODFPT3	MOVE.32	{A2}+ODFCOM+10,{A2}+ODFPT5	MOVE.32	{A2}+ODFCOM+14,{A2}+ODFPT7	RET; ---	MAPTT   ---;	MAPTT m e;	---------;	m:	map des traits  - - -;	e:	chelle (1..n)DOMAPT:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D0	MOVE.8	{A2}+ODFCOM+0,{A2}+ODFTTM ; stocke le map  - - -	MOVE.8	{A2}+ODFCOM+1,D0 ; D0 <-- chelle	JUMP,NE	 R8^L50$	INC.8	D0		; D0 <-- au moins unL50$:	MOVE.8	D0,{A2}+ODFTTS	; stocke l'chelle	CLR.16	{A2}+ODFPT1	; annule XMAPTT	POP.16	D0	RET; ---	DRAWFILLO   ---;	DRAWFILLO xx yy;	---------------;	xx:	coordonne x dbut remplissage;	yy:	coordonne y dbut remplissageDODRFO:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.32	D4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne (x;y)	SWAP.32	D4		; D4 <-- coordonne (y;x)	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_FILLO-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_FILLO	POP.32	A0	POP.32	D4	RET; ---	DRAWFILLC   ---;	DRAWFILLC;	---------DODRFC:	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_FILLC-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_FILLC	POP.32	A0	RET; ---	DRAWRASTER   ---;	DRAWRASTER xx yy pppp ii xx yy pppp ii dx dy m;	----------------------------------------------;	xx:	coordonne x gauche source/destination;	yy:	coordonne y suprieure source/destination;	pppp:	^source/destination (^nil si cran);	ii:	incrment (si mmoire) source/destination;	dx:	largeur;	dy:	hauteur;	m:	modeDODRRA:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1..D6|A3|A4	MOVE.32	{A2}+ODFCOM+0,D3; D3 <-- coordonne (x;y) source	SWAP.32	D3		; D3 <-- coordonne (y;x) source	MOVE.32	{A2}+ODFCOM+4,A3; A3 <-- ^source	MOVE.16	{A2}+ODFCOM+8,D5; D5 <-- Iy source	MOVE.32	{A2}+ODFCOM+10,D4; D4 <-- coordonne (x;y) destination	SWAP.32	D4		 ; D4 <-- coordonne (y;x) destination	MOVE.32	{A2}+ODFCOM+14,A4; A4 <-- ^destination	MOVE.16	{A2}+ODFCOM+18,D6; D6 <-- Iy destination	MOVE.32	{A2}+ODFCOM+20,D2; D2 <-- dim (dx;dy)	SWAP.32	D2		 ; D2 <-- dim (dy;dx)	MOVE.8	{A2}+ODFCOM+24,D1; D1 <-- opration	COMP.32	#0,A4		; A4=^nil (si cran) ?	JUMP,NE	 R8^L50$	; non => 50$	EX.32	D2,D3	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	EX.32	D3,D2L50$:	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_RASTER-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_RASTER	POP.32	A0	POPM.32	D1..D6|A3|A4	RET; ---	DRAWOSPRITE   ---;	DRAWOSPRITE xx yy dx dy ssss cccc n;	-----------------------------------;	xx:	coordonne x gauche;	yy:	coordonne y suprieure;	dx:	largeur dx;	dy:	hauteur dy;	ssss:	^matrice chair (set);	cccc:	^matrice fond (clear);	n:	numro du lutinDODROS:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D0|D3|D4|D6|A3|A4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne (x;y)	SWAP.32	D4		; D4 <-- coordonne (y;x)	MOVE.32	{A2}+ODFCOM+4,D3; D3 <-- dimensions (dx;dy)	SWAP.32	D3		; D3 <-- dimensions (dy;dx)	MOVE.32	{A2}+ODFCOM+8,A4 ; A4 <-- ^matrice chair (set)	MOVE.32	{A2}+ODFCOM+12,A3; A3 <-- ^matrice fond (clear)	MOVE.8	{A2}+ODFCOM+16,D6; D6 <-- numro du lutin	MOVE.16	#SPRITE_OPEN,D0	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_SPRITE-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_SPRITE	POP.32	A0	POPM.32	D0|D3|D4|D6|A3|A4	RET; ---	DRAWMSPRITE   ---;	DRAWMSPRITE xx yy n;	-------------------;	xx:	coordonne x gauche;	yy:	coordonne y suprieure;	n:	numro du lutinDODRMS:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D0|D1|D3|D4|D6|A3|A4	MOVE.8	{A2}+ODFCOM+4,D6; D6 <-- numro du lutin	MOVE.16	#SPRITE_GETPOS,D0	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_SPRITE-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_SPRITE	POP.32	A0	JUMP,NE L90$	EX.32	D3,D4		; D4 <-- pos et D3 <-- dim	CLR.16	D1		; D1 <-- mode	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne (x;y)	SWAP.32	D4		; D4 <-- coordonne (y;x)	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	MOVE.16	#SPRITE_MOVE,D0	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_SPRITE-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_SPRITE	POP.32	A0L90$:	POPM.32	D0|D1|D3|D4|D6|A3|A4	RET; ---	DRAWESPRITE   ---;	DRAWESPRITE n;	-------------;	n:	numro du lutinDODRES:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D0|D3|D4|D6|A3|A4	MOVE.8	{A2}+ODFCOM+0,D6; D6 <-- numro du lutin	MOVE.16	#SPRITE_CLEAR,D0	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_SPRITE-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_SPRITE	POP.32	A0	POPM.32	D0|D3|D4|D6|A3|A4	RET; ---	DRAWCSPRITE   ---;	DRAWCSPRITE n;	-------------;	n:	numro du lutinDODRCS:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D0|D3|D4|D6|A3|A4	MOVE.8	{A2}+ODFCOM+0,D6; D6 <-- numro du lutin	MOVE.16	#SPRITE_CLOSE,D0	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_SPRITE-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_SPRITE	POP.32	A0	POPM.32	D0|D3|D4|D6|A3|A4	RET; ---	DRAWPMOUSE   ---;	DRAWPMOUSE ssss cccc;	--------------------;	ssss:	^matrice lutin (set);	cccc:	^matrice fond  (clr)DODRPM:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.32	{A2}+ODFCOM+0,{A2}+ODFPMS; mm ^matrice lutin (set)	MOVE.32	{A2}+ODFCOM+4,{A2}+ODFPMC; mm ^matrice fond  (clr)	RET; ---	DRAWMOUSE   ---;	DRAWMOUSE xx yy ssss cccc o;	---------------------------;	xx:	coordonne x souris;	yy:	coordonne y souris;	ssss:	(*) ^matrice lutin (set);	cccc:	(*) ^matrice fond  (clr);	o:	(*) opration (SPRITE_OPEN/MOVE/CLOSE);;		(*)  -->  n'est plus utilis !DODRMO:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.32	D4	TEST.8	{A2}+ODFNOW	; est-on dans la fentre $DIS_0 ?	JUMP,NE	 R8^L90$	; non => 90$L50$:				; oui =>	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne (x;y)	SWAP.32	D4		; D4 <-- coordonne (y;x)	CALL	MOMOVE		; dplace le lutin de la sourisL90$:	POP.32	D4	RET; ---	DRAWMATRIX   ---;	DRAWMATRIX xx yy pppp m;	-----------------------;	xx:	coordonne x coin suprieur gauche;	yy:	coordonne y coin suprieur gauche;	pppp:	pointeur  la matrice;	m:	modeDODRMX:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D2|D3|D4|D5|A4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne (x;y)	SWAP.32	D4		; D4 <-- coordonne (y;x)	MOVE.32	{A2}+ODFCOM+4,A4; A4 <-- ^matrice	MOVE.8	{A2}+ODFCOM+8,D1; D1 <-- mode	CLR.32	D3	MOVE.8	{A4+},D3	; D3 <-- largeur matrice	JUMP,EQ	 R8^L90$	SWAP.32	D3	MOVE.8	{A4+},D3	; D3 <-- hauteur matrice	JUMP,EQ	 R8^L90$	SWAP.32	D3		; D3 <-- hauteur/largeur (dy;dx)	CLR.16	D5	MOVE.8	D3,D5	SR.8	#3,D5		; D5 <-- Iy (largeur en bytes)	MOVE.8	D3,D2	AND.8	#2'111,D2	; reste ?	JUMP,EQ	 R8^L60$	; non => 60$	INC.16	D5		; oui => compte un de plusL60$:	CLR.16	D2		; D2 <-- mode non invers	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_MATRIX-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_MATRIX	POP.32	A0L90$:	POPM.32	D1|D2|D3|D4|D5|A4	RET; ---	LEFT   ---DOLEFT:	PUSH.16	D0	MOVE.16	{A2}+ODFPX,D0	; D0 <-- position X actuelle	SUB.16	{A2}+ODFCX,D0	; recule d'un caractre	COMP.16	{A2}+ODFC1X,D0	; recul trop loin ?	JUMP,GE	 R8^L80$	; non => 80$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFC1X,D0	; revient au dbutL80$:	MOVE.16	D0,{A2}+ODFPX	POP.16	D0	RET; ---	RIGHT   ---DORIGHT:	PUSHM.16 D0|D1	MOVE.16	{A2}+ODFFDX,D1	SUB.16	{A2}+ODFC2X,D1	; D1 <-- pos  ne pas dpasser	MOVE.16	{A2}+ODFPX,D0	; D0 <-- position actuelle	ADD.16	{A2}+ODFCX,D0	; avance d'un caractre	COMP.16	D1,D0		; est-on trop  droite ?	JUMP,LE	 R8^L90$	; non => 90$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	D1,D0		; va tout  droiteL90$:	MOVE.16	D0,{A2}+ODFPX	POPM.A16 D0|D1	RET; ---	UP   ---DOUP:	PUSH.16	D0	MOVE.16	{A2}+ODFPY,D0	; D0 <-- position Y actuelle	SUB.16	{A2}+ODFCY,D0	; remonte d'une ligne	COMP.16	{A2}+ODFC1Y,D0	; remont trop haut ?	JUMP,GE	 R8^L80$	; non => 80$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFC1Y,D0	; remonte tout en hautL80$:	MOVE.16	D0,{A2}+ODFPY	POP.16	D0	RET; ---	DOWN   ---DODOWN:	PUSHM.16 D0|D1	MOVE.16	{A2}+ODFFDY,D1	SUB.16	{A2}+ODFC2Y,D1	; D1 <-- pos  ne pas dpasser	MOVE.16	{A2}+ODFPY,D0	; D0 <-- position actuelle	ADD.16	{A2}+ODFCY,D0	; descend d'un caractre	COMP.16	D1,D0		; est-on trop bas ?	JUMP,LE	 R8^L90$	; non => 90$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	D1,D0		; va tout en basL90$:	MOVE.16	D0,{A2}+ODFPY	POPM.A16 D0|D1	RET; ---	AFDIR   ---DOADIR:	TCLR.8	{A2}+ODFFLG:#BFVIDI ; vido normale	RET; ---	AFINV   ---DOAINV:	TSET.8	{A2}+ODFFLG:#BFVIDI ; vido inverse	RET; ---	AFTOUT   ---DOTOUT:	TSET.8	{A2}+ODFFLG:#BFTOUT ; affiche tout	RET; ---	AFNORM   ---DONORM:	TCLR.8	{A2}+ODFFLG:#BFTOUT ; excute CR, TAB, etc.	RET; ---	AFFULL   ---DOFULL:	TCLR.8	{A2}+ODFFLG:#BFGREY ; affiche en plein	RET; ---	AFGREY   ---DOGREY:	TSET.8	{A2}+ODFFLG:#BFGREY ; affiche en gris	RET; ---	ROLL   ---DOROLL:	TSET.8	{A2}+ODFMOD:#BFROLL ; fait du roll	TCLR.8	{A2}+ODFMOD:#BSROLL ; "hard" roll	RET; ---	SROLL   ---DOSROL:	TSET.8	{A2}+ODFMOD:#BFROLL ; fait du roll	TSET.8	{A2}+ODFMOD:#BSROLL ; "soft" roll	RET; ---	NOROLL   ---DONORO:	TCLR.8	{A2}+ODFMOD:#BFROLL ; plus de roll	RET; ---	TRUNC   ---DOTRUN:	TSET.8	{A2}+ODFMOD:#BFTRUNC ; tronque les lignes	RET; ---	AUTOCR   ---DOAUCR:	TCLR.8	{A2}+ODFMOD:#BFTRUNC ; ne tronque plus lignes	RET; ---	AUTOEFLI   ---DOAUEF:	TSET.8	{A2}+ODFMOD:#BFEFLI ; efface lignes aprs CR	RET; ---	NOEFLI   ---DONOEF:	TCLR.8	{A2}+ODFMOD:#BFEFLI ; n'efface pas les lignes	RET; ---	GCURS   ---DOGCUR:	TCLR.8	{A2}+ODFMOD:#BFNOCU ; y a un curseur	TCLR.8	{A2}+ODFMOD:#BFPCUR ; grand curseur	RET; ---	PCURS   ---DOPCUR:	TCLR.8	{A2}+ODFMOD:#BFNOCU ; y a un curseur	TSET.8	{A2}+ODFMOD:#BFPCUR ; petit curseur	RET; ---	CURS   ---DOCURS:	TCLR.8	{A2}+ODFMOD:#BFNOCU ; y a un curseur	RET; ---	NOCURS   ---DONOCU:	TSET.8	{A2}+ODFMOD:#BFNOCU ; plus de curseur du tout	RET; ---	AFCVAR   ---DOCVAR:	TCLR.8	{A2}+ODFMOD:#BFCFIX ; chasse variable	RET; ---	AFCFIX   ---DOCFIX:	TSET.8	{A2}+ODFMOD:#BFCFIX ; chasse fixe	RET; ---	AFCCMO   ---DOCCMO:	TSET.8	{A2}+ODFFLG:#BFNCMO ; curseur souris interdit	RET; ---	AFSCMO   ---DOSCMO:	TCLR.8	{A2}+ODFFLG:#BFNCMO ; curseur souris permis	RET; ---	AFFILLT   ---DOFILT:	TCLR.8	{A2}+ODFFLG:#BFFILA ; rempli: test si touche les bords	RET; ---	AFFILLA   ---DOFILA:	TSET.8	{A2}+ODFFLG:#BFFILA ; rempli: va jusque dans les bords	RET; ---	MMODULO   ---DOMODU:	CLR.16	{A2}+ODFADR	; suite de bytes termines	TCLR.8	{A2}+ODFFL2:#BFNOMOD	TEST.8	{A2}+ODFCOM+0	JUMP,EQ	 R8^L90$	TSET.8	{A2}+ODFFL2:#BFNOMODL90$:	RET; ---	IMAENA   ---DOIMAE:	TSET.8	{A2}+ODFFLG:#BFIMAA ; image alpha va exister	JUMP,BS	 R8^L90$	; si existait dj => 90$	CALL	CREIMA		; cre l'image alphanum.L90$:	RET; ---	IMADIS   ---DOIMAD:	TCLR.8	{A2}+ODFFLG:#BFIMAA ; plus d'image alpha	JUMP,BC	 R8^L90$	; si dj plus => 90$	CALL	KILIMA		; supprime l'image alphanum.L90$:	RET; ---	COLORSA	---;	COLORSA rr gg bb;	----------------;	rr:	intensit du rouge;	gg:	intensit du vert;	bb:	intensit du bleuDOCOSA:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	COLOR.OR.Color300	PUSHM.32 D3|D4|A4	MOVE.8	{A2}+ODFCOM+0,D3 ; D3 <-- r	SL.32	#8,D3	MOVE.8	{A2}+ODFCOM+2,D3 ; D3 <-- g	SL.32	#8,D3	MOVE.8	{A2}+ODFCOM+4,D3 ; D3 <-- b	SL.32	#8,D3	CALL	COLORFAUSRC	; A4/D4 <-- fausse couleur	MOVE.32	D4,{A2}+ODFCSF	MOVE.8	{A4}+OCOLFR,{A2}+ODFCSA+0 ; ODFCSA+0 <-- rouge	CLR.8	{A2}+ODFCSA+1	MOVE.8	{A4}+OCOLFG,{A2}+ODFCSA+2 ; ODFCSA+2 <-- vert	CLR.8	{A2}+ODFCSA+3	MOVE.8	{A4}+OCOLFB,{A2}+ODFCSA+4 ; ODFCSA+4 <-- bleu	CLR.8	{A2}+ODFCSA+5	POPM.32	D3|D4|A4.ENDIF	COLOR.OR.Color300	RET; ---	COLORCA	---;	COLORCA rr gg bb;	----------------;	rr:	intensit du rouge;	gg:	intensit du vert;	bb:	intensit du bleuDOCOCA:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	COLOR.OR.Color300	PUSHM.32 D3|D4|A4	MOVE.8	{A2}+ODFCOM+0,D3 ; D3 <-- r	SL.32	#8,D3	MOVE.8	{A2}+ODFCOM+2,D3 ; D3 <-- g	SL.32	#8,D3	MOVE.8	{A2}+ODFCOM+4,D3 ; D3 <-- b	SL.32	#8,D3	CALL	COLORFAUSRC	; A4/D4 <-- fausse couleur	MOVE.32	D4,{A2}+ODFCCF	MOVE.8	{A4}+OCOLFR,{A2}+ODFCCA+0 ; ODFCCA+0 <-- rouge	CLR.8	{A2}+ODFCCA+1	MOVE.8	{A4}+OCOLFG,{A2}+ODFCCA+2 ; ODFCCA+2 <-- vert	CLR.8	{A2}+ODFCCA+3	MOVE.8	{A4}+OCOLFB,{A2}+ODFCCA+4 ; ODFCCA+4 <-- bleu	CLR.8	{A2}+ODFCCA+5	POPM.32	D3|D4|A4.ENDIF	COLOR.OR.Color300	RET; ---	COLORSR	---;	COLORSR nnnn;	------------;	nnnn:	numroDOCOSR:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	Color300	PUSHM.32 D3|D4|A3|A4	MOVE.32	{A2}+ODFCOM+0,D4 ; D4 <-- nnnn	CALL	COLORRELSRC	; A3/D3 <-- ^dans OCOLRx	JUMP,NE	 R8^L90$L20$:	MOVE.32	D4,{A2}+ODFCSR	; ODFCSR <-- numro.IF	Safety	MOVE.32	{A3}+OCOLRR,D3		; D3 <-- |r|g|b|-|	CALL	ColorFauSRC		; recherche la fausse couleur.ELSE	Safety	CLR.32	D4	MOVE.8	{A3}+OCOLRF,D4.ENDIF	ELSE Safety	MOVE.32	D4,{A2}+ODFCSF	; ODFCSF <-- fausse couleur.IF	Safety	MOVE.8	{A4}+OCOLFR,{A2}+ODFCSA+0 ; ODFCSA+0 <-- rouge	CLR.8	{A2}+ODFCSA+1	MOVE.8	{A4}+OCOLFG,{A2}+ODFCSA+2 ; ODFCSA+2 <-- vert	CLR.8	{A2}+ODFCSA+3	MOVE.8	{A4}+OCOLFB,{A2}+ODFCSA+4 ; ODFCSA+4 <-- bleu	CLR.8	{A2}+ODFCSA+5.ELSE	Safety	MOVE.8	{A3}+OCOLRR,{A2}+ODFCSA+0 ; ODFCSA+0 <-- rouge	CLR.8	{A2}+ODFCSA+1	MOVE.8	{A3}+OCOLRG,{A2}+ODFCSA+2 ; ODFCSA+2 <-- vert	CLR.8	{A2}+ODFCSA+3	MOVE.8	{A3}+OCOLRB,{A2}+ODFCSA+4 ; ODFCSA+4 <-- bleu	CLR.8	{A2}+ODFCSA+5.ENDIF	ELSE SafetyL90$:	POPM.32	D3|D4|A3|A4.ENDIF	Color300	RET; ---	COLORCR	---;	COLORCR nnnn;	------------;	nnnn:	numroDOCOCR:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	Color300	PUSHM.32 D3|D4|A3|A4	MOVE.32	{A2}+ODFCOM+0,D4 ; D4 <-- nnnn	CALL	COLORRELSRC	; A3/D3 <-- ^dans OCOLRx	JUMP,NE	 R8^L90$L20$:	MOVE.32	D4,{A2}+ODFCCR		; ODFCCR <-- numro.IF	Safety	MOVE.32	{A3}+OCOLRR,D3		; D3 <-- |r|g|b|-|	CALL	ColorFauSRC		; recherche la fausse couleur.ELSE	Safety	CLR.32	D4	MOVE.8	{A3}+OCOLRF,D4.ENDIF	ELSE Safety	MOVE.32	D4,{A2}+ODFCCF		; ODFCCF <-- fausse couleur.IF	Safety	MOVE.8	{A4}+OCOLFR,{A2}+ODFCCA+0 ; ODFCCA+0 <-- rouge	CLR.8	{A2}+ODFCCA+1	MOVE.8	{A4}+OCOLFG,{A2}+ODFCCA+2 ; ODFCCA+2 <-- vert	CLR.8	{A2}+ODFCCA+3	MOVE.8	{A4}+OCOLFB,{A2}+ODFCCA+4 ; ODFCCA+4 <-- bleu	CLR.8	{A2}+ODFCCA+5.ELSE	Safety	MOVE.8	{A3}+OCOLRR,{A2}+ODFCCA+0 ; ODFCCA+0 <-- rouge	CLR.8	{A2}+ODFCCA+1	MOVE.8	{A3}+OCOLRG,{A2}+ODFCCA+2 ; ODFCCA+2 <-- vert	CLR.8	{A2}+ODFCCA+3	MOVE.8	{A3}+OCOLRB,{A2}+ODFCCA+4 ; ODFCCA+4 <-- bleu	CLR.8	{A2}+ODFCCA+5.ENDIF	ELSE SafetyL90$:	POPM.32	D3|D4|A3|A4.ENDIF	Color300	RET; ---	COLORLINK   ---;	COLORLINK nnnn rr gg bb;	-----------------------;	nnnn:	numro;	rr:	intensit du rouge;	gg:	intensit du vert;	bb:	intensit du bleuDOCOLK:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	COLOR.OR.Color300	PUSHM.32 D3|D4|A3|A4	MOVE.32	{A2}+ODFCOM+0,D4 ; D4 <-- nnnn	CALL	COLORRELSRC	; A3/D3 <-- ^dans OCOLRx	JUMP,EQ	 R8^L30$	CALL	COLORRELADD	; ajoute une nouvelle couleur	JUMP,NE	 R8^L90$L30$:	MOVE.8	{A2}+ODFCOM+4+0,{A3}+OCOLRR	MOVE.8	{A2}+ODFCOM+4+2,{A3}+OCOLRG	MOVE.8	{A2}+ODFCOM+4+4,{A3}+OCOLRB	MOVE.32	{A3}+OCOLRR,D3	; D3 <-- |r|g|b|-|	CALL	COLORFAUSRC	; A4/D4 <-- fausse couleur	MOVE.8	D4,{A3}+OCOLRFL90$:	POPM.32	D3|D4|A3|A4.ENDIF	COLOR.OR.Color300	RET; ---	COLORUNLINK   ---;	COLORUNLINK nnnn;	----------------;	nnnn:	numroDOCOUK:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	COLOR.OR.Color300	PUSHM.32 D3|D4|A3	MOVE.32	{A2}+ODFCOM+0,D4 ; D4 <-- nnnn	CALL	COLORRELSRC	; A3/D3 <-- ^dans OCOLRx	JUMP,NE	 R8^L90$	CALL	COLORRELSUB	; supprime une ancienne couleurL90$:	POPM.32	D3|D4|A3.ENDIF	COLOR.OR.Color300	RET; ---	COLOROP   ---;	COLOROP o;	---------;	o:	opration (COLOROPxxx)DOCOOP:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	COLOR.OR.Color300	PUSHM.32 D3|D4	MOVE.8	{A2}+ODFCOM,D3	; D3 <-- <o>	COMP.8	#COLOROPPUSH,D3	JUMP,EQ	 R8^PUSH$	COMP.8	#COLOROPPOP,D3	JUMP,EQ	 R8^POP$	COMP.8	#COLOROPFIX,D3	JUMP,EQ FIX$	COMP.8	#COLOROPAJUST,D3	JUMP,EQ AJUST$	MOVE.16	#ERDIOUT,D7	JUMP	EXIT$PUSH$:	CALL	COLORPUSH	; sauve les couleurs	JUMP	EXIT$POP$:	CALL	COLORPOP	; restitue les couleurs;-	JUMP	EXIT$FIX$:AJUST$:EXIT$:	POPM.32	D3|D4.ENDIF	COLOR.OR.Color300	RET; ---	COLORFALSE   ---;	COLORFALSE ffff rr gg bb;	------------------------;	ffff:	fausse couleur;	rr:	intensit du rouge;	gg:	intensit du vert;	bb:	intensit du bleuDOCOFA:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	Color300	PUSHM.32 A2|A3|D3|D0	TEST.8	{A2}+ODFCMD		; Mode couleur ?	JUMP,F	R8^Exit$	MOVE.32	{A2}+ODFCPF,A3		; A3 ^table des fausses couleurs	MOVE.32	{A2}+ODFCom,D3		; D3.32 <- numro de la fausse couleur  changer	TEST.16	D3	JUMP,EQ	Exit$			; Protge le blanc	MOVE.16	{A2}+ODFCNB,D0		; D0.32 <- nbre maximum de couleurs	DEC.16	D0			; Protge le noir	COMP.16	D0,D3	JUMP,HS	Exit$	MOVE.16	D3,D0			; D0.16 <- fausse couleur  changer	MUL.16	#LColF,D3	ADD.32	D3,A3			; A3 ^fausse couleur	MOVE.8	{A2}+ODFCOM+4+0,{A3}+OCOLFR ; Copie dans la table	MOVE.8	{A2}+ODFCOM+4+2,{A3}+OCOLFG	MOVE.8	{A2}+ODFCOM+4+4,{A3}+OCOLFB	CLR.16	D4	MOVE.8	{A2}+ODFCad+0,D4	; Numro de la fentre	JUMP,EQ	R8^doUpdate$		; Si pas dfini -> on touche le hard	SUB.8	#"1",D4	COMP.16	{A6}+ONoVBM,D4		; Bitmap actuellement visible ?	JUMP,NE	R8^dontTouch$doUpdate$:	CALL	SetCLUT			; Initialise le hardwaredontTouch$:	CLR.16	D7Exit$:	POPM.32	A2|A3|D3|D0.ENDIF	Color300	RET; ---	DIMWDO	---;	DIMWDO xx yy dxx dyy;	--------------------;	xx:	dbut de la fentre en X;	yy:	dbut de la fentre en Y;	dxx:	largeur de la fentre;	dyy:	hauteur de la fentreDODIMW:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D3	MOVE.16	#ERDIOUT,D7	 ; D7 <-- paramtres trop grand	TEST.8	{A2}+ODFFL2:#BFNOMOD	JUMP,BS	 R8^L20$	AND.16	#16'FFF8,{A2}+ODFCOM+0; aligne xx sur un byte	AND.16	#16'FFF8,{A2}+ODFCOM+4; aligne dxx sur un byte	AND.16	#16'FFFE,{A2}+ODFCOM+2; aligne yy sur un word	AND.16	#16'FFFE,{A2}+ODFCOM+6; aligne dyy sur un wordL20$:	MOVE.16	{A2}+ODFCOM+0,D3 ; D3 <-- xx	ADD.16	{A2}+ODFCOM+4,D3 ; D3 <-- xx + dxx	COMP.16	{A2}+ODFDX,D3	 ; trop large ?	JUMP,HI	 R8^L90$	 ; oui => 90$	MOVE.16	{A2}+ODFCOM+2,D3 ; D3 <-- yy	ADD.16	{A2}+ODFCOM+6,D3 ; D3 <-- yy + dyy	COMP.16	{A2}+ODFDY,D3	 ; trop long ?	JUMP,HI	 R8^L90$	 ; oui => 90$	MOVE.16	{A2}+ODFCOM+0,{A2}+ODFFX  ; mm. xx	MOVE.16	{A2}+ODFCOM+2,{A2}+ODFFY  ; mm. yy	MOVE.16	{A2}+ODFCOM+4,{A2}+ODFFDX ; mm. dxx	MOVE.16	{A2}+ODFCOM+6,{A2}+ODFFDY ; mm. dyy	CALL	WMINMAX		; init min et max (sous-)fentre	CLR.16	D7		; D7 <-- okL90$:	POP.16	D3	RET;--------\\; WMINMAX >;========/; Initialise les variables contenant les positions min/max de la; (sous-)fentre.; in	A2.L	^descripteur; out	-; mod	-WMINMAX:	PUSH.16	D4	MOVE.16	{A2}+ODFX,D4	ADD.16	{A2}+ODFFX,D4	MOVE.16	D4,{A2}+ODFWBX	; init min X	ADD.16	{A2}+ODFFDX,D4	MOVE.16	D4,{A2}+ODFWEX	; init max X	MOVE.16	{A2}+ODFY,D4	ADD.16	{A2}+ODFFY,D4	MOVE.16	D4,{A2}+ODFWBY	; init min Y	ADD.16	{A2}+ODFFDY,D4	MOVE.16	D4,{A2}+ODFWEY	; init max Y	POP.16	D4	RET; ---	SAVWDO	---DOSAVW:	JUMP	WDOSAV		; zone sauvetage <-- fentre; ---	GETWDO	---DOGETW:	JUMP	WDOGET		; fentre <-- zone sauvetage; ---	PROCURS   ---;	PROCURS c;	---------;	c:	caractre (dfinissant la largeur du curseur)DOPROC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D3	MOVE.8	{A2}+ODFCOM+0,D3 ; D3 <-- paramtre "c"	CALL	INVPROC	POP.16	D3	RET; ---	NEWGC   ---;	NEWGC o f ssss t;	----------------;	o:	opration (LOADGC/USEGC/KILLGC);	 :	fonte (normal, spcial, messenger, grec, etc);	ssss:	style (bits 0-7: style/chasse, bits 7-31: construction);	t:	tailleDONEGC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D2|D3	MOVE.8	{A2}+ODFCOM+0,D3 ; D3 <-- opration	MOVE.8	{A2}+ODFCOM+1,D0 ; D0 <-- fonte	MOVE.8	{A2}+ODFCOM+2,D1	SL.32	#8,D1	MOVE.8	{A2}+ODFCOM+3,D1	SL.32	#8,D1	MOVE.8	{A2}+ODFCOM+4,D1	SL.32	#8,D1	MOVE.8	{A2}+ODFCOM+5,D1 ; D1 <-- style	MOVE.8	{A2}+ODFCOM+6,D2 ; D2 <-- taille	COMP.8	#LOADGC,D3	JUMP,EQ	 R8^L30$	COMP.8	#KILLGC,D3	JUMP,EQ	 R8^L40$	CALL	GCUSE		; utilise	JUMP	R8^L90$L30$:	CALL	GCLOAD		; charge	JUMP	R8^L90$L40$:	CALL	GCKILL		; libreL90$:	POPM.32	D2|D3	RET; ---	USEGC   ---;	USEGC f s t;	-----------;	 :	fonte (normal, spcial, messenger, grec, etc);	s:	style (roman, italique, bold, etc);	t:	tailleDOUSGC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D2	MOVE.8	{A2}+ODFCOM+0,D0 ; D0 <-- fonte	MOVE.8	{A2}+ODFCOM+1,D1 ; D1 <-- style	MOVE.8	{A2}+ODFCOM+2,D2 ; D2 <-- taille	CALL	CONVNEWGC	; D0/D1/D2 <-- fst selon nouveau format	CALL	GCUSE	POP.16	D2	RET; ---	LOADGC   ---;	LOADGC f s t;	------------;	 :	fonte (normal, spcial, messenger, grec, etc);	s:	style (roman, italique, bold, etc);	t:	tailleDOLOGC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D2	MOVE.8	{A2}+ODFCOM+0,D0 ; D0 <-- fonte	MOVE.8	{A2}+ODFCOM+1,D1 ; D1 <-- style	MOVE.8	{A2}+ODFCOM+2,D2 ; D2 <-- taille	CALL	CONVNEWGC	; D0/D1/D2 <-- fst selon nouveau format	CALL	GCLOAD	POP.16	D2	RET; ---	KILLGC   ---;	KILLGC f s t;	------------;	 :	fonte (normal, spcial, messenger, grec, etc);	s:	style (roman, italique, bold, etc);	t:	tailleDOKIGC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D2	MOVE.8	{A2}+ODFCOM+0,D0 ; D0 <-- fonte	MOVE.8	{A2}+ODFCOM+1,D1 ; D1 <-- style	MOVE.8	{A2}+ODFCOM+2,D2 ; D2 <-- taille	CALL	CONVNEWGC	; D0/D1/D2 <-- fst selon nouveau format	CALL	GCKILL	POP.16	D2	RET; ---	PFIXGC   ---;	PFIXGC nnnn;	-----------;	nnnn:	prfix de 4 lettres au maximum;		- nom<0> si moins de 4 lettres;		- nom si 4 lettres;		- <0> si prfix standard "SYS" ou "100"DOPFGC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.32	{A2}+ODFCOM+0,{A2}+ODFFIX	RET; ---	ASSGC   ---;	ASSGC f s t   f s t	(logique-physique);	-------------------;	 :	fonte (normal, spcial, messenger, grec, etc);	s:	style (roman, italique, bold, etc);	t:	tailleDOASGC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	#ERDIOUT,D7	RET; ---	MEMGC   ---DOMEGC:	MOVE.16	#ERDIOUT,D7	RET; ---	EFLI   ---DOEFLI:	CALL	ITLLUTIN	; efface lutin-souris si ncessaire	JUMP	AFEFLI; ---	EFEOS   ---DOEFEOS:	JUMP	AFEFEOS; ---	CR   ---DOCR:	PUSHM.16 D0|D1	MOVE.16	{A2}+ODFC1X,{A2}+ODFPX ; rz position en X	MOVE.16	{A2}+ODFFDY,D1	SUB.16	{A2}+ODFC2Y,D1	; D1 <-- pos  ne pas dpasser	MOVE.16	{A2}+ODFPY,D0	; D0 <-- position en Y	ADD.16	{A2}+ODFCY,D0	; ajoute largeur d'un caractre	COMP.16	D1,D0		; trop bas ?	JUMP,LS	 R8^L50$	; non => 50$				; oui =>	COMP.8	#GRACLIP2,{A2}+ODFMGR	JUMP,EQ	 R8^L50$	CALL	CLRLUTIN	; enlve le lutin de la souris	CALL	ROLLCR		; effectue un roll de l'cran	JUMP	R8^L90$L50$:	MOVE.16	D0,{A2}+ODFPY	; mj mouvelle position en Y	TEST.8	{A2}+ODFMOD:#BFEFLI ; efface nouvelle ligne ?	JUMP,EQ	 R8^L90$	; non => 90$	CALL	DOEFLI		; oui => efface tout la ligneL90$:	POPM.A16 D0|D1	RET; ---	EOP   ---DOEOP:	CALL	EFFACE		; efface tout l'cran	MOVE.16	{A2}+ODFC1X,{A2}+ODFPX	MOVE.16	{A2}+ODFC1Y,{A2}+ODFPY ; clear coordonne alpha	CLR.16	{A2}+ODFPGX	CLR.16	{A2}+ODFPGY	; clear coordonne graphique	RET; ---	TAB   ---DOTAB:	PUSHM.16 D2|D3	CLR.32	D2	MOVE.16	{A2}+ODFPX,D2	; D2 <-- position en X	DIV.16	{A2}+ODFCX,D2	; D2 <-- position en car.L10$:	MOVE.8	#SPACE,D3	CALL	AFCODE		; affiche un espace	INC.8	D2	AND.8	#2'111,D2	; position modulo 8 ?	JUMP,NE L10$		; non => 10$	POPM.A16 D2|D3	RET; ---	BELL   ---DOBELL:	RET; ---	BS   ---DOBS:	PUSH.16	D3	CALL	DOLEFT		; recule d'un caractre	MOVE.8	#SPACE,D3	CALL	AFCODE		; affiche un espace	CALL	DOLEFT		; puis recule encore une fois	POP.16	D3	RET; ---	MSPACE   ---;	MSPACE n;	--------;	n:	nombre d'espaces  afficherDOMSPA:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.16 D0|D1|D3	MOVE.8	{A2}+ODFCOM,D0	; D0 <-- nb de SPACE  afficher	JUMP,EQ	 R8^L90$	; si zro => 90$L20$:				; si un ou plusieurs =>	MOVE.8	#SPACE,D3	CALL	AFCODE		; affiche qq SPACE(s)	DEC.8	D0	JUMP,NE L20$L90$:	POPM.A16 D0|D1|D3	RET	.END