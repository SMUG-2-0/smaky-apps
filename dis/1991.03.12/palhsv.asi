	.SBTTL	PALHSV.ASI;---------\\; HSVCDRAW >;=========/; Affiche la couleur originale (0) ou modifie (1).; in	D1.W	numro de la couleur (0,1); out	-; mod	D7.WHSVCDRAW:	PUSHM.L	D2..D5,A3	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.W	D3,D1	MUL.WU	D3,#102	ADD.W	D3,#30	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LOAD.W	D3,(A6)+OCURPX	LOAD.L	D4,#H'10000*75+70	LOAD.W	D2,#SETDOT	LIB	?DRRECT	LIB	?COLORPUSH	PUSHM.L	D3,D4	CALL	HSVCGET		; D3,D4,D5 <-- couleur	LIB	?COLORSA	POPM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	LIB	?COLORPOP	SWAP.W	D3	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#3	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A3,#R16"00$	TEST.W	D1	JUMP',EQ TEXT$	LOAD.L	A3,#R16"01$TEXT$:	LIB	?AFTEXTEXIT$:	POPM.L	D2..D5,A3	RET00$:	.ASCIZ	"Original"01$:	.ASCIZ	"Modifi"	.EVEN;--------\\; HSVCPUT >;========/; Donne les trois couleurs aux trois ascenseurs.; in	D3.W	rouge;	D4.W	vert;	D5.W	bleu; out	-; mod	D7.WHSVCPUT:	PUSHM.L	D3..D5	SR.W	D3,#8	SR.W	D4,#8	SR.W	D5,#8	CALL	CONVRGBHSV	LOAD.W	(A6)+OSCVAR+(LSCVAR*0)+OSCPOSV,D3	LOAD.W	(A6)+OSCVAR+(LSCVAR*1)+OSCPOSV,D4	LOAD.W	(A6)+OSCVAR+(LSCVAR*2)+OSCPOSV,D5	POPM.L	D3..D5	RET;--------\\; HSVCGET >;========/; Prend les trois couleurs des trois ascenseurs.; in	-; out	D3.W	rouge;	D4.W	vert;	D5.W	bleu; mod	D3.L, D4.L, D5.L, D7.WHSVCGET:	LOAD.W	D3,(A6)+OSCVAR+(LSCVAR*0)+OSCPOSV	LOAD.W	D4,(A6)+OSCVAR+(LSCVAR*1)+OSCPOSV	LOAD.W	D5,(A6)+OSCVAR+(LSCVAR*2)+OSCPOSV	CALL	CONVHSVRGB	SL.W	D3,#8	SL.W	D4,#8	SL.W	D5,#8	RET;-----------\\; CONVRGBHSV >;-----------/; Conversion RGB --> HSV.; in	D3.W	R (rouge)      [0..255];	D4.W	G (vert)       [0..255];	D5.W	B (bleu)       [0..255]; out	D3.W	H (teinte)     [0..359];	D4.W	S (saturation) [0..255];	D5.W	V (intensit)  [0..255]; mod	D3.L, D4.L, D5.L	.PC	PCVAR	.LOC	0OCRHRC:	.BLKB	2		; distance  rougeOCRHGC:	.BLKB	2		; distance  vertOCRHBC:	.BLKB	2		; distance  bleuLCRH:	.PC	PCCODECONVRGBHSV:	PUSHM.L	D0,D1,D2,D6,D7	LOAD.L	SP,#(SP)-LCRH	; SP <-- ^variables locales	LOAD.W	D6,D3		; D6 <-- MIN(R,G,B)	COMP.W	D6,D4	JUMP',LS MIN1$	LOAD.W	D6,D4MIN1$:	COMP.W	D6,D5	JUMP',LS MIN2$	LOAD.W	D6,D5MIN2$:	LOAD.W	D7,D3		; D7 <-- MAX(R,G,B)	COMP.W	D7,D4	JUMP',HS MAX1$	LOAD.W	D7,D4MAX1$:	COMP.W	D7,D5	JUMP',HS MAX2$	LOAD.W	D7,D5MAX2$:	LOAD.W	D2,D7	SUB.W	D2,D6		; D2 <-- MAX-MIN	CLR.W	D1		; D1 <-- saturation	TEST.W	D7	JUMP',EQ S2$	CLR.L	D1	LOAD.W	D1,D2		; D1 <-- MAX-MIN	MUL.WA	D1,#255	DIV.WA	D1,D7		; D1 <-- (MAX-MIN)/MAXS2$:	CLR.W	D0	TEST.W	D1	JUMP,EQ H6$	CLR.L	D0	LOAD.W	D0,D7	SUB.W	D0,D3	MUL.WA	D0,#255	DIV.WA	D0,D2		; D0 <-- distance  rouge	LOAD.W	(SP)+OCRHRC,D0	CLR.L	D0	LOAD.W	D0,D7	SUB.W	D0,D4	MUL.WA	D0,#255	DIV.WA	D0,D2		; D0 <-- distance  vert	LOAD.W	(SP)+OCRHGC,D0	CLR.L	D0	LOAD.W	D0,D7	SUB.W	D0,D5	MUL.WA	D0,#255	DIV.WA	D0,D2		; D0 <-- distance  bleu	LOAD.W	(SP)+OCRHBC,D0	COMP.W	D3,D7	JUMP',NE H2$	LOAD.W	D0,(SP)+OCRHBC	SUB.W	D0,(SP)+OCRHGC	; D0 <-- entre jaune et magenta	JUMP'	H5$H2$:	COMP.W	D4,D7	JUMP',NE H3$	LOAD.W	D0,(SP)+OCRHRC	ADD.W	D0,#256*2	SUB.W	D0,(SP)+OCRHBC	; D0 <-- entre cyan et jaune	JUMP'	H5$H3$:	LOAD.W	D0,(SP)+OCRHGC	ADD.W	D0,#256*4	SUB.W	D0,(SP)+OCRHRC	; D0 <-- entre magenta et cyanH5$:	MUL.WA	D0,#60	ADD.L	D0,#255/2	DIV.WA	D0,#255	JUMP',NC H6$	ADD.W	D0,#360H6$:	LOAD.W	D5,D7		; D5 <-- MAX	LOAD.W	D3,D0	LOAD.W	D4,D1	LOAD.L	SP,#(SP)+LCRH	; ajuste le stack	POPM.L	D0,D1,D2,D6,D7	RET;-----------\\; CONVHSVRGB >;-----------/; Conversion HSV --> RGB.; in	D3.W	H (teinte)     [0..359];	D4.W	S (saturation) [0..255];	D5.W	V (intensit)  [0..255]; out	D3.W	R (rouge)      [0..255];	D4.W	G (vert)       [0..255];	D5.W	B (bleu)       [0..255]; mod	D3.L, D4.L, D5.L	.PC	PCVAR	.LOC	0OCHRP:	.BLKB	2		; OCHRQ:	.BLKB	2		; OCHRT:	.BLKB	2		; LCHR:	.PC	PCCODECONVHSVRGB:	PUSHM.L	D0,D1,D2,D6,D7	LOAD.L	SP,#(SP)-LCHR	; SP <-- ^variables locales	TEST.W	D4		; saturation nulle ?	JUMP',NE S1$		; non => S1$				; oui => gris	LOAD.W	D3,D5	LOAD.W	D4,D5;	LOAD.W	D5,D5	JUMP	EXIT$S1$:	COMP.W	D3,#360	JUMP',LO H1$	CLR.W	D3H1$:	AND.L	D3,#H'FFFF	DIV.WU	D3,#60	LOAD.W	D2,D3		; D2 <-- 0..5	SWAP.W	D3	MUL.WA	D3,#256	DIV.WA	D3,#60		; D3 <-- 0..255	LOAD.W	D0,D4	SUB.W	D0,#255	NEG.W	D0	MUL.WA	D0,D5		; D0 <-- (255-S)*V	ADD.L	D0,#255/2	DIV.WA	D0,#255	LOAD.W	(SP)+OCHRP,D0	LOAD.W	D0,D3	MUL.WA	D0,D4	ADD.L	D0,#255/2	DIV.WA	D0,#255	SUB.W	D0,#255	NEG.W	D0	MUL.WA	D0,D5		; D0 <-- (255-(S*F))*V	ADD.L	D0,#255/2	DIV.WA	D0,#255	LOAD.W	(SP)+OCHRQ,D0	LOAD.W	D0,#255	SUB.W	D0,D3	MUL.WA	D0,D4	ADD.L	D0,#255/2	DIV.WA	D0,#255	SUB.W	D0,#255	NEG.W	D0	MUL.WA	D0,D5		; D0 <-- (255-(S*(255-F)))*V	ADD.L	D0,#255/2	DIV.WA	D0,#255	LOAD.W	(SP)+OCHRT,D0	DEC.W	D2	JUMP',NS C0$	DEC.W	D2	JUMP',NS C1$	DEC.W	D2	JUMP',NS C2$	DEC.W	D2	JUMP',NS C3$	DEC.W	D2	JUMP',NS C4$C5$:	LOAD.W	D3,D5	LOAD.W	D4,(SP)+OCHRP	LOAD.W	D5,(SP)+OCHRQ	JUMP'	EXIT$C4$:	LOAD.W	D3,(SP)+OCHRT	LOAD.W	D4,(SP)+OCHRP;	LOAD.W	D5,D5	JUMP'	EXIT$C3$:	LOAD.W	D3,(SP)+OCHRP	LOAD.W	D4,(SP)+OCHRQ;	LOAD.W	D5,D5	JUMP'	EXIT$C2$:	LOAD.W	D3,(SP)+OCHRP	LOAD.W	D4,D5	LOAD.W	D5,(SP)+OCHRT	JUMP'	EXIT$C1$:	LOAD.W	D3,(SP)+OCHRQ	LOAD.W	D4,D5	LOAD.W	D5,(SP)+OCHRP	JUMP'	EXIT$C0$:	LOAD.W	D3,D5	LOAD.W	D4,(SP)+OCHRT	LOAD.W	D5,(SP)+OCHRP;	JUMP'	EXIT$EXIT$:	LOAD.L	SP,#(SP)+LCHR	; ajuste le stack	POPM.L	D0,D1,D2,D6,D7	RET;---------\\; HSVDRAWS >;=========/; Dessine les trois ascenseurs.; in	-; out	-; mod	D7.WHSVDRAWS:	PUSH.L	D1	CLR.W	D1LOOP$:	CALL	HSVDRAW	INC.W	D1	COMP.W	D1,#3	JUMP,LO LOOP$	POP.L	D1	RET;--------\\; HSVDRAW >;--------/; Dessine l'un des trois ascenseur.; in	D1.W	numro de l'ascenseur (0..2); out	-; mod	D7.WHSVDRAW:	PUSHM.L	D3,D4,A3..A5	CALL	HSVOPEN		; ascenseur: met les couleurs spciales	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D4,D1	MUL.WU	D4,#LSCVAR	ADD.L	A5,D4	LOAD.W	(A5)+OSCDEBO,#30	CLR.W	D4	TEST.W	D1	JUMP',EQ POSX$	LOAD.W	D4,#56	COMP.W	D1,#1	JUMP',EQ POSX$	LOAD.W	D4,#96POSX$:	ADD.W	D4,(A6)+OCURPX	ADD.W	D4,#92	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	(A5)+OSCHTR,#194	SCROLL_	DRAW	LOAD.L	A3,#R16"TEXTH$	LOAD.L	A4,#R16"HELPH$	TEST.W	D1	JUMP',EQ SCALE$	LOAD.L	A3,#R16"TEXTS$	LOAD.L	A4,#R16"HELPS$	COMP.W	D1,#1	JUMP',EQ SCALE$	LOAD.L	A3,#R16"TEXTV$	LOAD.L	A4,#R16"HELPV$SCALE$:	LOAD.W	D3,#6		; D3 <-- nb de divisions	LOAD.W	D4,#8		; D4 <-- lg divisions	SCROLL_	SCALE	CALL	HSVCLOSE	; ascenseur: remet les couleurs normales	LOAD.W	D3,(A5)+OSCDEBO	SUB.W	D3,#8	SWAP.W	D3	LOAD.W	D3,(A5)+OSCDEBL	SUB.W	D3,#8+5	LIB	?SETCURS	LOAD.L	A3,A4	LIB	?AFTEXT	POPM.L	D3,D4,A3..A5	RETTEXTH$:	.ASCIZ	"Rou"	.ASCIZ	"Jau"	.ASCIZ	"Ver"	.ASCIZ	"Cya"	.ASCIZ	"Ble"	.ASCIZ	"Mag"	.ASCIZ	"Rou"TEXTS$:	.ASCIZ	"B"	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	"T"TEXTV$:	.ASCIZ	"N"	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	"T"HELPH$:	.ASCIZ	"Teinte"HELPS$:	.ASCIZ	" Sat."HELPV$:	.ASCIZ	" Int."	.EVEN;-----------\\; HSVUPDATES >;===========/; Met  jour les trois ascenseurs.; in	-; out	-; mod	D7.WHSVUPDATES:	PUSHM.L	D1	CLR.W	D1LOOP$:	CALL	HSVUPDATE	; met  jour un ascenseur	INC.W	D1	COMP.W	D1,#3	JUMP,LO LOOP$	POPM.L	D1	RET;----------\\; HSVUPDATE >;----------/; Met  jour un ascenseur.; in	D1.W	numro de l'ascenseur (0..2); out	-; mod	D7.WHSVUPDATE:	PUSHM.L	D4,A5	CALL	HSVOPEN		; ascenseur: met les couleurs spciales	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D4,D1	MUL.WU	D4,#LSCVAR	ADD.L	A5,D4	LOAD.W	(A5)+OSCHTV,#360	LOAD.W	(A5)+OSCINC,#360/60	TEST.W	D1	JUMP',EQ UPD$	LOAD.W	(A5)+OSCHTV,#256	LOAD.W	(A5)+OSCINC,#256/32UPD$:	SET.B	(A5)+OSCMARK	SCROLL_	UPDATE	CALL	HSVCLOSE	; ascenseur: remet les couleurs normales	POPM.L	D4,A5	RET;---------\\; HSVMOVES >;=========/; Dplace l'un des trois ascenseurs.; in	D4.L	position de la souris;	A1.L	^routine mj.; out	D7.W	ok/erreur; mod	D7.WHSVMOVES:	PUSH.L	D1	CLR.W	D1LOOP$:	CALL	HSVMOVE		; dplace un ascenseur ?	JUMP',EQ EXIT$	INC.W	D1	COMP.W	D1,#3	JUMP,LO LOOP$EXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;--------\\; HSVMOVE >;--------/; Dplace l'un des trois ascenseur.; in	D1.W	numro de l'ascenseur (0..2);	A1.L	^routine mj.;	D4.L	position de la souris; out	D7.W	ok/erreur; mod	D7.WHSVMOVE:	PUSHM.L	D2,D3,D4,D5,A5	CALL	HSVOPEN		; ascenseur: met les couleurs spciales	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D3,D1	MUL.WU	D3,#LSCVAR	ADD.L	A5,D3	SCROLL_	MOVE	JUMP,NE EXIT$	LOAD.W	D2,#-10	COMP.W	D4,#SCROLLFUP	JUMP',EQ INIT$	NEG.W	D2	COMP.W	D4,#SCROLLFDOWN	JUMP,NE OK$INIT$:	SCROLL_	PRESSLOOP$:	LIB	?IFCAR		; vnement ?	JUMP',NE MOVE$	COMP.W	D3,#KEYMGR	JUMP',EQ CLOSE$	COMP.W	D3,#KEYMMR	JUMP',EQ CLOSE$	COMP.W	D3,#KEYMDR	JUMP',EQ CLOSE$MOVE$:	LOAD.W	D5,(A5)+OSCPOSV	ADD.W	D5,D2	JUMP',NC MIN$	CLR.W	D5MIN$:	COMP.W	D5,(A5)+OSCHTV	JUMP',LO MAX$	LOAD.W	D5,(A5)+OSCHTV	DEC.W	D5MAX$:	LOAD.W	(A5)+OSCPOSV,D5	SCROLL_	UPDATE	CALL	(A1)		; mj. qq chose	PUSH.W	D4	LOAD.W	D4,#50/10	NTREL	?DELMS		; attend un poil ...	POP.W	D4	JUMP	LOOP$CLOSE$:	SCROLL_	PRESSOK$:	CALL	(A1)		; mj. qq chose	CLR.W	D7EXIT$:	CALL	HSVCLOSE	; ascenseur: remet les couleurs normales	POPM.L	D2,D3,D4,D5,A5	TEST.W	D7	RET;--------\\; HSVOPEN >;--------/; Ascenseur: met les couleurs spciales.; in	D1.W	numro de l'ascenseur (0..2); out	-; mod	D7.WHSVOPEN:	RET;---------\\; HSVCLOSE >;---------/; Ascenseur: remet les couleurs normales.; in	-; out	-; mod	-HSVCLOSE:	RET	.END