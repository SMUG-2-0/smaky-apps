	.CHAP	DISHEAD	.LOC	0START:	.IF	SM8	.16	0,D0BASE		; [*] principale	.16	1,D1BASE		; [1] grande	.16	2,D2BASE		; [1] petite	.16	3,D3BASE		; [1] petite	.16	4,D4BASE		; [1] petite	.16	7,D7BASE		; [*] soft-keys	.16	8,D8BASE		; [*] C.L.E.	.16	9,D9BASE		; [*] clock	.16	11,D11BASE		; [2] grande	.16	12,D12BASE		; [2] petite	.16	13,D13BASE		; [2] petite	.16	14,D14BASE		; [2] petite	.ENDIF	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300;	.IF	.NOT.COSTRONIC		; JMP	.16	0,D0BASE		; [*] principale	.16	1,D1BASE		; [1] grande	.16	2,D2BASE		; [2] grande	.16	3,D3BASE		; [3] grande	.16	4,D4BASE		; [4] grande	.16	7,D7BASE		; [*] soft-keys	.16	8,D8BASE		; [*] C.L.E.	.16	9,D9BASE		; [*] clock	.16	10,D10BASE		; [1] petite	.16	11,D11BASE		; [1] petite	.16	12,D12BASE		; [2] petite	.16	13,D13BASE		; [2] petite	.16	14,D14BASE		; [3] petite	.16	15,D15BASE		; [3] petite	.16	16,D16BASE		; [4] petite	.16	17,D17BASE		; [4] petite;	.ELSE				; JMP;	.16	0,D0BASE		; [*] principale;	.16	1,D1BASE		; [1] grande;	.16	2,D2BASE		; [2] grande;	.16	7,D7BASE		; [*] soft-keys;	.16	8,D8BASE		; [*] C.L.E.;	.16	9,D9BASE		; [*] clock;	.16	10,D10BASE		; [1] petite;	.16	11,D11BASE		; [1] petite;	.16	12,D12BASE		; [2] petite;	.16	13,D13BASE		; [2] petite;	.ENDIF				; JMP	.ENDIF	.IF	SM324BIG	.IF	.NOT.COSTRONIC	.16	0,D0BASE		; [*] principale	.16	1,D1BASE		; [1] grande	.16	2,D2BASE		; [2] demi ou grande	.16	3,D3BASE		; [2] demi ou rien	.16	4,D4BASE		; [3] demi ou grande	.16	5,D5BASE		; [3] demi ou rien	.16	6,D6BASE		; [4] compatible SMAKY-100	.16	7,D7BASE		; [*] soft-keys	.16	8,D8BASE		; [*] C.L.E.	.16	9,D9BASE		; [*] clock	.16	10,D10BASE		; [4] petite	.16	11,D11BASE		; [4] petite	.16	12,D12BASE		; [4] petite	.16	13,D13BASE		; [4] petite	.16	14,D14BASE		; [4] petite	.16	15,D15BASE		; [4] petite	.ELSE	.16	0,D0BASE		; [*] principale	.16	1,D1BASE		; [1] grande	.16	2,D2BASE		; [2] demi ou grande	.16	3,D3BASE		; [2] demi;	.W	4	D4BASE		; [3] demi ou grande;	.W	5	D5BASE		; [3] demi;	.W	6	D6BASE		; [4] compatible SMAKY-100	.16	7,D7BASE		; [*] soft-keys	.16	8,D8BASE		; [*] C.L.E.	.16	9,D9BASE		; [*] clock;	.W	10	D10BASE		; [4] petite;	.W	11	D11BASE		; [4] petite;	.W	12	D12BASE		; [4] petite;	.W	13	D13BASE		; [4] petite;	.W	14	D14BASE		; [4] petite;	.W	15	D15BASE		; [4] petite	.ENDIF	.ENDIF	.IF	COLOR	.16	20,D20BASE		; [*] principale couleur	.16	21,D21BASE		; [C] grande	.ENDIF	.16	2**7; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_0	(bitmap principal); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=D0ID:	.16	-1			; DOOPEN-D0BASE	.16	DOCOMMAND-D0BASE	.16	DORSTATUS-D0BASE	.16	DOREAD-D0BASE	.16	DOWRITE-D0BASE	.16	-1			; DOCLOSE-D0BASE	.16	-1			; STOPTR	.16	-1			; STARTR	.16	-1			; AVORTTR	.16	-1			; DOAUX1-D0BASE	.16	-1			; DOAUX2-D0BASE	.16	D0RESET-D0BASE	.16	DOKILL-D0BASE	.16	-1			; DOSTRT-D0BASE	.16	-1			; DOTSTRT-D0BASE	.16	-1			; DOSTART-D0BASED0NAB:	.ASCII	"DIS_0"			; Nom driverD0NAF:	.FILL.8	LGDNAM-(D0NAF-D0NAB),0	.8	NOBASE+0		; Numro driver	.8	TYPDIS			; Type: Bit-map complet	.8	0,0			; Rvision - version	.16	0			; Variante	.8	0			; Attribut 1	.8	2**BDRDOK.OR.2**BDWROK	; Attribut 0	.FILL.8	LGDDESC-(APC-D0ID),0	; Le reste.D0BASE:	.IF	SM100.OR.SM324LIT.OR.SM196	.16	0,0				; ODFY,X	.16	400,1024			; ODFDY,X	.8	"1","L"				; ODFCAD	.ENDIF	SM100.OR.SM324LIT.OR.SM196	.IF	SM300	.16	0,0				; ODFY,X	.16	480,1024			; ODFDY,X	.8	"1","L"				; ODFCAD	.ENDIF	SM300	.IF	SM324BIG	.16	0,0				; ODFY,X	.16	PVIEWY,PVIEWX			; ODFDY,X	.8	"1","L"				; ODFCAD	.ENDIF	.IF	SM8	.16	LARGCY*0,LARGCX*0		; ODFY,X	.16	LARGCY*64,LARGCX*127		; ODFDY,X	.8	"1","L"				; ODFCAD	.ENDIF	.8	0				; ODFNOW	.8	2**BFEFLI			; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_1	(grande fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=D1ID:	.16	-1			; DOOPEN-D1BASE	.16	DOCOMMAND-D1BASE	.16	DORSTATUS-D1BASE	.16	DOREAD-D1BASE	.16	DOWRITE-D1BASE	.16	-1			; DOCLOSE-D1BASE	.16	-1			; STOPTR	.16	-1			; STARTR	.16	-1			; AVORTTR	.16	-1			; DOAUX1-D1BASE	.16	-1			; DOAUX2-D1BASE	.16	DORESET-D1BASE	.16	DOKILL-D1BASE	.16	-1			; DOSTRT-D1BASE	.16	-1			; DOTSTRT-D1BASE	.16	-1			; DOSTART-D1BASED1NAB:	.ASCII	"DIS_1"			; Nom driverD1NAF:	.FILL.8	LGDNAM-(D1NAF-D1NAB),0	.8	NOBASE+1		; Numro driver	.8	TYPWDO			; Type: Fentre	.8	0,0			; Rvision - version	.16	0			; Variante	.8	0			; Attribut 1	.8	2**BDRDOK.OR.2**BDWROK	; Attribut 0	.FILL.8	LGDDESC-(APC-D1ID),0	; Le reste.D1BASE:	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.16	LARGCY*2,0			; ODFY,X	.16	LARGCY*(LVIEWY-6),PVIEWX	; ODFDY,X	.8	"1","L"				; ODFCAD	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM324BIG	.16	PBIGY,0				; ODFY,X	.16	DBIGY,PVIEWX			; ODFDY,X	.8	"1","L"				; ODFCAD	.ENDIF	.IF	SM8	.16	LARGCY*2,0			; ODFY,X	.16	512-(LARGCY*6),800-8		; ODFDY,X	.8	"1","L"				; ODFCAD	.ENDIF	.8	1				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_2	(grande fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=D2ID:	.16	-1			; DOOPEN-D2BASE	.16	DOCOMMAND-D2BASE	.16	DORSTATUS-D2BASE	.16	DOREAD-D2BASE	.16	DOWRITE-D2BASE	.16	-1			; DOCLOSE-D2BASE	.16	-1			; STOPTR	.16	-1			; STARTR	.16	-1			; AVORTTR	.16	-1			; DOAUX1-D2BASE	.16	-1			; DOAUX2-D2BASE	.16	DORESET-D2BASE	.16	DOKILL-D2BASE	.16	-1			; DOSTRT-D2BASE	.16	-1			; DOTSTRT-D2BASE	.16	-1			; DOSTART-D2BASED2NAB:	.ASCII	"DIS_2"			; Nom driverD2NAF:	.FILL.8	LGDNAM-(D2NAF-D2NAB),0	.8	NOBASE+2		; Numro driver	.8	TYPWDO			; Type: Fentre	.8	0,0			; Rvision - version	.16	0			; Variante	.8	0			; Attribut 1	.8	2**BDRDOK.OR.2**BDWROK	; Attribut 0	.FILL.8	LGDDESC-(APC-D2ID),0	; Le reste.D2BASE:	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.16	LARGCY*2,0			; ODFY,X	.16	LARGCY*(LVIEWY-6),PVIEWX	; ODFDY,X	.8	"2","L"				; ODFCAD	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM324BIG	.16	PBIGY,0				; ODFY,X	.16	DBIGY,PVIEWX			; ODFDY,X	.8	"2","L"				; ODFCAD	.ENDIF	.IF	SM8	.16	LARGCY*2,800			; ODFY,X	.16	160,1024-800			; ODFDY,X	.8	"1","R"				; ODFCAD	.ENDIF	.8	2				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI.OR.2**BFTRUNC; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_3	(grande fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=D3ID:	.16	-1			; DOOPEN-D3BASE	.16	DOCOMMAND-D3BASE	.16	DORSTATUS-D3BASE	.16	DOREAD-D3BASE	.16	DOWRITE-D3BASE	.16	-1			; DOCLOSE-D3BASE	.16	-1			; STOPTR	.16	-1			; STARTR	.16	-1			; AVORTTR	.16	-1			; DOAUX1-D3BASE	.16	-1			; DOAUX2-D3BASE	.16	DORESET-D3BASE	.16	DOKILL-D3BASE	.16	-1			; DOSTRT-D3BASE	.16	-1			; DOTSTRT-D3BASE	.16	-1			; DOSTART-D3BASED3NAB:	.ASCII	"DIS_3"			; Nom driverD3NAF:	.FILL.8	LGDNAM-(D3NAF-D3NAB),0	.8	NOBASE+3		; Numro driver	.8	TYPWDO			; Type: Fentre	.8	0,0			; Rvision - version	.16	0			; Variante	.8	0			; Attribut 1	.8	2**BDRDOK.OR.2**BDWROK	; Attribut 0	.FILL.8	LGDDESC-(APC-D3ID),0	; Le reste.D3BASE:	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.16	LARGCY*2,0			; ODFY,X	.16	LARGCY*(LVIEWY-6),PVIEWX	; ODFDY,X	.8	"3","L"				; ODFCAD	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM324BIG	.16	PBIGY+((DBIGY-10)/2)+10,0	; ODFY,X	.16	(DBIGY-10)/2,PVIEWX		; ODFDY,X	.8	"2","L"				; ODFCAD	.ENDIF	.IF	SM8	.16	LARGCY*2+160+LARGCY,800		; ODFY,X	.16	112,1024-800			; ODFDY,X	.8	"1","R"				; ODFCAD	.ENDIF	.8	3				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_4	(grande fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=D4ID:	.16	-1			; DOOPEN-D4BASE	.16	DOCOMMAND-D4BASE	.16	DORSTATUS-D4BASE	.16	DOREAD-D4BASE	.16	DOWRITE-D4BASE	.16	-1			; DOCLOSE-D4BASE	.16	-1			; STOPTR	.16	-1			; STARTR	.16	-1			; AVORTTR	.16	-1			; DOAUX1-D4BASE	.16	-1			; DOAUX2-D4BASE	.16	DORESET-D4BASE	.16	DOKILL-D4BASE	.16	-1			; DOSTRT-D4BASE	.16	-1			; DOTSTRT-D4BASE	.16	-1			; DOSTART-D4BASED4NAB:	.ASCII	"DIS_4"			; Nom driverD4NAF:	.FILL.8	LGDNAM-(D4NAF-D4NAB),0	.8	NOBASE+4		; Numro driver	.8	TYPWDO			; Type: Fentre	.8	0,0			; Rvision - version	.16	0			; Variante	.8	0			; Attribut 1	.8	2**BDRDOK.OR.2**BDWROK	; Attribut 0	.FILL.8	LGDDESC-(APC-D4ID),0	; Le reste.D4BASE:	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.16	LARGCY*2,0			; ODFY,X	.16	LARGCY*(LVIEWY-6),PVIEWX	; ODFDY,X	.8	"4","L"				; ODFCAD	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM324BIG	.16	PBIGY,0				; ODFY,X	.16	DBIGY,PVIEWX			; ODFDY,X	.8	"3","L"				; ODFCAD	.ENDIF	.IF	SM8	.16	LARGCY*2+160+LARGCY+112+LARGCY,800 ; ODFY,X	.16	112,1024-800			; ODFDY,X	.8	"1","R"				; ODFCAD	.ENDIF	.8	4				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN	.IF	SM324BIG; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_5	(grande fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=D5ID:	.16	-1			; DOOPEN-D5BASE	.16	DOCOMMAND-D5BASE	.16	DORSTATUS-D5BASE	.16	DOREAD-D5BASE	.16	DOWRITE-D5BASE	.16	-1			; DOCLOSE-D5BASE	.16	-1			; STOPTR	.16	-1			; STARTR	.16	-1			; AVORTTR	.16	-1			; DOAUX1-D5BASE	.16	-1			; DOAUX2-D5BASE	.16	DORESET-D5BASE	.16	DOKILL-D5BASE	.16	-1			; DOSTRT-D5BASE	.16	-1			; DOTSTRT-D5BASE	.16	-1			; DOSTART-D5BASED5NAB:	.ASCII	"DIS_5"			; Nom driverD5NAF:	.FILL.8	LGDNAM-(D5NAF-D5NAB),0	.8	NOBASE+5		; Numro driver	.8	TYPWDO			; Type: Fentre	.8	0,0			; Rvision - version	.16	0			; Variante	.8	0			; Attribut 1	.8	2**BDRDOK.OR.2**BDWROK	; Attribut 0	.FILL.8	LGDDESC-(APC-D5ID),0	; Le reste.D5BASE:	.16	PBIGY+((DBIGY-10)/2)+10,0	; ODFY,X	.16	(DBIGY-10)/2,PVIEWX		; ODFDY,X	.8	"3","L"				; ODFCAD	.8	5				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN	.ENDIF	.IF	SM324BIG; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_6	(fentre SMAKY100); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=D6ID:	.16	-1			; DOOPEN-D6BASE	.16	DOCOMMAND-D6BASE	.16	DORSTATUS-D6BASE	.16	DOREAD-D6BASE	.16	DOWRITE-D6BASE	.16	-1			; DOCLOSE-D6BASE	.16	-1			; STOPTR	.16	-1			; STARTR	.16	-1			; AVORTTR	.16	-1			; DOAUX1-D6BASE	.16	-1			; DOAUX2-D6BASE	.16	DORESET-D6BASE	.16	DOKILL-D6BASE	.16	-1			; DOSTRT-D6BASE	.16	-1			; DOTSTRT-D6BASE	.16	-1			; DOSTART-D6BASED6NAB:	.ASCII	"DIS_6"			; Nom driverD6NAF:	.FILL.8	LGDNAM-(D6NAF-D6NAB),0	.8	NOBASE+6		; Numro driver	.8	TYPWDO			; Type: Fentre	.8	0,0			; Rvision - version	.16	0			; Variante	.8	0			; Attribut 1	.8	2**BDRDOK.OR.2**BDWROK	; Attribut 0	.FILL.8	LGDDESC-(APC-D6ID),0	; Le reste.D6BASE:;;?	.W	PBIGY,0				; ODFY,X;;?	.W	DBIGY-((8+DLITY)*3)-8,PVIEWX	; ODFDY,X	.16	PBIGY+8,(PVIEWX-640)/2		; ODFY,X	.16	340,640				; ODFDY,X	.8	"4","L"				; ODFCAD	.8	6				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN	.ENDIF; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_7	(pour soft-keys); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=D7ID:	.16	-1			; DOOPEN-D7BASE	.16	DOCOMMAND-D7BASE	.16	DORSTATUS-D7BASE	.16	DOREAD-D7BASE	.16	DOWRITE-D7BASE	.16	-1			; DOCLOSE-D7BASE	.16	-1			; STOPTR	.16	-1			; STARTR	.16	-1			; AVORTTR	.16	-1			; DOAUX1-D7BASE	.16	-1			; DOAUX2-D7BASE	.16	DORESET-D7BASE	.16	DOKILL-D7BASE	.16	-1			; DOSTRT-D7BASE	.16	-1			; DOTSTRT-D7BASE	.16	-1			; DOSTART-D7BASED7NAB:	.ASCII	"DIS_7"			; Nom driverD7NAF:	.FILL.8	LGDNAM-(D7NAF-D7NAB),0	.8	NOBASE+7		; Numro driver	.8	TYPWDO			; Type: Fentre	.8	0,0			; Rvision - version	.16	0			; Variante	.8	0			; Attribut 1	.8	2**