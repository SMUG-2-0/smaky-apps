	.CHAP	DISHARD;--------\; CLRCURS >;========/; in	A2.L	^description de la fentre; out	-; mod	-CLRCURS:	PUSH.16	D0	TEST.8	{A2}+ODFMOD:#BFNOCU	JUMP,NE	 R8^L90$	TCLR.8	{A2}+ODFFLG:#BFCURS ; curseur dj enlev ?	JUMP,EQ	 R8^L90$	; oui => 90$				; non =>	MOVE.16	{A2}+ODFC1X,D0	ADD.16	{A2}+ODFC2X,D0	; D0 <-- largeur curseur	CALL	INVCURSL90$:	POP.16	D0	RET;--------\; SETCURS >;========/; in	A2.L	^description de la fentre; out	-; mod	-SETCURS:	PUSHM.32 D0|A0	TEST.8	{A2}+ODFMOD:#BFNOCU	JUMP,NE	 R8^L50$	TSET.8	{A2}+ODFFLG:#BFCURS ; curseur dj l ?	JUMP,NE	 R8^L50$	; oui => 50$				; non =>	MOVE.16	{A2}+ODFC1X,D0	ADD.16	{A2}+ODFC2X,D0	; D0 <-- largeur curseur	CALL	INVCURSL50$:	MOVE.32	{A6}+OLSTPD,A0	; A0 <-- ^descripteur o est la souris	TEST.8	{A0}+ODFMFL:#BFMCLR	JUMP,BC	 R8^L90$	CALL	IMCURS		; remet le curseur sourisL90$:	POPM.32	D0|A0	RET;---------\; ITCLUTIN >;=========/; Test si un caractre interrompt, mme partiellement, le; lutin de la souris. Si oui, enlve le lutin de la souris.; in	A2.L	^description de la fentre; out	-; mod	D7.WITCLUTIN:	PUSHM.32 D2|D3|D4|A0	MOVE.32	{A6}+OLSTPD,A0	; A0 <-- ^descripteur o est la souris	TEST.8	{A0}+ODFMFL:#BFMCLR ; lutin dj enlev ?	JUMP,BS	 R8^L90$	; oui => 90$	MOVE.32	{A0}+ODFMPO,D4	; D4 <-- (Y;X) min	MOVE.32	{A2}+ODFWBY,D3	; D3 <-- (Y;X) fentre	ADD.16	{A2}+ODFPX,D3	; D3 <-- X curseur	MOVE.16	D3,D2	ADD.16	{A2}+ODFC2X,D3	COMP.16	D4,D3	JUMP,LO	 R8^L90$	ADD.16	{A0}+ODFMDI+2,D4 ; D4 <-- X max	MOVE.16	D2,D3	SUB.16	{A2}+ODFC1X,D3	COMP.16	D4,D3	JUMP,HS	 R8^L90$	SWAP.32	D4		; D4 <-- Y min	SWAP.32	D3		; D3 <-- Y fentre	ADD.16	{A2}+ODFPY,D3	; D3 <-- Y curseur	MOVE.16	D3,D2	ADD.16	{A2}+ODFC2Y,D3	COMP.16	D4,D3	JUMP,LO	 R8^L90$	ADD.16	{A0}+ODFMDI+0,D4 ; D4 <-- Y max	MOVE.16	D2,D3	SUB.16	{A2}+ODFC1Y,D3	COMP.16	D4,D3	JUMP,HS	 R8^L90$	CALL	CLRLUTIN	; enlve le lutin de la sourisL90$:	POPM.32	D2|D3|D4|A0	RET;---------\; ITLLUTIN >;=========/; Test si une ligne interrompt, mme partiellement, le; lutin de la souris. Si oui, enlve le lutin de la souris.; in	A2.L	^description de la fentre; out	-; mod	D7.WITLLUTIN:	PUSHM.32 D2|D3|D4|A0	MOVE.32	{A6}+OLSTPD,A0	; A0 <-- ^descripteur o est la souris	TEST.8	{A0}+ODFMFL:#BFMCLR ; lutin dj enlev ?	JUMP,BS	 R8^L90$	; oui => 90$	MOVE.16	{A0}+ODFMPO+0,D4 ; D4 <-- Y min	MOVE.16	{A2}+ODFWBY,D3	; D3 <-- Y fentre	ADD.16	{A2}+ODFPY,D3	; D3 <-- Y curseur	MOVE.16	D3,D2	ADD.16	{A2}+ODFC2Y,D3	COMP.16	D4,D3	JUMP,LO	 R8^L90$	ADD.16	{A0}+ODFMDI+0,D4 ; D4 <-- Y max	MOVE.16	D2,D3	SUB.16	{A2}+ODFC1Y,D3	COMP.16	D4,D3	JUMP,HS	 R8^L90$	CALL	CLRLUTIN	; enlve le lutin de la sourisL90$:	POPM.32	D2|D3|D4|A0	RET;---------\\; ITELUTIN >;=========/; Test si une ellipse graphique du type (y;x)/(ry;rx) interrompt,; mme partiellement, le lutin de la souris.; Si oui, enlve le lutin de la souris.; in	A2.L	^description de la fentre;	D4.32	coordonne (y;x);	D3.32	rayons (ry;rx);	D1.8	mode (utile si pinceau, car plus large); out	-; mod	D7.WITELUTIN:	PUSHM.32 D3|D4	SUB.16	D3,D4		; D4 <-- met X  gauche	ASL.16	#1,D3		; D3 <-- rayon X *2	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,D4		; D4 <-- met Y en haut	ASL.16	#1,D3		; D3 <-- rayon Y *2	SWAP.32	D3	SWAP.32	D4	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	POPM.32	D3|D4	RET;---------\; ITGLUTIN >;=========/; Test si un objet graphique du type (y;x)/(dy;dx) interrompt,; mme partiellement, le lutin de la souris.; Si oui, enlve le lutin de la souris.; in	A2.L	^description de la fentre;	D4.32	coordonne (y;x);	D3.32	dimensions (dy;dx) positives ou ngatives;	D1.8	mode (utile si pinceau, car plus large); out	-; mod	D7.WITGLUTIN:	PUSHM.32 D2|D3|D4|A0	MOVE.32	{A6}+OLSTPD,A0	; A0 <-- ^descripteur o est la souris	TEST.8	{A0}+ODFMFL:#BFMCLR ; lutin dj enlev ?	JUMP,BS	 R8^L90$	; oui => 90$	TEST.16	D3		; dX positif ?	JUMP,NC	 R8^L20$	NEG.16	D3		; D3 <-- |dX|	SUB.16	D3,D4		; D4 <-- reculeL20$:	TEST.32	D1:#BPENDOT	; utilise le pinceau ?	JUMP,BC	 R8^L25$	; non => 25$	SUB.16	#8/2,D4	ADD.16	#8,D3L25$:	MOVE.32	{A0}+ODFMPO,D2	; D2 <-- min Y;X souris	ADD.16	{A2}+ODFWBX,D4	; D4 <-- min X graphique	ADD.16	D3,D4		; D4 <-- max X graphique	COMP.16	D2,D4	JUMP,LT	 R8^L90$	ADD.16	{A0}+ODFMDI+2,D2 ; D2 <-- max X souris	SUB.16	D3,D4		; D4 <-- min X graphique	COMP.16	D2,D4	JUMP,GE	 R8^L90$	SWAP.32	D2		; D2 <-- min Y souris	SWAP.32	D3		; D3 <-- dY graphique	SWAP.32	D4		; D4 <-- Y graphique	TEST.16	D3		; dY positif ?	JUMP,NC	 R8^L40$	NEG.16	D3		; D3 <-- |dY|	SUB.16	D3,D4		; D4 <-- reculeL40$:	TEST.32	D1:#BPENDOT	; utilise le pinceau ?	JUMP,BC	 R8^L45$	; non => 45$	SUB.16	#8/2,D4	ADD.16	#8,D3L45$:	ADD.16	{A2}+ODFWBY,D4	; D4 <-- min Y graphique	ADD.16	D3,D4		; D4 <-- max Y graphique	COMP.16	D2,D4	JUMP,LT	 R8^L90$	ADD.16	{A0}+ODFMDI+0,D2 ; D2 <-- max Y souris	SUB.16	D3,D4		; D4 <-- min Y graphique	COMP.16	D2,D4	JUMP,GE	 R8^L90$	CALL	CLRLUTIN	; enlve le lutin de la sourisL90$:	POPM.32	D2|D3|D4|A0	RET;---------\; CLRLUTIN >;=========/; Enlve le lutin (flche) de la souris.; in	A2.L	^descripteur fentre; out	-; mod	-CLRLUTIN:	PUSH.32	A0	MOVE.32	{A6}+OLSTPD,A0	; A0 <-- ^descripteur o est la souris	TEST.8	{A0}+ODFMFL:#BFMCLR	JUMP,BS	 R8^L10$	CALL	IMCURS		; enlve le curseur sourisL10$:	POP.32	A0	RET;--------\; IMCURS  >;--------/; Inverse le curseur de la souris plac dans la fentre; principale $DIS_0 pendant une opration (write) dans une; autre fentre.; Pour cela, il faut remplir les conditions suivantes:;   -	la fentre ne doit pas tre $DIS_0 ni $DIS_20;   -	le curseur souris doit tre dans la fentre concerne; in	A2.L	^descripteur fentre; out	-; mod	-IMCURS:	PUSHM.32 D0|D3|D4|D6|A0|A1|A2|A3|A4	TEST.8	{A2}+ODFNOW	; fentre $DIS_0 ?	JUMP,EQ L90$		; oui => 90$	.IF	COLOR	COMP.8	#NOWDOC,{A2}+ODFNOW ; fentre $DIS_20 ?	JUMP,EQ L90$		; oui => 90$	.ENDIF	COLOR				; non =>	MOVE.32	{A6}+OLSTPD,A1	; A1 <-- ^descripteur o est la souris	TEST.32	{A1}+ODFMDI	; lutin-souris existe ?	JUMP,EQ L90$		; non => 90$				; oui =>	CLR.16	D4	MOVE.8	{A2}+ODFCAD+0,D4	JUMP,EQ	 R8^L30$	SUB.8	#"1",D4		; D4 <-- 0..3	COMP.16	{A6}+ONOVBM,D4	; fentre dans bitmap visible ?	JUMP,NE L90$		; non => 90$L30$:	MOVE.32	{A1}+ODFMPO,D4	; D4 <-- coordonne (y;x)	MOVE.16	{A2}+ODFX,D3	; D3 <-- X minimum	ADD.16	{A1}+ODFMDI+2,D4 ; tient compte grandeur curseur	COMP.16	D3,D4	JUMP,LO	 R8^L90$	ADD.16	{A2}+ODFDX,D3	; D3 <-- X maximum	SUB.16	{A1}+ODFMDI+2,D4 ; tient compte grandeur curseur	COMP.16	D3,D4	JUMP,HS	 R8^L90$	SWAP.32	D4		; D4 <-- coordonne (x;y)	MOVE.16	{A2}+ODFY,D3	; D3 <-- Y minimum	ADD.16	{A1}+ODFMDI+0,D4 ; tient compte grandeur curseur	COMP.16	D3,D4	JUMP,LO	 R8^L90$	ADD.16	{A2}+ODFDY,D3	; D3 <-- Y maximum	SUB.16	{A1}+ODFMDI+0,D4 ; tient compte grandeur curseur	COMP.16	D3,D4	JUMP,HS	 R8^L90$	SWAP.32	D4		; D4 <-- coordonne (y;x)	TEST.8	{A2}+ODFFLG:#BFNCMO ; curseur souris permis ?	JUMP,NE	 R8^L90$	; non => 90$				; oui =>	MOVE.32	{A1}+ODFMPS,A4	; A4 <-- ^matrice "set"	MOVE.32	{A1}+ODFMPC,A3	; A3 <-- ^matrice "clear"	MOVE.32	{A1}+ODFMPO,D4	; D4 <-- coordonne (y;x)	MOVE.32	{A1}+ODFMDI,D3	; D3 <-- dimensions du lutin	CLR.16	D6		; D6 <-- numro du lutin	MOVE.16	#SPRITE_CLEAR,D0; D0 <-- enlve le lutin	TNOT.8	{A1}+ODFMFL:#BFMCLR	JUMP,BC	 R8^L70$	MOVE.16	#SPRITE_SET,D0	; D0 <-- remet le lutinL70$:	MOVE.32	A1,A2		; A2 <-- ^description $DIS_0 ou 20	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_SPRITE-GRA2_FIRST)),A0	CALL	{A0}		; met/enlve lutin souris	POP.32	A0L90$:	POPM.32	D0|D3|D4|D6|A0|A1|A2|A3|A4	RET;---------\; IMACURS0 >;---------/; Enlve le curseur de la souris plac dans la fentre; principale $DIS_0 pendant une opration (write) dans une; autre fentre, quelque soit sa position.; in	-; out	-; mod	-IMACURS0:	PUSHM.32 D0|D3|D4|D6|A0|A1|A2|A3|A4	MOVE.32	{A6}+OLSTPD,A1	; A1 <-- ^descripteur o est la souris	TSET.8	{A1}+ODFMFL:#BFMCLR	JUMP,BS	 R8^L90$	TEST.32	{A1}+ODFMDI	; lutin-souris existe ?	JUMP,EQ	 R8^L90$	; non => 90$				; oui =>	MOVE.32	{A1}+ODFMPS,A4	; A4 <-- ^matrice "set"	MOVE.32	{A1}+ODFMPC,A3	; A3 <-- ^matrice "clear"	MOVE.32	{A1}+ODFMPO,D4	; D4 <-- coordonne (y;x)	MOVE.32	{A1}+ODFMDI,D3	; D3 <-- dimensions du lutin	CLR.16	D6		; D6 <-- numro du lutin	MOVE.16	#SPRITE_CLOSE,D0; D0 <-- ferme le lutin	MOVE.32	A1,A2		; A2 <-- ^description $DIS_0 ou 20	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_SPRITE-GRA2_FIRST)),A0	CALL	{A0}		; ferme le lutin souris	POP.32	A0	CLR.32	{A1}+ODFMDIL90$:	POPM.32	D0|D3|D4|D6|A0|A1|A2|A3|A4	RET;---------\; IMACURS1 >;---------/; Remet le curseur de la souris plac dans la fentre; principale $DIS_0 pendant une opration (write) dans une; autre fentre, quelque soit sa position.; in	-; out	-; mod	-IMACURS1:	PUSH.32	A0	MOVE.32	{A6}+OLSTPD,A0	; A0 <-- ^descripteur o est la souris	TCLR.8	{A0}+ODFMFL:#BFMCLR	POP.32	A0	RET;--------\; INVPROC >;========/; Dessine un curseur en fonction de la largeur d'un caractre; donne dans le gnrateur.; in	D3.B	caractre;	A2.32	^description de la fentre; out	-; mod	-INVPROC:	PUSHM.32 D0|A1	CLR.16	D0	MOVE.8	D3,D0		; D0 <-- caractre	MOVE.32	{A2}+ODFPGC,A1	; A1 <-- ^dbut GENCAR	SUB.8	{A1}+OGCFCA,D0	; D0 <-- offset pour largeur	MOVE.32	#{A1}+OGCWID,A1	; A1 <-- ^largeurs	MOVE.8	{A1}+A16^{D0},D0; D0 <-- largeur	CALL	INVCURS		; met un curseur variable	POPM.32	D0|A1	RET;--------\; INVCURS >;========/; in	A2.L	^description de la fentre;	D0.16	largeur du curseur; out	-; mod	-INVCURS:	PUSHM.32 D1|D3|D4|A0|A4	TEST.8	{A2}+ODFNOW	; est-on dans $DIS_0 ?	JUMP,EQ L90$		; oui => 90$	CALL	ITCLUTIN	; enlve lutin souris si intersection	TEST.8	{A2}+ODFMOD:#BFPCUR ; petit curseur soulign ?	JUMP,NE	 R8^L50$	; oui => 50$				; non =>	MOVE.16	{A2}+ODFPY,D4	SUB.16	{A2}+ODFC1Y,D4	SWAP.32	D4	MOVE.16	{A2}+ODFPX,D4	SUB.16	{A2}+ODFC1X,D4	; D4 <-- coord. coin sup/gauche	MOVE.16	{A2}+ODFC1Y,D3	ADD.16	{A2}+ODFC2Y,D3	SWAP.32	D3	MOVE.16	D0,D3		; D3 <-- dimensions caractre	MOVE.8	#INVDOT,D1	; D1 <-- inverse le curseur	MOVE.32	#R16^L00$,A4	; A4 <-- ^trame pleine	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_TRAME-GRA2_FIRST)),A0	CALL	{A0}		; affiche le curseur invers	POP.32	A0	JUMP	R8^L90$L50$:				; inverse un curseur soulign:	MOVE.16	{A2}+ODFPY,D4	ADD.16	{A2}+ODFC2Y,D4	SUB.16	#2,D4	SWAP.32	D4	MOVE.16	{A2}+ODFPX,D4	SUB.16	{A2}+ODFC1X,D4	; D4 <-- coord. coin inf/gauche	MOVE.16	#2,D3	SWAP.32	D3	MOVE.16	D0,D3		; D3 <-- dimensions soulign	MOVE.8	#INVDOT,D1	; D1 <-- inverse le curseur	MOVE.32	#R16^L00$,A4	; A4 <-- ^trame pleine	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_TRAME-GRA2_FIRST)),A0	CALL	{A0}		; affiche le soulign invers	POP.32	A0L90$:	POPM.32	D1|D3|D4|A0|A4	RETL00$:	.8	2'11111111	; trame "pleine"	.8	2'11111111	.8	2'11111111	.8	2'11111111	.8	2'11111111	.8	2'11111111	.8	2'11111111	.8	2'11111111; Gestion de l'image alphanumrique d'une fentre; -----------------------------------------------;--------\; OPIMA?  >;========/; Vrifie s'il est permis d'utiliser l'image alphanumrique.; Pour cela, les trois conditions suivantes doivent tre; remplies:;  1)	Est-ce que l'image alpha existe ?;  2)	Est-ce que les caractres utiliss sont de la;	bonne grandeur ?;  3)	Est-ce qu'il s'agit de la bonne sous-fentre ?; in	A2.L	^description d'une fentre; out	NE	pas possible d'utiliser l'image;	EQ	ok; mod	-OPIMA?:	PUSHM.32 D4|A4	TEST.8	{A2}+ODFFLG:#BFIMAA ; image alphanum. existe ?	NOTZ	JUMP,NE	 R8^L90$	; non => retour NE	MOVE.32	{A2}+ODFPIM,A4	; A4 <-- ^base de l'image	MOVE.16	{A4}+OIMACX,D4	; D4 <-- largeur cars. ds image	COMP.16	{A2}+ODFCX,D4	; idem au gencar utilis ?	JUMP,NE	 R8^L90$	; non => 90$	MOVE.16	{A4}+OIMACY,D4	; D4 <-- hauteur cars. ds image	COMP.16	{A2}+ODFCY,D4	; idem au gencar utilis ?	JUMP,NE	 R8^L90$	; non => 90$	MOVE.16	{A4}+OIMASX,D4	COMP.16	{A2}+ODFFX,D4	; mme sous-fentre ?	JUMP,NE	 R8^L90$	; non => 90$	MOVE.16	{A4}+OIMASY,D4	COMP.16	{A2}+ODFFY,D4	JUMP,NE	 R8^L90$	MOVE.16	{A4}+OIMALX,D4	COMP.16	{A2}+ODFFDX,D4	JUMP,NE	 R8^L90$	MOVE.16	{A4}+OIMALY,D4	COMP.16	{A2}+ODFFDY,D4;	JUMP,NE	 R8^L90$L90$:	POPM.32	D4|A4	RET;--------\; GPTIMA  >;========/; Calcul le ^dans l'image alphanumrique associe  une; fentre en fonction des coordonnes du curseur typo.; in	A2.L	^description de la fentre; out	EQ	ok, ^dans A4;	 A4.32	 ^absolu dans l'image;	NE	erreur quelconque, A4 non valide; mod	D7.W, A4.LGPTIMA:	PUSHM.32 D0|D1	MOVE.16	#ERDIOUT,D7	; D7 <-- erreur pour retour NE	MOVE.32	{A2}+ODFPIM,A4	; A4 <-- ^base de l'image	CLR.32	D0	MOVE.16	{A2}+ODFPX,D0	; D0 <-- pos. X curseur typo	DIV.16	{A4}+OIMACX,D0	; D0 <-- pos. X dans image	COMP.16	{A4}+OIMADX,D0	; trop loin ?	JUMP,HS	 R8^L90$	; oui => 90$	CLR.32	D1	MOVE.16	{A2}+ODFPY,D1	; D1 <-- pos. Y curseur typo	SUB.16	{A4}+OIMAOY,D1	; soustrait offset Y ventuel	JUMP,LO	 R8^L90$	; si trop haut => 90$	DIV.16	{A4}+OIMACY,D1	; D1 <-- pos. Y dans image	COMP.16	{A4}+OIMADY,D1	; trop loin ?	JUMP,HS	 R8^L90$	; oui => 90$	MOVE.16	D0,{A4}+OIMAPX	; init position X	MOVE.16	D1,{A4}+OIMAPY	; init position Y	MUL.16	{A4}+OIMADX,D1	; D1 <-- pos. dbut bonne ligne	AND.32	#16'FFFF,D0	ADD.32	D0,D1		; D1 <-- pos. ok dans ligne	ADD.32	#LGIMA,D1	; D1 <-- ajoute offset fixe	ADD.32	D1,A4		; A4 <-- ^dans l'image	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D0|D1	TEST.16	D7		; retour EQ/NE	RET;--------\; ROLIMA  >;========/; Effectue un roll (dcalage d'une ligne vers le haut) dans; l'image alphanumrique.; in	A2.L	^description de la fentre;	D0.16	lg du roll; out	-; mod	-ROLIMA:	PUSHM.32 D0|D1|A3|A4	MOVE.32	{A2}+ODFPIM,A4	; A4 <-- ^base de l'image	MOVE.16	{A2}+ODFCY,D1	; D1 <-- lg d'un roll complet	SUB.16	D0,D1		; D1 <-- lg pas faite	JUMP,EQ	 R8^L10$	; si roll complet => 10$	MOVE.16	D1,{A4}+OIMAOY	; mm. offset YL10$:	CLR.32	D0	MOVE.16	{A4}+OIMADX,D0	; D0 <-- lg d'une ligne	MOVE.16	{A4}+OIMADY,D1	DEC.16	D1	MUL.16	D0,D1		; D1 <-- nb car. - une ligne	MOVE.32	#{A4}+LGIMA,A4	; A4 <-- ^dbut 1re ligne	MOVE.32	A4,A3	ADD.32	D0,A3		; A3 <-- ^dbut 2me ligneL20$:	MOVE.8	{A3+},{A4+}	; remonte tout d'une ligne	DEC.16	D1	JUMP,NE L20$L40$:	MOVE.8	#SPACE,{A4+}	; efface la dernire ligne	DEC.16	D0	JUMP,NE L40$L90$:	POPM.32	D0|D1|A3|A4	RET;--------\; CLRIMA  >;========/; Rempli l'image alphanumrique associe  une fentre; d'espaces (blancs).; in	A2.L	^description de la fentre; out	-; mod	-CLRIMA:	PUSHM.32 D0|A4	MOVE.32	{A2}+ODFPIM,A4	; A4 <-- ^base de l'image	CLR.16	{A4}+OIMAOY	; clear offset Y	MOVE.16	{A4}+OIMADX,D0	; D0 <-- lg d'une ligne	MUL.16	{A4}+OIMADY,D0	; D0 <-- nb car. dans image	MOVE.32	#{A4}+LGIMA,A4	; A4 <-- ^dbut 1re ligneL10$:	MOVE.8	#SPACE,{A4+}	; rempli de SPACEs	DEC.16	D0	JUMP,NE L10$	POPM.32	D0|A4	RET;--------\; EOSIMA  >;========/; Rempli la fin de l'image alphanumrique associe  une; fentre d'espaces (blancs).; in	A2.L	^description de la fentre; out	-; mod	-EOSIMA:	PUSHM.32 D0|A0|A4	CALL	GPTIMA		; A4 <-- ^dans l'image	JUMP,NE	 R8^L90$	MOVE.32	{A2}+ODFPIM,A0	; A0 <-- ^base de l'image	MOVE.16	{A0}+OIMADY,D0	; D0 <-- hauteur image	SUB.16	{A0}+OIMAPY,D0	; D0 <-- nb lignes restantes	MUL.16	{A0}+OIMADX,D0	; D0 <-- nb caractres restants	SUB.16	{A0}+OIMAPX,D0	; D0 <-- reste dans ligne	JUMP,LS	 R8^L90$	; si reste rien => 90$L20$:	MOVE.8	#SPACE,{A4+}	; efface la fin de l'cran	DEC.16	D0	JUMP,NE L20$L90$:	POPM.32	D0|A0|A4	RET;--------\; EFLIMA  >;========/; Efface depuis la position du curseur jusqu' la fin de; la ligne (comme EFLI).; in	A2.L	^description de la fentre; out	-; mod	D7.WEFLIMA:	PUSHM.32 D0|A0|A4	CALL	GPTIMA		; A4 <-- ^dans l'image	JUMP,NE	 R8^L90$	MOVE.32	{A2}+ODFPIM,A0	; A0 <-- ^base de l'image	MOVE.16	{A0}+OIMADX,D0	; D0 <-- largeur image	SUB.16	{A0}+OIMAPX,D0	; D0 <-- reste dans ligne	JUMP,EQ	 R8^L90$	; si reste rien => 90$L20$:	MOVE.8	#SPACE,{A4+}	; efface la fin de la ligne	DEC.16	D0	JUMP,NE L20$L90$:	POPM.32	D0|A0|A4	RET;--------\; CREIMA  >;========/; Demande au gestionnaire de mmoire de la place pour crer; une image alphanumrique d'une fentre quelconque.; Mmorise dans l'en-tte de l'image les dimensions x;y de; l'image, les dimensions x;y d'un caractre, et les; dimensions x;y dx;dy de la sous-fentre.; in	A2.L	^description de la fentre; out	D7.W	erreur; mod	D7.WCREIMA:	PUSHM.32 D0|D1|D2|D3|D4|A1|A4	CLR.32	D2	MOVE.16	{A2}+ODFFDX,D2	; D2 <-- largeur fentre	DIV.16	{A2}+ODFCX,D2	; D2 <-- nb car/ligne	INC.16	D2		; petite marge (si arrondi)	CLR.32	D3	MOVE.16	{A2}+ODFFDY,D3	; D3 <-- hauteur fentre	DIV.16	{A2}+ODFCY,D3	; D3 <-- nb lignes	INC.16	D3		; petite marge (si arrondi)	MOVE.16	D2,D4	MUL.16	D3,D4		; D4 <-- largeur * hauteur	ADD.32	#LGIMA,D4	; D4 <-- ajoute les frais fixes	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS_0	MOVE.16	#MTYPBD,D1	; type driver BIOS	GESMEM	?GETMEM		; demande mm. pour l'image	JUMP,NE L90$		; si erreur => 90$	MOVE.32	A4,{A2}+ODFPIM	; init ^image	MOVE.16	D2,{A4}+OIMADX	; init largeur image	MOVE.16	D3,{A4}+OIMADY	; init hauteur image	MOVE.16	{A2}+ODFCX,{A4}+OIMACX ; init largeur car.	MOVE.16	{A2}+ODFCY,{A4}+OIMACY ; init hauteur car.	MOVE.16	{A2}+ODFFX,{A4}+OIMASX	MOVE.16	{A2}+ODFFY,{A4}+OIMASY	MOVE.16	{A2}+ODFFDX,{A4}+OIMALX	MOVE.16	{A2}+ODFFDY,{A4}+OIMALY	CLR.16	{A4}+OIMAOY	; clear offset v. en Y	CALL	CLRIMA		; rempli l'image de SPACEs	TSET.8	{A2}+ODFFLG:#BFIMAA ; l'image existe (eh oui)L90$:	POPM.32	D0|D1|D2|D3|D4|A1|A4	RET;--------\; KILIMA  >;========/; Supprime l'image alphanumrique associe  une fentre.; in	A2.L	^description de la fentre; out	D7.W	erreur; mod	D7.WKILIMA:	PUSHM.32 D1|D4|A1|A4	MOVE.32	{A2}+ODFPIM,A4	; A4 <-- ^base de l'image	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS_0	MOVE.16	#MTYPBD,D1	; type driver BIOS	GESMEM	?GIVMEM		; rend la mmoire	JUMP,NE	 R8^L90$	; erreur => 90$	TCLR.8	{A2}+ODFFLG:#BFIMAA ; l'image n'existe plusL90$:	POPM.32	D1|D4|A1|A4	RET;--------\; WDOSAV  >;========/; Sauve le contenu de la fentre dans une zone mmoire.; in	A2.L	^description de la fentre; out	D7.W	erreur; mod	D7.WWDOSAV:	PUSHM.32 D1..D6|A0|A1|A3|A4	MOVE.16	#ERDIIL,D7	COMP.16	#4*MAXSAV,{A2}+ODFPSV	JUMP,HS L90$	.IF	COLOR	TEST.8	{A2}+ODFCMD	; cran couleur ?	JUMP,EQ	 R8^L20$	; non => 20$	MOVE.32	{A2}+ODFABS,D1	COMP.32	{A2}+ODFCAB,D1	; est-on dans l'cran couleur ?	JUMP,EQ L50$		; oui => 50$L20$:	.ENDIF	COLOR.IF	Color300	TEST.8	{A2}+ODFCMd	; cran couleur ?	JUMP,F	R8^BWSave$	COMP.32	#AdPixelMap1,{A2}+ODFAbs	JUMP,LO	R8^BWSave$	COMP.32	#AdPixelMap4+512*512,{A2}+ODFAbs	JUMP,LO	ColorSave$BWSave$:.ENDIF	Color300	MOVE.16	{A2}+ODFFX,D4	AND.16	#16'000F,D4	ADD.16	{A2}+ODFFDX,D4	ADD.16	#16-1,D4	AND.16	#16'FFF0,D4	; D4 <-- largeur multiple de word	SR.16	#3,D4		; D4 <-- largeur en bytes	MOVE.16	D4,D6		; D6 <-- Ix	MUL.16	{A2}+ODFFDY,D4	; D4 <-- taille en bytes	ADD.32	#4+4+2+4,D4	; D4 <-- ajoute place info	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS_0	MOVE.16	#MTYPBD,D1	; type driver BIOS	GESMEM	?GETMEM		; demande mmoire pour sauver	JUMP,NE L90$		; si erreur => 90$	MOVE.32	#{A2}+ODFSSV,A1	; A1 <-- ^dbut "stack"	MOVE.16	{A2}+ODFPSV,D1	MOVE.32	A4,{A1}+A16^{D1}; "stack" <-- ^zone de sauvetage	ADD.16	#4,D1	MOVE.16	D1,{A2}+ODFPSV	MOVE.32	{A2}+ODFFY,D3	; D3 <-- origine source	MOVE.32	#0,A3		; A3 <-- source dans l'cran	CLR.32	D4	MOVE.16	{A2}+ODFFX,D4	AND.16	#16'000F,D4	; D4 <-- origine destination	MOVE.32	{A2}+ODFFDY,D2	; D2 <-- dimensions	MOVE.32	D3,{A4+}	; buffer <-- origine dans l'cran	MOVE.32	D4,{A4+}	; buffer <-- origine dans buffer	MOVE.16	D6,{A4+}	; buffer <-- Ix dans buffer	MOVE.32	D2,{A4+}	; buffer <-- dimensions	MOVE.16	#LOADDOT,D1	; D1 <-- mode	PUSH.32	{A2}+ODFFY	PUSH.32	{A2}+ODFFDY	CLR.32	{A2}+ODFFY	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_RASTER-GRA2_FIRST)),A0	CALL	{A0}		; sauve toute la sous-fentre	POP.32	A0	POP.32	{A2}+ODFFDY	POP.32	{A2}+ODFFY	CALL	WMINMAX		; init min et max (sous-)fentre.IF	ModifJFG.IF	COLOR.OR.Color300	JUMP	L80$.ENDIF	COLOR.OR.Color300.ELSE	JUMP	L80$.ENDIF	ModifJFG	.IF	COLOR	MOVE.16	{A2}+ODFFDY,D2	; D2 <-- hauteur fentre en pts	MOVE.16	{A2}+ODFFDX,D3	; D3 <-- largeur fentre en pts	SR.16	#3,D3		; D3 <-- idem en bytes	PUSHM.32 D0..D4	MOVE.16	#MVDCLOAD,D0	CLR.32	D2	CLR.32	D3	MOVE.16	#-1,D4	CALL	MODVDCC		; init le mode logique	POPM.32	D0..D4	MOVE.16	D3,D4	MUL.16	D2,D4		; D4 <-- nb de bytes fentre	SL.32	#3,D4		; D4 <-- *8 plans couleurs	ADD.32	#4+2+2,D4	; D4 <-- ajoute place info	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS_0	MOVE.16	#MTYPBD,D1	; type driver BIOS	GESMEM	?GETMEM		; demande mm. pour l'image	JUMP,NE L90$		; si erreur => 90$	MOVE.32	#{A2}+ODFSSV,A1	; A1 <-- ^dbut "stack"	MOVE.16	{A2}+ODFPSV,D1	MOVE.32	A4,{A1}+A16^{D1}; "stack" <-- ^zone de sauvetage	ADD.16	#4,D1	MOVE.16	D1,{A2}+ODFPSV	MOVE.32	{A2}+ODFABS,A0	; A0 <-- adresse dbut cran	SUB.32	#LGBITS*8,A0	CLR.32	D1	MOVE.16	{A2}+ODFWBX,D1	; D1 <-- dbut fentre en X	AND.32	#1024-1,D1	SR.32	#3,D1	ADD.32	D1,A0		; ajoute dplacement X	CLR.32	D1	MOVE.16	{A2}+ODFWBY,D1	; D1 <-- dbut fentre en Y	 .IF	 SM324BIG	AND.32	#2048-1,D1	 .ELSE	AND.32	#512-1,D1	.ENDIF	SM324BIG	SL.32	#7,D1	ADD.32	D1,A0		; ajoute dplacement Y	MOVE.32	A0,{A4+}	; zone <-- ^absolu dans cran	MOVE.16	D3,{A4+}	; zone <-- largeur X (bytes)	MOVE.16	D2,{A4+}	; zone <-- hauteur Y (points)L60$:	CLR.32	D1L61$:	MOVE.32	#{A0}+32^{D1},A1; A1 <-- ^dbut dans l'cran	MOVE.16	D3,D4		; D4 <-- largeur fentre	DEC.16	D4		; D4 <-- -1  cause NMOL62$:	MOVE.8	{A1+},{A4+}	; sauve une ligne horizontale	DJ.16,NMO  D4,L62$	ADD.32	#LGBITS,D1	COMP.32	#LGBITS*8,D1	JUMP,LO L61$	MOVE.32	#{A0}+16'80,A0	; A0 <-- ^ligne suivante	DEC.16	D2	JUMP,NE L60$.ENDIF	COLOR.IF	Color300ColorSave$:	MOVE.16	{A2}+ODFFX,D4	; D4.16 <- origine, arrondie sur une frontire	AND.16	#16'0003,D4	; de word	ADD.16	{A2}+ODFFDX,D4	ADD.16	#4-1,D4	AND.16	#16'FFFC,D4	; D4 <-- largeur multiple de word	SR.16	D4		; D4 <-- largeur en bytes	MOVE.16	D4,D6		; D6 <-- Ix	MUL.16	{A2}+ODFFDY,D4	; D4 <-- taille en bytes	ADD.32	#4+4+2+4,D4	; D4 <-- ajoute place info	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS_0	MOVE.16	#MTYPBD,D1	; type driver BIOS	GESMEM	?GETMEM		; demande mmoire pour sauver	JUMP,NE L90$		; si erreur => 90$	MOVE.32	#{A2}+ODFSSV,A1	; A1 <-- ^dbut "stack"	MOVE.16	{A2}+ODFPSV,D1	MOVE.32	A4,{A1}+A16^{D1}; "stack" <-- ^zone de sauvetage	ADD.16	#4,D1	MOVE.16	D1,{A2}+ODFPSV	MOVE.32	{A2}+ODFFY,D3	; D3 <-- origine source	MOVE.32	#0,A3		; A3 <-- source dans l'cran	CLR.32	D4	MOVE.16	{A2}+ODFFX,D4	AND.16	#16'0003,D4	; D4 <-- origine destination	MOVE.32	{A2}+ODFFDY,D2	; D2 <-- dimensions	MOVE.32	D3,{A4+}	; buffer <-- origine dans l'cran	MOVE.32	D4,{A4+}	; buffer <-- origine dans buffer	MOVE.16	D6,{A4+}	; buffer <-- Ix dans buffer	MOVE.32	D2,{A4+}	; buffer <-- dimensions; On utilise ici GRA2_CRaster avec source=couleur et dest=couleur.	MOVE.16	#LOADDOT.OR.2**BSrcCoul.OR.2**BDstCoul,D1	PUSH.32	{A2}+ODFFY	PUSH.32	{A2}+ODFFDY	CLR.32	{A2}+ODFFY	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_CRASTER-GRA2_FIRST)),A0	CALL	{A0}		; sauve toute la sous-fentre	POP.32	A0	POP.32	{A2}+ODFFDY	POP.32	{A2}+ODFFY	CALL	WMINMAX		; init min et max (sous-)fentre.ENDIF	Color300L80$:	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D1..D6|A0|A1|A3|A4	RET;--------\; WDOGET  >;========/; Restitue le contenu d'une fentre sauve dans une zone; mmoire.; in	A2.L	^description de la fentre; out	D7.W	erreur; mod	D7.WWDOGET:	PUSHM.32 D1..D6|A0|A1|A3|A4	MOVE.16	#ERDIIL,D7	MOVE.32	#{A2}+ODFSSV,A1	; A1 <-- ^dbut "stack"	MOVE.16	{A2}+ODFPSV,D1	JUMP,EQ L90$	SUB.16	#4,D1	MOVE.32	{A1}+A16^{D1},A4; A4 <-- ^zone de sauvetage	MOVE.16	D1,{A2}+ODFPSV	.IF	COLOR	TEST.8	{A2}+ODFCMD	; cran couleur ?	JUMP,EQ	 R8^L20$	; non => 20$	MOVE.32	{A2}+ODFABS,D1	COMP.32	{A2}+ODFCAB,D1	; est-on dans l'cran couleur ?	JUMP,EQ L50$		; oui => 50$L20$:	.ENDIF	COLOR.IF	Color300	TEST.8	{A2}+ODFCMd	; Mode couleur ?	JUMP,F	R8^BWGet$	COMP.32	#AdPixelMap1,{A2}+ODFAbs	JUMP,LO	R8^BWGet$	COMP.32	#AdPixelMap4+512*512,{A2}+ODFAbs	JUMP,LO	ColorGet$BWGet$:.ENDIF	Color300	MOVE.32	A4,A3	MOVE.32	{A3+},D4	; D4 <-- origine dans l'cran	MOVE.32	{A3+},D3	; D3 <-- origine dans buffer	MOVE.16	{A3+},D5	; D5 <-- Ix dans buffer	MOVE.32	{A3+},D2	; D2 <-- dimensions	MOVE.32	#0,A4		; A4 <-- destination dans l'cran	MOVE.16	#LOADDOT,D1	; D1 <-- mode	PUSH.32	{A2}+ODFFY	PUSH.32	{A2}+ODFFDY	CLR.32	{A2}+ODFFY	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_RASTER-GRA2_FIRST)),A0	CALL	{A0}		; restitue toute la sous-fentre	POP.32	A0	POP.32	{A2}+ODFFDY	POP.32	{A2}+ODFFY	CALL	WMINMAX		; init min et max (sous-)fentre	MOVE.32	#{A3}-(4+4+2+4),A4.IF	ModifJFG.IF	COLOR.OR.Color300	JUMP	L80$.ENDIF	COLOR.OR.Color300.ELSE	JUMP	L80$.ENDIF	ModifJFG	.IF	COLORL50$:	PUSHM.32 D0..D4	MOVE.16	#MVDCLOAD,D0	CLR.32	D2	CLR.32	D3	MOVE.16	#-1,D4	CALL	MODVDCC		; init le mode logique	POPM.32	D0..D4	MOVE.32	A4,A3	MOVE.32	{A3+},A0	; A0 <-- ^absolu dans cran	MOVE.16	{A3+},D3	; D3 <-- largeur X (bytes)	MOVE.16	{A3+},D2	; D2 <-- hauteur Y (points)L60$:	CLR.32	D1L61$:	MOVE.32	#{A0}+32^{D1},A1; A1 <-- ^dbut dans l'cran	MOVE.16	D3,D4		; D4 <-- largeur fentre	DEC.16	D4		; D4 <-- -1  cause NMOL62$:	MOVE.8	{A3+},{A1+}	; remet une ligne horizontale	DJ.16,NMO  D4,L62$	ADD.32	#LGBITS,D1	COMP.32	#LGBITS*8,D1	JUMP,LO L61$	MOVE.32	#{A0}+16'80,A0	; A0 <-- ^ligne suivante	DEC.16	D2	JUMP,NE L60$	.ENDIF	COLOR.IF	Color300ColorGet$:	MOVE.32	A4,A3	MOVE.32	{A3+},D4	; D4 <-- origine dans l'cran	MOVE.32	{A3+},D3	; D3 <-- origine dans buffer	MOVE.16	{A3+},D5	; D5 <-- Ix dans buffer	MOVE.32	{A3+},D2	; D2 <-- dimensions	MOVE.32	#0,A4		; A4 <-- destination dans l'cran	MOVE.16	#LOADDOT.OR.2**BSrcCoul.OR.2**BDstCoul,D1	; D1 <-- mode	PUSH.32	{A2}+ODFFY	PUSH.32	{A2}+ODFFDY	CLR.32	{A2}+ODFFY	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_CRASTER-GRA2_FIRST)),A0	CALL	{A0}		; restitue toute la sous-fentre	POP.32	A0	POP.32	{A2}+ODFFDY	POP.32	{A2}+ODFFY	CALL	WMINMAX		; init min et max (sous-)fentre	MOVE.32	#{A3}-(4+4+2+4),A4.ENDIF	Color300L80$:	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS_0	MOVE.16	#MTYPBD,D1	; type driver BIOS	GESMEM	?GIVMEM		; rend la mmoireL90$:	POPM.32	D1..D6|A0|A1|A3|A4	RET	.END