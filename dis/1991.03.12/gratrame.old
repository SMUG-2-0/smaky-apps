	.SBTTL	GRATRAME;-----------\; _GRA_TRAME >;===========/; Rempli une surface rectangulaire avec une trame 8x8.; La trame est toujours aligne (horizontalement et verticalement);  une position modulo 8 pour rsoudre les problmes de jointures; entre deux trames.; in	A2.L	^description de la fentre;	D4.L	coordonnes y;x dbut (coin sup/gauche);	D3.L	delta y;x;	D1.B	opration (INVDOT, SETDOT ou CLRDOT);	A4.L	^trame; out	D7.W	erreur; mod	D7.W; use	D0 no bit		A0 ^byte;	D1 opration		A1 Iy;	D2 dY et dX		A2 ^descripteur;	D3 X			A3 ^ligne trame;	D4 Y			A4 ^dbut trame;	D5 compteur trame	A5;	D6 byte trame		A6;	D7			A7_GRA_TRAME:	PUSHM.L	D0..D6,A0..A5	TEST.W	D3		; largeur nulle ?	JUMP,EQ TRAME_EXIT	; oui => TRAME_EXIT	SWAP.W	D3	TEST.W	D3		; hauteur nulle ?	JUMP,EQ TRAME_EXIT	; oui => TRAME_EXIT	SWAP.W	D3	CALL	CLIPGRA		; dans la fentre ?	JUMP,NE	TRAME_EXIT	; non => TRAME_EXIT	.IF	COLOR	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP,EQ 19$		; non => 19$	LOAD.L	D0,(A2)+ODFABS	COMP.L	D0,(A2)+ODFCAB	; est-on dans l'cran couleur ?	JUMP,NE 19$		; non => 19$	PUSHM.L	D0,D2,D3,D4	TEST.L	D1:#0	JUMP',BC 12$	TEST.L	D1:#1	JUMP',BC 14$				; CLRDOT =>	LOAD.L	D0,#H'10000*MVDCOR2+MVDCAND1	LOAD.L	D3,(A2)+ODFCCF	; D3 <-- couleur pour effacer;	LOAD.B	D1,#CLRDOT	; D1 <-- mode CLR	JUMP'	16$12$:				; SETDOT =>	LOAD.L	D0,#H'10000*MVDCOR2+MVDCAND1	LOAD.L	D3,(A2)+ODFCSF	; D3 <-- couleur pour dessiner	LOAD.B	D1,#-1		; D1 <-- mode couleur	JUMP'	16$14$:				; INVDOT =>	LOAD.L	D0,#H'10000*MVDCXNOR+MVDCNOP	LOAD.L	D3,(A2)+ODFCSF	; D3 <-- couleur pour dessiner	LOAD.L	D2,(A2)+ODFCCF	; D2 <-- couleur pour effacer	XOR.L	D3,D2	LOAD.B	D1,#-1		; D1 <-- mode couleur16$:	CLR.L	D2	LOAD.W	D4,#-1	CALL	MODVDCC		; init le mode logique	POPM.L	D0,D2,D3,D419$:	.ENDIF	LOAD.L	D2,D3		; D2 <-- dimensions (dy;dx)	LOAD.W	D3,D4		; D3 <-- X	SWAP.W	D4		; D4 <-- Y	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit	LOAD.W	D5,D4	ADD.W	D5,(A2)+ODFFY	AND.W	D5,#B'111	; D5 <-- no ligne de la trame	LOAD.L	A3,#(A4)+(D5.W)	; A3 <-- ^ligne trame	SUB.W	D5,#8	NEG.W	D5	LOAD.W	A1,(A2)+ODFIIY	; A1 <-- Iy	.IF	COLOR	COMP.B	D1,#-1	JUMP,EQ	TRAME_COLOR	.ENDIF	COMP.B	D1,#CLRDOT	JUMP,EQ TRAME_CLR	COMP.B	D1,#SETDOT	JUMP,EQ TRAME_SET; Travail de dbut.	TEST.B	D0	JUMP',EQ 40$	LOAD.W	D7,#8	SUB.W	D7,D0	COMP.W	D2,D7	JUMP',HS 30$	SUB.W	D7,D2	SWAP.W	D2	DEC.W	D222$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	DEC.W	D5	JUMP',NE 24$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#824$:	SL.B	D6,D0	RR.B	D6,D0	SR.B	D6,D7	RL.B	D6,D7	XOR.B	(A0),D6	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,22$	JUMP	TRAME_END30$:	PUSHM.L	D0,D2,D5,A0,A3	SWAP.W	D2	DEC.W	D232$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	DEC.W	D5	JUMP',NE 34$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#834$:	SL.B	D6,D0	RR.B	D6,D0	XOR.B	(A0),D6	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,32$	POPM.L	D0,D2,D5,A0,A3	SUB.W	D2,D7	CLR.W	D0	INC.L	A0		; A0 <-- ^ gauche; Travail du milieu.40$:	COMP.W	D2,#8		; au moins un byte ?	JUMP',LO 60$		; non => 60$				; oui =>	PUSHM.L	D0,D2,D5,A0,A3	SWAP.W	D2		; D2 <-- hauteur	DEC.W	D2		; D2 <-- -1  cause NMO42$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	DEC.W	D5	JUMP',NE 44$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#844$:	PUSHM.L	D2,A0	SWAP.W	D2	SR.W	D2,#3		; D2 <-- largeur en bytes	DEC.W	D2		; D2 <-- -1  cause NMO46$:	XOR.B	(A0+),D6	DECJ.W,NMO D2,46$	POPM.L	D2,A0	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,42$	POPM.L	D0,D2,D5,A0,A3	LOAD.W	D7,D2	SR.W	D7,#3	ADD.W	A0,D7; Travail de fin.60$:	LOAD.B	D7,D2	AND.B	D7,#B'111	SUB.B	D7,#8	NEG.B	D7	JUMP,EQ TRAME_END	SWAP.W	D2		; D2 <-- hauteur	DEC.W	D2		; D2 <-- -1  cause NMO70$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	DEC.W	D5	JUMP',NE 74$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#874$:	SR.B	D6,D7	RL.B	D6,D7	XOR.B	(A0),D6	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,70$	JUMP	TRAME_ENDTRAME_SET:; Travail de dbut.	TEST.B	D0	JUMP',EQ 40$	LOAD.W	D7,#8	SUB.W	D7,D0	COMP.W	D2,D7	JUMP',HS 30$	SUB.W	D7,D2	SWAP.W	D2	DEC.W	D222$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	DEC.W	D5	JUMP',NE 24$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#824$:	SL.B	D6,D0	RR.B	D6,D0	SR.B	D6,D7	RL.B	D6,D7	OR.B	(A0),D6	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,22$	JUMP	TRAME_END30$:	PUSHM.L	D0,D2,D5,A0,A3	SWAP.W	D2	DEC.W	D232$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	DEC.W	D5	JUMP',NE 34$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#834$:	SL.B	D6,D0	RR.B	D6,D0	OR.B	(A0),D6	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,32$	POPM.L	D0,D2,D5,A0,A3	SUB.W	D2,D7	CLR.W	D0	INC.L	A0		; A0 <-- ^ gauche; Travail du milieu.40$:	COMP.W	D2,#8		; au moins un byte ?	JUMP',LO 60$		; non => 60$				; oui =>	PUSHM.L	D0,D2,D5,A0,A3	SWAP.W	D2		; D2 <-- hauteur	DEC.W	D2		; D2 <-- -1  cause NMO42$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	DEC.W	D5	JUMP',NE 44$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#844$:	PUSHM.L	D2,A0	SWAP.W	D2	SR.W	D2,#3		; D2 <-- largeur en bytes	DEC.W	D2		; D2 <-- -1  cause NMO46$:	OR.B	(A0+),D6	DECJ.W,NMO D2,46$	POPM.L	D2,A0	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,42$	POPM.L	D0,D2,D5,A0,A3	LOAD.W	D7,D2	SR.W	D7,#3	ADD.W	A0,D7; Travail de fin.60$:	LOAD.B	D7,D2	AND.B	D7,#B'111	SUB.B	D7,#8	NEG.B	D7	JUMP,EQ TRAME_END	SWAP.W	D2		; D2 <-- hauteur	DEC.W	D2		; D2 <-- -1  cause NMO70$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	DEC.W	D5	JUMP',NE 74$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#874$:	SR.B	D6,D7	RL.B	D6,D7	OR.B	(A0),D6	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,70$	JUMP	TRAME_ENDTRAME_CLR:; Travail de dbut.	TEST.B	D0	JUMP',EQ 40$	LOAD.W	D7,#8	SUB.W	D7,D0	COMP.W	D2,D7	JUMP',HS 30$	SUB.W	D7,D2	SWAP.W	D2	DEC.W	D222$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	NOT.B	D6	DEC.W	D5	JUMP',NE 24$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#824$:	SL.B	D6,D0	RR.B	D6,D0	SR.B	D6,D7	RL.B	D6,D7	NOT.B	D6	AND.B	(A0),D6	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,22$	JUMP	TRAME_END30$:	PUSHM.L	D0,D2,D5,A0,A3	SWAP.W	D2	DEC.W	D232$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	NOT.B	D6	DEC.W	D5	JUMP',NE 34$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#834$:	SL.B	D6,D0	RR.B	D6,D0	NOT.B	D6	AND.B	(A0),D6	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,32$	POPM.L	D0,D2,D5,A0,A3	SUB.W	D2,D7	CLR.W	D0	INC.L	A0		; A0 <-- ^ gauche; Travail du milieu.40$:	COMP.W	D2,#8		; au moins un byte ?	JUMP',LO 60$		; non => 60$				; oui =>	PUSHM.L	D0,D2,D5,A0,A3	SWAP.W	D2		; D2 <-- hauteur	DEC.W	D2		; D2 <-- -1  cause NMO42$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	DEC.W	D5	JUMP',NE 44$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#844$:	PUSHM.L	D2,A0	SWAP.W	D2	SR.W	D2,#3		; D2 <-- largeur en bytes	DEC.W	D2		; D2 <-- -1  cause NMO46$:	AND.B	(A0+),D6	DECJ.W,NMO D2,46$	POPM.L	D2,A0	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,42$	POPM.L	D0,D2,D5,A0,A3	LOAD.W	D7,D2	SR.W	D7,#3	ADD.W	A0,D7; Travail de fin.60$:	LOAD.B	D7,D2	AND.B	D7,#B'111	SUB.B	D7,#8	NEG.B	D7	JUMP,EQ TRAME_END	SWAP.W	D2		; D2 <-- hauteur	DEC.W	D2		; D2 <-- -1  cause NMO70$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	NOT.B	D6	DEC.W	D5	JUMP',NE 74$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#874$:	SR.B	D6,D7	RL.B	D6,D7	NOT.B	D6	AND.B	(A0),D6	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,70$	JUMP	TRAME_END	.IF	COLORTRAME_COLOR:; Travail de dbut.	TEST.B	D0	JUMP',EQ 40$	LOAD.W	D7,#8	SUB.W	D7,D0	COMP.W	D2,D7	JUMP',HS 30$	SUB.W	D7,D2	SWAP.W	D2	DEC.W	D222$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	DEC.W	D5	JUMP',NE 24$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#824$:	SL.B	D6,D0	RR.B	D6,D0	SR.B	D6,D7	RL.B	D6,D7	NOT.B	D6	AND.B	(A0),D6	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,22$	JUMP	TRAME_END30$:	PUSHM.L	D0,D2,D5,A0,A3	SWAP.W	D2	DEC.W	D232$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	DEC.W	D5	JUMP',NE 34$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#834$:	SL.B	D6,D0	RR.B	D6,D0	NOT.B	D6	AND.B	(A0),D6	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,32$	POPM.L	D0,D2,D5,A0,A3	SUB.W	D2,D7	CLR.W	D0	INC.L	A0		; A0 <-- ^ gauche; Travail du milieu.40$:	COMP.W	D2,#8		; au moins un byte ?	JUMP',LO 60$		; non => 60$				; oui =>	PUSHM.L	D0,D2,D5,A0,A3	SWAP.W	D2		; D2 <-- hauteur	DEC.W	D2		; D2 <-- -1  cause NMO42$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	NOT.B	D6	DEC.W	D5	JUMP',NE 44$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#844$:	PUSHM.L	D2,A0	SWAP.W	D2	SR.W	D2,#3		; D2 <-- largeur en bytes	DEC.W	D2		; D2 <-- -1  cause NMO46$:	AND.B	(A0+),D6	DECJ.W,NMO D2,46$	POPM.L	D2,A0	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,42$	POPM.L	D0,D2,D5,A0,A3	LOAD.W	D7,D2	SR.W	D7,#3	ADD.W	A0,D7; Travail de fin.60$:	LOAD.B	D7,D2	AND.B	D7,#B'111	SUB.B	D7,#8	NEG.B	D7	JUMP,EQ TRAME_END	SWAP.W	D2		; D2 <-- hauteur	DEC.W	D2		; D2 <-- -1  cause NMO70$:	LOAD.B	D6,(A3+)	; D6 <-- byte trame	DEC.W	D5	JUMP',NE 74$	LOAD.L	A3,A4		; A3 <-- ^premire ligne trame	LOAD.W	D5,#874$:	SR.B	D6,D7	RL.B	D6,D7	NOT.B	D6	AND.B	(A0),D6	ADD.L	A0,A1		; A0 <-- ^en dessous	DECJ.W,NMO D2,70$;	JUMP	TRAME_END	.ENDIFTRAME_END:	CLR.W	D7		; D7 <-- okTRAME_EXIT:	POPM.L	D0..D6,A0..A5	RET	.END