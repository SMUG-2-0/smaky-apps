	.TITLE	PALETTE.ASC;	--------------------------------------;		(C) 1988 - Daniel Roux;	--------------------------------------;	Source du programme PAGE.CODE	.PROC	M680002	.REF	SMAKY	.REF	MODULES	.REF	COLORS	.REV	1,0	.CODE	800,11,B'1111,300,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"COUL256	=	0		; 0 si 16 couleurs et 1 si 256 couleurs; Constantes; ----------PCCODE	=	1PCVAR	=	2	.IF	COUL256NBCOUL	=	256	.ELSENBCOUL	=	16	.ENDIFLPALINV	=	3DEGNBX	=	9DEGNBY	=	NBCOUL-1LTABLE	=	4+2+2+2+30LBUFILE	=	(4+2+2+2)*200LBUNAME	=	50KEYDBOX	=	H'7E00		; "touche" spciale; Modes de choix des couleurs; ---------------------------BMODRGB	=	0		; RGBBMODHSV	=	1		; HSVBMODPAL	=	2		; paletteBMODDEG	=	3		; dgrad; Variables; ---------	.PC	PCVAR	.LOC	0OPLCOM:	.BLKB	4		; ^ligne de commandeOCHDBOX:.BLKB	2		; canal module DBOXOCHSCROLL:.BLKB	2		; canal module SCROLLOPDDIS:	.BLKB	4		; ^descripteur de la fentreOBUDIS:	.BLKB	20		; buffer write displayOCNDIS:	.BLKB	2		; canal de la fentre $DIS_nOC0DIS:	.BLKB	2		; canal de la fentre $DIS_0OSLVAR:	.BLKB	LSLVAR		; variables scroll-listeOSCVAR:	.BLKB	LSCVAR*3	; variables ascenseurs rouge/vert/bleuOPALPX:	.BLKB	2		; palette: position en XOCURPX:	.BLKB	2		; curseur: position en XOPPFAN:	.BLKB	4		; pp: fanionsODFFAN:	.BLKB	4		; df: fanionsOBUCLUT:.BLKB	LBUNAME		; buffer pour nom .CLUTOBUFILE:.BLKB	LBUFILE		; buffer pour COLOR.INFOLGVAR:; Programme; ---------	.PC	PCCODE	.LOC	0START:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	; met toutes les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	LIB	?GCHDIS	LOAD.W	(A6)+OCNDIS,D6	LOAD.L	A3,#R16"NPDIS	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre $DIS_20	LOAD.W	(A6)+OC0DIS,D6	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT1	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT1	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT1	LOAD.W	(A6)+OCHSCROLL,D1	CALL	RDFILE		; lit COLOR.INFO	CALL	LINKALL		; lie toutes les couleurs relatives	LOAD.L	A3,(A6)+OPLCOM	LOAD.B	D3,#'I	LIB	?IFSWITCH	; PALETTE/I ?	JUMP,EQ ERFAT1	LIB	?AFTIM	.B	NOCURS,EOP,0	; efface tout	.EVEN	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	LIB	?DRMDEF	LIB	?GETDIM	CLR.L	D3	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	; grise toute le fentre	CALL	DBOXPP		; appel dbox principale ...ERFAT1:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D6,(A6)+OC0DIS	FOS	?CLOSE		; ferme $DIS_20	LIB	?AFTIM	.B	EOP,0	.EVEN	LIB	?CLOLIB	FOS	?STOP;--------\\; DBOXPP  >;========/; Choix des couleurs dans la dbox principale.; in	-; out	-; mod	D7.WDBOXPP:	PUSHM.L	D1..D6,A1..A4	LOAD.L	(A6)+OPPFAN,#2^BMODPAL	LOAD.L	(A6)+ODFFAN,#2^BMODDEGDEBUT$:	LOAD.L	A2,#R16"TDBOX_PP	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OPPFAN	; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	D6,D5	LOAD.W	(A6)+OPALPX,#340	LOAD.W	(A6)+OCURPX,#340	CALL	SLDRAW		; dessine la scroll-listeREFAIT$:	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_DBCLEAR	LIB	?COLORCR	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,#H'10000*(30-25)+320	LOAD.L	D4,#H'10000*(200+35)+245	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	LIB	?COLORPOPREFAITQ$:	CALL	SLCOLOR		; affiche les couleurs  droite de la scroll-liste	CALL	SLGET		; D3/D4/D5 <-- rouge/vert/bleu selon scroll-liste	TEST.B	(A6)+OPPFAN+3:#BMODPAL	JUMP',BS PAL$	TEST.B	(A6)+OPPFAN+3:#BMODHSV	JUMP',BS HSV$	CALL	RGBCPUT		; init les ascenseurs selon les couleurs	CALL	RGBDRAWS	; dessine les trois ascenseurs	CALL	RGBUPDATES	; met  jour les trois ascenseurs	CLR.W	D1	CALL	RGBCDRAW	; affiche la couleur d'origine	INC.W	D1	CALL	RGBCDRAW	; affiche la couleur modifie	JUMP'	LOOP$HSV$:	CALL	HSVCPUT		; init les ascenseurs selon les couleurs	CALL	HSVDRAWS	; dessine les trois ascenseurs	CALL	HSVUPDATES	; met  jour les trois ascenseurs	CLR.W	D1	CALL	HSVCDRAW	; affiche la couleur d'origine	INC.W	D1	CALL	HSVCDRAW	; affiche la couleur modifie	JUMP'	LOOP$PAL$:	CALL	PALDRAW		; dessine la palette	CALL	PALGET		; D1/D3/D4/D5 <-- rang/rouge/vert/bleu	CALL	PALINV		; allume la fausse couleur actuelle;	JUMP'	LOOP$LOOP$:	LOAD.L	D4,(A6)+OPPFAN	; D4 <-- fanions	LOAD.L	D5,D6	DBOX_	EDIT		; attend action ...	LOAD.L	(A6)+OPPFAN,D4	LOAD.L	A1,#R16"TKEY_PP	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	; bouton souris press ?	JUMP,EQ	CLIC$		; oui => CLIC$	COMP.W	D3,#END	JUMP,EQ QUITTE$	COMP.W	D3,#F6	JUMP,EQ PERNANENT$	COMP.W	D3,#F7	JUMP,EQ DEF$	COMP.W	D3,#F9	JUMP,EQ CLOSE$	COMP.W	D3,#DEFINE	JUMP,EQ COMPLEMENT$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$PERNANENT$:	CALL	WRFILE		; crit COLOR.INFO	JUMP	LOOP$CLOSE$:	LOAD.L	D5,D6	DBOX_	CLOSE		; ferme la DBOX	JUMP	DEBUT$KEYDBOX$:	JUMP	REFAIT$COMPLEMENT$:	CALL	SLGET		; D3/D4/D5 <-- rouge/vert/bleu selon scroll-liste	NOT.W	D3	CLR.B	D3	NOT.W	D4	CLR.B	D4	NOT.W	D5	CLR.B	D5	CALL	SLPUT		; change dans la scroll-liste	JUMP	REFAIT$CLIC$:	CALL	IFMOUSE	JUMP,NE BIP$	TEST.B	(A6)+OPPFAN+3:#BMODPAL	JUMP,BS	CLICPAL$	TEST.B	(A6)+OPPFAN+3:#BMODHSV	JUMP,BS	CLICHSV$	CALL	SLMOVE		; dplace la scroll-liste ?	JUMP,EQ REFAITQ$	LOAD.L	A1,#R16"CRMAJ$	CALL	RGBMOVES	; dplace l'un des trois ascenseurs ?	JUMP,NE BIP$	CALL	SLCOLOR		; affiche les couleurs  droite de la scroll-liste	JUMP	LOOP$CRMAJ$:	PUSHM.L	D1..D5	CALL	RGBCGET		; D3/D4/D5 <-- rouge/vert/bleu des ascenseurs	CALL	SLPUT		; change dans la scroll-liste	LOAD.W	D1,#1	CALL	RGBCDRAW	; affiche la couleur modifie	POPM.L	D1..D5	RETCLICHSV$:	CALL	SLMOVE		; dplace la scroll-liste ?	JUMP,EQ REFAITQ$	LOAD.L	A1,#R16"CHMAJ$	CALL	HSVMOVES	; dplace l'un des trois ascenseurs ?	JUMP,NE BIP$	CALL	SLCOLOR		; affiche les couleurs  droite de la scroll-liste	JUMP	LOOP$CHMAJ$:	PUSHM.L	D1..D5	CALL	HSVCGET		; D3/D4/D5 <-- rouge/vert/bleu des ascenseurs	CALL	SLPUT		; change dans la scroll-liste	LOAD.W	D1,#1	CALL	HSVCDRAW	; affiche la couleur modifie	POPM.L	D1..D5	RETCLICPAL$:	PUSH.L	D4	CALL	PALGET		; D1/D3/D4/D5 <-- rang/rouge/vert/bleu	CALL	PALINV		; teint la fausse couleur actuelle	POP.L	D4	CALL	SLMOVE		; dplace la scroll-liste ...	JUMP',EQ PEND$	CALL	PALMOVE		; choix d'une couleur dans la palette ...	JUMP',NE PEND$	CALL	PALPUT		; change la fausse couleur	CALL	SLCOLOR		; affiche les couleurs  droite de la scroll-listePEND$:	PUSH.W	D7	CALL	PALGET		; D1/D3/D4/D5 <-- rang/rouge/vert/bleu	CALL	PALINV		; allume la fausse couleur actuelle	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$DEF$:	LOAD.L	D5,D6	DBOX_	CLOSE		; ferme la DBOX	CALL	PALGET		; D1/D3/D4/D5 <-- rang/rouge/vert/bleu	CALL	DBOXDEF		; modifie les fausses-couleurs ...	JUMP	DEBUT$QUITTE$:	LOAD.L	D5,D6	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D1..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_PP:	.W	10$-TDBOX_PP	.W	20$-TDBOX_PP	.W	0,010$:	.B	ODBTABX,69	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,12	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	" PREND "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" MODIFIE "	.B	ODBTABX,40	.B	ODBLCIRCLE,BMODPAL!2^7,KEYDBOX/H'100,BMODPAL	.ASCIZ	" palette"	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,DEFINE,TDBOMBRE	.ASCIZ	"COMPLEMENT"	.B	ODBCR	.B	ODBTABX,40	.B	ODBLCIRCLE,BMODHSV!2^7,KEYDBOX/H'100,BMODHSV	.ASCIZ	" TSI (HSV)"	.B	ODBCR	.B	ODBBOX,0,END,TDBMEV	.ASCIZ	" TERMINE "	.B	ODBBOX,0,F6,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBBOX,0,F9,TDBNORM	.ASCIZ	" REFAIT  "	.B	ODBTABX,40	.B	ODBLCIRCLE,BMODRGB!2^7,KEYDBOX/H'100,BMODRGB	.ASCIZ	" RVB (RGB)"	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Termine"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie    Refait"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_PP:	.W	F1,F2,F3,END,0		DOKEND-TKEY_PP	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_PP	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_PP	.W	0;--------\\; DBOXDEF >;========/; Choix de la table des fausses couleurs.; in	D1.W	couleur initiale (0..n); out	-; mod	D7.WDBOXDEF:	PUSHM.L	D0..D6,A1..A4	LOAD.W	D0,D1	LOAD.L	A2,#R16"TDBOX_DEF	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+ODFFAN	; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	D6,D5	LOAD.W	(A6)+OPALPX,#20	LOAD.W	(A6)+OCURPX,#200	CALL	PALDRAW		; dessine la palette	CLR.W	D1	CALL	PALCROIX	LOAD.W	D1,#NBCOUL-1	CALL	PALCROIX	LOAD.W	D1,D0	CALL	PALINV		; allume la fausse couleur actuelleREFAIT$:	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_DBCLEAR	LIB	?COLORCR	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,#H'10000*(30-25)+230	LOAD.L	D4,#H'10000*(200+35)+220	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	LIB	?COLORPOP	TEST.B	(A6)+ODFFAN+3:#BMODDEG	JUMP',BS DEG$	TEST.B	(A6)+ODFFAN+3:#BMODHSV	JUMP',BS HSV$	CALL	RGBDRAWS	; dessine les trois ascenseurs	LOAD.W	D1,D0	CALL	DEFGET		; D3/D4/D5 <-- rouge/vert/bleu	CALL	RGBCPUT		; donne les couleurs aux ascenseurs	CALL	RGBUPDATES	; met  jour les trois ascenseurs	JUMP'	LOOP$HSV$:	CALL	HSVDRAWS	; dessine les trois ascenseurs	LOAD.W	D1,D0	CALL	DEFGET		; D3/D4/D5 <-- rouge/vert/bleu	CALL	HSVCPUT		; donne les couleurs aux ascenseurs	CALL	HSVUPDATES	; met  jour les trois ascenseurs	JUMP'	LOOP$DEG$:	CALL	DEGDRAW		; dessine le dgrad;	JUMP'	LOOP$LOOP$:	LOAD.L	D4,(A6)+ODFFAN	LOAD.L	D5,D6	DBOX_	EDIT		; attend action ...	LOAD.L	(A6)+ODFFAN,D4	LOAD.L	A1,#R16"TKEY_DEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	; bouton souris press ?	JUMP,EQ	CLIC$		; oui => CLIC$	COMP.W	D3,#END	JUMP,EQ QUITTE$	COMP.W	D3,#DEFINE	JUMP,EQ COMPLEMENT$	COMP.W	D3,#F4	JUMP,EQ PREND$	COMP.W	D3,#F6	JUMP,EQ SAUVE$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$KEYDBOX$:	SUB.B	D3,#100	JUMP,LO REFAIT$	LOAD.L	A3,#R16"COLOR$	AND.W	D3,#H'00FF	MUL.WU	D3,#6	ADD.L	A3,D3	LOAD.W	D3,(A3+)	LOAD.W	D4,(A3+)	LOAD.W	D5,(A3+)	LOAD.W	D1,D0	CALL	DEFPUT		; modifie une fausse couleur	JUMP	REFAIT$COMPLEMENT$:	LOAD.W	D1,D0	CALL	DEFGET		; D3/D4/D5 <-- rouge/vert/bleu	NOT.W	D3	CLR.B	D3	NOT.W	D4	CLR.B	D4	NOT.W	D5	CLR.B	D5	CALL	DEFPUT		; modifie une fausse couleur	JUMP	REFAIT$CLIC$:	CALL	IFMOUSE	JUMP,NE BIP$	TEST.B	(A6)+ODFFAN+3:#BMODDEG	JUMP,BS CLICDEG$	TEST.B	(A6)+ODFFAN+3:#BMODHSV	JUMP,BS CLICHSV$	LOAD.W	D1,D0	CALL	PALINV		; teint la fausse couleur actuelle	CALL	PALMOVE		; choix d'une couleur dans la palette ...	JUMP',NE RGBPEND$	LOAD.W	D0,D1		; D0 <-- nouvelle fausse couleur	CALL	DEFGET		; D3/D4/D5 <-- rouge/vert/bleu	CALL	RGBCPUT		; donne les couleurs aux ascenseurs	CALL	RGBUPDATES	; met  jour les trois ascenseurs	CLR.W	D7RGBPEND$:	PUSH.W	D7	LOAD.W	D1,D0	CALL	PALINV		; allume la fausse couleur actuelle	POP.W	D7	JUMP,EQ LOOP$	TEST.W	D0		; modifie le blanc ?	JUMP,EQ BIP$		; oui => BIP$	COMP.W	D0,#NBCOUL-1	; modifie le noir ?	JUMP,HS BIP$		; oui => BIP$	LOAD.L	A1,#R16"CRMAJ$	CALL	RGBMOVES	; dplace l'un des trois ascenseurs ?	JUMP,NE BIP$		; non => BIP$	JUMP	LOOP$CRMAJ$:	PUSHM.L	D1..D5	CALL	RGBCGET		; D3,D4,D5 <-- couleur	LOAD.W	D1,D0	CALL	DEFPUT		; modifie une fausse couleur	POPM.L	D1..D5	RETCLICHSV$:	LOAD.W	D1,D0	CALL	PALINV		; teint la fausse couleur actuelle	CALL	PALMOVE		; choix d'une couleur dans la palette ...	JUMP',NE HSVPEND$	LOAD.W	D0,D1		; D0 <-- nouvelle fausse couleur	CALL	DEFGET		; D3/D4/D5 <-- rouge/vert/bleu	CALL	HSVCPUT		; donne les couleurs aux ascenseurs	CALL	HSVUPDATES	; met  jour les trois ascenseurs	CLR.W	D7HSVPEND$:	PUSH.W	D7	LOAD.W	D1,D0	CALL	PALINV		; allume la fausse couleur actuelle	POP.W	D7	JUMP,EQ LOOP$	TEST.W	D0		; modifie le blanc ?	JUMP,EQ BIP$		; oui => BIP$	COMP.W	D0,#NBCOUL-1	; modifie le noir ?	JUMP,HS BIP$		; oui => BIP$	LOAD.L	A1,#R16"CHMAJ$	CALL	HSVMOVES	; dplace l'un des trois ascenseurs ?	JUMP,NE BIP$		; non => BIP$	JUMP	LOOP$CHMAJ$:	PUSHM.L	D1..D5	CALL	HSVCGET		; D3,D4,D5 <-- couleur	LOAD.W	D1,D0	CALL	DEFPUT		; modifie une fausse couleur	POPM.L	D1..D5	RETCLICDEG$:	LOAD.W	D1,D0	CALL	PALINV		; teint la fausse couleur actuelle	CALL	PALMOVE		; choix d'une couleur dans la palette ...	JUMP',NE DEND$	LOAD.W	D0,D1		; D0 <-- nouvelle fausse couleur	CALL	DEGDRAW		; dessine le dgrad	CLR.W	D7DEND$:	PUSH.W	D7	LOAD.W	D1,D0	CALL	PALINV		; allume la fausse couleur actuelle	POP.W	D7	JUMP,EQ LOOP$	TEST.W	D0		; modifie le blanc ?	JUMP,EQ BIP$		; oui => BIP$	COMP.W	D0,#NBCOUL-1	; modifie le noir ?	JUMP,HS BIP$		; oui => BIP$	CALL	DEGMOVE		; choix d'un dgrad ?	JUMP,NE BIP$		; non => BIP$	CALL	DEGCALCUL	; D3/D4/D5 <-- rouge/vert/bleu	LOAD.W	D1,D0	CALL	DEFPUT		; modifie une fausse couleur	CALL	DEGDRAW		; dessine le dgrad	JUMP	LOOP$PREND$:	LOAD.L	A3,#(A6)+OBUCLUT	CALL	DBOXEDITIF	; demande nom .CLUT ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	DEFREAD		; lit un fichier .CLUT	JUMP,NE BIP$	CALL	LINKALL		; lie toutes les couleurs relatives	LOAD.W	D1,D0	CALL	PALINV		; teint la fausse couleur actuelle	JUMP	REFAIT$SAUVE$:	LOAD.L	A3,#(A6)+OBUCLUT	CALL	DBOXEDITOF	; demande nom .CLUT ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	DEFWRITE	; crit un fichier .CLUT	JUMP,NE BIP$	JUMP	LOOP$QUITTE$:	LOAD.L	D5,D6	DBOX_	CLOSE		; ferme la DBOXEXIT$:	CALL	LINKALL		; lie toutes les couleurs relatives	POPM.L	D0..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RETCOLOR$:	.W	H'BBBB,H'BBBB,H'BBBB	; gris	.W	H'FFFF,H'FFFF,H'0000	; jaune	.W	H'FFFF,H'BBBB,H'0000	; orange	.W	H'FFFF,H'BBBB,H'FFFF	; rose	.W	H'FFFF,H'0000,H'FFFF	; magenta (violet)	.W	H'FFFF,H'0000,H'0000	; rouge	.W	H'0000,H'FFFF,H'FFFF	; cyan (bleu ciel)	.W	H'0000,H'0000,H'FFFF	; bleu (marine)	.W	H'0000,H'BBBB,H'0000	; vert (fonc)	.W	H'BBBB,H'0000,H'0000	; brunTDBOX_DEF:	.W	10$-TDBOX_DEF	.W	20$-TDBOX_DEF	.W	0,010$:	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,100,TDBNORM	.ASCIZ	"   GRIS   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,101,TDBNORM	.ASCIZ	"  JAUNE   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,102,TDBNORM	.ASCIZ	"  ORANGE  "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,103,TDBNORM	.ASCIZ	"   ROSE   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,104,TDBNORM	.ASCIZ	" MAGENTA  "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,105,TDBNORM	.ASCIZ	"  ROUGE   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,106,TDBNORM	.ASCIZ	"   CYAN   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,107,TDBNORM	.ASCIZ	"   BLEU   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,108,TDBNORM	.ASCIZ	"   VERT   "	.B	ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBBOX,KEYDBOX/H'100,109,TDBNORM	.ASCIZ	"   BRUN   "	.B	ODBCR2	.B	ODBTABX,12	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	" PREND "	.B	ODBTABX,35	.B	ODBLCIRCLE,BMODDEG!2^7,KEYDBOX/H'100,BMODDEG	.ASCIZ	" dgrad"	.B	ODBCR	.B	ODBTABX,35	.B	ODBLCIRCLE,BMODHSV!2^7,KEYDBOX/H'100,BMODHSV	.ASCIZ	" TSI (HSV)"	.B	ODBCR	.B	ODBBOX,0,END,TDBMEV	.ASCIZ	" TERMINE "	.B	ODBTABX,12	.B	ODBBOX,0,F6,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBTABX,35	.B	ODBLCIRCLE,BMODRGB!2^7,KEYDBOX/H'100,BMODRGB	.ASCIZ	" RVB (RGB)"	.B	ODBTABX,54	.B	ODBBOX,0,DEFINE,TDBOMBRE	.ASCIZ	"COMPLEMENT"	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Termine"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_DEF:	.W	F1,F2,F3,END,0		DOKEND-TKEY_DEF	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEF	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_DEF	.W	0;--------\\; SLDRAW  >;========/; Affiche la scroll-liste.; in	-; out	-; mod	D7.WSLDRAW:	PUSHM.L	D2,D3,D4,A3,A5	LOAD.L	A5,#(A6)+OSLVAR	LOAD.L	(A5)+OSLPOS,#H'10000*30+20	LOAD.L	(A5)+OSLDIM,#H'10000*200+270	SCROLL_	LDRAW	LOAD.L	A5,#(A6)+OSLVAR	LOAD.L	A3,#R16"SLDISPLAY	LOAD.L	(A5)+OSLADA,A3	LOAD.L	A3,#R16"TABLE-LTABLE	LOAD.W	D3,#-1CNT$:	INC.W	D3	ADD.L	A3,#LTABLE	TEST.L	(A3)	JUMP,NE CNT$	LOAD.W	(A5)+OSLCYN,D3	SCROLL_	LUPDATE	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	ADD.W	D3,D4	LOAD.W	D4,(A0)+ODFCX	ADD.W	D4,(A0)+ODFCX	ADD.W	D4,(A0)+ODFCX	LOAD.W	D2,#SETDOT	LIB	?DRRECT	CALL	SLCOLOR		; affiche les couleurs  droite	POPM.L	D2,D3,D4,A3,A5	RET;----------\\; SLDISPLAY >;----------/; Affiche une ligne dans la scroll-liste.; in	D3.W	rang de la case (0..OSLCYN-1);	D4.W	nb de caractres;	D5.W	rang du premier caractre  afficher; out	D3.W	zro; mod	D3.L, D7.WSLDISPLAY:	PUSHM.L	D4,A3	LIB	?AFSPACE	LOAD.L	A3,#R16"TABLE	MUL.WU	D3,#LTABLE	ADD.L	A3,D3	ADD.L	A3,#4+2+2+2	LOAD.W	D3,D4	SUB.W	D3,#1+1	LIB	?STRING	LIB	?AFSPACE	POPM.L	D4,A3	CLR.W	D3	RET;--------\\; SLMOVE  >;========/; Dplace la scroll-liste.; in	D4.L	position de la souris; out	D7.W	erreur; mod	D7.WSLMOVE:	PUSH.L	A5	LOAD.L	A5,#(A6)+OSLVAR	SCROLL_	LMOVE	JUMP',NE EXIT$	CALL	SLCOLOR		; affiche les couleurs  droiteEXIT$:	POP.L	A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; SLCOLOR >;========/; Affiche toutes les couleurs  droite de la scroll-liste.; in	-; out	-; mod	D7.WSLCOLOR:	PUSHM.L	D0..D5,A3,A5	LIB	?COLORPUSH	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	A5,#(A6)+OSLVAR	LOAD.L	A3,#R16"TABLE	LOAD.W	D3,(A5)+OSLCYA	MUL.WU	D3,#LTABLE	ADD.L	A3,D3	LOAD.W	D0,(A5)+OSLPOS+0	ADD.W	D0,#2	SWAP.W	D0	LOAD.W	D0,(A5)+OSLPOS+2	ADD.W	D0,(A5)+OSLDIM+2	ADD.W	D0,#2	LOAD.W	D1,(A5)+OSLNBYLOOP$:	LOAD.W	D3,(A3)+4+0	LOAD.W	D4,(A3)+4+2	LOAD.W	D5,(A3)+4+4	LIB	?COLORSA	LOAD.L	D3,D0	LOAD.W	D4,(A5)+OSLCAR+0	SUB.W	D4,#2	SWAP.W	D4	LOAD.W	D4,(A5)+OSLCAR+2	ADD.W	D4,(A5)+OSLCAR+2	ADD.W	D4,(A5)+OSLCAR+2	SUB.W	D4,#3	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	ADD.L	A3,#LTABLE	SWAP.W	D0	ADD.W	D0,(A5)+OSLCAR+0	SWAP.W	D0	DEC.W	D1	JUMP,NE LOOP$	LIB	?COLORPOP	POPM.L	D0..D5,A3,A5	RET;--------\\; SLGET   >;========/; Donne les couleurs choisies dans la scroll-liste.; in	-; out	D3.W	rouge;	D4.W	vert;	D5.W	bleu; mod	D3.L, D4.L, D5.L, D7.WSLGET:	PUSH.L	A3	LOAD.L	A3,#R16"TABLE	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	MUL.WU	D3,#LTABLE	ADD.L	A3,D3	LOAD.W	D3,(A3)+4+0	LOAD.W	D4,(A3)+4+2	LOAD.W	D5,(A3)+4+4	POP.L	A3	RET;--------\\; SLPUT   >;========/; Change les couleurs choisies dans la scroll-liste.; in	D3.W	rouge;	D4.W	vert;	D5.W	bleu; out	-; mod	D7.WSLPUT:	PUSHM.L	D2,A3	LOAD.L	A3,#R16"TABLE	LOAD.W	D2,(A6)+OSLVAR+OSLCYS	MUL.WU	D2,#LTABLE	ADD.L	A3,D2	LOAD.W	(A3)+4+0,D3	LOAD.W	(A3)+4+2,D4	LOAD.W	(A3)+4+4,D5	LOAD.L	D2,(A3)+0	CALL	LINK	POPM.L	D2,A3	RET;---------\\; DEFWRITE >;=========/; Ecrit un fichier .CLUT; in	A3.L	^nom; out	D7.W	erreur; mod	D7.WDEFWRITE:	PUSHM.L	D1..D6,A3,A4	FOS	?DELETE		; <<<<<<< PROVISOIRE !!!	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OBUFILE	LOAD.L	A3,A4	CLR.W	D1LOOP$:	CALL	DEFGET		; D3/D4/D5 <-- rouge/vert/bleu	LOAD.W	(A3+),D3	LOAD.W	(A3+),D4	LOAD.W	(A3+),D5	INC.W	D1	COMP.W	D1,#NBCOUL	JUMP,LO LOOP$	LOAD.L	D4,A3	SUB.L	D4,A4	FOS	?WRBYTE	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DEFREAD >;========/; Lit un fichier .CLUT; in	A3.L	^nom; out	D7.W	erreur; mod	D7.WDEFREAD:	PUSHM.L	D1..D6,A4	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OBUFILE	LOAD.L	D4,#LBUFILE	FOS	?RDBYTE	COMP.W	D7,#EROUTF	JUMP',NE CLOSE$	LOAD.L	D2,D4	DIV.WU	D2,#2+2+2	TEST.W	D2	JUMP',EQ OK$	CLR.W	D1LOOP$:	LOAD.W	D3,(A4+)	LOAD.W	D4,(A4+)	LOAD.W	D5,(A4+)	CALL	DEFPUT		; donne les couleurs rouge/vert/bleu	INC.W	D1	DEC.W	D2	JUMP,NE LOOP$OK$:	CLR.W	D7CLOSE$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	POPM.L	D1..D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DEFGET  >;========/; Donne les trois couleurs d'une fausse couleur.; in	D1.W	fausse couleur (0..n); out	D3.W	rouge;	D4.W	vert;	D5.W	bleu; mod	D3.L, D4.L, D5.L, D7.WDEFGET:	PUSHM.L	D1,A4	LOAD.L	A4,(A0)+ODFCPF	MUL.WU	D1,#3	ADD.L	A4,D1	LOAD.B	D3,(A4+)	; D3 <-- rouge	SL.W	D3,#8	LOAD.B	D4,(A4+)	; D4 <-- vert	SL.W	D4,#8	LOAD.B	D5,(A4+)	; D5 <-- bleu	SL.W	D5,#8	POPM.L	D1,A4	RET;--------\\; DEFPUT  >;========/; Modifie une fausse couleur.; in	D1.W	fausse couleur (0..n);	D3.W	rouge;	D4.W	vert;	D5.W	bleu; out	-; mod	D7.WDEFPUT:	PUSHM.L	D3,D6,A3	LOAD.W	D6,(A6)+OC0DIS	JUMP',EQ EXIT$	LIB	?PCHDIS		; travaille dans $DIS_20	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#COLORFALSE	CLR.W	(A3)+1	LOAD.W	(A3)+3,D1	LOAD.W	(A3)+5,D3	LOAD.W	(A3)+7,D4	LOAD.W	(A3)+9,D5	LOAD.W	D3,#11	LIB	?STRING	LOAD.W	D6,(A6)+OCNDIS	LIB	?PCHDIS		; remet $DIS_nEXIT$:	POPM.L	D3,D6,A3	RET;--------\\; RDFILE  >;========/; ; in	-; out	D7.W	erreur; mod	D7.WRDFILE:	PUSHM.L	D2..D6,A3,A4	LOAD.L	A3,#R16"NMFILE	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE EXIT$	LOAD.L	A4,#(A6)+OBUFILE	LOAD.L	D4,#LBUFILE	FOS	?RDBYTE	FOS	?CLOSE	LOAD.L	A4,#(A6)+OBUFILELOOP$:	TEST.L	(A4)	JUMP,EQ OK$	LOAD.L	D2,(A4+)	LOAD.W	D3,(A4+)	LOAD.W	D4,(A4+)	LOAD.W	D5,(A4+)	CALL	SRCRANG	JUMP,NE LOOP$	LOAD.W	(A3)+4+0,D3	LOAD.W	(A3)+4+2,D4	LOAD.W	(A3)+4+4,D5	JUMP	LOOP$OK$:	CLR.W	D7EXIT$:	POPM.L	D2..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRFILE  >;========/; ; in	-; out	D7.W	erreur; mod	D7.WWRFILE:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,#R16"TABLE	LOAD.L	A4,#(A6)+OBUFILELOOP$:	TEST.L	(A3)+0	JUMP',EQ WRITE$	LOAD.L	(A4+),(A3)+0	LOAD.W	(A4+),(A3)+4+0	LOAD.W	(A4+),(A3)+4+2	LOAD.W	(A4+),(A3)+4+4	ADD.L	A3,#LTABLE	JUMP	LOOP$WRITE$:	CLR.L	(A4+)	LOAD.L	A3,#R16"NMFILE	FOS	?DELETE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE EXIT$	LOAD.L	D4,A4	LOAD.L	A4,#(A6)+OBUFILE	SUB.L	D4,A4	FOS	?WRBYTE	FOS	?CLOSEEXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SRCRANG >;========/; ; in	D2.L	numro de couleur relative; in	A3.L	^dans TABLE;	D7.W	erreur; mod	D7.W, A3.LSRCRANG:	LOAD.L	A3,#R16"TABLE	LOAD.W	D7,#1LOOP$:	TEST.L	(A3)+0	JUMP',EQ EXIT$	COMP.L	D2,(A3)+0	JUMP',EQ OK$	ADD.L	A3,#LTABLE	JUMP	LOOP$OK$:	CLR.W	D7EXIT$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; LINKALL >;========/; Effectue le lien avec toutes les couleurs relatives.; in	-; out	-; mod	D7.WLINKALL:	PUSHM.L	D2..D5,A3	LOAD.L	A3,#R16"TABLELOOP$:	TEST.L	(A3)+0	JUMP',EQ EXIT$	LOAD.L	D2,(A3)+0	LOAD.W	D3,(A3)+4+0	LOAD.W	D4,(A3)+4+2	LOAD.W	D5,(A3)+4+4	CALL	LINK	ADD.L	A3,#LTABLE	JUMP	LOOP$EXIT$:	POPM.L	D2..D5,A3	RET;--------\\; LINK    >;========/; Effectue un lien entre une couleur relative (D2) et une; couleur absolue (D3/D4/D5).; in	D2.L	numro;	D3.W	rouge;	D4.W	vert;	D5.W	bleu; out	-; mod	D7.WLINK:	PUSHM.L	D3,D6,A3	LOAD.W	D6,(A6)+OC0DIS	JUMP',EQ EXIT$	LIB	?PCHDIS		; travaille dans $DIS_20	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#COLORLINK	LOAD.L	(A3)+1,D2	LOAD.W	(A3)+5,D3	LOAD.W	(A3)+7,D4	LOAD.W	(A3)+9,D5	LOAD.W	D3,#11	LIB	?STRING	LOAD.W	D6,(A6)+OCNDIS	LIB	?PCHDIS		; remet $DIS_nEXIT$:	POPM.L	D3,D6,A3	RET;--------\\; IFMOUSE >;========/; ; in	; out	; mod	IFMOUSE:	LIB	?IFMOUSE	JUMP',NE EXIT$	SUB.W	D4,(A0)+ODFFX	JUMP',LO EXIT$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',LO EXIT$	SWAP.W	D4EXIT$:	TEST.W	D7		; retour EQ/NE	RETDOKCR:	LOAD.W	D3,#CR	RETDOKEND:	LOAD.W	D3,#END	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETNMDBOX:	.ASCIZ	"DBOX"NMSCROLL:.ASCIZ	"SCROLL"NMFILE:	.ASCIZ	"#:COLOR.INFO"NPDIS:	.ASCIZ	"$DIS_0"	.EVENTABLE:	.L	COLOR_PPCLEAR	.W	H'FFFF,H'FFFF,H'FFFF	.ASCII	"Gnral:    fond              "	.L	COLOR_PPSET	.W	H'0000,H'0000,H'0000	.ASCII	"Gnral:    dessin            "	.L	COLOR_PPHILI	.W	H'FFFF,H'0000,H'FFFF	.ASCII	"Gnral:    mises en vidence "	.L	COLOR_PPCMOUSE	.W	H'FFFF,H'FFFF,H'0000	.ASCII	"Gnral:    pourtour souris   "	.L	COLOR_PPSMOUSE	.W	H'0000,H'0000,H'FFFF	.ASCII	"Gnral:    intrieur souris  "	.L	COLOR_MMCLEAR	.W	H'C000,H'FFFF,H'C000	.ASCII	"Menu:       fond              "	.L	COLOR_MMSET	.W	H'0000,H'0000,H'C000	.ASCII	"Menu:       contenu           "	.L	COLOR_MMCADRE	.W	H'FFFF,H'0000,H'FFFF	.ASCII	"Menu:       cadre             "	.L	COLOR_MMSEP	.W	H'0000,H'0000,H'FF00	.ASCII	"Menu:       sparations       "	.L	COLOR_DBCLEAR	.W	H'C000,H'FFFF,H'C000	.ASCII	"Dialogue:   fond              "	.L	COLOR_DBSET	.W	H'0000,H'0000,H'C000	.ASCII	"Dialogue:   contenu           "	.L	COLOR_DBCADRE	.W	H'FFFF,H'0000,H'FFFF	.ASCII	"Dialogue:   cadre             "	.L	COLOR_DBTITLE	.W	H'FFFF,H'0000,H'FFFF	.ASCII	"Dialogue:   titre             "	.L	COLOR_DBTRAME	.W	H'0000,H'FFFF,H'0000	.ASCII	"Dialogue:   trame de fond     "	.L	COLOR_DBSEL	.W	H'FFFF,H'8000,H'FFFF	.ASCII	"Dialogue:   slections        "	.L	COLOR_DBERROR	.W	H'0000,H'0000,H'0000	.ASCII	"Dialogue:   erreurs           "	.L	COLOR_DBICOCADRE	.W	H'FFFF,H'FFFF,H'FFFF	.ASCII	"Dialogue:   cadre des icnes  "	.L	COLOR_DBICODESS	.W	H'0000,H'FFFF,H'0000	.ASCII	"Dialogue:   dessin des icnes "	.L	COLOR_SCCLEAR	.W	H'FFFF,H'FFFF,H'A000	.ASCII	"Ascenseur:  fond              "	.L	COLOR_SCSET	.W	H'0000,H'0000,H'0000	.ASCII	"Ascenseur:  contenu           "	.L	COLOR_SCOBJ	.W	H'8000,H'0000,H'FFFF	.ASCII	"Ascenseur:  flches           "	.L	COLOR_SCPOS	.W	H'FFFF,H'0000,H'0000	.ASCII	"Ascenseur:  cabine            "	.L	COLOR_SCSCALE	.W	H'0000,H'0000,H'0000	.ASCII	"Ascenseur:  chelles          "	.L	COLOR_RUCLEAR	.W	H'0000,H'0000,H'0000	.ASCII	"Rgle:      fond              "	.L	COLOR_RUSET	.W	H'FF00,H'FF00,H'FF00	.ASCII	"Rgle:      contenu           "	.L	COLOR_RULINE	.W	H'FF00,H'FF00,H'FF00	.ASCII	"Rgle:      graduations       "	.L	COLOR_RUCAR	.W	H'FF00,H'FF00,H'FF00	.ASCII	"Rgle:      caractres        "	.L	COLOR_RUMARK	.W	H'FF00,H'FF00,H'FF00	.ASCII	"Rgle:      marques           "	.L	COLOR_PLNOIR	.W	H'0000,H'0000,H'0000	.ASCII	"PLAN:       noir              "	.L	COLOR_PLROUGE	.W	H'FF00,H'0000,H'0000	.ASCII	"PLAN:       rouge             "	.L	COLOR_PLVERT	.W	H'0000,H'FF00,H'0000	.ASCII	"PLAN:       vert              "	.L	COLOR_PLBLEU	.W	H'0000,H'0000,H'FF00	.ASCII	"PLAN:       bleu              "	.L	COLOR_PLVIOLET	.W	H'FF00,H'0000,H'FF00	.ASCII	"PLAN:       violet            "	.L	COLOR_PLJAUNE	.W	H'FF00,H'FF00,H'0000	.ASCII	"PLAN:       jaune             "	.L	COLOR_PLBRUN	.W	H'8000,H'0000,H'0000	.ASCII	"PLAN:       brun              "	.L	COLOR_PLBLANC	.W	H'D000,H'D000,H'D000	.ASCII	"PLAN:       blanc             "	.L	COLOR_PLINVIS	.W	H'FFFF,H'E000,H'E000	.ASCII	"PLAN:       invisible         "	.L	COLOR_DEOUTIL	.W	H'FFFF,H'8000,H'8000	.ASCII	"DESSIN:     outils            "	.L	COLOR_DEMODE	.W	H'FFFF,H'FFFF,H'8000	.ASCII	"DESSIN:     modes             "	.L	COLOR_DEOBJET	.W	H'FFFF,H'8000,H'FFFF	.ASCII	"DESSIN:     objets            "	.L	COLOR_DEMOD