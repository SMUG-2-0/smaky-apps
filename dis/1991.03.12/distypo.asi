\define g_Fond:\nef11;\g_Fond;	.CHAP	DISTYPO;--------\; AFCODE  >;========/; Affiche un caractre sans tenir compte des caractres;   ciaux.; in	D3.B	caractre  afficher;	A2.32	^description de la fentre; out	D7.W	erreur; mod	D7.WAFCODE:	PUSHM.32 D0..D5|A3|A4L10$:	MOVE.32	{A2}+ODFPGC,A3	; A3 <-- ^GENCAR; Cherche quel est le caractre  afficher, d'aprs le premier caractre; contenu dans le gnrateur (OGCFCA).	CLR.16	D0	MOVE.8	D3,D0		; D0 <-- code du caractre	COMP.8	{A3}+OGCLCA,D0	; code caractre trop grand ?	JUMP,HI L90$		; oui => 90$	SUB.8	{A3}+OGCFCA,D0	; code caractre trop petit ?	JUMP,LO L90$		; oui => 90$; Calcule la position sup/gauche et les dimensions du pav contenant; le caractre. La largeur dpend du caractre.	MOVE.32	{A2}+ODFPY,D4	; D4 <-- coordonne (y;x)	SUB.16	{A2}+ODFC1X,D4	; D4 <-- coordonne  gauche	SWAP.32	D4	SUB.16	{A2}+ODFC1Y,D4	; D4 <-- coordonne en haut	SWAP.32	D4	MOVE.16	{A2}+ODFC1Y,D2	ADD.16	{A2}+ODFC2Y,D2	; D2 <-- hauteur du caractre	SWAP.32	D2	CLR.16	D2	MOVE.32	#{A3}+OGCWID,A4	; A4 <-- ^table des largeurs	MOVE.8	{A4}+A16^{D0},D2; D2 <-- largeur du caractre; Vrifie si le caractre dborde sur la droite.	COMP.8	#GRACLIP2,{A2}+ODFMGR	JUMP,EQ	 R8^L20$	MOVE.16	D4,D1	ADD.16	D2,D1	COMP.16	{A2}+ODFFDX,D1	; dpasse  droite ?	JUMP,LO	 R8^L20$	; non => 20$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	TEST.8	{A2}+ODFMOD:#BFTRUNC	JUMP,NE L90$	CALL	DOCR		; passe  la ligne	JUMP	L10$; Vrifie si le caractre recouvre la souris, sans utiliser ITCLUTIN; pour aller plus vite !L20$:	MOVE.32	{A6}+OLSTPD,A4	; A4 <-- ^descripteur o est la souris	TEST.8	{A4}+ODFMFL:#BFMCLR ; lutin dj enlev ?	JUMP,BS	 R8^L32$	; oui => 32$	MOVE.32	D4,D5	ADD.16	{A2}+ODFWBX,D5	ADD.16	D2,D5	MOVE.16	{A4}+ODFMPO+2,D1 ; D1 <-- X min	COMP.16	D1,D5	JUMP,LO	 R8^L32$	SUB.16	D2,D5	ADD.16	{A4}+ODFMDI+2,D1 ; D1 <-- X max	COMP.16	D1,D5	JUMP,HS	 R8^L32$	SWAP.32	D2	SWAP.32	D5	ADD.16	{A2}+ODFWBY,D5	ADD.16	D2,D5	MOVE.16	{A4}+ODFMPO+0,D1 ; D1 <-- Y min	COMP.16	D1,D5	JUMP,LO	 R8^L30$	SUB.16	D2,D5	ADD.16	{A4}+ODFMDI+0,D1 ; D1 <-- Y max	COMP.16	D1,D5	JUMP,HS	 R8^L30$	CALL	CLRLUTIN	; enlve le lutin de la sourisL30$:	SWAP.32	D2; Si l'image alphanumrique existe, ne le caractre dedans.L32$:	TEST.8	{A2}+ODFFLG:#BFIMAA ; image alphanum. existe ?	JUMP,BC	 R8^L40$	; non => 40$	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE	 R8^L40$	; non => 40$				; oui =>	CALL	GPTIMA		; A4 <-- ^dans image	JUMP,NE	 R8^L40$	; si erreur => 40$	MOVE.8	D3,{A4}		; image <-- mm. caractre; Calcule les paramtres permettant d'appeler directement GRA2_RASTER, et; non GRA2_MATRIX, pour aller plus vite !L40$:	CLR.32	D3		; D3 <-- position dans source	CLR.16	D5	MOVE.8	{A3}+OGCMWB,D5	; D5 <-- incrment Y ds GENCAR	CLR.32	D1	MOVE.8	{A3}+OGCLCA,D1	SUB.8	{A3}+OGCFCA,D1	INC.8	D1		; D1 <-- nb car dans gnrateur	MOVE.32	#{A3}+OGCWID,A4	; A4 <-- ^table des largeurs	ADD.32	D1,A4		; A4 <-- skip width(s)	ADD.32	D1,A4		; A4 <-- swip heigth(s) above baseline	ADD.32	D1,A4		; A4 <-- swip heigth(s) under baseline	MUL.16	{A3}+OGCMSB,D0	; * matrix size (in bytes)	ADD.32	D0,A4		; A4 <-- ^matrix dans GENCAR	MOVE.32	A4,A3		; A3 <-- ^source	MOVE.32	#0,A4		; A4 <-- ^destination (dans l'cran)	MOVE.8	{A2}+ODFMCA,D1	; D1 <-- mode d'affichage	COMP.8	#SETDOT,D1	JUMP,NE	 R8^L50$	MOVE.8	#LOADDOT,D1L50$:	TCLR.32	D1:#BPENDOT	TEST.8	{A2}+ODFFLG:#BFVIDI ; vido inverse ?	JUMP,BC	 R8^L52$	TSET.32	D1:#BCPLDOTL52$:	TEST.8	{A2}+ODFFLG:#BFGREY ; affiche en gris ?	JUMP,BC	 R8^L53$	TSET.32	D1:#BGREDOTL53$:	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_RASTER-GRA2_FIRST)),A0	CALL	{A0}		; dessine un caractre ...	POP.32	A0; Avance la position du caractre plus loin vers la droite.	TEST.8	{A2}+ODFMOD:#BFCFIX ; chasse fixe ?	JUMP,EQ	 R8^L70$	; non => 70$	MOVE.16	{A2}+ODFCX,D2	; D2 <-- espace intercaractresL70$:	ADD.16	{A2}+ODFPX,D2	; D2 <-- nouvelle position en X	ADD.16	{A2}+ODFCIX,D2	; ajoute incrment +/-	MOVE.16	D2,{A2}+ODFPX	; mj mouvelle position en XL90$:	POPM.32	D0..D5|A3|A4	RET;--------\; AFEFEOS >;========/; Efface l'cran depuis la position actuelle du curseur; jusqu' la fin.; in	A2.L	^description fentre; out	-; mod	D7.WAFEFEOS:	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE	 R8^L10$	; non => 10$	CALL	EOSIMA		; rempli fin image de SPACEsL10$:	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_EFEOS-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_EFEOS	POP.32	A0	RET;--------\; AFEFLI  >;========/; Efface une ligne depuis la position actuelle du curseur; jusqu' la fin.; in	A2.L	^description fentre; out	-; mod	D7.WAFEFLI:	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE	 R8^L10$	; non => 10$	CALL	EFLIMA		; oui => fait aussi dans imageL10$:	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_EFLI-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_EFLI	POP.32	A0	RET	.END