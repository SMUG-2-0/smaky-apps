.CHAP	TestMachine	Dtermination de la machine pour laquelle le fichier est  assembler; Paramtres d'assemblage; -----------------------	.MACRO		Testmachine	.IF		%P=SYSSM8		=	True		; Assemblage pour SM8SM100		=	False		;SM196		=	FalseSM300		=	FalseSM324		=	FalseCOS20		=	FalseCOS21		=	False	.ENDIF	.IF		%P=100SM8		=	FalseSM100		=	True		; Assemblage pour Smaky 100SM196		=	FalseSM300		=	FalseSM324		=	FalseCOS20		=	FalseCOS21		=	False	.ENDIF	.IF		%P=196SM8		=	FalseSM100		=	FalseSM196		=	True		; Assemblage pour Smaky 196SM300		=	FalseSM324		=	FalseCOS20		=	FalseCOS21		=	False	.ENDIF	.IF		%P=300SM8		=	FalseSM100		=	FalseSM196		=	FalseSM300		=	True		; Assemblage pour Smaky 300SM324		=	FalseCOS20		=	FalseCOS21		=	False	.ENDIF	.IF		%P=324SM8		=	FalseSM100		=	FalseSM196		=	FalseSM300		=	FalseSM324		=	True		; Assemblage pour Smaky 324COS20		=	FalseCOS21		=	False	.ENDIF	.IF		%P=COSSM8		=	FalseSM100		=	FalseSM196		=	FalseSM300		=	FalseSM324		=	FalseCOS20		=	True		; Assemblage pour Costronic 20COS21		=	False	.ENDIF	.IF		%P=CO2SM8		=	FalseSM100		=	FalseSM196		=	FalseSM300		=	FalseSM324		=	FalseCOS20		=	FalseCOS21		=	True		; Assemblage pour Costronic 21	.ENDIF	.ENDMACRO.END