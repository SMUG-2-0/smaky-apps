	.TITLE	JOLIC.ASC;	--------------------------------------;		(C) 1987 - Daniel Roux;	--------------------------------------;	JOLI/D	-->	droite;	JOLI/R	-->	rectangle;	JOLI/S	-->	surface;	JOLI/C	-->	cercle;	JOLI/P	-->	petit;	JOLI/M	-->	moyen;	JOLI/G	-->	grand;	JOLI/N	-->	ngatif;	JOLI/L	-->	lent	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES; Constantes; ----------MAXFIFO	=	500LGFIFO	=	8; Variables; ---------	.LOC	0OPLCOM:	.BLKB	4		; ^ligne de commandeOMACHINE:.BLKB	1		; type de la machine (SMAKY8/SMAKY100)	.EVENOPDDIS:	.BLKB	4		; ^descripteur de la fentreOBUDIS:	.BLKB	100		; buffer write-displayOLINE:	.BLKB	4		; adresse de GRA_LINEOINV:	.BLKB	4		; adresse de GRA_INVOELLI:	.BLKB	4		; adresse de GRA_ELLIPSEOCIRC:	.BLKB	4		; adresse de GRA_CIRCLEOOBJET:	.BLKB	2		; objet (0..3)OFOND:	.BLKB	1		; ngatifOPAUSE:	.BLKB	1		; mode pauseOP1:	.BLKB	4		; P1(y;x)OP2:	.BLKB	4		; P2(y;x)OP1i:	.BLKB	4		; P1i(y;x)OP2i:	.BLKB	4		; P2i(y;x)OCOULR:	.BLKB	2		; couleur rougeOCOULG:	.BLKB	2		; couleur vertOCOULB:	.BLKB	2		; couleur bleuOINCR:	.BLKB	2		; incrment rougeOINCG:	.BLKB	2		; incrment vertOINCB:	.BLKB	2		; incrment bleuOFIFO:	.BLKB	LGFIFO*MAXFIFO	; data du fifoOHEAD:	.BLKB	2		; ^tte  (relatif)OTAIL:	.BLKB	2		; ^queue (relatif)ONB:	.BLKB	2		; nb d'lmentsOMAX:	.BLKB	2		; maximumOPMG:	.BLKB	2		; petit/moyen/grandOHAZA:	.BLKB	8		; registre 63 bits pour gnrateur alatoireLGVAR:	.LOC	0; Programme; ---------START:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LOAD.L	(A6)+OPLCOM,A320$:	LOAD.B	D3,(A3+)	JUMP',EQ 22$	COMP.B	D3,#CR	JUMP',EQ 22$	COMP.B	D3,#'/	JUMP',EQ 24$	JUMP	20$22$:	CLR.L	(A6)+OPLCOM24$:	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT1	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	JUMP,NE ERFAT1	LOAD.L	(A6)+OLINE,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	JUMP,NE ERFAT1	LOAD.L	(A6)+OINV,A3	LOAD.W	D3,#GRA_ELLIPSE	LIB_	GETAD	JUMP,NE ERFAT1	LOAD.L	(A6)+OELLI,A3	LOAD.W	D3,#GRA_CIRCLE	LIB_	GETAD	JUMP,NE ERFAT1	LOAD.L	(A6)+OCIRC,A3	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	AFCCMO		; pas de souris	.B	0	.EVEN	TEST.L	(A6)+OPLCOM	JUMP',NE 40$	LIB	?AFTIM	.B	EOP	.B	CR,CR,CR	.ASCII	"	--------------------------------------<CR>"	.ASCII	"		(C) 1987 - Daniel Roux<CR>"	.ASCII	"	--------------------------------------<CR>"	.B	0	.EVEN	LOAD.W	D4,#50	NTREL	?DELMS		; attend un peu ...40$:	LOAD.L	A3,#R16"TXMENU	LIB	?AFMENU	TEST.L	(A6)+OPLCOM	JUMP,EQ 80$	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LOAD.B	D3,#'D	LIB	?IFSWITCH	JUMP',NE 50$	LOAD.W	(A6)+OOBJET,#050$:	LOAD.B	D3,#'R	LIB	?IFSWITCH	JUMP',NE 51$	LOAD.W	(A6)+OOBJET,#151$:	LOAD.B	D3,#'S	LIB	?IFSWITCH	JUMP',NE 52$	LOAD.W	(A6)+OOBJET,#252$:	LOAD.B	D3,#'C	LIB	?IFSWITCH	JUMP',NE 53$	LOAD.W	(A6)+OOBJET,#353$:	LOAD.B	D3,#'P	LIB	?IFSWITCH	JUMP',NE 60$	LOAD.W	D3,#0	CALL	INIFIFO60$:	LOAD.B	D3,#'M	LIB	?IFSWITCH	JUMP',NE 61$	LOAD.W	D3,#1	CALL	INIFIFO61$:	LOAD.B	D3,#'G	LIB	?IFSWITCH	JUMP',NE 62$	LOAD.W	D3,#2	CALL	INIFIFO62$:	LOAD.B	D3,#'N	LIB	?IFSWITCH	JUMP',NE 70$	NOT.B	(A6)+OFOND	LOAD.W	D3,#10	LIB	?INVBARRE	INC.W	D3	LIB	?INVBARRE	INC.W	D3	LIB	?INVBARRE70$:	LOAD.B	D3,#'L	LIB	?IFSWITCH	JUMP',NE 71$	NOT.B	(A6)+OPAUSE	LOAD.W	D3,#13	LIB	?INVBARRE	INC.W	D3	LIB	?INVBARRE	INC.W	D3	LIB	?INVBARRE71$:	JUMP	NEW80$:	NOT.B	(A6)+OPAUSE	LOAD.W	D3,#13	LIB	?INVBARRE	INC.W	D3	LIB	?INVBARRE	INC.W	D3	LIB	?INVBARREOBJET:	CALL	CLRFIFO		; vide le fifoNEW:	CALL	COUPSAC		; hazard: hop, coup de sac	LOAD.W	D3,#1	LIB	?CLRBARRE	INC.W	D3	LIB	?CLRBARRE	INC.W	D3	LIB	?CLRBARRE	INC.W	D3	LIB	?CLRBARRE	LOAD.W	D3,(A6)+OOBJET	INC.W	D3	LIB	?SETBARRE	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface tout	TEST.B	(A6)+OFOND	JUMP',F	20$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.W	D2,#INVDOT	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LIB	?DRMATRIX20$:	CLR.W	D3	LOAD.W	D4,(A0)+ODFDY	CALL	MMHAZARD	LOAD.W	(A6)+OP1+0,D4	CLR.W	D3	LOAD.W	D4,(A0)+ODFDX	CALL	MMHAZARD	LOAD.W	(A6)+OP1+2,D4	CLR.W	D3	LOAD.W	D4,(A0)+ODFDY	CALL	MMHAZARD	LOAD.W	(A6)+OP2+0,D4	CLR.W	D3	LOAD.W	D4,(A0)+ODFDX	CALL	MMHAZARD	LOAD.W	(A6)+OP2+2,D4LOOP:	LIB	?IFCAR	JUMP,NE 10$	COMP.W	D3,#F0+SHIFT	JUMP',LO 02$	COMP.W	D3,#F15+SHIFT	JUMP',HI 02$	SUB.W	D3,#SHIFT02$:	COMP.W	D3,#F0	JUMP,EQ ERFAT1	COMP.W	D3,#END	JUMP,EQ ERFAT1	COMP.W	D3,#F7	JUMP,EQ 05$	COMP.W	D3,#F8	JUMP,EQ 05$	COMP.W	D3,#F9	JUMP,EQ 05$	COMP.W	D3,#F10	JUMP,EQ 06$	COMP.W	D3,#F11	JUMP,EQ 06$	COMP.W	D3,#F12	JUMP,EQ 06$	COMP.W	D3,#F13	JUMP,EQ 07$	COMP.W	D3,#F14	JUMP,EQ 07$	COMP.W	D3,#F15	JUMP,EQ 07$	COMP.W	D3,#F1	JUMP,LO 10$	COMP.W	D3,#F4	JUMP,HI 10$	SUB.W	D3,#F1	LOAD.W	(A6)+OOBJET,D3	JUMP	OBJET05$:				; petit/moyen/grand =>	SUB.W	D3,#F7	CALL	INIFIFO	JUMP	10$06$:				; ngatif =>	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.W	D2,#INVDOT	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LIB	?DRMATRIX	NOT.B	(A6)+OFOND	LOAD.W	D3,#10	LIB	?INVBARRE	INC.W	D3	LIB	?INVBARRE	INC.W	D3	LIB	?INVBARRE	JUMP	10$07$:				; pause =>	NOT.B	(A6)+OPAUSE	LOAD.W	D3,#13	LIB	?INVBARRE	INC.W	D3	LIB	?INVBARRE	INC.W	D3	LIB	?INVBARRE	JUMP	10$10$:	LOAD.L	(A6)+OP1i,(A6)+OP1	LOAD.L	(A6)+OP2i,(A6)+OP2	CLR.W	D3	LOAD.W	D4,(A0)+ODFDY	CALL	MMHAZARD	LOAD.W	(A6)+OP1+0,D4	CLR.W	D3	LOAD.W	D4,(A0)+ODFDX	CALL	MMHAZARD	LOAD.W	(A6)+OP1+2,D4	CLR.W	D3	LOAD.W	D4,(A0)+ODFDY	CALL	MMHAZARD	LOAD.W	(A6)+OP2+0,D4	CLR.W	D3	LOAD.W	D4,(A0)+ODFDX	CALL	MMHAZARD	LOAD.W	(A6)+OP2+2,D4	CLR.W	D3	LOAD.W	D4,#1000	CALL	MMHAZARD	LOAD.W	(A6)+OINCR,D4	LOAD.W	D4,#1000	CALL	MMHAZARD	LOAD.W	(A6)+OINCG,D4	LOAD.W	D4,#1000	CALL	MMHAZARD	LOAD.W	(A6)+OINCB,D4	LOAD.L	D1,(A6)+OP1	LOAD.L	D2,(A6)+OP1i	CALL	CALCLT	LOAD.W	D3,D4	LOAD.L	D1,(A6)+OP2	LOAD.L	D2,(A6)+OP2i	CALL	CALCLT	COMP.W	D4,D3	JUMP',HS 15$	LOAD.W	D4,D3		; D4 <-- MAX( Lt )15$:	CLR.W	D320$:	LOAD.L	D1,(A6)+OP1i	LOAD.L	D2,(A6)+OP1	CALL	CALCP0	LOAD.L	D5,D0	LOAD.L	D1,(A6)+OP2i	LOAD.L	D2,(A6)+OP2	CALL	CALCP0	LOAD.L	D6,D0	CALL	ONOFF	TEST.B	(A6)+OPAUSE	; mode "PAUSE" ?	JUMP',F	50$		; non => 50$				; oui =>	TEST.L	D3:#0	JUMP',BS 50$	PUSH.W	D4	LOAD.W	D4,#1	NTREL	?DELMS		; attend un peu ...	POP.W	D450$:	INC.W	D3	COMP.W	D3,D4	JUMP,LO 20$	JUMP	LOOPERFAT1:	LIB	?CLOLIB	FOS	?STOP;--------\\; ONOFF   >;========/; Met et/ou enlve un objet.; in	D5.L	P1(y;x);	D6.L	P2(y;x); out	-; mod	D7.WONOFF:	PUSHM.L	D0,D2..D410$:	LOAD.L	D1,D5	LOAD.L	D2,D6	CALL	PUTFIFO	JUMP',EQ 50$	CALL	GETFIFO	LOAD.W	D0,#CLRDOT	CALL	DESSINE		; enlve une droite	JUMP	10$50$:	LOAD.W	D0,#SETDOT	CALL	DESSINE		; met une droite	POPM.L	D0,D2..D4	RET;--------\\; DESSINE >;========/; Dessine un objet en mode inverse.; in	D0.W	mode de dessin;	D1.L	P1(y;x);	D2.L	P2(y;x); out	-; mod	D7.WDESSINE:	PUSHM.L	D1..D4,A1,A2	PUSHM.L	D3..D5	LOAD.W	D3,(A6)+OCOULR	; D3 <-- rouge	LOAD.W	D4,(A6)+OCOULG	; D4 <-- vert	LOAD.W	D5,(A6)+OCOULB	; D5 <-- bleu	LIB	?COLORSA	ADD.W	D3,(A6)+OINCR	; D3 <-- rouge	ADD.W	D4,(A6)+OINCG	; D4 <-- vert	ADD.W	D5,(A6)+OINCB	; D5 <-- bleu	LOAD.W	(A6)+OCOULR,D3	LOAD.W	(A6)+OCOULG,D4	LOAD.W	(A6)+OCOULB,D5	POPM.L	D3..D5	LOAD.W	D3,(A6)+OOBJET	COMP.W	D3,#1	JUMP,EQ RECT$	COMP.W	D3,#2	JUMP,EQ SURF$	COMP.W	D3,#3	JUMP,EQ CIRC$LINE$:	LOAD.L	D3,D1	LOAD.L	D4,D2	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	LOAD.L	A2,A0	CALL	QUICK_LINE	JUMP	EXIT$RECT$:	LOAD.L	D3,D1	LOAD.L	D4,D2	SUB.W	D3,D4	JUMP,EQ EXIT$	JUMP',NC RECTX$	NEG.W	D3	SUB.W	D4,D3RECTX$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	JUMP,EQ EXIT$	JUMP',NC RECTY$	NEG.W	D3	SUB.W	D4,D3RECTY$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	A2,A0	PUSHM.L	D3,D4	AND.L	D3,#H'FFFF	CALL	QUICK_LINE	POPM.L	D3,D4	PUSHM.L	D3,D4	CLR.W	D3	CALL	QUICK_LINE	POPM.L	D3,D4	PUSHM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D4	SWAP.W	D3	AND.L	D3,#H'FFFF	CALL	QUICK_LINE	POPM.L	D3,D4;	PUSHM.L	D3,D4	ADD.W	D4,D3	CLR.W	D3	CALL	QUICK_LINE;	POPM.L	D3,D4	JUMP	EXIT$SURF$:	LOAD.L	D3,D1	LOAD.L	D4,D2	SUB.W	D3,D4	JUMP,EQ EXIT$	JUMP',NC SURFX$	NEG.W	D3	SUB.W	D4,D3SURFX$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	JUMP,EQ EXIT$	JUMP',NC SURFY$	NEG.W	D3	SUB.W	D4,D3SURFY$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	A2,A0	LOAD.L	A1,(A6)+OINV	CALL	(A1)		; appel de GRA_INV	JUMP	EXIT$CIRC$:	LOAD.L	D3,D1	LOAD.L	D4,D2	SUB.W	D3,D4	JUMP,EQ EXIT$	JUMP',NC CIRCX$	NEG.W	D3	SUB.W	D4,D3CIRCX$:	SR.W	D3,#1	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	JUMP,EQ EXIT$	JUMP',NC CIRCY$	NEG.W	D3	SUB.W	D4,D3CIRCY$:	SR.W	D3,#1	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D2,D3	SWAP.W	D2	COMP.W	D2,D3	JUMP',HS CIRCR$	SWAP.W	D3CIRCR$:	LOAD.W	D1,D0	LOAD.W	D2,#-1	LOAD.L	A2,A0	LOAD.L	A1,(A6)+OCIRC	CALL	(A1)		; appel de GRA_CIRCLE	JUMP	EXIT$EXIT$:	POPM.L	D1..D4,A1,A2	RET; Gestion du fifo; ---------------;--------\\; CLRFIFO >;========/; Vide le FIFO.; in	-; out	-; mod	D7.WCLRFIFO:	PUSH.L	D3	CLR.W	(A6)+OHEAD	CLR.W	(A6)+OTAIL	CLR.W	(A6)+ONB	LOAD.W	D3,#1		; D3 <-- moyen	TEST.W	(A6)+OOBJET	; objet = "droite" ?	JUMP',EQ 40$		; oui => 40$	COMP.W	(A6)+OOBJET,#3	; objet = "cercle" ?	JUMP',EQ 40$		; oui => 40$	CLR.W	D3		; D3 <-- petit40$:	CALL	INIFIFO	POP.L	D3	RET;--------\\; INIFIFO >;========/; Initialise la taille maximale du fifo.; in	D3.W	petit/moyen/grand (0..2); out	-; mod	D7.WINIFIFO:	PUSHM.L	D3,D4	LOAD.W	(A6)+OPMG,D3	LOAD.W	D4,#10	TEST.W	D3	JUMP',EQ 10$	LOAD.W	D4,#200	COMP.W	D3,#1	JUMP',EQ 10$	LOAD.W	D4,#MAXFIFO10$:	LOAD.W	(A6)+OMAX,D4	LOAD.W	D4,D3	LOAD.W	D3,#7	LIB	?CLRBARRE	INC.W	D3	LIB	?CLRBARRE	INC.W	D3	LIB	?CLRBARRE	LOAD.W	D3,D4	ADD.W	D3,#7	LIB	?SETBARRE	POPM.L	D3,D4	RET;--------\\; PUTFIFO >;========/; ; in	D1/D2	 mettre dans le fifo; out	D7.W	erreur; mod	D7.WPUTFIFO:	PUSHM.L	D4,A4	LOAD.W	D7,#1	LOAD.W	D4,(A6)+ONB	COMP.W	D4,(A6)+OMAX	; fifo plein ?	JUMP',HS 90$		; oui => 90$	INC.W	(A6)+ONB	LOAD.L	A4,#(A6)+OFIFO	LOAD.W	D4,(A6)+OHEAD	LOAD.L	(A4)+(D4.W)+0,D1	LOAD.L	(A4)+(D4.W)+4,D2	ADD.W	D4,#LGFIFO	COMP.W	D4,#LGFIFO*MAXFIFO	JUMP',LO 20$	CLR.W	D420$:	LOAD.W	(A6)+OHEAD,D4	CLR.W	D790$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETFIFO >;========/; ; in	-; out	D1/D2	 mettre dans le fifo;	D7.W	erreur; mod	D1.L, D2.L, D7.WGETFIFO:	PUSHM.L	D4,A4	LOAD.W	D7,#1	TEST.W	(A6)+ONB	; fifo vide ?	JUMP',EQ 90$		; oui => 90$	DEC.W	(A6)+ONB	LOAD.L	A4,#(A6)+OFIFO	LOAD.W	D4,(A6)+OTAIL	LOAD.L	D1,(A4)+(D4.W)+0	LOAD.L	D2,(A4)+(D4.W)+4	ADD.W	D4,#LGFIFO	COMP.W	D4,#LGFIFO*MAXFIFO	JUMP',LO 20$	CLR.W	D420$:	LOAD.W	(A6)+OTAIL,D4	CLR.W	D790$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET; Routines de calcul; ------------------;--------\\; CALCLT  >;========/; Calcule l'incrment total Lt.; in	D1.L	P1(y;x);	D2.L	P2(y;x); out	D4.W	Lt [2..n]; mod	D4.LCALCLT:	PUSHM.L	D2,D3	LOAD.W	D3,D2	SUB.W	D3,D1	JUMP',NC 10$	NEG.W	D3		; D3 <-- |dx|10$:	SWAP.W	D1	SWAP.W	D2	LOAD.W	D4,D2	SUB.W	D4,D1	JUMP',NC 20$	NEG.W	D4		; D4 <-- |dy|20$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D4,D3	JUMP',HS 30$	LOAD.W	D4,D3		; D4 <-- MAX( |dx|, |dy| )30$:	LOAD.W	D2,#200	COMP.W	(A6)+OPMG,#2	; grand ?	JUMP',EQ 40$	LOAD.W	D2,#100	COMP.W	(A6)+OPMG,#1	; moyen ?	JUMP',EQ 40$	LOAD.W	D2,#5040$:	CLR.L	D3;;?	LOAD.W	D3,(A0)+ODFDYLOAD.W D3,#1000	DIV.WU	D3,D2	TEST.W	D3	JUMP',NE 50$	INC.W	D350$:	AND.L	D4,#H'FFFF	DIV.WU	D4,D3	COMP.W	D4,#2	JUMP',HS 90$	LOAD.W	D4,#290$:	POPM.L	D2,D3	RET;--------\\; CALCP0  >;========/; Calcule les coordonnes d'un point P0 plac sur la droite; P1-P2  l'incrment Li (compris entre 0 et Lt).; in	D1.L	P1(y;x);	D2.L	P2(y;x);	D3.W	Li [0..Lt];	D4.W	Lt [1..n]; out	D0.L	P0(y;x); mod	D0.LCALCP0:	PUSH.L	D5	LOAD.W	D0,D2	SUB.W	D0,D1		; D0 <-- P2-P1	MUL.WA	D0,D3		; D0 <-- (P2-P1)*Li	DIV.WA	D0,D4		; D0 <-- ((P2-P1)*Li)/Lt	ADD.W	D0,D1		; D0 <-- (((P2-P1)*Li)/Lt)+P1	SWAP.W	D1	SWAP.W	D2	LOAD.W	D5,D2	SUB.W	D5,D1		; D5 <-- P2-P1	MUL.WA	D5,D3		; D5 <-- (P2-P1)*Li	DIV.WA	D5,D4		; D5 <-- ((P2-P1)*Li)/Lt	ADD.W	D5,D1		; D5 <-- (((P2-P1)*Li)/Lt)+P1	SWAP.W	D0	LOAD.W	D0,D5	SWAP.W	D0	SWAP.W	D2	SWAP.W	D1	POP.L	D5	RET; Tirage de nombres alatoires; ----------------------------;--------\\; COUPSAC >;========/; Coup de sac pour le gnrateur alatoire.; in	-; out	-; mod	D7.WCOUPSAC:	PUSHM.L	D3,D4	LIB	?RDCLOCK	; D3/D4 <-- date et heure	RR.L	D3,#3	RL.L	D4,#7		; savante cuisine	NOT.L	D3	XOR.L	D4,D3	LOAD.L	(A6)+OHAZA+0,D3	LOAD.L	(A6)+OHAZA+4,D4	LOAD.W	D3,#10-120$:	CALL	HAZARD		; tire qq nombres	DECJ.W,NMO D3,20$	POPM.L	D3,D4	RET;---------\\; MMHAZARD >;=========/; Tire un nombre alatoire (16 bits) compris entre deux bornes.; in	D3.W	+/- borne infrieure (min);	D4.W	+/- borne suprieure (max+1); out	D4.W	+/- nombre alatoire: D3 <= n < D4; mod	D4.L, D7.WMMHAZARD:	PUSH.W	D2	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- sup - inf	CALL	HAZARD	AND.L	D4,#H'FFFF	DIV.WU	D4,D2	SWAP.W	D4		; D4 <-- reste de la division	ADD.W	D4,D3	POP.W	D2	RET;--------\\; HAZARD  >;========/; Tire un nombre alatoire de 32 bits.; On utilise un registre  dcalage de 63 bits, avec un XNOR entre; les bits 0 et 60 pour calculer le nouveau bit inject.; in	-; out	D4.L	nombre; mod	D4.L, D7.WHAZARD:	PUSHM.L	D2,D3	LOAD.W	D2,#32-1	LOAD.L	D3,(A6)+OHAZA+0	LOAD.L	D4,(A6)+OHAZA+410$:	TEST.L	D4:#1	JUMP,BC 20$	TEST.L	D3:#30	JUMP,BC 35$	JUMP	30$20$:	TEST.L	D3:#30	JUMP,BS 35$30$:	CLRX	RRX.L	D3,#1	RRX.L	D4,#1	JUMP	40$35$:	SETX	RRX.L	D3,#1	RRX.L	D4,#140$:	LOAD.L	(A6)+OHAZA+0,D3	LOAD.L	(A6)+OHAZA+4,D4	DECJ.W,NMO D2,10$	POPM.L	D2,D3	RET; Routine de droite ultra-rapide; ------------------------------;LINE_INCX:	.MACRO	LINE_INCX	.LOCALMACRO END	DEC.B	D0		; x <-- x+1	JUMP',PL END	LOAD.B	D0,#7	ADD.W	A0,D3END:	.ENDMACRO;LINE_DECX:	.MACRO	LINE_DECX	.LOCALMACRO END	INC.B	D0		; x <-- x-1	COMP.B	D0,#8	JUMP',LT END	CLR.B	D0	SUB.W	A0,D3END:	.ENDMACRO;LINE_INCY:	.MACRO	LINE_INCY	.LOCALMACRO END	ADD.W	A0,D4		; y <-- y+1END:	.ENDMACRO;LINE_DECY:	.MACRO	LINE_DECY	.LOCALMACRO END	SUB.W	A0,D4		; y <-- y-1END:	.ENDMACRO;-----------\; QUICK_LINE >;===========/; Trace un segment de droite trs rapidement.; in	A2.L	^description de la fentre;	D4.L	origine Y;X;	D3.L	longueur dY;dX;	D0.W	mode de dessin; out	-; mod	D7.WQUICK_LINE:	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP',NE 03$		; oui => 03$	COMP.B	(A6)+OMACHINE,#SMAKY8	JUMP',NE 05$	JUMP'	03$02$:	SWAP.W	D303$:				; SMAKY8 =>	PUSHM.L	D1,A1	LOAD.W	D1,D0	LOAD.L	A1,(A6)+OLINE	CALL	(A1)		; appel de GRA_LINE	POPM.L	D1,A1	RET05$:	TEST.W	D3	JUMP,EQ 03$	SWAP.W	D3	TEST.W	D3	JUMP,EQ 02$	SWAP.W	D3	PUSHM.L	D0..D6,A0	TEST.L	D3		; dX et dY nuls ?	JUMP,EQ SEGFIN		; oui => ne fait rien; Forme le pointeur sur la position mmoire de l'cran; contenant le point d'origine.	LOAD.W	D5,D3		; D5 <-- dx	SWAP.W	D3	LOAD.W	D6,D3		; D6 <-- dy	LOAD.W	D3,D4		; D3 <-- coordonne X relative	SWAP.W	D4		; D4 <-- coordonne Y relative	ADD.W	D3,(A2)+ODFWBX	; D3 <-- coordonne x absolue dans bitmap	ADD.W	D4,(A2)+ODFWBY	; D4 <-- coordonne y absolue dans bitmap	LOAD.B	D0,D3	NOT.B	D0		; bits inverss (7..0) !	AND.W	D0,#B'111	; D0 <-- no du bit dans le byte	LOAD.L	A0,(A2)+ODFABS	; A0 <-- adresse dbut cran	SR.W	D3,#3		; dcale coordonne X	ADD.W	A0,D3	MUL.WU	D4,(A2)+ODFIIY	; dcale coordonne Y	ADD.L	A0,D4		; A0 <-- adresse dans l'cran	LOAD.W	D3,(A2)+ODFIIX	; D3 <-- Ix	LOAD.W	D4,(A2)+ODFIIY	; D4 <-- Iy	LOAD.W	D2,D5		; D2 <-- dx	JUMP',PL 10$	NEG.W	D2		; D2 <-- !dx!10$:	LOAD.W	D1,D6		; D1 <-- dy	JUMP',PL 20$	NEG.W	D1		; D1 <-- !dy!20$:	COMP.W	D2,D1		; COMP  !dx! , !dy!	JUMP',LO 50$	TEST.W	D5	JUMP',MI 30$	TEST.W	D6	JUMP,PL SEG1	JUMP	SEG830$:	TEST.W	D6	JUMP,PL SEG4	JUMP	SEG550$:	TEST.W	D5	JUMP',MI 60$	TEST.W	D6	JUMP,PL SEG2	JUMP	SEG760$:	TEST.W	D6	JUMP,PL SEG3	JUMP	SEG6; Trace un segment de droite dans un huitime de cadrant.;		!;		!;	   SEG6	! SEG7;		!;	 SEG5	!   SEG8;	--------!--------> X;	 SEG4	!   SEG1;		!;	   SEG3	! SEG2;		!;	       \!/ Y; in	A0.L	^byte contenant le point;	D0.B	numro du bit dans le byte (0..7);	D5.W	delta x;	D6.W	delta y;	D3.W	Ix;	D4.W	Iy; use	D1	compteur (c);	D2	correction des erreurs (e); mod	D0,D1,D2,A0SEG1:	LOAD.W	D2,D5	ASR.W	D2,#1	NEG.W	D2		; e <-- -dx/2	LOAD.W	D1,D5		; c <-- dx	DEC.W	D110$:	TNOT.B	(A0):D0		; inverse un point	LINE_INCX		; x <-- x+1	ADD.W	D2,D6		; e <-- e+dy	JUMP',MI 20$	LINE_INCY		; y <-- y+1	SUB.W	D2,D5		; e <-- e-dx20$:	DECJ.W,NMO D1,10$	JUMP	SEGFINSEG2:	LOAD.W	D2,D6	ASR.W	D2,#1	NEG.W	D2		; e <-- -dy/2	LOAD.W	D1,D6		; c <-- dy	DEC.W	D110$:	TNOT.B	(A0):D0		; inverse un point	LINE_INCY		; y <-- y+1	ADD.W	D2,D5		; e <-- e+dx	JUMP',MI 20$	LINE_INCX		; x <-- x+1	SUB.W	D2,D6		; e <-- e-dy20$:	DECJ.W,NMO D1,10$	JUMP	SEGFINSEG3:	LOAD.W	D2,D6	ASR.W	D2,#1	NEG.W	D2		; e <-- -dy/2	LOAD.W	D1,D6		; c <-- dy	DEC.W	D110$:	TNOT.B	(A0):D0		; inverse un point	LINE_INCY		; y <-- y+1	SUB.W	D2,D5		; e <-- e-dx	JUMP',MI 20$	LINE_DECX		; y <-- x-1	SUB.W	D2,D6		; e <-- e-dy20$:	DECJ.W,NMO D1,10$	JUMP	SEGFINSEG4:	LOAD.W	D2,D5	ASR.W	D2,#1		; e <-- dx/2	LOAD.W	D1,D5		; c <-- dx10$:	TNOT.B	(A0):D0		; inverse un point	LINE_DECX		; x <-- x-1	ADD.W	D2,D6		; e <-- e+dy	JUMP',MI 20$	LINE_INCY		; y <-- y+1	ADD.W	D2,D5		; e <-- e+dx20$:	INC.W	D1	JUMP',NE 10$	JUMP	SEGFINSEG5:	LOAD.W	D2,D5	ASR.W	D2,#1		; e <-- dx/2	LOAD.W	D1,D5		; c <-- dx10$:	TNOT.B	(A0):D0		; inverse un point	LINE_DECX		; x <-- x-1	SUB.W	D2,D6		; e <-- e-dy	JUMP',MI 20$	LINE_DECY		; y <-- y-1	ADD.W	D2,D5		; e <-- e+dx20$:	INC.W	D1	JUMP,NE 10$	JUMP	SEGFINSEG6:	LOAD.W	D2,D6	ASR.W	D2,#1		; e <-- dy/2	LOAD.W	D1,D6		; c <-- dy10$:	TNOT.B	(A0):D0		; inverse un point	LINE_DECY		; y <-- y-1	SUB.W	D2,D5		; e <-- e-dx	JUMP',MI 20$	LINE_DECX		; x <-- x-1	ADD.W	D2,D6		; e <-- e+dy20$:	INC.W	D1	JUMP,NE 10$	JUMP	SEGFINSEG7:	LOAD.W	D2,D6	ASR.W	D2,#1		; e <-- dy/2	LOAD.W	D1,D6		; c <-- dy10$:	TNOT.B	(A0):D0		; inverse un point	LINE_DECY		; y <-- y-1	ADD.W	D2,D5		; e <-- e+dx	JUMP',MI 20$	LINE_INCX		; x <-- x+1	ADD.W	D2,D6		; e <-- e+dy20$:	INC.W	D1	JUMP,NE 10$	JUMP	SEGFINSEG8:	LOAD.W	D2,D5	ASR.W	D2,#1	NEG.W	D2		; e <-- -dx/2	LOAD.W	D1,D5		; c <-- dx	DEC.W	D110$:	TNOT.B	(A0):D0		; inverse un point	LINE_INCX		; x <-- x+1	SUB.W	D2,D6		; e <-- e-dy	JUMP',MI 20$	LINE_DECY		; y <-- y-1	SUB.W	D2,D5		; e <-- e-dx20$:	DECJ.W,NMO D1,10$;	JUMP	SEGFINSEGFIN:	POPM.L	D0..D6,A0	RETTXMENU:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"    Rectangle    "	.ASCIZ	"Droite    Surface"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Cercle           "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Petit Moyen Grand"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Ngatif"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Lent"		;     ;     ;     ;	.END	START