	.CHAP	DISCOLOR;----------\\; COLORPUSH >;==========/; Sauve les couleurs pour dessiner et pour effacer sur le stack.; in	-; out	D7.W	erreur; mod	D7.WCOLORPUSH:	PUSHM.32 D4|A4	MOVE.16	#ERDIOUT,D7	; D7 <-- y'a trop !.IF	Color300	TEST.8	{A2}+ODFCMD	JUMP,F	L90$.ENDIF	Color300	MOVE.16	{A2}+ODFCNS,D4	COMP.16	{A2}+ODFCMS,D4	; stack tout plein ?	JUMP,HS	 R8^L90$	; oui => 90$	MOVE.32	{A2}+ODFCPS,A4	SL.16	#3,D4		; D4 <-- *(4+2)	ADD.A16	D4,A4		; A4 <-- ^lment sur le stack	MOVE.32	{A2}+ODFCSF,{A4}+0 ; stack <-- fausse couleur pour dessiner	MOVE.32	{A2}+ODFCCF,{A4}+4 ; stack <-- fausse couleur pour effacer	INC.16	{A2}+ODFCNS	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D4|A4	RET;---------\\; COLORPOP >;=========/; Reprend sur le stack les couleurs pour dessiner et pour effacer.; in	-; out	D7.W	erreur; mod	D7.WCOLORPOP:	PUSHM.32 D4|A4	MOVE.16	#ERDIOUT,D7	; D7 <-- c'est vide !.IF	Color300	TEST.8	{A2}+ODFCMD	JUMP,F	L90$.ENDIF	Color300	MOVE.16	{A2}+ODFCNS,D4	JUMP,EQ	 R8^L90$	; stack vide => 90$	DEC.16	D4	MOVE.16	D4,{A2}+ODFCNS	MOVE.32	{A2}+ODFCPS,A4	SL.16	#3,D4		; D4 <-- *(4+2)	ADD.A16	D4,A4		; A4 <-- ^lment sur le stack	MOVE.32	{A4}+0,{A2}+ODFCSF ; remet fausse couleur pour dessiner	MOVE.32	{A4}+4,{A2}+ODFCCF ; remet fausse couleur pour effacer	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D4|A4	RET;------------\\; COLORRELSRC >;------------/; Cherche rapidement une couleur relative, par bissection.; in	D4.L	couleur relative; out	D7.W	ok;	 A3.32	 ^dans OCOLRx;	 D3.16	 rang;	D7.16	erreur;	 A3.32	 ^dans OCOLRx o insrer;	 D3.16	 rang; mod	D3.L, D7.W, A3.LCOLORRELSRC:	PUSHM.32 D0..D2|A2.IF	Color300	MOVE.32	{A6}+OPdFen,A2	; A2 ^descripteur $Dis_0	MOVE.16	#ErDiOut,D7	TEST.8	{A2}+ODFCMD	JUMP,F	L90$.ENDIF	Color300; Cherche rapidement la couleur par bissection.	MOVE.32	{A2}+ODFCPR,A3	; A3 <-- ^table des couleurs relatives	CLR.16	D2	CLR.16	D0		; D0 <-- borne infrieure	MOVE.16	{A2}+ODFCNR,D1	; D1 <-- borne suprieure	JUMP,EQ L50$L20$:	MOVE.16	D1,D2	SUB.16	D0,D2	SR.16	#1,D2	ADD.16	D0,D2		; D2 <-- entre les deux bornes	COMP.16	D2,D0		; borne infrieure juste avant borne suprieure ?	JUMP,EQ	 R8^L40$	; oui => 40$	MOVE.16	D2,D3	SL.16	#3,D3		; MUL D3,#LCOLR	COMP.32	{A3}+A16^{D3}+OCOLRN,D4	JUMP,EQ	 R8^L70$	JUMP,LO	 R8^L30$				; plus grand =>	MOVE.16	D2,D0		; borne infrieure <-- milieu	JUMP	L20$L30$:				; plus petit =>	MOVE.16	D2,D1		; borne suprieure <-- milieu	JUMP	L20$L40$:	MOVE.16	D2,D3	SL.16	#3,D3		; MUL D3,#LCOLR	COMP.32	{A3}+A16^{D3}+OCOLRN,D4	JUMP,EQ	 R8^L70$	JUMP,LO	 R8^L50$	INC.16	D2L50$:	MOVE.16	D2,D3	SL.16	#3,D3		; MUL D3,#LCOLR	ADD.A16	D3,A3		; A3 <-- ^OCOLRx	MOVE.16	D2,D3		; D3 <-- rang	MOVE.16	#ERDIOUT,D7	; D7 <-- pas trouv	JUMP	R8^L90$L70$:	ADD.A16	D3,A3		; A3 <-- ^OCOLRx	MOVE.16	D2,D3		; D3 <-- rang	CLR.16	D7		; D7 <-- trouvL90$:	POPM.32	D0..D2|A2	TEST.16	D7		; retour EQ/NE	RET;------------\\; COLORRELADD >;------------/; Ajoute une couleur dans la table, en poussant tous les lments suivants.; in	D4.L	couleur relative;	A3.32	^dans OCOLRx o insrer;	D3.16	rang; out	D7.W	erreur; mod	D7.WCOLORRELADD:	PUSHM.32 D2|D3|A3|A4|A2.IF	Color300	MOVE.32	{A6}+OPDFen,A2	MOVE.16	#ErDiOut,D7	TEST.8	{A2}+ODFCMD	JUMP,F	R8^L90$.ENDIF	Color300	MOVE.16	#ERDIOUT,D7	; D7 <-- c'est plein	MOVE.16	{A2}+ODFCNR,D2	COMP.16	{A2}+ODFCMR,D2	; table pleine ?	JUMP,HS	 R8^L90$	; oui => 90$	SUB.16	D3,D2	JUMP,EQ	 R8^L40$	MOVE.16	D2,D3	SL.16	#3,D3		; MUL D3,#LCOLR	ADD.A16	D3,A3	MOVE.32	#{A3}+LCOLR,A4	DEC.16	D2		; D2 <-- -1  cause NMOL20$:	MOVE.32	{-A3},{-A4}	MOVE.32	{-A3},{-A4}	; 2x LOAD.L = LCOLR !	DJ.16,NMO  D2,L20$L40$:	MOVE.32	D4,{A3}+OCOLRN	CLR.32	{A3}+OCOLRR	INC.16	{A2}+ODFCNR	; une couleur de plus	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D2|D3|A3|A4|A2	TEST.16	D7		; retour EQ/NE	RET;------------\\; COLORRELSUB >;------------/; Supprime une couleur dans la table, en compressant tous les lments suivants.; in	A3.L	^dans OCOLRx;	D3.16	rang; out	D7.W	erreur; mod	D7.WCOLORRELSUB:	PUSHM.32 D2|D3|A3|A4|A2.IF	Color300	MOVE.32	{A6}+OPdFen,A2	MOVE.16	#ErDiOut,D7	TEST.8	{A2}+ODFCMD	JUMP,F	R8^L90$.ENDIF	Color300	MOVE.16	#ERDIOUT,D7	; D7 <-- c'est vide	MOVE.16	{A2}+ODFCNR,D2	JUMP,EQ	 R8^L90$	; oui => 90$	SUB.16	D3,D2	JUMP,EQ	 R8^L90$	DEC.16	D2	JUMP,EQ	 R8^L40$	MOVE.32	#{A3}+LCOLR,A4	DEC.16	D2		; D2 <-- -1  cause NMOL20$:	MOVE.32	{A4+},{A3+}	MOVE.32	{A4+},{A3+}	; 2x LOAD.L = LCOLR !	DJ.16,NMO  D2,L20$L40$:	DEC.16	{A2}+ODFCNR	; une couleur de moins	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D2|D3|A3|A4	TEST.16	D7		; retour EQ/NE	RET;------------\\; COLORFAUSRC >;------------/; Cherche la couleur la plus proche dans la table des fausses couleurs.;	  = MIN( |R-R'| + |G-G'| + |B-B'| ); in	D3.L	couleur |R|G|B|x|; out	D4.L	fausse couleur (0..ODFCNB-1);	A4.32	^dans la table (OCOLFx); mod	D4.L, D7.W, A4.LCOLORFAUSRC:	PUSHM.32 D0..D3|D5|D6|A3|A2|A5	RL.32	#8,D3	MOVE.8	D3,D0		; D0 <-- rouge (R)	RL.32	#8,D3	MOVE.8	D3,D1		; D1 <-- vert (G)	RL.32	#8,D3	MOVE.8	D3,D2		; D0 <-- bleu (B).IF	Color300	TEST.8	{A2}+ODFCMD	; Mode couleur ?	JUMP,F	BWMode$		; Non => on rend "0".ENDIF	Color300	MOVE.32	{A2}+ODFCPF,A4	; A4 <-- ^table des fausses couleurs	MOVE.16	{A2}+ODFCNB,D3	; D3 <-- nombre de fausses couleurs	MOVE.16	#-1,D6		; D6 <-- cart minimalL10$:	CLR.16	D4	MOVE.8	D0,D4	CLR.16	D5	MOVE.8	{A4}+OColFR,D5	SUB.16	D5,D4	JUMP,NC	 R8^L20$	NEG.16	D4		; D4 <-- |R-R'|L20$:	MOVE.A16 D4,A5	MOVE.8	D1,D4	MOVE.8	{A4}+OColFG,D5	SUB.16	D5,D4	JUMP,NC	 R8^L22$	NEG.16	D4		; D4 <-- |G-G'|L22$:	ADD.A16	D4,A5	MOVE.8	D2,D4	MOVE.8	{A4}+OColFB,D5	SUB.16	D5,D4	JUMP,NC	 R8^L24$	NEG.16	D4		; D4 <-- |B-B'|L24$:	ADD.A16	D4,A5	MOVE.16	A5,D5	TEST.16	D5	JUMP,EQ	 R8^L80$	; si somme nulle => 80$ (parfait)	COMP.16	D5,D6		; cart plus petit ?	JUMP,LS	 R8^L50$	; non => 50$				; oui =>	MOVE.16	D5,D6		; D6 <-- cart minimal	SWAP.32	D6	MOVE.16	D3,D6		; D6-high <-- meilleur choix	SWAP.32	D6	MOVE.32	A4,A3		; A3 <-- ^meilleur choixL50$:	ADD.32	#LCOLF,A4	; A4 <-- fausse couleur suivante	DEC.16	D3	JUMP,NE L10$	SWAP.32	D6	MOVE.16	D6,D3		; D3 <-- meilleur choix	MOVE.32	A3,A4		; A4 <-- ^meilleur choixL80$:	CLR.32	D4	MOVE.16	{A2}+ODFCNB,D4	SUB.16	D3,D4		; D4 <-- fausse couleur.IF	Color300	JUMP	R8^Exit$BWMode$:	CLR.32	D4Exit$:.ENDIF	Color300	POPM.32	D0..D3|D5|D6|A3|A2|A5	RET.IF	Color300;-------------\\; WaitPalette  >;-------------/; Attente entre deux accs  la palette de fausses couleurs; Inmos IMSG171.; In:	-; Out:	-; Mod:	FWaitPalette:	RR.8	#8,D0	RR.8	#8,D0	RR.8	#8,D0	RR.8	#8,D0	RET;---------\\; SetCLUT  >;---------/; Initialise la palette des fausses couleurs Inmos 171; selon {A2}+ODFCPF.; In:	A2 ^descripteur de fentre; Out:	-; Mod:	FSetCLUT:	PUSHM.32 A0|D0..D2	TEST.8	{A2}+ODFCMD	JUMP,F	R8^Exit$	MOVE.8	#2'00001111,Ad171Mask			; Seulement 4 bits	CALL	WaitPalette	MOVE.32	{A2}+ODFCPF,A0				; A0 ^palette  charger	CLR.32	D0					; Index	MOVE.32	#16-1,D1				; DcompteurLoop$:	MOVE.8	D0,Ad171WrAddr				; Charge l'index.	CALL	WaitPalette	MOVE.8	{A0+},D2	SR.8	#2,D2	MOVE.8	D2,Ad171Data	CALL	WaitPalette	MOVE.8	{A0+},D2	SR.8	#2,D2	MOVE.8	D2,Ad171Data	CALL	WaitPalette	MOVE.8	{A0+},D2	SR.8	#2,D2	MOVE.8	D2,Ad171Data	CALL	WaitPalette	INC.8	D0	DJ.16,NMO D1,Loop$Exit$:	POPM.32 A0|D0..D2	RET.ENDIF	Color300	.END