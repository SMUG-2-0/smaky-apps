	.SBTTL	PALDBOX.ASI;-----------\\; DBOXEDITIF >;===========/; Edite un nom de fichier en entre (prend).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITIF:	PUSHM.L	D1,D2,D5,A2..A5	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TFEXT	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...90$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEDITOF >;===========/; Edite un nom de fichier en sortie (sauve).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F0/F1/F4);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITOF:	PUSHM.L	D1,D2,D5,A2..A5	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TFEXT	LOAD.W	D1,#DBOX_EXTRAIT ; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...90$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RETTFEXT:	.ASCIZ	".CLUT"TDBOX_IO:	.ASCIZ	"PALETTE"	; nom du logiciel	.ASCIZ	"Ftable des couleurs" ; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN	.END