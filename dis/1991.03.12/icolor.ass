	.TITLE		ICOLOR.ASS;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------	.PROC		M68000				; mnmonics CALM	.BASE		10'10				; base 10 par dfaut;	.LAYOUT		HEX				; listing en hexadcimal; Constantes utiles; -----------------BICCRET	=	16		; charge le fichier .CRETBICCLUT	=	17		; charge le fichier .CLUTBICMTEXT=	18		; affiche le texte du nom de la couleurBICMEDIT=	19		; dite le nom de la couleurBICMPAL	=	24		; modifie: paletteBICMRGB	=	25		; modifie: RGBBICMHSV	=	26		; modifie: HSVBICMDEG	=	27		; modifie: dgradBICCSPEC=	0		; conversion spciale; Numros des appels; ------------------	.SYSCALL.16	ICOL_ICOL_INIT	=	16'AAD0ICOL_MODRGB	=	16'AAD1ICOL_MODCRET	=	16'AAD2ICOL_MODCLUT	=	16'AAD3ICOL_RGBHSV	=	16'AAD4ICOL_HSVRGB	=	16'AAD5ICOL_CONVC	=	16'AAD6ICOL_CONVNB	=	16'AAD7ICOL_FIRST	=	ICOL_INITICOL_LAST	=	ICOL_CONVNB;-----------\\; _ICOL_INIT >;===========/; Initialise CLUT/CRET pour un logiciel donn.; Effectue la lecture du fichier suivant :;	si BICCRET	nom.CRET  -->	CLUT+CRET;	si BICCLUT	nom.CLUT  -->	CLUT; Ne pas mettre BICCRET et BICCLUT (l'un ou l'autre) !; in	A0.L	^descripteur fentre;	A3.L	^nom du logiciel (DESSIN4, PAGE, etc.);	D3.L	mode (BIC*);		 BICCRET --> charge le fichier .CRET;		 BICCLUT --> charge le fichier .CLUT;		 BTCGLOB --> CLUT/CRET globale;	A5.L	^table des textes pour la CRET (*); out	D5.L	identificateur CRET (zro si rien)	(si D3:#BICCRET);	D7.W	erreur; mod	D5.L, D7.W;--------------\\; _ICOL_MODCLUT >;==============/; Modifie la palette des couleurs (CLUT).; in	A0.L	^descripteur fentre;	D4.L	mode (BTC*);		 BICMDEG --> dgrads;		 BICMRGB --> ascenseurs RGB;		 BICMHSV --> ascenseurs HSV;		 BTCGLOB --> si CLUT globale; out	D7.W	erreur; mod	D7.W;--------------\\; _ICOL_MODCRET >;==============/; Modifie une ou plusieurs couleurs d'une CRET.; in	A0.L	^descripteur fentre;	D4.L	mode (BIC*);		 BICMPAL --> palette;		 BICMRGB --> ascenseurs RGB;		 BICMHSV --> ascenseurs HSV;		 BTCGLOB --> si CRET globale;	D5.L	identificateur CRET;	A3.L	^nom du logiciel (DESSIN4, PAGE, etc.);	A5.L	^table des textes pour la CRET (*); out	D4.L	mode (BIC*);	D5.L	identificateur CRET (!);	D7.W	erreur; mod	D4.L, D5.L, D7.W;-------------\\; _ICOL_MODRGB >;=============/; Choix d'une couleur dans la palette des couleurs disponibles.; in	A0.L	^descripteur fentre;	D4.L	mode (BIC*);		 BICMPAL  --> palette;		 BICMRGB  --> ascenseurs RGB;		 BICMHSV  --> ascenseurs HSV;		 BICMTEXT --> affiche le nom de la couleur;		 BICMEDIT --> dite le nom de la couleur;		 BTCGLOB  --> si CLUT globale;	A4.L	^couleur initiale RGB;	A3.L	^texte	(si D3:#BICMTEXT);	A3.L	^nom	(si D3:#BICMEDIT); out	D3.W	dernire touche (F1/F0);	D4.L	mode (BIC*);	(A4)+	couleur modifie RGB;	(A3)+	nom	(si D3:#BICMEDIT);	D7.W	erreur; mod	D3.L, D4.L, D7.W; (*)	Format de la table pointe par A5.L :;;	.L	numro		; numro de la couleur relative (>H'8000);	.W	R,G,B		; RGB par dfaut;	.ASCIZE	"nom"		; nom (lg max=40 caractres);;	...;;	.L	0		; terminateur;-------------\\; _ICOL_RGBHSV >;=============/; Conversion RGB --> HSV.; in	A4.L	^couleur RGB [0..65535,0..65535,0..65535];	A3.L	^buffer pour HSV; out	(A3)+	couleur HSV [0..359,0..255,0..255]; mod	D7.W;-------------\\; _ICOL_HSVRGB >;=============/; Conversion HSV --> RGB.; in	A4.L	^couleur HSV [0..359,0..255,0..255];	A3.L	^buffer pour RGB; out	(A3)+	couleur RGB [0..65535,0..65535,0..65535]; mod	D7.W;------------\\; _ICOL_CONVC >;============/; Conversion des couleurs d'une zone rectangulaire d'un bitmap couleur.; Si BICCSPEC=0, la conversion tente de faire correspondre les couleurs; du bitmap avec celles de la CLUT active (fentre).; in	D2.L	mode (BICC*);	A4.L	^bitmap couleur;	D3.L	coin sup/gauche (y;x);	D4.L	coin inf/droite (y;x);	D5.W	Iy bitmap;	D6.W	nb de bits/pixel (#4);	A0.L	^descripteur fentre;	A3.L	^CLUT du bitmap  (si D2<>BICCSPEC);	A3.L	^table du filtre (si D2:#BICCSPEC); out	D7.W	erreur; mod	D7.W;-------------\\; _ICOL_CONVNB >;=============/; Conversion d'une matrice couleur en matrice noir/blanc.; Les couleurs sont simules par des trames 8x8 dont l'intensit; varie en fonction de l'intensit de la couleur (i=R+G+B).; in	D2.L	mode (BICC*);	A4.L	^image couleur;	D4.L	dimensions (dy;dx);	D5.W	Iy bitmap;	A5.L	^buffer pour image noir/blanc;	D6.W	nb de bits/pixel (#4);	A0.L	^descripteur fentre;	A2.L	^table du filtre (si D2:#BICCSPEC);	A3.L	^trames 8x8      (si D2:#BICCSPEC); out	D7.W	erreur; mod	D7.W	.END