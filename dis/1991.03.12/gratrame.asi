	.SBTTL	GRATRAME; Variables de GRA_TRAME sur le stack; -----------------------------------TRAMMA1	=	0		; masque de dbutTRAMNBW	=	TRAMMA1+2	; nb de words -1TRAMMOT	=	TRAMNBW+2	; trame tendue (32x16)TRAMLGV	=	TRAMMOT+64	; lg des variables;-----------\; _GRA_TRAME >;===========/; Rempli une surface rectangulaire avec une trame 8x8.; La trame est toujours aligne (horizontalement et verticalement);  une position modulo 8 pour rsoudre les problmes de jointures; entre deux trames.; in	A2.L	^description de la fentre;	D4.L	coordonnes y;x dbut (coin sup/gauche);	D3.L	delta y;x;	D1.B	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT);	A4.L	^trame 8x8; out	D7.W	erreur; mod	D7.W_GRA_TRAME:	PUSHM.L	D0..D6,A0..A6; Effectue ventuellement un clipping si le rectangle dborde.	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la fentre	TEST.W	D3	JUMP,LE TRAME_EXIT	TEST.W	D4		; dpasse  gauche ?	JUMP',NC NoLeft$	ADD.W	D3,D4	JUMP,LE TRAME_EXIT	CLR.W	D4NoLeft$:	LOAD.W	D0,D4	ADD.W	D0,D3	SUB.W	D0,(A2)+ODFFDX	; dpasse  droite ?	JUMP',LS NoRight$	SUB.W	D3,D0	JUMP,LE TRAME_EXITNoRight$:	SWAP.W	D3	SWAP.W	D4	TEST.W	D3	JUMP,LE TRAME_EXIT	TEST.W	D4		; dpasse en haut ?	JUMP',NC NoUp$	ADD.W	D3,D4	JUMP,LE TRAME_EXIT	CLR.W	D4NoUp$:	LOAD.W	D0,D4	ADD.W	D0,D3	SUB.W	D0,(A2)+ODFFDY	; dpasse en bas ?	JUMP',LS NoDown$	SUB.W	D3,D0	JUMP,LE TRAME_EXITNoDown$:	SWAP.W	D3	SWAP.W	D4	TEST.L	(A2)+ODFTPM	; trame spciale ?	JUMP,NE TRAME_SPEC	; oui => TRAME_SPEC; Etend la trame 8x8 en une trame 32x16.	SUB.L	SP,#TRAMLGV	; stack <-- place pour variables	CLR.B	D6		; D6 <-- pas d'inversion	TEST.L	D1:#BCPLDOT	JUMP',BC 10$	NOT.B	D6		; D6 <-- inverse la trame10$:	AND.W	D1,#H'0003	; D1 <-- mode LOAD/INV/SET/CLR	COMP.B	D1,#CLRDOT	JUMP',NE 12$	NOT.B	D6		; D6 <-- inverse la trame si CLRDOT !12$:	LOAD.W	D7,(A2)+ODFFX	AND.W	D7,#H'0007	; D7 <-- dcalage selon origine fentre en X	LOAD.L	A3,#(SP)+TRAMMOT	LOAD.W	D5,#8-114$:	LOAD.B	D0,(A4+)	; D0 <-- un byte de la trame	RR.B	D0,D7		; D0 <-- v. dcale selon origine fentre	XOR.B	D0,D6		; D0 <-- v. inverse	LOAD.B	(A3+),D0	LOAD.B	(A3+),D0	LOAD.W	(A3+),(A3)-2	LOAD.L	(A3)+32-4,(A3)-4	DECJ.W,NMO D5,14$	LOAD.L	A3,#(SP)+TRAMMOT ; A3 <-- ^trame 32x16	LOAD.L	D7,D4	SWAP.W	D7	ADD.W	D7,(A2)+ODFFY	AND.W	D7,#H'000F	; D7 <-- ^relatif ligne trame	SL.W	D7,#2		; D7 <-- *4 car trame de 32 bits de large; Calcule l'adresse dans l'cran.TRAME_QUICK:	LOAD.L	D2,D3		; D2 <-- dimensions (dy;dx)	LOAD.L	D3,D4		; D4 <-- X	SWAP.W	D3		; D3 <-- Y	LOAD.W	D6,(A2)+ODFIIY	; D6 <-- Iy	ADD.W	D4,(A2)+ODFWBX	; D4 <-- coordonne x absolue dans bitmap	ADD.W	D3,(A2)+ODFWBY	; D3 <-- coordonne y absolue dans bitmap	LOAD.L	A4,(A2)+ODFABS	; A4 <-- adresse dbut cran	LOAD.W	D0,D4	SR.W	D0,#3		; dcale coordonne X	ADD.W	A4,D0	MUL.WU	D3,D6		; dcale coordonne Y	ADD.L	A4,D3		; A4 <-- adresse dans l'cran	AND.W	D4,#B'111	; D4 <-- Dd	LOAD.W	A6,D6		; A6 <-- Iy	LOAD.W	D0,A6	TEST.L	D0:#0		; Iy impair ?	JUMP,BS 60$		; oui => 60$; Calcule l'adresse de la routine de gestion d'une ligne.	LOAD.L	A0,#R16"TATRAME_OP;	AND.W	D1,#H'0003	SL.W	D1,#1	ADD.W	A0,(A0)+(D1.W)	; A0 <-- ^routine ligne; Si l'adresse n'est pas paire, recule d'un byte.	LOAD.W	D0,A4	RR.W	D0,#1	JUMP',CC 42$	DEC.L	A4		; A4 <-- adresse paire	ADD.W	D4,#8		; D4 <-- Dd42$:; Calcule le nombre de lignes  traiter.	LOAD.L	D5,D2	SWAP.W	D5		; D5 <-- hauteur	DEC.W	D5		; D5 <-- -1  cause NMO; Calcule le nombre de tranches de 16 bits.	LOAD.W	D1,D2	ADD.W	D1,D4		; D1 <-- Dd + largeur	DEC.W	D1	SR.W	D1,#4		; D1 <-- nb de words -1	LOAD.W	(SP)+TRAMNBW,D1	INC.W	D1	SL.W	D1,#1	SUB.W	A6,D1		; A6 <-- Iy - nb de bytes; Calcule les masques de dbut et de fin.	LOAD.L	A1,#R16"TATRAME_MASK	LOAD.W	D1,D4	SL.W	D1,#1	LOAD.W	D1,(A1)+(D1.W)	; D1 <-- masque de dbut	LOAD.W	(SP)+TRAMMA1,D1	ADD.W	D2,D4		; D2 <-- Dd + largeur	AND.W	D2,#H'000F	SL.W	D2,#1	LOAD.W	D2,(A1)+(D2.W)+32 ; D2 <-- masque de fin	JUMP	TRAME_LOOP; Calcule l'adresse de la routine de gestion d'une ligne,; dans le cas o Iy source ou destination est impair.60$:	LOAD.L	A0,#R16"TATRAME_OP	AND.W	D1,#H'0003	SL.W	D1,#1	ADD.W	D1,#4*2	ADD.W	A0,(A0)+(D1.W)	; A0 <-- ^routine ligne; Calcule le nombre de lignes  traiter.	LOAD.L	D5,D2	SWAP.W	D5		; D5 <-- hauteur	TEST.W	D5	JUMP',NC 63$	NEG.W	D5	EX.L	D5,A6	NEG.W	D5		; A6 <-- -A6	EX.L	A6,D563$:	DEC.W	D5		; D5 <-- -1  cause NMO; Calcule le nombre de tranches de 16 bits.	LOAD.W	D1,D2	ADD.W	D1,D4		; D1 <-- Dd + largeur	DEC.W	D1	SR.W	D1,#3		; D1 <-- nb de bytes -1	LOAD.W	(SP)+TRAMNBW,D1	INC.W	D1	SUB.W	A6,D1		; A6 <-- Iy - nb de bytes; Calcule les masques de dbut et de fin.	LOAD.L	A1,#R16"TATRAME_MASK	LOAD.W	D1,D4	SL.W	D1,#1	LOAD.B	D1,(A1)+(D1.W)	; D1 <-- masque de dbut	LOAD.W	(SP)+TRAMMA1,D1	ADD.W	D2,D4		; D2 <-- Dd + largeur	AND.W	D2,#H'0007	SL.W	D2,#1	LOAD.B	D2,(A1)+(D2.W)+32 ; D2 <-- masque de fin; Calcule le nombre de dcalages  droite.;	JUMP	TRAME_LOOP; Boucle principale de traitement des lignes.TRAME_LOOP:	LOAD.W	D1,(SP)+TRAMMA1	; D1 <-- masque de dbut	LOAD.W	D3,(SP)+TRAMNBW	; D3 <-- nombre de words -1	LOAD.L	D4,(A3)+(D7.W)	; D4 <-- trame	ADD.W	D7,#4		; D7 <-- offset suivant	AND.W	D7,#H'003F	; D7 <-- (0..15)*4	JUMP	(A0)		; traite une ligneTRAME_RETURN:	ADD.W	A4,A6		; A4 <-- ^ligne suivante	DECJ.W,NMO D5,TRAME_LOOP	CLR.W	D7		; D7 <-- ok	ADD.L	SP,#TRAMLGV	; ajuste le stackTRAME_EXIT:	POPM.L	D0..D6,A0..A6	AND.L	D7,#H'0000FFFF	; D7 <-- !	RET; (1)	transfert par words; (3)	transfert par bytesTATRAME_OP:	.W	TRAME_LOAD1-TATRAME_OP	.W	TRAME_INV1-TATRAME_OP	.W	TRAME_SET1-TATRAME_OP	.W	TRAME_CLR1-TATRAME_OP	.W	TRAME_LOAD3-TATRAME_OP	.W	TRAME_INV3-TATRAME_OP	.W	TRAME_SET3-TATRAME_OP	.W	TRAME_CLR3-TATRAME_OP;----------;; TRAME_op ;;----------;; Traite une ligne dans un mode quelconque.; in	D1.W	masque de dbut;	D2.W	masque de fin;	D3.W	nombre de words -1;	D4.L	trame;	A4.L	^destination; out	-; mod	D0.L, D1.L, D3.L, A4.LTRAME_INV1:	DEC.W	D3	JUMP',NS 40$	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	XOR.W	(A4+),D0	; destination <-- trame	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	TEST.W	D3	JUMP',EQ 40$	TCLR.L	D3:#0	JUMP',BC 30$	XOR.W	(A4+),D4	; destination <-- trame (juste une fois .W)30$:	SUB.W	D3,#16*2	JUMP',HS 34$	LOAD.W	D0,D3	NEG.W	D0	JUMP	(D0.W)+R8"34$	; saute en 34$ + qq instructions34$:	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	TEST.W	D3		; encore qq chose ?	JUMP,GT 30$		; oui => 30$40$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	XOR.W	(A4+),D0	; destination <-- trame	JUMP	TRAME_RETURNTRAME_INV3:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.B	D0,D4		; D0 <-- trame	AND.B	D0,D1		; D0 <-- conserve la partie utile	XOR.B	(A4+),D0	; destination <-- trame	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	JUMP	TRAME_RETURNTRAME_SET1:	DEC.W	D3	JUMP',NS 40$	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	OR.W	(A4+),D0	; destination <-- trame	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	TEST.W	D3	JUMP',EQ 40$	TCLR.L	D3:#0	JUMP',BC 30$	OR.W	(A4+),D4	; destination <-- trame (juste une fois .W)30$:	SUB.W	D3,#16*2	JUMP',HS 34$	LOAD.W	D0,D3	NEG.W	D0	JUMP	(D0.W)+R8"34$	; saute en 34$ + qq instructions34$:	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	TEST.W	D3		; encore qq chose ?	JUMP,GT 30$		; oui => 30$40$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	OR.W	(A4+),D0	; destination <-- trame	JUMP	TRAME_RETURNTRAME_SET3:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.B	D0,D4		; D0 <-- trame	AND.B	D0,D1		; D0 <-- conserve la partie utile	OR.B	(A4+),D0	; destination <-- trame	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	JUMP	TRAME_RETURNTRAME_CLR1:	DEC.W	D3	JUMP',NS 40$	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D0	AND.W	(A4+),D0	; destination <-- trame	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	NOT.L	D4	TEST.W	D3	JUMP',EQ 38$	TCLR.L	D3:#0	JUMP',BC 30$	AND.W	(A4+),D4	; destination <-- trame (juste une fois .W)30$:	SUB.W	D3,#16*2	JUMP',HS 34$	LOAD.W	D0,D3	NEG.W	D0	JUMP	(D0.W)+R8"34$	; saute en 34$ + qq instructions34$:	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	AND.L	(A4+),D4	; destination <-- trame	TEST.W	D3		; encore qq chose ?	JUMP,GT 30$		; oui => 30$38$:	NOT.L	D440$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D0	AND.W	(A4+),D0	; destination <-- trame	JUMP	TRAME_RETURNTRAME_CLR3:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.B	D0,D4		; D0 <-- trame	AND.B	D0,D1		; D0 <-- conserve la partie utile	NOT.B	D0	AND.B	(A4+),D0	; destination <-- trame	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	JUMP	TRAME_RETURNTRAME_LOAD1:	DEC.W	D3	JUMP',NS 40$	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4+),D0	; destination <-- trame	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	TEST.W	D3	JUMP',EQ 40$	TCLR.L	D3:#0	JUMP',BC 30$	LOAD.W	(A4+),D4	; destination <-- trame (juste une fois .W)30$:	SUB.W	D3,#16*2	JUMP',HS 34$	LOAD.W	D0,D3	NEG.W	D0	JUMP	(D0.W)+R8"34$	; saute en 34$ + qq instructions34$:	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	LOAD.L	(A4+),D4	; destination <-- trame	TEST.W	D3		; encore qq chose ?	JUMP,GT 30$		; oui => 30$40$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4+),D0	; destination <-- trame	JUMP	TRAME_RETURNTRAME_LOAD3:	DEC.W	D3	JUMP',NS 40$	LOAD.B	D0,D4		; D0 <-- trame	AND.B	D0,D1		; D0 <-- conserve la partie utile	NOT.B	D1	AND.B	D1,(A4)	OR.B	D0,D1	LOAD.B	(A4+),D0	; destination <-- trame	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP',NS 40$30$:	LOAD.W	(A4+),D4	; destination <-- trame	DECJ.W,NMO D3,30$40$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4+),D0	; destination <-- trame	JUMP	TRAME_RETURNTATRAME_MASK:	.W	B'1111111111111111	.W	B'0111111111111111	.W	B'0011111111111111	.W	B'0001111111111111	.W	B'0000111111111111	.W	B'0000011111111111	.W	B'0000001111111111	.W	B'0000000111111111	.W	B'0000000011111111	.W	B'0000000001111111	.W	B'0000000000111111	.W	B'0000000000011111	.W	B'0000000000001111	.W	B'0000000000000111	.W	B'0000000000000011	.W	B'0000000000000001	.W	B'1111111111111111	.W	B'1000000000000000	.W	B'1100000000000000	.W	B'1110000000000000	.W	B'1111000000000000	.W	B'1111100000000000	.W	B'1111110000000000	.W	B'1111111000000000	.W	B'1111111100000000	.W	B'1111111110000000	.W	B'1111111111000000	.W	B'1111111111100000	.W	B'1111111111110000	.W	B'1111111111111000	.W	B'1111111111111100	.W	B'1111111111111110; Traite le cas d'une trame de dimensions quelconques.; in	A2.L	^description de la fentre;	D4.L	coordonnes y;x dbut (coin sup/gauche);	D3.L	delta y;x;	D1.B	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT)TRAME_SPEC:	TEST.L	(A2)+ODFTPO	JUMP',NE 10$	LOAD.W	D2,(A2)+ODFTDI+2 ; D2 <-- largeur de la trame	COMP.W	D2,(A2)+ODFTDI+0 ; largeur = hauteur ?	JUMP',NE 10$		 ; non => 10$	COMP.W	D2,#2	JUMP,EQ TRAME_2x2	COMP.W	D2,#4	JUMP,EQ TRAME_4x4	COMP.W	D2,#8	JUMP,EQ TRAME_8x8	COMP.W	D2,#16	JUMP,EQ TRAME_16x1610$:	LOAD.L	A3,(A2)+ODFTPM	; A3 <-- ^bitmap trame source	LOAD.W	D5,(A2)+ODFTII	; D5 <-- ^incrment bitmap source	LOAD.L	A4,#0		; A4 <-- ^destination dans l'cran	LOAD.W	D2,(A2)+ODFTDI+0 ; D2 <-- hauteur trame	LOAD.L	D6,D4	SWAP.W	D6	ADD.W	D6,(A2)+ODFFY	SUB.W	D6,(A2)+ODFTOR+0	CONV.LA.WA D6	DIV.WA	D6,D2	SWAP.W	D6		; D6 <-- offset initial en Y	TEST.W	D6	JUMP',NC 14$	ADD.W	D6,D214$:	SUB.W	D2,D6		; D2 <-- hauteur initiale	SWAP.W	D2	JUMP'	22$20$:	CLR.W	D6		; D6 <-- plus d'offset en Y	LOAD.L	D2,(A2)+ODFTDI	; D2 <-- hauteur22$:	LOAD.W	D2,(A2)+ODFTDI+2 ; D2 <-- largeur trame	LOAD.W	D0,D4	ADD.W	D0,(A2)+ODFFX	SUB.W	D0,(A2)+ODFTOR+2	CONV.LA.WA D0	DIV.WA	D0,D2	SWAP.W	D0		; D0 <-- offset initial en X	TEST.W	D0	JUMP',NC 24$	ADD.W	D0,D224$:	SUB.W	D2,D0		; D2 <-- largeur initiale	PUSHM.L	D3,D4	JUMP'	32$30$:	CLR.W	D0		; D0 <-- plus d'offset en X	LOAD.W	D2,(A2)+ODFTDI+2 ; D2 <-- largeur32$:	PUSH.L	D3	COMP.W	D2,D3		; trame plus large que ce qu'il reste ?	JUMP',LS 34$		; non => 34$	LOAD.W	D2,D3		; D2 <-- largeur restante34$:	SWAP.W	D2	SWAP.W	D3	COMP.W	D2,D3		; trame plus haute que ce qu'il reste ?	JUMP',LS 35$		; non => 35$	LOAD.W	D2,D3		; D2 <-- hauteur restante35$:	SWAP.W	D2	SWAP.W	D3	LOAD.L	D3,(A2)+ODFTPO	; D3 <-- position source	ADD.W	D3,D0	SWAP.W	D3	ADD.W	D3,D6	SWAP.W	D3	CALL	_GRA_RASTERM	; dessine un bout de trame	POP.L	D3	ADD.W	D4,D2		; D4 <-- position suivante en X	SUB.W	D3,D2		; D3 <-- largeur restante en X	JUMP,NE 30$	POPM.L	D3,D4	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D2		; D4 <-- position suivante en Y	SUB.W	D3,D2		; D3 <-- largeur restante en Y	LOAD.W	D6,D3	SWAP.W	D4	SWAP.W	D3	TEST.W	D6	JUMP,NE 20$	CLR.W	D7		; D7 <-- ok	JUMP	TRAME_EXIT; Traite le cas d'une trame de 2x2 points.TRAME_2x2:	SUB.L	SP,#TRAMLGV	; stack <-- place pour variables	LOAD.L	A4,(A2)+ODFTPM	; A4 <-- ^bitmap trame source	CLR.L	D6		; D6 <-- pas d'inversion	TEST.L	D1:#BCPLDOT	JUMP',BC 10$	NOT.L	D6		; D6 <-- inverse la trame10$:	AND.W	D1,#H'0003	; D1 <-- mode LOAD/INV/SET/CLR	LOAD.W	D7,(A2)+ODFX	ADD.W	D7,(A2)+ODFTOR+2	AND.W	D7,#H'0001	; D7 <-- dcalage selon origine fentre en X	LOAD.L	A3,#(SP)+TRAMMOT	LOAD.W	D5,#2-114$:	CLR.L	D0	LOAD.B	D0,(A4)		; D0 <-- un byte de la trame	ADD.W	A4,(A2)+ODFTII	AND.B	D0,#B'11000000	LOAD.B	D2,D0		; D2 <-- TT000000	RR.B	D2,#2		; D2 <-- 00TT0000	OR.B	D0,D2	RR.B	D2,#2		; D2 <-- 0000TT00	OR.B	D0,D2	RR.B	D2,#2		; D2 <-- 000000TT	OR.B	D0,D2	LOAD.L	D2,D0	RL.L	D2,#8	OR.L	D0,D2	RL.L	D2,#8	OR.L	D0,D2	RL.L	D2,#8	OR.L	D0,D2	RR.L	D0,D7		; D0 <-- v. dcale selon origine fentre	XOR.L	D0,D6		; D0 <-- v. inverse	LOAD.L	(A3)+4*14,D0	LOAD.L	(A3)+4*12,D0	LOAD.L	(A3)+4*10,D0	LOAD.L	(A3)+4*8,D0	LOAD.L	(A3)+4*6,D0	LOAD.L	(A3)+4*4,D0	LOAD.L	(A3)+4*2,D0	LOAD.L	(A3+),D0	DECJ.W,NMO D5,14$	LOAD.L	A3,#(SP)+TRAMMOT ; A3 <-- ^trame 32x16	LOAD.L	D7,D4	SWAP.W	D7	ADD.W	D7,(A2)+ODFY	ADD.W	D7,(A2)+ODFFY	SUB.W	D7,(A2)+ODFTOR+0	AND.W	D7,#H'0001	; D7 <-- ^relatif ligne trame	SL.W	D7,#2		; D7 <-- *4 car trame de 32 bits de large	JUMP	TRAME_QUICK; Traite le cas d'une trame de 4x4 points.TRAME_4x4:	SUB.L	SP,#TRAMLGV	; stack <-- place pour variables	LOAD.L	A4,(A2)+ODFTPM	; A4 <-- ^bitmap trame source	CLR.L	D6		; D6 <-- pas d'inversion	TEST.L	D1:#BCPLDOT	JUMP',BC 10$	NOT.L	D6		; D6 <-- inverse la trame10$:	AND.W	D1,#H'0003	; D1 <-- mode LOAD/INV/SET/CLR	LOAD.W	D7,(A2)+ODFX	ADD.W	D7,(A2)+ODFTOR+2	AND.W	D7,#H'0003	; D7 <-- dcalage selon origine fentre en X	LOAD.L	A3,#(SP)+TRAMMOT	LOAD.W	D5,#4-114$:	CLR.L	D0	LOAD.B	D0,(A4)		; D0 <-- un byte de la trame	ADD.W	A4,(A2)+ODFTII	AND.B	D0,#B'11110000	LOAD.B	D2,D0		; D2 <-- TTTT0000	RR.B	D2,#4		; D2 <-- 0000TTTT	OR.B	D0,D2	LOAD.L	D2,D0	RL.L	D2,#8	OR.L	D0,D2	RL.L	D2,#8	OR.L	D0,D2	RL.L	D2,#8	OR.L	D0,D2	RR.L	D0,D7		; D0 <-- v. dcale selon origine fentre	XOR.L	D0,D6		; D0 <-- v. inverse	LOAD.L	(A3)+4*12,D0	LOAD.L	(A3)+4*8,D0	LOAD.L	(A3)+4*4,D0	LOAD.L	(A3+),D0	DECJ.W,NMO D5,14$	LOAD.L	A3,#(SP)+TRAMMOT ; A3 <-- ^trame 32x16	LOAD.L	D7,D4	SWAP.W	D7	ADD.W	D7,(A2)+ODFY	ADD.W	D7,(A2)+ODFFY	SUB.W	D7,(A2)+ODFTOR+0	AND.W	D7,#H'0003	; D7 <-- ^relatif ligne trame	SL.W	D7,#2		; D7 <-- *4 car trame de 32 bits de large	JUMP	TRAME_QUICK; Traite le cas d'une trame de 8x8 points.TRAME_8x8:	SUB.L	SP,#TRAMLGV	; stack <-- place pour variables	LOAD.L	A4,(A2)+ODFTPM	; A4 <-- ^bitmap trame source	CLR.L	D6		; D6 <-- pas d'inversion	TEST.L	D1:#BCPLDOT	JUMP',BC 10$	NOT.L	D6		; D6 <-- inverse la trame10$:	AND.W	D1,#H'0003	; D1 <-- mode LOAD/INV/SET/CLR	LOAD.W	D7,(A2)+ODFX	ADD.W	D7,(A2)+ODFTOR+2	AND.W	D7,#H'0007	; D7 <-- dcalage selon origine fentre en X	LOAD.L	A3,#(SP)+TRAMMOT	LOAD.W	D5,#8-1	LOAD.W	D2,(A2)+ODFTII14$:	LOAD.B	D0,(A4)		; D0 <-- un byte de la trame	ADD.W	A4,D2	RR.B	D0,D7		; D0 <-- v. dcale selon origine fentre	XOR.B	D0,D6		; D0 <-- v. inverse	LOAD.B	(A3+),D0	LOAD.B	(A3+),D0	LOAD.W	(A3+),(A3)-2	LOAD.L	(A3)+32-4,(A3)-4	DECJ.W,NMO D5,14$	LOAD.L	A3,#(SP)+TRAMMOT ; A3 <-- ^trame 32x16	LOAD.L	D7,D4	SWAP.W	D7	ADD.W	D7,(A2)+ODFY	ADD.W	D7,(A2)+ODFFY	SUB.W	D7,(A2)+ODFTOR+0	AND.W	D7,#H'0007	; D7 <-- ^relatif ligne trame	SL.W	D7,#2		; D7 <-- *4 car trame de 32 bits de large	JUMP	TRAME_QUICK; Traite le cas d'une trame de 16x16 points.TRAME_16x16:	SUB.L	SP,#TRAMLGV	; stack <-- place pour variables	LOAD.L	A4,(A2)+ODFTPM	; A4 <-- ^bitmap trame source	CLR.L	D6		; D6 <-- pas d'inversion	TEST.L	D1:#BCPLDOT	JUMP',BC 10$	NOT.L	D6		; D6 <-- inverse la trame10$:	AND.W	D1,#H'0003	; D1 <-- mode LOAD/INV/SET/CLR	LOAD.W	D7,(A2)+ODFX	ADD.W	D7,(A2)+ODFTOR+2	AND.W	D7,#H'000F	; D7 <-- dcalage selon origine fentre en X	LOAD.L	A3,#(SP)+TRAMMOT	LOAD.W	D5,#16-1	LOAD.W	D2,(A2)+ODFTII14$:	LOAD.W	D0,(A4)		; D0 <-- un word de la trame	ADD.W	A4,D2	RR.W	D0,D7		; D0 <-- v. dcale selon origine fentre	XOR.W	D0,D6		; D0 <-- v. inverse	LOAD.W	(A3+),D0	LOAD.W	(A3+),(A3)-2	DECJ.W,NMO D5,14$	LOAD.L	A3,#(SP)+TRAMMOT ; A3 <-- ^trame 32x16	LOAD.L	D7,D4	SWAP.W	D7	ADD.W	D7,(A2)+ODFY	ADD.W	D7,(A2)+ODFFY	SUB.W	D7,(A2)+ODFTOR+0	AND.W	D7,#H'000F	; D7 <-- ^relatif ligne trame	SL.W	D7,#2		; D7 <-- *4 car trame de 32 bits de large	JUMP	TRAME_QUICK	.END