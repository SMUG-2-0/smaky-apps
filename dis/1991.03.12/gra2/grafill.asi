	.SBTTL	GRAFILL;-----------\; _GRA_FILLO >;===========/; Rempli une surface quelconque.; in	A2.L	^description de la fentre;	D4.L	point initial (y;x); out	D7.W	erreur; mod	D7.W; use	D0 no bit		A0 ^byte;	D1 lg segment		A1;	D2 -1			A2 ^descripteur;	D3 P(x)			A3;	D4 P(y)			A4 Iy;	D5 reste (A6-A5)	A5 ^liste;	D6 nb pts sur stack	A6 ^stack;	D7 erreur		A7 SP;	|-------| <-- A5;	|   |   |;	|   |   | liste de segments horizontaux;	|  \|/  |;	|       |;	|       |;	|  /|\  |;	|   |   | stack de points;	|-------|;	          <-- A6	.MACRO	FILL_INCX	.LOCALMACRO FIN	DEC.B	D0	JUMP',NC FIN	LOAD.B	D0,#8-1	INC.L	A0FIN:	INC.W	D3		; X <-- X+1	.ENDMACRO	.MACRO	FILL_DECX	.LOCALMACRO FIN	INC.B	D0	COMP.B	D0,#8	JUMP',LO FIN	CLR.B	D0	DEC.L	A0FIN:	DEC.W	D3		; X <-- X-1	.ENDMACRO	.MACRO	FILL_INCX8	INC.L	A0	ADD.W	D3,#8		; X <-- X+8	.ENDMACRO	.MACRO	FILL_DECX8	DEC.L	A0	SUB.W	D3,#8		; X <-- X-8	.ENDMACRO	.MACRO	FILL_INCY	ADD.L	A0,A4	INC.W	D4		; Y <-- Y+1	.ENDMACRO	.MACRO	FILL_DECY	SUB.L	A0,A4	DEC.W	D4		; Y <-- Y-1	.ENDMACRO	.MACRO	FILL_PUSH	INC.W	D6	SUB.L	D5,#4	JUMP,LO FILL_OVER	LOAD.W	(-A6),D3	; PUSH (x,y)	LOAD.W	(-A6),D4	.ENDMACRO	.MACRO	FILL_PUSH1	INC.W	D6	SUB.L	D5,#4	JUMP,LO FILL_OVER1	LOAD.W	(-A6),D3	; PUSH (x,y)	LOAD.W	(-A6),D4	.ENDMACRO_GRA_FILLO:	PUSHM.L	D0..D6,A0..A6	LOAD.L	D0,D4		; D0 <-- point initial	CALL	_GRA_FILLC	; libre si pas encore fait !	LOAD.W	D3,#16		; D3 <-- prend tout, hum	LOAD.L	D4,#LGRAF*10	; D4 <-- minimum	LOAD.L	D5,#500000	; D5 <-- maximum	LOAD.W	D1,#MTYPBD	; D1 <-- type driver bios	LOAD.L	A1,(A2)+ODFBAS	; A1 <-- ^base du driver	GESMEM	?GETPMEM	; demande de la mmoire	JUMP,NE	FILL_EXIT	LOAD.L	(A2)+ODFFIP,A4	; mm ^table	LOAD.L	A5,A4		; A5 <-- ^liste	LOAD.L	D5,D4		; D5 <-- reste	SUB.L	D5,#20		; D5 <-- p'tite rserve	ADD.L	A4,D4	LOAD.L	A6,A4		; A6 <-- ^stack	CLR.W	D6		; D6 <-- place utilise sur le stack	LOAD.W	A4,(A2)+ODFIIY	; A4 <-- Iy	ADD.W	D0,(A2)+ODFWBX	; D0 <-- X initial	SWAP.W	D0	ADD.W	D0,(A2)+ODFWBY	; D0 <-- Y initial	SWAP.W	D0	INC.W	D6	SUB.L	D5,#4	LOAD.L	(-A6),D0	; PUSH (x,y) initial	SUB.L	D5,#6	CLR.W	(A5+)		; liste <-- lment bidon au dbut	CLR.L	(A5+)		; (par compatibilit avec l'ancien)	LOAD.B	D2,#-1; Boucle principale. Traite un point sur le stack.FILL_LOOP:	SUB.L	D5,#4	DEC.W	D6		; stack vide ?	JUMP,NS FILL_END	; oui => c'est fini	LOAD.W	D4,(A6+)	; POP (x,y)	LOAD.W	D3,(A6+)	CALL	GETPBNB		; A0 <-- ^byte, D0 <-- no bit	NOT.B	D0		; bits inverss (7..0) !	AND.W	D0,#B'111	; D0 <-- no du bit dans le byte; Cherche et rempli jusqu' l'extrme droite Xright.FILL_XRIGHT:	TSET.B	(A0):D0	JUMP,BS FILL_LOOP	PUSHM.L	D0,D3,A0	LOAD.W	D7,(A2)+ODFWEX	JUMP'	50$30$:	COMP.B	D0,#7	JUMP',NE 40$35$:	TEST.B	(A0)	JUMP',NE 40$	LOAD.B	(A0),D2	FILL_INCX8	COMP.W	D3,D7		; dpasse  droite ?	JUMP',GE 60$	JUMP	35$40$:	TSET.B	(A0):D0	JUMP',BS 80$50$:	FILL_INCX	COMP.W	D3,D7		; dpasse  droite ?	JUMP,LT 30$60$:	TEST.B	(A2)+ODFFLG:#BFFILA	JUMP,BC FILL_OUT180$:	FILL_DECX	LOAD.W	D1,D3		; D1 <-- Xright	POPM.L	D0,D3,A0; Cherche et rempli jusqu' l'extrme gauche Xleft.FILL_XLEFT:	LOAD.W	D7,(A2)+ODFWBX	JUMP'	50$30$:	TEST.B	D0	JUMP',NE 40$35$:	TEST.B	(A0)	JUMP',NE 40$	LOAD.B	(A0),D2	FILL_DECX8	COMP.W	D3,D7		; dpasse  gauche ?	JUMP',LT 60$	JUMP	35$40$:	TSET.B	(A0):D0	JUMP',BS 80$50$:	FILL_DECX	COMP.W	D3,D7		; dpasse  gauche ?	JUMP,GE 30$60$:	TEST.B	(A2)+ODFFLG:#BFFILA	JUMP,BC FILL_OUT280$:	FILL_INCX	SUB.W	D1,D3		; D1 <-- Xleft - Xright; Mmorise la ligne dans la liste.	PUSHM.L	D3,D4	SUB.W	D4,(A2)+ODFWBY	LOAD.W	(A5+),D4	; liste <-- Y	SUB.W	D3,(A2)+ODFWBX	LOAD.W	(A5+),D3	; liste <-- X dbut	ADD.W	D3,D1	LOAD.W	(A5+),D3	; liste <-- X fin	POPM.L	D3,D4	SUB.L	D5,#LGRAF	JUMP,LO FILL_OVER	INC.W	D1		; D1 <-- longueur; Balaye la ligne en-dessus.FILL_SCANUP:	PUSHM.L	D0,D1,D3,D4,A0	FILL_DECY	COMP.W	D4,(A2)+ODFWBY	; dpasse en haut ?	JUMP',GE 20$	TEST.B	(A2)+ODFFLG:#BFFILA	JUMP,BC FILL_OUT3	JUMP	80$20$:	TEST.B	(A0):D0		; saute les points allums	JUMP',BC 35$25$:	FILL_INCX	DEC.W	D1	JUMP,NE 20$	JUMP'	80$30$:	COMP.B	D0,#7	JUMP',NE 33$32$:	COMP.W	D1,#8	JUMP',LO 33$	TEST.B	(A0)	JUMP',NE 33$	FILL_INCX8	SUB.W	D1,#8	JUMP',EQ 37$	JUMP	32$33$:	TEST.B	(A0):D0		; saute les points teints	JUMP',BS 40$35$:	FILL_INCX	DEC.W	D1	JUMP,NE 30$37$:	DEC.W	D3	FILL_PUSH1		; PUSH (x-1,y);	INC.W	D3	JUMP'	80$40$:	DEC.W	D3	FILL_PUSH1		; PUSH (x-1,y)	INC.W	D3	JUMP	25$80$:	POPM.L	D0,D1,D3,D4,A0; Balaye la ligne en-dessous.FILL_SCANDOWN:	FILL_INCY	COMP.W	D4,(A2)+ODFWEY	; dpasse en bas ?	JUMP',LT 20$	TEST.B	(A2)+ODFFLG:#BFFILA	JUMP,BC FILL_OUT	JUMP	80$20$:	TEST.B	(A0):D0		; saute les points allums	JUMP',BC 35$25$:	FILL_INCX	DEC.W	D1	JUMP,NE 20$	JUMP'	80$30$:	COMP.B	D0,#7	JUMP',NE 33$32$:	COMP.W	D1,#8	JUMP',LO 33$	TEST.B	(A0)	JUMP',NE 33$	FILL_INCX8	SUB.W	D1,#8	JUMP',EQ 37$	JUMP	32$33$:	TEST.B	(A0):D0		; saute les points teints	JUMP',BS 40$35$:	FILL_INCX	DEC.W	D1	JUMP,NE 30$37$:	DEC.W	D3	FILL_PUSH		; PUSH (x-1,y);	INC.W	D3	JUMP'	80$40$:	DEC.W	D3	FILL_PUSH		; PUSH (x-1,y)	INC.W	D3	JUMP	25$80$:	JUMP	FILL_LOOPFILL_OVER1:	POPM.L	D0,D1,D3,D4,A0	; corrige le stack !FILL_OVER:	LOAD.W	D7,#ERNEMEM	; D7 <-- forme trop complique	JUMP	FILL_ERRORFILL_OUT1:	POPM.L	D0,D3,A0	; corrige le stack !	SUB.W	D4,(A2)+ODFWBY	LOAD.W	(A5+),D4	; liste <-- Y	SUB.W	D3,(A2)+ODFWBX	LOAD.W	(A5+),D3	; liste <-- X dbut	LOAD.W	D3,(A2)+ODFFDX	DEC.W	D3	LOAD.W	(A5+),D3	; liste <-- X fin	JUMP'	FILL_OUTFILL_OUT2:	SUB.W	D4,(A2)+ODFWBY	LOAD.W	(A5+),D4	; liste <-- Y	CLR.W	(A5+)		; liste <-- X dbut	SUB.W	D1,(A2)+ODFWBX	LOAD.W	(A5+),D1	; liste <-- X fin	JUMP'	FILL_OUTFILL_OUT3:	POPM.L	D0,D1,D3,D4,A0	; corrige le stack !FILL_OUT:	LOAD.W	D7,#ERDIOUT	; D7 <-- a dbordeFILL_ERROR:	LOAD.W	(A5),#-1	; liste <-- terminateur	CLR.L	(A2)+ODFVAR+OVARCTR+0	CLR.L	(A2)+ODFVAR+OVARCTR+4	CALL	FILL_TRAME	; efface tout	JUMP'	FILL_EXITFILL_END:	LOAD.W	(A5),#-1	; liste <-- terminateur	LOAD.L	(A2)+ODFVAR+OVARCTR+0,(A2)+ODFTRA+0	LOAD.L	(A2)+ODFVAR+OVARCTR+4,(A2)+ODFTRA+4	CALL	FILL_TRAME	; met la vraie trame	CLR.W	D7		; D7 <-- okFILL_EXIT:	POPM.L	D0..D6,A0..A6	TEST.W	D7		; retour EQ/NE	RET;-----------\; _GRA_FILLC >;===========/; Rend la mmoire des points allums.; in	A2.L	^description de la fentre; out	-; mod	-_GRA_FILLC:	PUSHM.L	D1,D7,A1,A4	TEST.L	(A2)+ODFFIP	; table existe ?	JUMP',EQ 90$		; non => 90$				; oui =>	LOAD.L	A4,(A2)+ODFFIP	; A4 <-- ^mmoire	LOAD.W	D1,#MTYPBD	; D1 <-- type driver bios	LOAD.L	A1,(A2)+ODFBAS	; A1 <-- ^base du driver	GESMEM	?GIVMEM		; rend la mmoire90$:	POPM.L	D1,D7,A1,A4	RET;-----------\\; FILL_TRAME >;-----------/     ; Redessine toute la surface avec la trame choisie.; La trame est aligns par rapport  la fentre, et non; par rapport  la sous-fentre !; in	A2.L	^description de la fentre; out	-; mod	-FILL_TRAME:	PUSHM.L	D0..D4,A5,A6	COMP.L	(A2)+ODFVAR+OVARCTR+0,#-1	JUMP',NE 05$	COMP.L	(A2)+ODFVAR+OVARCTR+4,#-1	JUMP,EQ 90$05$:	LOAD.L	A6,(A2)+ODFFIP	; A6 <-- ^liste	LOAD.L	A6,#(A6)+LGRAF	; A6 <-- saute l'lment bidon du dbut !10$:	LOAD.W	D4,(A6+)	; D4 <-- Y	COMP.W	D4,#-1	JUMP,EQ 90$	LOAD.L	A5,#(A2)+ODFVAR+OVARCTR	LOAD.W	D3,D4	ADD.W	D3,(A2)+ODFFY	AND.W	D3,#B'111	ADD.W	A5,D3		; A5 <-- ^byte de la trame	LOAD.B	D1,(A5)		; D1 <-- byte de la trame	LOAD.W	D3,(A6+)	; D3 <-- X	LOAD.W	D2,(A6+)	SUB.W	D2,D3	INC.W	D2		; D2 <-- longueur	NOT.B	D1	JUMP,EQ 10$	ADD.W	D3,(A2)+ODFWBX	ADD.W	D4,(A2)+ODFWBY	CALL	GETPBNB		; A0 <-- ^byte, D0 <-- no bit; Travail de dbut.	TEST.B	D0	JUMP',EQ 40$	LOAD.B	D3,D1		; D3 <-- byte trame	SL.B	D3,D0	RR.B	D3,D021$:	LOAD.W	D4,#8	SUB.W	D4,D0	COMP.W	D2,D4	JUMP',HS 30$	SUB.W	D4,D2	SR.B	D3,D4	RL.B	D3,D426$:	NOT.B	D3	AND.B	(A0),D3	JUMP	10$30$:	NOT.B	D3	AND.B	(A0+),D3	SUB.W	D2,D4	CLR.B	D0; Travail du milieu.40$:	COMP.W	D2,#8	JUMP',LO 60$	LOAD.W	D4,D2	SR.W	D4,#3		; D4 <-- nb de bytes	DEC.W	D4		; D4 <-- -1  cause NMO	NOT.B	D145$:	AND.B	(A0+),D1	DECJ.W,NMO D4,45$	NOT.B	D1; Travail de fin.60$:	AND.B	D2,#B'111	SUB.B	D2,#8	NEG.B	D2	JUMP,EQ 10$	LOAD.B	D3,D1		; D3 <-- byte trame	SR.B	D3,D2	RL.B	D3,D271$:	NOT.B	D3	AND.B	(A0),D3	JUMP	10$90$:	POPM.L	D0..D4,A5,A6	RET	.END