	.TITLE	TGRA.ASC	.PROC	M680002	.REF	SMAKY	.REF	GRA2	.REF	GRAMISCODFCRG	=	LGDIS6-4	.LOC	0OCHGRA:	.BLKB	2		; canal module GRA2OCHGMI:	.BLKB	2		; canal module GRAMISCORGNID:	.BLKB	4ORGNDF:	.BLKB	4LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur de la fentre	LOAD.W	D3,#2	LIB	?MOUSE	LIB	?AFTIM	.B	NOCURS	.B	NOEFLI	.B	0	.EVEN	LOAD.L	A3,#R16"NMGRA	LOAD.W	D3,#GRA2_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHGRA,D1	LOAD.L	A3,#R16"NMGMI	LOAD.W	D3,#GMI_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHGMI,D1	GMI_	NEWRGN	JUMP,NE ERFAT2	LOAD.L	(A6)+ORGNID,A4LOOP:	CALL	RGNCREATE;;?JUMP 40$JUMP 30$	LIB	?AFTIM	.ASCII	"Coucou...<CR>"	.ASCII	"<CR>"	.ASCII	"abcdefghijklmnopqrstuvwxyz<CR>"	.ASCII	"ABCDEFGHIJKLMNOPQRSTUVWXYZ<CR>"	.ASCII	"1234567890<CR>"	.ASCII	"<CR>"	.ASCII	"Et voil !<CR>"	.B	CR,CR,CR,CR,CR,CR,CR,CR,CR,CR,CR,CR,CR,CR,CR	.B	0	.EVEN	LOAD.L	A2,A0			; A2 <-- ^descripteur fentre	LOAD.L	(A2)+ODFCRG,(A6)+ORGNID	LOAD.L	D3,#H'10000*2+2		; D3 <-- source: position	LOAD.L	A3,#0			; A3 <-- source: dans l'cran	LOAD.L	D4,#H'10000*100+100	; D4 <-- destination: position	LOAD.L	A4,#0			; A4 <-- destination: dans l'cran	LOAD.L	D2,#H'10000*101+101	; D2 <-- dimensions	LOAD.W	D1,#LOADDOT		; D1 <-- mode	GRA2_	RASTER			; moteur ...	JUMP	ERFAT130$:	LOAD.L	A2,A0	LOAD.L	(A2)+ODFCRG,(A6)+ORGNID	LOAD.L	A4,#R16"TTRAME	LOAD.L	D4,#H'10000*100+100	LOAD.L	D3,#H'10000*400+400JUMP 34$	LOAD.W	D0,#5032$:	LOAD.W	D1,#INVDOT	GRA2_	TRAME	DEC.W	D0	JUMP,NE 32$34$:	LOAD.W	D1,#LOADDOT	GRA2_	TRAME36$:	LIB	?GETCAR	COMP.W	D3,#SPACE	JUMP,EQ LOOP	COMP.W	D3,#END	JUMP,EQ ERFAT1	JUMP	36$40$:	CALL	SIMUL	LOAD.L	D3,#H'10000*500+0	LIB	?SETCURS	JUMP	ERFAT1ERFAT1:	LOAD.L	A4,(A6)+ORGNID	GMI_	DISPOSERGN	LOAD.W	D1,(A6)+OCHGRA	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHGMI	LIB_	CLOSEERFAT2:	EXITTTRAME:	.B	B'10000000	.B	B'01000000	.B	B'00100000	.B	B'00010000	.B	B'00001000	.B	B'00000100	.B	B'00000010	.B	B'00000001	.EVEN;--------\\; SIMUL   >;========/; ; in	-; out	-; mod	D7.WSIMUL:	PUSHM.L	D0..D6,A2..A4	LOAD.L	A2,A0			; A2 <-- ^descripteur fentre	LOAD.L	(A2)+ODFCRG,(A6)+ORGNID	LOAD.L	A3,#R16"TRAME$	CLR.L	D3	LOAD.W	D5,#2	LOAD.L	A4,#0			; A4 <-- destination: dans l'cran	LOAD.L	D2,#H'10000*32+32	; D2 <-- dimensions	LOAD.W	D1,#SETDOT		; D1 <-- mode	CLR.L	D420$:	CLR.W	D430$:	GRA2_	RASTER			; moteur ...	ADD.W	D4,#32	COMP.W	D4,(A2)+ODFFDX	JUMP,LO 30$	SWAP.W	D4	ADD.W	D4,#32	LOAD.W	D0,D4	SWAP.W	D4	COMP.W	D0,(A2)+ODFFDY	JUMP,LO 20$90$:	POPM.L	D0..D6,A2..A4	RETTRAME$:	.W	B'0111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.EVEN;----------\\; RGNCREATE >;==========/; ; in	; out	; mod	RGNCREATE:	PUSHM.L	D1..D4,A4,A5	LOAD.B	D3,#EOP	LIB	?AFCAR	LOAD.L	D3,#H'10000*(100-2)+(100-2)	LOAD.L	D4,#H'10000*(400+3)+(400+3)	LOAD.W	D2,#SETDOT	LIB	?DRRECT	LOAD.W	D3,#GFILLXORPUSHM.L D0..D7,A0..A4,A6	GMI_	OPENRGNPOPM.L D0..D7,A0..A4,A6	LOAD.L	(A6)+ORGNDF,A520$:	LIB	?GETCAR	COMP.W	D3,#KEYMGR	JUMP,EQ 20$	COMP.W	D3,#KEYMMR	JUMP,EQ 20$	COMP.W	D3,#KEYMDR	JUMP,EQ 20$	COMP.W	D3,#KEYMGP	JUMP,NE 80$	LIB	?IFMOUSE	JUMP,NE 20$	LOAD.L	D1,D4	LOAD.L	D2,D430$:	LIB	?GETCAR	COMP.W	D3,#KEYMGR	JUMP,EQ 30$	COMP.W	D3,#KEYMMR	JUMP,EQ 30$	COMP.W	D3,#KEYMDR	JUMP,EQ 30$	COMP.W	D3,#KEYMGP	JUMP,NE 50$	LIB	?IFMOUSE	JUMP,NE 30$	LOAD.L	D3,D2	LOAD.L	D2,D4PUSHM.L D0..D7,A0..A6	GMI_	PUTLINEPOPM.L D0..D7,A0..A6	PUSHM.L	D2..D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2..D4	JUMP	30$50$:	LOAD.L	D3,D2	LOAD.L	D4,D1PUSHM.L D0..D7,A0..A6	GMI_	PUTLINEPOPM.L D0..D7,A0..A6	PUSHM.L	D2..D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2..D480$:	LOAD.W	D3,#GFILLXOR	LOAD.L	A5,(A6)+ORGNDF	LOAD.L	A4,(A6)+ORGNIDPUSHM.L D0..D7,A0..A6	GMI_	CLOSERGNPOPM.L D0..D7,A0..A690$:	POPM.L	D1..D4,A4,A5	TEST.W	D7		; retour EQ/NE	RETNMGRA:	.ASCIZ	"GRA2"NMGMI:	.ASCIZ	"TGRAMIS"VAR:	.FILLB	LGVAR,0	.END	START