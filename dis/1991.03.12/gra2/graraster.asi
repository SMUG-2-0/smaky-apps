	.SBTTL	GRARASTER	.IF	COLOR;------------\; RASTERC_CLR >;============/; Efface (rempli de zro) la destination.; Seulement si la destination est en mmoire couleur !; in	A4.L	^mmoire destination;	D6.W	Iy destination;	A6.L	By destination;	D2.L	hauteur/largeur (dy;dx); out	-; mod	-RASTERC_CLR:	COMP.L	A6,#0	JUMP,EQ RASTER_CLR	PUSHM.L	D0,A4	LOAD.W	D0,#8-110$:	CALL	RASTER_CLR	; efface un plan couleur	ADD.L	A4,A6		; A4 <-- ^bitmap suivant	DECJ.W,NMO D0,10$	POPM.L	D0,A4	RET	.ENDIF;-----------\; RASTER_CLR >;===========/; Efface (rempli de zro) la destination.; Seulement si la destination est en mmoire !; in	A4.L	^mmoire destination;	D6.W	Iy destination;	D2.L	hauteur/largeur (dy;dx); out	-; mod	-RASTER_CLR:	PUSHM.L	D0,D1,D2,A3,A4	LOAD.W	D1,D2	ADD.W	D1,#7	SR.W	D1,#3		; D1 <-- largeur en bytes	DEC.W	D1		; D1 <--  cause du test NMO	SWAP.W	D2		; D2 <-- hauteur en points	DEC.W	D2		; D2 <--  cause du test NMO30$:	LOAD.L	A3,A4	LOAD.W	D0,D140$:	CLR.B	(A3+)		; efface une ligne	DECJ.W,NMO D0,40$	ADD.W	A4,D6		; A4 <-- ^ligne en dessous	DECJ.W,NMO D2,30$	POPM.L	D0,D1,D2,A3,A4	RET	.IF	COLOR;-----------\; RASTERC_MM >;===========/; Dplace une surface rectangulaire mmoire [couleur] --> mmoire couleur.; in	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source;	D5.W	Iy source;	A5.L	By source;	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination;	D6.W	Iy destination;	A6.L	By destination;	----;	D2.L	hauteur/largeur (dy;dx);	D1.W	opration (SETDOT/CLRDOT/INVDOT/LOADDOT); out	-; mod	-RASTERC_MM:	JUMP	_GRA_RASTERC	.ENDIF;----------\; RASTER_MM >;==========/; Dplace une surface rectangulaire mmoire --> mmoire.; in	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source;	D5.W	Iy source;	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination;	D6.W	Iy destination;	----;	D2.L	hauteur/largeur (dy;dx);	D1.W	opration (SETDOT/CLRDOT/INVDOT/LOADDOT); out	-; mod	-RASTER_MM:	JUMP	_GRA_RASTERM	.IF	COLOR;-----------\; RASTERC_MD >;===========/; Dplace une surface rectangulaire mmoire couleur --> cran.; in	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source;	D5.W	Iy source;	A5.L	By source;	----;	D4.L	coordonne destination (y;x);	----;	D2.L	hauteur/largeur (dy;dx);	D1.W	opration (SETDOT/CLRDOT/INVDOT/LOADDOT); out	-; mod	-RASTERC_MD:	PUSH.L	A4	LOAD.L	A4,#0	CALL	_GRA_RASTERC	POP.L	A4	RET	.ENDIF;----------\; RASTER_MD >;==========/; Dplace une surface rectangulaire mmoire --> cran.; in	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source;	D5.W	Iy source;	----;	D4.L	coordonne destination (y;x);	----;	D2.L	hauteur/largeur (dy;dx);	D1.W	opration (SETDOT/CLRDOT/INVDOT/LOADDOT); out	-; mod	-RASTER_MD:	PUSH.L	A4	LOAD.L	A4,#0	CALL	_GRA_RASTERM	POP.L	A4	RET	.IF	COLOR;-----------\; RASTERC_DM >;===========/; Dplace une surface rectangulaire cran --> mmoire couleur.; in	----;	D3.L	coordonne source (y;x);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination;	D6.W	Iy destination;	A6.L	By destination;	----;	D2.L	hauteur/largeur (dy;dx);	D1.W	opration (SETDOT/CLRDOT/INVDOT/LOADDOT); out	-; mod	-RASTERC_DM:	PUSH.L	A3	LOAD.L	A3,#0	CALL	_GRA_RASTERC	POP.L	A3	RET	.ENDIF;----------\; RASTER_DM >;==========/; Dplace une surface rectangulaire cran --> mmoire.; in	----;	D3.L	coordonne source (y;x);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination;	D6.W	Iy destination;	----;	D2.L	hauteur/largeur (dy;dx);	D1.W	opration (SETDOT/CLRDOT/INVDOT/LOADDOT); out	-; mod	-RASTER_DM:	PUSH.L	A3	LOAD.L	A3,#0	CALL	_GRA_RASTERM	POP.L	A3	RET;------------\; _GRA_RASTER >;============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A2.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	D1.B	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT); out	-; mod	-_GRA_RASTER:	PUSH.W	D1	AND.W	D1,#H'00FF	; D1 <-- normal et plein	CALL	_GRA_RASTERM	POP.W	D1	RET	.IF	COLOR;-------------\; _GRA_RASTERC >;=============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A2.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	A5.L	By source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	A6.L	By destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	D1.W	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT);		 si 2^BCPLDOT  = 1	-->	inverse (pour AFINV);		 si 2^BGREDOT  = 1	-->	grise   (pour AFGREY); out	-; mod	-_GRA_RASTERC:	PUSHM.L	D0,D1,D7,A3,A4	LOAD.L	D0,A3		; source dans l'cran ?	JUMP',EQ 10$		; oui => 10$	LOAD.L	D0,A5		; source multiple ?	JUMP',NE 15$		; oui => 15$10$:	LOAD.L	D0,A4		; destination dans l'cran ?	JUMP',EQ 12$		; oui => 12$	LOAD.L	D0,A6		; destination multiple ?	JUMP',NE 15$		; oui => 15$12$:	CALL	_GRA_RASTERM	; c'est tout bte !	JUMP	90$15$:	LOAD.L	D0,A3		; source dans l'cran ?	JUMP,EQ 50$		; oui => 50$	LOAD.L	D0,A4		; destination dans l'cran ?	JUMP,EQ 50$		; oui => 50$	LOAD.L	D0,A5		; source multiple ?	JUMP,NE 50$		; oui => 50$	LOAD.W	D0,(A2)+ODFCSF+2 ; D0 <-- couleur pour dessiner	COMP.B	D1,#SETDOT	JUMP,EQ 20$	LOAD.W	D0,(A2)+ODFCCF+2 ; D0 <-- couleur pour effacer	COMP.B	D1,#CLRDOT	JUMP,EQ 20$	LOAD.W	D7,(A2)+ODFCSF+2	XOR.W	D0,D7		; D0 <-- couleur pour inverser	COMP.B	D1,#INVDOT	JUMP,EQ 30$	JUMP	40$; Source:	bitmap unique en mmoire; Destination:	bitmaps en mmoire; Mode:		SETDOT ou CLRDOT20$:	SWAP.W	D0		; D0 <-- couleur	LOAD.W	D0,#8-122$:	LOAD.W	D1,#CLRDOT!2^10	TEST.L	D0:#16+0	JUMP',BC 24$	LOAD.W	D1,#SETDOT!2^1024$:	CALL	_GRA_RASTERM	; travail dans un plan	ADD.L	A4,A6		; A4 <-- ^bitmap suivant	SWAP.W	D0	RR.W	D0,#1		; D0 <-- couleur suivante	SWAP.W	D0	DECJ.W,NMO D0,22$	JUMP	90$; Source:	bitmap unique en mmoire; Destination:	bitmaps en mmoire; Mode:		INVDOT30$:	SWAP.W	D0		; D0 <-- couleur	LOAD.W	D0,#8-132$:	TEST.L	D0:#16+0	JUMP',BC 34$	LOAD.W	D1,#INVDOT!2^10	CALL	_GRA_RASTERM	; travail dans un plan34$:	ADD.L	A4,A6		; A4 <-- ^bitmap suivant	SWAP.W	D0	RR.W	D0,#1		; D0 <-- couleur suivante	SWAP.W	D0	DECJ.W,NMO D0,32$	JUMP	90$; Source:	bitmap unique en mmoire; Destination:	bitmaps en mmoire; Mode:		LOADDOT40$:;	 faire ...	JUMP	90$; Source et/ou destination dans l'cran.50$:	PUSHM.L	D0..D4	LOAD.W	D0,#MVDCLOAD	CLR.L	D2	CLR.L	D3	LOAD.W	D4,#-1	CALL	MODVDCC		; init le mode logique	POPM.L	D0..D4	SUB.L	(A2)+ODFABS,#LGBITS*8	LOAD.W	D0,#8-152$:	TSET.L	D1:#10	CALL	_GRA_RASTERM	; travail dans un plan	COMP.L	A3,#0	JUMP',EQ 54$	ADD.L	A3,A5		; A3 <-- ^bitmap suivant54$:	COMP.L	A4,#0	JUMP',EQ 55$	ADD.L	A4,A6		; A4 <-- ^bitmap suivant55$:	ADD.L	(A2)+ODFABS,#LGBITS	DECJ.W,NMO D0,52$90$:	POPM.L	D0,D1,D7,A3,A4	RET	.ENDIF; Variables de GRA_RASTERM sur le stack; -------------------------------------	.PC	PCVAR	.LOC	0RASTMA1:.BLKB	2		; masque de dbutRASTNBW:.BLKB	2		; nb de words -1RASTIIX:.BLKB	2		; sens de parcour horizontal (+1/-1)RASTRGR:.BLKB	1		; <>0 si rgion non rectangulaire	.BLKB	1		; rserveRASTPOY:.BLKB	2		; position en YRASTCHY:.BLKB	2		; prochain Y ayant un changementRASTASK:.BLKB	4		; ^appel GMI_SEEKSRGNRASTLSK:.BLKB	4		; ^ligne de masqueRASTLGV:			; lg des variables	.PC	PCCODE;-------------\; _GRA_RASTERM >;=============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A2.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	D1.W	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT);		 si 2^BCPLDOT  = 1	-->	inverse (pour AFINV);		 si 2^BGREDOT  = 1	-->	grise   (pour AFGREY);		 si 2^10       = 1	-->	pas de mode logique; out	D7.W	ok; mod	D7.L_GRA_RASTERM:	PUSHM.L	D0..D6,A0..A6_GRA_RASTERP:	SUB.L	SP,#RASTLGV	; stack <-- place pour variables	CLR.B	(SP)+RASTRGR	; rgion rectangulaire; Effectue ventuellement un clipping sur la destination si elle est; dans l'cran.	LOAD.L	D0,A4		; destination dans l'cran ?	JUMP,NE NoClip$		; non => NoClip$;;?	TEST.L	D1:#BNTSDOT;;?	JUMP,BS NoClip$	TEST.W	D4		; dpasse  gauche ?	JUMP',NC NoLeft$	ADD.W	D2,D4	JUMP,LE RASTER_EXIT	SUB.W	D3,D4	CLR.W	D4NoLeft$:	LOAD.W	D0,D4	ADD.W	D0,D2	SUB.W	D0,(A2)+ODFFDX	; dpasse  droite ?	JUMP',LS NoRight$	SUB.W	D2,D0	JUMP,LE RASTER_EXITNoRight$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	TEST.W	D4		; dpasse en haut ?	JUMP',NC NoUp$	ADD.W	D2,D4	JUMP,LE RASTER_EXIT	SUB.W	D3,D4	CLR.W	D4NoUp$:	LOAD.W	D0,D4	ADD.W	D0,D2	SUB.W	D0,(A2)+ODFFDY	; dpasse en bas ?	JUMP',LS NoDown$	SUB.W	D2,D0	JUMP,LE RASTER_EXITNoDown$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	TEST.L	(A2)+ODFCRG	JUMP,EQ NoClip$	SUB.L	SP,#2+4+4	PUSH.L	(A2)+ODFCRG	PUSH.L	#(SP)+4+2	GMI_	RGNBBOX		; calcule la bounding-box de la rgion	LOAD.W	D0,(SP)+2+2	; D0 <-- p1(x)	SUB.W	D0,(A2)+ODFFX	COMP.W	D4,D0	JUMP',GE RgLeft$	SUB.W	D4,D0	ADD.W	D2,D4	JUMP,LE NoSect$	SUB.W	D3,D4	LOAD.W	D4,D0RgLeft$:	LOAD.W	D0,(SP)+2+6	; D0 <-- p2(x)	SUB.W	D0,(A2)+ODFFX	SUB.W	D0,D4	JUMP,LE NoSect$	COMP.W	D2,D0	JUMP',LE RgRight$	LOAD.W	D2,D0RgRight$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,(SP)+2+0	; D0 <-- p1(y)	SUB.W	D0,(A2)+ODFFY	COMP.W	D4,D0	JUMP',GE RgUp$	SUB.W	D4,D0	ADD.W	D2,D4	JUMP',LE NoSect$	SUB.W	D3,D4	LOAD.W	D4,D0RgUp$:	LOAD.W	D0,(SP)+2+4	; D0 <-- p2(y)	SUB.W	D0,(A2)+ODFFY	SUB.W	D0,D4	JUMP',LE NoSect$	COMP.W	D2,D0	JUMP',LE RgDown$	LOAD.W	D2,D0	JUMP'	RgDown$NoSect$:	ADD.L	SP,#2+4+4	JUMP	RASTER_EXITRgDown$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	POP.B	(SP)+4+4+RASTRGR	ADD.L	SP,#4+4	TEST.B	(SP)+RASTRGR	; rgion rectangulaire ?	JUMP',EQ NoClip$	; oui => NoClip$	SUB.L	SP,#LgBldRgn	LOAD.B	(SP)+RASTRGR,#1	; rgion (sans) complexe	SUB.L	SP,#2		; stack <-- place pour erreur en retour	PUSH.L	(A2)+ODFCRG	; stack <-- id rgion	PUSH.L	#(SP)+2+4+RASTLGV ; stack <-- ^variables	LOAD.W	D0,D4	ADD.W	D0,(A2)+ODFFX	PUSH.W	D0		; stack <-- left masque	ADD.W	D0,D2	PUSH.W	D0		; stack <-- right masque	LOAD.W	D0,D4	ADD.W	D0,(A2)+ODFFX	AND.B	D0,#B'11110000	PUSH.W	D0		; stack <-- dbut dans le masque	PUSH.B	#0		; stack <-- 0 de haut en bas	SWAP.W	D3	SWAP.W	D4	COMP.L	A3,A4		; ^source = ^destination ?	JUMP',NE UpDownSeek$	; non => UpDownSeek$	COMP.W	D3,D4	JUMP',GE UpDownSeek$	LOAD.B	(SP),#1		; stack <-- 1 de bas en hautUpDownSeek$:	SWAP.W	D4	SWAP.W	D3	PUSH.L	#(SP)+2+2+2+2+4+4+2+RASTASK ; RASTASK <-- ^routine "seek"	GMI_	INITSRGN	POP.W	D7		; D7 <-- ok/erreur	JUMP,NE RASTER_EXIT	LOAD.L	D0,D4	SWAP.W	D0	ADD.W	D0,(A2)+ODFFY	LOAD.W	(SP)+RASTPOY,D0	LOAD.W	(SP)+RASTCHY,D0NoClip$:; Inverse ventuellement le sens de balayage s'il y a recouvrement.;	gauche <--> droite;	  haut <--> bas	LOAD.W	(SP)+RASTIIX,#+1 ; RASTIIX <-- de gauche  droite	COMP.L	A3,A4		; ^source = ^destination ?	JUMP',NE InvExit$	; non => InvExit$	COMP.W	D3,D4	JUMP',HS InvLR$	LOAD.W	(SP)+RASTIIX,#-1 ; RASTIIX <-- de droite  gaucheInvLR$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',HS InvUD$	DEC.W	D2	ADD.W	D3,D2		; D3 <-- en bas	ADD.W	D4,D2		; D4 <-- en bas	INC.W	D2	NEG.W	D2		; D2 <-- de bas en haut (ngatif)	SUB.W	(SP)+RASTPOY,D2	SUB.W	(SP)+RASTCHY,D2InvUD$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4InvExit$:; Calcule le pointeur pour la source.	LOAD.L	D0,A3		; source dans l'cran ?	JUMP',NE Ps$		; non => Ps$				; oui =>	LOAD.L	A3,(A2)+ODFABS	; A3 <-- adresse dbut cran	LOAD.W	D5,(A2)+ODFIIY	; D5 <-- Iy cran	ADD.W	D3,(A2)+ODFWBX	; D3 <-- dans (sous-)fentre en X	SWAP.W	D3	ADD.W	D3,(A2)+ODFWBY	; D3 <-- dans (sous-)fentre en Y	SWAP.W	D3Ps$:	LOAD.L	D0,D3	SWAP.W	D0	MUL.WU	D0,D5	ADD.L	A3,D0	LOAD.W	D0,D3	SR.W	D0,#3	ADD.W	A3,D0		; A3 <-- ^byte source	AND.W	D3,#H'0007	; D3 <-- Ds	LOAD.W	A5,D5		; A5 <-- Iy source; Calcule le pointeur pour la destination.	.IF	COLOR	LOAD.L	D0,A4		; destination dans l'cran ?	JUMP',EQ cDScreen$	; oui => cDScreen$	TSET.L	D1:#10		; D1 <-- pas de mode logique !cDScreen$:	.ENDIF	LOAD.L	D0,A4		; destination dans l'cran ?	JUMP',NE Pd$		; non => Pd$				; oui =>	LOAD.L	A4,(A2)+ODFABS	; A4 <-- adresse dbut cran	LOAD.W	D6,(A2)+ODFIIY	; D6 <-- Iy cran	ADD.W	D4,(A2)+ODFWBX	; D4 <-- dans (sous-)fentre en X	SWAP.W	D4	ADD.W	D4,(A2)+ODFWBY	; D4 <-- dans (sous-)fentre en Y	SWAP.W	D4Pd$:	LOAD.L	D0,D4	SWAP.W	D0	MUL.WU	D0,D6	ADD.L	A4,D0	LOAD.W	D0,D4	SR.W	D0,#3	ADD.W	A4,D0		; A4 <-- ^byte destination	AND.W	D4,#H'0007	; D4 <-- Dd	LOAD.W	A6,D6		; A6 <-- Iy destination; Calcule les oprations de gris et d'inversion.	LOAD.L	D7,#-1		; D7 <-- plein	TEST.L	D1:#BGREDOT	JUMP',BC NoGrey$	LOAD.L	D7,#H'5555AAAA	; D7 <-- grisNoGrey$:	CLR.W	D6		; D6 <-- vido normale	TEST.L	D1:#BCPLDOT	JUMP',BC NoInv$	NOT.W	D6		; D6 <-- vido inverseNoInv$:	.IF	COLOR	TEST.L	D1:#10	JUMP',BS NoColor$	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP',EQ NoColor$	; non => NoColor$	LOAD.L	D0,(A2)+ODFABS	COMP.L	D0,(A2)+ODFCAB	; est-on dans l'cran couleur ?	JUMP,EQ RASTER_COLOR	; oui => RASTER_COLORNoColor$:	.ENDIF	TEST.B	(SP)+RASTRGR	; rgion rectangulaire ?	JUMP,NE NoLoadC$	; non => NoLoadC$	LOAD.W	D0,D7	NOT.W	D0	OR.W	D0,D6		; grise ou inverse ?	OR.W	D0,D3		; Ds = 0 ?	OR.W	D0,D4		; Dd = 0 ?	OR.B	D0,D1		; mode LOAD ?	JUMP',NE NoLoad8$	COMP.W	A5,#1		; Iy source = 1 ?	JUMP',NE NoLoad8$	TEST.L	D2		; hauteur ngative ?	JUMP',NS NoLoad8$	COMP.W	D2,#8		; largeur = 8 ?	JUMP,EQ RASTER_LOAD8NoLoad8$:	LOAD.W	D0,D7	NOT.W	D0	OR.W	D0,D6		; grise ou inverse ?	OR.W	D0,D3		; Ds = 0 ?	OR.B	D0,D1		; mode LOAD ?	JUMP',NE NoLoadC$	TEST.L	D2		; hauteur ngative ?	JUMP',NS NoLoadC$	COMP.W	D2,#16		; largeur troite ?	JUMP,LS RASTER_LOADCNoLoadC$:	LOAD.W	D0,A5	EX.L	A6,D6	OR.W	D0,D6	EX.L	D6,A6	TEST.L	D0:#0		; Iy source ou destination impair ?	JUMP,BS Odd$		; oui => Odd$; Calcule l'adresse de la routine de gestion d'une ligne.Even$:	LOAD.L	A0,#R16"TARASTER_OP	AND.W	D1,#H'0003	SL.W	D1,#1	LOAD.W	D0,D7	NOT.W	D0	OR.W	D0,D6		; grise ou inverse ?	JUMP',EQ NoIG$		; non => NoIG$	ADD.W	D1,#4*2		; oui => cas (2)NoIG$:	ADD.W	A0,(A0)+(D1.W)	; A0 <-- ^routine ligne; Si l'adresse n'est pas paire, recule d'un byte.	LOAD.W	D0,A3	RR.W	D0,#1	JUMP',CC NoPrevS$	DEC.L	A3		; A3 <-- adresse paire	ADD.W	D3,#8		; D3 <-- DsNoPrevS$:	LOAD.W	D0,A4	RR.W	D0,#1	JUMP',CC NoPrevD$	DEC.L	A4		; A4 <-- adresse paire	ADD.W	D4,#8		; D4 <-- DdNoPrevD$:; Calcule le nombre de lignes  traiter.	LOAD.L	D5,D2	SWAP.W	D5		; D5 <-- hauteur	TEST.W	D5	JUMP',NC eUpDown$	NEG.W	D5	EX.L	D5,A5	NEG.W	D5		; A5 <-- -A5	EX.L	A5,D5	EX.L	D5,A6	NEG.W	D5		; A6 <-- -A6	EX.L	A6,D5eUpDown$:	DEC.W	D5		; D5 <-- -1  cause NMO; Calcule le nombre de tranches de 16 bits.	LOAD.W	D1,D2	ADD.W	D1,D4		; D1 <-- Dd + largeur	DEC.W	D1	SR.W	D1,#4		; D1 <-- nb de words -1	LOAD.W	(SP)+RASTNBW,D1	INC.W	D1	SL.W	D1,#1	SUB.W	A5,D1		; A5 <-- Iy source - nb de bytes	SUB.W	A6,D1		; A6 <-- Iy destination - nb de bytes; Calcule les masques de dbut et de fin.	LOAD.L	A1,#R16"TARASTER_MASK	LOAD.W	D1,D4	SL.W	D1,#1	LOAD.W	D1,(A1)+(D1.W)	; D1 <-- masque de dbut	ADD.W	D2,D4		; D2 <-- Dd + largeur	AND.W	D2,#H'000F	SL.W	D2,#1	LOAD.W	D2,(A1)+(D2.W)+32 ; D2 <-- masque de fin; Inverse ventuellement le sens de parcour horizontal.	LOAD.W	A2,#+2		; A2 <-- Ix	TEST.W	(SP)+RASTIIX	JUMP',NC eLeftRight$	LOAD.W	D0,(SP)+RASTNBW	; D0 <-- nb de words -1	SL.W	D0,#1		; D0 <-- nb de bytes -2	ADD.W	A3,D0		; A3 <-- ^word  droite	ADD.W	A4,D0		; A4 <-- ^word  droite	ADD.W	D0,#2	SL.W	D0,#1	ADD.W	A5,D0		; A5 <-- Iy source + nb de bytes	ADD.W	A6,D0		; A6 <-- Iy destination + nb de bytes	EX.L	D1,D2		; change les masques de dbut et de fin	LOAD.W	A2,#-2		; A2 <-- IxeLeftRight$:	LOAD.W	(SP)+RASTMA1,D1; Calcule le nombre de dcalages  droite.	SUB.W	D4,D3		; D4 <-- nb de SR.L	JUMP',NS eExecpt$	SUB.L	A3,#2	JUMP	RASTER_LOOPeExecpt$:	ADD.W	D4,#16	JUMP	RASTER_LOOP; Calcule l'adresse de la routine de gestion d'une ligne,; dans le cas o Iy source ou destination est impair.Odd$:	LOAD.L	A0,#R16"TARASTER_OP	AND.W	D1,#H'0003	SL.W	D1,#1	ADD.W	D1,#8*2	ADD.W	A0,(A0)+(D1.W)	; A0 <-- ^routine ligne; Calcule le nombre de lignes  traiter.	LOAD.L	D5,D2	SWAP.W	D5		; D5 <-- hauteur	TEST.W	D5	JUMP',NC oUpDown$	NEG.W	D5	EX.L	D5,A5	NEG.W	D5		; A5 <-- -A5	EX.L	A5,D5	EX.L	D5,A6	NEG.W	D5		; A6 <-- -A6	EX.L	A6,D5oUpDown$:	DEC.W	D5		; D5 <-- -1  cause NMO; Calcule le nombre de tranches de 16 bits.	LOAD.W	D1,D2	ADD.W	D1,D4		; D1 <-- Dd + largeur	DEC.W	D1	SR.W	D1,#3		; D1 <-- nb de bytes -1	LOAD.W	(SP)+RASTNBW,D1	INC.W	D1	SUB.W	A5,D1		; A5 <-- Iy source - nb de bytes	SUB.W	A6,D1		; A6 <-- Iy destination - nb de bytes; Calcule les masques de dbut et de fin.	LOAD.L	A1,#R16"TARASTER_MASK	LOAD.W	D1,D4	SL.W	D1,#1	LOAD.B	D1,(A1)+(D1.W)	; D1 <-- masque de dbut	ADD.W	D2,D4		; D2 <-- Dd + largeur	AND.W	D2,#H'0007	SL.W	D2,#1	LOAD.B	D2,(A1)+(D2.W)+32 ; D2 <-- masque de fin; Inverse ventuellement le sens de parcour horizontal.	LOAD.W	A2,#+1		; A2 <-- Ix	TEST.W	(SP)+RASTIIX	JUMP',NC oLeftRight$	LOAD.W	D0,(SP)+RASTNBW	; D0 <-- nb de bytes -1	ADD.W	A3,D0		; A3 <-- ^byte  droite	ADD.W	A4,D0		; A4 <-- ^byte  droite	INC.W	D0	SL.W	D0,#1	ADD.W	A5,D0		; A5 <-- Iy source + nb de bytes	ADD.W	A6,D0		; A6 <-- Iy destination + nb de bytes	EX.L	D1,D2		; change les masques de dbut et de fin	LOAD.W	A2,#-1		; A2 <-- IxoLeftRight$:	LOAD.W	(SP)+RASTMA1,D1; Calcule le nombre de dcalages  droite.	SUB.W	D4,D3		; D4 <-- nb de SR.W	JUMP',NS oExcept	DEC.L	A3	JUMP'	RASTER_LOOPoExcept:	ADD.W	D4,#8;	JUMP'	RASTER_LOOP; Boucle principale de traitement des lignes.RASTER_LOOP:	LOAD.W	D1,(SP)+RASTMA1	; D1 <-- masque de dbut	LOAD.W	D3,(SP)+RASTNBW	; D3 <-- nombre de words -1	JUMP	(A0)		; traite une ligneRASTER_RETR:	INC.W	(SP)+RASTPOY	; RASTPOY <-- position suivante en Y	LOAD.W	D0,A6		; va de haut en bas ?	JUMP',NC RASTER_RETURN	; oui => RASTER_RETURN	SUB.W	(SP)+RASTPOY,#2	; RASTPOY <-- position prcdente en YRASTER_RETURN:	ADD.W	A3,A5		; A3 <-- ^ligne suivante source	ADD.W	A4,A6		; A4 <-- ^ligne suivante destination	DECJ.W,NMO D5,RASTER_LOOPRASTER_EXIT:	TEST.B	(SP)+RASTRGR	; rgion rectangulaire ?	JUMP',EQ 20$		; oui => 20$	SUB.L	SP,#2		; stack <-- place pour erreur en retour	PUSH.L	#(SP)+2+RASTLGV	; stack <-- ^variables	GMI_	RELSRGN	POP.W	D7		; D7 <-- ok/erreur	ADD.L	SP,#LgBldRgn20$:	ADD.L	SP,#RASTLGV	; ajuste le stack	POPM.L	D0..D6,A0..A6	CLR.L	D7		; D7 <-- ok	RET; (1)	transfert par words, sans inversion ni gris; (2)	transfert par words, avec inversion et/ou gris; (3)	transfert par bytesTARASTER_OP:	.W	RASTER_LOAD1-TARASTER_OP	.W	RASTER_INV1-TARASTER_OP	.W	RASTER_SET1-TARASTER_OP	.W	RASTER_CLR1-TARASTER_OP	.W	RASTER_LOAD2-TARASTER_OP	.W	RASTER_INV2-TARASTER_OP	.W	RASTER_SET2-TARASTER_OP	.W	RASTER_CLR2-TARASTER_OP	.W	RASTER_LOAD3-TARASTER_OP	.W	RASTER_INV3-TARASTER_OP	.W	RASTER_SET3-TARASTER_OP	.W	RASTER_CLR3-TARASTER_OP;-----------;; RASTER_op ;;-----------;; Traite une ligne dans un mode quelconque.; in	D1.W	masque de dbut;	D2.W	masque de fin;	D3.W	nombre de words -1;	D4.W	nombre de dcalages  droite;	D6.W	inversion (0/-1);	D7.W	gris;	A2.W	Ix (+2/-2);	A3.L	^source;	A4.L	^destination; out	D7.W	gris suivant; mod	D0.L, D1.L, D3.L, D7.L, A3.L, A4.LRASTER_INV1:	TEST.B	(SP)+RASTRGR	; rgion rectangulaire ?	JUMP,NE RASTER_INV1R	; non => RASTER_INV1R	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D1		; D0 <-- conserve la partie utile	XOR.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	JUMP	RASTER_RETURNRASTER_INV1R:	LOAD.W	D0,(SP)+RASTPOY	COMP.W	D0,(SP)+RASTCHY	; y a-t-il un changement ?	JUMP',NE 15$	LOAD.L	A1,(SP)+RASTASK	SUB.L	SP,#2		; stack <-- place pour paramtres en retour	PUSH.L	#(SP)+2+RASTLGV	; stack <-- ^variables	PUSH.W	D0		; stack <-- position en Y	PUSH.L	#(SP)+2+4+2+RASTLSK ; stack <-- ^(VAR ^ligne de masque)	CALL	(A1)		; appel GMI_SEEKSRGN: calcule la ligne de masque	POP.W	(SP)+RASTCHY15$:	LOAD.L	A1,(SP)+RASTLSK	; A1 <-- ^ligne de masque	LOAD.W	D0,A2		; de gauche  droite ?	JUMP',NC 20$		; oui => 20$	ADD.W	A1,D3	ADD.W	A1,D3		; A1 <-- ^fin ligne de masque20$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,(A1)		; D0 <-- conserve la partie utile	ADD.W	A1,A2		; A1 <-- ^suivant dans masque	XOR.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	DECJ.W,NMO D3,20$	JUMP	RASTER_RETRRASTER_INV2:	TEST.B	(SP)+RASTRGR	; rgion rectangulaire ?	JUMP,NE RASTER_INV2R	; non => RASTER_INV2R	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	AND.W	D0,D1		; D0 <-- conserve la partie utile	XOR.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	SWAP.W	D7		; D7 <-- gris suivant	JUMP	RASTER_RETURNRASTER_INV2R:	LOAD.W	D0,(SP)+RASTPOY	COMP.W	D0,(SP)+RASTCHY	; y a-t-il un changement ?	JUMP',NE 15$	LOAD.L	A1,(SP)+RASTASK	SUB.L	SP,#2		; stack <-- place pour paramtres en retour	PUSH.L	#(SP)+2+RASTLGV	; stack <-- ^variables	PUSH.W	D0		; stack <-- position en Y	PUSH.L	#(SP)+2+4+2+RASTLSK ; stack <-- ^(VAR ^ligne de masque)	CALL	(A1)		; appel GMI_SEEKSRGN: calcule la ligne de masque	POP.W	(SP)+RASTCHY15$:	LOAD.L	A1,(SP)+RASTLSK	; A1 <-- ^ligne de masque	LOAD.W	D0,A2		; de gauche  droite ?	JUMP',NC 20$		; oui => 20$	ADD.W	A1,D3	ADD.W	A1,D3		; A1 <-- ^fin ligne de masque20$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	AND.W	D0,(A1)		; D0 <-- conserve la partie utile	ADD.W	A1,A2		; A1 <-- ^suivant dans masque	XOR.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	DECJ.W,NMO D3,20$	SWAP.W	D7		; D7 <-- gris suivant	JUMP	RASTER_RETRRASTER_INV3:	TEST.B	(SP)+RASTRGR	; rgion rectangulaire ?	JUMP,NE RASTER_INV3R	; non => RASTER_INV3R	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.B	D0,(A3)	SL.W	D0,#8	LOAD.B	D0,(A3)+1	; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.W	D0,D4		; D0 <-- dcale selon D4	AND.B	D0,D7		; D0 <-- "grise" si ncessaire	XOR.B	D0,D6		; D0 <-- "inverse" si ncessaire	AND.B	D0,D1		; D0 <-- conserve la partie utile	XOR.B	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	SWAP.W	D7		; D7 <-- gris suivant	JUMP	RASTER_RETURNRASTER_INV3R:	LOAD.W	D0,(SP)+RASTPOY	COMP.W	D0,(SP)+RASTCHY	; y a-t-il un changement ?	JUMP',NE 15$	LOAD.L	A1,(SP