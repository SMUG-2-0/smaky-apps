ASTPOY	COMP.W	D0,(SP)+RASTCHY	; y a-t-il un changement ?	JUMP',NE 15$	LOAD.L	A1,(SP)+RASTASK	SUB.L	SP,#2		; stack <-- place pour paramtres en retour	PUSH.L	#(SP)+2+RASTLGV	; stack <-- ^variables	PUSH.W	D0		; stack <-- position en Y	PUSH.L	#(SP)+2+4+2+RASTLSK ; stack <-- ^(VAR ^ligne de masque)	CALL	(A1)		; appel GMI_SEEKSRGN: calcule la ligne de masque	POP.W	(SP)+RASTCHY15$:	LOAD.L	A1,(SP)+RASTLSK	; A1 <-- ^ligne de masque	LOAD.W	D0,A2		; de gauche  droite ?	JUMP',NC 20$		; oui => 20$	ADD.W	A1,D3	ADD.W	A1,D3		; A1 <-- ^fin ligne de masque20$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.W	D1,(A1)		; D1 <-- masque	ADD.W	A1,A2		; A1 <-- ^suivant dans masque	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	DECJ.W,NMO D3,20$	SWAP.W	D7		; D7 <-- gris suivant	JUMP	RASTER_RETRRASTER_LOAD3:	TEST.B	(SP)+RASTRGR	; rgion rectangulaire ?	JUMP,NE RASTER_LOA3R	; non => RASTER_LOA3R	DEC.W	D3	JUMP',NS 40$	LOAD.B	D0,(A3)	SL.W	D0,#8	LOAD.B	D0,(A3)+1	; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.W	D0,D4		; D0 <-- dcale selon D4	AND.B	D0,D7		; D0 <-- "grise" si ncessaire	XOR.B	D0,D6		; D0 <-- "inverse" si ncessaire	AND.B	D0,D1		; D0 <-- conserve la partie utile	NOT.B	D1	AND.B	D1,(A4)	OR.B	D0,D1	LOAD.B	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP',NS 40$30$:	LOAD.B	D0,(A3)	SL.W	D0,#8	LOAD.B	D0,(A3)+1	; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.W	D0,D4		; D0 <-- dcale selon D4	AND.B	D0,D7		; D0 <-- "grise" si ncessaire	XOR.B	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.B	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	DECJ.W,NMO D3,30$40$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.B	D0,(A3)	SL.W	D0,#8	LOAD.B	D0,(A3)+1	; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.W	D0,D4		; D0 <-- dcale selon D4	AND.B	D0,D7		; D0 <-- "grise" si ncessaire	XOR.B	D0,D6		; D0 <-- "inverse" si ncessaire	AND.B	D0,D1		; D0 <-- conserve la partie utile	NOT.B	D1	AND.B	D1,(A4)	OR.B	D0,D1	LOAD.B	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	SWAP.W	D7		; D7 <-- gris suivant	JUMP	RASTER_RETURNRASTER_LOA3R:	LOAD.W	D0,(SP)+RASTPOY	COMP.W	D0,(SP)+RASTCHY	; y a-t-il un changement ?	JUMP',NE 15$	LOAD.L	A1,(SP)+RASTASK	SUB.L	SP,#2		; stack <-- place pour paramtres en retour	PUSH.L	#(SP)+2+RASTLGV	; stack <-- ^variables	PUSH.W	D0		; stack <-- position en Y	PUSH.L	#(SP)+2+4+2+RASTLSK ; stack <-- ^(VAR ^ligne de masque)	CALL	(A1)		; appel GMI_SEEKSRGN: calcule la ligne de masque	POP.W	(SP)+RASTCHY15$:	LOAD.L	A1,(SP)+RASTLSK	; A1 <-- ^ligne de masque	LOAD.W	D0,A2		; de gauche  droite ?	JUMP',NC 20$		; oui => 20$	ADD.W	A1,D3		; A1 <-- ^fin ligne de masque20$:	LOAD.B	D0,(A3)	SL.W	D0,#8	LOAD.B	D0,(A3)+1	; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.W	D0,D4		; D0 <-- dcale selon D4	AND.B	D0,D7		; D0 <-- "grise" si ncessaire	XOR.B	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.B	D1,(A1)		; D1 <-- masque	ADD.W	A1,A2		; A1 <-- ^suivant dans masque	AND.B	D0,D1		; D0 <-- conserve la partie utile	NOT.B	D1	AND.B	D1,(A4)	OR.B	D0,D1	LOAD.B	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	DECJ.W,NMO D3,20$	SWAP.W	D7		; D7 <-- gris suivant	JUMP	RASTER_RETR; Cas super-optimis pour les caractres standards NRF09 ou NEF11,; avec les conditions suivantes :;	mode LOAD;	pas d'inversion ni de gris;	position multiple de 8;	largeur strictement gale  8RASTER_LOAD8:	SWAP.W	D2		; D2 <-- hauteur	DEC.W	D2		; D2 <-- -1  cause NMO20$:	LOAD.B	(A4),(A3+)	; destination <-- data	ADD.W	A4,A6		; A4 <-- ^ligne suivante destination	DECJ.W,NMO D2,20$	ADD.L	SP,#RASTLGV	; ajuste le stack	POPM.L	D0..D6,A0..A6	CLR.L	D7		; D7 <-- ok	RET; Cas optimis pour des caractres pas trop grands en mode LOAD.; in	D2.L	dimensions (dy;dx);	D4.W	Dd;	A3.L	^source;	A4.L	^destination;	A5.W	Iy source;	A6.W	Iy destinationRASTER_LOADC:	LOAD.L	D6,D2	SWAP.W	D6		; D6 <-- hauteur	LOAD.W	D7,D2		; D7 <-- largeur; Calcul l1 et l2, c'est--dire le dcalage horizontal par; rapport aux bytes dans l'cran, ainsi que les masques; correspondants.;	!      byte	!;	!---------------!		gnrateur caractres;    l1      l2;   <--> <-------->;  !---------------!---------------!	cran;  !      byte     !     byte      !;	LOAD.W	D4,D4		; D4 <-- l1	LOAD.W	D5,#8	SUB.W	D5,D4		; D5 <-- l2	DEC.W	D6		; -1  cause du test NMO !	LOAD.B	D3,(PC)+(D5.W)+02$	SWAP.W	D3	LOAD.B	D3,(PC)+(D4.W)+01$ ; D3 <-- 11111000 00000111; Calcul la valeur  ajouter dans le gnrateur de caractres; lorsque la coordonne Y augmente de 1.20$:	SUB.B	D7,D5		; D7 <-- D7 - l2	JUMP,LE 50$	SUB.B	D7,D4		; D7 <-- D7 - l1	JUMP,LE 60$	PUSHM.L	D6,A3,A4	TEST.B	D4		; l1 = zro ?	JUMP',EQ 35$		; oui => 35$30$:	LOAD.B	D0,(A4)		; D0 <-- byte de l'cran	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A3)		; D1 <-- byte de GENCAR	SR.B	D1,D4		; dcale selon l1	OR.B	D0,D1	LOAD.B	(A4),D0		; remet byte dans l'cran	LOAD.B	D0,(A4)+1	; D0 <-- byte de l'cran	SWAP.W	D3	AND.B	D0,D3		; garde partie utile	SWAP.W	D3	LOAD.B	D1,(A3)		; D1 <-- byte de GENCAR	SL.B	D1,D5		; dcale selon l2	OR.B	D0,D1	LOAD.B	(A4)+1,D0	; remet byte dans l'cran	ADD.W	A4,A6		; A4 <-- ^plus bas dans cran	ADD.W	A3,A5		; A3 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,30$	JUMP'	40$01$:	.B	B'00000000		; l1 = 0	.B	B'10000000		; l1 = 1	.B	B'11000000		; l1 = 2	.B	B'11100000		; l1 = 3	.B	B'11110000		; l1 = 4	.B	B'11111000		; l1 = 5	.B	B'11111100		; l1 = 6	.B	B'11111110		; l1 = 702$:	.B	B'00000000		; l2 = 0	.B	B'00000001		; l2 = 1	.B	B'00000011		; l2 = 2	.B	B'00000111		; l2 = 3	.B	B'00001111		; l2 = 4	.B	B'00011111		; l2 = 5	.B	B'00111111		; l2 = 6	.B	B'01111111		; l2 = 735$:	LOAD.B	D1,(A3)		; D1 <-- byte de GENCAR	LOAD.B	(A4),D1		; met byte dans l'cran	ADD.W	A4,A6		; A4 <-- ^plus bas dans cran	ADD.W	A3,A5		; A3 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,35$40$:	POPM.L	D6,A3,A4	INC.L	A4		; A4 <-- ^ droite dans cran	INC.L	A3		; A3 <-- ^suivant dans GENCAR	JUMP	20$; Dessine la dernire tranche de droite au milieu d'un byte; dans l'cran.50$:	NEG.B	D7	LOAD.B	D5,(PC)+(D7.W)+02$	OR.B	D3,D5		; D3 <-- 11000111	JUMP',EQ 55$	NOT.B	D5		; D5 <-- 0011111152$:	LOAD.B	D0,(A4)		; D0 <-- byte de l'cran	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A3)		; D1 <-- byte de GENCAR	SR.B	D1,D4		; dcale selon l1	AND.B	D1,D5		; masque partie de droite	OR.B	D0,D1	LOAD.B	(A4),D0		; remet byte dans l'cran	ADD.W	A4,A6		; A4 <-- ^plus bas dans cran	ADD.W	A3,A5		; A3 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,52$	JUMP	90$55$:	LOAD.B	D1,(A3)		; D1 <-- byte de GENCAR	LOAD.B	(A4),D1		; remet byte dans l'cran	ADD.W	A4,A6		; A4 <-- ^plus bas dans cran	ADD.W	A3,A5		; A3 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,55$	JUMP	90$; Dessine les deux dernires tranches de droite, la premire;  droite d'un byte de l'cran, et la deuxime  gauche d'un; byte de l'cran (mais plus troite).60$:	JUMP',EQ 62$	NEG.B	D7	SWAP.W	D361$:	SETX	RLX.B	D3,#1		; augmente masque	DEC.B	D7	JUMP,NE	61$	SWAP.W	D362$:	SWAP.W	D3	LOAD.B	D7,D3	NOT.B	D7		; D7 <-- masque pour caractre	SWAP.W	D365$:	LOAD.B	D0,(A4)		; D0 <-- byte de l'cran	AND.B	D0,D3		; garde partie utile	LOAD.B	D1,(A3)		; D1 <-- byte de GENCAR	SR.B	D1,D4		; dcale selon l1	OR.B	D0,D1	LOAD.B	(A4),D0		; remet byte dans l'cran	LOAD.B	D0,(A4)+1	; D0 <-- byte de l'cran	SWAP.W	D3	AND.B	D0,D3		; garde partie utile	SWAP.W	D3	LOAD.B	D1,(A3)		; D1 <-- byte de GENCAR	SL.B	D1,D5		; dcale selon l2	AND.B	D1,D7		; masque partie de droite	OR.B	D0,D1	LOAD.B	(A4)+1,D0	; remet byte dans l'cran	ADD.W	A4,A6		; A4 <-- ^plus bas dans cran	ADD.W	A3,A5		; A3 <-- ^suivant dans GENCAR	DECJ.W,NMO D6,65$90$:	ADD.L	SP,#RASTLGV	; ajuste le stack	POPM.L	D0..D6,A0..A6	CLR.L	D7		; D7 <-- ok	RET	.IF	COLOR;-------------\; RASTER_COLOR >;=============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A1.L	^table des masques;	A2.L	^description fentre;	----;	A3.L	^byte source;	D3.W	Ds;	A5.L	Iy source;	----;	A4.L	^byte destination;	D4.W	Dd;	A6.L	Iy destination;	----;	D2.L	hauteur/largeur (y;x);	D1.B	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT);	D6.L	gris/inversion; out	-; mod	-RASTER_COLOR:	SWAP.W	D6	LOAD.W	D7,D6		; D7 <-- gris	SWAP.W	D7	LOAD.W	D7,D6		; D7 <-- gris	COMP.W	D7,#-1	JUMP',EQ 10$	NOT.W	D7		; D7 <-- gris complmentaire	SWAP.W	D710$:	SWAP.W	D6		; D6 <-- inversion (0/-1); Calcule le mode logique pour la couleur.	SUB.L	SP,#2*6		; SP <-- place pour paramtres	LOAD.L	A0,SP		; A0 <-- ^paramtres pour MODVDCCP	COMP.B	D1,#LOADDOT	JUMP',EQ 16$	COMP.B	D1,#CLRDOT	JUMP',EQ 14$	COMP.B	D1,#SETDOT	JUMP',EQ 12$				; INVDOT =>	LOAD.W	(A0)+0,#MVDCNOP	LOAD.W	(A0)+2,#MVDCXOR;	LOAD.W	(A0)+4,#;	LOAD.W	(A0)+6,#	CLR.W	(A0)+8	LOAD.W	(A0)+10,(A2)+ODFCCF+2	LOAD.W	D0,(A2)+ODFCSF+2	XOR.W	(A0)+10,D0	JUMP'	20$12$:				; SETDOT =>	LOAD.W	(A0)+0,#MVDCAND2	LOAD.W	(A0)+2,#MVDCOR1;	LOAD.W	(A0)+4,#;	LOAD.W	(A0)+6,#	CLR.W	(A0)+8	LOAD.W	(A0)+10,(A2)+ODFCSF+2	JUMP'	20$14$:				; CLRDOT =>	LOAD.W	(A0)+0,#MVDCAND2	LOAD.W	(A0)+2,#MVDCOR1;	LOAD.W	(A0)+4,#;	LOAD.W	(A0)+6,#	CLR.W	(A0)+8	LOAD.W	(A0)+10,(A2)+ODFCCF+2	JUMP'	20$16$:				; LOADDOT =>	LOAD.W	(A0)+0,#MVDCZERO	LOAD.W	(A0)+2,#MVDCLOAD	LOAD.W	(A0)+4,#MVDCNOT1	LOAD.W	(A0)+6,#MVDCONE	LOAD.W	(A0)+8,(A2)+ODFCCF+2	LOAD.W	(A0)+10,(A2)+ODFCSF+2;	JUMP'	20$20$:	PUSHM.L	D2,D3,D4,A3,A4; Si l'adresse n'est pas paire, recule d'un byte.	LOAD.W	D0,A3	RR.W	D0,#1	JUMP',CC 30$	DEC.L	A3		; A3 <-- adresse paire	ADD.W	D3,#8		; D3 <-- Ds30$:	LOAD.W	D0,A4	RR.W	D0,#1	JUMP',CC 32$	DEC.L	A4		; A4 <-- adresse paire	ADD.W	D4,#8		; D4 <-- Dd32$:; Effectue le travail de dbut.	LOAD.W	D0,D3	OR.W	D0,D4	JUMP',NE 40$	COMP.W	D2,#16	JUMP,LO 70$	JUMP	50$40$:	LOAD.W	D0,D4	SL.W	D0,#1	LOAD.W	D5,(A1)+(D0.W)	; D5 <-- masque	CALL	MODVDCCP	; init le mode logique selon (A0)	LOAD.W	D1,D4	SUB.W	D4,D3		; D4 <-- Dm	JUMP',HS 44$	ADD.W	D4,#16		; D4 <-- Dm	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	SWAP.W	D044$:	ADD.W	D2,D1	SUB.W	D2,#16		; D2 <-- largeur restante	JUMP,LO 72$	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.L	D1,D0	RR.L	D1,D4	LOAD.W	(A4+),D1	; destination <-- dbut	SWAP.W	D0; Effectue le travail du milieu.50$:	LOAD.W	D3,D2	SR.W	D3,#4		; D3 <-- nb de words	JUMP,EQ 60$	DEC.W	D3		; D3 <-- -1  cause NMO	LOAD.W	D5,#H'FFFF	CALL	MODVDCCP	; init le mode logique selon (A0)52$:	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.L	D1,D0	RR.L	D1,D4	LOAD.W	(A4+),D1	; destination <-- milieu	SWAP.W	D0	DECJ.W,NMO D3,52$; Effectue le travail de fin.60$:	AND.W	D2,#H'000F	JUMP,EQ 80$	SL.W	D2,#1	LOAD.W	D5,(A1)+(D2.W)	; D5 <-- masque	NOT.W	D5	CALL	MODVDCCP	; init le mode logique selon (A0)	LOAD.W	D0,(A3)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	RR.L	D0,D4	LOAD.W	(A4),D0		; destination <-- fin	JUMP	80$; Effectue le travail de dbut/fin.70$:	SUB.W	D2,#16	LOAD.W	D5,#H'FFFF72$:	ADD.W	D2,#16	SL.W	D2,#1	LOAD.W	D1,(A1)+(D2.W)	; D1 <-- masque	NOT.W	D1	AND.W	D5,D1		; D5 <-- masque le masque !	CALL	MODVDCCP	; init le mode logique selon (A0)	LOAD.W	D0,(A3)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	RR.L	D0,D4	LOAD.W	(A4),D0		; destination <-- dbut/fin;	JUMP	80$80$:	POPM.L	D2,D3,D4,A3,A4	ADD.L	A3,A5		; A3 <-- ajoute Iy source	ADD.L	A4,A6		; A4 <-- ajoute Iy destination	SWAP.W	D7		; D7 <-- "gris" suivant	SUB.L	D2,#H'10000	LOAD.L	D1,D2	SWAP.W	D1	TEST.W	D1	JUMP,NE 20$	ADD.L	SP,#2*6		; SP <-- ajuste	POPM.L	D0..D7,A0..A6	RET	.ENDIFTARASTER_MASK:	.W	B'1111111111111111	.W	B'0111111111111111	.W	B'0011111111111111	.W	B'0001111111111111	.W	B'0000111111111111	.W	B'0000011111111111	.W	B'0000001111111111	.W	B'0000000111111111	.W	B'0000000011111111	.W	B'0000000001111111	.W	B'0000000000111111	.W	B'0000000000011111	.W	B'0000000000001111	.W	B'0000000000000111	.W	B'0000000000000011	.W	B'0000000000000001	.W	B'1111111111111111	.W	B'1000000000000000	.W	B'1100000000000000	.W	B'1110000000000000	.W	B'1111000000000000	.W	B'1111100000000000	.W	B'1111110000000000	.W	B'1111111000000000	.W	B'1111111100000000	.W	B'1111111110000000	.W	B'1111111111000000	.W	B'1111111111100000	.W	B'1111111111110000	.W	B'1111111111111000	.W	B'1111111111111100	.W	B'1111111111111110	.END