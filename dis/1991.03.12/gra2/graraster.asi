	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	JUMP	RASTER_RETURNRASTER_LOADQ:	ADD.L	A3,#2	DEC.W	D3	JUMP',NS 40$	LOAD.W	D0,(A3+)	; D0 <-- source	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4+),D0	; destination <-- data	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	TEST.W	D3	JUMP',EQ 40$	TCLR.L	D3:#0	JUMP',BC 30$	LOAD.W	(A4+),(A3+)	; destination <-- data (juste une fois .W)30$:	SUB.W	D3,#16*2	JUMP',HS 34$	LOAD.W	D0,D3	NEG.W	D0	JUMP	(D0.W)+R8"34$	; saute en 34$ + qq instructions34$:	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	TEST.W	D3		; encore qq chose ?	JUMP,GT 30$		; oui => 30$40$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.W	D0,(A3+)	; D0 <-- source	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4+),D0	; destination <-- data	SUB.L	A3,#2	JUMP	RASTER_RETURNRASTER_LOA1R:	LOAD.W	D0,(SP)+RASTPOY	COMP.W	D0,(SP)+RASTCHY	; y a-t-il un changement ?	JUMP',NE 15$	LOAD.L	A1,(SP)+RASTASK	SUB.L	SP,#2		; stack <-- place pour paramtres en retour	PUSH.L	#(SP)+2+RASTLGV	; stack <-- ^variables	PUSH.W	D0		; stack <-- position en Y	PUSH.L	#(SP)+2+4+2+RASTLSK ; stack <-- ^(VAR ^ligne de masque)	CALL	(A1)		; appel GMI_SEEKSRGN: calcule la 