	.SBTTL	GRASPRITE;------------\; _GRA_SPRITE >;============/; Effectue une opration avec un lutin.; in	A2.L	^description de la fentre;	D6.B	numro du lutin;	D0.W	opration (SPRITE_??);	D4.L	coordonne (y;x);	D3.L	dimensions (dy;dx) si SPRITE_OPEN;	A4.L	^matrice du lutin (set) si SPRITE_OPEN;	A3.L	^matrice du fond (clear) si SPRITE_OPEN (^nil=calcul); out	D7.W	erreur; mod	D7.W_GRA_SPRITE:	COMP.W	D0,#SPRITE_MOVE	JUMP,EQ	MSPRITE	COMP.W	D0,#SPRITE_OPEN	JUMP,EQ	FSPRITE	COMP.W	D0,#SPRITE_SET	JUMP,EQ	FSPRITE	COMP.W	D0,#SPRITE_CLOSE	JUMP,EQ	LSPRITE	COMP.W	D0,#SPRITE_CLEAR	JUMP,EQ	LSPRITE	COMP.W	D0,#SPRITE_GETPOS	JUMP,EQ	GSPRITE	RET;---------\; FSPRITE  >;=========/; Dessine le premier lutin.; in	A2.L	^description de la fentre;	D6.B	numro du lutin;	D0.W	opration (SPRITE_OPEN/SPRITE_SET);	D4.L	premire coordonne (y;x);	D3.L	dimensions (dy;dx);	A4.L	^matrice du lutin (set);	A3.L	^matrice du fond (clear) (^nil=calcul); out	D7.W	erreur; mod	D7.WFSPRITE:	PUSHM.L	D0..D6,A1,A3,A4,A6	COMP.W	D0,#SPRITE_OPEN	JUMP,NE	40$	CALL	SRCLU		; A6 <-- ^variables du lutin	COMP.W	D7,#ERDIIL	; lutin libre ?	JUMP',EQ 10$		; oui => 10$	TEST.W	D7		; autre erreur ?	JUMP,NE	90$		; oui => 90$				; lutin occup =>	LOAD.W	D0,#SPRITE_CLOSE	CALL	LSPRITE		; ferme le lutin actuel10$:	TSET.B	(A6)+OLUUSE:#0	; occupe le lutin; Initialise les variables du lutin en fonction des paramtres; donns par l'utilisateur.	LOAD.L	(A6)+OLUOLD,D4	LOAD.L	(A6)+OLULGY,D3	; mm. dimensions du lutin	LOAD.L	(A6)+OLUPTS,A4	; mm. ^matrice du lutin	LOAD.L	(A6)+OLUPTC,A3	; mm. ^matrice du fond	ADD.W	D3,#8-1	SR.W	D3,#3		; D3 <-- largeur en bytes	LOAD.W	(A6)+OLUIYF,D3	SL.W	D3,#1		; D3 <-- idem *2	LOAD.W	(A6)+OLUIYO,D3; Rserve la mmoire pour les matrices temporaires "fond" (1x) et; "opration" (4x). Si la matrice du fond n'est pas donne par; l'utilisateur, rserve encore 1x la place.	LOAD.W	D4,(A6)+OLUIYF	MUL.WU	D4,(A6)+OLULGY	LOAD.L	D1,D4	.IF	COLOR	CLR.L	(A6)+OLUBYF	CLR.L	(A6)+OLUBYO	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP',EQ 20$		; non => 20$	LOAD.L	D0,D4	LOAD.L	(A6)+OLUBYF,D0	MUL.WU	D0,#4	LOAD.L	(A6)+OLUBYO,D0	MUL.WU	D4,#8		; D4 <-- mmoire pour 8 plans !20$:	.ENDIF	LOAD.L	D0,D4	MUL.WU	D4,#1+4	TEST.L	(A6)+OLUPTC	; matrice du fond existe ?	JUMP',NE 22$		; oui => 22$	ADD.L	D4,D1		; non => prend mmoire pour elle22$:	LOAD.W	D1,#MTYPBD	; D1 <-- type driver bios	LOAD.L	A1,(A2)+ODFBAS	; A1 <-- ^base du driver	GESMEM	?GETMEM		; demande mmoire tampon	JUMP,NE 80$	LOAD.L	(A6)+OLUPTF,A4	; mm ^pour fond de l'cran	ADD.L	A4,D0	LOAD.L	(A6)+OLUPTO,A4	; mm ^pour oprations	CLR.B	(A6)+OLUSET	; lutin pas encore dessin	TEST.L	(A6)+OLUPTC	; matrice du fond existe ?	JUMP,NE 50$		; oui => 50$; Calcul automatiquement la matrice du fond (clear) en supposant un; espace d'un point tout autour de la matrice de la chair (set).	MUL.WU	D0,#4	ADD.L	A4,D0	LOAD.L	(A6)+OLUPTC,A4	; mm ^pour matrice fond	LOAD.L	D3,#H'10000*1+1	; D3 <-- coor. source (1;1)	LOAD.L	A3,(A6)+OLUPTS	; A3 <-- ^matrice du lutin	LOAD.W	D5,(A6)+OLUIYF	; D5 <-- Iy	CLR.L	D4		; D4 <-- coor. destination (0;0)	LOAD.W	D6,D5		; D6 <-- Iy	LOAD.L	D2,(A6)+OLULGY	; D2 <-- dimensions (dy;dx)	CALL	RASTER_CLR	SUB.W	D2,#2		; D2 <-- enlve marges gauche + droite	SWAP.W	D2	SUB.W	D2,#2		; D2 <-- enlve marges haut + bas	SWAP.W	D2	LOAD.W	D1,#SETDOT	; D1 <-- mode30$:	CALL	RASTER_MM	INC.W	D4		; D4 <-- inc X destination	COMP.W	D4,#3	JUMP,LO	30$	CLR.W	D4		; D4 <-- revient  gauche en X	SWAP.W	D4	INC.W	D4		; D4 <-- inc Y destination	LOAD.W	D0,D4	SWAP.W	D4	COMP.W	D0,#3	JUMP,LO	30$	JUMP'	50$40$:				; SPRITE_SET =>	CALL	SRCLU		; A6 <-- ^variables du lutin	JUMP',NE 90$	LOAD.L	(A6)+OLUOLD,D450$:	LOAD.L	(A6)+OLUNEW,(A6)+OLUOLD	CALL	CLRLUTIN	; enlve les lutins dessus	CALL	SSPRITE		; dessine le lutin	CALL	SETLUTIN	; remet les lutins dessus	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	TCLR.B	(A6)+OLUUSE:#0	; libre le lutin90$:	POPM.L	D0..D6,A1,A3,A4,A6	TEST.W	D7		; retour EQ/NE	RET;--------\; SSPRITE >;--------/; Dessine un premier lutin.; in	A6.L	^variables du lutin; out	-; mod	D7.WSSPRITE:	PUSHM.L	D1..D6,A3,A4	TEST.B	(A6)+OLUSET	; lutin dj dessin ?	JUMP,T	90$		; oui => 90$				; non =>	LOAD.L	D3,(A6)+OLUOLD	LOAD.L	A4,(A6)+OLUPTF	CLR.L	D4	LOAD.W	D6,(A6)+OLUIYF	LOAD.L	D2,(A6)+OLULGY	LOAD.W	D1,#LOADDOT	.IF	COLOR	PUSH.L	A6	LOAD.L	A6,(A6)+OLUBYF	CALL	RASTERC_DM	; sauve le fond	POP.L	A6	.ELSE	CALL	RASTER_DM	; sauve le fond	.ENDIF	LOAD.L	A3,(A6)+OLUPTC	CLR.L	D3	LOAD.W	D5,(A6)+OLUIYF	LOAD.L	D4,(A6)+OLUOLD	LOAD.W	D1,#CLRDOT	CALL	RASTER_MD	; dessine le fond du motif	LOAD.L	A3,(A6)+OLUPTS	LOAD.W	D1,#SETDOT	CALL	RASTER_MD	; dessine le contenu du motif	SET.B	(A6)+OLUSET	; signal lutin dessin90$:	POPM.L	D1..D6,A3,A4	RET;---------\; MSPRITE  >;=========/; Dplace un lutin.; in	A2.L	^description de la fentre;	D6.L	canal du lutin;	D4.L	nouvelle coordonne; out	-; mod	-MSPRITE:	PUSHM.L	D0..D6,A3,A4,A6	CALL	SRCLU		; A6 <-- ^variables du lutin	JUMP,NE	90$	TEST.B	(A6)+OLUSET	; lutin dj dessin ?	JUMP',T 05$		; oui => 05$				; non =>	LOAD.W	D0,#SPRITE_SET	CALL	FSPRITE		; met le premier lutin	JUMP	90$05$:	LOAD.L	(A6)+OLUNEW,D4	CALL	CLRLUTIN	; enlve les lutins dessus	LOAD.W	D3,(A6)+OLUOLD+0 ; D3 <-- Y le plus petit	LOAD.W	D1,(A6)+OLUNEW+0	COMP.W	D3,D1	JUMP',LS 10$	EX.L	D3,D1		; D3 <-- Y le plus petit10$:	SUB.W	D1,D3		; D1 <-- |diffrence|	SWAP.W	D3	LOAD.W	D4,(A6)+OLUOLD+2 ; D4 <-- X le plus petit	LOAD.W	D2,(A6)+OLUNEW+2	COMP.W	D4,D2	JUMP',LS 15$	EX.L	D4,D2		; D4 <-- X le plus petit15$:	SUB.W	D2,D4		; D2 <-- |diffrence|	LOAD.W	D3,D4	COMP.W	D2,(A6)+OLULGX	; intersection avec l'ancien ?	JUMP,HS	50$		; non => 50$	COMP.W	D1,(A6)+OLULGY	JUMP,HS	50$	ADD.W	D2,(A6)+OLULGX	; D2 <-- largeur	ADD.W	D1,(A6)+OLULGY	; D1 <-- hauteur	SWAP.W	D2	LOAD.W	D2,D1	SWAP.W	D2		; D2 <-- hauteur/largeur	LOAD.L	(A6)+OLUORI,D3	LOAD.L	A4,(A6)+OLUPTO	CLR.L	D4	LOAD.W	D6,(A6)+OLUIYO	LOAD.W	D1,#LOADDOT	.IF	COLOR	PUSH.L	A6	LOAD.L	A6,(A6)+OLUBYO	CALL	RASTERC_DM	; cran --> buffer oprations	POP.L	A6	.ELSE	CALL	RASTER_DM	; cran --> buffer oprations	.ENDIF	PUSH.L	D2	LOAD.L	D2,(A6)+OLULGY	LOAD.L	A3,(A6)+OLUPTF	CLR.L	D3	LOAD.W	D5,(A6)+OLUIYF;	LOAD.L	A4,(A6)+OLUPTO	LOAD.W	D4,(A6)+OLUOLD+0	SUB.W	D4,(A6)+OLUORI+0	SWAP.W	D4	LOAD.W	D4,(A6)+OLUOLD+2	SUB.W	D4,(A6)+OLUORI+2;	LOAD.W	D6,(A6)+OLUIYO	LOAD.W	D1,#LOADDOT	.IF	COLOR	PUSHM.L	A5,A6	LOAD.L	A5,(A6)+OLUBYF	LOAD.L	A6,(A6)+OLUBYO	CALL	RASTERC_MM	; remet le fond --> buffer opration	POPM.L	A5,A6	.ELSE	CALL	RASTER_MM	; remet le fond --> buffer opration	.ENDIF	LOAD.L	A3,(A6)+OLUPTO	LOAD.W	D3,(A6)+OLUNEW+0	SUB.W	D3,(A6)+OLUORI+0	SWAP.W	D3	LOAD.W	D3,(A6)+OLUNEW+2	SUB.W	D3,(A6)+OLUORI+2	LOAD.W	D5,(A6)+OLUIYO	LOAD.L	A4,(A6)+OLUPTF	CLR.L	D4	LOAD.W	D6,(A6)+OLUIYF	LOAD.W	D1,#LOADDOT	.IF	COLOR	PUSHM.L	A5,A6	LOAD.L	A5,(A6)+OLUBYO	LOAD.L	A6,(A6)+OLUBYF	CALL	RASTERC_MM	; sauve le nouveau fond	POPM.L	A5,A6	.ELSE	CALL	RASTER_MM	; sauve le nouveau fond	.ENDIF	LOAD.L	D4,D3	LOAD.L	A3,(A6)+OLUPTC	CLR.L	D3	LOAD.W	D5,(A6)+OLUIYF	LOAD.L	A4,(A6)+OLUPTO	LOAD.W	D6,(A6)+OLUIYO	LOAD.W	D1,#CLRDOT	.IF	COLOR	PUSHM.L	A5,A6	LOAD.L	A5,#0	LOAD.L	A6,(A6)+OLUBYO	CALL	RASTERC_MM	; met le fond du nouveau motif	POPM.L	A5,A6	.ELSE	CALL	RASTER_MM	; met le fond du nouveau motif	.ENDIF	LOAD.L	A3,(A6)+OLUPTS	LOAD.W	D1,#SETDOT	.IF	COLOR	PUSHM.L	A5,A6	LOAD.L	A5,#0	LOAD.L	A6,(A6)+OLUBYO	CALL	RASTERC_MM	; met le contenu du nouveau motif	POPM.L	A5,A6	.ELSE	CALL	RASTER_MM	; met le contenu du nouveau motif	.ENDIF	POP.L	D2	CLR.L	D3	LOAD.L	A3,(A6)+OLUPTO	LOAD.W	D5,(A6)+OLUIYO	LOAD.L	D4,(A6)+OLUORI	LOAD.W	D1,#LOADDOT	.IF	COLOR	PUSH.L	A5	LOAD.L	A5,(A6)+OLUBYO	CALL	RASTERC_MD	; remet dans l'cran	POP.L	A5	.ELSE	CALL	RASTER_MD	; remet dans l'cran	.ENDIF	JUMP	80$50$:	LOAD.L	D2,(A6)+OLULGY	LOAD.L	A3,(A6)+OLUPTF	CLR.L	D3	LOAD.W	D5,(A6)+OLUIYF	LOAD.L	D4,(A6)+OLUOLD	LOAD.W	D1,#LOADDOT	.IF	COLOR	PUSH.L	A5	LOAD.L	A5,(A6)+OLUBYF	CALL	RASTERC_MD	; remet l'ancien fond dans l'cran	POP.L	A5	.ELSE	CALL	RASTER_MD	; remet l'ancien fond dans l'cran	.ENDIF	LOAD.L	D3,(A6)+OLUNEW	LOAD.L	A4,(A6)+OLUPTF	CLR.L	D4	LOAD.W	D6,(A6)+OLUIYF	LOAD.W	D1,#LOADDOT	.IF	COLOR	PUSH.L	A6	LOAD.L	A6,(A6)+OLUBYF	CALL	RASTERC_DM	; sauve le nouveau fond	POP.L	A6	.ELSE	CALL	RASTER_DM	; sauve le nouveau fond	.ENDIF	LOAD.L	A3,(A6)+OLUPTC	CLR.L	D3	LOAD.W	D5,(A6)+OLUIYF	LOAD.L	D4,(A6)+OLUNEW	LOAD.W	D1,#CLRDOT	CALL	RASTER_MD	; dessine le fond du nouveau motif	LOAD.L	A3,(A6)+OLUPTS	LOAD.W	D1,#SETDOT	CALL	RASTER_MD	; dessine le contenu du nouveau motif80$:	CALL	SETLUTIN	; remet les lutins dessus	LOAD.L	(A6)+OLUOLD,(A6)+OLUNEW90$:	POPM.L	D0..D6,A3,A4,A6	RET;---------\; LSPRITE  >;=========/; Efface le dernier lutin.; in	A2.L	^description de la fentre;	D6.L	canal du lutin;	D0.W	opration (SPRITE_CLOSE/SPRITE_CLEAR); out	D7.W	erreur; mod	D7.WLSPRITE:	PUSHM.L	D1..D6,A1,A3,A4,A6	CALL	SRCLU		; A6 <-- ^variables du lutin	JUMP,NE	90$	LOAD.L	(A6)+OLUNEW,(A6)+OLUOLD	CALL	CLRLUTIN	; enlve les lutins dessus	CALL	CSPRITE		; efface le dernier lutin	CALL	SETLUTIN	; remet les lutins dessus	COMP.W	D0,#SPRITE_CLOSE	JUMP',NE 90$	LOAD.L	A4,(A6)+OLUPTF	; A4 <-- ^dbut tranche mmoire	LOAD.W	D1,#MTYPBD	; D1 <-- type driver bios	LOAD.L	A1,(A2)+ODFBAS	; A1 <-- ^base du driver	GESMEM	?GIVMEM		; rend la mmoire	TCLR.B	(A6)+OLUUSE:#0	; libre le lutin90$:	POPM.L	D1..D6,A1,A3,A4,A6	TEST.W	D7		; retour EQ/NE	RET;--------\; CSPRITE >;--------/; Efface le dernier lutin.; in	A6.L	^variables du lutin; out	-; mod	D7.WCSPRITE:	PUSHM.L	D1..D6,A3,A4	TEST.B	(A6)+OLUSET	; lutin dj enlev ?	JUMP',F 90$		; oui => 90$				; non =>	LOAD.L	A3,(A6)+OLUPTF	CLR.L	D3	LOAD.W	D5,(A6)+OLUIYF	LOAD.L	D4,(A6)+OLUOLD	LOAD.L	D2,(A6)+OLULGY	LOAD.W	D1,#LOADDOT	.IF	COLOR	PUSH.L	A5	LOAD.L	A5,(A6)+OLUBYF	CALL	RASTERC_MD	; remet le fond	POP.L	A5	.ELSE	CALL	RASTER_MD	; remet le fond	.ENDIF	CLR.B	(A6)+OLUSET	; signal lutin enlev90$:	POPM.L	D1..D6,A3,A4	RET;---------\; GSPRITE  >;=========/; Donne la position et les dimensions d'un lutin.; in	A2.L	^description de la fentre;	D6.L	canal du lutin; out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WGSPRITE:	PUSH.L	A6	CALL	SRCLU		; A6 <-- ^variables du lutin	JUMP',NE 90$	LOAD.W	D7,#ERDIIL	; D7 <-- erreur	TEST.B	(A6)+OLUSET	; lutin dj dessin ?	JUMP',F 90$		; non => 90$				; oui =>	LOAD.L	D3,(A6)+OLUOLD	; D3 <-- position	LOAD.L	D4,(A6)+OLULGY	; D4 <-- dimensions	CLR.W	D7		; D7 <-- ok90$:	POP.L	A6	TEST.W	D7		; retour EQ/NE	RET; Gestion des collisions entre lutins d'un mme fentre; -----------------------------------------------------;---------\; CLRLUTIN >;=========/; Efface les lutins en-dessus d'un lutin qui va bouger.; ATTENTION: La rcursion peut utiliser beaucoup de stack !; in	A2.L	^description de la fentre;	A6.L	^variables du lutin; out	-; mod	D7.WCLRLUTIN:	CALL	MSKLU		; enlve tous les masques10$:	PUSHM.L	D3..D6,A6	LOAD.W	D6,(A6)+OLUNUM	; D6 <-- numro du lutin	JUMP',EQ 90$	LOAD.L	D5,(A6)+OLUNEW	; D5 <-- nouvelle position	LOAD.L	D4,(A6)+OLUOLD	; D4 <-- ancienne position	LOAD.L	D3,(A6)+OLULGY	; D3 <-- dimensions du lutin20$:	DEC.W	D6		; D6 <-- numro lutin en dessus	CALL	COLLUTIN	; collision  l'ancienne position ?	JUMP',NE 40$		; non => 40$	CALL	10$		; enlve les lutins sur le lutin  enlever	CALL	CSPRITE		; enlve le lutin	JUMP'	50$		; inutile de l'enlever 2 fois !40$:	EX.L	D4,D5	CALL	COLLUTIN	; collision  la nouvelle position ?	EX.L	D5,D4	JUMP',NE 50$		; non => 50$	CALL	10$		; enlve les lutins sur le lutin  enlever	CALL	CSPRITE		; enlve le lutin50$:	TEST.W	D6		; encore un lutin dessus ?	JUMP,NE	20$		; oui => 20$90$:	POPM.L	D3..D6,A6	RET;---------\; SETLUTIN >;=========/; Remet les lutins en-dessus d'un lutin qui a boug.; in	A2.L	^description de la fentre;	A6.L	^variables du lutin; out	-; mod	D7.WSETLUTIN:	PUSHM.L	D6,A6	LOAD.W	D6,(A6)+OLUNUM	; D6 <-- numro du lutin	JUMP',EQ 90$20$:	DEC.W	D6		; D6 <-- numro lutin en dessus	CALL	SRCLU		; A6 <-- ^variables du lutin	JUMP',NE 50$		; s'il n'existe pas => 50$	TEST.B	(A6)+OLUMSK	; lutin masqu ?	JUMP',F 50$		; non => 50$	CALL	SSPRITE		; oui => remet le lutin50$:	TEST.W	D6		; encore un lutin dessus ?	JUMP,NE	20$		; oui => 20$90$:	POPM.L	D6,A6	RET;---------\; COLLUTIN >;---------/; Test si une zone rectangulaire (spcifie dans D3/D4) entre; en conflit avec un lutin dont le numro est donn dans D6.; in	A2.L	^description de la fentre;	D4.L	coordonne (y;x);	D3.L	dimensions (dy;dx);	D6.W	numro d'un lutin;	D0.W	opration (SPRITE_CLEAR/SPRITE_SET); out	D7.W	EQ => collision;	 A6.L	 ^variable du lutin incrimin;	D7.W	NE => pas de collision; mod	D7.W, A6.LCOLLUTIN:	PUSHM.L	D2,D3,D4	CALL	SRCLU		; A6 <-- ^variables du lutin	JUMP',NE 90$		; s'il n'existe pas => 90$	LOAD.W	D7,#1		; D7 <-- pas de collision	LOAD.W	D2,(A6)+OLUOLD+2; D2 <-- min X lutin	ADD.W	D4,D3		; D4 <-- max X zone	COMP.W	D4,D2	JUMP',LO 90$	ADD.W	D2,(A6)+OLULGX	; D2 <-- max X lutin	SUB.W	D4,D3		; D4 <-- min X zone	COMP.W	D4,D2	JUMP',HS 90$	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,(A6)+OLUOLD+0; D2 <-- min Y lutin	ADD.W	D4,D3		; D4 <-- max Y zone	COMP.W	D4,D2	JUMP',LO 90$	ADD.W	D2,(A6)+OLULGY	; D2 <-- max Y lutin	SUB.W	D4,D3		; D4 <-- min Y zone	COMP.W	D4,D2	JUMP',HS 90$	TEST.B	(A6)+OLUSET	; lutin dj enlev ?	JUMP',F 90$		; oui => 90$	SET.B	(A6)+OLUMSK	; signal lutin (sera) masqu	CLR.W	D7		; D7 <-- collision90$:	POPM.L	D2,D3,D4	TEST.W	D7		; retour EQ/NE	RET; Gestion des variables pour un lutin; -----------------------------------;--------\; MSKLU   >;--------/; Enlve tous les masques  tous les lutins.; in	A2.L	^description de la fentre; out	-; mod	-MSKLU:	PUSHM.L	D6,A6	TEST.L	(A2)+ODFPLU	; variables lutins existent ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A6,(A2)+ODFPLU	; A6 <-- ^variables lutins	LOAD.W	D6,#1		; D6 <-- un seul lutin (la souris)	.IF	COLOR	TEST.B	(A2)+ODFNOW	; fentre $DIS_0 ?	JUMP',EQ 20$		; oui => 20$	COMP.B	(A2)+ODFNOW,#20	; fentre $DIS_20 ?	JUMP',EQ 20$		; oui => 20$	.ELSE	TEST.B	(A2)+ODFNOW	; fentre $DIS_0 ?	JUMP',EQ 20$		; oui => 20$	.ENDIF	LOAD.W	D6,#MAXLU	; D6 <-- nb max de lutins20$:	CLR.B	(A6)+OLUMSK	; enlve le masque	LOAD.L	A6,#(A6)+LGLU	; A6 <-- ^lutin suivant	DEC.W	D6	JUMP,NE	20$90$:	POPM.L	D6,A6	RET;--------\; SRCLU   >;--------/; Cherche un lutin d'aprs son numro.; in	A2.L	^description de la fentre;	D6.B	numro du lutin (0..n); out	A6.L	^variables du lutin;	D7.W	ok/erreur; mod	D7.W, A6.LSRCLU:	PUSHM.L	D1,D4,D6,A1,A4	LOAD.W	D7,#ERDIIL	; D7 <-- erreur	AND.W	D6,#H'FF	LOAD.W	D1,#1		; D1 <-- un seul lutin (la souris)	.IF	COLOR	TEST.B	(A2)+ODFNOW	; fentre $DIS_0 ?	JUMP',EQ 10$		; oui => 10$	COMP.B	(A2)+ODFNOW,#20	; fentre $DIS_20 ?	JUMP',EQ 10$		; oui => 10$	.ELSE	TEST.B	(A2)+ODFNOW	; fentre $DIS_0 ?	JUMP',EQ 10$		; oui => 10$	.ENDIF	LOAD.W	D1,#MAXLU	; D1 <-- nb max de lutins10$:	COMP.W	D6,D1		; canal valide ?	JUMP',HS 90$		; non => 90$	TEST.L	(A2)+ODFPLU	; variables lutins existent ?	JUMP',NE 40$		; oui => 40$	LOAD.W	D4,#LGLU	; D4 <-- lg pour un lutin	MUL.WU	D4,D1		; D4 <-- lg pour tous les lutins	LOAD.W	D1,#MTYPBD	; D1 <-- type driver bios	LOAD.L	A1,(A2)+ODFBAS	; A1 <-- ^base du driver	GESMEM	?GETMEM		; demande mmoire	JUMP',NE 90$	LOAD.L	(A2)+ODFPLU,A420$:	CLR.B	(A4+)		; met toutes les variables  zro	DEC.W	D4	JUMP,NE	20$40$:	LOAD.W	D1,D6		; D1 <-- numro du lutin	LOAD.L	A6,(A2)+ODFPLU	; A6 <-- ^variables lutins	MUL.WU	D6,#LGLU	ADD.L	A6,D6		; A6 <-- ^le bon lutin	LOAD.W	(A6)+OLUNUM,D1	; mm. numro du lutin	LOAD.W	D7,#ERDIIL	; D7 <-- erreur	TEST.B	(A6)+OLUUSE:#0	; lutin utilis ?	JUMP',BC 90$		; non => 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D4,D6,A1,A4	TEST.W	D7		; retour EQ/NE	RET	.END