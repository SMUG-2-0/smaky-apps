	.TITLE	RGN.ASC	.PROC	M68000	.REF	SMAKY	.REF	GRAMISC	.REF	GRA2ODFCRG = LGDIS6-4;================================================; PROGRAMME DE DEMOEXSMILE	=	1	.LOC	0OSRCRGNA:	.BLK.32	1OSRCRGNB:	.BLK.32	1ODSTRGN:	.BLK.32	1OPTDIS:		.BLK.32	1OCHANGM:	.BLK.16	1OCHGRA:		.BLK.16 1OBITMAP:	.BLK.8	LGGBMAPLGVAR:.macro	dlib	?AFTIM.ascize	"(%1) "lib	?getcar.endmacro	.LOC	0	.START	STARTSTART:	.IF	EXSMILE	.ELSE	LIB	?OPELIB	MOVE.32	#LGVAR,D4	GESMEM	?GETMEM	.ENDIF	MOVE.32	A4,A6		; ^vars	MOVE.32	#R16^NMGRA,A3	MOVE.16	#GRA2_FIRST,D3	LIB_	OPEN	JUMP,NE EROR$	MOVE.16	D1,{A6}+OCHGRA	MOVE.32	#R16^TXGRAMISC,A3	MOVE.16	#GMI_FIRST,D3	LIB_	OPEN	JUMP,NE	EROR$	MOVE.16	D1,{A6}+OCHANGM	MOVE.16	#0,D3	LIB	?MOUSE	MOVE.32	#{A6}+OPTDIS,A4	MOVE.32	#4,D4	LIB	?GCHDIS	FOS	?RSTATUS	JUMP,EQ	OK$	LIB	?AFERROROK$:	GMI_	NEWRGN	MOVE.32	A4,{A6}+OSRCRGNA	GMI_	NEWRGN	MOVE.32	A4,{A6}+OSRCRGNB	GMI_	NEWRGN	MOVE.32	A4,{A6}+ODSTRGN.IF	0	PUSH.32	{A6}+OSRCRGNA	PUSH.16	#60		; left	PUSH.16	#30		; top	PUSH.16	#300		; right	PUSH.16	#200		; bottom	CALL	SETRECTRGN	PUSH.32	{A6}+OSRCRGNB	PUSH.16	#250		; left	PUSH.16	#100		; top	PUSH.16	#500		; right	PUSH.16	#300		; bottom	CALL	SETRECTRGN	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion A:"	MOVE.32	{A6}+OSRCRGNA,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion B:"	MOVE.32	{A6}+OSRCRGNB,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR.ENDIF 0OPER$:.IF 0	PUSH.32	{A6}+OSRCRGNA	PUSH.32	{A6}+OSRCRGNB	PUSH.32	{A6}+ODSTRGN	CALL	SECTRGN	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion intersection:"	MOVE.32	{A6}+ODSTRGN,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR	PUSH.32	{A6}+OSRCRGNA	PUSH.32	{A6}+OSRCRGNB	PUSH.32	{A6}+ODSTRGN	CALL	UNIONRGN	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion UNION:"	MOVE.32	{A6}+ODSTRGN,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR	PUSH.32	{A6}+OSRCRGNA	PUSH.32	{A6}+OSRCRGNB	PUSH.32	{A6}+ODSTRGN	CALL	DIFFRGN	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion diffrence A-B:"	MOVE.32	{A6}+ODSTRGN,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR	PUSH.32	{A6}+OSRCRGNA	PUSH.32	{A6}+OSRCRGNB	PUSH.32	{A6}+ODSTRGN	CALL	XORRGN	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion OU-exclusif:"	MOVE.32	{A6}+ODSTRGN,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR	PUSH.32	{A6}+ODSTRGN	PUSH.16	#100	PUSH.16	#50	CALL	OFFSETRGN	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion OU-exclusif, OFFSETe de (100,50):"	MOVE.32	{A6}+ODSTRGN,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR	PUSH.32	{A6}+ODSTRGN	PUSH.16	#-10	PUSH.16	#-10	CALL	INSETRGN	LIB	?AFTIM	.ASCIZE	"<EOP>La mme rgion Insete de (-10,-10):"	MOVE.32	{A6}+ODSTRGN,A1	MOVE.16	#GMCOPY,D2	CALL	AFRGN	LIB	?GETCAR	LIB	?AFTIM	.ASCIZE	"<CR>Dtection de points (I)n (O)out: X"RETEST$:	LIB	?IFMOUSE	PUSH.16	#0	PUSH.32	D4	PUSH.32	{A6}+ODSTRGN	CALL	PTINRGN	POP.16	D7	JUMP,EQ	NOTIN$	LIB	?AFTIM	.ASCIZE	"<BS>I"	JUMP	KEY$NOTIN$:		LIB	?AFTIM	.ASCIZE	"<BS>O"KEY$:	LIB	?IFCAR	JUMP,NE	RETEST$.ENDIF	LIB	?AFTIM	.ASCIZE	"<CR><CR>Voulez-vous encore dfinir des rgions quelconques ? "	LIB	?YESNO	JUMP,NE	FINDEMO$	LIB	?AFTIM	.ASCIZE	"<CR>Dessinez une rgion B (GAUCHE: pose point, CENTRE: round-rect, DROITE: finit) "	MOVE.32	{A6}+OSRCRGNB,A4	CALL	DEFINEMOUS	LIB	?AFTIM	.ASCIZE	"<cr>La rgion B, Dfinie: (APPUIEZ SUR SPACE)"	MOVE.32	{A6}+OSRCRGNB,A1	MOVE.16	#GMOR,D2	CALL	AFRGN	LIB	?AFTIM	.ASCIZE	"La rgion B est de complexit: "	SUB.32	#8+2,SP	PUSH.32	{A6}+OSRCRGNB	PUSH.32	#{SP}+4+2	GMI_	RGNBBOX	POP.16	D4	LIB	?AFX4,?AFTIM	.ASCIZE	" et de BBox: "	MOVE.16	#4-1,D3LBBOX$:	POP.16	D4	LIB	?AFX4,?AFSPACE	DJ.16,NMO D3,LBBOX$	LIB	?AFCR,?GETCAR	LIB	?AFTIM	.ASCIZE	"<CR>La rgion B affiche avec INITSRGN,SEEKSRGN,RELSRGN:"	MOVE.32	{A6}+OSRCRGNB,A1	MOVE.16	#GMOR,D2;;?	CALL	AFRGNSEEK	LIB	?AFTIM	.8	NOCURS,EOP	.ASCII	"Coucou...<CR>"	.ASCII	"<CR>"	.ASCII	"abcdefghijklmnopqrstuvwxyz<CR>"	.ASCII	"ABCDEFGHIJKLMNOPQRSTUVWXYZ<CR>"	.ASCII	"1234567890<CR>"	.ASCII	"<CR>"	.ASCII	"Et voil !<CR>"	.8	0	.EVEN	MOVE.32	{A6}+OPTDIS,A2		; A2 <-- ^descripteur fentre	MOVE.32	{A6}+OSRCRGNB,{A2}+ODFCRG	MOVE.32	#16'10000*2+2,D3	; D3 <-- source: position	MOVE.32	#0,A3			; A3 <-- source: dans l'cran	MOVE.32	#16'10000*1+203,D4	; D4 <-- destination: position	MOVE.32	#0,A4			; A4 <-- destination: dans l'cran	MOVE.32	#16'10000*101+101,D2	; D2 <-- dimensions	MOVE.16	#LOADDOT,D1		; D1 <-- mode	GRA2_	RASTER			; moteur ...	LIB	?GETCAR	MOVE.32	#0,{A2}+ODFCRG	MOVE.32	{A6}+OSRCRGNB,A4	MOVE.32	#16'ffff0000,D3	MOVE.32	#16'0000ffff,D4	GMI_	INSETRGN	LIB	?AFTIM	.ASCIZE	"<cr>La mme rgion Insete de [(-1,0),(0,-1)]:"	MOVE.32	{A6}+OSRCRGNB,A1	MOVE.16	#GMXOR,D2	CALL	AFRGN	LIB	?GETCAR	JUMP	OPER$FINDEMO$:	MOVE.32	{A6}+OSRCRGNA,A4	GMI_	DISPOSERGN	MOVE.32	{A6}+OSRCRGNB,A4	GMI_	DISPOSERGN	MOVE.32	{A6}+ODSTRGN,A4	GMI_	DISPOSERGN	MOVE.16	{A6}+OCHANGM,D1	LIB_	CLOSE	MOVE.16	{A6}+OCHGRA,D1	LIB_	CLOSEEROR$:	.IF	EXSMILE	EXIT	.ELSE	LIB	?CLOLIB	FOS	?STOP	.ENDIFAFRGN:	MOVE.32	A1,A4	MOVE.32	{A6}+OPTDIS,A2	MOVE.32	#0,{A6}+OBITMAP+OGBMAPRECT+OGRECTTL	MOVE.16	{A2}+ODFDY,D4	SWAP.32	D4	MOVE.16	{A2}+ODFDX,D4	MOVE.32	D4,{A6}+OBITMAP+OGBMAPRECT+OGRECTBR	MOVE.16	{A2}+ODFY,D0	MUL.16	{A2}+ODFIIY,D0	CLR.32	D1	MOVE.16	{A2}+ODFX,D1	SR.32	#3,D1			; /8 bits/byte	ADD.32	D1,D0	ADD.32	{A2}+ODFABS,D0	MOVE.32	D0,{A6}+OBITMAP+OGBMAPPT	MOVE.16	#10'1024/8,{A6}+OBITMAP+OGBMAPWIDTH	MOVE.32	#{A6}+OBITMAP,A2;;EXIT	GMI_	RGNTOBITMAP;;EXIT	RET; in	A4 ^rgion...DEFINEMOUS:	MOVE.16	#GFILLXOR,D3	GMI_	OPENRGNFIRSTPT$:	LIB	?IFMOUSE	TEST.8	D3	JUMP,EQ	FIRSTPT$	TEST.32	D3:#BMOCENT	JUMP,BS	DOOVAL$	TEST.32	D3:#BMORIGHT	JUMP,BS	ENDMOU$;;;	TEST.32	D3:#BMOLEFT	PUSH.32	D4		; D3 tats boutonsONEMORE$:	MOVE.32	#0,D5	MOVE.32	D4,D6NEXTPT$:	PUSH.16	D3	LIB	?IFMOUSE	POP.16	D1	PUSHM.32 D3|D4	PUSH.32	D4	MOVE.32	D6,D3	MOVE.32	D5,D4	MOVE.16	#INVDOT,D2	LIB	?DRSEG		; enlve le prcdent	POP.32	D4	MOVE.32	D6,D3	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	MOVE.32	D4,D5	LIB	?DRSEG		; affiche le nouveau	POPM.32	D3|D4	MOVE.16	D3,D7	XOR.16	D7,D1	AND.16	D1,D7		; D7 <= boutons appuys;;	TEST.32	D7:#BMOCENT;;	JUMP,BS	FIRSTPT$	TEST.32	D7:#BMORIGHT	JUMP,BS	ENDMOU$	TEST.32	D7:#BMOLEFT	JUMP,BC	NEXTPT$	PUSH.32	D3	MOVE.32	D6,D3	GMI_	PUTLINE			; D4 ^dj	POP.32	D3	JUMP	ONEMORE$DOOVAL$:		; D3 tats boutons	MOVE.32	#0,D5	MOVE.32	D4,D6NEXTOV$:	PUSH.16	D3	LIB	?IFMOUSE	POP.16	D1	PUSHM.32 D3|D4	PUSH.32	D4	MOVE.32	D6,D3	MOVE.32	D5,D4	MOVE.16	#INVDOT,D2	LIB	?DRRECT		; enlve le prcdent	POP.32	D4	MOVE.32	D6,D3	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	MOVE.32	D4,D5	LIB	?DRRECT		; affiche le nouveau	POPM.32	D3|D4	MOVE.16	D3,D7	XOR.16	D7,D1	AND.16	D1,D7		; D7 <= boutons appuys	TEST.32	D1:#BMOCENT	JUMP,BC	NEXTOV$	TEST.32	D3:#BMORIGHT	JUMP,BS	VRAIOVALE$.if	0	PUSH.32	D4	PUSH.32	D6	PUSH.32	A7	PUSH.16	#32	PUSH.16	#16	CALL	PUTOVAL	ADD.32	#8,A7.endif	JUMP	END$VRAIOVALE$:.if	0	PUSH.32	D4	PUSH.32	D6	PUSH.32	A7		; ^rect	PUSH.16	{A7}+4+6	; right	MOVE.16	{A7}+6+2,D0	SUB.16	D0,{A7}		; -left	PUSH.16	{A7}+6+4	; bottom	MOVE.16	{A7}+8+0,D0	SUB.16	D0,{A7}		; -top	CALL	PUTOVAL	ADD.32	#8,A7.endifWAITREL$:	LIB	?IFMOUSE	TEST.8	D3	JUMP,NE	WAITREL$	JUMP	END$ENDMOU$:	LIB	?IFMOUSE	TEST.8	D3	JUMP,NE	ENDMOU$	MOVE.32	D6,D3	POP.32	D4	GMI_	PUTLINEEND$:	GMI_	CLOSERGN	RETNMGRA:	.ASCIZ	"GRA2"TXGRAMISC:	.ASCIZE	"TGRAMIS"	.END