	.SBTTL	GRALINE;LINE_INCX:	.MACRO	LINE_INCX	.LOCALMACRO END	DEC.B	D0		; x <-- x+1	JUMP',PL END	LOAD.L	D0,#7	INC.L	A0END:	.ENDMACRO;LINE_DECX:	.MACRO	LINE_DECX	.LOCALMACRO END	INC.B	D0		; x <-- x-1	COMP.B	D0,#8	JUMP',LT END	CLR.B	D0	DEC.L	A0END:	.ENDMACRO;LINE_INCY:	.MACRO	LINE_INCY	ADD.W	A0,D4		; y <-- y+1	.ENDMACRO;LINE_DECY:	.MACRO	LINE_DECY	SUB.W	A0,D4		; y <-- y-1	.ENDMACRO;----------\; _GRA_LINE >;==========/; Trace un segment de droite trs rapidement.; in	A2.L	^description de la fentre;	D4.L	origine Y;X;	D3.L	longueur dY;dX;	D1.B	mode (INVDOT, SETDOT ou CLRDOT); out	D7.W	erreur; mod	D7.W_GRA_LINE:	PUSHM.L	D0..D6,A0,A1,A3	PUSH.L	#R16"SEGFIN1	LOAD.L	(A2)+ODFVAR+OVARSP,SP	TEST.L	D3		; dX et dY nuls ?	JUMP,EQ SEGOK		; oui => ne fait rien	.IF	COLOR	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP,EQ 19$		; non => 19$	LOAD.L	D0,(A2)+ODFABS	COMP.L	D0,(A2)+ODFCAB	; est-on dans l'cran couleur ?	JUMP,NE 19$		; non => 19$	PUSHM.L	D0..D4	TEST.L	D1:#0	JUMP',BC 12$	TEST.L	D1:#1	JUMP',BC 14$				; CLRDOT =>	LOAD.L	D0,#H'10000*MVDCOR2+MVDCAND1	LOAD.L	D3,(A2)+ODFCCF	; D3 <-- couleur pour effacer	JUMP'	16$12$:				; SETDOT =>	LOAD.L	D0,#H'10000*MVDCOR2+MVDCAND1	LOAD.L	D3,(A2)+ODFCSF	; D3 <-- couleur pour dessiner	JUMP'	16$14$:				; INVDOT =>	LOAD.L	D0,#H'10000*MVDCXNOR+MVDCNOP	LOAD.L	D3,(A2)+ODFCSF	; D3 <-- couleur pour dessiner	LOAD.L	D2,(A2)+ODFCCF	; D2 <-- couleur pour effacer	XOR.L	D3,D216$:	CLR.L	D2	LOAD.W	D4,#-1	CALL	MODVDCC		; init le mode logique	POPM.L	D0..D4	AND.B	D1,#B'11111100	OR.B	D1,#CLRDOT	; D1 <-- toujours le mode CLR !19$:	.ENDIF	TEST.L	D1:#BPENDOT	; utilise le pinceau ?	JUMP,BS	SEGI		; oui => SEGI	CALL	CLIPGRA		; dans la fentre ?	JUMP',EQ 30$		; oui => 30$	COMP.B	(A2)+ODFMGR,#GRAWHOLE ; mode "tout dans l'cran" ?	JUMP,EQ	SEGFIN		; oui => ne fait rien	JUMP	SEGI		; non => essaye de faire un petit bout; Cherche l'adresse de la routine de traitement d'un point; en fonction du mode dans D1.B30$:	TEST.L	D1:#BTTTDOT	; trait selon map ?	JUMP',BS 35$		; oui => 35$	LOAD.W	D5,D3		; dX nul ?	JUMP,EQ SEGVERT		; oui => droite verticale	JUMP',NC 32$	NEG.W	D532$:	COMP.W	D5,#16	JUMP',LO 35$	LOAD.L	D5,D3	SWAP.W	D5	TEST.W	D5		; dY nul ?	JUMP,EQ SEGHOR		; oui => droite horizontale35$:	CALL	ADOT		; A3 <-- ^routine "dot"; Forme le pointeur sur la position mmoire de l'cran; contenant le point d'origine.	LOAD.W	D5,D3		; D5 <-- dx	SWAP.W	D3	LOAD.W	D6,D3		; D6 <-- dy	LOAD.W	D3,D4		; D3 <-- coordonne X relative	SWAP.W	D4		; D4 <-- coordonne Y relative	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit	NOT.B	D0		; bits inverss (7..0) !	AND.W	D0,#B'111	; D0 <-- no du bit dans le byte50$:	LOAD.W	D4,(A2)+ODFIIY	; D4 <-- Iy	CLR.W	D7		; D7 <-- ok	LOAD.W	D2,D5		; D2 <-- dx	JUMP',PL 60$	NEG.W	D2		; D2 <-- !dx!60$:	LOAD.W	D1,D6		; D1 <-- dy	JUMP',PL 62$	NEG.W	D1		; D1 <-- !dy!62$:	COMP.W	D2,D1		; COMP  !dx! , !dy!	JUMP',LO 70$	TEST.W	D5	JUMP',MI 65$	TEST.W	D6	JUMP,PL SEG1	JUMP	SEG865$:	TEST.W	D6	JUMP,PL SEG4	JUMP	SEG570$:	TEST.W	D5	JUMP',MI 75$	TEST.W	D6	JUMP,PL SEG2	JUMP	SEG775$:	TEST.W	D6	JUMP,PL SEG3	JUMP	SEG6; Trace un segment de droite dans un huitime de cadrant.;		!;		!;	   SEG6	! SEG7;		!;	 SEG5	!   SEG8;	--------!--------> X;	 SEG4	!   SEG1;		!;	   SEG3	! SEG2;		!;	       \!/ Y; in	A0.L	^byte contenant le point;	D0.B	numro du bit dans le byte (0..7);	D5.W	delta x;	D6.W	delta y;	D4.W	Iy; use	D1	compteur (c);	D2	correction des erreurs (e); mod	D0,D1,D2,A0SEG1:	LOAD.W	D2,D5	ASR.W	D2,#1	NEG.W	D2		; e <-- -dx/2	LOAD.W	D1,D5		; c <-- dx	DEC.W	D110$:	CALL	(A3)		; traitement d'un point	LINE_INCX		; x <-- x+1	ADD.W	D2,D6		; e <-- e+dy	JUMP',MI 20$	LINE_INCY		; y <-- y+1	SUB.W	D2,D5		; e <-- e-dx20$:	DECJ.W,NMO D1,10$	JUMP	SEGOKSEG2:	LOAD.W	D2,D6	ASR.W	D2,#1	NEG.W	D2		; e <-- -dy/2	LOAD.W	D1,D6		; c <-- dy	DEC.W	D110$:	CALL	(A3)		; traitement d'un point	LINE_INCY		; y <-- y+1	ADD.W	D2,D5		; e <-- e+dx	JUMP',MI 20$	LINE_INCX		; x <-- x+1	SUB.W	D2,D6		; e <-- e-dy20$:	DECJ.W,NMO D1,10$	JUMP	SEGOKSEG3:	LOAD.W	D2,D6	ASR.W	D2,#1	NEG.W	D2		; e <-- -dy/2	LOAD.W	D1,D6		; c <-- dy	DEC.W	D110$:	CALL	(A3)		; traitement d'un point	LINE_INCY		; y <-- y+1	SUB.W	D2,D5		; e <-- e-dx	JUMP',MI 20$	LINE_DECX		; y <-- x-1	SUB.W	D2,D6		; e <-- e-dy20$:	DECJ.W,NMO D1,10$	JUMP	SEGOKSEG4:	LOAD.W	D2,D5	ASR.W	D2,#1		; e <-- dx/2	LOAD.W	D1,D5		; c <-- dx10$:	CALL	(A3)		; traitement d'un point	LINE_DECX		; x <-- x-1	ADD.W	D2,D6		; e <-- e+dy	JUMP',MI 20$	LINE_INCY		; y <-- y+1	ADD.W	D2,D5		; e <-- e+dx20$:	INC.W	D1	JUMP',NE 10$	JUMP	SEGOKSEG5:	LOAD.W	D2,D5	ASR.W	D2,#1		; e <-- dx/2	LOAD.W	D1,D5		; c <-- dx10$:	CALL	(A3)		; traitement d'un point	LINE_DECX		; x <-- x-1	SUB.W	D2,D6		; e <-- e-dy	JUMP',MI 20$	LINE_DECY		; y <-- y-1	ADD.W	D2,D5		; e <-- e+dx20$:	INC.W	D1	JUMP,NE 10$	JUMP	SEGOKSEG6:	LOAD.W	D2,D6	ASR.W	D2,#1		; e <-- dy/2	LOAD.W	D1,D6		; c <-- dy10$:	CALL	(A3)		; traitement d'un point	LINE_DECY		; y <-- y-1	SUB.W	D2,D5		; e <-- e-dx	JUMP',MI 20$	LINE_DECX		; x <-- x-1	ADD.W	D2,D6		; e <-- e+dy20$:	INC.W	D1	JUMP,NE 10$	JUMP	SEGOKSEG7:	LOAD.W	D2,D6	ASR.W	D2,#1		; e <-- dy/2	LOAD.W	D1,D6		; c <-- dy10$:	CALL	(A3)		; traitement d'un point	LINE_DECY		; y <-- y-1	ADD.W	D2,D5		; e <-- e+dx	JUMP',MI 20$	LINE_INCX		; x <-- x+1	ADD.W	D2,D6		; e <-- e+dy20$:	INC.W	D1	JUMP,NE 10$	JUMP	SEGOKSEG8:	LOAD.W	D2,D5	ASR.W	D2,#1	NEG.W	D2		; e <-- -dx/2	LOAD.W	D1,D5		; c <-- dx	DEC.W	D110$:	CALL	(A3)		; traitement d'un point	LINE_INCX		; x <-- x+1	SUB.W	D2,D6		; e <-- e-dy	JUMP',MI 20$	LINE_DECY		; y <-- y-1	SUB.W	D2,D5		; e <-- e-dx20$:	DECJ.W,NMO D1,10$	JUMP	SEGOK; Algorithme x-y pour les cas dlicats; ------------------------------------SEGI:	CALL	ADOTXY		; A3 <-- ^routine "dotxy"	LOAD.W	D5,D3		; D5 <-- dx	SWAP.W	D3	LOAD.W	D6,D3		; D6 <-- dy	LOAD.W	D3,D4		; D3 <-- coordonne X relative	SWAP.W	D4		; D4 <-- coordonne Y relative	CLR.W	D7		; D7 <-- ok	LOAD.W	D2,D5		; D2 <-- dx	JUMP',PL 10$	NEG.W	D2		; D2 <-- !dx!10$:	LOAD.W	D1,D6		; D1 <-- dy	JUMP',PL 20$	NEG.W	D1		; D1 <-- !dy!20$:	COMP.W	D2,D1		; COMP  !dx! , !dy!	JUMP',LO 50$	TEST.W	D5	JUMP',MI 30$	TEST.W	D6	JUMP,PL SEGI1	JUMP	SEGI830$:	TEST.W	D6	JUMP,PL SEGI4	JUMP	SEGI550$:	TEST.W	D5	JUMP',MI 60$	TEST.W	D6	JUMP,PL SEGI2	JUMP	SEGI760$:	TEST.W	D6	JUMP,PL SEGI3	JUMP	SEGI6; in	D3.W	coordonne x;	D4.W	coordonne y;	D5.W	delta x;	D6.W	delta y; use	D1	compteur (c);	D2	correction des erreurs (e); mod	D0,D1,D2,D3,D4,A0SEGI1:	LOAD.W	D2,D5	ASR.W	D2,#1	NEG.W	D2		; e <-- -dx/2	LOAD.W	D1,D5		; c <-- dx	DEC.W	D110$:	CALL	(A3)		; traitement d'un point	INC.W	D3		; x <-- x+1	ADD.W	D2,D6		; e <-- e+dy	JUMP',MI 20$	INC.W	D4		; y <-- y+1	SUB.W	D2,D5		; e <-- e-dx20$:	DECJ.W,NMO D1,10$	JUMP	SEGOKSEGI2:	LOAD.W	D2,D6	ASR.W	D2,#1	NEG.W	D2		; e <-- -dy/2	LOAD.W	D1,D6		; c <-- dy	DEC.W	D110$:	CALL	(A3)		; traitement d'un point	INC.W	D4		; y <-- y+1	ADD.W	D2,D5		; e <-- e+dx	JUMP',MI 20$	INC.W	D3		; x <-- x+1	SUB.W	D2,D6		; e <-- e-dy20$:	DECJ.W,NMO D1,10$	JUMP	SEGOKSEGI3:	LOAD.W	D2,D6	ASR.W	D2,#1	NEG.W	D2		; e <-- -dy/2	LOAD.W	D1,D6		; c <-- dy	DEC.W	D110$:	CALL	(A3)		; traitement d'un point	INC.W	D4		; y <-- y+1	SUB.W	D2,D5		; e <-- e-dx	JUMP',MI 20$	DEC.W	D3		; x <-- x-1	SUB.W	D2,D6		; e <-- e-dy20$:	DECJ.W,NMO D1,10$	JUMP	SEGOKSEGI4:	LOAD.W	D2,D5	ASR.W	D2,#1		; e <-- dx/2	LOAD.W	D1,D5		; c <-- dx10$:	CALL	(A3)		; traitement d'un point	DEC.W	D3		; x <-- x-1	ADD.W	D2,D6		; e <-- e+dy	JUMP',MI 20$	INC.W	D4		; y <-- y+1	ADD.W	D2,D5		; e <-- e+dx20$:	INC.W	D1	JUMP',NE 10$	JUMP	SEGOKSEGI5:	LOAD.W	D2,D5	ASR.W	D2,#1		; e <-- dx/2	LOAD.W	D1,D5		; c <-- dx10$:	CALL	(A3)		; traitement d'un point	DEC.W	D3		; x <-- x-1	SUB.W	D2,D6		; e <-- e-dy	JUMP',MI 20$	DEC.W	D4		; y <-- y-1	ADD.W	D2,D5		; e <-- e+dx20$:	INC.W	D1	JUMP,NE 10$	JUMP	SEGOKSEGI6:	LOAD.W	D2,D6	ASR.W	D2,#1		; e <-- dy/2	LOAD.W	D1,D6		; c <-- dy10$:	CALL	(A3)		; traitement d'un point	DEC.W	D4		; y <-- y-1	SUB.W	D2,D5		; e <-- e-dx	JUMP',MI 20$	DEC.W	D3		; x <-- x-1	ADD.W	D2,D6		; e <-- e+dy20$:	INC.W	D1	JUMP,NE 10$	JUMP	SEGOKSEGI7:	LOAD.W	D2,D6	ASR.W	D2,#1		; e <-- dy/2	LOAD.W	D1,D6		; c <-- dy10$:	CALL	(A3)		; traitement d'un point	DEC.W	D4		; y <-- y-1	ADD.W	D2,D5		; e <-- e+dx	JUMP',MI 20$	INC.W	D3		; x <-- x+1	ADD.W	D2,D6		; e <-- e+dy20$:	INC.W	D1	JUMP,NE 10$	JUMP	SEGOKSEGI8:	LOAD.W	D2,D5	ASR.W	D2,#1	NEG.W	D2		; e <-- -dx/2	LOAD.W	D1,D5		; c <-- dx	DEC.W	D110$:	CALL	(A3)		; traitement d'un point	INC.W	D3		; x <-- x+1	SUB.W	D2,D6		; e <-- e-dy	JUMP',MI 20$	DEC.W	D4		; y <-- y-1	SUB.W	D2,D5		; e <-- e-dx20$:	DECJ.W,NMO D1,10$	JUMP	SEGOK; Algorithme rapide pour droites verticales; -----------------------------------------; in	A2.L	^description de la fentre;	D4.L	origine Y;X;	D3.L	hauteur dY,0;	D1.B	mode (INVDOT, SETDOT ou CLRDOT)SEGVERT:	SWAP.W	D3	LOAD.W	D5,D3		; D5 <-- dy	LOAD.W	D3,D4		; D3 <-- coordonne X relative	SWAP.W	D4		; D4 <-- coordonne Y relative	TEST.W	D5	JUMP',NC 10$	NEG.W	D5		; D5 <-- |dy|	SUB.W	D4,D5	INC.W	D410$:	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit	NOT.B	D0		; D0 <-- bit 7  gauche !	LOAD.W	D2,(A2)+ODFIIY	; D2 <-- Iy	TCLR.L	D1:#BNCTDOT	COMP.B	D1,#SETDOT	JUMP,EQ SEGVERTSET	COMP.B	D1,#CLRDOT	JUMP,EQ SEGVERTCLRSEGVERTINV:	DEC.W	D520$:	TNOT.B	(A0):D0		; allume un point	ADD.W	A0,D2		; A0 <-- ^byte en dessous	DECJ.W,NMO D5,20$	JUMP	SEGOKSEGVERTSET:	DEC.W	D520$:	TSET.B	(A0):D0		; allume un point	ADD.W	A0,D2		; A0 <-- ^byte en dessous	DECJ.W,NMO D5,20$	JUMP	SEGOKSEGVERTCLR:	DEC.W	D520$:	TCLR.B	(A0):D0		; allume un point	ADD.W	A0,D2		; A0 <-- ^byte en dessous	DECJ.W,NMO D5,20$	JUMP	SEGOK; Algorithme ultra-rapide pour droites horizontales; -------------------------------------------------; in	A2.L	^description de la fentre;	D4.L	origine Y;X;	D3.W	longueur dX;	D1.B	mode (INVDOT, SETDOT ou CLRDOT)SEGHOR:	LOAD.W	D5,D3		; D5 <-- dx	JUMP',NC 10$	NEG.W	D5		; D5 <-- |dx|	SUB.W	D4,D5	INC.W	D410$:	LOAD.W	D3,D4		; D3 <-- coordonne X relative	SWAP.W	D4		; D4 <-- coordonne Y relative	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit	LOAD.W	D2,A0	TEST.L	D2:#0		; est-ce que A0 est pair ?	JUMP',BC 20$		; oui => 20$	DEC.L	A0	ADD.W	D0,#8		; D0 <-- 0..1520$:	LOAD.W	D2,#-1		; D2 <-- pattern	TCLR.L	D1:#BNCTDOT	COMP.B	D1,#SETDOT	JUMP,EQ SEGHORSET	COMP.B	D1,#CLRDOT	JUMP,EQ SEGHORCLRSEGHORINV:	TEST.W	D0	JUMP,EQ 30$	LOAD.W	D3,D2	SR.W	D3,D0	XOR.W	(A0+),D3	; trace le dbut	ADD.W	D5,D0	SUB.W	D5,#16		; D5 <-- longueur restante30$:	LOAD.W	D3,D5	SR.W	D3,#4	JUMP',EQ 40$	DEC.W	D332$:	XOR.W	(A0+),D2	; trace le milieu	DECJ.W,NMO D3,32$40$:	AND.W	D5,#B'1111	JUMP',EQ 90$	SUB.W	D5,#16	NEG.W	D5	SL.W	D2,D5	XOR.W	(A0),D2		; trace la fin90$:	JUMP	SEGOKSEGHORSET:	TEST.W	D0	JUMP,EQ 30$	LOAD.W	D3,D2	SR.W	D3,D0	OR.W	(A0+),D3	; trace le dbut	ADD.W	D5,D0	SUB.W	D5,#16		; D5 <-- longueur restante30$:	LOAD.W	D3,D5	SR.W	D3,#4	JUMP',EQ 40$	DEC.W	D332$:	LOAD.W	(A0+),D2	; trace le milieu	DECJ.W,NMO D3,32$40$:	AND.W	D5,#B'1111	JUMP',EQ 90$	SUB.W	D5,#16	NEG.W	D5	SL.W	D2,D5	OR.W	(A0),D2		; trace la fin90$:	JUMP	SEGOKSEGHORCLR:	TEST.W	D0	JUMP,EQ 30$	LOAD.W	D3,D2	SR.W	D3,D0	NOT.W	D3	AND.W	(A0+),D3	; trace le dbut	ADD.W	D5,D0	SUB.W	D5,#16		; D5 <-- longueur restante30$:	LOAD.W	D3,D5	SR.W	D3,#4	JUMP',EQ 40$	DEC.W	D3	NOT.W	D232$:	LOAD.W	(A0+),D2	; trace le milieu	DECJ.W,NMO D3,32$	NOT.W	D240$:	AND.W	D5,#B'1111	JUMP',EQ 90$	SUB.W	D5,#16	NEG.W	D5	SL.W	D2,D5	NOT.W	D2	AND.W	(A0),D2		; trace la fin90$:;	JUMP	SEGOKSEGOK:	CLR.L	D7		; D7 <-- okSEGFIN:	POP.L	D0		; annule le PUSH.L R16"SEGFIN1SEGFIN1:	POPM.L	D0..D6,A0,A1,A3	RET	.END