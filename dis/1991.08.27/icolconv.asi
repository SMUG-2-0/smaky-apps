	.SBTTL	ICOLCONV.ASI;------------\\; _ICOL_CONVC >;============/; Conversion des couleurs d'une zone rectangulaire d'un bitmap couleur.; Si BICCSPEC=0, la conversion tente de faire correspondre les couleurs; du bitmap avec celles de la CLUT active (fentre).; in	D2.L	mode (BICC*);	A4.L	^bitmap couleur;	D3.L	coin sup/gauche (y;x);	D4.L	coin inf/droite (y;x);	D5.W	Iy bitmap;	D6.W	nb de bits/pixel (#4);	A0.L	^descripteur fentre;	A3.L	^CLUT du bitmap  (si D2<>BICCSPEC);	A3.L	^table du filtre (si D2:#BICCSPEC); out	D7.W	erreur; mod	D7.W_ICOL_CONVC:	PUSHM.L	D0..D6,A3,A4,A6	CALL	VAROPEN		; A6 <-- ^variables	JUMP,NE ERFAT$	LOAD.L	D0,D2		; D0 <-- mode	LOAD.W	D7,#1		; D7 <-- erreur	COMP.W	D6,#4		; 4 bits/pixel ?	JUMP,NE EXIT$		; non => EXIT$ (vraiment navr)	LOAD.W	D2,D3	SR.W	D2,#1	ADD.W	A4,D2		; A4 <-- ^dans matrice selon X origine	SUB.W	D4,D3		; D4 <-- largeur	JUMP,LE EXIT$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D6,D4	SUB.W	D6,D3		; D6 <-- hauteur	JUMP,LE EXIT$	LOAD.W	D2,D3	MUL.WU	D2,D5	ADD.L	A4,D2		; A4 <-- ^dans matrice selon Y origine	SWAP.W	D3	SWAP.W	D4	TEST.L	D0:#BICCSPEC	JUMP',BS LOOPY$	CALL	CONVCALCC	; A3 <-- ^table du filtreLOOPY$:	PUSHM.L	D4,A4	TEST.L	D3:#0		; y a-t-il un demi byte  traiter au dbut ?	JUMP',BC MIDX$		; non => MIDX$	LOAD.B	D0,(A4)	LOAD.B	D1,D0	AND.W	D1,#B'00001111	AND.B	D0,#B'11110000	OR.B	D0,(A3)+(D1.W)	; D0 <-- nouvelle couleur	LOAD.B	(A4+),D0	DEC.W	D4	JUMP,EQ NEXTY$MIDX$:	LOAD.W	D2,D4	SR.W	D2,#1		; D2 <-- largeur restante /2	JUMP',EQ ENDX$	DEC.W	D2		; D2 <-- -1  cause NMOLOOPX$:	LOAD.B	D0,(A4)	LOAD.B	D1,D0	AND.W	D1,#B'00001111	AND.B	D0,#B'11110000	OR.B	D0,(A3)+(D1.W)	; D0 <-- nouvelle couleur;	CLR.W	D1	LOAD.B	D1,D0	SR.B	D1,#4	LOAD.B	D1,(A3)+(D1.W)	; D1 <-- nouvelle couleur	SL.B	D1,#4	AND.B	D0,#B'00001111	OR.B	D0,D1	LOAD.B	(A4+),D0	DECJ.W,NMO D2,LOOPX$ENDX$:	TEST.L	D4:#0		; y a-t-il un demi byte  traiter  la fin ?	JUMP',BC NEXTY$		; non => NEXTY$	LOAD.B	D0,(A4)	CLR.W	D1	LOAD.B	D1,D0	SR.B	D1,#4	LOAD.B	D1,(A3)+(D1.W)	; D1 <-- nouvelle couleur	SL.B	D1,#4	AND.B	D0,#B'00001111	OR.B	D0,D1	LOAD.B	(A4+),D0NEXTY$:	POPM.L	D4,A4	ADD.W	A4,D5		; A4 <-- ^ligne suivante	DEC.W	D6	JUMP,NE LOOPY$	CLR.W	D7		; D7 <-- okEXIT$:	CALL	VARCLOSE	; libre les variablesERFAT$:	POPM.L	D0..D6,A3,A4,A6	TEST.W	D7		; retour EQ/NE	RET;----------\\; CONVCALCC >;----------/; Calcule la table du filtre.; in	A3.L	^CLUT; out	A3.L	^table du filtre; mod	D7.W, A3.LCONVCALCC:	PUSHM.L	D2..D4,D6,A1,A2,A4	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal pour TCOLOR	LOAD.W	D2,(A3)+OCTNB	; D2 <-- nb de couleurs	LOAD.L	A2,#(A3)+LCTHEAD ; A2 <-- ^premire couleur	LOAD.L	A1,#(A6)+OBUDIS	; A1 <-- ^buffer pour filtreLOOP$:	LOAD.L	A4,#(A2)+OCTCOL	; A4 <-- ^RGB cherch	CLR.L	D3		; D3 <-- mode	TCOL_	SRCCLUT		; D4 <-- couleur de la palette	LOAD.B	(A1+),D4	; buffer <-- une couleur	LOAD.L	A2,#(A2)+LCTDATA ; A2 <-- ^couleur suivante	DEC.W	D2	JUMP,NE LOOP$	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^table du filtre	POPM.L	D2..D4,D6,A1,A2,A4	RET;-------------\\; _ICOL_CONVNB >;=============/; Conversion d'une matrice couleur en matrice noir/blanc.; Les couleurs sont simules par des trames 8x8 dont l'intensit; varie en fonction de l'intensit de la couleur (i=R+G+B).; in	D2.L	mode (BICC*);	A4.L	^image couleur;	D4.L	dimensions (dy;dx);	D5.W	Iy bitmap;	A5.L	^buffer pour image noir/blanc;	D6.W	nb de bits/pixel (#4);	A0.L	^descripteur fentre;	A2.L	^table du filtre (si D2:#BICCSPEC);	A3.L	^trames 8x8      (si D2:#BICCSPEC); out	D7.W	erreur; mod	D7.W_ICOL_CONVNB:	PUSHM.L	D0..D5,A2..A6	CALL	VAROPEN		; A6 <-- ^variables	JUMP,NE ERFAT$	LOAD.W	D7,#1		; D7 <-- erreur	COMP.W	D6,#4		; 4 bits/pixel ?	JUMP,NE EXIT$		; non => EXIT$ (vraiment navr)	TEST.L	D2:#BICCSPEC	JUMP',BS SPEC$	CALL	CONVCALCNB	; A2 <-- ^table du filtre	LOAD.L	A3,#R16"TRAMES$	; A3 <-- ^tramesSPEC$:	CLR.W	D2		; D2 <-- Y initialLOOPY$:	PUSHM.L	D4,A4	CLR.W	D3		; D3 <-- X initialLOOPX$:	LOAD.B	D0,(A4+)	DEC.W	D3		; D3 <-- X suivant	TCLR.B	(A5):D3	CLR.W	D1	LOAD.B	D1,D0	SR.W	D1,#4	LOAD.B	D1,(A2)+(D1.W)	; D1 <-- intensit (0..15)	SL.W	D1,#3		; D1 <-- *8	ADD.W	D1,D2		; D1 <-- ajoute Y	TEST.B	(A3)+(D1.W):D3	JUMP',BC WHITE0$	TSET.B	(A5):D3WHITE0$:	DEC.W	D3		; D3 <-- X suivant	TCLR.B	(A5):D3	LOAD.B	D1,D0	AND.W	D1,#B'00001111	LOAD.B	D1,(A2)+(D1.W)	; D1 <-- intensit (0..15)	SL.W	D1,#3		; D1 <-- *8	ADD.W	D1,D2		; D1 <-- ajoute Y	TEST.B	(A3)+(D1.W):D3	JUMP',BC WHITE1$	TSET.B	(A5):D3WHITE1$:	AND.W	D3,#B'111	JUMP',NE SKIP$	INC.L	A5		; A5 <-- ^byte suivantSKIP$:	SUB.W	D4,#2	JUMP,NE LOOPX$	POPM.L	D4,A4	ADD.W	A4,D5		; A4 <-- ^ligne suivante	INC.W	D2		; D2 <-- Y suivant	AND.W	D2,#B'111	; D2 <-- 0..7	SWAP.W	D4	DEC.W	D4	LOAD.W	D0,D4	SWAP.W	D4	TEST.W	D0	JUMP,NE LOOPY$	CLR.W	D7		; D7 <-- okEXIT$:	CALL	VARCLOSE	; libre les variablesERFAT$:	POPM.L	D0..D5,A2..A6	TEST.W	D7		; retour EQ/NE	RETTRAMES$:			; 0	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000				; 1	.B	B'10000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'10000000	.B	B'00000000	.B	B'00001000	.B	B'00000000				; 2	.B	B'10001000	.B	B'00000000	.B	B'00100010	.B	B'00000000	.B	B'10001000	.B	B'00000000	.B	B'00100010	.B	B'00000000				; 3	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010				; 4	.B	B'11001100	.B	B'00110011	.B	B'11001100	.B	B'00110011	.B	B'11001100	.B	B'00110011	.B	B'11001100	.B	B'00110011				; 5	.B	B'11011101	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101	.B	B'01110111				; 6	.B	B'11111111	.B	B'01110111	.B	B'11111111	.B	B'11011101	.B	B'11111111	.B	B'01110111	.B	B'11111111	.B	B'11011101				; 7	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.EVEN;-----------\\; CONVCALCNB >;-----------/; Calcule la table du filtre.; in	-; out	A2.L	^filtre; mod	D7.W, A2.LCONVCALCNB:	PUSHM.L	D2..D4,D6,A3,A4	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal pour TCOLOR	LOAD.L	A2,#(A6)+OBUDIS	CLR.L	D2LOOP$:	LOAD.L	D4,D2	LOAD.L	A3,#(A6)+OCOLR	LOAD.L	D3,#2^BTCFORCE!2^BTCGIVE	TCOL_	SRCCLUT		; OCOLR <-- couleur	CLR.L	D4	LOAD.W	D4,(A3+)	; D4 <-- rouge	CLR.L	D3	LOAD.W	D3,(A3+)	; D3 <-- vert	ADD.L	D4,D3	CLR.L	D3	LOAD.W	D3,(A3+)	; D3 <-- bleu	ADD.L	D4,D3	DIV.WU	D4,#((2^16)*3)/8	COMP.B	D4,#8	JUMP',LO PUT$	LOAD.B	D4,#8-1PUT$:	SUB.B	D4,#8-1	NEG.B	D4	LOAD.B	(A2+),D4	; buffer <-- une couleur	INC.W	D2	COMP.W	D2,#NBCOUL	JUMP,LO LOOP$	LOAD.L	A2,#(A6)+OBUDIS	POPM.L	D2..D4,D6,A3,A4	RET	.END