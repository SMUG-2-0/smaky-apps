	.TITLE	ICOLOR.ASL;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du module SMA_ICOLOR.LIB;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 0.9	16.08.91	CLUT: ascenseurs ok si prend; 0.8	08.05.91	BICKHELP: affiche le raccourci clavier; 0.7	07.05.91	type "COLO" -> "RGB" pour le bloc-notes;			colle: accepte le type "TEXT";			CLUT: empche de modifier blanc/noir !; 0.6	21.02.91	sauvetage .CRET corrig; 0.5	15.02.91	copier/coller dans ICOL_MODRGB;			double-clic dans ICOL_MODRGB (pour sortir); 0.3	01.02.91	copier/coller avec le classeur; 0.2	27.11.90	modes BICMTEXT et BICMEDIT pour ICOL_MODRGB; 0.1	16.11.90	dbut des travaux ...	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal	.REF	SMAKY	.REF	MODULES	.REF	BLOC	.REF	ICOLOR	.REF	TCOLOR	.REF	COLORS;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;SMAKY300 = 7DBOX_KHELP = 13;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;MAJREV	=	0MINREV	=	9	.REV	MAJREV,MINREV	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Assemblage conditionnel; -----------------------COUL256	=	0		; 0 = 16 couleurs et 1 = 256 couleurs (PROVISOIRE); Constantes; ----------PCCODE	=	1PCVAR	=	2BNTRGB	=	H'1000000*'R+H'10000*'G+H'100*'B+H'1*SPACE	.IF	COUL256NBCOUL	=	256	.ELSENBCOUL	=	16	.ENDIFLBUDIS	=	100		; lg max de OBUDISDEGNBX	=	9		; dgrad: nb horizontalementDEGNBY	=	NBCOUL-1	; dgrad: nb verticalementLBUNAME	=	50		; lg max d'un nom de fichierKEYDBOX	=	H'7E00		; "touche" spciale; Description des variables; -------------------------	.PC	PCVAR	.LOC	0OCCMO:	.BLKB	1		; 1 => souris enleve	.EVENOBUDIS:	.BLKB	LBUDIS		; buffer write displayOPALPY:	.BLKB	2		; palette: position en YOPALPX:	.BLKB	2		; palette: position en XOCURPY:	.BLKB	2		; curseur: position en YOCURPX:	.BLKB	2		; curseur: position en XOCOLR:	.BLKB	2		; couleur rougeOCOLG:	.BLKB	2		; couleur vertOCOLB:	.BLKB	2		; couleur bleuOFAN:	.BLKB	4		; fanionsOSCVAR:	.BLKB	LSCVAR*3	; variables trois ascenseursOSLVAR:	.BLKB	LSLVAR		; variables scroll-listeOIDCRET:.BLKB	4		; id. CRET temporaireOPTTEXT:.BLKB	4		; ^table des textesOPTNAME:.BLKB	4		; ^nom du logicielOBUCLUT:.BLKB	LBUNAME		; nom fichier .CLUTOBUCRET:.BLKB	LBUNAME		; nom fichier .CRETLGVAR:; En-tte du module LIB; ---------------------	.PC	PCCODE	.LOC	0DEBUT:	ICOL_	FIRST		; code du premier appel	ICOL_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	MAJREV,MINREV	; rvision.version	.W	0,END_ICOLOR	; longueur	.L	PATHLIB		; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"ICOLOR"	; nom du module	.FILLB	(LGHLIB-.),0	.W	_ICOL_INIT	.W	_ICOL_MODRGB	.W	_ICOL_MODCRET	.W	_ICOL_MODCLUT	.W	_ICOL_RGBHSV	.W	_ICOL_HSVRGB	.W	_ICOL_CONVC	.W	_ICOL_CONVNB; Codes des appels; ----------------;-----------\\; _ICOL_INIT >;===========/; Initialise CLUT/CRET pour un logiciel donn.; Effectue la lecture du fichier suivant :;	si BICCRET	nom.CRET  -->	CLUT+CRET;	si BICCLUT	nom.CLUT  -->	CLUT; Ne pas mettre BICCRET et BICCLUT (l'un ou l'autre) !; in	A0.L	^descripteur fentre;	A3.L	^nom du logiciel (DESSIN4, PAGE, etc.);	D3.L	mode (BIC*);		 BICCRET --> charge le fichier .CRET;		 BICCLUT --> charge le fichier .CLUT;		 BTCGLOB --> CLUT/CRET globale;	A5.L	^table des textes pour la CRET (*); out	D5.L	identificateur CRET (zro si rien)	(si D3:#BICCRET);	D7.W	erreur; mod	D5.L, D7.W_ICOL_INIT:	PUSHM.L	D2..D4,D6,A2..A4,A6	CALL	VAROPEN		; A6 <-- ^variables	JUMP,NE ERFAT$	LOAD.L	(A6)+OPTTEXT,A5	; OPTTEXT <-- ^table des textes	CLR.L	(A6)+OIDCRET	; OINIIC <-- pas d'id.	LOAD.L	D2,D3		; D2 <-- mode	CALL	IONAMECRET	; A3 <-- ^nom .CRET	TEST.L	D2:#BICCRET	; charge le fichier .CRET ?	JUMP',BC CLUT$	LOAD.L	A3,#(A6)+OBUCRET ; A3 <-- ^nom construit	LOAD.L	D3,D2	TSET.L	D3:#BTCNAME	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	LOADCRET	; D5 <-- id. de la CRET lue	JUMP',EQ CLADD$	LOAD.L	A3,#R16"TCRET$	LOAD.L	D3,D2	TSET.L	D3:#BTCTABLE	TCOL_	LOADCRET	; D5 <-- id. de la CRET vide	JUMP',NE EXIT$CLADD$:	LOAD.L	D3,D2	TCOL_	ADDCRET		; rend la CRET lue active	LOAD.L	(A6)+OIDCRET,D5	; OIDCRET <-- identificateur CRET	CALL	CRINIT		; initialise la CRET	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$CLUT$:	CLR.W	D7		; D7 <-- ok	TEST.L	D2:#BICCLUT	; charge le fichier .CLUT ?	JUMP',BC EXIT$	LOAD.L	A3,#(A6)+OBUCRET ; A3 <-- ^nom construit .CRET	LOAD.L	A4,#R16"EXT$	LOAD.W	D3,#1	LIB	?ADDEXT		; met l'extension .CLUT	LOAD.L	D3,D2	TSET.L	D3:#BTCNAME	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	TCOL_	LOADCLUT	; lit la CLUT activeEXIT$:	LOAD.L	D5,(A6)+OIDCRET	; D5 <-- identificateur CRET	CALL	VARCLOSE	; libre les variablesERFAT$:	POPM.L	D2..D4,D6,A2..A4,A6	TEST.W	D7		; retour EQ/NE	RETTCRET$:	.B	CRTYPE,0	; type	.L	0*10		; longueur	.W	0		; nb de couleurs	.FILLB	24,0		; reste de l'en-tteEXT$:	.ASCIZ	".CLUT"	.EVEN	.INS	ICOLCRET.ASI	.INS	ICOLRGB.ASI	.INS	ICOLCLUT.ASI	.INS	ICOLDBOX.ASI	.INS	ICOLCHOIX.ASI	.INS	ICOLICONE.ASI	.INS	ICOLIO.ASI	.INS	ICOLHSV.ASI	.INS	ICOLCONV.ASI	.INS	ICOLMISC.ASIEND_ICOLOR:	.END