	.SBTTL	DISHEADTTY	.LOC	0START:	.W	0	D0BASE	.W	1	D1BASE	.W	2	D2BASE	.W	3	D3BASE	.W	4	D4BASE	.W	7	D7BASE	.W	8	D8BASE	.W	9	D9BASE	.W	2^7; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_0	(bitmap principal); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=D0ID:	.W	-1			; DOOPEN-D0BASE	.W	DOCOMMAND-D0BASE	.W	DORSTATUS-D0BASE	.W	DOREAD-D0BASE	.W	DOWRITE-D0BASE	.W	-1			; DOCLOSE-D0BASE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	-1			; AVORTTR	.W	-1			; DOAUX1-D0BASE	.W	-1			; DOAUX2-D0BASE	.W	D0RESET-D0BASE	.W	DOKILL-D0BASE	.W	-1			; DOSTRT-D0BASE	.W	-1			; DOTSTRT-D0BASE	.W	-1			; DOSTART-D0BASED0NAB:	.ASCII	/DIS_0/			; Nom driverD0NAF:	.FILLB	LGDNAM-(D0NAF-D0NAB) 0	.B	NOBASE+0		; Numro driver	.B	TYPDIS			; Type: Bit-map complet	.B	0,0			; Rvision - version	.W	0			; Variante	.B	0			; Attribut 1	.B	2^BDRDOK!2^BDWROK	; Attribut 0	.FILLB	LGDDESC-(.-D0ID) 0	; Le reste.D0BASE:	.W	0,0				; ODFY,X	.W	16*24,8*80			; ODFDY,X	.B	'1,'L				; ODFCAD	.B	0				; ODFNOW	.B	2^BFEFLI			; ODFMOD	.B	SETDOT				; ODFMCA	.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_1; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=D1ID:	.W	-1			; DOOPEN-D1BASE	.W	DOCOMMAND-D1BASE	.W	DORSTATUS-D1BASE	.W	DOREAD-D1BASE	.W	DOWRITE-D1BASE	.W	-1			; DOCLOSE-D1BASE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	-1			; AVORTTR	.W	-1			; DOAUX1-D1BASE	.W	-1			; DOAUX2-D1BASE	.W	DORESET-D1BASE	.W	DOKILL-D1BASE	.W	-1			; DOSTRT-D1BASE	.W	-1			; DOTSTRT-D1BASE	.W	-1			; DOSTART-D1BASED1NAB:	.ASCII	/DIS_1/			; Nom driverD1NAF:	.FILLB	LGDNAM-(D1NAF-D1NAB) 0	.B	NOBASE+1		; Numro driver	.B	TYPWDO			; Type: Fentre	.B	0,0			; Rvision - version	.W	0			; Variante	.B	0			; Attribut 1	.B	2^BDRDOK!2^BDWROK	; Attribut 0	.FILLB	LGDDESC-(.-D1ID) 0	; Le reste.D1BASE:	.W	0,0				; ODFY,X	.W	16*24,8*80			; ODFDY,X	.B	'1,'L				; ODFCAD	.B	1				; ODFNOW	.B