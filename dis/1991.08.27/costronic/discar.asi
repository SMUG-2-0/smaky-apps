	.SBTTL	DISCAR;--------\; AFCAR   >;========/; Affiche un caractre dans une fentre.; in	D3.B	caractre  afficher;	A0.L	^variables globales;	A2.L	^description de la fentre;	A4.L	^paramtres;	D4.L	nb de paramtres; out	A4.L	^plus loin;	D4.L	nb de paramtres restants;	D7.W	erreur; mod	D0..A1, D3.W, D4.L, D7.W, A4.LAFCAR:	CLR.W	D7		; D7 <-- ok	AND.W	D3,#H'FF	; D3.W <-- caractre	CLR.L	D0	LOAD.W	D0,(A2)+ODFADR	; D0 <-- adresse rel. routine	JUMP',EQ 10$		; zro => 10$	ADD.L	D0,(A0)+OSTART	; D0 <-- adresse absolue	LOAD.L	A1,D0	JUMP	(A1)10$:	COMP.B	D3,#H'80	; commande ?	JUMP',LO 50$		; non => 50$				; oui =>	LOAD.L	A1,#R16"TACOMM	JUMP	EXROUTT		; excute une commande50$:	TEST.B	(A2)+ODFFLG:#BFTOUT ; affiche tout ?	JUMP',NE 70$		; oui => 70$				; non =>	COMP.B	D3,#NUL		; caractre NUL ?	JUMP',EQ 90$		; oui => ne fait rien				; non =>	COMP.B	D3,#'		; caractre spcial ?	JUMP',HS 70$		; non => 70$				; oui =>	LOAD.L	A1,#R16"TASPEC	JUMP	EXROUT		; excute un car spcial70$:	JUMP	AFCODE		; affiche un code90$:	RET;--------\; EXROUTT >;--------/; in	A1.L	^table de .WBB;	D3.B	caractre;	A2.L	^description de la fentre;	A4.L	^paramtres;	D4.L	nb de paramtres; out	A4.L	^plus loin;	D4.L	nb de paramtres restants;	D7.W	erreur; mod	D4.L, D7.W, A4.LEXROUTT:	PUSHM.L	D0..D3,A1	AND.W	D3,#H'7F	; D3 <-- 0..n	SL.W	D3,#2		; D3 <-- *4 car .WBB	ADD.W	A1,D3		; A1 <-- ^.WBB concern	.IF	~TTY	TEST.B	(A1)+3		; modifiera le contenu de la fentre ?	JUMP',NE 20$		; non => 20$	CALL	CLRLUTIN	; oui => enlve le lutin de la souris20$:	.ENDIF	CLR.W	D7		; D7 <-- ok	CLR.L	D1	LOAD.W	D1,(A1)+0	; D1 <-- adresse relative	JUMP',EQ 80$		; si commande inconnue => 80$	CLR.L	D0	LOAD.B	D0,(A1)+2	; D0 <-- nb paramtres attendus	JUMP',EQ 70$		; si aucun => 70$	COMP.L	D0,D4		; tous les paramtres dj l ?	JUMP',HI 60$		; non => 60$				; oui =>	LOAD.L	A1,#(A2)+ODFCOM	; A1 <-- ^buffer pour les paramtres	SUB.L	D4,D0		; D4 <-- signal paramtres dj pris	DEC.W	D0		; D0 <-- -1  cause du test NMO !40$:	LOAD.B	(A1+),(A4+)	; buffer <-- paramtres	DECJ.W,NMO D0,40$	JUMP'	70$60$:	CALL	WAITCOM		; attend le(s) paramtre(s)	JUMP'	90$70$:	LOAD.L	A1,D1		; A1 <-- adresse relative	ADD.L	A1,(A0)+OSTART	; A1 <-- adresse absolue	CALL	(A1)		; excute une routine spciale	JUMP'	90$80$:	LOAD.W	D7,#ERDIIL	; D7 <-- "illegal command"90$:	POPM.L	D0..D3,A1	RET;--------\; WAITCOM >;--------/; Attend une commande pouvant contenir un nombre quelconque; de bytes (maximum = MAXCOM).; in	D0.W	longueur de la commande;	D1.W	adresse relative routine  excuter lorsque;		la commande est termine; out	-; mod	-WAITCOM:	CLR.W	(A2)+ODFCPT	; rz ^relatif dans commande	LOAD.W	(A2)+ODFCCT,D0	; init compteur	LOAD.W	(A2)+ODFNXT,D1	; init routine lorsque fini	LOAD.W	(A2)+ODFADR,#10$	RET10$:	LOAD.W	D0,(A2)+ODFCPT	PUSH.L	A2	LOAD.L	A2,#(A2)+ODFCOM	LOAD.B	(A2)+(D0.W),D3	; mmorise le byte reu	POP.L	A2	INC.W	(A2)+ODFCPT	; incrmente le pointeur	DEC.W	(A2)+ODFCCT	; dcrmente le compteur	JUMP',EQ 20$	RET20$:	LOAD.W	(A2)+ODFADR,(A2)+ODFNXT	JUMP	AFCAR		; effectue JUMP (A2),ODFADR;--------\; EXROUT  >;--------/; in	A1.L	^table de  .W car adr;	D3.B	caractre;	A2.L	^description de la fentre; out	D7.W	erreur; mod	D7.WEXROUT:	PUSHM.L	D0,D1,D2,D3,D4,A0,A1	AND.W	D3,#H'FF	LOAD.W	D7,#ERDIIL	; D7 <-- "illegal command"10$:	ADD.L	A1,#4		; A1 <-- ^suivant dans table	TEST.W	(A1)-4		; fin de la table ?	JUMP',EQ 80$		; oui => 80$ (CC)	COMP.B	D3,(A1)-4	; caractre trouv ?	JUMP,NE 10$		; non => 10$				; oui =>	.IF	~TTY	TEST.B	(A1)-3		; modifiera le contenu de la fentre ?	JUMP',NE 50$		; non => 50$	CALL	CLRLUTIN	; oui => enlve le lutin de la souris50$:	.ENDIF	CLR.W	D7		; D7 <-- ok	CLR.L	D1	LOAD.W	D1,(A1)-2	LOAD.L	A1,D1		; A1 <-- adresse relative	ADD.L	A1,(A0)+OSTART	; A1 <-- adresse absolue	CALL	(A1)		; excute une routine spciale80$:	POPM.L	D0,D1,D2,D3,D4,A0,A1	RETTACOMM:	.W	DOCXY	.B		2,1	; H'80 = CARXY	.W	DOGXY	.B		4,1	; H'81 = GRAXY	.W	DOMSPA	.B		1,1	; H'82 = MSPACE	.W	0	.B		0,0	; H'83	.W	DOLEFT	.B		0,1	; H'84 = LEFT	.W	DORIGHT	.B		0,1	; H'85 = RIGHT	.W	DOUP	.B		0,1	; H'86 = UP	.W	DODOWN	.B		0,1	; H'87 = DOWN	.W	DOROLLU	.B		2,0	; H'88 = ROLLUP	.W	DOROLLD	.B		2,0	; H'89 = ROLLDOWN	.W	DOEFLI	.B		0,1	; H'8A = EFLI	.W	DOTRAM	.B		8,1	; H'8B = TRAME	.W	DOEFEOS	.B		0,0	; H'8C = EFEOS	.W	DOPEN	.B		8,1	; H'8D = PEN	.W	DOMAPT	.B		2,1	; H'8E = MAPTT	.W	0	.B		0,0	; H'8F	.W	DOADIR	.B		0,1	; H'90 = AFDIR	.W	DOAINV	.B		0,1	; H'91 = AFINV	.W	DONORM	.B		0,1	; H'92 = AFNORM	.W	DOTOUT	.B		0,1	; H'93 = AFTOUT	.W	DOROLL	.B		0,1	; H'94 = ROLL	.W	DONORO	.B		0,1	; H'95 = NOROLL	.W	DOTRUN	.B		0,1	; H'96 = TRUNC	.W	DOAUCR	.B		0,1	; H'97 = AUTOCR	.W	DOAUEF	.B		0,1	; H'98 = AUTOEFLI	.W	DONOEF	.B		0,1	; H'99 = NOEFLI	.W	DOGCUR	.B		0,1	; H'9A = GCURS	.W	DOPCUR	.B		0,1	; H'9B = PCURS	.W	DOCURS	.B		0,1	; H'9C = CURS	.W	DONOCU	.B		0,1	; H'9D = NOCURS	.W	DOPROC	.B		1,1	; H'9E = PROCURS	.W	0	.B		0,0	; H'9F	.W	DOUSGC	.B		3,1	; H'A0 = USEGC	.W	DOLOGC	.B		3,1	; H'A1 = LOADGC	.W	DOKIGC	.B		3,1	; H'A2 = KILLGC	.W	DOPFGC	.B		4,1	; H'A3 = PFIXGC	.W	DOCVAR	.B		0,1	; H'A4 = AFCVAR	.W	DOCFIX	.B		0,1	; H'A5 = AFCFIX	.W	DOSROL	.B		0,1	; H'A6 = SROLL	.W	DOMCAR	.B		1,1	; H'A7 = MODCAR	.W	DOCCMO	.B		0,0	; H'A8 = AFCCMO	.W	DOSCMO	.B		0,0	; H'A9 = AFSCMO	.W	DOIMAE	.B		0,1	; H'AA = IMAENA	.W	DOIMAD	.B		0,1	; H'AB = IMADIS	.W	DODIMW	.B		8,1	; H'AC = DIMWDO	.W	DOSAVW	.B		0,0	; H'AD = SAVWDO	.W	DOGETW	.B		0,0	; H'AE = GETWDO	.W	DOMGRA	.B		1,1	; H'AF = MODGRA	.W	DOTYAX	.B		2,1	; H'B0 = TYPOAX	.W	DOTYAY	.B		2,1	; H'B1 = TYPOAY	.W	DOTYRX	.B		1,1	; H'B2 = TYPORX	.W	DOTYRY	.B		1,1	; H'B3 = TYPORY	.W	DOHSPA	.B		1,1	; H'B4 = HSPACE	.W	DOVSPA	.B		1,1	; H'B5 = VSPACE	.W	DOFULL	.B		0,1	; H'B6 = AFFULL	.W	DOGREY	.B		0,1	; H'B7 = AFGREY	.W	DOCOSA	.B		6,1	; H'B8 = COLORSA	.W	DOCOCA	.B		6,1	; H'B9 = COLORCA	.W	DOCOSR	.B		4,1	; H'BA = COLORSR	.W	DOCOCR	.B		4,1	; H'BB = COLORCR	.W	DOCOLK	.B		10,1	; H'BC = COLORLINK	.W	DOCOUK	.B		4,1	; H'BD = COLORUNLINK	.W	DOCOOP	.B		1,1	; H'BE = COLOROP	.W	DOCOFA	.B		10,1	; H'BF = COLORFALSE	.W	DODRDO	.B		5,1	; H'C0 = DRAWDOT	.W	DODRLI	.B		5,1	; H'C1 = DRAWLINE	.W	DODRSE	.B		9,1	; H'C2 = DRAWSEG	.W	DODRCE	.B		3,1	; H'C3 = DRAWCERCLE	.W	DODRTR	.B		9,1	; H'C4 = DRAWTRAME	.W	DODRMX	.B		9,1	; H'C5 = DRAWMATRIX	.W	DODRAR	.B		9,1	; H'C6 = DRAWARC	.W	DODRFO	.B		4,0	; H'C7 = DRAWFILLO	.W	DODRFC	.B		0,0	; H'C8 = DRAWFILLC	.W	DODRRA	.B		25,1	; H'C9 = DRAWRASTER	.W	DODRMO	.B		13,1	; H'CA = DRAWMOUSE	.W	DODROS	.B		17,0	; H'CB = DRAWOSPRITE	.W	DODRMS	.B		5,1	; H'CC = DRAWMSPRITE	.W	DODRES	.B		1,0	; H'CD = DRAWESPRITE	.W	DODRCS	.B		1,0	; H'CE = DRAWCSPRITE	.W	DODREL	.B		11,1	; H'CF = DRAWELLIPSE	.W	DOASGC	.B		6,1	; H'D0 = ASSGC	.W	DOMEGC	.B		0,1	; H'D1 = MEMGC	.W	DODRPM	.B		8,1	; H'D2 = DRAWPMOUSE	.W	DONEGC	.B		7,1	; H'D3 = NEWGC	.W	DOMODU	.B		1,1	; H'D4 = MMODULO	.W	0	.B		0,0	; H'D5	.W	0	.B		0,0	; H'D6	.W	0	.B		0,0	; H'D7	.W	0	.B		0,0	; H'D8	.W	0	.B		0,0	; H'D9	.W	0	.B		0,0	; H'DA	.W	0	.B		0,0	; H'DB	.W	0	.B		0,0	; H'DC	.W	0	.B		0,0	; H'DD	.W	0	.B		0,0	; H'DE	.W	0	.B		0,0	; H'DF	.W	DOROLLL	.B		2,0	; H'E0 = ROLLLEFT	.W	DOROLLR	.B		2,0	; H'E1 = ROLLRIGHT	.W	DOFILT	.B		0,1	; H'E2 = AFFILLT	.W	DOFILA	.B		0,1	; H'E3 = AFFILLA	.W	0	.B		0,0	; H'E4	.W	0	.B		0,0	; H'E5	.W	0	.B		0,0	; H'E6	.W	0	.B		0,0	; H'E7	.W	0	.B		0,0	; H'E8	.W	0	.B		0,0	; H'E9	.W	0	.B		0,0	; H'EA	.W	0	.B		0,0	; H'EB	.W	0	.B		0,0	; H'EC	.W	0	.B		0,0	; H'ED	.W	0	.B		0,0	; H'EE	.W	0	.B		0,0	; H'EF	.W	0	.B		0,0	; H'F0	.W	0	.B		0,0	; H'F1	.W	0	.B		0,0	; H'F2	.W	0	.B		0,0	; H'F3	.W	0	.B		0,0	; H'F4	.W	0	.B		0,0	; H'F5	.W	0	.B		0,0	; H'F6	.W	0	.B		0,0	; H'F7	.W	0	.B		0,0	; H'F8	.W	0	.B		0,0	; H'F9	.W	0	.B		0,0	; H'FA	.W	0	.B		0,0	; H'FB	.W	0	.B		0,0	; H'FC	.W	0	.B		0,0	; H'FD	.W	0	.B		0,0	; H'FE	.W	0	.B		0,0	; H'FFTASPEC:	.B	CR,1	.W		DOCR	.B	TAB,1	.W		DOTAB	.B	BELL,1	.W		DOBELL	.B	BS,0	.W		DOBS	.B	LF,1	.W		DODOWN	.B	EOP,0	.W		DOEOP	.W	0; ---	CARXY   ---;	CARXY x y;	---------;	x,y:	nouvelle coordonne  atteindre (en caractres)DOCXY:	CLR.W	(A2)+ODFADR	; suite de bytes termines	CLR.W	D0	LOAD.B	D0,(A2)+ODFCOM+0 ; D0 <-- premier paramtre	MUL.WU	D0,(A2)+ODFCX	; * largeur d'un caractre	ADD.W	D0,(A2)+ODFC1X	CALL	DOTYIX		; init coordonne X	CLR.W	D0	LOAD.B	D0,(A2)+ODFCOM+1 ; D0 <-- deuxime paramtre	MUL.WU	D0,(A2)+ODFCY	; * hauteur d'un caractre	ADD.W	D0,(A2)+ODFC1Y	JUMP	DOTYIY		; init coordonne Y; ---	TYPOAX   ---;	TYPOAX xx;	---------;	xx:	coordonne absolue  atteindre (en points)DOTYAX:	CLR.W	(A2)+ODFADR	; suite de bytes termines	LOAD.W	D0,(A2)+ODFCOM+0 ; D0 <-- coordonne X absolueDOTYIX:	LOAD.W	D1,(A2)+ODFFDX	SUB.W	D1,(A2)+ODFC2X	; D1 <-- coordonne max	COMP.W	D0,D1		; trop  droite ?	JUMP',LS 20$		; non => 20$				; oui =>	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	LOAD.W	D0,D1		; D0 <-- coordonne X max	JUMP'	40$20$:	COMP.W	D0,(A2)+ODFC1X	; trop  gauche ?	JUMP',HS 40$		; non => 40$				; oui =>	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	LOAD.W	D0,(A2)+ODFC1X	; D0 <-- coordonne X min40$:	LOAD.W	(A2)+ODFPX,D0	; init nouvelle position en X	.IF	TTY	CALL	POSTTY	.ENDIF	RET; ---	TYPOAY   ---;	TYPOAY yy;	---------;	yy:	coordonne absolue  atteindre (en points)DOTYAY:	CLR.W	(A2)+ODFADR	; suite de bytes termines	LOAD.W	D0,(A2)+ODFCOM+0 ; D0 <-- coordonne Y absolueDOTYIY:	LOAD.W	D1,(A2)+ODFFDY	SUB.W	D1,(A2)+ODFC2Y	; D1 <-- coordonne max	COMP.W	D0,D1		; trop bas ?	JUMP',LS 20$		; non => 20$				; oui =>	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	LOAD.W	D0,D1		; D0 <-- coordonne Y max	JUMP'	40$20$:	COMP.W	D0,(A2)+ODFC1Y	; trop haut ?	JUMP',HS 40$		; non => 40$				; oui =>	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	LOAD.W	D0,(A2)+ODFC1Y	; D0 <-- coordonne Y min40$:	LOAD.W	(A2)+ODFPY,D0	; init nouvelle position en Y	.IF	TTY	CALL	POSTTY	.ENDIF	RET; ---	TYPORX   ---;	TYPORX x;	--------;	x:	coordonne relative positive ou ngativeDOTYRX:	CLR.W	(A2)+ODFADR	; suite de bytes termines	CLR.W	D1	LOAD.B	D1,(A2)+ODFCOM+0 ; D1 <-- coordonne X relative	JUMP',NC 15$		; valeur ngative ?	OR.W	D1,#H'FF00	; oui => tend le signe15$:	LOAD.W	D0,(A2)+ODFPX	ADD.W	D0,D1		; augmente/diminue coord. X	JUMP	DOTYIX		; init nouvelle coordonne; ---	TYPORY   ---;	TYPORY y;	--------;	y:	coordonne relative positive ou ngativeDOTYRY:	CLR.W	(A2)+ODFADR	; suite de bytes termines	CLR.W	D1	LOAD.B	D1,(A2)+ODFCOM+0 ; D1 <-- coordonne Y relative	JUMP',NC 15$		; valeur ngative ?	OR.W	D1,#H'FF00	; oui => tend le signe15$:	LOAD.W	D0,(A2)+ODFPY	ADD.W	D0,D1		; augmente/diminue coord. Y	JUMP	DOTYIY		; init nouvelle coordonne; ---	HSPACE   ---;	HSPACE x;	--------;	x:	modification de l'espace intercaractres;		positivement ou ngativementDOHSPA:	CLR.W	(A2)+ODFADR	; suite de bytes termines	CLR.W	D0	LOAD.B	D0,(A2)+ODFCOM+0 ; D0 <-- espacement H relatif	JUMP',NC 15$		; valeur ngative ?	OR.W	D0,#H'FF00	; oui => tend le signe15$:	LOAD.W	(A2)+ODFCIX,D0	; augmente/diminue espace H	RET; ---	VSPACE   ---;	VSPACE y;	--------;	y:	modification de l'espace interlignes;		positivement ou ngativementDOVSPA:	CLR.W	(A2)+ODFADR	; suite de bytes termines	CLR.W	D0	LOAD.B	D0,(A2)+ODFCOM+0 ; D0 <-- espacement V relatif	JUMP',NC 15$		; valeur ngative ?	OR.W	D0,#H'FF00	; oui => tend le signe15$:	ADD.W	(A2)+ODFCY,D0	; augmente/diminue espace V	RET; ---	MODCAR   ---;	MODCAR m;	--------;	m:	INVDOT ou SETDOTDOMCAR:	CLR.W	(A2)+ODFADR	; suite de bytes termines	LOAD.B	(A2)+ODFMCA,(A2)+ODFCOM+0	RET; ---	MODGRA   ---;	MODGRA g;	--------;	g:	GRAWHOLE, GRACLIP ou GRAROUNDDOMGRA:	CLR.W	(A2)+ODFADR	; suite de bytes termines	LOAD.B	(A2)+ODFMGR,(A2)+ODFCOM+0	RET; ---	ROLLUP   ---;	ROLLUP nn;	---------;	nn:	nb de points du dcalageDOROLLU:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSH.W	D4	LOAD.W	D4,(A2)+ODFCOM+0	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_ROLLUP-GRA_FIRST))	CALL	(A0)		; appel de GRA_ROLLUP	POP.L	A0	POP.W	D4	.ENDIF	RET; ---	ROLLDOWN   ---;	ROLLDOWN nn;	-----------;	nn:	nb de points du dcalageDOROLLD:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSH.W	D4	LOAD.W	D4,(A2)+ODFCOM+0	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_ROLLDOWN-GRA_FIRST))	CALL	(A0)		; appel de GRA_ROLLDOWN	POP.L	A0	POP.W	D4	.ENDIF	RET; ---	ROLLDOLEFT   ---;	ROLLLEFT nn;	-----------;	nn:	nb de points du dcalageDOROLLL:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSH.W	D4	LOAD.W	D4,(A2)+ODFCOM+0	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_ROLLLEFT-GRA_FIRST))	CALL	(A0)		; appel de GRA_ROLLLEFT	POP.L	A0	POP.W	D4	.ENDIF	RET; ---	ROLLRIGHT   ---;	ROLLRIGHT nn;	------------;	nn:	nb de points du dcalageDOROLLR:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSH.W	D4	LOAD.W	D4,(A2)+ODFCOM+0	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_ROLLRIGHT-GRA_FIRST))	CALL	(A0)		; appel de GRA_ROLLRIGHT	POP.L	A0	POP.W	D4	.ENDIF	RET; ---	GRAXY   ---;	GRAXY xx yy;	-----------;	xx,yy:	nouvelle coordonne  atteindre (en points)DOGXY:	CLR.W	(A2)+ODFADR	; suite de bytes termines	LOAD.W	D0,(A2)+ODFCOM+0 ; D0 <-- premier paramtre	COMP.W	D0,(A2)+ODFFDX	; dbordement ?	JUMP',LO 15$		; non => 15$	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	LOAD.W	D0,(A2)+ODFFDX	; D0 <-- coordonne X max	DEC.W	D015$:	LOAD.W	(A2)+ODFPGX,D0	; init nouvelle position en X	LOAD.W	D0,(A2)+ODFCOM+2 ; D0 <-- deuxime paramtre	COMP.W	D0,(A2)+ODFFDY	; dbordement ?	JUMP',LO 25$		; non => 25$	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	LOAD.W	D0,(A2)+ODFFDY	; D0 <-- coordonne Y max	DEC.W	D025$:	LOAD.W	(A2)+ODFPGY,D0	; init nouvelle position en Y	RET; ---	DRAWLINE   ---;	DRAWLINE xx yy m;	----------------;	xx:	arrive en x (high puis low);	yy:	arrive en y (high puis low);	m:	modeDODRLI:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D1,D3,D4	LOAD.W	D4,(A2)+ODFCOM+2 ; D4 <-- Y	LOAD.W	D3,(A2)+ODFPGY	SUB.W	D3,D4		; D3 <-- longueur en Y	SWAP.W	D4	SWAP.W	D3	LOAD.W	D4,(A2)+ODFCOM+0 ; D4 <-- Y;X	LOAD.W	D3,(A2)+ODFPGX	SUB.W	D3,D4		; D3 <-- longueur en X	LOAD.B	D1,(A2)+ODFCOM+4 ; D1 <-- mode	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_LINE-GRA_FIRST))	CALL	(A0)		; appel de GRA_LINE	POP.L	A0	TEST.W	D7		; dbordement ?	JUMP',NE 90$		; oui => 90$				; non =>	LOAD.L	(A2)+ODFPGY,D4	; init nouvelle coor. graphique90$:	POPM.L	D1,D3,D4	.ENDIF	RET; ---	DRAWSEG   ---;	DRAWSEG xx yy dxx dyy m;	-----------------------;	xx:	origine en x (high puis low);	yy:	origine en y (high puis low);	dxx:	longueur en x (high puis low);	dyy:	longueur en y (high puis low);	m:	modeDODRSE:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D1,D3,D4	LOAD.L	D4,(A2)+ODFCOM+0; D4 <-- X;Y	SWAP.W	D4		; D4 <-- Y;X	LOAD.L	D3,(A2)+ODFCOM+4; D3 <-- dX;dY	SWAP.W	D3		; D3 <-- dY;dX	LOAD.B	D1,(A2)+ODFCOM+8; D1 <-- mode	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_LINE-GRA_FIRST))	CALL	(A0)		; appel de GRA_LINE	POP.L	A0	POPM.L	D1,D3,D4	.ENDIF	RET; ---	DRAWCERCLE   ---;	DRAWCERCLE rr m;	---------------;	rr:	rayon du cercle (high puis low);	m:	modeDODRCE:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D1,D2,D3,D4	LOAD.W	D3,(A2)+ODFCOM+0; D3 <-- rayon du cercle	SWAP.W	D3	LOAD.W	D3,(A2)+ODFCOM+0; D3 <-- rayon du cercle	JUMP',EQ 90$		; si rayon nul => 90$	LOAD.B	D1,(A2)+ODFCOM+2; D1 <-- mode	LOAD.L	D4,(A2)+ODFPGY	; D4 <-- coordonne centre (y;x)	LOAD.B	D2,#B'11111111	; D4 <-- dessine tout	CALL	ITELUTIN	; efface lutin-souris si ncessaire	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_CIRCLE-GRA_FIRST))	CALL	(A0)		; appel de GRA_CIRCLE	POP.L	A090$:	POPM.L	D1,D2,D3,D4	.ENDIF	RET; ---	DRAWARC   ---;	DRAWARC xx yy rr aa m;	---------------------;	xx:	centre en x (high puis low);	yy:	centre en y (high puis low);	rr:	rayon du cercle (high puis low);	aa:	octants  dessiner (high puis low);	m:	modeDODRAR:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D1,D2,D3,D4	LOAD.L	D4,(A2)+ODFCOM+0; D4 <-- coordonne centre X;Y	SWAP.W	D4		; D4 <-- coordonne centre Y;X	LOAD.W	D3,(A2)+ODFCOM+4; D3 <-- rayon du cercle	SWAP.W	D3	LOAD.W	D3,(A2)+ODFCOM+4; D3 <-- rayon du cercle	JUMP',EQ 90$		; si rayon nul => 90$	LOAD.W	D2,(A2)+ODFCOM+6; D2 <-- octants  dessiner	LOAD.B	D1,(A2)+ODFCOM+8; D1 <-- mode	CALL	ITELUTIN	; efface lutin-souris si ncessaire	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_CIRCLE-GRA_FIRST))	CALL	(A0)		; appel de GRA_CIRCLE	POP.L	A090$:	POPM.L	D1,D2,D3,D4	.ENDIF	RET; ---	DRAWELLIPSE   ---;	DRAWELLIPSE xx yy rx ry aa m;	----------------------------;	xx:	centre en x (high puis low);	yy:	centre en y (high puis low);	rx:	rayon de l'ellipse en x (high puis low);	ry:	rayon de l'ellipse en y (high puis low);	aa:	octants  dessiner (high puis low);	m:	modeDODREL:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D1,D2,D3,D4	LOAD.L	D4,(A2)+ODFCOM+0; D4 <-- coordonne centre X;Y	SWAP.W	D4		; D4 <-- coordonne centre Y;X	LOAD.L	D3,(A2)+ODFCOM+4; D3 <-- rayons X;Y	SWAP.W	D3		; D3 <-- rayons Y;X	TEST.L	D3	JUMP',EQ 90$		; si rayons nuls => 90$	LOAD.W	D2,(A2)+ODFCOM+8; D2 <-- octants  dessiner	LOAD.B	D1,(A2)+ODFCOM+10; D1 <-- mode	CALL	ITELUTIN	; efface lutin-souris si ncessaire	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_ELLIPSE-GRA_FIRST))	CALL	(A0)		; appel de GRA_ELLIPSE	POP.L	A090$:	POPM.L	D1,D2,D3,D4	.ENDIF	RET; ---	DRAWDOT   ---;	DRAWDOT xx yy m;	---------------;	xx:	coordonne x (high puis low);	yy:	coordonne y (high puis low);	m:	modeDODRDO:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D1,D3,D4	LOAD.L	D4,(A2)+ODFCOM+0; D4 <-- coordonne (x;y)	SWAP.W	D4		; D4 <-- coordonne (y;x)	LOAD.B	D1,(A2)+ODFCOM+4; D1 <-- mode	LOAD.L	D3,#H'10000*1+1	; D3 <-- dimensions pour ITGLUTIN	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_DOT-GRA_FIRST))	CALL	(A0)		; appel de GRA_DOT	POP.L	A0	POPM.L	D1,D3,D4	.ENDIF	RET; ---	DRAWTRAME   ---;	DRAWTRAME xx yy dxx dyy m;	-------------------------;	xx:	coordonne x (high puis low);	yy:	coordonne y (high puis low);	dxx:	largeur x (high puis low);	dyy:	largeur y (high puis low);	m:	modeDODRTR:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D1,D3,D4,A4	LOAD.L	D4,(A2)+ODFCOM+0; D4 <-- X;Y	SWAP.W	D4		; D4 <-- Y;X	LOAD.L	D3,(A2)+ODFCOM+4; D3 <-- dX;dY	SWAP.W	D3		; D3 <-- dY;dX	LOAD.B	D1,(A2)+ODFCOM+8; D1 <-- mode	LOAD.L	A4,#(A2)+ODFTRA	; A4 <-- ^trame utilisateur	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_TRAME-GRA_FIRST))	CALL	(A0)		; appel de GRA_TRAME	POP.L	A0	POPM.L	D1,D3,D4,A4	.ENDIF	RET; ---	TRAME   ---;	TRAME n n n n n n n n;	---------------------;	n:	motif de la trameDOTRAM:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	.IF	SM100!SM324	PUSHM.L	D0,D1,D2,A0,A1	LOAD.L	A0,#(A2)+ODFTRA	; A0 <-- ^destination	LOAD.L	A1,#(A2)+ODFCOM	; A1 <-- ^source	CLR.W	D0	LOAD.W	D2,#8-1		; -1  cause du test NMO20$:	LOAD.B	D0,(A1+)	; D0 <-- trame de la commande; Permute tous les bits de D0 dans D1. Pas de boucle pour tre; rapide, et pas de table de 256 bytes pour conomiser la RAM !	RLX.B	D0	RRX.B	D1		; D1 <-- bit 0	RLX.B	D0	RRX.B	D1		; D1 <-- bit 1	RLX.B	D0	RRX.B	D1		; D1 <-- bit 2	RLX.B	D0	RRX.B	D1		; D1 <-- bit 3	RLX.B	D0	RRX.B	D1		; D1 <-- bit 4	RLX.B	D0	RRX.B	D1		; D1 <-- bit 5	RLX.B	D0	RRX.B	D1		; D1 <-- bit 6	RLX.B	D0	RRX.B	D1		; D1 <-- bit 7	LOAD.B	(A0+),D1	; stocke trame dans variables	DECJ.W,NMO D2,20$	POPM.L	D0,D1,D2,A0,A1	.ELSE	LOAD.L	(A2)+ODFTRA+0,(A2)+ODFCOM+0 ; stocke la trame	LOAD.L	(A2)+ODFTRA+4,(A2)+ODFCOM+4 ; dans les var.	.ENDIF	.ENDIF	RET; ---	PEN   ---;	PEN n n n n n n n n;	-------------------;	n:	motif du pinceauDOPEN:	CLR.W	(A2)+ODFADR	; suite de bytes termines	LOAD.L	(A2)+ODFPEN+0,(A2)+ODFCOM+0 ; stocke le pinceau	LOAD.L	(A2)+ODFPEN+4,(A2)+ODFCOM+4 ; dans les var.	RET; ---	MAPTT   ---;	MAPTT m e;	---------;	m:	map des traits  - - -;	e:	chelle (1..n)DOMAPT:	CLR.W	(A2)+ODFADR	; suite de bytes termines	PUSH.W	D0	LOAD.B	(A2)+ODFTTM,(A2)+ODFCOM+0 ; stocke le map  - - -	LOAD.B	D0,(A2)+ODFCOM+1 ; D0 <-- chelle	JUMP',NE 50$	INC.B	D0		; D0 <-- au moins un50$:	LOAD.B	(A2)+ODFTTS,D0	; stocke l'chelle	POP.W	D0	RET; ---	DRAWFILLO   ---;	DRAWFILLO xx yy;	---------------;	xx:	coordonne x dbut remplissage;	yy:	coordonne y dbut remplissageDODRFO:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSH.L	D4	LOAD.L	D4,(A2)+ODFCOM+0; D4 <-- coordonne (x;y)	SWAP.W	D4		; D4 <-- coordonne (y;x)	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_FILLO-GRA_FIRST))	CALL	(A0)		; appel de GRA_FILLO	POP.L	A0	POP.L	D4	.ENDIF	RET; ---	DRAWFILLC   ---;	DRAWFILLC;	---------DODRFC:	.IF	~TTY	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_FILLC-GRA_FIRST))	CALL	(A0)		; appel de GRA_FILLC	POP.L	A0	.ENDIF	RET; ---	DRAWRASTER   ---;	DRAWRASTER xx yy pppp ii xx yy pppp ii dx dy m;	----------------------------------------------;	xx:	coordonne x gauche source/destination;	yy:	coordonne y suprieure source/destination;	pppp:	^source/destination (^nil si cran);	ii:	incrment (si mmoire) source/destination;	dx:	largeur;	dy:	hauteur;	m:	modeDODRRA:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D1..D6,A3,A4	LOAD.L	D3,(A2)+ODFCOM+0; D3 <-- coordonne (x;y) source	SWAP.W	D3		; D3 <-- coordonne (y;x) source	LOAD.L	A3,(A2)+ODFCOM+4; A3 <-- ^source	LOAD.W	D5,(A2)+ODFCOM+8; D5 <-- Iy source	LOAD.L	D4,(A2)+ODFCOM+10; D4 <-- coordonne (x;y) destination	SWAP.W	D4		 ; D4 <-- coordonne (y;x) destination	LOAD.L	A4,(A2)+ODFCOM+14; A4 <-- ^destination	LOAD.W	D6,(A2)+ODFCOM+18; D6 <-- Iy destination	LOAD.L	D2,(A2)+ODFCOM+20; D2 <-- dim (dx;dy)	SWAP.W	D2		 ; D2 <-- dim (dy;dx)	LOAD.B	D1,(A2)+ODFCOM+24; D1 <-- opration	COMP.L	A4,#0		; A4=^nil (si cran) ?	JUMP',NE 50$		; non => 50$	EX.L	D3,D2	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	EX.L	D2,D350$:	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_RASTER-GRA_FIRST))	CALL	(A0)		; appel de GRA_RASTER	POP.L	A0	POPM.L	D1..D6,A3,A4	.ENDIF	RET; ---	DRAWOSPRITE   ---;	DRAWOSPRITE xx yy dx dy ssss cccc n;	-----------------------------------;	xx:	coordonne x gauche;	yy:	coordonne y suprieure;	dx:	largeur dx;	dy:	hauteur dy;	ssss:	^matrice chair (set);	cccc:	^matrice fond (clear);	n:	numro du lutinDODROS:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D0,D3,D4,D6,A3,A4	LOAD.L	D4,(A2)+ODFCOM+0; D4 <-- coordonne (x;y)	SWAP.W	D4		; D4 <-- coordonne (y;x)	LOAD.L	D3,(A2)+ODFCOM+4; D3 <-- dimensions (dx;dy)	SWAP.W	D3		; D3 <-- dimensions (dy;dx)	LOAD.L	A4,(A2)+ODFCOM+8 ; A4 <-- ^matrice chair (set)	LOAD.L	A3,(A2)+ODFCOM+12; A3 <-- ^matrice fond (clear)	LOAD.B	D6,(A2)+ODFCOM+16; D6 <-- numro du lutin	LOAD.W	D0,#SPRITE_OPEN	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_SPRITE-GRA_FIRST))	CALL	(A0)		; appel de GRA_SPRITE	POP.L	A0	POPM.L	D0,D3,D4,D6,A3,A4	.ENDIF	RET; ---	DRAWMSPRITE   ---;	DRAWMSPRITE xx yy n;	-------------------;	xx:	coordonne x gauche;	yy:	coordonne y suprieure;	n:	numro du lutinDODRMS:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D0,D1,D3,D4,D6,A3,A4	LOAD.B	D6,(A2)+ODFCOM+4; D6 <-- numro du lutin	LOAD.W	D0,#SPRITE_GETPOS	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_SPRITE-GRA_FIRST))	CALL	(A0)		; appel de GRA_SPRITE	POP.L	A0	JUMP,NE 90$	EX.L	D4,D3		; D4 <-- pos et D3 <-- dim	CLR.W	D1		; D1 <-- mode	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	LOAD.L	D4,(A2)+ODFCOM+0; D4 <-- coordonne (x;y)	SWAP.W	D4		; D4 <-- coordonne (y;x)	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	LOAD.W	D0,#SPRITE_MOVE	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_SPRITE-GRA_FIRST))	CALL	(A0)		; appel de GRA_SPRITE	POP.L	A090$:	POPM.L	D0,D1,D3,D4,D6,A3,A4	.ENDIF	RET; ---	DRAWESPRITE   ---;	DRAWESPRITE n;	-------------;	n:	numro du lutinDODRES:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D0,D3,D4,D6,A3,A4	LOAD.B	D6,(A2)+ODFCOM+0; D6 <-- numro du lutin	LOAD.W	D0,#SPRITE_CLEAR	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_SPRITE-GRA_FIRST))	CALL	(A0)		; appel de GRA_SPRITE	POP.L	A0	POPM.L	D0,D3,D4,D6,A3,A4	.ENDIF	RET; ---	DRAWCSPRITE   ---;	DRAWCSPRITE n;	-------------;	n:	numro du lutinDODRCS:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D0,D3,D4,D6,A3,A4	LOAD.B	D6,(A2)+ODFCOM+0; D6 <-- numro du lutin	LOAD.W	D0,#SPRITE_CLOSE	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_SPRITE-GRA_FIRST))	CALL	(A0)		; appel de GRA_SPRITE	POP.L	A0	POPM.L	D0,D3,D4,D6,A3,A4	.ENDIF	RET; ---	DRAWPMOUSE   ---;	DRAWPMOUSE ssss cccc;	--------------------;	ssss:	^matrice lutin (set);	cccc:	^matrice fond  (clr)DODRPM:	CLR.W	(A2)+ODFADR	; suite de bytes termines	LOAD.L	(A2)+ODFPMS,(A2)+ODFCOM+0; mm ^matrice lutin (set)	LOAD.L	(A2)+ODFPMC,(A2)+ODFCOM+4; mm ^matrice fond  (clr)	RET; ---	DRAWMOUSE   ---;	DRAWMOUSE xx yy ssss cccc o;	---------------------------;	xx:	coordonne x souris;	yy:	coordonne y souris;	ssss:	(*) ^matrice lutin (set);	cccc:	(*) ^matrice fond  (clr);	o:	(*) opration (SPRITE_OPEN/MOVE/CLOSE);;		(*)  -->  n'est plus utilis !DODRMO:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D4,A0	.IF	COLOR	TEST.B	(A2)+ODFNOW	; est-on dans la fentre $DIS_0 ?	JUMP',EQ 50$		; oui => 50$	COMP.B	(A2)+ODFNOW,#NOWDOC ; est-on dans la fentre $DIS_20 ?	JUMP',NE 90$		; non => 90$	.ELSE	TEST.B	(A2)+ODFNOW	; est-on dans la fentre $DIS_0 ?	JUMP',NE 90$		; non => 90$	.ENDIF50$:				; oui =>	LOAD.L	A0,A6		; A0 <-- ^variables globales	LOAD.L	D4,(A2)+ODFCOM+0; D4 <-- coordonne (x;y)	SWAP.W	D4		; D4 <-- coordonne (y;x)	CALL	MOMOVE		; dplace le lutin de la souris90$:	POPM.L	D4,A0	.ENDIF	RET; ---	DRAWMATRIX   ---;	DRAWMATRIX xx yy pppp m;	-----------------------;	xx:	coordonne x coin suprieur gauche;	yy:	coordonne y coin suprieur gauche;	pppp:	pointeur  la matrice;	m:	modeDODRMX:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSHM.L	D1,D2,D3,D4,D5,A4	LOAD.L	D4,(A2)+ODFCOM+0; D4 <-- coordonne (x;y)	SWAP.W	D4		; D4 <-- coordonne (y;x)	LOAD.L	A4,(A2)+ODFCOM+4; A4 <-- ^matrice	LOAD.B	D1,(A2)+ODFCOM+8; D1 <-- mode	CLR.L	D3	LOAD.B	D3,(A4+)	; D3 <-- largeur matrice	JUMP',EQ 90$	SWAP.W	D3	LOAD.B	D3,(A4+)	; D3 <-- hauteur matrice	JUMP',EQ 90$	SWAP.W	D3		; D3 <-- hauteur/largeur (dy;dx)	CLR.W	D5	LOAD.B	D5,D3	SR.B	D5,#3		; D5 <-- Iy (largeur en bytes)	LOAD.B	D2,D3	AND.B	D2,#B'111	; reste ?	JUMP',EQ 60$		; non => 60$	INC.W	D5		; oui => compte un de plus60$:	CLR.W	D2		; D2 <-- mode non invers	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	PUSH.L	A0	LOAD.L	A0,(A0)+OADGRA+(4*(GRA_MATRIX-GRA_FIRST))	CALL	(A0)		; appel de GRA_MATRIX	POP.L	A090$:	POPM.L	D1,D2,D3,D4,D5,A4	.ENDIF	RET; ---	LEFT   ---DOLEFT:	PUSH.W	D0	LOAD.W	D0,(A2)+ODFPX	; D0 <-- position X actuelle	SUB.W	D0,(A2)+ODFCX	; recule d'un caractre	COMP.W	D0,(A2)+ODFC1X	; recul trop loin ?	JUMP',GE 80$		; non => 80$				; oui =>	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	LOAD.W	D0,(A2)+ODFC1X	; revient au dbut80$:	LOAD.W	(A2)+ODFPX,D0	.IF	TTY	CALL	POSTTY	.ENDIF	POP.W	D0	RET; ---	RIGHT   ---DORIGHT:	PUSHM.W	D0,D1	LOAD.W	D1,(A2)+ODFFDX	SUB.W	D1,(A2)+ODFC2X	; D1 <-- pos  ne pas dpasser	LOAD.W	D0,(A2)+ODFPX	; D0 <-- position actuelle	ADD.W	D0,(A2)+ODFCX	; avance d'un caractre	COMP.W	D0,D1		; est-on trop  droite ?	JUMP',LE 90$		; non => 90$				; oui =>	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	LOAD.W	D0,D1		; va tout  droite90$:	LOAD.W	(A2)+ODFPX,D0	.IF	TTY	CALL	POSTTY	.ENDIF	POPM.W	D0,D1	RET; ---	UP   ---DOUP:	PUSH.W	D0	LOAD.W	D0,(A2)+ODFPY	; D0 <-- position Y actuelle	SUB.W	D0,(A2)+ODFCY	; remonte d'une ligne	COMP.W	D0,(A2)+ODFC1Y	; remont trop haut ?	JUMP',GE 80$		; non => 80$				; oui =>	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	LOAD.W	D0,(A2)+ODFC1Y	; remonte tout en haut80$:	LOAD.W	(A2)+ODFPY,D0	.IF	TTY	CALL	POSTTY	.ENDIF	POP.W	D0	RET; ---	DOWN   ---DODOWN:	PUSHM.W	D0,D1	LOAD.W	D1,(A2)+ODFFDY	SUB.W	D1,(A2)+ODFC2Y	; D1 <-- pos  ne pas dpasser	LOAD.W	D0,(A2)+ODFPY	; D0 <-- position actuelle	ADD.W	D0,(A2)+ODFCY	; descend d'un caractre	COMP.W	D0,D1		; est-on trop bas ?	JUMP',LE 90$		; non => 90$				; oui =>	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	LOAD.W	D0,D1		; va tout en bas90$:	LOAD.W	(A2)+ODFPY,D0	.IF	TTY	CALL	POSTTY	.ENDIF	POPM.W	D0,D1	RET; ---	AFDIR   ---DOADIR:	TCLR.B	(A2)+ODFFLG:#BFVIDI ; vido normale	RET; ---	AFINV   ---DOAINV:	TSET.B	(A2)+ODFFLG:#BFVIDI ; vido inverse	RET; ---	AFTOUT   ---DOTOUT:	TSET.B	(A2)+ODFFLG:#BFTOUT ; affiche tout	RET; ---	AFNORM   ---DONORM:	TCLR.B	(A2)+ODFFLG:#BFTOUT ; excute CR, TAB, etc.	RET; ---	AFFULL   ---DOFULL:	TCLR.B	(A2)+ODFFLG:#BFGREY ; affiche en plein	RET; ---	AFGREY   ---DOGREY:	TSET.B	(A2)+ODFFLG:#BFGREY ; affiche en gris	RET; ---	ROLL   ---DOROLL:	TSET.B	(A2)+ODFMOD:#BFROLL ; fait du roll	TCLR.B	(A2)+ODFMOD:#BSROLL ; "hard" roll	RET; ---	SROLL   ---DOSROL:	TSET.B	(A2)+ODFMOD:#BFROLL ; fait du roll	TSET.B	(A2)+ODFMOD:#BSROLL ; "soft" roll	RET; ---	NOROLL   ---DONORO:	TCLR.B	(A2)+ODFMOD:#BFROLL ; plus de roll	RET; ---	TRUNC   ---DOTRUN:	TSET.B	(A2)+ODFMOD:#BFTRUNC ; tronque les lignes	RET; ---	AUTOCR   ---DOAUCR:	TCLR.B	(A2)+ODFMOD:#BFTRUNC ; ne tronque plus lignes	RET; ---	AUTOEFLI   ---DOAUEF:	TSET.B	(A2)+ODFMOD:#BFEFLI ; efface lignes aprs CR	RET; ---	NOEFLI   ---DONOEF:	TCLR.B	(A2)+ODFMOD:#BFEFLI ; n'efface pas les lignes	RET; ---	GCURS   ---DOGCUR:	TCLR.B	(A2)+ODFMOD:#BFNOCU ; y a un curseur	TCLR.B	(A2)+ODFMOD:#BFPCUR ; grand curseur	RET; ---	PCURS   ---DOPCUR:	TCLR.B	(A2)+ODFMOD:#BFNOCU ; y a un curseur	TSET.B	(A2)+ODFMOD:#BFPCUR ; petit curseur	RET; ---	CURS   ---DOCURS:	TCLR.B	(A2)+ODFMOD:#BFNOCU ; y a un curseur	RET; ---	NOCURS   ---DONOCU:	TSET.B	(A2)+ODFMOD:#BFNOCU ; plus de curseur du tout	RET; ---	AFCVAR   ---DOCVAR:	TCLR.B	(A2)+ODFMOD:#BFCFIX ; chasse variable	RET; ---	AFCFIX   ---DOCFIX:	TSET.B	(A2)+ODFMOD:#BFCFIX ; chasse fixe	RET; ---	AFCCMO   ---DOCCMO:	TSET.B	(A2)+ODFFLG:#BFNCMO ; curseur souris interdit	RET; ---	AFSCMO   ---DOSCMO:	TCLR.B	(A2)+ODFFLG:#BFNCMO ; curseur souris permis	RET; ---	AFFILLT   ---DOFILT:	TCLR.B	(A2)+ODFFLG:#BFFILA ; rempli: test si touche les bords	RET; ---	AFFILLA   ---DOFILA:	TSET.B	(A2)+ODFFLG:#BFFILA ; rempli: va jusque dans les bords	RET; ---	MMODULO   ---DOMODU:	CLR.W	(A2)+ODFADR	; suite de bytes termines	TCLR.B	(A2)+ODFFL2:#BFNOMOD	TEST.B	(A2)+ODFCOM+0	JUMP',EQ 90$	TSET.B	(A2)+ODFFL2:#BFNOMOD90$:	RET; ---	IMAENA   ---DOIMAE:	.IF	~TTY	TSET.B	(A2)+ODFFLG:#BFIMAA ; image alpha va exister	JUMP',BS 90$		; si existait dj => 90$	CALL	CREIMA		; cre l'image alphanum.90$:	.ENDIF	RET; ---	IMADIS   ---DOIMAD:	.IF	~TTY	TCLR.B	(A2)+ODFFLG:#BFIMAA ; plus d'image alpha	JUMP',BC 90$		; si dj plus => 90$	CALL	KILIMA		; supprime l'image alphanum.90$:	.ENDIF	RET; ---	COLORSA	---;	COLORSA rr gg bb;	----------------;	rr:	intensit du rouge;	gg:	intensit du vert;	bb:	intensit du bleuDOCOSA:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	COLOR	PUSHM.L	D3,D4,A4	LOAD.B	D3,(A2)+ODFCOM+0 ; D3 <-- r	SL.L	D3,#8	LOAD.B	D3,(A2)+ODFCOM+2 ; D3 <-- g	SL.L	D3,#8	LOAD.B	D3,(A2)+ODFCOM+4 ; D3 <-- b	SL.L	D3,#8	CALL	COLORFAUSRC	; A4/D4 <-- fausse couleur	LOAD.L	(A2)+ODFCSF,D4	LOAD.B	(A2)+ODFCSA+0,(A4)+OCOLFR ; ODFCSA+0 <-- rouge	CLR.B	(A2)+ODFCSA+1	LOAD.B	(A2)+ODFCSA+2,(A4)+OCOLFG ; ODFCSA+2 <-- vert	CLR.B	(A2)+ODFCSA+3	LOAD.B	(A2)+ODFCSA+4,(A4)+OCOLFB ; ODFCSA+4 <-- bleu	CLR.B	(A2)+ODFCSA+5	POPM.L	D3,D4,A4	.ENDIF	RET; ---	COLORCA	---;	COLORCA rr gg bb;	----------------;	rr:	intensit du rouge;	gg:	intensit du vert;	bb:	intensit du bleuDOCOCA:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	COLOR	PUSHM.L	D3,D4,A4	LOAD.B	D3,(A2)+ODFCOM+0 ; D3 <-- r	SL.L	D3,#8	LOAD.B	D3,(A2)+ODFCOM+2 ; D3 <-- g	SL.L	D3,#8	LOAD.B	D3,(A2)+ODFCOM+4 ; D3 <-- b	SL.L	D3,#8	CALL	COLORFAUSRC	; A4/D4 <-- fausse couleur	LOAD.L	(A2)+ODFCCF,D4	LOAD.B	(A2)+ODFCCA+0,(A4)+OCOLFR ; ODFCCA+0 <-- rouge	CLR.B	(A2)+ODFCCA+1	LOAD.B	(A2)+ODFCCA+2,(A4)+OCOLFG ; ODFCCA+2 <-- vert	CLR.B	(A2)+ODFCCA+3	LOAD.B	(A2)+ODFCCA+4,(A4)+OCOLFB ; ODFCCA+4 <-- bleu	CLR.B	(A2)+ODFCCA+5	POPM.L	D3,D4,A4	.ENDIF	RET; ---	COLORSR	---;	COLORSR nnnn;	------------;	nnnn:	numroDOCOSR:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	COLOR	PUSHM.L	D3,D4,A3	LOAD.L	D4,(A2)+ODFCOM+0 ; D4 <-- nnnn	CALL	COLORRELSRC	; A3/D3 <-- ^dans OCOLRx	JUMP',EQ 20$	LOAD.L	A3,(A2)+ODFPDE	; A3 <-- ^descripteurs (32* .L)	TEST.L	(A3)+(4*NOWDOC)	; fentre inoccupe ?	JUMP',EQ 90$		; oui => 90$	PUSH.L	A2	LOAD.L	A2,(A3)+(4*NOWDOC) ; A2 <-- ^descripteur de $DIS_20	CALL	COLORRELSRC	; A3/D3 <-- ^dans OCOLRx	POPM.L	A2	JUMP',NE 90$20$:	LOAD.L	(A2)+ODFCSR,D4	; ODFCSR <-- numro	CLR.L	D4	LOAD.B	D4,(A3)+OCOLRF	LOAD.L	(A2)+ODFCSF,D4	; ODFCSF <-- fausse couleur	LOAD.B	(A2)+ODFCSA+0,(A3)+OCOLRR ; ODFCSA+0 <-- rouge	CLR.B	(A2)+ODFCSA+1	LOAD.B	(A2)+ODFCSA+2,(A3)+OCOLRG ; ODFCSA+2 <-- vert	CLR.B	(A2)+ODFCSA+3	LOAD.B	(A2)+ODFCSA+4,(A3)+OCOLRB ; ODFCSA+4 <-- bleu	CLR.B	(A2)+ODFCSA+590$:	POPM.L	D3,D4,A3	.ENDIF	RET; ---	COLORCR	---;	COLORSR nnnn;	------------;	nnnn:	numroDOCOCR:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	COLOR	PUSHM.L	D3,D4,A3	LOAD.L	D4,(A2)+ODFCOM+0 ; D4 <-- nnnn	CALL	COLORRELSRC	; A3/D3 <-- ^dans OCOLRx	JUMP',EQ 20$	LOAD.L	A3,(A2)+ODFPDE	; A3 <-- ^descripteurs (32* .L)	TEST.L	(A3)+(4*NOWDOC)	; fentre inoccupe ?	JUMP',EQ 90$		; oui => 90$	PUSH.L	A2	LOAD.L	A2,(A3)+(4*NOWDOC) ; A2 <-- ^descripteur de $DIS_20	CALL	COLORRELSRC	; A3/D3 <-- ^dans OCOLRx	POPM.L	A2	JUMP',NE 90$20$:	LOAD.L	(A2)+ODFCCR,D4	; ODFCCR <-- numro	CLR.L	D4	LOAD.B	D4,(A3)+OCOLRF	LOAD.L	(A2)+ODFCCF,D4	; ODFCCF <-- fausse couleur	LOAD.B	(A2)+ODFCCA+0,(A3)+OCOLRR ; ODFCCA+0 <-- rouge	CLR.B	(A2)+ODFCCA+1	LOAD.B	(A2)+ODFCCA+2,(A3)+OCOLRG ; ODFCCA+2 <-- vert	CLR.B	(A2)+ODFCCA+3	LOAD.B	(A2)+ODFCCA+4,(A3)+OCOLRB ; ODFCCA+4 <-- bleu	CLR.B	(A2)+ODFCCA+590$:	POPM.L	D3,D4,A3	.ENDIF	RET; ---	COLORLINK   ---;	COLORLINK nnnn rr gg bb;	-----------------------;	nnnn:	numro;	rr:	intensit du rouge;	gg:	intensit du vert;	bb:	intensit du bleuDOCOLK:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	COLOR	PUSHM.L	D3,D4,A3,A4	LOAD.L	D4,(A2)+ODFCOM+0 ; D4 <-- nnnn	CALL	COLORRELSRC	; A3/D3 <-- ^dans OCOLRx	JUMP',EQ 30$	CALL	COLORRELADD	; ajoute une nouvelle couleur	JUMP',NE 90$30$:	LOAD.B	(A3)+OCOLRR,(A2)+ODFCOM+4+0	LOAD.B	(A3)+OCOLRG,(A2)+ODFCOM+4+2	LOAD.B	(A3)+OCOLRB,(A2)+ODFCOM+4+4	LOAD.L	D3,(A3)+OCOLRR	; D3 <-- |r|g|b|-|	CALL	COLORFAUSRC	; A4/D4 <-- fausse couleur	LOAD.B	(A3)+OCOLRF,D490$:	POPM.L	D3,D4,A3,A4	.ENDIF	RET; ---	COLORUNLINK   ---;	COLORUNLINK nnnn;	----------------;	nnnn:	numroDOCOUK:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	COLOR	PUSHM.L	D3,D4,A3	LOAD.L	D4,(A2)+ODFCOM+0 ; D4 <-- nnnn	CALL	COLORRELSRC	; A3/D3 <-- ^dans OCOLRx	JUMP',NE 90$	CALL	COLORRELSUB	; supprime une ancienne couleur90$:	POPM.L	D3,D4,A3	.ENDIF	RET; ---	COLOROP   ---;	COLOROP o;	---------;	o:	opration (COLOROPxxx)DOCOOP:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	COLOR	PUSHM.L	D3,D4	LOAD.B	D3,(A2)+ODFCOM	; D3 <-- <o>	COMP.B	D3,#COLOROPPUSH	JUMP',EQ PUSH$	COMP.B	D3,#COLOROPPOP	JUMP',EQ POP$	COMP.B	D3,#COLOROPFIX	JUMP,EQ FIX$	COMP.B	D3,#COLOROPAJUST	JUMP,EQ AJUST$	LOAD.W	D7,#ERDIOUT	JUMP	EXIT$PUSH$:	CALL	COLORPUSH	; sauve les couleurs	JUMP	EXIT$POP$:	CALL	COLORPOP	; restitue les couleurs	JUMP	EXIT$FIX$:AJUST$:EXIT$:	POPM.L	D3,D4	.ENDIF	RET; ---	COLORFALSE   ---;	COLORFALSE ffff rr gg bb;	------------------------;	ffff:	fausse couleur;	rr:	intensit du rouge;	gg:	intensit du vert;	bb:	intensit du bleuDOCOFA:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	COLOR	PUSHM.L	D3,A3	LOAD.L	A3,(A2)+ODFCPF	; A3 <-- ^table des fausses couleurs	LOAD.L	D3,(A2)+ODFCOM+0	COMP.W	D3,(A2)+ODFCNB	JUMP',HS 90$	MUL.WU	D3,#LCOLF	ADD.L	A3,D3	LOAD.B	(A3)+OCOLFR,(A2)+ODFCOM+4+0	LOAD.B	(A3)+OCOLFG,(A2)+ODFCOM+4+2	LOAD.B	(A3)+OCOLFB,(A2)+ODFCOM+4+4	CALL	AFCVDCC		; initialise toute (?) la table des fausses couleurs90$:	POPM.L	D3,A3	.ENDIF	RET; ---	DIMWDO	---;	DIMWDO xx yy dxx dyy;	--------------------;	xx:	dbut de la fentre en X;	yy:	dbut de la fentre en Y;	dxx:	largeur de la fentre;	dyy:	hauteur de la fentreDODIMW:	CLR.W	(A2)+ODFADR	; suite de bytes termines	PUSH.W	D3	LOAD.W	D7,#ERDIOUT	 ; D7 <-- paramtres trop grand	TEST.B	(A2)+ODFFL2:#BFNOMOD	JUMP',BS 20$	AND.W	(A2)+ODFCOM+0,#H'FFF8 ; aligne xx sur un byte	AND.W	(A2)+ODFCOM+4,#H'FFF8 ; aligne dxx sur un byte	AND.W	(A2)+ODFCOM+2,#H'FFFE ; aligne yy sur un word	AND.W	(A2)+ODFCOM+6,#H'FFFE ; aligne dyy sur un word20$:	LOAD.W	D3,(A2)+ODFCOM+0 ; D3 <-- xx	ADD.W	D3,(A2)+ODFCOM+4 ; D3 <-- xx + dxx	COMP.W	D3,(A2)+ODFDX	 ; trop large ?	JUMP',HI 90$		 ; oui => 90$	LOAD.W	D3,(A2)+ODFCOM+2 ; D3 <-- yy	ADD.W	D3,(A2)+ODFCOM+6 ; D3 <-- yy + dyy	COMP.W	D3,(A2)+ODFDY	 ; trop long ?	JUMP',HI 90$		 ; oui => 90$	LOAD.W	(A2)+ODFFX,(A2)+ODFCOM+0  ; mm. xx	LOAD.W	(A2)+ODFFY,(A2)+ODFCOM+2  ; mm. yy	LOAD.W	(A2)+ODFFDX,(A2)+ODFCOM+4 ; mm. dxx	LOAD.W	(A2)+ODFFDY,(A2)+ODFCOM+6 ; mm. dyy	CALL	WMINMAX		; init min et max (sous-)fentre	CLR.W	D7		; D7 <-- ok90$:	POP.W	D3	RET;--------\\; WMINMAX >;========/; Initialise les variables contenant les positions min/max de la; (sous-)fentre.; in	A2.L	^descripteur; out	-; mod	-WMINMAX:	PUSH.W	D4	LOAD.W	D4,(A2)+ODFX	ADD.W	D4,(A2)+ODFFX	LOAD.W	(A2)+ODFWBX,D4	; init min X	ADD.W	D4,(A2)+ODFFDX	LOAD.W	(A2)+ODFWEX,D4	; init max X	LOAD.W	D4,(A2)+ODFY	ADD.W	D4,(A2)+ODFFY	LOAD.W	(A2)+ODFWBY,D4	; init min Y	ADD.W	D4,(A2)+ODFFDY	LOAD.W	(A2)+ODFWEY,D4	; init max Y	POP.W	D4	RET; ---	SAVWDO	---DOSAVW:	.IF	TTY	RET	.ELSE	JUMP	WDOSAV		; zone sauvetage <-- fentre	.ENDIF; ---	GETWDO	---DOGETW:	.IF	TTY	RET	.ELSE	JUMP	WDOGET		; fentre <-- zone sauvetage	.ENDIF; ---	PROCURS   ---;	PROCURS c;	---------;	c:	caractre (dfinissant la largeur du curseur)DOPROC:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSH.W	D3	LOAD.B	D3,(A2)+ODFCOM+0 ; D3 <-- paramtre "c"	CALL	INVPROC	POP.W	D3	.ENDIF	RET; ---	NEWGC   ---;	NEWGC o f ssss t;	----------------;	o:	opration (LOADGC/USEGC/KILLGC);	f:	fonte (normal, spcial, messenger, grec, etc);	ssss:	style (bits 0-7: style/chasse, bits 7-31: construction);	t:	tailleDONEGC:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	TTY	COMP.B	(A2)+ODFCOM+0,#USEGC	JUMP',NE 90$	LOAD.B	(A2)+ODFGCF,(A2)+ODFCOM+1	LOAD.B	(A2)+ODFGCS,(A2)+ODFCOM+5	LOAD.B	(A2)+ODFGCT,(A2)+ODFCOM+690$:	.ELSE	PUSHM.L	D2,D3	LOAD.B	D3,(A2)+ODFCOM+0 ; D3 <-- opration	LOAD.B	D0,(A2)+ODFCOM+1 ; D0 <-- fonte	LOAD.B	D1,(A2)+ODFCOM+2	SL.L	D1,#8	LOAD.B	D1,(A2)+ODFCOM+3	SL.L	D1,#8	LOAD.B	D1,(A2)+ODFCOM+4	SL.L	D1,#8	LOAD.B	D1,(A2)+ODFCOM+5 ; D1 <-- style	LOAD.B	D2,(A2)+ODFCOM+6 ; D2 <-- taille	COMP.B	D3,#LOADGC	JUMP',EQ 30$	COMP.B	D3,#KILLGC	JUMP',EQ 40$	CALL	GCUSE		; utilise	JUMP'	90$30$:	CALL	GCLOAD		; charge	JUMP'	90$40$:	CALL	GCKILL		; libre90$:	POPM.L	D2,D3	.ENDIF	RET; ---	USEGC   ---;	USEGC f s t;	-----------;	f:	fonte (normal, spcial, messenger, grec, etc);	s:	style (roman, italique, bold, etc);	t:	tailleDOUSGC:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	TTY	LOAD.B	(A2)+ODFGCF,(A2)+ODFCOM+0	LOAD.B	(A2)+ODFGCS,(A2)+ODFCOM+1	LOAD.B	(A2)+ODFGCT,(A2)+ODFCOM+2	.ELSE	PUSH.W	D2	LOAD.B	D0,(A2)+ODFCOM+0 ; D0 <-- fonte	LOAD.B	D1,(A2)+ODFCOM+1 ; D1 <-- style	LOAD.B	D2,(A2)+ODFCOM+2 ; D2 <-- taille	CALL	CONVNEWGC	; D0/D1/D2 <-- fst selon nouveau format	CALL	GCUSE	POP.W	D2	.ENDIF	RET; ---	LOADGC   ---;	LOADGC f s t;	------------;	f:	fonte (normal, spcial, messenger, grec, etc);	s:	style (roman, italique, bold, etc);	t:	tailleDOLOGC:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSH.W	D2	LOAD.B	D0,(A2)+ODFCOM+0 ; D0 <-- fonte	LOAD.B	D1,(A2)+ODFCOM+1 ; D1 <-- style	LOAD.B	D2,(A2)+ODFCOM+2 ; D2 <-- taille	CALL	CONVNEWGC	; D0/D1/D2 <-- fst selon nouveau format	CALL	GCLOAD	POP.W	D2	.ENDIF	RET; ---	KILLGC   ---;	KILLGC f s t;	------------;	f:	fonte (normal, spcial, messenger, grec, etc);	s:	style (roman, italique, bold, etc);	t:	tailleDOKIGC:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSH.W	D2	LOAD.B	D0,(A2)+ODFCOM+0 ; D0 <-- fonte	LOAD.B	D1,(A2)+ODFCOM+1 ; D1 <-- style	LOAD.B	D2,(A2)+ODFCOM+2 ; D2 <-- taille	CALL	CONVNEWGC	; D0/D1/D2 <-- fst selon nouveau format	CALL	GCKILL	POP.W	D2	.ENDIF	RET; ---	PFIXGC   ---;	PFIXGC nnnn;	-----------;	nnnn:	prfix de 4 lettres au maximum;		- nom<0> si moins de 4 lettres;		- nom si 4 lettres;		- <0> si prfix standard "SYS" ou "100"DOPFGC:	CLR.W	(A2)+ODFADR	; suite de bytes termines	LOAD.L	(A2)+ODFFIX,(A2)+ODFCOM+0	RET; ---	ASSGC   ---;	ASSGC f s t   f s t	(logique-physique);	-------------------;	f:	fonte (normal, spcial, messenger, grec, etc);	s:	style (roman, italique, bold, etc);	t:	tailleDOASGC:	CLR.W	(A2)+ODFADR	; suite de bytes termines	.IF	~TTY	PUSH.L	A2	LOAD.L	A2,#(A2)+ODFCOM	; A2 <-- ^2x(f,s,t)	CALL	ADDEQ		; ajoute galit	POP.L	A2	.ENDIF	RET; ---	MEMGC   ---DOMEGC:	.IF	TTY	RET	.ELSE	JUMP	PUTEQG		; buffer --> SYS_INFO	.ENDIF; ---	EFLI   ---DOEFLI:	.IF	TTY	CALL	EOLTTY	RET	.ELSE	CALL	ITLLUTIN	; efface lutin-souris si ncessaire	JUMP	AFEFLI	.ENDIF; ---	EFEOS   ---DOEFEOS:	.IF	TTY	CALL	EOLTTY	RET	.ELSE	JUMP	AFEFEOS	.ENDIF; ---	CR   ---DOCR:	.IF	TTY	PUSHM.W	D0,D1	LOAD.W	(A2)+ODFPX,(A2)+ODFC1X ; rz position en X	LOAD.W	D1,(A2)+ODFFDY	SUB.W	D1,(A2)+ODFC2Y	; D1 <-- pos  ne pas dpasser	LOAD.W	D0,(A2)+ODFPY	; D0 <-- position en Y	ADD.W	D0,(A2)+ODFCY	; ajoute largeur d'un caractre	COMP.W	D0,D1		; trop bas ?	JUMP',LS 50$		; non => 50$				; oui =>	CALL	ROLLTTY	CALL	POSTTY	JUMP'	90$50$:	LOAD.W	(A2)+ODFPY,D0	; mj mouvelle position en Y	CALL	POSTTY90$:	POPM.W	D0,D1	.ELSE	PUSHM.W	D0,D1	LOAD.W	(A2)+ODFPX,(A2)+ODFC1X ; rz position en X	LOAD.W	D1,(A2)+ODFFDY	SUB.W	D1,(A2)+ODFC2Y	; D1 <-- pos  ne pas dpasser	LOAD.W	D0,(A2)+ODFPY	; D0 <-- position en Y	ADD.W	D0,(A2)+ODFCY	; ajoute largeur d'un caractre	COMP.W	D0,D1		; trop bas ?	JUMP',LS 50$		; non => 50$				; oui =>	CALL	CLRLUTIN	; enlve le lutin de la souris	CALL	ROLLCR		; effectue un roll de l'cran	JUMP'	90$50$:	LOAD.W	(A2)+ODFPY,D0	; mj mouvelle position en Y	TEST.B	(A2)+ODFMOD:#BFEFLI ; efface nouvelle ligne ?	JUMP',EQ 90$		; non => 90$	CALL	DOEFLI		; oui => efface tout la ligne90$:	POPM.W	D0,D1	.ENDIF	RET; ---	EOP   ---DOEOP:	.IF	TTY	CALL	EOPTTY	LOAD.W	(A2)+ODFPX,(A2)+ODFC1X	LOAD.W	(A2)+ODFPY,(A2)+ODFC1Y ; clear coordonne alpha	CLR.W	(A2)+ODFPGX	CLR.W	(A2)+ODFPGY	; clear coordonne graphique	CALL	POSTTY	.ELSE	CALL	EFFACE		; efface tout l'cran	LOAD.W	(A2)+ODFPX,(A2)+ODFC1X	LOAD.W	(A2)+ODFPY,(A2)+ODFC1Y ; clear coordonne alpha	CLR.W	(A2)+ODFPGX	CLR.W	(A2)+ODFPGY	; clear coordonne graphique	.ENDIF	RET; ---	TAB   ---DOTAB:	PUSHM.W	D2,D3	CLR.L	D2	LOAD.W	D2,(A2)+ODFPX	; D2 <-- position en X	DIV.WU	D2,(A2)+ODFCX	; D2 <-- position en car.10$:	LOAD.B	D3,#SPACE	CALL	AFCODE		; affiche un espace	INC.B	D2	AND.B	D2,#B'111	; position modulo 8 ?	JUMP,NE 10$		; non => 10$	POPM.W	D2,D3	RET; ---	BELL   ---DOBELL:	RET; ---	BS   ---DOBS:	PUSH.W	D3	CALL	DOLEFT		; recule d'un caractre	LOAD.B	D3,#SPACE	CALL	AFCODE		; affiche un espace	CALL	DOLEFT		; puis recule encore une fois	POP.W	D3	RET; ---	MSPACE   ---;	MSPACE n;	--------;	n:	nombre d'espaces  afficherDOMSPA:	CLR.W	(A2)+ODFADR	; suite de bytes termines	PUSHM.W	D0,D1,D3	LOAD.B	D0,(A2)+ODFCOM	; D0 <-- nb de SPACE  afficher	JUMP',EQ 90$		; si zro => 90$20$:				; si un ou plusieurs =>	LOAD.B	D3,#SPACE	CALL	AFCODE		; affiche qq SPACE(s)	DEC.B	D0	JUMP,NE 20$90$:	POPM.W	D0,D1,D3	RET	.END