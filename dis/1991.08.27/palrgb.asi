	.SBTTL	PALRGB.ASI;---------\\; RGBCDRAW >;=========/; Affiche la couleur originale (0) ou modifie (1).; in	D1.W	numro de la couleur (0,1); out	-; mod	D7.WRGBCDRAW:	PUSHM.L	D2..D5,A3	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.W	D3,D1	MUL.WU	D3,#102	ADD.W	D3,#30	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LOAD.W	D3,(A6)+OCURPX	LOAD.L	D4,#H'10000*75+70	LOAD.W	D2,#SETDOT	LIB	?DRRECT	LIB	?COLORPUSH	PUSHM.L	D3,D4	CALL	RGBCGET		; D3,D4,D5 <-- couleur	LIB	?COLORSA	POPM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	LIB	?COLORPOP	SWAP.W	D3	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#3	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A3,#R16"00$	TEST.W	D1	JUMP',EQ TEXT$	LOAD.L	A3,#R16"01$TEXT$:	LIB	?AFTEXTEXIT$:	POPM.L	D2..D5,A3	RET00$:	.ASCIZ	"Original"01$:	.ASCIZ	"Modifi"	.EVEN;--------\\; RGBCPUT >;========/; Donne les trois couleurs aux trois ascenseurs.; in	D3.W	rouge;	D4.W	vert;	D5.W	bleu; out	-; mod	D7.WRGBCPUT:	PUSHM.L	D3..D5	SR.W	D3,#8	SR.W	D4,#8	SR.W	D5,#8	LOAD.W	(A6)+OSCVAR+(LSCVAR*0)+OSCPOSV,D3	LOAD.W	(A6)+OSCVAR+(LSCVAR*1)+OSCPOSV,D4	LOAD.W	(A6)+OSCVAR+(LSCVAR*2)+OSCPOSV,D5	POPM.L	D3..D5	RET;--------\\; RGBCGET >;========/; Prend les trois couleurs des trois ascenseurs.; in	-; out	D3.W	rouge;	D4.W	vert;	D5.W	bleu; mod	D3.L, D4.L, D5.L, D7.WRGBCGET:	LOAD.W	D3,(A6)+OSCVAR+(LSCVAR*0)+OSCPOSV	LOAD.W	D4,(A6)+OSCVAR+(LSCVAR*1)+OSCPOSV	LOAD.W	D5,(A6)+OSCVAR+(LSCVAR*2)+OSCPOSV	SL.W	D3,#8	SL.W	D4,#8	SL.W	D5,#8	RET;---------\\; RGBDRAWS >;=========/; Dessine les trois ascenseurs.; in	-; out	-; mod	D7.WRGBDRAWS:	PUSH.L	D1	CLR.W	D1LOOP$:	CALL	RGBDRAW	INC.W	D1	COMP.W	D1,#3	JUMP,LO LOOP$	POP.L	D1	RET;--------\\; RGBDRAW >;--------/; Dessine l'un des trois ascenseur.; in	D1.W	numro de l'ascenseur (0..2); out	-; mod	D7.WRGBDRAW:	PUSHM.L	D3,D4,A3..A5	CALL	RGBOPEN		; ascenseur: met les couleurs spciales	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D4,D1	MUL.WU	D4,#LSCVAR	ADD.L	A5,D4	LOAD.W	(A5)+OSCDEBO,#30	LOAD.W	D4,#26	MUL.WU	D4,D1	ADD.W	D4,(A6)+OCURPX	ADD.W	D4,#92	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	(A5)+OSCHTR,#194	SCROLL_	DRAW	COMP.W	D1,#2	JUMP,NE EXIT$	LOAD.W	D3,#10	LOAD.W	D4,#12	LOAD.L	A3,#R16"TEXT$	SCROLL_	SCALEEXIT$:	CALL	RGBCLOSE	; ascenseur: remet les couleurs normales	LOAD.L	A3,#R16"HELPR$	TEST.W	D1	JUMP',EQ HELP$	LOAD.L	A3,#R16"HELPG$	COMP.W	D1,#1	JUMP',EQ HELP$	LOAD.L	A3,#R16"HELPB$HELP$:	LOAD.W	D3,(A5)+OSCDEBO	SUB.W	D3,#8	SWAP.W	D3	LOAD.W	D3,(A5)+OSCDEBL	SUB.W	D3,#5	LIB	?SETCURS	LIB	?AFTEXT	POPM.L	D3,D4,A3..A5	RETTEXT$:	.ASCIZ	"fonc"	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	"moyen"	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	"clair"HELPR$:	.ASCIZ	" R "HELPG$:	.ASCIZ	" V "HELPB$:	.ASCIZ	" B "	.EVEN;-----------\\; RGBUPDATES >;===========/; Met  jour les trois ascenseurs.; in	-; out	-; mod	D7.WRGBUPDATES:	PUSHM.L	D1	CLR.W	D1LOOP$:	CALL	RGBUPDATE	; met  jour un ascenseur	INC.W	D1	COMP.W	D1,#3	JUMP,LO LOOP$	POPM.L	D1	RET;----------\\; RGBUPDATE >;----------/; Met  jour un ascenseur.; in	D1.W	numro de l'ascenseur (0..2); out	-; mod	D7.WRGBUPDATE:	PUSHM.L	D4,A5	CALL	RGBOPEN		; ascenseur: met les couleurs spciales	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D4,D1	MUL.WU	D4,#LSCVAR	ADD.L	A5,D4	LOAD.W	(A5)+OSCHTV,#256	LOAD.W	(A5)+OSCINC,#256/32	SET.B	(A5)+OSCMARK	SCROLL_	UPDATE	CALL	RGBCLOSE	; ascenseur: remet les couleurs normales	POPM.L	D4,A5	RET;---------\\; RGBMOVES >;=========/; Dplace l'un des trois ascenseurs.; in	D4.L	position de la souris;	A1.L	^routine mj.; out	D7.W	ok/erreur; mod	D7.WRGBMOVES:	PUSH.L	D1	CLR.W	D1LOOP$:	CALL	RGBMOVE		; dplace un ascenseur ?	JUMP',EQ EXIT$	INC.W	D1	COMP.W	D1,#3	JUMP,LO LOOP$EXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGBMOVE >;--------/; Dplace l'un des trois ascenseur.; in	D1.W	numro de l'ascenseur (0..2);	A1.L	^routine mj.;	D4.L	position de la souris; out	D7.W	ok/erreur; mod	D7.WRGBMOVE:	PUSHM.L	D2,D3,D4,D5,A5	CALL	RGBOPEN		; ascenseur: met les couleurs spciales	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D3,D1	MUL.WU	D3,#LSCVAR	ADD.L	A5,D3	SCROLL_	MOVE	JUMP,NE EXIT$	LOAD.W	D2,#-10	COMP.W	D4,#SCROLLFUP	JUMP',EQ INIT$	NEG.W	D2	COMP.W	D4,#SCROLLFDOWN	JUMP,NE OK$INIT$:	SCROLL_	PRESSLOOP$:	LIB	?IFCAR		; vnement ?	JUMP',NE MOVE$	COMP.W	D3,#KEYMGR	JUMP',EQ CLOSE$	COMP.W	D3,#KEYMMR	JUMP',EQ CLOSE$	COMP.W	D3,#KEYMDR	JUMP',EQ CLOSE$MOVE$:	LOAD.W	D5,(A5)+OSCPOSV	ADD.W	D5,D2	JUMP',NC MIN$	CLR.W	D5MIN$:	COMP.W	D5,(A5)+OSCHTV	JUMP',LO MAX$	LOAD.W	D5,(A5)+OSCHTV	DEC.W	D5MAX$:	LOAD.W	(A5)+OSCPOSV,D5	SCROLL_	UPDATE	CALL	(A1)		; mj. qq chose	PUSH.W	D4	LOAD.W	D4,#50/10	NTREL	?DELMS		; attend un poil ...	POP.W	D4	JUMP	LOOP$CLOSE$:	SCROLL_	PRESSOK$:	CALL	(A1)		; mj. qq chose	CLR.W	D7EXIT$:	CALL	RGBCLOSE	; ascenseur: remet les couleurs normales	POPM.L	D2,D3,D4,D5,A5	TEST.W	D7	RET;--------\\; RGBOPEN >;--------/; Ascenseur: met les couleurs spciales.; in	D1.W	numro de l'ascenseur (0..2); out	-; mod	D7.WRGBOPEN:	PUSHM.L	D2..D5,A3	LOAD.L	A3,#R16"TABLE$	LOAD.W	D3,D1	MUL.WU	D3,#2+2+2	ADD.L	A3,D3	LOAD.L	D2,#COLOR_SCCLEAR	LOAD.W	D3,(A3)+0	LOAD.W	D4,(A3)+2	LOAD.W	D5,(A3)+4	CALL	LINK	LOAD.L	D2,#COLOR_SCSET	LOAD.W	D3,#H'0000	LOAD.W	D4,#H'0000	LOAD.W	D5,#H'0000	CALL	LINK	LOAD.L	D2,#COLOR_SCOBJ	LOAD.W	D3,#H'0000	LOAD.W	D4,#H'0000	LOAD.W	D5,#H'0000	CALL	LINK	LOAD.L	D2,#COLOR_SCPOS	LOAD.W	D3,#H'FFFF	LOAD.W	D4,#H'FFFF	LOAD.W	D5,#H'FFFF	CALL	LINK	POPM.L	D2..D5,A3	RETTABLE$:	.W	H'FFFF,H'0000,H'0000	; rouge	.W	H'0000,H'FFFF,H'0000	; vert	.W	H'0000,H'0000,H'FFFF	; bleu;---------\\; RGBCLOSE >;---------/; Ascenseur: remet les couleurs normales.; in	-; out	-; mod	-RGBCLOSE:	PUSHM.L	D2..D5,D7,A3	LOAD.L	D2,#COLOR_SCCLEAR	CALL	SRCRANG	LOAD.W	D3,(A3)+4+0	LOAD.W	D4,(A3)+4+2	LOAD.W	D5,(A3)+4+4	CALL	LINK	LOAD.L	D2,#COLOR_SCSET	CALL	SRCRANG	LOAD.W	D3,(A3)+4+0	LOAD.W	D4,(A3)+4+2	LOAD.W	D5,(A3)+4+4	CALL	LINK	LOAD.L	D2,#COLOR_SCOBJ	CALL	SRCRANG	LOAD.W	D3,(A3)+4+0	LOAD.W	D4,(A3)+4+2	LOAD.W	D5,(A3)+4+4	CALL	LINK	LOAD.L	D2,#COLOR_SCPOS	CALL	SRCRANG	LOAD.W	D3,(A3)+4+0	LOAD.W	D4,(A3)+4+2	LOAD.W	D5,(A3)+4+4	CALL	LINK	POPM.L	D2..D5,D7,A3	RET	.END