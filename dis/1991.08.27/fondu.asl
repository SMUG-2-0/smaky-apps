\define g_Fond:\nef11;\define g_titre:\m(f)17;\define g_ev:\n(bf)09;\define g_it:\n(if)07;\g_Fond;; $sma; $erh:FONDU	.TITLE		\g_titre;FONDU.ASL\g_Fond;	.PROC		M68000	.BASE		10'10	.REF		SMAKY	.REF		MODULES	.REF		FONDU\g_ev;; Variables en {A6}; -----------------\g_Fond;OMACHINE:	.BLK.8		1			; type de la machine (SMAKYxxx)	.EVENoCHK:		.blk.32		1			; ^variable pour contrleoStatusEcran:	.blk.32		1			; ^status de la fentreoAdRaster:	.blk.32		1			; ^routine GRA_ (c)RASTERoAdGraLine:	.blk.32		1			; ^routine GRA_ LINE;-----OSDDIS:	.BLK.8		LGDIS7			; copie du descripteur de la fentre; lments  sauvegarder dans le descripteur de la fentre :oSavDfABS:	.blk.32		1oSavDfIIX:	.blk.16		1oSavDfIIY:	.blk.16		1oSavDfY:	.blk.32		1oSavDfDY:	.blk.32		1oSavDfFY:	.blk.32		1oSavDfFDY:	.blk.32		1oSavDfWBY:	.blk.32		1oSavDfWEY:	.blk.32		1oSavDfCMD:	.blk.8		1	.evenOMATPR:	;;;;;;	.BLK.8		((32*32)/8)*4		; matrice pour progressions (*4 bits/pixel)LgVar:\g_titre;\g_ev;; -----------------\; Entte du module |; -----------------/\g_Fond;	.LOC		0Base:	.16		FONDU_FIRST	.16		FONDU_LAST	.8		0	.FILL.8		(OHLREV-APC), 0	.8		1,0	.32		FONDU_END	.32		PATHLIB	.FILL.8		(OHLNAM-APC), 0	.ASCII		"FONDU"	.FILL.8		(LGHLIB-APC), 0	.16		OPEN				; FONDU_OPEN	.16		PROGRESS			; FONDU_PROGESS	.16		CLOSE				; FONDU_CLOSE\g_titre;;------\; OPEN  >;======/\g_Fond;; rserve les variables pour le module;; in	-; out	A0.32		^variables du module;	D7.16		erreur ventuelle; mod	A0.32, D7.16;OPEN:	pushm.32	A4|D1|D4|D3|A3	Lib		?GetPDis		; ^status de l'cran	jump,ne		r8^r$	move.32		A4, A0			; pour mettre dans les variables	clr.32		d4	move.8		{A4}+ODFCNP, d4		; nombre de plans couleurs	mul.16		#32*32/8, d4		; place pour matrice 32*32 pixels	add.32		#LgVar, d4		; plus variables diverses	move.16		#mTypCp, d1	GesMem		?GetMem			; un peu de mmoire s.v.p.	jump,ne		r8^r$	move.32		A0, {A4}+oStatusEcran	; conserve le ^status cran	ex.32		A4, A0			; retourne le "canal" -> A0	move.32		A0, {A0}+oCHK		; pour contrle validit	move.16		#GRA_LINE, D3	LIB_		GETAD			; adresse de la routine GRA_LINE	jump,ne		r8^r$	move.32		A3, {A0}+oAdGraLine	move.16		#GRA_RASTER, D3	LIB_		GETAD			; adresse de la routine GRA_RASTER	jump,ne		r8^r$	move.32		A3, {A0}+oAdRaster	test.8		{A4}+oDfCMD	jump,eq		r8^r$	move.16		#GRA_cRASTER, D3	LIB_		GETAD			; utilise la routine couleur	jump,ne		r8^r$	move.32		A3, {A0}+oAdRasterr$:	popm.32		A4|D1|D4|D3|A3	Ret\g_titre;;-------\; CLOSE  >;=======/\g_Fond;; restitue les variables du module;; in	A0.32		^variable fourni par FONDU_OPEN; out	D7.16		erreur ventuelle;CLOSE:	pushm.32	A4|D1	move.16		#ErILCH, D7	comp.32		{A0}+oCHK, A0	jump,ne		r8^r$	move.32		A0, A4	move.16		#mTypCP, D1	GesMem		?GivMemr$:	popm.32		A4|D1	Ret\g_titre;;---------\\; PROGRESS >;=========/\g_Fond;; Effectue une progression quelconque.; in	A0.32	^variables du module (^description fentre);	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.32	incrment/dlai;	----;	D0.16	type de progression (PROG*); out	-; mod	D7.16PROGRESS:	pushm.32	D0..D6|A0..A4|A6	call		A6vars			; ^var -> A6	jump,ne		Retour	COMP.16		#PROGHB,D0	JUMP,EQ		PROGRESSHB	COMP.16		#PROGBH,D0	JUMP,EQ 	PROGRESSBH	COMP.16		#PROGGD,D0	JUMP,EQ 	PROGRESSGD	COMP.16		#PROGDG,D0	JUMP,EQ 	PROGRESSDG	COMP.16		#PROGDHB,D0	JUMP,EQ		PROGRESSDHB	COMP.16		#PROGDBH,D0	JUMP,EQ 	PROGRESSDBH	COMP.16		#PROGDGD,D0	JUMP,EQ 	PROGRESSDGD	COMP.16		#PROGDDG,D0	JUMP,EQ 	PROGRESSDDG	COMP.16		#PROGCN,D0	JUMP,EQ		PROGRESSCN	COMP.16		#PROGCI,D0	JUMP,EQ		PROGRESSCI	COMP.16		#PROGSV,D0	JUMP,EQ		PROGRESSSV	comp.16		#PROGHOR,D0	jump,eq		PROGRESSHOR	comp.16		#PROGVER,D0	jump,eq		PROGRESSVER	COMP.16		#PROGA,D0	JUMP,EQ		PROGRESSA	JUMP		PROGRESSALRetour:	popm.32		D0..D6|A0..A4|A6	Ret\g_ev;;-----------\\; PROGRESSHB >;===========/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: progression de haut en bas; in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.32	incrment/dlai; out	-; mod	D7.16PROGRESSHB:;	PUSHM.32	D0..D6|A2..A4	CALL		PROGRESSI			; prpare les paramtres	MOVE.16		D1,D4				; D4 <-- dlai	CLR.16		D3				; D3 <-- compteur	MOVE.32		D2,D0	SR.16		#5,D0				; D0 <-- largeur /32 car par .L	TEST.8		{A0}+ODFCMD			; cran couleur ?	JUMP,EQ		R8^L10$				; non => 10$	SL.16		#2,D0				; D0 <-- *4 (nb de bits/pixel)L10$:	DEC.16		D0				; D0 <-- largeur -1 car NMO	MOVE.32		D1,D2	SWAP.32		D2				; D2 <-- incrmentL20$:	PUSHM.32	D0|A3|A4L30$:	MOVE.32		{A3+},{A4+}			; destination <-- source	DJ.16,NMO	D0,L30$	POPM.32		D0|A3|A4	INC.16		D3	CLR.32		D1	MOVE.16		D3,D1	DIV.16		D2,D1	SWAP.32		D1	TEST.16		D1	JUMP,NE		R8^L50$	NTREL		?DELMS				; attend un p'tit peuL50$:	ADD.A16		D5,A3				; A3 <-- ^ligne suivante	ADD.A16		D6,A4				; A4 <-- ^ligne suivante	SWAP.32		D0	DEC.16		D0	MOVE.16		D0,D1	SWAP.32		D0	TEST.16		D1	JUMP,NE		L20$;	POPM.32		D0..D6|A2..A4	jump		RETOUR\g_ev;;-----------\\; PROGRESSBH >;===========/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: progression de bas en haut; in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.32	incrment/dlai; out	-; mod	D7.16PROGRESSBH:;	PUSHM.32	D0..D6|A2..A4	swap.32		d3	swap.32		d4	move.16		d3, d0				; valeur initiale	swap.32		d1	swap.32		d2	add.16		d2, d3				; coordonne fin image	add.16		d2, d4	move.16		d1, d2				; nouvelle hauteur	swap.32		d2	swap.32		d3	swap.32		d4Lp$:	swap.32		d2	swap.32		d3	swap.32		d4	sub.16		d2, d3				; coordonne nouvelle tranche	sub.16		d2, d4	comp.16		d0, d3	jump,ge		r8^d$	sub.16		d0, d3			; en trop (ngatif)	sub.16		d3, d4	add.16		d3, d2			; reste dans la tranche	jump,eq		r8^r$			; plus rien -> fini	move.16		d0, d3			; origine originaled$:	swap.32		d2	swap.32		d3	swap.32		d4	move.32		A0, a2				; ^status cran pour GRA_	call		RasterOp			; fait le gra_(c)raster	swap.32		d1	ex.32		d1, d4	NTREL		?DELMS				; attend un p'tit peu	ex.32		d1, d4	swap.32		d1	JUMP		Lp$r$:;	POPM.32		D0..D6|A2..A4	jump		RETOUR\g_ev;;-----------\\; PROGRESSDG >;===========/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: progression de droite vers la gauche; in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.32	incrment/dlai; out	-; mod	D7.16PROGRESSDG:;	PUSHM.32	D0..D6|A2..A4	move.16		d3, d0				; valeur initiale	add.16		d2, d3				; coordonne fin image	add.16		d2, d4	swap.32		d1	move.16		d1, d2				; nouvelle hauteurLp$:	sub.16		d2, d3				; coordonne nouvelle tranche	sub.16		d2, d4	comp.16		d0, d3	jump,ge		r8^d$	sub.16		d0, d3			; en trop (ngatif)	sub.16		d3, d4	add.16		d3, d2			; reste dans la tranche	jump,eq		r8^r$			; plus rien -> fini	move.16		d0, d3			; origine originaled$:	move.32		A0, a2				; ^status cran pour GRA_	call		RasterOp			; fait le gra_(c)raster	swap.32		d1	ex.32		d1, d4	NTREL		?DELMS				; attend un p'tit peu	ex.32		d1, d4	swap.32		d1	JUMP		Lp$r$:;	POPM.32		D0..D6|A2..A4	jump		RETOUR\g_ev;;-----------\\; PROGRESSGD >;===========/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: progression de gauche vers la droite; in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.32	incrment/dlai; out	-; mod	D7.16PROGRESSGD:;	PUSHM.32	D0..D6|A2..A4	move.16		d3, d0				; valeur initiale	add.16		d2, d0				; coordonne fin image	swap.32		d1	move.16		d1, d2				; nouvelle largeur	sub.16		d2, d0				; coordonne dernire tranche	sub.16		d2, d3	sub.16		d2, d4Lp$:	add.16		d2, d3				; coordonne nouvelle tranche	add.16		d2, d4	comp.16		d0, d3	jump,le		r8^d$	sub.16		d0, d3			; en trop (positif)	sub.16		d3, d2			; reste dans la tranche	jump,eq		r8^r$			; plus rien -> fini	move.16		d0, d3d$:	move.32		A0, a2				; ^status cran pour GRA_	call		RasterOp			; fait le gra_(c)raster	swap.32		d1	ex.32		d1, d4	NTREL		?DELMS				; attend un p'tit peu	ex.32		d1, d4	swap.32		d1	JUMP		Lp$r$:;	POPM.32		D0..D6|A2..A4	jump		RETOURRasterOp:	move.16		#2**bSrcCoul+2**bDstCoul+LOADDOT, D1	push.32		{A6}+oAdRaster	Ret\g_ev;;------------\\; PROGRESSDHB >;============/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: diapositive de haut en bas; in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.32	incrment/dlai; out	-; mod	D7.16PROGRESSDHB:;	PUSHM.32	D0..D6|A2..A4	swap.32		d3	swap.32		d1	swap.32		d2	add.16		d2, d3				; coordonne fin image	move.16		d2, d0				; valeur initiale	move.16		#0, d2				; nouvelle hauteur	swap.32		d1	swap.32		d2	swap.32		d3Lp$:	swap.32		d1	swap.32		d2	swap.32		d3	comp.16		d0, d2	jump,eq		r$	add.16		d1, d2	sub.16		d1, d3				; coordonne nouvelle tranche	comp.16		d0, d2	jump,le		r8^d$	sub.16		d0, d2			; en trop (positif)	add.16		d2, d3	move.16		d0, d2			; dimension originaled$:	swap.32		d2	swap.32		d1	swap.32		d3	push.32		d1	move.32		A0, a2				; ^status cran pour GRA_	call		RasterOp			; fait le gra_(c)raster	pop.32		d1	ex.32		d1, d4	NTREL		?DELMS				; attend un p'tit peu	ex.32		d1, d4	JUMP		Lp$r$:;	POPM.32		D0..D6|A2..A4	jump		RETOUR\g_ev;;------------\\; PROGRESSDBH >;============/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: diapositive de bas en haut; in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.32	incrment/dlai; out	-; mod	D7.16PROGRESSDBH:;	PUSHM.32	D0..D6|A2..A4	swap.32		d4	swap.32		d1	swap.32		d2	add.16		d2, d4				; coordonne fin image	move.16		d2, d0				; valeur initiale	move.16		#0, d2				; nouvelle hauteur	swap.32		d1	swap.32		d2	swap.32		d4Lp$:	swap.32		d1	swap.32		d2	swap.32		d4	comp.16		d0, d2	jump,eq		r$	add.16		d1, d2	sub.16		d1, d4				; coordonne nouvelle tranche	comp.16		d0, d2	jump,le		r8^d$	sub.16		d0, d2			; en trop (positif)	add.16		d2, d4	move.16		d0, d2			; dimension originaled$:	swap.32		d2	swap.32		d1	swap.32		d4	push.32		d1	move.32		A0, a2				; ^status cran pour GRA_	call		RasterOp			; fait le gra_(c)raster	pop.32		d1	ex.32		d1, d4	NTREL		?DELMS				; attend un p'tit peu	ex.32		d1, d4	JUMP		Lp$r$:;	POPM.32		D0..D6|A2..A4	jump		RETOUR\g_ev;;------------\\; PROGRESSDGD >;============/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: diapositive de gauche  droite; in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.32	incrment/dlai; out	-; mod	D7.16PROGRESSDGD:;	PUSHM.32	D0..D6|A2..A4	swap.32		d1	add.16		d2, d3				; coordonne fin image	move.16		d2, d0				; valeur initiale	move.16		#0, d2				; nouvelle hauteur	swap.32		d1Lp$:	swap.32		d1	comp.16		d0, d2	jump,eq		r$	add.16		d1, d2	sub.16		d1, d3				; coordonne nouvelle tranche	comp.16		d0, d2	jump,le		r8^d$	sub.16		d0, d2			; en trop (positif)	add.16		d2, d3	move.16		d0, d2			; dimension originaled$:	swap.32		d1	push.32		d1	move.32		A0, a2				; ^status cran pour GRA_	call		RasterOp			; fait le gra_(c)raster	pop.32		d1	ex.32		d1, d4	NTREL		?DELMS				; attend un p'tit peu	ex.32		d1, d4	JUMP		Lp$r$:;	POPM.32		D0..D6|A2..A4	jump		RETOUR\g_ev;;------------\\; PROGRESSDDG >;============/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: diapositive de droite  gauche; in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.32	incrment/dlai; out	-; mod	D7.16PROGRESSDDG:;	PUSHM.32	D0..D6|A2..A4	swap.32		d1	add.16		d2, d4				; coordonne fin image	move.16		d2, d0				; valeur initiale	move.16		#0, d2				; nouvelle hauteur	swap.32		d1Lp$:	swap.32		d1	comp.16		d0, d2	jump,eq		r$	add.16		d1, d2	sub.16		d1, d4				; coordonne nouvelle tranche	comp.16		d0, d2	jump,le		r8^d$	sub.16		d0, d2			; en trop (positif)	add.16		d2, d4	move.16		d0, d2			; dimension originaled$:	swap.32		d1	push.32		d1	move.32		A0, a2				; ^status cran pour GRA_	call		RasterOp			; fait le gra_(c)raster	pop.32		d1	ex.32		d1, d4	NTREL		?DELMS				; attend un p'tit peu	ex.32		d1, d4	JUMP		Lp$r$:;	POPM.32		D0..D6|A2..A4	jump		RETOUR\g_ev;;-----------\\; PROGRESSCN >;===========/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: carrs (zoom avant); in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.16	dlai; out	-; mod	D7.16PROGRESSCN:;	PUSHM.32	D0..D6|A2..A4	CALL		PROGRESSI			; prpare les paramtres	MOVE.16		D1,D4				; D4 <-- dlai	CLR.16		D3L20$:	CALL		PROGRESSCC			; dessine un carr	CALL		PROGRESS1			; progresse un p'tit peu ...	TEST.16		D4	JUMP,EQ		R8^L50$	NTREL		?DELMS				; attend un p'tit peuL50$:	INC.16		D3	COMP.16		#16,D3	JUMP,LO		L20$;	POPM.32		D0..D6|A2..A4	JUMP		RETOUR\g_ev;;-----------\\; PROGRESSCI >;===========/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: carrs (zoom arrire); in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.16	dlai; out	-; mod	D7.16PROGRESSCI:;	PUSHM.32	D0..D6|A2..A4	CALL		PROGRESSI			; prpare les paramtres	MOVE.16		D1,D4				; D4 <-- dlai	MOVE.16		#15,D3L20$:	CALL		PROGRESSCC			; dessine un carr	CALL		PROGRESS1			; progresse un p'tit peu ...	TEST.16		D4	JUMP,EQ		R8^L50$	NTREL		?DELMS				; attend un p'tit peuL50$:	DEC.16		D3	JUMP,NC		L20$;	POPM.32		D0..D6|A2..A4	JUMP		RETOUR\g_ev;;-----------\\; PROGRESSCC >;-----------/\g_Fond;; Dessine un carr centr dans la matrice de transfert.; in	D3.16	rang (0..15); out	-; mod	D7.16PROGRESSCC:	PUSHM.32	D2..D4|A4	CALL		OPEDISMAT			; dessin en mmoire	MOVE.32		A2,A4				; A4 <-- ^matrice vide	MOVE.32		#16'10000*32+32,D4	CALL		NEWDISMAT	TEST.8		{A0}+ODFCMD			; cran couleur ?	JUMP,EQ		R8^DRAW$			; non => DRAW$	CLR.16		D2	MOVE.8		{A0}+ODFCNP,D2	MUL.16		{A0}+ODFIIY,D2	MOVE.16		D2,{A0}+ODFIIY	MOVE.8		#2,{A0}+ODFCMDDRAW$:	MOVE.16		D3,D2	INC.16		D2	SL.16		#1,D2	DEC.16		D2	MOVE.16		D2,D4	SWAP.32		D4	MOVE.16		D2,D4	MOVE.16		D3,D2	SUB.16		#15,D2	NEG.16		D2	MOVE.16		D2,D3	SWAP.32		D3	MOVE.16		D2,D3	MOVE.16		#SETDOT,D2	CALL		DRRECT	CALL		CLODISMAT			; dessin dans l'cran	POPM.32		D2..D4|A4	RET\g_ev;;-----------\\; PROGRESSSV >;===========/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: stores vnitiens; in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.16	dlai; out	-; mod	D7.16PROGRESSSV:;	PUSHM.32	D0..D6|A2..A4	CALL		PROGRESSI			; prpare les paramtres	TEST.8		{A0}+ODFCMD			; cran couleur ?	JUMP,NE		R8^COLOR$	MOVE.16		D1,D4				; D4 <-- dlai	CLR.16		D3BLOOP$:	MOVE.32		#{A6}+OMATPR,A2	MOVE.16		#32-1,D1BCLR$:	CLR.32		{A2+}	DJ.16,NMO	D1,BCLR$	MOVE.32		#{A6}+OMATPR,A2			; A2 <-- ^matrice vide	MOVE.32		#-1,{A2}+A16^{D3}	CALL		PROGRESS1			; progresse un p'tit peu ...	TEST.16		D4	JUMP,EQ		R8^BNEXT$	NTREL		?DELMS				; attend un p'tit peuBNEXT$:	ADD.16		#4,D3	COMP.16		#128,D3	JUMP,LO		BLOOP$	JUMP		EXIT$COLOR$:	MOVE.16		D1,D4				; D4 <-- dlai	CLR.16		D3CLOOP$:	MOVE.32		#{A6}+OMATPR,A2	MOVE.16		#32-1,D1CCLR$:	CLR.32		{A2+}	CLR.32		{A2+}	CLR.32		{A2+}	CLR.32		{A2+}	DJ.16,NMO	D1,CCLR$	MOVE.32		#{A6}+OMATPR,A2			; A2 <-- ^matrice vide	MOVE.32		#-1,{A2}+A16^{D3}+0	MOVE.32		#-1,{A2}+A16^{D3}+4	MOVE.32		#-1,{A2}+A16^{D3}+8	MOVE.32		#-1,{A2}+A16^{D3}+12	CALL		PROGRESS1			; progresse un p'tit peu ...	TEST.16		D4	JUMP,EQ		R8^CNEXT$	NTREL		?DELMS				; attend un p'tit peuCNEXT$:	ADD.16		#4*4,D3	COMP.16		#128*4,D3	JUMP,LO		CLOOP$EXIT$:;	POPM.32		D0..D6|A2..A4	JUMP		RETOUR\g_ev;;------------\\; PROGRESSHOR >;============/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: progression du milieu vers le haut et vers le bas; in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.32	incrment/dlai; out	-; mod	D7.16PROGRESSHOR:;	PUSHM.32	D0..D6|A2..A4	swap.32		d3	swap.32		d4	swap.32		d1	swap.32		d2	move.16		d2, d0				; hauteur initiale	swap.32		d0	move.16		d3, d0				; valeur initiale	sr.16		d2				; 1/2 hauteur	add.16		d2, d3				; coordonne milieu image	add.16		d2, d4	move.16		#0, d2				; nouvelle hauteur	swap.32		d1	swap.32		d2	swap.32		d3	swap.32		d4Lp$:	comp.32		d0, d2	jump,hs		r$	swap.32		d1	swap.32		d2	swap.32		d3	swap.32		d4	sub.16		d1, d3				; coordonne nouvelle tranche	add.16		d1, d2	add.16		d1, d2	sub.16		d1, d4	comp.16		d0, d3	jump,ge		r8^d$	sub.16		d0, d3			; en trop (ngatif)	sub.16		d3, d4	swap.32		d0	move.16		d0, d2			; taille totale	swap.32		d0	move.16		d0, d3			; origine originaled$:	swap.32		d1	swap.32		d2	swap.32		d3	swap.32		d4	push.32		d1	move.32		A0, a2				; ^status cran pour GRA_	call		RasterOp			; fait le gra_(c)raster	pop.32		d1	ex.32		d1, d4	NTREL		?DELMS				; attend un p'tit peu	ex.32		d1, d4	JUMP		Lp$r$:;	POPM.32		D0..D6|A2..A4	jump		RETOUR\g_ev;;------------\\; PROGRESSVER >;============/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: progression du milieu vers la droite et la gauche; in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	----;	D1.32	incrment/dlai; out	-; mod	D7.16PROGRESSVER:;	PUSHM.32	D0..D6|A2..A4	CALL		PROGRESSI			; prpare les paramtres	swap.32		d1	move.16		d2, d0				; largeur initiale	swap.32		d0	move.16		d3, d0				; valeur initiale	sr.16		d2				; 1/2 largeur	add.16		d2, d3				; coordonne milieu image	add.16		d2, d4	move.16		#0, d2				; nouvelle largeur	swap.32		d1Lp$:	swap.32		d0	comp.16		d0, d2	jump,hs		r$	swap.32		d0	swap.32		d1	sub.16		d1, d3				; coordonne nouvelle tranche	add.16		d1, d2	add.16		d1, d2	sub.16		d1, d4	comp.16		d0, d3	jump,ge		r8^d$	sub.16		d0, d3			; en trop (ngatif)	sub.16		d3, d4	swap.32		d0	move.16		d0, d2			; taille totale	swap.32		d0	move.16		d0, d3			; origine originaled$:	swap.32		d1	push.32		d1	move.32		A0, a2				; ^status cran pour GRA_	call		RasterOp			; fait le gra_(c)raster	pop.32		d1	ex.32		d1, d4	NTREL		?DELMS				; attend un p'tit peu	ex.32		d1, d4	JUMP		Lp$r$:;	POPM.32		D0..D6|A2..A4	jump		RETOUR\g_ev;;----------\\; PROGRESSA >;==========/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: alatoire (fondu enchan); in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	D1.16	dlai; out	-; mod	D7.16PROGRESSA:	COMP.8		#SMAKY324,{A6}+OMACHINE	JUMP,EQ		PROGRESSAL	test.16		D1	jump,ne		PROGRESSALALEARAPIDE:; le plus rapidement possible !;	PUSHM.32	D0..D6|A1..A4	CALL		PROGRESSI			; prpare les paramtres	TEST.8		{A0}+ODFCMD			; cran couleur ?	JUMP,NE		COLOR$	MOVE.32		#R16^TPR256,A1	MOVE.16		#(16*16)-1,D1BLOOP$:	MOVE.32		#{A6}+OMATPR,A2	MOVE.16		#(32/4)-1,D0	CLR.32		D3BCLR$:	MOVE.32		D3,{A2+}	MOVE.32		D3,{A2+}	MOVE.32		D3,{A2+}	MOVE.32		D3,{A2+}	DJ.16,NMO	D0,BCLR$	MOVE.32		#{A6}+OMATPR,A2	MOVE.8		{A1+},D3			; D3 <-- xxxxxxxx76543210	MOVE.16		D3,D4	SR.8		#5,D4				; D4 <-- xxxxxxxxooooo765	RR.16		#1,D3				; D3 <-- 0xxxxxxxo7654321	SL.8		#1,D3				; D3 <-- 0xxxxxxx7654321o	RL.16		#1,D3				; D3 <-- xxxxxxxx654321o0	AND.16		#2'111101,D3			; D3 <-- oooooooooo4321o0	TSET.8		{A2}+A16^{D3}:D4	ADD.16		#2,D3	TSET.8		{A2}+A16^{D3}:D4	ADD.16		#64-2,D3	TSET.8		{A2}+A16^{D3}:D4	ADD.16		#2,D3	TSET.8		{A2}+A16^{D3}:D4	CALL		PROGRESS1			; progresse un p'tit peu ...	DJ.16,NMO	D1,BLOOP$	JUMP		EXIT$COLOR$:	MOVE.32		#R16^TPR256,A1	MOVE.16		#(16*16)-1,D1CLOOP$:	MOVE.32		#{A6}+OMATPR,A2	CLR.16		D3	MOVE.8		{A1+},D3			; D3 <-- oooooooo76543210	MOVE.16		D3,D4	SR.8		#4,D4				; D4 <-- oooooooooooo7654	AND.8		#2'1111,D3			; D3 <-- oooooooooooo3210	CALL		PROGRESSCSD			; OMATPR <-- met un pixel	ADD.16		#16,D3	CALL		PROGRESSCSD			; OMATPR <-- met un pixel	ADD.16		#16,D4	CALL		PROGRESSCSD			; OMATPR <-- met un pixel	SUB.16		#16,D3	CALL		PROGRESSCSD			; OMATPR <-- met un pixel	CALL		PROGRESS1			; progresse un p'tit peu ...	SUB.16		#16,D4	CALL		PROGRESSCCD			; OMATPR <-- enlve un pixel	ADD.16		#16,D3	CALL		PROGRESSCCD			; OMATPR <-- enlve un pixel	ADD.16		#16,D4	CALL		PROGRESSCCD			; OMATPR <-- enlve un pixel	SUB.16		#16,D3	CALL		PROGRESSCCD			; OMATPR <-- enlve un pixel	DJ.16,NMO	D1,CLOOP$EXIT$:;	POPM.32		D0..D6|A1..A4	JUMP		RETOUR\g_ev;;-----------\\; PROGRESSAL >;===========/\g_Fond;; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: alatoire lent (fondu enchan); in	A0.32	^description fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----;	D2.32	hauteur/largeur (y;x);	D1.16	dlai; out	-; mod	D7.16PROGRESSAL:;	PUSHM.32	D0..D6|A1..A4	dec.16		d1	jump,cs		ALEARAPIDE			; le plus rapidement possible	CALL		PROGRESSI			; prpare les paramtres	TEST.8		{A0}+ODFCMD			; cran couleur ?	JUMP,NE		COLOR$	MOVE.32		#R16^TPR256,A1	MOVE.16		#(16*16)-1,d0BLOOP$:	swap.32		d0	MOVE.32		#{A6}+OMATPR,A2	MOVE.16		#(32/4)-1,D0	CLR.32		D3BCLR$:	MOVE.32		D3,{A2+}	MOVE.32		D3,{A2+}	MOVE.32		D3,{A2+}	MOVE.32		D3,{A2+}	DJ.16,NMO	D0,BCLR$	MOVE.32		#{A6}+OMATPR,A2	MOVE.8		{A1+},D3			; D3 <-- xxxxxxxx76543210	MOVE.16		D3,D4	SR.8		#5,D4				; D4 <-- xxxxxxxxooooo765	RR.16		#1,D3				; D3 <-- 0xxxxxxxo7654321	SL.8		#1,D3				; D3 <-- 0xxxxxxx7654321o	RL.16		#1,D3				; D3 <-- xxxxxxxx654321o0	AND.16		#2'111101,D3			; D3 <-- oooooooooo4321o0	TSET.8		{A2}+A16^{D3}:D4	CALL		PROGRESS1w			; progresse un p'tit peu ...	TCLR.8		{A2}+A16^{D3}:D4	ADD.16		#2,D3	TSET.8		{A2}+A16^{D3}:D4	CALL		PROGRESS1w			; progresse un p'tit peu ...	TCLR.8		{A2}+A16^{D3}:D4	ADD.16		#64-2,D3	TSET.8		{A2}+A16^{D3}:D4	CALL		PROGRESS1w			; progresse un p'tit peu ...	TCLR.8		{A2}+A16^{D3}:D4	ADD.16		#2,D3	TSET.8		{A2}+A16^{D3}:D4	CALL		PROGRESS1w			; progresse un p'tit peu ...	TCLR.8		{A2}+A16^{D3}:D4	swap.32		d0	DJ.16,NMO	d0,BLOOP$	JUMP		EXIT$COLOR$:	MOVE.32		#R16^TPR256,A1	MOVE.16		#(16*16)-1,d0CLOOP$:	swap.32		d0	MOVE.32		#{A6}+OMATPR,A2	CLR.16		D3	MOVE.8		{A1+},D3			; D3 <-- oooooooo76543210	MOVE.16		D3,D4	SR.8		#4,D4				; D4 <-- oooooooooooo7654	AND.8		#2'1111,D3			; D3 <-- oooooooooooo3210	CALL		PROGRESSCSD			; OMATPR <-- met un pixel	CALL		PROGRESS1w			; progresse un p'tit peu ...	CALL		PROGRESSCCD			; OMATPR <-- enlve un pixel	ADD.16		#16,D3	CALL		PROGRESSCSD			; OMATPR <-- met un pixel	CALL		PROGRESS1w			; progresse un p'tit peu ...	CALL		PROGRESSCCD			; OMATPR <-- enlve un pixel	ADD.16		#16,D4	CALL		PROGRESSCSD			; OMATPR <-- met un pixel	CALL		PROGRESS1w			; progresse un p'tit peu ...	CALL		PROGRESSCCD			; OMATPR <-- enlve un pixel	SUB.16		#16,D3	CALL		PROGRESSCSD			; OMATPR <-- met un pixel	CALL		PROGRESS1w			; progresse un p'tit peu ...	CALL		PROGRESSCCD			; OMATPR <-- enlve un pixel	swap.32		d0	DJ.16,NMO	d0,CLOOP$EXIT$:;	POPM.32		D0..D6|A1..A4	JUMP		RETOUR;------------\\; PROGRESSCSD >;------------/; Met un point couleur dans la matrice transfert.; in	A2.32	^matrice 32x32;	D3.16	X (0..31);	D4.16	Y (0..31); out	-; mod	D7.16PROGRESSCSD:	PUSHM.32	D3|D4|A2	SL.16		#4,D4	ADD.A16		D4,A2	SR.16		#1,D3	JUMP,CC		R8^RIGHT$	OR.8		#2'11110000,{A2}+A16^{D3}	JUMP		R8^EXIT$RIGHT$:	OR.8		#2'00001111,{A2}+A16^{D3}EXIT$:	POPM.32		D3|D4|A2	RET;------------\\; PROGRESSCCD >;------------/; Enlve un point couleur dans la matrice transfert.; in	A2.32	^matrice 32x32;	D3.16	X (0..31);	D4.16	Y (0..31); out	-; mod	D7.16PROGRESSCCD:	PUSHM.32	D3|D4|A2	SL.16		#4,D4	ADD.A16		D4,A2	SR.16		#1,D3	JUMP,CC		R8^RIGHT$	AND.8		#2'00001111,{A2}+A16^{D3}	JUMP		R8^EXIT$RIGHT$:	AND.8		#2'11110000,{A2}+A16^{D3}EXIT$:	POPM.32		D3|D4|A2	RET; Cette table (gnre par GENH256.ASC) donne 256 valeurs alatoires,; toutes diffrentes.TPR256:	.32		16'034C7F21,16'598509BF,16'FEB9B36C,16'B80ED424	.32		16'1D5008FF,16'01D5C79D,16'35697871,16'262705FA	.32		16'CCCB7C34,16'D9F81CD6,16'DEE3CF5B,16'A3D2EFB7	.32		16'648FE094,16'1A9756E8,16'77B1F24D,16'46F4F598	.32		16'96425F55,16'5C5D1089,16'D714E27D,16'9A0CBC2B	.32		16'D10DC81E,16'88836BEA,16'A49012FD,16'99321682	.32		16'159EE91B,16'B2A2473A,16'0AACEE2E,16'7BED4E7A	.32		16'5EF3E7F1,16'BDA7E445,16'30E68165,16'3E2C9C48	.32		16'DC41C9DF,16'362D8C79,16'734F58A1,16'76510F49	.32		16'0B54FC28,16'A60453C3,16'1FC02922,16'ABBB2A18	.32		16'438D66C1,16'CAA0BAE1,16'F7E5CDAD,16'6E173CB0	.32		16'92D86325,16'D0B46D4A,16'7420AF3B,16'F9333707	.32		16'AAC4B557,16'066A8E8A,16'86615A23,16'6F753D11	.32		16'60007038,16'804052CE,16'4BF06784,16'95313991	.32		16'9BAEDD72,16'87A868D3,16'F6EC7EFB,16'44C59319	.32		16'A9622FC2,16'DABE1302,16'A53F8BDB,16'EB9FB6C6;----------\\; PROGRESSI >;----------/; Prpare les paramtres.; in	A0.32	^descripteur fentre;	----;	D3.32	coordonne source (y;x);	A3.32	^mmoire source/^nil si cran;	D5.16	Iy source (si mmoire);	----;	D4.32	coordonne destination (y;x);	A4.32	^mmoire destination/^nil si cran;	D6.16	Iy destination (si mmoire);	----; out	A3.32	^mmoire source;	D5.16	Iy source;	A4.32	^mmoire destination;	D6.16	Iy destination;	A2.32	^matrice de transfert (32x32); mod	D5.32, D6.32, D7.16, A2.32, A3.32, A4.32PROGRESSI:	PUSHM.32	D0|D1|D3|D4	CLR.16		D1	MOVE.8		{A0}+ODFCNP,D1			; D1 <-- nb de bits/pixel	MOVE.32		A3,D0				; source dans l'cran ?	JUMP,NE		R8^L10$				; non => 10$							; oui =>	MOVE.32		{A0}+ODFABS,A3			; A3 <-- adresse dbut cran	MOVE.16		{A0}+ODFIIY,D5			; D5 <-- Iy cran	ADD.16		{A0}+ODFWBX,D3			; D3 <-- dans (sous-)fentre en X	SWAP.32		D3	ADD.16		{A0}+ODFWBY,D3			; D3 <-- dans (sous-)fentre en Y	SWAP.32		D3	JUMP		R8^L12$L10$:	MUL.16		D1,D5				; D5 <-- Iy bitmapL12$:	MOVE.32		D3,D0	SWAP.32		D0	MUL.16		D5,D0	ADD.32		D0,A3	MOVE.16		D3,D0	SR.16		#3,D0	MUL.16		D1,D0	ADD.A16		D0,A3				; A3 <-- ^byte source	MOVE.32		A4,D0				; destination dans l'cran ?	JUMP,NE		R8^L20$				; non => 20$							; oui =>	MOVE.32		{A0}+ODFABS,A4			; A4 <-- adresse dbut cran	MOVE.16		{A0}+ODFIIY,D6			; D6 <-- Iy cran	ADD.16		{A0}+ODFWBX,D4			; D4 <-- dans (sous-)fentre en X; fait le cliping de ce qui dborde l'cranadd.16		d2, d4comp.16		{A0}+ODFWEX, d4jump,ls		r8^bdx$sub.16		{A0}+ODFWEX, d4			; ce qui depassesub.16		d4, d2				; diminue la taille en consquencemove.16		{a0}+ODFWEX, d4			; limite la bornebdx$:sub.16		d2, d4				; reprend ^origineswap.32		d2	SWAP.32		D4	ADD.16		{A0}+ODFWBY,D4			; D4 <-- dans (sous-)fentre en Yadd.16		d2, d4comp.16		{A0}+ODFWEY, d4jump,ls		r8^bdy$sub.16		{A0}+ODFWEY, d4			; ce qui depassesub.16		d4, d2				; diminue la taille en consquencemove.16		{a0}+ODFWEY, d4			; limite la bornebdy$:sub.16		d2, d4				; reprend ^origineswap.32		d2	SWAP.32		D4	JUMP		R8^L22$L20$:	MUL.16		D1,D6				; D6 <-- Iy bitmapL22$:	MOVE.32		D4,D0	SWAP.32		D0	MUL.16		D6,D0	ADD.32		D0,A4	MOVE.16		D4,D0	SR.16		#3,D0	MUL.16		D1,D0	ADD.A16		D0,A4				; A4 <-- ^byte destination	MOVE.32		#{A6}+OMATPR,A2	MOVE.16		#32-1,D0	TEST.8		{A0}+ODFCMD			; cran couleur ?	JUMP,NE		R8^L40$L30$:	CLR.32		{A2+}	DJ.16,NMO	D0,L30$	JUMP		R8^L80$L40$:	CLR.32		{A2+}	CLR.32		{A2+}	CLR.32		{A2+}	CLR.32		{A2+}	DJ.16,NMO	D0,L40$L80$:	MOVE.32		#{A6}+OMATPR,A2			; A2 <-- ^matrice videret$:	POPM.32		D0|D1|D3|D4	comp.32		#16'10000, d1			; incrment de 1 au moins	jump,hs		r8^r$	add.32		#16'10000, d1			; le forcer$:	test.16		d7	RET;--------\; A6VARS  >;========/; donne le ^variables du module; in	A0.32		"canal" de FONDU_OPEN; out	A6.32		^variables du module;	A0.32		^descripteur fentreA6Vars:	move.16		#ErILCH, D7			; mauvais no canal ?	comp.32		{a0}+oCHK, a0	jump,ne		ret$	move.32		A0, A6				; ^variables du module	move.32		{A6}+oStatusEcran, A0		; ^descripteur de la fentre	clr.16		d7ret$:	RetPROGRESS1w:	push.16		d4	call		r8^PROGRESS1			; progresse un petit peu	move.16		d1, d4	jump,eq		r8^r$	Ntrel		?DelMs				; et attend selon d1.16r$:	pop.16		d4	ret;----------\\; PROGRESS1 >;----------/; Transfert une matrice source dans une matrice destination; en mode LOAD, mais seulement les points allums dans la; matrice de transfert de 32x32 points.; in	A3.32	^mmoire source;	D5.16	Iy source;	A4.32	^mmoire destination;	D6.16	Iy destination;	D2.32	hauteur/largeur (y;x);	A2.32	^matrice de transfert (32x32); out	-; mod	D7.16PROGRESS1:	PUSHM.32	D0..D4|A1..A4	TEST.8		{A0}+ODFCMD			; cran couleur ?	JUMP,NE		COLOR$	MOVE.32		D2,D0	SR.16		#5,D0				; D0 <-- largeur /32 car par .32	DEC.16		D0				; D0 <-- largeur -1 car NMO	MOVE.32		#{A2}+32*4,A1			; A1 <-- ^fin matriceBLOOPY$:	COMP.32		A1,A2				; est-on  la fin de la matrice ?	JUMP,NE		R8^BMAT$			; non => BMAT$	MOVE.32		#{A1}-32*4,A2			; A2 <-- ^dbut de la matriceBMAT$:	MOVE.32		{A2+},D2			; D2 <-- masque	JUMP,EQ		R8^BNEXTY$	MOVE.32		D2,D1	NOT.32		D1				; D1 <-- masque invers	PUSHM.32	D0|A3|A4BLOOPX$:	MOVE.32		{A3+},D3			; D3 <-- source	AND.32		D2,D3	MOVE.32		{A4},D4				; D4 <-- destination	AND.32		D1,D4	OR.32		D3,D4	MOVE.32		D4,{A4+}	DJ.16,NMO	D0,BLOOPX$	POPM.32		D0|A3|A4BNEXTY$:	ADD.A16		D5,A3				; A3 <-- ^ligne suivante	ADD.A16		D6,A4				; A4 <-- ^ligne suivante	SWAP.32		D0	DEC.16		D0	MOVE.16		D0,D1	SWAP.32		D0	TEST.16		D1	JUMP,NE		BLOOPY$	JUMP		EXIT$COLOR$:	MOVE.32		D2,D0	SR.16		#5,D0				; D0 <-- largeur /32 car par .32	DEC.16		D0				; D0 <-- largeur -1 car NMO	MOVE.32		#{A2}+32*4*4,A1			; A1 <-- ^fin matriceCLOOPY$:	COMP.32		A1,A2				; est-on  la fin de la matrice ?	JUMP,NE		R8^CMAT$			; non => CMAT$	MOVE.32		#{A1}-32*4*4,A2			; A2 <-- ^dbut de la matriceCMAT$:	PUSHM.32	A3|A4	MOVE.16		#4-1,D7CLOOPM$:	MOVE.32		{A2+},D2			; D2 <-- masque	JUMP,EQ		R8^CNEXTM$	MOVE.32		D2,D1	NOT.32		D1				; D1 <-- masque invers	PUSHM.32	D0|D7|A3|A4	MOVE.16		#4*4,D7CLOOPX$:	MOVE.32		{A3},D3				; D3 <-- source	AND.32		D2,D3	MOVE.32		{A4},D4				; D4 <-- destination	AND.32		D1,D4	OR.32		D3,D4	MOVE.32		D4,{A4}	ADD.A16		D7,A3	ADD.A16		D7,A4	DJ.16,NMO	D0,CLOOPX$	POPM.32		D0|D7|A3|A4CNEXTM$:	ADD.32		#4,A3	ADD.32		#4,A4	DJ.16,NMO	D7,CLOOPM$	POPM.32		A3|A4	ADD.A16		D5,A3				; A3 <-- ^ligne suivante	ADD.A16		D6,A4				; A4 <-- ^ligne suivante	SWAP.32		D0	DEC.16		D0	MOVE.16		D0,D1	SWAP.32		D0	TEST.16		D1	JUMP,NE		CLOOPY$EXIT$:	POPM.32		D0..D4|A1..A4	RET;----------\\; OPEDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	-; out	-; mod	D7.16OPEDISMAT:	MOVE.32		{A0}+ODFABS,{A6}+oSavDfABS	MOVE.16		{A0}+ODFIIX,{A6}+oSavDfIIX	MOVE.16		{A0}+ODFIIY,{A6}+oSavDfIIY	MOVE.32		{A0}+ODFY,{A6}+oSavDfY	MOVE.32		{A0}+ODFDY,{A6}+oSavDfDY	MOVE.32		{A0}+ODFFY,{A6}+oSavDfFY	MOVE.32		{A0}+ODFFDY,{A6}+oSavDfFDY	MOVE.32		{A0}+ODFWBY,{A6}+oSavDfWBY	MOVE.32		{A0}+ODFWEY,{A6}+oSavDfWEY	MOVE.8		{A0}+ODFCMD,{A6}+oSavDfCMD	RET;----------\\; NEWDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	A4.32	^matrice o dessiner;	D4.32	^dimensions (dy;dx); out	-; mod	D7.16NEWDISMAT:	PUSH.32		D4	MOVE.32		A4,{A0}+ODFABS	CLR.32		{A0}+ODFY	MOVE.32		D4,{A0}+ODFDY	CLR.32		{A0}+ODFFY	MOVE.32		D4,{A0}+ODFFDY	CLR.32		{A0}+ODFWBY	MOVE.32		D4,{A0}+ODFWEY	MOVE.16		#1,{A0}+ODFIIX	SR.16		#3,D4	MOVE.16		D4,{A0}+ODFIIY	POP.32		D4	RET;----------\\; CLODISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.16CLODISMAT:	MOVE.32		{A6}+oSavDfABS,{A0}+ODFABS	MOVE.16		{A6}+oSavDfIIX,{A0}+ODFIIX	MOVE.16		{A6}+oSavDfIIY,{A0}+ODFIIY	MOVE.32		{A6}+oSavDfY,{A0}+ODFY	MOVE.32		{A6}+oSavDfDY,{A0}+ODFDY	MOVE.32		{A6}+oSavDfFY,{A0}+ODFFY	MOVE.32		{A6}+oSavDfFDY,{A0}+ODFFDY	MOVE.32		{A6}+oSavDfWBY,{A0}+ODFWBY	MOVE.32		{A6}+oSavDfWEY,{A0}+ODFWEY	MOVE.8		{A6}+oSavDfCMD,{A0}+ODFCMD	RET;--------\; DRRECT  >;========/; dessine un rectangle dans l' (pseudo) cran;; in	D2.16		mode d'affichage;	D3.32		[y,x] origine;	D4.32		[dy,dx] dimension;	A0.32		^descripteur de la fentre; out	-; mod	D7.16DRRECT:	pushm.32	D1..D4|A0|A2	move.16		D2, D1			; mode de dessin pour GRA_	move.32		A0, A2			; ^cran pour GRA_	move.32		{A6}+oAdGraLine, A0	ex.32		D3, D4			; origine -> D4 pour GRA_	move.32		D3, D2			; conserve dimensions	clr.16		D3			; dy seul	call		{A0}			; GRA_LINE	add.32		D3, D4			; origine + dy	clr.32		D3	move.16		D2, D3			; dx seul	call		{A0}			; GRA_LINE	add.16		D3, D4			; origine + dy + dx	move.32		D2, D3	clr.16		D3			; dy seul	neg.32		D3	call		{A0}			; GRA_LINE	add.32		D3, D4	clr.32		D3	move.16		D2, D3			; dx seul	neg.16		D3	call		{A0}			; GRA_LINE	popm.32		D1..D4|A0|A2	ret	FONDU_END:	.END