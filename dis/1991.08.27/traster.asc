	.TITLE	TRASTER	.PROC	M680002	.REF	SM8	.REF	LIB	.REF	DRIVERS	.REF	FOS	.REF	GESMEM	.LOC	0OBUDIS:	.BLKB	100LGVAR:	.LOC	0START:;	LIB	?OPELIB	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LOAD.W	D3,#H'8000	LOAD.W	D4,#H'0000	LOAD.W	D5,#H'8000	LIB	?COLORCA	LOAD.W	D3,#H'FFFF	LOAD.W	D4,#H'FFFF	LOAD.W	D5,#H'FFFF	LIB	?COLORSA	LIB	?AFTIM	.B	EOP	.B	NOCURS	.B	0	.EVEN	LOAD.L	D0,#H'10000*10+10	LOAD.L	D1,#H'0000	LOAD.W	D6,#400/515$:	LOAD.W	D3,#H'0000	LOAD.W	D4,#H'0000	LOAD.W	D5,D1	LIB	?COLORSA	LOAD.L	D3,D0	LOAD.L	D4,#500	LOAD.W	D2,#SETDOT	LIB	?DRSEG	ADD.L	D0,#H'10000*5	ADD.W	D1,#H'4000	DEC.W	D6	JUMP,NE 15$	LOAD.W	D3,#H'FFFF	LOAD.W	D4,#H'0000	LOAD.W	D5,#H'0000	LIB	?COLORSA	LOAD.W	D3,#H'0000	LOAD.W	D4,#H'FFFF	LOAD.W	D5,#H'0000	LIB	?COLORCA	LOAD.W	D2,#LOADDOT	LOAD.L	D3,#H'10000*10+100	LOAD.W	D4,#1620$:	CALL	RASTER	INC.W	D3	SWAP.W	D3	ADD.W	D3,#15	SWAP.W	D3	DEC.W	D4	JUMP,NE 20$	LOAD.W	D2,#SETDOT	LOAD.L	D3,#H'10000*10+150	LOAD.W	D4,#1630$:	CALL	RASTER	INC.W	D3	SWAP.W	D3	ADD.W	D3,#15	SWAP.W	D3	DEC.W	D4	JUMP,NE 30$	LOAD.W	D2,#CLRDOT	LOAD.L	D3,#H'10000*10+200	LOAD.W	D4,#1640$:	CALL	RASTER	INC.W	D3	SWAP.W	D3	ADD.W	D3,#15	SWAP.W	D3	DEC.W	D4	JUMP,NE 40$	LOAD.W	D2,#INVDOT	LOAD.L	D3,#H'10000*10+250	LOAD.W	D4,#1650$:	CALL	RASTER	INC.W	D3	SWAP.W	D3	ADD.W	D3,#15	SWAP.W	D3	DEC.W	D4	JUMP,NE 50$	LOAD.W	D0,#2060$:	LOAD.W	D2,#INVDOT	LOAD.L	D3,#H'10000*10+300	LOAD.W	D4,#1665$:	CALL	RASTER	INC.W	D3	SWAP.W	D3	ADD.W	D3,#15	SWAP.W	D3	DEC.W	D4	JUMP,NE 65$	DEC.W	D0	JUMP,NE 60$ERFAT1:;	LIB	?CLOLIB;	FOS	?STOP	EXITRASTER:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.W	(A3)+1,#1	LOAD.W	(A3)+3,#0	LOAD.L	A4,#R16"MOTIF	LOAD.L	(A3)+5,A4	LOAD.W	(A3)+9,#2	LOAD.W	(A3)+11,D3	SWAP.W	D3	LOAD.W	(A3)+13,D3	LOAD.L	(A3)+15,#0	LOAD.W	(A3)+19,#0	LOAD.W	(A3)+21,#13	LOAD.W	(A3)+23,#13	LOAD.B	(A3)+25,D2	LOAD.W	D3,#26	LIB	?STRING	POPM.L	D3,D4,A3,A4	RETMOTIF:	.W	B'0111111111111100	.W	B'0110000000001100	.W	B'0101000000010100	.W	B'0100100000100100	.W	B'0100010001000100	.W	B'0100001010000100	.W	B'0100000100000100	.W	B'0100001010000100	.W	B'0100010001000100	.W	B'0100100000100100	.W	B'0101000000010100	.W	B'0110000000001100	.W	B'0111111111111100	.END	START