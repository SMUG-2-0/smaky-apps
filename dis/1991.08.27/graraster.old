	.SBTTL	GRARASTER	.IF	COLOR;------------\; RASTERC_CLR >;============/; Efface (rempli de zro) la destination.; Seulement si la destination est en mmoire couleur !; in	A4.L	^mmoire destination;	D6.W	Iy destination;	A6.L	By destination;	D2.L	hauteur/largeur (dy;dx); out	-; mod	-RASTERC_CLR:	COMP.L	A6,#0	JUMP,EQ RASTER_CLR	PUSHM.L	D0,A4	LOAD.W	D0,#8-110$:	CALL	RASTER_CLR	; efface un plan couleur	ADD.L	A4,A6		; A4 <-- ^bitmap suivant	DECJ.W,NMO D0,10$	POPM.L	D0,A4	RET	.ENDIF;-----------\; RASTER_CLR >;===========/; Efface (rempli de zro) la destination.; Seulement si la destination est en mmoire !; in	A4.L	^mmoire destination;	D6.W	Iy destination;	D2.L	hauteur/largeur (dy;dx); out	-; mod	-RASTER_CLR:	PUSHM.L	D0,D1,D2,A3,A4	LOAD.W	D1,D2	ADD.W	D1,#7	SR.W	D1,#3		; D1 <-- largeur en bytes	DEC.W	D1		; D1 <--  cause du test NMO	SWAP.W	D2		; D2 <-- hauteur en points	DEC.W	D2		; D2 <--  cause du test NMO30$:	LOAD.L	A3,A4	LOAD.W	D0,D140$:	CLR.B	(A3+)		; efface une ligne	DECJ.W,NMO D0,40$	ADD.W	A4,D6		; A4 <-- ^ligne en dessous	DECJ.W,NMO D2,30$	POPM.L	D0,D1,D2,A3,A4	RET	.IF	COLOR;-----------\; RASTERC_MM >;===========/; Dplace une surface rectangulaire mmoire [couleur] --> mmoire couleur.; in	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source;	D5.W	Iy source;	A5.L	By source;	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination;	D6.W	Iy destination;	A6.L	By destination;	----;	D2.L	hauteur/largeur (dy;dx);	D1.W	opration (SETDOT/CLRDOT/INVDOT/LOADDOT); out	-; mod	-RASTERC_MM:	JUMP	_GRA_RASTERC	.ENDIF;----------\; RASTER_MM >;==========/; Dplace une surface rectangulaire mmoire --> mmoire.; in	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source;	D5.W	Iy source;	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination;	D6.W	Iy destination;	----;	D2.L	hauteur/largeur (dy;dx);	D1.W	opration (SETDOT/CLRDOT/INVDOT/LOADDOT); out	-; mod	-RASTER_MM:	JUMP	_GRA_RASTERM	.IF	COLOR;-----------\; RASTERC_MD >;===========/; Dplace une surface rectangulaire mmoire couleur --> cran.; in	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source;	D5.W	Iy source;	A5.L	By source;	----;	D4.L	coordonne destination (y;x);	----;	D2.L	hauteur/largeur (dy;dx);	D1.W	opration (SETDOT/CLRDOT/INVDOT/LOADDOT); out	-; mod	-RASTERC_MD:	PUSH.L	A4	LOAD.L	A4,#0	CALL	_GRA_RASTERC	POP.L	A4	RET	.ENDIF;----------\; RASTER_MD >;==========/; Dplace une surface rectangulaire mmoire --> cran.; in	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source;	D5.W	Iy source;	----;	D4.L	coordonne destination (y;x);	----;	D2.L	hauteur/largeur (dy;dx);	D1.W	opration (SETDOT/CLRDOT/INVDOT/LOADDOT); out	-; mod	-RASTER_MD:	PUSH.L	A4	LOAD.L	A4,#0	CALL	_GRA_RASTERM	POP.L	A4	RET	.IF	COLOR;-----------\; RASTERC_DM >;===========/; Dplace une surface rectangulaire cran --> mmoire couleur.; in	----;	D3.L	coordonne source (y;x);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination;	D6.W	Iy destination;	A6.L	By destination;	----;	D2.L	hauteur/largeur (dy;dx);	D1.W	opration (SETDOT/CLRDOT/INVDOT/LOADDOT); out	-; mod	-RASTERC_DM:	PUSH.L	A3	LOAD.L	A3,#0	CALL	_GRA_RASTERC	POP.L	A3	RET	.ENDIF;----------\; RASTER_DM >;==========/; Dplace une surface rectangulaire cran --> mmoire.; in	----;	D3.L	coordonne source (y;x);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination;	D6.W	Iy destination;	----;	D2.L	hauteur/largeur (dy;dx);	D1.W	opration (SETDOT/CLRDOT/INVDOT/LOADDOT); out	-; mod	-RASTER_DM:	PUSH.L	A3	LOAD.L	A3,#0	CALL	_GRA_RASTERM	POP.L	A3	RET;------------\; _GRA_RASTER >;============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A2.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	D1.B	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT); out	-; mod	-_GRA_RASTER:	PUSH.W	D1	AND.W	D1,#H'00FF	; D1 <-- normal et plein	CALL	_GRA_RASTERM	POP.W	D1	RET	.IF	COLOR;-------------\; _GRA_RASTERC >;=============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A2.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	A5.L	By source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	A6.L	By destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	D1.W	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT);		 si 2^8  = 1	-->	inverse (pour AFINV);		 si 2^9  = 1	-->	grise   (pour AFGREY); out	-; mod	-_GRA_RASTERC:	PUSHM.L	D0,D1,D7,A3,A4	LOAD.L	D0,A3		; source dans l'cran ?	JUMP',EQ 10$		; oui => 10$	LOAD.L	D0,A5		; source multiple ?	JUMP',NE 15$		; oui => 15$10$:	LOAD.L	D0,A4		; destination dans l'cran ?	JUMP',EQ 12$		; oui => 12$	LOAD.L	D0,A6		; destination multiple ?	JUMP',NE 15$		; oui => 15$12$:	CALL	_GRA_RASTERM	; c'est tout bte !	JUMP	90$15$:	LOAD.L	D0,A3		; source dans l'cran ?	JUMP,EQ 50$		; oui => 50$	LOAD.L	D0,A4		; destination dans l'cran ?	JUMP,EQ 50$		; oui => 50$	LOAD.L	D0,A5		; source multiple ?	JUMP,NE 50$		; oui => 50$	LOAD.W	D0,(A2)+ODFCSF+2 ; D0 <-- couleur pour dessiner	COMP.B	D1,#SETDOT	JUMP,EQ 20$	LOAD.W	D0,(A2)+ODFCCF+2 ; D0 <-- couleur pour effacer	COMP.B	D1,#CLRDOT	JUMP,EQ 20$	LOAD.W	D7,(A2)+ODFCSF+2	XOR.W	D0,D7		; D0 <-- couleur pour inverser	COMP.B	D1,#INVDOT	JUMP,EQ 30$	JUMP	40$; Source:	bitmap unique en mmoire; Destination:	bitmaps en mmoire; Mode:		SETDOT ou CLRDOT20$:	SWAP.W	D0		; D0 <-- couleur	LOAD.W	D0,#8-122$:	LOAD.W	D1,#CLRDOT!2^10	TEST.L	D0:#16+0	JUMP',BC 24$	LOAD.W	D1,#SETDOT!2^1024$:	CALL	_GRA_RASTERM	; travail dans un plan	ADD.L	A4,A6		; A4 <-- ^bitmap suivant	SWAP.W	D0	RR.W	D0,#1		; D0 <-- couleur suivante	SWAP.W	D0	DECJ.W,NMO D0,22$	JUMP	90$; Source:	bitmap unique en mmoire; Destination:	bitmaps en mmoire; Mode:		INVDOT30$:	SWAP.W	D0		; D0 <-- couleur	LOAD.W	D0,#8-132$:	TEST.L	D0:#16+0	JUMP',BC 34$	LOAD.W	D1,#INVDOT!2^10	CALL	_GRA_RASTERM	; travail dans un plan34$:	ADD.L	A4,A6		; A4 <-- ^bitmap suivant	SWAP.W	D0	RR.W	D0,#1		; D0 <-- couleur suivante	SWAP.W	D0	DECJ.W,NMO D0,32$	JUMP	90$; Source:	bitmap unique en mmoire; Destination:	bitmaps en mmoire; Mode:		LOADDOT40$:;	 faire ...	JUMP	90$; Source et/ou destination dans l'cran.50$:	PUSHM.L	D0..D4	LOAD.W	D0,#MVDCLOAD	CLR.L	D2	CLR.L	D3	LOAD.W	D4,#-1	CALL	MODVDCC		; init le mode logique	POPM.L	D0..D4	SUB.L	(A2)+ODFABS,#LGBITS*8	LOAD.W	D0,#8-152$:	TSET.L	D1:#10	CALL	_GRA_RASTERM	; travail dans un plan	COMP.L	A3,#0	JUMP',EQ 54$	ADD.L	A3,A5		; A3 <-- ^bitmap suivant54$:	COMP.L	A4,#0	JUMP',EQ 55$	ADD.L	A4,A6		; A4 <-- ^bitmap suivant55$:	ADD.L	(A2)+ODFABS,#LGBITS	DECJ.W,NMO D0,52$90$:	POPM.L	D0,D1,D7,A3,A4	RET	.ENDIF;-------------\; _GRA_RASTERM >;=============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A2.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	D1.B	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT);		 si 2^8  = 1	-->	inverse (pour AFINV);		 si 2^9  = 1	-->	grise   (pour AFGREY);		 si 2^10 = 1	-->	pas de mode logique; out	-; mod	-_GRA_RASTERM:	PUSHM.L	D0..D7,A0..A6	LOAD.L	D0,A3		; source dans l'cran ?	JUMP',NE 10$		; non => 10$				; oui =>	LOAD.L	A3,(A2)+ODFABS	; A3 <-- adresse dbut cran	LOAD.W	D5,(A2)+ODFIIY	; D5 <-- Iy cran	ADD.W	D3,(A2)+ODFWBX	; D3 <-- dans (sous-)fentre en X	SWAP.W	D3	ADD.W	D3,(A2)+ODFWBY	; D3 <-- dans (sous-)fentre en Y	SWAP.W	D310$:	LOAD.L	D0,D3	SWAP.W	D0	MUL.WU	D0,D5	ADD.L	A3,D0	LOAD.W	D0,D3	SR.W	D0,#3	ADD.W	A3,D0		; A3 <-- ^byte source	AND.W	D3,#H'0007	; D3 <-- Ds	LOAD.W	A5,D5		; A5 <-- Iy source	.IF	COLOR	LOAD.L	D0,A4		; destination dans l'cran ?	JUMP',EQ 12$		; oui => 12$	TSET.L	D1:#10		; D1 <-- pas de mode logique !12$:	.ENDIF	LOAD.L	D0,A4		; destination dans l'cran ?	JUMP',NE 15$		; non => 15$				; oui =>	LOAD.L	A4,(A2)+ODFABS	; A4 <-- adresse dbut cran	LOAD.W	D6,(A2)+ODFIIY	; D6 <-- Iy cran	ADD.W	D4,(A2)+ODFWBX	; D4 <-- dans (sous-)fentre en X	SWAP.W	D4	SWAP.W	D2	ADD.W	D2,D4	COMP.W	D2,(A2)+ODFDY	; dpasse la fentre en bas ?	JUMP',LS 14$		; non => 14$	LOAD.W	D2,(A2)+ODFDY	; oui => limite la hauteur !14$:	SUB.W	D2,D4	ADD.W	D4,(A2)+ODFWBY	; D4 <-- dans (sous-)fentre en Y	SWAP.W	D4	SWAP.W	D215$:	LOAD.L	D0,D4	SWAP.W	D0	MUL.WU	D0,D6	ADD.L	A4,D0	LOAD.W	D0,D4	SR.W	D0,#3	ADD.W	A4,D0		; A4 <-- ^byte destination	AND.W	D4,#H'0007	; D4 <-- Dd	LOAD.W	A6,D6		; A6 <-- Iy destination	LOAD.L	A1,#R16"TARASTER_MASK	LOAD.W	D6,#B'1111111111111111 ; D6 <-- plein	TEST.L	D1:#9	JUMP',BC 20$	LOAD.W	D6,#B'1010101010101010 ; D6 <-- gris20$:	SWAP.W	D6	CLR.W	D6		; D6 <-- vido normale	TEST.L	D1:#8	JUMP',BC 22$	NOT.W	D6		; D6 <-- vido inverse22$:	.IF	COLOR	TEST.L	D1:#10	JUMP',BS 30$	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP',EQ 30$		; non => 30$	LOAD.L	D0,(A2)+ODFABS	COMP.L	D0,(A2)+ODFCAB	; est-on dans l'cran couleur ?	JUMP,EQ RASTER_COLOR	; oui => RASTER_COLOR30$:	.ENDIF	COMP.B	D1,#LOADDOT	JUMP',EQ RASTER_LOAD	COMP.B	D1,#SETDOT	JUMP,EQ RASTER_SET	COMP.B	D1,#CLRDOT	JUMP,EQ RASTER_CLEAR	JUMP	RASTER_INV;------------\; RASTER_LOAD >;============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A1.L	^table des masques;	----;	A3.L	^byte source;	D3.W	Ds;	A5.L	Iy source;	----;	A4.L	^byte destination;	D4.W	Dd;	A6.L	Iy destination;	----;	D2.L	hauteur/largeur (y;x);	D6.L	gris/inversion; out	-; mod	-RASTER_LOAD:	SWAP.W	D6	LOAD.W	D7,D6		; D7 <-- gris	SWAP.W	D7	LOAD.W	D7,D6		; D7 <-- gris	COMP.W	D7,#-1	JUMP',EQ 10$	NOT.W	D7		; D7 <-- gris complmentaire	SWAP.W	D710$:	SWAP.W	D6		; D6 <-- inversion (0/-1)20$:	PUSHM.L	D2,D3,D4,A3,A4; Si l'adresse n'est pas paire, recule d'un byte.	LOAD.W	D0,A3	RR.W	D0,#1	JUMP',CC 30$	DEC.L	A3		; A3 <-- adresse paire	ADD.W	D3,#8		; D3 <-- Ds30$:	LOAD.W	D0,A4	RR.W	D0,#1	JUMP',CC 32$	DEC.L	A4		; A4 <-- adresse paire	ADD.W	D4,#8		; D4 <-- Dd32$:; Effectue le travail de dbut.	LOAD.W	D0,D3	OR.W	D0,D4	JUMP',NE 40$	COMP.W	D2,#16	JUMP,LO 70$	JUMP	50$40$:	LOAD.W	D0,D4	SL.W	D0,#1	LOAD.W	D5,(A1)+(D0.W)	; D5 <-- masque	LOAD.W	D1,D4	SUB.W	D4,D3		; D4 <-- Dm	JUMP',HS 44$	ADD.W	D4,#16		; D4 <-- Dm	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	SWAP.W	D044$:	ADD.W	D2,D1	SUB.W	D2,#16		; D2 <-- largeur restante	JUMP,LO 72$	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.L	D1,D0	RR.L	D1,D4	AND.W	D1,D5	NOT.W	D5	LOAD.W	D3,(A4)	AND.W	D3,D5	OR.W	D1,D3	LOAD.W	(A4+),D1	; destination <-- dbut	SWAP.W	D0; Effectue le travail du milieu.50$:	LOAD.W	D3,D2	SR.W	D3,#4		; D3 <-- nb de words	JUMP',EQ 60$	DEC.W	D3		; D3 <-- -1  cause NMO52$:	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.L	D1,D0	RR.L	D1,D4	LOAD.W	(A4+),D1	; destination <-- milieu	SWAP.W	D0	DECJ.W,NMO D3,52$; Effectue le travail de fin.60$:	AND.W	D2,#H'000F	JUMP,EQ 80$	SL.W	D2,#1	LOAD.W	D5,(A1)+(D2.W)	; D5 <-- masque	LOAD.W	D0,(A3)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	RR.L	D0,D4	LOAD.W	D1,(A4)	AND.W	D1,D5	NOT.W	D5	AND.W	D0,D5	OR.W	D0,D1	LOAD.W	(A4),D0		; destination <-- fin	JUMP'	80$; Effectue le travail de dbut/fin.70$:	SUB.W	D2,#16	LOAD.W	D5,#H'FFFF72$:	ADD.W	D2,#16	SL.W	D2,#1	LOAD.W	D1,(A1)+(D2.W)	; D1 <-- masque	NOT.W	D1	AND.W	D5,D1		; D5 <-- masque le masque !	LOAD.W	D0,(A3)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	RR.L	D0,D4	AND.W	D0,D5	NOT.W	D5	LOAD.W	D3,(A4)	AND.W	D3,D5	OR.W	D0,D3	LOAD.W	(A4),D0		; destination <-- dbut/fin;	JUMP	80$80$:	POPM.L	D2,D3,D4,A3,A4	ADD.L	A3,A5		; A3 <-- ajoute Iy source	ADD.L	A4,A6		; A4 <-- ajoute Iy destination	SWAP.W	D7		; D7 <-- "gris" suivant	SUB.L	D2,#H'10000	LOAD.L	D1,D2	SWAP.W	D1	TEST.W	D1	JUMP,NE 20$	POPM.L	D0..D7,A0..A6	RET;------------\; RASTER_SET  >;============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A1.L	^table des masques;	----;	A3.L	^byte source;	D3.W	Ds;	A5.L	Iy source;	----;	A4.L	^byte destination;	D4.W	Dd;	A6.L	Iy destination;	----;	D2.L	hauteur/largeur (y;x);	D6.L	gris/inversion; out	-; mod	-RASTER_SET:	SWAP.W	D6	LOAD.W	D7,D6		; D7 <-- gris	SWAP.W	D7	LOAD.W	D7,D6		; D7 <-- gris	COMP.W	D7,#-1	JUMP',EQ 10$	NOT.W	D7		; D7 <-- gris complmentaire	SWAP.W	D710$:	SWAP.W	D6		; D6 <-- inversion (0/-1)20$:	PUSHM.L	D2,D3,D4,A3,A4; Si l'adresse n'est pas paire, recule d'un byte.	LOAD.W	D0,A3	RR.W	D0,#1	JUMP',CC 30$	DEC.L	A3		; A3 <-- adresse paire	ADD.W	D3,#8		; D3 <-- Ds30$:	LOAD.W	D0,A4	RR.W	D0,#1	JUMP',CC 32$	DEC.L	A4		; A4 <-- adresse paire	ADD.W	D4,#8		; D4 <-- Dd32$:; Effectue le travail de dbut.	LOAD.W	D0,D3	OR.W	D0,D4	JUMP',NE 40$	COMP.W	D2,#16	JUMP,LO 70$	JUMP	50$40$:	LOAD.W	D0,D4	SL.W	D0,#1	LOAD.W	D5,(A1)+(D0.W)	; D5 <-- masque	LOAD.W	D1,D4	SUB.W	D4,D3		; D4 <-- Dm	JUMP',HS 44$	ADD.W	D4,#16		; D4 <-- Dm	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	SWAP.W	D044$:	ADD.W	D2,D1	SUB.W	D2,#16		; D2 <-- largeur restante	JUMP,LO 72$	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.L	D1,D0	RR.L	D1,D4	AND.W	D1,D5	OR.W	(A4+),D1	; destination <-- dbut	SWAP.W	D0; Effectue le travail du milieu.50$:	LOAD.W	D3,D2	SR.W	D3,#4		; D3 <-- nb de words	JUMP',EQ 60$	DEC.W	D3		; D3 <-- -1  cause NMO52$:	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.L	D1,D0	RR.L	D1,D4	OR.W	(A4+),D1	; destination <-- milieu	SWAP.W	D0	DECJ.W,NMO D3,52$; Effectue le travail de fin.60$:	AND.W	D2,#H'000F	JUMP,EQ 80$	SL.W	D2,#1	LOAD.W	D5,(A1)+(D2.W)	; D5 <-- masque	LOAD.W	D0,(A3)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	RR.L	D0,D4	NOT.W	D5	AND.W	D0,D5	OR.W	(A4),D0		; destination <-- fin	JUMP'	80$; Effectue le travail de dbut/fin.70$:	SUB.W	D2,#16	LOAD.W	D5,#H'FFFF72$:	ADD.W	D2,#16	SL.W	D2,#1	LOAD.W	D1,(A1)+(D2.W)	; D1 <-- masque	NOT.W	D1	AND.W	D5,D1		; D5 <-- masque le masque !	LOAD.W	D0,(A3)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	RR.L	D0,D4	AND.W	D0,D5	OR.W	(A4),D0		; destination <-- dbut/fin;	JUMP	80$80$:	POPM.L	D2,D3,D4,A3,A4	ADD.L	A3,A5		; A3 <-- ajoute Iy source	ADD.L	A4,A6		; A4 <-- ajoute Iy destination	SWAP.W	D7		; D7 <-- "gris" suivant	SUB.L	D2,#H'10000	LOAD.L	D1,D2	SWAP.W	D1	TEST.W	D1	JUMP,NE 20$	POPM.L	D0..D7,A0..A6	RET;------------\; RASTER_INV  >;============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A1.L	^table des masques;	----;	A3.L	^byte source;	D3.W	Ds;	A5.L	Iy source;	----;	A4.L	^byte destination;	D4.W	Dd;	A6.L	Iy destination;	----;	D2.L	hauteur/largeur (y;x);	D6.L	gris/inversion; out	-; mod	-RASTER_INV:	SWAP.W	D6	LOAD.W	D7,D6		; D7 <-- gris	SWAP.W	D7	LOAD.W	D7,D6		; D7 <-- gris	COMP.W	D7,#-1	JUMP',EQ 10$	NOT.W	D7		; D7 <-- gris complmentaire	SWAP.W	D710$:	SWAP.W	D6		; D6 <-- inversion (0/-1)20$:	PUSHM.L	D2,D3,D4,A3,A4; Si l'adresse n'est pas paire, recule d'un byte.	LOAD.W	D0,A3	RR.W	D0,#1	JUMP',CC 30$	DEC.L	A3		; A3 <-- adresse paire	ADD.W	D3,#8		; D3 <-- Ds30$:	LOAD.W	D0,A4	RR.W	D0,#1	JUMP',CC 32$	DEC.L	A4		; A4 <-- adresse paire	ADD.W	D4,#8		; D4 <-- Dd32$:; Effectue le travail de dbut.	LOAD.W	D0,D3	OR.W	D0,D4	JUMP',NE 40$	COMP.W	D2,#16	JUMP,LO 70$	JUMP	50$40$:	LOAD.W	D0,D4	SL.W	D0,#1	LOAD.W	D5,(A1)+(D0.W)	; D5 <-- masque	LOAD.W	D1,D4	SUB.W	D4,D3		; D4 <-- Dm	JUMP',HS 44$	ADD.W	D4,#16		; D4 <-- Dm	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	SWAP.W	D044$:	ADD.W	D2,D1	SUB.W	D2,#16		; D2 <-- largeur restante	JUMP,LO 72$	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.L	D1,D0	RR.L	D1,D4	AND.W	D1,D5	XOR.W	(A4+),D1	; destination <-- dbut	SWAP.W	D0; Effectue le travail du milieu.50$:	LOAD.W	D3,D2	SR.W	D3,#4		; D3 <-- nb de words	JUMP',EQ 60$	DEC.W	D3		; D3 <-- -1  cause NMO52$:	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.L	D1,D0	RR.L	D1,D4	XOR.W	(A4+),D1	; destination <-- milieu	SWAP.W	D0	DECJ.W,NMO D3,52$; Effectue le travail de fin.60$:	AND.W	D2,#H'000F	JUMP,EQ 80$	SL.W	D2,#1	LOAD.W	D5,(A1)+(D2.W)	; D5 <-- masque	LOAD.W	D0,(A3)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	RR.L	D0,D4	NOT.W	D5	AND.W	D0,D5	XOR.W	(A4),D0		; destination <-- fin	JUMP'	80$; Effectue le travail de dbut/fin.70$:	SUB.W	D2,#16	LOAD.W	D5,#H'FFFF72$:	ADD.W	D2,#16	SL.W	D2,#1	LOAD.W	D1,(A1)+(D2.W)	; D1 <-- masque	NOT.W	D1	AND.W	D5,D1		; D5 <-- masque le masque !	LOAD.W	D0,(A3)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	RR.L	D0,D4	AND.W	D0,D5	XOR.W	(A4),D0		; destination <-- dbut/fin;	JUMP	80$80$:	POPM.L	D2,D3,D4,A3,A4	ADD.L	A3,A5		; A3 <-- ajoute Iy source	ADD.L	A4,A6		; A4 <-- ajoute Iy destination	SWAP.W	D7		; D7 <-- "gris" suivant	SUB.L	D2,#H'10000	LOAD.L	D1,D2	SWAP.W	D1	TEST.W	D1	JUMP,NE 20$	POPM.L	D0..D7,A0..A6	RET;-------------\; RASTER_CLEAR >;=============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A1.L	^table des masques;	----;	A3.L	^byte source;	D3.W	Ds;	A5.L	Iy source;	----;	A4.L	^byte destination;	D4.W	Dd;	A6.L	Iy destination;	----;	D2.L	hauteur/largeur (y;x);	D6.L	gris/inversion; out	-; mod	-RASTER_CLEAR:	SWAP.W	D6	LOAD.W	D7,D6		; D7 <-- gris	SWAP.W	D7	LOAD.W	D7,D6		; D7 <-- gris	COMP.W	D7,#-1	JUMP',EQ 10$	NOT.W	D7		; D7 <-- gris complmentaire	SWAP.W	D710$:	SWAP.W	D6		; D6 <-- inversion (0/-1)20$:	PUSHM.L	D2,D3,D4,A3,A4; Si l'adresse n'est pas paire, recule d'un byte.	LOAD.W	D0,A3	RR.W	D0,#1	JUMP',CC 30$	DEC.L	A3		; A3 <-- adresse paire	ADD.W	D3,#8		; D3 <-- Ds30$:	LOAD.W	D0,A4	RR.W	D0,#1	JUMP',CC 32$	DEC.L	A4		; A4 <-- adresse paire	ADD.W	D4,#8		; D4 <-- Dd32$:; Effectue le travail de dbut.	LOAD.W	D0,D3	OR.W	D0,D4	JUMP',NE 40$	COMP.W	D2,#16	JUMP,LO 70$	JUMP	50$40$:	LOAD.W	D0,D4	SL.W	D0,#1	LOAD.W	D5,(A1)+(D0.W)	; D5 <-- masque	LOAD.W	D1,D4	SUB.W	D4,D3		; D4 <-- Dm	JUMP',HS 44$	ADD.W	D4,#16		; D4 <-- Dm	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	SWAP.W	D044$:	ADD.W	D2,D1	SUB.W	D2,#16		; D2 <-- largeur restante	JUMP,LO 72$	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.L	D1,D0	RR.L	D1,D4	AND.W	D1,D5	NOT.W	D1	AND.W	(A4+),D1	; destination <-- dbut	SWAP.W	D0; Effectue le travail du milieu.50$:	LOAD.W	D3,D2	SR.W	D3,#4		; D3 <-- nb de words	JUMP',EQ 60$	DEC.W	D3		; D3 <-- -1  cause NMO52$:	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.L	D1,D0	RR.L	D1,D4	NOT.W	D1	AND.W	(A4+),D1	; destination <-- milieu	SWAP.W	D0	DECJ.W,NMO D3,52$; Effectue le travail de fin.60$:	AND.W	D2,#H'000F	JUMP,EQ 80$	SL.W	D2,#1	LOAD.W	D5,(A1)+(D2.W)	; D5 <-- masque	LOAD.W	D0,(A3)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	RR.L	D0,D4	NOT.W	D5	AND.W	D0,D5	NOT.W	D0	AND.W	(A4),D0		; destination <-- fin	JUMP'	80$; Effectue le travail de dbut/fin.70$:	SUB.W	D2,#16	LOAD.W	D5,#H'FFFF72$:	ADD.W	D2,#16	SL.W	D2,#1	LOAD.W	D1,(A1)+(D2.W)	; D1 <-- masque	NOT.W	D1	AND.W	D5,D1		; D5 <-- masque le masque !	LOAD.W	D0,(A3)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	RR.L	D0,D4	AND.W	D0,D5	NOT.W	D0	AND.W	(A4),D0		; destination <-- dbut/fin;	JUMP	80$80$:	POPM.L	D2,D3,D4,A3,A4	ADD.L	A3,A5		; A3 <-- ajoute Iy source	ADD.L	A4,A6		; A4 <-- ajoute Iy destination	SWAP.W	D7		; D7 <-- "gris" suivant	SUB.L	D2,#H'10000	LOAD.L	D1,D2	SWAP.W	D1	TEST.W	D1	JUMP,NE 20$	POPM.L	D0..D7,A0..A6	RET	.IF	COLOR;-------------\; RASTER_COLOR >;=============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A1.L	^table des masques;	A2.L	^description fentre;	----;	A3.L	^byte source;	D3.W	Ds;	A5.L	Iy source;	----;	A4.L	^byte destination;	D4.W	Dd;	A6.L	Iy destination;	----;	D2.L	hauteur/largeur (y;x);	D1.B	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT);	D6.L	gris/inversion; out	-; mod	-RASTER_COLOR:	SWAP.W	D6	LOAD.W	D7,D6		; D7 <-- gris	SWAP.W	D7	LOAD.W	D7,D6		; D7 <-- gris	COMP.W	D7,#-1	JUMP',EQ 10$	NOT.W	D7		; D7 <-- gris complmentaire	SWAP.W	D710$:	SWAP.W	D6		; D6 <-- inversion (0/-1); Calcule le mode logique pour la couleur.	SUB.L	SP,#2*6		; SP <-- place pour paramtres	LOAD.L	A0,SP		; A0 <-- ^paramtres pour MODVDCCP	COMP.B	D1,#LOADDOT	JUMP',EQ 16$	COMP.B	D1,#CLRDOT	JUMP',EQ 14$	COMP.B	D1,#SETDOT	JUMP',EQ 12$				; INVDOT =>	LOAD.W	(A0)+0,#MVDCNOP	LOAD.W	(A0)+2,#MVDCXOR;	LOAD.W	(A0)+4,#;	LOAD.W	(A0)+6,#	CLR.W	(A0)+8	LOAD.W	(A0)+10,(A2)+ODFCCF+2	LOAD.W	D0,(A2)+ODFCSF+2	XOR.W	(A0)+10,D0	JUMP'	20$12$:				; SETDOT =>	LOAD.W	(A0)+0,#MVDCAND2	LOAD.W	(A0)+2,#MVDCOR1;	LOAD.W	(A0)+4,#;	LOAD.W	(A0)+6,#	CLR.W	(A0)+8	LOAD.W	(A0)+10,(A2)+ODFCSF+2	JUMP'	20$14$:				; CLRDOT =>	LOAD.W	(A0)+0,#MVDCAND2	LOAD.W	(A0)+2,#MVDCOR1;	LOAD.W	(A0)+4,#;	LOAD.W	(A0)+6,#	CLR.W	(A0)+8	LOAD.W	(A0)+10,(A2)+ODFCCF+2	JUMP'	20$16$:				; LOADDOT =>	LOAD.W	(A0)+0,#MVDCZERO	LOAD.W	(A0)+2,#MVDCLOAD	LOAD.W	(A0)+4,#MVDCNOT1	LOAD.W	(A0)+6,#MVDCONE	LOAD.W	(A0)+8,(A2)+ODFCCF+2	LOAD.W	(A0)+10,(A2)+ODFCSF+2;	JUMP'	20$20$:	PUSHM.L	D2,D3,D4,A3,A4; Si l'adresse n'est pas paire, recule d'un byte.	LOAD.W	D0,A3	RR.W	D0,#1	JUMP',CC 30$	DEC.L	A3		; A3 <-- adresse paire	ADD.W	D3,#8		; D3 <-- Ds30$:	LOAD.W	D0,A4	RR.W	D0,#1	JUMP',CC 32$	DEC.L	A4		; A4 <-- adresse paire	ADD.W	D4,#8		; D4 <-- Dd32$:; Effectue le travail de dbut.	LOAD.W	D0,D3	OR.W	D0,D4	JUMP',NE 40$	COMP.W	D2,#16	JUMP,LO 70$	JUMP	50$40$:	LOAD.W	D0,D4	SL.W	D0,#1	LOAD.W	D5,(A1)+(D0.W)	; D5 <-- masque	CALL	MODVDCCP	; init le mode logique selon (A0)	LOAD.W	D1,D4	SUB.W	D4,D3		; D4 <-- Dm	JUMP',HS 44$	ADD.W	D4,#16		; D4 <-- Dm	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	SWAP.W	D044$:	ADD.W	D2,D1	SUB.W	D2,#16		; D2 <-- largeur restante	JUMP,LO 72$	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.L	D1,D0	RR.L	D1,D4	LOAD.W	(A4+),D1	; destination <-- dbut	SWAP.W	D0; Effectue le travail du milieu.50$:	LOAD.W	D3,D2	SR.W	D3,#4		; D3 <-- nb de words	JUMP,EQ 60$	DEC.W	D3		; D3 <-- -1  cause NMO	LOAD.W	D5,#H'FFFF	CALL	MODVDCCP	; init le mode logique selon (A0)52$:	LOAD.W	D0,(A3+)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.L	D1,D0	RR.L	D1,D4	LOAD.W	(A4+),D1	; destination <-- milieu	SWAP.W	D0	DECJ.W,NMO D3,52$; Effectue le travail de fin.60$:	AND.W	D2,#H'000F	JUMP,EQ 80$	SL.W	D2,#1	LOAD.W	D5,(A1)+(D2.W)	; D5 <-- masque	NOT.W	D5	CALL	MODVDCCP	; init le mode logique selon (A0)	LOAD.W	D0,(A3)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	RR.L	D0,D4	LOAD.W	(A4),D0		; destination <-- fin	JUMP	80$; Effectue le travail de dbut/fin.70$:	SUB.W	D2,#16	LOAD.W	D5,#H'FFFF72$:	ADD.W	D2,#16	SL.W	D2,#1	LOAD.W	D1,(A1)+(D2.W)	; D1 <-- masque	NOT.W	D1	AND.W	D5,D1		; D5 <-- masque le masque !	CALL	MODVDCCP	; init le mode logique selon (A0)	LOAD.W	D0,(A3)	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	RR.L	D0,D4	LOAD.W	(A4),D0		; destination <-- dbut/fin;	JUMP	80$80$:	POPM.L	D2,D3,D4,A3,A4	ADD.L	A3,A5		; A3 <-- ajoute Iy source	ADD.L	A4,A6		; A4 <-- ajoute Iy destination	SWAP.W	D7		; D7 <-- "gris" suivant	SUB.L	D2,#H'10000	LOAD.L	D1,D2	SWAP.W	D1	TEST.W	D1	JUMP,NE 20$	ADD.L	SP,#2*6		; SP <-- ajuste	POPM.L	D0..D7,A0..A6	RET	.ENDIFTARASTER_MASK:	.W	B'1111111111111111	.W	B'0111111111111111	.W	B'0011111111111111	.W	B'0001111111111111	.W	B'0000111111111111	.W	B'0000011111111111	.W	B'0000001111111111	.W	B'0000000111111111	.W	B'0000000011111111	.W	B'0000000001111111	.W	B'0000000000111111	.W	B'0000000000011111	.W	B'0000000000001111	.W	B'0000000000000111	.W	B'0000000000000011	.W	B'0000000000000001	.EVEN	.END