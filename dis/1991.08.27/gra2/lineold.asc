	.TITLE	LINEOLD.ASC	.PROC	M680002	.REF	SMAKY	.LOC	0START:	LIB	?GETPDIS	LOAD.L	A2,A4	LOAD.L	D2,#H'10000*100		; x1	LOAD.L	D1,#H'10000*100		; y1	LOAD.L	D4,#H'10000*500		; x2	LOAD.L	D3,#H'10000*100		; y2	CALL	PUTLINE	LOAD.L	D2,#H'10000*100		; x1	LOAD.L	D1,#H'10000*100		; y1	LOAD.L	D4,#H'10000*500		; x2	LOAD.L	D3,#H'10000*200		; y2	CALL	PUTLINE	LOAD.L	D2,#H'10000*100		; x1	LOAD.L	D1,#H'10000*100		; y1	LOAD.L	D4,#H'10000*500		; x2	LOAD.L	D3,#H'10000*400		; y2	CALL	PUTLINE	LOAD.L	D2,#H'10000*100		; x1	LOAD.L	D1,#H'10000*100		; y1	LOAD.L	D4,#H'10000*500		; x2	LOAD.L	D3,#H'10000*600		; y2	CALL	PUTLINE	LOAD.L	D2,#H'10000*100		; x1	LOAD.L	D1,#H'10000*100		; y1	LOAD.L	D4,#H'10000*500		; x2	LOAD.L	D3,#H'10000*800		; y2	CALL	PUTLINE	LOAD.L	D2,#H'10000*100		; x1	LOAD.L	D1,#H'10000*100		; y1	LOAD.L	D4,#H'10000*200		; x2	LOAD.L	D3,#H'10000*800		; y2	CALL	PUTLINE	LOAD.L	D2,#H'10000*100		; x1	LOAD.L	D1,#H'10000*100		; y1	LOAD.L	D4,#H'10000*100		; x2	LOAD.L	D3,#H'10000*800		; y2	CALL	PUTLINE	EXIT;--------\\; PUTLINE >;========/; in	A2.L	^descripteur de la fentre;	D1.L	y1;	D2.L	x1;	D3.L	y2;	D4.L	x2; out	-; mod	D7.WPUTLINE:	PUSHM.L	D0..D7,A0,A1	SWAP.W	D1	SWAP.W	D3	COMP.W	D3,D1		; y1 = y2 ?	JUMP,NE	NOTSAMEY$	; non => NOTSAMEY$	SWAP.W	D2	SWAP.W	D4	PUSHM.L	D3,D4	LOAD.W	D3,D2	LOAD.W	D4,D1	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit	NOT.B	D0		; D0 <-- bit 7  gauche !	AND.W	D0,#B'111	; D0 <-- no du bit dans le byte	POPM.L	D3,D4	LOAD.W	D6,D1	LOAD.W	D5,D2	LOAD.W	D1,D4	CALL	PUTDOTS	JUMP	EXIT$NOTSAMEY$:	JUMP,GT	NOTSWAP$	; y2 > y1 ?	EX.L	D3,D1	EX.L	D4,D2		; sinon inverseNOTSWAP$:	SWAP.W	D1	SWAP.W	D3	PUSHM.L	D3,D4	LOAD.L	D3,D2	SWAP.W	D3	LOAD.L	D4,D1	SWAP.W	D4	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit	NOT.B	D0		; D0 <-- bit 7  gauche !	AND.W	D0,#B'111	; D0 <-- no du bit dans le byte	POPM.L	D3,D4	LOAD.L	D6,D1		; D6 <-- y1	PUSHM.L	D0..D2	SUB.L	D2,D4	NEG.L	D2		; D2 <-- x2-x1	SUB.L	D1,D3	NEG.L	D1		; D1 <-- y2-y1	CALL	FIXDIV		; D0 <-- D1/D2	LOAD.L	D7,D0		; D7 <-- pente en fractionnaire	POPM.L	D0..D2	PUSHM.L	D0,D2	LOAD.L	D2,D1	CLR.W	D1	ADD.L	D1,#H'10000	; D1 <-- roundup(y1)	SUB.L	D1,D2		; D1 <-- roundup(y1)-y1	LOAD.L	D2,D7		; D2 <-- pente	CALL	FIXMUL		; D0 <-- D1*D2	LOAD.L	D1,D0		; D1 <-- dbut de la ligne suivante (x1)	POPM.L	D0,D2	ADD.L	D1,D2		; D1 <-- x1 + fraction restant en-haut	SWAP.W	D2	LOAD.W	D5,D2		; D5 <-- x1	SWAP.W	D6	SWAP.W	D3	SWAP.W	D4	LOAD.W	A1,(A2)+ODFIIY	; A1 <-- IyNEXT$:	SWAP.W	D1	CALL	PUTDOTS	LOAD.W	D5,D1		; D5 <-- nouveau x1	SWAP.W	D1	ADD.W	A0,A1		; A0 <-- descend de 1 point	INC.W	D6		; D6 <-- descend de 1 point	ADD.L	D1,D7		; D1 <-- additionne le ratio	COMP.W	D6,D3		; y1 courant = y2 ?	JUMP,LT	NEXT$		; non => traite l'y1 suivant	COMP.W	D5,D4		; x1 courant = x2 ?	JUMP,EQ	EXIT$	LOAD.W	D1,D4	CALL	PUTDOTS		; met les derniers pointsEXIT$:LIB ?GETCAR	POPM.L	D0..D7,A0,A1	CLR.W	D7		; D7 <-- ok	RET;--------\\; PUTDOTS >;--------/; ; in	D5.W	x1;	D1.W	x2;	D6.W	y;	A0/D0	^byte/bit; out	A0/D0	^byte/bit; mod	D0.L, D5.L, A0.LPUTDOTS:	SUB.W	D5,D1	JUMP,GT LEFT$	JUMP,NE RIGHT$	TSET.B	(A0):D0	RETRIGHT$:	TSET.B	(A0):D0	DEC.B	D0		; x <-- x+1	JUMP',PL RSAME$	LOAD.L	D0,#7	INC.L	A0RSAME$:	INC.W	D5	JUMP,NE RIGHT$	RETLEFT$:	TSET.B	(A0):D0	INC.B	D0		; x <-- x-1	COMP.B	D0,#8	JUMP',LT LSAME$	CLR.B	D0	DEC.L	A0LSAME$:	DEC.W	D5	JUMP,NE LEFT$	RET;--------\; GETPBNB >;========/; Donne pointeur au byte concern dans l'cran, et le numro; du bit dans le byte.; Les coordonnes donnes sont absolues dans le bitmap.;---------\; GETPBNBW >;=========/; Idem, mais les coordonnes donnes sont relatives dans la (sous-)fentre.; in	A2.L	^description de la fentre;	D3.W	coordonne X (0..n);	D4.W	coordonne Y (0..n); out	A0.L	^byte dans le bitmap cran;	D0.W	numro du bit (0..7);	toujours CC; mod	D0.W, A0.LGETPBNB:	PUSHM.L	D3,D4	JUMP'	GETPBNB0GETPBNBW:	PUSHM.L	D3,D4	ADD.W	D3,(A2)+ODFWBX	; D3 <-- coordonne x absolue dans bitmap	ADD.W	D4,(A2)+ODFWBY	; D4 <-- coordonne y absolue dans bitmapGETPBNB0:	LOAD.B	D0,D3	AND.W	D0,#B'111	; D0 <-- no du bit dans le byte	LOAD.L	A0,(A2)+ODFABS	; A0 <-- adresse dbut cran	SR.W	D3,#3		; dcale coordonne X	ADD.W	A0,D3	MUL.WU	D4,(A2)+ODFIIY	; dcale coordonne Y	ADD.L	A0,D4		; A0 <-- adresse dans l'cran	POPM.L	D3,D4	CLRC			; retour CC (pour CLIPDOT !)	RET; Routines mathmatiques; ----------------------;-------\\; FIXMUL >;=======/; in	D1.L	nombre  virgule fixe no 1;	D2.L	nombre  virgule fixe no 2; out	D0.L	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.LFIXMUL:	PUSHM.L	D1,D2,D4,D5,D6	CALL	TOPOSITIF	LOAD.L	D4,#H'00010000	COMP.L	D1,D4		; D1 = 1.0 ?	JUMP,NE	D1DIFF0$	; non => D2 = 1.0 ?	LOAD.L	D1,D2	JUMP	MUL10$D1DIFF0$:	COMP.L	D2,D4		; D2 = 1.0 ?	JUMP,NE	DIFFZERO$MUL10$:	CLR.L	D0	CLR.L	D4	LOAD.W	D4,D1	SWAP.W	D4	SWAP.W	D1	LOAD.W	D0,D1		; (D0;D4) = rsultat	JUMP	LONGTOFIX$DIFFZERO$:	LOAD.W	D4,D2	MUL.WU	D4,D1		; D4 <-- D1.fract * D2.fract	SWAP.W	D2	LOAD.W	D5,D2	MUL.WU	D5,D1		; D5 <-- D1.fract * D2.int	SWAP.W	D1	LOAD.W	D0,D2	MUL.WU	D0,D1		; D0 <-- D1.int * D2.int	SWAP.W	D2	MUL.WU	D2,D1		; D2 <-- D1.int * D2.fract	ADD.L	D2,D5		; mid	CLR.L	D5	LOAD.W	D5,D2	SWAP.W	D5		; mid * 2**16	LOAD.W	D2,D5		; #0	SWAP.W	D2	ADD.L	D4,D5		; + low	ADDX.L	D0,D2		; mid.31..W + high + carry				; (D0;D4): rsultatLONGTOFIX$:	SWAP.W	D0	TEST.W	D0		; high word <> 0 ?	JUMP,NE	SETMAX$		; oui => met la val. maximum	SWAP.W	D4	LOAD.W	D0,D4		; low res. word	TEST.L	D4		; high bit reste = 0 ?	JUMP,PL	NOTROUND$	INC.L	D0		; inc res.fract	JUMP,CS	SETMAX$NOTROUND$:	TEST.L	D0		; bit de signe dj mis ?	JUMP,MI	SETMAX$		; ==> dbordement !	TEST.B	D6		; (VC)	JUMP,EQ	EXIT$	NEG.L	D0		; met rsultat ngatif selon D1 et D2.in (VC)	JUMP	EXIT$SETMAX$:	LOAD.L	D0,#H'00000001	RR.L	D0,#1	TEST.B	D6	JUMP,NE	RTNOV$	DEC.L	D0RTNOV$:	SETV			; met le bit overflowEXIT$:	POPM.L	D1,D2,D4,D5,D6	RET;-------\\; FIXDIV >;=======/; in	D1.L	nombre  virgule fixe numrateur;	D2.L	nombre  virgule fixe dnominateur; out	D0.L	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.LFIXDIV:	PUSHM.L	D1..D6	LOAD.L	D4,D2	COMP.L	D4,D1	JUMP,EQ	EQUAL$	CALL	TOPOSITIF	TEST.L	D1		; /0 ?	JUMP,NE	DODIV$		; nonOVERFLOW$:	LOAD.L	D0,#H'7FFFFFFF	TEST.B	D6		; remet ngatif si l'tait	JUMP,EQ	POSOV$	INC.L	D0POSOV$:	SETV	JUMP	EXIT$DODIV$:	LOAD.L	D2,D1		; Dnom	CLR.L	D1	LOAD.L	D0,D4		; Num	CALL	INTDIV32	; Num/Denom: DIV.64 D2,(D1&D0) --> D3.L reste D4.L	JUMP,VS	OVERFLOW$	LOAD.W	D5,D3	SWAP.W	D5		; --> entier	CLR.L	D1		; reste * 2**16	SWAP.W	D4	LOAD.W	D1,D4	LOAD.L	D0,D4	CLR.W	D0	CALL	INTDIV32	; reste*2**16/ Denom	LOAD.W	D5,D3		; --> fraction	LOAD.L	D0,D5	TEST.L	D4	JUMP,PL	NOROUND$	INC.L	D5	JUMP,CS	OVERFLOW$NOROUND$:	TEST.L	D5	JUMP,NS	OVERFLOW$PUTSIGN$:	TEST.B	D6		; remet ngatif si l'tait (VC)	JUMP,EQ	POS$	NEG.L	D0		; (VC)POS$:	JUMP	EXIT$EQUAL$:	LOAD.L	D0,#1	SWAP.W	D0		; (VC)EXIT$:	POPM.L	D1..D6	RETTOPOSITIF:	TEST.L	D1	SET.B,MI D6	JUMP,PL	POS1$	NEG.L	D1POS1$:	TEST.L	D2	JUMP,PL	POS2$	NEG.L	D2	NOT.B	D6POS2$:	RET;---------\\; INTMUL32 >;=========/; Module de multiplication 32*32 --> 64 bits (non-sign).;	-------------------;	 D1&D0 <-- D2 * D3;	-------------------; in	D2.L	multiplicande (32 bits non-sign);	D3.L	multiplicateur (32 bits non-sign); out	D1&D0.L	rsultat (64 bits non-sign); mod	D0.L, D1.LINTMUL32:	PUSHM.L D4,D5	LOAD.W	D0,D3	MUL.WU	D0,D2		; D0 low longword <-- low word * low word	SWAP.W	D2	LOAD.W	D5,D3		; D5 mid longword <-- high word * low word	MUL.WU	D5,D2	SWAP.W	D3	LOAD.W	D1,D3		; D1 high long <-- high word * high word	MUL.WU	D1,D2	SWAP.W	D2	LOAD.W	D4,D3		; D4 mid long <-- high word * low word	MUL.WU	D4,D2	SWAP.W	D3	SWAP.W	D1	ADD.L	D4,D5		; ADD.L D4,D5 avec report sur D1 si ncessessaire	CLR.W	D5	ADDX.W	D1,D5	SWAP.W	D1	ADDX.W	D1,D5	LOAD.W	D5,D1		; ADD.64 D1&D0,D4*(2^16)	SWAP.W	D5	SWAP.W	D0	LOAD.W	D5,D0	ADD.L	D5,D4	LOAD.W	D0,D5	SWAP.W	D0	SWAP.W	D5	LOAD.W	D1,D5	SWAP.W	D1	CLR.L	D5	ADDX.L	D1,D5	SWAP.W	D1	POPM.L	D4,D5	RET;---------\\; INTDIV32 >;=========/; Module de division 64/32 --> 32 bits (non-sign).;	-------------------;	 D3 <-- D1&D0 / D2;	 D4 <-- reste;	-------------------; ATTENTION: pas de test de division par zro !; in	D1&D0.L	numrateur (64 bits non-sign);	D2.L	dnominateur (32 bits non-sign); out	D3.L	rsultat (32 bits non-sign);	D4.L	reste (32 bits non-sign);	VS	overflow; mod	D3.L, D4.LINTDIV32:	PUSHM.L D0,D1	LOAD.W	D4,#32-1	; D4 <-- dcompteur de bouclesLOOP$:	SETX	RLX.L	D0	RLX.L	D1	JUMP',CS ERROR$	SUB.L	D1,D2	JUMP',HS NEXT$	ADD.L	D1,D2	TCLR.L	D0:#0		; bit 0 si rtablissementNEXT$:	DECJ.W,NMO D4,LOOP$	COMP.L	D1,D2		; reste >= diviseur ?	JUMP',HS ERROR$	LOAD.L	D3,D0		; D3 <-- quotient	LOAD.L	D4,D1		; D4 <-- reste,	 F <-- V=0	JUMP'	EXIT$ERROR$:	SETV			; F <-- V=1EXIT$:	POPM.L	D0,D1	RET	.END	START