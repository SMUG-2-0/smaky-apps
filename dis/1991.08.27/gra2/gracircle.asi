	.SBTTL	GRACIRCLE;------------\; _GRA_CIRCLE >;============/; Trace un cercle complet en fonction du centre (x;y) et du; rayon.; in	A2.L	^description de la fentre;	D4.L	centre (y;x);	D3.W	rayon du cercle;	D2.B	bitmap des octants  dessiner;	D1.B	mode (INVDOT, SETDOT ou CLRDOT); out	D7.W	erreur; mod	D7.W; Bits des octants  dessiner :;;		!;		!;	   2^2	!  2^1;		!;	 2^3	!    2^0;	--------!--------> X;	 2^4	!    2^7;		!;	   2^5	!  2^6;		!;	       \!/ Y; use	D0	bit dans le byte du bitmap (0..7);	D1	X relatif au centre;	D2	Y relatif au centre;	D3	critre;	D4	1re composante de la matrice;	D5	2me		";	D6	3me		";	D7	4me		";	A0	^byte dans le bitmap;	A1	octants  dessiner;	A2	^description de la fentre;	A3	^routine "dot";	A4	-;	A5	2;	A6	H'400_GRA_CIRCLE:	PUSHM.L	D0..D6,A0..A6	; ATTENTION: idem  _GRA_ELLIPSE !	LOAD.W	D0,D3	SWAP.W	D3	LOAD.W	D3,D0		; D3 <-- 2x le mme rayon	.IF	COLOR	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP,EQ 19$		; non => 19$	LOAD.L	D0,(A2)+ODFABS	COMP.L	D0,(A2)+ODFCAB	; est-on dans l'cran couleur ?	JUMP,NE 19$		; non => 19$	PUSHM.L	D0..D4	TEST.L	D1:#0	JUMP',BC 12$	TEST.L	D1:#1	JUMP',BC 14$				; CLRDOT =>	LOAD.L	D0,#H'10000*MVDCOR2+MVDCAND1	LOAD.L	D3,(A2)+ODFCCF	; D3 <-- couleur pour effacer	JUMP'	16$12$:				; SETDOT =>	LOAD.L	D0,#H'10000*MVDCOR2+MVDCAND1	LOAD.L	D3,(A2)+ODFCSF	; D3 <-- couleur pour dessiner	JUMP'	16$14$:				; INVDOT =>	LOAD.L	D0,#H'10000*MVDCXNOR+MVDCNOP	LOAD.L	D3,(A2)+ODFCSF	; D3 <-- couleur pour dessiner	LOAD.L	D2,(A2)+ODFCCF	; D2 <-- couleur pour effacer	XOR.L	D3,D216$:	CLR.L	D2	LOAD.W	D4,#-1	CALL	MODVDCC		; init le mode logique	POPM.L	D0..D4	AND.B	D1,#B'11111100	OR.B	D1,#CLRDOT	; D1 <-- toujours le mode CLR !19$:	.ENDIF	TEST.L	D1:#BPENDOT	; utilise le pinceau ?	JUMP',BS 02$		; oui => 02$	PUSHM.L	D3,D4	CALL	DIMELLIPSE	; D4/D3 <-- place occupe	CALL	CLIPGRA		; dans la fentre ?	POPM.L	D3,D4	JUMP',EQ 05$		; oui => 05$	COMP.B	(A2)+ODFMGR,#GRAWHOLE ; mode "tout dans l'cran" ?	JUMP,EQ	99$		; oui => ne fait rien02$:				; non => essaye de faire un petit bout	JUMP	ELLIPSE_NOPUSH	; fait une ellipse avec rayon x = rayon y !; Met les paramtres dans les bons regsitres.05$:	LOAD.W	D0,D3		; D0 <-- rayon	LOAD.W	D3,D4		; D3 <-- X	SWAP.W	D4		; D4 <-- Y	ADD.W	D3,D0		; D3 <-- X + rayon; Cherche l'adresse de la routine de traitement d'un point; en fonction du mode dans D1.B	CALL	ADOT		; A3 <-- ^routine "dot"	LOAD.W	A1,D2		; A1 <-- octants  dessiner	LOAD.W	D1,D0		; D1 <-- rayon	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit	LOAD.L	A5,#2		; A5 <-- toujours 2	CLR.L	D7	LOAD.W	D7,(A2)+ODFIIY	; 4 me	CLR.L	D6		; 3 me	LOAD.L	D5,D7		; 2 me	LOAD.L	D4,#-1		; 1 re	LOAD.W	D3,D1		; D3 <-- R <-- critre	SL.W	D1,#1		; 2*X	CLR.W	D2		; 2*Y	PUSH.W	#4		; vite de tourner en rond; Algorithme 1; ------------10$:	EX.L	D2,A1	SL.B	D2,#1	EX.L	D2,A1	JUMP,CC	30$		; rien  faire => 30$20$:	ADD.W	D3,D2		; C <-- C + 2*Y	ADD.W	D2,A5		; Y <-- Y + 1	INC.W	D3		; C <-- C + 2*Y + 1	JUMP',LT 22$		; test du critre	SUB.W	D3,D1		; C <-- C - 2*X	SUB.W	D1,A5		; X <-- X-1	INC.W	D3		; C <-- C - 2*X + 1	ADD.L	A0,D5		; nouveau byte selon Y	ADD.W	D0,D4		; dplacement X	JUMP',GE 24$	LOAD.W	D0,#7		; ngatif	DEC.L	A0		; recule en Y	JUMP'	26$22$:	ADD.L	A0,D7	ADD.W	D0,D6	JUMP',GE 24$	LOAD.W	D0,#7		; ngatif	DEC.L	A0		; recule en Y	JUMP'	26$24$:	TCLR.L	D0:#3		; positif	JUMP',EQ 26$	INC.L	A0		; avance en Y26$:	NOT.B	D0		; bits en sens inverse !	PUSH.L	D7	CALL	(A3)		; traitement d'un point	POP.L	D7	NOT.B	D0		; bits en sens inverse !	COMP.W	D2,D1		; dtection pour le changement	JUMP',LE 20$		; d'octan	JUMP	38$30$:	ADD.W	D3,D2		; C <-- C + 2*Y	ADD.W	D2,A5		; Y <-- Y + 1	INC.W	D3		; C <-- C + 2*Y + 1	JUMP',LT 32$		; test du critre	SUB.W	D3,D1		; C <-- C - 2*X	SUB.W	D1,A5		; X <-- X-1	INC.W	D3		; C <-- C - 2*X + 1	ADD.L	A0,D5		; nouveau byte selon Y	ADD.W	D0,D4		; dplacement X	JUMP',GE 34$	LOAD.W	D0,#7		; ngatif	DEC.L	A0		; recule en Y	JUMP'	36$32$:	ADD.L	A0,D7	ADD.W	D0,D6	JUMP',GE 34$	LOAD.W	D0,#7		; ngatif	DEC.L	A0		; recule en Y	JUMP'	36$34$:	TCLR.L	D0:#3		; positif	JUMP',EQ 36$	INC.L	A0		; avance en Y36$:;	ne fait rien	COMP.W	D2,D1		; dtection pour le changement	JUMP,LE 30$		; d'octan38$:	SUB.L	D6,D4		; effectue les oprations de	NEG.L	D6		; transformation pour un	SUB.L	D7,D5		; changement d'octan	NEG.L	D7; Algorithme 2; ------------	EX.L	D2,A1	SL.B	D2,#1	EX.L	D2,A1	JUMP,CC	50$		; rien  faire => 50$40$:	SUB.W	D3,D1		; C <-- C - 2*X	SUB.W	D1,A5		; X <-- X - 1	ADD.W	D3,D2		; C <-- C - 2*X + 2*Y	ADD.W	D2,A5		; Y <-- Y + 1	ADD.W	D3,A5		; C <-- C - 2*X + 2*Y + 2	JUMP',LT 42$	SUB.W	D3,D2		; C <-- C - 2*Y	SUB.W	D2,A5		; Y <-- Y - 1	INC.W	D3		; C <-- C - 2*Y + 1	ADD.L	A0,D7		; nouvelle coordonne Y	ADD.W	D0,D6		; nouvelle coordonne X	JUMP',GE 44$		; jump si pas de dbordement	LOAD.W	D0,#7		; ngatif	DEC.L	A0		; recule en Y	JUMP'	46$		; va inverser le point42$:	ADD.L	A0,D5	ADD.W	D0,D4	JUMP',GE 44$	LOAD.W	D0,#7		; ngatif	DEC.L	A0		; recule en Y	JUMP'	46$44$:	TCLR.L	D0:#3	JUMP',EQ 46$	INC.L	A0		; avance en Y46$:	NOT.B	D0		; bits en sens inverse !	PUSH.L	D7	CALL	(A3)		; traitement d'un point	POP.L	D7	NOT.B	D0		; bits en sens inverse !	TEST.W	D1		; test changement de quadrant	JUMP,GT 40$	JUMP	58$50$:	SUB.W	D3,D1		; C <-- C - 2*X	SUB.W	D1,A5		; X <-- X - 1	ADD.W	D3,D2		; C <-- C - 2*X + 2*Y	ADD.W	D2,A5		; Y <-- Y + 1	ADD.W	D3,A5		; C <-- C - 2*X + 2*Y + 2	JUMP',LT 52$	SUB.W	D3,D2		; C <-- C - 2*Y	SUB.W	D2,A5		; Y <-- Y - 1	INC.W	D3		; C <-- C - 2*Y + 1	ADD.L	A0,D7		; nouvelle coordonne Y	ADD.W	D0,D6		; nouvelle coordonne X	JUMP',GE 54$		; jump si pas de dbordement	LOAD.W	D0,#7		; ngatif	DEC.L	A0		; recule en Y	JUMP'	56$		; va inverser le point52$:	ADD.L	A0,D5	ADD.W	D0,D4	JUMP',GE 54$	LOAD.W	D0,#7		; ngatif	DEC.L	A0		; recule en Y	JUMP'	56$54$:	TCLR.L	D0:#3	JUMP',EQ 56$	INC.L	A0		; avance en Y56$:;	rien  faire	TEST.W	D1		; test changement de quadrant	JUMP,GT 50$58$:	TEST.L	D6		; effectue les oprations de	JUMP',EQ 85$		; transformation pour un	NEG.L	D5		; changement de quadrant	JUMP'	90$85$:	NEG.L	D4		; fin du traitement d'un quadrant90$:	DEC.W	(SP)		; dec nombre de quadrant	JUMP',EQ 95$	EX.L	D1,D2		; X <==> Y pour chgm. de quadrant	NEG.W	D2	JUMP	10$95$:	POP.W	D0		; annule le PUSH.W #4	CLR.W	D7		; D7 <-- ok99$:	POPM.L	D0..D6,A0..A6	RET;-------------\; _GRA_ELLIPSE >;=============/; Trace une ellipse complte fonction du centre (x;y) et du; rayon.; in	A2.L	^description de la fentre;	D4.L	centre (y;x);	D3.L	rayons (y;x);	D2.B	bitmap des octants  dessiner;	D1.B	mode (INVDOT, SETDOT ou CLRDOT); out	D7.W	erreur; mod	D7.W; use	D0	coordonne (Y;X) relative au centre;	D1	X relatif au centre;	D2	Y relatif au centre;	D3	critre;	D4	1re composante de la matrice;	D5	2me		";	D6	3me		";	D7	4me		";	A0	coordonne (Y;X) du centre;	A1	octants  dessiner;	A2	^description de la fentre;	A3	^routine "dot";	A4	rayons (Y;X);	A5	coordonne (Y;X) dernier point;	A6	2_GRA_ELLIPSE:	PUSHM.L	D0..D6,A0..A6	; ATTENTION: idem  _GRA_CIRCLE !ELLIPSE_NOPUSH:	PUSH.L	#R16"ELLIPSEFIN	LOAD.L	(A2)+ODFVAR+OVARSP,SP	.IF	COLOR	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP,EQ 19$		; non => 19$	LOAD.L	D0,(A2)+ODFABS	COMP.L	D0,(A2)+ODFCAB	; est-on dans l'cran couleur ?	JUMP,NE 19$		; non => 19$	PUSHM.L	D0..D4	TEST.L	D1:#0	JUMP',BC 12$	TEST.L	D1:#1	JUMP',BC 14$				; CLRDOT =>	LOAD.L	D0,#H'10000*MVDCOR2+MVDCAND1	LOAD.L	D3,(A2)+ODFCCF	; D3 <-- couleur pour effacer	JUMP'	16$12$:				; SETDOT =>	LOAD.L	D0,#H'10000*MVDCOR2+MVDCAND1	LOAD.L	D3,(A2)+ODFCSF	; D3 <-- couleur pour dessiner	JUMP'	16$14$:				; INVDOT =>	LOAD.L	D0,#H'10000*MVDCXNOR+MVDCNOP	LOAD.L	D3,(A2)+ODFCSF	; D3 <-- couleur pour dessiner	LOAD.L	D2,(A2)+ODFCCF	; D2 <-- couleur pour effacer	XOR.L	D3,D216$:	CLR.L	D2	LOAD.W	D4,#-1	CALL	MODVDCC		; init le mode logique	POPM.L	D0..D4	AND.B	D1,#B'11111100	OR.B	D1,#CLRDOT	; D1 <-- toujours le mode CLR !19$:	.ENDIF	CALL	CLIPELLIPSE	; D2 <-- clip les octants inutiles	CLR.W	D7		; D7 <-- ok	TEST.B	D2		; reste qq chose  dessiner ?	JUMP,EQ	99$		; non => 99$; Met les paramtres dans les bons regsitres.	LOAD.L	D0,D3		; D0 <-- rayons (y;x)	LOAD.W	D3,D4		; D3 <-- X	SWAP.W	D4		; D4 <-- Y; Cherche l'adresse de la routine de traitement d'un point; en fonction du mode dans D1.B	CALL	ADOTXY		; A3 <-- ^routine "dotxy"	LOAD.W	A1,D2		; A1 <-- octants  dessiner	LOAD.L	A4,D0		; A4 <-- rayons (Y;X)	LOAD.L	D1,D0	SWAP.W	D1	COMP.W	D1,D0		; rayon X > rayon Y  ?	JUMP',LO 03$	SWAP.W	D0		; D0 <-- rayon le plus grand03$:	LOAD.W	D1,D0		; D1 <-- rayon	LOAD.W	D0,D4		; D0 <-- coordonne Y	SWAP.W	D0	LOAD.W	D0,D3		; D0 <-- coordonne X	LOAD.L	A0,D0		; A0 <-- coordonne (Y;X) du centre	CLR.L	D0	LOAD.W	D0,D1		; D0 <-- coordonne relative au centre	LOAD.W	A5,#-1		; A5 <-- coordonnes dernier point dessin	LOAD.W	A6,#2		; A6 <-- toujours 2	LOAD.L	D7,#1		; 4 me	CLR.L	D6		; 3 me	LOAD.L	D5,D7		; 2 me	LOAD.L	D4,#-1		; 1 re	LOAD.W	D3,D1		; D3 <-- R <-- critre	SL.W	D1,#1		; 2*X	CLR.W	D2		; 2*Y	PUSH.W	#4		; evite de tourner en rond; Algorithme 1; ------------10$:	EX.L	D2,A1	SL.B	D2,#1	EX.L	D2,A1	JUMP,CC	30$		; rien  faire => 30$20$:	ADD.W	D3,D2		; C <-- C + 2*Y	ADD.W	D2,A6		; Y <-- Y + 1	INC.W	D3		; C <-- C + 2*Y + 1	JUMP',LT 22$		; test du critre	SUB.W	D3,D1		; C <-- C - 2*X	SUB.W	D1,A6		; X <-- X-1	INC.W	D3		; C <-- C - 2*X + 1	SWAP.W	D0	ADD.W	D0,D5		; D0 <-- dplacement Y	SWAP.W	D0	ADD.W	D0,D4		; D0 <-- dplacement X	JUMP'	26$22$:	SWAP.W	D0	ADD.W	D0,D7		; D0 <-- dplacement Y	SWAP.W	D0	ADD.W	D0,D6		; D0 <-- dplacement X26$:	CALL	DOT_ELLIPSE	; traitement d'un point	COMP.W	D2,D1		; dtection pour le changement	JUMP',LE 20$		; d'octan	JUMP	38$30$:	ADD.W	D3,D2		; C <-- C + 2*Y	ADD.W	D2,A6		; Y <-- Y + 1	INC.W	D3		; C <-- C + 2*Y + 1	JUMP',LT 32$		; test du critre	SUB.W	D3,D1		; C <-- C - 2*X	SUB.W	D1,A6		; X <-- X-1	INC.W	D3		; C <-- C - 2*X + 1	SWAP.W	D0	ADD.W	D0,D5		; D0 <-- dplacement Y	SWAP.W	D0	ADD.W	D0,D4		; D0 <-- dplacement X	JUMP'	36$32$:	SWAP.W	D0	ADD.W	D0,D7		; D0 <-- dplacement Y	SWAP.W	D0	ADD.W	D0,D6		; D0 <-- dplacement X36$:;	ne fait rien	COMP.W	D2,D1		; dtection pour le changement	JUMP,LE 30$		; d'octan38$:	SUB.L	D6,D4		; effectue les oprations de	NEG.L	D6		; transformation pour un	SUB.L	D7,D5		; changement d'octan	NEG.L	D7; Algorithme 2; ------------	EX.L	D2,A1	SL.B	D2,#1	EX.L	D2,A1	JUMP,CC	50$		; rien  faire => 50$40$:	SUB.W	D3,D1		; C <-- C - 2*X	SUB.W	D1,A6		; X <-- X - 1	ADD.W	D3,D2		; C <-- C - 2*X + 2*Y	ADD.W	D2,A6		; Y <-- Y + 1	ADD.W	D3,A6		; C <-- C - 2*X + 2*Y + 2	JUMP',LT 42$	SUB.W	D3,D2		; C <-- C - 2*Y	SUB.W	D2,A6		; Y <-- Y - 1	INC.W	D3		; C <-- C - 2*Y + 1	SWAP.W	D0	ADD.W	D0,D7		; D0 <-- dplacement Y	SWAP.W	D0	ADD.W	D0,D6		; D0 <-- dplacement X	JUMP'	46$		; va inverser le point42$:	SWAP.W	D0	ADD.W	D0,D5		; D0 <-- dplacement Y	SWAP.W	D0	ADD.W	D0,D4		; D0 <-- dplacement X46$:	CALL	DOT_ELLIPSE	; traitement d'un point	TEST.W	D1		; test changement de quadrant	JUMP,GT 40$	JUMP	58$50$:	SUB.W	D3,D1		; C <-- C - 2*X	SUB.W	D1,A6		; X <-- X - 1	ADD.W	D3,D2		; C <-- C - 2*X + 2*Y	ADD.W	D2,A6		; Y <-- Y + 1	ADD.W	D3,A6		; C <-- C - 2*X + 2*Y + 2	JUMP',LT 52$	SUB.W	D3,D2		; C <-- C - 2*Y	SUB.W	D2,A6		; Y <-- Y - 1	INC.W	D3		; C <-- C - 2*Y + 1	SWAP.W	D0	ADD.W	D0,D7		; D0 <-- dplacement Y	SWAP.W	D0	ADD.W	D0,D6		; D0 <-- dplacement X	JUMP'	56$		; va inverser le point52$:	SWAP.W	D0	ADD.W	D0,D5		; D0 <-- dplacement Y	SWAP.W	D0	ADD.W	D0,D4		; D0 <-- dplacement X56$:;	rien  faire	TEST.W	D1		; test changement de quadrant	JUMP,GT 50$58$:	TEST.L	D6		; effectue les oprations de	JUMP',EQ 85$		; transformation pour un	NEG.L	D5		; changement de quadrant	JUMP'	90$85$:	NEG.L	D4		; fin du traitement d'un quadrant90$:	DEC.W	(SP)		; dec nombre de quadrant	JUMP',EQ 95$	EX.L	D1,D2		; X <==> Y pour chgm. de quadrant	NEG.W	D2	JUMP	10$95$:	POP.W	D0		; annule le PUSH.W #4	CLR.W	D7		; D7 <-- ok99$:	POP.L	D0		; annule le PUSH.L R16"ELLIPSEFINELLIPSEFIN:	POPM.L	D0..D6,A0..A6	RET;------------\; DOT_ELLIPSE >;------------/; Traitement d'un point pour une ellipse.; in	D0.L	coordonne (Y;X) relative au centre;	A0.L	coordonne (Y;X) du centre;	A3.L	^routine "dot";	A4.L	rayons (Y;X);	A5.L	coordonne (Y;X) dernier point; out	A5.L	coordonne (Y;X) dernier point; mod	A5.LDOT_ELLIPSE:	PUSHM.L	D0,D1,D3,D4,D7,A0	LOAD.W	D3,D0		; D3 <-- coordonne X	LOAD.L	D4,D0	SWAP.W	D4		; D4 <-- coordonne Y	LOAD.W	D0,A4		; D0 <-- rayon X	LOAD.L	D1,A4	SWAP.W	D1		; D1 <-- rayon Y	COMP.W	D0,D1	JUMP',EQ 50$		; si cercle => 50$	JUMP',LO 20$	MUL.WA	D4,D1	DIV.WA	D4,D0		; D4 <-- (Y*Ry)/Rx	JUMP'	50$20$:	MUL.WA	D3,D0	DIV.WA	D3,D1		; D3 <-- (X*Rx)/Ry50$:	LOAD.W	D0,D4	SWAP.W	D0	LOAD.W	D0,D3	COMP.L	D0,A5		; point dj dessin ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	A5,D0	LOAD.L	D0,A0		; A0 <-- coordonne du centre	ADD.W	D3,D0	SWAP.W	D0	ADD.W	D4,D0	CALL	(A3)		; traitement d'un point90$:	POPM.L	D0,D1,D3,D4,D7,A0	RET;-----------\; DIMELLIPSE >;-----------/; Donne la zone rectangulaire occupe par un ou plusieurs; arcs d'ellipse.; in	D4.L	centre (y;x);	D3.L	rayons (y;x);	D2.B	octants  dessiner; out	D4.L	origine;	D3.L	dimensions; mod	D3.L, D4.LDIMELLIPSE:	PUSHM.L	D0,D1	LOAD.W	D0,D3		; D0 <-- rayon x	LOAD.L	D1,D3	SWAP.W	D1		; D1 <-- rayon y	CLR.L	D3		; D3 <-- dimensions	TEST.L	D2:#4		; qq chose contre en bas ?	JUMP',BS 10$		; oui => 10$	TEST.L	D2:#5	JUMP',BS 10$	TEST.L	D2:#6	JUMP',BS 10$	TEST.L	D2:#7	JUMP',BC 15$10$:	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D315$:	TEST.L	D2:#0		; qq chose contre en haut ?	JUMP',BS 20$		; oui => 20$	TEST.L	D2:#1	JUMP',BS 20$	TEST.L	D2:#2	JUMP',BS 20$	TEST.L	D2:#3	JUMP',BC 25$20$:	SWAP.W	D4	SUB.W	D4,D1	SWAP.W	D4	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D325$:	TEST.L	D2:#0		; qq chose  droite ?	JUMP',BS 30$		; oui => 30$	TEST.L	D2:#1	JUMP',BS 30$	TEST.L	D2:#6	JUMP',BS 30$	TEST.L	D2:#7	JUMP',BC 35$30$:	ADD.W	D3,D035$:	TEST.L	D2:#2		; qq chose  gauche ?	JUMP',BS 40$		; oui => 40$	TEST.L	D2:#3	JUMP',BS 40$	TEST.L	D2:#4	JUMP',BS 40$	TEST.L	D2:#5	JUMP',BC 45$40$:	SUB.W	D4,D0	ADD.W	D3,D045$:	POPM.L	D0,D1	RET;------------\; CLIPELLIPSE >;------------/; Supprime les arcs (quarts) d'ellipse qui ne sont pas dans la; (sous-)fentre.; in	D4.L	centre (y;x);	D3.L	rayons (y;x);	D1.B	mode (INVDOT, SETDOT ou CLRDOT);	D2.B	octants  dessiner; out	D2.B	octants  dessiner; mod	D2.B, D7.WCLIPELLIPSE:	PUSHM.L	D0,D4,D5	COMP.B	(A2)+ODFMGR,#GRAROUND ; mode "cran cylindrique" ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	D0,D3	SWAP.W	D0		; D0 <-- rayon y	LOAD.B	D5,D2		; D5 <-- octants initiaux	TEST.L	D2:#6		; qq chose en bas  droite ?	JUMP',BS 10$	TEST.L	D2:#7	JUMP',BC 15$10$:	CALL	IFINCLU	JUMP',EQ 15$	AND.B	D2,#B'0011111115$:	SUB.W	D4,D3	TEST.L	D2:#4		; qq chose en bas  gauche ?	JUMP',BS 20$	TEST.L	D2:#5	JUMP',BC 25$20$:	CALL	IFINCLU	JUMP',EQ 25$	AND.B	D2,#B'1100111125$:	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D4	TEST.L	D2:#2		; qq chose en haut  gauche ?	JUMP',BS 30$	TEST.L	D2:#3	JUMP',BC 35$30$:	CALL	IFINCLU	JUMP',EQ 35$	AND.B	D2,#B'1111001135$:	ADD.W	D4,D3	TEST.L	D2:#0		; qq chose en haut  droite ?	JUMP',BS 40$	TEST.L	D2:#1	JUMP',BC 45$40$:	CALL	IFINCLU	JUMP',EQ 45$	AND.B	D2,#B'1111110045$:	TEST.L	D1:#BTTTDOT	; traitill ?	JUMP',BC 90$		; non => 90$				; oui =>	TEST.B	D2		; reste qq chose  dessiner ?	JUMP',EQ 90$		; non => 90$	LOAD.B	D2,D5		; D2 <-- si oui, dessine tout !90$:	POPM.L	D0,D4,D5	RET;--------\; IFINCLU >;--------/; Vrifie si un arc (quart) d'ellipse est inclu dans la (sous-)fentre.; in	D4.L	coin sup/gauche;	D3.L	dimensions;	D1.B	mode (INVDOT, SETDOT ou CLRDOT); out	EQ	inclu; mod	D7.WIFINCLU:	PUSHM.L	D1..D4	LOAD.W	D7,#ERDIOUT	; D7 <-- pas inclu	TEST.L	D1:#BPENDOT	; utilise le pinceau ?	JUMP',BC 30$		; non => 30$				; oui =>	LOAD.W	D1,#LGPENX/2	LOAD.W	D2,#LGPENY/2	TEST.L	(A2)+ODFPPM	; pinceau selon XPEN ?	JUMP',EQ 20$		; non => 20$	LOAD.W	D1,(A2)+ODFPDI+2	SR.W	D1,#1	INC.W	D1		; D1 <-- demi-largeur du pinceau	LOAD.W	D2,(A2)+ODFPDI+0	SR.W	D2,#1	INC.W	D2		; D2 <-- demi-hauteur du pinceau20$:	SUB.W	D4,D1	SWAP.W	D4	SUB.W	D4,D2	SWAP.W	D4	ADD.W	D3,D1	ADD.W	D3,D1	SWAP.W	D3	ADD.W	D3,D2	ADD.W	D3,D2	SWAP.W	D330$:	COMP.W	D4,(A2)+ODFFDX	JUMP',GE 90$	ADD.W	D4,D3	JUMP',NS 90$	SWAP.W	D3	SWAP.W	D4	COMP.W	D4,(A2)+ODFFDY	JUMP',GE 90$	ADD.W	D4,D3	JUMP',NS 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET	.END