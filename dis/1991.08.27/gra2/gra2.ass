	.TITLE		GRA2.ASS	.PROC		M68000		; mnmonics CALM 	.BASE		10'10		; base 10 par dfaut;	.LAYOUT		HEX		; listing en hexadcimaL; Numros des appels; ------------------	.SYSCALL.16	GRA2_GRA2_RASTER	=	16'AA80		; raster-opGRA2_MATRIX	=	16'AA81		; dessine une matrice (caractre)GRA2_TRAME	=	16'AA82		; dessine une trame rectangulaireGRA2_ROLLUP	=	16'AA83		; dcale vers le hautGRA2_ROLLDOWN	=	16'AA84		; dcale vers le basGRA2_CLEAR	=	16'AA85		; efface une zone rectangulaireGRA2_LINE	=	16'AA86		; dessine une ligne droiteGRA2_CIRCLE	=	16'AA87		; dessine un cercleGRA2_FILLO	=	16'AA88		; rempli une surfaceGRA2_FILLC	=	16'AA89		; libre mm aprs FILLOGRA2_SPRITE	=	16'AA8A		; dessine un lutinGRA2_DOT	=	16'AA8B		; dessine un pointGRA2_ELLIPSE	=	16'AA8C		; dessine une ellipseGRA2_EFLI	=	16'AA8D		; efface la fin de la ligneGRA2_EFEOS	=	16'AA8E		; efface la fin de l'cranGRA2_INV	=	16'AA8F		; inverse une zone rectangulaireGRA2_QIDOT	=	16'AA90		; inverse rapidement un pointGRA2_QXDOT	=	16'AA91		; opration quelconque rapide avec un pointGRA2_SET	=	16'AA92		; allume une zone rectangulaireGRA2_ROLLLEFT	=	16'AA93		; dcale vers la gaucheGRA2_ROLLRIGHT	=	16'AA94		; dcale vers la droiteGRA2_CODEIMA	=	16'AA95		; code une imageGRA2_DECOIMA	=	16'AA96		; dcode une imageGRA2_HVDOT	=	16'AA97		; dessine des points sur une droiteGRA2_RLINE	=	16'AA98		; dessine une ligne droite (nb rels)GRA2_FIRST	=	GRA2_RASTERGRA2_LAST	=	GRA2_RLINE; Codage d'images; ---------------IMLBUF		=	16'40		; rserve pour codage/dcodage; Table rendue par GRA2_FILLO; ---------------------------	.LOC	0OGRAFY:		.BLK.16		1		; coordonne Y ligneOGRAFXD:	.BLK.16		1		; coordonne X dbutOGRAFXF:	.BLK.16		1		; coordonne X finLGRAF:; Oprations possibles avec les lutins; ------------------------------------SPRITE_OPEN	=	1		; dessine un premier lutinSPRITE_MOVE	=	2		; dplace un lutinSPRITE_CLEAR	=	3		; enlve temporairement un lutinSPRITE_SET	=	4		; remet un lutin aprs SPRITE_CLEARSPRITE_CLOSE	=	5		; enlve un dernier lutinSPRITE_GETPOS	=	6		; donne position/dimensions; Les routines du module GRA2 ne s'occupent pas de la souris. Il faut; donc teindre la souris (AFCCMO) et la remettre (AFSCMO) si l'opration; effectue est succeptible d'altrer la flche de la souris !; Toutes les routines reoivent en entre le pointeur au descripteur de; la fentre dans A2.32 qui doit tre le descripteur rel (et non une copie).; Voir  ce sujet FOS,?RSTATUS avec D4=4.;------------\\; GRA_RASTER  >;============/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	A2.32		^description fentre;	----;	D3.32		coordonne source (y;x);	A3.32		^mmoire source/^nil si cran;	D5.16		Iy source (si mmoire);	----;	D4.32		coordonne destination (y;x);	A4.32		^mmoire destination/^nil si cran;	D6.16		Iy destination (si mmoire);	----;	D2.32		hauteur/largeur (y;x);	D1.8		opration (INVDOT, SETDOT ou CLRDOT); out	-; mod	-;------------\\; GRA_MATRIX  >;============/; Dessine la matrice d'un caractre typographique. Est aussi; utilis pour DRAWMATRIX (dessin d'un motif quelconque).; Primitive semblable au "raster-op", mais avec quelques petites; diffrences :;   -	bits dans les bytes toujours (SM8/100) 0..7,;	c'est--dire l'inverse des fichiers gencar !;   -	opration SETDOT faisant un "load" (chair + fond); in	A2.32		^description de la fentre;	D4.32		coordonne (y;x) dans la fentre;	D3.32		hauteur/largeur (dy;dx);	D2.8		opration d'inversion (0/-1);	D1.8		opration (SETDOT ou INVDOT);	A4.32		^matrice  dessiner;	D5.16		Iy (largeur en bytes); out	D7.16		erreur; mod	D7.16;-----------\\; GRA_TRAME  >;===========/; Rempli une surface rectangulaire avec une trame 8x8.; La trame est toujours aligne (horizontalement et verticalement);  une position modulo 8 pour rsoudre les problmes de jointures; entre deux trames.; in	A2.32		^description de la fentre;	D4.32		coordonnes y;x dbut (coin sup/gauche);	D3.32		delta y;x;	D1.8		opration (INVDOT, SETDOT ou CLRDOT);	A4.32		^trame; out	D7.16		erreur; mod	D7.16;------------\\; GRA_ROLLUP  >;============/; Effectue un roll contre le haut d'un nombre de points; quelconque dans une fentre.; in	A2.32		^description de la fentre;	D4.16		nb de points  "roller" (doit tre pair); out	-; mod	-;--------------\\; GRA_ROLLDOWN  >;==============/; Effectue un roll contre le bas d'un nombre de points; quelconque dans une fentre.; in	A2.32		^description de la fentre;	D4.16		nb de points  "roller" (doit tre pair); out	-; mod	-;-----------\\; GRA_EFEOS  >;===========/; Efface jusqu' la fin de l'cran.; in	A2.32		^description d'une fentre; out	-; mod	D7.16;-----------\\; GRA_EFLI   >;===========/; Efface jusqu' la fin de la ligne.; in	A2.32		^description d'une fentre; out	-; mod	D7.16;-----------\\; GRA_CLEAR  >;===========/; Efface rapidement une zone rectangulaire.; in	A2.32		^description d'une fentre;	D4.32		position (y;x);	D3.32		dimensions (dy;dx); out	D7.16		erreur; mod	D7.16;---------\\; GRA_SET  >;=========/; Allume rapidement une zone rectangulaire.; in	A2.32		^description d'une fentre;	D4.32		position (y;x);	D3.32		dimensions (dy;dx); out	-; mod	D7.16;---------\\; GRA_INV  >;=========/; Inverse rapidement une zone rectangulaire.; in	A2.32		^description d'une fentre;	D4.32		position (y;x);	D3.32		dimensions (dy;dx); out	-; mod	D7.16;----------\\; GRA_LINE  >;==========/; Trace un segment de droite trs rapidement.; in	A2.32		^description de la fentre;	D4.32		origine Y;X;	D3.32		longueur dY;dX;	D1.8		mode (INVDOT, SETDOT ou CLRDOT); out	D7.16		erreur; mod	D7.16;------------\\; GRA_CIRCLE  >;============/; Trace un cercle complet en fonction du centre (x;y) et du; rayon.; in	A2.32		^description de la fentre;	D4.32		centre (y;x);	D3.16		rayon du cercle;	D2.8		bitmap des octants  dessiner;	D1.8		mode (INVDOT, SETDOT ou CLRDOT); out	D7.16		erreur; mod	D7.16;-------------\\; GRA_ELLIPSE  >;=============/; Trace une ellipse complte fonction du centre (x;y) et du; rayon.; in	A2.32		^description de la fentre;	D4.32		centre (y;x);	D3.32		rayons (y;x);	D2.8		bitmap des octants  dessiner;	D1.8		mode (INVDOT, SETDOT ou CLRDOT); out	D7.16		erreur; mod	D7.16;-----------\\; GRA_FILLO  >;===========/; Rempli une surface quelconque.; in	A2.32		^description de la fentre;	D4.32		origine (y;x); out	D7.16		erreur; mod	D7.16;-----------\\; GRA_FILLC  >;===========/; Rend la mmoire des points allums.; in	A2.32		^description de la fentre; out	-; mod	-;------------\\; GRA_SPRITE  >;============/; Effectue une opration avec un lutin.; in	A2.32		^description de la fentre;	D6.8		numro du lutin;	D0.16		opration (SPRITE_??);	D4.32		coordonne (y;x);	D3.32		dimensions (dy;dx) si SPRITE_OPEN;	A4.32		^matrice du lutin (set) si SPRITE_OPEN;	A3.32		^matrice du fond (clear) si SPRITE_OPEN (^nil=calcul); out	D7.16		erreur; mod	D7.16;---------\\; GRA_DOT  >;=========/; Dessine un point graphique.; in	A2.32		^description de la fentre;	D4.32		coordonne Y;X;	D1.8		mode (INVDOT, SETDOT ou CLRDOT); out	D7.16		erreur; mod	D7.16;-----------\\; GRA_QIDOT  >;===========/; Inverse rapidement un point graphique.; in	A2.32		^description de la fentre;	D4.32		coordonne Y;X; out	-; mod	D7.16;-----------\\; GRA_QXDOT  >		(NE PLUS UTILISER);===========/; Opration quelconque rapide avec un point graphique.; Oprations autorises juste aprs :;	TNOT.8		{A0}:D0;	TSET.8		{A0}:D0;	TCLR.8		{A0}:D0;	TEST.8		{A0}:D0; in	A2.32		^description de la fentre;	D4.32		coordonne Y;X; out	A0.32		^byte dans l'cran;	D0.8		numro du bit dans le byte; mod	D0.8, D7.16, A0.32;-----------\\; GRA_HVDOT  >;===========/; Dessine une srie de points disposs sur une ligne; horizontale ou verticale.; Cet appel est idal pour dessiner des grilles, comme; dans les logiciels PLAN, DESSIN, FICHE, etc.; in	A2.L	^description de la fentre;	D4.L	coordonne Y;X;	D3.L	incrment dY;dX;	D2.W	nombre de points (1..n);	D1.B	mode (INVDOT, SETDOT ou CLRDOT); out	D7.W	erreur; mod	D7.W;------------\\; GRA_CODEIMA >;============/; Code une image.; in	A3.32		^image non code;	A4.32		^buffer codage (infrieur ou gal  #{A3}-IMLBUF);	A2.32		^entte du fichier image; out	{A4}+++		buffer rempli avec l'image code;	{A2}+OIMCOD	signale image code;	{A2}+OIMNBB	longueur image code;	D7.16		erreur; mod	D7.16;------------\\; GRA_DECOIMA >;============/; Dcode une image.; in	A3.32		^buffer image dcode (suprieur ou gal  #{A4}+IMLBUF);	A4.32		^image code;	A2.32		^entte du fichier image; out	{A3}+++		buffer rempli avec l'image dcode;	{A2}+OIMCOD	signale image non code;	{A2}+OIMNBB	longueur image non code;	D7.16		erreur; mod	D7.16	.END