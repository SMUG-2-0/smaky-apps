	.SBTTL	GRAMOVE;------------\; _GRA_ROLLUP >;============/; Effectue un roll contre le haut d'un nombre de points; quelconque dans une fentre.; in	A2.L	^description de la fentre;	D4.W	nb de points  "roller"; out	-; mod	-_GRA_ROLLUP:	.IF	COLOR	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP,EQ __GRA_ROLLUP	; non => __GRA_ROLLUP	PUSH.L	D2	LOAD.L	D2,(A2)+ODFABS	COMP.L	D2,(A2)+ODFCAB	; est-on dans l'cran couleur ?	POPM.L	D2	JUMP,NE __GRA_ROLLUP	; non => __GRA_ROLLUP	PUSHM.L	D0..D4	LOAD.W	D0,#MVDCLOAD	CLR.L	D2	CLR.L	D3	LOAD.W	D4,#-1	CALL	MODVDCC		; init le mode logique	POPM.L	D0..D4	SUB.L	(A2)+ODFABS,#LGBITS*8	CALL	__GRA_ROLLUP	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLUP	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLUP	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLUP	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLUP	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLUP	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLUP	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLUP	ADD.L	(A2)+ODFABS,#LGBITS	RET	.ENDIF__GRA_ROLLUP:	PUSHM.L	D0..D4,A3,A4	LOAD.W	D0,D4		; D0 <-- dplacement	JUMP,EQ 90$	CLR.L	D4		; D4 <-- origine destination	LOAD.W	D3,D0	SWAP.W	D3	CLR.W	D3		; D3 <-- origine source	LOAD.L	D2,(A2)+ODFFDY	SWAP.W	D2	SUB.W	D2,D0		; D2 <-- dimensions	JUMP',LS 90$	SWAP.W	D2	LOAD.L	A3,#0		; A3 <-- source dans l'cran	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.W	D1,#LOADDOT	; D1 <-- mode	CALL	_GRA_RASTERM	; dplace vers le haut	LOAD.L	D3,D2	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	LOAD.W	D3,D0	SWAP.W	D4	SWAP.W	D3	CALL	_GRA_CLEAR	; efface en bas90$:	POPM.L	D0..D4,A3,A4	RET;--------------\; _GRA_ROLLDOWN >;==============/; Effectue un roll contre le bas d'un nombre de points; quelconque dans une fentre.; in	A2.L	^description de la fentre;	D4.W	nb de points  "roller"; out	-; mod	-_GRA_ROLLDOWN:	.IF	COLOR	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP,EQ __GRA_ROLLDOWN	; non => __GRA_ROLLDOWN	PUSH.L	D2	LOAD.L	D2,(A2)+ODFABS	COMP.L	D2,(A2)+ODFCAB	; est-on dans l'cran couleur ?	POPM.L	D2	JUMP,NE __GRA_ROLLDOWN	; non => __GRA_ROLLDOWN	PUSHM.L	D0..D4	LOAD.W	D0,#MVDCLOAD	CLR.L	D2	CLR.L	D3	LOAD.W	D4,#-1	CALL	MODVDCC		; init le mode logique	POPM.L	D0..D4	SUB.L	(A2)+ODFABS,#LGBITS*8	CALL	__GRA_ROLLDOWN	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLDOWN	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLDOWN	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLDOWN	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLDOWN	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLDOWN	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLDOWN	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLDOWN	ADD.L	(A2)+ODFABS,#LGBITS	RET	.ENDIF__GRA_ROLLDOWN:	PUSHM.L	D0..D4,A3,A4	LOAD.W	D0,D4		; D0 <-- dplacement	JUMP,EQ 90$	CLR.L	D3		; D3 <-- origine source	LOAD.W	D4,D0	SWAP.W	D4	CLR.W	D4		; D4 <-- origine destination	LOAD.L	D2,(A2)+ODFFDY	SWAP.W	D2	SUB.W	D2,D0		; D2 <-- dimensions	JUMP',LS 90$	SWAP.W	D2	LOAD.L	A3,#0		; A3 <-- source dans l'cran	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.W	D1,#LOADDOT	; D1 <-- mode	CALL	_GRA_RASTERM	; dplace vers le bas	CLR.L	D4	LOAD.L	D3,D2	SWAP.W	D3	LOAD.W	D3,D0	SWAP.W	D3	CALL	_GRA_CLEAR	; efface en haut90$:	POPM.L	D0..D4,A3,A4	RET;--------------\; _GRA_ROLLLEFT >;==============/; Effectue un roll contre la gauche d'un nombre de points; quelconque dans une fentre.; in	A2.L	^description de la fentre;	D4.W	nb de points  "roller"; out	-; mod	-_GRA_ROLLLEFT:	.IF	COLOR	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP,EQ __GRA_ROLLLEFT	; non => __GRA_ROLLLEFT	PUSH.L	D2	LOAD.L	D2,(A2)+ODFABS	COMP.L	D2,(A2)+ODFCAB	; est-on dans l'cran couleur ?	POPM.L	D2	JUMP,NE __GRA_ROLLLEFT	; non => __GRA_ROLLLEFT	PUSHM.L	D0..D4	LOAD.W	D0,#MVDCLOAD	CLR.L	D2	CLR.L	D3	LOAD.W	D4,#-1	CALL	MODVDCC		; init le mode logique	POPM.L	D0..D4	SUB.L	(A2)+ODFABS,#LGBITS*8	CALL	__GRA_ROLLLEFT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLLEFT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLLEFT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLLEFT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLLEFT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLLEFT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLLEFT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLLEFT	ADD.L	(A2)+ODFABS,#LGBITS	RET	.ENDIF__GRA_ROLLLEFT:	PUSHM.L	D0..D4,A3,A4	LOAD.W	D0,D4		; D0 <-- dplacement	JUMP,EQ 90$	CLR.L	D4		; D4 <-- origine destination	CLR.L	D3	LOAD.W	D3,D0		; D3 <-- origine source	LOAD.L	D2,(A2)+ODFFDY	SUB.W	D2,D0		; D2 <-- dimensions	JUMP',LS 90$	LOAD.L	A3,#0		; A3 <-- source dans l'cran	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.W	D1,#LOADDOT	; D1 <-- mode	CALL	_GRA_RASTERM	; dplace vers la gauche	LOAD.L	D3,D2	ADD.W	D4,D3	LOAD.W	D3,D0	CALL	_GRA_CLEAR	; efface  droite90$:	POPM.L	D0..D4,A3,A4	RET;---------------\; _GRA_ROLLRIGHT >;===============/; Effectue un roll contre la droite d'un nombre de points; quelconque dans une fentre.; in	A2.L	^description de la fentre;	D4.W	nb de points  "roller"; out	-; mod	-_GRA_ROLLRIGHT:	.IF	COLOR	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP,EQ __GRA_ROLLRIGHT	; non => __GRA_ROLLRIGHT	PUSH.L	D2	LOAD.L	D2,(A2)+ODFABS	COMP.L	D2,(A2)+ODFCAB	; est-on dans l'cran couleur ?	POPM.L	D2	JUMP,NE __GRA_ROLLRIGHT	; non => __GRA_ROLLRIGHT	PUSHM.L	D0..D4	LOAD.W	D0,#MVDCLOAD	CLR.L	D2	CLR.L	D3	LOAD.W	D4,#-1	CALL	MODVDCC		; init le mode logique	POPM.L	D0..D4	SUB.L	(A2)+ODFABS,#LGBITS*8	CALL	__GRA_ROLLRIGHT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLRIGHT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLRIGHT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLRIGHT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLRIGHT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLRIGHT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLRIGHT	ADD.L	(A2)+ODFABS,#LGBITS	CALL	__GRA_ROLLRIGHT	ADD.L	(A2)+ODFABS,#LGBITS	RET	.ENDIF__GRA_ROLLRIGHT:	PUSHM.L	D0..D4,A3,A4	LOAD.W	D0,D4		; D0 <-- dplacement	JUMP,EQ 90$	CLR.L	D3		; D3 <-- origine source	CLR.L	D4	LOAD.W	D4,D0		; D4 <-- origine destination	LOAD.L	D2,(A2)+ODFFDY	SUB.W	D2,D0		; D2 <-- dimensions	JUMP',LS 90$	LOAD.L	A3,#0		; A3 <-- source dans l'cran	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.W	D1,#LOADDOT	; D1 <-- mode	CALL	_GRA_RASTERM	; dplace vers la droite	CLR.L	D4	LOAD.L	D3,D2	LOAD.W	D3,D0	CALL	_GRA_CLEAR	; efface  gauche90$:	POPM.L	D0..D4,A3,A4	RET;-----------\; _GRA_EFEOS >;===========/; Efface jusqu' la fin de l'cran.; in	A2.L	^description d'une fentre; out	-; mod	D7.W_GRA_EFEOS:	PUSHM.L	D3,D4	CALL	_GRA_EFLI	; efface jusqu' la fin de la ligne	LOAD.W	D4,(A2)+ODFPY	SUB.W	D4,(A2)+ODFC1Y	ADD.W	D4,(A2)+ODFCY	; D4 <-- position Y depuis o effacer	LOAD.W	D3,(A2)+ODFFDY	SUB.W	D3,D4		; D3 <-- hauteur  effacer	JUMP',LS 90$	SWAP.W	D4	CLR.W	D4	SWAP.W	D3	LOAD.W	D3,(A2)+ODFFDX	CALL	_GRA_CLEAR90$:	POPM.L	D3,D4	RET;-----------\; _GRA_EFLI  >;===========/; Efface jusqu' la fin de la ligne.; in	A2.L	^description d'une fentre; out	-; mod	D7.W_GRA_EFLI:	PUSHM.L	D3,D4	LOAD.L	D4,(A2)+ODFPY	; D4 <-- position curseur typo	SUB.W	D4,(A2)+ODFC1X	; D4 <-- position X  gauche	SWAP.W	D4	SUB.W	D4,(A2)+ODFC1Y	; D4 <-- position Y en haut	SWAP.W	D4	LOAD.W	D3,(A2)+ODFC1Y	ADD.W	D3,(A2)+ODFC2Y	; D3 <-- hauteur  effacer	SWAP.W	D3	LOAD.W	D3,(A2)+ODFFDX	; D3 <-- largeur sous-fentre	SUB.W	D3,D4		; D3 <-- largeur  effacer	CALL	_GRA_CLEAR	POPM.L	D3,D4	RET;-----------\; _GRA_CLEAR >;===========/; Efface rapidement une zone rectangulaire.; in	A2.L	^description d'une fentre;	D4.L	position (y;x);	D3.L	dimensions (dy;dx); out	D7.W	erreur; mod	D7.W_GRA_CLEAR:	PUSHM.L	D1,A3,A4	LOAD.L	A3,(A2)+ODFTPM	CLR.L	(A2)+ODFTPM	; pas de trame spciale	LOAD.L	A4,#R16"TRAME$	; A4 <-- ^trame pour effacer	LOAD.W	D1,#LOADDOT	; D1 <-- mode LOAD	CALL	_GRA_TRAME	; hop, efface	LOAD.L	(A2)+ODFTPM,A3	POPM.L	D1,A3,A4	RETTRAME$:	.B	0,0,0,0,0,0,0,0	; trame pour effacer	.EVEN;---------\; _GRA_INV >;=========/; Inverse rapidement une zone rectangulaire.; in	A2.L	^description d'une fentre;	D4.L	position (y;x);	D3.L	dimensions (dy;dx); out	-; mod	D7.W_GRA_INV:	PUSHM.L	D1,A3,A4	LOAD.L	A3,(A2)+ODFTPM	CLR.L	(A2)+ODFTPM	; pas de trame spciale	LOAD.L	A4,#R16"TRAME$	; A4 <-- ^trame pour inverser	LOAD.W	D1,#INVDOT	; D1 <-- mode inverse	CALL	_GRA_TRAME	; hop, inverse	LOAD.L	(A2)+ODFTPM,A3	POPM.L	D1,A3,A4	RETTRAME$:	.B	-1,-1,-1,-1,-1,-1,-1,-1 ; trame pour inverser	.EVEN;---------\; _GRA_SET >;=========/; Allume rapidement une zone rectangulaire.; in	A2.L	^description d'une fentre;	D4.L	position (y;x);	D3.L	dimensions (dy;dx); out	-; mod	D7.W_GRA_SET:	PUSHM.L	D1,A3,A4	LOAD.L	A3,(A2)+ODFTPM	CLR.L	(A2)+ODFTPM	; pas de trame spciale	LOAD.L	A4,#R16"TRAME$	; A4 <-- ^trame pour allumer	LOAD.W	D1,#LOADDOT	; D1 <-- mode LOAD	CALL	_GRA_TRAME	; hop, allume	LOAD.L	(A2)+ODFTPM,A3	POPM.L	D1,A3,A4	RETTRAME$:	.B	-1,-1,-1,-1,-1,-1,-1,-1 ; trame pour allumer	.EVEN	.END