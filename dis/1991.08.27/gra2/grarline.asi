	.SBTTL	GRARLINE;-----------\\; _GRA_RLINE >;===========/; Trace un segment de droite rapidement, avec des nombres rels.; in	A2.L	^description de la fentre;	A4.L	^Oy,Ox,Dy,Dx (nb rels .L);	D1.B	mode (INVDOT, SETDOT ou CLRDOT); out	D7.W	erreur; mod	D7.W_GRA_RLINE:	PUSHM.L	D0..D7,A0,A1,A3	CALL	ADOTRLINE	; A3 <-- ^routine selon mode	LOAD.L	D3,(A4)+4	; D3 <-- Ox	LOAD.L	D4,(A4)+0	; D4 <-- Oy	LOAD.L	D1,(A4)+12	; D1 <-- Dx	LOAD.L	D2,(A4)+8	; D2 <-- Dy	ADD.L	D1,D3		; D1 <-- Fx	ADD.L	D2,D4		; D2 <-- Fy	SWAP.W	D4	SWAP.W	D2	COMP.W	D2,D4		; y1 = y2 ?	JUMP,NE	NOTSAMEY$	; non => NOTSAMEY$	SWAP.W	D3	SWAP.W	D1	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit	NOT.B	D0		; D0 <-- bit 7  gauche !	AND.W	D0,#B'111	; D0 <-- no du bit dans le byte	LOAD.W	D6,D4	LOAD.W	D5,D3	LOAD.W	D4,D1	COMP.W	D5,D4	JUMP,EQ DOT$	JUMP,GT LEFT$RIGHT$:	INC.W	D4		; D4 <-- met encore un point tout  droite	CALL	(A3)		; met qq points	JUMP	EXIT$LEFT$:	DEC.W	D4		; D4 <-- met encore un point tout  gauche	CALL	(A3)		; met qq points	JUMP	EXIT$DOT$:	CALL	(A3)		; met qq points	JUMP	EXIT$NOTSAMEY$:	SWAP.W	D4	SWAP.W	D2	PUSHM.L	D1,D2	SUB.L	D1,D3		; D1 <-- x2-x1	SUB.L	D2,D4		; D2 <-- y2-y1	EX.L	D1,D2	CALL	FIXDIV		; D0 <-- D1/D2	LOAD.L	D7,D0		; D7 <-- pente en fractionnaire	POPM.L	D1,D2	SWAP.W	D4	SWAP.W	D2	COMP.W	D4,D2		; est-ce qu'on descend ?	JUMP,LT DOWN$		; oui => DOWN$	EX.L	D2,D4		; y2 <--> y1	EX.L	D1,D3		; x2 <--> x1DOWN$:	SWAP.W	D4	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	CALL	GETPBNBW	; A0 <-- ^byte, D0 <-- no bit	NOT.B	D0		; D0 <-- bit 7  gauche !	AND.W	D0,#B'111	; D0 <-- no du bit dans le byte	SWAP.W	D4	SWAP.W	D3	LOAD.L	D6,D4		; D6 <-- y1	PUSHM.L	D0..D2	LOAD.L	D1,D4	CLR.W	D1	ADD.L	D1,#H'10000	; D1 <-- roundup(y1)	SUB.L	D1,D4		; D1 <-- roundup(y1)-y1	LOAD.L	D2,D7		; D2 <-- pente	CALL	FIXMUL		; D0 <-- D1*D2	LOAD.L	D4,D0		; D4 <-- dbut de la ligne suivante (x1)	POPM.L	D0..D2	ADD.L	D4,D3		; D4 <-- x1 + fraction restant en-haut	SWAP.W	D3	LOAD.W	D5,D3		; D5 <-- x1	SWAP.W	D6	SWAP.W	D2	SWAP.W	D1	LOAD.W	A1,(A2)+ODFIIY	; A1 <-- IyNEXT$:	SWAP.W	D4	CALL	(A3)		; met qq points	LOAD.W	D5,D4		; D5 <-- nouveau x1	SWAP.W	D4	ADD.W	A0,A1		; A0 <-- descend de 1 point	INC.W	D6		; D6 <-- descend de 1 point	ADD.L	D4,D7		; D4 <-- additionne le ratio	COMP.W	D6,D2		; y1 courant = y2 ?	JUMP,LT	NEXT$		; non => traite l'y1 suivant	LOAD.W	D5,D1	LOAD.W	D4,D1	CALL	(A3)		; met le point d'arriveEXIT$:	POPM.L	D0..D7,A0,A1,A3	CLR.W	D7		; D7 <-- ok	RET;----------\; ADOTRLINE >;----------/; Donne l'adresse de la routine de traitement rapide d'une ligne; horizontale de points.; in	A2.L	^descripteur de la fentre;	D1.B	opration (INVDOT, SETDOT ou CLRDOT); out	A3.L	^routine "dot"; mod	D1.B, A3.LADOTRLINE:	TCLR.L	D1:#BNCTDOT	; rz du compteur ?	JUMP',BS 10$		; non => 10$	CLR.W	(A2)+ODFTTC	; rz compteur pour  - - -10$:	TCLR.L	D1:#BPENDOT	; utilise le pinceau ?	JUMP',BS 50$		; oui => 50$				; non =>	TCLR.L	D1:#BTTTDOT	; trait selon map ?	JUMP',BS 20$		; oui => 20$				; non =>	LOAD.L	A3,#R16"DOTRLSET	COMP.B	D1,#SETDOT	JUMP,EQ 90$	LOAD.L	A3,#R16"DOTRLCLR	COMP.B	D1,#CLRDOT	JUMP,EQ 90$	LOAD.L	A3,#R16"DOTRLINV ; inverse par dfaut	JUMP	90$20$:	LOAD.L	A3,#R16"DOTRLSETT	COMP.B	D1,#SETDOT	JUMP,EQ 90$	LOAD.L	A3,#R16"DOTRLCLRT	COMP.B	D1,#CLRDOT	JUMP,EQ 90$	LOAD.L	A3,#R16"DOTRLINVT ; inverse par dfaut	JUMP	90$50$:	LOAD.W	(A2)+ODFVAR+OVAROY,#H'7FFF ; Yold n'existe pas encore	TEST.L	(A2)+ODFPPM	; pinceau selon XPEN ?	JUMP',NE 60$		; oui => 60$	TCLR.L	D1:#BTTTDOT	; trait selon map ?	JUMP',BS 55$		; oui => 55$				; non =>	LOAD.L	A3,#R16"DOTRLSETP	COMP.B	D1,#SETDOT	JUMP',EQ 90$	LOAD.L	A3,#R16"DOTRLCLRP	COMP.B	D1,#CLRDOT	JUMP',EQ 90$	LOAD.L	A3,#R16"DOTRLINVP	JUMP'	90$55$:	LOAD.L	A3,#R16"DOTRLSETPT	COMP.B	D1,#SETDOT	JUMP',EQ 90$	LOAD.L	A3,#R16"DOTRLCLRPT	COMP.B	D1,#CLRDOT	JUMP',EQ 90$	LOAD.L	A3,#R16"DOTRLINVPT	JUMP'	90$60$:	TCLR.L	D1:#BTTTDOT	; trait selon map ?	JUMP',BS 65$		; oui => 65$				; non =>	LOAD.L	A3,#R16"DOTRLSETX	COMP.B	D1,#SETDOT	JUMP',EQ 90$	LOAD.L	A3,#R16"DOTRLCLRX	COMP.B	D1,#CLRDOT	JUMP',EQ 90$	LOAD.L	A3,#R16"DOTRLINVX	JUMP'	90$65$:	LOAD.L	A3,#R16"DOTRLSETXT	COMP.B	D1,#SETDOT	JUMP',EQ 90$	LOAD.L	A3,#R16"DOTRLCLRXT	COMP.B	D1,#CLRDOT	JUMP',EQ 90$	LOAD.L	A3,#R16"DOTRLINVXT;	JUMP'	90$90$:	RET;---------\\; DOTRL... >;---------/; Traitement rapide d'une ligne horizontale de points.; in	D5.W	x1;	D4.W	x2;	D6.W	y;	A0/D0	^byte/bit; out	A0/D0	^byte/bit; mod	D0.L, D5.L, A0.LDOTRLINV:	SUB.W	D5,D4	JUMP',GT LEFT$	JUMP',NE RIGHT$	TNOT.B	(A0):D0	RETRIGHT$:	TNOT.B	(A0):D0	DEC.B	D0		; x <-- x+1	JUMP',PL RSAME$	LOAD.L	D0,#7	INC.L	A0RSAME$:	INC.W	D5	JUMP,NE RIGHT$	RETLEFT$:	TNOT.B	(A0):D0	INC.B	D0		; x <-- x-1	COMP.B	D0,#8	JUMP',LT LSAME$	CLR.B	D0	DEC.L	A0LSAME$:	DEC.W	D5	JUMP,NE LEFT$	RETDOTRLSET:	SUB.W	D5,D4	JUMP',GT LEFT$	JUMP',NE RIGHT$	TSET.B	(A0):D0	RETRIGHT$:	TSET.B	(A0):D0	DEC.B	D0		; x <-- x+1	JUMP',PL RSAME$	LOAD.L	D0,#7	INC.L	A0RSAME$:	INC.W	D5	JUMP,NE RIGHT$	RETLEFT$:	TSET.B	(A0):D0	INC.B	D0		; x <-- x-1	COMP.B	D0,#8	JUMP',LT LSAME$	CLR.B	D0	DEC.L	A0LSAME$:	DEC.W	D5	JUMP,NE LEFT$	RETDOTRLCLR:	SUB.W	D5,D4	JUMP',GT LEFT$	JUMP',NE RIGHT$	TCLR.B	(A0):D0	RETRIGHT$:	TCLR.B	(A0):D0	DEC.B	D0		; x <-- x+1	JUMP',PL RSAME$	LOAD.L	D0,#7	INC.L	A0RSAME$:	INC.W	D5	JUMP,NE RIGHT$	RETLEFT$:	TCLR.B	(A0):D0	INC.B	D0		; x <-- x-1	COMP.B	D0,#8	JUMP',LT LSAME$	CLR.B	D0	DEC.L	A0LSAME$:	DEC.W	D5	JUMP,NE LEFT$	RETDOTRLINVT:	SUB.W	D5,D4	JUMP',GT LEFT$	JUMP',NE RIGHT$	CALL	IFDOT		; point allum ?	JUMP',BC OSKIP$	TNOT.B	(A0):D0OSKIP$:	RETRIGHT$:	CALL	IFDOT		; point allum ?	JUMP',BC RSKIP$	TNOT.B	(A0):D0RSKIP$:	DEC.B	D0		; x <-- x+1	JUMP',PL RSAME$	LOAD.L	D0,#7	INC.L	A0RSAME$:	INC.W	D5	JUMP,NE RIGHT$	RETLEFT$:	CALL	IFDOT		; point allum ?	JUMP',BC LSKIP$	TNOT.B	(A0):D0LSKIP$:	INC.B	D0		; x <-- x-1	COMP.B	D0,#8	JUMP',LT LSAME$	CLR.B	D0	DEC.L	A0LSAME$:	DEC.W	D5	JUMP,NE LEFT$	RETDOTRLSETT:	SUB.W	D5,D4	JUMP',GT LEFT$	JUMP',NE RIGHT$	CALL	IFDOT		; point allum ?	JUMP',BC OSKIP$	TSET.B	(A0):D0OSKIP$:	RETRIGHT$:	CALL	IFDOT		; point allum ?	JUMP',BC RSKIP$	TSET.B	(A0):D0RSKIP$:	DEC.B	D0		; x <-- x+1	JUMP',PL RSAME$	LOAD.L	D0,#7	INC.L	A0RSAME$:	INC.W	D5	JUMP,NE RIGHT$	RETLEFT$:	CALL	IFDOT		; point allum ?	JUMP',BC LSKIP$	TSET.B	(A0):D0LSKIP$:	INC.B	D0		; x <-- x-1	COMP.B	D0,#8	JUMP',LT LSAME$	CLR.B	D0	DEC.L	A0LSAME$:	DEC.W	D5	JUMP,NE LEFT$	RETDOTRLCLRT:	SUB.W	D5,D4	JUMP',GT LEFT$	JUMP',NE RIGHT$	CALL	IFDOT		; point allum ?	JUMP',BC OSKIP$	TCLR.B	(A0):D0OSKIP$:	RETRIGHT$:	CALL	IFDOT		; point allum ?	JUMP',BC RSKIP$	TCLR.B	(A0):D0RSKIP$:	DEC.B	D0		; x <-- x+1	JUMP',PL RSAME$	LOAD.L	D0,#7	INC.L	A0RSAME$:	INC.W	D5	JUMP,NE RIGHT$	RETLEFT$:	CALL	IFDOT		; point allum ?	JUMP',BC LSKIP$	TCLR.B	(A0):D0LSKIP$:	INC.B	D0		; x <-- x-1	COMP.B	D0,#8	JUMP',LT LSAME$	CLR.B	D0	DEC.L	A0LSAME$:	DEC.W	D5	JUMP,NE LEFT$	RETDOTRLINVP:	PUSHM.L	D4,D6,D7	LOAD.W	D3,D5	EX.L	D4,D6	SUB.W	D5,D6	JUMP',GT LEFT$	JUMP',NE RIGHT$	LOAD.W	D5,#-1RIGHT$:	CALL	PENXYINV	INC.W	D3	INC.W	D5	JUMP,NE RIGHT$	JUMP'	END$LEFT$:	CALL	PENXYINV	DEC.W	D3	DEC.W	D5	JUMP,NE LEFT$;	JUMP'	END$END$:	POPM.L	D4,D6,D7	RETDOTRLSETP:	PUSHM.L	D4,D6,D7	LOAD.W	D3,D5	EX.L	D4,D6	SUB.W	D5,D6	JUMP',GT LEFT$	JUMP',NE RIGHT$	LOAD.W	D5,#-1RIGHT$:	CALL	PENXYSET	INC.W	D3	INC.W	D5	JUMP,NE RIGHT$	JUMP'	END$LEFT$:	CALL	PENXYSET	DEC.W	D3	DEC.W	D5	JUMP,NE LEFT$;	JUMP'	END$END$:	POPM.L	D4,D6,D7	RETDOTRLCLRP:	PUSHM.L	D4,D6,D7	LOAD.W	D3,D5	EX.L	D4,D6	SUB.W	D5,D6	JUMP',GT LEFT$	JUMP',NE RIGHT$	LOAD.W	D5,#-1RIGHT$:	CALL	PENXYCLR	INC.W	D3	INC.W	D5	JUMP,NE RIGHT$	JUMP'	END$LEFT$:	CALL	PENXYCLR	DEC.W	D3	DEC.W	D5	JUMP,NE LEFT$;	JUMP'	END$END$:	POPM.L	D4,D6,D7	RETDOTRLINVPT:	PUSHM.L	D4,D6,D7	LOAD.W	D3,D5	EX.L	D4,D6	SUB.W	D5,D6	JUMP',GT LEFT$	JUMP',NE RIGHT$	LOAD.W	D5,#-1RIGHT$:	CALL	IFDOT		; point allum ?	JUMP',BC RSKIP$	CALL	PENXYINVRSKIP$:	INC.W	D3	INC.W	D5	JUMP,NE RIGHT$	JUMP'	END$LEFT$:	CALL	IFDOT		; point allum ?	JUMP',BC LSKIP$	CALL	PENXYINVLSKIP$:	DEC.W	D3	DEC.W	D5	JUMP,NE LEFT$;	JUMP'	END$END$:	POPM.L	D4,D6,D7	RETDOTRLSETPT:	PUSHM.L	D4,D6,D7	LOAD.W	D3,D5	EX.L	D4,D6	SUB.W	D5,D6	JUMP',GT LEFT$	JUMP',NE RIGHT$	LOAD.W	D5,#-1RIGHT$:	CALL	IFDOT		; point allum ?	JUMP',BC RSKIP$	CALL	PENXYSETRSKIP$:	INC.W	D3	INC.W	D5	JUMP,NE RIGHT$	JUMP'	END$LEFT$:	CALL	IFDOT		; point allum ?	JUMP',BC LSKIP$	CALL	PENXYSETLSKIP$:	DEC.W	D3	DEC.W	D5	JUMP,NE LEFT$;	JUMP'	END$END$:	POPM.L	D4,D6,D7	RETDOTRLCLRPT:	PUSHM.L	D4,D6,D7	LOAD.W	D3,D5	EX.L	D4,D6	SUB.W	D5,D6	JUMP',GT LEFT$	JUMP',NE RIGHT$	LOAD.W	D5,#-1RIGHT$:	CALL	IFDOT		; point allum ?	JUMP',BC RSKIP$	CALL	PENXYCLRRSKIP$:	INC.W	D3	INC.W	D5	JUMP,NE RIGHT$	JUMP'	END$LEFT$:	CALL	IFDOT		; point allum ?	JUMP',BC LSKIP$	CALL	PENXYCLRLSKIP$:	DEC.W	D3	DEC.W	D5	JUMP,NE LEFT$;	JUMP'	END$END$:	POPM.L	D4,D6,D7	RETDOTRLINVX:	PUSHM.L	D4,D6,D7	LOAD.W	D3,D5	EX.L	D4,D6	SUB.W	D5,D6	JUMP',GT LEFT$	JUMP',NE RIGHT$	LOAD.W	D5,#-1RIGHT$:	CALL	XPENXYINV	INC.W	D3	INC.W	D5	JUMP,NE RIGHT$	JUMP'	END$LEFT$:	CALL	XPENXYINV	DEC.W	D3	DEC.W	D5	JUMP,NE LEFT$;	JUMP'	END$END$:	POPM.L	D4,D6,D7	RETDOTRLSETX:	PUSHM.L	D4,D6,D7	LOAD.W	D3,D5	EX.L	D4,D6	SUB.W	D5,D6	JUMP',GT LEFT$	JUMP',NE RIGHT$	LOAD.W	D5,#-1RIGHT$:	CALL	XPENXYSET	INC.W	D3	INC.W	D5	JUMP,NE RIGHT$	JUMP'	END$LEFT$:	CALL	XPENXYSET	DEC.W	D3	DEC.W	D5	JUMP,NE LEFT$;	JUMP'	END$END$:	POPM.L	D4,D6,D7	RETDOTRLCLRX:	PUSHM.L	D4,D6,D7	LOAD.W	D3,D5	EX.L	D4,D6	SUB.W	D5,D6	JUMP',GT LEFT$	JUMP',NE RIGHT$	LOAD.W	D5,#-1RIGHT$:	CALL	XPENXYCLR	INC.W	D3	INC.W	D5	JUMP,NE RIGHT$	JUMP'	END$LEFT$:	CALL	XPENXYCLR	DEC.W	D3	DEC.W	D5	JUMP,NE LEFT$;	JUMP'	END$END$:	POPM.L	D4,D6,D7	RETDOTRLINVXT:	PUSHM.L	D4,D6,D7	LOAD.W	D3,D5	EX.L	D4,D6	SUB.W	D5,D6	JUMP',GT LEFT$	JUMP',NE RIGHT$	LOAD.W	D5,#-1RIGHT$:	CALL	IFDOT		; point allum ?	JUMP',BC RSKIP$	CALL	XPENXYINVRSKIP$:	INC.W	D3	INC.W	D5	JUMP,NE RIGHT$	JUMP'	END$LEFT$:	CALL	IFDOT		; point allum ?	JUMP',BC LSKIP$	CALL	XPENXYINVLSKIP$:	DEC.W	D3	DEC.W	D5	JUMP,NE LEFT$;	JUMP'	END$END$:	POPM.L	D4,D6,D7	RETDOTRLSETXT:	PUSHM.L	D4,D6,D7	LOAD.W	D3,D5	EX.L	D4,D6	SUB.W	D5,D6	JUMP',GT LEFT$	JUMP',NE RIGHT$	LOAD.W	D5,#-1RIGHT$:	CALL	IFDOT		; point allum ?	JUMP',BC RSKIP$	CALL	XPENXYSETRSKIP$:	INC.W	D3	INC.W	D5	JUMP,NE RIGHT$	JUMP'	END$LEFT$:	CALL	IFDOT		; point allum ?	JUMP',BC LSKIP$	CALL	XPENXYSETLSKIP$:	DEC.W	D3	DEC.W	D5	JUMP,NE LEFT$;	JUMP'	END$END$:	POPM.L	D4,D6,D7	RETDOTRLCLRXT:	PUSHM.L	D4,D6,D7	LOAD.W	D3,D5	EX.L	D4,D6	SUB.W	D5,D6	JUMP',GT LEFT$	JUMP',NE RIGHT$	LOAD.W	D5,#-1RIGHT$:	CALL	IFDOT		; point allum ?	JUMP',BC RSKIP$	CALL	XPENXYCLRRSKIP$:	INC.W	D3	INC.W	D5	JUMP,NE RIGHT$	JUMP'	END$LEFT$:	CALL	IFDOT		; point allum ?	JUMP',BC LSKIP$	CALL	XPENXYCLRLSKIP$:	DEC.W	D3	DEC.W	D5	JUMP,NE LEFT$;	JUMP'	END$END$:	POPM.L	D4,D6,D7	RET	.END