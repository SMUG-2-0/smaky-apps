	.SBTTL	GRATRAME; Variables de GRA_TRAME sur le stack; -----------------------------------	.PC	PCVAR	.LOC	0TRAMMA1:.BLKB	2		; masque de dbutTRAMNBW:.BLKB	2		; nb de words -1TRAMMOT:.BLKB	64		; trame tendue (32x16)TRAMRGR:.BLKB	1		; <>0 si rgion non rectangulaire	.BLKB	1		; rserveTRAMPOY:.BLKB	2		; position en YTRAMCHY:.BLKB	2		; prochain Y ayant un changementTRAMASK:.BLKB	4		; ^appel GMI_SEEKSRGNTRAMLSK:.BLKB	4		; ^ligne de masqueTRAMLGV:			; lg des variables	.PC	PCCODE;-----------\; _GRA_TRAME >;===========/; Rempli une surface rectangulaire avec une trame 8x8.; La trame est toujours aligne (horizontalement et verticalement);  une position modulo 8 pour rsoudre les problmes de jointures; entre deux trames.; in	A2.L	^description de la fentre;	D4.L	coordonnes y;x dbut (coin sup/gauche);	D3.L	delta y;x;	D1.B	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT);	A4.L	^trame 8x8; out	D7.W	erreur; mod	D7.W_GRA_TRAME:	PUSHM.L	D0..D6,A0..A6	SUB.L	SP,#TRAMLGV	; stack <-- place pour variables	CLR.B	(SP)+TRAMRGR	; rgion rectangulaire; Effectue ventuellement un clipping si le rectangle dborde.	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la fentre	TEST.W	D3	JUMP,LE TRAME_EXIT	TEST.W	D4		; dpasse  gauche ?	JUMP',NC NoLeft$	ADD.W	D3,D4	JUMP,LE TRAME_EXIT	CLR.W	D4NoLeft$:	LOAD.W	D0,D4	ADD.W	D0,D3	SUB.W	D0,(A2)+ODFFDX	; dpasse  droite ?	JUMP',LS NoRight$	SUB.W	D3,D0	JUMP,LE TRAME_EXITNoRight$:	SWAP.W	D3	SWAP.W	D4	TEST.W	D3	JUMP,LE TRAME_EXIT	TEST.W	D4		; dpasse en haut ?	JUMP',NC NoUp$	ADD.W	D3,D4	JUMP,LE TRAME_EXIT	CLR.W	D4NoUp$:	LOAD.W	D0,D4	ADD.W	D0,D3	SUB.W	D0,(A2)+ODFFDY	; dpasse en bas ?	JUMP',LS NoDown$	SUB.W	D3,D0	JUMP,LE TRAME_EXITNoDown$:	SWAP.W	D3	SWAP.W	D4; Regarde si la trame doit tre dessine avec le raster-op.	TEST.L	(A2)+ODFTPM	; trame spciale ?	JUMP',EQ TNorm$		; non => TNorm$	TEST.L	(A2)+ODFTPO	JUMP,NE TRAME_SPEC	LOAD.W	D2,(A2)+ODFTDI+2 ; D2 <-- largeur de la trame	COMP.W	D2,(A2)+ODFTDI+0 ; largeur = hauteur ?	JUMP,NE TRAME_SPEC	 ; non => TRAME_SPEC	COMP.W	D2,#2	JUMP',EQ TNorm$	COMP.W	D2,#4	JUMP',EQ TNorm$	COMP.W	D2,#8	JUMP',EQ TNorm$	COMP.W	D2,#16	JUMP,NE TRAME_SPECTNorm$:; Effectue ventuellement un clipping selon la rgion.	TEST.L	(A2)+ODFCRG	; rgion dfinie ?	JUMP,EQ NoRgn$		; non => NoRgn$	SUB.L	SP,#2+4+4	PUSH.L	(A2)+ODFCRG	PUSH.L	#(SP)+4+2	GMI_	RGNBBOX		; calcule la bounding-box de la rgion	LOAD.W	D0,(SP)+2+2	; D0 <-- p1(x)	SUB.W	D0,(A2)+ODFFX	COMP.W	D4,D0	JUMP',GE RgLeft$	SUB.W	D4,D0	ADD.W	D3,D4	JUMP,LE NoSect$	LOAD.W	D4,D0RgLeft$:	LOAD.W	D0,(SP)+2+6	; D0 <-- p2(x)	SUB.W	D0,(A2)+ODFFX	SUB.W	D0,D4	JUMP,LE NoSect$	COMP.W	D3,D0	JUMP',LE RgRight$	LOAD.W	D3,D0RgRight$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,(SP)+2+0	; D0 <-- p1(y)	SUB.W	D0,(A2)+ODFFY	COMP.W	D4,D0	JUMP',GE RgUp$	SUB.W	D4,D0	ADD.W	D3,D4	JUMP',LE NoSect$	LOAD.W	D4,D0RgUp$:	LOAD.W	D0,(SP)+2+4	; D0 <-- p2(y)	SUB.W	D0,(A2)+ODFFY	SUB.W	D0,D4	JUMP',LE NoSect$	COMP.W	D3,D0	JUMP',LE RgDown$	LOAD.W	D3,D0	JUMP'	RgDown$NoSect$:	ADD.L	SP,#2+4+4	JUMP	TRAME_EXITRgDown$:	SWAP.W	D3	SWAP.W	D4	POP.B	(SP)+4+4+TRAMRGR	ADD.L	SP,#4+4	TEST.B	(SP)+TRAMRGR	; rgion rectangulaire ?	JUMP',EQ NoRgn$		; oui => NoRgn$	SUB.L	SP,#LgBldRgn	LOAD.B	(SP)+TRAMRGR,#1	; rgion (sans) complexe	SUB.L	SP,#2		; stack <-- place pour erreur en retour	PUSH.L	(A2)+ODFCRG	; stack <-- id rgion	PUSH.L	#(SP)+2+4+TRAMLGV ; stack <-- ^variables	LOAD.W	D0,D4	ADD.W	D0,(A2)+ODFFX	PUSH.W	D0		; stack <-- left masque	ADD.W	D0,D3	PUSH.W	D0		; stack <-- right masque	LOAD.W	D0,D4	ADD.W	D0,(A2)+ODFFX	AND.B	D0,#B'11110000	PUSH.W	D0		; stack <-- dbut dans le masque	PUSH.B	#0		; stack <-- 0 de haut en bas	PUSH.L	#(SP)+2+2+2+2+4+4+2+TRAMASK ; TRAMASK <-- ^routine "seek"	GMI_	INITSRGN	POP.W	D7		; D7 <-- ok/erreur	JUMP,NE TRAME_EXIT	LOAD.L	D0,D4	SWAP.W	D0	ADD.W	D0,(A2)+ODFFY	LOAD.W	(SP)+TRAMPOY,D0	LOAD.W	(SP)+TRAMCHY,D0NoRgn$:	TEST.L	(A2)+ODFTPM	; trame spciale ?	JUMP',EQ TTNorm$	; non => TTNorm$	LOAD.W	D2,(A2)+ODFTDI+2 ; D2 <-- largeur de la trame	COMP.W	D2,#2	JUMP,EQ TRAME_2x2	COMP.W	D2,#4	JUMP,EQ TRAME_4x4	COMP.W	D2,#8	JUMP,EQ TRAME_8x8	COMP.W	D2,#16	JUMP,EQ TRAME_16x16TTNorm$:; Etend la trame 8x8 en une trame 32x16.	CLR.B	D6		; D6 <-- pas d'inversion	TEST.L	D1:#BCPLDOT	JUMP',BC 10$	NOT.B	D6		; D6 <-- inverse la trame10$:	AND.W	D1,#H'0003	; D1 <-- mode LOAD/INV/SET/CLR	COMP.B	D1,#CLRDOT	JUMP',NE 12$	NOT.B	D6		; D6 <-- inverse la trame si CLRDOT !12$:	LOAD.W	D7,(A2)+ODFFX	AND.W	D7,#H'0007	; D7 <-- dcalage selon origine fentre en X	LOAD.L	A3,#(SP)+TRAMMOT	LOAD.W	D5,#8-114$:	LOAD.B	D0,(A4+)	; D0 <-- un byte de la trame	RR.B	D0,D7		; D0 <-- v. dcale selon origine fentre	XOR.B	D0,D6		; D0 <-- v. inverse	LOAD.B	(A3+),D0	LOAD.B	(A3+),D0	LOAD.W	(A3+),(A3)-2	LOAD.L	(A3)+32-4,(A3)-4	DECJ.W,NMO D5,14$	LOAD.L	A3,#(SP)+TRAMMOT ; A3 <-- ^trame 32x16	LOAD.L	D7,D4	SWAP.W	D7	ADD.W	D7,(A2)+ODFFY	AND.W	D7,#H'000F	; D7 <-- ^relatif ligne trame	SL.W	D7,#2		; D7 <-- *4 car trame de 32 bits de large; Calcule l'adresse dans l'cran.TRAME_QUICK:	LOAD.L	D2,D3		; D2 <-- dimensions (dy;dx)	LOAD.L	D3,D4		; D4 <-- X	SWAP.W	D3		; D3 <-- Y	LOAD.W	D6,(A2)+ODFIIY	; D6 <-- Iy	ADD.W	D4,(A2)+ODFWBX	; D4 <-- coordonne x absolue dans bitmap	ADD.W	D3,(A2)+ODFWBY	; D3 <-- coordonne y absolue dans bitmap	LOAD.L	A4,(A2)+ODFABS	; A4 <-- adresse dbut cran	LOAD.W	D0,D4	SR.W	D0,#3		; dcale coordonne X	ADD.W	A4,D0	MUL.WU	D3,D6		; dcale coordonne Y	ADD.L	A4,D3		; A4 <-- adresse dans l'cran	AND.W	D4,#B'111	; D4 <-- Dd	LOAD.W	A6,D6		; A6 <-- Iy	LOAD.W	D0,A6	TEST.L	D0:#0		; Iy impair ?	JUMP,BS 60$		; oui => 60$; Calcule l'adresse de la routine de gestion d'une ligne.	LOAD.L	A0,#R16"TATRAME_OP;	AND.W	D1,#H'0003	SL.W	D1,#1	TEST.B	(SP)+TRAMRGR	; rgion rectangulaire ?	JUMP',EQ 40$		; oui => 40$	ADD.W	D1,#4*240$:	ADD.W	A0,(A0)+(D1.W)	; A0 <-- ^routine ligne; Si l'adresse n'est pas paire, recule d'un byte.	LOAD.W	D0,A4	RR.W	D0,#1	JUMP',CC 42$	DEC.L	A4		; A4 <-- adresse paire	ADD.W	D4,#8		; D4 <-- Dd42$:; Calcule le nombre de lignes  traiter.	LOAD.L	D5,D2	SWAP.W	D5		; D5 <-- hauteur	DEC.W	D5		; D5 <-- -1  cause NMO; Calcule le nombre de tranches de 16 bits.	LOAD.W	D1,D2	ADD.W	D1,D4		; D1 <-- Dd + largeur	DEC.W	D1	SR.W	D1,#4		; D1 <-- nb de words -1	LOAD.W	(SP)+TRAMNBW,D1	INC.W	D1	SL.W	D1,#1	SUB.W	A6,D1		; A6 <-- Iy - nb de bytes; Calcule les masques de dbut et de fin.	LOAD.L	A1,#R16"TATRAME_MASK	LOAD.W	D1,D4	SL.W	D1,#1	LOAD.W	D1,(A1)+(D1.W)	; D1 <-- masque de dbut	LOAD.W	(SP)+TRAMMA1,D1	ADD.W	D2,D4		; D2 <-- Dd + largeur	AND.W	D2,#H'000F	SL.W	D2,#1	LOAD.W	D2,(A1)+(D2.W)+32 ; D2 <-- masque de fin	JUMP	TRAME_LOOP; Calcule l'adresse de la routine de gestion d'une ligne,; dans le cas o Iy source ou destination est impair.60$:	LOAD.L	A0,#R16"TATRAME_OP	AND.W	D1,#H'0003	SL.W	D1,#1	ADD.W	D1,#8*2	TEST.B	(SP)+TRAMRGR	; rgion rectangulaire ?	JUMP',EQ 61$		; oui => 61$	ADD.W	D1,#4*261$:	ADD.W	A0,(A0)+(D1.W)	; A0 <-- ^routine ligne; Calcule le nombre de lignes  traiter.	LOAD.L	D5,D2	SWAP.W	D5		; D5 <-- hauteur	TEST.W	D5	JUMP',NC 63$	NEG.W	D5	EX.L	D5,A6	NEG.W	D5		; A6 <-- -A6	EX.L	A6,D563$:	DEC.W	D5		; D5 <-- -1  cause NMO; Calcule le nombre de tranches de 8 bits.	LOAD.W	D1,D2	ADD.W	D1,D4		; D1 <-- Dd + largeur	DEC.W	D1	SR.W	D1,#3		; D1 <-- nb de bytes -1	LOAD.W	(SP)+TRAMNBW,D1	INC.W	D1	SUB.W	A6,D1		; A6 <-- Iy - nb de bytes; Calcule les masques de dbut et de fin.	LOAD.L	A1,#R16"TATRAME_MASK	LOAD.W	D1,D4	SL.W	D1,#1	LOAD.B	D1,(A1)+(D1.W)	; D1 <-- masque de dbut	LOAD.W	(SP)+TRAMMA1,D1	ADD.W	D2,D4		; D2 <-- Dd + largeur	AND.W	D2,#H'0007	SL.W	D2,#1	LOAD.B	D2,(A1)+(D2.W)+32 ; D2 <-- masque de fin; Calcule le nombre de dcalages  droite.;	JUMP	TRAME_LOOP; Boucle principale de traitement des lignes.TRAME_LOOP:	LOAD.W	D1,(SP)+TRAMMA1	; D1 <-- masque de dbut	LOAD.W	D3,(SP)+TRAMNBW	; D3 <-- nombre de words -1	LOAD.L	D4,(A3)+(D7.W)	; D4 <-- trame	ADD.W	D7,#4		; D7 <-- offset suivant	AND.W	D7,#H'003F	; D7 <-- (0..15)*4	JUMP	(A0)		; traite une ligneTRAME_RETURN:	ADD.W	A4,A6		; A4 <-- ^ligne suivante	DECJ.W,NMO D5,TRAME_LOOP	CLR.W	D7		; D7 <-- okTRAME_EXIT:	TEST.B	(SP)+TRAMRGR	; rgion rectangulaire ?	JUMP',EQ 20$		; oui => 20$	SUB.L	SP,#2		; stack <-- place pour erreur en retour	PUSH.L	#(SP)+2+TRAMLGV	; stack <-- ^variables	GMI_	RELSRGN	POP.W	D7		; D7 <-- ok/erreur	ADD.L	SP,#LgBldRgn20$:	ADD.L	SP,#TRAMLGV	; ajuste le stack	POPM.L	D0..D6,A0..A6	AND.L	D7,#H'0000FFFF	; D7 <-- !	RET; (1)	transfert par words rectangulaire; (2)	transfert par words selon rgion; (3)	transfert par bytes rectangulaire; (4)	transfert par bytes selon rgionTATRAME_OP:	.W	TRAME_LOAD1-TATRAME_OP	.W	TRAME_INV1-TATRAME_OP	.W	TRAME_SET1-TATRAME_OP	.W	TRAME_CLR1-TATRAME_OP	.W	TRAME_LOAD2-TATRAME_OP	.W	TRAME_INV2-TATRAME_OP	.W	TRAME_SET2-TATRAME_OP	.W	TRAME_CLR2-TATRAME_OP	.W	TRAME_LOAD3-TATRAME_OP	.W	TRAME_INV3-TATRAME_OP	.W	TRAME_SET3-TATRAME_OP	.W	TRAME_CLR3-TATRAME_OP	.W	TRAME_LOAD4-TATRAME_OP	.W	TRAME_INV4-TATRAME_OP	.W	TRAME_SET4-TATRAME_OP	.W	TRAME_CLR4-TATRAME_OP;----------;; TRAME_op ;;----------;; Traite une ligne dans un mode quelconque.; in	D1.W	masque de dbut;	D2.W	masque de fin;	D3.W	nombre de words -1;	D4.L	trame;	A4.L	^destination; out	-; mod	D0.L, D1.L, D3.L, A4.LTRAME_INV1:	DEC.W	D3	JUMP',NS 40$	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	XOR.W	(A4+),D0	; destination <-- trame	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	TEST.W	D3	JUMP',EQ 40$	TCLR.L	D3:#0	JUMP',BC 30$	XOR.W	(A4+),D4	; destination <-- trame (juste une fois .W)30$:	SUB.W	D3,#16*2	JUMP',HS 34$	LOAD.W	D0,D3	NEG.W	D0	JUMP	(D0.W)+R8"34$	; saute en 34$ + qq instructions34$:	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	XOR.L	(A4+),D4	; destination <-- trame	TEST.W	D3		; encore qq chose ?	JUMP,GT 30$		; oui => 30$40$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	XOR.W	(A4+),D0	; destination <-- trame	JUMP	TRAME_RETURNTRAME_INV2:	LOAD.W	D0,(SP)+TRAMPOY	COMP.W	D0,(SP)+TRAMCHY	; y a-t-il un changement ?	JUMP',NE 10$	LOAD.L	A1,(SP)+TRAMASK	SUB.L	SP,#2		; stack <-- place pour paramtres en retour	PUSH.L	#(SP)+2+TRAMLGV	; stack <-- ^variables	PUSH.W	D0		; stack <-- position en Y	PUSH.L	#(SP)+2+4+2+TRAMLSK ; stack <-- ^(VAR ^ligne de masque)	CALL	(A1)		; appel GMI_SEEKSRGN: calcule la ligne de masque	POP.W	(SP)+TRAMCHY10$:	LOAD.L	A1,(SP)+TRAMLSK	; A1 <-- ^ligne de masque20$:	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,(A1+)	; D0 <-- conserve selon la rgion	XOR.W	(A4+),D0	; destination <-- trame	DECJ.W,NMO D3,20$	INC.W	(SP)+TRAMPOY	JUMP	TRAME_RETURNTRAME_INV3:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.B	D0,D4		; D0 <-- trame	AND.B	D0,D1		; D0 <-- conserve la partie utile	XOR.B	(A4+),D0	; destination <-- trame	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	JUMP	TRAME_RETURNTRAME_INV4:	LOAD.W	D0,(SP)+TRAMPOY	COMP.W	D0,(SP)+TRAMCHY	; y a-t-il un changement ?	JUMP',NE 10$	LOAD.L	A1,(SP)+TRAMASK	SUB.L	SP,#2		; stack <-- place pour paramtres en retour	PUSH.L	#(SP)+2+TRAMLGV	; stack <-- ^variables	PUSH.W	D0		; stack <-- position en Y	PUSH.L	#(SP)+2+4+2+TRAMLSK ; stack <-- ^(VAR ^ligne de masque)	CALL	(A1)		; appel GMI_SEEKSRGN: calcule la ligne de masque	POP.W	(SP)+TRAMCHY10$:	LOAD.L	A1,(SP)+TRAMLSK	; A1 <-- ^ligne de masque20$:	LOAD.B	D0,D4		; D0 <-- trame	AND.B	D0,(A1+)	; D0 <-- conserve selon la rgion	XOR.B	(A4+),D0	; destination <-- trame	DECJ.W,NMO D3,20$	INC.W	(SP)+TRAMPOY	JUMP	TRAME_RETURNTRAME_SET1:	DEC.W	D3	JUMP',NS 40$	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	OR.W	(A4+),D0	; destination <-- trame	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	TEST.W	D3	JUMP',EQ 40$	TCLR.L	D3:#0	JUMP',BC 30$	OR.W	(A4+),D4	; destination <-- trame (juste une fois .W)30$:	SUB.W	D3,#16*2	JUMP',HS 34$	LOAD.W	D0,D3	NEG.W	D0	JUMP	(D0.W)+R8"34$	; saute en 34$ + qq instructions34$:	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	OR.L	(A4+),D4	; destination <-- trame	TEST.W	D3		; encore qq chose ?	JUMP,GT 30$		; oui => 30$40$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.W	D0,D4		; D0 <-- trame	AND.W	D0,D1		; D0 <-- conserve la partie utile	OR.W	(A4+),D0	; destination <-- trame	JUMP	TRAME_RETURNTRAME_SET2:	LOAD.W	D0,(SP)+TRAMPOY	COMP.W	D0,(SP)+TRAMCHY	; y a-t-il un changement ?	JUMP',NE 10$	LOAD.L	A1,(SP)+TRAMASK	SUB.L	SP,#2		; stack <-- place pour paramtres en retour	PUSH.L	#(SP)+2+TRAMLGV	; stack <-- ^variables	PUSH.W	D0		; stack <-- position en 