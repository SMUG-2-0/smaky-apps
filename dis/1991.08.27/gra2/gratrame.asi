en Y	PUSH.L	#(SP)+2+4+2+TRAMLSK ; stack <-- ^(VAR ^ligne de masque)	CALL	(A1)		; appel GMI_SEEKSRGN: calcule la ligne de masque	POP.W	(SP)+TRAMCHY10$:	LOAD.L	A1,(SP)+TRAMLSK	; A1 <-- ^ligne de masque20$:	LOAD.W	D1,(A1+)	; D1 <-- masque selon rgion	LOAD.W	D0,D4	AND.W	D0,D1	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4+),D0	; destination <-- trame	DECJ.W,NMO D3,20$	INC.W	(SP)+TRAMPOY	JUMP	TRAME_RETURNTRAME_LOAD3:	DEC.W	D3	JUMP',NS 40$	LOAD.B	D0,D4		; D0 <-- trame	AND.B	D0,D1		; D0 <-- conserve la partie utile	NOT.B	D1	AND.B	D1,(A4)	OR.B	D0,D1	LOAD.B	(A4+),D0	; destination <-- trame	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP',NS 40$30$:	LOAD.B	(A4+),D4	; destination <-- trame	DECJ.W,NMO D3,30$40$:	AND.B	D1,D2		; D1 <-- masque de fin	LOAD.B	D0,D4		; D0 <-- trame	AND.B	D0,D1		; D0 <-- conserve la partie utile	NOT.B	D1	AND.B	D1,(A4)	OR.B	D0,D1	LOAD.B	(A4+),D0	; destination <-- trame	JUMP	TRAME_RETURNTRAME_LOAD4:	LOAD.W	D0,(SP)+TRAMPOY	COMP.W	D0,(SP)+TRAMCHY	; y a-t-il un changement ?	JUMP',NE 10$	LOAD.L	A1,(SP)+TRAMASK	SUB.L	SP,#2		; stack <-- place pour paramtres en retour	PUSH.L	#(SP)+2+TRAMLGV	; stack <-- ^variables	PUSH.W	D0		; stack <-- position en Y	PUSH.L	#(SP)+2+4+2+TRAMLSK ; stack <-- ^(VAR ^ligne de masque)	CALL	(A1)		; appel GMI_SEEKSRGN: calcule la ligne de masque	POP.W	(SP)+TRAMCHY10$:	LOAD.L	A1,(SP)+TRAMLSK	; A1 <-- ^ligne de masque20$:	LOAD.B	D1,(A1+)	; D1 <-- masque selon rgion	LOAD.B	D0,D4	AND.B	D0,D1	NOT.B	D1	AND.B	D1,(A4)	OR.B	D0,D1	LOAD.B	(A4+),D0	; destination <-- trame	DECJ.W,NMO D3,20$	INC.W	(SP)+TRAMPOY	JUMP	TRAME_RETURNTATRAME_MASK:	.W	B'1111111111111111	.W	B'0111111111111111	.W	B'0011111111111111	.W	B'0001111111111111	.W	B'0000111111111111	.W	B'0000011111111111	.W	B'0000001111111111	.W	B'0000000111111111	.W	B'0000000011111111	.W	B'0000000001111111	.W	B'0000000000111111	.W	B'0000000000011111	.W	B'0000000000001111	.W	B'0000000000000111	.W	B'0000000000000011	.W	B'0000000000000001	.W	B'1111111111111111	.W	B'1000000000000000	.W	B'1100000000000000	.W	B'1110000000000000	.W	B'1111000000000000	.W	B'1111100000000000	.W	B'1111110000000000	.W	B'1111111000000000	.W	B'1111111100000000	.W	B'1111111110000000	.W	B'1111111111000000	.W	B'1111111111100000	.W	B'1111111111110000	.W	B'1111111111111000	.W	B'1111111111111100	.W	B'1111111111111110; Traite le cas d'une trame de dimensions quelconques.; in	A2.L	^description de la fentre;	D4.L	coordonnes y;x dbut (coin sup/gauche);	D3.L	delta y;x;	D1.B	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT)TRAME_SPEC:	LOAD.L	A3,(A2)+ODFTPM	; A3 <-- ^bitmap trame source	LOAD.W	D5,(A2)+ODFTII	; D5 <-- ^incrment bitmap source	LOAD.L	A4,#0		; A4 <-- ^destination dans l'cran	LOAD.W	D2,(A2)+ODFTDI+0 ; D2 <-- hauteur trame	LOAD.L	D6,D4	SWAP.W	D6	ADD.W	D6,(A2)+ODFFY	SUB.W	D6,(A2)+ODFTOR+0	CONV.LA.WA D6	DIV.WA	D6,D2	SWAP.W	D6		; D6 <-- offset initial en Y	TEST.W	D6	JUMP',NC 14$	ADD.W	D6,D214$:	SUB.W	D2,D6		; D2 <-- hauteur initiale	SWAP.W	D2	JUMP'	22$20$:	CLR.W	D6		; D6 <-- plus d'offset en Y	LOAD.L	D2,(A2)+ODFTDI	; D2 <-- hauteur22$:	LOAD.W	D2,(A2)+ODFTDI+2 ; D2 <-- largeur trame	LOAD.W	D0,D4	ADD.W	D0,(A2)+ODFFX	SUB.W	D0,(A2)+ODFTOR+2	CONV.LA.WA D0	DIV.WA	D0,D2	SWAP.W	D0		; D0 <-- offset initial en X	TEST.W	D0	JUMP',NC 24$	ADD.W	D0,D224$:	SUB.W	D2,D0		; D2 <-- largeur initiale	PUSHM.L	D3,D4	JUMP'	32$30$:	CLR.W	D0		; D0 <-- plus d'offset en X	LOAD.W	D2,(A2)+ODFTDI+2 ; D2 <-- largeur32$:	PUSH.L	D3	COMP.W	D2,D3		; trame plus large que ce qu'il reste ?	JUMP',LS 34$		; non => 34$	LOAD.W	D2,D3		; D2 <-- largeur restante34$:	SWAP.W	D2	SWAP.W	D3	COMP.W	D2,D3		; trame plus haute que ce qu'il reste ?	JUMP',LS 35$		; non => 35$	LOAD.W	D2,D3		; D2 <-- hauteur restante35$:	SWAP.W	D2	SWAP.W	D3	LOAD.L	D3,(A2)+ODFTPO	; D3 <-- position source	ADD.W	D3,D0	SWAP.W	D3	ADD.W	D3,D6	SWAP.W	D3	CALL	_GRA_RASTERM	; dessine un bout de trame	POP.L	D3	ADD.W	D4,D2		; D4 <-- position suivante en X	SUB.W	D3,D2		; D3 <-- largeur restante en X	JUMP,NE 30$	POPM.L	D3,D4	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D2		; D4 <-- position suivante en Y	SUB.W	D3,D2		; D3 <-- largeur restante en Y	LOAD.W	D6,D3	SWAP.W	D4	SWAP.W	D3	TEST.W	D6	JUMP,NE 20$	CLR.W	D7		; D7 <-- ok	JUMP	TRAME_EXIT; Traite le cas d'une trame de 2x2 points.TRAME_2x2:	LOAD.L	A4,(A2)+ODFTPM	; A4 <-- ^bitmap trame source	CLR.L	D6		; D6 <-- pas d'inversion	TEST.L	D1:#BCPLDOT	JUMP',BC 10$	NOT.L	D6		; D6 <-- inverse la trame10$:	AND.W	D1,#H'0003	; D1 <-- mode LOAD/INV/SET/CLR	LOAD.W	D7,(A2)+ODFX	ADD.W	D7,(A2)+ODFTOR+2	AND.W	D7,#H'0001	; D7 <-- dcalage selon origine fentre en X	LOAD.L	A3,#(SP)+TRAMMOT	LOAD.W	D5,#2-114$:	CLR.L	D0	LOAD.B	D0,(A4)		; D0 <-- un byte de la trame	ADD.W	A4,(A2)+ODFTII	AND.B	D0,#B'11000000	LOAD.B	D2,D0		; D2 <-- TT000000	RR.B	D2,#2		; D2 <-- 00TT0000	OR.B	D0,D2	RR.B	D2,#2		; D2 <-- 0000TT00	OR.B	D0,D2	RR.B	D2,#2		; D2 <-- 000000TT	OR.B	D0,D2	LOAD.L	D2,D0	RL.L	D2,#8	OR.L	D0,D2	RL.L	D2,#8	OR.L	D0,D2	RL.L	D2,#8	OR.L	D0,D2	RR.L	D0,D7		; D0 <-- v. dcale selon origine fentre	XOR.L	D0,D6		; D0 <-- v. inverse	LOAD.L	(A3)+4*14,D0	LOAD.L	(A3)+4*12,D0	LOAD.L	(A3)+4*10,D0	LOAD.L	(A3)+4*8,D0	LOAD.L	(A3)+4*6,D0	LOAD.L	(A3)+4*4,D0	LOAD.L	(A3)+4*2,D0	LOAD.L	(A3+),D0	DECJ.W,NMO D5,14$	LOAD.L	A3,#(SP)+TRAMMOT ; A3 <-- ^trame 32x16	LOAD.L	D7,D4	SWAP.W	D7	ADD.W	D7,(A2)+ODFY	ADD.W	D7,(A2)+ODFFY	SUB.W	D7,(A2)+ODFTOR+0	AND.W	D7,#H'0001	; D7 <-- ^relatif ligne trame	SL.W	D7,#2		; D7 <-- *4 car trame de 32 bits de large	JUMP	TRAME_QUICK; Traite le cas d'une trame de 4x4 points.TRAME_4x4:	LOAD.L	A4,(A2)+ODFTPM	; A4 <-- ^bitmap trame source	CLR.L	D6		; D6 <-- pas d'inversion	TEST.L	D1:#BCPLDOT	JUMP',BC 10$	NOT.L	D6		; D6 <-- inverse la trame10$:	AND.W	D1,#H'0003	; D1 <-- mode LOAD/INV/SET/CLR	LOAD.W	D7,(A2)+ODFX	ADD.W	D7,(A2)+ODFTOR+2	AND.W	D7,#H'0003	; D7 <-- dcalage selon origine fentre en X	LOAD.L	A3,#(SP)+TRAMMOT	LOAD.W	D5,#4-114$:	CLR.L	D0	LOAD.B	D0,(A4)		; D0 <-- un byte de la trame	ADD.W	A4,(A2)+ODFTII	AND.B	D0,#B'11110000	LOAD.B	D2,D0		; D2 <-- TTTT0000	RR.B	D2,#4		; D2 <-- 0000TTTT	OR.B	D0,D2	LOAD.L	D2,D0	RL.L	D2,#8	OR.L	D0,D2	RL.L	D2,#8	OR.L	D0,D2	RL.L	D2,#8	OR.L	D0,D2	RR.L	D0,D7		; D0 <-- v. dcale selon origine fentre	XOR.L	D0,D6		; D0 <-- v. inverse	LOAD.L	(A3)+4*12,D0	LOAD.L	(A3)+4*8,D0	LOAD.L	(A3)+4*4,D0	LOAD.L	(A3+),D0	DECJ.W,NMO D5,14$	LOAD.L	A3,#(SP)+TRAMMOT ; A3 <-- ^trame 32x16	LOAD.L	D7,D4	SWAP.W	D7	ADD.W	D7,(A2)+ODFY	ADD.W	D7,(A2)+ODFFY	SUB.W	D7,(A2)+ODFTOR+0	AND.W	D7,#H'0003	; D7 <-- ^relatif ligne trame	SL.W	D7,#2		; D7 <-- *4 car trame de 32 bits de large	JUMP	TRAME_QUICK; Traite le cas d'une trame de 8x8 points.TRAME_8x8:	LOAD.L	A4,(A2)+ODFTPM	; A4 <-- ^bitmap trame source	CLR.L	D6		; D6 <-- pas d'inversion	TEST.L	D1:#BCPLDOT	JUMP',BC 10$	NOT.L	D6		; D6 <-- inverse la trame10$:	AND.W	D1,#H'0003	; D1 <-- mode LOAD/INV/SET/CLR	LOAD.W	D7,(A2)+ODFX	ADD.W	D7,(A2)+ODFTOR+2	AND.W	D7,#H'0007	; D7 <-- dcalage selon origine fentre en X	LOAD.L	A3,#(SP)+TRAMMOT	LOAD.W	D5,#8-1	LOAD.W	D2,(A2)+ODFTII14$:	LOAD.B	D0,(A4)		; D0 <-- un byte de la trame	ADD.W	A4,D2	RR.B	D0,D7		; D0 <-- v. dcale selon origine fentre	XOR.B	D0,D6		; D0 <-- v. inverse	LOAD.B	(A3+),D0	LOAD.B	(A3+),D0	LOAD.W	(A3+),(A3)-2	LOAD.L	(A3)+32-4,(A3)-4	DECJ.W,NMO D5,14$	LOAD.L	A3,#(SP)+TRAMMOT ; A3 <-- ^trame 32x16	LOAD.L	D7,D4	SWAP.W	D7	ADD.W	D7,(A2)+ODFY	ADD.W	D7,(A2)+ODFFY	SUB.W	D7,(A2)+ODFTOR+0	AND.W	D7,#H'0007	; D7 <-- ^relatif ligne trame	SL.W	D7,#2		; D7 <-- *4 car trame de 32 bits de large	JUMP	TRAME_QUICK; Traite le cas d'une trame de 16x16 points.TRAME_16x16:	LOAD.L	A4,(A2)+ODFTPM	; A4 <-- ^bitmap trame source	CLR.L	D6		; D6 <-- pas d'inversion	TEST.L	D1:#BCPLDOT	JUMP',BC 10$	NOT.L	D6		; D6 <-- inverse la trame10$:	AND.W	D1,#H'0003	; D1 <-- mode LOAD/INV/SET/CLR	LOAD.W	D7,(A2)+ODFX	ADD.W	D7,(A2)+ODFTOR+2	AND.W	D7,#H'000F	; D7 <-- dcalage selon origine fentre en X	LOAD.L	A3,#(SP)+TRAMMOT	LOAD.W	D5,#16-1	LOAD.W	D2,(A2)+ODFTII14$:	LOAD.W	D0,(A4)		; D0 <-- un word de la trame	ADD.W	A4,D2	RR.W	D0,D7		; D0 <-- v. dcale selon origine fentre	XOR.W	D0,D6		; D0 <-- v. inverse	LOAD.W	(A3+),D0	LOAD.W	(A3+),(A3)-2	DECJ.W,NMO D5,14$	LOAD.L	A3,#(SP)+TRAMMOT ; A3 <-- ^trame 32x16	LOAD.L	D7,D4	SWAP.W	D7	ADD.W	D7,(A2)+ODFY	ADD.W	D7,(A2)+ODFFY	SUB.W	D7,(A2)+ODFTOR+0	AND.W	D7,#H'000F	; D7 <-- ^relatif ligne trame	SL.W	D7,#2		; D7 <-- *4 car trame de 32 bits de large	JUMP	TRAME_QUICK	.END