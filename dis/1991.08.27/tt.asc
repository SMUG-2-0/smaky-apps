;-----------\; _GRA_TRAME >;===========/; Rempli une surface rectangulaire avec une trame 8x8.; La trame est toujours aligne (horizontalement et verticalement);  une position modulo 8 pour rsoudre les problmes de jointures; entre deux trames.; in	A2.L	^description de la fentre;	D4.L	coordonnes y;x dbut (coin sup/gauche);	D3.L	delta y;x;	D1.B	opration (INVDOT, SETDOT ou CLRDOT);	A4.L	^trame; out	D7.W	erreur; mod	D7.W_GRA_TRAME:	PUSHM.L	D0..D6,A0..A6	SUB.L	SP,#RASTLGV	; stack <-- place pour variables	TEST.W	D3		; largeur nulle ?	JUMP,EQ TRAME_EXIT	; oui => TRAME_EXIT	SWAP.W	D3	TEST.W	D3		; hauteur nulle ?	JUMP,EQ TRAME_EXIT	; oui => TRAME_EXIT	SWAP.W	D3	CALL	CLIPGRA		; dans la fentre ?	JUMP,NE	TRAME_EXIT	; non => TRAME_EXIT	LOAD.L	D2,D3		; D2 <-- dimensions (dy;dx)	LOAD.L	D3,D4		; D4 <-- X	SWAP.W	D3		; D3 <-- Y	LOAD.W	D6,(A2)+ODFIIY	; D6 <-- Iy	ADD.W	D4,(A2)+ODFWBX	; D4 <-- coordonne x absolue dans bitmap	ADD.W	D3,(A2)+ODFWBY	; D3 <-- coordonne y absolue dans bitmap	LOAD.L	A4,(A2)+ODFABS	; A4 <-- adresse dbut cran	LOAD.W	D0,D4	SR.W	D0,#3		; dcale coordonne X	ADD.W	A4,D0	MUL.WU	D3,D6		; dcale coordonne Y	ADD.L	A4,D3		; A4 <-- adresse dans l'cran	AND.W	D4,#B'111	; D4 <-- Dd	LOAD.W	A6,D6		; A6 <-- Iy; Calcule l'opration d'inversion.	CLR.W	D6		; D6 <-- vido normale	TEST.L	D1:#BCPLDOT	JUMP',BC 22$	NOT.W	D6		; D6 <-- vido inverse22$:	LOAD.W	D0,A6	TEST.L	D0:#0		; Iy impair ?	JUMP,BS 60$		; oui => 60$; Calcule l'adresse de la routine de gestion d'une ligne.	LOAD.L	A0,#R16"TATRAME_OP	AND.W	D1,#H'0003	SL.W	D1,#1	TEST.W	D6		; inverse ?	JUMP',EQ 40$		; non => 40$	ADD.W	D1,#4*2		; oui => cas (2)40$:	ADD.W	A0,(A0)+(D1.W)	; A0 <-- ^routine ligne; Si l'adresse n'est pas paire, recule d'un byte.	LOAD.W	D0,A4	RR.W	D0,#1	JUMP',CC 42$	DEC.L	A4		; A4 <-- adresse paire	ADD.W	D4,#8		; D4 <-- Dd42$:; Calcule le nombre de lignes  traiter.	LOAD.L	D5,D2	SWAP.W	D5		; D5 <-- hauteur	DEC.W	D5		; D5 <-- -1  cause NMO; Calcule le nombre de tranches de 16 bits.	LOAD.W	D1,D2	ADD.W	D1,D4		; D1 <-- Dd + largeur	DEC.W	D1	SR.W	D1,#4		; D1 <-- nb de words -1	LOAD.W	(SP)+RASTNBW,D1	INC.W	D1	SL.W	D1,#1	SUB.W	A6,D1		; A6 <-- Iy - nb de bytes; Calcule les masques de dbut et de fin.	LOAD.L	A1,#R16"TATRAME_MASK	LOAD.W	D1,D4	SL.W	D1,#1	LOAD.W	D1,(A1)+(D1.W)	; D1 <-- masque de dbut	LOAD.W	(SP)+RASTMA1,D1	ADD.W	D2,D4		; D2 <-- Dd + largeur	AND.W	D2,#H'000F	SL.W	D2,#1	LOAD.W	D2,(A1)+(D2.W)+32 ; D2 <-- masque de fin	JUMP	TRAME_LOOP; Calcule l'adresse de la routine de gestion d'une ligne,; dans le cas o Iy source ou destination est impair.60$:	LOAD.L	A0,#R16"TATRAME_OP	AND.W	D1,#H'0003	SL.W	D1,#1	ADD.W	D1,#8*2	ADD.W	A0,(A0)+(D1.W)	; A0 <-- ^routine ligne; Calcule le nombre de lignes  traiter.	LOAD.L	D5,D2	SWAP.W	D5		; D5 <-- hauteur	TEST.W	D5	JUMP',NC 63$	NEG.W	D5	EX.L	D5,A6	NEG.W	D5		; A6 <-- -A6	EX.L	A6,D563$:	DEC.W	D5		; D5 <-- -1  cause NMO; Calcule le nombre de tranches de 16 bits.	LOAD.W	D1,D2	ADD.W	D1,D4		; D1 <-- Dd + largeur	DEC.W	D1	SR.W	D1,#3		; D1 <-- nb de bytes -1	LOAD.W	(SP)+RASTNBW,D1	INC.W	D1	SUB.W	A6,D1		; A6 <-- Iy - nb de bytes; Calcule les masques de dbut et de fin.	LOAD.L	A1,#R16"TATRAME_MASK	LOAD.W	D1,D4	SL.W	D1,#1	LOAD.B	D1,(A1)+(D1.W)	; D1 <-- masque de dbut	LOAD.W	(SP)+RASTMA1,D1	ADD.W	D2,D4		; D2 <-- Dd + largeur	AND.W	D2,#H'0007	SL.W	D2,#1	LOAD.B	D2,(A1)+(D2.W)+32 ; D2 <-- masque de fin; Calcule le nombre de dcalages  droite.;	JUMP	TRAME_LOOP; Boucle principale de traitement des lignes.TRAME_LOOP:	LOAD.W	D1,(SP)+RASTMA1	; D1 <-- masque de dbut	LOAD.W	D3,(SP)+RASTNBW	; D3 <-- nombre de words -1	JUMP	(A0)		; traite une ligneTRAME_RETURN:	ADD.W	A4,A6		; A4 <-- ^ligne suivante	DECJ.W,NMO D5,TRAME_LOOP	CLR.W	D7		; D7 <-- okTRAME_EXIT:	ADD.L	SP,#RASTLGV	; ajuste le stack	POPM.L	D0..D6,A0..A6	TEST.W	D7		; D7 <-- ok	RET; (1)	transfert par words, sans inversion ni gris; (2)	transfert par words, avec inversion et/ou gris; (3)	transfert par bytesTATRAME_OP:	.W	TRAME_LOAD1-TATRAME_OP	.W	TRAME_INV1-TATRAME_OP	.W	TRAME_SET1-TATRAME_OP	.W	TRAME_CLR1-TATRAME_OP	.W	TRAME_LOAD2-TATRAME_OP	.W	TRAME_INV2-TATRAME_OP	.W	TRAME_SET2-TATRAME_OP	.W	TRAME_CLR2-TATRAME_OP	.W	TRAME_LOAD3-TATRAME_OP	.W	TRAME_INV3-TATRAME_OP	.W	TRAME_SET3-TATRAME_OP	.W	TRAME_CLR3-TATRAME_OP;----------;; TRAME_op ;;----------;; Traite une ligne dans un mode quelconque.; in	D1.W	masque de dbut;	D2.W	masque de fin;	D3.W	nombre de words -1;	D4.W	;	D6.W	inversion (0/-1);	A4.L	^destination; out	-; mod	D0.L, D1.L, D3.L, D7.L, A3.L, A4.LTRAME_INV1:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D1		; D0 <-- conserve la partie utile	XOR.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	JUMP	TRAME_RETURNTRAME_INV2:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	AND.W	D0,D1		; D0 <-- conserve la partie utile	XOR.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	SWAP.W	D7		; D7 <-- gris suivant	JUMP	TRAME_RETURNTRAME_INV3:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.B	D0,(A3)	SL.W	D0,#8	LOAD.B	D0,(A3)+1	; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.W	D0,D4		; D0 <-- dcale selon D4	AND.B	D0,D7		; D0 <-- "grise" si ncessaire	XOR.B	D0,D6		; D0 <-- "inverse" si ncessaire	AND.B	D0,D1		; D0 <-- conserve la partie utile	XOR.B	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	SWAP.W	D7		; D7 <-- gris suivant	JUMP	TRAME_RETURNTRAME_SET1:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D1		; D0 <-- conserve la partie utile	OR.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	JUMP	TRAME_RETURNTRAME_SET2:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	AND.W	D0,D1		; D0 <-- conserve la partie utile	OR.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	SWAP.W	D7		; D7 <-- gris suivant	JUMP	TRAME_RETURNTRAME_SET3:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.B	D0,(A3)	SL.W	D0,#8	LOAD.B	D0,(A3)+1	; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.W	D0,D4		; D0 <-- dcale selon D4	AND.B	D0,D7		; D0 <-- "grise" si ncessaire	XOR.B	D0,D6		; D0 <-- "inverse" si ncessaire	AND.B	D0,D1		; D0 <-- conserve la partie utile	OR.B	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	SWAP.W	D7		; D7 <-- gris suivant	JUMP	TRAME_RETURNTRAME_CLR1:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D0	AND.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	JUMP	TRAME_RETURNTRAME_CLR2:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D0	AND.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	SWAP.W	D7		; D7 <-- gris suivant	JUMP	TRAME_RETURNTRAME_CLR3:	TEST.W	D3	JUMP',NE 30$20$:	AND.W	D1,D2		; D1 <-- masque de fin30$:	LOAD.B	D0,(A3)	SL.W	D0,#8	LOAD.B	D0,(A3)+1	; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.W	D0,D4		; D0 <-- dcale selon D4	AND.B	D0,D7		; D0 <-- "grise" si ncessaire	XOR.B	D0,D6		; D0 <-- "inverse" si ncessaire	AND.B	D0,D1		; D0 <-- conserve la partie utile	NOT.B	D0	AND.B	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP,GT 30$	JUMP,EQ 20$	SWAP.W	D7		; D7 <-- gris suivant	JUMP	TRAME_RETURNTRAME_LOAD1:	TEST.W	D4		; y'a-t-il un dcalage ?	JUMP,NE 10$		; oui => 10$	COMP.W	A2,#+2		; travaille de gauche  droite ?	JUMP,EQ TRAME_LOADQ	; oui => on optimise (pour les scrolls up/down)10$:	DEC.W	D3	JUMP',NS 40$	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP',NS 40$30$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	LOAD.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	DECJ.W,NMO D3,30$40$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	JUMP	TRAME_RETURNTRAME_LOADQ:	ADD.L	A3,#2	DEC.W	D3	JUMP',NS 40$	LOAD.W	D0,(A3+)	; D0 <-- source	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4+),D0	; destination <-- data	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	TEST.W	D3	JUMP',EQ 40$	SR.W	D3,#1		; D3 <-- /2 car par .L	JUMP',CC 30$	LOAD.W	(A4+),(A3+)	; destination <-- data (juste une fois .W)30$:	SL.W	D3,#1		; D3 <-- *2 car un "LOAD.L (A4+),(A3+)" occupe 2 bytes !32$:	SUB.W	D3,#16*2	JUMP',HS 34$	LOAD.W	D0,D3	NEG.W	D0	JUMP	(D0.W)+R8"34$	; saute en 34$ + qq instructions34$:	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	LOAD.L	(A4+),(A3+)	; destination <-- data	TEST.W	D3		; encore qq chose ?	JUMP,GT 32$		; oui => 32$40$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.W	D0,(A3+)	; D0 <-- source	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4+),D0	; destination <-- data	SUB.L	A3,#2	JUMP	TRAME_RETURNTRAME_LOAD2:	DEC.W	D3	JUMP',NS 40$	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP',NS 40$30$:	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	DECJ.W,NMO D3,30$40$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.L	D0,(A3)		; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.L	D0,D4		; D0 <-- dcale selon D4	AND.W	D0,D7		; D0 <-- "grise" si ncessaire	XOR.W	D0,D6		; D0 <-- "inverse" si ncessaire	AND.W	D0,D1		; D0 <-- conserve la partie utile	NOT.W	D1	AND.W	D1,(A4)	OR.W	D0,D1	LOAD.W	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	SWAP.W	D7		; D7 <-- gris suivant	JUMP	TRAME_RETURNTRAME_LOAD3:	DEC.W	D3	JUMP',NS 40$	LOAD.B	D0,(A3)	SL.W	D0,#8	LOAD.B	D0,(A3)+1	; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.W	D0,D4		; D0 <-- dcale selon D4	AND.B	D0,D7		; D0 <-- "grise" si ncessaire	XOR.B	D0,D6		; D0 <-- "inverse" si ncessaire	AND.B	D0,D1		; D0 <-- conserve la partie utile	NOT.B	D1	AND.B	D1,(A4)	OR.B	D0,D1	LOAD.B	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	LOAD.L	D1,#-1		; D1 <-- ne masque plus rien	DEC.W	D3	JUMP',NS 40$30$:	LOAD.B	D0,(A3)	SL.W	D0,#8	LOAD.B	D0,(A3)+1	; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.W	D0,D4		; D0 <-- dcale selon D4	AND.B	D0,D7		; D0 <-- "grise" si ncessaire	XOR.B	D0,D6		; D0 <-- "inverse" si ncessaire	LOAD.B	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	DECJ.W,NMO D3,30$40$:	AND.W	D1,D2		; D1 <-- masque de fin	LOAD.B	D0,(A3)	SL.W	D0,#8	LOAD.B	D0,(A3)+1	; D0 <-- source	ADD.W	A3,A2		; A3 <-- ^suivant dans source	SR.W	D0,D4		; D0 <-- dcale selon D4	AND.B	D0,D7		; D0 <-- "grise" si ncessaire	XOR.B	D0,D6		; D0 <-- "inverse" si ncessaire	AND.B	D0,D1		; D0 <-- conserve la partie utile	NOT.B	D1	AND.B	D1,(A4)	OR.B	D0,D1	LOAD.B	(A4),D0		; destination <-- data	ADD.W	A4,A2		; A4 <-- ^suivant dans destination	SWAP.W	D7		; D7 <-- gris suivant	JUMP	TRAME_RETURN