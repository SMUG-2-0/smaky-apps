	.TITLE	TCOLOR.ASL;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du module SMA_TCOLOR.LIB;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 0.4	15.03.91	check dans les variables locales; 0.3	12.12.90	compte mmoire priv; 0.2	23.11.90	mode BTCACTIVE; 0.1	15.11.90	dbut des travaux ...	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal	.REF	SMAKY	.REF	MODULES	.REF	TCOLOR;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;SMAKY300	=	7AD171WRADDR=H'1007800AD171RDADDR=H'1007830AD171MASK=H'1007820AD171DATA=H'1007810;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;MAJREV	=	0MINREV	=	4	.REV	MAJREV,MINREV	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------MAXGCRET =	100		; nb max de CRET globalesMAXLCRET =	20		; nb max de CRET pour un TCOL_OPENRESERVE	 =	10		; rserve avant d'agrandir la mmoireCHECK	=	H'12345678	; valeur de contrle; Description d'un fichier .CLUT/.CRET; ------------------------------------OCTNBM	=	LCTHEAD-2	; nb max (interne); Variables locales en (A5); -------------------------	.LOC	0OLCHECK:.BLKB	4		; check de contrleOLACTIF:.BLKB	1		; 1 => fentre active	.EVENOLPPSS:	.BLKB	4		; ^procdure de recherche spciale dans CLUTOLPGLOB:.BLKB	4		; ^variables globalesOLPCLUT:.BLKB	4		; ^table CLUTOLPCRET:.BLKB	4*MAXLCRET	; ^tables CRETLGVLOC:; Variables globales en (A6); --------------------------	.LOC	0OGMACH:	.BLKB	1		; machine utilise	.EVENOGPACC:	.BLKB	4		; ^compte mmoire privOGPSEM:	.BLKB	4		; ^smaphore de bloquageOGPACCL:.BLKB	4		; ^CLUT activeOGPACCH:.BLKB	4		; canal actifOGPCLUT:.BLKB	4		; ^table CLUTOGPCRET:.BLKB	4*MAXGCRET	; ^tables CRETLGVGLOB:; En-tte du module LIB; ---------------------	.LOC	0DEBUT:	TCOL_	FIRST		; code du premier appel	TCOL_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	MAJREV,MINREV	; rvision.version	.W	0,END_TCOLOR	; longueur	.L	PATHLIB		; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"TCOLOR"	; nom du module	.FILLB	(LGHLIB-.),0	.W	_TCOL_OPEN	.W	_TCOL_CLOSE	.W	_TCOL_ACTIVE	.W	_TCOL_LOADCLUT	.W	_TCOL_SAVECLUT	.W	_TCOL_SRCCLUT	.W	_TCOL_PUTCLUT	.W	_TCOL_LOADCRET	.W	_TCOL_SAVECRET	.W	_TCOL_KILLCRET	.W	_TCOL_ADDCRET	.W	_TCOL_SUBCRET	.W	_TCOL_SRCCRET	.W	_TCOL_PUTCRET	.W	_TCOL_DELCRET	.W	_TCOL_MAKETRAME	.W	_TCOL_PPSSCLUT	.W	_TCOL_GPSSCLUT	.W	_TCOL_LISTCRET	.W	_TCOL_GETACTIVE; Codes des appels; ----------------;-----------\\; _TCOL_OPEN >;===========/; Ouvre une instance du module.; in	D4.W	nb de bits/pixel (1,2,4,8,15,24);	D3.L	mode (zro); out	D6.L	canal;	D7.W	erreur; mod	D6.L, D7.W_TCOL_OPEN:	PUSHM.L	D1,D4,A1..A6	LOAD.L	A4,#R16"DEBUT	LOAD.L	D4,#LGVGLOB+2^31	FOS	?GETCOMMEM	; demande variables globales	JUMP',NE EXIT$	LOAD.L	A6,A4		; A6 <-- ^variables globales	NTREL	?LOCK		; protge les variables globales	JUMP',NS EXIT$	TEST.L	(A6)+OGPACC	; est-ce la premire fois qu'on passe ici ?	JUMP',NE NOACC$		; non => on ne fait rien	LOAD.L	(A6)+OGPSEM,A5	; OGPSEM <-- ^smaphore	LOAD.L	A3,#R16"NMACC$	LOAD.L	D1,#MTYPSYS	LOAD.L	A1,#0	GESMEM	?CREMCPT	; A2 <-- cre un compte mmoire	JUMP',NS EXITUNLOCK$	LOAD.L	(A6)+OGPACC,A2NOACC$:	LOAD.L	D4,#LGVLOC	LOAD.L	D1,#MTYPUSER	LOAD.L	A1,(A6)+OGPACC	GESMEM	?GETMEM		; demande variables locales	JUMP',NE EXITUNLOCK$	GESMEM	?CLEARMEM	LOAD.L	A5,A4		; A5 <-- ^variables locales	LOAD.L	(A5)+OLCHECK,#CHECK	LOAD.L	(A5)+OLPGLOB,A6	TEST.B	(A6)+OGMACH	JUMP',NE NOFIRST$	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OGMACH,D4NOFIRST$:	TEST.L	(A6)+OGPCLUT	JUMP',EQ OK$	LOAD.L	A3,(A6)+OGPCLUT	; A3 <-- ^CLUT globale	LOAD.B	D1,#CLTYPE	; D1 <-- type attendu (CLUT)	CALL	TABMLOAD	; A4 <-- ^copie de la CLUT globale	JUMP',NE EXITUnLock$	LOAD.L	(A5)+OLPCLUT,A4OK$:	LOAD.L	D6,A5		; D6 <-- "canal"	CLR.W	D7		; D7 <-- okEXITUNLOCK$:	PUSH.W	D7	LOAD.L	A5,(A6)+OGPSEM	NTREL	?UNLOCK		; fin zone critique	POP.W	D7EXIT$:	POPM.L	D1,D4,A1..A6	TEST.W	D7		; retour EQ/NE	RETNMACC$:	.ASCIZ	"TColor_Memory"	.EVEN;------------\\; _TCOL_CLOSE >;============/; Ferme une instance du module.; in	D6.L	canal;	D3.L	mode (zro); out	-; mod	D7.W_TCOL_CLOSE:	PUSHM.L	D1,A1,A3..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	COMP.L	(A5)+OLCHECK,#CHECK	JUMP',EQ FAT$	.W	H'A042	.ASCIZE	"<CR>Check faux dans TCOL_ !"FAT$:	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	TEST.L	(A5)+OLPCLUT	JUMP',EQ CLUT$	LOAD.L	A4,(A5)+OLPCLUT	CALL	TABKILL		; libre la CLUT localeCLUT$:	LOAD.L	A3,#(A5)+OLPCRET ; A3 <-- ^liste des CRETs locales	LOAD.W	D1,#MAXLCRET-1LOOP$:	TEST.L	(A3)		; CRET existe ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	A4,(A3)		; A4 <-- ^CRET	CALL	TABKILL		; libre une CRET localeNEXT$:	ADD.L	A3,#4		; A3 <-- ^^CRET suivante	DECJ.W,NMO D1,LOOP$	LOAD.L	A4,A5	LOAD.L	D1,#MTYPUSER	LOAD.L	A1,(A6)+OGPACC	GESMEM	?GIVMEM		; libre les variables locales	POPM.L	D1,A1,A3..A6	RET	TRAP	#1;-------------\\; _TCOL_ACTIVE >;=============/; Dfinit si la fentre associe au module est active ou non; (chargement de la palette des couleurs associe dans le hardware; du moniteur). ; in	D6.L	canal;	D4.B	1 => fentre active;	D3.L	mode (zro);	A5.L	^liste des moniteurs (zro); out	-; mod	D7.W_TCOL_ACTIVE:	PUSHM.L	A5,A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	COMP.L	(A5)+OLCHECK,#CHECK	JUMP',EQ FAT$	.W	H'A042	.ASCIZE	"<CR>Check faux dans TCOL_ACTIVE !"FAT$:	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.B	(A5)+OLACTIF,D4	JUMP',EQ EXIT$	LOAD.L	(A6)+OGPACCH,A5	LOAD.L	(A6)+OGPACCL,(A5)+OLPCLUT	JUMP',NE HARD$	LOAD.L	(A6)+OGPACCL,(A6)+OGPCLUTHARD$:	CALL	HARDMAJCLUT	; initialise le hard si ncessaireEXIT$:	POPM.L	A5,A6	CLR.W	D7		; retour EQ	RET;----------------\\; _TCOL_GETACTIVE >;================/; Donne le canal actif  un instant donn.; in	D6.L	canal; out	D6.L	canal actif; mod	D7.W_TCOL_GETACTIVE:	PUSHM.L	A5,A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	COMP.L	(A5)+OLCHECK,#CHECK	JUMP',EQ FAT$	.W	H'A042	.ASCIZE	"<CR>Check faux dans TCOL_GETACTIVE !"FAT$:	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	D6,(A6)+OGPACCH	; D6 <-- canal actif	POPM.L	A5,A6	CLR.W	D7		; retour EQ	RET;----------------\\; _TCOL_MAKETRAME >;================/; Cre une trame qui apprixime une couleur donne.; in	D6.L	canal; 	D3.L	mode (BCT*);		 BTCT8X8 --> calcule une trame 8x8;		 BTCGIVE --> rend la couleur relle obtenue; 	A4.L	^couleur  approximer (RGB);	A3.L	^buffer pour couleur relle (si D3:#BTCGIVE);	A5.L	^buffer (8 bytes) pour la trame (si D3:#BTCT8X8); out	D4.L	couleur SET (si D3:#BTCT8X8);	D5.L	couleur CLEAR (si D3:#BTCT8X8);	(A5)+	trame 8x8 (si D3:#BTCT8X8);	(A3)+	RGB rel (si D3:#BTCGIVE);	D7.W	erreur; mod	D4.L, D5.L, D7.W_TCOL_MAKETRAME:	LOAD.W	D7,#ERTCQQ	RET	.INS	TCOLCLUT.ASI	.INS	TCOLCRET.ASI	.INS	TCOLTAB.ASI	.INS	TCOLHARD.ASIEND_TCOLOR:	.END