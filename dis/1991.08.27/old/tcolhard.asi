	.SBTTL	TCOLHARD.ASI;------------\\; HARDMAJCLUT >;============/; Met  jour la CLUT si ncessaire.; in	-; out	-; mod	D7.WHARDMAJCLUT:	PUSH.L	A4	TEST.B	(A5)+OLACTIF	; fentre active ?	JUMP',EQ EXIT$		; non => EXIT$	TEST.L	(A5)+OLPCLUT	JUMP',EQ EXIT$	LOAD.L	A4,(A5)+OLPCLUT	; A4 <-- ^CLUT locale	CALL	HARDSETCLUT	; initialise le hardEXIT$:	POP.L	A4	RET;------------\\; HARDSETCLUT >;------------/; Initialise la palette des couleurs Inmos 171.; in	A4.L	^CLUT; out	-; mod	D7.WHARDSETCLUT:	PUSHM.L D1,D2,A4	COMP.B	(A6)+OGMACH,#SMAKY300	JUMP',NE EXIT$	LOAD.B	AD171MASK,#B'00001111 ; seulement 4 bits	CALL	HARDWAIT$	LOAD.W	D1,(A4)+OCTNB	JUMP',EQ EXIT$	LOAD.L	A4,#(A4)+LCTHEADLOOP$:	LOAD.B	AD171WRADDR,(A4)+OCTNAM+3	CALL	HARDWAIT$	LOAD.B	D2,(A4)+OCTCOL+OTCCR+0 ; D2 <-- rouge	SR.B	D2,#2	LOAD.B	AD171DATA,D2	CALL	HARDWAIT$	LOAD.B	D2,(A4)+OCTCOL+OTCCG+0 ; D2 <-- vert	SR.B	D2,#2	LOAD.B	AD171DATA,D2	CALL	HARDWAIT$	LOAD.B	D2,(A4)+OCTCOL+OTCCB+0 ; D2 <-- bleu	SR.B	D2,#2	LOAD.B	AD171DATA,D2	CALL	HARDWAIT$	LOAD.L	A4,#(A4)+LCTDATA ; A4 <-- ^RGB suivant	DEC.W	D1	JUMP,NE LOOP$EXIT$:	POPM.L D1,D2,A4	RET;----------\\; HARDWAIT$ >;----------/; Attente entre deux accs  la palette de couleurs Inmos IMSG171.; in	-; out	-; mod	-HARDWAIT$:	RR.B	D0,#8	RR.B	D0,#8	RR.B	D0,#8	RR.B	D0,#8	RET	.END