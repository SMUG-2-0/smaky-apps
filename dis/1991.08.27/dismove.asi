	.CHAP	DISMOVE;--------\; ROLLCR  >;========/; Effectue un dcalage de toutes les lignes d'une fentre; du bas vers le haut si l'on est en mode roll. Autrement,; remet le curseur tout en haut.; in	A2.L	^description d'une fentre; out	D7.W	ERDIROL; mod	D7.WROLLCR:	PUSHM.32 D0|D1|D2|D3|D4	TEST.8	{A2}+ODFMOD:#BFROLL ; roll de l'cran	JUMP,BS	 R8^L20$	; oui => 20$				; non =>	MOVE.16	{A2}+ODFC1X,{A2}+ODFPX	MOVE.16	{A2}+ODFC1Y,{A2}+ODFPY	TEST.8	{A2}+ODFMOD:#BFEFLI	JUMP,EQ L90$L10$:	CALL	DOEFLI		; efface la premire ligne	JUMP	L90$L20$:	MOVE.16	{A2}+ODFFDY,D1	SUB.16	{A2}+ODFC2Y,D1	; D1 <-- position la plus basse	MOVE.16	D1,D2		; D2 <-- futur position en Y	SUB.16	{A2}+ODFCY,D1	; D1 <-- position ligne n-1	JUMP,NS L10$	MOVE.16	{A2}+ODFPY,D4	SUB.16	D1,D4		; D4 <-- nb points  "roller"	MOVE.16	D2,{A2}+ODFPY	; init nouvelle position Y	TEST.32	D4:#0		; D4 pair ?	JUMP,EQ	 R8^L30$	; oui => 30$	INC.16	D4		; non => roll un peu plus grand	DEC.16	{A2}+ODFPY	; remonte pos ds dernire ligneL30$:	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE	 R8^L40$	; non => 40$	MOVE.16	D4,D0		; D0 <-- nb points  "roller"	CALL	ROLIMA		; roll image alphanumriqueL40$:	TEST.8	{A2}+ODFMOD:#BSROLL	JUMP,BS	 R8^L50$	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_ROLLUP-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_ROLLUP	POP.32	A0	JUMP	L90$L50$:	CLR.32	D1	MOVE.16	D4,D1		; D1 <-- amplitude du roll	JUMP,EQ	 R8^L90$	MOVE.16	#4,D3		; fait le roll en 4 fois (!)	SR.16	D1		; D1 <-- nb de roll minimaux	DIV.16	D3,D1		; D1 <-- ampl. de chaque roll	MOVE.32	D1,D2	SWAP.32	D2		; D2 <-- resteL60$:	MOVE.16	D1,D4	TEST.16	D2		; reste encore qq chose ?	JUMP,EQ	 R8^L65$	; non => 65$	DEC.16	D2		; oui =>	INC.16	D4		; fait un de + pour compenserL65$:	TEST.16	D4		; roll nul ?	JUMP,EQ	 R8^L70$	; oui => 70$	SL.16	D4		; toujours multiple de 2 !	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_ROLLUP-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_ROLLUP	POP.32	A0L70$:	DEC.16	D3	JUMP,NE L60$L90$:	MOVE.16	#ERDIROL,D7	; D7 <-- "roll done"	POPM.32	D0|D1|D2|D3|D4	RET;--------\\; EFFACE  >;========/; Efface toute la fentre.; in	A2.L	^description de la fentre; out	-; mod	D7.WEFFACE:	PUSHM.32 D3|D4|A4	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE	 R8^L10$	; non => 10$	CALL	CLRIMA		; rempli image alpha de SPACEsL10$:;;?	.IF	COLOR.IF FALSE	CALL	COLORPUSH	; sauve les couleurs	COMP.8	#NOWDOC,{A2}+ODFNOW	JUMP,LO	 R8^L20$	CLR.32	D3		; D3 <-- r/g/b = noir	CALL	COLORFAUSRC	; A4/D4 <-- fausse couleur	MOVE.32	D4,{A2}+ODFCCF	MOVE.8	{A4}+OCOLFR,{A2}+ODFCCA+0 ; ODFCCA+0 <-- rouge	CLR.8	{A2}+ODFCCA+1	MOVE.8	{A4}+OCOLFG,{A2}+ODFCCA+2 ; ODFCCA+2 <-- vert	CLR.8	{A2}+ODFCCA+3	MOVE.8	{A4}+OCOLFB,{A2}+ODFCCA+4 ; ODFCCA+4 <-- bleu	CLR.8	{A2}+ODFCCA+5L20$:	.ENDIF	FALSE	CLR.32	D4		; D4 <-- origine (sous-)fentre	MOVE.32	{A2}+ODFFDY,D3	; D3 <-- dimensions (sous-)fentre	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_CLEAR-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_CLEAR	POP.32	A0;;?	.IF	COLOR.IF FALSE	CALL	COLORPOP	; restitue les couleurs	.ENDIF	FALSE	POPM.32	D3|D4|A4	RET	.IF	SM324BIG;--------\\; GRISE   >;========/; Grise toute la fentre.; in	A2.L	^description de la fentre; out	-; mod	D7.WGRISE:	PUSHM.32 D1|D3|D4|A4	CLR.32	D4		; D4 <-- origine (sous-)fentre	MOVE.32	{A2}+ODFFDY,D3	; D3 <-- dimensions (sous-)fentre	MOVE.16	#SETDOT,D1	; D1 <-- mode	MOVE.32	#R16^L00$,A4	; A4 <-- ^trame	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_CLEAR-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_CLEAR	POP.32	A0	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_TRAME-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_TRAME	POP.32	A0	POPM.32	D1|D3|D4|A4	RETL00$:	.32	TRAGRIS	.32	TRAGRIS	.ENDIF	SM324BIG;---------\; SHOWLEFT >;=========/; Transfre les deux fentres $DIS7 et $DIS8  gauche.; in	A1.L	^table d'initialisation de l'cran; out	-; mod	-SHOWLEFT:	.IF	SM8.OR.SM100.OR.SM324LIT.OR.SM196.OR.SM300	PUSHM.32 D0|D1|A0|A1|A2	MOVE.16	#7,D0	CALL	GETDESC		; A2 <-- ^descripteur $DIS_7	JUMP,EQ	 R8^L02$	CLR.16	{A2}+ODFX	; nouvelle origine en X	CLR.16	{A2}+ODFIX	; nouvelle origine en X ; +++ DD +++	CALL	WMINMAX		; init min et max (sous-)fentreL02$:	MOVE.16	#8,D0	CALL	GETDESC		; A2 <-- ^descripteur $DIS_8	JUMP,EQ	 R8^L03$	CLR.16	{A2}+ODFX	; nouvelle origine en X	CLR.16	{A2}+ODFIX	; nouvelle origine en X ; +++ DD +++	CALL	WMINMAX		; init min et max (sous-)fentreL03$:	MOVE.16	#9,D0	CALL	GETDESC		; A2 <-- ^descripteur $DIS_9	JUMP,EQ	 R8^L04$	MOVE.16	#LARGCX*SEPX89,{A2}+ODFX	MOVE.16	#LARGCX*SEPX89,{A2}+ODFIX ; +++ DD +++	CALL	WMINMAX		; init min et max (sous-)fentreL04$:	MOVE.32	{A6}+OPDFEN+(4*0),A2 ; A2 <-- ^descripteur $DIS_0	MOVE.32	{A2}+ODFABS,A0	MOVE.32	#{A0}+(1024-PVIEWX)/8,A1.IF	Color300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor$	MOVE.32	#{A0}+(1024-PVIEWX)/2,A1NoColor$:.ENDIF	Color300	MOVE.16	#SEPY81,D1L10$:	MOVE.16	#(PVIEWX/8)/2,D0.IF	Color300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor2$	MOVE.16	#(PViewX/2)/2,D0NoColor2$:.ENDIF	Color300	PUSHM.32 A0|A1L15$:	MOVE.16	{A1+},{A0+}	; dcale une ligne  gauche	DEC.16	D0	JUMP,NE L15$	POPM.32	A0|A1.IF	Color300	ADD.A16	{A2}+ODFIIY,A0	ADD.A16	{A2}+ODFIIY,A1.ELSE	Color300	ADD.A16	#128,A0	ADD.A16	#128,A1.ENDIF	ELSE Color300	DEC.16	D1	JUMP,NE L10$	MOVE.32	{A2}+ODFABS,A0	MOVE.16	#PViewY-LargCY*4,D0	MUL.16	{A2}+ODFIIY,D0	ADD.32	D0,A0	MOVE.16	#1024-PViewX,D0	SR.16	D0.IF	Color300	TEST.8	{A2}+ODFCMD	JUMP,T	R8^Color$	SR.16	#2,D0Color$:.ENDIF	Color300	MOVE.A16 D0,A1	ADD.32	A0,A1	MOVE.16	#LARGCY*4,D1L20$:	MOVE.16	#(PVIEWX/8)/2,D0.IF	Color300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor3$	MOVE.16	#(PViewX/2)/2,D0NoColor3$:.ENDIF	Color300	PUSHM.32 A0|A1L25$:	MOVE.16	{A1+},{A0+}	; dcale une ligne  gauche	DEC.16	D0	JUMP,NE L25$	POPM.32	A0|A1.IF	Color300	ADD.A16	{A2}+ODFIIY,A0	ADD.A16	{A2}+ODFIIY,A1.ELSE	Color300	ADD.A16	#128,A0	ADD.A16	#128,A1.ENDIF	ELSE Color300	DEC.16	D1	JUMP,NE L20$	MOVE.32	{A2}+ODFABS,D0	; D0 <-- adresse du bitmap.IF	Color300	MOVE.32	#PosIDLG,D1	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor4$	ADD.32	D1,D1	ADD.32	D1,D1NoColor4$:	ADD.32	D1,D0.ELSE	Color300	ADD.32	#POSIDLG,D0.ENDIF	ELSE Color300	MOVE.32	D0,_VINCIDL	MOVE.8	#"L",{A2}+ODFCAD+1; mm cadrage = left	CLR.16	{A2}+ODFCAX	; X coin sup/gauche = 0	POPM.32	D0|D1|A0|A1|A2	.ENDIF	SM8.OR.SM100.OR.SM324LIT.OR.SM196.OR.SM300	RET;----------\; SHOWRIGHT >;==========/; Transfre les deux fentres $DIS7 et $DIS8  droite.; in	A1.L	^table d'initialisation de l'cran; out	-; mod	-SHOWRIGHT:	.IF	SM8.OR.SM100.OR.SM324LIT.OR.SM196.OR.SM300	PUSHM.32 D0|D1|A0|A1|A2	MOVE.16	#7,D0	CALL	GETDESC		; A2 <-- ^descripteur $DIS_7	JUMP,EQ	 R8^L02$	MOVE.16	#1024-PVIEWX,{A2}+ODFX	MOVE.16	#1024-PVIEWX,{A2}+ODFIX ; +++ DD +++	CALL	WMINMAX		; init min et max (sous-)fentreL02$:	MOVE.16	#8,D0	CALL	GETDESC		; A2 <-- ^descripteur $DIS_8	JUMP,EQ	 R8^L03$	MOVE.16	#1024-PVIEWX,{A2}+ODFX	MOVE.16	#1024-PVIEWX,{A2}+ODFIX ; +++ DD +++	CALL	WMINMAX		; init min et max (sous-)fentreL03$:	MOVE.16	#9,D0	CALL	GETDESC		; A2 <-- ^descripteur $DIS_9	JUMP,EQ	 R8^L04$	MOVE.16	#1024-PVIEWX+LARGCX*SEPX89,{A2}+ODFX	MOVE.16	#1024-PVIEWX+LARGCX*SEPX89,{A2}+ODFIX ; +++ DD +++	CALL	WMINMAX		; init min et max (sous-)fentreL04$:	MOVE.32	{A6}+OPDFEN+(4*0),A2 ; A2 <-- ^descripteur $DIS_0.IF	Color300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^BlackAndWhite$	MOVE.32	{A2}+ODFABS,A0	MOVE.32	#{A0}+PVIEWX/2,A0	MOVE.32	#{A0}+(1024-PVIEWX)/2,A1	JUMP	R8^Next$BlackAndWhite$:.ENDIF	Color300	MOVE.32	{A2}+ODFABS,A0	MOVE.32	#{A0}+PVIEWX/8,A0	MOVE.32	#{A0}+(1024-PVIEWX)/8,A1.IF	Color300Next$:.ENDIF	Color300	MOVE.16	#SEPY81,D1L10$:	MOVE.16	#(PVIEWX/8)/2,D0.IF	Color300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor1$	ADD.16	D0,D0	ADD.16	D0,D0NoColor1$:.ENDIF	Color300	PUSHM.32 A0|A1L15$:	MOVE.16	{-A0},{-A1}	; dcale une ligne  droite	DEC.16	D0	JUMP,NE L15$	POPM.32	A0|A1.IF	Color300	ADD.A16	{A2}+ODFIIY,A0	ADD.A16	{A2}+ODFIIY,A1.ELSE	Color300	ADD.A16	#128,A0	ADD.A16	#128,A1.ENDIF	ELSE Color300	DEC.16	D1	JUMP,NE L10$.IF	Color300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^BlackAndWhite2$	MOVE.32	{A2}+ODFABS,A0	ADD.32	#512*(PViewY-LargCY*4),A0	MOVE.32	#{A0}+PVIEWX/2,A0	MOVE.32	#{A0}+(1024-PVIEWX)/2,A1	JUMP	R8^Next2$BlackAndWhite2$:.ENDIF	Color300	MOVE.32	{A2}+ODFABS,A0	ADD.32	#128*(PVIEWY-LARGCY*4),A0	MOVE.32	#{A0}+PVIEWX/8,A0	MOVE.32	#{A0}+(1024-PVIEWX)/8,A1.IF	Color300Next2$:.ENDIF	Color300	MOVE.16	#LARGCY*4,D1L20$:	MOVE.16	#(PVIEWX/8)/2,D0.IF	Color300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor2$	ADD.16	D0,D0	ADD.16	D0,D0NoColor2$:.ENDIF	Color300	PUSHM.32 A0|A1L25$:	MOVE.16	{-A0},{-A1}	; dcale une ligne  droite	DEC.16	D0	JUMP,NE L25$	POPM.32	A0|A1.IF	Color300	ADD.A16	{A2}+ODFIIY,A0	ADD.A16	{A2}+ODFIIY,A1.ELSE	Color300	ADD.A16	#128,A0	ADD.A16	#128,A1.ENDIF	ELSE Color300	DEC.16	D1	JUMP,NE L20$	MOVE.32	{A2}+ODFABS,D0	; D0 <-- adresse du bitmap.IF	Color300	MOVE.32	#PosIDLD,D1	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor4$	ADD.32	D1,D1	ADD.32	D1,D1NoColor4$:	ADD.32	D1,D0.ELSE	Color300	ADD.32	#POSIDLD,D0.ENDIF	ELSE Color300	MOVE.32	D0,_VINCIDL	MOVE.8	#"R",{A2}+ODFCAD+1; mm cadrage = right	MOVE.16	#1024-PVIEWX,{A2}+ODFCAX ; X coin sup/gauche	POPM.32	D0|D1|A0|A1|A2	.ENDIF	SM8.OR.SM100.OR.SM324LIT.OR.SM196.OR.SM300	RET	.IF	SM324BIG.AND.FONDBLANC;--------\\; COINS   >;========/; Arrondi les 4 coins du bitmap.; in	A2.L	^descripteur bitmap ($DIS_0); out	-; mod	D7.WCOINS:	PUSHM.32 D0|A0|A1	MOVE.32	{A2}+ODFABS,A1	MOVE.32	#R16^UL$,A0	MOVE.16	#8-1,D0L10$:	MOVE.8	{A0+},{A1}	; dessine le coin en haut  gauche	MOVE.32	#{A1}+1024/8,A1	DJ.16,NMO  D0,L10$	MOVE.32	{A2}+ODFABS,A1	ADD.32	#(PVIEWX/8)-1,A1	MOVE.32	#R16^UR$,A0	MOVE.16	#8-1,D0L20$:	MOVE.8	{A0+},{A1}	; dessine le coin en haut  droite	MOVE.32	#{A1}+1024/8,A1	DJ.16,NMO  D0,L20$	MOVE.32	{A2}+ODFABS,A1	ADD.32	#(1024/8)*(PVIEWY-8),A1	MOVE.32	#R16^DL$,A0	MOVE.16	#8-1,D0L30$:	MOVE.8	{A0+},{A1}	; dessine le coin en bas  gauche	MOVE.32	#{A1}+1024/8,A1	DJ.16,NMO  D0,L30$	MOVE.32	{A2}+ODFABS,A1	ADD.32	#((1024/8)*(PVIEWY-8))+(PVIEWX/8)-1,A1	MOVE.32	#R16^DR$,A0	MOVE.16	#8-1,D0L40$:	MOVE.8	{A0+},{A1}	; dessine le coin en bas  droite	MOVE.32	#{A1}+1024/8,A1	DJ.16,NMO  D0,L40$	POPM.32	D0|A0|A1	RET	.IF	FALSEUL$:	.8	2'11111000	.8	2'11100000	.8	2'11000000	.8	2'10000000	.8	2'10000000	.8	2'00000000	.8	2'00000000	.8	2'00000000UR$:	.8	2'00011111	.8	2'00000111	.8	2'00000011	.8	2'00000001	.8	2'00000001	.8	2'00000000	.8	2'00000000	.8	2'00000000DL$:	.8	2'00000000	.8	2'00000000	.8	2'00000000	.8	2'10000000	.8	2'10000000	.8	2'11000000	.8	2'11100000	.8	2'11111000DR$:	.8	2'00000000	.8	2'00000000	.8	2'00000000	.8	2'00000001	.8	2'00000001	.8	2'00000011	.8	2'00000111	.8	2'00011111	.ENDIF	FALSEUL$:	.8	2'11111110	.8	2'11111000	.8	2'11100000	.8	2'11000000	.8	2'11000000	.8	2'10000000	.8	2'10000000	.8	2'00000000UR$:	.8	2'01111111	.8	2'00011111	.8	2'00000111	.8	2'00000011	.8	2'00000011	.8	2'00000001	.8	2'00000001	.8	2'00000000DL$:	.8	2'00000000	.8	2'10000000	.8	2'10000000	.8	2'11000000	.8	2'11000000	.8	2'11100000	.8	2'11111000	.8	2'11111110DR$:	.8	2'00000000	.8	2'00000001	.8	2'00000001	.8	2'00000011	.8	2'00000011	.8	2'00000111	.8	2'00011111	.8	2'01111111	.ENDIF	SM324BIG.AND.FONDBLANC	.END