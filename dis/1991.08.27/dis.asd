	.TITLE	DIS.ASD;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------;	Source des pilotes *_DIS.DRIV	.PROC	M68000;-	.LISTIFDebugOpeDesc	=	FALSE		; Affiche le rsultat des coursesDebugReset	=	FalseSafety		=	True		; Utilise toujours ColorFauSRC.macro	waitKey.if	Falsepush.32	d3mon	?getcarpop.32	d3.endif	false.endmacro.MACRO	AF.IF	FALSEpush.16	sfPUSH.32		D3MON	?AFTIM.ASCIZE	" (Dis %1) "mon	?getcarPOP.32		D3pop.16	sf.ENDIF	FALSE.ENDMACRO; Assemblage conditionnel; -----------------------ModifJFG	=	TRUE.if	ModifJFG	.INS	TESTMACHINE.ASITestmachineCOSTRONIC	=	COS21ROMABLE		=	TRUE.ELSE	.REF	MACHINESM100	=	_SM100		; Smaky 100SM324	=	_SM324		; Smaky 324 SM324LIT =	 _SM324LIT	;   petit cran comme Smaky 100 SM324BIG =	 _SM324BIG	;   grand cran 80 MHz Smaky 324SM8	=	_SM8		; Smaky 8ROMABLE	=	TRUECOSTRONIC=	FALSE		; cran graphique COSTRONIC (avec SM324BIG=1).ENDIF	ModifJFG.IF	SM100.OR.SM8.OR.COSTRONIC.OR.SM196COLOR	=	FALSE.ENDIF	SM100.OR.SM8.OR.COSTRONIC.OR.SM196.IF	SM324COLOR	=	False		; youpie, k's b.ENDIF	SM324.IF	SM300COLOR		=	False	; Pas l'ancienne couleur...Color300	=	True	; ...mais la nouvelle !!!Prov300		=	True	; Bricolages provisoires.ELSE	SM300Color300	=	False	; Ni l'une, ni l'autre.Prov300		=	False.ENDIF	ELSE SM300BIGCOLOR=	FALSE		; grand cran couleurCOLOR8	=	FALSE		; seulement 8 couleurs (3 plans)	.IF	SM324BIG.OR.SM300FONDBLANC=	1		; cran  fond blanc (si SM324BIG=1)	.ELSEFONDBLANC=	0		; cran  fond blanc (si SM324BIG=1)	.ENDIF	SM324BIG.OR.SM300DISREV	=	6		; rvisionDISVERS	=	11		; version	.REV	DISREV,DISVERS	.CODE	0,0,0,0,0,0,0,0,"?","?","F",0	.IDENT	"(C)  Daniel ROUX et EPSITEC-system sa"; Date		Rev	Amliorations; ------------------------------------------------------------------------------------------; 21.05.91	6.11	commande IM[pos.B][tat.B][type.B];			  pos:	position 0..3 pour M0, M1, SHIFT-M0 et SHIFT-M1;			  tat:	0=rien, 1=release, 1=enter;			  type:	0=5 1/4", 1=3 1/2", 2=hyperflex, 3=autre; 04.10.90		+++ JMP +++ Correction dans ColorFauSrc qui ne calculait pas la;			distance juste entre deux couleurs.; 30.09.90		+++ JMP +++ Adaptation  la couleur (presque) termine; 13.09.90		+++ JMP +++ Dbut de la (r)adaptation  la couleur; 16.08.90	6.10	+++ JFG +++ Adaptation au Smaky 300; 23.11.89	6.8	+++ DD +++ Dplacement ODFIX selon RIGHT/LEFT (pour clic souris);			Il est possible de cliquer tout en haut d'un grand cran 324 -> CLE/CLOCK; 15.11.89	6.7	+++ DD +++ GETPGC durant la lecture en parallle du mme genc !!;			nb. Il faudrait faire mieux avec un second smaphore !!; 26.06.89	6.6	LOADGC: si NRF28 => prend NRF14 et construit 2x de nouveau ok;			LOADGC: ne cherche plus que les gencars SMA_;			install fentres 7,8,9 cal  gauche possible (pour RECUP); 16.06.89	6.5	charge XCAR  l'install d'une fentre normale; 09.06.89	6.4	LOADGC retourne l'erreur effective de XCAR; 30.05.89	6.3	MAXGC=32 --> 64 (et ODFMAP doubl); 13.04.89	6.2	LOADGC utilise le module XCAR si ncessaire; 31.03.89	6.1	mode graphique = GRACLIP par dfaut; 19.12.88	6.0	nouveaux: XPEN/XTRAME/XMAPTT (et LGDIS8);			ODFIY,ODFIDY: corrige bug avec LIB,?OPEBITMAP; 17.10.88	5.5	si SM324 petit cran => utilise NRF09; 07.10.88	5.4	soft-keys: SNF12 -> SNF11 et NEF12 -> NEF11;			ASSGC,MEMGC: supprims;			liens fixes: NRF12-NEF11, NEF12-NEF11 et SNF12-SNF11; 11.08.88	5.3	si romable, utilise _SMODECR; 04.07.88	5.2	mode GRACLIP2: clipping aussi pour les caractres; 02.05.88	5.1	AFFILLT/AFFILLA;			MMODULO;			utilise le module GRA 2.1 presque entirement refait !;			romable et relogeable; 11.04.88	5.0	nouveaux: COLORxx; 09.03.88	4.8	LOADGC: ne bloque plus tous les accs cran; 14.12.87	4.7	$DIS_6 ayant 640x340 points (comme SMAKY100); 25.11.87	4.6	nouveau .INS DISSOFTKEY.ASI pour ODFPSK.L; 20.11.87	4.5	.IF SM324 repris selon BB; 19.04.87		BB: adaptation grand cran Smaky 324; 04.04.87		BB: 1re adaptation Smaky 324; 02.03.87	4.4	commutation rapide de diapos selon 100_INFO; 25.02.87	4.3	AFGREY/AFFULL; 11.02.87	4.2	pour GENCAR: clear bit 2'7 de la fonte (D3.B); 12.01.87	4.1	gencar 2x plus petits possibles;			nouveau: NEWGC o f ssss t; 12.12.86	4.0	nom des gencars: (SMA,100)_TRP14.GENC; 09.12.86		commande SCRPARAM rinitialise bien tout; 21.11.86		nouvelle commande SCRPARAM; 08.10.86		CLOBITMAP si gencar n'existe pas !; 24.09.86		SPRITEs laisse la souris (si possible); 29.05.86		PFIXGC uniquement pour fontes "D" et "Q"; 06.05.86		SMAKY100: 4 grands bitmaps; 16.04.86		utilise ?CLOAD/?CUNLOAD pour les gencars; 28.02.86		PFIXGC prfix pour les gnrateurs; 11.02.86		LGDIS6 pour peindre en mmoire !; 09.01.86		DRAWPMOUSE ssss,cccc: matrice(s) de la souris	.REF	GRAMISC	.IF	SM8	.REF	SM8HARD	.ENDIF	SM8	.IF	SM324	.IF	.NOT.COSTRONIC	.REF	SM324HARD	.ENDIF	.NOT.COSTRONIC	.ENDIF	SM324	.IF	SM196	.REF	SM196HARD	.REF	SHIDRIV196	.REF	MON	.ENDIF	SM196	.IF	SM300	.REF	SM300HARD	.REF	SHIDRIV300	.REF	INDROM300	.ENDIF	SM300	.IF	MODIFJFG	.REF	SMAKY	.REF	MON	.ELSE	.REF	SM8	.REF	M8SYS	.REF	NTREL	.REF	FOS	.REF	GESMEM	.REF	BIOS	.ENDIF	ModifJFG	.REF	BIOSDRIV	.REF	BIOS	.IF	ModifJFG	.else	.REF	DRIVERS	.endif	ModifJFG	.REF	DOLIB	.REF	GRA2	.REF	GRA	.REF	GENCAR	.REF	XCAR	.REF	COLORS	.BASE	10'10	.LAYOUT HEX; Dfinitions diverses; --------------------.IF	.NOT.SM300REGHOR1	=	3		; VDC: numro registre dcalage HREGHOR2	=	2		; VDC: numro registre dcalage HREGVERT	=	7		; VDC: numro registre dcalage VREGPOX	=	13		; VDC: numro registre position XREGPOY	=	12		; VDC: numro registre position YLTAVDC	=	14		; VDC: longueur de la table TAVDCSCRNZONE=	16'093A		; donne l'adresse du premier bitmap cranSCVDC	=	16'094A		; ^table VDC standard	.IF	SM8ADVDC	=	VDC+1ADVDCR	=	VDCR+1	.ENDIF_SMODECR=	16'10EE	.IF	SM100	.REF	SHIDRIV100	; pour _SAVMECRADVDC	=	16'FF9080ADVDCR	=	16'FF9082MODECR	=	16'FF9A20	.ENDIF	.IF	SM324	.IF	COSTRONICBADECR1	=	16'07000000lbmap	=	10'128.IF	SM324LITBADECR2	=	16'07000000+LBMAP*10'1024.ENDIF	SM324LIT.IF	SM324BIGBADECR2	=	16'07000000.ENDIF	SM324BIGADVDC	=	16'FFFFF180ADVDCR	=	16'FFFFF181	.ELSEBADECR1	=	ADECR1BADECR2	=	ADECR2;ADVDC	=	ADVDC;ADVDCR	=	ADVDCR	.ENDIF	.ENDIF	.IF	COLORNOWDOC	=	20		; no fentre du bitmap couleur de baseADVME16	=	16'2000000	; adresse de base VME16M1MEGA	=	1024*1024	; 1 MgaADBCOUL	=	ADVME16+16'C0000000+10*M1MEGAADCVDC	=	ADBCOUL+0ADCVDCR	=	ADBCOUL+2ADCBITS	=	ADBCOUL+2*M1MEGAADCPIXELS=	ADBCOUL+3*M1MEGAADCLOGIC=	ADBCOUL+4*M1MEGAADCRAMDAC=	ADBCOUL+5*M1MEGALGBITS	=	128*1024	; lg entre deux plansMVDCZERO=	0		; mode  M <--  0MVDCAND1=	2		; mode  M <--  D &  MMVDCAND2=	4		; mode  M <-- ~D &  MMVDCNOP	=	6		; mode  M <--  MMVDCAND3=	8		; mode  M <--  D & ~MMVDCLOAD=	10		; mode  M <--  DMVDCXOR	=	12		; mode  M <-- ~D &  M  !   D & ~MMVDCOR1	=	14		; mode  M <--  D !  MMVDCNOR	=	16		; mode  M <-- ~D & ~MMVDCXNOR=	18		; mode  M <--  D &  M  !  ~D & ~MMVDCNOT1=	20		; mode  M <-- ~DMVDCOR2	=	22		; mode  M <-- ~D !  MMVDCNOT2=	24		; mode  M <-- ~MMVDCOR3	=	26		; mode  M <--  D ! ~MMVDCNAND=	28		; mode  M <-- ~D ! ~MMVDCONE	=	30		; mode  M <--  1	.ENDIF	.ENDIF	.NOT.SM300	.IF	SM100.OR.SM324LIT.OR.SM196.OR.sm300DEFTAILLE =	09		; taille par dfaut	.ELSEDEFTAILLE =	11		; taille par dfaut	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.sm300NOBASE	=	16'20		; numro de base pour driver	.IF	COLOR.OR.Color300; Table des couleurs relatives; ----------------------------	.LOC	0OCOLRN:	.BLK.8	4		; numroOCOLRR:	.BLK.8	1		; rouge   -->  |r|g|v|-|  (!)OCOLRG:	.BLK.8	1		; vertOCOLRB:	.BLK.8	1		; bleuOCOLRF:	.BLK.8	1		; fausse couleurLCOLR:	.ENDIF	COLOR.OR.Color300	.IF	COLOR.OR.Color300; Table des fausses couleurs; --------------------------	.LOC	0OCOLFR:	.BLK.8	1		; rougeOCOLFG:	.BLK.8	1		; vertOCOLFB:	.BLK.8	1		; bleuLCOLF:	.ENDIF	COLOR.OR.Color300; Table de description d'une fentre; ----------------------------------MAXSAV	=	10		; nb max de SAVWDO/GETWDO imbriqus	.LOC	0	.BLK.8	LGDIS8		; partie dfinie dans  .REF DRIVERSODFIY:	.BLK.8	2		; copie "invariable" de ODFY  (*)ODFIX:	.BLK.8	2		; copie "invariable" de ODFX  (*)ODFIDY:	.BLK.8	2		; copie "invariable" de ODFDY (*)ODFIDX:	.BLK.8	2		; copie "invariable" de ODFDX (*)ODFADR:	.BLK.8	2		; adresse suite pour comm multiODFNXT:	.BLK.8	2		; adresse routine aprs comm.ODFCPT:	.BLK.8	2		; ^relatif dans commandeODFCCT:	.BLK.8	2		; compteur pour commandeODFCOM:	.BLK.8	30		; buffer d'une commandeODFMAP:	.BLK.8	8		; map des gencar utiliss (voir MAXGC=64 !)ODFPSV:	.BLK.8	2		; "SP" dans ODFSSVODFSSV:	.BLK.8	4*MAXSAV	; stack de ^zones sauvetage fentreODFNGC:	.BLK.8	24		; nom du gnrateur de caractresLGDFEN:; (*)	Ces copies sont ncessaires pour la routine MOIFONE qui;	doit toujours pouvoir trouver dans quelle fentre se;	trouve la souris, mme aprs un LIB,?OPEBITMAP !; Dfinitions du hardware; -----------------------	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300LARGCX	=	6		; largeur caractre standardLARGCY	=	10		; hauteur caractre standard	.ELSELARGCX	=	8		; largeur caractre standardLARGCY	=	16		; hauteur caractre standard	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM8PVIEWX	=	832		; nb points visibles en XPVIEWY	=	512		; nb points visibles en Y	.ENDIF	.IF	SM100.OR.SM324LIT.OR.SM196PVIEWX	=	640		; nb points visibles en XPVIEWY	=	400		; nb points visibles en Y	.ENDIF	.IF	SM300PVIEWX	=	640		; nb points visibles en XPVIEWY	=	480		; nb points visibles en Y	.ENDIF	SM300	.IF	SM324BIGPVIEWX	=	864		; nb points visibles en XPVIEWY	=	1024		; nb points visibles en Y	.ENDIF	.IF	COLOR	.IF	BIGCOLORPCVIEWX	=	928		; nb points visibles en XPCVIEWY	=	736		; nb points visibles en Y	.ELSEPCVIEWX	=	640		; nb points visibles en XPCVIEWY	=	480		; nb points visibles en Y	.ENDIF	BIGCOLOR	.ENDIF	COLORLVIEWX	=	PVIEWX/LARGCX	; nb caractres visibles en XLVIEWY	=	PVIEWY/LARGCY	; nb caractres visibles en Y	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300SEPX89	=	LVIEWX-32	; sparation entre $DIS_8 et 9SEPY81	=	LARGCY+6	; sparation entre $DIS_8 et 1	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM324BIGSEPX89	=	LVIEWX-32	; sparation entre $DIS_8 et 9SEPY81	=	LARGCY+7	; sparation entre $DIS_8 et 1SEPY17	=	PVIEWY-(LARGCY*4)-2 ; sparation entre $DIS_1 et 7	.ENDIF	.IF	SM8SEPX89	=	LVIEWX-32	; sparation entre $DIS_8 et 9SEPY81	=	LARGCY+(LARGCY/2) ; sparation entre $DIS_8 et 1	.ENDIFLARICOX	=	204/LARGCX	; largeur pour les icnes en car	.IF	SM8.OR.SM100.OR.SM324LIT.OR.SM196.OR.SM300POSIDLG	=	(PVIEWX/8)-1POSIDLD	=	(1024/8)-1	.ENDIF	SM8.OR.SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM324BIGPOSIDLG	=	((1024/8)*3)+(PVIEWX/8)-2POSIDLD	=	POSIDLG	.ENDIF	.IF	SM324BIGPBIGY	=	SEPY81+1DBIGY	=	PVIEWY-(LARGCY*4)-2-PBIGYDLITX	=	424		; largeur d'une petite fentreDLITY	=	160+24		; hauteur d'une petite fentreTRAGRIS	=	16'11441144	; trame pour fentre inutilise	.ENDIF; Table pour un bitmap cran complet; ----------------------------------	.IF	COLORMAXBM	=	4+1		; nb max de grands bitmaps	.ELSE	.IF	SM8MAXBM	=	2		; nb max de grands bitmaps	.ELSEMAXBM	=	4		; nb max de grands bitmaps	.ENDIF	SM8	.ENDIF	COLOR	.IF	SM8NBWBM	=	4		; 4 fentres associes	.ENDIF	SM8	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300NBWBM	=	3		; 3 fentres associes	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM324BIGNBWBM	=	7		; 7 fentres associes	.ENDIF	SM324BIG	.LOC	0OBMABS:	.BLK.8	4		; adresse absolue du bitmapOBMWDO:	.BLK.8	NBWBM		; numros des fentres associes	.EVENLBM:; Table pour un gnrateur de caractres; --------------------------------------MAXGC	=	64		; nb max de gn. charg	.LOC	0OGCPT:	.BLK.8	4		; ^absolu dbut gnrateurOGCUSE:	.BLK.8	1		; 0 => lment libre (compteur)OGCF:	.BLK.8	1		; fonteOGCS:	.BLK.8	4		; styleOGCT:	.BLK.8	1		; tailleOGCNF:	.BLK.8	1		; fonte pour le nomOGCNS:	.BLK.8	1		; style pour le nomOGCNT:	.BLK.8	1		; taille pour le nomOGCX:	.BLK.8	1		; 1 => cr par XCAR	.EVENLGGC:; Table d'une image alphanumrique; --------------------------------	.LOC	0OIMADX:	.BLK.16	1		; nb de caractres/ligneOIMADY:	.BLK.16	1		; nb de lignes/fentreOIMACX:	.BLK.16	1		; largeur d'un caractreOIMACY:	.BLK.16	1		; hauteur d'un caractreOIMAPX:	.BLK.16	1		; position en X dans l'imageOIMAPY:	.BLK.16	1		; position en Y dans l'imageOIMASX:	.BLK.16	1		; dbut fentre en XOIMASY:	.BLK.16	1		; dbut fentre en YOIMALX:	.BLK.16	1		; largeur fentre en XOIMALY:	.BLK.16	1		; hauteur fentre en YOIMAOY:	.BLK.16	1		; offset ventuel en YLGIMA:; Dfinitions des variables globales; ----------------------------------	.LOC	0OSTART:	.BLK.16	2		; adr absolue de dbut du code.IF	.NOT.SM300OTAVDC:	.BLK.8	LTAVDC		; table des registres du VDCOTBVDC:	.BLK.8	LTAVDC		; table de base (copie du moniteur)OSREGH:	.BLK.8	1		; cadrage standard horizontalOSREGV:	.BLK.8	1		; cadrage standard vertical.ENDIF	SM300OPDFEN:	.BLK.8	32*4		; ^descripteurs des fentresOADGRA:	.BLK.8	4*(GRA2_LAST-GRA2_FIRST+1)OTAGC:	.BLK.8	MAXGC*LGGC	; table pour les GENCARsOPINFO:	.BLK.8	4		; ^informations dans SYS_INFOOSEMAX:	.BLK.16	2		; ^smaphore d'exclusionOBITMAP:.BLK.8	MAXBM*LBM	; table des bitmapsONOVBM:	.BLK.16	1		; numro du bitmap visible (0..3)	.IF	SM324.OR.SM300OBMUSE:	.BLK.8	1		; bitmap des crans utiliss	.ENDIF	SM324.OR.SM300	.IF	SM324OOREGX:	.BLK.8	1		; offset pour l'utilisation Y du registre X du VDCOWDO23:	.BLK.8	1		; fentre $DIS_2 et $DIS_3 existentOWDO45:	.BLK.8	1		; fentre $DIS_4 et $DIS_5 existent	.ENDIF	SM324ONBGCS:	.BLK.16	1		; nb de gencar "soft" chargsOCHGCS:	.BLK.16	1		; canal du module gencarONBGCX:	.BLK.16	1		; nb de gencar XCAR chargsOCHGCX:	.BLK.16	1		; canal du module XCAROERGCX:	.BLK.16	1		; erreur gnre par XCAROLSTPD:	.BLK.8	4		; ^dernier descripteur de la fentre o est la sourisLGVAR:; Dbut du code du driver; -----------------------	.INS	DISHEAD.ASI; Points d'entres pour les routines de bases; -------------------------------------------;--------\; RESET   >;========/; in	A0.L	^base du driver;	A2.32	^paramtres pour la fentre; out	A6 ^variables du pilote; mod	D0..A1, D7.WD0RESET:				; $DIS_0af	D0Reset	PUSHM.32 D2|D3|D4|A2|A3|A4|A5	MOVE.32	#LGVAR,D4	; D4 <-- longueur totale	MOVE.16	#MTYPBD,D1	; D1 <-- type driver bios	MOVE.32	A0,A1		; A1 <-- ^base du driver	GESMEM	?GETMEM		; demande mmoire pour variables globales	GESMEM	?CLEARMEM	MOVE.32	A4,A6		; A6 <-- ^variables globales	.IF	.NOT.SM300	MOVE.32	SCVDC,A3	MOVE.32	#{A6}+OTBVDC,A4	MOVE.16	#LTAVDC-1,D4L15$:	MOVE.8	{A3+},{A4+}	; OTBVDC <-- copie de la table du moniteur	DJ.16,NMO  D4,L15$	.ENDIF	.NOT.SM300	CALL	OPEDESC		; A2 <-- ^descripteur	CLR.8	D0	.IF	SM300	.ELSE	CALL	NEWVDC		; TAVDC <-- paramtres standards	.ENDIF	SM300	.IF	SM300	MOVE.32	#AdPixelMap1, A4	.ELSE	MOVE.32	SCRNZONE,A4	.ENDIF	SM300	.IF	SM300	CALL	VisuBitMap	; montre le bit map	.ELSE	CALL	INIYBITMAP	.ENDIF	SM300	MOVE.32	A2,{A6}+OLSTPD	; OLSTPD <-- ^descripteur o est la souris	.IF	SM324.OR.SM300	MOVE.8	#2'00000001,{A6}+OBMUSE	; init le bitmap 0 utilis	.ENDIF	SM324.OR.SM300	.IF	SM324	CLR.8	{A6}+OOREGX	; se rappelle de l'offset REGPOX	CLR.8	{A6}+OTAVDC+REGPOX	.ENDIF	.IF	SM8	MOVE.32	SCRNZONE,{A6}+OBITMAP+LBM*0+OBMABS	MOVE.8	#1,{A6}+OBITMAP+LBM*0+OBMWDO+0	MOVE.8	#2,{A6}+OBITMAP+LBM*0+OBMWDO+1	MOVE.8	#3,{A6}+OBITMAP+LBM*0+OBMWDO+2	MOVE.8	#4,{A6}+OBITMAP+LBM*0+OBMWDO+3	MOVE.8	#11,{A6}+OBITMAP+LBM*1+OBMWDO+0	MOVE.8	#12,{A6}+OBITMAP+LBM*1+OBMWDO+1	MOVE.8	#13,{A6}+OBITMAP+LBM*1+OBMWDO+2	MOVE.8	#14,{A6}+OBITMAP+LBM*1+OBMWDO+3	.ENDIF	.IF	SM100.OR.SM324LIT.OR.SM196	MOVE.32	SCRNZONE,{A6}+OBITMAP+LBM*0+OBMABS	MOVE.8	#1,{A6}+OBITMAP+LBM*0+OBMWDO+0	MOVE.8	#10,{A6}+OBITMAP+LBM*0+OBMWDO+1	MOVE.8	#11,{A6}+OBITMAP+LBM*0+OBMWDO+2	MOVE.8	#2,{A6}+OBITMAP+LBM*1+OBMWDO+0	MOVE.8	#12,{A6}+OBITMAP+LBM*1+OBMWDO+1	MOVE.8	#13,{A6}+OBITMAP+LBM*1+OBMWDO+2	MOVE.8	#3,{A6}+OBITMAP+LBM*2+OBMWDO+0	MOVE.8	#14,{A6}+OBITMAP+LBM*2+OBMWDO+1	MOVE.8	#15,{A6}+OBITMAP+LBM*2+OBMWDO+2	MOVE.8	#4,{A6}+OBITMAP+LBM*3+OBMWDO+0	MOVE.8	#16,{A6}+OBITMAP+LBM*3+OBMWDO+1	MOVE.8	#17,{A6}+OBITMAP+LBM*3+OBMWDO+2	.ENDIF	SM100.OR.SM324LIT.OR.SM196	.IF	SM300	MOVE.32	#AdPixelMap1,{A6}+OBITMAP+LBM*0+OBMABS	MOVE.8	#1,{A6}+OBITMAP+LBM*0+OBMWDO+0	MOVE.8	#10,{A6}+OBITMAP+LBM*0+OBMWDO+1	MOVE.8	#11,{A6}+OBITMAP+LBM*0+OBMWDO+2	MOVE.8	#2,{A6}+OBITMAP+LBM*1+OBMWDO+0	MOVE.8	#12,{A6}+OBITMAP+LBM*1+OBMWDO+1	MOVE.8	#13,{A6}+OBITMAP+LBM*1+OBMWDO+2	MOVE.8	#3,{A6}+OBITMAP+LBM*2+OBMWDO+0	MOVE.8	#14,{A6}+OBITMAP+LBM*2+OBMWDO+1	MOVE.8	#15,{A6}+OBITMAP+LBM*2+OBMWDO+2	MOVE.8	#4,{A6}+OBITMAP+LBM*3+OBMWDO+0	MOVE.8	#16,{A6}+OBITMAP+LBM*3+OBMWDO+1	MOVE.8	#17,{A6}+OBITMAP+LBM*3+OBMWDO+2	.ENDIF	SM300	.IF	SM324BIG	MOVE.32	SCRNZONE,{A6}+OBITMAP+LBM*0+OBMABS	MOVE.8	#1,{A6}+OBITMAP+LBM*0+OBMWDO+0	MOVE.8	#-1,{A6}+OBITMAP+LBM*0+OBMWDO+1	MOVE.8	#-1,{A6}+OBITMAP+LBM*0+OBMWDO+2	MOVE.8	#-1,{A6}+OBITMAP+LBM*0+OBMWDO+3	MOVE.8	#-1,{A6}+OBITMAP+LBM*0+OBMWDO+4	MOVE.8	#-1,{A6}+OBITMAP+LBM*0+OBMWDO+5	MOVE.8	#-1,{A6}+OBITMAP+LBM*0+OBMWDO+6	MOVE.8	#2,{A6}+OBITMAP+LBM*1+OBMWDO+0	MOVE.8	#3,{A6}+OBITMAP+LBM*1+OBMWDO+1	MOVE.8	#-1,{A6}+OBITMAP+LBM*1+OBMWDO+2	MOVE.8	#-1,{A6}+OBITMAP+LBM*1+OBMWDO+3	MOVE.8	#-1,{A6}+OBITMAP+LBM*1+OBMWDO+4	MOVE.8	#-1,{A6}+OBITMAP+LBM*1+OBMWDO+5	MOVE.8	#-1,{A6}+OBITMAP+LBM*1+OBMWDO+6	MOVE.8	#4,{A6}+OBITMAP+LBM*2+OBMWDO+0	MOVE.8	#5,{A6}+OBITMAP+LBM*2+OBMWDO+1	MOVE.8	#-1,{A6}+OBITMAP+LBM*2+OBMWDO+2	MOVE.8	#-1,{A6}+OBITMAP+LBM*2+OBMWDO+3	MOVE.8	#-1,{A6}+OBITMAP+LBM*2+OBMWDO+4	MOVE.8	#-1,{A6}+OBITMAP+LBM*2+OBMWDO+5	MOVE.8	#-1,{A6}+OBITMAP+LBM*2+OBMWDO+6	MOVE.8	#6,{A6}+OBITMAP+LBM*3+OBMWDO+0	MOVE.8	#10,{A6}+OBITMAP+LBM*3+OBMWDO+1	MOVE.8	#11,{A6}+OBITMAP+LBM*3+OBMWDO+2	MOVE.8	#12,{A6}+OBITMAP+LBM*3+OBMWDO+3	MOVE.8	#13,{A6}+OBITMAP+LBM*3+OBMWDO+4	MOVE.8	#14,{A6}+OBITMAP+LBM*3+OBMWDO+5	MOVE.8	#15,{A6}+OBITMAP+LBM*3+OBMWDO+6	.ENDIF	SM324BIG	.IF	SM300	MOVE.16	VideoInc,{A2}+ODFIIY	MOVE.32	#AdPixelMap1, {A2}+ODFABS.IF	Color300	MOVE.32	#0,{A2}+ODFCCF				; partout (et mme des clairs)	MOVE.32	#16'F,{A2}+ODFCSF.ENDIF	Color300	.ELSE	MOVE.32	SCRNZONE,{A2}+ODFABS	.ENDIF	SM300	MOVE.32	{A2}+ODFABS,{A2}+ODFCAB	MOVE.16	#1,{A2}+ODFIIX.IF	.NOT.Sm300	MOVE.16	#16'80,{A2}+ODFIIY.ENDIF	.NOT.Sm300	MOVE.32	#R16^NMGRAMISC,A3	MOVE.16	#GMI_First,D3	LIB_	Open	JUMP,NE	L90$	MOVE.32	#R16^NMGRA2,A3	; A3 <-- ^nom module graphique	MOVE.16	#GRA2_FIRST,D3	; D3 <-- code du premier appel	LIB_	OPEN		; charge le module GRA2	JUMP,NE L90$	MOVE.32	#R16^NMGRA,A3	; A3 <-- ^nom module graphique	MOVE.16	#GRA_FIRST,D3	; D3 <-- code du premier appel	LIB_	OPEN		; charge le module GRA	JUMP,NE L90$	MOVE.32	#{A6}+OADGRA,A1	; A1 <-- ^buffer pour les adresses	MOVE.16	#GRA2_FIRST,D3	; D3 <-- premier code du module GRA2	MOVE.16	#(GRA2_LAST-GRA2_FIRST+1)-1,D4L20$:	LIB_	GETAD		; 	MOVE.32	A3,{A1+}	; mmorise l'adresse de la routine	INC.16	D3		; D3 <-- code de l'appel GRA2 suivant	DJ.16,NMO  D4,L20$	MOVE.16	#1,D4	NTREL	?CRESEM		; cre smaphore d'exclusion	MOVE.32	A5,{A6}+OSEMAX	; init ^smaphore	MOVE.32	#R16^START,A1	MOVE.32	A1,{A6}+OSTART	FOS	?OPINFO		; A4 <-- ^infos	JUMP,NE L90$	MOVE.32	A4,{A6}+OPINFO	; mm. ^informations	CLR.16	D4		; D4 <-- pas de mj.	FOS	?CLINFO		; ferme les infos	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	.IF	SM300	MOVE.32	#AdPixelMap1, D0	.ELSE	MOVE.32	SCRNZONE,D0	; D0 <-- adresse de l'cran	.ENDIF	SM300.IF	Color300	TEST.8	{A2}+ODFCMD		; Ecran couleur ?	JUMP,F	R8^IdleBlack$	ADD.32	#PosIdlG*4,D0		; Oui => Idle plus  droite	JUMP	R8^IdleColor$IdleBlack$:	ADD.32	#PosIdlG,D0IdleColor$:.ELSE	Color300	ADD.32	#POSIDLG,D0.ENDIF	ELSE Color300	MOVE.32	D0,_VINCIDL	CLR.8	D0		; D0 <-- fonte par dfaut	CLR.32	D1		; D1 <-- style par dfaut	CLR.8	D2		; D2 <-- taille par dfaut	CLR.32	{A2}+ODFMAP+0	; clear compltement le map	CLR.32	{A2}+ODFMAP+4	CALL	GCLOAD		; charge le gnrateur standard	TEST.16	D7	JUMP,NE	 R8^L90$	CALL	GCUSE		; (A2)++ <-- paramtres	TEST.16	D7	JUMP,NE	 R8^L90$	CALL	EFFACE		; efface tout (1024 x 1024)	CLR.16	D1		; D1 <-- bitmap principal	CALL	IDIS		; remet les sparations	.IF	.NOT.SM300	CALL	INIVDC		; init le controleur d'cran	.ENDIF	.NOT.SM300	.IF	COLOR	CALL	INIVDCC		; init le controleur d'cran couleur	.ENDIFL80$:	CLR.16	D7		; D7 <-- okL90$:	.IF	ROMABLE	POPM.32	D2|D3|D4|A2|A3|A4|A5	.ELSE	POPM.32	D2|D3|D4|A2|A3|A4|A5|A6	.ENDIF	RETNMGRA:	.ASCIZ	"GRA"		; nom du module GRAphiqueNMGRA2:	.ASCIZ	"GRA2"		; nom du module GRAphiqueNMGRAMISC:	.ASCIZ	"GRAMISC"	.EVENDORESET:Af	Doreset	PUSHM.32 D2|A2|A4|A5	PUSH.32	A0	MOVE.32	#R16^D0BASE,A0	CLR.32	D0	MOVE.32	_INDNTR,A1	CALL	{A1}+OIN_GETDRIVVAR ; A6 <-- ^variables de $DIS_0	POP.32	A0	.IF	SM324BIG	MOVE.16	#ERDNTF,D7	; D7 <-- erreur	COMP.8	#NOBASE+3,{A0}+ODHNUM ; fentre $DIS_3 ?	JUMP,NE	 R8^L10$	; non => 10$	TEST.8	{A6}+OWDO23	; fentres $DIS_2 et $DIS_3 ensemble ?	JUMP,EQ L99$		; non => 99$L10$:	COMP.8	#NOBASE+5,{A0}+ODHNUM ; fentre $DIS_5 ?	JUMP,NE	 R8^L12$	; non => 12$	TEST.8	{A6}+OWDO45	; fentres $DIS_4 et $DIS_5 ensemble ?	JUMP,EQ L99$		; non => 99$L12$:	.ENDIF	SM324BIG	MOVE.32	A2,A1		; A1 <-- ^paramtres	CALL	OPEDESC		; A2 <-- ^descripteur	JUMP,NE L99$	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	MOVE.16	#1,{A2}+ODFIIX.IF	Color300	MOVE.16	VideoInc,{A2}+ODFIIY.ELSE	Color300	MOVE.16	#16'80,{A2}+ODFIIY.ENDIF	ELSE Color300	CALL	DIMOK?		; dimensions fentre ok ?	TEST.16	D7	JUMP,NE	 R8^L90$	; non => 90$	CALL	OPEBITMAP	; A4 <-- ^bitmap	JUMP,NE	 R8^L90$.IF	DebugResetPUSH.32	D3EX.32	D4,A4MON	?AFX8MON	?GETCAREX.32	D4,A4POP.32	D3.ENDIF	DebugReset	MOVE.32	A4,{A2}+ODFABS	MOVE.32	A4,{A2}+ODFCAB	COMP.8	#7,{A2}+ODFNOW	; fentre des soft-keys ?	JUMP,EQ	 R8^L30$	COMP.8	#8,{A2}+ODFNOW	; fentre du C.L.E. ?	JUMP,EQ	 R8^L30$	COMP.8	#9,{A2}+ODFNOW	; fentre du clock ?	JUMP,EQ	 R8^L30$	CALL	GCMXCARLOAD	; charge le module XCAR si ncessaireL30$:	CLR.32	{A2}+ODFMAP+0	; clear compltement le map	CLR.32	{A2}+ODFMAP+4	CALL	GCLOAD		; charge le gnrateur standard	TEST.16	D7	JUMP,NE	 R8^L90$	CALL	GCUSE		; (A2)++ <-- paramtres	TEST.16	D7	JUMP,NE	 R8^L90$	MOVE.32	{A2}+ODFC1Y,{A2}+ODFPY	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	CALL	IMACURS0	; enlve le curseur souris	.IF	COLOR	COMP.8	#NOWDOC,{A2}+ODFNOW	JUMP,NE	 R8^L70$	CALL	EFFACE		; efface la nouvelle fentreL70$:	.ENDIF	COLOR	CALL	IMACURS1	; remet le curseur souris	CLR.16	D7		; D7 <-- okL90$:	TEST.16	D7		; ok ?	JUMP,EQ	 R8^L95$	; oui => 95$	PUSH.16	D7	CALL	CLOBITMAP	; libre le bitmap si ncessaire	POP.16	D7	CALL	CLODESC		; rend le descripteurL95$:	PUSH.16	D7	NTREL	?UNLOCK		; fin de zone critique	POP.16	D7L99$:	.IF	ROMABLE	POPM.32	D2|A2|A4|A5	.ELSE	POPM.32	D2|A2|A4|A5|A6	.ENDIF	ROMABLE	RET;--------\; KILL    >;========/; in	A0.L	^base du driver; out	-; mod	D0..A1DOKILL:Af	DoKill	PUSHM.32 D2|D3|A2|A5|A6	.IF	.NOT.ROMABLE	MOVE.32	#R16^VAR,A6	.ENDIF	.NOT.ROMABLE	CALL	SRCDESC		; A2 <-- ^descripteur fentre	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	CALL	IMACURS0	; enlve curseur souris	CALL	CLRCURS		; enlve le curseur	.IF	SM324BIG	CALL	GRISE		; grise la fentre !!!	.ELSE	CALL	EFFACE		; efface la fentre	.ENDIF	SM324BIG	MOVE.8	#NOCURS,D3	CALL	AFCAR		; supprime un ventuel curseur	TEST.8	{A2}+ODFFLG:#BFIMAA ; image existe ?	JUMP,BC	 R8^L50$	; non => 50$	CALL	KILIMA		; oui => libre mmoireL50$:	CALL	WDOGET		; libre zone sauvetage fentre	CALL	CLOBITMAP	; libre le bitmap si ncessaire	CALL	GCRESET		; supprime gencar(s) utilis(s)	CALL	SETCURS		; remet le curseur (!)	CALL	CLODESC		; libre le descripteur	CALL	IMACURS1	; remet curseur souris	NTREL	?UNLOCK		; fin de zone critique	POPM.32	D2|D3|A2|A5|A6	RET;--------\; COMMAND >;========/; in	A0.L	base du driver;	A4.32	^table des commandes termine par zro; out	D7.W	erreur; mod	D0..A1, D7.WDOCOMMAND:Af	DoCommand	PUSHM.32 A2|A4|A5|A6	.IF	.NOT.ROMABLE	MOVE.32	#R16^VAR,A6	.ENDIF	.NOT.ROMABLE	CALL	SRCDESC		; A2 <-- ^description fentre	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	CALL	IMACURS0	; enlve curseur souris	CLR.16	D7		; D7 <-- okL10$:	TEST.8	{A4}		; fin de la table ?	JUMP,EQ	 R8^L80$	; oui => 80$	CALL	WRONEC		; excute une commande	TEST.16	D7		; commande ok ?	JUMP,NE	 R8^L80$	; non => 80$	JUMP	L10$L80$:	PUSH.16	D7	CALL	IMACURS1	; remet curseur souris	NTREL	?UNLOCK		; fin de zone critique	POP.16	D7	POPM.32	A2|A4|A5|A6	RET;--------\; RSTATUS >;========/; in	A0.L	^base du driver;	A4.32	^buffer;	D4.32	longueur buffer; out	D4.L	longueur rendue effectivement;	D7.16	erreur; mod	D0..A1, D4.L, D7.WDORSTATUS:Af	DoRstatus	PUSHM.32 A2|A5|A6	.IF	.NOT.ROMABLE	MOVE.32	#R16^VAR,A6	.ENDIF	.NOT.ROMABLE	CALL	SRCDESC		; A2 <-- ^description fentre	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	MOVE.32	A2,{A2}+ODFPST	; met le ^au status rel	COMP.16	#4,D4		; profondeur = 4 ?	JUMP,NE	 R8^L10$	; non => 10$				; oui =>	MOVE.32	A2,{A4}		; rend juste le ^au status rel !	CLR.16	D7		; D7 <-- ok	JUMP	L90$L10$:	.IF	SM300	.ELSE	MOVE.8	{A6}+OTAVDC+REGHOR1,{A2}+ODFCAH	MOVE.8	{A6}+OTAVDC+REGVERT,{A2}+ODFCAV	.ENDIF	SM300	MOVE.32	#R16^L00$,A0	CALL	32^_CNVLGS	JUMP,NE	 R8^L90$	MOVE.32	A4,A0		; A0 <-- ^buffer utilisateur	MOVE.16	D4,D0L20$:	MOVE.8	{A2+},{A0+}	; transfre chez l'utilisateur	DEC.16	D0	JUMP,NE L20$L90$:	PUSH.16	D7	NTREL	?UNLOCK		; fin de zone critique	POP.16	D7	POPM.32	A2|A5|A6	RETL00$:				; table pour CNVLGS :	.16	LGDIS0	.16	LGDIS1	.16	LGDIS2	.16	LGDIS3	.16	LGDIS4	.16	LGDIS5	.16	LGDIS6	.16	LGDIS7	.16	LGDIS8	.16	0;--------\; WRITE   >;========/; in	A0.L	^base du driver;	A4.32	^buffer texte;	D5.32	lg maximale du texte; out	D5.L	lg effectivement crite;	D7.16	erreur; mod	D7.W, D5.LDOWRITE:Af	DoWrite	PUSHM.32 D3|D4|D6|A2|A4|A5|A6	.IF	.NOT.ROMABLE	MOVE.32	#R16^VAR,A6	.ENDIF	.NOT.ROMABLE	CALL	SRCDESC		; A2 <-- ^description fentre	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	CALL	CLRCURS		; enlve le curseur	CLR.16	D6		; D6 <-- mm dernire erreur	MOVE.32	D5,D4		; D4 <-- nb caractres  crireL10$:	MOVE.8	{A4+},D3	; D3 <-- caractre  afficher	DEC.32	D4	CALL	AFCAR		; "affiche" un caractre	TEST.16	D7		; erreur lors du AFCAR ?	JUMP,EQ	 R8^L50$	; non => 50$	JUMP,NS	 R8^L40$	; si erreur grave => 40$	TEST.16	D6		; dj mm. erreur grave ?	JUMP,NS	 R8^L50$	; oui => 50$L40$:	MOVE.16	D7,D6		; D6 <-- dernire erreurL50$:	TEST.32	D4	JUMP,NE L10$	SUB.32	D4,D5		; D5 <-- nb caractres crits	CALL	SETCURS		; remet le curseur	NTREL	?UNLOCK		; fin de zone critique	MOVE.16	D6,D7		; D7 <-- dernire erreurL90$:	POPM.32	D3|D4|D6|A2|A4|A5|A6	RET;--------\; READ    >;========/; in	A0.L	^base du driver;	A4.32	^buffer texte;	D5.32	lg  lire;		2^31=1	--> nb points horizontaux (de gauche  droite);		2^30=1	--> nb points verticaux (de bas en haut); out	D5.L	lg effectivement lue;	D7.16	erreur; mod	D7.W, D5.LDOREAD:Af	DoRead	PUSHM.32 D2|D3|D4|A2..A6	.IF	.NOT.ROMABLE	MOVE.32	#R16^VAR,A6	.ENDIF	.NOT.ROMABLE	CALL	SRCDESC		; A2 <-- ^description fentre	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	TEST.32	D5:#31		; lecture graphique horizontale ?	JUMP,BS L40$		; oui => 40$	TEST.32	D5:#30		; lecture graphique verticale ?	JUMP,BS L40$		; oui => 40$				; non =>	MOVE.16	D5,D4		; D4 <-- lg  lire	CLR.32	D5		; D5 <-- rien d'encore lu	MOVE.16	#ERRDPR,D7	; D7 <-- read protected driver	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE L90$		; non => 90$ (erreur)	MOVE.32	A4,A5		; A5 <-- ^o mettre les cars.	CALL	GPTIMA		; A4 <-- ^dans image	JUMP,NE L90$		; si hors => 90$	MOVE.32	{A2}+ODFPIM,A3	; A3 <-- ^base de l'image	MOVE.16	{A3}+OIMADX,D3	MUL.16	{A3}+OIMADY,D3	; D3 <-- lg utile de l'image	ADD.32	#LGIMA,D3	; D3 <-- ajoute les frais fixes	ADD.32	D3,A3		; A3 <-- ^max  ne pas dpasser	MOVE.16	#EROUTF,D7	; D7 <-- erreur si dpassementL20$:	COMP.32	A3,A4		; image dpasse ?	JUMP,HS L90$		; oui => 90$	MOVE.8	{A4+},{A5+}	; buffer lecture <- image alpha	INC.32	D5		; D5 <-- un car. lu de plus	DEC.16	D4		; encore qq chose  lire ?	JUMP,NE L20$		; oui => 20$				; non =>	CLR.16	D7		; D7 <-- ok	JUMP	L90$L40$:				; lecture graphique h/v =>	MOVE.16	D5,D0		; D0 <-- lg  lire (points)	MOVE.16	{A2}+ODFPGX,D3	ADD.16	{A2}+ODFWBX,D3	; D3 <-- coordonne X absolue	MOVE.8	D3,D2	MOVE.16	{A2}+ODFPGY,D4	ADD.16	{A2}+ODFWBY,D4	; D3 <-- coordonne Y absolue	MOVE.32	{A2}+ODFABS,A3	; A3 <-- adresse dbut cran	AND.32	#1024-1,D3	; masque coordonne	SR.32	#3,D3	ADD.32	D3,A3		; A3 <-- ajoute offset X	AND.32	#1024-1,D4	; masque coordonne	SL.32	#7,D4	ADD.32	D4,A3		; A3 <-- ajoute offset Y	TEST.32	D5:#30		; lecture verticale ?	JUMP,BS L60$		; oui => 60$; Lit une ligne graphique horizontale allant de gauche  droite.	SR.16	#3,D0		; D0 <-- nb bytes  lire	DEC.16	D0		; -1  cause du test NMOL45$:	MOVE.8	{A3+},{A4+}	; user <-- un byte graphique	DJ.16,NMO  D0,L45$	JUMP	L80$; Lit une ligne graphique verticale allant de bas en haut.L60$:	AND.8	#2'111,D2	; D2 <-- 0..7	INC.8	D2		; D2 <-- dcalage colonne (1..8)L62$:	MOVE.16	#8-1,D1		; -1  cause du test NMO	COMP.16	#8,D0		; reste au moins 8 ?	JUMP,HS	 R8^L65$	; oui => 65$	MOVE.16	D0,D1		; D1 <-- lg du reste	DEC.16	D1		; -1  cause du test NMOL65$:	MOVE.8	{A3},D3		; D3 <-- byte de l'cran	MOVE.32	#{A3}-16'80,A3	; A3 <-- ^plus haut dans l'cran	RLX.8	D2,D3		; "X" <-- un point	RLX.8	#1,D4		; D4 <-- met le point dans "X"	DJ.16,NMO  D1,L65$	SUB.16	#8,D0		; D0 <-- 8 points lus	JUMP,LS	 R8^L67$	MOVE.8	D4,{A4+}	; buffer read <-- un byte	JUMP	L62$L67$:	NEG.16	D0	SL.8	D0,D4		; D4 <-- met qq zro (0..7)	MOVE.8	D4,{A4}		; buffer read <-- dernier byteL80$:	CLR.16	D7		; D7 <-- okL90$:	PUSH.16	D7	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	NTREL	?UNLOCK		; fin de zone critique	POP.16	D7	POPM.32	D2|D3|D4|A2..A6	RET;--------\; DIMOK?  >;========/; Vrifie si les dimensions d'une fentre sont comprises; entre les bornes donnes par l'utilisateur en (A1).; Rend dans D0-D1-D2 le gnrateur de caractres  utiliser.; Si la fonte est "?" "*" ou "-", rend le gnrateur NEF11 ou; NRF09 selon la largeur de la fentre.; in	A1.L	^paramtres;	A2.32	^description fentre; out	D0.B	fonte;	D1.32	style;	D2.8	taille;	D7.16	erreur; mod	D0.B, D1.L, D2.B, D7.WDIMOK?:Af	DimOk?	PUSH.32	D3	CLR.8	D0		; D0 <-- fonte par dfaut	CLR.32	D1		; D1 <-- style par dfaut	CLR.8	D2		; D2 <-- taille par dfaut	MOVE.32	A1,D3		; A1 = zro ?	JUMP,EQ L80$		; oui => 80$ (dimensions ok)				; non =>	COMP.32	#16'00FFFFFF,{A1}; paramtres valides ?	JUMP,EQ L80$		; non => 80$ (dimensions ok)				; oui =>	MOVE.8	{A1}+OIDGCF,D0	; D0 <-- fonte	MOVE.8	{A1}+OIDGCS,D1	; D1 <-- style	MOVE.8	{A1}+OIDGCT,D2	; D2 <-- taille	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFDY,D3	; D3 <-- hauteur fentre	COMP.16	{A1}+OIDYMIN,D3	; trop petit ?	JUMP,LO	 R8^L90$	; oui => 90$	COMP.16	{A1}+OIDYMAX,D3	; trop grand ?	JUMP,HI	 R8^L90$	; oui => 90$	MOVE.16	{A2}+ODFDX,D3	; D3 <-- largeur fentre	COMP.16	{A1}+OIDXMIN,D3	; trop petit ?	JUMP,LO	 R8^L90$	; oui => 90$	COMP.16	{A1}+OIDXMAX,D3	; trop grand ?	JUMP,HI	 R8^L90$	; oui => 90$	TEST.8	D0	JUMP,EQ	 R8^L40$	COMP.8	#"*",D0		; fonte = "*"  ?	JUMP,EQ	 R8^L40$	COMP.8	#"?",D0		; fonte = "?"  ?	JUMP,EQ	 R8^L40$	COMP.8	#"-",D0		; fonte = "-"  ?	JUMP,NE	 R8^L80$L40$:	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	MOVE.8	#"N",D0	MOVE.8	#"R".OR.2**7,D1	MOVE.8	#DEFTAILLE,D2	; NRF09 par dfaut	.ELSE	MOVE.8	#"N",D0	MOVE.8	#"E".OR.2**7,D1	MOVE.8	#DEFTAILLE,D2	; NEF11 par dfaut	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM8	COMP.16	#500,D3		; "grande" fentre ?	JUMP,HS	 R8^L80$	; oui => 80$				; non =>;	MOVE.8	#"N",D0	MOVE.8	#"R".OR.2**7,D1	MOVE.8	#07,D2		; NRF07 par dfaut	.ENDIF	SM8L80$:	CLR.16	D7		; D7 <-- okL90$:	POP.32	D3	RET;--------\\; LOCK    >;========/; Dbut de zone critique pour l'cran.; in	A5.L	^smaphore; out	-; mod	D7.WLOCK:	PUSH.32	D4	NTREL	?LOCK		; dbut de zone critique	JUMP,EQ	 R8^L90$	; ok => 90$	COMP.16	#ERTIMO,D7	; timeout ?	JUMP,NE	 R8^L90$	; non => 90$				; oui =>	MOVE.16	#-1,D4	NTREL	?MODTIM		; met timeout infini	NTREL	?LOCK		; dbut de zone critique	NTREL	?SETTIM		; remet timeout utilisateurL90$:	POP.32	D4	RET; Gestion des variables pour les descripteurs de chaque driver; ------------------------------------------------------------;--------\; OPEDESC >;========/; Prend et initialise les variables pour le descripteur de; la fentre.; in	A0.L	^base du driver; out	A2.L	^descripteur;	D7.16	erreur; mod	D7.W, A2.LOPEDESC:Af	OpeDesc	PUSHM.32 D1|D4|A1|A4	MOVE.32	#LGDFEN,D4	; D4 <-- longueur totale	MOVE.16	#MTYPBD,D1	; D1 <-- type driver bios	MOVE.32	A0,A1		; A1 <-- ^base du driver	GESMEM	?GETMEM		; demande mmoire pour descripteur	JUMP,NE	 R8^L90$	GESMEM	?CLEARMEM	MOVE.32	A4,A2		; A2 <-- ^descripteur	MOVE.32	#{A6}+OPDFEN,A4	CLR.16	D4	MOVE.8	{A0}+ODHNUM,D4	; D4 <-- numro du driver	SUB.16	#NOBASE,D4	; D4 <-- 0..n	SL.16	#2,D4		; *4 car .L	MOVE.32	A2,{A4}+A16^{D4}; mm. ^descripteur	MOVE.32	A0,{A2}+ODFBAS	; mm. ^base du driver	MOVE.32	A4,{A2}+ODFPDE	; mm. ^^descripteurs	CALL	INIDESC		; init le reste du descripteur	CALL	COLDESC		; init la couleur dans le descripteur	JUMP,EQ	 R8^L90$	; ok => 90$				; erreur =>	PUSH.16	D7	MOVE.32	A2,A4		; A4 <-- ^descripteur;	MOVE.16	#MTYPBD,D1	; D1 <-- type driver bios;	MOVE.32	A0,A1		; A1 <-- ^base du driver	GESMEM	?GIVMEM		; rend mmoire pour descripteur	POP.16	D7L90$:.IF	DebugOpeDescMOVE.16	D7,D4PUSH.16	D7MON	?AFTIM.ASCIZE	"<CR>Err="MON	?AFX4MON	?AFTIM.ASCIZE	" Drv="MOVE.8	{A0}+ODHNum,D4MON	?AFX2MON	?AFTIM.ASCIZE	" NoW="MOVE.8	{A2}+ODFNow,D4MON	?AFX2MON	?AFTIM.ASCIZE	" IiY="MOVE.16	{A2}+ODFIIY,D4MON	?AFX4MON	?AFTIM.ASCIZE	" Abs="MOVE.32	{A2}+ODFABS,D4MON	?AFX8MON	?AFTIM.ASCIZE	" CNb="MOVE.16	{A2}+ODFCNb,D4MON	?AFX4MON	?AFTIM.ASCIZE	" CNP="MOVE.8	{A2}+ODFCNP,D4MON	?AFX2MON	?AFTIM.ASCIZE	" CMD="MOVE.8	{A2}+ODFCMD,D4MON	?AFX2MON	?AFCRPUSH.32	D3MON	?GETCARPOP.32	D3POP.16	D7.ENDIF	DebugOpeDesc	POPM.32	D1|D4|A1|A4	TEST.16	D7		; retour EQ/NE	RET;--------\\; INIDESC >;--------/; Initialise le descripteur d'une fentre.; in	A2.L	^descripteur; out	-; mod	D7.WINIDESC:af	IniDesc	PUSHM.32 D4|A1	MOVE.32	{A2}+ODFBAS,A1			; A1 <-- ^base du driver	MOVE.32	{A1+},{A2}+ODFY	MOVE.32	{A1+},{A2}+ODFDY	MOVE.16	{A1+},{A2}+ODFCAD	MOVE.8	{A1+},{A2}+ODFNOW	MOVE.8	{A1+},{A2}+ODFMOD	MOVE.8	{A1+},{A2}+ODFMCA	MOVE.8	#GRACLIP,{A2}+ODFMGR	.IF	SM8.OR.SM100.OR.SM324LIT.OR.SM196	TEST.8	{A6}+OTAVDC+REGPOX		; cran cal  gauche ?	JUMP,EQ	 R8^L15$			; oui => 15$						; non =>	MOVE.16	#1024-PVIEWX,D4	COMP.8	#7,{A2}+ODFNOW	JUMP,EQ	 R8^L14$	COMP.8	#8,{A2}+ODFNOW	JUMP,EQ	 R8^L14$	MOVE.16	#1024-PVIEWX+LARGCX*SEPX89,D4	COMP.8	#9,{A2}+ODFNOW	JUMP,NE	 R8^L15$L14$:	MOVE.16	D4,{A2}+ODFX			; cadre la fentre  droiteL15$:	.ENDIF	SM8.OR.SM100.OR.SM324LIT.OR.SM196	.IF	SM300	TEST.16	VideoSamInit+2			; cran cal  gauche ?	JUMP,EQ	 R8^L15$			; oui => 15$						; non =>	MOVE.16	#1024-PVIEWX,D4	COMP.8	#7,{A2}+ODFNOW	JUMP,EQ	 R8^L14$	COMP.8	#8,{A2}+ODFNOW	JUMP,EQ	 R8^L14$	MOVE.16	#1024-PVIEWX+LARGCX*SEPX89,D4	COMP.8	#9,{A2}+ODFNOW	JUMP,NE	 R8^L15$L14$:	MOVE.16	D4,{A2}+ODFX			; cadre la fentre  droiteL15$:	.ENDIF	SM300	.IF	SM324BIG	COMP.8	#2,{A2}+ODFNOW	JUMP,NE	 R8^L20$	TEST.8	{A6}+OWDO23	; fentre $DIS_2 et $DIS_3 ensemble ?	JUMP,EQ	 R8^L20$	MOVE.16	#(DBIGY-10)/2,{A2}+ODFDYL20$:	COMP.8	#4,{A2}+ODFNOW	JUMP,NE	 R8^L30$	TEST.8	{A6}+OWDO45	; fentre $DIS_4 et $DIS_5 ensemble ?	JUMP,EQ	 R8^L30$	MOVE.16	#(DBIGY-10)/2,{A2}+ODFDYL30$:	.ENDIF	SM324BIG	MOVE.32	{A2}+ODFY,{A2}+ODFIY		; copie rfrence (pour MOUSE)	MOVE.32	{A2}+ODFDY,{A2}+ODFIDY	.IF	SM324BIG			; +++ DD +++	COMP.8	#8,{A2}+ODFNOW	JUMP,EQ	 R8^L14$	COMP.8	#9,{A2}+ODFNOW	JUMP,NE	 R8^L15$L14$:	MOVE.16	#0,{A2}+ODFIY			; souris valable jusque tout en hautL15$:	.ENDIF	SM324BIG			; +++ DD +++	MOVE.8	#2'11111111,{A2}+ODFTTM	MOVE.8	#1,{A2}+ODFTTS	MOVE.8	#2**BFWMOU,{A2}+ODFFLG	.IF	FONDBLANC	TSET.8	{A2}+ODFMOD:#BFBLANC	.ENDIF	FONDBLANC	MOVE.32	#R16^TASOFTKEY,A1	MOVE.32	A1,{A2}+ODFPSK	; mm. ^table pour soft-keys	POPM.32	D4|A1	RET;--------\\; COLDESC >;--------/; Initialise le descripteur d'une fentre en fonction de la couleur.; in	A0.L	^base du driver;	A2.32	^descripteur; out	D7.W	erreur; mod	D7.WCOLDESC:AF	ColDesc	PUSHM.32 D1|D4|A1|A4.IF	Color300	CLR.8	{A2}+ODFCMD		; Pas encore en couleur...	MOVE.16	VideoInc,D4	MOVE.16	D4,{A2}+ODFIIY		; Initialise le descripteur	COMP.16	#512,D4			; Mode couleur [berke] ?	JUMP,LO	BlackWhiteScreen$	; Non => on est en N/B	MOVE.32	#MTypBD,D1		; Demande de la mmoire pour notre table	MOVE.32	A0,A1			; des fausses couleurs.	MOVE.32	#LColF*16,D4	GESMEM	?GetMem	JUMP,NS	L90$	MOVE.32	A4,{A2}+ODFCPF		; ODFCPF <-- ^table des fausses couleurs	TEST.8	{A2}+ODFNOW		; $DIS_0 ?	JUMP,NE	R8^NotDis0$		; Non => copie de la CLUT de $DIS_0	MOVE.32	#R16^TaFaux,A1		; Oui => CLUT initiale comme en ROMSetupCLUT$:	MOVE.32	#(LColF*16)/4-1,D4CopyFalse$:	MOVE.32	{A1+},{A4+}	DJ.16,NMO D4,CopyFalse$	TEST.8	{A2}+ODFNOW		; $DIS_0 ?	JUMP,NE	R8^NoRelCol$		; Non => pas de couleurs relatives	JUMP	R8^L15$			; Oui => rserve les couleurs relativesNotDis0$:	PUSH.32	A4	MOVE.32	{A6}+OPDFen,A4		; A4 ^descr. $DIS_0	MOVE.32	{A4}+ODFCPF,A1		; A1 ^CLUT de $DIS_0	POP.32	A4	JUMP	SetupCLUT$L15$:	MOVE.16	#200,D4		; D4 <-- 200 couleurs relatives au maximum (?)	MOVE.16	D4,{A2}+ODFCMR	; ODFCMR <-- nb max de couleurs relatives	MUL.16	#LCOLR,D4	; D4 <-- longueur totale	MOVE.16	#MTYPBD,D1	; D1 <-- type driver bios	MOVE.32	A0,A1		; A1 <-- ^base du driver	GESMEM	?GETMEM		; demande mmoire pour couleurs relatives	JUMP,NE L75$	MOVE.32	A4,{A2}+ODFCPR	; ODFCPR <-- ^table	JUMP	R8^RelCol$NoRelCol$:	CLR.32	{A2}+ODFCPRRelCol$:	MOVE.16	#10,D4		; D4 <-- nb max de PUSHs	MOVE.16	D4,{A2}+ODFCMS	; ODFCMS <-- nb max de PUSHs	MUL.16	#4*2,D4		; D4 <-- longueur totale	MOVE.16	#MTYPBD,D1	; D1 <-- type driver bios	MOVE.32	A0,A1		; A1 <-- ^base du driver	GESMEM	?GETMEM		; demande mmoire pour stack des couleurs	JUMP,NE	 R8^L80$	MOVE.32	A4,{A2}+ODFCPS	; ODFCPR <-- ^stack	MOVE.16	#16,{A2}+ODFCNB	; ODFCNB <-- 16 couleurs	MOVE.8	#4,{A2}+ODFCNP	; ODFCNP <-- 4bits/pixel	MOVE.8	#1,{A2}+ODFCMD	; ODFCMD <-- mode couleur	MOVE.32	#0,{A2}+ODFCLG ; ODFCLG <-- distance entre deux plans	MOVE.32	#16'0,{A2}+ODFCCF	MOVE.32	#16'F,{A2}+ODFCSF	MOVE.32	#COLOR_PPSET,{A2}+ODFCOM	CALL	DOCOSR		; init la couleur pour dessiner	MOVE.32	#COLOR_PPCLEAR,{A2}+ODFCOM	CALL	DOCOCR		; init la couleur pour effacer	CLR.16	D7		; D7 <-- ok	JUMP	R8^L90$L80$:	TEST.8	{A2}+ODFNow	; $DIS_0 ?	JUMP,NE	R8^L75$		; non => pas de fausses couleurs  rendre	PUSH.16	D7	MOVE.32	{A2}+ODFCPF,A4	; A4 <-- ^table	MOVE.16	#MTYPBD,D1	; D1 <-- type driver bios	MOVE.32	A0,A1		; A1 <-- ^base du driver	GESMEM	?GIVMEM		; rend la mmoire pour les fausses couleurs	CLR.32	{A2}+ODFCPF	POP.16	D7L75$:	TEST.8	{A2}+ODFNoW	; $DIS_0 ?	JUMP,NE	R8^L90$		; non => pas de couleurs relatives  rendre	PUSH.16	D7	MOVE.32	{A2}+ODFCPR,A4	; A4 <-- ^table	MOVE.16	#MTYPBD,D1	; D1 <-- type driver bios	MOVE.32	A0,A1		; A1 <-- ^base du driver	GESMEM	?GIVMEM		; rend la mmoire pour couleurs relatives	CLR.32	{A2}+ODFCPR	POP.16	D7	JUMP	R8^L90$BlackWhiteScreen$:.ENDIF	Color300L85$:	MOVE.16	#2,{A2}+ODFCNB	; ODFCNB <-- 2 niveaux de gris	MOVE.8	#1,{A2}+ODFCNP	; ODFCNP <-- 1 seul plan	CLR.8	{A2}+ODFCMD	; ODFCMD <-- mode noir et blanc (monochrome)	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D1|D4|A1|A4	TEST.16	D7		; retour EQ/NE	RET;--------\; SRCDESC >;========/; Cherche les variables pour le descripteur de la fentre.; in	A0.L	^base du driver; out	A2.L	^descripteur; mod	A2.LSRCDESC:af	SrcDesc	PUSH.16	D2	MOVE.32	#{A6}+OPDFEN,A2	CLR.16	D2	MOVE.8	{A0}+ODHNUM,D2	; D2 <-- numro du driver	SUB.16	#NOBASE,D2	; D2 <-- 0..n	SL.16	#2,D2		; *4 car .L	MOVE.32	{A2}+A16^{D2},A2; A2 <-- ^descripteur	POP.16	D2	RET;--------\; IFDESC  >;========/; Cherche si les variables pour le descripteur de la fentre; existent.; in	D0.W	numro de la fentre (0..n); out	NE	descripteur existe;	EQ	descripteur n'existe pas; mod	-IFDESC:af	IfDesc	PUSH.32	A2	CALL	GETDESC	POP.32	A2	RET;--------\; GETDESC >;========/; Cherche les variables pour le descripteur de la fentre.; in	D0.W	numro de la fentre (0..n); out	NE	descripteur existe;	 A2.32	 ^descripteur;	EQ	descripteur n'existe pas; mod	A2.LGETDESC:af	Getdesc	PUSH.32	D0	MOVE.32	#{A6}+OPDFEN,A2	SL.16	#2,D0		; *4 car .L	MOVE.32	{A2}+A16^{D0},D0; D0 <-- ^descripteur	JUMP,EQ	 R8^L90$	MOVE.32	D0,A2		; A2 <-- ^descripteurL90$:	POPM.32	D0	RET;--------\; CLODESC >;========/; Rend les variables pour le descripteur de la fentre.; in	A2.L	^descripteur; out	-; mod	-CLODESC:af	CloDesc	PUSHM.32 D1|D7|A1|A4	MOVE.16	#MTYPBD,D1	; D1 <-- type driver bios	MOVE.32	{A2}+ODFBAS,A1	; A1 <-- ^base du driver	.IF	COLOR.OR.Color300.IF	Color300	TEST.32	{A2}+ODFCPF	; Fausses couleurs ?	JUMP,EQ	R8^NoFalse$	; Non => rien  rendre	MOVE.32	{A2}+ODFCPF,A4	GESMEM	?GivMem	CLR.32	{A2}+ODFCPFNoFalse$:.ENDIF	Color300	TEST.32	{A2}+ODFCPR	JUMP,EQ	 R8^L10$	MOVE.32	{A2}+ODFCPR,A4	; A4 <-- ^zone mmoire	GESMEM	?GIVMEM		; demande mmoire pour couleurs relatives	CLR.32	{A2}+ODFCPRL10$:	TEST.32	{A2}+ODFCPS	JUMP,EQ	 R8^L20$	MOVE.32	{A2}+ODFCPS,A4	; A4 <-- ^zone mmoire	GESMEM	?GIVMEM		; demande mmoire pour stack des couleurs	CLR.32	{A2}+ODFCPSL20$:	.ENDIF	COLOR.OR.Color300	MOVE.32	A2,A4		; A4 <-- ^zone mmoire	GESMEM	?GIVMEM		; demande mmoire pour descripteur	MOVE.32	#{A6}+OPDFEN,A4	CLR.16	D1	MOVE.8	{A1}+ODHNUM,D1	; D1 <-- numro du driver	SUB.16	#NOBASE,D1	; D1 <-- 0..n	SL.16	#2,D1		; *4 car .L	CLR.32	{A4}+A16^{D1}	; ^descripteur = ^nil	POPM.32	D1|D7|A1|A4	RET; Initialisation gnrale de $DIS_0; ---------------------------------;--------\; IDIS    >;========/; Met les traits de sparations entre les fentres.; in	D1.W	numro du bitmap (0..3); out	-; mod	D7.WIDIS:af IDis	PUSHM.32 D0|D3|D4|A1|A2	MOVE.32	{A6}+OPDFEN+(4*0),A2 ; A2 <-- ^desc. cran complt	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#SEPY81,D4	; D4 <-- Y	MOVE.16	#1024,D0	; D0 <-- dX (longueur);trap	#1	CALL	SEGHOR		; droite sous $DIS8,9waitKey;trap	#1	MOVE.16	#PVIEWX+4,D3	MOVE.16	#PVIEWY-(LARGCY/2)-(LARGCY*5),D0	CALL	SEGVERT		; droite entre $DIS1 et $DIS2/3waitkey.if	sm300	move.16	#(Largcy*2)+(Largcy*(Lviewy-6)/2), d4.else	MOVE.16	#LARGCY*2+170,D4.endif	sm300	MOVE.16	#1024-(PVIEWX+4),D0	CALL	SEGHOR		; droite entre $DIS2 et $DIS3waitkey	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.SM300		.IF	SM324BIG	.IF	FONDBLANC	CALL	COINS		; arrondi les 4 coins	.ENDIF	fondblanc		MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#SEPY81,D4	; D4 <-- Y	MOVE.16	#PVIEWX,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS8,9	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#SEPY17,D4	; D4 <-- Y	MOVE.16	#PVIEWX,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS1	TEST.16	D1	JUMP,EQ BITMAP1$	COMP.16	#1,D1	JUMP,EQ BITMAP2$	COMP.16	#2,D1	JUMP,EQ BITMAP3$	COMP.16	#3,D1	JUMP,EQ BITMAP4$	JUMP	L90$BITMAP1$:	MOVE.32	#R16^D1BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_1	JUMP	L90$BITMAP2$:	TEST.8	{A6}+OWDO23	; fentre $DIS_2 et $DIS_3 ensemble ?	JUMP,NE	 R8^BITMAP2B$	; oui => BITMAP2B$	MOVE.32	#R16^D2BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_2	JUMP	L90$BITMAP2B$:	MOVE.32	#R16^D2BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	SWAP.32	D3	MOVE.16	#(DBIGY-10)/2,D3	SWAP.32	D3	CALL	TRARECT		; grise $DIS_2	MOVE.32	#R16^D3BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_3	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#PBIGY+((DBIGY-10)/2)+0,D4 ; D4 <-- Y	MOVE.16	#PVIEWX,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS_2	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#PBIGY+((DBIGY-10)/2)+10-1,D4 ; D4 <-- Y	MOVE.16	#PVIEWX,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus $DIS_3	JUMP	L90$BITMAP3$:	TEST.8	{A6}+OWDO45	; fentre $DIS_4 et $DIS_5 ensemble ?	JUMP,NE	 R8^BITMAP3B$	; oui => BITMAP3B$	MOVE.32	#R16^D4BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_4	JUMP	L90$BITMAP3B$:	MOVE.32	#R16^D4BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	SWAP.32	D3	MOVE.16	#(DBIGY-10)/2,D3	SWAP.32	D3	CALL	TRARECT		; grise $DIS_4	MOVE.32	#R16^D5BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_5	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#PBIGY+((DBIGY-10)/2)+0,D4 ; D4 <-- Y	MOVE.16	#PVIEWX,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS_4	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#PBIGY+((DBIGY-10)/2)+10-1,D4 ; D4 <-- Y	MOVE.16	#PVIEWX,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus $DIS_5	JUMP	L90$BITMAP4$:	MOVE.32	#R16^D6BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_6	MOVE.32	#R16^D10BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_10	MOVE.32	#R16^D11BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_11	MOVE.32	#R16^D12BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_12	MOVE.32	#R16^D13BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_13	MOVE.32	#R16^D14BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_14	MOVE.32	#R16^D15BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_15	MOVE.16	#((PVIEWX-640)/2)-1,D3 ; D3 <-- X	MOVE.16	#PBIGY+8-1,D4	; D4 <-- Y	MOVE.16	#640+1,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus $DIS_6	MOVE.16	#((PVIEWX-640)/2)-1,D3 ; D3 <-- X	MOVE.16	#PBIGY+8+340,D4	; D4 <-- Y	MOVE.16	#640+1,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessous $DIS_6	MOVE.16	#((PVIEWX-640)/2)-1,D3 ; D3 <-- X	MOVE.16	#PBIGY+8-1,D4	; D4 <-- Y	MOVE.16	#340+1,D0	; D0 <-- dY (hauteur)	CALL	SEGVERT		; droite  gauche $DIS_6	MOVE.16	#((PVIEWX-640)/2)+640,D3 ; D3 <-- X	MOVE.16	#PBIGY+8-1,D4	; D4 <-- Y	MOVE.16	#340+1+1,D0	; D0 <-- dY (hauteur)	CALL	SEGVERT		; droite  droite $DIS_6	MOVE.16	#PBIGY+DBIGY-((8+DLITY)*3)-1,D4	CALL	LITLEFT$	MOVE.16	#PBIGY+DBIGY-((8+DLITY)*2)-1,D4	CALL	LITLEFT$	MOVE.16	#PBIGY+DBIGY-((8+DLITY)*1)-1,D4	CALL	LITLEFT$	MOVE.16	#PBIGY+DBIGY-((8+DLITY)*3)-1,D4	CALL	LITRIGHT$	MOVE.16	#PBIGY+DBIGY-((8+DLITY)*2)-1,D4	CALL	LITRIGHT$	MOVE.16	#PBIGY+DBIGY-((8+DLITY)*1)-1,D4	CALL	LITRIGHT$	.ENDIF	SM324BIG	.IF	SM8; UTILISER UNE FOIS LARGCX ET LARGCY AU LIEU DE 8 ET 16 !!!	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#SEPY81,D4	; D4 <-- Y	MOVE.16	#1024-8,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS8,9,10	MOVE.16	#800-4,D3	MOVE.16	#32+160+8,D4	MOVE.16	#1024-(800-4)-8,D0	CALL	SEGHOR		; droite entre $DIS2 et 3	MOVE.16	#32+160+16+112+8,D4	CALL	SEGHOR		; droite entre $DIS3 et 4	MOVE.16	#800-4,D3	MOVE.16	#SEPY81,D4	MOVE.16	#8+160+16+112+16+112,D0	CALL	SEGVERT		; droite entre $DIS1 et 2,3,4	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#512+SEPY81,D4	; D4 <-- Y	MOVE.16	#1024-8,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS8,9,10	MOVE.16	#800-4,D3	MOVE.16	#512+32+160+8,D4	MOVE.16	#1024-(800-4)-8,D0	CALL	SEGHOR		; droite entre $DIS12 et 13	MOVE.16	#512+32+160+16+112+8,D4	CALL	SEGHOR		; droite entre $DIS13 et 14	MOVE.16	#800-4,D3	MOVE.16	#512+SEPY81,D4	MOVE.16	#8+160+16+112+16+112,D0	CALL	SEGVERT		; droite entre $DIS11 et 12,14	.ENDIF	SM8L90$:	POPM.32	D0|D3|D4|A1|A2	RET	.IF	SM324BIGLITLEFT$:	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#DLITX+1,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus	ADD.16	#DLITY+1,D4	CALL	SEGHOR		; droite dessous	SUB.16	#DLITY+1,D4	MOVE.16	#DLITX,D3	; D3 <-- X	MOVE.16	#DLITY+1,D0	; D0 <-- dY (hauteur)	CALL	SEGVERT		; droite  droite	RETLITRIGHT$:	MOVE.16	#DLITX+16-1,D3	; D3 <-- X	MOVE.16	#DLITX+1,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus	ADD.16	#DLITY+1,D4	CALL	SEGHOR		; droite dessous	SUB.16	#DLITY+1,D4	MOVE.16	#DLITY+1,D0	; D0 <-- dY (hauteur)	CALL	SEGVERT		; droite  droite	RET	.ENDIF	SM324BIG;--------\; SEGHOR  >;--------/; Trace un segment horizontal.; in	A2.L	^description de la fentre;	D3.16	coordonne X;	D4.16	coordonne Y;	D0.16	longueur; out	-; mod	D7.WSEGHOR:	PUSHM.32 D0|D1|D3|D4	SWAP.32	D4	MOVE.16	D3,D4		; D4 <-- coordonne (y;x)	CLR.32	D3	MOVE.16	D0,D3		; D3 <-- longueurs (dy;dx)	MOVE.16	#SETDOT,D1	; D1 <-- mode	GRA2_	LINE		; dessine une ligne horizontale	.IF	SM8	SWAP.32	D4	DEC.16	D4	SWAP.32	D4	GRA2_	LINE		;  cause du mode entrelac	.ENDIF	SM8	POPM.32	D0|D1|D3|D4	RET;--------\; SEGVERT >;--------/; Trace un segment vertical.; in	A2.L	^description de la fentre;	D3.16	coordonne X;	D4.16	coordonne Y;	D0.16	longueur; out	-; mod	D7.WSEGVERT:	PUSHM.32 D0|D1|D3|D4	SWAP.32	D4	MOVE.16	D3,D4		; D4 <-- coordonne (y;x)	CLR.32	D3	MOVE.16	D0,D3	SWAP.32	D3		; D3 <-- longueurs (dy;dx)	MOVE.16	#SETDOT,D1	; D1 <-- mode	GRA2_	LINE		; dessine une ligne verticale	.IF	SM8	DEC.16	D4	GRA2_	LINE		;  cause du mode entrelac	.ENDIF	SM8	POPM.32	D0|D1|D3|D4	RET	.IF	SM324BIG;--------\\; TRARECT >;--------/; Dessine une trame grise rectangulaire.; in	D4.L	origine (y;x);	D3.32	dimensions (dy;dx); out	-; mod	D7.WTRARECT:	PUSHM.32 D1|A4	MOVE.16	#SETDOT,D1	; D1 <-- mode	MOVE.32	#R16^L00$,A4	; A4 <-- ^trame	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_TRAME-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_TRAME	POP.32	A0	POPM.32	D1|A4	RETL00$:	.32	TRAGRIS	.32	TRAGRIS	.ENDIF	SM324BIG	.INS	DISCAR.ASI.IF	COLOR.OR.Color300	.INS	DISCOLOR.ASI.ENDIF	Color.OR.Color300	.INS	DISMOUSE.ASI	.INS	DISGC.ASI	.INS	DISTYPO.ASI	.INS	DISMOVE.ASI	.INS	DISHARD.ASI	.INS	DISCOMM.ASI	.INS	DISBITMAP.ASI	.INS	DISSOFTKEY.ASI	.INS	DISVAR.ASI	.END