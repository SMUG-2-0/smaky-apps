	.SBTTL	GRACODIMA.ASI; Codage/Dcodage d'image; =======================	DD_4	= 4; Le codage propos ici transforme une succession d'octets identiques; en deux octets (paterne/nombre). Les octets solitaires sont laisss; inchangs. Un octet supplmentaire est rajout tous les 8 objets pour; dire quel sont les octets non cod.; Paramtres;	image		image;	code	       dcode;	-----				---; A4 -> |   |				 v	espacement minimal IMLBUF;	|   |		-----		---;	|   |	  A3 ->	|   |;	|   |		|   |;	-----		|   |;			|   |;			~~~~~; Les 2 buffers peuvent se chevaucher (ou non) comme ci-dessus,; aussi bien au codage qu'au dcodage. Il faut toutefois toujours laisser; au moins #IMLBUF au dessus de l'image dcode.; DESCRIPTION DES ROUTINES; ========================;-------------\\; _GRA_CODEIMA >;=============/; Codage d'une image en format DD-4.; in	A3.L		^image non code;	A4.L		^buffer codage	(infrieur ou gal  #{A3}-IMLBUF);	A2.L		^entte du fichier image; out	{A4}+++		buffer rempli avec l'image code;	{A2}+OIMCOD	signale image code DD-4;	{A2}+OIMNBB	longueur image code;	D7.W	erreur;		#ERDIBUF buffers incorrects;		#ERDINC image non codable (trop alatoire);		#ERDIDC image dj code; mod	D7.W_GRA_CODEIMA:	PUSHM.L	D0..D4,A0..A2; Contrle d'abord si l'image n'est pas code.	LOAD.W	D7,#ERDIDC	TEST.B	(A2)+OIMCOD	; code zro ?	JUMP,NE	EXIT$		; non -> erreur; Contrle l'espacement minimal des ^	CALL	TSTSPACE	; A3-A4 suffisant ?	JUMP,NE	EXIT$		; non -> erreur; Contrle ensuite que l'image n'est pas trop alatoire.	LOAD.L	D0,#IMLBUF-1	; longueur de rserve pour le codage-marge	LOAD.L	A0,A3		; ^d'analyse	LOAD.L	D4,(A2)+OIMNBB	; nb d'octets  coderNXTM$:	LOAD.W	D3,#8-1		; compteur de 8 lmentsNXTP$:	LOAD.B	D1,(A0)		; paterne en test	LOAD.B	D2,#0		; nb de rptitionCPT$:	TEST.L	D4		; encore un octet ?	JUMP,EQ	FIN$		; non -> fin	COMP.B	D1,(A0)		; toujours la mme paterne ?	JUMP',NE STO$		; non -> stoque	INC.L	A0		; oui -> suivant	INC.L	D0		; une place libre de plus	DEC.L	D4		; un octet de moins	INC.B	D2		; compte les paternes identiques	JUMP,NE	CPT$		; -> compte encore				; 256* -> stoqueSTO$:	DEC.L	D0		; place pour la paterne	COMP.B	D2,#1		; un seul octet ?	JUMP',EQ ONE$		; oui -> une seul place	DEC.L	D0		; place pour le compteurONE$:	DECJ.W,NMO D3,NXTP$	; 8 lments trouvs ?				; non -> "code" la suite	DEC.L	D0		; place pour le byte de MAP	JUMP,NE	NXTM$		; reste de la place -> ok nextERR$:				; dbordement possible ici seulement	LOAD.W	D7,#ERDINC	; image non codable	JUMP	EXIT$		; -> erreurFIN$:	TEST.B	D2		; encore une paterne ?	JUMP',EQ FMAP$		; non -> place juste le MAP	DEC.L	D0		; place pour la paterne	COMP.B	D2,#1		; un seul octet ?	JUMP',EQ FMAP$		; oui -> une seul place	DEC.L	D0		; place pour le compteurFMAP$:	DEC.L	D0		; place pour le byte de MAP	JUMP,EQ	ERR$	DEC.L	D0		; et pour le byte compteur MAP	JUMP,EQ	ERR$	COMP.L	D0,#IMLBUF	; on y gagne quelque chose ?	JUMP,LS	ERR$		; -> non c'est pas la peine; Code finalement l'image en partant du haut !; in	A0.L	^fin de l'image  coder;	D0.L	espacement (fin image  coder) - (fin image code)	INC.L	D0		; bouche marge de 1	NEG.L	D0		; trou restant	ADD.L	D0,A0		; ^fin image code	SUB.L	D0,A3		; long.	ADD.L	D0,#IMLBUF	; avec buffer	LOAD.L	A1,A4		; ^buffer user	LOAD.L	A0,A3		; ^image	LOAD.B	(A2)+OIMCOD,#DD_4 ; image code	LOAD.L	D4,(A2)+OIMNBB	; nb d'octets  coder	LOAD.L	(A2)+OIMNBB,D0	; long. codecNXTM$:	LOAD.W	D3,#8-1		; compteur de 8 lments	CLR.L	D0		; MAP de codagecNXTP$:	LOAD.B	D1,(A0)		; paterne en test	LOAD.B	D2,#0		; nb de rptitioncCPT$:	TEST.L	D4		; encore un octet ?	JUMP,EQ	cFIN$		; non -> cFIN$	COMP.B	D1,(A0)		; toujours la mme paterne ?	JUMP',NE cSTO$		; non -> stoque	INC.L	A0		; oui -> suivant	DEC.L	D4		; un octet de moins	INC.B	D2		; compte les paternes identiques	JUMP,NE	cCPT$		; oui -> compte encore				; over -> stoquecSTO$:	COMP.B	D2,#1		; un seul octet ?	JUMP',EQ cONE$		; oui -> une seul place	LOAD.B	(A1+),D2	; place le compteur	TSET.L	D0:D3		; signale codcONE$:	LOAD.B	(A1+),D1	; place la paterne	TEST.L	D4		; correction BUG DD 13.3.91	JUMP',EQ cFMAP$		; si fin correspond exactement  256 octets cods !	DECJ.W,NMO D3,cNXTP$	; 8 lments trouvs ? non -> "code" la suite	LOAD.B	(A1+),D0	; place le byte de MAP	JUMP	cNXTM$		; -> nextcFIN$:	TEST.B	D2		; encore une paterne ?	JUMP',EQ cFMAP$		; non -> place juste le MAP	COMP.B	D2,#1		; un seul octet ?	JUMP',EQ cFONE$		; oui -> une seul place	LOAD.B	(A1+),D2	; place le compteur	TSET.L	D0:D3		; signale compteurcFONE$:	LOAD.B	(A1+),D1	; place la dernire paternecFMAP$:	LOAD.B	(A1+),D0	; place le dernier MAP	LOAD.B	(A1+),D3	; garde le dernier compteur MAPEXIT$:	POPM.L	D0..D4,A0..A2	TEST.W	D7		; c'tait bon ?	RET;-------------\\; _GRA_DECOIMA >;=============/; Dcodage d'une image en format DD-4.; in	A3.L	^buffer image dcode	(suprieur ou gal  #{A4}+IMLBUF);	A4.L	^image code;	A2.L	^entte du fichier image; out	{A3}+++	buffer rempli avec l'image decode;	{A2}+OIMCOD	signale image non code;	{A2}+OIMNBB	longueur image non code;	D7.W	erreur;		#ERDIBUF buffers incorrects;		#ERDIND image non dcodable (autre code);		#ERDIDD image dj dcode; mod	D7.W_GRA_DECOIMA:	PUSHM.L	D0..D5,A0,A1; Vrifie d'abord si l'image est code avec un code connu.	LOAD.W	D7,#ERDIND	; D7 <-- erreur pas cod	TEST.B	(A2)+OIMCOD	; image code ?	JUMP,EQ	EXIT$		; non => EXIT$	LOAD.W	D7,#ERDIDD	; D7 <-- erreur mauvais code	COMP.B	(A2)+OIMCOD,#DD_4 ; est-ce le bon codage ?	JUMP,NE	EXIT$		; non => EXIT$; Contrle l'espacement minimal des ^	CALL	TSTSPACE	; A3-A4 suffisant ?	JUMP,NE	EXIT$		; non => EXIT$; Dcode depuis le bas.	LOAD.L	A1,A4		; A1 <-- ^image code	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- nb d'octet donne code	ADD.L	A1,D4		; A1 <-- ^fin du data cod;	LOAD.W	D5,(A2)+OIMDLX	; D5 <-- largeur	CLR.W	D5	LOAD.B	D5,(A2)+OIMBIP	MUL.WU	D5,(A2)+OIMDLX	; D5 <-- largeur image couleur	ADD.W	D5,#8-1		; D5 <-- si image non multiple de 8 pts	SR.W	D5,#3		; D5 <-- /8 (en octets)	MUL.WU	D5,(A2)+OIMDLY	; D5 <-- surface image dcode	LOAD.L	A0,A3		; A0 <-- ^buffer image dcode	ADD.L	A0,D5		; A0 <-- ^fin buffer dcodage	CLR.B	(A2)+OIMCOD	; OIMCOD <-- signale plus cod	LOAD.L	(A2)+OIMNBB,D5	; OIMNBB <-- lg data dcod	CLR.L	D3	LOAD.B	D3,(-A1)	; D3 <-- valeur restante compteur au codage	DEC.L	D4NXTM$:	LOAD.B	D0,(-A1)	; D0 <-- MAP	DEC.L	D4		; fin data ?	JUMP',CS FIN$		; si fini juste avant MAPNXTP$:	TEST.L	D4		; fin des datas	JUMP',EQ FIN$	JUMP',NS FAT$		; contrle cohrence	DEC.L	D5		; vrifie buffer destination	JUMP',CS FAT$		; pas possible	LOAD.B	(-A0),(-A1)	; copie paterne	DEC.L	D4		; fin data ?;	JUMP',CS FAT$		; pas possible	TEST.L	D0:D3		; code ?	JUMP',F	NC$		; non => saute	LOAD.B	D2,(-A1)	; nb d'identiques	DEC.L	D4	DEC.B	D2		; dj un en placeLP$:	DEC.L	D5		; reste de la place ?	JUMP',CS FAT$		; pas possible	LOAD.B	(-A0),(A0)	; copie paterne	DEC.B	D2		; encore une copie ?	JUMP,NE	LP$		; oui => LP$NC$:	INC.L	D3		; D3 <-- ^MAP suivant	COMP.B	D3,#8		; 8 passs ?	JUMP,LO	NXTP$		; non => boucle	LOAD.L	D3,#0		; D3 <-- init compteur MAP	JUMP	NXTM$FIN$:	TEST.L	D5		; destination bien pleine ?	JUMP',EQ EXIT$		; oui => okFAT$:	LOAD.W	D7,#ERDIND	; D7 <-- pas possible !EXIT$:	POPM.L	D0..D5,A0,A1	TEST.W	D7	RET;---------\\; TSTSPACE >;---------/; Test si les pointeurs sont corrects pour le fonctionnement.; in	A3.L	^image dcode;	A4.L	^image code;	A2.L	^entte image; out	D7.W	erreur/ok; mod	D7.W, D0.LTSTSPACE:	LOAD.W	D7,#ERDIBUF	; buffer incorrect ?	LOAD.L	D0,A3		; ^image dcode	SUB.L	D0,A4		; ^image cod	JUMP',CS TEST2$		; A4>A3 -> test 2	COMP.L	D0,#IMLBUF	; pas la place ?	JUMP',LO EXIT$		; non -> erreur	JUMP'	OK$		; oui -> okTEST2$:;	LOAD.W	D0,(A2)+OIMDLX	; largeur * hauteur	CLR.W	D0	LOAD.B	D0,(A2)+OIMBIP	MUL.WU	D0,(A2)+OIMDLX	; D0 <- largeur image couleur	ADD.W	D0,#8-1		; D0 <-- si image non multiple de 8 pts	SR.W	D0,#3		; D0 <-- /8 (en octets)	MUL.WU	D0,(A2)+OIMDLY	; = surface	ADD.L	D0,A3		; ^fin image	COMP.L	D0,A4		; fin>A4	JUMP',HI EXIT$		; oui -> erreurOK$:	CLR.W	D7		; non -> correctEXIT$:	TEST.W	D7	RET	.END