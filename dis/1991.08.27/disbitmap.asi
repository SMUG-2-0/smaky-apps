	.CHAP	DISBITMAP;----------\\; OPEBITMAP >;==========/; Ouvre un nouveau bitmap.; in	A2.L	^descripteur de la fentre; out	A4.L	^bitmap;	D7.16	erreur; mod	D7.W, A4.LOPEBITMAP:af	OpeBitMap	PUSHM.32 D0|D1|A1|A2	.IF	COLOR;;-	LOAD.L	A4,#ADCPIXELS	; A4 <-- ^bitmap couleur	MOVE.32	#ADCPIXELS,D0	MOVE.32	D0,A4	COMP.8	#NOWDOC,{A2}+ODFNOW	JUMP,EQ L85$	.ENDIF	COLOR	CALL	CHERBITMAP	; A1 <-- ^table du bitmap	JUMP,EQ	 R8^L20$	MOVE.16	{A6}+ONOVBM,D1	; D1 <-- no bitmap visible	JUMP	R8^L40$L20$:	CALL	FREEBITMAP	; bitmap existe ?	JUMP,EQ	 R8^L50$	; non => 50$; S'il s'agit d'un bitmap global ($DIS_0, 7, 8 ou 9), rend; le bitmap visible.; S'il s'agit d'un bitmap dj occup (dans une autre fentre),; rend le bitmap dj occup.L30$:	MOVE.16	D1,D0	MUL.16	#LBM,D0	MOVE.32	#{A6}+OBITMAP,A1	ADD.32	D0,A1	MOVE.32	{A1}+OBMABS,A4	; A4 <-- ^bitmap visible	JUMP	R8^L80$L40$:	MOVE.16	D1,D0	MUL.16	#LBM,D0	MOVE.32	#{A6}+OBITMAP,A1	ADD.32	D0,A1	MOVE.32	{A1}+OBMABS,A4	; A4 <-- ^bitmap visible	JUMP	R8^L85$; S'il s'agit d'un bitmap libre, demande de la mmoire pour.L50$:	.IF	COLOR	MOVE.32	{A1}+OBMABS,A4	; A4 <-- ^bitmap couleur	COMP.8	#NOWDOC,{A1}+OBMWDO+0	JUMP,HS	 R8^L80$	.ENDIF	COLOR	MOVE.32	{A1}+OBMABS,A4	COMP.8	#1,{A1}+OBMWDO+0	JUMP,EQ	 R8^L80$	CALL	GETMBITMAP	; A4 <-- ^nouveau bitmap	JUMP,NE	 R8^L90$	MOVE.32	A4,{A1}+OBMABS	MOVE.32	{A6}+OPDFEN+(4*0),A2 ; A2 <-- ^descripteur $DIS_0	PUSH.32	{A2}+ODFABS	MOVE.32	A4,{A2}+ODFABS	; init ^adresse du bitmap	CALL	IDIS		; dessine les sparations	POP.32	{A2}+ODFABSL80$:	MOVE.8	#"O",D0		; D0 <-- "O"pen	ADD.8	#"1",D1		; D1 <-- "1..4"	CALL	AFICONE		; allume l'icneL85$:	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D0|D1|A1|A2	TEST.16	D7		; retour EQ/NE	RET;----------\\; CLOBITMAP >;==========/; Ferme un bitmap.; in	A2.L	^descripteur de la fentre; out	-; mod	D7.WCLOBITMAP:Af	CloBitMap	PUSHM.32 D0|D1|A1|A4	CALL	CHERBITMAP	; A1 <-- ^table du bitmap	JUMP,NE	 R8^L90$	CALL	FREEBITMAP	; bitmap encore occup ?	JUMP,NE	 R8^L90$	; oui => 90$; S'il s'agit d'un bitmap plus utilis par personne, montre le; bitmap principal et libre la mmoire.	COMP.16	{A6}+ONOVBM,D1	; libre le bitmap visible ?	JUMP,NE	 R8^L60$	; non => 60$				; oui =>	TEST.16	D1	JUMP,EQ	 R8^L60$	MOVE.16	D1,D0	CLR.16	D1	CALL	CHANBITMAP	; montre le bitmap principal (zro)	MOVE.16	D0,D1L60$:	.IF	COLOR	COMP.8	#NOWDOC,{A1}+OBMWDO+0	JUMP,HS	 R8^L70$	.ENDIF	COLOR	COMP.8	#1,{A1}+OBMWDO+0	JUMP,EQ	 R8^L70$	MOVE.32	{A1}+OBMABS,A4	CALL	GIVMBITMAP	; rend le bitmap	CLR.32	{A1}+OBMABSL70$:	MOVE.8	#"C",D0		; D0 <-- "C"lose	ADD.8	#"1",D1		; D1 <-- "1..4"	CALL	AFICONE		; teint l'icneL90$:	POPM.32	D0|D1|A1|A4	RET;-----------\\; CHERBITMAP >;-----------/; Cherche le bitmap associ  une fentre.; in	A2.L	^descripteur de la fentre; out	A1.L	^table du bitmap;	D1.16	numro du bitmap (0..3);	D7.16	erreur; mod	D1.L, D7.W, A1.LCHERBITMAP:Af	CherBitMap	PUSH.16	D2	MOVE.8	{A2}+ODFNOW,D2	; D2 <-- numro de la fentre	CALL	CHENBITMAP	POP.16	D2	TEST.16	D7		; retour EQ/NE	RET;-----------\\; CHENBITMAP >;-----------/; Cherche le bitmap d'aprs un numro.; in	D2.B	numro de fentre; out	A1.L	^table du bitmap;	D1.16	numro du bitmap (0..3);	D7.16	erreur; mod	D1.L, D7.W, A1.LCHENBITMAP:Af	ChenBitMap	PUSHM.32 D3|A2	CLR.16	D7		; D7 <-- trouv	MOVE.32	#{A6}+OBITMAP,A1	CLR.16	D1L20$:	MOVE.32	#{A1}+OBMWDO,A2	MOVE.16	#NBWBM-1,D3L30$:	COMP.8	{A2+},D2	JUMP,EQ	 R8^L90$	DJ.16,NMO  D3,L30$	MOVE.32	#{A1}+LBM,A1	; A1 <-- ^suivant	INC.16	D1		; D1 <-- no suivant	COMP.16	#MAXBM,D1	JUMP,LO L20$	MOVE.16	#1,D7		; D7 <-- pas trouvL90$:	POPM.32	D3|A2	TEST.16	D7		; retour EQ/NE	RET;-----------\\; FREEBITMAP >;-----------/; Vrifie si le bitmap associ  une fentre est entirement vide.; in	A2.L	^descripteur de la fentre;	A1.32	^table du bitmap; out	D7.W	autre	=>  occup;		zro	=>  libre; mod	D7.WFREEBITMAP:Af	FreeBitMap	PUSHM.32 D1|D2|D3|A2|A3	MOVE.16	#1,D7		; D7 <-- occup	MOVE.8	{A2}+ODFNOW,D3	; D3 <-- numro de la fentre	MOVE.32	#{A1}+OBMWDO,A2	MOVE.16	#NBWBM-1,D1	MOVE.32	#{A6}+OPDFEN,A3L30$:	CLR.16	D2	MOVE.8	{A2+},D2	JUMP,NS	 R8^L40$	COMP.8	D3,D2	JUMP,EQ	 R8^L40$	SL.16	#2,D2		; *4 car .L	TEST.32	{A3}+A16^{D2}	; fentre occupe ?	JUMP,NE	 R8^L90$	; oui => 90$L40$:	DJ.16,NMO  D1,L30$	CLR.16	D7		; D7 <-- libreL90$:	POPM.32	D1|D2|D3|A2|A3	TEST.16	D7		; retour EQ/NE	RET;----------\\; USEBITMAP >;----------/; Vrifie si le bitmap associ  une fentre est entirement vide.; in	D1.W	numro du bitmap (0..3); out	D7.W	autre	=>  occup;		zro	=>  libre; mod	D7.WUSEBITMAP:Af	UseBitMap	PUSHM.32 D1|D2|A1|A3	MOVE.16	#1,D7		; D7 <-- occup	MOVE.32	#{A6}+OBITMAP+OBMWDO,A1	MUL.16	#LBM,D1	ADD.32	D1,A1	MOVE.16	#NBWBM-1,D1	MOVE.32	#{A6}+OPDFEN,A3L30$:	CLR.16	D2	MOVE.8	{A1+},D2	JUMP,NS	 R8^L40$	SL.16	#2,D2		; *4 car .L	TEST.32	{A3}+A16^{D2}	; fentre occupe ?	JUMP,NE	 R8^L90$	; oui => 90$L40$:	DJ.16,NMO  D1,L30$	CLR.16	D7		; D7 <-- libreL90$:	POPM.32	D1|D2|A1|A3	TEST.16	D7		; retour EQ/NE	RET;-----------\\; CHANBITMAP >;===========/; Change de bitmap visible.; in	D1.W	nouveau bitmap; out	D7.W	erreur; mod	D7.WCHANBITMAP:Af	ChanBitMap	PUSHM.32 D0|D1|A1..A4	MOVE.16	#ERDIIL,D7	; D7 <-- "commande illgale"	COMP.16	#MAXBM,D1	JUMP,HS L90$	MOVE.16	D1,D0	MUL.16	#LBM,D1	MOVE.32	#{A6}+OBITMAP,A1	TEST.32	{A1}+A16^{D1}+OBMABS	JUMP,NE	 R8^L20$	.IF	SM324BIG	COMP.16	#1,D0		; fentre de $DIS_2 et $DIS_3 ?	JUMP,NE	 R8^L10$	; non => 10$	NOT.8	{A6}+OWDO23	MOVE.8	D0,D1	MOVE.8	#"C",D0		; D0 <-- "C"lose	ADD.8	#"1",D1		; D1 <-- "1..4"	CALL	AFICONE		; change l'icne	MOVE.32	#R16^PWSK3,A1	CLR.8	{A1}+NWSK3	TEST.8	{A6}+OWDO23	JUMP,EQ L80$	MOVE.8	#3,{A1}+NWSK3	JUMP	L80$L10$:	COMP.16	#2,D0		; fentre de $DIS_4 et $DIS_5 ?	JUMP,NE L90$		; non => 90$	NOT.8	{A6}+OWDO45	MOVE.8	D0,D1	MOVE.8	#"C",D0		; D0 <-- "C"lose	ADD.8	#"1",D1		; D1 <-- "1..4"	CALL	AFICONE		; change l'icne	MOVE.32	#R16^PWSK5,A1	CLR.8	{A1}+NWSK5	TEST.8	{A6}+OWDO45	JUMP,EQ L80$	MOVE.8	#5,{A1}+NWSK5	JUMP	L80$	.ELSE	JUMP	L90$	.ENDIF	SM324BIGL20$:	MOVE.32	{A1}+A16^{D1}+OBMABS,A2; A2 <-- ^nouveau bitmap; Transfert les parties suprieure (CLE, horloge, etc) et infrieure (soft-keys); dans le nouveau bitmap.	MOVE.16	{A6}+ONOVBM,D1	COMP.16	D1,D0		; bitmap dj visible ?	JUMP,EQ L80$		; oui => 80$	MOVE.16	D0,{A6}+ONOVBM	.IF	COLOR	COMP.16	#4,D0		; bitmap destination en couleur ?	JUMP,EQ L80$		; oui => 80$	COMP.16	#4,D1		; bitmap source en couleur ?	JUMP,EQ L80$		; oui => 80$	MOVE.16	D0,{A6}+ONOVBP	.ENDIF	COLOR	CALL	XFERBITMAP	; transfert les parties communes; Modifie l'adresse de base du bitmap  toutes les fentres fixes.	MOVE.32	#{A6}+OPDFEN,A3	TEST.32	{A3}+4*0	JUMP,EQ	 R8^L30$	MOVE.32	{A3}+4*0,A3	MOVE.32	A2,{A3}+ODFABS	; modifie ODFABS de $DIS_0L30$:	MOVE.32	#{A6}+OPDFEN,A3	TEST.32	{A3}+4*7	JUMP,EQ	 R8^L32$	MOVE.32	{A3}+4*7,A3	MOVE.32	A2,{A3}+ODFABS	; modifie ODFABS de $DIS_7L32$:	MOVE.32	#{A6}+OPDFEN,A3	TEST.32	{A3}+4*8	JUMP,EQ	 R8^L34$	MOVE.32	{A3}+4*8,A3	MOVE.32	A2,{A3}+ODFABS	; modifie ODFABS de $DIS_8L34$:	MOVE.32	#{A6}+OPDFEN,A3	TEST.32	{A3}+4*9	JUMP,EQ	 R8^L36$	MOVE.32	{A3}+4*9,A3	MOVE.32	A2,{A3}+ODFABS	; modifie ODFABS de $DIS_9; Dplace l'indicateur "idle".L36$:	MOVE.32	A2,D0		; D0 <-- adresse du bitmap.IF	Color300	COMP.16	#512,VideoInc	JUMP,LO	R8^BW1$	ADD.32	#4*PosIDLG,D0	JUMP	R8^Col1$BW1$:	ADD.32	#POSIDLG,D0Col1$:.ELSE	ADD.32	#POSIDLG,D0.ENDIF	ELSE Color300.IF	SM300	TEST.16	VideoSamInit+2.ELSE	MOVE.32	#{A6}+OTAVDC,A3	; A3 <-- ^table VDC	TEST.8	{A3}+REGPOX	; cran cal  gauche ?.ENDIF	SM300	JUMP,EQ	 R8^L38$	; oui => 38$	MOVE.32	A2,D0		; D0 <-- adresse du bitmap.IF	Color300	COMP.16	#512,VideoInc	JUMP,LO	R8^BW2$	ADD.32	#4*PosIDLD,D0	JUMP	R8^Col2$BW2$:	ADD.32	#POSIDLD,D0Col2$:.ELSE	ADD.32	#POSIDLD,D0.ENDIF	ELSE Color300L38$:	MOVE.32	D0,_VINCIDL; Montre le nouveau bitmap maintenant complet.	MOVE.32	A2,A4	CALL	VISUBITMAP	; montre le nouveau bitmapL80$:	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D0|D1|A1..A4	TEST.16	D7		; retour EQ/NE	RET;-----------\\; XFERBITMAP >;-----------/; Transfert les parties suprieure et infrieure d'un bitmap; dans un autre.; in	D0.W	bitmap destination;	D1.16	bitmap source; out	-; mod	-XFERBITMAP:Af	XferBitMap	PUSHM.32 D0|D1|A0|A1	MOVE.32	#{A6}+OBITMAP,A0	MOVE.32	A0,A1	MUL.16	#LBM,D0	MUL.16	#LBM,D1	ADD.32	D0,A0	ADD.32	D1,A1	MOVE.32	{A0}+OBMABS,A0	; A0 <-- ^bitmap destination	MOVE.32	{A1}+OBMABS,A1	; A1 <-- ^bitmap source.IF	Color300	COMP.16	#512,VideoInc	JUMP,LO	R8^BW1$	MOVE.16	#(512*(SepY81+1)/4)-1,D0	JUMP	R8^Col1$BW1$:	MOVE.16	#(128*(SEPY81+1)/4)-1,D0Col1$:.ELSE	Color300	MOVE.16	#(128*(SEPY81+1)/4)-1,D0.ENDIF	ELSE Color300L20$:	MOVE.32	{A1+},{A0+}	DJ.16,NMO  D0,L20$.IF	Color300	COMP.16	#512,VideoInc	JUMP,LO	R8^BW2$	MOVE.16	#(512*LargCY)-1,D0	ADD.32	#512*(PVIEWY-(SEPY81+1)-(LARGCY*4)),A0	ADD.32	#512*(PVIEWY-(SEPY81+1)-(LARGCY*4)),A1	JUMP	R8^Col2$BW2$:	ADD.32	#128*(PVIEWY-(SEPY81+1)-(LARGCY*4)),A0	ADD.32	#128*(PVIEWY-(SEPY81+1)-(LARGCY*4)),A1	MOVE.16	#(128*LARGCY*4/4)-1,D0Col2$:.ELSE	Color300	ADD.32	#128*(PVIEWY-(SEPY81+1)-(LARGCY*4)),A0	ADD.32	#128*(PVIEWY-(SEPY81+1)-(LARGCY*4)),A1	MOVE.16	#(128*LARGCY*4/4)-1,D0.ENDIF	ELSE Color300L30$:	MOVE.32	{A1+},{A0+}	DJ.16,NMO  D0,L30$	POPM.32	D0|D1|A0|A1	RET	.IF	SM300;-----------\\; GETMBITMAP >;-----------/; in	-; out	A4.L	^nouveau bitmap;	D7.16	erreur; mod	D7.W, A4.LGETMBITMAP:Af	GetMBitMap	PUSHM.32 D1|A0	MOVE.32	#R16^TABDBMAP,A4	MOVE.8	#1-1,D1L10$:	INC.8	D1	TSET.8	{A6}+OBMUSE:D1	JUMP,BC	 R8^L30$	ADD.32	#4,A4		; A4 <-- ^^bitmap suivant	JUMP	L10$; Efface compltement le nouveau bitmap.L30$:	MOVE.32	{A4},A4		; A4 <-- ^bitmap	MOVE.32	A4,A0.IF	Color300	COMP.16	#512,VideoInc	JUMP,LO	R8^BW$	MOVE.16	#(((PViewY)*512)/4)-1,D1	JUMP	R8^Color$BW$:	MOVE.16	#(((PVIEWY)*128)/4)-1,D1 ; D4 <-- /4 car efface par .32Color$:.ELSE	Color300	MOVE.16	#(((PVIEWY)*128)/4)-1,D1 ; D4 <-- /4 car efface par .32.ENDIF	ELSE Color300L40$:	CLR.32	{A0+}		; efface tout le bitmap	DJ.16,NMO  D1,L40$L90$:	POPM.32	D1|A0	CLR.16	D7		; retour EQ toujours (4 bitmaps toujours disponibles)	RET; Table d'adresse de dbut des 3 autres bitmaps :TABDBMAP:	.32	AdPixelMap2			; ^2me bitmap	.32	AdPixelMap3			; ^3me bitmap	.32	AdPixelMap4			; ^4me bitmap.ELSE;-----------\\; GETMBITMAP >;-----------/; Demande de la mmoire pour un nouveau bitmap.; Il faut respecter les contraintes suivantes :;   -	le dbut doit tre modulo 4 Kbytes	.IF	SM100;   -	ne doit pas tre  cheval sur une tranche de 128 Kbytes (2^17);   -   ne doit pas dpasser 1 Mbytes (2^20)	.ENDIF	SM100; in	-; out	A4.L	^nouveau bitmap;	D7.16	erreur; mod	D7.W, A4.LGETMBITMAP:	.IF	SM8	PUSHM.32 D0|A0	MOVE.32	#16'80000+(16'80*PVIEWY),A4	MOVE.32	A4,A0	MOVE.16	#((16'80*PVIEWY)/4)-1,D0; D0 <-- /4 car efface par .LL40$:	CLR.32	{A0+}		; efface tout le bitmap	DJ.16,NMO  D0,L40$	POPM.32	D0|A0	CLR.16	D7		; retour EQ toujours (2 bitmaps toujours disponibles)	RET	.ENDIF	.IF	SM100.OR.SM196	PUSHM.32 D1|D3..D5|A1|A5.IF	SM196	CLR.32	D3.ELSE	CLR.32	D3		; D3 <-- adresse initiale.ENDIF	MOVE.32	#128*PVIEWY,D4	; D4 <-- lg	MOVE.32	#16'1000,D5	; D5 <-- modulo	MOVE.32	#{A6}+OPDFEN,A1	MOVE.32	{A1},A1		; A1 <-- ^descripteur de $DIS_0	MOVE.32	{A1}+ODFBAS,A1	; A1 <-- ^base du driver $DIS_0	MOVE.16	#MTYPBD,D1	; D1 <-- type driver bios; Essaye 8 fois dans des tranches de 128 Kbytes.L20$:	MOVE.32	D3,A4		; A4 <-- adresse minimale	MOVE.32	D3,A5.IF	SM196	ADD.32	#(2**17)-16'10000, A5.ELSE	ADD.32	#2**17,A5.ENDIF	SM196	SUB.32	D4,A5		; A5 <-- adresse maximale (de dbut)	GESMEM	?GETALMEM	; demande la mmoire	JUMP,EQ	 R8^L30$	; ok => 30$				; erreur =>	ADD.32	#2**17,D3	; D3 <-- adresse suivante	COMP.32	#2**20,D3	; dpasse 1 Mbytes ?	JUMP,LO L20$		; non => 20$	JUMP	R8^L90$; Efface compltement le nouveau bitmap.L30$:	MOVE.32	A4,A5	SR.32	#2,D4		; D4 <-- /4 car efface par .L	DEC.16	D4		; D4 <-- -1  cause NMOL40$:	CLR.32	{A5+}		; efface tout le bitmap	DJ.16,NMO  D4,L40$L90$:	POPM.32	D1|D3..D5|A1|A5	TEST.16	D7		; retour EQ/NE	RET	.ENDIF	.IF	SM324	PUSHM.32 D1|A0	MOVE.32	#R16^TABDBMAP,A4	MOVE.8	#1-1,D1L10$:	INC.8	D1	TSET.8	{A6}+OBMUSE:D1	JUMP,BC	 R8^L30$	ADD.32	#4,A4		; A4 <-- ^^bitmap suivant	JUMP	L10$; Efface compltement le nouveau bitmap.L30$:	MOVE.32	{A4},A4		; A4 <-- ^bitmap	MOVE.32	A4,A0	MOVE.16	#(((PVIEWY/16)*2048)/4)-1,D1 ; D4 <-- /4 car efface par .LL40$:	CLR.32	{A0+}		; efface tout le bitmap	DJ.16,NMO  D1,L40$L90$:	POPM.32	D1|A0	CLR.16	D7		; retour EQ toujours (4 bitmaps toujours disponibles)	RET; Table d'adresse de dbut des 3 autres bitmaps :TABDBMAP:	.32	BADECR1+((PVIEWY/16)*2048)	; ^2me bitmap	.32	BADECR2				; ^3me bitmap	.32	BADECR2+((PVIEWY/16)*2048)	; ^4me bitmap	.ENDIF	SM324.ENDIF	SM300;-----------\\; GIVMBITMAP >;-----------/; Rend la mmoire d'un bitmap.; in	A4.L	^mmoire bitmap; out	D7.W	erreur; mod	D7.WGIVMBITMAP:Af	GivMbitMap	.IF	SM300	PUSH.32	D1	CLR.16	D1	COMP.32	#Adpixelmap1,A4	JUMP,EQ	 R8^OKCLR$	INC.16	D1	COMP.32	#AdPixelMap2,A4	JUMP,EQ	 R8^OKCLR$	INC.16	D1	COMP.32	#AdPixelMap3,A4	JUMP,EQ	 R8^OKCLR$	INC.16	D1	COMP.32	#AdPixelMap4,A4	JUMP,EQ	 R8^OKCLR$	INC.16	D1		; scu si erreur ?!OKCLR$:	TCLR.8	{A6}+OBMUSE:D1	POP.32	D1	CLR.16	D7		; retour EQ toujours	RET	.ENDIF	SM300	.IF	SM8	CLR.16	D7		; retour EQ toujours	RET	.ENDIF	.IF	SM100.OR.SM196	PUSHM.32 D1|A1	MOVE.32	#{A6}+OPDFEN,A1	MOVE.32	{A1},A1		; A1 <-- ^descripteur de $DIS_0	MOVE.32	{A1}+ODFBAS,A1	; A1 <-- ^base du driver $DIS_0	MOVE.16	#MTYPBD,D1	; D1 <-- type driver bios	GESMEM	?GIVMEM		; rend la mmoire	POPM.32	D1|A1	TEST.16	D7		; retour EQ/NE	RET	.ENDIF	SM100.OR.SM196	.IF	SM324	PUSH.32	D1	CLR.16	D1	COMP.32	#BADECR1,A4	JUMP,EQ	 R8^OKCLR$	INC.16	D1	COMP.32	#BADECR1+((PVIEWY/16)*2048),A4	JUMP,EQ	 R8^OKCLR$	INC.16	D1	COMP.32	#BADECR2,A4	JUMP,EQ	 R8^OKCLR$	INC.16	D1	COMP.32	#BADECR2+((PVIEWY/16)*2048),A4	JUMP,EQ	 R8^OKCLR$	INC.16	D1		; scu si erreur ?!OKCLR$:	TCLR.8	{A6}+OBMUSE:D1	POP.32	D1	CLR.16	D7		; retour EQ toujours	RET	.ENDIF.IF	SM300;-----------\\VisuBitMap: ;>;===========/;; Visualise un bit map;; in	A4.32	adresse du bit Map; out	-; mod	Af	VisuBitMap.IF	False	PUSHM.32	D0..D1	MOVE.32		A4, D0	MOVE.32		#AdSam, D1	SUB.32		#AdPixelMap1, D0	JUMP,EQ		Init$Loop$:	ADD.32		#64*1024, D1	sub.32		#16'200000, d0	JUMP,NE		Loop$Init$:	MOVE.32		D1, VideoSamInit	POPM.32		D0..D1	RET.else	push.32		a0	move.32		_IndShi, A0	CALL		{A0}+_ShowBitMap	CLR.16		D7	pop.32		a0	ret.ENDIF	FALSE.ELSE;-----------\\; VISUBITMAP >;-----------/; Initialise le contrleur d'cran pour visualiser un bitmap quelconque.; in	A4.L	adresse du bitmap; out	-; mod	D7.WVISUBITMAP:	PUSHM.32 D1..D4|A1.IF	SM196.ELSE	MOVE.32	{A6}+OPINFO,A1	; A1 <-- ^contenu de 100_INFO	NTREL	?GETPRIO	MOVE.16	D4,D1	MOVE.16	#2,D4	NTREL	?SETPRIO	; met trs grande priorit;	MOVE.16	#1,D4;	.W	NTREL,?DELMS	; synchro sur retour de trace !;	MOVE.16	#400-20,D4;	.W	NTREL,?DELUS; Dcale l'cran progressivement vers la gauche.	TEST.8	{A1}+OINSTA:#0	; changement de diapo ultra-rapide ?	JUMP,BS	 R8^L20$	; oui => 20$	MOVE.8	#80/4,D3	MOVE.8	{A6}+OTAVDC+REGPOX,D2	.IF	SM324	ADD.8	{A6}+OOREGX,D2	; additionne l'offset en X	.ENDIFL10$:	MOVE.16	#1,D4	NTREL	?DELMS	INC.8	D2	MOVE.8	#REGPOX,ADVDC	MOVE.8	D2,ADVDCR	DEC.8	D3	MOVE.8	#1,ADVDC	MOVE.8	D3,ADVDCR	; diminue la largeur	TEST.8	D3	JUMP,NE L10$	JUMP	R8^L30$L20$:	MOVE.8	#1,ADVDC	MOVE.8	#0,ADVDCR	; largeur nulle	MOVE.16	#1,D4	NTREL	?DELMS; Maintenant que l'cran n'affiche plus rien, modifie l'adresse; du VDC et de MODECR. Le "parasite" de commutation est invisible; puisque l'cran affiche zro byte par ligne !L30$:.ENDIF	SM196	CALL	INIYBITMAP; Dcale le nouvel cran vers la droite..IF	SM196.ELSE	TEST.8	{A1}+OINSTA:#0	; changement de diapo ultra-rapide ?	JUMP,BS	 R8^L50$	; oui => 50$	CLR.8	D3	MOVE.8	{A6}+OTAVDC+REGPOX,D2	.IF	SM324	ADD.8	{A6}+OOREGX,D2	; additionne l'offset traditionnel	.ENDIF	ADD.8	#80/4,D2L40$:	MOVE.16	#1,D4	NTREL	?DELMS	DEC.8	D2	MOVE.8	#REGPOX,ADVDC	MOVE.8	D2,ADVDCR	INC.8	D3	MOVE.8	#1,ADVDC	MOVE.8	D3,ADVDCR	; augmente la largeur	COMP.8	#80/4,D3	JUMP,NE L40$	JUMP	R8^L60$L50$:	MOVE.16	#1,D4	NTREL	?DELMSL60$:	MOVE.8	#1,ADVDC	MOVE.8	{A6}+OTAVDC+1,ADVDCR ; remet largeur selon le mode !	MOVE.16	D1,D4	NTREL	?SETPRIO	; remet priorit initiale.ENDIF	SM196	POPM.32	D1..D4|A1	RET;-----------\\; INIYBITMAP >;-----------/; Initialise le contrleur d'cran pour visualiser un bitmap quelconque.; in	A4.L	adresse du bitmap; out	-; mod	D7.WINIYBITMAP:	.IF	SM8	PUSH.32	D4	MOVE.32	A4,D4	SUB.32	#16'80000,D4	SWAP.32	D4	SL.8	#5,D4		; D4 <-- H'00 ou H'20	MOVE.8	#REGPOY,ADVDC	MOVE.8	D4,ADVDCR	MOVE.8	D4,{A6}+OTAVDC+REGPOY	POP.32	D4	RET	.ENDIF	.IF	SM100	PUSHM.32 D4|A3	MOVE.32	A4,D4	SR.32	#8,D4	SR.32	#3,D4	AND.16	#2'00111111,D4	MOVE.8	#REGPOY,ADVDC	MOVE.8	D4,ADVDCR	MOVE.8	D4,{A6}+OTAVDC+REGPOY	MOVE.32	A4,D4	SWAP.32	D4	AND.8	#2'00001110,D4	SL.8	#1,D4	TCLR.32	D4:#4	JUMP,BC	 R8^L20$	TSET.32	D4:#1		; D4 <-- C512/C128/C256L20$:	.IF	ROMABLE	AND.8	#2'11110001,_SMODECR	OR.8	D4,_SMODECR	MOVE.8	_SMODECR,MODECR	.ELSE	MOVE.32	_INDSHI,A3	AND.8	#2'11110001,{A3}+_SAVMECR	OR.8	D4,{A3}+_SAVMECR	MOVE.8	{A3}+_SAVMECR,MODECR	.ENDIF	POPM.32	D4|A3	RET	.ENDIF	.IF	SM324	PUSHM.32 D4|D5	MOVE.32	A4,D4	SUB.32	#BADECR1,D4	; D4 <-- adresse relative: shift par 16 lignes	SR.32	#8,D4		; /256	1024 points/ligne= 128 bytes	SR.16	#3,D4		; /8 => /2K	MOVE.8	D4,D5	AND.8	#2'00111111,D4	MOVE.8	D4,{A6}+OTAVDC+REGPOY	MOVE.8	#REGPOY,ADVDC	MOVE.8	{A6}+OTAVDC+REGPOY,ADVDCR	XOR.8	D5,D4		; D4 <-- bits B'11000000	SR.16	#1,D4		; D4 <-- bits B'01100000	MOVE.8	D4,{A6}+OOREGX	OR.8	{A6}+OTAVDC+REGPOX,D4	MOVE.8	#REGPOX,ADVDC	MOVE.8	D4,ADVDCR	POPM.32	D4|D5	RET	.ENDIF	.IF	SM196	PUSHM.32	A0	MOVE.32		_INDSHI, A0	CALL		{A0}+_IniAdBitMap.IF	true	MOVE.8		#REGPOY, ADVDC	MOVE.8		ADVDCR, {A6}+OTAVDC+REGPOY	MOVE.8		#REGPOX, ADVDC;	MOVE.8		ADVDCR, {A6}+OTAVDC+REGPOX	MOVE.8		{A6}+OTAVDC+REGPOX, ADVDCR.ENDIF	FALSE	POPM.32		A0	RET	.ENDIF	SM196.ENDIF	SM300	.END