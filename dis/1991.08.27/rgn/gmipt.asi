	.CHAP	GMIPT.ASI; Traitement des points; =====================;----------------\\;  _GMI_AddPt     >;================/; FUNCTION AddPt(PtA, PtB: Point): Point;; Additionne les coordonnes de PtB  PtA et rend le rsultat.; in	SP^;	+8.32	place pour rsultat;	+4.32	PtA;	+0.32	PtB; out	SP^;	+0.32	rsultat: PtA-PtB; mod	F_GMI_AddPt:	PUSH.32		D0	MOVE.16		{A7}+2*4+4+0,D0		; PtA.y	ADD.16		{A7}+2*4+0+0,D0		; +PtB.y	MOVE.16		D0,{A7}+2*4+8+0		; --> rsultat.y	MOVE.16		{A7}+2*4+4+2,D0		; PtA.x	ADD.16		{A7}+2*4+0+2,D0		; +PtB.x	MOVE.16		D0,{A7}+2*4+8+2		; --> rsultat.x	POP.32		D0	MOVE.32		{A7},{A7}+8	ADD.A16		#8,A7	RET;----------------\\;  _GMI_SubPt     >;================/; FUNCTION SubPt(PtA, PtB: Point): Point;; Soustrait les coordonnes de PtB  PtA et rend le rsultat.; in	SP^;	+8.32	place pour rsultat;	+4.32	PtA;	+0.32	PtB; out	SP^;	+0.32	rsultat: PtA-PtB; mod	F_GMI_SubPt:	PUSH.32		D0	MOVE.16		{A7}+2*4+4+0,D0		; PtA.y	SUB.16		{A7}+2*4+0+0,D0		; -PtB.y	MOVE.16		D0,{A7}+2*4+8+0		; --> rsultat.y	MOVE.16		{A7}+2*4+4+2,D0		; PtA.x	SUB.16		{A7}+2*4+0+2,D0		; -PtB.x	MOVE.16		D0,{A7}+2*4+8+2		; --> rsultat.x	POP.32		D0	MOVE.32		{A7},{A7}+8	ADD.A16		#8,A7	RET;-----------------\\;  _GMI_PtInRect   >;=================/; FUNCTION PtInRect (pt: Point; r: Rect):BOOLEAN;; Teste si le point  droite et en-dessous du point donn; est inclus dans le rectangle donn. Rend TRUE si le; point se trouve  l'intrieur, FALSE sinon.;; in	SP^;	+8.16	place pour BOOLEAN (rendu en retour);	+4.32	pt;	+0.32	^r; out	SP^;	+0.8	BOOLEAN (=1 TRUE, =0 FALSE); mod	F_GMI_PTINRECT:	LINK.32		A6,#+16'0000	PUSHM.32	D0|D1|A0	MOVE.32		{A6}+8+0,A0		; ^r	MOVE.16		{A6}+8+4+2,D0		; x	MOVE.16		{A6}+8+4+0,D1		; y	CLR.8		{A6}+8+8		; BOOLEAN FALSE par dfaut	COMP.16		{A0+},D1		; y < top ?	JUMP,LT		NOTIN$	COMP.16		{A0+},D0		; x < left ?	JUMP,LT		NOTIN$	COMP.16		{A0+},D1		; y >= bottom ?	JUMP,GE		NOTIN$	COMP.16		{A0+},D0		; y >= right ?	JUMP,GE		NOTIN$			; oui => pas dedans (laisse FALSE)	INC.8		{A6}+8+8		; non => dedans (met TRUE)NOTIN$:	POPM.32		D0|D1|A0	UNLINK.32	A6	MOVE.32		{A7},{A7}+8	ADD.A16		#8,A7	RET;-----------------\\;  _GMI_MapPt      >;=================/; On donne un point pt dans SrcRect, et MapPt le repositionne; relativement  DstRect (coordonnes absolues), selon le rapport; des dimensions de DstRect relativement  SrcRect.;; PROCEDURE MapPt (VAR pt: Point; srcRect,dstRect: Rect);; in	SP^;	+8.32	^pt	(rendu en retour);	+4.32	^srcRect;	+0.32	^dstRect; out	pt; mod	F_GMI_MapPt:MAPPT:	LINK.32		A6,#+16'0000	PUSHM.32	D0|D1|D2|D3|D4|D5|D6|A0|A1|A2	MOVE.32		{A6}+16'0010,A0		; A0 ^pt.y	MOVE.32		{A6}+16'000C,A1		; A1 ^srcRect.topleft.y	MOVE.32		{A6}+16'0008,A2		; A2 ^dstRect.topleft.y	CALL		CALCPROP$	ADD.A16		#16'02,A0		; A0 ^pt.x	ADD.A16		#16'02,A1		; A1 ^srcRect.topleft.x	ADD.A16		#16'02,A2		; A2 ^dstRect.topleft.x	CALL		CALCPROP$	POPM.32		D0|D1|D2|D3|D4|D5|D6|A0|A1|A2	UNLINK.32	A6	MOVE.32		{SP},{SP}+16'000C	ADD.A16		#16'000C,SP	RETCALCPROP$:	MOVE.16		{A1},D2			; src.topleft	MOVE.16		{A1}+16'0004,D3		; src.bottomright	SUB.16		D2,D3			; src.delta --> D3	MOVE.16		{A2},D4	MOVE.16		{A2}+16'0004,D5	SUB.16		D4,D5			; dst.delta --> D5	MOVE.16		{A0},D0	SUB.16		D2,D0			; pt.delta  --> D0	COMP.16		D3,D5			; src.delta = dst.delta ?	JUMP,EQ		FIN$			; oui --> translater rel dst	MOVE.16		D3,D1	SR.16		#16'01,D1	CONV.A16.32	D1			; src.delta / 2 --> D1.32	MOVE.16		D0,D2			; delta(pt) positif ?	JUMP,PL		POSITIF$	NEG.16		D0			; non --> rend positifPOSITIF$:	MUL.16		D5,D0			; delta(pt) * delta(dst)	ADD.32		D1,D0			; + delta(src)/2  (pour arrondi !)	DIV.16		D3,D0			; / delta(src)	TEST.16		D2	JUMP,PL		FIN$	NEG.16		D0			; remet negatif s'il l'taitFIN$:	ADD.16		D4,D0			; delta(pt.scal)+dst.topleft	MOVE.16		D0,{A0}			; rend dans le pt	RET	.END