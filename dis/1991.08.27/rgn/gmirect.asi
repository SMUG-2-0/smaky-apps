	.CHAP	GMIRECT.ASI; Traitement des rectangles; =========================;-------------------\\;  _GMI_EmptyRect    >;===================/; FUNCTION EmptyRect (r: Rect): BOOLEAN;; Rend si le rectangle est vide (TRUE=1) ou pas (FALSE=0).; (comparaison par top<bottom et left<right); in	SP^;	+4.16	RESULT:		place pour rsultat;	+0.32	^Rect; out	SP^;	+0.16	RESULT:	BOOLEAN (dans byte de poids fort); mod	F;--------------\\;  EmptyRect    >;==============/_GMI_EmptyRect:EMPTYRECT:	PUSHM.32	D0|D1|A0	MOVE.32		{SP}+4*4+0,A0	; ^r	MOVE.16		{A0+},D0	; top	MOVE.16		{A0+},D1	; left	COMP.16		{A0+},D0	; top >= bottom ?	JUMP,GE		VIDE$	COMP.16		{A0+},D1	; left >= right ?	JUMP,GE		VIDE$	CLR.8		{SP}+4*4+4	; pas vide !	JUMP		RTN$VIDE$:	MOVE.8		#1,{SP}+4*4+4RTN$:	POPM.32		D0|D1|A0	POP.32		{SP}	RET;-------------------\\;  _GMI_InSetRect    >;===================/; PROCEDURE InSetRect (VAR r: Rect; dvBottom, dvTop, dhRight, dhLeft);; Extension (valeurs ngatives de dh ou dv) ou diminution (valeurs positives); d'un rectangle relativement  son centre; les cots gauche et droite bougent chacun de dhLeft, resp. dhRight.; le haut et le bas bougent chacun de dvTop, resp. dvBottom.; l'effet est que les dimensions du rectangle diminuent de dvTop+dvBottom, et; de dhLeft+dhRight; le rectangle peut devenir vide ( [(0,0),(0,0)] ).; Un rectangle vide est agrandit uniquement autour de l'origine; in	SP^;	+8.32	^rect;	+4.32	dvTop;dvBottom;	+0.32	dhLeft;dhRight; out	SP^	rien;	Result,Remainder,Over; mod	F_GMI_InSetRect:	PUSHM.32 D3|D4|D7|A3	MOVE.32	{SP}+5*4+0,D4		; dhLeft;dhRight	MOVE.32	{SP}+5*4+4,D3		; dhTop;dhBottom	MOVE.32	{SP}+5*4+8,A3		; ^rect	CALL	InSetRect	POPM.32	D3|D4|D7|A3	MOVE.32	{SP},{SP}+4+8	ADD.32	#4+8,SP	RET;--------------\\;  InSetRect    >;==============/; Extension (valeurs ngatives de dh ou dv) ou diminution (valeurs positives); d'un rectangle relativement  son centre; les cots gauche et droite bougent chacun de dhLeft, resp. dhRight.; le haut et le bas bougent chacun de dvTop, resp. dvBottom.; l'effet est que les dimensions du rectangle diminuent de dvTop+dvBottom, et; de dhLeft+dhRight; le rectangle peut devenir vide ( [(0,0),(0,0)] ).; Un rectangle vide est agrandit uniquement autour de l'origine; in	A3	^descripteur de rectangle;	D3.32	dvTop;dvBottom;	D4.32	dhLeft;dhRight; out	D7.16	erreur (JAMAIS); mod	D7.16INSETRECT:	PUSH.32 A3	SWAP.32	D3	SWAP.32	D4	ADD.16	D3,{A3+}	; top+dvTop	ADD.16	D4,{A3+}	; left+dhLeft	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,{A3+}	; bottom-dvBottom	SUB.16	D4,{A3+}	; right-dhRight	POP.32	A3	PUSH.16	D0	MOVE.16	{A3}+OGRECTTL+OGPTY,D0	COMP.16	{A3}+OGRECTBR+OGPTY,D0	; top >= bottom ?	JUMP,GE	EMPTY$			; oui => vide !	MOVE.16	{A3}+OGRECTTL+OGPTX,D0	COMP.16	{A3}+OGRECTBR+OGPTX,D0	; et left < right ?	JUMP,LT	NOTEMPTY$		;    oui => pas videEMPTY$:	CLR.32	{A3}	CLR.32	{A3}+4			; vide le rectangleNOTEMPTY$:	POP.16	D0	CLR.16	D7			; jamais d'erreur !	RET;------------------\\;  _GMI_SectRect    >;==================/; Calcule l'intersection de 2 rectangles et rend si les deux; rectangles intersectent ou pas. Fonctionne aussi si le rectangle; de destination est le meme que l'une des deux sources.; Si intersection ensemble vide, rend le rectangle [(0,0)(0,0)].;; FUNCTION SectRect (src1,src2: Rect; VAR dstRect: Rect) : BOOLEAN;;; in	SP^;	+12.16	place pour BOOLEAN;			(valeur boolenne dans bit zro) ( rendre);	+8.32	^src1Rect;	+4.32	^src2Rect;	+0.32	^dstRect; out	SP^;	+1.8	RESULT:	BOOLEAN  (TRUE=1 si intersection, FALSE=0 si ensemble vide); mod	F;-------------\\;  SectRect    >;=============/_GMI_SectRect:SECTRECT:	LINK.32		A6,#0	PUSH.32		{A6}+8+8	; ^src1	PUSH.32		{A6}+8+4	; ^src2	PUSH.16		#2	PUSH.32		{A6}+8+0	; ^dst	CALL		R8^RSECT	SET.8,NE	{A6}+8+10'12	; boolean	NEG.8		{A6}+8+10'12	UNLINK.32	A6	MOVE.32		{SP},{SP}+10'12	ADD.A16		#10'12,SP	RET;------------------------------------------------; PROCEDURE RSECT (src1,src2,...,srcN : Rect, N: INTEGER, VAR dstRect: Rect);; Calcule l'intersection de N rectangles !; Retour: EQ: pas d'intersection, NE: intersection existeRSECT:	LINK.32		A6,#+16'0000	PUSHM.32	D0|D1|D2|D3|D4|A0|A1	MOVE.32		#{A6}+8+4,A1		; A1 ^N	MOVE.16		{A1+},D0		; Teste si N =< 0 ?	JUMP,LE		NOINTERSECT$		; oui => pas la peine !	MOVE.32		{A1+},A0		; A0 ^rectangle srcN	MOVEM.A16	{A0+},D1|D2|D3|D4	; D1...D4 coordonnes	DEC.16		D0			; corrige compteur pour DJ.16,NMO D0	JUMP		RECOMMENCE$LOOP$:	MOVE.32		{A1+},A0		; A0 ^srcI (1=<I=<N)	COMP.16		{A0+},D1		; srcI.top >= min.top ?	JUMP,GE		NOTOP$	MOVE.16		{A0}-16'0002,D1NOTOP$:	COMP.16		{A0+},D2		; srcI.left >= min.left ?	JUMP,GE		NOLEFT$	MOVE.16		{A0}-16'0002,D2NOLEFT$:	COMP.16		{A0+},D3		; srcI.bottom =< min.bottom ?	JUMP,LE		NOBOTTOM$	MOVE.16		{A0}-16'0002,D3NOBOTTOM$:	COMP.16		{A0+},D4		; srcI.right =< min.right ?	JUMP,LE		RECOMMENCE$	MOVE.16		{A0}-16'0002,D4RECOMMENCE$:	COMP.16		D1,D3			; min.top >= min.bottom ?	JUMP,LE		NOINTERSECT$	COMP.16		D2,D4			; min.left >= min.right ?	JUMP,LE		NOINTERSECT$	DJ.16,NMO	D0,LOOP$		; recommence N-I fois...	JUMP		TROUVE$			; toujours quelque chose: youppiiiNOINTERSECT$:	CLR.16		D1			; rectangle [(0,0)(0,0)]	CLR.16		D2	CLR.16		D3	CLR.16		D4TROUVE$:	MOVE.32		{A6}+16'0008,A0		; A0 ^dstRect	MOVE.16		D1,{A0+}	MOVE.16		D2,{A0+}	MOVE.16		D3,{A0+}	MOVE.16		D4,{A0+}	MOVE.16		{A6}+16'000C,D0		; N --> D0 (pour recup. stack !)	SL.16		#2,D0			; *4 (car ^=32 bits)	ADD.16		#10'6,D0	MOVE.32		{A6}+16'0004,{A6}+A16^{D0}+16'0004	MOVE.16		D0,{A6}+16'0004		; pour add	COMP.16		D1,D3			; gnre EQ si pas d'intersection.	POPM.32		D0|D1|D2|D3|D4|A0|A1	UNLINK.32	A6	ADD.A16		{SP},SP	RET;-------------------\\;  _GMI_UnionRect    >;===================/; PROCEDURE UnionRect (src1,src2: Rect; VAR dstRect: Rect);;; Calcule le plus petit rectangle englobant les 2 rectangles donns.; Fonctionne aussi si le rectangle de destination est le meme que; l'une des deux sources.;; in	SP^;	+8.32	^src1Rect;	+4.32	^src2Rect;	+0.32	^dstRect; out	-; mod	F_GMI_UnionRect:	PUSHM.32 D0|D1|A0|A1	MOVE.32	{A7}+5*4+8,A0		; ^src1	MOVE.32	{A7}+5*4+4,A1		; ^src2	MOVE.16	{A0+},D0	COMP.16	{A1+},D0		; src1.top =< sr2.top ?	JUMP,LE	SRC1TOP$		; oui => prend src1.top	MOVE.16	{A1}-2,D0		; non => prend src2.topSRC1TOP$:	SWAP.32	D0			; sauve top	MOVE.16	{A0+},D0	COMP.16	{A1+},D0		; src1.left =< src2.left ?	JUMP,LE	SRC1LEFT$		; oui => prend src1.left	MOVE.16	{A1}-2,D0		; non => prend src2.leftSRC1LEFT$:	MOVE.16	{A0+},D1	COMP.16	{A1+},D1		; src1.bottom >= src2.bottom ?	JUMP,GE	SRC1BOT$		; oui => prend src1.bottom	MOVE.16	{A1}-2,D1		; non => prend src2.bottomSRC1BOT$:	SWAP.32	D1			; sauve bottom	MOVE.16	{A0+},D1	COMP.16	{A1+},D1		; src1.right >= src2.right	JUMP,GE	SRC1RIGHT$		; oui => prend src1.right	MOVE.16	{A1}-16'0002,D1		; non => prend src2.rightSRC1RIGHT$:	MOVE.32	{A7}+5*4+0,A0		; ^dstRect	MOVE.32	D0,{A0+}		; minTop;minLeft	MOVE.32	D1,{A0+}		; maxBottom;maxRight	POPM.32	D0|D1|A0|A1	MOVE.32	{A7},{A7}+10'12	ADD.A16	#10'12,A7	RET;----------------------\\;  _GMI_PointsToRect    >;======================/; PROCEDURE PointsToRect (pt1, pt2: Point; VAR dstRect: Rect);;; Calcule le plus petit rectangle englobant les 2 rectangles donns.; Fonctionne aussi si le rectangle de destination est le meme que; l'une des deux sources.;; in	SP^;	+8.32	pt1;	+4.32	pt2;	+0.32	^dstRect; out	-; mod	F_GMI_PointsToRect:	PUSHM.32 D0|D1|A0	MOVE.32	{A7}+4*4+0,A0		; ^dstRect	MOVE.16	{A7}+4*4+8+2,D0		; p1.x	MOVE.16	{A7}+4*4+4+2,D1		; p2.x	COMP.16	D0,D1			; p2.x >= p1.x ?	JUMP,GE	P2GEP1X$		; oui => c'est bon	EX.32	D1,D0			; non => changeP2GEP1X$:	MOVE.16	D0,{A0}+2		; minX --> dstRect.Left	MOVE.16	D1,{A0}+6		; maxX --> dstRect.Right	MOVE.16	{A7}+4*4+8+0,D0		; p1.y	MOVE.16	{A7}+4*4+4+0,D1		; p2.y	COMP.16	D0,D1			; p2.y >= p1.y ?	JUMP,GE	P2GEP1Y$		; oui => c'est bon	EX.32	D1,D0			; non => changeP2GEP1Y$:	MOVE.16	D0,{A0}+0		; minY --> dstRect.Top	MOVE.16	D1,{A0}+16'0004		; minY --> dstRect.Bottom	POPM.32	D0|D1|A0	MOVE.32	{A7},{A7}+10'12	ADD.A16	#10'12,A7	RET;--------------------\\;  _GMI_MapRect       >;====================/; On donne un rectangle r dans SrcRect, et MapRect le proportionne; relativement  DstRect, selon le rapport des dimensions de DstRect; relativement  SrcRect. Il le fait en appellant MapPt pour le point; en haut  gauche, puis pour le point en bas  droite.;; PROCEDURE MapRect (VAR r: Rect; srcRect,dstRect: Rect);; in:	SP^;	+8.32	^r	(rempli en retour);	+4.32	^srcRect;	+0.32	^dstRect; out	r	mis  jour; mod	F;----------------\\;   MapRect       >;================/_GMI_MAPRECT:MAPRECT:	PUSH.32		{A7}+16'000C		; ^point en haut  gauche	PUSH.32		{A7}+16'000C		; ^rectangle source	PUSH.32		{A7}+16'000C		; ^rectangle destination	CALL		R16^MAPPT		; calcule la coordonne	ADD.32		#4,{A7}+16'C		; ^point en bas  droite	JUMP		R16^MAPPT		; calcule la coordonne	.END