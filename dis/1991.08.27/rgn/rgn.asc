	.TITLE	RGN.ASC	.PROC	M68000	.REF	SMAKY	.REF	GRAMISC; RgnHandle^:	.LOC	0OrgnSize:	.BLK.16	1	; Taille courante (paire)OrgnBBox:	.BLK.16	4	; rectangle englobant la rgionOrgnData:			; plus de donnes si ncessaire...LGrgnMin:rgnENDLIST	=	16'7FFF	; fin de liste en X ou en Y; pseudo-grafport:						; EN PLUS:		.LOC	0OsimgrpPT:	.BLK.32	1		; Init ^RgnHandle dans RgnSaveOsimgrpLG:	.BLK.16	1		; lgOsimgrpNB:	.BLK.16	1		; lg utiliseOsimgrpMODE:	.BLK.16	1		; modeLGsimgrp:;================================================; PROGRAMME DE DEMOEXSMILE	=	1	.LOC	0OSRCRGNA:	.BLK.32	1OSRCRGNB:	.BLK.32	1ODSTRGN:	.BLK.32	1OSIMGRAFPORT:	.BLK.8	LGsimgrpOMASKLIDEF:	.BLK.8	24OPTDIS:		.BLK.32	1LGVAR:.macro	dPUSHM.32 D0..A7lib	?AFTIM.ascize	"(%1) "lib	?getcarPOPM.32 D0..A7.endmacro.macro	daPUSHM.32 D0..A7lib	?AFTIM.ascize	"(%1) "MOVE.32	%2,D4LIB	?AFX8,?AFSPACElib	?getcarPOPM.32 D0..A7.endmacro.macro	dsPUSHM.32 D0..A7lib	?AFTIM.ascize	"(%1) "exitPOPM.32 D0..A7.endmacro	.LOC	0	.START	STARTSTART:	.IF	EXSMILE	.ELSE	LIB	?OPELIB	MOVE.32	#LGVAR,D4	GESMEM	?GETMEM	.ENDIF	MOVE.32	A4,A6		; ^vars	MOVE.16	#0,D3	LIB	?MOUSE	MOVE.32	#{A6}+OPTDIS,A4	MOVE.32	#4,D4	LIB	?GCHDIS	FOS	?RSTATUS	JUMP,EQ	OK$	LIB	?AFERROROK$:	CALL	_GMI_NEWRGN	MOVE.32	A4,{A6}+OSRCRGNA	CALL	_GMI_NEWRGN	MOVE.32	A4,{A6}+OSRCRGNB	CALL	_GMI_NEWRGN	MOVE.32	A4,{A6}+ODSTRGN	PUSH.32	{A6}+OSRCRGNA	PUSH.16	#60		; left	PUSH.16	#30		; top	PUSH.16	#300		; right	PUSH.16	#200		; bottom	CALL	SETRECTRGN	PUSH.32	{A6}+OSRCRGNB	PUSH.16	#250		; left	PUSH.16	#100		; top	PUSH.16	#500		; right	PUSH.16	#300		; bottom	CALL	SETRECTRGN	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion A:"	MOVE.32	{A6}+OSRCRGNA,A1	CALL	AFRGN	LIB	?GETCAR	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion B:"	MOVE.32	{A6}+OSRCRGNB,A1	CALL	AFRGN	LIB	?GETCAROPER$:	MOVE.32	{A6}+OSRCRGNA,A4	MOVE.32	{A6}+OSRCRGNB,A3	MOVE.32	{A6}+ODSTRGN,A5	MOVE.16	#GOpSECT,D3	CALL	_GMI_OperRgn	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion intersection:"	MOVE.32	{A6}+ODSTRGN,A1	CALL	AFRGN	LIB	?GETCAR	MOVE.32	{A6}+OSRCRGNA,A4	MOVE.32	{A6}+OSRCRGNB,A3	MOVE.32	{A6}+ODSTRGN,A5	MOVE.16	#GOpUNION,D3	CALL	_GMI_OperRgn	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion UNION:"	MOVE.32	{A6}+ODSTRGN,A1	CALL	AFRGN	LIB	?GETCAR	MOVE.32	{A6}+OSRCRGNA,A4	MOVE.32	{A6}+OSRCRGNB,A3	MOVE.32	{A6}+ODSTRGN,A5	MOVE.16	#GOpDIFF,D3	CALL	_GMI_OperRgn	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion diffrence A-B:"	MOVE.32	{A6}+ODSTRGN,A1	CALL	AFRGN	LIB	?GETCAR	MOVE.32	{A6}+OSRCRGNA,A4	MOVE.32	{A6}+OSRCRGNB,A3	MOVE.32	{A6}+ODSTRGN,A5	MOVE.16	#GOpXOR,D3	CALL	_GMI_OperRgn	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion OU-exclusif:"	MOVE.32	{A6}+ODSTRGN,A1	CALL	AFRGN	LIB	?GETCAR	PUSH.32	{A6}+ODSTRGN	PUSH.16	#100	PUSH.16	#50	CALL	OFFSETRGN	LIB	?AFTIM	.ASCIZE	"<EOP>Rgion OU-exclusif, OFFSETe de (100,50):"	MOVE.32	{A6}+ODSTRGN,A1	CALL	AFRGN	LIB	?GETCAR	MOVE.32	{A6}+ODSTRGN,A4	MOVE.32	#16'ffff0000,D3	MOVE.32	#16'0000ffff,D4	CALL	_GMI_INSETRGN	LIB	?AFTIM	.ASCIZE	"<EOP>La mme rgion Insete de (-10,-10):"	MOVE.32	{A6}+ODSTRGN,A1	CALL	AFRGN	LIB	?GETCAR	PUSH.32	#100*(2**16)+(100)	PUSH.32	#0	PUSH.32	#60*(2**16)+60	PUSH.32	#0	PUSH.32	{A6}+ODSTRGN	PUSH.32	#{A7}+4+8	PUSH.32	#{A7}+4+4	CALL	MAPRGN	LIB	?AFTIM	.ASCIZE	"<EOP>La mme rgion mappe de [(0,0),(100,100)}  [(0,0),(60,60)]:"	MOVE.32	{A6}+ODSTRGN,A1	CALL	AFRGN	LIB	?GETCAR	LIB	?AFTIM	.ASCIZE	"<CR>Dtection de points (I)n (O)out: X"RETEST$:	LIB	?IFMOUSE	PUSH.16	#0	PUSH.32	D4	PUSH.32	{A6}+ODSTRGN	CALL	PTINRGN	POP.16	D7	JUMP,EQ	NOTIN$	LIB	?AFTIM	.ASCIZE	"<BS>I"	JUMP	KEY$NOTIN$:		LIB	?AFTIM	.ASCIZE	"<BS>O"KEY$:	LIB	?IFCAR	JUMP,NE	RETEST$	LIB	?AFTIM	.ASCIZE	"<CR><CR>Voulez-vous encore dfinir des rgions quelconques ? "	LIB	?YESNO	JUMP,NE	FINDEMO$	LIB	?AFTIM	.ASCIZE	"<EOP>Dessinez une rgion A (GAUCHE: pose point, CENTRE: round-rect, DROITE: finit) "	MOVE.32	{A6}+OSRCRGNA,A4	CALL	DEFINEMOUS	LIB	?AFTIM	.ASCIZE	"<EOP>La rgion A, Dfinie:"	MOVE.32	{A6}+OSRCRGNA,A1	CALL	AFRGN	LIB	?AFTIM	.ASCIZE	"<CR>Dessinez une rgion B (GAUCHE: pose point, CENTRE: round-rect, DROITE: finit) "	MOVE.32	{A6}+OSRCRGNB,A4	CALL	DEFINEMOUS	LIB	?AFTIM	.ASCIZE	"<EOP>La rgion B, Dfinie: (APPUIEZ SUR SPACE)"	MOVE.32	{A6}+OSRCRGNB,A1	CALL	AFRGN	LIB	?GETCAR	JUMP	OPER$FINDEMO$:	MOVE.32	{A6}+OSRCRGNA,A4	CALL	_GMI_DISPOSERGN	MOVE.32	{A6}+OSRCRGNB,A4	CALL	_GMI_DISPOSERGN	MOVE.32	{A6}+ODSTRGN,A4	CALL	_GMI_DISPOSERGN	.IF	EXSMILE	EXIT	.ELSE	LIB	?CLOLIB	FOS	?STOP	.ENDIFAFRGN:	.IF	FALSE	MOVE.32	{A1},A0	COMP.16	#LGrgnMin,{A0}+OrgnSize	JUMP,EQ	RECTSIMPLE$	MOVE.32	#{A0}+OrgnData,A1	MOVE.32	A1,A3	MOVE.32	#-1,D3	MOVE.32	D3,D4	LIB	?DRMDEF	MOVE.16	#INVDOT,D2NEXTY$:	MOVE.16	{A1+},D3	MOVE.16	#600,D4	SUB.16	D3,D4	SWAP.32	D4	SWAP.32	D3NEXTX$:	MOVE.16	{A1+},D3	MOVE.16	{A1+},D4	SUB.16	D3,D4	LIB	?DRTRAME	COMP.16	#rgnENDLIST,{A1}	JUMP,NE	NEXTX$	ADD.A16	#2,A1	COMP.16	#rgnENDLIST,{A1}	JUMP,NE	NEXTY$	RET	.ELSE	MOVE.32	{A1},A0	COMP.16	#LGrgnMin,{A0}+OrgnSize	JUMP,EQ	RECTSIMPLE$	MOVE.32	{A6}+OPTDIS,A2	MOVE.16	{A2}+ODFDX,D1	MOVE.32	#{A6}+OMASKLIDEF,A1	MOVE.16	#0,D0	MOVE.16	#0,D2	MOVE.32	A7,A3	CALL	INITRGN	MOVE.16	{A2}+ODFY,D0	MUL.16	{A2}+ODFIIY,D0	CLR.32	D1	MOVE.16	{A2}+ODFX,D1	SR.32	#3,D1			; /8 bits/byte	ADD.32	D1,D0	ADD.32	{A2}+ODFABS,D0	MOVE.32	D0,A4	MOVE.16	{A2}+ODFDY,D2	CLR.16	D0NEXTLI$:	CALL	SEEKRGN	MOVE.32	{A1}+8,A5	MOVE.16	{A1}+16'C,D3	PUSH.32	A4LOOPLI$:	MOVE.32	{A5+},{A4+}	DJ.16,NMO D3,LOOPLI$	POP.32	A4	ADD.A16	{A2}+ODFIIY,A4	INC.16	D0	DEC.16	D2	JUMP,NE	NEXTLI$	MOVE.32	A3,A7	RET	.ENDIFRECTSIMPLE$:	MOVE.32	#-1,D3	MOVE.32	D3,D4	LIB	?DRMDEF	MOVE.32	{A0}+OrgnBBox+0,D3		; top;left	MOVE.16	{A0}+OrgnBBox+4,D4	SUB.16	{A0}+OrgnBBox+0,D4	SWAP.32	D4	MOVE.16	{A0}+OrgnBBox+6,D4	SUB.16	D3,D4	MOVE.16	#INVDOT,D2	LIB	?DRTRAME	RET; in	A4 ^rgion...DEFINEMOUS:	MOVE.32	#{A6}+OSIMGRAFPORT,A5	move.16	#GFILLXOR,D3		; #GFILLwinding,D3	CALL	OPENRGNFIRSTPT$:	LIB	?IFMOUSE	TEST.8	D3	JUMP,EQ	FIRSTPT$	TEST.32	D3:#BMOCENT	JUMP,BS	DOOVAL$	TEST.32	D3:#BMORIGHT	JUMP,BS	ENDMOU$;;;	TEST.32	D3:#BMOLEFT	PUSH.32	D4		; D3 tats boutonsONEMORE$:	MOVE.32	#0,D5	MOVE.32	D4,D6NEXTPT$:	PUSH.16	D3	LIB	?IFMOUSE	POP.16	D1	PUSHM.32 D3|D4	PUSH.32	D4	MOVE.32	D6,D3	MOVE.32	D5,D4	MOVE.16	#INVDOT,D2	LIB	?DRSEG		; enlve le prcdent	POP.32	D4	MOVE.32	D6,D3	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	MOVE.32	D4,D5	LIB	?DRSEG		; affiche le nouveau	POPM.32	D3|D4	MOVE.16	D3,D7	XOR.16	D7,D1	AND.16	D1,D7		; D7 <= boutons appuys;;	TEST.32	D7:#BMOCENT;;	JUMP,BS	FIRSTPT$	TEST.32	D7:#BMORIGHT	JUMP,BS	ENDMOU$	TEST.32	D7:#BMOLEFT	JUMP,BC	NEXTPT$	push.32	d3	move.32	d6,d3.IF 0push.32 d4LIB ?AFTIM.ascize "PUT("LIB ?AFX8, ?AFTIM.ascize " , "move.32 d6,d4lib ?AFX8, ?AFTIM.ascize ") "pop.32 d4.ENDIF	CALL	_GMI_PUTLINE	pop.32	d3	JUMP	ONEMORE$DOOVAL$:		; D3 tats boutons	MOVE.32	#0,D5	MOVE.32	D4,D6NEXTOV$:	PUSH.16	D3	LIB	?IFMOUSE	POP.16	D1	PUSHM.32 D3|D4	PUSH.32	D4	MOVE.32	D6,D3	MOVE.32	D5,D4	MOVE.16	#INVDOT,D2	LIB	?DRRECT		; enlve le prcdent	POP.32	D4	MOVE.32	D6,D3	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	MOVE.32	D4,D5	LIB	?DRRECT		; affiche le nouveau	POPM.32	D3|D4	MOVE.16	D3,D7	XOR.16	D7,D1	AND.16	D1,D7		; D7 <= boutons appuys	TEST.32	D1:#BMOCENT	JUMP,BC	NEXTOV$	TEST.32	D3:#BMORIGHT	JUMP,BS	VRAIOVALE$	PUSH.32	D4	PUSH.32	D6	PUSH.32	A7	PUSH.16	#32	PUSH.16	#16	CALL	PUTOVAL	ADD.32	#8,A7	JUMP	END$VRAIOVALE$:	PUSH.32	D4	PUSH.32	D6	PUSH.32	A7		; ^rect	PUSH.16	{A7}+4+6	; right	MOVE.16	{A7}+6+2,D0	SUB.16	D0,{A7}		; -left	PUSH.16	{A7}+6+4	; bottom	MOVE.16	{A7}+8+0,D0	SUB.16	D0,{A7}		; -top	CALL	PUTOVAL	ADD.32	#8,A7WAITREL$:	LIB	?IFMOUSE	TEST.8	D3	JUMP,NE	WAITREL$	JUMP	END$ENDMOU$:	POP.32	D4	PUSH.16	#0	PUSH.16	D6	SWAP.32	D6	PUSH.16	#0	PUSH.16	D6	SWAP.32	D6	PUSH.16	#0	PUSH.16	D4	SWAP.32	D4	PUSH.16	#0	PUSH.16	D4	SWAP.32	D4	CALL	PUTLINE		; D4 dj push: ferme la rgionEND$:;;d B	PUSH.32	A4	CALL	CLOSERGN;;D Cttp$:	LIB	?IFMOUSE	TEST.8	D3	JUMP,ne	ttp$	RET; FIN DU PROGRAMME DE DEMO; ===============================================================================	.INS	GMIRGN.ASI	.END