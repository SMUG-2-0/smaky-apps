	.TITLE	TMOUSE.ASC	.PROC	M680002	.REF	SMAKY	.LOC	0START:	LIB	?OPELIB	LOAD.W	D3,#3	LIB	?MOUSE	LIB	?AFTIM	.B	NOCURS,EOP	.B	CR,CR,CR,CR,CR,CR,CR,CR	.ASCII	"	0 = enlve la souris<CR>"	.ASCII	"	1 = remet la souris<CR>"	.B	CR	.ASCII	"	S = sablier<CR>"	.ASCII	"	F = flche<CR>"	.B	CR,CR,CR	.B	0	.EVENLOOP:	LIB	?GETCAR	COMP.W	D3,#END	JUMP,EQ FINI	COMP.W	D3,#F0	JUMP,EQ FINI	COMP.W	D3,#F0+SHIFT	JUMP,EQ FINI	COMP.W	D3,#'0	JUMP,EQ ENLEVE	COMP.W	D3,#'1	JUMP,EQ REMET	COMP.W	D3,#'S	JUMP,EQ SABLIER	COMP.W	D3,#'s	JUMP,EQ SABLIER	COMP.W	D3,#'F	JUMP,EQ FLECHE	COMP.W	D3,#'f	JUMP,EQ FLECHE	JUMP	LOOPENLEVE:	LIB	?AFTIM	.ASCIZ	"	Plus de flche ...<CR>"	.EVEN	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	JUMP	LOOPREMET:	LIB	?AFTIM	.ASCIZ	"	De nouveau une flche ...<CR>"	.EVEN	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	JUMP	LOOPSABLIER:	LIB	?AFTIM	.ASCIZ	"	Souris = sablier ...<CR>"	.EVEN	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	LOAD.W	D4,#0	LIB	?WAITMOUSE	JUMP	LOOPFLECHE:	LIB	?AFTIM	.ASCIZ	"	Souris = flche ...<CR>"	.EVEN	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	LOAD.W	D4,#1	LIB	?WAITMOUSE	JUMP	LOOPFINI:	LIB	?CLOLIB	FOS	?STOP	.END	START