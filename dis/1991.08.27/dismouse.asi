	.CHAP	DISMOUSE;--------\\; MOMOVE  >;========/; Dplace le lutin de la souris.; in	D4.L	position de la souris;	A2.32	^descripteur de $DIS_0 ou $DIS_20; out	-; mod	D7.WMOMOVE:	PUSHM.32 D0|D3|D6|A3|A4	MOVE.32	D4,{A2}+ODFMPO	CLR.16	D6		; D6 <-- numro du lutin	CALL	MOGETLU		; D3/A4/A3 <-- lutin de la souris	COMP.32	{A2}+ODFMDI,D3	; mme dimensions ?	JUMP,NE	 R8^L30$	COMP.32	{A2}+ODFMPS,A4	; mme ^matrice "set" ?	JUMP,NE	 R8^L30$	COMP.32	{A2}+ODFMPC,A3	; mme ^matrice "clear" ?	JUMP,NE	 R8^L30$				; dplace le lutin =>	TEST.32	D3	JUMP,EQ L90$	MOVE.16	#SPRITE_MOVE,D0	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_SPRITE-GRA2_FIRST)),A0	CALL	{A0}		; dplace la souris	POP.32	A0	TCLR.8	{A2}+ODFMFL:#BFMCLR	JUMP	L90$L30$:				; change le lutin =>	PUSH.32	A2	TEST.32	{A2}+ODFMDI	JUMP,EQ	 R8^L40$	PUSHM.32 D3|A3|A4	MOVE.32	{A2}+ODFMDI,D3	MOVE.32	{A2}+ODFMPS,A4	MOVE.32	{A2}+ODFMPC,A3	MOVE.16	#SPRITE_CLOSE,D0	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_SPRITE-GRA2_FIRST)),A0	CALL	{A0}		; ferme la souris	POP.32	A0	TSET.8	{A2}+ODFMFL:#BFMCLR	POPM.32	D3|A3|A4L40$:	POP.32	A2	MOVE.32	D3,{A2}+ODFMDI	MOVE.32	A4,{A2}+ODFMPS	MOVE.32	A3,{A2}+ODFMPC	TEST.32	D3	JUMP,EQ	 R8^L90$	MOVE.16	#SPRITE_OPEN,D0	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_SPRITE-GRA2_FIRST)),A0	CALL	{A0}		; ouvre la souris	POP.32	A0	TCLR.8	{A2}+ODFMFL:#BFMCLRL90$:	POPM.32	D0|D3|D6|A3|A4	RET;--------\\; MOGETLU >;========/; Cherche le lutin  utiliser pour la souris en fonction de sa position.; in	D4.L	position de la souris;	A2.32	^descripteur de $DIS_0; out	D3.L	dimensions du lutin;	A4.32	^matrice "set";	A3.32	^matrice "clear"; mod	D3.L, D7.W, A3.L, A4.LMOGETLU:	PUSHM.32 D0|D1|A1	CLR.16	{A2}+ODFCAM	CLR.8	{A2}+ODFNOM	CALL	MOIFUSE		; fentre avec souris ?	TEST.8	{A2}+ODFNOM	JUMP,NE	 R8^FOUND$	TEST.8	{A2}+ODFNOM	; dj trouv o est souris ?	JUMP,NE	 R8^FOUND$	; oui => FOUND$	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	MOVE.32	#R16^D1BASE,A1	CALL	MOIFFREE	; dans $DIS_1 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D10BASE,A1	CALL	MOIFFREE	; dans $DIS_10 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D11BASE,A1	CALL	MOIFFREE	; dans $DIS_11 ?	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM324BIG	MOVE.32	#R16^D1BASE,A1	CALL	MOIFFREE	; dans $DIS_1 ?	.ENDIF	SM324BIG	.IF	SM8	MOVE.32	#R16^D1BASE,A1	CALL	MOIFFREE	; dans $DIS_1 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D2BASE,A1	CALL	MOIFFREE	; dans $DIS_2 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D3BASE,A1	CALL	MOIFFREE	; dans $DIS_3 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D4BASE,A1	CALL	MOIFFREE	; dans $DIS_4 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D11BASE,A1	CALL	MOIFFREE	; dans $DIS_11 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D12BASE,A1	CALL	MOIFFREE	; dans $DIS_12 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D13BASE,A1	CALL	MOIFFREE	; dans $DIS_13 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D14BASE,A1	CALL	MOIFFREE	; dans $DIS_14 ?	.ENDIF	SM8FOUND$:	TEST.16	{A2}+ODFCAM	; dj trouv le cadrage ?	JUMP,NE	 R8^LUTIN$	; oui => LUTIN$				; non =>	MOVE.8	#"U",{A2}+ODFCAM+0; mm. cadrage vertical U/D	MOVE.8	#"L",D1		; D1 <-- tout  gauche	COMP.16	#1024-(LVIEWX*LARGCX),D4	JUMP,LO	 R8^LEFT$	CLR.8	D1		; D1 <-- dans partie centrale	COMP.16	#LVIEWX*LARGCX,D4	JUMP,LO	 R8^LEFT$	MOVE.8	#"R",D1		; D1 <-- tout  droiteLEFT$:	MOVE.8	D1,{A2}+ODFCAM+1; mm. cadrage horizontal L/RLUTIN$:	CLR.16	D0	MOVE.8	{A2}+ODFNOM,D0	; D0 <-- no fentre o est la souris	JUMP,EQ	 R8^FLECHE$	COMP.8	#7,D0		; fentre des "soft keys" ?	JUMP,EQ	 R8^FLECHE$	; oui => FLECHE$	SL.16	#2,D0		; D0 <-- *4 car .L	MOVE.32	{A2}+ODFPDE,A1	; A1 <-- ^descripteurs (32* .L)	MOVE.32	{A1}+A16^{D0},D0; fentre inoccupe ?	JUMP,EQ	 R8^FLECHE$	; oui => FLECHE$	MOVE.32	D0,A1		; A1 <-- ^descripteur $DIS_n o est la souris	TEST.8	{A1}+ODFFLG:#BFNCMO ; mode "AFCCMO" ?	JUMP,BS	 R8^NIL$	TEST.8	{A1}+ODFFLG:#BFWMOU ; souris "en attente" ?	JUMP,BS	 R8^SABLIER$	TEST.32	{A1}+ODFPMS	; lutin spcial ?	JUMP,EQ	 R8^FLECHE$	; non => FLECHE$				; oui =>	MOVE.32	{A1}+ODFPMS,A4	MOVE.32	{A1}+ODFPMC,A3	JUMP	R8^TAKE$FLECHE$:	MOVE.32	#R16^MSFLECHE,A4	MOVE.32	#0,A3	JUMP	R8^TAKE$SABLIER$:	MOVE.32	#R16^MWFLECHE,A4	MOVE.32	#R16^MVFLECHE,A3	JUMP	R8^TAKE$NIL$:	MOVE.32	#0,A4	MOVE.32	A4,A3;	JUMP	R8^TAKE$; Cherche les dimensions du lutin de la souris.TAKE$:	CLR.32	D3		; D3 <-- init pour dy;dx	MOVE.32	A4,D0	JUMP,EQ	 R8^EXIT$	MOVE.8	{A4}+1,D3	; D3 <-- dy	SWAP.32	D3	MOVE.8	{A4}+0,D3	; D3 <-- dy;dx	ADD.32	#2,A4		; A4 <-- saute dx;dy (2x .B)	MOVE.32	A3,D0	JUMP,EQ	 R8^EXIT$	ADD.32	#2,A3		; A3 <-- saute dx;dy (2x .B)EXIT$:	POPM.32	D0|D1|A1	TEST.16	D7		; retour EQ/NE	RET;--------\; MOIFUSE >;--------/; Cherche si la souris est dans une fentre utilise.; in	D4.L		position de la souris;	A2.32		^descripteur fentre $DIS_0 ou $DIS_20; out	(A2)+ODFNOM.B	no fentre o est la souris;	{A2}+ODFCAM.W	cadrage; mod	D7.WMOIFUSE:	PUSHM.32 D0|A1..A3	MOVE.32	A2,A1		; A1 <-- ^description de $DIS_0 ou $DIS_20	MOVE.32	#{A6}+OBITMAP,A3	MOVE.16	{A6}+ONOVBM,D0	; D0 <-- no du bitmap visible (0..3)	MUL.16	#LBM,D0	ADD.32	D0,A3		; A3 <-- ^table du bitmap visible	CLR.16	D0	.IF	SM8	MOVE.8	{A3}+OBMWDO+0,D0	CALL	MOIFONE		; curseur dans $DIS_1,11 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+1,D0	CALL	MOIFONE		; curseur dans $DIS_2,12 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+2,D0	CALL	MOIFONE		; curseur dans $DIS_3,13 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+3,D0	CALL	MOIFONE		; curseur dans $DIS_4,14 ?	JUMP,EQ	 R8^L50$	; oui => 50$	.ENDIF	SM8	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	MOVE.8	{A3}+OBMWDO+0,D0	CALL	MOIFONE		; curseur dans $DIS_1,2,3,4 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+1,D0	CALL	MOIFONE		; curseur dans $DIS_10,12,14,16 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+2,D0	CALL	MOIFONE		; curseur dans $DIS_11,13,15,17 ?	JUMP,EQ	 R8^L50$	; oui => 50$	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM324BIG	MOVE.8	{A3}+OBMWDO+0,D0	CALL	MOIFONE		; curseur dans $DIS_1,2,3,4 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+1,D0	CALL	MOIFONE		; curseur dans $DIS_10 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+2,D0	CALL	MOIFONE		; curseur dans $DIS_11 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+3,D0	CALL	MOIFONE		; curseur dans $DIS_12 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+4,D0	CALL	MOIFONE		; curseur dans $DIS_13 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+5,D0	CALL	MOIFONE		; curseur dans $DIS_14 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+6,D0	CALL	MOIFONE		; curseur dans $DIS_15 ?	JUMP,EQ	 R8^L50$	; oui => 50$	.ENDIF	SM324BIG	MOVE.16	#7,D0	CALL	MOIFONE		; curseur dans $DIS_7 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.16	#8,D0	CALL	MOIFONE		; curseur dans $DIS_8 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.16	#9,D0	CALL	MOIFONE		; curseur dans $DIS_9 ?	JUMP,NE	 R8^L90$	; non => 90$L50$:	MOVE.16	{A2}+ODFCAD,{A1}+ODFCAM	; mm. cadrage o est souris	MOVE.8	{A2}+ODFNOW,{A1}+ODFNOM	; mm. no wdo o est sourisL90$:	POPM.32	D0|A1..A3	RET;--------\; MOIFONE >;--------/; Teste si les coordonne du curseur donnes dans D4.L; sont dans la fentre dont le pointeur est dans A2.L; in	D4.L	position de la souris;	D0.16	numro de la fentre (0..n); out	EQ	souris dans cette fentre;	 A2.32	 ^descripteur fentre;	NE	souris ailleurs; mod	A2.LMOIFONE:	PUSHM.32 D3|D4	TEST.8	D0	JUMP,NS	 R8^L50$	CALL	GETDESC		; A2 <-- ^descripteur $DIS_n	JUMP,EQ	 R8^L50$	; si fentre n'existe pas => 50$	MOVE.16	{A2}+ODFIX,D3	; D3 <-- X minimum;;?	ADD.W	D4,(A2)+ODFMDI+2 ; tient compte grandeur curseur	COMP.16	D3,D4	JUMP,LO	 R8^L50$	ADD.16	{A2}+ODFIDX,D3	; D3 <-- X maximum;;?	SUB.W	D4,(A2)+ODFMDI+2 ; tient compte grandeur curseur	COMP.16	D3,D4	JUMP,HS	 R8^L50$	SWAP.32	D4		; D4 <-- y	MOVE.16	{A2}+ODFIY,D3	; D3 <-- Y minimum;;?	ADD.W	D4,(A2)+ODFMDI+0 ; tient compte grandeur curseur	COMP.16	D3,D4	JUMP,LO	 R8^L50$	ADD.16	{A2}+ODFIDY,D3	; D3 <-- Y maximum;;?	SUB.W	D4,(A2)+ODFMDI+0 ; tient compte grandeur curseur	COMP.16	D3,D4	JUMP,HS	 R8^L50$	SETZ			; retour EQ	JUMP	R8^L90$L50$:	CLRZ			; retour NEL90$:	POPM.32	D3|D4	RET;---------\; MOIFFREE >;---------/; Cherche si la souris est dans une fentre inutilise.; in	D4.L		position de la souris;	A2.32		^descripteur fentre $DIS_0 ou $DIS_20;	A1.32		^description "condense" aprs base du driver; out	(A2)+ODFNOM.B	no fentre o est la souris;	{A2}+ODFCAM.W	cadrage;	D7.16		ok/pas trouv; mod	D7.WMOIFFREE:	PUSHM.32 D1|D4	MOVE.16	#1,D7		; D7 <-- pas trouv	MOVE.16	{A1}+2,D1	; D1 <-- x min	COMP.16	D1,D4	JUMP,LO	 R8^L90$	ADD.16	{A1}+6,D1	; D1 <-- x max	COMP.16	D1,D4	JUMP,HS	 R8^L90$	SWAP.32	D4	MOVE.16	{A1}+0,D1	; D1 <-- y min	COMP.16	D1,D4	JUMP,LO	 R8^L90$	ADD.16	{A1}+4,D1	; D1 <-- y max	COMP.16	D1,D4	JUMP,HS	 R8^L90$	MOVE.16	{A1}+8,{A2}+ODFCAM  ; mm. cadrage	MOVE.8	{A1}+10,{A2}+ODFNOM ; mm. numro fentre	CLR.16	D7		; D7 <-- trouvL90$:	POPM.32	D1|D4	TEST.16	D7		; retour EQ/NE	RET	.IF	SM100.OR.SM324LIT.OR.SM196.OR.SM300MSFLECHE:	.8	12,17	.8	2'00000000,2'00000000	.8	2'01000000,2'00000000	.8	2'01100000,2'00000000	.8	2'01110000,2'00000000	.8	2'01111000,2'00000000	.8	2'01111100,2'00000000	.8	2'01111110,2'00000000	.8	2'01111111,2'00000000	.8	2'01111111,2'10000000	.8	2'01111111,2'11000000	.8	2'01111110,2'00000000	.8	2'01101110,2'00000000	.8	2'01000111,2'00000000	.8	2'00000111,2'00000000	.8	2'00000011,2'10000000	.8	2'00000011,2'10000000	.8	2'00000000,2'00000000	.ENDIF	SM100.OR.SM324LIT.OR.SM196.OR.SM300	.IF	SM8.OR.SM324BIGMSFLECHE:	.8	14,20	.8	2'00000000,2'00000000	.8	2'01000000,2'00000000	.8	2'01100000,2'00000000	.8	2'01110000,2'00000000	.8	2'01111000,2'00000000	.8	2'01111100,2'00000000	.8	2'01111110,2'00000000	.8	2'01111111,2'00000000	.8	2'01111111,2'10000000	.8	2'01111111,2'11000000	.8	2'01111111,2'11100000	.8	2'01111111,2'11110000	.8	2'01111111,2'11111000	.8	2'01111111,2'10000000	.8	2'01110111,2'10000000	.8	2'01100011,2'11000000	.8	2'01000011,2'11000000	.8	2'00000001,2'11100000	.8	2'00000001,2'11000000	.8	2'00000000,2'00000000	.ENDIF	SM8.OR.SM324BIG	.IF	SM324BIG	.INS	SABLIER324.ASI	.ELSE	.INS	SABLIER.ASI	.ENDIF	SM324BIG	.EVEN	.END