	.SBTTL	ICOLCRET.ASI;--------------\\; _ICOL_MODCRET >;==============/; Modifie une ou plusieurs couleurs d'une CRET.; Format de la table (*) :;;	.L	numro		; numro de la couleur relative (>H'8000);	.W	R,G,B		; RGB par dfaut;	.ASCIZE	"nom"		; nom (lg max=40 caractres);;	...;;	.L	0		; terminateur; in	A0.L	^descripteur fentre;	D4.L	mode (BIC*);		 BICMPAL --> palette;		 BICMRGB --> ascenseurs RGB;		 BICMHSV --> ascenseurs HSV;		 BICKHELP--> affiche raccourci clavier;		 BTCGLOB --> si CRET globale;	D5.L	identificateur CRET;	A3.L	^nom du logiciel (DESSIN4, PAGE, etc.);	A5.L	^table des textes pour la CRET (*);	A2.L	^texte raccourci clavier (si D3:#BICKHELP); out	D4.L	mode (BIC*);	D5.L	identificateur CRET;	D7.W	erreur; mod	D4.L, D5.L, D7.W_ICOL_MODCRET:	PUSHM.L	D1..D3,A1..A4,A6	CALL	VAROPEN		; A6 <-- ^variables	JUMP,NE ERFAT$	LOAD.L	A1,A2		; A1 <-- ^texte raccourci clavier	LOAD.L	(A6)+OFAN,D4	; OFAN <-- mode	LOAD.L	(A6)+OIDCRET,D5	; OIDCRET <-- identificateur CRET	LOAD.L	(A6)+OPTTEXT,A5	; OPTTEXT <-- ^table des textes	LOAD.L	(A6)+OPTNAME,A3	; OPTNAME <-- ^nom do logiciel	LOAD.L	A2,#R16"TDBOX_MODCRET	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFAN	; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	CALL	DBOXKHELP	; affiche le raccourci clavier	CALL	CRINIT		; initialise la CRET	CALL	CRSLDRAW	; dessine la scroll-listeLOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_MODCRET	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	; bouton souris press ?	JUMP',EQ CLIC$		; oui => CLIC$	COMP.W	D3,#F1	JUMP,EQ TERMINE$	COMP.W	D3,#F4	JUMP,EQ COPIE$	COMP.W	D3,#H'100*(2^BCOPY)+SPACE	JUMP,EQ COPIE$	COMP.W	D3,#F6	JUMP,EQ COLLE$	COMP.W	D3,#H'100*(2^BCURSOR)+SPACE	JUMP,EQ COLLE$	COMP.W	D3,#H'100*(2^BSHOW)+SPACE	JUMP,EQ CLASSEUR$	COMP.W	D3,#F7	JUMP',EQ MODIF$	COMP.W	D3,#F10	JUMP',EQ SAUVE$	COMP.W	D3,#F13	JUMP,EQ PALETTE$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ERROR$:	CALL	DBOXERROR	; affiche une erreur ...	JUMP	LOOP$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	CALL	CRSLMOVE	; dplace la scroll-liste ...	JUMP,NE BIP$	JUMP	LOOP$MODIF$:	CALL	CRSLGET		; A4 <-- ^RGB actuel	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	CALL	CRSEARCH	; A3 <-- ^dans la table	LOAD.L	A3,#(A3)+LCTDATA ; A3 <-- ^nom de la couleur	LOAD.L	D4,(A6)+OFAN	; D4 <-- mode	TSET.L	D4:#BICMTEXT	TCLR.L	D4:#BICKHELP	CALL	_ICOL_MODRGB	; modifie une couleur ...	CALL	DBOXRSK		; refait les soft-keys	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.L	(A6)+OFAN,D4	; OFAN <-- mode	CALL	CRSLPUT	CALL	CRSLCOLOR	; affiche les couleurs  droite	JUMP	LOOP$SAUVE$:	LOAD.L	A3,(A6)+OPTNAME	; A3 <-- ^nom do logiciel	CALL	IONAMECRET	; A3 <-- ^nom du fichier .CRET	ADD.L	A3,#6		; A3 <-- saute (:,#:)	CALL	DBOXSVCRET	; demande comment sauver ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	IOSAVECRET	; sauve la CRET	JUMP,NE ERROR$	JUMP	LOOP$PALETTE$:	LOAD.L	D4,(A6)+OFAN	; D4 <-- mode	TCLR.L	D4:#BICMPAL	JUMP',BC PAL2$	TSET.L	D4:#BICMHSVPAL2$:	TCLR.L	D4:#BICKHELP	CALL	_ICOL_MODCLUT	; modifie la CLUT ...	CALL	DBOXRSK		; refait les soft-keys	TEST.W	D7	JUMP,NE BIP$	CALL	CRSLCOLOR	; affiche les couleurs  droite	JUMP	LOOP$COPIE$:	CALL	CRSLGET		; A4 <-- ^RGB actuel	LOAD.W	(A6)+OCOLR,(A4+)	LOAD.W	(A6)+OCOLG,(A4+)	LOAD.W	(A6)+OCOLB,(A4+)	CALL	COPIE		; bloc-notes <-- couleur	JUMP,NE BIP$	JUMP	LOOP$COLLE$:	CALL	COLLE		; OCOLR <-- rouge/vert/bleu	JUMP,NE BIP$	LOAD.L	A4,#(A6)+OCOLR	CALL	CRSLPUT	CALL	CRSLCOLOR	; affiche les couleurs  droite	JUMP	LOOP$CLASSEUR$:	LOAD.W	D2,#2^BDBSAV	BLOC_	VISU		; accs au classeur ...	PUSH.W	D7	CALL	DBOXRSK		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP'	COLLE$TERMINE$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	LOAD.L	D4,(A6)+OFAN	; D4 <-- mode	LOAD.L	D5,(A6)+OIDCRET	; D5 <-- identificateur CRET	CALL	VARCLOSE	; libre les variablesERFAT$:	POPM.L	D1..D3,A1..A4,A6	TEST.W	D7		; retour EQ/NE	RETTDBOX_MODCRET:	.W	10$-TDBOX_MODCRET	.W	20$-TDBOX_MODCRET	.W	0,010$:	.B	ODBTABX,53	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBTABX,53-38	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	"  COPIE  "	.B	ODBBOX,0,F6,TDBNORM	.ASCIZ	"  COLLE  "	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" TERMINE "	.B	ODBTABX,53-38	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" MODIFIE "	.B	ODBBOX,0,F10,TDBNORM	.ASCIZ	"  SAUVE  "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F13,TDBNORM	.ASCIZ	" PALETTE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Termine"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Copie       Colle"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Palette"	.EVENTKEY_MODCRET:	.W	F1,F2,F3,CR,END,0	DOKF1-TKEY_MODCRET	.W	F7,F8,F9,DEFINE,0	DOKF7-TKEY_MODCRET	.W	F10,F11,F12,DEFINE,0	DOKF10-TKEY_MODCRET	.W	F13,F14,F15,DEFINE,0	DOKF13-TKEY_MODCRET	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MODCRET	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_MODCRET	.W	0;--------\\; CRINIT  >;========/; Initialise la CRET en fonction de la table.; Ajoute les couleurs qui n'y sont pas.; in	-; out	-; mod	D7.WCRINIT:	PUSHM.L	D2..D6,A3,A4	LOAD.L	D5,(A6)+OIDCRET	; D5 <-- identificateur CRET	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	LOAD.L	A3,(A6)+OPTTEXT	; A3 <-- ^table des textes	CLR.W	D2LOOP$:	TEST.L	(A3)		; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.L	D4,(A3)+OCTNAM	; D4 <-- couleur relative	LOAD.L	A4,#(A6)+OCOLR	; A4 <-- ^buffer	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode	TCOL_	SRCCRET		; cherche une couleur dans la CRET	JUMP',EQ NEXT$	LOAD.L	D4,(A3)+OCTNAM	; D4 <-- couleur relative	LOAD.L	A4,#(A3)+OCTCOL	; A4 <-- ^RGB par dfaut	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode	TCOL_	PUTCRET		; ajoute une couleur dans la CRETNEXT$:	LOAD.L	A3,#(A3)+LCTDATASKIP$:	TEST.B	(A3+)		; A3 <-- saute .ASCIZE	JUMP,NE SKIP$	EX.L	D3,A3	INC.L	D3	TCLR.L	D3:#0	EX.L	A3,D3	INC.W	D2		; D2 <-- une couleur de plus	JUMP	LOOP$EXIT$:	LOAD.W	(A6)+OSLVAR+OSLCYN,D2	LOAD.L	(A6)+OIDCRET,D5	; OIDCRET <-- identificateur CRET	POPM.L	D2..D6,A3,A4	RET;---------\\; CRSLDRAW >;=========/; Affiche la scroll-liste.; in	-; out	-; mod	D7.WCRSLDRAW:	PUSHM.L	D2..D4,A3,A5	LOAD.L	A5,#(A6)+OSLVAR	LOAD.L	(A5)+OSLPOS,#H'10000*20+20	LOAD.L	(A5)+OSLDIM,#H'10000*200+(8*48)	SCROLL_	LDRAW	LOAD.L	A5,#(A6)+OSLVAR	LOAD.L	A3,#R16"CRSLDISPLAY	LOAD.L	(A5)+OSLADL,A3	SCROLL_	LUPDATE	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	ADD.W	D3,D4	LOAD.W	D4,(A0)+ODFCX	ADD.W	D4,(A0)+ODFCX	ADD.W	D4,(A0)+ODFCX	LOAD.W	D2,#SETDOT	LIB	?DRRECT	CALL	CRSLCOLOR	; affiche les couleurs  droite	POPM.L	D2..D4,A3,A5	RET;------------\\; CRSLDISPLAY >;------------/; Affiche une ligne dans la scroll-liste.; in	D3.W	rang de la case (0..OSLCYN-1); out	D3.W	1 si ligne pointille;	D7.W	erreur; mod	D3.L, D7.WCRSLDISPLAY:	CALL	CRSEARCH	; A3 <-- ^dans la table	JUMP',NE EXIT$	LOAD.L	A3,#(A3)+LCTDATA ; A3 <-- ^texte	CLR.W	D3	LOAD.B	D3,(A3+)	; D3 <-- type de ligne pointille	COMP.B	D3,#3	JUMP',LS EXIT$	DEC.L	A3	CLR.W	D3EXIT$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; CRSLMOVE >;=========/; Dplace la scroll-liste.; in	D4.L	position de la souris; out	D7.W	erreur; mod	D7.WCRSLMOVE:	PUSH.L	A5	LOAD.L	A5,#(A6)+OSLVAR	SCROLL_	LMOVE	JUMP',NE EXIT$	CALL	CRSLCOLOR	; affiche les couleurs  droiteEXIT$:	POP.L	A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; CRSLCOLOR >;==========/; Affiche toutes les couleurs  droite de la scroll-liste.; in	-; out	-; mod	D7.WCRSLCOLOR:	PUSHM.L	D0..D6,A2..A5	LIB	?COLORPUSH	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	LOAD.L	A5,#(A6)+OSLVAR	LOAD.W	D3,(A5)+OSLCYA	CALL	CRSEARCH	; A3 <-- ^dans la table	LOAD.L	A2,A3	LOAD.W	D0,(A5)+OSLPOS+0	ADD.W	D0,#2	SWAP.W	D0	LOAD.W	D0,(A5)+OSLPOS+2	ADD.W	D0,(A5)+OSLDIM+2	ADD.W	D0,#2	LOAD.W	D1,(A5)+OSLCYN	SUB.W	D1,(A5)+OSLCYA	COMP.W	D1,(A5)+OSLNBY	JUMP',LS LOOP$	LOAD.W	D1,(A5)+OSLNBYLOOP$:	TEST.W	D1	JUMP',EQ EXIT$	LOAD.L	D4,(A2)+OCTNAM	; D4 <-- couleur relative	LOAD.L	A4,#(A6)+OCOLR	; A4 <-- ^buffer	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^buffer	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode	TSET.L	D3:#BTCGIVE	TCOL_	SRCCRET		; cherche une couleur dans la CRET	LOAD.L	(A0)+ODFCSF,D4	LOAD.L	D3,D0	LOAD.W	D4,(A5)+OSLCAR+0	SUB.W	D4,#2	SWAP.W	D4	LOAD.W	D4,(A5)+OSLCAR+2	ADD.W	D4,(A5)+OSLCAR+2	ADD.W	D4,(A5)+OSLCAR+2	SUB.W	D4,#3	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	LOAD.L	A2,#(A2)+LCTDATASKIP$:	TEST.B	(A2+)		; A2 <-- saute .ASCIZE	JUMP,NE SKIP$	EX.L	D3,A2	INC.L	D3	TCLR.L	D3:#0	EX.L	A2,D3	SWAP.W	D0	ADD.W	D0,(A5)+OSLCAR+0	SWAP.W	D0	DEC.W	D1	JUMP	LOOP$EXIT$:	LIB	?COLORPOP	POPM.L	D0..D6,A2..A5	RET;--------\\; CRSLGET >;========/; Donne les couleurs choisies dans la scroll-liste.; in	-; out	A4.L	^RGB; mod	D7.W, A4.LCRSLGET:	PUSHM.L	D3,D4,D6,A3	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	CALL	CRSEARCH	; A3 <-- ^dans la table	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	LOAD.L	D4,(A3)+OCTNAM	; D4 <-- couleur relative	LOAD.L	A4,#(A6)+OCOLR	; A4 <-- ^buffer	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode	TCOL_	SRCCRET		; cherche une couleur dans la CRET	POPM.L	D3,D4,D6,A3	RET;--------\\; CRSLPUT >;========/; Change les couleurs choisies dans la scroll-liste.; in	A4.L	^RGB; out	-; mod	D7.WCRSLPUT:	PUSHM.L	D3..D6,A3	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	CALL	CRSEARCH	; A3 <-- ^dans la table	LOAD.L	D5,(A6)+OIDCRET	; D5 <-- identificateur CRET	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal TCOLOR	LOAD.L	D4,(A3)+OCTNAM	; D4 <-- couleur relative	LOAD.L	D3,(A6)+OFAN	; D3 <-- mode	TCOL_	PUTCRET		; ajoute une couleur dans la CRET	LOAD.L	(A6)+OIDCRET,D5	; OIDCRET <-- identificateur CRET	POPM.L	D3..D6,A3	RET;---------\\; CRSEARCH >;---------/; Cherche une couleur dans la table.; in	D3.W	rang (0..n); out	A3.L	^dans table;	D7.W	erreur; mod	D7.W, A3.LCRSEARCH:	PUSH.W	D3	LOAD.L	A3,(A6)+OPTTEXT	; A3 <-- ^table des textes	LOAD.W	D7,#1LOOP$:	TEST.L	(A3)		; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	DEC.W	D3	JUMP',NS FOUND$	LOAD.L	A3,#(A3)+LCTDATASKIP$:	TEST.B	(A3+)		; A3 <-- saute .ASCIZE	JUMP,NE SKIP$	EX.L	D3,A3	INC.L	D3	TCLR.L	D3:#0	EX.L	A3,D3	JUMP	LOOP$FOUND$:	CLR.W	D7		; D7 <-- okEXIT$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET	.END