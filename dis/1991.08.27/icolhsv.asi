	.SBTTL	ICOLHSV.ASI;-------------\\; _ICOL_RGBHSV >;=============/; Conversion RGB --> HSV.; in	A4.L	^couleur RGB [0..65535,0..65535,0..65535];	A3.L	^buffer pour HSV; out	(A3)+	couleur HSV [0..359,0..255,0..255]; mod	D7.W	.PC	PCVAR	.LOC	0OCRHRC:	.BLKB	2		; distance  rougeOCRHGC:	.BLKB	2		; distance  vertOCRHBC:	.BLKB	2		; distance  bleuLCRH:	.PC	PCCODE_ICOL_RGBHSV:	PUSHM.L	D0..D7	LOAD.L	SP,#(SP)-LCRH	; SP <-- ^variables locales	LOAD.W	D3,(A4)+OTCCR	; D3 <-- rouge	SR.W	D3,#8	LOAD.W	D4,(A4)+OTCCG	; D4 <-- vert	SR.W	D4,#8	LOAD.W	D5,(A4)+OTCCB	; D5 <-- bleu	SR.W	D5,#8	LOAD.W	D6,D3		; D6 <-- MIN(R,G,B)	COMP.W	D6,D4	JUMP',LS MIN1$	LOAD.W	D6,D4MIN1$:	COMP.W	D6,D5	JUMP',LS MIN2$	LOAD.W	D6,D5MIN2$:	LOAD.W	D7,D3		; D7 <-- MAX(R,G,B)	COMP.W	D7,D4	JUMP',HS MAX1$	LOAD.W	D7,D4MAX1$:	COMP.W	D7,D5	JUMP',HS MAX2$	LOAD.W	D7,D5MAX2$:	LOAD.W	D2,D7	SUB.W	D2,D6		; D2 <-- MAX-MIN	CLR.W	D1		; D1 <-- saturation	TEST.W	D7	JUMP',EQ S2$	CLR.L	D1	LOAD.W	D1,D2		; D1 <-- MAX-MIN	MUL.WA	D1,#255	DIV.WA	D1,D7		; D1 <-- (MAX-MIN)/MAXS2$:	CLR.W	D0	TEST.W	D1	JUMP,EQ H6$	CLR.L	D0	LOAD.W	D0,D7	SUB.W	D0,D3	MUL.WA	D0,#255	DIV.WA	D0,D2		; D0 <-- distance  rouge	LOAD.W	(SP)+OCRHRC,D0	CLR.L	D0	LOAD.W	D0,D7	SUB.W	D0,D4	MUL.WA	D0,#255	DIV.WA	D0,D2		; D0 <-- distance  vert	LOAD.W	(SP)+OCRHGC,D0	CLR.L	D0	LOAD.W	D0,D7	SUB.W	D0,D5	MUL.WA	D0,#255	DIV.WA	D0,D2		; D0 <-- distance  bleu	LOAD.W	(SP)+OCRHBC,D0	COMP.W	D3,D7	JUMP',NE H2$	LOAD.W	D0,(SP)+OCRHBC	SUB.W	D0,(SP)+OCRHGC	; D0 <-- entre jaune et magenta	JUMP'	H5$H2$:	COMP.W	D4,D7	JUMP',NE H3$	LOAD.W	D0,(SP)+OCRHRC	ADD.W	D0,#256*2	SUB.W	D0,(SP)+OCRHBC	; D0 <-- entre cyan et jaune	JUMP'	H5$H3$:	LOAD.W	D0,(SP)+OCRHGC	ADD.W	D0,#256*4	SUB.W	D0,(SP)+OCRHRC	; D0 <-- entre magenta et cyanH5$:	MUL.WA	D0,#60	ADD.L	D0,#255/2	DIV.WA	D0,#255	JUMP',NC H6$	ADD.W	D0,#360H6$:	LOAD.W	(A3)+OTCCB,D7	LOAD.W	(A3)+OTCCR,D0	LOAD.W	(A3)+OTCCG,D1	LOAD.L	SP,#(SP)+LCRH	; ajuste le stack	POPM.L	D0..D7	RET;-------------\\; _ICOL_HSVRGB >;=============/; Conversion HSV --> RGB.; in	A4.L	^couleur HSV [0..359,0..255,0..255];	A3.L	^buffer pour RGB; out	(A3)+	couleur RGB [0..65535,0..65535,0..65535]; mod	D7.W	.PC	PCVAR	.LOC	0OCHRP:	.BLKB	2		; OCHRQ:	.BLKB	2		; OCHRT:	.BLKB	2		; LCHR:	.PC	PCCODE_ICOL_HSVRGB:	PUSHM.L	D0..D7	LOAD.L	SP,#(SP)-LCHR	; SP <-- ^variables locales	LOAD.W	D3,(A4)+OTCCR	; D3 <-- teinte	LOAD.W	D4,(A4)+OTCCG	; D4 <-- saturation	LOAD.W	D5,(A4)+OTCCB	; D5 <-- intensit	TEST.W	D4		; saturation nulle ?	JUMP',NE S1$		; non => S1$				; oui => gris	LOAD.W	D3,D5	LOAD.W	D4,D5;	LOAD.W	D5,D5	JUMP	EXIT$S1$:	COMP.W	D3,#360	JUMP',LO H1$	CLR.W	D3H1$:	AND.L	D3,#H'FFFF	DIV.WU	D3,#60	LOAD.W	D2,D3		; D2 <-- 0..5	SWAP.W	D3	MUL.WA	D3,#256	DIV.WA	D3,#60		; D3 <-- 0..255	LOAD.W	D0,D4	SUB.W	D0,#255	NEG.W	D0	MUL.WA	D0,D5		; D0 <-- (255-S)*V	ADD.L	D0,#255/2	DIV.WA	D0,#255	LOAD.W	(SP)+OCHRP,D0	LOAD.W	D0,D3	MUL.WA	D0,D4	ADD.L	D0,#255/2	DIV.WA	D0,#255	SUB.W	D0,#255	NEG.W	D0	MUL.WA	D0,D5		; D0 <-- (255-(S*F))*V	ADD.L	D0,#255/2	DIV.WA	D0,#255	LOAD.W	(SP)+OCHRQ,D0	LOAD.W	D0,#255	SUB.W	D0,D3	MUL.WA	D0,D4	ADD.L	D0,#255/2	DIV.WA	D0,#255	SUB.W	D0,#255	NEG.W	D0	MUL.WA	D0,D5		; D0 <-- (255-(S*(255-F)))*V	ADD.L	D0,#255/2	DIV.WA	D0,#255	LOAD.W	(SP)+OCHRT,D0	DEC.W	D2	JUMP',NS C0$	DEC.W	D2	JUMP',NS C1$	DEC.W	D2	JUMP',NS C2$	DEC.W	D2	JUMP',NS C3$	DEC.W	D2	JUMP',NS C4$C5$:	LOAD.W	D3,D5	LOAD.W	D4,(SP)+OCHRP	LOAD.W	D5,(SP)+OCHRQ	JUMP'	EXIT$C4$:	LOAD.W	D3,(SP)+OCHRT	LOAD.W	D4,(SP)+OCHRP;	LOAD.W	D5,D5	JUMP'	EXIT$C3$:	LOAD.W	D3,(SP)+OCHRP	LOAD.W	D4,(SP)+OCHRQ;	LOAD.W	D5,D5	JUMP'	EXIT$C2$:	LOAD.W	D3,(SP)+OCHRP	LOAD.W	D4,D5	LOAD.W	D5,(SP)+OCHRT	JUMP'	EXIT$C1$:	LOAD.W	D3,(SP)+OCHRQ	LOAD.W	D4,D5	LOAD.W	D5,(SP)+OCHRP	JUMP'	EXIT$C0$:	LOAD.W	D3,D5	LOAD.W	D4,(SP)+OCHRT	LOAD.W	D5,(SP)+OCHRP;	JUMP'	EXIT$EXIT$:	LOAD.B	(A3)+OTCCR+0,D3	LOAD.B	(A3)+OTCCR+1,D3	LOAD.B	(A3)+OTCCG+0,D4	LOAD.B	(A3)+OTCCG+1,D4	LOAD.B	(A3)+OTCCB+0,D5	LOAD.B	(A3)+OTCCB+1,D5	LOAD.L	SP,#(SP)+LCHR	; ajuste le stack	POPM.L	D0..D7	RET	.END