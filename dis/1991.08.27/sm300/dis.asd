	.TITLE	DIS.ASD;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------;	Source des pilotes *_DIS.DRIV	.BASE	10'10	.LAYOUT HEXDebugActive = falseCheckCanalTcol	=	falseModifJFG	=	TRUETestDescValid	=	false; Date		Rev	Amliorations; ------------------------------------------------------------------------------------------; 21.05.91	6.18	commande IM[pos.B][tat.B][type.B];			  pos:	position 0..3 pour M0, M1, SHIFT-M0 et SHIFT-M1;			  tat:	0=rien, 1=release, 1=enter;			  type:	0=5 1/4", 1=3 1/2", 2=hyperflex, 3=autre; 20.03.91	6.17	Correction dans CloDesc: le descripteur est remis  zro dans sa liste; 19.03.91	6.16	Meilleures exclusions !??; 18.03.91	6.15	Correction lors de TCol_ Close mise  zro de {A2}+ODFCPF; 15.03.91	6.14	ActiveOne modifiait D4.32; 28.11.90	6.13	Petites amliorations esthtiques pour le smaky300: coins arrondis,;			dimensions des fentres modifies.; 19.11.90	6.12	Adaptation au module couleur TColor, suite du nettoyage.; 14.11.90	6.11	Nettoyage gnral, suppression des moult .IF parasites et illisibles;			accumuls au fil du temps.; 04.10.90		+++ JMP +++ Correction dans ColorFauSrc qui ne calculait pas la;			distance juste entre deux couleurs.; 30.09.90		+++ JMP +++ Adaptation  la couleur (presque) termine; 13.09.90		+++ JMP +++ Dbut de la (r)adaptation  la couleur; 16.08.90	6.10	+++ JFG +++ Adaptation au Smaky 300; 23.11.89	6.8	+++ DD +++ Dplacement ODFIX selon RIGHT/LEFT (pour clic souris);			Il est possible de cliquer tout en haut d'un grand cran 324 -> CLE/CLOCK; 15.11.89	6.7	+++ DD +++ GETPGC durant la lecture en parallle du mme genc !!;			nb. Il faudrait faire mieux avec un second smaphore !!; 26.06.89	6.6	LOADGC: si NRF28 => prend NRF14 et construit 2x de nouveau ok;			LOADGC: ne cherche plus que les gencars SMA_;			install fentres 7,8,9 cal  gauche possible (pour RECUP); 16.06.89	6.5	charge XCAR  l'install d'une fentre normale; 09.06.89	6.4	LOADGC retourne l'erreur effective de XCAR; 30.05.89	6.3	MAXGC=32 --> 64 (et ODFMAP doubl); 13.04.89	6.2	LOADGC utilise le module XCAR si ncessaire; 31.03.89	6.1	mode graphique = GRACLIP par dfaut; 19.12.88	6.0	nouveaux: XPEN/XTRAME/XMAPTT (et LGDIS8);			ODFIY,ODFIDY: corrige bug avec LIB,?OPEBITMAP; 17.10.88	5.5	si SM324 petit cran => utilise NRF09; 07.10.88	5.4	soft-keys: SNF12 -> SNF11 et NEF12 -> NEF11;			ASSGC,MEMGC: supprims;			liens fixes: NRF12-NEF11, NEF12-NEF11 et SNF12-SNF11; 11.08.88	5.3	si romable, utilise _SMODECR; 04.07.88	5.2	mode GRACLIP2: clipping aussi pour les caractres; 02.05.88	5.1	AFFILLT/AFFILLA;			MMODULO;			utilise le module GRA 2.1 presque entirement refait !;			romable et relogeable; 11.04.88	5.0	nouveaux: COLORxx; 09.03.88	4.8	LOADGC: ne bloque plus tous les accs cran; 14.12.87	4.7	$DIS_6 ayant 640x340 points (comme SMAKY100); 25.11.87	4.6	nouveau .INS DISSOFTKEY.ASI pour ODFPSK.L; 20.11.87	4.5	.IF SM324 repris selon BB; 19.04.87		BB: adaptation grand cran Smaky 324; 04.04.87		BB: 1re adaptation Smaky 324; 02.03.87	4.4	commutation rapide de diapos selon 100_INFO; 25.02.87	4.3	AFGREY/AFFULL; 11.02.87	4.2	pour GENCAR: clear bit 2'7 de la fonte (D3.B); 12.01.87	4.1	gencar 2x plus petits possibles;			nouveau: NEWGC o f ssss t; 12.12.86	4.0	nom des gencars: (SMA,100)_TRP14.GENC; 09.12.86		commande SCRPARAM rinitialise bien tout; 21.11.86		nouvelle commande SCRPARAM; 08.10.86		CLOBITMAP si gencar n'existe pas !; 24.09.86		SPRITEs laisse la souris (si possible); 29.05.86		PFIXGC uniquement pour fontes "D" et "Q"; 06.05.86		SMAKY100: 4 grands bitmaps; 16.04.86		utilise ?CLOAD/?CUNLOAD pour les gencars; 28.02.86		PFIXGC prfix pour les gnrateurs; 11.02.86		LGDIS6 pour peindre en mmoire !; 09.01.86		DRAWPMOUSE ssss,cccc: matrice(s) de la souris.CHAP	Assemblage conditionnelDebugRESET	=	FalseDebug		=	False		; Messages diversDebugTColor	=	False		; Messages concernant TColorKillRegions	=	True		; Dtruit {A2}+ODFCRGUseRaster	=	False		; Essai d'utiliser Gra2Raster					; pour dcaler les fentresSeparateCLUT	=	False		; CLUT systme dans un fichier spar; FullPage	(Valable uniquement pour sm324 et Cos21) indique que l'on;		assemble un pilote pour un cran pleine page A4.; FondBlanc	Indique que l'on assemble pour un moniteur  fond blanc;		(sm324 + FullPage, Cos21+FullPage, sm300)	.INS	TESTMACHINE.ASI	Testmachine.IF	Sm324.OR.Cos21FullPage	=	false		; Ecran pleine page A4 (Costronic/sm324), 					; on modifie ici ! ! !.ELSE	Sm324.OR.Cos21.IF	Sm300FullPage	=	False.ELSE	Sm300FullPage	=	False.ENDIF	ELSE Sm300.ENDIF	ELSE Sm324.OR.Cos21.IF	Sm300.OR.(sm324.AND.FullPage).OR.(Cos21.AND.FullPage)FondBlanc	=	True.ELSE	Sm300.OR.(sm324.AND.FullPage).OR.(Cos21.AND.FullPage)FondBlanc	=	False.ENDIF	ELSE Sm300.OR.(sm324.AND.FullPage).OR.(Cos21.AND.FullPage).IF	Sm196.OR.Sm300.OR.Sm324.OR.Cos21CPU020		=	True	.PROC	M68020.ELSE	Sm196.OR.Sm300.OR.Sm324.OR.Cos21CPU020		=	False	.PROC	M68000.ENDIF	ELSE Sm196.OR.Sm300.OR.Sm324.OR.Cos21DISREV	=	6		; rvisionDISVERS	=	18		; version	.REV	DISREV,DISVERS	.CODE	0,0,0,0,0,0,0,0,"?","?","F",0.if	SM300	.IDENT	"Pilote Ecran Smaky 300, (C)  Daniel ROUX et EPSITEC-system sa".ENDIF	.if	SM324.if	FullPage	.IDENT	"Pilote Ecran pleine page Smaky 324, (C)  Daniel ROUX et EPSITEC-system sa".ELSE	.IDENT	"Pilote Ecran petit  Smaky 324, (C)  Daniel ROUX et EPSITEC-system sa".ENDIF	FullPage.ENDIF	.if	SM100	.IDENT	"Pilote Ecran Smaky 100, (C)  Daniel ROUX et EPSITEC-system sa".ENDIF	.if	SM196	.IDENT	"Pilote Ecran Smaky 196, (C)  Daniel ROUX et EPSITEC-system sa".ENDIF	.if	SM8	.IDENT	"Pilote Ecran Smaky 8, (C)  Daniel ROUX et EPSITEC-system sa".ENDIF	.if	COS21.IF	FullPage	.IDENT	"Pilote Ecran pleine page COSTRONIC, (C)  Daniel ROUX et EPSITEC-system sa".else	.IDENT	"Pilote petit cran COSTRONIC, (C)  Daniel ROUX et EPSITEC-system sa".endif.ENDIF;;?GRA2_CRASTER = 16'AA99		; raster-op couleurBSRCCOUL = 11BDSTCOUL = 12VIDEONINC = 16'2001018;;?	.REF	GRAMISC	.REF	SMAKY	.REF	MON	.REF	BIOSDRIV	.REF	BIOS	.REF	DOLIB	.REF	GRA2	.REF	GRA	.REF	GENCAR	.REF	XCAR	.REF	Drivers.IF	Sm300	.REF	COLORS	.REF	TColor.ENDIF	Sm300.IF	SM8	.REF	SM8HARD.ENDIF	SM8.IF	SM324	.REF	SM324HARD.ENDIF	SM324.IF	Cos21	.REF	Co2HardAdEcr1	=	16'7000000			; Manquent dans Co2Hard.ASSAdEcr2	=	16'7020000.ENDIF	Cos21.IF	Sm100	.REF	ShiDriv100.ENDIF	Sm100.IF	SM196	.REF	SM196HARD	.REF	SHIDRIV196	.REF	MON.ENDIF	SM196.IF	SM300	.REF	SM300HARD	.REF	SHIDRIV300	.REF	INDROM300.ENDIF	SM300.CHAP	Macroinstructions.MACRO	_Debug		; Texte.IF	Debug	MON	?AFTIM.ASCIZE	"{%1} "	PUSH.32	D3	MON	?GETCAR	POP.32	D3.ENDIF	Debug.ENDMACRO.MACRO	_DebugN		; Texte.IF	Debug	MON	?AFTIM.ASCIZE	"{%1} ".ENDIF	Debug.ENDMACRO.MACRO	_DebugX2	; Texte, var.8.IF	Debug	PUSH.32	D4	MON	?AFTIM.ASCIZE	"{%1 "	MOVE.8	%2,D4	MON	?AFX2	MON	?AFTIM.ASCIZE	"} "	PUSH.32	D3	MON	?GetCar	POP.32	D3	POP.32	D4.ENDIF	Debug.ENDMACRO.MACRO	_Header		; ID.LOCALMACRO Start, NameStart:	.16	-1			; DOOPEN-D1BASE	.16	DOCOMMAND-D%1BASE	.16	DORSTATUS-D%1BASE	.16	DOREAD-D%1BASE	.16	DOWRITE-D%1BASE	.16	-1			; DOCLOSE	.16	-1			; STOPTR	.16	-1			; STARTR	.16	-1			; AVORTTR	.16	-1			; DOAUX1	.16	-1			; DOAUX2	.16	DORESET-D%1BASE	.16	DOKILL-D%1BASE	.16	-1			; DOSTRT	.16	-1			; DOTSTRT	.16	-1			; DOSTARTName:	.ASCII	"DIS_%1"		; Nom driver	.FILL.8	LGDNAM-(APC-Name),0	.8	NOBASE+%1		; Numro driver	.8	TYPWDO			; Type: Fentre	.8	0,0			; Rvision - version	.16	0			; Variante	.8	0			; Attribut 1	.8	2**BDRDOK.OR.2**BDWROK	; Attribut 0	.FILL.8	LGDDESC-(APC-Start),0	; Le reste.D%1BASE:.ENDMACRO.MACRO	_GraCall	; Gra2Name.IF	KillRegions	PUSH.32	{A2}+ODFCRG	CLR.32	{A2}+ODFCRG.ENDIF	KillRegions.IF	CPU020	CALL	{{A6}+OAdGra+4*(Gra2_%1-Gra2_First)}.ELSE	CPU020	PUSH.32	A0	MOVE.32	{A6}+OADGRA+(4*(GRA2_%1-GRA2_FIRST)),A0	CALL	{A0}		; appel de GRA2_TRAME	POP.32	A0.ENDIF	ELSE CPU020.IF	KillRegions	POP.32	{A2}+ODFCRG.ENDIF	KillRegions.ENDMACRO.macro	TestDesc.if	TestDescValid.IF	ModifJFG	PUSHM.32	A0|D0|D1|D4	push.16		sf	move.16		#16'2500, sf	move.32	{a6}+OBitMapDis, D1	move.16	#32-1, d0	MOVE.32	#{A6}+OpDFen, A0	CLR.16	D4Loop$:	SR.32	D1	JUMP,CC	Libre$	TEST.32	{A0+}	JUMP,NE	Ok$	JUMP	Err$Libre$:	TEST.32	{A0+}	JUMP,EQ	Ok$Err$:	mon	?aftim	.ascize	"<cr>TestDesc dans %1: "	mon	?afx2	trap	#1Ok$:	INC.16	D4	DJ.16,NMO D0, Loop$	pop.16	sf	POPM.32	A0|D0|D1|D4	.ENDIF	ModifJFG.endif	TestDescValid.ENDMACRO.CHAP	Dfinitions diverses.IF	.NOT.SM300REGHOR1	=	3		; VDC: numro registre dcalage HREGHOR2	=	2		; VDC: numro registre dcalage HREGVERT	=	7		; VDC: numro registre dcalage VREGPOX	=	13		; VDC: numro registre position XREGPOY	=	12		; VDC: numro registre position YLTAVDC	=	14		; VDC: longueur de la table TAVDCSCRNZONE=	16'093A		; donne l'adresse du premier bitmap cranSCVDC	=	16'094A		; ^table VDC standard	.IF	SM8ADVDC	=	VDC+1ADVDCR	=	VDCR+1	.ENDIF_SMODECR=	16'10EE	.IF	SM100ADVDC	=	16'FF9080ADVDCR	=	16'FF9082MODECR	=	16'FF9A20	.ENDIF.ENDIF	.NOT.SM300.IF	FullPageDefTaille	=	11	; Ecran pleine page: caractres NEF11.ELSE	FullPageDefTaille	=	9	; Ecran demi page: caractres NRF09.ENDIF	ELSE FullPageNOBASE	=	16'20		; numro de base pour driver.IF	FullPagePViewX		=	864	; Dimensions de l'cran pleine pagePViewY		=	1024	; A4  70KhzLargCX		=	8	; Dimensions des caractres par dfautLargCY		=	16	; (NEF11).ELSE	FullPageLargCX		=	6	; Dimensions des caractres par dfautLargCY		=	10	; (NRF09).IF	SM8PViewX		=	832	; Dimension de l'cran 16Khz entrelacPViewY		=	512	; du Smaky 8.ELSE	SM8.IF	Sm300PViewX		=	640	; Dimensions de l'cran "mac"  35KhzPViewY		=	480.ELSE	Sm300PViewX		=	640	; Dimensions de l'cran Philips 20.1 KHzPViewY		=	400.ENDIF	ELSE Sm300.ENDIF	ELSE SM8.ENDIF	ELSE FullPageLVIEWX	=	PVIEWX/LARGCX	; nb caractres visibles en XLVIEWY	=	PVIEWY/LARGCY	; nb caractres visibles en Y.IF	FullPageSepX89	=	PViewX-32*LargCX; Sparation [pix] entre $Dis_8 (CLE) et $Dis_9 (Clock)SepY81	=	LargCy+7	; Sparation [pix] entre $Dis_8 et $Dis_1 (grande fentre)SepY17	=	PViewY-(LargCY*4)-2 ; Sparation [pix] entre $Dis_1 et $Dis_7 (softKeys)PBIGY	=	SEPY81+1DBIGY	=	PVIEWY-(LARGCY*4)-2-PBIGYDLITX	=	424		; largeur d'une petite fentreDLITY	=	160+24		; hauteur d'une petite fentreTRAGRIS	=	16'11441144	; trame pour fentre inutilisePOSIDLG	=	((1024/8)*3)+(PVIEWX/8)-2POSIDLD	=	POSIDLG.ELSE	FullPage.IF	Sm8SepX89	=	PViewX-32*LargCX; Sparation [pix] entre $Dis_8 (CLE) et $Dis_9 (Clock)SepY81	=	LargCy+(LargCY/2); Sparation [pix] entre $Dis_8 et $Dis_1 (grande fentre).ELSE	Sm8.IF	Sm300SepX89	=	446		; Sparation [pix] entre $Dis_8 (CLE) et $Dis_9 (Clock)SepY81	=	15		; Sparation [pix] entre $Dis_8 et $Dis_1 (grande fentre)SepY17	=	438		; Sparation entre $DIS_1 et $DIS_7POSIDLG	=	128*1 + (PVIEWX/8)-1POSIDLD	=	128*1 + (1024/8)-1.ELSE	Sm300SepX89	=	PViewX-32*LargCX; Sparation [pix] entre $Dis_8 (CLE) et $Dis_9 (Clock)SepY81	=	LargCy+6	; Sparation [pix] entre $Dis_8 et $Dis_1 (grande fentre)POSIDLG	=	(PVIEWX/8)-1POSIDLD	=	(1024/8)-1.ENDIF	ELSE Sm300.ENDIF	ELSE Sm8.ENDIF	ELSE FullPage.IF	.NOT.Sm300LARICOX	=	204/LARGCX	; largeur pour les icnes en car.ENDIF	Sm300.CHAP	Structures; Table de description d'une fentre; ----------------------------------MAXSAV	=	10		; nb max de SAVWDO/GETWDO imbriqus.LOC	LGDis8		; Partie dj dfinieODFIY:		.BLK.16		1		; copie "invariable" de ODFY  (*)ODFIX:		.BLK.16		1		; copie "invariable" de ODFX  (*)ODFIDY:		.BLK.16		1		; copie "invariable" de ODFDY (*)ODFIDX:		.BLK.16		1		; copie "invariable" de ODFDX (*)ODFADR:		.BLK.16		1		; adresse suite pour comm multiODFNXT:		.BLK.16		1		; adresse routine aprs comm.ODFCPT:		.BLK.16		1		; ^relatif dans commandeODFCCT:		.BLK.16		1		; compteur pour commandeODFCOM:		.BLK.8		30		; buffer d'une commandeODFMAP:		.BLK.8		8		; map des gencar utiliss (voir MAXGC=64 !)ODFPSV:		.BLK.16		1		; "SP" dans ODFSSVODFSSV:		.BLK.32		MAXSAV		; stack de ^zones sauvetage fentreODFNGC:		.BLK.8		24		; nom du gnrateur de caractresLGDFEN:; (*)	Ces copies sont ncessaires pour la routine MOIFONE qui;	doit toujours pouvoir trouver dans quelle fentre se;	trouve la souris, mme aprs un LIB,?OPEBITMAP !; Table pour un bitmap cran complet; ----------------------------------.IF	Cos21.IF	FullPageMaxBM	=	2		; Nbre max de grands bitmaps.ELSEMaxBM	=	4		; Nbre max de grands bitmaps.ENDIF	ELSE FullPage.ELSE	Cos21.IF	SM8MAXBM	=	2		; nb max de grands bitmaps.ELSE	Sm8MAXBM	=	4		; nb max de grands bitmaps.ENDIF	ELSE SM8.ENDIF	ELSE Cos21.IF	SM8NBWBM	=	4		; 4 fentres associes.ELSE	Sm8.IF	FullPageNBWBM	=	7		; 7 fentres associes.ELSE	FullPageNBWBM	=	3		; 3 fentres associes.ENDIF	ELSE FullPage.ENDIF	ELSE SM8	.LOC	0OBMABS:		.BLK.32		1		; adresse absolue du bitmapOBMWDO:		.BLK.8		NBWBM		; numros des fentres associes	.EVENLBM:; Table pour un gnrateur de caractres; --------------------------------------MAXGC	=	64		; nb max de gn. charg	.LOC	0OGCPT:		.BLK.32		1		; ^absolu dbut gnrateurOGCUSE:		.BLK.8		1		; 0 => lment libre (compteur)OGCF:		.BLK.8		1		; fonteOGCS:		.BLK.32		1		; styleOGCT:		.BLK.8		1		; tailleOGCNF:		.BLK.8		1		; fonte pour le nomOGCNS:		.BLK.8		1		; style pour le nomOGCNT:		.BLK.8		1		; taille pour le nomOGCX:		.BLK.8		1		; 1 => cr par XCAR	.EVENLGGC:; Table d'une image alphanumrique; --------------------------------	.LOC	0OIMADX:		.BLK.16		1		; nb de caractres/ligneOIMADY:		.BLK.16		1		; nb de lignes/fentreOIMACX:		.BLK.16		1		; largeur d'un caractreOIMACY:		.BLK.16		1		; hauteur d'un caractreOIMAPX:		.BLK.16		1		; position en X dans l'imageOIMAPY:		.BLK.16		1		; position en Y dans l'imageOIMASX:		.BLK.16		1		; dbut fentre en XOIMASY:		.BLK.16		1		; dbut fentre en YOIMALX:		.BLK.16		1		; largeur fentre en XOIMALY:		.BLK.16		1		; hauteur fentre en YOIMAOY:		.BLK.16		1		; offset ventuel en YLGIMA:.CHAP	Variables globales aux pilotes	.LOC	0OSTART:		.BLK.32		1		; adr absolue de dbut du code.IF	.NOT.SM300OTAVDC:		.BLK.8		LTAVDC		; table des registres du VDCOTBVDC:		.BLK.8		LTAVDC		; table de base (copie du moniteur)OSREGH:		.BLK.8		1		; cadrage standard horizontalOSREGV:		.BLK.8		1		; cadrage standard vertical.ENDIF	.NOT.SM300OPDFEN:		.BLK.32		32		; ^descripteurs des fentresOADGRA:		.BLK.32		(GRA2_LAST-GRA2_FIRST+1)OTAGC:		.BLK.8		MAXGC*LGGC	; table pour les GENCARsOPINFO:		.BLK.32		1		; ^informations dans SYS_INFOOSEMAX:		.BLK.16		2		; ^smaphore d'exclusionOBITMAP:.BLK.8	MAXBM*LBM	; table des bitmapsONOVBM:		.BLK.16		1		; numro du bitmap visible (0..3).IF	SM324.OR.SM300OBMUSE:		.BLK.8		1		; bitmap des crans utiliss.ENDIF	SM324.OR.SM300.IF	Sm300OGlobCRET:	.BLK.8		1		; CRET globale charge correctementOGloBCLUT:	.BLK.8		1		; CLUT globale charge correctement.ENDIF	Sm300;;jfg.IF	FullPage.if	sm324.or.cos21OOREGX:		.BLK.8		1		; offset pour l'utilisation Y du registre X du VDC.if	FullPageOWDO23:		.BLK.8		1		; fentre $DIS_2 et $DIS_3 existent.IF	.NOT.Cos21OWDO45:		.BLK.8		1		; fentre $DIS_4 et $DIS_5 existent.ENDIF	.NOT.Cos21.ENDIF	FullPage.endif	sm324.or.cos21.EVEN.if	ModifJFG.if	TestDescValid.EVENoBitMapDis:	.BLK.32		1		; bit map des pilotes installs.ENDIF	TestDescValid.ENDIF	ModifJFGONBGCS:		.BLK.16		1		; nb de gencar "soft" chargsOCHGCS:		.BLK.16		1		; canal du module gencarONBGCX:		.BLK.16		1		; nb de gencar XCAR chargsOCHGCX:		.BLK.16		1		; canal du module XCAROERGCX:		.BLK.16		1		; erreur gnre par XCAROLSTPD:		.BLK.32		1		; ^dernier descripteur de la fentre o est la sourisLGVAR:.CHAP	Descripteurs de pilotes	.LOC	0START:.IF	Sm324.IF	FullPage	.16	0,D0BASE		; [*] principale	.16	1,D1BASE		; [1] grande	.16	2,D2BASE		; [2] demi ou grande	.16	3,D3BASE		; [2] demi ou rien	.16	4,D4BASE		; [3] demi ou grande	.16	5,D5BASE		; [3] demi ou rien	.16	6,D6BASE		; [4] compatible SMAKY-100	.16	7,D7BASE		; [*] soft-keys	.16	8,D8BASE		; [*] C.L.E.	.16	9,D9BASE		; [*] clock	.16	10,D10BASE		; [4] petite	.16	11,D11BASE		; [4] petite	.16	12,D12BASE		; [4] petite	.16	13,D13BASE		; [4] petite	.16	14,D14BASE		; [4] petite	.16	15,D15BASE		; [4] petite.ELSE	FullPage	.16	0,D0BASE		; [*] principale	.16	1,D1BASE		; [1] grande	.16	2,D2BASE		; [2] grande	.16	3,D3BASE		; [3] grande	.16	4,D4BASE		; [4] grande	.16	7,D7BASE		; [*] soft-keys	.16	8,D8BASE		; [*] C.L.E.	.16	9,D9BASE		; [*] clock	.16	10,D10BASE		; [1] petite	.16	11,D11BASE		; [1] petite	.16	12,D12BASE		; [2] petite	.16	13,D13BASE		; [2] petite	.16	14,D14BASE		; [3] petite	.16	15,D15BASE		; [3] petite	.16	16,D16BASE		; [4] petite	.16	17,D17BASE		; [4] petite.ENDIF	ELSE FullPage.ELSE	Sm324.IF	Cos21.IF	FullPage	.16	0,D0BASE		; [*] principale	.16	1,D1BASE		; [1] grande	.16	2,D2BASE		; [2] demi ou grande	.16	3,D3BASE		; [2] demi	.16	7,D7BASE		; [*] soft-keys	.16	8,D8BASE		; [*] C.L.E.	.16	9,D9BASE		; [*] clock.ELSE	FullPage	.16	0,D0BASE		; [*] principale	.16	1,D1BASE		; [1] grande	.16	2,D2BASE		; [2] grande	.16	3,D3BASE		; [3] grande	.16	4,D4BASE		; [4] grande	.16	7,D7BASE		; [*] soft-keys	.16	8,D8BASE		; [*] C.L.E.	.16	9,D9BASE		; [*] clock	.16	10,D10BASE		; [1] petite	.16	11,D11BASE		; [1] petite	.16	12,D12BASE		; [2] petite	.16	13,D13BASE		; [2] petite	.16	14,D14BASE		; [3] petite	.16	15,D15BASE		; [3] petite	.16	16,D16BASE		; [4] petite	.16	17,D17BASE		; [4] petite.ENDIF	ELSE FullPage.ELSE	Cos21.IF	Sm8	.16	0,D0BASE		; [*] principale	.16	1,D1BASE		; [1] grande	.16	2,D2BASE		; [1] petite	.16	3,D3BASE		; [1] petite	.16	4,D4BASE		; [1] petite	.16	7,D7BASE		; [*] soft-keys	.16	8,D8BASE		; [*] C.L.E.	.16	9,D9BASE		; [*] clock	.16	11,D11BASE		; [2] grande	.16	12,D12BASE		; [2] petite	.16	13,D13BASE		; [2] petite	.16	14,D14BASE		; [2] petite.ELSE	Sm8	.16	0,D0BASE		; [*] principale	.16	1,D1BASE		; [1] grande	.16	2,D2BASE		; [2] grande	.16	3,D3BASE		; [3] grande	.16	4,D4BASE		; [4] grande	.16	7,D7BASE		; [*] soft-keys	.16	8,D8BASE		; [*] C.L.E.	.16	9,D9BASE		; [*] clock	.16	10,D10BASE		; [1] petite	.16	11,D11BASE		; [1] petite	.16	12,D12BASE		; [2] petite	.16	13,D13BASE		; [2] petite	.16	14,D14BASE		; [3] petite	.16	15,D15BASE		; [3] petite	.16	16,D16BASE		; [4] petite	.16	17,D17BASE		; [4] petite.ENDIF	ELSE Sm8.ENDIF	ELSE Cos21.ENDIF	ELSE Sm324	.16	2**7			; Fin de la liste; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_0	(bitmap principal); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=D0ID:	.16	-1			; DOOPEN-D0BASE	.16	DOCOMMAND-D0BASE	.16	DORSTATUS-D0BASE	.16	DOREAD-D0BASE	.16	DOWRITE-D0BASE	.16	-1			; DOCLOSE-D0BASE	.16	-1			; STOPTR	.16	-1			; STARTR	.16	-1			; AVORTTR	.16	-1			; DOAUX1-D0BASE	.16	-1			; DOAUX2-D0BASE	.16	D0RESET-D0BASE	.16	DOKILL-D0BASE	.16	-1			; DOSTRT-D0BASE	.16	-1			; DOTSTRT-D0BASE	.16	-1			; DOSTART-D0BASED0NAB:	.ASCII	"DIS_0"			; Nom driverD0NAF:	.FILL.8	LGDNAM-(D0NAF-D0NAB),0	.8	NOBASE+0		; Numro driver	.8	TYPDIS			; Type: Bit-map complet	.8	0,0			; Rvision - version	.16	0			; Variante	.8	0			; Attribut 1	.8	2**BDRDOK.OR.2**BDWROK	; Attribut 0	.FILL.8	LGDDESC-(APC-D0ID),0	; Le reste.D0BASE:	.16	0,0				; ODFY,X.IF	FullPage	.16	PVIEWY,PVIEWX			; ODFDY,X.ELSE	FullPage.IF	Sm8	.16	LARGCY*64,LARGCX*127		; ODFDY,X.ELSE	Sm8	.16	PViewY,1024			; ODFDY,X.ENDIF	ELSE Sm8.ENDIF	ELSE FullPage	.8	"1","L"				; ODFCAD	.8	0				; ODFNOW	.8	2**BFEFLI			; ODFMOD	.8	SETDOT				; ODFMCA.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_1	(grande fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	1.IF	FullPage	.16	PBigY, 0			; ODFY, X	.16	DBIGY,PVIEWX			; ODFDY,X.ELSE	FullPage.IF	Sm8	.16	LARGCY*2,0			; ODFY,X	.16	512-(LARGCY*6),800-8		; ODFDY,X.ELSE	Sm8.IF	Sm300	.16	SepY81+1,0			; ODFY,X	.16	422,PViewX			; ODFDY,X.ELSE	Sm300	.16	LARGCY*2,0			; ODFY,X	.16	LARGCY*(LVIEWY-6),PVIEWX	; ODFDY,X.ENDIF	ELSE Sm300.ENDIF	ELSE Sm8.ENDIF	ELSE FullPage	.8	"1","L"				; ODFCAD	.8	1				; ODFNOW	.8	2**BFEFLI.OR.2**BFRoll		; ODFMOD	.8	SETDOT				; ODFMCA.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_2	(grande fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	2.IF	FullPage	.16	PBigY, 0			; ODFY, X	.16	DBIGY,PVIEWX			; ODFDY,X	.8	"2","L"				; ODFCAD.ELSE	FullPage.IF	Sm8	.16	LARGCY*2,800			; ODFY,X	.16	160,1024-800			; ODFDY,X	.8	"1","R"				; ODFCAD.ELSE	Sm8.IF	Sm300	.16	SepY81+1,0			; ODFY,X	.16	422,PViewX			; ODFDY,X	.8	"2","L"				; ODFCAD.ELSE	Sm300	.16	LARGCY*2,0			; ODFY,X	.16	LARGCY*(LVIEWY-6),PVIEWX	; ODFDY,X	.8	"2","L"				; ODFCAD.ENDIF	ELSE Sm300.ENDIF	ELSE Sm8.ENDIF	ELSE FullPage	.8	2				; ODFNOW	.8	2**BFEFLI.OR.2**BFRoll		; ODFMOD	.8	SETDOT				; ODFMCA.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_3	(grande fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	3.IF	FullPage	.16	PBIGY+((DBIGY-10)/2)+10,0	; ODFY,X	.16	(DBIGY-10)/2,PVIEWX		; ODFDY,X	.8	"2","L"				; ODFCAD.ELSE	FullPage.IF	Sm8	.16	LARGCY*2+160+LARGCY,800		; ODFY,X	.16	112,1024-800			; ODFDY,X	.8	"1","R"				; ODFCAD.ELSE	Sm8.IF	Sm300	.16	SepY81+1,0			; ODFY,X	.16	422,PViewX			; ODFDY,X	.8	"3","L"				; ODFCAD.ELSE	Sm300	.16	LARGCY*2,0			; ODFY,X	.16	LARGCY*(LVIEWY-6),PVIEWX	; ODFDY,X	.8	"3","L"				; ODFCAD.ENDIF	ELSE Sm300.ENDIF	ELSE Sm8.ENDIF	ELSE FullPage	.8	3				; ODFNOW	.8	2**BFEFLI.OR.2**BFRoll		; ODFMOD	.8	SETDOT				; ODFMCA.EVEN.IF	.NOT.(Cos21.AND.FullPage); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_4	(grande fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	4.IF	FullPage	.16	PBIGY,0				; ODFY,X	.16	DBIGY,PVIEWX			; ODFDY,X	.8	"3","L"				; ODFCAD.ELSE	FullPage.IF	Sm8	.16	LARGCY*2+160+LARGCY+112+LARGCY,800 ; ODFY,X	.16	112,1024-800			; ODFDY,X	.8	"1","R"				; ODFCAD.ELSE	Sm8.IF	Sm300	.16	SepY81+1,0			; ODFY,X	.16	422,PViewX			; ODFDY,X	.8	"4","L"				; ODFCAD.ELSE	Sm300	.16	LARGCY*2,0			; ODFY,X	.16	LARGCY*(LVIEWY-6),PVIEWX	; ODFDY,X	.8	"4","L"				; ODFCAD.ENDIF	ELSE Sm300.ENDIF	ELSE Sm8.ENDIF	ELSE FullPage	.8	4				; ODFNOW	.8	2**BFEFLI.OR.2**BFRoll		; ODFMOD	.8	SETDOT				; ODFMCA.EVEN.ENDIF	.NOT.(Cos21.AND.FullPage).IF	FullPage; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_5	(grande fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	5	.16	PBIGY+((DBIGY-10)/2)+10,0	; ODFY,X	.16	(DBIGY-10)/2,PVIEWX		; ODFDY,X	.8	"3","L"				; ODFCAD	.8	5				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_6	(fentre SMAKY100); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=		_Header 6	.16	PBIGY+8,(PVIEWX-640)/2		; ODFY,X	.16	340,640				; ODFDY,X	.8	"4","L"				; ODFCAD	.8	6				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN.ENDIF	FullPage; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_7	(pour soft-keys); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	7.IF	FullPage	.16	LARGCY*(LVIEWY-4),LARGCX	; ODFY,X	.16	LARGCY*4,PVIEWX-(LARGCX*2)	; ODFDY,X.ELSE	FullPage.IF	Sm8	.16	512-(LARGCY*4),0		; ODFY,X	.16	LARGCY*4,LVIEWX*8		; ODFDY,X.ELSE	Sm8.IF	Sm300	.16	SepY17+1,2			; ODFY,X	.16	LargCY*4,PViewX-4		; ODFDY,X.ELSE	Sm300	.16	LARGCY*(LVIEWY-4),0		; ODFY,X	.16	LARGCY*4,PVIEWX			; ODFDY,X.ENDIF	ELSE Sm300.ENDIF	ELSE Sm8.ENDIF	ELSE FullPage	.8	0,0				; ODFCAD	.8	7				; ODFNOW.IF	Sm300	.8	2**BFNOCU			; ODFMOD.ELSE	Sm300	.8	2**BFROLL.OR.2**BFNOCU		; ODFMOD.ENDIF	ELSE Sm300	.8	SETDOT				; ODFMCA.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_8	(pour le C.L.E.); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	8.IF	FullPage	.16	2,LARGCX*1			; ODFY,X	.16	LARGCY,SEPX89-LargCX*(LARICOX-1); ODFDY,X.ELSE	FullPage.IF	Sm8	.16	0,0				; ODFY,X	.16	LARGCY,SepX89-LARGCX*LARICOX	; ODFDY,X.ELSE	Sm8.IF	Sm300	.16	2,2				; ODFY,X	.16	LargCY,268			; ODFDY,X.ELSE	Sm300	.16	0,0				; ODFY,X	.16	LARGCY,SEPX89-LargCX*LARICOX	; ODFDY,X.ENDIF	ELSE Sm300.ENDIF	ELSE Sm8.ENDIF	ELSE FullPage	.8	0,0				; ODFCAD	.8	8				; ODFNOW	.8	2**BFROLL.OR.2**BFEfli.OR.2**BFPCur ; ODFMOD	.8	SETDOT				; ODFMCA.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_9	(pour l'horloge); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	9.IF	FullPage	.16	2,SEPX89			; ODFY,X	.16	LARGCY,LARGCX*29		; ODFDY,X.ELSE	FullPage.IF	Sm8	.16	0,SEPX89			; ODFY,X	.16	LARGCY,LARGCX*29		; ODFDY,X.ELSE	Sm8.IF	Sm300	.16	2,SEPX89			; ODFY,X	.16	LARGCY,LARGCX*29		; ODFDY,X.ELSE	Sm300	.16	0,SEPX89			; ODFY,X	.16	LARGCY,LARGCX*29		; ODFDY,X.ENDIF	ELSE Sm300.ENDIF	ELSE Sm8.ENDIF	ELSE FullPage	.8	0,0				; ODFCAD	.8	9				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI.OR.2**BFPCUR.OR.2**BFNOCU; ODFMOD	.8	SETDOT				; ODFMCA.EVEN.IF	Sm8; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_11	(petite fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	11	.16	LARGCY*2,0			; ODFY,X	.16	512-(LARGCY*6),800-8		; ODFDY,X	.8	"2","L"				; ODFCAD	.8	11				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_12	(petite fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	12	.16	L