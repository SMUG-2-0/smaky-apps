R"				; ODFCAD	.8	11				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_12	(petite fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	12.if	sm300	.16	SepY81+1,PVIEWX+8		; ODFY,X	.16	208,1024-(PVIEWX+8)		; ODFDY,X.else	.16	LARGCY*2,PVIEWX+8		; ODFY,X	.16	165,1024-(PVIEWX+8)		; ODFDY,X.endif	sm300	.8	"2","R"				; ODFCAD	.8	12				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_13	(petite fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	13.if	sm300	.16	SepY81+213, PViewX+8		; ODFY, X	.16	210,1024-(PVIEWX+8).else		.16	LARGCY*2+175,PVIEWX+8		; ODFY,X	.16	165,1024-(PVIEWX+8)		; ODFDY,X.endif	sm300	.8	"2","R"				; ODFCAD	.8	13				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_14	(petite fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	14.if	sm300	.16	SepY81+1,PVIEWX+8		; ODFY,X	.16	208,1024-(PVIEWX+8)		; ODFDY,X.else	.16	LARGCY*2,PVIEWX+8		; ODFY,X	.16	165,1024-(PVIEWX+8)		; ODFDY,X.endif	sm300	.8	"3","R"				; ODFCAD	.8	14				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_15	(petite fentre); =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=	_Header	15.if	sm300	.16	SepY81+213, PViewX+8		; ODFY, X	.16	210,1024-(PVIEWX+8).else		.16	LARGCY*2+175,PVIEWX+8		; ODFY,X	.16	165,1024-(PVIEWX+8)		; ODFDY,X.endif	sm300	.8	"3","R"				; ODFCAD	.8	15				; ODFNOW	.8	2**BFROLL.OR.2**BFEFLI		; ODFMOD	.8	SETDOT				; ODFMCA	.EVEN; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;		DRIVER $DIS_