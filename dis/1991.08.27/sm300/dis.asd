 D3 <-- code du premier appel	LIB_	OPEN		; charge le module GRA	JUMP,NE L90$.IF	.NOT.SM300	MOVE.32	SCVDC,A3	MOVE.32	#{A6}+OTBVDC,A4	MOVE.16	#LTAVDC-1,D4L15$:	MOVE.8	{A3+},{A4+}	; OTBVDC <-- copie de la table du moniteur	DJ.16,NMO  D4,L15$.ENDIF	.NOT.SM300	CALL	OPEDESC		; A2 <-- ^descripteur	CLR.8	D0.IF	.NOT.Sm300	CALL	NEWVDC		; TAVDC <-- paramtres standards	MOVE.32	SCRNZONE,A4	; A4 ^1er cran.ELSE	.NOT.Sm300	MOVE.32	#AdPixelMap1, A4; A4 ^1er cran.ENDIF	ELSE .NOT.SM300.IF	SM300	CALL	VisuBitMap	; montre le bit map.ELSE	CALL	INIYBITMAP.ENDIF	ELSE SM300	MOVE.32	A2,{A6}+OLSTPD	; OLSTPD <-- ^descripteur o est la souris.IF	SM324.OR.SM300	MOVE.8	#2'00000001,{A6}+OBMUSE	; init le bitmap 0 utilis.ENDIF	SM324.OR.SM300.IF	SM324	CLR.8	{A6}+OOREGX	; se rappelle de l'offset REGPOX	CLR.8	{A6}+OTAVDC+REGPOX.ENDIF	Sm324.IF	SM8	MOVE.32	SCRNZONE,{A6}+OBITMAP+LBM*0+OBMABS	MOVE.8	#1,{A6}+OBITMAP+LBM*0+OBMWDO+0	MOVE.8	#2,{A6}+OBITMAP+LBM*0+OBMWDO+1	MOVE.8	#3,{A6}+OBITMAP+LBM*0+OBMWDO+2	MOVE.8	#4,{A6}+OBITMAP+LBM*0+OBMWDO+3	MOVE.8	#11,{A6}+OBITMAP+LBM*1+OBMWDO+0	MOVE.8	#12,{A6}+OBITMAP+LBM*1+OBMWDO+1	MOVE.8	#13,{A6}+OBITMAP+LBM*1+OBMWDO+2	MOVE.8	#14,{A6}+OBITMAP+LBM*1+OBMWDO+3.ENDIF	Sm8.IF	Sm324.OR.Cos21.IF	FullPage	MOVE.32	SCRNZONE,{A6}+OBITMAP+LBM*0+OBMABS	MOVE.8	#1,{A6}+OBITMAP+LBM*0+OBMWDO+0	MOVE.8	#-1,{A6}+OBITMAP+LBM*0+OBMWDO+1	MOVE.8	#-1,{A6}+OBITMAP+LBM*0+OBMWDO+2	MOVE.8	#-1,{A6}+OBITMAP+LBM*0+OBMWDO+3	MOVE.8	#-1,{A6}+OBITMAP+LBM*0+OBMWDO+4	MOVE.8	#-1,{A6}+OBITMAP+LBM*0+OBMWDO+5	MOVE.8	#-1,{A6}+OBITMAP+LBM*0+OBMWDO+6	MOVE.8	#2,{A6}+OBITMAP+LBM*1+OBMWDO+0	MOVE.8	#3,{A6}+OBITMAP+LBM*1+OBMWDO+1	MOVE.8	#-1,{A6}+OBITMAP+LBM*1+OBMWDO+2	MOVE.8	#-1,{A6}+OBITMAP+LBM*1+OBMWDO+3	MOVE.8	#-1,{A6}+OBITMAP+LBM*1+OBMWDO+4	MOVE.8	#-1,{A6}+OBITMAP+LBM*1+OBMWDO+5	MOVE.8	#-1,{A6}+OBITMAP+LBM*1+OBMWDO+6	MOVE.8	#4,{A6}+OBITMAP+LBM*2+OBMWDO+0	MOVE.8	#5,{A6}+OBITMAP+LBM*2+OBMWDO+1	MOVE.8	#-1,{A6}+OBITMAP+LBM*2+OBMWDO+2	MOVE.8	#-1,{A6}+OBITMAP+LBM*2+OBMWDO+3	MOVE.8	#-1,{A6}+OBITMAP+LBM*2+OBMWDO+4	MOVE.8	#-1,{A6}+OBITMAP+LBM*2+OBMWDO+5	MOVE.8	#-1,{A6}+OBITMAP+LBM*2+OBMWDO+6	MOVE.8	#6,{A6}+OBITMAP+LBM*3+OBMWDO+0	MOVE.8	#10,{A6}+OBITMAP+LBM*3+OBMWDO+1	MOVE.8	#11,{A6}+OBITMAP+LBM*3+OBMWDO+2	MOVE.8	#12,{A6}+OBITMAP+LBM*3+OBMWDO+3	MOVE.8	#13,{A6}+OBITMAP+LBM*3+OBMWDO+4	MOVE.8	#14,{A6}+OBITMAP+LBM*3+OBMWDO+5	MOVE.8	#15,{A6}+OBITMAP+LBM*3+OBMWDO+6.ELSE	FullPage	MOVE.32	SCRNZONE,{A6}+OBITMAP+LBM*0+OBMABS	MOVE.8	#1,{A6}+OBITMAP+LBM*0+OBMWDO+0	MOVE.8	#10,{A6}+OBITMAP+LBM*0+OBMWDO+1	MOVE.8	#11,{A6}+OBITMAP+LBM*0+OBMWDO+2	MOVE.8	#2,{A6}+OBITMAP+LBM*1+OBMWDO+0	MOVE.8	#12,{A6}+OBITMAP+LBM*1+OBMWDO+1	MOVE.8	#13,{A6}+OBITMAP+LBM*1+OBMWDO+2	MOVE.8	#3,{A6}+OBITMAP+LBM*2+OBMWDO+0	MOVE.8	#14,{A6}+OBITMAP+LBM*2+OBMWDO+1	MOVE.8	#15,{A6}+OBITMAP+LBM*2+OBMWDO+2	MOVE.8	#4,{A6}+OBITMAP+LBM*3+OBMWDO+0	MOVE.8	#16,{A6}+OBITMAP+LBM*3+OBMWDO+1	MOVE.8	#17,{A6}+OBITMAP+LBM*3+OBMWDO+2.ENDIF	ELSE FullPage.ENDIF	Sm324.OR.Cos21.IF	SM100.OR.SM196	MOVE.32	SCRNZONE,{A6}+OBITMAP+LBM*0+OBMABS	MOVE.8	#1,{A6}+OBITMAP+LBM*0+OBMWDO+0	MOVE.8	#10,{A6}+OBITMAP+LBM*0+OBMWDO+1	MOVE.8	#11,{A6}+OBITMAP+LBM*0+OBMWDO+2	MOVE.8	#2,{A6}+OBITMAP+LBM*1+OBMWDO+0	MOVE.8	#12,{A6}+OBITMAP+LBM*1+OBMWDO+1	MOVE.8	#13,{A6}+OBITMAP+LBM*1+OBMWDO+2	MOVE.8	#3,{A6}+OBITMAP+LBM*2+OBMWDO+0	MOVE.8	#14,{A6}+OBITMAP+LBM*2+OBMWDO+1	MOVE.8	#15,{A6}+OBITMAP+LBM*2+OBMWDO+2	MOVE.8	#4,{A6}+OBITMAP+LBM*3+OBMWDO+0	MOVE.8	#16,{A6}+OBITMAP+LBM*3+OBMWDO+1	MOVE.8	#17,{A6}+OBITMAP+LBM*3+OBMWDO+2.ENDIF	SM100.OR.SM196.IF	SM300	MOVE.32	#AdPixelMap1,{A6}+OBITMAP+LBM*0+OBMABS	MOVE.8	#1,{A6}+OBITMAP+LBM*0+OBMWDO+0	MOVE.8	#10,{A6}+OBITMAP+LBM*0+OBMWDO+1	MOVE.8	#11,{A6}+OBITMAP+LBM*0+OBMWDO+2	MOVE.8	#2,{A6}+OBITMAP+LBM*1+OBMWDO+0	MOVE.8	#12,{A6}+OBITMAP+LBM*1+OBMWDO+1	MOVE.8	#13,{A6}+OBITMAP+LBM*1+OBMWDO+2	MOVE.8	#3,{A6}+OBITMAP+LBM*2+OBMWDO+0	MOVE.8	#14,{A6}+OBITMAP+LBM*2+OBMWDO+1	MOVE.8	#15,{A6}+OBITMAP+LBM*2+OBMWDO+2	MOVE.8	#4,{A6}+OBITMAP+LBM*3+OBMWDO+0	MOVE.8	#16,{A6}+OBITMAP+LBM*3+OBMWDO+1	MOVE.8	#17,{A6}+OBITMAP+LBM*3+OBMWDO+2	MOVE.16	VideoNInc+2,{A2}+ODFIIY	MOVE.32	#AdPixelMap1, {A2}+ODFABS.ELSE	Sm300	MOVE.32	SCRNZONE,{A2}+ODFABS.ENDIF	ELSE Sm300	MOVE.32	{A2}+ODFABS,{A2}+ODFCAB	MOVE.16	#1,{A2}+ODFIIX.IF	.NOT.Sm300	MOVE.16	#16'80,{A2}+ODFIIY.ENDIF	.NOT.Sm300	MOVE.32	#{A6}+OADGRA,A1	; A1 <-- ^buffer pour les adresses	MOVE.16	#GRA2_FIRST,D3	; D3 <-- premier code du module GRA2	MOVE.16	#(GRA2_LAST-GRA2_FIRST+1)-1,D4L20$:	LIB_	GETAD		; 	MOVE.32	A3,{A1+}	; mmorise l'adresse de la routine	INC.16	D3		; D3 <-- code de l'appel GRA2 suivant	DJ.16,NMO  D4,L20$	MOVE.16	#1,D4	NTREL	?CRESEM		; cre smaphore d'exclusion	MOVE.32	A5,{A6}+OSEMAX	; init ^smaphore	MOVE.32	#R16^START,A1	MOVE.32	A1,{A6}+OSTART	FOS	?OPINFO		; A4 <-- ^infos	JUMP,NE L90$	MOVE.32	A4,{A6}+OPINFO	; mm. ^informations	CLR.16	D4		; D4 <-- pas de mj.	FOS	?CLINFO		; ferme les infos	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre.IF	SM300	MOVE.32	#AdPixelMap1, D0.ELSE	Sm300	MOVE.32	SCRNZONE,D0	; D0 <-- adresse de l'cran.ENDIF	ELSE SM300.IF	Sm300	TEST.8	{A2}+ODFCMD		; Ecran couleur ?	JUMP,F	R8^IdleBlack$	ADD.32	#PosIdlG*4,D0		; Oui => Idle plus  droite	JUMP	R8^IdleColor$IdleBlack$:	ADD.32	#PosIdlG,D0IdleColor$:.ELSE	Sm300	ADD.32	#POSIDLG,D0.ENDIF	ELSE Sm300	MOVE.32	D0,_VINCIDL	CLR.8	D0		; D0 <-- fonte par dfaut	CLR.32	D1		; D1 <-- style par dfaut	CLR.8	D2		; D2 <-- taille par dfaut	CLR.32	{A2}+ODFMAP+0	; clear compltement le map	CLR.32	{A2}+ODFMAP+4	CALL	GCLOAD		; charge le gnrateur standard	TEST.16	D7	JUMP,NE	 R8^L90$	CALL	GCUSE		; (A2)++ <-- paramtres	TEST.16	D7	JUMP,NE	 R8^L90$	CALL	EFFACE		; efface tout (1024 x 1024)	CLR.16	D1		; D1 <-- bitmap principal	CALL	IDIS		; remet les sparations.IF	.NOT.SM300	CALL	INIVDC		; init le controleur d'cran.ENDIF	.NOT.SM300L80$:.if	ModifJFG.if	TestDescValid	PUSH.16	SF	MOVE.16	#16'2500, SF	MOVE.32	{A6}+oBitMapDis, D0	TSET.32	D0:#0	MOVE.32	D0, {A6}+oBitMapDis	POP.16	SF.endif	TestDescValid.ENDIF	ModifJFG	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D2|D3|D4|A2|A3|A4|A5.IF	DebugReset	PUSH.32	D3	PUSH.32	D4	MON	?AFTIM.ASCIZE	" D0Reset END, D7="	MOVE.16	D7,D4	MON	?AFX4	MON	?GetCar	MON	?AFSPACE	POP.32	D4	POP.32	D3	TEST.16	D7.ENDIF	DebugReset	RETDORESET:.IF	ModifJFG.if	TestDescValid	PUSH.32	A0.endif	TestDescValid.ENDIF	ModifJFG.IF	DebugRESET	PUSH.32	D3	PUSH.32	D4	MON	?AFTIM.ASCIZE	"DoReset "	MOVE.8	{A0}+ODHNum,D4	SUB.8	#NoBase,D4	MON	?AFX2	MON	?AFSPace	MON	?GetCar	POP.32	D4	POP.32	D3.ENDIF	DebugReset	PUSHM.32 D2|A2|A4|A5	PUSH.32	A0	MOVE.32	#R16^D0BASE,A0	CLR.32	D0	MOVE.32	_INDNTR,A1	CALL	{A1}+OIN_GETDRIVVAR ; A6 <-- ^variables de $DIS_0	POP.32	A0.IF	FullPage	MOVE.16	#ERDNTF,D7	; D7 <-- erreur	COMP.8	#NOBASE+3,{A0}+ODHNUM ; fentre $DIS_3 ?	JUMP,NE	 R8^L10$	; non => 10$	TEST.8	{A6}+OWDO23	; fentres $DIS_2 et $DIS_3 ensemble ?	JUMP,EQ L99$		; non => 99$L10$:	COMP.8	#NOBASE+5,{A0}+ODHNUM ; fentre $DIS_5 ?	JUMP,NE	 R8^L12$	; non => 12$	TEST.8	{A6}+OWDO45	; fentres $DIS_4 et $DIS_5 ensemble ?	JUMP,EQ L99$		; non => 99$L12$:.ENDIF	FullPage.IF	ModifJFG	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	MOVE.32	A2,A1		; A1 <-- ^paramtres	CALL	OPEDESC		; A2 <-- ^descripteur.if	false	JUMP,EQ	S100$mon	?aftim.ascize	"Err OpeDesc: "	TEST.16	D7S100$:.endif	False	JUMP,NE L95$.ELSE	MOVE.32	A2,A1		; A1 <-- ^paramtres	CALL	OPEDESC		; A2 <-- ^descripteur	JUMP,NE L99$	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique.ENDIF	ModifJFG	MOVE.16	#1,{A2}+ODFIIX.IF	Sm300	MOVE.16	VideoNInc+2,{A2}+ODFIIY.ELSE	Sm300	MOVE.16	#16'80,{A2}+ODFIIY.ENDIF	ELSE Sm300	CALL	DIMOK?		; dimensions fentre ok ?	TEST.16	D7.if	falseJUMP,EQ	S110$MON	?AFTIM.ASCIZE	"Err DIMOK?"TEST.16	D7S110$:.endif	false.if	ModifJfg	JUMP,NE	 L200$	; non => 90$.else	jump,ne	L90$.endif	MODIFJFG	CALL	OPEBITMAP	; A4 <-- ^bitmap.if	falseJUMP,EQ	S120$MON	?AFTIM.ASCIZE	"Err OPEBITMAP"TEST.16	D7S120$:.endif	false	JUMP,NE	 L90$	MOVE.32	A4,{A2}+ODFABS	MOVE.32	A4,{A2}+ODFCAB	COMP.8	#7,{A2}+ODFNOW	; fentre des soft-keys ?	JUMP,EQ	 R8^L30$	COMP.8	#8,{A2}+ODFNOW	; fentre du C.L.E. ?	JUMP,EQ	 R8^L30$	COMP.8	#9,{A2}+ODFNOW	; fentre du clock ?	JUMP,EQ	 R8^L30$	CALL	GCMXCARLOAD	; charge le module XCAR si ncessaire.if	falseTEST.16	D7JUMP,EQ	S130$MON	?AFTIM.ASCIZE	"Err GCMXCALOAD"TEST.16	D7S130$:.endif	falseL30$:	CLR.32	{A2}+ODFMAP+0	; clear compltement le map	CLR.32	{A2}+ODFMAP+4	CALL	GCLOAD		; charge le gnrateur standard	TEST.16	D7.if	falseJUMP,EQ	S140$MON	?AFTIM.ASCIZE	"GCLOAD"TEST.16	D7S140$:.endif	false	JUMP,NE	 L90$	CALL	GCUSE		; (A2)++ <-- paramtres	TEST.16	D7.if	falseJUMP,EQ	S150$MON	?AFTIM.ASCIZE	"Err GCUSE"TEST.16	D7S150$:.endif	false	JUMP,NE	 L90$	MOVE.32	{A2}+ODFC1Y,{A2}+ODFPY	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	CALL	IMACURS0	; enlve le curseur souris	CALL	EFFACE		; efface la nouvelle fentreL70$:	CALL	IMACURS1	; remet le curseur souris	CLR.16	D7		; D7 <-- okL90$:	TEST.16	D7		; ok ?	JUMP,EQ	 R8^L95$	; oui => 95$	PUSH.16	D7	CALL	CLOBITMAP	; libre le bitmap si ncessaire	POP.16	D7	CALL	CLODESC		; rend le descripteurL95$:	PUSH.16	D7	NTREL	?UNLOCK		; fin de zone critique	POP.16	D7L99$:	POPM.32	D2|A2|A4|A5	TEST.16	D7.IF	DebugReset	PUSH.32	D3	PUSH.32	D4	MON	?AFTIM.ASCIZE	" DoReset "	MOVE.8	{A0}+ODHNum,D4	MON	?AFX2	MON	?AFTIM.ASCIZE	" END, D7="	MOVE.16	D7,D4	MON	?AFX4	MON	?GetCar	MON	?AFSPACE	POP.32	D4	POP.32	D3	TEST.16	D7.ENDIF	DebugReset.if	ModifJfg.if	false	JUMP,eq	Ok$	PUSH.16	SF	MOVE.16	#16'2500, SF	MOVE.32	{SP}+2, A0	CLR.16	D0	MOVE.8	{A0}+oDHnum, D0	SUB.16	#Nobase, D0	test.32	{A6}+a16^{d0}*4	jump,eq	s10$	mon	?aftim	.ascize	"<CR>Doreset: "	EX.32	D0, D4	MON	?AFX2	EX.32	D0, D4	trap	#1s10$:	pop.16	sf	jump	jfgout$Ok$:	PUSH.16	SF	MOVE.16	#16'2500, SF	MOVE.32	{SP}+2, A0	CLR.16	D0	MOVE.8	{A0}+oDHnum, D0	SUB.16	#Nobase, D0	MOVE.32	{A6}+oBitMapDis, D1	TSET.32	D1:D0	MOVE.32	D1, {A6}+oBitMapDis	POP.16	SF;	jump	jfgOut$jfgOut$:	POP.32	A0	TEST.16	D7.endif	false.ENDIF	ModifJFG	RETL200$:	CALL	CLODESC	JUMP	L95$;--------\; KILL    >;========/; in	A0.L	^base du driver; out	-; mod	D0..A1DOKILL:.IF	ModifJFG.if	TestDescValid	PUSH.32	A0.endif	TestDescValid.ENDIF	ModifJFG	_DebugN	DoKill	PUSHM.32 D2|D3|A2|A5|A6.IF	ModifJFG	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	CALL	SRCDESC		; A2 <-- ^descripteur fentre.ELSE	CALL	SRCDESC		; A2 <-- ^descripteur fentre	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique.ENDIF	ModifJFG	CALL	IMACURS0	; enlve curseur souris	CALL	CLRCURS		; enlve le curseur.IF	Sm324.OR.Cos21.IF	FullPage	CALL	GRISE		; grise la fentre !!!.ELSE	FullPage	CALL	EFFACE		; efface la fentre.ENDIF	ELSE FullPage.ELSE	Sm324.OR.Cos21	CALL	EFFACE		; efface la fentre.ENDIF	ELSE Sm324.OR.Cos21	MOVE.8	#NOCURS,D3	CALL	AFCAR		; supprime un ventuel curseur	TEST.8	{A2}+ODFFLG:#BFIMAA ; image existe ?	JUMP,BC	 R8^L50$	; non => 50$	CALL	KILIMA		; oui => libre mmoireL50$:	CALL	WDOGET		; libre zone sauvetage fentre	CALL	CLOBITMAP	; libre le bitmap si ncessaire	CALL	GCRESET		; supprime gencar(s) utilis(s)	CALL	SETCURS		; remet le curseur (!)	CALL	CLODESC		; libre le descripteur	CALL	IMACURS1	; remet curseur souris	NTREL	?UNLOCK		; fin de zone critique	POPM.32	D2|D3|A2|A5|A6.IF	ModifJFG.if	TestDescValid	PUSH.16	SF	MOVE.16	#16'2500, SF	MOVE.32	{SP}+2, A0	CLR.16	D0	MOVE.8	{A0}+oDHnum, D0	SUB.16	#Nobase, D0	MOVE.32	{A6}+oBitMapDis, D1	TCLR.32	D1:D0	MOVE.32	D1, {A6}+oBitMapDis	POP.16	SF	POP.32	A0.endif	TestDescValid.ENDIF	ModifJFG	RET;--------\; COMMAND >;========/; in	A0.L	base du driver;	A4.32	^table des commandes termine par zro; out	D7.W	erreur; mod	D0..A1, D7.WDOCOMMAND:	TestDesc DoCommand	_DebugN	DoCommand	PUSHM.32 A2|A4|A5|A6.IF	ModifJFG	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	SRCDESC		; A2 <-- ^description fentre	CALL	LOCK		; dbut de zone critique.ELSE	CALL	SRCDESC		; A2 <-- ^description fentre	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique.ENDIF	ModifJFG	CALL	IMACURS0	; enlve curseur souris	CLR.16	D7		; D7 <-- okL10$:	TEST.8	{A4}		; fin de la table ?	JUMP,EQ	 R8^L80$	; oui => 80$	CALL	WRONEC		; excute une commande	TEST.16	D7		; commande ok ?	JUMP,NE	 R8^L80$	; non => 80$	JUMP	L10$L80$:	PUSH.16	D7	CALL	IMACURS1	; remet curseur souris	NTREL	?UNLOCK		; fin de zone critique	POP.16	D7	POPM.32	A2|A4|A5|A6	TEST.16	D7.IF	Debug	JUMP,NE	OpKO$	_DebugX2 DoCommandOK,{A2}+ODFNoW	JUMP	RealExit$OpKO$:	_DebugX2 DoCommandKO,{A2}+ODFNowRealExit$:	TEST.16	D7.ENDIF	Debug	RET;--------\; RSTATUS >;========/; in	A0.L	^base du driver;	A4.32	^buffer;	D4.32	longueur buffer; out	D4.L	longueur rendue effectivement;	D7.16	erreur; mod	D0..A1, D4.L, D7.WDORSTATUS:	TestDesc DoRStatus	_DebugN	DoRStatus	PUSHM.32 A2|A5|A6.IF	ModifJFG	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	CALL	SRCDESC		; A2 <-- ^description fentre.ELSE	CALL	SRCDESC		; A2 <-- ^description fentre	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique.ENDIF	ModifJFG	MOVE.32	A2,{A2}+ODFPST	; met le ^au status rel	COMP.16	#4,D4		; profondeur = 4 ?	JUMP,NE	 R8^L10$	; non => 10$				; oui =>	MOVE.32	A2,{A4}		; rend juste le ^au status rel !	CLR.16	D7		; D7 <-- ok	JUMP	L90$L10$:.IF	.NOT.SM300	MOVE.8	{A6}+OTAVDC+REGHOR1,{A2}+ODFCAH	MOVE.8	{A6}+OTAVDC+REGVERT,{A2}+ODFCAV.ENDIF	.NOT.SM300	MOVE.32	#R16^L00$,A0	CALL	32^_CNVLGS	JUMP,NE	 R8^L90$	MOVE.32	A4,A0		; A0 <-- ^buffer utilisateur	MOVE.16	D4,D0L20$:	MOVE.8	{A2+},{A0+}	; transfre chez l'utilisateur	DEC.16	D0	JUMP,NE L20$L90$:	PUSH.16	D7	NTREL	?UNLOCK		; fin de zone critique	POP.16	D7	POPM.32	A2|A5|A6	RETL00$:				; table pour CNVLGS :	.16	LGDIS0	.16	LGDIS1	.16	LGDIS2	.16	LGDIS3	.16	LGDIS4	.16	LGDIS5	.16	LGDIS6	.16	LGDIS7	.16	LGDIS8	.16	0;--------\; WRITE   >;========/; in	A0.L	^base du driver;	A4.32	^buffer texte;	D5.32	lg maximale du texte; out	D5.L	lg effectivement crite;	D7.16	erreur; mod	D7.W, D5.LDOWRITE:	PUSHM.32 D3|D4|D6|A2|A4|A5|A6.IF	ModifJFG	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	TestDesc DoWrite	CALL	SRCDESC		; A2 <-- ^description fentre.ELSE	CALL	SRCDESC		; A2 <-- ^description fentre	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique.ENDIF	ModifJFG	CALL	CLRCURS		; enlve le curseur	CLR.16	D6		; D6 <-- mm dernire erreur	MOVE.32	D5,D4		; D4 <-- nb caractres  crireL10$:	MOVE.8	{A4+},D3	; D3 <-- caractre  afficher	DEC.32	D4	CALL	AFCAR		; "affiche" un caractre	TEST.16	D7		; erreur lors du AFCAR ?	JUMP,EQ	 R8^L50$	; non => 50$	JUMP,NS	 R8^L40$	; si erreur grave => 40$	TEST.16	D6		; dj mm. erreur grave ?	JUMP,NS	 R8^L50$	; oui => 50$L40$:	MOVE.16	D7,D6		; D6 <-- dernire erreurL50$:	TEST.32	D4	JUMP,NE L10$	SUB.32	D4,D5		; D5 <-- nb caractres crits	CALL	SETCURS		; remet le curseur	NTREL	?UNLOCK		; fin de zone critique	MOVE.16	D6,D7		; D7 <-- dernire erreurL90$:	POPM.32	D3|D4|D6|A2|A4|A5|A6	RET;--------\; READ    >;========/; in	A0.L	^base du driver;	A4.32	^buffer texte;	D5.32	lg  lire;		2^31=1	--> nb points horizontaux (de gauche  droite);		2^30=1	--> nb points verticaux (de bas en haut); out	D5.L	lg effectivement lue;	D7.16	erreur; mod	D7.W, D5.LDOREAD:	TestDesc DoRead	_DebugN DoRead	PUSHM.32 D2|D3|D4|A2..A6.IF	ModifJFG	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique	CALL	SRCDESC		; A2 <-- ^description fentre.ELSE	CALL	SRCDESC		; A2 <-- ^description fentre	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	CALL	LOCK		; dbut de zone critique.ENDIF	ModifJFG	TEST.32	D5:#31		; lecture graphique horizontale ?	JUMP,BS L40$		; oui => 40$	TEST.32	D5:#30		; lecture graphique verticale ?	JUMP,BS L40$		; oui => 40$				; non =>	MOVE.16	D5,D4		; D4 <-- lg  lire	CLR.32	D5		; D5 <-- rien d'encore lu	MOVE.16	#ERRDPR,D7	; D7 <-- read protected driver	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE L90$		; non => 90$ (erreur)	MOVE.32	A4,A5		; A5 <-- ^o mettre les cars.	CALL	GPTIMA		; A4 <-- ^dans image	JUMP,NE L90$		; si hors => 90$	MOVE.32	{A2}+ODFPIM,A3	; A3 <-- ^base de l'image	MOVE.16	{A3}+OIMADX,D3	MUL.16	{A3}+OIMADY,D3	; D3 <-- lg utile de l'image	ADD.32	#LGIMA,D3	; D3 <-- ajoute les frais fixes	ADD.32	D3,A3		; A3 <-- ^max  ne pas dpasser	MOVE.16	#EROUTF,D7	; D7 <-- erreur si dpassementL20$:	COMP.32	A3,A4		; image dpasse ?	JUMP,HS L90$		; oui => 90$	MOVE.8	{A4+},{A5+}	; buffer lecture <- image alpha	INC.32	D5		; D5 <-- un car. lu de plus	DEC.16	D4		; encore qq chose  lire ?	JUMP,NE L20$		; oui => 20$				; non =>	CLR.16	D7		; D7 <-- ok	JUMP	L90$L40$:				; lecture graphique h/v =>	MOVE.16	D5,D0		; D0 <-- lg  lire (points)	MOVE.16	{A2}+ODFPGX,D3	ADD.16	{A2}+ODFWBX,D3	; D3 <-- coordonne X absolue	MOVE.8	D3,D2	MOVE.16	{A2}+ODFPGY,D4	ADD.16	{A2}+ODFWBY,D4	; D3 <-- coordonne Y absolue	MOVE.32	{A2}+ODFABS,A3	; A3 <-- adresse dbut cran	AND.32	#1024-1,D3	; masque coordonne	SR.32	#3,D3	ADD.32	D3,A3		; A3 <-- ajoute offset X	AND.32	#1024-1,D4	; masque coordonne	SL.32	#7,D4	ADD.32	D4,A3		; A3 <-- ajoute offset Y	TEST.32	D5:#30		; lecture verticale ?	JUMP,BS L60$		; oui => 60$; Lit une ligne graphique horizontale allant de gauche  droite.	SR.16	#3,D0		; D0 <-- nb bytes  lire	DEC.16	D0		; -1  cause du test NMOL45$:	MOVE.8	{A3+},{A4+}	; user <-- un byte graphique	DJ.16,NMO  D0,L45$	JUMP	L80$; Lit une ligne graphique verticale allant de bas en haut.L60$:	AND.8	#2'111,D2	; D2 <-- 0..7	INC.8	D2		; D2 <-- dcalage colonne (1..8)L62$:	MOVE.16	#8-1,D1		; -1  cause du test NMO	COMP.16	#8,D0		; reste au moins 8 ?	JUMP,HS	 R8^L65$	; oui => 65$	MOVE.16	D0,D1		; D1 <-- lg du reste	DEC.16	D1		; -1  cause du test NMOL65$:	MOVE.8	{A3},D3		; D3 <-- byte de l'cran	MOVE.32	#{A3}-16'80,A3	; A3 <-- ^plus haut dans l'cran	RLX.8	D2,D3		; "X" <-- un point	RLX.8	#1,D4		; D4 <-- met le point dans "X"	DJ.16,NMO  D1,L65$	SUB.16	#8,D0		; D0 <-- 8 points lus	JUMP,LS	 R8^L67$	MOVE.8	D4,{A4+}	; buffer read <-- un byte	JUMP	L62$L67$:	NEG.16	D0	SL.8	D0,D4		; D4 <-- met qq zro (0..7)	MOVE.8	D4,{A4}		; buffer read <-- dernier byteL80$:	CLR.16	D7		; D7 <-- okL90$:	PUSH.16	D7	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore	NTREL	?UNLOCK		; fin de zone critique	POP.16	D7	POPM.32	D2|D3|D4|A2..A6	RET;--------\; DIMOK?  >;========/; Vrifie si les dimensions d'une fentre sont comprises; entre les bornes donnes par l'utilisateur en (A1).; Rend dans D0-D1-D2 le gnrateur de caractres  utiliser.; Si la fonte est "?" "*" ou "-", rend le gnrateur NEF11 ou; NRF09 selon la largeur de la fentre.; in	A1.L	^paramtres;	A2.32	^description fentre; out	D0.B	fonte;	D1.32	style;	D2.8	taille;	D7.16	erreur; mod	D0.B, D1.L, D2.B, D7.WDIMOK?:;	_DebugN DimOK?	PUSH.32	D3	CLR.8	D0		; D0 <-- fonte par dfaut	CLR.32	D1		; D1 <-- style par dfaut	CLR.8	D2		; D2 <-- taille par dfaut	MOVE.32	A1,D3		; A1 = zro ?	JUMP,EQ L80$		; oui => 80$ (dimensions ok)				; non =>	COMP.32	#16'00FFFFFF,{A1}; paramtres valides ?	JUMP,EQ L80$		; non => 80$ (dimensions ok)				; oui =>	MOVE.8	{A1}+OIDGCF,D0	; D0 <-- fonte	MOVE.8	{A1}+OIDGCS,D1	; D1 <-- style	MOVE.8	{A1}+OIDGCT,D2	; D2 <-- taille	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFDY,D3	; D3 <-- hauteur fentre	COMP.16	{A1}+OIDYMIN,D3	; trop petit ?	JUMP,LO	 R8^L90$	; oui => 90$	COMP.16	{A1}+OIDYMAX,D3	; trop grand ?	JUMP,HI	 R8^L90$	; oui => 90$	MOVE.16	{A2}+ODFDX,D3	; D3 <-- largeur fentre	COMP.16	{A1}+OIDXMIN,D3	; trop petit ?	JUMP,LO	 R8^L90$	; oui => 90$	COMP.16	{A1}+OIDXMAX,D3	; trop grand ?	JUMP,HI	 R8^L90$	; oui => 90$	TEST.8	D0	JUMP,EQ	 R8^L40$	COMP.8	#"*",D0		; fonte = "*"  ?	JUMP,EQ	 R8^L40$	COMP.8	#"?",D0		; fonte = "?"  ?	JUMP,EQ	 R8^L40$	COMP.8	#"-",D0		; fonte = "-"  ?	JUMP,NE	 R8^L80$L40$:.IF	FullPage	MOVE.8	#"N",D0	MOVE.8	#"E".OR.2**7,D1	MOVE.8	#DEFTAILLE,D2	; NEF11 par dfaut.ELSE	FullPage	MOVE.8	#"N",D0	MOVE.8	#"R".OR.2**7,D1	MOVE.8	#DEFTAILLE,D2	; NRF09 par dfaut.ENDIF	ELSE FullPage.IF	SM8	COMP.16	#500,D3		; "grande" fentre ?	JUMP,HS	 R8^L80$	; oui => 80$				; non =>;	MOVE.8	#"N",D0	MOVE.8	#"R".OR.2**7,D1	MOVE.8	#07,D2		; NRF07 par dfaut.ENDIF	SM8L80$:	CLR.16	D7		; D7 <-- okL90$:	POP.32	D3	TEST.16	D7	RET;--------\\; LOCK    >;========/; Dbut de zone critique pour l'cran.; in	A5.L	^smaphore; out	-; mod	D7.WLOCK:	_DebugN Lock	PUSH.32	D4	NTREL	?LOCK		; dbut de zone critique	JUMP,EQ	 R8^L90$	; ok => 90$	COMP.16	#ERTIMO,D7	; timeout ?	JUMP,NE	 R8^L90$	; non => 90$				; oui =>	MOVE.16	#-1,D4	NTREL	?MODTIM		; met timeout infini	NTREL	?LOCK		; dbut de zone critique	NTREL	?SETTIM		; remet timeout utilisateurL90$:	POP.32	D4	_DebugN endLock	RET; Gestion des variables pour les descripteurs de chaque driver; ------------------------------------------------------------;--------\; OPEDESC >;========/; Prend et initialise les variables pour le descripteur de; la fentre.; in	A0	^base du driver; out	A2	^descripteur;	D7.16	erreur; mod	D7.16, A2 FOPEDESC:	_DebugX2 OpeDesc, {A0}+ODHNum	PUSHM.32 D1|D4|A1|A4	MOVE.32	#LGDFEN,D4	; D4 <-- longueur totale	MOVE.32	#MTYPBD,D1	; D1 <-- type driver bios	MOVE.32	A0,A1		; A1 <-- ^base du driver	GESMEM	?GETMEM		; demande mmoire pour descripteur	JUMP,NE	 R8^L90$	GESMEM	?CLEARMEM	MOVE.32	A4,A2		; A2 <-- ^descripteur	MOVE.32	#{A6}+OPDFEN,A4	CLR.16	D4	MOVE.8	{A0}+ODHNUM,D4	; D4 <-- numro du driver	SUB.16	#NOBASE,D4	; D4 <-- 0..n.IF	CPU020	MOVE.32	A2,{A4}+A16^{D4}*4.ELSE	CPU020	SL.16	#2,D4		; *4 car .L	MOVE.32	A2,{A4}+A16^{D4}; mm. ^descripteur.ENDIF	ELSE CPU020	MOVE.32	A0,{A2}+ODFBAS	; mm. ^base du driver	MOVE.32	A4,{A2}+ODFPDE	; mm. ^^descripteurs	CALL	INIDESC		; init le reste du descripteur	CALL	COLDESC		; init la couleur dans le descripteur	JUMP,EQ	 R8^L90$	; ok => 90$				; erreur =>	PUSH.16	D7	MOVE.32	A2,A4		; A4 <-- ^descripteur;	MOVE.32	#MTYPBD,D1	; D1 <-- type driver bios;	MOVE.32	A0,A1		; A1 <-- ^base du driver	GESMEM	?GIVMEM		; rend mmoire pour descripteur.if	ModifJfg	.IF	CPU020	CLR.32	{A4}+A16^{D4}*4.ELSE	CPU020	CLR.32	{A4}+A16^{D4}; mm. ^descripteur.ENDIF	ELSE CPU020.endif	ModifJfg	POP.16	D7L90$:	POPM.32	D1|D4|A1|A4	TEST.16	D7		; retour EQ/NE	RET;--------\\; INIDESC >;--------/; Initialise le descripteur d'une fentre.; in	A2.L	^descripteur; out	-; mod	D7.WINIDESC:	_DebugX2 IniDesc,{A0}+ODHNum	PUSHM.32 D4|A1	MOVE.32	{A2}+ODFBAS,A1			; A1 <-- ^base du driver	MOVE.32	{A1+},{A2}+ODFY	MOVE.32	{A1+},{A2}+ODFDY	MOVE.16	{A1+},{A2}+ODFCAD	MOVE.8	{A1+},{A2}+ODFNOW	MOVE.8	{A1+},{A2}+ODFMOD	MOVE.8	{A1+},{A2}+ODFMCA	MOVE.8	#GRACLIP,{A2}+ODFMGR.IF	SM300	COMP.8	#7,{A2}+ODFNow			; Pour le CLE, les touches	JUMP,LO	R8^Modulo$			; fonctions et l'horloge, on	COMP.8	#9,{A2}+ODFNow			; force un modulo 1.	JUMP,HI	R8^Modulo$	TSET.8	{A2}+ODFFL2:#BFNoModModulo$:	TEST.16	VideoSamInit+2			; cran cal  gauche ?	JUMP,EQ	 R8^L15$			; oui => 15$						; non =>	MOVE.16	#1024-PVIEWX+2,D4	COMP.8	#7,{A2}+ODFNOW	JUMP,EQ	 R8^L14$	COMP.8	#8,{A2}+ODFNOW	JUMP,EQ	 R8^L14$	MOVE.16	#1024-PVIEWX+SEPX89+2,D4	COMP.8	#9,{A2}+ODFNOW	JUMP,NE	 R8^L15$L14$:	MOVE.16	D4,{A2}+ODFX			; cadre la fentre  droiteL15$:.ELSE	SM300.IF	FullPage	COMP.8	#2,{A2}+ODFNOW	JUMP,NE	 R8^L20$	TEST.8	{A6}+OWDO23	; fentre $DIS_2 et $DIS_3 ensemble ?	JUMP,EQ	 R8^L20$	MOVE.16	#(DBIGY-10)/2,{A2}+ODFDYL20$:	COMP.8	#4,{A2}+ODFNOW	JUMP,NE	 R8^L30$	TEST.8	{A6}+OWDO45	; fentre $DIS_4 et $DIS_5 ensemble ?	JUMP,EQ	 R8^L30$	MOVE.16	#(DBIGY-10)/2,{A2}+ODFDYL30$:	COMP.8	#8,{A2}+ODFNOW	JUMP,EQ	 R8^L14$	COMP.8	#9,{A2}+ODFNOW	JUMP,NE	 R8^L15$L14$:	MOVE.16	#0,{A2}+ODFIY			; souris valable jusque tout en hautL15$:.ELSE	FullPage	TEST.8	{A6}+OTAVDC+REGPOX		; cran cal  gauche ?	JUMP,EQ	 R8^L15$			; oui => 15$						; non =>	MOVE.16	#1024-PVIEWX,D4	COMP.8	#7,{A2}+ODFNOW	JUMP,EQ	 R8^L14$	COMP.8	#8,{A2}+ODFNOW	JUMP,EQ	 R8^L14$	MOVE.16	#1024-PVIEWX+SEPX89,D4	COMP.8	#9,{A2}+ODFNOW	JUMP,NE	 R8^L15$L14$:	MOVE.16	D4,{A2}+ODFX			; cadre la fentre  droiteL15$:.ENDIF	ELSE FullPage.ENDIF	ELSE Sm300	MOVE.32	{A2}+ODFY,{A2}+ODFIY		; copie rfrence (pour MOUSE)	MOVE.32	{A2}+ODFDY,{A2}+ODFIDY	MOVE.8	#2'11111111,{A2}+ODFTTM	MOVE.8	#1,{A2}+ODFTTS	MOVE.8	#2**BFWMOU,{A2}+ODFFLG.IF	FONDBLANC	TSET.8	{A2}+ODFMOD:#BFBLANC.ENDIF	FONDBLANC	MOVE.32	#R16^TASOFTKEY,A1	MOVE.32	A1,{A2}+ODFPSK	; mm. ^table pour soft-keys	POPM.32	D4|A1	RET.IF	Sm300;----------\\; LoadGlob  >;----------/; Teste si les fichiers %M_SYSTEM.CRET et/ou %M_SYSTEM.CLUT ont pu tre; chargs correctement. Sinon, on essaye une n-ime fois...; In:	A6 ^variables globales des pilotes crans;	A2 ^descripteur de la fentre (n'importe lequel, en gros); Out:	D7.16 erreur; Mod:	D7.16 FLoadGlob:	PUSHM.32 A0|A3|D3|D5|D6	CLR.16	D7	MOVE.32	{A6}+OPDFen+0,A0	; A0 ^descripteur de $DIS_0	TEST.8	{A6}+OGlobCRET		; CRET globale charge ?	JUMP,T	CLUT?$	MOVE.32	{A0}+ODFCPF,D6		; D6.32 <- canal de TColor pour $DIS_0	MOVE.32	#R16^SysCretName,A3	; On charge une CRET (palette) globale	MOVE.32	#2**BTCName.OR.2**BTCGlob,D3;;?	TCol_	LoadCRET	TCol_	LoadCRE	JUMP,NC	DiskLoadOK$		; La CRET est bonne, elle vient du disque	TEST.32	{A0}+ODFCPR		; CRET de secours dj charge ?	JUMP,NE	CLUT?$			; Oui => on essaye la CLUT	MOVE.32	#R16^ROMCRET,A3		; On charge une CRET globale de secours	MOVE.32	#2**BTCTable,D3;;?	TCol_	LoadCRET	TCol_	LoadCRE	JUMP,NS	Exit$			; Erreur fatale !	MOVE.32	#2**BTCGlob,D3		; On ajoute cette CRET  la liste globale	TCol_	AddCRET	JUMP,EQ	AddOk$	PUSH.16	D7	MOVE.32	#0,D3			; On n'a pas pu l'ajouter, a c'est;;?	TCol_	KillCRET		; grave...	TCol_	KillCRE			; grave...	POP.16	D7	JUMP	Exit$DiskLoadOK$:	MOVE.32	D5,D0			; D0.32 <- id de la CRET charge du disque	MOVE.32	{A0}+ODFCPR,D5		; D5.32 <- CRET en ROM, on la dtruit	JUMP,EQ	NoROMCRET$	MOVE.32	#2**BTCGlob,D3		; On enlve cette CRET de la liste	TCol_	SubCRET	JUMP,NS	Exit$	MOVE.32	#0,D3;;?	TCol_	KillCRET	TCol_	KillCRE	JUMP,NS	Exit$NoROMCRET$:	SET.8	{A6}+OGlobCRET	MOVE.32	D0,D5			; D5.32 <- id de la CRET charge de la ROM	MOVE.32	#2**BTCGlob,D3		; On ajoute cette CRET  la liste globale	TCol_	AddCRET	JUMP,EQ	AddOk$	CLR.8	{A6}+OGlobCRET		; Erreur fatale !!!	PUSH.16	D7	MOVE.32	#0,D3			; On n'a pas pu l'ajouter, a c'est;;?	TCol_	KillCRET		; grave...	TCol_	KillCRE			; grave...	POP.16	D7	JUMP	Exit$AddOk$:	MOVE.32	D5,{A0}+ODFCPR		; On mmorise dans {$DIS_0}+ODFCPRCLUT?$:.IF	SeparateCLUT	TEST.8	{A6}+OGlobCLUT		; CLUT globale dj charge ?	JUMP,T	Exit$	MOVE.32	{A0}+ODFCPF,D6		; D6.32 <- canal de TColor pour $DIS_0	MOVE.32	#R16^SysCLUTName,A3	; On charge une CLUT globale	MOVE.32	#2**BTCName.OR.2**BTCGlob,D3	TCol_	LoadCLUT	JUMP,EQ	ClutOk$	CLR.16	D7			; On ignore cette erreur	JUMP	Exit$ClutOk$:	SET.8	{A6}+OGlobCLUT		; On a charg la CLUT globale !!!.ELSE	SeparateCLUT	CLR.16	D7			; Ignore l'erreur ventuelle.ENDIF	ELSE SeparateCLUTExit$:	POPM.32	A0|A3|D3|D5|D6	TEST.16	D7	RET.ENDIF	Sm300;--------\\; COLDESC >;--------/; Initialise le descripteur d'une fentre en fonction de la couleur.; in	A0	^base du driver;	A2	^descripteur; out	D7.16	erreur; mod	D7.16 FCOLDESC:	_DebugN ColDesc	PUSHM.32 A1|A3|A4|D1|D2|D3|D4|D6.IF	Sm300	CLR.8	{A2}+ODFCMD		; Pas encore en couleur...	MOVE.32	VideoNInc,D4	MOVE.16	D4,{A2}+ODFIIY		; Initialise le descripteur	COMP.16	#512,D4			; Mode couleur [berke] ?	JUMP,LO	BlackWhiteScreen$	; Non => on est en N/B	MOVE.16	#16,{A2}+ODFCNB		; 16 couleurs	MOVE.32	#4,D4			; Machine  4 bits/pixel	MOVE.8	D4,{A2}+ODFCNP	MOVE.8	#1,{A2}+ODFCMD		; Mode couleur	MOVE.16	#10,D4			; D4 <-- nb max de PUSHs	MOVE.16	D4,{A2}+ODFCMS		; ODFCMS <-- nb max de PUSHs	MUL.16	#4*2,D4			; D4 <-- longueur totale	MOVE.32	#MTYPBD,D1		; D1 <-- type driver bios	MOVE.32	A0,A1			; A1 <-- ^base du driver	GESMEM	?GETMEM			; demande mmoire pour stack des couleurs	JUMP,NS	L90$	MOVE.32	A4,{A2}+ODFCPS		; ODFCPS <-- ^stack	CLR.32	{A2}+ODFCPF		; Pas de canal pour le moment	MOVE.32	#0,D3			; Mode pour le moment nul	TCol_	Open			; On ouvre notre instance du module.	JUMP,NS	L90$			; Erreur fatale... .if	DebugActive	pushm.32	d3|d4	mon	?aftim	.ascize	"<CR>Tcol_ OPEN: "	MOVE.32	D6, D4	MON	?AFX8, ?GETCAR	POPM.32		D3|D4.ENDIF	DebugActive.IF	DebugTColor	TEST.8	{A2}+ODFNow	JUMP,NE	Not0$	PUSH.32	D4	MON	?AFTIM.ASCIZE	"chan $DIS_0="	MOVE.32	D6,D4	MON	?AFX8	POP.32	D4	PUSH.32	D3	MON	?GETCAR	POP.32	D3Not0$:.ENDIF	DebugTColor	MOVE.32	D6,{A2}+ODFCPF		; On mmorise le canal de TColor	TEST.8	{A2}+ODFNoW		; Fentre zro ?	JUMP,NE	NotFirst$		; Non => pas de chargement de la CLUT.	MOVE.32	#2**BTCTable.OR.2**BTCGlob,D3	; On prend la CLUT de secours	MOVE.32	#R16^ROMCLUT,A3;;?	TCol_	LoadCLUT	TCol_	LoadCLU.if	false	JUMP,EQ	NotFirst$	mon	?aftim	.ascize	"Err LoadCLUT "	TRAP	#1	JUMP	L90$.else	JUMP,NS	L90$.endif	falseNotFirst$:	CALL	LoadGlob		; On rssaie de charger %M_SYSTEM.CRET.IF	false	JUMP,EQ	jfg1$	MON	?AFTIM	.ASCIZE	"<CR>Err LoadGlob: "	JUMP	L90$jfg1$:.ELSE	JUMP,NE	L90$.ENDIF	false	MOVE.32	#COLOR_PPSET,{A2}+ODFCOM	CALL	DOCOSR	JUMP,EQ	R8^PPSETOk$	MOVE.32	#-1,{A2}+ODFCSF		; Color_PPSET n'existe pas	CLR.16	D7PPSetOK$:;;?	MOVE.32	#COLOR_PPCLEAR,{A2}+ODFCOM	MOVE.32	#COLOR_PPCLEA,{A2}+ODFCOM	CALL	DOCOCR	JUMP,EQ	R8^PPCLEAROk$	MOVE.32	#0,{A2}+ODFCCF		; Color_PPCLEAR n'existe pas	CLR.16	D7PPClearOK$:	CALL	ActiveOne		; On active cette fentre	JUMP	L90$			; Nous avons fini...BlackWhiteScreen$:.ENDIF	Sm300L85$:	MOVE.16	#2,{A2}+ODFCNB	; ODFCNB <-- 2 niveaux de gris	MOVE.8	#1,{A2}+ODFCNP	; ODFCNP <-- 1 seul plan	CLR.8	{A2}+ODFCMD	; ODFCMD <-- mode noir et blanc (monochrome)	CLR.32	{A2}+ODFCCF	; Initialise les couleurs par dfaut.	MOVE.32	#-1,{A2}+ODFCSF	CLR.16	D7		; D7 <-- okL90$:	POPM.32	A1|A3|A4|D1|D2|D3|D4|D6	TEST.16	D7		; retour EQ/NE	RET;--------\; SRCDESC >;========/; Cherche les variables pour le descripteur de la fentre.; in	A0.L	^base du driver; out	A2.L	^descripteur; mod	A2.LSRCDESC:	_DebugN SrcDesc	PUSH.16	D2	MOVE.32	#{A6}+OPDFEN,A2	CLR.16	D2	MOVE.8	{A0}+ODHNUM,D2	; D2 <-- numro du driver	SUB.16	#NOBASE,D2	; D2 <-- 0..n.IF	CPU020	MOVE.32	{A2}+A16^{D2}*4,A2.ELSE	CPU020	SL.16	#2,D2		; *4 car .L	MOVE.32	{A2}+A16^{D2},A2; A2 <-- ^descripteur.ENDIF	ELSE CPU020	POP.16	D2	RET;--------\; IFDESC  >;========/; Cherche si les variables pour le descripteur de la fentre; existent.; in	D0.W	numro de la fentre (0..n); out	NE	descripteur existe;	EQ	descripteur n'existe pas; mod	-IFDESC:	_DebugN IfDesc	PUSH.32	A2	CALL	GETDESC	POP.32	A2	RET;--------\; GETDESC >;========/; Cherche les variables pour le descripteur de la fentre.; in	D0.W	numro de la fentre (0..n); out	NE	descripteur existe;	 A2.32	 ^descripteur;	EQ	descripteur n'existe pas; mod	A2.LGETDESC:	_DebugN GetDesc	PUSH.32	D0	MOVE.32	#{A6}+OPDFEN,A2.IF	CPU020	MOVE.32 {A2}+A16^{D0}*4,D0.ELSE	CPU020	SL.16	#2,D0		; *4 car .L	MOVE.32	{A2}+A16^{D0},D0; D0 <-- ^descripteur.ENDIF	ELSE CPU020	JUMP,EQ	 R8^L90$	MOVE.32	D0,A2		; A2 <-- ^descripteurL90$:	POPM.32	D0	RET;--------\; CLODESC >;========/; Rend les variables pour le descripteur de la fentre.; in	A2.L	^descripteur; out	-; mod	-CLODESC:	PUSHM.32 D1|D7|A1|A4|D6	MOVE.32	#MTYPBD,D1	; D1 <-- type driver bios	MOVE.32	{A2}+ODFBAS,A1	; A1 <-- ^base du driver.IF	Sm300	TEST.32	{A2}+ODFCPS	JUMP,EQ	 R8^L20$	MOVE.32	{A2}+ODFCPS,A4	; A4 <-- ^zone mmoire	GESMEM	?GIVMEM		; rend la mmoire pour stack des couleurs	CLR.32	{A2}+ODFCPSL20$:	MOVE.32	{A2}+ODFCPF,D6	; D6.32 <- canal TColor	JUMP,EQ	R8^noTColor$.if	DEBUGACTIVEPUSHM.32	D4|D3MON	?AFTIM.ASCIZE	"<cr>TCOL CLOSE: "MOVE.32	D6, D4MON	?AFX8, ?GETCARPOPM.32	D3|D4.endif	DEBUGACTIVE	TCol_	Close	clr.32	{a2}+odfcpf	; ++jfg++noTColor$:	MOVE.32	{A6}+OPDFEN+0,A4; Ractive $DIS_0 (?)	EX.32	A2,A4	CALL	ActiveOne	EX.32	A2,A4.ENDIF	Sm300	MOVE.32	#{A6}+OPDFEN,A4	CLR.16	D1	MOVE.8	{A1}+ODHNUM,D1	; D1 <-- numro du driver	SUB.16	#NOBASE,D1	; D1 <-- 0..n.if	falsemon	?aftim.ascize	"<CR>No descripteur dans d1: "trap	#1.endif	false.IF	CPU020	CLR.32	{A4}+A16^{D1}*4.ELSE	CPU020	SL.16	#2,D1		; *4 car .L	CLR.32	{A4}+A16^{D1}	; ^descripteur = ^nil.ENDIF	ELSE CPU020	MOVE.32	#MTYPBD,D1	; D1 <-- type driver bios	MOVE.32	A2,A4		; A4 <-- ^zone mmoire	GESMEM	?GIVMEM		; rend mmoire pour descripteur	POPM.32	D1|D7|A1|A4|D6	RET; Initialisation gnrale de $DIS_0; ---------------------------------;--------\; IDIS    >;========/; Met les traits de sparations entre les fentres.; in	D1.16	numro du bitmap (0..3); out	-; mod	D7.16IDIS:	_DebugN IDIS	PUSHM.32 D0|D3|D4|A1|A2	MOVE.32	{A6}+OPDFEN+(4*0),A2 ; A2 <-- ^desc. cran complet.IF	SM100.OR.SM196.OR.SM300	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#SEPY81,D4	; D4 <-- Y	MOVE.16	#1024,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS8,9.IF	Sm300	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#SEPY17,D4	; D4 <-- Y	MOVE.16	#1024,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS_1.ENDIF	Sm300.IF	Sm300	MOVE.16	#PVIEWX+4,D3	MOVE.16	#SepY81,D4	MOVE.16	#SepY17-SepY81,D0	CALL	SEGVERT		; droite entre $DIS1 et $DIS 10/11.ELSE	Sm300	MOVE.16	#PVIEWX+4,D3	MOVE.16	#PVIEWY-(LARGCY/2)-(LARGCY*5),D0	CALL	SEGVERT		; droite entre $DIS1 et $DIS 10/11.ENDIF	ELSE Sm300.if	sm300	move.16	#SepY81+211, d4.else	MOVE.16	#LARGCY*2+170,D4.endif	sm300	MOVE.16	#1024-(PVIEWX+4),D0	CALL	SEGHOR		; droite entre $DIS10 et $DIS11.IF	Sm300	CALL	Coins		; Arrondit les bords....ENDIF	Sm300.ELSE	SM100.OR.SM196.OR.SM300.IF	SM8	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#SEPY81,D4	; D4 <-- Y	MOVE.16	#1024-8,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS8,9,10	MOVE.16	#800-4,D3	MOVE.16	#32+160+8,D4	MOVE.16	#1024-(800-4)-8,D0	CALL	SEGHOR		; droite entre $DIS2 et 3	MOVE.16	#32+160+16+112+8,D4	CALL	SEGHOR		; droite entre $DIS3 et 4	MOVE.16	#800-4,D3	MOVE.16	#SEPY81,D4	MOVE.16	#8+160+16+112+16+112,D0	CALL	SEGVERT		; droite entre $DIS1 et 2,3,4	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#512+SEPY81,D4	; D4 <-- Y	MOVE.16	#1024-8,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS8,9,10	MOVE.16	#800-4,D3	MOVE.16	#512+32+160+8,D4	MOVE.16	#1024-(800-4)-8,D0	CALL	SEGHOR		; droite entre $DIS12 et 13	MOVE.16	#512+32+160+16+112+8,D4	CALL	SEGHOR		; droite entre $DIS13 et 14	MOVE.16	#800-4,D3	MOVE.16	#512+SEPY81,D4	MOVE.16	#8+160+16+112+16+112,D0	CALL	SEGVERT		; droite entre $DIS11 et 12,14.ELSE	Sm8.IF	FullPage	CALL	COINS		; arrondi les 4 coins		MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#SEPY81,D4	; D4 <-- Y	MOVE.16	#PVIEWX,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS8,9	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#SEPY17,D4	; D4 <-- Y	MOVE.16	#PVIEWX,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS1	TEST.16	D1	JUMP,EQ BITMAP1$	COMP.16	#1,D1	JUMP,EQ BITMAP2$	COMP.16	#2,D1	JUMP,EQ BITMAP3$	COMP.16	#3,D1	JUMP,EQ BITMAP4$	JUMP	L90$BITMAP1$:	MOVE.32	#R16^D1BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_1	JUMP	L90$BITMAP2$:	TEST.8	{A6}+OWDO23	; fentre $DIS_2 et $DIS_3 ensemble ?	JUMP,NE	 R8^BITMAP2B$	; oui => BITMAP2B$	MOVE.32	#R16^D2BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_2	JUMP	L90$BITMAP2B$:	MOVE.32	#R16^D2BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	SWAP.32	D3	MOVE.16	#(DBIGY-10)/2,D3	SWAP.32	D3	CALL	TRARECT		; grise $DIS_2	MOVE.32	#R16^D3BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_3	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#PBIGY+((DBIGY-10)/2)+0,D4 ; D4 <-- Y	MOVE.16	#PVIEWX,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS_2	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#PBIGY+((DBIGY-10)/2)+10-1,D4 ; D4 <-- Y	MOVE.16	#PVIEWX,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus $DIS_3	JUMP	L90$BITMAP3$:	TEST.8	{A6}+OWDO45	; fentre $DIS_4 et $DIS_5 ensemble ?	JUMP,NE	 R8^BITMAP3B$	; oui => BITMAP3B$	MOVE.32	#R16^D4BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_4	JUMP	L90$BITMAP3B$:	MOVE.32	#R16^D4BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	SWAP.32	D3	MOVE.16	#(DBIGY-10)/2,D3	SWAP.32	D3	CALL	TRARECT		; grise $DIS_4	MOVE.32	#R16^D5BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_5	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#PBIGY+((DBIGY-10)/2)+0,D4 ; D4 <-- Y	MOVE.16	#PVIEWX,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS_4	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#PBIGY+((DBIGY-10)/2)+10-1,D4 ; D4 <-- Y	MOVE.16	#PVIEWX,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus $DIS_5	JUMP	L90$BITMAP4$:	MOVE.32	#R16^D6BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_6	MOVE.32	#R16^D10BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_10	MOVE.32	#R16^D11BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_11	MOVE.32	#R16^D12BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_12	MOVE.32	#R16^D13BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_13	MOVE.32	#R16^D14BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_14	MOVE.32	#R16^D15BASE,A1	MOVE.32	{A1}+0,D4	MOVE.32	{A1}+4,D3	CALL	TRARECT		; grise $DIS_15	MOVE.16	#((PVIEWX-640)/2)-1,D3 ; D3 <-- X	MOVE.16	#PBIGY+8-1,D4	; D4 <-- Y	MOVE.16	#640+1,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus $DIS_6	MOVE.16	#((PVIEWX-640)/2)-1,D3 ; D3 <-- X	MOVE.16	#PBIGY+8+340,D4	; D4 <-- Y	MOVE.16	#640+1,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessous $DIS_6	MOVE.16	#((PVIEWX-640)/2)-1,D3 ; D3 <-- X	MOVE.16	#PBIGY+8-1,D4	; D4 <-- Y	MOVE.16	#340+1,D0	; D0 <-- dY (hauteur)	CALL	SEGVERT		; droite  gauche $DIS_6	MOVE.16	#((PVIEWX-640)/2)+640,D3 ; D3 <-- X	MOVE.16	#PBIGY+8-1,D4	; D4 <-- Y	MOVE.16	#340+1+1,D0	; D0 <-- dY (hauteur)	CALL	SEGVERT		; droite  droite $DIS_6	MOVE.16	#PBIGY+DBIGY-((8+DLITY)*3)-1,D4	CALL	LITLEFT$	MOVE.16	#PBIGY+DBIGY-((8+DLITY)*2)-1,D4	CALL	LITLEFT$	MOVE.16	#PBIGY+DBIGY-((8+DLITY)*1)-1,D4	CALL	LITLEFT$	MOVE.16	#PBIGY+DBIGY-((8+DLITY)*3)-1,D4	CALL	LITRIGHT$	MOVE.16	#PBIGY+DBIGY-((8+DLITY)*2)-1,D4	CALL	LITRIGHT$	MOVE.16	#PBIGY+DBIGY-((8+DLITY)*1)-1,D4	CALL	LITRIGHT$.ELSE	FullPage	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#SEPY81,D4	; D4 <-- Y	MOVE.16	#1024,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite sous $DIS8,9	MOVE.16	#PVIEWX+4,D3	MOVE.16	#PVIEWY-(LARGCY/2)-(LARGCY*5),D0	CALL	SEGVERT		; droite entre $DIS1 et $DIS2/3	MOVE.16	#LARGCY*2+170,D4	MOVE.16	#1024-(PVIEWX+4),D0	CALL	SEGHOR		; droite entre $DIS2 et $DIS3.ENDIF	ELSE FullPage.ENDIF	ELSE Sm8.ENDIF	ELSE SM100.OR.SM196.OR.SM300L90$:	POPM.32	D0|D3|D4|A1|A2	RET.IF	FullPageLITLEFT$:	MOVE.16	#0,D3		; D3 <-- X	MOVE.16	#DLITX+1,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus	ADD.16	#DLITY+1,D4	CALL	SEGHOR		; droite dessous	SUB.16	#DLITY+1,D4	MOVE.16	#DLITX,D3	; D3 <-- X	MOVE.16	#DLITY+1,D0	; D0 <-- dY (hauteur)	CALL	SEGVERT		; droite  droite	RETLITRIGHT$:	MOVE.16	#DLITX+16-1,D3	; D3 <-- X	MOVE.16	#DLITX+1,D0	; D0 <-- dX (longueur)	CALL	SEGHOR		; droite dessus	ADD.16	#DLITY+1,D4	CALL	SEGHOR		; droite dessous	SUB.16	#DLITY+1,D4	MOVE.16	#DLITY+1,D0	; D0 <-- dY (hauteur)	CALL	SEGVERT		; droite  droite	RET.ENDIF	FullPage;--------\; SEGHOR  >;--------/; Trace un segment horizontal.; in	A2.L	^description de la fentre;	D3.16	coordonne X;	D4.16	coordonne Y;	D0.16	longueur; out	-; mod	D7.WSEGHOR:	PUSHM.32 D0|D1|D3|D4	SWAP.32	D4	MOVE.16	D3,D4		; D4 <-- coordonne (y;x)	CLR.32	D3	MOVE.16	D0,D3		; D3 <-- longueurs (dy;dx)	MOVE.16	#SETDOT,D1	; D1 <-- mode	_GraCall Line.IF	SM8	SWAP.32	D4	DEC.16	D4	SWAP.32	D4	_GraCall Line.ENDIF	SM8	POPM.32	D0|D1|D3|D4	RET;--------\; SEGVERT >;--------/; Trace un segment vertical.; in	A2.L	^description de la fentre;	D3.16	coordonne X;	D4.16	coordonne Y;	D0.16	longueur; out	-; mod	D7.WSEGVERT:	PUSHM.32 D0|D1|D3|D4	SWAP.32	D4	MOVE.16	D3,D4		; D4 <-- coordonne (y;x)	CLR.32	D3	MOVE.16	D0,D3	SWAP.32	D3		; D3 <-- longueurs (dy;dx)	MOVE.16	#SETDOT,D1	; D1 <-- mode	_GraCall Line.IF	SM8	DEC.16	D4	_GraCall Line.ENDIF	SM8	POPM.32	D0|D1|D3|D4	RET.IF	Cos21.OR.Sm324.IF	FullPage;--------\\; TRARECT >;--------/; Dessine une trame grise rectangulaire.; in	D4.L	origine (y;x);	D3.32	dimensions (dy;dx); out	-; mod	D7.WTRARECT:	PUSHM.32 D1|A4	MOVE.16	#SETDOT,D1	; D1 <-- mode	MOVE.32	#R16^L00$,A4	; A4 <-- ^trame	_GraCall Trame	POPM.32	D1|A4	RETL00$:	.32	TRAGRIS	.32	TRAGRIS.ENDIF	FullPage.ENDIF	Cos21.OR.Sm324.CHAP	Caractres de commande;--------\; AFCAR   >;========/; Affiche un caractre dans une fentre.; in	D3.B	caractre  afficher;	A2.32	^description de la fentre;	A4.32	^paramtres;	D4.32	nb de paramtres; out	A4.L	^plus loin;	D4.32	nb de paramtres restants;	D7.16	erreur; mod	D0..A1, D3.W, D4.L, D7.W, A4.LAFCAR:	CLR.16	D7		; D7 <-- ok	AND.16	#16'FF,D3	; D3.W <-- caractre	CLR.32	D0	MOVE.16	{A2}+ODFADR,D0	; D0 <-- adresse rel. routine	JUMP,EQ	 R8^L10$	; zro => 10$	ADD.32	{A6}+OSTART,D0	; D0 <-- adresse absolue	MOVE.32	D0,A1	JUMP	{A1}L10$:	COMP.8	#16'80,D3	; commande ?	JUMP,LO	 R8^L50$	; non => 50$				; oui =>	MOVE.32	#R16^TACOMM,A1	JUMP	EXROUTT		; excute une commandeL50$:	TEST.8	{A2}+ODFFLG:#BFTOUT ; affiche tout ?	JUMP,NE	 R8^L70$	; oui => 70$				; non =>	COMP.8	#NUL,D3		; caractre NUL ?	JUMP,EQ	 R8^L90$	; oui => ne fait rien				; non =>	COMP.8	#"",D3		; caractre spcial ?	JUMP,HS	 R8^L70$	; non => 70$				; oui =>	MOVE.32	#R16^TASPEC,A1	JUMP	EXROUT		; excute un car spcialL70$:	JUMP	AFCODE		; affiche un codeL90$:	RET;--------\; EXROUTT >;--------/; in	A1.L	^table de .WBB;	D3.8	caractre;	A2.32	^description de la fentre;	A4.32	^paramtres;	D4.32	nb de paramtres; out	A4.L	^plus loin;	D4.32	nb de paramtres restants;	D7.16	erreur; mod	D4.L, D7.W, A4.LEXROUTT:	PUSHM.32 D0..D3|A1	AND.16	#16'7F,D3	; D3 <-- 0..n	SL.16	#2,D3		; D3 <-- *4 car .WBB	ADD.A16	D3,A1		; A1 <-- ^.WBB concern	TEST.8	{A1}+3		; modifiera le contenu de la fentre ?	JUMP,NE	 R8^L20$	; non => 20$	CALL	CLRLUTIN	; oui => enlve le lutin de la sourisL20$:	CLR.16	D7		; D7 <-- ok	CLR.32	D1	MOVE.16	{A1}+0,D1	; D1 <-- adresse relative	JUMP,EQ	 R8^L80$	; si commande inconnue => 80$	CLR.32	D0	MOVE.8	{A1}+2,D0	; D0 <-- nb paramtres attendus	JUMP,EQ	 R8^L70$	; si aucun => 70$	COMP.32	D4,D0		; tous les paramtres dj l ?	JUMP,HI	 R8^L60$	; non => 60$				; oui =>	MOVE.32	#{A2}+ODFCOM,A1	; A1 <-- ^buffer pour les paramtres	SUB.32	D0,D4		; D4 <-- signal paramtres dj pris	DEC.16	D0		; D0 <-- -1  cause du test NMO !L40$:	MOVE.8	{A4+},{A1+}	; buffer <-- paramtres	DJ.16,NMO  D0,L40$	JUMP	R8^L70$L60$:	CALL	WAITCOM		; attend le(s) paramtre(s)	JUMP	R8^L90$L70$:	MOVE.32	D1,A1		; A1 <-- adresse relative	ADD.32	{A6}+OSTART,A1	; A1 <-- adresse absolue	CALL	{A1}		; excute une routine spciale	JUMP	R8^L90$L80$:	MOVE.16	#ERDIIL,D7	; D7 <-- "illegal command"L90$:	POPM.32	D0..D3|A1	RET;--------\; WAITCOM >;--------/; Attend une commande pouvant contenir un nombre quelconque; de bytes (maximum = MAXCOM).; in	D0.W	longueur de la commande;	D1.16	adresse relative routine  excuter lorsque;		la commande est termine; out	-; mod	-WAITCOM:	CLR.16	{A2}+ODFCPT	; rz ^relatif dans commande	MOVE.16	D0,{A2}+ODFCCT	; init compteur	MOVE.16	D1,{A2}+ODFNXT	; init routine lorsque fini	MOVE.16	#L10$,{A2}+ODFADR	RETL10$:	MOVE.16	{A2}+ODFCPT,D0	PUSH.32	A2	MOVE.32	#{A2}+ODFCOM,A2	MOVE.8	D3,{A2}+A16^{D0}; mmorise le byte reu	POP.32	A2	INC.16	{A2}+ODFCPT	; incrmente le pointeur	DEC.16	{A2}+ODFCCT	; dcrmente le compteur	JUMP,EQ	 R8^L20$	RETL20$:	MOVE.16	{A2}+ODFNXT,{A2}+ODFADR	JUMP	AFCAR		; effectue JUMP (A2),ODFADR;--------\; EXROUT  >;--------/; in	A1.L	^table de  .W car adr;	D3.8	caractre;	A2.32	^description de la fentre; out	D7.W	erreur; mod	D7.WEXROUT:	PUSHM.32 D0|D1|D2|D3|D4|A0|A1	AND.16	#16'FF,D3	MOVE.16	#ERDIIL,D7	; D7 <-- "illegal command"L10$:	ADD.32	#4,A1		; A1 <-- ^suivant dans table	TEST.16	{A1}-4		; fin de la table ?	JUMP,EQ	 R8^L80$	; oui => 80$ (CC)	COMP.8	{A1}-4,D3	; caractre trouv ?	JUMP,NE L10$		; non => 10$				; oui =>	TEST.8	{A1}-3		; modifiera le contenu de la fentre ?	JUMP,NE	 R8^L50$	; non => 50$	CALL	CLRLUTIN	; oui => enlve le lutin de la sourisL50$:	CLR.16	D7		; D7 <-- ok	CLR.32	D1	MOVE.16	{A1}-2,D1	MOVE.32	D1,A1		; A1 <-- adresse relative	ADD.32	{A6}+OSTART,A1	; A1 <-- adresse absolue	CALL	{A1}		; excute une routine spcialeL80$:	POPM.32	D0|D1|D2|D3|D4|A0|A1	RETTACOMM:	.16	DOCXY	.8		2,1	; H'80 = CARXY	.16	DOGXY	.8		4,1	; H'81 = GRAXY	.16	DOMSPA	.8		1,1	; H'82 = MSPACE	.16	0	.8		0,0	; H'83	.16	DOLEFT	.8		0,1	; H'84 = LEFT	.16	DORIGHT	.8		0,1	; H'85 = RIGHT	.16	DOUP	.8		0,1	; H'86 = UP	.16	DODOWN	.8		0,1	; H'87 = DOWN	.16	DOROLLU	.8		2,0	; H'88 = ROLLUP	.16	DOROLLD	.8		2,0	; H'89 = ROLLDOWN	.16	DOEFLI	.8		0,1	; H'8A = EFLI	.16	DOTRAM	.8		8,1	; H'8B = TRAME	.16	DOEFEOS	.8		0,0	; H'8C = EFEOS	.16	DOPEN	.8		8,1	; H'8D = PEN	.16	DOMAPT	.8		2,1	; H'8E = MAPTT	.16	0	.8		0,0	; H'8F	.16	DOADIR	.8		0,1	; H'90 = AFDIR	.16	DOAINV	.8		0,1	; H'91 = AFINV	.16	DONORM	.8		0,1	; H'92 = AFNORM	.16	DOTOUT	.8		0,1	; H'93 = AFTOUT	.16	DOROLL	.8		0,1	; H'94 = ROLL	.16	DONORO	.8		0,1	; H'95 = NOROLL	.16	DOTRUN	.8		0,1	; H'96 = TRUNC	.16	DOAUCR	.8		0,1	; H'97 = AUTOCR	.16	DOAUEF	.8		0,1	; H'98 = AUTOEFLI	.16	DONOEF	.8		0,1	; H'99 = NOEFLI	.16	DOGCUR	.8		0,1	; H'9A = GCURS	.16	DOPCUR	.8		0,1	; H'9B = PCURS	.16	DOCURS	.8		0,1	; H'9C = CURS	.16	DONOCU	.8		0,1	; H'9D = NOCURS	.16	DOPROC	.8		1,1	; H'9E = PROCURS	.16	0	.8		0,0	; H'9F	.16	DOUSGC	.8		3,1	; H'A0 = USEGC	.16	DOLOGC	.8		3,1	; H'A1 = LOADGC	.16	DOKIGC	.8		3,1	; H'A2 = KILLGC	.16	DOPFGC	.8		4,1	; H'A3 = PFIXGC	.16	DOCVAR	.8		0,1	; H'A4 = AFCVAR	.16	DOCFIX	.8		0,1	; H'A5 = AFCFIX	.16	DOSROL	.8		0,1	; H'A6 = SROLL	.16	DOMCAR	.8		1,1	; H'A7 = MODCAR	.16	DOCCMO	.8		0,0	; H'A8 = AFCCMO	.16	DOSCMO	.8		0,0	; H'A9 = AFSCMO	.16	DOIMAE	.8		0,1	; H'AA = IMAENA	.16	DOIMAD	.8		0,1	; H'AB = IMADIS	.16	DODIMW	.8		8,1	; H'AC = DIMWDO	.16	DOSAVW	.8		0,0	; H'AD = SAVWDO	.16	DOGETW	.8		0,0	; H'AE = GETWDO	.16	DOMGRA	.8		1,1	; H'AF = MODGRA	.16	DOTYAX	.8		2,1	; H'B0 = TYPOAX	.16	DOTYAY	.8		2,1	; H'B1 = TYPOAY	.16	DOTYRX	.8		1,1	; H'B2 = TYPORX	.16	DOTYRY	.8		1,1	; H'B3 = TYPORY	.16	DOHSPA	.8		1,1	; H'B4 = HSPACE	.16	DOVSPA	.8		1,1	; H'B5 = VSPACE	.16	DOFULL	.8		0,1	; H'B6 = AFFULL	.16	DOGREY	.8		0,1	; H'B7 = AFGREY	.16	DOCOSA	.8		6,1	; H'B8 = COLORSA	.16	DOCOCA	.8		6,1	; H'B9 = COLORCA	.16	DOCOSR	.8		4,1	; H'BA = COLORSR	.16	DOCOCR	.8		4,1	; H'BB = COLORCR	.16	DOCOLK	.8		10,1	; H'BC = COLORLINK	.16	DOCOUK	.8		4,1	; H'BD = COLORUNLINK	.16	DOCOOP	.8		1,1	; H'BE = COLOROP	.16	DOCOFA	.8		10,1	; H'BF = COLORFALSE	.16	DODRDO	.8		5,1	; H'C0 = DRAWDOT	.16	DODRLI	.8		5,1	; H'C1 = DRAWLINE	.16	DODRSE	.8		9,1	; H'C2 = DRAWSEG	.16	DODRCE	.8		3,1	; H'C3 = DRAWCERCLE	.16	DODRTR	.8		9,1	; H'C4 = DRAWTRAME	.16	DODRMX	.8		9,1	; H'C5 = DRAWMATRIX	.16	DODRAR	.8		9,1	; H'C6 = DRAWARC	.16	DODRFO	.8		4,0	; H'C7 = DRAWFILLO	.16	DODRFC	.8		0,0	; H'C8 = DRAWFILLC	.16	DODRRA	.8		25,1	; H'C9 = DRAWRASTER	.16	DODRMO	.8		13,1	; H'CA = DRAWMOUSE	.16	DODROS	.8		17,0	; H'CB = DRAWOSPRITE	.16	DODRMS	.8		5,1	; H'CC = DRAWMSPRITE	.16	DODRES	.8		1,0	; H'CD = DRAWESPRITE	.16	DODRCS	.8		1,0	; H'CE = DRAWCSPRITE	.16	DODREL	.8		11,1	; H'CF = DRAWELLIPSE	.16	DOASGC	.8		6,1	; H'D0 = ASSGC	.16	DOMEGC	.8		0,1	; H'D1 = MEMGC	.16	DODRPM	.8		8,1	; H'D2 = DRAWPMOUSE	.16	DONEGC	.8		7,1	; H'D3 = NEWGC	.16	DOMODU	.8		1,1	; H'D4 = MMODULO	.16	DOXPEN	.8		14,1	; H'D5 = XPEN	.16	DOXTRA	.8		18,1	; H'D6 = XTRAME	.16	DOXMAP	.8		18,1	; H'D7 = XMAPTT	.16	0	.8		0,0	; H'D8	.16	0	.8		0,0	; H'D9	.16	0	.8		0,0	; H'DA	.16	0	.8		0,0	; H'DB	.16	0	.8		0,0	; H'DC	.16	0	.8		0,0	; H'DD	.16	0	.8		0,0	; H'DE	.16	0	.8		0,0	; H'DF	.16	DOROLLL	.8		2,0	; H'E0 = ROLLLEFT	.16	DOROLLR	.8		2,0	; H'E1 = ROLLRIGHT	.16	DOFILT	.8		0,1	; H'E2 = AFFILLT	.16	DOFILA	.8		0,1	; H'E3 = AFFILLA	.16	0	.8		0,0	; H'E4	.16	0	.8		0,0	; H'E5	.16	0	.8		0,0	; H'E6	.16	0	.8		0,0	; H'E7	.16	0	.8		0,0	; H'E8	.16	0	.8		0,0	; H'E9	.16	0	.8		0,0	; H'EA	.16	0	.8		0,0	; H'EB	.16	0	.8		0,0	; H'EC	.16	0	.8		0,0	; H'ED	.16	0	.8		0,0	; H'EE	.16	0	.8		0,0	; H'EF	.16	0	.8		0,0	; H'F0	.16	0	.8		0,0	; H'F1	.16	0	.8		0,0	; H'F2	.16	0	.8		0,0	; H'F3	.16	0	.8		0,0	; H'F4	.16	0	.8		0,0	; H'F5	.16	0	.8		0,0	; H'F6	.16	0	.8		0,0	; H'F7	.16	0	.8		0,0	; H'F8	.16	0	.8		0,0	; H'F9	.16	0	.8		0,0	; H'FA	.16	0	.8		0,0	; H'FB	.16	0	.8		0,0	; H'FC	.16	0	.8		0,0	; H'FD	.16	0	.8		0,0	; H'FE	.16	0	.8		0,0	; H'FFTASPEC:	.8	CR,1	.16		DOCR	.8	TAB,1	.16		DOTAB	.8	BELL,1	.16		DOBELL	.8	BS,0	.16		DOBS	.8	LF,1	.16		DODOWN	.8	EOP,0	.16		DOEOP	.16	0; ---	CARXY   ---;	CARXY x y;	---------;	x,y:	nouvelle coordonne  atteindre (en caractres)DOCXY:	CLR.16	{A2}+ODFADR	; suite de bytes termines	CLR.16	D0	MOVE.8	{A2}+ODFCOM+0,D0 ; D0 <-- premier paramtre	MUL.16	{A2}+ODFCX,D0	; * largeur d'un caractre	ADD.16	{A2}+ODFC1X,D0	CALL	DOTYIX		; init coordonne X	CLR.16	D0	MOVE.8	{A2}+ODFCOM+1,D0 ; D0 <-- deuxime paramtre	MUL.16	{A2}+ODFCY,D0	; * hauteur d'un caractre	ADD.16	{A2}+ODFC1Y,D0	JUMP	DOTYIY		; init coordonne Y; ---	TYPOAX   ---;	TYPOAX xx;	---------;	xx:	coordonne absolue  atteindre (en points)DOTYAX:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	{A2}+ODFCOM+0,D0 ; D0 <-- coordonne X absolueDOTYIX:	COMP.8	#GRACLIP2,{A2}+ODFMGR	JUMP,EQ	 R8^L40$	MOVE.16	{A2}+ODFFDX,D1	SUB.16	{A2}+ODFC2X,D1	; D1 <-- coordonne max	COMP.16	D1,D0		; trop  droite ?	JUMP,LS	 R8^L20$	; non => 20$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	D1,D0		; D0 <-- coordonne X max	JUMP	R8^L40$L20$:	COMP.16	{A2}+ODFC1X,D0	; trop  gauche ?	JUMP,HS	 R8^L40$	; non => 40$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFC1X,D0	; D0 <-- coordonne X minL40$:	MOVE.16	D0,{A2}+ODFPX	; init nouvelle position en X	RET; ---	TYPOAY   ---;	TYPOAY yy;	---------;	yy:	coordonne absolue  atteindre (en points)DOTYAY:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	{A2}+ODFCOM+0,D0 ; D0 <-- coordonne Y absolueDOTYIY:	COMP.8	#GRACLIP2,{A2}+ODFMGR	JUMP,EQ	 R8^L40$	MOVE.16	{A2}+ODFFDY,D1	SUB.16	{A2}+ODFC2Y,D1	; D1 <-- coordonne max	COMP.16	D1,D0		; trop bas ?	JUMP,LS	 R8^L20$	; non => 20$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	D1,D0		; D0 <-- coordonne Y max	JUMP	R8^L40$L20$:	COMP.16	{A2}+ODFC1Y,D0	; trop haut ?	JUMP,HS	 R8^L40$	; non => 40$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFC1Y,D0	; D0 <-- coordonne Y minL40$:	MOVE.16	D0,{A2}+ODFPY	; init nouvelle position en Y	RET; ---	TYPORX   ---;	TYPORX x;	--------;	x:	coordonne relative positive ou ngativeDOTYRX:	CLR.16	{A2}+ODFADR	; suite de bytes termines	CLR.16	D1	MOVE.8	{A2}+ODFCOM+0,D1 ; D1 <-- coordonne X relative	JUMP,NC	 R8^L15$	; valeur ngative ?	OR.16	#16'FF00,D1	; oui => tend le signeL15$:	MOVE.16	{A2}+ODFPX,D0	ADD.16	D1,D0		; augmente/diminue coord. X	JUMP	DOTYIX		; init nouvelle coordonne; ---	TYPORY   ---;	TYPORY y;	--------;	y:	coordonne relative positive ou ngativeDOTYRY:	CLR.16	{A2}+ODFADR	; suite de bytes termines	CLR.16	D1	MOVE.8	{A2}+ODFCOM+0,D1 ; D1 <-- coordonne Y relative	JUMP,NC	 R8^L15$	; valeur ngative ?	OR.16	#16'FF00,D1	; oui => tend le signeL15$:	MOVE.16	{A2}+ODFPY,D0	ADD.16	D1,D0		; augmente/diminue coord. Y	JUMP	DOTYIY		; init nouvelle coordonne; ---	HSPACE   ---;	HSPACE x;	--------;	x:	modification de l'espace intercaractres;		positivement ou ngativementDOHSPA:	CLR.16	{A2}+ODFADR	; suite de bytes termines	CLR.16	D0	MOVE.8	{A2}+ODFCOM+0,D0 ; D0 <-- espacement H relatif	JUMP,NC	 R8^L15$	; valeur ngative ?	OR.16	#16'FF00,D0	; oui => tend le signeL15$:	MOVE.16	D0,{A2}+ODFCIX	; augmente/diminue espace H	RET; ---	VSPACE   ---;	VSPACE y;	--------;	y:	modification de l'espace interlignes;		positivement ou ngativementDOVSPA:	CLR.16	{A2}+ODFADR	; suite de bytes termines	CLR.16	D0	MOVE.8	{A2}+ODFCOM+0,D0 ; D0 <-- espacement V relatif	JUMP,NC	 R8^L15$	; valeur ngative ?	OR.16	#16'FF00,D0	; oui => tend le signeL15$:	ADD.16	D0,{A2}+ODFCY	; augmente/diminue espace V	RET; ---	MODCAR   ---;	MODCAR m;	--------;	m:	INVDOT ou SETDOTDOMCAR:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.8	{A2}+ODFCOM+0,{A2}+ODFMCA	RET; ---	MODGRA   ---;	MODGRA g;	--------;	g:	GRAWHOLE, GRACLIP ou GRAROUNDDOMGRA:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.8	{A2}+ODFCOM+0,{A2}+ODFMGR	RET; ---	ROLLUP   ---;	ROLLUP nn;	---------;	nn:	nb de points du dcalageDOROLLU:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D4	MOVE.16	{A2}+ODFCOM+0,D4	_GraCall RollUp	POP.16	D4	RET; ---	ROLLDOWN   ---;	ROLLDOWN nn;	-----------;	nn:	nb de points du dcalageDOROLLD:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D4	MOVE.16	{A2}+ODFCOM+0,D4	_GraCall RollDown	POP.16	D4	RET; ---	ROLLDOLEFT   ---;	ROLLLEFT nn;	-----------;	nn:	nb de points du dcalageDOROLLL:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D4	MOVE.16	{A2}+ODFCOM+0,D4	_GraCall RollLeft	POP.16	D4	RET; ---	ROLLRIGHT   ---;	ROLLRIGHT nn;	------------;	nn:	nb de points du dcalageDOROLLR:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D4	MOVE.16	{A2}+ODFCOM+0,D4	_GraCall RollRight	POP.16	D4	RET; ---	GRAXY   ---;	GRAXY xx yy;	-----------;	xx,yy:	nouvelle coordonne  atteindre (en points)DOGXY:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	{A2}+ODFCOM+0,D0 ; D0 <-- premier paramtre	COMP.16	{A2}+ODFFDX,D0	; dbordement ?	JUMP,LO	 R8^L15$	; non => 15$	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFFDX,D0	; D0 <-- coordonne X max	DEC.16	D0L15$:	MOVE.16	D0,{A2}+ODFPGX	; init nouvelle position en X	MOVE.16	{A2}+ODFCOM+2,D0 ; D0 <-- deuxime paramtre	COMP.16	{A2}+ODFFDY,D0	; dbordement ?	JUMP,LO	 R8^L25$	; non => 25$	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFFDY,D0	; D0 <-- coordonne Y max	DEC.16	D0L25$:	MOVE.16	D0,{A2}+ODFPGY	; init nouvelle position en Y	RET; ---	DRAWLINE   ---;	DRAWLINE xx yy m;	----------------;	xx:	arrive en x (high puis low);	yy:	arrive en y (high puis low);	m:	modeDODRLI:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D3|D4	MOVE.16	{A2}+ODFCOM+2,D4 ; D4 <-- Y	MOVE.16	{A2}+ODFPGY,D3	SUB.16	D4,D3		; D3 <-- longueur en Y	SWAP.32	D4	SWAP.32	D3	MOVE.16	{A2}+ODFCOM+0,D4 ; D4 <-- Y;X	MOVE.16	{A2}+ODFPGX,D3	SUB.16	D4,D3		; D3 <-- longueur en X	MOVE.8	{A2}+ODFCOM+4,D1 ; D1 <-- mode	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	_GraCall Line	JUMP,NE	 R8^L90$	; oui => 90$				; non =>	MOVE.32	D4,{A2}+ODFPGY	; init nouvelle coor. graphiqueL90$:	POPM.32	D1|D3|D4	RET; ---	DRAWSEG   ---;	DRAWSEG xx yy dxx dyy m;	-----------------------;	xx:	origine en x (high puis low);	yy:	origine en y (high puis low);	dxx:	longueur en x (high puis low);	dyy:	longueur en y (high puis low);	m:	modeDODRSE:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D3|D4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- X;Y	SWAP.32	D4		; D4 <-- Y;X	MOVE.32	{A2}+ODFCOM+4,D3; D3 <-- dX;dY	SWAP.32	D3		; D3 <-- dY;dX	MOVE.8	{A2}+ODFCOM+8,D1; D1 <-- mode	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	_GraCall Line	POPM.32	D1|D3|D4	RET; ---	DRAWCERCLE   ---;	DRAWCERCLE rr m;	---------------;	rr:	rayon du cercle (high puis low);	m:	modeDODRCE:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D2|D3|D4	MOVE.16	{A2}+ODFCOM+0,D3; D3 <-- rayon du cercle	SWAP.32	D3	MOVE.16	{A2}+ODFCOM+0,D3; D3 <-- rayon du cercle	JUMP,EQ	 R8^L90$	; si rayon nul => 90$	MOVE.8	{A2}+ODFCOM+2,D1; D1 <-- mode	MOVE.32	{A2}+ODFPGY,D4	; D4 <-- coordonne centre (y;x)	MOVE.8	#2'11111111,D2	; D4 <-- dessine tout	CALL	ITELUTIN	; efface lutin-souris si ncessaire	_GraCall CircleL90$:	POPM.32	D1|D2|D3|D4	RET; ---	DRAWARC   ---;	DRAWARC xx yy rr aa m;	---------------------;	xx:	centre en x (high puis low);	yy:	centre en y (high puis low);	rr:	rayon du cercle (high puis low);	aa:	octants  dessiner (high puis low);	m:	modeDODRAR:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D2|D3|D4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne centre X;Y	SWAP.32	D4		; D4 <-- coordonne centre Y;X	MOVE.16	{A2}+ODFCOM+4,D3; D3 <-- rayon du cercle	SWAP.32	D3	MOVE.16	{A2}+ODFCOM+4,D3; D3 <-- rayon du cercle	JUMP,EQ	 R8^L90$	; si rayon nul => 90$	MOVE.16	{A2}+ODFCOM+6,D2; D2 <-- octants  dessiner	MOVE.8	{A2}+ODFCOM+8,D1; D1 <-- mode	CALL	ITELUTIN	; efface lutin-souris si ncessaire	_GraCall CircleL90$:	POPM.32	D1|D2|D3|D4	RET; ---	DRAWELLIPSE   ---;	DRAWELLIPSE xx yy rx ry aa m;	----------------------------;	xx:	centre en x (high puis low);	yy:	centre en y (high puis low);	rx:	rayon de l'ellipse en x (high puis low);	ry:	rayon de l'ellipse en y (high puis low);	aa:	octants  dessiner (high puis low);	m:	modeDODREL:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D2|D3|D4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne centre X;Y	SWAP.32	D4		; D4 <-- coordonne centre Y;X	MOVE.32	{A2}+ODFCOM+4,D3; D3 <-- rayons X;Y	SWAP.32	D3		; D3 <-- rayons Y;X	TEST.32	D3	JUMP,EQ	 R8^L90$	; si rayons nuls => 90$	MOVE.16	{A2}+ODFCOM+8,D2; D2 <-- octants  dessiner	MOVE.8	{A2}+ODFCOM+10,D1; D1 <-- mode	CALL	ITELUTIN	; efface lutin-souris si ncessaire	_GraCall EllipseL90$:	POPM.32	D1|D2|D3|D4	RET; ---	DRAWDOT   ---;	DRAWDOT xx yy m;	---------------;	xx:	coordonne x (high puis low);	yy:	coordonne y (high puis low);	m:	modeDODRDO:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D3|D4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne (x;y)	SWAP.32	D4		; D4 <-- coordonne (y;x)	MOVE.8	{A2}+ODFCOM+4,D1; D1 <-- mode	MOVE.32	#16'10000*1+1,D3; D3 <-- dimensions pour ITGLUTIN	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	_GraCall Dot	POPM.32	D1|D3|D4	RET; ---	DRAWTRAME   ---;	DRAWTRAME xx yy dxx dyy m;	-------------------------;	xx:	coordonne x (high puis low);	yy:	coordonne y (high puis low);	dxx:	largeur x (high puis low);	dyy:	largeur y (high puis low);	m:	modeDODRTR:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D3|D4|A4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- X;Y	SWAP.32	D4		; D4 <-- Y;X	MOVE.32	{A2}+ODFCOM+4,D3; D3 <-- dX;dY	SWAP.32	D3		; D3 <-- dY;dX	MOVE.8	{A2}+ODFCOM+8,D1; D1 <-- mode	MOVE.32	#{A2}+ODFTRA,A4	; A4 <-- ^trame utilisateur	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	_GraCall Trame	POPM.32	D1|D3|D4|A4	RET; ---	XTRAME   ---;	XTRAME xx yy pppp ii dx dy ox oy;	--------------------------------;	xx:	coordonne x gauche;	yy:	coordonne y suprieure;	pppp:	^matrice (^nil si 8x8 standard);	ii:	incrment ligne;	dx:	largeur;	dy:	hauteur;	ox:	origine motif;	oy:	origine motifDOXTRA:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	{A2}+ODFCOM+0,{A2}+ODFTPO+2	MOVE.16	{A2}+ODFCOM+2,{A2}+ODFTPO+0	MOVE.32	{A2}+ODFCOM+4,{A2}+ODFTPM	MOVE.16	{A2}+ODFCOM+8,{A2}+ODFTII	MOVE.16	{A2}+ODFCOM+10,{A2}+ODFTDI+2	MOVE.16	{A2}+ODFCOM+12,{A2}+ODFTDI+0	MOVE.16	{A2}+ODFCOM+14,{A2}+ODFTOR+2	MOVE.16	{A2}+ODFCOM+16,{A2}+ODFTOR+0	RET; ---	TRAME   ---;	TRAME n n n n n n n n;	---------------------;	n:	motif de la trameDOTRAM:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D0|D1|D2|A0|A1	MOVE.32	#{A2}+ODFTRA,A0	; A0 <-- ^destination	MOVE.32	#{A2}+ODFCOM,A1	; A1 <-- ^source	CLR.16	D0	MOVE.16	#8-1,D2		; -1  cause du test NMOL20$:	MOVE.8	{A1+},D0	; D0 <-- trame de la commande; Permute tous les bits de D0 dans D1. Pas de boucle pour tre; rapide, et pas de table de 256 bytes pour conomiser la RAM !	RLX.8	D0	RRX.8	D1		; D1 <-- bit 0	RLX.8	D0	RRX.8	D1		; D1 <-- bit 1	RLX.8	D0	RRX.8	D1		; D1 <-- bit 2	RLX.8	D0	RRX.8	D1		; D1 <-- bit 3	RLX.8	D0	RRX.8	D1		; D1 <-- bit 4	RLX.8	D0	RRX.8	D1		; D1 <-- bit 5	RLX.8	D0	RRX.8	D1		; D1 <-- bit 6	RLX.8	D0	RRX.8	D1		; D1 <-- bit 7	MOVE.8	D1,{A0+}	; stocke trame dans variables	DJ.16,NMO  D2,L20$	CLR.32	{A2}+ODFTPM	; annule XTRAME	POPM.32	D0|D1|D2|A0|A1	RET; ---	XPEN   ---;	XPEN xx yy pppp ii dx dy;	------------------------;	xx:	coordonne x gauche;	yy:	coordonne y suprieure;	pppp:	^matrice (^nil si 8x8 standard);	ii:	incrment ligne;	dx:	largeur;	dy:	hauteurDOXPEN:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	{A2}+ODFCOM+0,{A2}+ODFPPO+2	MOVE.16	{A2}+ODFCOM+2,{A2}+ODFPPO+0	MOVE.32	{A2}+ODFCOM+4,{A2}+ODFPPM	MOVE.16	{A2}+ODFCOM+8,{A2}+ODFPII	MOVE.16	{A2}+ODFCOM+10,{A2}+ODFPDI+2	MOVE.16	{A2}+ODFCOM+12,{A2}+ODFPDI+0	RET; ---	PEN   ---;	PEN n n n n n n n n;	-------------------;	n:	motif du pinceauDOPEN:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.32	{A2}+ODFCOM+0,{A2}+ODFPEN+0 ; stocke le pinceau	MOVE.32	{A2}+ODFCOM+4,{A2}+ODFPEN+4 ; dans les var.	CLR.32	{A2}+ODFPPM	; annule XPEN	RET; ---	XMAPTT   ---;	XMAPTT oo p1 v1 p2 v2 p3 v3 p4 v4;	---------------------------------;	oo:	origine traitill;	pn:	longueur pleine;	vn:	longueur videDOXMAP:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	{A2}+ODFCOM+0,{A2}+ODFPTO	MOVE.32	{A2}+ODFCOM+2,{A2}+ODFPT1	MOVE.32	{A2}+ODFCOM+6,{A2}+ODFPT3	MOVE.32	{A2}+ODFCOM+10,{A2}+ODFPT5	MOVE.32	{A2}+ODFCOM+14,{A2}+ODFPT7	RET; ---	MAPTT   ---;	MAPTT m e;	---------;	m:	map des traits  - - -;	e:	chelle (1..n)DOMAPT:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D0	MOVE.8	{A2}+ODFCOM+0,{A2}+ODFTTM ; stocke le map  - - -	MOVE.8	{A2}+ODFCOM+1,D0 ; D0 <-- chelle	JUMP,NE	 R8^L50$	INC.8	D0		; D0 <-- au moins unL50$:	MOVE.8	D0,{A2}+ODFTTS	; stocke l'chelle	CLR.16	{A2}+ODFPT1	; annule XMAPTT	POP.16	D0	RET; ---	DRAWFILLO   ---;	DRAWFILLO xx yy;	---------------;	xx:	coordonne x dbut remplissage;	yy:	coordonne y dbut remplissageDODRFO:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.32	D4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne (x;y)	SWAP.32	D4		; D4 <-- coordonne (y;x)	_GraCall FillO	POP.32	D4	RET; ---	DRAWFILLC   ---;	DRAWFILLC;	---------DODRFC:	_GraCall FillC	RET; ---	DRAWRASTER   ---;	DRAWRASTER xx yy pppp ii xx yy pppp ii dx dy m;	----------------------------------------------;	xx:	coordonne x gauche source/destination;	yy:	coordonne y suprieure source/destination;	pppp:	^source/destination (^nil si cran);	ii:	incrment (si mmoire) source/destination;	dx:	largeur;	dy:	hauteur;	m:	modeDODRRA:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1..D6|A3|A4	MOVE.32	{A2}+ODFCOM+0,D3; D3 <-- coordonne (x;y) source	SWAP.32	D3		; D3 <-- coordonne (y;x) source	MOVE.32	{A2}+ODFCOM+4,A3; A3 <-- ^source	MOVE.16	{A2}+ODFCOM+8,D5; D5 <-- Iy source	MOVE.32	{A2}+ODFCOM+10,D4; D4 <-- coordonne (x;y) destination	SWAP.32	D4		 ; D4 <-- coordonne (y;x) destination	MOVE.32	{A2}+ODFCOM+14,A4; A4 <-- ^destination	MOVE.16	{A2}+ODFCOM+18,D6; D6 <-- Iy destination	MOVE.32	{A2}+ODFCOM+20,D2; D2 <-- dim (dx;dy)	SWAP.32	D2		 ; D2 <-- dim (dy;dx)	CLR.32	D1	MOVE.8	{A2}+ODFCOM+24,D1; D1 <-- opration	COMP.32	#0,A4		; A4=^nil (si cran) ?	JUMP,NE	 R8^L50$	; non => 50$	EX.32	D2,D3	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	EX.32	D3,D2L50$:	_GraCall Raster	POPM.32	D1..D6|A3|A4	RET; ---	DRAWOSPRITE   ---;	DRAWOSPRITE xx yy dx dy ssss cccc n;	-----------------------------------;	xx:	coordonne x gauche;	yy:	coordonne y suprieure;	dx:	largeur dx;	dy:	hauteur dy;	ssss:	^matrice chair (set);	cccc:	^matrice fond (clear);	n:	numro du lutinDODROS:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D0|D3|D4|D6|A3|A4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne (x;y)	SWAP.32	D4		; D4 <-- coordonne (y;x)	MOVE.32	{A2}+ODFCOM+4,D3; D3 <-- dimensions (dx;dy)	SWAP.32	D3		; D3 <-- dimensions (dy;dx)	MOVE.32	{A2}+ODFCOM+8,A4 ; A4 <-- ^matrice chair (set)	MOVE.32	{A2}+ODFCOM+12,A3; A3 <-- ^matrice fond (clear)	MOVE.8	{A2}+ODFCOM+16,D6; D6 <-- numro du lutin	MOVE.16	#SPRITE_OPEN,D0	_GraCall Sprite	POPM.32	D0|D3|D4|D6|A3|A4	RET; ---	DRAWMSPRITE   ---;	DRAWMSPRITE xx yy n;	-------------------;	xx:	coordonne x gauche;	yy:	coordonne y suprieure;	n:	numro du lutinDODRMS:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D0|D1|D3|D4|D6|A3|A4	MOVE.8	{A2}+ODFCOM+4,D6; D6 <-- numro du lutin	MOVE.16	#SPRITE_GETPOS,D0	_GraCall Sprite	JUMP,NE L90$	EX.32	D3,D4		; D4 <-- pos et D3 <-- dim	CLR.16	D1		; D1 <-- mode	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne (x;y)	SWAP.32	D4		; D4 <-- coordonne (y;x)	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	MOVE.16	#SPRITE_MOVE,D0	_GraCall SpriteL90$:	POPM.32	D0|D1|D3|D4|D6|A3|A4	RET; ---	DRAWESPRITE   ---;	DRAWESPRITE n;	-------------;	n:	numro du lutinDODRES:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D0|D3|D4|D6|A3|A4	MOVE.8	{A2}+ODFCOM+0,D6; D6 <-- numro du lutin	MOVE.16	#SPRITE_CLEAR,D0	_GraCall Sprite	POPM.32	D0|D3|D4|D6|A3|A4	RET; ---	DRAWCSPRITE   ---;	DRAWCSPRITE n;	-------------;	n:	numro du lutinDODRCS:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D0|D3|D4|D6|A3|A4	MOVE.8	{A2}+ODFCOM+0,D6; D6 <-- numro du lutin	MOVE.16	#SPRITE_CLOSE,D0	_GraCall Sprite	POPM.32	D0|D3|D4|D6|A3|A4	RET; ---	DRAWPMOUSE   ---;	DRAWPMOUSE ssss cccc;	--------------------;	ssss:	^matrice lutin (set);	cccc:	^matrice fond  (clr)DODRPM:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.32	{A2}+ODFCOM+0,{A2}+ODFPMS; mm ^matrice lutin (set)	MOVE.32	{A2}+ODFCOM+4,{A2}+ODFPMC; mm ^matrice fond  (clr)	RET; ---	DRAWMOUSE   ---;	DRAWMOUSE xx yy ssss cccc o;	---------------------------;	xx:	coordonne x souris;	yy:	coordonne y souris;	ssss:	(*) ^matrice lutin (set);	cccc:	(*) ^matrice fond  (clr);	o:	(*) opration (SPRITE_OPEN/MOVE/CLOSE);;		(*)  -->  n'est plus utilis !DODRMO:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.32	D4	TEST.8	{A2}+ODFNOW	; est-on dans la fentre $DIS_0 ?	JUMP,NE	 R8^L90$	; non => 90$L50$:				; oui =>	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne (x;y)	SWAP.32	D4		; D4 <-- coordonne (y;x)	CALL	MOMOVE		; dplace le lutin de la sourisL90$:	POP.32	D4	RET; ---	DRAWMATRIX   ---;	DRAWMATRIX xx yy pppp m;	-----------------------;	xx:	coordonne x coin suprieur gauche;	yy:	coordonne y coin suprieur gauche;	pppp:	pointeur  la matrice;	m:	modeDODRMX:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D1|D2|D3|D4|D5|A4	MOVE.32	{A2}+ODFCOM+0,D4; D4 <-- coordonne (x;y)	SWAP.32	D4		; D4 <-- coordonne (y;x)	MOVE.32	{A2}+ODFCOM+4,A4; A4 <-- ^matrice	MOVE.8	{A2}+ODFCOM+8,D1; D1 <-- mode	CLR.32	D3	MOVE.8	{A4+},D3	; D3 <-- largeur matrice	JUMP,EQ	 R8^L90$	SWAP.32	D3	MOVE.8	{A4+},D3	; D3 <-- hauteur matrice	JUMP,EQ	 R8^L90$	SWAP.32	D3		; D3 <-- hauteur/largeur (dy;dx)	CLR.16	D5	MOVE.8	D3,D5	SR.8	#3,D5		; D5 <-- Iy (largeur en bytes)	MOVE.8	D3,D2	AND.8	#2'111,D2	; reste ?	JUMP,EQ	 R8^L60$	; non => 60$	INC.16	D5		; oui => compte un de plusL60$:	CLR.16	D2		; D2 <-- mode non invers	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	_GraCall MatrixL90$:	POPM.32	D1|D2|D3|D4|D5|A4	RET; ---	LEFT   ---DOLEFT:	PUSH.16	D0	MOVE.16	{A2}+ODFPX,D0	; D0 <-- position X actuelle	SUB.16	{A2}+ODFCX,D0	; recule d'un caractre	COMP.16	{A2}+ODFC1X,D0	; recul trop loin ?	JUMP,GE	 R8^L80$	; non => 80$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFC1X,D0	; revient au dbutL80$:	MOVE.16	D0,{A2}+ODFPX	POP.16	D0	RET; ---	RIGHT   ---DORIGHT:	PUSHM.16 D0|D1	MOVE.16	{A2}+ODFFDX,D1	SUB.16	{A2}+ODFC2X,D1	; D1 <-- pos  ne pas dpasser	MOVE.16	{A2}+ODFPX,D0	; D0 <-- position actuelle	ADD.16	{A2}+ODFCX,D0	; avance d'un caractre	COMP.16	D1,D0		; est-on trop  droite ?	JUMP,LE	 R8^L90$	; non => 90$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	D1,D0		; va tout  droiteL90$:	MOVE.16	D0,{A2}+ODFPX	POPM.A16 D0|D1	RET; ---	UP   ---DOUP:	PUSH.16	D0	MOVE.16	{A2}+ODFPY,D0	; D0 <-- position Y actuelle	SUB.16	{A2}+ODFCY,D0	; remonte d'une ligne	COMP.16	{A2}+ODFC1Y,D0	; remont trop haut ?	JUMP,GE	 R8^L80$	; non => 80$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	{A2}+ODFC1Y,D0	; remonte tout en hautL80$:	MOVE.16	D0,{A2}+ODFPY	POP.16	D0	RET; ---	DOWN   ---DODOWN:	PUSHM.16 D0|D1	MOVE.16	{A2}+ODFFDY,D1	SUB.16	{A2}+ODFC2Y,D1	; D1 <-- pos  ne pas dpasser	MOVE.16	{A2}+ODFPY,D0	; D0 <-- position actuelle	ADD.16	{A2}+ODFCY,D0	; descend d'un caractre	COMP.16	D1,D0		; est-on trop bas ?	JUMP,LE	 R8^L90$	; non => 90$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	MOVE.16	D1,D0		; va tout en basL90$:	MOVE.16	D0,{A2}+ODFPY	POPM.A16 D0|D1	RET; ---	AFDIR   ---DOADIR:	TCLR.8	{A2}+ODFFLG:#BFVIDI ; vido normale	RET; ---	AFINV   ---DOAINV:	TSET.8	{A2}+ODFFLG:#BFVIDI ; vido inverse	RET; ---	AFTOUT   ---DOTOUT:	TSET.8	{A2}+ODFFLG:#BFTOUT ; affiche tout	RET; ---	AFNORM   ---DONORM:	TCLR.8	{A2}+ODFFLG:#BFTOUT ; excute CR, TAB, etc.	RET; ---	AFFULL   ---DOFULL:	TCLR.8	{A2}+ODFFLG:#BFGREY ; affiche en plein	RET; ---	AFGREY   ---DOGREY:	TSET.8	{A2}+ODFFLG:#BFGREY ; affiche en gris	RET; ---	ROLL   ---DOROLL:	TSET.8	{A2}+ODFMOD:#BFROLL ; fait du roll	TCLR.8	{A2}+ODFMOD:#BSROLL ; "hard" roll	RET; ---	SROLL   ---DOSROL:	TSET.8	{A2}+ODFMOD:#BFROLL ; fait du roll	TSET.8	{A2}+ODFMOD:#BSROLL ; "soft" roll	RET; ---	NOROLL   ---DONORO:	TCLR.8	{A2}+ODFMOD:#BFROLL ; plus de roll	RET; ---	TRUNC   ---DOTRUN:	TSET.8	{A2}+ODFMOD:#BFTRUNC ; tronque les lignes	RET; ---	AUTOCR   ---DOAUCR:	TCLR.8	{A2}+ODFMOD:#BFTRUNC ; ne tronque plus lignes	RET; ---	AUTOEFLI   ---DOAUEF:	TSET.8	{A2}+ODFMOD:#BFEFLI ; efface lignes aprs CR	RET; ---	NOEFLI   ---DONOEF:	TCLR.8	{A2}+ODFMOD:#BFEFLI ; n'efface pas les lignes	RET; ---	GCURS   ---DOGCUR:	TCLR.8	{A2}+ODFMOD:#BFNOCU ; y a un curseur	TCLR.8	{A2}+ODFMOD:#BFPCUR ; grand curseur	RET; ---	PCURS   ---DOPCUR:	TCLR.8	{A2}+ODFMOD:#BFNOCU ; y a un curseur	TSET.8	{A2}+ODFMOD:#BFPCUR ; petit curseur	RET; ---	CURS   ---DOCURS:	TCLR.8	{A2}+ODFMOD:#BFNOCU ; y a un curseur	RET; ---	NOCURS   ---DONOCU:	TSET.8	{A2}+ODFMOD:#BFNOCU ; plus de curseur du tout	RET; ---	AFCVAR   ---DOCVAR:	TCLR.8	{A2}+ODFMOD:#BFCFIX ; chasse variable	RET; ---	AFCFIX   ---DOCFIX:	TSET.8	{A2}+ODFMOD:#BFCFIX ; chasse fixe	RET; ---	AFCCMO   ---DOCCMO:	TSET.8	{A2}+ODFFLG:#BFNCMO ; curseur souris interdit	RET; ---	AFSCMO   ---DOSCMO:	TCLR.8	{A2}+ODFFLG:#BFNCMO ; curseur souris permis	RET; ---	AFFILLT   ---DOFILT:	TCLR.8	{A2}+ODFFLG:#BFFILA ; rempli: test si touche les bords	RET; ---	AFFILLA   ---DOFILA:	TSET.8	{A2}+ODFFLG:#BFFILA ; rempli: va jusque dans les bords	RET; ---	MMODULO   ---DOMODU:	CLR.16	{A2}+ODFADR	; suite de bytes termines	TCLR.8	{A2}+ODFFL2:#BFNOMOD	TEST.8	{A2}+ODFCOM+0	JUMP,EQ	 R8^L90$	TSET.8	{A2}+ODFFL2:#BFNOMODL90$:	RET; ---	IMAENA   ---DOIMAE:	TSET.8	{A2}+ODFFLG:#BFIMAA ; image alpha va exister	JUMP,BS	 R8^L90$	; si existait dj => 90$	CALL	CREIMA		; cre l'image alphanum.L90$:	RET; ---	IMADIS   ---DOIMAD:	TCLR.8	{A2}+ODFFLG:#BFIMAA ; plus d'image alpha	JUMP,BC	 R8^L90$	; si dj plus => 90$	CALL	KILIMA		; supprime l'image alphanum.L90$:	RET; ---	COLORSA	---;	COLORSA rr gg bb;	----------------;	rr:	intensit du rouge;	gg:	intensit du vert;	bb:	intensit du bleuDOCOSA:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	Sm300	PUSHM.32 D3|D4|A4|D6|A3	MOVE.32	{A2}+ODFCPF,D6		; D6.32 <- canal TColor	JUMP,EQ	Exit$	MOVE.32	#2**BTCGive,D3		; Cherche dans la CLUT locale	MOVE.32	#{A2}+ODfCom,A4		; A4 ^R,V,B recherch	MOVE.32	#{A2}+ODfCSA,A3		; A3 ^R,V,B trouv	TCol_	SrcCLUT	JUMP,NS	Exit$	MOVE.32	D4,{A2}+ODFCSF		; On dfinit la couleur SETExit$:	POPM.32	D3|D4|A4|D6|A3.ENDIF	Sm300	RET; ---	COLORCA	---;	COLORCA rr gg bb;	----------------;	rr:	intensit du rouge;	gg:	intensit du vert;	bb:	intensit du bleuDOCOCA:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	Sm300	PUSHM.32 D3|D4|A4|D6|A3	MOVE.32	{A2}+ODFCPF,D6		; D6.32 <- canal TColor	JUMP,EQ	Exit$	MOVE.32	#2**BTCGive,D3		; Cherche dans la CLUT locale	MOVE.32	#{A2}+ODfCom,A4		; A4 ^R,V,B recherch	MOVE.32	#{A2}+ODfCCA,A3		; A3 ^R,V,B trouv	TCol_	SrcCLUT	JUMP,NS	Exit$	MOVE.32	D4,{A2}+ODFCCF		; On dfinit la couleur SETExit$:	POPM.32	D3|D4|A4|D6|A3.ENDIF	Sm300	RET; ---	COLORSR	---;	COLORSR nnnn;	------------;	nnnn:	numroDOCOSR:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	Sm300	PUSHM.32 D3|D4|A4|D6|A3	MOVE.32	{A2}+ODFCPF,D6		; D6.32 <- canal TColor	JUMP,EQ	Exit$	LINK.32	A6,#-LtCC	MOVE.32	#{A6}-LTCC,A3		; A4 ^emplacement bidon	MOVE.32	#2**BTCGive,D3		; Cherche dans la CRET locale d'abord	MOVE.32	{A2}+ODfCom,D4		; D4.32 couleur cherche	MOVE.32	#{A2}+ODfCSA,A4		; A3 ^R,V,B trouv dans la CRET	TCol_	SrcCRET	UNLINK.32 A6	JUMP,EQ	Found$			; Couleur trouve !	COMP.16	#ErTCCDNE,D7		; "Couleur n'existe pas" ?	JUMP,NE	Exit$			; Non => erreur fatale !	CLR.16	D7			; Si oui => on ignore	MOVE.32	#-1,D4			; et on met du NOIR !!!.IF	DebugTColor	JUMP	Found2$.ENDIF	DebugTColorFound$:.IF	DebugTColor	COMP.32	#16,D4	JUMP,LO	Found2$	PUSH.32	D3	PUSH.32	D4	MON	?AFTIM.ASCIZE	"SrcCRET S chan="	MOVE.32	D6,D4	MON	?AFX8	MON	?AFTIM.ASCIZE	" n="	MOVE.32	{A2}+ODFCom,D4	MON	?AFX8	MON	?AFTIM.ASCIZE	" CRET="	MOVE.16	{A4}+0,D4	MON	?AFX4	MON	?AFSPACE	MOVE.16	{A4}+2,D4	MON	?AFX4	MON	?AFSPACE	MOVE.16	{A4}+4,D4	MON	?AFX4	MON	?AFTIM.ASCIZE	" i="	POP.32	D4	MON	?AFX8	MON	?GETCAR	MON	?AFCR	POP.32	D3Found2$:.ENDIF	DebugTColor	MOVE.32	D4,{A2}+ODFCSF		; On dfinit la couleur SETExit$:	POPM.32	D3|D4|A4|D6|A3	TEST.16	D7.ENDIF	Sm300	RET; ---	COLORCR	---;	COLORCR nnnn;	------------;	nnnn:	numroDOCOCR:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	Sm300	PUSHM.32 D3|D4|A4|D6|A3	MOVE.32	{A2}+ODFCPF,D6		; D6.32 <- canal TColor	JUMP,EQ	Exit$	LINK.32	A6,#-LtCC	MOVE.32	#{A6}-LtCC,A3		; A4 ^emplacement bidon	MOVE.32	#2**BTCGive,D3		; Cherche dans la CRET locale	MOVE.32	{A2}+ODfCom,D4		; D4.32 couleur cherche	MOVE.32	#{A2}+ODfCCA,A4		; A4 ^R,V,B trouv dans la CRET	TCol_	SrcCRET	UNLINK.32 A6	JUMP,EQ	Found$			; Couleur trouve !	COMP.16	#ErTCCDNE,D7		; "Couleur n'existe pas" ?	JUMP,NE	Exit$			; Non => erreur fatale !	CLR.16	D7			; Si oui => on ignore	MOVE.32	#0,D4			; et on met du blanc !!!.IF	DebugTColor	JUMP	Found2$.ENDIF	DebugTColorFound$:.IF	DebugTColor	COMP.32	#16,D4	JUMP,LO	Found2$	PUSH.32	D3	PUSH.32	D4	MON	?AFTIM.ASCIZE	"SrcCRET C chan="	MOVE.32	D6,D4	MON	?AFX8	MON	?AFTIM.ASCIZE	" n="	MOVE.32	{A2}+ODFCom,D4	MON	?AFX8	MON	?AFTIM.ASCIZE	" CRET="	MOVE.16	{A4}+0,D4	MON	?AFX4	MON	?AFSPACE	MOVE.16	{A4}+2,D4	MON	?AFX4	MON	?AFSPACE	MOVE.16	{A4}+4,D4	MON	?AFX4	MON	?AFTIM.ASCIZE	" i="	POP.32	D4	MON	?AFX8	MON	?GETCAR	MON	?AFCR	POP.32	D3Found2$:.ENDIF	DebugTColor	MOVE.32	D4,{A2}+ODFCCF		; On dfinit la couleur CLEARExit$:	POPM.32	D3|D4|A4|D6|A3	TEST.16	D7.ENDIF	Sm300	RET; ---	COLORLINK   ---;	COLORLINK nnnn rr gg bb;	-----------------------;	nnnn:	numro;	rr:	intensit du rouge;	gg:	intensit du vert;	bb:	intensit du bleuDOCOLK:	CLR.16	{A2}+ODFADR	; suite de bytes termines	RET; ---	COLORUNLINK   ---;	COLORUNLINK nnnn;	----------------;	nnnn:	numroDOCOUK:	CLR.16	{A2}+ODFADR	; suite de bytes termines	RET; ---	COLOROP   ---;	COLOROP o;	---------;	o:	opration (COLOROPxxx)DOCOOP:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	Sm300	PUSHM.32 D3|D4	MOVE.8	{A2}+ODFCOM,D3	; D3 <-- <o>	COMP.8	#COLOROPPUSH,D3	JUMP,EQ	 R8^PUSH$	COMP.8	#COLOROPPOP,D3	JUMP,EQ	 R8^POP$	COMP.8	#COLOROPFIX,D3	JUMP,EQ FIX$	COMP.8	#COLOROPAJUST,D3	JUMP,EQ AJUST$	MOVE.16	#ERDIOUT,D7	JUMP	EXIT$PUSH$:	CALL	COLORPUSH	; sauve les couleurs	JUMP	EXIT$POP$:	CALL	COLORPOP	; restitue les couleurs;-	JUMP	EXIT$FIX$:AJUST$:EXIT$:	POPM.32	D3|D4.ENDIF	Sm300	RET; ---	COLORFALSE   ---;	COLORFALSE ffff rr gg bb;	------------------------;	ffff:	fausse couleur;	rr:	intensit du rouge;	gg:	intensit du vert;	bb:	intensit du bleuDOCOFA:	CLR.16	{A2}+ODFADR	; suite de bytes termines.IF	Sm300	PUSHM.32 D6|D4|A3|A4	MOVE.32	{A2}+ODFCPF,D6	; Module TColor ouvert ?	JUMP,EQ	Exit$		; Non => on abandonne	MOVE.32	#2**BTCForce,D3	; Mode: on force la fausse couleur	MOVE.32	{A2}+ODFCom+0,D4	; D4.32 <- fausse couleur  modifier	MOVE.32	#{A2}+ODFCom+4,A4	; A4 ^R,V,B 16 bits	TCol_	PutCLUTExit$:	POPM.32 D6|D4|A3|A4.ENDIF	Sm300	RET; ---	DIMWDO	---;	DIMWDO xx yy dxx dyy;	--------------------;	xx:	dbut de la fentre en X;	yy:	dbut de la fentre en Y;	dxx:	largeur de la fentre;	dyy:	hauteur de la fentreDODIMW:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D3	MOVE.16	#ERDIOUT,D7	 ; D7 <-- paramtres trop grand	TEST.8	{A2}+ODFFL2:#BFNOMOD	JUMP,BS	 R8^L20$	AND.16	#16'FFF8,{A2}+ODFCOM+0; aligne xx sur un byte	AND.16	#16'FFF8,{A2}+ODFCOM+4; aligne dxx sur un byte	AND.16	#16'FFFE,{A2}+ODFCOM+2; aligne yy sur un word	AND.16	#16'FFFE,{A2}+ODFCOM+6; aligne dyy sur un wordL20$:	MOVE.16	{A2}+ODFCOM+0,D3 ; D3 <-- xx	ADD.16	{A2}+ODFCOM+4,D3 ; D3 <-- xx + dxx	COMP.16	{A2}+ODFDX,D3	 ; trop large ?	JUMP,HI	 R8^L90$	 ; oui => 90$	MOVE.16	{A2}+ODFCOM+2,D3 ; D3 <-- yy	ADD.16	{A2}+ODFCOM+6,D3 ; D3 <-- yy + dyy	COMP.16	{A2}+ODFDY,D3	 ; trop long ?	JUMP,HI	 R8^L90$	 ; oui => 90$	MOVE.16	{A2}+ODFCOM+0,{A2}+ODFFX  ; mm. xx	MOVE.16	{A2}+ODFCOM+2,{A2}+ODFFY  ; mm. yy	MOVE.16	{A2}+ODFCOM+4,{A2}+ODFFDX ; mm. dxx	MOVE.16	{A2}+ODFCOM+6,{A2}+ODFFDY ; mm. dyy	CALL	WMINMAX		; init min et max (sous-)fentre	CLR.16	D7		; D7 <-- okL90$:	POP.16	D3	RET;--------\\; WMINMAX >;========/; Initialise les variables contenant les positions min/max de la; (sous-)fentre.; in	A2.L	^descripteur; out	-; mod	-WMINMAX:	PUSH.16	D4	MOVE.16	{A2}+ODFX,D4	ADD.16	{A2}+ODFFX,D4	MOVE.16	D4,{A2}+ODFWBX	; init min X	ADD.16	{A2}+ODFFDX,D4	MOVE.16	D4,{A2}+ODFWEX	; init max X	MOVE.16	{A2}+ODFY,D4	ADD.16	{A2}+ODFFY,D4	MOVE.16	D4,{A2}+ODFWBY	; init min Y	ADD.16	{A2}+ODFFDY,D4	MOVE.16	D4,{A2}+ODFWEY	; init max Y	POP.16	D4	RET; ---	SAVWDO	---DOSAVW:	JUMP	WDOSAV		; zone sauvetage <-- fentre; ---	GETWDO	---DOGETW:	JUMP	WDOGET		; fentre <-- zone sauvetage; ---	PROCURS   ---;	PROCURS c;	---------;	c:	caractre (dfinissant la largeur du curseur)DOPROC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D3	MOVE.8	{A2}+ODFCOM+0,D3 ; D3 <-- paramtre "c"	CALL	INVPROC	POP.16	D3	RET; ---	NEWGC   ---;	NEWGC o f ssss t;	----------------;	o:	opration (LOADGC/USEGC/KILLGC);	 :	fonte (normal, spcial, messenger, grec, etc);	ssss:	style (bits 0-7: style/chasse, bits 7-31: construction);	t:	tailleDONEGC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.32 D2|D3	MOVE.8	{A2}+ODFCOM+0,D3 ; D3 <-- opration	MOVE.8	{A2}+ODFCOM+1,D0 ; D0 <-- fonte	MOVE.8	{A2}+ODFCOM+2,D1	SL.32	#8,D1	MOVE.8	{A2}+ODFCOM+3,D1	SL.32	#8,D1	MOVE.8	{A2}+ODFCOM+4,D1	SL.32	#8,D1	MOVE.8	{A2}+ODFCOM+5,D1 ; D1 <-- style	MOVE.8	{A2}+ODFCOM+6,D2 ; D2 <-- taille	COMP.8	#LOADGC,D3	JUMP,EQ	 R8^L30$	COMP.8	#KILLGC,D3	JUMP,EQ	 R8^L40$	CALL	GCUSE		; utilise	JUMP	R8^L90$L30$:	CALL	GCLOAD		; charge	JUMP	R8^L90$L40$:	CALL	GCKILL		; libreL90$:	POPM.32	D2|D3	RET; ---	USEGC   ---;	USEGC f s t;	-----------;	 :	fonte (normal, spcial, messenger, grec, etc);	s:	style (roman, italique, bold, etc);	t:	tailleDOUSGC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D2	MOVE.8	{A2}+ODFCOM+0,D0 ; D0 <-- fonte	MOVE.8	{A2}+ODFCOM+1,D1 ; D1 <-- style	MOVE.8	{A2}+ODFCOM+2,D2 ; D2 <-- taille	CALL	CONVNEWGC	; D0/D1/D2 <-- fst selon nouveau format	CALL	GCUSE	POP.16	D2	RET; ---	LOADGC   ---;	LOADGC f s t;	------------;	 :	fonte (normal, spcial, messenger, grec, etc);	s:	style (roman, italique, bold, etc);	t:	tailleDOLOGC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D2	MOVE.8	{A2}+ODFCOM+0,D0 ; D0 <-- fonte	MOVE.8	{A2}+ODFCOM+1,D1 ; D1 <-- style	MOVE.8	{A2}+ODFCOM+2,D2 ; D2 <-- taille	CALL	CONVNEWGC	; D0/D1/D2 <-- fst selon nouveau format	CALL	GCLOAD	POP.16	D2	RET; ---	KILLGC   ---;	KILLGC f s t;	------------;	 :	fonte (normal, spcial, messenger, grec, etc);	s:	style (roman, italique, bold, etc);	t:	tailleDOKIGC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSH.16	D2	MOVE.8	{A2}+ODFCOM+0,D0 ; D0 <-- fonte	MOVE.8	{A2}+ODFCOM+1,D1 ; D1 <-- style	MOVE.8	{A2}+ODFCOM+2,D2 ; D2 <-- taille	CALL	CONVNEWGC	; D0/D1/D2 <-- fst selon nouveau format	CALL	GCKILL	POP.16	D2	RET; ---	PFIXGC   ---;	PFIXGC nnnn;	-----------;	nnnn:	prfix de 4 lettres au maximum;		- nom<0> si moins de 4 lettres;		- nom si 4 lettres;		- <0> si prfix standard "SYS" ou "100"DOPFGC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.32	{A2}+ODFCOM+0,{A2}+ODFFIX	RET; ---	ASSGC   ---;	ASSGC f s t   f s t	(logique-physique);	-------------------;	 :	fonte (normal, spcial, messenger, grec, etc);	s:	style (roman, italique, bold, etc);	t:	tailleDOASGC:	CLR.16	{A2}+ODFADR	; suite de bytes termines	MOVE.16	#ERDIOUT,D7	RET; ---	MEMGC   ---DOMEGC:	MOVE.16	#ERDIOUT,D7	RET; ---	EFLI   ---DOEFLI:	CALL	ITLLUTIN	; efface lutin-souris si ncessaire	JUMP	AFEFLI; ---	EFEOS   ---DOEFEOS:	JUMP	AFEFEOS; ---	CR   ---DOCR:	PUSHM.16 D0|D1	MOVE.16	{A2}+ODFC1X,{A2}+ODFPX ; rz position en X	MOVE.16	{A2}+ODFFDY,D1	SUB.16	{A2}+ODFC2Y,D1	; D1 <-- pos  ne pas dpasser	MOVE.16	{A2}+ODFPY,D0	; D0 <-- position en Y	ADD.16	{A2}+ODFCY,D0	; ajoute largeur d'un caractre	COMP.16	D1,D0		; trop bas ?	JUMP,LS	 R8^L50$	; non => 50$				; oui =>	COMP.8	#GRACLIP2,{A2}+ODFMGR	JUMP,EQ	 R8^L50$	CALL	CLRLUTIN	; enlve le lutin de la souris	CALL	ROLLCR		; effectue un roll de l'cran	JUMP	R8^L90$L50$:	MOVE.16	D0,{A2}+ODFPY	; mj mouvelle position en Y	TEST.8	{A2}+ODFMOD:#BFEFLI ; efface nouvelle ligne ?	JUMP,EQ	 R8^L90$	; non => 90$	CALL	DOEFLI		; oui => efface tout la ligneL90$:	POPM.A16 D0|D1	RET; ---	EOP   ---DOEOP:	CALL	EFFACE		; efface tout l'cran	MOVE.16	{A2}+ODFC1X,{A2}+ODFPX	MOVE.16	{A2}+ODFC1Y,{A2}+ODFPY ; clear coordonne alpha	CLR.16	{A2}+ODFPGX	CLR.16	{A2}+ODFPGY	; clear coordonne graphique	RET; ---	TAB   ---DOTAB:	PUSHM.16 D2|D3	CLR.32	D2	MOVE.16	{A2}+ODFPX,D2	; D2 <-- position en X	DIV.16	{A2}+ODFCX,D2	; D2 <-- position en car.L10$:	MOVE.8	#SPACE,D3	CALL	AFCODE		; affiche un espace	INC.8	D2	AND.8	#2'111,D2	; position modulo 8 ?	JUMP,NE L10$		; non => 10$	POPM.A16 D2|D3	RET; ---	BELL   ---DOBELL:	RET; ---	BS   ---DOBS:	PUSH.16	D3	CALL	DOLEFT		; recule d'un caractre	MOVE.8	#SPACE,D3	CALL	AFCODE		; affiche un espace	CALL	DOLEFT		; puis recule encore une fois	POP.16	D3	RET; ---	MSPACE   ---;	MSPACE n;	--------;	n:	nombre d'espaces  afficherDOMSPA:	CLR.16	{A2}+ODFADR	; suite de bytes termines	PUSHM.16 D0|D1|D3	MOVE.8	{A2}+ODFCOM,D0	; D0 <-- nb de SPACE  afficher	JUMP,EQ	 R8^L90$	; si zro => 90$L20$:				; si un ou plusieurs =>	MOVE.8	#SPACE,D3	CALL	AFCODE		; affiche qq SPACE(s)	DEC.8	D0	JUMP,NE L20$L90$:	POPM.A16 D0|D1|D3	RET.IF	Sm300.CHAP	Gestion de la couleur;----------\\; COLORPUSH >;==========/; Sauve les couleurs pour dessiner et pour effacer sur le stack.; in	-; out	D7.W	erreur; mod	D7.WCOLORPUSH:	PUSHM.32 D4|A4	MOVE.16	#ERDIOUT,D7	; D7 <-- y'a trop !	TEST.8	{A2}+ODFCMD	JUMP,F	L90$	MOVE.16	{A2}+ODFCNS,D4	COMP.16	{A2}+ODFCMS,D4	; stack tout plein ?	JUMP,HS	 R8^L90$	; oui => 90$	MOVE.32	{A2}+ODFCPS,A4	SL.16	#3,D4		; D4 <-- *(4+2)	ADD.A16	D4,A4		; A4 <-- ^lment sur le stack	MOVE.32	{A2}+ODFCSF,{A4}+0 ; stack <-- fausse couleur pour dessiner	MOVE.32	{A2}+ODFCCF,{A4}+4 ; stack <-- fausse couleur pour effacer	INC.16	{A2}+ODFCNS	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D4|A4	RET;---------\\; COLORPOP >;=========/; Reprend sur le stack les couleurs pour dessiner et pour effacer.; in	-; out	D7.W	erreur; mod	D7.WCOLORPOP:	PUSHM.32 D4|A4	MOVE.16	#ERDIOUT,D7	; D7 <-- c'est vide !	TEST.8	{A2}+ODFCMD	JUMP,F	L90$	MOVE.16	{A2}+ODFCNS,D4	JUMP,EQ	 R8^L90$	; stack vide => 90$	DEC.16	D4	MOVE.16	D4,{A2}+ODFCNS	MOVE.32	{A2}+ODFCPS,A4	SL.16	#3,D4		; D4 <-- *(4+2)	ADD.A16	D4,A4		; A4 <-- ^lment sur le stack	MOVE.32	{A4}+0,{A2}+ODFCSF ; remet fausse couleur pour dessiner	MOVE.32	{A4}+4,{A2}+ODFCCF ; remet fausse couleur pour effacer	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D4|A4	RET.ENDIF	Sm300.CHAP	La souris.IF	Sm300;----------------\\; SetMouseColors  >;----------------/; Redfinit les couleurs de SET et de CLEAR d'un descripteur; pour dessiner la souris. Attention, ne modifie pas ODFCCA; ni ODFCSA.; In:	A2 ^descripteur de fentre; Out:	D7.16 = 0; Mod:	D7.16 FSetMouseColors:	PUSHM.32 D3|D4|D6|A4	TEST.8	{A2}+ODFCMD		; Ecran en couleur ?	JUMP,F	Exit$			; Non => on bche	MOVE.32	{A2}+ODFCPF,D6		; D6.32 <- canal de TColor	JUMP,EQ	Exit$			; Rat !!!	LINK.32	A6,#-LTCC	MOVE.32	#{A6}-LTCC,A4		; A4 ^couleur  trouver;;?	MOVE.32	#Color_PPSMouse,D4	; Nom de la couleur	MOVE.32	#Color_PPSMou,D4	; Nom de la couleur	MOVE.32	#0,D3			; Mode = rien	TCol_	SrcCRET	JUMP,NS	NoSet$			; Pas de couleur SET trouve !!!	MOVE.32	#2**BTCActive,D3	; On utilise la CLUT active	TCol_	SrcCLUT			; et on essaye de trouver une couleur	JUMP,NS	NoSet$	MOVE.32	D4,{A2}+ODFCSF		; On met cette couleur.NoSet$:;;?	MOVE.32	#Color_PPCMouse,D4	; Nom de la couleur	MOVE.32	#Color_PPCMou,D4	; Nom de la couleur	MOVE.32	#0,D3			; Mode = rien	TCol_	SrcCRET	JUMP,NS	NoClr$			; Pas de couleur CLEAR trouve !!!	MOVE.32	#2**BTCActive,D3	; On utilise la CLUT active	TCol_	SrcCLUT			; et on essaye de trouver une couleur	JUMP,NS	NoClr$	MOVE.32	D4,{A2}+ODFCCFNoClr$:	UNLINK.32 A6			; Libre les variables localesExit$:	POPM.32 D3|D4|D6|A4	CLR.16	D7			; JAMAIS d'erreur	RET.ENDIF	Sm300;--------\\; MOMOVE  >;========/; Dplace le lutin de la souris.; in	D4.L	position de la souris;	A2.32	^descripteur de $DIS_0; out	-; mod	D7.WMOMOVE:	PUSHM.32 D0|D3|D6|A3|A4	MOVE.32	D4,{A2}+ODFMPO	CLR.16	D6		; D6 <-- numro du lutin	CALL	MOGETLU		; D3/A4/A3 <-- lutin de la souris	COMP.32	{A2}+ODFMDI,D3	; mme dimensions ?	JUMP,NE	 R8^L30$	COMP.32	{A2}+ODFMPS,A4	; mme ^matrice "set" ?	JUMP,NE	 R8^L30$	COMP.32	{A2}+ODFMPC,A3	; mme ^matrice "clear" ?	JUMP,NE	 R8^L30$				; dplace le lutin =>	TEST.32	D3	JUMP,EQ L90$.IF	Sm300	PUSH.32	{A2}+ODFCSF	; Sauve les couleurs de SET et de CLEAR	PUSH.32	{A2}+ODFCCF	CALL	SetMouseColors	; Dfinit les couleurs SET/CLEAR.ENDIF	Sm300	MOVE.16	#SPRITE_MOVE,D0	_GraCall Sprite.IF	Sm300	POP.32	{A2}+ODFCCF	; Rcupre les couleurs SET/CLEAR	POP.32	{A2}+ODFCSF.ENDIF	Sm300	TCLR.8	{A2}+ODFMFL:#BFMCLR	JUMP	L90$L30$:				; change le lutin =>	PUSH.32	A2	TEST.32	{A2}+ODFMDI	JUMP,EQ	 R8^L40$	PUSHM.32 D3|A3|A4	MOVE.32	{A2}+ODFMDI,D3	MOVE.32	{A2}+ODFMPS,A4	MOVE.32	{A2}+ODFMPC,A3	MOVE.16	#SPRITE_CLOSE,D0.IF	Sm300	PUSH.32	{A2}+ODFCSF	; Sauve les couleurs de SET et de CLEAR	PUSH.32	{A2}+ODFCCF	CALL	SetMouseColors	; Dfinit les couleurs SET/CLEAR.ENDIF	Sm300	_GraCall Sprite.IF	Sm300	POP.32	{A2}+ODFCCF	; Rcupre les couleurs SET/CLEAR	POP.32	{A2}+ODFCSF.ENDIF	Sm300	TSET.8	{A2}+ODFMFL:#BFMCLR	POPM.32	D3|A3|A4L40$:	POP.32	A2	MOVE.32	D3,{A2}+ODFMDI	MOVE.32	A4,{A2}+ODFMPS	MOVE.32	A3,{A2}+ODFMPC	TEST.32	D3	JUMP,EQ	 R8^L90$.IF	Sm300	PUSH.32	{A2}+ODFCSF	; Sauve les couleurs de SET et de CLEAR	PUSH.32	{A2}+ODFCCF	CALL	SetMouseColors	; Dfinit les couleurs SET/CLEAR.ENDIF	Sm300	MOVE.16	#SPRITE_OPEN,D0	_GraCall Sprite.IF	Sm300	POP.32	{A2}+ODFCCF	; Rcupre les couleurs SET/CLEAR	POP.32	{A2}+ODFCSF.ENDIF	Sm300	TCLR.8	{A2}+ODFMFL:#BFMCLRL90$:	POPM.32	D0|D3|D6|A3|A4	RET;--------\\; MOGETLU >;========/; Cherche le lutin  utiliser pour la souris en fonction de sa position.; in	D4.L	position de la souris;	A2.32	^descripteur de $DIS_0; out	D3.L	dimensions du lutin;	A4.32	^matrice "set";	A3.32	^matrice "clear"; mod	D3.L, D7.W, A3.L, A4.LMOGETLU:	PUSHM.32 D0|D1|A1	CLR.16	{A2}+ODFCAM	CLR.8	{A2}+ODFNOM	CALL	MOIFUSE		; fentre avec souris ?	TEST.8	{A2}+ODFNOM	JUMP,NE	 R8^FOUND$	TEST.8	{A2}+ODFNOM	; dj trouv o est souris ?	JUMP,NE	 R8^FOUND$	; oui => FOUND$.IF	SM8	MOVE.32	#R16^D1BASE,A1	CALL	MOIFFREE	; dans $DIS_1 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D2BASE,A1	CALL	MOIFFREE	; dans $DIS_2 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D3BASE,A1	CALL	MOIFFREE	; dans $DIS_3 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D4BASE,A1	CALL	MOIFFREE	; dans $DIS_4 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D11BASE,A1	CALL	MOIFFREE	; dans $DIS_11 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D12BASE,A1	CALL	MOIFFREE	; dans $DIS_12 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D13BASE,A1	CALL	MOIFFREE	; dans $DIS_13 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D14BASE,A1	CALL	MOIFFREE	; dans $DIS_14 ?.ELSE	SM8.IF	(sm324.OR.Cos21).AND.FullPage	MOVE.32	#R16^D1BASE,A1	CALL	MOIFFREE	; dans $DIS_1 ?.ELSE	(sm324.OR.Cos21).AND.FullPage	MOVE.32	#R16^D1BASE,A1	CALL	MOIFFREE	; dans $DIS_1 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D10BASE,A1	CALL	MOIFFREE	; dans $DIS_10 ?	JUMP,EQ	 R8^FOUND$	MOVE.32	#R16^D11BASE,A1	CALL	MOIFFREE	; dans $DIS_11 ?.ENDIF 	ELSE (sm324.OR.Cos21).AND.FullPage.ENDIF	ELSE SM8FOUND$:	TEST.16	{A2}+ODFCAM	; dj trouv le cadrage ?	JUMP,NE	 R8^LUTIN$	; oui => LUTIN$				; non =>	MOVE.8	#"U",{A2}+ODFCAM+0; mm. cadrage vertical U/D	MOVE.8	#"L",D1		; D1 <-- tout  gauche	COMP.16	#1024-(LVIEWX*LARGCX),D4	JUMP,LO	 R8^LEFT$	CLR.8	D1		; D1 <-- dans partie centrale	COMP.16	#LVIEWX*LARGCX,D4	JUMP,LO	 R8^LEFT$	MOVE.8	#"R",D1		; D1 <-- tout  droiteLEFT$:	MOVE.8	D1,{A2}+ODFCAM+1; mm. cadrage horizontal L/RLUTIN$:	CLR.16	D0	MOVE.8	{A2}+ODFNOM,D0	; D0 <-- no fentre o est la souris	JUMP,EQ	 R8^FLECHE$	COMP.8	#7,D0		; fentre des "soft keys" ?	JUMP,EQ	 R8^FLECHE$	; oui => FLECHE$	MOVE.32	{A2}+ODFPDE,A1	; A1 <-- ^descripteurs (32* .L).IF	CPU020	MOVE.32	{A1}+A16^{D0}*4,D0.ELSE	CPU020	SL.16	#2,D0		; D0 <-- *4 car .L	MOVE.32	{A1}+A16^{D0},D0; fentre inoccupe ?.ENDIF	ELSE CPU020	JUMP,EQ	 R8^FLECHE$	; oui => FLECHE$	MOVE.32	D0,A1		; A1 <-- ^descripteur $DIS_n o est la souris	TEST.8	{A1}+ODFFLG:#BFNCMO ; mode "AFCCMO" ?	JUMP,BS	 R8^NIL$	TEST.8	{A1}+ODFFLG:#BFWMOU ; souris "en attente" ?	JUMP,BS	 R8^SABLIER$	TEST.32	{A1}+ODFPMS	; lutin spcial ?	JUMP,EQ	 R8^FLECHE$	; non => FLECHE$				; oui =>	MOVE.32	{A1}+ODFPMS,A4	MOVE.32	{A1}+ODFPMC,A3	JUMP	R8^TAKE$FLECHE$:	MOVE.32	#R16^MSFLECHE,A4	MOVE.32	#0,A3	JUMP	R8^TAKE$SABLIER$:	MOVE.32	#R16^MWFLECHE,A4	MOVE.32	#R16^MVFLECHE,A3	JUMP	R8^TAKE$NIL$:	MOVE.32	#0,A4	MOVE.32	A4,A3;	JUMP	R8^TAKE$; Cherche les dimensions du lutin de la souris.TAKE$:	CLR.32	D3		; D3 <-- init pour dy;dx	MOVE.32	A4,D0	JUMP,EQ	 R8^EXIT$	MOVE.8	{A4}+1,D3	; D3 <-- dy	SWAP.32	D3	MOVE.8	{A4}+0,D3	; D3 <-- dy;dx	ADD.32	#2,A4		; A4 <-- saute dx;dy (2x .B)	MOVE.32	A3,D0	JUMP,EQ	 R8^EXIT$	ADD.32	#2,A3		; A3 <-- saute dx;dy (2x .B)EXIT$:	POPM.32	D0|D1|A1	TEST.16	D7		; retour EQ/NE	RET;--------\; MOIFUSE >;--------/; Cherche si la souris est dans une fentre utilise.; in	D4.L		position de la souris;	A2.32		^descripteur fentre $DIS_0 ou $DIS_20; out	(A2)+ODFNOM.B	no fentre o est la souris;	{A2}+ODFCAM.W	cadrage; mod	D7.WMOIFUSE:	PUSHM.32 D0|A1..A3	MOVE.32	A2,A1		; A1 <-- ^description de $DIS_0 ou $DIS_20	MOVE.32	#{A6}+OBITMAP,A3	MOVE.16	{A6}+ONOVBM,D0	; D0 <-- no du bitmap visible (0..3)	MUL.16	#LBM,D0	ADD.32	D0,A3		; A3 <-- ^table du bitmap visible	CLR.16	D0.IF	SM8	MOVE.8	{A3}+OBMWDO+0,D0	CALL	MOIFONE		; curseur dans $DIS_1,11 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+1,D0	CALL	MOIFONE		; curseur dans $DIS_2,12 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+2,D0	CALL	MOIFONE		; curseur dans $DIS_3,13 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+3,D0	CALL	MOIFONE		; curseur dans $DIS_4,14 ?	JUMP,EQ	 R8^L50$	; oui => 50$.ELSE	SM8.IF	(Sm324.OR.Cos21).AND.FullPage	MOVE.8	{A3}+OBMWDO+0,D0	CALL	MOIFONE		; curseur dans $DIS_1,2,3,4 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+1,D0	CALL	MOIFONE		; curseur dans $DIS_10 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+2,D0	CALL	MOIFONE		; curseur dans $DIS_11 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+3,D0	CALL	MOIFONE		; curseur dans $DIS_12 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+4,D0	CALL	MOIFONE		; curseur dans $DIS_13 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+5,D0	CALL	MOIFONE		; curseur dans $DIS_14 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+6,D0	CALL	MOIFONE		; curseur dans $DIS_15 ?	JUMP,EQ	 R8^L50$	; oui => 50$.ELSE	(Sm324.OR.Cos21).AND.FullPage	MOVE.8	{A3}+OBMWDO+0,D0	CALL	MOIFONE		; curseur dans $DIS_1,2,3,4 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+1,D0	CALL	MOIFONE		; curseur dans $DIS_10,12,14,16 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.8	{A3}+OBMWDO+2,D0	CALL	MOIFONE		; curseur dans $DIS_11,13,15,17 ?	JUMP,EQ	 R8^L50$	; oui => 50$.ENDIF	ELSE (Sm324.OR.Cos21).AND.FullPage.ENDIF	ELSE SM8	MOVE.16	#7,D0	CALL	MOIFONE		; curseur dans $DIS_7 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.16	#8,D0	CALL	MOIFONE		; curseur dans $DIS_8 ?	JUMP,EQ	 R8^L50$	; oui => 50$	MOVE.16	#9,D0	CALL	MOIFONE		; curseur dans $DIS_9 ?	JUMP,NE	 R8^L90$	; non => 90$L50$:	MOVE.16	{A2}+ODFCAD,{A1}+ODFCAM	; mm. cadrage o est souris	MOVE.8	{A2}+ODFNOW,{A1}+ODFNOM	; mm. no wdo o est sourisL90$:	POPM.32	D0|A1..A3	RET;--------\; MOIFONE >;--------/; Teste si les coordonne du curseur donnes dans D4.L; sont dans la fentre dont le pointeur est dans A2.L; in	D4.L	position de la souris;	D0.16	numro de la fentre (0..n); out	EQ	souris dans cette fentre;	 A2.32	 ^descripteur fentre;	NE	souris ailleurs; mod	A2.LMOIFONE:	PUSHM.32 D3|D4	TEST.8	D0	JUMP,NS	 R8^L50$	CALL	GETDESC		; A2 <-- ^descripteur $DIS_n	JUMP,EQ	 R8^L50$	; si fentre n'existe pas => 50$	MOVE.16	{A2}+ODFIX,D3	; D3 <-- X minimum	COMP.16	D3,D4	JUMP,LO	 R8^L50$	ADD.16	{A2}+ODFIDX,D3	; D3 <-- X maximum	COMP.16	D3,D4	JUMP,HS	 R8^L50$	SWAP.32	D4		; D4 <-- y	MOVE.16	{A2}+ODFIY,D3	; D3 <-- Y minimum	COMP.16	D3,D4	JUMP,LO	 R8^L50$	ADD.16	{A2}+ODFIDY,D3	; D3 <-- Y maximum	COMP.16	D3,D4	JUMP,HS	 R8^L50$	SETZ			; retour EQ	JUMP	R8^L90$L50$:	CLRZ			; retour NEL90$:	POPM.32	D3|D4	RET;---------\; MOIFFREE >;---------/; Cherche si la souris est dans une fentre inutilise.; in	D4.L		position de la souris;	A2.32		^descripteur fentre $DIS_0 ou $DIS_20;	A1.32		^description "condense" aprs base du driver; out	(A2)+ODFNOM.B	no fentre o est la souris;	{A2}+ODFCAM.W	cadrage;	D7.16		ok/pas trouv; mod	D7.WMOIFFREE:	PUSHM.32 D1|D4	MOVE.16	#1,D7		; D7 <-- pas trouv	MOVE.16	{A1}+2,D1	; D1 <-- x min	COMP.16	D1,D4	JUMP,LO	 R8^L90$	ADD.16	{A1}+6,D1	; D1 <-- x max	COMP.16	D1,D4	JUMP,HS	 R8^L90$	SWAP.32	D4	MOVE.16	{A1}+0,D1	; D1 <-- y min	COMP.16	D1,D4	JUMP,LO	 R8^L90$	ADD.16	{A1}+4,D1	; D1 <-- y max	COMP.16	D1,D4	JUMP,HS	 R8^L90$	MOVE.16	{A1}+8,{A2}+ODFCAM  ; mm. cadrage	MOVE.8	{A1}+10,{A2}+ODFNOM ; mm. numro fentre	CLR.16	D7		; D7 <-- trouvL90$:	POPM.32	D1|D4	TEST.16	D7		; retour EQ/NE	RET.IF	FullPage.OR.Sm8MSFLECHE:	.8	14,20	.8	2'00000000,2'00000000	.8	2'01000000,2'00000000	.8	2'01100000,2'00000000	.8	2'01110000,2'00000000	.8	2'01111000,2'00000000	.8	2'01111100,2'00000000	.8	2'01111110,2'00000000	.8	2'01111111,2'00000000	.8	2'01111111,2'10000000	.8	2'01111111,2'11000000	.8	2'01111111,2'11100000	.8	2'01111111,2'11110000	.8	2'01111111,2'11111000	.8	2'01111111,2'10000000	.8	2'01110111,2'10000000	.8	2'01100011,2'11000000	.8	2'01000011,2'11000000	.8	2'00000001,2'11100000	.8	2'00000001,2'11000000	.8	2'00000000,2'00000000MWFLECHE:	.8	32,40	.8	2'00000000,2'00000000,2'00000000,2'00000000	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'01111111,2'11111101,2'11101101,2'01010110	.8	2'01111111,2'11111111,2'10111010,2'10101010	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00011100,2'00001111,2'11110000,2'00111000	.8	2'00011100,2'00111000,2'00001100,2'00111000	.8	2'00011100,2'01100000,2'00000010,2'00101000	.8	2'00011100,2'11000000,2'00000001,2'00111000	.8	2'00011100,2'11000000,2'00000001,2'00101000	.8	2'00010100,2'11000000,2'00000001,2'00101000	.8	2'00011100,2'11100000,2'00000011,2'00101000	.8	2'00010100,2'11010100,2'00010101,2'00101000	.8	2'00011100,2'01101010,2'10101010,2'00101000	.8	2'00010100,2'01110101,2'01010110,2'00101000	.8	2'00010100,2'00111010,2'10101100,2'00101000	.8	2'00010100,2'00011101,2'01011000,2'00101000	.8	2'00010100,2'00001110,2'10110000,2'00101000	.8	2'00010100,2'00000111,2'01100000,2'00101000	.8	2'00010100,2'00000011,2'11000000,2'00101000	.8	2'00010100,2'00000011,2'01000000,2'00101000	.8	2'00010100,2'00000110,2'10100000,2'00101000	.8	2'00010100,2'00001100,2'00010000,2'00101000	.8	2'00010100,2'00011000,2'10001000,2'00101000	.8	2'00010100,2'00110000,2'00000100,2'00101000	.8	2'00010100,2'01100000,2'10000010,2'00101000	.8	2'00010100,2'01100000,2'00000010,2'00101000	.8	2'00010100,2'11000000,2'10000001,2'00101000	.8	2'00010100,2'11000001,2'01000001,2'00101000	.8	2'00010100,2'11000010,2'10100001,2'00101000	.8	2'00010100,2'11010101,2'01010101,2'00101000	.8	2'00010100,2'11101010,2'10101011,2'00101000	.8	2'00010100,2'01110101,2'01010110,2'00101000	.8	2'00010100,2'00111010,2'10101100,2'00101000	.8	2'00010100,2'00001111,2'01011000,2'00101000	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'01111111,2'11111111,2'11111011,2'01010110	.8	2'01111111,2'11111111,2'11011110,2'10101010	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00000000,2'00000000,2'00000000,2'00000000MVFLECHE:	.8	32,40	.8	2'01111111,2'11111111,2'11111111,2'11111110	.8	2'11111111,2'11111111,2'11111111,2'11111111	.8	2'11111111,2'11111111,2'11111111,2'11111111	.8	2'11111111,2'11111111,2'11111111,2'11111111	.8	2'11111111,2'11111111,2'11111111,2'11111111	.8	2'01111111,2'11111111,2'11111111,2'11111110	.8	2'00111110,2'11111111,2'11111111,2'01111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111110,2'11111111,2'11111111,2'01111100	.8	2'00111110,2'11111111,2'11111111,2'01111100	.8	2'00111110,2'01111111,2'11111110,2'01111100	.8	2'00111110,2'00111111,2'11111100,2'01111100	.8	2'00111110,2'00011111,2'11111000,2'01111100	.8	2'00111110,2'00001111,2'11110000,2'01111100	.8	2'00111110,2'00001111,2'11110000,2'01111100	.8	2'00111110,2'00011111,2'11111000,2'01111100	.8	2'00111110,2'00111111,2'11111100,2'01111100	.8	2'00111110,2'01111111,2'11111110,2'01111100	.8	2'00111110,2'11111111,2'11111111,2'01111100	.8	2'00111110,2'11111111,2'11111111,2'01111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111111,2'11111111,2'11111111,2'11111100	.8	2'00111110,2'11111111,2'11111111,2'01111100	.8	2'01111111,2'11111111,2'11111111,2'11111110	.8	2'11111111,2'11111111,2'11111111,2'11111111	.8	2'11111111,2'11111111,2'11111111,2'11111111	.8	2'11111111,2'11111111,2'11111111,2'11111111	.8	2'11111111,2'11111111,2'11111111,2'11111111	.8	2'01111111,2'11111111,2'11111111,2'11111110.ELSE	FullPage.OR.Sm8MWFLECHE:	.8	23,27	.8	2'00000000,2'00000000,2'00000000	.8	2'01111111,2'11111111,2'11111100	.8	2'01111010,2'00000000,2'00000100	.8	2'01111111,2'11111111,2'11111100	.8	2'00011000,2'11111110,2'00110000	.8	2'00011001,2'11111111,2'00110000	.8	2'00011011,2'11111111,2'10110000	.8	2'00011011,2'11111111,2'10110000	.8	2'00011010,2'11111110,2'10110000	.8	2'00011001,2'00011001,2'00110000	.8	2'00011000,2'10000010,2'00110000	.8	2'00011000,2'01000100,2'00110000	.8	2'00011000,2'00101000,2'00110000	.8	2'00011000,2'00101000,2'00110000	.8	2'00011000,2'00101000,2'00110000	.8	2'00011000,2'01101100,2'00110000	.8	2'00011000,2'11101110,2'00110000	.8	2'00011001,2'11101111,2'00110000	.8	2'00011011,2'11000111,2'10110000	.8	2'00011011,2'00000011,2'10110000	.8	2'00011010,2'00000000,2'10110000	.8	2'00011001,2'00000001,2'00110000	.8	2'00011000,2'10000010,2'00110000	.8	2'01111111,2'11111111,2'11111100	.8	2'01111010,2'00000000,2'00000100	.8	2'01111111,2'11111111,2'11111100	.8	2'00000000,2'00000000,2'00000000MVFLECHE:	.8	23,27	.8	2'11111111,2'11111111,2'11111110	.8	2'11111111,2'11111111,2'11111110	.8	2'11111111,2'11111111,2'11111110	.8	2'11111111,2'11111111,2'11111110	.8	2'11111111,2'11111111,2'11111110	.8	2'00111111,2'11111111,2'11111000	.8	2'00111111,2'11111111,2'11111000	.8	2'00111111,2'11111111,2'11111000	.8	2'00111111,2'11111111,2'11111000	.8	2'00111111,2'11111111,2'11111000	.8	2'00111111,2'11111111,2'11111000	.8	2'00111101,2'11111111,2'01111000	.8	2'00111100,2'11111110,2'01111000	.8	2'00111100,2'01111100,2'01111000	.8	2'00111100,2'11111110,2'01111000	.8	2'00111101,2'11111111,2'01111000	.8	2'00111111,2'11111111,2'11111000	.8	2'00111111,2'11111111,2'11111000	.8	2'00111111,2'11111111,2'11111000	.8	2'00111111,2'11111111,2'11111000	.8	2'00111111,2'11111111,2'11111000	.8	2'00111111,2'11111111,2'11111000	.8	2'11111111,2'11111111,2'11111110	.8	2'11111111,2'11111111,2'11111110	.8	2'11111111,2'11111111,2'11111110	.8	2'11111111,2'11111111,2'11111110	.8	2'11111111,2'11111111,2'11111110MSFLECHE:	.8	12,17	.8	2'00000000,2'00000000	.8	2'01000000,2'00000000	.8	2'01100000,2'00000000	.8	2'01110000,2'00000000	.8	2'01111000,2'00000000	.8	2'01111100,2'00000000	.8	2'01111110,2'00000000	.8	2'01111111,2'00000000	.8	2'01111111,2'10000000	.8	2'01111111,2'11000000	.8	2'01111110,2'00000000	.8	2'01101110,2'00000000	.8	2'01000111,2'00000000	.8	2'00000111,2'00000000	.8	2'00000011,2'10000000	.8	2'00000011,2'10000000	.8	2'00000000,2'00000000.ENDIF	ELSE FullPage.OR.SM8.EVEN	.CHAP	Gnrateurs de caractres;----------\\; CONVNEWGC >;----------/; Converti "fst" pour les "vieux" appels LOADGC/USEGC/KILLGC.; in	D0.B	fonte;	D1.8	style/chasse;	D2.8	taille; out	D0.B	fonte;	D1.32	style/chasse;	D2.8	taille; mod	D0.B, D1.L, D2.B, D7.WCONVNEWGC:	AND.32	#16'000000FF,D1	TEST.32	D0:#7		; gencar construit ?	JUMP,BC	 R8^L90$	; non => 90$				; oui =>	SL.32	#8,D1	MOVE.8	#"R",D1		; D1 <-- style "Roman"	TEST.32	D1:#8+7	JUMP,BC	 R8^L90$	TSET.32	D1:#7		; D1 <-- chasse "Fixe"L90$:	RET;--------\; GCLOAD  >;========/; Charge un gnrateur en mmoire.; in	A2	^description fentre;	D0.8	fonte;	D1.32	style/chasse;	D2.8	taille; out	D7.16	erreur; mod	D7.16GCLOAD:	PUSHM.32 D0..D6|A1|A3|A4|A5;--DD--	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore;--DD--	NTREL	?UNLOCK		; fin de zone critique;--DD -> dplac plus loin	CALL	SRCEQ		; cherche v. quivalence	TEST.32	D0:#7		; gencar " construire" ?	JUMP,BC L85$		; non => 85$				; oui =>	CALL	GETTGC		; gnrateur  construire dj charg ?	TEST.16	D7	JUMP,NE	 R8^L10$	; non => 10$				; oui =>	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D3,D0	SR.16	#3,D0	TSET.8	{A3}+A16^{D0}:D3; ODFMAP <-- ajoute un bit	JUMP,BS L90$		; si dj l => 90$	INC.8	{A1}+OGCUSE	; une utilisation de plus	JUMP	L90$L10$:	CALL	PUTTGC		; cherche lment libre ds TAGC	TEST.16	D7		; A1 <-- ^dans TAGC	JUMP,NE L90$	MOVE.16	D3,D6		; D6 <-- position dans TAGC	TCLR.32	D0:#7	MOVE.8	D0,D3		; D3 <-- fonte	MOVE.32	D1,D4		; D4 <-- style	MOVE.8	D2,D5		; D5 <-- taille	AND.32	#16'000000FF,D1	CALL	GCHLOAD		; charge le gencar de base	JUMP,EQ	 R8^L40$	; ok => 40$	COMP.16	#1,D7	JUMP,EQ	 R8^L40$	COMP.16	#ERDIGC,D7	JUMP,NE L80$	SR.8	#1,D2		; D2 <-- 1/2 x taille	CALL	GCHLOAD		; charge le gencar 2x plus petit	JUMP,EQ	 R8^L40$	; ok => 40$	COMP.16	#1,D7	JUMP,NE L80$L40$:	TSET.32	D0:#31		; D0 <-- gencar effectivement charg	COMP.16	#1,D7	JUMP,NE	 R8^L42$	TCLR.32	D0:#31		; D0 <-- chargement pas faitL42$:	TEST.16	{A6}+ONBGCS	; module gencar dj charg ?	JUMP,NE	 R8^L50$	; oui => 50$	MOVE.32	#R16^NMGENC,A3	; A3 <-- ^nom du module gencar	PUSHM.32 D1|D3	MOVE.16	#GENCAR_FIRST,D3; D3 <-- code du premier appel	LIB_	OPEN		; charge le module GENCAR	MOVE.16	D1,{A6}+OCHGCS	; mm. canal du module	POPM.32	D1|D3	TEST.16	D7	JUMP,NE L70$L50$:	INC.16	{A6}+ONBGCS	; un gencar soft de plus	MOVE.32	A4,A3	RR.32	#8,D4;;?	GENCAR_	CREATE		; cre un gencar "soft"	GENCAR_	CREAT		; cre un gencar "soft"	RL.32	#8,D4	TEST.16	D7	JUMP,NE	 R8^L70$	COMP.32	A4,A3		; qq chose construit ?	JUMP,EQ	 R8^L80$	; non => 80$	PUSHM.32 D1|D2|A2	MOVE.32	#MTYPCP,D1	; D1 <-- processus courant	MOVE.32	#MTYPBD,D2	; D2 <-- type driver BIOS	MOVE.32	#R16^D0BASE,A2	; A2 <-- ^base de $DIS0	GESMEM	?TRAMEM		; transfre sur compte driver	POPM.32	D1|D2|A2	JUMP,NE	 R8^L70$	MOVE.32	A4,{A1}+OGCPT	; init ^gencar dans TAGC	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D6,D4	SR.16	#3,D4	TSET.8	{A3}+A16^{D4}:D6; ODFMAP <-- ajoute un bit gencar utilis	CLR.16	D7	TEST.32	D0:#31		; D0 <-- gencar effectivement charg ?	JUMP,BC	 R8^L90$	; non => 90$	CALL	GCKILL		; oui => libre le gencar de base	CLR.16	D7	JUMP	R8^L90$L70$:	PUSH.16	D7	CALL	GCKILL		; libre le gencar de base	POP.16	D7L80$:	CLR.8	{A1}+OGCUSE	; libre lment dans TAGC	JUMP	R8^L90$L85$:	AND.32	#16'000000FF,D1	CALL	GCHLOAD		; charge un gencar "hard"	JUMP,EQ	 R8^L90$	COMP.16	#1,D7	JUMP,NE	 R8^L90$	CLR.16	D7		; D7 <-- okL90$:;--DD--	PUSH.16	D7;--DD--	CALL	LOCK		; dbut de zone critique;--DD--	POP.16	D7	POPM.32	D0..D6|A1|A3|A4|A5	TEST.16	D7	RET;--------\; GCHLOAD >;========/; Charge un gnrateur "hard" en mmoire.; in	A2.L	^description fentre;	D0.8	fonte;	D1.32	style/chasse;	D2.8	taille; out	A4.L	^gencar;	D7.16	erreur (1 => chargement inutile); mod	D7.W, A4.LGCHLOAD:	PUSHM.32 D0..D5|A1..A3|A5	CLR.8	D3	TEST.8	D0	JUMP,NE	 R8^L02$	MOVE.8	#"N",D0		; D0 <-- fonte "normal"	INC.8	D3L02$:	TEST.8	D1	JUMP,NE	 R8^L03$	MOVE.8	#"E".OR.2**7,D1	; D1 <-- style "troit/fixe"	INC.8	D3L03$:	TEST.8	D2	JUMP,NE	 R8^L04$	MOVE.8	#DEFTAILLE,D2	; D2 <-- taille par dfaut	INC.8	D3L04$:	TEST.8	D3		; fonte, style ou taille nul ?	JUMP,EQ	 R8^L06$	; non => 06$	CALL	SRCEQ		; oui => cherche v. quivalenceL06$:.IF	Debug	PUSH.32	D4	MON	?AFTIM.ASCIZE	"{GCHLoad"GCAf$:	MON	?AFTIM.ASCIZE	" F="	MOVE.8	D0,D4	MON	?AFX2	MON	?AFTIM.ASCIZE	" S="	MOVE.32	D1,D4	MON	?AFX8	MON	?AFTIM.ASCIZE	" T="	MOVE.8	D2,D4	MON	?AFX2	MON	?AFTIM.ASCIZE	"}"	PUSH.32	D3	MON	?GetCar	POP.32	D3	POP.32	D4.ENDIF	Debug	MOVE.16	#ERDIIL,D7	COMP.8	#99,D2		; taille > 99 ?	JUMP,HI L90$		; oui => erreur (+ de 2 digits)	CALL	GETTGC		; gnrateur dj charg ?	TEST.16	D7	JUMP,NE	 R8^L10$	; non => 10$				; oui =>	MOVE.16	#1,D7		; D7 <-- chargement inutile	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D3,D0	SR.16	#3,D0	TSET.8	{A3}+A16^{D0}:D3; ODFMAP <-- ajoute un bit	JUMP,BS L70$		; si dj l => 70$	INC.8	{A1}+OGCUSE	; une utilisation de plus	CLR.16	D7		; D7 <-- ok, charg	JUMP	L70$L10$:	CALL	PUTTGC		; cherche lment libre ds TAGC	TEST.16	D7		; A1 <-- ^dans TAGC	JUMP,NE L90$	MOVE.16	D3,D5		; D5 <-- numro gn. dans TAGC	CALL	GCCFILE		; A3 <-- ^nom du fichier.IF	Debug	MON	?AFTIM.ASCIZE	"{Load """	PUSH.32	A3	MON	?AFText	POP.32	A3	MON	?AFTIM.ASCIZE	"""} "	PUSH.32	D3	MON	?GetCar	POP.32	D3.ENDIF	Debug	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore ;+++ DD +++	NTREL	?UNLOCK		; fin de zone critique ;+++ DD +++	MOVE.32	#2**BEXNHEAD,D3	; D3 <-- ne charge pas l'en-tte	FOS	?CLOAD		; charge le gnrateur	JUMP,EQ	 R8^L50$	; ok => 50$	XCAR_	CREATE		; cre un gencar quelconque ...	JUMP,NE	 R8^L80$	PUSHM.32 D1|D2|A2	MOVE.32	#MTYPCP,D1	; D1 <-- processus courant	MOVE.32	#MTYPBD,D2	; D2 <-- type driver BIOS	MOVE.32	#R16^D0BASE,A2	; A2 <-- ^base de $DIS0	GESMEM	?TRAMEM		; transfre sur compte driver	POPM.32	D1|D2|A2	INC.8	{A1}+OGCX	; cr par XCARL50$:	PUSH.16	D7						; +++ DD +++;;	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore		; +++ DD +++	CALL	LOCK		; dbut de zone critique	; +++ DD +++	POP.16	D7						; +++ DD +++	MOVE.8	D0,{A1}+OGCNF	MOVE.8	D1,{A1}+OGCNS	MOVE.8	D2,{A1}+OGCNT	MOVE.32	A4,{A1}+OGCPT	; init ^GENCAR dans TAGC	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D5,D0	SR.16	#3,D0	TSET.8	{A3}+A16^{D0}:D5; ODFMAP <-- ajoute un bit gencar utilisL70$:	MOVE.32	{A1}+OGCPT,A4	; A4 <-- ^dbut gencar	JUMP	R8^L90$L80$:	PUSH.16	D7						; +++ DD +++;;	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore		; +++ DD +++	CALL	LOCK		; dbut de zone critique	; +++ DD +++	POP.16	D7						; +++ DD +++	CLR.8	{A1}+OGCUSE	; libre lment dans TAGCL90$:	COMP.16	#ERFDNE,D7	; D7 <-- fichier n'existe pas ?	JUMP,NE	 R8^L95$	; non => 95$	MOVE.16	#ERDIGC,D7	; D7 <-- gencar n'existe pasL95$:	POPM.32	D0..D5|A1..A3|A5	TEST.16	D7		; retour EQ/NE	RET;------------\\; GCMXCARLOAD >;============/; Si ncessaire, charge le module XCAR.; in	-; out	D7.W	erreur; mod	D7.WGCMXCARLOAD:	PUSHM.32 D1|D3|A3	MOVE.16	{A6}+OERGCX,D7	; chargement de XCAR possible ?	JUMP,NE	 R8^L90$	; non => 90$	TEST.16	{A6}+ONBGCX	; module XCAR dj charg ?	JUMP,NE	 R8^L90$	; oui => 90$	MOVE.32	#R16^NMXCAR,A3	; A3 <-- ^nom du module XCAR	MOVE.16	#XCAR_FIRST,D3	; D3 <-- code du premier appel	LIB_	OPEN		; charge le module XCAR	MOVE.16	D1,{A6}+OCHGCX	; mm. canal du module	MOVE.16	D7,{A6}+OERGCX	; OERGCX <-- ok/erreur;	TEST.16	D7	JUMP,NE	 R8^L90$	XCAR_	OPEN		; ouvre XCAR (charge GRAMISC)	;%error	MOVE.16	#1,{A6}+ONBGCX	; module XCAR charg	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D1|D3|A3	TEST.16	D7		; retour EQ/NE	RET;--------\; GCUSE   >;========/; Initialise les paramtres dcrivant les grandeurs d'un; caractre dans la table d'une fentre, en fonction d'un; gnrateur de caractre quelconque.; in	A2.L	^description fentre;	D0.8	fonte;	D1.32	style/chasse;	D2.8	taille; out	D7.W	erreur; mod	D7.WGCUSE:	PUSHM.32 D0..D6|A1|A3	MOVE.8	D0,D4		; D4 <-- fonte	MOVE.32	D1,D5		; D5 <-- style	MOVE.8	D2,D6		; D6 <-- taille	CALL	SRCEQ		; cherche v. quivalence	CALL	GETTGC		; cherche GENCAR dans TAGC	TEST.16	D7	JUMP,NE L90$	MOVE.16	#ERDIGC,D7	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D3,D0	SR.16	#3,D0	TEST.8	{A3}+A16^{D0}:D3; gnrateur utilis ?	JUMP,BC L90$		; non => 90$	TEST.32	D4:#7		; gencar construit ?	JUMP,BC	 R8^L20$	; non => 20$	SR.16	#8,D5L20$:	MOVE.8	D4,{A2}+ODFGCF	MOVE.8	D5,{A2}+ODFGCS	MOVE.8	D6,{A2}+ODFGCT	MOVE.32	{A1}+OGCPT,A1	; A1 <-- ^gnrateur	MOVE.32	A1,{A2}+ODFPGC	; init ^au gnrateur	MOVE.16	{A1}+OGCMWI,{A2}+ODFCX	MOVE.16	{A1}+OGCISP,{A2}+ODFCY	MOVE.16	{A1}+OGCLMA,{A2}+ODFC1X	MOVE.16	{A1}+OGCMH1,{A2}+ODFC1Y	MOVE.16	{A1}+OGCMWI,D0	SUB.16	{A1}+OGCLMA,D0	MOVE.16	D0,{A2}+ODFC2X	MOVE.16	{A1}+OGCMH2,{A2}+ODFC2Y	CLR.16	{A2}+ODFCIX	MOVE.16	{A2}+ODFPX,D0	COMP.16	{A2}+ODFC1X,D0	; position trop  gauche ?	JUMP,HS	 R8^L40$	; non => 40$	MOVE.16	{A2}+ODFC1X,D0	; oui => avance un peuL40$:	MOVE.16	{A2}+ODFFDX,D1	SUB.16	{A2}+ODFC2X,D1	; D1 <-- pos  l'extme droite	COMP.16	D1,D0		; position trop  droite ?	JUMP,LS	 R8^L45$	; non => 45$	MOVE.16	D1,D0		; oui => recule un peuL45$:	MOVE.16	D0,{A2}+ODFPX	; mj la position horizontale	MOVE.16	{A2}+ODFPY,D0	COMP.16	{A2}+ODFC1Y,D0	; position trop haute ?	JUMP,HS	 R8^L50$	; non => 50$	MOVE.16	{A2}+ODFC1Y,D0	; oui => descend un peuL50$:	MOVE.16	{A2}+ODFFDY,D1	SUB.16	{A2}+ODFC2Y,D1	; D1 <-- pos tout en bas	COMP.16	D1,D0		; position trop basse ?	JUMP,LS	 R8^L55$	; non => 55$	MOVE.16	D1,D0		; oui => remonte un peuL55$:	MOVE.16	D0,{A2}+ODFPY	; mj la position verticale	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D0..D6|A1|A3	RET;--------\; GCKILL  >;========/; Supprime un gnrateur en mmoire.; in	A2.L	^description fentre;	D0.8	fonte;	D1.32	style/chasse;	D2.8	taille; out	D7.W	erreur; mod	D7.WGCKILL:	PUSHM.32 D0..D3|A1|A3	CALL	SRCEQ		; cherche v. quivalence	CALL	GETTGC		; cherche GENCAR dans TAGC	TEST.16	D7	JUMP,NE	 R8^L90$	MOVE.16	#ERDIGC,D7	MOVE.32	{A2}+ODFPGC,D0	; D0 <-- ^gencar utilis	COMP.32	{A1}+OGCPT,D0	; gnrateur utilis ?	JUMP,EQ	 R8^L90$	; oui => 90$				; non =>	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D3,D0	SR.16	#3,D0	TCLR.8	{A3}+A16^{D0}:D3; ODFMAP <-- clear bit gencar supprim	JUMP,BC	 R8^L90$	; si dj clear => 90$	CALL	GCKILP		; supprime le gnrateurL90$:	POPM.32	D0..D3|A1|A3	RET;--------\; GCRESET >;========/; Libre tous les gnrateurs utiliss par une fentre.; in	A2.L	^description fentre; out	D7.W	erreur; mod	D7.WGCRESET:	PUSHM.32 D0|D3|A1|A3	MOVE.32	#{A6}+OTAGC,A1	; A1 <-- ^dbut de TAGC	CLR.16	D3		; D3 <-- position dans TAGCL10$:	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D3,D0	SR.16	#3,D0	TEST.8	{A3}+A16^{D0}:D3; gnrateur utilis ?	JUMP,BC	 R8^L50$	; non => 50$				; oui =>	CALL	GCKILP		; supprime un gnrateurL50$:	MOVE.32	#{A1}+LGGC,A1	; A1 <-- ^lment suivant	INC.16	D3		; D3 <-- position suivante	COMP.16	#MAXGC,D3	JUMP,NE L10$	CLR.32	{A2}+ODFMAP+0	; clear TOUT le map	CLR.32	{A2}+ODFMAP+4	POPM.32	D0|D3|A1|A3	RET;--------\; GCKILP  >;--------/; Supprime un gnrateur de caractres.; in	A1.L	^gnrateur  supprimer; out	D7.W	erreur; mod	D7.WGCKILP:	PUSHM.32 D0..D2|A3|A4	DEC.8	{A1}+OGCUSE	; une utilisation de moins	JUMP,NE L90$	TEST.8	{A1}+OGCX	; cr par XCAR ?	JUMP,NE L60$		; oui => 60$	TEST.8	{A1}+OGCF:#7	; gencar " construire" ?	JUMP,BS	 R8^L50$	; oui => 50$				; non =>	MOVE.32	{A1}+OGCPT,A4	; A4 <-- ^gnrateur	MOVE.8	{A1}+OGCNF,D0	MOVE.8	{A1}+OGCNS,D1	MOVE.8	{A1}+OGCNT,D2	CALL	GCCFILE		; A3 <-- ^nom du fichier	FOS	?CUNLOAD	; libre le gnrateur	JUMP	R8^L90$L50$:	MOVE.32	{A1}+OGCPT,A4	; A4 <-- ^gnrateur	PUSH.32	A1	MOVE.32	#MTYPBD,D1	; D1 <-- type driver BIOS	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS0	GESMEM	?GIVMEM		; libre la mmoire du gn.	POP.32	A1	DEC.16	{A6}+ONBGCS	; un gencar soft de moins	JUMP,NE	 R8^L90$	MOVE.16	{A6}+OCHGCS,D1	; D1 <-- canal du module gencar	LIB_	CLOSE		; ferme le module gencar	JUMP	R8^L90$L60$:	MOVE.32	{A1}+OGCPT,A4	; A4 <-- ^gnrateur	PUSH.32	A1	MOVE.32	#MTYPBD,D1	; D1 <-- type driver BIOS	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS0	GESMEM	?GIVMEM		; libre la mmoire du gn.	POP.32	A1L90$:	POPM.32	D0..D2|A3|A4	RET;--------\\; GCCFILE >;--------/; Construit le nom d'un fichier gencar.; in	A2.L	^description de la fentre;	D0.8	fonte;	D1.8	style/chasse;	D2.8	taille; out	A3.L	^nom du fichier; mod	D7.W, A3.LGCCFILE:	PUSHM.32 D0..D4|A4	MOVE.32	#{A2}+ODFNGC,A3	; A3 <-- ^buffer pour construire le nom	TEST.8	{A2}+ODFFIX	; prfix spcial ?	JUMP,NE	 R8^L12$	; oui => 12$L10$:				; non =>	MOVE.32	#R16^NAME$,A4L11$:	MOVE.8	{A4+},{A3+}	; non <-- "SMA"	JUMP,NE L11$	DEC.32	A3	JUMP	R8^L15$L12$:				; prfix spcial =>	COMP.8	#"D",D0	JUMP,EQ	 R8^L13$	COMP.8	#"Q",D0		; fonte de l'imprimante ?	JUMP,NE L10$		; non => 10$L13$:	MOVE.32	#{A2}+ODFFIX,A4	; A4 <-- ^prfix	MOVE.16	#4-1,D4		; D4 <-- lg max du prfixL14$:	MOVE.8	{A4+},D3	JUMP,EQ	 R8^L15$	MOVE.8	D3,{A3+}	; nom <-- prfix variable	DJ.16,NMO  D4,L14$L15$:	MOVE.8	#"_",{A3+}	; nom <-- "_" aprs le prfix	MOVE.8	D0,{A3+}	; nom <-- fonte	MOVE.8	#"P",D3	TCLR.32	D1:#7	JUMP,BC	 R8^L17$	MOVE.8	#"F",D3L17$:	MOVE.8	D1,{A3+}	; nom <-- style	MOVE.8	D3,{A3+}	; nom <-- chasse	CLR.32	D3	MOVE.8	D2,D3		; D3 <-- taille	DIV.16	#10,D3	ADD.8	#"0",D3	MOVE.8	D3,{A3+}	; nom <-- dizaine taille	SWAP.32	D3	ADD.8	#"0",D3	MOVE.8	D3,{A3+}	; nom <-- unit taille	MOVE.32	#R16^EXT$,A4L20$:	MOVE.8	{A4+},{A3+}	; nom <-- ".GENC<0>"	JUMP,NE L20$	MOVE.32	#{A2}+ODFNGC,A3	; A3 <-- ^nom construit	POPM.32	D0..D4|A4	RETNAME$:	.ASCIZ	"SMA"EXT$:	.ASCIZ	".GENC"	.EVEN;--------\; PUTTGC  >;--------/; Cherche une place libre dans TAGC.; in	D0.B	fonte;	D1.32	style/chasse;	D2.8	taille; out	A1.L	^dans TAGC;	D3.16	position dans TAGC;	D0.8	fonte majuscule;	D1.32	style/chasse majuscule;	D7.16	erreur; mod	D3.W, D7.W, A1.LPUTTGC:	MOVE.8	D0,D3	AND.8	#16'7F,D3	; D3 <-- fonte	AND.8	#16'80,D0	; D0 <-- soft	CALL	MINMAJ	OR.8	D3,D0		; D0 <-- style/soft maj.	MOVE.8	D1,D3	AND.8	#16'7F,D3	; D3 <-- style	AND.8	#16'80,D1	; D1 <-- chasse	CALL	MINMAJ	OR.8	D3,D1		; D1 <-- style/chasse maj.	MOVE.32	#{A6}+OTAGC,A1	; A1 <-- ^dbut de TAGC	CLR.16	D3		; D3 <-- position dans TAGCL10$:	TEST.8	{A1}+OGCUSE	; lment libre ?	JUMP,EQ	 R8^L50$	; oui => 50$				; non =>	MOVE.32	#{A1}+LGGC,A1	; A1 <-- ^lment suivant	INC.16	D3		; D3 <-- position suivante	COMP.16	#MAXGC,D3	JUMP,NE L10$	MOVE.16	#ERDIIL,D7	JUMP	R8^L90$L50$:	INC.8	{A1}+OGCUSE	; occupe l'lment (une fois)	MOVE.8	D0,{A1}+OGCF	; mm. la fonte	MOVE.32	D1,{A1}+OGCS	; mm. le style/chasse	MOVE.8	D2,{A1}+OGCT	; mm. la taille	CLR.8	{A1}+OGCX	; pas cr par XCAR	CLR.16	D7		; D7 <-- okL90$:	RET;--------\; GETTGC  >;--------/; Cherche un gnrateur utilis dans TAGC.; (*) la valeur zro permet de trouver n'importe quoi !; in	D0.B	fonte (*);	D1.32	style/chasse (*);	D2.8	taille (*); out	A1.L	^lment dans TAGC trouv;	D3.16	position dans TAGC;	D0.8	fonte majuscule;	D1.8	style/chasse majuscule;	D7.16	erreur; mod	D0.B, D1.B, D3.W, D7.W, A1.LGETTGC:	MOVE.8	D0,D3	AND.8	#16'7F,D3	; D3 <-- fonte	AND.8	#16'80,D0	; D0 <-- soft	CALL	MINMAJ	OR.8	D3,D0		; D0 <-- style/soft maj.	MOVE.8	D1,D3	AND.8	#16'7F,D3	; D3 <-- style	AND.8	#16'80,D1	; D1 <-- chasse	CALL	MINMAJ	OR.8	D3,D1		; D1 <-- style/chasse maj.	MOVE.32	#{A6}+OTAGC,A1	; A1 <-- ^dbut de TAGC	CLR.16	D3		; D3 <-- position dans TAGCL10$:	TEST.8	{A1}+OGCUSE	; lment libre ?	JUMP,NE	 R8^L50$	; non => 50$L20$:				; oui =>	MOVE.32	#{A1}+LGGC,A1	; A1 <-- ^lment suivant	INC.16	D3		; D3 <-- position suivante	COMP.16	#MAXGC,D3	JUMP,NE L10$	MOVE.16	#ERDIGC,D7	JUMP	R8^L90$L50$:	TEST.8	D0		; n'importe quelle fonte ?	JUMP,EQ	 R8^L60$	; oui => 60$	COMP.8	{A1}+OGCF,D0	; fonte correcte ?	JUMP,NE L20$		; non => 20$L60$:	TEST.32	D1		; n'importe quel style ?	JUMP,EQ	 R8^L70$	; oui => 70$	COMP.32	{A1}+OGCS,D1	; style/chasse correct ?	JUMP,NE L20$		; non => 20$L70$:	TEST.8	D2		; n'importe quelle taille ?	JUMP,EQ	 R8^L80$	; oui => 80$	COMP.8	{A1}+OGCT,D2	; taille correcte ?	JUMP,NE L20$		; non => 20$L80$:	test.32	{A1}+OGCPT	; en cours de chargement ?	; +++ DD +++	jump,eq	L20$		; oui -> ignore pour l'instant	; +++ DD +++	CLR.16	D7		; D7 <-- okL90$:	RET;--------\; SRCEQ   >;========/; Cherche une ventuelle quivalence.; Avant la version 5.4, on cherchait dans 100_INFO une table; variable et modifiable par l'utilisateur. Depuis, on se; contente d'une table rduite au stricte minimum (l'idal; serait d'avoir une table vide).; in	D0.B	fonte;	D1.8	style/chasse;	D2.8	taille; out	D7.W	zro (trouv);	 D0.8	 fonte;	 D1.8	 style/chasse;	 D2.8	 taille;	D7.16	autre (pas trouv);	 D0.8	 idem;	 D1.8	 idem;	 D2.8	 idem; mod	D0.L, D1.L, D2.L, D7,WSRCEQ:	PUSHM.32 D3|A3	MOVE.8	D0,D3	AND.8	#16'80,D3	; D0 <-- fonte "soft" ou pas	AND.8	#16'7F,D0	; D0 <-- enlve le bit "soft"	MOVE.32	#R16^TABLE$-(3+3),A3	MOVE.16	#ERDIGC,D7	; D7 <-- "pas trouv" !L20$:	ADD.32	#3+3,A3		; A3 <-- ^suivant	TEST.8	{A3}		; fin de la table ?	JUMP,EQ	 R8^L80$	; oui => 80$	TEST.8	D0	JUMP,EQ	 R8^L30$	COMP.8	{A3}+0,D0	; mme fonte ?	JUMP,NE L20$		; non => 20$L30$:	TEST.8	D1	JUMP,EQ	 R8^L31$	COMP.8	{A3}+1,D1	; mme style ?	JUMP,NE L20$		; non => 20$L31$:	TEST.8	D2	JUMP,EQ	 R8^L32$	COMP.8	{A3}+2,D2	; mme taille ?	JUMP,NE L20$		; non => 20$L32$:	MOVE.8	{A3}+3,D0	; D0 <-- nouvelle fonte	MOVE.8	{A3}+4,D1	; D1 <-- nouveau style	MOVE.8	{A3}+5,D2	; D2 <-- nouvelle taille	CLR.16	D7		; D7 <-- trouvL80$:	OR.8	D3,D0		; D0 <-- remet si fonte "soft" ou pas	POPM.32	D3|A3	TEST.16	D7		; retour EQ/NE	RETTABLE$:	.8	"N","R".OR.2**7,12; NRF12	.8	"N","E".OR.2**7,11; NEF11	.8	"N","E".OR.2**7,12; NEF12	.8	"N","E".OR.2**7,11; NEF11	.8	"S","N".OR.2**7,12; SNF12	.8	"S","N".OR.2**7,11; SNF11	.8	0	.EVEN;--------\; MINMAJ  >;========/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMINMAJ:	TEST.32	D3:#7		; code "supplmentaire" ?	JUMP,NE	 R8^L20$	; oui => 20$	COMP.8	#SPACE-2,D3	; lettre accentue ?	JUMP,LO	 R8^L50$	; oui => 50$	COMP.8	#"a",D3	JUMP,LO	 R8^L20$	COMP.8	#"z",D3		; minuscule non accentue ?	JUMP,HI	 R8^L20$	; non => 20$	SUB.8	#"a"-"A",D3	; oui => transformeL20$:	RETL50$:	COMP.8	#"",D3	JUMP,LO L20$	PUSH.16	D0	SUB.8	#"",D3	CLR.16	D0	MOVE.8	D3,D0	MOVE.8	R8^L70$+A16^{D3},D3; D3 <-- lettre majuscule	POP.16	D0	RETL70$:	.8	"U","A","A","E","E","E","E","I","I","O","U","U","A","O","C"	.EVEN.CHAP	Routines typographiques;--------\; AFCODE  >;========/; Affiche un caractre sans tenir compte des caractres;   ciaux.; in	D3.B	caractre  afficher;	A2.32	^description de la fentre; out	D7.W	erreur; mod	D7.WAFCODE:	PUSHM.32 D0..D5|A3|A4L10$:	MOVE.32	{A2}+ODFPGC,A3	; A3 <-- ^GENCAR; Cherche quel est le caractre  afficher, d'aprs le premier caractre; contenu dans le gnrateur (OGCFCA).	CLR.16	D0	MOVE.8	D3,D0		; D0 <-- code du caractre	COMP.8	{A3}+OGCLCA,D0	; code caractre trop grand ?	JUMP,HI L90$		; oui => 90$	SUB.8	{A3}+OGCFCA,D0	; code caractre trop petit ?	JUMP,LO L90$		; oui => 90$; Calcule la position sup/gauche et les dimensions du pav contenant; le caractre. La largeur dpend du caractre.	MOVE.32	{A2}+ODFPY,D4	; D4 <-- coordonne (y;x)	SUB.16	{A2}+ODFC1X,D4	; D4 <-- coordonne  gauche	SWAP.32	D4	SUB.16	{A2}+ODFC1Y,D4	; D4 <-- coordonne en haut	SWAP.32	D4	MOVE.16	{A2}+ODFC1Y,D2	ADD.16	{A2}+ODFC2Y,D2	; D2 <-- hauteur du caractre	SWAP.32	D2	CLR.16	D2	MOVE.32	#{A3}+OGCWID,A4	; A4 <-- ^table des largeurs	MOVE.8	{A4}+A16^{D0},D2; D2 <-- largeur du caractre; Vrifie si le caractre dborde sur la droite.	COMP.8	#GRACLIP2,{A2}+ODFMGR	JUMP,EQ	 R8^L20$	MOVE.16	D4,D1	ADD.16	D2,D1	COMP.16	{A2}+ODFFDX,D1	; dpasse  droite ?	JUMP,LO	 R8^L20$	; non => 20$				; oui =>	MOVE.16	#ERDIOUT,D7	; D7 <-- "out of screen"	TEST.8	{A2}+ODFMOD:#BFTRUNC	JUMP,NE L90$	CALL	DOCR		; passe  la ligne	JUMP	L10$; Vrifie si le caractre recouvre la souris, sans utiliser ITCLUTIN; pour aller plus vite !L20$:	MOVE.32	{A6}+OLSTPD,A4	; A4 <-- ^descripteur o est la souris	TEST.8	{A4}+ODFMFL:#BFMCLR ; lutin dj enlev ?	JUMP,BS	 R8^L32$	; oui => 32$	MOVE.32	D4,D5	ADD.16	{A2}+ODFWBX,D5	ADD.16	D2,D5	MOVE.16	{A4}+ODFMPO+2,D1 ; D1 <-- X min	COMP.16	D1,D5	JUMP,LO	 R8^L32$	SUB.16	D2,D5	ADD.16	{A4}+ODFMDI+2,D1 ; D1 <-- X max	COMP.16	D1,D5	JUMP,HS	 R8^L32$	SWAP.32	D2	SWAP.32	D5	ADD.16	{A2}+ODFWBY,D5	ADD.16	D2,D5	MOVE.16	{A4}+ODFMPO+0,D1 ; D1 <-- Y min	COMP.16	D1,D5	JUMP,LO	 R8^L30$	SUB.16	D2,D5	ADD.16	{A4}+ODFMDI+0,D1 ; D1 <-- Y max	COMP.16	D1,D5	JUMP,HS	 R8^L30$	CALL	CLRLUTIN	; enlve le lutin de la sourisL30$:	SWAP.32	D2; Si l'image alphanumrique existe, ne le caractre dedans.L32$:	TEST.8	{A2}+ODFFLG:#BFIMAA ; image alphanum. existe ?	JUMP,BC	 R8^L40$	; non => 40$	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE	 R8^L40$	; non => 40$				; oui =>	CALL	GPTIMA		; A4 <-- ^dans image	JUMP,NE	 R8^L40$	; si erreur => 40$	MOVE.8	D3,{A4}		; image <-- mm. caractre; Calcule les paramtres permettant d'appeler directement GRA2_RASTER, et; non GRA2_MATRIX, pour aller plus vite !L40$:	CLR.32	D3		; D3 <-- position dans source	CLR.16	D5	MOVE.8	{A3}+OGCMWB,D5	; D5 <-- incrment Y ds GENCAR	CLR.32	D1	MOVE.8	{A3}+OGCLCA,D1	SUB.8	{A3}+OGCFCA,D1	INC.8	D1		; D1 <-- nb car dans gnrateur	MOVE.32	#{A3}+OGCWID,A4	; A4 <-- ^table des largeurs	ADD.32	D1,A4		; A4 <-- skip width(s)	ADD.32	D1,A4		; A4 <-- swip heigth(s) above baseline	ADD.32	D1,A4		; A4 <-- swip heigth(s) under baseline	MUL.16	{A3}+OGCMSB,D0	; * matrix size (in bytes)	ADD.32	D0,A4		; A4 <-- ^matrix dans GENCAR	MOVE.32	A4,A3		; A3 <-- ^source	MOVE.32	#0,A4		; A4 <-- ^destination (dans l'cran)	MOVE.8	{A2}+ODFMCA,D1	; D1 <-- mode d'affichage	COMP.8	#SETDOT,D1	JUMP,NE	 R8^L50$	MOVE.8	#LOADDOT,D1L50$:	TCLR.32	D1:#BPENDOT	TEST.8	{A2}+ODFFLG:#BFVIDI ; vido inverse ?	JUMP,BC	 R8^L52$	TSET.32	D1:#BCPLDOTL52$:	TEST.8	{A2}+ODFFLG:#BFGREY ; affiche en gris ?	JUMP,BC	 R8^L53$	TSET.32	D1:#BGREDOTL53$:	AND.32	#2**BCplDot.OR.2**BGreDot.OR.(2'11),D1	_GraCall Raster; Avance la position du caractre plus loin vers la droite.	TEST.8	{A2}+ODFMOD:#BFCFIX ; chasse fixe ?	JUMP,EQ	 R8^L70$	; non => 70$	MOVE.16	{A2}+ODFCX,D2	; D2 <-- espace intercaractresL70$:	ADD.16	{A2}+ODFPX,D2	; D2 <-- nouvelle position en X	ADD.16	{A2}+ODFCIX,D2	; ajoute incrment +/-	MOVE.16	D2,{A2}+ODFPX	; mj mouvelle position en XL90$:	POPM.32	D0..D5|A3|A4	RET;--------\; AFEFEOS >;========/; Efface l'cran depuis la position actuelle du curseur; jusqu' la fin.; in	A2.L	^description fentre; out	-; mod	D7.WAFEFEOS:	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE	 R8^L10$	; non => 10$	CALL	EOSIMA		; rempli fin image de SPACEsL10$:	_GraCall EfEOS	RET;--------\; AFEFLI  >;========/; Efface une ligne depuis la position actuelle du curseur; jusqu' la fin.; in	A2.L	^description fentre; out	-; mod	D7.WAFEFLI:	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE	 R8^L10$	; non => 10$	CALL	EFLIMA		; oui => fait aussi dans imageL10$:	_GraCall EFLI	RET.CHAP	Scrolls et compagnie;--------\; ROLLCR  >;========/; Effectue un dcalage de toutes les lignes d'une fentre; du bas vers le haut si l'on est en mode roll. Autrement,; remet le curseur tout en haut.; in	A2.L	^description d'une fentre; out	D7.W	ERDIROL; mod	D7.WROLLCR:	PUSHM.32 D0|D1|D2|D3|D4	TEST.8	{A2}+ODFMOD:#BFROLL ; roll de l'cran	JUMP,BS	 R8^L20$	; oui => 20$				; non =>	MOVE.16	{A2}+ODFC1X,{A2}+ODFPX	MOVE.16	{A2}+ODFC1Y,{A2}+ODFPY	TEST.8	{A2}+ODFMOD:#BFEFLI	JUMP,EQ L90$L10$:	CALL	DOEFLI		; efface la premire ligne	JUMP	L90$L20$:	MOVE.16	{A2}+ODFFDY,D1	SUB.16	{A2}+ODFC2Y,D1	; D1 <-- position la plus basse	MOVE.16	D1,D2		; D2 <-- futur position en Y	SUB.16	{A2}+ODFCY,D1	; D1 <-- position ligne n-1	JUMP,NS L10$	MOVE.16	{A2}+ODFPY,D4	SUB.16	D1,D4		; D4 <-- nb points  "roller"	MOVE.16	D2,{A2}+ODFPY	; init nouvelle position Y	TEST.32	D4:#0		; D4 pair ?	JUMP,EQ	 R8^L30$	; oui => 30$	INC.16	D4		; non => roll un peu plus grand	DEC.16	{A2}+ODFPY	; remonte pos ds dernire ligneL30$:	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE	 R8^L40$	; non => 40$	MOVE.16	D4,D0		; D0 <-- nb points  "roller"	CALL	ROLIMA		; roll image alphanumriqueL40$:	TEST.8	{A2}+ODFMOD:#BSROLL	JUMP,BS	 R8^L50$	_GraCall RollUp	JUMP	L90$L50$:	CLR.32	D1	MOVE.16	D4,D1		; D1 <-- amplitude du roll	JUMP,EQ	 R8^L90$	MOVE.16	#4,D3		; fait le roll en 4 fois (!)	SR.16	D1		; D1 <-- nb de roll minimaux	DIV.16	D3,D1		; D1 <-- ampl. de chaque roll	MOVE.32	D1,D2	SWAP.32	D2		; D2 <-- resteL60$:	MOVE.16	D1,D4	TEST.16	D2		; reste encore qq chose ?	JUMP,EQ	 R8^L65$	; non => 65$	DEC.16	D2		; oui =>	INC.16	D4		; fait un de + pour compenserL65$:	TEST.16	D4		; roll nul ?	JUMP,EQ	 R8^L70$	; oui => 70$	SL.16	D4		; toujours multiple de 2 !	_GraCall RollUpL70$:	DEC.16	D3	JUMP,NE L60$L90$:	MOVE.16	#ERDIROL,D7	; D7 <-- "roll done"	POPM.32	D0|D1|D2|D3|D4	RET;--------\\; EFFACE  >;========/; Efface toute la fentre.; in	A2.L	^description de la fentre; out	-; mod	D7.WEFFACE:	PUSHM.32 D3|D4|A4	CALL	OPIMA?		; image alphanum. existe ?	JUMP,NE	 R8^L10$	; non => 10$	CALL	CLRIMA		; rempli image alpha de SPACEsL10$:	CLR.32	D4		; D4 <-- origine (sous-)fentre	MOVE.32	{A2}+ODFFDY,D3	; D3 <-- dimensions (sous-)fentre	_GraCall Clear	POPM.32	D3|D4|A4	RET.IF	FullPage;--------\\; GRISE   >;========/; Grise toute la fentre.; in	A2.L	^description de la fentre; out	-; mod	D7.WGRISE:	PUSHM.32 D1|D3|D4|A4	CLR.32	D4		; D4 <-- origine (sous-)fentre	MOVE.32	{A2}+ODFFDY,D3	; D3 <-- dimensions (sous-)fentre	MOVE.16	#SETDOT,D1	; D1 <-- mode	MOVE.32	#R16^L00$,A4	; A4 <-- ^trame	_GraCall Clear	_GraCall Trame	POPM.32	D1|D3|D4|A4	RETL00$:	.32	TRAGRIS	.32	TRAGRIS.ENDIF	FullPage;---------\; SHOWLEFT >;=========/; Transfre les deux fentres $DIS7 et $DIS8  gauche.; in	A1.L	^table d'initialisation de l'cran; out	-; mod	-SHOWLEFT:.IF	.NOT.FullPage.IF	UseRaster	PUSHM.32 D0..D7|A0..A4.ELSE	UseRaster	PUSHM.32 D0|D1|A0|A1|A2.ENDIF	ELSE UseRaster	MOVE.16	#7,D0	CALL	GETDESC		; A2 <-- ^descripteur $DIS_7	JUMP,EQ	 R8^L02$.IF	Sm300	MOVE.16	#2,{A2}+ODFX	; nouvelle origine en X	MOVE.16	#2,{A2}+ODFIX	; nouvelle origine en X ; +++ DD +++.ELSE	Sm300	CLR.16	{A2}+ODFX	; nouvelle origine en X	CLR.16	{A2}+ODFIX	; nouvelle origine en X ; +++ DD +++.ENDIF	ELSE Sm300	CALL	WMINMAX		; init min et max (sous-)fentreL02$:	MOVE.16	#8,D0	CALL	GETDESC		; A2 <-- ^descripteur $DIS_8	JUMP,EQ	 R8^L03$.IF	Sm300	MOVE.16	#2,{A2}+ODFX	; nouvelle origine en X	MOVE.16	#2,{A2}+ODFIX	; nouvelle origine en X ; +++ DD +++.ELSE	Sm300	CLR.16	{A2}+ODFX	; nouvelle origine en X	CLR.16	{A2}+ODFIX	; nouvelle origine en X ; +++ DD +++.ENDIF	ELSE Sm300	CALL	WMINMAX		; init min et max (sous-)fentreL03$:	MOVE.16	#9,D0	CALL	GETDESC		; A2 <-- ^descripteur $DIS_9	JUMP,EQ	 R8^L04$	MOVE.16	#SEPX89,{A2}+ODFX	MOVE.16	#SEPX89,{A2}+ODFIX ; +++ DD +++	CALL	WMINMAX		; init min et max (sous-)fentreL04$:	MOVE.32	{A6}+OPDFEN+(4*0),A2 ; A2 <-- ^descripteur $DIS_0.IF	UseRaster	MOVE.32	#(16'10000*(PViewY-SepY17))+PViewX,D2; Dimensions du transfert	MOVE.32	#(16'10000*SepY17)+0,D4		; Destination	MOVE.32	#(16'10000*SepY17)+1024-PViewX,D3; Source	MOVE.32	#0,A3				; ^source	MOVE.32	#0,A4				; ^destination	MOVE.32	#LoadDot,D1			; Mode de transfert	_GraCall Raster				; On dplace les softkeys	MOVE.32	#(16'10000*SepY81)+PViewX,D2	; Dimensions du transfert	MOVE.32	#0,D4				; Destination	MOVE.32	#1024-PViewX,D3			; Source	MOVE.32	#0,A3				; ^source	MOVE.32	#0,A4				; ^destination	MOVE.32	#LoadDot,D1			; Mode de transfert	_GraCall Raster				; On dplace la ligne du haut.ELSE	UseRaster	MOVE.32	{A2}+ODFABS,A0	MOVE.32	#{A0}+(1024-PVIEWX)/8,A1.IF	Sm300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor$	MOVE.32	#{A0}+(1024-PVIEWX)/2,A1NoColor$:.ENDIF	Sm300	MOVE.16	#SEPY81,D1L10$:	MOVE.16	#(PVIEWX/8)/2,D0.IF	Sm300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor2$	MOVE.16	#(PViewX/2)/2,D0NoColor2$:.ENDIF	Sm300	PUSHM.32 A0|A1L15$:	MOVE.16	{A1+},{A0+}	; dcale une ligne  gauche	DEC.16	D0	JUMP,NE L15$	POPM.32	A0|A1.IF	Sm300	ADD.A16	{A2}+ODFIIY,A0	ADD.A16	{A2}+ODFIIY,A1.ELSE	Sm300	ADD.A16	#128,A0	ADD.A16	#128,A1.ENDIF	ELSE Sm300	DEC.16	D1	JUMP,NE L10$	MOVE.32	{A2}+ODFABS,A0	MOVE.16	#PViewY-LargCY*4,D0	MUL.16	{A2}+ODFIIY,D0	ADD.32	D0,A0	MOVE.16	#1024-PViewX,D0	SR.16	D0.IF	Sm300	TEST.8	{A2}+ODFCMD	JUMP,T	R8^Color$	SR.16	#2,D0Color$:.ENDIF	Sm300	MOVE.A16 D0,A1	ADD.32	A0,A1	MOVE.16	#LARGCY*4,D1L20$:	MOVE.16	#(PVIEWX/8)/2,D0.IF	Sm300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor3$	MOVE.16	#(PViewX/2)/2,D0NoColor3$:.ENDIF	Sm300	PUSHM.32 A0|A1L25$:	MOVE.16	{A1+},{A0+}	; dcale une ligne  gauche	DEC.16	D0	JUMP,NE L25$	POPM.32	A0|A1.IF	Sm300	ADD.A16	{A2}+ODFIIY,A0	ADD.A16	{A2}+ODFIIY,A1.ELSE	Sm300	ADD.A16	#128,A0	ADD.A16	#128,A1.ENDIF	ELSE Sm300	DEC.16	D1	JUMP,NE L20$.ENDIF	ELSE UseRaster	MOVE.32	{A2}+ODFABS,D0	; D0 <-- adresse du bitmap.IF	Sm300	MOVE.32	#PosIDLG,D1	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor4$	ADD.32	D1,D1	ADD.32	D1,D1NoColor4$:	ADD.32	D1,D0.ELSE	Sm300	ADD.32	#POSIDLG,D0.ENDIF	ELSE Sm300	MOVE.32	D0,_VINCIDL	MOVE.8	#"L",{A2}+ODFCAD+1; mm cadrage = left	CLR.16	{A2}+ODFCAX	; X coin sup/gauche = 0.IF	UseRaster	POPM.32 D0..D7|A0..A4.ELSE	UseRaster	POPM.32 D0|D1|A0|A1|A2.ENDIF	ELSE UseRaster.ENDIF	.NOT.FullPage	RET;----------\; SHOWRIGHT >;==========/; Transfre les deux fentres $DIS7 et $DIS8  droite.; in	A1.L	^table d'initialisation de l'cran; out	-; mod	-SHOWRIGHT:.IF	.NOT.FullPage.IF	UseRaster	PUSHM.32 D0..D7|A0..A4.ELSE	UseRaster	PUSHM.32 D0|D1|A0|A1|A2.ENDIF	ELSE UseRaster	MOVE.16	#7,D0	CALL	GETDESC		; A2 <-- ^descripteur $DIS_7	JUMP,EQ	 R8^L02$.IF	Sm300	MOVE.16	#(1024-PVIEWX)+2,{A2}+ODFX	MOVE.16	#(1024-PVIEWX)+2,{A2}+ODFIX ; +++ DD +++.ELSE	Sm300	MOVE.16	#1024-PVIEWX,{A2}+ODFX	MOVE.16	#1024-PVIEWX,{A2}+ODFIX ; +++ DD +++.ENDIF	ELSE Sm300	CALL	WMINMAX		; init min et max (sous-)fentreL02$:	MOVE.16	#8,D0	CALL	GETDESC		; A2 <-- ^descripteur $DIS_8	JUMP,EQ	 R8^L03$.IF	Sm300	MOVE.16	#(1024-PVIEWX)+2,{A2}+ODFX	MOVE.16	#(1024-PVIEWX)+2,{A2}+ODFIX ; +++ DD +++.ELSE	Sm300	MOVE.16	#1024-PVIEWX,{A2}+ODFX	MOVE.16	#1024-PVIEWX,{A2}+ODFIX ; +++ DD +++.ENDIF	ELSE Sm300	CALL	WMINMAX		; init min et max (sous-)fentreL03$:	MOVE.16	#9,D0	CALL	GETDESC		; A2 <-- ^descripteur $DIS_9	JUMP,EQ	 R8^L04$	MOVE.16	#1024-PVIEWX+SEPX89,{A2}+ODFX	MOVE.16	#1024-PVIEWX+SEPX89,{A2}+ODFIX ; +++ DD +++	CALL	WMINMAX		; init min et max (sous-)fentreL04$:	MOVE.32	{A6}+OPDFEN+(4*0),A2 ; A2 <-- ^descripteur $DIS_0.IF	UseRaster	MOVE.32	#(16'10000*(PViewY-SepY17))+PViewX,D2; Dimensions du transfert	MOVE.32	#(16'10000*SepY17)+0,D3		; Source	MOVE.32	#(16'10000*SepY17)+1024-PViewX,D4; Destination	MOVE.32	#0,A3				; ^source	MOVE.32	#0,A4				; ^destination	MOVE.32	#LoadDot,D1			; Mode de transfert	_GraCall Raster				; On dplace les softkeys	MOVE.32	#(16'10000*SepY81)+PViewX,D2	; Dimensions du transfert	MOVE.32	#0,D3				; Source	MOVE.32	#1024-PViewX,D4			; Destination	MOVE.32	#0,A3				; ^source	MOVE.32	#0,A4				; ^destination	MOVE.32	#LoadDot,D1			; Mode de transfert	_GraCall Raster				; On dplace la ligne du haut.ELSE	UseRaster.IF	Sm300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^BlackAndWhite$	MOVE.32	{A2}+ODFABS,A0	MOVE.32	#{A0}+PVIEWX/2,A0	MOVE.32	#{A0}+(1024-PVIEWX)/2,A1	JUMP	R8^Next$BlackAndWhite$:.ENDIF	Sm300	MOVE.32	{A2}+ODFABS,A0	MOVE.32	#{A0}+PVIEWX/8,A0	MOVE.32	#{A0}+(1024-PVIEWX)/8,A1.IF	Sm300Next$:.ENDIF	Sm300	MOVE.16	#SEPY81,D1L10$:	MOVE.16	#(PVIEWX/8)/2,D0.IF	Sm300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor1$	ADD.16	D0,D0	ADD.16	D0,D0NoColor1$:.ENDIF	Sm300	PUSHM.32 A0|A1L15$:	MOVE.16	{-A0},{-A1}	; dcale une ligne  droite	DEC.16	D0	JUMP,NE L15$	POPM.32	A0|A1.IF	Sm300	ADD.A16	{A2}+ODFIIY,A0	ADD.A16	{A2}+ODFIIY,A1.ELSE	Sm300	ADD.A16	#128,A0	ADD.A16	#128,A1.ENDIF	ELSE Sm300	DEC.16	D1	JUMP,NE L10$.IF	Sm300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^BlackAndWhite2$	MOVE.32	{A2}+ODFABS,A0	ADD.32	#512*(PViewY-LargCY*4),A0	MOVE.32	#{A0}+PVIEWX/2,A0	MOVE.32	#{A0}+(1024-PVIEWX)/2,A1	JUMP	R8^Next2$BlackAndWhite2$:.ENDIF	Sm300	MOVE.32	{A2}+ODFABS,A0	ADD.32	#128*(PVIEWY-LARGCY*4),A0	MOVE.32	#{A0}+PVIEWX/8,A0	MOVE.32	#{A0}+(1024-PVIEWX)/8,A1.IF	Sm300Next2$:.ENDIF	Sm300	MOVE.16	#LARGCY*4,D1L20$:	MOVE.16	#(PVIEWX/8)/2,D0.IF	Sm300	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor2$	ADD.16	D0,D0	ADD.16	D0,D0NoColor2$:.ENDIF	Sm300	PUSHM.32 A0|A1L25$:	MOVE.16	{-A0},{-A1}	; dcale une ligne  droite	DEC.16	D0	JUMP,NE L25$	POPM.32	A0|A1.IF	Sm300	ADD.A16	{A2}+ODFIIY,A0	ADD.A16	{A2}+ODFIIY,A1.ELSE	Sm300	ADD.A16	#128,A0	ADD.A16	#128,A1.ENDIF	ELSE Sm300	DEC.16	D1	JUMP,NE L20$.ENDIF	ELSE UseRaster	MOVE.32	{A2}+ODFABS,D0	; D0 <-- adresse du bitmap.IF	Sm300	MOVE.32	#PosIDLD,D1	TEST.8	{A2}+ODFCMD	JUMP,F	R8^NoColor4$	ADD.32	D1,D1	ADD.32	D1,D1NoColor4$:	ADD.32	D1,D0.ELSE	Sm300	ADD.32	#POSIDLD,D0.ENDIF	ELSE Sm300	MOVE.32	D0,_VINCIDL	MOVE.8	#"R",{A2}+ODFCAD+1; mm cadrage = right	MOVE.16	#1024-PVIEWX,{A2}+ODFCAX ; X coin sup/gauche.IF	UseRaster	POPM.32 D0..D7|A0..A4.ELSE	UseRaster	POPM.32 D0|D1|A0|A1|A2.ENDIF	ELSE UseRaster.ENDIF	.NOT.FullPage	RET.IF	(FondBlanc.AND.FullPage).OR.Sm300;--------\\; COINS   >;========/; Arrondi les 4 coins du bitmap.; in	A2	^descripteur bitmap ($DIS_0); out	-; mod	D7.16 FCOINS:	PUSHM.32 D0..D5|A3|A4	MOVE.32	#1,D5		; rowBytes source	MOVE.32	#LoadDot,D1	; Mode de transfert	MOVE.32	#0,A4		; ^destination	CLR.32	D3		; Origine source..IF	Sm300	MOVE.32	#5*16'10000+5,D2; Dimensions du transfert.ELSE	Sm300	MOVE.32	#8*16'10000+8,D2; Dimensions du transfert.ENDIF	ELSE Sm300	MOVE.32	#R16^UL$,A3	; En haut  gauche	MOVE.32	#0,D4	_GraCall Raster	MOVE.32	#R16^UR$,A3	; En haut  droite.IF	Sm300	MOVE.32	#PViewX-5,D4.ELSE	Sm300	MOVE.32	#PViewX-8,D4.ENDIF	ELSE Sm300	_GraCall Raster	MOVE.32	#R16^DL$,A3	; En bas  gauche.IF	Sm300	MOVE.32	#16'10000*(PViewY-5),D4.ELSE	Sm300	MOVE.32	#16'10000*(PViewY-8),D4.ENDIF	ELSE Sm300	_GraCall Raster	MOVE.32	#R16^DR$,A3	; En bas  droite.IF	Sm300	MOVE.32	#16'10000*(PViewY-5)+(PViewX-5),D4.ELSE	Sm300	MOVE.32	#16'10000*(PViewY-8)+(PViewX-8),D4.ENDIF	ELSE Sm300	_GraCall Raster	POPM.32	D0..D5|A3|A4	RET.IF	Sm300UL$:	.8	2'11111000	.8	2'11000000	.8	2'10000000	.8	2'10000000	.8	2'10000000UR$:	.8	2'11111000	.8	2'00011000	.8	2'00001000	.8	2'00001000	.8	2'00001000DL$:	.8	2'10000000	.8	2'10000000	.8	2'10000000	.8	2'11000000	.8	2'11111000DR$:	.8	2'00001000	.8	2'00001000	.8	2'00001000	.8	2'00011000	.8	2'11111000.ELSE	Sm300UL$:	.8	2'11111110	.8	2'11111000	.8	2'11100000	.8	2'11000000	.8	2'11000000	.8	2'10000000	.8	2'10000000	.8	2'00000000UR$:	.8	2'01111111	.8	2'00011111	.8	2'00000111	.8	2'00000011	.8	2'00000011	.8	2'00000001	.8	2'00000001	.8	2'00000000DL$:	.8	2'00000000	.8	2'10000000	.8	2'10000000	.8	2'11000000	.8	2'11000000	.8	2'11100000	.8	2'11111000	.8	2'11111110DR$:	.8	2'00000000	.8	2'00000001	.8	2'00000001	.8	2'00000011	.8	2'00000011	.8	2'00000111	.8	2'00011111	.8	2'01111111.ENDIF	ELSE Sm300.EVEN.ENDIF	(FondBlanc.AND.FullPage).OR.Sm300.CHAP	DisHard ???;--------\; CLRCURS >;========/; in	A2.L	^description de la fentre; out	-; mod	-CLRCURS:	PUSH.16	D0	TEST.8	{A2}+ODFMOD:#BFNOCU	JUMP,NE	 R8^L90$	TCLR.8	{A2}+ODFFLG:#BFCURS ; curseur dj enlev ?	JUMP,EQ	 R8^L90$	; oui => 90$				; non =>	MOVE.16	{A2}+ODFC1X,D0	ADD.16	{A2}+ODFC2X,D0	; D0 <-- largeur curseur	CALL	INVCURSL90$:	POP.16	D0	RET;--------\; SETCURS >;========/; in	A2.L	^description de la fentre; out	-; mod	-SETCURS:	PUSHM.32 D0|A0	TEST.8	{A2}+ODFMOD:#BFNOCU	JUMP,NE	 R8^L50$	TSET.8	{A2}+ODFFLG:#BFCURS ; curseur dj l ?	JUMP,NE	 R8^L50$	; oui => 50$				; non =>	MOVE.16	{A2}+ODFC1X,D0	ADD.16	{A2}+ODFC2X,D0	; D0 <-- largeur curseur	CALL	INVCURSL50$:	MOVE.32	{A6}+OLSTPD,A0	; A0 <-- ^descripteur o est la souris	TEST.8	{A0}+ODFMFL:#BFMCLR	JUMP,BC	 R8^L90$	CALL	IMCURS		; remet le curseur sourisL90$:	POPM.32	D0|A0	RET;---------\; ITCLUTIN >;=========/; Test si un caractre interrompt, mme partiellement, le; lutin de la souris. Si oui, enlve le lutin de la souris.; in	A2.L	^description de la fentre; out	-; mod	D7.WITCLUTIN:	PUSHM.32 D2|D3|D4|A0	MOVE.32	{A6}+OLSTPD,A0	; A0 <-- ^descripteur o est la souris	TEST.8	{A0}+ODFMFL:#BFMCLR ; lutin dj enlev ?	JUMP,BS	 R8^L90$	; oui => 90$	MOVE.32	{A0}+ODFMPO,D4	; D4 <-- (Y;X) min	MOVE.32	{A2}+ODFWBY,D3	; D3 <-- (Y;X) fentre	ADD.16	{A2}+ODFPX,D3	; D3 <-- X curseur	MOVE.16	D3,D2	ADD.16	{A2}+ODFC2X,D3	COMP.16	D4,D3	JUMP,LO	 R8^L90$	ADD.16	{A0}+ODFMDI+2,D4 ; D4 <-- X max	MOVE.16	D2,D3	SUB.16	{A2}+ODFC1X,D3	COMP.16	D4,D3	JUMP,HS	 R8^L90$	SWAP.32	D4		; D4 <-- Y min	SWAP.32	D3		; D3 <-- Y fentre	ADD.16	{A2}+ODFPY,D3	; D3 <-- Y curseur	MOVE.16	D3,D2	ADD.16	{A2}+ODFC2Y,D3	COMP.16	D4,D3	JUMP,LO	 R8^L90$	ADD.16	{A0}+ODFMDI+0,D4 ; D4 <-- Y max	MOVE.16	D2,D3	SUB.16	{A2}+ODFC1Y,D3	COMP.16	D4,D3	JUMP,HS	 R8^L90$	CALL	CLRLUTIN	; enlve le lutin de la sourisL90$:	POPM.32	D2|D3|D4|A0	RET;---------\; ITLLUTIN >;=========/; Test si une ligne interrompt, mme partiellement, le; lutin de la souris. Si oui, enlve le lutin de la souris.; in	A2.L	^description de la fentre; out	-; mod	D7.WITLLUTIN:	PUSHM.32 D2|D3|D4|A0	MOVE.32	{A6}+OLSTPD,A0	; A0 <-- ^descripteur o est la souris	TEST.8	{A0}+ODFMFL:#BFMCLR ; lutin dj enlev ?	JUMP,BS	 R8^L90$	; oui => 90$	MOVE.16	{A0}+ODFMPO+0,D4 ; D4 <-- Y min	MOVE.16	{A2}+ODFWBY,D3	; D3 <-- Y fentre	ADD.16	{A2}+ODFPY,D3	; D3 <-- Y curseur	MOVE.16	D3,D2	ADD.16	{A2}+ODFC2Y,D3	COMP.16	D4,D3	JUMP,LO	 R8^L90$	ADD.16	{A0}+ODFMDI+0,D4 ; D4 <-- Y max	MOVE.16	D2,D3	SUB.16	{A2}+ODFC1Y,D3	COMP.16	D4,D3	JUMP,HS	 R8^L90$	CALL	CLRLUTIN	; enlve le lutin de la sourisL90$:	POPM.32	D2|D3|D4|A0	RET;---------\\; ITELUTIN >;=========/; Test si une ellipse graphique du type (y;x)/(ry;rx) interrompt,; mme partiellement, le lutin de la souris.; Si oui, enlve le lutin de la souris.; in	A2.L	^description de la fentre;	D4.32	coordonne (y;x);	D3.32	rayons (ry;rx);	D1.8	mode (utile si pinceau, car plus large); out	-; mod	D7.WITELUTIN:	PUSHM.32 D3|D4	SUB.16	D3,D4		; D4 <-- met X  gauche	ASL.16	#1,D3		; D3 <-- rayon X *2	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,D4		; D4 <-- met Y en haut	ASL.16	#1,D3		; D3 <-- rayon Y *2	SWAP.32	D3	SWAP.32	D4	CALL	ITGLUTIN	; efface lutin-souris si ncessaire	POPM.32	D3|D4	RET;---------\; ITGLUTIN >;=========/; Test si un objet graphique du type (y;x)/(dy;dx) interrompt,; mme partiellement, le lutin de la souris.; Si oui, enlve le lutin de la souris.; in	A2.L	^description de la fentre;	D4.32	coordonne (y;x);	D3.32	dimensions (dy;dx) positives ou ngatives;	D1.8	mode (utile si pinceau, car plus large); out	-; mod	D7.WITGLUTIN:	PUSHM.32 D2|D3|D4|A0	MOVE.32	{A6}+OLSTPD,A0	; A0 <-- ^descripteur o est la souris	TEST.8	{A0}+ODFMFL:#BFMCLR ; lutin dj enlev ?	JUMP,BS	 R8^L90$	; oui => 90$	TEST.16	D3		; dX positif ?	JUMP,NC	 R8^L20$	NEG.16	D3		; D3 <-- |dX|	SUB.16	D3,D4		; D4 <-- reculeL20$:	TEST.32	D1:#BPENDOT	; utilise le pinceau ?	JUMP,BC	 R8^L25$	; non => 25$	SUB.16	#8/2,D4	ADD.16	#8,D3L25$:	MOVE.32	{A0}+ODFMPO,D2	; D2 <-- min Y;X souris	ADD.16	{A2}+ODFWBX,D4	; D4 <-- min X graphique	ADD.16	D3,D4		; D4 <-- max X graphique	COMP.16	D2,D4	JUMP,LT	 R8^L90$	ADD.16	{A0}+ODFMDI+2,D2 ; D2 <-- max X souris	SUB.16	D3,D4		; D4 <-- min X graphique	COMP.16	D2,D4	JUMP,GE	 R8^L90$	SWAP.32	D2		; D2 <-- min Y souris	SWAP.32	D3		; D3 <-- dY graphique	SWAP.32	D4		; D4 <-- Y graphique	TEST.16	D3		; dY positif ?	JUMP,NC	 R8^L40$	NEG.16	D3		; D3 <-- |dY|	SUB.16	D3,D4		; D4 <-- reculeL40$:	TEST.32	D1:#BPENDOT	; utilise le pinceau ?	JUMP,BC	 R8^L45$	; non => 45$	SUB.16	#8/2,D4	ADD.16	#8,D3L45$:	ADD.16	{A2}+ODFWBY,D4	; D4 <-- min Y graphique	ADD.16	D3,D4		; D4 <-- max Y graphique	COMP.16	D2,D4	JUMP,LT	 R8^L90$	ADD.16	{A0}+ODFMDI+0,D2 ; D2 <-- max Y souris	SUB.16	D3,D4		; D4 <-- min Y graphique	COMP.16	D2,D4	JUMP,GE	 R8^L90$	CALL	CLRLUTIN	; enlve le lutin de la sourisL90$:	POPM.32	D2|D3|D4|A0	RET;---------\; CLRLUTIN >;=========/; Enlve le lutin (flche) de la souris.; in	A2.L	^descripteur fentre; out	-; mod	-CLRLUTIN:	PUSH.32	A0	MOVE.32	{A6}+OLSTPD,A0	; A0 <-- ^descripteur o est la souris	TEST.8	{A0}+ODFMFL:#BFMCLR	JUMP,BS	 R8^L10$	CALL	IMCURS		; enlve le curseur sourisL10$:	POP.32	A0	RET;--------\; IMCURS  >;--------/; Inverse le curseur de la souris plac dans la fentre; principale $DIS_0 pendant une opration (write) dans une; autre fentre.; Pour cela, il faut remplir les conditions suivantes:;   -	la fentre ne doit pas tre $DIS_0 ni $DIS_20;   -	le curseur souris doit tre dans la fentre concerne; in	A2.L	^descripteur fentre; out	-; mod	-IMCURS:	PUSHM.32 D0|D3|D4|D6|A0|A1|A2|A3|A4	TEST.8	{A2}+ODFNOW	; fentre $DIS_0 ?	JUMP,EQ L90$		; oui => 90$				; non =>	MOVE.32	{A6}+OLSTPD,A1	; A1 <-- ^descripteur o est la souris	TEST.32	{A1}+ODFMDI	; lutin-souris existe ?	JUMP,EQ L90$		; non => 90$				; oui =>	CLR.16	D4	MOVE.8	{A2}+ODFCAD+0,D4	JUMP,EQ	 R8^L30$	SUB.8	#"1",D4		; D4 <-- 0..3	COMP.16	{A6}+ONOVBM,D4	; fentre dans bitmap visible ?	JUMP,NE L90$		; non => 90$L30$:	MOVE.32	{A1}+ODFMPO,D4	; D4 <-- coordonne (y;x)	MOVE.16	{A2}+ODFX,D3	; D3 <-- X minimum	ADD.16	{A1}+ODFMDI+2,D4 ; tient compte grandeur curseur	COMP.16	D3,D4	JUMP,LO	 R8^L90$	ADD.16	{A2}+ODFDX,D3	; D3 <-- X maximum	SUB.16	{A1}+ODFMDI+2,D4 ; tient compte grandeur curseur	COMP.16	D3,D4	JUMP,HS	 R8^L90$	SWAP.32	D4		; D4 <-- coordonne (x;y)	MOVE.16	{A2}+ODFY,D3	; D3 <-- Y minimum	ADD.16	{A1}+ODFMDI+0,D4 ; tient compte grandeur curseur	COMP.16	D3,D4	JUMP,LO	 R8^L90$	ADD.16	{A2}+ODFDY,D3	; D3 <-- Y maximum	SUB.16	{A1}+ODFMDI+0,D4 ; tient compte grandeur curseur	COMP.16	D3,D4	JUMP,HS	 R8^L90$	SWAP.32	D4		; D4 <-- coordonne (y;x)	TEST.8	{A2}+ODFFLG:#BFNCMO ; curseur souris permis ?	JUMP,NE	 R8^L90$	; non => 90$				; oui =>	MOVE.32	{A1}+ODFMPS,A4	; A4 <-- ^matrice "set"	MOVE.32	{A1}+ODFMPC,A3	; A3 <-- ^matrice "clear"	MOVE.32	{A1}+ODFMPO,D4	; D4 <-- coordonne (y;x)	MOVE.32	{A1}+ODFMDI,D3	; D3 <-- dimensions du lutin	CLR.16	D6		; D6 <-- numro du lutin	MOVE.16	#SPRITE_CLEAR,D0; D0 <-- enlve le lutin	TNOT.8	{A1}+ODFMFL:#BFMCLR	JUMP,BC	 R8^L70$	MOVE.16	#SPRITE_SET,D0	; D0 <-- remet le lutinL70$:	MOVE.32	A1,A2		; A2 <-- ^description $DIS_0 ou 20.IF	Sm300	PUSH.32	{A2}+ODFCSF	; Sauve les couleurs de SET et de CLEAR	PUSH.32	{A2}+ODFCCF	CALL	SetMouseColors	; Dfinit les couleurs SET/CLEAR.ENDIF	Sm300	_GraCall Sprite.IF	Sm300	POP.32	{A2}+ODFCCF	; Rcupre les couleurs SET/CLEAR	POP.32	{A2}+ODFCSF.ENDIF	Sm300L90$:	POPM.32	D0|D3|D4|D6|A0|A1|A2|A3|A4	RET;---------\; IMACURS0 >;---------/; Enlve le curseur de la souris plac dans la fentre; principale $DIS_0 pendant une opration (write) dans une; autre fentre, quelque soit sa position.; in	-; out	-; mod	-IMACURS0:	PUSHM.32 D0|D3|D4|D6|A0|A1|A2|A3|A4	MOVE.32	{A6}+OLSTPD,A1	; A1 <-- ^descripteur o est la souris	TSET.8	{A1}+ODFMFL:#BFMCLR	JUMP,BS	 R8^L90$	TEST.32	{A1}+ODFMDI	; lutin-souris existe ?	JUMP,EQ	 R8^L90$	; non => 90$				; oui =>	MOVE.32	{A1}+ODFMPS,A4	; A4 <-- ^matrice "set"	MOVE.32	{A1}+ODFMPC,A3	; A3 <-- ^matrice "clear"	MOVE.32	{A1}+ODFMPO,D4	; D4 <-- coordonne (y;x)	MOVE.32	{A1}+ODFMDI,D3	; D3 <-- dimensions du lutin	CLR.16	D6		; D6 <-- numro du lutin	MOVE.16	#SPRITE_CLOSE,D0; D0 <-- ferme le lutin	MOVE.32	A1,A2		; A2 <-- ^description $DIS_0 ou 20.IF	Sm300	PUSH.32	{A2}+ODFCSF	; Sauve les couleurs de SET et de CLEAR	PUSH.32	{A2}+ODFCCF	CALL	SetMouseColors	; Dfinit les couleurs SET/CLEAR.ENDIF	Sm300	_GraCall Sprite.IF	Sm300	POP.32	{A2}+ODFCCF	; Rcupre les couleurs SET/CLEAR	POP.32	{A2}+ODFCSF.ENDIF	Sm300	CLR.32	{A1}+ODFMDIL90$:	POPM.32	D0|D3|D4|D6|A0|A1|A2|A3|A4	RET;---------\; IMACURS1 >;---------/; Remet le curseur de la souris plac dans la fentre; principale $DIS_0 pendant une opration (write) dans une; autre fentre, quelque soit sa position.; in	-; out	-; mod	-IMACURS1:	PUSH.32	A0	MOVE.32	{A6}+OLSTPD,A0	; A0 <-- ^descripteur o est la souris	TCLR.8	{A0}+ODFMFL:#BFMCLR	POP.32	A0	RET;--------\; INVPROC >;========/; Dessine un curseur en fonction de la largeur d'un caractre; donne dans le gnrateur.; in	D3.B	caractre;	A2.32	^description de la fentre; out	-; mod	-INVPROC:	PUSHM.32 D0|A1	CLR.16	D0	MOVE.8	D3,D0		; D0 <-- caractre	MOVE.32	{A2}+ODFPGC,A1	; A1 <-- ^dbut GENCAR	SUB.8	{A1}+OGCFCA,D0	; D0 <-- offset pour largeur	MOVE.32	#{A1}+OGCWID,A1	; A1 <-- ^largeurs	MOVE.8	{A1}+A16^{D0},D0; D0 <-- largeur	CALL	INVCURS		; met un curseur variable	POPM.32	D0|A1	RET;--------\; INVCURS >;========/; in	A2.L	^description de la fentre;	D0.16	largeur du curseur; out	-; mod	-INVCURS:	PUSHM.32 D1|D3|D4|A0|A4	TEST.8	{A2}+ODFNOW	; est-on dans $DIS_0 ?	JUMP,EQ L90$		; oui => 90$	CALL	ITCLUTIN	; enlve lutin souris si intersection	TEST.8	{A2}+ODFMOD:#BFPCUR ; petit curseur soulign ?	JUMP,NE	 R8^L50$	; oui => 50$				; non =>	MOVE.16	{A2}+ODFPY,D4	SUB.16	{A2}+ODFC1Y,D4	SWAP.32	D4	MOVE.16	{A2}+ODFPX,D4	SUB.16	{A2}+ODFC1X,D4	; D4 <-- coord. coin sup/gauche	MOVE.16	{A2}+ODFC1Y,D3	ADD.16	{A2}+ODFC2Y,D3	SWAP.32	D3	MOVE.16	D0,D3		; D3 <-- dimensions caractre	MOVE.8	#INVDOT,D1	; D1 <-- inverse le curseur	MOVE.32	#R16^L00$,A4	; A4 <-- ^trame pleine	_GraCall Trame	JUMP	R8^L90$L50$:				; inverse un curseur soulign:	MOVE.16	{A2}+ODFPY,D4	ADD.16	{A2}+ODFC2Y,D4	SUB.16	#2,D4	SWAP.32	D4	MOVE.16	{A2}+ODFPX,D4	SUB.16	{A2}+ODFC1X,D4	; D4 <-- coord. coin inf/gauche	MOVE.16	#2,D3	SWAP.32	D3	MOVE.16	D0,D3		; D3 <-- dimensions soulign	MOVE.8	#INVDOT,D1	; D1 <-- inverse le curseur	MOVE.32	#R16^L00$,A4	; A4 <-- ^trame pleine	_GraCall TrameL90$:	POPM.32	D1|D3|D4|A0|A4	RETL00$:	.8	2'11111111	; trame "pleine"	.8	2'11111111	.8	2'11111111	.8	2'11111111	.8	2'11111111	.8	2'11111111	.8	2'11111111	.8	2'11111111; Gestion de l'image alphanumrique d'une fentre; -----------------------------------------------;--------\; OPIMA?  >;========/; Vrifie s'il est permis d'utiliser l'image alphanumrique.; Pour cela, les trois conditions suivantes doivent tre; remplies:;  1)	Est-ce que l'image alpha existe ?;  2)	Est-ce que les caractres utiliss sont de la;	bonne grandeur ?;  3)	Est-ce qu'il s'agit de la bonne sous-fentre ?; in	A2.L	^description d'une fentre; out	NE	pas possible d'utiliser l'image;	EQ	ok; mod	-OPIMA?:	PUSHM.32 D4|A4	TEST.8	{A2}+ODFFLG:#BFIMAA ; image alphanum. existe ?	NOTZ	JUMP,NE	 R8^L90$	; non => retour NE	MOVE.32	{A2}+ODFPIM,A4	; A4 <-- ^base de l'image	MOVE.16	{A4}+OIMACX,D4	; D4 <-- largeur cars. ds image	COMP.16	{A2}+ODFCX,D4	; idem au gencar utilis ?	JUMP,NE	 R8^L90$	; non => 90$	MOVE.16	{A4}+OIMACY,D4	; D4 <-- hauteur cars. ds image	COMP.16	{A2}+ODFCY,D4	; idem au gencar utilis ?	JUMP,NE	 R8^L90$	; non => 90$	MOVE.16	{A4}+OIMASX,D4	COMP.16	{A2}+ODFFX,D4	; mme sous-fentre ?	JUMP,NE	 R8^L90$	; non => 90$	MOVE.16	{A4}+OIMASY,D4	COMP.16	{A2}+ODFFY,D4	JUMP,NE	 R8^L90$	MOVE.16	{A4}+OIMALX,D4	COMP.16	{A2}+ODFFDX,D4	JUMP,NE	 R8^L90$	MOVE.16	{A4}+OIMALY,D4	COMP.16	{A2}+ODFFDY,D4;	JUMP,NE	 R8^L90$L90$:	POPM.32	D4|A4	RET;--------\; GPTIMA  >;========/; Calcul le ^dans l'image alphanumrique associe  une; fentre en fonction des coordonnes du curseur typo.; in	A2.L	^description de la fentre; out	EQ	ok, ^dans A4;	 A4.32	 ^absolu dans l'image;	NE	erreur quelconque, A4 non valide; mod	D7.W, A4.LGPTIMA:	PUSHM.32 D0|D1	MOVE.16	#ERDIOUT,D7	; D7 <-- erreur pour retour NE	MOVE.32	{A2}+ODFPIM,A4	; A4 <-- ^base de l'image	CLR.32	D0	MOVE.16	{A2}+ODFPX,D0	; D0 <-- pos. X curseur typo	DIV.16	{A4}+OIMACX,D0	; D0 <-- pos. X dans image	COMP.16	{A4}+OIMADX,D0	; trop loin ?	JUMP,HS	 R8^L90$	; oui => 90$	CLR.32	D1	MOVE.16	{A2}+ODFPY,D1	; D1 <-- pos. Y curseur typo	SUB.16	{A4}+OIMAOY,D1	; soustrait offset Y ventuel	JUMP,LO	 R8^L90$	; si trop haut => 90$	DIV.16	{A4}+OIMACY,D1	; D1 <-- pos. Y dans image	COMP.16	{A4}+OIMADY,D1	; trop loin ?	JUMP,HS	 R8^L90$	; oui => 90$	MOVE.16	D0,{A4}+OIMAPX	; init position X	MOVE.16	D1,{A4}+OIMAPY	; init position Y	MUL.16	{A4}+OIMADX,D1	; D1 <-- pos. dbut bonne ligne	AND.32	#16'FFFF,D0	ADD.32	D0,D1		; D1 <-- pos. ok dans ligne	ADD.32	#LGIMA,D1	; D1 <-- ajoute offset fixe	ADD.32	D1,A4		; A4 <-- ^dans l'image	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D0|D1	TEST.16	D7		; retour EQ/NE	RET;--------\; ROLIMA  >;========/; Effectue un roll (dcalage d'une ligne vers le haut) dans; l'image alphanumrique.; in	A2.L	^description de la fentre;	D0.16	lg du roll; out	-; mod	-ROLIMA:	PUSHM.32 D0|D1|A3|A4	MOVE.32	{A2}+ODFPIM,A4	; A4 <-- ^base de l'image	MOVE.16	{A2}+ODFCY,D1	; D1 <-- lg d'un roll complet	SUB.16	D0,D1		; D1 <-- lg pas faite	JUMP,EQ	 R8^L10$	; si roll complet => 10$	MOVE.16	D1,{A4}+OIMAOY	; mm. offset YL10$:	CLR.32	D0	MOVE.16	{A4}+OIMADX,D0	; D0 <-- lg d'une ligne	MOVE.16	{A4}+OIMADY,D1	DEC.16	D1	MUL.16	D0,D1		; D1 <-- nb car. - une ligne	MOVE.32	#{A4}+LGIMA,A4	; A4 <-- ^dbut 1re ligne	MOVE.32	A4,A3	ADD.32	D0,A3		; A3 <-- ^dbut 2me ligneL20$:	MOVE.8	{A3+},{A4+}	; remonte tout d'une ligne	DEC.16	D1	JUMP,NE L20$L40$:	MOVE.8	#SPACE,{A4+}	; efface la dernire ligne	DEC.16	D0	JUMP,NE L40$L90$:	POPM.32	D0|D1|A3|A4	RET;--------\; CLRIMA  >;========/; Rempli l'image alphanumrique associe  une fentre; d'espaces (blancs).; in	A2.L	^description de la fentre; out	-; mod	-CLRIMA:	PUSHM.32 D0|A4	MOVE.32	{A2}+ODFPIM,A4	; A4 <-- ^base de l'image	CLR.16	{A4}+OIMAOY	; clear offset Y	MOVE.16	{A4}+OIMADX,D0	; D0 <-- lg d'une ligne	MUL.16	{A4}+OIMADY,D0	; D0 <-- nb car. dans image	MOVE.32	#{A4}+LGIMA,A4	; A4 <-- ^dbut 1re ligneL10$:	MOVE.8	#SPACE,{A4+}	; rempli de SPACEs	DEC.16	D0	JUMP,NE L10$	POPM.32	D0|A4	RET;--------\; EOSIMA  >;========/; Rempli la fin de l'image alphanumrique associe  une; fentre d'espaces (blancs).; in	A2.L	^description de la fentre; out	-; mod	-EOSIMA:	PUSHM.32 D0|A0|A4	CALL	GPTIMA		; A4 <-- ^dans l'image	JUMP,NE	 R8^L90$	MOVE.32	{A2}+ODFPIM,A0	; A0 <-- ^base de l'image	MOVE.16	{A0}+OIMADY,D0	; D0 <-- hauteur image	SUB.16	{A0}+OIMAPY,D0	; D0 <-- nb lignes restantes	MUL.16	{A0}+OIMADX,D0	; D0 <-- nb caractres restants	SUB.16	{A0}+OIMAPX,D0	; D0 <-- reste dans ligne	JUMP,LS	 R8^L90$	; si reste rien => 90$L20$:	MOVE.8	#SPACE,{A4+}	; efface la fin de l'cran	DEC.16	D0	JUMP,NE L20$L90$:	POPM.32	D0|A0|A4	RET;--------\; EFLIMA  >;========/; Efface depuis la position du curseur jusqu' la fin de; la ligne (comme EFLI).; in	A2.L	^description de la fentre; out	-; mod	D7.WEFLIMA:	PUSHM.32 D0|A0|A4	CALL	GPTIMA		; A4 <-- ^dans l'image	JUMP,NE	 R8^L90$	MOVE.32	{A2}+ODFPIM,A0	; A0 <-- ^base de l'image	MOVE.16	{A0}+OIMADX,D0	; D0 <-- largeur image	SUB.16	{A0}+OIMAPX,D0	; D0 <-- reste dans ligne	JUMP,EQ	 R8^L90$	; si reste rien => 90$L20$:	MOVE.8	#SPACE,{A4+}	; efface la fin de la ligne	DEC.16	D0	JUMP,NE L20$L90$:	POPM.32	D0|A0|A4	RET;--------\; CREIMA  >;========/; Demande au gestionnaire de mmoire de la place pour crer; une image alphanumrique d'une fentre quelconque.; Mmorise dans l'en-tte de l'image les dimensions x;y de; l'image, les dimensions x;y d'un caractre, et les; dimensions x;y dx;dy de la sous-fentre.; in	A2.L	^description de la fentre; out	D7.W	erreur; mod	D7.WCREIMA:	PUSHM.32 D0|D1|D2|D3|D4|A1|A4	CLR.32	D2	MOVE.16	{A2}+ODFFDX,D2	; D2 <-- largeur fentre	DIV.16	{A2}+ODFCX,D2	; D2 <-- nb car/ligne	INC.16	D2		; petite marge (si arrondi)	CLR.32	D3	MOVE.16	{A2}+ODFFDY,D3	; D3 <-- hauteur fentre	DIV.16	{A2}+ODFCY,D3	; D3 <-- nb lignes	INC.16	D3		; petite marge (si arrondi)	MOVE.16	D2,D4	MUL.16	D3,D4		; D4 <-- largeur * hauteur	ADD.32	#LGIMA,D4	; D4 <-- ajoute les frais fixes	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS_0	MOVE.32	#MTYPBD,D1	; type driver BIOS	GESMEM	?GETMEM		; demande mm. pour l'image	JUMP,NE L90$		; si erreur => 90$	MOVE.32	A4,{A2}+ODFPIM	; init ^image	MOVE.16	D2,{A4}+OIMADX	; init largeur image	MOVE.16	D3,{A4}+OIMADY	; init hauteur image	MOVE.16	{A2}+ODFCX,{A4}+OIMACX ; init largeur car.	MOVE.16	{A2}+ODFCY,{A4}+OIMACY ; init hauteur car.	MOVE.16	{A2}+ODFFX,{A4}+OIMASX	MOVE.16	{A2}+ODFFY,{A4}+OIMASY	MOVE.16	{A2}+ODFFDX,{A4}+OIMALX	MOVE.16	{A2}+ODFFDY,{A4}+OIMALY	CLR.16	{A4}+OIMAOY	; clear offset v. en Y	CALL	CLRIMA		; rempli l'image de SPACEs	TSET.8	{A2}+ODFFLG:#BFIMAA ; l'image existe (eh oui)L90$:	POPM.32	D0|D1|D2|D3|D4|A1|A4	RET;--------\; KILIMA  >;========/; Supprime l'image alphanumrique associe  une fentre.; in	A2.L	^description de la fentre; out	D7.W	erreur; mod	D7.WKILIMA:	PUSHM.32 D1|D4|A1|A4	MOVE.32	{A2}+ODFPIM,A4	; A4 <-- ^base de l'image	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS_0	MOVE.32	#MTYPBD,D1	; type driver BIOS	GESMEM	?GIVMEM		; rend la mmoire	JUMP,NE	 R8^L90$	; erreur => 90$	TCLR.8	{A2}+ODFFLG:#BFIMAA ; l'image n'existe plusL90$:	POPM.32	D1|D4|A1|A4	RET;--------\; WDOSAV  >;========/; Sauve le contenu de la fentre dans une zone mmoire.; in	A2.L	^description de la fentre; out	D7.W	erreur; mod	D7.WWDOSAV:	PUSHM.32 D1..D6|A0|A1|A3|A4	MOVE.16	#ERDIIL,D7	COMP.16	#4*MAXSAV,{A2}+ODFPSV	JUMP,HS L90$.IF	Sm300	TEST.8	{A2}+ODFCMd	; cran couleur ?	JUMP,F	R8^BWSave$	COMP.32	#AdPixelMap1,{A2}+ODFAbs	JUMP,LO	R8^BWSave$	COMP.32	#AdPixelMap4+512*512,{A2}+ODFAbs	JUMP,LO	ColorSave$BWSave$:.ENDIF	Sm300	MOVE.16	{A2}+ODFFX,D4	AND.16	#16'000F,D4	ADD.16	{A2}+ODFFDX,D4	ADD.16	#16-1,D4	AND.16	#16'FFF0,D4	; D4 <-- largeur multiple de word	SR.16	#3,D4		; D4 <-- largeur en bytes	MOVE.16	D4,D6		; D6 <-- Ix	MUL.16	{A2}+ODFFDY,D4	; D4 <-- taille en bytes	ADD.32	#4+4+2+4,D4	; D4 <-- ajoute place info	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS_0	MOVE.32	#MTYPBD,D1	; type driver BIOS	GESMEM	?GETMEM		; demande mmoire pour sauver	JUMP,NE L90$		; si erreur => 90$	MOVE.32	#{A2}+ODFSSV,A1	; A1 <-- ^dbut "stack"	MOVE.16	{A2}+ODFPSV,D1	MOVE.32	A4,{A1}+A16^{D1}; "stack" <-- ^zone de sauvetage	ADD.16	#4,D1	MOVE.16	D1,{A2}+ODFPSV	MOVE.32	{A2}+ODFFY,D3	; D3 <-- origine source	MOVE.32	#0,A3		; A3 <-- source dans l'cran	CLR.32	D4	MOVE.16	{A2}+ODFFX,D4	AND.16	#16'000F,D4	; D4 <-- origine destination	MOVE.32	{A2}+ODFFDY,D2	; D2 <-- dimensions	MOVE.32	D3,{A4+}	; buffer <-- origine dans l'cran	MOVE.32	D4,{A4+}	; buffer <-- origine dans buffer	MOVE.16	D6,{A4+}	; buffer <-- Ix dans buffer	MOVE.32	D2,{A4+}	; buffer <-- dimensions	MOVE.16	#LOADDOT,D1	; D1 <-- mode	PUSH.32	{A2}+ODFFY	PUSH.32	{A2}+ODFFDY	CLR.32	{A2}+ODFFY	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	_GraCall Raster	POP.32	{A2}+ODFFDY	POP.32	{A2}+ODFFY	CALL	WMINMAX		; init min et max (sous-)fentre.IF	Sm300	JUMP	L80$ColorSave$:	MOVE.16	{A2}+ODFFX,D4	; D4.16 <- origine, arrondie sur une frontire	AND.16	#16'0003,D4	; de word	ADD.16	{A2}+ODFFDX,D4	ADD.16	#4-1,D4	AND.16	#16'FFFC,D4	; D4 <-- largeur multiple de word	SR.16	D4		; D4 <-- largeur en bytes	MOVE.16	D4,D6		; D6 <-- Ix	MUL.16	{A2}+ODFFDY,D4	; D4 <-- taille en bytes	ADD.32	#4+4+2+4,D4	; D4 <-- ajoute place info	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS_0	MOVE.32	#MTYPBD,D1	; type driver BIOS	GESMEM	?GETMEM		; demande mmoire pour sauver	JUMP,NE L90$		; si erreur => 90$	MOVE.32	#{A2}+ODFSSV,A1	; A1 <-- ^dbut "stack"	MOVE.16	{A2}+ODFPSV,D1	MOVE.32	A4,{A1}+A16^{D1}; "stack" <-- ^zone de sauvetage	ADD.16	#4,D1	MOVE.16	D1,{A2}+ODFPSV	MOVE.32	{A2}+ODFFY,D3	; D3 <-- origine source	MOVE.32	#0,A3		; A3 <-- source dans l'cran	CLR.32	D4	MOVE.16	{A2}+ODFFX,D4	AND.16	#16'0003,D4	; D4 <-- origine destination	MOVE.32	{A2}+ODFFDY,D2	; D2 <-- dimensions	MOVE.32	D3,{A4+}	; buffer <-- origine dans l'cran	MOVE.32	D4,{A4+}	; buffer <-- origine dans buffer	MOVE.16	D6,{A4+}	; buffer <-- Ix dans buffer	MOVE.32	D2,{A4+}	; buffer <-- dimensions; On utilise ici GRA2_CRaster avec source=couleur et dest=couleur.	MOVE.16	#LOADDOT.OR.2**BSrcCoul.OR.2**BDstCoul,D1	PUSH.32	{A2}+ODFFY	PUSH.32	{A2}+ODFFDY	CLR.32	{A2}+ODFFY	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	_GraCall CRaster	POP.32	{A2}+ODFFDY	POP.32	{A2}+ODFFY	CALL	WMINMAX		; init min et max (sous-)fentre.ENDIF	Sm300L80$:	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D1..D6|A0|A1|A3|A4	RET;--------\; WDOGET  >;========/; Restitue le contenu d'une fentre sauve dans une zone; mmoire.; in	A2.L	^description de la fentre; out	D7.W	erreur; mod	D7.WWDOGET:	PUSHM.32 D1..D6|A0|A1|A3|A4	MOVE.16	#ERDIIL,D7	MOVE.32	#{A2}+ODFSSV,A1	; A1 <-- ^dbut "stack"	MOVE.16	{A2}+ODFPSV,D1	JUMP,EQ L90$	SUB.16	#4,D1	MOVE.32	{A1}+A16^{D1},A4; A4 <-- ^zone de sauvetage	MOVE.16	D1,{A2}+ODFPSV.IF	Sm300	TEST.8	{A2}+ODFCMd	; Mode couleur ?	JUMP,F	R8^BWGet$	COMP.32	#AdPixelMap1,{A2}+ODFAbs	JUMP,LO	R8^BWGet$	COMP.32	#AdPixelMap4+512*512,{A2}+ODFAbs	JUMP,LO	ColorGet$BWGet$:.ENDIF	Sm300	MOVE.32	A4,A3	MOVE.32	{A3+},D4	; D4 <-- origine dans l'cran	MOVE.32	{A3+},D3	; D3 <-- origine dans buffer	MOVE.16	{A3+},D5	; D5 <-- Ix dans buffer	MOVE.32	{A3+},D2	; D2 <-- dimensions	MOVE.32	#0,A4		; A4 <-- destination dans l'cran	MOVE.16	#LOADDOT,D1	; D1 <-- mode	PUSH.32	{A2}+ODFFY	PUSH.32	{A2}+ODFFDY	CLR.32	{A2}+ODFFY	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	_GraCall Raster	POP.32	{A2}+ODFFDY	POP.32	{A2}+ODFFY	CALL	WMINMAX		; init min et max (sous-)fentre	MOVE.32	#{A3}-(4+4+2+4),A4.IF	Sm300	JUMP	L80$ColorGet$:	MOVE.32	A4,A3	MOVE.32	{A3+},D4	; D4 <-- origine dans l'cran	MOVE.32	{A3+},D3	; D3 <-- origine dans buffer	MOVE.16	{A3+},D5	; D5 <-- Ix dans buffer	MOVE.32	{A3+},D2	; D2 <-- dimensions	MOVE.32	#0,A4		; A4 <-- destination dans l'cran	MOVE.16	#LOADDOT.OR.2**BSrcCoul.OR.2**BDstCoul,D1	; D1 <-- mode	PUSH.32	{A2}+ODFFY	PUSH.32	{A2}+ODFFDY	CLR.32	{A2}+ODFFY	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	_GraCall CRaster	POP.32	{A2}+ODFFDY	POP.32	{A2}+ODFFY	CALL	WMINMAX		; init min et max (sous-)fentre	MOVE.32	#{A3}-(4+4+2+4),A4.ENDIF	Sm300L80$:	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS_0	MOVE.32	#MTYPBD,D1	; type driver BIOS	GESMEM	?GIVMEM		; rend la mmoireL90$:	POPM.32	D1..D6|A0|A1|A3|A4	RET	.CHAP	Commandes; Routines pour ?COMMAND; ----------------------;--------\; WRONEC  >;========/; Effectue une commande en modifiant le contenu de la table; pour le controleur d'cran VDC.; in	A4.L	^commande;	A2.32	^description fentre; out	A4.L	^plus loin;	D7.16	erreur; mod	D0..A1, A4.L, D7.WWRONEC:	MOVE.8	{A4+},D0	; D0 <-- commandeWRONEX:	CLR.16	D7		; D7 <-- ok	MOVE.32	#R16^L00$-4,A1L10$:	ADD.32	#4,A1		; A1 <-- ^suivant dans table	TEST.8	{A1}+1		; fin de la table	JUMP,EQ	 R8^L80$	; oui => 80$	COMP.8	{A1}+1,D0	; commande trouve ?	JUMP,NE L10$		; non => 10$				; oui =>	CLR.32	D0	MOVE.16	{A1}+2,D0	; D0 <-- adresse relative	ADD.32	{A6}+OSTART,D0	; D0 <-- adresse absolue	PUSH.32	D0.IF	.NOT.SM300	MOVE.32	#{A6}+OTAVDC,A1	; A1 <-- ^table VDC.ENDIF	.NOT.SM300	RET			; JUMP (D0)L80$:	MOVE.16	#ERDIIL,D7	; D7 <-- "commande illgale"	RETL00$:	.16	SCRCADRE,DOCADRE	.16	SCRMVERT,DOMVERT	.16	SCRDVERT,DODVERT	.16	SCRGHOR,DOGHOR	.16	SCRDHOR,DODHOR	.16	SCRVERT,DOVERT	.16	SCRHOR,DOHOR	.16	SCRLEFT,DOCLEFT	.16	SCRRIGHT,DOCRIGHT	.16	SCRUP,DOCUP	.16	SCRDOWN,DOCDOWN	.16	SCRCENTRE,DOCENTRE	.16	SCRCOIN,DOCOIN	.16	SCRPOX,DOPOX	.16	SCRPOY,DOPOY	.16	SCRICONE,DOICONE	.16	SCRPARAM,DOPARAM	.16	SCRBITMAP+0,DOBITMAP0	.16	SCRBITMAP+1,DOBITMAP1.IF	SM100.OR.SM324.OR.SM196.or.sm300.OR.Cos21	.16	SCRBITMAP+2,DOBITMAP2	.16	ScrBitMap+3,DoBitMap3.ENDIF	SM100.OR.SM324.OR.SM196.OR.SM300.OR.Cos21	.16	SCRVIDEO,DOVIDEO	.16	0; ---	SCRCADRE   ---; Remet le cadrage standard horizontalement et verticalement.DOCADRE:.IF	SM300	RET.ELSE	Sm300	MOVE.8	{A6}+OSREGV,{A1}+REGVERT	MOVE.8	{A6}+OSREGH,{A1}+REGHOR1	JUMP	INIVDC		; init le contrleur d'cran.ENDIF	ELSE SM300; ---	SCRMVERT   ---; Monte le cadrage vertical.DOMVERT:.IF	SM300	RET.ELSE	Sm300	INC.8	{A1}+REGVERT	; modifie dans la table TAVDC	JUMP	INIVDC		; init le contrleur d'cran.ENDIF	ELSE SM300; ---	SCRDVERT   ---; Descend le cadrage vertical.DODVERT:.IF	SM300	RET.ELSE	SM300	DEC.8	{A1}+REGVERT	; modifie dans la table TAVDC	JUMP	INIVDC		; init le contrleur d'cran.ENDIF	ELSE SM300; ---	SCRGHOR   ---; Met le cadrage horizontal plus  gauche.DOGHOR:.IF	SM300	RET.ELSE	Sm300	INC.8	{A1}+REGHOR1	; modifie dans la table TAVDC	JUMP	INIVDC		; init le contrleur d'cran.ENDIF	ELSE SM300; ---	SCRDHOR   ---; Met le cadrage horizontal plus  droite.DODHOR:.IF	SM300	RET.ELSE	Sm300	DEC.8	{A1}+REGHOR1	; modifie dans la table TAVDC;;?	SUB.B	(A1)+REGHOR2,#2	JUMP	INIVDC		; init le contrleur d'cran.ENDIF	ELSE SM300; ---	SCRVERT   ---; Initialise le cadrage vertical en fonction du byte suivant; la commande (zro = standard).DOVERT:.IF	SM300	RET.ELSE	Sm300	MOVE.8	{A4+},D0	; D0 <-- paramtre commande	ADD.8	{A6}+OSREGV,D0	MOVE.8	D0,{A1}+REGVERT	JUMP	INIVDC		; init le contrleur d'cran.ENDIF	ELSE SM300; ---	SCRHOR   ---; Initialise le cadrage horizontal en fonction du byte suivant; la commande (zro = standard).DOHOR:.IF	SM300	RET.ELSE	Sm300	MOVE.8	{A4+},D0	; D0 <-- paramtre commande	ADD.8	{A6}+OSREGH,D0	MOVE.8	D0,{A1}+REGHOR1	JUMP	INIVDC		; init le contrleur d'cran.ENDIF	ELSE SM300; ---	SCRLEFT   ---; Montre la partie gauche de l'cran 1024 x 1024.DOCLEFT:.IF	SM300	TEST.16	VideoSamInit+2	JUMP,EQ	R8^Out$		CALL	ShowLeft	CLR.16	VideoSamInit+2Out$:	RET.ELSE	Sm300.IF	.NOT.FullPage	COMP.8	#16'00,{A1}+REGPOX	JUMP,EQ	 R8^L90$	CALL	SHOWLEFT	MOVE.8	#16'00,{A1}+REGPOXL90$:.ENDIF	.NOT.FullPage	JUMP	INIVDC		; init le contrleur d'cran.ENDIF	ELSE SM300; ---	SCRRIGHT   ---; Montre la partie droite de l'cran 1024 x 1024.DOCRIGHT:.IF	SM300	TEST.16	VideoSamInit+2	JUMP,ne	R8^Out$	CALL	ShowRight	COMP.16	#512,VideoNInc+2	JUMP,LO	R8^BW$	MOVE.16	#48*4, VideoSamInit+2	JUMP	R8^Out$BW$:	MOVE.16	#48, VideoSamInit+2Out$:	RET.ELSE	Sm300.IF	.NOT.FUllPage	COMP.8	#16'0C,{A1}+REGPOX	JUMP,EQ	 R8^L90$	CALL	SHOWRIGHT	MOVE.8	#16'0C,{A1}+REGPOXL90$:.ENDIF	.NOT.FullPage	JUMP	INIVDC		; init le contrleur d'cran.ENDIF	ELSE SM300; ---	SCRUP   ---; Montre la moiti suprieure de l'cran 1024 x 1024.DOCUP:	RET; ---	SCRDOWN   ---; Montre la moiti infrieure de l'cran 1024 x 1024.DOCDOWN:	RET; ---	SCRPOX   ---DOPOX:	MOVE.8	{A4+},D0	; D0 <-- paramtre high	SL.16	#8,D0	MOVE.8	{A4+},D0	; D0 <-- paramtre low	MOVE.16	D0,D1	SR.16	#4,D0		; D0 <-- <xx> /16	COMP.8	#16'0C,D0	JUMP,LO	 R8^L40$	MOVE.8	#16'0C,D0L40$:	COMP.8	#16'0C/2,D0	; plutt  gauche ?	JUMP,LO DOCLEFT		; oui => cale  gauche	JUMP	DOCRIGHT	; non => cale  droite; ---	SCRPOY   ---DOPOY:	MOVE.8	{A4+},D0	; D0 <-- paramtre high	SL.16	#8,D0	MOVE.8	{A4+},D0	; D0 <-- paramtre low	RET; ---	SCRCENTRE   ---; Centre l'cran pour que la fentre utilise soit visible.DOCENTRE:	MOVE.8	#"O",D0		; D0 <-- "O"pen	MOVE.16	{A6}+ONOVBM,D1	CALL	USEBITMAP	; bitmap occup ?	JUMP,NE	 R8^L10$	; oui => 10$	MOVE.8	#"C",D0		; D0 <-- "C"loseL10$:	ADD.8	#"1",D1		; D1 <-- "1..4"	CALL	AFICONE		; grise l'ancienne icne.IF	Sm300	COMP.8	#7,{A2}+ODFNoW	JUMP,LO	Active$	COMP.8	#9,{A2}+ODFNoW	JUMP,LS	NotActive$Active$:	CALL	ActiveOne	; Active cette CLUTNotActive$:.ENDIF	Sm300	MOVE.8	{A2}+ODFCAD+1,D0 ; 2me commande de centrage	JUMP,EQ	 R8^L20$	CALL	WRONEXL20$:	MOVE.8	{A2}+ODFCAD+0,D0 ; 1re commande de centrage	JUMP,EQ	 R8^L30$	CALL	WRONEXL30$:	MOVE.8	#"U",D0		; D0 <-- "U"se	MOVE.16	{A6}+ONOVBM,D1	CALL	USEBITMAP	; bitmap occup ?	JUMP,NE	 R8^L50$	; oui => 50$	MOVE.8	#"O",D0		; D0 <-- "O"penL50$:	ADD.8	#"1",D1		; D1 <-- "1..4"	CALL	AFICONE		; allume la nouvelle icne	CLR.16	D7		; D7 <-- ok	RET; ---	SCRBITMAP   ---; Change de bitmap principal.DOBITMAP0:	CLR.16	D1	JUMP	CHANBITMAP	; change de bitmapDOBITMAP1:	MOVE.16	#1,D1	JUMP	CHANBITMAP	; change de bitmapDOBITMAP2:	MOVE.16	#2,D1	JUMP	CHANBITMAP	; change de bitmapDOBITMAP3:	MOVE.16	#3,D1	JUMP	CHANBITMAP	; change de bitmapDOBITMAP4:	MOVE.16	#4,D1	JUMP	CHANBITMAP	; change de bitmap; ---	SCRVIDEO   ---; Change de standard vido.DOVIDEO:.IF	SM300	RET.ELSE	Sm300	MOVE.8	{A4+},D0	; D0 <-- paramtre commande	CALL	NEWVDC	JUMP	INIVDC		; init le contrleur d'cran.ENDIF	ELSE SM300; ---	SCRPARAM   ---; Redonne les paramtres comme  l'INSTALLDOPARAM:	PUSH.32	D2	MOVE.32	{A4+},A1	; A1 <-- pointeur paramtres	CALL	DIMOK?		; dimensions fentre ok ?	TEST.16	D7	JUMP,NE	 R8^L90$	; non => 90$	CALL	GCLOAD		; charge le gnrateur standard	TEST.16	D7	JUMP,NE	 R8^L90$	CALL	GCUSE		; (A2)++ <-- paramtres	TEST.16	D7	JUMP,NE	 R8^L90$	MOVE.32	{A2}+ODFC1Y,{A2}+ODFPY	CLR.32	{A2}+ODFPGY	CLR.32	{A2}+ODFFY	MOVE.32	{A2}+ODFDY,{A2}+ODFFDY	CALL	WMINMAX		; init min et max (sous-)fentre	CLR.32	{A2}+ODFPMS	; remet la souris standard	CLR.32	{A2}+ODFPMC	CALL	INIDESC		; init le reste du descripteurL90$:	POP.32	D2	RET; ---	DOICONE   ---DOICONE:	MOVE.8	{A4+},D0	; D0 <-- floppy/clavier	MOVE.8	{A4+},D1	; D1 <-- paramtre	COMP.8	#"M",D0	JUMP,NE R8^AFICONE	RR.16	#8,D1	MOVE.8	{A4+},D1	; D1 <-- tat	RR.16	#8,D1	SWAP.32	D1	MOVE.8	{A4+},D1	; D1 <-- type	SWAP.32	D1;	JUMP	R8^AFICONE;--------\\; AFICONE >;========/; Affiche une icne tout en haut.; in	D0.8	floppy/clavier/bitmap;	D1.8	paramtre;	D1.32	si D0="M" --> |-|type|tat|position|; out	-; mod	-AFICONE:	PUSHM.32 A1..A4|D1..D5	MOVE.32	#R16^TAICONE-6,A1ILOOP$:	ADD.A16	#6,A1		; A1 <-- ^suivant dans TAICONE	TEST.8	{A1}		; fin de la table ?	JUMP,EQ EXIT$		; oui => EXIT$	COMP.8	{A1}+0,D0	JUMP,NE ILOOP$	COMP.8	{A1}+1,D1	JUMP,NE ILOOP$	MOVE.32	#16'10000,D4	; Coordonne Y destination	MOVE.16	{A1}+4,D4	; D4.32 <- coordonnes destination	TEST.16	{A1}+2		; icne connue ?	JUMP,NE	R8^DRAW$	; oui => DRAW$	SR.32	#8,D1		; D1 <-- |-|-|type|tat|	MOVE.32	#R16^TAICONEMM-4,A1MMLOOP$:	ADD.A16	#4,A1		; A1 <-- ^suivant dans TAICONEMM	TEST.8	{A1}		; fin de la table ?	JUMP,NS EXIT$		; oui => EXIT$	COMP.16	{A1}+0,D1	JUMP,NE MMLOOP$DRAW$:	MOVE.32	#R16^TaIcone,A3	ADD.A16	{A1}+2,A3	; A3 ^matrice source	MOVE.32	{A6}+OPDFEN+(4*0),A2 ; A2 <-- ^descripteur $DIS_0	COMP.8	#"R",{A2}+ODFCAD+1; fentre cadre  droite ?	JUMP,NE	 R8^L40$	; non => 40$	ADD.16	#1024-PViewX,D4	; Oui => on en tient compte.L40$:	MOVE.16	#LIcone,D2	SWAP.32	D2	CLR.16	D2	MOVE.8	{A3+},D2	MOVE.16	D2,D5		; D5.16 <- rowBytes source	ADD.16	D2,D2	ADD.16	D2,D2	ADD.16	D2,D2		; D2.32 <- dimensions du transfert	MOVE.32	#0,D3		; D3.32 <- coordonnes source	MOVE.32	#0,A4		; A4 <- ^nil (destination=cran)	MOVE.32	#LoadDot,D1	_GraCall Raster		; Et on affiche.	CLR.16	D7EXIT$:	POPM.32	A1..A4|D1..D5	RETTAICONE:.IF	Sm300	.8.8.16.16		"O","1",	ICONESO-TaIcone,	 SEPX89-176	.8.8.16.16		"O","2",	ICONESO-TaIcone,	 SEPX89-152	.8.8.16.16		"O","3",	ICONESO-TaIcone,	 SEPX89-128	.8.8.16.16		"O","4",	ICONESO-TaIcone,	 SepX89-104	.8.8.16.16		"U","1",	ICONES1-TaIcone,	 SEPX89-176	.8.8.16.16		"U","2",	ICONES2-TaIcone,	 SEPX89-152	.8.8.16.16		"U","3",	ICONES3-TaIcone,	 SEPX89-128	.8.8.16.16		"U","4",	ICONES4-TaIcone,	 SEPX89-104	.8.8.16.16		"C","1",	ICONESC-TaIcone,	 SEPX89-176	.8.8.16.16		"C","2",	ICONESC-TaIcone,	 SEPX89-152	.8.8.16.16		"C","3",	ICONESC-TaIcone,	 SEPX89-128	.8.8.16.16		"C","4",	ICONESC-TaIcone,	 SEPX89-104	.8.8.16.16		"K","R",	ICONE0-TaIcone,		SEPX89-80	.8.8.16.16		"K","P",	ICONEKP-TaIcone,	SEPX89-80.IF 0	.8.8.16.16		"F","0",	ICONE0-TaIcone,		SEPX89-32	.8.8.16.16		"F","1",	ICONE0-TaIcone,		SEPX89-16	.8.8.16.16		"F","2",	ICONEF23-TaIcone,	SEPX89-32	.8.8.16.16		"F","3",	ICONEF23-TaIcone,	SEPX89-16	.8.8.16.16		"F","4",	ICONEF45-TaIcone,	SEPX89-32	.8.8.16.16		"F","5",	ICONEF45-TaIcone,	SEPX89-16.ENDIF	.8.8.16.16		"M",0,		0,			SEPX89-64	.8.8.16.16		"M",1,		0,			SEPX89-48	.8.8.16.16		"M",2,		0,			SEPX89-32	.8.8.16.16		"M",3,		0,			SEPX89-16	.8	0.ELSE	Sm300	.8	"O","1"	.16		ICONESO-TaIcone,SEPX89-LargCX*LARICOX+1*8	.8	"O","2"	.16		ICONESO-TaIcone,SEPX89-LargCX*LARICOX+4*8	.8	"O","3"	.16		ICONESO-TaIcone,SEPX89-LargCX*LARICOX+7*8	.8	"O","4"	.16		ICONESO-TaIcone,SEPX89-LargCX*LARICOX+10*8	.8	"U","1"	.16		ICONES1-TaIcone,SEPX89-LargCX*LARICOX+1*8	.8	"U","2"	.16		ICONES2-TaIcone,SEPX89-LargCX*LARICOX+4*8	.8	"U","3"	.16		ICONES3-TaIcone,SEPX89-LargCX*LARICOX+7*8	.8	"U","4"	.16		ICONES4-TaIcone,SEPX89-LargCX*LARICOX+10*8	.8	"C","1"	.16		ICONESC-TaIcone,SEPX89-LargCX*LARICOX+1*8	.8	"C","2"	.16		ICONESC-TaIcone,SEPX89-LargCX*LARICOX+4*8	.8	"C","3"	.16		ICONESC-TaIcone,SEPX89-LargCX*LARICOX+7*8	.8	"C","4"	.16		ICONESC-TaIcone,SEPX89-LargCX*LARICOX+10*8	.8	"K","R"	.16		ICONE0-TaIcone,SEPX89-LargCX*LARICOX+16*8	.8	"K","P"	.16		ICONEKP-TaIcone,SEPX89-LargCX*LARICOX+16*8.IF 0	.8	"F","0"	.16		ICONE0-TaIcone,SEPX89-LargCX*LARICOX+19*8	.8	"F","1"	.16		ICONE0-TaIcone,SEPX89-LargCX*LARICOX+21*8	.8	"F","2"	.16		ICONEF23-TaIcone,SEPX89-LargCX*LARICOX+19*8	.8	"F","3"	.16		ICONEF23-TaIcone,SEPX89-LargCX*LARICOX+21*8	.8	"F","4"	.16		ICONEF45-TaIcone,SEPX89-LargCX*LARICOX+19*8	.8	"F","5"	.16		ICONEF45-TaIcone,SEPX89-LargCX*LARICOX+21*8.ENDIF	.8	0.ENDIF	ELSE Sm300TAICONEMM:	.8.8.16	0,0,	ICONE0-TaIcone	.8.8.16	0,1,	ICONEFV5-TaIcone	.8.8.16	0,2,	ICONEFE5-TaIcone	.8.8.16	1,0,	ICONE0-TaIcone	.8.8.16	1,1,	ICONEFV3-TaIcone	.8.8.16	1,2,	ICONEFE3-TaIcone	.8.8.16	2,0,	ICONE0-TaIcone	.8.8.16	2,1,	ICONEFVH-TaIcone	.8.8.16	2,2,	ICONEFEH-TaIcone	.8.8.16	3,0,	ICONE0-TaIcone	.8.8.16	3,1,	ICONEFVX-TaIcone	.8.8.16	3,2,	ICONEFEX-TaIcone	.8	-1;	.EVEN	.ODD.IF	Sm300ICONE0:	.8	2	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000LICONE	= (APC-ICONE0)/2	.ODDICONEKP:	.8	2	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0110011001100011	.16	2'1000100101010100	.16	2'1000100101010100	.16	2'1000100101010010	.16	2'1000111101100001	.16	2'1000100101000001	.16	2'0110100101000110	.16	2'0000000000000000	.16	2'0000000000000000	.16	2'0000000000000000	.ODDICONESO:	.8	3        .8      2'01111111,2'11111111,2'11100000   