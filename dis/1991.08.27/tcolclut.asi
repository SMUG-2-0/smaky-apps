	.SBTTL	TCOLCLUT.ASI;---------------\\; _TCOL_LOADCLUT >;===============/; Charge la palette des couleurs (CLUT) active.; in	D6.L	canal;	D3.L	mode (BTC*);		 BTCTABLE --> donne une table;		 BTCNAME  --> donne un nom de fichier;		 BTCCHFOS --> donne un canal FOS;		 BTCGLOB  --> si CLUT globale;	A3.L	^table (si D3:#BTCTABLE);	A3.L	^nom (si D3:#BTCNAME);	D4.W	canal FOS (si D3:#BTCCHFOS); out	D7.W	erreur; mod	D7.W_TCOL_LOADCLUT:	PUSHM.L	D1..D4,D6,A4..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	COMP.L	A5,(A5)+OLPLOC	JUMP',EQ CHKOK$	CALL	ERRCHANNELCHKOK$:	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	D2,D3		; D2 <-- mode	LOAD.B	D1,#CLTYPE	; D1 <-- type attendu (CLUT)	TEST.L	D2:#BTCTABLE	JUMP',BS TABLE$	TEST.L	D2:#BTCNAME	JUMP',BS NAME$	TEST.L	D2:#BTCCHFOS	JUMP',BS CHFOS$	LOAD.W	D7,#ERTCMODE	; D7 <-- mode incorrect	JUMP	EXIT$TABLE$:	CALL	TABMLOAD	; A4 <-- ^table lue	JUMP,NE EXIT$	JUMP'	PUT$NAME$:	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE EXIT$	CALL	TABFLOAD	; A4 <-- ^table lue	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	JUMP',NE EXIT$	JUMP'	PUT$CHFOS$:	LOAD.W	D6,D4		; D6 <-- canal FOS	CALL	TABFLOAD	; A4 <-- ^table lue	JUMP',NE EXIT$PUT$:	CALL	CLUTMEM		; mmorise la nouvelle CLUT	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,D6,A4..A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLUTMEM >;--------/; Mmorise une nouvelle CLUT.; in	A4.L	^nouvelle CLUT;	D2.L	mode; out	-; mod	D7.WCLUTMEM:	PUSHM.L	D3,D4,D6,A1,A3..A5	LOAD.L	A3,A4		; A3 <-- ^nouvelle CLUT	TEST.L	D2:#BTCGLOB	JUMP',BC LOCAL$	LOAD.L	A1,#(A6)+OGPCLUT ; A1 <-- ^^CLUT globale	TEST.L	(A1)		; existe dj une CLUT ?	JUMP',EQ GKILL$		; non => GKILL$	LOAD.L	A4,(A1)	CALL	TABKILL		; libre l'ancienne tableGKILL$:	LOAD.L	(A1),A3		; OGPCLUT <-- ^nouvelle CLUTLOCAL$:	LOAD.L	A1,#(A5)+OLPCLUT ; A1 <-- ^^CLUT locale	TEST.L	(A1)		; existe dj une CLUT ?	JUMP',EQ LKILL$		; non => LKILL$	LOAD.L	A4,(A1)	CALL	TABKILL		; libre l'ancienne tableLKILL$:	LOAD.L	(A1),A3		; OLPCLUT <-- ^nouvelle CLUT	LOAD.B	D4,(A5)+OLACTIF	LOAD.L	D6,A5		; D6 <-- canal	CLR.L	D3		; D3 <-- mode	LOAD.L	A5,#0		; A5 <-- ^liste des moniteurs	CALL	_TCOL_ACTIVE	; active la nouvelle CLUT si ncessaire	POPM.L	D3,D4,D6,A1,A3..A5	RET;---------------\\; _TCOL_SAVECLUT >;===============/; Sauve la palette des couleurs (CLUT) active.; in	D6.L	canal;	D3.L	mode (BTC*);		 BTCTABLE --> donne une table;		 BTCNAME  --> donne un nom de fichier;		 BTCCHFOS --> donne un canal FOS;		 BTCGLOB  --> si CLUT globale;	A3.L	^buffer (si D3:#BTCTABLE);	A3.L	^nom (si D3:#BTCNAME);	D4.W	canal FOS (si D3:#BTCCHFOS); out	(A3)+	table;	D7.W	erreur; mod	D7.W_TCOL_SAVECLUT:	PUSHM.L	D2..D4,D6,A2..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	COMP.L	A5,(A5)+OLPLOC	JUMP',EQ CHKOK$	CALL	ERRCHANNELCHKOK$:	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	D2,D3		; D2 <-- mode	LOAD.L	A4,(A5)+OLPCLUT	; A4 <-- ^CLUT locale	TEST.L	D2:#BTCGLOB	JUMP',BC LOCAL$	LOAD.L	A4,(A6)+OGPCLUT	; A4 <-- ^CLUT globaleLOCAL$:	COMP.L	A4,#0	JUMP',EQ ERROR$	TEST.L	D2:#BTCTABLE	JUMP',BS TABLE$	TEST.L	D2:#BTCNAME	JUMP',BS NAME$	TEST.L	D2:#BTCCHFOS	JUMP',BS CHFOS$ERROR$:	LOAD.W	D7,#ERTCMODE	; D7 <-- mode incorrect	JUMP'	EXIT$TABLE$:	CALL	TABMSAVE	; sauve la table	JUMP'	EXIT$NAME$:	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE EXIT$	CALL	TABFSAVE	; sauve la table	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	JUMP'	EXIT$CHFOS$:	LOAD.W	D6,D4		; D6 <-- canal FOS	CALL	TABFSAVE	; sauve la table;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4,D6,A2..A6	TEST.W	D7		; retour EQ/NE	RET;--------------\\; _TCOL_SRCCLUT >;==============/; Cherche une couleur dans la palette.; in	D6.L	canal;	D3.L	mode (BTC*);		 BTCFORCE --> on donne la couleur cherche;		 BTCGIVE  --> rend la couleur exacte;		 BTCGLOB  --> si CLUT globale;	A4.L	^couleur cherche (RGB) (si D3<>BTCFORCE);	D4.L	couleur de la palette (si D3:#BTCFORCE);	A3.L	^buffer (si D3:#BTCGIVE); out	D4.L	couleur de la palette;	(A3)+	RGB exact (si D3:#BTCGIVE);	D7.W	erreur; mod	D4.L, D7.W_TCOL_SRCCLUT:	PUSHM.L	D2,D3,A2..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	COMP.L	A5,(A5)+OLPLOC	JUMP',EQ CHKOK$	CALL	ERRCHANNELCHKOK$:	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	A2,A3		; A2 <-- ^buffer	LOAD.L	A3,A4		; A3 <-- ^couleur cherche	LOAD.L	D2,D3		; D2 <-- mode	TEST.L	D2:#BTCACTIVE	JUMP',BC NORM$	LOAD.L	A4,(A6)+OGPACCL	; A4 <-- ^CLUT active	COMP.L	A4,#0	JUMP',NE LOCAL$NORM$:	LOAD.L	A4,(A5)+OLPCLUT	; A4 <-- ^CLUT locale	TEST.L	D2:#BTCGLOB	JUMP',BC LOCAL$	LOAD.L	A4,(A6)+OGPCLUT	; A4 <-- ^CLUT globaleLOCAL$:	LOAD.W	D7,#ERTCQQ	COMP.L	A4,#0	JUMP',EQ EXIT$	TEST.L	D2:#BTCFORCE	JUMP',BS FORCE$	CALL	TABSRCCA	; D3/D4/A3 <-- nom/index/RGB approximatif	JUMP',NE EXIT$	JUMP'	GIVE$FORCE$:	LOAD.L	D3,D4		; D3 <-- nom	CALL	TABSRCN		; D4/A3 <-- index/^RGB	JUMP',NE EXIT$GIVE$:	LOAD.L	D4,D3		; D4 <-- couleur de la palette	TEST.L	D2:#BTCGIVE	JUMP',BC OK$	LOAD.W	(A2+),(A3+)	; buffer <-- rouge	LOAD.W	(A2+),(A3+)	; buffer <-- vert	LOAD.W	(A2+),(A3+)	; buffer <-- bleuOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D3,A2..A6	TEST.W	D7		; retour EQ/NE	RET;--------------\\; _TCOL_PUTCLUT >;==============/; Ajoute ou modifie une couleur dans la palette.; in	D6.L	canal;	D3.L	mode (BTC*);		 BTCFORCE --> on donne la couleur;		 BTCGLOB  --> si CLUT globale;	A4.L	^couleur (RGB);	D4.L	couleur de la palette (si D3:#BTCFORCE); out	D4.L	couleur de la palette modifie;	D7.W	erreur; mod	D4.L, D7.W_TCOL_PUTCLUT:	TEST.L	D3:#BTCGLOB	JUMP',BC BEGIN$	PUSH.L	D3	TCLR.L	D3:#BTCGLOB	CALL	_TCOL_PUTCLUT	; modifie aussi la CLUT locale	POPM.L	D3	JUMP',EQ BEGIN$	RETBEGIN$:	PUSHM.L	D2,D3,A1..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	COMP.L	A5,(A5)+OLPLOC	JUMP',EQ CHKOK$	CALL	ERRCHANNELCHKOK$:	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	A2,A4		; A2 <-- ^nouvelle couleur (RGB)	LOAD.L	D2,D3		; D2 <-- mode	LOAD.L	A1,#(A5)+OLPCLUT ; A1 <-- ^^CLUT locale	TEST.L	D2:#BTCGLOB	JUMP',BC LOCAL$	LOAD.L	A1,#(A6)+OGPCLUT ; A1 <-- ^^CLUT globaleLOCAL$:	LOAD.W	D7,#ERTCQQ	; D7 <-- erreur	TEST.L	(A1)	JUMP',EQ EXIT$	LOAD.L	A4,(A1)		; A4 <-- ^table CLUT	TEST.L	D2:#BTCFORCE	JUMP',BC EXIT$	LOAD.L	D3,D4		; D3 <-- nom	CALL	TABSRCN		; D4/A3 <-- index/^RGB	JUMP',NE NEW$	LOAD.L	A3,A2		; A3 <-- ^nouvelle couleur	CALL	TABREPL		; remplace dans la table	JUMP'	OK$NEW$:	LOAD.L	A3,A2		; A3 <-- ^nouvelle couleur	LOAD.L	D4,D3	CALL	TABADD		; ajoute dans la table	JUMP',NE EXIT$	LOAD.L	(A1),A4		; O[L/G]PCLUT <-- mj ^CLUT si changOK$:	LOAD.L	D4,D3		; D4 <-- couleur de la palette	CALL	HARDMAJCLUT	; initialise le hard si ncessaire	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D3,A1..A6	TEST.W	D7		; retour EQ/NE	RET;---------------\\; _TCOL_PPSSCLUT >;===============/; Donne la procdure  utiliser pour chercher une couleur dans la CLUT.; in	D6.L	canal;	D3.L	mode (zro);	A4.L	^procdure de recherche/nil, voir (*); out	D7.W	erreur; mod	D7.W; (*)	La procdure de recherche est dfinie comme suit :;; in	A4.L	^table CLUT;	A3.L	^RGB cherch; out	A3.L	^RGB trouv (dans la table);	D4.W	index trouv (0..n);	D3.L	couleur de la palette;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A3.L_TCOL_PPSSCLUT:	PUSHM.L	A5,A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	COMP.L	A5,(A5)+OLPLOC	JUMP',EQ CHKOK$	CALL	ERRCHANNELCHKOK$:	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	(A5)+OLPPSS,A4	; OLPPSS <-- ^procdure de recherche	POPM.L	A5,A6	CLR.W	D7		; retour EQ	RET;---------------\\; _TCOL_GPSSCLUT >;===============/; Rend la procdure utilise pour chercher une couleur dans la CLUT.; in	D6.L	canal;	D3.L	mode (zro); out	A4.L	^procdure de recherche/nil;	D7.W	erreur; mod	D7.W, A4.L_TCOL_GPSSCLUT:	PUSHM.L	A5,A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	COMP.L	A5,(A5)+OLPLOC	JUMP',EQ CHKOK$	CALL	ERRCHANNELCHKOK$:	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	LOAD.L	A4,(A5)+OLPPSS	; A4 <-- ^procdure de recherche	POPM.L	A5,A6	CLR.W	D7		; retour EQ	RET	.END