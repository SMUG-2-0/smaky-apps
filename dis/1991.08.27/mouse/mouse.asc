	.TITLE	MOUSE.ASC;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------;	Source des programmes SYS_MOUSE.CODE, 100_MOUSE.CODE ou 324_MOUSE.CODE; Date		Rev	Amliorations; -------------------------------------------------------------------------------------; 03.06.91	4.5	mouvement plus fluide; 21.05.91	4.4	4 mmoires de masse (utilise FOS,?MMVASSIGN); 08.06.89	4.2	priorit 4 -> 5 !; 25.05.88	4.1	?DELMS = 2 si SMAKY100; 20.04.88	4.0	en couleur ...; 26.11.87	3.15	grand sablier si SM324BIG;			utilise ODFPSK.L; 20.11.87	3.14	.IF SM324BIG repris de BB; 21.04.87	3.13	BB: Adaptation Smaky 324; 26.02.87	3.12	Ne prend plus le clavier au dmarrage;			Clic (3 boutons) dans "smaky" supprim !	.PROC	M68000	.BASE	10'10	.LAYOUT HEX; Assemblage conditionnel; -----------------------;	.REF	MACHINESM300	=	FALSESM100	=	FALSESM196	=	FALSESM324	=	TRUESM324BIG=	TRUESM8	=	FALSE.if	FalseSM100	=	_SM100.OR._SM324LIT; 1 => SM100 ou SM324LITSM324BIG=	_SM324BIG	; 1 => SM324 grand cranSM8	=	_SM8		; 1 => SM8.endif	FalseCOLOR	=	0		; 1 => 2me cran couleurBIGCOLOR=	0		; 1 => grand cran couleur	.REF	SMAKY	.REF	MODULES	.REF	COLORS;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;FOS?MMVassign	=	FOS_BASE+110	; donne le nom de la mmoire de masse selon contrle;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.REV	4,5	.CODE	800,5,2'110,20,2000,20,2000,2,"*",0,0; Constantes; ----------	.IF	SM100LVIEWX	=	640		; largeur partie visibleLVIEWY	=	400		; hauteur partie visible	.ENDIF	.IF	SM300LVIEWX	=	640		; largeur partie visibleLVIEWY	=	480		; hauteur partie visible	.ENDIF	.IF	SM324.AND.(.NOT.SM324BIG)LVIEWX	=	640		; largeur partie visibleLVIEWY	=	400		; hauteur partie visible	.ENDIF	SM324.AND.(.NOT.SM324BIG)	.IF	SM324BIGLVIEWX	=	864		; largeur partie visibleLVIEWY	=	1024		; hauteur partie visible	.ENDIF	.IF	SM8LVIEWX	=	8*104		; largeur partie visibleLVIEWY	=	16*32		; hauteur partie visible	.ENDIF	.IF	COLOR	.IF	BIGCOLORPCVIEWX	=	928		; nb points visibles en XPCVIEWY	=	736		; nb points visibles en Y	.ELSEPCVIEWX	=	640		; nb points visibles en XPCVIEWY	=	480		; nb points visibles en Y	.ENDIF	.ENDIF	.IF	SM8ADDX	=	17	.ENDIF	.IF	SM100ADDX	=	0	.ENDIF	.IF	SM324.AND.(.NOT.SM324BIG)ADDX	=	0	.ENDIF	.IF	SM324BIGADDX	=	21	.ENDIF.IF	Sm300PBIM0X	=	302		; position icone bitmap 0PBIM1X	=	326		; position icone bitmap 1PBIM2X	=	350		; position icone bitmap 2PBIM3X	=	374		; position icone bitmap 3DBIMX	=	20		; largeur icone bitmapPFLO0X	=	382+1		; position icone floppy 0PFLO1X	=	398+1		; position icone floppy 1PFLO2X	=	414+1		; position icone floppy 2PFLO3X	=	430+1		; position icone floppy 3DFLOXY	=	13		; dimensions icones floppy.ELSE	Sm300PBIM0X	=	8*(31+ADDX)	; position icone bitmap 0PBIM1X	=	8*(34+ADDX)	; position icone bitmap 1PBIM2X	=	8*(37+ADDX)	; position icone bitmap 2PBIM3X	=	8*(40+ADDX)	; position icone bitmap 3DBIMX	=	20		; largeur icone bitmapPFLO0X	=	8*(46+ADDX)	; position icone floppy 0PFLO1X	=	8*(48+ADDX)	; position icone floppy 1PFLO2X	=	8*(50+ADDX)	; position icone floppy 2PFLO3X	=	8*(52+ADDX)	; position icone floppy 3DFLOXY	=	14		; dimensions icones floppy.ENDIF	ELSE Sm300WDOSKY	=	7		; $DIS_7 --> fentre soft keysMAXHYST	=	50		; hystrsis maximaleCTDEL	=	2		; compteur pour attendreLBDIS	=	150		; lg max du buffer OBDIS	.IF	COLORNOWDOC	=	20		; numro de la fentre bitmap couleur	.ENDIF	.IF	COLOR; Tables des crans multiples; ---------------------------MAXVS	=	2+1		; nb max d'crans	.LOC	0OVSPOS:	.BLK.8	4		; coin sup/gaucheOVSDIM:	.BLK.8	4		; dimensionsOVSCHD:	.BLK.8	2		; canalOVSPTD:	.BLK.8	4		; ^descripteurLVS:	.ENDIF; Variables; ---------	.LOC	0OFLAGS:	.BLK.8	1		; flags divers BABORT	=  0			;  le fils doit faire un ?ABORT BEFFACE=  1			;  efface la fentre BFIRST	=  2			;  premier motif dessinOBOUTON:.BLK.8	1		; ancien tat des boutonsOWMOUSE:.BLK.8	1		; souris "en attente"	.EVENOPINFO:	.BLK.16	2		; ^contenu de SYS_INFOOCHMOU:	.BLK.8	2		; canal de la sourisOCHDIS:	.BLK.8	2		; canal de la fentre $DIS_n	.IF	COLOROCHDI0:	.BLK.8	2		; canal de la fentre $DIS_0OCHDI1:	.BLK.8	2		; canal de la fentre $DIS_20	.ENDIFOOLDPOS:.BLK.8	4		; ancienne position sourisOOLDPOM:.BLK.8	4		; ancienne position MFLECHEODLCOM:	.BLK.8	4		; ancienne commande U/D,L/ROHPOSX:	.BLK.16	1		; ancienne position en XOCHAZO:	.BLK.16	1		; canal fentre pour zoneOBEGZO:	.BLK.16	2		; position dbut zone "alpha"OBKEYS:	.BLK.8	2		; couple touche - fonctionOBWRITE:.BLK.8	40		; buffer pour write fentreOPDIS:	.BLK.8	4		; ^descripteur de $DIS_n (en permanance)	.IF	COLOROPDIS0:	.BLK.8	4		; ^descripteur de $DIS_0 (en permanance)OPDIS1:	.BLK.8	4		; ^descripteur de $DIS_20 (en permanance)	.ENDIFOBDIS:	.BLK.8	LBDIS		; buffer pour read $DIS_nOBSKEY:	.BLK.8	LGKEY1		; buffer pour status $KEYOMINY:	.BLK.8	2		; coor Y minimaleOMINX:	.BLK.8	2		; coor X minimaleOMAXY:	.BLK.8	2		; coor Y maximaleOMAXX:	.BLK.8	2		; coor X maximaleOLGY:	.BLK.8	2		; hauteur du lutin de la sourisOLGX:	.BLK.8	2		; largeur du lutin de la souris	.IF	COLOROPTVS:	.BLK.8	4		; ^dans OTAVSOTAVS:	.BLK.8	MAXVS*LVS	; table des crans multiples	.ENDIFLGVAR:; Programme; ---------	.LOC	0START:	MOVE.32	#16'10001,D7	; D7 <-- ne prend plus le clavier !	LIB	?OPELIB	MOVE.32	#LGVAR,D4	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ER2	GESMEM	?CLEARMEM	; met toutes les variables  zro	MOVE.32	A4,A6		; A6 <-- ^variables;	CLR.8	{A6}+OFLAGS	; clear tous les flags	MOVE.8	#-1,{A6}+OBOUTON;	CLR.8	{A6}+OWMOUSE;	CLR.32	{A6}+ODLCOM;	CLR.32	{A6}+OBEGZO	; pas de dbut zone "alpha";;?	LOAD.W	D3,#1;;?	LIB	?ASSKEY		; redonne clavier au CLE !	MOVE.32	#R16^NLMOU,A3	; A3 <-- ^nom logique	MOVE.32	#R16^NPMOU,A4	; A4 <-- ^nom physique	MOVE.32	#0,A2		; A2 <-- pas de paramtres	CLR.16	D3		; D3 <-- pour tous	FOS	?INSTALL	; installe driver souris ...	JUMP,NE ER2	MOVE.16	#2**BOPRD,D3	FOS	?OPEN		; ouvre la souris	JUMP,NE ER1	MOVE.16	D6,{A6}+OCHMOU	; mm canal souris	LIB	?PCHMOU		; donne canal  la librairie	MOVE.32	#R16^NPDIS0,A3	MOVE.16	#2**BOPWR,D3	FOS	?OPEN		; ouvre $DIS_0	MOVE.16	D6,{A6}+OCHDIS	; mm canal fentre principale	LIB	?PCHDIS		; donne canal  la librairie	.IF	COLOR	MOVE.16	D6,{A6}+OCHDI0	MOVE.32	#0,A3		; A3 <-- ^nom logique	MOVE.32	#R16^NPDIS1,A4	; A4 <-- ^nom physique	MOVE.32	#0,A2		; A2 <-- pas de paramtres	CLR.16	D3		; D3 <-- pour tous	FOS	?INSTALL	; installe $DIS_20	MOVE.32	#R16^NPDIS1,A3	MOVE.16	#2**BOPWR,D3	FOS	?OPEN		; ouvre $DIS_20	MOVE.16	D6,{A6}+OCHDI1	.ENDIF	FOS	?OPINFO		; ouvre SYS_INFO	MOVE.32	A4,{A6}+OPINFO	; mm. ^SYS_INFO en premanance (!)	CLR.16	D4		; D4 <-- pas de mise  jour	FOS	?CLINFO		; ferme SYS_INFO	LIB	?AFTIM	.8	NOCURS,NOROLL,0	.EVEN	MOVE.32	#{A6}+OPDIS,A4	; A4 <-- ^buffer	MOVE.32	#4,D4		; D4 <-- longueur pour le ^	MOVE.16	#TYPDIS,D3	; D3 <-- type fentre principale	MOVE.16	{A6}+OCHDIS,D6	; D6 <-- canal de $DIS_0	FOS	?RSTATUS	; OPDIS0 <-- ^descripteur de $DIS_0	.IF	COLOR	MOVE.32	{A6}+OPDIS,{A6}+OPDIS0	MOVE.32	#{A6}+OPDIS1,A4	; A4 <-- ^buffer	MOVE.32	#4,D4		; D4 <-- longueur pour le ^	MOVE.16	#TYPDIS,D3	; D3 <-- type fentre principale	MOVE.16	{A6}+OCHDI1,D6	; D6 <-- canal de $DIS_20	FOS	?RSTATUS	; OPDIS1 <-- ^descripteur de $DIS_20	.ENDIF	.IF	COLOR	CLR.32	{A6}+OTAVS+(LVS*0)+OVSPOS	MOVE.32	#16'10000*LVIEWY+LVIEWX+10,{A6}+OTAVS+(LVS*0)+OVSDIM	MOVE.16	{A6}+OCHDI0,{A6}+OTAVS+(LVS*0)+OVSCHD	MOVE.32	{A6}+OPDIS0,{A6}+OTAVS+(LVS*0)+OVSPTD	MOVE.32	#LVIEWX+10,{A6}+OTAVS+(LVS*1)+OVSPOS	MOVE.32	#16'10000*(PCVIEWY+10)+PCVIEWX+10,{A6}+OTAVS+(LVS*1)+OVSDIM	MOVE.16	{A6}+OCHDI1,{A6}+OTAVS+(LVS*1)+OVSCHD	MOVE.32	{A6}+OPDIS1,{A6}+OTAVS+(LVS*1)+OVSPTD	MOVE.32	#{A6}+OTAVS+(LVS*0),A4	MOVE.32	A4,{A6}+OPTVS	MOVE.32	{A4}+OVSPOS,D3	MOVE.32	{A4}+OVSDIM,D4	LIB	?PPMOUSE	; donne l'information  la librairie !	.ENDIF	CLR.32	{A6}+OMINY	; init OMINX et OMINY	MOVE.16	#LVIEWX+10,{A6}+OMAXX	MOVE.16	#LVIEWY,{A6}+OMAXY	.IF	SM100.OR.SM300.OR.SM196	MOVE.16	#10*2+2,D4	; init Y initial	SWAP.32	D4	MOVE.16	#10,D4		; init X initial	.ENDIF	.IF	SM8.OR.SM324BIG	MOVE.16	#16*2+2,D4	; init Y initial	SWAP.32	D4	MOVE.16	#10,D4		; init X initial	.ENDIF	CALL	MOPO		; positionne la sourisLOOP1$:	MOVE.32	D4,{A6}+OOLDPOS	; mm coor. actuelleLOOP2$:	CALL	MFLECHE		; dplace la flche	MOVE.16	#2,D4		; D4 <-- attente si bouton(s) press(s);;?	.IF	.NOT.(SM100.OR.SM300.OR.SM324)	TEST.8	{A6}+OBOUTON	; bouton(s) press(s) ?	JUMP,NE	 R8^DELMS$	; oui => DELMS$	MOVE.16	#1,D4		; D4 <-- attente si aucun bouton pressDELMS$:				; attend un p'tit peu, ce qui permet aux;;?	.ENDIF	NTREL	?DELMS		; autres processus de faire quelque chose !	MOVE.16	#50/4,D4	NTREL	?SETTIM		; met timeout de 1/4 seconde	LIB	?MRDMOUSE	; lit la souris ...	PUSH.16	D7	MOVE.16	#-1,D4	NTREL	?SETTIM		; remet timeout infini	POP.16	D7	.IF	COLOR	JUMP,NE	 R8^L20$	PUSH.16	D7	CALL	VSSEARCH	; cherche l'cran o est la souris	POP.16	D7L20$:	.ENDIF	MOVE.32	{A3}+0,D4	; D4 <-- nouvelle coordonne	MOVE.8	{A3}+4,D3	; D3 <-- boutons master	TEST.16	D7	JUMP,NE LOOP2$	CALL	KEYMOU		; utile si souris par le clavier	COMP.8	{A6}+OBOUTON,D3	; les boutons ont-ils changs ?	JUMP,EQ	 R8^BSAME$	; non => BSAME$	MOVE.8	D3,{A6}+OBOUTON	; oui => mm nouveaux boutons	CALL	EXBMOU		; excute selon bouton souris	MOVE.8	D3,{A3}+5	; init boutons pour userBSAME$:;;?	LOAD.B	D3,#BIPLIT	; D3 <-- tout petit bruit	COMP.16	{A6}+OMINX,D4	JUMP,GE	 R8^MINX$	MOVE.16	{A6}+OMINX,D4	CALL	MOPO;;?	LIB	?BEEPMINX$:	MOVE.16	{A6}+OMAXX,D2	SUB.16	{A6}+OLGX,D2	COMP.16	D2,D4	JUMP,LT	 R8^MAXX$	MOVE.16	D2,D4	CALL	MOPO;;?	LIB	?BEEPMAXX$:	SWAP.32	D4	COMP.16	{A6}+OMINY,D4	JUMP,GE	 R8^MINY$	MOVE.16	{A6}+OMINY,D4	SWAP.32	D4	CALL	MOPO	SWAP.32	D4;;?	LIB	?BEEPMINY$:	MOVE.16	{A6}+OMAXY,D2	SUB.16	{A6}+OLGY,D2	COMP.16	D2,D4	JUMP,LT	 R8^MAXY$	MOVE.16	D2,D4	SWAP.32	D4	CALL	MOPO	SWAP.32	D4;;?	LIB	?BEEPMAXY$:	SWAP.32	D4	MOVE.32	{A6}+OPDIS,A4	; A4 <-- ^descripteur de $DIS_0 ou $DIS_20	.IF	COLOR	COMP.8	#NOWDOC,{A4}+ODFNOW	JUMP,EQ	 R8^END$	.ENDIF	CLR.16	D1	MOVE.16	#LVIEWX+10,D2	COMP.8	#"L",{A4}+ODFCAD+1	JUMP,EQ	 R8^LIMIT$	MOVE.16	#1024-LVIEWX,D1	MOVE.16	#1024,D2	COMP.8	#"R",{A4}+ODFCAD+1	JUMP,NE	 R8^END$LIMIT$:	MOVE.16	D1,{A6}+OMINX	MOVE.16	D2,{A6}+OMAXXEND$:	JUMP	LOOP1$;;?FINI:;;?	CLR.W	D6;;?	LIB	?PCHMOU		; plus de souris dans LIB !;;?;;?	LOAD.W	D6,(A6)+OCHMOU	; D6 <-- canal souris;;?	FOS	?CLOSE		; ferme la sourisER1:	MOVE.32	#R16^NLMOU,A3	CLR.16	D3	FOS	?DEINSTALL	; d-installe driver sourisER2:	LIB	?CLOLIB	FOS	?STOP	.IF	COLOR;---------\\; VSSEARCH >;=========/; Cherche dans quelle cran (monochrome ou couleur) est la souris.; in	A3.L	^position de la souris; out	(A3)	nouvelle position; mod	D7.WVSSEARCH:	PUSHM.32 D3|D4|A4	MOVE.32	#{A6}+OTAVS,A4L10$:	TEST.32	{A4}+OVSDIM	; encore un cran ?	JUMP,EQ	 R8^L50$	; non => 50$	MOVE.32	{A3},D4		; D4 <-- position de la souris	SUB.16	{A4}+OVSPOS+2,D4 ; trop  gauche ?	JUMP,LO	 R8^L20$	COMP.16	{A4}+OVSDIM+2,D4 ; trop  droite ?	JUMP,HS	 R8^L20$	SWAP.32	D4	SUB.16	{A4}+OVSPOS+0,D4 ; trop en haut ?	JUMP,LO	 R8^L20$	COMP.16	{A4}+OVSDIM+0,D4 ; trop en bas ?	JUMP,LO	 R8^L30$L20$:	ADD.32	#LVS,A4	JUMP	L10$L30$:	MOVE.32	A4,{A6}+OPTVS	SWAP.32	D4	MOVE.32	D4,{A3}		; (A3) <-- position relative	MOVE.32	{A4}+OVSDIM,{A6}+OMAXY	MOVE.16	{A4}+OVSCHD,{A6}+OCHDIS	MOVE.32	{A4}+OVSPTD,{A6}+OPDIS	MOVE.32	{A4}+OVSPOS,D3	MOVE.32	{A4}+OVSDIM,D4	LIB	?PPMOUSE	; donne l'information  la librairie !	JUMP	R8^L90$L50$:	MOVE.32	{A6}+OPTVS,A4	MOVE.32	{A3},D4		; D4 <-- position de la souris	SUB.16	{A4}+OVSPOS+2,D4	SWAP.32	D4	SUB.16	{A4}+OVSPOS+0,D4	SWAP.32	D4	MOVE.32	D4,{A3}		; (A3) <-- position relativeL90$:	POPM.32	D3|D4|A4	RET	.ENDIF;--------\; KEYMOU  >;========/; Si on est en mode "souris par le clavier", envoie les; boutons de la souris presss/relachs dans le clavier.; in	D3.B		nouveaux boutons;	{A6}+OBOUTON.B	anciens boutons;	D4.32		position; out	-; mod	D7.WKEYMOU:	PUSHM.32 D0|D1|D2|D3|D4|D5|D6|A0|A4	MOVE.32	D4,D0		; D0 <-- position de la souris	MOVE.8	D3,D2	LIB	?VASSKEY	; D3 <-- no clavier "utilis"	JUMP,NE L90$	LIB	?SRCCHK		; D4:#17=1 --> souris par clavier	JUMP,NE L90$		; D6 <-- canal du clavier	TEST.32	D4:#17		; souris par le clavier ?	JUMP,BC L90$;;?	LOAD.W	D1,D4		; D1 <-- no fentre	MOVE.8	D2,D3		; D3 <-- nouveaux	MOVE.8	{A6}+OBOUTON,D2	; D2 <-- anciens	MOVE.8	D3,D4	NOT.8	D4		; D4 <-- nouveaux inverss	MOVE.8	D2,D5	NOT.8	D5		; D5 <-- anciens inverss	OR.8	D2,D4		; D4 <-- zro si bouton press	OR.8	D3,D5		; D5 <-- zro si bouton relach	MOVE.16	#KEYMGP,D2	TEST.32	D4:#BMOLEFT	; bouton press ?	JUMP,BC	 R8^L50$	; oui => 50$	MOVE.16	#KEYMMP,D2	TEST.32	D4:#BMOCENT	; bouton press ?	JUMP,BC	 R8^L50$	; oui => 50$	MOVE.16	#KEYMDP,D2	TEST.32	D4:#BMORIGHT	; bouton press ?	JUMP,BC	 R8^L50$	; oui => 50$	MOVE.16	#KEYMGR,D2	TEST.32	D5:#BMOLEFT	; bouton relach ?	JUMP,BC	 R8^L50$	; oui => 50$	MOVE.16	#KEYMMR,D2	TEST.32	D5:#BMOCENT	; bouton relach ?	JUMP,BC	 R8^L50$	; oui => 50$	MOVE.16	#KEYMDR,D2	TEST.32	D5:#BMORIGHT	; bouton relach ?	JUMP,BC	 R8^L50$	; oui => 50$	MOVE.32	#{A6}+OBSKEY,A4	; A4 <-- ^buffer pour status	MOVE.32	#LGKEY1,D4	; D4 <-- lg buffer	MOVE.16	#TYPKEY,D3	; D3 <-- type clavier	FOS	?RSTATUS	; lit le status du clavier	JUMP,NE	 R8^L90$	TEST.16	{A4}+OKYUSF	; fifo vide ?	JUMP,NE	 R8^L90$	; non => 90$				; oui =>	MOVE.16	#KEYMPO,D2	; D2 <-- souris bouge	JUMP	R8^L60$L50$:	MOVE.32	D0,D4		; D4 <-- position de la souris;;?	LOAD.W	D5,D1		; D5 <-- no fentre	CALL	SRCWDO		; D3 <-- fentre actuelle	JUMP,NE	 R8^L90$	; si pas dans fentre => 90$	COMP.16	#WDOSKY,D3	; est-on dans $DIS_7 ?	JUMP,EQ	 R8^L90$	; oui => 90$;;?	COMP.W	D3,D5		; est-on dans la bonne fentre ?;;?	JUMP',NE 90$		; non => 90$L60$:	CLR.32	D3	MOVE.16	D2,D3		; D3 <-- "touche"  envoyer	LIB	?WRAKEY		; envoie bouton press/relachL90$:	POPM.32	D0|D1|D2|D3|D4|D5|D6|A0|A4	RET;--------\; EXBMOU  >;========/; Excute qq chose selon un bouton de la souris.; in	D4.L	coordonnes de la souris;	D3.8	boutons de la souris; out	D3.B	boutons de la souris (- qq z'un); mod	D3.B, D7.WEXBMOU:	PUSHM.32 D0|D1|D2|D4|D6|A0|A4	CLR.16	D7		; D7 <-- ok	MOVE.8	D3,D2		; D2 <-- boutons de la souris	JUMP,EQ	 R8^L10$	; si tous relachs => 10$	TEST.32	D2:#BMORIGHT	; (DROITE) press ?	JUMP,BS L60$		; oui => 60$	TEST.32	D2:#BMOCENT	; (CENTRE) press ?	JUMP,BS L40$		; oui => 40$	TEST.32	D2:#BMOLEFT	; (GAUCHE) press ?	JUMP,BS	 R8^L20$	; oui => 20$	JUMP	L90$L10$:	MOVE.32	{A6}+OBEGZO,D3	; dbut zone "alpha" existe ?	JUMP,EQ L90$		; non => 90$	CLR.32	{A6}+OBEGZO	MOVE.16	{A6}+OCHAZO,D6	; D6 <-- canal fentre	CALL	SNDWORD		; envoie qq mot(s) complet(s)	JUMP	L90$L20$:				; (GAUCHE) -->	CALL	DOASSKEY	; oui => assigne le clavier	JUMP,EQ L35$		; si assignation ok => 35$				; dj fait ou pas possible =>	CALL	SRCSKY		; cherche soft key	JUMP,NE	 R8^L25$	; pas trouv => 25$	CALL	SNDSKY		; envoie une soft key	JUMP,NE L90$		; erreur => 90$	JUMP	L35$		; ok => 35$L25$:	CALL	SRCFLO		; cherche ENTER/RELEASE floppy	JUMP,EQ L35$		; ok => 35$				; pas trouv =>	CALL	SRCWDO		; D3 <- no fentre, D6 <- canal	JUMP,NE L90$		; si pas dans fentre => 90$	MOVE.16	#1,D7		; D7 <-- erreur quelconque	TEST.8	D3		; dans $DIS_0 (bitmap) ?	JUMP,EQ L90$		; oui => 90$	COMP.8	#WDOSKY,D3	; dans $DIS_7 (soft keys) ?	JUMP,EQ L90$		; oui => 90$	MOVE.32	D4,D0		; D0 <-- coordonne souris	LIB	?SRCWDO		; fen. utilise normalement ?	JUMP,NE L90$		; non => 90$	LIB	?VASSKEY	; D3 <-- no clavier "utilis"	JUMP,NE L90$	LIB	?SRCKEY		; D4:#16=1 --> utilise souris	JUMP,NE L90$	TEST.32	D4:#16		; utilise les boutons ?	JUMP,BS L95$		; oui => silence				; non =>	CALL	IFSWORD		; lecture fentre possible ?	JUMP,NE	 R8^L90$	; non => 90$				; oui =>	MOVE.32	D0,{A6}+OBEGZO	; mm. dbut zone "alpha"	MOVE.16	D6,{A6}+OCHAZO	; mm. canal fentreL35$:	TCLR.32	D2:#BMOLEFT	; "cache" le bouton press	JUMP	R8^L90$L40$:				; (CENTRE) -->	MOVE.16	#UNDO,D0	CALL	L00$		; essaye d'envoyer un (UNDO)	JUMP,NE	 R8^L95$	TCLR.32	D2:#BMOCENT	; "cache" le bouton press	JUMP	R8^L90$L60$:				; (DROITE) -->	MOVE.16	#CR,D0	CALL	L00$		; essaye d'envoyer un (RETURN)	JUMP,NE	 R8^L95$	TCLR.32	D2:#BMORIGHT	; "cache" le bouton pressL90$:	TEST.16	D7		; ok ?	JUMP,EQ	 R8^L95$	; oui => 95$	PUSH.16	D7	MOVE.8	#BIPLIT,D3	LIB	?BEEP		; p'tit bruit	POP.16	D7L95$:	MOVE.8	D2,D3		; D3 <-- boutons de la souris	POPM.32	D0|D1|D2|D4|D6|A0|A4	RET; in	D0.W	touche  envoyer;	D4.32	coordonnes de la souris; out	D7.W	erreur; mod	D4.W, D7.W, A0.L, A4.LL00$:	PUSH.32	D3	LIB	?VASSKEY	; D3 <-- no clavier "utilis"	JUMP,NE	 R8^L09$	LIB	?SRCKEY		; D4:#16=1 --> utilise souris	JUMP,NE	 R8^L09$	MOVE.16	#1,D7		; D7 <-- erreur quelconque	TEST.32	D4:#16		; utilise les boutons ?	JUMP,BS	 R8^L09$	; oui => ne fait rien				; non =>	CALL	SNDSKY		; envoie un (RETURN)L09$:	POP.32	D3	TEST.16	D7		; retour EQ/NE	RET;---------\; DOASSKEY >;=========/; Assigne le clavier  la fentre dans laquelle se trouve; le curseur.; in	D4.L	coordonnes de la souris; out	D7.W	erreur; mod	D7.WDOASSKEY:	PUSHM.32 D3|D4|D6|A3|A4	CALL	SRCWDO		; D3 <-- numro fentre	JUMP,NE	 R8^L90$	; si curseur ailleurs => 90$	MOVE.16	#1,D7	TEST.8	D3		; fentre principale ?	JUMP,EQ	 R8^L90$	; oui => 90$	COMP.8	#WDOSKY,D3	; fentre des soft keys ?	JUMP,EQ	 R8^L90$	; oui => 90$	LIB	?SRCWDO		; D4 <-- no clavier physique	JUMP,NE	 R8^L90$	MOVE.16	D4,D3		; D3 <-- no clavier physique	LIB	?ASSKEY		; assigne le clavier;;?	JUMP',EQ 90$		; ok => 90$;;?	COMP.W	D7,#H'8000	; dj assign ?;;?	JUMP',EQ 90$		; oui => pas de bruitL90$:	POPM.32	D3|D4|D6|A3|A4	TEST.16	D7		; retour EQ/NE	RET;--------\; SRCWDO  >;========/; Cherche la fentre dans laquelle se trouve la souris.; in	-; out	D0.B	commande U/D;	D1.8	commande L/R;	D3.16	no fentre (0..n);	D7.16	<>0 => la souris n'est pas dans une fentre; mod	D0.W, D1.W, D3.W, D7.WSRCWDO:	PUSH.32	A4	MOVE.32	{A6}+OPDIS,A4	; A4 <-- ^descripteur de $DIS_0 ou $DIS_20	MOVE.16	#1,D7	CLR.16	D3	MOVE.8	{A4}+ODFNOM,D3	; D3 <-- no fentre	JUMP,EQ	 R8^L90$	MOVE.8	{A4}+ODFCAM+0,D0 ; D0 <-- U/D	MOVE.8	{A4}+ODFCAM+1,D1 ; D1 <-- L/R	CLR.16	D7		; D7 <-- okL90$:	POP.32	A4	TEST.16	D7		; retour EQ/NE	RET;--------\; IFSWORD >;========/; Vrifie s'il est possible de lire dans cette fentre.; in	D6.W	canal de la fentre o est la souris; out	D7.W	zro => possible; mod	D7.WIFSWORD:	PUSHM.32 D3|D4|A4	MOVE.32	#{A6}+OBDIS,A4	; A4 <-- ^buffer read $DIS_n	MOVE.32	#LGDIS2,D4	; D4 <-- longueur du buffer	MOVE.16	#TYPWDO,D3	; D3 <-- type fentre qq	FOS	?RSTATUS	; demande infos fentre	JUMP,NE	 R8^L90$	TEST.8	{A4}+ODFFLG:#BFIMAA ; image alpha existe ?	JUMP,BS	 R8^L90$	; oui => 90$	MOVE.16	#1,D7L90$:	POPM.32	D3|D4|A4	TEST.16	D7		; retour EQ/NE	RET;--------\; SNDWORD >;========/; Envoie au driver de clavier le mot situ dans l'cran autour; de la souris.; in	D3.L	coordonne souris dbut zone;	D4.32	coordonne souris fin zone;	D6.16	canal de la fentre o est la souris;		(rendu par l'appel LIB,?SRCWDO); out	D7.W	erreur; mod	D7.WSNDWORD:	PUSHM.32 D0|D1|D2|D3|D4|D5|D6|A4	LIB	?PCHDIS		; lib <-- nouveau canal	MOVE.16	D4,D5		; D5 <-- fin	MOVE.16	D3,D4		; D4 <-- dbut	SUB.16	D4,D5		; D5 <-- longueur en X	JUMP,NC	 R8^L10$	; longueur positive ?	NEG.16	D5		; non => valeur absolue	SUB.16	D5,D4		; D4 <-- dbut  gaucheL10$:	PUSH.32	D4	MOVE.32	#{A6}+OBDIS,A4	; A4 <-- ^buffer read $DIS_n	MOVE.32	#LGDIS1,D4	; D4 <-- longueur du buffer	MOVE.16	#TYPWDO,D3	; D3 <-- type fentre qq	FOS	?RSTATUS	; demande infos fentre	POP.32	D4	TEST.16	D7		; ok ?	JUMP,NE L90$		; non => 90$	MOVE.16	#ERDIOUT,D7	SUB.16	{A4}+ODFX,D4	JUMP,LO L90$	SUB.16	{A4}+ODFFX,D4	; D4 <-- coord. X relative	JUMP,LO L90$	COMP.16	{A4}+ODFFDX,D4	; dans sous-fentre en X ?	JUMP,HS L90$		; non => 90$	SWAP.32	D4	SUB.16	{A4}+ODFY,D4	JUMP,LO L90$	SUB.16	{A4}+ODFFY,D4	; D4 <-- coord. Y relative	JUMP,LO L90$	COMP.16	{A4}+ODFFDY,D4	; dans sous-fentre en Y ?	JUMP,HS L90$		; non => 90$	SWAP.32	D4	CLR.32	D2	MOVE.16	D4,D2		; D2 <-- pos. dans ligne en pts	DIV.16	{A4}+ODFCX,D2	; D2 <-- pos. dans ligne en car	DIV.16	{A4}+ODFCX,D5	; D5 <-- lg ligne en car	CLR.32	D3	MOVE.16	{A4}+ODFFDX,D3	; D3 <-- largeur fentre en pts	DIV.16	{A4}+ODFCX,D3	; D3 <-- nb de car/ligne	COMP.16	#LBDIS,D3	; buffer trop petit ?	JUMP,LS	 R8^L20$	; non => 20$	MOVE.16	#LBDIS,D3	; oui => lit le maximum !L20$:	MOVE.16	D3,D1		; D1 <-- lg du buffer	CLR.16	D4		; D4 <-- coord. Y;X dbut ligne	MOVE.32	#{A6}+OBDIS,A4	; A4 <-- ^buffer	CALL	MOPICK		; lit toute une ligne	JUMP,NE L90$		; si erreur => 90$	CLR.8	D0		; D0 <-- nb de car. trouvs	MOVE.8	{A4}+A16^{D2},D3; D3 <-- car. sous la souris	CALL	MOTERM		; terminateur ?	JUMP,EQ L70$		; oui => 70$L40$:	TEST.16	D2		; trop  gauche ?	JUMP,EQ	 R8^L50$	; oui => 50$	DEC.16	D2		; D2 <-- pos. car. prcdent	INC.16	D5		; D5 <-- augmente lg zone	MOVE.8	{A4}+A16^{D2},D3; D3 <-- car. prcdent	CALL	MOTERM		; dbut d'un "mot" ?	JUMP,NE L40$		; non => 40$	INC.16	D2		; D2 <-- pos. dbut du mot	DEC.16	D5		; D5 <-- lg zone depuis dbutL50$:	MOVE.8	{A4}+A16^{D2},D3; D3 <-- un car. du "mot"	CALL	MOTERM		; fin du "mot" ?	JUMP,EQ	 R8^L60$	; oui => 60$L55$:	AND.16	#16'FF,D3	; D3 <-- pas de touche fonction	LIB	?WRAKEY		; envoie touche au clavier	INC.8	D0		; D0 <-- un car. de plus trouv	DEC.16	D5		; D5 <-- diminue lg zone	INC.16	D2		; D2 <-- pos. caractre suivant	COMP.16	D1,D2		; fin du buffer ?	JUMP,NE L50$		; non => 50$	JUMP	R8^L70$		; oui => 70$L60$:	TEST.16	D5		; encore un mot ?	JUMP,GT L55$		; oui => 55$L70$:	COMP.8	#1,D0		; un seul car. trouv ?	JUMP,EQ	 R8^L90$	; oui => 90$	MOVE.16	#SPACE,D3	; D3 <-- SPACE (sans fonction)	LIB	?WRAKEY		; envoie touche au clavierL90$:	PUSH.16	D7	MOVE.16	{A6}+OCHDIS,D6	LIB	?PCHDIS		; lib <-- canal de $DIS_0 ou $DIS_20	POP.16	D7	POPM.32	D0|D1|D2|D3|D4|D5|D6|A4	TEST.16	D7		; retour EQ/NE	RET;--------\; MOTERM  >;--------/; Test si le caractre dans D3.B est un terminateur de "mot".; in	D3.B	caractre; out	D3.B	caractre v. transform;	EQ	c'est un terminateur; mod	D3.BMOTERM:	AND.8	#16'7F,D3	; masque si inverse vido !;;?	.W	LIB,?MINMAJ	; D3 <-- lettre MAJUSCULE;;?	COMP.B	D3,#'A;;?	JUMP',LO 10$;;?	COMP.B	D3,#'Z		; lettre ?;;?	JUMP',HI 10$		; non => 10$;;?				; oui =>;;?	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule;;?10$:	COMP.8	#SPACE,D3	JUMP,HI	 R8^L40$	; si SPACE..n --> retour NE	JUMP,EQ	 R8^L50$	; si SPACE --> retour EQ				; si 0..SPACE -->	COMP.8	#"",D3	JUMP,LO	 R8^L50$	COMP.8	#"",D3		; lettre accentue ?	JUMP,HI	 R8^L50$	; non => 50$L40$:	CLRZ			; retour NE	RETL50$:	SETZ			; retour EQ	RET;--------\; MOPICK  >;--------/; Lit un caractre dans la fentre, en fonction d'une; coordonne graphique.; in	D4.L	coordonne graphique (Y;X);	A4.32	^buffer;	D3.16	nb de car.  lire; out	D7.W	erreur; mod	D7.WMOPICK:	PUSHM.32 D2|D3|D4|D5|D6|A4	CLR.32	D5	MOVE.16	D3,D5		; D5 <-- lg  lire	LIB	?GETCURS	MOVE.32	D3,D2		; D2 <-- position actuelle	MOVE.32	D4,D3	LIB	?SETCURS	; va nouvelle position	MOVE.32	D5,D4		; D4 <-- longueur  lire	LIB	?GCHDIS		; D6 <-- canal fentre $DIS_n	FOS	?RDBYTE		; lit un byte dans la fentre	JUMP,NS	 R8^L80$	; si erreur => 80$	CLR.16	D7		; D7 <-- okL80$:	PUSH.16	D7	MOVE.32	D2,D3	LIB	?SETCURS	; revient position de dpart	POP.16	D7	POPM.32	D2|D3|D4|D5|D6|A4	TEST.16	D7		; retour EQ/NE	RET;--------\; SRCFLO  >;========/; Cherche si la souris est dans l'icone d'un floppy pour; essayer un ENTER/RELEASE.; in	D4.L	coordonne de la souris; out	D7.W	erreur (ok => ENTER/RELEASE essay); mod	D7.WSRCFLO:	PUSHM.32 D3|D4|D6|A2..A4	MOVE.32	{A6}+OPDIS,A4	; A4 <-- ^descripteur de $DIS_0 ou $DIS_20	MOVE.32	D4,D3		; D4 <-- X	SWAP.32	D3		; D3 <-- Y	MOVE.16	#1,D7		; D7 <-- pas (encore) trouv !	.IF	COLOR	COMP.8	#NOWDOC,{A4}+ODFNOW	JUMP,EQ L90$	.ENDIF	COMP.8	#"R",{A4}+ODFCAD+1	JUMP,NE	 R8^L20$	SUB.16	#1024-LVIEWX,D4	; D4 <-- plus  droite	JUMP,LO L90$L20$:	COMP.16	#DFLOXY,D3	; trop bas ?	JUMP,HI L90$		; oui => 90$	CLR.16	D3	COMP.16	#PBIM0X,D4	; dans icne bitmap 0 ?	JUMP,LO L35$	COMP.16	#PBIM0X+DBIMX,D4	JUMP,LS	 R8^L30$	INC.16	D3	COMP.16	#PBIM1X,D4	; dans icne bitmap 1 ?	JUMP,LO	 R8^L35$	COMP.16	#PBIM1X+DBIMX,D4	JUMP,LS	 R8^L30$	INC.16	D3	COMP.16	#PBIM2X,D4	; dans icne bitmap 2 ?	JUMP,LO	 R8^L35$	COMP.16	#PBIM2X+DBIMX,D4	JUMP,LS	 R8^L30$	INC.16	D3	COMP.16	#PBIM3X,D4	; dans icne bitmap 3 ?	JUMP,LO	 R8^L35$	COMP.16	#PBIM3X+DBIMX,D4	JUMP,HI	R8^L35$L30$:	MOVE.32	{A6}+OPDIS,A2	; A2 <-- ^descripteur de $DIS_0 ou $DIS_20	LIB	?ASSBITMAP	; assigne le clavier au bitmap choisi	JUMP,EQ L90$	.IF	SM324BIG	COMP.16	#ERDNTF,D7	; driver introuvable ?	JUMP,NE L70$		; non => 70$	COMP.16	#1,D3		; fentre de $DIS_2 et $DIS_3 ?	JUMP,EQ	 R8^L32$	; oui => 32$	COMP.16	#2,D3		; fentre de $DIS_4 et $DIS_5 ?	JUMP,NE L70$		; non => 70$L32$:				; oui =>	ADD.8	#SCRBITMAP,D3	MOVE.32	#{A6}+ODLCOM,A4	; A4 <-- ^buffer pour commande	MOVE.8	D3,{A4}+0	; <SCRBITMAP+0..3>	CLR.8	{A4}+1		; <0>	MOVE.16	#TYPDIS,D3	; D3 <-- type fentre princ.	MOVE.16	{A6}+OCHDIS,D6	; D6 <-- canal de $DIS_0 ou $DIS_20	FOS	?COMMAND	; commute fentre simple <--> double	JUMP	L80$	.ELSE	JUMP	L70$	.ENDIFL35$:	CLR.16	D3		; D3 <-- 0 pour (M0)	COMP.16	#PFLO0X,D4	JUMP,LO	 R8^L40$	COMP.16	#PFLO0X+DFLOXY,D4	JUMP,LS	 R8^L60$L40$:	INC.16	D3		; D3 <-- 1 pour (M1)	COMP.16	#PFLO1X,D4	JUMP,LO	 R8^L41$	COMP.16	#PFLO1X+DFLOXY,D4	JUMP,LS	 R8^L60$L41$:	INC.16	D3		; D3 <-- 2 pour (SHIFT-M0)	COMP.16	#PFLO2X,D4	JUMP,LO	 R8^L42$	COMP.16	#PFLO2X+DFLOXY,D4	JUMP,LS	 R8^L60$L42$:	INC.16	D3		; D3 <-- 3 pour (SHIFT-M1)	COMP.16	#PFLO3X,D4	JUMP,LO	 R8^L90$	COMP.16	#PFLO3X+DFLOXY,D4	JUMP,HI	 R8^L90$L60$:	MOVE.16	D3,D4		; D4 <-- 0..3	FOS	?MMVASSIGN	; A3/D3 <-- ^nom physique/type	JUMP,NE	 R8^L70$	TEST.8	{A3}		; nom existe ?	JUMP,EQ	 R8^L70$	; non => L70$	FOS	?RELEASE	; tente un "release"	JUMP,EQ	 R8^L80$	; ok => 80$	COMP.16	#ERUNNI,D7	JUMP,NE	 R8^L70$	FOS	?ENTER		; tente un "enter"	JUMP,EQ	 R8^L80$	; ok => 80$L70$:	MOVE.8	#BIPERR,D3	; erreur =>	LIB	?BEEP		; signal qq chose rat !L80$:	CLR.16	D7		; D7 <-- ENTER/RELEASE essayL90$:	POPM.32	D3|D4|D6|A2..A4	TEST.16	D7		; retour EQ/NE	RET;--------\; SRCSKY  >;========/; Cherche la soft key dans laquelle se trouve la souris.; in	D4.L	coordonne souris; out	D0.W	^touche + fonction  envoyer;	D7.16	<>0 => la souris n'est pas dans une soft key; mod	D0.W, D7.WSRCSKY:	PUSHM.32 D1..D4|A4	MOVE.32	{A6}+OPDIS,A4	; A4 <-- ^descripteur de $DIS_0 ou $DIS_20	MOVE.32	D4,D3		; D4 <-- X	SWAP.32	D3		; D3 <-- Y	MOVE.16	#1,D7		; D7 <-- pas (encore) trouv !	.IF	COLOR	COMP.8	#NOWDOC,{A4}+ODFNOW	JUMP,EQ L90$	.ENDIF	COMP.8	#"D",{A4}+ODFCAD+0	JUMP,NE	 R8^L20$	SUB.16	#LVIEWY,D3	; D3 <-- coord. Y plus basse	JUMP,LO L90$L20$:	COMP.8	#"R",{A4}+ODFCAD+1	JUMP,NE	 R8^L40$	SUB.16	#1024-LVIEWX,D4	; D4 <-- coord. X plus  droite	JUMP,LO L90$L40$:	MOVE.32	{A4}+ODFPSK,A4	; A4 <-- ^table des soft-keys	ADD.A16	{A4}+0,A4	; A4 <-- ^table des positions en X	MOVE.16	{A4}+(16*2)+0,D1	SUB.16	{A4}+(16*2)+12,D4	JUMP,LO	 R8^L90$	SUB.16	#LVIEWY,D3	ADD.16	{A4}+(16*2)+2,D3	JUMP,NC	 R8^L90$	MOVE.16	#F0,D0		; D0 <-- (F0)	ADD.16	{A4}+(16*2)+2,D3	JUMP,NC	 R8^L50$	MOVE.16	#F0+SHIFT,D0	; D0 <-- (SHIFT-F0)	ADD.16	{A4}+(16*2)+2,D3	JUMP,NS	 R8^L90$L50$:	MOVE.16	{A4+},D2	; D2 <-- X	COMP.16	D2,D4	JUMP,LO	 R8^L60$	ADD.16	D1,D2		; D2 <-- X+dX	COMP.16	D2,D4	JUMP,HS	 R8^L60$	CLR.16	D7		; D7 <-- trouv !	JUMP	R8^L90$L60$:	INC.16	D0		; D0 <-- (Fn) suivant	MOVE.8	D0,D2	AND.8	#2'1111,D2	JUMP,NE L50$L90$:	POPM.32	D1..D4|A4	TEST.16	D7		; retour EQ/NE	RET;--------\; SNDSKY  >;========/; Envoie une commande SNDKEY au clavier $KEY_0 pour simuler; le fait qu'une touche (soft-key ou autre) a t presse.; in	D0.W	^couple touche + fonction; out	D7.W	erreur; mod	D7.WSNDSKY:	PUSH.32	D3	CLR.32	D3	MOVE.16	D0,D3		; D3 <-- fonction/touche	LIB	?WRAKEY		; envoie touche + fonction	POPM.32	D3	RET;--------\; MOPO    >;========/; Modifie la position en X;Y de la souris.; in	D4.L	nouvelle position (Y;X); out	D7.W	erreur; mod	D7.WMOPO:	PUSHM.32 D3|D4|D6|A4	.IF	COLOR	MOVE.32	{A6}+OPTVS,A4	ADD.16	{A4}+OVSPOS+2,D4	SWAP.32	D4	ADD.16	{A4}+OVSPOS+0,D4	SWAP.32	D4	.ENDIF	MOVE.32	#{A6}+OBWRITE+1,A4	MOVE.8	#"P",{A4}+0	MOVE.32	D4,{A4}+1	CLR.8	{A4}+5	MOVE.16	#TYPIO,D3	MOVE.16	{A6}+OCHMOU,D6	; D6 <-- canal de la souris	FOS	?COMMAND	POPM.32	D3|D4|D6|A4	RET;--------\\; MFLECHE >;========/; Dplace la flche de la souris, et change la flche-lutin; si ncessaire.; in	D4.L	coordonne; out	D7.W	erreur; mod	D7.WMFLECHE:	PUSHM.32 D3|D4|D6|A4	MOVE.32	#{A6}+OBWRITE,A4	MOVE.8	#0,{A4+}	; NOP + odd alignment	MOVE.8	#DRAWMOUSE,{A4+}	TEST.16	D4	JUMP,NC	 R8^L10$	CLR.16	D4L10$:	MOVE.16	D4,{A4+}	; <xx>	SWAP.32	D4	TEST.16	D4	JUMP,NC	 R8^L15$	CLR.16	D4L15$:	MOVE.16	D4,{A4+}	; <yy>	CLR.32	{A4+}		; <ssss>	CLR.32	{A4+}		; <cccc>	CLR.8	{A4+}		; <o>	MOVE.32	A4,D4	MOVE.32	#{A6}+OBWRITE,A4	SUB.32	A4,D4	MOVE.16	{A6}+OCHDIS,D6	FOS	?WRBYTE		; dplace le lutin	MOVE.32	{A6}+OPDIS,A4	; A4 <-- ^descripteur de $DIS_0 ou $DIS_20	MOVE.16	{A4}+ODFMDI+2,{A6}+OLGX	MOVE.16	{A4}+ODFMDI+0,{A6}+OLGY	POPM.32	D3|D4|D6|A4	RETNPMOU:	.ASCIZ	"$MOUSE"NLMOU:	.ASCIZ	"#MOUSE"NPDIS0:	.ASCIZ	"$DIS_0"	.IF	COLORNPDIS1:	.ASCIZ	"$DIS_20"	.ENDIFNPKEY:	.ASCIZ	"$KEY_0"	.EVEN	.START	START	.END