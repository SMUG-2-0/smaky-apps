	.CHAP	DISGC;----------\\; CONVNEWGC >;----------/; Converti "fst" pour les "vieux" appels LOADGC/USEGC/KILLGC.; in	D0.B	fonte;	D1.8	style/chasse;	D2.8	taille; out	D0.B	fonte;	D1.32	style/chasse;	D2.8	taille; mod	D0.B, D1.L, D2.B, D7.WCONVNEWGC:	AND.32	#16'000000FF,D1	TEST.32	D0:#7		; gencar construit ?	JUMP,BC	 R8^L90$	; non => 90$				; oui =>	SL.32	#8,D1	MOVE.8	#"R",D1		; D1 <-- style "Roman"	TEST.32	D1:#8+7	JUMP,BC	 R8^L90$	TSET.32	D1:#7		; D1 <-- chasse "Fixe"L90$:	RET;--------\; GCLOAD  >;========/; Charge un gnrateur en mmoire.; in	A2.L	^description fentre;	D0.8	fonte;	D1.32	style/chasse;	D2.8	taille; out	D7.W	erreur; mod	D7.WGCLOAD:	PUSHM.32 D0..D6|A1|A3|A4|A5;--DD--	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore;--DD--	NTREL	?UNLOCK		; fin de zone critique;--DD -> dplac plus loin	CALL	SRCEQ		; cherche v. quivalence	TEST.32	D0:#7		; gencar " construire" ?	JUMP,BC L85$		; non => 85$				; oui =>	CALL	GETTGC		; gnrateur  construire dj charg ?	TEST.16	D7	JUMP,NE	 R8^L10$	; non => 10$				; oui =>	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D3,D0	SR.16	#3,D0	TSET.8	{A3}+A16^{D0}:D3; ODFMAP <-- ajoute un bit	JUMP,BS L90$		; si dj l => 90$	INC.8	{A1}+OGCUSE	; une utilisation de plus	JUMP	L90$L10$:	CALL	PUTTGC		; cherche lment libre ds TAGC	TEST.16	D7		; A1 <-- ^dans TAGC	JUMP,NE L90$	MOVE.16	D3,D6		; D6 <-- position dans TAGC	TCLR.32	D0:#7	MOVE.8	D0,D3		; D3 <-- fonte	MOVE.32	D1,D4		; D4 <-- style	MOVE.8	D2,D5		; D5 <-- taille	AND.32	#16'000000FF,D1	CALL	GCHLOAD		; charge le gencar de base	JUMP,EQ	 R8^L40$	; ok => 40$	COMP.16	#1,D7	JUMP,EQ	 R8^L40$	COMP.16	#ERDIGC,D7	JUMP,NE L80$	SR.8	#1,D2		; D2 <-- 1/2 x taille	CALL	GCHLOAD		; charge le gencar 2x plus petit	JUMP,EQ	 R8^L40$	; ok => 40$	COMP.16	#1,D7	JUMP,NE L80$L40$:	TSET.32	D0:#31		; D0 <-- gencar effectivement charg	COMP.16	#1,D7	JUMP,NE	 R8^L42$	TCLR.32	D0:#31		; D0 <-- chargement pas faitL42$:	TEST.16	{A6}+ONBGCS	; module gencar dj charg ?	JUMP,NE	 R8^L50$	; oui => 50$	MOVE.32	#R16^NMGENC,A3	; A3 <-- ^nom du module gencar	PUSHM.32 D1|D3	MOVE.16	#GENCAR_FIRST,D3; D3 <-- code du premier appel	LIB_	OPEN		; charge le module GENCAR	MOVE.16	D1,{A6}+OCHGCS	; mm. canal du module	POPM.32	D1|D3	TEST.16	D7	JUMP,NE L70$L50$:	INC.16	{A6}+ONBGCS	; un gencar soft de plus	MOVE.32	A4,A3	RR.32	#8,D4;;?	GENCAR_	CREATE		; cre un gencar "soft"	GENCAR_	CREAT		; cre un gencar "soft"	RL.32	#8,D4	TEST.16	D7	JUMP,NE	 R8^L70$	COMP.32	A4,A3		; qq chose construit ?	JUMP,EQ	 R8^L80$	; non => 80$	PUSHM.32 D1|D2|A2	MOVE.16	#MTYPCP,D1	; D1 <-- processus courant	MOVE.16	#MTYPBD,D2	; D2 <-- type driver BIOS	MOVE.32	#R16^D0BASE,A2	; A2 <-- ^base de $DIS0	GESMEM	?TRAMEM		; transfre sur compte driver	POPM.32	D1|D2|A2	JUMP,NE	 R8^L70$	MOVE.32	A4,{A1}+OGCPT	; init ^gencar dans TAGC	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D6,D4	SR.16	#3,D4	TSET.8	{A3}+A16^{D4}:D6; ODFMAP <-- ajoute un bit gencar utilis	CLR.16	D7	TEST.32	D0:#31		; D0 <-- gencar effectivement charg ?	JUMP,BC	 R8^L90$	; non => 90$	CALL	GCKILL		; oui => libre le gencar de base	CLR.16	D7	JUMP	R8^L90$L70$:	PUSH.16	D7	CALL	GCKILL		; libre le gencar de base	POP.16	D7L80$:	CLR.8	{A1}+OGCUSE	; libre lment dans TAGC	JUMP	R8^L90$L85$:	AND.32	#16'000000FF,D1	CALL	GCHLOAD		; charge un gencar "hard"	JUMP,EQ	 R8^L90$	COMP.16	#1,D7	JUMP,NE	 R8^L90$	CLR.16	D7		; D7 <-- okL90$:;--DD--	PUSH.16	D7;--DD--	CALL	LOCK		; dbut de zone critique;--DD--	POP.16	D7	POPM.32	D0..D6|A1|A3|A4|A5	RET;--------\; GCHLOAD >;========/; Charge un gnrateur "hard" en mmoire.; in	A2.L	^description fentre;	D0.8	fonte;	D1.32	style/chasse;	D2.8	taille; out	A4.L	^gencar;	D7.16	erreur (1 => chargement inutile); mod	D7.W, A4.LGCHLOAD:	PUSHM.32 D0..D5|A1..A3|A5	CLR.8	D3	TEST.8	D0	JUMP,NE	 R8^L02$	MOVE.8	#"N",D0		; D0 <-- fonte "normal"	INC.8	D3L02$:	TEST.8	D1	JUMP,NE	 R8^L03$	MOVE.8	#"E".OR.2**7,D1	; D1 <-- style "troit/fixe"	INC.8	D3L03$:	TEST.8	D2	JUMP,NE	 R8^L04$	MOVE.8	#DEFTAILLE,D2	; D2 <-- taille par dfaut	INC.8	D3L04$:	TEST.8	D3		; fonte, style ou taille nul ?	JUMP,EQ	 R8^L06$	; non => 06$	CALL	SRCEQ		; oui => cherche v. quivalenceL06$:	MOVE.16	#ERDIIL,D7	COMP.8	#99,D2		; taille > 99 ?	JUMP,HI L90$		; oui => erreur (+ de 2 digits)	CALL	GETTGC		; gnrateur dj charg ?	TEST.16	D7	JUMP,NE	 R8^L10$	; non => 10$				; oui =>	MOVE.16	#1,D7		; D7 <-- chargement inutile	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D3,D0	SR.16	#3,D0	TSET.8	{A3}+A16^{D0}:D3; ODFMAP <-- ajoute un bit	JUMP,BS L70$		; si dj l => 70$	INC.8	{A1}+OGCUSE	; une utilisation de plus	CLR.16	D7		; D7 <-- ok, charg	JUMP	L70$L10$:	CALL	PUTTGC		; cherche lment libre ds TAGC	TEST.16	D7		; A1 <-- ^dans TAGC	JUMP,NE L90$	MOVE.16	D3,D5		; D5 <-- numro gn. dans TAGC	CALL	GCCFILE		; A3 <-- ^nom du fichier	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore ;+++ DD +++	NTREL	?UNLOCK		; fin de zone critique ;+++ DD +++	MOVE.32	#2**BEXNHEAD,D3	; D3 <-- ne charge pas l'en-tte	FOS	?CLOAD		; charge le gnrateur	JUMP,EQ	 R8^L50$	; ok => 50$	XCAR_	CREATE		; cre un gencar quelconque ...	JUMP,NE	 R8^L80$	PUSHM.32 D1|D2|A2	MOVE.16	#MTYPCP,D1	; D1 <-- processus courant	MOVE.16	#MTYPBD,D2	; D2 <-- type driver BIOS	MOVE.32	#R16^D0BASE,A2	; A2 <-- ^base de $DIS0	GESMEM	?TRAMEM		; transfre sur compte driver	POPM.32	D1|D2|A2	INC.8	{A1}+OGCX	; cr par XCARL50$:	PUSH.16	D7						; +++ DD +++;;	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore		; +++ DD +++	CALL	LOCK		; dbut de zone critique	; +++ DD +++	POP.16	D7						; +++ DD +++	MOVE.8	D0,{A1}+OGCNF	MOVE.8	D1,{A1}+OGCNS	MOVE.8	D2,{A1}+OGCNT	MOVE.32	A4,{A1}+OGCPT	; init ^GENCAR dans TAGC	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D5,D0	SR.16	#3,D0	TSET.8	{A3}+A16^{D0}:D5; ODFMAP <-- ajoute un bit gencar utilisL70$:	MOVE.32	{A1}+OGCPT,A4	; A4 <-- ^dbut gencar	JUMP	R8^L90$L80$:	PUSH.16	D7						; +++ DD +++;;	MOVE.32	{A6}+OSEMAX,A5	; A5 <-- ^smaphore		; +++ DD +++	CALL	LOCK		; dbut de zone critique	; +++ DD +++	POP.16	D7						; +++ DD +++	CLR.8	{A1}+OGCUSE	; libre lment dans TAGCL90$:	COMP.16	#ERFDNE,D7	; D7 <-- fichier n'existe pas ?	JUMP,NE	 R8^L95$	; non => 95$	MOVE.16	#ERDIGC,D7	; D7 <-- gencar n'existe pasL95$:	POPM.32	D0..D5|A1..A3|A5	TEST.16	D7		; retour EQ/NE	RET;------------\\; GCMXCARLOAD >;============/; Si ncessaire, charge le module XCAR.; in	-; out	D7.W	erreur; mod	D7.WGCMXCARLOAD:	PUSHM.32 D1|D3|A3	MOVE.16	{A6}+OERGCX,D7	; chargement de XCAR possible ?	JUMP,NE	 R8^L90$	; non => 90$	TEST.16	{A6}+ONBGCX	; module XCAR dj charg ?	JUMP,NE	 R8^L90$	; oui => 90$	MOVE.32	#R16^NMXCAR,A3	; A3 <-- ^nom du module XCAR	MOVE.16	#XCAR_FIRST,D3	; D3 <-- code du premier appel	LIB_	OPEN		; charge le module XCAR	MOVE.16	D1,{A6}+OCHGCX	; mm. canal du module	MOVE.16	D7,{A6}+OERGCX	; OERGCX <-- ok/erreur;	TEST.16	D7	JUMP,NE	 R8^L90$	XCAR_	OPEN		; ouvre XCAR (charge GRAMISC)	;%error	MOVE.16	#1,{A6}+ONBGCX	; module XCAR charg	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D1|D3|A3	TEST.16	D7		; retour EQ/NE	RET;--------\; GCUSE   >;========/; Initialise les paramtres dcrivant les grandeurs d'un; caractre dans la table d'une fentre, en fonction d'un; gnrateur de caractre quelconque.; in	A2.L	^description fentre;	D0.8	fonte;	D1.32	style/chasse;	D2.8	taille; out	D7.W	erreur; mod	D7.WGCUSE:	PUSHM.32 D0..D6|A1|A3	MOVE.8	D0,D4		; D4 <-- fonte	MOVE.32	D1,D5		; D5 <-- style	MOVE.8	D2,D6		; D6 <-- taille	CALL	SRCEQ		; cherche v. quivalence	CALL	GETTGC		; cherche GENCAR dans TAGC	TEST.16	D7	JUMP,NE L90$	MOVE.16	#ERDIGC,D7	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D3,D0	SR.16	#3,D0	TEST.8	{A3}+A16^{D0}:D3; gnrateur utilis ?	JUMP,BC L90$		; non => 90$	TEST.32	D4:#7		; gencar construit ?	JUMP,BC	 R8^L20$	; non => 20$	SR.16	#8,D5L20$:	MOVE.8	D4,{A2}+ODFGCF	MOVE.8	D5,{A2}+ODFGCS	MOVE.8	D6,{A2}+ODFGCT	MOVE.32	{A1}+OGCPT,A1	; A1 <-- ^gnrateur	MOVE.32	A1,{A2}+ODFPGC	; init ^au gnrateur	MOVE.16	{A1}+OGCMWI,{A2}+ODFCX	MOVE.16	{A1}+OGCISP,{A2}+ODFCY	MOVE.16	{A1}+OGCLMA,{A2}+ODFC1X	MOVE.16	{A1}+OGCMH1,{A2}+ODFC1Y	MOVE.16	{A1}+OGCMWI,D0	SUB.16	{A1}+OGCLMA,D0	MOVE.16	D0,{A2}+ODFC2X	MOVE.16	{A1}+OGCMH2,{A2}+ODFC2Y	CLR.16	{A2}+ODFCIX	MOVE.16	{A2}+ODFPX,D0	COMP.16	{A2}+ODFC1X,D0	; position trop  gauche ?	JUMP,HS	 R8^L40$	; non => 40$	MOVE.16	{A2}+ODFC1X,D0	; oui => avance un peuL40$:	MOVE.16	{A2}+ODFFDX,D1	SUB.16	{A2}+ODFC2X,D1	; D1 <-- pos  l'extme droite	COMP.16	D1,D0		; position trop  droite ?	JUMP,LS	 R8^L45$	; non => 45$	MOVE.16	D1,D0		; oui => recule un peuL45$:	MOVE.16	D0,{A2}+ODFPX	; mj la position horizontale	MOVE.16	{A2}+ODFPY,D0	COMP.16	{A2}+ODFC1Y,D0	; position trop haute ?	JUMP,HS	 R8^L50$	; non => 50$	MOVE.16	{A2}+ODFC1Y,D0	; oui => descend un peuL50$:	MOVE.16	{A2}+ODFFDY,D1	SUB.16	{A2}+ODFC2Y,D1	; D1 <-- pos tout en bas	COMP.16	D1,D0		; position trop basse ?	JUMP,LS	 R8^L55$	; non => 55$	MOVE.16	D1,D0		; oui => remonte un peuL55$:	MOVE.16	D0,{A2}+ODFPY	; mj la position verticale	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D0..D6|A1|A3	RET;--------\; GCKILL  >;========/; Supprime un gnrateur en mmoire.; in	A2.L	^description fentre;	D0.8	fonte;	D1.32	style/chasse;	D2.8	taille; out	D7.W	erreur; mod	D7.WGCKILL:	PUSHM.32 D0..D3|A1|A3	CALL	SRCEQ		; cherche v. quivalence	CALL	GETTGC		; cherche GENCAR dans TAGC	TEST.16	D7	JUMP,NE	 R8^L90$	MOVE.16	#ERDIGC,D7	MOVE.32	{A2}+ODFPGC,D0	; D0 <-- ^gencar utilis	COMP.32	{A1}+OGCPT,D0	; gnrateur utilis ?	JUMP,EQ	 R8^L90$	; oui => 90$				; non =>	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D3,D0	SR.16	#3,D0	TCLR.8	{A3}+A16^{D0}:D3; ODFMAP <-- clear bit gencar supprim	JUMP,BC	 R8^L90$	; si dj clear => 90$	CALL	GCKILP		; supprime le gnrateurL90$:	POPM.32	D0..D3|A1|A3	RET;--------\; GCRESET >;========/; Libre tous les gnrateurs utiliss par une fentre.; in	A2.L	^description fentre; out	D7.W	erreur; mod	D7.WGCRESET:	PUSHM.32 D0|D3|A1|A3	MOVE.32	#{A6}+OTAGC,A1	; A1 <-- ^dbut de TAGC	CLR.16	D3		; D3 <-- position dans TAGCL10$:	MOVE.32	#{A2}+ODFMAP,A3	MOVE.16	D3,D0	SR.16	#3,D0	TEST.8	{A3}+A16^{D0}:D3; gnrateur utilis ?	JUMP,BC	 R8^L50$	; non => 50$				; oui =>	CALL	GCKILP		; supprime un gnrateurL50$:	MOVE.32	#{A1}+LGGC,A1	; A1 <-- ^lment suivant	INC.16	D3		; D3 <-- position suivante	COMP.16	#MAXGC,D3	JUMP,NE L10$	CLR.32	{A2}+ODFMAP+0	; clear TOUT le map	CLR.32	{A2}+ODFMAP+4	POPM.32	D0|D3|A1|A3	RET;--------\; GCKILP  >;--------/; Supprime un gnrateur de caractres.; in	A1.L	^gnrateur  supprimer; out	D7.W	erreur; mod	D7.WGCKILP:	PUSHM.32 D0..D2|A3|A4	DEC.8	{A1}+OGCUSE	; une utilisation de moins	JUMP,NE L90$	TEST.8	{A1}+OGCX	; cr par XCAR ?	JUMP,NE L60$		; oui => 60$	TEST.8	{A1}+OGCF:#7	; gencar " construire" ?	JUMP,BS	 R8^L50$	; oui => 50$				; non =>	MOVE.32	{A1}+OGCPT,A4	; A4 <-- ^gnrateur	MOVE.8	{A1}+OGCNF,D0	MOVE.8	{A1}+OGCNS,D1	MOVE.8	{A1}+OGCNT,D2	CALL	GCCFILE		; A3 <-- ^nom du fichier	FOS	?CUNLOAD	; libre le gnrateur	JUMP	R8^L90$L50$:	MOVE.32	{A1}+OGCPT,A4	; A4 <-- ^gnrateur	PUSH.32	A1	MOVE.16	#MTYPBD,D1	; D1 <-- type driver BIOS	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS0	GESMEM	?GIVMEM		; libre la mmoire du gn.	POP.32	A1	DEC.16	{A6}+ONBGCS	; un gencar soft de moins	JUMP,NE	 R8^L90$	MOVE.16	{A6}+OCHGCS,D1	; D1 <-- canal du module gencar	LIB_	CLOSE		; ferme le module gencar	JUMP	R8^L90$L60$:	MOVE.32	{A1}+OGCPT,A4	; A4 <-- ^gnrateur	PUSH.32	A1	MOVE.16	#MTYPBD,D1	; D1 <-- type driver BIOS	MOVE.32	#R16^D0BASE,A1	; A1 <-- ^base de $DIS0	GESMEM	?GIVMEM		; libre la mmoire du gn.	POP.32	A1L90$:	POPM.32	D0..D2|A3|A4	RET;--------\\; GCCFILE >;--------/; Construit le nom d'un fichier gencar.; in	A2.L	^description de la fentre;	D0.8	fonte;	D1.8	style/chasse;	D2.8	taille; out	A3.L	^nom du fichier; mod	D7.W, A3.LGCCFILE:	PUSHM.32 D0..D4|A4	MOVE.32	#{A2}+ODFNGC,A3	; A3 <-- ^buffer pour construire le nom	TEST.8	{A2}+ODFFIX	; prfix spcial ?	JUMP,NE	 R8^L12$	; oui => 12$L10$:				; non =>	MOVE.32	#R16^NAME$,A4L11$:	MOVE.8	{A4+},{A3+}	; non <-- "SMA"	JUMP,NE L11$	DEC.32	A3	JUMP	R8^L15$L12$:				; prfix spcial =>	COMP.8	#"D",D0	JUMP,EQ	 R8^L13$	COMP.8	#"Q",D0		; fonte de l'imprimante ?	JUMP,NE L10$		; non => 10$L13$:	MOVE.32	#{A2}+ODFFIX,A4	; A4 <-- ^prfix	MOVE.16	#4-1,D4		; D4 <-- lg max du prfixL14$:	MOVE.8	{A4+},D3	JUMP,EQ	 R8^L15$	MOVE.8	D3,{A3+}	; nom <-- prfix variable	DJ.16,NMO  D4,L14$L15$:	MOVE.8	#"_",{A3+}	; nom <-- "_" aprs le prfix	MOVE.8	D0,{A3+}	; nom <-- fonte	MOVE.8	#"P",D3	TCLR.32	D1:#7	JUMP,BC	 R8^L17$	MOVE.8	#"F",D3L17$:	MOVE.8	D1,{A3+}	; nom <-- style	MOVE.8	D3,{A3+}	; nom <-- chasse	CLR.32	D3	MOVE.8	D2,D3		; D3 <-- taille	DIV.16	#10,D3	ADD.8	#"0",D3	MOVE.8	D3,{A3+}	; nom <-- dizaine taille	SWAP.32	D3	ADD.8	#"0",D3	MOVE.8	D3,{A3+}	; nom <-- unit taille	MOVE.32	#R16^EXT$,A4L20$:	MOVE.8	{A4+},{A3+}	; nom <-- ".GENC<0>"	JUMP,NE L20$	MOVE.32	#{A2}+ODFNGC,A3	; A3 <-- ^nom construit	POPM.32	D0..D4|A4	RETNAME$:	.ASCIZ	"SMA"EXT$:	.ASCIZ	".GENC"	.EVEN;--------\; PUTTGC  >;--------/; Cherche une place libre dans TAGC.; in	D0.B	fonte;	D1.32	style/chasse;	D2.8	taille; out	A1.L	^dans TAGC;	D3.16	position dans TAGC;	D0.8	fonte majuscule;	D1.32	style/chasse majuscule;	D7.16	erreur; mod	D3.W, D7.W, A1.LPUTTGC:	MOVE.8	D0,D3	AND.8	#16'7F,D3	; D3 <-- fonte	AND.8	#16'80,D0	; D0 <-- soft	CALL	MINMAJ	OR.8	D3,D0		; D0 <-- style/soft maj.	MOVE.8	D1,D3	AND.8	#16'7F,D3	; D3 <-- style	AND.8	#16'80,D1	; D1 <-- chasse	CALL	MINMAJ	OR.8	D3,D1		; D1 <-- style/chasse maj.	MOVE.32	#{A6}+OTAGC,A1	; A1 <-- ^dbut de TAGC	CLR.16	D3		; D3 <-- position dans TAGCL10$:	TEST.8	{A1}+OGCUSE	; lment libre ?	JUMP,EQ	 R8^L50$	; oui => 50$				; non =>	MOVE.32	#{A1}+LGGC,A1	; A1 <-- ^lment suivant	INC.16	D3		; D3 <-- position suivante	COMP.16	#MAXGC,D3	JUMP,NE L10$	MOVE.16	#ERDIIL,D7	JUMP	R8^L90$L50$:	INC.8	{A1}+OGCUSE	; occupe l'lment (une fois)	MOVE.8	D0,{A1}+OGCF	; mm. la fonte	MOVE.32	D1,{A1}+OGCS	; mm. le style/chasse	MOVE.8	D2,{A1}+OGCT	; mm. la taille	CLR.8	{A1}+OGCX	; pas cr par XCAR	CLR.16	D7		; D7 <-- okL90$:	RET;--------\; GETTGC  >;--------/; Cherche un gnrateur utilis dans TAGC.; (*) la valeur zro permet de trouver n'importe quoi !; in	D0.B	fonte (*);	D1.32	style/chasse (*);	D2.8	taille (*); out	A1.L	^lment dans TAGC trouv;	D3.16	position dans TAGC;	D0.8	fonte majuscule;	D1.8	style/chasse majuscule;	D7.16	erreur; mod	D0.B, D1.B, D3.W, D7.W, A1.LGETTGC:	MOVE.8	D0,D3	AND.8	#16'7F,D3	; D3 <-- fonte	AND.8	#16'80,D0	; D0 <-- soft	CALL	MINMAJ	OR.8	D3,D0		; D0 <-- style/soft maj.	MOVE.8	D1,D3	AND.8	#16'7F,D3	; D3 <-- style	AND.8	#16'80,D1	; D1 <-- chasse	CALL	MINMAJ	OR.8	D3,D1		; D1 <-- style/chasse maj.	MOVE.32	#{A6}+OTAGC,A1	; A1 <-- ^dbut de TAGC	CLR.16	D3		; D3 <-- position dans TAGCL10$:	TEST.8	{A1}+OGCUSE	; lment libre ?	JUMP,NE	 R8^L50$	; non => 50$L20$:				; oui =>	MOVE.32	#{A1}+LGGC,A1	; A1 <-- ^lment suivant	INC.16	D3		; D3 <-- position suivante	COMP.16	#MAXGC,D3	JUMP,NE L10$	MOVE.16	#ERDIGC,D7	JUMP	R8^L90$L50$:	TEST.8	D0		; n'importe quelle fonte ?	JUMP,EQ	 R8^L60$	; oui => 60$	COMP.8	{A1}+OGCF,D0	; fonte correcte ?	JUMP,NE L20$		; non => 20$L60$:	TEST.32	D1		; n'importe quel style ?	JUMP,EQ	 R8^L70$	; oui => 70$	COMP.32	{A1}+OGCS,D1	; style/chasse correct ?	JUMP,NE L20$		; non => 20$L70$:	TEST.8	D2		; n'importe quelle taille ?	JUMP,EQ	 R8^L80$	; oui => 80$	COMP.8	{A1}+OGCT,D2	; taille correcte ?	JUMP,NE L20$		; non => 20$L80$:	test.32	{A1}+OGCPT	; en cours de chargement ?	; +++ DD +++	jump,eq	L20$		; oui -> ignore pour l'instant	; +++ DD +++	CLR.16	D7		; D7 <-- okL90$:	RET;--------\; SRCEQ   >;========/; Cherche une ventuelle quivalence.; Avant la version 5.4, on cherchait dans 100_INFO une table; variable et modifiable par l'utilisateur. Depuis, on se; contente d'une table rduite au stricte minimum (l'idal; serait d'avoir une table vide).; in	D0.B	fonte;	D1.8	style/chasse;	D2.8	taille; out	D7.W	zro (trouv);	 D0.8	 fonte;	 D1.8	 style/chasse;	 D2.8	 taille;	D7.16	autre (pas trouv);	 D0.8	 idem;	 D1.8	 idem;	 D2.8	 idem; mod	D0.L, D1.L, D2.L, D7,WSRCEQ:	PUSHM.32 D3|A3	MOVE.8	D0,D3	AND.8	#16'80,D3	; D0 <-- fonte "soft" ou pas	AND.8	#16'7F,D0	; D0 <-- enlve le bit "soft"	MOVE.32	#R16^TABLE$-(3+3),A3	MOVE.16	#ERDIGC,D7	; D7 <-- "pas trouv" !L20$:	ADD.32	#3+3,A3		; A3 <-- ^suivant	TEST.8	{A3}		; fin de la table ?	JUMP,EQ	 R8^L80$	; oui => 80$	TEST.8	D0	JUMP,EQ	 R8^L30$	COMP.8	{A3}+0,D0	; mme fonte ?	JUMP,NE L20$		; non => 20$L30$:	TEST.8	D1	JUMP,EQ	 R8^L31$	COMP.8	{A3}+1,D1	; mme style ?	JUMP,NE L20$		; non => 20$L31$:	TEST.8	D2	JUMP,EQ	 R8^L32$	COMP.8	{A3}+2,D2	; mme taille ?	JUMP,NE L20$		; non => 20$L32$:	MOVE.8	{A3}+3,D0	; D0 <-- nouvelle fonte	MOVE.8	{A3}+4,D1	; D1 <-- nouveau style	MOVE.8	{A3}+5,D2	; D2 <-- nouvelle taille	CLR.16	D7		; D7 <-- trouvL80$:	OR.8	D3,D0		; D0 <-- remet si fonte "soft" ou pas	POPM.32	D3|A3	TEST.16	D7		; retour EQ/NE	RETTABLE$:	.8	"N","R".OR.2**7,12; NRF12	.8	"N","E".OR.2**7,11; NEF11	.8	"N","E".OR.2**7,12; NEF12	.8	"N","E".OR.2**7,11; NEF11	.8	"S","N".OR.2**7,12; SNF12	.8	"S","N".OR.2**7,11; SNF11	.8	0	.EVEN;--------\; MINMAJ  >;========/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMINMAJ:	TEST.32	D3:#7		; code "supplmentaire" ?	JUMP,NE	 R8^L20$	; oui => 20$	COMP.8	#SPACE-2,D3	; lettre accentue ?	JUMP,LO	 R8^L50$	; oui => 50$	COMP.8	#"a",D3	JUMP,LO	 R8^L20$	COMP.8	#"z",D3		; minuscule non accentue ?	JUMP,HI	 R8^L20$	; non => 20$	SUB.8	#"a"-"A",D3	; oui => transformeL20$:	RETL50$:	COMP.8	#"",D3	JUMP,LO L20$	PUSH.16	D0	SUB.8	#"",D3	CLR.16	D0	MOVE.8	D3,D0	MOVE.8	R8^L70$+A16^{D3},D3; D3 <-- lettre majuscule	POP.16	D0	RETL70$:	.8	"U","A","A","E","E","E","E","I","I","O","U","U","A","O","C"	.EVENNMGENC:	.ASCIZ	"GENCAR"	; nom du module des gencarsNMXCAR:	.ASCIZ	"XCAR"		; nom du module des xcar's	.EVEN	.END