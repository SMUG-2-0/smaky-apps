	.TITLE	TPEN	.PROC	M680002	.REF	SM8	.REF	LIB	.REF	DRIVERS	.REF	FOS	.REF	GESMEM	.LOC	0OBUDIS:	.BLKB	100LGVAR:	.LOC	0START:	LIB	?OPELIB	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LIB	?AFTIM	.B	EOP	.B	NOCURS	.B	PEN	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'01111110	.B	B'00111100	.B	0	.EVEN	LOAD.L	D3,#H'10000*10+10	LOAD.L	D4,#H'10000*300+0	LOAD.W	D1,#600/820$:	PUSH.L	D3	LOAD.W	D2,#INVDOT!PENDOT	LIB	?DRSEG	POP.L	D3	ADD.W	D4,#8	DEC.W	D1	JUMP,NE 20$	LOAD.B	D3,#EOP	LIB	?AFCARERFAT1:	LIB	?CLOLIB	FOS	?STOP	.END	START