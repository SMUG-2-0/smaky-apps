	.TITLE	TLUTIN	.PROC	M680002	.REF	SM8	.REF	LIB	.REF	DRIVERS	.REF	FOS	.REF	GESMEM	.LOC	0OBUDIS:	.BLKB	100LGVAR:	.LOC	0START:	LIB	?OPELIB	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LIB	?AFTIM	.B	EOP	.B	NOCURS	.B	0	.EVENLOOP:	LIB	?AFTIM	.ASCIZ	"<CR>(M)et, (E)nlve ? "	.EVEN	LIB	?GETCAR	LIB	?MINMAJ	COMP.W	D3,#END	JUMP,EQ ERFAT1	COMP.W	D3,#'M	JUMP,EQ MET	COMP.W	D3,#'E	JUMP,EQ ENLEVE	JUMP	LOOPMET:	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	JUMP	LOOPENLEVE:	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	JUMP	LOOPERFAT1:	LIB	?CLOLIB	FOS	?STOP	.END	START