	.SBTTL	TCOLTAB.ASI; Gestion des tables; ------------------;---------\\; TABSRCCA >;=========/; Cherche un lment dans une table, d'aprs sa couleur approximative.; Cherche la couleur la plus proche dans la table des fausses couleurs.;	  = MIN( |R-R'| + |G-G'| + |B-B'| ); in	A4.L	^table;	A3.L	^RGB cherch; out	A3.L	^RGB trouv;	D4.W	index trouv (0..n);	D3.L	nom trouv;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A3.LTABSRCCA:	TEST.L	(A5)+OLPPSS	; y a-t-il une procdure de recherche spciale ?	JUMP',NE PSS$		; oui => PSS$	PUSHM.L	D0..D2,D5,D6,A2,A4	CLR.W	D4		; D4 <-- index	LOAD.W	D2,(A4)+OCTNB	; D2 <-- nb d'lments	LOAD.L	A4,#(A4)+LCTHEAD	LOAD.L	D6,#-1		; D6 <-- cart maximalLOOP$:	COMP.W	D4,D2		; encore un lment dans la table ?	JUMP,HS END$		; non => END$	CLR.L	D3	LOAD.W	D3,(A3)+OTCCR	; D3 <-- rouge	CLR.L	D0	LOAD.W	D0,(A4)+OCTCOL+OTCCR	SUB.L	D3,D0	JUMP',NC AR$	NEG.L	D3		; D3 <-- |R-R'|AR$:	LOAD.L	D5,D3	CLR.L	D3	LOAD.W	D3,(A3)+OTCCG	; D3 <-- vert;	CLR.L	D0	LOAD.W	D0,(A4)+OCTCOL+OTCCG	SUB.L	D3,D0	JUMP',NC AG$	NEG.L	D3		; D3 <-- |G-G'|AG$:	ADD.L	D5,D3	CLR.L	D3	LOAD.W	D3,(A3)+OTCCB	; D3 <-- bleu;	CLR.L	D0	LOAD.W	D0,(A4)+OCTCOL+OTCCB	SUB.L	D3,D0	JUMP',NC AB$	NEG.L	D3		; D3 <-- |B-B'|AB$:	ADD.L	D5,D3	JUMP',EQ OK$		; si l'cart est nul => OK$ (parfait)	COMP.L	D6,D5		; cart plus petit que le prcdent ?	JUMP',LS NEXT$		; non => NEXT$	LOAD.L	D6,D5		; D6 <-- cart minimal	LOAD.L	A2,A4		; A2 <-- ^meilleur choix	LOAD.W	D1,D4		; D1 <-- index correspondantNEXT$:	INC.W	D4		; D4 <-- index suivant	LOAD.L	A4,#(A4)+LCTDATA ; A4 <-- ^lment suivant	JUMP	LOOP$END$:	LOAD.L	A4,A2		; A4 <-- ^meilleur choix	LOAD.W	D4,D1		; D4 <-- indexOK$:	LOAD.L	D3,(A4)+OCTNAM	; D3 <-- nom	LOAD.L	A3,#(A4)+OCTCOL	; A3 <-- ^couleur trouve	CLR.W	D7		; D7 <-- ok	POPM.L	D0..D2,D5,D6,A2,A4	TEST.W	D7		; retour EQ/NE	RETPSS$:	PUSH.L	A1	LOAD.L	A1,(A5)+OLPPSS	; A1 <-- ^procdure de recherche	CALL	(A1)		; appel la procdure spciale ...	POP.L	A1	TEST.W	D7		; retour EQ/NE	RET;---------\\; TABSRCCE >;=========/; Cherche un lment dans une table, d'aprs sa couleur exacte.; in	A4.L	^table;	A3.L	^RGB cherch; out	D4.W	index trouv (0..n);	D3.L	nom trouv;	D7.W	erreur; mod	D3.L, D4.L, D7.WTABSRCCE:	PUSHM.L	D2,A1,A2,A4	CLR.W	D4		; D4 <-- index	LOAD.W	D2,(A4)+OCTNB	; D2 <-- nb d'lments	LOAD.L	A4,#(A4)+LCTHEAD	LOAD.W	D7,#ERTCCDNELOOP$:	COMP.W	D4,D2	JUMP',HS EXIT$	LOAD.L	A2,#(A4)+OCTCOL	LOAD.L	A1,A3	COMP.W	(A1+),(A2+)	; couleur trouve ?	JUMP',NE NEXT$	COMP.W	(A1+),(A2+)	JUMP',NE NEXT$	COMP.W	(A1+),(A2+)	JUMP',EQ OK$NEXT$:	INC.W	D4		; D4 <-- index suivant	LOAD.L	A4,#(A4)+LCTDATA ; A4 <-- ^lment suivant	JUMP	LOOP$OK$:	LOAD.L	D3,(A4)+OCTNAM	; D3 <-- nom	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,A1,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TABSRCN >;========/; Cherche un lment dans une table, d'aprs son nom.; in	A4.L	^table;	D3.L	nom cherch; out	D4.W	index trouv (0..n);	A3.L	^RGB trouv;	D7.W	erreur; mod	D4.L, D7.W, A3.LTABSRCN:	PUSHM.L	D2,A4	CLR.W	D4		; D4 <-- index	LOAD.W	D2,(A4)+OCTNB	; D2 <-- nb d'lments	LOAD.L	A4,#(A4)+LCTHEAD	LOAD.W	D7,#ERTCCDNELOOP$:	COMP.W	D4,D2	JUMP',HS EXIT$	COMP.L	D3,(A4)+OCTNAM	; nom trouv ?	JUMP',EQ OK$		; oui => OK$	INC.W	D4		; D4 <-- index suivant	LOAD.L	A4,#(A4)+LCTDATA ; A4 <-- ^lment suivant	JUMP	LOOP$OK$:	LOAD.L	A3,#(A4)+OCTCOL	; A3 <-- ^RGB	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TABSRCI >;========/; Cherche un lment dans une table, d'aprs son index.; in	A4.L	^table;	D4.W	index (0..n); out	D3.L	nom;	A3.L	^RGB;	D7.W	erreur; mod	D3.L, D7.W, A3.LTABSRCI:	PUSHM.L	D4,A4	LOAD.W	D7,#ERTCCDNE	COMP.W	D4,(A4)+OCTNB	JUMP',HS EXIT$	MUL.WU	D4,#LCTDATA	LOAD.L	A4,#(A4)+(D4.L)+LCTHEAD	LOAD.L	D3,(A4+)	; D3 <-- nom dans la table	LOAD.L	A3,A4		; A3 <-- ^RGB dans la table	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TABREPL >;========/; Remplace un lment dans une table.; in	A4.L	^table;	D4.W	index (0..n);	D3.L	nom;	A3.L	^RGB; out	D7.W	erreur; mod	D7.WTABREPL:	PUSHM.L	D4,A3,A4	LOAD.W	D7,#ERTCCDNE	COMP.W	D4,(A4)+OCTNB	JUMP',HS EXIT$	MUL.WU	D4,#LCTDATA	LOAD.L	A4,#(A4)+(D4.L)+LCTHEAD	LOAD.L	(A4+),D3	; table <-- nom	LOAD.W	(A4+),(A3+)	; table <-- rouge	LOAD.W	(A4+),(A3+)	; table <-- vert	LOAD.W	(A4+),(A3+)	; table <-- bleu	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TABADD  >;========/; Ajoute un lment dans une table.; in	A4.L	^table;	D4.W	index (0..n);	D3.L	nom;	A3.L	^RGB; out	A4.L	^table;	D7.W	erreur; mod	D7.W, A4.LTABADD:	PUSHM.L	D0..D4,A1..A3,A5	LOAD.W	D0,D4		; D0 <-- index	COMP.W	D0,(A4)+OCTNB	JUMP',LS MAX$	LOAD.W	D0,(A4)+OCTNB	; D0 <-- index max possibleMAX$:	LOAD.W	D4,(A4)+OCTNB	COMP.W	D4,(A4)+OCTNBM	; encore de la place ?	JUMP',LO INSERT$	; oui => INSERT$	LOAD.L	A5,A4		; A5 <-- ^ancienne	ADD.W	D4,#RESERVE	MUL.WU	D4,#LCTDATA	ADD.L	D4,#LCTHEAD	LOAD.L	A1,(A6)+OGPACC	LOAD.L	D1,#MTYPUSER	GESMEM	?GETMEM		; A4 <-- demande nouvelle mmoire	JUMP,NE EXIT$	SUB.W	D4,#LCTDATA*RESERVE	SR.W	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMO	PUSHM.L	A4,A5XNEW$:	LOAD.W	(A4+),(A5+)	; nouvelle <-- ancienne	DECJ.W,NMO D4,XNEW$	POPM.L	A4,A5	ADD.W	(A4)+OCTNBM,#RESERVE	EX.L	A4,A5;	LOAD.L	D1,#MTYPUSER;	LOAD.L	A1,(A6)+OGPACC	GESMEM	?GIVMEM		; libre l'ancienne	LOAD.L	A4,A5INSERT$:	LOAD.W	D4,(A4)+OCTNB	MUL.WU	D4,#LCTDATA	LOAD.L	A2,#(A4)+(D4.L)+LCTHEAD	LOAD.L	A1,#(A2)+LCTDATA	LOAD.W	D4,(A4)+OCTNB	SUB.W	D4,D0	JUMP',EQ END$	MUL.WU	D4,#LCTDATA/2	DEC.W	D4XFER$:	LOAD.W	(-A1),(-A2)	DECJ.W,NMO D4,XFER$END$:	LOAD.L	(A2+),D3	; table <-- nom	LOAD.W	(A2+),(A3+)	; table <-- rouge	LOAD.W	(A2+),(A3+)	; table <-- vert	LOAD.W	(A2+),(A3+)	; table <-- bleu	INC.W	(A4)+OCTNB	; un lment de plus	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A1..A3,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; TABSUB  >;========/; Enlve un lment d'une table.; in	A4.L	^table;	D4.W	index (0..n); out	D7.W	erreur; mod	D7.WTABSUB:	PUSHM.L	D3,D4,A2,A3	COMP.W	D4,(A4)+OCTNB	JUMP',LS MAX$	LOAD.W	D4,(A4)+OCTNB	; D4 <-- index max possibleMAX$:	LOAD.W	D3,D4	MUL.WU	D4,#LCTDATA	LOAD.L	A3,#(A4)+(D4.L)+LCTHEAD	LOAD.L	A2,#(A3)+LCTDATA	LOAD.W	D4,(A4)+OCTNB	SUB.W	D4,D3	DEC.W	D4	JUMP',EQ END$	MUL.WU	D4,#LCTDATA/2	DEC.W	D4XFER$:	LOAD.W	(A3+),(A2+)	DECJ.W,NMO D4,XFER$END$:	DEC.W	(A4)+OCTNB	; un lment de moins	POPM.L	D3,D4,A2,A3	CLR.W	D7		; retour EQ	RET;--------\\; TABMAKE >;========/; Construit une table vide.; in	-; out	A4.L	^table;	D7.W	erreur; mod	D7.W, A4.LTABMAKE:	PUSHM.L	D1,D4,A1	LOAD.L	D4,#LCTHEAD+(LCTDATA*RESERVE)	LOAD.L	A1,(A6)+OGPACC	LOAD.L	D1,#MTYPUSER	GESMEM	?GETMEM		; A4 <-- ^nouvelle table vide	JUMP',NE EXIT$	GESMEM	?CLEARMEM	; vide la table	LOAD.W	(A4)+OCTNBM,#RESERVEEXIT$:	POPM.L	D1,D4,A1	TEST.W	D7		; retour EQ/NE	RET;---------\\; TABMLOAD >;=========/; Copie une table en mmoire.; in	A3.L	^table donn dans un buffer;	D1.B	type attendu (CLTYPE/CRTYPE); out	A4.L	^copie de la table;	D7.W	erreur; mod	D7.W, A4.LTABMLOAD:	PUSHM.L	D1,D4,A3,A1	LOAD.W	D7,#ERTCTYPE	; D7 <-- type incorrect	COMP.B	D1,(A3)+OCTTYP	; est-ce le bon type ?	JUMP',NE EXIT$	LOAD.W	D4,(A3)+OCTNB	ADD.W	D4,#RESERVE	MUL.WU	D4,#LCTDATA	ADD.L	D4,#LCTHEAD	LOAD.L	D1,#MTYPUSER	LOAD.L	A1,(A6)+OGPACC	GESMEM	?GETMEM		; A4 <-- ^nouvelle table	JUMP',NE EXIT$	SUB.W	D4,#LCTDATA*RESERVE	SR.W	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMO	PUSH.L	A4XFER$:	LOAD.W	(A4+),(A3+)	; table <-- buffer	DECJ.W,NMO D4,XFER$	POP.L	A4	LOAD.W	(A4)+OCTNBM,(A4)+OCTNB	ADD.W	(A4)+OCTNBM,#RESERVEEXIT$:	POPM.L	D1,D4,A3,A1	TEST.W	D7		; retour EQ/NE	RET;---------\\; TABMSAVE >;=========/; Sauve une table dans un buffer.; in	A3.L	^buffer;	A4.L	^table; in	D7.W	erreur; mod	D7.WTABMSAVE:	PUSHM.L	D4,A3,A4	LOAD.W	D4,(A4)+OCTNB	MUL.WU	D4,#LCTDATA	LOAD.L	(A4)+OCTLG,D4	; OCTLG <-- longueur utilise;	LOAD.L	D4,(A4)+OCTLG	ADD.L	D4,#LCTHEAD	SR.W	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMOXFER$:	LOAD.W	(A3+),(A4+)	; buffer <-- table	DECJ.W,NMO D4,XFER$	POPM.L	D4,A3,A4	CLR.W	D7		; retour EQ	RET;---------\\; TABFLOAD >;=========/; Lit une table sur disque en mmoire.; in	D6.W	canal FOS;	D1.B	type attendu (CLTYPE/CRTYPE); out	A4.L	^table;	D7.W	erreur; mod	D7.W, A4.LTABFLOAD:	PUSHM.L	D1..D5,A1..A3	LOAD.B	D5,D1		; D5 <-- type attendu	LOAD.L	D1,#MTYPUSER	LOAD.L	A1,(A6)+OGPACC	LOAD.L	D4,#LCTHEAD	GESMEM	?GETMEM		; rserve mmoire pour l'en-tte	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^en-tte	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE GHEAD$	COMP.B	D5,(A2)+OCTTYP	; est-ce le bon type ?	JUMP',NE ERTYPE$	; non => ERTYPE$	LOAD.L	D4,(A2)+OCTLG	ADD.L	D4,#LCTHEAD+(LCTDATA*RESERVE)	GESMEM	?GETMEM		; rserve mmoire pour le fichier	JUMP,NE GHEAD$	LOAD.L	A3,A4		; A3 <-- ^fichier	PUSHM.L	A2,A3	LOAD.W	D4,#(LCTHEAD/2)-1XHEAD$:	LOAD.W	(A3+),(A2+)	; fichier <-- en-tte	DECJ.W,NMO D4,XHEAD$	POPM.L	A2,A3	LOAD.L	A4,#(A3)+LCTHEAD	LOAD.L	D4,(A2)+OCTLG	FOS	?RDBYTE		; lit le data du fichier	JUMP',NE GFILE$	LOAD.W	(A3)+OCTNBM,(A3)+OCTNB	ADD.W	(A3)+OCTNBM,#RESERVE	LOAD.L	A4,A3		; A4 <-- ^fichier lu	JUMP'	GHEAD$ERTYPE$:	FOS	?GPOS	SUB.L	D4,#LCTHEAD	FOS	?SPOS		; revient avant l'en-tte	LOAD.W	D7,#ERTCTYPE	; D7 <-- type incorrect	JUMP'	GHEAD$GFILE$:	PUSHM.L	D7,A4	LOAD.L	A4,A3	GESMEM	?GIVMEM		; rend le fichier	POPM.L	D7,A4GHEAD$:	PUSHM.L	D7,A4	LOAD.L	A4,A2	GESMEM	?GIVMEM		; rend l'en-tte	POPM.L	D7,A4EXIT$:	POPM.L	D1..D5,A1..A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; TABFSAVE >;=========/; Ecrit une table en mmoire sur le disque.; in	D6.W	canal FOS;	A4.L	^table; out	D7.W	erreur; mod	D7.WTABFSAVE:	PUSH.L	D4	LOAD.W	D4,(A4)+OCTNB	MUL.WU	D4,#LCTDATA	LOAD.L	(A4)+OCTLG,D4	; OCTLG <-- longueur utilise;	LOAD.L	D4,(A4)+OCTLG	ADD.L	D4,#LCTHEAD	FOS	?WRBYTE		; crit tout le fichier (en-tte + data)	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TABKILL >;========/; Libre une table en mmoire.; in	A4.L	^table; out	-; mod	D7.WTABKILL:	PUSHM.L	D1,A1	LOAD.L	D1,#MTYPUSER	LOAD.L	A1,(A6)+OGPACC	GESMEM	?GIVMEM	POPM.L	D1,A1	TEST.L	D7	RET	.END