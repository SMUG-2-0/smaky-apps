	.TITLE	TTRAME	.PROC	M680002	.REF	SM8	.REF	LIB	.REF	DRIVERS	.REF	FOS	.REF	GESMEM	.LOC	0OBUDIS:	.BLKB	100LGVAR:	.LOC	0START:	LIB	?OPELIB	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LOAD.W	D3,#H'8000	LOAD.W	D4,#H'0000	LOAD.W	D5,#H'8000	LIB	?COLORCA	LOAD.W	D3,#H'0000	LOAD.W	D4,#H'0000	LOAD.W	D5,#H'FFFF	LIB	?COLORSA	LIB	?AFTIM	.B	EOP	.B	NOCURS	.B	0	.EVEN	LOAD.L	D3,#H'FFFFFFFF	LOAD.L	D4,#H'FFFFFFFF	LIB	?DRMDEF	LOAD.L	D3,#H'10000*90+5	LOAD.L	D4,#H'10000*100+500	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	LOAD.W	D3,#H'FFFF	LOAD.W	D4,#H'0000	LOAD.W	D5,#H'0000	LIB	?COLORSA	LOAD.W	D3,#H'0000	LOAD.W	D4,#H'FFFF	LOAD.W	D5,#H'0000	LIB	?COLORCA	LOAD.L	D3,#H'F0F0F0F0	LOAD.L	D4,#H'00000000	LIB	?DRMDEF	LOAD.L	D3,#H'10000*10+10	LOAD.L	D4,#H'10000*75+75	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	LOAD.L	D3,#H'10000*10+110	LOAD.L	D4,#H'10000*75+75	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	LOAD.L	D3,#H'10000*10+210	LOAD.L	D4,#H'10000*75+75	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	LOAD.L	D3,#H'10000*100+10	LOAD.L	D4,#H'10000*75+75	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	LOAD.L	D3,#H'10000*100+110	LOAD.L	D4,#H'10000*75+75	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	LOAD.L	D3,#H'10000*100+210	LOAD.L	D4,#H'10000*75+75	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	LOAD.W	D0,#10050$:	LOAD.L	D3,#H'10000*10+310	LOAD.L	D4,#H'10000*75+75	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	DEC.W	D0	JUMP,NE 50$ERFAT1:	LIB	?CLOLIB	FOS	?STOP	.END	START