	.TITLE		TCOLOR.ASS;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------	.PROC		M68000				; mnmonics CALM	.BASE		10'10				; base 10 par dfaut;	.LAYOUT		HEX				; listing en hexadcimal; Constantes utiles; -----------------BTCGLOB	 =	0		; CLUT/CRET globaleBTCFORCE =	1		; force la fausse couleurBTCGIVE	 =	2		; rend la couleur relleBTCTABLE =	3		; donne une tableBTCNAME	 =	4		; donne un nom de fichierBTCCHFOS =	5		; donne un canal FOSBTCT8X8	 =	6		; cre une trame 8x8BTCACTIVE=	7		; utilise la CLUT active; Erreurs; -------ERTCQQ	 =	16'D000		; erreur quelconqueERTCMODE =	16'D001		; mode incorrectERTCFULL =	16'D002		; table pleineERTCCDNE =	16'D003		; couleur n'existe pasERTCTYPE =	16'D004		; type incorrect; Descripteur d'une couleur RGB; -----------------------------	.LOC	0OTCCR:	.BLK.8	2		; rougeOTCCG:	.BLK.8	2		; vertOTCCB:	.BLK.8	2		; bleuLTCC:; Description d'un fichier .CLUT/.CRET; ------------------------------------CLTYPE	=	16'90		; type .CLUT (Color LookUp Table)CRTYPE	=	16'91		; type .CRET (Color RElative Table)	.LOC	0OCTTYP:	.BLK.8	1		; type C[L/R]TYPE	.BLK.8	1		; rserveOCTLG:	.BLK.8	4		; longueur du fichier (sans l'en-tte)OCTNB:	.BLK.8	2		; nb de couleurs contenues (0..n)	.BLK.8	24		; rserve (ne pas utiliser les 8 derniers bytes)LCTHEAD:	.LOC	0OCTNAM:	.BLK.8	4		; nom (32 bits quelconques)OCTCOL:	.BLK.8	LTCC		; RGBLCTDATA:; Numros des appels; ------------------	.SYSCALL.16	TCOL_TCOL_OPEN	=	16'AAB0TCOL_CLOSE	=	16'AAB1TCOL_ACTIVE	=	16'AAB2TCOL_LOADCLUT	=	16'AAB3TCOL_SAVECLUT	=	16'AAB4TCOL_SRCCLUT	=	16'AAB5TCOL_PUTCLUT	=	16'AAB6TCOL_LOADCRET	=	16'AAB7TCOL_SAVECRET	=	16'AAB8TCOL_KILLCRET	=	16'AAB9TCOL_ADDCRET	=	16'AABATCOL_SUBCRET	=	16'AABBTCOL_SRCCRET	=	16'AABCTCOL_PUTCRET	=	16'AABDTCOL_DELCRET	=	16'AABETCOL_MAKETRAME	=	16'AABFTCOL_PPSSCLUT	=	16'AAC0TCOL_GPSSCLUT	=	16'AAC1TCOL_LISTCRET	=	16'AAC2TCOL_GETACTIVE	=	16'AAC3TCOL_FIRST	=	TCOL_OPENTCOL_LAST	=	TCOL_GETACTIVE; Le canal qu'il faut donner dans D6.L pour chaque appel TCOL_ doit tre; pris dans le descripteur de fentre en ODFCPF.; Appels gnraux; ---------------;-----------\\; _TCOL_OPEN >;===========/; Ouvre une instance du module.; ATTENTION: Cet appel ne doit tre utilis que par le pilote $DIS !; in	D4.W	nb de bits/pixel (1,2,4,8,15,24);	D3.L	mode (zro); out	D6.L	canal;	D7.W	erreur; mod	D6.L, D7.W;------------\\; _TCOL_CLOSE >;============/; Ferme une instance du module.; ATTENTION: Cet appel ne doit tre utilis que par le pilote $DIS !; in	D6.L	canal;	D3.L	mode (zro); out	-; mod	D7.W;-------------\\; _TCOL_ACTIVE >;=============/; Dfinit si la fentre associe au module est active ou non; (chargement de la palette des couleurs associe dans le hardware; du moniteur). ; ATTENTION: Cet appel ne doit tre utilis que par le pilote $DIS !; in	D6.L	canal;	D4.B	1 => fentre active;	D3.L	mode (zro);	A5.L	^liste des moniteurs (zro); out	-; mod	D7.W;----------------\\; _TCOL_GETACTIVE >;================/; Donne le canal actif  un instant donn.; in	D6.L	canal; out	D6.L	canal actif; mod	D7.W; Appels pour la CLUT (Color LookUp Table); ----------------------------------------; La CLUT, appele aussi "palette des couleurs", contient 16 couleurs; sur un SMAKY-300. Ces 16 couleurs sont les seules couleurs que le; hardware peut gnrer  un instant donn. La couleur zro correspond; toujours au blanc (R=G=B=-1), et la couleur quinze au noir (R=G=B=0).; Chaque fentre ouverte (donc chaque logiciel) possde une CLUT; personnelle, appele CLUT locale. Il en rsulte que chaque logiciel; peut utiliser 14 couleurs personnelles (16 moins le blanc et le noir),; diffrentes de celles des autres logiciels.; Pour choisir une couleur, l'utilisateur donne les trois composantes; rouge-vert-bleu (RGB) sous forme de 3x16 bits. Ceci permet un maximum; de 2^(16+16+16) = 2.8*10^14 couleurs ! La CLUT se charge de chercher; la couleur la plus proche parmi les 16 couleurs possibles. En fait,; tout se passe pour cacher au maximum le fait que l'cran ne sache; afficher que 16 couleurs.;	                 |--------|;	     RGB  -------|  CLUT  |------>  hardware;	                 |--------|;	Des millions                       Seulement;	de possibi-                        16 couleurs !;	lits.;---------------\\; _TCOL_LOADCLUT >;===============/; Charge la palette des couleurs (CLUT) active.; in	D6.L	canal;	D3.L	mode (BTC*);		 BTCTABLE --> donne une table;		 BTCNAME  --> donne un nom de fichier;		 BTCCHFOS --> donne un canal FOS;		 BTCGLOB  --> si CLUT globale;	A3.L	^table		(si D3:#BTCTABLE);	A3.L	^nom		(si D3:#BTCNAME);	D4.W	canal FOS	(si D3:#BTCCHFOS); out	D7.W	erreur; mod	D7.W;---------------\\; _TCOL_SAVECLUT >;===============/; Sauve la palette des couleurs (CLUT) active.; in	D6.L	canal;	D3.L	mode (BTC*);		 BTCTABLE --> donne une table;		 BTCNAME  --> donne un nom de fichier;		 BTCCHFOS --> donne un canal FOS;		 BTCGLOB  --> si CLUT globale;	A3.L	^buffer		(si D3:#BTCTABLE);	A3.L	^nom		(si D3:#BTCNAME);	D4.W	canal FOS	(si D3:#BTCCHFOS); out	(A3)+	table;	D7.W	erreur; mod	D7.W;--------------\\; _TCOL_SRCCLUT >;==============/; Cherche une couleur dans la palette.; in	D6.L	canal;	D3.L	mode (BTC*);		 BTCFORCE --> on donne la couleur cherche;		 BTCGIVE  --> rend la couleur exacte;		 BTCGLOB  --> si CLUT globale;	A4.L	^couleur cherche (RGB)	(si D3<>BTCFORCE);	D4.L	couleur de la palette	(si D3:#BTCFORCE);	A3.L	^buffer			(si D3:#BTCGIVE); out	D4.L	couleur de la palette;	(A3)+	RGB exact		(si D3:#BTCGIVE);	D7.W	erreur; mod	D4.L, D7.W;--------------\\; _TCOL_PUTCLUT >;==============/; Ajoute ou modifie une couleur dans la palette.; in	D6.L	canal;	D3.L	mode (BTC*);		 BTCFORCE --> on donne la couleur;		 BTCGLOB  --> si CLUT globale;	A4.L	^couleur (RGB);	D4.L	couleur de la palette	(si D3:#BTCFORCE); out	D4.L	couleur de la palette modifie;	D7.W	erreur; mod	D4.L, D7.W;---------------\\; _TCOL_PPSSCLUT >;===============/; Donne la procdure  utiliser pour chercher une couleur dans la CLUT.; in	D6.L	canal;	D3.L	mode (zro);	A4.L	^procdure de recherche/nil, voir (*); out	D7.W	erreur; mod	D7.W;---------------\\; _TCOL_GPSSCLUT >;===============/; Rend la procdure utilise pour chercher une couleur dans la CLUT.; in	D6.L	canal;	D3.L	mode (zro); out	A4.L	^procdure de recherche/nil, voir (*);	D7.W	erreur; mod	D7.W, A4.L; (*)	La procdure de recherche est dfinie comme suit :;; in	A4.L	^table CLUT;	A3.L	^RGB cherch; out	A3.L	^RGB trouv (dans la table);	D4.W	index trouv (0..n);	D3.L	couleur de la palette;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A3.L; Appels pour la CRET (Color RElative Table); ------------------------------------------; La CRET permet d'assigner des numros (32 bits)  certains lments; graphiques (icnes, objets, fonds, etc.). Ainsi, lorsqu'un logiciel; dessine une icne, il indique simplement qu'il faut utiliser la; couleur numro H'8012 par exemple. C'est l'utilisateur du logiciel; qui dcide quelle doit tre la couleur assigne au numro H'8012,; donc aux icnes.; Il existe plusieurs CRET globales, pour les couleurs de la souris,; des botes de dialogues, des ascenseurs, etc. De mme, chaque logiciel; peut utiliser une ou plusieurs CRET locales. Lorsqu'une couleur est; cherche, elle l'est d'abord dans toutes les CRET locales, puis dans; toutes les CRET globales. Ainsi, si un logiciel dcide que les; ascenseurs doivent avoir une couleur particulire, il suffit de; l'indiquer dans une CRET locale, qui aura priorit sur les CRET; globales.; Les numros des couleurs dans les CRET locales doivent tre plus; grands que H'8000. Les numros infrieurs sont rservs pour les; CRET globales.;	           |--------|;	           |  CRET  |;	           |--------|             |--------|;	numro  ---|  CRET  |-->  RGB  ---|  CLUT  |-->  hardware;	           |--------|             |--------|;	           |  CRET  |;	           |--------|;	              ...;---------------\\; _TCOL_LOADCRET >;===============/; Charge une table des couleurs relatives (CRET).; in	D6.L	canal;	D3.L	mode (BTC*);		 BTCTABLE --> donne une table;		 BTCNAME  --> donne un nom de fichier;		 BTCCHFOS --> donne un canal FOS;	A3.L	^table		(si D3:#BTCTABLE);	A3.L	^nom		(si D3:#BTCNAME);	D4.W	canal FOS	(si D3:#BTCCHFOS); out	D5.L	identificateur de CRET;	D7.W	erreur; mod	D5.L, D7.W;---------------\\; _TCOL_SAVECRET >;===============/; Sauve une table des couleurs relatives (CRET).; in	D6.L	canal;	D5.L	identificateur de CRET;	D3.L	mode (BTC*);		 BTCTABLE --> donne une table;		 BTCNAME  --> donne un nom de fichier;		 BTCCHFOS --> donne un canal FOS;	A3.L	^buffer		(si D3:#BTCTABLE);	A3.L	^nom		(si D3:#BTCNAME);	D4.W	canal FOS	(si D3:#BTCCHFOS); out	(A3)+	table;	D7.W	erreur; mod	D7.W;---------------\\; _TCOL_KILLCRET >;===============/; Libre une table des couleurs relatives (CRET).; in	D6.L	canal;	D5.L	identificateur de CRET;	D3.L	mode (zro); out	-; mod	D7.W;--------------\\; _TCOL_ADDCRET >;==============/; Donne une nouvelle CRET dans la liste courante.; in	D6.L	canal;	D5.L	identificateur de CRET;	D3.L	mode (BTC*);		 BTCGLOB --> si CRET globale; out	D7.W	erreur; mod	D7.W;--------------\\; _TCOL_SUBCRET >;==============/; Enlve une CRET de la liste courante.; in	D6.L	canal;	D5.L	identificateur de CRET;	D3.L	mode (BTC*);		 BTCGLOB --> si CRET globale; out	D7.W	erreur; mod	D7.W;--------------\\; _TCOL_SRCCRET >;==============/; Cherche une couleur relative.; in	D6.L	canal;	D3.L	mode (BTC*);		 BTCGIVE --> pour obtenir la couleur relle;	D4.L	numro de la couleur relative;	A4.L	^buffer pour couleur nomme (RGB);	A3.L	^buffer pour couleur relle	(si D3:#BTCGIVE); out	(A4)+	RGB nomm;	(A3)+	RGB exact			(si D3:#BTCGIVE);	D4.L	couleur de la palette		(si D3:#BTCGIVE);	D7.W	erreur; mod	D4.L, D7.W;--------------\\; _TCOL_PUTCRET >;==============/; Ajoute ou modifie une couleur relative.; in	D6.L	canal;	D5.L	identificateur de CRET;	D3.L	mode (zro);	D4.L	numro de la couleur relative;	A4.L	^nouvelle couleur (RGB); out	D5.L	identificateur de CRET (!);	D7.W	erreur; mod	D5.L, D7.W;--------------\\; _TCOL_DELCRET >;==============/; Supprime une couleur relative.; in	D6.L	canal;	D5.L	identificateur de CRET;	D3.L	mode (zro);	D4.L	numro de la couleur relative; out	D7.W	erreur; mod	D7.W;---------------\\; _TCOL_LISTCRET >;===============/; Donne la liste de tous les identificateurs de CRET utiliss.; in	D6.L	canal;	D3.L	mode (zro);	A4.L	^buffer;	D4.L	lg max buffer; out	(A4)++	identificateurs de CRET (.L), termins par zro;	D7.W	erreur; mod	D7.W; Appels divers; -------------;----------------\\; _TCOL_MAKETRAME >;================/; Cre une trame qui apprixime une couleur donne.; ATTENTION: Cet appel ne fonctionne pas encore !; in	D6.L	canal; 	D3.L	mode (BCT*);		 BTCT8X8 --> calcule une trame 8x8;		 BTCGIVE --> rend la couleur relle obtenue; 	A4.L	^couleur  approximer (RGB);	A3.L	^buffer pour couleur relle	(si D3:#BTCGIVE);	A5.L	^buffer (8 bytes) pour la trame	(si D3:#BTCT8X8); out	D4.L	couleur SET			(si D3:#BTCT8X8);	D5.L	couleur CLEAR			(si D3:#BTCT8X8);	(A5)+	trame 8x8			(si D3:#BTCT8X8);	(A3)+	RGB rel			(si D3:#BTCGIVE);	D7.W	erreur; mod	D4.L, D5.L, D7.W	.END