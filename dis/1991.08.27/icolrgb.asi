	.SBTTL	ICOLRGB.ASI;-------------\\; _ICOL_MODRGB >;=============/; Choix d'une couleur dans la palette des couleurs disponibles.; in	A0.L	^descripteur fentre;	D4.L	mode (BIC*);		 BICMPAL  --> palette;		 BICMRGB  --> ascenseurs RGB;		 BICMHSV  --> ascenseurs HSV;		 BICMTEXT --> affiche le nom de la couleur;		 BICMEDIT --> dite le nom de la couleur;		 BICKHELP --> affiche raccourci clavier;		 BTCGLOB  --> si CLUT globale;	A4.L	^couleur initiale RGB;	A3.L	^texte	(si D3:#BICMTEXT);	A3.L	^nom	(si D3:#BICMEDIT);	A2.L	^texte raccourci clavier (si D3:#BICKHELP); out	D3.W	dernire touche (F1/F0);	D4.L	mode (BIC*);	(A4)+	couleur modifie RGB;	(A3)+	nom	(si D3:#BICMEDIT);	D7.W	erreur; mod	D3.L, D4.L, D7.W_ICOL_MODRGB:	PUSHM.L	D1,D2,D5,A1..A6	CALL	VAROPEN		; A6 <-- ^variables	JUMP,NE ERFAT$	LOAD.L	A1,A2		; A1 <-- ^texte raccourci clavier	LOAD.L	A5,A4		; A5 <-- ^couleur initiale	LOAD.L	(A6)+OFAN,D4	LOAD.W	(A6)+OCOLR,(A5)+0	LOAD.W	(A6)+OCOLG,(A5)+2	LOAD.W	(A6)+OCOLB,(A5)+4	LOAD.W	(A6)+OPALPX,#224	LOAD.W	(A6)+OCURPX,#224	LOAD.W	(A6)+OPALPY,#30+(16*2)+8	LOAD.W	(A6)+OCURPY,#30+(16*2)+8	LOAD.L	A2,#R16"TDBOX_MODRG3	TEST.L	D4:#BICMEDIT	JUMP',BS OPEN$	LOAD.W	(A6)+OPALPY,#30+(16*2)	LOAD.W	(A6)+OCURPY,#30+(16*2)	LOAD.L	A2,#R16"TDBOX_MODRG2	TEST.L	D4:#BICMTEXT	JUMP',BS OPEN$	LOAD.W	(A6)+OPALPY,#30	LOAD.W	(A6)+OCURPY,#30	LOAD.L	A2,#R16"TDBOX_MODRG1OPEN$:	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFAN	; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	CALL	DBOXKHELP	; affiche le raccourci clavier	TEST.L	D4:#BICMTEXT	JUMP',BC ITXEND$	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZE	/"/	LIB	?AFTEXT		; affiche le nom de la couleur	LIB	?AFTIM	.ASCIZE	/" :/ITXEND$:	TEST.L	D4:#BICMEDIT	JUMP',BC IEDEND$	LOAD.L	A4,A3IEDLOOP$:	TEST.B	(A4+)	JUMP,NE IEDLOOP$	DEC.L	A4		; A4 <-- ^fin du nom  diterIEDEND$:	CLR.W	D1	CALL	RGBCDRAW	; affiche la couleur d'origine	INC.W	D1	CALL	RGBCDRAW	; affiche la couleur modifieREFAIT$:	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_DBCLEAR	LIB	?COLORCR	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.W	D3,(A6)+OCURPY	SUB.W	D3,#25	SWAP.W	D3	LOAD.W	D3,#224-20	LOAD.L	D4,#H'10000*(200+30)+(200+40)	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface le prcdent	LIB	?COLORPOP	TEST.B	(A6)+OFAN+0:#BICMPAL-24	JUMP',BS PAL$	TEST.B	(A6)+OFAN+0:#BICMHSV-24	JUMP',BS HSV$	CALL	RGBCPUT		; init les ascenseurs selon les couleurs	CALL	RGBDRAWS	; dessine les trois ascenseurs	CALL	RGBUPDATES	; met  jour les trois ascenseurs	JUMP'	LOOP$HSV$:	CALL	HSVCPUT		; init les ascenseurs selon les couleurs	CALL	HSVDRAWS	; dessine les trois ascenseurs	CALL	HSVUPDATES	; met  jour les trois ascenseurs	JUMP'	LOOP$PAL$:	CALL	PALDRAW		; dessine la palette	CALL	PALGET		; D1 <-- rang	CALL	PALINV		; allume la fausse couleur actuelle;	JUMP'	LOOP$LOOP$:	LOAD.L	D4,(A6)+OFAN	DBOX_	EDIT		; attend action ...	LOAD.L	(A6)+OFAN,D4	TEST.L	D4:#BICMEDIT	JUMP',BC NOEDIT$	CALL	DBOXZEROCR	; remplace <CR> par <0>NOEDIT$:	LOAD.L	A1,#R16"TKEY_MODRGB	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	; bouton souris press ?	JUMP,EQ CLIC$		; oui => CLIC$	COMP.W	D3,#F1	JUMP,EQ DACCORD$	COMP.W	D3,#F0	JUMP,EQ ANNULE$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#F4	JUMP,EQ COPIE$	COMP.W	D3,#H'100*(2^BCOPY)+SPACE	JUMP,EQ COPIE$	COMP.W	D3,#F6	JUMP,EQ COLLE$	COMP.W	D3,#H'100*(2^BCURSOR)+SPACE	JUMP,EQ COLLE$	COMP.W	D3,#H'100*(2^BSHOW)+SPACE	JUMP,EQ CLASSEUR$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	TEST.B	(A6)+OFAN+1:#BICMEDIT-16	JUMP,BC BIP$	LOAD.L	A4,A3	CLR.B	(A3)	JUMP	LOOP$KEYDBOX$:	JUMP	REFAIT$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	TEST.B	(A6)+OFAN+0:#BICMPAL-24	JUMP,BS	CLICPAL$	TEST.B	(A6)+OFAN+0:#BICMHSV-24	JUMP,BS	CLICHSV$CLICRGB$:	LOAD.L	A1,#R16"CRMAJ$	CALL	RGBMOVES	; dplace l'un des trois ascenseurs ?	JUMP,NE BIP$	JUMP	LOOP$CRMAJ$:	PUSH.W	D1	CALL	RGBCGET		; OCOL[R,G,B] <-- rouge/vert/bleu des ascenseurs	LOAD.W	D1,#1	CALL	RGBCDRAW	; affiche la couleur modifie	POP.W	D1	RETCLICHSV$:	LOAD.L	A1,#R16"CHMAJ$	CALL	HSVMOVES	; dplace l'un des trois ascenseurs ?	JUMP,NE BIP$	JUMP	LOOP$CHMAJ$:	PUSH.W	D1	CALL	HSVCGET		; OCOL[R,G,B] <-- rouge/vert/bleu des ascenseurs	LOAD.W	D1,#1	CALL	RGBCDRAW	; affiche la couleur modifie	POP.W	D1	RETCLICPAL$:	CALL	PALGET		; D1 <-- rang	CALL	PALINV		; teint la fausse couleur actuelle	LOAD.W	D2,D1	CALL	PALMOVE		; choix d'une couleur dans la palette ...	JUMP',NE PEND$	CALL	PALPUT		; change la fausse couleur	LOAD.W	D3,D1	LOAD.W	D1,#1	CALL	RGBCDRAW	; affiche la couleur modifie	COMP.W	D3,D2		; double-clic ?	JUMP,EQ DACCORD$	; oui => DACCORD$PEND$:	PUSH.W	D7	CALL	PALGET		; D1 <-- rang	CALL	PALINV		; allume la fausse couleur actuelle	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$COPIE$:	CALL	COPIE		; bloc-notes <-- couleur	JUMP,NE BIP$	JUMP	LOOP$COLLE$:	CALL	COLLE		; OCOLR <-- rouge/vert/bleu	JUMP,NE BIP$	LOAD.W	D1,#1	CALL	RGBCDRAW	; affiche la couleur modifie	JUMP	REFAIT$CLASSEUR$:	LOAD.W	D2,#2^BDBSAV	BLOC_	VISU		; accs au classeur ...	PUSH.W	D7	CALL	DBOXRSK		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP	COLLE$DACCORD$:	LOAD.W	(A5)+0,(A6)+OCOLR	LOAD.W	(A5)+2,(A6)+OCOLG	LOAD.W	(A5)+4,(A6)+OCOLB	LOAD.W	D3,#F1ANNULE$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	LOAD.L	D4,(A6)+OFAN	; D4 <-- fanions	CALL	VARCLOSE	; libre les variablesERFAT$:	POPM.L	D1,D2,D5,A1..A6	TEST.W	D7		; retour EQ/NE	RETTDBOX_MODRG1:	.W	10$-TDBOX_MODRG1	.W	TSK_MODRGB-TDBOX_MODRG1	.W	0,010$:	.B	ODBTABX,54	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	"  COPIE  "	.B	ODBBOX,0,F6,TDBNORM	.ASCIZ	" COLLE  "	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" CHOISIT "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,26	.B	ODBCIRCLE,BICMPAL!2^7,KEYDBOX/H'100,BICMPAL	.ASCIZ	" palette"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BICMHSV!2^7,KEYDBOX/H'100,BICMHSV	.ASCIZ	" TSI"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BICMRGB!2^7,KEYDBOX/H'100,BICMRGB	.ASCIZ	" RVB"	.B	0TDBOX_MODRG2:	.W	10$-TDBOX_MODRG2	.W	TSK_MODRGB-TDBOX_MODRG2	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix de la couleur "	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBTABX,54	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	"  COPIE  "	.B	ODBBOX,0,F6,TDBNORM	.ASCIZ	" COLLE  "	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" CHOISIT "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,26	.B	ODBCIRCLE,BICMPAL!2^7,KEYDBOX/H'100,BICMPAL	.ASCIZ	" palette"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BICMHSV!2^7,KEYDBOX/H'100,BICMHSV	.ASCIZ	" TSI"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BICMRGB!2^7,KEYDBOX/H'100,BICMRGB	.ASCIZ	" RVB"	.B	0TDBOX_MODRG3:	.W	10$-TDBOX_MODRG3	.W	TSK_MODRGB-TDBOX_MODRG3	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Nom de la couleur "	.B	ODBCLINE,16+1	.B	ODBCR,ODBCR,ODBCR2	.B	ODBTABX,54	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	"  COPIE  "	.B	ODBBOX,0,F6,TDBNORM	.ASCIZ	" COLLE  "	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" CHOISIT "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,26	.B	ODBCIRCLE,BICMPAL!2^7,KEYDBOX/H'100,BICMPAL	.ASCIZ	" palette"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BICMHSV!2^7,KEYDBOX/H'100,BICMHSV	.ASCIZ	" TSI"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BICMRGB!2^7,KEYDBOX/H'100,BICMRGB	.ASCIZ	" RVB"	.B	0TSK_MODRGB:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Copie       Colle"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_MODRGB:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_MODRGB	.W	F13,F14,F15,END,0	DOKF0-TKEY_MODRGB	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MODRGB	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_MODRGB	.W	0;---------\\; RGBCDRAW >;=========/; Affiche la couleur originale (0) ou modifie (1).; in	D1.W	numro de la couleur (0,1); out	-; mod	D7.WRGBCDRAW:	PUSHM.L	D2..D5,A3	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.W	D3,D1	MUL.WU	D3,#86	ADD.W	D3,(A6)+OCURPY	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LOAD.W	D3,#20	LOAD.L	D4,#H'10000*60+168	LOAD.W	D2,#SETDOT	LIB	?DRRECT	LIB	?COLORPUSH	PUSHM.L	D3,D4	LOAD.W	D3,(A6)+OCOLR	LOAD.W	D4,(A6)+OCOLG	LOAD.W	D5,(A6)+OCOLB	LIB	?COLORSA	POPM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	LIB	?COLORPOP	SWAP.W	D3	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#3	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A3,#R16"TX0$	TEST.W	D1	JUMP',EQ TEXT$	LOAD.L	A3,#R16"TX1$TEXT$:	LIB	?AFTEXT		; affiche original/modifiEXIT$:	POPM.L	D2..D5,A3	RETTX0$:	.ASCIZ	"Original"TX1$:	.ASCIZ	"Modifi"	.EVEN	.END