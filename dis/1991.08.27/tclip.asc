	.TITLE	TCLIP.ASC	.PROC	M680002	.REF	SMAKY	.REF	MODULES	.LOC	0OWDO:	.BLKB	2LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.W	D3,#3	LIB	?MOUSE	LIB	?GETPDIS	LOAD.L	A0,A4	LIB	?AFTIM	.B	EOP	.B	NOCURS	.B	MODGRA,GRACLIP2	.B	MMODULO,1	.B	PEN	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'01111110	.B	B'00111100	.B	0	.EVEN	LOAD.L	A3,#R16"TXMENU	LIB	?AFMENU	LOAD.L	D3,#H'10000*100+200	LOAD.L	D4,#H'10000*151+301	PUSHM.L	D3,D4	SUB.W	D3,#2	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	ADD.W	D4,#2+1	SWAP.W	D4	ADD.W	D4,#2+1	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT	POPM.L	D3,D4	LIB	?CREWDO	LOAD.W	(A6)+OWDO,D5	LIB	?USEWDO	LOAD.W	D4,#50	SWAP.W	D4	LOAD.W	D4,#-100	LOAD.W	D3,#0	SWAP.W	D3	LOAD.W	D3,#5	LOAD.W	D2,#600/5	LOAD.W	D1,#SETDOT	LOAD.L	A2,A0	GRA_	HVDOT	LOAD.W	D4,#-100	SWAP.W	D4	LOAD.W	D4,#50	LOAD.W	D3,#5	SWAP.W	D3	LOAD.W	D3,#0	LOAD.W	D2,#600/5	LOAD.W	D1,#SETDOT	LOAD.L	A2,A0	GRA_	HVDOTLOOP:	LIB	?GETCAR	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC	COMP.W	D3,#F0	JUMP,EQ QUITTE	COMP.W	D3,#F14	JUMP,EQ EFFACE	JUMP	LOOPCLIC:	CALL	IFMOUSE	LOAD.L	D0,D4	LOAD.L	D1,D420$:	LIB	?GETKEY	COMP.W	D3,#KEYMPO	JUMP,NE LOOP	CALL	DESSIN	CALL	IFMOUSE	LOAD.L	D1,D4	CALL	DESSIN	JUMP	20$EFFACE:	LOAD.B	D3,#EOP	LIB	?AFCAR	JUMP	LOOP;--------\\; DESSIN  >;========/; ; in	D0.L	origine;	D1.L	arrive; out	-; mod	D7.WDESSIN:	PUSHM.L	D2..D4	COMP.L	D0,D1	JUMP,EQ	90$	LOAD.W	D2,#INVDOT	LOAD.L	D3,D0	LOAD.L	D4,D1	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG90$:	POPM.L	D2..D4	RET	LOAD.W	D3,#0	SWAP.W	D3	LOAD.W	D3,#-100	LOAD.W	D4,#+150	SWAP.W	D4	LOAD.W	D4,#+500	LOAD.W	D2,#SETDOT!PENDOT	LIB	?DRSEG	LOAD.W	D3,#0+150+20	SWAP.W	D3	LOAD.W	D3,#-100+500	LOAD.W	D4,#-150	SWAP.W	D4	LOAD.W	D4,#-500	LOAD.W	D2,#SETDOT!PENDOT	LIB	?DRSEG	LOAD.W	D3,#0+40	SWAP.W	D3	LOAD.W	D3,#-100	LOAD.W	D4,#+150	SWAP.W	D4	LOAD.W	D4,#+500	LOAD.W	D2,#SETDOT	LIB	?DRSEG	LOAD.W	D3,#0+150+50	SWAP.W	D3	LOAD.W	D3,#-100+500	LOAD.W	D4,#-150	SWAP.W	D4	LOAD.W	D4,#-500	LOAD.W	D2,#SETDOT	LIB	?DRSEGQUITTE:	CLR.W	D5	LIB	?USEWDO	LOAD.W	D5,(A6)+OWDO	LIB	?KILWDO	EXITIFMOUSE:	LIB	?IFMOUSE	SUB.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SWAP.W	D4	RETTXMENU:	.ASCIZ	""	.ASCIZ	" Fin "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"      Efface     "		;     ;     ;     ;	.EVENVAR:	.FILLB	LGVAR,0	.END	START