	.SBTTL	PICSELECT.ASI;------------\\; INIPOIGNEES >;============/; Initialise les 4 points pour les poignes.; in	D1.L	position d'un coin;	D2.L	position de l'autre coin; out	-; mod	D7.WINIPOIGNEES:	PUSHM.L	D1,D2	CALL	ORDONNE		; D1/D2 <-- coins opposs	CALL	D1D2POIGNEE	; OSEPxx <-- coins	SUB.W	D2,D1	ASR.W	D2,#1	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	ASR.W	D2,#1	ADD.W	D2,D1;	SWAP.W	D1	SWAP.W	D2	LOAD.L	(A6)+OSEPMI,D2	; OSEPMI <-- centre de symtrie	LOAD.L	(A6)+OSEOHG,(A6)+OSEPHG	LOAD.L	(A6)+OSEOHD,(A6)+OSEPHD	LOAD.L	(A6)+OSEOBG,(A6)+OSEPBG	LOAD.L	(A6)+OSEOBD,(A6)+OSEPBD	LOAD.L	(A6)+OSEOMI,(A6)+OSEPMI	POPM.L	D1,D2	RET;------------\\; D1D2POIGNEE >;============/; Initialise les quatre paramtres OSEPxx.; in	D1.L	coin sup/gauche;	D2.L	coin inf/droite; out	-; mod	D7.WD1D2POIGNEE:	LOAD.L	(A6)+OSEPHG,D1	LOAD.L	(A6)+OSEPBD,D2	LOAD.W	(A6)+OSEPHD+2,D2	LOAD.W	(A6)+OSEPBG+2,D1	SWAP.W	D1	SWAP.W	D2	LOAD.W	(A6)+OSEPHD+0,D1	LOAD.W	(A6)+OSEPBG+0,D2	SWAP.W	D1	SWAP.W	D2	RET;-------------\\; TESTPOIGNEES >;=============/; Vrifie que la zone de slection ne dborde pas de la matrice.; in	-; out	D7.W	erreur; mod	D7.WTESTPOIGNEES:	PUSHM.L	D3,D4	CLR.W	D7		; D7 <-- ok	LOAD.W	D3,(A6)+OSEPHG+2	JUMP',NC 10$	SUB.W	(A6)+OSEPHG+2,D3	SUB.W	(A6)+OSEPHD+2,D3	SUB.W	(A6)+OSEPBG+2,D3	SUB.W	(A6)+OSEPBD+2,D3	LOAD.W	D7,#110$:	LOAD.W	D3,(A6)+OSEPHD+2	JUMP',NC 11$	SUB.W	(A6)+OSEPHG+2,D3	SUB.W	(A6)+OSEPHD+2,D3	SUB.W	(A6)+OSEPBG+2,D3	SUB.W	(A6)+OSEPBD+2,D3	LOAD.W	D7,#111$:	LOAD.W	D3,(A6)+OSEPBG+2	JUMP',NC 12$	SUB.W	(A6)+OSEPHG+2,D3	SUB.W	(A6)+OSEPHD+2,D3	SUB.W	(A6)+OSEPBG+2,D3	SUB.W	(A6)+OSEPBD+2,D3	LOAD.W	D7,#112$:	LOAD.W	D3,(A6)+OSEPBD+2	JUMP',NC 13$	SUB.W	(A6)+OSEPHG+2,D3	SUB.W	(A6)+OSEPHD+2,D3	SUB.W	(A6)+OSEPBG+2,D3	SUB.W	(A6)+OSEPBD+2,D3	LOAD.W	D7,#113$:	LOAD.W	D4,(A6)+OMALMX	DEC.W	D4	LOAD.W	D3,(A6)+OSEPHG+2	SUB.W	D3,D4	JUMP',LS 20$	SUB.W	(A6)+OSEPHG+2,D3	SUB.W	(A6)+OSEPHD+2,D3	SUB.W	(A6)+OSEPBG+2,D3	SUB.W	(A6)+OSEPBD+2,D3	LOAD.W	D7,#120$:	LOAD.W	D3,(A6)+OSEPHD+2	SUB.W	D3,D4	JUMP',LS 21$	SUB.W	(A6)+OSEPHG+2,D3	SUB.W	(A6)+OSEPHD+2,D3	SUB.W	(A6)+OSEPBG+2,D3	SUB.W	(A6)+OSEPBD+2,D3	LOAD.W	D7,#121$:	LOAD.W	D3,(A6)+OSEPBG+2	SUB.W	D3,D4	JUMP',LS 22$	SUB.W	(A6)+OSEPHG+2,D3	SUB.W	(A6)+OSEPHD+2,D3	SUB.W	(A6)+OSEPBG+2,D3	SUB.W	(A6)+OSEPBD+2,D3	LOAD.W	D7,#122$:	LOAD.W	D3,(A6)+OSEPBD+2	SUB.W	D3,D4	JUMP',LS 23$	SUB.W	(A6)+OSEPHG+2,D3	SUB.W	(A6)+OSEPHD+2,D3	SUB.W	(A6)+OSEPBG+2,D3	SUB.W	(A6)+OSEPBD+2,D3	LOAD.W	D7,#123$:	LOAD.W	D3,(A6)+OSEPHG+0	JUMP',NC 30$	SUB.W	(A6)+OSEPHG+0,D3	SUB.W	(A6)+OSEPHD+0,D3	SUB.W	(A6)+OSEPBG+0,D3	SUB.W	(A6)+OSEPBD+0,D3	LOAD.W	D7,#130$:	LOAD.W	D3,(A6)+OSEPHD+0	JUMP',NC 31$	SUB.W	(A6)+OSEPHG+0,D3	SUB.W	(A6)+OSEPHD+0,D3	SUB.W	(A6)+OSEPBG+0,D3	SUB.W	(A6)+OSEPBD+0,D3	LOAD.W	D7,#131$:	LOAD.W	D3,(A6)+OSEPBG+0	JUMP',NC 32$	SUB.W	(A6)+OSEPHG+0,D3	SUB.W	(A6)+OSEPHD+0,D3	SUB.W	(A6)+OSEPBG+0,D3	SUB.W	(A6)+OSEPBD+0,D3	LOAD.W	D7,#132$:	LOAD.W	D3,(A6)+OSEPBD+0	JUMP',NC 33$	SUB.W	(A6)+OSEPHG+0,D3	SUB.W	(A6)+OSEPHD+0,D3	SUB.W	(A6)+OSEPBG+0,D3	SUB.W	(A6)+OSEPBD+0,D3	LOAD.W	D7,#133$:	LOAD.W	D4,(A6)+OMALMY	DEC.W	D4	LOAD.W	D3,(A6)+OSEPHG+0	SUB.W	D3,D4	JUMP',LS 40$	SUB.W	(A6)+OSEPHG+0,D3	SUB.W	(A6)+OSEPHD+0,D3	SUB.W	(A6)+OSEPBG+0,D3	SUB.W	(A6)+OSEPBD+0,D3	LOAD.W	D7,#140$:	LOAD.W	D3,(A6)+OSEPHD+0	SUB.W	D3,D4	JUMP',LS 41$	SUB.W	(A6)+OSEPHG+0,D3	SUB.W	(A6)+OSEPHD+0,D3	SUB.W	(A6)+OSEPBG+0,D3	SUB.W	(A6)+OSEPBD+0,D3	LOAD.W	D7,#141$:	LOAD.W	D3,(A6)+OSEPBG+0	SUB.W	D3,D4	JUMP',LS 42$	SUB.W	(A6)+OSEPHG+0,D3	SUB.W	(A6)+OSEPHD+0,D3	SUB.W	(A6)+OSEPBG+0,D3	SUB.W	(A6)+OSEPBD+0,D3	LOAD.W	D7,#142$:	LOAD.W	D3,(A6)+OSEPBD+0	SUB.W	D3,D4	JUMP',LS 43$	SUB.W	(A6)+OSEPHG+0,D3	SUB.W	(A6)+OSEPHD+0,D3	SUB.W	(A6)+OSEPBG+0,D3	SUB.W	(A6)+OSEPBD+0,D3	LOAD.W	D7,#143$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; OPERPOIGNEE >;============/; Modifie le rectangle de slection pour un zoom.; in	D0.W	poigne;	D1.B	ICOxx;	D3.L	nouvelle coordonne; out	-; mod	D7.WOPERPOIGNEE:	TEST.L	D0:#BPOICE	; poigne centrale ?	JUMP,BS	DEPLACEPOIGNEE	; oui => DEPLACEPOIGNEE	COMP.B	(A6)+OYICO,#ICOZOOM	JUMP,EQ ZOOMPOIGNEE	COMP.B	(A6)+OYICO,#ICOTOURNE	JUMP,EQ TOURNEPOIGNEE	COMP.B	(A6)+OYICO,#ICODEFORME	JUMP,EQ DEFPOIGNEE	RET;---------------\\; DEPLACEPOIGNEE >;---------------/; Modifie le rectangle de slection pour le dplacer.; in	D3.L	nouvelle coordonne; out	-; mod	D7.WDEPLACEPOIGNEE:	PUSHM.L	D3,D4	LOAD.L	D4,D3	CALL	POMPOIGNEE	; D3 <-- position de la poigne centrale	EX.L	D3,D4	SUB.W	D3,D4		; D3 <-- +/- dplacement en X	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4		; D3 <-- +/- dplacement en Y	SWAP.W	D3;	SWAP.W	D4	LOAD.L	D4,(A6)+OSEPHG	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OSEPHG,D4	LOAD.L	D4,(A6)+OSEPHD	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OSEPHD,D4	LOAD.L	D4,(A6)+OSEPBG	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OSEPBG,D4	LOAD.L	D4,(A6)+OSEPBD	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OSEPBD,D4	LOAD.L	D4,(A6)+OSEPMI	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OSEPMI,D4	POPM.L	D3,D4	RET;------------\\; ZOOMPOIGNEE >;------------/; Modifie le rectangle de slection pour un zoom.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WZOOMPOIGNEE:	PUSHM.L	D1..D4	TEST.L	D0:#BPOIHG	JUMP',BS 20$	TEST.L	D0:#BPOIHD	JUMP,BS 30$	TEST.L	D0:#BPOIBG	JUMP,BS 40$	TEST.L	D0:#BPOIBD	JUMP,BS 50$	JUMP	90$20$:				; sup/gauche =>	COMP.B	(A6)+OSTRHV,#ICOHOMOT	JUMP',NE 22$	LOAD.W	D2,(A6)+OSEOBG+0	SUB.W	D2,(A6)+OSEOHG+0 ; D2 <-- dy'	LOAD.W	D1,(A6)+OSEPHD+2	SUB.W	D1,D3		 ; D1 <-- dx	MUL.WA	D2,D1	LOAD.W	D1,(A6)+OSEOHD+2	SUB.W	D1,(A6)+OSEOHG+2 ; D2 <-- dx'	DIV.WA	D2,D1		 ; D2 <-- (dy'*dx)/dx'	LOAD.W	D1,(A6)+OSEPBG+0	SUB.W	D1,D2	SWAP.W	D3	LOAD.W	D3,D1	SWAP.W	D322$:	LOAD.L	(A6)+OSEPHG,D3	LOAD.W	(A6)+OSEPBG+2,D3	SWAP.W	D3	LOAD.W	(A6)+OSEPHD+0,D3	JUMP	90$30$:				; sup/droite =>	COMP.B	(A6)+OSTRHV,#ICOHOMOT	JUMP',NE 32$	LOAD.W	D2,(A6)+OSEOBG+0	SUB.W	D2,(A6)+OSEOHG+0 ; D2 <-- dy'	LOAD.W	D1,D3	SUB.W	D1,(A6)+OSEPHG+2 ; D1 <-- dx	MUL.WA	D2,D1	LOAD.W	D1,(A6)+OSEOHD+2	SUB.W	D1,(A6)+OSEOHG+2 ; D2 <-- dx'	DIV.WA	D2,D1		 ; D2 <-- (dy'*dx)/dx'	LOAD.W	D1,(A6)+OSEPBG+0	SUB.W	D1,D2	SWAP.W	D3	LOAD.W	D3,D1	SWAP.W	D332$:	LOAD.L	(A6)+OSEPHD,D3	LOAD.W	(A6)+OSEPBD+2,D3	SWAP.W	D3	LOAD.W	(A6)+OSEPHG+0,D3	JUMP	90$40$:				; inf/gauche =>	COMP.B	(A6)+OSTRHV,#ICOHOMOT	JUMP',NE 42$	LOAD.W	D2,(A6)+OSEOBG+0	SUB.W	D2,(A6)+OSEOHG+0 ; D2 <-- dy'	LOAD.W	D1,(A6)+OSEPHD+2	SUB.W	D1,D3		 ; D1 <-- dx	MUL.WA	D2,D1	LOAD.W	D1,(A6)+OSEOHD+2	SUB.W	D1,(A6)+OSEOHG+2 ; D2 <-- dx'	DIV.WA	D2,D1		 ; D2 <-- (dy'*dx)/dx'	ADD.W	D2,(A6)+OSEPHG+0	SWAP.W	D3	LOAD.W	D3,D2	SWAP.W	D342$:	LOAD.L	(A6)+OSEPBG,D3	LOAD.W	(A6)+OSEPHG+2,D3	SWAP.W	D3	LOAD.W	(A6)+OSEPBD+0,D3	JUMP	90$50$:				; inf/droite =>	COMP.B	(A6)+OSTRHV,#ICOHOMOT	JUMP',NE 52$	LOAD.W	D2,(A6)+OSEOBG+0	SUB.W	D2,(A6)+OSEOHG+0 ; D2 <-- dy'	LOAD.W	D1,D3	SUB.W	D1,(A6)+OSEPHG+2 ; D1 <-- dx	MUL.WA	D2,D1	LOAD.W	D1,(A6)+OSEOHD+2	SUB.W	D1,(A6)+OSEOHG+2 ; D2 <-- dx'	DIV.WA	D2,D1		 ; D2 <-- (dy'*dx)/dx'	ADD.W	D2,(A6)+OSEPHG+0	SWAP.W	D3	LOAD.W	D3,D2	SWAP.W	D352$:	LOAD.L	(A6)+OSEPBD,D3	LOAD.W	(A6)+OSEPHD+2,D3	SWAP.W	D3	LOAD.W	(A6)+OSEPBG+0,D3;	JUMP	90$90$:	POPM.L	D1..D4	RET;--------------\\; TOURNEPOIGNEE >;--------------/; Modifie le rectangle de slection pour une rotation.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WTOURNEPOIGNEE:	PUSHM.L	D1..D4	TEST.L	D0:#BPOIHG	JUMP',BS 20$	TEST.L	D0:#BPOIHD	JUMP',BS 30$	TEST.L	D0:#BPOIBG	JUMP',BS 40$	TEST.L	D0:#BPOIBD	JUMP',BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OSEOHG	JUMP'	80$30$:				; sup/droite =>	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OSEOHD	JUMP'	80$40$:				; inf/gauche =>	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OSEOBG	JUMP'	80$50$:				; inf/droite =>	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OSEOBD;	JUMP'	80$80$:	LOAD.L	D1,(A6)+OSEPMI	SUB.W	D1,(A6)+OSEOMI+2	SWAP.W	D1	SUB.W	D1,(A6)+OSEOMI+0	SWAP.W	D1		; D1 <-- dplacement	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en X	SWAP.W	D1	SWAP.W	D3	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en Y	SWAP.W	D1	SWAP.W	D3	CALL	XTOURNE		; D2 <-- angle de rotation	LOAD.W	(A6)+OSEANG,D2	LOAD.L	D3,(A6)+OSEOHG	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en X	SWAP.W	D1	SWAP.W	D3	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en Y	SWAP.W	D1	SWAP.W	D3	CALL	QTOURNE	LOAD.L	(A6)+OSEPHG,D3	LOAD.L	D3,(A6)+OSEOHD	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en X	SWAP.W	D1	SWAP.W	D3	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en Y	SWAP.W	D1	SWAP.W	D3	CALL	QTOURNE	LOAD.L	(A6)+OSEPHD,D3	LOAD.L	D3,(A6)+OSEOBG	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en X	SWAP.W	D1	SWAP.W	D3	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en Y	SWAP.W	D1	SWAP.W	D3	CALL	QTOURNE	LOAD.L	(A6)+OSEPBG,D3	LOAD.L	D3,(A6)+OSEOBD	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en X	SWAP.W	D1	SWAP.W	D3	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en Y	SWAP.W	D1	SWAP.W	D3	CALL	QTOURNE	LOAD.L	(A6)+OSEPBD,D390$:	POPM.L	D1..D4	RET;-----------\\; DEFPOIGNEE >;-----------/; Modifie le rectangle de slection pour une dformation.; in	D0.W	poigne;	D1.B	ICOxx;	D3.L	nouvelle coordonne; out	-; mod	D7.WDEFPOIGNEE:	COMP.B	(A6)+OSTRDF,#ICODEFORMETX	JUMP,EQ DEFTXPOIGNEE	COMP.B	(A6)+OSTRDF,#ICODEFORMETY	JUMP,EQ DEFTYPOIGNEE	COMP.B	(A6)+OSTRDF,#ICODEFORMEPX	JUMP,EQ DEFPXPOIGNEE	COMP.B	(A6)+OSTRDF,#ICODEFORMEPY	JUMP,EQ DEFPYPOIGNEE	COMP.B	(A6)+OSTRDF,#ICODEFORMEQQ	JUMP,EQ DEFQQPOIGNEE	RET;-------------\\; DEFTXPOIGNEE >;-------------/; Modifie le rectangle de slection pour une dformation en trapze.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WDEFTXPOIGNEE:	PUSHM.L	D3,D4	TEST.L	D0:#BPOIHG	JUMP',BS 20$	TEST.L	D0:#BPOIHD	JUMP',BS 30$	TEST.L	D0:#BPOIBG	JUMP',BS 40$	TEST.L	D0:#BPOIBD	JUMP',BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.W	D4,(A6)+OSEPHG+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPHG,D3	LOAD.W	D3,(A6)+OSEPHD+2	ADD.W	D3,D4	LOAD.L	(A6)+OSEPHD,D3	JUMP'	90$30$:				; sup/droite =>	LOAD.W	D4,(A6)+OSEPHD+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPHD,D3	LOAD.W	D3,(A6)+OSEPHG+2	ADD.W	D3,D4	LOAD.L	(A6)+OSEPHG,D3	JUMP'	90$40$:				; inf/gauche =>	LOAD.W	D4,(A6)+OSEPBG+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPBG,D3	LOAD.W	D3,(A6)+OSEPBD+2	ADD.W	D3,D4	LOAD.L	(A6)+OSEPBD,D3	JUMP'	90$50$:				; inf/droite =>	LOAD.W	D4,(A6)+OSEPBD+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPBD,D3	LOAD.W	D3,(A6)+OSEPBG+2	ADD.W	D3,D4	LOAD.L	(A6)+OSEPBG,D3;	JUMP'	90$90$:	POPM.L	D3,D4	RET;-------------\\; DEFTYPOIGNEE >;-------------/; Modifie le rectangle de slection pour une dformation en trapze.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WDEFTYPOIGNEE:	PUSHM.L	D3,D4	TEST.L	D0:#BPOIHG	JUMP',BS 20$	TEST.L	D0:#BPOIHD	JUMP',BS 30$	TEST.L	D0:#BPOIBG	JUMP',BS 40$	TEST.L	D0:#BPOIBD	JUMP',BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.W	D4,(A6)+OSEPHG+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPHG,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPBG+0	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPBG,D3	JUMP'	90$30$:				; sup/droite =>	LOAD.W	D4,(A6)+OSEPHD+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPHD,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPBD+0	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPBD,D3	JUMP'	90$40$:				; inf/gauche =>	LOAD.W	D4,(A6)+OSEPBG+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPBG,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPHG+0	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPHG,D3	JUMP'	90$50$:				; inf/droite =>	LOAD.W	D4,(A6)+OSEPBD+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPBD,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPHD+0	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPHD,D3;	JUMP'	90$90$:	POPM.L	D3,D4	RET;-------------\\; DEFPXPOIGNEE >;-------------/; Modifie le rectangle de slection pour une dformation en paralllogramme.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WDEFPXPOIGNEE:	PUSHM.L	D3,D4	TEST.L	D0:#BPOIHG	JUMP',BS 20$	TEST.L	D0:#BPOIHD	JUMP',BS 30$	TEST.L	D0:#BPOIBG	JUMP',BS 40$	TEST.L	D0:#BPOIBD	JUMP',BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.W	D4,(A6)+OSEPHG+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPHG,D3	LOAD.W	D3,(A6)+OSEPHD+2	SUB.W	D3,D4	LOAD.L	(A6)+OSEPHD,D3	JUMP'	90$30$:				; sup/droite =>	LOAD.W	D4,(A6)+OSEPHD+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPHD,D3	LOAD.W	D3,(A6)+OSEPHG+2	SUB.W	D3,D4	LOAD.L	(A6)+OSEPHG,D3	JUMP'	90$40$:				; inf/gauche =>	LOAD.W	D4,(A6)+OSEPBG+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPBG,D3	LOAD.W	D3,(A6)+OSEPBD+2	SUB.W	D3,D4	LOAD.L	(A6)+OSEPBD,D3	JUMP'	90$50$:				; inf/droite =>	LOAD.W	D4,(A6)+OSEPBD+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPBD,D3	LOAD.W	D3,(A6)+OSEPBG+2	SUB.W	D3,D4	LOAD.L	(A6)+OSEPBG,D3;	JUMP'	90$90$:	POPM.L	D3,D4	RET;-------------\\; DEFPYPOIGNEE >;-------------/; Modifie le rectangle de slection pour une dformation en paralllogramme.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WDEFPYPOIGNEE:	PUSHM.L	D3,D4	TEST.L	D0:#BPOIHG	JUMP',BS 20$	TEST.L	D0:#BPOIHD	JUMP',BS 30$	TEST.L	D0:#BPOIBG	JUMP',BS 40$	TEST.L	D0:#BPOIBD	JUMP',BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.W	D4,(A6)+OSEPHG+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPHG,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPBG+0	SUB.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPBG,D3	JUMP'	90$30$:				; sup/droite =>	LOAD.W	D4,(A6)+OSEPHD+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPHD,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPBD+0	SUB.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPBD,D3	JUMP'	90$40$:				; inf/gauche =>	LOAD.W	D4,(A6)+OSEPBG+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPBG,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPHG+0	SUB.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPHG,D3	JUMP'	90$50$:				; inf/droite =>	LOAD.W	D4,(A6)+OSEPBD+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPBD,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPHD+0	SUB.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPHD,D3;	JUMP'	90$90$:	POPM.L	D3,D4	RET;-------------\\; DEFQQPOIGNEE >;-------------/; Modifie le rectangle de slection pour une dformation quelconque.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WDEFQQPOIGNEE:	PUSH.L	D3	TEST.L	D0:#BPOIHG	JUMP',BS 20$	TEST.L	D0:#BPOIHD	JUMP',BS 30$	TEST.L	D0:#BPOIBG	JUMP',BS 40$	TEST.L	D0:#BPOIBD	JUMP',BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.L	(A6)+OSEPHG,D3	JUMP'	90$30$:				; sup/droite =>	LOAD.L	(A6)+OSEPHD,D3	JUMP'	90$40$:				; inf/gauche =>	LOAD.L	(A6)+OSEPBG,D3	JUMP'	90$50$:				; inf/droite =>	LOAD.L	(A6)+OSEPBD,D3;	JUMP'	90$90$:	POP.L	D3	RET;--------------\\; SCROLLPOIGNEE >;==============/; Dplace ventuellement la partie visible.; in	D3.L	point o est la souris (y;x); out	-; mod	D7.WSCROLLPOIGNEE:	PUSH.L	A1	LOAD.L	A1,#0		; A1 <-- pas de routine d'inversion	CALL'	SCROLLIPOIGNEE	POP.L	A1	RET;---------------\\; SCROLLIPOIGNEE >;===============/; Dplace ventuellement la partie visible.; in	D3.L	point o est la souris (y;x);	A1.L	^routine d'inversion/nil; out	-; mod	D7.WSCROLLIPOIGNEE:	PUSHM.L	D1,D2,D4	LOAD.L	D1,D3	LOAD.L	D2,D3	CALL	DDCALCOV	; D4 <-- nouvel emplacement partie visible	CALL	DDSCROLL	; dplace v. la partie visible	POPM.L	D1,D2,D4	RET;------------\\; DETPOIGNEES >;============/; Dtecte dans quelle poigne est la souris.; in	D4.L	position de la souris; out	D0.W	poigne o est la souris;	D7.W	erreur; mod	D0.L, D7.WDETPOIGNEES:	LOAD.W	D0,#2^BPOIHG	CALL	DETPOIGNEE	; dans la poigne sup/gauche ?	JUMP',EQ 90$	LOAD.W	D0,#2^BPOIHD	CALL	DETPOIGNEE	; dans la poigne sup/droite ?	JUMP',EQ 90$	LOAD.W	D0,#2^BPOIBG	CALL	DETPOIGNEE	; dans la poigne inf/gauche ?	JUMP',EQ 90$	LOAD.W	D0,#2^BPOIBD	CALL	DETPOIGNEE	; dans la poigne inf/droite ?	JUMP',EQ 90$	LOAD.W	D0,#2^BPOICE	CALL	DETPOIGNEE	; dans la poigne centrale ?;	JUMP',EQ 90$90$:	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DETPOIGNEE >;-----------/; Dtecte si la souris est dans une poigne bien prcise.; in	D0.W	poigne;	D4.L	position de la souris; out	D7.W	ok/erreur; mod	D7.WDETPOIGNEE:	PUSHM.L	D3,D4	CALL	POSPOIGNEE	; D3 <-- position de la poigne	JUMP',NE 90$	LOAD.W	D7,#1		; D7 <-- en dehors	SUB.W	D3,#DPOIGNEE	COMP.W	D4,D3		; trop  gauche ?	JUMP',LO 90$	ADD.W	D3,#DPOIGNEE*2	COMP.W	D4,D3		; trop  droite ?	JUMP',HS 90$	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#DPOIGNEE	COMP.W	D4,D3		; trop en haut ?	JUMP',LO 90$	ADD.W	D3,#DPOIGNEE*2	COMP.W	D4,D3		; trop en bas ?	JUMP',HS 90$	CLR.W	D7		; D7 <-- hop, sur la poigne90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; INVPOIGNEES >;============/; Inverse les poignes de la zone slectionne par la souris.; Le rectangle peut dpasser dans les quatre directions.; in	D0.W	poignes  inverser; out	-; mod	D7.WINVPOIGNEES:	PUSHM.L	D0..D4	LOAD.W	D4,D0		; D4 <-- poignes  inverser	TEST.L	D4:#BPOIHG	JUMP',BC 20$	LOAD.L	D0,#2^BPOIHG	CALL	POSPOIGNEE	JUMP',NE 20$	CALL	INVPOIGNEE	; inverse la poigne sup/gauche20$:	TEST.L	D4:#BPOIHD	JUMP',BC 30$	LOAD.L	D0,#2^BPOIHD	CALL	POSPOIGNEE	JUMP',NE 30$	CALL	INVPOIGNEE	; inverse la poigne sup/droite30$:	TEST.L	D4:#BPOIBG	JUMP',BC 40$	LOAD.L	D0,#2^BPOIBG	CALL	POSPOIGNEE	JUMP',NE 40$	CALL	INVPOIGNEE	; inverse la poigne inf/gauche40$:	TEST.L	D4:#BPOIBD	JUMP',BC 50$	LOAD.L	D0,#2^BPOIBD	CALL	POSPOIGNEE	JUMP',NE 50$	CALL	INVPOIGNEE	; inverse la poigne inf/droite50$:	TEST.L	D4:#BPOICE	JUMP',BC 60$	LOAD.L	D0,#2^BPOICE	CALL	POSPOIGNEE	JUMP',NE 60$	CALL	INVPOIGNEE	; inverse la poigne centrale60$:	POPM.L	D0..D4	RET;-----------\\; INVPOIGNEE >;-----------/; Inverse une poigne.; in	D3.L	coordonne dans l'cran; out	-; mod	D7.WINVPOIGNEE:	PUSHM.L	D2..D4	LOAD.L	D4,#-1	CALL	_DRMDEF		; dfinit une trame pleine	SUB.W	D3,#DPOIGNEE/2	SWAP.W	D3	SUB.W	D3,#DPOIGNEE/2	SWAP.W	D3	LOAD.W	D4,#DPOIGNEE	SWAP.W	D4	LOAD.W	D4,#DPOIGNEE	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	; inverse la poigne	SUB.W	D3,#4/2	SWAP.W	D3	SUB.W	D3,#4/2	SWAP.W	D3	ADD.W	D4,#4-1	SWAP.W	D4	ADD.W	D4,#4-1	SWAP.W	D4	LIB	?DRRECT		; inverse rectangle autour	POPM.L	D2..D4	RET;-----------\\; POSPOIGNEE >;-----------/; Donne la position d'une poigne.; in	D0.W	poigne; out	D3.L	position dans l'cran;	D7.W	ok/erreur; mod	D3.L, D7.WPOSPOIGNEE:	CALL	POMPOIGNEE	; D3 <-- coordonne dans la matrice	JUMP',NE 90$	CALL	CONVGPOINT	; D3 <-- coordonne l'cran90$:	TEST.W	D7		; retour EQ/NE	RET;-----------\\; POMPOIGNEE >;-----------/; Donne la position d'une poigne dans la matrice principale.; in	D0.W	poigne; out	D3.L	position dans la matrice;	D7.W	ok/erreur; mod	D3.L, D7.WPOMPOIGNEE:	CLR.W	D7		; D7 <-- ok	COMP.B	(A6)+OYICO,#ICOMIROIR	JUMP',EQ 20$	LOAD.L	D3,(A6)+OSEPHG	TEST.L	D0:#BPOIHG	; poigne sup/gauche ?	JUMP',BS 90$	LOAD.L	D3,(A6)+OSEPHD	TEST.L	D0:#BPOIHD	; poigne sup/droite ?	JUMP',BS 90$	LOAD.L	D3,(A6)+OSEPBG	TEST.L	D0:#BPOIBG	; poigne inf/gauche ?	JUMP',BS 90$	LOAD.L	D3,(A6)+OSEPBD	TEST.L	D0:#BPOIBD	; poigne inf/droite ?	JUMP',BS 90$20$:	TEST.L	D0:#BPOICE	; poigne centrale ?	JUMP',BS 40$	LOAD.W	D7,#1	JUMP'	90$40$:	LOAD.W	D3,(A6)+OSEPHG+0	ADD.W	D3,(A6)+OSEPHD+0	ADD.W	D3,(A6)+OSEPBG+0	ADD.W	D3,(A6)+OSEPBD+0	SR.W	D3,#2	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPHG+2	ADD.W	D3,(A6)+OSEPHD+2	ADD.W	D3,(A6)+OSEPBG+2	ADD.W	D3,(A6)+OSEPBD+2	SR.W	D3,#290$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; INVSELECT >;==========/; Inverse toute la slection (quadrilatre quelconque).; in	-; out	-; mod	D7.WINVSELECT:	PUSHM.L	D0..D6	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	0	.EVEN	CLR.W	D2		; D2 <-- nb de points invisibles	LOAD.L	D3,(A6)+OSEPHG	CALL	CONVGPOINT	; D3 <-- coordonne	JUMP',EQ 20$	INC.W	D2		; D2 <-- un point invisible20$:	LOAD.L	D0,D3	LOAD.L	D3,(A6)+OSEPHD	CALL	CONVGPOINT	; D3 <-- coordonne	JUMP',EQ 21$	INC.W	D2		; D2 <-- un point invisible21$:	LOAD.L	D1,D3	LOAD.L	D3,(A6)+OSEPBG	CALL	CONVGPOINT	; D3 <-- coordonne	JUMP',EQ 22$	INC.W	D2		; D2 <-- un point invisible22$:	LOAD.L	D5,D3	LOAD.L	D3,(A6)+OSEPBD	CALL	CONVGPOINT	; D3 <-- coordonne	JUMP',EQ 23$	INC.W	D2		; D2 <-- un point invisible23$:	LOAD.L	D6,D3	TEST.W	D2		; y a-t-il un point invisible ?	JUMP',EQ 30$		; non => 30$				; oui =>	PUSH.L	D5	LOAD.W	D5,(A6)+OGWDO	LIB	?USEWDO		; utilise swdo autour de la grande matrice	POP.L	D5	SUB.W	D0,(A6)+OGMPOX	SWAP.W	D0	SUB.W	D0,(A6)+OGMPOY	SWAP.W	D0	SUB.W	D1,(A6)+OGMPOX	SWAP.W	D1	SUB.W	D1,(A6)+OGMPOY	SWAP.W	D1	SUB.W	D5,(A6)+OGMPOX	SWAP.W	D5	SUB.W	D5,(A6)+OGMPOY	SWAP.W	D5	SUB.W	D6,(A6)+OGMPOX	SWAP.W	D6	SUB.W	D6,(A6)+OGMPOY	SWAP.W	D630$:	LOAD.B	D3,(A6)+ODDOP	; D3 <-- type de l'opration	COMP.B	D3,#ICOZOOM	JUMP,EQ 51$	COMP.B	D3,#ICOTOURNE	JUMP,EQ 51$	COMP.B	D3,#ICOMIROIR	JUMP,EQ 51$	COMP.B	D3,#ICODEFORME	JUMP,EQ 51$	COMP.W	D0,D5	JUMP,NE 51$	COMP.W	D1,D6	JUMP,NE 51$	SWAP.W	D0	SWAP.W	D1	SWAP.W	D5	SWAP.W	D6	COMP.W	D0,D1	JUMP,NE 50$	COMP.W	D5,D6	JUMP,NE 50$	SWAP.W	D0	SWAP.W	D1	SWAP.W	D5	SWAP.W	D6				; zone parfaitement rectangulaire =>	PUSH.W	D2	LOAD.L	D1,D0	LOAD.L	D2,D6	CALL	ORDONNE	LOAD.L	D3,D1	LOAD.L	D4,D2	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE 40$	ADD.W	D4,(A6)+OGMLPX	SWAP.W	D4	ADD.W	D4,(A6)+OGMLPX	SWAP.W	D440$:	SUB.W	D4,D3		; D4 <-- largeur	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT		; dessine un rectangle traitill	POP.W	D2	JUMP'	80$50$:	SWAP.W	D0	SWAP.W	D1	SWAP.W	D5	SWAP.W	D651$:	LOAD.L	D3,D0		; D3 <-- sup/gauche	LOAD.L	D4,D1		; D4 <-- sup/droite	CALL	INVSELSEG	LOAD.L	D3,D1		; D3 <-- sup/droite	LOAD.L	D4,D6		; D4 <-- inf/droite	CALL	INVSELSEG	LOAD.L	D3,D6		; D3 <-- inf/droite	LOAD.L	D4,D5		; D4 <-- inf/gauche	CALL	INVSELSEG	LOAD.L	D3,D5		; D3 <-- inf/gauche	LOAD.L	D4,D0		; D4 <-- sup/gauche	CALL	INVSELSEG80$:	TEST.W	D2		; y a-t-il un point invisible ?	JUMP',EQ 90$		; non => 90$				; oui =>	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale90$:	POPM.L	D0..D6	RET;----------\\; INVSELSEG >;----------/; Inverse un segment de droite.; in	D3.L	origine (y;x);	D4.L	arrive (y;x); out	-; mod	D3.L, D4.L, D7.WINVSELSEG:	PUSH.W	D2	SUB.W	D4,D3		; D4 <-- largeur	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRSEG		; dessine un segment traitill	POP.W	D2	RET;--------\\; POSDIM  >;========/; Ordonne D1.L et D2.L pour que D1 soit en haut  gauche et; D2 la longueur.; in	D1.L	position d'un coin;	D2.L	position de l'autre coin; out	D1.L	position coin sup/gauche;	D2.L	dimensions; mod	D1.L, D2.LPOSDIM:	CALL	ORDONNE	SUB.W	D2,D1	INC.W	D2	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	INC.W	D2	SWAP.W	D1	SWAP.W	D2	RET;--------\\; ORDONNE >;========/; Ordonne D1.L et D2.L pour que D1 soit en haut  gauche et; D2 en bas  droite (D1<D2).; in	D1.L	position d'un coin;	D2.L	position de l'autre coin; out	D1.L	position d'un coin;	D2.L	position de l'autre coin; mod	D1.L, D2.LORDONNE:	PUSH.W	D3	COMP.W	D1,D2	JUMP',LE 10$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D310$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,D2	JUMP',LE 15$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D315$:	SWAP.W	D1	SWAP.W	D2	POP.W	D3	RET	.END