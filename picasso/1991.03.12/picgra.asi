	.SBTTL	PICGRA.ASI;-------------\\; DIMCOMMEPLAN >;=============/; Donne les dimensions occupes par un objet graphique,; en tenant compte v. de l'paisseur du pinceau.; in	D5.L	origine (y;x);	D6.L	arrive (y;x); out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WDIMCOMMEPLAN:	PUSHM.L	D0..D2	LOAD.L	D3,D5	LOAD.L	D4,D6	LOAD.B	D0,(A6)+OOBJET	; D0 <-- objet slectionn	COMP.B	D0,#ICOCERCLE	JUMP',EQ 20$				; objet rectangulaire =>	SUB.W	D4,D3	JUMP',GE 12$	ADD.W	D3,D4		; D3 <-- x	NEG.W	D4		; D4 <-- dx12$:	INC.W	D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',GE 14$	ADD.W	D3,D4		; D3 <-- y	NEG.W	D4		; D4 <-- dy14$:	INC.W	D4	SWAP.W	D3	SWAP.W	D4	JUMP	50$20$:				; cercle/ellipse =>	SUB.W	D4,D3		; D4 <-- dx 	JUMP',GE 22$	NEG.W	D422$:	LOAD.W	D1,D4		; D1 <-- rx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	JUMP',GE 24$	NEG.W	D424$:	LOAD.W	D2,D4		; D2 <-- ry	SWAP.W	D3	SWAP.W	D4	TEST.B	(A6)+OPOLY:#BPOLYE	JUMP',BS 30$				; cercle =>	LOAD.W	D4,D1	ADD.W	D4,D2		; D4 <-- rayon	LOAD.W	D1,D4	SWAP.W	D4	LOAD.W	D4,D1	SWAP.W	D430$:	SUB.W	D3,D4		; D3 <-- x	SL.W	D4,#1		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4		; D3 <-- y	SL.W	D4,#1		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4;	JUMP'	50$; Tient compte ventuellement de l'paisseur du pinceau.50$:	COMP.B	(A6)+OOUTIL,#ICOGOMME	JUMP',EQ 60$	COMP.B	(A6)+OOUTIL,#ICOPINCEAU	JUMP',NE 70$	SUB.W	D3,#8/2	ADD.W	D4,#8	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#8/2	ADD.W	D4,#8	SWAP.W	D3	SWAP.W	D4	JUMP'	70$60$:	SUB.W	D3,#12/2	ADD.W	D4,#12	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#12/2	ADD.W	D4,#12	SWAP.W	D3	SWAP.W	D4; Vrifie si les dimensions dpassent la partie visible.70$:	LOAD.W	D2,(A6)+OPMOVX	COMP.W	D3,D2	JUMP',GE 72$	LOAD.W	D3,D272$:	ADD.W	D2,(A6)+OPMDIX	SUB.W	D2,D3	COMP.W	D4,D2	JUMP',LE 73$	LOAD.W	D4,D273$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A6)+OPMOVY	COMP.W	D3,D2	JUMP',GE 74$	LOAD.W	D3,D274$:	ADD.W	D2,(A6)+OPMDIY	SUB.W	D2,D3	COMP.W	D4,D2	JUMP',LE 75$	LOAD.W	D4,D275$:	SWAP.W	D3	SWAP.W	D4	POPM.L	D0..D2	RET;-------------\\; DESCOMMEPLAN >;=============/; Dessine un objet graphique (droite/cercle/etc.) dans; la petite matrice.; in	D5.L	origine (y;x);	D6.L	arrive (y;x);	D2.W	mode de dessin;		 si 2^15=1 --> dessine dans matrice principale;		 si 2^14=1 --> dessine dans matrice masque;		 si 2^13=1 --> dessine directement dans la fentre principale; out	-; mod	D7.WDESCOMMEPLAN:	PUSHM.L	D0..D6,A3,A4	COMP.L	D5,D6		; origine = arrive ?	JUMP,EQ EXIT$		; oui => EXIT$	COMP.B	(A6)+OOUTIL,#ICOPINCEAU	JUMP',NE PEN$	COMP.W	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ PEN$		; oui => PEN$ (pas encore de pinceau)	LOAD.W	D0,D2	LOAD.L	A4,#(A6)+OPDEF	LOAD.W	D1,(A6)+ONPDEF	DESSIN_	DDEF		; dfinit le bon pinceau avec traitill	OR.W	D2,D0		; D2 <-- mode utilisant le pinceauPEN$:	LOAD.L	D3,D5	LOAD.L	D4,D6	LOAD.L	A4,(A6)+OPMAT	TEST.L	D2:#15		; dessine dans la matrice principale ?	JUMP,BS OPEN$		; oui => OPEN$	LOAD.L	A4,(A6)+OPMAM	TEST.L	D2:#14		; dessine dans la matrice masque ?	JUMP,BS OPEN$		; oui => OPEN$	TEST.L	D2:#13		; dessine directement dans l'cran ?	JUMP,BS DRAW$		; oui => DRAW$	LOAD.W	(A6)+OSDDIS+ODFTTC,(A0)+ODFTTC	TEST.W	(A6)+OSCALE	JUMP',NS LITTLE$	SUB.W	D3,(A6)+OPMOVX	SWAP.W	D3	SUB.W	D3,(A6)+OPMOVY	SWAP.W	D3	SUB.W	D4,(A6)+OPMOVX	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	SWAP.W	D4	JUMP'	COOR$LITTLE$:	CALL	CONVGPOINT	SUB.W	D3,(A6)+OGMPOX	SWAP.W	D3	SUB.W	D3,(A6)+OGMPOY	SWAP.W	D3	EX.L	D3,D4	CALL	CONVGPOINT	SUB.W	D3,(A6)+OGMPOX	SWAP.W	D3	SUB.W	D3,(A6)+OGMPOY	SWAP.W	D3	EX.L	D3,D4COOR$:	TEST.L	D2:#BPENDOT	JUMP',BS USEWDO$	COMP.B	(A6)+OOBJET,#ICOTRAIT	JUMP,EQ LINEAR$USEWDO$:	LOAD.W	D5,(A6)+OPWDO	LIB	?USEWDO		; utilise swdo autour de la petite matrice	JUMP'	DRAW$OPEN$:	CALL	_OPEDISMAT	; dessine dans la matrice principale/masque	LOAD.W	(A0)+ODFTTC,(A6)+OSDDIS+ODFTTCDRAW$:	LOAD.B	D0,(A6)+OOBJET	; D0 <-- objet slectionn	COMP.B	D0,#ICOTRAIT	JUMP',EQ LINE$	COMP.B	D0,#ICODROITE	JUMP',EQ LINE$	COMP.B	D0,#ICOSPLINE	JUMP',EQ LINE$	COMP.B	D0,#ICOFILET	JUMP,EQ FILET$	COMP.B	D0,#ICOCERCLE	JUMP,EQ CIRCLE$	COMP.B	D0,#ICORECTANGLE	JUMP,EQ RECT$	JUMP	END$LINE$:				; trait/droite =>	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine la droite	COMP.B	D0,#ICOSPLINE	JUMP,EQ END$	COMP.B	(A6)+OOUTIL,#ICOCRAYON	JUMP,NE END$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWDOT	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.B	(A3)+5,D2	; <mode>	LOAD.W	D3,#6	LIB	?STRING		; dessine le point d'arrive !	JUMP	END$LINEAR$:	SUB.W	D4,D3		; D4 <-- dx	ADD.W	D3,(A6)+OPMPOX	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	ADD.W	D3,(A6)+OPMPOY	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine la droite	COMP.B	(A6)+OOUTIL,#ICOCRAYON	JUMP,NE END$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWDOT	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.B	(A3)+5,D2	; <mode>	LOAD.W	D3,#6	LIB	?STRING		; dessine le point d'arrive !	JUMP	EXIT$FILET$:				; filet =>	TEST.L	D2:#14		; dessine dans la matrice masque ?	JUMP',BS FDRAW$		; oui => FDRAW$	LIB	?AFTIM	.B	MAPTT	.B	B'01010101	; map	.B	1		; chelle	.B	0	.EVENFDRAW$:	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine la droite	JUMP	END$CIRCLE$:			; cercle/ellipse =>	TEST.B	(A6)+OMCERC:#BMCEDIA	JUMP',BC CDRAW$	PUSH.L	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	POP.L	D4CDRAW$:	TEST.B	(A6)+OARC:#BARCQ	JUMP,BS ARC$	LOAD.W	D1,#3	TEST.B	(A6)+OPOLY:#BPOLY3	JUMP,BS POLY$	INC.W	D1	TEST.B	(A6)+OPOLY:#BPOLY4	JUMP,BS POLY$	INC.W	D1	TEST.B	(A6)+OPOLY:#BPOLY5	JUMP,BS POLY$	INC.W	D1	TEST.B	(A6)+OPOLY:#BPOLY6	JUMP,BS POLY$	ADD.W	D1,#2	TEST.B	(A6)+OPOLY:#BPOLY8	JUMP,BS POLY$	ADD.W	D1,#2	TEST.B	(A6)+OPOLY:#BPOLY10	JUMP,BS POLY$	TEST.B	(A6)+OPOLY:#BPOLYE	JUMP',BS RAYON$	CALL	CALCRAYON	; D5 <-- rayon	LOAD.W	(A6)+OCERAY,D5RAYON$:	CLR.W	D0	SUB.W	D4,D3		; D4 <-- rx 	JUMP',HS RX$	NEG.W	D4	ADD.W	D0,#2RX$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- ry	JUMP',HS RY$	NEG.W	D4	ADD.W	D0,#4RY$:	SWAP.W	D3	SWAP.W	D4	TEST.L	D0:#2	JUMP',BC OCT$	TNOT.L	D0:#1		; D0 <-- 0,2,4,6 selon cadrantOCT$:	LOAD.W	D1,#B'11000000	; D1 <-- arcs pour 1/4 cercle	TEST.B	(A6)+OARC:#BARC4	JUMP',BS ROT$	LOAD.W	D1,#B'11110000	; D1 <-- arcs pour 1/2 cercle	TEST.B	(A6)+OARC:#BARC2	JUMP',BS ROT$	LOAD.W	D1,#B'11111111	; D1 <-- arcs pour cercle completROT$:	RR.B	D1,D0		; D1 <-- tourne les arcs selon le cadrant	TEST.B	(A6)+OPOLY:#BPOLYE	JUMP',BS ELLI$	LOAD.W	D4,D5		; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- RxELLI$:	LIB	?DRELLIPSE	; dessine un cercle ou une ellipse	JUMP'	END$ARC$:	CALL	ARCQQ		; dessine un arc de cercle	JUMP'	END$POLY$:	CALL	POLYGONE	; dessine le polygone  n cts	JUMP'	END$RECT$:				; rectangle =>	LOAD.W	D0,(A6)+ORRECT	; D0 <-- rayon du rectangle	LOAD.B	D1,(A6)+OTRECT	COMP.B	D2,#INVDOT	; dessin "provisoire" ?	JUMP',NE RDRAW$		; non => RDRAW$	LOAD.B	D1,#2^BRECONT	; D1 <-- dessine seulement le pourtourRDRAW$:	CALL	RRECTTRAM;	JUMP'	END$END$:	TEST.L	D2:#15		; dessine dans la matrice principale ?	JUMP',BS CLOSE$		; oui => CLOSE$	TEST.L	D2:#14		; dessine dans la matrice masque ?	JUMP',BS CLOSE$		; oui => CLOSE$	TEST.L	D2:#13		; dessine directement dans l'cran ?	JUMP',BS EXIT$		; oui => EXIT$				; non =>	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	JUMP'	EXIT$CLOSE$:	CALL	_CLODISMAT	; dessine  nouveau dans l'cranEXIT$:	POPM.L	D0..D6,A3,A4	RET;----------\\; RRECTTRAM >;----------/; Dessine un rectangle tram aux coins arrondis.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D1.B	type (BRExxxx);	D0.W	rayon; out	-; mod	D7.WRRECTTRAM:	PUSHM.L	D0,D5,D6,A4	LOAD.L	D5,D3	LOAD.L	D6,D4	SUB.W	D5,D6	JUMP',NC 10$	NEG.W	D5		; D5 <-- |largeur|10$:	SWAP.W	D5	SWAP.W	D6	SUB.W	D6,D5	JUMP',NC 12$	NEG.W	D6		; D6 <-- |hauteur|12$:	SWAP.W	D5	COMP.W	D5,D6	JUMP',LS 14$	LOAD.W	D5,D6		; D5 <-- MIN(largeur,hauteur)14$:	SR.W	D5,#1		; D5 <-- rayon minimum	SUB.W	D5,#2	COMP.W	D0,D5	JUMP',LE 20$	CLR.W	D0	COMP.W	D5,#3	JUMP',LE 20$	LOAD.W	D0,#3	COMP.W	D5,#4	JUMP',LE 20$	LOAD.W	D0,#4	COMP.W	D5,#8	JUMP',LE 20$	LOAD.W	D0,#8	COMP.W	D5,#12	JUMP',LE 20$	LOAD.W	D0,#12	COMP.W	D5,#16	JUMP',LE 20$	LOAD.W	D0,#1620$:	PUSH.W	D2	TCLR.L	D2:#BTTTDOT	TCLR.L	D2:#BPENDOT	TEST.L	D1:#BRETRAM	JUMP',BC 40$	LOAD.L	A4,#(A6)+OTDEF	LOAD.W	D5,(A6)+ONTDEF	MUL.WU	D5,#8	ADD.L	A4,D5		; A4 <-- ^bonne trame	LOAD.L	D5,(A4)+0	LOAD.L	D6,(A4)+4	; D5/D6 <-- trame	CALL	RTRAME		; trame le rectangle arrondi	TEST.L	D1:#BREOPAQ	JUMP',BC 50$	NOT.L	D5	NOT.L	D6		; D5/D6 <-- trame inverse	CALL	INVMODE		; D2 <-- mode inverse	CALL	RTRAME		; laisse le fond opaque	JUMP'	50$40$:	TEST.L	D1:#BREOPAQ	JUMP',BC 50$	LOAD.L	D5,#-1	LOAD.L	D6,D5		; D5/D6 <-- trame blanche	CALL	INVMODE		; D2 <-- mode inverse	CALL	RTRAME		; laisse le fond opaque50$:	POP.W	D2	TEST.L	D1:#BRECONT	JUMP',BC 90$	CALL	RRECTANGLE	; dessine le rectangle arrondi90$:	POPM.L	D0,D5,D6,A4	RET;--------\\; INVMODE >;--------/; Inverse le mode de dessin.; in	D2.B	mode de dessin; out	D2.B	mode de dessin inverse; mod	D2.B, D7.WINVMODE:	PUSH.W	D3	LOAD.B	D3,#SETDOT	COMP.B	D2,#CLRDOT	JUMP',EQ 80$	LOAD.B	D3,#CLRDOT	COMP.B	D2,#SETDOT	JUMP',EQ 80$	LOAD.B	D3,D280$:	LOAD.B	D2,D3	POP.W	D3	RET;-----------\; RRECTANGLE >;-----------/; Dessine un rectangle aux coins arrondis.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D0.W	rayon; out	-; mod	D7.WRRECTANGLE:	PUSHM.L	D1..D4	EX.L	D1,D3	EX.L	D2,D4	CALL	ORDONNE	EX.L	D3,D1	EX.L	D4,D2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D0		; D1 <-- rayon	LIB	?DRRECTA	; dessine un rectangle arrondi	POPM.L	D1..D4	RET;--------\\; RTRAME  >;--------/; Dessine une trame rectangulaire, ventuellement avec les coins arrondis !; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D0.W	rayon;	D5/D6	trame; out	-; mod	D7.WRTRAME:	PUSHM.L	D1..D4	PUSHM.L	D3,D4	LOAD.L	D3,D5	LOAD.L	D4,D6	COMP.B	D2,#CLRDOT	JUMP',NE 10$	NOT.L	D3	NOT.L	D410$:	LIB	?DRMDEF		; dfinit la trame	POPM.L	D3,D4	EX.L	D1,D3	EX.L	D2,D4	CALL	ORDONNE	EX.L	D3,D1	EX.L	D4,D2	SUB.W	D4,D3	INC.W	D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	INC.W	D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D0		; D1 <-- rayon	LIB	?DRTRAMEA	; dessine une trame arrondie	POPM.L	D1..D4	RET;---------\\; ARCQQ    >;=========/; Dessine un arc de cercle quelconque.; in	D3.L	origine (y;x);	D4.L	arrive (y;x);	D2.B	mode de dessin; out	-; mod	D7.WARCQQ:	PUSHM.L	D1,D4,D5	TEST.W	(A6)+ONARC	JUMP,EQ 90$	CALL	CALCRAYON	; D5 <-- rayon	LOAD.W	(A6)+OCERAY,D5	PUSHM.L	D2,D3	LOAD.L	(A6)+OSEPMI,D3	ADD.W	D3,D5	CALL	XTOURNE		; D2 <-- angle initial	LOAD.W	(A6)+OCEANG,D2	LOAD.W	D1,D2	LOAD.W	D2,(A6)+ONARC	SR.W	D2,#1	SUB.W	D1,D2		; D1 <-- angle de dpart	JUMP',NC 20$	ADD.W	D1,#36020$:	LOAD.W	D2,D1	ADD.W	D2,(A6)+ONARC	; D2 <-- angle d'arrive	SWAP.W	D1	LOAD.W	D1,D2		; D1 <-- angles (a;d)	SWAP.W	D1	POPM.L	D2,D3	LOAD.W	D4,D5		; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- Rx	TEST.B	(A6)+OMCERC:#BMCETRA	JUMP',BS 60$	LIB	?DRARC		; dessine un arc de cercle	JUMP'	90$60$:	LIB	?DRTRANCHE	; dessine un tranche de gteau (miam)90$:	POPM.L	D1,D4,D5	RET;---------\\; POLYGONE >;=========/; Dessine un polygone avec un nombre quelconque de cts.; in	D3.L	origine (y;x);	D4.L	arrive (y;x);	D2.B	mode de dessin;	D1.W	nombre de cts (3..n); out	-; mod	D7.WPOLYGONE:	PUSHM.L	D1,D4,D5	CALL	CALCRAYON	; D5 <-- rayon	LOAD.W	(A6)+OCERAY,D5	PUSHM.L	D2,D3	LOAD.L	(A6)+OSEPMI,D3	ADD.W	D3,D5	CALL	XTOURNE		; D2 <-- angle initial	LOAD.W	(A6)+OCEANG,D2	SWAP.W	D1		; D1 <-- nb de cts	LOAD.W	D1,D2		; D1 <-- angle	POPM.L	D2,D3	LOAD.W	D4,D5		; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- Rx	LIB	?DRPOLYGONE	; dessine un polygone	POPM.L	D1,D4,D5	RET;---------\\; HAZSPRAY >;=========/; Calcule la position et les dimensions d'un point pour le spray.; On calcule alatoirement un angle et une distance depuis le; centre. Avec le mode "rpartition linaire", la distance est; calcule comme suit :;;	           RND[0,RAY]^2;	D = RAY - --------------     avec RAY = DIA/2;	               RAY;; Avec le mode "rpartition moyenne", la distance est calcule; comme suit :;;	D = RND[0,RAY]               avec RAY = DIA/2;; Avec le mode "rpartition centre", la distance est calcule; comme suit :;;	     RND[0,RAY]^2;	D = --------------           avec RAY = DIA/2;	         RAY; in	D3.L	position "centre" (y;x); out	D3.L	position (y;x);	D4.W	dimension (dy=dx); mod	D3.L, D4.L, D7.WHAZSPRAY:	PUSHM.L	D0..D2	LOAD.L	D0,D3		; D0 <-- centre (y;x)	CLR.W	D3	LOAD.W	D4,#360	CALL	_MMHAZARD	; D4 <-- angle (0..360-1)	LOAD.W	D1,D4		; D1 <-- angle	CLR.W	D3	LOAD.W	D4,(A6)+OSPDIA	SR.W	D4,#1	TEST.B	(A6)+OSPFAN+3:#BSPMOY-0	JUMP',BS MOY$	SL.W	D4,#4	LOAD.W	D2,D4	CALL	_MMHAZARD	; D4 <-- distance	MUL.WU	D4,D4	DIV.WU	D4,D2	TEST.B	(A6)+OSPFAN+3:#BSPCENT-0	JUMP',BS CENT$	SUB.W	D4,D2	NEG.W	D4CENT$:	SR.W	D4,#4	JUMP'	DIST$MOY$:	CALL	_MMHAZARD	; D4 <-- distanceDIST$:	LOAD.W	D2,D4		; D2 <-- distance	LOAD.L	D3,D0		; D3 <-- centre	LOAD.L	D4,D0	ADD.W	D4,D2		; D4 <-- point  tourner	LIB	?CALCPSYM	; D4 <-- point tourn	LOAD.L	D0,D4	LOAD.W	D3,#1	LOAD.W	D4,(A6)+OSPDIM	COMP.W	D4,D3	JUMP',EQ DIM$	INC.W	D4	CALL	_MMHAZARD	; D4 <-- largeur dX=dYDIM$:	LOAD.L	D3,D0		; D3 <-- position (y;x)	POPM.L	D0..D2	RET;---------\\; DESSPRAY >;=========/; Dessine un "point" avec le spray, et tenant compte de la trame de remplissage.; in	D3.L	position du centre (y;x);	D4.W	dimension (dy=dx); out	-; mod	D7.WDESSPRAY:	PUSHM.L	D0..D4,A4	LOAD.L	A4,#R16"TABLE$	LOAD.W	D2,D4		; D2 <-- 1..16	DEC.W	D2		; D2 <-- 0..15	JUMP',NS EXIT$	SL.W	D2,#5		; D2 <-- *32	ADD.W	A4,D2		; A4 <-- ^matrice cercle	LOAD.W	D2,D4		; D2 <-- hauteurLOOPY$:	PUSHM.L	D3,D4	LOAD.W	D0,(A4+)	; D0 <-- ligne de 16 points	LOAD.W	D1,#15		; D1 <-- bit de gaucheLOOPX$:	TEST.L	D0:D1	JUMP',BC NEXTX$	CALL	DESSPRAYONE	; dessine juste un pointNEXTX$:	DEC.W	D1		; D1 <-- bit suivant	INC.W	D3		; D3 <-- X suivant	DEC.W	D4	JUMP,NE LOOPX$	POPM.L	D3,D4	SWAP.W	D3	INC.W	D3		; D3 <-- Y suivant	SWAP.W	D3	DEC.W	D2	JUMP,NE LOOPY$EXIT$:	POPM.L	D0..D4,A4	RETTABLE$:					; 1	.W	B'1000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 2	.W	B'1100000000000000	.W	B'1100000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 3	.W	B'1110000000000000	.W	B'1110000000000000	.W	B'1110000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 4	.W	B'0110000000000000	.W	B'1111000000000000	.W	B'1111000000000000	.W	B'0110000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 5	.W	B'0111000000000000	.W	B'1111100000000000	.W	B'1111100000000000	.W	B'1111100000000000	.W	B'0111000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 6	.W	B'0111100000000000	.W	B'1111110000000000	.W	B'1111110000000000	.W	B'1111110000000000	.W	B'1111110000000000	.W	B'0111100000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 7	.W	B'0011100000000000	.W	B'0111110000000000	.W	B'1111111000000000	.W	B'1111111000000000	.W	B'1111111000000000	.W	B'0111110000000000	.W	B'0011100000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 8	.W	B'0011110000000000	.W	B'0111111000000000	.W	B'1111111100000000	.W	B'1111111100000000	.W	B'1111111100000000	.W	B'1111111100000000	.W	B'0111111000000000	.W	B'0011110000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 9	.W	B'0011111000000000	.W	B'0111111100000000	.W	B'1111111110000000	.W	B'1111111110000000	.W	B'1111111110000000	.W	B'1111111110000000	.W	B'1111111110000000	.W	B'0111111100000000	.W	B'0011111000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 10	.W	B'0001111000000000	.W	B'0111111110000000	.W	B'0111111110000000	.W	B'1111111111000000	.W	B'1111111111000000	.W	B'1111111111000000	.W	B'1111111111000000	.W	B'0111111110000000	.W	B'0111111110000000	.W	B'0001111000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 11	.W	B'0001111100000000	.W	B'0111111111000000	.W	B'0111111111000000	.W	B'1111111111100000	.W	B'1111111111100000	.W	B'1111111111100000	.W	B'1111111111100000	.W	B'1111111111100000	.W	B'0111111111000000	.W	B'0111111111000000	.W	B'0001111100000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 12	.W	B'0000111100000000	.W	B'0011111111000000	.W	B'0111111111100000	.W	B'0111111111100000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'0111111111100000	.W	B'0111111111100000	.W	B'0011111111000000	.W	B'0000111100000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 13	.W	B'0000111110000000	.W	B'0111111111100000	.W	B'0111111111110000	.W	B'0111111111110000	.W	B'1111111111111000	.W	B'1111111111111000	.W	B'1111111111111000	.W	B'1111111111111000	.W	B'1111111111111000	.W	B'0111111111110000	.W	B'0111111111110000	.W	B'0011111111100000	.W	B'0000111110000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 14	.W	B'0000011110000000	.W	B'0001111111100000	.W	B'0011111111110000	.W	B'0111111111111000	.W	B'0111111111111000	.W	B'1111111111111100	.W	B'1111111111111100	.W	B'1111111111111100	.W	B'1111111111111100	.W	B'0111111111111000	.W	B'0111111111111000	.W	B'0011111111110000	.W	B'0001111111100000	.W	B'0000011110000000	.W	B'0000000000000000	.W	B'0000000000000000					; 15	.W	B'0000011111000000	.W	B'0001111111110000	.W	B'0011111111111000	.W	B'0111111111111100	.W	B'0111111111111100	.W	B'1111111111111110	.W	B'1111111111111110	.W	B'1111111111111110	.W	B'1111111111111110	.W	B'1111111111111110	.W	B'0111111111111100	.W	B'0111111111111100	.W	B'0011111111111000	.W	B'0001111111110000	.W	B'0000011111000000	.W	B'0000000000000000					; 16	.W	B'0000011111100000	.W	B'0001111111111000	.W	B'0011111111111100	.W	B'0111111111111110	.W	B'0111111111111110	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'0111111111111110	.W	B'0111111111111110	.W	B'0011111111111100	.W	B'0001111111111000	.W	B'0000011111100000;------------\\; DESSPRAYONE >;------------/; Dessine un "point" avec le spray, et tenant compte de la trame de remplissage.; ATTENTION: Routine optimise ne fonctionnant qu'avec 4 bits/pixel !!!; in	D3.L	position du centre (y;x); out	-; mod	D7.WDESSPRAYONE:	PUSHM.L	D0..D2,D4,A1	LOAD.L	D0,(A6)+OSPFAN	; D0 <-- fanions	LOAD.L	A1,#R16"BLACK$	; A1 <-- ^trame noire	TEST.L	D0:#BSPTRAM	;  travers la trame ?	JUMP',BC TRAME$		; non => TRAME$	LOAD.L	A1,#(A6)+OTDEF	LOAD.W	D1,(A6)+ONTDEF	SL.W	D1,#3		; D1 <-- *8	ADD.W	A1,D1		; A1 <-- ^trame de remplissageTRAME$:	COMP.W	D3,(A6)+OMALMX	; dpasse  droite ?	JUMP,HS EXIT$		; oui => EXIT$	LOAD.L	D1,D3	SWAP.W	D1	COMP.W	D1,(A6)+OMALMY	; dpasse en bas ?	JUMP,HS EXIT$		; oui => EXIT$	AND.W	D1,#B'111	ADD.W	A1,D1		; A1 <-- ^bonne ligne trame remplissage	TEST.B	(A1):D3		; point  dessiner selon trame remplissage ?	JUMP,BC EXIT$		; non => EXIT$	LOAD.L	D1,(A0)+ODFCSF	; D1 <-- couleur pour le point	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice	LOAD.L	D2,D3	SWAP.W	D2		; D2 <-- position en Y	MUL.WU	D2,(A6)+OMANBB	MUL.WU	D2,(A6)+OMANBP	ADD.L	A1,D2		; A1 <-- ^dbut bonne ligne dans matrice	LOAD.W	D4,D3	SR.W	D4,#1	JUMP',CS SET$CLR$:	LOAD.B	D2,(A1)+(D4.W)	SR.B	D2,#4	COMP.B	D2,D1		; dj la bonne couleur ?	JUMP',EQ EXIT$		; oui => EXIT$	TEST.L	D0:#BSPCALL	JUMP',BS CPUT$	TEST.L	D0:#BSPCNOT	JUMP',BS CNOT$CONE$:	COMP.B	D2,(A6)+OSPCOL+3	JUMP,NE EXIT$	JUMP'	CPUT$CNOT$:	COMP.B	D2,(A6)+OSPCOL+3	JUMP,EQ EXIT$CPUT$:	LOAD.B	D2,(A1)+(D4.W)	SL.B	D2,#4	OR.B	D2,D1	RR.B	D2,#4	LOAD.B	(A1)+(D4.W),D2	JUMP'	DRAW$SET$:	LOAD.B	D2,(A1)+(D4.W)	AND.B	D2,#B'00001111	COMP.B	D2,D1		; dj la bonne couleur ?	JUMP',EQ EXIT$		; oui => EXIT$	TEST.L	D0:#BSPCALL	JUMP',BS SPUT$	TEST.L	D0:#BSPCNOT	JUMP',BS SNOT$SONE$:	COMP.B	D2,(A6)+OSPCOL+3	JUMP',NE EXIT$	JUMP'	SPUT$SNOT$:	COMP.B	D2,(A6)+OSPCOL+3	JUMP',EQ EXIT$SPUT$:	LOAD.B	D2,(A1)+(D4.W)	AND.B	D2,#B'11110000	OR.B	D2,D1	LOAD.B	(A1)+(D4.W),D2;	JUMP'	DRAW$DRAW$:	TEST.W	(A6)+OSCALE	; test dans la dbox ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE SCALE$	CALL	DESGPOINT	; dessine point dans grande matriceSCALE$:	CALL	DESPPOINT	; dessine point dans petite matriceEXIT$:	POPM.L	D0..D2,D4,A1	RETBLACK$:	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.EVEN;----------\\; DESEPONGE >;==========/; Dessine un "point" avec l'ponge.; in	D3.L	dpart  (y;x);	D4.L	arrive (y;x); out	-; mod	D7.WDESEPONGE:	PUSHM.L	D1..D5	CALL	CALEPONGE	; calcule si ncessaire	JUMP,NE EXIT$	LOAD.W	D1,(A6)+OEPDIA	SR.W	D1,#1		; D1 <-- diamtre/2	DEC.W	D1	SUB.W	D4,D3		; D4 <-- largeur	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur	SWAP.W	D3	SWAP.W	D4	LOAD.L	D2,D3		; D2 <-- dpart	LOAD.L	D3,D4	SWAP.W	D3	TEST.W	D3	JUMP',NC DY$	NEG.W	D3		; D3 <-- |hauteur|DY$:	LOAD.W	D5,D4	JUMP',NC DX$	NEG.W	D5		; D5 <-- |largeur|DX$:	COMP.W	D5,D3	JUMP',LO VERT$HORIZ$:	TEST.W	D4	JUMP,EQ ONE$	JUMP',NS HG$	JUMP'	HD$VERT$:	LOAD.L	D3,D4	SWAP.W	D3	TEST.W	D3	JUMP,EQ ONE$	JUMP,NS VH$	JUMP	VB$HD$:	CLR.W	D5HDLOOP$:	LOAD.L	D3,D4	SWAP.W	D3	MUL.WA	D3,D5	DIV.WA	D3,D4	SWAP.W	D2	ADD.W	D3,D2	SWAP.W	D2	SWAP.W	D3	LOAD.W	D3,D5	ADD.W	D3,D2	CALL	DESEPONGEONE	; dessine un "point"	ADD.W	D5,D1	COMP.W	D5,D4	JUMP,LT HDLOOP$	JUMP	EXIT$HG$:	CLR.W	D5HGLOOP$:	LOAD.L	D3,D4	SWAP.W	D3	MUL.WA	D3,D5	DIV.WA	D3,D4	SWAP.W	D2	ADD.W	D3,D2	SWAP.W	D2	SWAP.W	D3	LOAD.W	D3,D5	ADD.W	D3,D2	CALL	DESEPONGEONE	; dessine un "point"	SUB.W	D5,D1	COMP.W	D5,D4	JUMP,GT HGLOOP$	JUMP	EXIT$VB$:	CLR.W	D5VBLOOP$:	LOAD.W	D3,D4	MUL.WA	D3,D5	SWAP.W	D4	DIV.WA	D3,D4	SWAP.W	D4	ADD.W	D3,D2	SWAP.W	D3	LOAD.W	D3,D5	SWAP.W	D2	ADD.W	D3,D2	SWAP.W	D2	SWAP.W	D3	CALL	DESEPONGEONE	; dessine un "point"	ADD.W	D5,D1	LOAD.L	D3,D4	SWAP.W	D3	COMP.W	D5,D3	JUMP,LT VBLOOP$	JUMP'	EXIT$VH$:	CLR.W	D5VHLOOP$:	LOAD.W	D3,D4	MUL.WA	D3,D5	SWAP.W	D4	DIV.WA	D3,D4	SWAP.W	D4	ADD.W	D3,D2	SWAP.W	D3	LOAD.W	D3,D5	SWAP.W	D2	ADD.W	D3,D2	SWAP.W	D2	SWAP.W	D3	CALL	DESEPONGEONE	; dessine un "point"	SUB.W	D5,D1	LOAD.L	D3,D4	SWAP.W	D3	COMP.W	D5,D3	JUMP,GT VHLOOP$	JUMP'	EXIT$ONE$:	LOAD.L	D3,D2	CALL	DESEPONGEONE	; dessine un "point"EXIT$:	POPM.L	D1..D5	RET;-------------\\; DESEPONGEONE >;-------------/; Dessine un "point" alatoire avec l'ponge.; in	D3.L	centre (y;x); out	-; mod	D7.WDESEPONGEONE:	PUSHM.L	D2..D5,A3	PUSH.L	(A6)+OSPFAN	PUSH.L	(A6)+OSPCOL	LOAD.L	(A6)+OSPFAN,(A6)+OEPFAN	LOAD.L	(A6)+OSPCOL,(A6)+OEPCOL	TCLR.B	(A6)+OSPFAN+1:#BSPTRAM-16	PUSH.L	D3	LOAD.L	A3,(A6)+OEPPMA	; A3 <-- ^matrices	CLR.W	D3	LOAD.W	D4,#NBEPONGE	CALL	_MMHAZARD	; D4 <-- 0..9	LOAD.W	D3,(A6)+OEPDIA	ADD.W	D3,#8-1	SR.W	D3,#3	MUL.WU	D3,(A6)+OEPDIA	MUL.WU	D3,D4	ADD.L	A3,D3		; A3 <-- ^matrice	POP.L	D3	LOAD.W	D4,(A6)+OEPDIA	SR.W	D4,#1	SUB.W	D3,D4	SWAP.W	D3	SUB.W	D3,D4	SWAP.W	D3	LOAD.W	D4,(A6)+OEPDIALOOPY$:	PUSHM.L	D3,D4	LOAD.W	D5,(A6)+OEPDIA	ADD.W	D5,#8-1	SR.W	D5,#3		; D5 <-- largeur en bytesLOOPB$:	LOAD.B	D2,(A3+)	LOAD.W	D4,#8-1LOOPX$:	SL.B	D2,#1		; point  dessiner selon matrice spray ?	JUMP',CC NEXTX$		; non => NEXTX$				; oui =>	CALL	DESSPRAYONE	; dessine un pointNEXTX$:	INC.W	D3		; D3 <-- avance en X	DECJ.W,NMO D4,LOOPX$	DEC.W	D5	JUMP,NE LOOPB$	POPM.L	D3,D4	SWAP.W	D3	INC.W	D3		; D3 <-- avance en Y	SWAP.W	D3	DEC.W	D4	JUMP,NE LOOPY$	POP.L	(A6)+OSPCOL	POP.L	(A6)+OSPFAN	POPM.L	D2..D5,A3	RET;----------\\; CALEPONGE >;==========/; Calcule si ncessaire les matrices pour l'ponge.; in	-; out	D7.W	erreur; mod	D7.WCALEPONGE:	PUSHM.L	D0..D5,A3,A4	TEST.L	(A6)+OEPPMA	; matrices existent ?	JUMP',EQ MODIF$		; non => MODIF$	LOAD.L	D4,(A6)+OEPFAN	COMP.L	D4,(A6)+OEPLSF	JUMP',NE MODIF$	LOAD.W	D4,(A6)+OEPDIA	COMP.W	D4,(A6)+OEPLSD	JUMP',NE MODIF$	LOAD.W	D4,(A6)+OEPINT	COMP.W	D4,(A6)+OEPLSI	JUMP,EQ OK$MODIF$:	CALL	KILEPONGE	; libre les matrices prcdentes	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.W	D4,(A6)+OEPDIA	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.W	D2,D4		; D2 <-- Iy d'une matrice	MUL.WU	D4,(A6)+OEPDIA	LOAD.L	D0,D4		; D0 <-- lg d'une matrice	MUL.WU	D4,#NBEPONGE	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour matrices	JUMP,NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	(A6)+OEPPMA,A4	PUSH.L	(A6)+OSPFAN	PUSH.W	(A6)+OSPDIA	LOAD.L	(A6)+OSPFAN,(A6)+OEPFAN	LOAD.W	(A6)+OSPDIA,(A6)+OEPDIA	LOAD.W	D1,#NBEPONGE-1MLOOP$:	LOAD.W	D5,(A6)+OEPDIA	MUL.WU	D5,D5		; D5 <-- surface	MUL.WU	D5,(A6)+OEPINT	; D5 <-- multiplie par l'intensit (1..10)	DIV.WU	D5,#10DLOOP$:	LOAD.W	D4,(A6)+OEPDIA	SR.W	D4,#1		; D4 <-- rayon	LOAD.W	D3,D4	SWAP.W	D3	LOAD.W	D3,D4	CALL	HAZSPRAY	; D3/D4 <-- position/dimensions	LOAD.L	A3,A4		; A3 <-- ^matrice	LOAD.L	D4,D3	SWAP.W	D4	COMP.W	D4,(A6)+OEPDIA	JUMP',HS DNEXT$	MUL.WU	D4,D2	ADD.L	A3,D4		; A3 <-- ^matrice selon Y	LOAD.W	D4,D3	COMP.W	D4,(A6)+OEPDIA	JUMP',HS DNEXT$	SR.W	D4,#3		; D4 <-- dplacement selon X	AND.B	D3,#B'111	SUB.B	D3,#8-1	NEG.B	D3		; D3 <-- numro du bit (7..0)	TSET.B	(A3)+(D4.W):D3	; met un point dans une matriceDNEXT$:	DECJ.W,NMO D5,DLOOP$	ADD.L	A4,D0		; A4 <-- ^matrice suivante	DECJ.W,NMO D1,MLOOP$	POP.W	(A6)+OSPDIA	POP.L	(A6)+OSPFANOK$:	LOAD.L	(A6)+OEPLSF,(A6)+OEPFAN	LOAD.W	(A6)+OEPLSD,(A6)+OEPDIA	LOAD.W	(A6)+OEPLSI,(A6)+OEPINT	CLR.W	D7		; D7 <-- okEXIT$:	CALL	_NORMMOUSE	; souris: enlve le sablier	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; KILEPONGE >;==========/; Supprime les matrices pour l'ponge.; in	-; out	-; mod	D7.WKILEPONGE:	PUSHM.L	D1,A4	TEST.L	(A6)+OEPPMA	JUMP',EQ EXIT$	LOAD.L	A4,(A6)+OEPPMA	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OEPPMAEXIT$:	POPM.L	D1,A4	RET;---------\\; DESFILET >;=========/; Essaye de remplir le filet dans la matrice masque.; in	D1.L	coin sup/gauche;	D2.L	coin inf/droite; out	D7.W	erreur; mod	D7.WDESFILET:	PUSHM.L	D2..D4,A3,A4	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.L	(A0)+ODFCSF,#NBCOUL-1	CLR.L	(A0)+ODFCCF	LOAD.L	D4,#-1	CALL	_DRMDEF		; dfinit une trame pleine	LOAD.L	A4,(A6)+OPMAM	CALL	_OPEDISMAT	; dessine dans la matrice copie	LOAD.L	D3,D1	LOAD.L	D4,D2	TEST.W	D3	JUMP',EQ DX$	DEC.W	D3DX$:	AND.B	D3,#B'11111000	ADD.W	D4,#8-1+1	AND.B	D4,#B'11111000	COMP.W	D4,(A6)+OMALMX	JUMP',LS FX$	LOAD.W	D4,(A6)+OMALMXFX$:	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	TEST.W	D3	JUMP',EQ DY$	DEC.W	D3DY$:	AND.B	D3,#B'11111110	ADD.W	D4,#2-1+1	AND.B	D4,#B'11111110	COMP.W	D4,(A6)+OMALMY	JUMP',LS FY$	LOAD.W	D4,(A6)+OMALMYFY$:	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A0)+ODFFY,D3	LOAD.L	(A0)+ODFWBY,D3	LOAD.L	(A0)+ODFFDY,D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3;	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A0)+ODFWEY,D4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3)+0,#AFFILLA	LOAD.B	(A3)+1,#DRAWFILLO	CLR.L	(A3)+2	LOAD.B	(A3)+6,#DRAWFILLC	LOAD.W	D3,#1+5+1	LIB	?STRING		; rempli ...	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	CALL	_CLODISMAT	; redessine dans l'cran	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D2..D4,A3,A4	CLR.W	D7		; retour EQ	RET;--------\\; DEGDRAW >;========/; Dessine provisoirement avec le bidon.; in	D3.L	dpart  (y;x);	D4.L	arrive (y;x); out	-; mod	D7.WDEGDRAW:	PUSHM.L	D2..D5	LOAD.W	D5,(A6)+OPWDO	LIB	?USEWDO		; utilise swdo autour de la petite matrice	TEST.W	(A6)+OSCALE	JUMP',NS LITTLE$	SUB.W	D3,(A6)+OPMOVX	SWAP.W	D3	SUB.W	D3,(A6)+OPMOVY	SWAP.W	D3	SUB.W	D4,(A6)+OPMOVX	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	SWAP.W	D4	JUMP'	COOR$LITTLE$:	CALL	CONVGPOINT	SUB.W	D3,(A6)+OGMPOX	SWAP.W	D3	SUB.W	D3,(A6)+OGMPOY	SWAP.W	D3	EX.L	D3,D4	CALL	CONVGPOINT	SUB.W	D3,(A6)+OGMPOX	SWAP.W	D3	SUB.W	D3,(A6)+OGMPOY	SWAP.W	D3	EX.L	D3,D4COOR$:	TEST.B	(A6)+OBIFAN+1:#BBICIRC-16	JUMP',BS CIRC$	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRSEG		; dessine une droite	JUMP'	EXIT$CIRC$:	LOAD.L	D2,D3	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LIB	?CALCHYPO	; D4 <-- distance	LOAD.L	D3,D2	LOAD.W	D2,#INVDOT	LIB	?DRCERCLE	; dessine un cercleEXIT$:	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	POPM.L	D2..D5	RET;--------\\; DEGMEMP >;========/; Mmorise les paramtres, seulement si l'arrive n'est pas; superpose avec le dpart.; in	D3.L	dpart  (y;x);	D4.L	arrive (y;x); out	-; mod	D7.WDEGMEMP:	PUSHM.L	D1..D5	LOAD.L	D5,D4	SUB.W	D5,D3	JUMP',NC MINX$	NEG.W	D5		; D5 <-- |dx|MINX$:	COMP.W	D5,#2	JUMP',HI MEM$	SWAP.W	D3	SWAP.W	D5	SUB.W	D5,D3	JUMP',NC MINY$	NEG.W	D5		; D5 <-- |dy|MINY$:	COMP.W	D5,#2	JUMP',LS INIT$	SWAP.W	D3;	SWAP.W	D5MEM$:	LOAD.L	(A6)+OBIP1,D3	LOAD.L	(A6)+OBIP2,D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LIB	?CALCHYPO	; D4 <-- distance	TEST.W	D4	JUMP',NE LG$	INC.W	D4		; D4 <-- jamais zro !LG$:	LOAD.W	(A6)+OBILG,D4	LOAD.L	D3,(A6)+OBIP1	LOAD.L	D4,D3	ADD.W	D4,(A6)+OBILG	LOAD.L	D5,(A6)+OBIP2	LIB	?CALCANGLE	; D2 <-- angle	LOAD.W	(A6)+OBIANG,D2INIT$:	LOAD.L	D3,(A6)+OBIP1	LOAD.L	D4,D3	ADD.W	D4,(A6)+OBILG	LOAD.W	D1,#360	SUB.W	D1,(A6)+OBIANG	LIB	?CALCPSYM	; D4 <-- P' tourn	LOAD.L	(A6)+OBIP2,D4	CLR.W	(A6)+OBIDEL	LOAD.W	D3,(A6)+OBIP2+2	SUB.W	D3,(A6)+OBIP1+2	; D3 <-- Ax	LOAD.W	D4,(A6)+OBIP2+0	SUB.W	D4,(A6)+OBIP1+0	; D4 <-- Ay	LOAD.W	D1,D3	JUMP',NC LGX$	NEG.W	D1		; D1 <-- |Ax|LGX$:	LOAD.W	D2,D4	JUMP',NC LGY$	NEG.W	D2		; D2 <-- |Ay|LGY$:	COMP.W	D1,D2	JUMP',LS DIV$	EX.L	D3,D4		; X <--> Y	INC.W	(A6)+OBIDELDIV$:	LOAD.W	D2,D3	MUL.WA	D2,D2	DIV.WA	D2,D4	ADD.W	D2,D4		; D2 <-- Ax^2/Ay + Ay	LOAD.W	(A6)+OBIDIV,D2	POPM.L	D1..D5	RET;--------\\; DEGFILL >;========/; Rempli avec un joli dgrad.; in	A3.L	^liste des lignes; out	-; mod	D7.WDEGFILL:	PUSHM.L	D0..D6,A1,A3,A4	LOAD.L	A4,#(A6)+OBICOL	; A4 <-- ^liste des couleursLLOOP$:	LOAD.L	A3,#(A3)+LGRAF	; A3 <-- ^ligne suivante	COMP.W	(A3),#-1	; fin de la liste ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.L	D5,(A3)+OGRAFY	LOAD.W	D6,(A3)+OGRAFXFDLOOP$:	CALL'	DEGFILLDOT	; met un point	INC.W	D5	COMP.W	D5,D6	JUMP,LS DLOOP$	JUMP	LLOOP$EXIT$:	POPM.L	D0..D6,A1,A3,A4	RET;-----------\\; DEGFILLDOT >;-----------/; Met un point dans la matrice principale en fonction du dgrad.; ATTENTION: Routine optimise ne fonctionnant qu'avec 4 bits/pixel !!!; Les dgrads linaires sont calculs comme suit :;;	Ax = P2x-P1x  et  Ay = P2y-P1y;	Px = P'x-P1x  et  Py = P'y-P1y;;	            Ax^2;	DIV = Ay + ------;	             Ay;;	     Ax*Px + Ay*Py;	y = ---------------;	          DIV;;	distance = y;	longueur = Ay; in	D5.L	coordonne (y;x);	A4.L	^liste des couleurs; out	-; mod	D0..D4.L, D7.W, A1.LDEGFILLDOT:	LOAD.L	D0,D5	LOAD.L	D3,D5	SUB.W	D3,(A6)+OBIP1+2	SWAP.W	D3	SUB.W	D3,(A6)+OBIP1+0	SWAP.W	D3	TEST.B	(A6)+OBIFAN+1:#BBICIRC-16	JUMP,BS CIRC$	LOAD.L	D4,(A6)+OBIP2	SUB.W	D4,(A6)+OBIP1+2	SWAP.W	D4	SUB.W	D4,(A6)+OBIP1+0	SWAP.W	D4	TEST.W	(A6)+OBIDEL	; |dx| < |dy|  ?	JUMP',EQ LGO$		; oui => LGO$	SWAP.W	D3	SWAP.W	D4		; X <--> YLGO$:	LOAD.W	D1,D4	MUL.WA	D1,D3		; D1 <-- Ax*Px	LOAD.L	D2,D4	SWAP.W	D2	SWAP.W	D3	MUL.WA	D2,D3		; D2 <-- Ay*Py	SWAP.W	D3	ADD.L	D1,D2		; D1 <-- Ax*Px + Ay*Py	DIV.WA	D1,(A6)+OBIDIV	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- longueur	LOAD.W	D4,D1		; D4 <-- distance	TEST.W	D3	JUMP',NC RAPPORT$	NEG.W	D3	NEG.W	D4	JUMP'	RAPPORT$CIRC$:	LIB	?CALCHYPO	; D4 <-- distance	LOAD.W	D3,(A6)+OBILG	; D3 <-- longueurRAPPORT$:	LOAD.W	D2,(A6)+OBINBC	SL.W	D2,#4	SUB.W	D2,#16-1	; D2 <-- (NBC*16)-15	MUL.WA	D4,D2	DIV.WA	D4,D3		; D4 <-- position (0..n)	TEST.W	D4	JUMP',NC MIN$	CLR.W	D4MIN$:	COMP.W	D4,D2	JUMP',LO MAX$	LOAD.W	D4,D2	DEC.W	D4MAX$:	LOAD.W	D3,D4	SR.W	D4,#4	AND.W	D3,#B'1111	; D3 <-- 0..15	DEC.W	D3	JUMP',NS COLOR$	LOAD.L	A1,#R16"TRAMES$	SL.W	D3,#2	ADD.W	A1,D3		; A1 <-- ^trame	LOAD.L	D3,D0	SWAP.W	D3	AND.W	D3,#B'11	; D3 <-- Y (0..3)	TEST.B	(A1)+(D3.W):D0	JUMP',BC COLOR$	INC.W	D4COLOR$:;	CLR.L	D1	LOAD.B	D1,(A4)+(D4.W)	; D1 <-- couleur	LOAD.L	D3,D0	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	LOAD.L	D4,D3		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	MUL.WU	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMANBP	ADD.L	A1,D4	SR.W	D3,#1		; ATTENTION: seulement si OMANBP=4 <<<<<<<<<<<<<<<<<<<<	JUMP',CS SET$CLR$:	SL.B	D1,#4	AND.B	(A1)+(D3.W),#B'00001111	OR.B	(A1)+(D3.W),D1	JUMP'	EXIT$SET$:	AND.B	D1,#B'00001111	AND.B	(A1)+(D3.W),#B'11110000	OR.B	(A1)+(D3.W),D1;	JUMP'	EXIT$EXIT$:	RETTRAMES$:	.B	B'10000000	; 2	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'10001000	; 4	.B	B'00000000	.B	B'00100010	.B	B'00000000	.B	B'10001000	; 4	.B	B'00000000	.B	B'00100010	.B	B'00000000	.B	B'10001000	; 8	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'10001000	; 8	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'10001000	; 8	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'11001100	; 16	.B	B'00110011	.B	B'11001100	.B	B'00110011	.B	B'11001100	; 16	.B	B'00110011	.B	B'11001100	.B	B'00110011	.B	B'11001100	; 16	.B	B'00110011	.B	B'11001100	.B	B'00110011	.B	B'11011101	; 24	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101	; 24	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101	; 24	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11111111	; 28	.B	B'01110111	.B	B'11111111	.B	B'11011101	.B	B'11111111	; 28	.B	B'01110111	.B	B'11111111	.B	B'11011101	.B	B'11111111	; 30	.B	B'01111111	.B	B'11111111	.B	B'11110111	.EVEN.IF 0;---------\\; DEGCOLOR >;---------/; Cherche une couleur situe quelque part (0..32) entre; les couleurs de "set" et de "clear".; in	D4.W	position (0..32); out	D1.L	couleur; mod	D1.L, D7.WDEGCOLOR:	PUSHM.L	D0,D2..D4,D6,A3,A4	LOAD.W	D2,D4	COMP.W	D2,#32	JUMP',LS MAX$	LOAD.W	D2,#32		; D2 <-- 0..32MAX$:	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal pour TCOLOR	LOAD.L	A3,#(A6)+OBUDIS+10	LOAD.L	D3,#2^BTCFORCE!2^BTCGIVE	LOAD.L	D4,(A6)+OCSET	TCOL_	SRCCLUT		; OBUDIS+10 <-- couleur set	LOAD.L	A3,#(A6)+OBUDIS+20	LOAD.L	D3,#2^BTCFORCE!2^BTCGIVE	LOAD.L	D4,(A6)+OCCLR	TCOL_	SRCCLUT		; OBUDIS+20 <-- couleur clear	LOAD.W	D3,(A6)+OBUDIS+10+0	LOAD.W	D4,(A6)+OBUDIS+20+0	SR.W	D3,#8	SR.W	D4,#8	SUB.W	D4,D3	MUL.WA	D4,D2	DIV.WA	D4,#32	ADD.W	D4,D3	LOAD.B	(A6)+OBUDIS+0+0,D4	LOAD.B	(A6)+OBUDIS+0+1,D4	LOAD.W	D3,(A6)+OBUDIS+10+2	LOAD.W	D4,(A6)+OBUDIS+20+2	SR.W	D3,#8	SR.W	D4,#8	SUB.W	D4,D3	MUL.WA	D4,D2	DIV.WA	D4,#32	ADD.W	D4,D3	LOAD.B	(A6)+OBUDIS+0+2,D4	LOAD.B	(A6)+OBUDIS+0+3,D4	LOAD.W	D3,(A6)+OBUDIS+10+4	LOAD.W	D4,(A6)+OBUDIS+20+4	SR.W	D3,#8	SR.W	D4,#8	SUB.W	D4,D3	MUL.WA	D4,D2	DIV.WA	D4,#32	ADD.W	D4,D3	LOAD.B	(A6)+OBUDIS+0+4,D4	LOAD.B	(A6)+OBUDIS+0+5,D4	LOAD.L	A4,#(A6)+OBUDIS+0	CLR.L	D3	TCOL_	SRCCLUT		; D4 <-- couleur	LOAD.L	D1,D4	POPM.L	D0,D2..D4,D6,A3,A4	RET.ENDIF	.END