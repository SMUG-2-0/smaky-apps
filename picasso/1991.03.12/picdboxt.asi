	.SBTTL	PICDBOXT.ASI;---------\\; DBOXOPEN >;---------/; Ouvre une dbox.; in	A2.L	table;	D2.W	mode; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WDBOXOPEN:	PUSH.L	D3	CALL	DBOXOPEN1	CALL	DBOXPOS3	; D3 <-- centre de la dbox	DBOX_	OPEN		; ouvre la dbox	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETDBOXOPEN1:	PUSH.W	D3	CALL	ERGMOUSE	; efface les flches dans les rgles	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	POP.W	D3	RET;----------\\; DBOXCLOSE >;----------/; Ferme une dbox.; in	D5.L	canal; out	D7.W	erreur; mod	D7.WDBOXCLOSE:	DBOX_	CLOSE		; ferme la dboxDBOXCLOSE1:	CALL	AFMENU		; refait les soft-keys	RET;---------\\; DBOXPOS5 >;---------/; Centre ventuellement les dbox selon les icnes de gauche.; in	D2.W	mode d'ouverture; out	D2.W	mode d'ouverture;	D5.L	position (y;x); mod	D2.L, D5.L, D7.WDBOXPOS5:	PUSH.L	D3	CALL	DBOXPOS3	LOAD.L	D5,D3	POP.L	D3	RET;---------\\; DBOXPOS3 >;---------/; Centre ventuellement les dbox selon les icnes de gauche.; in	D2.W	mode d'ouverture; out	D2.W	mode d'ouverture;	D3.L	position (y;x); mod	D2.L, D3.L, D7.WDBOXPOS3:	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC EXIT$		; non => EXIT$				; oui =>	LOAD.W	D3,(A6)+ODICO+0	ADD.W	D3,#ICOLY/2	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#1	TSET.L	D2:#BDBPOS	; D2 <-- centre selon D3.LEXIT$:	RET;--------\\; DBOXRSK >;========/; Refait les soft-keys.; in	A2.L	^table DBOX; out	-; mod	-DBOXRSK:	PUSHM.L	D3,D7,A3	LOAD.W	D3,(A2)+2	LOAD.L	A3,#(A2)+(D3.W)	LIB	?AFMENU		; refait les soft-keys	POPM.L	D3,D7,A3	RET;-----------\\; DBOXZEROCR >;===========/; Remplace le terminateur <CR> par <0>.; Utile aprs DBOX_EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-DBOXZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ EXIT$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>EXIT$:	POP.L	A3	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXAFCOL >;==========/; Affiche la couleur.; in	D2.W	rang;	D4.L	couleur; out	-; mod	D7.WDBOXAFCOL:	PUSHM.L	D2..D4	PUSH.L	(A0)+ODFCSF	LOAD.L	(A0)+ODFCSF,D4	LOAD.L	D4,#-1	CALL	DRMDEF	DBOX_	GETCO	SUB.W	D3,#3	ADD.W	D4,#4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,#5	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#2	SUB.W	D4,D3	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; dessine la couleur	POP.L	(A0)+ODFCSF	POPM.L	D2..D4	RET;----------\\; DBOXMEMPT >;==========/; Donne le ^ la table de la dbox.; in	A2.L	^table de la dbox; out	-; mod	D7.WDBOXMEMPT:	LOAD.L	(A6)+ODBPTE,A2	; ODBPTE <-- ^table dbox	RET;----------\\; DBOXMEDIT >;==========/; Donne la bonne valeur  DBOX_MEDIT.; in	D2.W	rang (0..n);	D5.L	canal dbox; out	-; mod	D7.WDBOXMEDIT:	PUSHM.L	D2,D3,A2	LOAD.W	D3,D2	COMP.W	D3,#-1	JUMP',EQ 50$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D3,(A2)+ODBRED50$:	DBOX_	MEDIT	POPM.L	D2,D3,A2	RET;---------\\; DBOXCLIC >;=========/; Incrmente v. un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox; out	D2.W	rang (0..n);	A3.L	^dbut ligne;	A4.L	^curseur dans ligne; mod	D2.L, D7.W, A3.L, A4.LDBOXCLIC:	PUSHM.L	D0,D1,D3,D4,A0,A2	PUSH.W	D2	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	CALL	DBOXPUT		; mj. paramtre ditable	JUMP,NE ERROR$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE ERROR$	SUB.W	D4,(A0)+ODFFX	JUMP,LO ERROR$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP,LO ERROR$	SWAP.W	D4	LOAD.L	D1,D4		; D1 <-- position de la souris	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	CLR.W	D0		; D0 <-- rangLOOP$:	COMP.W	(A2),#-1	JUMP,EQ ERROR$	TEST.W	(A2)+ODBINC	JUMP',EQ NEXT2$	LOAD.W	D2,(A2)+ODBRGC	DBOX_	GETCO	ADD.W	D4,(A0)+ODFCX	ADD.W	D4,#6	COMP.W	D1,D4	JUMP',LO NEXT2$	ADD.W	D4,#12+4	COMP.W	D1,D4	JUMP',HS NEXT2$	SWAP.W	D1	SWAP.W	D4	SUB.W	D4,#6+12	COMP.W	D1,D4	JUMP',LO NEXT1$	ADD.W	D4,#12	COMP.W	D1,D4	JUMP',LO INC$	ADD.W	D4,#12	COMP.W	D1,D4	JUMP',LO DEC$NEXT1$:	SWAP.W	D1NEXT2$:	LOAD.L	A2,#(A2)+LDB	; A2 <-- ^suivant	INC.W	D0		; D0 <-- rang suivant	JUMP	LOOP$INC$:	LOAD.W	D1,(A2)+ODBINC	; D1 <-- +incrment	JUMP'	MOD$DEC$:	LOAD.W	D1,(A2)+ODBINC	NEG.W	D1		; D1 <-- -incrment;	JUMP'	MOD$MOD$:	PUSH.L	D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	POP.L	D3	SUB.W	D3,#12	SWAP.W	D3	SUB.W	D3,#12+1+4	LOAD.L	D4,#H'10000*13+15	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; allume +/-	PUSHM.L	D3,D4	CALL	DBOXCLICINC	; incrmente le paramtre	LOAD.W	D2,#20		; D2 <-- premier dlaiMLOOP$:	LOAD.W	D4,D2	NTREL	?SETTIM	LIB	?GETCAR		; attend souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP',EQ MEND$	CALL	DBOXCLICINC	; incrmente le paramtre	LOAD.W	D2,#8		; D2 <-- dlai de rptition	JUMP	MLOOP$MEND$:	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; teint +/-	LOAD.W	D2,D0		; D2 <-- rang	CALL	DBOXMEDIT	ADD.L	SP,#2		; POP.W D2 bidon	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	POP.W	D2	CALL	DBOXGET		; A3/A4 <-- ^dbut/ligne	LOAD.W	D7,#1		; D7 <-- erreurEXIT$:	POPM.L	D0,D1,D3,D4,A0,A2	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXCLICINC >;------------/; Incrmente un paramtre.; in	A2.L	^dans table dbox;	D5.L	canal dbox;	D1.W	+/- incrment;	D0.W	rang; out	A3.L	^dbut ligne;	A4.L	^curseur dans ligne; mod	D7.W, A3.L, A4.LDBOXCLICINC:	PUSHM.L	D2..D4	LOAD.W	D2,(A2)+ODBOFF	; D2 <-- offset variable	LOAD.W	D4,(A6)+(D2.W)	; D4 <-- nombre initial	COMP.B	(A2)+ODBTYP+1,#DBTYPNF	JUMP',NE NUMF2$NUMF1$:	COMP.W	D4,#-1	JUMP',NE NUMF2$	CLR.W	D4NUMF2$:	ADD.W	D4,D1		; D4 <-- +/- incrment	LOAD.W	D3,(A2)+ODBMIN	TEST.B	(A2)+ODBTYP+0:#14-8	JUMP',BC PUTNUM1$	LOAD.W	D3,(A6)+(D3.W)PUTNUM1$:	COMP.W	D4,D3	JUMP',GE PUTNUM2$	LOAD.W	D4,D3PUTNUM2$:	LOAD.W	D3,(A2)+ODBMAX	TEST.B	(A2)+ODBTYP+0:#15-8	JUMP',BC PUTNUM3$	LOAD.W	D3,(A6)+(D3.W)PUTNUM3$:	COMP.W	D4,D3	JUMP',LE PUTNUM4$	LOAD.W	D4,D3PUTNUM4$:	COMP.B	(A2)+ODBTYP+1,#DBTYPNF	JUMP',NE NUMF4$NUMF3$:	TEST.W	D4	JUMP',NE NUMF4$	DEC.W	D4		; D4 <-- -1NUMF4$:	COMP.W	D4,(A6)+(D2.W)	JUMP',EQ EXIT$	LOAD.W	(A6)+(D2.W),D4	; mj. le nombre	LOAD.W	D2,D0		; D2 <-- rang	CALL	DBOXGET		; A3/A4 <-- ^dbut/ligne	PUSH.W	(A2)+ODBINC	CLR.W	(A2)+ODBINC	; pour ne pas rafficher +/- !	CALL	DBOXAFF		; affiche la nouvelle valeur	POP.W	(A2)+ODBINCEXIT$:	POPM.L	D2..D4	RET;--------\\; DBOXAFF >;========/; Affiche un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox; out	-; mod	D7.WDBOXAFF:	PUSHM.L	D2..D4,A2..A4	COMP.W	D2,#-1	JUMP,EQ EXIT$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D2,(A2)+ODBRGC	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A4,A3	LIB	?AFTEXT		; affiche le texte	LOAD.L	D2,A3	SUB.L	D2,A4		; D2 <-- nb de caractres affichs	SUB.W	D2,(A2)+ODBNBC	NEG.W	D2	JUMP',NS INC$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D2	LIB	?AFCAR		; efface la finINC$:	TEST.W	(A2)+ODBINC	; +/- incrment existe ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	ADD.W	D4,(A0)+ODFCX	ADD.W	D4,#5	SWAP.W	D4	SUB.W	D4,#6+12;	SWAP.W	D4	LOAD.L	(A3)+1,D4	LOAD.L	A4,#R16"MATRIX$	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#SETDOT	LOAD.W	D3,#10	LIB	?STRINGEXIT$:	POPM.L	D2..D4,A2..A4	RETMATRIX$:	.B	16,25	.W	B'0000000100000000	.W	B'0000001010000000	.W	B'0000010001000000	.W	B'0000100000100000	.W	B'0001000000010000	.W	B'0010000000001000	.W	B'0111100000111100	.W	B'0000100100100000	.W	B'0000101110100000	.W	B'0000100100100000	.W	B'0000100000100000	.W	B'0000111111100000	.W	B'0000000000000000	.W	B'0000111111100000	.W	B'0000100000100000	.W	B'0000100000100000	.W	B'0000101110100000	.W	B'0000100000100000	.W	B'0111100000111100	.W	B'0010000000001000	.W	B'0001000000010000	.W	B'0000100000100000	.W	B'0000010001000000	.W	B'0000001010000000	.W	B'0000000100000000;--------\\; DBOXGET >;========/; Donne le contenu d'un paramtre ditable.; in	D2.W	rang (0..n);	D5.L	canal dbox; out	A3.L	^dbut ligne;	A4.L	^curseur dans ligne; mod	D7.W, A3.L, A4.LDBOXGET:	PUSHM.L	D2..D4,D6,A1,A2	LOAD.L	A3,#(A6)+ODBLIN	LOAD.L	A4,A3	CLR.B	(A4)	COMP.W	D2,#-1	JUMP,EQ EXIT$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D2,(A2)+ODBOFF	; D2 <-- offset variable	COMP.B	(A2)+ODBTYP+1,#DBTYPN	JUMP',EQ NUM$	COMP.B	(A2)+ODBTYP+1,#DBTYPNS	JUMP',EQ NUMS$	COMP.B	(A2)+ODBTYP+1,#DBTYPNF	JUMP,EQ NUMF$	COMP.B	(A2)+ODBTYP+1,#DBTYPA	JUMP,EQ ALPHA$	JUMP	EXIT$NUM$:	CLR.L	D4	LOAD.W	D4,(A6)+(D2.W)	; D4 <-- nombre	CALL	PUTANUM		; ODBLIN <-- nombre	CLR.B	(A4)	JUMP	EXIT$NUMS$:	LOAD.B	D3,#'+	CLR.L	D4	LOAD.W	D4,(A6)+(D2.W)	; D4 <-- nombre	JUMP',NC NUMSP$	NEG.W	D4	LOAD.B	D3,#'-NUMSP$:	LOAD.B	(A4+),D3	; ODBLIN <-- signe (+/-)	CALL	PUTANUM		; ODBLIN <-- nombre	CLR.B	(A4)	JUMP	EXIT$NUMF$:	CLR.L	D4	LOAD.W	D4,(A6)+(D2.W)	; D4 <-- nombre	JUMP',NS NUMF2$	CALL	PUTANUM		; ODBLIN <-- nombreNUMF2$:	CLR.B	(A4)	JUMP'	EXIT$ALPHA$:	LOAD.L	A1,#(A6)+(D2.W)	; A1 <-- ^chaneALPHA1$:	LOAD.B	(A4+),(A1+)	; ODBLIN <-- chane	JUMP,NE ALPHA1$	DEC.L	A4;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4,D6,A1,A2	RET;--------\\; DBOXPUT >;========/; Met  jour un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox; out	D7.W	erreur; mod	D7.WDBOXPUT:	CALL	DBOXMAJ		; met  jour	JUMP',NE EXIT$	PUSHM.L	A3,A4	CALL	DBOXGET		; A3 <-- ^paramtre	CALL	DBOXAFF		; raffiche correctement	POPM.L	A3,A4	CLR.W	D7		; D7 <-- okEXIT$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXMAJ >;--------/; Met  jour un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox; out	D7.W	erreur; mod	D7.WDBOXMAJ:	PUSHM.L	D2..D4,D6,A2..A4	CLR.W	D7		; D7 <-- ok	COMP.W	D2,#-1	JUMP,EQ EXIT$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D2,(A2)+ODBOFF	; D2 <-- offset variable	COMP.B	(A2)+ODBTYP+1,#DBTYPN	JUMP',EQ NUM$	COMP.B	(A2)+ODBTYP+1,#DBTYPNS	JUMP,EQ NUMS$	COMP.B	(A2)+ODBTYP+1,#DBTYPNF	JUMP,EQ NUMF$	COMP.B	(A2)+ODBTYP+1,#DBTYPA	JUMP,EQ ALPHA$	LOAD.W	D7,#ERSYNT	; D7 <-- erreur	JUMP	EXIT$NUM$:	LOAD.L	A4,A3	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$PUTNUM$:	LOAD.W	D3,(A2)+ODBMIN	TEST.B	(A2)+ODBTYP+0:#14-8	JUMP',BC PUTNUM1$	LOAD.W	D3,(A6)+(D3.W)PUTNUM1$:	COMP.W	D4,D3	JUMP',GE PUTNUM2$	LOAD.W	D4,D3PUTNUM2$:	LOAD.W	D3,(A2)+ODBMAX	TEST.B	(A2)+ODBTYP+0:#15-8	JUMP',BC PUTNUM3$	LOAD.W	D3,(A6)+(D3.W)PUTNUM3$:	COMP.W	D4,D3	JUMP',LE PUTNUM4$	LOAD.W	D4,D3PUTNUM4$:	LOAD.W	(A6)+(D2.W),D4	; mj. le nombre	CLR.W	D7		; D7 <-- ok	JUMP	EXIT$NUMS$:	LOAD.L	A4,A3	LOAD.B	D3,#'-	COMP.B	D3,(A4+)	JUMP',EQ NUMS2$	LOAD.B	D3,#'+	COMP.B	D3,(A4)-1	JUMP',EQ NUMS2$	DEC.L	A4NUMS2$:	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$	COMP.B	D3,#'-	JUMP,NE PUTNUM$	NEG.W	D4	JUMP	PUTNUM$NUMF$:	LOAD.L	A4,A3	LOAD.W	D4,#-1	TEST.B	(A4)	JUMP,EQ PUTNUM4$	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$	JUMP	PUTNUM$ALPHA$:	LOAD.L	A4,#(A6)+(D2.W)	; A4 <-- ^chaneALPHA1$:	LOAD.B	(A4+),(A3+)	; mj. chane	JUMP,NE ALPHA1$	CLR.W	D7		; D7 <-- ok;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\; DBOXHLINE >;==========/; Trace une ligne horizontale dans une dbox.; in	D2.W	rang de l'objet; out	D3.L	position d'arrive; mod	D3.L, D7.WDBOXHLINE:	PUSHM.L	D2,D4,A4	LIB	?GETPDIS	; A4 <-- ^descripteur fentre	DBOX_	GETCO	CLR.W	D3	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A4)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2,D4,A4	RET; Tables; ------TDBOX_PREND:	.B	LDBOX_PREND	.B	ODBLCIRCLE,BDBCOUL!2^7,0,1	.ASCIZ	" couleur       (.COLOR)"	.B	ODBCR	.B	ODBLCIRCLE,BDBIMAG!2^7,0,1	.ASCIZ	" noir et blanc (.IMAGE)"	.B	ODBCRLDBOX_PREND	=	.-TDBOX_PREND-1TDBOX_SAUVE:	.B	LDBOX_SAUVE	.B	ODBLCIRCLE,BDBCOUL!2^7,0,1	.ASCIZ	" couleur       (.COLOR)"	.B	ODBCR	.B	ODBLCIRCLE,BDBIMAG!2^7,0,1	.ASCIZ	" noir et blanc (.IMAGE)";;?	.B	ODBCR,ODBCR2;;?	.B	ODBSQUARE,BDBDEF;;?	.ASCIZ	" dfinitions   (.DCOL)"	.B	ODBCRLDBOX_SAUVE	=	.-TDBOX_SAUVE-1TDBOX_DEFINE:	.W	10$-TDBOX_DEFINE	.W	20$-TDBOX_DEFINE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Dimensions (l x h) "	.B	ODBTABX,19	.B	ODBLINE,(14+2)!2^7,0,0,TDBOMBRE	.B	ODBCR,ODBCR	.B	ODBSQUARE,BDEFZOOM	.ASCIZ	" zoom gnral"	.B	ODBTABX,19	.B	ODBBOX,0,FNCT,TDBOMBRE	.ASCIZ	" ECRAN "	.B	ODBBOX,0,DEFINE,TDBOMBRE	.ASCIZ	" PAGE "	.B	ODBCR	.B	ODBLCIRCLE,BDEFMM!2^7!2^6,KEYICO/H'100,BDEFMM	.ASCIZ	" millimtres"	.B	ODBCR	.B	ODBLCIRCLE,BDEFPG!2^7!2^6,KEYICO/H'100,BDEFPG	.ASCIZ	" points graphiques"	.B	ODBCR,ODBCR	.B	ODBSQUARE,BDEFICO	.ASCIZ	" utilise les icnes"	.B	ODBCR	.B	ODBSQUARE,BDEFASC	.ASCIZ	" utilise les ascenseurs"	.B	ODBCR	.B	ODBSQUARE,BDEFMDC	.ASCIZ	" mmorise la dernire case"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEFINE:	.W	F1,F2,F3,CR,0		DOKCR-TKEY_DEFINE	.W	F13,F14,F15,END,0	DOKEND-TKEY_DEFINE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEFINE	.W	0TDBOX_BIDON:	.W	10$-TDBOX_BIDON	.W	20$-TDBOX_BIDON	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Remplissage avec le bidon :"	.B	ODBTABX,30	.B	ODBLABEL,20	.B	ODBTEXT	.ASCIZ	"Dpart x="	.B	ODBLABEL,100	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBLABEL,21	.B	ODBTEXT	.ASCIZ	"  y="	.B	ODBLABEL,101	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBLABEL,22	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR	.B	ODBSQUARE,BBIFILL	.ASCIZ	" jusque dans les bords"	.B	ODBTABX,30	.B	ODBLABEL,23	.B	ODBTEXT	.ASCIZ	"Distance "	.B	ODBLABEL,102	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBLABEL,24	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,BBITRAM!2^7!2^6,KEYDBOX/H'100,BBITRAM	.ASCIZ	" selon la trame"	.B	ODBCR2	.B	ODBTABX,30	.B	ODBLABEL,25	.B	ODBTEXT	.ASCIZ	"Angle    "	.B	ODBLABEL,103	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBLABEL,26	.B	ODBTEXT	.ASCIZ	"  degrs"	.B	ODBCR2	.B	ODBLCIRCLE,BBIFULL!2^7!2^6,KEYDBOX/H'100,BBIFULL	.ASCIZ	" plein (100%)"	.B	ODBCR	.B	ODBLCIRCLE,BBIDEG!2^7!2^6,KEYDBOX/H'100,BBIDEG	.ASCIZ	" dgrad"	.B	ODBCR2	.B	ODBTABX,30	.B	ODBLABEL,27	.B	ODBLCIRCLE,BBILIN!2^7!2^6,KEYDBOX/H'100,BBILIN	.ASCIZ	" linaire"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,28	.B	ODBLCIRCLE,BBICIRC!2^7!2^6,KEYDBOX/H'100,BBICIRC	.ASCIZ	" circulaire"	.B	ODBCR2	.B	ODBTABX,30-2	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLABEL,29	.B	ODBTEXT	.ASCIZ	"Couleurs du dgrad :"	.B	ODBTABX,30	.B	ODBLABEL,30	.B	ODBTEXT	.ASCIZ	"Nombre de couleurs "	.B	ODBLABEL,104	.B	ODBCLINE,(2+2)!2^7,KEYDBOX/H'100,104,TDBNORM	.B	ODBLABEL,31	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR;	.B	ODBTABX,4*0	.B	ODBLABEL,50	.B	ODBBOX,KEYDBOX/H'100,50,TDBNORM	.ASCIZ	"   "	.B	ODBTABX,4*1	.B	ODBLABEL,51	.B	ODBBOX,KEYD