	.SBTTL	PICOPER.ASI;-----------\\; OPERMATRIX >;===========/; Effectue une opration.; in	D3.B	opration (ICOxx); out	D7.W	erreur; mod	D7.WOPERMATRIX:	COMP.B	(A6)+OYICO,#ICOZOOM	JUMP,EQ ZOOMMATRIX	COMP.B	(A6)+OYICO,#ICOTOURNE	JUMP,EQ TOURNEMATRIX	COMP.B	(A6)+OYICO,#ICOMIROIR	JUMP,EQ MIROIRMATRIX	LOAD.W	D7,#1		; retour NE	RET;-----------\\; ZOOMMATRIX >;-----------/; Zoom une zone rectangulaire d'aprs la matrice copie dans; la matrice principale.; in	D3.B	zoom (ICOZOOMxx); out	D7.W	erreur; mod	D7.WZOOMMATRIX:	PUSHM.L	D0..D3	LOAD.L	D1,(A6)+OSEPHG	; D1 <-- coin haut/gauche	LOAD.L	D2,(A6)+OSEPBD	; D2 <-- coin bas/droite	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	COMP.B	D3,#ICOZOOMAA	JUMP',EQ 20$	COMP.B	D3,#ICOZOOMAI	JUMP',NE 22$20$:				; *2 en X =>	LOAD.W	D0,D2	ASR.W	D0,#1	SUB.W	D1,D0	ASL.W	D2,#122$:	COMP.B	D3,#ICOZOOMDD	JUMP',EQ 24$	COMP.B	D3,#ICOZOOMDI	JUMP',NE 26$24$:				; */ en X =>	LOAD.W	D0,D2	ASR.W	D0,#2	ADD.W	D1,D0	ASR.W	D2,#126$:	SWAP.W	D1	SWAP.W	D2	COMP.B	D3,#ICOZOOMAA	JUMP',EQ 30$	COMP.B	D3,#ICOZOOMIA	JUMP',NE 32$30$:				; *2 en Y =>	LOAD.W	D0,D2	ASR.W	D0,#1	SUB.W	D1,D0	ASL.W	D2,#132$:	COMP.B	D3,#ICOZOOMDD	JUMP',EQ 34$	COMP.B	D3,#ICOZOOMID	JUMP',NE 36$34$:				; */ en Y =>	LOAD.W	D0,D2	ASR.W	D0,#2	ADD.W	D1,D0	ASR.W	D2,#136$:;	SWAP.W	D1;	SWAP.W	D2	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	ADD.W	D2,D1;	SWAP.W	D1;	SWAP.W	D2	LOAD.L	(A6)+OSEPHG,D1	LOAD.L	(A6)+OSEPBD,D2	LOAD.W	(A6)+OSEPHD+2,D2	LOAD.W	(A6)+OSEPBG+2,D1	SWAP.W	D1	SWAP.W	D2	LOAD.W	(A6)+OSEPHD+0,D1	LOAD.W	(A6)+OSEPBG+0,D2;	SWAP.W	D1;	SWAP.W	D2	POPM.L	D0..D3	TEST.W	D7		; retour EQ/NE	RET;-------------\\; TOURNEMATRIX >;-------------/; Tourne une zone rectangulaire d'aprs la matrice copie dans; la matrice principale.; in	D3.B	rotation (ICOTxxD); out	D7.W	erreur; mod	D7.WTOURNEMATRIX:	PUSHM.L	D1..D3	LOAD.W	D2,#+10	COMP.B	D3,#ICOT10D	JUMP',EQ 10$	LOAD.W	D2,#+20	COMP.B	D3,#ICOT20D	JUMP',EQ 10$	LOAD.W	D2,#+30	COMP.B	D3,#ICOT30D	JUMP',EQ 10$	LOAD.W	D2,#+45	COMP.B	D3,#ICOT45D	JUMP',EQ 10$	LOAD.W	D2,#+60	COMP.B	D3,#ICOT60D	JUMP',EQ 10$	LOAD.W	D2,#+90;	COMP.B	D3,#ICOT90D;	JUMP',EQ 10$10$:	COMP.B	(A6)+OSTRRO,#ICOTOURNEP	JUMP',NE 20$	NEG.W	D220$:	ADD.W	(A6)+OSEANG,D2	LOAD.W	D2,(A6)+OSEANG	; D2 <-- angle absolu	LOAD.L	D1,(A6)+OSEPMI	SUB.W	D1,(A6)+OSEOMI+2	SWAP.W	D1	SUB.W	D1,(A6)+OSEOMI+0	SWAP.W	D1		; D1 <-- dplacement	LOAD.L	D3,(A6)+OSEOHG	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en X	SWAP.W	D1	SWAP.W	D3	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en Y	SWAP.W	D1	SWAP.W	D3	CALL	QTOURNE	LOAD.L	(A6)+OSEPHG,D3	LOAD.L	D3,(A6)+OSEOHD	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en X	SWAP.W	D1	SWAP.W	D3	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en Y	SWAP.W	D1	SWAP.W	D3	CALL	QTOURNE	LOAD.L	(A6)+OSEPHD,D3	LOAD.L	D3,(A6)+OSEOBG	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en X	SWAP.W	D1	SWAP.W	D3	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en Y	SWAP.W	D1	SWAP.W	D3	CALL	QTOURNE	LOAD.L	(A6)+OSEPBG,D3	LOAD.L	D3,(A6)+OSEOBD	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en X	SWAP.W	D1	SWAP.W	D3	ADD.W	D3,D1		; D3 <-- tient compte du dplacement en Y	SWAP.W	D1	SWAP.W	D3	CALL	QTOURNE	LOAD.L	(A6)+OSEPBD,D3	POPM.L	D1..D3	TEST.W	D7		; retour EQ/NE	RET;-------------\\; MIROIRMATRIX >;-------------/; Symtrise une zone rectangulaire d'aprs la matrice copie dans; la matrice principale.; in	D3.W	miroir (ICOMIROIRx); out	D7.W	erreur; mod	D7.WMIROIRMATRIX:	PUSH.L	D0	COMP.B	D3,#ICOMIROIRV	JUMP',NE 30$	LOAD.W	D0,(A6)+OSEPHG+0	LOAD.W	(A6)+OSEPHG+0,(A6)+OSEPBG+0	LOAD.W	(A6)+OSEPBG+0,D0	LOAD.W	D0,(A6)+OSEPHD+0	LOAD.W	(A6)+OSEPHD+0,(A6)+OSEPBD+0	LOAD.W	(A6)+OSEPBD+0,D030$:	COMP.B	D3,#ICOMIROIRH	JUMP',NE 35$	LOAD.W	D0,(A6)+OSEPHG+2	LOAD.W	(A6)+OSEPHG+2,(A6)+OSEPHD+2	LOAD.W	(A6)+OSEPHD+2,D0	LOAD.W	D0,(A6)+OSEPBD+2	LOAD.W	(A6)+OSEPBD+2,(A6)+OSEPBG+2	LOAD.W	(A6)+OSEPBG+2,D035$:	COMP.B	D3,#ICOMIROIRX	JUMP',NE 40$	LOAD.L	D0,(A6)+OSEPHD	LOAD.L	(A6)+OSEPHD,(A6)+OSEPBG	LOAD.L	(A6)+OSEPBG,D040$:	COMP.B	D3,#ICOMIROIRY	JUMP',NE 45$	LOAD.L	D0,(A6)+OSEPHG	LOAD.L	(A6)+OSEPHG,(A6)+OSEPBD	LOAD.L	(A6)+OSEPBD,D045$:	POP.L	D0	TEST.W	D7		; retour EQ/NE	RET;----------\\; ISSTRETCH >;----------/; Initialise la source du module stretch.; in	D1.L	position (y;x);	D2.L	dimensions (dy;dx); out	-; mod	D7.WISSTRETCH:	PUSHM.L	D1,D2	ADD.W	D2,D1	DEC.W	D2	SWAP.W	D1	SWAP.W	D2	ADD.W	D2,D1	DEC.W	D2	SWAP.W	D1	SWAP.W	D2	CLR.W	(A6)+OSTRETCH+OSTRTYP	CLR.W	(A6)+OSTRETCH+OSTROP	LOAD.L	(A6)+OSTRETCH+OSTRS0,D1	LOAD.L	(A6)+OSTRETCH+OSTRS2,D2	LOAD.L	(A6)+OSTRETCH+OSTRSPT,(A6)+OPMAM	LOAD.W	D2,(A6)+OMANBB	MUL.WU	D2,(A6)+OMANBP	LOAD.W	(A6)+OSTRETCH+OSTRSDX,D2	POPM.L	D1,D2	RET;----------\\; IDSTRETCH >;----------/; Initialise la destination du module stretch.; in	D1.L	position (y;x);	D2.L	dimensions (dy;dx); out	-; mod	D7.WIDSTRETCH:	PUSHM.L	D1..D3	ADD.W	D2,D1	DEC.W	D2	SWAP.W	D1	SWAP.W	D2	ADD.W	D2,D1	DEC.W	D2	SWAP.W	D1	SWAP.W	D2	LOAD.L	(A6)+OSTRETCH+OSTRD0,D1	LOAD.L	(A6)+OSTRETCH+OSTRD2,D2	LOAD.W	D3,D1	LOAD.W	D1,D2	LOAD.W	D2,D3	LOAD.L	(A6)+OSTRETCH+OSTRD1,D1	LOAD.L	(A6)+OSTRETCH+OSTRD3,D2	LOAD.L	(A6)+OSTRETCH+OSTRDPT,(A6)+OPMAT	LOAD.W	D2,(A6)+OMANBB	MUL.WU	D2,(A6)+OMANBP	LOAD.W	(A6)+OSTRETCH+OSTRDDX,D2	POPM.L	D1..D3	RET;----------\\; GOSTRETCH >;----------/; Lance le "stretcheur" miracle ...; in	-; out	D7.W	erreur; mod	D7.WGOSTRETCH:	PUSHM.L	D3,A3,A4	LOAD.L	D3,(A6)+OSTRETCH+OSTRD0	CALL	IFSTRETCH	; point dpasse ?	JUMP',NE 50$	LOAD.L	D3,(A6)+OSTRETCH+OSTRD1	CALL	IFSTRETCH	; point dpasse ?	JUMP',NE 50$	LOAD.L	D3,(A6)+OSTRETCH+OSTRD2	CALL	IFSTRETCH	; point dpasse ?	JUMP',NE 50$	LOAD.L	D3,(A6)+OSTRETCH+OSTRD3	CALL	IFSTRETCH	; point dpasse ?	JUMP',NE 50$	PUSH.L	A0	LOAD.L	A0,#(A6)+OSTRETCH	LOAD.W	(A0)+OSTRTYP,#2	; stretch en couleur	LOAD.W	(A0)+OSTPIXEL,(A6)+OMANBP	ST_	RECT		; ... et vive Francis+Denis !	POP.L	A0	CLR.W	D7		; D7 <-- a baigne	JUMP'	90$50$:	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	_XFERALL	; matrice principale <-- matrice copie	LOAD.W	D7,#1		; D7 <-- pas possible90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IFSTRETCH >;----------/; Regarde si un point dborde.; in	D3.L	point (y;x); out	D7.W	erreur; mod	D7.WIFSTRETCH:	PUSH.L	D3	LOAD.W	D7,#1		; D7 <-- a dborde	TEST.W	D3		; dborde  gauche ?	JUMP',NS 90$	COMP.W	D3,(A6)+OMALMX	; dborde  droite ?	JUMP',HS 90$	SWAP.W	D3	TEST.W	D3		; dborde en haut ?	JUMP',NS 90$	COMP.W	D3,(A6)+OMALMY	; dborde en bas ?	JUMP',HS 90$	CLR.W	D7		; D7 <-- ok90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;-------------\\; RELIEFMATRIX >;=============/; Extrait le contour d'une zone rectangulaire d'aprs la matrice copie; dans la matrice principale.; in	D1/D2.L	emplacement  extraire le contour;	D3.W	opration (0..7); out	-; mod	D7.WRELIEFMATRIX:	PUSHM.L	D1..D6,A2..A4	CALL	_WAITMOUSE	; met le sablier	LOAD.L	A2,#(A6)+OOPREL	MUL.WU	D3,#LREL	ADD.L	A2,D3		; A2 <-- ^matrices d'oprations	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- position source	LOAD.L	D4,D1		; D4 <-- position destination	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	_XFERZONE	; efface dans matrice principale !	PUSH.L	D5	LOAD.L	D2,D5		; D2 <-- dimensions	LOAD.L	D5,(A6)+OMALMY	; D5 <-- dimensions bitmap source	ADD.W	D5,#16-1	AND.B	D5,#B'11110000	; D5 <-- largeur multiple de 16 points !	LOAD.L	D6,D5		; D6 <-- dimensions bitmap destination	DESS2_	RELIEF		; moteur ...	POP.L	D5	EX.L	A3,A4		; A3 <-- ^source, A4 <-- ^destination	LOAD.W	D2,#LOADDOT	; D2 <-- mode	CALL	_XFERZONE	; remet dans matrice masque !	POPM.L	D1..D6,A2..A4	RET;--------\\; OPTRAME >;========/; Trame une zone slectionne.; in	-; out	-; mod	D7.WOPTRAME:	PUSHM.L	D1..D6,A2..A4	CALL	_WAITMOUSE	; met le sablier	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	_XFERALL	; matrice principale <-- matrice copie	LOAD.L	D1,(A6)+OSEPHG	; D1 <-- coin haut/gauche	LOAD.L	D2,(A6)+OSEPBD	; D2 <-- coin bas/droite	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- position source	LOAD.L	D4,D1		; D4 <-- position destination	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	_XFERZONE	; efface dans matrice principale !	LOAD.L	D2,D5		; D2 <-- dimensions	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^bitmap source	LOAD.L	D5,(A6)+OMALMY	; D5 <-- dimensions bitmap source	ADD.W	D5,#16-1	AND.B	D5,#B'11110000	; D5 <-- largeur multiple de 16 points !;	LOAD.L	D3,D1		; D3 <-- origine source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^bitmap destination	LOAD.L	D6,D5		; D6 <-- dimensions bitmap destination;	LOAD.L	D4,D1		; D4 <-- origine destination	CLR.L	D1	LOAD.B	D1,(A6)+OTRALU+1 ; D1 <-- luminosit	SL.L	D1,#8	LOAD.B	D1,(A6)+OTRANI+1 ; D1 <-- niveaux	SL.L	D1,#8	LOAD.B	D1,(A6)+OTRAPA+1 ; D1 <-- pas	LOAD.L	A2,#(A6)+OTRAT1	; A2 <-- ^trames de la famille 1	TEST.W	(A6)+OTRAFA	JUMP',EQ 30$	LOAD.L	A2,#(A6)+OTRAT2	; A2 <-- ^trames de la famille 2	COMP.W	(A6)+OTRAFA,#1	JUMP',EQ 30$	LOAD.L	A2,#(A6)+OTRAT3	; A2 <-- ^trames de la famille 330$:	DESS2_	TRAME		; moteur ...	POPM.L	D1..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; OPLISSE >;========/; Lisse une zone slectionne.; in	-; out	-; mod	D7.WOPLISSE:	PUSHM.L	D1..D6,A3,A4	CALL	_WAITMOUSE	; met le sablier	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	_XFERALL	; matrice principale <-- matrice copie	LOAD.L	D1,(A6)+OSEPHG	; D1 <-- coin haut/gauche	LOAD.L	D2,(A6)+OSEPBD	; D2 <-- coin bas/droite	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- position source	LOAD.L	D4,D1		; D4 <-- position destination	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	_XFERZONE	; efface dans matrice principale !	LOAD.L	D2,D5		; D2 <-- dimensions	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^bitmap source	LOAD.L	D5,(A6)+OMALMY	; D5 <-- dimensions bitmap source	ADD.W	D5,#16-1	AND.B	D5,#B'11110000	; D5 <-- largeur multiple de 16 points !;	LOAD.L	D3,D1		; D3 <-- origine source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^bitmap destination	LOAD.L	D6,D5		; D6 <-- dimensions bitmap destination;	LOAD.L	D4,D1		; D4 <-- origine destination	LOAD.W	D1,(A6)+OLISLU	; D1 <-- luminosit	MUL.WA	D1,#2	AND.L	D1,#H'000000FF	SWAP.W	D1	LOAD.B	D1,(A6)+OLISPA+1 ; D1 <-- pas	DESS2_	LISSE		; moteur ...	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; REDUIT  >;========/; Rduit toute une matrice d'un facteur constant 2, 4 ou 8.; Super-rapide dans tous les cas, si si !; in	A3.L		^matrice source; out	A4.L		^matrice rduite;	(A6)+OMANBS.W	largeur en byte;	D7.W		erreur; mod	D7.W, A4.LREDUIT:	PUSHM.L	D1..D4	LOAD.W	D3,(A6)+OSCALE	NEG.W	D3		; D3 <-- 2, 4 ou 8	CLR.L	D4	LOAD.W	D4,(A6)+OMANBB	DIV.WU	D4,D3	INC.W	D4		; D4 <-- largeur en bytes rduite	LOAD.W	(A6)+OMANBS,D4	CLR.L	D2	LOAD.W	D2,(A6)+OMALMY	DIV.WU	D2,D3	INC.W	D2		; D2 <-- hauteur en points rduite	MUL.WU	D4,D2	ADD.L	D4,#4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour matrice rduite	JUMP',NE 90$	PUSH.L	A4	SR.L	D4,#2		; D4 <-- /4 car transfert par long-worvd	DEC.W	D4		; D4 <-- -1  cause NMO30$:	CLR.L	(A4+)		; efface toute la mmoire	DECJ.W,NMO D4,30$	POP.L	A4	COMP.W	D3,#2	JUMP',EQ 40$	COMP.W	D3,#4	JUMP',EQ 42$	COMP.W	D3,#8	JUMP',EQ 44$	JUMP'	80$40$:	CALL	REDUIT2	JUMP'	80$42$:	CALL	REDUIT4	JUMP'	80$44$:	CALL	REDUIT8;	JUMP'	80$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RETREDUIT2:	PUSHM.L	D0..D4,A2..A5	LOAD.L	A5,A4		; A5 <-- ^destination	LOAD.W	D1,(A6)+OMALMY	; D1 <-- hauteur en bytes	SR.W	D1,#1		; D1 <-- hauteur /2	LOAD.W	D2,(A6)+OMANBB	; D2 <-- largeur en bytes10$:	LOAD.L	A4,A5		; A4 <-- ^destination	LOAD.W	D3,D2		; D3 <-- largeur en bytes	DEC.W	D3		; D3 <-- -1  cause NMO20$:	LOAD.B	D0,(A3)+(D2.W)	OR.B	D0,(A3+)	JUMP',NE 30$	SL.B	D4,#4		; D4 <-- 4 points blancs	JUMP'	34$30$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 31$	TSET.L	D4:#031$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 32$	TSET.L	D4:#032$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 33$	TSET.L	D4:#033$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 34$	TSET.L	D4:#034$:	DEC.W	D3	JUMP',NS 50$	LOAD.B	D0,(A3)+(D2.W)	OR.B	D0,(A3+)	JUMP',NE 40$	SL.B	D4,#4		; D4 <-- 4 points blancs	JUMP'	44$40$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 41$	TSET.L	D4:#041$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 42$	TSET.L	D4:#042$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 43$	TSET.L	D4:#043$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 44$	TSET.L	D4:#044$:	LOAD.B	(A4+),D4	; destination <-- 8 points	DECJ.W,NMO D3,20$	JUMP'	60$50$:	SL.B	D4,#4		; D4 <-- 4 points blancs	LOAD.B	(A4+),D4	; destination <-- 4 points effectifs60$:	ADD.W	A3,D2		; A3 <-- y=y+2 source	ADD.W	A5,(A6)+OMANBS	; A5 <-- y=y+1 destination	DEC.W	D1	JUMP,NE 10$	POPM.L	D0..D4,A2..A5	RETREDUIT4:	PUSHM.L	D0..D5,A2..A5	LOAD.L	A5,A4		; A5 <-- ^destination	LOAD.W	D1,(A6)+OMALMY	; D1 <-- hauteur en bytes	SR.W	D1,#2		; D1 <-- hauteur /4	LOAD.W	D2,(A6)+OMANBB	; D2 <-- largeur en bytes10$:	LOAD.L	A4,A5		; A4 <-- ^destination	LOAD.B	D4,#7		; D4 <-- destination tout  gauche	LOAD.W	D3,D2		; D3 <-- largeur en bytes	DEC.W	D3		; D3 <-- -1  cause NMO20$:	LOAD.L	A2,A3	LOAD.B	D0,(A2)	ADD.W	A2,D2	OR.B	D0,(A2)	ADD.W	A2,D2	OR.B	D0,(A2)	ADD.W	A2,D2	OR.B	D0,(A2)	LOAD.B	D5,D0	AND.B	D5,#B'11110000	JUMP',NE 30$	TCLR.B	(A4):D4		; teint le point destination	JUMP'	32$30$:	TSET.B	(A4):D4		; allume le point destination32$:	DEC.B	D4		; D4 <-- x=x+1 destination	JUMP',NC 34$	LOAD.B	D4,#7	INC.L	A4		; A4 <-- x=x+8 destination34$:	AND.B	D0,#B'00001111	JUMP',NE 40$	TCLR.B	(A4):D4		; teint le point destination	JUMP'	42$40$:	TSET.B	(A4):D4		; allume le point destination42$:	DEC.B	D4		; D4 <-- x=x+1 destination	JUMP',NC 44$	LOAD.B	D4,#7	INC.L	A4		; A4 <-- x=x+8 destination44$:	INC.L	A3		; A3 <-- x=x+8 source	DECJ.W,NMO D3,20$	LOAD.W	D3,D2	MUL.WU	D3,#4-1	ADD.L	A3,D3		; A3 <-- y=y+4 source	ADD.W	A5,(A6)+OMANBS	; A5 <-- y=y+1 destination	DEC.W	D1	JUMP,NE 10$	POPM.L	D0..D5,A2..A5	RETREDUIT8:	PUSHM.L	D1..D4,A2..A5	LOAD.L	A5,A4		; A5 <-- ^destination	LOAD.W	D1,(A6)+OMALMY	; D1 <-- hauteur en bytes	SR.W	D1,#3		; D1 <-- hauteur /8	LOAD.W	D2,(A6)+OMANBB	; D2 <-- largeur en bytes10$:	LOAD.L	A4,A5		; A4 <-- ^destination	LOAD.B	D4,#7		; D4 <-- destination tout  gauche	LOAD.W	D3,D2		; D3 <-- largeur en bytes	DEC.W	D3		; D3 <-- -1  cause NMO20$:	LOAD.L	A2,A3	TEST.B	(A2)		; points (0,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (1,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (2,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (3,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (4,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (5,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (6,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (7,0..7) allums ?	JUMP',NE 30$	TCLR.B	(A4):D4		; teint le point destination	JUMP'	32$30$:	TSET.B	(A4):D4		; allume le point destination32$:	DEC.B	D4		; D4 <-- x=x+1 destination	JUMP',NC 34$	LOAD.B	D4,#7	INC.L	A4		; A4 <-- x=x+8 destination34$:	INC.L	A3		; A3 <-- x=x+8 source	DECJ.W,NMO D3,20$	LOAD.W	D3,D2	MUL.WU	D3,#8-1	ADD.L	A3,D3		; A3 <-- y=y+8 source	ADD.W	A5,(A6)+OMANBS	; A5 <-- y=y+1 destination	DEC.W	D1	JUMP,NE 10$	POPM.L	D1..D4,A2..A5	RET	.END