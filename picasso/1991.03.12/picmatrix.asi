	.SBTTL	PICMATRIX.ASI;----------\\; DESMATRIX >;==========/; Dessine toutes les matrices.; in	-; out	-; mod	D7.WDESMATRIX:	CALL	DESPMATRIX	; dessine la petite matrice	CALL	DESGMATRIX	; dessine la grande matrice	RET;-----------\\; DESPMATRIX >;===========/; Dessine toute la petite matrice.; in	-; out	-; mod	D7.WDESPMATRIX:	PUSHM.L	D0..D5,A3,A4	CLR.L	D4	CALL	_DRMDEF	CLR.W	D0	LOAD.W	D4,(A6)+OMALSX	SUB.W	D4,(A6)+OPMOVX	SUB.W	D4,(A6)+OPMDIX	JUMP',HS 20$	NEG.W	D4	LOAD.W	D0,D4	LOAD.W	D3,(A6)+OPMPOX	ADD.W	D3,(A6)+OPMDIX	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OPMPOY	LOAD.W	D4,(A6)+OPMDIY	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface bande  droite20$:	CLR.W	D1	LOAD.W	D4,(A6)+OMALSY	SUB.W	D4,(A6)+OPMOVY	SUB.W	D4,(A6)+OPMDIY	JUMP',HS 30$	NEG.W	D4	LOAD.W	D1,D4	LOAD.W	D3,(A6)+OPMPOY	ADD.W	D3,(A6)+OPMDIY	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OPMPOX	LOAD.W	D4,(A6)+OPMDIX	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface bande en bas30$:	LOAD.L	D3,(A6)+OPMOVY	; D3 <-- position source	LOAD.L	D4,(A6)+OPMPOY	; D4 <-- position destination	LOAD.L	D5,(A6)+OPMDIY	; D5 <-- dimensions	SUB.W	D5,D0	SWAP.W	D5	SUB.W	D5,D1	SWAP.W	D5	LOAD.W	D2,#LOADDOT	; D2 <-- mode	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP',NC 50$		; non => 50$				; oui =>	LOAD.L	A3,(A6)+OPMAT	; A3 <-- ^matrice source	CALL	REDUIT		; A4 <-- ^matrice rduite	JUMP',NE EXIT$	PUSH.L	A4	LOAD.L	A3,A4		; A3 <-- ^matrice rduite	LOAD.L	A4,#0		; A4 <-- matrice destination dans l'cran	LOAD.W	(A6)+OMANBD,(A6)+OMANBB	CALL	_XFERZONESD	; petit rectangle <-- matrice principale rduite	POP.L	A4	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la matrice rduite	JUMP'	EXIT$50$:	LOAD.L	A3,(A6)+OPMAT	; A3 <-- ^matrice source	LOAD.L	A4,#0		; A4 <-- matrice destination dans l'cran	CALL	_XFERZONE	; petit rectangle <-- matrice principaleEXIT$:	POPM.L	D0..D5,A3,A4	RET;-----------\\; DESGMATRIX >;===========/; Dessine toute la grande matrice.; in	-; out	-; mod	D7.WDESGMATRIX:	PUSHM.L	D1..D5,A1	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,LE EXIT$	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice	LOAD.W	D3,(A6)+OGMOVY	SWAP.W	D3		; D3 <-- position initiale en Y	CLR.L	D5	LOAD.W	D5,(A6)+OGMDIY	DIV.WU	D5,(A6)+OGMLPY	; D5 <-- nb points verticalement	INC.W	D5		; D5 <-- +1 si fraction de pointLOOPY$:	LOAD.W	D3,(A6)+OGMOVX	; D3 <-- position initiale en X	CLR.L	D4	LOAD.W	D4,(A6)+OGMDIX	DIV.WU	D4,(A6)+OGMLPX	; D4 <-- nb points horizontalement	INC.W	D4		; D4 <-- +1 si fraction de pointLOOPX$:	CALL	COULPOINT	; D1 <-- couleur du point	CALL	DESGPOINT	; allume le point	INC.W	D3		; D3 <-- avance en X	DEC.W	D4	JUMP,NE LOOPX$	SWAP.W	D3	INC.W	D3		; D3 <-- avance en Y	SWAP.W	D3	DEC.W	D5	JUMP,NE LOOPY$EXIT$:	POPM.L	D1..D5,A1	RET;-----------\\; MAJGMATRIX >;===========/; Met  jour la grande matrice  l'cran en fonction des diffrences; entre la matrice principale et sa copie.; Seuls les points modifis (allums ou teints) sont r-affichs.; in	-; out	-; mod	D7.WMAJGMATRIX:	PUSHM.L	D1..D5,A1	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,LE EXIT$	LOAD.W	D3,(A6)+OGMOVY	SWAP.W	D3		; D3 <-- position initiale en Y	CLR.L	D5	LOAD.W	D5,(A6)+OGMDIY	DIV.WU	D5,(A6)+OGMLPY	; D5 <-- nb points verticalement	INC.W	D5		; D5 <-- +1 si fraction de pointLOOPY$:	LOAD.W	D3,(A6)+OGMOVX	; D3 <-- position initiale en X	CLR.L	D4	LOAD.W	D4,(A6)+OGMDIX	DIV.WU	D4,(A6)+OGMLPX	; D4 <-- nb points horizontalement	INC.W	D4		; D4 <-- +1 si fraction de pointLOOPX$:	LOAD.L	A1,(A6)+OPMAC	; A1 <-- ^matrice copie	CALL	COULPOINT	; D1 <-- couleur du point	LOAD.L	D2,D1	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	CALL	COULPOINT	; D1 <-- couleur du point	COMP.L	D1,D2		; point identique  la copie ?	JUMP',EQ NEXTX$		; oui => NEXTX$	CALL	DESGPOINT	; dessine un pointNEXTX$:	INC.W	D3		; D3 <-- avance en X	DEC.W	D4	JUMP,NE LOOPX$	SWAP.W	D3	INC.W	D3		; D3 <-- avance en Y	SWAP.W	D3	DEC.W	D5	JUMP,NE LOOPY$EXIT$:	POPM.L	D1..D5,A1	RET;-----------\\; SHOGMATRIX >;===========/; Met  jour la grande matrice  l'cran en fonction de la; matrice principale.; Seuls les points modifis sont r-affichs.; in	D1.L	couleur des points modifis;	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WSHOGMATRIX:	PUSHM.L	D1..D6,A1	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,LE EXIT$	TEST.W	D4	JUMP,LE EXIT$	SWAP.W	D4	TEST.W	D4	JUMP,LE EXIT$	SWAP.W	D4	CALL	_CCMO		; enlve la souris	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	LOAD.L	D2,D1		; D2 <-- couleurLOOPY$:	PUSHM.L	D3,D4LOOPX$:	CALL	COULPOINT	; D1 <-- couleur du point	COMP.L	D1,D2		; est-ce la bonne couleur ?	JUMP',NE NEXTX$		; non => NEXTX$	CALL	DESGPOINT	; dessine le pointNEXTX$:	INC.W	D3		; D3 <-- avance en X	DEC.W	D4	JUMP,NE LOOPX$	POPM.L	D3,D4	SWAP.W	D3	INC.W	D3		; D3 <-- avance en Y	SWAP.W	D3	SWAP.W	D4	DEC.W	D4	LOAD.W	D1,D4	SWAP.W	D4	TEST.W	D1	JUMP,NE LOOPY$EXIT$:	POPM.L	D1..D6,A1	RET;-----------\\; MOVGMATRIX >;===========/; Inverse les points dplacs dans la grande matrice; d'aprs la matrice principale (qui contient le dessin; initial sans les nouveaux points) et le petit rectangle; sur l'cran (qui contient le dessin initial plus le; nouvel objet dessin en inverse).; in	D2.W	mode de dessin (SETDOT/CLRDOT);	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WMOVGMATRIX:	PUSHM.L	D0..D5,A1,A2	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,LE EXIT$	TEST.W	D4	JUMP,LE EXIT$	SWAP.W	D4	TEST.W	D4	JUMP,LE EXIT$	SWAP.W	D4	CALL	_CCMO		; enlve la souris	LOAD.L	D5,D3		; D5 <-- coin sup/gauche	LOAD.W	D0,D2		; D0 <-- mode de dessin	LOAD.L	A2,A0		; A2 <-- description fentreLOOPY$:	PUSHM.L	D4,D5LOOPX$:	PUSH.L	D4	LOAD.L	D4,D5	SUB.W	D4,(A6)+OPMOVX	ADD.W	D4,(A6)+OPMPOX	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	ADD.W	D4,(A6)+OPMPOY	SWAP.W	D4		; D4 <-- coordonne dans petit rectangle	LOAD.L	A1,(A6)+OGDOT	CALL	(A1)		; appel GRA_GDOT, D3 <-- fausse couleur	LOAD.L	D2,D3		; D2 <-- couleur du point dans l'cran	POP.L	D4	LOAD.L	D3,D5	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	CALL	COULPOINT	; D1 <-- couleur du point	COMP.L	D1,D2		; mmes couleurs ?	JUMP',EQ NEXTX$		; oui => NEXTX$;	LOAD.L	D1,D1		; D1 <-- couleur selon matrice principale	COMP.W	D0,#CLRDOT	JUMP',EQ DOT$	LOAD.L	D1,D2		; D1 <-- couleur selon l'cranDOT$:	LOAD.L	D3,D5	CALL	DESGPOINT	; dessine le pointNEXTX$:	INC.W	D5		; D5 <-- avance en X	DEC.W	D4	JUMP,NE LOOPX$	POPM.L	D4,D5	SWAP.W	D5	INC.W	D5		; D5 <-- avance en Y	SWAP.W	D5	SWAP.W	D4	DEC.W	D4	LOAD.W	D1,D4	SWAP.W	D4	TEST.W	D1	JUMP,NE LOOPY$EXIT$:	POPM.L	D0..D5,A1,A2	RET;--------\\; DDINIT  >;========/; Initialise pour un dplacement.; in	D1/D2.L	emplacement nouveau;	D5/D6.L	emplacement initial; out	-; mod	D7.WDDINIT:	PUSHM.L	D1..D4	LOAD.L	(A6)+OLASTD1,D5	LOAD.L	(A6)+OLASTD2,D6	LOAD.L	D3,(A6)+OFLAGS	TEST.L	D3:#BFLAUTO	; automatique ?	JUMP',BC 20$		; non => 20$	LOAD.B	D4,(A6)+OSELECT	; D4 <-- rectangle/filet/crochet	LOAD.B	D3,#2^BFLCONT	COMP.B	D4,#ICOFILET	JUMP',EQ 20$	LOAD.B	D3,#2^BFLOR20$:	LOAD.B	(A6)+ODD,D3	; ODD <-- mode de dplacement	CALL	DDCOPEN		; ouvre la matrice contour	CALL	DDPRECT		; dessine rectangle dans matrice masque	COMP.B	(A6)+ODDOP,#ICODEPLACE	JUMP',EQ 40$	COMP.B	(A6)+ODDOP,#ICODUPLIQUE	JUMP',EQ 40$				; bloc-notes/ajoute =>	CALL	DDMOVE		; dplace dans l'cran	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',EQ EXIT$	CALL	INVSELECT	; dessine le rectangle pointill	JUMP'	EXIT$40$:				; dplace/duplique =>	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE 45$	CALL	INVSELECT	; efface le rectangle pointill45$:	TEST.B	(A6)+ODD:#BFLBOLD	JUMP',BC 60$	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE 60$	CALL	INVSELECT	; efface le rectangle pointill	CALL	DDMOVE		; dplace dans l'cran	CALL	INVSELECT	; redessine le rectangle pointill	JUMP'	EXIT$60$:	CALL	DDMOVE		; dplace dans l'cranEXIT$:	POPM.L	D1..D4	RET;----------\\; DDISOURCE >;==========/; Inverse la zone  dplacer dans la matrice copie.; in	D5/D6.L	emplacement initial; out	-; mod	D7.WDDISOURCE:	PUSHM.L	D1..D5,A3,A4	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP',NS EXIT$		; oui => EXIT$	LOAD.L	D1,D5	LOAD.L	D2,D6	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice masque (source)	LOAD.L	D3,D1	LOAD.L	A4,(A6)+OPMAC	; A4 <-- ^matrice copie (destination)	LOAD.L	D4,D1	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	_XFERZONE	; inverse ...EXIT$:	POPM.L	D1..D5,A3,A4	RET;--------\\; DDCOPEN >;========/; Ouvre la matrice pour extraire le contour.; in	D5/D6.L	emplacement initial; out	D7.W	erreur; mod	D7.WDDCOPEN:	PUSHM.L	D1..D6,A2..A4	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.L	(A0)+ODFCSF,#NBCOUL-1	CLR.L	(A0)+ODFCCF	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+ODD:#BFLCONT	JUMP',BS CONT$	TEST.B	(A6)+ODD:#BFLBOLD	JUMP,BC EXIT$CONT$:	LOAD.L	D1,D5	LOAD.L	D2,D6	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	ADD.W	D2,#6	SWAP.W	D2	ADD.W	D2,#6	SWAP.W	D2	LOAD.L	D5,D1	LOAD.L	D6,D2	LOAD.L	(A6)+ODDDIM,D6	LOAD.L	D4,D2	SWAP.W	D4	ADD.W	D2,#8-1	SR.W	D2,#3	LOAD.W	(A6)+ODDNBB,D2	MUL.WU	D2,(A6)+OMANBP	MUL.WU	D4,D2	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour matrice	JUMP,NE EXIT$	GESMEM	?CLEARMEM	; matrice blanche !	LOAD.L	(A6)+ODDPMA,A4	PUSH.L	D5	LOAD.L	A3,(A6)+OPMAM	LOAD.L	D3,D5;	LOAD.L	A4,(A6)+ODDPMA	LOAD.L	D4,#H'10000*3+3	LOAD.L	D5,D6	SUB.W	D5,#6	SWAP.W	D5	SUB.W	D5,#6	SWAP.W	D5	LOAD.W	D2,#SETDOT	LOAD.W	(A6)+OMANBS,(A6)+OMANBB	LOAD.W	(A6)+OMANBD,(A6)+ODDNBB	CALL	_XFERZONESD	POP.L	D5	PUSH.L	(A6)+OMALMY	PUSH.W	(A6)+OMANBB	LOAD.W	(A6)+OMANBB,(A6)+ODDNBB	LOAD.L	(A6)+OMALMY,D6	LOAD.L	A4,(A6)+ODDPMA	CALL	_OPEDISMAT	; init dessin dans ODDPMA	POP.W	(A6)+OMANBB	POP.L	(A6)+OMALMY	CLR.L	D3	LOAD.L	D4,D6	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle pour dlimiter le tour	LOAD.L	D4,#-1	CALL	_DRMDEF		; dfinit une trame pleine	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWFILLO	LOAD.L	(A3)+1,#H'10000*1+1 ; <xx> et <yy>	LOAD.B	(A3)+5,#DRAWFILLC	LOAD.W	D3,#5+1	LIB	?STRING		; rempli ...	LOAD.L	A4,(A6)+ODDPMA	LOAD.W	D4,(A6)+ODDDIM+0	MUL.WU	D4,(A6)+OMANBP	MUL.WU	D4,(A6)+ODDNBB	SR.L	D4,#2		; D4 <-- /4 car transfert par .L	DEC.W	D4		; D4 <-- -1  cause NMOILOOP$:	NOT.L	(A4+)		; inverse tout (rapidement)	DECJ.W,NMO D4,ILOOP$	TEST.B	(A6)+ODD:#BFLBOLD	JUMP,BC CLOSE$	LOAD.L	A3,(A6)+OPMAM	LOAD.L	D3,D5	LOAD.L	A4,(A6)+ODDPMA;	LOAD.L	D4,#H'10000*3+3	LOAD.L	D5,D6	SUB.W	D5,#6	SWAP.W	D5	SUB.W	D5,#6	SWAP.W	D5	LOAD.W	D2,#SETDOT	LOAD.W	(A6)+OMANBS,(A6)+OMANBB	LOAD.W	(A6)+OMANBD,(A6)+ODDNBB	LOAD.L	A2,#R16"TMOVE$	; A2 <-- ^table pour contour grasBLOOP$:	LOAD.L	D4,(A2+)	JUMP',EQ BFILTRE$	CALL	_XFERZONESD	; diminue un peu le masque !	JUMP	BLOOP$BFILTRE$:	CLR.L	D3	LOAD.L	D4,(A6)+ODDDIM	PUSH.L	(A6)+OPMAT	PUSH.W	(A6)+OMANBB	LOAD.L	(A6)+OPMAT,(A6)+ODDPMA	LOAD.W	(A6)+OMANBB,(A6)+ODDNBB	LOAD.L	A3,#R16"TFILTRE$	CALL	FILOPER		; filtre ...	POP.W	(A6)+OMANBB	POP.L	(A6)+OPMATCLOSE$:	CALL	_CLODISMAT	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D1..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETTMOVE$:	.W	2,2	.W	2,3	.W	2,4	.W	3,2;	.W	3,3		; inutile (si, si !)	.W	3,4	.W	4,2	.W	4,3	.W	4,4	.W	0,0; Toutes les couleurs deviennent noires, le blanc reste blanc :TFILTRE$:	.B	0,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15	.EVEN;---------\\; DDCCLOSE >;=========/; Ferme la matrice pour extraire le contour.; in	-; out	-; mod	D7.WDDCCLOSE:	PUSHM.L	D1,A4	TEST.L	(A6)+ODDPMA	JUMP',EQ EXIT$	LOAD.L	A4,(A6)+ODDPMA	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire	CLR.L	(A6)+ODDPMAEXIT$:	POPM.L	D1,A4	RET;--------\\; DDPRECT >;========/; Dessine (en inverse) le rectangle pointill dans la matrice masque.; in	D5/D6.L	emplacement initial; out	-; mod	D7.WDDPRECT:	PUSHM.L	D1..D4,A4	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,NE EXIT$		; non => EXIT$	LOAD.L	D1,D5		; D1 <-- origine	LOAD.L	D2,D6	SUB.W	D2,D1		; D2 <-- largeur	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1		; D2 <-- hauteur	SWAP.W	D1	SWAP.W	D2	LOAD.L	A4,(A6)+OPMAM	CALL	_OPEDISMAT	; dessine dans la matrice masque	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D3,D1		; D3 <-- origine	LOAD.L	D4,D2		; D4 <-- dimensions	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT		; inverse le rectangle	CALL	_CLODISMAT	; redessine dans l'cranEXIT$:	POPM.L	D1..D4,A4	RET;------------\\; DDINVSELECT >;============/; Inverse le rectangle entourant la zone slectionne par la souris,; seulement si l'chelle est ngative (tout).; in	-; out	-; mod	D7.WDDINVSELECT:	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,NE INVSELECT	; non => INVSELECT	RET			; oui => ne fait rien;--------\\; DDMOVE  >;========/; Dessine les points allums d'une zone rectangulaire dans; le petit et dans le grand rectangle.; in	D5/D6.L	emplacement initial; out	-; mod	D7.WDDMOVE:	PUSHM.L	D0..D6,A1,A3..A5	LOAD.L	D1,(A6)+OSEPHG	LOAD.L	D2,(A6)+OSEPBD	CALL	ORDONNE		; D1/D2 <-- ordonne	EX.L	D1,D5	EX.L	D2,D6	CALL	ORDONNE		; D5/D6 <-- ordonne	EX.L	D1,D5	EX.L	D2,D6; Regarde si le rectangle dpasse la partie visible.	CALL	DDCALCOV	; D4 <-- nouvel emplacement partie visible	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NS 50$		; oui => 50$	PUSH.L	D4		; stack <-- nouvel emplacement; Remet l'tat initial dans la matrice principale (d'aprs la; matrice copie).	PUSHM.L	D1,D2,D5	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.L	A3,(A6)+OPMAC	LOAD.L	D3,(A6)+OLASTD1	TEST.W	D3	JUMP',EQ 15$	DEC.W	D3	INC.W	D515$:	INC.W	D5	LOAD.W	D4,(A6)+OMALMX	SUB.W	D4,D3	COMP.W	D5,D4	JUMP',LS 16$	LOAD.W	D5,D416$:	SWAP.W	D3	SWAP.W	D5	TEST.W	D3	JUMP',EQ 17$	DEC.W	D3	INC.W	D517$:	INC.W	D5	LOAD.W	D4,(A6)+OMALMY	SUB.W	D4,D3	COMP.W	D5,D4	JUMP',LS 18$	LOAD.W	D5,D418$:	SWAP.W	D3	SWAP.W	D5	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D4,D3	LOAD.W	D2,#LOADDOT	; D2 <-- mode de dessin	CALL	_XFERZONE	; matrice principale <-- matrice copie	POPM.L	D1,D2,D5; Si le contour existe, efface le contour dans la matrice principale.	TEST.L	(A6)+ODDPMA	; masque pour contour existe ?	JUMP,EQ 30$		; non => 30$				; oui =>	PUSHM.L	D1,D2,D5,D6	CALL	POSDIM		; D1 <-- pos et D2 <-- dim (nouveau)	LOAD.L	A3,(A6)+ODDPMA	; A3 <-- ^matrice contour (source)	LOAD.L	D3,#H'10000*3+3	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice principale (destination)	LOAD.L	D4,D1	LOAD.L	D5,D2		; D5 <-- dimensions	TEST.B	(A6)+ODD:#BFLBOLD	JUMP,BC 25$	TEST.W	D4	JUMP',EQ 20$	DEC.W	D3	DEC.W	D4	INC.W	D520$:	LOAD.W	D1,D4	ADD.W	D1,D5	COMP.W	D1,(A6)+OMALMX	JUMP',HS 21$	INC.W	D521$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	TEST.W	D4	JUMP',EQ 22$	DEC.W	D3	DEC.W	D4	INC.W	D522$:	LOAD.W	D1,D4	ADD.W	D1,D5	COMP.W	D1,(A6)+OMALMY	JUMP',HS 23$	INC.W	D523$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D525$:	LOAD.W	D2,#CLRDOT	LOAD.W	(A6)+OMANBS,(A6)+ODDNBB	LOAD.W	(A6)+OMANBD,(A6)+OMANBB	CALL	_XFERZONESD	; matrice principale <-- efface l'emplacement	POPM.L	D1,D2,D5,D6; Dessine la zone dplace dans la matrice principale.30$:	PUSHM.L	D1,D2	CALL	POSDIM		; D1 <-- pos et D2 <-- dim (nouveau)	EX.L	D1,D5	EX.L	D2,D6	CALL	POSDIM		; D5 <-- pos et D6 <-- dim (initial)	EX.L	D1,D5	EX.L	D2,D6	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice masque	LOAD.L	D3,D5	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D4,D1	LOAD.L	D5,D6		; D5 <-- dimensions	LOAD.W	D2,#LOADDOT	; D2 <-- mode de dessin	TEST.B	(A6)+ODD:#BFLLOAD	JUMP',BS 35$	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin35$:	CALL	_XFERZONE	; matrice principale <-- zone dplace	POPM.L	D1,D2; Dessine dans l'cran une zone qui englobe l'ancien et le nouvel; emplacement de la partie dplace.	POP.L	D4		; D4 <-- nouvel emplacement	COMP.L	D4,(A6)+OGMOVY	; dplace la partie visible ?	JUMP,NE 50$		; oui => 50$				; non =>	PUSHM.L	D1,D2	COMP.W	D1,(A6)+OLASTD1+2	JUMP',LS 40$	LOAD.W	D1,(A6)+OLASTD1+240$:	SWAP.W	D1	COMP.W	D1,(A6)+OLASTD1+0	JUMP',LS 41$	LOAD.W	D1,(A6)+OLASTD1+041$:	SWAP.W	D1	COMP.W	D2,(A6)+OLASTD2+2	JUMP',HS 42$	LOAD.W	D2,(A6)+OLASTD2+242$:	SWAP.W	D2	COMP.W	D2,(A6)+OLASTD2+0	JUMP',HS 43$	LOAD.W	D2,(A6)+OLASTD2+043$:	SWAP.W	D2	TEST.B	(A6)+ODD:#BFLBOLD	JUMP',BC 49$	TEST.W	D1	JUMP',EQ 45$	DEC.W	D145$:	SWAP.W	D1	TEST.W	D1	JUMP',EQ 46$	DEC.W	D146$:	SWAP.W	D1	COMP.W	D2,(A6)+OMALMX	JUMP',HS 47$	INC.W	D247$:	SWAP.W	D2	COMP.W	D2,(A6)+OMALMY	JUMP',HS 48$	INC.W	D248$:	SWAP.W	D249$:	LOAD.L	A4,(A6)+OPMAT	LOAD.L	D5,D1	LOAD.L	D6,D2	LOAD.W	D0,#LOADDOT	CALL	BBPGMATRIX	; dessine dans l'cran	POPM.L	D1,D2	JUMP'	80$; Dplace la partie visible, car le rectangle dpassait un bord.50$:	LOAD.L	A1,#0		; A1 <-- pas de routine d'inversion	CALL	DDSCROLL	; dplace la partie visible; Mmorise le nouvel emplacement (le prochain coup, ce sera; l'emplacement initial).80$:	LOAD.L	(A6)+OLASTD1,D1	LOAD.L	(A6)+OLASTD2,D2EXIT$:	POPM.L	D0..D6,A1,A3..A5	RET;---------\\; DDCALCOV >;---------/; Calcule la nouvelle origine visible.; in	D1.L	coin sup/gauche (y;x);	D2.L	coin inf/droite (y;x); out	D4.L	nouvelle valeur pour OGMOVY; mod	D4.L, D7.WDDCALCOV:	PUSHM.L	D0..D3	LOAD.L	D3,D1	LOAD.L	D4,(A6)+OGMOVY	; D4 <-- nouvel emplacement partie visible	LOAD.W	D1,D3	CALL	D1SCALEP	; D1 <-- plus petit si "tout"	COMP.W	D1,(A6)+OGMOVX	; dpasse  gauche ?	JUMP',GE 10$	LOAD.W	D4,D110$:	CLR.L	D1	LOAD.W	D1,(A6)+OGMDIX	DIV.WU	D1,(A6)+OGMLPX	; D1 <-- largeur visible	ADD.W	D1,(A6)+OGMOVX	CALL	D1SCALEN	; D1 <-- plus grand si "tout"	SUB.W	D1,D2		; dpasse  droite ?	JUMP',GE 12$	NEG.W	D1	ADD.W	D1,(A6)+OGMOVX	LOAD.W	D4,D112$:	LOAD.W	D1,(A6)+OMALMX	CALL	D1SCALEP	; D1 <-- plus petit si "tout"	CLR.L	D0	LOAD.W	D0,(A6)+OGMDIX	DIV.WU	D0,(A6)+OGMLPX	SUB.W	D1,D0	COMP.W	D4,D1	JUMP',LS 14$	LOAD.W	D4,D114$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D3	CALL	D1SCALEP	; D1 <-- plus petit si "tout"	COMP.W	D1,(A6)+OGMOVY	; dpasse en haut ?	JUMP',GE 20$	LOAD.W	D4,D120$:	CLR.L	D1	LOAD.W	D1,(A6)+OGMDIY	DIV.WU	D1,(A6)+OGMLPY	; D1 <-- hauteur visible	ADD.W	D1,(A6)+OGMOVY	CALL	D1SCALEN	; D1 <-- plus grand si "tout"	SUB.W	D1,D2		; dpasse en bas ?	JUMP',GE 22$	NEG.W	D1	ADD.W	D1,(A6)+OGMOVY	LOAD.W	D4,D122$:	LOAD.W	D1,(A6)+OMALMY	CALL	D1SCALEP	; D1 <-- plus petit si "tout"	CLR.L	D0	LOAD.W	D0,(A6)+OGMDIY	DIV.WU	D0,(A6)+OGMLPY	SUB.W	D1,D0	COMP.W	D4,D1	JUMP',LS 24$	LOAD.W	D4,D124$:;	SWAP.W	D2;	SWAP.W	D3	SWAP.W	D4	POPM.L	D0..D3	RET;---------\\; DDSCROLL >;---------/; Dplace la partie visible.; in	D4.L	nouvelle valeur pour OGMOVY;	A1.L	^routine d'inversion/nil; out	-; mod	D7.WDDSCROLL:	PUSHM.L	D3,D4,A5	LOAD.L	D3,D4		; D3 <-- nouvel emplacement	LOAD.L	D4,(A6)+OGMOVY	; D4 <-- ancien emplacement	COMP.L	D3,D4		; emplacement chang ?	JUMP,EQ EXIT$		; non => EXIT$				; oui =>	COMP.L	A1,#0	JUMP',EQ 20$	CALL	(A1)		; teint qq chose20$:	LOAD.L	(A6)+OGMOVY,D3	LOAD.L	(A6)+OPMOVY,D3	LOAD.W	(A6)+OASHOR+OSCPOSV,D3	SWAP.W	D3	LOAD.W	(A6)+OASVER+OSCPOSV,D3	CALL	DESPMATRIX	; dessine la petite matrice	CALL	DESGMATRIX	; dessine la grande matrice	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC EXIT$		; non => EXIT$				; oui =>	COMP.W	D4,(A6)+OGMOVX	JUMP',EQ 40$	LOAD.L	A5,#(A6)+OASHOR	; A5 <-- ^descripteur ascenseur horizontal	SCROLL_	UPDATE		; dplace l'ascenseur40$:	SWAP.W	D4	COMP.W	D4,(A6)+OGMOVY	JUMP',EQ 50$	LOAD.L	A5,#(A6)+OASVER	; A5 <-- ^descripteur ascenseur vertical	SCROLL_	UPDATE		; dplace l'ascenseur50$:	COMP.L	A1,#0	JUMP',EQ EXIT$	CALL	(A1)		; rallume qq choseEXIT$:	POPM.L	D3,D4,A5	RET;-----------\\; DDPGMATRIX >;===========/; Dessine les points allums d'une zone rectangulaire dans; le petit et dans le grand rectangle.; in	D1/D2.L	emplacement nouveau;	D5/D6.L	emplacement initial;	D0.W	mode de dessin; out	-; mod	D7.WDDPGMATRIX:	PUSH.L	A4	LOAD.L	A4,(A6)+OPMAM	; A4 <-- ^matrice masque	CALL	BBPGMATRIX	POP.L	A4	RET;-----------\\; BBPGMATRIX >;===========/; Dessine les points allums d'une zone rectangulaire dans; le petit et dans le grand rectangle.; in	D1/D2.L	emplacement nouveau;	D5/D6.L	emplacement initial;	A4.L	^matrice initiale;	D0.W	mode de dessin; out	-; mod	D7.WBBPGMATRIX:	PUSHM.L	D1..D6,A1..A4	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP',NC BIG$		; non => BIG$				; oui =>	CALL	DESPMATRIX	; dessine toute la petite matrice	JUMP	EXIT$BIG$:	LOAD.L	A2,A4		; A2 <-- ^matrice initiale; Dessine les points de la zone dans le petit rectangle.	CALL	POSDIM		; D1 <-- pos et D2 <-- dim (nouveau)	EX.L	D1,D5	EX.L	D2,D6	CALL	POSDIM		; D5 <-- pos et D6 <-- dim (initial)	EX.L	D1,D5	EX.L	D2,D6	LOAD.L	A3,A2		; A3 <-- ^matrice source	LOAD.L	D3,D5	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.L	D4,D1	SUB.W	D4,(A6)+OPMOVX	ADD.W	D4,(A6)+OPMPOX	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	ADD.W	D4,(A6)+OPMPOY	SWAP.W	D4	LOAD.L	D5,D6		; D5 <-- dimensions	LOAD.W	D6,(A6)+OPMPOX	COMP.W	D4,D6		; dpasse  gauche ?	JUMP',GE LEFT$	SUB.W	D6,D4	ADD.W	D1,D6	ADD.W	D3,D6	ADD.W	D4,D6	SUB.W	D5,D6LEFT$:	LOAD.W	D6,(A6)+OPMPOX	ADD.W	D6,(A6)+OPMDIX	SUB.W	D6,D4	COMP.W	D5,D6		; dpasse  droite ?	JUMP',LE RIGHT$	LOAD.W	D5,D6RIGHT$:	SWAP.W	D1	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	LOAD.W	D6,(A6)+OPMPOY	COMP.W	D4,D6		; dpasse en haut ?	JUMP',GE UP$	SUB.W	D6,D4	ADD.W	D1,D6	ADD.W	D3,D6	ADD.W	D4,D6	SUB.W	D5,D6UP$:	LOAD.W	D6,(A6)+OPMPOY	ADD.W	D6,(A6)+OPMDIY	SUB.W	D6,D4	COMP.W	D5,D6		; dpasse en bas ?	JUMP',LE DOWN$	LOAD.W	D5,D6DOWN$:	SWAP.W	D1	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	LOAD.W	D2,D0		; D2 <-- mode de dessin	CALL	_XFERZONE	; petit rectangle <-- zone; Dessine les points de la zone dans le grand rectangle.	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,LE EXIT$	TEST.W	D5		; largeur nulle ou ngative ?	JUMP,LE EXIT$		; oui => EXIT$	SWAP.W	D5	TEST.W	D5		; hauteur nulle ou ngative ?	JUMP,LE EXIT$		; oui => EXIT$	SWAP.W	D5;	LOAD.L	D3,D3		; D3 <-- origine (y;x) source	LOAD.L	D4,D1		; D4 <-- origine (y;x) destinationLOOPY$:	PUSHM.L	D3..D5LOOPX$:	LOAD.L	A1,A2		; A1 <-- ^matrice	CALL	COULPOINT	; D1 <-- couleur du point	CALL	DESGPOINT	; dessine le point	INC.W	D3		; D3 <-- avance source en X	INC.W	D4		; D4 <-- avance destination en X	DEC.W	D5	JUMP,NE LOOPX$	POPM.L	D3..D5	SWAP.W	D3	INC.W	D3		; D3 <-- avance source en Y	SWAP.W	D3	SWAP.W	D4	INC.W	D4		; D4 <-- avance destination en Y	SWAP.W	D4	SWAP.W	D5	DEC.W	D5	LOAD.W	D2,D5	SWAP.W	D5	TEST.W	D2	JUMP,NE LOOPY$EXIT$:	POPM.L	D1..D6,A1..A4	RET;----------\\; COULPOINT >;==========/; Donne la couleur d'un point.; ATTENTION: Routine optimise ne fonctionnant qu'avec 4 bits/pixel !!!; in	D3.L	position (y;x);	A1.L	^matrice; out	D1.L	couleur du point;	D7.W	erreur => hors de la matrice; mod	D1.L, D7.WCOULPOINT:	PUSHM.L	D3,D4,A1	CLR.L	D1		; D1 <-- couleur	LOAD.L	D4,D3		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	COMP.W	D3,(A6)+OMALMX	JUMP',HS EXIT$	COMP.W	D4,(A6)+OMALMY	JUMP',HS EXIT$	MUL.WU	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMANBP	ADD.L	A1,D4	SR.W	D3,#1		; ATTENTION: seulement si OMANBP=4 <<<<<<<<<<<<<<<<<<<<	JUMP',CS SET$CLR$:	LOAD.B	D1,(A1)+(D3.W)	SR.B	D1,#4	JUMP'	OK$SET$:	LOAD.B	D1,(A1)+(D3.W)	AND.B	D1,#B'1111;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A1	TEST.W	D7		; retour EQ/NE	RET;---------\\; MODPOINT >;=========/; Modifie la couleur d'un point.; ATTENTION: Routine optimise ne fonctionnant qu'avec 4 bits/pixel !!!; in	D3.L	position (y;x);	A1.L	^matrice;	D1.L	couleur du point; out	D7.W	erreur => hors de la matrice; mod	D7.WMODPOINT:	PUSHM.L	D1,D3,D4,A1	LOAD.L	D4,D3		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	COMP.W	D3,(A6)+OMALMX	JUMP',HS EXIT$	COMP.W	D4,(A6)+OMALMY	JUMP',HS EXIT$	MUL.WU	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMANBP	ADD.L	A1,D4	SR.W	D3,#1		; ATTENTION: seulement si OMANBP=4 <<<<<<<<<<<<<<<<<<<<	JUMP',CS SET$CLR$:	SL.B	D1,#4	AND.B	(A1)+(D3.W),#B'00001111	OR.B	(A1)+(D3.W),D1	JUMP'	OK$SET$:	AND.B	D1,#B'00001111	AND.B	(A1)+(D3.W),#B'11110000	OR.B	(A1)+(D3.W),D1;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D3,D4,A1	TEST.W	D7		; retour EQ/NE	RET;--------\\; ADPOINT >;========/; Donne l'adresse d'un point.; ATTENTION: Routine optimise ne fonctionnant qu'avec 4 bits/pixel !!!; in	D3.L	position (y;x);	A1.L	^matrice; out	A1.L	^byte;	D7.W	erreur => hors de la matrice; mod	D7.W, A1.LADPOINT:	PUSHM.L	D3,D4	LOAD.L	D4,D3		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	COMP.W	D3,(A6)+OMALMX	JUMP',HS EXIT$	COMP.W	D4,(A6)+OMALMY	JUMP',HS EXIT$	MUL.WU	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMANBP	ADD.L	A1,D4	SR.W	D3,#1		; ATTENTION: seulement si OMANBP=4 <<<<<<<<<<<<<<<<<<<<	ADD.W	A1,D3	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DESPPOINT >;==========/; Dessine un point dans la petite matrice.; S'il est en dehors de la partie visible, ne dessine rien !; in	D3.L	position du point (y;x);	D1.L	couleur du point; out	-; mod	D7.WDESPPOINT:	PUSHM.L	D0,D1,D3,D4,A1,A2	PUSH.L	(A0)+ODFCSF	LOAD.L	(A0)+ODFCSF,D1	LOAD.L	D1,D3	CALL	D1SCALEP	; D1 <-- plus petit si "tout"	LOAD.L	D4,D1	SUB.W	D4,(A6)+OPMOVX	; dpasse  gauche ?	JUMP',LO EXIT$	COMP.W	D4,(A6)+OPMDIX	; dpasse  droite ?	JUMP',HS EXIT$	ADD.W	D4,(A6)+OPMPOX	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	; dpasse en haut ?	JUMP',LO EXIT$	COMP.W	D4,(A6)+OPMDIY	; dpasse en bas ?	JUMP',HS EXIT$	ADD.W	D4,(A6)+OPMPOY	SWAP.W	D4	CALL	_CCMO		; enlve la souris	LOAD.W	D1,#SETDOT	; D1 <-- mode	LOAD.L	A2,A0		; A2 <-- description fentre	LOAD.L	A1,(A6)+ODOT	CALL	(A1)		; appel GRA_DOTEXIT$:	POP.L	(A0)+ODFCSF	POPM.L	D0,D1,D3,D4,A1,A2	RET;----------\\; DESGPOINT >;==========/; Dessine un point dans la grande matrice.; S'il est en dehors de la partie visible, ne dessine rien !; in	D3.L	position du point (y;x);	D1.L	couleur du point; out	-; mod	D7.WDESGPOINT:	PUSHM.L	D0..D4	PUSH.L	(A0)+ODFCSF	LOAD.L	(A0)+ODFCSF,D1	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,LE EXIT$	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	LOAD.L	D4,D3		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	SUB.W	D3,(A6)+OGMOVX 	JUMP,LT EXIT$	MUL.WU	D3,(A6)+OGMLPX	ADD.W	D3,(A6)+OGMPOX	SUB.W	D4,(A6)+OGMOVY	JUMP,LT EXIT$	MUL.WU	D4,(A6)+OGMLPY	ADD.W	D4,(A6)+OGMPOY	SWAP.W	D3	LOAD.W	D3,D4		; D3 <-- position (y;x)	SWAP.W	D3	LOAD.W	D4,(A6)+OGMLPY	DEC.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OGMLPX	DEC.W	D4	LOAD.W	D0,(A6)+OGMPOX	ADD.W	D0,(A6)+OGMDIX	SUB.W	D0,D3	JUMP,LE EXIT$	COMP.W	D4,D0		; point dpasse  droite ?	JUMP',LT 40$	LOAD.W	D4,D040$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,(A6)+OGMPOY	ADD.W	D0,(A6)+OGMDIY	SUB.W	D0,D3	JUMP,LE EXIT$	COMP.W	D4,D0		; point dpasse en bas ?	JUMP',LT 45$	LOAD.W	D4,D045$:	SWAP.W	D3	SWAP.W	D4; Si on est  ct du petit rectangle, gre correctement le clipping; pour dessiner la ou les deux parties rectangulaires du point.	LOAD.L	D0,D3	SWAP.W	D0	SUB.W	D0,(A6)+OPRPOY	SUB.W	D0,(A6)+OPRDIY	SUB.W	D0,#2		;  ct du petit rectangle ?	JUMP',PL 70$		; non => 70$				; oui =>	LOAD.W	D0,D3	ADD.W	D0,D4	SUB.W	D0,(A6)+OPRPOX	ADD.W	D0,#2		; touche le bord gauche du rectangle ?	JUMP',MI 70$		; non => 70$				; oui =>	LOAD.W	D0,(A6)+OPRPOX	SUB.W	D0,#2	SUB.W	D0,D3	JUMP',LE 60$	PUSH.W	D4	LOAD.W	D4,D0	CALL	GPOINT		; dessine la partie gauche du point	POP.W	D4	ADD.W	D3,D0	SUB.W	D4,D060$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,(A6)+OPRPOY	ADD.W	D0,(A6)+OPRDIY	ADD.W	D0,#2	SUB.W	D0,D3	ADD.W	D3,D0	SUB.W	D4,D0	JUMP',LE EXIT$	SWAP.W	D4	SWAP.W	D370$:	CALL	GPOINT		; dessine un gros pointEXIT$:	POP.L	(A0)+ODFCSF	POPM.L	D0..D4	RET;--------\\; GPOINT  >;--------/; Dessine un gros point (surface pleine).;; Joue sur la constation suivante :;  GRA_SET/CLEAR/INV	->	rapide si grande surface;  GRA_TRAME		->	rapide si petite surface; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WGPOINT:	PUSHM.L	D1,D3,D4,A1,A2,A4	CALL	_CCMO		; enlve la souris	EX.L	D3,D4		; D4 <-- (y;x) et D3 <-- (dy;dx)	LOAD.L	A2,A0		; A2 <-- ^description fentre	COMP.W	D2,#SETDOT	JUMP',EQ 60$	COMP.W	D2,#CLRDOT	JUMP',EQ 40$	LOAD.W	D1,D2	LOAD.L	A4,#R16"01$	LOAD.L	A1,(A6)+OTRAME	CALL	(A1)		; inverse le point	JUMP'	EXIT$40$:	COMP.W	D3,#32		; grande surface ?	JUMP',HS 50$		; oui => 50$	LOAD.W	D1,D2	LOAD.L	A4,#R16"00$	LOAD.L	A1,(A6)+OTRAME	CALL	(A1)		; efface le point	JUMP'	EXIT$50$:	LOAD.L	A1,(A6)+OCLEAR	CALL	(A1)		; efface le point	JUMP'	EXIT$60$:	LOAD.W	D1,D2	LOAD.L	A4,#R16"01$	LOAD.L	A1,(A6)+OTRAME	CALL	(A1)		; allume le point;	JUMP'	EXIT$EXIT$:	POPM.L	D1,D3,D4,A1,A2,A4	RET00$:	.B	H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'0001$:	.B	H'FF,H'FF,H'FF,H'FF,H'FF,H'FF,H'FF,H'FF	.EVEN;----------\\; DETGPOINT >;==========/; Comme DETGPOINTF, mais en tenant compte du pas !; in	D4.L	position de la souris (y;x); out	D3.L	position du point (y;x);	D7.W	ok/erreur; mod	D3.L, D7.WDETGPOINT:	CALL	DETGPOINTF	; D3 <-- position brutte	CALL	PASGPOINT	; D3 <-- position arrondie	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DETGPOINTF >;===========/; Dtecte dans quel point de la grande matrice est la souris.; En cas d'erreur, rend la position la plus proche !; in	D4.L	position de la souris (y;x); out	D3.L	position du point (y;x);	D7.W	ok/erreur; mod	D3.L, D7.WDETGPOINTF:	PUSH.L	D4	CLR.W	D7		; D7 <-- dans la matrice; Vrifie d'abord si la souris est dans le petit rectangle.	LOAD.L	D3,D4	SUB.W	D3,(A6)+OPRPOX	; souris trop  gauche ?	JUMP',LO 10$	COMP.W	D3,(A6)+OPRDIX	; souris trop  droite ?	JUMP',HS 10$	SWAP.W	D3	SUB.W	D3,(A6)+OPRPOY	; souris trop en haut ?	JUMP',LO 10$	COMP.W	D3,(A6)+OPRDIY	; souris trop en bas ?	JUMP',HS 10$; Donne les positions dans la petite matrice, en tenant compte; des marges entre le petit rectangle et la petite matrice.	LOAD.L	D3,D4	SUB.W	D3,(A6)+OPMPOX	; souris trop  gauche ?	JUMP',HS 02$	CLR.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice02$:	COMP.W	D3,(A6)+OPMDIX	; souris trop  droite ?	JUMP',LO 03$	LOAD.W	D3,(A6)+OPMDIX	DEC.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice03$:	ADD.W	D3,(A6)+OPMOVX	SWAP.W	D3	SUB.W	D3,(A6)+OPMPOY	; souris trop en haut ?	JUMP',HS 04$	CLR.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice04$:	COMP.W	D3,(A6)+OPMDIY	; souris trop  gauche ?	JUMP',LO 05$	LOAD.W	D3,(A6)+OPMDIY	DEC.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice05$:	ADD.W	D3,(A6)+OPMOVY	SWAP.W	D3	EX.L	D1,D3	CALL	D1SCALEN	; D3 <-- plus grand si "tout"	EX.L	D3,D1	JUMP	EXIT$; Dtecte o est la souris dans la grande matrice.10$:	CLR.L	D3	LOAD.W	D3,D4		; D3 <-- position en X	CLR.W	D4	SWAP.W	D4		; D4 <-- position en Y	SUB.W	D3,(A6)+OGMPOX	; souris trop  gauche ?	JUMP',HS 20$	CLR.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice20$:	COMP.W	D3,(A6)+OGMDIX	; souris trop  droite ?	JUMP',LO 21$	LOAD.W	D3,(A6)+OGMDIX	DEC.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice21$:	DIV.WU	D3,(A6)+OGMLPX	ADD.W	D3,(A6)+OGMOVX	COMP.W	D3,(A6)+OMALMX	JUMP',LO 22$	LOAD.W	D3,(A6)+OMALMX	DEC.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice22$:	SUB.W	D4,(A6)+OGMPOY	; souris trop en haut ?	JUMP',HS 40$	CLR.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice40$:	COMP.W	D4,(A6)+OGMDIY	; souris trop en bas ?	JUMP',LO 41$	LOAD.W	D4,(A6)+OGMDIY	DEC.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice41$:	DIV.WU	D4,(A6)+OGMLPY	ADD.W	D4,(A6)+OGMOVY	SWAP.W	D3	LOAD.W	D3,D4		; D3 <-- position (y;x)	SWAP.W	D3EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DETGPOINTOUT >;=============/; Dtecte o est la souris, mme si elle dpasse la surface de dessin.; in	D4.L	position de la souris (y;x); out	D3.L	position du point (y;x); mod	D3.L, D7.WDETGPOINTOUT:	PUSH.L	D4	CLR.W	D7		; D7 <-- dans la matrice	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',GT 30$; Dtecte o est la souris dans la petite matrice.	LOAD.L	D3,D4	SUB.W	D3,(A6)+OPMPOX	ADD.W	D3,(A6)+OPMOVX	SWAP.W	D3	SUB.W	D3,(A6)+OPMPOY	ADD.W	D3,(A6)+OPMOVY	SWAP.W	D3	EX.L	D1,D3	CALL	D1SCALEN	; D3 <-- plus grand si "tout"	EX.L	D3,D1	JUMP'	50$; Dtecte o est la souris dans la grande matrice.30$:	LOAD.W	D3,D4		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	SUB.W	D3,(A6)+OGMPOX	CONV.LA.WA D3	DIV.WA	D3,(A6)+OGMLPX	ADD.W	D3,(A6)+OGMOVX	SUB.W	D4,(A6)+OGMPOY	CONV.LA.WA D4	DIV.WA	D4,(A6)+OGMLPY	ADD.W	D4,(A6)+OGMOVY	SWAP.W	D3	LOAD.W	D3,D4		; D3 <-- position (y;x)	SWAP.W	D3; Si on dpasse la matrice, ramne la position dedans.50$:	TEST.W	D3	JUMP',NC 60$	CLR.W	D360$:	COMP.W	D3,(A6)+OMALMX	JUMP',LO 61$	LOAD.W	D3,(A6)+OMALMX	DEC.W	D361$:	SWAP.W	D3	TEST.W	D3	JUMP',NC 62$	CLR.W	D362$:	COMP.W	D3,(A6)+OMALMY	JUMP',LO 63$	LOAD.W	D3,(A6)+OMALMY	DEC.W	D363$:	SWAP.W	D3	POP.L	D4	RET;----------\\; PASGPOINT >;==========/; Arrondi une coordonne selon le pas.; in	D3.L	coordonne (y;x); out	D3.L	coordonne (y;x); mod	D3.LPASGPOINT:	PUSHM.L	D1,D2,D4	LOAD.W	D2,(A6)+OPAS	; D2 <-- pas	COMP.W	D2,#1	JUMP',EQ EXIT$	LOAD.W	D1,D2	SR.W	D1,#1		; D1 <-- 1/2 pas	LOAD.L	D4,D3		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	ADD.W	D3,D1	CONV.LA.WA D3	DIV.WA	D3,D2	MUL.WA	D3,D2	ADD.W	D4,D1	CONV.LA.WA D4	DIV.WA	D4,D2	MUL.WA	D4,D2	SWAP.W	D3	LOAD.W	D3,D4		; D3 <-- coordonne arrondie (y;x)	SWAP.W	D3EXIT$:	POPM.L	D1,D2,D4	RET;-----------\\; CONVGPOINT >;===========/; Transforme la coordonne d'un point dans la grande matrice; en un point dans l'cran.; in	D3.L	position d'un point (y;x); out	D3.L	position dans l'cran (y;x);	D7.W	erreur; mod	D3.L, D7.WCONVGPOINT:	PUSH.L	D2	CLR.W	D7		; D7 <-- ok	EX.L	D1,D3	CALL	D1SCALEP	; D3 <-- plus petit si "tout"	EX.L	D3,D1	SUB.W	D3,(A6)+OGMOVX	; dpasse  gauche ?	JUMP',GE 10$	LOAD.W	D7,#1		; D7 <-- en dehors10$:	SWAP.W	D3	SUB.W	D3,(A6)+OGMOVY	; dpasse en haut ?	JUMP',GE 12$	LOAD.W	D7,#1		; D7 <-- en dehors12$:	SWAP.W	D3	LOAD.W	D2,D3	MUL.WA	D2,(A6)+OGMLPX	; D3 <-- plus grand si "loupe"	LOAD.W	D3,D2	SWAP.W	D3	LOAD.W	D2,D3	MUL.WA	D2,(A6)+OGMLPY	; D3 <-- plus grand si "loupe"	LOAD.W	D3,D2	SWAP.W	D3	COMP.W	D3,(A6)+OGMDIX	; dpasse  droite ?	JUMP',LE 20$	LOAD.W	D7,#1		; D7 <-- en dehors20$:	ADD.W	D3,(A6)+OGMPOX	SWAP.W	D3	COMP.W	D3,(A6)+OGMDIY	; dpasse en bas ?	JUMP',LE 22$	LOAD.W	D7,#1		; D7 <-- en dehors22$:	ADD.W	D3,(A6)+OGMPOY	SWAP.W	D3	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE EXIT$	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3EXIT$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET	.END