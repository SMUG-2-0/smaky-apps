	.SBTTL	PICCADRE.ASI;--------\\; ICAMOVE >;========/; Dplace une icne dans le cadre.; in	D4.L	position de la souris (y;x); out	D2.W	icne (0..n);	D7.W	erreur; mod	D2.L, D7.WICAMOVE:	PUSHM.L	D1,D3,D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORCINFO	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	; donne la couleur relative pour dessiner	CALL	ICADET		; souris dans une icne ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.W	D1,D2	JUMP'	NEW$LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE END$		; non => END$	CALL	__IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	ICADET		; D2 <-- icne o est la souris	COMP.W	D2,D1		; est-on toujours dans la mme icne ?	JUMP,EQ LOOP$		; oui => LOOP$	EX.L	D2,D1	CALL	ICAINV		; teint l'ancienne icneNEW$:	LOAD.W	D2,D1	CALL	ICAINV		; allume la nouvelle icne	JUMP	LOOP$END$:	LOAD.W	D2,D1	CALL	ICAINV		; teint l'ancienne icne	CLR.W	D7		; D7 <-- okEXIT$:	PUSH.W	D7	LIB	?COLORPOP	; restitue les couleurs	POP.W	D7	POPM.L	D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ICADET  >;--------/; Dtecte dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	icne (0..n);	D7.W	erreur; mod	D2.L, D7.WICADET:	PUSHM.L	D3..D6	LOAD.W	D5,D4		; D5 <-- position en X	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- position en Y	CLR.W	D2LOOP$:	CALL	ICAPOS		; D3/D4 <--position/dimensions	JUMP',NE ERROR$	COMP.W	D5,D3	JUMP',LO NEXT$	ADD.W	D3,D4	COMP.W	D5,D3	JUMP',HS NEXT$	SWAP.W	D3	SWAP.W	D4	COMP.W	D6,D3	JUMP',LO NEXT$	ADD.W	D3,D4	COMP.W	D6,D3	JUMP',LO EXIT$NEXT$:	INC.W	D2	JUMP	LOOP$ERROR$:	LOAD.W	D2,#-1EXIT$:	POPM.L	D3..D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; ICAINV  >;--------/; Inverse une icne.; in	D2.W	numro (0..n); out	-; mod	D7.WICAINV:	PUSHM.L	D2..D4	COMP.W	D2,#-1	JUMP',EQ EXIT$	LOAD.L	D4,#-1	CALL	__DRMDEF	CALL	ICAPOS		; D3/D4 <--position/dimensions	JUMP',NE EXIT$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse l'icneEXIT$:	POPM.L	D2..D4	RET;--------\\; ICAPOS  >;--------/; Donne la position et les dimensions d'une icne dans le cadre.; in	D2.W	numro (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WICAPOS:	LOAD.W	D3,#POSZONE	LOAD.W	D4,#3	TEST.W	D2	JUMP',EQ OK$	LOAD.W	D3,#POSSCALE	LOAD.W	D4,#4	COMP.W	D2,#1	JUMP',EQ OK$	LOAD.W	D3,#POSPAS;	LOAD.W	D4,#4	COMP.W	D2,#2	JUMP',EQ OK$	LOAD.W	D7,#1	JUMP'	EXIT$OK$:	MUL.WU	D3,(A0)+ODFCX	MUL.WU	D4,(A0)+ODFCX	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	INC.W	D4	SWAP.W	D4	CLR.W	D7		; D7 <-- okEXIT$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; DESWDO  >;========/; Grise toute la fentre et place les icnes.; in	-; out	-; mod	D7.WDESWDO:	PUSHM.L	D2..D4	CALL	__ERGMOUSE	; efface les flches dans les rgles	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORFOND	LIB	?COLORCR	; donne la couleur relative pour effacer	CALL	DESMDEF		; D4 <-- trame grise pour le fond	CALL	__DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; grise toute la fentre	LIB	?COLORPOP	LOAD.L	D4,#-1	CALL	__DRMDEF	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	; donne la couleur relative pour dessiner	CLR.L	D3	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LOAD.W	D4,(A0)+ODFFDX;	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; dessine une bande blanche en haut	LIB	?COLORPOP	CALL	DESINFO		; affiche les informations	CALL	DESINFZONE	; affiche la zone	CALL	DESINFSC	; affiche l'chelle	CALL	DESINFPA	; affiche le pas	CALL	DESINFFILE	; affiche le nom du dessin	CLR.L	D4	CALL	__DRMDEF	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,#ICOLY	SWAP.W	D4	LOAD.W	D4,#MARGX+GCIMX	LOAD.L	(A6)+ODICO,D4	; ODICO <-- position pour icnes  gauche	CALL	DESICONE	; dessine toutes les icnes	CALL	MAJICONE	; mj les icnes variables	POPM.L	D2..D4	RET;--------\\; DESMDEF >;========/; Dtermine la trame grise pour le fond.; in	-; out	D4.L	trame grise; mod	D4.L, D7.WDESMDEF:	LOAD.L	D4,#H'88882222	; D4 <-- trame pour cran entrelac	COMP.B	(A6)+OMACHINE,#SMAKY8	JUMP',EQ EXIT$	LOAD.L	D4,#H'88228822	; D4 <-- trame pour joli cranEXIT$:	RET;---------\\; MAJICONE >;=========/; Met  jour les icnes "variables".; in	-; out	-; mod	D7.WMAJICONE:	PUSH.L	D3	LOAD.B	D3,(A6)+OXICO	COMP.B	D3,#NIVSPLINE1	JUMP,EQ COURBE$	COMP.B	D3,#NIVSPLINE2	JUMP,EQ COURBE$	COMP.B	D3,#NIVDEFORME	JUMP,EQ DEFORME$	COMP.B	D3,#NIVTEXTE	JUMP,EQ	TEXTE$	COMP.B	D3,#NIVRELIEF	JUMP,EQ	RELIEF$	COMP.B	D3,#NIVTRAME	JUMP,EQ	TRAME$	COMP.B	D3,#NIVLISSE	JUMP,EQ	LISSE$	TEST.B	D3		; icnes spciales ?	JUMP,NE EXIT$		; oui => EXIT$	CALL	DESCOLOR	; dessine les couleurs	CALL	DESPDEF		; dessine l'icne du pinceau	CALL	DESTDEF		; dessine l'icne de la trame	CALL	DESLOUPE	; dessine la loupe;;?	TEST.W	(A6)+OSCALE;;?	JUMP',NS ICO2$	LOAD.B	D3,(A6)+OOUTIL	CALL	INVICONE	; outil par dfaut	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; objet par dfaut;;?ICO2$:	LOAD.B	D3,(A6)+OSELECT	CALL	INVICONE	; slection par dfaut	JUMP	EXIT$COURBE$:	LOAD.B	D3,(A6)+OSPLOF	CALL	INVICONE	; allume ouvert/ferm	LOAD.B	D3,(A6)+OSTRHV	JUMP,EQ EXIT$	CALL	INVICONE	; allume horizontal/vertical/rien	JUMP	EXIT$DEFORME$:	LOAD.B	D3,(A6)+OSTRDF	CALL	INVICONE	; allume le type de dformation	LOAD.B	D3,(A6)+OSTRRO	CALL	INVICONE	; allume le sens de la rotation	LOAD.B	D3,(A6)+OSTRHV	JUMP,EQ EXIT$	CALL	INVICONE	; allume horizontal/vertical/rien	JUMP	EXIT$TEXTE$:	LOAD.B	D3,(A6)+OJUTEXT	CALL	INVICONE	; justification par dfaut	TEST.B	(A6)+OCMTEXT	JUMP',F TEXTE2$	LOAD.B	D3,#ICODIVISE	CALL	INVICONE	; allume les ciseauxTEXTE2$:	TEST.B	(A6)+OCTTEXT	JUMP',F TEXTE3$	LOAD.B	D3,#ICOCONTOUR	CALL	INVICONE	; allume le contourTEXTE3$:	LOAD.B	D3,(A6)+OHVTEXT	JUMP',EQ TEXTE4$	CALL	INVICONE	; allume horizontal/verticalTEXTE4$:	CALL	DESCSPACE	; dessine l'espacement entre caractres	CALL	DESCCOUPE	; dessine le critre pour les divisions	CALL	DESESPCX	; dessine l'espace pour le contour en X	CALL	DESESPCY	; dessine l'espace pour le contour en Y	CALL	DESITL		; dessine l'interligne	CALL	DESITC		; dessine l'intercaractre	JUMP	EXIT$RELIEF$:	CLR.W	D3RELIEF2$:	CALL	DESXDEF		; dessine le type de relief	INC.W	D3	COMP.W	D3,#8	JUMP,LO RELIEF2$	JUMP'	EXIT$TRAME$:	CALL	DESTRAP		; dessine le pas	CALL	DESTRAN		; dessine le niveau	CALL	DESTRAL		; dessine la luminosit	LOAD.W	D3,(A6)+OTRAFA	ADD.W	D3,#ICOTRAF1	CALL	INVICONE	; allume la famille de trames	JUMP'	EXIT$LISSE$:	LOAD.W	D3,(A6)+OLISLU	ADD.W	D3,#ICOLISSEM	CALL	INVICONE	; allume la luminosit;	JUMP'	EXIT$EXIT$:	POP.L	D3	RET;--------------\\; FULLGREYICONE >;==============/; Grise ou dgrise toutes les icnes ncessaires.; in	-; out	-; mod	D7.WFULLGREYICONE:	PUSHM.L	D3,D4,A4	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP,BC EXIT$		; non => EXIT$	LOAD.B	D3,(A6)+OXICO	COMP.B	D3,#NIVSPLINE1	JUMP,EQ COURBE$	COMP.B	D3,#NIVSPLINE2	JUMP,EQ COURBE$	COMP.B	D3,#NIVDEFORME	JUMP,EQ DEFORME$	COMP.B	D3,#NIVTEXTE	JUMP,EQ	TEXTE$	COMP.B	D3,#NIVRELIEF	JUMP,EQ	RELIEF$	COMP.B	D3,#NIVTRAME	JUMP,EQ	TRAME$	COMP.B	D3,#NIVLISSE	JUMP,EQ	LISSE$	TEST.B	D3		; icnes spciales ?	JUMP,NE EXIT$		; oui => EXIT$	LOAD.L	A4,#(A6)+OBLOC	LOAD.W	D4,#NBBLOC-1	LOAD.B	D3,#ICOBLOC1ICONE2$:	CLR.W	D7		; D7 <-- dgrise	TEST.L	(A4)+OBLKPT	; bloc-notes contient qq chose ?	JUMP',NE ICONE4$	COMP.B	D3,(A6)+OOBJET	JUMP',NE ICONE3$	PUSH.W	D3	CALL	INVICONE	; teint le bloc-notes	LOAD.B	D3,#ICOTRAIT	CALL	INVICONE	; allume le trait  main leve	LOAD.B	(A6)+OOBJET,D3	LOAD.B	D3,#ICOCRAYON	CALL	INVICONE	; allume le crayon	LOAD.B	(A6)+OOUTIL,D3	POP.W	D3ICONE3$:	INC.W	D7		; D7 <-- griseICONE4$:	CALL	GREYICONE	LOAD.L	A4,#(A4)+LGBLOC	; A4 <-- ^bloc-notes suivant	INC.B	D3	DECJ.W,NMO D4,ICONE2$	CLR.W	D7		; D7 <-- dgrise	TEST.W	(A6)+OASVER+OSCHTV	JUMP',NE ICONE6$	TEST.W	(A6)+OASHOR+OSCHTV	JUMP',NE ICONE6$	COMP.B	(A6)+OOUTIL,#ICOMAIN	JUMP',NE ICONE5$	LOAD.B	D3,#ICOMAIN	CALL	INVICONE	; teint la main	LOAD.B	D3,#ICOCRAYON	CALL	INVICONE	; allume le crayon	LOAD.B	(A6)+OOUTIL,D3	LOAD.B	D3,#ICOTRAIT	CALL	INVICONE	; allume le trait  main leve	LOAD.B	(A6)+OOBJET,D3ICONE5$:	INC.W	D7		; D7 <-- griseICONE6$:	LOAD.B	D3,#ICOMAIN	CALL	GREYICONE	TEST.W	(A6)+OCHBLOC	; module BLOC charg ?	JUMP,NE EXIT$		; oui => EXIT$	LOAD.W	D7,#1		; D7 <-- grise	LOAD.B	D3,#ICOCOLLE	CALL	GREYICONE	; grise l'icne "colle"	JUMP	EXIT$COURBE$:	CLR.W	D7		; D7 <-- dgrise	LOAD.L	A4,#(A6)+OSPLPT	; A4 <-- ^table des points	COMP.B	(A6)+OSPLOF,#ICOSPLINEO ; spline ouvert ?	JUMP',NE COURBE2$				; spline ouvert =>	COMP.L	(A4)+4,#-1	; seulement 1 points ?	JUMP',NE COURBE4$	; non => COURBE4$	JUMP'	COURBE3$COURBE2$:			; spline ferm =>	COMP.L	(A4)+8,#-1	; seulement 2 points ?	JUMP',NE COURBE4$	; non => COURBE4$COURBE3$:	INC.W	D7		; D7 <-- griseCOURBE4$:	LOAD.B	D3,#ICODACCORD	CALL	GREYICONE	JUMP	EXIT$DEFORME$:	CLR.W	D7		; D7 <-- dgrise	LOAD.L	D4,(A6)+OSEPHG	COMP.L	D4,(A6)+OSEOHG	JUMP',NE DEFORME2$	LOAD.L	D4,(A6)+OSEPHD	COMP.L	D4,(A6)+OSEOHD	JUMP',NE DEFORME2$	LOAD.L	D4,(A6)+OSEPBG	COMP.L	D4,(A6)+OSEOBG	JUMP',NE DEFORME2$	LOAD.L	D4,(A6)+OSEPBD	COMP.L	D4,(A6)+OSEOBD	JUMP',NE DEFORME2$	INC.W	D7		; D7 <-- griseDEFORME2$:	LOAD.B	D3,#ICOINIT4	CALL	GREYICONE	LOAD.B	D3,#ICOINIT0	CALL	GREYICONE	COMP.B	(A6)+OYICO,#ICOZOOM	JUMP',EQ ZOOM$	COMP.B	(A6)+OYICO,#ICOTOURNE	JUMP,EQ TOURNE$	JUMP	EXIT$ZOOM$:	LOAD.B	D3,#ICOZOOMAA	CALL	OPEROK$	CALL	GREYICONE	LOAD.B	D3,#ICOZOOMAI	CALL	OPEROK$	CALL	GREYICONE	LOAD.B	D3,#ICOZOOMIA	CALL	OPEROK$	CALL	GREYICONE	JUMP	EXIT$TOURNE$:	LOAD.B	D3,#ICOT10D	CALL	OPEROK$	CALL	GREYICONE	LOAD.B	D3,#ICOT20D	CALL	OPEROK$	CALL	GREYICONE	LOAD.B	D3,#ICOT30D	CALL	OPEROK$	CALL	GREYICONE	LOAD.B	D3,#ICOT45D	CALL	OPEROK$	CALL	GREYICONE	LOAD.B	D3,#ICOT60D	CALL	OPEROK$	CALL	GREYICONE	LOAD.B	D3,#ICOT90D	CALL	OPEROK$	CALL	GREYICONE	JUMP	EXIT$TEXTE$:	CLR.W	D7		; D7 <-- dgrise	COMP.B	(A6)+OJUTEXT,#ICOJUSTA	JUMP',EQ TEXTE2$	INC.W	D7		; D7 <-- griseTEXTE2$:	LOAD.L	A4,#R16"DESCSPACE	LOAD.B	D3,#ICOCSPACE	CALL	TEXTOK$	CLR.W	D7		; D7 <-- dgrise	TEST.B	(A6)+OCMTEXT	JUMP',T TEXTE3$	INC.W	D7		; D7 <-- griseTEXTE3$:	LOAD.L	A4,#R16"DESCCOUPE	LOAD.B	D3,#ICOCCOUPE	CALL	TEXTOK$	CLR.W	D7		; D7 <-- dgrise	TEST.B	(A6)+OCTTEXT	JUMP',T TEXTE4$	INC.W	D7		; D7 <-- griseTEXTE4$:	LOAD.L	A4,#R16"DESESPCX	LOAD.B	D3,#ICOESPCONTX	CALL	TEXTOK$	CLR.W	D7		; D7 <-- dgrise	TEST.B	(A6)+OCTTEXT	JUMP',T TEXTE5$	INC.W	D7		; D7 <-- griseTEXTE5$:	LOAD.L	A4,#R16"DESESPCY	LOAD.B	D3,#ICOESPCONTY	CALL	TEXTOK$	JUMP	EXIT$RELIEF$:	CLR.W	D7		; D7 <-- dgrise	TEST.W	(A6)+OPTREL	JUMP',NE RELIEF2$	INC.W	D7		; D7 <-- griseRELIEF2$:	LOAD.B	D3,#ICORELANN	CALL	GREYICONE	LOAD.B	D3,#ICOINIT0	CALL	GREYICONE	JUMP	EXIT$TRAME$:	CLR.W	D7		; D7 <-- dgrise	COMP.W	(A6)+OTRAPA,#2	JUMP',NE TRAME1$	INC.W	D7		; D7 <-- griseTRAME1$:	LOAD.B	D3,#ICOTRAPM	CALL	GREYICONE	CLR.W	D7		; D7 <-- dgrise	COMP.W	(A6)+OTRAPA,#64	JUMP',NE TRAME2$	INC.W	D7		; D7 <-- griseTRAME2$:	LOAD.B	D3,#ICOTRAPP	CALL	GREYICONE	CLR.W	D7		; D7 <-- dgrise	COMP.W	(A6)+OTRANI,#2	JUMP',NE TRAME3$	INC.W	D7		; D7 <-- griseTRAME3$:	LOAD.B	D3,#ICOTRANM	CALL	GREYICONE	CLR.W	D7		; D7 <-- dgrise	COMP.W	(A6)+OTRANI,#16	JUMP',NE TRAME4$	INC.W	D7		; D7 <-- griseTRAME4$:	LOAD.B	D3,#ICOTRANP	CALL	GREYICONE	CLR.W	D7		; D7 <-- dgrise	COMP.W	(A6)+OTRALU,#-8	JUMP',NE TRAME5$	INC.W	D7		; D7 <-- griseTRAME5$:	LOAD.B	D3,#ICOTRALM	CALL	GREYICONE	CLR.W	D7		; D7 <-- dgrise	COMP.W	(A6)+OTRALU,#+8	JUMP',NE TRAME6$	INC.W	D7		; D7 <-- griseTRAME6$:	LOAD.B	D3,#ICOTRALP	CALL	GREYICONE	JUMP	EXIT$LISSE$:	CLR.W	D7		; D7 <-- dgrise	COMP.W	(A6)+OLISPA,#2	JUMP',NE LISSE2$	INC.W	D7		; D7 <-- griseLISSE2$:	LOAD.B	D3,#ICOLISSE2	CALL	GREYICONE	CLR.W	D7		; D7 <-- dgrise	COMP.W	(A6)+OLISPA,#4	JUMP',NE LISSE4$	INC.W	D7		; D7 <-- griseLISSE4$:	LOAD.B	D3,#ICOLISSE4	CALL	GREYICONE	CLR.W	D7		; D7 <-- dgrise	COMP.W	(A6)+OLISPA,#6	JUMP',NE LISSE6$	INC.W	D7		; D7 <-- griseLISSE6$:	LOAD.B	D3,#ICOLISSE6	CALL	GREYICONE	CLR.W	D7		; D7 <-- dgrise	COMP.W	(A6)+OLISPA,#8	JUMP',NE LISSE8$	INC.W	D7		; D7 <-- griseLISSE8$:	LOAD.B	D3,#ICOLISSE8	CALL	GREYICONE;	JUMP'	EXIT$EXIT$:	POPM.L	D3,D4,A4	RETOPEROK$:	PUSH.L	(A6)+OSEPHG	PUSH.L	(A6)+OSEPHD	PUSH.L	(A6)+OSEPBG	PUSH.L	(A6)+OSEPBD	PUSH.L	(A6)+OSEPMI	PUSH.W	(A6)+OSEANG	CALL	OPERMATRIX	; effectue une opration	CALL	TESTPOIGNEES	; vrifie que rien ne dborde	POP.W	(A6)+OSEANG	POP.L	(A6)+OSEPMI	POP.L	(A6)+OSEPBD	POP.L	(A6)+OSEPBG	POP.L	(A6)+OSEPHD	POP.L	(A6)+OSEPHG	TEST.W	D7		; retour EQ/NE	RETTEXTOK$:	CALL	GREYICONE	TEST.W	D7	JUMP',NE TEXTOK9$	CALL	(A4)		; dessine le curseur tout joli !TEXTOK9$:	RET;--------\\; DESINFO >;========/; Dessine les informations tout en haut.; in	-; out	-; mod	D7.WDESINFO:	PUSHM.L	D3,D4,A3	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORCINFO	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	; donne la couleur relative pour dessiner	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	AFINV		; vido inverse	.ASCII	" PICASSO "	.B	PICREV+'0,'.	.IF	PICVERS<10	.B	PICVERS+'0	.ELSE	.B	(PICVERS/10)+'0,(PICVERS-((PICVERS/10)*10))+'0	.ENDIF	.B	PICPROV	.B	0	.EVEN	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	LIB	?COLORPOP	POPM.L	D3,D4,A3	RET;---------\\; DESINF3B >;=========/; Affiche les fonctions des trois boutons de la souris.; in	A3.L	^texte; out	-; mod	D7.WDESINF3B:	PUSHM.L	D3,A3,A4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORCINFO	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	; donne la couleur relative pour dessiner	LOAD.W	D3,#LIHELP	MUL.WU	D3,(A0)+ODFCX	SUB.W	D3,(A0)+ODFDX	NEG.W	D3	CONV.LA.WA D3	LIB	?SETCURS	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4+),#AFINV	LOAD.B	(A4+),#AFTOUT20$:	LOAD.B	(A4+),(A3+)	JUMP,NE 20$	DEC.L	A4	LOAD.B	(A4+),#AFNORM	LOAD.B	(A4+),#AFDIR	CLR.B	(A4+)	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BS 50$		; oui => 50$	LOAD.L	A3,#R16"00$	LOAD.L	A4,#(A6)+OBUDIS+2+830$:	LOAD.B	D3,(A3+)	JUMP',EQ 50$	LOAD.B	(A4+),D3	; buffer <-- met le mot "icnes"	JUMP	30$50$:	LOAD.L	A3,#(A6)+OBUDIS	LIB	?AFTEXT		; affiche les 3 boutons de la souris	LIB	?COLORPOP	POPM.L	D3,A3,A4	RET		;<--8--->;00$:	.ASCIZ	"|icnes|"	.EVEN;---------\\; DESINFXY >;=========/; Affiche la position x,y de la souris dans les informations.; in	D3.L	position (y;x) ou -1 si hors de l'aire de dessin; out	-; mod	D7.WDESINFXY:	PUSHM.L	D2..D4	LOAD.L	D4,D3		; D4 <-- position (y;x)	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORCINFO	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	; donne la couleur relative pour dessiner	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSXY	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	COMP.L	D4,#-1		; hors de l'aire de dessin ?	JUMP',EQ 50$		; oui => 50$				; non =>	LIB	?AFTIM	.ASCIZ	"X="	.EVEN	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode	LOAD.W	D3,#3		; D3 <-- nb digits pour 0..999	PUSH.L	D4	CONV.LA.WA D4	LIB	?AFDEC	POP.L	D4	LIB	?AFTIM	.ASCIZ	" Y="	.EVEN	CLR.W	D4	SWAP.W	D4	SUB.W	D4,(A6)+OMALMY	NEG.W	D4	DEC.W	D4	LIB	?AFDEC	JUMP'	80$50$:	LIB	?AFTIM	.B	MSPACE,6+6,0	; efface tout	.EVEN80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?COLORPOP	POPM.L	D2..D4	RET;---------\\; DESINFCP >;=========/; Affiche les dimensions pendant le dessin d'un objet; graphique (comme plan) dans les informations.; in	D5.L	P1(y;x);	D6.L	P2(y;x); out	-; mod	D7.WDESINFCP:	PUSHM.L	D2..D6	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORCINFO	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	; donne la couleur relative pour dessiner	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSXY	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode	LOAD.W	D3,#3		; D3 <-- nb digits pour 0..999	LOAD.B	D4,(A6)+OOBJET	COMP.B	D4,#ICOCERCLE	JUMP,EQ 30$	COMP.B	D4,#ICOTRAIT	JUMP,EQ 70$20$:				; droite/rectangle/etc. =>	LIB	?AFTIM	.ASCIZ	"L="	.EVEN	CLR.L	D4	LOAD.W	D4,D5	SUB.W	D4,D6	JUMP',NC 22$	NEG.W	D422$:	LIB	?AFDEC		; affiche la largeur	LIB	?AFTIM	.ASCIZ	" H="	.EVEN	SWAP.W	D5	SWAP.W	D6	CLR.L	D4	LOAD.W	D4,D5	SUB.W	D4,D6	JUMP',NC 24$	NEG.W	D424$:	LIB	?AFDEC		; affiche la hauteur	JUMP	80$30$:				; cercle =>	TEST.B	(A6)+OPOLY:#BPOLYE	JUMP,BS 20$	LIB	?AFTIM	.ASCIZ	"R="	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OCERAY	LIB	?AFDEC		; affiche le rayon	TEST.B	(A6)+OARC:#BARCQ	JUMP',BS 35$	TEST.B	(A6)+OPOLY:#BPOLY3	JUMP',BS 35$	TEST.B	(A6)+OPOLY:#BPOLY4	JUMP',BS 35$	TEST.B	(A6)+OPOLY:#BPOLY5	JUMP',BS 35$	TEST.B	(A6)+OPOLY:#BPOLY6	JUMP',BS 35$	TEST.B	(A6)+OPOLY:#BPOLY8	JUMP',BS 35$	TEST.B	(A6)+OPOLY:#BPOLY10	JUMP',BS 35$	LIB	?AFTIM	.B	MSPACE,6,0	.EVEN	JUMP'	80$35$:	LIB	?AFTIM	.ASCIZ	" a="	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OCEANG	LIB	?AFDEC		; affiche l'angle	JUMP'	80$70$:	LIB	?AFTIM	.B	MSPACE,6+6,0	; efface tout	.EVEN80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?COLORPOP	POPM.L	D2..D6	RET;---------\\; DESINFLT >;=========/; Affiche la largeur du texte dans les informations.; in	D4.L	hauteur/largeur; out	-; mod	D7.WDESINFLT:	PUSHM.L	D2..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORCINFO	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	; donne la couleur relative pour dessiner	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSXY	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode	LOAD.W	D3,#3		; D3 <-- nb digits pour 0..999	LIB	?AFTIM	.ASCIZ	"L="	.EVEN	PUSH.L	D4	CONV.LA.WA D4	LIB	?AFDEC		; affiche la largeur	POP.L	D4	LIB	?AFTIM	.ASCIZ	" H="	.EVEN	CLR.W	D4	SWAP.W	D4	LIB	?AFDEC		; affiche la hauteur	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?COLORPOP	POPM.L	D2..D4	RET;----------\\; DESINFDEF >;==========/; Affiche la dformation dans les informations.; in	D0.W	poigne;	D1.B	ICOxx; out	-; mod	D7.WDESINFDEF:	PUSHM.L	D2..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORCINFO	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	; donne la couleur relative pour dessiner	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSXY	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	COMP.B	(A6)+OYICO,#ICOZOOM	JUMP,EQ ZOOM$	COMP.B	(A6)+OYICO,#ICOTOURNE	JUMP,EQ TOURNE$	LOAD.L	D3,(A6)+OSEPHG	LOAD.L	D4,(A6)+OSEOHG	TEST.L	D0:#BPOIHG	JUMP',BS DELTA$	LOAD.L	D3,(A6)+OSEPHD	LOAD.L	D4,(A6)+OSEOHD	TEST.L	D0:#BPOIHD	JUMP',BS DELTA$	LOAD.L	D3,(A6)+OSEPBG	LOAD.L	D4,(A6)+OSEOBG	TEST.L	D0:#BPOIBG	JUMP',BS DELTA$	LOAD.L	D3,(A6)+OSEPBD	LOAD.L	D4,(A6)+OSEOBD;	TEST.L	D0:#BPOIBD;	JUMP',BS DELTA$DELTA$:	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode	LOAD.W	D3,#3		; D3 <-- nb digits pour 0..999	LIB	?AFTIM	.ASCIZ	"L="	.EVEN	PUSH.L	D4	CONV.LA.WA D4	TEST.W	D4	JUMP',NC DELTAX$	NEG.W	D4DELTAX$:	LIB	?AFDEC	POP.L	D4	LIB	?AFTIM	.ASCIZ	" H="	.EVEN	CLR.W	D4	SWAP.W	D4	TEST.W	D4	JUMP',NC DELTAY$	NEG.W	D4DELTAY$:	LIB	?AFDEC	JUMP	EXIT$ZOOM$:	LOAD.W	D4,(A6)+OSEPHG+2	SUB.W	D4,(A6)+OSEPHD+2	LOAD.W	D3,(A6)+OSEOHG+2	SUB.W	D3,(A6)+OSEOHD+2	CALL	DESINFZOOM	LIB	?AFSPACE	LOAD.W	D4,(A6)+OSEPHG+0	SUB.W	D4,(A6)+OSEPBG+0	LOAD.W	D3,(A6)+OSEOHG+0	SUB.W	D3,(A6)+OSEOBG+0	CALL	DESINFZOOM	JUMP	EXIT$TOURNE$:	CLR.L	D4	LOAD.W	D4,(A6)+OSEANG	; D4 <-- angle de rotation	JUMP',NC TOURNE1$	NEG.W	D4TOURNE1$:	DIV.WU	D4,#360	SWAP.W	D4	COMP.W	D4,#180	JUMP',LS TOURNE2$	SUB.W	D4,#360	NEG.W	D4TOURNE2$:	CONV.LA.WA D4	CLR.W	D2		; D2 <-- mode	LOAD.W	D3,#3		; D3 <-- nb digits pour 0..180	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" degrs "	.EVEN;	JUMP	EXIT$EXIT$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?COLORPOP	POPM.L	D2..D4	RET;-----------\\; DESINFZOOM >;-----------/; Affiche un facteur de zoom positif ou ngatif.; in	D4.W	nouvelle longueur;	D3.W	ancienne longueur; out	-; mod	D7.WDESINFZOOM:	PUSHM.L	D2..D4	TEST.W	D4	JUMP',NC 10$	NEG.W	D410$:	TEST.W	D3	JUMP,EQ 80$	JUMP',NC 15$	NEG.W	D315$:	MUL.WU	D4,#1000	DIV.WU	D4,D3	COMP.W	D4,#10000	JUMP,HS 80$	CONV.LA.WA D4	LIB	?BINBCD	CLR.W	D220$:	RL.L	D4,#4	LOAD.L	D3,D4	SWAP.W	D3	AND.B	D3,#H'0F	ADD.B	D3,#'0	LIB	?AFCAR	TEST.W	D2	JUMP',NE 30$	LOAD.B	D3,#'.	LIB	?AFCAR30$:	INC.W	D2	COMP.W	D2,#4	JUMP,LO 20$	JUMP'	EXIT$80$:	LIB	?AFTIM	.ASCIZ	"  ?  "	.EVENEXIT$:	POPM.L	D2..D4	RET;-----------\\; DESINFZONE >;===========/; Affiche l'chelle dans les informations.;	OSCALE positif	-->	n:1;	OSCALE ngatif	-->	1:n; in	(A6)+OSCALE.W; out	-; mod	D7.WDESINFZONE:	PUSHM.L	D2..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORCINFO	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	; donne la couleur relative pour dessiner	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSZONE	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	LOAD.B	D3,#'[	LIB	?AFCAR	LOAD.W	D3,(A6)+ONOZO	; D3 <-- zone (0..9)	ADD.B	D3,#'1	COMP.B	D3,#'9	JUMP',LS NUM$	LOAD.B	D3,#'0NUM$:	LIB	?AFCAR	LOAD.B	D3,#']	LIB	?AFCAR	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?COLORPOP	POPM.L	D2..D4	RET;---------\\; DESINFSC >;=========/; Affiche l'chelle dans les informations.;	OSCALE positif	-->	n:1;	OSCALE ngatif	-->	1:n; in	(A6)+OSCALE.W; out	-; mod	D7.WDESINFSC:	PUSHM.L	D2..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORCINFO	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	; donne la couleur relative pour dessiner	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSSCALE	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LOAD.W	D3,#2		; D3 <-- 2 digits au maximum	CLR.L	D4	LOAD.W	D4,(A6)+OSCALE	; D4 <-- +/- chelle	JUMP',NS 50$				; chelle n:1 =>	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	":1"	.EVEN	JUMP'	60$50$:				; chelle 1:n =>	NEG.W	D4	LIB	?AFTIM	.ASCIZ	"1:"	.EVEN	LIB	?AFDEC60$:	COMP.W	D4,#10		; deux digits affichs ?	JUMP',HS 80$		; oui => 80$	LIB	?AFSPACE	; non => affiche encore un espace80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?COLORPOP	POPM.L	D2..D4	RET;---------\\; DESINFPA >;=========/; Affiche le pas dans les informations.; in	(A6)+OPAS.W; out	-; mod	D7.WDESINFPA:	PUSHM.L	D2..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORCINFO	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	; donne la couleur relative pour dessiner	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSPAS	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"p="	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OPAS	; D4 <-- pas	LOAD.W	D3,#2		; D3 <-- 2 digits au maximum	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LIB	?AFDEC	COMP.W	D4,#10		; deux digits affichs ?	JUMP',HS 80$		; oui => 80$	LIB	?AFSPACE	; non => affiche encore un espace80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?COLORPOP	POPM.L	D2..D4	RET;-----------\\; DESINFFILE >;===========/; Affiche le nom du fichier dans les informations.; in	-; out	-; mod	D7.WDESINFFILE:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A3,#(A6)+OBUNAME	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORCINFO	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	; donne la couleur relative pour dessiner	LIB	?BUCAR		; mode rapide	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSFILE	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A0)+ODFDX	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb car dans toute la largeur	SUB.W	D4,#POSFILE	SUB.W	D4,#LIHELP+1	; D4 <-- nb car restants pour le nom	TEST.B	(A3)	JUMP',EQ 50$	COMP.B	(A3),#CR	JUMP',EQ 50$	LIB	?AFTIM	.B	'"		; guillemet au dbut	.B	AFTOUT	.B	0	.EVEN	SUB.W	D4,#2	LOAD.L	A4,#(A6)+OBUDIS	CALL	PUTINFFILE	; OBUDIS <-- nom du fichier	COMP.W	D3,D4	JUMP',LS 30$	ADD.W	A4,D3	SUB.W	A4,D4		; A4 <-- saute le dbut du nom	LOAD.B	(A4),#5		; dbut de nom <-- triangle "<"	LOAD.W	D3,D430$:	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le nom, ou seulement la fin	SUB.W	D4,D3		; D4 <-- lg restante	LIB	?AFTIM	.B	AFNORM	.B	'"		; guillemet  la fin	.B	0	.EVEN50$:	TEST.W	D4	JUMP',EQ 80$	LOAD.B	D3,#MSPACE	LIB	?AFCAR		; efface la fin	LOAD.B	D3,D4	LIB	?AFCAR80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?NOBUCAR	; mode normal	LIB	?COLORPOP	POPM.L	D2..D4,A3,A4	RET;-----------\\; PUTINFFILE >;-----------/; Prpare le nom du fichier  afficher.; in	A3.L	^nom;	A4.L	^buffer; out	D3.W	nb de caractres; mod	D3.L, D7.WPUTINFFILE:	PUSHM.L	D1,D2,A4	LOAD.W	D2,#2^BAFXMI	; D2 <-- affiche en minuscules	LOAD.W	D3,#100		; D3 <-- lg max	LOAD.L	D1,A4	LIB	?PUTXFILE	; OBUDIS <-- nom du fichier20$:	COMP.L	A4,D1	JUMP',EQ 30$	LOAD.B	D3,(-A4)	COMP.B	D3,#':	JUMP',EQ 30$	COMP.B	D3,#'.	JUMP,NE 20$	CLR.B	(A4)		; enlve l'extension30$:	LOAD.L	A4,D1	LOAD.W	D3,#-140$:	INC.W	D3	TEST.B	(A4+)	JUMP,NE 40$	POPM.L	D1,D2,A4	RET;---------\\; DESCADRE >;=========/; Dessine le cadre de la grande matrice, avec les ascenseurs; et la grille. Dessine aussi le "L" pour dlimiter le; petit rectangle.; in	-; out	-; mod	D7.WDESCADRE:	PUSHM.L	D2..D5,A5	CALL	__ERGMOUSE	; efface les flches dans les rgles	CLR.L	D4	CALL	__DRMDEF	LOAD.L	D3,(A6)+OGRPOY	LOAD.L	D4,(A6)+OGRDIY	TEST.B	(A6)+OREGLE	; rgles prsentes ?	JUMP',F 10$		; non => 10$	ADD.W	D4,#LGREGLE	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#LGREGLE	ADD.W	D4,#LGREGLE	SWAP.W	D3	SWAP.W	D410$:	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 20$		; non => 20$	SUB.W	D3,#LGSCROLL-1	ADD.W	D4,#LGSCROLL-1	SWAP.W	D4	ADD.W	D4,#LGSCROLL-1	SWAP.W	D420$:	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface toute la grande matrice	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour grande matrice	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	CALL	DESGRILLE	; dessine la grille dans le grand rectangle	LOAD.L	A5,#(A6)+OASVER	LOAD.W	D4,(A6)+OGRPOY	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OGRPOX	SUB.W	D4,#LGSCROLL	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OGRDIY	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	CLR.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 40$		; non => 40$	SCROLL_	DRAW		; dessine la cage verticale40$:	LOAD.L	A5,#(A6)+OASHOR	LOAD.W	D4,(A6)+OGRPOX	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OGRPOY	ADD.W	D4,(A6)+OGRDIY	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OGRDIX	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 50$		; non => 50$	SCROLL_	DRAW		; dessine la cage horizontale50$:	CALL	MAJCADRE; Dessine le "L" pour dlimiter le petit rectangle.	LOAD.W	D5,(A6)+OPWDO	JUMP',EQ 60$	LIB	?KILWDO		; dtruit la swdo autour petite matrice60$:	LOAD.W	D5,(A6)+OGWDO	JUMP',EQ 62$	LIB	?KILWDO		; dtruit la swdo autour grande matrice62$:	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE 70$	LOAD.W	D3,(A6)+OPRPOY	LOAD.W	D4,(A6)+OPRDIY;;?	INC.W	D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OPRPOX	DEC.W	D3	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; dessine ligne verticale	CLR.L	D4	LOAD.W	D4,(A6)+OPRDIX	INC.W	D4;	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; dessine ligne horizontale70$:	LOAD.L	D3,(A6)+OPMPOY	LOAD.L	D4,(A6)+OPMDIY	LIB	?CREWDO		; cre swdo autour de la petite matrice	LOAD.W	(A6)+OPWDO,D5	LOAD.L	D3,(A6)+OGMPOY	LOAD.L	D4,(A6)+OGMDIY	LIB	?CREWDO		; cre swdo autour de la grande matrice	LOAD.W	(A6)+OGWDO,D5; Grise ventuellement les zones en haut et  droite qui dbordent.	LOAD.L	D4,#H'88882222	CALL	__DRMDEF	LOAD.W	D4,(A6)+OPRDIY	; D4 <-- hauteur petit rectangle	SUB.W	D4,(A6)+OPMDIY	; D4 <-- hauteur  griser	JUMP',LS 74$	SWAP.W	D4	LOAD.W	D4,(A6)+OPRDIX	LOAD.L	D3,(A6)+OPRPOY	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	; grise en haut74$:	LOAD.W	D4,(A6)+OPRDIX	; D4 <-- largeur petit rectangle	SUB.W	D4,(A6)+OPMDIX	; D4 <-- largeur  griser	JUMP',LS 76$	LOAD.W	D3,(A6)+OPRPOX	ADD.W	D3,(A6)+OPMDIX	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OPRPOY	ADD.W	D3,(A6)+OPRDIY	SUB.W	D3,(A6)+OPMDIY	LOAD.W	D4,(A6)+OPMDIY	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	; grise  droite76$:	POPM.L	D2..D5,A5	RET;---------\\; MAJCADRE >;=========/; Met  jour le cadre (ascenseurs et rgles).; in	-; out	-; mod	D7.WMAJCADRE:	PUSHM.L	D3,D4,A5	CALL	DESREGLE	; dessine les rgles	LOAD.L	A5,#(A6)+OASVER	LOAD.W	D4,(A6)+OMALSY	CLR.L	D3	LOAD.W	D3,(A6)+OGMDIY	DIV.WU	D3,(A6)+OGMLPY	SUB.W	D4,D3	LOAD.W	(A5)+OSCHTV,D4	JUMP',EQ 40$	INC.W	(A5)+OSCHTV	LOAD.W	(A5)+OSCPOSV,(A6)+OGMOVY	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 40$		; non => 40$	SCROLL_	UPDATE		; dessine la cabine verticale40$:	LOAD.L	A5,#(A6)+OASHOR	LOAD.W	D4,(A6)+OMALSX	CLR.L	D3	LOAD.W	D3,(A6)+OGMDIX	DIV.WU	D3,(A6)+OGMLPX	SUB.W	D4,D3	LOAD.W	(A5)+OSCHTV,D4	JUMP',EQ 60$	INC.W	(A5)+OSCHTV	LOAD.W	(A5)+OSCPOSV,(A6)+OGMOVX	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 60$		; non => 60$	SCROLL_	UPDATE		; dessine la cabine horizontale60$:	POPM.L	D3,D4,A5	RET;-------------\\; DOKASCENSEUR >;=============/; Agit dans les ascenseurs en fonction d'une touche presse.; in	D3.W	touche presse;	A1.L	^routine d'inversion/nil; out	D7.W	erreur; mod	D7.WDOKASCENSEUR:	PUSHM.L	D3,D4,A5	COMP.B	D3,#'a	JUMP',LO 10$	COMP.B	D3,#'z	JUMP',HI 10$	SUB.B	D3,#'a-'A	; D3 <-- lettre MAJUSCULE10$:	LOAD.L	D4,#SCROLLFUP!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'R	JUMP',EQ 20$	LOAD.L	D4,#SCROLLPUP!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'E	JUMP',EQ 20$	LOAD.L	D4,#SCROLLFDOWN!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'C	JUMP',EQ 20$	LOAD.L	D4,#SCROLLPDOWN!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'X	JUMP',EQ 20$	LOAD.L	D4,#SCROLLFUP!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'D	JUMP',EQ 40$	LOAD.L	D4,#SCROLLPUP!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'S	JUMP',EQ 40$	LOAD.L	D4,#SCROLLFDOWN!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'F	JUMP',EQ 40$	LOAD.L	D4,#SCROLLPDOWN!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'G	JUMP',EQ 40$	JUMP'	80$20$:	LOAD.L	A5,#(A6)+OASVER	TEST.W	(A5)+OSCHTV	JUMP',EQ 80$	CALL	ASCMOVEV	; dplace l'ascenseur vertical ...	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$40$:	LOAD.L	A5,#(A6)+OASHOR	TEST.W	(A5)+OSCHTV	JUMP',EQ 80$	CALL	ASCMOVEH	; dplace l'ascenseur horizontal ...	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$80$:	LOAD.W	D7,#1EXIT$:	POPM.L	D3,D4,A5	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DOMASCENSEUR >;=============/; Agit dans les ascenseurs en fonction de la souris.; in	D4.L	position de la souris (y;x);	A1.L	^routine d'inversion/nil; out	D7.W	erreur; mod	D7.WDOMASCENSEUR:	PUSHM.L	D1,D4,A5	LOAD.W	D7,#1	TEST.B	(A6)+ODEF+3:#BDEFASC	JUMP',BC 80$	LOAD.L	D1,D4		; D1 <-- position de la souris	LOAD.L	A5,#(A6)+OASVER	TEST.W	(A5)+OSCHTV	JUMP',EQ 20$	LOAD.W	(A5)+OSCPOSV,(A6)+OGMOVY	SCROLL_	MOVE		; dans ascenseur vertical ?	JUMP',NE 20$	TCLR.L	D4:#16		; D4 <-- avec rptition	CALL	ASCMOVEV	; dplace l'ascenseur vertical ...	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$20$:	LOAD.L	D4,D1		; D4 <-- position de la souris	LOAD.L	A5,#(A6)+OASHOR	TEST.W	(A5)+OSCHTV	JUMP',EQ 80$	LOAD.W	(A5)+OSCPOSV,(A6)+OGMOVX	SCROLL_	MOVE		; dans ascenseur horizontal ?	JUMP',NE 80$	TCLR.L	D4:#16		; D4 <-- avec rptition	CALL	ASCMOVEH	; dplace l'ascenseur horizontal ...	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$80$:	LOAD.W	D7,#1EXIT$:	POPM.L	D1,D4,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; ASCMOVEH >;=========/; Dplace l'ascenseur horizontal.; in	A5.L	^description ascenseur;	D4.L	SCROLL(F/P)(UP/DOWN);	A1.L	^routine d'inversion/nil; out	-; mod	D7.WASCMOVEH:	PUSHM.L	D1..D4	TEST.B	(A6)+ODEF+3:#BDEFASC	JUMP',BC 05$	SCROLL_	PRESS		; allume le "bouton"05$:	COMP.L	A1,#0	JUMP',EQ 06$	CALL	(A1)		; teint qq chose !06$:	LOAD.L	D2,D4		; D2 <-- "bouton" de l'ascenseur10$:	LOAD.W	D3,#+4		; D3 <-- +4 point	COMP.W	D2,#SCROLLFDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -4 point	COMP.W	D2,#SCROLLFUP	JUMP',EQ 50$	LOAD.W	D1,(A6)+OGMDIX	NEG.W	(A6)+OSCALE	CALL	D1SCALEP	NEG.W	(A6)+OSCALE	DEC.W	D1	LOAD.W	D3,D1		; D3 <-- +1 cran	COMP.W	D2,#SCROLLPDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -1 cran	COMP.W	D2,#SCROLLPUP	JUMP',EQ 50$; Dplacement absolu selon l'ascenseur.	LOAD.L	D4,(A6)+OGMOVY	LOAD.W	D4,(A5)+OSCPOSV	CALL	ASCMOVE		; dplace la partie visible	JUMP'	80$; Dplacement selon la quantit dans D3.50$:	LOAD.L	D4,(A6)+OGMOVY	ADD.W	D4,D3	CALL	ASCMOVE		; dplace la partie visible	TEST.L	D2:#16		; juste une fois ?	JUMP',BS 80$		; oui => 80$				; non =>	LIB	?IFCAR		; bouton relach ?	JUMP,NE 10$		; non => 10$80$:	TEST.B	(A6)+ODEF+3:#BDEFASC	JUMP',BC 85$	LOAD.W	D4,D2	SCROLL_	PRESS		; teint le "bouton"85$:	COMP.L	A1,#0	JUMP',EQ 86$	CALL	(A1)		; allume qq chose !86$:	CALL	DESREGLE	; dessine les rgles	POPM.L	D1..D4	RET;---------\\; ASCMOVEV >;=========/; Dplace l'ascenseur vertical.; in	A5.L	^description ascenseur;	D4.L	SCROLL(F/P)(UP/DOWN);	A1.L	^routine d'inversion/nil; out	-; mod	D7.WASCMOVEV:	PUSHM.L	D1..D4	TEST.B	(A6)+ODEF+3:#BDEFASC	JUMP',BC 05$	SCROLL_	PRESS		; allume le "bouton"05$:	COMP.L	A1,#0	JUMP',EQ 06$	CALL	(A1)		; teint qq chose !06$:	LOAD.L	D2,D4		; D2 <-- "bouton" de l'ascenseur10$:	LOAD.W	D3,#+4		; D3 <-- +4 point	COMP.W	D2,#SCROLLFDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -4 point	COMP.W	D2,#SCROLLFUP	JUMP',EQ 50$	LOAD.W	D1,(A6)+OGMDIY	NEG.W	(A6)+OSCALE	CALL	D1SCALEP	NEG.W	(A6)+OSCALE	DEC.W	D1	LOAD.W	D3,D1		; D3 <-- +1 cran	COMP.W	D2,#SCROLLPDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -1 cran	COMP.W	D2,#SCROLLPUP	JUMP',EQ 50$; Dplacement absolu selon l'ascenseur.	LOAD.L	D4,(A6)+OGMOVY	SWAP.W	D4	LOAD.W	D4,(A5)+OSCPOSV	SWAP.W	D4	CALL	ASCMOVE		; dplace la partie visible	JUMP'	80$; Dplacement selon la quantit dans D3.50$:	LOAD.L	D4,(A6)+OGMOVY	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D4	CALL	ASCMOVE		; dplace la partie visible	TEST.L	D2:#16		; juste une fois ?	JUMP',BS 80$		; oui => 80$				; non =>	LIB	?IFCAR		; bouton relach ?	JUMP,NE 10$		; non => 10$80$:	TEST.B	(A6)+ODEF+3:#BDEFASC	JUMP',BC 85$	LOAD.W	D4,D2	SCROLL_	PRESS		; teint le "bouton"85$:	COMP.L	A1,#0	JUMP',EQ 86$	CALL	(A1)		; allume qq chose !86$:	CALL	DESREGLE	; dessine les rgles	POPM.L	D1..D4	RET;--------\\; ASCMOVE >;--------/; Dplace la partie visible horizontalement ou verticalement.; in	A5.L	^description ascenseur;	D4.L	nouvelle position (y;x); out	-; mod	D7.WASCMOVE:	PUSHM.L	D3,D4	TEST.W	D4	JUMP',NC 20$	CLR.W	D420$:	COMP.W	D4,(A6)+OASHOR+OSCHTV	JUMP',LO 22$	LOAD.W	D4,(A6)+OASHOR+OSCHTV	JUMP',EQ 22$	DEC.W	D422$:	SWAP.W	D4	TEST.W	D4	JUMP',NC 30$	CLR.W	D430$:	COMP.W	D4,(A6)+OASVER+OSCHTV	JUMP',LO 32$	LOAD.W	D4,(A6)+OASVER+OSCHTV	JUMP',EQ 32$	DEC.W	D432$:	SWAP.W	D4	LOAD.L	(A6)+OGMOVY,D4	LOAD.L	(A6)+OPMOVY,D4	LOAD.W	(A6)+OASHOR+OSCPOSV,D4	SWAP.W	D4	LOAD.W	(A6)+OASVER+OSCPOSV,D4	TEST.B	(A6)+ODEF+3:#BDEFASC	JUMP',BC 50$	SCROLL_	UPDATE		; dplace l'ascenseur50$:	CALL	DESPMATRIX	; dessine la petite matrice	CALL	DESGMATRIX	; dessine la grande matrice	POPM.L	D3,D4	RET;---------\\; MAJREGLE >;=========/; Met  jour les rgles centimtriques si la partie visible; a t dplace.; in	-; out	-; mod	D7.WMAJREGLE:	PUSHM.L	D2..D4,A5	TEST.B	(A6)+OREGLE	; rgles prsentes ?	JUMP,F	EXIT$		; non => EXIT$				; oui =>	LOAD.L	A5,#(A6)+ORGVAR; Regarde les variables pour la rgle horizontale.	LOAD.W	D4,(A6)+OGMOVX	COMP.W	D4,(A5)+ORGHOR	JUMP',NE 80$; Regarde les variables pour la rgle verticale.	CLR.L	D3	LOAD.W	D3,(A6)+OGMDIY	LOAD.W	D2,(A6)+OSCALE	JUMP',NS 50$	DIV.WU	D3,D2		; D3 <-- nb points visibles en Y	JUMP'	55$50$:	NEG.W	D2	MUL.WU	D3,D2		; D3 <-- nb points visibles en Y55$:	CLR.W	D2	LOAD.W	D4,(A6)+OMALMY	SUB.W	D4,(A6)+OGMOVY	SUB.W	D4,D3	JUMP',LO 60$	LOAD.W	D2,D460$:	COMP.W	D2,(A5)+ORGVOR	JUMP',EQ EXIT$80$:	CALL	DESREGLE	; redessine les deux rglesEXIT$:	POPM.L	D2..D4,A5	RET;---------\\; DESREGLE >;=========/; Dessine les rgles centimtriques (mme s'il n'y a rien de chang).; in	-; out	-; mod	D7.WDESREGLE:	PUSHM.L	D2..D4,A5	TEST.B	(A6)+OREGLE	; rgles prsentes ?	JUMP,F	EXIT$		; non => EXIT$				; oui =>	LOAD.L	A5,#(A6)+ORGVAR; Initialise les variables pour la rgle horizontale.	LOAD.W	(A5)+ORGHPO+2,(A6)+OGRPOX	LOAD.W	D4,(A6)+OGRPOY	SUB.W	D4,#LGREGLE	LOAD.W	(A5)+ORGHPO+0,D4	LOAD.W	D4,(A6)+OGRDIX	INC.W	D4	LOAD.W	(A5)+ORGHLG,D4	LOAD.W	(A5)+ORGHOR,(A6)+OGMOVX	LOAD.W	(A5)+ORGHSC,(A6)+OSCALE	LOAD.L	D4,#10000*64	DIV.WU	D4,(A6)+OMMX	CONV.LA.WA D4	DIV.WU	D4,(A6)+OFACX	LOAD.W	(A5)+ORGHPA,D4; Initialise les variables pour la rgle verticale.	LOAD.W	D4,(A6)+OGRPOX	ADD.W	D4,(A6)+OGRDIX	INC.W	D4	LOAD.W	(A5)+ORGVPO+2,D4	LOAD.W	(A5)+ORGVPO+0,(A6)+OGRPOY	LOAD.W	D4,(A6)+OGRDIY	INC.W	D4	LOAD.W	(A5)+ORGVLG,D4	CLR.L	D3	LOAD.W	D3,(A6)+OGMDIY	LOAD.W	D2,(A6)+OSCALE	JUMP',NS 50$	DIV.WU	D3,D2		; D3 <-- nb points visibles en Y	JUMP'	55$50$:	NEG.W	D2	MUL.WU	D3,D2		; D3 <-- nb points visibles en Y55$:	CLR.W	(A5)+ORGVOR	LOAD.W	D4,(A6)+OMALMY	SUB.W	D4,(A6)+OGMOVY	SUB.W	D4,D3	JUMP',LO 60$	LOAD.W	(A5)+ORGVOR,D460$:	LOAD.W	(A5)+ORGVSC,(A6)+OSCALE	LOAD.L	D4,#10000*64	DIV.WU	D4,(A6)+OMMY	CONV.LA.WA D4	DIV.WU	D4,(A6)+OFACY	LOAD.W	(A5)+ORGVPA,D4	SCROLL_	RUPDATE		; dessine les rgles graduesEXIT$:	POPM.L	D2..D4,A5	RET;----------\\; DESGRILLE >;==========/; Dessine la grille de points dans toute la matrice.; in	-; out	-; mod	D7.WDESGRILLE:	PUSHM.L	D0..D5,A0..A2	COMP.W	(A6)+OSCALE,#SCALEMIN	JUMP,LT EXIT$	CALL	CCMO		; enlve la souris	LOAD.L	A2,A0		; A2 <-- ^description fentre	LOAD.L	A1,(A6)+OQXDOT	; A1 <-- adresse routine	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	LOAD.L	A1,(A6)+ODOT	; A1 <-- adresse routineNOCOUL$:	LOAD.W	D4,(A6)+OGMPOY	; D4 <-- position initiale en Y	DEC.W	D4	SWAP.W	D4	CLR.L	D5	LOAD.W	D5,(A6)+OGMDIY	DIV.WU	D5,(A6)+OGMLPY	; D5 <-- nb points verticalement;	INC.W	D5		; D5 <-- va jusque tout en bas;	DEC.W	D5		; D5 <--  cause NMOLOOP$:	LOAD.W	D4,(A6)+OGMPOX	; D4 <-- position initiale en X	ADD.W	D4,(A6)+OGMLPX	DEC.W	D4	CLR.L	D3	LOAD.W	D3,(A6)+OGMDIX	; D3 <-- largeur totale	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A6)+OPRDIY	COMP.W	D2,(A6)+OPRPOY	; petit rectangle  ct ?	JUMP',GT RECT$		; non => RECT$	LOAD.W	D2,(A6)+OPRPOX	; oui =>	SUB.W	D2,(A6)+OGRPOX	; D2 <-- largeur moins rectangle	COMP.W	D3,D2	JUMP',LS RECT$	LOAD.W	D3,D2RECT$:	DIV.WU	D3,(A6)+OGMLPX	; D3 <-- nb de points dans la largeur	LOAD.W	D2,(A6)+OMALMX	SUB.W	D2,(A6)+OGMOVX	LOAD.W	D1,D3	SUB.W	D1,D2		; D1 <-- nb de points  effacer ( droite)	JUMP',LS GO$	LOAD.W	D3,D2GO$:	DEC.W	D3		; D3 <--  cause NMO	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COUL$		; oui => COUL$XSET$:	CALL	(A1)		; appel GRA_QXDOT	TSET.B	(A0):D0		; met un point	ADD.W	D4,(A6)+OGMLPX	; D4 <-- avance en X	DECJ.W,NMO D3,XSET$	TEST.W	D1		; qq points  effacer ?	JUMP',LE NEXT$		; non => NEXT$	DEC.W	D1		; D1 <--  cause NMOXCLR$:	CALL	(A1)		; appel GRA_QXDOT	TCLR.B	(A0):D0		; efface un point	ADD.W	D4,(A6)+OGMLPX	; D4 <-- avance en X	DECJ.W,NMO D1,XCLR$	JUMP'	NEXT$COUL$:	LOAD.W	D0,D1	LOAD.W	D1,#SETDOTDSET$:	CALL	(A1)		; appel GRA_DOT (met un point)	ADD.W	D4,(A6)+OGMLPX	; D4 <-- avance en X	DECJ.W,NMO D3,DSET$	TEST.W	D0		; qq points  effacer ?	JUMP',LE NEXT$		; non => NEXT$	DEC.W	D0		; D0 <--  cause NMO	LOAD.W	D1,#CLRDOTCCLR$:	CALL	(A1)		; appel GRA_DOT (efface un point)	ADD.W	D4,(A6)+OGMLPX	; D4 <-- avance en X	DECJ.W,NMO D0,CCLR$;	JUMP'	NEXT$NEXT$:	SWAP.W	D4	ADD.W	D4,(A6)+OGMLPY	; D4 <-- avance en Y	SWAP.W	D4	DECJ.W,NMO D5,LOOP$EXIT$:	POPM.L	D0..D5,A0..A2	RET;--------\\; DOSCALE >;========/; Change d'chelle.; in	D4.B	- 1 + T F; out	D7.W	erreur; mod	D7.WDOSCALE:	PUSHM.L	D3,D4	COMP.B	D4,#'-	JUMP,EQ MOINS$	COMP.B	D4,#'1	JUMP,EQ UNUN$	COMP.B	D4,#'+	JUMP,EQ PLUS$	COMP.B	D4,#'T	JUMP,EQ TOUT$	COMP.B	D4,#'F	JUMP,EQ FLIP$	JUMP	BIP$UNUN$:	LOAD.W	D4,#SCALE11	COMP.W	D4,(A6)+OSCALE	JUMP,EQ BIP$	JUMP	SCALE$PLUS$:	LOAD.W	D4,(A6)+OSCALE	JUMP',NS PLUS2$	COMP.W	D4,#SCALEMAX	JUMP,EQ BIP$	SL.W	D4,#1	JUMP	SCALE$PLUS2$:	COMP.W	D4,#-2	JUMP,EQ UNUN$	ASR.W	D4,#1	JUMP	SCALE$MOINS$:	LOAD.W	D4,(A6)+OSCALE	JUMP',NS MOINS2$	COMP.W	D4,#SCALE11	JUMP',EQ MOINS3$	COMP.W	D4,#SCALEMIN	JUMP,EQ UNUN$	SR.W	D4,#1	JUMP	SCALE$MOINS2$:	COMP.W	D4,#-8	JUMP,LE BIP$	ASL.W	D4,#1	JUMP	SCALE$MOINS3$:	LOAD.W	D4,#-2	JUMP	SCALE$TOUT$:	CLR.L	D3	LOAD.W	D3,(A6)+OMALMX	DIV.WU	D3,(A6)+OGRDIX	; D3 <-- chelle ncessaire en X	SWAP.W	D3	TEST.W	D3	JUMP',EQ TOUT1$	ADD.L	D3,#H'10000TOUT1$:	SWAP.W	D3	CLR.L	D2	LOAD.W	D2,(A6)+OMALMY	DIV.WU	D2,(A6)+OGRDIY	; D2 <-- chelle ncessaire en Y	SWAP.W	D2	TEST.W	D2	JUMP',EQ TOUT2$	ADD.L	D2,#H'10000TOUT2$:	SWAP.W	D2	COMP.W	D3,D2	JUMP',HS TOUT3$	LOAD.W	D3,D2		; D3 <-- chelle la plus rduiteTOUT3$:	LOAD.W	D4,#SCALE11	COMP.W	D3,#1	JUMP',LE TOUT5$	LOAD.W	D4,#-2	COMP.W	D3,#2	JUMP',LE TOUT5$	LOAD.W	D4,#-4	COMP.W	D3,#4	JUMP',LE TOUT5$	LOAD.W	D4,#-8TOUT5$:	COMP.W	D4,(A6)+OSCALE	JUMP',EQ BIP$	JUMP'	SCALE$FLIP$:	LOAD.W	D4,#SCALE11	COMP.W	D4,(A6)+OSCALE	JUMP',NE SCALE$	LOAD.W	D4,#SCALELOUPE;	JUMP'	SCALE$SCALE$:	CALL	CALSCALE	CALL	DESCADRE	CALL	DESMATRIX	; redessine toutes les matrices	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$BIP$:	LOAD.W	D7,#1EXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; CALSCALE >;=========/; Modifie l'chelle en centrant toujours le mieux possible; la partie visible.; in	D4.W		nouvelle chelle (1..n);	(A6)+OSCALE.W	ancienne chelle (1..n);	(A6)+OPMOV?.W	petite mat: ancien offset zone visible;	(A6)+OPMDI?.W	petite mat: anciennes dimensions; out	(A6)+OSCALE.W	nouvelle chelle (1..n);	(A6)+OPRPO?.W	petit rect: position;	(A6)+OPRDI?.W	petit rect: dimensions;	(A6)+OPMPO?.W	petite mat: position;	(A6)+OPMDI?.W	petite mat: dimensions;	(A6)+OPMOV?.W	petite mat: offset zone visible;	(A6)+OGMPO?.W	grande mat: position;	(A6)+OGMDI?.W	grande mat: dimensions;	(A6)+OGMOV?.W	grande mat: offset zone visible;	(A6)+OGMLP?.W	rect matrice: hauteur/largeur d'un point selon chelle; mod	D7.WCALSCALE:	PUSHM.L	D0..D5	TEST.W	D4		; <<<<<<<<<<<<<<<<<<<<< PROVISOIRE <<<<<<<<<<<<<<<<<<<<<<	JUMP',NC 05$	LOAD.W	D4,#SCALE1105$:	COMP.W	D4,#SCALE11	; chelle 1:1 ?	JUMP',LE 15$		; oui => 15$ (ok)	COMP.W	D4,#SCALEMIN	JUMP',HS 10$	LOAD.W	D4,#SCALEMIN	; interdit les chelles 2..410$:	COMP.W	D4,#SCALEMAX	; chelle trop grande ?	JUMP',LS 15$		; non => 15$	LOAD.W	D4,#SCALEMAX	; oui => met le maximum; Allume ou teint la petite loupe dans les icnes.; La loupe doit tre allume si l'chelle n'est pas 1:1 !15$:	CALL	ICOSCALE	; allume/teint qq icnes; Calcul les coordonnes du point actuellement au centre de la; petite matrice visible.	LOAD.W	D0,(A6)+OPMDIX	SR.W	D0,#1	ADD.W	D0,(A6)+OPMOVX	; D0 <-- point au centre zone visible en X	LOAD.W	D1,(A6)+OPMDIY	SR.W	D1,#1	ADD.W	D1,(A6)+OPMOVY	; D1 <-- point au centre zone visible en Y; Calcul la position et les dimensions du petit rectangle.	LOAD.W	D5,#1	TEST.W	D4		; chelle "tout" ?	JUMP',NS 25$		; oui => 25$	LOAD.W	D5,D425$:	CLR.L	D3	LOAD.W	D3,(A6)+OGRDIX	DIV.WU	D3,D5		; D3 <-- largeur visible	ADD.W	D3,#8-1	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X	LOAD.W	(A6)+OPRDIX,D3	SUB.W	D3,(A6)+OGRDIX	NEG.W	D3	ADD.W	D3,(A6)+OGRPOX	LOAD.W	(A6)+OPRPOX,D3	CLR.L	D3	LOAD.W	D3,(A6)+OGRDIY	DIV.WU	D3,D5		; D3 <-- largeur visible	ADD.W	D3,#2-1	AND.B	D3,#B'11111110	; D3 <-- modulo 2 en Y	LOAD.W	(A6)+OPRDIY,D3	LOAD.W	(A6)+OPRPOY,(A6)+OGRPOY; Calcul les dimensions de la matrice visible si l'chelle est; ngative (fonction "tout").	LOAD.L	(A6)+OMALSY,(A6)+OMALMY	TEST.W	D4		; chelle ngative ?	JUMP',NC 30$		; non => 30$	LOAD.W	D3,D4	NEG.W	D3		; D3 <-- |chelle|	CLR.L	D2	LOAD.W	D2,(A6)+OMALMX	DIV.WU	D2,D3	LOAD.W	(A6)+OMALSX,D2	CLR.L	D2	LOAD.W	D2,(A6)+OMALMY	DIV.WU	D2,D3	LOAD.W	(A6)+OMALSY,D2; Calcul les nouvelles origine et dimension dans la matrice.30$:	LOAD.W	D3,(A6)+OPRDIX	; D3 <-- nouvelle largeur	LOAD.W	D2,D3	SR.W	D2,#1		; D2 <-- 1/2 nouvelle largeur	ADD.W	D0,D2	COMP.W	D0,(A6)+OMALSX	JUMP',LO 40$	LOAD.W	D0,(A6)+OMALSX40$:	SUB.W	D0,D3	JUMP',HS 42$	CLR.W	D042$:	LOAD.W	(A6)+OGMOVX,D0	LOAD.W	(A6)+OPMOVX,D0	SUB.W	D0,(A6)+OMALSX	NEG.W	D0	COMP.W	D3,D0	JUMP',LS 44$	LOAD.W	D3,D044$:	LOAD.W	(A6)+OPMDIX,D3	LOAD.W	(A6)+OPMPOX,(A6)+OPRPOX; Idem dans le sens de la hauteur.	LOAD.W	D3,(A6)+OPRDIY	; D3 <-- nouvelle hauteur	LOAD.W	D2,D3	SR.W	D2,#1		; D2 <-- 1/2 nouvelle hauteur	ADD.W	D1,D2	COMP.W	D1,(A6)+OMALSY	JUMP',LO 50$	LOAD.W	D1,(A6)+OMALSY50$:	SUB.W	D1,D3	JUMP',HS 52$	CLR.W	D152$:	LOAD.W	(A6)+OGMOVY,D1	LOAD.W	(A6)+OPMOVY,D1	SUB.W	D1,(A6)+OMALSY	NEG.W	D1	COMP.W	D3,D1	JUMP',LS 54$	LOAD.W	D3,D154$:	LOAD.W	(A6)+OPMDIY,D3	LOAD.W	D3,(A6)+OPRPOY	ADD.W	D3,(A6)+OPRDIY	SUB.W	D3,(A6)+OPMDIY	LOAD.W	(A6)+OPMPOY,D3; Met  jour les nouvelles dimensions d'un point.	LOAD.W	(A6)+OGMLPX,D5	LOAD.W	(A6)+OGMLPY,D5; Calcul l'emplacement de la matrice dans le grand rectangle; (utile au cas o le rectangle est trop grand).	LOAD.W	D3,(A6)+OGRDIX	LOAD.W	D2,(A6)+OMALSX	SUB.W	D2,(A6)+OGMOVX	MUL.WU	D2,(A6)+OGMLPX	COMP.W	D3,D2	JUMP',LS 60$	LOAD.W	D3,D260$:	LOAD.W	(A6)+OGMDIX,D3	LOAD.W	(A6)+OGMPOX,(A6)+OGRPOX	LOAD.W	D3,(A6)+OGRDIY	LOAD.W	D2,(A6)+OMALSY	SUB.W	D2,(A6)+OGMOVY	MUL.WU	D2,(A6)+OGMLPY	COMP.W	D3,D2	JUMP',LS 65$	LOAD.W	D3,D265$:	LOAD.W	(A6)+OGMDIY,D3	LOAD.W	D3,(A6)+OGRPOY	ADD.W	D3,(A6)+OGRDIY	SUB.W	D3,(A6)+OGMDIY	LOAD.W	(A6)+OGMPOY,D3; Met  jour la nouvelle chelle.	LOAD.W	(A6)+OSCALE,D4	CALL	DESINFSC	; affiche la nouvelle chelle	POPM.L	D0..D5	RET;---------\\; ICOSCALE >;---------/; Allume ou teint qq icnes en fonction d'un changement d'chelle.; in	D4.W		nouvelle chelle;	(A6)+OSCALE.W	ancienne chelle; out	-; mod	D7.WICOSCALE:	COMP.W	D4,(A6)+OSCALE	; chelle change ?	JUMP',EQ EXIT$		; non => EXIT$	PUSH.W	(A6)+OSCALE	LOAD.W	(A6)+OSCALE,D4	CALL	DESLOUPE	; dessine loupe/jumelles	POP.W	(A6)+OSCALEEXIT$:	RET;---------\\; CALCADRE >;=========/; Calcul la position et les dimensions du grand rectangle; dans la fentre.; in	-; out	(A6)+OGRPO?.W	grand rect: coin sup/gauche;	(A6)+OGRDI?.W	grand rect: dimensions;	D7.W		erreur; mod	D7.WCALCADRE:	PUSHM.L	D1..D4	LOAD.W	D7,#ERDIOUT	; D7 <-- matrice trop grande	LOAD.W	D3,(A0)+ODFFDX	SUB.W	D3,#8+8	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC 10$		; non => 10$	LOAD.W	D3,(A0)+ODFFDX	SUB.W	D3,#MARGX+(GCIMX+GCICX/2+GCIMX)*3+MARGX10$:	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 12$		; non => 12$	SUB.W	D3,#LGSCROLL12$:	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X	LOAD.W	(A6)+OGRDIX,D3	LOAD.W	D3,(A0)+ODFFDY	SUB.W	D3,#MARGY+MARGY	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 22$		; non => 22$	SUB.W	D3,#LGSCROLL22$:	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	AND.B	D3,#B'11111110	; D3 <-- modulo 2 en Y	LOAD.W	(A6)+OGRDIY,D3	LOAD.W	D3,#8	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC 30$		; non => 30$	LOAD.W	D3,#MARGX+(GCIMX+GCICX/2+GCIMX)*3+MARGX30$:	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 32$		; non => 32$	ADD.W	D3,#LGSCROLL32$:	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X	LOAD.W	(A6)+OGRPOX,D3	LOAD.W	D3,#MARGY	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	AND.B	D3,#B'11111110	; D3 <-- modulo 2 en Y	LOAD.W	(A6)+OGRPOY,D3	TEST.B	(A6)+OREGLE	; rgles prsentes ?	JUMP',F 80$		; non => 80$	ADD.W	(A6)+OGRPOY,#LGREGLE	SUB.W	(A6)+OGRDIX,#LGREGLE	SUB.W	(A6)+OGRDIY,#LGREGLE80$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET	.END