inition de l'entte d'un gnrateur de caractres; ----------------------------------------------------OGCH1	=	256+128*1	; 128 x h1OGCH2	=	256+128*2	; 128 x h2OGCMAT	=	256+128*3	; 128 x matrix; Variables d'un bloc-notes; -------------------------NBBLOC	=	2	.LOC	0OBLKPT:	.BLKB	4		; ^matrice du bloc-notesOBLKP1:	.BLKB	4		; P1(y;x)OBLKP2:	.BLKB	4		; P2(y;x)OBLKNBB:.BLKB	2		; nb bytes/ligneLGBLOC:; Variables pour les zones; ------------------------NBZONE	=	10	.LOC	0OZOPM:	.BLKB	4		; ^matriceOZOLY:	.BLKB	2		; hauteur (dy)OZOLX:	.BLKB	2		; largeur (dx)OZOSCA:	.BLKB	2		; chelleOZOOV:	.BLKB	4		; offset zone visibleOZODI:	.BLKB	4		; dimensions zone visibleOZONAM:	.BLKB	LBUFILE		; nom du dessinOZOMAJ:	.BLKB	1		; 1 => mise  jour ncessaire	.EVENOZOPC:	.BLKB	4		; ^CLUTLZO:; Variables des pavs de texte; ----------------------------NBPAVE	=	10	.LOC	0OPAPOS:	.BLKB	4		; position (y;x)OPADIM:	.BLKB	4		; dimensions (dy;dx)OPAOPO:	.BLKB	4		; ancienne position (y;x)OPAODI:	.BLKB	4		; anciennes dimensions (dy;dx)LPA:; Descripteur pour une ligne ditable dans une DBOX; -------------------------------------------------	.LOC	0ODBOFF:	.BLKB	2		; offset variableODBTYP:	.BLKB	2		; type DBTYPN =  0			;  nombre entier positif DBTYPNS=  1			;  nombre entier sign (+/-) DBTYPNF=  2			;  nombre entier positif facultatif DBTYPA =  10			;  chane alphanumriqueODBMIN:	.BLKB	2		; valeur minimaleODBMAX:	.BLKB	2		; valeur maximaleODBINC:	.BLKB	2		; incrmentODBRGC:	.BLKB	2		; rang pour DBOX_GETCOODBRED:	.BLKB	2		; rang pour DBOX_MEDITODBNBC:	.BLKB	2		; nb de caractresLDB:; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHDGENC:.BLKB	2		; canal module DGENCOCHDESSIN:.BLKB	2		; canal module DESSINOCHDESS2:.BLKB	2		; canal module DESSIN2OCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHCOUPE:.BLKB	2		; canal module COUPEOCHSPLINE:.BLKB	2		; canal module SPLINEOCHSTRET