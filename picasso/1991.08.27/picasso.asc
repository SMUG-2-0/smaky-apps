OHAZA:	.BLKB	8		; registre 63 bits pour gnrateur alatoireOMACHINE:.BLKB	1		; type de la machine (SMAKY8/SMAKY100)	.EVENONOZO:	.BLKB	2		; no de la zone visibleOTAZO:	.BLKB	LZO*NBZONE	; table des zonesOPICO:	.BLKB	4		; ^matrice des icnes de gaucheODICO:	.BLKB	4		; position des icnes de gaucheOTICO:	.BLKB	256/8		; tables des icnes grises (bits)OXICO:	.BLKB	1		; type des icnes de gauche (NIVxxx)OYICO:	.BLKB	1		; sous-type (ICO...)OBICO:	.BLKB	1		; indique si clic haut/bas dans icneOGICO:	.BLKB	1		; indique si clic gauche/droite dans icneOMICO:	.BLKB	1		; indique si clic milieu dans icne	.EVENOPMAT:	.BLKB	4		; ^matriceOPMAC:	.BLKB	4		; ^matrice copie (pour UNDO)OPMAM:	.BLKB	4		; ^matrice masqueOMANBP:	.BLKB	2		; matrice: nb de bits/pixelOMALMY:	.BLKB	2		; matrice: nb de points en YOMALMX:	.BLKB	2		; matrice: nb de points en XOMANBB:	.BLKB	2		; matrice: nb de bytes en XOMANBS:	.BLKB	2		; matrice: nb de bytes en X (source)OMANBD:	.BLKB	2		; matrice: nb de bytes en X (destination)OMALSY:	.BLKB	2		; matrice: nb de points en Y (si -OSCALE)OMALSX:	.BLKB	2		; matrice: nb de points en X (si -OSCALE)OMASTR:	.BLKB	1		; matrice: flags pour stretch BMASTR	=  0			;            stretch BMAHOM	=  1			;            homothtie	.EVENOGRPOY:	.BLKB	2		; grand rect: coin sup/gauche en YOGRPOX:	.BLKB	2		; grand rect: coin sup/gauche en XOGRDIY:	.BLKB	2		; grand rect: hauteurOGRDIX:	.BLKB	2		; grand rect: largeurOGMPOY:	.BLKB	2		; grande mat: coin sup/gauche en YOGMPOX:	.BLKB	2		; grande mat: coin sup/gauche en XOGMDIY:	.BLKB	2		; grande mat: hauteurOGMDIX:	.BLKB	2		; grande mat: largeurOGMOVY:	.BLKB	2		; grande mat: offset zone visible en YOGMOVX:	.BLKB	2		; grande mat: offset zone visible en XOGMLPY:	.BLKB	2		; grande mat: hauteur d'un point chelle nOGMLPX:	.BLKB	2		; grande mat: largeur d'un point chelle nOPRPOY:	.BLKB	2		; petit rect: coin sup/gauche en YOPRPOX:	.BLKB	2		; petit rect: coin sup/gauche en XOPRDIY:	.BLKB	2		; petit rect: hauteurOPRDIX:	.BLKB	2		; petit rect: largeurOPMPOY:	.BLKB	2		; petite mat: coin sup/gauche en YOPMPOX:	.BLKB	2		; petite mat: coin sup/gauche en XOPMDIY:	.BLKB	2		; petite mat: hauteurOPMDIX:	.BLKB	2		; petite mat: largeurOPMOVY:	.BLKB	2		; petite mat: offset zone visible en YOPMOVX:	.BLKB	2		; petite mat: offset zone visible en XOSCALE:	.BLKB	2		; grande mat: chelle (1..n)ODEF:	.BLKB	4		; dfinitionsOFLAGS:	.BLKB	4		; flagsOPAS:	.BLKB	2		; pas pour le dessinODD:	.BLKB	1		; mode de dplacementOREGLE:	.BLKB	1		; 1 => rgles prsentes	.EVENOASVER:	.BLKB	LSCVAR		; variables de l'ascenseur verticalOASHOR:	.BLKB	LSCVAR		; variables de l'ascenseur horizontalORGVAR:	.BLKB	LRGVAR		; variables des rglesOLASTP1:.BLKB	4		; slection: P1 pour COPY-clicOLASTP2:.BLKB	4		; slection: P2 pour COPY-clicOSEOHG:	.BLKB	4		; slection: point original sup/gaucheOSEOHD:	.BLKB	4		; slection: point original sup/droiteOSEOBG:	.BLKB	4		; slection: point original inf/gaucheOSEOBD:	.BLKB	4		; slection: point original inf/droiteOSEPHG:	.BLKB	4		; slection: point courant sup/gaucheOSEPHD:	.BLKB	4		; slection: point courant sup/droiteOSEPBG:	.BLKB	4		; slection: point courant inf/gaucheOSEPBD:	.BLKB	4		; slection: point courant inf/droiteOSEOMI:	.BLKB	4		; slection: centre de symtrie originalOSEPMI:	.BLKB	4		; slection: centre de symtrie courantOSEANG:	.BLKB	2		; slection: angle de la rotation [degrs]OSEBLX:	.BLKB	1		; slection: dplacement seulement en XOSEBLY:	.BLKB	1		; slection: dplacement seulement en Y	.EVENOMAJ:	.BLKB	1		; 1 => mise  jour ncessaireODRAW:	.BLKB	1		; 1 => il faut tout redessiner	.EVENODBLIN:	.BLKB	50		; dbox: ligne en ditionODBPTE:	.BLKB	4		; dbox: ^table des objets ditablesODBPA1:	.BLKB	2		; dbox: paramtre 1ODBPA2:	.BLKB	2		; dbox: paramtre 2ODBPA3:	.BLKB	2		; dbox: paramtre 3ODBPA4:	.BLKB	2		; dbox: paramtre 4ODBPA5:	.BLKB	2		; dbox: paramtre 5OCERAY:	.BLKB	2		; cercle: rayon  afficherOCEANG:	.BLKB	2		; cercle: angle  afficherOCSET:	.BLKB	4		; couleur setOCCLR:	.BLKB	4		; couleur clearOOUTIL:	.BLKB	1		; outil (crayon, pinceau, etc.)OOBJET:	.BLKB	1		; objet (trait, droite, cercle, etc.)OSELECT:.BLKB	1		; slection (zone ou filet)OLOUTIL:.BLKB	1		; loupe: dernier outilOLOBJET:.BLKB	1		; loupe: dernier objet	.EVENONPDEF:	.BLKB	2		; no trame du pinceauONTDEF:	.BLKB	2		; no trame de remplissageOPDEF:	.BLKB	MAXDEF*(8+2)	; trames du pinceauOTDEF:	.BLKB	MAXDEF*8	; trames de remplissageOBIFAN:	.BLKB	4		; bidon: fanionsOBIP1:	.BLKB	4		; bidon: P1OBIP2:	.BLKB	4		; bidon: P2OBILG:	.BLKB	2		; bidon: longueurOBIANG:	.BLKB	2		; bidon: angleOBIDEL:	.BLKB	2		; bidon: 0 si |dx| < |dy|OBIDIV:	.BLKB	2		; bidon: diviseur (Ax^2/Ay+Ay)OBINBC:	.BLKB	2		; bidon: nb de couleursOBICOL:	.BLKB	NBCOUL		; bidon: buffer pour les couleursOBIANC:	.BLKB	2		; bidon: nb de couleurs affichesOSPFAN:	.BLKB	4		; spray: fanionsOSPDIA:	.BLKB	2		; spray: diamtre (2..100)OSPVIT:	.BLKB	2		; spray: vitesse (0..10)OSPDIM:	.BLKB	2		; spray: dimensions des gouttes (1..16)OSPCOL:	.BLKB	4		; spray: couleurOSPTPO:	.BLKB	4		; spray: position testOSPTDI:	.BLKB	4		; spray: dimensions testOEPFAN:	.BLKB	4		; ponge: fanionsOEPDIA:	.BLKB	2		; ponge: diamtreOEPINT:	.BLKB	2		; ponge: intensitOEPCOL:	.BLKB	4		; ponge: couleurOEPPMA:	.BLKB	4		; ponge: ^matricesOEPLSF:	.BLKB	4		; ponge: derniers fanionsOEPLSD:	.BLKB	2		; ponge: dernier diamtreOEPLSI:	.BLKB	2		; ponge: dernire intensitORRECT:	.BLKB	2		; rectangle: rayon des arrondis (0..n)OTRECT:	.BLKB	1		; rectangle: type (BRExxxx)OPOLY:	.BLKB	1		; polygone: type (BPOLYx)OMCERC:	.BLKB	1		; mode cercle: type (BMCExxx)OARC:	.BLKB	1		; cercle: bits pour les arcs (BARCx)	.EVENONARC:	.BLKB	2		; arc: valeurOBARC:	.BLKB	10		; arc: buffer pour valeurOBLOC:	.BLKB	LGBLOC*NBBLOC	; bloc-notesOSPLPT:	.BLKB	4*MAXSPLINE	; points pour splineOSPLOF:	.BLKB	1		; ouvert/ferm	.EVENOSTRETCH:.BLKB	ST_LGTRECT	; variables pour le module STRETCHOSTRHV:	.BLKB	1		; horizontal/verticalOSTRDF:	.BLKB	1		; type de dformationOSTRRO:	.BLKB	1		; sens de la rotation	.EVENOIOFAN:	.BLKB	4		; i/o: fanionsOTRAPA:	.BLKB	2		; trame: pas (2..64)OTRANI:	.BLKB	2		; trame: niveau (2..16)OTRALU:	.BLKB	2		; trame: luminosit (-8..+8)OTRAFA:	.BLKB	2		; trame: famille (0..1)OTRAT1:	.BLKB	MAXDEF*8	; trame: trames de remplissage famille 1OTRAT2:	.BLKB	MAXDEF*8	; trame: trames de remplissage famille 2OTRAT3:	.BLKB	MAXDEF*8	; trame: trames de remplissage famille 3OLISPA:	.BLKB	2		; lisse: pas (2..64)OLISLU:	.BLKB	2		; lisse: luminosit (-1..+1)OTAPAVE:.BLKB	(NBPAVE+1)*LPA	; liste des pavs de texteOPTTEXT:.BLKB	4		; ^ligne de texte en ditionONBTEXT:.BLKB	2		; nb de caractresOCUTEXT:.BLKB	2		; position du curseurOCPTEXT:.BLKB	4		; curseur: y;xOCHTEXT:.BLKB	2		; curseur: hOPOTEXT:.BLKB	4		; position ligne de texte en ditionOPSTEXT:.BLKB	4		; position de la souris pour EDDETECTOHTTEXT:.BLKB	2		; hauteur de la ligne \OLGTEXT:.BLKB	2		; largeur de la ligne /OOPTEXT:.BLKB	4		; ancienne positionOOHTEXT:.BLKB	2		; ancienne hauteur de la ligne \OOLTEXT:.BLKB	2		; ancienne largeur de la ligne /OILTEXT:.BLKB	2		; interligneOICTEXT:.BLKB	2		; intercaractreOECTEXT:.BLKB	2		; espace-caractresOCNTEXT:.BLKB	2		; critre pour les coupures dans les motsOCXTEXT:.BLKB	2		; espace pour le contour en XOCYTEXT:.BLKB	2		; espace pour le contour en YOBLTEXT:.BLKB	LBLTEXT		; ligne de points si pouse le contourOJUTEXT:.BLKB	1		; mode de justificationOCMTEXT:.BLKB	1		; coupures dans les motsOCTTEXT:.BLKB	1		; pouse le coutourO3PTEXT:.BLKB	1		; 3 poignes ?ODETEXT:.BLKB	1		; est-ce que le texte dborde ?OHVTEXT:.BLKB	1		; horizontal/verticalODATEXT:.BLKB	1		; d'accord/annuleOACTEXT:.BLKB	1		; accent flottant en coursOVIFDCR:.BLKB	1		; enable/disable <cr>ODTTEXT:.BLKB	1		; dtecte/affiche pour EDDETECTOQCTEXT:.BLKB	1		; normal/curseur pour EDAFTEXT	.EVENOBUMOT:	.BLKB	LBUMOT		; mot  couperOBULMO:	.BLKB	LBUMOT*2	; positions des caractres du mot  couperOBUCOUP:.BLKB	LBUCOUP+2	; coupures de motsOBUGC:	.BLKB	LGGC*MAXGC	; table des gnrateurs de caractresOGCLIST:.BLKB	MAXGENC*3	; liste des gencars contenus sur disqueOFAGC:	.BLKB	4		; fanions pour dbox des gencarsOBUNAME:.BLKB	LBUFILE		; nom du dessin en mmoireOBUPRES:.BLKB	16		; nom de la prsentationOBUFIN:	.BLKB	LBUFILE		; nom du fichier en entre (prend)OBUFAJ:	.BLKB	LBUFILE		; nom du fichier en entre (ajoute)OBUFOUT:.BLKB	LBUFILE		; nom du fichier en sortieOBUFTX:	.BLKB	LBUFILE		; nom du fichier texteOBXFILE:.BLKB	LBUFILE		; nom du fichier avec extensionOBUHIMA:.BLKB	LGHIMA+LGCLUT	; en-tte d'un fichier .image + CLUTOBUHDEF:.BLKB	LGHDEF		; en-tte d'un fichier .ddesOXZOOM:	.BLKB	2		; facteur de zoom spcial en X (*1000)OYZOOM:	.BLKB	2		; facteur de zoom spcial en Y (*1000)OBXZOOM:.BLKB	10		; buffer pour valeur de zoom en XOBYZOOM:.BLKB	10		; buffer pour valeur de zoom en YOOPREL:	.BLKB	LREL*8		; relief: matrices d'oprationsOO1REL:	.BLKB	LREL		; relief: une matrice d'oprationsOPTREL:	.BLKB	2		; relief: ^relatifOBUREL:	.BLKB	MAXREL		; relief: buffer pour oprationsORDLG:	.BLKB	2		; relief: dimension d'un pointORDOP:	.BLKB	1		; relief: opration (0..2)	.EVENOFDBTAB:.BLKB	FDBNBX		; filtre: tableOFDBCNB:.BLKB	FDBNBX		; filtre: couleur -> noir/blancOFDBSAV:.BLKB	FDBNBX		; filtre: sauvetage si annuleOFDBNNB:.BLKB	2		; filtre: numro de l'opration "cnb"OFDBPTF:.BLKB	4		; filtre: ^tableOFDBMOD:.BLKB	1		; filtre: mode (0=filtre, 1=cnb)	.EVENOFDBPOS:.BLKB	4		; filtre: position coin sup/gaucheOFDBDIM:.BLKB	4		; filtre: dimensions d'une caseOFDBFAN:.BLKB	4		; filtre: fanionsOSTPRI:	.BLKB	LGPRI0		; status de l'imprimanteOFACX:	.BLKB	2		; facteur rduction en XOFACY:	.BLKB	2		; facteur rduction en YOMMX:	.BLKB	2		; nb de 1/10 de um pour un point en XOMMY:	.BLKB	2		; nb de 1/10 de um pour un point en YLGVAR:; Programme; ---------	.LOC	0	JUMP	START	.INS	PICTAB1.ASISTART:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CALL	_WAITMOUSE	; met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	; met TOUTES les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	LOAD.B	(A6)+OGCLIST,#-1	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*5+1	; est-ce au moins 5.1 ?	JUMP,LO ERFAT2		; non => ERFAT2	LOAD.L	A3,#R16"TXERFATDIS	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT2	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	COMP.W	(A0)+ODFIIX,#1	; cran de type SMAKY100/324 ?	JUMP,NE ERFAT2		; non => patatras ...	COMP.W	(A0)+ODFCNB,#NBCOUL	JUMP,NE ERFAT2	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	LOAD.L	A3,#R16"TXERFATTXT	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATICO	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATICO1	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT+1	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A1,#R16"TXERFATGRA	LOAD.W	D3,#GRA_DOT	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+ODOT,A3	LOAD.W	D3,#GRA_GDOT	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OGDOT,A3	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OQXDOT,A3	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+ORASTER,A3	LOAD.W	D3,#GRA_CRASTER	LIB_	GETAD	JUMP',NE CRAST$	LOAD.L	(A6)+OCRASTER,A3CRAST$:	LOAD.W	D3,#GRA_MATRIX	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OMATRIX,A3	LOAD.W	D3,#GRA_TRAME	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OTRAME,A3	LOAD.W	D3,#GRA_CLEAR	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OCLEAR,A3	LOAD.W	D3,#GRA_SET	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OSET,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OINV,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMDGENC	LOAD.W	D3,#DGENC_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDGENC,D1	LOAD.L	A3,#R16"NMDESSIN	LOAD.W	D3,#DESSIN_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDESSIN,D1	LOAD.L	A3,#R16"NMDESS2	LOAD.W	D3,#DESS2_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDESS2,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMCOUPE	LOAD.W	D3,#COUPE_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHCOUPE,D1	LOAD.L	A3,#R16"NMSPLINE	LOAD.W	D3,#SPLINE_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSPLINE,D1	LOAD.L	A3,#R16"NMSTRETCH	LOAD.W	D3,#ST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSTRETCH,D1	LOAD.L	A3,#R16"NMBLOC	LOAD.W	D3,#BLOC_FIRST	LIB_	OPEN	JUMP',NE NOBLOC$	LOAD.W	(A6)+OCHBLOC,D1	BLOC_	OPEN		; ouverture globaleNOBLOC$:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	LOAD.L	A3,#R16"NMICOLOR	LOAD.W	D3,#ICOL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHICOLOR,D1NOCOUL$:	LOAD.L	A3,#R16"NMPRINTA	LOAD.W	D3,#PRINTA_FIRST	LIB_	OPEN	JUMP',NE 30$	LOAD.W	(A6)+OCHPRINTA,D1	CLR.L	D3	PRINTA_	OPEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OCAPRINT,A230$:	CALL	_RDSTPRINT	; lit le status de l'imprimante	LOAD.L	A3,#R16"NMSCAN	LOAD.W	D3,#SCAN_FIRST	LIB_	OPEN	JUMP',NE 32$	LOAD.W	(A6)+OCHSCAN,D1	SCAN_	OPEN	JUMP',NE 31$	LOAD.L	(A6)+OCASCAN,D6	JUMP'	32$31$:	LIB_	CLOSE32$:	CALL	_COUPSAC	; coup de sac des nombres alatoires	LOAD.W	(A6)+OMANBP,#NBBITP	LOAD.L	(A6)+OCSET,#NBCOUL-1;	LOAD.L	(A6)+OCCLR,#0	LOAD.B	(A6)+OOUTIL,#ICOCRAYON	LOAD.B	(A6)+OOBJET,#ICOTRAIT	LOAD.B	(A6)+OSELECT,#ICOZONE	LOAD.L	(A6)+ODEF,#2^BDEFPG!2^BDEFICO!2^BDEFASC	LOAD.L	(A6)+OFLAGS,#2^BFLAUTO	LOAD.W	(A6)+OPAS,#1	LOAD.L	(A6)+OIOFAN,#2^BDBCOUL	LOAD.L	A3,#R16"TXERFATMEM	LOAD.L	D4,#MAXTEXT+2	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour pav de texte	JUMP,NE ERFAT2	LOAD.L	(A6)+OPTTEXT,A4	LOAD.B	(A6)+OSTRDF,#ICODEFORMEQQ	LOAD.B	(A6)+OSTRRO,#ICOTOURNEP	LOAD.B	(A6)+OSPLOF,#ICOSPLINEO	LOAD.B	(A6)+OJUTEXT,#ICOJUSTA	LOAD.W	(A6)+OCNTEXT,#5-1	LOAD.W	(A6)+OCXTEXT,#2	LOAD.W	(A6)+OCYTEXT,#2	LOAD.W	(A6)+OTRAPA,#8	LOAD.W	(A6)+OTRANI,#8;	LOAD.W	(A6)+OTRALU,#0	LOAD.L	A3,#(A6)+OTRAT1	CLR.W	D4	DESS2_	TGET	LOAD.W	D4,#((17*8)/2)-140$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,40$	LOAD.L	A3,#(A6)+OTRAT2	LOAD.W	D4,#1	DESS2_	TGET	LOAD.W	D4,#((17*8)/2)-141$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,41$	LOAD.L	A3,#(A6)+OTRAT3	LOAD.W	D4,#2	DESS2_	TGET	LOAD.W	D4,#((17*8)/2)-142$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,42$;	LOAD.L	A3,#R16"TXERFATMEM	CALL	_CALCADRE	; calcul pos/dim du grand rectangle	LOAD.W	D3,(A6)+OGRDIX	; D3 <-- largeur visible	LOAD.W	D4,(A6)+OGRDIY	; D4 <-- hauteur visible	CALL	_GETMEMMATRIX	; rserve mmoire pour matrices	JUMP,NE ERFAT2	CALL	_DEFGENCAR	; utilise tous les gencars par dfaut	LOAD.L	A3,#(A6)+OPDEF	CLR.W	D4	DESSIN_	DGET	LOAD.W	D4,#((MAXDEF*(8+2))/2)-150$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,50$	LOAD.L	A3,#(A6)+OTDEF	CLR.W	D4	DESSIN_	TGET	LOAD.W	D4,#((MAXDEF*8)/2)-152$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,52$	LOAD.L	A3,#(A6)+OOPREL	CLR.W	D4	DESS2_	RGET	LOAD.W	D4,#((LREL*8)/2)-156$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,56$	LOAD.W	(A6)+ONPDEF,#8	; utilise trame pinceau par dfaut	LOAD.W	(A6)+ONTDEF,#3	; utilise trame remplissage par dfaut	LOAD.L	(A6)+OBIFAN,#2^BBITRAM!2^BBILIN	LOAD.W	(A6)+OBILG,#50	LOAD.W	(A6)+OBIANG,#90	LOAD.W	(A6)+OBINBC,#4;	LOAD.B	(A6)+OBICOL+0,#0	LOAD.B	(A6)+OBICOL+1,#1	LOAD.B	(A6)+OBICOL+2,#2	LOAD.B	(A6)+OBICOL+3,#3	LOAD.L	(A6)+OSPFAN,#2^BSPMOY!2^BSPCALL!2^BSPTRAM	LOAD.W	(A6)+OSPDIA,#20	LOAD.W	(A6)+OSPVIT,#5	LOAD.W	(A6)+OSPDIM,#1	LOAD.L	(A6)+OSPCOL,#1	LOAD.L	(A6)+OEPFAN,#2^BSPCENT!2^BSPCALL	LOAD.W	(A6)+OEPDIA,#8	LOAD.W	(A6)+OEPINT,#5	LOAD.L	(A6)+OEPCOL,#1	CLR.W	(A6)+ORRECT	LOAD.B	(A6)+OTRECT,#2^BRECONT!2^BRETRAN	LOAD.B	(A6)+OPOLY,#2^BPOLYC	LOAD.B	(A6)+OMCERC,#2^BMCERAY	LOAD.B	(A6)+OARC,#2^BARC1	LOAD.W	(A6)+ONARC,#90	LOAD.B	(A6)+OBARC+0,#'9	LOAD.B	(A6)+OBARC+1,#'0;	CLR.B	(A6)+OBARC+2	CLR.B	(A6)+OFDBMOD	CLR.W	D3	CALL	FILDBINIT	; initialise le filtre	INC.B	(A6)+OFDBMOD	CLR.W	D3	CALL	FILDBINIT	; initialise les conversions couleur -> noir/blanc	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCRET$	; non => NOCRET$	LOAD.L	A3,#R16"NMPIC	LOAD.L	A5,#R16"TCOUL	LOAD.L	D3,#2^BICCRET	ICOL_	INIT		; charge PICASSO.CRET	LOAD.L	(A6)+OIDCRET,D5NOCRET$:	LOAD.W	D4,#SCALE11	LOAD.W	(A6)+OSCALE,D4	CALL	_CALSCALE	; met l'chelle par dfaut	CALL	_CCMO		; enlve la souris	CALL	_DESWDO	CALL	_DESCADRE	CALL	_AFMENU		; affiche les soft-keys	LIB	?BUZZ		; signal: c'est prt !	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SKPNAM	JUMP,NE LOOP	LOAD.L	A4,#(A6)+OBUFIN70$:	LOAD.B	D3,(A3+)	JUMP',EQ 75$	COMP.B	D3,#CR	JUMP',EQ 75$	COMP.B	D3,#SPACE	JUMP',EQ 75$	COMP.B	D3,#TAB	JUMP',EQ 75$	COMP.B	D3,#'/	JUMP',EQ 75$	LOAD.B	(A4+),D3	; OBUFIN <-- nom ligne de commande	JUMP	70$75$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUFIN	; A3 <-- ^nom	LOAD.L	D4,#2^BDBCOUL	; D4 <-- image couleur (.COLOR)	JUMP	_PRENDF		; essaye de prendre ce fichier ...;	***************;	*    LOOP     *;	***************MATRIX:	TEST.B	(A6)+ODRAW	; faut-il tout redessiner ?	JUMP',T LOOP		; oui => LOOP	CALL	DESMATRIX	; dessine les deux matricesLOOP:	TEST.B	(A6)+ODRAW	; faut-il tout redessiner ?	JUMP',F DRAW$		; non => DRAW$	CALL	_DESWDO		; dessine la fentre	CALL	_DESCADRE	; dessine le cadre	CALL	DESMATRIX	; dessine les deux matrices	CLR.B	(A6)+ODRAW	; tout est redessinDRAW$:	CALL	FULLGREYICONE	; (d)grise qq icnes	CALL	_SCMO		; remet la souris	CALL	_NORMMOUSE	; enlve le sablierLOOP$:	LOAD.B	D3,(A6)+OOUTIL	JUMP',NE SELMO$	LOAD.B	D3,(A6)+OOBJETSELMO$:	CALL	_SELMO		; utilise le bon lutin	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP',NE OUT$	CALL	_RGMOUSE	; dessine la position dans les rgles	TEST.L	(A6)+OPOTEXT	; ligne de texte en dition ?	JUMP',NE WAIT$		; oui => WAIT$ ( cause du curseur)	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP',NE OUT$	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP',EQ AFFXY$OUT$:	LOAD.L	D3,#-1		; D3 <-- on est pas dans l'aire de dessinAFFXY$:	COMP.L	D3,(A6)+OLASTXY	JUMP',EQ WAIT$	LOAD.L	(A6)+OLASTXY,D3	CALL	DESINFXY	; affiche X= et Y= dans les informationsWAIT$:	LIB	?GETKEY		; attend clavier/souris ...	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP,BS WAIT$		; non => WAIT$				; oui =>	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ LOOP$		; oui => LOOP$EXECUTE:	COMP.W	D3,#F0+SHIFT	JUMP',LO SHIFT$	COMP.W	D3,#F15+SHIFT	JUMP',HI SHIFT$	SUB.W	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)SHIFT$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC	LOAD.L	A4,#R16"TAKEY-6	LOAD.W	D2,D3	COMP.B	D2,#'a	JUMP',LO LOOP$	COMP.B	D2,#'z	JUMP',HI LOOP$	SUB.B	D2,#'a-'A	; D2 <-- lettre MAJUSCULELOOP$:	ADD.L	A4,#6	TEST.W	(A4)+0	JUMP',EQ END$	COMP.W	D2,(A4)+0	JUMP,NE LOOP$	LOAD.W	D3,(A4)+2	LOAD.W	D1,(A4)+4	JUMP	CLICICONEEND$:	LOAD.L	A1,#0	CALL	DOKASCENSEUR	; agit dans ascenseurs selon touche	JUMP,EQ LOOP	COMP.W	D3,#UNDO	JUMP,EQ EXUNDO	COMP.W	D3,#BS	JUMP,EQ EXUNDO	COMP.W	D3,#DEL	JUMP,EQ EXUNDO	COMP.W	D3,#DELETE	JUMP,EQ EXUNDO	COMP.W	D3,#HELP	JUMP,EQ DOHELP	COMP.W	D2,#H'100*(2^BPROGRA)+'C	JUMP,EQ COLOR	COMP.W	D2,#H'100*(2^BPROGRA)+'N	JUMP,EQ CONVNB	COMP.W	D3,#H'100*(2^BKILL)+SPACE	JUMP,EQ _COUPE	COMP.W	D3,#H'100*(2^BCOPY)+SPACE	JUMP,EQ _COPIE	COMP.W	D3,#H'100*(2^BCURSOR)+SPACE	JUMP,EQ _COLLE	COMP.W	D3,#H'100*(2^BSHOW)+SPACE	JUMP,EQ _CLASSEUR	COMP.W	D3,#F0	JUMP,EQ FINI	COMP.W	D3,#END	JUMP,EQ FINI	COMP.W	D3,#F1	JUMP,EQ _PREND	COMP.W	D3,#H'100*(2^BSHOW)+DEFINE	JUMP,EQ _PREND	COMP.W	D3,#F2	JUMP,EQ _AJOUTE	COMP.W	D3,#F3	JUMP,EQ _SAUVE	COMP.W	D3,#H'100*(2^BCOPY)+DEFINE	JUMP,EQ _SAUVE	COMP.W	D3,#F4	JUMP,EQ MODIFDEF	COMP.W	D3,#F5	JUMP,EQ MODIFZOOM	COMP.W	D3,#F6	JUMP,EQ _SCAN	LOAD.B	D4,#'1	COMP.W	D3,#F8	JUMP,EQ SCALE	LOAD.B	D4,#'-	COMP.W	D3,#F7	JUMP,EQ SCALE	LOAD.B	D4,#'+	COMP.W	D3,#F9	JUMP,EQ SCALE	LOAD.B	D4,#'T	COMP.W	D3,#F13	JUMP,EQ SCALE	COMP.W	D3,#F10	JUMP,EQ REGLE	COMP.W	D3,#F11	JUMP,EQ FILTRE	COMP.W	D3,#F12	JUMP,EQ NEGATIF	COMP.W	D3,#F14	JUMP,EQ EFFACE	COMP.W	D3,#F15	JUMP,EQ _IMPRIME	COMP.W	D3,#H'100*(2^BSHOW)+'0	JUMP',LO 60$	COMP.W	D3,#H'100*(2^BSHOW)+'9	JUMP,LS SHOWZONE60$:	JUMP	BIPCLIC:	LOAD.W	D1,D3		; D1 <-- bouton press	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP; Traite le cas o la souris est dans un ascenseur.	LOAD.L	A1,#0	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP; Traite le cas o la souris est dans les informations.	CALL	ICAMOVE		; souris dans les informations ?	JUMP,EQ CLICINFO	; oui => CLICINFO; Traite le cas o la souris est dans une icne.	CALL	_MOVICONE	; souris dans une icne ?	JUMP,EQ CLICICONE	; oui => CLICICONE				; non =>	CALL	_DPLICONE	; dplace toutes les icnes ?	JUMP,EQ LOOP		; oui => LOOP	LOAD.W	D3,D1		; D3 <-- bouton press	COMP.W	D3,#KEYMGP	JUMP,EQ OUTIL	COMP.W	D3,#KEYMMP	JUMP,EQ MILIEU	COMP.W	D3,#KEYMDP	JUMP,EQ ENTOURE	JUMP	BIPCLICINFO:	TEST.W	D2	JUMP,EQ MENUZONE	DEC.W	D2	JUMP,EQ MENUSCALE	DEC.W	D2	JUMP,EQ MENUPAS	JUMP	BIPCLICICONE:	COMP.W	D1,#KEYMDP	JUMP,EQ CLICDEF	LOAD.L	D4,D3	LIB	?GETSHIFT	; D4 <-- touches super-shift	EX.L	D4,D3	TEST.L	D4:#BCHANGE	; touche (CHANGE) enfonce ?	JUMP,BS CLICDEF	COMP.B	D3,#ICOCRAYON	JUMP,EQ OUTILNEW	COMP.B	D3,#ICOPINCEAU	JUMP,EQ OUTILNEW	COMP.B	D3,#ICOPLOUPE	JUMP,EQ LOUPENEW	COMP.B	D3,#ICOGOMME	JUMP,EQ OUTILNEW	COMP.B	D3,#ICOEPONGE	JUMP,EQ OUTILNEW	COMP.B	D3,#ICOMAIN	JUMP,EQ MAINNEW	COMP.B	D3,#ICOSPRAY	JUMP,EQ OUTILNEW	COMP.B	D3,#ICOBIDON	JUMP,EQ OUTILNEW	COMP.B	D3,#ICOPIPETTE	JUMP,EQ OUTILNEW	COMP.B	D3,#ICOTRAIT	JUMP,EQ OBJETNEW	COMP.B	D3,#ICODROITE	JUMP,EQ OBJETNEW	COMP.B	D3,#ICOSPLINE	JUMP,EQ OBJETNEW	COMP.B	D3,#ICORECTANGLE	JUMP,EQ OBJETNEW	COMP.B	D3,#ICOCERCLE	JUMP,EQ OBJETNEW	COMP.B	D3,#ICOTEXTE	JUMP,EQ OBJETNEW	COMP.B	D3,#ICOCOLLE	JUMP,EQ _COLLE	COMP.B	D3,#ICOBLOC1	JUMP,EQ OBJETNEW	COMP.B	D3,#ICOBLOC2	JUMP,EQ OBJETNEW;;?	COMP.B	D3,#ICOBLOC3;;?	JUMP,EQ OBJETNEW	COMP.B	D3,#ICOCOULSET	JUMP,EQ COULSET	COMP.B	D3,#ICOCOULCLR	JUMP,EQ COULCLR	COMP.B	D3,#ICOCOULEUR	JUMP,EQ COULEUR	COMP.B	D3,#ICOPDEF	JUMP,EQ MODIFPDEF	COMP.B	D3,#ICOTDEF	JUMP,EQ MODIFTDEF	COMP.B	D3,#ICOZONE	JUMP,EQ SELECTNEW	COMP.B	D3,#ICOFILET	JUMP,EQ SELECTNEW	COMP.B	D3,#ICOCROCHET	JUMP,EQ SELECTNEW	JUMP	BIPCLICDEF:	COMP.B	D3,#ICOPINCEAU	JUMP,EQ MODIFPDEF	COMP.B	D3,#ICOBIDON	JUMP,EQ MODIFBIDON	COMP.B	D3,#ICOSPRAY	JUMP,EQ MODIFSPRAY	COMP.B	D3,#ICOEPONGE	JUMP,EQ MODIFEPONGE	COMP.B	D3,#ICORECTANGLE	JUMP,EQ MODIFRDEF	COMP.B	D3,#ICOCERCLE	JUMP,EQ MODIFADEF	COMP.B	D3,#ICOTEXTE	JUMP',EQ TEXT$	COMP.B	D3,#ICOCOLLE	JUMP,EQ _CLASSEUR	COMP.B	D3,#ICOZONE	JUMP,EQ MODIFFLAGS	COMP.B	D3,#ICOFILET	JUMP,EQ MODIFFLAGS	COMP.B	D3,#ICOCROCHET	JUMP,EQ MODIFFLAGS	JUMP	BIPTEXT$:	CLR.B	D3		; D3 <-- refait	JUMP	_TEXTECOULSET:	LOAD.L	A3,#R16"TCOLRS	LOAD.L	A2,#(A6)+OCSET	; A2 <-- ^couleur set	JUMP'	COULXCOULCLR:	LOAD.L	A3,#R16"TCOLRC	LOAD.L	A2,#(A6)+OCCLR	; A2 <-- ^couleur clear	JUMP'	COULXCOULEUR:	LOAD.L	A3,#R16"TCOLRS	LOAD.L	A2,#(A6)+OCSET	; A2 <-- ^couleur set	TEST.B	(A6)+OMICO	; clic au milieu de l'icne ?	JUMP',T COULX		; oui => COULX	LOAD.L	A3,#R16"TCOLRC	LOAD.L	A2,#(A6)+OCCLR	; A2 <-- ^couleur clearCOULX:	LOAD.L	D4,(A2)	CALL	_DBOXONECOL	; choix d'une couleur ...	JUMP,NE BIP	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.L	(A2),D4	CALL	DESCOLOR	; redessine les couleurs	CALL	DESPDEF		; dessine l'icne du pinceau	CALL	DESTDEF		; dessine l'icne de la trame	JUMP	LOOPTCOLRS:	.ASCIZ	"(Q)"TCOLRC:	.ASCIZ	"(H)"	.EVENMAINNEW:	TEST.W	(A6)+OASVER+OSCHTV	JUMP,NE OUTILNEW	TEST.W	(A6)+OASHOR+OSCHTV	JUMP,NE OUTILNEW	JUMP	BIP		; si aucun ascenseur => BIPLOUPENEW:	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE 40$	LOAD.W	D4,#SCALE11	CALL	_CALSCALE	; remet l'chelle 1:1	CALL	_DESCADRE	CALL	DESLOUPE	; redessine la loupe	JUMP	MATRIX40$:	COMP.B	D3,(A6)+OOUTIL	JUMP,EQ BIP	LOAD.B	(A6)+OLOUTIL,(A6)+OOUTIL	LOAD.B	(A6)+OLOBJET,(A6)+OOBJET;	JUMP'	OUTILNEWOUTILNEW:			; change d'outil =>	COMP.B	D3,(A6)+OOUTIL	JUMP,EQ CLICDEFOUTILNEW2:	PUSH.W	D3	LOAD.B	D3,(A6)+OOUTIL	CALL	_INVICONE	; teint l'ancien outil	POP.W	D3	LOAD.B	(A6)+OOUTIL,D3	CALL	_INVICONE	; allume le nouvel outil	COMP.B	D3,#ICOMAIN	JUMP',EQ 40$	COMP.B	D3,#ICOPLOUPE	JUMP',EQ 40$	COMP.B	D3,#ICOBIDON	JUMP',EQ 40$	COMP.B	D3,#ICOEPONGE	JUMP',EQ 40$	COMP.B	D3,#ICOGOMME	JUMP',EQ 40$	COMP.B	D3,#ICOPIPETTE	JUMP',EQ 40$	COMP.B	D3,#ICOSPRAY	JUMP',NE 50$40$:				; main/loupe/... =>	LOAD.B	D3,(A6)+OOBJET	CALL	_INVICONE	; teint l'ancien objet	CLR.B	(A6)+OOBJET	JUMP	LOOP50$:	LOAD.B	D3,(A6)+OOBJET	; y'a-t-il un objet slectionn ?	JUMP',EQ 60$		; non => 60$	COMP.B	D3,#ICOBLOC1	JUMP',EQ 60$	COMP.B	D3,#ICOBLOC2	JUMP',EQ 60$;;?	COMP.B	D3,#ICOBLOC3;;?	JUMP',EQ 60$	COMP.B	D3,#ICOTEXTE	JUMP,NE LOOP60$:	LOAD.B	D3,#ICOTRAIT	JUMP	OBJETNEW2	; utilise l'objet traitOUTILNIL:			; y'a plus d'outil =>	TEST.B	(A6)+OOUTIL	JUMP,EQ LOOP	LOAD.B	D3,(A6)+OOUTIL	CALL	_INVICONE	; teint l'ancien outil	CLR.B	(A6)+OOUTIL	JUMP	LOOPOBJETNEW:			; change d'objet =>	COMP.B	D3,(A6)+OOBJET	JUMP,EQ CLICDEFOBJETNEW2:	COMP.B	D3,#ICOBLOC1	JUMP',LO 20$	COMP.B	D3,#ICOBLOC2	JUMP',HI 20$				; bloc-notes =>	LOAD.L	A4,#(A6)+OBLOC	CLR.W	D4	LOAD.B	D4,D3	SUB.B	D4,#ICOBLOC1	MUL.WU	D4,#LGBLOC	ADD.L	A4,D4		; A4 <-- ^bloc-notes	TEST.L	(A4)+OBLKPT	; bloc-notes contient qq chose ?	JUMP,EQ BIP		; non => BIP20$:	PUSH.W	D3	LOAD.B	D3,(A6)+OOBJET	CALL	_INVICONE	; teint l'ancien objet	POP.W	D3	LOAD.B	(A6)+OOBJET,D3	CALL	_INVICONE	; allume le nouvel objet	COMP.B	D3,#ICOTEXTE	JUMP,EQ OUTILNIL	COMP.B	D3,#ICOBLOC1	JUMP,EQ OUTILNIL	COMP.B	D3,#ICOBLOC2	JUMP,EQ OUTILNIL;;?	COMP.B	D3,#ICOBLOC3;;?	JUMP,EQ OUTILNIL	LOAD.B	D3,(A6)+OOUTIL	COMP.B	D3,#ICOBIDON	JUMP',EQ 50$	COMP.B	D3,#ICOSPRAY	JUMP',EQ 50$	COMP.B	D3,#ICOMAIN	JUMP',EQ 50$	COMP.B	D3,#ICOPLOUPE	JUMP',EQ 50$	COMP.B	D3,#ICOEPONGE	JUMP',EQ 50$	COMP.B	D3,#ICOGOMME	JUMP',EQ 50$	COMP.B	D3,#ICOPIPETTE	JUMP',EQ 50$	TEST.B	D3	JUMP,NE LOOP50$:	LOAD.B	D3,#ICOCRAYON	JUMP	OUTILNEW2	; utilise l'outil crayonSELECTNEW:	COMP.B	D3,(A6)+OSELECT	JUMP,EQ CLICDEFSELECTNEW2:	PUSH.W	D3	LOAD.B	D3,(A6)+OSELECT	CALL	_INVICONE	; teint l'ancienne slection	POP.W	D3	LOAD.B	(A6)+OSELECT,D3	CALL	_INVICONE	; allume la nouvelle slection	JUMP	LOOPPRESSKEY:			; clic icne => touche presse	AND.W	D3,#H'FF	OR.W	D3,#KEYICO	; D3 <-- code "touche" presse	JUMP	EXECUTEOUTIL:	LOAD.B	D3,(A6)+OOUTIL	; D3 <-- outil	COMP.B	D3,#ICOBIDON	JUMP,EQ BIDON	COMP.B	D3,#ICOSPRAY	JUMP,EQ SPRAY	COMP.B	D3,#ICOMAIN	JUMP,EQ MAIN	COMP.B	D3,#ICOPLOUPE	JUMP,EQ LOUPE	COMP.B	D3,#ICOGOMME	JUMP,EQ GOMME	COMP.B	D3,#ICOEPONGE	JUMP,EQ EPONGE	COMP.B	D3,#ICOPIPETTE	JUMP,EQ PIPETTE	LOAD.B	D3,(A6)+OOBJET	; D3 <-- objet	COMP.B	D3,#ICOTRAIT	JUMP,EQ TRAIT	COMP.B	D3,#ICOSPLINE	JUMP,EQ SPLINE	COMP.B	D3,#ICODROITE	JUMP,EQ COMMEPLAN	COMP.B	D3,#ICOCERCLE	JUMP,EQ COMMEPLAN	COMP.B	D3,#ICORECTANGLE	JUMP,EQ COMMEPLAN	COMP.B	D3,#ICOTEXTE	JUMP,EQ _TEXTE	COMP.B	D3,#ICOBLOC1	JUMP,EQ BLOCNOTES	COMP.B	D3,#ICOBLOC2	JUMP,EQ BLOCNOTES;;?	COMP.B	D3,#ICOBLOC3;;?	JUMP,EQ BLOCNOTES	JUMP	BIP;	***************;	*    TRAIT    *;	***************TRAIT:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	D5,D3		; D5 <-- origine	CLR.W	D0		; D0 <-- souris pas bouge	LOAD.W	D2,#SETDOT	PUSH.L	(A0)+ODFCSF	LOAD.L	(A0)+ODFCSF,(A6)+OCSETLOOP$:	CALL	_SCOMO	CALL	WAITMOVE	; attend dplacement souris ...	JUMP,NE END$		; fin du dplacement => END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE LOOP$	COMP.L	D3,D5		; souris dplace ?	JUMP,EQ LOOP$		; non => LOOP$				; oui =>	LOAD.L	D6,D3		; D6 <-- arrive	CALL	DESCOMMEPLAN	; petit: dessine droite de "origine"  "arrive"	TSET.L	D2:#15	CALL	DESCOMMEPLAN	; dessine directement dans la matrice principqle	TCLR.L	D2:#15	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE NEXT$	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim de la droite	LOAD.L	D1,(A0)+ODFCSF	CALL	SHOGMATRIX	; grand: dessine aussi la droiteNEXT$:	LOAD.L	D5,D6		; D5 <-- future origine	OR.W	D2,#NCTDOT	; D2 <-- plus de rz traitill	INC.W	D0		; D0 <-- souris bouge	JUMP	LOOP$END$:	POP.L	(A0)+ODFCSF	TEST.W	D0		; souris bouge ?	JUMP',EQ NOIRBLANC	; non => NOIRBLANC				; oui =>	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NC LOOP		; non => LOOP	JUMP	MATRIXNOIRBLANC:	LOAD.L	D3,D5		; D3 <-- position	LOAD.L	A1,(A6)+OPMAT	CALL	COULPOINT	; D1 <-- couleur du point	LOAD.L	D2,(A6)+OCCLR	COMP.L	D1,(A6)+OCSET	JUMP',EQ DOT$	LOAD.L	D2,(A6)+OCSETDOT$:	LOAD.L	D1,D2	CALL	MODPOINT	; modifie le point dans la matrice principale	CALL	DESGPOINT	; dessine point dans grande matrice	CALL	DESPPOINT	; dessine point dans petite matrice	JUMP	LOOP;	***************;	*    GOMME    *;	***************GOMME:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	D5,D3		; D5 <-- origine	PUSH.B	(A6)+OOBJET	PUSH.L	(A0)+ODFCCF	LOAD.B	(A6)+OOBJET,#ICOTRAIT	LOAD.L	(A0)+ODFCCF,(A6)+OCCLR	LOAD.L	A4,#R16"TMAT$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#XPEN	CLR.L	(A3)+1	LOAD.L	(A3)+5,A4	LOAD.W	(A3)+9,#2	LOAD.L	(A3)+11,#H'10000*12+12	LOAD.W	D3,#15	LIB	?STRING	LOAD.W	D2,#CLRDOT!PENDOTLOOP$:;;?	PUSH.B	(A6)+OOUTIL;;?	LOAD.B	(A6)+OOUTIL,#ICOGOMME	CALL	_SCOMO		; lutin souris = gomme;;?	POP.B	(A6)+OOUTIL	CALL	WAITMOVE	; attend dplacement souris ...	JUMP,NE END$		; fin du dplacement => END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE LOOP$	COMP.L	D3,D5		; souris dplace ?	JUMP,EQ LOOP$		; non => LOOP$				; oui =>	LOAD.L	D6,D3		; D6 <-- arrive	CALL	DESCOMMEPLAN	; petit: dessine droite de "origine"  "arrive"	TSET.L	D2:#15	CALL	DESCOMMEPLAN	; dessine directement dans la matrice principqle	TCLR.L	D2:#15	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE NEXT$	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim de la droite	LOAD.L	D1,(A0)+ODFCCF	CALL	SHOGMATRIX	; grand: dessine aussi la droiteNEXT$:	LOAD.L	D5,D6		; D5 <-- future origine	JUMP	LOOP$END$:	POP.L	(A0)+ODFCCF	POP.B	(A6)+OOBJET	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NC LOOP		; non => LOOP	JUMP	MATRIXTMAT$:	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000;	***************;	*   PIPETTE   *;	***************PIPETTE:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	LOAD.L	D5,D3	JUMP'	NEXT$LOOP$:	CALL	_SCOMO	CALL	WAITMOVE	; attend dplacement souris ...	JUMP,NE END$		; fin du dplacement => END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE LOOP$	COMP.L	D3,D5		; souris dplace ?	JUMP,EQ LOOP$		; non => LOOP$NEXT$:				; oui =>	LOAD.L	A1,(A6)+OPMAT	CALL	COULPOINT	; D1 <-- couleur du point	LOAD.L	A4,#(A6)+OCSET	; A4 <-- ^couleur set	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BKILL	; touche (KILL) enfonce ?	JUMP',BC COMP$		; non => COMP$	LOAD.L	A4,#(A6)+OCCLR	; A4 <-- ^couleur clearCOMP$:	COMP.L	D1,(A4)		; couleur change ?	JUMP,EQ LOOP$		; non => LOOP$	LOAD.L	(A4),D1	CALL	DESCOLOR	; redessine les couleurs	CALL	DESPDEF		; dessine l'icne du pinceau	CALL	DESTDEF		; dessine l'icne de la trame	JUMP	LOOP$END$:	JUMP	LOOP;	***************;	*    BIDON    *;	***************BIDON:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINT	; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.L	D0,D3		; D0 <-- dpart	LOAD.L	D1,D3		; D1 <-- arrive	TEST.B	(A6)+OBIFAN+2:#BBIDEG-8	JUMP',BC GO$	LOAD.L	D4,D3	CALL	DEGDRAW		; dessine le premierLOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE END$		; non => END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINT	; D3 <-- point o est la souris	JUMP,NE LOOP$	LOAD.L	D2,D3	LOAD.L	D3,D0	LOAD.L	D4,D1	CALL	DEGDRAW		; efface le prcdent	LOAD.L	D1,D2	LOAD.L	D4,D2	CALL	DEGDRAW		; dessine le nouveau	JUMP	LOOP$END$:	LOAD.L	D3,D0	LOAD.L	D4,D1	CALL	DEGDRAW		; efface le dernier	CALL	DEGMEMP		; mmorise les paramtresGO$:	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	A4,(A6)+OPMAT	TEST.B	(A6)+OBIFAN+2:#BBIDEG-8	JUMP',BC OPEN$	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.L	A3,(A6)+OPMAT	LOAD.L	A4,(A6)+OPMAM	CALL	_XFERALL	; matrice masque <-- matrice principaleOPEN$:	CALL	_OPEDISMAT	; dessine dans la matrice principale/masque	LOAD.L	D3,#-1	LOAD.L	D4,D3	TEST.B	(A6)+OBIFAN+2:#BBIFULL-8	JUMP',BS TRAME$	LOAD.L	A4,#(A6)+OTDEF	LOAD.W	D4,(A6)+ONTDEF	MUL.WU	D4,#8	ADD.L	A4,D4		; A4 <-- ^bonne trame	LOAD.L	D3,(A4)+0	LOAD.L	D4,(A4)+4TRAME$:	LIB	?DRMDEF		; dfinit la trame	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.L	(A0)+ODFCSF,(A6)+OCSET	LOAD.L	(A0)+ODFCCF,(A6)+OCCLR	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3)+0,#AFFILLT	TEST.B	(A6)+OBIFAN+3:#BBIFILL-0	JUMP',BC TEST$	LOAD.B	(A3)+0,#AFFILLATEST$:	LOAD.B	(A3)+1,#DRAWFILLO	LOAD.L	D3,D0	SWAP.W	D3	LOAD.L	(A3)+2,D3	; <xx> et <yy>	LOAD.W	D3,#1+5	LIB	?STRING		; rempli ...	JUMP',NE CLOSE$	TEST.B	(A6)+OBIFAN+2:#BBIDEG-8	JUMP',BC CLOSE$	LOAD.L	A3,(A0)+ODFFIP	; A3 <-- ^liste des lignes remplies	LOAD.L	D3,D0	LOAD.L	D4,D0	CALL	DEGFILL		; met un joli dgrad	CLR.W	D7		; D7 <-- okCLOSE$:	PUSH.W	D7	LOAD.B	D3,#DRAWFILLC	LIB	?AFCAR		; libre le remplissage	POP.W	D7	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	PUSH.W	D7	CALL	_CLODISMAT	; redessine dans l'cran	POP.W	D7	JUMP,NE BIGBIP	JUMP	MATRIX;	***************;	*    SPRAY    *;	***************SPRAY:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	PUSH.L	(A0)+ODFCSF	LOAD.L	(A0)+ODFCSF,(A6)+OCSET	LOAD.L	D1,D3	JUMP'	SPRAY$LOOP$:	CALL	_SCMO		; remet la sourisLOOP2$:	CLR.W	D0		; D0 <-- souris immobile	CLR.W	D4	COMP.W	(A6)+OSPVIT,#5	JUMP',HS TIMO$	LOAD.W	D4,(A6)+OSPVIT	; D4 <-- vitesse du spray (0..4)	SUB.W	D4,#5	NEG.W	D4		; D4 <-- 5..1TIMO$:	NTREL	?SETTIM		; met timeout trs court	LIB	?GETKEY		; qq chose tout de suite ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	JUMP',NE SPRAY$	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE END$		; non => END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP2$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE LOOP2$	LOAD.L	D1,D3		; D1 <-- "centre"	INC.W	D0		; D0 <-- souris bougeSPRAY$:	LOAD.W	D2,#1	COMP.W	(A6)+OSPVIT,#5	JUMP',LS SLOOP$	LOAD.W	D2,(A6)+OSPVIT	; D2 <-- vitesse du spray (6..10)	SUB.W	D2,#5-1		; D2 <-- 2..6SLOOP$:	LOAD.L	D3,D1	CALL	HAZSPRAY	; D3/D4 <-- position/dimensions	CALL	DESSPRAY	; dessine selon le spray	DEC.W	D2	JUMP,NE SLOOP$	TEST.W	D0		; souris bouge ?	JUMP,EQ LOOP2$		; non => LOOP2$	JUMP	LOOP$END$:	POP.L	(A0)+ODFCSF;;?	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?;;?	JUMP,NC LOOP		; non => LOOP;;?	CALL	DESMATRIX	; oui => redessine la matrice rduite	JUMP	LOOP;	***************;	*   EPONGE    *;	***************EPONGE:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	PUSH.W	(A6)+ONTDEF	PUSH.L	(A0)+ODFCSF	LOAD.W	(A6)+ONTDEF,#-1	LOAD.L	(A0)+ODFCSF,(A6)+OCSET	LOAD.L	D0,D3	JUMP'	FIRST$LOOP$:	CALL	_SCOMO		; remet la souris	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE END$		; non => END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE LOOP$	COMP.L	D3,D0		; souris bouge ?	JUMP,EQ LOOP$		; non => LOOP$FIRST$:	LOAD.L	D4,D3	LOAD.L	D3,D0	CALL	DESEPONGE	; dessine le motif	LOAD.L	D0,D4	JUMP	LOOP$END$:	POP.L	(A0)+ODFCSF	POP.W	(A6)+ONTDEF	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NC LOOP		; non => LOOP	JUMP	MATRIX;	***************;	*     MAIN    *;	***************MAIN:	TEST.W	(A6)+OASVER+OSCHTV	JUMP',NE 10$	TEST.W	(A6)+OASHOR+OSCHTV	JUMP,EQ BIP10$:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	LOAD.L	D2,D3		; D2 <-- rfrence	LOAD.L	D1,(A6)+OGMOVY	LOAD.L	D0,(A6)+OPMOVY	CALL	_SCOMO		; met la main20$:	CALL	_SCMO		; remet la souris	CALL	WAITMOVE	; attend dplacement souris ...	JUMP,NE 50$		; fin du dplacement => 50$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	PUSH.L	(A6)+OGMOVY	PUSH.L	(A6)+OPMOVY	LOAD.L	(A6)+OGMOVY,D1	LOAD.L	(A6)+OPMOVY,D0	CALL	DETGPOINTOUT	; D3 <-- point o est la souris	POP.L	(A6)+OPMOVY	POP.L	(A6)+OGMOVY	TEST.W	D7	JUMP,NE 20$	LOAD.W	D5,(A6)+OASVER+OSCHTV	JUMP',EQ 25$	DEC.W	D525$:	SWAP.W	D5	LOAD.W	D5,(A6)+OASHOR+OSCHTV	JUMP',EQ 26$	DEC.W	D526$:	LOAD.L	D4,D1	ADD.W	D4,D2	SUB.W	D4,D3	JUMP',NC 30$	CLR.W	D430$:	COMP.W	D4,D5	JUMP',LS 31$	LOAD.W	D4,D531$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	ADD.W	D4,D2	SUB.W	D4,D3	JUMP',NC 32$	CLR.W	D432$:	COMP.W	D4,D5	JUMP',LS 33$	LOAD.W	D4,D533$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	COMP.L	D4,(A6)+OGMOVY	JUMP,EQ 20$	LOAD.L	(A6)+OGMOVY,D4	LOAD.L	D4,D0	ADD.W	D4,D2	SUB.W	D4,D3	JUMP',NC 34$	CLR.W	D434$:	COMP.W	D4,D5	JUMP',LS 35$	LOAD.W	D4,D535$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	ADD.W	D4,D2	SUB.W	D4,D3	JUMP',NC 36$	CLR.W	D436$:	COMP.W	D4,D5	JUMP',LS 37$	LOAD.W	D4,D537$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	LOAD.L	(A6)+OPMOVY,D4	CALL	DESPMATRIX	; dessine la petite matrice	CALL	DESGMATRIX	; dessine la grande matrice	JUMP	20$50$:	CALL	MAJCADRE	; met  jour ascenseurs et rgles	JUMP	LOOP;	***************;	*    LOUPE    *;	***************LOUPE:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	LOAD.L	(A6)+OPMOVY,D3	CLR.L	(A6)+OPMDIY	LOAD.B	D3,#ICOPLOUPE	CALL	_INVICONE	; teint la loupe	LOAD.B	(A6)+OOUTIL,(A6)+OLOUTIL	LOAD.B	(A6)+OOBJET,(A6)+OLOBJET	LOAD.B	D3,(A6)+OOUTIL	CALL	_INVICONE	; allume le nouvel outil	LOAD.B	D3,(A6)+OOBJET	CALL	_INVICONE	; allume le nouvel objet	CLR.B	(A6)+OLOUTIL	CLR.B	(A6)+OLOBJET	LOAD.W	D4,#SCALELOUPE	CALL	_CALSCALE	CALL	_DESCADRE	CALL	DESLOUPE	; dessine les jumelles	JUMP	MATRIX;	***************;	*  COMMEPLAN  *;	***************COMMEPLAN:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINT	; D3 <-- point o est la souris	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	D5,D3		; D5 <-- origine fixe	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.L	(A0)+ODFCSF,(A6)+OCSET	LOAD.L	(A0)+ODFCCF,(A6)+OCCLR	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE NEXT$	COMP.B	(A6)+OOBJET,#ICODROITE	JUMP',NE NEXT$	CALL	_CCMO		; enlve la souris	JUMP'	NEXT$LOOP$:	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE SCMO$	COMP.B	(A6)+OOBJET,#ICODROITE	JUMP',EQ AFLH$SCMO$:	CALL	_SCOMO		; remet la sourisAFLH$:	CALL	DESINFCP	; affiche L= et H=LOOP2$:	CALL	WAITMOVES	; attend dplacement souris ...	JUMP,NE END$		; fin du dplacement => END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP2$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINTOUT	; D3 <-- point o est la souris	CALL	PASGPOINT	; D3 <-- tient compte du pas	COMP.L	D3,D6		; souris dplace ?	JUMP,EQ LOOP2$		; non => LOOP2$				; oui =>	PUSH.L	D3	LOAD.L	D3,D1		; D3 <-- ancienne pos	LOAD.L	D4,D2		; D4 <-- ancienne dim	LOAD.W	D2,#CLRDOT	; D2 <-- mode de dessin	CALL	MOVGMATRIX	; grand: efface dernier droite/cercle/etc.	LOAD.W	D2,#INVDOT	CALL	DESCOMMEPLAN	; petit: efface dernier droite/cercle/etc.	POP.L	D3NEXT$:	CALL	SCROLLPOIGNEE	; dplace v. la partie visible	LOAD.L	D6,D3		; D6 <-- nouvelle arrive	LOAD.W	D2,#INVDOT	CALL	DESCOMMEPLAN	; petit: dessine nouveau droite/cercle/etc.	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim objet	LOAD.W	D2,#SETDOT	CALL	MOVGMATRIX	; grand: dessine nouveau droite/cercle/etc.	LOAD.L	D1,D3		; D1 <-- pos	LOAD.L	D2,D4		; D2 <-- dim	JUMP	LOOP$END$:	COMP.L	D5,D6		; souris bouge ?	JUMP,EQ NB$		; non => NB$				; oui =>	LOAD.L	D3,D1		; D3 <-- ancienne pos	LOAD.L	D4,D2		; D4 <-- ancienne dim	LOAD.W	D2,#CLRDOT	; D2 <-- mode de dessin	CALL	MOVGMATRIX	; grand: efface dernier droite/cercle/etc.	LOAD.W	D2,#INVDOT	CALL	DESCOMMEPLAN	; petit: efface dernier droite/cercle/etc.	LOAD.W	D2,#SETDOT!2^15	; D2 <-- dessine dans la matrice principale	CALL	DESCOMMEPLAN	; petit: dessine droite/cercle dfinitif	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim objet	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D1,D3	LOAD.L	D2,D4	LOAD.L	D5,D3	LOAD.L	D6,D4	LOAD.L	A4,(A6)+OPMAT	LOAD.W	D0,#LOADDOT	CALL	BBPGMATRIX	; affiche  l'cran (v. dans les deux fentres)	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	CALL	MAJREGLE	; met  jour les rgles	JUMP	LOOPNB$:	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	JUMP	NOIRBLANC;	***************;	*  BLOCNOTES  *;	***************BLOCNOTES:	LOAD.L	A5,#(A6)+OBLOC	CLR.W	D3	LOAD.B	D3,(A6)+OOBJET	SUB.B	D3,#ICOBLOC1	MUL.WU	D3,#LGBLOC	ADD.L	A5,D3		; A5 <-- ^bloc-notes	TEST.L	(A5)+OBLKPT	; bloc-notes contient qq chose ?	JUMP,EQ BIP		; non => BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	D1,(A5)+OBLKP1	; D1 <-- P1(y;x)	LOAD.L	D2,(A5)+OBLKP2	; D2 <-- P2(y;x)	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	COMP.W	D2,(A6)+OMALMX	JUMP,HS BIP	SWAP.W	D2	COMP.W	D2,(A6)+OMALMY	JUMP,HS BIP	SWAP.W	D2	LOAD.W	(A6)+OMANBS,(A5)+OBLKNBB	LOAD.W	(A6)+OMANBD,(A6)+OMANBB	LOAD.L	A3,(A5)+OBLKPT	; A3 <-- ^matrice source	LOAD.L	D3,D1	LOAD.L	A4,(A6)+OPMAM	; A4 <-- ^matrice destination	CLR.L	D4	LOAD.L	D5,D2		; D5 <-- dimensions	CALL	_CLEARALL	; matrice masque <-- vide	LOAD.W	D2,#SETDOT	CALL	_XFERZONESD	; matrice masque <-- contenu du bloc-notes	LOAD.L	D6,D5	CLR.L	D5	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	CALL	DETGPOINT	JUMP,NE BIP	LOAD.L	D1,D3	LOAD.L	D2,D3	ADD.W	D1,D6	LOAD.W	D3,D1	SUB.W	D3,(A6)+OMALMX	JUMP',LO 60$	SUB.W	D1,D3	SUB.W	D2,D360$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D6	ADD.W	D1,D6	LOAD.W	D3,D1	SUB.W	D3,(A6)+OMALMY	JUMP',LO 62$	SUB.W	D1,D3	SUB.W	D2,D362$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D6	CLR.L	D0	LOAD.B	(A6)+ODDOP,(A6)+OOBJET	JUMP	ZONEMOVEMODIFDEF:	CALL	_DBOXDEF	; choix des dfinitions ...	JUMP,NE ERROR	JUMP	LOOPMODIFZOOM:	CALL	_DBOXZOOM	; choix du zoom ...	JUMP,NE ERROR	JUMP	LOOPMODIFBIDON:	CALL	_DBOXBIDON	; choix du bidon ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.B	D3,#ICOBIDON	JUMP	OUTILNEW2	; utilise le pinceauMODIFSPRAY:	CALL	_DBOXSPRAY	; choix du vaporisateur ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.B	D3,#ICOSPRAY	JUMP	OUTILNEW2	; utilise le pinceauMODIFEPONGE:	CALL	_DBOXEPONGE	; choix de l'ponge ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.B	D3,#ICOEPONGE	JUMP	OUTILNEW2	; utilise le pinceauMODIFPDEF:	CALL	_DBOXPDEF	; choix du pinceau ...	JUMP,NE ERROR	CALL	DESPDEF		; dessine l'icne du pinceau	LOAD.B	D3,#ICOPINCEAU	JUMP	OUTILNEW2	; utilise le pinceauMODIFTDEF:	CALL	_DBOXTDEF	; choix de la trame ...	JUMP,NE ERROR	CALL	DESTDEF		; dessine l'icne de la trame	JUMP	LOOPMODIFRDEF:	CALL	_DBOXRDEF	; choix du rectangle ...	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICORECTANGLE	JUMP	OBJETNEW2	; objet rectangleMODIFADEF:	CALL	_DBOXADEF	; choix du clercle ...	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICOCERCLE	JUMP	OBJETNEW2	; objet cercleMODIFFLAGS:	LOAD.W	D4,D3	CALL	_DBOXFLAGS	; change le mode ...	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.W	D3,D4	JUMP	SELECTNEW2REGLE:	CALL	_CCMO		; enlve la souris	NOT.B	(A6)+OREGLE	; met/enlve les rgles	CALL	_CALCADRE	LOAD.W	D4,(A6)+OSCALE	CALL	_CALSCALE	CALL	_DESCADRE	JUMP	MATRIXCOLOR:	CALL	_DBOXCOLOR	; choix des couleurs ...	JUMP,NE BIP	JUMP	LOOPCONVNB:	CALL	DBOXCONVNB	; choix des conversions ...	JUMP,NE BIP	JUMP	LOOPFILTRE:	CALL	DBOXFILTRE	; choix du filtre ...	JUMP,NE BIP	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	_COPYALL	; fait une copie de la matrice	CLR.L	D3	LOAD.L	D4,(A6)+OMALMY	LOAD.L	A3,#(A6)+OFDBTAB ; A3 <-- ^table du filtre	CALL	FILOPER		; transforme ...	JUMP	MATRIXNEGATIF:	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	A4,(A6)+OPMAT	CALL	_INVALL		; inverse toute la matrice	JUMP	MATRIXEFFACE:	CALL	_DBOXEFFACE	; Voulez-vous effacer ?	COMP.W	D3,#F1	JUMP,NE LOOPEFFACEI:	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	A4,(A6)+OPMAT	CALL	_CLEARALL	; efface toute la matrice	LOAD.L	A3,#(A6)+OBUFIN	CLR.B	(A3)	CALL	_SAVFILE	; OBUNAME <-- plus de nom	CALL	DESINFFILE	; le dessin n'a plus de nom !	CLR.B	(A6)+OMAJ	; le dessin est  jour	LOAD.L	A3,(A6)+OPMAT	LOAD.L	A4,#(A6)+OBLOC	LOAD.W	D4,#NBBLOC-140$:	COMP.L	A3,(A4)+OBLKPT	; bloc-notes dans cette zone ?	JUMP',NE 45$		; non => 45$	CLR.L	(A4)+OBLKPT	; vide ce bloc-notes !45$:	LOAD.L	A4,#(A4)+LGBLOC	; A4 <-- ^bloc-notes suivant	DECJ.W,NMO D4,40$	JUMP	MATRIXMENUSCALE:	LOAD.L	A3,#R16"MMENU$	CLR.L	D4	LOAD.W	D2,(A6)+OSCALE	LOAD.W	D3,#5	COMP.W	D2,#16	JUMP',EQ GREY$	DEC.W	D3	COMP.W	D2,#10	JUMP',EQ GREY$	DEC.W	D3	COMP.W	D2,#8	JUMP',EQ GREY$	DEC.W	D3	COMP.W	D2,#5	JUMP',EQ GREY$	DEC.W	D3GREY$:	TSET.L	D4:D3		; D4 <-- grise l'chelle actuelle	LOAD.W	D3,#2^15	; D3 <-- utilise D4.L en entre	LOAD.L	A4,#0		; A4 <-- pas de dernire case	CALL	_MMENU		; attend selon mmenu ...	JUMP,NE BIP	DEC.W	D3		; D3 <-- 0..9	JUMP,NS LOOP	LOAD.W	D4,#1	DEC.W	D3	JUMP',NS SCALE$	LOAD.W	D4,#5	DEC.W	D3	JUMP',NS SCALE$	LOAD.W	D4,#8	DEC.W	D3	JUMP',NS SCALE$	LOAD.W	D4,#10	DEC.W	D3	JUMP',NS SCALE$	LOAD.W	D4,#16SCALE$:	CALL	_CALSCALE	CALL	_DESCADRE	; redessine le cadre	JUMP	MATRIXMMENU$:	.ASCIZ	" "	.B	-1	.ASCIZ	"  1:1  "	.ASCIZ	"  5:1  "	.ASCIZ	"  8:1  "	.ASCIZ	" 10:1  "	.ASCIZ	" 16:1  "	.B	0	.EVENMENUPAS:	LOAD.L	A3,#R16"MMENU$	CLR.L	D4	LOAD.W	D2,(A6)+OPAS	LOAD.W	D3,#6	COMP.W	D2,#32	JUMP',EQ GREY$	DEC.W	D3	COMP.W	D2,#16	JUMP',EQ GREY$	DEC.W	D3	COMP.W	D2,#8	JUMP',EQ GREY$	DEC.W	D3	COMP.W	D2,#4	JUMP',EQ GREY$	DEC.W	D3	COMP.W	D2,#2	JUMP',EQ GREY$	DEC.W	D3GREY$:	TSET.L	D4:D3		; D4 <-- grise l'chelle actuelle	LOAD.W	D3,#2^15	; D3 <-- utilise D4.L en entre	LOAD.L	A4,#0		; A4 <-- pas de dernire case	CALL	_MMENU		; attend selon mmenu ...	JUMP,NE BIP	DEC.W	D3		; D3 <-- 0..n	JUMP,NS LOOP	LOAD.W	D4,#1	DEC.W	D3	JUMP',NS PAS$	LOAD.W	D4,#2	DEC.W	D3	JUMP',NS PAS$	LOAD.W	D4,#4	DEC.W	D3	JUMP',NS PAS$	LOAD.W	D4,#8	DEC.W	D3	JUMP',NS PAS$	LOAD.W	D4,#16	DEC.W	D3	JUMP',NS PAS$	LOAD.W	D4,#32PAS$:	LOAD.W	(A6)+OPAS,D4	CALL	DESINFPA	; affiche le pas	JUMP	LOOPMMENU$:	.ASCIZ	" "	.B	-1	.ASCIZ	"  p=1   "	.ASCIZ	"  p=2   "	.ASCIZ	"  p=4   "	.ASCIZ	"  p=8   "	.ASCIZ	"  p=16  "	.ASCIZ	"  p=32  "	.B	0	.EVENSCALE:	CALL	DOSCALE		; change d'chelle	JUMP,NE BIP	JUMP	LOOPMENUZONE:	CALL	_CMZONE		; A3 <-- ^mmenu	CLR.L	D4	LOAD.W	D3,(A6)+ONOZO	INC.W	D3	TSET.L	D4:D3		; D4 <-- zone visible en gris	LOAD.W	D3,#2^15	; D3 <-- utilise D4.L en entre	LOAD.L	A4,#0		; A4 <-- pas de dernire case	CALL	_MMENU		; attend selon mmenu ...	JUMP,NE BIP	DEC.W	D3		; D3 <-- 0..9	JUMP,NS LOOP	JUMP'	XZONESHOWZONE:	AND.W	D3,#H'00FF	SUB.B	D3,#'0		; D3 <-- 0..9	DEC.B	D3	JUMP',NC 20$	LOAD.B	D3,#NBZONE-120$:	COMP.W	D3,(A6)+ONOZO	; est-ce une autre zone ?	JUMP,EQ BIP		; non => BIPXZONE:	LOAD.W	D4,(A6)+OSCALE	CALL	_NEWZONE	; utilise une nouvelle zone	JUMP,NE ERROR	LOAD.W	D3,D4		; D3 <-- ancienne chelle	LOAD.W	D4,(A6)+OSCALE	; D4 <-- nouvelle chelle	LOAD.W	(A6)+OSCALE,D3	CALL	ICOSCALE	; allume/teint qq icnes	LOAD.W	(A6)+OSCALE,D4	CALL	_CALSCALE	TEST.B	(A6)+ODRAW	; faut-il tout redessiner ?	JUMP,T	LOOP		; oui => LOOP	CALL	DESINFZONE	; affiche la zone	CALL	DESINFFILE	; affiche le nom du dessin	CALL	_DESCADRE	; redessine le cadre	JUMP	MATRIXDOHELP:	CLR.W	D3	CALL	_SELMO		; utilise la flche	LOAD.B	(A6)+OXICO,#NIVHELP	CALL	_AFMENU		; refait les soft-keys	CLR.W	D210$:	LOAD.L	A3,#R16"THELP1	TEST.W	D2	JUMP',EQ 20$	LOAD.L	A3,#R16"THELP220$:	CALL	_WAITMOUSE	; met le sablier	CALL	_AFIMAGE	; affiche l'image d'aide	JUMP,NE 80$	CALL	_NORMMOUSE	; enlve le sablier30$:	LIB	?GETCAR		; attend une touche ...	COMP.W	D3,#F0+SHIFT	JUMP',LO 35$	COMP.W	D3,#F15+SHIFT	JUMP',HI 35$	SUB.W	D3,#SHIFT35$:	COMP.W	D3,#KEYMGR	JUMP,EQ 30$	COMP.W	D3,#KEYMMR	JUMP,EQ 30$	COMP.W	D3,#KEYMDR	JUMP,EQ 30$	CLR.W	D7		; D7 <-- ok	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#END	JUMP,EQ 80$	COMP.W	D3,#F1	JUMP',EQ 50$	COMP.W	D3,#F2	JUMP',EQ 50$	COMP.W	D3,#F3	JUMP',EQ 50$	COMP.W	D3,#SPACE	JUMP',EQ 50$	COMP.W	D3,#CR	JUMP',EQ 50$	COMP.W	D3,#HELP	JUMP',EQ 50$	COMP.W	D3,#KEYMGP	JUMP',EQ 50$	COMP.W	D3,#KEYMMP	JUMP',EQ 50$	COMP.W	D3,#KEYMDP	JUMP',EQ 50$	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	30$50$:	INC.W	D2		; D2 <-- image suivante	COMP.W	D2,#2	JUMP,LO 10$	CLR.W	D2	JUMP	10$80$:	PUSH.W	D7	CLR.B	(A6)+OXICO	CALL	_DESWDO	CALL	_DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CALL	_AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE ERROR	JUMP	LOOPEXUNDO:	CALL	_UNDOALL	; rcupre tout !	JUMP	MATRIXBIP:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPBIGBIP:				; erreur =>	LOAD.B	D3,#BIPERR	LIB	?BEEP		; grand bruit	JUMP	LOOPERROR:	PUSH.W	D7	CLR.B	D3	CALL	_SELMO		; outil = flche	CALL	_SCMO		; remet la flche	CALL	_NORMMOUSE	; remet la flche	POP.W	D7	TEST.W	D7	JUMP,EQ LOOP	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	_AFMENU		; refait les soft-keys	JUMP	LOOPFINI:	LOAD.W	D3,(A6)+ONOZO	; D3 <-- zone actuelle	CALL	_CLOZONE	; sauve la zone actuelle	LOAD.W	D4,D3		; D4 <-- zone actuelle	CLR.W	D3		; D3 <-- premire zone  sauver20$:	CALL	_OPEZONE	; prend une zone	LOAD.W	(A6)+ONOZO,D3	CLR.W	D0		; D0 <-- avant de quitter	CALL	_DBOXSAVE	; sauve si ncessaire avant de quitter	JUMP',EQ 50$		; ok => 50$	COMP.W	D7,#1		; (ANNULE) ?	JUMP',EQ 80$		; oui => 80$				; erreur =>	PUSH.W	D7	LOAD.W	D3,D4	CALL	_OPEZONE	; reprend la zone initiale	LOAD.W	(A6)+ONOZO,D3	POP.W	D7	JUMP	ERROR50$:	INC.W	D3		; D3 <-- numro zone suivante	COMP.W	D3,#NBZONE	JUMP,LO 20$	CALL	_DBOXQUITTE	; demande s'il faut quitter ...	COMP.W	D3,#F1	JUMP',EQ ERFAT80$:	LOAD.W	D3,D4	CALL	_OPEZONE	; reprend la zone initiale	LOAD.W	(A6)+ONOZO,D3	JUMP	LOOPERFAT:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDGENC	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDESSIN	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDESS2	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHCOUPE	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSPLINE	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSTRETCH	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHICOLOR	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHBLOC	JUMP',EQ 40$	BLOC_	CLOSE		; fermeture globale	JUMP',NE 40$	LIB_	CLOSE40$:	TEST.L	(A6)+OCAPRINT	JUMP',EQ 50$	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	CLOSE	LOAD.W	D1,(A6)+OCHPRINTA	LIB_	CLOSE50$:	TEST.L	(A6)+OCASCAN	JUMP',EQ 60$	LOAD.L	D6,(A6)+OCASCAN	SCAN_	CLOSE	LOAD.W	D1,(A6)+OCHSCAN	LIB_	CLOSE60$:ERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LOAD.W	D3,#BIPFAT	LIB	?BEEP		; vilain bruit	LIB	?AFTIM	.B	NOCURS,EOP,CR,CR,CR,CR,CR,CR,CR,CR	.ASCIZ	"<TAB>ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFTIM	.B	CR,TAB,0	.EVEN	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?AFTIM	.B	CR,CR	.ASCIZ	"<TAB>Appuyez sur une touche ..."	.EVEN	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	PICDROITE.ASI	.INS	PICFILTRE.ASI	.INS	PICSELECT.ASI	.INS	PICMATH.ASI	.INS	PICGRA.ASI	.INS	PICSPLINE.ASI	.INS	PICIND1.ASI	.INS	PICOPER.ASI	.INS	PICMATRIX.ASI	.INS	PICCADRE.ASI	.INS	PICICONE.ASI	.INS	PICIO.ASI	.INS	PICZONE.ASI	.INS	PICIND2.ASI	.INS	PICDBOX.ASI	.INS	PICDBOXT.ASI	.INS	PICGENC.ASI	.INS	PICAFTEXT.ASI	.INS	PICMISC.ASI	.INS	PICTAB2.ASI	.END	START