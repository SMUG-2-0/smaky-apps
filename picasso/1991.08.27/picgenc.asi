	.SBTTL	PICGENC.ASITEXTE:	TEST.B	D3	JUMP,EQ REFAIT$	COMP.B	D3,#1	JUMP',EQ DOCOLLE$	CALL	IFMOUSE	JUMP,NE __BIP	CALL	CLRPAVE		; efface tous les pavs	CALL	EDIFPAVE	; souris dans un pav de texte ?	JUMP,EQ __BIP		; oui => __BIP	CALL	COPYALL		; fait une copie de la matrice	CALL	OPETEXTE	; ouvre un pav de texte	LOAD.B	(A6)+OXICO,#NIVTEXTE ; dbut de l'dition	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	FULLGREYICONE	; (d)grise qq icnes	CALL	AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TTHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	CLR.W	D3	CALL	SELMO		; utilise la flche	JUMP	PAVE1$DOCOLLE$:	CALL	WAITMOUSE	; met le sablier	CLR.L	D1	CALL	__D1SCALEP	; D1 <-- plus petit si "tout"	LOAD.L	D4,D1	ADD.W	D4,(A6)+OGMPOX	ADD.W	D4,#10	SWAP.W	D4	ADD.W	D4,(A6)+OGMPOY	ADD.W	D4,#16	SWAP.W	D4	CALL	CVPTEXTE	; D4 <-- position dans la matrice	LOAD.L	(A6)+OPOTEXT,D4	CALL	CLRPAVE		; efface tous les pavs	CALL	COPYALL		; fait une copie de la matrice	CALL	OPETEXTE	; ouvre un pav de texte	CLR.W	D3	CALL	CLOPAVE		; initialise le pav	CALL	OPEPAVE		; utilise le pav	CLR.W	D2		; D2 <-- les 3 poignes	CALL	IRETEXTE	; dessine le premier rectangle	LOAD.B	(A6)+OXICO,#NIVTEXTE ; dbut de l'dition	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	FULLGREYICONE	; (d)grise qq icnes	CALL	AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TTHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	CLR.W	D3	CALL	SELMO		; utilise la flche	CALL	EDCOLLE		; colle le texte	CALL	DESTEXTE	; dessine tous les pavs de texte	JUMP	LOOP1$REFAIT$:	CALL	MAXPAVE	TEST.W	D3		; existe-t-il au moins un pav ?	JUMP,EQ __BIP		; non => __BIP	TEST.B	(A6)+ODATEXT	; termin avec "d'accord" ?	JUMP,T	__BIP		; oui => __BIP	CLR.W	D3REFAIT2$:	CALL	OPEPAVE		; utilise le pav	JUMP',NE REFAIT3$	LOAD.W	D4,(A6)+OPOTEXT+2	ADD.W	D4,(A6)+OLGTEXT	COMP.W	D4,(A6)+OMALMX	; dpasse la matrice  droite ?	JUMP,HS __BIP	LOAD.W	D4,(A6)+OPOTEXT+0	ADD.W	D4,(A6)+OHTTEXT	COMP.W	D4,(A6)+OMALMY	; dpasse la matrice en bas ?	JUMP,HS __BIP	INC.W	D3		; D3 <-- pav suivant	JUMP	REFAIT2$REFAIT3$:	CALL	COPYALL		; fait une copie de la matrice	LOAD.B	(A6)+OXICO,#NIVTEXTE ; dbut de l'dition	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TTHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	CLR.W	D3	CALL	SELMO		; utilise la flche	CALL	JRETEXTE	; remet les rectangles englobantsLOOP$:	LIB	?IFCAR		; D3 <-- touche presse rapidement ?	JUMP',EQ LOOP2$		; oui => LOOP2$	CALL	DESTEXTE	; dessine tous les pavs de texteLOOP1$:	CALL	FULLGREYICONE	; (d)grise qq icnes	CALL	SCMO		; remet la souris	CALL	NORMMOUSE	; enlve le sablierCLIGN1$:	CALL	ICUTEXTE	; dessine le curseur	LOAD.W	D4,#20	NTREL	?SETTIM	CALL	__WAITPRESS	; attend clavier/souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP',EQ CLIGN9$	CALL	ICUTEXTE	; efface le curseur	LOAD.W	D4,#12	NTREL	?SETTIM	CALL	__WAITPRESS	; attend clavier/souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP',EQ LOOP2$	JUMP	CLIGN1$CLIGN9$:	CALL	ICUTEXTE	; efface le curseurLOOP2$:	COMP.W	D3,#F0+SHIFT	JUMP',LO LOOP3$	COMP.W	D3,#F15+SHIFT	JUMP',HI LOOP3$	SUB.W	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)LOOP3$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP1$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP1$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP1$	LOAD.L	A1,#R16"JRETEXTE ; A1 <-- ^routine d'inversion	CALL	DOKASCENSEUR	; agit dans ascenseurs selon touche	JUMP,EQ LOOP1$	TEST.B	(A6)+OACTEXT	JUMP,T	DESOUS$LOOP5$:	COMP.W	D3,#H'100*(2^BKILL)+SPACE	JUMP,EQ COUPE$	COMP.W	D3,#H'100*(2^BCOPY)+SPACE	JUMP,EQ COPIE$	COMP.W	D3,#H'100*(2^BCURSOR)+SPACE	JUMP,EQ COLLE$	LOAD.W	D2,D3	SR.W	D2,#8	COMP.B	D2,#2^BCURSOR	JUMP,EQ CURSOR$	COMP.B	D2,#2^BCURSOR!2^BKILL	JUMP,EQ KILL$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ MENU$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ EXIT$	COMP.W	D3,#END	JUMP,EQ EXIT$	COMP.W	D3,#ENTER	JUMP,EQ EXIT$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ CLEAR$	COMP.W	D3,#DELETE	JUMP,EQ DEL$	COMP.W	D3,#DEL	JUMP,EQ DEL$	COMP.W	D3,#BS	JUMP,EQ BS$	COMP.W	D3,#HELP	JUMP,EQ HELP$	COMP.W	D3,#F1	JUMP,EQ PREND$	COMP.W	D3,#H'100*(2^BSHOW)+DEFINE	JUMP,EQ PREND$	LOAD.B	D4,#'1	COMP.W	D3,#F8	JUMP,EQ SCALE$	LOAD.B	D4,#'-	COMP.W	D3,#F7	JUMP,EQ SCALE$	LOAD.B	D4,#'+	COMP.W	D3,#F9	JUMP,EQ SCALE$	LOAD.B	D4,#'T	COMP.W	D3,#F13	JUMP,EQ SCALE$	COMP.W	D3,#CR	JUMP,EQ INSERT$	COMP.W	D3,#EOP	JUMP,EQ INSERT$	COMP.W	D3,#2		; cadratin ?	JUMP,EQ INSERT$	COMP.W	D3,#TRIZERO	JUMP,EQ TRIZERO$	LOAD.W	D2,#'^	COMP.W	D3,#KCIRCON	JUMP,EQ ACCENT$	LOAD.W	D2,#'"	COMP.W	D3,#KTREMA	JUMP,EQ ACCENT$	LOAD.B	D2,#'.	COMP.W	D3,#POINT	JUMP',EQ INSERT2$	COMP.W	D3,#'	JUMP',LO BIP$	COMP.W	D3,#H'7F	JUMP',HS BIP$	JUMP'	INSERT$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP1$BIPDES$:			; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$ERROR$:	PUSH.W	D7	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	POP.W	D7	JUMP,EQ LOOP$	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP$	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	AFMENU		; refait les soft-keys	JUMP	LOOP$INSERT2$:			; frappe un caractre =>	LOAD.B	D3,D2INSERT$:	CALL	EDINSCAR	JUMP,NE BIP$	JUMP	LOOP$TRIZERO$:			; (000) =>	LOAD.B	D3,#'0	CALL	EDINSCAR	JUMP,NE BIP$	CALL	EDINSCAR	JUMP,NE BIPDES$	CALL	EDINSCAR	JUMP,NE BIPDES$	JUMP	LOOP$CLEAR$:				; (CLEAR) =>	LOAD.L	A3,(A6)+OPTTEXT	CLR.B	(A3)	CLR.W	(A6)+ONBTEXT	CLR.W	(A6)+OCUTEXT	CLR.B	(A6)+OACTEXT	JUMP	LOOP$DEL$:				; (DEL) =>	TEST.W	(A6)+OCUTEXT	JUMP,EQ BIP$	DEC.W	(A6)+OCUTEXT	CALL	EDKILCAR	JUMP	LOOP$BS$:				; (BS) =>	LOAD.W	D3,(A6)+OCUTEXT	COMP.W	D3,(A6)+ONBTEXT	JUMP,HS BIP$	CALL	EDKILCAR	JUMP	LOOP$CURSOR$:			; (CURSOR) =>	CALL	EDCURSOR	JUMP,NE BIP$	SET.B	(A6)+OQCTEXT	CALL	DESTEXTE	; positionne juste le curseur	CLR.B	(A6)+OQCTEXT	JUMP	LOOP1$KILL$:				; (CURSOR-KILL) =>	CALL	EDKILL	JUMP,NE BIP$	JUMP	LOOP$DESOUS$:			; sous l'accent flottant =>	CLR.B	(A6)+OACTEXT	COMP.W	D3,#H'7F	JUMP,HS LOOP5$	LOAD.L	A4,(A6)+OPTTEXT	LOAD.W	D4,(A6)+OCUTEXT	LOAD.B	D4,(A4)+(D4.W)-1 ; D4 <-- accent	CALL	GETACCENT	; D3 <-- cherche lettre accentue	JUMP,NE LOOP5$	LOAD.W	D4,(A6)+OCUTEXT	LOAD.B	(A4)+(D4.W)-1,D3	JUMP	LOOP$ACCENT$:			; accent flottant frapp =>	LOAD.B	D3,D2	CALL	EDINSCAR	JUMP,NE BIP$	SET.B	(A6)+OACTEXT	JUMP	LOOP$SCALE$:	CALL	JRETEXTE	; enlve les rectangles englobants	CALL	DOSCALE		; change d'chelle	PUSH.W	D7	CALL	JRETEXTE	; remet les rectangles englobants	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP1$MENU$:	CALL	MENUICONE	; menu des icnes de gauche ...	JUMP,NE BIP$	TEST.B	D3	JUMP,EQ LOOP1$	JUMP	ICONE$CLIC$:	LOAD.W	D2,D3		; D2 <-- bouton press	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	CLR.W	D3		; D3 <-- premier pavCLICP1$:	CALL	OPEPAVE		; utilise le bon pav	JUMP',NE CLICP5$	CALL	MVPTEXTE	; dplace le pav de texte ...	JUMP',EQ CLICP2$	INC.W	D3		; D3 <-- pav suivant	JUMP	CLICP1$CLICP2$:	CALL	CLOPAVE		; met  jour le pav modifi	JUMP	LOOP$CLICP5$:	CALL	EDDETECT	; dplace le curseur ?	JUMP',NE CLICIC$	JUMP	LOOP1$CLICIC$:	CALL	MOVICONE	; souris dans une icne ?	JUMP,NE CLICAS$		; non => CLICAS$ICONE$:	COMP.B	D3,#ICOJUSTA	JUMP',LO ICONE1$	COMP.B	D3,#ICOJUSTC	JUMP,LS JUSTNEW$ICONE1$:	COMP.B	D3,#ICOCSPACE	JUMP,EQ CSPACE$	COMP.B	D3,#ICODIVISE	JUMP,EQ DIVISE$	COMP.B	D3,#ICOCCOUPE	JUMP,EQ CCOUPE$	COMP.B	D3,#ICOCONTOUR	JUMP,EQ CONTOUR$	COMP.B	D3,#ICOESPCONTX	JUMP,EQ ESPCX$	COMP.B	D3,#ICOESPCONTY	JUMP,EQ ESPCY$	COMP.B	D3,#ICOGGDEF	JUMP,EQ CAR$	COMP.B	D3,#ICOPMGENC	JUMP,EQ PMGENC$	COMP.B	D3,#ICOTPREND	JUMP,EQ PREND$	COMP.B	D3,#ICOCOLLE	JUMP,EQ COLLE$	COMP.B	D3,#ICOITLM	JUMP,EQ ITLM$	COMP.B	D3,#ICOITLX	JUMP,EQ ITLX$	COMP.B	D3,#ICOITLP	JUMP,EQ ITLP$	COMP.B	D3,#ICOITCM	JUMP,EQ ITCM$	COMP.B	D3,#ICOITCX	JUMP,EQ ITCX$	COMP.B	D3,#ICOITCP	JUMP,EQ ITCP$	COMP.B	D3,#ICOHORIZ	JUMP,EQ BLOQUE$	COMP.B	D3,#ICOVERTI	JUMP,EQ BLOQUE$	COMP.B	D3,#ICODACCORD	JUMP,EQ EXIT$	COMP.B	D3,#ICOANNULE	JUMP,EQ UNDO$	JUMP	BIP$CLICAS$:	LOAD.L	A1,#R16"JRETEXTE ; A1 <-- ^routine d'inversion	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP1$PAVE1$:	CALL	EDIFPAVE	; souris dans un pav de texte ?	JUMP,EQ BIP$		; oui => BIP$	CALL	MAXPAVE		; D3 <-- numro du dernier pav	JUMP,NE BIP$	LOAD.W	D1,D3	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	SUB.W	D4,#DPOIGNEE-2	SWAP.W	D4	ADD.W	D4,#DPOIGNEE+2	SWAP.W	D4	CALL	CVPTEXTE	; D4 <-- position dans la matrice	LOAD.L	(A6)+OPOTEXT,D4	LOAD.W	D2,#B'1101	; D2 <-- pas les poignes droite/bas	CALL	IRETEXTE	; dessine le premier rectangle	LOAD.L	D5,(A6)+OPOTEXT	LOAD.L	D3,D5	CALL	DESINFXY	; affiche X= et Y= dans les informationsPAVE3$:	CALL	SCMO	CALL	__WAITMOVES	; attend dplacement souris ...	JUMP',NE PAVE5$		; fin du dplacement => PAVE5$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE PAVE3$	CALL	RGMOUSE		; dessine la position dans les rgles	LOAD.L	D3,D4	SUB.W	D4,#DPOIGNEE-2	SWAP.W	D4	ADD.W	D4,#DPOIGNEE+2	SWAP.W	D4	CALL	CVPTEXTE	; D4 <-- position dans la matrice	COMP.L	D4,(A6)+OPOTEXT	; position change ?	JUMP,EQ PAVE3$		; non => PAVE3$				; oui =>	CALL	IRETEXTE	; efface l'ancien rectangle	LOAD.L	(A6)+OPOTEXT,D4	LOAD.L	D4,D3	CALL	__DETGPOINTOUT	; D3 <-- point o est la souris	LOAD.L	A1,#R16"KRETEXTE ; A1 <-- ^routine d'inversion	CALL	__SCROLLIPOIGNEE ; dplace v. la partie visible	CALL	IRETEXTE	; dessine le nouveau rectangle	LOAD.L	D3,(A6)+OPOTEXT	CALL	DESINFXY	; affiche X= et Y= dans les informations	JUMP	PAVE3$PAVE5$:	CALL	IRETEXTE	; efface l'ancien rectangle	CALL	CLPTEXTE	; diminue v. les dimensions du pav	CLR.W	D2		; D2 <-- les 3 poignes	CALL	IRETEXTE	; redessine le rectangle dfinitif	LOAD.L	(A6)+OOPTEXT,(A6)+OPOTEXT	LOAD.L	(A6)+OOHTEXT,(A6)+OHTTEXT	LOAD.W	D3,D1	CALL	CLOPAVE		; initialise le nouveau pav	DEC.W	D3	JUMP',NS PAVE7$	CALL	OPEPAVE		; utilise le pav prcdent	CLR.B	(A6)+O3PTEXT	CALL	IRETEXTE	; efface le pav prcdent	SET.B	(A6)+O3PTEXT	CALL	IRETEXTE	; redessine le avec 3 poignes !PAVE7$:	LOAD.L	D3,#-1	CALL	DESINFXY	; efface les informations	CALL	MAJREGLE	; met  jour les rgles	JUMP	LOOP$CSPACE$:	LOAD.W	D4,#+1	TEST.B	(A6)+OBICO	JUMP',F CSPACE1$	NEG.W	D4CSPACE1$:	LOAD.W	D3,(A6)+OECTEXT	ADD.W	D3,D4	JUMP',NC CSPACE2$	CLR.W	D3CSPACE2$:	COMP.W	D3,#5	JUMP',LO CSPACE3$	LOAD.W	D3,#5-1CSPACE3$:	LOAD.W	(A6)+OECTEXT,D3	CALL	DESCSPACE	; dessine l'espacement entre caractres	LOAD.B	D3,#ICOJUSTAJUSTNEW$:	COMP.B	D3,(A6)+OJUTEXT	JUMP,EQ LOOP$	PUSH.W	D3	LOAD.B	D3,(A6)+OJUTEXT	CALL	INVICONE	; teint l'ancien mode	POP.W	D3	LOAD.B	(A6)+OJUTEXT,D3	CALL	INVICONE	; allume le nouveau mode	JUMP	LOOP$CCOUPE$:	LOAD.W	D4,#+1	TEST.B	(A6)+OBICO	JUMP',F CCOUPE1$	NEG.W	D4CCOUPE1$:	LOAD.W	D3,(A6)+OCNTEXT	ADD.W	D3,D4	JUMP',NC CCOUPE2$	CLR.W	D3CCOUPE2$:	COMP.W	D3,#5	JUMP',LO CCOUPE3$	LOAD.W	D3,#5-1CCOUPE3$:	LOAD.W	(A6)+OCNTEXT,D3	CALL	DESCCOUPE	; dessine le critre pour les divisions	TEST.B	(A6)+OCMTEXT	JUMP,T	LOOP$DIVISE$:	NOT.B	(A6)+OCMTEXT	LOAD.B	D3,#ICODIVISE	CALL	INVICONE	; inverse l'icne	JUMP	LOOP$ESPCX$:	LOAD.W	D4,#+1	TEST.B	(A6)+OGICO	JUMP',F ESPCX1$	NEG.W	D4ESPCX1$:	LOAD.W	D3,(A6)+OCXTEXT	ADD.W	D3,D4	JUMP',NC ESPCX2$	CLR.W	D3ESPCX2$:	COMP.W	D3,#5	JUMP',LO ESPCX3$	LOAD.W	D3,#5-1ESPCX3$:	LOAD.W	(A6)+OCXTEXT,D3	CALL	DESESPCX	; dessine l'espace pour le contour	TEST.B	(A6)+OCTTEXT	JUMP,T	LOOP$	JUMP	CONTOUR$ESPCY$:	LOAD.W	D4,#+1	TEST.B	(A6)+OBICO	JUMP',F ESPCY1$	NEG.W	D4ESPCY1$:	LOAD.W	D3,(A6)+OCYTEXT	ADD.W	D3,D4	JUMP',NC ESPCY2$	CLR.W	D3ESPCY2$:	COMP.W	D3,#5	JUMP',LO ESPCY3$	LOAD.W	D3,#5-1ESPCY3$:	LOAD.W	(A6)+OCYTEXT,D3	CALL	DESESPCY	; dessine l'espace pour le contour	TEST.B	(A6)+OCTTEXT	JUMP,T	LOOP$;	JUMP	CONTOUR$CONTOUR$:	NOT.B	(A6)+OCTTEXT	LOAD.B	D3,#ICOCONTOUR	CALL	INVICONE	; inverse l'icne	JUMP	LOOP$CAR$:	CALL	DBOXGENCAR	; choix du caractre ...	JUMP,NE BIP$	CLR.W	(A6)+OICTEXT	CALL	DESITC		; dessine l'intercaractre;	JUMP'	ITLX$ITLX$:	CALL	GETPGC		; A4 <-- ^dans OBUGC	LOAD.W	(A6)+OILTEXT,(A4)+OGCITL	CALL	DESITL		; dessine l'interligne	JUMP	LOOP$ITLM$:	COMP.W	(A6)+OILTEXT,#2	JUMP,LS BIP$	DEC.W	(A6)+OILTEXT	CALL	DESITL		; dessine l'interligne	JUMP	LOOP$ITLP$:	COMP.W	(A6)+OILTEXT,#99	JUMP,HS BIP$	INC.W	(A6)+OILTEXT	CALL	DESITL		; dessine l'interligne	JUMP	LOOP$ITCX$:	CLR.W	(A6)+OICTEXT	CALL	DESITC		; dessine l'intercaractre	JUMP	LOOP$ITCM$:	COMP.W	(A6)+OICTEXT,#-20	JUMP,LE BIP$	DEC.W	(A6)+OICTEXT	CALL	DESITC		; dessine l'intercaractre	JUMP	LOOP$ITCP$:	COMP.W	(A6)+OICTEXT,#+20	JUMP,GE BIP$	INC.W	(A6)+OICTEXT	CALL	DESITC		; dessine l'intercaractre	JUMP	LOOP$PMGENC$:	LOAD.W	D3,#+1		; D3 <-- incrment (+1)	TEST.B	(A6)+OBICO	JUMP',F PMGENC1$	NEG.W	D3		; D3 <-- incrment (-1)PMGENC1$:	CALL	PMGENC	JUMP,NE BIP$	CLR.W	(A6)+OICTEXT	CALL	DESITC		; dessine l'intercaractre	JUMP	ITLX$PREND$:	LOAD.L	A3,#(A6)+OBUFTX	; A3 <-- ^buffer pour nom	CALL	DBOXEDITTX	; demande le nom du texte ...	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	TEXTREAD	; A4 <-- ^texte <0>	JUMP,NE ERROR$	LOAD.L	A2,A4	LOAD.L	A3,(A6)+OPTTEXT	CLR.W	D4PREND2$:	LOAD.B	D3,(A2+)	JUMP',EQ PREND3$	LOAD.B	(A3+),D3	; OPTTEXT <-- tout le texte lu	INC.W	D4	COMP.W	D4,#MAXTEXT	JUMP,LO PREND2$PREND3$:	CLR.B	(A3)	LOAD.W	(A6)+ONBTEXT,D4	; ONBTEXT <-- nb de caractres	LOAD.W	(A6)+OCUTEXT,D4	; OCUTEXT <-- position du curseur	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le texte	JUMP	LOOP$COUPE$:	CALL	EDCOPIE	JUMP,NE BIP$	JUMP	CLEAR$COPIE$:	CALL	EDCOPIE	JUMP,NE BIP$	JUMP	LOOP$COLLE$:	CALL	EDCOLLE	JUMP,NE BIP$	JUMP	LOOP$BLOQUE$:	COMP.B	D3,(A6)+OHVTEXT	JUMP',EQ DEBLOQUE$	PUSH.W	D3	LOAD.B	D3,(A6)+OHVTEXT	CALL	INVICONE	; teint l'ancien mode	POP.W	D3	LOAD.B	(A6)+OHVTEXT,D3	CALL	INVICONE	; allume le nouveau mode	JUMP	LOOP1$DEBLOQUE$:	CALL	INVICONE	CLR.B	(A6)+OHVTEXT	JUMP	LOOP1$HELP$:	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve tout l'cran	JUMP,NE BIP$	CLR.W	D3	CALL	__SELMO		; utilise la flche	LOAD.B	(A6)+OXICO,#NIVHELP	CALL	AFMENU		; refait les soft-keys	CALL	WAITMOUSE	; met le sablier	LOAD.L	A3,#R16"THELPT	CALL	AFIMAGE		; affiche l'image d'aide	JUMP,NE HELP8$	CALL	NORMMOUSE	; enlve le sablierHELP2$:	LIB	?GETCAR		; attend une touche ...	COMP.W	D3,#KEYMGR	JUMP,EQ HELP2$	COMP.W	D3,#KEYMMR	JUMP,EQ HELP2$	COMP.W	D3,#KEYMDR	JUMP,EQ HELP2$	CLR.W	D7		; D7 <-- ok	COMP.W	D3,#F0	JUMP',EQ HELP8$	COMP.W	D3,#F0+SHIFT	JUMP',EQ HELP8$	COMP.W	D3,#END	JUMP',EQ HELP8$	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	HELP2$HELP8$:	PUSH.W	D7	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue tout l'cran	LOAD.B	(A6)+OXICO,#NIVTEXTE	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE ERROR$	JUMP	LOOP$UNDO$:	CLR.B	(A6)+ODATEXT	; indique "annule"	CLR.B	(A6)+OXICO	; fin de l'dition	CALL	REMICONE	; remet les icnes  gauche	CALL	AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TIIHELP	CALL	DESINF3B	; remet les 3 boutons de la souris	CALL	CLOTEXTE	; ferme le pav de texte	CALL	UNDOALL		; rcupre tout !	CALL	__DESMATRIX	; redessine toutes les matrices	JUMP	__LOOPEXIT$:	TEST.W	(A6)+ONBTEXT	; y a-t-il des caractres ?	JUMP,EQ UNDO$		; non => UNDO$;;?	CALL	MAXPAVE		; D3 <-- nb de pavs;;?	COMP.W	D3,#1		; y a-t-il plus d'un pav ?;;?	JUMP',LS EXIT2$		; non => EXIT2$;;?				; oui =>	CALL	DBOXOKTEXT	; demande s'il faut figer le texte ...	JUMP,NE ERROR$	COMP.W	D3,#CR	JUMP,NE LOOP1$EXIT2$:	SET.B	(A6)+ODATEXT	; indique "d'accord"	CLR.B	(A6)+OXICO	; fin de l'dition	CALL	REMICONE	; remet les icnes  gauche	CALL	AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TIIHELP	CALL	DESINF3B	; remet les 3 boutons de la souris	CALL	CLOTEXTE	; ferme le pav de texte	JUMP	__LOOP;--------\\; PMGENC  >;========/; Cherche le gencar suivant/prcdent dans la taille.; in	D3.W	+/- incrment; out	D7.W	erreur; mod	D7.WPMGENC:	PUSHM.L	D1..D4,A2..A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A3,#(A6)+OBUGC	; A3 <-- ^buffer des gencars	CALL	GETPGC		; A4 <-- ^dans OBUGC	LOAD.B	D1,(A4)+OGCCOD+3 ; D1 <-- taille actuelle	LOAD.W	D2,#10		; D2 <-- nb max d'essais20$:	ADD.B	D1,D3		; D1 <-- taille suivante	JUMP',EQ 80$	COMP.B	D1,#99	JUMP',HI 80$	LOAD.B	(A4)+OGCCOD+3,D1	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	DGENC_	NEW		; essaye de charger le gencar suivant	JUMP',EQ 90$	DEC.W	D2	JUMP,NE 20$80$:	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POPM.L	D1..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXGENCAR >;===========/; Dialogue pour la DBOX des gencars.; in	-; out	D7.W	erreur; mod	D7.WDBOXGENCAR:	PUSHM.L	D0..D5,A0..A5	LOAD.B	D3,#ICOGGDEF	CALL	INVALLICONE	; allume l'icne	CLR.W	D3	CALL	SELMO		; met la flche10$:	LOAD.L	D4,(A6)+OFAGC	; D4 <-- fanions	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A5,#(A6)+OGCLIST; A5 <-- ^liste des gencars sur disque	LOAD.W	D5,#MAXGENC*3	; D5 <-- lg pour la liste	LOAD.L	D1,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	CALL	DBOXPOS3	; D3 <-- centre de la dbox	DGENC_	MODIF		; modifie un/qq gencar(s) ...	JUMP',NE 90$	LOAD.L	(A6)+OFAGC,D4	; mm. derniers fanions utiliss	COMP.W	D3,#F1		; MODIFIE ?	JUMP,EQ 10$	COMP.W	D3,#F4		; SUPPRIME ?	JUMP',NE 90$	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	KILL		; libre le gencar	JUMP	10$90$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	LOAD.B	D3,#ICOGGDEF	CALL	INVALLICONE	; teint l'icne	POP.W	D7	POPM.L	D0..D5,A0..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DEFGENCAR >;==========/; Utilise tous les gencars par dfaut.; Conserve 30 Kbytes de mmoire libre !; in	-; out	-; mod	D7.WDEFGENCAR:	PUSHM.L	D3,D4,D5,A2..A5	LOAD.L	A5,#R16"TGDEF	LOAD.L	A4,#(A6)+OBUGC	LOAD.B	D3,#2^BGCPROT20$:	TEST.B	(A5)		; fin de la table ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	A3,#(A4)+OGCTIT30$:	LOAD.B	(A3+),(A5+)	; OBUGC <-- titre	JUMP,NE 30$	LOAD.B	(A4)+OGCFLG,D3	LOAD.B	(A4)+OGCF,(A5+)	; OBUGC <-- fonte	LOAD.B	(A4)+OGCS,(A5+)	; OBUGC <-- style	LOAD.B	(A4)+OGCT,(A5+)	; OBUGC <-- taille	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	NEW	JUMP',NE 60$	GESMEM	?ARGMEM		; D5 <-- zone libre conscutive	COMP.L	D5,#30000	; reste assez ?	JUMP',LO 80$		; non => 80$60$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- suivant dans OBUGC	CLR.B	D3		; D3 <-- protection seulement pour 1er	JUMP	20$80$:	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	KILL90$:	POPM.L	D3,D4,D5,A2..A5	RET;---------\\; OPETEXTE >;=========/; "Ouvre" une ligne de texte pour pouvoir l'diter.; in	-; out	-; mod	D7.WOPETEXTE:	PUSHM.L	D2..D4,A3,A4	CALL	GETPGC		; A4 <-- ^dans OBUGC	LOAD.L	A3,(A6)+OPTTEXT	CLR.B	(A3)		; on part avec une ligne vide	CLR.W	(A6)+ONBTEXT	CLR.W	(A6)+OCUTEXT	CLR.B	(A6)+OACTEXT	; pas d'accent flottant	CLR.W	(A6)+OICTEXT	LOAD.W	(A6)+OILTEXT,(A4)+OGCITL	LOAD.W	D3,(A4)+OGC1Y	ADD.W	D3,(A4)+OGC2Y	LOAD.W	(A6)+OHTTEXT,D3	TEST.W	(A6)+OLGTEXT	JUMP',NE 30$	LOAD.W	(A6)+OLGTEXT,#20030$:	LOAD.L	(A6)+OOPTEXT,(A6)+OPOTEXT	LOAD.L	(A6)+OOHTEXT,(A6)+OHTTEXT	CLR.B	(A6)+OHVTEXT	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DESTEXTE >;=========/; Dessine tous les pavs de texte en dition dans les; deux rectangles  l'cran.; in	-; out	-; mod	D7.WDESTEXTE:	PUSHM.L	A2..A4	TEST.B	(A6)+OQCTEXT	; dplace le curseur ?	JUMP',T	10$		; oui => 10$	COMP.W	(A6)+ONBTEXT,#100	JUMP',LO 10$	CALL	WAITMOUSE	; met le sablier10$:	CALL	GETPGC		; A4 <-- ^dans OBUGC	LOAD.L	A2,A4		; A2 <-- ^dans OBUGC	LOAD.L	A3,(A6)+OPTTEXT	CALL	EDAFTEXT	; matrice principale <-- pav de texte	POPM.L	A2..A4	RET;---------\\; CLOTEXTE >;=========/; "Ferme" une ligne de texte.; Les points sont transfrs dans la matrice principale.; in	-; out	-; mod	D7.WCLOTEXTE:	PUSHM.L	D2..D4	TEST.L	(A6)+OPOTEXT	; ligne de texte existe ?	JUMP',EQ 90$		; non => 90$				; oui =>	LOAD.B	D3,#NOCURS	LIB	?AFCAR		; enlve le curseur	CLR.W	D2		; D2 <-- les 2 poignes	CALL	JRETEXTE	; enlve les derniers rectangles englobants	CALL	SCMO		; remet la souris	CLR.L	(A6)+OPOTEXT	; plus de texte en dition90$:	POPM.L	D2..D4	RET;---------\\; MVPTEXTE >;=========/; Dplace une poigne si la souris est dedans.; in	D3.W	numro du pav;	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WMVPTEXTE:	PUSHM.L	D1..D5,A1,A3,A4	MUL.WU	D3,#LPA	LOAD.L	A3,#(A6)+OTAPAVE	ADD.L	A3,D3	PUSH.L	(A3)+OPAPOS	LOAD.L	(A3)+OPAPOS,#-1	; pour IRETEXTE !	CALL	__DETGPOINT	; souris dans le dessin ?	JUMP,NE 90$		; non => 90$	CALL	GETPGC		; A4 <-- ^dans OBUGC	CLR.W	D2		; D2 <-- numro de la premire poigne10$:	CALL	PPOTEXTE	; D3 <-- position de la poigne	JUMP',NE 13$	SUB.W	D3,#DPOIGNEE	COMP.W	D4,D3		; trop  gauche ?	JUMP',LT 13$	ADD.W	D3,#DPOIGNEE*2	COMP.W	D4,D3		; trop  droite ?	JUMP',GE 13$	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#DPOIGNEE	COMP.W	D4,D3		; trop en haut ?	JUMP',LT 12$	ADD.W	D3,#DPOIGNEE*2	COMP.W	D4,D3		; trop en bas ?	JUMP',LT 15$12$:	SWAP.W	D413$:	INC.W	D2		; D2 <-- numro de la poigne suivante	COMP.W	D2,#3	JUMP,LO 10$	LOAD.W	D7,#1		; D7 <-- pas dans une poigne	JUMP	90$15$:	COMP.W	D2,#2	JUMP,EQ 40$	COMP.W	D2,#1	JUMP,EQ 30$; Clic dans la poigne en haut  gauche.20$:	CLR.W	D2		; D2 <-- les 3 poignes	CALL	IRETEXTE	; efface le premier rectangle	LOAD.W	D2,#B'0101	; D2 <-- pas les poignes gauche/bas	CALL	IRETEXTE	; dessine le premier rectangle	LOAD.L	D5,(A6)+OPOTEXT	LOAD.L	D3,D5	CALL	DESINFXY	; affiche X= et Y= dans les informations22$:	CALL	SCMO	CALL	__WAITMOVES	; attend dplacement souris ...	JUMP',NE 28$		; fin du dplacement => 28$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 22$	CALL	RGMOUSE		; dessine la position dans les rgles	LOAD.L	D3,D4	SUB.W	D4,#DPOIGNEE-2	SWAP.W	D4	ADD.W	D4,#DPOIGNEE+2	SWAP.W	D4	CALL	CVPTEXTE	; D4 <-- position dans la matrice	COMP.B	(A6)+OHVTEXT,#ICOHORIZ	JUMP',NE 24$	SWAP.W	D4	LOAD.W	D4,(A6)+OPOTEXT+0 ; bloque le dplacement en Y	SWAP.W	D424$:	COMP.B	(A6)+OHVTEXT,#ICOVERTI	JUMP',NE 25$	LOAD.W	D4,(A6)+OPOTEXT+2 ; bloque le dplacement en X25$:	COMP.L	D4,(A6)+OPOTEXT	; position change ?	JUMP,EQ 22$		; non => 22$				; oui =>	CALL	IRETEXTE	; efface l'ancien rectangle	LOAD.L	(A6)+OPOTEXT,D4	LOAD.L	D4,D3	CALL	__DETGPOINTOUT	; D3 <-- point o est la souris	LOAD.L	A1,#R16"KRETEXTE ; A1 <-- ^routine d'inversion	CALL	__SCROLLIPOIGNEE ; dplace v. la partie visible	CALL	IRETEXTE	; dessine le nouveau rectangle	LOAD.L	D3,(A6)+OPOTEXT	CALL	DESINFXY	; affiche X= et Y= dans les informations	JUMP	22$28$:	CALL	IRETEXTE	; efface l'ancien rectangle	PUSH.L	(A6)+OPOTEXT	LOAD.L	(A6)+OPOTEXT,D5	CLR.W	D2		; D2 <-- les 3 poignes	CALL	IRETEXTE	; redessine le rectangle primitif	POP.L	(A6)+OPOTEXT	JUMP	70$; Clic dans la poigne en haut  droite.30$:	CLR.W	D2		; D2 <-- les 3 poignes	CALL	IRETEXTE	; efface le premier rectangle	LOAD.W	D2,#B'0110	; D2 <-- pas les poignes gauche/bas	CALL	IRETEXTE	; dessine le premier rectangle	LOAD.L	D5,(A6)+OHTTEXT	LOAD.L	D4,D5	CALL	DESINFLT	; affiche L=/H= dans les informations32$:	CALL	SCMO	CALL	__WAITMOVES	; attend dplacement souris ...	JUMP',NE 38$		; fin du dplacement => 38$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 32$	CALL	RGMOUSE		; dessine la position dans les rgles	LOAD.L	D3,D4	ADD.W	D4,#DPOIGNEE-2	CALL	CVPTEXTE	; D4 <-- position dans la matrice	SUB.W	D4,(A6)+OPOTEXT+2	COMP.W	D4,(A4)+OGCX	; trop petit ?	JUMP',GE 34$		; non => 34$	LOAD.W	D4,(A4)+OGCX	; D4 <-- minimum possible34$:	COMP.W	D4,(A6)+OLGTEXT	; position change ?	JUMP,EQ 32$		; non => 32$				; oui =>	CALL	IRETEXTE	; efface l'ancien rectangle	LOAD.W	(A6)+OLGTEXT,D4	LOAD.L	D4,D3	CALL	__DETGPOINTOUT	; D3 <-- point o est la souris	LOAD.L	A1,#R16"KRETEXTE ; A1 <-- ^routine d'inversion	CALL	__SCROLLIPOIGNEE ; dplace v. la partie visible	CALL	IRETEXTE	; dessine le nouveau rectangle	LOAD.L	D4,(A6)+OHTTEXT	CALL	DESINFLT	; affiche L=/H= dans les informations	JUMP	32$38$:	CALL	IRETEXTE	; efface l'ancien rectangle	PUSH.W	(A6)+OLGTEXT	LOAD.W	(A6)+OLGTEXT,D5	CLR.W	D2		; D2 <-- les 3 poignes	CALL	IRETEXTE	; redessine le rectangle primitif	POP.W	(A6)+OLGTEXT	JUMP	70$; Clic dans la poigne en bas  droite.40$:	CLR.W	D2		; D2 <-- les 3 poignes	CALL	IRETEXTE	; efface le premier rectangle	LOAD.W	D2,#B'0011	; D2 <-- pas les poignes droite/gauche	CALL	IRETEXTE	; dessine le premier rectangle	LOAD.L	D5,(A6)+OHTTEXT	LOAD.L	D4,D5	CALL	DESINFLT	; affiche L=/H= dans les informations42$:	CALL	SCMO	CALL	__WAITMOVES	; attend dplacement souris ...	JUMP,NE 48$		; fin du dplacement => 48$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 42$	CALL	RGMOUSE		; dessine la position dans les rgles	LOAD.L	D3,D4	ADD.W	D4,#DPOIGNEE-2	SWAP.W	D4	SUB.W	D4,#DPOIGNEE+2	SWAP.W	D4	CALL	CVPTEXTE	; D4 <-- position dans la matrice	SUB.W	D4,(A6)+OPOTEXT+2	SWAP.W	D4	SUB.W	D4,(A6)+OPOTEXT+0	SWAP.W	D4	COMP.W	D4,(A4)+OGCX	; trop petit ?	JUMP',GE 43$		; non => 43$	LOAD.W	D4,(A4)+OGCX	; D4 <-- minimum possible43$:	SWAP.W	D4	LOAD.W	D1,(A4)+OGC1Y	ADD.W	D1,(A4)+OGC2Y	COMP.W	D4,D1		; trop petit ?	JUMP',GE 44$		; non => 44$	LOAD.W	D4,D1		; D4 <-- minimum possible44$:	SWAP.W	D4	COMP.B	(A6)+OHVTEXT,#ICOHORIZ	JUMP',NE 45$	SWAP.W	D4	LOAD.W	D4,(A6)+OHTTEXT	; bloque le dplacement en Y	SWAP.W	D445$:	COMP.B	(A6)+OHVTEXT,#ICOVERTI	JUMP',NE 46$	LOAD.W	D4,(A6)+OLGTEXT	; bloque le dplacement en X46$:	COMP.L	D4,(A6)+OHTTEXT	; dimensions changes ?	JUMP,EQ 42$		; non => 42$				; oui =>	CALL	IRETEXTE	; efface l'ancien rectangle	LOAD.L	(A6)+OHTTEXT,D4	LOAD.L	D4,D3	CALL	__DETGPOINTOUT	; D3 <-- point o est la souris	LOAD.L	A1,#R16"KRETEXTE ; A1 <-- ^routine d'inversion	CALL	__SCROLLIPOIGNEE ; dplace v. la partie visible	CALL	IRETEXTE	; dessine le nouveau rectangle	LOAD.L	D4,(A6)+OHTTEXT	CALL	DESINFLT	; affiche L=/H= dans les informations	JUMP	42$48$:	CALL	IRETEXTE	; efface l'ancien rectangle	PUSH.L	(A6)+OHTTEXT	LOAD.L	(A6)+OHTTEXT,D5	CLR.W	D2		; D2 <-- les 3 poignes	CALL	IRETEXTE	; redessine le rectangle primitif	POP.L	(A6)+OHTTEXT;	JUMP	70$70$:	CALL	CLPTEXTE	; diminue v. les dimensions du pav	LOAD.L	D3,#-1	CALL	DESINFXY	; efface les informations	CALL	MAJREGLE	; met  jour les rgles	CLR.W	D7		; D7 <-- ok90$:	POP.L	(A3)+OPAPOS	POPM.L	D1..D5,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; CVPTEXTE >;---------/; Calcule la position dans la mattrice d'aprs la position de; la souris directement dans l'cran.; in	D4.L	position de la souris (y;x); out	D4.L	position dans la matrice (y;x); mod	D4.L, D7.WCVPTEXTE:	PUSH.L	D3	CALL	__DETGPOINT	; D3 <-- position du point (y;x)	LOAD.L	D4,D3	POP.L	D3	RET;---------\\; CLPTEXTE >;---------/; Diminue ventuellement les dimensions du pav courant,; s'il dpasse la matrice  droite ou en bas.; in	-; out	-; mod	D7.WCLPTEXTE:	PUSHM.L	D3,D4	LOAD.W	D3,(A6)+OLGTEXT	LOAD.W	D4,(A6)+OMALMX	SUB.W	D4,#2	SUB.W	D4,(A6)+OPOTEXT+2	COMP.W	D3,D4		; pav dborde  droite ?	JUMP',LS 10$	LOAD.W	(A6)+OLGTEXT,D410$:	LOAD.W	D3,(A6)+OHTTEXT	LOAD.W	D4,(A6)+OMALMY	SUB.W	D4,#DPOIGNEE*2+1	SUB.W	D4,(A6)+OPOTEXT+0	COMP.W	D3,D4		; pav dborde en bas ?	JUMP',LS 20$	LOAD.W	(A6)+OHTTEXT,D420$:	POPM.L	D3,D4	RET;---------\\; KRETEXTE >;=========/; Inverse tous les rectangles autour des pavs de texte.; Aucune variable n'est modifie !; in	-; out	-; mod	D7.WKRETEXTE:	PUSH.L	(A6)+OPOTEXT	PUSH.L	(A6)+OHTTEXT	PUSH.L	(A6)+OOPTEXT	PUSH.L	(A6)+OOHTEXT	PUSH.B	(A6)+O3PTEXT	CALL'	JRETEXTE	POP.B	(A6)+O3PTEXT	POP.L	(A6)+OOHTEXT	POP.L	(A6)+OOPTEXT	POP.L	(A6)+OHTTEXT	POP.L	(A6)+OPOTEXT	RET;---------\\; JRETEXTE >;=========/; Inverse tous les rectangles autour des pavs de texte.; in	-; out	-; mod	D7.WJRETEXTE:	PUSHM.L	D2,D3	CLR.W	D3		; D3 <-- premier pav10$:	CALL	OPEPAVE		; utilise le bon pav	JUMP',NE 90$	CLR.W	D2		; D2 <-- les 3 poignes	CALL'	IRETEXTE	; enlve le rectangle englobant	INC.W	D3		; D3 <-- pav suivant	JUMP	10$90$:	POPM.L	D2,D3	RET;---------\\; IRETEXTE >;=========/; Inverse le rectangle autour du texte.; in	D2.W	poignes  ne pas dessiner; out	-; mod	D7.WIRETEXTE:	PUSHM.L	D0..D6	COMP.L	(A6)+OPOTEXT,#-1	JUMP,EQ 90$	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; <map>	.B	1		; <chelle>	.B	0	.EVEN	LOAD.W	D0,D2	LOAD.W	D2,#INVDOT!TTTDOT	CLR.W	D6		; D6 <-- nb de points invisibles	LOAD.L	D3,(A6)+OPOTEXT	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	CALL	__CONVGPOINT	; D3 <-- position dans l'cran sup/gauche	JUMP',EQ 20$	INC.W	D6		; D6 <-- un point invisible20$:	PUSH.L	D3	LOAD.L	D3,(A6)+OPOTEXT	ADD.W	D3,(A6)+OLGTEXT	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,(A6)+OHTTEXT	ADD.W	D3,#2	SWAP.W	D3	CALL	__CONVGPOINT	; D3 <-- position dans l'cran inf/droite	JUMP',EQ 22$	INC.W	D6		; D6 <-- un point invisible22$:	LOAD.L	D4,D3		; D4 <-- coin inf/droite	POP.L	D3		; D3 <-- coin sup/gauche	TEST.W	D6		; y a-t-il un point invisible ?	JUMP',EQ 26$		; non => 26$				; oui =>	LOAD.W	D5,(A6)+OGWDO	LIB	?USEWDO		; utilise swdo autour de la grande matrice	SUB.W	D3,(A6)+OGMPOX	SWAP.W	D3	SUB.W	D3,(A6)+OGMPOY	SWAP.W	D3	SUB.W	D4,(A6)+OGMPOX	SWAP.W	D4	SUB.W	D4,(A6)+OGMPOY	SWAP.W	D426$:	SUB.W	D4,D3		; D4 <-- largeur	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur	SWAP.W	D3	SWAP.W	D4	COMP.B	D2,#B'1101	; cre un nouveau pav ?	JUMP',EQ 30$		; oui => 30$	COMP.B	D0,#B'0110	; pas les poignes gauche/bas ?	JUMP',NE 32$		; non => 32$30$:	SWAP.W	D4	LOAD.W	D4,(A0)+ODFDY	; D4 <-- va jusque en bas	SWAP.W	D432$:	LIB	?DRRECT		; inverse le rectangle	TEST.W	D6		; y a-t-il un point invisible ?	JUMP',EQ 40$		; non => 40$				; oui =>	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale40$:	TEST.L	D0:#1		; dessine la poigne de gauche ?	JUMP',BS 50$		; non => 50$	CLR.W	D2	CALL	PPOTEXTE	; D3 <-- position de la poigne	JUMP',NE 50$	CALL	__INVPOIGNEE	; inverse la poigne de gauche50$:	TEST.L	D0:#0		; dessine la poigne de droite ?	JUMP',BS 60$		; non => 60$	LOAD.W	D2,#1	CALL	PPOTEXTE	; D3 <-- position de la poigne	JUMP',NE 60$	CALL	__INVPOIGNEE	; inverse la poigne de droite60$:	TEST.L	D0:#2		; dessine la poigne en bas ?	JUMP',BS 70$		; non => 70$	LOAD.W	D2,#2	CALL	PPOTEXTE	; D3 <-- position de la poigne	JUMP',NE 70$	CALL	__INVPOIGNEE	; inverse la poigne en bas70$:90$:	POPM.L	D0..D6	RET;---------\\; PPOTEXTE >;---------/; Donne la position dans l'cran d'une poigne.; in	D2.W	numro de la poigne (0..2); out	D3.L	position de la poigne (y;x);	D7.W	erreur; mod	D3.L, D7.WPPOTEXTE:	LOAD.W	D7,#1	COMP.W	D2,#2	JUMP,EQ 50$	COMP.W	D2,#1	JUMP',EQ 40$;	COMP.W	D2,#0;	JUMP',EQ 30$30$:				; haut/gauche =>	LOAD.L	D3,(A6)+OPOTEXT	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	CALL	__CONVGPOINT	; D3 <-- position dans l'cran	ADD.W	D3,#DPOIGNEE-1	SWAP.W	D3	SUB.W	D3,#DPOIGNEE	SWAP.W	D3	JUMP	90$40$:				; haut/droite =>	TEST.B	(A6)+O3PTEXT	; 3me poigne existe ?	JUMP,T	90$		; oui => 90$	LOAD.L	D3,(A6)+OPOTEXT	ADD.W	D3,(A6)+OLGTEXT	ADD.W	D3,#2	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	CALL	__CONVGPOINT	; D3 <-- position dans l'cran	SUB.W	D3,#DPOIGNEE-1	SWAP.W	D3	SUB.W	D3,#DPOIGNEE	SWAP.W	D3	JUMP'	90$50$:				; bas/droite =>	TEST.B	(A6)+O3PTEXT	; 3me poigne existe ?	JUMP',F	90$		; non => 90$	LOAD.L	D3,(A6)+OPOTEXT	ADD.W	D3,(A6)+OLGTEXT	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,(A6)+OHTTEXT	ADD.W	D3,#2	SWAP.W	D3	CALL	__CONVGPOINT	; D3 <-- position dans l'cran	SUB.W	D3,#DPOIGNEE-1	SWAP.W	D3	ADD.W	D3,#DPOIGNEE	SWAP.W	D3;	JUMP'	90$90$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; ICUTEXTE >;=========/; Inverse le curseur dans le texte.; in	-; out	-; mod	D7.WICUTEXTE:	PUSHM.L	D1..D5	LOAD.W	D5,(A6)+OGWDO	LIB	?USEWDO		; utilise swdo autour de la grande matrice	LOAD.L	D3,(A6)+OCPTEXT	COMP.L	D3,#-1	JUMP',EQ 50$	CALL	__CONVGPOINT	; D3 <-- position dans l'cran	SUB.W	D3,(A6)+OGMPOX	SWAP.W	D3	SUB.W	D3,(A6)+OGMPOY	SWAP.W	D3	LOAD.W	D1,(A6)+OCHTEXT	MUL.WA	D1,(A6)+OGMLPY	CALL	__D1SCALEP	; D1 <-- plus petit si "tout"	LOAD.W	D4,D1	SWAP.W	D4	CLR.W	D4		; D4 <-- <dxx>	LOAD.W	D2,#INVDOT	LIB	?DRSEG		; inverse le curseur50$:	TEST.B	(A6)+ODETEXT	; texte dborde ?	JUMP',F 90$		; non => 90$				; oui =>	LOAD.L	D3,(A6)+OPOTEXT	ADD.W	D3,(A6)+OLGTEXT	SWAP.W	D3	ADD.W	D3,(A6)+OHTTEXT	SWAP.W	D3	SUB.W	D3,(A6)+OGMOVX	LOAD.W	D5,D3	MUL.WA	D5,(A6)+OGMLPX	LOAD.W	D3,D5	LOAD.W	D1,D3	CALL	__D1SCALEP	; D1 <-- plus petit si "tout"	LOAD.W	D3,D1	LOAD.W	D5,(A6)+OGMDIX	SUB.W	D5,#GCICX	COMP.W	D3,D5	JUMP',LS 60$	LOAD.W	D3,D560$:	SWAP.W	D3	SUB.W	D3,(A6)+OGMOVY	LOAD.W	D5,D3	MUL.WA	D5,(A6)+OGMLPY	LOAD.W	D3,D5	LOAD.W	D5,(A6)+OGMDIY	DEC.W	D5	COMP.W	D3,D5	JUMP',LS 65$	LOAD.W	D3,D565$:	SUB.W	D3,#GCICB	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT+1	.B	MODCAR,INVDOT	.B	ICODEBORDE&H'7F	.B	MODCAR,SETDOT	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN90$:	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	POPM.L	D1..D5	RET;--------\\; GETPGC  >;========/; Donne le pointeur dans OBUGC au gencar actullement utilis.; in	-; out	A4.L	^dans OBUGC; mod	A4.LGETPGC:	PUSHM.L	D3,D4	LOAD.L	D4,(A6)+OFAGC	; D4 <-- fanions dbox gencar	JUMP',EQ 50$	LOAD.W	D3,#-120$:	INC.W	D3		; D3 <-- compte le rang du bit dans D4	RR.L	D4	JUMP,CC 20$	LOAD.L	A4,#(A6)+OBUGC	MUL.WU	D3,#LGGC	ADD.L	A4,D3	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BS 90$		; oui => 90$50$:	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- prend "Fond"90$:	POPM.L	D3,D4	RET;----------\\; GETACCENT >;==========/; Calcul le code correspondant  une lettre (a,e,i,o,u) et ; un accent (^,").; in	D4.B	accent (^,");	D3.B	caractre; out	D7.W	zro => ok (lettre accentue existe);	 D3.B	 lettre accentue;	D7.W	un => lettre accentue n'existe pas;	 D3.B	 caractre qui devait aller sous l'accent; mod	D3.B, D7.WGETACCENT:	PUSH.L	A3	LOAD.L	A3,#R16"TABACCENT-310$:	ADD.L	A3,#3		; A3 <-- ^suivant dans table	TEST.B	(A3)		; fin de la table ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,(A3)		; lettre trouve dans table ?	JUMP,NE 10$		; non => 10$				; oui =>	COMP.B	D4,#'^	JUMP',EQ 30$	COMP.B	D4,#'"	JUMP',NE 50$	LOAD.B	D3,(A3)+2	; D3 <-- lettre accentue (")	CLR.W	D7		; D7 <-- ok	JUMP'	90$30$:	LOAD.B	D3,(A3)+1	; D3 <-- lettre accentue (^)	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.W	D7,#1		; D7 <-- erreur90$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RETTABACCENT:	.B	'a	' '	.B	'e	' '	.B	'i	' '	.B	'o	' '	.B	'u	' '	.B	SPACE	'^ '"	.B	KCIRCON	'^ '^	.B	KTREMA	'" '"	.B	0	.EVEN	.END