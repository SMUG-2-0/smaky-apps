ck. * *		    Paul Haeberli / Silicon Graphics - 1987 */main(){/* print header */    printf("r\tg\tb\t|\tc\tm\ty\tk\n");/* transform the corners of the color cube */    printf("-----------------------------------------------------------\n");    printvals(0,0,0);    printvals(0,0,255);    printvals(0,255,0);    printvals(0,255,255);    printvals(255,0,0);    printvals(255,0,255);    printvals(255,255,0);    printvals(255,255,255);/* up one edge of the color cube */    printf("-----------------------------------------------------------\n");    printvals(0,0,0);    printvals(0,0,32);    printvals(0,0,64);    printvals(0,0,128);    printvals(0,0,192);    printvals(0,0,255);/* transform a few a chromatic colors */    printf("-----------------------------------------------------------\n");    printvals(0,0,0);    printvals(1,1,1);    printvals(16,16,16);    printvals(32,32,32);    printvals(64,64,64);    printvals(128,128,128);    printvals(192,192,192);    printvals(255,255,255);}printvals(r,g,b)int r, g, b; {    int c,m,y,k;    rgb_to_cmyk(r,g,b,&c,&m,&y,&k);    printf("%d\t%d\t%d\t|\t%d\t%d\t%d\t%d\n",r,g,b,c,m,y,k);}/* *	rgb_to_cmyk - *		Convert from rgb to cmyk.  This implements grey component *	replacement.  * *	Inputs: *		r intensity 0 to 255 *		g intensity 0 to 255 *		b intensity 0 to 255 * *	Outputs: *		c coverage 0 to 255 *		m coverage 0 to 255 *		y coverage 0 to 255 *		k coverage 0 to 255 * * *	An input value of rgb=[255,255,255] represents white.  When this is *	transformed to cmyk, we get cmyk=[0,0,0,0] which represents zero  *	coverage.  * *	An input value of rgb=[128,128,128] represents 50 percent grey.  When *	this is transformed to cmyk, we get cmyk=[0,0,0,127] which represents  *	zero coverage by cmy, and 50 percent coverage by black.  * */rgb_to_cmyk(r,g,b,c,m,y,k)int r, g, b;int *c, *m, *y, *k;{    int i; /* i is the max of r, g, and b */    i = 0;    if(r>i)	i = r;    if(g>i)	i = g;    if(b>i)	i = b;/* if r, g and b are all zero then print full black */    if(i == 0) {	*c = 0;	*m = 0;	*y = 0;	*k = 255;	return;    }    r = (255*r)/i;    g = (255*g)/i;    b = (255*b)/i;    *c = 255-r;    *m = 255-g;    *y = 255-b;    *k = 255-i;}From disuns2!sicsun!chx400!chx400!cernvax!mcsun!unido!fauern!ira.uka.de!sol.ctr.columbia.edu!lll-winken!elroy.jpl.nasa.gov!usc!apple!well!jef Fri Apr 19 13:17:35 MET DST 1991Article: 4458 of comp.graphicsPath: disuns2!sicsun!chx400!chx400!cernvax!mcsun!unido!fauern!ira.uka.de!sol.ctr.columbia.edu!lll-winken!elroy.jpl.nasa.gov!usc!apple!well!jefFrom: jef@well.sf.ca.us (Jef Poskanzer)Newsgroups: comp.graphicsSubject: (04feb91) Frequently asked questions - READ THIS BEFORE YOU POST.Message-ID: <24073@well.sf.ca.us>Date: 7 Apr 91 14:56:37 GMTExpires: 21 Apr 91 14:56:34 GMTReply-To: Jef Poskanzer <jef@well.sf.ca.us>Followup-To: no followups, pleaseOrganization: Paratheo-Anametamystikhood Of Eris Esoteric, Ada Lovelace CabalLines: 417This message is automatically posted once a week in an effort to cutdown on the repetitive junk in comp.graphics.  It was last changed on04feb91.  If you have answers to other frequently asked questions thatyou would like included in this posting, please send me mail.  If youdon't want to see this posting every week, please add the subject lineto your kill file.  Thank you.---Jef      Jef Poskanzer  jef@well.sf.ca.us  {ucbvax, apple, hplabs}!well!jef                        "...Is this a trick question?"- - - - - - - - - -Contents:    1) General references for graphics questions.    2) Drawing three-dimensional objects on a two-dimensional screen.    3) Quantizing 24 bit images down to 8 bits.    4) Converting color into grayscale.    5) Quantizing grayscale to black&white.    6) Rotating a raster image by an arbitrary angle.    7) Free image manipulation software.    8) Format documents for GIF, TIFF, IFF, BIFF, NFF, OFF, 