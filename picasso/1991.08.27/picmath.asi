	.SBTTL	PALMATH.ASIPASTOURNE =	20		; valeur minimale pour n=(360*p)+p;----------\\; CALCRAYON >;==========/; Calcule le rayon d'un cercle.; in	D3.L	origine (y;x);	D4.L	arrive (y;x); out	D5.W	rayon; mod	D5.L, D7.WCALCRAYON:	PUSHM.L	D3,D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LIB	?CALCHYPO	; D4 <-- hypothnuse	LOAD.W	D5,D4	POPM.L	D3,D4	RET;--------\\; XTOURNE >;--------/; Dtermine l'angle de rotation en fonction de la position; de la souris.; in	D4.L	position de la souris (y;x);	D3.L	point  tourner (y;x); out	D2.W	angle en degr; mod	D2.LXTOURNE:	PUSHM.L	D3,D5	LOAD.L	D5,D3		; D5 <-- point  tourner	LOAD.L	D3,(A6)+OSEPMI	; D3 <-- centre	LIB	?CALCANGLE	; D2 <-- angle	POPM.L	D3,D5	RET;--------\\; QTOURNE >;--------/; Tourne un point d'un angle quelconque selon la; formule magique suivante :;;	x' = x*cos(a) - y*sin(a);	y' = x*sin(a) + y*cos(a);; OSEPMI.L contient la coordonne du centre de symtrie.; in	D2.W	angle en degrs;	D3.L	coordonne (y;x); out	D3.L	coordonne (y;x); mod	D3.LQTOURNE:	PUSHM.L	D1,D4	LOAD.W	D1,D2		; D1 <-- angle	LOAD.L	D4,D3		; D4 <-- point  tourner	LOAD.L	D3,(A6)+OSEPMI	; D3 <-- centre de symtrie	LIB	?CALCPSYM	; D4 <-- point tourn	LOAD.L	D3,D4	POPM.L	D1,D4	RET	.END