	.TITLE	EXEMPLE.ASC; -----------------------------------------------------------------; Ce petit exemple de programme incomplet montre l'utilisation des; modules BLOC (pour le couper/coller) et ICOLOR (pour la couleur).; -----------------------------------------------------------------	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	BLOC	.REF	ICOLOR; Nouvelles dfinitions; ---------------------GRA_CRASTER	 = H'A899		; raster-op couleurGRA_GDOT	 = H'A89A		; get-dotBSRCCOUL	 = 11BDSTCOUL	 = 12; Couleurs; --------COLORBASE=	H'8000COLOROUTIL=	COLORBASE+1	; outilsCOLORMODE=	COLORBASE+2	; modesCOLOROBJET=	COLORBASE+3	; objetsCOLORMODIF=	COLORBASE+4	; modificationsCOLORFINFO=	COLORBASE+5	; fond infoCOLORCINFO=	COLORBASE+6	; chair infoCOLORFOND=	COLORBASE+7	; fond cadre; En-tte d'une image couleur (.COLOR); ------------------------------------	.LOC	0	.BLKB	1		; OIMTYP: H'82	.BLKB	1		; OIMCOD: 0 ou 4	.BLKB	1		; OIMBIP: 4 bits/pixel	.BLKB	1		; OIMDIR: 2	.BLKB	2		; OIMDLX: largeur (multiple de 16)	.BLKB	2		; OIMDLY: hauteur	.BLKB	4		; OIMNBB: longueur du dataOIMSIZ:	.BLKB	2		; taille d'un pixel (4)OIMCNT:	.BLKB	2		; nb de pixels (1)OIMLGC:	.BLKB	4		; longueur de la CLUT	.BLKB	12		; rserve				; LGHIMA: longueur de l'en-tte; Variables; ---------	.LOC	0OCHBLOC:.BLKB	2		; canal module BLOCOCHICOLOR:.BLKB	2		; canal du module ICOLOROIDCRET:.BLKB	4		; identificateur de la CRET...LGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	...; Initialisation; --------------	LOAD.L	A3,#R16"NMBLOC	LOAD.W	D3,#BLOC_FIRST	LIB_	OPEN		; ouvre le module BLOC	JUMP',NE NOBLOC$	LOAD.W	(A6)+OCHBLOC,D1	BLOC_	OPEN		; ouverture globaleNOBLOC$:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	LOAD.L	A3,#R16"NMICOLOR	LOAD.W	D3,#ICOL_FIRST	LIB_	OPEN		; ouvre le module ICOLOR	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHICOLOR,D1NOCOUL$:	...; Fin de l'initialisation,  faire le plus tard possible; ------------------------------------------------------	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCRET$	; non => NOCRET$	LOAD.L	A3,#R16"NMLOG	; A3 <-- ^nom du logiciel (EXEMPLE)	LOAD.L	A5,#R16"TCOUL	; A5 <-- ^table des couleurs	LOAD.L	D3,#2^BICCRET	ICOL_	INIT		; charge EXEMPLE.CRET	LOAD.L	(A6)+OIDCRET,D5NOCRET$:; Programme principal; -------------------MAIN:	LIB	?GETCAR	COMP.W	D3,#H'100*(2^BKILL)+SPACE	JUMP,EQ COUPE	COMP.W	D3,#H'100*(2^BKILL!2^BPROGRA)+SPACE	JUMP,EQ COUPE	COMP.W	D3,#H'100*(2^BCOPY)+SPACE	JUMP,EQ COPIE	COMP.W	D3,#H'100*(2^BCOPY!2^BPROGRA)+SPACE	JUMP,EQ COPIE	COMP.W	D3,#H'100*(2^BCURSOR)+SPACE	JUMP,EQ COLLE	COMP.W	D3,#H'100*(2^BSHOW)+SPACE	JUMP,EQ CLASSEUR	...COUPE:	...COPIE:	...COLLE:	...CLASSEUR:	...; Fermeture finale; ----------------END:	LOAD.W	D1,(A6)+OCHBLOC	JUMP',EQ NOBLOC$	BLOC_	CLOSE		; fermeture globale	JUMP',NE NOBLOC$	LIB_	CLOSE		; ferme le module BLOCNOBLOC$:	LOAD.W	D1,(A6)+OCHICOLOR	LIB_	CLOSE		; ferme le module ICOLOR	LIB	?CLOLIB	FOS	?STOP;----------\\; DBOXCOLOR >;==========/; Choix des couleurs dans EXEMPLE.CRET.; in	-; out	D7.W	erreur; mod	D7.WDBOXCOLOR:	PUSHM.L	D3..D5,A3..A5	LOAD.L	A3,#R16"NMLOG	; A3 <-- ^nom du logiciel	LOAD.L	A5,#R16"TCOUL	; A5 <-- ^table des couleurs	LOAD.L	D5,(A6)+OIDCRET	LOAD.L	D4,#2^BICMPAL	; D4 <-- mode local	ICOL_	MODCRET		; modifie la CRET ...	PUSH.W	D7	CALL	...		; refait les soft-keys	POP.W	D7	JUMP',NE EXIT$	LOAD.L	(A6)+OIDCRET,D5EXIT$:	POPM.L	D3..D5,A3..A5	TEST.W	D7		; retour EQ/NE	RET; Noms des modules; ----------------NMBLOC:		.ASCIZ	"BLOC"NMICOLOR:	.ASCIZ	"ICOLOR"NMLOG:		.ASCIZ	"EXEMPLE"	; nom du logiciel (sans .CODE)		.EVEN; Tables des couleurs relatives; -----------------------------TCOUL:	.L	COLORFOND	.W	-1,-1,-1	.ASCIZE	"fond du cadre"	.L	COLORFINFO	.W	0,0,0	.ASCIZE	"fond des informations (ligne en haut)"	.L	COLORCINFO	.W	-1,-1,-1	.ASCIZE	"<1>contenu des informations"	.L	COLOROUTIL	.W	-1,-1,-1	.ASCIZE	"icnes des outils"	.L	COLORMODE	.W	-1,-1,-1	.ASCIZE	"icnes des modes"	.L	COLOROBJET	.W	-1,-1,-1	.ASCIZE	"icnes des objets"	.L	COLORMODIF	.W	-1,-1,-1	.ASCIZE	"icnes des modifications"	.L	0	.END	START