	.SBTTL	PICDROITE.ASIMILIEU:	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP,BC MENUICO$	; non => MENUICO$	LOAD.L	A3,#R16"TMENUMILIEU	LOAD.L	A4,#(A6)+OMPAMI	; A4 <-- ^paramtres;	CLR.L	(A4)+LMM*0+OMMINA	CLR.L	(A4)+LMM*1+OMMINA;	CLR.L	(A4)+LMM*2+OMMINA	CLR.L	(A4)+LMM*3+OMMINA	TEST.B	(A6)+OMAJ	; mise  jour ncessaire ?	JUMP',T 10$		; oui => 10$	TSET.B	(A4)+LMM*1+OMMINA+3:#2 ; plus de case "sauve"10$:	TEST.L	(A6)+OCASCAN	; scanner prsent ?	JUMP',NE 12$		; oui => 12$	TSET.B	(A4)+LMM*1+OMMINA+3:#4 ; plus de case "scanne"12$:	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE 20$	TSET.B	(A4)+LMM*3+OMMINA+3:#2 ; plus de case "chelle 1:1"20$:	COMP.W	(A6)+OSCALE,#SCALEMAX	JUMP',NE 22$	TSET.B	(A4)+LMM*3+OMMINA+3:#3 ; plus de case "chelle +"22$:	TEST.W	(A6)+OASHOR+OSCHTV	JUMP',NE 24$	TEST.W	(A6)+OASVER+OSCHTV	JUMP',NE 24$	TSET.B	(A4)+LMM*3+OMMINA+3:#1 ; plus de case "chelle -"	TSET.B	(A4)+LMM*3+OMMINA+3:#0 ; plus de case "tout"24$:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE 30$		; oui => 30$	TSET.B	(A4)+LMM*0+OMMINA+3:#5 ; plus de case "couleurs"30$:	TEST.W	(A6)+OCHBLOC	; module BLOC charg ?	JUMP',NE 32$		; oui => 32$	TSET.B	(A4)+LMM*2+OMMINA+3:#2	; grise "coupe"	TSET.B	(A4)+LMM*2+OMMINA+3:#3	; grise "copie"	TSET.B	(A4)+LMM*2+OMMINA+3:#4	; grise "colle"	TSET.B	(A4)+LMM*2+OMMINA+3:#5	; grise "classeur.."32$:	CALL	_MMENUS		; action selon mmenu hirarchique ...	LOAD.W	D4,(A4)+LMM*0+OMMSEL	DEC.W	D4	JUMP,EQ FILE$	DEC.W	D4	JUMP,EQ EDIT$	DEC.W	D4	JUMP,EQ SCALE$	LOAD.W	D3,#F4		; D3 <-- Df.	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#H'100*(2^BPROGRA)+'C	DEC.W	D4	JUMP,EQ EXECUTE	JUMP	LOOPFILE$:	LOAD.W	D4,(A4)+LMM*1+OMMSEL	LOAD.W	D3,#F1		; D3 <-- Prend	TEST.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F2		; D3 <-- Ajoute	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F3		; D3 <-- Sauve	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#H'100*(2^BPROGRA)+'N	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F6		; D3 <-- Scanne	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F15		; D3 <-- Imp.	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F0		; D3 <-- Quitte	DEC.W	D4	JUMP,EQ EXECUTE	JUMP	LOOPEDIT$:	LOAD.W	D4,(A4)+LMM*2+OMMSEL	LOAD.W	D3,#UNDO	; D3 <-- Annule	TEST.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F14		; D3 <-- Efface	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#H'100*(2^BKILL)+SPACE ; D3 <-- Coupe	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#H'100*(2^BCOPY)+SPACE ; D3 <-- Copie	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#H'100*(2^BCURSOR)+SPACE ; D3 <-- Colle	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#H'100*(2^BSHOW)+SPACE ; D3 <-- Classeur	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#HELP	; D3 <-- Aide	DEC.W	D4	JUMP,EQ EXECUTE	JUMP	LOOPSCALE$:	LOAD.W	D4,(A4)+LMM*3+OMMSEL	LOAD.W	D3,#F13		; D3 <-- Tout	TEST.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F7		; D3 <-- Echelle -	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F8		; D3 <-- Echelle 1:1	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F9		; D3 <-- Echelle +	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F5		; D3 <-- Zoom	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F11		; D3 <-- Filtre	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F12		; D3 <-- Ngatif	DEC.W	D4	JUMP,EQ EXECUTE	LOAD.W	D3,#F10		; D3 <-- Rgles	DEC.W	D4	JUMP,EQ EXECUTE	JUMP	LOOPMENUICO$:	CALL	MENUICONE	; menu des icnes de gauche ...	JUMP,NE LOOP	TEST.B	D3	JUMP,EQ LOOP	JUMP	CLICICONEENTOURE:	LOAD.B	D3,(A6)+OSELECT	; D3 <-- type de slection choisie	COMP.B	D3,#ICOZONE	JUMP',EQ ENTOUREZONE	COMP.B	D3,#ICOFILET	JUMP,EQ ENTOUREFILET	COMP.B	D3,#ICOCROCHET	JUMP,EQ ENTOURECROCHET	JUMP	BIPENTOUREZONE:	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCOPY	; touche (COPY) enfonce ?	JUMP',BS 10$		; oui => 10$				; non =>	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	LOAD.L	D1,D3		; D1 <-- coin initial	LOAD.L	D2,D3	JUMP'	12$10$:	CLR.B	D3	CALL	_SELMO		; utilise le lutin flche	LOAD.L	D1,(A6)+OLASTP1	LOAD.L	D2,(A6)+OLASTP2	LOAD.L	D3,D2	CALL	CONVGPOINT	JUMP',NE 12$	LOAD.L	D4,D3	CALL	_PMOUSE		; remet la souris dans le bon coin	LOAD.W	D4,#2	NTREL	?DELMS		; attend que le positionnement soit fait !12$:	CALL	D1D2POIGNEE	; OSEPxx <-- coins	CLR.B	(A6)+ODDOP	CALL	INVSELECT	; dessine le premier tour	CLR.B	D3	CALL	_SELMO		; utilise le lutin flche20$:	CALL	_SCMO	CALL	WAITMOVES	; attend dplacement souris ...	COMP.W	D3,#'1	JUMP,EQ 60$	COMP.W	D3,#'2	JUMP,EQ 60$	COMP.W	D3,#'3	JUMP,EQ 60$	TEST.W	D7	JUMP',NE 50$		; fin du dplacement => 50$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINTOUT	; D3 <-- point o est la souris	COMP.L	D3,(A6)+OSEPBD	; souris dplace ?	JUMP,EQ 20$		; non => 20$				; oui =>	CALL	INVSELECT	; efface l'ancien tour	LOAD.L	(A6)+OSEPBD,D3	LOAD.W	(A6)+OSEPHD+2,D3	SWAP.W	D3	LOAD.W	(A6)+OSEPBG+0,D3	SWAP.W	D3	CALL	SCROLLPOIGNEE	; dplace v. la partie visible	CALL	INVSELECT	; dessine le nouveau tour	JUMP	20$50$:	CALL	MAJREGLE	; met  jour les rgles	LOAD.L	(A6)+OLASTP1,(A6)+OSEPHG	LOAD.L	(A6)+OLASTP2,(A6)+OSEPBD	CLR.L	D0		; D0 <-- souris dans le coin	JUMP	ENTOUREMENU60$:	COMP.B	(A6)+OSELECT,#ICOZONE ; filet/crochet ?	JUMP,NE 20$		; oui => 20$	CALL	MAJREGLE	; met  jour les rgles	SUB.W	D3,#'1		; D3 <-- 0..2	CALL	INVSELECT	; efface l'ancien tour	JUMP	QUICKBLOCENTOUREFILET:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	LOAD.L	A4,(A6)+OPMAM	CALL	_CLEARALL	; efface toute la matrice masque	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	D5,D3		; D5 <-- origine fixe	CLR.W	D0		; D0 <-- souris pas bouge	PUSH.B	(A6)+OOUTIL	PUSH.B	(A6)+OOBJET	PUSH.L	(A0)+ODFCSF	LOAD.B	(A6)+OOUTIL,#ICOCRAYON	LOAD.B	(A6)+OOBJET,#ICOFILET	LOAD.L	(A0)+ODFCSF,#NBCOUL-1	PUSH.L	D5		; stack <-- origine	CLR.B	D3	CALL	_SELMO		; utilise le lutin flche	LOAD.W	D4,#2	NTREL	?DELMS		; attend qu'il change ... !	LOAD.L	D1,#-1		; D1 <-- coin sup/gauche	CLR.L	D2		; D2 <-- coin inf/droiteLOOP$:	CLR.B	D3	CALL	_SELMO		; utilise le lutin flche	CALL	_SCMO		; montre la flche	CALL	WAITMOVE	; attend dplacement souris ...	JUMP,NE END$		; fin du dplacement => END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE LOOP$	COMP.L	D3,D5		; souris dplace ?	JUMP,EQ LOOP$		; non => LOOP$				; oui =>	COMP.W	D1,D3	JUMP',LS LEFT$	LOAD.W	D1,D3		; D1 <-- extrme gaucheLEFT$:	COMP.W	D2,D3	JUMP',HS RIGHT$	LOAD.W	D2,D3		; D2 <-- extrme droiteRIGHT$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	COMP.W	D1,D3	JUMP',LS UP$	LOAD.W	D1,D3		; D1 <-- extrme hautUP$:	COMP.W	D2,D3	JUMP',HS DOWN$	LOAD.W	D2,D3		; D2 <-- extrme basDOWN$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	LOAD.L	D6,D3		; D6 <-- arrive	PUSHM.L	D1,D2	LOAD.W	D2,#SETDOT!TTTDOT!NCTDOT	CALL	DESCOMMEPLAN	; petit: dessine droite de "origine"  "arrive"	LOAD.W	D2,#SETDOT!2^14	CALL	DESCOMMEPLAN	; dessine dans la matrice masque	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE NEXT$	LOAD.W	D2,#SETDOT!TTTDOT!NCTDOT!2^15	CALL	DESCOMMEPLAN	; dessine dans la matrice principale	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim de la droite	LOAD.L	D1,(A0)+ODFCSF	CALL	SHOGMATRIX	; grand: dessine aussi la droiteNEXT$:	POPM.L	D1,D2	LOAD.L	D5,D6		; D5 <-- future origine	INC.W	D0		; D0 <-- souris bouge	JUMP	LOOP$END$:	POP.L	D6		; D6 <-- point initial	COMP.L	D6,D5	JUMP',EQ CLOSE$				; lie le dpart  l'arrive =>	PUSHM.L	D1,D2	LOAD.W	D2,#SETDOT!TTTDOT!NCTDOT	CALL	DESCOMMEPLAN	; petit: dessine droite de "origine"  "arrive"	LOAD.W	D2,#SETDOT!2^14	CALL	DESCOMMEPLAN	; dessine dans la matrice masque	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE NOLOUP$	LOAD.W	D2,#SETDOT!TTTDOT!NCTDOT!2^15	CALL	DESCOMMEPLAN	; dessine dans la matrice principale	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim de la droite	LOAD.L	D1,(A0)+ODFCSF	CALL	SHOGMATRIX	; grand: dessine aussi la droiteNOLOUP$:	POPM.L	D1,D2CLOSE$:	POP.L	(A0)+ODFCSF	POP.B	(A6)+OOBJET	POP.B	(A6)+OOUTIL	COMP.W	D0,#2		; souris bouge ?	JUMP,LS BIP		; non => BIP				; oui =>	CALL	_UNDOALL	; rcupre tout pour effacer le filet !	CALL	DESMATRIX	; redessine toutes les matrices	CALL	DESFILET	; matrice masque <-- rempli le filet	JUMP,NE BIP	JUMP	ENTOURERMENUENTOURECROCHET:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	LOAD.L	A3,#R16"TABLE$	; A3 <-- ^liste des points o chercher	LOAD.L	D0,D3SLOOP$:	COMP.W	(A3),#100	; fin de la table ?	JUMP,EQ BIP		; oui => BIP (on a rien accroch)	LOAD.L	D3,D0	SWAP.W	D3	ADD.W	D3,(A3+)	SWAP.W	D3	ADD.W	D3,(A3+)	; D3 <-- point cherch	LOAD.L	A1,(A6)+OPMAT	CALL	COULPOINT	; D1 <-- couleur du point	COMP.L	D1,(A6)+OCCLR	; point montr allum ?	JUMP,EQ SLOOP$		; non => SLOOP$				; oui =>	LOAD.L	D0,D3		; D0 <-- point "croch"	CALL	_WAITMOUSE	; met le sablier	LOAD.L	A3,(A6)+OPMAT	LOAD.L	A4,(A6)+OPMAM	CALL	_XFERALL	; matrice masque <-- matrice principale;	LOAD.L	A4,(A6)+OPMAM	CALL	_OPEDISMAT	; dessine dans la matrice masque	PUSH.L	(A6)+ODFCSF	PUSH.L	(A6)+ODFCCF	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	_DRMDEF		; dfinit une trame pleine	CLR.L	(A6)+ODFCSF	; rempli en blanc	CLR.L	(A6)+ODFCCF	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3)+0,#AFFILLA	LOAD.B	(A3)+1,#DRAWFILLO	LOAD.L	D3,D0	SWAP.W	D3	LOAD.L	(A3)+2,D3	; <xx> et <yy>	LOAD.W	D3,#1+5	LIB	?STRING		; rempli ...	JUMP,NE CLOSE$;	LOAD.L	A4,(A6)+OPMAM	CALL	_CLEARALL	; matrice masque <-- efface	LOAD.L	A3,(A0)+ODFFIP	LOAD.L	D1,#-1		; D1 <-- coin sup/gauche	CLR.L	D2		; D2 <-- coin inf/droite	LOAD.L	(A6)+ODFCSF,#NBCOUL-1;	CLR.L	(A6)+ODFCCFFLOOP$:	CLR.W	D7		; D7 <-- ok	LOAD.L	A3,#(A3)+LGRAF	; A3 <-- ^ligne suivante	COMP.W	(A3),#-1	JUMP,EQ CLOSE$	LOAD.L	D3,(A3)+OGRAFY	CLR.L	D4	LOAD.W	D4,(A3)+OGRAFXF	SUB.W	D4,D3	INC.W	D4	PUSHM.L	D2,D3	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; redessine ligne par ligne	POPM.L	D2,D3	COMP.W	D1,D3	JUMP',LS 24$	LOAD.W	D1,D3		; D1 <-- extrme gauche24$:	COMP.W	D2,D3	JUMP',HS 25$	LOAD.W	D2,D3		; D2 <-- extrme droite25$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	COMP.W	D1,D3	JUMP',LS 26$	LOAD.W	D1,D3		; D1 <-- extrme haut26$:	COMP.W	D2,D3	JUMP',HS 27$	LOAD.W	D2,D3		; D2 <-- extrme bas27$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	ADD.W	D3,D4		; D3 <-- position d'arrive	COMP.W	D1,D3	JUMP',LS 34$	LOAD.W	D1,D3		; D1 <-- extrme gauche34$:	COMP.W	D2,D3	JUMP',HS 35$	LOAD.W	D2,D3		; D2 <-- extrme droite35$:	JUMP	FLOOP$CLOSE$:	POP.L	(A6)+ODFCCF	POP.L	(A6)+ODFCSF	PUSH.W	D7	LOAD.B	D3,#DRAWFILLC	LIB	?AFCAR		; libre le remplissage	CALL	_CLODISMAT	; redessine dans l'cran	POP.W	D7	JUMP,NE BIGBIPWAIT$:	LIB	?IFMOUSE	; attend que l'on relche les boutons ...	TEST.B	D3	JUMP,NE WAIT$	LOAD.L	D5,D0	JUMP	ENTOURERMENUTABLE$:	.W	0,0	.W	0,1	.W	1,1	.W	1,0	.W	1,-1	.W	0,-1	.W	-1,-1	.W	-1,0	.W	-1,1	.W	-1,2	.W	0,2	.W	1,2	.W	2,2	.W	2,1	.W	2,0	.W	2,-1	.W	2,-2	.W	1,-2	.W	0,-2	.W	-1,-2	.W	-2,-2	.W	-2,-1	.W	-2,0	.W	-2,1	.W	-2,2	.W	100ENTOURERMENU:	CALL	D1D2POIGNEE	; OSEPxx <-- coins	CLR.B	(A6)+ODDOP	CALL	INVSELECT	; dessine le tour rectangulaire	CALL	_SCMO		; remet la flche	CALL	_NORMMOUSE	; enlve le sablier	LOAD.L	D0,D2	SUB.W	D0,D5	SWAP.W	D0	SWAP.W	D5	SUB.W	D0,D5		; D0 <-- offset pour ne pas bouger la souris !	SWAP.W	D0	SWAP.W	D5	EX.L	D1,D0	CALL	D1SCALEP	; D0 <-- plus petit si "tout"	EX.L	D0,D1	TEST.W	(A6)+OSCALE	JUMP',NS ENTOUREMENU	LOAD.W	D1,D0	MUL.WU	D1,(A6)+OSCALE	LOAD.W	D0,D1	SWAP.W	D0	LOAD.W	D1,D0	MUL.WU	D1,(A6)+OSCALE	LOAD.W	D0,D1	SWAP.W	D0ENTOUREMENU:	LOAD.L	D1,(A6)+OSEPHG	LOAD.L	D2,(A6)+OSEPBD	CALL	_IFMOUSE	; D4 <-- position souris avant mmenu	LOAD.L	A3,#R16"TMENUENTOURE	LOAD.L	A4,#(A6)+OMPADR	; A4 <-- ^paramtres	CLR.L	(A4)+LMM*0+OMMINA	CLR.L	(A4)+LMM*1+OMMINA	CLR.L	(A4)+LMM*2+OMMINA	COMP.B	(A6)+OSELECT,#ICOZONE ; filet/crochet ?	JUMP',EQ 20$		; non => 20$	TSET.B	(A4)+LMM*0+OMMINA+3:#6	; grise "bloc-notes"	TSET.B	(A4)+LMM*2+OMMINA+3:#4	; grise "filtre"20$:	TEST.W	(A6)+OCHBLOC	; module BLOC charg ?	JUMP',NE 22$		; oui => 22$	TSET.B	(A4)+LMM*0+OMMINA+3:#4	; grise "coupe"	TSET.B	(A4)+LMM*0+OMMINA+3:#5	; grise "copie"22$:	CALL	_MMENUS		; action selon mmenu hirarchique ...	LOAD.W	D3,(A4)+LMM*0+OMMSEL	DEC.W	D3	JUMP,EQ ZONEDETRUIT	DEC.W	D3	JUMP,EQ ZONEDEPLACE	DEC.W	D3	JUMP,EQ ZONEDUPLIQUE	DEC.W	D3	JUMP,EQ ZONECOUPE	DEC.W	D3	JUMP,EQ ZONECOPIE	DEC.W	D3	JUMP,EQ ZONEBLOC	DEC.W	D3	JUMP,EQ ZONEOPER	DEC.W	D3	JUMP,EQ ZONELOUPE	DEC.W	D3	JUMP,EQ ZONESAUVE	CALL	INVSELECT	; efface l'ancien tour	JUMP	LOOPZONEBLOC:	LOAD.W	D3,(A4)+LMM*1+OMMSEL	CALL	INVSELECT	; efface l'ancien tour	JUMP	QUICKBLOCZONEOPER:	LOAD.W	D3,(A4)+LMM*2+OMMSEL	JUMP,EQ ZONEZOOM	DEC.W	D3	JUMP,EQ ZONETOURNE	DEC.W	D3	JUMP,EQ ZONEMIROIR	DEC.W	D3	JUMP,EQ ZONEDEFORME	DEC.W	D3	JUMP,EQ ZONEFILTRE	DEC.W	D3	JUMP,EQ ZONENEGATIF	CALL	INVSELECT	; efface l'ancien tour	JUMP	LOOPZONEFILTRE:	CALL	DBOXFILTRE	; demande le filtre ...	JUMP',NE END$	COMP.W	D3,#F1	JUMP',NE END$	CALL	_COPYZALL	; fait une copie de la matrice	LOAD.L	D1,(A6)+OSEPHG	LOAD.L	D2,(A6)+OSEPBD	CALL	ORDONNE	LOAD.L	D3,D1	LOAD.L	D4,D2	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.L	A3,#(A6)+OFDBTAB ; A3 <-- ^table du filtre	CALL	FILOPER		; transforme ...	CALL	INVSELECT	; efface l'ancien tour	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	JUMP	LOOPEND$:	CALL	INVSELECT	; efface l'ancien tour	JUMP	LOOPZONEDETRUIT:	CALL	_COPYZALL	; fait une copie de la matrice	CALL	INVSELECT	; efface l'ancien tour	CALL	POSDIM		; D1 <-- pos et D2 <-- dimZONEDETR2:	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; D4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- position source	LOAD.L	D4,D1		; D4 <-- position destination	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	_XFERZONE	; inverse avec source = destination !	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	JUMP	LOOPZONEDEPLACE:	CALL	_COPYZALL	; fait une copie de la matrice	CALL	_PMOUSE		; remet souris comme avant mmenu	LOAD.L	D5,D1		; D5 <-- origine	LOAD.L	D6,D2		; D6 <-- arrive (o est la souris)	LOAD.B	(A6)+ODDOP,#ICODEPLACE	JUMP	ZONEMOVEZONEDUPLIQUE:	CALL	_COPYZALL	; fait une copie de la matrice	CALL	_PMOUSE		; remet souris comme avant mmenu	LOAD.L	D5,D1		; D5 <-- origine	LOAD.L	D6,D2		; D6 <-- arrive (o est la souris)	LOAD.B	(A6)+ODDOP,#ICODUPLIQUE;	JUMP	ZONEMOVE; in	D1/D2		rectangle dans matrice principale;	D5/D6		rectangle dans matrice masque;	D4.L		position de la souris;	D0.L		offset position souris;	(A6)+ODDOP.B	opration (ICODEPLACE, etc.)ZONEMOVE:	CALL	D1D2POIGNEE	; OSEPxx <-- coins	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D4	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D4	CALL	DETGPOINTF	; D3 <-- point o est la souris	CALL	FIXPAS		; fixe l'origine pour le pas	COMP.B	(A6)+ODDOP,#ICODEPLACE	JUMP',NE 18$	CALL	DDISOURCE	; efface dans matrice copie18$:	CALL	DDINIT		; init pour dplacement20$:	CALL	_SCMO	CALL	WAITMOVES	; attend dplacement souris ...	JUMP,NE 50$		; fin du dplacement => 50$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	_RGMOUSE	; dessine la position dans les rgles	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D4	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D4	CALL	DETGPOINTOUT	; D3 <-- point o est la souris	CALL	RNDPAS		; D3 <-- arrondi selon le pas	COMP.L	D3,(A6)+OSEPBD	; souris dplace ?	JUMP,EQ 20$		; non => 20$				; oui =>	CALL	DDINVSELECT	; efface l'ancien tour	SUB.W	D3,(A6)+OSEPBD+2	ADD.W	(A6)+OSEPHG+2,D3	ADD.W	(A6)+OSEPHD+2,D3	ADD.W	(A6)+OSEPBG+2,D3	ADD.W	(A6)+OSEPBD+2,D3	SWAP.W	D3	SUB.W	D3,(A6)+OSEPBD+0	ADD.W	(A6)+OSEPHG+0,D3	ADD.W	(A6)+OSEPHD+0,D3	ADD.W	(A6)+OSEPBG+0,D3	ADD.W	(A6)+OSEPBD+0,D3;	SWAP.W	D3	CALL	TESTPOIGNEES	; vrifie que rien ne dborde	CALL	DDMOVE		; dplace dans l'cran	CALL	DDINVSELECT	; dessine le nouveau tour	JUMP	20$50$:	CALL	DDINVSELECT	; efface le dernier tour	CALL	DDPRECT		; efface rectangle dans matrice masque	CALL	DDMOVE		; dplace dans l'cran	COMP.B	(A6)+ODDOP,#ICODEPLACE	JUMP',NE 52$	CALL	DDISOURCE	; remet dans matrice copie52$:	CALL	DDCCLOSE	; ferme la matrice contour	LOAD.L	D1,(A6)+OSEPHG	LOAD.L	D2,(A6)+OSEPBD	LOAD.L	(A6)+OLASTP1,D1	LOAD.L	(A6)+OLASTP2,D2	CALL	MAJREGLE	; met  jour les rgles	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NC LOOP		; non => LOOP	LOAD.W	D0,#SETDOT	CALL	DDPGMATRIX	; dessine la matrice dfinitive	CALL	POSDIM		; D1 <-- pos et D2 <-- dim (nouveau)	EX.L	D1,D5	EX.L	D2,D6	CALL	POSDIM		; D5 <-- pos et D6 <-- dim (initial)	EX.L	D1,D5	EX.L	D2,D6	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice masque	LOAD.L	D3,D5	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D4,D1	LOAD.L	D5,D6		; D5 <-- dimensions	COMP.B	(A6)+ODDOP,#ICODEPLACE	JUMP',NE 80$	PUSHM.L	D4,A3	LOAD.L	A3,A4		; A3 <-- ^matrice principale	LOAD.L	D4,D5		; D4 <-- dimensions	CALL	_CLEARZONE	; matrice principale <-- efface	POPM.L	D4,A380$:	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CALL	_XFERZONE	; matrice principale <-- zone dplace	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NC LOOP		; non => LOOP	CALL	DESPMATRIX	; oui => redessine la matrice	JUMP	LOOPZONECOUPE:	CALL	INVSELECT	; efface l'ancien tour	PUSH.B	(A6)+OMAJ	CALL	_COPYZALL	; fait une copie de la matrice	POP.B	(A6)+OMAJ	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	CALL	SAUVEBLOC	; sauve dans le bloc-notes ..	JUMP,NE BIP	CALL	_COPYZALL	; fait une copie de la matrice	JUMP	ZONEDETR2	; .. puis efface la zoneZONECOPIE:	CALL	INVSELECT	; efface l'ancien tour	PUSH.B	(A6)+OMAJ	CALL	_COPYZALL	; fait une copie de la matrice	POP.B	(A6)+OMAJ	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	CALL	SAUVEBLOC	; sauve dans le bloc-notes	JUMP,NE BIP	JUMP	LOOPQUICKBLOC:	LOAD.L	A4,#(A6)+OBLOC	LOAD.W	D4,D3		; D4 <-- 0..2	MUL.WU	D4,#LGBLOC	ADD.L	A4,D4		; A4 <-- ^bloc-notes	LOAD.L	(A4)+OBLKPT,(A6)+OPMAT	LOAD.L	(A4)+OBLKP1,(A6)+OSEPHG	LOAD.L	(A4)+OBLKP2,(A6)+OSEPBD	LOAD.W	(A4)+OBLKNBB,(A6)+OMANBB	CALL	FULLGREYICONE	; (d)grise qq icnes	ADD.W	D3,#ICOBLOC1	; D3 <-- ICOBLOC1..3	JUMP	OBJETNEWZONEZOOM:	LOAD.B	D4,#ICOZOOM	JUMP'	QQDEFORMEZONETOURNE:	LOAD.B	D4,#ICOTOURNE	JUMP'	QQDEFORMEZONEMIROIR:	LOAD.B	D4,#ICOMIROIR	JUMP'	QQDEFORMEZONEDEFORME:	LOAD.B	D4,#ICODEFORME;	JUMP'	QQDEFORMEQQDEFORME:	CALL	INVSELECT	; efface l'ancien tour	LOAD.L	D1,(A6)+OSEPHG	LOAD.L	D2,(A6)+OSEPBD	CALL	ORDONNE	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE INIT0$	INC.W	D2	SWAP.W	D2	INC.W	D2	SWAP.W	D2INIT0$:	CALL	D1D2POIGNEE	; OSEPxx <-- coins	CLR.W	(A6)+OSEANG	CLR.B	(A6)+OSTRHV	LOAD.B	(A6)+OXICO,#NIVDEFORME ; dbut de la dformation	LOAD.B	(A6)+OYICO,D4	COMP.B	D4,#ICOZOOM	JUMP',NE INIT1$	CLR.B	(A6)+OSTRDFINIT1$:	COMP.B	D4,#ICOTOURNE	JUMP',NE INIT2$	CLR.B	(A6)+OSTRDFINIT2$:	COMP.B	D4,#ICOMIROIR	JUMP',NE INIT3$	CLR.B	(A6)+OSTRDFINIT3$:	COMP.B	D4,#ICODEFORME	JUMP',NE INIT4$	LOAD.B	(A6)+OSTRDF,#ICODEFORMEQQINIT4$:	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TPHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	CALL	_COPYZALL	; fait une copie de la matrice	CALL	INIPOIGNEES	; init les 4 poigns	LOAD.B	(A6)+ODDOP,(A6)+OYICO	CALL	INVSELECT	; dessine la slection	LOAD.W	D0,#-1	CALL	INVPOIGNEES	; dessine les 4 poignesLOOP$:	CALL	FULLGREYICONE	; (d)grise qq icnes	COMP.B	(A6)+OYICO,#ICOZOOM	JUMP',EQ LOOP1$	COMP.B	(A6)+OYICO,#ICOTOURNE	JUMP',EQ LOOP1$	LOAD.L	D3,#-1	CALL	DESINFXY	; efface les informations	JUMP'	LOOP2$LOOP1$:	CALL	DESINFDEF	; affiche qq informationsLOOP2$:	CALL	_SCMO		; montre la flche	LOAD.W	D0,#-1	CALL	WAITPRESS	; attend la souris ...	COMP.W	D3,#F0+SHIFT	JUMP',LO MAJ$	COMP.W	D3,#F15+SHIFT	JUMP',HI MAJ$	SUB.W	D3,#SHIFTMAJ$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	LOAD.L	A1,#R16"INVSEL$	CALL	DOKASCENSEUR	; agit dans ascenseurs selon touche	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	; clic-gauche ?	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ MENU$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#F0		; termine ?	JUMP,EQ OK$	COMP.W	D3,#END	JUMP,EQ OK$	COMP.W	D3,#UNDO	; annule ?	JUMP,EQ CANCEL$	LOAD.B	D4,#'1	COMP.W	D3,#F8	JUMP,EQ SCALE$	LOAD.B	D4,#'-	COMP.W	D3,#F7	JUMP,EQ SCALE$	LOAD.B	D4,#'+	COMP.W	D3,#F9	JUMP,EQ SCALE$	LOAD.B	D4,#'T	COMP.W	D3,#F13	JUMP,EQ SCALE$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$MENU$:	CALL	MENUICONE	; menu des icnes de gauche ...	JUMP,NE BIP$	TEST.B	D3	JUMP,EQ LOOP$	JUMP	ICONE$CLIC$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"INVSEL$	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	CALL	MOVICONE	; souris dans une icne ?	JUMP,EQ ICONE$	CALL	DETPOIGNEES	; D0 <-- poigne o est la souris	JUMP,NE BIP$	PUSH.W	D0	LOAD.W	D0,#-1	CALL	INVPOIGNEES	; efface les 4 poignes	POP.W	D0	CALL	INVPOIGNEES	; redessine juste la bonne poigne	CALL	POMPOIGNEE	; D3 <-- position de la poigne	LOAD.L	D2,D3MOVE$:	CALL	_SCMO	CALL	WAITMOVES	; attend dplacement souris ...	JUMP,NE DEFORME$	; fin du dplacement => DEFORME$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE MOVE$	CALL	_RGMOUSE	; dessine la position dans les rgles	LOAD.W	D3,(A6)+OGMLPX	SR.W	D3,#1	ADD.W	D4,D3	SWAP.W	D4	LOAD.W	D3,(A6)+OGMLPY	SR.W	D3,#1	ADD.W	D4,D3	SWAP.W	D4;;?	PUSH.W	(A6)+OGMDIX;;?	PUSH.W	(A6)+OGMDIY;;?	PUSH.W	(A6)+OMALMX;;?	PUSH.W	(A6)+OMALMY;;?	INC.W	(A6)+OGMDIX;;?	INC.W	(A6)+OGMDIY;;?	INC.W	(A6)+OMALMX;;?	INC.W	(A6)+OMALMY	CALL	DETGPOINTOUT	; D3 <-- point o est la souris	CALL	RNDPAS		; D3 <-- arrondi selon le pas;;?	POP.W	(A6)+OMALMY;;?	POP.W	(A6)+OMALMX;;?	POP.W	(A6)+OGMDIY;;?	POP.W	(A6)+OGMDIX	COMP.B	(A6)+OSTRHV,#ICOHORIZ	JUMP',NE MOVEX$	SWAP.W	D2	SWAP.W	D3	LOAD.W	D3,D2		; D3 <-- bloque le dplacement en Y	SWAP.W	D3	SWAP.W	D2MOVEX$:	COMP.B	(A6)+OSTRHV,#ICOVERTI	JUMP',NE MOVEY$	LOAD.W	D3,D2		; D4 <-- bloque le dplacement en XMOVEY$:	COMP.L	D3,D2		; position change ?	JUMP,EQ MOVE$		; non => MOVE$				; oui =>	LOAD.L	D2,D3	CALL	INVPOIGNEES	; efface la poigne	CALL	INVSELECT	; efface la slection	PUSH.L	(A6)+OSEPHG	PUSH.L	(A6)+OSEPHD	PUSH.L	(A6)+OSEPBG	PUSH.L	(A6)+OSEPBD	PUSH.L	(A6)+OSEPMI	PUSH.W	(A6)+OSEANG	CALL	OPERPOIGNEE	; modifie rectangle	CALL	TESTPOIGNEES	; vrifie que rien ne dborde	JUMP',NE MOVEERR$	ADD.L	SP,#(4*5)+2	; SP <-- POPs bidons	JUMP'	MOVEOK$MOVEERR$:	POP.W	(A6)+OSEANG	POP.L	(A6)+OSEPMI	POP.L	(A6)+OSEPBD	POP.L	(A6)+OSEPBG	POP.L	(A6)+OSEPHD	POP.L	(A6)+OSEPHGMOVEOK$:	CALL	SCROLLPOIGNEE	; dplace v. la partie visible	CALL	INVSELECT	; dessine la slection	CALL	INVPOIGNEES	; dessine la poigne	CALL	DESINFDEF	; affiche qq informations	JUMP	MOVE$DEFORME$:	CALL	_WAITMOUSE	; met le sablier	CALL	INVPOIGNEES	; efface la dernire poigne	CALL	MAJREGLE	; met  jour les rgles	CALL	EXDEFORME	; hop, dforme ...	CALL	INVSELECT	; efface la slectionREFAIT$:	CALL	DESGMATRIX	; dessine la grande matrice	CALL	DESPMATRIX	; dessine la petite matrice	CALL	INVSELECT	; redessine la slection	LOAD.W	D0,#-1	CALL	INVPOIGNEES	; redessine les 4 poignes	CALL	_NORMMOUSE	; enlve le sablier	JUMP	LOOP$SCALE$:	CALL	INVSELECT	; efface la slection	LOAD.W	D0,#-1	CALL	INVPOIGNEES	; efface les 4 poignes	CALL	DOSCALE		; change d'chelle	PUSH.W	D7	CALL	INVSELECT	; redessine la slection	LOAD.W	D0,#-1	CALL	INVPOIGNEES	; redessine les 4 poignes	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$ICONE$:	COMP.B	D3,#ICODEFORMETX	JUMP,EQ TYPDEF$	COMP.B	D3,#ICODEFORMETY	JUMP,EQ TYPDEF$	COMP.B	D3,#ICODEFORMEPX	JUMP,EQ TYPDEF$	COMP.B	D3,#ICODEFORMEPY	JUMP,EQ TYPDEF$	COMP.B	D3,#ICODEFORMEQQ	JUMP,EQ TYPDEF$	COMP.B	D3,#ICOTOURNEP	JUMP,EQ SENS$	COMP.B	D3,#ICOTOURNEN	JUMP,EQ SENS$	COMP.B	D3,#ICOHOMOT	JUMP,EQ BLOQUE$	COMP.B	D3,#ICOHORIZ	JUMP,EQ BLOQUE$	COMP.B	D3,#ICOVERTI	JUMP,EQ BLOQUE$	COMP.B	D3,#ICOINIT4	JUMP,EQ INIT$	COMP.B	D3,#ICOINIT0	JUMP,EQ INIT$	COMP.B	D3,#ICODACCORD	JUMP,EQ OK$	COMP.B	D3,#ICOANNULE	JUMP,EQ CANCEL$	COMP.B	D3,#ICOVIDE	JUMP,EQ BIP$	CALL	_WAITMOUSE	; met le sablier	LOAD.W	D0,#-1	CALL	INVPOIGNEES	; efface les 4 poignes	CALL	INVSELECT	; efface la slection	PUSH.L	(A6)+OSEPHG	PUSH.L	(A6)+OSEPHD	PUSH.L	(A6)+OSEPBG	PUSH.L	(A6)+OSEPBD	PUSH.L	(A6)+OSEPMI	PUSH.W	(A6)+OSEANG	CALL	OPERMATRIX	; effectue une opration	CALL	TESTPOIGNEES	; vrifie que rien ne dborde	JUMP',NE OPERERR$	ADD.L	SP,#(4*5)+2	; SP <-- POPs bidons	JUMP'	OPEROK$OPERERR$:	POP.W	(A6)+OSEANG	POP.L	(A6)+OSEPMI	POP.L	(A6)+OSEPBD	POP.L	(A6)+OSEPBG	POP.L	(A6)+OSEPHD	POP.L	(A6)+OSEPHG	CALL	INVSELECT	; redessine la slection	LOAD.W	D0,#-1	CALL	INVPOIGNEES	; redessine les 4 poignes	CALL	_NORMMOUSE	; enlve le sablier	JUMP	BIP$OPEROK$:	CALL	EXDEFORME	; hop, dforme ...	JUMP	REFAIT$BLOQUE$:	COMP.B	D3,(A6)+OSTRHV	JUMP',EQ DEBLOQUE$	PUSH.W	D3	LOAD.B	D3,(A6)+OSTRHV	CALL	INVICONE	; teint l'ancien mode	POP.W	D3	LOAD.B	(A6)+OSTRHV,D3	CALL	INVICONE	; allume le nouveau mode	JUMP	LOOP$DEBLOQUE$:	CALL	INVICONE	CLR.B	(A6)+OSTRHV	JUMP	LOOP$INIT$:	LOAD.W	D0,#-1	CALL	INVPOIGNEES	; efface les 4 poignes	CALL	INVSELECT	; efface la slection	LOAD.L	(A6)+OSEPHG,(A6)+OSEOHG	LOAD.L	(A6)+OSEPHD,(A6)+OSEOHD	LOAD.L	(A6)+OSEPBG,(A6)+OSEOBG	LOAD.L	(A6)+OSEPBD,(A6)+OSEOBD	LOAD.L	(A6)+OSEPMI,(A6)+OSEOMI	CLR.W	(A6)+OSEANG	CALL	EXDEFORME	; hop, dforme ...	JUMP	REFAIT$TYPDEF$:	COMP.B	D3,(A6)+OSTRDF	JUMP,EQ LOOP$	PUSH.W	D3	LOAD.B	D3,(A6)+OSTRDF	CALL	INVICONE	; teint l'ancien mode	POP.W	D3	LOAD.B	(A6)+OSTRDF,D3	CALL	INVICONE	; allume le nouveau mode	JUMP	LOOP$SENS$:	COMP.B	D3,(A6)+OSTRRO	JUMP,EQ LOOP$	PUSH.W	D3	LOAD.B	D3,(A6)+OSTRRO	CALL	INVICONE	; teint l'ancien sens	POP.W	D3	LOAD.B	(A6)+OSTRRO,D3	CALL	INVICONE	; allume le nouveau sens	JUMP	LOOP$OK$:	CALL	INVPOIGNEES	; efface les poignes	CALL	INVSELECT	; efface la slection	JUMP'	EXIT$CANCEL$:	CALL	INVPOIGNEES	; efface les poignes	CALL	INVSELECT	; efface la slection	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	_XFERALL	CALL	DESGMATRIX	; dessine la grande matrice	CALL	DESPMATRIX	; dessine la petite matriceEXIT$:	CLR.B	(A6)+OXICO	; fin de la dformation	CALL	REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; remet les 3 boutons de la souris	JUMP	LOOPINVSEL$:	PUSH.W	D0	LOAD.W	D0,#-1	CALL	INVPOIGNEES	; inverse les 4 poignes	CALL	INVSELECT	; inverse la slection	POP.W	D0	RET;----------\\; EXDEFORME >;----------/; Dforme une zone rectangulaire.; in	-; out	-; mod	D7.WEXDEFORME:	PUSHM.L	D1..D5,A0,A3,A4	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	_XFERALL	; matrice principale <-- matrice copie	LOAD.L	D1,(A6)+OSEOHG	LOAD.L	D2,(A6)+OSEOBD	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice source;	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- position source	LOAD.L	D4,D1		; D4 <-- position destination	LOAD.L	D5,D2		; D5 <-- dimensions	DEC.W	D5	SWAP.W	D5	DEC.W	D5	SWAP.W	D5	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	_XFERZONE	; efface dans matrice principale !	LOAD.L	A0,#(A6)+OSTRETCH	LOAD.W	(A0)+OSTRTYP,#2	; stretch en couleur	CLR.W	(A0)+OSTROP	LOAD.W	D2,(A6)+OMANBP	; D2 <-- nb de bits/pixel	LOAD.W	(A0)+OSTPIXEL,D2	MUL.WU	D2,(A6)+OMANBB	; D2 <-- largeur en bytes	LOAD.L	(A0)+OSTRSPT,(A6)+OPMAM	LOAD.W	(A0)+OSTRSDX,D2	LOAD.L	(A0)+OSTRS0,(A6)+OSEOHG	LOAD.L	(A0)+OSTRS2,(A6)+OSEOBD	LOAD.L	(A0)+OSTRDPT,(A6)+OPMAT	LOAD.W	(A0)+OSTRDDX,D2	LOAD.L	(A0)+OSTRD0,(A6)+OSEPHG	LOAD.L	(A0)+OSTRD1,(A6)+OSEPHD	LOAD.L	(A0)+OSTRD2,(A6)+OSEPBD	LOAD.L	(A0)+OSTRD3,(A6)+OSEPBG	ST_	RECT		; ... et vive Francis+Denis !	POPM.L	D1..D5,A0,A3,A4	RETZONENEGATIF:	CALL	_COPYALL	; fait une copie de la matrice	CALL	INVSELECT	; efface l'ancien tour	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	LOAD.L	A4,(A6)+OPMAM	COMP.B	(A6)+OSELECT,#ICOFILET	JUMP',EQ 10$	CALL	_SETALL		; rempli la matrice-masque de un10$:	LOAD.L	A3,A4		; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- (y;x) source	LOAD.L	D4,D1		; D4 <-- (y;x) destination	LOAD.L	D5,D2		; D5 <-- (dy;dx)	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	_XFERZONE	; inverse zone dans matrice principale	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	JUMP	LOOPZONERELIEF:	LOAD.B	(A6)+OXICO,#NIVRELIEF ; dbut de l'opration	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TPHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	LOAD.L	D3,#-1	CALL	DESINFXY	; efface les informations	CALL	_COPYZALL	; fait une copie de la matrice	CLR.W	(A6)+OPTRELLOOP$:	CALL	FULLGREYICONE	; (d)grise qq icnes	CALL	_SCMO		; montre la flche	CALL	WAITPRESS	; attend la souris ...	COMP.W	D3,#F0+SHIFT	JUMP',LO MAJ$	COMP.W	D3,#F15+SHIFT	JUMP',HI MAJ$	SUB.W	D3,#SHIFTMAJ$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	LOAD.L	A1,#R16"INVSELECT	CALL	DOKASCENSEUR	; agit dans ascenseurs selon touche	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	; clic-gauche ?	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ MENU$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#BS	JUMP,EQ ANNULE$	COMP.W	D3,#DEL	JUMP,EQ ANNULE$	COMP.W	D3,#DELETE	JUMP,EQ ANNULE$	COMP.W	D3,#F0		; termine ?	JUMP,EQ OK$	COMP.W	D3,#END	JUMP,EQ OK$	COMP.W	D3,#UNDO	; annule ?	JUMP,EQ CANCEL$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$MENU$:	CALL	MENUICONE	; menu des icnes de gauche ...	JUMP,NE BIP$	TEST.B	D3	JUMP,EQ LOOP$	JUMP'	ICONE$CLIC$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"INVSELECT	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	CALL	MOVICONE	; souris dans une icne ?	JUMP,NE BIP$ICONE$:	COMP.B	D3,#ICORELIEF1	JUMP',LO ICONE2$	COMP.B	D3,#ICORELIEF8	JUMP,LS RELIEF$ICONE2$:	COMP.B	D3,#ICODRELIEF1	JUMP',LO ICONE3$	COMP.B	D3,#ICODRELIEF8	JUMP,LS MODIF$ICONE3$:	COMP.B	D3,#ICORELANN	JUMP,EQ ANNULE$	COMP.B	D3,#ICOINIT4	JUMP,EQ INIT$	COMP.B	D3,#ICOINIT0	JUMP,EQ INIT$	COMP.B	D3,#ICODACCORD	JUMP,EQ OK$	COMP.B	D3,#ICOANNULE	JUMP,EQ CANCEL$	JUMP	BIP$RELIEF$:	CLR.W	D4	LOAD.B	D4,D3	SUB.B	D4,#ICORELIEF1	; D4 <-- 0..7	LOAD.W	D3,(A6)+OPTREL	COMP.W	D3,#MAXREL	JUMP,HS BIP$	LOAD.L	A3,#(A6)+OBUREL	LOAD.B	(A3)+(D3.W),D4	; OBUREL <-- opration	INC.W	(A6)+OPTREL	LOAD.W	D3,D4		; D3 <-- 1..n	LOAD.L	D1,(A6)+OSEPHG	LOAD.L	D2,(A6)+OSEPBD	CALL	ORDONNE	CALL	RELIEFMATRIX	; moteur ...	CALL	INVSELECT	; teint le rectangle	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	CALL	INVSELECT	; rallume le rectangle	JUMP	LOOP$MODIF$:	LOAD.B	D0,D3	CALL	INVALLICONE	; allume l'icne	CLR.W	D4	LOAD.B	D4,D3	SUB.B	D4,#ICODRELIEF1	; D4 <-- 0..7	LOAD.W	D5,D4	LOAD.L	A3,#(A6)+OOPREL	MUL.WU	D4,#LREL	ADD.L	A3,D4		; A3 <-- ^matrices	LOAD.L	A4,#(A6)+OO1REL	LOAD.L	(A4)+0,(A3)+0	LOAD.L	(A4)+4,(A3)+4	; OO1REL <-- OOPREL	LOAD.L	(A4)+8,(A3)+8	LOAD.L	(A4)+12,(A3)+12	LOAD.W	(A4)+16,(A3)+16	LOAD.L	D1,#H'1000000*GCICF+H'10000*GCICS+H'100*GCICT+ICORELIEF1	LOAD.W	D2,#2^BDBSAV	CALL	_DBOXOPEN1	CALL	_DBOXPOS3	; D3 <-- centre de la dbox	DESS2_	REDIT		; modifie ...	PUSHM.L	D3,D7	CALL	_DBOXCLOSE1	LOAD.B	D3,D0	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,NE LOOP$		; non => LOOP$	LOAD.L	(A3)+0,(A4)+0	LOAD.L	(A3)+4,(A4)+4	; OOPREL <-- OO1REL	LOAD.L	(A3)+8,(A4)+8	LOAD.L	(A3)+12,(A4)+12	LOAD.W	(A3)+16,(A4)+16	LOAD.W	D3,D5	CALL	DESXDEF		; dessine le type de relief	JUMP'	ANNULE1$ANNULE$:	TEST.W	(A6)+OPTREL	JUMP,EQ BIP$	DEC.W	(A6)+OPTRELANNULE1$:	CALL	_WAITMOUSE	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	_XFERALL	; matrice principale <-- matrice copie;	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAM	CALL	_XFERALL	; matrice masque <-- matrice copie	LOAD.L	A3,#(A6)+OBUREL	LOAD.W	D4,(A6)+OPTRELANNULE2$:	DEC.W	D4	JUMP',NS ANNULE4$	CLR.W	D3	LOAD.B	D3,(A3+)	; D3 <-- 1..n	LOAD.L	D1,(A6)+OSEPHG	LOAD.L	D2,(A6)+OSEPBD	CALL	ORDONNE	CALL	RELIEFMATRIX	; moteur ...	JUMP	ANNULE2$ANNULE4$:	CALL	INVSELECT	; teint le rectangle	CALL	DESMATRIX	; dessine les deux matrices	CALL	INVSELECT	; rallume le rectangle	JUMP	LOOP$INIT$:	CLR.W	(A6)+OPTREL	JUMP	ANNULE1$OK$:	CALL	INVSELECT	; efface la slection	JUMP'	EXIT$CANCEL$:	CALL	INVSELECT	; efface la slection	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	_XFERALL	CALL	DESGMATRIX	; dessine la grande matrice	CALL	DESPMATRIX	; dessine la petite matriceEXIT$:	CLR.B	(A6)+OXICO	; fin de la dformation	CALL	REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; remet les 3 boutons de la souris	JUMP	LOOPZONETRAME:	LOAD.B	(A6)+OXICO,#NIVTRAME ; dbut de l'opration	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TPHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	LOAD.L	D3,#-1	CALL	DESINFXY	; efface les informations	CALL	_COPYZALL	; fait une copie de la matrice	JUMP	REFAIT$LOOP$:	CALL	FULLGREYICONE	; (d)grise qq icnes	CALL	_SCMO		; montre la flche	CALL	WAITPRESS	; attend la souris ...	COMP.W	D3,#F0+SHIFT	JUMP',LO MAJ$	COMP.W	D3,#F15+SHIFT	JUMP',HI MAJ$	SUB.W	D3,#SHIFTMAJ$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	LOAD.L	A1,#R16"INVSELECT	CALL	DOKASCENSEUR	; agit dans ascenseurs selon touche	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	; clic-gauche ?	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ MENU$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#F0		; termine ?	JUMP,EQ OK$	COMP.W	D3,#END	JUMP,EQ OK$	COMP.W	D3,#UNDO	; annule ?	JUMP,EQ CANCEL$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$MENU$:	CALL	MENUICONE	; menu des icnes de gauche ...	JUMP,NE BIP$	TEST.B	D3	JUMP,EQ LOOP$	JUMP'	ICONE$CLIC$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"INVSELECT	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	CALL	MOVICONE	; souris dans une icne ?	JUMP,NE BIP$ICONE$:	COMP.B	D3,#ICOTRAPX	JUMP,EQ PASX$	COMP.B	D3,#ICOTRAPM	JUMP,EQ PASM$	COMP.B	D3,#ICOTRAPP	JUMP,EQ PASP$	COMP.B	D3,#ICOTRANX	JUMP,EQ NIVX$	COMP.B	D3,#ICOTRANM	JUMP,EQ NIVM$	COMP.B	D3,#ICOTRANP	JUMP,EQ NIVP$	COMP.B	D3,#ICOTRALX	JUMP,EQ LUMX$	COMP.B	D3,#ICOTRALM	JUMP,EQ LUMM$	COMP.B	D3,#ICOTRALP	JUMP,EQ LUMP$	COMP.B	D3,#ICOTRAF1	JUMP,EQ FAMILLE1$	COMP.B	D3,#ICOTRAF2	JUMP,EQ FAMILLE2$	COMP.B	D3,#ICOTRAF3	JUMP,EQ FAMILLE3$	COMP.B	D3,#ICOTRAM1	JUMP,EQ MODIF1$	COMP.B	D3,#ICOTRAM2	JUMP,EQ MODIF2$	COMP.B	D3,#ICOTRAM3	JUMP,EQ MODIF3$	COMP.B	D3,#ICODACCORD	JUMP,EQ OK$	COMP.B	D3,#ICOANNULE	JUMP,EQ CANCEL$	JUMP	BIP$PASX$:				; pas x =>	LOAD.W	D4,#8	JUMP'	PAS$PASM$:				; pas - =>	LOAD.W	D4,(A6)+OTRAPA	COMP.W	D4,#2	JUMP,EQ BIP$	LOAD.W	D3,#-1	JUMP'	PAST$PASP$:				; pas + =>	LOAD.W	D4,(A6)+OTRAPA	COMP.W	D4,#64	JUMP,EQ BIP$	LOAD.W	D3,#+1PAST$:	LOAD.L	A4,#R16"TAPAS$PAST1$:	COMP.B	D4,(A4+)	JUMP,NE PAST1$	LOAD.B	D4,(A4)+(D3.W)-1PAS$:	COMP.W	D4,(A6)+OTRAPA	; pas chang ?	JUMP,EQ BIP$	LOAD.W	(A6)+OTRAPA,D4	CALL	DESTRAP		; dessine le pas	JUMP	REFAIT$TAPAS$:	.B	2,3,4,5,6,7,8,10,12,16,24,32,48,64	.EVENNIVX$:				; niveau x =>	LOAD.W	D4,#8	JUMP'	NIV$NIVM$:				; niveau - =>	LOAD.W	D4,(A6)+OTRANI	COMP.W	D4,#2	JUMP,EQ BIP$	SR.W	D4,#1	JUMP'	NIV$NIVP$:				; niveau + =>	LOAD.W	D4,(A6)+OTRANI	COMP.W	D4,#16	JUMP,EQ BIP$	SL.W	D4,#1;	JUMP'	NIV$NIV$:	COMP.W	D4,(A6)+OTRANI	; niveau chang ?	JUMP,EQ BIP$	LOAD.W	(A6)+OTRANI,D4	CALL	DESTRAN		; dessine le niveau	JUMP	REFAIT$LUMX$:				; luminosit x =>	CLR.W	D4	JUMP'	LUM$LUMM$:				; luminosit - =>	LOAD.W	D4,(A6)+OTRALU	COMP.W	D4,#-8	JUMP,EQ BIP$	DEC.W	D4	JUMP'	LUM$LUMP$:				; luminosit + =>	LOAD.W	D4,(A6)+OTRALU	COMP.W	D4,#+8	JUMP,EQ BIP$	INC.W	D4;	JUMP'	LUM$LUM$:	COMP.W	D4,(A6)+OTRALU	; luminosit change ?	JUMP,EQ BIP$	LOAD.W	(A6)+OTRALU,D4	CALL	DESTRAL		; dessine la luminosit;	JUMP	REFAIT$REFAIT$:	CALL	OPTRAME		; moteur ...	CALL	INVSELECT	; teint le rectangle	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	CALL	INVSELECT	; rallume le rectangle	JUMP	LOOP$FAMILLE1$:	CLR.W	D4	JUMP'	FAMILLE$FAMILLE2$:	LOAD.W	D4,#1	JUMP'	FAMILLE$FAMILLE3$:	LOAD.W	D4,#2FAMILLE$:	COMP.W	D4,(A6)+OTRAFA	; famille change ?	JUMP,EQ BIP$	LOAD.W	D3,(A6)+OTRAFA	ADD.W	D3,#ICOTRAF1	CALL	INVICONE	; teint la famille de trames	LOAD.W	(A6)+OTRAFA,D4	LOAD.W	D3,D4	ADD.W	D3,#ICOTRAF1	CALL	INVICONE	; allume la famille de trames	JUMP	REFAIT$MODIF1$:	LOAD.W	D3,(A6)+OTRAFA	ADD.W	D3,#ICOTRAF1	CALL	INVICONE	; teint la famille de trames	CLR.W	D3	LOAD.W	(A6)+OTRAFA,D3	ADD.W	D3,#ICOTRAF1	CALL	INVICONE	; allume la famille de trames	CALL	_DBOXTTDEF	; modifie les trames ...	JUMP,NE BIP$	JUMP	REFAIT$MODIF2$:	LOAD.W	D3,(A6)+OTRAFA	ADD.W	D3,#ICOTRAF1	CALL	INVICONE	; teint la famille de trames	LOAD.W	D3,#1	LOAD.W	(A6)+OTRAFA,D3	ADD.W	D3,#ICOTRAF1	CALL	INVICONE	; allume la famille de trames	CALL	_DBOXTTDEF	; modifie les trames ...	JUMP,NE BIP$	JUMP	REFAIT$MODIF3$:	LOAD.W	D3,(A6)+OTRAFA	ADD.W	D3,#ICOTRAF1	CALL	INVICONE	; teint la famille de trames	LOAD.W	D3,#2	LOAD.W	(A6)+OTRAFA,D3	ADD.W	D3,#ICOTRAF1	CALL	INVICONE	; allume la famille de trames	CALL	_DBOXTTDEF	; modifie les trames ...	JUMP,NE BIP$	JUMP	REFAIT$OK$:	CALL	INVSELECT	; efface la slection	JUMP'	EXIT$CANCEL$:	CALL	INVSELECT	; efface la slection	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	_XFERALL	CALL	DESGMATRIX	; dessine la grande matrice	CALL	DESPMATRIX	; dessine la petite matriceEXIT$:	CLR.B	(A6)+OXICO	; fin du tramage	CALL	REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; remet les 3 boutons de la souris	JUMP	LOOPZONELISSE:	CLR.W	(A6)+OLISPA	CLR.W	(A6)+OLISLU	LOAD.B	(A6)+OXICO,#NIVLISSE ; dbut de l'opration	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TPHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	LOAD.L	D3,#-1	CALL	DESINFXY	; efface les informations	CALL	_COPYZALL	; fait une copie de la matriceLOOP$:	CALL	FULLGREYICONE	; (d)grise qq icnes	CALL	_SCMO		; montre la flche	CALL	WAITPRESS	; attend la souris ...	COMP.W	D3,#F0+SHIFT	JUMP',LO MAJ$	COMP.W	D3,#F15+SHIFT	JUMP',HI MAJ$	SUB.W	D3,#SHIFTMAJ$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	LOAD.L	A1,#R16"INVSELECT	CALL	DOKASCENSEUR	; agit dans ascenseurs selon touche	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	; clic-gauche ?	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ MENU$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#F0		; termine ?	JUMP,EQ OK$	COMP.W	D3,#END	JUMP,EQ OK$	COMP.W	D3,#UNDO	; annule ?	JUMP,EQ CANCEL$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$MENU$:	CALL	MENUICONE	; menu des icnes de gauche ...	JUMP,NE BIP$	TEST.B	D3	JUMP,EQ LOOP$	JUMP'	ICONE$CLIC$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"INVSELECT	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	CALL	MOVICONE	; souris dans une icne ?	JUMP,NE BIP$ICONE$:	LOAD.W	D4,#2	COMP.B	D3,#ICOLISSE2	JUMP',EQ REFAIT$	LOAD.W	D4,#4	COMP.B	D3,#ICOLISSE4	JUMP',EQ REFAIT$	LOAD.W	D4,#6	COMP.B	D3,#ICOLISSE6	JUMP',EQ REFAIT$	LOAD.W	D4,#8	COMP.B	D3,#ICOLISSE8	JUMP',EQ REFAIT$	LOAD.W	D4,#-1	COMP.B	D3,#ICOLISSEF	JUMP',EQ LUM$	CLR.W	D4	COMP.B	D3,#ICOLISSEM	JUMP',EQ LUM$	LOAD.W	D4,#+1	COMP.B	D3,#ICOLISSEC	JUMP',EQ LUM$	COMP.B	D3,#ICODACCORD	JUMP,EQ OK$	COMP.B	D3,#ICOANNULE	JUMP,EQ CANCEL$	JUMP	BIP$REFAIT$:	LOAD.W	(A6)+OLISPA,D4	CALL	FULLGREYICONE	; (d)grise qq icnesREFAIT2$:	CALL	OPLISSE		; moteur ...	CALL	INVSELECT	; teint le rectangle	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	CALL	INVSELECT	; rallume le rectangle	JUMP	LOOP$LUM$:	COMP.W	D4,(A6)+OLISLU	; luminosit change ?	JUMP,EQ BIP$		; non => BIP$	LOAD.W	D3,(A6)+OLISLU	ADD.W	D3,#ICOLISSEM	CALL	INVICONE	; teint la luminosit	LOAD.W	(A6)+OLISLU,D4	LOAD.W	D3,D4	ADD.W	D3,#ICOLISSEM	CALL	INVICONE	; allume la luminosit	TEST.W	(A6)+OLISPA	JUMP,NE	REFAIT2$	JUMP	LOOP$OK$:	CALL	INVSELECT	; efface la slection	JUMP'	EXIT$CANCEL$:	CALL	INVSELECT	; efface la slection	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	_XFERALL	CALL	DESGMATRIX	; dessine la grande matrice	CALL	DESPMATRIX	; dessine la petite matriceEXIT$:	CLR.B	(A6)+OXICO	; fin du lissage	CALL	REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; remet les 3 boutons de la souris	JUMP	LOOPZONELOUPE:	CALL	INVSELECT	; efface l'ancien tour	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	CLR.L	D3	LOAD.W	D3,(A6)+OGRDIX	DIV.WU	D3,D2	SWAP.W	D2	CLR.L	D4	LOAD.W	D4,(A6)+OGRDIY	DIV.WU	D4,D2	SWAP.W	D2	COMP.W	D4,D3	JUMP',LS 30$	LOAD.W	D4,D330$:	COMP.W	D4,#SCALE11	JUMP',GE 40$	LOAD.W	D4,#SCALE1140$:	LOAD.L	(A6)+OPMOVY,D1	LOAD.L	(A6)+OPMDIY,D2	CALL	CALSCALE	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	JUMP	LOOPZONESAUVE:	CALL	INVSELECT	; efface l'ancien tour	PUSH.B	(A6)+OMAJ	CALL	_COPYZALL	; fait une copie de la matrice	POP.B	(A6)+OMAJ	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	JUMP	SAUVERECT	; disque <-- contenu de la zone;-----------\\; D1D2SCALEN >;===========/; Tient compte de la fonction tout pour dlimiter une modification.; in	D1.L	(y;x);	D2.L	(y;x); out	D1.L	(y;x) plus grand;	D2.L	(y;x) plus grand; mod	D1.L, D2.LD1D2SCALEN:	EX.L	D1,D2	CALL	D1SCALEN	; D2 <-- agrandi si "tout"	EX.L	D2,D1;	CALL	D1SCALEN	; D1 <-- agrandi si "tout";	RET;---------\\; D1SCALEN >;---------/; Tient compte de la fonction tout pour dlimiter une modification.; in	D1.L	(y;x); out	D1.L	(y;x) plus grand; mod	D1.LD1SCALEN:	PUSHM.L	D2,D3	LOAD.W	D2,(A6)+OSCALE	; chelle ngative (tout) ?	JUMP',NC 90$		; non => 90$				; oui =>	NEG.W	D2		; D2 <-- |chelle|	LOAD.W	D3,D1	MUL.WU	D3,D2	LOAD.W	D1,D3		; D1 <-- x	SWAP.W	D1	LOAD.W	D3,D1	MUL.WU	D3,D2	LOAD.W	D1,D3		; D1 <-- y	SWAP.W	D190$:	POPM.L	D2,D3	RET;-----------\\; D1D2SCALEP >;===========/; Tient compte de la fonction tout pour dlimiter une modification.; in	D1.L	(y;x);	D2.L	(y;x); out	D1.L	(y;x) plus petit;	D2.L	(y;x) plus petit; mod	D1.L, D2.LD1D2SCALEP:	EX.L	D1,D2	CALL	D1SCALEP	; D2 <-- agrandi si "tout"	EX.L	D2,D1;	CALL	D1SCALEP	; D1 <-- agrandi si "tout";	RET;---------\\; D1SCALEP >;---------/; Tient compte de la fonction tout pour dlimiter une modification.; in	D1.L	(y;x); out	D1.L	(y;x) plus petit; mod	D1.LD1SCALEP:	PUSHM.L	D2,D3	LOAD.W	D2,(A6)+OSCALE	; chelle ngative (tout) ?	JUMP',NC 90$		; non => 90$				; oui =>	NEG.W	D2		; D2 <-- |chelle|	CLR.L	D3	LOAD.W	D3,D1	DIV.WU	D3,D2	LOAD.W	D1,D3		; D1 <-- x	SWAP.W	D1	CLR.L	D3	LOAD.W	D3,D1	DIV.WU	D3,D2	LOAD.W	D1,D3		; D1 <-- y	SWAP.W	D190$:	POPM.L	D2,D3	RET;----------\\; WAITPRESS >;----------/; Attend une pression d'une touche ou d'un bouton.; in	-; out	D3.L	touche presse; mod	D3.L, D7.WWAITPRESS:	PUSH.L	D410$:	LIB	?GETKEY		; attend souris ...	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP,BS 10$		; non => 10$	COMP.W	D3,#KEYMPO	; dplacement ?	JUMP',NE 90$		; non => 90$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 10$	CALL	_RGMOUSE	; dessine la position dans les rgles	JUMP	10$90$:	POP.L	D4	RET;----------\\; WAITMOVES >;----------/; Attend les dplacements de la souris, mme si elle ne bouge pas.; in	-; out	D3.L	touche presse;	D7.W	EQ si souris dplace; mod	D3.L, D7.WWAITMOVES:	PUSH.L	D4	CLR.W	D4	NTREL	?SETTIM		; met timeout nul (trs trs court)	CALL	WAITMOVE	; attend dplacement souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; WAITMOVE >;---------/; Attend un dplacement de la souris.; in	-; out	D3.L	touche presse;	D7.W	EQ si souris dplace; mod	D3.L, D7.WWAITMOVE:10$:	LIB	?GETKEY		; attend souris ...	JUMP',NE 20$		; si timeout => 20$	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP',BC 30$		; oui => 30$	JUMP	10$20$:	LOAD.W	D3,#KEYMPO	; D3 <-- dplacement	CLR.W	D7		; D7 <-- souris bouge	JUMP'	90$30$:	LOAD.W	D7,#1		; D7 <-- fin du dplacement	COMP.W	D3,#KEYMGP	JUMP',EQ 90$	COMP.W	D3,#KEYMMP	JUMP',EQ 90$	COMP.W	D3,#KEYMDP	JUMP',EQ 90$	COMP.W	D3,#KEYMGR	JUMP',EQ 90$	COMP.W	D3,#KEYMMR	JUMP',EQ 90$	COMP.W	D3,#KEYMDR	JUMP',EQ 90$	CLR.W	D7		; D7 <-- souris bouge90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; FIXPAS  >;--------/; Fixe la position pour RNDPAS.; in	D3.L	position (y;x); out	-; mod	D7.WFIXPAS:	PUSHM.L	D3,D4	LOAD.L	D4,D3	CALL	PASGPOINT	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3;	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+ORNDPA,D4	POPM.L	D3,D4	RET;--------\\; RNDPAS  >;--------/; Arrondi la position selon FIXPAS.; in	D3.L	position (y;x); out	D3.L	position (y;x); mod	D3.LRNDPAS:	SUB.W	D3,(A6)+ORNDPA+2	SWAP.W	D3	SUB.W	D3,(A6)+ORNDPA+0	SWAP.W	D3	CALL	PASGPOINT	ADD.W	D3,(A6)+ORNDPA+2	SWAP.W	D3	ADD.W	D3,(A6)+ORNDPA+0	SWAP.W	D3	RET	.END