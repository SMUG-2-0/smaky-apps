	.SBTTL	TEXTINIT; in	A3.L	^dbut ligne de commandeSTART:	LIB	?OPELIB		; ouvre la librairie ...	LOAD.W	D3,#3		; D3 <-- souris par le clavier + sablier manuel	LIB	?MOUSE		; souris par le clavier; Demande la mmoire pour les variables et met-les toutes;  zro pour conomiser des tonnes de CLR.W (A6)+machin.	LOAD.L	D4,#LGVAR	; D4 <-- longueur ncessaire	LOAD.W	D1,#MTYPCP	; D1 <-- pour processus courant	GESMEM	?GETMEM		; demande mmoire pour var	JUMP,NE ERFAT1		; plein => erreur fatale	LOAD.L	A6,A4		; A6 <-- ^variables (TOUJOURS)01$:	CLR.B	(A4+)		; rempli TOUTES les variables	DEC.W	D4		; avec des zro !	JUMP,NE	01$	CALL	SWMO		; souris: met le sablier; Initialises les variables les plus importantes.	LOAD.L	A4,#R16"START	LOAD.L	(A6)+OSTART,A4	; mm. adr. de dbut du code	LOAD.L	(A6)+OSTACK,SP	; mm. valeur initiale du stack	LOAD.L	(A6)+OPTCOM,A3	; mm. ^dbut ligne de commande	LOAD.B	(A6)+OSEAMOD,#2^BSEAMIMA!2^BSEAAV	LOAD.W	(A6)+OJUPAL,#DJUPAL	LOAD.W	(A6)+OJUPTR,#DJUPTR	LOAD.W	(A6)+OJUPNL,#DJUPNL	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*5+1	; au moins rvision 5.1 ?	JUMP,LO ERFAT2		; non => ERFAT2	CALL	INILICOM	; init selon ligne de commande	LOAD.L	D4,#2^BFAREG!2^BFAIMA!2^BFAEOL!2^BFABIG!2^BFATAB!2^BFAENG!2^BFANUC	TEST.B	(A6)+OFLAGS:#BEPRO ; dition de programmes ?	JUMP',BC 05$		; non => 05$	LOAD.L	D4,#2^BFAREG!2^BFAIMA05$:	LOAD.L	(A6)+OFANION,D4	LOAD.L	A3,#(A6)+ODFNUM	LOAD.B	(A3+),#'-	LOAD.B	(A3+),#SPACE	LOAD.B	(A3+),#'1	; met "- 1 -" pour numroter les pages	LOAD.B	(A3+),#SPACE	LOAD.B	(A3+),#'-	LOAD.L	A3,#(A6)+ODFNGC	LOAD.B	(A3+),#'F	LOAD.B	(A3+),#'o	; numrote avec "Fond"	LOAD.B	(A3+),#'n	LOAD.B	(A3+),#'d; Initialise les variables en fonction de l'imprimante.	LOAD.L	A3,#R16"NAMPRIN	LOAD.W	D3,#PRINTA_FIRST	LIB_	OPEN	JUMP',NE 10$	LOAD.W	(A6)+OCHPRIN,D1	CLR.L	D3	PRINTA_	OPEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OCAPRINT,A210$:	LOAD.L	A3,#R16"TXERFATPRI	CALL	_STPRINT	; lit le status de l'imprimante	COMP.W	D7,#1	JUMP,NE ERFAT2; Initialise la fentre dans le bon mode.	LIB	?AFTIM	.B	NOROLL		; pas de roll dans la fentre	.B	TRUNC		; tronque lignes trop longues	.B	NOEFLI		; efface pas la fin des lignes	.B	GCURS		; grand curseur si questions	.B	NOCURS		; pas de curseur normalement	.B	0	.EVEN	LOAD.L	A3,#R16"TXERFATTXT	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT ; charge le gencar du texte	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATICO	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT ; charge le gencar des icnes	.B	0	.EVEN	JUMP,NE	ERFAT2; Initialise les variables en fonctions des dimensions de la; fentre et des caractres.	LOAD.L	A3,#R16"TXERFATDIS	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	(A6)+OCHDIS,D6	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+ODISPS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT2	LOAD.L	A4,(A6)+ODISPS	; A4 <-- ^status fentre	LOAD.L	A2,(A4)+ODFPGC	; A2 <-- ^dbut GENCAR	LOAD.L	A2,#(A2)+OGCWID	; A2 <-- ^table des largeurs	CLR.W	D4	LOAD.B	D4,(A2)+SPACE	; D4 <-- largeur d'un SPACE	LOAD.W	(A6)+OCX,D4	LOAD.W	(A6)+OC1X,(A4)+ODFC1X	LOAD.W	(A6)+OCY,(A4)+ODFCY	LOAD.W	(A6)+OC1Y,(A4)+ODFC1Y	LOAD.W	(A6)+OC2Y,(A4)+ODFC2Y	LOAD.W	(A6)+OCYR,#GCICY	LOAD.W	(A6)+OCYI,(A6)+OCY; Cre les sous-fentres pour les informations et pour le texte.	LOAD.W	D4,(A4)+ODFFDY	SUB.W	D4,(A6)+OCYI	; D4 <-- hauteur totale sans les infos	LOAD.W	D2,D4	SR.W	D2,#2	LOAD.W	D4,D2	ADD.W	D4,D2	ADD.W	D4,D2		; D4 <-- 3/4 hauteur	TCLR.L	D4:#0		; D4 <-- doit tre pair !	LOAD.W	(A6)+OYWDP,D4	CALL	CREWDOS		; cre toutes les swdos; Charge et initialise le caractre propre  l'imprimante DRF07.	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#PFIXGC	LOAD.L	(A3)+1,(A6)+OSTPRI+OPRNAM ; nom de l'imprimante	LOAD.W	D3,#5	LIB	?STRING		; donne le prfix pour les fontes "D" et "Q"	LOAD.L	A3,#R16"TXERFATGCP	LIB	?AFTIM	.B	LOADGC,GCPRF,GCPRS,GCPRT ; charge le gencar de l'imprimante	.B	0	.EVEN	JUMP,NE	ERFAT2	LIB	?AFTIM	.B	USEGC,GCPRF,GCPRS,GCPRT ; utilise le gencar de l'imprimante	.B	0	.EVEN	LOAD.W	(A6)+ODRFX,(A4)+ODFCX	LOAD.W	(A6)+ODRF1Y,(A4)+ODFC1Y	LOAD.W	(A6)+ODRF2Y,(A4)+ODFC2Y	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT ; utilise le gencar du texte	.B	0	.EVEN	CALL	_AJPRINT	; ajustement subtile !; Initialise le gencar du texte par dfaut.40$:	LOAD.L	A3,#R16"NAMDGEN	LOAD.W	D3,#DGENC_FIRST	LIB_	OPEN		; ouvre le module DGENC	JUMP,NE	ERFAT2	LOAD.W	(A6)+OCHDGEN,D1	LOAD.L	A4,#(A6)+OBUGC	TSET.B	(A4)+OGCFLG:#BGCPROT	LOAD.B	(A4)+OGCF,#'U!2^7 ; utilise URP09 par dfaut !	LOAD.B	(A4)+OGCS,#0	LOAD.B	(A4)+OGCT,#09	TEST.B	(A6)+OFLAGS:#BEPRO ; dition de programmes ?	JUMP',BC 50$		; non => 50$	LOAD.B	(A4)+OGCF,#GCTXF	LOAD.B	(A4)+OGCS,#GCTXS	LOAD.B	(A4)+OGCT,#GCTXT50$:	LOAD.L	A3,#(A4)+OGCTIT	LOAD.B	(A3+),#'F	LOAD.B	(A3+),#'o	LOAD.B	(A3+),#'n	LOAD.B	(A3+),#'d	LOAD.L	(A4)+OGCMAP,#-1	; utilis par tous les buffers	CALL	LODGC	LOAD.L	A3,#R16"TXERFATTYPO	JUMP,NE	ERFAT2	TEST.B	(A6)+OFLAGS:#BEPRO ; dition de programmes ?	JUMP',BS 55$		; oui => 55$	LOAD.L	A4,#(A6)+OBUGC+LGGC	LOAD.B	(A4)+OGCF,#'U!2^7	LOAD.B	(A4)+OGCS,#2^BGCBOLD	LOAD.B	(A4)+OGCT,#09	LOAD.L	A3,#(A4)+OGCTIT	LOAD.B	(A3+),#'E	LOAD.B	(A3+),#'v	LOAD.B	(A3+),#'i	LOAD.B	(A3+),#'d	LOAD.B	(A3+),#'e	LOAD.B	(A3+),#'n	LOAD.B	(A3+),#'c	LOAD.B	(A3+),#'e	LOAD.L	(A4)+OGCMAP,#1	; utilis par le buffer principal	CALL	LODGC; Demande les adresses des routines graphiques rapides.55$:	LOAD.L	A0,#R16"TXERFATGRA	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE	ERFAT3	LOAD.L	(A6)+OADRAST,A3	LOAD.W	D3,#GRA_MATRIX	LIB_	GETAD	LOAD.L	(A6)+OADMATR,A3	LOAD.W	D3,#GRA_TRAME	LIB_	GETAD	LOAD.L	(A6)+OADTRAM,A3	LOAD.W	D3,#GRA_ROLLUP	LIB_	GETAD	LOAD.L	(A6)+OADROLU,A3	LOAD.W	D3,#GRA_ROLLDOWN	LIB_	GETAD	LOAD.L	(A6)+OADROLD,A3	LOAD.W	D3,#GRA_CLEAR	LIB_	GETAD	LOAD.L	(A6)+OADCLEA,A3	LOAD.W	D3,#GRA_CIRCLE	LIB_	GETAD	LOAD.L	(A6)+OADCIRC,A3	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	LOAD.L	(A6)+OADLINE,A3	LOAD.W	D3,#GRA_DOT	LIB_	GETAD	LOAD.L	(A6)+OADDOT,A3	LOAD.W	D3,#GRA_EFLI	LIB_	GETAD	LOAD.L	(A6)+OADEFLI,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	JUMP,NE	ERFAT3	LOAD.L	(A6)+OADINV,A3; Demande la mmoire pour les buffers de textes.	LOAD.W	(A6)+OSRCBUF,#SRCBUF	LOAD.W	(A6)+OMACBUF,#MACBUF	LOAD.L	A3,(A6)+OPTCOM	; A3 <-- ^ligne de commande	LOAD.W	D3,#MPDIV*2/5	; prend les 2/5 de la mmoire	LOAD.L	D4,#10		; D4 <-- longueur minimum	LOAD.L	D5,#-1		; D5 <-- pas de maximum	LOAD.W	D1,#MTYPCP	; D1 <-- processus courant	LIB	?GTRSMM		; cherche rservation mmoire	LOAD.L	A3,#R16"TXERFATMEM	JUMP,NE	ERFAT2		; si erreur => fatal	LOAD.L	D0,A4		; D0 <-- ^dbut	LOAD.L	D1,D4		; D1 <-- longueur	ADD.L	D1,D0		; D1 <-- ^fin	CALL	_INIBUF		; vide tous les buffers	CALL	_FLUSH		; vide tout; Donne une bonne allure  la fentre pour faire croire que; c'est termin.	CALL	AFFPROV		; affiche les informations provisoires	CALL	AFMENU		; met soft-keys standards	TEST.B	(A6)+OFLAGS:#BEPRO ; dition de programmes ?	JUMP',BS 60$		; oui => 60$	CALL	INSREGLE	; met toujours une rgle au dbut !				; (elle n'est pas affiche pendant le				; chargement des modules)	LOAD.W	D3,#TEOL	CALL	_INSERT		; met juste une fin de ligne	CALL	_RECULE		; puis recule avant !; Charge les modules LIB utiliss aprs avoir donn une bonne; allure  l'cran pour faire croire avant l'heure que le; chargement est termin !60$:	LOAD.L	A3,#R16"NAMSCRO	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN		; ouvre le module SCROLL	JUMP,NE	ERFAT2	LOAD.W	(A6)+OCHSCRO,D1	CALL	AFFDEROULEUR	; affiche le drouleur	LOAD.L	A3,#R16"NAMDBOX	LOAD.W	D3,#DBOX_OPEN	LIB_	OPEN		; ouvre le module DBOX	JUMP,NE	ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NAMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN		; ouvre le module LIST	JUMP,NE	ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NAMCOUP	LOAD.W	D3,#COUPE_FIRST	LIB_	OPEN		; ouvre le module COUPE	JUMP,NE	ERFAT2	LOAD.W	(A6)+OCHCOUP,D1	LOAD.L	A3,#R16"NAMMATH	LOAD.W	D3,#MATH64_FIRST	LIB_	OPEN		; ouvre le module MATH64	JUMP,NE	ERFAT2	LOAD.W	(A6)+OCHMATH,D1	PUSH.L	A5	CLR.L	D0		; D0 <-- mode par dfaut	MATH64_	OPEN	LOAD.L	A4,A5		; A4 <-- canal	POP.L	A5	JUMP,NE ERFAT2	LOAD.L	(A6)+OCHMATI,A4	LOAD.W	(A6)+OCHFICH,#-1; Lit un texte s'il a t donn dans la ligne de commande.	LOAD.L	A3,(A6)+OPTCOM	; A3 <-- ^ligne de commande80$:	LIB	?SKPNAM		; A3 <-- cherche nom suivant	JUMP',NE 82$		; si rien => 82$	LIB	?SWITCH		; D3 <-- cherche le(s) switch(s)	JUMP,NE	80$		; erreur => 80$	TEST.L	D3		; switch(s) existe(nt) ?	JUMP,NE	80$		; oui => 80$				; non =>	CALL	_FINPUT		; lit un texte ...	JUMP	MAIN82$:	CALL	_TINPUT		; lit TEXT.TEXT ...	JUMP	MAIN;---------\\; INILICOM >;---------/; Initialise les variables en fonction de la ligne de commande.; in	-; out	-; mod	toutINILICOM:; Cherche un ".../i" dans la ligne de commande.	LOAD.L	A3,(A6)+OPTCOM	; A3 <-- ^dbut ligne de commande10$:	LIB	?SKPNAM	JUMP',NE 20$	LOAD.B	D3,#'I		; D3 <-- cherche .../i	LIB	?IFSWITCH	JUMP,NE 10$	JUMP'	50$; Cherche un "file.ext" dans la ligne de commande.20$:	LOAD.L	A3,(A6)+OPTCOM	; A3 <-- ^dbut ligne de commande22$:	LIB	?SKPNAM	JUMP',NE 30$	LIB	?SWITCH		; D3 <-- cherche le(s) switch(s)	JUMP,NE	22$		; erreur => 22$	TEST.L	D3		; switch(s) existe(nt) ?	JUMP,NE	22$		; oui => 22$; Cherche si le nom du fichier contient un "."	LOAD.L	A4,A325$:	LOAD.B	D3,(A4+)	JUMP',EQ 30$	COMP.B	D3,#CR	JUMP',EQ 30$	COMP.B	D3,#SPACE	JUMP',EQ 30$	COMP.B	D3,#'/	JUMP',EQ 30$	COMP.B	D3,#'.	JUMP,NE 25$	LOAD.L	A3,A4		; A3 <-- ^extension du fichier	JUMP'	50$; Si rien trouv dans la ligne de commande, met ".text" par dfaut.30$:	LOAD.L	A3,#R16"TXTEXT	; A3 <-- ^extension ".text" par dfaut; Transfert l'extension dans OBUEXT en mettant toujours un "." au dbut.50$:	LOAD.L	A4,#(A6)+OBUEXT	COMP.B	(A3),#'.	; extension commence par "." ?	JUMP',EQ 55$		; oui => 55$	LOAD.B	(A4+),#'.	; non => met toujours un "."55$:	LOAD.B	D3,(A3+)	JUMP',EQ 60$	COMP.B	D3,#CR	JUMP',EQ 60$	COMP.B	D3,#SPACE	JUMP',EQ 60$	COMP.B	D3,#'/	JUMP',EQ 60$	CALL	MAJMIN		; D3 <-- lettre minuscule	LOAD.B	(A4+),D3	; OBUEXT <-- extension par dfaut	JUMP	55$60$:	CLR.B	(A4); Met le flag BEPRO  un si l'extension n'est pas ".text".	LOAD.L	A3,#(A6)+OBUEXT	; A3 <-- ^extension choisie	LOAD.L	A4,#R16"TXTEXT	; A4 <-- ^extension ".text"	LOAD.L	A2,#R16"LSTERM	; A2 <-- ^liste de terminateurs	LIB	?CPSTRING	; utilise ".text" ?	JUMP',EQ 90$		; oui => 90$	TSET.B	(A6)+OFLAGS:#BEPRO ; non => dition de programmes90$:	RET;--------\\; CREWDOS >;========/; Cre toutes les swdo ncessaires pour les zones de textes et; les informations.; in	(A6)+OYWDP.W	hauteur swdo zone principale; out	(A6)+ODWDT.L	dimensions swdo texte;	     OYWDT.W	hauteur;	     OXWDT.W	largeur; mod	D7.WCREWDOS:	PUSHM.L	D1..D5,A4	LOAD.L	A4,(A6)+ODISPS	; A4 <-- ^status fentre	LOAD.W	(A6)+OXWDD,#LGSCROLL ; init largeur du drouleur	CLR.W	D1	TEST.B	(A6)+OFANION+2:#BFASCH ; ascenseur horizontal ?	JUMP',BC 10$	LOAD.W	D1,#LGSCROLL	; D1 <-- hauteur pour l'ascenseur10$:	CLR.L	D3		; D3 <-- y,x	LOAD.W	D4,(A6)+OCYI	; D4 <-- dy	SWAP.W	D4	LOAD.W	D4,(A4)+ODFFDX	; D4 <-- dx	LIB	?CREWDO		; cre swdo informations (zone principale)	LOAD.W	(A6)+ONOWDI,D5	LOAD.W	D3,(A6)+OCYI	; D3 <-- y	LOAD.W	D4,(A4)+ODFFDY	SUB.W	D4,D3	SUB.W	D4,D1		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OXWDD	; D3 <-- x	LOAD.W	D4,(A4)+ODFFDX	SUB.W	D4,D3		; D4 <-- dx	LOAD.L	(A6)+ODWDT,D4	LIB	?CREWDO		; cre swdo texte (zone principale unique)	LOAD.W	(A6)+ONOWDT,D5	SWAP.W	D4	LOAD.W	D4,(A6)+OYWDP	; D4 <-- hauteur zone principale	SWAP.W	D4	LIB	?CREWDO		; cre swdo texte (zone principale)	LOAD.W	(A6)+ONOWDP,D5	LOAD.W	D2,(A6)+OXWDD	; D2 <-- largeur du drouleur	SUB.W	D3,D2	ADD.W	D4,D2	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	LOAD.W	D4,(A6)+OCY	SWAP.W	D4	SWAP.W	D3	LIB	?CREWDO		; cre swdo informations (zone secondaire)	LOAD.W	(A6)+ONOWDJ,D5	ADD.W	D3,D2	SUB.W	D4,D2	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	LOAD.W	D4,(A4)+ODFFDY	SUB.W	D4,D3	SUB.W	D4,D1	SWAP.W	D4	SWAP.W	D3	LIB	?CREWDO		; cre swdo texte (zone secondaire)	LOAD.W	(A6)+ONOWDS,D5	LOAD.W	D4,(A6)+OXWDT	LOAD.W	D3,(A6)+OCX	SL.W	D3,#2		; D3 <-- 4*OCX	SUB.W	D4,D3	LOAD.W	(A6)+OMWDT,D4	; init largeur maximale pour le texte	CALL	ALLSCREEN	; faudra tout repeindre	POPM.L	D1..D5,A4	RET;--------\\; KILWDOS >;========/; Dtruit toutes les swdos.; in	-; out	-; mod	D7.WKILWDOS:	PUSH.W	D5	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.W	D5,(A6)+ONOWDI	LIB	?KILWDO	LOAD.W	D5,(A6)+ONOWDT	LIB	?KILWDO	LOAD.W	D5,(A6)+ONOWDP	LIB	?KILWDO	LOAD.W	D5,(A6)+ONOWDJ	LIB	?KILWDO	LOAD.W	D5,(A6)+ONOWDS	LIB	?KILWDO	POP.W	D5	RET; Noms des modules; ----------------NAMDBOX:.ASCIZ	"DBOX"		; nom du module LIBNAMLIST:.ASCIZ	"LIST"		; nom du module LIBNAMCOUP:.ASCIZ	"COUPE"		; nom du module LIBNAMSCRO:.ASCIZ	"SCROLL"	; nom du module LIBNAMDGEN:.ASCIZ	"DGENC"		; nom du module LIBNAMMATH:.ASCIZ	"MATH64"	; nom du module LIBNAMPRIN:.ASCIZ	"PRINTA"	; nom du module LIBLSTERM:	.B	0,-1		; terminateurs pour LIB,?CPSTRING	.EVEN; Erreurs fatales; ---------------TXERFATREV:	.ASCIZ	"La rvision du systme est incompatible"TXERFATMEM:	.ASCIZ	"Problme avec la mmoire"TXERFATDIS:	.ASCIZ	"Driver d'cran incompatible"TXERFATGRA:	.ASCIZ	"Module GRA incompatible"TXERFATTXT:	.ASCIZ	"Erreur avec le gencar NEF11"TXERFATICO:	.ASCIZ	"Erreur avec le gencar ITP16"TXERFATTYPO:	.ASCIZ	"Erreur avec le gencar URP09"TXERFATGCP:	.ASCIZ	"Erreur avec le gencar imprimante_DRF07"TXERFATPRI:	.ASCIZ	"Imprimante pas install correctement"		.EVEN	.END