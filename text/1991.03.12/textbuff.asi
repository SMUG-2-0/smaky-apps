	.SBTTL TEXTBUFF; Utilisation des 4 pointeurs principaux dans un buffer de; texte non compactifi :;;	OPDB	       OPDT		   OPFT		OPFB;	 |		|		    |		 |;	|--------------|-------------------|------------|;	|ABCDEFGHIJKLMN|     t r o u       |OPQRSTUVWXYZ|;	|--------------|-------------------|------------|;;	premire partie	     curseur	   deuxime partie;	du texte	    (triangle)	   du texte; Observation dans un buffer; --------------------------;----------\\; QUICKDOWN >;==========/; Cherche trs rapidement une commande contre en bas.; in	A5.L	^description d'un buffer trou;	A4.L	^dans un buffer; out	A4.L	^aprs le caractre;	D3.B	caractre trouv;	D7.W	trouv/pas trouv; mod	D3.W, D7.W, A4.LQUICKDOWN:	PUSH.L	D4	LOAD.W	D7,#ERTNOT	; D7 <-- pas trouv; Cherche avant le trou en descendant.	LOAD.L	D4,(A5)+OPDT	SUB.L	D4,A4		; D4 <-- lg jusqu'au trou	JUMP',LO 50$	JUMP',EQ 40$	DEC.W	D4		;  cause du test NMO20$:	TEST.B	(A4+):#BSPEC	SKIP,BS	DECJ.W,NMO D4,20$	JUMP',BS 80$		; trouv => 80$; Cherche aprs le trou en descendant.40$:	LOAD.L	A4,(A5)+OPFT	; A4 <-- saute le trou50$:	LOAD.L	D4,(A5)+OPFB	SUB.L	D4,A4		; D4 <-- lg jusqu' la fin	JUMP',LS 90$	DEC.W	D4		;  cause du test NMO60$:	TEST.B	(A4+):#BSPEC	SKIP,BS	DECJ.W,NMO D4,60$	JUMP',BC 90$		; pas trouv => 90$80$:	LOAD.B	D3,(A4)-1	; D3 <-- caractre trouv	CLR.W	D7		; D7 <-- trouv90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; QUICKUP >;========/; Cherche trs rapidement une commande contre en haut.; in	A5.L	^description d'un buffer trou;	A4.L	^dans un buffer; out	A4.L	^sur le caractre;	D3.B	caractre trouv;	D7.W	trouv/pas trouv; mod	D3.W, D7.W, A4.LQUICKUP:	PUSH.L	D4	LOAD.W	D7,#ERTNOT	; D7 <-- pas trouv; Cherche aprs le trou en remontant.	LOAD.L	D4,A4	SUB.L	D4,(A5)+OPFT	; D4 <-- lg jusqu'au trou	JUMP',LO 50$	JUMP',EQ 40$	DEC.W	D4		;  cause du test NMO20$:	TEST.B	(-A4):#BSPEC	SKIP,BS	DECJ.W,NMO D4,20$	JUMP',BS 80$		; trouv => 80$; Cherche avant le trou en remontant.40$:	LOAD.L	A4,(A5)+OPDT	; A4 <-- saute le trou50$:	LOAD.L	D4,A4	SUB.L	D4,(A5)+OPDB	; D4 <-- lg jusqu'au dbut	JUMP',LS 90$	DEC.W	D4		;  cause du test NMO60$:	TEST.B	(-A4):#BSPEC	SKIP,BS	DECJ.W,NMO D4,60$	JUMP',BC 90$		; pas trouv => 90$80$:	LOAD.B	D3,(A4)		; D3 <-- caractre trouv	CLR.W	D7		; D7 <-- trouv90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SKIPHOL >;========/; Saute le trou en avant si cela est ncessaire.; in	A4.L	^dans buffer; out	A4.L	^dans buffer; mod	A4.L, D7.WSKIPHOL:	COMP.L	A4,(A5)+OPDT	; est-on au dbut du trou ?	JUMP',NE 90$		; non => 90$				; oui =>	PUSH.W	D3	CALL	NVISU		; saute le trou	POP.W	D390$:	RET;--------\\; MSVISU  >;========/; Cherche en avant si un SAJEX(M/T/S) est suivit d'autres semblables.; in	D3.W	SAJEX(M/T/S);	A4.L	^aprs le premier; out	D4.W	longueur globale;	A4.L	^plus loin; mod	D4.W, D7.W, A4.LMSVISU:	PUSHM.L	D2,D3	LOAD.B	D2,D3		; D3 <-- code du SAJEX?	CLR.W	D4		; D4 <-- longueur globale20$:	SR.W	D3,#8		; D3 <-- largeur de l'espace	ADD.W	D4,D3		; D4 <-- ajoute dans lg globale	COMP.L	A4,(A5)+OPDT	JUMP',EQ 90$	COMP.L	A4,(A5)+OPFB	JUMP',EQ 90$	COMP.B	D2,(A4)		; encore un SAJEX? juste aprs ?	JUMP',NE 90$		; non => 90$	CALL	NVISU		; oui => saute et compte	JUMP	20$90$:	POPM.L	D2,D3	RET;--------\\; NVISU   >;========/; Observation dans un buffer en avanant, mais sans dplacer; le trou.; in	A5.L	^description d'un buffer trou;	A4.L	^dans un buffer; out	D7.W	zro =>;	 D3.W	 caractre;	 A4.L	 ^plus loin;	D7.W	ERHOL => trou rencontr (et saut);	 A4.L	 ^plus loin;	D7.W	EREOB => on ne peut plus avancer; mod	D3.W, D7.W, A4.LTNVISU:10$:	CALL	NVISU		; avance	JUMP',EQ 90$	COMP.W	D7,#ERTHOL	; trou rencontr ?	JUMP,EQ	10$		; oui => 10$90$:	RETNVISU:10$:	CALL	CNVISU		; D3 <-- un caractre	JUMP,NE 90$	COMP.B	D3,#DEBIMA	; dbut d'une image ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#DEBREG	; dbut d'une rglette ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,#SAJEXM	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXT	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXS	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#DEBCOM	; dbut d'une commande ?	JUMP,NE 90$		; non => 90$				; COMMAND =>	PUSHM.L	A3,A4	LOAD.L	A4,#(A4)+LGCOM	; A4 <-- ^paramtres "next"	LOAD.L	A3,#(A5)+OVCOM	CALL	MAJCOMMAND	; OVCOM <-- commande en cours ici	POPM.L	A3,A425$:	CALL	CNVISU		; saute la commande en avant	JUMP',NE 90$	COMP.B	D3,#FINCOM	; fin de la commande ?	JUMP,NE	25$		; non => 25$	LOAD.B	D3,#COMMAND	JUMP'	90$40$:				; IMAGE =>	CALL	CNVISU		; saute l'image en avant	JUMP',NE 90$	COMP.B	D3,#FINIMA	; fin de l'image ?	JUMP,NE	40$		; non => 40$	LOAD.B	D3,#IMAGE	JUMP'	90$50$:				; REGLE =>	PUSHM.L	A3,A4	LOAD.L	A4,#(A4)+LGREG	; A4 <-- ^paramtres "next"	LOAD.L	A3,#(A5)+OVREG	CALL	MAJREGLE	; OVREG <-- rglette en cours ici	POPM.L	A3,A455$:	CALL	CNVISU		; saute la rglette en avant	JUMP',NE 90$	COMP.B	D3,#FINREG	; fin de la rglette ?	JUMP,NE	55$		; non => 55$	LOAD.B	D3,#REGLE	JUMP'	90$60$:				; SAJEXM/SAJEXT/SAJEXS =>	PUSH.B	D3	CALL	CNVISU	SL.W	D3,#8		; D3 <-- largeur	POP.B	D3	PUSH.W	D3	CALL	CNVISU	POP.W	D390$:	TEST.W	D7		; retour EQ/NE	RETCNVISU:	COMP.L	A4,(A5)+OPDT	; trou rencontr ?	JUMP',NE 10$		; non => 10$				; oui =>	LOAD.L	A4,(A5)+OPFT	; oui => saute-le (hop) ...	LOAD.W	D7,#ERTHOL	; D7 <-- erreur "trou"	RET10$:	COMP.L	A4,(A5)+OPFB	; fin du buffer ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.W	D7,#ERTEOB	; D7 <-- erreur "eob"	RET20$:	LOAD.B	D3,(A4+)	; D3 <-- un caractre	CLR.W	D7		; D7 <-- ok	RET;--------\\; PVISU   >;========/; Observation dans un buffer en reculant, mais sans dplacer; le trou.; in	A5.L	^description d'un buffer trou;	A4.L	^dans un buffer; out	D7.W	zro =>;	 D3.W	 caractre;	 A4.L	 ^plus loin;	D7.W	ERHOL => trou rencontr (et saut);	 A4.L	 ^plus loin;	D7.W	ERBOB => on ne peut plus reculer; mod	D3.W, D7.W, A4.LTPVISU:10$:	CALL	PVISU		; recule	JUMP',EQ 90$	COMP.W	D7,#ERTHOL	; trou rencontr ?	JUMP,EQ	10$		; oui => 10$90$:	RETPVISU:10$:	CALL	CPVISU		; D3 <-- un caractre	JUMP,NE 90$	COMP.B	D3,#FINIMA	; fin d'une image ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#FINREG	; fin d'une rglette ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,#SAJEXM	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXT	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXS	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#FINCOM	; fin d'une commande ?	JUMP,NE 90$		; non => 90$				; COMMAND =>	PUSHM.L	A3,A4	LOAD.L	A4,#(A4)-LGCOM*2; A4 <-- ^paramtres "prev"	LOAD.L	A3,#(A5)+OVCOM	CALL	MAJCOMMAND	; OVCOM <-- commande en cours ici	POPM.L	A3,A425$:	CALL	CPVISU		; saute la commande en arrire	JUMP',NE 90$	COMP.B	D3,#DEBCOM	; dbut de la commande ?	JUMP,NE	25$		; non => 25$	LOAD.B	D3,#COMMAND	JUMP'	90$40$:				; IMAGE =>	CALL	CPVISU		; saute l'image en arrire	JUMP',NE 90$	COMP.B	D3,#DEBIMA	; dbut de l'image ?	JUMP,NE	40$		; non => 40$	LOAD.B	D3,#IMAGE	JUMP'	90$50$:				; REGLE =>	PUSHM.L	A3,A4	LOAD.L	A4,#(A4)-LGREG*2; A4 <-- ^paramtres "prev"	LOAD.L	A3,#(A5)+OVREG	CALL	MAJREGLE	; OVREG <-- rglette en cours ici	POPM.L	A3,A455$:	CALL	CPVISU		; saute la rglette en arrire	JUMP',NE 90$	COMP.B	D3,#DEBREG	; dbut de la rglette ?	JUMP,NE	55$		; non => 55$	LOAD.B	D3,#REGLE	JUMP'	90$60$:				; SAJEXM/SAJEXT/SAJEXS =>	PUSH.B	D3	CALL	CPVISU	SL.W	D3,#8		; D3 <-- largeur	POP.B	D3	PUSH.W	D3	CALL	CPVISU	POP.W	D390$:	TEST.W	D7		; retour EQ/NE	RETCPVISU:	COMP.L	A4,(A5)+OPFT	; trou rencontr ?	JUMP',NE 10$		; non => 10$				; oui =>	LOAD.L	A4,(A5)+OPDT	; saute-le (hop) ...	LOAD.W	D7,#ERTHOL	; D7 <-- erreur "trou"	RET10$:	COMP.L	A4,(A5)+OPDB	; dbut du buffer ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.W	D7,#ERTBOB	; D7 <-- erreur "bob"	RET20$:	LOAD.B	D3,(-A4)	; D3 <-- un caractre	CLR.W	D7		; D7 <-- ok	RET; Dplacements dans un buffer; ---------------------------;--------\\; VAFIN   >;========/; Avance le curseur tout  la fin d'un buffer trou.; in	A5.L	^description du buffer trou; out	-; mod	D7.WVAFIN:	PUSH.L	A4	LOAD.L	A4,(A5)+OPFB	CALL	VAQQPART	; avance  la fin	POP.L	A4	RET;--------\\; VADEBUT >;========/; Recule le curseur tout au dbut d'un buffer trou.; in	A5.L	^description du buffer trou; out	-; mod	D7.WVADEBUT:	PUSH.L	A4	LOAD.L	A4,(A5)+OPDB	CALL	VAQQPART	; recule au dbut	POP.L	A4	RET;---------\\; VAQQPART >;=========/; Avance ou recule n'importe o dans un buffer trou.; ATTENTION: A4 ne doit pas pointer  l'intrieur du trou !; in	A5.L	^description du buffer trou;	A4.L	^o aller; out	-; mod	D7.WVAQQPART:	PUSHM.L	D4,A3,A4; Vrifie si A4.L est dans le trou ou hors du buffer (ceci ne; devrait jamais arriver). Si c'est le cas, ne fait rien !	COMP.L	A4,(A5)+OPDB	JUMP',LO 90$	COMP.L	A4,(A5)+OPDT	JUMP',LS 10$	COMP.L	A4,(A5)+OPFT	JUMP',LO 90$	COMP.L	A4,(A5)+OPFB	JUMP',HI 90$10$:	COMP.L	A4,(A5)+OPFT	JUMP',EQ 90$		; si on y est dj => 90$	JUMP',HI 50$		; si avance => 50$				; si recule =>	LOAD.L	D4,(A5)+OPDT	SUB.L	D4,A4		; D4 <-- lg  reculer	JUMP',EQ 90$	LOAD.L	A4,(A5)+OPFT	LOAD.L	A3,(A5)+OPDT30$:	LOAD.B	(-A4),(-A3)	; recule le trou ...	DEC.L	D4	JUMP,NE 30$	JUMP'	80$50$:	SUB.L	A4,(A5)+OPFT	LOAD.L	D4,A4		; D4 <-- lg  avancer	LOAD.L	A4,(A5)+OPFT	LOAD.L	A3,(A5)+OPDT60$:	LOAD.B	(A3+),(A4+)	; avance le trou ...	DEC.L	D4	JUMP,NE 60$80$:	LOAD.L	(A5)+OPFT,A4	LOAD.L	(A5)+OPDT,A390$:	LOAD.L	A4,(A5)+OPFT	LOAD.L	A3,#(A5)+OCREG	CALL	_VAQQREGLE	; OCREG <-- rglette en cours ici	LOAD.L	A4,(A5)+OPFT	LOAD.L	A3,#(A5)+OCCOM	CALL	VAQQCOMMAND	; OCCOM <-- commande en cours ici	LOAD.W	D4,#MODCUR	; D4 <-- curseur dplac	CALL	MODIF		; signal type de modification	CLR.W	D7		; D7 <-- ok	POPM.L	D4,A3,A4	RET;--------\\; AVANCE  >;========/; Avance d'un caractre dans un buffer trou.; in	A5.L	^description du buffer trou; out	D7.W	zro =>;	 D3.W	 caractre avanc;	D7.W	EREOB (end of buffer); mod	D3.W, D7.WAVANCE:10$:	CALL	CAVANCE		; D3 <-- un caractre	JUMP,NE 90$	COMP.B	D3,#DEBIMA	; dbut d'une image ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#DEBREG	; dbut d'une rglette ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,#SAJEXM	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXT	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXS	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#DEBCOM	; dbut d'une commande ?	JUMP,NE 90$		; non => 90$				; COMMAND =>	PUSHM.L	A3,A4	LOAD.L	A4,(A5)+OPFT	LOAD.L	A4,#(A4)+LGCOM	; A4 <-- ^paramtres "next"	LOAD.L	A3,#(A5)+OCCOM	CALL	MAJCOMMAND	; OCCOM <-- commande en cours ici	POPM.L	A3,A425$:	CALL	CAVANCE		; saute la commande en avant	JUMP,NE 90$	COMP.B	D3,#FINCOM	; fin de la commande ?	JUMP,NE	25$		; non => 25$	LOAD.B	D3,#COMMAND	JUMP'	90$40$:				; IMAGE =>	CALL	CAVANCE		; saute l'image en avant	JUMP',NE 90$	COMP.B	D3,#FINIMA	; fin de l'image ?	JUMP,NE	40$		; non => 40$	LOAD.B	D3,#IMAGE	JUMP'	90$50$:				; REGLE =>	PUSHM.L	A3,A4	LOAD.L	A4,(A5)+OPFT	LOAD.L	A4,#(A4)+LGREG	; A4 <-- ^paramtres "next"	LOAD.L	A3,#(A5)+OCREG	CALL	MAJREGLE	; OCREG <-- rglette en cours ici	POPM.L	A3,A455$:	CALL	CAVANCE		; saute la rglette en avant	JUMP',NE 90$	COMP.B	D3,#FINREG	; fin de la rglette ?	JUMP,NE	55$		; non => 55$	LOAD.B	D3,#REGLE	JUMP'	90$60$:				; SAJEXM/SAJEXT/SAJEXS =>	PUSH.B	D3	CALL	CAVANCE	SL.W	D3,#8		; D3 <-- largeur	POP.B	D3	PUSH.W	D3	CALL	CAVANCE	POP.W	D390$:	TEST.W	D7		; retour EQ/NE	RETCAVANCE:	PUSHM.L	D4,A4	LOAD.L	A4,(A5)+OPFT	COMP.L	A4,(A5)+OPFB	; est-on  la fin ?	JUMP',NE 50$		; non => 50$				; oui =>	LOAD.W	D7,#ERTEOB	; D7 <-- erreur	JUMP'	90$50$:	LOAD.B	D3,(A4+)	; D3 <-- caractre	LOAD.L	(A5)+OPFT,A4	LOAD.L	A4,(A5)+OPDT	LOAD.B	(A4+),D3	; remet le caractre de l'autre	LOAD.L	(A5)+OPDT,A4	; ct du trou.	LOAD.W	D4,#MODCUR	; D4 <-- curseur dplac	CALL	MODIF		; signal type de modification	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	RET;--------\\; RECULE  >;========/; Recule d'un caractre dans un buffer trou.; in	A5.L	^description du buffer; out	D7.W	zro =>;	 D3.W	 caractre recu;	D7.W	ERBOB (begin of buffer); mod	D3.W, D7.WRECULE:10$:	CALL	CRECULE		; D3 <-- un caractre	JUMP,NE 90$	COMP.B	D3,#FINIMA	; fin d'une image ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#FINREG	; fin d'une rglette ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,#SAJEXM	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXT	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXS	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#FINCOM	; fin d'une commande ?	JUMP,NE 90$		; non => 90$				; COMMAND =>	PUSHM.L	A3,A4	LOAD.L	A4,(A5)+OPDT	LOAD.L	A4,#(A4)-LGCOM*2; A4 <-- ^paramtres "prev"	LOAD.L	A3,#(A5)+OCCOM	CALL	MAJCOMMAND	; OCCOM <-- commande en cours ici	POPM.L	A3,A425$:	CALL	CRECULE		; saute la commande en arrire	JUMP',NE 90$	COMP.B	D3,#DEBCOM	; dbut de la commande ?	JUMP,NE	25$		; non => 25$	LOAD.B	D3,#COMMAND	JUMP'	90$40$:				; IMAGE =>	CALL	CRECULE		; saute l'image en arrire	JUMP',NE 90$	COMP.B	D3,#DEBIMA	; dbut de l'image ?	JUMP,NE	40$		; non => 40$	LOAD.B	D3,#IMAGE	JUMP'	90$50$:				; REGLE =>	PUSHM.L	A3,A4	LOAD.L	A4,(A5)+OPDT	LOAD.L	A4,#(A4)-LGREG*2; A4 <-- ^paramtres "prev"	LOAD.L	A3,#(A5)+OCREG	CALL	MAJREGLE	; OCREG <-- rglette en cours ici	POPM.L	A3,A455$:	CALL	CRECULE		; saute la rglette en arrire	JUMP',NE 90$	COMP.B	D3,#DEBREG	; dbut de la rglette ?	JUMP,NE	55$		; non => 55$	LOAD.B	D3,#REGLE	JUMP'	90$60$:				; SAJEXM/SAJEXT/SAJEXS =>	PUSH.B	D3	CALL	CRECULE	SL.W	D3,#8		; D3 <-- largeur	POP.B	D3	PUSH.W	D3	CALL	CRECULE	POP.W	D390$:	TEST.W	D7		; retour EQ/NE	RETCRECULE:	PUSHM.L	D4,A4	LOAD.L	A4,(A5)+OPDT	COMP.L	A4,(A5)+OPDB	; est-on au dbut ?	JUMP',NE 50$		; non => 50$				; oui =>	LOAD.W	D7,#ERTBOB	; D7 <-- erreur	JUMP'	90$50$:	LOAD.B	D3,(-A4)	; D3 <-- caractre	LOAD.L	(A5)+OPDT,A4	LOAD.L	A4,(A5)+OPFT	LOAD.B	(-A4),D3	; remet le caractre de l'autre	LOAD.L	(A5)+OPFT,A4	; ct du trou.	LOAD.W	D4,#MODCUR	; D4 <-- curseur dplac	CALL	MODIF		; signal type de modification	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	RET; Insertions et destructions dans un buffer; -----------------------------------------;--------\\; INSERT  >;========/; Insre un caractre dans un buffer trou.; in	A5.L	^description du buffer trou;	D3.W	caractre  insrer; out	D7.W	zro => ok;	D7.W	ERPDP => buffer plein; mod	D7.WINSERT:	PUSHM.L	D4,A4	CALL	CINSERT	JUMP',NE 90$	COMP.B	D3,#SAJEXM	; espace variable ?	JUMP',EQ 20$	COMP.B	D3,#SAJEXT	JUMP',EQ 20$	COMP.B	D3,#SAJEXS	JUMP',NE 30$		; non => 30$20$:				; oui =>	RR.W	D3,#8		; D3 <-- largeur	CALL	CINSERT	RL.W	D3,#8	CALL	CINSERT30$:	LOAD.W	D4,#MODALL	; D4 <-- tout modifi	CALL	IFIEOL		; fin de ligne ?	JUMP',EQ 70$		; oui => 70$	LOAD.W	D4,#MODLIN	; D4 <-- ligne modifie	LOAD.L	A4,(A5)+OPFT	COMP.L	A4,(A5)+OPFB	JUMP',EQ 70$	COMP.B	(A4),#DEBIMA	; insr juste avant une image ?	JUMP',EQ 50$		; oui => 50$	COMP.B	(A4),#DEBREG	; insr juste avant une rglette ?	JUMP',NE 70$		; non => 70$50$:				; oui =>	LOAD.W	D4,#MODALL	; D4 <-- tout modifi70$:	CALL	MODIF		; signal type de modification90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RETCINSERT:	PUSH.L	A4	LOAD.L	A4,(A5)+OPDT	INC.L	A4	COMP.L	A4,(A5)+OPFT	; reste de la place ?	JUMP',LO 50$		; oui => 50$				; non =>	LOAD.W	D7,#ERTPDP	; D7 <-- erreur	JUMP'	90$50$:	LOAD.B	(A4)-1,D3	; buffer <-- caractre	LOAD.L	(A5)+OPDT,A4	TSET.B	(A5)+OSTATUS:#BFILMOD ; fichier pas  jour	TSET.B	(A5)+OSTATUS:#BEOPMOD	CLR.W	D7		; D7 <-- ok90$:	POP.L	A4	RET;--------\\; PLACE?  >;========/; Vrifie s'il reste au moins n bytes dans un buffer.; in	A5.L	^description du buffer trou;	D4.W	nb minimum de bytes; out	D7.W	zro => ok;	D7.W	ERPDP => buffer plein; mod	D7.WPLACE?:	PUSHM.L	D3,D4	LOAD.W	D7,#ERTPDP	; D7 <-- plus de place	LOAD.L	D3,(A5)+OPFT	SUB.L	D3,(A5)+OPDT	DEC.L	D3		; D3 <-- place restante	AND.L	D4,#H'FFFF	COMP.L	D4,D3		; reste assez ?	JUMP',HS 90$		; non => 90$				; oui =>	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DAVANCE >;========/; Dtruit un caractre en avant dans un buffer trou.; Action quivalente  (DEL), c'est--dire dtruit le caractre; situ sous le curseur.; in	A5.L	^description du buffer; out	D7.W	zro =>;	 D3.W	 caractre dtruit;	D7.W	EREOB (end of buffer); mod	D3.W, D7.WDAVANCE:10$:	CALL	CDAVANCE	; D3 <-- un caractre	JUMP,NE 90$	COMP.B	D3,#DEBIMA	; dbut d'une image ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#DEBREG	; dbut d'une rglette ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,#SAJEXM	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXT	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXS	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#DEBCOM	; dbut d'une commande ?	JUMP,NE 90$		; non => 90$				; COMMAND =>	PUSHM.L	A3,A4	LOAD.L	A4,(A5)+OPFT	LOAD.L	A4,#(A4)+LGCOM	; A4 <-- ^paramtres "next"	LOAD.L	A3,#(A5)+OCCOM	CALL	MAJCOMMAND	; OCCOM <-- commande en cours ici	POPM.L	A3,A4	DEC.L	(A5)+OPFT	; rcupre le DEBCOM dj dtruit20$:	CALL	CAVANCE		; saute la commande en avant	JUMP,NE 90$	COMP.B	D3,#FINCOM	; fin de la commande ?	JUMP,NE	20$		; non => 20$	LOAD.B	D3,#COMMAND	JUMP'	90$40$:				; IMAGE =>	PUSH.L	A3	LOAD.L	A3,(A5)+OPFT	; A3 <-- ^nom de l'image	CALL	_IMARELEASE	; libre l'image	POP.L	A342$:	CALL	CDAVANCE	; saute l'image en avant	JUMP',NE 90$	COMP.B	D3,#FINIMA	; fin de l'image ?	JUMP,NE	42$		; non => 42$	LOAD.B	D3,#IMAGE	JUMP'	90$50$:				; REGLE =>	CALL	CDAVANCE	; saute la rglette en avant	JUMP',NE 90$	COMP.B	D3,#FINREG	; fin de la rglette ?	JUMP,NE	50$		; non => 50$	LOAD.B	D3,#REGLE	CALL	DELREGLE	; mj rglettes sup/inf	PUSH.L	A4	LOAD.L	A4,#0	CALL	RJUSTIF		; justifie un p'tit peu	POP.L	A4	CLR.W	D7		; D7 <-- ok	JUMP'	90$60$:				; SAJEXM/SAJEXT/SAJEXS =>	PUSH.B	D3	CALL	CDAVANCE	SL.W	D3,#8		; D3 <-- largeur	POP.B	D3	PUSH.W	D3	CALL	CDAVANCE	POP.W	D390$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; DCAVANCE >;=========/; Dtruit une commande en avant.; in	A5.L	^description du buffer; out	-; mod	D3.W, D7.WDCAVANCE:20$:	CALL	CDAVANCE	; dtruit la commande en avant	JUMP',NE 90$	COMP.B	D3,#FINCOM	; fin de la commande ?	JUMP,NE	20$		; non => 20$				; oui =>	CALL	DELCOMMAND	; mj commandes sup/inf	CLR.W	D7		; D7 <-- ok90$:	RET;---------\\; CDAVANCE >;=========/; Dtruit un byte en avant.; in	A5.L	^description du buffer; out	D7.W	zro =>;	 D3.W	 caractre dtruit;	D7.W	EREOB (end of buffer); mod	D3.W, D7.WCDAVANCE:	PUSHM.L	D4,A4	LOAD.L	A4,(A5)+OPFT	COMP.L	A4,(A5)+OPFB	; est-on  la fin ?	JUMP',NE 10$		; non => 10$				; oui =>	LOAD.W	D7,#ERTEOB	; D7 <-- erreur	JUMP'	90$10$:	LOAD.B	D3,(A4+)	; D3 <-- caractre dtruit	LOAD.L	(A5)+OPFT,A4	LOAD.W	D4,#MODALL	; D4 <-- tout modifi	CALL	IFIEOL		; fin de ligne ?	JUMP',EQ 70$		; oui => 70$	LOAD.W	D4,#MODLIN	; D4 <-- ligne modifie70$:	CALL	MODIF		; signal type de modification	TSET.B	(A5)+OSTATUS:#BFILMOD ; fichier pas  jour;;?	COMP.B	D3,#PEOP;;?	JUMP',EQ 80$;;?	COMP.B	D3,#TEOP;;?	JUMP',NE 85$;;?80$:				; PEOP/TEOP =>	TSET.B	(A5)+OSTATUS:#BEOPMOD;;?85$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	RET;--------\\; DRECULE >;========/; Dtruit un caractre en arrire dans un buffer trou.; Action quivalente  (BS), c'est--dire dtruit le caractre; situ  gauche du curseur.; in	A5.L	^description du buffer; out	D7.W	zro =>;	 D3.W	 caractre dtruit;	D7.W	ERBOB (begin of buffer); mod	D3.W, D7.WDRECULE:10$:	CALL	CDRECULE	; D3 <-- un caractre	JUMP,NE 90$	COMP.B	D3,#FINIMA	; fin d'une image ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#FINREG	; fin d'une rglette ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,#SAJEXM	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXT	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXS	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#FINCOM	; fin d'une commande ?	JUMP,NE 90$		; non => 90$				; COMMAND =>	PUSHM.L	A3,A4	LOAD.L	A4,(A5)+OPDT	LOAD.L	A4,#(A4)-LGCOM*2; A4 <-- ^paramtres "prev"	LOAD.L	A3,#(A5)+OCCOM	CALL	MAJCOMMAND	; OCCOM <-- commande en cours ici	POPM.L	A3,A4	INC.L	(A5)+OPDT	; rcupre le FINCOM dj dtruit20$:	CALL	CRECULE		; saute la commande en arrire	JUMP,NE 90$	COMP.B	D3,#DEBCOM	; dbut de la commande ?	JUMP,NE	20$		; non => 20$	LOAD.B	D3,#COMMAND	JUMP'	90$40$:				; IMAGE =>	CALL	CDRECULE	; saute l'image en arrire	JUMP',NE 90$	COMP.B	D3,#DEBIMA	; dbut de l'image ?	JUMP,NE	40$		; non => 40$	PUSH.L	A3	LOAD.L	A3,(A5)+OPDT	INC.L	A3		; A3 <-- ^nom de l'image	CALL	_IMARELEASE	; libre l'image	POP.L	A3	CLR.W	D7		; D7 <-- ok	LOAD.B	D3,#IMAGE	JUMP'	90$50$:				; REGLE =>	PUSHM.L	A3,A4	LOAD.L	A4,(A5)+OPDT	LOAD.L	A4,#(A4)-LGREG*2; A4 <-- ^paramtres "prev"	LOAD.L	A3,#(A5)+OCREG	CALL	MAJREGLE	; OCREG <-- rglette en cours ici	POPM.L	A3,A455$:	CALL	CDRECULE	; saute la rglette en arrire	JUMP',NE 90$	COMP.B	D3,#DEBREG	; dbut de la rglette ?	JUMP,NE	55$		; non => 55$	LOAD.B	D3,#REGLE	CALL	DELREGLE	; mj rglettes sup/inf	PUSH.L	A4	LOAD.L	A4,#0	CALL	RJUSTIF		; justifie un p'tit peu	POP.L	A4	CLR.W	D7		; D7 <-- ok	JUMP'	90$60$:				; SAJEXM/SAJEXT/SAJEXS =>	PUSH.B	D3	CALL	CDRECULE	SL.W	D3,#8		; D3 <-- largeur	POP.B	D3	PUSH.W	D3	CALL	CDRECULE	POP.W	D390$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; DCRECULE >;=========/; Dtruit une commande en arrire.; in	-; out	-; mod	D3.W, D7.WDCRECULE:20$:	CALL	CDRECULE	; dtruit la commande en arrire	JUMP,NE 90$	COMP.B	D3,#DEBCOM	; dbut de la commande ?	JUMP,NE	20$		; non => 20$	CALL	DELCOMMAND	; mj commandes sup/inf	CLR.W	D7		; D7 <-- ok90$:	RET;---------\\; CDRECULE >;=========/; Dtruit un byte en arrire.; in	A5.L	^description du buffer; out	D7.W	zro =>;	 D3.W	 caractre dtruit;	D7.W	ERBOB (begin of buffer); mod	D3.W, D7.WCDRECULE:	PUSHM.L	D4,A4	LOAD.L	A4,(A5)+OPDT	COMP.L	A4,(A5)+OPDB	; est-on au dbut ?	JUMP',NE 10$		; non => 10$				; oui =>	LOAD.W	D7,#ERTBOB	; D7 <-- erreur	JUMP'	90$10$:	LOAD.B	D3,(-A4)	; D3 <-- caractre dtruit	LOAD.L	(A5)+OPDT,A4	LOAD.W	D4,#MODALL	; D4 <-- tout modifi	CALL	IFIEOL		; fin de ligne ?	JUMP',EQ 70$		; oui => 70$	LOAD.W	D4,#MODLIN	; D4 <-- ligne modifie70$:	CALL	MODIF		; signal type de modification	TSET.B	(A5)+OSTATUS:#BFILMOD ; fichier pas  jour;;?	COMP.B	D3,#PEOP;;?	JUMP',EQ 80$;;?	COMP.B	D3,#TEOP;;?	JUMP',NE 85$;;?80$:				; PEOP/TEOP =>	TSET.B	(A5)+OSTATUS:#BEOPMOD;;?85$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	RET;--------\\; FLUSH   >;========/; Vide compltement un buffer.; in	A5.L	^description du buffer; out	-; mod	D7.WFLUSH:	PUSHM.L	D4,A3	CALL	_IMACLBUF	; ferme toutes les images	CALL	FLUSHGC		; libre les gencars inutiles	LOAD.L	(A5)+OPDT,(A5)+OPDB	LOAD.L	(A5)+OPFT,(A5)+OPFB	TCLR.B	(A5)+OSTATUS:#BFILMOD	TCLR.B	(A5)+OSTATUS:#BEOPMOD	CLR.B	(A5)+OBUMEMF	; plus de nom mmoris	LOAD.L	A3,#(A5)+OCREG	CALL	DEFREGLE	; OCREG <-- rgle par dfaut	LOAD.L	A3,#(A5)+OCCOM	CALL	DEFCOMMAND	; OCCOM <-- commandes par dfaut	LOAD.W	D4,#MODALL	; D4 <-- tout modifi	CALL	MODIF		; signal type de modification	POPM.L	D4,A3	RET;--------\\; IFVIDE  >;========/; Vrifie si un buffer est vide. S'il contient juste une; rglette, il est considr comme vide !; in	A5.L	^description d'un buffer; out	D7.W	zro => buffer plein;	D7.W	autre => buffer vide; mod	D7.WIFVIDE:	PUSHM.L	D3,A4	LOAD.L	A4,(A5)+OPDB	CALL	TNVISU		; D3 <-- premier caractre	JUMP',NE 90$		; si y'en a pas => 90$ (vide)	COMP.B	D3,#REGLE	; est-ce une rgle ?	JUMP',NE 90$		; non => 90$ (plein)				; oui =>	CALL	TNVISU		; D3 <-- caractre aprs rgle	JUMP',NE 90$		; si y'en a pas => 90$ (vide)	COMP.B	D3,#TEOL	; est-ce une fin de ligne ?	JUMP',NE 90$		; non => 90$ (plein)				; oui =>	CALL	TNVISU		; D3 <-- caractre aprs fin de ligne90$:	POPM.L	D3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETPTC  >;========/; Donne le caractre sous le pointeur.; in	A5.L	^description d'un buffer trou; out	D7.W	zro => ok;	 D3.W	 caractre;	D7.W	EREOB => fin du buffer; mod	D3.W, D7.WGETPTC:10$:	CALL	CGETPTC		; D3 <-- un caractre	JUMP',NE 90$	COMP.B	D3,#DEBIMA	; dbut d'une image ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#DEBREG	; dbut d'une rglette ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,#SAJEXM	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXT	; espace variable ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#SAJEXS	; espace variable ?	JUMP',EQ 60$		; oui => 60$	COMP.B	D3,#DEBCOM	; dbut d'une commande ?	JUMP',NE 90$		; non => 90$				; COMMAND =>	LOAD.B	D3,#COMMAND	JUMP'	90$40$:				; IMAGE =>	LOAD.B	D3,#IMAGE	JUMP'	90$50$:				; REGLE =>	LOAD.B	D3,#REGLE	JUMP'	90$60$:				; SAJEXM/SAJEXT/SAJEXS =>	PUSH.B	D3	PUSH.L	A4	LOAD.L	A4,(A5)+OPFT	LOAD.B	D3,(A4)+1	SL.W	D3,#8		; D3 <-- largeur	POP.L	A4	POP.B	D390$:	TEST.W	D7		; retour EQ/NE	RETCGETPTC:	PUSH.L	A4	LOAD.L	A4,(A5)+OPFT	COMP.L	A4,(A5)+OPFB	; fin du buffer ?	JUMP',NE 10$		; non => 10$				; oui =>	LOAD.W	D7,#ERTEOB	; D7 <-- erreur	JUMP'	90$10$:	LOAD.B	D3,(A4)		; D3 <-- caractre	CLR.W	D7		; D7 <-- ok90$:	POP.L	A4	RET; Gestion des buffers; -------------------; Organisation interne des pointeurs aux diffrents buffers; de texte:;		!-------!;  OPTDB  ----> !	!;		!-------!;		! OPCD	!	NBBF-1;		! OPCC	!;		!-------!;		!	!	NBBF-2;		  ...;		!	!;		!-------!;		!	!	0;		!	!;		!-------!;  OPTFB  ---->	!	!;		!-------!;;			      OPCD   OPCC   OPCD (suivant);				!      !      !;  !------!--------!---!-------!-------------!-----------!;  ! vide !   5    ! 4 !   3   !       2     !      1    !;  !------!--------!---!-------!-------------!-----------!;   !							  !; OPTDB							OPTFB;--------\; GPPBUF  >;========/; Cherche la description d'un buffer compactifi, et signal si; le buffer en question est vide.; in	D0.W	no du buffer; out	A4.L	^description buffer compactifi;	EQ	buffer vide; mod	A4.LGPPBUF:	PUSH.L	D0	LOAD.L	A4,#(A6)+OPTDB+4; A4 <-- ^^dbut dernier buffer	SUB.W	D0,#NBBF-1	NEG.W	D0	MUL.WU	D0,#LGPC	ADD.L	A4,D0		; A4 <-- ^description compactifie	LOAD.L	D0,(A4)+OPCD	COMP.L	D0,(A4)+LGPC+OPCD ; buffer vide ?				; oui => retour EQ	POPM.L	D0	RET;--------\; BALANCE >;========/; R-quilibre les buffers de textes en rpartissant; quitablement la place disponible restante.; in	-; out	-; mod	-BALANCE:	PUSHM.L	D0,D1	LOAD.W	D0,(A6)+OBUFP+ONOBUF	LOAD.W	D1,(A6)+OBUFS+ONOBUF	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE ; buf. sec. utilis ?	JUMP',BC 50$		; oui => 50$				; non =>	CALL	INI1B		; init 1 (ou 2) buffer	JUMP'	90$50$:	CALL	INI2B		; init 2 (ou 3) buffers90$:	POPM.L	D0,D1	RET;--------\; KILBUF  >;========/; Dtruit entirement un buffer.; in	D0.B	numro du buffer  dtruire; out	-; mod	-KILBUF:	PUSHM.L	D0,D1,D2,D3	AND.W	D0,#H'FF	; D0.W <-- no de buffer word	LOAD.W	D2,(A5)+ONOBUF	LOAD.W	D1,(A6)+OBUFS+ONOBUF	LOAD.B	D3,(A6)+OBUFS+OSTBUF	CALL	COMPACT		; compactifie tous les buffers	LOAD.W	(A5)+ONOBUF,D0	; init no buffer  dtruire	TCLR.B	(A5)+OSTBUF:#BBUFRE	CLR.L	(A5)+OLGBUF	; init lg nulle	CALL	CREUSE		; creuse le buffer  dtruire	LOAD.L	(A5)+OPDT,(A5)+OPDB	LOAD.L	(A5)+OPDP,(A5)+OPDB	LOAD.L	(A5)+OPFT,(A5)+OPFB	TCLR.B	(A5)+OSTATUS:#BFILMOD ; signal buffer  jour	TCLR.B	(A5)+OSTATUS:#BEOPMOD	CALL	BOUCHE		; bouche le buffer dtruit	LOAD.W	D0,D2		; D0 <-- no buffer principal	TEST.L	D3:#BBUFRE	; buffer secondaire existait ?	JUMP',BC 50$		; oui => 50$				; non =>	CALL	INI1B		; remet juste le principal	JUMP'	90$50$:	CALL	INI2B		; remet les 2 buffers90$:	POPM.L	D0,D1,D2,D3	RET;--------\; INI1B   >;========/; Initialise le buffer principal comme buffer unique.; Deux buffers seront ventuellement initialiss si le buffer; macro est utilis.; in	D0.B	numro du buffer; out	A5.L	^buffer principal; mod	A5.LINI1B:	PUSHM.L	D0,D4	LOAD.L	A5,#(A6)+OBUFP	LOAD.W	D4,#MODALL	CALL	MODIF		; faudra tout refaire	CALL	COMPACT	AND.W	D0,#H'FF	; D0.W <-- no de buffer word	LOAD.W	(A6)+OBUFP+ONOBUF,D0	TCLR.B	(A6)+OBUFP+OSTBUF:#BBUFRE	TSET.B	(A6)+OBUFP+OSTBUF:#BBUCOM ; pas encore creus	TSET.B	(A6)+OBUFS+OSTBUF:#BBUFRE	TSET.B	(A6)+OBUFM+OSTBUF:#BBUFRE	LOAD.L	D0,(A6)+OPTDB+4	SUB.L	D0,(A6)+OPTDB	; D0 <-- grandeur du vide	TEST.B	(A6)+OFLMAC:#BMAC ; macro en cours ?	JUMP',BC 50$		; non => 50$				; oui =>	SR.L	D0		; D0 <-- 1/2 pour chacun	TCLR.L	D0:#0		; DO doit tre pair (!)	LOAD.W	(A6)+OBUFM+ONOBUF,(A6)+OMACBUF	TCLR.B	(A6)+OBUFM+OSTBUF:#BBUFRE	TSET.B	(A6)+OBUFM+OSTBUF:#BBUCOM ; pas encore creus	LOAD.L	(A6)+OBUFM+OLGBUF,D050$:	LOAD.L	(A6)+OBUFP+OLGBUF,D0	CALL	INIPB		; init 1 ou 2 buffer(s)	POPM.L	D0,D4	RET;--------\; INI2B   >;========/; Initialise le buffer principal et le buffer secondaire.; Trois buffers seront ventuellement initialiss si le buffer; macro est utilis.; in	D0.B	numro du buffer principal;	D1.B	numro du buffer secondaire; out	A5.L	^buffer principal; mod	A5.LINI2B:	COMP.B	D0,D1		; init deux fois le mme ?	JUMP,EQ INI1B		; oui => init un seul				; non =>	PUSHM.L	D0,D1,D4	LOAD.L	A5,#(A6)+OBUFP	LOAD.W	D4,#MODALL	CALL	MODIF		; faudra refaire zone principale	LOAD.L	A5,#(A6)+OBUFS	CALL	MODIF		; faudra refaire zone secondaire	CALL	COMPACT	AND.W	D0,#H'FF	; D0.W <-- no de buffer word	LOAD.W	(A6)+OBUFP+ONOBUF,D0	TCLR.B	(A6)+OBUFP+OSTBUF:#BBUFRE	TSET.B	(A6)+OBUFP+OSTBUF:#BBUCOM ; pas encore creus	AND.W	D1,#H'FF	; D1.W <-- no de buffer word	LOAD.W	(A6)+OBUFS+ONOBUF,D1	TCLR.B	(A6)+OBUFS+OSTBUF:#BBUFRE	TSET.B	(A6)+OBUFS+OSTBUF:#BBUCOM ; pas encore creus	TSET.B	(A6)+OBUFM+OSTBUF:#BBUFRE	LOAD.L	D0,(A6)+OPTDB+4	SUB.L	D0,(A6)+OPTDB	; D0 <-- grandeur du vide	SR.L	D0		; D0 <-- 1/2 pour chacun	TCLR.L	D0:#0		; DO doit tre pair (!)	LOAD.L	(A6)+OBUFP+OLGBUF,D0	TEST.B	(A6)+OFLMAC:#BMAC ; macro en cours ?	JUMP',BC 50$		; non => 50$				; oui =>	SR.L	D0		; D0 <-- 1/4 pour sec et macro	TCLR.L	D0:#0		; DO doit tre pair (!)	LOAD.W	(A6)+OBUFM+ONOBUF,(A6)+OMACBUF	TCLR.B	(A6)+OBUFM+OSTBUF:#BBUFRE	TSET.B	(A6)+OBUFM+OSTBUF:#BBUCOM ; pas encore creus	LOAD.L	(A6)+OBUFM+OLGBUF,D050$:	LOAD.L	(A6)+OBUFS+OLGBUF,D0	CALL	INIPB		; init 2 ou 3 buffers	POPM.L	D0,D1,D4	RET;--------\; INIPB   >;========/; Creuse plusieurs buffers selon OBUFP, OBUFS et OBUFM.; Un petit algorythme est utilis pour creuser d'abord le; buffer ayant le plus petit numro (donc le plus haut en; mmoire).; in	A6		^variables;	(A6)+OBUFP	^buffer principal;	(A6)+OBUFS	^buffer secondaire;	(A6)+OBUFM	^buffer macro; out	A5.L		^buffer principal; mod	A5.LINIPB:	PUSHM.L	D0,D1,D2,D3	LOAD.W	D3,#NBSBF-110$:	LOAD.L	A5,#(A6)+OBUFP	; A5 <-- ^buffer principal	CLR.L	D2	LOAD.W	D0,#-1		; D0 <-- plus petit numro	LOAD.W	D1,#NBSBF-1	; D1 <-- dcompteur40$:	TEST.B	(A5)+OSTBUF:#BBUFRE ; buffer utilis ?	JUMP',BS 50$		; non => 50$	TEST.B	(A5)+OSTBUF:#BBUCOM ; buffer dj creus ?	JUMP',BC 50$		; oui => 50$	COMP.W	D0,(A5)+ONOBUF	; buffer plus petit ?	JUMP',LO 50$		; non => 50$	LOAD.W	D0,(A5)+ONOBUF	; D0 <-- numro plus petit	LOAD.L	D2,A550$:	ADD.L	A5,#LGBUFF	; A5 <-- ^buffer trou suivant	DECJ.W,NMO D1,40$	TEST.L	D2		; D2 = zro ?	JUMP',EQ 60$		; oui => 60$				; non =>	LOAD.L	A5,D2		; A5 <-- ^buffer  creuser	CALL	CREUSE		; creuse un buffer ...60$:	DECJ.W,NMO D3,10$	LOAD.L	A5,#(A6)+OBUFP	; A5 <-- ^buffer principal	POPM.L	D0,D1,D2,D3	RET;--------\; COMPACT >;========/; Compactifie tous les buffers. Les caractres seront alors; tous contigus (plus de trou). Les informations contenues; dans OBUFP, OBUFS et OBUFM n'ont plus de sens.; Un petit algorythme est utilis pour boucher d'abord le; buffer ayant le plus grand numro (donc le plus bas en; mmoire).; in	A6.L		^variables;	(A6)+OBUFP	^buffer principal;	(A6)+OBUFS	^buffer secondaire;	(A6)+OBUFM	^buffer macro; out	-; mod	-COMPACT:	PUSHM.L	D0,D1,D2,D3,A5	LOAD.W	D3,#NBSBF-1	; D3 <-- dcompteur10$:	LOAD.L	A5,#(A6)+OBUFP	; A5 <-- ^buffer principal	CLR.L	D2	CLR.W	D0		; D0 <-- plus grand numro	LOAD.W	D1,#NBSBF-1	; D1 <-- dcompteur40$:	TEST.B	(A5)+OSTBUF:#BBUFRE ; buffer utilis ?	JUMP',BS 50$		; non => 50$	COMP.W	D0,(A5)+ONOBUF	; buffer plus petit ?	JUMP',HI 50$		; non => 50$	LOAD.W	D0,(A5)+ONOBUF	; D0 <-- numro plus grand	LOAD.L	D2,A550$:	ADD.L	A5,#LGBUFF	; A5 <-- ^buffer trou suivant	DECJ.W,NMO D1,40$	TEST.L	D2		; D2 = zro ?	JUMP',EQ 60$		; oui => 60$				; non =>	LOAD.L	A5,D2		; A5 <-- ^buffer  boucher	CALL	BOUCHE		; bouche un buffer ...60$:	DECJ.W,NMO D3,10$	POPM.L	D0,D1,D2,D3,A5	RET;--------\; CREUSE  >;========/; Creuse un trou dans un buffer quelconque.; Chaque caractre correspond  un word en mmoire.; Le texte ne peut pas contenir plus de 64'000 caractres.; in	A6.L		^variables;	A5.L		^description pour le buffer  creuser;	(A5)+ONOBUF.W	numro du buffer  creuser;	(A5)+OLGBUF.L	longueur  creuser (doit tre paire); out	(A5)+OSTBUF.B	buffer creus (BBUCOM=0);	(A5)+OPDB.L	^dbut du buffer;	(A5)+OPDT.L	^dbut du trou;	(A5)+OPFT.L	^fin du trou;	(A5)+OPFB.L	^fin du buffer;	(A5)+OPDP.L	^dbut de la page;	(A5)+OPDA.L	^dbut du buffer;	(A5)+OFLBUF.W	status du buffer; mod	-CREUSE:	PUSHM.L	D0,D1,D2,A2,A3,A4	TCLR.B	(A5)+OSTBUF:#BBUCOM ; signal buffer creus	LOAD.L	D1,(A5)+OLGBUF	; D1.L <-- lg  creuser	LOAD.W	D0,#NBBF-1	SUB.W	D0,(A5)+ONOBUF	; D0 <-- n-1..1	LOAD.L	A2,#(A6)+OPTDB+4; A2 <-- ^dbut buffer n-1	LOAD.L	A4,(A2)+OPCD	; A4 <-- ^source pour transfert10$:	SUB.L	(A2+),D1	; ajuste OPCD	SUB.L	(A2+),D1	; ajuste OPCP	SUB.L	(A2+),D1	; ajuste OPCC	LOAD.L	A2,#(A2)+LGCE	; saute zone commune	DECJ.W,NMO D0,10$	LOAD.L	(A5)+OPFB,(A2)+OPCD	LOAD.L	D0,(A2)-LGPC+OPCC	LOAD.L	(A5)+OPDT,D0	ADD.L	D0,D1	LOAD.L	(A5)+OPFT,D0	LOAD.L	(A5)+OPDB,(A2)-LGPC+OPCD	LOAD.L	(A5)+OPDP,(A2)-LGPC+OPCP	LOAD.L	(A5)+OPDA,(A5)+OPDB	PUSHM.L	A2,A5	LOAD.W	D2,#LGCE-140$:	LOAD.B	(A5),(A2)-LGPC+OPCZ ; transfert la zone commune	INC.L	A5	INC.L	A2	DECJ.W,NMO D2,40$	POPM.L	A2,A5	LOAD.L	A3,A4	SUB.L	A3,D1		; A3 <-- ^destination	SUB.L	D0,A4		; D0 <-- nb byte  transfrer	JUMP',EQ 80$50$:	LOAD.B	(A3+),(A4+)	; cre le trou ...	DEC.L	D0	JUMP,NE 50$80$:	LOAD.L	A4,(A5)+OPFT	LOAD.L	A3,#(A5)+OCREG	CALL	_VAQQREGLE	; cherche la rglette valide ici	LOAD.L	A4,(A5)+OPFT	LOAD.L	A3,#(A5)+OCCOM	CALL	VAQQCOMMAND	; cherche la commande valide ici	POPM.L	D0,D1,D2,A2,A3,A4	RET;--------\; BOUCHE  >;========/; Creuse un trou dans un buffer quelconque.; Mmes limites que pour la routine CREUSE.; in	A6.L		^variables;	A5.L		^description du buffer  boucher;	(A5)+OPDB.L	^dbut du buffer;	(A5)+OPDT.L	^dbut du trou;	(A5)+OPFT.L	^fin du trou;	(A5)+OPFB.L	^fin du buffer;	(A5)+OPDP.L	^dbut de la page;	(A5)+ONOBUF.W	numro du buffer;	(A5)+OSTBUF.B	status du buffer; out	(A5)+OSTBUF.B	buffer "libre" (BBUFRE=1); mod	-BOUCHE:	PUSHM.L	D0,D1,D2,A2,A3,A4	TSET.B	(A5)+OSTBUF:#BBUFRE ; buffer dj bouch ?	JUMP,BS 90$		; oui => 90$	LOAD.L	D1,(A5)+OPFT	SUB.L	D1,(A5)+OPDT	; D1 <-- lg du trou  boucher	LOAD.W	D0,#NBBF-1	SUB.W	D0,(A5)+ONOBUF	; D0 <-- n-1..1	LOAD.L	A2,#(A6)+OPTDB+4; A2 <-- ^dbut buffer n-1	LOAD.L	D2,(A2)+OPCD10$:	ADD.L	(A2+),D1	; ajuste OPCD	ADD.L	(A2+),D1	; ajuste OPCP	ADD.L	(A2+),D1	; ajuste OPCC	LOAD.L	A2,#(A2)+LGCE	; saute zone commune	DECJ.W,NMO D0,10$	LOAD.L	A3,(A5)+OPFT	; A3 <-- ^destination	LOAD.L	(A2)-LGPC+OPCC,A3	LOAD.L	A4,(A5)+OPDB	ADD.L	A4,D1	LOAD.L	(A2)-LGPC+OPCD,A4	LOAD.L	A4,(A5)+OPDP	ADD.L	A4,D1	LOAD.L	(A2)-LGPC+OPCP,A4	PUSHM.L	D2,A2,A5	LOAD.W	D2,#LGCE-140$:	LOAD.B	(A2)-LGPC+OPCZ,(A5) ; transfert la zone commune	INC.L	A5	INC.L	A2	DECJ.W,NMO D2,40$	POPM.L	D2,A2,A5	LOAD.L	A4,A3	SUB.L	A4,D1		; A4 <-- ^source	LOAD.L	D0,A4	SUB.L	D0,D2		; D0 <-- nb byte  transfrer	JUMP',EQ 90$50$:	LOAD.B	(-A3),(-A4)	; bouche le trou ...	DEC.L	D0	JUMP,NE 50$90$:	POPM.L	D0,D1,D2,A2,A3,A4	RET;--------\; INIBUF  >;========/; Vide tous les buffres de texte.; in	A6.L	^variables;	D0.L	^dbut mmoire libre;	D1.L	^fin mmoire libre; out	A5.L	^description du buffer principal; mod	?INIBUF:	LOAD.L	(A6)+OPTDB,D0	LOAD.L	(A6)+OPTFB,D1	LOAD.L	A5,#(A6)+OPTDB+4	LOAD.W	D0,#NBBF-110$:	LOAD.L	(A5+),D1	; init OPCD	LOAD.L	(A5+),D1	; init OPCP	LOAD.L	(A5+),D1	; init OPCC	LOAD.L	A5,#(A5)+LGCE	; saute zone commune	DECJ.W,NMO D0,10$	TSET.B	(A6)+OBUFP+OSTBUF:#BBUFRE	TSET.B	(A6)+OBUFS+OSTBUF:#BBUFRE	TSET.B	(A6)+OBUFM+OSTBUF:#BBUFRE	CLR.W	D0	CALL	INI1B		; init buffer zro	RET	.END