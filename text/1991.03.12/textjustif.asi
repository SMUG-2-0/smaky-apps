	.SBTTL	TEXTJUSTIF;--------\\; PJUSTIF >;========/; Coupe les pages dans tout le texte.; in	A5.L		^description du buffer; out	(A6)+OJUNPA.W	nb de pages; mod	D7.WPJUSTIF:	PUSHM.L	D1..D4,A3,A4	CALL	SWMO		; souris: met le sablier; Met une marque pour retrouver la position du curseur.	LOAD.B	D3,#MARQUED	CALL	INSERT		; marque la position du curseur	JUMP,NE 90$; Revient au dbut du texte et coupe toutes les pages.	CALL	VADEBUT		; revient au dbut	CLR.W	D110$:	LOAD.W	D2,(A6)+OHTP	SUB.W	D2,(A6)+OMGS	SUB.W	D2,(A6)+OMGI	; D2 <-- hauteur maximale dans la page	CALL	GIVHNUM		; D4 <-- hauteur pour numroter	SUB.W	D2,D4		; D2 <-- hauteur maximale "tout compris"20$:	LOAD.L	A4,#(A5)+OCREG	LOAD.L	A3,#(A5)+OVREG	CALL	_COPREGLE	; OVREG <-- OCREG	LOAD.L	A4,#(A5)+OCCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	_COPCOMMAND	; OVCOM <-- OCCOM	LOAD.L	A4,(A5)+OPFT	CALL	_SRCHTL		; calcul la hauteur de la ligne	LOAD.W	D4,(A6)+OTYR	; D4 <-- hauteur relle (pas forcment paire)	TEST.L	D4:#BAFFREG	; rgle ?	JUMP',BS 50$		; oui => 50$	SUB.W	D2,D4		; D2 <-- reste dans la page	JUMP',HS 50$	TEST.W	D1	JUMP',EQ 40$	COMP.W	D1,(A6)+OJUPNL	JUMP',HS 40$30$:	CALL	GOUP		; remonte d'une ligne	DEC.W	D1	JUMP,NE 30$; Insre une pseudo-fin de page, mais jamais juste aprs une rgle.40$:	LOAD.L	A4,(A5)+OPDT	CALL	PVISU	COMP.B	D3,#REGLE	; rgle juste avant ?	JUMP',NE 45$		; non => 45$	CALL	GOUP		; oui => recule avant la rgle45$:	LOAD.B	D3,#PEOP	CALL	INSERT		; insre une pseudo-fin de page	JUMP,NE 70$	JUMP	10$50$:	CALL	AVANCE	JUMP,NE 70$	TEST.L	D3:#BSPEC	; caractre spcial ?	JUMP,BC 50$		; non => 50$	TEST.L	D3:#BEOL	; fin de la ligne ?	JUMP,BC 50$		; non => 50$	INC.W	D1		; D1 <-- une ligne de plus	COMP.B	D3,#PEOL	JUMP,EQ 20$	CLR.W	D1	COMP.B	D3,#TEOP	JUMP,EQ 10$	COMP.B	D3,#PEOP	; pseudo-fin de ligne ?	JUMP,NE	20$		; non => 20$	CALL	DRECULE		; oui => enlve	JUMP	20$; Recule jusqu' la marque pour remettre le curseur  sa place; originale, puis enlve la marque.70$:	LOAD.L	A4,(A5)+OPDT75$:	CALL	PVISU	JUMP',NE 90$	COMP.B	D3,#MARQUED	JUMP,NE	75$	CALL	VAQQPART	CALL	DAVANCE		; enlve la marque90$:	CALL	_PSEUDOAV	; avance encore si pseudo-caractres	LOAD.W	D4,#MODALL	CALL	MODIF		; repeint toute la fentre	TCLR.B	(A5)+OSTATUS:#BEOPMOD	POPM.L	D1..D4,A3,A4	RET;--------\\; AJUSTIF >;========/; Justifie tout le texte, puis remet le curseur o il tait.; in	A5.L	^description du buffer; out	D7.W	erreur (ERPDP); mod	D7.WAJUSTIF:	PUSHM.L	D3,D4,A4	CALL	SWMO		; souris: met le sablier; Met une marque pour retrouver la position du curseur.	LOAD.B	D3,#MARQUED	CALL	INSERT		; marque la position du curseur	JUMP',NE 90$; Revient au dbut du texte et justifie tout.	CALL	VADEBUT		; revient au dbut20$:	CALL	JUSTLINE	; justifie une ligne	JUMP,EQ	20$	COMP.W	D7,#ERTPDP	JUMP',EQ 50$	CLR.W	D7; Recule jusqu' la marque pour remettre le curseur  sa place; originale, puis enlve la marque.50$:	PUSH.W	D7	LOAD.L	A4,(A5)+OPDT60$:	CALL	PVISU	JUMP',NE 70$	COMP.B	D3,#MARQUED	JUMP,NE	60$	CALL	VAQQPART	CALL	DAVANCE		; enlve la marque70$:	POP.W	D790$:	PUSH.W	D7	CALL	_PSEUDOAV	; avance encore si pseudo-caractres	LOAD.W	D4,#MODALL	CALL	MODIF		; repeint toute la fentre	POP.W	D7	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RJUSTIF >;========/; Justifie contre en bas (jusqu' la prochaine rglette) aprs; avoir mis/enlev/modifi une rglette.; Le curseur n'est pas dplac !; in	A5.L	^description du buffer;	A4.L	^rgle modifie ou ^nil (zro); out	-; mod	D7.WRJUSTIF:	PUSHM.L	D2..D4,A3,A4	CALL	SWMO		; souris: met le sablier; Met une marque pour retrouver la position du curseur.	LOAD.B	D3,#MARQUED	CALL	INSERT		; marque la position du curseur	JUMP,NE	90$; Recule jusqu' la premire rglette rencontre.	CALL	AVANCE		; si on est sur la rglette,				; avance juste aprs !	LOAD.L	D4,A4		; D4 <-- ^rgle modifie/^nil	LOAD.L	A4,(A5)+OPFT	LOAD.L	A3,#(A5)+OCREG	CLR.B	D2		; D2 <-- nb de rgles remontes20$:	INC.B	D2		; D2 <-- un rgle de plus remonte	CALL	_VAQQREGLE	; A4 <-- ^o aller	JUMP',NE 30$		; rglette pas trouve => 30$	TEST.L	D4		; ^nil ?	JUMP',EQ 25$		; oui => 25$	COMP.L	D4,A4		; est-on remont jusqu' la rgle modifie ?	JUMP,LO 20$		; non => 20$ (remonte encore)25$:	CALL	VAQQPART	; recule sur la rglette	CALL	AVANCE		; puis avance juste aprs	JUMP'	40$30$:	CALL	VADEBUT		; revient au dbut; Justifie jusqu' la prochaine rglette.40$:	CALL	JUSTLINE	; justifie une ligne	JUMP',NE 50$	COMP.B	D3,#REGLE	JUMP,NE	40$50$:	LOAD.W	D4,#MODALL	CALL	MODIF		; faudra tout repeindre; Recule jusqu' la marque pour remettre le curseur  sa place; originale, puis enlve la marque. Si elle n'est pas trouve,; cherche contre en bas (avance).	LOAD.L	A4,(A5)+OPDT	LOAD.L	D4,#-1		; D4 <-- remonte jusqu'en haut	DEC.B	D2		; est-on remont plus que juste une rgle ?	JUMP',EQ 70$		; non => 70$	LOAD.L	D4,#10		; oui => remonte juste 10 caractres70$:	DEC.L	D4	JUMP',EQ 75$	CALL	TPVISU	JUMP',NE 75$	COMP.B	D3,#MARQUED	JUMP,NE	70$	CALL	VAQQPART	CALL	DAVANCE		; enlve la marque	JUMP'	90$75$:				; cherche la marque contre en bas =>	CALL	TNVISU	JUMP',NE 90$	COMP.B	D3,#MARQUED	JUMP,NE	75$	CALL	VAQQPART	CALL	DRECULE		; enlve la marque90$:	CALL	_PSEUDOAV	; avance encore si pseudo-caractres	POPM.L	D2..D4,A3,A4	RET;--------\\; ZJUSTIF >;========/; Justifie une zone d'une longueur quelconque qui dbute par le; caractre MARQUED et qui est termine par le caractre MARQUEF.; Les marques ne sont pas enleves. Il faut encore utiliser l'une; des routines ZDJUSTIF ou ZFJUSTIF.; in	A5.L	^description du buffer; out	-; mod	D7.WZJUSTIF:	PUSHM.L	D1..D4,A4	CALL	SWMO		; souris: met le sablier	CLR.W	(A6)+OJUNLN	CLR.W	(A6)+OJUNLO; Cherche en arrire la marque de dbut, puis va au dbut de; la ligne.10$:	CALL	RECULE		; recule sur la marque de dbut	JUMP',NE 15$	COMP.B	D3,#MARQUED	JUMP,NE 10$	CALL	GOBOL		; va au dbut de la ligne; Justifie jusqu' la marque de fin.15$:	LOAD.W	D4,#MODLIN	CALL	MODIF		; une ligne modifie	TCLR.B	(A6)+OFLAGS:#BMRKF	CLR.W	D1	CLR.W	D2	CLR.B	D320$:	COMP.B	D3,#TEOT	; fin du texte ?	JUMP,EQ 80$		; oui => 80$	INC.W	D2		; D2 <-- une ligne modifie de plus	CALL	MJUSTLINE	; justifie ligne(s) suivante(s)	JUMP',NE 30$		; si chang => 30$	COMP.B	D3,#REGLE	JUMP',NE 25$	INC.W	D1		; D1 <-- une rgle passe25$:	TEST.B	(A6)+OFLAGS:#BMRKF ; marque de fin rencontre ?	JUMP,BC 20$		; non => 20$	JUMP'	50$30$:	COMP.B	D3,#REGLE	JUMP',NE 35$	INC.W	D1		; D1 <-- une rgle passe35$:	TEST.B	(A6)+OFLAGS:#BMRKF ; marque de fin rencontre ?	JUMP,BC 20$		; non => 20$; Justifie encore jusqu' ce qu'il n'y ai plus de boulversement.	INC.W	D2		; D2 <-- faudra tout repeindre !	COMP.B	D3,#PEOL	; fin du paragraphe ?	JUMP',NE 50$		; oui => 50$40$:	INC.W	D2		; D2 <-- une ligne modifie de plus	CALL	MJUSTLINE	; justifie ligne(s) suivante(s)	JUMP',EQ 45$		; si inchang => 45$	COMP.B	D3,#PEOL	; fin du paragraphe ?	JUMP,EQ	40$		; non => 40$45$:	COMP.B	D3,#REGLE	JUMP',NE 50$	INC.W	D1		; D1 <-- une rgle passe50$:	TEST.W	D1		; une rglette passe ?	JUMP',EQ 80$		; non => 80$; Justifie jusqu' la prochaine rglette.60$:	INC.W	D2		; D2 <-- une ligne modifie de plus	CALL	JUSTLINE	; justifie une ligne	JUMP',NE 80$	COMP.B	D3,#REGLE	JUMP,NE	60$; Signal que tout est modifi si plus d'une ligne a t justifie.80$:	COMP.W	D2,#1		; plus d'une ligne modifie ?	JUMP',LS 85$		; non => 85$	LOAD.W	D4,#MODALL	; oui =>	CALL	MODIF		; signal tout modifi85$:	POPM.L	D1..D4,A4	RET;---------\\; ZDJUSTIF >;=========/; Enlve les marques de dbut/fin et positionne le curseur; au dbut.; in	A5.L	^description du buffer; out	-; mod	D7.WZDJUSTIF:	PUSH.W	D3; Recule jusqu' la marque de fin, puis enlve la marque.20$:	CALL	RECULE		; recule d'un caractre	JUMP',NE 40$	COMP.B	D3,#MARQUEF	; marque trouve ?	JUMP,NE	20$		; non => 20$				; oui =>	CALL	DAVANCE		; enlve la marque; Recule jusqu' la marque de dbut, puis enlve la marque.40$:	CALL	RECULE		; recule d'un caractre	JUMP',NE 90$	COMP.B	D3,#MARQUED	; marque trouve ?	JUMP,NE	40$		; non => 40$				; oui =>	CALL	DAVANCE		; enlve la marque90$:	CALL	_PSEUDOAV	; avance encore si pseudo-caractres	POP.W	D3	RET;---------\\; ZFJUSTIF >;=========/; Enlve les marques de dbut/fin et positionne le curseur;  la fin.; in	A5.L	^description du buffer; out	-; mod	D7.WZFJUSTIF:	PUSH.W	D3; Recule jusqu' la marque de dbut, puis enlve la marque.20$:	CALL	RECULE		; recule d'un caractre	JUMP',NE 40$	COMP.B	D3,#MARQUED	; marque trouve ?	JUMP,NE	20$		; non => 20$				; oui =>	CALL	DAVANCE		; enlve la marque; Avance jusqu' la marque de fin, puis enlve la marque.40$:	CALL	AVANCE		; avance d'un caractre	JUMP',NE 90$	COMP.B	D3,#MARQUEF	; marque trouve ?	JUMP,NE	40$		; non => 40$				; oui =>	CALL	DRECULE		; enlve la marque90$:	CALL	_PSEUDOAV	; avance encore si pseudo-caractres	POP.W	D3	RET;--------\\; QJUSTIF >;========/; Justifie le moins possible aprs avoir insr/dtruit juste; quelques caractres dans une ligne.; in	A5.L	^description du buffer; out	-; mod	D7.WQJUSTIF:	PUSHM.L	D2,D3,D4,A4	CLR.W	(A6)+OJUNLN	CLR.W	(A6)+OJUNLO; Met une marque pour retrouver la position du curseur.	LOAD.B	D3,#MARQUED	CALL	INSERT		; marque la position du curseur	JUMP,NE	90$; Si la ligne en dessus fait partie du mme paragraphe, vrifie si elle; se justifie de la mme faon.	CALL	GOBOL		; va au dbut de la ligne	LOAD.L	A4,(A5)+OPDT	CALL	PVISU		; D3 <-- caractre fin ligne en dessus	JUMP',NE 40$	COMP.B	D3,#PEOL	JUMP',NE 40$	CALL	GOUP		; recule au dbut de la ligne en dessus	CALL	MJUSTLINE	; justifie ligne en dessus	JUMP',EQ 40$		; si inchang => 40$	LOAD.W	D4,#MODALL	CALL	MODIF		; signal tout modifi	JUMP'	45$; Justifie le paragraphe. Arrte sitt qu'une ligne n'est plus change,; ou si la fin du paragraphe est rencontre. Si le paragraphe n'a plus; le mme nombre de lignes, il faudra repeindre toute la fentre.40$:	CALL	CNTNBLP		; D4 <-- nb de lignes du paragraphe	CLR.W	D245$:	INC.W	D2		; D2 <-- une ligne modifie de plus	CALL	MJUSTLINE	; justifie ligne(s) suivante(s)	JUMP',EQ 50$		; si inchang => 50$	COMP.B	D3,#PEOL	; fin du paragraphe ?	JUMP,EQ	45$		; non => 45$50$:	COMP.B	D3,#PEOL	; fin du paragraphe ?	JUMP',EQ 55$		; non => 55$	COMP.W	D2,D4		; mme nombre de lignes ?	JUMP',EQ 55$		; oui => 55$				; non =>	LOAD.W	D4,#MODALL	; faudra repeindre toute la fentre !	CALL	MODIF		; signal modification	JUMP'	60$55$:	ADD.W	D2,#MODLIN-1	LOAD.W	D4,D2		; D4 <-- refait juste qq lignes	CALL	MODIF		; signal qq lignes modifies; Recule jusqu' la marque pour remettre le curseur  sa place; originale, puis enlve la marque.60$:	CALL	RECULE		; recule d'un caractre	JUMP',NE 90$	COMP.B	D3,#MARQUED	; marque trouve ?	JUMP,NE	60$		; non => 60$				; oui =>	CALL	DAVANCE		; enlve la marque90$:	CALL	_PSEUDOAV	; avance encore si pseudo-caractres	POPM.L	D2,D3,D4,A4	RET;--------\\; CNTNBLP >;========/; Compte le nombre de lignes d'un paragraphe, depuis la; position du curseur.; in	A5.L	^description du buffer; out	D4.W	nombre de lignes (1..n); mod	D4.W, D7.WCNTNBLP:	PUSHM.L	D3,A4	LOAD.L	A4,(A5)+OPFT	CLR.W	D410$:	INC.W	D4		; D4 <-- une ligne de plus20$:	CALL	QUICKDOWN	; A4 <-- avance rapidement	JUMP',NE 90$	TEST.L	D3:#BEOL	; fin de la ligne ?	JUMP,BC 20$		; non => 20$				; oui =>	COMP.B	D3,#PEOL	; fin du paragraphe ?	JUMP,EQ	10$		; non => 10$90$:	POPM.L	D3,A4	RET;----------\\; MJUSTLINE >;==========/; Identique  JUSTLINE, mais indique si la ligne justfie  t modifie.; ATTENTION:	Avant l'emploi de plusieurs MJUSTLINE, il ne faut pas;		oublier de mettre  zro OJUNLN et OJUNLO !!; in	A5.L	^description du buffer; out	D3.B	dernier caractre TEOL/PEOL/TEOP/PEOP/TEOT;	D7.W	EQ	=> ligne inchange;		NE	=> ligne modifie; mod	D3.W, D7.WMJUSTLINE:	PUSHM.L	D2,D4,A3,A4	LOAD.L	A4,(A5)+OPFT	CALL	_SRCDOWN	; A4 <-- ^dbut ligne suivante	LOAD.L	A3,A4		; A3 <-- ^dbut ligne suivante; Compte la longueur du ou des SAJEXMs au dbut de la ligne suivante.	CLR.L	D2		; D2 <-- lg SAJEXM(s)20$:	CALL	NVISU		; D3 <-- caractre dbut ligne suivante	JUMP',NE 40$	COMP.B	D3,#SAJEXM	JUMP',NE 40$	SR.W	D3,#8		; D3 <-- longueur du SAJEXM	ADD.W	D2,D3		; D2 <-- un SAJEXM de plus	JUMP	20$; Justifie juste la ligne o est le curseur.40$:	CALL	JUSTLINE	; justifie la ligne	JUMP',EQ 50$		; fin du texte ?	LOAD.B	D3,#TEOT	; oui => signal "end of text"; Remet le(s) SAJEXM(s) enlev(s) au dbut de la nouvelle ligne,; et positionne le curseur avant !; S'ils y sont encore, n'ajoute rien.50$:	LOAD.B	D4,D3		; D4 <-- dernier caractre	LOAD.L	A4,(A5)+OPFT	CALL	NVISU		; D3 <-- premier caractre nouvelle ligne	JUMP',NE 80$	COMP.B	D3,#SAJEXM	; est-ce que les SAJEXMs sont toujours l ?	JUMP',EQ 80$		; oui => 80$				; non =>	SET.B	(A6)+OCVAR	; met chasse variable	LOAD.L	A4,(A5)+OPDT	CALL	JUSTINSSM	; remet SAJEXM(s) au dbut ligne suivante60$:	COMP.L	A4,(A5)+OPDT	JUMP',HS 80$	CALL	RECULE		; recule dbut SAJEXM(s) ajout(s)	JUMP	60$80$:	LOAD.B	D3,D4		; D3 <-- dernier caractre	LOAD.W	D7,#ERTNOT	; D7 <-- ligne modifie	COMP.L	A3,(A5)+OPFT	; dbut ligne suivante dplac ?	JUMP',NE 90$		; oui => 90$				; non =>	COMP.B	D3,#PEOL	JUMP',NE 85$	LOAD.W	D4,(A6)+OJUNLO	COMP.W	D4,(A6)+OJUNLN	; mme nombre de lignes avant et aprs ?	JUMP',NE 90$		; non => 90$85$:				; oui =>	CLR.W	D7		; D7 <-- ligne inchange90$:	POPM.L	D2,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; JUSTLINE >;=========/; Justifie une ligne dans un mode quelconque.; Attention: ne met pas  jour MODIF !; in	A5.L	^description du buffer; out	D3.B	dernier caractre TEOL/PEOL/TEOP/PEOP;	D7.W	ok/erreur; mod	D3.W, D7.WJUSTLINE:	PUSHM.L	D0..D2,D4,D5,A3,A4	PUSH.W	(A5)+OMODIF; Met dans OCVAR le mode de justification de la ligne (chasse fixe; ou variable) selon le premier caractre de la ligne.; Si la ligne contient <SAJEXM><COMMAND><car>.., il faut sauter les; sajex pour atteindre la commande !	LOAD.L	A4,#(A5)+OCCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	_COPCOMMAND	; OVCOM <-- OCCOM	LOAD.L	A4,(A5)+OPFT02$:	CALL	NVISU		; D3 <-- premier caractre de la ligne	JUMP',NE 03$	COMP.B	D3,#SAJEXM	JUMP,EQ 02$	COMP.B	D3,#MARQUED	JUMP,EQ 02$	COMP.B	D3,#MARQUEF	JUMP,EQ 02$03$:	CLR.W	D4	LOAD.B	D4,(A5)+OVCOM+OCOMNOG ; D4 <-- no du gencar	MUL.WU	D4,#LGGC	LOAD.L	A4,#(A6)+OBUGC	ADD.L	A4,D4		; A4 <-- ^dans OBUGC	LOAD.W	(A6)+OCXL,(A4)+OGCX	LOAD.B	(A6)+OCVAR,(A4)+OGCVAR	CALL	JUSTGMG		; D5 <-- marge gauche	CLR.L	D4	LOAD.W	D4,(A5)+OCREG+OREGMGD ; D4 <-- largeur pour la ligne; Si on est dans la premire ligne d'un paragraphe, tient compte du; renforcement.	LOAD.L	A4,(A5)+OPDT05$:	CALL	PVISU		; D3 <-- caractre avant la ligne	JUMP',NE 10$	COMP.B	D3,#PEOP	; ATTENTION: les caractres PEOP ou TEOP	JUMP,EQ 05$		; peuvent couper un paragraphe en deux !!!	COMP.B	D3,#TEOP	JUMP,EQ 05$	COMP.B	D3,#PEOL	; 2..n ime ligne ?	JUMP',EQ 15$		; oui => 15$10$:;;?	LOAD.L	A4,(A5)+OPFT;;?	CALL	_SRCDOWN;;?	JUMP',NE 15$;;?	CALL	PVISU		; D3 <-- dernier car. de la ligne;;?	COMP.B	D3,#PEOL;;?	JUMP',NE 15$	LOAD.W	D5,(A5)+OCREG+OREGRENF ; D5 <-- renforcement15$:	TEST.B	(A6)+OCVAR	; chasse variable ?	JUMP',T 20$		; oui => 20$	DIV.WU	D5,(A6)+OCXL	MUL.WU	D5,(A6)+OCXL	; D4 <-- multiple de OCXL (chasse fixe)	DIV.WU	D4,(A6)+OCXL	MUL.WU	D4,(A6)+OCXL	; D4 <-- multiple de OCXL (chasse fixe); Prend le mode AVANT de justifier la ligne, car aprs JUSTLID, on est; dj au dbut de la ligne suivante (donc peut-tre dans un autre mode) !20$:	LOAD.B	D0,(A5)+OCREG+OREGJUST	CALL	JUSTLID		; justifie en drapeau  droite	JUMP',NE 90$	COMP.B	D3,#IMAGE	; image ?	JUMP',EQ 70$		; oui => 70$	COMP.B	D3,#REGLE	; rglette ?	JUMP',EQ 90$		; oui => 90$	COMP.B	D3,#TAB		; tabulateur(s) dans la ligne ?	JUMP',NE 30$		; non => 30$	LOAD.B	D3,#PEOL	; oui => c'est bon comme a !	JUMP'	90$30$:	COMP.B	D0,#JUSTD	JUMP',EQ 40$	COMP.B	D0,#JUSTG	JUMP',EQ 50$	COMP.B	D0,#JUSTC	JUMP',EQ 60$	CALL	JUSTLIA		; justifie align	JUMP'	90$40$:	CALL	JUSTMDGC	; justifie en drapeau  droite	JUMP'	90$50$:	CALL	JUSTLIG		; justifie en drapeau  gauche	JUMP'	90$60$:	CALL	JUSTLIC		; justifie centr	JUMP'	90$70$:	CALL	JUSTIMAGE	; justifie une image90$:	POP.W	(A5)+OMODIF	POPM.L	D0..D2,D4,D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; JUSTGMG >;--------/; Donne la marge gauche, en tenant compte d'une ventuelle indentation.; in	-; out	D5.L	marge gauche; mod	D5.L, D7.WJUSTGMG:	PUSHM.L	D0..D4,A2..A4	CLR.L	D5	LOAD.W	D5,(A5)+OCREG+OREGMGG ; D5 <-- marge gauche (sans indentation); Cherche s'il existe un indentateur dans la rgle. Si non, on a rien;  faire de spcial.	LOAD.L	A3,#(A5)+OCREG	; A3 <-- ^rglette selon curseur	CALL	IFTABI		; indentateur dans la rgle ?	JUMP,NE 90$		; non => 90$; Si oui, il faut remonter jusqu'au dbut du paragraphe pour chercher; s'il est indent.	LOAD.L	A4,(A5)+OPFT05$:	CALL	JNVISU		; D3 <-- premier caractre de la ligne	JUMP',NE 10$	COMP.B	D3,#SAJEXM	JUMP,EQ 05$	COMP.B	D3,#SAJEXS	JUMP,EQ 05$	COMP.B	D3,#SAJEXT	JUMP,EQ 05$	COMP.B	D3,#TAB		; ligne commence par un tabulateur ?	JUMP,EQ 90$		; oui => 90$10$:	PUSH.L	A3;	LOAD.L	A4,#(A5)+OCREG;	LOAD.L	A3,#(A5)+OVREG;	CALL	_COPREGLE	; OVREG <-- OCREG	LOAD.L	A4,#(A5)+OCCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	_COPCOMMAND	; OVCOM <-- OCCOM	POP.L	A3	LOAD.L	A4,(A5)+OPDT	CLR.W	D0		; D0 <-- clear tous les flags;;?	TSET.L	D0:#0		; D0 <-- on est dans cette ligne	JUMP'	21$20$:	TEST.L	D0:#2		; est-on au dbut du paragraphe ?	JUMP,BS 90$		; oui => 90$;;?	TCLR.L	D0:#0		; D0 <-- on est dans une ligne prcdente21$:	TCLR.L	D0:#1		; D0 <-- pas (encore) de tabulateur dans cette ligne22$:	CALL	PVISU		; D3 <-- caractre prcdent	JUMP,NE 90$	COMP.B	D3,#TEOL	; dbut du paragraphe ?	JUMP',EQ 24$		; oui => 24$	COMP.B	D3,#TEOP	JUMP',EQ 24$	COMP.B	D3,#PEOP	JUMP',EQ 24$	COMP.B	D3,#IMAGE	JUMP',EQ 24$	COMP.B	D3,#REGLE	JUMP',EQ 24$	COMP.B	D3,#PEOL	; dbut de la ligne ?	JUMP',EQ 25$		; oui => 25$	COMP.B	D3,#SAJEXT	JUMP,NE 22$	TSET.L	D0:#1		; D0 <-- un tabulateur dans cette ligne	JUMP	22$24$:	TSET.L	D0:#2		; D0 <-- on est au dbut du paragraphe25$:	TEST.L	D0:#1		; tabulateur(s) dans cette ligne ?	JUMP,BC 20$		; non => 20$; Cherche si l'un des tabulateurs de la ligne est l'indentateur.	LOAD.L	A2,A4		; A2 <-- ^dbut de la ligne	PUSHM.L	A3,A4;	LOAD.L	A4,#(A5)+OVREG;	LOAD.L	A3,#(A6)+OSREG;	CALL	_COPREGLE	; OSREG <-- OVREG	LOAD.L	A4,#(A5)+OVCOM	LOAD.L	A3,#(A6)+OSCOM	CALL	_COPCOMMAND	; OSCOM <-- OVCOM	POPM.L	A3,A4	CALL	NVISU		; saute le PEOL	CLR.W	D2		; D2 <-- position dans la ligne	CLR.W	D4		; D4 <-- pas encore d'indentateur(s) trouv(s)30$:	CALL	NVISU		; D3 <-- caractre suivant dans la ligne	JUMP',NE 40$	CALL	IFIEOL		; fin de la ligne ?	JUMP',EQ 40$		; oui => 40$	CALL	VADDLGC		; D2 <-- avance dans la ligne	COMP.B	D3,#SAJEXT	JUMP,NE 30$	LOAD.W	D1,D2	TEST.B	(A6)+OCVAR	; chasse variable ?	JUMP',T 32$		; oui => 32$	SUB.W	D2,(A6)+OCXL	; D2 <-- arrondi au caractre prcdent32$:	DEC.W	D2		; si juste dessus, NEXTTAB donne le suivent !	CALL	_NEXTTAB	; D1 <-- position et type du tabulateur	EX.L	D1,D2	JUMP',NE 40$	TEST.L	D1:#BTABIND1	JUMP,BC 30$	TEST.L	D1:#BTABIND2	; indentateur ?	JUMP,BC 30$		; non => 30$	AND.W	D1,#MASKTAB	TEST.B	(A6)+OCVAR	; chasse variable ?	JUMP',T 35$		; oui => 35$	AND.L	D1,#H'FFFF	DIV.WU	D1,(A6)+OCXL	SWAP.W	D1	TEST.W	D1		; reste qq chose ?	JUMP',EQ 34$		; non => 34$	ADD.L	D1,#H'10000	; oui => arrondi suprieur (D1=D1+1)34$:	SWAP.W	D1	MUL.WU	D1,(A6)+OCXL	; D1 <-- multiple de OCXL (chasse fixe)35$:	COMP.W	D1,D2		; est-on sur l'indentateur ?	JUMP,NE 30$		; non => 30$				; oui =>;;?	TEST.L	D0:#0		; est-on dans cette ligne ?;;?	JUMP',BS 90$		; oui => 90$	LOAD.W	D4,D1		; D4 <-- pos dernier indentateur de la ligne	JUMP	30$40$:	TEST.W	D4		; indentateur(s) dans la ligne ?	JUMP',EQ 45$		; non => 45$	LOAD.W	D5,D4		; D5 <-- augmente la marge gauche de l'indentation	JUMP'	90$45$:	PUSH.L	A3;	LOAD.L	A4,#(A6)+OSREG;	LOAD.L	A3,#(A5)+OVREG;	CALL	_COPREGLE	; OVREG <-- OSREG	LOAD.L	A4,#(A6)+OSCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	_COPCOMMAND	; OVCOM <-- OSCOM	POP.L	A3	LOAD.L	A4,A2		; A4 <-- ^revient au dbut de la ligne	JUMP	20$90$:	POPM.L	D0..D4,A2..A4	RET;--------\\; JUSTLID >;========/; Justifie une ligne en drapeau.; N'ajoute pas de SAJEXM et ne coupe pas  l'intrieur du dernier mot.; Il faut tre au dbut de la ligne !; in	A5.L	^description du buffer;	D4.W	largeur maximale pour la ligne;	D5.W	marge gauche; out	D1.W	nb d'espaces (0..n);	D2.W	largeur de la ligne (avec la marge gauche);	D3.B	dernier caractre TEOL/PEOL/TEOP/PEOP/TAB/IMAGE/REGLE/TEOT;	D7.W	ok/erreur; mod	D1.W, D2.W D3.W, D7.WJUSTLID:	PUSHM.L	D0,D4..D6,A4	CLR.W	D202$:	CALL	JAVANCE		; D3 <-- premier caractre de la ligne	JUMP,NE 95$	INC.W	D2		; D2 <-- un caractre de plus avanc	COMP.B	D3,#COMMAND	JUMP,EQ	02$	COMP.B	D3,#IMAGE	; "ligne" avec une image ?	JUMP,EQ 90$		; oui => 90$	COMP.B	D3,#REGLE	; "ligne" avec une rglette ?	JUMP,EQ 90$		; oui => 90$05$:	CALL	RECULE		; recule TOUS les caractres avancs	DEC.W	D2	JUMP,NE	05$	CLR.L	D2	LOAD.W	D2,D5		; D2 <-- marge ou renfoncement	TEST.B	(A6)+OCVAR	; chasse variable ?	JUMP',T 08$		; oui => 08$	DIV.WU	D2,(A6)+OCXL	; non => nb entier d'espaces08$:	CALL	JUSTINSSM	; met SAJEXM pour faire la marge gauche	JUMP,NE 95$	CLR.L	D0		; D0 <-- nb caractres dans mot / flag tab	CLR.W	D1		; D1 <-- nb de mots	LOAD.W	D2,D5		; D2 <-- position dans ligne10$:	COMP.W	D2,D4		; largeur ligne atteinte ?	JUMP,HI	40$		; oui => 40$	CALL	JAVANCE		; D3 <-- caractre en avant	JUMP,NE	90$		; EOB => 90$	COMP.B	D3,#COMMAND	JUMP,EQ	10$	COMP.B	D3,#TEOL	JUMP,EQ	90$	COMP.B	D3,#IMAGE	JUMP,EQ 30$	COMP.B	D3,#REGLE	JUMP,EQ 30$	COMP.B	D3,#TEOP	JUMP,EQ	90$	COMP.B	D3,#PEOP	JUMP,EQ	90$	COMP.B	D3,#TAB	JUMP',NE 15$	LOAD.W	D5,D2		; D5 <-- largeur jusqu'au TAB	CALL	JUSTTAB	JUMP,NE 95$	TSET.L	D0:#16		; D0 <-- tabulateur rencontr	LOAD.W	D0,#1		; D0 <-- un caractre (le tab)	CLR.W	D1		; D1 <-- ignore tout avant tab	JUMP'	20$15$:	INC.W	D0		; D0 <-- +1 caractre	CALL	ADDLGC		; D2 <-- compte largeur car.	COMP.B	D3,#SPACE	JUMP,EQ	10$20$:	COMP.W	D2,D4		; largeur ligne atteinte ?	JUMP,HI	40$		; oui => 40$	CALL	JAVANCE		; D3 <-- caractre en avant	JUMP,NE	90$		; EOB => 90$	COMP.B	D3,#COMMAND	JUMP,EQ	20$	COMP.B	D3,#TEOL	JUMP,EQ	90$	COMP.B	D3,#IMAGE	JUMP',EQ 30$	COMP.B	D3,#REGLE	JUMP',EQ 30$	COMP.B	D3,#TEOP	JUMP,EQ	90$	COMP.B	D3,#PEOP	JUMP,EQ	90$	COMP.B	D3,#TAB	JUMP',NE 25$	LOAD.W	D5,D2		; D5 <-- largeur jusqu'au TAB	CALL	JUSTTAB	JUMP,NE 95$	TSET.L	D0:#16		; D0 <-- tabulateur rencontr	LOAD.W	D0,#1		; D0 <-- un caractre (le tab)	CLR.W	D1		; D1 <-- ignore tout avant tab	JUMP'	20$25$:	INC.W	D0		; D0 <-- +1 caractre	LOAD.W	D6,D2	CALL	ADDLGC		; D2 <-- compte largeur car.	COMP.B	D3,#SPACE	JUMP,NE	20$	CLR.W	D0		; D0 <-- rz avance dans mot	INC.W	D1		; D1 <-- +1 mot	LOAD.W	D5,D6		; D5 <-- lg jusque l, sans dernier SPACE	JUMP	10$30$:				; image/rglette dans la ligne =>	CALL	RECULE		; recule avant image/rglette	LOAD.B	D3,#TEOL	CALL	INSERT		; met une vritable fin de ligne !	JUMP'	95$40$:	LOAD.W	D2,D5		; D2 <-- largeur sans le dernier mot	TEST.L	D0:#16		; tabulateur(s) dans la ligne ?	JUMP',BS 45$		; oui => 45$				; non =>	TEST.W	D1		; un seul mot ?	JUMP',EQ 80$		; oui => 80$	DEC.W	D1		; non => ne compte pas le dernier mot	JUMP'	50$45$:	TEST.W	D1		; un seul mot ?	JUMP',EQ 50$		; oui => 50$	DEC.W	D1		; non => ne compte pas le dernier mot50$:	TEST.W	D0		; qq chose  reculer ?	JUMP',EQ 80$		; non => 80$60$:				; oui =>	CALL	RECULE		; recule le mot " cheval"	JUMP',NE 80$	COMP.B	D3,#COMMAND	JUMP,EQ	60$	COMP.B	D3,#MARQUED	; ignore la marque	JUMP,EQ	60$	COMP.B	D3,#MARQUEF	; ignore la marque	JUMP,EQ	60$	DEC.W	D0	JUMP,NE	60$80$:	LOAD.B	D3,#PEOL	CALL	IFINSERT	; insre PEOL si ncessaire	JUMP',NE 95$90$:	CLR.W	D7		; D7 <-- ok95$:	POPM.L	D0,D4..D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; JUSTTAB >;========/; Ajoute un espace variable juste aprs un tabulateur.; La longueur de cet espace dpend du type du tabulateur.; in	D2.W	largeur jusqu'avant le tabulateur; out	D2.W	largeur aprs le tabulateur;	D7.W	erreur; mod	D2.W, D7.WJUSTTAB:	PUSHM.L	D1,D3,D4,A3,A4	LOAD.W	D1,D2		; D1 <-- position avant le tabulateur	LOAD.W	D4,D2	LOAD.B	D3,#'.	CLR.W	D2	CALL	ADDLGC		; D2 <-- lg du point	SR.W	D2,#1		; D2 <-- 1/2 de chaque ct	ADD.W	D2,D4		; D2 <-- avance de 1/2 point	LOAD.L	A3,#(A5)+OCREG	; A3 <-- ^rglette selon curseur	CALL	_NEXTTAB	; D2 <-- position aprs le tabulateur	JUMP',EQ 10$		; ok => 10$				; tabulateur pas trouv =>	LOAD.W	D2,(A6)+OCXL	; D2 <-- avance si aucun tabulateur	LOAD.L	A4,A3		; A4 <-- ^rglette	CALL	GMXTAB		; D1 <-- tabulateur le plus  droite	JUMP,NE 60$		; si aucun tabulateur => 60$05$:				; si plus de tabulateur =>	LOAD.W	D2,#(2^BTABGAU)-1 ; D2 <-- position maximale (a dborde)	CLR.W	D7		; D7 <-- ok	JUMP	90$10$:	TEST.L	D2:#BTABIND1	JUMP',BC 12$	TEST.L	D2:#BTABIND2	JUMP',BS 20$12$:	TEST.L	D2:#BTABNUM	JUMP',BS 50$	TEST.L	D2:#BTABCEN	JUMP',BS 40$	TEST.L	D2:#BTABGAU	JUMP',BS 30$				; tabulateur normal =>	SUB.W	D2,D1		; D2 <-- lg  avancer	JUMP	60$20$:				; indentation =>	AND.W	D2,#MASKTAB	SUB.W	D2,D1		; D2 <-- lg  avancer (dans la 1re ligne)	COMP.W	D2,(A6)+OCXL	; au moins un caractre ?	JUMP,LT 05$		; non => 05$	JUMP'	60$30$:				; tabulateur gauche =>	AND.W	D2,#MASKTAB	SUB.W	D2,D1		; D2 <-- lg max du tabulateur	CALL	JUSTGLG		; D4 <-- lg "rentre" dans le tabulateur	SUB.W	D2,D4		; D2 <-- lg pour le tabulateur	JUMP'	60$40$:				; tabulateur centr =>	AND.W	D2,#MASKTAB	SUB.W	D2,D1		; D2 <-- lg max du tabulateur	CALL	JUSTGLG		; D4 <-- lg "rentre" dans le tabulateur	SR.W	D4,#1		; D4 <-- seulement la moiti	SUB.W	D2,D4		; D2 <-- lg pour le tabulateur	JUMP'	60$50$:				; tabulateur numrique =>	AND.W	D2,#MASKTAB	SUB.W	D2,D1		; D2 <-- lg max du tabulateur	CALL	JUSTNLG		; D4 <-- lg "rentre" dans le tabulateur	SUB.W	D2,D4		; D2 <-- lg pour le tabulateur60$:	COMP.W	D2,(A6)+OCXL	; au moins un caractre ?	JUMP',GE 70$		; oui => 70$	LOAD.W	D2,(A6)+OCXL	; non => avance un minimum !70$:	TEST.B	(A6)+OCVAR	; chasse variable ?	JUMP',T 75$		; oui => 75$	AND.L	D2,#H'FFFF	; non =>	DIV.WU	D2,(A6)+OCXL	; D2 <-- nb d'espaces entiers	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- reste	TEST.W	D3		; reste qq chose ?	JUMP',EQ 72$		; non => 72$	INC.W	D2		; oui => arrondi suprieur72$:	CALL	JUSTINSST	; insre un espace variable	MUL.WU	D2,(A6)+OCXL	JUMP'	80$75$:	CALL	JUSTINSST	; insre un espace variable80$:	ADD.W	D2,D1		; D2 <-- position aprs le tabulateur90$:	POPM.L	D1,D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; JUSTGLG >;--------/; Calcul la longueur rentre pour un tabulateur gauche.; La moiti permet de raliser un tabulateur centr.; in	-; out	D4.W	lg "rentre"; mod	D4.W, D7.WJUSTGLG:	PUSHM.L	D2,D3,A3,A4	LOAD.L	A4,#(A5)+OCREG	LOAD.L	A3,#(A5)+OVREG	CALL	_COPREGLE	; OVREG <-- OCREG	LOAD.L	A4,#(A5)+OCCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	_COPCOMMAND	; OVCOM <-- OCCOM	LOAD.L	A4,(A5)+OPFT	CLR.L	D420$:	CALL	NVISU		; D3 <-- caractre suivant	JUMP',NE 90$	CALL	IFIEOL	JUMP',EQ 90$	COMP.B	D3,#TAB	JUMP',EQ 90$	COMP.B	D3,#SAJEXM	JUMP,EQ	20$	COMP.B	D3,#SAJEXT	JUMP,EQ	20$	COMP.B	D3,#SAJEXS	JUMP,EQ	20$	COMP.B	D3,#MARQUED	JUMP,EQ	20$	COMP.B	D3,#MARQUEF	JUMP,EQ	20$	CLR.W	D2	CALL	VADDLGC		; D2 <-- lg du caractre	ADD.W	D4,D2		; D4 <-- augmente lg "rentre"	JUMP	20$90$:	POPM.L	D2,D3,A3,A4	RET;--------\\; JUSTNLG >;--------/; Calcul la longueur rentre pour un tabulateur numrique.; in	-; out	D4.W	lg "rentre"; mod	D4.W, D7.WJUSTNLG:	PUSHM.L	D2,D3,A3,A4	LOAD.L	A4,#(A5)+OCREG	LOAD.L	A3,#(A5)+OVREG	CALL	_COPREGLE	; OVREG <-- OCREG	LOAD.L	A4,#(A5)+OCCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	_COPCOMMAND	; OVCOM <-- OCCOM	LOAD.L	A4,(A5)+OPFT	CLR.W	D420$:	CALL	NVISU		; D3 <-- caractre suivant	JUMP',NE 60$	CALL	IFIEOL	JUMP',EQ 60$	COMP.B	D3,#SPACE	JUMP',EQ 60$	COMP.B	D3,#TAB	JUMP',EQ 60$	COMP.B	D3,#'.	JUMP',EQ 60$	COMP.B	D3,#',	JUMP',EQ 60$	COMP.B	D3,#SAJEXM	JUMP,EQ	20$	COMP.B	D3,#SAJEXT	JUMP,EQ	20$	COMP.B	D3,#SAJEXS	JUMP,EQ	20$	COMP.B	D3,#MARQUED	JUMP,EQ	20$	COMP.B	D3,#MARQUEF	JUMP,EQ	20$	CLR.W	D2	CALL	VADDLGC		; D2 <-- lg du caractre	ADD.W	D4,D2		; D4 <-- augmente lg "rentre"	JUMP	20$60$:	LOAD.B	D3,#'.	CLR.W	D2	CALL	VADDLGC		; D2 <-- lg du point	SR.W	D2,#1		; D2 <-- 1/2 de chaque ct	ADD.W	D4,D2		; D4 <-- augmente lg "rentre"	POPM.L	D2,D3,A3,A4	RET;--------\\; JUSTLIA >;========/; Ajoute quelques SAJEXS pour aligner une ligne  gauche et  droite.; in	A5.L	^description du buffer;	D1.W	nb d'espaces (0..n);	D2.W	largeur de la ligne;	D3.B	dernier caractre TEOL/PEOL/TEOP/PEOP/TEOT;	D4.W	largeur maximale pour la ligne; out	D7.W	erreur; mod	D7.WJUSTLIA:	PUSHM.L	D0..D6	COMP.B	D3,#PEOL	JUMP,NE 80$	COMP.W	D2,D4		; ligne dj parfaite ?	JUMP,HS 80$		; oui => 80$; Si c'est ncessaire, essaye une coupure dans le mot au dbut de; la ligne suivante.	TEST.B	(A5)+OCREG+OREGCOUP	JUMP',F 08$	TEST.W	D1		; au moins un espace ?	JUMP',EQ 06$		; non => 06$	CLR.L	D0	LOAD.W	D0,D4	SUB.W	D0,D2		; D0 <-- lg manquante	DIV.WU	D0,D1		; D0 <-- lg manquante par espace	MUL.WU	D0,#100	DIV.WU	D0,(A6)+OCXL	COMP.W	D0,(A6)+OJUPAL	; espace assez petit ?	JUMP',LS 08$		; oui => 08$06$:	CALL	JUSTMOT		; coupe dans le dernier mot	JUMP',NE 08$		; coupure pas faite => 08$	INC.W	D1		; D1 <-- un espace de plus !08$:	TEST.W	D1		; au moins un espace ?	JUMP,EQ 80$		; non => 80$	SUB.W	D2,D4	NEG.W	D2		; D2 <-- lg manquante	TEST.B	(A6)+OCVAR	; chasse variable ?	JUMP',T 10$		; oui => 10$	AND.L	D2,#H'FFFF	DIV.WU	D2,(A6)+OCXL	; D2 <-- nb de SAJEXS  ajouter10$:	TEST.W	D2	JUMP,EQ	80$	CALL	GOUPS		; revient au dbut de la ligne	LOAD.W	D5,D1		; D5 <-- nb d'espace(s)	AND.L	D2,#H'FFFF	DIV.WU	D2,D1		; D2 <-- nb SAJEXS par espace	LOAD.W	D4,D2		; D4 <-- nb SAJEXS par espace	LOAD.L	D1,D2	SWAP.W	D1		; D1 <-- reste division	LOAD.W	D6,#1		; D6 <-- rpartiteur du reste	TEST.W	D1	JUMP',EQ 20$	CLR.L	D6	LOAD.W	D6,D5		; D6 <-- nb espace(s)	DIV.WU	D6,D1	SR.W	D6,#1	INC.W	D6		; D6 <-- (nb_space/reste/2)+120$:	LOAD.W	D0,D6	SWAP.W	D6	LOAD.W	D6,D0		; D6 <-- rpartiteur du reste30$:	CALL	AVANCE		; D3 <-- caractre en avant	JUMP,NE	90$	COMP.B	D3,#MARQUED	JUMP,EQ	30$	COMP.B	D3,#MARQUEF	JUMP,EQ	30$	COMP.B	D3,#COMMAND	JUMP,EQ	30$	COMP.B	D3,#PEOL	JUMP,EQ	80$	COMP.B	D3,#SPACE	JUMP,NE	30$	LOAD.W	D2,D4		; D2 <-- nb SAJEXS par espace	TEST.W	D1		; reste un reste (hahaha) ?	JUMP',EQ 50$		; non => 50$				; oui =>	DEC.W	D6		; rparti le reste	JUMP',NE 50$	LOAD.L	D0,D6	SWAP.W	D0	LOAD.W	D6,D0		; r-arme le rpartiteur	DEC.W	D1		; D1 <-- un reste de moins	INC.W	D250$:	CALL	JUSTINSSS	; insre qq SAJEXSs	JUMP',NE 90$	DEC.W	D5		; encore un espace  tendre ?	JUMP,NE	30$		; oui => 30$60$:	CALL	AVANCE		; avance au dbut ligne suivante	JUMP',NE 90$	COMP.B	D3,#PEOL	JUMP,NE	60$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; JUSTLIG >;========/; Ajoute quelques SAJEXM  gauche pour aligner  droite.; in	A5.L	^description du buffer;	D1.W	nb d'espaces (0..n);	D2.W	largeur de la ligne;	D3.B	dernier caractre TEOL/PEOL/TEOP/PEOP/TEOT;	D4.W	largeur maximale pour la ligne; out	D7.W	erreur; mod	D7.WJUSTLIG:	PUSHM.L	D0,D2..D4,A4	CALL	JUSTMDGC	; coupe v. mot	COMP.W	D2,D4		; ligne dj parfaite ?	JUMP',HS 80$		; oui => 80$	SUB.W	D2,D4	NEG.W	D2		; D2 <-- lg manquante	TEST.B	(A6)+OCVAR	; chasse variable ?	JUMP',T 10$		; oui => 10$	AND.L	D2,#H'FFFF	DIV.WU	D2,(A6)+OCXL	; D2 <-- nb de SAJEXM  ajouter10$:	TEST.W	D2	JUMP',EQ 80$	CALL	GOUPS		; revient au dbut de la ligne	LOAD.L	A4,(A5)+OPFT30$:	CALL	TNVISU		; D3 <-- premier caractre de la ligne	JUMP',NE 40$	COMP.B	D3,#MARQUED	; ignore une ventuelle marque	JUMP,EQ	30$	COMP.B	D3,#MARQUEF	; ignore une ventuelle marque	JUMP,EQ	30$	CALL	IFIEOL		; juste un "terminateur" ?	JUMP',EQ 60$		; oui => 60$40$:	CALL	JUSTINSSM	; insre qq SAJEXMs au dbut	JUMP',NE 90$60$:	CALL	AVANCE		; avance au dbut ligne suivante	JUMP',NE 90$	CALL	IFIEOL	JUMP,NE	60$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; JUSTLIC >;========/; Ajoute quelques SAJEXM  gauche pour centrer.; in	A5.L	^description du buffer;	D1.W	nb d'espaces (0..n);	D2.W	largeur de la ligne;	D3.B	dernier caractre TEOL/PEOL/TEOP/PEOP/TEOT;	D4.W	largeur maximale pour la ligne; out	D7.W	erreur; mod	D7.WJUSTLIC:	PUSHM.L	D0,D2..D4,A4	CALL	JUSTMDGC	; coupe v. mot	COMP.W	D2,D4		; ligne dj parfaite ?	JUMP',HS 80$		; oui => 80$	SUB.W	D2,D4	NEG.W	D2		; D2 <-- lg manquante	TEST.B	(A6)+OCVAR	; chasse variable ?	JUMP',T 10$		; oui => 10$	AND.L	D2,#H'FFFF	DIV.WU	D2,(A6)+OCXL	; D2 <-- nb de SAJEXM  ajouter10$:	SR.W	D2,#1		; D2 <-- la moiti	JUMP',EQ 80$	CALL	GOUPS		; revient au dbut de la ligne	LOAD.L	A4,(A5)+OPFT30$:	CALL	TNVISU		; D3 <-- premier caractre de la ligne	JUMP',NE 40$	COMP.B	D3,#MARQUED	; ignore une ventuelle marque	JUMP,EQ	30$	COMP.B	D3,#MARQUEF	; ignore une ventuelle marque	JUMP,EQ	30$	CALL	IFIEOL		; juste un "terminateur" ?	JUMP',EQ 60$		; oui => 60$40$:	CALL	JUSTINSSM	; insre qq SAJEXMs au dbut	JUMP',NE 90$60$:	CALL	AVANCE		; avance au dbut ligne suivante	JUMP',NE 90$	CALL	IFIEOL	JUMP,NE	60$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; JUSTMDGC >;=========/; Coupe un mot si ncessaire pour les modes en drapeau  droite; ou  gauche et centr.; in	D2.W	largeur de la ligne;	D3.B	dernier caractre TEOL/PEOL/TEOP/PEOP/TEOT;	D4.W	largeur maximale pour la ligne; out	D2.W	largeur de la ligne;	D7.W	ok; mod	D0.L, D2.L, D7.WJUSTMDGC:	COMP.B	D3,#PEOL	JUMP',NE 90$	TEST.B	(A5)+OCREG+OREGCOUP	JUMP',F 90$	LOAD.W	D0,D4	SUB.W	D0,D2		; D0 <-- lg manquante	MUL.WU	D0,#100	DIV.WU	D0,D4	COMP.W	D0,(A6)+OJUPTR	; reste trop ?	JUMP',LS 90$		; non => 90$06$:	CALL	JUSTMOT		; coupe dans le dernier mot90$:	CLR.W	D7		; D7 <-- ok	RET;--------\\; JUSTMOT >;========/; Amliore la justification en essayant de couper dans le mot; au dbut de la ligne suivante.; in	A5.L	^description du buffer;	D2.W	largeur de la ligne;	D4.W	largeur maximale pour la ligne; out	D2.W	nouvelle largeur de la ligne;	D7.W	ok => coupure effectue; mod	D2.L, D7.WJUSTMOT:	PUSHM.L	D0,D1,D3,D4,D5,A2..A4	LOAD.W	D5,D2		; D5 <-- largeur de la ligne	LOAD.W	D0,D4	SUB.W	D0,D5		; D0 <-- lg manquante	JUMP,LO 80$	LOAD.L	A4,#(A5)+OCREG	LOAD.L	A3,#(A5)+OVREG	CALL	_COPREGLE	; OVREG <-- OCREG	LOAD.L	A4,#(A5)+OCCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	_COPCOMMAND	; OVCOM <-- OCCOM	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^dbut mot (dbut ligne suivante)	LOAD.L	A3,#(A6)+OBUMOT	; A3 <-- ^buffer pour mot	LOAD.L	A2,#(A6)+OBULMO	; A2 <-- ^buffer pour lg caractres	LOAD.W	D4,#LBUMOT-1	; D4 <-- nb car. max pour le mot	CLR.W	D2		; D2 <-- position dans le mot	CLR.W	D1		; D1 <-- compte nb car. avancs	CALL	JPVISU	JUMP,NE 80$	COMP.B	D3,#PEOL	JUMP,NE 80$	CALL	JPVISU	JUMP,NE 80$	COMP.B	D3,#SPACE	JUMP,NE 80$	CALL	JNVISU		; saute le SPACE	CALL	VADDLGC		; D2 <-- ajoute largeur de l'espace	LOAD.W	(A2+),D2	CALL	JNVISU		; saute le PEOP10$:	INC.W	D1		; D1 <-- +1 caractre avanc	CALL	JNVISU		; D3 <-- caractre en avant	JUMP,NE	80$	COMP.B	D3,#SPACE	; fin du mot ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D3,#TAB	JUMP',EQ 20$	CALL	IFIEOL	JUMP',EQ 20$	LOAD.B	(A3+),D3	; OBUMOT <-- un caractre	CALL	VADDLGC		; D2 <-- ajoute largeur du caractre	LOAD.W	(A2+),D2	DEC.W	D4	JUMP,NE	10$	JUMP	80$20$:	DEC.W	D1		; D1 <-- ne compte pas le terminateur	JUMP,EQ	80$	LOAD.L	A3,#(A6)+OBUMOT	; A3 <-- ^mot	LOAD.W	D3,D1		; D3 <-- lg mot	LOAD.L	A4,#(A6)+OBUCOU	; A4 <-- ^buffer	LOAD.W	D4,#LBUCOU	; D4 <-- lg buffer	COUPE_	HASH		; cherche la liste des coupures	JUMP,NE 80$; Cherche la coupure optimale dans la liste rendue.	CLR.W	D2	LOAD.B	D3,#'-	CALL	VADDLGC		; D2 <-- largeur du tiret	CLR.W	D430$:	INC.W	D4	TEST.B	(A4+)	JUMP,NE	30$	DEC.L	A4		; A4 <-- ^dernire coupure	LOAD.L	A2,#(A6)+OBULMO	; A2 <-- ^buffer pour lg caractres40$:	DEC.W	D4	JUMP,EQ 80$	CLR.W	D3	LOAD.B	D3,(-A4)	; D3 <-- position coupure (nb car)	JUMP,EQ 80$	JUMP',NS 50$				; coupe en ajoutant un tiret =>	SL.W	D3,#1	LOAD.W	D1,(A2)+(D3.W)	; D1 <-- lg du mot jusque l	ADD.W	D1,D2		; D1 <-- lg du mot avec le tiret	COMP.W	D0,D1		; reste assez de place en bout de ligne ?	JUMP,LO 40$		; non => 40$	SR.W	D3,#1	JUMP'	60$50$:				; coupe sans ajouter de tiret =>	TCLR.L	D3:#7	SL.W	D3,#1	LOAD.W	D1,(A2)+(D3.W)	; D1 <-- lg du mot jusque l	COMP.W	D0,D1		; reste assez de place en bout de ligne ?	JUMP,LO 40$		; non => 40$	SR.W	D3,#1	TSET.L	D3:#15; Coupe aprs le nombre de caractres indiqu dans D3.60$:	ADD.W	D5,D1		; D5 <-- nouvelle lg restante	LOAD.W	D4,D3		; D4 <-- nb caractre  avancer	CALL	DRECULE		; dtruit le PEOL	INC.W	(A6)+OJUNLO	; une ancienne ligne de plus65$:	CALL	AVANCE		; avance sur la coupure	COMP.B	D3,#COMMAND	JUMP,EQ	65$	COMP.B	D3,#MARQUED	JUMP,EQ	65$	COMP.B	D3,#MARQUEF	JUMP,EQ	65$	DEC.B	D4	JUMP,NE	65$	TEST.L	D4:#15		; mot contient dj "-" ?	JUMP',BS 70$		; oui => 70$	LOAD.B	D3,#TIRET	; non =>	CALL	INSERT		; insre un pseudo-tiret70$:	LOAD.B	D3,#PEOL	CALL	INSERT		; remet PEOL	INC.W	(A6)+OJUNLN	; une nouvelle ligne de plus	CLR.W	D7		; D7 <-- coupure effectue	JUMP'	90$80$:	LOAD.W	D7,#ERTNOT	; D7 <-- coupure pas faite !90$:	LOAD.W	D2,D5		; D2 <-- largeur de la ligne	POPM.L	D0,D1,D3,D4,D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; JUSTIMAGE >;==========/; Justifie une image (modifie son cadrage horizontal).; in	D0.B	mode de justification (JUST?);	D4.W	largeur maximale pour la ligne;	D5.W	marge gauche; out	-; mod	D7.WJUSTIMAGE:	PUSHM.L	D0..D4,A4	LOAD.W	D1,D4		; D1 <-- largeur maximale pour la ligne	SUB.W	D1,D5		; D1 <-- largeur utile	CALL	RECULE		; recule sur l'image	LOAD.L	A4,(A5)+OPFT	CALL	_IMAPARAM	; D4 <-- dimensions de l'image (dy;dx)	JUMP',NE 80$	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^commande image20$:	TEST.B	(A4+)		; A4 <-- saute <DEBIMA>nom<0>	JUMP,NE	20$	SUB.W	D1,D4		; D1 <-- largeur en trop	JUMP',HS 30$	CLR.W	D130$:	LOAD.W	D4,D1		; D4 <-- nouvelle indentation <ixx>	COMP.B	D0,#JUSTG	JUMP',EQ 70$	COMP.B	D0,#JUSTC	JUMP',EQ 50$	COMP.B	D0,#JUSTA	JUMP',EQ 50$				; drapeau  droite =>	CLR.W	D4	JUMP'	70$50$:				; align ou centr =>	SR.W	D4,#1		; D4 <-- 1/2 de chaque ct70$:	CALL	NUMRB		; mj <ixx> dans le buffer	LOAD.B	(A4)+4,D1	LOAD.B	(A4)+5,D080$:	CALL	AVANCE		; avance juste aprs l'image	POPM.L	D0..D4,A4	RET;----------\\; JUSTINSSM >;----------/; Insert un espace variable SAJEXM.; in	D2.W	largeur de l'espace variable; out	D7.W	erreur; mod	D7.WJUSTINSSM:	PUSHM.L	D2,D3	TEST.W	D2	JUMP',EQ 90$	TEST.B	(A6)+OCVAR	; chasse variable ?	JUMP',T 20$		; oui => 20$	MUL.WU	D2,(A6)+OCXL	; D2 <-- distance totale20$:	LOAD.B	D3,D2	COMP.W	D2,#127	JUMP',LS 30$	LOAD.B	D3,#12730$:	SL.W	D3,#8	LOAD.B	D3,#SAJEXM	CALL	INSERT	JUMP',NE 90$	SR.W	D3,#8	SUB.W	D2,D3	JUMP,NE 20$90$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; JUSTINSST >;----------/; Insert un espace variable SAJEXT.; in	D2.W	largeur de l'espace variable; out	D7.W	erreur; mod	D7.WJUSTINSST:	PUSHM.L	D2,D3	TEST.W	D2	JUMP',EQ 90$	TEST.B	(A6)+OCVAR	; chasse variable ?	JUMP',T 20$		; oui => 20$	MUL.WU	D2,(A6)+OCXL	; D2 <-- distance totale20$:	LOAD.B	D3,D2	COMP.W	D2,#127	JUMP',LS 30$	LOAD.B	D3,#12730$:	SL.W	D3,#8	LOAD.B	D3,#SAJEXT	CALL	INSERT	JUMP',NE 90$	SR.W	D3,#8	SUB.W	D2,D3	JUMP,NE 20$90$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; JUSTINSSS >;----------/; Insert un espace variable SAJEXS.; in	D2.W	largeur de l'espace variable; out	D7.W	erreur; mod	D7.WJUSTINSSS:	PUSHM.L	D2,D3	TEST.W	D2	JUMP',EQ 90$	TEST.B	(A6)+OCVAR	; chasse variable ?	JUMP',T 20$		; oui => 20$	MUL.WU	D2,(A6)+OCXL	; D2 <-- distance totale20$:	LOAD.B	D3,D2	COMP.W	D2,#127	JUMP',LS 30$	LOAD.B	D3,#12730$:	SL.W	D3,#8	LOAD.B	D3,#SAJEXS	CALL	INSERT	JUMP',NE 90$	SR.W	D3,#8	SUB.W	D2,D3	JUMP,NE 20$90$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; GOBOL   >;========/; Revient au dbut de la ligne (bol = begin of line).; in	A5.L	^description du buffer; out	-; mod	D7.WGOBOL:	PUSH.W	D320$:	CALL	RECULE		; recule	JUMP',NE 90$	CALL	IFIEOL		; fin ligne prcdente ?	JUMP,NE 20$		; non => 20$				; oui =>	CALL	AVANCE		; saute TEOL, PEOL, IMAGE, etc.90$:	POP.W	D3	RET;--------\\; GOUP    >;========/; Va au dbut de la ligne prcdente (contre en haut).; in	A5.L	^description d'un buffer; out	D7.W	erreur; mod	D7.WGOUP:	PUSH.W	D3	CALL	RECULE		; recule un car. de toute faon	JUMP',NE 90$		; eob => 90$40$:	CALL	RECULE		; recule d'un caractre	JUMP',NE 80$		; eob => 80$ (dbut ligne)	CALL	IFIEOL		; fin de ligne/image ?	JUMP,NE 40$		; non => 40$				; oui =>	CALL	AVANCE		; avance au dbut de la ligne80$:	CLR.W	D7		; D7 <-- ok90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; GOUPS   >;========/; Va au dbut de la ligne prcdente (contre en haut),; sans remonter les SAJEXMs de la marge gauche ni les TABs/SAJEXTs.; in	A5.L	^description d'un buffer; out	D7.W	erreur; mod	D7.WGOUPS:	PUSH.W	D3	CALL	RECULE		; recule un car. de toute faon	JUMP',NE 90$		; eob => 90$40$:	CALL	RECULE		; recule d'un caractre	JUMP',NE 80$		; eob => 80$ (dbut ligne)	COMP.B	D3,#SAJEXM	; SAJEXM de la marge gauche ?	JUMP',EQ 70$		; oui => 70$	COMP.B	D3,#SAJEXT	; SAJEXT d'un tabulateur ?	JUMP',EQ 70$		; oui => 70$	COMP.B	D3,#TAB		; dernier TAB de la ligne ?	JUMP',EQ 70$		; oui => 70$	CALL	IFIEOL		; fin de ligne/image ?	JUMP,NE 40$		; non => 40$70$:				; oui =>	CALL	AVANCE		; avance au dbut de la ligne80$:	CLR.W	D7		; D7 <-- ok90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; JAVANCE >;========/; Avance en supprimant les pseudo-caractres et en sautant; les caractres MARQUED et MARQUEF.; Supprime galement les commandes devenues inutiles et les; commandes  la queue leuleu !; in	-; out	D7.W	ok;	 D3.W	 caractre quelconque;	D7.W	erreur;	 D3.W	 caractre TEOT; mod	D3.W, D7.WJAVANCE:	PUSHM.L	D2,A410$:	LOAD.B	D2,(A5)+OCCOM+OCOMMOD	SWAP.W	D2	LOAD.B	D2,(A5)+OCCOM+OCOMNOG	CALL	AVANCE		; D3 <-- caractre avanc	JUMP',NE 35$	COMP.B	D3,#MARQUED	JUMP,EQ	10$	COMP.B	D3,#MARQUEF	JUMP',EQ 40$	COMP.B	D3,#COMMAND	JUMP',EQ 50$	COMP.B	D3,#PEOL	JUMP',EQ 25$	COMP.B	D3,#PEOP	JUMP',EQ 30$	COMP.B	D3,#TIRET	JUMP',EQ 30$	COMP.B	D3,#SAJEXM	JUMP',EQ 30$	COMP.B	D3,#SAJEXT	JUMP',EQ 30$	COMP.B	D3,#SAJEXS	JUMP',EQ 30$	JUMP	90$25$:	INC.W	(A6)+OJUNLO	; une ancienne ligne de plus30$:	CALL	DRECULE		; supprime le pseudo-caractre	JUMP	10$35$:	LOAD.B	D3,#TEOT	; D3 <-- caractre de fin	JUMP	90$40$:				; marque de fin =>	TSET.B	(A6)+OFLAGS:#BMRKF	JUMP	10$50$:				; commande =>	LOAD.L	A4,(A5)+OPFT	CALL	CNVISU		; D3 <-- caractre juste aprs	JUMP',NE 70$	COMP.B	D3,#MARQUED	JUMP',EQ 62$	COMP.B	D3,#MARQUEF	JUMP',EQ 60$	COMP.B	D3,#DEBCOM	; deuxime commande juste aprs ?	JUMP',NE 70$		; non => 70$	CALL	DCRECULE	; oui => supprime la premire	CALL	AVANCE		; puis avance aprs la deuxime	JUMP	50$60$:	TSET.B	(A6)+OFLAGS:#BMRKF62$:	CALL	CNVISU		; D3 <-- caractre aprs la marque	JUMP',NE 70$	COMP.B	D3,#DEBCOM	; deuxime commande aprs la marque ?	JUMP',NE 70$		; non => 70$	CALL	DCRECULE	; oui => supprime la premire	CALL	AVANCE		; puis avance aprs la marque	CALL	AVANCE		; puis avance aprs la deuxime	JUMP	50$70$:	LOAD.L	A4,(A5)+OPDT	COMP.B	D2,(A4)-(1+LGCOM)+OCOMNOG ; mme gencar aprs la commande ?	JUMP',NE 80$		; non => 80$	SWAP.W	D2	COMP.B	D2,(A4)-(1+LGCOM)+OCOMMOD ; mme mode aprs la commande ?	JUMP',NE 80$		; non => 80$	CALL	DCRECULE	; oui => supprime la commande	JUMP	10$80$:	LOAD.B	D3,#COMMAND	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; IFINSERT >;=========/; Insre un caractre, pour autant qu'il n'existe pas dj.; De plus, n'insre jamais le caractre aprs une commande.; in	D3.B	caractre; out	D7.W	erreur; mod	D7.WIFINSERT:	PUSHM.L	D3,D4	LOAD.B	D4,D3		; D4 <-- caractre  insrer10$:	CALL	RECULE		; D3 <-- caractre juste avant	JUMP',NE 30$	COMP.B	D3,#MARQUED	JUMP,EQ	10$	COMP.B	D3,#MARQUEF	JUMP,EQ	10$	COMP.B	D3,#COMMAND	; est-on juste aprs une commande ?	JUMP',EQ 30$		; oui => 30$	CALL	AVANCE		; non => avance le caractre recul30$:	CALL	AVANCE		; D3 <-- caractre juste aprs	JUMP',NE 50$	COMP.B	D3,#MARQUED	JUMP,EQ	30$	COMP.B	D3,#MARQUEF	JUMP,EQ	30$	COMP.B	D3,D4		; le mme juste aprs ?	JUMP',EQ 90$		; oui => 90$				; non =>	CALL	RECULE		; recule le caractre avanc50$:	LOAD.B	D3,D4		; D3 <-- caractre  insrer	CALL	INSERT	JUMP',NE 90$	COMP.B	D3,#PEOL	JUMP',NE 90$	INC.W	(A6)+OJUNLN	; une nouvelle ligne de plus90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; JNVISU  >;========/; Comme TNVISU, mais saute les marques et les commandes.; in	voir TNVISU; out	; mod	JNVISU:10$:	CALL	TNVISU	JUMP',NE 90$	COMP.B	D3,#MARQUED	JUMP,EQ	10$	COMP.B	D3,#MARQUEF	JUMP,EQ	10$	COMP.B	D3,#COMMAND	JUMP,EQ	10$90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; JPVISU  >;========/; Comme TPVISU, mais saute les marques et les commandes.; in	voir TPVISU; out	; mod	JPVISU:10$:	CALL	TPVISU	JUMP',NE 90$	COMP.B	D3,#MARQUED	JUMP,EQ	10$	COMP.B	D3,#MARQUEF	JUMP,EQ	10$	COMP.B	D3,#COMMAND	JUMP,EQ	10$90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; VADDLGC >;========/; Ajoute la largeur d'un caractre avec NVISU/PVISU.; in	D3.W	caractre;	D2.W	position dans ligne; out	D2.W	nouvelle position; mod	D2.WVADDLGC:	PUSHM.L	D3,D4,A2	COMP.B	D3,#MARQUED	JUMP',EQ 90$	COMP.B	D3,#MARQUEF	JUMP',EQ 90$	COMP.B	D3,#COMMAND	JUMP',EQ 90$	COMP.B	D3,#SAJEXM	JUMP',EQ 30$	COMP.B	D3,#SAJEXT	JUMP',EQ 30$	COMP.B	D3,#SAJEXS	JUMP',EQ 30$	COMP.B	D3,#TAB	JUMP',EQ 90$	CLR.W	D4	LOAD.B	D4,(A5)+OVCOM+OCOMNOG ; D4 <-- no du gencar	MUL.WU	D4,#LGGC	LOAD.L	A2,#(A6)+OBUGC	ADD.L	A2,D4		; A2 <-- ^dans OBUGC	LOAD.L	A2,(A2)+OGCPT	; A2 <-- ^gencar	LOAD.L	A2,#(A2)+OGCWID	; A2 <-- ^table des largeurs	AND.W	D3,#H'FF	LOAD.B	D3,(A2)+(D3.W)	; D3 <-- largeur du caractre	ADD.W	D2,D3		; D2 <-- position dans ligne	JUMP'	90$30$:				; sajex =>	SR.W	D3,#8		; D3 <-- largeur	ADD.W	D2,D3		; D2 <-- position dans ligne90$:	POPM.L	D3,D4,A2	RET;--------\\; ADDLGC  >;========/; Ajoute la largeur d'un caractre selon la position du curseur.; in	D3.W	caractre;	D2.W	position dans ligne; out	D2.W	nouvelle position; mod	D2.WADDLGC:	PUSHM.L	D3,D4,A2	COMP.B	D3,#MARQUED	JUMP',EQ 90$	COMP.B	D3,#MARQUEF	JUMP',EQ 90$	COMP.B	D3,#COMMAND	JUMP',EQ 90$	COMP.B	D3,#SAJEXM	JUMP',EQ 30$	COMP.B	D3,#SAJEXT	JUMP',EQ 30$	COMP.B	D3,#SAJEXS	JUMP',EQ 30$	COMP.B	D3,#TAB	JUMP',EQ 90$	CLR.W	D4	LOAD.B	D4,(A5)+OCCOM+OCOMNOG ; D4 <-- no du gencar	MUL.WU	D4,#LGGC	LOAD.L	A2,#(A6)+OBUGC	ADD.L	A2,D4		; A2 <-- ^dans OBUGC	LOAD.L	A2,(A2)+OGCPT	; A2 <-- ^gencar	LOAD.L	A2,#(A2)+OGCWID	; A2 <-- ^table des largeurs	AND.W	D3,#H'FF	LOAD.B	D3,(A2)+(D3.W)	; D3 <-- largeur du caractre	ADD.W	D2,D3		; D2 <-- position dans ligne	JUMP'	90$30$:				; sajex =>	SR.W	D3,#8		; D3 <-- largeur	ADD.W	D2,D3		; D2 <-- position dans ligne90$:	POPM.L	D3,D4,A2	RET;--------\\; GIVHNUM >;========/; Donne la hauteur occupe en haut de chaque page pour numroter.; in	-; out	D4.W	hauteur requise/zro; mod	D4.L, D7.WGIVHNUM:	PUSHM.L	D5,A3,A4	CLR.W	D5		; D5 <-- hauteur nulle	TEST.B	(A6)+OFANION+2:#BFANUM-8 ; numrote les pages ?	JUMP',BC 80$		; non => 80$				; oui =>	LOAD.L	A3,#(A6)+ODFNGC	; A3 <-- ^titre du gencar de numrotation	CALL	SRCGC		; A4 <-- ^dans OBUGC	JUMP',NE 80$	LOAD.W	D5,(A4)+OGC1Y	ADD.W	D5,(A4)+OGC2Y	; D5 <-- hauteur des caractres	COMP.W	D5,(A6)+OITL	; plus grand que l'interligne ?	JUMP',HS 50$		; oui => 50$	COMP.W	D5,(A6)+OITL	; D5 <-- interligne simple standard50$:	SL.W	D5,#1		; D5 <-- *2 car deux lignes80$:	LOAD.W	D4,D5		; D4 <-- hauteur	POPM.L	D5,A3,A4	RET;--------\\; GIVPNUM >;========/; Donne le numro de la premire page.; in	-; out	D4.W	numro de la premire page; mod	D4.L, D7.WGIVPNUM:	PUSHM.L	D3,A3	LOAD.W	D4,#1		; D4 <-- numro par dfaut	TEST.B	(A6)+OFANION+2:#BFANUM-8 ; numrote les pages ?	JUMP',BC 90$		; non => 90$				; oui =>	LOAD.L	A3,#(A6)+ODFNUM	; A3 <-- ^chane "-- 34 --" par exemple10$:	LOAD.B	D3,(A3+)	JUMP',EQ 90$	COMP.B	D3,#'0	JUMP,LO 10$	COMP.B	D3,#'9	JUMP,HI 10$	DEC.L	A3	CALL	DBOXGETN	LOAD.W	D4,D3		; D4 <-- numro de la 1re page90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET	.END