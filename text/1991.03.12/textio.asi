	.SBTTL	TEXTIO;--------\\; EXHOME  >;========/; Archive toutes les zones qui ne sont pas  jour.; Les zones 10..19 ne sont pas prisent en compte !; in	-; out	D7.W	erreur (reste dans TEXT); mod	D7.WEXHOME:	PUSHM.L	D0,D3,D4	TEST.B	(A6)+OFLAGS:#BFPRINT	JUMP',BC 05$	LOAD.W	D7,#ERTFPR	CALL	IOERROR		; affiche "Impression en cours"	JUMP	_MAIN05$:	LOAD.W	D4,(A5)+ONOBUF	; D4 <-- no zone actuelle	CLR.W	D3		; D3 <-- no 1re zone  sauver10$:	LOAD.L	A5,#(A6)+OBUFP	; A5 <-- ^description buffer principal	COMP.W	D3,(A5)+ONOBUF	; buffer principal ?	JUMP',EQ 30$		; oui => 30$	LOAD.L	A5,#(A6)+OBUFP	; A5 <-- ^description buffer secondaire	TEST.B	(A5)+OSTBUF:#BBUFRE ; buffer secondaire existe ?	JUMP',BS 20$		; non => 20$	COMP.W	D3,(A5)+ONOBUF	; buffer secondaire ?	JUMP',EQ 30$		; oui => 30$20$:	LOAD.W	D0,D3		; D0 <-- no zone	CALL	GPPBUF		; A4 <-- ^description compactifie	JUMP',EQ 50$		; si zone vide => 50$	TEST.B	(A4)+OPCZ+OSTATUS:#BFILMOD ; zone dj  jour ?	JUMP',BC 50$		; oui => 50$				; non =>	CALL	INI1B		; A5 <-- ^description de la zone  archiver30$:	CLR.W	D0		; D0 <-- avant de quitter	CALL	DBOXSAVE	; sauve la zone ...	JUMP',NE 80$		; erreur => 80$50$:	INC.W	D3		; D3 <-- no zone suivante	COMP.W	D3,#NBBF/2	; sauve seulement les zones 0..9 !	JUMP,LO	10$80$:	PUSH.W	D7	LOAD.W	D0,D4		; D0 <-- no zone initiale	CALL	INI1B		; remet la zone initiale	POP.W	D7	POPM.L	D0,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOERROR >;--------/; Affiche une erreur quelconque.; in	D7.W	erreur;	A3.L	^nom du fichier (facultatif); out	-; mod	-IOERROR:	PUSHM.L	D2..D4,D7,A3	CLR.W	D2		; D2 <-- au milieu de la fentre	LOAD.W	D4,D7		; erreur grave ?	JUMP',NC 90$		; non => 90$				; oui =>	CALL	CWMO		; souris: plus de sablier	LOAD.B	D3,#BIPERR	LIB	?BEEP		; fait un "mauvais" bruit	LOAD.W	D3,D4	SR.W	D3,#8	COMP.B	D3,#ERTEOB/H'100 ; erreur interne  TEXT ?	JUMP',NE 50$		; non => 50$				; oui =>	LOAD.L	A3,#R16"TAERR20$:	TEST.W	(A3+)		; fin de la table ?	JUMP',EQ 40$		; oui => 40$	COMP.W	D4,(A3)-2	; erreur trouve ?	JUMP',EQ 40$		; oui => 40$30$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE	30$	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- saute comme .EVEN	LOAD.L	A3,D3	JUMP	20$40$:	TCLR.B	(A6)+OFLAGS:#BMDBOX	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode (avec sauvetage)	DBOX_	TERROR		; affiche l'erreur text	JUMP',EQ 80$		; ok => 80$	CLR.W	D2		; D2 <-- mode (sans sauvetage)	DBOX_	TERROR		; affiche l'erreur text	JUMP',NE 80$		; erreur => 80$	TSET.B	(A6)+OFLAGS:#BMDBOX	JUMP'	80$50$:	TCLR.B	(A6)+OFLAGS:#BMDBOX	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode (avec sauvetage)	LOAD.W	D7,D4		; D7 <-- no de l'erreur	DBOX_	MERROR		; affiche l'erreur PSos	JUMP',EQ 80$		; ok => 80$	CLR.W	D2		; D2 <-- mode (sans sauvetage)	LOAD.W	D7,D4		; D7 <-- no de l'erreur	DBOX_	MERROR		; affiche l'erreur PSos	JUMP',NE 80$		; erreur => 80$	TSET.B	(A6)+OFLAGS:#BMDBOX80$:	CALL	DBOXREFAIT	; remet les soft-keys standards90$:	POPM.L	D2..D4,D7,A3	RETTAERR:	.W	ERTPDP	.ASCII	"La mmoire alloue au logi-<CR>"	.ASCIZ	"ciel TEXT est pleine !"	.EVEN	.W	ERTNOT	.ASCII	"Pas trouv dans la<CR>"	.ASCIZ	"direction choisie !"	.EVEN	.W	ERTFPR	.ASCII	"Il y a une impression en cours !<CR>"	.ASCII	"<CR>"	.ASCII	"RAPPEL: Si ncessaire, (CTRL-M3)<CR>"	.ASCIZ	"        stoppe l'impression en cours."	.EVEN	.W	ERTMGC	.ASCII	"Un ou plusieurs caractres<CR>"	.ASCIZ	"n'ont pas pu tre chargs !"	.EVEN	.W	ERTIMA	.ASCII	"L'image doit tre dans le<CR>"	.ASCIZ	"mme dossier que le texte !"	.EVEN	.W	ERTPRI	.ASCII	"L'imprimante n'est pas<CR>"	.ASCIZ	"installe !"	.EVEN	.W	0		; <-- terminateur	.ASCIZ	"Erreur avec le logiciel TEXT !"	.EVEN;--------\\; STOFILE >;========/; Mmorise le nom du fichier s'il n'y a pas eu d'erreur.; S'il s'agit du nom TEXT.TEXT, ne mmorise pas !; in	A3.L	^nom du fichier  mmoriser; out	-; mod	-STOFILE:	PUSHM.L	D3,D7,A2..A4	LOAD.L	A4,A3		; A4 <-- ^nom  mmoriser	LOAD.L	A3,#R16"TXDEF	; A3 <-- ^nom TEXT.TEXT	LOAD.L	A2,#R16"01$	; A2 <-- ^terminateurs	LIB	?CPSTRING	; est-ce TEXT.TEXT ?	JUMP',NC 90$		; oui => 90$				; non =>	LOAD.L	A3,#(A5)+OBUMEMF20$:	LOAD.B	D3,(A4+)	JUMP',EQ 50$	COMP.B	D3,#CR	JUMP',EQ 50$	LOAD.B	(A3+),D3	JUMP	20$50$:	CLR.B	(A3)90$:	POPM.L	D3,D7,A2..A4	RET01$:	.B	0,CR,SPACE,'/,-1TXDEF:	.ASCIZ	"(,#:)TEXT.TEXT"	.EVEN;--------\\; RCLFILE >;========/; Rappel le nom du fichier.; in	A3.L	^buffer o rappeler le fichier; out	-; mod	-RCLFILE:	PUSHM.L	A3,A4	LOAD.L	A4,#(A5)+OBUMEMF10$:	LOAD.B	(A3+),(A4+)	JUMP,NE	10$	POPM.L	A3,A4	RET;--------\\; AFFFILE >;========/; Affiche le nom d'un fichier, en minuscules et; avec deux guillemets (de part et d'autre).; in	A3.L	^nom du fichier; out	-; mod	D7.WAFFFILE:	PUSHM.L	D3,A3,A4	LOAD.L	A4,#(A6)+OBUAFFF10$:	LOAD.B	D3,(A3+)	JUMP',EQ 50$	COMP.B	D3,#CR	JUMP',EQ 50$	CALL	MAJMIN		; D3 <-- lettre minuscule	LOAD.B	(A4+),D3	JUMP	10$50$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUAFFF	CALL	KILEXT		; n'affiche pas l'extension	LOAD.B	D3,#'"	LIB	?AFCAR	LIB	?AFTEXT		; affiche le nom du fichier	LIB	?AFCAR	POPM.L	D3,A3,A4	RET;--------\\; KILEXT  >;========/; Supprime l'extension d'un fichier.; in	A3.L	^nom du fichier; out	-; mod	-KILEXT:	PUSHM.L	D3,A4	LOAD.L	A4,A310$:	TEST.B	(A4+)		; A4 <-- ^fin du nom	JUMP',EQ 20$	COMP.B	(A4)-1,#CR	JUMP,NE	10$20$:	CLR.B	(A4)-1		; met un <0> terminateur;	COMP.L	A4,A3		; dbut du nom ?;	JUMP',EQ 90$		; ou => 90$;	LOAD.B	D3,(-A4);	COMP.B	D3,#':;	JUMP',EQ 90$;	COMP.B	D3,#'.;	JUMP,NE	20$;	CLR.B	(A4)		; remplace "." par terminateur;90$:	POPM.L	D3,A4	RET	.END