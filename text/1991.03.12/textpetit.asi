	.SBTTL	TEXTPETITLDBOXPETIT =	36		; largeur de la dbox [car]FACMIN	=	16		; facteur le plus petit (20 pages sur Smaky 100);----------\\; DBOXPETIT >;==========/; Montre qq pages en petit.; in	A5.L	^description du buffer; out	-; mod	D7.WDBOXPETIT:	PUSHM.L	D0..D6,A0..A4	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface tout	CALL	_STPRINT	; relit le status de l'imprimante	JUMP',EQ 10$	CALL	_AJPRINT	; ajustement subtile !	CALL	CHKREGLES	; ajuste les rgles	CALL	_AJUSTIF	; rejustifie tout ...	CALL	_PJUSTIF	; coupe toutes les pages ...	JUMP'	12$10$:	TEST.B	(A5)+OSTATUS:#BEOPMOD	JUMP',BC 12$	CALL	_PJUSTIF	; coupe toutes les pages ...12$:	LOAD.L	A4,#(A5)+OCREG	LOAD.L	A3,#(A5)+OVREG	CALL	COPREGLE	; OVREG <-- OCREG	LOAD.L	A4,#(A5)+OCCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OCCOM	LOAD.L	A4,(A5)+OPDT	CALL	_TNVISU		; A4 <-- avance un caractre de toute faon	CALL	SRCPUP		; A4 <-- ^dbut de la page	CALL	PAGESP		; sauve les paramtres (REG et COM)	LOAD.L	A0,(A6)+ODISPS	; A0 <-- ^status	LOAD.L	A2,#R16"TDBOX_PETIT	LOAD.L	D4,#2^0		; D4 <-- fanions	LOAD.W	D3,(A0)+ODFDY	SR.W	D3,#1		; D3 <-- position Y (au milieu)	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#LDBOXPETIT/2	SUB.W	D3,D2		; D3 <-- position X ( droite)	LOAD.W	D2,#2^BDBPOS	DBOX_	OPEN	JUMP,NE 95$	LOAD.W	D1,(A6)+OITL	SR.W	D1,#1		; D1 <-- facteur = itl/2	JUMP	65$		; met facteur "max" tout de suite20$:	LOAD.L	(A6)+OPETFA,D4	CALL	DESPPT		; met/enlve (PLUS PETIT)	CALL	DESPGR		; met/enlve (PLUS GRAND)	CALL	XYPETIT		; calcul nb de pages affichables	CALL	AFFPETIT	; affiche une ou plusieurs pages	JUMP',EQ 30$		; pages pas trop pleine => 30$	CALL	_PJUSTIF	; coupe toutes les pages ...	CALL	AFFPETIT	; r-affiche une ou plusieurs pages30$:	PUSHM.L	D1,A4	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_OK	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POPM.L	D1,A4	COMP.W	D3,#KEYMGR	JUMP,EQ 30$	COMP.W	D3,#KEYMGP	JUMP,EQ 80$	COMP.W	D3,#CR		; (TERMINE) ?	JUMP,EQ 90$		; oui => 90$	COMP.W	D3,#END	JUMP,EQ 90$	COMP.W	D3,#F0	JUMP,EQ 90$	COMP.W	D3,#F4	JUMP,EQ 70$	COMP.W	D3,#F5	JUMP,EQ 71$	COMP.W	D3,#F6	JUMP,EQ 72$	COMP.W	D3,#F13	JUMP',EQ 40$	COMP.W	D3,#F15	JUMP',EQ 45$	COMP.W	D3,#F7	JUMP,EQ 50$	COMP.W	D3,#F9	JUMP,EQ 55$	COMP.W	D3,#F10	JUMP,EQ 60$	COMP.W	D3,#F12	JUMP,EQ 65$35$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	LOAD.L	D4,(A6)+OPETFA	JUMP	30$40$:				; MONTE =>	CALL	XYPETIT		; calcul nb de pages affichables	CALL	PAGEGP		; reprend les paramtres (REG et COM)	CALL	SRCPUP		; A4 <-- ^dbut page prcdente	JUMP,NE 35$	LOAD.W	D3,(A6)+OPETNPX	MUL.WU	D3,(A6)+OPETNPY	; D3 <-- nb de pages affiches	DEC.W	D3	JUMP',EQ 42$41$:	CALL	SRCPUP		; A4 <-- ^dbut page prcdente	JUMP',NE 42$	DEC.W	D3	JUMP,NE 41$42$:	CALL	PAGESP		; sauve les paramtres (REG et COM)	JUMP	20$45$:				; DESCEND =>	CALL	XYPETIT		; calcul nb de pages affichables	CALL	PAGEGP		; reprend les paramtres (REG et COM)	CALL	SRCPDOWN	; A4 <-- ^dbut page suivante	JUMP,NE 35$	LOAD.W	D3,(A6)+OPETNPX	MUL.WU	D3,(A6)+OPETNPY	; D3 <-- nb de pages affiches	DEC.W	D3	JUMP',EQ 47$46$:	CALL	SRCPDOWN	; A4 <-- ^dbut page suivante	JUMP',NE 47$	DEC.W	D3	JUMP,NE 46$47$:	CALL	PAGESP		; sauve les paramtres (REG et COM)	JUMP	20$50$:				; PLUS PETIT =>	COMP.W	D1,#FACMIN	JUMP,HS 35$	MUL.WU	D1,#4	DIV.WU	D1,#3		; D1 <-- augmente le facteur	JUMP	20$55$:				; PLUS GRAND =>	LOAD.W	D3,D1	MUL.WU	D1,#3	DIV.WU	D1,#4		; D1 <-- diminue le facteur	CALL	XYPETIT	EX.L	D3,D1		; D1 <-- ancien, D3 <-- nouveau	TEST.W	(A6)+OPETNPX	JUMP,EQ 35$	TEST.W	(A6)+OPETNPY	JUMP,EQ 35$	LOAD.W	D1,D3		; D1 <-- nouveau	JUMP	20$60$:				; MIN =>	LOAD.W	D1,#FACMIN	JUMP	20$65$:				; MAX =>	LOAD.W	D3,D1	MUL.WU	D1,#3	DIV.WU	D1,#4		; D1 <-- diminue le facteur	TEST.W	D1	JUMP',EQ 67$	CALL	XYPETIT	EX.L	D3,D1		; D1 <-- ancien, D3 <-- nouveau	TEST.W	(A6)+OPETNPX	JUMP,EQ 20$	TEST.W	(A6)+OPETNPY	JUMP,EQ 20$	LOAD.W	D1,D3		; D1 <-- nouveau	JUMP	65$67$:	LOAD.W	D1,#1		; D1 <-- page la plus grande possible	JUMP	20$70$:				; CARACTERES =>	LOAD.W	D4,#2^0	JUMP	20$71$:				; MOTS =>	LOAD.W	D4,#2^1	JUMP	20$72$:				; PARAGRAPHES =>	LOAD.W	D4,#2^2	JUMP	20$80$:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 35$	CALL	XYPDETECTE	; positionne selon la souris	JUMP,NE 35$	CALL	BIGCURS		; faudra dessiner le grand curseur90$:	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; remet les soft-keys standards95$:	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface tout	CALL	ALLSCREEN	; signal tout l'cran  repeindre	POPM.L	D0..D6,A0..A4	RET;-----------\\; XYPDETECTE >;-----------/; Dtecte o est la souris en mode petit, c'est--dire dans; quelle page, dans quelle ligne et dans quelle colonne.; in	D1.W	facteur;	D4.L	position de la souris (y;x);	A4.L	^dbut page; out	D7.W	erreur; mod	D7.W, A4.LXYPDETECTE:	PUSHM.L	D1..D4,A4	CALL	PAGEGP		; reprend les paramtres (REG et COM)	LOAD.W	D7,#ERTNOT	; D7 <-- hors d'une page	CLR.L	D3	LOAD.W	D3,D4		; D3 <-- position souris en X	CLR.W	D4	SWAP.W	D4		; D4 <-- position souris en Y	DIV.WU	D3,(A6)+OPETDIM+2	DIV.WU	D4,(A6)+OPETDIM+0	COMP.W	D3,(A6)+OPETNPX	; trop  droite ?	JUMP,HS 90$		; oui => 90$	COMP.W	D4,(A6)+OPETNPY	; trop en bas ?	JUMP,HS 90$		; oui => 90$; Cherche le dbut de la bonne page.	LOAD.W	D2,D4	MUL.WU	D2,(A6)+OPETNPX	ADD.W	D2,D3		; D2 <-- rang de la page	JUMP',EQ 15$10$:	CALL	SRCPDOWN	; A4 <-- ^dbut page suivante	JUMP,NE 90$	DEC.W	D2	JUMP,NE 10$15$:	SWAP.W	D3		; D3 <-- position X dans la page	SWAP.W	D4		; D4 <-- position Y dans la page	LOAD.W	D7,#ERTNOT	; D7 <-- hors d'une page	SUB.W	D3,#10	JUMP,LO 90$	SUB.W	D4,#10	JUMP,LO 90$	MUL.WU	D3,D1	MUL.WU	D4,D1	LOAD.W	D1,D3		; D1 <-- position X dans la page	LOAD.W	D2,D4		; D2 <-- position Y dans la page; Cherche dans quelle ligne est la souris, sans chercher caractre par; caractre pour aller plus vite.	LOAD.W	D3,(A6)+OMGS	; D3 <-- position Y dbut 1re ligne20$:	CALL	SRCHTL		; D4 <-- hauteur de la ligne	TEST.L	D4:#BAFFREG	; rgle ?	JUMP',BS 25$		; oui => 25$	ADD.W	D3,D4		; D3 <-- position Y ligne suivante	COMP.W	D2,D3		; souris dans cette ligne ?	JUMP',LO 40$		; oui => 40$25$:	CALL	SRCDOWN		; A4 <-- ^dbut ligne suivante	JUMP,EQ	20$	JUMP'	80$40$:	CALL	_SKIPHOL	; A4 <-- saute le trou si ncessaire	TEST.L	D4:#BAFFIMA	JUMP',BC 45$	CALL	IMAPARAM	; A4 <-- ^dbut image	JUMP'	80$45$:;;?	CLR.W	D2		; D2 <-- position dans la ligne	LOAD.W	D2,(A6)+OMGG	; D2 <-- position dans la ligne60$:	CALL	_TNVISU		; D3 <-- caractre suivant	JUMP',NE 70$	CALL	IFIEOL		; fin de la ligne ?	JUMP',EQ 70$		; oui => 70$	CALL	_VADDLGC	; D2 <-- compte la largeur	COMP.W	D1,D2		; souris dans ce caractre ?	JUMP,HS	60$		; non => 60$70$:	CALL	_TPVISU		; A4 <-- ^sur le caractre80$:	CALL	SKIPPSEUDO	; A4 <-- saute si pseudo caractres	CALL	_VAQQPART	; positionne dans le texte	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D1..D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SRCPUP  >;========/; Cherche le dbut de la page prcdente (contre en haut).; in	A4.L	^dans buffer; out	A4.L	^une page plus haut;	D7.W	erreur; mod	D7.W, A4.LSRCPUP:	PUSH.W	D3	CALL	_TPVISU		; recule un caractre de toute faon	JUMP',NE 90$40$:	CALL	_QUICKUP	; cherche contre en haut	JUMP',NE 80$	COMP.B	D3,#FINCOM	; fin d'une commande ?	JUMP',EQ 60$		; oui => 60$	COMP.B	D3,#FINREG	; fin d'une rgle ?	JUMP',EQ 60$		; oui => 60$	COMP.B	D3,#FINIMA	; fin d'une image ?	JUMP',EQ 60$		; oui => 60$	COMP.B	D3,#TEOP	JUMP',EQ 50$	COMP.B	D3,#PEOP	; fin de la page ?	JUMP,NE	40$		; non => 40$50$:				; oui =>	INC.L	A4		; saute TEOP/PEOP	JUMP'	90$60$:	INC.L	A4		; A4 <-- ^aprs la commande	CALL	_PVISU		; recule la commande	JUMP	40$80$:	CLR.W	D7		; D7 <-- ok90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; SRCPDOWN >;=========/; Cherche le dbut de la page suivante (contre en bas).; in	A4.L	^dans buffer; out	A4.L	^une page plus bas;	D7.W	erreur; mod	D7.W, A4.LSRCPDOWN:	PUSH.W	D3	CALL	_TNVISU		; avance un caractre de toute faon	JUMP',NE 90$40$:	CALL	_QUICKDOWN	; cherche contre en bas	JUMP',NE 80$	COMP.B	D3,#DEBCOM	; dbut d'une commande ?	JUMP',EQ 60$		; oui => 60$	COMP.B	D3,#DEBREG	; dbut d'une rgle ?	JUMP',EQ 60$		; oui => 60$	COMP.B	D3,#DEBIMA	; dbut d'une image ?	JUMP',EQ 60$		; oui => 60$	COMP.B	D3,#TEOP	JUMP',EQ 90$	COMP.B	D3,#PEOP	; fin de la page ?	JUMP',EQ 90$		; oui => 90$	JUMP	40$		; non => 40$60$:	DEC.L	A4		; A4 <-- ^avant la commande	CALL	_NVISU		; saute la commande	JUMP	40$80$:	CLR.W	D7		; D7 <-- ok90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PAGESP  >;========/; Sauve les paramtres (REG et COM).; in	-; out	-; mod	D7.WPAGESP:	PUSHM.L	A3,A4	LOAD.L	A4,#(A5)+OVREG	LOAD.L	A3,#(A6)+OSREG	CALL	COPREGLE	; OSREG <-- OVREG	LOAD.L	A4,#(A5)+OVCOM	LOAD.L	A3,#(A6)+OSCOM	CALL	COPCOMMAND	; OSCOM <-- OVCOM	POPM.L	A3,A4	RET;--------\\; PAGEGP  >;========/; Reprend les paramtres (REG et COM).; in	-; out	-; mod	D7.WPAGEGP:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OSREG	LOAD.L	A3,#(A5)+OVREG	CALL	COPREGLE	; OVREG <-- OSREG	LOAD.L	A4,#(A6)+OSCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OSCOM	POPM.L	A3,A4	RET;--------\\; XYPETIT >;========/; Calcul le nombre de pages qu'il est possible de dessiner; horizontalement et verticalement.; in	D1.W	facteur; out	-; mod	D7.WXYPETIT:	PUSHM.L	D3,D4; Calcul le nombre de pages affichables verticalement.	CLR.L	D3	LOAD.W	D3,(A6)+OHTP	; D3 <-- hauteur de la page	DIV.WU	D3,D1	ADD.W	D3,#10*2	; D3 <-- place relle en hauteur	CLR.L	D4	LOAD.W	D4,(A0)+ODFDY	DIV.WU	D4,D3	LOAD.W	(A6)+OPETNPY,D4; Calcul le nombre de pages affichables horizontalement.	CLR.L	D3	LOAD.W	D3,(A6)+OLGP	; D3 <-- largeur de la page	DIV.WU	D3,D1	ADD.W	D3,#10*2	; D3 <-- place relle en largeur	CLR.L	D4	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#LDBOXPETIT	SUB.W	D4,(A0)+ODFDX	NEG.W	D4		; D4 <-- largeur sans la dbox	DIV.WU	D4,D3	LOAD.W	(A6)+OPETNPX,D4	POPM.L	D3,D4	RET;---------\\; AFFPETIT >;=========/; Affiche une ou plusieurs pages en mode petit.; in	A4.L	^dbut de l'affichage;	A0.L	^description de la fentre;	D1.W	facteur; out	D7.W	erreur (si page dborde); mod	D7.WAFFPETIT:	PUSHM.L	D0..D6,A4	CALL	SWMO		; souris: met le sablier	LOAD.L	D6,D5		; D6 <-- canal dbox	CALL	DESFLUP		; met/enlve flche contre en haut	LIB	?GETWDO		; D5 <-- no swdo actuelle (dbox)	PUSH.W	D5	CLR.W	D5	LIB	?USEWDO		; utilise la swdo principale	CALL	PAGEGP		; reprend les paramtres (REG et COM)	CLR.L	D4		; D4 <-- origine (y;x)	LOAD.W	D3,(A0)+ODFDY	; D3 <-- hauteur	SWAP.W	D3	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#LDBOXPETIT	SUB.W	D2,(A0)+ODFDX	NEG.W	D2		; D2 <-- largeur sans la dbox	LOAD.W	D3,D2		; D3 <-- largeur	CALL	ITGMOUSE	; enlve la souris si ncessaire	CALL	DISCLEAR	; efface toutes les pages	CALL	DISSCMO		; remet la souris si ncessaire	CLR.L	D3	LOAD.W	D3,(A6)+OHTP	; D3 <-- hauteur de la page	DIV.WU	D3,D1	ADD.W	D3,#10*2	SWAP.W	D3	CLR.L	D0	LOAD.W	D0,(A6)+OLGP	; D0 <-- largeur de la page	DIV.WU	D0,D1	LOAD.W	D3,D0	ADD.W	D3,#10*2	LOAD.L	(A6)+OPETDIM,D3	SUB.W	D2,D3		; D2 <-- origine max en X	JUMP',LO 80$	SWAP.W	D2	SWAP.W	D3	LOAD.W	D2,(A0)+ODFDY	; D2 <-- hauteur	SUB.W	D2,D3		; D2 <-- origine max en Y	JUMP',LO 80$	SWAP.W	D2	SWAP.W	D320$:	CALL	AFPALL		; affiche une petite page	JUMP',NE 85$	COMP.L	A4,(A5)+OPFB	; page suivante existe ?	JUMP',EQ 80$		; si y'en a plus => 80$	ADD.W	D4,D3		; D4 <-- origine suivante en X	COMP.W	D4,D2		; dpasse (dans la dbox) ?	JUMP,LO 20$		; non => 20$	CLR.W	D4	SWAP.W	D4	SWAP.W	D3	SWAP.W	D2	ADD.W	D4,D3		; D4 <-- origine suivante en Y	COMP.W	D4,D2		; dpasse (contre le bas) ?	JUMP',HS 80$		; oui => 80$	SWAP.W	D4	SWAP.W	D3	SWAP.W	D2	JUMP	20$80$:	CLR.W	D7		; D7 <-- pas de dbordement85$:	POP.W	D5	PUSH.W	D7	LIB	?USEWDO		; r-utilise la swdo de la dbox	LOAD.L	D5,D6		; D5 <-- canal dbox	CALL	DESFLDOWN	; met/enlve flche contre en bas	CALL	CWMO		; souris: plus de sablier	POP.W	D7	POPM.L	D0..D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DESPPT  >;--------/; Dessine la touche (PLUS PETIT).; in	D1.W	facteur; out	-; mod	D7.WDESPPT:	PUSHM.L	D2..D4	CLR.W	D2		; D2 <-- rang	DBOX_	GETCO		; D3 <-- coordonne dbut	LIB	?SETCURS	COMP.W	D1,#FACMIN	JUMP',HS 20$	LIB	?AFTIM	.ASCIZ	" PLUS PETIT "	.EVEN	INC.W	D2		; D2 <-- rang	DBOX_	GETCO		; D3 <-- coordonne dbut	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	" MIN "	.EVEN	JUMP'	90$20$:	LIB	?AFTIM	.ASCIZ	"            "	.EVEN	INC.W	D2		; D2 <-- rang	DBOX_	GETCO		; D3 <-- coordonne dbut	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"     "	.EVEN90$:	POPM.L	D2..D4	RET;--------\\; DESPGR  >;--------/; Dessine la touche (PLUS GRAND).; in	D1.W	facteur; out	-; mod	D7.WDESPGR:	PUSHM.L	D1..D4	LOAD.W	D2,#2		; D2 <-- rang	DBOX_	GETCO		; D3 <-- coordonne dbut	LIB	?SETCURS	MUL.WU	D1,#3	DIV.WU	D1,#4	CALL	XYPETIT	TEST.W	(A6)+OPETNPX	JUMP',EQ 20$	TEST.W	(A6)+OPETNPY	JUMP',EQ 20$	LIB	?AFTIM	.ASCIZ	" PLUS GRAND "	.EVEN	INC.W	D2		; D2 <-- rang	DBOX_	GETCO		; D3 <-- coordonne dbut	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	" MAX "	.EVEN	JUMP'	90$20$:	LIB	?AFTIM	.ASCIZ	"            "	.EVEN	INC.W	D2		; D2 <-- rang	DBOX_	GETCO		; D3 <-- coordonne dbut	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"     "	.EVEN90$:	POPM.L	D1..D4	RET;--------\\; DESFLUP >;--------/; Dessine la flche contre en haut.; in	A4.L	^dbut page; out	-; mod	D7.WDESFLUP:	PUSHM.L	D2..D4,A1,A4	CALL	_TPVISU	JUMP',NE 20$		; si on est au dbut => 20$	LOAD.W	D2,#7		; D2 <-- rang	DBOX_	GETCO		; D3 <-- coordonne dbut	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"  MONTE  "	.EVEN	SUB.W	D3,#24	SWAP.W	D3	SUB.W	D3,#18	SWAP.W	D3	LOAD.L	A1,#R16"TFLUP	LOAD.W	D2,#SETDOT	CALL	DESMOTIF	; dessine la flche	JUMP'	90$20$:	LOAD.W	D2,#7		; D2 <-- rang	DBOX_	GETCO		; D3 <-- coordonne dbut	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"         "	.EVEN	SUB.W	D3,#24	SWAP.W	D3	SUB.W	D3,#18	SWAP.W	D3	LOAD.L	A1,#R16"TFLUP	LOAD.W	D2,#CLRDOT	CALL	DESMOTIF	; efface la flche90$:	POPM.L	D2..D4,A1,A4	RET;----------\\; DESFLDOWN >;----------/; Dessine la flche contre en bas.; in	A4.L	^fin page; out	-; mod	D7.WDESFLDOWN:	PUSHM.L	D2..D4,A1,A4	CALL	_TNVISU	JUMP',NE 20$		; si on est  la fin => 20$	LOAD.W	D2,#8		; D2 <-- rang	DBOX_	GETCO		; D3 <-- coordonne dbut	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	" DESCEND "	.EVEN	SUB.W	D3,#24	SWAP.W	D3	ADD.W	D3,#6	SWAP.W	D3	LOAD.L	A1,#R16"TFLDOWN	LOAD.W	D2,#SETDOT	CALL	DESMOTIF	; dessine la flche	JUMP'	90$20$:	LOAD.W	D2,#8		; D2 <-- rang	DBOX_	GETCO		; D3 <-- coordonne dbut	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"         "	.EVEN	SUB.W	D3,#24	SWAP.W	D3	ADD.W	D3,#6	SWAP.W	D3	LOAD.L	A1,#R16"TFLDOWN	LOAD.W	D2,#CLRDOT	CALL	DESMOTIF	; efface la flche90$:	POPM.L	D2..D4,A1,A4	RET;---------\\; DESMOTIF >;---------/; Dessine un motif dcrit par des segments de droites (dy;dx).; in	A1.L	^table du motif (dy;dx);	D3.L	coordonne initiale (y;x);	D2.W	mode de dessin; out	-; mod	D7.WDESMOTIF:	PUSHM.L	D3,D4,A110$:	LOAD.L	D4,(A1+)	; D4 <-- (dy;dx)	JUMP',EQ 90$		; fin de la table => 90$	LIB	?DRSEG		; trace un segment	JUMP	10$90$:	POPM.L	D3,D4,A1	RETTFLUP:	.W	12,-12	.W	0,6	.W	12,0	.W	0,12	.W	-12,0	.W	0,6	.W	-12,-12	.W	0,0TFLDOWN:	.W	-12,-12	.W	0,6	.W	-12,0	.W	0,12	.W	12,0	.W	0,6	.W	12,-12	.W	0,0TFLDEBORDE:	.W	0,-8	.W	6,0	.W	0,-8	.W	6,16	.W	-6,16	.W	0,-8	.W	-6,0	.W	0,-8	.W	0,0;--------\\; AFPALL  >;--------/; Affiche toutes les lignes d'une page en mode petit.; in	A4.L	^dbut de l'affichage;	D4.L	origine (y;x);	D3.L	dimensions (dy;dx);	D1.W	facteur; out	A4.L	^dbut page suivante;	D7.W	erreur (si page dborde); mod	D7.W, A4.LAFPALL:	PUSHM.L	D0..D5,A1	ADD.W	D4,#10-2	SWAP.W	D4	ADD.W	D4,#10-2	SWAP.W	D4	SUB.W	D3,#(10-2)*2	SWAP.W	D3	SUB.W	D3,#(10-2)*2	SWAP.W	D3	PUSH.L	D3		; stack <-- dimensions	PUSH.L	D4		; stack <-- origine	PUSHM.L	D3,D4	LOAD.L	D3,#-1		; D3 <-- trame	LOAD.L	D4,D3		; D4 <-- trame	LIB	?DRMDEF		; dfini pour LIB,?DRRECTO	POPM.L	D3,D4	PUSHM.L	D1,D3,D4	CALL	ITGMOUSE	; enlve la souris si ncessaire	CALL	DISCLEAR	; efface le rectangle	EX.L	D3,D4	LOAD.W	D2,#SETDOT	; D2 <-- <mode>	LOAD.W	D1,#2		; D1 <-- paisseur de l'ombre	LIB	?DRRECTO	; rectangle ombr autour de la page	POPM.L	D1,D3,D4	LOAD.W	D0,(A6)+OMGS	; D0 <-- position Y dbut 1re ligne	TEST.B	(A6)+OFANION+2:#BFANUM-8 ; numrote les pages ?	JUMP',BC 15$		; non => 15$				; oui =>	PUSHM.L	D3,D4	LOAD.L	D3,#H'11441144	; D3 <-- trame	LOAD.L	D4,D3		; D4 <-- trame	LIB	?DRMDEF		; dfini pour LIB,?DRMATRIX	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D2,D3		; D2 <-- <dxx>	LOAD.L	D3,D4		; D3 <-- <yy> <xx> initial	CLR.L	D4	LOAD.W	D4,D0	DIV.WU	D4,D1	SWAP.W	D3	ADD.W	D3,D4		; D3 <-- <yy> aprs marge suprieure	SWAP.W	D3	CALL	_GIVHNUM	; D4 <-- hauteur pour numroter	ADD.W	D0,D4		; D0 <-- position Y dbut 1re ligne	AND.L	D4,#H'FFFF	DIV.WU	D4,D1		; D4 <-- <dyy>	TEST.W	D4	JUMP',EQ 14$	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- <dyy> et <dxx>	LOAD.W	D2,#SETDOT	; D2 <-- <mode>	LIB	?DRMATRIX	; bande grise horizontale pour numrotation14$:	POPM.L	D3,D415$:	LOAD.W	D3,D0		; D3 <-- position Y dbut 1re ligne	LOAD.L	D0,D4	CLR.L	D4	LOAD.W	D4,(A6)+OMGG	DIV.WU	D4,D1	ADD.W	D0,D4		; D0 <-- tient compte de la marge gauche	ADD.W	D0,#2		; D0 <-- origine X	SWAP.W	D0	ADD.W	D0,#2		; D0 <-- origine Y	SWAP.W	D020$:	CALL	SRCHTL		; D4 <-- hauteur de la ligne	LOAD.W	D4,(A6)+OTYR	; D4 <-- hauteur relle (pas forcment paire)	CALL	AFPLINE		; affiche une ligne	CLR.W	D7	COMP.B	D5,#TEOP	JUMP',EQ 80$	COMP.B	D5,#PEOP	JUMP',EQ 80$	COMP.B	D5,#TEOT	JUMP',EQ 80$	COMP.B	D5,#REGLE	JUMP,EQ 20$	ADD.W	D3,D4		; D3 <-- position Y ligne suivante	LOAD.W	D4,(A6)+OHTP	SUB.W	D4,(A6)+OMGI	COMP.W	D3,D4		; page pleine ?	JUMP,LS	20$		; non => 20$				; oui =>	LOAD.L	D3,(SP)+0	; D3 <-- origine	LOAD.L	D4,(SP)+4	; D4 <-- dimensions	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- en bas du rectangle	ADD.W	D3,#2	SWAP.W	D4	SWAP.W	D3	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- au milieu du rectangle	LOAD.L	A1,#R16"TFLDEBORDE	LOAD.W	D2,#SETDOT	CALL	DESMOTIF	; dessine la flche de dbordement	CALL	SRCPDOWN	; A4 <-- ^dbut page suivante	LOAD.W	D7,#1		; D7 <-- dbordement80$:	PUSH.W	D7	CALL	DISSCMO		; remet la souris si ncessaire	POP.W	D7	POPM.L	D3,D4		; pop bidon	POPM.L	D0..D5,A1	TEST.W	D7		; retour EQ/NE	RET;--------\\; AFPLINE >;========/; Affiche une bande horizontale dans la fentre pouvant contenir une; ligne de texte ou une (partie d') image en mode petit.; in	A5.L	^description du buffer;	A4.L	^dans le buffer (dbut ligne);	D3.W	position Y dbut ligne (haut de la ligne);	D4.W	hauteur de la ligne (BAFFIMA ou BAFFREG);	D1.W	facteur de rduction;	D0.L	origine (y;x); out	A4.L	^dans le buffer (dbut ligne suivante);	D5.B	dernier caractre; mod	D5.W, D7.W, A4.LAFPLINE:	PUSHM.L	D2,D3	TEST.L	D4:#BAFFIMA	; est-ce une image ?	JUMP',BC 10$		; non => 10$	CALL	AFPIMAGE	; oui => affiche une image	LOAD.B	D3,#IMAGE	JUMP	90$10$:	TEST.L	D4:#BAFFREG	; est-ce une rglette ?	JUMP',BC 20$		; non => 20$	CALL	AFPREGLE	; oui => affiche une rglette	LOAD.B	D3,#REGLE	JUMP	90$20$:	LOAD.W	D2,D3		; D2 <-- position Y haut de la ligne	ADD.W	D2,(A6)+OT1YM	; D2 <-- position Y ligne de base	SWAP.W	D2	CLR.W	D2		; D2 <-- position X40$:	CALL	_NVISU		; D3 <-- caractre suivant	JUMP',EQ 50$		; ok => 50$	LOAD.B	D3,#TEOT	; D3 <-- fin du texte	COMP.W	D7,#ERTHOL	; trou rencontr ?	JUMP',NE 90$		; non (EOB) => 90$;	...	JUMP	40$50$:	CALL	IFIEOL		; fin de la ligne ?	JUMP',EQ 90$		; oui => 90$	CALL	AFPTYPO		; affiche le caractre	CALL	_VADDLGC	; D2 <-- compte la largeur	JUMP	40$90$:	LOAD.W	D5,D3		; D5 <-- dernier caractre	POPM.L	D2,D3	RET;--------\\; AFPTYPO >;========/; Affiche un "caractre" en mode petit, sous la forme d'un point.; in	D3.W	caractre;	D2.L	coordonne (y;x);	D1.W	facteur de rduction;	D0.L	origine (y;x); out	-; mod	D7.WAFPTYPO:	TEST.L	D3:#BSPEC	; caractre spcial ?	JUMP',BS 90$		; oui => 90$	COMP.B	D3,#TAB	JUMP',EQ 90$	COMP.B	D3,#SAJEXM	JUMP',EQ 90$	COMP.B	D3,#SAJEXT	JUMP',EQ 90$	TEST.B	(A6)+OPETFA+3:#2; paragraphe ?	JUMP',BS 50$		; oui => 50$	COMP.B	D3,#SAJEXS	JUMP',EQ 90$	COMP.B	D3,#SPACE	JUMP',EQ 90$	COMP.B	D3,#CADRATIN	JUMP',EQ 90$50$:	CALL	AFPCAR		; affiche un petit caractre90$:	RET;--------\\; AFPCAR  >;========/; Affiche un petit caractre selon les dimensions du gnrateur de; caractres contenu dans OVCOM (selon NVISU/PVISU).; in	D3.W	caractre;	D2.L	coordonne (y;x);	D1.W	facteur de rduction;	D0.L	origine (y;x); out	-; mod	D7.WAFPCAR:	PUSHM.L	D0..D5,A2..A4	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	CLR.W	D4	LOAD.B	D4,(A5)+OVCOM+OCOMNOG ; D4 <-- no du gencar	MUL.WU	D4,#LGGC	LOAD.L	A3,#(A6)+OBUGC	ADD.L	A3,D4		; A3 <-- ^dans OBUGC	LOAD.L	A3,(A3)+OGCPT	; A3 <-- ^gencar	LOAD.L	D4,D2		; D4 <-- position curseur typo	LOAD.W	D2,D3		; D2 <-- code du caractre	COMP.B	D2,(A3)+OGCLCA	; code caractre trop grand ?	JUMP,HI 90$		; oui => 90$	SUB.B	D2,(A3)+OGCFCA	; code caractre trop petit ?	JUMP,LO 90$		; oui => 90$	SWAP.W	D4	TEST.B	(A6)+OPETFA+3:#2; paragraphe ?	JUMP',BC 25$		; non => 25$	SUB.W	D4,(A6)+OT1YM	; D4 <-- en haut de la tranche	JUMP'	35$25$:	LOAD.W	D3,(A3)+OGCMHD	SUB.W	D3,(A3)+OGCBLI	; D3 <-- hauteur  remonter	SUB.W	D4,D3		; D4 <-- en haut du caractre	TEST.B	(A5)+OVCOM+OCOMMOD:#BMODDOWN	JUMP',BS 30$	TEST.B	(A5)+OVCOM+OCOMMOD:#BMODUP	JUMP',BC 35$				; exposant =>	SR.W	D3,#1		; D3 <-- hauteur  monter	SUB.W	D4,D3		; D4 <-- monter encore un peu	JUMP'	35$30$:				; indice =>	SR.W	D3,#1		; D3 <-- hauteur  redescendre	ADD.W	D4,D3		; D4 <-- descend un peu35$:	SWAP.W	D4	LOAD.L	A4,#(A3)+OGCWID	; A4 <-- ^table des largeurs	COMP.B	D2,#SAJEXM	JUMP',EQ 40$	COMP.B	D2,#SAJEXT	JUMP',EQ 40$	COMP.B	D2,#SAJEXS	JUMP',EQ 40$	AND.W	D2,#H'7F	; D2 <-- juste le caractre	CLR.W	D3	LOAD.B	D3,(A4)+(D2.W)	; D3 <-- largeur caractre	JUMP'	45$40$:	LOAD.W	D3,D2	SR.W	D3,#8		; D3 <-- largeur du SAJEX(S)	AND.W	D2,#H'7F	; D2 <-- juste le caractre45$:	TEST.B	(A6)+OPETFA+3:#0; caractres ?	JUMP',BS 50$		; oui => 50$	INC.W	D3		; non => un de plus pour contigu50$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OT1YM	ADD.W	D3,(A6)+OT2YM	; D3 <-- hauteur totale de la tranche	INC.W	D3		; D3 <-- un de plus pour contigu	TEST.B	(A6)+OPETFA+3:#2; paragraphe ?	JUMP',BS 60$		; oui => 60$	LOAD.W	D3,(A3)+OGCMHD	TEST.B	(A6)+OPETFA+3:#0; caractres ?	JUMP',BC 60$		; non => 60$	CLR.W	D5	LOAD.B	D5,(A3)+OGCLCA	SUB.B	D5,(A3)+OGCFCA	INC.B	D5		; D5 <-- nb caractres dans gencar	ADD.W	A4,D5		; A4 <-- saute largeurs	ADD.W	D4,(A3)+OGCMHD	SUB.W	D4,(A3)+OGCBLI	CLR.W	D3	LOAD.B	D3,(A4)+(D2.W)	; D3 <-- h1	SUB.W	D4,D3	ADD.W	A4,D5		; A4 <-- saute h1	ADD.B	D3,(A4)+(D2.W)	; D3 <-- h1+h260$:	SWAP.W	D4	SWAP.W	D3	LOAD.L	D2,#-1		; D2 <-- trame	CALL	AFPDOT		; affiche un petit point90$:	POPM.L	D0..D5,A2..A4	RET;---------\\; AFPIMAGE >;=========/; Affiche une image en mode petit.; in	D3.W	position Y dbut ligne (haut de la ligne);	D4.W	hauteur de la ligne (BAFFIMA ou BAFFREG);	D1.W	facteur de rduction;	D0.L	origine (y;x);	A4.L	^dbut ligne; out	A4.L	^ligne suivante; mod	D7.W, A4.LAFPIMAGE:	PUSHM.L	D2..D4	LOAD.W	D2,D3	CALL	IMAPARAM	; D3 <-- <ixx>  D4 <-- dy;dx	JUMP',NE 80$	EX.L	D3,D4		; D3 <-- dimensions (dy;dx)	ADD.W	D4,(A5)+OVREG+OREGRENF	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- position (y;x)	SWAP.W	D4	LOAD.L	D2,#H'55AA55AA	; D2 <-- trame	CALL	AFPDOT		; dessine un rectangle pour l'image80$:	CALL	SRCDOWN		; A4 <-- ^dbut ligne suivante	POPM.L	D2..D4	RET;---------\\; AFPREGLE >;=========/; Affiche une rgle en mode petit.; in	D3.W	position Y dbut ligne (haut de la ligne);	D4.W	hauteur de la ligne (BAFFIMA ou BAFFREG);	D2.L	coordonne (y;x);	D1.W	facteur de rduction;	D0.L	origine (y;x);	A4.L	^dbut ligne; out	A4.L	^ligne suivante; mod	D7.W, A4.LAFPREGLE:	CALL	SRCDOWN		; A4 <-- ^dbut ligne suivante	RET;---------\\; AFPDOT   >;=========/; Affiche un petit point.; in	D4.L	position (y;x);	D3.L	dimensions (dy;dx);	D2.L	trame;	D1.W	facteur de rduction;	D0.L	origine (y;x); out; mod	D7.WAFPDOT:	PUSHM.L	D0..D6	CLR.L	D5	LOAD.W	D5,D3	DIV.WU	D5,D1	LOAD.L	D6,D5	SWAP.W	D6	SL.W	D6,#1	COMP.W	D6,D1	JUMP',LO 10$	INC.W	D510$:	LOAD.W	D3,D5		; D3 <-- dimension X	JUMP',NE 15$	INC.W	D3		; D3 <-- au moins un15$:	CLR.L	D5	LOAD.W	D5,D4	DIV.WU	D5,D1	LOAD.L	D6,D5	SWAP.W	D6	SL.W	D6,#1	COMP.W	D6,D1	JUMP',LO 20$	INC.W	D520$:	ADD.W	D5,D0	LOAD.W	D4,D5		; D4 <-- origine X	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	CLR.L	D5	LOAD.W	D5,D3	DIV.WU	D5,D1	LOAD.L	D6,D5	SWAP.W	D6	SL.W	D6,#1	COMP.W	D6,D1	JUMP',LO 30$	INC.W	D530$:	LOAD.W	D3,D5		; D3 <-- dimension Y	JUMP',NE 35$	INC.W	D3		; D3 <-- au moins un35$:	CLR.L	D5	LOAD.W	D5,D4	DIV.WU	D5,D1	LOAD.L	D6,D5	SWAP.W	D6	SL.W	D6,#1	COMP.W	D6,D1	JUMP',LO 40$	INC.W	D540$:	ADD.W	D5,D0	LOAD.W	D4,D5		; D4 <-- origine Y	SWAP.W	D4	SWAP.W	D3	COMP.L	D3,#H'10000*1+1	; dimensions (1;1) ?	JUMP',EQ 60$		; oui => 60$				; non =>	LOAD.L	D1,D2		; D1 <-- trame	LOAD.L	D0,D2		; D0 <-- trame	LOAD.W	D2,#SETDOT	; D2 <-- mode	CALL	DISTRAME	; dessine un rectangle blanc	JUMP'	90$60$:	LOAD.W	D2,#SETDOT	; D2 <-- mode	CALL	DISDOT		; dessine juste un point blanc90$:	POPM.L	D0..D6	RET	.END