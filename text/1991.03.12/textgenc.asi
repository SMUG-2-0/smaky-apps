	.SBTTL	TEXTGENC;-----------\\; DBOXGENCAR >;===========/; Dialogue pour la DBOX des gencars.; in	-; out	D7.W	erreur; mod	D7.WDBOXGENCAR:	PUSHM.L	D0..D5,A0..A5	CLR.W	D0		; D0 <-- nb de modifications10$:	LOAD.L	D4,(A6)+OFAGC	; D4 <-- fanions	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A5,#(A6)+OGCLIST; A5 <-- ^liste des gencars sur disque	LOAD.W	D5,#MAXGENC*3	; D5 <-- lg pour la liste	LOAD.L	D1,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^descripteur de la fentre	DGENC_	MODIF		; modifie un/qq gencar(s) ...	JUMP',NE 90$	LOAD.L	(A6)+OFAGC,D4	; mm. derniers fanions utiliss	COMP.W	D3,#F1	JUMP',EQ 30$	COMP.W	D3,#F4	JUMP',EQ 50$	JUMP'	80$30$:				; MODIFIE =>	INC.W	D0		; D0 <-- une modification de plus	JUMP	10$50$:				; SUPPRIME =>	LOAD.L	A5,#(A6)+OBUFP	CALL	SWMO		; souris: met le sablier	CALL	SUPGC		; supprime le gencar PARTOUT	CALL	CWMO		; souris: remet la flche	INC.W	D0		; D0 <-- une modification de plus	JUMP	10$80$:	LOAD.L	A5,#(A6)+OBUFP	TEST.W	D0		; texte modifi ?	JUMP',EQ 90$		; non => 90$	CALL	AJUSTIF		; oui => re-justifie tout !90$:	PUSH.W	D7	CALL	SPASOULGC	; remplace espace par soulign dans titres	TCLR.B	(A6)+OFLAGS:#BMDBOX	CALL	DBOXREFAIT	; remet les soft-keys	POP.W	D7	POPM.L	D0..D5,A0..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; SPASOULGC >;----------/; Remplace tous les espaces dans les titres des gencars; par des souligns.; in	-; out	-; mod	D7.WSPASOULGC:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,#(A6)+OBUGC	LOAD.W	D4,#MAXGC-110$:	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar occup ?	JUMP',BC 50$		; non => 50$	LOAD.L	A3,#(A4)+OGCTIT	; A3 <-- ^titre du gencar20$:	LOAD.B	D3,(A3+)	JUMP',EQ 50$	COMP.B	D3,#SPACE	JUMP,NE 20$	LOAD.B	(A3)-1,#'_	; remplace espace par soulign	JUMP	20$50$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^gencar suivant	DECJ.W,NMO D4,10$	POPM.L	D3,D4,A3,A4	RET;----------\\; DISABLEGC >;==========/; Libre provisoirement tous les gencars.; in	-; out	-; mod	D7.WDISABLEGC:	PUSHM.L	A2,A4	CALL	GCDEF		; utilise g.c. par dfaut	LIB	?AFTIM	.B	KILLGC,GCICF,GCICS,GCICT ; libre le gencar des icnes	.B	0	.EVEN	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^descripteur de la fentre	DGENC_	DISGC		; disable tous les gencars	POPM.L	A2,A4	RET;---------\\; ENABLEGC >;=========/; Reprend tous les gencars librs provisoirement.; in	-; out	-; mod	D7.WENABLEGC:	PUSHM.L	A2,A4	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT ; charge le gencar du texte	.B	LOADGC,GCICF,GCICS,GCICT ; charge le gencar des icnes	.B	0	.EVEN	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^descripteur de la fentre	DGENC_	ENAGC		; enable tous les gencars	CALL	GCDEF		; utilise g.c. par dfaut	POPM.L	A2,A4	RET;--------\\; FLUSHGC >;========/; Libre tous les gencars qui ne sont utiliss plus que par; la zone vide.; in	A5.L	^description du buffer; out	-; mod	D7.WFLUSHGC:	PUSHM.L	D1..D4,A3,A4	LOAD.W	D1,(A5)+ONOBUF	; D1 <-- numro du buffer	LOAD.L	A4,#(A6)+OBUGC	LOAD.W	D2,#MAXGC-110$:	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar occup ?	JUMP',BC 50$		; non => 50$	TEST.B	(A4)+OGCFLG:#BGCPROT ; gencar protg ?	JUMP',BS 50$		; oui => 50$	LOAD.L	D3,(A4)+OGCMAP	TCLR.L	D3:D1	LOAD.L	(A4)+OGCMAP,D3	JUMP',NE 50$		; si encore occup => 50$				; si plus personne ne l'utilise =>;;?	TEST.B	(A4)+OGCFLG:#BGCPROT ; gencar indestructible ?;;?	JUMP',BS 50$		; oui => 50$	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	KILL		; libre le gencar	JUMP',NE 50$	TCLR.B	(A4)+OGCFLG:#BGCUSE ; signal gencar libre50$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^gencar suivant	DECJ.W,NMO D2,10$	POPM.L	D1..D4,A3,A4	RET;--------\\; SUPGC   >;========/; Supprime partout o est utilis un gencar.; in	A4.L	^dans OBUGC le gencar  supprimer; out	-; mod	D7.WSUPGC:	PUSHM.L	D0..D4,A2,A3	LOAD.L	A2,#(A6)+OBUGC	LOAD.L	D2,A4	SUB.L	D2,A2	DIV.WU	D2,#LGGC	; D2 <-- rang du gencar	LOAD.W	D1,(A5)+ONOBUF	; D1 <-- no buffer initial	CLR.W	D010$:	LOAD.L	D3,(A4)+OGCMAP	TEST.L	D3:D0		; gencar utilis dans cette zone ?	JUMP',BC 50$		; non => 50$	CALL	INI1B		; A5 <-- ^description de la zone	CALL	SUPZGC		; supprime le gencar dans la zone	COMP.W	D0,D1	JUMP',EQ 50$	CALL	AJUSTIF		; rejustifie tout50$:	INC.W	D0	COMP.W	D0,#NBBF	JUMP,LO 10$	LOAD.W	D0,D1	CALL	INI1B		; remet la zone initiale	TEST.B	(A4)+OGCFLG:#BGCPROT ; gencar indestructible ?	JUMP',BS 90$		; oui => 90$				; non =>	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	KILL		; libre le gencar	JUMP',NE 90$	TCLR.B	(A4)+OGCFLG:#BGCUSE ; signal gencar libre90$:	POPM.L	D0..D4,A2,A3	RET;--------\\; SUPZGC  >;--------/; Supprime un gencar partout o il est utilis dans un buffer.; in	D2.B	no du gencar  supprimer; out	-; mod	D7.WSUPZGC:	PUSHM.L	D1..D4,A4; Met une marque pour retrouver la position du curseur.	LOAD.B	D3,#MARQUED	CALL	INSERT		; marque la position du curseur	JUMP',NE 90$; Revient au dbut du texte et justifie tout.	CALL	VADEBUT		; revient au dbut	CLR.B	D1		; D1 <-- no gencar "Fond"20$:	CALL	AVANCE		; D3 <-- caractre suivant	JUMP',NE 70$	COMP.B	D3,#COMMAND	; commande ?	JUMP,NE 20$		; non => 20$				; oui =>	COMP.B	D2,(A5)+OCCOM+OCOMNOG ; commande gencar  supprimer ?	JUMP',EQ 40$		; oui => 40$	LOAD.B	D1,(A5)+OCCOM+OCOMNOG	JUMP	20$40$:	CALL	RECULE		; recule sur la commande	LOAD.L	A4,(A5)+OPFT	LOAD.B	(A4)+1+LGCOM+OCOMNOG,D1	CALL	MODCOMMAND	CALL	AVANCE		; saute la commande modifie	JUMP	20$; Recule jusqu' la marque pour remettre le curseur  sa place; originale, puis enlve la marque.70$:	LOAD.L	A4,(A5)+OPDT80$:	CALL	PVISU	JUMP',NE 90$	COMP.B	D3,#MARQUED	JUMP,NE	80$	CALL	VAQQPART	CALL	DAVANCE		; enlve la marque90$:	CALL	PSEUDOAV	; avance encore si pseudo-caractres	POPM.L	D1..D4,A4	RET;--------\\; SRCGC   >;========/; Cherche un gencar d'aprs son titre.; Si le gencar cherch est dans OBUGC, il ne se trouve pas lui-mme !; in	A3.L	^nom d'un titre de gencar; out	A4.L	^dans OBUGC;	D4.W	no du gencar;	D7.W	erreur; mod	D4.W, D7.W, A4.LSRCGC:	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	DGENC_	SEARCH		; cherche	RET;--------\\; FREGC   >;========/; Cherche un gencar libre.; in	-; out	A4.L	^dans OBUGC;	D4.W	no du gencar;	D7.W	erreur; mod	D4.W, D7.W, A4.LFREGC:	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	DGENC_	FREE		; cherche gencar libre	JUMP',NE 90$	CLR.L	(A4)+OGCMAP	; utilis par aucune zone90$:	RET;--------\\; LODGC   >;========/; Si ncessaire, charge un nouveau gnrateur de caractre.; Il est interdit de librer le gencar, car il peut tre utilis; dans un buffer de texte !; in	A4.L	^lment dans OBUGC; out	D7.W	erreur; mod	D7.WLODGC:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A2,#(A6)+OBUGC	LOAD.L	D3,A4	SUB.L	D3,A2	DIV.WU	D3,#LGGC	; D3 <-- no du gencar (0..MAXGC-1)	CALL	UZGC		; signal gencar utilis par cette zone	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	NEW		; charge nouveau gencar	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; UZGC    >;========/; Signal qu'un gencar est utilis dans une zone donne.; in	A5.L	^description du buffer;	D3.B	no du gencar (0..MAXGC-1); out	-; mod	-UZGC:	PUSHM.L	D2,D3,A4	LOAD.L	A4,#(A6)+OBUGC	AND.W	D3,#H'FF	MUL.WU	D3,#LGGC	ADD.W	A4,D3		; A4 <-- ^dans OBUGC	LOAD.W	D2,(A5)+ONOBUF	; D2 <-- no du buffer	LOAD.L	D3,(A4)+OGCMAP	TSET.L	D3:D2	LOAD.L	(A4)+OGCMAP,D3	POPM.L	D2,D3,A4	RET;--------\\; MAJNGC  >;========/; Construit le nom du gencar en fonction des 3 bytes compactifis.; in	A4.L	^dans OBUGC; out	-; mod	D7.WMAJNGC:	PUSHM.L	D4,A3	LOAD.L	A3,#(A4)+OGCNAM	LOAD.L	D4,(A4)+OGCCOD	; D4 <-- "-fst"	DGENC_	PUT	POPM.L	D4,A3	RET;--------\\; SYNGC   >;========/; Vrifie la syntaxe d'un nom de gencar "fsctt".; in	A3.L	^fsctt; out	A3.L	^plus loin;	D5.L	"fst" compactifi :	| - | f | s | t |;	D7.W	erreur; mod	D5.L, D7.W, A3.LSYNGC:	DGENC_	GET		; D5 <-- "-fst"	RET;--------\\; GCDEF   >;========/; Utilise le gnrateur de caractre par dfaut.; in	-; out	-; mod	D7.WGCDEF:	PUSHM.L	D4,D6,A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#USEGC	LOAD.B	(A4)+1,#GCTXF	LOAD.B	(A4)+2,#GCTXS	LOAD.B	(A4)+3,#GCTXT	LOAD.L	D4,#4	LOAD.W	D6,(A6)+OCHDIS	; D6 <-- canal	FOS	?WRBYTE	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GCICONE >;========/; Utilise le gnrateur de caractres des icnes.; in	-; out	D7.W	erreur; mod	D7.WGCICONE:	PUSHM.L	D4,D6,A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#USEGC	LOAD.B	(A4)+1,#GCICF	LOAD.B	(A4)+2,#GCICS	LOAD.B	(A4)+3,#GCICT	LOAD.L	D4,#4	LOAD.W	D6,(A6)+OCHDIS	; D6 <-- canal	FOS	?WRBYTE	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET	.END