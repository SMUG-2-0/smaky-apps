	.SBTTL	TEXTREGLE;---------\\; INSREGLE >;=========/; Cre une nouvelle rglette, identique  la prcdente (contre en haut).; Il n'est pas ncessaire de justifier jusqu' la rglette suivante; puisque la rglette est identique. Par contre, il faut justifier; la ligne, au cas o la rglette est insre au milieu.;	           |--------------------------------|   <-- dj fait;	           |------------|--|                |   <--  faire;	           |            V  V                V;	-------(Rp-Rn)---------(Rp-Rn)====---------(Rp-Rn)-------;	                              ^   ^;	                              DT  FT; in	-; out	D7.W	erreur; mod	D7.WINSREGLE:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,(A5)+OPDT	CALL	UPREGLE		; (A6)+OUREG <-- rglette prcdente	CALL	GOBOP		; revient au dbut du paragraphe	CALL	NILREGLE	; cre une rglette vierge	JUMP',NE 80$	LOAD.L	A4,#(A6)+OUREG	LOAD.L	A3,(A5)+OPDT	LOAD.L	A3,#(A3)-(LGREG+1)	CALL	UPDREGLE	; mj paramtres "next"	LOAD.L	A3,(A5)+OPDT	LOAD.L	A3,#(A3)-(LGREG+LGREG+1)	CALL	UPDREGLE	; mj paramtres "prev"	LOAD.L	A3,#(A5)+OCREG	CALL	COPREGLE	; OCREG <-- nouvelle rglette en cours	CALL	_QJUSTIF	; justifie un p'tit peu	LOAD.W	D4,#MODALL	CALL	MODIF		; faudra tout repeindre	CLR.W	D7		; D7 <-- ok80$:	CALL	IOERROR		; affiche erreur si ncessaire	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; NILREGLE >;=========/; Cre une nouvelle rglette vierge (sans paramtres).; in	-; out	D7.W	erreur; mod	D7.WNILREGLE:	PUSHM.L	D3,D4	LOAD.W	D4,#1+(LGREG*2)+1	CALL	PLACE?		; place pour une rgle ?	JUMP',NE 90$		; non => 90$	LOAD.B	D3,#DEBREG	; <debreg>	CALL	CINSERT; Cre de la place pour les paramtres "prev" et "next".	LOAD.W	D4,#LGREG*250$:	CLR.B	D3	CALL	CINSERT	DEC.W	D4	JUMP,NE	50$	LOAD.B	D3,#FINREG	; <finreg>	CALL	CINSERT90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; NEWREGLE >;=========/; Met  jour les rglettes en fonction d'une nouvelle rglette cre.; Doit tre utilis chaque fois qu'une nouvelle rglette est mise; par un autre moyen que INSREGLE (copie, insertion de fichier, etc).;	           |------------|  |---------------|;	           |            V  |               V;	-------(Rp-Rn)---------(Rp-Rn)====--------(Rp-Rn)-------;	                              ^   ^;	                              DT  FT; in	-; out	D7.W	ok; mod	D7.WNEWREGLE:	PUSHM.L	D3,A3,A4	LOAD.L	A4,(A5)+OPDT	CALL	PVISU		; A4 <-- recule nouvelle rglette	CALL	UPREGLE		; OUREG <-- rglette prcdente	LOAD.L	A4,#(A6)+OUREG	LOAD.L	A3,(A5)+OPDT	LOAD.L	A3,#(A3)-(LGREG+LGREG+1)	CALL	UPDREGLE	; mj paramtres "prev"	LOAD.L	A4,(A5)+OPFT	CALL	DOWNREGLE	; ODREG <-- rglette suivante	JUMP',NE 60$	LOAD.L	A3,#(A4)+1	LOAD.L	A4,(A5)+OPDT	LOAD.L	A4,#(A4)-(LGREG+1)	CALL	COPREGLE	; mj paramtres "next"60$:	LOAD.L	A3,#(A5)+OCREG	LOAD.L	A4,(A5)+OPDT	LOAD.L	A4,#(A4)-(LGREG+1)	CALL	MAJREGLE	; OCREG <-- rglette en cours ici	CLR.W	D7		; D7 <-- ok	POPM.L	D3,A3,A4	RET;---------\\; MODREGLE >;=========/; Met  jour la rglette suivante en fonction d'une rglette modifie.; La rglette modifie est forcment sous le curseur !;	                           |----------------|;	                           |                V;	-------(Rp-Rn)-----====(Rp-Rn)-------------(Rp-Rn)-------;	                   ^   ^;	                   DT  FT; in	-; out	D7.W	ok; mod	D7.WMODREGLE:	PUSHM.L	D3,A3,A4	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^rglette modifie	CALL	TNVISU		; A4 <-- saute la rglette modifie	CALL	DOWNREGLE	; (A6)+ODREG <-- rglette suivante	JUMP',NE 80$		; pas de rglette suivante => 80$	LOAD.L	A3,#(A4)+1	; A3 <-- ^paramtres "prev"	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^rglette modifie	LOAD.L	A4,#(A4)+1+LGREG	CALL	COPREGLE	; suivante[prev] <-- actuelle[next]80$:	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^rglette modifie	LOAD.L	A4,#(A4)+1+LGREG	LOAD.L	A3,#(A5)+OCREG	CALL	MAJREGLE	; OCREG <-- nouvelle rglette en cours	CLR.W	D7		; D7 <-- ok	POPM.L	D3,A3,A4	RET;---------\\; DELREGLE >;=========/; Met  jour la rglette infrieure en fonction de la rglette; suprieure aprs avoir dtruit une rglette entre les deux.;	           |--------------------------------|;	           |                                V;	-------(Rp-Rn)---------=======-------------(Rp-Rn)-------;	                       ^      ^;	                       DT     FT; in	-; out	-; mod	D7.WDELREGLE:	PUSHM.L	A3,A4	LOAD.L	A4,(A5)+OPDT	CALL	UPREGLE		; (A6)+OUREG <-- rglette prcdente	LOAD.L	A4,#(A6)+OUREG	LOAD.L	A3,#(A5)+OCREG	CALL	COPREGLE	; OCREG <-- nouvelle rglette en cours	LOAD.L	A4,(A5)+OPFT	CALL	DOWNREGLE	; (A6)+ODREG <-- rglette suivante	JUMP',NE 90$	LOAD.L	A3,#(A4)+1	; A3 <-- ^paramtres "prev"	LOAD.L	A4,#(A6)+OUREG	CALL	UPDREGLE	; suivante[prev] <-- prcdente[next]90$:	POPM.L	A3,A4	RET;---------\\; SLAREGLE >;=========/; Cherche une rgle ayant un certain label.; in	D3.B	label cherch (1..10); out	A4.L	^variables de la rgle;	D7.W	erreur; mod	D7.W, A4.LSLAREGLE:	LOAD.L	A4,(A5)+OPDB	; A4 <-- ^dbut du texte10$:	CALL	DOWNREGLE	; A4 <-- ^dbut de la rgle	JUMP',NE 90$	LOAD.L	A4,#(A4)+1+LGREG	COMP.B	D3,(A4)+OREGLAB	; est-ce le bon label ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	A4,#(A4)+1+LGREG	JUMP	10$90$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; LABREGLE >;=========/; Si la rgle possde un label, met aussi  jour les autres; rgles du mme label.; in	A4.L	^variables de la rgle; out	-; mod	D7.WLABREGLE:	PUSHM.L	D3,A2..A4	LOAD.L	A3,A4		; A3 <-- ^variables de la rgle	LOAD.B	D3,(A3)+OREGLAB	; D3 <-- label	JUMP,EQ 90$		; si rgle isole => 90$				; si rgle groupe =>	CALL	SWMO		; souris: met le sablier	LOAD.L	A2,#0		; A2 <-- ^rgle prcdente	LOAD.L	A4,(A5)+OPDB	; A4 <-- ^dbut du texte10$:	CALL	DOWNREGLE	; A4 <-- ^dbut de la rgle	JUMP,NE 80$	COMP.B	D3,(A4)+1+LGREG+OREGLAB ; est-ce le bon label ?	JUMP',NE 30$		; non => 30$				; oui =>	PUSHM.L	A3,A4	EX.L	A3,A4	LOAD.L	A3,#(A3)+1+LGREG	CALL	UPDREGLE	; met  jour une rgle	POPM.L	A3,A430$:	COMP.L	A2,#0		; rgle prcdente existe ?	JUMP',EQ 50$		; non => 50$				; oui =>	PUSHM.L	A3,A4	LOAD.L	A3,#(A4)+1	LOAD.L	A4,#(A2)+1+LGREG	CALL	COPREGLE	; actuelle[prev] <-- prcdente[next]	POPM.L	A3,A450$:	LOAD.L	A2,A4		; A2 <-- ^rgle prcdente	LOAD.L	A4,#(A4)+(1+LGREG)*2	JUMP	10$80$:	CALL	_AJUSTIF	; re-justifie tout !90$:	POPM.L	D3,A2..A4	RET;----------\\; CHKREGLES >;==========/; Vrifie toutes les rglettes.; in	-; out	-; mod	D7.WCHKREGLES:	PUSHM.L	D3,A3,A4	LOAD.L	A4,(A5)+OPDB	; A4 <-- ^dbut du buffer	COMP.B	(A4),#DEBREG	JUMP',EQ 20$10$:	CALL	QUICKDOWN	; cherche contre en bas	JUMP,NE 90$		; pas trouv => 90$	COMP.B	D3,#DEBREG	; dbut d'une rglette ?	JUMP,NE	10$		; non => 10$				; oui =>	DEC.L	A4		; A4 <-- ^dbut rglette	PUSH.L	A4	LOAD.L	A3,#(A4)+1	; A3 <-- ^paramtres "prev"	LOAD.L	A4,#(A6)+OSREG	CALL	UPDREGLE	; actuelle[prev] <-- met  jour	POP.L	A420$:	PUSH.L	A4	LOAD.L	A4,#(A4)+1+LGREG; A4 <-- ^paramtres "next"	LOAD.L	A3,#(A6)+OSREG	CALL	MAJREGLE	; OSREG <-- rglette	EX.L	A3,A4	CALL	CHKREGLE	; vrifie si tout est ok	CALL	UPDREGLE	; actuelle[next] <-- met  jour	POP.L	A4	LOAD.L	A4,#(A4)+(1+LGREG)*2	JUMP	10$90$:	POPM.L	D3,A3,A4	RET;---------\\; CHKREGLE >;---------/; Vrifie si tout est en ordre dans une rglette, par-rapport  la; largeur du papier utilis.; in	A4.L	^variables de la rglette; out	D7.W	nb de modifications effectues (0..n); mod	D7.WCHKREGLE:	PUSHM.L	D0..D3,A3	LOAD.W	D1,(A6)+OLGP	SUB.W	D1,(A6)+OMGG	; D1 <-- largeur maximale	CLR.W	D0		; D0 <-- nb de modifications	COMP.W	D1,(A4)+OREGMGD	JUMP',HS 10$	LOAD.W	(A4)+OREGMGD,D1	INC.W	D0		; D0 <-- une modification de plus; Supprime tous les tabulateurs qui dpassent  droite.10$:	SUB.W	D1,#8+820$:	LOAD.L	A3,#(A4)+OREGTAB	LOAD.W	D3,#MAXTAB	; D3 <-- tabulateurs22$:	TEST.W	(A3)		; place libre ?	JUMP',EQ 25$		; oui => 25$	LOAD.W	D2,(A3)		; D2 <-- position	AND.W	D2,#MASKTAB	COMP.W	D2,D1		; dpasse  droite ?	JUMP',LO 25$		; non => 25$				; oui =>	CALL	SUBTAB		; supprime le tabulateur	INC.W	D0		; D0 <-- une modification de plus	JUMP	20$25$:	ADD.L	A3,#2		; A3 <-- ^tabulateur suivant	DEC.W	D3		; encore un ?	JUMP,NE	22$		; oui => 22$	LOAD.W	D7,D0		; D7 <-- nb de modifications	POPM.L	D0..D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; VAQQREGLE >;==========/; Cherche la rgle valide d'aprs un pointeur dans un buffer.; in	A5.L	^description d'un buffer;	A4.L	^dans le buffer;	A3.L	^pour paramtres de la rglette; out	A4.L	^dbut de la rglette;	D7.W	erreur; mod	D7.W, A4.LVAQQREGLE:	PUSH.W	D310$:	CALL	QUICKUP		; cherche contre en haut	JUMP',NE 50$		; pas trouv => 50$	COMP.B	D3,#DEBREG	; dbut d'une rglette ?	JUMP,NE	10$		; non => 10$				; oui =>	PUSH.L	A4	LOAD.L	A4,#(A4)+1+LGREG; A4 <-- ^paramtres "next"	CALL	MAJREGLE	; met  jour les variables	POP.L	A4	CLR.W	D7		; D7 <-- commande trouve	JUMP'	90$50$:				; pas trouve =>	CALL	DEFREGLE	; met  jour les variables	LOAD.W	D7,#ERTNOT	; D7 <-- commande pas trouve90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; UPREGLE >;========/; Cherche la rgle la plus proche contre en haut.; in	A5.L		^description d'un buffer;	A4.L		^dans le buffer; out	(A6)+OUREG	paramtres de la rglette;	A4.L		^dbut de la rglette;	D7.W		erreur; mod	D7.W, A4.LUPREGLE:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OUREG	; A3 <-- ^descripteur rglette10$:	CALL	QUICKUP		; cherche contre en haut	JUMP',NE 50$		; pas trouv => 50$	COMP.B	D3,#DEBREG	; dbut d'une rglette ?	JUMP,NE	10$		; non => 10$				; oui =>	PUSH.L	A4	LOAD.L	A4,#(A4)+1+LGREG; A4 <-- ^paramtres "next"	CALL	MAJREGLE	; met  jour les variables	POP.L	A4	CLR.W	D7		; D7 <-- rglette trouve	JUMP'	90$50$:	CALL	DEFREGLE	; met  jour les variables	LOAD.W	D7,#ERTNOT	; D7 <-- rglette pas trouve90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; DOWNREGLE >;==========/; Cherche la rgle la plus proche contre en bas.; in	A5.L		^description d'un buffer;	A4.L		^dans le buffer; out	(A6)+ODREG	paramtres de la rglette;	A4.L		^dbut de la rglette;	D7.W		erreur; mod	D7.W, A4.LDOWNREGLE:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+ODREG	; A3 <-- ^descripteur rglette10$:	CALL	QUICKDOWN	; cherche contre en bas	JUMP',NE 50$		; pas trouv => 50$	COMP.B	D3,#DEBREG	; dbut d'une rglette ?	JUMP,NE	10$		; non => 10$				; oui =>	DEC.L	A4		; A4 <-- ^dbut rglette	PUSH.L	A4	INC.L	A4		; A4 <-- ^paramtres "prev"	CALL	MAJREGLE	; met  jour les variables	POP.L	A4	CLR.W	D7		; D7 <-- rglette trouve	JUMP'	90$50$:	CALL	DEFREGLE	; met  jour les variables	LOAD.W	D7,#ERTNOT	; D7 <-- rglette pas trouve90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DEFREGLE >;=========/; Met  jour les variables en fonction de la rglette par dfaut.; in	A3.L	^variables pour la rglette; out	-; mod	D7.WDEFREGLE:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,A3	LOAD.W	D4,#LGREG-110$:	CLR.B	(A4+)		; met tout  zro	DECJ.W,NMO D4,10$;	CLR.W	(A3)+OREGRENF;	CLR.W	(A3)+OREGMGG	LOAD.B	(A3)+OREGITL,#ITL1;	CLR.B	(A3)+OREGCOUP;	CLR.B	(A3)+OREGLAB	TEST.B	(A6)+OFLAGS:#BEPRO ; dition de programmes ?	JUMP',BS 50$		; oui => 50$				; non =>	LOAD.B	(A3)+OREGJUST,#JUSTA	LOAD.W	D2,(A6)+OCX	MUL.WU	D2,#20	LOAD.W	(A3)+OREGTAB,D2	; met juste un tabulateur	LOAD.W	D4,(A6)+OLGP	; D4 <-- largeur de la page	SUB.W	D4,(A6)+OMGG	COMP.W	D4,(A6)+OMWDT	; trop large par rapport  l'cran ?	JUMP',LS 30$		; non => 30$	LOAD.W	D4,(A6)+OMWDT	; oui => met le maximum30$:	LOAD.W	(A3)+OREGMGD,D4	JUMP'	90$50$:				; dition de programmes =>	LOAD.B	(A3)+OREGJUST,#JUSTD	LOAD.L	A4,#(A3)+OREGTAB	CLR.W	D4	LOAD.W	D3,#MAXTAB	LOAD.W	D2,(A6)+OCX	MUL.WU	D2,#860$:	ADD.W	D4,D2	COMP.W	D4,(A6)+OMWDT	JUMP',HS 65$	LOAD.W	(A4+),D4	DEC.W	D3	JUMP,NE	60$65$:	LOAD.W	(A3)+OREGMGD,(A6)+OMWDT90$:	POPM.L	D2..D4,A3,A4	RET;---------\\; MAJREGLE >;=========/; Met  jour les variables en fonction d'une nouvelle rglette rencontre.; in	A3.L	^variables pour la rglette;	A4.L	^paramtres next/prev rglette rencontre; out	-; mod	D7.WMAJREGLE:	PUSHM.L	D0..D4,A3,A4	LOAD.B	(A3)+OREGJUST,(A4)+OREGJUST	LOAD.B	(A3)+OREGITL,(A4)+OREGITL	LOAD.B	(A3)+OREGCOUP,(A4)+OREGCOUP	LOAD.B	(A3)+OREGLAB,(A4)+OREGLAB	LOAD.L	A3,#(A3)+OREGTAB	LOAD.L	A4,#(A4)+OREGTAB	LOAD.W	D3,#MAXTAB+2+1-1 ; D3 <-- tabulateurs + marges + renforcement50$:	LOAD.B	D1,(A4+)	LOAD.B	D0,(A4+)	CALL	NUMBR	LOAD.W	(A3+),D4	DECJ.W,NMO D3,50$	POPM.L	D0..D4,A3,A4	RET;---------\\; UPDREGLE >;=========/; Met  jour une rglette en fonction de variables.; in	A3.L	^paramtres next/prev rglette  mettre  jour;	A4.L	^variables pour la rglette; out	-; mod	D7.WUPDREGLE:	PUSHM.L	D0..D4,A3,A4	LOAD.B	(A3)+OREGJUST,(A4)+OREGJUST	LOAD.B	(A3)+OREGITL,(A4)+OREGITL	LOAD.B	(A3)+OREGCOUP,(A4)+OREGCOUP	LOAD.B	(A3)+OREGLAB,(A4)+OREGLAB	LOAD.L	A3,#(A3)+OREGTAB	LOAD.L	A4,#(A4)+OREGTAB	LOAD.W	D3,#MAXTAB+2+1-1 ; D3 <-- tabulateurs + marges + renforcement50$:	LOAD.W	D4,(A4+)	CALL	NUMRB	LOAD.B	(A3+),D1	LOAD.B	(A3+),D0	DECJ.W,NMO D3,50$	POPM.L	D0..D4,A3,A4	RET;---------\\; COPREGLE >;=========/; Met  jour les variables en fonction d'une nouvelle rglette rencontre.; in	A3.L	^variables pour la rglette (destination);	A4.L	^variables pour la rglette (source); out	-; mod	D7.WCOPREGLE:	PUSHM.L	D3,A3,A4	LOAD.W	D3,#LGREG-110$:	LOAD.B	(A3+),(A4+)	; A3 <-- A4	DECJ.W,NMO D3,10$	POPM.L	D3,A3,A4	RET;---------\\; AFFREGLE >;=========/; Affiche une rglette entire.; in	A5.L	^description du buffer;	A4.L	^dans le buffer (ligne o est la rglette);	D3.W	position Y dbut rglette;	D4.W	hauteur de la rglette;	D5.W	hauteur en trop (contre en bas);	D6.W	hauteur en trop (contre en haut); out	A4.L	^dans le buffer (ligne suivante); mod	D7.W, A4.LAFFREGLE:	PUSHM.L	D2..D4,A3	LOAD.L	A3,A4	CALL	REGPARAM	; A4 <-- ^dbut rglette	JUMP,NE 80$	TEST.W	D4		; rglette invisible ?	JUMP,EQ	80$		; oui => 80$	OR.W	D5,D6		; place pour toute la hauteur ?	JUMP',EQ 08$		; oui => 08$	CALL	AFFVIDE		; non => efface bande horizontale	JUMP	80$08$:	COMP.W	(A5)+OMODIF,#MODALL	JUMP',NE 10$	CALL	AFFVIDE		; efface zone o ira la rglette10$:	COMP.L	A3,(A5)+OPDT	JUMP',EQ 15$	COMP.L	A3,(A5)+OPFT	JUMP',EQ 15$	COMP.L	A4,(A5)+OPFT	; curseur au dbut de la rglette ?	JUMP',NE 20$		; non => 20$15$:				; oui =>	PUSH.L	D4	LOAD.W	D4,(A6)+OCYR	SR.W	D4,#1	ADD.W	D4,D3	SWAP.W	D4	LOAD.W	D4,(A6)+OCX	LOAD.L	(A5)+OCURS,D4	; mm position du curseur	POP.L	D4	LOAD.L	(A5)+OPDL,A4	; mm ^dbut de la ligne	LOAD.W	(A5)+OPOSYL,D3	; mm position Y dbut ligne	LOAD.W	(A5)+OHTL,D4	; mm hauteur de la ligne	PUSHM.L	A3,A4	LOAD.L	A4,#(A5)+OVREG	LOAD.L	A3,#(A5)+OLREG	CALL	COPREGLE	; OLREG <-- OVREG	LOAD.L	A4,#(A5)+OVCOM	LOAD.L	A3,#(A5)+OLCOM	CALL	COPCOMMAND	; OLCOM <-- OVCOM	POPM.L	A3,A420$:	TEST.W	(A5)+OMODIF	; rglette dj dessine ?	JUMP',EQ 80$		; oui => 80$	SWAP.W	D4		; D4 <-- hauteur	LOAD.W	D4,(A6)+OXWDT	; D4 <-- largeur	LOAD.L	D2,#10000*64	DIV.WU	D2,(A6)+OMMX	AND.L	D2,#H'FFFF	DIV.WU	D2,(A6)+OFACX	; D2 <-- pas *64	CALL	JOLIREGLE	; affiche la rglette	CALL	JOLITREGLE	; affiche les tabulateurs et les marges80$:	CALL	SRCDOWN		; A4 <-- ^dbut ligne suivante	POPM.L	D2..D4,A3	RET;---------\\; REGPARAM >;=========/; Donne les paramtres d'une rglette.; in	A4.L	^ligne o est la rglette; out	A4.L	^commande rglette (DEBREG);	D7.W	erreur; mod	D7.W, A4.LREGPARAM:	PUSHM.L	D3,A310$:	CALL	TNVISU		; D3 <-- caractre suivant	JUMP',NE 90$	CALL	IFIEOL		; fin de ligne/rglette ?	JUMP,NE	10$		; non => 10$				; oui =>	CALL	PVISU		; A3 <-- recule dessus	LOAD.W	D7,#ERTNOT	COMP.B	D3,#REGLE	; rglette ?	JUMP',NE 90$		; non => 90$				; oui =>	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; JOLIREGLE >;==========/; Dessine une jolie rglette.; in	D2.W	pas (1..n) *64;	D3.W	position (y);	D4.L	dimensions (y;x);	A4.L	^dbut rglette dans le buffer; out	-; mod	D7.WJOLIREGLE:	PUSHM.L	D0..D5,A2	LOAD.W	D0,D2		; D0 <-- pas	LOAD.W	D1,D3		; D1 <-- position Y	INC.W	D3	SWAP.W	D3		; D3 <-- origine Y	LOAD.W	D3,#1		; D3 <-- origine X	SUB.W	D4,#3		; D4 <-- largeur X	SWAP.W	D4	SUB.W	D4,#3		; D4 <-- hauteur Y	SWAP.W	D4	LOAD.W	D2,#SETDOT	; D2 <-- mode	EX.L	D3,D4	CALL	DISRECT	EX.L	D3,D4	PUSH.L	D3	ADD.W	D3,(A6)+OCX	; D3 <-- dbut en X	SWAP.W	D3	ADD.W	D3,#GCICY+2	; D3 <-- dbut en Y	SWAP.W	D3	CALL	DISSETCURS	CALL	GCICONE		; utilise g.c. des icnes	LIB	?AFTIM	.B	AFTOUT	.B	ICOSPACE	.B	ICOBTAB		; bote tabulateur	.B	ICOBTABG	; bote tabulateur gauche	.B	ICOBTABC	; bote tabulateur centr	.B	ICOBTABN	; bote tabulateur numrique	.B	ICOBTABI	; bote indentateur	.B	ICOSPACE	.B	ICOSPACE	.B	ICOSPACE	.B	ICOSPACE	.B	ICOJUSTA	; align	.B	ICOSPACE	.B	ICOJUSTD	; drapeau  droite	.B	ICOSPACE	.B	ICOJUSTG	; drapeau  gauche	.B	ICOSPACE	.B	ICOJUSTC	; centr	.B	ICOSPACE	.B	ICOCOUP		; coupe	.B	ICOSPACE	.B	ICOSPACE	.B	ICOSPACE	.B	ICOSPACE	.B	ICOSPACE	.B	ICOSPACE	.B	ICOITL1		; interligne 1	.B	ICOSPACE	.B	ICOITL12	; interligne 1/2	.B	ICOSPACE	.B	ICOITL2		; interligne 2	.B	ICOSPACE	.B	AFNORM	.B	0	.EVEN	LOAD.B	D3,(A4)+1+LGREG+OREGLAB	ADD.B	D3,#ICOLABEL	LIB	?AFCAR		; affiche le label;;?	COMP.B	D3,#ICOLABEL;;?	JUMP',EQ 20$;;?	LOAD.W	D3,D1		; D3 <-- position Y;;?	LOAD.W	D2,#9;;?	CALL	IIJREGLE	; inverse la label A..J;;?20$:	LOAD.W	D3,D1		; D3 <-- position Y	CLR.W	D2	LOAD.B	D2,(A4)+1+LGREG+OREGJUST	CALL	IIJREGLE	; inverse l'icne de justification choisie	LOAD.B	D2,(A4)+1+LGREG+OREGITL	CALL	IIIREGLE	; inverse l'icne d'interligne choisie	TEST.B	(A4)+1+LGREG+OREGCOUP	JUMP',F 25$	LOAD.W	D2,#4	CALL	IIJREGLE	; allume l'icne des ciseaux25$:	POP.L	D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,#10		; D4 <-- hauteur pour l'chelle	ADD.W	D3,#32-1	NEG.W	D4	SWAP.W	D4	SWAP.W	D3	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.L	A2,(A2)+ODFPGC	; A2 <-- ^gencar	LOAD.L	A2,#(A2)+OGCWID	; A2 <-- ^table des largeurs	LOAD.W	D3,(A6)+OCX	SL.W	D3,#6		; D3 <-- OCX*64	LOAD.W	D1,D4		; D1 <-- position X maximale	SL.W	D1,#6	CLR.W	D4		; D4 <-- dX	CLR.L	D5	LOAD.W	D5,(A6)+OSCROLH+OSCPOSV	ADD.W	D5,(A6)+OMGG	SL.L	D5,#6	DIV.WU	D5,D0	AND.L	D5,#H'FFFF	; D5 <-- rang premire barette	LOAD.W	D2,#INVDOT	; D2 <-- mode30$:	PUSHM.L	D3..D5	SR.W	D3,#6		; D3 <-- origine X /64	SWAP.W	D4	DIV.WU	D5,#10		; D5 <-- rang/10	SWAP.W	D5		; D5 <-- reste de la division	TEST.W	D5	JUMP',EQ 40$	ASR.W	D4,#1		; D4 <-- 1/2 de la hauteur	COMP.W	D5,#5	JUMP',EQ 40$	LOAD.W	D4,#1		; D4 <-- juste un point40$:	SWAP.W	D4	EX.L	D3,D4	CALL	DISLINE		; dessine une barette	POPM.L	D3..D5	PUSHM.L	D1..D5	SR.W	D3,#6		; D3 <-- origine X /64	DIV.WU	D5,#10*5	SWAP.W	D5	TEST.W	D5		; est-ce une dizaine ?	JUMP',NE 70$		; non => 70$	SWAP.W	D5	MUL.WU	D5,#5	DIV.WU	D5,#10	CLR.W	D1	LOAD.B	D1,(A2)+ICONUM	; D1 <-- largeur du chiffre zro	SUB.W	D3,D1	DEC.W	D3	ADD.W	D3,(A6)+OC1X	TEST.W	D5	JUMP',EQ 50$	COMP.W	D5,#10		; y a-t-il des centaines ?	JUMP',LO 45$		; non => 45$	PUSH.L	D3	SUB.W	D3,D1	CALL	DISSETCURS	; positionne pour les centaines	CLR.L	D3	LOAD.W	D3,D5	DIV.WU	D3,#10	ADD.B	D3,#ICONUM	CALL	DISDAFCAR	; affiche les centaines	SWAP.W	D3	LOAD.W	D5,D3	POP.L	D345$:	CALL	DISSETCURS	; positionne pour les dizaines	EX.L	D3,D5	ADD.B	D3,#ICONUM	CALL	DISDAFCAR	; affiche les dizaines	EX.L	D5,D350$:	ADD.W	D3,D1	ADD.W	D3,#2+2	CALL	DISSETCURS	; positionne pour les units	SWAP.W	D5	LOAD.B	D3,D5	ADD.B	D3,#ICONUM	CALL	DISDAFCAR	; affiche les units70$:	POPM.L	D1..D5	INC.W	D5		; D5 <-- rang suivant	ADD.W	D3,D0		; D3 <-- barette suivante	COMP.W	D3,D1		; fin de la rglette ?	JUMP,LO	30$		; non => 30$	CALL	GCDEF		; utilise g.c. par dfaut	POPM.L	D0..D5,A2	RET;-----------\\; JOLITREGLE >;===========/; Dessine les tabulateurs et les marges dans une rglette.; in	D2.W	pas (1..n);	D3.W	position (y);	D4.L	dimensions (y;x);	A3.L	^dans buffer;	A4.L	^dbut rglette dans le buffer; out	A3.L	^dans buffer; mod	D7.W, A3.LJOLITREGLE:	PUSHM.L	D0..D5,A3,A4	CALL	GCICONE		; utilise g.c. des icnes	LOAD.L	A3,#(A4)+1+LGREG+OREGTAB	LOAD.W	D5,#MAXTAB50$:	LOAD.B	D1,(A3+)	LOAD.B	D0,(A3+)	CALL	NUMBR	LOAD.W	D2,D4	JUMP',EQ 60$	CALL	IITREGLE	; met un tabulateur	DEC.W	D5	JUMP,NE	50$60$:	LOAD.L	A3,#(A4)+1+LGREG+OREGMGG	LOAD.B	D1,(A3+)	LOAD.B	D0,(A3+)	CALL	NUMBR	LOAD.W	D2,D4	TSET.L	D2:#BTABMGG	CALL	IITREGLE	; met la marge gauche	LOAD.B	D1,(A3+)	LOAD.B	D0,(A3+)	CALL	NUMBR	LOAD.W	D2,D4	TSET.L	D2:#BTABMGD	CALL	IITREGLE	; met la marge droite	LOAD.B	D1,(A3+)	LOAD.B	D0,(A3+)	CALL	NUMBR	LOAD.W	D2,D4	TSET.L	D2:#BTABMGG	TSET.L	D2:#BTABMGD	CALL	IITREGLE	; met le renfoncement	CALL	GCDEF		; utilise g.c. par dfaut	POPM.L	D0..D5,A3,A4	RET;---------\\; DETREGLE >;=========/; Dtecte et excute une action dans une rglette avec la souris.; in	D4.L	position de la souris (y;x);	D3.W	position Y dbut rglette;	A4.L	^dbut rglette dans buffer; out	D7.W	erreur (pas dans un objet connu de la rgle); mod	D7.WDETREGLE:	PUSHM.L	D1..D4,A2..A4	LOAD.L	A2,A4		; A2 <-- ^dbut rgle	LOAD.L	A4,#(A4)+1+LGREG; A4 <-- ^paramtres "next"	LOAD.L	A3,#(A6)+OSREG	CALL	MAJREGLE	; OSREG <-- rglette	EX.L	A4,A3		; A4 <-- ^variables rglette	CALL	DISCCMO		; enlve la flche de la souris	CALL	GCICONE		; utilise g.c. des icnes	CALL	DIJREGLE	; D2 <-- rang icne	JUMP,NE 50$		; ailleur dans rglette => 50$	LOAD.W	D7,#ERTNOT	; D7 <-- pas trouv	COMP.W	D2,#5	JUMP',HS 30$				; bote de tabulation =>	LOAD.W	D1,D2	JUMP',EQ 10$	LOAD.W	D2,#2^BTABGAU	DEC.W	D1	JUMP',EQ 10$	LOAD.W	D2,#2^BTABCEN	DEC.W	D1	JUMP',EQ 10$	LOAD.W	D2,#2^BTABNUM	DEC.W	D1	JUMP',EQ 10$	LOAD.W	D2,#2^BTABIND1!2^BTABIND210$:	CALL	MOVTAB		; sort un tabulateur d'une bote ...	JUMP,NE 90$		; si pas pos correctement => 90$	CALL	ADDTAB		; ajoute nouveau tabulateur dans la liste	JUMP',NE 15$	CALL	IITREGLE	; et dessine-le	JUMP	85$15$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	90$30$:				; justification =>	SUB.W	D2,#5	COMP.W	D2,#5	JUMP',HS 40$	COMP.W	D2,#4		; dans les ciseaux ?	JUMP',EQ 35$		; oui => 35$	COMP.B	D2,(A4)+OREGJUST ; mme icne dj slectionne ?	JUMP,EQ 90$		; oui => 90$	LOAD.W	D1,D2	LOAD.B	D2,(A4)+OREGJUST	CALL	IIJREGLE	; efface l'ancien	LOAD.W	D2,D1	CALL	IIJREGLE	; puis montre le nouveau	LOAD.B	(A4)+OREGJUST,D2	JUMP	85$35$:				; ciseaux =>	NOT.B	(A4)+OREGCOUP	; inverse dans la rgle	CALL	IIJREGLE	; inverse sur l'cran	JUMP	85$40$:				; interligne =>	SUB.W	D2,#5+1	JUMP,LO 95$	COMP.W	D2,#4	JUMP,HS 95$	COMP.W	D2,#3	JUMP,EQ 45$	COMP.B	D2,(A4)+OREGITL	; mme icne dj slectionne ?	JUMP,EQ 90$		; oui => 90$	LOAD.W	D1,D2	LOAD.B	D2,(A4)+OREGITL	CALL	IIIREGLE	; efface l'ancien	LOAD.W	D2,D1	CALL	IIIREGLE	; puis montre le nouveau	LOAD.B	(A4)+OREGITL,D2	JUMP	85$45$:				; label =>	CALL	DISSCMO		; remet la flche de la souris	LIB	?GETCAR		; attend le bouton relch !	PUSHM.L	A3,A4	LOAD.L	A3,#R16"TMLABEL	LOAD.L	A4,#(A6)+OCASLAB ; A4 <-- ^variable pour la case	CALL	MMENU		; attend choix selon menu ...	POPM.L	A3,A4	JUMP,NE 95$	TEST.W	D3	JUMP,EQ 90$	DEC.W	D3		; D3 <-- 0,1..10	LOAD.B	(A4)+OREGLAB,D3	CALL	UPDREGLE	; mj rglette dans le buffer	TEST.B	D3		; rgle isole ?	JUMP,EQ 86$		; oui => 86$	CALL	SLAREGLE	; A4 <-- cherche rgle avec ce label ?	JUMP,NE 86$	CALL	COPREGLE	; mj rglette comme les autres	JUMP	86$50$:	CALL	DITREGLE	; D2 <-- rang tabulateur	JUMP,NE 95$		; ailleur dans rglette => 95$	CALL	SRCTAB		; cherche si tabulateur existe	JUMP,NE 90$		; non => 90$				; oui =>	TEST.L	D2:#BTABMGG	; marge gauche ?	JUMP',BS 60$		; oui => 60$	TEST.L	D2:#BTABMGD	; marge droite ?	JUMP,BS 70$		; oui => 70$	CALL	SUBTAB		; enlve-le dans la liste	CALL	IITREGLE	; efface-le dans la fentre	CALL	MOVTAB		; puis dplace-le ...	JUMP,NE 85$		; si supprim => 85$	CALL	ADDTAB		; ajoute nouveau tabulateur dans la liste	JUMP',NE 55$	CALL	IITREGLE	; et dessine-le	JUMP	85$55$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	85$60$:				; marge gauche =>	TEST.L	D2:#BTABMGD	; renfoncement ?	JUMP,BS 80$		; oui => 80$	CALL	IITREGLE	; efface-le dans la fentre	CALL	MOVTAB		; puis dplace-le ...	ADD.W	D2,#8+8	CALL	GMNTAB		; D1 <-- tabulateur le plus  gauche	JUMP',NE 62$	COMP.W	D2,D1	JUMP',LS 62$	LOAD.W	D2,D162$:	COMP.W	D2,(A4)+OREGMGD	JUMP',LS 64$	LOAD.W	D2,(A4)+OREGMGD64$:	SUB.W	D2,#8+8	LOAD.W	(A4)+OREGMGG,D2	TSET.L	D2:#BTABMGG	CALL	IITREGLE	; et dessine-le	JUMP	85$70$:				; marge droite =>	CALL	IITREGLE	; efface-le dans la fentre	CALL	MOVTAB		; puis dplace-le ...	SUB.W	D2,#8+8	CALL	GMXTAB		; D1 <-- tabulateur le plus  droite	JUMP',NE 72$	COMP.W	D2,D1	JUMP',HS 72$	LOAD.W	D2,D172$:	COMP.W	D2,(A4)+OREGMGG	JUMP',HS 73$	LOAD.W	D2,(A4)+OREGMGG73$:	COMP.W	D2,(A4)+OREGRENF	JUMP',HS 74$	LOAD.W	D2,(A4)+OREGRENF74$:	ADD.W	D2,#8+8	LOAD.W	(A4)+OREGMGD,D2	TSET.L	D2:#BTABMGD	CALL	IITREGLE	; et dessine-le	JUMP'	85$80$:				; renfoncement =>	CALL	IITREGLE	; efface-le dans la fentre	CALL	MOVTAB		; puis dplace-le ...	ADD.W	D2,#8+8	COMP.W	D2,(A4)+OREGMGD	JUMP',LS 82$	LOAD.W	D2,(A4)+OREGMGD82$:	SUB.W	D2,#8+8	LOAD.W	(A4)+OREGRENF,D2	TSET.L	D2:#BTABMGG	TSET.L	D2:#BTABMGD	CALL	IITREGLE	; et dessine-le;	JUMP'	85$85$:	CALL	DISSCMO		; remet la flche de la souris	CALL	UPDREGLE	; mj rglette dans le buffer	TEST.B	(A4)+OREGLAB	; rgle isole ?	JUMP',NE 88$		; non => 88$86$:				; oui =>	CALL	AVANCE		; la rgle modifie doit tre avant le trou	LOAD.W	D4,D7		; D4 <-- avance ok ou pas	CALL	DELREGLE	; mj rglette suivante	TEST.W	D4		; avance ok ?	JUMP',NE 87$		; non => 87$	CALL	RECULE		; oui => recule pour annuler l'effet87$:	LOAD.L	A4,A2		; A4 <-- ^dbut rgle	CALL	_RJUSTIF	; justifie un p'tit peu	JUMP'	90$88$:	CALL	LABREGLE	; mj rglettes soeurs (mme label)90$:	CLR.W	D7		; D7 <-- ok95$:	PUSH.W	D7	CALL	GCDEF		; utilise g.c. par dfaut	CALL	DISSCMO		; remet la flche de la souris	POP.W	D7	POPM.L	D1..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; MOVTAB  >;--------/; Dplace un tabulateur ou une marge dans une rglette.; in	D2.W	type de tabulateur (BTABNUM,MGG,MGD);	D3.W	position Y dbut rglette; out	D2.W	position d'arrive (x);	D7.W	erreur (tabulateur  supprimer); mod	D4.L, D7.WMOVTAB:	PUSHM.L	D0,D1,D3..D5	LOAD.W	D0,D3		; D0 <-- minimum Y	ADD.W	D0,(A6)+OCYR	ADD.W	D0,(A6)+OCYR	LOAD.W	D1,D0	ADD.W	D1,(A6)+OCYR	; D1 <-- maximum Y	LIB	?IFMOUSE	; D4 <-- position de la souris	CALL	MOWTAB		; D4 <-- position dans sous-fentre	CALL	IPTREGLE	; dessine le premier tabulateur	LOAD.L	D5,D420$:	LIB	?GETKEY		; attend souris/clavier ...	TEST.L	D3:#BKPSEUDO	; touche relache ?	JUMP,BS	20$		; oui => 20$	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE 50$		; non => 50$				; oui =>	LIB	?IFMOUSE	; D4 <-- position de la souris	CALL	MOWTAB		; D4 <-- position dans sous-fentre	JUMP',EQ 30$	COMP.W	D7,#1	JUMP,NE 20$30$:	COMP.L	D4,D5		; identique  la dernire position ?	JUMP,EQ	20$		; oui => 20$	EX.L	D4,D5	CALL	IPTREGLE	; efface l'ancien tabulateur	LOAD.L	D4,D5	CALL	IPTREGLE	; dessine le nouveau tabulateur	JUMP	20$50$:	LOAD.L	D4,D5	CALL	IPTREGLE	; efface le dernier tabulateur	SUB.W	D4,(A6)+OCX	JUMP',HS 60$	CLR.W	D460$:	ADD.W	D4,(A6)+OSCROLH+OSCPOSV ; tient compte de l'ascenseur horizontal	AND.W	D2,#2^BTABNUM!2^BTABGAU!2^BTABCEN	OR.W	D2,D4		; D2 <-- position d'arrive; Vrifie si la souris est bien dans le quart infrieur de la rglette.	LOAD.W	D7,#ERTNOT	; D7 <--  ignorer	SWAP.W	D4	COMP.W	D4,D0		; souris trop haute ?	JUMP',LO 90$		; oui => 90$	COMP.W	D4,D1		; souris trop basse ?	JUMP',HS 90$		; oui => 90$				; non =>	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1,D3..D5	RET;--------\\; MOWTAB  >;--------/; Donne la position relle d'un tabulateur, d'une marge ou d'un; renfoncement. Ces deux derniers ont toujours la mme position; horizontale (en Y).; in	D4.L	coordonne de la souris;	D2.W	type du tabulateur;	D0.W	minimum Y; out	D4.L	coordonne de la souris;	D7.W	erreur (ERNOT/1); mod	D4.L, D7.WMOWTAB:	PUSH.L	D3	CALL	WDOMOUSE	; D4 <-- position dans sous-fentre	JUMP',NE 90$	LOAD.W	D7,#1	SUB.W	D4,(A6)+OCX	; dpasse  gauche de la rgle ?	JUMP',HS 10$		; non => 10$	CLR.W	D4		; oui => colle  gauche	JUMP'	30$10$:	LOAD.W	D3,(A6)+OLGP	SUB.W	D3,(A6)+OMGG	SUB.W	D3,(A6)+OSCROLH+OSCPOSV ; tient compte de l'ascenseur horizontal	COMP.W	D4,D3		; dpasse  droite de la rgle ?	JUMP',LS 20$		; non => 20$	LOAD.W	D4,D3		; oui => colle  droite	JUMP'	30$20$:	CLR.W	D7		; D7 <-- ok30$:	ADD.W	D4,(A6)+OCX	TEST.L	D2:#BTABMGG	JUMP',BS 50$	TEST.L	D2:#BTABMGD	JUMP',BC 90$50$:				; si marges ou renfoncement =>	SWAP.W	D4	LOAD.W	D4,(A6)+OCYR	SR.W	D4,#1	ADD.W	D4,D0	DEC.W	D4		; D4 <-- position Y standard	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DIJREGLE >;=========/; Dtecte dans quelle icne de bote de tabulation, de justification; ou d'interligne est la souris.; in	D3.W	position Y dbut rglette;	D4.L	position de la souris (y;x); out	D2.W	icne (0..4=bote, 5..9=just, 11..13=itl, 14=label);	D7.W	erreur; mod	D2.W, D7.WDIJREGLE:	PUSHM.L	D3,D4	LOAD.W	D7,#ERTNOT	; D7 <-- pas trouv	SWAP.W	D4		; D4 <-- position Y de la souris	ADD.W	D3,#1+2	COMP.W	D4,D3		; souris trop haute ?	JUMP',LO 90$		; oui => 90$	ADD.W	D3,#GCICY	COMP.W	D4,D3		; souris trop basse ?	JUMP',HS 90$		; oui => 90$	CLR.W	D4	SWAP.W	D4		; D4 <-- position X de la souris	SUB.W	D4,(A6)+OCX	; souris trop  gauche ?	JUMP',LO 90$		; oui => 90$	COMP.W	D4,#(GCICX/4)*25	JUMP',HS 50$				; dans bote de tabulation =>	SUB.W	D4,#GCICX/4	JUMP',LO 90$	DIV.WU	D4,#GCICX	COMP.W	D4,#5	JUMP',HS 90$	LOAD.W	D2,D4		; D2 <-- rang (0..4)	JUMP'	80$50$:				; dans justification/interligne =>	SUB.W	D4,#(GCICX/4)*25	DIV.WU	D4,#GCICX+(GCICX/4)	LOAD.W	D2,D4		; D2 <-- rang (0..n)	ADD.W	D2,#5		; D2 <-- rang (5..n)	SWAP.W	D4		; D4 <-- reste de la division	COMP.W	D4,#GCICX	JUMP',HS 90$80$:	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DITREGLE >;=========/; Dtecte dans quel tabulateur ou marge est la souris.; in	D3.W	position Y dbut rglette;	D4.L	position de la souris (y;x); out	D2.W	tabulateur (0..n);	D7.W	erreur; mod	D2.W, D7.WDITREGLE:	PUSHM.L	D3,D4	LOAD.W	D7,#ERTNOT	; D7 <-- pas trouv	SWAP.W	D4		; D4 <-- position Y de la souris	ADD.W	D3,(A6)+OCYR	ADD.W	D3,(A6)+OCYR	COMP.W	D4,D3		; souris trop haute ?	JUMP',LO 90$		; oui => 90$	ADD.W	D3,(A6)+OCYR	COMP.W	D4,D3		; souris trop basse ?	JUMP',HS 90$		; oui => 90$	CLR.W	D4	SWAP.W	D4		; D4 <-- position X de la souris	SUB.W	D4,(A6)+OCX	; souris trop  gauche ?	JUMP',HS 50$		; non => 50$	CLR.W	D4		; oui => cale  gauche50$:	LOAD.W	D2,D4		; D2 <-- rang (0..n)	ADD.W	D2,(A6)+OSCROLH+OSCPOSV ; tient compte ascenseur horizontal	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IIIREGLE  >;==========/; Inverse une icne d'interligne dans une rglette.; in	D2.W	numro de l'icne  inverser (0..n);	D3.W	position Y dbut rglette; out	-; mod	D7.WIIIREGLE:	PUSH.W	D2	ADD.W	D2,#5+1	CALL	IIJREGLE	; inverse l'icne	POP.W	D2	RET;----------\\; IIJREGLE  >;==========/; Inverse une icne de justification dans une rglette.; in	D2.W	numro de l'icne  inverser (0..4=just, 6..8=itl, 9=label);	D3.W	position Y dbut rglette; out	-; mod	D7.WIIJREGLE:	PUSHM.L	D0..D4	ADD.W	D3,#1+2+1	LOAD.W	D4,D3		; D4 <-- yy	SWAP.W	D4	LOAD.W	D1,D2	MUL.WU	D2,#GCICX+(GCICX/4)	ADD.W	D2,#(GCICX/4)*25	ADD.W	D2,(A6)+OCX	ADD.W	D2,#1+1	LOAD.W	D4,D2		; D4 <-- xx	LOAD.L	D3,#H'10000*(GCICY-3)+(GCICX-3)	COMP.W	D1,#9	JUMP',NE 20$	ADD.W	D4,#12	SUB.W	D3,#1220$:	LOAD.W	D2,#INVDOT	; D2 <-- mode	LOAD.L	D0,#-1		; D0 <-- trame	LOAD.L	D1,D0		; D1 <-- trame	CALL	DISTRAME	POPM.L	D0..D4	RET;----------\\; IITREGLE  >;==========/; Inverse un tabulateur dans une rglette.; in	D2.W	tabulateur  inverser (0..n);	D3.W	position Y dbut rglette; out	-; mod	D7.WIITREGLE:	PUSHM.L	D3,D4	LOAD.W	D4,D3	LOAD.W	D3,(A6)+OCYR	ADD.W	D4,D3	ADD.W	D4,D3	SR.W	D3,#1	ADD.W	D4,D3	DEC.W	D4		; D4 <-- position Y	SWAP.W	D4	LOAD.W	D4,D2	AND.W	D4,#MASKTAB	SUB.W	D4,(A6)+OSCROLH+OSCPOSV ; tient compte ascenseur horizontal	JUMP',LO 90$	ADD.W	D4,(A6)+OCX	CALL	IPTREGLE	; inverse le tabulateur90$:	POPM.L	D3,D4	RET;----------\\; IPTREGLE  >;==========/; Inverse un tabulateur ou une marge dans une rglette;  une position quelconque.; in	D2.W	type de tabulateur (BTABNUM,MGG,MGD);	D4.L	position (y;x); out	-; mod	D7.WIPTREGLE:	PUSHM.L	D2..D4	LOAD.B	D3,#ICORENF	TEST.L	D2:#BTABMGG	JUMP',BC 10$	TEST.L	D2:#BTABMGD	JUMP',BS 20$10$:	LOAD.B	D3,#ICOTABI	TEST.L	D2:#BTABIND1	JUMP',BC 12$	TEST.L	D2:#BTABIND2	JUMP',BS 20$12$:	LOAD.B	D3,#ICOMGG	TEST.L	D2:#BTABMGG	JUMP',BS 20$	LOAD.B	D3,#ICOMGD	TEST.L	D2:#BTABMGD	JUMP',BS 20$	LOAD.B	D3,#ICOTABN	TEST.L	D2:#BTABNUM	JUMP',BS 20$	LOAD.B	D3,#ICOTABC	TEST.L	D2:#BTABCEN	JUMP',BS 20$	LOAD.B	D3,#ICOTABG	TEST.L	D2:#BTABGAU	JUMP',BS 20$	LOAD.B	D3,#ICOTAB20$:	SUB.W	D4,#8		; D4 <--  gauche	JUMP',HS 40$	CLR.W	D440$:	CALL	DISTYPOAX	SWAP.W	D4	ADD.W	D4,#8		; D4 <-- en bas	CALL	DISTYPOAY	LOAD.W	D2,#INVDOT	CALL	DISDAFCAR	; affiche l'icne	POPM.L	D2..D4	RET;--------\\; NEXTTAB >;========/; Cherche le tabulateur suivant.; in	A3.L	^variables rglette;	D2.W	position; out	D2.W	position du tabulateur suivant;	D7.W	erreur; mod	D2.W, D7.WNEXTTAB:	PUSHM.L	D3,D4,A3	LOAD.W	D7,#ERTNOT	LOAD.L	A3,#(A3)+OREGTAB	LOAD.W	D3,#MAXTAB20$:	LOAD.W	D4,(A3)		; place libre ?	JUMP',EQ 90$		; oui => 90$	AND.W	D4,#MASKTAB	COMP.W	D2,D4	JUMP',LO 50$	ADD.L	A3,#2		; A3 <-- ^tabulateur suivant	DEC.W	D3		; encore un ?	JUMP,NE	20$		; oui => 20$	JUMP'	90$		; non => 90$50$:	LOAD.W	D2,(A3)		; D2 <-- position exacte	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFTABI  >;========/; Cherche le tabulateur suivant.; in	A3.L	^variables rglette; out	D7.W	erreur si pas d'indentateur(s); mod	D7.WIFTABI:	PUSHM.L	D3,D4,A3	LOAD.W	D7,#ERTNOT	LOAD.L	A3,#(A3)+OREGTAB	LOAD.W	D3,#MAXTAB20$:	LOAD.W	D4,(A3)		; place libre ?	JUMP',EQ 90$		; oui => 90$	TEST.L	D4:#BTABIND1	JUMP',BC 30$	TEST.L	D4:#BTABIND2	; indentateur ?	JUMP',BS 50$		; oui => 50$30$:	ADD.L	A3,#2		; A3 <-- ^tabulateur suivant	DEC.W	D3		; encore un ?	JUMP,NE	20$		; oui => 20$	JUMP'	90$		; non => 90$50$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; SRCTAB  >;========/; Cherche un tabulateur ou une marge existant.; in	D2.W	tabulateur prsum;	A4.L	^variables rglette; out	D2.W	tabulateur ou marge;	D7.W	erreur; mod	D2.W, D7.WSRCTAB:	PUSHM.L	D0,D1,D3,D4,A3,A4	LOAD.W	D7,#ERTNOT	AND.W	D2,#MASKTAB	LOAD.W	D0,D2	SUB.W	D0,#8		; D0 <-- minumum	JUMP',HS 10$	CLR.W	D010$:	LOAD.W	D1,D2	ADD.W	D1,#8		; D1 <-- maximum; Cherche si la souris est dans un tabulateur.	LOAD.L	A3,#(A4)+OREGTAB	LOAD.W	D3,#MAXTAB	; D3 <-- tabulateurs20$:	TEST.W	(A3)		; place libre ?	JUMP',EQ 25$		; oui => 25$	LOAD.W	D4,(A3)		; D4 <-- position	AND.W	D4,#MASKTAB	COMP.W	D0,D4	JUMP',HI 25$	COMP.W	D1,D4	JUMP',LS 25$	LOAD.W	D2,(A3)		; D2 <-- position exacte	JUMP	80$25$:	ADD.L	A3,#2		; A3 <-- ^tabulateur suivant	DEC.W	D3		; encore un ?	JUMP,NE	20$		; oui => 20$; Cherche si la souris est dans la marge gauche.	LOAD.W	D4,(A4)+OREGMGG	; D4 <-- position	COMP.W	D2,D4	JUMP',HI 30$	COMP.W	D1,D4	JUMP',LS 30$	LOAD.W	D2,(A4)+OREGMGG	; D2 <-- position exacte	TSET.L	D2:#BTABMGG	; D2 <-- marge gauche	JUMP'	80$; Cherche si la souris est dans la marge droite.30$:	LOAD.W	D4,(A4)+OREGMGD	; D4 <-- position	COMP.W	D0,D4	JUMP',HI 40$	COMP.W	D1,D4	JUMP',LS 40$	LOAD.W	D2,(A4)+OREGMGD	; D2 <-- position exacte	TSET.L	D2:#BTABMGD	; D2 <-- marge droite	JUMP'	80$; Cherche si la souris est dans le renfoncement.40$:	LOAD.W	D4,(A4)+OREGRENF; D4 <-- position	COMP.W	D0,D4	JUMP',HI 90$	COMP.W	D2,D4	JUMP',LS 90$	LOAD.W	D2,(A4)+OREGRENF; D2 <-- position exacte	TSET.L	D2:#BTABMGG	TSET.L	D2:#BTABMGD	; D2 <-- renfoncement;	JUMP'	80$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1,D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GMNTAB  >;========/; Cherche le tabulateur le plus  gauche.; in	A4.L	^variables rglette; out	D1.W	tabulateur minimal;	D7.W	erreur; mod	D1.W, D7.WGMNTAB:	LOAD.W	D7,#ERTNOT	LOAD.W	D1,(A4)+OREGTAB	; D1 <-- tabulateur minimal	JUMP',EQ 90$	AND.W	D1,#MASKTAB	CLR.W	D7		; D7 <-- ok90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; GMXTAB  >;========/; Cherche le tabulateur le plus  droite.; in	A4.L	^variables rglette; out	D1.W	tabulateur maximal;	D7.W	erreur; mod	D1.W, D7.WGMXTAB:	PUSHM.L	D3,A4	LOAD.W	D7,#ERTNOT	LOAD.L	A4,#(A4)+OREGTAB	TEST.W	(A4)		; au moins un tabulateur ?	JUMP',EQ 90$		; non => 90$	LOAD.W	D3,#MAXTAB	; D3 <-- tabulateurs20$:	TEST.W	(A4+)		; tabulateur existe ?	JUMP',EQ 50$		; non => 50$	DEC.W	D3		; encore un ?	JUMP,NE	20$		; oui => 20$50$:	LOAD.W	D1,(A4)-4	; D1 <-- tabulateur maximal	AND.W	D1,#MASKTAB	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ADDTAB  >;========/; Ajoute un nouveau tabulateur.; in	D2.W	tabulateur;	A4.L	^variables rglette; out	D2.W	tabulateur rel;	D7.W	erreur; mod	D2.W, D7.WADDTAB:	PUSHM.L	D1,D3,D4,A3,A4	LOAD.W	D7,#ERTNOT	; D7 <-- pas possible	LOAD.W	D1,D2	AND.W	D2,#MASKTAB	SUB.W	D2,#8+8	COMP.W	D2,(A4)+OREGMGG	; avant la marge gauche ?	JUMP,LT	90$		; oui => 90$	ADD.W	D2,#(8+8)*2	COMP.W	D2,(A4)+OREGMGD	; aprs la marge droite ?	JUMP,GE	90$		; oui => 90$	SUB.W	D2,#8+8	LOAD.L	A4,#(A4)+OREGTAB	LOAD.W	D3,#MAXTAB20$:	LOAD.W	D4,(A4)		; place libre ?	JUMP',EQ 40$		; oui => 40$	AND.W	D4,#MASKTAB	COMP.W	D2,D4	JUMP',EQ 82$		; si existe dj => modifie	JUMP',LO 40$	ADD.L	A4,#2		; A4 <-- ^tabulateur suivant	DEC.W	D3		; encore un ?	JUMP,NE	20$		; oui => 20$	JUMP'	90$		; non => 90$40$:	LOAD.W	D4,(A4)		; tabulateur suivant existe ?	JUMP',EQ 50$		; non => 50$	AND.W	D4,#MASKTAB	SUB.W	D4,#8+8	COMP.W	D2,D4		; est-on trop prs du suivant ?	JUMP',HI 82$		; oui => modifie le suivant50$:	COMP.W	D3,#MAXTAB	; tabulateur prcdent existe ?	JUMP',EQ 52$		; non => 52$	LOAD.W	D4,(A4)-2	; D4 <-- tabulateur prcdent	AND.W	D4,#MASKTAB	ADD.W	D4,#8+8	COMP.W	D2,D4		; est-on trop prs du prcdent ?	JUMP',LO 80$		; oui => modifie le prcdent52$:	ADD.W	A4,D3	ADD.W	A4,D3		; A4 <-- ^fin liste des tabulateurs	LOAD.L	A3,#(A4)-2	DEC.W	D3	JUMP',EQ 70$60$:	LOAD.W	(-A4),(-A3)	DEC.W	D3	JUMP,NE	60$70$:	AND.W	D1,#2^BTABNUM!2^BTABCEN!2^BTABGAU	OR.W	D2,D1	LOAD.W	(-A4),D2	; met le nouveau	JUMP'	85$80$:				; modifie un tabulateur	SUB.L	A4,#282$:	AND.W	D1,#2^BTABNUM!2^BTABCEN!2^BTABGAU	LOAD.W	D2,(A4)	AND.W	D2,#MASKTAB	OR.W	D2,D1	LOAD.W	(A4),D285$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SUBTAB  >;========/; Supprime un tabulateur existant.; in	D2.W	tabulateur;	A4.L	^variables rglette; out	D7.W	erreur; mod	D7.WSUBTAB:	PUSHM.L	D2..D4,A3,A4	LOAD.W	D7,#ERTNOT	AND.W	D2,#MASKTAB	LOAD.L	A4,#(A4)+OREGTAB	LOAD.W	D3,#MAXTAB20$:	LOAD.W	D4,(A4)	AND.W	D4,#MASKTAB	COMP.W	D2,D4	JUMP',EQ 50$		; trouv => 50$	ADD.L	A4,#2		; A4 <-- ^tabulateur suivant	DEC.W	D3		; encore un ?	JUMP,NE	20$		; oui => 20$	JUMP'	90$		; non => 90$50$:	LOAD.L	A3,#(A4)+2	DEC.W	D3	JUMP',EQ 70$60$:	LOAD.W	(A4+),(A3+)	DEC.W	D3	JUMP,NE	60$70$:	CLR.W	(A4)	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET	.END