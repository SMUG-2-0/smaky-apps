	.SBTTL	TEXTCOMM;--------\\; GINSERT >;========/; Insert un caractre ayant un gencar et un mode bien prcis.; in	D3.L	caractre (gencar/mode/n/code); out	D7.W	erreur; mod	D7.WGINSERT:	PUSHM.L	D1,D2	CALL	INSERT		; insert normalement	JUMP',NE 90$	CALL	RECULE		; recule avant le caractre insr	LOAD.L	D2,D3	SWAP.W	D2		; D2 <-- gencar/mode	LOAD.W	D1,#1		; D1 <-- un seul caractre	CALL	AZGMCOMMAND	; utilise le bon gencar/mode90$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;------------\\; AZGMCOMMAND >;============/; Utilise un gencar et un mode dans une nouvelle zone.; On est au dbut de la zone, et on connat sa longueur.; in	D2.W	gencar/mode (15.gencar.8/7.mode.0);	D1.W	nb de caractres; out	D7.W	erreur; mod	D7.WAZGMCOMMAND:	PUSHM.L	D0..D4,A3,A4; S'il y a une commande juste aprs, il faut la sauter pour l'ignorer.	CALL	GETPTC	JUMP',NE 10$	COMP.B	D3,#COMMAND	; commande juste aprs ?	JUMP',NE 10$		; non => 10$	CALL	AVANCE		; oui => saute la commande; S'il y a une commande juste avant, il faut la modifier.10$:	CALL	RECULE	JUMP',NE 15$	COMP.B	D3,#COMMAND	; commande juste avant ?	JUMP',EQ 42$		; oui => 42$	CALL	AVANCE; Cherche quel est le gencar et le mode actuellement utilis.15$:	LOAD.W	D0,(A5)+OCCOM+OCOMNOG ; D0 <-- gencar/mode initial; Ajoute une premire commande de dbut si ncessaire.	COMP.W	D2,(A5)+OCCOM+OCOMNOG ; mme gencar/mode dj utilis ?	JUMP',EQ 30$		; oui => 30$				; non =>	LOAD.L	A4,(A5)+OPDT	CALL	NILCOMMAND	; cre une commande vierge	JUMP,NE 90$	LOAD.B	(A4)+1+LGCOM+OCOMMOD,D2	RR.W	D2,#8	LOAD.B	(A4)+1+LGCOM+OCOMNOG,D2	RR.W	D2,#8	CALL	NEWCOMMAND	; mj commandes suivante/prcdente; Avance jusqu' la fin de la zone, en modifiant les commandes; rencontres.30$:	TEST.W	D1		; encore caractre(s)  avancer ?	JUMP',EQ 50$		; non => 50$	CALL	AVANCE		; D3 <-- caractre suivant	JUMP',NE 50$	COMP.B	D3,#COMMAND	JUMP',EQ 40$	CALL	IFLPSEUDO	JUMP,EQ	30$	DEC.W	D1		; D1 <-- un caractre avanc de plus	JUMP	30$40$:	CALL	RECULE42$:	LOAD.L	A4,(A5)+OPFT	LOAD.B	D0,(A4)+1+LGCOM+OCOMNOG	RR.W	D0,#8	LOAD.B	D0,(A4)+1+LGCOM+OCOMMOD	LOAD.B	(A4)+1+LGCOM+OCOMMOD,D2	RR.W	D2,#8	LOAD.B	(A4)+1+LGCOM+OCOMNOG,D2	RR.W	D2,#8	CALL	MODCOMMAND	; mj commande suivante	CALL	AVANCE	JUMP	30$; Met une commande pour remettre le gencar initial.50$:	COMP.W	D0,(A5)+OCCOM+OCOMNOG ; mme gencar/mode dj utilis ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	A4,(A5)+OPDT	CALL	NILCOMMAND	; met une nouvelle commande	JUMP',NE 90$	LOAD.B	(A4)+1+LGCOM+OCOMMOD,D0 ; remet mode initial	RR.W	D0,#8	LOAD.B	(A4)+1+LGCOM+OCOMNOG,D0 ; remet gencar initial	CALL	NEWCOMMAND	; mj commandes suivante/prcdente90$:	POPM.L	D0..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; AZGCOMMAND >;===========/; Utilise un gencar dans une nouvelle zone.; On est au dbut de la zone, et on connat sa longueur.; in	D2.B	gencar;	D1.W	nb de caractres; out	D7.W	erreur; mod	D7.WAZGCOMMAND:	PUSHM.L	D0..D4,A3,A4; S'il y a une commande juste aprs, il faut la sauter pour l'ignorer.	CALL	GETPTC	JUMP',NE 10$	COMP.B	D3,#COMMAND	; commande juste aprs ?	JUMP',NE 10$		; non => 10$	CALL	AVANCE		; oui => saute la commande; S'il y a une commande juste avant, il faut la modifier.10$:	CALL	RECULE	JUMP',NE 15$	COMP.B	D3,#COMMAND	; commande juste avant ?	JUMP',EQ 42$		; oui => 42$	CALL	AVANCE; Cherche quel est le gencar et le mode actuellement utilis.15$:	LOAD.W	D0,(A5)+OCCOM+OCOMNOG ; D0 <-- gencar/mode initial; Ajoute une premire commande de dbut si ncessaire.	COMP.B	D2,(A5)+OCCOM+OCOMNOG ; mme gencar dj utilis ?	JUMP',EQ 30$		; oui => 30$				; non =>	LOAD.L	A4,(A5)+OPDT	CALL	NILCOMMAND	; cre une commande vierge	JUMP,NE 90$	LOAD.B	(A4)+1+LGCOM+OCOMMOD,D0	LOAD.B	(A4)+1+LGCOM+OCOMNOG,D2	CALL	NEWCOMMAND	; mj commandes suivante/prcdente; Avance jusqu' la fin de la zone, en modifiant les commandes; rencontres.30$:	TEST.W	D1		; encore caractre(s)  avancer ?	JUMP',EQ 50$		; non => 50$	CALL	AVANCE		; D3 <-- caractre suivant	JUMP',NE 50$	COMP.B	D3,#COMMAND	JUMP',EQ 40$	CALL	IFLPSEUDO	JUMP,EQ	30$	DEC.W	D1		; D1 <-- un caractre avanc de plus	JUMP	30$40$:	CALL	RECULE42$:	LOAD.L	A4,(A5)+OPFT	LOAD.B	D0,(A4)+1+LGCOM+OCOMNOG	RR.W	D0,#8	LOAD.B	D0,(A4)+1+LGCOM+OCOMMOD	LOAD.B	(A4)+1+LGCOM+OCOMNOG,D2	CALL	MODCOMMAND	; mj commande suivante	CALL	AVANCE	JUMP	30$; Met une commande pour remettre le gencar initial.50$:	COMP.W	D0,(A5)+OCCOM+OCOMNOG ; mme gencar/mode dj utilis ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	A4,(A5)+OPDT	CALL	NILCOMMAND	; met une nouvelle commande	JUMP',NE 90$	LOAD.B	(A4)+1+LGCOM+OCOMMOD,D0 ; remet mode initial	RR.W	D0,#8	LOAD.B	(A4)+1+LGCOM+OCOMNOG,D0 ; remet gencar initial	CALL	NEWCOMMAND	; mj commandes suivante/prcdente90$:	POPM.L	D0..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; AZMCOMMAND >;===========/; Utilise un mode dans une nouvelle zone.; On est au dbut de la zone, et on connat sa longueur.; in	D2.B	mode;	D1.W	nb de caractres; out	D7.W	erreur; mod	D7.WAZMCOMMAND:	PUSHM.L	D0..D4,A3,A4; S'il y a une commande juste aprs, il faut la sauter pour l'ignorer.	CALL	GETPTC	JUMP',NE 10$	COMP.B	D3,#COMMAND	; commande juste aprs ?	JUMP',NE 10$		; non => 10$	CALL	AVANCE		; oui => saute la commande; S'il y a une commande juste avant, il faut la modifier.10$:	CALL	RECULE	JUMP',NE 15$	COMP.B	D3,#COMMAND	; commande juste avant ?	JUMP',EQ 42$		; oui => 42$	CALL	AVANCE; Cherche quel est le gencar et le mode actuellement utilis.15$:	LOAD.W	D0,(A5)+OCCOM+OCOMNOG ; D0 <-- gencar/mode initial; Ajoute une premire commande de dbut si ncessaire.	COMP.B	D2,(A5)+OCCOM+OCOMMOD ; mme mode dj utilis ?	JUMP',EQ 30$		; oui => 30$				; non =>	LOAD.L	A4,(A5)+OPDT	CALL	NILCOMMAND	; cre une commande vierge	JUMP,NE 90$	RR.W	D0,#8	LOAD.B	(A4)+1+LGCOM+OCOMNOG,D0	RR.W	D0,#8	LOAD.B	(A4)+1+LGCOM+OCOMMOD,D2	CALL	NEWCOMMAND	; mj commandes suivante/prcdente; Avance jusqu' la fin de la zone, en modifiant les commandes; rencontres.30$:	TEST.W	D1		; encore caractre(s)  avancer ?	JUMP',EQ 50$		; non => 50$	CALL	AVANCE		; D3 <-- caractre suivant	JUMP',NE 50$	COMP.B	D3,#COMMAND	JUMP',EQ 40$	CALL	IFLPSEUDO	JUMP,EQ	30$	DEC.W	D1		; D1 <-- un caractre avanc de plus	JUMP	30$40$:	CALL	RECULE42$:	LOAD.L	A4,(A5)+OPFT	LOAD.B	D0,(A4)+1+LGCOM+OCOMNOG	RR.W	D0,#8	LOAD.B	D0,(A4)+1+LGCOM+OCOMMOD	LOAD.B	(A4)+1+LGCOM+OCOMMOD,D2	CALL	MODCOMMAND	; mj commande suivante	CALL	AVANCE	JUMP	30$; Met une commande pour remettre le mode initial.50$:	COMP.W	D0,(A5)+OCCOM+OCOMNOG ; mme gencar/mode dj utilis ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	A4,(A5)+OPDT	CALL	NILCOMMAND	; met une nouvelle commande	JUMP',NE 90$	LOAD.B	(A4)+1+LGCOM+OCOMMOD,D0 ; remet mode initial	RR.W	D0,#8	LOAD.B	(A4)+1+LGCOM+OCOMNOG,D0 ; remet gencar initial	CALL	NEWCOMMAND	; mj commandes suivante/prcdente90$:	POPM.L	D0..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; NILCOMMAND >;===========/; Cre une nouvelle commande vierge.; in	-; out	D7.W	erreur; mod	D7.WNILCOMMAND:	PUSHM.L	D3,D4	LOAD.W	D4,#1+(LGCOM*2)+1	CALL	PLACE?		; place pour une commande ?	JUMP',NE 90$		; non => 90$	LOAD.B	D3,#DEBCOM	; <debcom>	CALL	CINSERT; Cre de la place pour les paramtres "prev" et "next".	LOAD.W	D4,#LGCOM*250$:	CLR.B	D3	CALL	CINSERT	DEC.W	D4	JUMP,NE	50$	LOAD.B	D3,#FINCOM	; <fincom>	CALL	CINSERT90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; NEWCOMMAND >;===========/; Met  jour les commandes en fonction d'une nouvelle commande cre.; Doit tre utilis chaque fois qu'une nouvelle commande est mise; dans un buffer (cration, copie, insertion de fichier, etc).;	           |------------|  |---------------|;	           |            V  |               V;	-------(Cp-Cn)---------(Cp-Cn)====--------(Cp-Cn)-------;	                              ^   ^;	                              DT  FT; in	-; out	D7.W	ok; mod	D7.WNEWCOMMAND:	PUSHM.L	D3,A3,A4	LOAD.L	A4,(A5)+OPDT	CALL	PVISU		; A4 <-- recule nouvelle commande	CALL	UPCOMMAND	; OUCOM <-- commande prcdente	LOAD.L	A4,#(A6)+OUCOM	LOAD.L	A3,(A5)+OPDT	LOAD.L	A3,#(A3)-(LGCOM+LGCOM+1)	CALL	UPDCOMMAND	; mj paramtres "prev"	LOAD.L	A4,(A5)+OPFT	CALL	DOWNCOMMAND	; ODCOM <-- commande suivante	JUMP',NE 60$	LOAD.L	A3,#(A4)+1	LOAD.L	A4,(A5)+OPDT	LOAD.L	A4,#(A4)-(LGCOM+1)	CALL	COPCOMMAND	; mj paramtres "next"60$:	LOAD.L	A3,#(A5)+OCCOM	LOAD.L	A4,(A5)+OPDT	LOAD.L	A4,#(A4)-(LGCOM+1)	CALL	MAJCOMMAND	; OCCOM <-- commande en cours ici	LOAD.B	D3,(A5)+OCCOM+OCOMNOG	CALL	UZGC		; signal gencar utilis par cette zone	CLR.W	D7		; D7 <-- ok	POPM.L	D3,A3,A4	RET;-----------\\; MODCOMMAND >;===========/; Met  jour la commande suivante en fonction d'une commande modifie.; La commande modifie est forcment sous le curseur !;	                           |----------------|;	                           |                V;	-------(Cp-Cn)-----====(Cp-Cn)-------------(Cp-Cn)-------;	                   ^   ^;	                   DT  FT; in	-; out	D7.W	ok; mod	D7.WMODCOMMAND:	PUSHM.L	D3,A3,A4	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^commande modifie	CALL	NVISU		; A4 <-- saute la commande modifie	CALL	DOWNCOMMAND	; (A6)+ODCOM <-- commande suivante	JUMP',NE 80$		; pas de commande suivante => 80$	LOAD.L	A3,#(A4)+1	; A3 <-- ^paramtres "prev"	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^commande modifie	LOAD.L	A4,#(A4)+1+LGCOM	CALL	COPCOMMAND	; suivante[prev] <-- actuelle[next]80$:	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^commande modifie	LOAD.L	A4,#(A4)+1+LGCOM	LOAD.L	A3,#(A5)+OCCOM	CALL	MAJCOMMAND	; OCCOM <-- nouvelle commande en cours	LOAD.B	D3,(A5)+OCCOM+OCOMNOG	CALL	UZGC		; signal gencar utilis par cette zone	CLR.W	D7		; D7 <-- ok	POPM.L	D3,A3,A4	RET;-----------\\; DELCOMMAND >;===========/; Met  jour la commande infrieure en fonction de la commande; suprieure aprs avoir dtruit une commande entre les deux.;	           |--------------------------------|;	           |                                V;	-------(Cp-Cn)---------=======-------------(Cp-Cn)-------;	                       ^      ^;	                       DT     FT; in	-; out	-; mod	D7.WDELCOMMAND:	PUSHM.L	A3,A4	LOAD.L	A4,(A5)+OPDT	CALL	UPCOMMAND	; (A6)+OUCOM <-- commande prcdente	LOAD.L	A4,#(A6)+OUCOM	LOAD.L	A3,#(A5)+OCCOM	CALL	COPCOMMAND	; OCCOM <-- nouvelle commande en cours	LOAD.L	A4,(A5)+OPFT	CALL	DOWNCOMMAND	; (A6)+ODCOM <-- commande suivante	JUMP',NE 90$	LOAD.L	A3,#(A4)+1	; A3 <-- ^paramtres "prev"	LOAD.L	A4,#(A6)+OUCOM	CALL	UPDCOMMAND	; suivante[prev] <-- prcdente[next]90$:	POPM.L	A3,A4	RET;------------\\; VAQQCOMMAND >;============/; Cherche la commande valide d'aprs un pointeur dans un buffer.; in	A5.L	^description d'un buffer;	A4.L	^dans le buffer;	A3.L	^pour paramtres de la commande; out	A4.L	^dbut de la commande;	D7.W	erreur; mod	D7.W, A4.LVAQQCOMMAND:	PUSH.W	D310$:	CALL	QUICKUP		; cherche contre en haut	JUMP',NE 50$		; pas trouv => 50$	COMP.B	D3,#DEBCOM	; dbut d'une commande ?	JUMP,NE	10$		; non => 10$				; oui =>	PUSH.L	A4	LOAD.L	A4,#(A4)+1+LGCOM; A4 <-- ^paramtres "next"	CALL	MAJCOMMAND	; met  jour les variables	POP.L	A4	CLR.W	D7		; D7 <-- commande trouve	JUMP'	90$50$:				; pas trouve =>	CALL	DEFCOMMAND	; met  jour les variables	LOAD.W	D7,#ERTNOT	; D7 <-- commande pas trouve90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; UPCOMMAND >;==========/; Cherche la commande la plus proche contre en haut.; in	A5.L		^description d'un buffer;	A4.L		^dans le buffer; out	(A6)+OUCOM	paramtres de la commande;	A4.L		^dbut de la commande;	D7.W		erreur; mod	D7.W, A4.LUPCOMMAND:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OUCOM	; A3 <-- ^descripteur commande10$:	CALL	QUICKUP		; cherche contre en haut	JUMP',NE 50$		; pas trouv => 50$	COMP.B	D3,#DEBCOM	; dbut d'une commande ?	JUMP,NE	10$		; non => 10$				; oui =>	PUSH.L	A4	LOAD.L	A4,#(A4)+1+LGCOM; A4 <-- ^paramtres "next"	CALL	MAJCOMMAND	; met  jour les variables	POP.L	A4	CLR.W	D7		; D7 <-- commande trouve	JUMP'	90$50$:	CALL	DEFCOMMAND	; met  jour les variables	LOAD.W	D7,#ERTNOT	; D7 <-- commande pas trouve90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; DOWNCOMMAND >;============/; Cherche la commande la plus proche contre en bas.; in	A5.L		^description d'un buffer;	A4.L		^dans le buffer; out	(A6)+ODCOM	paramtres de la commande;	A4.L		^dbut de la commande;	D7.W		erreur; mod	D7.W, A4.LDOWNCOMMAND:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+ODCOM	; A3 <-- ^descripteur commande10$:	CALL	QUICKDOWN	; cherche contre en bas	JUMP',NE 50$		; pas trouv => 50$	COMP.B	D3,#DEBCOM	; dbut d'une commande ?	JUMP,NE	10$		; non => 10$				; oui =>	DEC.L	A4		; A4 <-- ^dbut commande	PUSH.L	A4	INC.L	A4		; A4 <-- ^paramtres "prev"	CALL	MAJCOMMAND	; met  jour les variables	POP.L	A4	CLR.W	D7		; D7 <-- commande trouve	JUMP'	90$50$:	CALL	DEFCOMMAND	; met  jour les variables	LOAD.W	D7,#ERTNOT	; D7 <-- commande pas trouve90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DEFCOMMAND >;===========/; Met  jour les variables en fonction de la commande par dfaut.; in	A3.L	^variables pour la commande; out	-; mod	D7.WDEFCOMMAND:	PUSHM.L	D2..D4,A3,A4	CLR.B	(A3)+OCOMNOG	; utilise gencar du fond	CLR.B	(A3)+OCOMMOD	; pas de mode	POPM.L	D2..D4,A3,A4	RET;-----------\\; MAJCOMMAND >;===========/; Met  jour les variables en fonction d'une nouvelle commande rencontre.; in	A3.L	^variables pour la commande;	A4.L	^paramtres next/prev commande rencontre; out	-; mod	D7.WMAJCOMMAND:;-----------\\; UPDCOMMAND >;===========/; Met  jour une commande en fonction de variables.; in	A3.L	^paramtres next/prev commande  mettre  jour;	A4.L	^variables pour la commande; out	-; mod	D7.WUPDCOMMAND:;-----------\\; COPCOMMAND >;===========/; Met  jour les variables en fonction d'une nouvelle commande rencontre.; in	A3.L	^variables pour la commande (destination);	A4.L	^variables pour la commande (source); out	-; mod	D7.WCOPCOMMAND:	PUSHM.L	D3,A3,A4	LOAD.W	D3,#LGCOM-150$:	LOAD.B	(A3+),(A4+)	DECJ.W,NMO D3,50$	POPM.L	D3,A3,A4	RET	.END