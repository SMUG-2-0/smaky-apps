	.SBTTL	TEXTDBOX; Gestion des DBOXs; -----------------;-----------\\; DBOXQUITTE >;===========/; Demande s'il faut quitter TEXT.; in	-; out	D7.W	rponse; mod	D7.WDBOXQUITTE:	PUSHM.L	D1..D4,A2..A5	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	CLR.L	D3	CALL	DBOXPREF	; dbox: attend la rponse ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',EQ 90$	LOAD.W	D7,#1		; D7 <-- rponse "non"90$:	POPM.L	D1..D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer le texte.; in	A5.L	^description de la zone  effacer; out	D7.W	erreur (reste dans edit); mod	D7.WDBOXEFFACE:	PUSHM.L	D1..D4,A2..A5	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	LOAD.W	D3,(A5)+ONOBUF	PUSH.L	A5	LOAD.L	A5,#(A5)+OBUMEMF; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	CALL	DBOXPREF	; dbox: attend la rponse ...	POPM.L	A5	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',EQ 90$	LOAD.W	D7,#1		; D7 <-- rponse "non"90$:	POPM.L	D1..D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXSURE >;=========/; Demande "Etes-vous sr ? "; in	-; out	D7.W	rponse; mod	D7.WDBOXSURE:	PUSHM.L	D1..D4,A1..A4	LIB	?BUZZ		; signal qq chose de spcial	LOAD.L	A2,#R16"TDBOX_SURE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUINON	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	CLR.W	D4	COMP.W	D3,#'O	JUMP',EQ 50$	INC.W	D4	COMP.W	D3,#'N	JUMP',EQ 50$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:	CALL	DBOXCLOSE	; ferme la DBOX	LOAD.W	D7,D4		; D7 <-- oui/non90$:	POPM.L	D1..D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXSAVE >;=========/; Sauve le texte actuel selon le choix de l'utilisateur.; in	A5.L	^description de la zone  sauver;	D0.W	mode (0=quitte, 1=nouveau texte); out	D7.W	erreur (reste dans edit); mod	D7.WDBOXSAVE:	PUSHM.L	D1..D4,A2..A5	TEST.B	(A5)+OSTATUS:#BFILMOD ; texte  jour ?	JUMP,BC	80$		; oui => 80$ (quitte, snif)				; non =>	CALL	IFVIDE		; buffer vide ?	JUMP',EQ 10$		; non => 10$				; oui =>	TCLR.B	(A5)+OSTATUS:#BFILMOD ; fait comme si texte  jour	JUMP	80$10$:	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	LOAD.W	D3,(A5)+ONOBUF	TEST.B	D0	JUMP',NE 25$	TSET.L	D3:#BDBIOQUIT	; D3 <-- texte "avant de quitter"25$:	PUSH.L	A5	LOAD.L	A5,#(A5)+OBUMEMF; A5 <-- ^nom du fichier	CLR.W	D2		; D2 <-- pas d'automatisme	TEST.B	(A5)		; nom existe ?	JUMP',EQ 30$		; non => 30$	LOAD.W	D2,#2^BDBAUTO	; D2 <-- automatique (plus de questions)30$:	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_MAJ	; D1 <-- code du sous-appel	CALL	DBOXPREF	; dbox: attend la rponse ...	POP.L	A5	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 85$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$	CALL	AOUTPUT		; sauve tout sur disque (in D2.W !)	JUMP',NE 85$80$:	CLR.W	D7		; D7 <-- quitte EDIT	JUMP'	90$85$:	LOAD.W	D7,#1		; D7 <-- reste dans EDIT90$:	POPM.L	D1..D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCREATE >;===========/; Cre et ouvre un fichier quelconque.; in	A3.L	^nom actuel;	A4.L	^extension;	D4.L	fanions;	D2.W	mode; out	D6.W	canal;	D4.L	fanions;	D3.W	dernire touche (F1/F0);	(A6)+OFLIO:#BNOTEXT;	D7.W	erreur; mod	D3.L, D4.L, D7.W +DBOXCREATE:	PUSHM.L	D0..D2,D5,A2..A4	LOAD.L	D0,D4		; D0 <-- fanions	TEST.B	(A5)+OSTATUS:#BFILMOD ; texte  jour ?	JUMP',BS 11$		; non => 11$;;?	JUMP',BC 10$		; oui => 10$;;?				; non =>;;?	CALL	IFVIDE		; buffer vide ?;;?	JUMP',EQ 11$		; non => 11$10$:	TSET.L	D2:#BDBNMAJ	; D2 <-- touche (MET A JOUR) grise11$:	LOAD.L	D4,D0		; D4 <-- fanions	CALL	DBOXEDITO	; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F0	JUMP,EQ	90$	LOAD.W	D1,D3		; D1 <-- F1/F4	LOAD.L	D0,D4		; D0 <-- fanions20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	PUSH.L	D0	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	POPM.L	D0	JUMP,EQ	70$		; ok => 70$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	TEST.L	D2:#BDBAUTO	; mode automatique ?	JUMP',BS 45$		; oui => 45$	COMP.W	D1,#F4		; touche (MET A JOUR) ?	JUMP',EQ 45$		; oui => 45$	TSET.L	D2:#BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	JUMP',NE 90$	CALL	AFMENU		; remet les soft-keys	COMP.W	D3,#'O	JUMP,NE 10$45$:	PUSH.L	D0	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	POPM.L	D0	JUMP',NE 90$	JUMP	20$70$:	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	POPM.L	D0	JUMP',NE 90$	TCLR.B	(A6)+OFLIO:#BNOTEXT	LOAD.L	A4,A3		; A4 <-- ^nom du fichier	LOAD.L	A3,#R16"01$	; A3 <-- ^critre "texte"	LOAD.L	A2,#R16"02$	; A2 <-- ^terminateurs	LIB	?CPSTRING	; est-ce que le fichier est un texte ?	JUMP',NC 80$		; oui => 80$	TSET.B	(A6)+OFLIO:#BNOTEXT80$:	LOAD.W	D3,#F1		; D3 <-- (RETURN)	LOAD.L	D4,D0		; D4 <-- fanions	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2,D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	"*.text"	; critre pour "texte"02$:	.B	0,CR,-1		; terminateurs	.EVEN;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre.; in	D4.L	tats des fanions;	A3.L	^nom actuel;	A4.L	^extension;	D2.W	mode; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	A3.L	^nouveau nom;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,A2..A5	CALL	KILEXT		; supprime l'extension	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_FAN	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	TEST.L	D4:#BIOAJOUTE	JUMP',BC 20$	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel20$:	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOFULL	COMP.L	A4,#0		; extension existe ?	JUMP',EQ 22$		; non => 22$	TSET.L	D3:#BDBIOEXT1	; oui => met le bon bit22$:	CALL	DBOXPREF	; dbox: attend la rponse ...	COMP.W	D3,#F1	JUMP,NE 90$	LOAD.L	D2,A4		; extension existe ?	JUMP',EQ 90$		; non => 80$	LOAD.L	A3,A5	PUSH.W	D3	CLR.W	D3		; D3 <-- laisse si autre extension	LIB	?ADDEXT		; ajoute l'extension	POP.W	D390$:	CALL	IOERROR		; affiche erreur si ncessaire	POPM.L	D1,D2,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEDITIM >;===========/; Edite un nom d'image en entre.; in	A2.L	^table pour DBOX;	D4.L	tats des fanions;	A3.L	^nom actuel;	A4.L	^extension;	D2.W	mode; out	D3.W	dernire touche (RETURN/END);	D4.L	tats des fanions;	A3.L	^nouveau nom;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITIM:	PUSHM.L	D0..D2,D5,A0..A4	LOAD.L	A0,A4		; A0 <-- ^extension	TSET.L	D2:#BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	CALL	KILEXT		; supprime l'extension	LOAD.L	A4,A3		; A4 <-- ^dbut du nom10$:	TEST.B	(A4+)		; A4 <-- ^fin du nom	JUMP,NE	10$	DEC.L	A420$:	LOAD.L	D0,D4	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	CLR.W	D7		; D7 <-- ok	COMP.W	D3,#CR		; COLLE ?	JUMP,EQ	60$	COMP.W	D3,#F7		; LISTE ?	JUMP,EQ	55$	COMP.W	D3,#F8	JUMP,EQ 55$	COMP.W	D3,#F9	JUMP,EQ 55$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ	80$	COMP.W	D3,#UNDO	JUMP',EQ 40$	COMP.W	D3,#F10	JUMP',EQ 50$	COMP.W	D3,#F12	JUMP',EQ 51$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$50$:	LOAD.L	D4,D0	AND.B	D4,#B'11111100	TSET.L	D4:#BIOBOA	JUMP	20$51$:	LOAD.L	D4,D0	AND.B	D4,#B'11111100	TSET.L	D4:#BIONOBOA	JUMP	20$55$:				; LISTE =>	CALL	DBOXCLOSE	; ferme la DBOX	PUSH.L	D4	LOAD.L	A4,A3		; A4 <-- ^buffer pour le nom	LOAD.L	A3,A0		; A3 <-- ^critre (extension)	LOAD.L	D4,#2^BLIDBNOM	; D4 <-- mode	LOAD.L	A2,#R16"01$	; A2 <-- ^nom de la touche principale	TCLR.B	(A6)+OFLAGS:#BMDBOX	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode (avec sauvetage)	LIST_	DBOX		; liste et choix selon dbox ...	JUMP',EQ 57$		; ok => 57$	CLR.W	D2		; D2 <-- mode (sans sauvetage)	LIST_	DBOX		; liste et choix selon dbox ...	JUMP',NE 57$		; erreur => 57$	TSET.B	(A6)+OFLAGS:#BMDBOX57$:	POPM.L	D4	PUSH.W	D7	CALL	DBOXREFAIT	; remet les soft-keys standards	POP.W	D7	JUMP,NE 90$	LOAD.L	A3,A4		; A3 <-- ^nom du fichier	JUMP	90$60$:				; COLLE =>	TEST.B	(A3)		; nom existe ?	JUMP,EQ	30$		; non => 30$	COMP.B	(A3),#CR	JUMP,EQ	30$70$:	LOAD.L	D0,A0		; extension existe ?	JUMP',EQ 80$		; non => 80$	LOAD.L	A4,A0		; A4 <-- ^extension	PUSH.W	D3	CLR.W	D3		; D3 <-- laisse si autre extension	LIB	?ADDEXT		; ajoute l'extension	POP.W	D380$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	CALL	IOERROR		; affiche erreur si ncessaire	POPM.L	D0..D2,D5,A0..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	"COLLE"	.EVEN;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie.; in	D4.L	tats des fanions;	A3.L	^nom actuel;	A4.L	^extension;	D2.W	mode; out	D3.W	dernire touche (F1/F4/F0);	D4.L	tats des fanions;	A3.L	^nouveau nom;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITO:	PUSHM.L	D1,D2,A2..A5	LOAD.W	D3,#F1		; D3 <-- comme si (SAUVE)	TEST.L	D2:#BDBAUTO	; mode automatique ?	JUMP,BS	70$		; oui => 70$	CALL	KILEXT		; supprime l'extension	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_FAN	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOFULL	COMP.L	A4,#0		; extension existe ?	JUMP',EQ 22$		; non => 22$	TSET.L	D3:#BDBIOEXT1	; oui => met le bon bit22$:	TEST.L	D2:#BDBNMAJ	JUMP',BC 30$	TSET.L	D3:#BDBIONMAJ	; D3 <-- touche (MET A JOUR) grise30$:	CALL	DBOXPREF	; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	COMP.W	D3,#F1	JUMP',NE 90$70$:	LOAD.L	D2,A4		; extension existe ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A3,A5	PUSH.W	D3	CLR.W	D3		; D3 <-- laisse si autre extension	LIB	?ADDEXT		; ajoute l'extension	POP.W	D390$:	CALL	IOERROR		; affiche erreur si ncessaire	POPM.L	D1,D2,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXDEFINE >;===========/; Dialogue pour la DBOX de dfinition.; in	-; out	D7.W	erreur; mod	D7.WDBOXDEFINE:	PUSHM.L	D1..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_DEFINE	LOAD.L	D4,(A6)+OFANION	; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	LOAD.L	A3,#(A6)+OBUEXT	LOAD.L	A4,A310$:	TEST.B	(A4+)	JUMP,NE 10$	DEC.L	A420$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,A326$:	TEST.B	(A1)	JUMP',EQ 27$	COMP.B	(A1+),#CR	JUMP,NE 26$	CLR.B	(A1)-1		; remplace <CR> par <0>27$:	LOAD.L	A1,#R16"TKEY_OKANNCR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP,EQ 50$	COMP.W	D3,#END	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP',EQ 35$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$35$:				; UNDO =>	CLR.B	(A3)	LOAD.L	A4,A3	JUMP	20$50$:				; OK =>	LOAD.L	(A6)+OFANION,D4	; mj tous les fanions	TSET.B	(A5)+OSTATUS:#BFILMOD ; fichier pas  jour	LOAD.W	D4,#MODALL	CALL	MODIF		; signal tout modifi80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXJUST  >;==========/; Dialogue avec la DBOX des paramtres de justification.; in	-; out	D7.W	erreur; mod	D7.WDBOXJUST:	PUSHM.L	D0..D5,A0..A4	LOAD.L	A2,#R16"TDBOX_JUST	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode d'ouverture	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	CALL	GCICONE		; utilise g.c. des icnes	LOAD.W	D2,#1	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.B	AFTOUT,ICOJUSTA,AFNORM,0	.EVEN	LOAD.W	D2,#5	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.B	AFTOUT,ICOJUSTD,AFNORM,0	.EVEN	SWAP.W	D3	ADD.W	D3,#GCICY+2	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.B	AFTOUT,ICOJUSTG,AFNORM,0	.EVEN	SWAP.W	D3	ADD.W	D3,#GCICY+2	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.B	AFTOUT,ICOJUSTC,AFNORM,0	.EVEN	CALL	GCDEF		; utilise g.c. par dfaut	LOAD.L	A0,#R16"TANJUST	CLR.W	D2		; D2 <-- premier choix10$:	PUSH.W	D2	CLR.W	D212$:	CALL	DBOXAFN		; affiche tous les paramtres	INC.W	D2	COMP.W	D2,#3	JUMP,LO 12$	POP.W	D220$:	CLR.W	D0		; D0 <-- rang digit22$:	CALL	DBOXAFN		; affiche un nombre	LOAD.B	D3,#CURS	LIB	?AFCAR		; remet le curseur	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OKANNCR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	CLR.W	D7		; D7 <-- [OK]	COMP.W	D3,#F1	JUMP,EQ	80$	INC.W	D7		; D7 <-- [ANNULE]	COMP.W	D3,#END	JUMP,EQ	85$	COMP.W	D3,#F7	JUMP',EQ 50$	COMP.W	D3,#F8	JUMP',EQ 51$	COMP.W	D3,#F9	JUMP',EQ 52$	COMP.W	D3,#CR	JUMP,EQ	60$	COMP.W	D3,#DEL	JUMP,EQ	62$	COMP.W	D3,#UNDO	JUMP,EQ	64$	COMP.W	D3,#'0	JUMP',LO 30$	COMP.W	D3,#'9	JUMP,LS	70$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	22$50$:	CLR.W	D2	JUMP	10$51$:	LOAD.W	D2,#1	JUMP	10$52$:	LOAD.W	D2,#2	JUMP	10$60$:				; RETURN =>	INC.W	D2	COMP.W	D2,#3	JUMP,LO	10$	CLR.W	D2	JUMP	10$62$:				; DEL =>	TEST.W	D0		; premier digit ?	JUMP,EQ	64$		; oui => 64$	CLR.L	D1	LOAD.W	D1,(A4)	DIV.WU	D1,#10	LOAD.W	(A4),D1	DEC.W	D0		; D0 <-- un digit de moins	JUMP	22$64$:				; UNDO =>	CLR.W	(A4)	JUMP	20$70$:				; DIGIT =>	COMP.W	D0,#4		; trop de digits ?	JUMP,HS	30$		; oui => 30$	CLR.W	D1	TEST.W	D0		; premier digit ?	JUMP',EQ 72$		; oui => 72$	LOAD.W	D1,(A4)72$:	MUL.WU	D1,#10		; pousse d'un digit	SUB.W	D3,#'0		; D3 <-- 0..9	ADD.W	D1,D3		; ajoute nouveau digit	LOAD.W	(A4),D1	INC.W	D0		; D0 <-- un digit de plus	JUMP	22$80$:	CALL	AJUSTIF		; re-justifie tout le texte85$:	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D790$:	POPM.L	D0..D5,A0..A4	RETTANJUST:	.W	OJUPAL	.W	0,0	.B	3,0	.W	OJUPTR	.W	0,0	.B	7,0	.W	OJUPNL	.W	0,0	.B	10,0;----------\\; DBOXPARAM >;==========/; Dialogue avec la DBOX des paramtres de l'imprimante.; in	-; out	D7.W	erreur; mod	D7.WDBOXPARAM:	PUSHM.L	D0..D5,A0..A4	LOAD.W	D4,(A6)+OITL	CALL	CONVPMY		; D4 <-- nombre [mm]	LOAD.W	(A6)+OTITL,D4	LOAD.W	D4,(A6)+OMGS	CALL	CONVPMY		; D4 <-- nombre [mm]	LOAD.W	(A6)+OTMGS,D4	LOAD.W	D4,(A6)+OMGI	CALL	CONVPMY		; D4 <-- nombre [mm]	LOAD.W	(A6)+OTMGI,D4	LOAD.W	D4,(A6)+OMGG	CALL	CONVPMY		; D4 <-- nombre [mm]	LOAD.W	(A6)+OTMGG,D4	LOAD.L	A2,#R16"TDBOX_PARAM	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode d'ouverture	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A0,#R16"TANPARAM	CLR.W	D2		; D2 <-- premier choix10$:	PUSH.W	D2	CLR.W	D212$:	CALL	DBOXAFN		; affiche tous les paramtres	INC.W	D2	COMP.W	D2,#4	JUMP,LO 12$	POP.W	D220$:	CLR.L	D0		; D0 <-- rang digit22$:	CALL	DBOXAFN		; affiche un nombre	LOAD.B	D3,#CURS	LIB	?AFCAR		; remet le curseur	CLR.L	D4		; D4 <-- fanions	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OKANNCR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	CLR.W	D7		; D7 <-- ok	COMP.W	D3,#F1	JUMP,EQ	80$	COMP.W	D3,#END	JUMP,EQ	85$	COMP.W	D3,#CR	JUMP,EQ	60$	COMP.W	D3,#DEL	JUMP,EQ	62$	COMP.W	D3,#UNDO	JUMP,EQ	64$	COMP.W	D3,#'.	JUMP,EQ 61$	COMP.W	D3,#POINT	JUMP,EQ 61$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ 50$	COMP.W	D3,#'0	JUMP',LO 30$	COMP.W	D3,#'9	JUMP,LS	70$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	22$50$:	CALL	DBOXCKN		; check les limites du paramtre	AND.W	D3,#H'00FF	; D3 <-- 0..n	LOAD.W	D2,D3	JUMP	10$60$:				; RETURN =>	CALL	DBOXCKN		; check les limites du paramtre	INC.W	D2	COMP.W	D2,#4	JUMP,LO	10$	CLR.W	D2	JUMP	10$61$:				; POINT =>	TSET.L	D0:#16	JUMP	22$62$:				; DEL =>	TEST.W	D0		; premier digit ?	JUMP',EQ 64$		; oui => 64$	CLR.L	D1	LOAD.W	D1,(A4)	DIV.WU	D1,#10	LOAD.W	(A4),D1	DEC.W	D0		; D0 <-- un digit de moins	LOAD.W	D4,D2	MUL.WU	D4,#8	TEST.B	(A0)+(D4.W)+7	; nombre avec une dcimale ?	JUMP,BC 22$		; non => 22$	TCLR.L	D0:#16		; "." frapp ?	JUMP,BS 22$		; oui => 22$	CLR.L	D1		; non =>	LOAD.W	D1,(A4)	DIV.WU	D1,#10	MUL.WU	D1,#10		; met la dcimale  zro	LOAD.W	(A4),D1	JUMP	22$64$:				; UNDO =>	CLR.W	(A4)	CLR.L	D0	JUMP	20$70$:				; DIGIT =>	COMP.W	D0,#4		; trop de digits ?	JUMP,HS	30$		; oui => 30$	CLR.W	D1	TEST.W	D0		; premier digit ?	JUMP',EQ 72$		; oui => 72$	LOAD.W	D1,(A4)72$:	MUL.WU	D1,#10		; pousse d'un digit	SUB.W	D3,#'0		; D3 <-- 0..9	LOAD.W	D4,D2	MUL.WU	D4,#8	TEST.B	(A0)+(D4.W)+7	; nombre avec une dcimale ?	JUMP',BC 74$		; non => 74$	MUL.WU	D3,#10	TEST.L	D0:#16		; "." frapp ?	JUMP',BC 74$		; non => 74$	DIV.WU	D1,#10		; oui => pousse pas	DIV.WU	D3,#1074$:	ADD.W	D1,D3		; ajoute nouveau digit	LOAD.W	(A4),D1	INC.W	D0		; D0 <-- un digit de plus	JUMP	22$80$:	CALL	DBOXCKN		; check les limites du paramtre	CALL	DBOXAFN		; affiche juste ce paramtre	LOAD.W	D4,(A6)+OTITL	CALL	CONVMPY		; D4 <-- nombre [p]	LOAD.W	(A6)+OITL,D4	LOAD.W	D4,(A6)+OTMGS	CALL	CONVMPY		; D4 <-- nombre [p]	LOAD.W	(A6)+OMGS,D4	LOAD.W	D4,(A6)+OTMGI	CALL	CONVMPY		; D4 <-- nombre [p]	LOAD.W	(A6)+OMGI,D4	LOAD.W	D4,(A6)+OTMGG	CALL	CONVMPY		; D4 <-- nombre [p]	LOAD.W	(A6)+OMGG,D4	CALL	AJUSTIF		; re-justifie tout le texte85$:	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D790$:	POPM.L	D0..D5,A0..A4	RETTANPARAM:	.W	OTMGG	.W	0,0	.B	1,1	.W	OTITL	.W	0,0	.B	3,1	.W	OTMGS	.W	OMGSH,0	.B	5,1	.W	OTMGI	.W	OMGIH,0	.B	7,1;--------\\; DBOXCKN >;--------/; Check d'un nombre pour qu'il soit dans les limites autorises.; in	D2.W	rang du nombre (0..n);	A0.L	^table .WWWBB; out	A4.L	^nombre (.W); mod	D7.W, A4.LDBOXCKN:	PUSHM.L	D0..D4,A4	LOAD.W	D0,D2	MUL.WU	D0,#8	LOAD.W	D1,(A0)+(D0.W)+0 ; D1 <-- offset variable	LOAD.L	A4,#(A6)+(D1.W)	; A4 <-- ^nombre	CLR.L	D2	LOAD.W	D2,(A4)		; D2 <-- nombre	LOAD.W	D1,(A0)+(D0.W)+2 ; limite infrieure existe ?	JUMP',EQ 30$		; non => 30$	LOAD.W	D4,(A6)+(D1.W)	CALL	CONVPMY		; D4 <-- nombre [mm]	COMP.W	D2,D4		; trop petit ?	JUMP',HS 30$	LOAD.W	D2,D430$:	LOAD.W	D1,(A0)+(D0.W)+4 ; limite suprieure existe ?	JUMP',EQ 35$		; non => 35$	LOAD.W	D4,(A6)+(D1.W)	CALL	CONVPMX		; D4 <-- nombre [mm]	COMP.W	D2,D4		; trop grand ?	JUMP',LS 35$	LOAD.W	D2,D435$:	LOAD.W	(A4),D2		; mj le nombre	POPM.L	D0..D4,A4	RET;--------\\; DBOXAFN >;--------/; Affiche un nombre dans la DBOX.; in	D2.W	rang du nombre (0..n);	A0.L	^table .WWWBB; out	A4.L	^nombre (.W); mod	D7.W, A4.LDBOXAFN:	PUSHM.L	D0..D4	LOAD.B	D3,#NOCURS	LIB	?AFCAR		; plus de curseur	LOAD.W	D0,D2	MUL.WU	D0,#8	CLR.W	D2	LOAD.B	D2,(A0)+(D0.W)+6 ; D2 <-- rang dans DBOX	DBOX_	GETCO		; D3 <-- coordonne	LIB	?SETCURS	; positionne	LOAD.W	D1,(A0)+(D0.W)+0 ; D1 <-- offset variable	LOAD.L	A4,#(A6)+(D1.W)	; A4 <-- ^nombre	CLR.L	D4	LOAD.W	D4,(A4)		; D4 <-- nombre	TEST.B	(A0)+(D0.W)+7	; nombre avec une dcimale ?	JUMP',NE 50$		; oui => 50$	LOAD.W	D3,#5		; D3 <-- nb digits (0..99999)	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC		; affiche le nombre	JUMP'	90$50$:	DIV.WA	D4,#10	SWAP.W	D4	LOAD.W	D1,D4		; D1 <-- reste (partie fractionnaire)	CLR.W	D4	SWAP.W	D4	LOAD.W	D3,#3		; D3 <-- nb digits partie entire (0..999)	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC		; affiche la partie entire	LOAD.B	D3,#'.	LIB	?AFCAR	LOAD.B	D3,D1	ADD.B	D3,#'0	LIB	?AFCAR		; affiche la partie fractionnaire90$:	POPM.L	D0..D4	RET;-----------\\; DBOXSEARCH >;===========/; Dialogue pour la DBOX de recherche/substitution.; in	-; out	D3.W	rponse;	D7.W	erreur; mod	D3.L, D7.WDBOXSEARCH:	PUSHM.L	D0,D1,D2,D4,D5,A0..A4	LOAD.L	A0,#(A6)+OSEAST1	CALL	GETSEARCH	LOAD.L	A0,#(A6)+OSEAST2	CALL	GETSEARCH	LOAD.L	A2,#R16"TDBOX_SEARCH	CLR.L	D4	LOAD.B	D4,(A6)+OSEAMOD	; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	CLR.B	D2		; D2 <-- pas d'accent en cours	LOAD.L	A0,#(A6)+OSEAST2	LOAD.B	D0,#1	TEST.B	(A0)	JUMP',EQ 05$	CALL	UNDSEARCH	; efface la chane05$:	CALL	AFFSEARCH	; affiche la chane de substitution	LOAD.L	A0,#(A6)+OSEAST1	CLR.B	D0	TEST.B	(A0)	JUMP',EQ 10$	CALL	UNDSEARCH	; efface la chane10$:	CALL	AFFSEARCH	; affiche la bonne chane	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_SEA	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	10$		; oui => 10$	COMP.W	D3,#MACRO	; bouton/flag boug ?	JUMP,EQ 10$		; oui => 10$	COMP.W	D3,#END	JUMP,EQ	85$	COMP.W	D3,#F1	JUMP,EQ	80$	COMP.W	D3,#F3	JUMP,EQ	80$	COMP.W	D3,#F4	JUMP,EQ	80$	COMP.W	D3,#F6	JUMP,EQ	80$	COMP.W	D3,#F7	JUMP,EQ	80$	COMP.W	D3,#F9	JUMP,EQ	80$	COMP.W	D3,#F2	JUMP,EQ	81$	COMP.W	D3,#F5	JUMP,EQ	81$	COMP.W	D3,#F8	JUMP,EQ	81$	COMP.W	D3,#F10		; (a=A) ?	JUMP,EQ 70$	COMP.W	D3,#F12		; (Mot) ?	JUMP,EQ 72$	COMP.W	D3,#F14		; (Cherche) ?	JUMP,EQ	74$	COMP.W	D3,#F15		; (Change) ?	JUMP,EQ	76$	COMP.W	D3,#DEFINE	JUMP,EQ 60$	COMP.W	D3,#UNDO	JUMP,EQ 50$	COMP.W	D3,#F13		; (Prcdent) ?	JUMP,EQ 55$	COMP.W	D3,#DEL	JUMP,EQ 40$	COMP.W	D3,#DELETE	JUMP,EQ 40$	COMP.W	D3,#H'80	JUMP',LO 30$20$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	10$30$:				; frappe =>	TEST.B	D2		; accent en cours ?	JUMP',NE 35$		; oui => 35$	LOAD.B	D2,#CIRCON	COMP.B	D3,#KCIRCON	JUMP',EQ 34$	LOAD.B	D2,#TREMA	COMP.B	D3,#KTREMA	JUMP',EQ 34$32$:	COMP.B	D3,#CR	JUMP',EQ 33$	COMP.B	D3,#SCR	JUMP',EQ 33$	COMP.B	D3,#CCR	JUMP',EQ 33$	COMP.B	D3,#TAB	JUMP',EQ 33$	COMP.B	D3,#CADRATIN	JUMP',EQ 33$	COMP.B	D3,#'		; caractre "impossible" ?	JUMP,LO 20$		; oui => 20$33$:	CLR.B	D2		; D2 <-- pas d'accent en cours	CALL	INSSEARCH	; insre un caractre	JUMP	10$34$:	LOAD.B	D3,D2	CALL	INSSEARCH	; insre un accent flottant	JUMP	10$35$:	PUSH.L	D4	LOAD.B	D4,D2		; D4 <-- accent	CALL	GETACCENT	; D3 <-- lettre accentue	POPM.L	D4	JUMP,NE 32$		; si impossible => 32$	CALL	DELSEARCH	; enlve l'accent flottant	JUMP	32$40$:				; (DEL) =>	CLR.B	D2		; D2 <-- pas d'accent en cours	CALL	DELSEARCH	JUMP	10$50$:				; (UNDO) =>	CLR.B	D2		; D2 <-- pas d'accent en cours	CALL	UNDSEARCH	JUMP	10$55$:				; (Prcdent) =>	CLR.B	D2		; D2 <-- pas d'accent en cours	LOAD.L	A0,#(A6)+OSEAST2	LOAD.B	D0,#1	CALL	UNDSEARCH	; efface/ramne la chane	CALL	AFFSEARCH	; affiche la chane de substitution	LOAD.L	A0,#(A6)+OSEAST1	CLR.B	D0	CALL	UNDSEARCH	; efface/ramne la chane	JUMP	10$60$:				; (DEFINE) =>	CLR.B	D2		; D2 <-- pas d'accent en cours	LOAD.L	A0,#(A6)+OSEAST2	TSET.L	D0:#0		; passe  la 2me chane	JUMP,BC	10$	JUMP'	85$70$:				; (a=A) =>	TNOT.L	D4:#BSEAMIMA	JUMP	10$72$:				; (Mot) =>	TNOT.L	D4:#BSEAMOT	JUMP	10$74$:				; (Cherche) =>	CLR.B	D2		; D2 <-- pas d'accent en cours	LOAD.L	A0,#(A6)+OSEAST1	CLR.B	D0	JUMP	10$76$:				; (Change) =>	CLR.B	D2		; D2 <-- pas d'accent en cours	LOAD.L	A0,#(A6)+OSEAST2	LOAD.B	D0,#1	JUMP	10$81$:	INC.W	D3		; D3 <-- touche "en avant"	TEST.L	D4:#BSEAAR	JUMP',BC 80$	SUB.W	D3,#2		; D3 <-- touche "en arrire"80$:	TEST.B	(A6)+OSEAST1	; chane de recherche existe ?	JUMP',NE 85$		; oui => 85$	TEST.B	(A6)+OSEAST2	; chane de substitution existe ?	JUMP',NE 83$		; oui => 83$				; non =>	LOAD.L	A0,#(A6)+OSEAST1	CLR.B	D0	CALL	UNDSEARCH	; ramne la chane de recherche	LOAD.L	A0,#(A6)+OSEAST2	LOAD.B	D0,#1	CALL	UNDSEARCH	; ramne la chane de substitution	TEST.B	(A6)+OSEAST1	; chane de recherche existe ?	JUMP',NE 85$		; oui => 85$83$:				; non =>	CLR.B	D2		; D2 <-- pas d'accent en cours	LOAD.L	A0,#(A6)+OSEAST1	CLR.B	D0	JUMP	20$85$:	LOAD.B	(A6)+OSEAMOD,D4	; mj tous les fanions	CALL	DBOXCLOSE	; ferme la DBOX90$:	LOAD.L	A0,#(A6)+OSEAST1	CALL	PUTSEARCH	LOAD.L	A0,#(A6)+OSEAST2	CALL	PUTSEARCH	POPM.L	D0,D1,D2,D4,D5,A0..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; INSSEARCH >;----------/; Insert un caractre dans une chane.; in	A0.L	^dbut chane;	D3.B	caractre; out	-; mod	D7.WINSSEARCH:	PUSHM.L	D4,A0	LOAD.W	D4,#MAXSEARCH-110$:	DEC.W	D4	JUMP',EQ 90$	TEST.B	(A0+)	JUMP,NE	10$	LOAD.B	(A0)-1,D3	; met le caractre	CLR.B	(A0)		; remet le terminateur90$:	POPM.L	D4,A0	RET;----------\\; DELSEARCH >;----------/; Dtruit un caractre dans une chane.; in	A0.L	^dbut chane; out	-; mod	D7.WDELSEARCH:	PUSHM.L	D4,A0	CLR.W	D410$:	INC.W	D4	TEST.B	(A0+)	JUMP,NE	10$	DEC.W	D4	JUMP',EQ 90$	CLR.B	(A0)-2		; remet le terminateur90$:	POPM.L	D4,A0	RET;----------\\; UNDSEARCH >;----------/; Dtruit/rcupre toute une chane.; in	A0.L	^dbut chane; out	-; mod	D7.WUNDSEARCH:	PUSHM.L	D4,A0	TEST.B	(A0)		; chane existante ?	JUMP',EQ 50$		; non => 50$				; oui =>	CLR.W	D410$:	INC.W	D4	TEST.B	(A0+)	JUMP,NE	10$20$:	LOAD.B	(A0),(A0)-1	; pousse la chane  droite	DEC.L	A0	DEC.W	D4	JUMP,NE	20$	CLR.B	(A0)		; puis met un terminateur au dbut	JUMP'	90$50$:	LOAD.B	(A0),(A0)+1	; pousse la chane  gauche	INC.L	A0	JUMP,NE	50$90$:	POPM.L	D4,A0	RET;----------\\; GETSEARCH >;----------/; Transforme une chane pour pouvoir l'diter.; in	A0.L	^chane  afficher; out	-; mod	-GETSEARCH:	PUSHM.L	D3,D4,A010$:	LOAD.B	D3,(A0+)	JUMP',EQ 90$	LOAD.B	D4,#CR	COMP.B	D3,#TEOL	JUMP',EQ 50$	LOAD.B	D4,#SCR	COMP.B	D3,#TEOP	JUMP',EQ 50$	LOAD.B	D4,#CCR	COMP.B	D3,#PEOP	JUMP,NE 10$50$:	LOAD.B	(A0)-1,D4	JUMP	10$90$:	POPM.L	D3,D4,A0	RET;----------\\; PUTSEARCH >;----------/; Transforme une chane pour pouvoir chercher/substituer.; in	A0.L	^chane  afficher; out	-; mod	-PUTSEARCH:	PUSHM.L	D3,D4,A010$:	LOAD.B	D3,(A0+)	JUMP',EQ 90$	LOAD.B	D4,#TEOL	COMP.B	D3,#CR	JUMP',EQ 50$	LOAD.B	D4,#TEOP	COMP.B	D3,#SCR	JUMP',EQ 50$	LOAD.B	D4,#PEOP	COMP.B	D3,#CCR	JUMP,NE 10$50$:	LOAD.B	(A0)-1,D4	JUMP	10$90$:	POPM.L	D3,D4,A0	RET;----------\\; AFFSEARCH >;----------/; Affiche la chane de recherche ou de substitution.; in	A0.L	^chane  afficher;	D0.B	0/1 => recherche/substitution; out	-; mod	D7.WAFFSEARCH:	PUSHM.L	D2..D4,A0,A3	LOAD.W	D2,#2		; D2 <-- rang chane de recherche	TEST.B	D0	JUMP',BC 10$	LOAD.W	D2,#4		; D2 <-- rang chane de substitution10$:	DBOX_	GETCO		; D3 <-- position du dbut	LIB	?SETCURS	; positionne le curseur au dbut	LIB	?AFTIM	.B	NOCURS		; plus de curseur	.B	AFTOUT		; affiche tous les codes	.B	0	.EVEN	LOAD.L	A3,A0	LOAD.W	D3,#-120$:	INC.W	D3	TEST.B	(A0+)	JUMP,NE	20$	LOAD.W	D4,#MAXSEARCH	SUB.W	D4,D3		; D4 <-- reste jusqu' la fin	LIB	?STRING		; affiche la chane	LOAD.B	D3,#AFNORM	LIB	?AFCAR		; remet le mode normal	LIB	?GETCURS	LOAD.L	D2,D3	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin de la ligne	LOAD.L	D3,D2	LIB	?SETCURS	; remet le curseur  la fin	LOAD.B	D3,#CURS	LIB	?AFCAR		; remet le curseur	POPM.L	D2..D4,A0,A3	RET;--------------\\; DBOXOCCURENCE >;==============/; Dialogue pour la DBOX du nombre d'occurence(s).; in	D4.W	nb d'occurences; out	D7.W	erreur; mod	D7.WDBOXOCCURENCE:	PUSHM.L	D1..D5,A1..A4	CLR.L	D1	LOAD.W	D1,D4	LOAD.L	A2,#R16"TDBOX_OCCURENCE	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE 90$	LOAD.W	D2,#1	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,D1		; D4 <-- nombre	LOAD.W	D3,#8		; D3 <-- nb max de digits	LOAD.W	D2,#2^BAFDCM!2^BAFDSP	LIB	?AFDEC		; affiche le nombre10$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OK	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	10$		; oui => 10$	COMP.W	D3,#CR		; ok ?	JUMP',EQ 80$		; oui => 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	10$80$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXCHERCHE >;============/; Dialogue pour la DBOX de confirmation de recherche.; in	-; out	D3.W	rponse;	D7.W	erreur; mod	D3.L, D7.WDBOXCHERCHE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.W	D3,(A6)+OXWDT	SR.W	D3,#1		; D3 <-- au milieu en X	SWAP.W	D3	LOAD.W	D3,(A5)+OCURS+0	; D3 <-- position Y du curseur	LOAD.W	D2,(A6)+OCYI	; D2 <-- hauteur des infos	ADD.W	D3,D2		; D3 <-- position Y du curseur dans swdo principale	LOAD.W	D4,(A6)+OCY	MUL.WU	D4,#5+1		; D4 <-- hauteur de la dbox + une ligne	ADD.W	D3,D4	SR.W	D4,#1		; D4 <-- hauteur de la dbox /2	ADD.W	D2,(A6)+OYWDT	; D2 <-- tout en bas	COMP.W	D3,D2		; dpasse en bas ?	JUMP',HS 10$		; oui => 10$				; met la dbox en dessous =>	SUB.W	D3,D4	JUMP'	20$10$:				; met la dbox en dessus =>	LOAD.W	D3,(A5)+OCURS+0	; D3 <-- position Y du curseur	SUB.W	D3,D4	JUMP',NC 20$	CLR.W	D320$:	SWAP.W	D3	LOAD.L	A2,#R16"TDBOX_CHERCHE	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV!2^BDBPOS ; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE 90$30$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	JUMP',NE 50$		; touche inconnue => 50$	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	30$		; oui => 30$	JUMP'	80$		; non => 80$50$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	30$80$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCHANGE >;===========/; Dialogue pour la DBOX de confirmation de changement.; in	-; out	D3.W	rponse;	D7.W	erreur; mod	D3.L, D7.WDBOXCHANGE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.W	D3,(A6)+OXWDT	SR.W	D3,#1		; D3 <-- au milieu en X	SWAP.W	D3	LOAD.W	D3,(A5)+OCURS+0	; D3 <-- position Y du curseur	LOAD.W	D2,(A6)+OCYI	; D2 <-- hauteur des infos	ADD.W	D3,D2		; D3 <-- position Y du curseur dans swdo principale	LOAD.W	D4,(A6)+OCY	MUL.WU	D4,#10+1	; D4 <-- hauteur de la dbox + une ligne	ADD.W	D3,D4	SR.W	D4,#1		; D4 <-- hauteur de la dbox /2	ADD.W	D2,(A6)+OYWDT	; D2 <-- tout en bas	COMP.W	D3,D2		; dpasse en bas ?	JUMP',HS 10$		; oui => 10$				; met la dbox en dessous =>	SUB.W	D3,D4	JUMP'	20$10$:				; met la dbox en dessus =>	LOAD.W	D3,(A5)+OCURS+0	; D3 <-- position Y du curseur	SUB.W	D3,D4	JUMP',NC 20$	CLR.W	D320$:	SWAP.W	D3	LOAD.L	A2,#R16"TDBOX_CHANGE	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV!2^BDBPOS ; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE 90$30$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_CHG	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	JUMP',NE 50$		; touche inconnue => 50$	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	30$		; oui => 30$	JUMP'	80$		; non => 80$50$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	30$80$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXFRAPPE >;===========/; Dialogue pour la DBOX du choix de la frappe.; in	-; out	D7.W	erreur; mod	D7.WDBOXFRAPPE:	PUSHM.L	D1..D5,A1..A4	LOAD.L	D4,(A6)+OFAFR	; D4 <-- fanions	JUMP',NE 05$	LOAD.L	D4,#2^1		; D4 <-- met le fanion par dfaut05$:	LOAD.L	A2,#R16"TDBOX_FRAPPE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	CLR.W	D212$:	CALL	DBFRAFN		; affiche un nom	INC.W	D2		; D2 <-- no nom suivant	COMP.W	D2,#MAXGC	JUMP,LO	12$20$:	LOAD.L	D2,D4		; D2 <-- anciens fanions	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_FRAPPE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; frappe ?	JUMP,EQ 70$	COMP.W	D3,#END		; annule ?	JUMP,EQ 80$	LOAD.L	A1,#R16"00$	COMP.W	D3,#F1	JUMP',EQ 40$	COMP.W	D3,#F2	JUMP',LO 30$	COMP.W	D3,#F5	JUMP',LS 50$	COMP.W	D3,#F15	JUMP',LS 60$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; (F1) environnant =>	LOAD.L	D4,#2^1	JUMP	20$50$:				; (F2)..(F5) mode =>	SUB.W	D3,#F0	SL.W	D3,#1	LOAD.W	D4,(A1)+(D3.W)	; D4 <-- bit correspondant	AND.W	D2,#B'1111111111000000	JUMP',NE 52$	LOAD.W	D2,#2^6		; D2 <-- caractre Fond52$:	OR.W	D4,D2	JUMP	20$60$:				; (F6)..(F15) caractre =>	SUB.W	D3,#F0	SL.W	D3,#1	LOAD.W	D4,(A1)+(D3.W)	; D4 <-- bit correspondant	CALL	DBFRGPT		; A4 <-- ^dans OBUGC	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BS 61$		; oui => 61$	LOAD.L	D4,D2		; non => reprend les anciens fanions	JUMP	30$61$:	AND.W	D2,#B'0000000000111100	JUMP',NE 62$	LOAD.W	D2,#2^2		; D2 <-- mode normal62$:	OR.W	D4,D2	JUMP	20$70$:				; FRAPPE =>	LOAD.L	(A6)+OFAFR,D4	; mm. derniers fanions utiliss80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.W	B'0000000000000001	.W	B'0000000000000010	.W	B'0000000000000100	.W	B'0000000000001000	.W	B'0000000000010000	.W	B'0000000000100000	.W	B'0000000001000000	.W	B'0000000010000000	.W	B'0000000100000000	.W	B'0000001000000000	.W	B'0000010000000000	.W	B'0000100000000000	.W	B'0001000000000000	.W	B'0010000000000000	.W	B'0100000000000000	.W	B'1000000000000000;--------\\; DBFRGPT >;--------/; Donne le pointeur dans OBUGC en fonction des fanions.; in	D4.L	fanions; out	A4.L	^dans OBUGC; mod	D7.W, A4.LDBFRGPT:	PUSHM.L	D2,D4	CLR.W	D2	SR.L	D4,#610$:	SR.L	D4,#1	JUMP',CS 20$	INC.W	D2	JUMP	10$20$:	LOAD.L	A4,#(A6)+OBUGC	MUL.WU	D2,#LGGC	ADD.L	A4,D2		; A4 <-- ^dans OBUGC	POPM.L	D2,D4	RET;--------\\; DBFRAFN >;--------/; Affiche un nom dans la dbox.; in	D2.W	rang du nom (0..n); out	-; mod	D7.WDBFRAFN:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,#(A6)+OBUGC	LOAD.W	D4,D2	MUL.WU	D4,#LGGC	ADD.L	A4,D4		; A4 <-- ^dans OBUGC	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP',BC 90$	SL.W	D2,#1		; D2 <-- *2 car deux colonnes	ADD.W	D2,#2		; D2 <-- +2 pour sauter 1er texte + 1re colonne	DBOX_	GETCO		; D3/D4 <-- position dbut/fin	LOAD.W	D4,(A6)+OCX	MUL.WU	D4,#3	ADD.W	D3,D4		; D3 <-- saute le cercle	LIB	?SETCURS	; positionne au dbut	LOAD.L	A3,#(A4)+OGCTIT	LIB	?AFTEXT		; affiche le nom90$:	POPM.L	D2..D4,A3,A4	RET;---------\\; DBOXZONE >;=========/; Dialogue pour la DBOX du choix de la zone.; in	-; out	D0.W	no zone principale;	D1.W	no zone secondaire;	D3.W	touche (RETURN) ou (END);	D7.W	erreur; mod	D0.L, D1.L, D3.L, D7.WDBOXZONE:	PUSHM.L	D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_ZONE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	CLR.W	D312$:	CALL	DBZNAFN		; affiche une zone	INC.W	D3		; D3 <-- no zone suivante	COMP.W	D3,#NBBF/2	JUMP,LO	12$	LOAD.W	D0,(A5)+ONOBUF	LOAD.W	D1,#NBBF/2	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE	JUMP',BS 14$	LOAD.W	D1,(A6)+OBUFS+ONOBUF14$:	LOAD.W	D3,D0	TCLR.L	D3:#16	CALL	DBZNAFR		; met rectangle zone principale	LOAD.W	D3,D1	TSET.L	D3:#16	CALL	DBZNAFR		; met rectangle zone secondaire20$:	CLR.L	D4		; D4 <-- fanions	DBOX_	EDIT		; attend une action ...	PUSH.W	D1	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.W	D1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#KEYMGP	; bouton souris press ?	JUMP',EQ 40$		; oui => 40$	COMP.W	D3,#CR		; ok ?	JUMP,EQ 80$	COMP.W	D3,#END		; annule ?	JUMP,EQ 80$	COMP.W	D3,#'0	JUMP',LO 30$	COMP.W	D3,#'9	JUMP,LS 70$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; bouton souris press =>	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 30$	CALL	DBZNDET		; D3 <-- no zone o est la souris	JUMP,NE 30$	LOAD.W	D2,D3		; D2 <-- no zone o est la souris	TCLR.L	D2:#16	COMP.W	D3,D0		; est-on dans la zone principale ?	JUMP',EQ 50$		; oui => 50$	TSET.L	D2:#16	COMP.W	D3,D1		; est-on dans la zone secondaire ?	JUMP,NE 30$		; non => 30$50$:				; oui =>	LIB	?GETKEY	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE 55$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 50$	CALL	DBZNDET		; D3 <-- no zone o est la souris	JUMP,NE 50$	COMP.W	D3,D2		; est-on toujours dans la mme zone ?	JUMP,EQ 50$		; oui => 50$	TEST.L	D2:#16	JUMP',BS 52$	COMP.W	D3,D1		; est-on sur la zone secondaire ?	JUMP,EQ 50$		; oui => 50$	COMP.W	D3,#NBBF/2	; est-on sur la zone sec. inutilise ?	JUMP,EQ 50$		; oui => 50$	JUMP'	53$52$:	COMP.W	D3,D0		; est-on sur la zone principale ?	JUMP,EQ 50$		; oui => 50$53$:	EX.L	D3,D2	CALL	DBZNAFR		; efface l'ancien rectangle	SWAP.W	D3	SWAP.W	D2	LOAD.W	D2,D3		; D2 <-- met bit :#16 de D3	SWAP.W	D2	LOAD.L	D3,D2	CALL	DBZNAFR		; dessine nouveau rectangle	JUMP	50$55$:	TEST.L	D2:#16	JUMP',BS 57$	LOAD.W	D0,D2		; D0 <-- nouvelle zone principale	JUMP	20$57$:	LOAD.W	D1,D2		; D1 <-- nouvelle zone secondaire	JUMP	20$70$:				; (0)..(9) =>	SUB.W	D3,#'0	LOAD.W	D0,D3		; D0 <-- no zone principale choisie	LOAD.W	D1,#NBBF/2	; D1 <-- pas de zone secondaire	LOAD.W	D3,#CR		; D3 <-- comme si ok (RETURN)80$:				; (OK) ou (ANNULE) =>	CLR.W	D7		; D7 <-- ok	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBZNAFN >;--------/; Affiche une zone dans la dbox.; in	D3.W	numro de la zone; out	-; mod	D7.WDBZNAFN:	PUSHM.L	D1..D4,A3..A5	LOAD.W	D1,D3		; D1 <-- no zone	LOAD.L	A4,#(A6)+OPTFB	LOAD.W	D4,D3	INC.W	D4	MUL.WU	D4,#LGPC	SUB.L	A4,D4		; A4 <-- ^description zone compactifie	SL.W	D3,#1		; D3 <-- premire colonne (0,2,4,6,8)	COMP.W	D3,#NBBF/2	JUMP',LO 20$	SUB.W	D3,#(NBBF/2)-1	; D3 <-- deuxime colonne (1,3,5,7,9)20$:	SL.W	D3,#1		; D3 <-- *2 car ODBBOX et ODBTEXT	INC.W	D3		; D3 <-- +1 pour dbut ODBTEXT	LOAD.W	D2,D3	DBOX_	GETCO		; D3/D4 <-- position dbut/fin	LIB	?SETCURS	; positionne au dbut	LOAD.L	D4,(A4)+LGPC	SUB.L	D4,(A4)+OPCD	; D4 <-- taille	LOAD.L	A3,#(A4)+OPCZ+OBUMEMF	COMP.W	D1,(A5)+ONOBUF	; zone principale ?	JUMP',EQ 40$		; oui => 40$	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE	JUMP',BS 50$	LOAD.L	A5,#(A6)+OBUFS	COMP.W	D1,(A5)+ONOBUF	; zone secondaire ?	JUMP',NE 50$		; non => 50$40$:				; oui =>	LOAD.L	D4,(A5)+OPDT	SUB.L	D4,(A5)+OPDB	LOAD.L	D3,(A5)+OPFB	SUB.L	D3,(A5)+OPFT	ADD.L	D4,D3		; D4 <-- taille	LOAD.L	A3,#(A5)+OBUMEMF50$:	TEST.L	D4	JUMP',EQ 60$	LOAD.B	D3,#5		; D3 <-- nb digits	LOAD.B	D2,#2^BAFDSP	; D2 <-- mode (' tous les 3 digits)	LIB	?AFDEC		; affiche la taille	JUMP'	70$60$:	LIB	?AFTIM	.ASCIZ	"  vide"	.EVEN70$:	LIB	?AFSPACE	TEST.B	(A3)		; nom de fichier existe ?	JUMP',EQ 90$		; non => 90$	LOAD.W	D4,#24-(6+1+1)80$:	LOAD.B	D3,(A3+)	JUMP',EQ 90$	COMP.B	D3,#CR	JUMP',EQ 90$	CALL	MAJMIN		; D3 <-- lettre minuscule	LIB	?AFCAR		; affiche une lettre	DEC.W	D4		; encore de la place ?	JUMP,NE 80$		; oui => 80$90$:	POPM.L	D1..D4,A3..A5	RET;--------\\; DBZNDET >;--------/; Dtecte dans quelle zone est la souris.; in	D4.L	coordonne souris; out	D3.W	numro de la zone;	D7.W	erreur; mod	D3.L, D7.WDBZNDET:	PUSHM.L	D0,D1,D2,D4,A4	LOAD.L	A4,(A6)+ODISPS	; A4 <-- ^status	CALL	WDOMOUSE	; D4 <-- coordonne dans swdo	JUMP,NE 90$	LOAD.L	D0,D4	CLR.W	D1		; D1 <-- zones 0..4	LOAD.W	D2,#1	DBOX_	GETCO		; D3/D4 <-- dbut/fin 1re colonne	LOAD.W	D7,#1		; D7 <-- pas trouv	COMP.W	D0,D3	JUMP,LO 90$	COMP.W	D0,D4	JUMP,LO 30$	LOAD.W	D1,#5		; D1 <-- zones 5..9	LOAD.W	D2,#3	DBOX_	GETCO		; D3/D4 <-- dbut/fin 2me colonne	LOAD.W	D7,#1		; D7 <-- pas trouv	LOAD.W	D2,(A4)+ODFCX	MUL.WU	D2,#5		; D3 <-- recule ( gauche) dans ODBBOX	SUB.W	D3,D2		;  cause de "Zone sec. inutilise" !	COMP.W	D0,D3	JUMP,LO 90$	COMP.W	D0,D4	JUMP,HS 90$30$:	CLR.W	D0	SWAP.W	D0	SWAP.W	D3	SUB.W	D3,(A4)+ODFC1Y	SUB.W	D3,(A4)+ODFC2Y	SUB.W	D3,#2		; D3 <-- haut 1re case	SUB.W	D0,D3		; souris trop haute ?	JUMP',LO 90$		; oui => 90$	LOAD.W	D3,(A4)+ODFCY	SL.W	D3,#1		; D3 <-- hauteur entre deux ODBBOX	DIV.WU	D0,D3	SWAP.W	D0	LOAD.W	D3,(A4)+ODFC2Y	SL.W	D3,#1	ADD.W	D3,(A4)+ODFC1Y	ADD.W	D3,#2+2		; D3 <-- hauteur totale ODBBOX	COMP.W	D0,D3	JUMP',HS 90$	SWAP.W	D0	COMP.W	D0,#5	JUMP',EQ 60$	JUMP',HI 90$	ADD.W	D1,D0	LOAD.W	D3,D1		; D3 <-- no zone	JUMP'	80$60$:	COMP.W	D1,#5		; est-on dans la 2me colonne	JUMP',NE 90$		; non => 90$	LOAD.W	D3,#NBBF/2	; D3 <-- on est dans "Zone sec. inutilise"80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1,D2,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBZNAFR >;--------/; Inverse un rectangle quelconque.; in	D3.W	numro de la zone;	D3:#16	0 => zone principale, 1 => zone secondaire; out	-; mod	D7.WDBZNAFR:	PUSHM.L	D1..D4,A4	LOAD.L	D1,D3		; D1 <-- no zone	LOAD.W	D2,#(NBBF/2)*2	; D2 <-- rang pour "Zone sec. inutilise"	COMP.W	D3,#NBBF/2	; zone sec. inutilise ?	JUMP',EQ 25$		; oui => 25$				; non =>	SL.W	D3,#1		; D3 <-- premire colonne (0,2,4,6,8)	COMP.W	D3,#NBBF/2	JUMP',LO 20$	SUB.W	D3,#(NBBF/2)-1	; D3 <-- deuxime colonne (1,3,5,7,9)20$:	SL.W	D3,#1		; D3 <-- *2 car ODBBOX et ODBTEXT	INC.W	D3		; D3 <-- +1 pour dbut ODBTEXT	LOAD.W	D2,D325$:	DBOX_	GETCO		; D3/D4 <-- position dbut/fin	LIB	?SETCURS	; positionne au dbut	LOAD.W	D2,#INVDOT	TEST.L	D1:#16	JUMP',BC 40$	LIB	?AFTIM	.B	MAPTT	.B	B'01010101	; map traitill	.B	1		; chelle	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT40$:	LOAD.L	A4,(A6)+ODISPS	; A4 <-- ^status	SUB.W	D3,#2	SWAP.W	D3	SUB.W	D3,(A4)+ODFC1Y	SUB.W	D3,(A4)+ODFC2Y	SUB.W	D3,#2	SWAP.W	D3	SUB.W	D4,D3	SUB.W	D4,(A4)+ODFCX	; D4 <-- largeur moins un caractre	ADD.W	D4,#2	SWAP.W	D4	LOAD.W	D4,(A4)+ODFC1Y	ADD.W	D4,(A4)+ODFC2Y	ADD.W	D4,(A4)+ODFC2Y	ADD.W	D4,#2+2	SWAP.W	D4	LIB	?DRRECT		; trace rectangle plein/traitill	POPM.L	D1..D4,A4	RET;----------\\; DBOXPRINT >;==========/; Dialogue avant l'impression.; in	-; out	D3.W	ok/annule;	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXPRINT:	PUSHM.L	D1,D2,A1..A4	LOAD.L	A2,#R16"TDBOX_PRINT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OFANION	; D4 <-- fanions	COMP.W	(A5)+ONOBUF,#NBBF/2	JUMP',LO 10$	TCLR.L	D4:#BFACOU10$:	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	PUSH.L	D4	LOAD.L	A1,(A6)+ODISPS	; A1 <-- ^status	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	CLR.W	D3	SWAP.W	D3	SUB.W	D3,(A1)+ODFC1Y	SUB.W	D3,(A1)+ODFCY	SUB.W	D3,#2	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A1)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	CLR.W	D3	SWAP.W	D3	ADD.W	D3,(A1)+ODFC2Y	ADD.W	D3,(A1)+ODFCY	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A1)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG	LOAD.W	D2,#0!2^BDBGCLABEL	DBOX_	GETCO	LOAD.W	D4,(A1)+ODFCX	MUL.WU	D4,#16	LOAD.W	D3,D4	SWAP.W	D3	SUB.W	D3,(A1)+ODFC1Y	SUB.W	D3,#2	SWAP.W	D3	LOAD.W	D4,#+5	SWAP.W	D4	LOAD.W	D4,#-5	LOAD.W	D2,#SETDOT	LIB	?DRSEG	LOAD.W	D4,(A1)+ODFCY	MUL.WU	D4,#3	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	LOAD.W	D4,#+5	SWAP.W	D4	LOAD.W	D4,#-5	LIB	?DRSEG	LOAD.W	D4,#+5	SWAP.W	D4	LOAD.W	D4,#+5	LIB	?DRSEG	LOAD.W	D4,(A1)+ODFCY	MUL.WU	D4,#3	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	LOAD.W	D4,#+5	SWAP.W	D4	LOAD.W	D4,#+5	LIB	?DRSEG	POP.L	D4	LOAD.W	D2,#1	CALL	DBPRIGLI	; affiche "numro"	INC.W	D2	CALL	DBPRIGLI	; affiche "caractre"	INC.W	D2	CALL	DBPRIGLI	; affiche ".FICHE"	CLR.W	D2		; D2 <-- rang initial20$:	CALL	DBPRIGLI	; A3 <-- ^dbut, A4 <-- ^fin22$:	LOAD.W	D3,D2	DBOX_	MEDIT	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,A326$:	TEST.B	(A1)	JUMP',EQ 27$	COMP.B	(A1+),#CR	JUMP,NE 26$	CLR.B	(A1)-1		; remplace <CR> par <0>27$:	LOAD.L	A1,#R16"TKEY_OKANNCR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	22$		; oui => 22$	COMP.W	D3,#KEYDBOX+BFANUM	JUMP,EQ 46$	COMP.W	D3,#KEYDBOX+BFACOU	JUMP,EQ 47$	COMP.W	D3,#KEYDBOX+BFAENG	JUMP,EQ 50$	COMP.W	D3,#KEYDBOX+BFAENC	JUMP,EQ 50$	COMP.W	D3,#KEYDBOX+BFAEND	JUMP,EQ 50$	COMP.W	D3,#KEYDBOX+BFANUG	JUMP,EQ 52$	COMP.W	D3,#KEYDBOX+BFANUC	JUMP,EQ 52$	COMP.W	D3,#KEYDBOX+BFANUD	JUMP,EQ 52$	COMP.W	D3,#KEYDBOX+102	; clic dans choix du caractre ?	JUMP,EQ 44$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	; clic dans rectangle ditable ?	JUMP',EQ 40$	COMP.W	D3,#CR		; suivant ?	JUMP',EQ 42$	COMP.W	D3,#F1		; ok ?	JUMP,EQ 70$	COMP.W	D3,#END		; annule ?	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP',EQ 35$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	22$35$:				; (UNDO) =>	CLR.B	(A3)	LOAD.L	A4,A3	JUMP	22$40$:	CALL	DBPRIPLI	; sauve la ligne en dition	JUMP,NE 30$	LOAD.B	D2,D3	SUB.B	D2,#100		; D2 <-- nouveau rang	JUMP	20$42$:	CALL	DBPRIPLI	; sauve la ligne en dition	JUMP,NE 30$	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,#4	JUMP,LO 20$	CLR.W	D2	JUMP	20$44$:	CALL	DBPRIPLI	; sauve la ligne en dition	PUSHM.L	D4,D5	LIB	?GETWDO	LOAD.W	D1,D5		; D1 <-- no swdo de la dbox	POPM.L	D4,D5	CALL	MENUGC		; D3 <-- no du gencar choisi	PUSHM.L	D5,D7	LOAD.W	D5,D1	LIB	?USEWDO		; r-utilise la swdo de la dbox !	POPM.L	D5,D7	TEST.W	D7	JUMP,NE 30$	COMP.W	D3,#-1	JUMP,EQ 22$	LOAD.L	A1,#(A6)+OBUGC	; A1 <-- ^buffer des gencars	MUL.WU	D3,#LGGC	ADD.L	A1,D3		; A4 <-- ^gencar choisit	TEST.B	(A1)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP,BC 30$		; non => 30$	LOAD.L	A1,#(A1)+OGCTIT	LOAD.L	A4,#(A6)+ODFNGC45$:	LOAD.B	(A4+),(A1+)	; prend le titre du gencar	JUMP,NE 45$	LOAD.W	D2,#2		; D2 <-- case "caractre"	JUMP	20$46$:				; clic dans BFANUM =>	CLR.W	D2	JUMP	20$47$:				; clic dans BFACOU =>	COMP.W	(A5)+ONOBUF,#NBBF/2	JUMP',LO 48$	TCLR.L	D4:#BFACOU	JUMP	30$48$:	TEST.L	D4:#BFACOU	JUMP,BC 22$	LOAD.W	D2,#3	JUMP	20$50$:	CALL	DBPRIPLI	; sauve la ligne en dition	JUMP,NE 30$	CLR.W	D2	AND.L	D4,#-1-(2^BFAENG!2^BFAENC!2^BFAEND)	TSET.L	D4:D3	ADD.B	D3,#3	TCLR.L	D4:D3	JUMP,BC 20$	INC.B	D3	COMP.B	D3,#BFANUD	JUMP',LS 51$	LOAD.B	D3,#BFANUG51$:	TSET.L	D4:D3	JUMP	20$52$:	CALL	DBPRIPLI	; sauve la ligne en dition	JUMP,NE 30$	LOAD.W	D2,#1	AND.L	D4,#-1-(2^BFANUG!2^BFANUC!2^BFANUD)	TSET.L	D4:D3	SUB.B	D3,#3	TCLR.L	D4:D3	JUMP,BC 20$	INC.B	D3	COMP.B	D3,#BFAEND	JUMP',LS 53$	LOAD.B	D3,#BFAENG53$:	TSET.L	D4:D3	JUMP	20$70$:				; IMPRIME =>	CALL	DBPRIPLI	; sauve la ligne en dition	JUMP,NE 30$	TEST.L	D4:#BFACOU	JUMP',BC 72$	TEST.B	(A6)+OPRNFI	; nom .FICHE existe ?	JUMP,EQ 30$		; non => 30$72$:	TSET.B	(A5)+OSTATUS:#BFILMOD ; fichier pas  jour	LOAD.L	D2,D4		; D2 <-- nouveaux fanions	COMP.L	D2,(A6)+OFANION	; fanion(s) modifi(s) ?	JUMP',EQ 78$		; non => 78$	LOAD.L	D3,(A6)+OFANION	; D3 <-- anciens fanions	LOAD.L	(A6)+OFANION,D2	; mj tous les fanions	XOR.L	D2,D3		; D2 <-- fanions modifis	TEST.L	D2:#BFANUM	; "numrotation automatique" modifie ?	JUMP',BC 78$		; non => 78$				; oui =>	TSET.B	(A5)+OSTATUS:#BEOPMOD78$:	LOAD.W	D3,#F180$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBPRIGLI >;---------/; Prpare une ligne pour l'diter, et affiche-la.; in	D2.W	rang;	D5.L	canal DBOX; out	A3.L	^dbut;	A4.L	^fin; mod	D7.W, A3.L, A4.LDBPRIGLI:	PUSHM.L	D0..D4,A2	LOAD.L	A3,#(A6)+OBUTEMP	LOAD.L	A4,A3	LOAD.W	D0,#-1	LOAD.L	A2,#(A6)+ODFNEN	TEST.W	D2	JUMP',EQ 20$	LOAD.L	A2,#(A6)+ODFNUM	COMP.W	D2,#1	JUMP',EQ 20$	LOAD.L	A2,#(A6)+ODFNGC	COMP.W	D2,#2	JUMP',EQ 20$	LOAD.L	A2,#(A6)+OPRNFI20$:	INC.W	D0		; D0 <-- nb de caractres	LOAD.B	(A4+),(A2+)	; buffer <-- texte	JUMP,NE 20$	DEC.L	A4	LOAD.W	D1,#LDFNUM-2	; D1 <-- lg max	TEST.W	D2	JUMP',EQ 40$;	LOAD.W	D1,#LDFNUM-2	; D1 <-- lg max	COMP.W	D2,#1	JUMP',EQ 40$	LOAD.W	D1,#16		; D1 <-- lg max40$:	TSET.L	D2:#BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	; positionne le curseur	LOAD.L	A2,A3	LIB	?AFTEXT		; affiche le texte	LOAD.L	A3,A2	SUB.W	D1,D0		; D1 <-- reste  effacer	JUMP',LE 90$	LOAD.B	D3,#MSPACE	LIB	?AFCAR		; efface la fin de la ligne	LOAD.B	D3,D1	LIB	?AFCAR90$:	POPM.L	D0..D4,A2	RET;---------\\; DBPRIPLI >;---------/; Sauve une ligne dite.; in	D2.W	rang;	A3.L	^ligne; out	D7.W	erreur; mod	D7.WDBPRIPLI:	PUSHM.L	D3,A3,A4	LOAD.L	A4,#(A6)+ODFNEN	TEST.W	D2	JUMP',EQ 20$	LOAD.L	A4,#(A6)+ODFNUM	COMP.W	D2,#1	JUMP',EQ 20$	LOAD.L	A4,#(A6)+ODFNGC	COMP.W	D2,#2	JUMP',EQ 20$	LOAD.L	A4,#(A6)+OPRNFI20$:	LOAD.B	(A4+),(A3+)	JUMP,NE 20$	POPM.L	D3,A3,A4	CLR.W	D7		; retour EQ	RET;------------\\; DBOXMAILING >;============/; Dialogue avant l'impression en mode courrier personnalis.; in	D6.W	canal .FICHE; out	D3.W	imprime/vrifie/annule;	D4.L	clef d'accs;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXMAILING:	PUSHM.L	D1,D2,A1..A4	LOAD.L	A2,#R16"TDBOX_MAILING	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,#B'00001	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	PUSH.L	D4	LOAD.L	A1,(A6)+ODISPS	; A1 <-- ^status	CLR.W	D1		; D1 <-- rang10$:	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^buffer	LOAD.W	D3,#LBUDIS	; D3 <-- lg buffer	FICHE_	LITTRI		; OBUDIS <-- nom du critre de tri	JUMP,NE 18$	LOAD.W	D2,D1	TSET.L	D2:#15	DBOX_	GETCO		; D3 <-- coordonne	ADD.W	D3,(A1)+ODFCX	ADD.W	D3,(A1)+ODFCX	ADD.W	D3,(A1)+ODFCX	LIB	?SETCURS	; positionne le curseur	LOAD.L	A4,A3	LOAD.W	D3,#-114$:	INC.W	D3		; D3 <-- lg du nom du critre	COMP.B	(A4+),#SPACE	JUMP,NE 14$	LIB	?STRING		; affiche le nom du critre	INC.W	D1		; D1 <-- rang suivant	COMP.W	D1,#18	JUMP,LO	10$18$:	POP.L	D420$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; imprime ?	JUMP',EQ 70$	COMP.W	D3,#F4		; vrifie ?	JUMP',EQ 70$	COMP.W	D3,#END		; annule ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:				; IMPRIME =>	LOAD.L	D1,D4	LOAD.L	D4,#H'000000FF72$:	INC.B	D4	RR.L	D1,#1	JUMP,CC 72$	RR.L	D4,#8		; D4 <-- clef d'accs80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXGOTO >;=========/; Dialogue pour aller au dbut d'une page.; in	-; out	D3.W	ok/annule;	D4.W	numro de la page o aller (1..n);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXGOTO:	PUSHM.L	D1,D2,A1..A4	LOAD.L	A2,#R16"TDBOX_GOTO	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A3,#(A6)+OBUTEMP	CLR.B	(A3)		; donne un numro vide	LOAD.L	A4,A320$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; ok ?	JUMP,EQ 70$	COMP.W	D3,#END		; annule ?	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP',EQ 35$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$35$:				; (UNDO) =>	CLR.B	(A3)	LOAD.L	A4,A3	JUMP	20$70$:				; VA =>	TEST.B	(A3)		; nombre existe ?	JUMP,EQ 30$		; non => 30$	COMP.B	(A3),#CR	JUMP,EQ 30$	CALL	DBOXGETN	; D3 <-- nombre	JUMP,NE 30$	CALL	GIVPNUM		; D4 <-- numro de la premire page	COMP.W	D3,D4	JUMP',HS 75$	LOAD.W	D3,D4	LOAD.L	A4,A3	CALL	DBOXPUTN	; buffer <-- 1er numro possible	EX.L	A3,A4	JUMP	30$75$:	SUB.W	D3,D4	INC.W	D3	LOAD.W	D4,D3		; D4 <-- page relative o aller	LOAD.W	D3,#CR80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.END