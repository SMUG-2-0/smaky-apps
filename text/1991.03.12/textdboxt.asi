	.SBTTL	TEXTDBOXT;---------\\; DBOXPREF >;---------/; Travaille dans une DBOX prfabrique en sauvant si possible; le dessous.; in	voir DBOX_EXTEND; out	idem; mod	idemDBOXPREF:	PUSH.W	D2	CALL	CWMO		; souris: plus de sablier	TCLR.B	(A6)+OFLAGS:#BMDBOX	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	DBOX_	EXTEND		; travaille dans la DBOX ...	JUMP',EQ 80$		; ok => 80$	TCLR.L	D2:#BDBSAV	; essaye sans sauver	DBOX_	EXTEND		; travaille dans la DBOX ...	JUMP',NE 90$		; erreur => 90$	TSET.B	(A6)+OFLAGS:#BMDBOX80$:	CALL	DBOXREFAIT	; refait v. le dessous90$:	POP.W	D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXOPEN >;---------/; Ouvre une DBOX en sauvant si possible le dessous.; in	voir DBOX_OPEN; out	idem; mod	idemDBOXOPEN:	PUSH.W	D2	CALL	CWMO		; souris: plus de sablier	TCLR.B	(A6)+OFLAGS:#BMDBOX	DBOX_	OPEN		; ouvre la DBOX	JUMP',EQ 90$		; ok => 90$	TCLR.L	D2:#BDBSAV	; essaye sans sauver	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE 90$		; erreur => 90$	TSET.B	(A6)+OFLAGS:#BMDBOX90$:	POP.W	D2	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXCLOSE >;----------/; Ferme une DBOX en redessinant tout l'cran si le dessous; n'a pas pu tre sauv.; in	voir DBOX_CLOSE; out	idem; mod	idemDBOXCLOSE:	TEST.L	D5		; dbox ouverte ?	JUMP',NE 50$		; oui => 50$	RET			; non => ne fait rien !50$:	DBOX_	CLOSE		; ferme la DBOXDBOXREFAIT:	TEST.B	(A6)+OFLAGS:#BMDBOX	JUMP',BC 50$	PUSH.W	D4	LOAD.W	D4,#MODALL	CALL	MODIF		; faut tout repeindre	POP.W	D4	CALL	AFFBUF		; redessine le texte50$:	LIB	?AFTIM	.B	NOCURS,0	; supprime le curseur	.EVEN	CALL	AFMENU		; remet soft-keys standards	CLR.W	D7		; D7 <-- ok	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXPUTN >;---------/; Construit un nombre en ASCII.; in	D3.W	nombre;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LDBOXPUTN:	PUSHM.L	D2..D4	CLR.L	D4	LOAD.W	D4,D3	LIB	?BINBCD		; D4 <-- nombre en BCD	LOAD.L	D2,#8-1		; D2 <-- nb max de digits20$:	RL.L	D4,#4	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- digit 0..9	JUMP',NE 30$	TEST.W	D2		; dernier digit ?	JUMP',EQ 30$		; oui => 30$	TEST.L	D2:#16	JUMP',BC 50$30$:	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- un digit	TSET.L	D2:#1650$:	DECJ.W,NMO D2,20$	CLR.B	(A3)		; buffer <-- terminateur	POPM.L	D2..D4	RET;---------\\; DBOXGETN >;---------/; Lit un nombre ASCII.; in	A3.L	^nombre; out	D3.W	nombre; mod	D3.L, D7.WDBOXGETN:	PUSHM.L	D4,A3	LOAD.W	D7,#1		; D7 <-- nombre incorrect	CLR.L	D3		; D3 <-- futur nombre10$:	CLR.W	D4	LOAD.B	D4,(A3+)	JUMP',EQ 40$	COMP.B	D4,#CR	JUMP',EQ 40$	COMP.B	D4,#'0	JUMP',LO 90$	COMP.B	D4,#'9	JUMP',HI 90$	SUB.B	D4,#'0	MUL.WU	D3,#10	ADD.W	D3,D4	JUMP	10$40$:	CLR.W	D7		; D7 <-- nombre ok90$:	POPM.L	D4,A3	RET;--------\\; DOK...  >;========/DOKOUI:	LOAD.W	D3,#'O	RETDOKNON:	LOAD.W	D3,#'N	RETDOKOK:	LOAD.W	D3,#CR	RETDOKDEF:	LOAD.W	D3,#DEFINE	RETDOKANNULE:	LOAD.W	D3,#END	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RET; Tables pour DBOX; ----------------TDBOX_FAN:	.B	LDBOX_FAN	.B	ODBLCIRCLE,BIOBOA	.ASCIZ	" le document entier"	.B	ODBCR	.B	ODBLCIRCLE,BIONOBOA	.ASCIZ	" le texte seul"	.B	ODBCRLDBOX_FAN	=	.-TDBOX_FAN-1TDBOX_SURE:	.W	10$-TDBOX_SURE	.W	MENU_OUINON-TDBOX_SURE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Etes-vous sr ?"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,'O,TDBNORM	.ASCIZ	"   OUI   "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,'N,TDBMEV	.ASCIZ	"   NON   "	.B	0	.EVENTDBOX_IMAGE:	.W	10$-TDBOX_IMAGE	.W	MENU_COAN-TDBOX_IMAGE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	" Nom de l'image  coller :"	.B	ODBCR,ODBCR	.B	ODBFILE,32	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	"LISTE"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" COLLE "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	" ANNULE "	.B	0	.EVENTDBOX_DEFINE:	.W	10$-TDBOX_DEFINE	.W	MENU_OKAN-TDBOX_DEFINE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Affiche les :"	.B	ODBCR,ODBCR	.B	ODBSQUARE,BFAIMA	.ASCIZ	" images"	.B	ODBTABX,26	.B	ODBSQUARE,BFASCH	.ASCIZ	" ascenseur horizontal"	.B	ODBCR	.B	ODBSQUARE,BFAREG	.ASCIZ	" rgles"	.B	ODBTABX,26	.B	ODBSQUARE,BFABIG	.ASCIZ	" aide pour situer le curseur"	.B	ODBCR	.B	ODBSQUARE,BFAEOL	.ASCIZ	" fins de paragraphes"	.B	ODBTABX,26	.B	ODBSQUARE,BFAMCA	.ASCIZ	" mmorise la dernire case"	.B	ODBCR	.B	ODBSQUARE,BFASAJ	.ASCIZ	" cales"	.B	ODBCR	.B	ODBSQUARE,BFATAB	.ASCIZ	" tabulateurs"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Extension :  "	.B	ODBFILE,6+2	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	0	.EVENTDBOX_JUST:	.W	10$-TDBOX_JUST	.W	MENU_OKAN-TDBOX_JUST	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Paramtres globaux de justification :"	.B	ODBCR,ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"       "	.B	ODBTEXT	.ASCIZ	"Espaces tendus de "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	"      "	.B	ODBTEXT	.ASCIZ	"% au maximum"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"       "	.B	ODBTEXT	.ASCIZ	"Partie vide ne dpassant pas "	.B	ODBBOX,0,F8,TDBNORM	.ASCIZ	"      "	.B	ODBTEXT	.ASCIZ	"%"	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"  