	.TITLE	VCOUPE	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal	.REF	SM8		; df diverses	.REF	NTREL		; df noyau temps rel	.REF	GESMEM		; df gestionnaire de mmoire	.REF	FOS		; df file operating system	.REF	LIB		; df librairie	.REF	DRIVERS		; df drivers	.REF	COUPELCLIST	=	20		; max 20 coupures/motLBUFFER	=	500	.LOC	0OCLIST:	.BLKB	LCLIST		; liste des coupures possiblesOFAPOS:	.BLKB	1		; position apostrophe dans motOFSTAR:	.BLKB	1		; offset dbut du motOFPREP:	.BLKB	1		; offset prpositionOFNCOU:	.BLKB	1		; offset coupure interditeOBUNAM:		.BLKB	100OSOLUTION:	.BLKB	100ORESULTAT:	.BLKB	100OBUFFER:	.BLKB	LBUFFEROCHCOUPE:	.BLKW	1LGVAR:;===========================================================	.LOC	0START:	.W	LIB,?OPELIB	LOAD.L	D4,#LGVAR	.W	GESMEM,?GETMEM	; demande mmoire pour var.	JUMP,NE	ER	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A3,#R16"NAMCOUPE	LOAD.W	D3,#COUPE_FIRST	.W	LIB_OPEN	; ouvre le module COUPE	JUMP,NE	ER	LOAD.W	(A6)+OCHCOUPE,D1	.W	LIB,?AFTIM	.ASCIZ	/<CR>(A)utomatique, (M)anuel : /	.EVEN	.W	LIB,?GETCAR	.W	LIB,?AFCR	.W	LIB,?MINMAJ	COMP.B	D3,#'A	JUMP,EQ	AUTOMAIN:	.W	LIB,?AFTIM	.ASCIZ	/Donnez un mot : /	.EVEN	LOAD.L	A3,#(A6)+OBUNAM	LOAD.L	D3,#100	.W	LIB,?GETLINE	COMP.W	D3,#END	JUMP,EQ	FIN	COMP.W	D3,#CR	JUMP,NE	MAIN	LOAD.L	A0,A3	LOAD.W	D0,#-110$:	INC.W	D0	COMP.B	(A3+),#CR	JUMP,NE	10$	CLR.B	(A3)-1	LOAD.L	A2,#(A6)+OCLIST	LOAD.W	D2,#LCLIST	CALL	LCOUPE		; cherche toutes les coupures	TCLR.B	(A2):#7	CLR.B	D050$:	INC.B	D0	LOAD.B	D3,(A0+)	JUMP,EQ	60$	.W	LIB,?AFCAR	COMP.B	D0,(A2)	JUMP,NE	50$	INC.L	A2	LOAD.B	D3,#'/	.W	LIB,?AFCAR	JUMP	50$60$:	.W	LIB,?AFCR	JUMP	MAINAUTO:	.W	LIB,?AFTIM	.ASCIZ	/Nom du fichier : /	.EVEN	LOAD.L	A3,#(A6)+OBUNAM	LOAD.L	D3,#100	.W	LIB,?GETLINE	COMP.W	D3,#END	JUMP,EQ	FIN	COMP.W	D3,#CR	JUMP,NE	AUTO	LOAD.B	D3,#2^BOPRD	.W	FOS,?OPEN	JUMP,NE	ER	CLR.L	D410$:	LOAD.L	A3,#(A6)+OSOLUTION	CALL	RDLINE	TEST.W	D7	JUMP,NS	ER	JUMP,NE	80$	TEST.B	(A3)	JUMP,EQ	10$	LOAD.L	A0,#(A6)+OBUNAM	CLR.W	D020$:	LOAD.B	D3,(A3+)	JUMP,EQ	30$	COMP.B	D3,#'/	JUMP,EQ	20$	LOAD.B	(A0+),D3	INC.W	D0	JUMP	20$30$:	CLR.B	(A0)	LOAD.L	A0,#(A6)+OBUNAM	LOAD.L	A2,#(A6)+OCLIST	LOAD.W	D2,#LCLIST	CALL	LCOUPE		; cherche toutes les coupures	TCLR.B	(A2):#7	LOAD.L	A1,#(A6)+ORESULTAT	CLR.B	D050$:	INC.B	D0	LOAD.B	D3,(A0+)	JUMP,EQ	60$	LOAD.B	(A1+),D3	COMP.B	D0,(A2)	JUMP,NE	50$	INC.L	A2	LOAD.B	(A1+),#'/	JUMP	50$60$:	CLR.B	(A1)	LOAD.L	A3,#(A6)+OSOLUTION	LOAD.L	A2,#(A6)+ORESULTAT	CALL	CPSTRING	TEST.W	D7	JUMP,EQ	70$	.W	LIB,?AFCR	LOAD.L	A3,#(A6)+OSOLUTION	.W	LIB,?AFTEXT	.W	LIB,?AFTIM	.ASCIZ	/  ---  /	.EVEN	LOAD.L	A3,#(A6)+ORESULTAT	.W	LIB,?AFTEXT	.W	LIB,?AFTIM	.ASCIZ	/   /	.EVEN	.W	LIB,?BUZZ	.W	LIB,?GETCAR	COMP.B	D3,#END	JUMP,EQ	FIN	.W	LIB,?AFTIM	.ASCIZ	/<CR>/	.EVEN	JUMP	10$70$:	LOAD.B	D3,#'.	.W	LIB,?AFCAR	JUMP	10$80$:	JUMP	FINER:	PUSH.W	D7	.W	LIB,?AFCR	.W	LIB,?AFCR	POP.W	D7	.W	LIB,?AFERROR	.W	LIB,?AFCR	.W	LIB,?GETCARFIN:	LOAD.W	D1,(A6)+OCHCOUPE	.W	LIB_CLOSE	; ferme le module COUPE	.W	FOS,?CLOSE	.W	LIB,?CLOLIB	.W	FOS,?STOP; in	A4-D4	buffer i/o;	D6	canal;	A3	^buffer pour ligne; out	A4-D4	buffer i/o;	D7RDLINE:	PUSHM.L	D3,A3	TEST.W	D4	JUMP,NE	50$10$:	LOAD.L	A4,#(A6)+OBUFFER	LOAD.L	D4,#LBUFFER	.W	FOS,?RDBYTE	JUMP,EQ	20$	COMP.W	D7,#EROUTF	JUMP,NE	90$20$:	LOAD.W	D7,#1	TEST.L	D4	JUMP,EQ	90$50$:	TEST.W	D4	JUMP,EQ	10$	DEC.W	D4	LOAD.B	D3,(A4+)	COMP.B	D3,#CR	JUMP,EQ	60$	LOAD.B	(A3+),D3	JUMP	50$60$:	CLR.B	(A3)	CLR.W	D790$:	POPM.L	D3,A3	RETCPSTRING:	LOAD.W	D7,#210$:	LOAD.B	D3,(A3+)	JUMP,EQ	50$	COMP.B	D3,(A2+)	JUMP,EQ	10$	JUMP	90$50$:	TEST.B	(A2)	JUMP,NE	90$	CLR.W	D790$:	RETLCOUPE:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,A0	LOAD.W	D3,D0	LOAD.L	A4,A2	LOAD.W	D4,D2	.W	COUPE_HASH	POPM.L	D3,D4,A3,A4	RETNAMCOUPE:	.ASCIZ	"COUPE"		.EVEN	.END	START