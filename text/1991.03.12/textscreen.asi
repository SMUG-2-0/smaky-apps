	.SBTTL	TEXTSCREENBAFFIMA	=	16		; bit indiquant une imageBAFFREG	=	17		; bit indiquant une rglette;----------\\; ALLSCREEN >;==========/;------------\\; ALLSCREENSA >;============/; Signal qu'il faudra tout repeindre l'cran.; ALLSCREENSA => mais pas les ascenseurs verticaux !; in	-; out	-; mod	D7.WALLSCREEN:	CLR.W	(A6)+OYWDD	; redessine la cage de l'ascenseurALLSCREENSA:	TSET.B	(A6)+OFLASC:#BASHDE ; idem pour l'ascenseur horizontal	PUSHM.L	D4,A5	LOAD.L	A5,#(A6)+OBUFP	LOAD.W	D4,#MODALL	CALL	MODIF		; pour redessiner la zone principale	LOAD.L	A5,#(A6)+OBUFS;	LOAD.W	D4,#MODALL	CALL	MODIF		; pour redessiner la zone secondaire	POPM.L	D4,A5	RET;-------------\\; AFFDEROULEUR >;=============/; Affiche le drouleur.; in	A5.L	^description du buffer; out	-; mod	D7.WAFFDEROULEUR:	PUSHM.L	D0..D5,A4	LOAD.W	D3,(A5)+OMODID	; D3 <-- type de modification	JUMP,EQ 90$	COMP.W	D3,#MODLIN	; juste une ligne modifie ?	JUMP,EQ 90$		; oui => 90$	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.L	A4,(A5)+OPDB	CLR.W	D0		; D0 <-- nb de lignes total	CLR.W	D1		; D1 <-- nb de lignes avant curseur30$:	CALL	CAPDOWN		; D2 <-- nb ligne(s)	JUMP',NE 40$	ADD.W	D0,D2	ADD.W	D1,D2	COMP.L	A4,(A5)+OPDT	JUMP,LO 30$	SUB.W	D1,D235$:	CALL	CAPDOWN		; D2 <-- nb ligne(s)	JUMP',NE 40$	ADD.W	D0,D2	JUMP	35$40$:	LOAD.W	(A6)+OSCROLL+OSCPOSV,D1	; mm. position virtuelle	COMP.W	D0,#10	JUMP',HS 45$	LOAD.W	D0,#1045$:	LOAD.W	(A6)+OSCROLL+OSCHTV,D0	; mm. nb total de lignes	LOAD.W	(A6)+OSCROLL+OSCDEBO,(A6)+OCYI	CLR.W	(A6)+OSCROLL+OSCDEBL	LOAD.W	D2,(A6)+OYWDT	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE	JUMP',BS 50$	LOAD.W	D2,(A6)+OYWDP50$:	LOAD.W	(A6)+OSCROLL+OSCHTR,D2	CLR.B	(A6)+OSCROLL+OSCHOR  ; ascenseur horizontal	SET.B	(A6)+OSCROLL+OSCPAGE ; met les avances par pages	PUSH.L	A5	LOAD.L	A5,#(A6)+OSCROLL	CLR.W	D2		; D2 <-- cage pas change	LOAD.W	D4,(A6)+OYWDD	COMP.W	D4,(A5)+OSCHTR	; mme cage que prcdemment ?	JUMP',EQ 55$		; oui => 55$	SCROLL_	DRAW		; non => dessine la cage de l'ascenseur	LOAD.W	(A6)+OYWDD,(A5)+OSCHTR	INC.W	D255$:	SCROLL_	UPDATE		; dessine l'ascenseur	POP.L	A5	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE	JUMP',BS 60$	TEST.W	D2		; cage de l'ascenseur refaite ?	JUMP',EQ 60$		; non => 60$	LOAD.W	D4,(A6)+OCYI	; D4 <-- hauteur des infos principales	ADD.W	D4,(A6)+OCY	; D4 <-- hauteur des infos princ. + sec.	ADD.W	D4,(A6)+OYWDP	; D4 <-- dbut Y zone secondaire	LOAD.W	(A6)+OSCROLS+OSCDEBO,D4	CLR.W	(A6)+OSCROLS+OSCDEBL	LOAD.W	D4,(A6)+OYWDT	SUB.W	D4,(A6)+OYWDP	SUB.W	D4,(A6)+OCY	; D4 <-- hauteur zone secondaire	LOAD.W	(A6)+OSCROLS+OSCHTR,D4	CLR.B	(A6)+OSCROLS+OSCHOR  ; ascenseur horizontal	CLR.B	(A6)+OSCROLS+OSCPAGE ; ne met pas les avances par pages	PUSH.L	A5	LOAD.L	A5,#(A6)+OSCROLS	SCROLL_	DRAW		; dessine juste la cage	POP.L	A560$:	TEST.B	(A6)+OFANION+2:#BFASCH-8 ; ascenseur horizontal ?	JUMP',BC 80$		; non => 80$	TCLR.B	(A6)+OFLASC:#BASHDE	JUMP',BC 80$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit une trame pleine	LOAD.W	(A6)+OSCROLH+OSCDEBO,(A6)+OXWDD	LOAD.W	D3,(A6)+OYWDT	ADD.W	D3,(A6)+OXWDD	LOAD.W	(A6)+OSCROLH+OSCDEBL,D3	LOAD.W	(A6)+OSCROLH+OSCHTR,(A6)+OXWDT	SET.B	(A6)+OSCROLH+OSCHOR  ; ascenseur horizontal	CLR.B	(A6)+OSCROLH+OSCPAGE ; ne met pas les avances par pages	SWAP.W	D3		; D3 <-- <yy>	CLR.W	D3		; D3 <-- <xx>	LOAD.W	D4,(A6)+OXWDD	; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,(A6)+OXWDD	; D4 <-- <dxx>	LOAD.W	D2,#SETDOT	; D2 <-- mode	LIB	?DRMATRIX	; met un carr blanc en bas  gauche	PUSH.L	A5	LOAD.L	A5,#(A6)+OSCROLH	SCROLL_	DRAW		; dessine la cage	POP.L	A5	TSET.B	(A6)+OFLASC:#BASHCA ; juste la cage	LOAD.W	D4,(A6)+OLGP	SUB.W	D4,(A6)+OMGG	SUB.W	D4,(A6)+OMWDT	JUMP',LS 80$	TCLR.B	(A6)+OFLASC:#BASHCA ; le contenu est valide	LOAD.W	(A6)+OSCROLH+OSCHTV,D4	PUSH.L	A5	LOAD.L	A5,#(A6)+OSCROLH	SCROLL_	UPDATE		; dessine l'ascenseur	POP.L	A580$:	CALL	DISSCMO		; remet souris si ncessaire90$:	CLR.W	(A5)+OMODID	; signal drouleur  jour	POPM.L	D0..D5,A4	RET;------------\\; GODEROULEUR >;============/; Va  l'endroit indiqu par la souris dans le drouleur.; in	-; out	-; mod	D7.WGODEROULEUR:	PUSHM.L	D2..D4,A4	LOAD.W	D4,(A6)+OSCROLL+OSCPOSV	LOAD.L	A4,(A5)+OPDB	TEST.W	D4	JUMP',EQ 70$20$:	CALL	CAPDOWN		; D2 <-- nb ligne(s)	JUMP',NE 70$	SUB.W	D4,D2	JUMP,HI 20$70$:	CALL	SKIPPSEUDO	; A4 <-- saute si pseudo caractres	CALL	_VAQQPART	; met le curseur selon A4	POPM.L	D2..D4,A4	RET;--------\\; CAPDOWN >;--------/; Compte approximativement (et rapidement) le nombre de ligne; en descendant.; On suppose qu'une rgle ou qu'une image fait 4 lignes !; in	-; out	D2.W	nombre de lignes;	D7.W	erreur; mod	D2.W, D3.W, D7.WCAPDOWN:10$:	CALL	_QUICKDOWN	JUMP',NE 90$	COMP.B	D3,#DEBCOM	; dbut d'une commande ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#DEBIMA	; dbut image ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,#DEBREG	; dbut rglette ?	JUMP',EQ 50$		; oui => 50$	TEST.L	D3:#BEOL	; fin d'une ligne ?	JUMP,BC 10$		; non => 10$	LOAD.W	D2,#1		; D2 <-- une ligne	JUMP'	90$40$:	DEC.L	A4		; A4 <-- ^avant la commande	CALL	_NVISU		; saute la commande	JUMP	10$50$:	DEC.L	A4		; A4 <-- ^avant rgle/image	CALL	_NVISU		; saute rgle/image	LOAD.W	D2,#4		; D2 <-- 4 lignes !90$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; QUPDOWN  >;=========/; Affiche le plus rapidement possible contre en haut ou contre en bas; jusqu' ce que la souris soit relche.; in	D4.W	SCROLLF(UP/DOWN); out	-; mod	D7.WQUPDOWN:	PUSHM.L	D3..D5	CALL	DISCCMO		; enlve la flche de la souris	TSET.B	(A6)+OFLMOU:#BLOCKMO ; refuse de la remettre !	PUSH.L	A5	LOAD.L	A5,#(A6)+OSCROLL	SCROLL_	PRESS		; presse la flche	POP.L	A5	CALL	INKCURS		; enlve le curseur40$:	COMP.W	D4,#SCROLLFUP	JUMP',EQ 45$	PUSH.W	D4	CLR.B	D4		; D4 <-- pour les classes	CALL	DLIGNE		; descend d'une ligne	POP.W	D4	JUMP'	50$45$:	PUSH.W	D4	CLR.B	D4		; D4 <-- pour les classes	CALL	DBLIGNE		; remonte d'une ligne	POP.W	D450$:	LOAD.W	D5,(A6)+ONOWDT	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE	JUMP',BS 60$	LOAD.W	D5,(A6)+ONOWDP60$:	LIB	?USEWDO		; utilise swdo du texte	CALL	AFF1BUF		; affiche la zone principale	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	CALL	AFFDEROULEUR	; affiche le drouleur	LIB	?IFCAR		; bouton souris relch ?	JUMP,NE 40$		; non => 40$				; oui =>	CALL	INKCURS		; remet le curseur	PUSH.L	A5	LOAD.L	A5,#(A6)+OSCROLL	SCROLL_	PRESS		; relche la flche	POP.L	A5	TCLR.B	(A6)+OFLMOU:#BLOCKMO ; cette fois, on peut la remettre	CALL	DISSCMO		; remet la flche de la souris	POPM.L	D3..D5	RET;--------\\; AFFPROV >;========/; Met  jour l'affichage des informations provisoirement,; c'est--dire pendant le dmarrage du programme.; in	A5.L	^description buffer principal; out	-; mod	D7.WAFFPROV:	PUSHM.L	D3,D5	LOAD.W	D5,(A6)+ONOWDI	LIB	?USEWDO		; utilise swdo des infos principales	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	AFINV		; vido inverse	.ASCII	" TEXT "	.B	TEXTREV+'0,'.	.IF	TEXTVERS<10	.B	TEXTVERS+'0	.ELSE	.B	(TEXTVERS/10)+'0,(TEXTVERS-((TEXTVERS/10)*10))+'0	.ENDIF	.ASCII	"          "	.ASCII	"(C)  Daniel ROUX et EPSITEC-system sa"	.B	AFDIR		; vido normale	.B	0	.EVEN	CALL	DISIEFLI	; efface fin de la ligne	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	POPM.L	D3,D5	RET;--------\\; AFFINFO >;========/; Met  jour l'affichage des informations en fonction; des buffers de texte (principal et secondaire).; in	A5.L	^description buffer principal; out	-; mod	D7.WAFFINFO:	CALL	AFFINFOP	; infos zone principale	JUMP	AFFINFOS	; infos zone secondaire;---------\\; AFFINFOP >;=========/; Met  jour l'affichage des informations en fonction; du buffer de texte principal.; in	A5.L	^description buffer principal; out	-; mod	D7.WAFFINFOP:	PUSHM.L	D3..D5,A3,A4	LOAD.W	D5,(A6)+ONOWDI	LIB	?USEWDO		; utilise swdo des infos principales	TEST.B	(A6)+OFLAGS:#BCALCUL	JUMP',BS 50$	LIB	?BUCAR		; mode rapide	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	AFINV		; vido inverse	.ASCII	" TEXT "	.B	TEXTREV+'0,'.	.IF	TEXTVERS<10	.B	TEXTVERS+'0	.ELSE	.B	(TEXTVERS/10)+'0,(TEXTVERS-((TEXTVERS/10)*10))+'0	.ENDIF	.B	0	.EVEN	LIB	?AFTIM	.ASCIZ	"   Zone: "	.EVEN	CALL	AFFINFC		; affiche numro, etc.	LIB	?NOBUCAR	; remet mode normal	JUMP'	90$50$:	CLR.L	D3	LIB	?SETCURS	CALL	GCICONE		; utilise g.c. des icnes	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	AFINV		; vido inverse	.B	AFTOUT	.B	ICOSPACE	.B	ICOSPACE	.B	ICOEGAL		; dessine touche (=)	.B	ICOSPACE	.B	ICOSPACE	.B	ICOANUL		; dessine touche (c)	.B	ICOSPACE	.B	ICOSPACE	.B	ICOSPACE	.B	ICOSPACE	.B	AFNORM	.B	0	.EVEN	CALL	GCDEF		; utilise g.c. par dfaut	LIB	?AFTIM	.ASCIZ	"Rsultat = "	.EVEN	LOAD.L	D3,(A6)+OCALCUL+0	LOAD.L	D4,(A6)+OCALCUL+4 ; D4 <-- rsultat intermdiaire	LOAD.L	A4,#(A6)+OBUDIS	CALL	PUTNUM	LOAD.L	A3,#(A6)+OBUDIS	LIB	?AFTEXT		; affiche le nombre	CALL	DISIEFLI	; efface fin de la ligne	LIB	?AFTIM	.B	AFDIR		; vido normale	.B	0	.EVEN90$:	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	POPM.L	D3..D5,A3,A4	RET;---------\\; AFFINFOS >;=========/; Met  jour l'affichage des informations en fonction; du buffer de texte secondaire.; in	A5.L	^description buffer principal; out	-; mod	D7.WAFFINFOS:	PUSHM.L	D3,D5,A5; Si la zone secondaire existe, affiche les informations la concernant.	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE	JUMP',BS 90$	LOAD.L	A5,#(A6)+OBUFS	; A5 <-- ^description zone secondaire	LOAD.W	D5,(A6)+ONOWDJ	LIB	?USEWDO		; utilise swdo des infos secondaires	CLR.L	D3	LIB	?SETCURS	CALL	GCICONE		; utilise g.c. des icnes	LIB	?AFTIM	.B	AFINV		; vido inverse	.B	AFTOUT	.B	ICOSPACE	.B	ICOSPACE	.B	ICOCOPK		; copie puis destruction	.B	ICOSPACE	.B	ICOSPACE	.B	ICOCOPM		; copie multiple	.B	ICOSPACE	.B	ICOSPACE	.B	ICOCOPD		; destruction sans copie	.B	ICOSPACE	.B	ICOSPACE	.B	ICOCOPX		; change	.B	ICOSPACE	.B	ICOSPACE	.B	ICOCOPZ		; dplace la frontire	.B	ICOSPACE	.B	ICOSPACE	.B	ICOSPACE	.B	ICOSPACE	.B	AFNORM	.B	0	.EVEN	CALL	GCDEF		; utilise g.c. par dfaut	LIB	?AFTIM	.ASCIZ	"Zone: "	.EVEN	CALL	AFFINFC		; affiche numro, etc.90$:	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	POPM.L	D3,D5,A5	RET;--------\\; AFFINFC >;--------/; Affiche la partie des informations commune aux zones; principales et secondaire, c'est--dire :;;	numro [fichier] utilis %; in	-; out	-; mod	D7.WAFFINFC:	PUSHM.L	D0..D5,A3	CLR.L	D4	LOAD.W	D4,(A5)+ONOBUF	LOAD.W	D3,#3		; D3 <-- nb digits	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode	LIB	?AFDEC		; affiche no zone	LIB	?AFTIM	.ASCIZ	"   "	.EVEN	LOAD.L	A3,#(A5)+OBUMEMF	TEST.B	(A3)		; nom existe ?	JUMP',EQ 20$		; non => 20$	CALL	_AFFFILE	; affiche le nom du texte20$:;;?	.W	LIB,?AFTIM;;?	.ASCIZ	"   Reste: ";;?	.EVEN	LOAD.L	D4,(A5)+OPFT	SUB.L	D4,(A5)+OPDT	LOAD.W	D3,#8		; D3 <-- nb digits	LOAD.W	D2,#2^BAFDCM!2^BAFDSP ; D2 <-- mode;;?	.W	LIB,?AFDEC	; affiche nb restants	LOAD.L	D0,D4		; D0 <-- reste	LIB	?AFTIM	.ASCIZ	"   Utilis: "	.EVEN	LOAD.L	D4,(A5)+OPDT	SUB.L	D4,(A5)+OPDB	LOAD.L	D5,(A5)+OPFB	SUB.L	D5,(A5)+OPFT	ADD.L	D4,D5	LIB	?AFDEC		; affiche nb utiliss	LOAD.L	D1,D4		; D1 <-- utilis	LIB	?AFSPACE	ADD.L	D0,D1		; D0 <-- U+R, D1 <-- U	CLR.W	D2	COMP.L	D0,#10000	JUMP',LO 50$		;	  0 ..   9'999 => /1	LOAD.W	D2,#3		;    10'000 ..  99'999 => /8	COMP.L	D0,#100000	;   100'000 .. 999'999 => /64	JUMP',LO 50$		; 1'000'000 .. infini  => /512	LOAD.W	D2,#6	COMP.L	D0,#1000000	JUMP',LO 50$	LOAD.W	D2,#950$:	SR.L	D0,D2		; D0 <-- R/1 ou R/8 ou R/64	SR.L	D1,D2		; D1 <-- U/1 ou U/8 ou U/64	MUL.WU	D1,#100	DIV.WU	D1,D0		; D1 <-- (U*100)/(U+R)	CLR.L	D4	LOAD.W	D4,D1		; D4 <-- utilis en %	JUMP',EQ 60$		; si 0% => n'affiche rien !	LOAD.B	D3,#3		; D3 <-- 3 digits au maximum	LOAD.B	D2,#2^BAFDCM	; D2 <-- compact sans '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	"%"	.EVEN60$:	CALL	DISIEFLI	; efface fin de la ligne	LIB	?AFTIM	.B	AFDIR		; vido normale	.B	0	.EVEN	POPM.L	D0..D5,A3	RET;--------\\; AFFBUF  >;========/; Met  jour l'affichage en fonction du buffer de texte; en dessinant le minimum de choses.; in	A5.L	^description du buffer  afficher; out	-; mod	D7.WAFFBUF:	PUSHM.L	D3..D6,A4,A5	TEST.B	(A6)+OFANION+2:#BFASCH-8 ; ascenseur horizontal ?	JUMP',BS 10$		; oui => 10$				; non =>	TCLR.B	(A6)+OFLASC:#BASHVI	JUMP',BC 20$	JUMP'	15$10$:	TSET.B	(A6)+OFLASC:#BASHVI	JUMP',BS 20$	TSET.B	(A6)+OFLASC:#BASHDE ; faudra le dessiner !15$:	CLR.W	(A6)+OSCROLH+OSCPOSV ; plus de dcalage !	CALL	KILWDOS		; dtruit toutes les swdos	CALL	CREWDOS		; re-cre avec/sans l'ascenseur horizontal20$:	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE	JUMP',BC 50$	LOAD.W	D5,(A6)+ONOWDT	LIB	?USEWDO		; utilise swdo du texte	LOAD.L	D3,(A5)+OCURS	; D3 <-- position du curseur	CALL	INVCURS		; enlve le curseur	CALL	AFF1BUF		; affiche la zone principale unique	LOAD.L	D3,(A5)+OCURS	; D3 <-- position du curseur	CALL	INVCURS		; remet le curseur	JUMP'	80$50$:	LOAD.W	D5,(A6)+ONOWDP	LIB	?USEWDO		; utilise swdo zone principale	LOAD.L	D3,(A5)+OCURS	; D3 <-- position du curseur	CALL	INVCURS		; enlve le curseur	CALL	AFF1BUF		; affiche la zone principale	LOAD.L	D3,(A5)+OCURS	; D3 <-- position du curseur	CALL	INVCURS		; remet le curseur	LOAD.L	A5,#(A6)+OBUFS	; A5 <-- ^description zone secondaire	TEST.W	(A5)+OMODIF	; zone secondaire parfaitement  jour ?	JUMP',EQ 80$		; oui => 80$	LOAD.W	D5,(A6)+ONOWDS	LIB	?USEWDO		; utilise swdo zone secondaire	LOAD.L	D3,(A5)+OCURS	; D3 <-- position du curseur	CALL	INVCURS		; enlve le curseur	CALL	AFF1BUF		; affiche la zone secondaire	LOAD.L	D3,(A5)+OCURS	; D3 <-- position du curseur	CALL	INVCURS		; remet le curseur80$:	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	CALL	DISSCMO		; remet la flche de la souris	CALL	GCDEF		; remet g.c. par dfaut	POPM.L	D3..D6,A4,A5	RET;--------\\; AFF1BUF >;--------/; Affiche le buffer principal ou secondaire.; in	A5.L	^description du buffer; out	-; mod	D7.WAFF1BUF:	PUSHM.L	D2..D6,A3,A4	LIB	?GETWDO		; D4 <-- dimensions swdo utilise	SWAP.W	D4		; D4 <-- hauteur de la fentre	TCLR.B	(A5)+OFLAFF:#BAFEOT ; EOT pas encore affiche	LOAD.W	D3,(A5)+OMODIF	; D3 <-- type de modification	JUMP,EQ	80$	CLR.L	(A5)+OCURS	; curseur pas encore affich	COMP.W	D3,#MODALL	JUMP,EQ 50$	COMP.W	D3,#MODLIN	JUMP,HS 40$	COMP.W	D3,#MODCUR	JUMP,NE 50$				; CURSEUR DEPLACE =>	CALL	SRCBAF		; A4 <-- ^dbut affichage, D6 <-- skip	COMP.L	A4,(A5)+OPDA	; idem au dernier ?	JUMP',NE 15$		; non => 15$	COMP.W	D6,(A5)+OHDA	; mme hauteur  sauter au dbut ?	JUMP',EQ 30$		; oui => 30$	JUMP',LO 10$	LOAD.W	D2,D6	SUB.W	D2,(A5)+OHDA	; D2 <-- nb points descendus	JUMP'	17$10$:	LOAD.W	D2,(A5)+OHDA	SUB.W	D2,D6		; D2 <-- nb points monts	JUMP'	22$15$:	CALL	CALNUP		; reste qq chose  monter ?	JUMP',NE 20$		; non => 20$17$:	COMP.W	D2,D4		; refait + que la fentre ?	JUMP',HS 25$		; oui => 25$	CALL	AFFDOWN		; monte et refait le bas	JUMP'	30$20$:	CALL	CALNDOWN	; reste qq chose  descendre ?	JUMP',NE 25$		; non => 25$22$:	COMP.W	D2,D4		; refait + que la fentre ?	JUMP',HS 25$		; oui => 25$	CALL	AFFUP		; descend et refait le haut	JUMP'	30$25$:	CALL	AFFALL		; refait toutes les lignes	JUMP'	80$30$:	TEST.W	(A5)+ODMO	; dcalage pour la souris ?	JUMP',NE 80$		; oui => 80$	CALL	SRCLCU		; D3 <-- position Y o est le curseur	CLR.W	(A5)+OMODIF	; si image => dj dessine	TCLR.B	(A5)+OFLAFF:#BAFEOT ; EOT pas encore affiche	CALL	AFFLINE		; refait juste cette ligne	JUMP'	80$40$:				; LIGNE(S) MODIFIEE(S) =>	CALL	SRCBAF		; A4 <-- ^dbut affichage, D6 <-- skip	COMP.L	A4,(A5)+OPDA	; idem au dernier ?	JUMP',NE 55$		; non => 55$	COMP.W	D6,(A5)+OHDA	; mme hauteur  sauter au dbut ?	JUMP',NE 55$		; non => 55$	LOAD.L	A4,#(A5)+OLREG	LOAD.L	A3,#(A5)+OVREG	CALL	COPREGLE	; OVREG <-- OLREG	LOAD.L	A4,#(A5)+OLCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OLCOM	LOAD.L	A4,(A5)+OPDL	; A4 <-- ^dbut ligne(s) modifie(s)	PUSH.L	D4	CALL	SRCHTL		; D4 <-- hauteur de la ligne	COMP.W	D4,(A5)+OHTL	; mme hauteur que prcdement ?	POPM.L	D4	JUMP',NE 50$		; non => 50$	CALL	AFFQQL		; refait quelques lignes	JUMP'	80$50$:				; TOUT MODIFIE =>	CALL	SRCBAF		; A4 <-- ^dbut affichage, D6 <-- skip55$:	CALL	AFFALL		; refait toutes les lignes80$:	CLR.W	(A5)+OMODIF	; affichage  jour	POPM.L	D2..D6,A3,A4	RET;--------\\; SRCBAF  >;========/; Cherche le premier caractre  afficher dans le buffer de; texte. Utilise l'algorithme suivant :;  1) avance (contre en bas) de "h/2";  2) remonte (contre en haut) de "h"; in	A5.L		^description du buffer;	D4.W		hauteur "h";	(A5)+ODMO.W	dcalage supplmentaire; out	A4.L		^dbut d'une ligne dans buffer texte;	D6.W		hauteur  sauter; mod	D6.W, D7.W, A4.LSRCBAF:	PUSHM.L	D3,D4,A3	LOAD.W	D6,D4	SR.W	D6,#1		; D6 <-- h/2; Descend de h/2 si c'est possible, ou tout en bas.	CALL	SRCBLIC		; A4 <-- ^dbut de la ligne	PUSH.L	A4	LOAD.L	A4,#(A5)+OVREG	LOAD.L	A3,#(A6)+OSREG	CALL	COPREGLE	; OSREG <-- OVREG	LOAD.L	A4,#(A5)+OVCOM	LOAD.L	A3,#(A6)+OSCOM	CALL	COPCOMMAND	; OSCOM <-- OVCOM	POP.L	A4	LOAD.L	A3,A4		; A3 <-- ^idem	CLR.W	D310$:	CALL	SRCHTL		; D4 <-- hauteur de la ligne	ADD.W	D3,D4		; D3 <-- distance descendue	COMP.W	D3,D6	JUMP',HS 40$	CALL	SRCDOWN		; A4 <-- ^dbut ligne suivante	JUMP',NE 30$	COMP.L	A4,(A5)+OPFB	; est-on tout  la fin ?	JUMP,NE	10$		; non => 10$	CALL	SRCBLI		; oui => revient dbut dernire ligne30$:	SL.W	D6,#1		; D6 <-- h;;?	SUB.W	D6,D4		; D6 <-- h-dernire ligne	JUMP'	50$40$:	LOAD.L	A4,A3		; A4 <-- repart o est le curseur	PUSH.L	A4	LOAD.L	A4,#(A6)+OSREG	LOAD.L	A3,#(A5)+OVREG	CALL	COPREGLE	; OVREG <-- OSREG	LOAD.L	A4,#(A6)+OSCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OSCOM	POP.L	A4	CALL	SRCUP		; A4 <-- ^dbut ligne prcdente	JUMP',NE 80$; Remonte de la distance contenue dans D6.W50$:	CLR.W	D355$:	CALL	SRCHTL		; D4 <-- hauteur de la ligne	ADD.W	D3,D4		; D3 <-- distance remonte	COMP.W	D3,D6	JUMP',EQ 80$	JUMP',HI 60$	CALL	SRCUP		; A4 <-- ^dbut ligne prcdente	JUMP,EQ	55$	JUMP'	80$60$:	TEST.L	D4:#BAFFIMA	; image dans la premire ligne ?	JUMP',BC 70$		; non => 70$	SUB.W	D3,D6		; oui =>	LOAD.W	D6,D3		; D6 <-- lg remonte en trop	JUMP'	90$70$:	CALL	SRCDOWN		; ignore ligne partiellement affichable80$:	CLR.W	D6		; D6 <-- rien de remont en trop; Descend encore un peu s'il y a un dcalage lors de la mise en vidence; d'une grande zone avec la souris.90$:	LOAD.W	D3,(A5)+ODMO	; D3 <-- nb lignes pour dcalage souris	JUMP',EQ 95$	CLR.W	D6		; D6 <-- rien de remont en trop92$:	CALL	SRCDOWN	JUMP',NE 94$	DEC.W	D3	JUMP,NE 92$94$:	SUB.W	(A5)+ODMO,D3	; diminue le dcalage95$:	PUSH.L	A4	LOAD.L	A4,#(A5)+OVREG	LOAD.L	A3,#(A5)+OAREG	CALL	COPREGLE	; OAREG <-- OVREG	LOAD.L	A4,#(A5)+OVCOM	LOAD.L	A3,#(A5)+OACOM	CALL	COPCOMMAND	; OACOM <-- OVCOM	POP.L	A4	POPM.L	D3,D4,A3	RET;--------\\; CALNUP  >;========/; Calcul le nombre de points  dcaler contre le haut.; in	A4.L	^dbut de l'affichage;	D6.W	hauteur descendue en trop;	D4.W	hauteur totale; out	D2.W	nombre de points  dcaler;	D7.W	erreur; mod	D2.W, D7.WCALNUP:	PUSHM.L	D4,D5,A3,A4	PUSH.L	A4	LOAD.L	A4,#(A5)+OVREG	LOAD.L	A3,#(A6)+OSREG	CALL	COPREGLE	; OSREG <-- OVREG	LOAD.L	A4,#(A5)+OVCOM	LOAD.L	A3,#(A6)+OSCOM	CALL	COPCOMMAND	; OSCOM <-- OVCOM	POP.L	A4	CLR.W	D2		; D2 <-- nb points  dcaler	LOAD.W	D5,D4		; D5 <-- hauteur totale10$:	COMP.L	A4,(A5)+OPDA	; dbut affichage rejoint ?	JUMP',EQ 80$		; oui => 80$	CALL	SRCUP		; A4 <-- ^ligne plus haute	JUMP',NE 90$	CALL	SRCHTL		; D4 <-- hauteur ligne	ADD.W	D2,D4	COMP.W	D2,D5		; encore une ligne ?	JUMP,LS	10$		; oui => 10$				; non =>	LOAD.W	D7,#ERTBOB	JUMP'	90$80$:	SUB.W	D2,(A5)+OHDA	; ne remonte pas ce qui tait cach	ADD.W	D2,D6		; remonte ce qui est cach	INC.W	D2	TCLR.L	D2:#0		; D2 <-- modulo 2	CLR.W	D7		; D7 <-- ok90$:	LOAD.L	A4,#(A6)+OSREG	LOAD.L	A3,#(A5)+OVREG	CALL	COPREGLE	; OVREG <-- OSREG	LOAD.L	A4,#(A6)+OSCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OSCOM	POPM.L	D4,D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; CALNDOWN >;=========/; Calcul le nombre de points  dcaler contre le bas.; in	A4.L	^dbut de l'affichage;	D6.W	hauteur remonte en trop;	D4.W	hauteur totale; out	D2.W	nombre de points  dcaler;	D7.W	erreur; mod	D2.W, D7.WCALNDOWN:	PUSHM.L	D4,D5,A3,A4	PUSH.L	A4	LOAD.L	A4,#(A5)+OVREG	LOAD.L	A3,#(A6)+OSREG	CALL	COPREGLE	; OSREG <-- OVREG	LOAD.L	A4,#(A5)+OVCOM	LOAD.L	A3,#(A6)+OSCOM	CALL	COPCOMMAND	; OSCOM <-- OVCOM	POP.L	A4	CLR.W	D2		; D2 <-- nb points  dcaler	LOAD.W	D5,D4		; D5 <-- hauteur totale	LOAD.L	A3,(A5)+OPDA	; A3 <-- ^ancien dbut de l'affichage	COMP.L	A3,(A5)+OPDT	; est-il maintenant dans le trou ?	JUMP',LS 10$		; non => 10$	COMP.L	A3,(A5)+OPFT	; oui =>	JUMP',HS 10$	LOAD.L	D4,(A5)+OPFT	SUB.L	D4,(A5)+OPDT	; D4 <-- longueur du trou	ADD.L	A3,D4		; A3 <-- saute  droite du trou10$:	COMP.L	A4,A3		; dbut affichage rejoint ?	JUMP',EQ 80$		; oui => 80$	CALL	SRCHTL		; D4 <-- hauteur ligne	ADD.W	D2,D4	CALL	SRCDOWN		; A4 <-- ^ligne plus basse	JUMP',NE 90$	COMP.W	D2,D5		; encore une ligne ?	JUMP,LS	10$		; oui => 10$				; non =>	LOAD.W	D7,#ERTEOB	JUMP'	90$80$:	ADD.W	D2,(A5)+OHDA	; descend ce qui tait cach	SUB.W	D2,D6		; ne descend pas ce qui est cach	INC.W	D2	TCLR.L	D2:#0		; D2 <-- modulo 2	CLR.W	D7		; D7 <-- ok90$:	LOAD.L	A4,#(A6)+OSREG	LOAD.L	A3,#(A5)+OVREG	CALL	COPREGLE	; OVREG <-- OSREG	LOAD.L	A4,#(A6)+OSCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OSCOM	POPM.L	D4,D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SRCLCU  >;========/; Cherche dans quelle ligne est le curseur.; in	A5.L	^description buffer; out	A4.L	^dbut ligne;	D3.W	position Y o est le curseur;	D4.W	hauteur de la ligne (BAFFIMA et BAFFREG);	D5.W	hauteur en trop (contre en bas);	D6.W	hauteur en trop (contre en haut); mod	D3.W, D4.W, D5.W, D6.W, D7.W, A4.LSRCLCU:	PUSH.L	(A5)+OPFB	; sauve la fin du buffer	LOAD.L	A4,(A5)+OPFT	CALL	SRCDOWN		; A4 <-- ^aprs ligne o est le curseur	LOAD.L	(A5)+OPFB,A4	; met la fin juste ici	PUSH.L	A3	LOAD.L	A4,#(A5)+OAREG	LOAD.L	A3,#(A5)+OVREG	CALL	COPREGLE	; OVREG <-- OAREG	LOAD.L	A4,#(A5)+OACOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OACOM	POP.L	A3	LOAD.L	A4,(A5)+OPDA	; A4 <-- ^dbut affichage	LOAD.W	D6,(A5)+OHDA	; D6 <-- hauteur  sauter	CLR.W	D520$:	CALL	SRCHTL		; D4 <-- hauteur de la ligne	SUB.W	D4,D6	CALL	SRCDOWN		; A4 <-- ^dbut ligne suivante	COMP.L	A4,(A5)+OPFB	; a-t-on rencontr le curseur ?	JUMP',EQ 50$		; oui => 50$	CLR.W	D6	ADD.W	D5,D4		; D5 <-- position Y ligne suivante	JUMP	20$50$:	POP.L	(A5)+OPFB	; remet la fin du buffer normale	LOAD.W	D3,D5		; D3 <-- position Y dbut ligne	CLR.W	D5	JUMP	SRCBLIC		; A4 <-- ^dbut ligne;	CALL	SRCBLIC;	RET;--------\\; AFFALL  >;========/; Affiche toutes les lignes de la fentre.; S'il reste une fraction de ligne tout en bas de la sous-fentre,; efface toute la surface.; in	A4.L	^dbut de l'affichage;	D4.W	hauteur totale;	D6.W	hauteur  sauter (en haut); out	-; mod	D7.WAFFALL:	PUSHM.L	D0,D3..D6,A4	LOAD.W	(A5)+OMODIF,#MODALL ; si image => efface avant le dessin	LOAD.L	(A5)+OPDA,A4	; mm ^dbut affichage	LOAD.W	(A5)+OHDA,D6	; mm hauteur  sauter	CLR.W	D3		; D3 <-- position Y dbut 1re ligne	LOAD.W	D0,D4		; D0 <-- hauteur20$:	CALL	SRCHTL		; D4 <-- hauteur de la ligne	SUB.W	D4,D6	CLR.W	D5	COMP.W	D0,D4		; reste place pour toute la ligne ?	JUMP',HS 30$		; oui => 30$	LOAD.W	D5,D4		; non =>	SUB.W	D5,D0		; D5 <-- hauteur en trop	LOAD.W	D4,D0		; D4 <-- hauteur restante30$:	CALL	AFFLINE		; affiche une ligne	CLR.W	D6	ADD.W	D3,D4		; D3 <-- position Y ligne suivante	SUB.W	D0,D4	JUMP,HI	20$	POPM.L	D0,D3..D6,A4	RET;--------\\; AFFQQL  >;========/; Affiche quelques lignes,  partir de la ligne o est le curseur.; in	A4.L	^dbut de l'affichage;	D4.W	hauteur;	D3.W	MODLIN+n (n+1 = nombre de lignes); out	-; mod	D7.WAFFQQL:	PUSHM.L	D0,D1,D3..D6,A4	LOAD.W	D1,D3	SUB.W	D1,#MODLIN-1	; D1 <-- nb de ligne(s) modifie(s) 1..n	LOAD.W	D3,(A5)+OPOSYL	; D3 <-- position Y premire ligne	LOAD.W	D0,D4		; D0 <-- hauteur totale	SUB.W	D0,D3		; D0 <-- hauteur restante	CLR.W	D620$:	CALL	SRCHTL		; D4 <-- hauteur de la ligne	CLR.W	D5	COMP.W	D0,D4		; reste place pour toute la ligne ?	JUMP',HS 30$		; oui => 30$	LOAD.W	D5,D4		; non =>	SUB.W	D5,D0		; D5 <-- hauteur en trop	LOAD.W	D4,D0		; D4 <-- hauteur restante30$:	CALL	AFFLINE		; affiche juste une(qq) ligne(s)	ADD.W	D3,D4		; D3 <-- position Y ligne suivante	SUB.W	D0,D4	JUMP',LS 90$	DEC.W	D1		; encore une ligne ?	JUMP,NE	20$		; oui => 20$90$:	POPM.L	D0,D1,D3..D6,A4	RET;--------\\; AFFUP   >;========/; Affiche qq lignes en haut de la fentre.; in	A4.L	^dbut de l'affichage;	D4.W	hauteur totale;	D2.W	hauteur  repeindre (en haut);	D6.W	hauteur  sauter (en haut); out	-; mod	D7.WAFFUP:	PUSHM.L	D2..D6,A4	LOAD.W	D4,D2	CALL	DISROLLDOWN	LOAD.L	(A5)+OPDA,A4	; mm ^dbut affichage	LOAD.W	(A5)+OHDA,D6	; mm hauteur  sauter	CLR.W	D3		; D3 <-- position Y dbut ligne20$:	CALL	SRCHTL		; D4 <-- hauteur de la ligne	SUB.W	D4,D6	CLR.W	D5	COMP.W	D2,D4		; reste place pour toute la ligne ?	JUMP',HS 30$		; oui => 30$	LOAD.W	D5,D4		; non =>	SUB.W	D5,D2		; D5 <-- hauteur en trop	LOAD.W	D4,D2		; D4 <-- hauteur restante30$:	CALL	AFFLINE		; affiche une ligne	CLR.W	D6	ADD.W	D3,D4		; D3 <-- position Y ligne suivante	SUB.W	D2,D4	JUMP,HI	20$90$:	POPM.L	D2..D6,A4	RET;--------\\; AFFDOWN >;========/; Affiche qq lignes en bas de la fentre.; in	A4.L	^dbut de l'affichage;	D4.W	hauteur totale;	D2.W	hauteur  repeindre (en bas);	D6.W	hauteur  sauter (en haut); out	-; mod	D7.WAFFDOWN:	PUSHM.L	D0,D2..D6,A4	EX.L	D4,D2	CALL	DISROLLUP	EX.L	D2,D4	LOAD.L	(A5)+OPDA,A4	; mm ^dbut affichage	LOAD.W	(A5)+OHDA,D6	; mm hauteur  sauter	LOAD.W	D0,D4	SUB.W	D0,D2		; D0 <-- nb points ok ( sauter)	CLR.W	D3		; D3 <-- position Y dbut ligne20$:	CALL	SRCHTL		; D4 <-- hauteur de la ligne	SUB.W	D4,D6	COMP.W	D0,D4		; encore sauter cette ligne ?	JUMP',LO 40$		; non => 40$	CALL	SRCDOWN		; saute une ligne ok	CLR.W	D6	ADD.W	D3,D4		; D3 <-- position Y ligne suivante	SUB.W	D0,D4	JUMP	20$40$:	TEST.L	D4:#BAFFIMA	; image dans tranche ?	JUMP',BS 45$		; oui => 45$	ADD.W	D2,D0		; D2 <-- hauteur  repeindre	CLR.W	D6	JUMP'	50$45$:				; image => ne repeint pas tout	ADD.W	D3,D0		; D3 <-- saute hauteur dj peinte	ADD.W	D6,D050$:	CALL	SRCHTL		; D4 <-- hauteur de la ligne	SUB.W	D4,D6	CLR.W	D5	COMP.W	D2,D4		; reste place pour toute la ligne ?	JUMP',HS 60$		; oui => 60$	LOAD.W	D5,D4		; non =>	SUB.W	D5,D2		; D5 <-- hauteur en trop	LOAD.W	D4,D2		; D4 <-- hauteur restante60$:	CALL	AFFLINE		; affiche une ligne	CLR.W	D6	ADD.W	D3,D4		; D3 <-- position Y ligne suivante	SUB.W	D2,D4	JUMP,HI	50$90$:	POPM.L	D0,D2..D6,A4	RET; Recherches rapides de dbuts de lignes; --------------------------------------; Les schmas ci-dessous donnent les pointeurs rendus pour les; recherches en avant et/ou en arrire :;	abc<cr> <image> def<cr>;	|       |       |;	abc <image> def<cr>;	|           |;--------\\; SRCUP   >;========/; Cherche le dbut de la ligne prcdente (contre en haut).; in	A4.L	^dans buffer; out	A4.L	^une ligne plus haut;	D7.W	erreur; mod	D7.W, A4.LSRCUP:	PUSH.W	D3	CALL	_TPVISU		; recule un caractre de toute faon	JUMP',NE 90$40$:	CALL	_QUICKUP	; cherche contre en haut	JUMP',NE 80$	COMP.B	D3,#FINCOM	; fin d'une commande ?	JUMP',EQ 60$		; oui => 60$	TEST.L	D3:#BEOL	; fin de la ligne ?	JUMP,BC	40$		; non => 40$				; oui =>	INC.L	A4		; saute TEOL, PEOL, etc.	JUMP'	90$60$:	INC.L	A4		; A4 <-- ^aprs la commande	CALL	_PVISU		; recule la commande	JUMP	40$80$:	CLR.W	D7		; D7 <-- ok90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; SRCDOWN >;========/; Cherche le dbut de la ligne suivante (contre en bas).; in	A4.L	^dans buffer; out	A4.L	^une ligne plus bas;	D7.W	erreur; mod	D7.W, A4.LSRCDOWN:	PUSH.W	D3	CALL	_TNVISU		; A4 <-- avance d'un caractre	JUMP',NE 90$	CALL	IFIEOL		; fin de ligne/image ?	JUMP',EQ 90$		; oui => 90$40$:	CALL	_QUICKDOWN	; cherche contre en bas	JUMP',NE 80$	COMP.B	D3,#DEBCOM	; dbut d'une commande ?	JUMP',EQ 60$		; oui => 60$	TEST.L	D3:#BEOL	; fin de la ligne ?	JUMP,BC	40$		; non => 40$	COMP.B	D3,#DEBIMA	; dbut image ?	JUMP',EQ 70$		; oui => 70$	COMP.B	D3,#DEBREG	; dbut rglette ?	JUMP',EQ 70$		; oui => 70$	JUMP'	90$		; non => 90$60$:	DEC.L	A4		; A4 <-- ^avant la commande	CALL	_NVISU		; saute la commande	JUMP	40$70$:	DEC.L	A4		; recule sur image/rglette	CALL	_NVISU		; saute image/rglette80$:	CLR.W	D7		; D7 <-- ok90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; SRCHTL  >;========/; Calcul la hauteur d'une ligne. Cette routine doit tre optimise; car elle est appele trs souvent.; in	A4.L	^dbut de la ligne; out	D4.W	hauteur;		 bit BAFFIMA si image;		 bit BAFFREG si rglette;		 si aucun bit =>;	 (A6)+OT1YM.W	 h1 jusqu'en haut;	 (A6)+OT2YM.W	 h2 jusqu'en bas;	(A6)+OTYR.W	hauteur relle (pas forcment paire); mod	D4.L, D7.WSRCHTL:	PUSHM.L	D0..D3,D5,D6,A3,A4	PUSH.L	A4	LOAD.L	A4,#(A5)+OVREG	LOAD.L	A3,#(A6)+OHREG	CALL	COPREGLE	; OHREG <-- OVREG	LOAD.L	A4,#(A5)+OVCOM	LOAD.L	A3,#(A6)+OHCOM	CALL	COPCOMMAND	; OHCOM <-- OVCOM	POP.L	A4	CLR.W	D0		; D0 <-- h1 maximum	CLR.W	D1		; D1 <-- h2 maximum	CLR.L	D4		; D4 <-- interligne maximum	LOAD.W	D2,#-1		; D2 <-- dernier gencar/mode05$:	COMP.L	A4,(A5)+OPDT	; est-on au dbut du trou ?	JUMP',NE 06$		; non => 06$	LOAD.L	A4,(A5)+OPFT	; oui => saute le trou06$:	COMP.L	A4,(A5)+OPFB	; est-on tout  la fin du texte ?	JUMP',EQ 10$		; oui => 10$	LOAD.B	D3,(A4)	COMP.B	D3,#SAJEXM	; sajex pour faire la marge gauche ?	JUMP',NE 07$		; non => 07$	CALL	_NVISU		; oui => saute la marge gauche	JUMP	05$07$:	COMP.B	D3,#DEBCOM	; commande au dbut de la ligne ?	JUMP',NE 10$		; non => 10$	CALL	_NVISU		; oui => prend-la en compte tout de suite !10$:	COMP.W	D2,(A5)+OVCOM+OCOMNOG ; gencar/mode identique au prcdent ?	JUMP',EQ 30$		; oui => 30$	LOAD.W	D2,(A5)+OVCOM+OCOMNOG ; D2 <-- gencar/mode	LOAD.W	D3,D2	SR.W	D3,#8		; D3.W <-- gencar	MUL.WU	D3,#LGGC	LOAD.L	A3,#(A6)+OBUGC	ADD.L	A3,D3		; A3 <-- ^dans OBUGC	LOAD.W	D5,(A3)+OGC1Y	; D5 <-- h1	LOAD.W	D6,(A3)+OGC2Y	; D6 <-- h2	TEST.L	D2:#BMODDOWN	JUMP',BS 13$	TEST.L	D2:#BMODUP	JUMP',BC 15$				; mode exposant (up) =>	LOAD.W	D3,D5	SR.W	D3,#1		; D3 <-- hauteur  monter	ADD.W	D5,D3		; D5 <-- augmente h1	SUB.W	D6,D3		; D6 <-- diminue h2	JUMP'	15$13$:				; mode indice (down) =>	LOAD.W	D3,D5	SR.W	D3,#1		; D3 <-- hauteur  descendre	SUB.W	D5,D3		; D5 <-- diminue h1	ADD.W	D6,D3		; D6 <-- augmente h215$:	COMP.W	D0,D5		; h1 plus grand ?	JUMP',GE 20$		; non => 20$	LOAD.W	D0,D5		; oui => prend le plus grand20$:	COMP.W	D1,D6		; h2 plus grand ?	JUMP',GE 25$		; non => 25$	LOAD.W	D1,D6		; oui => prend le plus grand25$:;;?	COMP.W	D4,(A3)+OGCITL	; interligne plus grand ?;;?	JUMP',GE 30$		; non => 30$;;?	LOAD.W	D4,(A3)+OGCITL	; oui => prend le plus grand30$:	CALL	_QUICKDOWN	; cherche plus bas	JUMP',NE 35$	TEST.L	D3:#BEOL	; fin de la ligne ?	JUMP',BS 40$		; oui => 40$	COMP.B	D3,#DEBCOM	; changement de caractres ?	JUMP,NE	30$		; non => 30$	DEC.L	A4		; oui =>	CALL	_NVISU		; A4 <-- saute le changement	JUMP	10$35$:	LOAD.B	D3,#TEOT	; D3 <-- fin du texte40$:	LOAD.W	D4,D0	ADD.W	D4,D1		; D4 <-- hauteur totale utilise	LOAD.W	D2,(A6)+OITL	; D2 <-- interligne standard simple	LOAD.B	D5,(A5)+OVREG+OREGITL	COMP.B	D5,#ITL2	JUMP',EQ 45$	COMP.B	D5,#ITL12	JUMP',NE 46$		; D2 <-- 1 * itl	LOAD.W	D5,D2	SR.W	D5,#1	ADD.W	D2,D5		; D2 <-- 1.5 * itl	JUMP'	46$45$:	SL.W	D2,#1		; D2 <-- 2 * itl46$:	COMP.W	D4,D2		; ligne plus haute qu'il faudrait ?	JUMP',HS 47$		; oui => 47$	LOAD.W	D4,D2		; non => prend l'interligne standard47$:	LOAD.W	D5,D4	SUB.W	D5,D0	SUB.W	D5,D1	JUMP',NS 50$;;?	SR.W	D5,#1		; D5 <-- (D4-(D0+D1))/2CLR.W D5 ; <<<<<<<<<<<<<<<<<<<<<<<<<< cale les lignes en haut <<<<<<<<<<<<<<<<<<<<<<<<<<<<<	ADD.W	D5,D0	LOAD.W	(A6)+OT1YM,D5	SUB.W	D5,D4	NEG.W	D5	LOAD.W	(A6)+OT2YM,D5	JUMP'	55$50$:	LOAD.W	D4,D0	ADD.W	D4,D1		; D4 <-- (D0+D1)	LOAD.W	(A6)+OT1YM,D0	LOAD.W	(A6)+OT2YM,D155$:	COMP.B	D3,#DEBIMA	; dbut d'une image ?	JUMP',EQ 60$		; oui => 60$	COMP.B	D3,#DEBREG	; dbut d'une rglette ?	JUMP',EQ 70$		; oui => 70$	JUMP'	90$60$:				; image =>	DEC.L	A4		; A4 <-- ^DEBIMA	CALL	IMAPARAM	; D4 <-- dimensions (dy;dx)	CLR.W	D4	SWAP.W	D4		; D4 <-- hauteur de l'image	TSET.L	D4:#BAFFIMA	; D4 <-- signal une image !	JUMP'	90$70$:				; rglette =>	CLR.L	D4	TEST.B	(A6)+OFANION+3:#BFAREG ; rglettes visibles ?	JUMP',BC 75$		; non => 75$	LOAD.W	D4,(A6)+OCYR	; oui =>	SL.W	D4,#1	ADD.W	D4,(A6)+OCYR	; D4 <-- prend 3 lignes75$:	TSET.L	D4:#BAFFREG	; D4 <-- signal une rglette !90$:	LOAD.L	A4,#(A6)+OHREG	LOAD.L	A3,#(A5)+OVREG	CALL	COPREGLE	; OVREG <-- OHREG	LOAD.L	A4,#(A6)+OHCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OHCOM	LOAD.W	(A6)+OTYR,D4	; mm. la hauteur relle	TEST.L	D4:#0		; hauteur impaire ?	JUMP',BC 95$		; non => 95$	INC.W	D4		; oui => augmente pour rendre pair	INC.W	(A6)+OT2YM95$:	POPM.L	D0..D3,D5,D6,A3,A4	RET;--------\\; SRCBLIC >;========/; Cherche le dbut de la ligne courante (o est le curseur).; in	A5.L	^description du buffer; out	A4.L	^dbut ligne; mod	D7.W, A4.LSRCBLIC:	PUSH.L	A3	LOAD.L	A4,#(A5)+OCREG	LOAD.L	A3,#(A5)+OVREG	CALL	COPREGLE	; OVREG <-- OCREG	LOAD.L	A4,#(A5)+OCCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OCCOM	LOAD.L	A4,(A5)+OPDT	; A4 <-- ^DT	CALL	SRCBLI		; A4 <-- ^dbut de la ligne	POP.L	A3	RET;--------\\; SRCBLI  >;========/; Cherche le dbut d'une ligne quelconque.; in	A5.L	^description du buffer;	A4.L	^dans une ligne; out	A4.L	^dbut ligne; mod	D7.W, A4.LSRCBLI:	PUSHM.L	D3,A320$:	CALL	_QUICKUP	; A4 <-- recule rapidement	JUMP',NE 90$	COMP.B	D3,#FINCOM	; commande ?	JUMP',EQ 50$		; oui => 50$	TEST.L	D3:#BEOL	; fin de la ligne prcdente ?	JUMP,BC	20$		; non => 20$	JUMP'	80$		; oui => 80$50$:				; commande =>	INC.L	A4		; A4 <-- ^aprs la commande	CALL	_PVISU		; recule la commande	JUMP	20$80$:	INC.L	A4		; A4 <-- saute TEOL, PEOL, IMAGE, etc.90$:	POPM.L	D3,A3	RET;--------\\; AFFLINE >;========/; Affiche une bande horizontale dans la fentre pouvant contenir une; ligne de texte ou une (partie d') image.;		^;=============	|     ======== haut de la fentre ====;    ^		|  D6;    |	D3	|;    v		v;   ----|-------------------------------------;	|	^;	|	|  D4		ligne/image;	|	v;	|------------------------------;		^;		|  D5;		v; in	A5.L	^description du buffer;	A4.L	^dans le buffer (dbut ligne);	D3.W	position Y dbut ligne (haut de la ligne);	D4.W	hauteur de la ligne (BAFFIMA ou BAFFREG);	D5.W	hauteur en trop (contre en bas);	D6.W	hauteur en trop (contre en haut); out	A4.L	^dans le buffer (dbut ligne suivante); mod	D7.W, A4.LAFFLINE:	PUSHM.L	D0..D5,A1,A2	CALL	ITLMOUSE	; enlve souris si dans cette ligne	TEST.L	D4:#BAFFIMA	; est-ce une image ?	JUMP',BC 10$		; non => 10$	CALL	AFFIMAGE	; oui => affiche une image	JUMP	95$10$:	TEST.L	D4:#BAFFREG	; est-ce une rglette ?	JUMP',BC 20$		; non => 20$	CALL	AFFREGLE	; oui => affiche une rglette	JUMP	95$20$:	PUSHM.L	A3,A4	LOAD.L	A4,#(A5)+OVCOM	LOAD.L	A3,#(A6)+OMCOM	CALL	COPCOMMAND	; OMCOM <-- OVCOM	POPM.L	A3,A4	OR.W	D5,D6		; place pour toute la hauteur ?	JUMP',EQ 25$		; oui => 25$	CALL	AFFVIDE		; non => efface bande horizontale	JUMP	95$25$:	LOAD.L	D1,#-1	LOAD.L	(A6)+OMZHP,D1	LOAD.L	(A6)+OMZBP,D1	LOAD.L	A1,A4		; A1 <-- ^dbut de la ligne	CALL	AFFPLI		; positionne au dbut ligne	LOAD.W	D5,D3		; D5 <-- position Y dbut ligne	CALL	CALOFFSET	; D2 <-- dcalage ligne et D0 <-- lg  sauter	LOAD.W	D1,(A6)+OXWDT	; D1 <-- largeur d'une ligne	SUB.W	D1,(A6)+OCX	; D1 <-- laisse un car  droite (curseur)	ADD.W	D1,D2		; D1 <-- position  ne pas dpasser	ADD.W	D1,D0		; D1 <-- tient compte fraction caractre;;?	ADD.W	D1,(A5)+OVREG+OREGMGG;;?	ADD.W	D2,(A5)+OVREG+OREGMGG40$:	CALL	_NVISU		; D3 <-- caractre suivant	JUMP',EQ 50$		; ok => 50$	COMP.W	D7,#ERTHOL	; trou rencontr ?	JUMP',NE 60$		; non (EOB) => 60$	CALL	CURSTYPO	; D3 <-- position du curseur typo	LOAD.L	(A5)+OCURS,D3	; mm position du curseur	LOAD.L	(A5)+OPDL,A1	; mm ^dbut de la ligne	LOAD.W	(A5)+OHTL,D4	; mm hauteur de la ligne	LOAD.W	(A5)+OPOSYL,D5	; mm position Y dbut ligne	PUSHM.L	A3,A4	LOAD.L	A4,#(A5)+OVREG	LOAD.L	A3,#(A5)+OLREG	CALL	COPREGLE	; OLREG <-- OVREG	LOAD.L	A4,#(A6)+OMCOM	LOAD.L	A3,#(A5)+OLCOM	CALL	COPCOMMAND	; OLCOM <-- OMCOM	POPM.L	A3,A4	JUMP	40$50$:	CALL	IFIEOL		; fin de la ligne ?	JUMP',EQ 70$		; oui => 70$	CALL	AFFTYPO		; affiche caractre et compte largeur dans D2	COMP.W	D2,D1		; largeur dpasse ?	JUMP,LO	40$		; non => 40$	CALL	SRCDOWN		; A4 <-- ^dbut ligne suivante	JUMP'	80$60$:				; fin du texte =>	TSET.B	(A5)+OFLAFF:#BAFEOT	JUMP',BS 80$	LOAD.B	D3,#CAREOT	LOAD.W	D2,#SETDOT	CLR.W	D4	CALL	DISAFCAR	; affiche la fin du texte	JUMP'	80$70$:				; fin de la ligne =>	COMP.B	D3,#TEOP	JUMP',EQ 85$	COMP.B	D3,#PEOP	JUMP',EQ 85$	COMP.B	D3,#TEOL	JUMP',NE 80$	TEST.B	(A6)+OFANION+3:#BFAEOL ; affiche les fins de lignes ?	JUMP',BC 80$		; non => 80$	LOAD.B	D3,#CAREOL	LOAD.W	D2,#SETDOT	CLR.W	D4	CALL	DISAFCAR	; affiche la fin du paragraphe80$:	CALL	DISEFLI		; efface la fin de la ligne	JUMP'	90$85$:	CALL	AFFEOP		; affiche fin de page90$:	CLR.L	D4	CLR.L	D3	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	CALL	DISCLEARUP	; efface en haut (vide "buffer")	CALL	DISCLEARDOWN	; efface en bas (vide "buffer")95$:	CALL	DISSCMO		; remet la souris si ncessaire	POPM.L	D0..D5,A1,A2	RET;--------\\; AFFVIDE >;========/; Efface toute une bande horizontale.; in	D3.W	dbut Y (haut);	D4.W	hauteur  effacer; out	-; mod	D7.WAFFVIDE:	PUSHM.L	D0..D4	EX.L	D3,D4	SWAP.W	D4		; D4 <-- yy	CLR.W	D4		; D4 <-- xx	SWAP.W	D3		; D3 <-- dyy	LOAD.W	D3,(A6)+OXWDT	; D3 <-- dxx	LOAD.W	D2,#CLRDOT	; D2 <-- mode	CLR.L	D0		; D0 <-- trame	CLR.L	D1		; D1 <-- trame	CALL	DISTRAME	POPM.L	D0..D4	RET;----------\\; CALOFFSET >;==========/; Saute ventuellement un bout au dbut de la ligne en fonction; de la position de l'ascenseur horizontal.;	|<------------->|         dcalage demand (ascenseur);	|-----|-----|-----|---------------;	|  A  |  B  |  C  |  ...;	|-----|-----|-----|-------------;	|           |<->|         = D0;	|<--------->|             = D2;	|            |;	             A4; in	A4.L	^dbut ligne; out	A4.L	^dbut pour affichage;	D2.W	offset (0..n);	D0.W	lg  sauter; mod	D0.L, D2.L, D7.W, A4.LCALOFFSET:	PUSHM.L	D1,D3	CLR.W	D0	LOAD.W	D2,(A6)+OSCROLH+OSCPOSV	JUMP,EQ 90$	LOAD.W	D1,D2		; D1 <-- lg  ne pas dpasser	CLR.W	D2		; D2 <-- lg totale10$:	CALL	_TNVISU		; D3 <-- caractre suivant	JUMP',NE 30$		; fin du buffer => 30$	CALL	IFIEOL		; fin de la ligne ?	JUMP',NE 50$		; non => 50$				; oui =>	CALL	_TPVISU30$:	LOAD.W	D2,D1		; D2 <-- dcalage selon ascenseur	CLR.W	D0		; D0 <-- rien  sauter	JUMP'	90$50$:	LOAD.W	D0,D2	CALL	_VADDLGC	; D2 <-- compte largeur du caractre	COMP.W	D2,D1	JUMP,LO 10$	JUMP,EQ 30$	CALL	_TPVISU		; recule le caractre fractionn	LOAD.W	D2,D0		; D2 <-- lg jusque l	SUB.W	D0,D1	NEG.W	D0		; D0 <-- lg  sauter90$:	POPM.L	D1,D3	RET;---------\\; CURSTYPO >;=========/; Donne la position du curseur typo en tenant compte des modes; exposant et indice.; in	-; out	D3.L	position (y;x); mod	D3.L, D7.WCURSTYPO:	PUSHM.L	D4,A3	CALL	DISGETCURS	; D3 <-- position du curseur	CLR.W	D4	LOAD.B	D4,(A5)+OVCOM+OCOMNOG ; D4 <-- no du gencar	MUL.WU	D4,#LGGC	LOAD.L	A3,#(A6)+OBUGC	ADD.L	A3,D4		; A3 <-- ^dans OBUGC	TEST.B	(A5)+OVCOM+OCOMMOD:#BMODDOWN	JUMP',BS 30$	TEST.B	(A5)+OVCOM+OCOMMOD:#BMODUP	JUMP',BC 90$				; exposant =>	LOAD.W	D4,(A3)+OGC1Y	SR.W	D4,#1		; D4 <-- hauteur  monter	SWAP.W	D3	SUB.W	D3,D4		; D3 <-- monte un peu	SWAP.W	D3	JUMP'	90$30$:				; indice =>	LOAD.W	D4,(A3)+OGC1Y	SR.W	D4,#1		; D4 <-- hauteur  descendre	SWAP.W	D3	ADD.W	D3,D4		; D3 <-- descend un peu	SWAP.W	D390$:	POPM.L	D4,A3	RET;--------\\; INKCURS >;========/; Inverse le dernier curseur dessin dans l'cran.; in	-; out	-; mod	D7.WINKCURS:	PUSHM.L	D3,D5	LOAD.W	D5,(A6)+ONOWDT	LIB	?USEWDO		; utilise swdo du texte	LOAD.L	D3,(A5)+OCURS	; D3 <-- position du curseur	CALL	INVCURS		; inverse le curseur	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	CALL	DISSCMO		; remet la flche de la souris	POPM.L	D3,D5	RET;--------\; INVCURS >;========/; Inverse le triangle du curseur sur l'cran.; in	D3.L	coordonne d'un caractre; out	-; mod	D7.WINVCURS:	PUSHM.L	D2..D4	TSET.B	(A5)+OFLAFF:#BAFCUR ; curseur dj affich ?	JUMP',BC 90$		; non => 90$				; oui =>	LOAD.L	D4,D3	JUMP',EQ 90$		; si pas de curseur => 90$	LOAD.W	D3,(A6)+OCX	; D3 <-- largeur du triangle	SR.W	D3,#1		; D3 <-- demi largeur	SUB.W	D4,D3		; D4 <-- recule 1/2 caractre	JUMP',HS 10$	CLR.W	D410$:	CALL	DISTYPOAX	; positionne en X	SWAP.W	D4	ADD.W	D4,(A6)+OC2Y	; D4 <-- sous ligne de base	LOAD.W	D3,(A6)+OYWDT	SUB.W	D3,(A6)+OC2Y	; D3 <-- maximum  ne pas dpasser	COMP.W	D4,D3		; est-on trop bas ?	JUMP',LS 20$		; non => 20$	LOAD.W	D4,D3		; oui => remonte un peu20$:	CALL	DISTYPOAY	; positionne en Y	SUB.W	D4,(A6)+OC1Y	; D4 <-- position en haut	SWAP.W	D4	SUB.W	D4,(A6)+OC1X	; D4 <-- position  gauche	LOAD.W	D3,(A6)+OCY	; D3 <-- hauteur	SWAP.W	D3	LOAD.W	D3,(A6)+OCX	; D3 <-- largeur	CALL	ITGMOUSE	; enlve souris si ncessaire	LOAD.B	D3,#CODCUR	; affiche le triangle	LOAD.W	D2,#INVDOT	CALL	DISDAFCAR90$:	POPM.L	D2..D4	RET;---------\\; BIGCURS  >;=========/; Signal qu'il faudra allumer le grand curseur sur l'cran.; in	-; out	-; mod	D7.WBIGCURS:	TEST.B	(A6)+OFANION+3:#BFABIG ; utilise le "big-curseur" ?	JUMP',BC 90$		; non => 90$	TSET.B	(A5)+OFLAFF:#BBIGCUR90$:	RET;---------\; IBIGCURS >;=========/; Inverse le grand curseur sur l'cran.; in	-; out	-; mod	D7.WIBIGCURS:	PUSHM.L	D1..D5,A2	TEST.L	(A5)+OCURS	; curseur existe ?	JUMP,EQ 90$		; non => 90$	CALL	_GETPTC		; D3 <-- caractre sous le curseur	JUMP',NE 10$	COMP.B	D3,#REGLE	; est-on sur une rglette ?	JUMP,EQ 90$		; oui => 90$10$:	LOAD.W	D5,(A6)+ONOWDT	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE	JUMP',BS 20$	LOAD.W	D5,(A6)+ONOWDP20$:	LIB	?USEWDO		; utilise swdo du texte	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	PUSH.B	(A2)+ODFMGR	LOAD.B	(A2)+ODFMGR,#GRACLIP	LOAD.L	D1,(A5)+OCURS	; D1 <-- position du curseur	SWAP.W	D1	INC.W	D1		; D1 <-- un p'tit peu plus bas	SWAP.W	D1	LOAD.W	D5,(A6)+OCY	SL.W	D5,#2		; D5 <-- OCY*4	LOAD.L	D4,D1		; D4 <-- position du centre	SUB.W	D4,D5	SWAP.W	D4	SUB.W	D4,D5	SWAP.W	D4	LOAD.W	D3,D5	ADD.W	D3,D5	SWAP.W	D3	LOAD.W	D3,D5	ADD.W	D3,D5	SWAP.W	D3	CALL	ITGMOUSE	; enlve souris si ncessaire	LOAD.L	D4,D1		; D4 <-- centre du cercle	LOAD.W	D3,D5		; D3 <-- rayon	SUB.W	D3,(A6)+OCY	; D3 <-- rayon un poil plus p'tit	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	DISCIRCLE	; dessine un cercle	LOAD.L	D4,D1		; D4 <-- position du curseur	SUB.W	D4,D5	CLR.L	D3	LOAD.W	D3,D5	ADD.W	D3,D5	CALL	DISLINE		; met ligne horizontale (dessus)	LOAD.L	D4,D1		; D4 <-- position du curseur	SWAP.W	D4	SUB.W	D4,D5	SWAP.W	D4	LOAD.W	D3,D5	ADD.W	D3,D5	SWAP.W	D3	CLR.W	D3	CALL	DISLINE		; met ligne verticale (droite)	POP.B	(A2)+ODFMGR	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	CALL	DISSCMO		; remet la flche de la souris90$:	POPM.L	D1..D5,A2	RET;--------\\; AFFPLI  >;========/; Positionne le curseur au dbut d'une ligne.; in	D3.W	position Y dbut ligne; out	-; mod	D7.WAFFPLI:	PUSHM.L	D3,D4	LOAD.W	D4,D3		; D4 <-- position Y dbut ligne	ADD.W	D4,(A6)+OT1YM	CALL	DISTYPOAY	LOAD.W	D4,(A6)+OC1X	CALL	DISTYPOAX	LOAD.W	D4,(A6)+OCX;;?	ADD.W	D4,(A5)+OVREG+OREGMGG	PUSH.B	(A5)+OVCOM+OCOMMOD	TCLR.B	(A5)+OVCOM+OCOMMOD:#BMODSOUL	CLR.B	D3		; D3 <-- code	CALL	DISPSPACE	; efface la marge gauche	POP.B	(A5)+OVCOM+OCOMMOD	POPM.L	D3,D4	RET;--------\\; AFFEOP  >;========/; Affiche une ligne horizontale de fin de page.; in	D3.B	caractre TEOP/PEOP; out	-; mod	D7.WAFFEOP:	PUSHM.L	D2..D4	LOAD.W	D2,#SETDOT	; D2 <-- mode si TEOP	COMP.B	D3,#PEOP	; pseudo-fin de page ?	JUMP',NE 10$		; non => 10$	LIB	?AFTIM		; oui =>	.B	MAPTT	.B	B'11111100	; map des traitills	.B	1		; chelle	.B	0	.EVEN	LOAD.W	D2,#SETDOT!TTTDOT10$:	COMP.W	(A5)+OMODIF,#MODALL	JUMP',NE 20$	CALL	DISEFLI		; efface la fin de la ligne20$:	CALL	DISGETCURS	; D3 <-- position du curseur	LOAD.L	D4,D3		; D4 <-- yy/xx	CLR.W	D4		; D4 <-- part tout  gauche	CLR.L	D3		; D3 <-- dyy	LOAD.W	D3,D4	SUB.W	D3,(A6)+OXWDT	NEG.W	D3		; D3 <-- dxx	DEC.W	D3	CALL	DISLINE		; dessine une ligne horizonale	POPM.L	D2..D4	RET;--------\\; AFFTYPO >;========/; Affiche un caractre typographique.; in	D3.W	caractre;	D2.W	position dans la ligne;	D0.W	lg  sauter au dbut;	A4.L	^caractre suivant; out	D2.W	nouvelle position;	D0.W	plus rien  sauter (sauf si tab);	A4.L	^v. plus loin; mod	D0.W, D2.W, D3.W, D7.W, A4.LAFFTYPO:	COMP.B	D3,#SAJEXM	JUMP,EQ 60$	COMP.B	D3,#SAJEXT	JUMP,EQ 65$	COMP.B	D3,#SAJEXS	JUMP,EQ 70$	COMP.B	D3,#SPACE	JUMP',EQ 50$	COMP.B	D3,#TIRET	JUMP,EQ 80$	COMP.B	D3,#COMMAND	; commande ?	JUMP,EQ 95$		; oui => 95$	COMP.B	D3,#TAB		; tabulateur ?	JUMP,EQ 95$		; oui => 95$	COMP.B	D3,#MARQUED	JUMP,EQ 95$	COMP.B	D3,#MARQUEF	JUMP,EQ 95$30$:	PUSH.W	D2	LOAD.W	D2,#SETDOT	; D2 <-- mode	CALL	DISAFCAR	; affiche un caractre	POP.W	D2	JUMP	90$50$:				; SPACE =>	COMP.L	A4,(A5)+OPFB	JUMP,EQ 30$	COMP.B	(A4),#PEOL	; pseudo-fin de ligne juste aprs ?	JUMP,NE	30$		; non => 30$				; oui =>	PUSH.B	(A5)+OVCOM+OCOMMOD	TCLR.B	(A5)+OVCOM+OCOMMOD:#BMODSOUL	PUSH.W	D2	LOAD.W	D2,#SETDOT	CALL	DISAFCAR	; affiche un caractre sans soulignement	POP.W	D2	POP.B	(A5)+OVCOM+OCOMMOD	JUMP	90$60$:				; SAJEXM =>	PUSH.W	D4	PUSH.B	(A5)+OVCOM+OCOMMOD	TCLR.B	(A5)+OVCOM+OCOMMOD:#BMODSOUL	CALL	_MSVISU		; D4 <-- largeur de l'espace	SUB.W	D4,D0		; D4 <-- enlve lg  sauter au dbut	CALL	DISPSPACE	; affiche un espace proportionnel	POP.B	(A5)+OVCOM+OCOMMOD	ADD.W	D2,D4		; D2 <-- largeur SAJEXMs	POP.W	D4	JUMP	92$65$:				; SAJEXT =>	PUSH.W	D4	PUSH.B	(A5)+OVCOM+OCOMMOD	TCLR.B	(A5)+OVCOM+OCOMMOD:#BMODSOUL	CALL	_MSVISU		; D4 <-- largeur de l'espace	SUB.W	D4,D0		; D4 <-- enlve lg  sauter au dbut	CALL	DISPSPACE	; affiche un espace proportionnel	POP.B	(A5)+OVCOM+OCOMMOD	ADD.W	D2,D4		; D2 <-- largeur SAJEXTs	POP.W	D4	JUMP'	92$70$:				; SAJEXS =>	PUSH.W	D4	CALL	_MSVISU		; D4 <-- largeur de l'espace	SUB.W	D4,D0		; D4 <-- enlve lg  sauter au dbut	CALL	DISPSPACE	; affiche un espace proportionnel	ADD.W	D2,D4		; D2 <-- largeur SAJEXSs	POP.W	D4	JUMP'	92$80$:				; TIRET =>	LOAD.B	D3,#'-	JUMP	30$90$:	CALL	_VADDLGC	; D2 <-- compte la largeur92$:	CLR.W	D0		; D0 <-- plus rien  sauter95$:	RET;--------\\; AFMENU  >;========/; Remet le menu standard pour les soft-keys.; in	-; out	-; mod	D7.WAFMENU:	PUSH.L	A3	LOAD.L	A3,#R16"TXMENU	LIB	?AFMENU	POP.L	A3	RETTXMENU:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"      Ajoute     "	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" Df. Image Rgle"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" Car. Frap.Change"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Just. Param. Va "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Tout  Efface Imp."		;     ;     ;     ;	.EVEN	.END