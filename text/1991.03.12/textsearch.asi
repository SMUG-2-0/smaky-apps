	.SBTTL	TEXTSEARCH; touche (SEARCH); ---------------OSEARCH:	CALL	EXKEY	.WW	'F	SCAV	; cherche en avant	.WW	'D	SCAR	; cherche en arrire	.WW	'C	CPTAV	; compte en avant	.WW	'R	CPTAR	; compte en arrire	.WW	'T	CPTT	; compte partout	.WW	'	SCERR	; cherche erreur AS	.WW	'E	SCERR	; idem (SEARCH-^)	.WW	0	NMAIN; touche (CHANGE); ---------------OCHANGE:	CALL	EXKEY	.WW	'F	CHAV	; change suivant	.WW	'D	CHAR	; change prcdent	.WW	'C	CHIAV	; if-change tout en avant	.WW	'R	CHIAR	; if-change tout en arrire	.WW	'X	CHTAV	; change tout en avant	.WW	'E	CHTAR	; change tout en arrire	.WW	'T	CHTT	; change tout	.WW	0	NMAINDOSEARCH:	CALL	DBOXSEARCH	; dfinit les deux chanes ...	JUMP,NE	MAIN	COMP.W	D3,#F1	JUMP,EQ	SCTAR	COMP.W	D3,#F3	JUMP,EQ	SCTAV	COMP.W	D3,#F4	JUMP,EQ	CPTAR	COMP.W	D3,#F6	JUMP,EQ	CPTAV	COMP.W	D3,#F7	JUMP,EQ	CHIAR	COMP.W	D3,#F9	JUMP,EQ	CHIAV	JUMP	MAIN; SEARCH -->	(cherche en avant)SCAV:	LOAD.L	A3,#(A6)+OSEAST1	CALL	SEAV		; cherche en avant	JUMP,NE	SERROR	CALL	BIGCURS		; met le grand curseur	RET; SEARCH <--	(cherche en arrire)SCAR:	LOAD.L	A3,#(A6)+OSEAST1	CALL	SEAR		; cherche en arrire	JUMP,NE	SERROR	CALL	BIGCURS		; met le grand curseur	RET; SEARCH -->	(cherche tout en avant)SCTAV:	LOAD.L	A3,#(A6)+OSEAST130$:	CALL	SEAV		; cherche en avant	JUMP,NE	MAIN	CALL	AFFBUF		; montre la situation	CALL	IBIGCURS	; dessine le grand curseur	CALL	DBOXCHERCHE	; attend choix ...	CALL	IBIGCURS	; enlve le grand curseur	COMP.W	D3,#CR		; (Suivant) ?	JUMP,EQ 30$		; oui => 30$	JUMP	MAIN; SEARCH <--	(cherche tout en arrire)SCTAR:	LOAD.L	A3,#(A6)+OSEAST130$:	CALL	SEAR		; cherche en arrire	JUMP,NE	MAIN	CALL	AFFBUF		; montre la situation	CALL	IBIGCURS	; dessine le grand curseur	CALL	DBOXCHERCHE	; attend choix ...	CALL	IBIGCURS	; enlve le grand curseur	COMP.W	D3,#CR		; (Suivant) ?	JUMP,EQ 30$		; oui => 30$	JUMP	MAIN; SEARCH up	(compte en arrire)CPTAR:	LOAD.L	A3,#(A6)+OSEAST1	LOAD.L	A4,(A5)+OPFT	; A4 <-- position actuelle du trou	CLR.W	D4		; D4 <-- init compteur10$:	CALL	SEAR		; cherche en arrire	JUMP,NE	CPTEX		; pas trouv => CPTEX	INC.W	D4		; D4 <-- une occurence de plus	JUMP	10$; SEARCH end	(compte tout)CPTT:	CALL	_VADEBUT	; revient au dbut;	JUMP	CPTAV		; puis compte en avant ...; SEARCH down	(compte en avant)CPTAV:	LOAD.L	A3,#(A6)+OSEAST1	LOAD.L	A4,(A5)+OPDT	; A4 <-- position actuelle du trou	CLR.W	D4		; D4 <-- init compteur10$:	CALL	SEAV		; cherche en avant	JUMP,NE	CPTEX		; pas trouv => CPTEX	INC.W	D4		; D4 <-- une occurence de plus	JUMP	10$CPTEX:	CALL	_VAQQPART	; remet le curseur o il tait	CALL	DBOXOCCURENCE	; affiche le nombre d'occurences	RET; SEARCH errorSCERR:	PUSH.B	(A6)+OSEAMOD	CLR.B	(A6)+OSEAMOD	LOAD.L	A3,#R16"TXSERR	; A3 <-- ^chane d'erreur	CALL	SEAV		; cherche en avant	POP.B	(A6)+OSEAMOD	TEST.W	D7	JUMP,NE	SERROR	CALL	BIGCURS		; met le grand curseur	RET; CHANGE -->	(substitue en avant)CHAV:10$:	CALL	_RECULE	CALL	IFCPSEUDO	JUMP,EQ	10$	COMP.B	D3,#PEOL	JUMP,EQ	10$	LOAD.L	A3,#(A6)+OSEAST1	LOAD.L	A4,#(A6)+OSEAST2	CALL	SEAV		; cherche en avant	JUMP,NE	SERROR	CALL	AFFBUF		; affiche aprs le dplacement	CALL	DOCHANGE	CALL	BIGCURS		; met le grand curseur	RET; CHANGE <--	(substitue en arrire)CHAR:10$:	CALL	_AVANCE	CALL	IFCPSEUDO	JUMP,EQ	10$	COMP.B	D3,#PEOL	JUMP,EQ	10$	LOAD.L	A3,#(A6)+OSEAST1	LOAD.L	A4,#(A6)+OSEAST2	CALL	SEAR		; cherche en arrire	JUMP,NE	SERROR	CALL	AFFBUF		; affiche aprs le dplacement	CALL	DOCHANGE	CALL	DOARRIERE	CALL	BIGCURS		; met le grand curseur	RET; CHANGE ==>	(substitue conditionnellement tout en avant)CHIAV:	LOAD.L	A3,#(A6)+OSEAST1	LOAD.L	A4,#(A6)+OSEAST220$:	CALL	_RECULE	CALL	IFCPSEUDO	JUMP,EQ	20$	COMP.B	D3,#PEOL	JUMP,EQ	20$30$:	CALL	SEAV		; cherche en avant	JUMP',NE 90$	CALL	AFFBUF		; montre la situation	CALL	IBIGCURS	; dessine le grand curseur	CALL	DBOXCHANGE	; attend choix ...	CALL	IBIGCURS	; enlve le grand curseur	COMP.W	D3,#F4		; (Suivant) ?	JUMP,EQ 30$	COMP.W	D3,#F7		; (Partout) ?	JUMP,EQ CHTAV	COMP.W	D3,#F10		; (Un) ?	JUMP',EQ 50$	COMP.W	D3,#F1		; (Change) ?	JUMP,NE	MAIN	CALL	DOCHANGE	; effectue le changement	CALL	AFFBUF		; montre la situation	JUMP	20$50$:	CALL	DOCHANGE90$:	CALL	AFFBUF		; montre la situation	JUMP	MAIN; CHANGE <==	(substitue conditionnellement tout en arrire)CHIAR:	LOAD.L	A3,#(A6)+OSEAST1	LOAD.L	A4,#(A6)+OSEAST220$:	CALL	_AVANCE	CALL	IFCPSEUDO	JUMP,EQ	20$	COMP.B	D3,#PEOL	JUMP,EQ	20$30$:	CALL	SEAR		; cherche en arrire	JUMP',NE 90$	CALL	AFFBUF		; montre la situation	CALL	IBIGCURS	; dessine le grand curseur	CALL	DBOXCHANGE	; attend choix ...	CALL	IBIGCURS	; enlve le grand curseur	COMP.W	D3,#F4		; (Suivant) ?	JUMP,EQ 30$	COMP.W	D3,#F7		; (Partout) ?	JUMP,EQ CHTAR	COMP.W	D3,#F10		; (Un) ?	JUMP',EQ 50$	COMP.W	D3,#F1		; (Change) ?	JUMP,NE	MAIN	CALL	DOCHANGE	; effectue le changement	CALL	DOARRIERE	CALL	AFFBUF		; montre la situation	JUMP	20$50$:	CALL	DOCHANGE	CALL	DOARRIERE90$:	CALL	AFFBUF		; montre la situation	JUMP	MAIN; CHANGE all	(substitue tout)CHTT:	CALL	_VADEBUT	; revient au dbut;	JUMP	CHTAV; CHANGE ==>	(substitue tout en avant)CHTAV:	LOAD.L	A3,#(A6)+OSEAST1	LOAD.L	A4,#(A6)+OSEAST220$:	CALL	_RECULE	CALL	IFCPSEUDO	JUMP,EQ	20$	COMP.B	D3,#PEOL	JUMP,EQ	20$	CALL	SEAV		; cherche en avant	JUMP',NE 90$	CALL	DOCHANGE	; effectue le changement	JUMP	20$90$:	LOAD.W	D4,#MODALL	CALL	MODIF	CALL	BIGCURS		; met le grand curseur	RET; CHANGE <==	(substitue tout en arrire)CHTAR:	LOAD.L	A3,#(A6)+OSEAST1	LOAD.L	A4,#(A6)+OSEAST220$:	CALL	_AVANCE	CALL	IFCPSEUDO	JUMP,EQ	20$	COMP.B	D3,#PEOL	JUMP,EQ	20$	CALL	SEAR		; cherche en arrire	JUMP',NE 90$	CALL	DOCHANGE	; effectue le changement	CALL	DOARRIERE	JUMP	20$90$:	LOAD.W	D4,#MODALL	CALL	MODIF	CALL	BIGCURS		; met le grand curseur	RETSERROR:	LOAD.W	D7,#ERTNOT	JUMP	_IOERROR	; affiche "pas trouv";--------\; SEAV    >;========/; Cherche une chane en avant.; in	A3.L	^chane cherche; out	D7.W	erreur; mod	D7.WSEAV:	PUSHM.L	D2,D3,A2,A4	CALL	SWMO		; souris: met le sablier10$:	CALL	_AVANCE		; avance d'un caractre	JUMP,NE 90$		; fin du buffer => 90$	CALL	IFCPSEUDO	JUMP,EQ	10$	COMP.B	D3,#PEOL	JUMP,EQ	10$	LOAD.L	A4,(A5)+OPFT	LOAD.L	A2,A3		; A2 <-- ^chane  chercher	TEST.B	(A6)+OSEAMOD:#BSEAMIMA ; recherche a=A ?	JUMP,BC	30$		; non => 30$20$:	TEST.B	(A2)		; fin chane de recherche ?	JUMP,EQ 40$		; oui => 40$ (presque trouv)	LOAD.B	D3,(A2+)	CALL	MINMAJ		; D3 <-- majuscule	LOAD.B	D2,D325$:	CALL	_NVISU		; D3 <-- caractre suivant	JUMP,NE 10$	CALL	IFCPSEUDO	JUMP,EQ	25$	COMP.B	D3,#PEOL	JUMP,EQ	25$	CALL	MINMAJ		; D3 <-- majuscule	COMP.B	D3,D2		; caractres gaux ?	JUMP,EQ	20$		; oui => 20$	JUMP	10$		; non => 10$30$:	TEST.B	(A2)		; fin chane de recherche ?	JUMP,EQ 40$		; oui => 40$ (presque trouv)	LOAD.B	D2,(A2+)35$:	CALL	_NVISU		; D3 <-- caractre suivant	JUMP,NE 10$	CALL	IFCPSEUDO	JUMP,EQ	35$	COMP.B	D3,#PEOL	JUMP,EQ	35$	COMP.B	D3,D2		; caractres gaux ?	JUMP,EQ	30$		; oui => 30$	JUMP	10$		; non => 10$40$:	TEST.B	(A6)+OSEAMOD:#BSEAMOT ; recherche d'un mot ?	JUMP',BC 80$		; non => 80$ (trouv)				; oui =>	CALL	_NVISU		; D3 <-- caractre aprs la chane	JUMP',NE 50$	CALL	SDELWO		; dlimiteur de mot ?	JUMP,NE	10$		; non => 10$50$:	LOAD.L	A4,(A5)+OPDT	CALL	_PVISU		; D1 <-- caractre avant la chane	JUMP',NE 80$	CALL	SDELWO		; dlimiteur de mot ?	JUMP,NE	10$		; non => 10$80$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; fait un p'tit bruit	CALL	SPSEUDOAV	; avance encore si pseudo-caractres	CLR.W	D7		; D7 <-- trouv90$:	CALL	CWMO		; souris: plus de sablier	POPM.L	D2,D3,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; SEAR    >;========/; Cherche une chane en arrire.; in	A3.L	^chane cherche; out	D7.W	erreur; mod	D7.WSEAR:	PUSHM.L	D2,D3,A2,A4	CALL	SWMO		; souris: met le sablier10$:	CALL	_RECULE		; recule d'un caractre	JUMP,NE 90$		; dbut du buffer => 90$	CALL	IFCPSEUDO	JUMP,EQ	10$	COMP.B	D3,#PEOL	JUMP,EQ	10$	LOAD.L	A4,(A5)+OPFT	LOAD.L	A2,A3		; A2 <-- ^chane  chercher	TEST.B	(A6)+OSEAMOD:#BSEAMIMA ; recherche a=A ?	JUMP,BC	30$		; non => 30$20$:	TEST.B	(A2)		; fin chane de recherche ?	JUMP,EQ 40$		; oui => 40$ (presque trouv)	LOAD.B	D3,(A2+)	CALL	MINMAJ		; D3 <-- majuscule	LOAD.B	D2,D325$:	CALL	_NVISU		; D3 <-- caractre suivant	JUMP,NE 10$	CALL	IFCPSEUDO	JUMP,EQ	25$	COMP.B	D3,#PEOL	JUMP,EQ	25$	CALL	MINMAJ		; D3 <-- majuscule	COMP.B	D3,D2		; caractres gaux ?	JUMP,EQ	20$		; oui => 20$	JUMP	10$		; non => 10$30$:	TEST.B	(A2)		; fin chane de recherche ?	JUMP,EQ 40$		; oui => 40$ (presque trouv)	LOAD.B	D2,(A2+)35$:	CALL	_NVISU		; D3 <-- caractre suivant	JUMP,NE 10$	CALL	IFCPSEUDO	JUMP,EQ	35$	COMP.B	D3,#PEOL	JUMP,EQ	35$	COMP.B	D3,D2		; caractres gaux ?	JUMP,EQ	30$		; oui => 30$	JUMP	10$		; non => 10$40$:	TEST.B	(A6)+OSEAMOD:#BSEAMOT ; recherche d'un mot ?	JUMP',BC 80$		; non => 80$ (trouv)				; oui =>	CALL	_NVISU		; D3 <-- caractre aprs la chane	JUMP',NE 50$	CALL	SDELWO		; dlimiteur de mot ?	JUMP,NE	10$		; non => 10$50$:	LOAD.L	A4,(A5)+OPDT	CALL	_PVISU		; D1 <-- caractre avant la chane	JUMP',NE 80$	CALL	SDELWO		; dlimiteur de mot ?	JUMP,NE	10$		; non => 10$80$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; fait un p'tit bruit	CALL	SPSEUDOAV	; avance encore si pseudo-caractres	CLR.W	D7		; D7 <-- trouv90$:	CALL	CWMO		; souris: plus de sablier	POPM.L	D2,D3,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; SDELWO  >;========/; Cherche si un caractre est un dlimiteur de mots pour; les recherches de mots.; in	D3.B	caractre; out	EQ	dlimiteur de mots; mod	D1.WSDELWO:	CALL	MINMAJ	COMP.B	D3,#'0	JUMP,LO	70$	COMP.B	D3,#'9	JUMP,LS	80$	COMP.B	D3,#'A	JUMP,LO	70$	COMP.B	D3,#'Z	JUMP,LS	80$70$:	SETZ			; retour EQ	JUMP	90$80$:	CLRZ			; retour NE90$:	RET;---------\\; DOCHANGE >;=========/; Effectue une substitution.; in	A3.L	^chane de recherche;	A4.L	^chane de substitution; out	-; mod	D7.WDOCHANGE:	PUSHM.L	D3,A3,A4	LOAD.B	D3,#MARQUED	CALL	_INSERT		; marque le dbut; Dtruit la chane de recherche.10$:	TEST.B	(A3+)	JUMP',EQ 20$15$:	CALL	_DAVANCE	CALL	IFCPSEUDO	JUMP,EQ	15$	COMP.B	D3,#PEOL	JUMP,EQ	15$	JUMP	10$; Met la chane de substitution  la place.20$:	LOAD.B	D3,(A4+)	JUMP',EQ 50$	COMP.B	D3,#CR	JUMP',NE 30$	LOAD.B	D3,#TEOL30$:	CALL	_INSERT	JUMP	20$; Justifie la zone modifie.50$:	LOAD.B	D3,#MARQUEF	CALL	_INSERT		; marque la fin	CALL	_ZJUSTIF	; justifie la zone	CALL	_ZFJUSTIF	; enlve les marques et va  la fin	POPM.L	D3,A3,A4	RET;----------\\; DOARRIERE >;==========/; Recule aprs une substitution en arrire.; in	A3.L	^chane de recherche;	A4.L	^chane de substitution; out	-; mod	D7.WDOARRIERE:	PUSHM.L	D3,A410$:	TEST.B	(A4+)	JUMP',EQ 90$	CALL	_RECULE		; recule la chane change	JUMP	10$90$:	POPM.L	D3,A4	RET;----------\\; SPSEUDOAV >;----------/; Saute un ou plusieurs pseudo-caractres en avant,; y compris les pseudo-fins de lignes.; in	A5.L	^description d'un buffer; out	-; mod	D7.WSPSEUDOAV:	PUSH.W	D310$:	CALL	_AVANCE		; avance un caractre	JUMP',NE 90$	CALL	IFCPSEUDO	; pseudo-caractre ?	JUMP,EQ	10$		; oui => 10$	COMP.B	D3,#PEOL	JUMP,EQ	10$	CALL	_RECULE		; recule caractre avanc en trop90$:	POP.W	D3	RETTXSERR:	.ASCIZ	/^ /		; chane pour (SEARCH-^)	.EVEN	.END