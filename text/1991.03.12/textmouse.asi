	.SBTTL	TEXTMOUSE; boutons de la souris; --------------------OMOUSE:	CALL	EXKEY	.WW	KEYMGP	MOUSEGP	.WW	KEYMMP	MOUSEMP	.WW	KEYMDP	MOUSEDP	.WW	KEYMGR	MAIN	.WW	KEYMMR	MAIN	.WW	KEYMDR	MAIN	.WW	0	NMAINMOUSEGP:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE	NMAIN	CALL	PDETECTE	; positionne selon la souris	JUMP,EQ	MAIN		; ok => MAIN	LOAD.L	D3,D4	SWAP.W	D3	COMP.W	D3,(A6)+OCYI	; souris dans les informations ?	JUMP,LO 70$		; oui => 70$	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE	JUMP',BS 10$	LOAD.W	D5,(A6)+ONOWDJ	LIB	?USEWDO		; utilise swdo info secondaire	LOAD.L	A4,#R16"TIICOPY	CALL	CIINFO		; D3 <-- code de l'icne slectionne ...	JUMP,EQ 50$10$:	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale;;?	LOAD.W	(A6)+OSCROLL+OSCINC,#10	PUSH.L	A5	LOAD.L	A5,#(A6)+OSCROLL	SCROLL_	MOVE		; est-on dans le drouleur ?	POP.L	A5	JUMP',NE 40$		; non => 40$				; oui =>	COMP.W	D4,#SCROLLFUP	JUMP',EQ 20$	COMP.W	D4,#SCROLLFDOWN	JUMP',EQ 20$	COMP.W	D4,#SCROLLPUP	JUMP',EQ 30$	COMP.W	D4,#SCROLLPDOWN	JUMP',EQ 35$	CALL	GODEROULEUR	; va  l'endroit indiqu	JUMP	MAIN20$:	CALL	QUPDOWN		; monte/descend un moment ...	JUMP	MAIN30$:	CLR.B	D4		; D4 <-- pour les classes	CALL	DBPAGE		; recule d'une page	JUMP	MAIN35$:	CLR.B	D4		; D4 <-- pour les classes	CALL	DPAGE		; avance d'une page	JUMP	MAIN40$:	TEST.B	(A6)+OFANION+2:#BFASCH-8 ; ascenseur horizontal ?	JUMP,BC NMAIN	TEST.B	(A6)+OFLASC:#BASHCA ; juste la cage ?	JUMP,BS NMAIN		; oui => NMAIN	LOAD.W	(A6)+OSCROLH+OSCINC,#100	PUSH.L	A5	LOAD.L	A5,#(A6)+OSCROLH	SCROLL_	MOVE		; est-on dans le drouleur horizontal ?	POP.L	A5	JUMP,NE NMAIN	CALL	ALLSCREENSA	; faut tout repeindre (pas les ascenseurs)	JUMP	MAIN50$:				; souris dans les infos secondaires =>	COMP.W	D3,#ICOCOPZ	JUMP',EQ 55$	COMP.W	D3,#ICOCOPX	JUMP',EQ 57$	COMP.W	D3,#ICOCOPD	JUMP',EQ 60$	CLR.W	D2	COMP.W	D3,#ICOCOPM	JUMP',EQ 52$	INC.W	D252$:	LOAD.W	D0,(A6)+OBUFS+ONOBUF	CALL	COPYSP		; copie zone secondaire --> zone principale	JUMP	MAIN55$:	CALL	MOVEFPS		; dplace la frontire entre les zones;;?	JUMP,NE NMAIN	JUMP	MAIN57$:	LOAD.W	D0,(A6)+OBUFS+ONOBUF	LOAD.W	D1,(A5)+ONOBUF	CALL	_INI2B		; permute les deux zones	JUMP	MAIN60$:				; dtruit la zone secondaire =>	TEST.B	(A6)+OBUFS+OBUMEMF ; nom de fichier associ  la zone ?	JUMP',EQ 62$		; non => 62$	CALL	DBOXSURE	; etes-vous sr ?	JUMP,NE	MAIN		; non => MAIN62$:	LOAD.W	D1,(A5)+ONOBUF	LOAD.W	D0,(A6)+OBUFS+ONOBUF	CALL	_INI1B		; init seulement la zone secondaire	CALL	_FLUSH		; vide tout	LOAD.W	D0,D1	CALL	_INI1B		; remet la zone principale unique	JUMP	MAIN70$:				; souris dans les infos principales =>	TEST.B	(A6)+OFLAGS:#BCALCUL	JUMP,BC	NMAIN	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.L	A4,#R16"TIICALCUL	CALL	CIINFO		; D3 <-- code de l'icne slectionne ...	JUMP,NE NMAIN	COMP.W	D3,#ICOEGAL	; icne (=) ?	JUMP',EQ 75$		; oui => 75$				; non => icne (c)	TCLR.B	(A6)+OFLAGS:#BCALCUL	JUMP	MAIN75$:	TCLR.B	(A6)+OFLAGS:#BCALCUL	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D3,(A6)+OCALCUL+0	LOAD.L	D4,(A6)+OCALCUL+4 ; D3D4 <-- rsultat du calcul	CALL	PUTNUM	LOAD.L	A4,#(A6)+OBUDIS80$:	LOAD.B	D3,(A4+)	JUMP',EQ 85$	CALL	FINSERT		; insre le rsultat	JUMP	80$85$:	CALL	_QJUSTIF	; justifie un p'tit peu	JUMP	MAINMOUSEMP:	COMP.B	(A5)+OACTION,#2^BAKILL	JUMP',EQ 10$	TSET.B	(A6)+OPARMM+LMM*2+OMMINA+3:#0 ; grise la case "annule"10$:	TEST.L	(A6)+OCAPRINT	; imprimante prsente ?	JUMP',NE 12$	TSET.B	(A6)+OPARMM+LMM*1+OMMINA+3:#3 ; grise la case "imprime"12$:	LOAD.L	A3,#R16"TMCHOIX	LOAD.L	A4,#(A6)+OCASMP	; A4 <-- ^variable pour la case	CALL	MMENUS		; attend choix selon menu hirarchique ...	JUMP,NE	NMAIN	LOAD.W	D3,(A4)+LMM*0+OMMSEL	COMP.W	D3,#1	JUMP,EQ	FILE$	COMP.W	D3,#2	JUMP,EQ EDIT$	COMP.W	D3,#3	JUMP,EQ SCREEN$	COMP.W	D3,#4	JUMP,EQ MISC$	CALL	EXOTHER		; action non rcuprable	COMP.W	D3,#5	JUMP,EQ DBOXGENCAR	COMP.W	D3,#6	JUMP,EQ DBOXFRAPPE	JUMP	MAINFILE$:	CALL	EXOTHER		; action non rcuprable	LOAD.W	D3,(A4)+LMM*1+OMMSEL	COMP.W	D3,#0	JUMP,EQ _AINPUT	COMP.W	D3,#1	JUMP,EQ _AAJOUTE	COMP.W	D3,#2	JUMP,EQ COPDEF	COMP.W	D3,#3	JUMP,EQ _DOPRINT	COMP.W	D3,#4	JUMP,EQ RETOUR	JUMP	MAINEDIT$:	LOAD.W	D3,(A4)+LMM*2+OMMSEL	COMP.W	D3,#0	JUMP,EQ EXRECUP	CALL	EXOTHER		; action non rcuprable	COMP.W	D3,#1	JUMP,EQ INSREGLE	COMP.W	D3,#2	JUMP,EQ DBOXIMAGE	COMP.W	D3,#3	JUMP,EQ DOSEARCH	COMP.W	D3,#4	JUMP,EQ DOEFFACE	JUMP	MAINSCREEN$:	CALL	EXOTHER		; action non rcuprable	LOAD.W	D3,(A4)+LMM*3+OMMSEL	COMP.W	D3,#0	JUMP,EQ DBOXPETIT	COMP.W	D3,#1	JUMP,EQ MZONE	COMP.W	D3,#2	JUMP,EQ DOGOTO	JUMP	MAINMISC$:	CALL	EXOTHER		; action non rcuprable	LOAD.W	D3,(A4)+LMM*4+OMMSEL	COMP.W	D3,#0	JUMP,EQ DBOXDEFINE	COMP.W	D3,#1	JUMP,EQ DBOXJUST	COMP.W	D3,#2	JUMP,EQ DBOXPARAM	JUMP	MAINMZONE:	CALL	DBOXZONE	; D3 <-- (RETURN) ou (END)	JUMP,NE NMAIN	COMP.W	D3,#CR	JUMP,NE MAIN	COMP.W	D1,#NBBF/2	; zone secondaire utilise ?	JUMP',NE 50$		; oui => 50$	CALL	_INI1B	JUMP	MAIN50$:	CALL	_INI2B	JUMP	MAINMOUSEDP:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE	NMAIN	CALL	DDETECTE	; A4 <-- ^dbut zone	JUMP,NE	NMAIN	LOAD.L	A2,A4		; A2 <-- position dbut zone	LOAD.L	A3,A2		; A3 <-- position fin zone (=dbut)	CLR.W	D5		; D5 <-- pas de dernier "flag"30$:	LIB	?GETKEY		; attend souris/clavier ...	TEST.L	D3:#BKPSEUDO	; touche relache ?	JUMP,BS	30$		; oui => 30$	COMP.W	D3,#KEYMPO	JUMP,NE	50$32$:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE	30$	TEST.B	D3		; bouton relch ?	JUMP,EQ 50$		; oui => 50$	LOAD.W	D6,D5		; D6 <-- dernier "flags"	CALL	FDETECTE	; A4 <-- ^fin zone	JUMP,NE	30$	TEST.L	D5:#0		; souris dans la premire ligne ?	JUMP',BS 35$	TEST.L	D5:#1		; souris dans la dernire ligne ?	JUMP,BC 38$	LOAD.L	A0,A3	LOAD.L	A1,A4	CALL	INVZONE		; inverse un bout en plus ou en moins	LOAD.L	A3,A1		; A3 <-- ^nouvelle fin	INC.W	(A5)+ODMO	; descend la fentre	LOAD.W	D4,#MODCUR	CALL	MODIF	CALL	AFFBUF		; affiche un peu plus bas	TEST.L	D5:#2		; image incomplte ?	JUMP,BC 32$		; non => 32$	LOAD.L	A4,A3	CALL	SRCUP	LOAD.L	A0,A4		; A0 <-- ^dbut image	LOAD.L	A1,A3		; A1 <-- ^fin image	LOAD.W	(A6)+OIHLI,(A6)+OOHLI	CALL	INVZONE		; inverse un bout de plus	JUMP	32$35$:	TEST.W	(A5)+ODMO	JUMP',EQ 38$	DEC.W	(A5)+ODMO	; remonte la fentre	PUSH.W	D4	LOAD.W	D4,#MODCUR	CALL	MODIF	POP.W	D4	CALL	AFFBUF		; affiche un peu plus bas; Inverse la ligne r-apparue en haut de l'cran qui tait; dj slectionne, mais qui ne l'est plus puisqu'elle a; t r-affiche !	LOAD.L	A4,A2		; A4 <-- ^dbut zone	CALL	SRCBLI		; A4 <-- ^dbut ligne o commence la zone		LOAD.L	A0,(A5)+OPDA	; A0 <-- ^dbut premire ligne	COMP.L	A0,A4		; est avant le dbut ?	JUMP',LO 36$		; oui => 36$	LOAD.L	A4,A0	CALL	SRCDOWN	LOAD.L	A1,A4		; A1 <-- ^fin premire ligne	LOAD.L	A0,A2	CALL	INVZONE		; r-inverse la premire ligne36$:	CALL	FDETECTE	; A4 <-- ^fin zone	COMP.L	A4,A2		; est-on avant le dbut ?	JUMP',HS 37$		; non => 37$	LOAD.L	A4,A2		; oui => ne recule pas plus37$:	COMP.L	A4,A3		; fin identique ?	JUMP,EQ	32$		; oui => 32$	LOAD.L	A0,A3	LOAD.L	A1,A4	CALL	INVZONE		; inverse un bout en plus ou en moins	LOAD.L	A3,A1		; A3 <-- ^nouvelle fin	JUMP	32$38$:	COMP.L	A4,A2		; est-on avant le dbut ?	JUMP',HS 40$		; non => 40$	LOAD.L	A4,A2		; oui => ne recule pas plus40$:	COMP.L	A4,A3		; fin identique ?	JUMP,EQ	30$		; oui => 30$				; non =>	LOAD.L	A0,A3	LOAD.L	A1,A4	CALL	INVZONE		; inverse un bout en plus ou en moins	LOAD.L	A3,A1		; A3 <-- ^nouvelle fin	JUMP	30$50$:	TEST.W	(A5)+ODMO	; cran dcal ?	JUMP',EQ 55$		; non => 55$	CLR.W	(A5)+ODMO	; plus de dcalage !	LOAD.W	D4,#MODCUR	CALL	MODIF		; faudra repeindre l'cran55$:	LOAD.L	A0,A2		; A0 <-- ^dbut zone	LOAD.L	A1,A3		; A1 <-- ^fin zone	COMP.L	A0,A1	JUMP',NE 60$;;?	CALL	INVZONE		; efface zone actuelle	CALL	WORDZONE	; A0/A1 <-- ^dbut/fin du mot	CALL	INVZONE		; montre zone du mot	LOAD.W	D4,#50/4	; D4 <-- 1/4 de seconde	NTREL	?DELMS		; petit dlais pour voir le mot !60$:	COMP.L	A0,A1	JUMP,EQ 90$	LOAD.L	A4,#(A6)+OCASDP	; A4 <-- ^variable pour la case	CALL	IFZONE		; D3 <-- caractre unique de la zone	COMP.B	D3,#REGLE	JUMP,EQ 70$	COMP.B	D3,#IMAGE	JUMP,EQ 80$	LOAD.L	A4,A0		; A4 <-- ^dbut zone	CALL	GETNUM		; D3D4 <-- nombre ventuel	JUMP',NE 65$		; non => 65$	COMP.L	A4,A1		; nombre fini juste aprs ?	JUMP',NE 65$		; non => 65$	TEST.B	(A6)+OFLAGS:#BCALCUL	JUMP,BS MNCALCUL	LOAD.L	A3,#R16"TMMODC	LOAD.L	A4,#(A6)+OCASDP	; A4 <-- ^variable pour la case	CALL	MMENUS		; attend choix selon menu hirarchique ...	JUMP,NE 90$	LOAD.W	D3,(A4)+LMM*0+OMMSEL	COMP.W	D3,#1	JUMP,EQ	MDETRUIT	COMP.W	D3,#2	JUMP,EQ	MDEPLACE	COMP.W	D3,#3	JUMP,EQ	MDUPLIFIE	COMP.W	D3,#4	JUMP,EQ	MMODE	COMP.W	D3,#5	JUMP,EQ	MMODIFIE	COMP.W	D3,#6	JUMP,EQ	M1CALCUL	CALL	INVZONE		; efface toute la zone	JUMP	MAIN65$:	LOAD.L	A3,#R16"TMMODCAR	LOAD.L	A4,#(A6)+OCASDP	; A4 <-- ^variable pour la case	CALL	MMENUS		; attend choix selon menu hirarchique ...	JUMP,NE 90$	LOAD.W	D3,(A4)+LMM*0+OMMSEL	COMP.W	D3,#1	JUMP,EQ	MDETRUIT	COMP.W	D3,#2	JUMP,EQ	MDEPLACE	COMP.W	D3,#3	JUMP,EQ	MDUPLIFIE	COMP.W	D3,#4	JUMP,EQ	MMODE	COMP.W	D3,#5	JUMP,EQ	MMODIFIE	COMP.W	D3,#6	JUMP,EQ	MMIMA	CALL	INVZONE		; efface toute la zone	JUMP	MAIN70$:				; rgle unique =>	LOAD.L	A3,#R16"TMMODR	CALL	MMENU		; attend choix selon menu ...	JUMP',NE 90$	COMP.W	D3,#1	JUMP,EQ	MDETRUIT	COMP.W	D3,#2	JUMP,EQ	MDEPLACE	COMP.W	D3,#3	JUMP,EQ	MDUPLIFIE	COMP.W	D3,#4	JUMP,EQ	MREGLE	CALL	INVZONE		; efface toute la zone	JUMP	MAIN80$:				; image unique =>	LOAD.L	A3,#R16"TMMODI	CALL	MMENU		; attend choix selon menu ...	JUMP',NE 90$	COMP.W	D3,#1	JUMP,EQ	MDETRUIT	COMP.W	D3,#2	JUMP,EQ	MDEPLACE	COMP.W	D3,#3	JUMP,EQ	MDUPLIFIE	COMP.W	D3,#4	JUMP,EQ	MREFAIT	COMP.W	D3,#5	JUMP,EQ	MIMAGE	COMP.W	D3,#6	JUMP,EQ	MPLAN	CALL	INVZONE		; efface toute la zone	JUMP	MAIN90$:	CALL	INVZONE		; efface toute la zone	JUMP	NMAINMDETRUIT:	CALL	SWMO		; souris: met le sablier	CALL	INVZONE		; efface toute la zone	CALL	CNTZONE		; D1 <-- nb caractres dans zone	LOAD.L	A4,A0	CALL	_VAQQPART	; va au dbut de la zone  dtruire	CALL	AFFBUF		; montre aprs dplacement	TEST.W	D1		; au moins un carcatre ?	JUMP,EQ	MAIN		; non => MAIN	CALL	EXKILL		; signal destruction20$:	CALL	KILLAV		; mmorise pour v. rcupration	CALL	_DAVANCE	; dtruit un caractre	CALL	IFLPSEUDO	JUMP,EQ	20$	DEC.W	D1	JUMP,NE	20$	CALL	_QJUSTIF	; justifie un p'tit peu	JUMP	MAINMDEPLACE:	CALL	SWMO		; souris: met le sablier	CALL	INVZONE		; efface toute la zone	CALL	CNTZONE		; D1 <-- nb caractres dans zone	LOAD.L	A4,A0	CALL	_VAQQPART	; va au dbut de la zone  dplacer	CALL	AFFBUF		; montre aprs dplacement	CALL	INI2BC		; init zone secondaire si pas dj fait	CALL	EXCOPY		; signal copie	PUSH.L	A5	LOAD.L	A5,#(A6)+OBUFS	; A5 <-- ^description buffer secondaire	LOAD.B	D3,#MARQUED	CALL	_INSERT		; marque le dbut de la zone	POP.L	A5	TEST.W	D1		; au moins un carcatre ?	JUMP',EQ 30$		; non => 30$20$:	CALL	COPYONE		; copie un caractre	JUMP',NE 30$	CALL	_DAVANCE	; dtruit un caractre	JUMP',NE 30$	CALL	IFLPSEUDO	JUMP,EQ	20$	DEC.W	D1	JUMP,NE	20$30$:	CALL	_QJUSTIF	; justifie un p'tit peu	PUSH.L	A5	LOAD.L	A5,#(A6)+OBUFS	; A5 <-- ^description buffer secondaire	LOAD.B	D3,#MARQUEF	CALL	_INSERT		; marque la fin de la zone	CALL	_ZJUSTIF	; justifie la zone	CALL	_ZFJUSTIF	; enlve les marques et va  la fin	POP.L	A5	CALL	AFFBUF		; montre aprs suppression	JUMP	MAINMDUPLIFIE:	CALL	SWMO		; souris: met le sablier	CALL	INVZONE		; efface toute la zone	CALL	CNTZONE		; D1 <-- nb caractres dans zone	LOAD.L	A4,A0	CALL	_VAQQPART	; va au dbut de la zone  dplacer	CALL	AFFBUF		; montre aprs dplacement	CALL	INI2BC		; init zone secondaire si pas dj fait	CALL	EXCOPY		; signal copie	PUSH.L	A5	LOAD.L	A5,#(A6)+OBUFS	; A5 <-- ^description buffer secondaire	LOAD.B	D3,#MARQUED	CALL	_INSERT		; marque le dbut de la zone	POP.L	A5	TEST.W	D1		; au moins un carcatre ?	JUMP',EQ 30$		; non => 30$20$:	CALL	COPYONE		; copie un caractre	JUMP',NE 30$	CALL	_AVANCE		; avance un caractre	JUMP',NE 30$	CALL	IFLPSEUDO	JUMP,EQ	20$	DEC.W	D1	JUMP,NE	20$30$:	PUSH.L	A5	LOAD.L	A5,#(A6)+OBUFS	; A5 <-- ^description buffer secondaire	LOAD.B	D3,#MARQUEF	CALL	_INSERT		; marque la fin de la zone	CALL	_ZJUSTIF	; justifie la zone	CALL	_ZFJUSTIF	; enlve les marques et va  la fin	POP.L	A5	CALL	AFFBUF		; montre aprs suppression	JUMP	MAINMMODE:	CALL	INVZONE		; efface toute la zone	LOAD.W	D3,(A4)+LMM*1+OMMSEL	LOAD.L	A3,#R16"VMMODE	LOAD.B	D2,(A3)+(D3.W)	; D2 <-- mode	CALL	SWMO		; souris: met le sablier	CALL	CNTZONE		; D1 <-- nb caractres dans zone	LOAD.L	A4,A0	CALL	_VAQQPART	; va au dbut de la zone  modifier	CALL	AFFBUF		; montre aprs dplacement	TEST.W	D1		; au moins un caractre ?	JUMP,EQ	MAIN		; non => MAIN	LOAD.B	D3,#MARQUED	CALL	_INSERT		; marque le dbut de la zone	CALL	AZMCOMMAND	; utilise mode dans toute la zone	LOAD.B	D3,#MARQUEF	CALL	_INSERT		; marque la fin de la zone	CALL	_ZJUSTIF	; justifie la zone	CALL	_ZFJUSTIF	; enlve les marques et va  la fin	JUMP	MAINMMODIFIE:	CALL	INVZONE		; efface toute la zone	LOAD.W	D3,(A4)+LMM*2+OMMSEL	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.W	D4,D3	MUL.WU	D4,#LGGC	ADD.L	A4,D4		; A4 <-- ^gencar choisit	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP,BC	MAIN		; non => MAIN	CALL	SWMO		; souris: met le sablier	CALL	CNTZONE		; D1 <-- nb caractres dans zone	LOAD.L	A4,A0	CALL	_VAQQPART	; va au dbut de la zone  modifier	CALL	AFFBUF		; montre aprs dplacement	TEST.W	D1		; au moins un caractre ?	JUMP,EQ	MAIN		; non => MAIN	LOAD.B	D2,D3		; D2 <-- no gencar	LOAD.B	D3,#MARQUED	CALL	_INSERT		; marque le dbut de la zone	CALL	AZGCOMMAND	; utilise gencar dans toute la zone	LOAD.B	D3,#MARQUEF	CALL	_INSERT		; marque la fin de la zone	CALL	_ZJUSTIF	; justifie la zone	CALL	_ZFJUSTIF	; enlve les marques et va  la fin	JUMP	MAINMMIMA:	CALL	INVZONE		; efface toute la zone	LOAD.W	D5,(A4)+LMM*3+OMMSEL	INC.W	D5		; D5 <-- opration (1, 2 ou 3)	CALL	SWMO		; souris: met le sablier	CALL	CNTZONE		; D1 <-- nb caractres dans zone	LOAD.L	A4,A0	CALL	_VAQQPART	; va au dbut de la zone  modifier	CALL	AFFBUF		; montre aprs dplacement	TEST.W	D1		; au moins un caractre ?	JUMP,EQ	MAIN		; non => MAIN	LOAD.B	D3,#MARQUED	CALL	_INSERT		; marque le dbut de la zone	LOAD.B	D4,#1		; D4 <-- classe 1 (mots)	CALL	INITCLASS	; A2/D2 <-- descripteur de la classe	CLR.W	D0		; D0 <-- dbut d'un mot20$:	CALL	_AVANCE		; avance d'un caractre	CALL	IFLPSEUDO	JUMP,EQ	20$	COMP.W	D5,#1	JUMP',EQ 30$	COMP.W	D5,#3	JUMP',EQ 40$25$:				; min --> MAJ	CALL	MINMAJ		; D3 <-- lettre majuscule	COMP.B	D3,#'A	JUMP',LO 50$	COMP.B	D3,#'Z	JUMP',HI 50$	PUSH.W	D3	CALL	_DRECULE	POP.W	D3	CALL	_INSERT	JUMP'	50$30$:				; MAJ --> min	CALL	MAJMIN		; D3 <-- lettre minuscule	COMP.B	D3,#'a	JUMP',LO 50$	COMP.B	D3,#'z	JUMP',HI 50$	PUSH.W	D3	CALL	_DRECULE	POP.W	D3	CALL	_INSERT	JUMP'	50$40$:				; nom propre =>	CALL	TSTCLASS	; dlimiteur de mots ?	JUMP',EQ 48$		; oui => 48$	TEST.W	D0		; dbut d'un mot ?	JUMP,NE 30$		; non => 30$ (minuscule)				; oui =>	CALL	MINMAJ		; D3 <-- lettre majuscule	COMP.B	D3,#'A	JUMP',LO 50$	COMP.B	D3,#'Z	JUMP',HI 50$	INC.W	D0		; si lettre => une seule majuscule	JUMP	25$48$:	CLR.W	D0		; D0 <-- nouveau dbut de mot50$:	DEC.W	D1	JUMP,NE	20$	LOAD.B	D3,#MARQUEF	CALL	_INSERT		; marque la fin de la zone	CALL	_ZJUSTIF	; justifie la zone	CALL	_ZFJUSTIF	; enlve les marques et va  la fin	JUMP	MAINM1CALCUL:	CLR.W	D7	LOAD.W	D3,#1		; D3 <-- addition en premier	JUMP'	M2CALCULMNCALCUL:	LOAD.L	A3,#R16"TMCALCUL	LOAD.L	A4,#(A6)+OCASCAL; A4 <-- ^variable pour la case	CALL	MMENU		; attend choix selon menu ...M2CALCUL:	PUSH.W	D7	CALL	INVZONE		; efface toute la zone	POP.W	D7	JUMP,NE NMAIN	LOAD.W	D2,D3		; D2 <-- opration (1..4)	JUMP,EQ	MAIN		; si case vide => MAIN	LOAD.L	A4,A0		; A4 <-- ^dbut nombre dans buffer	CALL	GETNUM		; D3D4 <-- nombre	JUMP,NE	NMAIN	TSET.B	(A6)+OFLAGS:#BCALCUL	JUMP',BS 20$	CLR.L	(A6)+OCALCUL+0	CLR.L	(A6)+OCALCUL+420$:	LOAD.W	D0,D2	LOAD.L	D1,D3	LOAD.L	D2,D4	LOAD.L	D3,(A6)+OCALCUL+0	LOAD.L	D4,(A6)+OCALCUL+4	DEC.W	D0	JUMP',EQ 30$	DEC.W	D0	JUMP',EQ 32$	DEC.W	D0	JUMP',EQ 34$	DEC.W	D0	JUMP',EQ 36$	JUMP'	40$30$:				; addition =>	PUSH.L	A5	LOAD.L	A5,(A6)+OCHMATI	; A5 <-- canal interne de math64	MATH64_	ADD	POP.L	A5	JUMP'	40$32$:				; soustraction =>	PUSH.L	A5	LOAD.L	A5,(A6)+OCHMATI	; A5 <-- canal interne de math64	MATH64_	SUB	POP.L	A5	JUMP'	40$34$:				; multiplication =>	PUSH.L	A5	LOAD.L	A5,(A6)+OCHMATI	; A5 <-- canal interne de math64	MATH64_	MUL	POP.L	A5	JUMP'	40$36$:				; division =>	TEST.L	D3	JUMP',NE 37$	TEST.L	D4	JUMP,EQ	NMAIN37$:	PUSH.L	A5	LOAD.L	A5,(A6)+OCHMATI	; A5 <-- canal interne de math64	MATH64_	DIV	POP.L	A540$:	LOAD.L	(A6)+OCALCUL+0,D3	LOAD.L	(A6)+OCALCUL+4,D4	JUMP	MAINMREGLE:	CALL	INVZONE		; efface toute la rgle	LOAD.L	A4,A0		; A4 <-- ^dbut zone	CALL	_VAQQPART	; va au dbut de la rgle	CALL	REGPARAM	; A4 <-- ^dbut rgle	JUMP,NE	NMAIN	PUSH.L	(A5)+OPDB	PUSH.L	(A5)+OPFB	PUSH.L	A4	LOAD.L	A4,#(A4)+1+LGREG; A4 <-- ^paramtres "next"	LOAD.L	A3,#(A6)+OMREG	CALL	MAJREGLE	; OMREG <-- rglette	POP.L	A4	CALL	_NVISU	LOAD.L	(A5)+OPFB,A4	LOAD.L	A4,(A5)+OPDT	LOAD.L	(A5)+OPDB,A4	LOAD.L	(A5)+OPDA,A4	CLR.W	(A5)+OHDA	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LIB	?AFTIM	.B	EOP		; efface tout l'cran	.B	NOCURS		; pas de curseur	.B	0	.EVEN	LOAD.W	D4,#MODLIN	CALL	MODIF		; repeint la rgle	LOAD.W	D5,(A6)+ONOWDT	LIB	?USEWDO		; utilise swdo du texte	CALL	DISCCMO		; enlve la flche de la souris	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^dbut rgle	CALL	SRCHTL		; D4 <-- hauteur de la rgle	CLR.W	D5	CLR.W	D6	CLR.W	D3		; D3 <-- dbut Y	CALL	AFFREGLE	; affiche juste la rgle	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	CALL	GCDEF		; remet g.c. par dfaut	CALL	DISSCMO		; remet la flche de la souris	LOAD.L	A2,#R16"TDBOX_REGLE	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBPOS	; D2 <-- mode d'ouverture	LOAD.L	D3,(A6)+ODWDT	; D3 <-- dimensions swdo texte	SR.W	D3,#1		; D3 <-- position X = 1/2 largeur	SWAP.W	D3	SR.W	D3,#2	LOAD.W	D1,D3	ADD.W	D3,D1	ADD.W	D3,D1		; D3 <-- position Y = 3/4 hauteur	SWAP.W	D3	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	55$	LOAD.L	D6,D5		; D6 <-- canal dbox	LIB	?GETWDO	LOAD.W	D0,D5		; D1 <-- no swdo dbox20$:	CALL	CWMO		; souris: enlve le sablier	LOAD.W	D5,D0		; D5 <-- no swdo dbox	LIB	?USEWDO		; utilise swdo dbox	LOAD.L	D5,D6		; D5 <-- canal dbox	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^dbut rgle	CALL	TXTREGLE	; affiche la rgle sous forme de textes25$:	LOAD.W	D5,D0		; D5 <-- no swdo dbox	LIB	?USEWDO		; utilise swdo dbox	LOAD.L	D5,D6		; D5 <-- canal dbox	CLR.L	D4		; D4 <-- fanions	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton relch ?	JUMP,EQ	25$	COMP.W	D3,#CR		; ok ?	JUMP',EQ 50$	COMP.W	D3,#END		; annule ?	JUMP',EQ 50$	COMP.W	D3,#KEYMGP	JUMP',EQ 30$	COMP.W	D3,#KEYMMP	JUMP',EQ 30$	COMP.W	D3,#KEYMDP	JUMP',NE 40$30$:	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 40$	CALL	PDETECTE	; positionne selon la souris	JUMP,EQ	20$40$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	25$50$:	LOAD.L	D5,D6		; D5 <-- canal dbox	DBOX_	CLOSE		; ferme la dbox	CALL	AFMENU		; remet les soft-keys standards55$:	POP.L	(A5)+OPFB	POP.L	(A5)+OPDB	COMP.W	D3,#CR	JUMP',NE 80$				; OK =>	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^dbut rgle	TEST.B	(A4)+1+LGREG+OREGLAB ; rgle isole ?	JUMP',NE 70$		; non => 70$				; oui =>	CALL	MODREGLE	; mj rgle suivante	CALL	_RJUSTIF	; justifie jusqu' la rgle suivante	JUMP'	90$70$:	LOAD.L	A4,#(A4)+1+LGREG; A4 <-- ^paramtres "next"	LOAD.L	A3,#(A6)+OSREG	CALL	MAJREGLE	; OSREG <-- rglette	LOAD.L	A4,A3	CALL	LABREGLE	; mj rglettes soeurs (mme label)	JUMP'	90$80$:				; ANNULE =>	LOAD.L	A3,(A5)+OPFT	; A3 <-- ^dbut rgle	LOAD.L	A3,#(A3)+1+LGREG; A3 <-- ^paramtres "next"	LOAD.L	A4,#(A6)+OMREG	CALL	UPDREGLE	; rgle <-- OMREG90$:	CALL	ALLSCREEN	; signal tout l'cran  repeindre	JUMP	MAINMREFAIT:	CALL	SWMO		; souris: met le sablier	CALL	INVZONE		; efface toute l'image	LOAD.L	A4,A0		; A4 <-- ^dbut zone	CALL	_VAQQPART	; va au dbut de l'image	CALL	IMAPARAM	; A4 <-- ^dbut image	JUMP,NE	NMAIN	INC.L	A4		; A4 <-- ^nom de l'image	LOAD.L	A0,#(A6)+OTAIM	LOAD.W	D0,#MAXIM-120$:	TEST.B	(A0)+OIMNAM	; lment libre ?	JUMP',EQ 40$		; oui => 40$				; non =>	LOAD.L	A2,#(A0)+OIMNAM	LOAD.L	A3,A430$:	TEST.B	(A2)	JUMP',EQ 35$	COMP.B	(A2+),(A3+)	; trouv le bon nom ?	JUMP,EQ 30$	JUMP'	40$35$:	TEST.B	(A3)	JUMP',EQ 50$		; oui => 50$40$:	LOAD.L	A0,#(A0)+LGIM	DECJ.W,NMO D0,20$	JUMP	MAIN50$:	CALL	IMACLOSE	; ferme l'image60$:	TEST.B	(A4+)		; saute le nom de l'image	JUMP,NE	60$	CLR.B	(A4)+0	CLR.B	(A4)+1		; <dyy> <-- zro	CLR.B	(A4)+2	CLR.B	(A4)+3		; <dxx> <-- zro	LOAD.W	D4,#MODALL	CALL	MODIF		; toute la fentre  repeindre	CALL	_QJUSTIF	; justifie (centre) l'image	JUMP	MAINMIMAGE:	CALL	SWMO		; souris: met le sablier	CALL	INVZONE		; efface toute l'image	LOAD.L	A4,A0		; A4 <-- ^dbut zone	CALL	_VAQQPART	; va au dbut de l'image	CALL	IMAPARAM	; A4 <-- ^dbut image	JUMP,NE	NMAIN	LOAD.L	A3,#(A6)+OBUEXE	LOAD.L	A2,#R16"XDESSIN20$:	LOAD.B	(A3+),(A2+)	; buffer <-- "DESSIN "	JUMP,NE	20$	DEC.L	A3	INC.L	A430$:	LOAD.B	(A3+),(A4+)	; buffer <-- nom de l'image	JUMP,NE	30$	CLR.B	(A4)+0	CLR.B	(A4)+1		; <dyy> <-- zro	CLR.B	(A4)+2	CLR.B	(A4)+3		; <dxx> <-- zro	JUMP	MIMAGEPLANMPLAN:	CALL	SWMO		; souris: met le sablier	CALL	INVZONE		; efface toute l'image	LOAD.L	A4,A0		; A4 <-- ^dbut zone	CALL	_VAQQPART	; va au dbut de l'image	CALL	IMAPARAM	; A4 <-- ^dbut image	JUMP,NE	NMAIN	LOAD.L	A3,#(A6)+OBUEXE	LOAD.L	A2,#R16"XPLAN20$:	LOAD.B	(A3+),(A2+)	; buffer <-- "PLAN "	JUMP,NE	20$	DEC.L	A3	INC.L	A430$:	LOAD.B	(A3+),(A4+)	; buffer <-- nom de l'image	JUMP,NE	30$	CLR.B	(A4)+0	CLR.B	(A4)+1		; <dyy> <-- zro	CLR.B	(A4)+2	CLR.B	(A4)+3		; <dxx> <-- zroMIMAGEPLAN:	LOAD.L	A3,#(A6)+OBUEXE	FOS	?EXECUTE	; excute DESSIN/PLAN ...	CALL	_IOERROR	; affiche erreur si ncessaire	JUMP	MAIN;---------\\; TXTREGLE >;---------/; Affiche le contenu d'une rgle sous forme de textes dans la dbox.; in	A4.L	^rgle;	D5.L	canal de la dbox; out	-; mod	D7.WTXTREGLE:	PUSHM.L	D0..D4	LOAD.W	D2,#1	DBOX_	GETCO	LOAD.L	D3,D4	LIB	?SETCURS	LOAD.W	D4,(A6)+OITL	LOAD.B	D3,(A4)+1+LGREG+OREGITL	COMP.B	D3,#ITL2	JUMP',EQ 45$	COMP.B	D3,#ITL12	JUMP',NE 46$		; D4 <-- 1 * itl	LOAD.W	D3,D4	SR.W	D3,#1	ADD.W	D4,D3		; D4 <-- 1.5 * itl	JUMP'	46$45$:	SL.W	D4,#1		; D4 <-- 2 * itl46$:	CALL	AFYMM		; affiche l'interligne	LOAD.W	D2,#2	DBOX_	GETCO	LOAD.L	D3,D4	LIB	?SETCURS	LOAD.B	D1,(A4)+1+LGREG+OREGMGG+0	LOAD.B	D0,(A4)+1+LGREG+OREGMGG+1	CALL	NUMBR	CALL	AFXMM	PUSH.W	D4	LOAD.W	D2,#3	DBOX_	GETCO	LOAD.L	D3,D4	LIB	?SETCURS	POP.W	D3	LOAD.B	D1,(A4)+1+LGREG+OREGRENF+0	LOAD.B	D0,(A4)+1+LGREG+OREGRENF+1	CALL	NUMBR	SUB.W	D4,D3	CALL	AFXMM	PUSH.W	D3	LOAD.W	D2,#4	DBOX_	GETCO	LOAD.L	D3,D4	LIB	?SETCURS	POP.W	D3	LOAD.B	D1,(A4)+1+LGREG+OREGMGD+0	LOAD.B	D0,(A4)+1+LGREG+OREGMGD+1	CALL	NUMBR	SUB.W	D4,D3	CALL	AFXMM	POPM.L	D0..D4	RET;--------\; MENUGC  >;========/; Affiche le menu pour choisir le gencar.; in	-; out	D3.W	no du gencar choisi;	D7.W	erreur; mod	D3.W, D7.WMENUGC:	PUSHM.L	D4,A2..A4	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^buffer pour construire m-menu	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^descripteur de la fentre	DGENC_	MENU		; construit le m-menu	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^buffer pour construire m-menu	LOAD.L	A4,#(A6)+OCASCAR; A4 <-- ^variable pour la case	CALL	MMENU		; attend choix selon menu ...	DEC.W	D3		; D3 <-- -1 si case vide (pas de choix)	JUMP',NS 90$	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.W	D4,D3	MUL.WU	D4,#LGGC	ADD.L	A4,D4		; A4 <-- ^gencar choisit	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BS 90$		; oui => 90$	LOAD.W	D3,#-1		; non => comme si case vide90$:	POPM.L	D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; MMENUS  >;========/; Appel un mmenu hirarchique, avec mmorisation ventuelle de la case.; in	A3.L	^mmenu;	A4.L	^variable de mmorisation; out	A4.L	^paramtres (OMMxxx);	D7.W	erreur; mod	D7.W, A4.LMMENUS:	PUSHM.L	D3..D5,A1..A3	PUSH.L	A4	LOAD.L	A2,A3	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^buffer pour construire m-menu	CALL	MENUBUF		; buffer <-- mmenu	LOAD.L	A1,#(A6)+OBUDIS	; A1 <-- ^mmenu dans buffer20$:	TEST.B	(A1)		; fin du mmenu ?	JUMP,EQ 60$		; oui => 60$30$:	LOAD.B	D3,(A1+)	JUMP,EQ 20$	COMP.B	D3,#-2	JUMP,NE 30$				; ^sous-menu =>	LOAD.B	D3,(A1+)	SL.W	D3,#8	LOAD.B	D3,(A1+)	; D3 <-- ^relatif	LOAD.L	A4,#(A6)+OBUDIS	SUB.L	A4,A3	LOAD.L	D4,A4	NEG.L	D4	LOAD.B	(A1)-1,D4	RR.W	D4,#8	LOAD.B	(A1)-2,D4	; buffer <-- ^relatif au sous-menu	RR.W	D4,#8	TEST.W	D3		; .BW -2,0  ?	JUMP',EQ 50$		; oui => 50$	LOAD.L	A4,A2	ADD.W	A4,D3		; A4 <-- ^sous-menu	CALL	MENUBUF		; buffer <-- sous-menu	JUMP	30$50$:	PUSH.L	A2	PUSH.L	A3	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^descripteur de la fentre	DGENC_	MENU		; buffer <-- sous-menu des gencars	INC.L	A3		; A3 <-- saute le zro terminateur	POP.L	A4	POP.L	A252$:	INC.W	D4	COMP.B	(A4+),#-1	; A4 <-- saute la premire case vide	JUMP,NE 52$	LOAD.B	(A1)-1,D4	RR.W	D4,#8	LOAD.B	(A1)-2,D4	; buffer <-- ajuste le ^relatif	JUMP	30$60$:	POP.L	A2		; A2 <-- ^variable de mmorisation	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^mmenu	LOAD.L	A4,#(A6)+OPARMM	; A4 <-- ^paramtres	CLR.W	(A4)+OMMSEL	TEST.B	(A6)+OFANION+3:#BFAMCA	JUMP',BC 65$	LOAD.W	(A4)+OMMSEL,(A2)65$:	CLR.L	D5		; D5 <-- mode	LIB	?MMENUS		; attend selon choix	LOAD.W	(A2),(A4)+OMMSEL	CLR.L	(A4)+LMM*0+OMMINA	CLR.L	(A4)+LMM*1+OMMINA	CLR.L	(A4)+LMM*2+OMMINA	CLR.L	(A4)+LMM*3+OMMINA	CLR.L	(A4)+LMM*4+OMMINA	CLR.L	(A4)+LMM*5+OMMINA	POPM.L	D3..D5,A1..A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; MENUBUF >;--------/; Met un mmenu dans un buffer.; in	A4.L	^mmenu;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LMENUBUF:	PUSHM.L	D3,A410$:	TEST.B	(A4)		; fin du mmenu ?	JUMP',EQ 80$20$:	LOAD.B	D3,(A4+)	LOAD.B	(A3+),D3	; buffer <-- .ASCIZ	JUMP,EQ 10$	COMP.B	D3,#-2	JUMP,NE	20$	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-high>	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-low>	JUMP	20$80$:	CLR.B	(A3+)		; buffer <-- terminateur	POPM.L	D3,A4	RET;--------\\; MMENU   >;========/; Appel un mmenu, avec mmorisation ventuelle de la case.; in	A4.L	^variable de mmorisation;	+ voir LIB,?MMEMUMMENU:	CLR.W	D3		; D3 <-- case en haut par dfaut	TEST.B	(A6)+OFANION+3:#BFAMCA	JUMP',BC 20$	LOAD.W	D3,(A4)		; D3 <-- dernire case20$:	LIB	?MMENU	JUMP',NE 90$	LOAD.W	(A4),D3		; mmorise dernire case90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFZONE  >;========/; Si la zone n'englobe qu'un caractre, dit de quel caractre; il s'agit.; in	A0.L	^dbut zone dans texte;	A1.L	^fin zone dans texte; out	D3.B	caractre (zro si plus d'un); mod	D3.W, D7.WIFZONE:	PUSHM.L	D4,A4	LOAD.L	A4,A0		; A4 <-- ^dbut zone	CLR.B	D410$:	COMP.L	A4,A1		; fin zone atteinte ?	JUMP',EQ 90$		; oui => 90$	CALL	_NVISU		; D3 <-- caractre suivant	JUMP',EQ 20$	COMP.W	D7,#ERTHOL	; trou rencontr ?	JUMP,EQ	10$		; oui => 10$	JUMP'	90$20$:	CALL	IFLPSEUDO	JUMP,EQ	10$	TEST.B	D4		; 2me caractre ?	JUMP',NE 50$		; oui => 50$	LOAD.B	D4,D3		; D4 <-- premier caractre	JUMP	10$50$:	CLR.B	D4		; D4 <-- y'a plus d'un caractre90$:	LOAD.B	D3,D4		; D3 <-- zro/caractre	POPM.L	D4,A4	RET;--------\\; CNTZONE >;========/; Compte le nombre de caractre inclus dans une zone.; in	A0.L	^dbut zone dans texte;	A1.L	^fin zone dans texte; out	D1.W	nombre de caractres; mod	D1.W, D7.WCNTZONE:	PUSHM.L	D3,A4	LOAD.L	A4,A0		; A4 <-- ^dbut zone	CLR.W	D110$:	COMP.L	A4,A1		; fin zone atteinte ?	JUMP',EQ 90$		; oui => 90$	CALL	_NVISU		; D3 <-- caractre suivant	JUMP',EQ 20$	COMP.W	D7,#ERTHOL	; trou rencontr ?	JUMP,EQ	10$		; oui => 10$	JUMP'	90$20$:	CALL	IFLPSEUDO	JUMP,EQ	10$	INC.W	D1		; D1 <-- un caractre de plus	JUMP	10$90$:	POPM.L	D3,A4	RET;----------\\; GOMARQUEF >;==========/; Remet le curseur sur la marque MARQUEF et enlve-la.; in	A0.L	^dbut zone;	A1.L	^fin zone;	A2.L	^ancien OPDT; out	-; mod	D7.WGOMARQUEF:	PUSH.W	D3	CALL	_AVANCE	JUMP',NE 10$	COMP.B	D3,#MARQUEF	; marque juste aprs ?	JUMP',EQ 40$		; oui => 40$	CALL	_RECULE10$:	COMP.L	A0,A2	JUMP',HS 50$	COMP.L	A1,A2	JUMP',HI 50$30$:	CALL	_AVANCE	JUMP',NE 90$	COMP.B	D3,#MARQUEF	JUMP,NE	30$40$:	PUSH.W	(A5)+OMODIF	CALL	_DRECULE	; supprime MARQUEF	POP.W	(A5)+OMODIF	JUMP'	90$50$:	CALL	_RECULE	JUMP',NE 90$	COMP.B	D3,#MARQUEF	JUMP,NE	50$	PUSH.W	(A5)+OMODIF	CALL	_DAVANCE	; supprime MARQUEF	POP.W	(A5)+OMODIF90$:	POP.W	D3	RET; Mise en vidence d'une zone; ---------------------------;--------\\; INVZONE >;========/; Inverse une zone montre par la souris.; in	A0.L		^dbut zone dans texte;	A1.L		^fin zone dans texte;	(A6)+OIHLI.W	hauteur  sauter la premire fois; out	-; mod	D7.WINVZONE:	PUSHM.L	D0..D6,A0..A4	CALL	DISCCMO		; enlve la flche de la souris	COMP.L	A0,A1	JUMP',LS 10$	EX.L	A0,A1		; A0 < A110$:	LOAD.W	D5,(A6)+ONOWDT	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE	JUMP',BS 12$	LOAD.W	D5,(A6)+ONOWDP12$:	LIB	?USEWDO		; utilise swdo du texte; Cherche dans quelle ligne commence la zone  inverser, sans chercher; caractre par caractre pour aller plus vite.	LOAD.L	A4,(A6)+ODISPS	; A4 <-- ^status fentre	LOAD.W	D4,(A4)+ODFFDY	; D4 <-- hauteur de la fentre	LOAD.L	A4,#(A5)+OAREG	LOAD.L	A3,#(A5)+OVREG	CALL	COPREGLE	; OVREG <-- OAREG	LOAD.L	A4,#(A5)+OACOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OACOM	LOAD.L	A4,(A5)+OPDA	; A4 <-- ^dbut affichage	LOAD.W	D6,(A5)+OHDA	; D6 <-- hauteur  sauter	CLR.W	D3		; D3 <-- position Y dbut 1re ligne	LOAD.W	D0,D4		; D0 <-- hauteur20$:	CALL	SRCHTL		; D4 <-- hauteur de la ligne	SUB.W	D4,D6	CLR.W	D5	COMP.W	D0,D4		; reste place pour toute la ligne ?	JUMP',HS 25$		; oui => 25$	LOAD.W	D5,D4		; non =>	SUB.W	D5,D0		; D5 <-- hauteur en trop	LOAD.W	D4,D0		; D4 <-- hauteur restante25$:	PUSH.L	A4	LOAD.L	A4,#(A5)+OVREG	LOAD.L	A3,#(A6)+OSREG	CALL	COPREGLE	; OSREG <-- OVREG	LOAD.L	A4,#(A5)+OVCOM	LOAD.L	A3,#(A6)+OSCOM	CALL	COPCOMMAND	; OSCOM <-- OVCOM	POP.L	A4	LOAD.L	A3,A4		; A3 <-- ^dbut ligne	CALL	SRCDOWN		; A4 <-- ^dbut ligne suivante	COMP.L	A0,A4		; dbut zone dans cette ligne ?	JUMP',LO 30$		; oui => 30$	CLR.W	D6	ADD.W	D3,D4		; D3 <-- position Y ligne suivante	SUB.W	D0,D4	JUMP,HI	20$	JUMP	90$; Inverse ligne par ligne les parties de la zone.30$:	LOAD.L	A4,A3		; A4 <-- ^dbut ligne o commence zone	PUSH.L	A4	LOAD.L	A4,#(A6)+OSREG	LOAD.L	A3,#(A5)+OVREG	CALL	COPREGLE	; OVREG <-- OSREG	LOAD.L	A4,#(A6)+OSCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OSCOM	POP.L	A4	CALL	_SKIPHOL	; A4 <-- saute le trou si ncessaire40$:	COMP.L	A1,A4		; fin zone dans cette ligne ?	JUMP',LS 90$		; oui => 90$				; non =>	CALL	SRCHTL		; D4 <-- hauteur de la ligne	SUB.W	D4,D6	CLR.W	D5	COMP.W	D0,D4		; reste place pour toute la ligne ?	JUMP',HS 45$		; oui => 45$	LOAD.W	D5,D4		; non =>	SUB.W	D5,D0		; D5 <-- hauteur en trop	LOAD.W	D4,D0		; D4 <-- hauteur restante45$:	PUSHM.L	D0,D1,D3,D4	CALL	DETHZONE	ADD.W	D3,(A6)+OIHLI	SUB.W	D4,(A6)+OIHLI	CALL	INVHZONE	CLR.W	(A6)+OIHLI	; ne l'utilise qu'une fois !	POPM.L	D0,D1,D3,D4	CLR.W	D6	ADD.W	D3,D4		; D3 <-- position Y ligne suivante	SUB.W	D0,D4	JUMP,HI	40$90$:	CLR.W	(A6)+OIHLI	; plus rien  sauter	CALL	DISSCMO		; remet la flche de la souris	POPM.L	D0..D6,A0..A4	RET;---------\\; DETHZONE >;---------/; Cherche le dbut et la fin (horizontalement) de la zone ; inverser dans une ligne.; Les pseudo-caractres en dbut de ligne ne sont pas inclus dans; la zone, pour rsoudre le cas des SAJEXM en mode drapeau  gauche; ou centr !; in	A4.L	^dbut de la ligne;	A0.L	^dbut zone dans texte;	A1.L	^fin zone dans texte;	D4.W	(BAFFIMA ou BAFFREG); out	D0.W	longueur jusqu'au dbut de la zone;	D1.W	longueur jusqu' la fin de la zone;	A4.L	^dbut ligne suivante; mod	D0.W, D1.W, D7.W, A4.LDETHZONE:	PUSHM.L	D2..D4,A0,A1	CALL	_SKIPHOL	; A4 <-- saute le trou si ncessaire	TEST.L	D4:#BAFFIMA	; image ?	JUMP',BC 10$		; non => 10$; On est dans une image. Prend ses dimensions.	CALL	IMAPARAM	; D3 <-- <ixx>, D4 <-- <dyy>;<dxx>, A4 <-- ^DEBIMA	LOAD.W	D0,(A5)+OVREG+OREGRENF ; D0 <-- position dbut image	ADD.W	D0,D3		; D0 <-- tient compte de l'indentation <ixx>	LOAD.W	D1,D4	ADD.W	D1,D0		; D1 <-- position fin image	CALL	_TNVISU		; A4 <-- saute l'image	JUMP	80$10$:	TEST.L	D4:#BAFFREG	; rglette ?	JUMP',BC 20$		; non => 20$; On est dans une rglette. Prend ses dimensions.	CALL	REGPARAM	; A4 <-- ^DEBREG	CLR.W	D0		; D0 <-- position dbut rglette	LOAD.W	D1,(A6)+OXWDT	; D1 <-- position fin rglette	CALL	_TNVISU		; A4 <-- saute la rglette	JUMP	90$; On est dans une ligne de texte.20$:	CALL	CALOFFSET	; tient compte v. dcalage de la ligne	LOAD.W	D0,D2	LOAD.W	D1,D2; Saute les ventuels SAJEXM (faisant la marge gauche) au dbut de la ligne.25$:	CALL	_TNVISU		; D3 <-- caractre suivant	JUMP,NE 80$	COMP.B	D3,#COMMAND	JUMP,EQ 25$	COMP.B	D3,#SAJEXM	; SAJEXM faisant la marge gauche ?	JUMP',NE 30$		; non => 30$	CALL	_VADDLGC	; D2 <-- compte la largeur	LOAD.W	D0,D2	LOAD.W	D1,D2	JUMP	25$30$:	CALL	_TPVISU		; recule caractre pas pseudo; Cherche le dbut de la zone.	COMP.L	A0,(A5)+OPFT	; est-on  la fin du trou ?	JUMP',NE 35$		; non => 35$	LOAD.L	A0,(A5)+OPDT	; oui => vient au dbut35$:	COMP.L	A0,A4	JUMP',LS 40$	CALL	_TNVISU		; D3 <-- caractre suivant	JUMP',NE 80$	CALL	IFIEOL		; fin de la ligne ?	JUMP',EQ 60$		; oui => 60$	CALL	_VADDLGC	; D2 <-- compte la largeur	LOAD.W	D0,D2	LOAD.W	D1,D2	JUMP	35$; Cherche la fin de la zone.40$:	COMP.L	A1,(A5)+OPFT	; est-on  la fin du trou ?	JUMP',NE 45$		; non => 45$	LOAD.L	A1,(A5)+OPDT	; oui => vient au dbut45$:	COMP.L	A1,A4	JUMP',LS 80$	CALL	_TNVISU		; D3 <-- caractre suivant	JUMP',NE 80$	CALL	IFIEOL		; fin de la ligne ?	JUMP',EQ 60$		; oui => 60$	CALL	_VADDLGC	; D2 <-- compte la largeur	LOAD.W	D1,D2	JUMP	45$; Ajuste la fin en fonction du caractre terminant la ligne.60$:	COMP.B	D3,#TEOL	JUMP',EQ 70$	COMP.B	D3,#TEOP	JUMP',EQ 65$	COMP.B	D3,#PEOP	JUMP',NE 80$65$:				; fin de page =>	CLR.W	D0		; depuis tout  gauche	LOAD.W	D1,(A6)+OXWDT	; prend toute la largeur	JUMP'	90$70$:				; fin de ligne =>	LOAD.B	D3,#CAREOL	CALL	_VADDLGC	; D2 <-- compte la largeur	LOAD.W	D1,D2;	JUMP'	80$80$:	LOAD.W	D2,(A6)+OSCROLH+OSCPOSV ; tient compte de l'ascenseur horizontal	SUB.W	D0,D2	JUMP',HS 82$	CLR.W	D082$:	SUB.W	D1,D2	JUMP',HS 83$	CLR.W	D183$:	LOAD.W	D2,(A6)+OCX	ADD.W	D0,D2		; tient compte de la marge  gauche	ADD.W	D1,D2		; tient compte de la marge  gauche90$:	POPM.L	D2..D4,A0,A1	RET;---------\\; INVHZONE >;---------/; Inverse une bande horizontale.; in	D0.W	dbut zone en X;	D1.W	fin zone en X;	D3.W	dbut zone en Y;	D4.W	longueur zone en Y; out	-; mod	D7.WINVHZONE:	PUSHM.L	D3,D4	COMP.W	D0,D1		; dbut = fin ?	JUMP',EQ 90$		; oui => 90$				; non =>	EX.L	D4,D3	SWAP.W	D4		; D4 <-- yy	LOAD.W	D4,D0		; D4 <-- xx	SWAP.W	D3		; D3 <-- dyy	LOAD.W	D3,D1	SUB.W	D3,D0		; D3 <-- dxx	CALL	ITGMOUSE	; enlve souris si ncessaire	CALL	DISINV		; inverse une zone90$:	POPM.L	D3,D4	RET;---------\\; WORDZONE >;=========/; Cherche le dbut et la fin d'un mot (un mot est dfini selon; les classes).; in	A0.L	^un caractre; out	A0.L	^dbut du mot;	A1.L	^fin du mot; mod	D7.W, A0.L, A1.LWORDZONE:	PUSHM.L	D2..D4,A2,A4	LOAD.B	D4,#1		; D4 <-- classe 1 (mots)	CALL	INITCLASS	; A2/D2 <-- descripteur de la classe	LOAD.L	A4,A0	CALL	_TNVISU		; D3 <-- premier caractre	JUMP',NE 10$	COMP.B	D3,#IMAGE	; est-ce une image ?	JUMP,EQ 90$		; oui => prend l'image sans rien en plus	COMP.B	D3,#REGLE	; est-ce une rglette ?	JUMP,EQ 90$		; oui => prend la rglette sans rien en plus10$:	LOAD.L	A4,A020$:	CALL	_TPVISU		; recule jusqu'au dbut du mot	JUMP',NE 45$	COMP.B	D3,#'.	JUMP,EQ 20$	COMP.B	D3,#',	JUMP,EQ 20$	COMP.B	D3,#'-	JUMP,EQ 20$	CALL	TSTCLASS	; dlimiteur de mots ?	JUMP,NE	20$		; non => 20$				; oui =>	CALL	_TNVISU		; avance sur le premier caractre du mot45$:	LOAD.L	A0,A4		; A0 <-- ^dbut du mot50$:	CALL	_TNVISU		; avance jusqu' la fin du mot	JUMP',NE 90$	COMP.B	D3,#TIRET	JUMP',EQ 55$	COMP.B	D3,#'.	JUMP',EQ 60$	COMP.B	D3,#',	JUMP',EQ 60$	COMP.B	D3,#'-	JUMP,EQ 50$	CALL	TSTCLASS	; dlimiteur de mots ?	JUMP,NE	50$		; non => 50$	JUMP'	80$55$:				; TIRET =>	CALL	_TNVISU		; saute le PEOL	CALL	_TNVISU	COMP.B	D3,#SAJEXM	JUMP,EQ	50$	CALL	_TPVISU	JUMP	50$60$:	CALL	_TNVISU		; D3 <-- caractre aprs la virgule	JUMP',NE 80$	COMP.B	D3,#'-	JUMP,EQ 50$	COMP.B	D3,#'0	JUMP',LO 70$	COMP.B	D3,#'9	JUMP,LS	50$70$:	CALL	_TPVISU		; recule caractre aprs la virgule80$:	CALL	_TPVISU		; recule sur le dernier caractre du mot90$:	LOAD.L	A1,A4		; A1 <-- ^fin du mot	POPM.L	D2..D4,A2,A4	RET;--------\\; MOVEFPS >;========/; Dplace la frontire entre les zones principale et secondaire.; in	-; out	D7.W	erreur; mod	D7.WMOVEFPS:	PUSHM.L	D0..D5,A4	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.L	A4,(A6)+ODISPS	; A4 <-- ^status fentre	LOAD.W	D3,(A6)+OCY	LOAD.W	D1,D3	MUL.WU	D1,#1+6		; D1 <-- position la plus haute	LOAD.W	D2,(A4)+ODFDY	MUL.WU	D3,#4	SUB.W	D2,D3		; D2 <-- position la plus basse	TEST.B	(A6)+OFANION+2:#BFASCH ; ascenseur horizontal ?	JUMP',BC 05$	SUB.W	D2,(A6)+OXWDD05$:	LOAD.W	D5,(A6)+OCYI	ADD.W	D5,(A6)+OYWDP	; D5 <-- position actuelle	LIB	?IFMOUSE	SWAP.W	D4		; D4 <-- position souris initiale	LOAD.W	D0,D4	SUB.W	D0,D5		; D0 <-- offset initial10$:	LIB	?GETKEY	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 30$		; non => 30$	LIB	?IFMOUSE	; D4 <-- coordonne souris	JUMP,NE 10$	SWAP.W	D4	SUB.W	D4,D0		; D4 <-- corrige selon offset initial	TCLR.L	D4:#0		; D4 <-- doit tre pair !	COMP.W	D4,D1		; souris trop haute ?	JUMP',HS 20$		; non => 20$	LOAD.W	D4,D1		; oui => descend20$:	COMP.W	D4,D2		; souris trop basse ?	JUMP',LS 22$		; non => 22$	LOAD.W	D4,D2		; oui => monte22$:	EX.L	D4,D5	CALL	MOVEFZ		; dplace la zone	JUMP	10$30$:	LOAD.W	D7,#1		; D7 <-- frontire pas bouge	SUB.W	D5,(A6)+OCYI	TCLR.L	D5:#0		; OYWDP doit tre pair !	COMP.W	D5,(A6)+OYWDP	; frontire bouge ?	JUMP',EQ 90$		; non => 90$	LOAD.W	(A6)+OYWDP,D5	CALL	KILWDOS		; dtruit toutes les swdos	CALL	CREWDOS		; re-cre toutes les swdos	CALL	AFFINFOS	; dessine tout de suite les infos sec.	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D5,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; MOVEFZ  >;--------/; Dplace la zone (grande bande horizontale).; in	D4.W	ancienne coordonne Y de la souris;	D5.W	nouvelle coordonne Y de la souris;	A4.L	^descripteur de la fentre; out	-; mod	D7.WMOVEFZ:	PUSHM.L	D0..D5	LOAD.W	D2,D4	LOAD.W	D1,(A6)+OCY	; D1 <-- hauteur	CLR.W	D4		; D4 <-- <xx>	LOAD.W	D3,(A4)+ODFDX	; D3 <-- <dxx>	SWAP.W	D4	SWAP.W	D3	COMP.W	D2,D5	JUMP',EQ 90$	JUMP',LO 10$	EX.L	D2,D5		; D2 < D510$:	LOAD.W	D4,D2		; D4 <-- <yy>	LOAD.W	D3,D5	SUB.W	D3,D2		; D3 <-- <dyy>	LOAD.W	D0,D2	ADD.W	D0,D1	COMP.W	D3,D1		; chevauchement entre les deux zones ?	JUMP',LO 20$		; oui => 20$	LOAD.W	D3,D1		; D3 <-- <dyy>	LOAD.W	D0,D520$:	SWAP.W	D3	SWAP.W	D4	CALL	ITGMOUSE	; enlve la souris si ncessaire	CALL	DISINV		; inverse un bout	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- <yy>	SWAP.W	D4	CALL	ITGMOUSE	; enlve la souris si ncessaire	CALL	DISINV		; inverse un autre bout	CALL	DISSCMO		; remet la souris si ncessaire90$:	POPM.L	D0..D5	RET; Dtection de la souris; ----------------------;---------\\; PDETECTE >;=========/; Dtecte sous quel caractre est le curseur dans une ligne pour; un dplacement.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WPDETECTE:	PUSHM.L	D0..D5,A4	CALL	YDETECTE	; A4 <-- ^dbut ligne	JUMP,NE 90$	TEST.L	D4:#BAFFIMA	; image ?	JUMP,BS 80$		; oui => 80$	TEST.L	D4:#BAFFREG	; rglette ?	JUMP',BC 40$		; non => 40$				; oui =>	LOAD.L	D4,D1		; D4 <-- position de la souris	COMP.L	A4,(A5)+OPDT	; est-on avant la rgle ?	JUMP',HI 20$		; oui => 20$				; non =>	CALL	DETREGLE	; action selon l'endroit dans la rgle	JUMP',EQ 85$		; icne, tabulateur, etc. => 85$	CALL	_VAQQPART	; rien de spcial => va sur la rglette	JUMP'	85$20$:	CALL	_VAQQPART	; avance sur la rgle	CALL	DETREGLE	; action selon l'endroit dans la rgle	JUMP'	85$40$:	SUB.W	D1,(A6)+OCX	JUMP',LO 80$	CALL	CALOFFSET	; tient compte v. dcalage de la ligne	ADD.W	D1,D0	ADD.W	D1,D2		; D1 <-- tient compte du dcalage50$:	CALL	_TNVISU		; D3 <-- caractre suivant	JUMP',NE 80$	CALL	IFIEOL		; fin de la ligne ?	JUMP',EQ 70$		; oui => 70$	LOAD.W	D4,D2		; D2 <-- position avant le caractre	CALL	_VADDLGC	; D2 <-- compte la largeur	LOAD.W	D0,D2		; D0 <-- position aprs le caractre	SUB.W	D0,D4		; D0 <-- largeur du caractre	SR.W	D0,#1		; D0 <-- 1/2 largeur du caractre	ADD.W	D4,D0		; D4 <-- position avant + 1/2 largeur	COMP.W	D1,D4		; souris dans ce caractre ?	JUMP,HS	50$		; non => 50$70$:	CALL	_TPVISU		; A4 <-- ^sur le caractre80$:	CALL	SKIPPSEUDO	; A4 <-- saute si pseudo caractres	CALL	_VAQQPART	; positionne dans le texte85$:	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D0..D5,A4	RET;---------\\; DDETECTE >;=========/; Dtecte sous quel caractre est le curseur dans une ligne pour; un dbut de zone.; in	D4.L	position de la souris (y;x); out	A4.L	^sur le caractre; mod	D7.W, A4.LDDETECTE:	PUSHM.L	D0..D5	CALL	YDETECTE	; A4 <-- ^dbut ligne	JUMP',NE 90$	TEST.L	D4:#BAFFIMA	; image ?	JUMP',BS 80$		; oui => 80$	TEST.L	D4:#BAFFREG	; rglette ?	JUMP',BS 80$		; oui => 80$	SUB.W	D1,(A6)+OCX	JUMP',LO 75$	CALL	CALOFFSET	; tient compte v. dcalage de la ligne	ADD.W	D1,D0	ADD.W	D1,D2		; D1 <-- tient compte du dcalage50$:	CALL	_TNVISU		; D3 <-- caractre suivant	JUMP',NE 70$	CALL	IFIEOL		; fin de la ligne ?	JUMP',EQ 70$		; oui => 70$	LOAD.W	D4,D2		; D2 <-- position avant le caractre	CALL	_VADDLGC	; D2 <-- compte la largeur	LOAD.W	D0,D2		; D0 <-- position aprs le caractre	SUB.W	D0,D4		; D0 <-- largeur du caractre	SR.W	D0,#1		; D0 <-- 1/2 largeur du caractre	ADD.W	D4,D0		; D4 <-- position avant + 1/2 largeur	COMP.W	D1,D4		; souris dans ce caractre ?	JUMP,HS	50$		; non => 50$70$:	CALL	_TPVISU		; A4 <-- ^sur le caractre75$:	CALL	SKIPPSEUDO	; A4 <-- saute si pseudo caractres80$:	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D0..D5	RET;---------\\; FDETECTE >;=========/; Dtecte sous quel caractre est le curseur dans une ligne.; in	D4.L		position de la souris (y;x); out	A4.L		^sur le caractre;	D5.W		:0 => on est tout en haut;			:1 => on est tout en bas;			:2 => image incomplte;	(A6)+OOHLI.W	hauteur incluse dans la fentre; mod	D5.W, D7.W, A4.LFDETECTE:	PUSHM.L	D0..D4	CALL	YDETECTE	; A4 <-- ^dbut ligne	JUMP',NE 90$	TEST.L	D4:#BAFFIMA	; image ?	JUMP',BS 20$		; oui => 20$	TEST.L	D4:#BAFFREG	; rglette ?	JUMP',BC 40$		; non => 40$20$:				; oui =>	CALL	_TNVISU		; A4 <-- ^aprs l'image	JUMP'	80$40$:	SUB.W	D1,(A6)+OCX	JUMP',LO 75$	CALL	CALOFFSET	; tient compte v. dcalage de la ligne	ADD.W	D1,D0	ADD.W	D1,D2		; D1 <-- tient compte du dcalage50$:	CALL	_TNVISU		; D3 <-- caractre suivant	JUMP',NE 80$	LOAD.W	D4,D2		; D2 <-- position avant le caractre	CALL	_VADDLGC	; D2 <-- compte la largeur	LOAD.W	D0,D2		; D0 <-- position aprs le caractre	SUB.W	D0,D4		; D0 <-- largeur du caractre	SR.W	D0,#1		; D0 <-- 1/2 largeur du caractre	ADD.W	D4,D0		; D4 <-- position avant + 1/2 largeur	COMP.W	D1,D4		; souris dans ce caractre ?	JUMP',LO 70$		; oui => 70$				; non =>	CALL	IFIEOL		; fin de la ligne ?	JUMP,NE	50$		; non => 50$	JUMP'	80$		; oui => 80$70$:	CALL	_TPVISU		; A4 <-- ^sur le caractre75$:	CALL	SKIPPSEUDO	; A4 <-- saute si pseudo caractres80$:	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D0..D4	RET;---------\\; YDETECTE >;---------/; Dtecte dans quelle ligne est la souris.; in	D4.L		position de la souris (y;x); out	A4.L		^dbut de la ligne;	D4.W		hauteur de la ligne (BAFFIMA ou BAFFREG);	D1.L		position de la souris dans la fentre (y;x);	D3.W		position Y dbut ligne/image/rglette;	D5.W		:0 => on est tout en haut;			:1 => on est tout en bas;			:2 => image incomplte;	(A6)+OOHLI.W	hauteur incluse dans la fentre;	D7.W		erreur; mod	D1.L, D4.L, D5.W, D7.W, A4.LYDETECTE:	PUSHM.L	D0,D2,D6,A3	LOAD.L	D1,D4		; D1 <-- position (Y;X) de la souris	LOAD.W	D5,(A6)+ONOWDT	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE	JUMP',BS 10$	LOAD.W	D5,(A6)+ONOWDP10$:	LIB	?USEWDO		; utilise swdo du texte; Vrifie si la souris est dans la sous-fentre du texte.	LOAD.L	A4,(A6)+ODISPS	; A4 <-- ^status fentre	LOAD.L	D4,D1	CALL	WDOMOUSE	; D1 <-- position dans sous-fentre	JUMP,NE	90$	LOAD.L	D1,D4; Cherche dans quelle ligne est la souris, sans chercher caractre par; caractre pour aller plus vite.	LOAD.W	D4,(A4)+ODFFDY	; D4 <-- hauteur de la fentre	LOAD.L	A4,#(A5)+OAREG	LOAD.L	A3,#(A5)+OVREG	CALL	COPREGLE	; OVREG <-- OAREG	LOAD.L	A4,#(A5)+OACOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OACOM	LOAD.L	A4,(A5)+OPDA	; A4 <-- ^dbut affichage	LOAD.W	D6,(A5)+OHDA	; D6 <-- hauteur  sauter	CLR.W	D3		; D3 <-- position Y dbut 1re ligne	LOAD.W	D0,D4		; D0 <-- hauteur	LOAD.W	D5,#2^0		; D5 <-- on est tout en haut20$:	CALL	SRCHTL		; D4 <-- hauteur de la ligne	SUB.W	D4,D6	TEST.L	D4:#BAFFIMA	JUMP',BS 30$	COMP.W	D0,D4		; reste place pour toute la ligne ?	JUMP',LO 50$		; non => 50$30$:				; oui =>	LOAD.L	D2,D1	SWAP.W	D2		; D2 <-- position Y de la souris	SUB.W	D2,D3		; souris trop haute ?	JUMP',LO 40$		; oui => 40$	COMP.W	D2,D4		; souris trop basse ?	JUMP',LO 60$		; non => 60$ (dans cette ligne)40$:	CALL	SRCDOWN		; A4 <-- ^dbut ligne suivante	JUMP,NE 90$	TCLR.L	D5:#0		; D5 <-- on est plus tout en haut	CLR.W	D6	ADD.W	D3,D4		; D3 <-- position Y ligne suivante	SUB.W	D0,D4	JUMP,HI	20$	LOAD.W	D7,#ERTNOT	; D7 <-- pas trouv	JUMP	90$; Il n'y a pas suffisemment de place en bas de la fentre pour la; ligne au dbut de laquelle on est. Il faut remonter  la prcdente.50$:	CALL	SRCUP		; remonte la ligne incomplte	CALL	SRCHTL		; D4 <-- hauteur de la ligne complte	SUB.W	D3,D4	TSET.L	D5:#1		; D5 <-- on est tout en bas	JUMP'	70$; La souris est dans cette ligne. Vrifie s'il s'agit de la dernire; ligne entire (si oui, met le bit D5:#1  un).60$:	COMP.W	D0,D4		; reste place pour toute la hauteur ?	JUMP',HI 62$		; oui => 62$				; non => image	LOAD.W	(A6)+OOHLI,D0	; mm. hauteur dans la fentre	TSET.L	D5:#1		; D5 <-- on est tout en bas	TSET.L	D5:#2		; D5 <-- image incomplte	JUMP'	70$62$:	SUB.W	D0,D4		; D0 <-- place restante	PUSH.L	D4	CALL	SRCDOWN		; A4 <-- ^dbut ligne suivante	JUMP',NE 68$	CALL	SRCHTL		; D4 <-- hauteur de la ligne suivante	TEST.L	D4:#BAFFIMA	; image juste aprs ?	JUMP',BS 65$		; oui => 65$ (pas encore dernire ligne)	COMP.W	D0,D4		; place pour la ligne suivante entire ?	JUMP',HS 65$		; oui => 65$	TSET.L	D5:#1		; D5 <-- on est tout en bas65$:	CALL	SRCUP		; A4 <-- revient o on tait68$:	POP.L	D470$:	CALL	_SKIPHOL	; A4 <-- saute le trou si ncessaire	TEST.L	D4:#BAFFIMA	JUMP',BC 75$	PUSHM.L	D3,D4	CALL	IMAPARAM	; A4 <-- ^dbut image	POPM.L	D3,D4	JUMP'	80$75$:	TEST.L	D4:#BAFFREG	JUMP',BC 80$	CALL	REGPARAM	; A4 <-- ^dbut rglette80$:	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D0,D2,D6,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; WDOMOUSE >;=========/; Donne la coordonne de la souris relativement dans la sous-fentre.; in	D4.L	position souris (y;x); out	D4.L	position souris dans sous-fentre;	D7.W	erreur; mod	D4.L, D7.WWDOMOUSE:	PUSH.L	A4	LOAD.L	A4,(A6)+ODISPS	; A4 <-- ^status fentre	LOAD.W	D7,#ERTNOT	; D7 <-- pas trouv	SUB.W	D4,(A4)+ODFFX	JUMP',LO 90$	COMP.W	D4,(A4)+ODFFDX	JUMP',HS 90$	SWAP.W	D4	SUB.W	D4,(A4)+ODFFY	JUMP',LO 90$	COMP.W	D4,(A4)+ODFFDY	JUMP',HS 90$	SWAP.W	D4	CLR.W	D7		; D7 <-- ok90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; SKIPPSEUDO >;===========/; Saute ventuellement un ou plusieurs pseudo-caractres.; Voir commentaire de PSEUDOAV !;	   in             out;	   |               |;	abc <sajex> <sajex> def;	  out    in		<-- ici, on recule !;	   |     |;	abc <tab> <sajex> def; in	A4.L	^dans buffer; out	A4.L	^dans buffer; mod	D7.W, A4.LSKIPPSEUDO:	PUSH.W	D3	CALL	_TPVISU		; D3 <-- caractre juste avant	JUMP',NE 20$	COMP.B	D3,#TAB		; tabulateur ?	JUMP',EQ 90$		; oui => 90$	CALL	_TNVISU20$:	CALL	_TNVISU		; D3 <-- caractre suivant	JUMP',NE 90$	CALL	IFPSEUDO	; pseudo caractre ?	JUMP,EQ	20$		; oui => 20$	COMP.B	D3,#COMMAND	JUMP',NE 50$	LOAD.B	D3,(A4)-(1+LGCOM*2)+OCOMNOG	COMP.B	D3,(A4)-(1+LGCOM*1)+OCOMNOG	JUMP,LO 20$50$:	CALL	_TPVISU		; recule le caractre avanc en trop60$:	CALL	_TPVISU		; recule un caractre	JUMP',NE 90$	COMP.B	D3,#COMMAND	JUMP',NE 70$	LOAD.B	D3,(A4)+(1+LGCOM*0)+OCOMNOG	COMP.B	D3,(A4)+(1+LGCOM*1)+OCOMNOG	JUMP,HI 60$70$:	CALL	_TNVISU		; avance caractre recul en trop90$:	POP.W	D3	RET; Menus pour la souris; --------------------TMMODCAR:	.ASCIZ	" "	.B	-1	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICODETR,ICOSPACE