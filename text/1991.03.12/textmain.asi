	.SBTTL	TEXTMAIN; Point de retour pour toutes les fonctions de l'diteur; ------------------------------------------------------;--------\\; MAIN    >;========/MAIN:	LOAD.L	SP,(A6)+OSTACK	PUSH.L	#R16"MAIN.IF 0CLR.L H'900LOAD.B D4,(A5)+OCREG+OREGJUST.W H'A038,H'A024LOAD.B D4,(A5)+OAREG+OREGJUST.W H'A038,H'A024LOAD.B D4,(A5)+OLREG+OREGJUST.W H'A038,H'A024.W H'A024LOAD.B D4,(A5)+OCCOM+OCOMNOG.W H'A038,H'A024LOAD.B D4,(A5)+OACOM+OCOMNOG.W H'A038,H'A024LOAD.B D4,(A5)+OLCOM+OCOMNOG.W H'A038,H'A024.ENDIF	LIB	?IFCAR		; une touche presse ?	JUMP',EQ 20$		; oui => 20$	CALL	AFFBUF		; non => affiche le buffer de texte	LIB	?IFCAR		; une touche presse ?	JUMP',EQ 20$		; oui => 20$	CALL	AFFINFO		; non => affiche les informations	LIB	?IFCAR		; une touche presse ?	JUMP',EQ 20$		; oui => 20$	CALL	AFFDEROULEUR	; non => affiche le drouleur	CALL	CWMO		; souris: plus de sablier	TEST.B	(A5)+OFLAFF:#BBIGCUR	JUMP',BC 10$	CALL	IBIGCURS	; allume le grand curseur10$:	LOAD.W	D4,#40	NTREL	?SETTIM	LIB	?GETCAR		; une touche presse ?	JUMP',EQ 18$		; oui => 18$	CALL	INKCURS		; non => efface le curseur	LOAD.W	D4,#20	NTREL	?SETTIM	LIB	?GETCAR		; une touche presse ?	JUMP',EQ 16$		; oui => 16$	CALL	INKCURS		; non => remet le curseur	JUMP	10$16$:	CALL	INKCURS		; remet le curseur18$:	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	TCLR.B	(A5)+OFLAFF:#BBIGCUR	JUMP',BC 20$	CALL	IBIGCURS	; teint le grand curseur20$:	LOAD.W	(A6)+OKEY,D3	; mm touche presse	COMP.W	D3,#KEYMGR	; bouton de la souris relach ?	JUMP,EQ	MAIN		; oui => MAIN (ignore)	COMP.W	D3,#KEYMMR	JUMP,EQ	MAIN	COMP.W	D3,#KEYMDR	JUMP,EQ	MAIN	LOAD.L	D4,D3	SWAP.W	D4		; D4 <-- pseudo-code	COMP.B	D4,#'A	JUMP',LO 23$	COMP.B	D4,#'Z	JUMP',HI 23$	SUB.B	D4,#'A-1	COMP.B	D4,D3		; (CTRL-lettre) ?	JUMP',NE 23$		; non => 23$				; oui =>	CALL	EXNOACCENT	; annule si frappe accent en cours	LOAD.W	D4,D3	SR.W	D4,#8	TEST.B	D4		; (CTRL-lettre) ?	JUMP,EQ OCTRL	COMP.B	D4,#CURSOR	; (CTRL-CURSOR-lettre) ?	JUMP,EQ OCTRL23$:	COMP.W	D3,#H'100	; touche fonction presse ?	JUMP,LO	40$		; non => 40$	CALL	EXNOACCENT	; annule si frappe accent en cours	CALL	EXFONC		; cherche routine ...	.WW	CURSOR		OCURSOR	.WW	CURSOR!KILL	OKILLCURS	.WW	KEYMPO/H'100	OMOUSE	.WW	0		25$25$:	CALL	EXOTHER		; action non rcuprable	CALL	EXFONC		; cherche routine ...	.WW	SHOW		OSHOW	.WW	PROGRA!SHOW	OPROSHOW	.WW	KILL		OKILL	.WW	COPY		OCOPY	.WW	COPY!KILL	OCOPYKILL	.WW	PROGRA		OPROGRA	.WW	SEARCH		OSEARCH	.WW	CHANGE		OCHANGE	.WW	0		NMAIN40$:	COMP.B	D3,#F0+SHIFT	JUMP',LO 45$	COMP.B	D3,#F15+SHIFT	JUMP',HI 45$	SUB.B	D3,#SHIFT45$:	TEST.B	(A6)+OFLAGS:#BACC ; frappe accent en cours ?	JUMP,BC	50$		; non => 50$	CALL	ACCENT		; traite les cas ^e, "i, etc.	JUMP,NE	50$		; autre cas => 50$	CALL	EXOTHER		; action non rcuprable	JUMP	MAIN50$:	CALL	EXKEY	.WW	DELETE	KBCARAC	.WW	DEL	KBCARAC	.WW	BS	KCARAC	.WW	UNDO	EXRECUP	.WW	0	60$60$:	CALL	EXOTHER		; action non rcuprable	CALL	EXKEY	.WW	KCIRCON	XCIRCON	.WW	KTREMA	XTREMA	.WW	END	RETOUR	.WW	F0	RETOUR		; (Fin)	.WW	F1	AINPUT		; (Prend)	.WW	F2	AAJOUTE		; (Ajoute)	.WW	F3	COPDEF		; (Sauve)	.WW	F4	DBOXDEFINE	; (Df.)	.WW	F5	DBOXIMAGE	; (Image)	.WW	F6	INSREGLE	; (Rgle)	.WW	F7	DBOXGENCAR	; (Car.)	.WW	F8	DBOXFRAPPE	; (Frap.)	.WW	F9	DOSEARCH	; (Change)	.WW	F10	DBOXJUST	; (Just.)	.WW	F11	DBOXPARAM	; (Param.)	.WW	F12	DOGOTO		; (Va )	.WW	F13	DBOXPETIT	; (Tout)	.WW	F14	DOEFFACE	; (Efface)	.WW	F15	DOPRINT		; (Imp.)	.WW	DEFINE	DOSEARCH	.WW	CR	IEOL	.WW	ENTER	IEOL	.WW	EOP	IEOP	.WW	CCR	IPEOP	.WW	TAB	ITAB	.WW	POINT	IPOINT	.WW	TRIZERO	ITRIZERO	.WW	CADRATIN IMAIN	.WW	CLEAR	DOIMACLOSE	.WW	0	65$65$:	TEST.L	D3:#7	JUMP,BS	NMAIN	COMP.B	D3,#'	JUMP,LO	NMAIN	JUMP	IMAINIEOL:	LOAD.B	D3,#TEOL	JUMP	IMAINIEOP:	LOAD.B	D3,#TEOP	JUMP	IMAINIPEOP:	LOAD.B	D3,#PEOP	JUMP	IMAINITAB:	LOAD.B	D3,#TAB	JUMP	IMAINIPOINT:	LOAD.B	D3,#'.	JUMP	IMAINITRIZERO:	LOAD.B	D3,#'0	CALL	FINSERT	CALL	FINSERT;	JUMP	IMAIN;--------\\; IMAIN   >;========/IMAIN:	CALL	FINSERT		; insre le caractre	JUMP',NE NMAIN	CALL	_QJUSTIF	; justifie un p'tit peu	JUMP	MAIN;--------\\; FINSERT >;========/; Insre un caractre selon le mode choisi pour la frappe.; in	D3.B	caractre  insrer; out	D7.W	erreur; mod	D7.WFINSERT:	PUSHM.L	D3,D4	LOAD.L	D4,(A6)+OFAFR	; D4 <-- fanions de la frappe	JUMP',EQ 80$	TEST.L	D4:#1	JUMP',BS 80$	SWAP.W	D3		; D3 <-- x/code/x/x	RR.W	D4,#3	AND.B	D4,#B'00000111	LOAD.B	D3,D4		; D3 <-- x/code/x/mode	RR.W	D3,#8		; D3 <-- x/code/mode/x	CLR.B	D3	LOAD.L	D4,(A6)+OFAFR	RR.W	D4,#640$:	RR.W	D4,#1	JUMP',CS 45$	INC.B	D3		; D3 <-- x/code/mode/gencar	JUMP	40$45$:	RR.W	D3,#8		; D3 <-- x/code/gencar/mode	SWAP.W	D3		; D3 <-- gencar/mode/x/code	CALL	GINSERT	JUMP'	90$80$:	CALL	_INSERT90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; NMAIN   >;========/NMAIN:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	MAIN;--------\\; RETOUR  >;========/; Quitte l'diteur et libre les ressources utilises par; l'diteur, dtruit le processus fils, etc.RETOUR:	CALL	_EXHOME		; sauve tous les textes;;?	COMP.W	D7,#1;;?	JUMP',EQ 20$	TEST.W	D7	JUMP,NE	MAIN20$:	CALL	DBOXQUITTE	; demande s'il faut quitter ...	JUMP,NE MAIN	NTREL	?WFABDESC	; attend la fin des processus fils ...FINI:	LOAD.L	A5,(A6)+OCHMATI	; A5 <-- canal interne de math64	MATH64_	CLOSE	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE		; ferme le module DBOX	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE		; ferme le module LIST	LOAD.W	D1,(A6)+OCHCOUP	LIB_	CLOSE		; ferme le module COUPE	LOAD.W	D1,(A6)+OCHSCRO	LIB_	CLOSE		; ferme le module SCROLL	LOAD.W	D1,(A6)+OCHDGEN	LIB_	CLOSE		; ferme le module DGENC	LOAD.W	D1,(A6)+OCHMATH	LIB_	CLOSE		; ferme le module MATH64	TEST.L	(A6)+OCAPRINT	JUMP',EQ 50$	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	CLOSE	LOAD.W	D1,(A6)+OCHPRIN	LIB_	CLOSE50$:ERFAT1:	LIB	?CLOLIB		; ferme la librairie	FOS	?STOP		; c'est fini ...ERFAT3:	LOAD.L	A3,A0		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	FINI	.END