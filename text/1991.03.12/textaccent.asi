	.SBTTL	TEXTACCENTXCIRCON:	LOAD.W	D4,#CIRCON	; met un circonflxe	JUMP'	XACCENTXTREMA:	LOAD.W	D4,#TREMA	; met qq chose comme un trma;	JUMP'	XACCENTXACCENT:	CALL	EXOTHER		; action non rcuprable	CALL	_GETPTC		; D3 <-- car "sous" le curseur	JUMP',NE 50$		; rien => 50$	CALL	GETACCENT	; calcul lettre accentue	JUMP',NE 50$		; n'existe pas => 50$				; existe =>	TEST.B	D3	JUMP',EQ 50$	PUSH.W	D330$:	CALL	_DAVANCE	; dtruit lettre non accentue	COMP.B	D3,#COMMAND	JUMP,EQ 30$	POP.W	D3	CALL	FINSERT		; remplace par lettre accentue	JUMP'	90$50$:	LOAD.W	D3,D4		; D3 <-- accent	CALL	FINSERT		; insert un accent tout seul60$:	CALL	_RECULE		; puis recule "dessus"	COMP.B	D3,#COMMAND	JUMP,EQ 60$	TSET.B	(A6)+OFLAGS:#BACC90$:	RET;--------\\; ACCENT  >;========/; Caractre aprs un accent flottant frapp.; in	D3.B	caractre aprs accent; out	D7.W	erreur; mod	D7.WACCENT:	PUSHM.L	D3,D4	TCLR.B	(A6)+OFLAGS:#BACC ; clear flag des accents	LOAD.W	D4,D3	CALL	_GETPTC		; D3 <-- cherche car prcdent tap	EX.L	D3,D4		; D4 <-- accent, D3 <-- car qui ira "sous"	CALL	GETACCENT	; accent existe ?	JUMP',NE 40$		; non => 40$				; oui =>	TEST.B	D3		; laisse l'accent seul ?	JUMP',EQ 40$		; oui => 40$				; non =>	PUSH.W	D330$:	CALL	_DAVANCE	; dtruit l'accent seul	COMP.B	D3,#COMMAND	JUMP,EQ 30$	POP.W	D3	CALL	FINSERT		; remplace par lettre accentue	JUMP'	90$40$:	PUSH.W	D750$:	CALL	_AVANCE		; saute '^' ou '"'	COMP.B	D3,#COMMAND	JUMP,EQ 50$	POP.W	D790$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; GETACCENT >;==========/; Calcul le code correspondant  une lettre (a,e,i,o,u) et ; un accent (^,").; in	D4.B	accent (^,");	D3.B	caractre; out	D7.W	zro => ok (lettre accentue existe);	 D3.B	 lettre accentue;	D7.W	ERTNOT => lettre accentue n'existe pas;	 D3.B	 caractre qui devait aller sous l'accent; mod	D3.B, D7.WGETACCENT:	PUSH.L	A3	LOAD.L	A3,#R16"TABACCENT-310$:	ADD.L	A3,#3		; A3 <-- ^suivant dans table	TEST.B	(A3)		; fin de la table ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,(A3)		; lettre trouve dans table ?	JUMP,NE 10$		; non => 10$				; oui =>	COMP.B	D4,#CIRCON	JUMP',EQ 30$	COMP.B	D4,#TREMA	JUMP',NE 50$	LOAD.B	D3,(A3)+2	; D3 <-- lettre accentue (")	CLR.W	D7		; D7 <-- ok	JUMP'	90$30$:	LOAD.B	D3,(A3)+1	; D3 <-- lettre accentue (^)	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.W	D7,#ERTNOT	; D7 <-- erreur90$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RETTABACCENT:	.B	'a	' '	.B	'e	' '	.B	'i	' '	.B	'o	' '	.B	'u	' '	.B	SPACE	 0  0	.B	KCIRCON	'^ '^	.B	KTREMA	'" '"	.B	0	.EVEN;-----------\\; EXNOACCENT >;===========/; Annule l'effet d'un ventuel accent flottant tap, alors; que la lettre devant aller "desous" n'a pas encore t; tape.EXNOACCENT:	TCLR.B	(A6)+OFLAGS:#BACC	JUMP',BC 90$	PUSH.W	D330$:	CALL	_AVANCE		; saute l'accent flottant	COMP.B	D3,#COMMAND	JUMP,EQ 30$	POP.W	D390$:	RET	.END