	.SBTTL	TEXTABSOLU; touches (CTRL) ou (CTRL-CURSOR); -------------------------------OCTRL:	CALL	EXKEY	.WW	'F-H'40	DCARAC		; +1 caractre	.WW	'G-H'40	DCHAMP		; +1 mot	.WW	'C-H'40	ALIGNE		; +1 ligne	.WW	'X-H'40	A4LIGNE		; +4 lignes	.WW	'B-H'40	DALINEA		; +1 alina	.WW	'Y-H'40	DPAGE		; +1 page	.WW	'V-H'40	DBUFFER		; fin du texte	.WW	'D-H'40	DBCARAC		; -1 caractre	.WW	'S-H'40	DBCHAMP		; -1 mot	.WW	'R-H'40	ABLIGNE		; -1 ligne	.WW	'E-H'40	AB4LIGNE	; -4 lignes	.WW	'Z-H'40	DBALINEA	; -1 alina	.WW	'W-H'40	DBPAGE		; -1 page	.WW	'T-H'40	DBBUFFER	; dbut du texte	.WW	0	NMAINALIGNE:	LOAD.W	D1,#1	JUMP'	ANLIGNEA4LIGNE:	LOAD.W	D1,#4ANLIGNE:	CALL	EXABS		; excute un dplacement absolu20$:	CALL	GODOWN		; va au dbut de la ligne suivante	DEC.W	D1	JUMP,NE 20$	LOAD.W	D2,(A5)+OPOSABS	; D2 <-- position dans la ligne	CALL	PPOSABS		; va au bon endroit dans la ligne	JUMP	MAINABLIGNE:	LOAD.W	D1,#1	JUMP'	ABNLIGNEAB4LIGNE:	LOAD.W	D1,#4ABNLIGNE:	CALL	EXABS		; excute un dplacement absolu	CALL	_GOBOL		; revient au dbut de la ligne20$:	CALL	_GOUP		; va au dbut de la ligne prcdente	DEC.W	D1	JUMP,NE 20$	LOAD.W	D2,(A5)+OPOSABS	; D2 <-- position dans la ligne	CALL	PPOSABS		; va au bon endroit dans la ligne	JUMP	MAIN;--------\\; GPOSABS >;========/; Donne la position absolue du curseur dans la ligne.; in	-; out	D2.W	position dans la ligne; mod	D2.L, D7.WGPOSABS:	PUSHM.L	D3,A3,A4;	LOAD.L	A4,#(A5)+OCREG;	LOAD.L	A3,#(A5)+OVREG;	CALL	COPREGLE	; OVREG <-- OCREG	LOAD.L	A4,#(A5)+OCCOM	LOAD.L	A3,#(A5)+OVCOM	CALL	COPCOMMAND	; OVCOM <-- OCCOM	LOAD.L	A4,(A5)+OPDT	CALL	SRCBLI		; A4 <-- ^dbut de la ligne	CLR.W	D2		; D2 <-- position dans la ligne30$:	CALL	_NVISU		; D3 <-- caractre suivant dans la ligne	JUMP',NE 90$	CALL	_VADDLGC	; D2 <-- avance dans la ligne	JUMP	30$90$:	POPM.L	D3,A3,A4	RET;--------\\; PPOSABS >;========/; Met le curseur  une position absolue dans la ligne.; in	D2.W	position dans la ligne; out	-; mod	D7.WPPOSABS:	PUSHM.L	D0..D4	CALL	_GOBOL		; revient au dbut de la ligne	LOAD.W	D4,D2		; D4 <-- position  atteindre	CLR.W	D2		; D2 <-- position dans la ligne20$:	CALL	_AVANCE		; D3 <-- caractre suivant	JUMP',NE 90$	CALL	IFIEOL		; fin de la ligne ?	JUMP',EQ 80$	LOAD.W	D1,D2	CALL	_ADDLGC		; D2 <-- position suivante	LOAD.W	D0,D2	SUB.W	D0,D1		; D0 <-- largeur du caractre	SR.W	D0,#1		; D0 <-- demi-largeur	ADD.W	D0,D1	COMP.W	D0,D4	JUMP,LO 20$80$:	CALL	_RECULE		; recule un caractre avanc en trop90$:	CALL	PSEUDOAV	; avance encore si pseudo-caractres	POPM.L	D0..D4	RET;--------\\; GODOWN  >;========/; Va au dbut de la ligne suivante (contre en bas).; in	A5.L	^description d'un buffer; out	D7.W	erreur; mod	D7.WGODOWN:	PUSH.W	D340$:	CALL	_AVANCE		; avance d'un caractre	JUMP',NE 90$	CALL	IFIEOL		; dbut de ligne/image ?	JUMP,NE 40$		; non => 40$90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET	.END