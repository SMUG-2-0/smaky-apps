	.TITLE	TEXT;	--------------------------------------;		(C) 1985 - Daniel Roux;	--------------------------------------; TEXT	Date		Amliorations; ---------------------------------------------------------------------------------------------; 3.7	12.07.88	sauve: si "le texte seul" => plus de LF dans texte; 3.6	13.06.88	Imp: numrotation des pages avec + de possibilits; 3.5	25.02.88	mmenus hirarchiques;			courrier personnalis: plus de dbox  chaque impression;			sauve: "le texte seul" de nouveau ok;			imprime: si diffrent de .text => de nouveau ok; 3.4	01.02.88	adaptation  PRINTA/PRINTB;			ok avec prsentation avec zoom=1;			change en arrire: plus de bloquage;			mmenus: ".." et indication si maintenir press;			efface: relit TEXT.TEXT; 3.3	15.10.87	F0 demande s'il faut quitter;			utilisation de DBOX_PREND,AJOUTE,SAUVE,MAJ,etc.;			ok si imprimante pas installe;			Imp: libre toutes les images (+ de mmoire);			vrifie la rvision du systme avec LIB,?GETREV; 3.2	25.09.87	prend: ignore les \\zoom;; 3.1	08.09.87	F2 = Ajoute (et plus Modif);			Prend puis LISTE montre alors PREND/ANNULE;			utilisation de DBOX_ERCALL pour les appels FOS;			lit #:TEXT.TEXT si pas trouv dans dossier courant;			ajoute \\zoom; en sortie pour forcer le zoom 2; 3.0	11.08.87	Imp: pages de ..  .. et nb de copies;			Imp: courrier personnalis ...;			messages d'erreur plus clairs;			fichier!text: pas de /1 si aucune image;			(F12) = (Coupe pages) supprim => automatique !;			(F12) = (Va ), nouvelle fonction;			si ncessaire: (PROGRA-C) = coupe pages;			info: TEXT rev 3.0 --> TEXT 3.0; 2.15	09.07.87	frappe: Ind. <--> Exp. dans les soft-keys;			image: liste ok avec (F8) et (F9);			image: erreur si nom avec ":" (pas dans mme dossier);			efface: met un <CR> aprs la rgle;			prend: met le curseur aprs la premire rgle;			sauve: met tous les noms de gencars (\define g_Fond...);			fichier!text: met tous les noms d'images;			fichier!text: met les noms de gencars (nouveau);			image gnrique;			lit TEXT.TEXT par dfaut;			param: largeur/hauteur d'une page supprims !;			prend: ne met plus  jour OHTP/OLGP;			jusqu' 300 gencars sur disque (150 anciennement); 2.14			i/o: commande \large 0mm; avant \marge xmm;\large xmm;; 2.13			petite correction pour MATH64; 2.12			calculs enfin ok;			frappe: accents flottants ok; 2.11			Df: numrotation automatique des pages;			Sauve: si disque plein => erreur toujours affiche;			Sauve: cre un fichier "!";			image: affiche le nom en haut  gauche;			modifie une image: LIB,?OEXECUTE --> FOS,?EXECUTE;			refait une image: nouvelle fonction; 2.10			image: accepte les images codes; 2.9			appel de DESSIN ou PLAN pour modifier une image;			commandes \width et \dimcar dans textes;			tient compte des marges "hard" de l'imprimante;			Impression: plus les choix qualit, brouillon, etc.;			SRCHTL: colle la ligne en haut;			image: remet le <CR> aprs la commande !; 2.8	3.41		Param: marge fixe  gauche;			Imp: non simultan par dfaut;			Imp: si simultan et disque protg => fait non simultan;			image: n'ajoute plus <CR> aprs la commande; 2.7			Ne raffiche pas tout  chaque frappe d'un caractre !!!;			Justif: ok si seul tab dj dpass;			utilise urp09 (au lieu de mrp09) aussi pour "Evidence" !;			Justif: ok si un seul indent et deux tab frapps;			Remplace espace par _ dans les fonctions des caractres; 2.6			Justif: ok si <sajex><commande>car.. et chasse fixe (DRF07); 2.5	3.39		Prend: si erreur d'ouverture => re-dite le nom du fichier;			Utilis: un digit de plus;			Met un interligne de 4.2mm quelle que soit l'imprimante;			i/o: commandes \h et \hn remplaces par \a et \an (si .IF ABS=1);			utilise urp09 (au lieu de mrp09) par dfaut;			tab numrique: ok si nombre sans point ou virgule;			indentateurs...;			(CURSOR-Z et -B): dplacements par alinas;			(PROGRA-[ et -]): caractres spciaux << et >>;			dmarrage: erreurs fatales en clair;			(CTRL-flches): dplacements absolus;			(CLEAR): ferme toutes les images et refait liste des gencars;			Tout: ok mme si pages trs petites (plus de "zero div");			Images: sur la mme unit:rp: que le fichier texte;			Prend: \image #mm1:x; --> ne met plus "hn56" aprs l'image; 2.4			text seul: laisse les PEOP (LF) pour les I.R.L. !; 2.3	3.38		dbox io: ne fait plus EOP; 2.2	3.37		Autre --> Modif;			AFFBUF: si MODLIN, vrifie si "BAF" chang (oui => MODALL);			Tout: si plusieurs pages, transmet REG et COM;			@:#printer --> #printer; 2.1	3.36		(F2) = Autre;			infos: n'affiche plus "Reste:";			Disque: oprations "Prend", "Sauve" et "Autre";			mmenu ok si supprime gencar;			interligne ok si <C1>Titre<CR><C2>Suite... avec C1 grand; 2.0	3.35		accepte des gencar "f(sss..)tt" et "fsctt";			Prend: "le document entier" ou "le texte seul";			Df: choix de l'extension par dfaut;			asm/i dans la ligne de commande;			i/o: ok si pas assez de mmoire aprs justif en entre;			souris: changement de principe pour dplace/duplifie;			milieu: opration "zones";			calcul: 1re ligne des infos inverse, et icnes  gauche;			zone secondaire: icnes dans la ligne des infos;			(COPY-UNDO) et (COPY-KILL-UNDO) si zone sec. visible;			(SHOW)/(KILL): (R)gle, (I)mage, (C)ale, (TAB) et (RETURN);			souris: dplacement frontire entre zones princ. et sec.;			infos: zone inverse va jusqu' l'extrme droite;			duplifie --> duplique !;			ascenseur horizontal;			SAJEXM, SAJEXT et SAJEXS;			i/o: grouper si plusieurs \h ou \hn  la suite;			frappe: (PROGRA-0..9) -,) -.) -SPACE), etc.;			utilisation du module "lib" DGENC;			OK --> D'ACCORD ou VU;			Prend: touches PREND/AJOUTE et LISTE revient dans dbox;			Prend: si zro caractre => ne mmorise pas le nom;			Transforme: noms propres;			Icnes = ITP16; 1.6			droite: plus "transforme" si nombre;			calcul possible sur un nombre en Evidence;			bit BEOPMOD si PEOP/TEOP supprims;			si PEOP/TEOP au milieu d'un paragraphe => pas de 2me renfoncement;			descente/monte continue dans l'ascenseur (flches);			supprimer tous les RSTATUS fentre (sauf dans MIMAGE);			droite: mise en vidence de grandes zones;			plus de double TEOT  la fin du texte;			icnes "calcul" inverss pendant le clic;			plus de petit dcalage vertical d'un point (SRCHTL pair);			dernire ligne justifie si "toto<eot>";			(CURSOR-KILL-T) et -V) vont jusqu'au bout;			souris: dplacement tout  la fin ok;			output: ok si erreur pendant l'impression (CTRL-M3) !;			output: sauve le "texte seul" n'crit pas les TIRETs; 1.5			calculs; 1.4	3.34		justif aligne: sajex avant mot coup;			Coupe pages: PEOP jamais juste aprs une rgle;			mmenu: mmorise dernire case;			milieu: case "imprime";			tabulateur gauche ok si chasse fixe;			rgle: pas plus large que selon "Param";			transforme puis minuscules/majuscules;			justif: ok si tab dans ligne trop longue;			i/o: ok si pas assez de mmoire pour tous les gencars;			ligne des infos plus serre, avec utilis en %;			utilise MRP09 par dfaut; 1.3	3.33		m-menu avec premire case vide;			rgles plus petites (moins hautes);			(F8) --> frappe;			Cherche: dbox en BAS si possible;			Cherche: dbox Suivant-Stop;			i/o: commande \ver 1; au tout dbut;			i/o: unit "p" remplace par "pg";			i/o: ok pour longues commandes (>8 tabs);			Petit: minimum plus grand;			appel de PLAN pour modifier une image;			modification d'une rgle seule;			Imprime: utilisation d'une dbox;			i/o: commande \textfact x,y;; 1.2			ascenseur en haut si on est au dbut du texte;			Efface: utilise le gencar du fond aprs; 1.1			buffer image plus grand (LBUIM);			utilise le module SCROLL; 1.0	3.32		r1 aaa r2 bbb => si curseur dans bbb, ok si clic dans r1;			mot en gras => frappe lettre avant/aprs aussi en gras;			supprimer BFACVA (chasse proportionnelle);			Tout: met le plus grand au dpart;			Tout: MIN/MAX;			justif si ligne trop longue avec tab;			Sauve: mettre \g_Fond; au dbut;			curseur pas au bon endroit dans rgles/images;			Imp: processus fils ... (nouveau NTR de BB);			souris: menu droite diffrent si rgle/image seule	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"ABS	=	0		; 1 => commandes de positionnement absolues; Numros de rvision; -------------------TEXTREV	=	3		; rvision (0..9)TEXTVERS=	7		; version (0..99)	.REV	TEXTREV,TEXTVERS; Touches fonction; ----------------CURSOR	=	2^BCURSORCOPY	=	2^BCOPYKILL	=	2^BKILLPROGRA	=	2^BPROGRASHOW	=	2^BSHOWSEARCH	=	2^BSEARCHCHANGE	=	2^BCHANGE; Touches spciales; -----------------KCIRCON	=	'		; touche circonflxeKTREMA	=	'		; touche trmaKEYDBOX	=	H'7E00		; "touche" pour dbox; Caractres spciaux; -------------------SAJEXM	=	H'00		; espace variable <SAJEX> <0..127> <SAJEX>SAJEXS	=	H'01		; idem, mais soulign si ncessaireCADRATIN=	H'02		; espace indivisibleCODCUR	=	H'03		; code pour triangle curseurENDLINE	=	H'04		; indique fin ligne tronqueBEGLINE	=	H'05		; indique dbut ligne tronquCAREOP	=	H'06		; pseudo-fin de pageCAREOT	=	H'07		; fin du texteSAJEXT	=	H'08		; espace variable aprs <TAB>;TAB	=	H'09		; tabulateur fixe (modulo 8)TIRET	=	H'0B		; pseudo-tiretCAREOL	=	H'0D		; fin de ligneSPEC1	=	H'1E		; caractre spcialSPEC2	=	H'1F		; caractre spcialBOA	=	'\		; dbut d'une commande "boa"MAIL	=	'#		; dbut d'une commande "mailing"BSPEC	=	7		; bit pour caractres spciauxBEOL	=	5		; bit pour caractres fin de ligneTEOL	=	0!2^BEOL!2^BSPEC ; fin de lignePEOL	=	1!2^BEOL!2^BSPEC ; pseudo-fin de ligneTEOP	=	2!2^BEOL!2^BSPEC ; fin de pagePEOP	=	3!2^BEOL!2^BSPEC ; pseudo-fin de pageTEOT	=	4!2^BEOL!2^BSPEC ; fin du texteDEBIMA	=	8!2^BEOL!2^BSPEC ; dbut d'une imageFINIMA	=	9!2^BEOL!2^BSPEC ; fin d'une imageIMAGE	=	DEBIMA		 ; "caractre" imageDEBREG	=	10!2^BEOL!2^BSPEC ; dbut d'une rgletteFINREG	=	11!2^BEOL!2^BSPEC ; fin d'une rgletteREGLE	=	DEBREG		  ; "caractre" rgletteDEBCOM	=	0!2^BSPEC	; dbut d'une commandeFINCOM	=	1!2^BSPEC	; fin d'une commandeCOMMAND	=	DEBCOM		; "caractre" commandeMARQUED	=	2!2^BSPEC	; marque de dbut pendant justifMARQUEF	=	3!2^BSPEC	; marque de fin pendant justifCIRCON	=	'^		; caractre circonflxeTREMA	=	'"		; caractre trma; Gnrateurs de caractres; -------------------------GCTXF	=	'N!2^7		; fonte du texte  N(F)12GCTXS	=	2^BGCFIX	; style/chasse du texteGCTXT	=	12		; taille du texteGCPRF	=	'D		; fonte de l'imprimante  DRF07GCPRS	=	'R!2^7		; style/chasse de l'imprimanteGCPRT	=	07		; taille de l'imprimanteGCICF	=	'I		; fonte des icnes  ITP16GCICS	=	'T		; style/chasse des icnesGCICT	=	16		; taille des icnesGCICX	=	32		; largeur d'une icneGCICY	=	GCICT		; hauteur d'une icneICOSPACE=	1		; 1/4 espaceICOJUSTA=	2		; justification aligneICOJUSTD=	3		; justification drapeau  droiteICOJUSTG=	4		; justification drapeau  gaucheICOJUSTC=	5		; justification centreICOITL1	=	6		; interligne 1ICOITL12=	7		; interligne 1/2ICOITL2	=	8		; interligne 2ICOBTAB	=	9		; bote tabulateurICOBTABG=	10		; bote tabulateur gaucheICOBTABC=	11		; bote tabulateur centrICOBTABN=	12		; bote tabulateur numriqueICOTAB	=	13		; tabulateurICOTABG	=	14		; tabulateur gaucheICOTABC	=	15		; tabulateur centrICOTABN	=	16		; tabulateur numriqueICOMGG	=	17		; marge gaucheICORENF	=	18		; renfoncementICOMGD	=	19		; marge droiteICODETR	=	20		; dtruitICODEPL	=	21		; dplaceICODUPL	=	22		; duplifieICOMODE	=	23		; modeICOCAR	=	24		; caractreICONORM	=	25		; normalICOSOUL	=	26		; soulignICOEXP	=	27		; exposantICOIND	=	28		; indiceICOCOUP	=	29		; ciseauxICOIMAGE=	30		; imageICOREGLE=	31		; rgleICOCHER	=	32		; chercheICOJUST	=	33		; justificationICODEF	=	34		; dfinitionICOPREND=	35		; prendICOSAUVE=	36		; sauveICOPRINT=	37		; imprimanteICOPETIT=	38		; mode petitICOFRAPPE=	39		; frappeICOMODI	=	40		; modification image (PLAN)ICOMODR	=	41		; modification rgleICOMIMA	=	42		; A <--> aICOMIN	=	43		; abcICOMAJ	=	44		; ABCICOMAMI	=	45		; Abc (noms propres)ICOAJOUTE=	46		; ajouteICODISK	=	47		; disqueICONUM	=	48;;57		; chiffres 0..9ICOCALC	=	58		; calculICOADD	=	59		; additionneICOSUB	=	60		; soustraitICOMUL	=	61		; multiplieICODIV	=	62		; diviseICOEGAL	=	63		; touche =ICOANUL	=	64		; touche annuleICOCOPK	=	65		; copie avec destructionICOCOPM	=	66		; copie multipleICOCOPD	=	67		; destruction sans copieICOCOPX	=	68		; change des zonesICOCOPZ	=	69		; dplace la frontireICOZONE	=	70		; changement de zonesICOBTABI=	71		; bote indentateurICOTABI	=	72		; indentateurICOMODJ	=	73		; modification image (DESSIN)ICOREFAIT=	74		; refait l'imageICOGOTO	=	75		; va ICOMOVE	=	76		; tenir press le bouton de la souris !ICOEDITE=	77		; dite  >ICOVUE	=	78		; vue    >ICODIVERS=	79		; divers >ICOLABEL=	80;;90		; labels [ ] et [A]..[J]ICOQUITTE=	91		; quitteICOEFFACE=	92		; effaceICOJUSTIF=	93		; justificationICOPARAM=	94		; paramtresICOANNULE=	95		; annule; Rglette; --------MAXTAB	=	20		; nb max de tabulateurs	.LOC	0OREGJUST:.BLKB	1		; mode de justification JUSTA	=  0			;  justification aligne JUSTD	=  1			;  justification drapeau  droite JUSTG	=  2			;  justification drapeau  gauche JUSTC	=  3			;  justification centreOREGITL:.BLKB	1		; distance de l'interligne ITL1	=  0			;  interligne 1 ITL12	=  1			;  interligne 1/2 ITL2	=  2			;  interligne 2OREGTAB:.BLKW	MAXTAB		; tabulateurs (*) BTABGAU=  11			;  bit pour tabulateur gauche BTABCEN=  12			;  bit pour tabulateur centr BTABNUM=  13			;  bit pour tabulateur numrique BTABIND1= 12			;  bit pour indentateur (+BTABIND2) BTABIND2= 13			;  bit pour indentateur (+BTABIND1) BTABMGG=  14			;  bit pour marge gauche (+BTABMGD=renf) BTABMGD=  15			;  bit pour marge droite (+BTABMGG=renf)OREGMGG:.BLKW	1		; marge gauche (*)OREGMGD:.BLKW	1		; marge droi