ions d'une page (Y;X)OSTPRI:	.BLKB	LGPRI2		; status actuel de l'imprimanteOSSPRI:	.BLKB	LGPRI0		; status prcdent de l'imprimanteOITL:	.BLKB	2		; interligne standardOHTP:	.BLKB	2		; hauteur d'une pageOLGP:	.BLKB	2		; largeur d'une pageOMGS:	.BLKB	2		; marge suprieureOMGI:	.BLKB	2		; marge infrieureOMGG:	.BLKB	2		; marge gaucheOMGSH:	.BLKB	2		; marge suprieure hardOMGIH:	.BLKB	2		; marge infrieure hardOFACX:	.BLKB	2		; facteur rduction en XOFACY:	.BLKB	2		; facteur rduction en YOMMX:	.BLKB	2		; nb de 1/10 de um pour un point en XOMMY:	.BLKB	2		; nb de 1/10 de um pour un point en YOQUAL:	.BLKB	2		; nb max de qualits possiblesOTITL:	.BLKB	2		; interligne standardOTHTP:	.BLKB	2		; hauteur d'une pageOTLGP:	.BLKB	2		; largeur d'une pageOTMGS:	.BLKB	2		; marge suprieureOTMGI:	.BLKB	2		; marge infrieureOTMGG:	.BLKB	2		; marge gaucheODRFX:	.BLKB	2		; DRF07: largeurODRF1Y:	.BLKB	2		; DRF07: hauteur dessus la ligne de baseODRF2Y:	.BLKB	2		; DRF07: hauteur dessous la ligne de baseOCALCUL:.BLKB	8		; rsultat du calcul en coursLGVAR:	.LOC	0	.INS	TEXTINIT.ASI	.INS	TEXTMAIN.ASI	.INS	TEXTACCENT.ASI	.INS	TEXTFLECHE.ASI	.INS	TEXTABSOLU.ASI	.INS	TEXTSEARCH.ASI	.INS	TEXTMOUSE.ASI	.INS	TEXTCALCUL.ASI	.INS	TEXTSCREEN.ASI	.INS	TEXTPETIT.ASI	.INS	TEXTIMAGE.ASI	.INS	TEXTIMGC.ASI	.INS	TEXTREGLE.ASI	.INS	TEXTCOMM.ASI _INIBUF:	JUMP	INIBUF_GETPTC:	JUMP	GETPTC_MSVISU:	JUMP	MSVISU_NVISU:		JUMP	NVISU_PVISU:		JUMP	PVISU_TNVISU:	JUMP	TNVISU_TPVISU:	JUMP	TPVISU_CNVISU:	JUMP	CNVISU_CPVISU:	JUMP	CPVISU_VAFIN:		JUMP	VAFIN_VADEBUT:	JUMP	VADEBUT_VAQQPART:	JUMP	VAQQPART_QUICKUP:	JUMP	QUICKUP_QUICKDOWN:	JUMP	QUICKDOWN_INSERT:	JUMP	INSERT_CINSERT:	JUMP	CINSERT_AVANCE:	JUMP	AVANCE_RECULE:	JUMP	RECULE_DAVANCE:	JUMP	DAVANCE_DRECULE:	JUMP	DRECULE_GPPBUF:	JUMP	GPPBUF_PLACE?:	JUMP	PLACE?_SKIPHOL:	JUMP	SKIPHOL_INI1B:		JUMP	INI1B_INI2B:		JUMP	INI2B_FLUSH:		JUMP	FLUSH_GNBUF:		JUMP	GNBUF_PSEUDOAV:	JUMP	PSEUDOAV_FINPUT:	JUMP	FINP