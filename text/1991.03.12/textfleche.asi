	.SBTTL	TEXTFLECHEDOGOTO:	CALL	DBOXGOTO	; D4 <-- demande page o aller ...	JUMP,NE 90$	COMP.W	D3,#CR	JUMP,NE 90$	TEST.B	(A5)+OSTATUS:#BEOPMOD	JUMP',BC 10$	CALL	_PJUSTIF	; coupe toutes les pages ...10$:	LOAD.L	A4,(A5)+OPDB	; A4 <-- ^dbut du texte20$:	DEC.W	D4	JUMP',LE 30$	CALL	SRCPDOWN	; A4 <-- ^dbut page suivante	JUMP,EQ	20$30$:	CALL	_VAQQPART	; va au dbut de la page choisie	CALL	BIGCURS		; faudra dessiner le grand curseur90$:	RET; touche (CURSOR); ---------------OCURSOR:	CALL	EXKEY	.WW	'F	DCARAC		; +1 caractre	.WW	'G	DCHAMP		; +1 mot	.WW	'C	DLIGNE		; +1 ligne	.WW	'X	D4LIGNE		; +4 lignes	.WW	'B	DALINEA		; +1 alina	.WW	'Y	DPAGE		; +1 page	.WW	'V	DBUFFER		; fin du texte	.WW	'D	DBCARAC		; -1 caractre	.WW	'S	DBCHAMP		; -1 mot	.WW	'R	DBLIGNE		; -1 ligne	.WW	'E	DB4LIGNE	; -4 lignes	.WW	'Z	DBALINEA	; -1 alina	.WW	'W	DBPAGE		; -1 page	.WW	'T	DBBUFFER	; dbut du texte	.WW	0	NMAINDBUFFER:	CALL	BIGCURS		; faudra dessiner le grand curseur	CALL	EXDEPL		; signal dplacement	JUMP	_VAFIND4LIGNE:	CALL	BIGCURS		; faudra dessiner le grand curseur	CALL	EXDEPL		; signal dplacement	LOAD.B	D4,#2		; classe 2 (saut de lignes)	LOAD.B	D0,#NBMYLI	; 4 fois10$:	CALL	BORNAV	DEC.B	D0	JUMP,NE	10$	RETDPAGE:	INC.B	D4		; classe 4DALINEA:INC.B	D4		; classe 3DLIGNE:	INC.B	D4		; classe 2	CALL	BIGCURS		; faudra dessiner le grand curseurDCHAMP:	INC.B	D4		; classe 1DCARAC:	CALL	EXDEPL		; signal dplacement	JUMP	BORNAVDBBUFFER:	CALL	BIGCURS		; faudra dessiner le grand curseur	CALL	EXDEPL		; signal dplacement	JUMP	_VADEBUTDB4LIGNE:	CALL	BIGCURS		; faudra dessiner le grand curseur	CALL	EXDEPL		; signal dplacement	LOAD.B	D4,#2		; classe 2 (saut de lignes)	LOAD.B	D0,#NBMYLI	; 4 fois10$:	CALL	BORNAR	DEC.B	D0	JUMP,NE	10$	RETDBPAGE:	INC.B	D4		; classe 4DBALINEA:INC.B	D4		; classe 3DBLIGNE:INC.B	D4		; classe 2	CALL	BIGCURS		; faudra dessiner le grand curseurDBCHAMP:INC.B	D4		; classe 1DBCARAC:CALL	EXDEPL		; signal dplacement	JUMP	BORNAR; touches (KILL-CURSOR); ---------------------OKILLCURS:	CALL	EXKEY	.WW	'F	KCARAC		; +1 caractre	.WW	'G	KCHAMP		; +1 mot	.WW	'C	KLIGNE		; +1 ligne	.WW	'X	K4LIGNE		; +4 lignes	.WW	'B	KALINEA		; +1 alina	.WW	'Y	KPAGE		; +1 page	.WW	'V	KBUFFER		; fin du texte	.WW	'D	KBCARAC		; -1 caractre	.WW	'S	KBCHAMP		; -1 mot	.WW	'R	KBLIGNE		; -1 ligne	.WW	'E	KB4LIGNE	; -4 lignes	.WW	'Z	KBALINEA	; -1 alina	.WW	'W	KBPAGE		; -1 page	.WW	'T	KBBUFFER	; dbut du texte	.WW	0	NMAINKBUFFER:	CALL	DBOXSURE	; etes-vous sr ?	JUMP,NE	MAIN		; non => MAIN	CALL	BIGCURS		; faudra dessiner le grand curseur	CALL	EXKILL		; signal destruction20$:	CALL	KILLAV		; mmorise pour v. rcupration	CALL	_DAVANCE	JUMP,EQ 20$	RETK4LIGNE:	CALL	BIGCURS		; faudra dessiner le grand curseur	CALL	EXKILL		; signal destruction	LOAD.B	D4,#2		; classe 2 (saut de lignes)	LOAD.B	D0,#NBMYLI	; 4 fois10$:	CALL	BORNAV	CALL	_QJUSTIF	; justifie un p'tit peu	DEC.B	D0	JUMP,NE	10$	RETKPAGE:	INC.B	D4		; classe 4KALINEA:INC.B	D4		; classe 3KLIGNE:	INC.B	D4		; classe 2	CALL	BIGCURS		; faudra dessiner le grand curseurKCHAMP:	INC.B	D4		; classe 1KCARAC:	CALL	EXKILL		; signal destruction	CALL	BORNAV	CALL	_QJUSTIF	; justifie un p'tit peu	RETKBBUFFER:	CALL	DBOXSURE	; etes-vous sr ?	JUMP,NE	MAIN		; non => MAIN	CALL	BIGCURS		; faudra dessiner le grand curseur	CALL	EXKILL		; signal destruction20$:	CALL	KILLAR		; mmorise pour v. rcupration	CALL	_DRECULE	JUMP,EQ 20$	RETKB4LIGNE:	CALL	BIGCURS		; faudra dessiner le grand curseur	CALL	EXKILL		; signal destruction	LOAD.B	D4,#2		; classe 2 (saut de lignes)	LOAD.B	D0,#NBMYLI	; 4 fois10$:	CALL	BORNAR	CALL	_QJUSTIF	; justifie un p'tit peu	DEC.B	D0	JUMP,NE	10$	RETKBPAGE:	INC.B	D4		; classe 4KBALINEA:INC.B	D4		; classe 3KBLIGNE:INC.B	D4		; classe 2	CALL	BIGCURS		; faudra dessiner le grand curseurKBCHAMP:INC.B	D4		; classe 1KBCARAC:CALL	EXKILL		; signal destruction	CALL	BORNAR	CALL	_QJUSTIF	; justifie un p'tit peu	RETDOEFFACE:	CALL	DBOXEFFACE	; etes-vous sr ?	JUMP,NE	MAIN		; non => MAIN	CALL	_FLUSH		; vide tout en mmoire	TEST.B	(A6)+OFLAGS:#BEPRO ; dition de programmes ?	JUMP',BS 90$		; oui => 90$				; non =>	CALL	_TINPUT		; lit TEXT.TEXT ...	TEST.W	D7	JUMP',EQ 90$	CALL	_FLUSH		; vide tout en mmoire	CALL	INSREGLE	; met toujours une rgle au dbut !	LOAD.W	D3,#TEOL	CALL	_INSERT		; met juste une fin de ligne	CALL	_RECULE		; puis recule avant !90$:	RET; touche (KILL); -------------OKILL:	CALL	EXKEY	.WW	'R	AFNREGLE	.WW	'I	AFNIMAGE	.WW	'C	AFNCALE	.WW	'H	AFNASCH	.WW	TAB	AFNTAB	.WW	CR	AFNCR	.WW	SPACE	AFNTOUT	.WW	0	NMAINAFNTOUT:	CALL	AFNCR	CALL	AFNTAB	CALL	AFNCALE	CALL	AFYIMAGE;	CALL	AFNREGLE;	RETAFNREGLE:	TCLR.B	(A6)+OFANION+3:#BFAREG	JUMP'	AFNAFNIMAGE:	TCLR.B	(A6)+OFANION+3:#BFAIMA	JUMP'	AFNAFNCALE:	TCLR.B	(A6)+OFANION+3:#BFASAJ	JUMP'	AFNAFNASCH:	TCLR.B	(A6)+OFANION+2:#BFASCH-8	JUMP'	AFNAFNTAB:	TCLR.B	(A6)+OFANION+3:#BFATAB	JUMP'	AFNAFNCR:	TCLR.B	(A6)+OFANION+3:#BFAEOL;	JUMP'	AFNAFN:	JUMP',BC 90$	LOAD.W	D4,#MODALL	CALL	MODIF90$:	RETAFYTOUT:	CALL	AFYCR	CALL	AFYTAB	CALL	AFYCALE	CALL	AFNIMAGE;	CALL	AFYREGLE;	RETAFYREGLE:	TSET.B	(A6)+OFANION+3:#BFAREG	JUMP'	AFYAFYIMAGE:	TSET.B	(A6)+OFANION+3:#BFAIMA	JUMP'	AFYAFYCALE:	TSET.B	(A6)+OFANION+3:#BFASAJ	JUMP'	AFYAFYASCH:	TSET.B	(A6)+OFANION+2:#BFASCH-8	JUMP'	AFYAFYTAB:	TSET.B	(A6)+OFANION+3:#BFATAB	JUMP'	AFYAFYCR:	TSET.B	(A6)+OFANION+3:#BFAEOL;	JUMP'	AFYAFY:	JUMP',BS 90$	LOAD.W	D4,#MODALL	CALL	MODIF90$:	RET; touche (COPY); -------------OCOPY:	CALL	EXKEY	.WW	'F	CCARAC		; +1 caractre	.WW	'G	CCHAMP		; +1 mot	.WW	'C	CLIGNE		; +1 ligne	.WW	'X	C4LIGNE		; +4 lignes	.WW	'B	CALINEA		; +1 alina	.WW	'Y	CPAGE		; +1 page	.WW	'V	CBUFFER		; jusqu' la fin	.WW	'T	CTOUT		; tout	.WW	DEFINE	COPDEF	.WW	UNDO	COPYUNDO	.WW	0	COPYINITCOPDEF:	CLR.W	D2		; D2 <-- au milieu de la fentre	JUMP	_AOUTPUT	; crit ...COPYINIT:	CALL	_GNBUF		; (SHOW-[SHIFT-]0..9) ?	JUMP,NE COPYCTRL	; non => COPYCTRL				; oui =>	LOAD.W	D1,D0		; D1 <-- no buffer secondaire	LOAD.W	D0,(A5)+ONOBUF	; D0 <-- no buffer principal	COMP.W	D0,D1	JUMP',EQ 90$	CALL	_INI2B		; init 2 buffers si diffrents	CALL	BIGCURS		; faudra dessiner le grand curseur90$:	RETCOPYCTRL:	COMP.B	D3,#'0-H'20	JUMP,LO NMAIN	COMP.B	D3,#'9-H'20	; (CTRL-0)..(CTRL-9) ?	JUMP,HI NMAIN		; non => NMAIN				; oui =>	LOAD.B	D0,D3	SUB.B	D0,#'0-H'20	; D0 <-- 0..9	AND.W	D0,#H'FF	LOAD.W	D2,#1		; D2 <-- COPY avec KILL	SR.W	D3,#8		; D3 <-- (COPY) ou (COPY-KILL)	COMP.B	D3,#COPY!KILL	; (COPY-KILL-CTRL) ?	JUMP',EQ 10$		; oui => 10$	CLR.W	D2		; D2 <-- COPY sans KILL10$:	JUMP	COPYSPCOPYUNDO:	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE	JUMP,BS NMAIN	LOAD.W	D0,(A6)+OBUFS+ONOBUF	LOAD.W	D2,#1		; D2 <-- COPY avec KILL	SR.W	D3,#8		; D3 <-- (COPY) ou (COPY-KILL)	COMP.B	D3,#COPY!KILL	; (COPY-KILL-CTRL) ?	JUMP',EQ 10$		; oui => 10$	CLR.W	D2		; D2 <-- COPY sans KILL10$:	JUMP	COPYSPC4LIGNE:	CALL	BIGCURS		; faudra dessiner le grand curseur	CALL	INI2BC		; init zone secondaire si pas dj fait	CALL	EXCOPY		; signal copie	LOAD.B	D4,#2		; classe 2 (saut de lignes)	LOAD.B	D0,#NBMYLI	; 4 fois10$:	CALL	BORNAV	DEC.B	D0	JUMP,NE	10$	RETCTOUT:	CALL	_VADEBUT	; revient au dbutCBUFFER:INC.B	D4		; classe 5CPAGE:	INC.B	D4		; classe 4CALINEA:INC.B	D4		; classe 3CLIGNE:	INC.B	D4		; classe 2	CALL	BIGCURS		; faudra dessiner le grand curseurCCHAMP:	INC.B	D4		; classe 1CCARAC:	CALL	INI2BC		; init zone secondaire si pas dj fait	CALL	EXCOPY		; signal copie	CALL	BORNAV	RET; touches (COPY-KILL); -------------------OCOPYKILL:	CALL	EXKEY	.WW	'F	CKCARAC		; +1 caractre	.WW	'G	CKCHAMP		; +1 mot	.WW	'C	CKLIGNE		; +1 ligne	.WW	'X	CK4LIGNE	; +4 lignes	.WW	'B	CKALINEA	; +1 alina	.WW	'Y	CKPAGE		; +1 page	.WW	'V	CKBUFFER	; jusqu' la fin	.WW	'T	CKTOUT		; tout	.WW	UNDO	COPYUNDO	.WW	0	COPYCTRLCK4LIGNE:	CALL	BIGCURS		; faudra dessiner le grand curseur	CALL	INI2BC		; init zone secondaire si pas dj fait	CALL	EXCOPYKILL	; signal copie	LOAD.B	D4,#2		; classe 2 (saut de lignes)	LOAD.B	D0,#NBMYLI	; 4 fois10$:	CALL	BORNAV	CALL	_QJUSTIF	; justifie un p'tit peu	DEC.B	D0	JUMP,NE	10$	RETCKTOUT:	CALL	_VADEBUT	; revient au dbutCKBUFFER:INC.B	D4		; classe 5CKPAGE:	INC.B	D4		; classe 4CKALINEA:INC.B	D4		; classe 3CKLIGNE:INC.B	D4		; classe 2	CALL	BIGCURS		; faudra dessiner le grand curseurCKCHAMP:INC.B	D4		; classe 1CKCARAC:CALL	INI2BC		; init zone secondaire si pas dj fait	CALL	EXCOPYKILL	; signal copie	CALL	BORNAV	CALL	_QJUSTIF	; justifie un p'tit peu	RET;--------\; INI2BC  >;========/; Initialise deux buffers pour les (COPY). S'il y en a dj; deux, rien est chang. S'il n'y en a qu'un, cherche le; prochain buffer vide. S'il n'y a aucun buffer libre, utilise; le buffer suivant de toute faon.; Cette recherche est effectue seulement dans les 10 premiers; buffers.; in	-; out	-; mod	D7.WINI2BC:	PUSHM.L	D0,D1,D2,A4	TEST.B	(A6)+OBUFS+OSTBUF:#BBUFRE ; dj 2 buffer ?	JUMP',BC 90$		; oui => 90$ (ne change rien)				; non =>	LOAD.W	D0,(A5)+ONOBUF	LOAD.W	D2,#(NBBF/2)-1	; D2 <-- nb buffer o chercher10$:	INC.W	D0		; D0 <-- no buffer suivant	COMP.W	D0,#NBBF/2	; dernier buffer ?	JUMP',NE 20$		; non => 20$	CLR.W	D0		; oui => repart au premier20$:	CALL	_GPPBUF		; A4 <-- ^description compactifie	JUMP',EQ 50$		; zone vide => 50$				; non =>	DEC.W	D2	JUMP,NE	10$		; cherche plus loin				; si tous plein =>	LOAD.W	D0,(A5)+ONOBUF	INC.W	D0		; D0 <-- no buffer suivant50$:	LOAD.W	D1,D0		; D1 <-- no buffer secondaire	LOAD.W	D0,(A5)+ONOBUF	; D0 <-- no buffer actuel	CALL	_INI2B		; initialise 2 buffers	CALL	BIGCURS		; faudra dessiner le grand curseur90$:	POPM.L	D0,D1,D2,A4	RET;--------\\; COPYSP  >;========/; Copie une zone secondaire quelconque dans la zone principale.; in	D0.W	no buffer secondaire (source);	D2.W	zro => COPY, un => COPY-KILL; out	-; mod	D7.WCOPYSP:	PUSHM.L	D0..D3	LOAD.W	D1,(A5)+ONOBUF	; D1 <-- no buffer destination	COMP.W	D0,D1		; 2 buffer gaux ?	JUMP,EQ 90$		; oui => 90$ (rien  faire)				; non =>	LOAD.B	D3,#MARQUED	CALL	_INSERT		; marque le dbut de la zone	SL.W	D2,#8		; D2 <-- :#8 = COPY avec/sans KILL	LOAD.B	D2,(A6)+OBUFS+OSTBUF ; D2 <-- 2^BBUFRE si dj deux zones	PUSH.W	(A6)+OBUFP+OMODIF	CALL	_INI2B		; zone principale = source	POP.W	(A6)+OBUFS+OMODIF	CALL	_VADEBUT	; revient au dbut zone principale	TEST.L	D2:#8		; COPY-KILL ?	JUMP',BS 40$		; oui => 40$20$:	CALL	COPYONE		; copie un caractre	JUMP',NE 80$	CALL	_AVANCE		; puis avance sur le suivant	JUMP,EQ	20$	JUMP'	80$40$:	CALL	COPYONE		; copie un caractre	JUMP',NE 50$	CALL	_DAVANCE	; dtruit le puis avance	JUMP,EQ	40$50$:	CALL	_FLUSH		; enlve les commandes qui sont restes !80$:	EX.L	D0,D1	TEST.L	D2:#BBUFRE	; y avait-il deux zones ?	JUMP',BC 82$		; oui => 82$				; non =>	PUSH.W	(A6)+OBUFS+OMODIF	CALL	_INI1B		; remet la zone principale initiale	POP.W	(A6)+OBUFP+OMODIF	JUMP'	85$82$:	TEST.L	D2:#8	JUMP',BC 83$	CALL	_INI1B		; met une zone, puis refait tout	JUMP'	85$83$:				; COPY sans KILL =>	CALL	_INI2B		; met deux zones, puis refait tout85$:	LOAD.B	D3,#MARQUEF	CALL	_INSERT		; marque la fin de la zone	CALL	_ZJUSTIF	; justifie la zone	CALL	_ZFJUSTIF	; enlve les marques et va  la fin	CALL	BIGCURS		; faudra dessiner le grand curseur90$:	POPM.L	D0..D3	RET;--------\\; COPYONE >;========/; Copie un caractre dans le buffer secondaire.;	principal --> secondaire; N'avance pas dans le buffer principal, pour permettre de; faire AVANCE ou DAVANCE !; in	-; out	D7.W	erreur; mod	D7.WCOPYONE:	PUSHM.L	D3,D4,A4,A5	CALL	_GETPTC		; D3 <-- caractre sous le curseur	JUMP,NE 90$	COMP.B	D3,#COMMAND	JUMP,EQ 90$	COMP.B	D3,#IMAGE	JUMP',EQ 40$	COMP.B	D3,#REGLE	JUMP',EQ 60$	CALL	IFPSEUDO	JUMP,EQ 90$	COMP.B	D3,#PEOL	JUMP,EQ 90$	SWAP.W	D3	LOAD.W	D3,(A5)+OCCOM+OCOMNOG	SWAP.W	D3	LOAD.L	A5,#(A6)+OBUFS	CALL	GINSERT		; insre dans le buffer secondaire	JUMP	90$40$:				; image =>	LOAD.W	D4,#LGNAME+10	CALL	_PLACE?		; place pour l'image ?	JUMP',NE 90$		; non => 90$	LOAD.L	A4,(A5)+OPFT45$:	LOAD.L	A5,#(A6)+OBUFP	CALL	_CNVISU		; D3 <-- caractre suivant	JUMP',NE 90$	LOAD.L	A5,#(A6)+OBUFS	CALL	_CINSERT	; insre dans le buffer secondaire	COMP.B	D3,#FINIMA	; fin de l'image ?	JUMP,NE	45$		; non => 45$	LOAD.W	D4,#MODALL	CALL	MODIF	JUMP'	90$60$:				; rglette =>	LOAD.W	D4,#1+(LGREG*2)+1	CALL	_PLACE?		; place pour la rglette ?	JUMP',NE 90$		; non => 90$	LOAD.L	A4,(A5)+OPFT65$:	LOAD.L	A5,#(A6)+OBUFP	CALL	_CNVISU		; D3 <-- caractre suivant	JUMP',NE 90$	LOAD.L	A5,#(A6)+OBUFS	CALL	_CINSERT	; insre dans le buffer secondaire	COMP.B	D3,#FINREG	; fin de la rglette ?	JUMP,NE	65$		; non => 65$	LOAD.W	D4,#MODALL	CALL	MODIF	CALL	NEWREGLE	; mj selon rglettes suivante/prcdente90$:	POPM.L	D3,D4,A4,A5	TEST.W	D7		; retour EQ/NE	RET; Rcupration; ------------;--------\\; EXDEPL  >;========/; Signal qu'un dplacement va tre fait.; in	-; out	-; mod	-EXDEPL:	LOAD.B	(A5)+OACTION,#2^BACURS	RET;--------\\; EXKILL  >;========/; Signal qu'une destruction va tre faite.; in	-; out	-; mod	-EXKILL:	COMP.B	(A5)+OACTION,#2^BAKILL	JUMP',EQ 90$	LOAD.B	(A5)+OACTION,#2^BAKILL	PUSH.L	A4	LOAD.L	A4,#(A6)+OTMIO+(LTMIO/2)	LOAD.L	(A6)+ORECPA,A4	LOAD.L	(A6)+ORECPR,A4	LOAD.W	(A6)+ORECNA,#LTMIO/2	LOAD.W	(A6)+ORECNR,#LTMIO/2	LOAD.W	(A6)+ORECGA,#-1	LOAD.W	(A6)+ORECGR,#-1	POP.L	A490$:	RET;--------\\; EXCOPY  >;========/; Signal qu'une copie va tre faite.; in	-; out	-; mod	-EXCOPY:	LOAD.B	(A5)+OACTION,#2^BACOPY	RET;-----------\\; EXCOPYKILL >;===========/; Signal qu'une copie avec destruction va tre faite.; in	-; out	-; mod	-EXCOPYKILL:	LOAD.B	(A5)+OACTION,#2^BACOPK	RET;--------\\; EXABS   >;========/; Signal qu'un dplacement absolu va tre fait.; in	-; out	-; mod	-EXABS:	COMP.B	(A5)+OACTION,#2^BACTRL	JUMP',EQ 90$	LOAD.B	(A5)+OACTION,#2^BACTRL	PUSH.L	D2	CALL	GPOSABS		; D2 <-- position absolue dans la ligne	LOAD.W	(A5)+OPOSABS,D2	POP.L	A290$:	RET;--------\\; EXOTHER >;========/; Signal qu'une chose non rcuprable va tre faire.; in	-; out	-; mod	-EXOTHER:	CLR.B	(A5)+OACTION	RET;--------\\; EXRECUP >;========/; Rcupre une destruction ou un dplacement.; in	-; out	-; mod	D7.WEXRECUP:	PUSHM.L	D2,D3,D4,A3,A4	COMP.B	(A5)+OACTION,#2^BAKILL	JUMP',EQ 20$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	80$; Met une commande au dbut de la zone dtruite en arrire.; Ici, les commandes sont toujours mises avec un retard pour; tre au dbut des caractres concerns, et pas  la fin !20$:	LOAD.L	A4,(A6)+ORECPR	LOAD.W	D4,(A6)+ORECNR	JUMP',EQ 30$	LOAD.W	D3,(A6)+ORECGR	COMP.W	D3,#-1	JUMP',EQ 30$	SUB.W	D4,#3	JUMP',LE 30$	RR.W	D3,#8	LOAD.B	(-A4),D3	; <gencar>	RR.W	D3,#8	LOAD.B	(-A4),D3	; <mode>	LOAD.B	(-A4),#COMMAND	; <command>	LOAD.L	(A6)+ORECPR,A4	LOAD.W	(A6)+ORECNR,D430$:	LOAD.B	D3,#MARQUED	CALL	_INSERT	LOAD.L	A4,(A6)+ORECPR	LOAD.W	D4,#LTMIO/2	SUB.W	D4,(A6)+ORECNR	CALL	ANTIKILL	; rcupre les destructions en arrire	LOAD.B	D3,#MARQUEF	CALL	_INSERT	CALL	_ZJUSTIF	; justifie la zone	CALL	_ZFJUSTIF	; enlve les marques et va  la fin	LOAD.B	D3,#MARQUED	CALL	_INSERT	LOAD.L	A4,#(A6)+OTMIO+(LTMIO/2)	LOAD.W	D4,#LTMIO/2	SUB.W	D4,(A6)+ORECNA	CALL	ANTIKILL	; rcupre les destructions en avant	LOAD.B	D3,#MARQUEF	CALL	_INSERT	CALL	_ZJUSTIF	; justifie la zone	CALL	_ZDJUSTIF	; enlve les marques et va au dbut	CALL	BIGCURS		; faudra dessiner le grand curseur80$:	CALL	EXOTHER		; une seule rcupration	POPM.L	D2,D3,D4,A3,A4	RET;---------\\; ANTIKILL >;---------/; Rcupre quelques caractres.; Il n'est pas ncessaire de vrifier s'il y a assez de place; car les caractres viennent d'tre dtruits !; in	A4.L	^bytes  rcuprer;	D4.W	nombre; out	-; mod	D2.L, D3.L, D4.W, A3.L, A4.LANTIKILL:	LOAD.L	A3,A4		; A3 <-- ^byte(s)	CLR.W	D2		; D2 <-- gencar/mode10$:	TEST.W	D4		; encore un caractre ?	JUMP,LE 90$		; non => 90$	LOAD.B	D3,(A3+)	DEC.W	D4	COMP.B	D3,#DEBIMA	JUMP',EQ 20$	COMP.B	D3,#DEBREG	JUMP',EQ 40$	COMP.B	D3,#COMMAND	JUMP',EQ 60$	COMP.B	D3,#MARQUED	JUMP,EQ	10$	COMP.B	D3,#MARQUEF	JUMP,EQ	10$	SWAP.W	D3	LOAD.W	D3,D2		; D3 <-- gencar/mode/?/code	SWAP.W	D3	CALL	GINSERT		; rcupre un caractre	JUMP	10$20$:				; image =>	CALL	_CINSERT25$:	LOAD.B	D3,(A3+)	DEC.W	D4	CALL	_CINSERT	COMP.B	D3,#FINIMA	JUMP,NE	25$	PUSH.W	D4	LOAD.W	D4,#MODALL	CALL	MODIF	POP.W	D4	JUMP	10$40$:				; rglette =>	CALL	_CINSERT45$:	LOAD.B	D3,(A3+)	DEC.W	D4	CALL	_CINSERT	COMP.B	D3,#FINREG	JUMP,NE	45$	CALL	NEWREGLE	; mj rglettes sup/inf	PUSH.W	D4	LOAD.W	D4,#MODALL	CALL	MODIF	POP.W	D4	JUMP	10$60$:				; commande (format spcial) =>	LOAD.B	D2,(A3+)	; D2 <-- mode	RR.W	D2,#8	LOAD.B	D2,(A3+)	; D2 <-- gencar	RR.W	D2,#8	SUB.W	D4,#2	JUMP	10$90$:	RET;--------\\; KILLAV  >;========/; Mmorise un caractre dtruit en avant en vue d'une; ventuelle rcupration avec (UNDO).; Doit tre appel juste avant DAVANCE !; in	-; out	-; mod	-KILLAV:	PUSHM.L	D2..D4,A2,A4	LOAD.L	A2,(A5)+OPFT	COMP.L	A2,(A5)+OPFB	; est-on tout  la fin ?	JUMP,EQ 90$		; oui => 90$	LOAD.B	D3,(A2+)	; D3 <-- premier byte qui sera dtruit	COMP.B	D3,#SAJEXM	JUMP,EQ 90$	COMP.B	D3,#SAJEXT	JUMP,EQ 90$	COMP.B	D3,#SAJEXS	JUMP,EQ 90$	COMP.B	D3,#TIRET	JUMP,EQ 90$	COMP.B	D3,#PEOL	JUMP,EQ 90$	COMP.B	D3,#PEOP	JUMP,EQ 90$	COMP.B	D3,#DEBCOM	JUMP,EQ 90$	LOAD.W	D2,#1	TEST.L	D3:#BSPEC	; caractre spcial ?	JUMP',BC 40$		; non => 40$				; oui =>	LOAD.B	D4,#FINIMA	COMP.B	D3,#DEBIMA	JUMP',EQ 30$	LOAD.B	D4,#FINREG	COMP.B	D3,#DEBREG	JUMP',NE 40$30$:	INC.W	D2	COMP.B	D4,(A2+)	; cherche le caractre de fin	JUMP,NE	30$40$:	LOAD.L	A4,(A6)+ORECPA	LOAD.W	D4,(A6)+ORECNA	JUMP',EQ 90$	SUB.W	A2,D2		; A2 <-- ^dbut	LOAD.W	D3,(A5)+OCCOM+OCOMNOG	COMP.W	D3,(A6)+ORECGA	; mme gencar/mode ?	JUMP',EQ 60$		; oui => 60$	LOAD.W	(A6)+ORECGA,D3	; non =>	SUB.W	D4,#3	JUMP',LE 90$	LOAD.B	(A4+),#COMMAND	; <command>	LOAD.B	(A4+),D3	; <mode>	RR.W	D3,#8	LOAD.B	(A4+),D3	; <gencar>60$:	LOAD.B	(A4+),(A2+)	DEC.W	D4	JUMP',EQ 90$	DEC.W	D2	JUMP,NE 60$	LOAD.L	(A6)+ORECPA,A4	LOAD.W	(A6)+ORECNA,D490$:	POPM.L	D2..D4,A2,A4	RET;--------\\; KILLAR  >;========/; Mmorise un caractre dtruit en arrire en vue d'une; ventuelle rcupration avec (UNDO).; Doit tre appel juste avant DRECULE !; in	-; out	-; mod	-KILLAR:	PUSHM.L	D1..D4,A2,A4	LOAD.L	A2,(A5)+OPDT	COMP.L	A2,(A5)+OPDB	; est-on tout au dbut ?	JUMP,EQ 90$		; oui => 90$	LOAD.B	D3,(-A2)	; D3 <-- premier byte qui sera dtruit	COMP.B	D3,#SAJEXM	JUMP,EQ 90$	COMP.B	D3,#SAJEXT	JUMP,EQ 90$	COMP.B	D3,#SAJEXS	JUMP,EQ 90$	COMP.B	D3,#TIRET	JUMP,EQ 90$	COMP.B	D3,#PEOL	JUMP,EQ 90$	COMP.B	D3,#PEOP	JUMP,EQ 90$	COMP.B	D3,#FINCOM	JUMP,EQ 90$	LOAD.W	D2,#1	TEST.L	D3:#BSPEC	; caractre spcial ?	JUMP',BC 40$		; non => 40$				; oui =>	LOAD.B	D4,#DEBIMA	COMP.B	D3,#FINIMA	JUMP',EQ 30$	LOAD.B	D4,#DEBREG	COMP.B	D3,#FINREG	JUMP',NE 40$30$:	INC.W	D2	COMP.B	D4,(-A2)	; cherche le caractre de dbut	JUMP,NE	30$40$:	LOAD.L	A4,(A6)+ORECPR	LOAD.W	D4,(A6)+ORECNR	JUMP',EQ 90$	ADD.W	A2,D2		; A2 <-- ^fin; Met une commande au dbut de la zone dtruite en arrire.; Ici, les commandes sont toujours mises avec un retard pour; tre au dbut des caractres concerns, et pas  la fin !	LOAD.W	D3,(A5)+OCCOM+OCOMNOG	LOAD.W	D1,(A6)+ORECGR	COMP.W	D3,D1		; mme gencar/mode ?	JUMP',EQ 60$		; oui => 60$	LOAD.W	(A6)+ORECGR,D3	; non =>	COMP.W	D1,#-1	JUMP',EQ 60$	SUB.W	D4,#3	JUMP',LE 90$	RR.W	D1,#8	LOAD.B	(-A4),D1	; <gencar>	RR.W	D1,#8	LOAD.B	(-A4),D1	; <mode>	LOAD.B	(-A4),#COMMAND	; <command>60$:	LOAD.B	(-A4),(-A2)	DEC.W	D4	JUMP',EQ 90$	DEC.W	D2	JUMP,NE 60$	LOAD.L	(A6)+ORECPR,A4	LOAD.W	(A6)+ORECNR,D490$:	POPM.L	D1..D4,A2,A4	RET; Routines gnrales de "dplacement"; -----------------------------------;-------\; BORNAV >;=======/; Cherche en avant dans un buffer un caractre selon la classe.; Traite les cas :;	(CURSOR)		dplacement;	(CURSOR-KILL)		dplacement avec destruction;	(COPY)			copie;	(COPY-KILL)		copie avec destruction; in	D4.B	classe; out	-; mod	-BORNAV:	PUSHM.L	D1,D2,D3,D4,A2,A3,A4	CALL	INITCLASS	; A2/D2 <-- dlimiteurs	LOAD.W	D1,#1		; D1 <-- amplitude d'un	TEST.B	D4		; dplacement d'un caractre ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^dans texte	CLR.W	D1		; D1 <-- amplitude	COMP.B	(A2),#PEOL	; classe 2 (ligne) ?	JUMP',EQ 15$		; oui => 15$10$:	CALL	_NVISU		; saute n sparateurs	JUMP',NE 30$	CALL	IFCPSEUDO	JUMP,EQ	10$	INC.W	D1		; D1 <-- augmente amplitude	CALL	TSTCLASS	; dlimiteur ?	JUMP,EQ 10$		; oui => 10$	JUMP'	20$15$:	CALL	_NVISU	JUMP',NE 30$	CALL	IFCPSEUDO	JUMP,EQ	15$	INC.W	D1		; D1 <-- augmente amplitude20$:	CALL	_NVISU		; avance sur le 1er sp.	JUMP',NE 30$	CALL	IFCPSEUDO	JUMP,EQ	20$	INC.W	D1		; D1 <-- augmente amplitude	CALL	TSTCLASS	; dlimiteur ?	JUMP,NE 20$		; non => 20$	DEC.W	D130$:	COMP.B	(A5)+OACTION,#2^BACURS	JUMP',EQ 40$	COMP.B	(A5)+OACTION,#2^BAKILL	JUMP',EQ 50$	COMP.B	(A5)+OACTION,#2^BACOPY	JUMP,EQ 60$	COMP.B	(A5)+OACTION,#2^BACOPK	JUMP,EQ 70$	JUMP	90$40$:				; <--- (CURSOR)	TEST.W	D1	JUMP,EQ 85$	CALL	_AVANCE		; avance D1 fois	JUMP,NE 85$	CALL	IFCPSEUDO	JUMP,EQ	40$	DEC.W	D1	JUMP	40$50$:				; <--- (CURSUR-KILL)	TEST.W	D1	JUMP,EQ 85$	CALL	KILLAV		; mmorise pour v. rcupration	CALL	_DAVANCE	; dtruit D1 caractres	JUMP,NE 85$	CALL	IFCPSEUDO	JUMP,EQ	50$	DEC.W	D1	JUMP	50$60$:				; <--- (COPY)	PUSH.L	A5	LOAD.L	A5,#(A6)+OBUFS	; A5 <-- ^description buffer secondaire	LOAD.B	D3,#MARQUED	CALL	_INSERT		; marque le dbut de la zone	POP.L	A562$:	TEST.W	D1	JUMP',EQ 80$	CALL	COPYONE		; copie un caractre	JUMP',NE 80$	CALL	_AVANCE	JUMP',NE 80$	CALL	IFCPSEUDO	JUMP,EQ	62$	DEC.W	D1	JUMP	62$70$:				; <--- (COPY-KILL)	PUSH.L	A5	LOAD.L	A5,#(A6)+OBUFS	; A5 <-- ^description buffer secondaire	LOAD.B	D3,#MARQUED	CALL	_INSERT		; marque le dbut de la zone	POP.L	A572$:	TEST.W	D1	JUMP',EQ 80$	CALL	COPYONE		; copie un caractre	JUMP',NE 80$	CALL	_DAVANCE	JUMP',NE 80$	CALL	IFCPSEUDO	JUMP,EQ	72$	DEC.W	D1	JUMP	72$80$:	PUSH.L	A5	LOAD.L	A5,#(A6)+OBUFS	; A5 <-- ^description buffer secondaire	LOAD.B	D3,#MARQUEF	CALL	_INSERT		; marque la fin de la zone	CALL	_ZJUSTIF	; justifie la zone	CALL	_ZFJUSTIF	; enlve les marques et va  la fin	POP.L	A585$:	CALL	PSEUDOAV	; avance encore si pseudo-caractres90$:	POPM.L	D1,D2,D3,D4,A2,A3,A4	RET;-------\; BORNAR >;=======/; Cherche en arrire dans un buffer un caractre selon la classe.; Traite les cas :;	(CURSOR)		dplacement;	(CURSOR-KILL)		dplacement avec destruction; in	D4.B	classe; out	-; mod	-BORNAR:	PUSHM.L	D1,D2,D3,D4,A2,A3,A4	CALL	INITCLASS	; A2/D2 <-- dlimiteurs	LOAD.W	D1,#1		; D1 <-- amplitude d'un	TEST.B	D4		; dplacement d'un caractre ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,(A5)+OPDT	; A2 <-- ^dans texte	CLR.W	D1		; D1 <-- amplitude	COMP.B	(A2),#PEOL	; classe 2 (ligne) ?	JUMP',EQ 15$		; oui => 15$10$:	CALL	_PVISU		; recule n sparateurs	JUMP',NE 30$	CALL	IFCPSEUDO	JUMP,EQ	10$	INC.W	D1		; D1 <-- augmente amplitude	CALL	TSTCLASS	; dlimiteur ?	JUMP,EQ 10$		; oui => 10$	JUMP'	20$15$:	CALL	_PVISU	JUMP',NE 30$	CALL	IFCPSEUDO	JUMP,EQ	15$	INC.W	D1		; D1 <-- augmente amplitude20$:	CALL	_PVISU		; recule au dernier non dlim.	JUMP',NE 30$	CALL	IFCPSEUDO	JUMP,EQ	20$	INC.W	D1		; D1 <-- augmente amplitude	CALL	TSTCLASS	; dlimiteur ?	JUMP,NE 20$		; non => 20$	DEC.W	D130$:	COMP.B	(A5)+OACTION,#2^BACURS	JUMP',EQ 40$	COMP.B	(A5)+OACTION,#2^BAKILL	JUMP',EQ 50$	JUMP'	90$40$:				; <-- (CURSOR)	TEST.W	D1	JUMP',EQ 85$	CALL	_RECULE		; recule D1 fois	JUMP',NE 85$	CALL	IFCPSEUDO	JUMP,EQ	40$	DEC.W	D1	JUMP	40$50$:				; <--- (CURSOR-KILL)	TEST.W	D1	JUMP',EQ 85$	CALL	KILLAR		; mmorise pour v. rcupration	CALL	_DRECULE	; dtruit D1 caractres	JUMP',NE 85$	CALL	IFCPSEUDO	JUMP,EQ	50$	DEC.W	D1	JUMP	50$85$:	CALL	PSEUDOAV	; avance encore si pseudo-caractres90$:	POPM.L	D1,D2,D3,D4,A2,A3,A4	RET;---------\\; PSEUDOAV >;---------/; Saute un ou plusieurs pseudo-caractres en avant.; Si on rencontre une commande, met le curseur avant ou aprs; selon les numros des gencars prev et next comme suit :;	         p n              p n	(p=prev et n=next);	   <com: 0/1>       <com: 1/0>;	000          1111111          000;	             |     |;	           aprs avant; in	A5.L	^description d'un buffer; out	-; mod	D7.WPSEUDOAV:	PUSHM.L	D3,A410$:	CALL	_AVANCE		; avance un caractre	JUMP',NE 90$	CALL	IFPSEUDO	; pseudo-caractre ?	JUMP,EQ	10$		; oui => 10$	COMP.B	D3,#COMMAND	JUMP',NE 50$	LOAD.L	A4,(A5)+OPDT	LOAD.B	D3,(A4)-(1+LGCOM*2)+OCOMNOG	COMP.B	D3,(A4)-(1+LGCOM*1)+OCOMNOG	JUMP,LO 10$50$:	CALL	_RECULE		; recule caractre avanc en trop60$:	CALL	_RECULE		; recule un caractre	JUMP',NE 90$	COMP.B	D3,#COMMAND	JUMP',NE 70$	LOAD.L	A4,(A5)+OPFT	LOAD.B	D3,(A4)+(1+LGCOM*0)+OCOMNOG	COMP.B	D3,(A4)+(1+LGCOM*1)+OCOMNOG	JUMP,HI 60$70$:	CALL	_AVANCE		; avance caractre recul en trop90$:	POPM.L	D3,A4	RET; Test des dlimiteurs; --------------------;----------\; INITCLASS >;==========/; Initialise le pointeur aux caractres terminateurs d'une; classe ainsi le nombre de ces caractres.; classe 1 :	mots; classe 2 :	lignes; classe 3 :	alinas; classe 4 :	pages; classe 5 :	buffer; in	D4.B	classe; out	A2.L	^aux caractres terminateurs;	D2.W	nombre de caractres terminateurs;	D4.B	diff de zro => dplacement d'un seul caractre; mod	D4.B, D2.W, A2.LINITCLASS:	LOAD.L	A2,#R16"CLASS1	; A2 <-- ^fin de mots	LOAD.W	D2,#ECLASS-CLASS1	DEC.B	D4	JUMP',EQ 90$ 		; si classe 1 => 90$	LOAD.L	A2,#R16"CLASS2	; A2 <-- ^fin de lignes	LOAD.W	D2,#ECLASS-CLASS2	DEC.B	D4	JUMP',EQ 90$ 		; si classe 2 => 90$	LOAD.L	A2,#R16"CLASS3	; A2 <-- ^fin d'alinas	LOAD.W	D2,#ECLASS-CLASS3	DEC.B	D4	JUMP',EQ 90$		; si classe 3 => 90$	LOAD.L	A2,#R16"CLASS4	; A2 <-- ^fin de pages	LOAD.W	D2,#ECLASS-CLASS4	DEC.B	D4	JUMP',EQ 90$		; si classe 4 => 90$	LOAD.L	A2,#R16"CLASS5	; A2 <-- ^rien du tout	LOAD.W	D2,#ECLASS-CLASS5	DEC.B	D490$:	RET;---------\; TSTCLASS >;=========/; Test si un caractre fait partie de la classe initialise.; in	D3.B	caractre;	A2.L	^aux caractres de la classe;	D2.W	nombre de caractres de la classe; out	D7.W	zro =>	le caractre est un dlimiteur; mod	D7.WTSTCLASS:	PUSHM.L	D2,A2	TEST.W	D2		; classe 4 ?	JUMP',EQ 80$		; oui => 80$	CLR.W	D7		; D7 <-- trouv	DEC.W	D2		;  cause du "DECJ.W,NMO"10$:	COMP.B	D3,(A2+)	; dlimiteur ?	JUMP',EQ 90$		; oui => 90$	DECJ.W,NMO D2,10$80$:	LOAD.W	D7,#ERTNOT	; D7 <-- erreur (pas trouv)90$:	POPM.L	D2,A2	RET;  ATTENTION:	La table pour la classe 1 doit commencer par;  ---------	SPACE et celle pour la classe 2 doit commencer;		par PEOL !CLASS1:	.B	SPACE TAB SAJEXM SAJEXT SAJEXS CADRATIN	.B	', '. '; ': '! '?	.B	'+ '- '* '/CLASS2:	.B	PEOLCLASS3:	.B	TEOL IMAGE REGLECLASS4:	.B	TEOP PEOPCLASS5:ECLASS:	.B	0	.EVEN	.END