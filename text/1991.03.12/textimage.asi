	.SBTTL	TEXTIMAGE; touche (PROGRA); ---------------OPROGRA:	CALL	EXKEY	.WW	'I	DBOXIMAGE	.WW	'R	INSREGLE	.WW	'G	DBOXGENCAR	.WW	'J	AJUSTIF	.WW	'C	PJUSTIF	.WW	'P	PJUSTIF	.WW	'[	INSSPEC1	.WW	']	INSSPEC2	.WW	UNDO	FRAPENV	.WW	'0	FRAPGC0	.WW	'1	FRAPGC1	.WW	'2	FRAPGC2	.WW	'3	FRAPGC3	.WW	'4	FRAPGC4	.WW	'5	FRAPGC5	.WW	'6	FRAPGC6	.WW	'7	FRAPGC7	.WW	'8	FRAPGC8	.WW	'9	FRAPGC9	.WW	SPACE	FRAPNORM	.WW	'-	FRAPSOUL	.WW	'_	FRAPSOUL	.WW	',	FRAPEXP	.WW	';	FRAPEXP	.WW	'<	FRAPEXP	.WW	'.	FRAPIND	.WW	':	FRAPIND	.WW	'>	FRAPIND	.WW	'@	50$	.WW	0	NMAIN50$:	CALL	ALLSCREEN	; signal tout l'cran  repeindre	LIB	?GETDIM	LOAD.L	D3,D4	CLR.L	D4	LOAD.W	D2,#SETDOT	LOAD.L	D0,#-1	LOAD.L	D1,D0	CALL	DISTRAME	JUMP	MAININSSPEC1:	LOAD.B	D3,#SPEC1	JUMP	IMAIN		; insre un <<INSSPEC2:	LOAD.B	D3,#SPEC2	JUMP	IMAIN		; insre un >>FRAPENV:	CLR.L	(A6)+OFAFR	RETFRAPGC0:	LOAD.W	D4,#2^(6+0)	JUMP'	FRAPGCFRAPGC1:	LOAD.W	D4,#2^(6+1)	JUMP'	FRAPGCFRAPGC2:	LOAD.W	D4,#2^(6+2)	JUMP'	FRAPGCFRAPGC3:	LOAD.W	D4,#2^(6+3)	JUMP'	FRAPGCFRAPGC4:	LOAD.W	D4,#2^(6+4)	JUMP'	FRAPGCFRAPGC5:	LOAD.W	D4,#2^(6+5)	JUMP'	FRAPGCFRAPGC6:	LOAD.W	D4,#2^(6+6)	JUMP'	FRAPGCFRAPGC7:	LOAD.W	D4,#2^(6+7)	JUMP'	FRAPGCFRAPGC8:	LOAD.W	D4,#2^(6+8)	JUMP'	FRAPGCFRAPGC9:	LOAD.W	D4,#2^(6+9);	JUMP'	FRAPGCFRAPGC:	CALL	DBFRGPT		; A4 <-- ^dans OBUGC	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP,BC NMAIN		; non => NMAIN	LOAD.L	D3,(A6)+OFAFR	AND.W	D3,#B'0000000000111100 ; D3 <-- conserve juste le mode	OR.W	D3,D4		; D3 <-- ajoute le gencar	LOAD.L	(A6)+OFAFR,D3	RETFRAPNORM:	CLR.W	D4	JUMP'	FRAPMDFRAPSOUL:	LOAD.W	D4,#2^(2+1)	JUMP'	FRAPMDFRAPEXP:	LOAD.W	D4,#2^(2+2)	JUMP'	FRAPMDFRAPIND:	LOAD.W	D4,#2^(2+3);	JUMP'	FRAPMDFRAPMD:	LOAD.L	D3,(A6)+OFAFR	AND.W	D3,#B'1111111111000000 ; D3 <-- conserve juste le gencar	JUMP',NE 20$	LOAD.W	D3,#B'0000000001000000 ; D3 <-- met "Fond" par dfaut20$:	OR.W	D3,D4		; D3 <-- ajoute le mode	LOAD.L	(A6)+OFAFR,D3	RETDOIMACLOSE:	CALL	SWMO		; souris: met le sablier	CALL	IMACLALL	; ferme toutes les images	LOAD.L	A3,#(A6)+OGCLIST	COMP.B	(A3),#-2	; nom de l'imprimante existe ?	JUMP',NE 30$		; non => 30$20$:				; oui =>	TEST.B	(A3+)		; A3 <-- saute le nom de l'imprimante	JUMP,NE 20$30$:	LOAD.B	(A3),#-1	; module DGENC refait la liste des gencars	CALL	CWMO		; souris: plus de sablier	CALL	ALLSCREEN	; signal tout l'cran  repeindre	JUMP	MAIN;----------\\; DBOXIMAGE >;==========/; Demande un nom d'image, et insre dans le texte.; in	-; out	-; mod	D7.WDBOXIMAGE:	PUSHM.L	D2,D3,D4,A0,A2,A3,A4	LOAD.L	A2,#R16"TDBOX_IMAGE	CLR.L	D4	LOAD.L	A3,#(A6)+OBUTEMP	CLR.B	(A3)10$:	LOAD.L	A4,#R16"TXIMAGE	; A4 <-- ^extension .image	CLR.W	D2		; D2 <-- mode	CALL	DBOXEDITIM	; attend le nom de l'image ...	JUMP,NE	90$	COMP.W	D3,#END	JUMP,EQ	90$	LOAD.L	A4,A320$:	LOAD.B	D3,(A4+)	JUMP',EQ 30$	COMP.B	D3,#CR	JUMP',EQ 30$	COMP.B	D3,#':		; y a-t-il un ":" dans le nom ?	JUMP,NE 20$		; non => 20$				; oui =>	LOAD.W	D7,#ERTIMA	CALL	IOERROR		; affiche erreur ...	JUMP	10$30$:	CALL	IMAOPEN		; A0 <-- ^dans OTAIM	JUMP,NE	80$	LOAD.W	D4,#LGNAME+10	CALL	_PLACE?		; place pour une image ?	JUMP,NE 80$		; non => 80$	CALL	GOBOP		; revient au dbut du paragraphe	LOAD.B	D3,#DEBIMA	; <debima>	CALL	_CINSERT	LOAD.L	A3,#(A0)+OIMNAM50$:	LOAD.B	D3,(A3+)	; nom<0>	CALL	_CINSERT	TEST.B	D3	JUMP,NE	50$	CLR.B	D3	CALL	_CINSERT	CALL	_CINSERT	; <dyy>	CALL	_CINSERT	CALL	_CINSERT	; <dxx>	CALL	_CINSERT	CALL	_CINSERT	; <ixx>	LOAD.B	D3,#FINIMA	; <finima>	CALL	_CINSERT	LOAD.W	D4,#MODALL	CALL	MODIF	CALL	_RECULE		; recule sur l'image	CALL	_QJUSTIF	; justifie l'image (centrage)	CALL	_AVANCE		; avance aprs l'image80$:	CALL	IOERROR		; affiche si ereur90$:	POPM.L	D2,D3,D4,A0,A2,A3,A4	RET;--------\\; GOBOP   >;========/; Revient au dbut d'un paragraphe si on y est pas dj.; in	A5.L	^description d'un buffer; out	-; mod	D7.WGOBOP:	PUSH.W	D310$:	CALL	_RECULE	JUMP',NE 90$	COMP.B	D3,#PEOL	JUMP',EQ 10$	CALL	IFIEOL	JUMP,NE	10$	CALL	_AVANCE90$:;	LOAD.L	A4,(A5)+OPDT;	CALL	PVISU		; D3 <-- caractre juste avant;	JUMP',NE 45$;	COMP.B	D3,#TEOL	; dj une fin de ligne ?;	JUMP',EQ 45$		; oui => 45$;	COMP.B	D3,#IMAGE	; une image juste avant ?;	JUMP',EQ 45$		; oui => 45$;	COMP.B	D3,#REGLE	; une rglette juste avant ?;	JUMP',EQ 45$		; oui => 45$;				; non =>;	LOAD.B	D3,#TEOL;	CALL	INSERT		; <eol>;45$:	POP.W	D3	RET;---------\\; AFFIMAGE >;=========/; Affiche une image, ou une partie d'image.; in	A5.L	^description du buffer;	A4.L	^dans le buffer (ligne avec image);	D3.W	position Y dbut image;	D4.W	hauteur de l'image;	D5.W	hauteur en trop (contre en bas);	D6.W	hauteur en trop (contre en haut); out	A4.L	^dans le buffer (ligne suivante); mod	D7.W, A4.LAFFIMAGE:	PUSHM.L	D0..D5,A0,A3	LOAD.L	A3,A4	PUSHM.L	D3,D4	CALL	IMAPARAM	; A4 <-- ^dbut image	LOAD.W	D0,D3		; D0 <-- indentation <ixx>	LOAD.L	D1,D4		; D1 <-- dimensions (dy;dx)	POPM.L	D3,D4	TEST.W	D7	JUMP,NE 80$	COMP.W	(A5)+OMODIF,#MODALL	JUMP',NE 10$	CALL	AFFVIDE		; efface zone o ira l'image10$:	COMP.L	A3,(A5)+OPDT	JUMP',EQ 15$	COMP.L	A3,(A5)+OPFT	JUMP',EQ 15$	COMP.L	A4,(A5)+OPFT	; curseur au dbut de l'image ?	JUMP',NE 20$		; non => 20$15$:				; oui =>	PUSH.L	D4	LOAD.W	D4,(A6)+OCY	SR.W	D4,#1	ADD.W	D4,D3	SWAP.W	D4	LOAD.W	D4,(A6)+OCX	ADD.W	D4,(A5)+OVREG+OREGRENF ; D4 <-- tient compte renfoncement	ADD.W	D4,D0		; D4 <-- tient compte de l'indentation <ixx>	LOAD.L	(A5)+OCURS,D4	; mm position du curseur	POP.L	D4	LOAD.L	(A5)+OPDL,A4	; mm ^dbut de la ligne	LOAD.W	(A5)+OPOSYL,D3	; mm position Y dbut ligne	LOAD.W	(A5)+OHTL,D4	; mm hauteur de la ligne	PUSH.L	A4	LOAD.L	A4,#(A5)+OVREG	LOAD.L	A3,#(A5)+OLREG	CALL	COPREGLE	; OLREG <-- OVREG	LOAD.L	A4,#(A5)+OVCOM	LOAD.L	A3,#(A5)+OLCOM	CALL	COPCOMMAND	; OLCOM <-- OVCOM	POP.L	A420$:	TEST.W	(A5)+OMODIF	; image dj dessine ?	JUMP',EQ 80$		; oui => 80$	LOAD.L	A3,#(A4)+1	; A3 <-- ^nom de l'image	CALL	IMAOPEN		; A0 <-- ^dans OTAIM	JUMP',NE 80$	LOAD.W	D2,D3		; D2 <-- position Y dans fentre	SWAP.W	D2	LOAD.W	D2,(A5)+OVREG+OREGRENF	ADD.W	D2,D0		; D2 <-- dbut X de l'image	CLR.W	D5		; D5 <-- pas de partie cache  gauche	SUB.W	D2,(A6)+OSCROLH+OSCPOSV ; partie cache  gauche ?	JUMP',HS 60$		; non => 60$	NEG.W	D2		; oui =>	LOAD.W	D5,D2		; D5 <-- lg partie cache  gauche	CLR.W	D2		; D2 <-- dbut X de l'image60$:	ADD.W	D2,(A6)+OCX	; D2 <-- position X dans fentre	LOAD.W	D3,D6		; D3 <-- origine Y dans l'image	SWAP.W	D4		; D4 <-- hauteur Y de l'image	LOAD.W	D4,D1		; D4 <-- largeur X de l'image	LOAD.W	D1,(A5)+OVREG+OREGMGD	SUB.W	D1,(A5)+OVREG+OREGRENF	SUB.W	D1,D0	COMP.W	D4,D1		; image dborde  droite ?	JUMP',LS 70$		; non => 70$	LOAD.W	D4,D1		; oui => tronque une partie !70$:	SUB.W	D4,D5		; D4 <-- largeur sans partie cache	JUMP',HS 75$		; reste qq chose => 75$	CLR.W	D4		; reste rien => zro75$:	CALL	IMAVISU		; affiche (partie de) l'image80$:	CALL	SRCDOWN		; A4 <-- ^dbut ligne suivante	POPM.L	D0..D5,A0,A3	RET;---------\\; IMAPARAM >;=========/; Donne les paramtres d'une image.; in	A4.L	^ligne o est l'image; out	A4.L	^commande image (DEBIMA);	D3.W	indentation en x;	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.LIMAPARAM:	PUSHM.L	D0,D1,A0,A1,A310$:	CALL	TNVISU		; D3 <-- caractre suivant	JUMP,NE 90$	CALL	IFIEOL		; fin de ligne/image ?	JUMP,NE	10$		; non => 10$	CALL	PVISU		; oui => recule dessus	LOAD.W	D7,#ERTNOT	COMP.B	D3,#IMAGE	; image ?	JUMP',NE 90$		; non => 90$	LOAD.L	A1,A4		; A1 <-- ^dbut image	CLR.W	D7		; D7 <-- ok	LOAD.L	A3,#(A4)+1	; A3 <-- ^nom de l'image20$:	TEST.B	(A4+)		; A4 <-- saute le nom	JUMP,NE	20$	LOAD.B	D1,(A4)+4	LOAD.B	D0,(A4)+5	CALL	NUMBR	LOAD.W	D3,D4		; D3 <-- <ixx>	LOAD.B	D1,(A4)+0	LOAD.B	D0,(A4)+1	CALL	NUMBR		; D4 <-- <dyy>	SWAP.W	D4	LOAD.B	D1,(A4)+2	LOAD.B	D0,(A4)+3	CALL	NUMBR		; D4 <-- <dxx>	TEST.L	D4	JUMP',NE 80$	CALL	IMAOPEN		; A0 <-- ^dans OTAIM	JUMP',NE 80$	LOAD.L	D4,(A0)+OIMDY	; D4 <-- dimensions (dy;dx)	CALL	NUMRB	LOAD.B	(A4)+2,D1	LOAD.B	(A4)+3,D0	; buffer <-- <dyy>	SWAP.W	D4	CALL	NUMRB	LOAD.B	(A4)+0,D1	LOAD.B	(A4)+1,D0	; buffer <-- <dxx>	SWAP.W	D480$:	LOAD.L	A4,A1		; A4 <-- ^dbut image90$:	POPM.L	D0,D1,A0,A1,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; IMAOPEN >;========/; Ouvre une image.; in	A5.L	^description du buffer;	A3.L	^nom de l'image; out	A0.L	^lment dans OTAIM;	D7.W	erreur; mod	D7.W, A0.LIMAOPEN:	PUSHM.L	D2,D3,D4,A4; Cherche si cette image est dj ouverte.	LOAD.L	A0,#(A6)+OTAIM	LOAD.W	D4,#MAXIM-110$:	LOAD.L	A4,#(A0)+OIMNAM	; A4 <-- ^nom dans la table	CALL	COMPFILE	; image dj ouverte ?	JUMP',EQ 80$		; oui => 80$				; non =>	LOAD.L	A0,#(A0)+LGIM	DECJ.W,NMO D4,10$; Cherche un lment libre dans la table des images ouvertes.	LOAD.L	A0,#(A6)+OTAIM	LOAD.W	D4,#MAXIM-120$:	TEST.B	(A0)+OIMNAM	; lment libre ?	JUMP',EQ 60$		; oui => 60$				; non =>	LOAD.L	A0,#(A0)+LGIM	DECJ.W,NMO D4,20$; Prend la place de l'lment inutilis depuis le plus longtemps.30$:	LOAD.L	A0,#(A6)+OTAIM	LOAD.W	D4,#MAXIM-1	LOAD.W	D3,#-1		; D3 <-- "date" la plus rcente	CLR.L	D2		; D2 <-- pas encore trouv32$:	TEST.B	(A0)+OIMNAM	; lment libre ?	JUMP',EQ 35$		; oui => 35$	COMP.W	D3,(A0)+OIMCT	; lment plus vieux ?	JUMP',LO 35$		; non => 35$	LOAD.W	D3,(A0)+OIMCT	LOAD.L	D2,A0		; D2 <-- ^image  shooter35$:	LOAD.L	A0,#(A0)+LGIM	DECJ.W,NMO D4,32$	LOAD.W	D7,#ERNEMEM	; D7 <-- pas assez de mmoire	TEST.L	D2		; trouv une image  shooter ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A0,D2		; A0 <-- ^lment le plus vieux	CALL	IMACLOSE	; shoot la vieille image; Met l'image dans l'lment trouv.60$:	CALL	IMANEW		; ouvre une nouvelle image	JUMP',EQ 80$		; ok => 80$				; erreur =>	CLR.B	(A0)+OIMNAM	; libre l'lment	COMP.W	D7,#ERNEMEM	; pas assez de mmoire ?	JUMP,EQ 30$		; oui => essaye de shooter une image	JUMP'	90$80$:	INC.W	(A6)+OCTIM	; augmente la "date"	LOAD.W	(A0)+OIMCT,(A6)+OCTIM ; "date" l'image90$:	POPM.L	D2,D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IMARELEASE >;===========/; Libre une image.; in	A3.L	^nom de l'image; out	-; mod	D7.WIMARELEASE:	PUSHM.L	D4,A0,A4	LOAD.L	A0,#(A6)+OTAIM	LOAD.W	D4,#MAXIM-110$:	LOAD.L	A4,#(A0)+OIMNAM	; A4 <-- ^nom dans la table	CALL	COMPFILE	; image dj ouverte ?	JUMP',EQ 30$		; oui => 30$				; non =>	LOAD.L	A0,#(A0)+LGIM	DECJ.W,NMO D4,10$	JUMP'	90$30$:	CALL	IMACLOSE	; ferme l'image90$:	POPM.L	D4,A0,A4	RET;--------\\; IMANEW  >;--------/; Ouvre une nouvelle image sur la mme unit qu'o est; le texte.; in	A5.L	^description du buffer;	A3.L	^nom de l'image;	A0.L	^lment dans OTAIM; out	D7.W	erreur; mod	D7.WIMANEW:	PUSHM.L	D1,D3,D4,D6,A2..A4	LOAD.L	A4,#(A6)+OBUAFFF; Regarde si le nom de l'image contient dj un ":".	LOAD.L	A2,A310$:	LOAD.B	D3,(A2+)	CALL	IFTERMF	JUMP',EQ 12$	COMP.B	D3,#':		; ":" dans le nom de l'image ?	JUMP,NE 10$		; non => 10$	JUMP'	20$		; oui => n'ajoute rien devant !; Cherche si le nom du texte contenu dans cette zone est prcd d'un; ou de plusieurs noms de rpertoires.12$:	LOAD.L	A2,#(A5)+OBUMEMF ; A2 <-- ^nom du texte dans cette zone	CLR.L	D4		; D4 <-- pas encore trouv de ":"14$:	LOAD.B	D3,(A2+)	CALL	IFTERMF	JUMP',EQ 16$	COMP.B	D3,#':	JUMP,NE 14$	LOAD.L	D4,A2		; D4 <-- ^dernier ":" trouv	JUMP	14$16$:	TEST.L	D4		; un ou plusieurs ":" trouvs ?	JUMP',EQ 20$		; non => 20$; Construit le nom de l'image en connenant par les rpertoires; trouvs dans le nom du texte.	LOAD.L	A2,#(A5)+OBUMEMF ; A2 <-- ^nom du texte dans cette zone	SUB.L	D4,A2		; D4 <-- nb de caractres18$:	LOAD.B	(A4+),(A2+)	; OBUAFFF <-- nom(s) de rpertoire(s)	DEC.W	D4	JUMP,NE 18$; Ajoute ensuite le nom de l'image trouv dans la commande "boa"; puis force l'extension ".image".20$:	LOAD.L	A2,A4		; A2 <-- ^nom aprs les ventuels unit:rp:22$:	LOAD.B	D3,(A3+)	CALL	IFTERMF	JUMP',EQ 25$	LOAD.B	(A4+),D3	; OBUAFFF <-- nom du fichier	JUMP	22$25$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUAFFF	LOAD.L	A4,#R16"TXIMAGE	LOAD.W	D3,#1		; D3 <-- force si dj une autre	LIB	?ADDEXT		; ajoute ".image"; Ouvre l'image, et mmorise son nom.	LOAD.W	D3,#2^BOPRD	; D3 <-- mode "lecture"	FOS	?OPEN		; ouvre l'image	JUMP,NE	90$	LOAD.L	A4,#(A0)+OIMNAM30$:	LOAD.B	(A4+),(A2+)	; OIMNAM <-- nom sans les rp:	JUMP',EQ 32$	COMP.B	(A2)-1,#'.	JUMP,NE	30$	CLR.B	(A4)-1; Lit l'en-tte de l'image, et mmorise les paramtres importants.32$:	LOAD.L	A4,#(A6)+OBUIM	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit en-tte image/binaire	JUMP,NE 80$	COMP.B	(A4)+0,#H'82	; commence par en-tte binaire ?	JUMP',NE 40$		; non => 40$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute l'en-tte binaire	JUMP,NE 80$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte de l'image	JUMP,NE 80$40$:	LOAD.W	(A0)+OIMDX,(A4)+OIMDLX	LOAD.W	(A0)+OIMDY,(A4)+OIMDLY	TCLR.B	(A0)+OIMDY+1:#0	; si hauteur impaire => moins un !	LOAD.W	D4,(A4)+OIMDLX	ADD.W	D4,#8-1	SR.W	D4,#3		; D4 <-- largeur en bytes	LOAD.W	(A0)+OIMBX,D4	LOAD.W	(A0)+OIMNB,(A5)+ONOBUF; Rserve de la mmoire pour toute l'image.	LOAD.L	A2,A4		; A2 <-- ^en-tte de l'image	LOAD.W	D4,(A2)+OIMDLX	MUL.WU	D4,(A2)+OIMDLY	SR.L	D4,#3	ADD.L	D4,#IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande de la mmoire	JUMP',NE 80$	LOAD.L	A4,#(A4)+IMLBUF	LOAD.L	(A0)+OIMPT,A4; Lit toute l'image, et dcode les images codes.	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 50$		; oui => 50$				; non =>	LOAD.L	D4,(A2)+OIMNBB	FOS	?RDBYTE		; lit toute l'image dcode	JUMP',NE 80$	JUMP'	60$50$:	LOAD.L	A3,A4	LOAD.L	A4,#(A4)-IMLBUF	LOAD.L	D4,(A2)+OIMNBB	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 80$	GRA_	DECOIMA		; dcode l'image ...	JUMP',NE 80$60$:	FOS	?CLOSE		; ferme le fichier image	CALL	IMATEXT		; incruste le nom de l'image	CLR.W	D7		; D7 <-- ok	JUMP'	90$; En cas d'erreur, rend la mmoire de l'image et ferme le fichier image.80$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier image	CALL	IMACLOSE	; rend la mmoire de l'image	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; IMACLALL >;=========/; Ferme toutes les images.; in	-; out	-; mod	D7.WIMACLALL:	PUSHM.L	D4,A0	LOAD.L	A0,#(A6)+OTAIM	LOAD.W	D4,#MAXIM-120$:	TEST.B	(A0)+OIMNAM	; lment libre ?	JUMP',EQ 60$		; oui => 60$				; non =>	CALL	IMACLOSE	; ferme l'image60$:	LOAD.L	A0,#(A0)+LGIM	DECJ.W,NMO D4,20$	POPM.L	D4,A0	RET;---------\\; IMACLBUF >;=========/; Ferme toutes les images utilises dans un buffer.; in	A5.L	^description du buffer; out	-; mod	D7.WIMACLBUF:	PUSHM.L	D4,D5,A0	LOAD.W	D5,(A5)+ONOBUF	; D5 <-- numro du buffer	LOAD.L	A0,#(A6)+OTAIM	LOAD.W	D4,#MAXIM-120$:	TEST.B	(A0)+OIMNAM	; lment libre ?	JUMP',EQ 60$		; oui => 60$				; non =>	COMP.W	D5,(A0)+OIMNB	; image utilise dans ce buffer ?	JUMP',NE 60$		; non => 60$				; oui =>	CALL	IMACLOSE	; ferme l'image60$:	LOAD.L	A0,#(A0)+LGIM	DECJ.W,NMO D4,20$	POPM.L	D4,D5,A0	RET;---------\\; IMACLOSE >;=========/; Ferme une image.; in	A0.L	^lment dans OTAIM; out	-; mod	D7.WIMACLOSE:	PUSHM.L	D1,A4	TEST.L	(A0)+OIMPT	JUMP',EQ 85$	LOAD.L	A4,(A0)+OIMPT	LOAD.L	A4,#(A4)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	CLR.L	(A0)+OIMPT85$:	CLR.B	(A0)+OIMNAM	; libre l'lment	POPM.L	D1,A4	RET;--------\\; IMAVISU >;========/; Affiche une partie d'image.; in	A0.L	^dans OTAIM;	D2.L	position dans la fentre (y;x);	D3.W	origine dans l'image (y);	D4.L	dimensions de la partie d'image (dy;dx);	D5.W	partie cache  gauche dans l'image; out	D7.W	erreur; mod	D7.WIMAVISU:	PUSHM.L	D0..D6,A3,A4	TEST.B	(A6)+OFANION+3:#BFAIMA ; images visibles ?	JUMP',BC 70$		; non => 70$				; oui =>	SWAP.W	D3	LOAD.W	D3,D5		; D3 <-- yy/xx source	LOAD.L	A3,(A0)+OIMPT	; A3 <-- ^source (image)	LOAD.W	D5,(A0)+OIMBX	; D5 <-- ii source	EX.L	D4,D2		; D4 <-- yy/xx destination, D2 <-- dimensions	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	CLR.W	D6		; D6 <-- ii destination	LOAD.W	D1,#SETDOT	; D1 <-- mode	CALL	DISRASTEROP	; dessine une partie d'image	JUMP'	90$70$:				; image invisible =>	LOAD.L	D3,D4		; D3 <-- dimensions (dy;dx)	LOAD.L	D4,D2		; D4 <-- origine (y;x)	LOAD.W	D2,#SETDOT	; D2 <-- mode	LOAD.L	D0,#H'AAAAAAAA	; D0 <-- trame	LOAD.L	D1,D0		; D1 <-- trame	CALL	DISTRAME	; met une trame  la place90$:	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IMATEXT >;========/; Incruste le nom d'une image directement dans son bitmap.; in	A0.L	^dans OTAIM; out	-; mod	D7.WIMATEXT:	PUSHM.L	D2..D4,A3,A4	COMP.W	(A0)+OIMDY,#LIMGCY+2 ; image pas assez haute ?	JUMP,LO 90$		; oui => 90$; Efface la place o sera incrust le nom de l'image.	LOAD.L	A3,A0		; A3 <-- nom de l'image	LOAD.W	D3,#-110$:	INC.W	D3		; D3 <-- nb de caractres du nom	TEST.B	(A3+)	JUMP,NE 10$	MUL.WU	D3,#LIMGCX+1	; D3 <-- largeur ncessaire pour le nom	ADD.W	D3,#2	ADD.W	D3,#8-1	SR.W	D3,#3		; D3 <-- largeur en bytes	COMP.W	D3,(A0)+OIMBX	; trop large ?	JUMP',LS 20$		; non => 20$	LOAD.W	D3,(A0)+OIMBX	; oui => efface un maximum20$:	LOAD.L	A3,(A0)+OIMPT	; A3 <-- ^bitmap de l'image	LOAD.W	D2,#LIMGCY+2-1	; D2 <-- hauteur  effacer (-1  cause NMO)30$:	LOAD.L	A4,A3	LOAD.W	D4,D3	DEC.W	D435$:	LOAD.B	(A4+),#-1	; efface une ligne horizontale	DECJ.W,NMO D4,35$	ADD.W	A3,(A0)+OIMBX	; A3 <-- ^ligne en dessous	DECJ.W,NMO D2,30$; Incruste le nom de l'image, caractre par caractre.	LOAD.L	A3,A0		; A3 <-- nom de l'image	LOAD.L	D4,#H'10000*1+1	; D4 <-- coordonne initiale (y;x)	LOAD.W	D2,(A0)+OIMDX	SUB.W	D2,#LIMGCX+1	JUMP',LO 90$50$:	LOAD.B	D3,(A3+)	; D3 <-- caractre suivant	JUMP',EQ 90$	COMP.W	D4,D2		; dpasse  droite ?	JUMP',HI 90$		; oui => 90$	CALL	IMACAR		; "affiche" un caractre	ADD.W	D4,#LIMGCX+1	; D4 <-- position suivante en X	JUMP	50$90$:	POPM.L	D2..D4,A3,A4	RET;--------\\; IMACAR  >;--------/; Incruste un caractre dans l'image, avec le raster-op !; in	D3.B	caractre ASCII;	D4.L	coordonne sup/gauche (y;x);	A0.L	^dans OTAIM; out	-; mod	D7.WIMACAR:	PUSHM.L	D1..D6,A0,A2..A4	LOAD.L	A3,#R16"TAIMGC-LIMGCY	LIB	?MINMAJ		; D3 <-- lettre MAJUSCULE10$:	ADD.L	A3,#LIMGCY	TEST.B	(A3)	JUMP,EQ 90$	COMP.B	D3,(A3+)	; caractre trouv ?	JUMP,NE	10$		; non => 10$				; oui =>	CLR.L	D3		; D3 <-- x;y source	LOAD.W	D5,#1		; D5 <-- ii source	LOAD.L	A4,(A0)+OIMPT	; A4 <-- ^image destination	LOAD.W	D6,(A0)+OIMBX	; D6 <-- ii destination	LOAD.L	D2,#H'10000*LIMGCY+LIMGCX	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.W	D1,#CLRDOT	; D1 <-- mode	LOAD.L	A0,(A6)+OADRAST	CALL	(A0)		; appel de GRA_RASTER90$:	POPM.L	D1..D6,A0,A2..A4	RET;---------\\; COMPFILE >;=========/; Compare deux noms de fichiers.; in	A3.L	^nom;	A4.L	^nom; out	EQ	gaux;	NE	diffrents; mod	-COMPFILE:	PUSHM.L	D3,A3,A4	LOAD.W	D7,#1		; D7 <-- diffrents10$:	LOAD.B	D3,(A3+)	CALL	IFTERMF		; premier nom termin ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,(A4+)	JUMP,EQ	10$	JUMP'	90$50$:	LOAD.B	D3,(A4+)	CALL	IFTERMF		; deuxime nom termin ?	JUMP',NE 90$		; non => 90$				; oui =>	CLR.W	D7		; D7 <-- gaux90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFTERMF >;========/; Test si un caractre est un terminateur de nom de fichier.; in	D3.B	caractre; out	EQ	terminateur; mod	-IFTERMF:	TEST.B	D3	JUMP',EQ 90$	COMP.B	D3,#CR	JUMP',EQ 90$	COMP.B	D3,#SPACE	JUMP',EQ 90$	COMP.B	D3,#TAB	JUMP',EQ 90$	COMP.B	D3,#'.90$:	RET	.END