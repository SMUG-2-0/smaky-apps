	.SBTTL	TEXTPRINT;--------\\; DOPRINT >;========/; Imprime le texte dans la zone de travail.DOPRINT:	LOAD.W	D7,#ERTPRI	; D7 <-- imprimante pas installe	TEST.L	(A6)+OCAPRINT	; imprimante prsente ?	JUMP,EQ	92$		; non => 92$	LOAD.W	D7,#ERTFPR	; D7 <-- impression en cours	TSET.B	(A6)+OFLAGS:#BFPRINT	JUMP,BS 92$	CALL	DBOXPRINT	; demande comment imprimer ...	JUMP,NE	90$	COMP.W	D3,#F1		; imprime ?	JUMP,NE	90$		; non => MAIN	CALL	SWMO		; souris: met le sablier	CALL	_IMACLBUF	; ferme toutes les images	TEST.L	D4:#BFACOU	; courrier personnalis ?	JUMP,BS DOMAILING	CALL	STPRINT		; relit le status de l'imprimante	JUMP',EQ 10$	CALL	AJPRINT		; ajustement subtile !	CALL	CHKREGLES	; ajuste les rgles	CALL	AJUSTIF		; rejustifie tout ...	CALL	PJUSTIF		; coupe toutes les pages ...	JUMP'	12$10$:	TEST.B	(A5)+OSTATUS:#BEOPMOD	JUMP',BC 12$	CALL	PJUSTIF		; coupe toutes les pages ...12$:	PUSH.L	A5	LOAD.L	A2,(A6)+OCAPRINT	CLR.L	D3	LOAD.L	A3,#(A5)+OBUMEMF ; A3 <-- ^nom du fichier	LOAD.L	A4,#(A6)+OBUPRES ; A4 <-- ^nom de la prsentation	CLR.B	(A4)	CLR.L	D2		; D2 <-- lg du document	LOAD.L	A5,#R16"NAMTEXT	; A5 <-- ^nom du logiciel	PRINTA_	OPPRINT		; ouvre l'imprimante ...	PUSH.W	D7	CALL	_AFMENU		; remet soft-keys standards	POP.W	D7	POPM.L	A5	JUMP,NE 90$	LOAD.L	D5,D4	LOAD.B	D4,#2^BIOPRINT!2^BIOBOA ; D4 <-- le document entier	TEST.L	D3:#BPRINTERVAL	JUMP',BC 50$	TSET.L	D4:#BIODEA	; D4 <-- imprime de ..  ..	LOAD.W	(A6)+OPRLPA,D5	SWAP.W	D5	LOAD.W	(A6)+OPRFPA,D550$:	CALL	BOUTPUT		; imprime le texte ...	LOAD.W	D4,#MODALL	CALL	MODIF		; faut tout repeindre90$:	TCLR.B	(A6)+OFLAGS:#BFPRINT92$:	CALL	IOERROR		; affiche erreur si ncessaire95$:	RETDOMAILING:	CALL	OPMFICHE	; ouvre le module FICHE	JUMP,NE 90$	LOAD.L	A3,#(A6)+OPRNFI	; A3 <-- ^nom du fichier .FICHE	LOAD.W	D3,#2^BFIMODMEM!2^BFIMODLG	CLR.L	D4		; D4 <-- lg en plus	FICHE_	OUVRE		; D6 <-- canal du fichier	JUMP,NE 90$	CALL	MAILRDDEF	; OBUFIC <-- toutes les dfinitions	CALL	DBOXMAILING	; D4 <-- demande la clef d'accs ...	JUMP,NE	85$	COMP.W	D3,#F4		; vrifie ?	JUMP,EQ 50$		; oui => 50$	COMP.W	D3,#CR		; imprime ?	JUMP,NE	85$		; non => 85$	CALL	SWMO		; souris: met le sablier	LOAD.W	D5,(A6)+ONOWDT	LIB	?USEWDO	LIB	?AFTIM	.B	EOP,NOCURS	.B	CR,CR,CR,CR,CR,CR,CR,CR	.ASCII	"		Impression du courrier personnalis en cours,<CR>"	.ASCII	"		attendez un instant ...<CR>"	.ASCIZ	"		"	LIB	?GETCURS	; D3 <-- position du curseur	LIB	?AFTIM	.B	CR,CR	.ASCIZ	"		(CTRL-M3) stoppe l'impression avant la fin !"	.EVEN	LOAD.W	D1,(A5)+ONOBUF	; D1 <-- no du buffer secondaire	LOAD.W	D0,D1	ADD.W	D0,#NBBF/2	; D0 <-- no du buffer principal	CALL	INI2B		; initialise 2 buffers	LOAD.L	D2,D3		; D2 <-- position du curseur	LOAD.L	D3,D4		; D3 <-- premire clef d'accs	PUSH.L	D3	FICHE_	NBFICHE		; D3/D4 <-- nb de fiches total/selon clef	LOAD.L	D5,D4		; D5 <-- nb de fiches selon clef	POP.L	D330$:	PUSHM.L	D2,D3	LOAD.L	D3,D2		; D3 <-- position du curseur	LIB	?SETCURS	; positionne le curseur	LIB	?AFTIM	.ASCIZ	"(Il reste "	.EVEN	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LOAD.W	D3,#8		; D3 <-- nb max de digits	LOAD.L	D4,D5		; D4 <-- nombre  afficher	LIB	?AFDEC		; affiche le nombre de fiches restantes	LIB	?AFTIM	.ASCIZ	" fiches  insrer)<EFLI>"	.EVEN	POPM.L	D2,D3	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^buffer	LOAD.W	D4,#LBUDIS	; D4 <-- lg buffer	FICHE_	LIT		; lit une fiche ...	JUMP,NE 75$	LOAD.W	D0,(A5)+ONOBUF	; D0 <-- no du buffer principal	CALL	KILBUF		; vide le buffer principal	PUSH.L	D2	LOAD.W	D0,(A5)+ONOBUF	SUB.W	D0,#NBBF/2	; D0 <-- no du buffer secondaire (source)	CLR.W	D2		; D2 <-- COPY sans KILL	CALL	_COPYSP		; principal <-- secondaire	POP.L	D2	CALL	MAILINSERT	; principal <-- ajoute la fiche lue	PUSHM.L	D2..D6	PUSH.L	A5	LOAD.L	A2,(A6)+OCAPRINT	CLR.L	D3	TSET.L	D3:#BPRIMPRIME	; D3 <-- saute la DBOX d'impression	TSET.L	D3:#BPRSILENCE	; D3 <-- n'affiche pas boites commentaires	LOAD.L	A3,#(A5)+OBUMEMF ; A3 <-- ^nom du fichier	LOAD.L	A4,#(A6)+OBUPRES ; A4 <-- ^nom de la prsentation	CLR.B	(A4)	CLR.L	D2		; D2 <-- lg du document	LOAD.L	A5,#R16"NAMTEXT	; A5 <-- ^nom du logiciel	PRINTA_	OPPRINT		; ouvre l'imprimante ...	PUSH.W	D7	CALL	_AFMENU		; remet soft-keys standards	POP.W	D7	POPM.L	A5	JUMP',NE 45$	LOAD.B	D4,#2^BIOPRINT!2^BIOBOA ; D4 <-- le document entier	CALL	BOUTPUT		; imprime une lettre personnalise ...45$:	POPM.L	D2..D6	JUMP,NE 80$	INC.W	D3		; D3 <-- clef d'accs suivante	DEC.L	D5		; D5 <-- nb de fichiers restantes	JUMP	30$50$:				; vrifie =>	CALL	SWMO		; souris: met le sablier	LOAD.W	D1,(A5)+ONOBUF	; D1 <-- no du buffer secondaire	LOAD.W	D0,D1	ADD.W	D0,#NBBF/2	; D0 <-- no du buffer principal	CALL	INI2B		; initialise 2 buffers	LOAD.L	D3,D4		; D3 <-- premire clef d'accs	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^buffer	LOAD.W	D4,#LBUDIS	; D4 <-- lg buffer	FICHE_	LIT		; lit une fiche ...	JUMP,NE 75$	LOAD.W	D0,(A5)+ONOBUF	; D0 <-- no du buffer principal	CALL	KILBUF		; vide le buffer principal	PUSH.L	D2	LOAD.W	D0,(A5)+ONOBUF	SUB.W	D0,#NBBF/2	; D0 <-- no du buffer secondaire (source)	CLR.W	D2		; D2 <-- COPY sans KILL	CALL	_COPYSP		; principal <-- secondaire	POP.L	D2	CALL	MAILINSERT	; principal <-- ajoute la fiche lue	LOAD.W	D0,(A5)+ONOBUF	; D0 <-- no du buffer principal	CALL	INI1B		; remet un seul buffer	LOAD.W	D4,#MODALL	CALL	MODIF		; faut tout repeindre	CLR.W	D7		; D7 <-- ok	JUMP'	85$75$:	COMP.W	D7,#ERFFNF	; fiche pas trouve ?	JUMP',NE 80$		; non => 80$	CLR.W	D7		; oui => tout est ok80$:	PUSH.W	D7	LOAD.W	D0,(A5)+ONOBUF	; D0 <-- no du buffer principal	CALL	KILBUF		; vide le buffer principal;	LOAD.W	D0,(A5)+ONOBUF	; D0 <-- no du buffer principal	SUB.W	D0,#NBBF/2	CALL	INI1B		; remet un seul buffer	LOAD.W	D4,#MODALL	CALL	MODIF		; faut tout repeindre	POP.W	D785$:	PUSH.W	D7	FICHE_	FERME		; ferme le fichier	POP.W	D790$:	PUSH.W	D7	CALL	CLMFICHE	; ferme le module FICHE92$:	LIB	?IFCAR		; vide le fifo du clavier	JUMP,EQ 92$	POP.W	D7	TCLR.B	(A6)+OFLAGS:#BFPRINT	CALL	IOERROR		; affiche erreur si ncessaire	RET;-----------\\; MAILINSERT >;-----------/; Insre le contenu d'une fiche dans le buffer principal.; in	D6.W	canal .FICHE; out	-; mod	D7.WMAILINSERT:	PUSHM.L	D1..D4,A2..A4	CALL	VADEBUT		; revient au dbut10$:	CALL	AVANCE		; D3 <-- caractre suivant	JUMP,NE 80$	COMP.B	D3,#MAIL	; dbut d'une commande ?	JUMP,NE 10$		; non => 10$				; oui =>	CALL	DRECULE		; supprime le "#"	LOAD.L	A4,#(A6)+OBUBOA	; A4 <-- ^buffer pour commande	LOAD.W	D4,#LBUBOA-2	; D4 <-- lg max buffer	LOAD.L	D1,#-1		; D1 <-- commande20$:	CALL	DAVANCE		; D3 <-- supprime la commande	JUMP,NE 80$	COMP.B	D3,#SAJEXM	; espace variable ?	JUMP,EQ 20$	COMP.B	D3,#SAJEXT	; espace variable ?	JUMP,EQ 20$	COMP.B	D3,#SAJEXS	; espace variable ?	JUMP,EQ 20$	COMP.B	D3,#TIRET	; pseudo-tiret ?	JUMP,EQ 20$	COMP.B	D3,#PEOL	JUMP,EQ 20$	COMP.B	D3,#PEOP	JUMP,EQ 20$	COMP.B	D3,#COMMAND	; commande ?	JUMP',NE 22$		; non => 22$				; oui =>	COMP.L	D1,#-1	JUMP,NE 20$	CLR.L	D1	LOAD.B	D1,(A5)+OCCOM+OCOMMOD	RR.L	D1,#8	LOAD.B	D1,(A5)+OCCOM+OCOMNOG	RR.L	D1,#8		; D1 <-- gencar/mode/0/0	JUMP	20$22$:	COMP.B	D3,#';		; fin de la commande ?	JUMP',EQ 28$	COMP.B	D3,#TEOL	JUMP',EQ 28$	COMP.B	D3,#TEOP	JUMP',EQ 28$	LOAD.B	D2,#SPACE	COMP.B	D3,#CADRATIN	JUMP',EQ 25$	COMP.B	D3,#TAB	JUMP',EQ 25$	LOAD.B	D2,D325$:	LOAD.B	(A4+),D2	; OBUBOA <-- commande "mail"	DEC.W	D4	JUMP,NE 20$28$:	CLR.B	(A4)		; OBUBOA <-- terminateur	LOAD.L	A4,#(A6)+OBUBOA	; A4 <-- ^commande29$:	LOAD.L	A2,#R16"ER1$	; A2 <-- ^message d'erreur	CALL	MAILSEARCH	; D4 <-- no de la commande	JUMP,NE 70$		; pas trouv => 70$				; trouv =>	COMP.B	D4,#1		; commande "rubrique" ?	JUMP',EQ 30$	COMP.B	D4,#2		; commande "si" ?	JUMP,EQ 40$	COMP.B	D4,#3		; commande "texte" ?	JUMP,EQ 50$	JUMP	70$30$:				; RUBRIQUE =>	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^fiche lue	CALL	MAILRUB		; A3 <-- ^rubrique trouve	JUMP,NE 10$32$:	LOAD.B	D3,(A3+)	; D3 <-- contenu de la rubrique	JUMP,EQ 10$	COMP.B	D3,#CR	JUMP,EQ 10$	CALL	MAILINSCAR	; insre le contenu de la rubrique	JUMP	32$40$:				; SI =>	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^fiche lue	CALL	MAILRUB		; A3 <-- ^rubrique trouve	LOAD.L	A2,#R16"ER2$	; A2 <-- ^message d'erreur	LOAD.B	D3,(A4+)	COMP.B	D3,#'=	JUMP',EQ 42$	COMP.B	D3,#'<	JUMP,NE 70$	LOAD.B	D3,(A4+)	COMP.B	D3,#'>	JUMP,NE 70$42$:	LOAD.L	A2,#R16"ER3$	; A2 <-- ^message d'erreur	LOAD.B	D4,(A4+)	COMP.B	D4,#'"	JUMP,NE 70$43$:	LOAD.L	A2,#R16"TERM$	EX.L	A3,A4	LIB	?CPSTRING	EX.L	A4,A3	JUMP',NC 46$44$:	LOAD.B	D4,(A4)	JUMP',EQ 45$	COMP.B	D4,#'"	JUMP',EQ 45$	INC.L	A4	COMP.B	D4,#'|	JUMP,EQ 43$	JUMP	44$45$:				; faux =>	COMP.B	D3,#'=	JUMP,EQ 10$	JUMP'	47$46$:				; vrai =>	COMP.B	D3,#'=	JUMP,NE 10$47$:	TEST.B	(A4)	JUMP,EQ 10$	COMP.B	(A4+),#'"	JUMP,NE 47$48$:	COMP.B	(A4+),#SPACE	JUMP,EQ 48$	DEC.L	A4	JUMP	29$50$:				; TEXTE =>	LOAD.L	A2,#R16"ER3$	; A2 <-- ^message d'erreur	LOAD.B	D3,(A4+)	COMP.B	D3,#'"	JUMP,NE 70$52$:	LOAD.B	D3,(A4+)	JUMP,EQ 10$	COMP.B	D3,#'"	JUMP,EQ 10$	CALL	MAILINSCAR	JUMP	52$; En cas d'erreur, insre le message en (A2).70$:	LOAD.B	D3,(A2+)	JUMP,EQ 10$	COMP.B	D3,#SPACE	JUMP',NE 72$	LOAD.B	D3,#CADRATIN72$:	CALL	MAILINSCAR	JUMP	70$; Lorsque tout est fini, il faut rejustifier le texte.80$:	CALL	VADEBUT		; revient au dbut	CALL	AJUSTIF		; rejustifie tout ...	CALL	PJUSTIF		; coupe toutes les pages ...90$:	POPM.L	D1..D4,A2..A4	RETTERM$:	.B	0,CR,'",'|,-1ER1$:	.ASCIZ	/ ### COMMANDE INCONNUE ### /ER2$:	.ASCIZ	/ ### "=" OU "<'<><'>>" ATTENDU ### /ER3$:	.ASCIZ	/ ### "CHAINE" ATTENDUE ### /	.EVEN;-----------\\; MAILINSCAR >;-----------/; Insre un caractre avec le bon gencar/mode.; in	D3.B	caractre  insrer;	D1.L	gencar/mode/0/0; out	D7.W	erreur; mod	D7.WMAILINSCAR:	PUSH.L	D3	COMP.L	D1,#-1		; gencar/mode connu ?	JUMP',NE 50$		; oui => 50$				; non =>	CALL	INSERT		; insre normalement	JUMP'	90$50$:	AND.L	D3,#H'000000FF	OR.L	D3,D1		; D3 <-- /gencar/mode/0/car	CALL	GINSERT		; insre avec le bon gencar/mode90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MAILSEARCH >;-----------/; Cherche une commande "mail".; in	A4.L	^commande "mail"; out	D7.W	ok;	 D4.B	 numro de la commande;	 A4.L	 ^plus loin;	D7.W	erreur;	 D4.B	 zro;	 A4.L	 idem; mod	D4.L, D7.W, A4.LMAILSEARCH:	PUSHM.L	D3,A2,A3	LOAD.L	A3,#R16"00$10$:	LOAD.W	D7,#1		; D7 <-- pas trouv	LOAD.B	D4,(A3+)	; D4 <-- numro de la commande	JUMP,EQ 90$	LOAD.L	A2,A420$:	TEST.B	(A3)	JUMP',EQ 30$	LOAD.B	D3,(A2+)	CALL	MINMAJ	COMP.B	D3,(A3+)	JUMP,EQ 20$25$:	TEST.B	(A3+)		; A3 <-- ^commande suivante	JUMP,NE 25$	JUMP	10$30$:	LOAD.B	D3,(A2)	JUMP',EQ 40$	COMP.B	D3,#SPACE	JUMP,NE 25$40$:	COMP.B	(A2+),#SPACE	JUMP,EQ 40$	LOAD.L	A4,#(A2)-1	; A4 <-- ^plus loin	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,A2,A3	TEST.W	D7		; retour EQ/NE	RET00$:	.ASCIZ	"<1>RUBRIQUE"	.ASCIZ	"<1>RUBRI"	.ASCIZ	"<1>RUBR"	.ASCIZ	"<1>RUB"	.ASCIZ	"<1>FIELD"	.ASCIZ	"<2>SI"	.ASCIZ	"<2>IF"	.ASCIZ	"<3>TEXTE"	.ASCIZ	"<3>TEXT"	.B	0	.EVEN;--------\\; MAILRUB >;--------/; Cherche une rubrique dans une fiche.; in	A4.L	^nom de la rubrique;	A3.L	^contenu de la fiche; out	D7.W	ok;	 A4.L	 ^plus loin;	 A3.L	 ^rubrique;	D7.W	erreur;	 A4.L	 ^plus loin;	 A3.L	 ^rubrique vide; mod	D7.W, A3.L, A4.LMAILRUB:	PUSHM.L	D3,A1,A2	LOAD.L	A1,A3		; A1 <-- ^contenu de la fiche	LOAD.L	A3,#(A6)+OBUFIC	; A3 <-- ^dfinitions10$:	TEST.B	(A3)		; fin des dfinitions ?	JUMP,EQ 40$		; oui => 40$	PUSH.L	A320$:	COMP.B	(A3+),#SPACE	; A3 <-- saute les lettres initiales	JUMP,NE 20$	LOAD.L	A2,#R16"00$	LIB	?CPSTRING	; nom trouv ?	JUMP',NC 35$		; oui => 35$				; non =>	POP.L	A330$:	COMP.B	(A3+),#CR	; A3 <-- ^dfinition suivante	JUMP,NE 30$	JUMP	10$35$:	POP.L	A2		; A2 <-- ^lettres initiales	PUSH.L	A4	LOAD.L	A4,A1		; A4 <-- ^fiche	FICHE_	PRUBRIQUE	; A3 <-- ^rubrique	POPM.L	A4	JUMP',EQ 50$40$:	LOAD.L	A3,#R16"01$	; A3 <-- ^rubrique vide	LOAD.W	D7,#1		; D7 <-- erreur50$:	LOAD.B	D3,(A4+)	LOAD.L	A2,#R16"00$52$:	TEST.B	(A2)	JUMP,NS 50$	COMP.B	D3,(A2+)	JUMP,NE 52$	DEC.L	A460$:	COMP.B	(A4+),#SPACE	JUMP,EQ 60$	DEC.L	A4	POPM.L	D3,A1,A2	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0,CR,SPACE,'=,'<,-101$:	.ASCIZ	"<CR>"	.EVEN;----------\\; MAILRDDEF >;----------/; Lit toutes les dfinitions.; in	D6.W	canal .FICHE; out	-; mod	D7.WMAILRDDEF:	PUSHM.L	D1,D3,A3	CLR.W	D1		; D1 <-- rang	LOAD.L	A3,#(A6)+OBUFIC	; A3 <-- ^buffer	LOAD.W	D3,#LBUFIC	; D3 <-- lg max buffer10$:	FICHE_	LITDEF		; OBUFIC <-- une dfinition	JUMP',NE 50$20$:	DEC.W	D3	COMP.B	(A3+),#CR	JUMP,NE 20$	INC.W	D1		; D1 <-- rang suivant	JUMP	10$50$:	CLR.B	(A3)		; OBUFIC <-- terminateur	POPM.L	D1,D3,A3	RET;---------\\; OPMFICHE >;---------/; Ouvre le module FICHE.; in	-; out	D7.W	erreur; mod	D7.WOPMFICHE:	PUSHM.L	D1,D3,A3	CLR.W	D7		; D7 <-- ok	COMP.W	(A6)+OCHFICH,#-1 ; module dj ouvert ?	JUMP',NE 90$		; oui => 90$				; non =>	LOAD.L	A3,#R16"NAMFICH	LOAD.W	D3,#FICHE_FIRST	LIB_	OPEN		; ouvre le module FICHE	JUMP',NE 90$	LOAD.W	(A6)+OCHFICH,D190$:	POPM.L	D1,D3,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; CLMFICHE >;---------/; Ferme le module FICHE.; in	-; out	-; mod	D7.WCLMFICHE:	PUSH.L	D1	LOAD.W	D1,(A6)+OCHFICH	COMP.W	D1,#-1		; module dj ferm ?	JUMP',EQ 90$		; oui => 90$				; non =>	LIB_	CLOSE		; ferme le module FICHE	LOAD.W	(A6)+OCHFICH,#-190$:	POP.L	D1	RET;--------\\; STPRINT >;========/; Lit le status de l'imprimante.; in	-; out	D7.W	erreur; mod	D7.WSTPRINT:	PUSHM.L	D2..D4,A2..A4	LOAD.L	A3,#(A6)+OSSPRI	LOAD.L	A4,#(A6)+OSTPRI	LOAD.W	D4,#(LGPRI0/2)-110$:	LOAD.W	(A3+),(A4+)	; OSSPRI <-- OSTPRI	DECJ.W,NMO D4,10$	LOAD.L	A2,(A6)+OCAPRINT	LOAD.L	A4,#(A6)+OSTPRI	; A4 <-- ^buffer	LOAD.L	D4,#LGPRI2	; D4 <-- longueur demande	PRINTA_	RSTATUS	JUMP,NE 90$	LOAD.L	A3,#(A6)+OSSPRI;	LOAD.L	A4,#(A6)+OSTPRI	LOAD.W	D4,#(LGPRI0/2)-115$:	COMP.W	(A3+),(A4+)	; OSSPRI = OSTPRI ?	JUMP',NE 20$	DECJ.W,NMO D4,15$	JUMP	90$20$:	LOAD.L	A4,#(A6)+OSTPRI; Ajuste le status si le zoom n'est pas gal  2 (LQ800).	CLR.L	D4	LOAD.W	D4,(A4)+OPRDEFZ	DIV.WU	D4,(A4)+OPRZ	LOAD.W	D3,(A4)+OPRGLX	MUL.WU	D3,D4	LOAD.W	(A4)+OPRGLX,D3	LOAD.W	D3,(A4)+OPRGLY	MUL.WU	D3,D4	LOAD.W	(A4)+OPRGLY,D3	LOAD.W	D4,(A4)+OPRGLX	SR.W	D4,#3	LOAD.W	(A6)+OFACX,D4	LOAD.W	D4,(A4)+OPRGLY	SR.W	D4,#3	LOAD.W	(A6)+OFACY,D4	LOAD.W	(A6)+OMMX,(A4)+OPRUMX+2	LOAD.W	(A6)+OMMY,(A4)+OPRUMY+2	LOAD.W	D4,#42		; D4 <-- 4.2 mm	CALL	CONVMPY	LOAD.W	(A6)+OITL,D4	CLR.L	D4	LOAD.W	D4,(A4)+OPRLGPH	SUB.W	D4,(A4)+OPRMGGH	SUB.W	D4,(A4)+OPRMGDH	DIV.WU	D4,(A6)+OFACX	; largeur maximale du papier	LOAD.W	(A6)+OLGP,D4	LOAD.W	D4,#2960	; D4 <-- 29.60 cm	CALL	CONVMPY	LOAD.W	(A6)+OHTP,D4	; hauteur du papier par dfaut	CLR.L	D4	LOAD.W	D4,(A4)+OPRHTP	JUMP',EQ 32$	DIV.WU	D4,(A6)+OFACY	; hauteur du papier relle	LOAD.W	(A6)+OHTP,D432$:	CLR.L	D4	LOAD.W	D4,(A4)+OPRMGSH	DIV.WU	D4,(A6)+OFACY	; marge suprieure hard	LOAD.W	(A6)+OMGS,D4	LOAD.W	(A6)+OMGSH,D4	CLR.L	D4	LOAD.W	D4,(A4)+OPRMGIH	DIV.WU	D4,(A6)+OFACY	; marge infrieure hard	LOAD.W	(A6)+OMGI,D4	LOAD.W	(A6)+OMGIH,D4	LOAD.B	(A6)+OQUAL+1,(A4)+OPRNBQ; Met le nom de l'imprimante dans la liste des gencars.	LOAD.L	A3,#(A6)+OGCLIST	LOAD.B	(A3),#-1	LOAD.L	A4,#(A6)+OSTPRI+OPRNAM ; A4 <-- ^nom de l'imprimante	TEST.B	(A4)		; nom existe ?	JUMP',EQ 80$		; non => 80$				; oui =>	LOAD.B	(A3+),#-240$:	LOAD.B	(A3+),(A4+)	; OGCLIST <-- nom de l'imprimante	JUMP,NE 40$	LOAD.B	(A3),#-180$:	LOAD.W	D7,#1		; D7 <-- ok, modifi90$:	POPM.L	D2..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; AJPRINT >;========/; Modifie subtilement les units pour les conversions en mm.; Le valeur donnes en commentaires correspondent  l'OKI-84 !; in	-; out	-; mod	D7.WAJPRINT:	PUSHM.L	D2..D4	LOAD.L	D4,#25400	LOAD.W	D3,(A6)+OMMX	CALL	DIVD4D3		; D4 <-- 36	LOAD.W	D3,(A6)+ODRFX	MUL.WU	D3,(A6)+OFACX	; D3 <-- 35	LOAD.W	D2,(A6)+OLGP	MUL.WU	D2,D3	DIV.WU	D2,D4	LOAD.W	(A6)+OLGP,D2	LOAD.W	D2,(A6)+OMMX	MUL.WU	D2,D4	DIV.WU	D2,D3	LOAD.W	(A6)+OMMX,D2	POPM.L	D2..D4	RET; Textes; ------NAMTEXT:.ASCIZ	"TEXT"		; nom du logicielNAMFICH:.ASCIZ	"FICHE"		; nom du module LIB	.EVEN	.END