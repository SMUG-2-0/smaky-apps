	.TITLE	COUPE	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcima	.REF	SM8		; df diverses	.REF	NTREL		; df noyau temps rel	.REF	GESMEM		; df gestionnaire de mmoire	.REF	FOS		; df file operating system	.REF	LIB		; df librairie	.REF	DRIVERS		; df drivers	.REF	DOLIB		; df restart LIB	.REF	COUPE		; df coupe	.REV	1,2; Constantes; ----------; Variables; ---------;	 OFSTAR   OFAPOS;;	!<--->!<----------->!;	!     !		    !;	-----------------------------;	( d ' a u j o u r d ' h u i );	-----------------------------;	      !;	      !<------- ...	OFPREP;	      !<---------- ...	OFNCOU	.LOC	0OFAPOS:	.BLKB	1		; position apostrophe dans motOFSTAR:	.BLKB	1		; offset dbut du motOFPREP:	.BLKB	1		; offset prpositionOFNCOU:	.BLKB	1		; offset coupure interditeLGVAR:; En-tte du module LIB; ---------------------	.LOC	0	COUPE_	FIRST		; code du premier appel	COUPE_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	1,2		; rvision.version	.W	0,END_COUPE	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"COUPE"		; nom du module	.FILLB	(LGHLIB-.),0	.W	_COUPE_HASH;------------\\; _COUPE_HASH >;============/; Hache un mot, c'est--dire cherche toutes les coupures possibles.; in	A3.L	^mot  couper;	D3.W	longueur du mot;	A4.L	^buffer pour mettre les coupures;	D4.W	longueur du buffer; out	D7.W	erreur; mod	D7.W_COUPE_HASH:	PUSHM.L	D0,D1,D2,D4,A0,A2,A4,A6	LOAD.L	A0,A3		; A0 <-- ^mot	LOAD.W	D0,D3		; D0 <-- lg mot	LOAD.L	A2,A4		; A2 <-- ^buffer	LOAD.W	D2,D4		; D2 <-- lg buffer	LOAD.L	D4,#LGVAR	; D4 <-- lg pour les variables	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour les variables	JUMP',NE 95$	LOAD.L	A6,A4		; A6 <-- ^variables	CALL	LCOUPE		; moteur ...90$:	PUSH.W	D7	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend les variables	POP.W	D795$:	POPM.L	D0,D1,D2,D4,A0,A2,A4,A6	TEST.W	D7		; retour EQ/NE	RET;--------\; LCOUPE  >;========/; Coupe un mot selon un certain nombre de rgles bases sur; les voyelles et les consonnes.; Rend une liste des coupures possibles, termine par zro.; Une valeur dans cette liste avec 2^7=1 indique une coupure; pour laquelle il n'est pas ncessaire d'ajouter un TIRET.; in	A0.L		^dbut du mot;	D0.W		nombre de caractres du mot;	A2.L		^buffer pour liste (.B);	D2.W		longueur buffer (2..n); out	-; mod	-LCOUPE:	PUSHM.L	D0,D1,D2,D3,D4,A0,A1,A2	COMP.W	D2,#2		; 2 places au moins ds liste ?	JUMP,LO	90$		; non => 90$	DEC.W	D2		; garde une place pour <0>; Ignore les caractres  la fin qui ne sont pas des lettres,; pour rsoudre les cas du type:  (commenc-e)	LOAD.L	A1,#(A0)+(D0.W)	; A1 <-- ^fin du mot02$:	LOAD.B	D3,(-A1)	CALL	MIMAJ	COMP.B	D3,#'A		; est-ce bien une lettre ?	JUMP,LO 04$		; non => 04$	COMP.B	D3,#'Z		; oui => 06$	JUMP,LS 06$04$:	DEC.W	D0		; D0 <-- un caractre  ignorer	JUMP,NE	02$06$:	LOAD.W	D1,D0		; D1 <-- lg du mot	COMP.W	D1,#5		; mot de moins de 5 lettres ?	JUMP,LO	90$		; oui => ne coupe pas	CLR.B	(A6)+OFAPOS	; pas d'apostrophe	CLR.B	(A6)+OFSTAR	; mot commence tout de suite	CLR.B	(A6)+OFPREP	; pas de prposition	CLR.B	(A6)+OFNCOU	; pas de coupure interdite; Cherche si le mot contient un "-". Si oui, permet une seule; coupure,  l'endroit o est le premier "-". Cette position; est signale dans la liste avec le bit 2^7  un pour indiquer; qu'il ne faut pas rajouter un "-".; Exemples: aime-/t-il  c'est-/-dire  viendra-/t-on  ...	LOAD.L	A1,A0		; A1 <-- ^dbut du mot	CLR.B	D0		; D0 <-- pos. dans le mot10$:	LOAD.B	D3,(A1+)	COMP.B	D3,#'-		; un "-" dans le mot ?	JUMP,NE 15$		; non => 15$ (cherche encore)				; oui =>	INC.B	D0		; saute le "-"	LOAD.B	(A2+),D0	; mm. coupure	TSET.B	(A2)-1:#7	; coupure "spciale" ...	JUMP	90$15$:	INC.B	D0		; D0 <-- pos. suivante	COMP.B	D0,D1		; fin du mot atteinte ?	JUMP,NE	10$		; non => 10$; Avance dans le mot jusqu' ce qu'une lettre soit rencontre.; OFSTAR permettra de savoir quelle a t l'avance.20$:	LOAD.B	D3,(A0)	CALL	MIMAJ	COMP.B	D3,#'A		; est-ce bien une lettre ?	JUMP,LO 22$		; non => 22$	COMP.B	D3,#'Z		; oui => 24$	JUMP,LS 24$22$:	INC.L	A0		; A0 <-- ^caractre suivant	INC.B	(A6)+OFSTAR	; augmente l'offset du dbut	DEC.W	D1	JUMP,NE	20$	JUMP	90$		; reste plus rien => 90$24$:	COMP.W	D1,#5		; mot de moins de 5 lettres ?	JUMP,LO	90$		; oui => ne coupe pas; Test si la 2me ou 3me lettre du mot est un apostrophe,; pour rsoudre les cas du genre:  l'extra-ordinaire  qu'elles	LOAD.B	D3,(A0)+2	; D3 <-- 3me lettre du mot	COMP.B	D3,#''		; apostrophe ?	JUMP,NE 27$		; non => 27$				; oui =>	INC.L	A0		; A0 <-- saute l'apostrophe	DEC.W	D1	INC.B	(A6)+OFSTAR	; saute un caractre	JUMP	28$		; puis saute deux caractres27$:	LOAD.B	D3,(A0)+1	; D3 <-- 2me lettre du mot	COMP.B	D3,#''		; apostrophe ?	JUMP,NE 30$		; non => 30$28$:	ADD.L	A0,#2		; A0 <-- ^aprs l'apostrophe	SUB.W	D1,#2		; D1 <-- deux car de moins	ADD.B	(A6)+OFSTAR,#2	; augmente l'offset du dbut	COMP.W	D1,#5		; mot de moins de 5 lettres ?	JUMP,LO	90$		; oui => ne coupe pas; Cherche si le mot contient un apostrophe. Si oui, la variable; OFAPOS contient la position de l'apostrophe dans le mot.30$:	LOAD.L	A1,A0		; A1 <-- ^dbut du mot	CLR.B	D0		; D0 <-- pos. dans le mot32$:	LOAD.B	D3,(A1+)	COMP.B	D3,#''		; un apostrophe dans le mot ?	JUMP,NE 35$		; non => 35$	LOAD.B	(A6)+OFAPOS,D0	; OFAPOS <-- position "'"35$:	INC.W	D0	COMP.W	D0,D1		; fin du mot rencontre ?	JUMP,NE	32$		; non => 32$	LOAD.W	D4,D1		; D4 <-- longueur du mot	DEC.W	D4	CLR.W	D0		; D0 <-- pos. dans mot	TCLR.L	D2:#31		; D2 <-- signal 1re syllabe; Cherche dans le dictionnaire des exceptions si le mot en fait; partie ou pas.	CALL	EXCEPT		; teste si exception ...	JUMP,CS 90$		; fini => 90$; Avance dans le mot syllabes par syllabes ...40$:	TEST.W	D1		; reste qq caractres ?	JUMP,EQ 90$		; non => 90$	CALL	SYLLABE		; avance d'une syllabe	JUMP,CS 60$	TSET.L	D2:#31		; D2 <-- signal n me syllabe; Teste si la coupure est une coupure interdite  cause d'une; exception dans DICONC.	COMP.B	D0,(A6)+OFNCOU	; coupure interdite ?	JUMP,EQ	40$		; oui => 40$; Teste si la coupure est trop proche du dbut du mot (par; exemple: -cole) ou trop proche de la fin du mot (par; exemple: cole-s).	LOAD.B	D3,(A6)+OFPREP	ADD.B	D3,#2	COMP.B	D0,D3		; trop prs du dbut ?	JUMP,LO	40$		; oui => 40$	COMP.B	D0,D4		; trop prs de la fin ?	JUMP,HS	40$		; oui => 40$; Teste s'il ne reste que des consonnes depuis cette ventuelle; coupure (par exemple: rangeme-nts)	CALL	RSTCON		; reste que des consonne ?	JUMP,CS	40$		; oui => 40$; Teste si la coupure est un ou deux caractres aprs un; apostrophe.	LOAD.B	D3,(A6)+OFAPOS	; apostrophe dans le mot ?	JUMP,EQ 50$		; non => 50$	INC.B	D3	COMP.B	D3,D0	JUMP,EQ	40$	INC.B	D3	COMP.B	D3,D0		; coupure trop proche ?	JUMP,EQ	40$		; oui => n'en tient pas compte; Insert la proposition de coupure dans la liste.50$:	LOAD.B	D3,(A6)+OFSTAR	ADD.B	D3,D0		; ajoute offset (v) de dbut	TEST.W	D2		; encore place dans liste ?	JUMP,EQ	40$		; non => 40$	DEC.W	D2	LOAD.B	(A2+),D3	; liste <-- possibilit	JUMP	40$60$:	INC.L	A0		; A0 <-- ^suivant	DEC.W	D1	INC.W	D0	JUMP	40$90$:	CLR.B	(A2)		; termine la liste	POPM.L	D0,D1,D2,D3,D4,A0,A1,A2	RET;--------\; EXCEPT  >;--------/; Cherche dans DICOEX si le mot est une exception.; in	A0.L		^mot;	D0,D1.W		position,reste;	A2.L		^liste;	D2.W		longueur liste; out	A0.L		^plus loin;	D0,D1.W		position,reste;	A2.L		^liste;	D2.W		longueur liste;	(A6)+OFPREP.B	longueur prposition;	(A6)+OFNCOU.B	pos. coupure interdite;	CS		rien  couper; mod	D0.W, D1.W, D2.W, A0.L, A2.LEXCEPT:	PUSHM.L	D3	LOAD.L	A1,#R16"DICONE	CALL	SRCDIC		; cherche si pas exception	JUMP,CC 90$		; normal => 90$	LOAD.L	A1,#R16"DICONC	CALL	SRCDIC		; cherche si coupure interdite	JUMP,CS 10$		; rien d'interdit => 10$	LOAD.B	(A6)+OFNCOU,(A1) ; mm. coupure interdite	JUMP	90$10$:	LOAD.L	A1,#R16"DICOEX	CALL	SRCDIC		; cherche une exception	JUMP,CS 90$		; y en a pas => 90$20$:	LOAD.B	D3,(A1+)	; D3 <-- pos. coupure bizarre	JUMP,EQ 40$	LOAD.B	(A6)+OFPREP,D3	; OFPREP <- plus grande coupure	ADD.B	D3,(A6)+OFSTAR	TEST.W	D2		; encore place dans liste ?	JUMP,EQ	20$		; non => 20$	DEC.W	D2	LOAD.B	(A2+),D3	; liste <-- une possibilit	JUMP	20$40$:	LOAD.B	D3,(A6)+OFPREP50$:	INC.L	A0		; saute la plus grande coupure	INC.W	D0	DEC.W	D1	DEC.B	D3	JUMP,NE	50$90$:	CLRC			; retour CC95$:	POPM.L	D3	RET;--------\; SYLLABE >;--------/; Cherche s'il s'agit d'une syllabe normale, c'est--dire:;  - une ou plusieurs consonnes quelconques (voir *);  - une ou plusieurs voyelles quelconques (voir *);  - ventuellement quelques consonnes (jusqu'au dbut de la;    syllabe suivante); (*) Considre qu'il s'agit d'une syllabe lorsque deux mmes; lettres sont trouves.; in	A0.L		^qq chose;	D0,D1.W		position,reste; out	CC		s'est une syllabe;	 A0.L		 ^aprs;	 D0,D1.W	 position,reste;	CS		c'est autre chose;	 A0.L		 idem;	 D0,D1.W	 idem; mod	D0.W, D1.W, A0.LSYLLABE:	PUSHM.L	D0,D1,A0	PUSH.L	A1	COMP.W	D1,#2		; reste moins de 2 caractres ?	JUMP,LO 90$		; oui => retour CS	CALL	SKPCON		; saute les consonnes	JUMP,CS 80$	CALL	SKPVOY		; saute les voyelles	JUMP,CS 80$50$:	LOAD.L	A1,#R16"DICOSY	CALL	SRCDIC		; dbut prochaine syllabe ?	JUMP,CC 80$		; oui => coupe avant	CALL	DOUBLE		; double lettres ?	JUMP,CC 80$		; oui => coupe entre les 2	COMP.W	D1,#2		; reste moins de deux lettres ?	JUMP,LO 90$		; oui => ne coupe plus	LOAD.B	D3,(A0)+1	; D3 <-- lettre suivante	CALL	VOYELLE		; <consonne><voyelle> ?	JUMP,CC 80$		; oui => coupe avant				; non =>	INC.L	A0		; A0 <-- ^suivant	INC.W	D0	DEC.W	D1	JUMP	50$80$:				; c'est une syllabe :	POP.L	A1	ADD.L	SP,#4*3		; POPM.L D0,D1,A0 bidon	CLRC			; retour CC	RET90$:				; ce n'est pas une syllabe :	POP.L	A1	POPM.L	D0,D1,A0	SETC			; retour CS	RET;--------\; SRCDIC  >;--------/; Cherche un groupe de lettres dans un dictionnaire.; in	A0.L		^lettres;	D1.W		nb de caractres restants;	A1.L		^dictionnaire; out	CC		trouv;	 D3.L		 nb de lettres;	 A1.L		 ^2me partie lment (aprs SPACE);	CS		pas trouv; mod	D3.L, A1.LSRCDIC:	PUSHM.L	D0,A0,A2	TEST.W	D1		; reste qq chose ?	SETC	JUMP,EQ 90$		; non => retour CS10$:	TEST.B	(A1)		; fin du dictionnaire ?	SETC	JUMP,EQ 90$		; oui => retour CS	LOAD.W	D0,D1		; D0 <-- lg reste	LOAD.L	A2,A0		; A2 <-- ^mot20$:	TEST.B	(A1)		; fin lment dans dico ?	JUMP,EQ	55$		; oui => 55$ (trouv)	COMP.B	(A1),#SPACE	; fin 1re partie lment ?	JUMP,EQ	50$		; oui => 50$ (trouv)	TEST.W	D0		; reste qq chose ?	JUMP,EQ	30$		; non => 30$	DEC.W	D0	LOAD.B	D3,(A2+)	; D3 <-- une lettre du mot	CALL	MIMAJ	COMP.B	D3,(A1+)	; compare avec dico	JUMP,EQ	20$		; gales => 20$30$:	TEST.B	(A1+)		; cherche l'lment suivant	JUMP,NE	30$		; dans le dico.	JUMP	10$50$:	INC.L	A1		; A1 <-- ^dbut 2me partie55$:	LOAD.L	D3,A2		; D3 <-- ^fin du mot	SUB.L	D3,A0		; D3 <-- lg du mot	CLRC			; retour CC90$:	POPM.L	D0,A0,A2	RET;--------\; RSTCON  >;--------/; Teste s'il ne reste plus que des consonnes dans le mot.; in	A0.L		^lettres;	D0,D1.W		position,reste; out	CC		non (il y a une ou plusieures voyelles);	CS		oui; mod	-RSTCON:	PUSHM.L	D0,D1,D3,A010$:	LOAD.B	D3,(A0+)	CALL	MIMAJ	COMP.B	D3,#'X		; ici, le 'X' n'est pas une	JUMP,EQ 20$		; voyelle !	CALL	VOYELLE		; est-ce une voyelle ?	JUMP,CC 90$		; oui => retour CC20$:	INC.W	D0	DEC.W	D1		; reste qq lettres ?	JUMP,NE	10$		; oui => 10$	SETC			; non => retour CS90$:	POPM.L	D0,D1,D3,A0	RET;--------\; SKPCON  >;--------/; Saute une ou plusieurs consonnes.; in	A0.L		^lettres;	D0,D1.W		position,reste;	D2.L		2^31=0 => 1re syllabe; out	A0.L		^pas une consonne;	D0,D1.W		position,reste;	CS		si doubles lettres; mod	D0.W, D1.W, A0.LSKPCON:	PUSHM.L	D3	TEST.L	D2:#31		; 1re syllabe ?	JUMP,BC 50$		; oui => 50$10$:	TEST.W	D1		; reste qq chose ?	JUMP,EQ	90$		; non => retour CC	LOAD.B	D3,(A0)	CALL	VOYELLE		; d'abord une consonne ?	JUMP,CS 50$		; oui => 50$				; non =>	INC.L	A0		; avance jusqu' ce	INC.W	D0		; qu'une consonne soit	DEC.W	D1		; rencontre.	JUMP	10$50$:	TEST.W	D1		; reste qq chose ?	JUMP,EQ	90$		; non => retour CC	CALL	DOUBLE		; doubles lettres ?	NOTC	JUMP,CS	90$		; oui => retour CS	LOAD.B	D3,(A0)	CALL	VOYELLE		; consonne ?	JUMP,CC	90$		; non => retour CC				; oui =>	INC.L	A0		; A0 <-- ^suivant	INC.W	D0	DEC.W	D1	JUMP	50$90$:	POPM.L	D3	RET;--------\; SKPVOY  >;--------/; Saute une ou plusieurs voyelles.; in	A0.L		^lettres;	D0,D1.W		position,reste; out	A0.L		^pas une voyelle;	D0,D1.W		position,reste;	CS		si doubles lettres; mod	D0.W, D1.W, A0.LSKPVOY:	PUSHM.L	D310$:	TEST.W	D1		; reste qq chose ?	JUMP,EQ	90$		; non => retour CC	CALL	DOUBLE		; doubles lettres ?	NOTC	JUMP,CS	90$		; oui => retour CS	LOAD.B	D3,(A0)		; D3 <-- un caractre	CALL	VOYELLE		; voyelle ?	NOTC	JUMP,CC	90$		; non => retour CC	INC.L	A0		; A0 <-- ^suivant	INC.W	D0		; D0 <-- suivant	DEC.W	D1		; D1 <-- une lettre de moins	JUMP	10$90$:	POPM.L	D3	RET;--------\; DOUBLE  >;--------/; Test s'il y a deux mmes lettres qui se suivent.; in	A0.L		^1re lettre;	D0,D1.W		position,reste; out	CC		deux mmes lettres;	 A0.L		 ^2me consonne;	 D0,D1.W	 position,reste;	CS		autrement;	 A0.L		 inchang;	 D0,D1.W	 inchangs; mod	D0.W, D1.W, A0.LDOUBLE:	PUSHM.L	D3,D4	COMP.W	D1,#2		; reste moins de 2 caractres ?	JUMP,LO 90$		; oui => retour CS	LOAD.B	D3,(A0)+0	; D3 <-- 1re lettre	CALL	MIMAJ	LOAD.B	D4,D3	LOAD.B	D3,(A0)+1	; D3 <-- 2me lettre	CALL	MIMAJ	COMP.B	D3,D4		; deux lettres gales ?	JUMP,NE 90$		; non => retour CS; Vrifie si la coupure est dans une terminaison "fminin pluriel",; c'est--dire "es", pour viter de couper "commenc-es" !	COMP.W	D1,#3		; reste 3 lettres (es) ?	JUMP,NE	50$		; non => 50$	COMP.B	D3,#'E	JUMP,NE	50$	COMP.B	D4,#'E	JUMP,NE	50$	LOAD.B	D3,(A0)+2	; D3 <-- 3me lettre	CALL	MIMAJ	COMP.B	D3,#'S	JUMP,EQ	90$50$:				; coupe =>	INC.L	A0		; saute 1re lettre	DEC.W	D1		; un caractre en moins	INC.W	D0	CLRC			; retour CC	JUMP	95$90$:				; ne coupe pas =>	SETC			; retour CS95$:	POPM.L	D3,D4	RET;--------\; VOYELLE >;--------/; Test si le caractre est une voyelle, c'est--dire :;  "A" , "E" , "I" , "O" , "U"  ou  "Y"; La lettre "X" suit les mmes rgles que la lettre "Y".; De plus, une voyelle peut tre un apostrophe pour rsoudre; les cas du genre  "l'cran"  "qu'il"  "d'apprendre"  etc.; (on suppose qu'un apostrophe est toujours suivit d'une; voyelle).; in	D3.B		caractre; out	D3.B		lettre majuscule;	CC		voyelle;	CS		consonne; mod	D3.BVOYELLE:	CALL	MIMAJ		; D3 <-- lettre MAJUSCULE	COMP.B	D3,#'A	JUMP,EQ	90$	COMP.B	D3,#'E	JUMP,EQ	90$	COMP.B	D3,#'I	JUMP,EQ	90$	COMP.B	D3,#'O	JUMP,EQ	90$	COMP.B	D3,#'U	JUMP,EQ	90$	COMP.B	D3,#'Y	JUMP,EQ	90$	COMP.B	D3,#'X		; "X" = voyelle	JUMP,EQ	90$	COMP.B	D3,#''		; apostrophe = voyelle  !	JUMP,EQ	90$	SETC			; retour CS90$:	RET;--------\; MIMAJ   >;========/; Converti un caractre quelconque en majuscule, sans utiliser; la librairie pour tre plus rapide.; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMIMAJ:	TEST.L	D3:#7		; code "supplmentaire" ?	JUMP,NE 20$		; oui => 20$	COMP.B	D3,#SPACE-2	; lettre accentue ?	JUMP,LO 50$		; oui => 50$	COMP.B	D3,#'a	JUMP,LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP,HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D3)+70$  ; D3 <-- lettre majuscule	POP.W	D0	RET70$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN; Dictionnaires; -------------; Dictionnaire de tous les dbuts possibles de syllabes (cette; liste ne doit contenir que des consonnes) :DICOSY:	.ASCIZ	/BL/		; re-blochon	.ASCIZ	/BR/		; cham-bre	.ASCIZ	/CH/		; al-chimie	.ASCIZ	/CL/		; in-cliner	.ASCIZ	/CR/		; convain-cre	.ASCIZ	/DR/		; suspen-dre	.ASCIZ	/FL/		; in-fluence	.ASCIZ	/FR/		; b-froid	.ASCIZ	/GL/		; jon-gleur	.ASCIZ	/GN/		; ma-gntique	.ASCIZ	/GR/		; bi-gre	.ASCIZ	/PH/		; phos-phore	.ASCIZ	/PL/		; exem-plaire	.ASCIZ	/PR/		; com-prhension	.ASCIZ	/PS/		; rha-psodie	.ASCIZ	/SCH/		; 	.ASCIZ	/TH/		; or-thographe	.ASCIZ	/TR/		; cons-truction	.ASCIZ	/VR/		; fi-vre	.B	0; Dictionnaire de tous les mots (ou dbuts de mots)  couper; normalement (cette liste est parcourue AVANT la liste des; divisions tymoligiques DICOEX) :DICONE:	.ASCIZ	/DESERT/	; d-sert	.ASCIZ	/DESID/		; d-sidratif	.ASCIZ	/DESIGN/	; d-signer	.ASCIZ	/DESIR/		; d-sirer	.ASCIZ	/DESIS/		; d-sister	.ASCIZ	/DESOL/		; d-sol	.ASCIZ	/DESORM/	; d-sormais	.ASCIZ	/HEMIE/		; hemi-dre	.ASCIZ	/INIQ/		; ini-que	.ASCIZ	/INIT/		; ini-tiative	.ASCIZ	/NONA/		; no-nante	.ASCIZ	/PREN/		; pren-dre	.ASCIZ	/PRESB/		; pres-byte	.ASCIZ	/PRESCR/	; pres-crire	.ASCIZ	/PRESQ/		; pres-que	.ASCIZ	/PRESS/		; pres-sion	.ASCIZ	/PREST/		; pres-tence	.ASCIZ	/PREU/		; preu-ve	.ASCIZ	/REINE/		; rei-ne	.ASCIZ	/RETROU/	; retrou-ver	.ASCIZ	/SURAN/		; su-rann	.ASCIZ	/SUREA/		; su-reau	.ASCIZ	/SUREMEN/	; su-rement	.ASCIZ	/SURET/		; su-ret	.ASCIZ	/SURICA/	; su-ricate	.ASCIZ	/SUROI/		; su-rot	.ASCIZ	/SUROS/		; su-ros	.ASCIZ	/SURIR/		; su-rir	.ASCIZ	/SUPERI/	; su-p-rio-ri-t	.ASCIZ	/TRANSI/	; tran-sistor	.B	0; Dictionnaire de tous les mots (ou dbuts de mots)  couper; spcialement (divisions tymologiques) :DICOEX:	.ASCIZ	/AERO <4>/	; aro-spatial	.ASCIZ	/ANTIA <2><4>/	; anti-alcoolique	.ASCIZ	/ANTISP <2><4>/	; anti-spasmodique	.ASCIZ	/ATMO <2><4>/	; atmo-sphre	.ASCIZ	/COO <2>/	; co-opration	.ASCIZ	/DES <3>/	; ds-aveu	.ASCIZ	/DIAGN <4>/	; diag-nostique	.ASCIZ	/EXTRAO <2><5>/	; extra-ordinaire	.ASCIZ	/HEMI <4>/	; hemi-sphre	.ASCIZ	/INA <2>/	; in-actif	.ASCIZ	/INE <2>/	; in-gal	.ASCIZ	/INI <2>/	; in-imaginable	.ASCIZ	/INO <2>/	; in-oubliable	.ASCIZ	/INSTAB <2>/	; in-stable	.ASCIZ	/INU <2>/	; in-utiliser	.ASCIZ	/KILO <2><4>/	; kilo-octets	.ASCIZ	/MALADR <3>/	; mal-adroit	.ASCIZ	/MALAP <3>/	; mal-appris	.ASCIZ	/MALENT <3>/	; mal-entendu	.ASCIZ	/MALINT <3>/	; mal-intensionn	.ASCIZ	/MALODO <3>/	; mal-odorant	.ASCIZ	/MESAL <3>/	; mes-alliance	.ASCIZ	/MESAV <3>/	; mes-aventure	.ASCIZ	/MESE <3>/	; mes-estimer	.ASCIZ	/MESI <3>/	; mes-intelligence	.ASCIZ	/MICRO <2><5>/	; micro-ordinateur	.ASCIZ	/NON <3>/	; non-obstant	.ASCIZ	/OTORH <3>/	; oto-rhinolaryngologiste	.ASCIZ	/PRE <3>/	; pr-occuper	.ASCIZ	/PROE <3>/	; pro-minent	.ASCIZ	/REAB <2>/	; r-abonner	.ASCIZ	/REAC <2>/	; r-action	.ASCIZ	/REAF <2>/	; r-affirmer	.ASCIZ	/REAG <2>/	; r-agir	.ASCIZ	/REAR <2>/	; r-armer	.ASCIZ	/REAS <2>/	; r-assigner	.ASCIZ	/REAT <2>/	; r-atteler	.ASCIZ	/REE <2>/	; r-lection	.ASCIZ	/REI <2>/	; r-intgrer	.ASCIZ	/REO <2>/	; r-organiser	.ASCIZ	/RETRO <2><5>/	; rtro-spectif	.ASCIZ	/SUBLU <3>/	; sub-lunaire	.ASCIZ	/SUBO <3>/	; sub-ordonner	.ASCIZ	/SUBRO <3>/	; sub-rogateur	.ASCIZ	/SUBUR <3>/	; sub-urbain	.ASCIZ	/SUR <3>/	; sur-lever	.ASCIZ	/SUPER <2><5>/	; su-per-struc-tu-re	.ASCIZ	/TRANS <5>/	; trans-atlantique	.ASCIZ	/TECH <4>/	; tech-nique	.ASCIZ	/TELE <2><4>/	; tl-scope	.B	0; Dictionnaire de tous les dbuts de mots  ne pas couper; (exceptions trs spciales) :DICONC:	.ASCIZ	/CON <3>/	; con-cierge	.ASCIZ	/ELLE <2>/	; el-le	.ASCIZ	/HYMNE <3>/	; hym-ne	.B	0	.EVENEND_COUPE:	.END