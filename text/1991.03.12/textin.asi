	.SBTTL	TEXTIN; touche (SHOW); -------------OSHOW:	CALL	EXKEY	.WW	DEFINE	AINPUT	.WW	'R	AFYREGLE	.WW	'I	AFYIMAGE	.WW	'C	AFYCALE	.WW	'H	AFYASCH	.WW	TAB	AFYTAB	.WW	CR	AFYCR	.WW	SPACE	AFYTOUT	.WW	0	SHOBUF; touches (PROGRA-SHOW); ---------------------OPROSHOW:	CALL	EXKEY	.WW	DEFINE	AAJOUTE	.WW	0	NMAINSHOBUF:	CALL	GNBUF		; D0 <-- numro du buffer	JUMP,NE	_NMAIN		; pas trouv => NMAIN	CALL	BIGCURS		; faudra dessiner le grand curseur	COMP.W	D0,(A5)+ONOBUF	; buffer dj affich ?	JUMP,EQ	INI1B		; oui => ne montre plus que lui	LOAD.W	D1,(A5)+ONOBUF	JUMP	INI2B;--------\; FINPUT  >;========/; Cette routine est utilise pour lire le texte donn dans; la ligne de commande.; in	A3.L	^nom de fichier brut; out	D7.W	erreur; mod	D7.WTINPUT:	LOAD.L	A3,#R16"TXDEF	; A3 <-- ^nom du fichier TEXT.TEXTFINPUT:	PUSHM.L	D3,A2,A3,A4	LOAD.L	A4,#(A6)+OBUTEMP10$:	LOAD.B	D3,(A3+)	JUMP',EQ 20$	COMP.B	D3,#SPACE	; fin du nom ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D3,#CR	JUMP',EQ 20$	COMP.B	D3,#'.	JUMP',EQ 20$	LOAD.B	(A4+),D3	; buffer <-- un caractre	JUMP	10$20$:	CLR.B	(A4)		; buffer <-- terminateur	LOAD.L	A3,#(A6)+OBUTEMP	LOAD.L	A4,#(A6)+OBUEXT	; A4 <-- ^extension	CLR.W	D3		; D3 <-- laisse si dj extension	LIB	?ADDEXT		; ajoute l'extension	JUMP',NE 90$	CALL	FLUSH		; vide tout en mmoire (la rgle)	LOAD.B	D4,#2^BIOPREND!2^BIOBOA ; D4 <-- "prend"/"le document entier"	CALL	BINPUT		; lit le texte	JUMP',NE 90$	TCLR.B	(A5)+OSTATUS:#BFILMOD	TCLR.B	(A5)+OSTATUS:#BEOPMOD	TEST.B	(A6)+OFLIO:#BIONE	JUMP',BC 90$	CALL	STOFILE		; mm nom du fichier90$:	POPM.L	D3,A2,A3,A4	RET;--------\\; AINPUT  >;========/; in	-; out	-; mod	D7.WAINPUT:	PUSHM.L	D2,D3,D4,A3,A4	LOAD.L	A3,#(A6)+OBUINPF	CLR.B	(A3)	LOAD.B	D4,#2^BIOPREND!2^BIOBOA10$:	LOAD.L	A4,#(A6)+OBUEXT	; A4 <-- ^extension	CLR.W	D2		; D2 <-- DBOX au milieu fentre	CALL	DBOXEDITI	; attend un nom de fichier	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	LOAD.W	D0,#1		; D0 <-- avant de reprendre	CALL	DBOXSAVE	; sauve plan actuel si ncessaire	JUMP',NE 90$		; l'utilisateur veut pas => 90$	CALL	FLUSH		; vide tout en mmoire	CALL	BINPUT		; lit le texte dans le buffer	JUMP',EQ 30$	TEST.L	D7:#16		; erreur lors de l'ouverture ?	JUMP,BS 10$		; oui => 10$	JUMP'	90$		; non => 90$30$:	TCLR.B	(A5)+OSTATUS:#BFILMOD	TCLR.B	(A5)+OSTATUS:#BEOPMOD	TEST.B	(A6)+OFLIO:#BIONE	JUMP',BC 90$	CALL	STOFILE		; mm nom du fichier90$:	POPM.L	D2,D3,D4,A3,A4	RET;--------\\; AAJOUTE >;========/; in	-; out	-; mod	D7.WAAJOUTE:	PUSHM.L	D2,D3,D4,A3,A4	LOAD.L	A3,#(A6)+OBUINPF	CLR.B	(A3)	LOAD.B	D4,#2^BIOAJOUTE!2^BIOBOA10$:	LOAD.L	A4,#(A6)+OBUEXT	; A4 <-- ^extension	CLR.W	D2		; D2 <-- DBOX au milieu fentre	CALL	DBOXEDITI	; attend un nom de fichier	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	CALL	BIGCURS		; faudra dessiner le grand curseur	LOAD.B	D3,#MARQUED	CALL	INSERT		; marque le dbut de la zone	CALL	BINPUT		; lit le texte dans le buffer	JUMP',EQ 55$	TEST.L	D7:#16		; erreur lors de l'ouverture ?	JUMP,BS 10$		; oui => 10$	JUMP'	60$		; non => 60$55$:	TSET.B	(A5)+OSTATUS:#BFILMOD	TSET.B	(A5)+OSTATUS:#BEOPMOD60$:	LOAD.B	D3,#MARQUEF	CALL	INSERT		; marque la fin de la zone	CALL	ZJUSTIF		; justifie la zone (le fichier ajout)	CALL	ZDJUSTIF	; enlve les marques et va au dbut90$:	POPM.L	D2,D3,D4,A3,A4	RET;--------\; BINPUT  >;========/; Lit un texte dans un buffer.; in	A5.L	^description buffer;	A3.L	^nom de fichier (avec extension);	D4.W	fanions; out	D7.W	erreur;	D7:#16	1 => erreur lors de l'ouverture; mod	D7.LBINPUT:	PUSHM.L	D0..D4,D6,A2..A4	LOAD.B	(A6)+OFLIO3,D4	CALL	SWMO		; souris: met le sablier	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	POPM.L	D0	TSET.L	D7:#16		; D7 <-- erreur d'ouverture	TEST.W	D7	JUMP,NE 96$	TCLR.B	(A6)+OFLIO:#BNOTEXT	LOAD.L	A4,A3		; A4 <-- ^nom du fichier	LOAD.L	A3,#R16"01$	; A3 <-- ^critre "texte"	LOAD.L	A2,#R16"02$	; A2 <-- ^terminateurs	LIB	?CPSTRING	; est-ce que le fichier est un texte ?	JUMP',NC 05$		; oui => 05$	TSET.B	(A6)+OFLIO:#BNOTEXT05$:	LOAD.L	A4,(A5)+OPDT	; A4 <-- ^dbut du trou	CALL	RDOPEN		; ouvre	TCLR.B	(A6)+OFLIO:#BCREG	TCLR.B	(A6)+OFLIO:#BIJUST	TSET.B	(A6)+OFLIO:#BIHEAD	TCLR.B	(A6)+OFLIO:#BIDCR	TCLR.B	(A6)+OFLIO:#BITAB	TCLR.B	(A6)+OFLIO:#BERMGC	TCLR.B	(A6)+OFLIO:#BIONE	TCLR.B	(A6)+OFLIO2:#BICRIM	CLR.B	(A6)+OIOLNOG	CLR.B	(A6)+OIOLMOD	CLR.W	(A6)+OIOPOSL	; on est au dbut de la ligne10$:	CALL	RDONE		; D3 <-- lit un byte	JUMP,NE 80$	TEST.B	D3		; "sajex" de l'ancien EDIT ?	JUMP,EQ	10$		; oui => 10$ (ignore)	COMP.B	D3,#BOA	JUMP,EQ 30$15$:	COMP.B	D3,#CR	JUMP,EQ 50$	TCLR.B	(A6)+OFLIO:#BIHEAD	TCLR.B	(A6)+OFLIO2:#BICRIM ; ce n'est plus un <cr> aprs une image	CALL	ICLREGLE	; cre rglette si ncessaire	COMP.B	D3,#TAB	JUMP,EQ 55$	TCLR.B	(A6)+OFLIO:#BITAB	COMP.B	D3,#LF	JUMP,EQ 51$	COMP.B	D3,#EOP	JUMP,EQ 52$	COMP.B	D3,#CAREOP	JUMP,EQ 53$	COMP.B	D3,#TIRET	JUMP,EQ 54$	COMP.B	D3,#SAJEXM	JUMP,EQ 10$	COMP.B	D3,#SAJEXT	JUMP,EQ 10$	COMP.B	D3,#SAJEXS	JUMP,EQ 10$	COMP.B	D3,#H'80	JUMP,HS 10$	LOAD.W	D2,(A6)+OIOPOSL	CALL	ADDLGC		; D2 <-- position dans la ligne	LOAD.W	(A6)+OIOPOSL,D220$:	CALL	CINSERT		; insert un caractre dans le texte	JUMP,NE 80$	TSET.B	(A6)+OFLIO:#BIONE	JUMP	10$30$:	TCLR.B	(A6)+OFLIO2:#BICRIM ; ce n'est plus un <cr> aprs une image	TEST.B	(A6)+OFLIO:#BNOTEXT ; fichier ".text" ?	JUMP,BS 15$		; non => 15$				; oui =>	LOAD.L	A3,#(A6)+OBUBOA	; A3 <-- ^buffer pour commande "boa"	LOAD.W	D1,#LBUBOA-2	; D1 <-- lg max commande	LOAD.B	(A3+),D3	; buffer <-- <BOA>	CALL	RDONE		; D3 <-- premier caractre	JUMP,NE 80$	LOAD.B	(A3+),D3	; buffer <-- premier caractre	CLR.B	(A3)		; buffer <-- terminateur	CLR.W	D0		; D0 <-- nb de \; imbriqus	COMP.B	D3,#'0	JUMP',LO 40$	COMP.B	D3,#'9	JUMP',LS 35$	COMP.B	D3,#'A	JUMP',LO 40$	COMP.B	D3,#'Z	JUMP',LS 35$	COMP.B	D3,#'a	JUMP',LO 40$	COMP.B	D3,#'z	JUMP',HI 40$35$:	CALL	RDONE		; D3 <-- caractre	JUMP,NE 80$	LOAD.B	(A3+),D3	; buffer <-- caractre	CLR.B	(A3)		; buffer <-- terminateur	DEC.W	D1		; commande trop longue ?	JUMP',EQ 45$		; oui => 45$	COMP.B	D3,#CR		; fin de la commande ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#';	JUMP',EQ 38$	COMP.B	D3,#BOA		; dbut d'une commande \; imbrique ?	JUMP,NE 35$		; non => 35$	INC.W	D0		; D0 <-- un niveau de plus	JUMP	35$38$:	DEC.W	D0		; D0 <-- un niveau de moins	JUMP,NC 35$40$:	LOAD.L	A3,#(A6)+OBUBOA	CALL	INPBOA		; cherche commande "boa"	JUMP,EQ	10$		; ok => 10$;;?	COMP.W	D7,#ERTCMI	; commande inconnue ?;;?	JUMP',EQ 45$		; oui => 45$;;?	TSET.B	(A6)+OFLIO:#BIJUST ; autre erreur => il faudra tout re-justifier45$:				; commande <boa> inconnue =>	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA	JUMP,BS 10$	CALL	ICLREGLE	; cre rglette si ncessaire	LOAD.L	A3,#(A6)+OBUBOA46$:	LOAD.B	D3,(A3+)	JUMP,EQ	10$	COMP.B	D3,#CR	JUMP',NE 47$	LOAD.B	D3,#TEOL47$:	CALL	CINSERT		; insert une commande fausse	JUMP,NE 80$	JUMP	46$50$:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO:#BIDCR	JUMP,BS 10$	CLR.W	(A6)+OIOPOSL	; revient au dbut de la ligne	TCLR.B	(A6)+OFLIO:#BIHEAD	TCLR.B	(A6)+OFLIO2:#BICRIM ; est-ce un <cr> aprs une image ?	JUMP,BS 10$		; oui => 10$	CALL	ICLREGLE	; cre rglette si ncessaire	LOAD.B	D3,#TEOL	JUMP	20$51$:	TEST.B	(A6)+OFLIO3:#BIONOBOA	JUMP,BS 10$	CLR.W	(A6)+OIOPOSL	; revient au dbut de la ligne	LOAD.B	D3,#PEOL	JUMP	20$52$:	CLR.W	(A6)+OIOPOSL	; revient au dbut de la ligne	LOAD.B	D3,#TEOP	JUMP	20$53$:	TEST.B	(A6)+OFLIO3:#BIONOBOA	JUMP,BS 10$	CLR.W	(A6)+OIOPOSL	; revient au dbut de la ligne	LOAD.B	D3,#PEOP	JUMP	20$54$:	TEST.B	(A6)+OFLIO3:#BIONOBOA	JUMP,BS 10$	LOAD.B	D3,#TIRET	JUMP	20$55$:	TSET.B	(A6)+OFLIO:#BITAB	JUMP	20$80$:	PUSH.W	D7	CALL	RDCLOSE		; ferme le fichier	CALL	VAQQPART	; revient au dbut du texte lu	CALL	TNVISU		; D3 <-- premier caractre lu	JUMP',NE 82$		; si y'en a pas => 82$	COMP.B	D3,#REGLE	; est-ce une rgle ?	JUMP',NE 82$		; non => 82$	CALL	AVANCE		; oui => saute la rgle !82$:	POP.W	D7	PUSH.W	D4	LOAD.W	D4,#MODALL	CALL	MODIF		; signal type de modification	POP.W	D4	COMP.W	D7,#EROUTF	; fin du fichier rencontre ?	JUMP',NE 90$		; non => 90$	CLR.W	D7		; oui => parfait	TEST.B	(A6)+OFLIO:#BNOTEXT ; fichier ".text" ?	JUMP',BS 85$		; oui => 85$	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 85$		; oui => 85$	TEST.B	(A6)+OFLIO:#BIJUST ; re-justification ncessaire ?	JUMP',BC 90$		; non => 90$85$:				; oui =>	CALL	AJUSTIF		; re-justifie tout90$:	TEST.B	(A6)+OFLIO:#BERMGC	JUMP',BC 95$	LOAD.W	D7,#ERTMGC	; D7 <-- il manque un (des) gencar(s)95$:	TCLR.L	D7:#16		; D7 <-- pas une erreur d'ouverture96$:	CALL	IOERROR		; affiche erreur si ncessaire	POPM.L	D0..D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	"*.text"	; critre pour "texte"02$:	.B	0,CR,-1		; terminateurs	.EVEN;--------\\; INPBOA  >;========/; Cherche l'adresse de la routine d'une squence "boa".; in	A3.L	^commande;	D4.W	mode (0 = prend, autre = ajoute); out	A3.L	adresse routine;	D7.W	erreur; mod	D7.W, A3.LINPBOA:	PUSHM.L	D0..D5,A0..A4	LOAD.W	D7,#ERTCMI	; D7 <-- commande inconnue	LOAD.L	A4,#R16"TAIBOA10$:	TEST.B	(A4)		; fin de la table ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	A2,A3		; A2 <-- ^commande cherche20$:	TEST.B	(A4)	JUMP',EQ 50$	COMP.B	(A4+),(A2+)	JUMP,EQ 20$30$:	TEST.B	(A4+)		; A4 <-- saute fin du .ASCIZ	JUMP,NE	30$	INC.L	A4		; A4 <-- saute .B	EX.L	D4,A4	INC.L	D4	TCLR.L	D4:#0		; A4 <-- saute .EVEN	EX.L	A4,D4	ADD.L	A4,#2		; A4 <-- saute .W	JUMP	10$50$:	LOAD.L	A3,A2		; A3 <-- ^paramtres ventuels	INC.L	A4		; A4 <-- saute le <0>	LOAD.B	D3,(A4+)	; D3 <-- .B	EX.L	D4,A4	INC.L	D4	TCLR.L	D4:#0		; A4 <-- saute .EVEN	EX.L	A4,D4	CLR.L	D2	LOAD.W	D2,(A4)		; D2 <-- adresse relative	LOAD.L	A2,(A6)+OSTART	; A2 <-- adresse absolue dbut du code	ADD.L	A2,D2		; A2 <-- adresse absolue	CLR.W	D7		; D7 <-- ok	CALL	(A2)		; appel routine ...90$:	POPM.L	D0..D5,A0..A4	TEST.W	D7		; retour EQ/NE	RETTAIBOA:	.ASCIZ	"<BOA>h "	.B	1	.EVEN	.W	IBOASAJEXS	.ASCIZ	"<BOA>hn "	.B	1	.EVEN	.W	IBOASAJEXMT	.ASCIZ	"<BOA>a "	.B	0	.EVEN	.W	IBOASAJEXS	.ASCIZ	"<BOA>an "	.B	0	.EVEN	.W	IBOASAJEXMT	.ASCIZ	"<BOA>_"	.B	BMODSOUL	.EVEN	.W	IBOACOMMODE	.ASCIZ	"<BOA>g_"	.B	0	.EVEN	.W	IBOACOMGENCAR	.ASCIZ	"<BOA>define g_"	.B	0	.EVEN	.W	IBOADEFINE	.ASCIZ	"<BOA>up;"	.B	BMODUP	.EVEN	.W	IBOACOMMODE	.ASCIZ	"<BOA>down;"	.B	BMODDOWN	.EVEN	.W	IBOACOMMODE	.ASCIZ	"<BOA>image "	.B	0	.EVEN	.W	IBOAIMAGE	.ASCIZ	"<BOA><BOA>"	.B	0	.EVEN	.W	IBOABOA	.ASCIZ	"<BOA>justif;"	.B	JUSTA	.EVEN	.W	IBOAJUSTIF	.ASCIZ	"<BOA>justifie;"	.B	JUSTA	.EVEN	.W	IBOAJUSTIF	.ASCIZ	"<BOA>justifi;"	.B	JUSTA	.EVEN	.W	IBOAJUSTIF	.ASCIZ	"<BOA>drapeau;"	.B	JUSTD	.EVEN	.W	IBOAJUSTIF	.ASCIZ	"<BOA>drapg;"	.B	JUSTD	.EVEN	.W	IBOAJUSTIF	.ASCIZ	"<BOA>drapd;"	.B	JUSTG	.EVEN	.W	IBOAJUSTIF	.ASCIZ	"<BOA>centre;"	.B	JUSTC	.EVEN	.W	IBOAJUSTIF	.ASCIZ	"<BOA>centr;"	.B	JUSTC	.EVEN	.W	IBOAJUSTIF; *****	Provisoire vv	.ASCIZ	"<BOA>interligne 1il;"	.B	ITL1	.EVEN	.W	IBOAINTERL	.ASCIZ	"<BOA>interligne 1.5il;"	.B	ITL12	.EVEN	.W	IBOAINTERL	.ASCIZ	"<BOA>interligne 2il;"	.B	ITL2	.EVEN	.W	IBOAINTERL; *****	Provisoire ^^	.ASCIZ	"<BOA>interligne "	.B	0	.EVEN	.W	IBOAINTERN	.ASCIZ	"<BOA>marge "	.B	0	.EVEN	.W	IBOAMARGE	.ASCIZ	"<BOA>large "	.B	0	.EVEN	.W	IBOALARGE	.ASCIZ	"<BOA>largeur "	.B	0	.EVEN	.W	IBOALARGE	.ASCIZ	"<BOA>renf "	.B	0	.EVEN	.W	IBOARENF	.ASCIZ	"<BOA>newtab "	.B	0	.EVEN	.W	IBOANEWTAB	.ASCIZ	"<BOA>justtab "	.B	0	.EVEN	.W	IBOAJUSTTAB	.ASCIZ	"<BOA>coupe;"	.B	-1	.EVEN	.W	IBOACOUPE	.ASCIZ	"<BOA>nocoupe;"	.B	0	.EVEN	.W	IBOACOUPE	.ASCIZ	"<BOA>label "	.B	0	.EVEN	.W	IBOALABEL	.ASCIZ	"<BOA>ver 1;"	.B	0	.EVEN	.W	IBOAVER	.ASCIZ	"<BOA>enable <'<>cr<'>>;"	.B	0	.EVEN	.W	IBOAENACR	.ASCIZ	"<BOA>disable <'<>cr<'>>;"	.B	0	.EVEN	.W	IBOADISCR	.ASCIZ	"<BOA>disable "	.B	0	.EVEN	.W	IBOAHEADER	.ASCIZ	"<BOA>justmode "	.B	0	.EVEN	.W	IBOAJUSTMODE	.ASCIZ	"<BOA>textdef "	.B	0	.EVEN	.W	IBOATEXTDEF	.ASCIZ	"<BOA>textfact "	.B	0	.EVEN	.W	IBOATEXTFACT	.ASCIZ	"<BOA>hauteur "	.B	0	.EVEN	.W	IBOAHAUTEUR	.ASCIZ	"<BOA>marsup "	.B	0	.EVEN	.W	IBOAMARSUP	.ASCIZ	"<BOA>marinf "	.B	0	.EVEN	.W	IBOAMARINF	.ASCIZ	"<BOA>zoom;"	.B	0	.EVEN	.W	IBOAZOOM	.ASCIZ	"<BOA>width "	.B	0	.EVEN	.W	IBOAWIDTH	.ASCIZ	"<BOA>dimcar "	.B	0	.EVEN	.W	IBOADIMCAR	.ASCIZ	"<BOA>cpage="	.B	0	.EVEN	.W	IBOACPAGE	.ASCIZ	"<BOA>debutpage:"	.B	0	.EVEN	.W	IBOADEBUTPAGE	.B	0	.EVEN;-----------\\; IBOAHEADER >;-----------/; Lit les commandes d'en-tte.; in	-; out	D7.W	erreur; mod	+IBOAHEADER:	RET;---------\\; IBOAVER  >;---------/; Lit la commande de version.; in	-; out	D7.W	erreur; mod	+IBOAVER:	RET;----------\\; IBOAZOOM  >;----------/; Lit la commande de zoom.; in	-; out	D7.W	erreur; mod	+IBOAZOOM:	RET;----------\\; IBOAWIDTH >;----------/; Lit la commande de largeur des caractres internes.; in	-; out	D7.W	erreur; mod	+IBOAWIDTH:	RET;-----------\\; IBOADIMCAR >;-----------/; Lit la commande de dimensionnement des caractres internes.; in	-; out	D7.W	erreur; mod	+IBOADIMCAR:	RET;----------\\; IBOADISCR >;----------/; Lit la commande disable <cr>.; in	-; out	D7.W	erreur; mod	+IBOADISCR:	TSET.B	(A6)+OFLIO:#BIDCR	RET;----------\\; IBOAENACR >;----------/; Lit la commande enable <cr>.; in	-; out	D7.W	erreur; mod	+IBOAENACR:	TCLR.B	(A6)+OFLIO:#BIDCR	RET;----------\\; IBOACPAGE >;----------/; Lit la commande du compteur de page initial.; in	-; out	D7.W	erreur; mod	+IBOACPAGE:	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	TEST.B	(A6)+OFLIO3:#BIOAJOUTE ; ajoute ?	JUMP',BS 90$	LOAD.L	A4,#(A6)+ODFNUT20$:	LOAD.B	D3,(A3+)	COMP.B	D3,#'0	JUMP',LO 30$	COMP.B	D3,#'9	JUMP',HI 30$	LOAD.B	(A4+),D3	; ODFNUT <-- numro initial	JUMP	20$30$:	CLR.B	(A4)		; ODFNUT <-- terminateur90$:	RET;--------------\\; IBOADEBUTPAGE >;--------------/; Lit la commande de numrotation de page.; in	-; out	D7.W	erreur; mod	+IBOADEBUTPAGE:	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS EXIT$		; oui => EXIT$	TEST.B	(A6)+OFLIO3:#BIOAJOUTE ; ajoute ?	JUMP,BS EXIT$	CLR.B	(A6)+ODFNEN	; pas d'en-tte	CLR.B	(A6)+ODFNUM	; pas de numro	CLR.W	D2		; D2 <-- nombre de commande "hn" rencontres	CLR.W	D4		; D4 <-- on n'est pas dans une commande BOALOOP$:	LOAD.B	D3,(A3+)	JUMP,EQ EXIT$	COMP.B	D3,#LF	JUMP,EQ EXIT$	COMP.B	D3,#BOA		; dbut d'une commande ?	JUMP',EQ BOABEGIN$	COMP.B	D3,#';		; fin d'une commande ?	JUMP',EQ BOAEND$	TEST.W	D4		; caractre dans une commande ?	JUMP,NE LOOP$		; oui => LOOP$	DEC.L	A3	JUMP'	TEXT$BOAEND$:			; fin d'une commande =>	TEST.W	D4	JUMP,EQ LOOP$	DEC.W	D4	JUMP	LOOP$BOABEGIN$:			; dbut d'une commande =>	CALL	IBOAIFCPAGE	; commande "cpage" ?	JUMP',EQ TEXT0$		; oui => TEXT0$	INC.W	D4	COMP.B	(A3)+0,#'h	JUMP',NE GCIF$	COMP.B	(A3)+1,#'n	JUMP',NE GCIF$	COMP.B	(A3)+2,#SPACE	JUMP',EQ HN$GCIF$:	COMP.B	(A3)+0,#'g	JUMP,NE LOOP$	COMP.B	(A3)+1,#'_	; commande "g_Fond" par exemple ?	JUMP,NE LOOP$		; non => LOOP$				; oui =>	ADD.L	A3,#2		; A3 <-- saute "g_"	LOAD.L	A4,#(A6)+ODFNGCGCLOOP$:	LOAD.B	D3,(A3+)	JUMP',EQ GCEND$	COMP.B	D3,#';	JUMP',EQ GCEND$	LOAD.B	(A4+),D3	; ODFNGC <-- nom du gencar	JUMP	GCLOOP$GCEND$:	CLR.B	(A4)		; ODFNGC <-- terminateur	DEC.L	A3	JUMP	LOOP$HN$:	INC.W	D2		; D2 <-- une commande "hn" de plus	JUMP	LOOP$TEXT0$:	DEC.L	A3TEXT$:	LOAD.L	A4,#(A6)+ODFNEN	; A4 <-- ^buffer pour en-tte	COMP.W	D2,#2	JUMP',LO TEXTLOOP$	LOAD.L	A4,#(A6)+ODFNUM	; A4 <-- ^buffer pour numroTEXTLOOP$:	LOAD.B	D3,(A3+)	JUMP',EQ TEXTEND$	COMP.B	D3,#LF	JUMP',EQ TEXTEND$	COMP.B	D3,#BOA		; commande ?	JUMP',EQ TEXTBOA$	LOAD.B	(A4+),D3	; ODFNEN/NUM <-- prfixe	JUMP	TEXTLOOP$TEXTBOA$:	CALL	IBOAIFCPAGE	; commande "cpage" ?	JUMP',NE TEXTEND$	; non => TEXTEND$	ADD.L	A3,#6		; A3 <-- saute la commande "cpage"	LOAD.L	A2,#(A6)+ODFNUTCPAGE$:	LOAD.B	(A4+),(A2+)	; ODFNEN/NUM <-- numro initial	JUMP,NE CPAGE$	DEC.L	A4	JUMP	TEXTLOOP$TEXTEND$:	DEC.L	A3	CLR.B	(A4)		; ODFNEN/NUM <-- terminateur	JUMP	LOOP$EXIT$:	RET;------------\\; IBOAIFCPAGE >;------------/; ; in	A3.L	^commande (aprs le BOA); out	EQ	c'est la commande "cpage;"; mod	-IBOAIFCPAGE:	COMP.B	(A3)+0,#'c	JUMP',NE 90$	COMP.B	(A3)+1,#'p	JUMP',NE 90$	COMP.B	(A3)+2,#'a	JUMP',NE 90$	COMP.B	(A3)+3,#'g	JUMP',NE 90$	COMP.B	(A3)+4,#'e	JUMP',NE 90$	COMP.B	(A3)+5,#';90$:	RET;-------------\\; IBOAJUSTMODE >;-------------/; Lit la commande des paramtres de justification.; in	-; out	D7.W	erreur; mod	+IBOAJUSTMODE:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	ICLREGLE	; cre rglette si ncessaire	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLIO3:#BIOAJOUTE ; ajoute ?	JUMP',BS 90$	CALL	RDNUM	JUMP',NE 90$	LOAD.W	(A6)+OJUPAL,D4	CALL	RDNUM	JUMP',NE 90$	LOAD.W	(A6)+OJUPTR,D4	CALL	RDNUM	JUMP',NE 80$	LOAD.W	(A6)+OJUPNL,D480$:	CLR.W	D7		; D7 <-- ok90$:	RET;------------\\; IBOATEXTDEF >;------------/; Lit la commande pour les dfinitions (fanions).; in	-; out	D7.W	erreur; mod	+IBOATEXTDEF:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	ICLREGLE	; cre rglette si ncessaire	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLIO3:#BIOAJOUTE ; ajoute ?	JUMP',BS 90$	CALL	RDNUM	JUMP',NE 90$	LOAD.L	D3,D4	AND.L	D3,#2^BFAENG!2^BFAENC!2^BFAEND!2^BFANUG!2^BFANUC!2^BFANUD	JUMP',NE 60$	OR.L	D4,#2^BFAENG!2^BFANUC60$:	LOAD.L	(A6)+OFANION,D4	SWAP.W	D4	LOAD.B	D3,D4	SR.B	D3,#3	AND.B	D3,#B'111	AND.B	D4,#B'111	COMP.B	D4,D3		; en-tte  gauche de la numrotation ?	JUMP',LS 90$		; oui => 90$	LOAD.L	A3,#(A6)+ODFNEN	LOAD.L	A4,#(A6)+ODFNUM	LOAD.W	D4,#LDFNUM-170$:	LOAD.B	D3,(A3)	LOAD.B	(A3+),(A4)	; EX.B (A3+),(A4+)	LOAD.B	(A4+),D3	DECJ.W,NMO D4,70$90$:	RET;-------------\\; IBOATEXTFACT >;-------------/; Lit la commande pour les facteurs.; in	-; out	D7.W	erreur; mod	+IBOATEXTFACT:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	ICLREGLE	; cre rglette si ncessaire	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLIO3:#BIOAJOUTE ; ajoute ?	JUMP',BS 90$	CALL	RDNUM		; D4 <-- facteur en X	JUMP',NE 90$	COMP.W	D4,(A6)+OFACX	; mme facteur en X ?	JUMP',EQ 90$		; oui => 90$	TSET.B	(A6)+OFLIO:#BIJUST ; non => il faudra tout re-justifier90$:	RET;------------\\; IBOAHAUTEUR >;------------/; Lit la commande pour la hauteur.; in	-; out	D7.W	erreur; mod	+IBOAHAUTEUR:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	ICLREGLE	; cre rglette si ncessaire	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLIO3:#BIOAJOUTE ; ajoute ?	JUMP',BS 90$	CALL	RDNUMY	JUMP',NE 90$	COMP.W	D4,(A6)+OHTP	JUMP',EQ 90$	TSET.B	(A6)+OFLIO:#BIJUST ; il faudra tout re-justifier90$:	RET;-----------\\; IBOAMARSUP >;-----------/; Lit la commande pour la marge suprieure.; in	-; out	D7.W	erreur; mod	+IBOAMARSUP:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	ICLREGLE	; cre rglette si ncessaire	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLIO3:#BIOAJOUTE ; ajoute ?	JUMP',BS 90$	CALL	RDNUMY	JUMP',NE 90$	COMP.W	D4,(A6)+OMGSH	; trop petit ?	JUMP',HS 70$		; non => 70$	LOAD.W	D4,(A6)+OMGSH	; D4 <-- minimum possible	TSET.B	(A6)+OFLIO:#BIJUST ; il faudra tout re-justifier70$:	LOAD.W	(A6)+OMGS,D490$:	RET;-----------\\; IBOAMARINF >;-----------/; Lit la commande pour la marge infrieure.; in	-; out	D7.W	erreur; mod	+IBOAMARINF:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	ICLREGLE	; cre rglette si ncessaire	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLIO3:#BIOAJOUTE ; ajoute ?	JUMP',BS 90$	CALL	RDNUMY	JUMP',NE 90$	COMP.W	D4,(A6)+OMGIH	; trop petit ?	JUMP',HS 70$		; non => 70$	LOAD.W	D4,(A6)+OMGIH	; D4 <-- minimum possible	TSET.B	(A6)+OFLIO:#BIJUST ; il faudra tout re-justifier70$:	LOAD.W	(A6)+OMGI,D490$:	RET;--------\\; IBOABOA >;--------/; Lit une commande "double boa".; in	-; out	D7.W	erreur; mod	+IBOABOA:	TCLR.B	(A6)+OFLIO:#BITAB	CALL	ICLREGLE	; cre rglette si ncessaire	LOAD.B	D3,#BOA	LOAD.W	D2,(A6)+OIOPOSL	CALL	ADDLGC		; D2 <-- position dans la ligne	LOAD.W	(A6)+OIOPOSL,D2	JUMP	CINSERT;	CALL	CINSERT;	RET;-----------\\; IBOAJUSTIF >;-----------/; Lit une commande de mode de justification.; in	D3.B	mode; out	D7.W	erreur; mod	+IBOAJUSTIF:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	IOPREGLE	; dbut d'une rglette	LOAD.B	(A6)+OSREG+OREGJUST,D3	CLR.W	D7		; D7 <-- ok90$:	RET;-----------\\; IBOAINTERL >;-----------/; PROVISOIRE: Lit une commande d'interligne.; in	D3.B	interligne; out	D7.W	erreur; mod	+IBOAINTERL:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	IOPREGLE	; dbut d'une rglette	LOAD.B	(A6)+OSREG+OREGITL,D3	CLR.W	D7		; D7 <-- ok90$:	RET;-----------\\; IBOAINTERN >;-----------/; Lit une commande d'interligne quelconque.; in	D4.W	fanions; out	D7.W	erreur; mod	+IBOAINTERN:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 90$		; oui => 90$	TEST.B	(A6)+OFLIO:#BIHEAD ; commande dans l'en-tte ?	JUMP',BC 50$		; non => 50$				; oui =>	TEST.B	(A6)+OFLIO3:#BIOAJOUTE ; ajoute ?	JUMP',BS 90$	CALL	RDNUMY	JUMP',NE 90$	LOAD.W	(A6)+OITL,D4	; init l'interligne global	JUMP'	90$50$:				; commande dans rgle =>	CALL	IOPREGLE	; dbut d'une rglette	CALL	RDNUMY	JUMP',NE 90$	LOAD.B	D3,#ITL1	; D3 <-- interligne 1	COMP.W	D4,(A6)+OITL	JUMP',LS 80$	LOAD.B	D3,#ITL2	; D3 <-- interligne 2	SR.W	D4,#1	COMP.W	D4,(A6)+OITL	JUMP',HS 80$	LOAD.B	D3,#ITL12	; D3 <-- interligne 1.580$:	LOAD.B	(A6)+OSREG+OREGITL,D390$:	RET;----------\\; IBOAMARGE >;----------/; Lit une commande de marge gauche.; in	A3.L	^paramtre(s); out	D7.W	erreur; mod	+IBOAMARGE:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	TEST.B	(A6)+OFLIO:#BIHEAD ; commande dans l'en-tte ?	JUMP',BC 50$		; non => 50$				; oui =>	TEST.B	(A6)+OFLIO3:#BIOAJOUTE ; ajoute ?	JUMP',BS 90$	CALL	RDNUMX	JUMP',NE 90$	LOAD.W	(A6)+OMGG,D4	; init la marge gauche fixe	JUMP'	90$50$:				; commande dans rgle =>	CALL	IOPREGLE	; dbut d'une rglette	CALL	RDNUMX		; D4 <-- marge gauche	JUMP',NE 90$	SUB.W	D4,(A6)+OMGG	; D4 <-- soustrait la marge gauche fixe	JUMP',HS 70$	CLR.W	D470$:	LOAD.W	(A6)+OSREG+OREGMGG,D490$:	RET;----------\\; IBOALARGE >;----------/; Lit une commande de largeur utile.; in	A3.L	^paramtre(s);	D4.W	fanions; out	D7.W	erreur; mod	+IBOALARGE:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	TEST.B	(A6)+OFLIO:#BIHEAD ; commande dans l'en-tte ?	JUMP',BC 50$		; non => 50$				; oui =>	TEST.B	(A6)+OFLIO3:#BIOAJOUTE ; ajoute ?	JUMP',BS 90$	CALL	RDNUMX	JUMP',NE 90$	COMP.W	D4,#50000/5	; <<< PROVISOIRE <<<	JUMP',EQ 90$	TEST.W	D4		; commande "\large 0mm;" ?	JUMP',EQ 90$	COMP.W	D4,(A6)+OLGP	JUMP',EQ 90$	TSET.B	(A6)+OFLIO:#BIJUST ; il faudra tout re-justifier	JUMP'	90$50$:	CALL	IOPREGLE	; dbut d'une rglette	CALL	RDNUMX		; D4 <-- largeur	JUMP',NE 90$	ADD.W	D4,(A6)+OSREG+OREGMGG	LOAD.W	(A6)+OSREG+OREGMGD,D490$:	RET;----------\\; IBOARENF  >;----------/; Lit une commande de renfoncement.; in	A3.L	^paramtre(s); out	D7.W	erreur; mod	+IBOARENF:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	IOPREGLE	; dbut d'une rglette	CALL	RDNUMX		; D4 <-- renfoncement	JUMP',NE 90$	ADD.W	D4,(A6)+OSREG+OREGMGG	LOAD.W	(A6)+OSREG+OREGRENF,D490$:	RET;-----------\\; IBOANEWTAB >;-----------/; Lit une commande de nouveaux tabulateurs.; in	A3.L	^paramtre(s); out	D7.W	erreur; mod	+IBOANEWTAB:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA	; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	IOPREGLE	; dbut d'une rglette	LOAD.L	A4,#(A6)+OSREG+OREGTAB	LOAD.W	D1,#MAXTAB-1	CLR.W	(A4)10$:	LOAD.B	D3,(A3+)	; D3 <-- type du tabulateur	LOAD.W	D2,#2^BTABIND1!2^BTABIND2	COMP.B	D3,#'i	JUMP',EQ 20$	LOAD.W	D2,#2^BTABGAU	COMP.B	D3,#'g	JUMP',EQ 20$	LOAD.W	D2,#2^BTABCEN	COMP.B	D3,#'c	JUMP',EQ 20$	LOAD.W	D2,#2^BTABNUM	COMP.B	D3,#'d	JUMP',EQ 20$	CLR.W	D2	DEC.L	A320$:	CALL	RDNUMX		; D4 <-- un tabulateur	JUMP',NE 90$	OR.W	D4,D2		; D4 <-- ajoute le type	LOAD.W	(A4+),D4	CLR.W	(A4)	DEC.W	D1	JUMP,NE	10$90$:	CLR.W	D7		; D7 <-- ok	RET;------------\\; IBOAJUSTTAB >;------------/; Lit une commande de types de tabulateurs.; in	A3.L	^paramtre(s); out	D7.W	erreur; mod	+IBOAJUSTTAB:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	IOPREGLE	; dbut d'une rglette	LOAD.L	A4,#(A6)+OSREG+OREGTAB	LOAD.W	D1,#MAXTAB-110$:	LOAD.B	D3,(A3+)	; D3 <-- type du tabulateur	LOAD.W	D2,#2^BTABIND1!2^BTABIND2	COMP.B	D3,#'i	JUMP',EQ 20$	LOAD.W	D2,#2^BTABGAU	COMP.B	D3,#'g	JUMP',EQ 20$	LOAD.W	D2,#2^BTABCEN	COMP.B	D3,#'c	JUMP',EQ 20$	LOAD.W	D2,#2^BTABNUM	COMP.B	D3,#'d	JUMP',EQ 20$	CLR.W	D2	COMP.B	D3,#'n	JUMP',NE 90$20$:	OR.W	(A4+),D2	; met le type	DEC.W	D1	JUMP',EQ 90$	COMP.B	(A3+),#',	JUMP,EQ	10$90$:	CLR.W	D7		; D7 <-- ok	RET;-----------\\; IBOACOUPE  >;-----------/; Lit une commande de coupure.; in	D3.B	mode pour les coupures; out	D7.W	erreur; mod	+IBOACOUPE:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	IOPREGLE	; dbut d'une rglette	LOAD.B	(A6)+OSREG+OREGCOUP,D3	CLR.W	D7		; D7 <-- ok90$:	RET;-----------\\; IBOALABEL  >;-----------/; Lit une commande de label.; in	A3.L	^paramtre; out	D7.W	erreur; mod	+IBOALABEL:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	CALL	IOPREGLE	; dbut d'une rglette	LOAD.B	D3,(A3)	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'A+10	JUMP',HS 90$	SUB.B	D3,#'A-1	LOAD.B	(A6)+OSREG+OREGLAB,D3	CLR.W	D7		; D7 <-- ok90$:	RET;----------\\; IBOAIMAGE >;----------/; Lit une commande d'image.; in	A3.L	^paramtre(s); out	D7.W	erreur; mod	+IBOAIMAGE:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 90$		; oui => 90$	CALL	ICLREGLE	; cre rglette si ncessaire	LOAD.L	A4,#(A6)+OBUINPI10$:	LOAD.B	D3,(A3)		; D3 <-- un caractre du nom	COMP.B	D3,#';	JUMP',EQ 20$	COMP.B	D3,#CR	JUMP',EQ 20$	INC.L	A3	COMP.B	D3,#',	JUMP',EQ 20$	LOAD.B	(A4+),D3	; OBUINPI <-- nom du fichier image	JUMP	10$20$:	CLR.B	(A4)	LOAD.L	A4,A3		; A4 <-- ^paramtres aprs le nom	LOAD.L	A3,#(A6)+OBUINPI	LOAD.B	D3,#DEBIMA	; <debima>	CALL	CINSERT30$:	LOAD.B	D3,(A3+)	; nom<0>	CALL	CINSERT	TEST.B	D3	JUMP,NE	30$	CLR.B	D3	CALL	CINSERT	CALL	CINSERT		; <dyy>;	CLR.B	D3	CALL	CINSERT	CALL	CINSERT		; <dxx>	LOAD.L	A3,A4		; A3 <-- ^paramtres aprs le nom	CALL	RDNUM		; D4 <-- facteur zoom	JUMP',NE 50$	CALL	RDNUMX		; D4 <-- indentation en X	JUMP',NE 50$	SUB.W	D4,(A5)+OCREG+OREGRENF	JUMP',HS 40$	CLR.W	D440$:	CALL	NUMRB	LOAD.B	D3,D1	CALL	CINSERT		; <ix> high	LOAD.B	D3,D0	CALL	CINSERT		; <ix> low	JUMP'	60$50$:	CLR.B	D3	CALL	CINSERT	CALL	CINSERT		; <ixx>60$:	LOAD.B	D3,#FINIMA	; <finima>	CALL	CINSERT;;?	CALL	RDONE		; "mange" le <CR> aprs l'image;;?	CLR.W	(A6)+OIOPOSL	; revient au dbut de la ligne	TSET.B	(A6)+OFLIO2:#BICRIM ; attend un <cr> aprs l'image90$:	RET;-----------\\; IBOADEFINE >;-----------/; Lit une commande de dfinition d'un gencar.; in	A3.L	^paramtre(s) "titre:<BOA>gencar;<CR>"; out	D7.W	erreur; mod	+IBOADEFINE:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 95$		; oui => 95$	TCLR.B	(A6)+OFLIO:#BIHEAD	CALL	ICLREGLE	; cre rglette si ncessaire	TEST.B	(A6)+OFLIO3:#BIOAJOUTE ; ajoute ?	JUMP',BS 10$				; PREND =>	CALL	SRCGC		; cherche si titre existe dj ?	JUMP',EQ 15$		; oui => 15$ (modifie-le)	JUMP'	12$10$:				; AJOUTE =>	CALL	SRCGC		; cherche si titre existe dj ?	JUMP,EQ 95$		; oui => 95$12$:	CALL	FREGC		; A4 <-- ^place vide dans OBUGC	JUMP,NE 92$15$:	LOAD.W	D7,#ERTNOT	LOAD.L	A1,A3		; A1 <-- ^titre20$:	LOAD.B	D3,(A3+)	; A3 <-- saute le titre	COMP.B	D3,#':	JUMP',EQ 30$	COMP.B	D3,#';	JUMP,EQ 90$	COMP.B	D3,#CR	JUMP,EQ 90$	COMP.B	D3,#',	JUMP,EQ 90$	JUMP	20$30$:	COMP.B	(A3+),#BOA	JUMP',NE 90$	LOAD.L	A2,A3		; A2 <-- ^fsctt	CALL	SYNGC		; D5 <-- "fst" compactifi	JUMP',NE 90$		; syntaxe pas correcte => 90$	LOAD.W	D7,#ERTNOT	COMP.B	(A3+),#';	JUMP',NE 90$	COMP.B	(A3+),#CR	JUMP',NE 90$	LOAD.L	(A4)+OGCCOD,D5	; OBUGC <-- "fst" compactifi	LOAD.L	A3,#(A4)+OGCTIT50$:	LOAD.B	(A3+),(A1+)	; OBUGC <-- titre	COMP.B	(A1)-1,#':	JUMP,NE	50$	CLR.B	(A3)-1	LOAD.L	A3,#(A4)+OGCNAM60$:	LOAD.B	(A3+),(A2+)	; OBUGC <-- fsctt	COMP.B	(A2)-1,#';	JUMP,NE	60$	CLR.B	(A3)-1	CALL	LODGC		; charge gencar si ncessaire	JUMP',EQ 95$		; ok => 95$90$:	TCLR.B	(A4)+OGCFLG:#BGCUSE ; libre le gencar92$:	TSET.B	(A6)+OFLIO:#BERMGC ; il manque un (des) gencar(s)95$:	RET;--------------\\; IBOACOMGENCAR >;--------------/; Lit une commande de changement de gencar. Si le gencar n'existe pas; (il n'a pas pu tre charg), ignore cette commande !; in	A3.L	^paramtre(s); out	D7.W	erreur; mod	+IBOACOMGENCAR:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 90$		; oui => 90$	CALL	ICLREGLE	; cre rglette si ncessaire	CALL	SRCGC		; cherche si titre d'un gencar ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A4,(A5)+OPDT	COMP.L	A4,(A5)+OPDB	; est-on au dbut du buffer ?	JUMP',NE 30$		; non => 30$				; oui =>	LOAD.L	A3,#(A6)+OSCOM	CALL	DEFCOMMAND	; A3 <-- met commande par dfaut	COMP.B	D4,(A3)+OCOMNOG	; commande "g_Fond" (donc inutile) ?	JUMP',NE 40$		; non => 40$	JUMP'	90$		; oui => 90$30$:	COMP.B	(A4)-1,#FINCOM	; dj commande juste avant ?	JUMP',EQ 50$		; oui => 50$40$:				; non =>	CALL	NILCOMMAND	; cre une commande vierge	LOAD.L	A4,(A5)+OPDT50$:	LOAD.B	(A4)-(1+LGCOM)+OCOMNOG,D4	LOAD.B	(A4)-(1+LGCOM)+OCOMMOD,(A6)+OIOLMOD	LOAD.B	(A6)+OIOLNOG,D4	CALL	NEWCOMMAND	; mj commandes sup/inf;;?	CLR.W	D7		; D7 <-- ok90$:	CLR.W	D7		; D7 <-- toujours ok	RET;------------\\; IBOACOMMODE >;------------/; Lit une commande de changement de mode.; in	D3.B	mode; out	D7.W	erreur; mod	+IBOACOMMODE:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 90$		; oui => 90$	CALL	ICLREGLE	; cre rglette si ncessaire	LOAD.B	D4,(A6)+OIOLMOD	; D4 <-- mode prcdent	COMP.B	D3,#BMODUP	; commande "up" ?	JUMP',NE 20$		; non => 20$	TEST.L	D4:#BMODDOWN	; est-on en bas ?	JUMP',BC 20$		; non => 20$	LOAD.B	D3,#BMODDOWN	; oui => fin d'indice20$:	COMP.B	D3,#BMODDOWN	; commande "down" ?	JUMP',NE 25$		; non => 25$	TEST.L	D4:#BMODUP	; est-on en haut ?	JUMP',BC 25$		; non => 25$	LOAD.B	D3,#BMODUP	; oui => fin d'exposant25$:	TNOT.L	D4:D3		; D4 <-- inverse bit du nouveau mode	LOAD.L	A4,(A5)+OPDT	COMP.L	A4,(A5)+OPDB	JUMP',EQ 40$	COMP.B	(A4)-1,#FINCOM	; dj commande juste avant ?	JUMP',EQ 50$		; oui => 50$40$:				; non =>	CALL	NILCOMMAND	; cre une commande vierge	LOAD.L	A4,(A5)+OPDT50$:	LOAD.B	(A4)-(1+LGCOM)+OCOMMOD,D4	LOAD.B	(A4)-(1+LGCOM)+OCOMNOG,(A6)+OIOLNOG	LOAD.B	(A6)+OIOLMOD,D4	CALL	NEWCOMMAND	; mj commandes sup/inf90$:	CLR.W	D7		; D7 <-- ok	RET;------------\\; IBOASAJEXMT >;------------/; Lit une commande d'espace variable.; in	A3.L	^paramtre(s);	D3.B	mode (0=absolu=new et 1=relatif=old); out	D7.W	erreur; mod	+IBOASAJEXMT:	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	LOAD.B	D0,D3		; D0 <-- absolu/relatif	CALL	ICLREGLE	; cre rglette si ncessaire	CALL	RDNUMX		; D4 <-- largeur de l'espace	JUMP',NE 90$	LOAD.W	D2,D4	TEST.B	D0	JUMP',NE 30$		; relatif => 30$	SUB.W	D2,(A6)+OIOPOSL	; absolu => calcul l'avance relative	JUMP',LO 90$30$:	SET.B	(A6)+OCVAR	; met chasse variable	TEST.B	(A6)+OFLIO:#BITAB	JUMP',BS 50$	CALL	JUSTINSSM	; insre SAJEXM(s)	JUMP'	80$50$:	CALL	JUSTINSST	; insre SAJEXT(s)80$:	ADD.W	(A6)+OIOPOSL,D2	; avance dans la ligne90$:	RET;-----------\\; IBOASAJEXS >;-----------/; Lit une commande d'espace variable.; in	A3.L	^paramtre(s);	D3.B	mode (0=absolu=new et 1=relatif=old); out	D7.W	erreur; mod	+IBOASAJEXS:	TCLR.B	(A6)+OFLIO:#BITAB	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 90$		; oui => 90$	LOAD.B	D0,D3		; D0 <-- absolu/relatif	CALL	ICLREGLE	; cre rglette si ncessaire	CALL	RDNUMX		; D4 <-- largeur de l'espace	JUMP',NE 90$	LOAD.W	D2,D4	TEST.B	D0	JUMP',NE 30$		; relatif => 30$	SUB.W	D2,(A6)+OIOPOSL	; absolu => calcul l'avance relative	JUMP',LO 90$30$:	SET.B	(A6)+OCVAR	; met chasse variable	CALL	JUSTINSSS	; insre SAJEXS(s)	ADD.W	(A6)+OIOPOSL,D2	; avance dans la ligne90$:	RET;---------\\; IOPREGLE >;---------/; Prpare les variables de la prochaine rglette qui sera cre en; prenant la rglette suprieure comme modle.; in	-; out	-; mod	D7.WIOPREGLE:	PUSHM.L	A3,A4	TSET.B	(A6)+OFLIO:#BCREG ; dj rglette en cration ?	JUMP',BS 90$		; oui => 90$				; non =>	LOAD.L	A4,(A5)+OPDT	CALL	UPREGLE		; OUREG <-- rglette suprieure	LOAD.L	A4,#(A6)+OUREG	LOAD.L	A3,#(A6)+OSREG	CALL	COPREGLE	; OSREG <-- OUREG	CLR.W	(A3)+OREGTAB	; OSREG <-- supprime tous les tabulateurs	CLR.B	(A3)+OREGLAB	; OSREG <-- supprime le label90$:	POPM.L	A3,A4	RET;---------\\; ICLREGLE >;---------/; Cre la rglette en fonction des variables mise  jour; depuis le dernier IOPREGLE.; in	-; out	-; mod	D7.WICLREGLE:	PUSHM.L	A3,A4	TCLR.B	(A6)+OFLIO:#BCREG ; rglette en cration ?	JUMP',BC 90$		; non => 90$				; oui =>	CALL	NILREGLE	; cre une rglette vierge	LOAD.L	A3,(A5)+OPDT	LOAD.L	A3,#(A3)-(LGREG+1)	LOAD.L	A4,#(A6)+OSREG	CALL	CHKREGLE	; vrifie si ok en largeur	JUMP',EQ 50$		; si tout est ok => 50$	TSET.B	(A6)+OFLIO:#BIJUST ; il faudra tout re-justifier50$:	CALL	UPDREGLE	; rglette dans buffer <-- OSREG	CALL	NEWREGLE	; mj rglettes sup/inf	CLR.W	(A6)+OIOPOSL	; revient au dbut de la ligne90$:	POPM.L	A3,A4	RET;--------\\; RDNUMX  >;========/; Lit un nombre pour une distance horizontale.; in	A3.L	^nombre prsum; out	A3.L	^plus loin;	D4.W	nombre (+/-);	D7.W	erreur; mod	D3.W, D4.L, D7.W, A3.LRDNUMX:	CALL	RDNUM		; D4 <-- nombre	JUMP',NE 90$	COMP.W	D3,#H'100*"p"+"g"	JUMP',EQ 90$	COMP.W	D3,#H'100*"m"+"m"	JUMP',EQ 50$	COMP.W	D3,#H'100*"p"+" "	JUMP',NE 90$	CONV.LA.WA D4		; D4 <-- .L positif ou ngatif	LOAD.W	D3,#5		; D3 <-- ancien OFACX de l'OKI-84	CALL	DIVD4D3	JUMP'	90$50$:				; [1/10mm] =>	MUL.WA	D4,#1000	LOAD.W	D3,(A6)+OMMX	CALL	DIVD4D3	CONV.LA.WA D4		; D4 <-- .L positif ou ngatif	LOAD.W	D3,(A6)+OFACX	CALL	DIVD4D390$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDNUMY  >;========/; Lit un nombre pour une distance verticale.; in	A3.L	^nombre prsum; out	A3.L	^plus loin;	D4.W	nombre (+/-);	D7.W	erreur; mod	D3.W, D4.L, D7.W, A3.LRDNUMY:	CALL	RDNUM		; D4 <-- nombre	JUMP',NE 90$	COMP.W	D3,#H'100*"p"+"g"	JUMP',EQ 90$	COMP.W	D3,#H'100*"m"+"m"	JUMP',EQ 50$	COMP.W	D3,#H'100*"p"+" "	JUMP',NE 90$	CONV.LA.WA D4		; D4 <-- .L positif ou ngatif	LOAD.W	D3,#2		; D3 <-- ancien OFACY de l'OKI-84	CALL	DIVD4D3	JUMP'	90$50$:				; [1/10mm] =>	MUL.WA	D4,#1000	LOAD.W	D3,(A6)+OMMY	CALL	DIVD4D3	CONV.LA.WA D4		; D4 <-- .L positif ou ngatif	LOAD.W	D3,(A6)+OFACY	CALL	DIVD4D390$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDNUM   >;========/; Lit un nombre dcimal avec une unit quelconque.; in	A3.L	^nombre prsum; out	A3.L	^plus loin;	D4.L	nombre (+/-);	D3.W	unit (2 lettres);	D7.W	erreur; mod	D3.W, D4.L, D7.W, A3.LRDNUM:	PUSHM.L	D0,D1,D2,A4	CLR.W	D1		; D1 <-- nb de dcimales	CLR.W	D2		; D2 <-- positif	COMP.B	(A3),#'-	; signe moins ?	JUMP',NE 05$		; non => 05$	INC.L	A3		; oui =>	INC.W	D2		; D2 <-- ngatif05$:	LOAD.W	D7,#ERTNOT	LOAD.L	A4,A3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A3)		; D3 <-- caractre	COMP.B	D3,#'.	JUMP',EQ 30$	COMP.B	D3,#'0		; est un digit ?	JUMP',LO 40$		; non => 40$	COMP.B	D3,#'9	JUMP',HI 40$	INC.L	A3		; A3 <-- saute le digit	TEST.L	D1:#15		; est-on dans les dcimales ?	JUMP',BC 20$		; non => 20$	INC.B	D1		; oui => une dcimale de plus	COMP.B	D1,#1		; plus d'une dcimale ?	JUMP,HI 10$		; oui => 10$ (ignore)20$:	SUB.B	D3,#'0		; D3 <-- 0..9	SL.L	D4,#1	LOAD.L	D0,D4	SL.L	D4,#2	ADD.L	D4,D0		; D4 <-- pousse d'un digit (*10)	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$30$:	INC.L	A3		; A3 <-- saute le point	TSET.L	D1:#15		; D1 <-- partie dcimale existe	JUMP,BS 95$		; si 2me point => 95$ (erreur)	JUMP	10$40$:	TEST.W	D2		; nombre positif ?	JUMP',EQ 45$		; oui => 45$	NEG.L	D4		; non => prend le complment45$:	COMP.L	A3,A4		; au moins un digit ?	JUMP,EQ 95$		; non => 95$ (erreur)	LOAD.L	A4,A3		; A4 <-- ^dbut unit50$:	LOAD.B	D3,(A3)	COMP.B	D3,#';	JUMP',EQ 60$	COMP.B	D3,#CR	JUMP',EQ 60$	INC.L	A3	COMP.B	D3,#',	JUMP',EQ 60$	COMP.B	D3,#':	JUMP',NE 50$60$:	LOAD.B	D3,(A4+)	; D3 <-- premire lettre de l'unit	COMP.B	D3,#"a"	JUMP',LO 70$	COMP.B	D3,#"z"	JUMP',LS 72$70$:	LOAD.W	D3,#H'100*" "+" "	JUMP'	82$72$:	SL.W	D3,#8	LOAD.B	D3,(A4)		; D3 <-- deuxime lettre de l'unit	COMP.B	D3,#"a"	JUMP',LO 80$	COMP.B	D3,#"z"	JUMP',LS 82$80$:	LOAD.B	D3,#" "82$:	COMP.W	D3,#H'100*"m"+"m"	JUMP',EQ 85$	TEST.L	D1:#15		; "." dans le nombre ?	JUMP',BS 95$		; oui => 95$ (erreur)	JUMP'	90$85$:	TEST.B	D1		; partie dcimale existe ?	JUMP',NE 90$		; oui => 90$	MUL.WA	D4,#10		; non => simule .090$:	CLR.W	D7		; D7 <-- ok95$:	POPM.L	D0,D1,D2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; RDOPEN  >;========/; Ouvre le fichier en entre.; in	D6.W	canal; out	-; mod	-RDOPEN:	LOAD.W	(A6)+OCHIO,D6	; mm. canal	LOAD.W	(A6)+OPTIO,#LTMIO	RET;--------\; RDONE   >;========/; Lit un byte dans le fichier d'entre.; in	-; out	D3.B	byte lu;	D7.W	erreur; mod	D3.L, D7.WRDONE:	PUSHM.L	D4,D6,A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^buffer tampon	COMP.W	(A6)+OPTIO,#LTMIO ; reste qq chose ?	JUMP',LO 50$		; oui => 50$				; non =>	LOAD.L	D4,#LTMIO	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?RDBYTE		; lit tout le buffer	LOAD.W	(A6)+ONBIO,#-1	CLR.W	(A6)+OPTIO	; buffer vide	TEST.W	D7		; lecture ok ?	JUMP',EQ 50$		; oui => 50$	COMP.W	D7,#EROUTF	; fin du fichier ?	JUMP',NE 90$		; non => 90$	CLR.W	D7		; D7 <-- ok pour l'instant	LOAD.W	(A6)+ONBIO,D4	; mm. lg dernire tranche50$:	TEST.W	(A6)+ONBIO	; reste qq chose ?	JUMP',NE 60$		; oui => 60$	LOAD.W	D7,#EROUTF	; D7 <-- fin du fichier	JUMP'	90$60$:	LOAD.W	D4,(A6)+OPTIO	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- un byte du buffer	INC.W	(A6)+OPTIO	; avance "pointeur"	DEC.W	(A6)+ONBIO	; diminue reste90$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; RDCLOSE >;========/; Ferme le fichier en entre.; in	-; out	D7.W	erreur; mod	D7.WRDCLOSE:	PUSH.L	D6	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?CLOSE		; ferme le fichier	POP.L	D6	TEST.W	D7		; retour EQ/NE	RET	.END