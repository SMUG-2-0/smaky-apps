	.SBTTL	TEXTCALCUL;--------\\; CIINFO  >;========/; Dtecte dans quelle icne des infos est la souris.; in	D4.L	coordonne de la souris;	A4.L	^liste des icnes; out	D3.W	code de l'icne slectionne;	D7.W	erreur; mod	D3.L, D7.WCIINFO:	PUSHM.L	D4..D6	CALL	IDINFO		; D5 <-- icne	JUMP,NE 90$	LOAD.W	D3,D5	TCLR.L	D3:#7		; n'attend pas relch ?	JUMP,BS 90$		; oui => 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit une trame pleine	CALL	IIINFO		; allume l'icne	LOAD.W	D6,D5		; D6 <-- icne o est la souris20$:	LIB	?GETKEY		; attend touche/souris ...	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE 50$		; non => 50$				; oui =>	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	IDINFO		; D5 <-- icne o est la souris	TEST.L	D5:#7		; icne  ne pas attendre relch ?	JUMP',BC 30$		; non => 30$	LOAD.W	D5,#-1		; oui => ne pas slectionner30$:	COMP.W	D5,D6		; est-on dans la mme icne ?	JUMP,EQ 20$		; oui => 20$				; non =>	CALL	IIINFO		; allume nouvelle icne	EX.L	D5,D6	CALL	IIINFO		; teint ancienne icne	JUMP	20$50$:	LOAD.W	D5,D6	CALL	IIINFO		; teint l'icne	LOAD.W	D7,#ERTNOT	COMP.W	D5,#-1	JUMP',EQ 90$	LOAD.W	D3,D5		; D3 <-- code de l'icne	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4..D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; IDINFO  >;--------/; Dtecte dans quelle icne est la souris.; in	A4.L	^liste des icnes;	D4.L	coordonne de la souris (y;x); out	D5.W	code de l'icne (-1 si ailleurs);	D7.W	erreur; mod	D5.W, D7.WIDINFO:	PUSH.L	D4	LOAD.W	D5,#-1		; D5 <-- icne "ailleurs"	CALL	WDOMOUSE	; souris dans la swdo ?	JUMP',NE 90$		; non => 90$	LOAD.W	D7,#ERTNOT	; D7 <-- on est pas dans une icne	SWAP.W	D4	COMP.W	D4,#GCICY	JUMP',HS 90$	CLR.W	D4	SWAP.W	D4	DIV.WU	D4,#(GCICX/2)+GCICX	COMP.B	D4,(A4)+0	JUMP',HS 90$	SWAP.W	D4	COMP.W	D4,#GCICX/2	JUMP',LO 90$	SWAP.W	D4	CLR.W	D5	LOAD.B	D5,(A4)+(D4.W)+1 ; D5 <-- code de l'icne	CLR.W	D7		; D7 <-- trouv90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IIINFO  >;--------/; Inverse une icne.; in	D5.W	code de l'icne;	A4.L	^liste des icnes; out	-; mod	D7.WIIINFO:	PUSHM.L	D2..D4,A4	COMP.W	D5,#-1		; icne "ailleurs" ?	JUMP',EQ 90$		; oui => 90$	INC.L	A4		; A4 <-- saute "n"	LOAD.W	D3,#GCICX/210$:	COMP.B	D5,(A4+)	JUMP',EQ 15$	ADD.W	D3,#GCICX+(GCICX/2)	JUMP	10$15$:	INC.W	D3		; D3 <-- <xx>	SWAP.W	D3	LOAD.W	D3,#1		; D3 <-- <yy>	SWAP.W	D3	LOAD.L	D4,#H'10000*(GCICY-2)+(GCICX-2)	LOAD.W	D2,#INVDOT	; D2 <-- mode	LIB	?DRMATRIX	; allume l'icne90$:	POPM.L	D2..D4,A4	RETTIICALCUL:	.B	2	.B	ICOEGAL	.B	ICOANULTIICOPY:	.B	5	.B	ICOCOPK	.B	ICOCOPM	.B	ICOCOPD	.B	ICOCOPX	.B	ICOCOPZ!2^7	.EVEN;--------\\; GETNUM  >;========/; Lit un nombre dcimal dans un buffer.; in	A4.L	^nombre prsum dans un buffer;	A5.L	^description du buffer; out	A4.L	^plus loin;	D3D4.L	nombre;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.LGETNUM:	PUSHM.L	D1,D2,A2,A3	LOAD.L	A2,#(A6)+OBUTEMP	CLR.W	D1		; D1 <-- nb de dcimales	CLR.W	D2		; D2 <-- positif02$:	CALL	_TNVISU		; D3 <-- premier caractre	JUMP',NE 05$	COMP.B	D3,#COMMAND	JUMP,EQ 02$	COMP.B	D3,#'+		; signe plus ?	JUMP',EQ 05$		; oui => 05$	COMP.B	D3,#'-		; signe moins ?	JUMP',NE 04$		; non => 04$	INC.W	D2		; D2 <-- ngatif	LOAD.B	(A2+),D3	JUMP'	05$04$:	CALL	_TPVISU		; recule caractre avanc en trop05$:	LOAD.L	A3,A4	CLR.L	D4		; D4 <-- futur nombre10$:	CALL	_TNVISU		; D3 <-- caractre suivant	JUMP,NE 90$	COMP.B	D3,#COMMAND	JUMP,EQ 10$	COMP.B	D3,#''		; accepte 5'125'000	JUMP,EQ 10$	COMP.B	D3,#'.	JUMP',EQ 30$	COMP.B	D3,#',	JUMP',EQ 30$	COMP.B	D3,#'-	JUMP',NE 15$	LOAD.B	D3,#'0		; accepte 123.--15$:	COMP.B	D3,#'0		; est un digit ?	JUMP',LO 40$		; non => 40$	COMP.B	D3,#'9	JUMP',HI 40$	TEST.L	D1:#15		; est-on dans les dcimales ?	JUMP',BC 20$		; non => 20$	INC.B	D1		; oui => une dcimale de plus	COMP.B	D1,#2		; plus de 2 dcimales ?	JUMP,HI 10$		; oui => 10$ (ignore)20$:	LOAD.B	(A2+),D3	JUMP	10$30$:	LOAD.W	D7,#ERTNOT	TSET.L	D1:#15		; D1 <-- partie dcimale existe	JUMP,BS 90$		; si 2me point => 90$ (erreur)	LOAD.B	(A2+),D3	JUMP	10$40$:	CLR.B	(A2)	CALL	_TPVISU	LOAD.W	D7,#ERTNOT	COMP.L	A3,A4		; au moins un digit ?	JUMP',EQ 90$		; non => 90$ (erreur)	LOAD.L	A3,#(A6)+OBUTEMP	PUSH.L	A5	LOAD.L	A5,(A6)+OCHMATI	; A5 <-- canal interne de math64	MATH64_	ASC_FP		; D3D4 <-- nombre	POP.L	A5	JUMP',VS 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D2,A2,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PUTNUM  >;========/; Ecrit un nombre dcimal dans un buffer.; in	D3D4.L	nombre;	A4.L	^buffer; out	A4.L	^plus loin;	D7.W	erreur; mod	D7.W, A4.LPUTNUM:	PUSHM.L	D0,A3	LOAD.L	A3,A4	LOAD.L	D0,#2^BM64COMM!2^BM64POW	LOAD.B	D0,#20		; D0 <-- nb digits max	SWAP.W	D0	LOAD.B	D0,#-2		; D0 <-- nb dcimales	SWAP.W	D0	PUSH.L	A5	LOAD.L	A5,(A6)+OCHMATI	; A5 <-- canal interne de math64	MATH64_	FP_ASC	POP.L	A540$:	TEST.B	(A4+)	JUMP,NE 40$	DEC.L	A4	POPM.L	D0,A3	TEST.W	D7		; retour EQ/NE	RET	.END