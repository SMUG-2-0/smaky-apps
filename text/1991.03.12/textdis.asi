	.SBTTL	TEXTDIS;----------\\; DISDAFCAR >;==========/; Affiche un caractre avec le gnrateur de caractres actuellement; utilis par la fentre.; in	D3.B	caractre (2^7=1 si vido inverse);	D2.W	mode; out	-; mod	D7.WDISDAFCAR:	PUSHM.L	D0..D5,A0,A2..A4	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.L	A3,(A2)+ODFPGC	; A3 <-- ^gencar	CLR.W	D0	LOAD.B	D0,D3		; D0 <-- code du caractre	LOAD.B	D1,D2		; D1 <-- mode	CLR.B	D2		; D2 <-- pas d'inversion	TCLR.L	D0:#7		; caractre  inverser ?	JUMP',BC 20$		; non => 20$	NOT.B	D2		; D2 <-- opration d'inversion20$:	COMP.B	D0,(A3)+OGCLCA	; code caractre trop grand ?	JUMP',HI 90$		; oui => 90$	SUB.B	D0,(A3)+OGCFCA	; code caractre trop petit ?	JUMP',LO 90$		; oui => 90$	LOAD.L	D4,(A2)+ODFPY	; D4 <-- position curseur typo	SWAP.W	D4	ADD.W	D4,(A3)+OGCBLI	; D4 <-- en bas du caractre	SUB.W	D4,(A3)+OGCMHD	; D4 <-- en haut du caractre	SWAP.W	D4	LOAD.L	A4,#(A3)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D3,(A3)+OGCMHD	; D3 <-- hauteur caractre	SWAP.W	D3	CLR.W	D3	LOAD.B	D3,(A4)+(D0.W)	; D3 <-- largeur caractre	ADD.W	(A2)+ODFPX,D3	; avance le curseur typographique	CLR.W	D5	LOAD.B	D5,(A3)+OGCLCA	SUB.B	D5,(A3)+OGCFCA	INC.B	D5		; D5 <-- nb caractres dans gencar	ADD.W	A4,D5		; A4 <-- saute largeurs	ADD.W	A4,D5		; A4 <-- saute h1	ADD.W	A4,D5		; A4 <-- saute h2	MUL.WU	D0,(A3)+OGCMSB	ADD.L	A4,D0		; A4 <-- ^matrice	CLR.W	D5	LOAD.B	D5,(A3)+OGCMWB	; D5 <-- largeur en bytes	LOAD.L	A0,(A6)+OADMATR	CALL	(A0)		; appel de GRA_MATRIX90$:	POPM.L	D0..D5,A0,A2..A4	RET;---------\\; DISAFCAR >;=========/; Affiche un caractre avec le gnrateur de caractres contenu; dans OVCOM (selon NVISU/PVISU).; in	D3.B	caractre;	D2.W	mode;	D0.W	lg  sauter au dbut (zro si tout); out	-; mod	D7.WDISAFCAR:	PUSHM.L	D0..D6,A0,A2..A4	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.W	D6,D0		; D6 <-- lg  sauter au dbut	CLR.W	D4	LOAD.B	D4,(A5)+OVCOM+OCOMNOG ; D4 <-- no du gencar	MUL.WU	D4,#LGGC	LOAD.L	A3,#(A6)+OBUGC	ADD.L	A3,D4		; A3 <-- ^dans OBUGC	LOAD.L	A3,(A3)+OGCPT	; A3 <-- ^gencar	CLR.W	D0	LOAD.B	D0,D3		; D0 <-- code du caractre	LOAD.B	D1,D2		; D1 <-- mode;;?	TSET.L	D1:#BNTSDOT	; D1 <-- mode rapide, sans test !	CLR.B	D2		; D2 <-- pas d'inversion;;?	TCLR.L	D0:#7		; caractre  inverser ?;;?	JUMP',BC 20$		; non => 20$;;?	NOT.B	D2		; D2 <-- opration d'inversion;;?20$:	COMP.B	D0,(A3)+OGCLCA	; code caractre trop grand ?	JUMP,HI 90$		; oui => 90$	SUB.B	D0,(A3)+OGCFCA	; code caractre trop petit ?	JUMP,LO 90$		; oui => 90$	LOAD.L	D4,(A2)+ODFPY	; D4 <-- position curseur typo	SWAP.W	D4	LOAD.W	D3,(A3)+OGCMHD	SUB.W	D3,(A3)+OGCBLI	; D3 <-- hauteur  remonter	SUB.W	D4,D3		; D4 <-- en haut du caractre	TEST.B	(A5)+OVCOM+OCOMMOD:#BMODDOWN	JUMP',BS 30$	TEST.B	(A5)+OVCOM+OCOMMOD:#BMODUP	JUMP',BC 35$				; exposant =>	SR.W	D3,#1		; D3 <-- hauteur  monter	SUB.W	D4,D3		; D4 <-- monter encore un peu	JUMP'	35$30$:				; indice =>	SR.W	D3,#1		; D3 <-- hauteur  redescendre	ADD.W	D4,D3		; D4 <-- descend un peu35$:	SWAP.W	D4	LOAD.L	A4,#(A3)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D3,(A3)+OGCMHD	; D3 <-- hauteur caractre	SWAP.W	D3	CLR.W	D3	LOAD.B	D3,(A4)+(D0.W)	; D3 <-- largeur caractre	SUB.W	D3,D6		; D3 <-- enlve lg  sauter au dbut	ADD.W	(A2)+ODFPX,D3	; avance le curseur typographique	CALL	DISCLEARUP	; efface v. en haut du caractre	CALL	DISCLEARDOWN	; efface v. en bas du caractre	CLR.W	D5	LOAD.B	D5,(A3)+OGCLCA	SUB.B	D5,(A3)+OGCFCA	INC.B	D5		; D5 <-- nb caractres dans gencar	ADD.W	A4,D5		; A4 <-- saute largeurs	ADD.W	A4,D5		; A4 <-- saute h1	ADD.W	A4,D5		; A4 <-- saute h2	MUL.WU	D0,(A3)+OGCMSB	ADD.L	A4,D0		; A4 <-- ^matrice	CLR.W	D5	LOAD.B	D5,(A3)+OGCMWB	; D5 <-- largeur en bytes	TEST.W	D6		; dpasse  gauche ?	JUMP',NE 70$		; oui => 70$	LOAD.W	D0,(A2)+ODFPX	; D0 <-- position curseur typo en X	COMP.W	D0,(A2)+ODFFDX	; dpasse  droite ?	JUMP',HS 70$		; oui => 70$	LOAD.L	A0,(A6)+OADMATR	CALL	(A0)		; appel de GRA_MATRIX	JUMP'	80$70$:				; peint une partie du caractre =>	LOAD.W	D0,(A2)+ODFFDX	SUB.W	D0,D4;;?	DEC.W	D0		; D0 <-- largeur maximale	JUMP',LE 90$	COMP.W	D3,D0		; dpasse  droite ?	JUMP',LS 72$		; non => 72$	LOAD.W	D3,D0		; oui => dessine le maximum72$:	CALL	DISCLEAR	; efface la surface	PUSHM.L	D3,D4,A3	LOAD.L	A3,A4		; A3 <-- ^matrice	LOAD.L	D2,D3		; D2 <-- dy;dx	CLR.L	D3		; D3 <-- y source	LOAD.W	D3,D6		; D3 <-- x source	LOAD.L	A4,#0		; A4 <-- ^destination	CLR.W	D6		; D6 <-- Iy destination	LOAD.W	D1,#SETDOT	; D1 <-- mode	CALL	DISRASTEROP	; allume les points  un	POPM.L	D3,D4,A380$:	CALL	DISAFSOUL	; souligne le caractre si ncessaire90$:	POPM.L	D0..D6,A0,A2..A4	RET;----------\\; DISAFSOUL >;----------/; Souligne un caractre si ncessaire.; in	D4.L	coordonne (y;x) coin sup/gauche caractre;	D3.L	dimensions (dy;dx) du caractre;	A3.L	^header gencar; out	-; mod	D2.W, D3.L, D4.L, D7.WDISAFSOUL:	TEST.B	(A5)+OVCOM+OCOMMOD:#BMODSOUL	JUMP',BC 90$				; si soulign =>	SWAP.W	D4	ADD.W	D4,(A3)+OGCMHD	; D4 <-- en bas du caractre	SUB.W	D4,(A3)+OGCBLI	; D4 <-- ligne de base du caractre	ADD.W	D4,#2		; D4 <-- juste en dessous	SWAP.W	D4	AND.L	D3,#H'FFFF	; D3 <-- met dy  zro	LOAD.W	D2,#SETDOT	CALL	DISLINE		; souligne le caractre90$:	RET;-----------\\; DISCLEARUP >;-----------/; Efface une zone en haut du caractre si ncessaire.; Si la zone a la mme hauteur que la prcdente, elle est; ajoute  la prcdente pour tout effacer en bloc.; in	D4.L	position sup/gauche caractre (x;y);	D3.L	dimensions (dx;dy);	A2.L	^status; out	-; mod	D7.WDISCLEARUP:	PUSHM.L	D2..D4	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,(A2)+ODFPY	; D2 <-- position ligne de base	SUB.W	D2,(A6)+OT1YM	; D2 <-- haut de la ligne	SUB.W	D2,D4	NEG.W	D2		; D2 <-- hauteur  effacer en haut	SUB.W	D4,D2	LOAD.W	D3,D2	SWAP.W	D3	SWAP.W	D4	COMP.L	D4,(A6)+OMZHP	; mme dbut (y;x) ?	JUMP',NE 50$		; non => 50$	COMP.W	D2,(A6)+OMZHD+0	; mme hauteur ?	JUMP',NE 50$		; non => 50$				; oui =>	ADD.W	(A6)+OMZHP+2,D3	; pousse fin X vers la droite	ADD.W	(A6)+OMZHD+2,D3	; augmente la largeur	JUMP'	90$50$:	PUSHM.L	D3,D4	LOAD.L	D4,(A6)+OMZHP	COMP.L	D4,#-1		; premier passage ?	JUMP',EQ 60$		; oui => 60$	LOAD.L	D3,(A6)+OMZHD	SUB.W	D4,D3	CALL	DISCLEAR	; efface la zone prcdente60$:	POPM.L	D3,D4	ADD.W	D4,D3	LOAD.L	(A6)+OMZHP,D4	LOAD.L	(A6)+OMZHD,D390$:	POPM.L	D2..D4	RET;-------------\\; DISCLEARDOWN >;-------------/; Efface une zone en bas du caractre si ncessaire.; Si la zone a la mme hauteur que la prcdente, elle est; ajoute  la prcdente pour tout effacer en bloc.; in	D4.L	position sup/gauche caractre (x;y);	D3.L	dimensions (dx;dy);	A2.L	^status; out	-; mod	D7.WDISCLEARDOWN:	PUSHM.L	D2..D4	SWAP.W	D4	SWAP.W	D3	ADD.W	D4,D3		; D4 <-- position bas du caractre	LOAD.W	D2,(A2)+ODFPY	; D2 <-- position ligne de base	ADD.W	D2,(A6)+OT2YM	; D2 <-- bas de la ligne	SUB.W	D2,D4		; D2 <-- hauteur  effacer en bas	LOAD.W	D3,D2	SWAP.W	D3	SWAP.W	D4	COMP.L	D4,(A6)+OMZBP	; mme dbut (y;x) ?	JUMP',NE 50$		; non => 50$	COMP.W	D2,(A6)+OMZBD+0	; mme hauteur ?	JUMP',NE 50$		; non => 50$				; oui =>	ADD.W	(A6)+OMZBP+2,D3	; pousse fin X vers la droite	ADD.W	(A6)+OMZBD+2,D3	; augmente la largeur	JUMP'	90$50$:	PUSHM.L	D3,D4	LOAD.L	D4,(A6)+OMZBP	COMP.L	D4,#-1		; premier passage ?	JUMP',EQ 60$		; oui => 60$	LOAD.L	D3,(A6)+OMZBD	SUB.W	D4,D3	CALL	DISCLEAR	; efface la zone prcdente60$:	POPM.L	D3,D4	ADD.W	D4,D3	LOAD.L	(A6)+OMZBP,D4	LOAD.L	(A6)+OMZBD,D390$:	POPM.L	D2..D4	RET;----------\\; DISPSPACE >;==========/; Affiche un espace d'une largeur quelconque.; Les cas suivants sont traits :;	si D3=SAJEXS et BFASAJ=1	--> rectangle blanc;	si D3=SAJEXT et BFATAB=1	--> flche (tabulateur);	autrement			--> efface la surface; in	D4.W	largeur de l'espace;	D3.B	code de l'espace SAJEX(M/T/S); out	-; mod	D7.WDISPSPACE:	PUSHM.L	D0..D4,A2,A3	LOAD.B	D0,D3		; D0 <-- code	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	CLR.W	D3	LOAD.B	D3,(A5)+OVCOM+OCOMNOG ; D3 <-- no du gencar	MUL.WU	D3,#LGGC	LOAD.L	A3,#(A6)+OBUGC	ADD.L	A3,D3		; A3 <-- ^dans OBUGC	LOAD.L	A3,(A3)+OGCPT	; A3 <-- ^gencar	LOAD.W	D3,D4		; D3 <-- largeur	SWAP.W	D3	LOAD.W	D3,(A3)+OGCMHD	; D3 <-- hauteur	LOAD.L	D4,(A2)+ODFPY	; D4 <-- position curseur typo	SWAP.W	D4	LOAD.W	D2,(A3)+OGCMHD	SUB.W	D2,(A3)+OGCBLI	; D2 <-- hauteur  remonter	SUB.W	D4,D2		; D4 <-- en haut du caractre	TEST.B	(A5)+OVCOM+OCOMMOD:#BMODDOWN	JUMP',BS 30$	TEST.B	(A5)+OVCOM+OCOMMOD:#BMODUP	JUMP',BC 35$				; exposant =>	SR.W	D2,#1		; D2 <-- hauteur  monter	SUB.W	D4,D2		; D4 <-- monter encore un peu	JUMP'	35$30$:				; indice =>	SR.W	D2,#1		; D2 <-- hauteur  redescendre	ADD.W	D4,D2		; D4 <-- descend un peu35$:; Vrifie si la surface  effacer dpasse en haut pour rsoudre le cas; d'un SAJEXM en dbut de ligne ayant un caractre plus haut que tout; le reste de la ligne (et qui n'est pas compt par SRCHTL volontairement).	LOAD.W	D2,(A2)+ODFPY	SUB.W	D2,(A6)+OT1YM	; D2 <-- hauteur  ne pas dpasser	COMP.W	D4,D2		; trop haut ?	JUMP',HS 40$		; non => 40$	SUB.W	D2,D4	ADD.W	D4,D2		; D4 <-- descend un peu Y	SUB.W	D3,D2		; D3 <-- diminue un peu dY40$:	SWAP.W	D4	SWAP.W	D3	CALL	DISCLEARUP	; efface v. en haut de l'espace	CALL	DISCLEARDOWN	; efface v. en bas de l'espace	COMP.B	D0,#SAJEXT	; tabulateur ?	JUMP',EQ 75$		; oui => 75$	TEST.B	(A6)+OFANION+3:#BFASAJ	JUMP',BC 70$	COMP.B	D0,#SAJEXS	JUMP',NE 70$	LOAD.W	D2,#SETDOT	; D2 <-- mode	LOAD.L	D0,#-1		; D0 <-- trame	LOAD.L	D1,D0		; D1 <-- trame	CALL	DISTRAME	; dessine une trame pleine	JUMP'	80$70$:	CALL	DISCLEAR	; efface l'espace	JUMP'	80$75$:				; tabulateur =>	CALL	DISCLEAR	; efface l'espace	TEST.B	(A6)+OFANION+3:#BFATAB	JUMP',BC 80$	CALL	DISAFTAB	; affiche le tabulateur80$:	ADD.W	(A2)+ODFPX,D3	; avance le curseur typo	CALL	DISAFSOUL	; souligne l'espace si ncessaire	POPM.L	D0..D4,A2,A3	RET;---------\\; DISAFTAB >;---------/; Affiche une flche horizontale pour montrer un tabuateur.; in	A2.L	^status fentre;	D4.L	origine rectangle (y;x);	D3.L	dimensions rectangle (dy;dx); out	-; mod	D7.WDISAFTAB:	PUSHM.L	D1..D4	PUSH.B	(A2)+ODFTTM	PUSH.B	(A2)+ODFTTS				; <maptt>	LOAD.B	(A2)+ODFTTM,#B'01010101	LOAD.B	(A2)+ODFTTS,#1	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D3		; D1 <-- hauteur	SR.W	D1,#1		; D1 <-- 1/2 hauteur	ADD.W	D4,D1	CLR.W	D3		; D3 <-- dy	SWAP.W	D4	SWAP.W	D3	DEC.W	D3		; D3 <-- dx-1	LOAD.W	D2,(A2)+ODFFDX	SUB.W	D2,D4		; D2 <-- longueur maximale	JUMP',LO 90$	COMP.W	D3,D2		; ligne trop longue ?	JUMP',LS 20$		; non => 20$				; oui =>	LOAD.W	D3,D2		; D3 <-- dx maximum	LOAD.W	D2,#SETDOT!TTTDOT ; D2 <-- mode (traitill)	CALL	DISLINE		; dessine ligne horizontale	JUMP'	90$		; ne met pas la flche au bout20$:	LOAD.W	D2,#SETDOT!TTTDOT ; D2 <-- mode (traitill)	CALL	DISLINE		; dessine ligne horizontale	SR.W	D1,#1		; D1 <-- 1/4 hauteur	NEG.W	D1	LOAD.W	D3,D1		; D3 <-- dy	SWAP.W	D3	LOAD.W	D3,D1		; D3 <-- dx	PUSH.L	D4	LOAD.W	D2,#SETDOT	; D2 <-- mode (trait plein)	CALL	DISLINE		; dessine oblique suprieure	POP.L	D4	SWAP.W	D3	NEG.W	D3		; D3 <-- -dy	SWAP.W	D3	CALL	DISLINE		; dessine oblique infrieure90$:	POP.B	(A2)+ODFTTS	POP.B	(A2)+ODFTTM	POPM.L	D1..D4	RET;--------\\; DISEFLI >;========/; Efface la fin de la ligne.; in	-; out	-; mod	D7.WDISEFLI:	PUSHM.L	D3,D4,A2	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.L	D4,(A2)+ODFPY	; D4 <-- position curseur typo	SWAP.W	D4	SUB.W	D4,(A6)+OT1YM	SWAP.W	D4	LOAD.W	D3,(A6)+OT1YM	ADD.W	D3,(A6)+OT2YM	; D3 <-- hauteur	SWAP.W	D3	LOAD.W	D3,(A2)+ODFFDX	; D3 <-- largeur (sous-)fentre	SUB.W	D3,D4		; D3 <-- largeur  effacer	JUMP',LE 90$	CALL	DISCLEAR	; efface la fin de la ligne90$:	POPM.L	D3,D4,A2	RET;---------\\; DISIEFLI >;=========/; Efface la fin de la ligne en mode inverse (pour les infos).; in	-; out	-; mod	D7.WDISIEFLI:	PUSHM.L	D2..D4,A2	LIB	?FLUSH		; vide si mode ?BUCAR	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit une trame pleine	LOAD.L	D3,(A2)+ODFPY	SWAP.W	D3	SUB.W	D3,(A2)+ODFC1Y	; D3 <-- <yy>	SWAP.W	D3	SUB.W	D3,(A2)+ODFC1X	; D3 <-- <xx>	LOAD.W	D4,(A2)+ODFC1Y	ADD.W	D4,(A2)+ODFC2Y	; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,(A2)+ODFDX	SUB.W	D4,D3		; D4 <-- <dxx>	JUMP',LE 90$	LOAD.W	D2,#SETDOT	; D2 <-- mode	LIB	?DRMATRIX90$:	POPM.L	D2..D4,A2	RET;----------\\; DISTYPOAX >;==========/; Positionne le curseur en X.; in	D4.W	position en X; out	-; mod	D7.WDISTYPOAX:	PUSH.L	A2	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.W	(A2)+ODFPX,D4	POP.L	A2	RET;----------\\; DISTYPOAY >;==========/; Positionne le curseur en Y.; in	D4.W	position en Y; out	-; mod	D7.WDISTYPOAY:	PUSH.L	A2	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.W	(A2)+ODFPY,D4	POP.L	A2	RET;-----------\\; DISSETCURS >;===========/; Positionne le curseur.; in	D3.L	position (y;x); out	-; mod	D7.WDISSETCURS:	PUSH.L	A2	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.L	(A2)+ODFPY,D3	POP.L	A2	RET;-----------\\; DISGETCURS >;===========/; Donne la position du curseur.; in	-; out	D3.L	position (y;x); mod	D3.L, D7.WDISGETCURS:	PUSH.L	A2	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.L	D3,(A2)+ODFPY	; D3 <-- position	POP.L	A2	RET;--------\; DISRECT >;========/; Dessine un rectangle quelconque.; in	D4.L	origine (y;x);	D3.L	dimensions (dy;dx);	D2.W	mode; out	D7.W	erreur; mod	D7.WDISRECT:	PUSHM.L	D3..D5	LOAD.L	D5,D3		; D5 <-- dimensions dy;dx	AND.L	D3,#H'FFFF	CALL	DISLINE		; trace ligne suprieure	LOAD.L	D3,D5	CLR.W	D3	CALL	DISLINE		; trace ligne de droite	LOAD.L	D3,D5	AND.L	D3,#H'FFFF	NEG.W	D3	CALL	DISLINE		; trace ligne infrieure	LOAD.L	D3,D5	SWAP.W	D3	NEG.W	D3	SWAP.W	D3	CLR.W	D3	CALL	DISLINE		; trace ligne de gauche	POPM.L	D3..D5	RET;--------\\; DISLINE >;========/; Dessine une ligne droite.; in	D4.L	origine (y;x);	D3.L	longueur (dy;dx);	D2.W	mode; out	D4.L	arrive (y;x); mod	D4.L, D7.WDISLINE:	PUSHM.L	D1,A0,A2	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.W	D1,D2		; D1 <-- mode	LOAD.L	A0,(A6)+OADLINE	CALL	(A0)		; appel de GRA_LINE	ADD.W	D4,D3		; D4 <-- point d'arrive en X	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3		; D4 <-- point d'arrive en Y	SWAP.W	D4	SWAP.W	D3	POPM.L	D1,A0,A2	RET;----------\\; DISCIRCLE >;==========/; Dessine un cercle.; in	D4.L	origine (y;x);	D3.W	rayon (r);	D2.W	mode; out	-; mod	D7.WDISCIRCLE:	PUSHM.L	D1,D2,A0,A2	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.W	D1,D2		; D1 <-- mode	LOAD.B	D2,#B'11111111	; D2 <-- arcs	LOAD.L	A0,(A6)+OADCIRC	CALL	(A0)		; appel de GRA_CIRCLE	POPM.L	D1,D2,A0,A2	RET;--------\\; DISDOT  >;========/; Dessine un point.; in	D4.L	coordonne (y;x);	D2.W	mode; out	-; mod	D7.WDISDOT:	PUSHM.L	D1,A0,A2	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.W	D1,D2		; D1 <-- mode	LOAD.L	A0,(A6)+OADDOT	CALL	(A0)		; appel de GRA_DOT	POPM.L	D1,A0,A2	RET;---------\\; DISINV   >;=========/; Inverse une zone rectangulaire.; in	D4.L	dbut (y;x);	D3.L	dimensions (dy;dx); out	-; mod	D7.WDISINV:	PUSHM.L	D1,D3,A0,A2	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.W	D1,D4	ADD.W	D1,D3	COMP.W	D1,(A2)+ODFFDX	; dpasse  droite ?	JUMP',LO 40$		; non => 40$	LOAD.W	D3,(A2)+ODFFDX	; oui =>	SUB.W	D3,D4		; D3 <-- maximum possible;;?	DEC.W	D340$:	TEST.W	D3		; largeur nulle ou ngative ?	JUMP',LE 90$		; oui => 90$	SWAP.W	D3	TEST.W	D3		; hauteur nulle ou ngative ?	JUMP',LE 90$		; oui => 90$	SWAP.W	D3	LOAD.L	A0,(A6)+OADINV	CALL	(A0)		; appel de GRA_INV90$:	POPM.L	D1,D3,A0,A2	RET;---------\\; DISCLEAR >;=========/; Efface une zone rectangulaire.; in	D4.L	dbut (y;x);	D3.L	dimensions (dy;dx); out	-; mod	D7.WDISCLEAR:	PUSHM.L	D1,D3,A0,A2	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.W	D1,D4	ADD.W	D1,D3	COMP.W	D1,(A2)+ODFFDX	; dpasse  droite ?	JUMP',LO 40$		; non => 40$	LOAD.W	D3,(A2)+ODFFDX	; oui =>	SUB.W	D3,D4		; D3 <-- maximum possible;;?	DEC.W	D340$:	TEST.W	D3		; largeur nulle ou ngative ?	JUMP',LE 90$		; oui => 90$	SWAP.W	D3	TEST.W	D3		; hauteur nulle ou ngative ?	JUMP',LE 90$		; oui => 90$	SWAP.W	D3	LOAD.L	A0,(A6)+OADCLEA	CALL	(A0)		; appel de GRA_CLEAR90$:	POPM.L	D1,D3,A0,A2	RET;---------\\; DISTRAME >;=========/; Dessine une zone rectangulaire trame.; in	D4.L	dbut (y;x);	D3.L	dimensions (dy;dx);	D2.W	mode;	D0,1.L	trame; out	-; mod	D7.WDISTRAME:	PUSHM.L	D1,D3,A0,A2,A4	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.L	A4,#(A2)+ODFTRA	; A4 <-- ^trame	LOAD.L	(A4)+0,D0	LOAD.L	(A4)+4,D1	LOAD.W	D1,D4	ADD.W	D1,D3	COMP.W	D1,(A2)+ODFFDX	; dpasse  droite ?	JUMP',LO 40$		; non => 40$	LOAD.W	D3,(A2)+ODFFDX	; oui =>	SUB.W	D3,D4		; D3 <-- maximum possible;;?	DEC.W	D340$:	TEST.W	D3		; largeur nulle ou ngative ?	JUMP',LE 90$		; oui => 90$	SWAP.W	D3	TEST.W	D3		; hauteur nulle ou ngative ?	JUMP',LE 90$		; oui => 90$	SWAP.W	D3	LOAD.W	D1,D2		; D1 <-- mode	LOAD.L	A0,(A6)+OADTRAM	CALL	(A0)		; appel de GRA_TRAME90$:	POPM.L	D1,D3,A0,A2,A4	RET;------------\\; DISRASTEROP >;============/; Utilise le raster-op.; in	D3.L	yy/xx source;	A3.L	^source;	D5.W	ii source;	D4.L	yy/xx destination;	A4.L	^destination;	D6.W	ii destination;	D2.L	dyy/dxx;	D1.W	mode; out	-; mod	D7.WDISRASTEROP:	PUSHM.L	D0,D2,A0,A2	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.W	D0,(A2)+ODFFDX	SUB.W	D0,D4		; D0 <-- largeur maximale	JUMP',LS 90$;;?	DEC.W	D0;;?	JUMP',EQ 90$	COMP.W	D2,D0		; trop large ?	JUMP',LO 50$		; non => 50$	LOAD.W	D2,D0		; oui => met le maximum possible50$:	TEST.W	D2		; largeur nulle ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	A0,(A6)+OADRAST	CALL	(A0)		; appel de GRA_RASTER90$:	POPM.L	D0,D2,A0,A2	RET;------------\\; DISROLLDOWN >;============/; Dcale l'cran de qq points contre le bas.; in	D4.W	nombre de points; out	-; mod	D7.WDISROLLDOWN:	PUSHM.L	A0,A2	CALL	DISCCMO		; enlve la souris	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.L	A0,(A6)+OADROLD	CALL	(A0)		; appel de GRA_ROLLDOWN	POPM.L	A0,A2	RET;----------\\; DISROLLUP >;==========/; Dcale l'cran de qq points contre le haut.; in	D4.W	nombre de points; out	-; mod	D7.WDISROLLUP:	PUSHM.L	A0,A2	CALL	DISCCMO		; enlve la souris	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.L	A0,(A6)+OADROLU	CALL	(A0)		; appel de GRA_ROLLUP	POPM.L	A0,A2	RET;---------\; ITLMOUSE >;=========/; Test si une ligne interrompt, mme partiellement, la; flche de la souris. Si oui, enlve la flche de la souris.; in	D3.W	position dbut ligne (y);	D4.W	hauteur de la ligne (dy); out	-; mod	D7.WITLMOUSE:	PUSHM.L	D2,D3,A1,A2	TEST.B	(A6)+OFLMOU:#BCLRMO ; souris dj enleve ?	JUMP',BS 90$		; oui => 90$	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.L	A1,(A2)+ODFPDE	; A1 <-- ^^status des 32 fentres	LOAD.L	A1,(A1)+0	; A1 <-- ^status de $DIS_0	LOAD.W	D2,(A1)+ODFMPO+0; D2 <-- Y min souris	ADD.W	D3,(A2)+ODFWBY	; D3 <-- Y min fentre	ADD.W	D3,D4		; D3 <-- Y max fentre	COMP.W	D3,D2	JUMP',LO 90$	ADD.W	D2,(A1)+ODFMDI+0; D2 <-- Y max souris	SUB.W	D3,D4		; D3 <-- Y min fentre	COMP.W	D3,D2	JUMP',HS 90$	CALL	DISCCMO		; enlve la flche de la souris90$:	POPM.L	D2,D3,A1,A2	RET;---------\; ITGMOUSE >;=========/; Test si un objet graphique du type (y;x)/(dy;dx) interrompt,; mme partiellement, la flche de la souris.; Si oui, enlve la flche de la souris.; in	D4.L	coordonne (y;x);	D3.L	dimensions (dy;dx) positives; out	-; mod	D7.WITGMOUSE:	PUSHM.L	D2..D4,A1,A2	TEST.B	(A6)+OFLMOU:#BCLRMO ; souris dj enleve ?	JUMP',BS 90$		; oui => 90$	LOAD.L	A2,(A6)+ODISPS	; A2 <-- ^status	LOAD.L	A1,(A2)+ODFPDE	; A1 <-- ^^status des 32 fentres	LOAD.L	A1,(A1)+0	; A1 <-- ^status de $DIS_0	LOAD.L	D2,(A1)+ODFMPO	; D2 <-- min Y;X souris	ADD.W	D4,(A2)+ODFWBX	; D4 <-- min X graphique	ADD.W	D4,D3		; D4 <-- max X graphique	COMP.W	D4,D2	JUMP',LT 90$	ADD.W	D2,(A1)+ODFMDI+2; D2 <-- max X souris	SUB.W	D4,D3		; D4 <-- min X graphique	COMP.W	D4,D2	JUMP',GE 90$	SWAP.W	D2		; D2 <-- min Y souris	SWAP.W	D3		; D3 <-- dY graphique	SWAP.W	D4		; D4 <-- Y graphique	ADD.W	D4,(A2)+ODFWBY	; D4 <-- min Y graphique	ADD.W	D4,D3		; D4 <-- max Y graphique	COMP.W	D4,D2	JUMP',LT 90$	ADD.W	D2,(A1)+ODFMDI+0; D2 <-- max Y souris	SUB.W	D4,D3		; D4 <-- min Y graphique	COMP.W	D4,D2	JUMP',GE 90$	CALL	DISCCMO		; enlve la flche de la souris90$:	POPM.L	D2..D4,A1,A2	RET;--------\\; DISCCMO >;========/; Enlve la flche de la souris.; in	-; out	-; mod	D7.WDISCCMO:	PUSH.W	D3	TEST.B	(A6)+OFLMOU:#BLOCKMO ; souris bloque ?	JUMP',BS 90$		; oui => 90$				; non =>	TSET.B	(A6)+OFLMOU:#BCLRMO ; souris dj enleve ?	JUMP',BS 90$		; oui => 90$				; non =>	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la souris90$:	POP.W	D3	RET;--------\\; DISSCMO >;========/; Remet la flche de la souris.; in	-; out	-; mod	D7.WDISSCMO:	PUSH.W	D3	TEST.B	(A6)+OFLMOU:#BLOCKMO ; souris bloque ?	JUMP',BS 90$		; oui => 90$				; non =>	TCLR.B	(A6)+OFLMOU:#BCLRMO ; souris dj remise ?	JUMP',BC 90$		; oui => 90$				; non =>	LOAD.B	D3,#AFSCMO	LIB	?AFCAR		; remet la souris90$:	POP.W	D3	RET	.END