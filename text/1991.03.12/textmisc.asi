	.SBTTL	TEXTMISC;--------\; EXKEY   >;========/; in	D3.B	touche presse; out	D4.W	zro (pour les classes); mod	D4.W, A0.LEXKEY:	POP.L	A0		; A0 <-- ^table des .WW	PUSH.W	D3	COMP.B	D3,#'a		; minuscule ?	JUMP',LO 10$		; non => 10$	COMP.B	D3,#'z	JUMP',HI 10$	SUB.B	D3,#'a-'A	; oui => transforme10$:	SUB.L	A0,#4		; A0 <-- recule .WW20$:	ADD.L	A0,#4		; A0 <-- saute .WW	TEST.W	(A0)		; table termine ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.B	D3,(A0)+1	; code touche trouve ?	JUMP,NE	20$		; non => 20$50$:	CLR.L	D3	LOAD.W	D3,(A0)+2	LOAD.L	A0,D3		; A0 <-- adresse relative	ADD.L	A0,(A6)+OSTART	; A0 <-- adresse absolue	POP.W	D3	CLR.W	D4		; D4 <-- zro (pour les classes)	JUMP	(A0)		; excute ...;--------\; EXFONC  >;========/; in	D3.W	touche fonction (dans high); out	-; mod	A0.LEXFONC:	POP.L	A0		; A0 <-- ^table des .WW	PUSH.W	D3	SR.W	D3,#8		; D3 <-- touche fonction	SUB.L	A0,#4		; A0 <-- recule .WW20$:	ADD.L	A0,#4		; A0 <-- saute .WW	TEST.W	(A0)		; table termine ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.B	D3,(A0)+1	; code touche fonction trouv ?	JUMP,NE	20$		; non => 20$50$:	CLR.L	D3	LOAD.W	D3,(A0)+2	LOAD.L	A0,D3		; A0 <-- adresse relative	ADD.L	A0,(A6)+OSTART	; A0 <-- adresse absolue	POP.W	D3	JUMP	(A0)		; excute ...;--------\\; GNBUF   >;========/; Cherche un numro de buffer en fonction d'une touche dans l'un; des invervals suivant :;	(0) .. (9)		-->	0..9;	(SHIFT-0) .. (SHIFT-9)	-->	10..19; in	D3.W	touche presse; out	D0.W	numro du buffer (0..NBBF-1);	D7.W	erreur; mod	D0.W, D7.WGNBUF:	PUSH.L	A3	CLR.W	D7		; D7 <-- trouv	CLR.W	D0	LOAD.B	D0,D3	SUB.B	D0,#'0	JUMP',LO 20$	COMP.B	D0,#9	JUMP',LS 90$20$:	LOAD.L	A3,#R16"00$-2	LOAD.W	D7,#ERTNOT	; D7 <-- pas trouv30$:	ADD.L	A3,#2		; A3 <-- ^lment suivant	TEST.B	(A3)+0		; fin de la table ?	JUMP',EQ 90$		; oui => 90$	COMP.B	D3,(A3)+0	; touche trouve ?	JUMP,NE	30$		; non => 30$	CLR.W	D0		; oui =>	LOAD.B	D0,(A3)+1	; D0 <-- numro 10..19	CLR.W	D7		; D7 <-- trouv90$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET00$:	.B	'+	11	; (SHIFT-1)	.B	'"	12	; (SHIFT-2)	.B	'*	13	; (SHIFT-3)	.B	'	14	; (SHIFT-4)	.B	'%	15	; (SHIFT-5)	.B	'&	16	; (SHIFT-6)	.B	'/	17	; (SHIFT-7)	.B	'(	18	; (SHIFT-8)	.B	')	19	; (SHIFT-9)	.B	'=	10	; (SHIFT-0)	.B	0	.EVEN;--------\\; MODIF   >;========/; Mmorise le type de modification effectue dans le texte; pour n'afficher que le minimum.; in	D4.W	type de modification; out	-; mod	-MODIF:	COMP.W	D4,(A5)+OMODIF	; modification plus importante ?	JUMP',LS 50$		; non => 50$	LOAD.W	(A5)+OMODIF,D4	; oui => mmorise-la50$:	COMP.W	D4,(A5)+OMODID	; modification plus importante ?	JUMP',LS 60$		; non => 60$	LOAD.W	(A5)+OMODID,D4	; oui => mmorise-la60$:	RET;--------\\; IFEOL   >;========/;--------\\; IFIEOL  >;========/; Test si le caractre dans D3.B est une fin de ligne.; in	D3.B	caractre; out	EQ	fin de ligne;	NE	autre chose; mod	-IFIEOL:	COMP.B	D3,#IMAGE	JUMP',EQ 90$	COMP.B	D3,#REGLE	JUMP',NE IFEOL90$:	RETIFEOL:	COMP.B	D3,#TEOL	JUMP',EQ 90$	COMP.B	D3,#PEOL	JUMP',EQ 90$	COMP.B	D3,#TEOP	JUMP',EQ 90$	COMP.B	D3,#PEOP90$:	RET;----------\\; IFLPSEUDO >;==========/;----------\\; IFCPSEUDO >;==========/;---------\\; IFPSEUDO >;=========/; Test si le caractre dans D3.B est une pseudo-caractre.; in	D3.B	caractre; out	EQ	pseudo-caractre;	NE	autre chose; mod	-IFLPSEUDO:	COMP.B	D3,#PEOL	JUMP',NE IFCPSEUDO	RETIFCPSEUDO:	COMP.B	D3,#COMMAND	JUMP',NE IFPSEUDO	RETIFPSEUDO:	COMP.B	D3,#SAJEXM	JUMP',EQ 90$	COMP.B	D3,#SAJEXT	JUMP',EQ 90$	COMP.B	D3,#SAJEXS	JUMP',EQ 90$	COMP.B	D3,#TIRET90$:	RET;--------\; MINMAJ  >;========/; N'utilise pas LIB,?MINMAJ pour tre plus rapide !; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.WMINMAJ:	TEST.L	D3:#7		; code "supplmentaire" ?	JUMP',NE 20$		; oui => 20$	COMP.B	D3,#SPACE-2	; lettre accentue ?	JUMP',LO 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	SUB.B	D3,#'	AND.W	D3,#H'FF	LOAD.B	D3,(PC)+(D3)+70$  ; D3 <-- lettre majuscule	RET70$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN;--------\\; MAJMIN  >;========/; Effectue une conversion MAJUSCULE --> minuscule.; in	D3.B	caractre; out	D3.B	caractre; mod	D3.BMAJMIN:	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'Z	JUMP',HI 90$	ADD.B	D3,#'a-'A90$:	RET;--------\\; NUMRB   >;========/; Transforme un word en deux bytes pouvant aller dans un buffer.; Les deux bytes dans le buffer doivent avoir le bit 2^7  zro !; in	D4.W	nombre (14 bits significatifs); out	D0.B	low;	D1.B	high; mod	D0.W, D1.WNUMRB:	LOAD.B	D0,D4	AND.B	D0,#H'7F	; D0 <-- bits 0..6 de D4	LOAD.W	D1,D4	SR.W	D1,#7	AND.B	D1,#H'7F	; D1 <-- bits 7..13 de D4	RET;--------\\; NUMBR   >;========/; Transforme deux bytes dans un buffer en un word.; Les deux bytes dans le buffer doivent avoir le bit 2^7  zro !; in	D0.B	low;	D1.B	high; out	D4.W	nombre (14 bits significatifs); mod	D4.WNUMBR:	CLR.W	D4	LOAD.B	D4,D1	SL.W	D4,#7		; D4 <-- bits 7..13  de D1	OR.B	D4,D0		; D4 <-- bits 0..6 de D0	RET;--------\\; AFXMM   >;========/; Affiche un nombre horizontal en millimtres, sans dcimales.; in	D4.W	nombre; out	-; mod	D7.WAFXMM:	PUSHM.L	D2..D4	CALL	CONVPMX		; D4 <-- nombre [1/10mm]	JUMP'	AFMM;--------\\; AFYMM   >;========/; Affiche un nombre horizontal en millimtres, sans dcimales.; in	D4.W	nombre; out	-; mod	D7.WAFYMM:	PUSHM.L	D2..D4	CALL	CONVPMY		; D4 <-- nombre [1/10mm]AFMM:	LOAD.B	D3,#SPACE	TEST.W	D4	JUMP',NC 10$	NEG.W	D4	LOAD.B	D3,#'-10$:	LIB	?AFCAR		; affiche le signe +/-	AND.L	D4,#H'FFFF	LOAD.W	D3,#10	CALL	DIVD4D3	AND.L	D4,#H'FFFF	; D4 <-- nombre [mm]	LOAD.W	D3,#3		; D3 <-- nb max digits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC		; affiche le nombre	LIB	?AFTIM	.ASCIZ	" mm"	.EVEN	POPM.L	D2..D4	RET;--------\\; CONVMPX >;========/; Converti un nombre horizontal en millimtres --> en points.; in	D4.W	nombre [1/10mm]; out	D4.W	nombre [p]; mod	D3.W, D4.LCONVMPX:	MUL.WA	D4,#1000	LOAD.W	D3,(A6)+OMMX	CALL	DIVD4D3	AND.L	D4,#H'FFFF	LOAD.W	D3,(A6)+OFACX	JUMP'	DIVD4D3;--------\\; CONVMPY >;========/; Converti un nombre vertical en millimtres --> en points.; in	D4.W	nombre [1/10mm]; out	D4.W	nombre [p]; mod	D3.W, D4.LCONVMPY:	MUL.WA	D4,#1000	LOAD.W	D3,(A6)+OMMY	CALL	DIVD4D3	AND.L	D4,#H'FFFF	LOAD.W	D3,(A6)+OFACY	JUMP'	DIVD4D3;--------\\; CONVPMX >;========/; Converti un nombre horizontal en points --> en millimtres.; in	D4.W	nombre [p]; out	D4.W	nombre [1/10mm]; mod	D3.W, D4.LCONVPMX:	MUL.WA	D4,(A6)+OFACX	MUL.WA	D4,(A6)+OMMX	LOAD.W	D3,#1000	JUMP'	DIVD4D3;--------\\; CONVPMY >;========/; Converti un nombre vertical en points --> en millimtres.; in	D4.W	nombre [p]; out	D4.W	nombre [1/10mm]; mod	D3.W, D4.LCONVPMY:	MUL.WA	D4,(A6)+OFACY	MUL.WA	D4,(A6)+OMMY	LOAD.W	D3,#1000;	JUMP'	DIVD4D3;--------\\; DIVD4D3 >;--------/; Divise D4 par D3 avec un arrondi.; in	D4.L	nombre  diviser (+/-);	D3.W	diviseur (+); out	D4.L	reste/div; mod	D4.LDIVD4D3:	PUSH.W	D3	DIV.WA	D4,D3	JUMP',NS 40$	SR.W	D3,#1	SWAP.W	D4	COMP.W	D4,D3	JUMP',LE 20$	SWAP.W	D4	INC.W	D4		; D4 <-- arrondi (+1)	POP.W	D3	RET20$:	SWAP.W	D4	POP.W	D3	RET40$:	SR.W	D3,#1	SWAP.W	D4		; D4 <-- reste ngatif	NEG.W	D4		; D4 <-- reste positif	COMP.W	D4,D3	JUMP',LE 60$	SWAP.W	D4	DEC.W	D4		; D4 <-- arrondi (-1)	POP.W	D3	RET60$:	SWAP.W	D4	POP.W	D3	RET;--------\; SWMO    >;========/; Met la flche de la souris et attente.; in	-; out	-; mod	-SWMO:	PUSHM.L	D4,D7	TSET.B	(A6)+OFLMOU:#BWMOUSE	JUMP',BS 90$	CLR.W	D4	LIB	?WAITMOUSE90$:	POPM.L	D4,D7	RET;--------\; CWMO    >;========/; Remet la flche normale de la souris.; in	-; out	-; mod	-CWMO:	PUSHM.L	D4,D7	TCLR.B	(A6)+OFLMOU:#BWMOUSE	JUMP',BC 90$	LOAD.W	D4,#1	LIB	?WAITMOUSE90$:	POPM.L	D4,D7	RET; Textes divers pour tous les .INS; --------------------------------TXTEXT:	.ASCIZ	".text"TXIMAGE:.ASCIZ	".image"	.EVEN	.END