	.SBTTL	TEXTOUT;--------\\; AOUTPUT >;========/; in	D2.W	mode; out	-; mod	D7.WAOUTPUT:	PUSHM.L	D2..D4,D6,A3,A4	LOAD.L	A3,#(A6)+OBUTEMP	CALL	RCLFILE		; A3 <-- prend nom si existe	LOAD.L	A4,#(A6)+OBUEXT	; A4 <-- ^extension	LOAD.B	D4,#2^BIOBOA	; D4 <-- fanions si ".text"	CALL	DBOXCREATE	; cre le fichier	JUMP',NE 90$	LOAD.W	D7,#1		; D7 <-- (END)	COMP.W	D3,#F1	JUMP',NE 90$	CALL	BOUTPUT		; sauve le texte sur disque	JUMP',NE 90$	LOAD.L	A3,#(A6)+OBUTEMP	CALL	WRFILES		; crit le fichier "!"	JUMP',NE 90$	TCLR.B	(A5)+OSTATUS:#BFILMOD	CALL	STOFILE		; mm nom du fichier90$:	CALL	IOERROR		; affiche erreur si ncessaire	POPM.L	D2..D4,D6,A3,A4	RET;--------\\; BOUTPUT >;========/; Sauve tout le texte sur disque.; in	D4.B	fanions;	D6.W	canal; out	D7.W	erreur; mod	D7.WBOUTPUT:	PUSHM.L	D2..D4,A3,A4	CALL	SWMO		; souris: met le sablier	TEST.B	(A6)+OFLIO:#BNOTEXT ; fichier ".text" ?	JUMP',BC 10$		; oui => 10$	TCLR.L	D4:#BIOBOA	TSET.L	D4:#BIONOBOA	; D4 <-- pas de <boa>10$:	LOAD.B	(A6)+OFLIO3,D4	CLR.B	(A6)+OIOLNOG	; dernier gencar	CLR.B	(A6)+OIOLMOD	; dernier mode	CALL	WROPEN		; ouvre le fichier	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP',BS 30$		; oui => 30$	CALL	OUTHEADER	; crit les dfinitions d'en-tte	JUMP,NE 80$	CALL	OUTGENCAR	; crit les dfinitions de gencars	JUMP,NE 80$30$:	LOAD.L	(A6)+OPDI,(A5)+OPDB	LOAD.L	(A6)+OPFI,(A5)+OPFB	TEST.B	(A6)+OFLIO3:#BIODEA ; imprime de ..  .. ?	JUMP,BC 40$		; non => 40$				; oui =>	LOAD.L	A4,(A5)+OPDB	PUSH.L	D4	CALL	GIVPNUM		; D4 <-- numro de la premire page	LOAD.W	D2,D4		; D2 <-- numro de la premire page	POP.L	D432$:	COMP.W	D2,(A6)+OPRFPA	JUMP',EQ 34$	CALL	SRCPDOWN	; A4 <-- ^dbut page suivante	JUMP,NE 80$	INC.W	D2		; D2 <-- numro de la page suivante	JUMP	32$34$:	LOAD.L	(A6)+OPDI,A4	; OPDI <-- ^dbut de l'impression35$:	CALL	SRCPDOWN	; A4 <-- ^dbut page suivante	JUMP',NE 37$	INC.W	D2		; D2 <-- numro de la page suivante	COMP.W	D2,(A6)+OPRLPA	JUMP,LS 35$37$:	LOAD.L	(A6)+OPFI,A4	; OPFI <-- ^fin de l'impression40$:	LOAD.L	A4,(A6)+OPDI	LOAD.L	A3,#(A5)+OVREG	CALL	VAQQREGLE	; cherche la rglette valide ici	LOAD.L	A4,(A6)+OPDI	LOAD.L	A3,#(A5)+OVCOM	CALL	VAQQCOMMAND	; cherche la commande valide ici	CLR.W	(A6)+OIOPOSL	; on est au dbut de la ligne	LOAD.L	A4,(A6)+OPDI	; A4 <-- ^dbut 1re partie	LOAD.L	A3,(A5)+OPDT	; A3 <-- ^fin 1re partie	COMP.L	A4,A3	JUMP',HS 52$	COMP.L	A3,(A6)+OPFI	JUMP',LS 50$	LOAD.L	A3,(A6)+OPFI50$:	CALL	COUTPUT		; sauve la tranche avant le trou	JUMP',NE 80$52$:	LOAD.L	A4,(A5)+OPFT	; A4 <-- ^dbut 2me partie	LOAD.L	A3,(A6)+OPFI	; A3 <-- ^fin 2re partie	COMP.L	A4,A3	JUMP',HS 80$	COMP.L	A4,(A6)+OPDI	JUMP',HS 54$	LOAD.L	A4,(A6)+OPDI54$:	CALL	COUTPUT		; sauve la tranche aprs le trou80$:	CALL	WRCLOSE		; ferme le fichier	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; COUTPUT >;========/; Sauve une tranche sur disque.; in	A4.L	^dbut de la tranche;	A3.L	^fin de la tranche; out	D7.W	erreur; mod	D7.WCOUTPUT:	PUSHM.L	D2,D3,A1..A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A1,A4		; A1 <-- ^dbut bloc	TCLR.B	(A6)+OFLIO3:#BIODEA ; imprime de ..  .. ?	JUMP',BC 10$		; non => 10$				; oui =>	LOAD.L	A2,#(A5)+OVREG-1-LGREG	CALL	OUTREGLE	JUMP,NE 90$	LOAD.L	A2,#(A5)+OVCOM-1-LGCOM	CALL	OUTCOMMAND	JUMP,NE 90$10$:	TEST.W	D7		; ok ?	JUMP,NE 90$		; non => 90$	LOAD.L	A2,A4		; A2 <-- ^fin bloc	COMP.L	A4,A3		; est-on arriv  la fin ?	JUMP,HS 80$		; oui => 80$				; non =>	CALL	NVISU		; D3 <-- caractre suivant	COMP.B	D3,#REGLE	; rglette ?	JUMP,EQ 20$	COMP.B	D3,#IMAGE	; image ?	JUMP,EQ 25$	COMP.B	D3,#COMMAND	; commande ?	JUMP,EQ 30$	COMP.B	D3,#SAJEXM	; espace variable ?	JUMP,EQ 35$	COMP.B	D3,#SAJEXT	; espace variable ?	JUMP,EQ 35$	COMP.B	D3,#SAJEXS	; espace variable ?	JUMP,EQ 36$	COMP.B	D3,#TEOL	JUMP,EQ 50$	COMP.B	D3,#PEOL	JUMP,EQ 51$	COMP.B	D3,#TEOP	JUMP,EQ 52$	COMP.B	D3,#PEOP	JUMP,EQ 53$	COMP.B	D3,#BOA	JUMP,EQ 54$	COMP.B	D3,#TIRET	JUMP,EQ 55$	LOAD.W	D2,(A6)+OIOPOSL	CALL	VADDLGC		; D2 <-- position dans la ligne	LOAD.W	(A6)+OIOPOSL,D2	CLR.W	D7		; D7 <-- ok	JUMP	10$20$:				; rglette =>	CLR.W	(A6)+OIOPOSL	; revient au dbut de la ligne	CALL	DOUTPUT	JUMP,NE 90$	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 10$		; oui => 10$	CALL	OUTREGLE	JUMP	10$25$:				; image =>	CLR.W	(A6)+OIOPOSL	; revient au dbut de la ligne	CALL	DOUTPUT	JUMP,NE 90$	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 10$		; oui => 10$	CALL	OUTIMAGE	JUMP	10$30$:				; commande =>	CALL	DOUTPUT	JUMP,NE 90$	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 10$		; oui => 10$	CALL	OUTCOMMAND	JUMP	10$35$:				; espace variable =>	CALL	DOUTPUT	JUMP,NE 90$	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 10$		; oui => 10$	CALL	OUTSAJEXMT	LOAD.L	A1,A4		; A1 <-- ^dbut bloc	JUMP	10$36$:				; espace variable =>	CALL	DOUTPUT	JUMP,NE 90$	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 10$		; oui => 10$	CALL	OUTSAJEXS	LOAD.L	A1,A4		; A1 <-- ^dbut bloc	JUMP	10$50$:				; TEOL =>	CLR.W	(A6)+OIOPOSL	; revient au dbut de la ligne	CALL	DOUTPUT	JUMP,NE 90$	LOAD.B	D3,#CR	CALL	WRONE	JUMP	10$51$:				; PEOL =>	CLR.W	(A6)+OIOPOSL	; revient au dbut de la ligne	CALL	DOUTPUT	JUMP,NE 90$	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 10$		; oui => 10$	LOAD.B	D3,#LF	CALL	WRONE	JUMP	10$52$:				; TEOP =>	CLR.W	(A6)+OIOPOSL	; revient au dbut de la ligne	CALL	DOUTPUT	JUMP,NE 90$	LOAD.B	D3,#EOP	CALL	WRONE	JUMP	10$53$:				; PEOP =>	CLR.W	(A6)+OIOPOSL	; revient au dbut de la ligne	CALL	DOUTPUT	JUMP,NE 90$	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 10$		; oui => 10$	LOAD.B	D3,#CAREOP	CALL	WRONE	JUMP	10$54$:				; BOA =>	CALL	DOUTPUT	JUMP,NE 90$	LOAD.B	D3,#BOA	LOAD.W	D2,(A6)+OIOPOSL	CALL	VADDLGC		; D2 <-- position dans la ligne	LOAD.W	(A6)+OIOPOSL,D2	CALL	WRONE	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 10$		; oui => 10$	CALL	WRONE	JUMP	10$55$:				; TIRET =>	CALL	DOUTPUT	JUMP,NE 90$	TEST.B	(A6)+OFLIO3:#BIONOBOA ; le texte seul ?	JUMP,BS 10$		; oui => 10$	LOAD.B	D3,#TIRET	LOAD.W	D2,(A6)+OIOPOSL	CALL	VADDLGC		; D2 <-- position dans la ligne	LOAD.W	(A6)+OIOPOSL,D2	CALL	WRONE	JUMP	10$80$:	CALL	DOUTPUT		; crit la dernire tranche90$:	POPM.L	D2,D3,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DOUTPUT >;========/; Ecrit un bloc de bytes contigs.; in	A1.L	^dbut bloc;	A2.L	^fin bloc;	A4.L	^dbut bloc suivant; out	A1.L	^dbut bloc suivant;	D7.W	erreur; mod	D7.W, A1.LDOUTPUT:	PUSHM.L	D4,A4	EX.L	A1,A4	LOAD.L	D4,A2	SUB.L	D4,A4		; D4 <-- lg du bloc	JUMP',EQ 90$	CALL	WRMANY		; crit tout le bloc90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; OUTHEADER >;==========/; Ecrit l'en-tte sous forme de squences "boa".; in	D4.L	fanions; out	D7.W	erreur; mod	D7.WOUTHEADER:	PUSHM.L	D1..D5,A3,A4	LOAD.L	A4,#R16"FIX$	CALL	WRTEXT		; ver + disable<cr> + width<cr>	JUMP,NE 90$	LOAD.L	A4,#R16"HAUT$	CALL	WRTEXT		; hauteur	JUMP,NE 90$	LOAD.W	D4,(A6)+OHTP	CALL	WRNUMMY	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#R16"MARS$	CALL	WRTEXT		; marsup	JUMP,NE 90$	LOAD.W	D4,(A6)+OMGS	CALL	WRNUMMY	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#R16"MARI$	CALL	WRTEXT		; marinf	JUMP,NE 90$	LOAD.W	D4,(A6)+OMGI	CALL	WRNUMMY	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#R16"ITL$	CALL	WRTEXT		; interligne	JUMP,NE 90$	LOAD.W	D4,(A6)+OITL	CALL	WRNUMPY	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#R16"MARG$	CALL	WRTEXT		; marge	JUMP,NE 90$	LOAD.W	D4,(A6)+OMGG	CALL	WRNUMMX	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#R16"LARG$	CALL	WRTEXT		; large	JUMP,NE 90$	LOAD.W	D4,(A6)+OLGP	CALL	WRNUMMX	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE 90$	TEST.B	(A6)+OFANION+2:#BFANUM-8 ; numrote les pages ?	JUMP',BC 60$		; non => 60$				; oui =>	CALL	OUTPAGE		; debutpage	JUMP,NE 90$60$:	LOAD.L	A4,#R16"DIMC$	CALL	WRTEXT		; dimcar	JUMP,NE 90$	LOAD.W	D4,(A6)+ODRF1Y	CALL	WRNUMPY	JUMP,NE 90$	LOAD.B	D3,#',	CALL	WRONE	JUMP,NE 90$	LOAD.W	D4,(A6)+ODRF2Y	CALL	WRNUMPY	JUMP,NE 90$	LOAD.B	D3,#',	CALL	WRONE	JUMP,NE 90$	LOAD.W	D4,(A6)+ODRFX	CALL	WRNUMPY	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#R16"DISA$	CALL	WRTEXT	JUMP,NE 90$	LOAD.L	A4,#R16"JUST$	CALL	WRTEXT		; justmode	JUMP,NE 90$	LOAD.W	D4,(A6)+OJUPAL	CALL	WRNUM	JUMP,NE 90$	LOAD.B	D3,#',	CALL	WRONE	JUMP,NE 90$	LOAD.W	D4,(A6)+OJUPTR	CALL	WRNUM	JUMP,NE 90$	LOAD.B	D3,#',	CALL	WRONE	JUMP,NE 90$	LOAD.W	D4,(A6)+OJUPNL	CALL	WRNUM	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#R16"DEF$	CALL	WRTEXT		; textdef	JUMP',NE 90$	LOAD.L	D4,(A6)+OFANION	CALL	WRNUML	JUMP',NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP',NE 90$	LOAD.B	D3,#CR	CALL	WRONE	JUMP',NE 90$	LOAD.L	A4,#R16"FACT$	CALL	WRTEXT		; textfact	JUMP',NE 90$	LOAD.W	D4,(A6)+OFACX	CALL	WRNUM	JUMP',NE 90$	LOAD.B	D3,#',	CALL	WRONE	JUMP',NE 90$	LOAD.W	D4,(A6)+OFACY	CALL	WRNUM	JUMP',NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP',NE 90$	LOAD.B	D3,#CR	CALL	WRONE	JUMP',NE 90$	LOAD.L	A4,#R16"ENAB$	CALL	WRTEXT		; enable <cr>;	JUMP',NE 90$90$:	POPM.L	D1..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RETFIX$:	.ASCII	"<BOA>ver 1;"	.ASCII	"<BOA>disable <'<>cr<'>>;<CR>"	.ASCII	"<BOA>zoom;<CR>"	.ASCIZ	"<BOA>width 7pt;<CR>"HAUT$:	.ASCIZ	"<BOA>hauteur "MARS$:	.ASCIZ	"<BOA>marsup "MARI$:	.ASCIZ	"<BOA>marinf "ITL$:	.ASCIZ	"<BOA>interligne "MARG$:	.ASCII	"<BOA>large 0mm;<CR>"	.ASCIZ	"<BOA>marge "LARG$:	.ASCIZ	"<BOA>large "DIMC$:	.ASCIZ	"<BOA>dimcar "DISA$:	.ASCII	"<BOA>disable justmode textdef textfact;<CR>"	.ASCII	"<BOA>disable justif drapeau drapd centre;<CR>"	.ASCII	"<BOA>disable marge large renf newtab justtab;<CR>"	.ASCIZ	"<BOA>disable coupe nocoupe label <'<>tab<'>>;<CR>"JUST$:	.ASCIZ	"<BOA>justmode "DEF$:	.ASCIZ	"<BOA>textdef "FACT$:	.ASCIZ	"<BOA>textfact "ENAB$:	.ASCIZ	"<BOA>enable <'<>cr<'>>;"	.EVEN;--------\\; OUTPAGE >;--------/; Ecrit dans l'en-tte les commandes de dbut de page sous forme de squences "boa".; in	-; out	D7.W	erreur; mod	D1.L, D2.L, D3.L, D4.L, D7.W, A3.L, A4.LOUTPAGE:	CALL	OUTPAGELP	LOAD.L	D5,D4		; D5 <-- origine,largeur pour numrotation	LOAD.L	A4,#R16"PAGEQ$	CALL	WRTEXT		; cpage=	JUMP,NE 90$	CALL	GIVPNUM		; D4 <-- numro de la premire page	TEST.B	(A6)+OFLIO3:#BIODEA ; imprime de ..  .. ?	JUMP',BC 10$		; non => 10$	LOAD.W	D4,(A6)+OPRFPA	; D4 <-- numro "de .."10$:	CALL	WRNUM		; numro de la premire page	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#R16"DEBUT$	CALL	WRTEXT		; dbut commande debutpage	JUMP,NE 90$	LOAD.L	A3,#(A6)+ODFNGC20$:	LOAD.B	D3,(A3+)	JUMP',EQ 22$	CALL	WRONE		; nom du gencar	JUMP,NE 90$	JUMP	20$22$:	LOAD.L	A4,#R16"ITL$	CALL	WRTEXT		; interligne	JUMP,NE 90$	LOAD.W	D4,(A6)+OITL	CALL	WRNUMPY		; valeur de l'interligne	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.L	A3,#(A6)+ODFNEN	LOAD.L	D4,(A6)+OFANION	SWAP.W	D4	CALL	OUTPAGEGA	; D3/D4 <-- dx/x pour en-tte	LOAD.W	D1,D3	LOAD.W	D2,D4	LOAD.L	A3,#(A6)+ODFNUM	LOAD.L	D4,(A6)+OFANION	SWAP.W	D4	SR.B	D4,#3	CALL	OUTPAGEGA	; D3/D4 <-- dx/x pour numrotation	COMP.W	D2,D4		; en-tte aprs la numrotation ?	JUMP',HI 40$		; oui => 40$				; non =>	SUB.W	D4,D2	SUB.W	D4,D1	EX.L	D2,D4	CALL	OUTPAGEEN	; en-tte	JUMP,NE 90$	LOAD.W	D4,D2	CALL	OUTPAGENU	; numrotation	JUMP,NE 90$	JUMP'	50$40$:	SUB.W	D2,D4	SUB.W	D2,D3	CALL	OUTPAGENU	; numrotation	JUMP',NE 90$	LOAD.W	D4,D2	CALL	OUTPAGEEN	; en-tte	JUMP',NE 90$50$:	LOAD.B	D3,#LF	CALL	WRONE	JUMP',NE 90$	TEST.B	(A6)+OFANION+1:#BFALIN-16	JUMP',BC 60$	LOAD.L	A4,#R16"LINE1$	CALL	WRTEXT		; hline	JUMP',NE 90$	LOAD.L	D4,D5	SWAP.W	D4	CALL	WRNUMPX		; origine en X	JUMP',NE 90$	LOAD.L	A4,#R16"LINE2$	CALL	WRTEXT		; origine en Y	JUMP',NE 90$	LOAD.W	D4,D5	CALL	WRNUMPX		; largeur	JUMP',NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP',NE 90$60$:	LOAD.L	A4,#R16"END$	CALL	WRTEXT		; fin commande debutpage90$:	TEST.W	D7		; retour EQ/NE	RETPAGEQ$:	.ASCIZ	"<BOA>cpage="DEBUT$:	.ASCIZ	"<BOA>debutpage:<BOA>g_"ITL$:	.ASCIZ	";<BOA>interligne "LINE1$:	.ASCIZ	"<BOA>hline "LINE2$:	.ASCIZ	",-0.5h1,"END$:	.ASCIZ	"<LF><BOA>cpage=+;<BOA>;<CR>"	.EVEN;----------\\; OUTPAGEEN >;----------/; Ecrit le texte de l'en-tte.; in	D4.W	avance; out	D7.W	erreur; mod	D3.L, D4.L, D7.W, A3.L, A4.LOUTPAGEEN:	LOAD.W	D3,D4	LOAD.L	A4,#R16"LEFT$	CALL	WRTEXT		; hn	JUMP',NE 90$	LOAD.W	D4,D3	CALL	WRNUMPX		; x	JUMP',NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP',NE 90$	LOAD.L	A4,#(A6)+ODFNEN	CALL	WRTEXT		; crit le texte de l'en-tte90$:	TEST.W	D7		; retour EQ/NE	RETLEFT$:	.ASCIZ	"<BOA>hn "	.EVEN;----------\\; OUTPAGENU >;----------/; Ecrit le texte de numrotation.; in	D4.W	avance; out	D7.W	erreur; mod	D3.L, D4.L, D7.W, A3.L, A4.LOUTPAGENU:	LOAD.W	D3,D4	LOAD.L	A4,#R16"LEFT$	CALL	WRTEXT		; hn	JUMP,NE 90$	LOAD.W	D4,D3	CALL	WRNUMPX		; x	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.L	A3,#(A6)+ODFNUM30$:	LOAD.B	D3,(A3+)	JUMP,EQ 90$	COMP.B	D3,#'0	JUMP',LO 32$	COMP.B	D3,#'9	JUMP',LS 40$32$:	COMP.B	D3,#BOA	JUMP,EQ 30$	COMP.B	D3,#';	JUMP,EQ 30$	CALL	WRONE		; crit le prfixe	JUMP',NE 90$	JUMP	30$40$:	LOAD.L	A4,#R16"CPAGE$	CALL	WRTEXT		; crit cpage	JUMP',NE 90$50$:	LOAD.B	D3,(A3+)	JUMP',EQ 90$	COMP.B	D3,#'0	JUMP',LO 52$	COMP.B	D3,#'9	JUMP,LS 50$52$:	DEC.L	A354$:	LOAD.B	D3,(A3+)	JUMP',EQ 90$	COMP.B	D3,#BOA	JUMP,EQ 54$	COMP.B	D3,#';	JUMP,EQ 54$	CALL	WRONE		; crit le postfixe	JUMP',NE 90$	JUMP	54$90$:	TEST.W	D7		; retour EQ/NE	RETLEFT$:	.ASCIZ	"<BOA>hn "CPAGE$:	.ASCIZ	"<BOA>cpage;"	.EVEN;----------\\; OUTPAGEGA >;----------/; Donne l'avance et la largeur d'un texte quelconque.; in	A3.L	^texte;	D4.W	bits (0=gauche, 1=centre et 2=droite);	D5.L	origine,largeur pour numrotation; out	D3.W	largeur;	D4.W	avance horizontale; mod	D3.L, D4.L, D7.WOUTPAGEGA:	PUSHM.L	D0,D1,D2,A2,A3,A4	LOAD.L	A2,A3		; A2 <-- ^texte	LOAD.W	D2,D4		; D2 <-- bits	LOAD.L	A3,#(A6)+ODFNGC	; A3 <-- ^titre du gencar de numrotation	CALL	SRCGC		; A4 <-- ^dans OBUGC	JUMP',EQ 10$	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^gencar "Fond"10$:	CLR.W	D1		; D1 <-- largeur du texte	TEST.L	D2:#2		;  droite ?	JUMP',BC 20$		; non => 20$	LOAD.L	A3,#(A6)+ODFNUM	COMP.L	A2,A3		; numrotation ?	JUMP',NE 20$		; non => 20$	CALL	GIVPNUM		; D4 <-- numro de la premire page	LOAD.W	D0,D4	CALL	OUTPAGEND	; D4 <-- nb de digits premire page	LOAD.W	D3,D4		; D3 <-- nb de digits premire page	CALL	OUTPAGENL	; D4 <-- nb de pages	ADD.W	D4,D0	DEC.W	D4		; D4 <-- numro de la dernire page	CALL	OUTPAGEND	; D4 <-- nb de digits dernire page	SUB.W	D4,D3		; D4 <-- nb de digits  rserver en plus	JUMP',LE 20$	LOAD.W	D1,D4	LOAD.B	D3,#'0	CALL	OUTPAGELC	; D4 <-- largeur d'un zro	MUL.WU	D1,D4		; D1 <-- largeur des digits supplmentaires20$:	LOAD.B	D3,(A2+)	; D3 <-- un caractre	JUMP',EQ 22$	CALL	OUTPAGELC	; D4 <-- largeur du caractre	ADD.W	D1,D4	JUMP	20$22$:	LOAD.W	D3,D1		; D3 <-- largeur du texte	CLR.W	D4		; D4 <-- pas d'avance	TEST.L	D2:#0		;  gauche ?	JUMP',BS 60$		; oui => 60$	LOAD.W	D4,D5		; D4 <-- largeur pour numrotation	SUB.W	D4,D3	TEST.L	D2:#2		;  droite ?	JUMP',BS 60$		; oui => 60$	ASR.W	D4,#1		; D4 <-- la moiti de chaque ct60$:	SWAP.W	D5	ADD.W	D4,D5		; D4 <-- ajoute l'origine	SWAP.W	D5	TEST.W	D4	JUMP',NC 90$	CLR.W	D490$:	POPM.L	D0,D1,D2,A2,A3,A4	RET;----------\\; OUTPAGENL >;----------/; Cherche le nombre de pages du texte.; in	-; out	D4.W	nombre de pages (1..n); mod	D4.L, D7.WOUTPAGENL:	PUSHM.L	D3,A4	LOAD.L	A4,(A5)+OPDB	; A4 <-- ^dbut du texte	LOAD.W	D4,#1		; D4 <-- au moins une page10$:	CALL	QUICKDOWN	; D3 <-- commande suivante	JUMP',NE 90$	COMP.B	D3,#TEOP	JUMP',EQ 20$	COMP.B	D3,#PEOP	JUMP,NE 10$20$:	INC.W	D4		; D4 <-- une page de plus	JUMP	10$90$:	POPM.L	D3,A4	RET;----------\\; OUTPAGEND >;----------/; Cherche le nombre de digits ncessaires pour un nombre.; in	D4.W	nombre; out	D4.W	nombre de digits (1..n); mod	D4.WOUTPAGEND:	PUSH.W	D3	LOAD.W	D3,D4	LOAD.W	D4,#1	COMP.W	D3,#9	JUMP',LS 90$	INC.W	D4	COMP.W	D3,#99	JUMP',LS 90$	INC.W	D4	COMP.W	D3,#999	JUMP',LS 90$	INC.W	D4	COMP.W	D3,#9999	JUMP',LS 90$	INC.W	D490$:	POP.W	D3	RET;----------\\; OUTPAGELC >;----------/; Calcule la largeur d'un caractre.; in	D3.B	caractre;	A4.L	^dans OBUGC; out	D4.W	largeur; mod	D4.LOUTPAGELC:	PUSHM.L	D3,A4	CLR.W	D4		; D4 <-- largeur nulle	LOAD.L	A4,(A4)+OGCPT	; A4 <-- ^gencar	COMP.B	D3,(A4)+OGCLCA	; code caractre trop grand ?	JUMP',HI 90$		; oui => 90$	SUB.B	D3,(A4)+OGCFCA	; code caractre trop petit ?	JUMP',LO 90$		; oui => 90$	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.B	D4,(A4)+(D3.W)	; D3 <-- largeur caractre90$:	POPM.L	D3,A4	RET;----------\\; OUTPAGELP >;----------/; Calcule la largeur de la page pour la numrotation automatique.; Prend la largeur de la premire rgle rencontre dans le texte.; in	-; out	D4.L	origine,largeur; mod	D4.L, D7.WOUTPAGELP:	PUSHM.L	D3,A3,A4	CLR.L	D4		; D4 <-- origine par dfaut	LOAD.W	D4,(A6)+OLGP	SUB.W	D4,(A6)+OMGG	; D4 <-- largeur du papier par dfaut	LOAD.L	A4,(A5)+OPDB	; A4 <-- ^dbut du texte10$:	CALL	QUICKDOWN	; cherche contre en bas	JUMP',NE 90$		; pas trouv => 90$	COMP.B	D3,#DEBREG	; dbut d'une rglette ?	JUMP,NE	10$		; non => 10$				; oui =>	LOAD.L	A4,#(A4)+LGREG	; A4 <-- ^paramtres "next"	LOAD.L	A3,#(A6)+OSREG	CALL	MAJREGLE	; OSREG <-- rglette	LOAD.W	D4,(A3)+OREGMGG	; D4 <-- marge gauche (origine)	LOAD.W	D3,(A3)+OREGMGD	; D3 <-- marge droite	SUB.W	D3,D4		; D3 <-- largeur	SWAP.W	D4	LOAD.W	D4,D390$:	POPM.L	D3,A3,A4	RET;---------\\; OUTREGLE >;=========/; Ecrit une rglette sous forme de squences "boa".; in	A2.L	^dbut rglette; out	D7.W	erreur; mod	D7.WOUTREGLE:	PUSHM.L	D0..D4,A2,A4	LOAD.L	A2,#(A2)+1+LGREG	LOAD.L	A4,#R16"01$	LOAD.B	D4,(A2)+OREGJUST	CALL	WRTEXTN		; justif, drapeau, etc	JUMP,NE 90$	LOAD.L	A4,#R16"02$	CALL	WRTEXT		; interligne	JUMP,NE 90$	LOAD.B	D3,(A2)+OREGITL	LOAD.W	D4,(A6)+OITL	; D4 <-- 1 * interligne	COMP.B	D3,#ITL1	JUMP',EQ 20$	SL.W	D4,#1		; D4 <-- 2 * interligne	COMP.B	D3,#ITL2	JUMP',EQ 20$	SR.W	D4,#2	ADD.W	D4,(A6)+OITL	; D4 <-- 1.5 * interligne20$:	CALL	WRNUMPY	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#R16"03$	CALL	WRTEXT		; marge gauche	JUMP,NE 90$	LOAD.B	D1,(A2)+OREGMGG+0	LOAD.B	D0,(A2)+OREGMGG+1	CALL	NUMBR	LOAD.W	D2,D4	ADD.W	D4,(A6)+OMGG	CALL	WRNUMMX	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#R16"04$	CALL	WRTEXT		; marge droite	JUMP,NE 90$	LOAD.B	D1,(A2)+OREGMGD+0	LOAD.B	D0,(A2)+OREGMGD+1	CALL	NUMBR	SUB.W	D4,D2		; D4 <-- largeur utile	CALL	WRNUMMX	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#R16"05$	CALL	WRTEXT		; marge renfoncement	JUMP,NE 90$	LOAD.B	D1,(A2)+OREGRENF+0	LOAD.B	D0,(A2)+OREGRENF+1	CALL	NUMBR	SUB.W	D4,D2		; D4 <-- renfoncement relatif	CALL	WRNUMMX	JUMP,NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#(A2)+OREGTAB	LOAD.B	D1,(A4+)	LOAD.B	D0,(A4+)	CALL	NUMBR	TEST.W	D4	JUMP,EQ 80$	PUSHM.L	D4,A4	LOAD.L	A4,#R16"06$	CALL	WRTEXT		; newtab	POPM.L	D4,A4	JUMP,NE 90$	LOAD.W	D2,#MAXTAB-150$:	AND.W	D4,#MASKTAB	CALL	WRNUMMX	JUMP,NE 90$	LOAD.B	D1,(A4+)	LOAD.B	D0,(A4+)	CALL	NUMBR	TEST.W	D4	JUMP',EQ 55$	DEC.W	D2	JUMP',EQ 55$	LOAD.B	D3,#',	CALL	WRONE	JUMP,NE 90$	JUMP	50$55$:	LOAD.B	D3,#';	CALL	WRONE	JUMP,NE 90$	LOAD.L	A4,#(A2)+OREGTAB	LOAD.B	D1,(A4+)	LOAD.B	D0,(A4+)	CALL	NUMBR	TEST.W	D4	JUMP,EQ 80$	PUSHM.L	D4,A4	LOAD.L	A4,#R16"07$	CALL	WRTEXT		; justtab	POPM.L	D4,A4	JUMP,NE 90$	LOAD.W	D2,#MAXTAB-160$:	LOAD.B	D3,#'i	TEST.L	D4:#BTABIND1	JUMP',BC 62$	TEST.L	D4:#BTABIND2	JUMP',BS 64$62$:	LOAD.B	D3,#'g	TEST.L	D4:#BTABGAU	JUMP',BS 64$	LOAD.B	D3,#'c	TEST.L	D4:#BTABCEN	JUMP',BS 64$	LOAD.B	D3,#'d	TEST.L	D4:#BTABNUM	JUMP',BS 64$	LOAD.B	D3,#'n64$:	CALL	WRONE	JUMP,NE 90$	LOAD.B	D1,(A4+)	LOAD.B	D0,(A4+)	CALL	NUMBR	TEST.W	D4	JUMP',EQ 70$	DEC.W	D2	JUMP',EQ 70$	LOAD.B	D3,#',	CALL	WRONE	JUMP,NE 90$	JUMP	60$70$:	LOAD.B	D3,#';	CALL	WRONE	JUMP',NE 90$80$:	LOAD.L	A4,#R16"08$	TEST.B	(A2)+OREGCOUP	JUMP',T 85$	LOAD.L	A4,#R16"09$85$:	CALL	WRTEXT		; coupe/nocoupe	JUMP',NE 90$	TEST.B	(A2)+OREGLAB	JUMP',EQ 90$	LOAD.L	A4,#R16"10$	CALL	WRTEXT		; label	JUMP',NE 90$	LOAD.B	D3,(A2)+OREGLAB	ADD.B	D3,#'A-1	CALL	WRONE	JUMP',NE 90$	LOAD.B	D3,#';	CALL	WRONE90$:	POPM.L	D0..D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	"<BOA>justif;"	.ASCIZ	"<BOA>drapeau;"	.ASCIZ	"<BOA>drapd;"	.ASCIZ	"<BOA>centre;"02$:	.ASCIZ	"<BOA>interligne "03$:	.ASCIZ	"<BOA>marge "04$:	.ASCIZ	"<BOA>large "05$:	.ASCIZ	"<BOA>renf "06$:	.ASCIZ	"<BOA>newtab "07$:	.ASCIZ	"<BOA>justtab "08$:	.ASCIZ	"<BOA>coupe;"09$:	.ASCIZ	"<BOA>nocoupe;"10$:	.ASCIZ	"<BOA>label "	.EVEN;---------\\; OUTIMAGE >;=========/; Ecrit une image sous forme d'une squence "boa".; in	A2.L	^dbut image; out	D7.W	erreur; mod	D7.WOUTIMAGE:	PUSHM.L	D0,D1,D3,D4,A4	LOAD.L	A4,#R16"01$	CALL	WRTEXT	JUMP',NE 90$	LOAD.L	A4,#(A2)+1	CALL	WRTEXT	JUMP',NE 90$	LOAD.L	A4,#R16"02$	CALL	WRTEXT	JUMP',NE 90$	LOAD.L	A4,A240$:	TEST.B	(A4+)	JUMP,NE	40$	LOAD.B	D1,(A4)+4	LOAD.B	D0,(A4)+5	CALL	NUMBR	ADD.W	D4,(A5)+OVREG+OREGRENF	CALL	WRNUMMX	JUMP',NE 90$	LOAD.L	A4,#R16"03$	CALL	WRTEXT90$:	POPM.L	D0,D1,D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	"<BOA>image "02$:	.ASCIZ	",1,"03$:	.ASCIZ	";<CR>"	.EVEN;----------\\; OUTGENCAR >;==========/; Ecrit les dfinitions de gencar sous forme de squences "boa".; in	-; out	D7.W	erreur; mod	D7.WOUTGENCAR:	PUSHM.L	D1..D4,A2..A4	LOAD.W	D1,(A5)+ONOBUF	; D1 <-- numro du buffer	LOAD.L	A2,#(A6)+OBUGC	LOAD.W	D2,#MAXGC-110$:	TEST.B	(A2)+OGCFLG:#BGCUSE ; gencar occup ?	JUMP,BC 50$		; non => 50$				; oui =>;;?	LOAD.L	D3,(A2)+OGCMAP;;?	TEST.L	D3:D1		; gencar utilis dans cette zone ?;;?	JUMP',BS 20$		; oui => 20$;;?				; non =>;;?	TEST.B	(A6)+OFANION+2:#BFANUM-8 ; numrote les pages ?;;?	JUMP,BC 50$		; non => 50$;;?	LOAD.L	A3,#(A2)+OGCTIT;;?	LOAD.L	A4,#(A6)+ODFNGC;;?15$:;;?	TEST.B	(A3);;?	JUMP',EQ 16$;;?	COMP.B	(A3+),(A4+)	; gencar pour numroter les pages ?;;?	JUMP,EQ 15$;;?	JUMP	50$;;?16$:;;?	TEST.B	(A4);;?	JUMP,NE 50$20$:	LOAD.L	A4,#R16"01$	CALL	WRTEXT	JUMP',NE 90$	LOAD.L	A4,#(A2)+OGCTIT	CALL	WRTEXT	JUMP',NE 90$	LOAD.L	A4,#R16"02$	CALL	WRTEXT	JUMP',NE 90$	LOAD.L	A4,#(A2)+OGCNAM	CLR.L	D430$:	INC.W	D4		; D4 <-- lg jusqu'au 1er chiffre	COMP.B	(A4+),#'0	JUMP,LO 30$	COMP.B	(A4)-1,#'9	JUMP,HI	30$	DEC.W	D4	LOAD.L	A4,#(A2)+OGCNAM	CALL	WRMANY		; crit la fonte et le style	JUMP',NE 90$	CLR.W	D4	LOAD.B	D4,(A2)+OGCT	CALL	WRNUMPY		; crit la taille	JUMP',NE 90$	LOAD.L	A4,#R16"03$	CALL	WRTEXT	JUMP',NE 90$50$:	LOAD.L	A2,#(A2)+LGGC	; A2 <-- ^gencar suivant	DECJ.W,NMO D2,10$	LOAD.L	A4,#R16"04$	CALL	WRTEXT		; met un "\\g_Fond;" au dbut !	JUMP',NE 90$	LOAD.L	A4,#(A6)+OBUGC+OGCTIT	CALL	WRTEXT	JUMP',NE 90$	LOAD.B	D3,#';	CALL	WRONE;	JUMP',NE 90$90$:	POPM.L	D1..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	"<BOA>define g_"02$:	.ASCIZ	":<BOA>"03$:	.ASCIZ	";<CR>"04$:	.ASCIZ	"<BOA>g_"	.EVEN;-----------\\; OUTCOMMAND >;===========/; Ecrit une commande sous forme d'une squence "boa".; in	A2.L	^dbut commande; out	D7.W	erreur; mod	D7.WOUTCOMMAND:	PUSHM.L	D3,D4,A4	CLR.W	D3	LOAD.B	D3,(A2)+1+LGCOM+OCOMNOG	COMP.B	D3,(A6)+OIOLNOG	; mme gencar ?	JUMP',EQ 50$		; oui => 50$				; non =>	LOAD.B	(A6)+OIOLNOG,D3	LOAD.L	A4,#R16"01$	CALL	WRTEXT	JUMP',NE 90$	LOAD.L	A4,#(A6)+OBUGC	MUL.WU	D3,#LGGC	ADD.L	A4,D3	LOAD.L	A4,#(A4)+OGCTIT	CALL	WRTEXT	JUMP',NE 90$	LOAD.B	D3,#';	CALL	WRONE	JUMP',NE 90$50$:	LOAD.B	D4,(A2)+1+LGCOM+OCOMMOD	LOAD.B	D3,(A6)+OIOLMOD	COMP.B	D4,D3		; mme mode ?	JUMP',EQ 90$		; oui => 90$				; non =>	XOR.B	D3,D4		; D3 <-- changement(s)	LOAD.B	(A6)+OIOLMOD,D4	TEST.L	D3:#BMODSOUL	; dbut/fin de soulign ?	JUMP',BC 60$		; non => 60$	LOAD.L	A4,#R16"02$	CALL	WRTEXT	JUMP',NE 90$60$:	TEST.L	D3:#BMODUP	; dbut/fin d'exposant ?	JUMP',BC 70$		; non => 70$	LOAD.L	A4,#R16"04$	; A4 <-- ^commande pour fin	TEST.B	(A6)+OIOLMOD:#BMODUP	JUMP',BC 65$	LOAD.L	A4,#R16"03$	; A4 <-- ^commande pour dbut65$:	CALL	WRTEXT	JUMP',NE 90$70$:	TEST.L	D3:#BMODDOWN	; dbut/fin d'indice ?	JUMP',BC 90$		; non => 90$	LOAD.L	A4,#R16"03$	; A4 <-- ^commande pour fin	TEST.B	(A6)+OIOLMOD:#BMODDOWN	JUMP',BC 75$	LOAD.L	A4,#R16"04$	; A4 <-- ^commande pour dbut75$:	CALL	WRTEXT;	JUMP',NE 90$90$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	"<BOA>g_"02$:	.ASCIZ	"<BOA>_"03$:	.ASCIZ	"<BOA>up;"04$:	.ASCIZ	"<BOA>down;"	.EVEN;-----------\\; OUTSAJEXMT >;===========/; Ecrit un espace variable sous forme d'une squence "boa".; in	A4.L	^dans buffer;	D3.W	SAJEX(M/T); out	A4.L	^plus loin;	D7.W	erreur; mod	D7.W, A4.LOUTSAJEXMT:	PUSHM.L	D3,D4	PUSH.L	A4	LOAD.L	A4,#R16"01$	CALL	WRTEXT	POP.L	A4	JUMP',NE 90$	CALL	MSVISU		; D4 <-- largeur de l'espace	.IF	ABS	ADD.W	D4,(A6)+OIOPOSL	; D4 <-- position absolue depuis dbut ligne !	LOAD.W	(A6)+OIOPOSL,D4	; avance dans la ligne	.ELSE	ADD.W	(A6)+OIOPOSL,D4	; avance dans la ligne	.ENDIF	CALL	WRNUMPX	JUMP',NE 90$	LOAD.B	D3,#';	CALL	WRONE90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET	.IF	ABS01$:	.ASCIZ	"<BOA>an "	.ELSE01$:	.ASCIZ	"<BOA>hn "	.ENDIF	.EVEN;----------\\; OUTSAJEXS >;==========/; Ecrit un espace variable sous forme d'une squence "boa".; in	A4.L	^dans buffer;	D3.W	SAJEXS; out	A4.L	^plus loin;	D7.W	erreur; mod	D7.W, A4.LOUTSAJEXS:	PUSHM.L	D3,D4	PUSH.L	A4	LOAD.L	A4,#R16"01$	CALL	WRTEXT	POP.L	A4	JUMP',NE 90$	CALL	MSVISU		; D4 <-- largeur de l'espace	.IF	ABS	ADD.W	D4,(A6)+OIOPOSL	; D4 <-- position absolue depuis dbut ligne !	LOAD.W	(A6)+OIOPOSL,D4	; avance dans la ligne	.ELSE	ADD.W	(A6)+OIOPOSL,D4	; avance dans la ligne	.ENDIF	CALL	WRNUMPX	JUMP',NE 90$	LOAD.B	D3,#';	CALL	WRONE90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET	.IF	ABS01$:	.ASCIZ	"<BOA>a "	.ELSE01$:	.ASCIZ	"<BOA>h "	.ENDIF	.EVEN;--------\; WROPEN  >;========/; Ouvre le fichier en sortie.; in	D6.W	canal; out	-; mod	-WROPEN:	LOAD.W	(A6)+OCHIO,D6	; mm. canal	CLR.W	(A6)+OPTIO	; buffer vide	RET;--------\\; WRNUMMX >;========/; Ecrit un nombre dcimal suivit d'un "mm" dans le fichier en sortie.; in	D4.W	nombre; out	D7.W	erreur; mod	D7.WWRNUMMX:	PUSHM.L	D3,D4	CALL	CONVPMX		; D4 <-- nombre [1/10mm]	JUMP'	WRNUMM2;--------\\; WRNUMMY >;========/; Ecrit un nombre dcimal suivit d'un "mm" dans le fichier en sortie.; in	D4.W	nombre; out	D7.W	erreur; mod	D7.WWRNUMMY:	PUSHM.L	D3,D4	CALL	CONVPMY		; D4 <-- nombre [1/10mm]WRNUMM2:	CONV.LA.WA D4		; D4 <-- .L positif ou ngatif	DIV.WA	D4,#10	CALL	WRNUM		; crit la partie entire	JUMP',NE 90$	SWAP.W	D4	TEST.W	D4	JUMP',EQ 50$	JUMP',NC 30$	NEG.W	D430$:	LOAD.B	D3,#'.	CALL	WRONE	JUMP',NE 90$	CALL	WRNUM		; crit la partie dcimale	JUMP',NE 90$50$:	LOAD.B	D3,#'m	CALL	WRONE	JUMP',NE 90$	LOAD.B	D3,#'m	CALL	WRONE90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRNUMPX >;========/; Ecrit un nombre dcimal suivit d'un "p" dans le fichier en sortie.; in	D4.W	nombre; out	D7.W	erreur; mod	D7.WWRNUMPX:	PUSHM.L	D3,D4;;?	MUL.WA	D4,(A6)+OFACX	CALL	WRNUM	JUMP',NE 90$	LOAD.B	D3,#'p	CALL	WRONE	JUMP',NE 90$	LOAD.B	D3,#'g	CALL	WRONE90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRNUMPY >;========/; Ecrit un nombre dcimal suivit d'un "p" dans le fichier en sortie.; in	D4.W	nombre; out	D7.W	erreur; mod	D7.WWRNUMPY:	PUSHM.L	D3,D4;;?	MUL.WA	D4,(A6)+OFACY	CALL	WRNUM	JUMP',NE 90$	LOAD.B	D3,#'p	CALL	WRONE	JUMP',NE 90$	LOAD.B	D3,#'g	CALL	WRONE90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRNUML  >;========/; Ecrit un nombre dcimal dans le fichier en sortie.; in	D4.L	nombre (positif et 32 bits); out	D7.W	erreur; mod	D7.WWRNUML:	PUSHM.L	D2..D4	LIB	?BINBCD		; D4 <-- nombre en BCD	LOAD.L	D2,#8-1		; D2 <-- nb max de digits10$:	RL.L	D4,#4	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- digit 0..9	JUMP',NE 20$	TEST.W	D2		; dernier digit ?	JUMP',EQ 20$		; oui => 20$	TEST.L	D2:#16	JUMP',BC 30$20$:	ADD.B	D3,#'0	CALL	WRONE		; crit un digit	JUMP',NE 90$	TSET.L	D2:#1630$:	DECJ.W,NMO D2,10$90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRNUM   >;========/; Ecrit un nombre dcimal dans le fichier en sortie.; in	D4.W	nombre (+/-); out	D7.W	erreur; mod	D7.WWRNUM:	PUSHM.L	D2..D4	TEST.W	D4		; nombre positif ?	JUMP',NC 05$		; oui => 05$	NEG.W	D4		; non =>	LOAD.B	D3,#'-	CALL	WRONE		; met un signe moins	JUMP',NE 90$05$:	AND.L	D4,#H'FFFF	LIB	?BINBCD		; D4 <-- nombre en BCD	LOAD.L	D2,#8-1		; D2 <-- nb max de digits10$:	RL.L	D4,#4	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- digit 0..9	JUMP',NE 20$	TEST.W	D2		; dernier digit ?	JUMP',EQ 20$		; oui => 20$	TEST.L	D2:#16	JUMP',BC 30$20$:	ADD.B	D3,#'0	CALL	WRONE		; crit un digit	JUMP',NE 90$	TSET.L	D2:#1630$:	DECJ.W,NMO D2,10$90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRTEXTN >;========/; Ecrit le n-ime texte termin par un zro dans le fichier en sortie.; in	A4.L	^textes<0>;	D4.B	rang du texte (0..n); out	D7.W	erreur; mod	D4.L, D7.W, A4.LWRTEXTN:10$:	TEST.B	D4	JUMP',EQ 50$	DEC.B	D420$:	TEST.B	(A4+)		; A4 <-- saute un texte<0>	JUMP,NE	20$	JUMP	10$50$:;	CALL	WRTEXT;	RET;--------\\; WRTEXT  >;========/; Ecrit un texte termin par un zro dans le fichier en sortie.; in	A4.L	^texte<0>; out	D7.W	erreur; mod	D4.L, D7.W, A4.LWRTEXT:	LOAD.L	D4,A410$:	TEST.B	(A4+)	JUMP,NE	10$	DEC.L	A4	EX.L	D4,A4		; A4 <-- ^dbut	SUB.L	D4,A4		; D4 <-- longueur;	CALL	WRMANY;	RET;--------\; WRMANY  >;========/; Ecrit plusieurs bytes dans le fichier de sortie.; in	A4.L	^bytes  crire;	D4.L	nombre de bytes  crire; out	D7.W	erreur; mod	D7.WWRMANY:	PUSHM.L	D3,D4,D6,A2..A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A3,A4		; A3 <-- ^bytes  crire	LOAD.W	D3,D4		; D3 <-- nombre	JUMP,EQ 90$10$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OPTIO	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer20$:	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4+),(A3+)	; buffer <-- un byte	INC.W	D4		; D4 <-- un byte de plus	DEC.W	D3	JUMP,NE	20$	LOAD.W	(A6)+OPTIO,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	TEST.B	(A6)+OFLIO3:#BIOPRINT	JUMP',BS 60$.	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OPTIO	; signal buffer vide	JUMP	10$60$:	LOAD.L	A2,(A6)+OCAPRINT ; A2 <-- canal	PRINTA_	WRPRINT		; imprime tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OPTIO	; signal buffer vide	JUMP	10$90$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\; WRONE   >;========/; Ecrit un byte dans le fichier de sortie.; in	D3.B	byte  crire; out	D7.W	erreur; mod	D7.WWRONE:	PUSHM.L	D4,D6,A2,A410$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OPTIO	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4),D3		; buffer <-- le byte	INC.W	D4		; D4 <-- un byte de plus	LOAD.W	(A6)+OPTIO,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	TEST.B	(A6)+OFLIO3:#BIOPRINT	JUMP',BS 60$	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OPTIO	; signal buffer vide	JUMP	10$60$:	LOAD.L	A2,(A6)+OCAPRINT ; A2 <-- canal	PRINTA_	WRPRINT		; imprime tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OPTIO	; signal buffer vide	JUMP	10$90$:	POPM.L	D4,D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; WRCLOSE >;========/; Ecrit le reste du fichier de sortie, puis ferme.; in	D7.W	ok/erreur; out	D7.W	erreur; mod	D7.WWRCLOSE:	PUSHM.L	D4..D6,A2,A4	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	LOAD.L	A2,(A6)+OCAPRINT ; A2 <-- canal	LOAD.W	D5,D7		; D5 <-- ok/erreur	JUMP',NE 50$		; erreur => 50$				; ok =>	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^buffer tampon	CLR.L	D4	LOAD.W	D4,(A6)+OPTIO	; D4 <-- nb bytes dans buffer	JUMP',EQ 50$		; si vide => 50$				; si reste qq chose =>	TEST.B	(A6)+OFLIO3:#BIOPRINT	JUMP',BS 40$	FOS	?WRBYTE		; crit tout le buffer	LOAD.W	D5,D7	JUMP'	50$40$:	PRINTA_	WRPRINT		; imprime tout le buffer	LOAD.W	D5,D750$:	TEST.B	(A6)+OFLIO3:#BIOPRINT	JUMP',BS 55$	FOS	?CLOSE		; ferme le fichier	JUMP'	60$55$:	PRINTA_	CLPRINT		; ferme l'imprimante60$:	COMP.W	D7,D5	JUMP',HS 90$	LOAD.W	D7,D5		; D7 <-- erreur la plus grve !90$:	POPM.L	D4..D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRFILES >;========/; Ecrit le fichier "!" contenant la liste des images utilises.; Exemple de fichier :;	TOTO!TEXT/D -CL;	TOTO.TEXT/D -C+L;	GEOM.IMAGE/M;	SMAKY.IMAGE/M;	...; in	A3.L	^nom du fichier texte; out	D7.W	erreur; mod	D7.WWRFILES:	PUSHM.L	D2..D4,D6,A1..A4; Met le nom du texte dans OBUOUTF pour pouvoir le dmolir; et le remolir (mais oui)  volont !	LOAD.L	A1,#(A6)+OBUOUTF10$:	LOAD.B	D3,(A3+)	JUMP',EQ 12$	COMP.B	D3,#CR	JUMP',EQ 12$	LIB	?MINMAJ	LOAD.B	(A1+),D3	; OBUOUTF <-- nom complet	JUMP	10$12$:	CLR.B	(A1)		; OBUOUTF <-- terminateur; Construit le nom en remplaant le "." par "!", puis dtruit; l'ventuel ancien fichier.	LOAD.L	A3,#(A6)+OBUOUTF14$:	COMP.L	A1,A3	JUMP',EQ 17$	LOAD.B	D3,(-A1)	COMP.B	D3,#':	JUMP',EQ 16$	COMP.B	D3,#'.	JUMP,NE 14$	LOAD.B	(A1),#'!	; remplace le "." par "!"	JUMP	14$16$:	INC.L	A1		; A1 <-- ^dbut du nom (sans unit:rep:rep:)17$:	FOS	?DELETE		; dtruit l'ancien fichier "!"; Prpare le contenu du fichier "!".	LOAD.L	A4,(A5)+OPDB	; A4 <-- ^dbut du texte	LOAD.L	A3,#R16"01$	; A3 <-- ^en-tte sans images20$:	CALL	TNVISU		; D3 <-- caractre suivant	JUMP',NE 22$	COMP.B	D3,#IMAGE	; est-ce une image ?	JUMP,NE 20$		; non => 20$	CALL	TPVISU	LOAD.L	A3,#R16"00$	; A3 <-- ^en-tte avec image(s)22$:	LOAD.L	A2,#(A6)+OTMIO25$:	LOAD.B	(A2+),(A3+)	; OTMIO <-- en-tte	JUMP,NE 25$	DEC.L	A2; Met d'abord le nom du fichier "!" lui-mme (NOM!TEXT).	PUSH.L	A130$:	LOAD.B	D3,(A1+)	JUMP',EQ 31$;	.W	LIB,?MINMAJ	LOAD.B	(A2+),D3	; OTMIO <-- NOM!TEXT/D -CL	JUMP	30$31$:	LOAD.L	A3,#R16"02$32$:	LOAD.B	(A2+),(A3+)	; OTMIO <-- "/D -CL<CR>"	JUMP,NE 32$	DEC.L	A2	POP.L	A1; Met ensuite le nom du fichier texte (NOM.TEXT).	PUSH.L	A135$:	LOAD.B	D3,(A1+)	JUMP',EQ 36$;	.W	LIB,?MINMAJ	LOAD.B	(A2+),D3	; OTMIO <-- NOM.TEXT/D -C+L	COMP.B	D3,#'!	JUMP,NE 35$	LOAD.B	(A2)-1,#'.	JUMP	35$36$:	LOAD.L	A3,#R16"03$37$:	LOAD.B	(A2+),(A3+)	; OTMIO <-- "/D -C+L<CR>"	JUMP,NE 37$	DEC.L	A2	POP.L	A1; Met les noms de toutes les images utilises dans le texte.40$:	LOAD.L	A3,A4	CALL	TNVISU		; D3 <-- caractre suivant	JUMP,NE 50$	COMP.B	D3,#IMAGE	; est-ce une image ?	JUMP,NE 40$		; non => 40$				; oui =>	INC.L	A3		; A3 <-- saute DEBIMA	CALL	SKIPREP		; A3 <-- saute unit:rep:rep:42$:	LOAD.B	D3,(A3+)	JUMP',EQ 43$	LIB	?MINMAJ	LOAD.B	(A2+),D3	; OTMIO <-- fichier.IMAGE	JUMP	42$43$:	LOAD.L	A3,#R16"04$45$:	LOAD.B	(A2+),(A3+)	; OTMIO <-- ".IMAGE/1<CR>"	JUMP,NE 45$	DEC.L	A2	JUMP	40$; Met les noms de tous les gencars dans le fichier "!".50$:	LOAD.L	A4,#(A6)+OBUGC	LOAD.W	D2,#MAXGC-1	CLR.L	(A6)+OBUDIS	; aucun gencar rencontr60$:	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar occup ?	JUMP,BC 65$		; non => 65$				; oui =>	LOAD.L	D4,(A4)+OGCCOD	; D4 <-- "-fst"	AND.L	D4,#H'00FFFFFF	TCLR.L	D4:#16+7	; gencar calcul ?	JUMP',BC 61$		; non => 61$	AND.W	D4,#H'80FF	OR.W	D4,#H'100*'R	; D4 <-- met un style "roman"61$:	CALL	GCEXIST		; gencar dj rencontr ?	JUMP,EQ 65$		; oui => 65$	LOAD.L	A3,#R16"05$62$:	LOAD.B	(A2+),(A3+)	; OTMIO <-- "SMA_"	JUMP,NE 62$	DEC.L	A2	LOAD.L	A3,A2	DGENC_	PUT		; OTMIO <-- "fsctt"63$:	LOAD.B	D3,(A2)	LIB	?MINMAJ	LOAD.B	(A2+),D3	JUMP,NE 63$	DEC.L	A2	LOAD.L	A3,#R16"06$64$:	LOAD.B	(A2+),(A3+)	; OTMIO <-- ".GENC/N/2<CR>"	JUMP,NE 64$	DEC.L	A265$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^gencar suivant	DECJ.W,NMO D2,60$; Ecrit le fichier "!" sur disque, d'un seul coup pour tre rapide.	LOAD.L	A3,#(A6)+OBUOUTF	LOAD.L	D3,#DEFATT-(2^BATTL)	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le nouveau fichier "!"	JUMP',NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier "!"	JUMP',NE 90$	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut du data	LOAD.L	D4,A2	SUB.L	D4,A4		; D4 <-- lg du data	FOS	?WRBYTE		; crit le fichier "!"	JUMP',NE 80$	FOS	?CLOSE		; ferme le fichier "!"	JUMP'	90$80$:				; erreur =>	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier "!"	POP.W	D790$:	POPM.L	D2..D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.ASCII	'"images colles dans le texte"/1/A<CR>'01$:	.ASCIZ	'"gnrateurs de caractres"/2/E<CR>'02$:	.ASCIZ	"/D -CL<CR>"03$:	.ASCIZ	"/D -C+L<CR>"04$:	.ASCIZ	".IMAGE/1<CR>"05$:	.ASCIZ	"SMA_"06$:	.ASCIZ	".GENC/N/2<CR>"	.EVEN;--------\\; GCEXIST >;========/; Regarde si le gencar a dj t rencontr une fois.; in	D4.L	"-fst"; out	D7.W	EQ si existe dj; mod	D7.WGCEXIST:	PUSH.L	A4	LOAD.L	A4,#(A6)+OBUDIS10$:	TEST.L	(A4)		; fin ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.L	D4,(A4+)	; gencar trouv ?	JUMP,NE 10$		; non => 10$				; oui =>	CLR.W	D7		; D7 <-- gencar trouv	JUMP'	90$50$:	LOAD.L	(A4+),D4	; OBUDIS <-- gencar	CLR.L	(A4)		; OBUDIS <-- terminateur	LOAD.W	D7,#1		; D7 <-- gencar n'existe pas90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SKIPREP >;========/; Saute tous les noms d'units et de rpertoires devant; un nom de fichier.; in	A3.L	^unit:rp:rp:nom.ext; out	A3.L	^nom.ext; mod	A3.LSKIPREP:	PUSH.W	D3	CLR.W	D310$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE 10$20$:	DEC.W	D3	JUMP,NS 90$	COMP.B	(-A3),#':	JUMP,NE 20$	INC.L	A390$:	POP.W	D3	RET	.END