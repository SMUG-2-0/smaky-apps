	.TITLE	EPRO.ASS	.PROC		M68000		; mnmonics CALM	.BASE		10'10		; base 10 par dfaut; Numros des appels; ------------------	.SYSCALL.16	EPRO_EPRO_OPEN	=	16'A840		; creuse le trouEPRO_MAIN	=	16'A841		; ditionEPRO_CLOSE	=	16'A842		; bouche le trouEPRO_NVISU	=	16'A843		; observe le caractre suivantEPRO_PVISU	=	16'A844		; observe le caractre prcdentEPRO_VAFIN	=	16'A845		; va au dbutEPRO_VADEBUT	=	16'A846		; va  la finEPRO_AVANCE	=	16'A847		; avance d'un caractreEPRO_RECULE	=	16'A848		; recule d'un caractreEPRO_INSERT	=	16'A849		; insre un caractreEPRO_DAVANCE	=	16'A84A		; dtruit un caractre en avantEPRO_DRECULE	=	16'A84B		; dtruit un caractre en arrireEPRO_FLUSH	=	16'A84C		; dtruit tout le texteEPRO_GETPTC	=	16'A84D		; donne le caractre sous le curseurEPRO_IFEOL	=	16'A84E		; est-ce une fin de ligne ?EPRO_EXTEND	=	16'A84F		; appels supplmentairesEPRO_FIRST	=	EPRO_OPENEPRO_LAST	=	EPRO_EXTEND; Appels supplmentaires; ----------------------EPRO_GETPDBUFF	=	1		; donne le ^descripteur du bufferEPRO_AFFBUF	=	2		; reaffiche l'cranEPRO_VAPOSN	=	3		; va au nime caractreEPRO_AFFINFO	=	4		; affiche la ligne d'information;EPRO_UNDO	=	5		; fait comme la touche UNDOEPRO_SETMODE	=	6		; met le mode d'affichage (TAB,CR,LF)EPRO_UPDATE	=	7		; reaffiche l'cranEPRO_AFFSCROLL	=	8		; raffiche l'ascenseur; Modes d'utilisation; -------------------BEPRONI		=	0		; n'affiche pas les informationsBEPROCL		=	1		; A5 ^les 3 classesBEPRONEOT	=	2		; pas le caractre de fin de texte (eot)BEPROTXT	=	3		; A1 ^nom de l'diteur ou 0BEPROQUITTE	=	4		; quitte aprs chaque actionBEPROMOUSE	=	5		; utilise la souris et l'ascenseurBEPROILMIN	=	6		; utilise un interligne minimalBEPROAFCR	=	7		; affiche les CRBEPROAFLF	=	8		; affiche les LFBEPROAFTAB	=	9		; affiche les TABsBEPRONOUT	=	10		; n'affiche pas le nb. de car. utilissBEPRONORE	=	11		; n'affiche pas le nb. de car. restantsBEPROPCENT	=	12		; affiche le %tage utilisBEPRONOMOD	=	13		; interdit les modificationsBEPROAUTOC	=	14		; R,C,D,F,E,T,X,V font comme CURSOR-(R,C,D...)BEPROEXTEND	=	15		; extension de D4  32 bitsBEPROCURSTR	=	16		; curseur traitBEPROCURSBL	=	17		; curseur bloc; Constantes diverses; -------------------EPROMODCUR	=	1		; curseur dplacEPROMODLIN	=	2		; ligne modifieEPROMODALL	=	3		; tout modifi; Erreurs de l'diteur; --------------------EREOB	=		16'9601		; fin du bufferERBOB	=		16'9602		; dbut du bufferERHOL	=		16'9603		; trou rencontrERPDP	=		16'9604		; plus de placeERNOT	=		16'9605		; pas trouv; Descripteur d'un buffer; -----------------------	.LOC	0OEPROPDB:	.BLK.32	1		; ^dbut du bufferOEPROPDT:	.BLK.32	1		; ^dbut du trouOEPROPFT:	.BLK.32	1		; ^fin du trouOEPROPFB:	.BLK.32	1		; ^fin du buffer	.LOC	16'1BOEPROSTATUS:	.BLK.8	1		; status du buffer BEPROFILMOD =  0			;  texte sur disque pas  jour;-----------\\; EPRO_OPEN  >;===========/; Dbut d'dition du texte.; Creuse le buffer de texte et affiche une premire fois; le texte et les informations.; in	A3.32	^dbut du texte (termin par zro);	A4.32	^position du curseur;	D3.32	longueur max du buffer;	D4.16	mode (2**BEPRONI.OR.2**BEPROCL);	 2**BEPRONO	n'affiche pas les informations;	 2**BEPROCL	A5.32 ^table des classes;	 2**BEPRONEOT	n'affiche pas le caractre de fin de texte;	 2**BEPROTXT	A0, A1, A2 ^texte d'information (-NEW-);	 2**BEPROQUITTE	quitte EPRO_MAIN aprs chaque action (-NEW-);	 2**BEPROMOUSE	utilise l'ascenseur et la souris (-NEW-);	 2**BEPROILMIN	utilise un interligne minumal (-NEW-);	 2**BEPROAFCR	affiche les retours de chariot (-NEW-);	 2**BEPROAFLF	affiche les line-feed (-NEW-);	 2**BEPROAFTAB	affiche les tabulateurs (-NEW-);	 2**BEPROPCENT	affiche le nb. de car. utiliss en pourcent (-NEW-);	 2**BEPRONORE	n'affiche pas le nb. de car. rstants (-NEW-);	 2**BEPRONOUT	n'affiche pas le nb. de car. utiliss (-NEW-);	 2**BEPRONOMOD	interdit les modifications (-NEW-);	 2**BEPROAUTOC  en combinaison avec BEPRONOMOD, si l'on presse sur;			R,D,C,F,E,T,S,G,X,V, a fait comme CURSOR-(R,D,C,F...);	A5.32	si 2**BEPROCL=1 (-NEW-);		^<SPACE>classe1<0><CR>classe2<0><EOP>classe3<0>;	A1.32	si 2**BEPROTXT=1 (-NEW-);		^le nom affiche tout  gauche de la ligne d'information;	A0.32	si 2**BEPROTXT=1 (-NEW-);		^le texte affich entre le nom tout  gauche et l'affichage;		 du nombre de caractres utiliss;	A2.32	si 2**BEPROTXT=1 (-NEW-);		^le texte affich aprs l'affichage du nombre de;		caractres utiliss; out	D6.32	canal;	D7.16	erreur; mod	D6.32, D7.16; La classe 1 dlimite les "mots" (CURSOR-S), (CURSOR-G), etc.; La classe 2 dlimite les "lignes" (CURSOR-R), (CURSOR-C), etc.; La classe 3 dlimite les "pages" (CURSOR-W), (CURSOR-Y), etc.; Exemple :;;TACLASSES:;	.ASCIZ	"<SPACE><TAB>,.;:!?"	; classe 1;	.ASCIZ	"<CR>"			; classe 2;	.ASCIZ	"<EOP>"			; classe 3;	.EVEN;; Ligne d'information:;; A1		  A0				       A2; |		  |				       |; START 5.8       Zone: 2    Utilis: 12345  10%       "toto.asm";;-----------\\; EPRO_MAIN  >;===========/; Edite le texte jusqu' ce qu'une touche invalide soit; lue du clavier.; in	D6.32	canal;	A4.32	^touches terminatrices (.8.8 f,c puis .16 0); out	D7.16	zro => ok;	 D3.16	 dernire touche presse;	D7.16	ERPDP => buffer plein; mod	D3.32, D7.16; Exemple :;;TATERM:;	.8	0,TAB;	.8	2**BCURSOR,"R";	.8	2**BCURSOR,"C";	.16	0;-----------\\; EPRO_CLOSE >;===========/; Termine l'dition d'un texte.; Bouche le buffer et ferme tout.; in	D6.32	canal; out	A3.32	^dbut du texte (termin par zro);	A4.32	^position du curseur;	D3.32	longueur max du buffer; mod	D3.32, D7.16, A3.32, A4.32;------------\\; EPRO_VAFIN  >;============/; Avance jusqu' la fin.; in	D6.32	canal; out	-; mod	D7.16;-------------\\; EPRO_VADEBUT >;=============/; Recule jusqu'au dbut.; in	D6.32	canal; out	-; mod	D7.16;------------\\; EPRO_AVANCE >;============/; Avance d'un caractre.; in	D6.32	canal; out	D7.16	zro =>;	 D3.8	 caractre avanc;	D7.16	EREOB => fin du buffer; mod	D3.16, D7.16;------------\\; EPRO_RECULE >;============/; Recule d'un caractre.; in	D6.32	canal; out	D7.16	zro =>;	 D3.8	 caractre recul;	D7.16	ERBOB => dbut du buffer; mod	D3.16, D7.16;------------\\; EPRO_INSERT >;============/; Insre un caractre.; in	D6.32	canal;	D3.8	caractre  insrer; out	D7.16	zro => ok;	D7.16	ERPDP => buffer plein; mod	D7.16;-------------\\; EPRO_DAVANCE >;=============/; Dtruit un caractre en avant.; in	D6.32	canal; out	D7.16	zro =>;	 D3.8	 caractre dtruit;	D7.16	EREOB => fin du buffer; mod	D3.16, D7.16;-------------\\; EPRO_DRECULE >;=============/; Dtruit un caractre en arrire.; in	D6.32	canal; out	D7.16	zro =>;	 D3.8	 caractre dtruit;	D7.16	ERBOB => dbut du buffer; mod	D3.16, D7.16;------------\\; EPRO_FLUSH  >;============/; Vide compltement le texte.; in	D6.32	canal; out	-; mod	D7.16;------------\\; EPRO_GETPTC >;============/; Donne le caractre sous le curseur et le pointeur; pour NVISU et PVISU.; in	D6.32	canal; out	A4.32	^pour NVISU et PVISU;	D7.16	zro => ok;	 D3.8	 caractre;	D7.16	EREOB => fin du buffer; mod	D3.16, D7.16, A4.32;------------\\; EPRO_NVISU  >;============/; Observe le caractre suivant.; in	D6.32	canal;	A4.32	^dans un buffer; out	D7.16	zro =>;	 D3.8	 caractre;	 A4.32	 ^plus loin;	D7.16	ERHOL => trou rencontr (et saut);	 A4.32	 ^plus loin;	D7.16	EREOB => on ne peut plus avancer; mod	D3.16, D7.16, A4.32;------------\\; EPRO_PVISU  >;============/; Observe le caractre prcdent.; in	D6.32	canal;	A4.32	^dans un buffer; out	D7.16	zro =>;	 D3.8	 caractre;	 A4.32	 ^moins loin;	D7.16	ERHOL => trou rencontr (et saut);	 A4.32	 ^moins loin;	D7.16	ERBOB => on ne peut plus reculer; mod	D3.16, D7.16, A4.32;------------\\; EPRO_IFEOL  >;============/; Test si un caractre est une fin de ligne.; in	D6.32	canal; in	D3.8	caractre; out	EQ	fin de ligne;	NE	autre chose; mod	-;-------------\\; EPRO_EXTEND  >	(EPRO_GETPDBUFF) (-NEW-);=============/; Permet de connatre le pointeur au descripteur du buffer de texte.; in	D1.16	#EPRO_GETPDBUFF;	D6.32	canal; out	A5.32	^descripteur du buffer de texte; mod	A5.32;-------------\\; EPRO_EXTEND  >	(EPRO_AFFBUF) (-NEW-);=============/; Refait compltement l'cran. Ceci est utile si l'cran a t effac pour; une raison ou une autre.; in	D1.16	#EPRO_AFFBUF;	D6.32	canal; out	-; mod	D7.16;-------------\\; EPRO_EXTEND  >	(EPRO_AFFINFO) (-NEW-);=============/; Reaffiche la ligne d'information.; in	D1.16	#EPRO_AFFBUF;	D6.32	canal; out	-; mod	D7.16;-------------\\; EPRO_EXTEND  >	(EPRO_VAPOSN) (-NEW-);=============/; Positionne le curseur sur le nime caractre du texte.; in	D1.16	#EPRO_VAPOSN;	D4.32	position du curseur;	D6.32	canal; out	D7.16	erreur; mod	D7.16;-------------\\; EPRO_EXTEND  >	(EPRO_SETMODE) (-NEW-);=============/; Change le mode d'affichage pour les line-feed, retours de chariot et tabulateurs.; in	D1.16	#EPRO_SETMODE;	D4.16	bits de mode;	 2**BEPROAFCR	affiche les retours de chariot;	 2**BEPROAFLF	affiche les line-feed;	 2**BEPROAFTAB	affiche les tabulateurs;	D6.32	canal; out	-; mod	-;-------------\\; EPRO_EXTEND  >	(EPRO_UPDATE) (-NEW-);=============/; Reaffiche le text en affichant le minimum ; in	D1.16	#EPRO_UPDATE;	D6.32	canal;	D4.8	degr de modification;	 #0           automatique;	 #EPROMODCUR  curseur dplac;	 #EPROMODLIN  ligne modifie;	 #EPROMODALL  tout modifi; out	-; mod	-;-------------\\; EPRO_EXTEND  >	(EPRO_AFFSCROLL) (-NEW-);=============/; Reaffiche l'ascenseur; in	D1.16	#EPRO_AFFSCROLL;	D6.32	canal; out	-; mod	-	.END