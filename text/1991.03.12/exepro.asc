	.TITLE	EXEPRO;	Daniel Roux	.PROC	M680002	.RADIX	10.	.HEX	.REF	SM8	.REF	NTREL	.REF	GESMEM	.REF	BIOS	.REF	FOS	.REF	LIB	.REF	DRIVERS	.REF	EPRO	.CODE	500,11,B'111,20,2000,20,2000,2,'*,0,0; Variables en (A6); -----------------LBUFFER	=	500	.LOC	0OCHEPRO:.BLKB	2		; canal module EPROOBUFFER:.BLKB	LBUFFER		; buffer pour le texteLGVAR:; Dbut du code; -------------	.LOC	0START:	.W	LIB,?OPELIB	; ouvre la librairie ...	LOAD.W	D3,#2	.W	LIB,?MOUSE	; souris par le clavier	LOAD.L	D4,#LGVAR	; D4 <-- longueur ncessaire	LOAD.W	D1,#MTYPCP	; D1 <-- pour processus courant	.W	GESMEM,?GETMEM	; demande mmoire pour var	JUMP,NE ERFAT1		; plein => erreur fatale	LOAD.L	A6,A4		; A6 <-- ^variables (TOUJOURS)10$:	CLR.B	(A4+)		; rempli TOUTES les variables	DEC.W	D4		; avec des zro !	JUMP,NE	10$	LOAD.L	A3,#R16"NAMEPRO	LOAD.W	D3,#EPRO_FIRST	.W	LIB_OPEN	; ouvre le module EPRO	JUMP,NE	ERFAT2	LOAD.W	(A6)+OCHEPRO,D1	LOAD.L	D3,#H'AAAA5555	LOAD.L	D4,#H'AAAA5555	.W	LIB,?DRMDEF	; dfinit la trame	.W	LIB,?GETDIM	; D4 <-- dimensions fentre	CLR.L	D3		; D3 <-- origine sup/gauche	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	.W	LIB,?DRMATRIX	; rempli tout par la trame	.W	LIB,?GETDIM	LOAD.W	D3,#50	SWAP.W	D3	LOAD.W	D3,#50	SUB.W	D4,#50*2	SWAP.W	D4	SUB.W	D4,#50*2	SWAP.W	D4	.W	LIB,?CREWDO	; cre swdo	.W	LIB,?USEWDO	; utilise swdo	LOAD.L	A3,#R16"TXMENU	.W	LIB,?AFMENU	; affiche les soft-keys	LOAD.L	A3,#(A6)+OBUFFER	LOAD.L	A4,#R16"TXTEST50$:	LOAD.B	(A3+),(A4+)	; OBUFFER <-- texte de test	JUMP,NE	50$	LOAD.L	A3,#(A6)+OBUFFER	LOAD.L	A4,#(A3)+10	LOAD.L	D3,#LBUFFER;	CLR.W	D4	LOAD.W	D4,#2^BEPRONI	.W	EPRO_OPEN	; dbut d'dition	JUMP,NE	ERFAT2LOOP:	LOAD.L	A4,#R16"TATERM	; A4 <-- ^touches terminatrices	.W	EPRO_MAIN	; dite ...	JUMP,NE	40$	COMP.W	D3,#END	JUMP,EQ	RETOUR	COMP.W	D3,#F0	JUMP,EQ	RETOUR	COMP.W	D3,#F0+SHIFT	JUMP,EQ	RETOUR	LOAD.L	A4,#R16"TXMM0	COMP.W	D3,#F1	JUMP,EQ	50$	COMP.W	D3,#STAB	JUMP,EQ	50$	LOAD.L	A4,#R16"TXMM1	COMP.W	D3,#F2	JUMP,EQ	50$	COMP.W	D3,#TAB	JUMP,EQ	50$	LOAD.L	A4,#R16"TXMM2	COMP.W	D3,#F3	JUMP,EQ	50$	COMP.W	D3,#CTAB	JUMP,EQ	50$40$:	LOAD.B	D3,#BIPLIT	.W	LIB,?BEEP	; p'tit bruit	JUMP	LOOP50$:				; insre " #mm?:"	LOAD.B	D3,(A4+)	JUMP,EQ	LOOP	.W	EPRO_INSERT	; insre un caractre	JUMP	50$RETOUR:	.W	EPRO_CLOSE	; fin d'ditionERFAT2:	LOAD.W	D1,(A6)+OCHEPRO	.W	LIB_CLOSE	; ferme le module EPROERFAT1:	.W	LIB,?CLOLIB	; ferme la librairie	.W	FOS,?STOP	; c'est fini ...NAMEPRO:.ASCIZ	"EPRO"		; nom du module LIBTXTEST:	.ASCIZ	"Essai du module SYS_EPRO.LIB"TXMENU:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"#mm0: #mm1: #mm2:"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TXMM0:	.ASCIZ	" #mm0:"TXMM1:	.ASCIZ	" #mm1:"TXMM2:	.ASCIZ	" #mm2:"	.EVENTATERM:	.BB	0,TAB	.BB	0,STAB	.BB	0,CTAB	.W	0	.END	START