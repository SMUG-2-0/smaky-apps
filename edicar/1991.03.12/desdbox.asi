	.SBTTL	DESDBOX;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut;	D2.W	mode; out	D2.W	mode;	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXEDITO:	PUSHM.L	D1,D4,A2..A5	TEST.B	(A3)		; nom du fichier existe ?	JUMP',EQ 10$		; non => 10$				; oui =>	CLR.W	D7		; D7 <-- ok	LOAD.W	D3,#F1		; D3 <-- comme si (SAUVE)	TEST.L	D2:#BDBAUTO	; mode automatique ?	JUMP,BS	90$		; oui => 90$10$:	CALL	DBOXOPEN1	LOAD.W	D4,D2		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_SAUVE	LOAD.L	A3,#R16"TDBOX_IO	.IF	DESSIN	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^critre de recherche (extension)	.ELSE	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^critre de recherche (extension)	.ENDIF	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	TSET.L	D2:#BDBEXTEND	; D2 <-- sous-appel d'extension	TSET.L	D2:#BDBSAV	; D2 <-- sauve le fond	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXT1	TEST.L	D2:#BDBNMAJ	JUMP',BC 30$	TSET.L	D3:#BDBIONMAJ	; D3 <-- touche (MET A JOUR) grise30$:	DBOX_	EXTEND		; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITE >;==========/; Edite un nom de fichier en sortie (extraction).; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXEDITE:	PUSHM.L	D1,D2,D4,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_SAUVE	LOAD.L	A3,#R16"TDBOX_IO	.IF	DESSIN	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^critre de recherche (extension)	.ELSE	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^critre de recherche (extension)	.ENDIF	LOAD.W	D1,#DBOX_EXTRAIT; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre (prend).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	.IF	DESSIN	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^critre de recherche (extension)	.ELSE	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^critre de recherche (extension)	.ENDIF	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITA >;==========/; Edite un nom de fichier en entre (ajoute).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITA:	PUSHM.L	D1,D2,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	.IF	DESSIN	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^critre de recherche (extension)	.ELSE	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^critre de recherche (extension)	.ENDIF	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,A2..A5	TEST.W	D7		; retour EQ/NE	RET	.IF	EDGAR;-----------\\; DBOXEDITIM >;===========/; Edite un nom d'image en entre.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITIM:	PUSHM.L	D1,D2,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOIM	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,A2..A5	TEST.W	D7		; retour EQ/NE	RET	.ENDIF;---------\\; DBOXSAVE >;=========/; Sauve le dessin selon le choix de l'utilisateur.; in	D0.W	mode (0=quitte, 1=nouveau texte); out	D7.W	0	=> ok, on peut quitter;		1	=> (ANNULE), donc on reste;		autre	=> erreur grve; mod	D7.WDBOXSAVE:	PUSHM.L	D1..D4,A2..A5	TEST.B	(A6)+OMAJ	; mise  jour ncessaire ?	JUMP,F	80$		; non => 80$ (quitte, snif)				; oui =>	CALL	IFVIDE		; dessin vide ?	JUMP',NE 10$		; non => 10$				; oui =>	CLR.B	(A6)+OMAJ	; fait comme si dessin  jour	JUMP	80$10$:	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	.IF	DESSIN	LOAD.W	D3,(A6)+ONOZO	INC.B	D3		; D3 <-- numro de la page  afficher	COMP.B	D3,#NBZONE	JUMP',NE 20$	CLR.B	D320$:	.ENDIF	TEST.B	D0	JUMP',NE 25$	TSET.L	D3:#BDBIOQUIT	; D3 <-- texte "avant de quitter"25$:	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_SAUVE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_MAJ	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	TSET.L	D3:#BDBIOOBJ	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 85$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$	OR.W	D2,D4		; D2 <-- met aussi les fanions (pour BDBDEF)	CALL	SAUVETOUT	; sauve tout sur disque (in D2.W !)	JUMP'	90$80$:	CLR.W	D7		; D7 <-- quitte	JUMP'	90$85$:	LOAD.W	D7,#1		; D7 <-- reste90$:	POPM.L	D1..D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande si l'on veut quitter DESSIN.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXQUITTE:	PUSHM.L	D1,D2,D4,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer le dessin.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXEFFACE:	PUSHM.L	D1,D2,D4,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	.IF	DESSIN	LOAD.W	D3,(A6)+ONOZO	INC.B	D3		; D3 <-- numro de la page  afficher	COMP.B	D3,#NBZONE	JUMP',NE 20$	CLR.B	D320$:	.ENDIF	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXTDEF >;=========/; Dfini une trame 8x8 quelconque.; in	-; out	D7.W	erreur; mod	D7.WDBOXTDEF:	PUSHM.L	D2..D4,A2..A4	.IF	DESSIN	CALL	ERGMOUSE	; efface les flches dans les rgles	.ENDIF	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.L	D2,#2^BDBSAV	LOAD.W	D4,(A6)+ONTDEF	LOAD.L	A4,#(A6)+OTDEF	LOAD.L	A3,#R16"00$	DESSIN_	TEDIT		; dite les trames ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	LOAD.W	(A6)+ONTDEF,D490$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	POPM.L	D2..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0,0,0	.EVEN;---------\\; DBOXPDEF >;=========/; Dfini un pinceau 8x8 quelconque.; in	-; out	D7.W	erreur; mod	D7.WDBOXPDEF:	PUSHM.L	D2..D4,A2..A4	.IF	DESSIN	CALL	ERGMOUSE	; efface les flches dans les rgles	.ENDIF	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.L	D2,#2^BDBSAV	LOAD.W	D4,(A6)+ONPDEF	LOAD.L	A4,#(A6)+OPDEF	LOAD.L	A3,#R16"00$	DESSIN_	DEDIT		; dite les pinceaux ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	LOAD.W	(A6)+ONPDEF,D490$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	POPM.L	D2..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0,0,0	.EVEN;----------\\; DBOXRDEF  >;==========/; Dbox pour le choix du rayon des rectangles arrondis.; in	-; out	D7.W	erreur; mod	D7.WDBOXRDEF:	PUSHM.L	D0..D5,A1..A4	LOAD.L	A1,#R16"TVAL_RRECT	LOAD.W	D3,(A6)+ORRECT	LOAD.L	D4,#2^005$:	TEST.W	(A1)	JUMP',EQ 10$	COMP.W	D3,(A1+)	JUMP',EQ 10$	SL.B	D4,#1	JUMP	05$10$:	LOAD.L	A2,#R16"TDBOX_RRECT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A1,#R16"TVAL_RRECT	CLR.W	D215$:	LOAD.W	D0,(A1+)	; D0 <-- rayon	JUMP',EQ 20$	CALL	DBDESRRECT	INC.W	D2		; D2 <-- rang suivant dans dbox	JUMP	15$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_RRECT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	LOAD.L	A1,#R16"TVAL_RRECT82$:	LOAD.W	D3,(A1+)	JUMP',EQ 85$	RR.B	D4,#1	JUMP,CC 82$85$:	LOAD.W	(A6)+ORRECT,D3	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBDESRRECT >;-----------/; Dessine un rectangle arrondi dans la dbox.; in	D2.W	rang ODBCIRCLE dans dbox;	D0.W	rayon; out	-; mod	D7.WDBDESRRECT:	PUSHM.L	D2..D4	DBOX_	GETCO	LOAD.L	D3,D4		; D3 <-- <xx>	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#5	ADD.W	D4,D2		; D4 <-- <xx>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A0)+ODFCY	SR.W	D2,#2	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,D2		; D3 <-- <yy>	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,D2		; D4 <-- <yy>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	CALL	RRECTANGLE	POPM.L	D2..D4	RET;----------\\; DBOXADEF  >;==========/; Dbox pour le choix des arcs de cercle/ellipse.; in	-; out	D7.W	erreur; mod	D7.WDBOXADEF:	PUSHM.L	D1..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_ARC	CLR.L	D4	LOAD.B	D4,(A6)+OARC	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_ARC	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	LOAD.B	(A6)+OARC,D4	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.IF	DESSIN;--------\\; DBOXDEF >;========/; Change les dfinitions gnrales.; in	-; out	D7.W	erreur; mod	D7.WDBOXDEF:	PUSHM.L	D0..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_DEFINE	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+ODEF	; D4 <-- fanions	TCLR.L	D4:#BDEFZOOM	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	LOAD.L	D2,D4		; D2 <-- fanions	LOAD.L	D4,(A6)+OMALMY	; D4 <-- dimensions (y;x)10$:	TEST.L	D2:#BDEFMM	; unit "millimtre" ?	JUMP',BC 12$		; non => 12$	LOAD.L	D1,D4	CALL	CONVPMX		; D4 <-- largeur [mm]	EX.L	D4,D1	SWAP.W	D4	CALL	CONVPMY		; D4 <-- hauteur [mm]	SWAP.W	D4	LOAD.W	D4,D112$:	LOAD.L	A3,#(A6)+OBUFOUT	LOAD.L	A4,A3	CALL	PUTANUM	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'x	; sparateur	LOAD.B	(A4+),#SPACE	SWAP.W	D4	CALL	PUTANUM	CLR.B	(A4)		; terminateur20$:	LOAD.L	D0,D2		; D0 <-- anciens fanions	LOAD.L	D4,D2		; D4 <-- fanions	DBOX_	EDIT		; attend action ...	LOAD.L	D2,D4		; D2 <-- fanions	LOAD.L	A1,#R16"TKEY_DEFINE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR	JUMP,EQ 60$	COMP.W	D3,#END	JUMP,EQ 80$	COMP.W	D3,#FNCT	JUMP',EQ 30$	COMP.W	D3,#DEFINE	JUMP',EQ 35$	COMP.W	D3,#UNDO	JUMP',EQ 40$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP,EQ 50$25$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$30$:				; ECRAN =>	LOAD.L	D4,(A6)+OGRDIY	JUMP	10$35$:				; PAGE =>	CALL	WAITMOUSE	; souris: met le sablier	CALL	RDSTPRINT	; lit le status de l'imprimante ...	CALL	NORMMOUSE	; souris: remet la flche	CLR.L	D4	LOAD.W	D4,(A6)+OSTPRI+OPRHTP	SUB.W	D4,(A6)+OSTPRI+OPRMGS	SUB.W	D4,(A6)+OSTPRI+OPRMGI	SUB.W	D4,(A6)+OSTPRI+OPRITL ; <<<<<<<<<< A SUPPRIMER, VOIR AVEC FK <<<<<<<<<<	DIV.WU	D4,(A6)+OFACY	SWAP.W	D4	CLR.L	D3	LOAD.W	D3,(A6)+OSTPRI+OPRLGP	SUB.W	D3,(A6)+OSTPRI+OPRMGG	SUB.W	D3,(A6)+OSTPRI+OPRMGD	DIV.WU	D3,(A6)+OFACX	LOAD.W	D4,D3	JUMP	10$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$50$:				; changement d'unit =>	LOAD.B	D1,D3	LOAD.L	D2,D0		; D2 <-- anciens fanions	PUSH.L	D1	CALL	DBDEFPUT	; D3/D4 <-- largeur/hauteur	POPM.L	D1	JUMP,NE 25$	TCLR.L	D2:#BDEFMM	TCLR.L	D2:#BDEFPG	TSET.L	D2:D1		; D2 <-- allume le bon fanion	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- nouvelle dimensions (y;x)	JUMP	10$60$:				; D'ACCORD =>	LOAD.L	D0,(A6)+ODEF	XOR.L	D0,D2		; D0 <-- fanions modifis	TCLR.L	D2:#BDEFZOOM	LOAD.L	(A6)+ODEF,D2	CALL	DBDEFPUT	; D3/D4 <-- largeur/hauteur	JUMP,NE 25$	CALL	DBOXCLOSE	; ferme la DBOX	TEST.W	D1		; dimensions modifies ?	JUMP',NE 70$		; oui => 70$	TEST.L	D0:#BDEFICO	JUMP,BS 73$	TEST.L	D0:#BDEFASC	JUMP,BS 74$	CLR.W	D7	JUMP	90$70$:;	LOAD.W	D3,		; D3 <-- largeur de l'image;	LOAD.W	D4,		; D4 <-- hauteur de l'image	TEST.L	D0:#BDEFZOOM	JUMP',BC 71$	LOAD.B	(A6)+OMASTR,#2^BMASTR!2^BMAHOM71$:	CALL	GETMEMMATRIX	; demande mmoire pour nouvelle image	CLR.B	(A6)+OMASTR	TEST.W	D7	JUMP,NE 90$	SET.B	(A6)+OMAJ	; une mise  jour sera ncessaire	LOAD.W	D4,#SCALE11	LOAD.W	(A6)+OSCALE,D4	CLR.L	(A6)+OPMOVY	CLR.L	(A6)+OPMDIY	TEST.L	D0:#BDEFICO	JUMP,BS 73$	TEST.L	D0:#BDEFASC	JUMP,BS 74$	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CLR.W	D7		; D7 <-- ok	JUMP	90$73$:				; montre/cache les icnes =>	CALL	CCMO		; enlve la souris	CALL	CALCADRE	CALL	DESWDO	LOAD.W	D4,(A6)+OSCALE	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CLR.W	D7		; D7 <-- ok	JUMP'	90$74$:				; montre/cache les ascenseurs =>	CALL	CALCADRE	LOAD.W	D4,(A6)+OSCALE	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBDEFPUT >;---------/; Met  jour les valeurs.; in	D2.L	fanions;	A3.L	^ligne en dition; out	D3.W	largeur;	D4.W	hauteur;	D1.W	0 => valeurs pas modifies;	D7.W	erreur (syntaxe); mod	D1.L, D3.L, D4.L, D7.WDBDEFPUT:	PUSHM.L	D2,A4	CLR.W	D1	LOAD.L	A4,A3		; A4 <-- ^1er nombre	CALL	GETANUM		; D4 <-- largeur	TEST.L	D2:#BDEFMM	JUMP',BC 10$	CALL	CONVMPX		; D4 <-- largeur [pg]10$:	COMP.W	D4,#8	JUMP',HS 20$	LOAD.W	D4,#820$:	AND.B	D4,#B'11111000	; D4 <-- modulo 8 en X !	COMP.W	D4,(A6)+OMALMX	; idem ?	JUMP',EQ 30$		; oui => 30$	INC.W	D1		; non => signal30$:	LOAD.W	D7,#1		; D7 <-- erreur de syntaxe	LOAD.B	D3,(A4+)	; D3 <-- sparateur	JUMP',EQ 90$	COMP.B	D3,#CR	JUMP',EQ 90$	COMP.B	D3,#'0	JUMP,LO	30$	COMP.B	D3,#'9	JUMP,HI	30$	DEC.L	A4		; A4 <-- ^2me nombre	LOAD.W	D3,D4		; D3 <-- largeur	CALL	GETANUM		; D4 <-- hauteur	TEST.L	D2:#BDEFMM	JUMP',BC 50$	PUSH.W	D3	CALL	CONVMPY		; D4 <-- hauteur [pg]	POP.W	D350$:	COMP.W	D4,#8	JUMP',HS 60$	LOAD.W	D4,#860$:	AND.B	D4,#B'11111110	; D4 <-- modulo 2 en Y !	COMP.W	D4,(A6)+OMALMY	; idem ?	JUMP',EQ 70$		; oui => 70$	INC.W	D1		; non => signal70$:	CLR.W	D7		; D7 <-- ok	LOAD.B	D2,(A4+)	JUMP',EQ 90$	COMP.B	D2,#CR	JUMP',EQ 90$	COMP.B	D2,#SPACE	JUMP,EQ 70$	LOAD.W	D7,#1		; D7 <-- erreur de syntaxe90$:	POPM.L	D2,A4	TEST.W	D7		; retour EQ/NE	RET	.ELSE;--------\\; DBOXDEF >;========/; Change les dfinitions gnrales.; in	-; out	D7.W	erreur; mod	D7.WDBOXDEF:	PUSHM.L	D1..D5,A1..A4	LOAD.L	A3,(A6)+OPGC	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.W	D4,#OGCWID-110$:	LOAD.B	(A4+),(A3+)	; OBUHEAD <-- header	DECJ.W,NMO D4,10$	LOAD.L	A2,#R16"TDBOX_DEFINE	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	CLR.W	D215$:	CALL	PUTDNUM		; A3 <-- ^paramtre	CALL	AFFDNUM		; affiche un paramtre	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#10	JUMP,LO 15$	CLR.L	D4	CLR.W	D220$:	CALL	PUTDNUM		; A3/A4 <-- paramtre	LOAD.W	D3,D2		; D3 <-- rang	DBOX_	MEDIT		; indique rang ligne  diter22$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_DEFINE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	22$		; oui => 22$	COMP.W	D3,#F1	JUMP,EQ 60$	COMP.W	D3,#END	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP',EQ 40$	COMP.W	D3,#CR	JUMP',EQ 42$	LOAD.W	D1,D3	SR.W	D1,#8	COMP.B	D1,#H'7E	JUMP,EQ 45$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	22$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	22$42$:				; RETURN =>	CALL	GETDNUM		; sauve le paramtre en dition	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#10	JUMP,LO 20$	CLR.W	D2	JUMP	20$45$:				; clic dans ODBLINE =>	CALL	GETDNUM		; sauve le paramtre en dition	LOAD.B	D2,D3		; D2 <-- nouveau paramtre	JUMP	20$60$:				; OK =>	CALL	GETDNUM		; sauve le paramtre en dition	LOAD.L	A3,(A6)+OPGC	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.W	D4,#OGCWID-161$:	COMP.B	(A3+),(A4+)	; header = OBUHEAD ?	JUMP',NE 62$	DECJ.W,NMO D4,61$	JUMP	80$		; oui => 80$62$:				; non =>	LOAD.L	A3,(A6)+OPGC	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.W	D4,#OGCWID-165$:	LOAD.B	(A3+),(A4+)	; header <-- OBUHEAD	DECJ.W,NMO D4,65$	CALL	DBOXCLOSE	; ferme la DBOX	LOAD.L	A4,(A6)+OPGC	; A4 <-- ^gencar	LOAD.B	D2,(A6)+OCAR	; D2 <-- code du caractre en dition	CLR.W	D3	LOAD.B	D3,(A4)+OGCMWB	SL.W	D3,#3		; D3 <-- largeur de l'image	LOAD.W	D4,(A4)+OGCMHD	; D4 <-- hauteur de l'image	COMP.W	D3,(A6)+OMALMX	; largeur change ?	JUMP',NE 67$	COMP.W	D4,(A6)+OMALMY	; hauteur change ?	JUMP',EQ 68$67$:	CALL	GETMEMMATRIX	; demande mmoire pour nouvelle image	JUMP,NE 90$68$:	LOAD.W	D4,(A6)+OSCALE	CLR.L	(A6)+OPMOVY	CLR.L	(A6)+OPMDIY	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	LOAD.B	D3,D2	CALL	CARSELECT	; slectionne le mme caractre	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PUTDNUM >;--------/; Prpare un paramtre dans le buffer d'dition.; in	D2.W	rang du paramtre (0..n); out	A3.L	^ligne ASCII;	A4.L	^ la fin; mod	D7.W, A3.L, A4.LPUTDNUM:	PUSHM.L	D2..D4	CLR.W	D4	LOAD.B	D4,(A6)+OBUHEAD+OGCMWB	SL.W	D4,#3	DEC.W	D2	JUMP',NS 30$	LOAD.W	D4,(A6)+OBUHEAD+OGCMHD	DEC.W	D2	JUMP',NS 30$	LOAD.W	D4,(A6)+OBUHEAD+OGCISP	DEC.W	D2	JUMP',NS 30$	LOAD.W	D4,(A6)+OBUHEAD+OGCLMA	DEC.W	D2	JUMP',NS 30$	LOAD.W	D4,(A6)+OBUHEAD+OGCBLI	DEC.W	D2	JUMP',NS 30$	CLR.W	D4	LOAD.B	D4,(A6)+OBUHEAD+OGCFCA	DEC.W	D2	JUMP',NS 30$	CLR.W	D4	LOAD.B	D4,(A6)+OBUHEAD+OGCLCA	DEC.W	D2	JUMP',NS 30$	LOAD.L	A3,#(A6)+OBUHEAD+OGCRBI	DEC.W	D2	JUMP',NS 50$	LOAD.L	A3,#(A6)+OBUHEAD+OGCIDE	DEC.W	D2	JUMP',NS 50$	LOAD.L	A3,#(A6)+OBUHEAD+OGCCNM	DEC.W	D2	JUMP',NS 50$	CLR.W	D4		; nombre =>30$:	LOAD.L	A3,#(A6)+OBUFOUT	LOAD.L	A4,A3	CALL	PUTANUM		; buffer <-- nombre	CLR.B	(A4)		; buffer <-- terminateur	JUMP'	90$50$:				; texte =>	LOAD.L	A4,#(A6)+OBUFOUT52$:	LOAD.B	(A4+),(A3+)	; buffer <-- texte	JUMP',EQ 55$	COMP.B	(A3)-1,#CR	JUMP,NE 52$55$:	CLR.B	(-A4)		; buffer <-- terminateur	LOAD.L	A3,#(A6)+OBUFOUT90$:	POPM.L	D2..D4	RET;--------\\; GETDNUM >;--------/; Met le paramtre en dition dans le buffer.; in	D2.W	rang du paramtre (0..n);	A3.L	^ligne ASCII; out	-; mod	D7.WGETDNUM:	PUSHM.L	D1..D4,A3,A4	LOAD.L	A4,A3	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D1,D2	DEC.W	D1	JUMP,NS 10$	DEC.W	D1	JUMP,NS 15$	DEC.W	D1	JUMP,NS 20$	DEC.W	D1	JUMP,NS 30$	DEC.W	D1	JUMP,NS 35$	DEC.W	D1	JUMP,NS 40$	DEC.W	D1	JUMP,NS 45$	DEC.W	D1	JUMP,NS 50$	DEC.W	D1	JUMP,NS 52$	DEC.W	D1	JUMP,NS 54$	JUMP	90$10$:	SR.W	D4,#3	JUMP',NE 12$	INC.B	D412$:	LOAD.B	(A6)+OBUHEAD+OGCMWB,D4	JUMP	80$15$:	COMP.W	D4,#3	JUMP',HS 17$	LOAD.W	D4,#317$:	LOAD.W	(A6)+OBUHEAD+OGCMHD,D4	JUMP	80$20$:	COMP.W	D4,(A6)+OBUHEAD+OGCMHD	JUMP',HS 22$	LOAD.W	D4,(A6)+OBUHEAD+OGCMHD22$:	LOAD.W	(A6)+OBUHEAD+OGCISP,D4	JUMP	80$30$:	CLR.W	D3	LOAD.B	D3,(A6)+OBUHEAD+OGCMWB	SL.W	D3,#3	COMP.W	D4,D3	JUMP',LS 32$	LOAD.W	D4,D332$:	LOAD.W	(A6)+OBUHEAD+OGCLMA,D4	JUMP	80$35$:	COMP.W	D4,(A6)+OBUHEAD+OGCMHD	JUMP',LS 37$	LOAD.W	D4,(A6)+OBUHEAD+OGCMHD37$:	LOAD.W	(A6)+OBUHEAD+OGCBLI,D4	JUMP	80$40$:	COMP.B	D4,(A6)+OBUHEAD+OGCLCA	JUMP',LS 42$	LOAD.B	D4,(A6)+OBUHEAD+OGCLCA42$:	LOAD.B	(A6)+OBUHEAD+OGCFCA,D4	JUMP	80$45$:	COMP.B	D4,(A6)+OBUHEAD+OGCFCA	JUMP',HS 47$	LOAD.B	D4,(A6)+OBUHEAD+OGCFCA47$:	COMP.B	D4,#127	JUMP',LS 48$	LOAD.B	D4,#12748$:	LOAD.B	(A6)+OBUHEAD+OGCLCA,D4	JUMP	80$50$:	LOAD.L	A4,#(A6)+OBUHEAD+OGCRBI	CLR.L	(A4)	JUMP'	60$52$:	LOAD.L	A4,#(A6)+OBUHEAD+OGCIDE	JUMP'	60$54$:	LOAD.L	A4,#(A6)+OBUHEAD+OGCCNM;	JUMP'	60$60$:	LOAD.B	(A4+),(A3+)	; buffer <-- texte	JUMP',EQ 62$	COMP.B	(A3)-1,#CR	JUMP,NE 60$62$:	CLR.B	(-A4)		; buffer <-- terminateur80$:	CALL	PUTDNUM		; A3 <-- ^paramtre v. ajust	CALL	AFFDNUM		; affiche la valeur retenue90$:	POPM.L	D1..D4,A3,A4	RET;--------\\; AFFDNUM >;--------/; Affiche le paramtre en dition dans le buffer.; in	D2.W	rang du paramtre (0..n);	A3.L	^ligne ASCII; out	-; mod	D7.WAFFDNUM:	PUSHM.L	D2..D4,A3,A4	SL.W	D2,#1	INC.W	D2	COMP.W	D2,#15	JUMP',LS GETCO$	INC.W	D2GETCO$:	DBOX_	GETCO		; D3/D4 <-- positions dbut/fin	JUMP',NE 90$	LIB	?SETCURS	; positionne curseur dans ODBLINE	SUB.W	D4,D3		; D4 <-- longueur en points	AND.L	D4,#H'FFFF	DIV.WU	D4,(A0)+ODFCX	; D4 <-- longueur en caractres	LOAD.L	A4,A3	LIB	?AFTEXT		; affiche le paramtre	LOAD.L	D3,A3	SUB.L	D3,A4	DEC.W	D3		; D3 <-- longueur affiche	SUB.W	D4,D3		; D4 <-- reste  effacer	JUMP',LE 90$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR90$:	POPM.L	D2..D4,A3,A4	RET	.ENDIF;--------\\; PUTANUM >;--------/; Met un nombre dcimal dans un buffer.; in	D4.W	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	AND.L	D4,#H'FFFF	; D4 <-- nombre binaire	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;--------/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSH.L	D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POP.L	D3	RET	.IF	DESSIN;----------\\; DBOXZOOM  >;==========/; Demande deux facteurs de zoom spciaux.; in	-; out	D7.W	erreur; mod	D7.WDBOXZOOM:	PUSHM.L	D1..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_ZOOM	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBYZOOM	LIB	?AFTEXT		; affiche le facteur vertical	CLR.W	D2		; D2 <-- dans facteur en X20$:	LOAD.L	A3,#(A6)+OBXZOOM	TEST.W	D2	JUMP',EQ 22$	LOAD.L	A3,#(A6)+OBYZOOM22$:	LOAD.L	A4,A323$:	TEST.B	(A4+)	JUMP,NE 23$	DEC.L	A4		; A4 <-- ^fin du dernier nombre25$:	LOAD.W	D3,D2	DBOX_	MEDIT		; indique le facteur  diter	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_ZOOM	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	25$		; oui => 25$	COMP.W	D3,#UNDO	JUMP',EQ 40$	COMP.W	D3,#KEYICO+0	JUMP',EQ 45$	COMP.W	D3,#KEYICO+1	JUMP',EQ 45$	COMP.W	D3,#CR	JUMP',EQ 47$	COMP.W	D3,#F1		; (ZOOM) ?	JUMP',EQ 50$	LOAD.W	D7,#ERKSTO	COMP.W	D3,#F0		; (ANNULE) ?	JUMP,EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	25$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	25$45$:				; change =>	SUB.W	D3,#KEYICO	LOAD.W	D2,D3		; D2 <-- 0..1	JUMP	20$47$:				; suivant =>	INC.W	D2	COMP.W	D2,#2	JUMP,LO 20$	CLR.W	D2	JUMP	20$50$:				; ZOOM =>	CLR.W	D2	LOAD.L	A3,#(A6)+OBXZOOM	LOAD.L	A4,A3		; A4 <-- ^nombre prsum	CALL	ZRDNUM		; D4 <-- nombre *1000	JUMP,NE 30$	LOAD.W	(A6)+OXZOOM,D4	INC.W	D2	LOAD.L	A3,#(A6)+OBYZOOM	LOAD.L	A4,A3		; A4 <-- ^nombre prsum	CALL	ZRDNUM		; D4 <-- nombre *1000	JUMP,NE 30$	LOAD.W	(A6)+OYZOOM,D4	CALL	DBOXCLOSE	; ferme la DBOX	LOAD.W	D3,(A6)+OMALMX	MUL.WU	D3,(A6)+OXZOOM	DIV.WU	D3,#1000	; D3 <-- largeur de l'image	LOAD.W	D4,(A6)+OMALMY	MUL.WU	D4,(A6)+OYZOOM	DIV.WU	D4,#1000	; D4 <-- hauteur de l'image	LOAD.B	(A6)+OMASTR,#2^BMASTR	CALL	GETMEMMATRIX	; demande mmoire pour nouvelle image	CLR.B	(A6)+OMASTR	TEST.W	D7	JUMP',NE 90$	SET.B	(A6)+OMAJ	; une mise  jour sera ncessaire	LOAD.W	D4,#SCALE11	LOAD.W	(A6)+OSCALE,D4	CLR.L	(A6)+OPMOVY	CLR.L	(A6)+OPMDIY	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:				; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D790$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZRDNUM  >;--------/; Lit un nombre  trois dcimales, rendu 1000 fois plus grand.; S'il n'y a pas de nombre, rend 1 pour ne rien zoomer !; in	A4.L	^nombre prsum; out	A4.L	^plus loin;	D4.W	nombre (+/-);	D7.W	erreur; mod	D4.L, D7.W, A4.LZRDNUM:	PUSHM.L	D1..D3,A3	CLR.W	D1		; D1 <-- nb de dcimales	CLR.W	D2		; D2 <-- positif	COMP.B	(A4),#'-	; signe moins ?	JUMP',NE 05$		; non => 05$	INC.L	A4		; oui =>	INC.W	D2		; D2 <-- ngatif05$:	LOAD.W	D7,#ERSYNT	LOAD.L	A3,A4		; A3 <-- ^dbut du nombre	CLR.W	D4		; D4 <-- futur nombre10$:	CLR.W	D3	LOAD.B	D3,(A4+)	; D3 <-- caractre	COMP.B	D3,#'.	JUMP',EQ 30$	COMP.B	D3,#'0		; est un digit ?	JUMP',LO 40$		; non => 40$	COMP.B	D3,#'9	JUMP',HI 40$	TEST.L	D1:#15		; est-on dans les dcimales ?	JUMP',BC 20$		; non => 20$				; oui =>	COMP.B	D1,#3		; plus de 3 dcimales ?	JUMP,HS 10$		; oui => 10$ (ignore)	INC.B	D1		; non => une dcimale de plus20$:	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.W	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$30$:	TSET.L	D1:#15		; D1 <-- partie dcimale existe	JUMP,BS 90$		; si 2me point => 90$ (erreur)	JUMP	10$40$:	TEST.W	D2		; nombre positif ?	JUMP',EQ 45$		; oui => 45$	NEG.L	D4		; non => prend le complment45$:	TEST.B	D3		; nombre termin ?	JUMP',NE 90$		; non => 90$				; oui =>	DEC.L	A4	COMP.L	A4,A3		; au moins un digit ?	JUMP',NE 55$		; oui => 55$	LOAD.W	D4,#1		; non => pas de zoom, donc facteur 155$:	LOAD.W	D2,#1000	; D2 <-- aucune dcimale	TEST.B	D1	JUMP',EQ 60$	LOAD.W	D2,#100		; D2 <-- une dcimale	DEC.B	D1	JUMP',EQ 60$	LOAD.W	D2,#10		; D2 <-- deux dcimales	DEC.B	D1	JUMP',EQ 60$	LOAD.W	D2,#1		; D2 <-- trois dcimales60$:	MUL.WU	D4,D2		; D4 <-- simule les dcimales manquantes	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D3,A3	TEST.W	D7		; retour EQ/NE	RET	.ENDIF;----------\\; DBOXFLAGS >;==========/; Change le mode.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXFLAGS:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_FLAGS	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFLAGS	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_FLAGS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP,EQ 60$	COMP.W	D3,#F0	JUMP,EQ 80$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP,EQ 50$25$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO 52$	LOAD.L	D1,#H'FFFF00FF	COMP.B	D3,#16	JUMP',LO 52$	LOAD.L	D1,#H'FF00FFFF	COMP.B	D3,#24	JUMP',LO 52$	LOAD.L	D1,#H'00FFFFFF52$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon	JUMP	20$60$:				; D'ACCORD =>	LOAD.L	(A6)+OFLAGS,D4	LOAD.W	D1,#32	TEST.L	D4:#BFLP32	JUMP',BS 70$	LOAD.W	D1,#16	TEST.L	D4:#BFLP16	JUMP',BS 70$	LOAD.W	D1,#8	TEST.L	D4:#BFLP8	JUMP',BS 70$	LOAD.W	D1,#4	TEST.L	D4:#BFLP4	JUMP',BS 70$	LOAD.W	D1,#2	TEST.L	D4:#BFLP2	JUMP',BS 70$	LOAD.W	D1,#170$:	LOAD.W	(A6)+OPAS,D180$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.IF	EDGAR;---------\\; DBOXCAR  >;=========/; Demande un caractre ASCII quelconque.; in	-; out	D3.B	code ASCII choisi (0..127);	D7.W	erreur; mod	D3.L, D7.WDBOXCAR:	PUSHM.L	D1,D2,D4,D5,A1..A4	CALL	NORMMOUSE	; souris: remet la flche	LOAD.L	A2,#R16"TDBOX_CAR	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_CAR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#H'80	JUMP',LO 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXOPER  >;==========/; Dbox pour le choix de l'opration de transformation; d'un gencar.; in	D4.L	fanions; out	D3.W	dernire touche;	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXOPER:	PUSHM.L	D1,D2,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_OPER	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OPER	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP',EQ 80$	COMP.W	D3,#END		; ANNULE ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXMINUS >;==========/; Dbox pour confirmer l'opration "minuscules".; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXMINUS:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_MINUS	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_MINUS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; OUI ?	JUMP',EQ 80$	COMP.W	D3,#END		; NON ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.ENDIF	.END