	.SBTTL	DDESSINTABL;-------------\\; _DESSIN_TGET >;=============/; Donne le pointeur  une collection de trames.;	Collection 0	-->	DESSIN.CODE;	Collection 1	-->	GRAPHE.CODE; in	D4.W	rang de la collection (0,1); out	A4.L	^trames;	D7.W	erreur; mod	D7.W, A4.L_DESSIN_TGET:	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,#R16"TTDEF0	TEST.W	D4	JUMP',EQ 90$	LOAD.L	A4,#R16"TTDEF1	COMP.W	D4,#1	JUMP',EQ 90$	LOAD.W	D7,#1		; D7 <-- impossible90$:	TEST.W	D7		; retour EQ/NE	RET;-------------\\; _DESSIN_DGET >;=============/; Donne le pointeur  une collection de droites.;	Collection 0	-->	DESSIN.CODE;	Collection 1	-->	GRAPHE.CODE; in	D4.W	rang de la collection (0,1); out	A4.L	^droites;	D7.W	erreur; mod	D7.W, A4.L_DESSIN_DGET:	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,#R16"TDDEF0	TEST.W	D4	JUMP',EQ 90$	LOAD.L	A4,#R16"TDDEF1	COMP.W	D4,#1	JUMP',EQ 90$	LOAD.W	D7,#1		; D7 <-- impossible90$:	TEST.W	D7		; retour EQ/NE	RET;-------------\\; _DESSIN_PGET >;=============/; Donne le pointeur  une collection de points.;	Collection 0	-->	GRAPHE.CODE; in	D4.W	rang de la collection (0); out	A4.L	^points;	D7.W	erreur; mod	D7.W, A4.L_DESSIN_PGET:	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,#R16"TPDEF0	TEST.W	D4	JUMP',EQ 90$	LOAD.W	D7,#1		; D7 <-- impossible90$:	TEST.W	D7		; retour EQ/NE	RETTTDEF0:				; 0	.B	B'10000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'10000000	.B	B'00000000	.B	B'00001000	.B	B'00000000				; 1	.B	B'10001000	.B	B'00000000	.B	B'00100010	.B	B'00000000	.B	B'10001000	.B	B'00000000	.B	B'00100010	.B	B'00000000				; 2	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010				; 3	.B	B'10101010	.B	B'01010101	.B	B'10101010	.B	B'01010101	.B	B'10101010	.B	B'01010101	.B	B'10101010	.B	B'01010101				; 4	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101				; 5	.B	B