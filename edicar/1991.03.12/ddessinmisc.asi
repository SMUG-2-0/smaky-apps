	.SBTTL	DDESSINMISC;-------------\\; _DESSIN_TDEF >;=============/; Dfini une trame selon son rang.; Aprs cet appel, on peut utiliser :;	LIB,?DRMATRIX	ou	DRAWTRAME;	--		ou	DRAWFILLO/DRAWFILLC; in	D1.W	rang de la trame;	A4.L	^liste de trames; out	A4.L	^trame;	D2.W	mode (-1 si rien  dessiner); mod	D2.L, D7.W, A4.L_DESSIN_TDEF:	PUSHM.L	D3,D4	LOAD.W	D4,D1	MUL.WU	D4,#8	ADD.L	A4,D4		; A4 <-- ^bonne trame	LOAD.L	D3,(A4)+0	LOAD.L	D4,(A4)+4	LOAD.W	D2,#-1		; D2 <-- rien  dessiner	TEST.L	D3	JUMP',NE 20$	TEST.L	D4	JUMP',EQ 90$20$:	CALL	DRTRADEF	CLR.W	D2		; D2 <-- mode normal90$:	POPM.L	D3,D4	RET;-------------\\; _DESSIN_DDEF >;=============/; Dfini un pinceau selon son rang.; Aprs cet appel, on peut utiliser :;	LIB,?DRSEG	ou	DRAWSEG;	LIB,?DRRECT	ou	--;	LIB,?DRCERCLE	ou	DRAWCERCLE;	--		ou	DRAWARC;	etc.; in	D1.W	rang de la droite;	A4.L	^liste de droites; out	A4.L	^droite;	D2.W	mode (-1 si rien  dessiner); mod	D2.L, D7.W, A4.L_DESSIN_DDEF:	PUSHM.L	D3,D4,A3	SUB.L	SP,#16		; p'tit buffer sur stack, hop !	LOAD.W	D4,D1	MUL.WU	D4,#8+2	ADD.L	A4,D4		; A4 <-- ^bon trait	LOAD.W	D2,#-1		; D2 <-- rien  dessiner	TEST.L	(A4)+0	JUMP',NE 20$	TEST.L	(A4)+4	JUMP,EQ 90$20$:	TEST.B	(A4)+8	JUMP,EQ 90$	LOAD.W	D2,#PENDOT!TTTDOT	COMP.L	(A4)+0,#DEFTR0	JUMP',NE 40$	COMP.L	(A4)+4,#DEFTR4	JUMP',NE 40$	TCLR.L	D2:#BPENDOT	; D2 <-- pas de pinceau40$:	COMP.W	(A4)+8,#DEFTR8	JUMP',NE 50$	TCLR.L	D2:#BTTTDOT	; D2 <-- pas de traitill50$:	LOAD.L	A3,#(SP)+1	; A3 <-- ^p'tit buffer	TEST.L	D2:#BPENDOT	JUMP',BC 60$	LOAD.B	(A3+),#PEN	; <pen>	LOAD.L	(A3+),(A4)+0	LOAD.L	(A3+),(A4)+460$:	TEST.L	D2:#BTTTDOT	JUMP',BC 70$	LOAD.B	(A3+),#MAPTT	; <maptt>	LOAD.B	(A3+),(A4)+8	; <m>	LOAD.B	(A3+),(A4)+9	; <e>70$:	LOAD.L	D3,A3	LOAD.L	A3,#(SP)+1	SUB.L	D3,A3		; D3 <-- longueur	JUMP',EQ 90$	LIB	?STRING		; dfini le pinceau90$:	ADD.L	SP,#16		; fini, le p'tit buffer rigolo !	POPM.L	D3,D4,A3	RET;-------------\\; _DESSIN_PDEF >;=============/; Dfini un point selon son rang.; Aprs cet appel, on peut utiliser :;	--		ou	DRAWDOT; in	D1.W	rang du point;	A4.L	^liste de points; out	A4.L	^point;	D2.W	mode (-1 si rien  dessiner); mod	D2.L, D7.W, A4.L_DESSIN_PDEF:	PUSHM.L	D3,D4,A3	SUB.L	SP,#16		; p'tit buffer sur stack, hop !	LOAD.W	D4,D1	MUL.WU	D4,#8	ADD.L	A4,D4		; A4 <-- ^(em)bon point	LOAD.W	D2,#-1		; D2 <-- rien  dessiner	TEST.L	(A4)+0	JUMP',NE 20$	TEST.L	(A4)+4	JUMP,EQ 90$20$:	LOAD.W	D2,#PENDOT	LOAD.L	A3,#(SP)+1	; A3 <-- ^p'tit buffer	LOAD.B	(A3+),#PEN	; <pen>	LOAD.L	(A3+),(A4)+0	LOAD.L	(A3+),(A4)+4	LOAD.B	(A3+),#MAPTT	; <maptt>	LOAD.B	(A3+),#-1	; <m>	LOAD.B	(A3+),#1	; <e>	LOAD.L	D3,A3	LOAD.L	A3,#(SP)+1	SUB.L	D3,A3		; D3 <-- longueur	JUMP',EQ 90$	LIB	?STRING		; dfini le point90$:	ADD.L	SP,#16		; fini, le p'tit buffer rigolo !	POPM.L	D3,D4,A3	RET;--------\\; DRRECT  >;========/; Dessine un rectangle.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRRECT:	PUSHM.L	D3..D5	LOAD.L	D5,D4		; D5 <-- dimensions (dy;dx)	AND.L	D4,#H'FFFF	CALL	DRLINE		; trace ligne suprieure	LOAD.L	D4,D5	CLR.W	D4	CALL	DRLINE		; trace ligne de droite	LOAD.L	D4,D5	AND.L	D4,#H'FFFF	NEG.W	D4	CALL	DRLINE		; trace ligne infrieure	LOAD.L	D4,D5	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DRLINE		; trace ligne de gauche	POPM.L	D3..D5	RET;-------\\; DRDOT  >;=======/; Dessine un point.; in	D3.L	coordonne (y;x);	D2.W	mode; out	-; mod	D7.WDRDOT:	PUSHM.L	D1..D4,A1,A2	CALL	CCMO		; enlve la souris	LOAD.W	D1,D2		; D1 <-- mode	LOAD.L	D4,D3		; D4 <-- y;x	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADDOT	CALL	(A1)		; appel de GRA_DOT	POPM.L	D1..D4,A1,A2	RET;--------\\; DRLINE  >;========/; Dessine un segment de droite.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	D3.L	coordonne d'arrive (y;x); mod	D3.L, D7.WDRLINE:	PUSHM.L	D1,D2,D4,A1,A2	CALL	CCMO		; enlve la souris	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADLINE	CALL	(A1)		; appel de GRA_LINE	EX.L	D3,D4	ADD.W	D3,D4		; D3 <-- arrive en X	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- arrive en Y	SWAP.W	D3;	SWAP.W	D4	POPM.L	D1,D2,D4,A1,A2	RET;---------\\; DRTRADEF >;=========/; Dfinit une trame.; in	D3.L	trame;	D4.L	trame; out	-; mod	D7.WDRTRADEF:	PUSHM.L	D1..D4	COMP.B	(A6)+OMACHINE,#SMAKY8	JUMP',EQ 80$				; si SMAKY100 =>	LOAD.W	D1,#4-120$:	CALL	FLIP	RR.L	D3,#8	DECJ.W,NMO D1,20$	EX.L	D3,D4	LOAD.W	D1,#4-130$:	CALL	FLIP	RR.L	D3,#8	DECJ.W,NMO D1,30$	EX.L	D4,D380$:	LOAD.L	(A0)+ODFTRA+0,D3	LOAD.L	(A0)+ODFTRA+4,D4	POPM.L	D1..D4	RET;--------\\; FLIP    >;--------/; Permute tous les bits de D3.B. Pas de boucle pour tre; rapide, et pas de table de 256 bytes pour conomiser la RAM !; in	D3.B	byte; out	D3.B	byte "flipp"; mod	D2.B, D3.BFLIP:	RLX.B	D3	RRX.B	D2		; D2 <-- bit 0	RLX.B	D3	RRX.B	D2		; D2 <-- bit 1	RLX.B	D3	RRX.B	D2		; D2 <-- bit 2	RLX.B	D3	RRX.B	D2		; D2 <-- bit 3	RLX.B	D3	RRX.B	D2		; D2 <-- bit 4	RLX.B	D3	RRX.B	D2		; D2 <-- bit 5	RLX.B	D3	RRX.B	D2		; D2 <-- bit 6	RLX.B	D3	RRX.B	D2		; D2 <-- bit 7	LOAD.B	D3,D2		; D3 <-- byte "flipp"	RET;---------\\; DRTRAME  >;=========/; Dessine une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRTRAME:	PUSHM.L	D1..D4,A1,A2,A4	TEST.W	D4		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D4	CALL	CCMO		; enlve la souris	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A4,#(A0)+ODFTRA	; A4 <-- ^trame utilisateur	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADTRAME	CALL	(A1)		; appel de GRA_TRAME90$:	POPM.L	D1..D4,A1,A2,A4	RET;--------\\; DRZONE  >;========/; Efface, allume ou inverse une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRZONE:	COMP.B	D2,#INVDOT	JUMP,EQ DRINV	COMP.B	D2,#SETDOT	JUMP,EQ DRSET;---------\\; DRCLEAR  >;=========/; Efface une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRCLEAR:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D4	CALL	CCMO		; enlve la souris	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADCLEAR	CALL	(A1)		; appel de GRA_SET90$:	POPM.L	D1..D4,A1,A2	RET;---------\\; DRSET    >;=========/; Allume une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRSET:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D4	CALL	CCMO		; enlve la souris	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADSET	CALL	(A1)		; appel de GRA_SET90$:	POPM.L	D1..D4,A1,A2	RET;---------\\; DRINV    >;=========/; Inverse une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRINV:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D4	CALL	CCMO		; enlve la souris	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADINV	CALL	(A1)		; appel de GRA_INV90$:	POPM.L	D1..D4,A1,A2	RET;--------\\; CCMO    >;========/; Enlve la souris.; in	-; out	-; mod	D7.WCCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',T 90$	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	SET.B	(A6)+OCCMO90$:	POP.W	D3	RET;--------\\; SCMO    >;========/; Remet la souris.; in	-; out	-; mod	D7.WSCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',F 90$	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	CLR.B	(A6)+OCCMO90$:	POP.W	D3	RET;--------\\; OPEVAR  >;========/; Ouvre les variables.; in	D2.L	flags divers;	D4.W	trame slectionne;	A2.L	^table d'icnes;	A3.L	^trois textes;	A4.L	^table des 4x7 trames; out	A6.L	^variables;	D7.W	erreur; mod	D7.W, A6.LOPEVAR:	PUSHM.L	D0,D1,D3,D4,A1,A3,A4	LOAD.W	D0,D4	LOAD.L	A1,A4	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE 90$	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LOAD.W	(A6)+OSELEC,D0	LOAD.L	(A6)+OMODE,D2	LOAD.L	(A6)+OPOBJ,A1	LOAD.L	(A6)+OPICO,A2	LOAD.L	(A6)+OPTEXT,A3	NTREL	?GETMACHINE		 ; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LOAD.W	D3,#GRA_DOT	LIB_	GETAD	LOAD.L	(A6)+OADDOT,A3	LOAD.W	D3,#GRA_TRAME	LIB_	GETAD	LOAD.L	(A6)+OADTRAME,A3	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	LOAD.L	(A6)+OADLINE,A3	LOAD.W	D3,#GRA_CLEAR	LIB_	GETAD	LOAD.L	(A6)+OADCLEAR,A3	LOAD.W	D3,#GRA_SET	LIB_	GETAD	LOAD.L	(A6)+OADSET,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	LOAD.L	(A6)+OADINV,A3	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	LOAD.L	(A6)+OADQXDOT,A3	LOAD.L	A4,(A6)+OPOBJ	LOAD.L	A3,#(A6)+OBUFF	LOAD.W	D4,#(((8+2)*MAMAX)/4)-1	TEST.B	(A6)+OMODE+0:#BMADR	JUMP',BS 50$	LOAD.W	D4,#((8*MAMAX)/4)-150$:	LOAD.L	(A3+),(A4+)	; OBUFF <-- objets	DECJ.W,NMO D4,50$90$:	POPM.L	D0,D1,D3,D4,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOVAR  >;========/; Ferme les variables.; in	A6.L	variables; out	D2.L	flags divers;	D4.W	trame slectionne; mod	D2.L, D4.L, D7.WCLOVAR:	PUSHM.L	D1,A4	LOAD.L	D2,(A6)+OMODE	LOAD.W	D4,(A6)+OSELEC	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre les variables	POPM.L	D1,A4	RET	.END