	.SBTTL	DESDBOXT;---------\\; DBOXOPEN >;---------/; Ouvre une dbox.; in	A2.L	table;	D2.W	mode; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WDBOXOPEN:	CALL	DBOXOPEN1	DBOX_	OPEN		; ouvre la dbox	RETDBOXOPEN1:	PUSH.W	D3	.IF	DESSIN	CALL	ERGMOUSE	; efface les flches dans les rgles	.ENDIF	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	POP.W	D3	RET;----------\\; DBOXCLOSE >;----------/; Ferme une dbox.; in	D5.L	canal; out	D7.W	erreur; mod	D7.WDBOXCLOSE:	DBOX_	CLOSE		; ferme la dboxDBOXCLOSE1:	CALL	AFMENU		; refait les soft-keys	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs DBOX_EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>90$:	POP.L	A3	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET; Tables; ------TDBOX_SAUVE:	.B	LDBOX_SAUVE	.IF	DESSIN	.B	ODBSQUARE,BDBDEF	.ASCIZ	" sauve les pinceaux et les trames"	.B	ODBCR	.ENDIFLDBOX_SAUVE	=	.-TDBOX_SAUVE-1TDBOX_RRECT:	.W	10$-TDBOX_RRECT	.W	20$-TDBOX_RRECT	.W	0,010$:	.B	ODBCIRCLE,0	.ASCIZ	"  4   "	.B	ODBTABX,14	.B	ODBCR,ODBCR	.B	ODBCIRCLE,1	.ASCIZ	"  8   "	.B	ODBCR,ODBCR	.B	ODBCIRCLE,2	.ASCIZ	" 12   "	.B	ODBCR,ODBCR	.B	ODBCIRCLE,3	.ASCIZ	" 16   "	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;