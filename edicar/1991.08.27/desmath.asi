	.SBTTL	DESMATHPASTOURNE =	20		; valeur minimale pour n=(360*p)+p;--------\\; XTOURNE >;--------/; Dtermine l'angle de rotation en fonction de la position; de la souris.; in	D4.L	position de la souris (y;x);	D3.L	point  tourner (y;x); out	D2.W	angle en degr; mod	D2.LXTOURNE:	PUSHM.L	D0,D1,D3,D4,D5,D6,D7	LOAD.L	D0,D3; Balaye les angles par incrments de PASTOURNE degrs en cherchant; la distance minimale.	LOAD.W	D2,#0	LOAD.W	D1,#360/PASTOURNE	LOAD.W	D5,#-1		; D5 <-- distance minimale10$:	LOAD.L	D3,D0	CALL	QTOURNE		; D3 <-- tourne selon l'angle D2	SUB.W	D3,D4	JUMP',NC 20$	NEG.W	D320$:	LOAD.W	D7,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	JUMP',NC 22$	NEG.W	D322$:	SWAP.W	D4	ADD.W	D3,D7		; D3 <-- |dx| + |dy|	COMP.W	D3,D5		; distance plus courte ?	JUMP',HS 30$		; non => 30$	LOAD.W	D5,D3	LOAD.W	D6,D2		; D6 <-- angle le meilleur30$:	ADD.W	D2,#PASTOURNE	; D2 <-- angle suivant	DEC.W	D1	JUMP,NE 10$; Balaye tous les angles possibles autour du multiple de PASTOURNE degrs; en cherchant la distance minimale.	LOAD.W	D2,D6	SUB.W	D2,#(PASTOURNE/2)+1	LOAD.W	D1,#(PASTOURNE)+2	LOAD.W	D5,#-1		; D5 <-- distance minimale40$:	LOAD.L	D3,D0	CALL	QTOURNE		; D3 <-- tourne selon l'angle D2	SUB.W	D3,D4	JUMP',NC 50$	NEG.W	D350$:	LOAD.W	D7,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	JUMP',NC 52$	NEG.W	D352$:	SWAP.W	D4	ADD.W	D3,D7		; D3 <-- |dx| + |dy|	COMP.W	D3,D5		; distance plus courte ?	JUMP',HS 60$		; non => 60$	LOAD.W	D5,D3	LOAD.W	D6,D2		; D6 <-- angle le meilleur60$:	INC.W	D2		; D2 <-- angle suivant	DEC.W	D1	JUMP,NE 40$	LOAD.W	D2,D6		; D2 <-- angle	POPM.L	D0,D1,D3,D4,D5,D6,D7	RET;--------\\; QTOURNE >;--------/; Tourne un point d'un angle quelconque selon la; formule magique suivante :;;	x' = x*cos(a) - y*sin(a);	y' = x*sin(a) + y*cos(a);; OSEPMI.L contient la coordonne du centre de symtrie.; in	D2.W	angle en degrs;	D3.L	coordonne (y;x); out	D3.L	coordonne (y;x); mod	D3.LQTOURNE:	PUSHM.L	D0,D1,D2,D4,D5,A0	SUB.W	D3,(A6)+OSEPMI+2	SWAP.W	D3	SUB.W	D3,(A6)+OSEPMI+0	SWAP.W	D3	CLR.L	D0	LOAD.W	D0,D2		; D0 <-- angle	JUMP',NC 20$	ADD.W	D0,#36020$:	DIV.WU	D0,#360	SWAP.W	D0	LOAD.L	A0,#R16"TSINUS	; A0 <-- ^table des sinus de 0..90 degrs	LOAD.W	D2,D3		; D2 <-- X	SWAP.W	D3		; D3 <-- Y	LOAD.W	D4,D2	CALL	COSINUS		; D4 <-- x*cos(a)	LOAD.W	D1,D4	LOAD.W	D4,D3	CALL	SINUS		; D4 <-- y*sin(a)	SUB.W	D1,D4	LOAD.W	D4,D2	CALL	SINUS		; D4 <-- x*sin(a)	LOAD.W	D5,D4	LOAD.W	D4,D3	CALL	COSINUS		; D4 <-- y*cos(a)	ADD.W	D5,D4	LOAD.W	D3,D5	SWAP.W	D3	LOAD.W	D3,D1	ADD.W	D3,(A6)+OSEPMI+2	SWAP.W	D3	ADD.W	D3,(A6)+OSEPMI+0	SWAP.W	D3	POPM.L	D0,D1,D2,D4,D5,A0	RET;--------\\; COSINUS >;--------/; in	D4.W	valeur;	D0.W	angle en degrs;	A0.L	^table des sinus; out	D4.W	cosinus de la valeur; mod	D4.WCOSINUS:	PUSHM.L	D0..D2	AND.L	D0,#H'FFFF	DIV.WU	D0,#90	LOAD.W	D1,D0		; D1 <-- octant (0..3)	SWAP.W	D0		; D0 <-- angle (0..90-1)	COMP.B	D1,#0	JUMP',EQ 20$	COMP.B	D1,#2	JUMP',NE 30$				;   0..90  =>20$:				; 180..270 =>	SUB.W	D0,#90	NEG.W	D030$:	LOAD.W	D2,D4	SL.W	D0,#1		; D0 <-- *2 car table de .W	MUL.WA	D2,(A0)+(D0.W)	DIV.WA	D2,#1000	LOAD.W	D4,D2	COMP.B	D1,#1	JUMP',EQ 50$	COMP.B	D1,#2	JUMP',NE 90$				;  90..180 =>50$:				; 180..270 =>	NEG.W	D490$:	POPM.L	D0..D2	RET;--------\\; SINUS   >;--------/; in	D4.W	valeur;	D0.W	angle en degrs;	A0.L	^table des sinus; out	D4.W	sinus de la valeur; mod	D4.WSINUS:	PUSHM.L	D0..D2	AND.L	D0,#H'FFFF	DIV.WU	D0,#90	LOAD.W	D1,D0		; D1 <-- octant (0..3)	SWAP.W	D0		; D0 <-- angle (0..90-1)	COMP.B	D1,#1	JUMP',EQ 20$	COMP.B	D1,#3	JUMP',NE 30$				;  90..180 =>20$:				; 270..360 =>	SUB.W	D0,#90	NEG.W	D030$:	LOAD.W	D2,D4	SL.W	D0,#1		; D0 <-- *2 car table de .W	MUL.WA	D2,(A0)+(D0.W)	DIV.WA	D2,#1000	LOAD.W	D4,D2	COMP.B	D1,#2	JUMP',EQ 50$	COMP.B	D1,#3	JUMP',NE 90$				; 180..270 =>50$:				; 270..360 =>	NEG.W	D490$:	POPM.L	D0..D2	RET; Table des sinus *1000 de 0  90 degrs :TSINUS:	.W	0,17,35,52,70,87,105,122,139,156		; 0..9	.W	174,191,208,225,242,259,276,292,309,326		; 10..19	.W	342,358,375,391,407,423,438,454,469,485		; 20..29	.W	500,515,530,545,559,574,588,602,616,629		; 30..39	.W	643,656,669,682,695,707,719,731,743,755		; 40..49	.W	766,777,788,799,809,819,829,839,848,857		; 50..59	.W	866,875,883,891,899,906,914,921,927,934		; 60..69	.W	940,946,951,956,961,966,970,974,978,982		; 70..79	.W	985,988,990,993,995,996,998,999,999,1000	; 80..89	.W	1000						; 90	.END