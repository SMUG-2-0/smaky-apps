	.SBTTL	DESMATRIX;----------\\; DESMATRIX >;==========/; Dessine toutes les matrices.; in	-; out	-; mod	D7.WDESMATRIX:	CALL	DESPMATRIX	; dessine la petite matrice	CALL	DESGMATRIX	; dessine la grande matrice	RET;-----------\\; DESPMATRIX >;===========/; Dessine toute la petite matrice.; in	-; out	-; mod	D7.WDESPMATRIX:	PUSHM.L	D0..D5,A3,A4	CLR.L	D4	CALL	DRMDEF	CLR.W	D0	LOAD.W	D4,(A6)+OMALSX	SUB.W	D4,(A6)+OPMOVX	SUB.W	D4,(A6)+OPMDIX	JUMP',HS 20$	NEG.W	D4	LOAD.W	D0,D4	LOAD.W	D3,(A6)+OPMPOX	ADD.W	D3,(A6)+OPMDIX	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OPMPOY	LOAD.W	D4,(A6)+OPMDIY	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface bande  droite20$:	CLR.W	D1	LOAD.W	D4,(A6)+OMALSY	SUB.W	D4,(A6)+OPMOVY	SUB.W	D4,(A6)+OPMDIY	JUMP',HS 30$	NEG.W	D4	LOAD.W	D1,D4	LOAD.W	D3,(A6)+OPMPOY	ADD.W	D3,(A6)+OPMDIY	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OPMPOX	LOAD.W	D4,(A6)+OPMDIX	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface bande en bas30$:	LOAD.L	A3,(A6)+OPMAT	; A3 <-- ^matrice source	.IF	DESSIN	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP',NC 40$		; non => 40$				; oui =>	LOAD.L	A4,(A6)+OPMAM	; A3 <-- ^matrice destination	CALL	REDUIT		; OPMAM <-- matrice rduite	LOAD.L	A3,A440$:	.ENDIF	LOAD.L	D3,(A6)+OPMOVY	; D3 <-- position source	LOAD.L	A4,#0		; A4 <-- matrice destination dans l'cran	LOAD.L	D4,(A6)+OPMPOY	; D4 <-- position destination	LOAD.L	D5,(A6)+OPMDIY	; D5 <-- dimensions	SUB.W	D5,D0	SWAP.W	D5	SUB.W	D5,D1	SWAP.W	D5	LOAD.W	D2,#LOADDOT	; D2 <-- mode	CALL	XFERZONE	; petit rectangle <-- matrice principale	POPM.L	D0..D5,A3,A4	RET;-----------\\; DESGMATRIX >;===========/; Dessine toute la grande matrice.; in	-; out	-; mod	D7.WDESGMATRIX:	PUSHM.L	D0..D5,A1	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,LE 90$	LOAD.W	D3,(A6)+OGMOVY	SWAP.W	D3		; D3 <-- position initiale en Y	CLR.L	D5	LOAD.W	D5,(A6)+OGMDIY	DIV.WU	D5,(A6)+OGMLPY	; D5 <-- nb points verticalement	INC.W	D5		; D5 <-- +1 si fraction de point10$:	LOAD.W	D3,(A6)+OGMOVX	; D3 <-- position initiale en X	CLR.L	D4	LOAD.W	D4,(A6)+OGMDIX	DIV.WU	D4,(A6)+OGMLPX	; D4 <-- nb points horizontalement	INC.W	D4		; D4 <-- +1 si fraction de point	CLR.W	D020$:	LOAD.W	D2,#CLRDOT	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice	CALL	TESTPOINT	JUMP',NE 30$	TEST.B	(A1):D1	JUMP',BC 30$	LOAD.W	D2,#SETDOT30$:	COMP.W	D2,#CLRDOT	JUMP',NE 50$	INC.W	D0		; D0 <-- un point teint de plus	JUMP'	70$50$:	LOAD.W	D1,D0		; un/qq points teint avant ?	JUMP',EQ 60$		; non => 60$	PUSH.W	D3	SUB.W	D3,D1	LOAD.W	D2,#CLRDOT	CALL	DESGPOINT	; teint qq points	POP.W	D3	CLR.W	D060$:	LOAD.W	D1,#1	LOAD.W	D2,#SETDOT	CALL	DESGPOINT	; allume le point70$:	INC.W	D3		; D3 <-- avance en X	DEC.W	D4	JUMP,NE 20$	LOAD.W	D1,D0		; un/qq points teint avant ?	JUMP',EQ 80$		; non => 80$	SUB.W	D3,D1	LOAD.W	D2,#CLRDOT	CALL	DESGPOINT	; teint qq points80$:	SWAP.W	D3	INC.W	D3		; D3 <-- avance en Y	SWAP.W	D3	DEC.W	D5	JUMP,NE 10$90$:	POPM.L	D0..D5,A1	RET;-----------\\; MAJGMATRIX >;===========/; Met  jour la grande matrice  l'cran en fonction des diffrences; entre la matrice principale et sa copie.; Seuls les points modifis (allums ou teints) sont r-affichs.; in	-; out	-; mod	D7.WMAJGMATRIX:	PUSHM.L	D0..D6,A1	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,LE 90$	LOAD.W	D3,(A6)+OGMOVY	SWAP.W	D3		; D3 <-- position initiale en Y	CLR.L	D5	LOAD.W	D5,(A6)+OGMDIY	DIV.WU	D5,(A6)+OGMLPY	; D5 <-- nb points verticalement	INC.W	D5		; D5 <-- +1 si fraction de point10$:	LOAD.W	D3,(A6)+OGMOVX	; D3 <-- position initiale en X	CLR.L	D4	LOAD.W	D4,(A6)+OGMDIX	DIV.WU	D4,(A6)+OGMLPX	; D4 <-- nb points horizontalement	INC.W	D4		; D4 <-- +1 si fraction de point	CLR.W	D020$:	LOAD.W	D6,#CLRDOT	LOAD.L	A1,(A6)+OPMAC	; A1 <-- ^matrice copie	CALL	TESTPOINT	JUMP',NE 25$	TEST.B	(A1):D1	JUMP',BC 25$	LOAD.W	D6,#SETDOT25$:	LOAD.W	D2,#CLRDOT	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	CALL	TESTPOINT	JUMP',NE 30$	TEST.B	(A1):D1	JUMP',BC 30$	LOAD.W	D2,#SETDOT30$:	COMP.W	D2,D6		; point indentique  la copie ?	JUMP',NE 40$		; non => 40$				; oui =>	LOAD.W	D1,D0		; un/qq points teint avant ?	JUMP',EQ 70$		; non => 70$	PUSH.W	D3	SUB.W	D3,D1	LOAD.W	D2,#CLRDOT	CALL	DESGPOINT	; teint qq points	POP.W	D3	CLR.W	D0	JUMP'	70$40$:	COMP.W	D2,#CLRDOT	JUMP',NE 50$	INC.W	D0		; D0 <-- un point teint de plus	JUMP'	70$50$:	LOAD.W	D1,D0		; un/qq points teint avant ?	JUMP',EQ 60$		; non => 60$	PUSH.W	D3	SUB.W	D3,D1	LOAD.W	D2,#CLRDOT	CALL	DESGPOINT	; teint qq points	POP.W	D3	CLR.W	D060$:	LOAD.W	D1,#1	LOAD.W	D2,#SETDOT	CALL	DESGPOINT	; allume le point70$:	INC.W	D3		; D3 <-- avance en X	DEC.W	D4	JUMP,NE 20$	LOAD.W	D1,D0		; un/qq points teint avant ?	JUMP',EQ 80$		; non => 80$	SUB.W	D3,D1	LOAD.W	D2,#CLRDOT	CALL	DESGPOINT	; teint qq points80$:	SWAP.W	D3	INC.W	D3		; D3 <-- avance en Y	SWAP.W	D3	DEC.W	D5	JUMP,NE 10$90$:	POPM.L	D0..D6,A1	RET;-----------\\; SHOGMATRIX >;===========/; Met  jour la grande matrice  l'cran et en mmoire en fonction; des diffrences entre la matrice principale et son affichage;  l'cran.; Seuls les points modifis (allums ou teints) sont r-affichs.; in	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WSHOGMATRIX:	PUSHM.L	D0..D6,A0..A2	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,LE EXIT$	TEST.W	D4	JUMP,LE EXIT$	SWAP.W	D4	TEST.W	D4	JUMP,LE EXIT$	SWAP.W	D4	CALL	CCMO		; enlve la souris	LOAD.L	D5,D4	SWAP.W	D5		; D5 <-- nb points verticalement	LOAD.L	A2,A0		; A2 <-- description fentreLOOPY$:	PUSHM.L	D3,D4	CLR.W	D0LOOPX$:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COUL$		; oui => COUL$	PUSHM.L	D0,D4,A0	LOAD.L	D4,D3	SUB.W	D4,(A6)+OPMOVX	ADD.W	D4,(A6)+OPMPOX	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	ADD.W	D4,(A6)+OPMPOY	; D4 <-- coordonne dans petit rectangle	SWAP.W	D4	LOAD.L	A1,(A6)+OQXDOT	CALL	(A1)		; appel GRA_QXDOT	LOAD.W	D2,#CLRDOT	TEST.B	(A0):D0	JUMP',BC SCR$	LOAD.W	D2,#SETDOTSCR$:	POPM.L	D0,D4,A0	JUMP'	GO$COUL$:	PUSHM.L	D3,D4	LOAD.L	D4,D3	SUB.W	D4,(A6)+OPMOVX	ADD.W	D4,(A6)+OPMPOX	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	ADD.W	D4,(A6)+OPMPOY	; D4 <-- coordonne dans petit rectangle	SWAP.W	D4	LOAD.L	A1,(A6)+OGDOT	LOAD.L	D3,A1	JUMP',EQ NOGDOT$	CALL	(A1)		; appel GRA_GDOT, D3 <-- fausse couleurNOGDOT$:	LOAD.W	D2,#CLRDOT	TEST.L	D3		; point blanc ?	JUMP',EQ CSCR$		; oui => CSCR$	LOAD.W	D2,#SETDOTCSCR$:	POPM.L	D3,D4;	JUMP'	GO$GO$:	LOAD.W	D6,#CLRDOT	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	CALL	TESTPOINT	JUMP',NE MAT$	TEST.B	(A1):D1	JUMP',BC MAT$	LOAD.W	D6,#SETDOTMAT$:	COMP.W	D2,D6		; point indentique  la copie ?	JUMP',NE DIFF$		; non => DIFF$				; oui =>	LOAD.W	D1,D0		; un/qq points teint avant ?	JUMP',EQ NEXTX$		; non => NEXTX$	PUSH.W	D3	SUB.W	D3,D1	LOAD.W	D2,#CLRDOT	CALL	DESGPOINT	; teint qq points	POP.W	D3	CLR.W	D0	JUMP'	NEXTX$DIFF$:	COMP.W	D2,#CLRDOT	JUMP',NE SET$	INC.W	D0		; D0 <-- un point teint de plus	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	CALL	TESTPOINT	JUMP',NE NEXTX$	TCLR.B	(A1):D1		; teint le point dans la matrice principale	JUMP'	NEXTX$SET$:	LOAD.W	D1,D0		; un/qq points teint avant ?	JUMP',EQ SETG$		; non => SETG$	PUSH.W	D3	SUB.W	D3,D1	LOAD.W	D2,#CLRDOT	CALL	DESGPOINT	; teint qq points	POP.W	D3	CLR.W	D0SETG$:	LOAD.W	D1,#1	LOAD.W	D2,#SETDOT	CALL	DESGPOINT	; allume le point	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	CALL	TESTPOINT	JUMP',NE NEXTX$	TSET.B	(A1):D1		; allume le point dans la matrice principaleNEXTX$:	INC.W	D3		; D3 <-- avance en X	DEC.W	D4	JUMP,NE LOOPX$	LOAD.W	D1,D0		; un/qq points teint avant ?	JUMP',EQ NEXTY$		; non => NEXTY$	SUB.W	D3,D1	LOAD.W	D2,#CLRDOT	CALL	DESGPOINT	; teint qq pointsNEXTY$:	POPM.L	D3,D4	SWAP.W	D3	INC.W	D3		; D3 <-- avance en Y	SWAP.W	D3	DEC.W	D5	JUMP,NE LOOPY$EXIT$:	POPM.L	D0..D6,A0..A2	RET;-----------\\; MOVGMATRIX >;===========/; Inverse les points dplacs dans la grande matrice; d'aprs la matrice principale (qui contient le dessin; initial sans les nouveaux points) et le petit rectangle; sur l'cran (qui contient le dessin initial plus le; nouvel objet dessin en inverse).; in	D2.W	mode de dessin (SETDOT/CLRDOT);	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WMOVGMATRIX:	PUSHM.L	D0..D6,A0..A2	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,LE EXIT$	TEST.W	D4	JUMP,LE EXIT$	SWAP.W	D4	TEST.W	D4	JUMP,LE EXIT$	SWAP.W	D4	CALL	CCMO		; enlve la souris	LOAD.L	D5,D3		; D5 <-- coin sup/gauche	LOAD.W	D6,D2		; D6 <-- mode de dessin	LOAD.L	A2,A0		; A2 <-- description fentreLOOPY$:	PUSHM.L	D4,D5LOOPX$:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COUL$		; oui => COUL$	PUSHM.L	D0,D4,A0	LOAD.L	D4,D5	SUB.W	D4,(A6)+OPMOVX	ADD.W	D4,(A6)+OPMPOX	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	ADD.W	D4,(A6)+OPMPOY	SWAP.W	D4		; D4 <-- coordonne dans petit rectangle	LOAD.L	A1,(A6)+OQXDOT	CALL	(A1)		; appel GRA_QXDOT	LOAD.L	A1,A0	LOAD.B	D1,D0	POPM.L	D0,D4,A0	COMP.W	D6,#CLRDOT	JUMP',EQ CLR$SET$:	TEST.B	(A1):D1	JUMP',BC NEXTX$	JUMP'	EXIST$CLR$:	TEST.B	(A1):D1	JUMP',BS NEXTX$	JUMP'	EXIST$COUL$:	PUSH.L	D4	LOAD.L	D4,D5	SUB.W	D4,(A6)+OPMOVX	ADD.W	D4,(A6)+OPMPOX	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	ADD.W	D4,(A6)+OPMPOY	SWAP.W	D4		; D4 <-- coordonne dans petit rectangle	LOAD.L	A1,(A6)+OGDOT	LOAD.L	D3,A1	JUMP',EQ NOGDOT$	CALL	(A1)		; appel GRA_GDOT, D3 <-- fausse couleurNOGDOT$:	POP.L	D4	COMP.W	D6,#CLRDOT	JUMP',EQ CCLR$CSET$:	TEST.L	D3		; point blanc ?	JUMP',EQ NEXTX$		; oui => NEXTX$	JUMP'	EXIST$CCLR$:	TEST.L	D3		; point blanc ?	JUMP',NE NEXTX$		; non => NEXTX$;	JUMP'	EXIST$EXIST$:	LOAD.W	D2,#CLRDOT	LOAD.L	D3,D5	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	CALL	TESTPOINT	JUMP',NE MATRIX$	TEST.B	(A1):D1	JUMP',BC MATRIX$	LOAD.W	D2,#SETDOT	; D2 <-- tat point dans principaleMATRIX$:	COMP.W	D2,D6	JUMP',EQ NEXTX$				; point  dessiner =>	LOAD.L	D3,D5	LOAD.W	D1,#1	LOAD.W	D2,#INVDOT	CALL	DESGPOINT	; inverse le pointNEXTX$:	INC.W	D5		; D5 <-- avance en X	DEC.W	D4	JUMP,NE LOOPX$	POPM.L	D4,D5	SWAP.W	D5	INC.W	D5		; D5 <-- avance en Y	SWAP.W	D5	SWAP.W	D4	DEC.W	D4	LOAD.W	D1,D4	SWAP.W	D4	TEST.W	D1	JUMP,NE LOOPY$EXIT$:	POPM.L	D0..D6,A0..A2	RET;--------\\; DDINIT  >;========/; Initialise pour un dplacement.; in	D1/D2.L	emplacement nouveau;	D5/D6.L	emplacement initial; out	-; mod	D7.WDDINIT:	PUSHM.L	D1..D4	PUSHM.L	D1,D2	LOAD.L	D1,D5	LOAD.L	D2,D6	CALL	ORDONNE	LOAD.L	(A6)+OLASTD1,D1	LOAD.L	(A6)+OLASTD2,D2	POPM.L	D1,D2	LOAD.L	D3,(A6)+OFLAGS	TEST.L	D3:#BFLAUTO	; automatique ?	JUMP',BC 20$		; non => 20$	LOAD.B	D4,(A6)+OSELECT	; D4 <-- rectangle/filet/crochet	LOAD.B	D3,#2^BFLCONT	COMP.B	D4,#ICOFILET	JUMP',EQ 20$	LOAD.B	D3,#2^BFLOR20$:	LOAD.B	(A6)+ODD,D3	; ODD <-- mode de dplacement	CALL	DDCOPEN		; ouvre la matrice contour	CALL	DDPRECT		; dessine rectangle dans matrice masque	COMP.B	(A6)+ODDOP,#ICODEPLACE	JUMP',EQ 40$	COMP.B	(A6)+ODDOP,#ICODUPLIQUE	JUMP',EQ 40$				; bloc-notes/ajoute =>	TEST.W	(A6)+OSCALE	JUMP',NC 45$	CALL	INVENTOURE	; dessine le rectangle pointill	JUMP'	45$40$:				; dplace/duplique =>	TEST.W	(A6)+OSCALE	JUMP',NS 45$	CALL	INVENTOURE	; efface le rectangle pointill45$:	CALL	DDMOVE		; dplace dans l'cran	POPM.L	D1..D4	RET;----------\\; DDISOURCE >;==========/; Inverse la zone  dplacer dans la matrice copie.; in	D5/D6.L	emplacement initial; out	-; mod	D7.WDDISOURCE:	PUSHM.L	D1..D5,A3,A4	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NS 90$		; oui => 90$	LOAD.L	D1,D5	LOAD.L	D2,D6	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice masque (source)	LOAD.L	D3,D1	LOAD.L	A4,(A6)+OPMAC	; A4 <-- ^matrice copie (destination)	LOAD.L	D4,D1	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	XFERZONE	; inverse ...90$:	POPM.L	D1..D5,A3,A4	RET;--------\\; DDCOPEN >;========/; Ouvre la matrice pour extraire le contour.; in	D5/D6.L	emplacement initial; out	D7.W	erreur; mod	D7.WDDCOPEN:	PUSHM.L	D1..D6,A2..A4	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+ODD:#BFLCONT	JUMP',BS 10$	TEST.B	(A6)+ODD:#BFLBOLD	JUMP,BC 90$10$:	LOAD.L	D1,D5	LOAD.L	D2,D6	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	ADD.W	D2,#6	SWAP.W	D2	ADD.W	D2,#6	SWAP.W	D2	LOAD.L	D5,D1	LOAD.L	D6,D2	LOAD.L	(A6)+ODDDIM,D6	LOAD.L	D4,D2	SWAP.W	D4	ADD.W	D2,#8-1	SR.W	D2,#3	LOAD.W	(A6)+ODDNBB,D2	MUL.WU	D4,D2	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour matrice	JUMP,NE 90$	LOAD.L	(A6)+ODDPMA,A4	SR.W	D4,#1		; D4 <-- /2 car transfert par .W	DEC.W	D4		; D4 <-- -1  cause NMO30$:	CLR.W	(A4+)	DECJ.W,NMO D4,30$	PUSH.L	D5	LOAD.L	A3,(A6)+OPMAM	LOAD.L	D3,D5	LOAD.L	A4,(A6)+ODDPMA	LOAD.L	D4,#H'10000*3+3	LOAD.L	D5,D6	SUB.W	D5,#6	SWAP.W	D5	SUB.W	D5,#6	SWAP.W	D5	LOAD.W	D2,#SETDOT	LOAD.W	(A6)+OMANBS,(A6)+OMANBB	LOAD.W	(A6)+OMANBD,(A6)+ODDNBB	CALL	XFERZONESD	POP.L	D5	PUSH.L	(A6)+OMALMY	PUSH.W	(A6)+OMANBB	LOAD.W	(A6)+OMANBB,(A6)+ODDNBB	LOAD.L	(A6)+OMALMY,D6	LOAD.L	A4,(A6)+ODDPMA	CALL	OPEDISMAT	; init dessin dans ODDPMA	POP.W	(A6)+OMANBB	POP.L	(A6)+OMALMY	CLR.L	D3	LOAD.L	D4,D6	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle pour dlimiter le tour	LOAD.L	D4,#-1	CALL	DRMDEF		; dfinit une trame pleine	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWFILLO	LOAD.L	(A3)+1,#H'10000*1+1 ; <xx> et <yy>	LOAD.B	(A3)+5,#DRAWFILLC	LOAD.W	D3,#5+1	LIB	?STRING		; rempli ...	LOAD.L	A4,(A6)+ODDPMA	LOAD.W	D4,(A6)+ODDDIM+0	MUL.WU	D4,(A6)+ODDNBB	SR.W	D4,#1		; D4 <-- /2 car transfert par .W	DEC.W	D4		; D4 <-- -1  cause NMO60$:	NOT.W	(A4+)		; inverse tout (rapidement)	DECJ.W,NMO D4,60$	TEST.B	(A6)+ODD:#BFLBOLD	JUMP,BC 80$	LOAD.L	A3,(A6)+OPMAM	LOAD.L	D3,D5	LOAD.L	A4,(A6)+ODDPMA;	LOAD.L	D4,#H'10000*3+3	LOAD.L	D5,D6	SUB.W	D5,#6	SWAP.W	D5	SUB.W	D5,#6	SWAP.W	D5	LOAD.W	D2,#SETDOT	LOAD.W	(A6)+OMANBS,(A6)+OMANBB	LOAD.W	(A6)+OMANBD,(A6)+ODDNBB	LOAD.L	A2,#R16"01$	; A2 <-- ^table pour contour gras70$:	LOAD.L	D4,(A2+)	JUMP',EQ 80$	CALL	XFERZONESD	; diminue un peu le masque !	JUMP	70$80$:	CALL	CLODISMAT	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.W	2,2	.W	2,3	.W	2,4	.W	3,2;	.W	3,3		; inutile (si, si !)	.W	3,4	.W	4,2	.W	4,3	.W	4,4	.W	0,0;---------\\; DDCCLOSE >;=========/; Ferme la matrice pour extraire le contour.; in	-; out	-; mod	D7.WDDCCLOSE:	PUSHM.L	D1,A4	TEST.L	(A6)+ODDPMA	JUMP',EQ 90$	LOAD.L	A4,(A6)+ODDPMA	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire	CLR.L	(A6)+ODDPMA90$:	POPM.L	D1,A4	RET;--------\\; DDPRECT >;========/; Dessine (en inverse) le rectangle pointill dans la matrice masque.; in	D5/D6.L	emplacement initial; out	-; mod	D7.WDDPRECT:	PUSHM.L	D1..D4,A4	LOAD.L	D1,D5	LOAD.L	D2,D6	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	LOAD.L	A4,(A6)+OPMAM	CALL	OPEDISMAT	; dessine dans la matrice masque	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D3,D1		; D3 <-- origine	LOAD.L	D4,D2		; D4 <-- dimensions	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT		; inverse le rectangle	CALL	CLODISMAT	; redessine dans l'cran	POPM.L	D1..D4,A4	RET;-------------\\; DDINVENTOURE >;=============/; Inverse le rectangle entourant la zone slectionne par la souris,; seulement si l'chelle est ngative (tout).; in	D1.L	position d'un coin;	D2.L	position de l'autre coin; out	-; mod	D7.WDDINVENTOURE:	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NS INVENTOURE	; oui => INVENTOURE	RET			; non => ne fait rien;--------\\; DDMOVE  >;========/; Dessine les points allums d'une zone rectangulaire dans; le petit et dans le grand rectangle.; in	D1/D2.L	emplacement nouveau;	D5/D6.L	emplacement initial; out	-; mod	D7.WDDMOVE:	PUSHM.L	D0..D6,A3..A5	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NS 90$		; oui => 90$	CALL	ORDONNE		; D1/D2 <-- ordonne	EX.L	D1,D5	EX.L	D2,D6	CALL	ORDONNE		; D5/D6 <-- ordonne	EX.L	D1,D5	EX.L	D2,D6; Regarde si le rectangle dpasse la partie visible.	LOAD.L	D4,(A6)+OGMOVY	; D4 <-- nouvel emplacement partie visible	COMP.W	D1,(A6)+OGMOVX	; dpasse  gauche ?	JUMP',HS 10$	LOAD.W	D4,D110$:	CLR.L	D3	LOAD.W	D3,(A6)+OGMDIX	DIV.WU	D3,(A6)+OGMLPX	; D3 <-- largeur visible	ADD.W	D3,(A6)+OGMOVX	SUB.W	D3,D2		; dpasse  droite ?	JUMP',HS 11$	NEG.W	D3	ADD.W	D3,(A6)+OGMOVX	LOAD.W	D4,D311$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D4	COMP.W	D1,(A6)+OGMOVY	; dpasse en haut ?	JUMP',HS 12$	LOAD.W	D4,D112$:	CLR.L	D3	LOAD.W	D3,(A6)+OGMDIY	DIV.WU	D3,(A6)+OGMLPY	; D3 <-- hauteur visible	ADD.W	D3,(A6)+OGMOVY	SUB.W	D3,D2		; dpasse en bas ?	JUMP',HS 13$	NEG.W	D3	ADD.W	D3,(A6)+OGMOVY	LOAD.W	D4,D313$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D4	PUSH.L	D4		; stack <-- nouvel emplacement; Remet l'tat initial dans la matrice principale (d'aprs la; matrice copie).	PUSHM.L	D1,D2,D5	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.L	A3,(A6)+OPMAC	LOAD.L	D3,(A6)+OLASTD1	TEST.W	D3	JUMP',EQ 15$	DEC.W	D3	INC.W	D515$:	INC.W	D5	LOAD.W	D4,(A6)+OMALMX	SUB.W	D4,D3	COMP.W	D5,D4	JUMP',LS 16$	LOAD.W	D5,D416$:	SWAP.W	D3	SWAP.W	D5	TEST.W	D3	JUMP',EQ 17$	DEC.W	D3	INC.W	D517$:	INC.W	D5	LOAD.W	D4,(A6)+OMALMY	SUB.W	D4,D3	COMP.W	D5,D4	JUMP',LS 18$	LOAD.W	D5,D418$:	SWAP.W	D3	SWAP.W	D5	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D4,D3	LOAD.W	D2,#LOADDOT	; D2 <-- mode de dessin	CALL	XFERZONE	; matrice principale <-- matrice copie	POPM.L	D1,D2,D5; Si le contour existe, efface le contour dans la matrice principale.	TEST.L	(A6)+ODDPMA	; masque pour contour existe ?	JUMP,EQ 30$		; non => 30$				; oui =>	PUSHM.L	D1,D2,D5,D6	CALL	POSDIM		; D1 <-- pos et D2 <-- dim (nouveau)	LOAD.L	A3,(A6)+ODDPMA	; A3 <-- ^matrice contour (source)	LOAD.L	D3,#H'10000*3+3	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice principale (destination)	LOAD.L	D4,D1	LOAD.L	D5,D2		; D5 <-- dimensions	TEST.B	(A6)+ODD:#BFLBOLD	JUMP,BC 25$	TEST.W	D4	JUMP',EQ 20$	DEC.W	D3	DEC.W	D4	INC.W	D520$:	LOAD.W	D1,D4	ADD.W	D1,D5	COMP.W	D1,(A6)+OMALMX	JUMP',HS 21$	INC.W	D521$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	TEST.W	D4	JUMP',EQ 22$	DEC.W	D3	DEC.W	D4	INC.W	D522$:	LOAD.W	D1,D4	ADD.W	D1,D5	COMP.W	D1,(A6)+OMALMY	JUMP',HS 23$	INC.W	D523$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D525$:	LOAD.W	D2,#CLRDOT	LOAD.W	(A6)+OMANBS,(A6)+ODDNBB	LOAD.W	(A6)+OMANBD,(A6)+OMANBB	CALL	XFERZONESD	; matrice principale <-- efface l'emplacement	POPM.L	D1,D2,D5,D6; Dessine la zone dplace dans la matrice principale.30$:	PUSHM.L	D1,D2	CALL	POSDIM		; D1 <-- pos et D2 <-- dim (nouveau)	EX.L	D1,D5	EX.L	D2,D6	CALL	POSDIM		; D5 <-- pos et D6 <-- dim (initial)	EX.L	D1,D5	EX.L	D2,D6	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice masque	LOAD.L	D3,D5	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D4,D1	LOAD.L	D5,D6		; D5 <-- dimensions	COMP.B	(A6)+OMODE,#ICOCLEAR	JUMP',NE 34$	LOAD.W	D2,#CLRDOT	; D2 <-- mode de dessin	COMP.B	(A6)+ODDOP,#ICOBLOC1	JUMP',EQ 35$	COMP.B	(A6)+ODDOP,#ICOBLOC2	JUMP',EQ 35$	COMP.B	(A6)+ODDOP,#ICOBLOC3	JUMP',EQ 35$34$:	LOAD.W	D2,#LOADDOT	; D2 <-- mode de dessin	TEST.B	(A6)+ODD:#BFLLOAD	JUMP',BS 35$	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin35$:	CALL	XFERZONE	; matrice principale <-- zone dplace	POPM.L	D1,D2; Dessine dans l'cran une zone qui englobe l'ancien et le nouvel; emplacement de la partie dplace.	POP.L	D4		; D4 <-- nouvel emplacement	COMP.L	D4,(A6)+OGMOVY	; dplace la partie visible ?	JUMP,NE 50$		; oui => 50$				; non =>	PUSHM.L	D1,D2	COMP.W	D1,(A6)+OLASTD1+2	JUMP',LS 40$	LOAD.W	D1,(A6)+OLASTD1+240$:	SWAP.W	D1	COMP.W	D1,(A6)+OLASTD1+0	JUMP',LS 41$	LOAD.W	D1,(A6)+OLASTD1+041$:	SWAP.W	D1	COMP.W	D2,(A6)+OLASTD2+2	JUMP',HS 42$	LOAD.W	D2,(A6)+OLASTD2+242$:	SWAP.W	D2	COMP.W	D2,(A6)+OLASTD2+0	JUMP',HS 43$	LOAD.W	D2,(A6)+OLASTD2+043$:	SWAP.W	D2	LOAD.L	A4,(A6)+OPMAT	LOAD.L	D5,D1	LOAD.L	D6,D2	LOAD.W	D0,#LOADDOT	CALL	BBPGMATRIX	; dessine dans l'cran	POPM.L	D1,D2	JUMP	80$; Dplace la partie visible, car le rectangle dpassait un bord.50$:	LOAD.L	D3,D4		; D3 <-- nouvel emplacement	LOAD.L	D4,(A6)+OGMOVY	; D4 <-- ancien emplacement	LOAD.L	(A6)+OGMOVY,D3	.IF	DESSIN	LOAD.L	(A6)+OPMOVY,D3	.ENDIF	LOAD.W	(A6)+OASHOR+OSCPOSV,D3	SWAP.W	D3	LOAD.W	(A6)+OASVER+OSCPOSV,D3	.IF	EDGAR	CALL	DESGRILLE	; pour effacer v. qq points  droite	.ENDIF	CALL	DESPMATRIX	; dessine la petite matrice	CALL	DESGMATRIX	; dessine la grande matrice	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 80$		; non => 80$				; oui =>	COMP.W	D4,(A6)+OGMOVX	JUMP',EQ 55$	LOAD.L	A5,#(A6)+OASHOR	; A5 <-- ^descripteur ascenseur horizontal	SCROLL_	UPDATE		; dplace l'ascenseur55$:	SWAP.W	D4	COMP.W	D4,(A6)+OGMOVY	JUMP',EQ 80$	LOAD.L	A5,#(A6)+OASVER	; A5 <-- ^descripteur ascenseur vertical	SCROLL_	UPDATE		; dplace l'ascenseur; Mmorise le nouvel emplacement (le prochain coup, ce sera; l'emplacement initial).80$:	LOAD.L	(A6)+OLASTD1,D1	LOAD.L	(A6)+OLASTD2,D290$:	POPM.L	D0..D6,A3..A5	RET;-----------\\; DDPGMATRIX >;===========/; Dessine les points allums d'une zone rectangulaire dans; le petit et dans le grand rectangle.; in	D1/D2.L	emplacement nouveau;	D5/D6.L	emplacement initial;	D0.W	mode de dessin; out	-; mod	D7.WDDPGMATRIX:	PUSH.L	A4	LOAD.L	A4,(A6)+OPMAM	; A4 <-- ^matrice masque	CALL	BBPGMATRIX	POP.L	A4	RET;-----------\\; BBPGMATRIX >;===========/; Dessine les points allums d'une zone rectangulaire dans; le petit et dans le grand rectangle.; in	D1/D2.L	emplacement nouveau;	D5/D6.L	emplacement initial;	A4.L	^matrice initiale;	D0.W	mode de dessin; out	-; mod	D7.WBBPGMATRIX:	PUSHM.L	D0..D6,A1..A4	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NS 90$		; oui => 90$	LOAD.L	A2,A4		; A2 <-- ^matrice initiale; Dessine les points de la zone dans le petit rectangle.	CALL	POSDIM		; D1 <-- pos et D2 <-- dim (nouveau)	EX.L	D1,D5	EX.L	D2,D6	CALL	POSDIM		; D5 <-- pos et D6 <-- dim (initial)	EX.L	D1,D5	EX.L	D2,D6	LOAD.L	A3,A2		; A3 <-- ^matrice source	LOAD.L	D3,D5	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.L	D4,D1	SUB.W	D4,(A6)+OPMOVX	ADD.W	D4,(A6)+OPMPOX	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	ADD.W	D4,(A6)+OPMPOY	SWAP.W	D4	LOAD.L	D5,D6		; D5 <-- dimensions	LOAD.W	D6,(A6)+OPMPOX	COMP.W	D4,D6		; dpasse  gauche ?	JUMP',GE 20$	SUB.W	D6,D4	ADD.W	D1,D6	ADD.W	D3,D6	ADD.W	D4,D6	SUB.W	D5,D620$:	LOAD.W	D6,(A6)+OPMPOX	ADD.W	D6,(A6)+OPMDIX	SUB.W	D6,D4	COMP.W	D5,D6		; dpasse  droite ?	JUMP',LE 22$	LOAD.W	D5,D622$:	SWAP.W	D1	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	LOAD.W	D6,(A6)+OPMPOY	COMP.W	D4,D6		; dpasse en haut ?	JUMP',GE 24$	SUB.W	D6,D4	ADD.W	D1,D6	ADD.W	D3,D6	ADD.W	D4,D6	SUB.W	D5,D624$:	LOAD.W	D6,(A6)+OPMPOY	ADD.W	D6,(A6)+OPMDIY	SUB.W	D6,D4	COMP.W	D5,D6		; dpasse en bas ?	JUMP',LE 26$	LOAD.W	D5,D626$:	SWAP.W	D1	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	LOAD.W	D2,D0		; D2 <-- mode de dessin	CALL	XFERZONE	; petit rectangle <-- zone; Dessine les points de la zone dans le grand rectangle.	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,LE 90$;	LOAD.L	D3,D3		; D3 <-- origine (y;x) source	LOAD.L	D4,D1		; D4 <-- origine (y;x) destination30$:	PUSHM.L	D3..D5	CLR.W	D040$:	LOAD.W	D2,#CLRDOT	LOAD.L	A1,A2		; A1 <-- ^matrice	CALL	TESTPOINT	JUMP',NE 42$	TEST.B	(A1):D1	JUMP',BC 42$	LOAD.W	D2,#SETDOT42$:	COMP.W	D2,#CLRDOT	JUMP',NE 44$	INC.W	D0		; D0 <-- un point teint de plus	JUMP'	48$44$:	LOAD.W	D1,D0		; un/qq points teint avant ?	JUMP',EQ 46$		; non => 46$	PUSH.W	D3	SUB.W	D3,D1	LOAD.W	D2,#CLRDOT	CALL	DESGPOINT	; teint qq points	POP.W	D3	CLR.W	D046$:	LOAD.W	D1,#1	LOAD.W	D2,#SETDOT	CALL	DESGPOINT	; allume le point48$:	INC.W	D3		; D3 <-- avance source en X	INC.W	D4		; D4 <-- avance destination en X	DEC.W	D5	JUMP,NE 40$	LOAD.W	D1,D0		; un/qq points teint avant ?	JUMP',EQ 50$		; non => 50$	SUB.W	D3,D1	LOAD.W	D2,#CLRDOT	CALL	DESGPOINT	; teint qq points50$:	POPM.L	D3..D5	SWAP.W	D3	INC.W	D3		; D3 <-- avance source en Y	SWAP.W	D3	SWAP.W	D4	INC.W	D4		; D4 <-- avance destination en Y	SWAP.W	D4	SWAP.W	D5	DEC.W	D5	LOAD.W	D2,D5	SWAP.W	D5	TEST.W	D2	JUMP,NE 30$90$:	POPM.L	D0..D6,A1..A4	RET;----------\\; TESTPOINT >;==========/; Donne de quoi allumer, teindre, inverser ou tester un point; dans la matrice du caractre avec une instruction du type :;	TEST.B	(A1):D1; in	D3.L	position (y;x);	A1.L	^matrice; out	A1.L	^byte;	D1.B	bit dans le byte;	D7.W	erreur => hors de la matrice; mod	D1.L, D7.W, A1.LTESTPOINT:	PUSHM.L	D3,D4	LOAD.L	D4,D3		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	COMP.W	D3,(A6)+OMALMX	JUMP',HS 90$	COMP.W	D4,(A6)+OMALMY	JUMP',HS 90$	MUL.WU	D4,(A6)+OMANBB	LOAD.B	D1,D3	NOT.B	D1		; D1 <-- bit 2^7  gauche !	AND.B	D1,#B'111	; D1 <-- no du bit dans le byte	SR.W	D3,#3	ADD.W	A1,D3	ADD.L	A1,D4	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DESPPOINT >;==========/; Dessine un point dans la petite matrice.; S'il est en dehors de la partie visible, ne dessine rien !; in	D3.L	position du point (y;x);	D2.W	mode de dessin; out	-; mod	D7.WDESPPOINT:	PUSHM.L	D0,D1,D4,A0..A2	LOAD.L	D4,D3		; D4 <-- position du point	SUB.W	D4,(A6)+OPMOVX	; dpasse  gauche ?	JUMP',LO EXIT$	COMP.W	D4,(A6)+OPMDIX	; dpasse  droite ?	JUMP',HS EXIT$	ADD.W	D4,(A6)+OPMPOX	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	; dpasse en haut ?	JUMP',LO EXIT$	COMP.W	D4,(A6)+OPMDIY	; dpasse en bas ?	JUMP',HS EXIT$	ADD.W	D4,(A6)+OPMPOY	SWAP.W	D4	CALL	CCMO		; enlve la souris	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COUL$		; oui => COUL$	LOAD.L	A2,A0		; A2 <-- description fentre	LOAD.L	A1,(A6)+OQXDOT	CALL	(A1)		; appel GRA_QXDOT	COMP.W	D2,#SETDOT	JUMP',EQ SET$	COMP.W	D2,#CLRDOT	JUMP',EQ CLR$	TNOT.B	(A0):D0	JUMP'	EXIT$SET$:	TSET.B	(A0):D0	JUMP'	EXIT$CLR$:	TCLR.B	(A0):D0	JUMP'	EXIT$COUL$:	LOAD.B	D1,D2		; D1 <-- mode	LOAD.L	A2,A0		; A2 <-- description fentre	LOAD.L	A1,(A6)+ODOT	CALL	(A1)		; appel GRA_DOTEXIT$:	POPM.L	D0,D1,D4,A0..A2	RET;----------\\; DESGPOINT >;==========/; Dessine un point dans la grande matrice.; S'il est en dehors de la partie visible, ne dessine rien !; in	D3.L	position du point (y;x);	D2.W	mode de dessin;	D1.W	nb de points horizontaux (1..n); out	-; mod	D7.WDESGPOINT:	PUSHM.L	D0,D1,D3,D4	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,LE 90$	LOAD.L	D4,D3		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	SUB.W	D3,(A6)+OGMOVX 	JUMP,LO 90$	MUL.WU	D3,(A6)+OGMLPX	ADD.W	D3,(A6)+OGMPOX	SUB.W	D4,(A6)+OGMOVY	JUMP,LO 90$	MUL.WU	D4,(A6)+OGMLPY	ADD.W	D4,(A6)+OGMPOY	SWAP.W	D3	LOAD.W	D3,D4		; D3 <-- position (y;x)	SWAP.W	D3	LOAD.W	D4,(A6)+OGMLPX	MUL.WU	D4,D1	DEC.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OGMLPY	DEC.W	D4	SWAP.W	D4	LOAD.W	D0,(A6)+OGMPOX	ADD.W	D0,(A6)+OGMDIX	SUB.W	D0,D3	JUMP,LE 90$	COMP.W	D4,D0		; point dpasse  droite ?	JUMP',LO 40$	LOAD.W	D4,D040$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,(A6)+OGMPOY	ADD.W	D0,(A6)+OGMDIY	SUB.W	D0,D3	JUMP,LE 90$	COMP.W	D4,D0		; point dpasse en bas ?	JUMP',LO 45$	LOAD.W	D4,D045$:	SWAP.W	D3	SWAP.W	D4; Si on est  ct du petit rectangle, gre correctement le clipping; pour dessiner la ou les deux parties rectangulaires du point.	.IF	EDGAR	COMP.W	D1,#1		; dessine plus d'un point ?	JUMP',EQ 50$		; non => 50$	CALL	CLRREPERE	; oui => efface les repres50$:	.ENDIF	LOAD.L	D0,D3	SWAP.W	D0	SUB.W	D0,(A6)+OPRPOY	SUB.W	D0,(A6)+OPRDIY	SUB.W	D0,#2		;  ct du petit rectangle ?	JUMP',PL 70$		; non => 70$				; oui =>	LOAD.W	D0,D3	ADD.W	D0,D4	SUB.W	D0,(A6)+OPRPOX	ADD.W	D0,#2		; touche le bord gauche du rectangle ?	JUMP',MI 70$		; non => 70$				; oui =>	LOAD.W	D0,(A6)+OPRPOX	SUB.W	D0,#2	SUB.W	D0,D3	JUMP',LE 60$	PUSH.W	D4	LOAD.W	D4,D0	CALL	GPOINT		; dessine la partie gauche du point	POP.W	D4	ADD.W	D3,D0	SUB.W	D4,D060$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,(A6)+OPRPOY	ADD.W	D0,(A6)+OPRDIY	ADD.W	D0,#2	SUB.W	D0,D3	ADD.W	D3,D0	SUB.W	D4,D0	JUMP',LE 90$	SWAP.W	D4	SWAP.W	D370$:	CALL	GPOINT		; dessine un gros point90$:	POPM.L	D0,D1,D3,D4	RET;--------\\; GPOINT  >;--------/; Dessine un gros point (surface pleine).;; Joue sur la constation suivante :;  GRA_SET/CLEAR/INV	->	rapide si grande surface;  GRA_TRAME		->	rapide si petite surface; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WGPOINT:	PUSHM.L	D1,D3,D4,A1,A2,A4	CALL	CCMO		; enlve la souris	EX.L	D3,D4		; D4 <-- (y;x) et D3 <-- (dy;dx)	LOAD.L	A2,A0		; A2 <-- ^description fentre	COMP.W	D2,#SETDOT	JUMP',EQ 60$	COMP.W	D2,#CLRDOT	JUMP',EQ 40$	LOAD.W	D1,D2	LOAD.L	A4,#R16"01$	LOAD.L	A1,(A6)+OTRAME	CALL	(A1)		; inverse le point	JUMP'	90$40$:	COMP.W	D3,#32		; grande surface ?	JUMP',HS 50$		; oui => 50$	LOAD.W	D1,D2	LOAD.L	A4,#R16"00$	LOAD.L	A1,(A6)+OTRAME	CALL	(A1)		; efface le point	JUMP'	90$50$:	LOAD.L	A1,(A6)+OCLEAR	CALL	(A1)		; efface le point	JUMP'	90$60$:	LOAD.W	D1,D2	LOAD.L	A4,#R16"01$	LOAD.L	A1,(A6)+OTRAME	CALL	(A1)		; allume le point;	JUMP'	90$90$:	POPM.L	D1,D3,D4,A1,A2,A4	RET00$:	.B	H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'0001$:	.B	H'FF,H'FF,H'FF,H'FF,H'FF,H'FF,H'FF,H'FF	.EVEN;----------\\; DETGPOINT >;==========/; Comme DETGPOINTF, mais en tenant compte du pas !; in	D4.L	position de la souris (y;x); out	D3.L	position du point (y;x);	D7.W	ok/erreur; mod	D3.L, D7.WDETGPOINT:	CALL	DETGPOINTF	; D3 <-- position brutte	CALL	PASGPOINT	; D3 <-- position arrondie	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DETGPOINTF >;===========/; Dtecte dans quel point de la grande matrice est la souris.; En cas d'erreur, rend la position la plus proche !; in	D4.L	position de la souris (y;x); out	D3.L	position du point (y;x);	D7.W	ok/erreur; mod	D3.L, D7.WDETGPOINTF:	PUSH.L	D4	CLR.W	D7		; D7 <-- dans la matrice; Vrifie d'abord si la souris est dans le petit rectangle.	LOAD.L	D3,D4	SUB.W	D3,(A6)+OPRPOX	; souris trop  gauche ?	JUMP',LO 10$	COMP.W	D3,(A6)+OPRDIX	; souris trop  droite ?	JUMP',HS 10$	SWAP.W	D3	SUB.W	D3,(A6)+OPRPOY	; souris trop en haut ?	JUMP',LO 10$	COMP.W	D3,(A6)+OPRDIY	; souris trop en bas ?	JUMP',HS 10$; Donne les positions dans la petite matrice, en tenant compte; des marges entre le petit rectangle et la petite matrice.	LOAD.L	D3,D4	SUB.W	D3,(A6)+OPMPOX	; souris trop  gauche ?	JUMP',HS 02$	CLR.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice02$:	COMP.W	D3,(A6)+OPMDIX	; souris trop  droite ?	JUMP',LO 03$	LOAD.W	D3,(A6)+OPMDIX	DEC.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice03$:	ADD.W	D3,(A6)+OPMOVX	SWAP.W	D3	SUB.W	D3,(A6)+OPMPOY	; souris trop en haut ?	JUMP',HS 04$	CLR.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice04$:	COMP.W	D3,(A6)+OPMDIY	; souris trop en bas ?	JUMP',LO 05$	LOAD.W	D3,(A6)+OPMDIY	DEC.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice05$:	ADD.W	D3,(A6)+OPMOVY	SWAP.W	D3	JUMP	90$; Dtecte o est la souris dans la grande matrice.10$:	CLR.L	D3	LOAD.W	D3,D4		; D3 <-- position en X	CLR.W	D4	SWAP.W	D4		; D4 <-- position en Y	SUB.W	D3,(A6)+OGMPOX	; souris trop  gauche ?	JUMP',HS 20$	CLR.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice20$:	COMP.W	D3,(A6)+OGMDIX	; souris trop  droite ?	JUMP',LO 21$	LOAD.W	D3,(A6)+OGMDIX	DEC.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice21$:	DIV.WU	D3,(A6)+OGMLPX	ADD.W	D3,(A6)+OGMOVX	COMP.W	D3,(A6)+OMALMX	JUMP',LO 22$	LOAD.W	D3,(A6)+OMALMX	DEC.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice22$:	SUB.W	D4,(A6)+OGMPOY	; souris trop en haut ?	JUMP',HS 40$	CLR.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice40$:	COMP.W	D4,(A6)+OGMDIY	; souris trop en bas ?	JUMP',LO 41$	LOAD.W	D4,(A6)+OGMDIY	DEC.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice41$:	DIV.WU	D4,(A6)+OGMLPY	ADD.W	D4,(A6)+OGMOVY	SWAP.W	D3	LOAD.W	D3,D4		; D3 <-- position (y;x)	SWAP.W	D390$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DETGPOINTOUT >;=============/; Dtecte o est la souris, mme si elle dpasse la surface de dessin.; in	D4.L	position de la souris (y;x); out	D3.L	position du point (y;x); mod	D3.L, D7.WDETGPOINTOUT:	PUSH.L	D4	CLR.W	D7		; D7 <-- dans la matrice	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,HI 30$; Dtecte o est la souris dans la petite matrice.	LOAD.L	D3,D4	SUB.W	D3,(A6)+OPMPOX	ADD.W	D3,(A6)+OPMOVX	SWAP.W	D3	SUB.W	D3,(A6)+OPMPOY	ADD.W	D3,(A6)+OPMOVY	SWAP.W	D3	JUMP	50$; Dtecte o est la souris dans la grande matrice.30$:	CLR.L	D3	LOAD.W	D3,D4		; D3 <-- position en X	CLR.W	D4	SWAP.W	D4		; D4 <-- position en Y	SUB.W	D3,(A6)+OGMPOX	DIV.WA	D3,(A6)+OGMLPX	ADD.W	D3,(A6)+OGMOVX	SUB.W	D4,(A6)+OGMPOY	DIV.WA	D4,(A6)+OGMLPY	ADD.W	D4,(A6)+OGMOVY	SWAP.W	D3	LOAD.W	D3,D4		; D3 <-- position (y;x)	SWAP.W	D3; Si on dpasse la matrice, ramne la position dedans.50$:	TEST.W	D3	JUMP',NC 60$	CLR.W	D360$:	COMP.W	D3,(A6)+OMALMX	JUMP',LO 61$	LOAD.W	D3,(A6)+OMALMX	DEC.W	D361$:	SWAP.W	D3	TEST.W	D3	JUMP',NC 62$	CLR.W	D362$:	COMP.W	D3,(A6)+OMALMY	JUMP',LO 63$	LOAD.W	D3,(A6)+OMALMY	DEC.W	D363$:	SWAP.W	D3	POP.L	D4	RET;----------\\; PASGPOINT >;==========/; Arrondi une coordonne selon le pas.; in	D3.L	coordonne (y;x); out	D3.L	coordonne (y;x); mod	D3.LPASGPOINT:	PUSHM.L	D1,D2,D4	LOAD.W	D2,(A6)+OPAS	; D2 <-- pas	COMP.W	D2,#1	JUMP,EQ 90$	LOAD.W	D1,D2	SR.W	D1,#1		; D1 <-- 1/2 pas	LOAD.L	D4,D3	CLR.W	D4	SWAP.W	D4		; D4 <-- position en Y	AND.L	D3,#H'FFFF	; D3 <-- position en X	ADD.W	D3,D1	DIV.WU	D3,D2	MUL.WU	D3,D2	ADD.W	D4,D1	DIV.WU	D4,D2	MUL.WU	D4,D2	SWAP.W	D3	LOAD.W	D3,D4		; D3 <-- coordonne arrondie (y;x)	SWAP.W	D390$:	POPM.L	D1,D2,D4	RET;-----------\\; CONVGPOINT >;===========/; Transforme la coordonne d'un point dans la grande matrice; en un point dans l'cran.; in	D3.L	position d'un point (y;x); out	D3.L	position dans l'cran (y;x);	D7.W	erreur; mod	D3.L, D7.WCONVGPOINT:	PUSH.L	D2	LOAD.W	D7,#1		; D7 <-- en dehors	LOAD.W	D2,D3	SWAP.W	D3	SUB.W	D3,(A6)+OGMOVY	; dpasse en haut ?	JUMP,LT 90$	MUL.WU	D3,(A6)+OGMLPY	ADD.W	D3,(A6)+OGMPOY	DEC.W	D3	SWAP.W	D3	SUB.W	D2,(A6)+OGMOVX	; dpasse  gauche ?	JUMP,LT 90$	MUL.WU	D2,(A6)+OGMLPX	ADD.W	D2,(A6)+OGMPOX	DEC.W	D2	LOAD.W	D3,D2	LOAD.W	D2,(A6)+OGMPOX	ADD.W	D2,(A6)+OGMDIX	COMP.W	D3,D2		; dpasse  droite ?	JUMP',HI 90$	SWAP.W	D3	LOAD.W	D2,(A6)+OGMPOY	ADD.W	D2,(A6)+OGMDIY	COMP.W	D3,D2		; dpasse en bas ?	JUMP',HI 90$	SWAP.W	D3	CLR.W	D7		; D7 <-- ok90$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET	.END