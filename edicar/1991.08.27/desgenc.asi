	.SBTTL	DESGENC	.IF	EDGARADDMCAR:	CALL	DBOXCAR		; D3 <-- code choisit	JUMP,NE _ERROR	COMP.B	D3,(A6)+OCAR	; mme caractre ?	JUMP,EQ _BIP	CALL	COPYALL		; fait une copie de la matrice	LOAD.L	A3,(A6)+OPGC	AND.W	D3,#H'7F	MUL.WU	D3,(A3)+OGCMSB	ADD.L	D3,#OGCMAT	ADD.L	A3,D3		; A3 <-- ^matrice source	CLR.L	D3	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	CLR.L	D4	LOAD.L	D5,(A6)+OMALMY	; D5 <-- dimensions	LOAD.W	D2,#SETDOT	; D2 <-- mode	CALL	XFERZONE	; matrice actuelle <-- matrice choisie	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	JUMP	_LOOPOPERCAR:	CLR.L	D4	CALL	DBOXOPER	; D4 <-- fanions (style soft)	JUMP,NE _ERROR	COMP.W	D3,#CR	JUMP,NE _LOOP	TEST.L	D4		; qq chose  faire ?	JUMP,EQ _BIP	CALL	WAITMOUSE	; met le sablier	CALL	CHKGENC		; met  jour qq paramtres du gencar	LOAD.L	A4,(A6)+OPGC	PUSH.B	(A4)+OGCFCA	PUSH.B	(A4)+OGCLCA	CLR.B	(A4)+OGCFCA	; y'a tous les caractres !	LOAD.B	(A4)+OGCLCA,#127	LOAD.L	D0,#'N	LOAD.L	D1,#'R	LOAD.L	D2,#12	LOAD.L	D3,#'N	LOAD.L	D5,#12	TEST.L	D4:#24	JUMP',BC 20$	SL.B	D5,#1		; D5 <-- double la taille20$:	GENCAR_	CREATE	LOAD.L	A3,A4		; A3 <-- ^nouveau gencar	LOAD.L	A4,(A6)+OPGC	POP.B	(A4)+OGCLCA	POP.B	(A4)+OGCFCA	TEST.W	D7	JUMP,NE _ERROR	CLR.W	D3	LOAD.B	D3,(A3)+OGCMWB	LOAD.W	(A6)+OMANBB,D3	SL.W	D3,#3	LOAD.W	(A6)+OMALMX,D3	LOAD.W	(A6)+OMALMY,(A3)+OGCMHD	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le gencar initial	LOAD.L	A4,(A6)+OPMAC	GESMEM	?GIVMEM		; rend la matrice copie	LOAD.L	A4,(A6)+OPMAM	GESMEM	?GIVMEM		; rend la matrice masque	LOAD.W	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMALMY	GESMEM	?GETMEM		; redemande la matrice copie	JUMP,NE FATMEM	LOAD.L	(A6)+OPMAC,A4	CALL	CLEARALL	GESMEM	?GETMEM		; redemande la matrice masque	JUMP,NE FATMEM	LOAD.L	(A6)+OPMAM,A4	LOAD.L	(A6)+OPGC,A3	LOAD.B	D3,(A6)+OCAR	; D3 <-- caractre en dition	CLR.L	(A6)+OSEPP1	CLR.L	(A6)+OSEPP2	; plus de sparateur	LOAD.W	D4,#SCALEMAX	CALL	IFSCALE		; tout est visible ?	JUMP',EQ 60$		; oui => 60$	LOAD.W	D4,#SCALELOUPE	CALL	IFSCALE		; tout est visible ?	JUMP',EQ 60$		; oui => 60$	LOAD.W	D4,#SCALEMIN60$:	CLR.L	(A6)+OPMOVY	CLR.L	(A6)+OPMDIY	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	CALL	CARSELECT	; slectionne le mme caractre	JUMP	_LOOPOPERMIN:	CALL	DBOXMINUS	; Etes-vous sr ?	COMP.W	D3,#CR	JUMP,NE _LOOP	LOAD.L	A2,#R16"00$	CLR.W	D2	LOAD.W	D4,#'20$:	CLR.W	D3	LOAD.B	D3,(A2+)	; D3 <-- caractre source suivant	JUMP',EQ 40$	LOAD.L	A3,(A6)+OPGC	LOAD.L	A1,#(A3)+OGCWID	ADD.W	A1,D3		; A1 <-- ^largeur source	MUL.WU	D3,(A3)+OGCMSB	ADD.L	D3,#OGCMAT	ADD.L	A3,D3		; A3 <-- ^matrice source (a, e, i, etc)	LOAD.L	A4,(A6)+OPGC	LOAD.W	D3,D4	LOAD.L	A5,#(A4)+OGCWID	ADD.W	A5,D3		; A5 <-- ^largeur destination	MUL.WU	D3,(A4)+OGCMSB	ADD.L	D3,#OGCMAT	ADD.L	A4,D3		; A4 <-- ^matrice destination ()	CALL	XFERALL		; transfert une lettre	COMP.B	D4,(A6)+OCAR	; caractre destination visible ?	JUMP',NE 30$		; non => 30$	INC.W	D2		; oui => indique-le	CALL	CLRREPERE	; efface les repres30$:	LOAD.B	(A5),(A1)	; transfert aussi la largeur	INC.W	D4		; D4 <-- caractre destination suivant	JUMP	20$40$:	TEST.W	D2		; caractre visible modifi ?	JUMP,EQ _LOOP		; non => _LOOP	CALL	DESMATRIX	; oui => affiche les matrices	JUMP	_LOOP00$:	.ASCIZ	"uaaeeeeiiouuaoc"	.EVEN;----------\\; SEARCHLGV >;==========/; Cherche la largeur maximale d'un caractre.; in	A4.L	^matrice; out	D4.W	largeur maximale; mod	D4.L, D7.WSEARCHLGV:	PUSHM.L	D0..D3,A4	CLR.W	D4		; D4 <-- largeur maximale	LOAD.W	D0,(A6)+OMALMY; Calcul dans D2.W la longueur d'une ligne.20$:	PUSH.L	A4	LOAD.W	D1,(A6)+OMANBB	ADD.W	A4,D1	LOAD.W	D2,D1	SL.W	D2,#3		; D2 <-- largeur maximale30$:	LOAD.B	D3,(-A4)	JUMP',EQ 36$32$:	RR.B	D3	JUMP',CS 38$	DEC.W	D2		; D2 <-- un bit "vide"	JUMP	32$36$:	SUB.W	D2,#8		; D2 <-- un byte entier "vide"	DEC.W	D1	JUMP,NE 30$38$:	POP.L	A4	COMP.W	D4,D2	JUMP',HS 50$	LOAD.W	D4,D2		; D4 <-- largeur maximale50$:	ADD.W	A4,(A6)+OMANBB	; A4 <-- dbut ligne suivante	DEC.W	D0	JUMP,NE 20$	POPM.L	D0..D3,A4	RET;--------\\; CHKGENC >;========/; Met  jour qq paramtres dans l'en-tte d'un gencar comme :;	- les 128 largeurs ne doivent pas dpasser;	- les 128 hauteurs h1 et h2;	- la largeur maximale;	- les pointeurs relatifs;	- les textes;	- etc.; in	-; out	-; mod	D7.WCHKGENC:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A4,(A6)+OPGC; Vrifie qu'aucune largeur ne dpasse la largeur maximale; de la matrice.	CLR.W	D3	LOAD.B	D3,(A4)+OGCMWB	SL.W	D3,#3		; D3 <-- largeur maximale	LOAD.L	A3,#(A4)+OGCWID	; A3 <-- ^largeurs	LOAD.W	D4,#128-110$:	COMP.B	D3,(A3+)	; largeur dpasse  droite ?	JUMP',HS 15$		; non => 15$	LOAD.B	(A3)-1,D3	; oui => met au maximum  droite15$:	DECJ.W,NMO D4,10$; Initialise la table des hauteurs h1 (en-dessus de la ligne de base).	LOAD.W	D3,(A4)+OGCMHD	SUB.W	D3,(A4)+OGCBLI	LOAD.L	A3,#(A4)+OGCH1	; A3 <-- ^h1	LOAD.W	D4,#128-120$:	LOAD.B	(A3+),D3	; h1 <-- hauteur	DECJ.W,NMO D4,20$	LOAD.W	(A4)+OGCMH1,D3; Initialise la table des hauteurs h2 (en-dessous de la ligne de base).	LOAD.W	D3,(A4)+OGCBLI	LOAD.L	A3,#(A4)+OGCH2	; A3 <-- ^h2	LOAD.W	D4,#128-130$:	LOAD.B	(A3+),D3	; h2 <-- hauteur	DECJ.W,NMO D4,30$	LOAD.W	(A4)+OGCMH2,D3; Cherche la largeur maximale parmis les 128 caractres.	CLR.W	D3	LOAD.L	A3,#(A4)+OGCWID	; A3 <-- ^largeurs	LOAD.W	D4,#128-140$:	COMP.B	D3,(A3+)	; largeur dpasse  droite ?	JUMP',HS 45$		; non => 45$	LOAD.B	D3,(A3)-1	; D3 <-- largeur maximale45$:	DECJ.W,NMO D4,40$	LOAD.W	(A4)+OGCMWI,D3; Met  jour les pointeurs relatifs.	CLR.W	D3	LOAD.B	D3,(A4)+OGCLCA	SUB.B	D3,(A4)+OGCFCA	INC.B	D3		; D3 <-- nb de caractres	CLR.W	D4	LOAD.W	(A4)+OGCPWI,D4	ADD.W	D4,D3	LOAD.W	(A4)+OGCPH1,D4	ADD.W	D4,D3	LOAD.W	(A4)+OGCPH2,D4	ADD.W	D4,D3	LOAD.W	(A4)+OGCPMX,D4; Met la date (jour, mois et anne) actuelle.	LIB	?RDCLOCK	; D4 <-- date en BCD	LOAD.B	(A4)+OGCDAT+3,D4 ; anne	LOAD.B	(A4)+OGCDAT+2,#H'19 ; toujours 19xx (!)	SR.L	D4,#8	LOAD.B	(A4)+OGCDAT+1,D4 ; mois	SR.L	D4,#8	LOAD.B	(A4)+OGCDAT+0,D4 ; jour; Met  jour le texte fixe inutile et le nom de l'auteur s'il est omis.	LOAD.L	A2,#R16"00$	LOAD.L	A3,#(A4)+OGCTXT70$:	LOAD.B	(A3+),(A2+)	; gencar <-- texte fixe	JUMP,NE 70$	LOAD.L	A2,#R16"01$	LOAD.L	A3,#(A4)+OGCIDE	TEST.B	(A3)	JUMP',EQ 72$	COMP.B	(A3),#CR	JUMP',NE 75$72$:	LOAD.B	(A3+),(A2+)	; gencar <-- EDICAR se prend pour un auteur !	JUMP,NE 72$75$:	POPM.L	D3,D4,A2..A4	RET00$:	.ASCIZ	"(C) 1896, Daniel ROUX et EPSITEC-system sa"01$:	.ASCIZ	"EDICAR"	.EVEN	.ENDIF;-----------\\; DBOXGENCAR >;===========/; Dialogue pour la DBOX des gencars.; in	-; out	D7.W	erreur; mod	D7.WDBOXGENCAR:	PUSHM.L	D0..D5,A0..A5	CLR.W	D3	CALL	SELMO		; met la flche10$:	LOAD.L	D4,(A6)+OFAGC	; D4 <-- fanions	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A5,#(A6)+OGCLIST; A5 <-- ^liste des gencars sur disque	LOAD.W	D5,#MAXGENC*3	; D5 <-- lg pour la liste	LOAD.L	D1,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	DGENC_	MODIF		; modifie un/qq gencar(s) ...	JUMP',NE 90$	LOAD.L	(A6)+OFAGC,D4	; mm. derniers fanions utiliss	COMP.W	D3,#F1		; MODIFIE ?	JUMP,EQ 10$	COMP.W	D3,#F4		; SUPPRIME ?	JUMP',NE 90$	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	KILL		; libre le gencar	JUMP	10$90$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	POPM.L	D0..D5,A0..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DEFGENCAR >;==========/; Utilise tous les gencars par dfaut.; Conserve 30 Kbytes de mmoire libre !; in	-; out	-; mod	D7.WDEFGENCAR:	PUSHM.L	D3,D4,D5,A2..A5	LOAD.L	A5,#R16"TGDEF	LOAD.L	A4,#(A6)+OBUGC	LOAD.B	D3,#2^BGCPROT20$:	TEST.B	(A5)		; fin de la table ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	A3,#(A4)+OGCTIT30$:	LOAD.B	(A3+),(A5+)	; OBUGC <-- titre	JUMP,NE 30$	LOAD.B	(A4)+OGCFLG,D3	LOAD.B	(A4)+OGCF,(A5+)	; OBUGC <-- fonte	LOAD.B	(A4)+OGCS,(A5+)	; OBUGC <-- style	LOAD.B	(A4)+OGCT,(A5+)	; OBUGC <-- taille	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	NEW	JUMP',NE 60$	GESMEM	?ARGMEM		; D5 <-- zone libre conscutive	COMP.L	D5,#30000	; reste assez ?	JUMP',LO 80$		; non => 80$60$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- suivant dans OBUGC	CLR.B	D3		; D3 <-- protection seulement pour 1er	JUMP	20$80$:	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	KILL90$:	POPM.L	D3,D4,D5,A2..A5	RET;---------\\; OPETEXTE >;=========/; "Ouvre" une ligne de texte pour pouvoir l'diter.; in	D3.L	point o est la souris (y;x); out	D7.W	erreur; mod	D7.WOPETEXTE:	PUSHM.L	D2,D4,A4	CALL	CLOTEXTE	; ferme v. ancienne ligne !	CALL	GETPGC		; A4 <-- ^dans OBUGC	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la fentre	LOAD.L	D4,D3	SWAP.W	D4	SUB.W	D4,(A4)+OGC1Y	LOAD.W	D2,(A6)+OPMOVY	COMP.W	D4,D2		; dpasse en haut ?	JUMP',LT 90$	ADD.W	D4,(A4)+OGC1Y	ADD.W	D4,(A4)+OGC2Y	ADD.W	D2,(A6)+OPMDIY	COMP.W	D4,D2		; dpasse en bas ?	JUMP',GE 90$	LOAD.L	(A6)+OPOTEXT,D3	CLR.B	(A6)+OLITEXT	; on part avec une ligne vide	CLR.W	(A6)+OLGTEXT	; longueur nulle	CLR.B	(A6)+OACTEXT	; pas d'accent flottant	CALL	DESTEXTE	; dessine la ligne de texte	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2,D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DESTEXTE >;=========/; Dessine toute la ligne de texte en dition dans les; deux rectangles  l'cran.; Si la ligne est raccourcie, restitue ce qui tait dessous; en fonction de la matrice-copie.; in	-; out	-; mod	D7.WDESTEXTE:	PUSHM.L	D1..D6,A2..A4	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#NOCURS	; enlve le curseur	LOAD.B	(A3)+1,#MODCAR	LOAD.B	(A3)+2,#SETDOT!PENDOT	COMP.B	(A6)+OMODE,#ICOCLEAR	JUMP',NE 20$	LOAD.B	(A3)+2,#CLRDOT!PENDOT20$:	CALL	GETPGC		; A4 <-- ^dans OBUGC	LOAD.L	A2,A4		; A2 <-- idem	LOAD.L	(A3)+3,(A4)+OGCCOD	LOAD.B	(A3)+3,#USEGC	LOAD.W	D3,#1+2+4	LIB	?STRING		; slectionne mode et gencar	LOAD.L	D3,(A6)+OPOTEXT	SUB.W	D3,(A6)+OPMOVX	JUMP,LO 80$	LOAD.W	D2,D3	ADD.W	D3,(A6)+OPMPOX	SWAP.W	D3	SUB.W	D3,(A6)+OPMOVY	JUMP,LO 80$	ADD.W	D3,(A6)+OPMPOY	SWAP.W	D3	LIB	?SETCURS	LOAD.L	D4,D3; Transfert la ligne de texte dans OBUDIS, jusqu' la fin ou; jusqu' ce que la marge droite soit rencontre.	PUSHM.L	A2,A4	SUB.W	D2,(A6)+OPMDIX	NEG.W	D2		; D2 <-- lg jusqu' droite	LOAD.L	A2,(A0)+ODFPGC	; A2 <-- ^gencar	LOAD.L	A2,#(A2)+OGCWID	; A2 <-- ^table des largeurs	LOAD.L	A3,#(A6)+OLITEXT	LOAD.L	A4,#(A6)+OBUDIS30$:	CLR.W	D3	LOAD.B	D3,(A3+)	JUMP',EQ 35$	CLR.W	D1	LOAD.B	D1,(A2)+(D3.W)	; D1 <-- largeur du caractre	SUB.W	D2,D1	JUMP',LO 34$	LOAD.B	(A4+),D3	; OBUDIS <-- ligne de texte	JUMP	30$34$:	CLR.B	(A3)-1		; raccourci la ligne !	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; fait un p'tit bruit35$:	CLR.B	(A4)		; OBUDIS <-- terminateur	LOAD.L	A3,#(A6)+OBUDIS	LIB	?AFTEXT		; affiche la ligne de texte	POPM.L	A2,A4	LIB	?GETCURS	SUB.W	D3,D4		; D3 <-- longueur du texte	COMP.W	D3,(A6)+OLGTEXT	; ligne plus courte ?	JUMP',HS 50$		; non => 50$				; oui =>	PUSHM.L	D3,A4	LOAD.W	D1,D3		; D1 <-- nouvelle longueur (trop courte)	LOAD.L	D3,D4	ADD.W	D3,D1	SUB.W	D3,(A2)+OGC1X	; D3 <-- <xx>	LOAD.W	D5,(A6)+OLGTEXT	SUB.W	D5,D1		; D5 <-- <dxx> largeur  restituer	SWAP.W	D3	SWAP.W	D5	LOAD.W	D5,(A2)+OGC1Y	SUB.W	D3,D5		; D3 <-- <yy>	ADD.W	D5,(A2)+OGC2Y	; D5 <-- <dyy> hauteur  restituer	SWAP.W	D3	SWAP.W	D5	LOAD.L	D4,D3	LOAD.W	D2,#INVDOT	LOAD.L	A3,#0	LOAD.L	A4,A3	CALL	XFERZONE	; efface la partie raccourcie dans l'cran	LOAD.L	A3,(A6)+OPMAC	; A3 <-- ^matrice source (copie)	LOAD.L	D3,(A6)+OPOTEXT	ADD.W	D3,D1	SUB.W	D3,(A2)+OGC1X	SWAP.W	D3	SUB.W	D3,(A2)+OGC1Y	SWAP.W	D3	LOAD.W	D2,#SETDOT	CALL	XFERZONE	; remet le contenu initial selon copie	POPM.L	D3,A450$:	LOAD.W	D1,(A6)+OLGTEXT	LOAD.W	(A6)+OLGTEXT,D3	; mm nouvelle longeur de la ligne	LOAD.L	D3,(A6)+OPOTEXT	SUB.W	D3,(A2)+OGC1X	; D3 <-- <xx>	SWAP.W	D3	SUB.W	D3,(A2)+OGC1Y	; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D4,(A2)+OGC1Y	ADD.W	D4,(A2)+OGC2Y	; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,(A6)+OLGTEXT	; D4 <-- <dxx>	COMP.W	D4,D1		; nouvelle lg plus grande ?	JUMP',HS 60$		; oui => 60$	LOAD.W	D4,D1		; non => prend l'ancienne60$:	CALL	SHOGMATRIX	; affiche ligne dans grande matrice80$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	MODCAR,SETDOT	; remet le mode normal	.B	PCURS,CURS	; affiche le curseur dans la ligne	.B	0	.EVEN	POPM.L	D1..D6,A2..A4	RET;---------\\; CLOTEXTE >;=========/; "Ferme" une ligne de texte.; Les points sont transfrs dans la matrice principale.; in	-; out	-; mod	D7.WCLOTEXTE:	PUSHM.L	D3,D4,A4	TEST.L	(A6)+OPOTEXT	; ligne de texte existe ?	JUMP',EQ 90$		; non => 90$				; oui =>	LOAD.B	D3,#NOCURS	LIB	?AFCAR		; enlve le curseur	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE 80$	CALL	GETPGC		; A4 <-- ^dans OBUGC	LOAD.L	D3,(A6)+OPOTEXT	SUB.W	D3,(A4)+OGC1X	; D3 <-- <xx>	SWAP.W	D3	SUB.W	D3,(A4)+OGC1Y	; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D4,(A4)+OGC1Y	ADD.W	D4,(A4)+OGC2Y	; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,(A6)+OLGTEXT	; D4 <-- <dxx>	CALL	CPECRANMATRIX	; matrice <-- cran (petit rectangle)	CALL	SCMO		; remet la souris80$:	CLR.L	(A6)+OPOTEXT	; plus de texte en dition90$:	POPM.L	D3,D4,A4	RET;--------\\; GETPGC  >;========/; Donne le pointeur dans OBUGC au gencar actullement utilis.; in	-; out	A4.L	^dans OBUGC; mod	A4.LGETPGC:	PUSHM.L	D3,D4	LOAD.L	D4,(A6)+OFAGC	; D4 <-- fanions dbox gencar	JUMP',EQ 50$	LOAD.W	D3,#-120$:	INC.W	D3		; D3 <-- compte le rang du bit dans D4	RR.L	D4	JUMP,CC 20$	LOAD.L	A4,#(A6)+OBUGC	MUL.WU	D3,#LGGC	ADD.L	A4,D3	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BS 90$		; oui => 90$50$:	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- prend "Fond"90$:	POPM.L	D3,D4	RET;----------\\; GETACCENT >;==========/; Calcul le code correspondant  une lettre (a,e,i,o,u) et ; un accent (^,").; in	D4.B	accent (^,");	D3.B	caractre; out	D7.W	zro => ok (lettre accentue existe);	 D3.B	 lettre accentue;	D7.W	un => lettre accentue n'existe pas;	 D3.B	 caractre qui devait aller sous l'accent; mod	D3.B, D7.WGETACCENT:	PUSH.L	A3	LOAD.L	A3,#R16"TABACCENT-310$:	ADD.L	A3,#3		; A3 <-- ^suivant dans table	TEST.B	(A3)		; fin de la table ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,(A3)		; lettre trouve dans table ?	JUMP,NE 10$		; non => 10$				; oui =>	COMP.B	D4,#'^	JUMP',EQ 30$	COMP.B	D4,#'"	JUMP',NE 50$	LOAD.B	D3,(A3)+2	; D3 <-- lettre accentue (")	CLR.W	D7		; D7 <-- ok	JUMP'	90$30$:	LOAD.B	D3,(A3)+1	; D3 <-- lettre accentue (^)	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.W	D7,#1		; D7 <-- erreur90$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RETTABACCENT:	.B	'a	' '	.B	'e	' '	.B	'i	' '	.B	'o	' '	.B	'u	' '	.B	SPACE	'^ '"	.B	KCIRCON	'^ '^	.B	KTREMA	'" '"	.B	0	.EVEN	.END