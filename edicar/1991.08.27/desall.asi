	.SBTTL	DESALLNBALLX	=	16		; tout: nb car/ligneNBALLY	=	8		; tout: nb lignesMCALL	=	4		; marge autour d'un caractreALLCAR:	TEST.L	(A6)+OPGC	; gencar existe ?	JUMP,EQ BIP		; non => BIP	CALL	OPENALL		; ouvre la swdo	JUMP,NE ERROR	CALL	ALLALLCAR	; affiche tous les caractres	LOAD.B	D2,(A6)+OCAR	; D2 <-- caractre en dition	LOAD.B	D3,D2	CALL	ALLINVERSE	; montre le caractre en dition20$:	CLR.B	D3	CALL	SELMO		; remet la flche	CALL	SCMO		; remet la souris	LIB	?GETCAR		; attend clavier/souris ...	COMP.W	D3,#F0+SHIFT	JUMP',LO 22$	COMP.W	D3,#F15+SHIFT	JUMP',HI 22$	SUB.W	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)22$:	COMP.W	D3,#KEYMGR	JUMP,EQ 20$	COMP.W	D3,#KEYMMR	JUMP,EQ 20$	COMP.W	D3,#KEYMDR	JUMP,EQ 20$	COMP.W	D3,#KEYMGP	JUMP,EQ 40$	COMP.W	D3,#KEYMMP	JUMP,EQ 40$	COMP.W	D3,#KEYMDP	JUMP,EQ 40$	COMP.W	D3,#F0	JUMP,EQ 90$	COMP.W	D3,#END	JUMP,EQ 90$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; clic =>	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 30$	LOAD.L	D1,D4		; D1 <-- position de la souris	LOAD.L	A5,#(A6)+OALVER	; A5 <-- ^variables ascenseur vertical	TEST.W	(A5)+OSCHTV	JUMP',EQ 45$	LOAD.W	(A5)+OSCINC,#1	LOAD.W	D0,(A5)+OSCPOSV	; D0 <-- ancienne position	SCROLL_	MOVE		; dans ascenseur vertical ?	JUMP',EQ 50$45$:	LOAD.L	D4,D1		; D4 <-- position de la souris	LOAD.L	A5,#(A6)+OALHOR	; A5 <-- ^variables ascenseur horizontal	TEST.W	(A5)+OSCHTV	JUMP',EQ 60$	LOAD.W	(A5)+OSCINC,#1	LOAD.W	D0,(A5)+OSCPOSV	; D0 <-- ancienne position	SCROLL_	MOVE		; dans ascenseur horizontal ?	JUMP',NE 60$50$:	LOAD.W	D1,(A5)+OSCPOSV	; D1 <-- nouvelle position	LOAD.W	(A5)+OSCPOSV,D0	LOAD.B	D3,D2	CALL	ALLINVERSE	; efface le caractre en dition	LOAD.W	(A5)+OSCPOSV,D1	CALL	ALLALLCAR	; affiche tous les caractres	CALL	ALLINVERSE	; montre le caractre en dition	JUMP	20$60$:	LOAD.L	D4,D1		; D4 <-- position de la souris	CALL	ALLDETECTE	; D3 <-- caractre o est la souris	JUMP,NE 30$	JUMP'	67$65$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 70$		; non => 70$				; oui =>	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 65$	CALL	ALLDETECTE	; D3 <-- caractre o est la souris67$:	COMP.B	D3,D2		; souris dplace ?	JUMP,EQ 65$		; non => 65$				; oui =>	EX.L	D3,D2	CALL	ALLINVERSE	; efface l'ancien	LOAD.B	D3,D2	CALL	ALLINVERSE	; dessine le nouveau	JUMP	65$70$:	CALL	CLOSEALL	; ferme la swdo	LOAD.B	D3,D2	CALL	CARSELECT	; slectionne le nouveau caractre	JUMP	LOOP90$:	CALL	CLOSEALL	; ferme la swdo	JUMP	LOOP;--------\\; OPENALL >;========/; Ouvre la swdo pour afficher tous les caractres,; et dessine le cadre avec les ascenseurs.; in	-; out	D7.W	erreur; mod	D7.WOPENALL:	PUSHM.L	D2..D5,A3,A5	LOAD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	ADD.W	D3,#8	AND.B	D3,#B'11111110	; D3 <-- <yy>	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,D3	SUB.W	D4,#8		; D4 <-- <dyy>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,#8		; D3 <-- <xx>	LOAD.W	D4,(A0)+ODFDX	SUB.W	D4,D3	SUB.W	D4,#8		; D4 <-- <dxx>	LIB	?CREWDO		; cre la grande swdo	LIB	?USEWDO	LOAD.W	(A6)+OAWDO,D5	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve le contenu sous la swdo	JUMP,NE 80$	LOAD.W	(A6)+OALPOX,#LGSCROLL+1	LOAD.W	(A6)+OALPOY,#2	SUB.W	D4,#LGSCROLL+3	SWAP.W	D4	SUB.W	D4,#LGSCROLL+3	SWAP.W	D4	LOAD.L	(A6)+OALDIY,D4	CLR.L	D4	LOAD.W	D4,(A6)+OALDIX	LOAD.W	D3,(A6)+OMALMX	ADD.W	D3,#MCALL*2	DIV.WU	D4,D3	COMP.W	D4,#NBALLX	JUMP',LS 20$	LOAD.W	D4,#NBALLX20$:	LOAD.W	(A6)+OALNBX,D4	CLR.L	D4	LOAD.W	D4,(A6)+OALDIY	LOAD.W	D3,(A6)+OMALMY	ADD.W	D3,#MCALL*2	DIV.WU	D4,D3	COMP.W	D4,#NBALLY	JUMP',LS 25$	LOAD.W	D4,#NBALLY25$:	LOAD.W	(A6)+OALNBY,D4	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface toute la swdo	LOAD.L	D3,(A6)+OALPOY	LOAD.L	D4,(A6)+OALDIY	SUB.W	D3,#LGSCROLL	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#LGSCROLL	SWAP.W	D4	ADD.W	D4,#LGSCROLL	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour grande matrice	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	LOAD.L	A5,#(A6)+OALVER	; A5 <-- ^variables ascenseur vertical	LOAD.W	D4,(A6)+OALPOY	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OALPOX	SUB.W	D4,#LGSCROLL	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OALDIY	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	CLR.B	(A5)+OSCHOR	CLR.B	(A5)+OSCPAGE	SCROLL_	DRAW		; dessine la cage verticale	CLR.W	(A5)+OSCHTV	CLR.W	(A5)+OSCPOSV	LOAD.W	D4,#NBALLY	SUB.W	D4,(A6)+OALNBY	JUMP',LE 40$	INC.W	D4	LOAD.W	(A5)+OSCHTV,D4	SCROLL_	UPDATE		; dessine la cabine verticale40$:	LOAD.L	A5,#(A6)+OALHOR	; A5 <-- ^variables ascenseur horizontal	LOAD.W	D4,(A6)+OALPOX	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OALPOY	ADD.W	D4,(A6)+OALDIY	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OALDIX	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCHOR	CLR.B	(A5)+OSCPAGE	SCROLL_	DRAW		; dessine la cage horizontale	CLR.W	(A5)+OSCHTV	CLR.W	(A5)+OSCPOSV	LOAD.W	D4,#NBALLX	SUB.W	D4,(A6)+OALNBX	JUMP',LE 60$	INC.W	D4	LOAD.W	(A5)+OSCHTV,D4	SCROLL_	UPDATE		; dessine la cabine horizontale60$:	LOAD.L	A3,#R16"TXMALL	LIB	?AFMENU		; affiche les soft-keys	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:				; erreur =>	PUSH.W	D7	CLR.W	D5	LIB	?USEWDO	LOAD.W	D5,(A6)+OAWDO	LIB	?KILWDO		; dtruit la swdo	POP.W	D790$:	POPM.L	D2..D5,A3,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; CLOSEALL >;=========/; Ferme la fentre pour tous les caractres.; in	-; out	-; mod	D7.WCLOSEALL:	PUSHM.L	D3,D5	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue sous la swdo	CLR.W	D5	LIB	?USEWDO	LOAD.W	D5,(A6)+OAWDO	LIB	?KILWDO		; dtruit la swdo	CALL	AFMENU		; refait les soft-keys	POPM.L	D3,D5	RET;-----------\\; ALLDETECTE >;===========/; Dtecte dans quel caractre est la souris.; in	D4.L	position de la souris (y;x); out	D3.B	caractre;	D7.W	erreur; mod	D3.L, D7.WALLDETECTE:	PUSHM.L	D2,D4	CLR.W	D7		; D7 <-- ok	CLR.L	D3	LOAD.W	D3,D4		; D3 <-- position en X	CLR.W	D4	SWAP.W	D4		; D4 <-- position en Y	SUB.W	D3,(A6)+OALPOX	; dpasse  gauche ?	JUMP',HS 10$	CLR.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- pas dans un caractre10$:	LOAD.W	D2,(A6)+OMALMX	ADD.W	D2,#MCALL*2	DIV.WU	D3,D2	COMP.W	D3,#NBALLX	; dpasse  droite ?	JUMP',LO 15$	LOAD.W	D3,#NBALLX-1	LOAD.W	D7,#ERDIOUT	; D7 <-- pas dans un caractre15$:	ADD.W	D3,(A6)+OALHOR+OSCPOSV	SUB.W	D4,(A6)+OALPOY	; dpasse en haut ?	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- pas dans un caractre20$:	LOAD.W	D2,(A6)+OMALMY	ADD.W	D2,#MCALL*2	DIV.WU	D4,D2	COMP.W	D4,#NBALLY	; dpasse en bas ?	JUMP',LO 25$	LOAD.W	D4,#NBALLY-1	LOAD.W	D7,#ERDIOUT	; D7 <-- pas dans un caractre25$:	ADD.W	D4,(A6)+OALVER+OSCPOSV	MUL.WU	D4,#NBALLX	ADD.W	D3,D4		; D3 <-- code du caractre	POPM.L	D2,D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ALLINVERSE >;===========/; Inverse un caractre.; in	D3.B	caractre; out	-; mod	D7.WALLINVERSE:	PUSHM.L	D2..D4	COMP.B	D3,#-1	JUMP,EQ 90$	LOAD.L	D4,#-1	CALL	DRMDEF	AND.L	D3,#H'FF	DIV.WU	D3,#NBALLX	LOAD.L	D4,D3		; D3 <-- Y	SWAP.W	D4		; D4 <-- X	SUB.W	D3,(A6)+OALVER+OSCPOSV	JUMP',LO 90$	COMP.W	D3,(A6)+OALNBY	JUMP',HS 90$	LOAD.W	D2,(A6)+OMALMY	ADD.W	D2,#MCALL*2	MUL.WU	D3,D2	ADD.W	D3,(A6)+OALPOY	; D3 <-- <yy>	SWAP.W	D2	SWAP.W	D3	SUB.W	D4,(A6)+OALHOR+OSCPOSV	JUMP',LO 90$	COMP.W	D4,(A6)+OALNBX	JUMP',HS 90$	LOAD.W	D2,(A6)+OMALMX	ADD.W	D2,#MCALL*2	MUL.WU	D4,D2	ADD.W	D4,(A6)+OALPOX	; D4 <-- <xx>	LOAD.W	D3,D4	LOAD.L	D4,D2		; D4 <-- <dyy> et <dxx>	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	; inverse le caractre90$:	POPM.L	D2..D4	RET;----------\\; ALLALLCAR >;----------/; Affiche tous les caractres dans la swdo.; in	-; out	-; mod	D7.WALLALLCAR:	PUSHM.L	D1..D5	LOAD.W	D5,(A6)+OALVER+OSCPOSV	SWAP.W	D5	CLR.L	D4	LOAD.W	D1,(A6)+OALNBY	INC.W	D120$:	LOAD.W	D5,(A6)+OALHOR+OSCPOSV	CLR.W	D4	LOAD.W	D2,(A6)+OALNBX	INC.W	D230$:	LOAD.B	D3,#-1	COMP.W	D5,#NBALLX	JUMP',HS 35$	LOAD.L	D3,D5	SWAP.W	D3	MUL.WU	D3,#NBALLX	ADD.W	D3,D5		; D3 <-- code du caractre35$:	CALL	ALLONECAR	; affiche un caractre	INC.W	D4		; D4 <-- position suivante en X	INC.W	D5		; D5 <-- position suivante en X	DEC.W	D2	JUMP,NE 30$	SWAP.W	D4	INC.W	D4		; D4 <-- position suivante en Y	SWAP.W	D4	SWAP.W	D5	INC.W	D5		; D5 <-- position suivante en Y	SWAP.W	D5	DEC.W	D1	JUMP,NE 20$	POPM.L	D1..D5	RET;----------\\; ALLONECAR >;----------/; Affiche un caractre dans la swdo.; in	D3.B	code du caractre (0..127);	D4.L	position (y;x); out	-; mod	D7.WALLONECAR:	PUSHM.L	D0..D5,A3,A4	CLR.W	D0	LOAD.B	D0,D3		; D0 <-- code	LOAD.L	D3,D4	SWAP.W	D3	LOAD.W	D2,(A6)+OMALMY	ADD.W	D2,#MCALL*2	MUL.WU	D3,D2	ADD.W	D3,(A6)+OALPOY	; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D2,(A6)+OMALMX	ADD.W	D2,#MCALL*2	MUL.WU	D4,D2	ADD.W	D4,(A6)+OALPOX	LOAD.W	D3,D4		; D3 <-- <xx>	LOAD.W	D4,(A6)+OMALMY	ADD.W	D4,#MCALL*2	; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,(A6)+OMALMX	ADD.W	D4,#MCALL*2	; D4 <-- <dxx>	LOAD.L	D1,D3	LOAD.L	D2,D4	CALL	ALLCLIP		; D3/D4 <-- clipping	JUMP,NE 90$	PUSH.L	D4	CLR.L	D4	CALL	DRMDEF	POP.L	D4	PUSH.W	D2	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface l'emplacement	POP.W	D2	LOAD.L	D3,D1	LOAD.L	D4,D2	LOAD.L	A3,(A6)+OPGC	; A3 <-- ^gencar	COMP.B	D0,(A3)+OGCFCA	JUMP',LO 50$	COMP.B	D0,(A3)+OGCLCA	JUMP',HI 50$				; caractre valide =>	ADD.W	D3,#MCALL	SWAP.W	D3	ADD.W	D3,#MCALL	SWAP.W	D3	SUB.W	D4,#MCALL*2	SWAP.W	D4	SUB.W	D4,#MCALL*2	SWAP.W	D4	CALL	ALLCLIP		; D3/D4 <-- clipping	JUMP',NE 90$	MUL.WU	D0,(A3)+OGCMSB	LOAD.L	A3,#(A3)+256+128*3	ADD.L	A3,D0		; A3 <-- ^bonne matrice	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.L	D5,D4		; D5 <-- dimensions	LOAD.L	D4,D3	CLR.L	D3	LOAD.W	D2,#SETDOT	CALL	XFERZONE	; affiche le caractre	JUMP'	90$50$:				; caractre invalide =>	CALL	ALLCLIP		; D3/D4 <-- clipping	JUMP',NE 90$	PUSH.L	D4	LOAD.L	D4,#H'88002200	CALL	DRMDEF	POP.L	D4	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise l'emplacement90$:	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ALLCLIP >;--------/; Clip une zone rectangulaire qui pourrait dpasser  droite; et/ou en bas.; in	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx); out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur (y'a rien qui reste dedans); mod	D3.L, D4.L, D7.WALLCLIP:	PUSH.L	D2	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la fentre	LOAD.W	D2,(A6)+OALPOX	ADD.W	D2,(A6)+OALDIX	SUB.W	D2,D3		; D2 <-- largeur maximale	JUMP',LE 90$	COMP.W	D4,D2		; dpasse  droite ?	JUMP',LE 20$	LOAD.W	D4,D220$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A6)+OALPOY	ADD.W	D2,(A6)+OALDIY	SUB.W	D2,D3		; D2 <-- hauteur maximale	JUMP',LE 90$	COMP.W	D4,D2		; dpasse en bas ?	JUMP',LE 25$	LOAD.W	D4,D225$:	SWAP.W	D3	SWAP.W	D4	CLR.W	D7		; D7 <-- ok90$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET	.END