	.SBTTL	DESIOBDBAUTO	=	15		; mode de sauvetage automatiqueBDBDEF	=	14		; sauve les dfinitionsBDBNMAJ	=	13		; touche (MET A JOUR) griseCOUPE:	TEST.W	(A6)+OCHBLOC	; module BLOC charg ?	JUMP,EQ BIP		; non => BIP	CALL	IOCOPIE		; bloc-notes <-- image du caractre	JUMP,NE BIP	JUMP	EFFACECOPIE:	TEST.W	(A6)+OCHBLOC	; module BLOC charg ?	JUMP,EQ BIP		; non => BIP	CALL	IOCOPIE		; bloc-notes <-- image du caractre	JUMP,NE BIP	JUMP	LOOPCLASSEUR:	TEST.W	(A6)+OCHBLOC	; module BLOC charg ?	JUMP,EQ BIP		; non => BIP	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN1	BLOC_	VISU		; accs au classeur ...	PUSH.W	D7	CALL	DBOXCLOSE1	; refait les soft-keys	POP.W	D7	JUMP,NE BIP	COMP.W	D3,#F1	JUMP,NE LOOPCOLLE:	TEST.W	(A6)+OCHBLOC	; module BLOC charg ?	JUMP,EQ BIP		; non => BIP	CALL	WAITMOUSE	; met le sablier	TEST.L	(A6)+OPIM	JUMP',EQ 12$	LOAD.L	A4,(A6)+OPIM	LOAD.L	A4,#(A4)-IMLBUF	; A4 <-- saute la rserve pour codage	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancienne image	CLR.L	(A6)+OPIM	; y'a plus12$:	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	RDOPEN		; ouvre le bloc-notes	JUMP,NE BIP	LOAD.L	A2,#(A6)+OBUHIMA ; A2 <-- ^en-tte image	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	BLOC_	RDDATA		; lit l'en-tte	JUMP,NE 26$	LOAD.W	D4,(A2)+OIMDLX	; D4 <-- largeur de l'image	ADD.W	D4,#8-1	AND.B	D4,#B'11111000	MUL.WU	D4,(A2)+OIMDLY	; D4 <-- taille de l'image en points	SR.L	D4,#3		; D4 <-- taille de l'image en bytes	ADD.L	D4,#IMLBUF+10	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour nouvelle image	JUMP,NE 26$	LOAD.L	A4,#(A4)+IMLBUF	; A4 <-- saute la rserve pour codage	LOAD.L	(A6)+OPIM,A4	; OPIM <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- taille de l'image	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 24$		; oui => 24$				; non =>	BLOC_	RDDATA		; lit tout le data de l'image	JUMP'	26$24$:				; image code =>	LOAD.L	A3,A4		; A3 <-- ^pour image dcode	LOAD.L	A4,#(A4)-IMLBUF	; A4 <-- ^pour image code	BLOC_	RDDATA		; lit toute l'image code	JUMP',NE 26$	GRA_	DECOIMA		; dcode l'image ...26$:	PUSH.W	D7	BLOC_	RDCLOSE		; ferme le bloc-notes	POP.W	D7	JUMP,NE ERROR	LOAD.W	D4,(A2)+OIMDLX	; D4 <-- largeur de l'image	COMP.W	D4,(A6)+OMALMX	JUMP',LS ADD$	LOAD.W	D4,(A2)+OIMDLY	; D4 <-- hauteur de l'image	COMP.W	D4,(A6)+OMALMY	JUMP,HI	TAKEIMAGE	; prend des bouts d'image ...ADD$:	LOAD.L	A3,(A6)+OPIM	; A3 <-- ^source	CLR.L	D3	LOAD.W	D5,(A2)+OIMDLX	ADD.W	D5,#8-1	SR.W	D5,#3	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^destination	CLR.L	D4	LOAD.W	D6,(A6)+OMANBB	LOAD.W	D2,(A2)+OIMDLY	COMP.W	D2,(A6)+OMALMY	JUMP',LS DIMY$	LOAD.W	D2,(A6)+OMALMYDIMY$:	SWAP.W	D2	LOAD.W	D2,(A2)+OIMDLX	COMP.W	D2,(A6)+OMALMX	JUMP',LS DIMX$	LOAD.W	D2,(A6)+OMALMXDIMX$:	LOAD.W	D1,#SETDOT	LOAD.L	A2,A0	GRA_	RASTER		; ajoute dans la matrice	CALL	DESMATRIX	; dessine les deux matrices	JUMP	LOOP;--------\\; IOCOPIE >;========/; Copie le caractre courant dans le bloc-notes (IMAG).; in	-; out	D7.W	erreur; mod	D7.WIOCOPIE:	PUSHM.L	D2..D4,A3,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	A3,#R16"NAME$	; A3 <-- ^nom du logiciel	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	LOAD.W	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMALMY	ADD.L	D4,#LGHIMA	; D4 <-- lg totale	BLOC_	WROPEN		; ouvre le bloc-notes	JUMP,NE EXIT$	LOAD.L	A4,#(A6)+OBUHIMA	LOAD.L	D4,#LGHIMA	GESMEM	?CLEARMEM	LOAD.B	(A4)+OIMTYP,#H'81	LOAD.B	(A4)+OIMCOD,#H'00	LOAD.B	(A4)+OIMBIP,#H'01	LOAD.B	(A4)+OIMDIR,#H'02	LOAD.W	(A4)+OIMDLX,(A6)+OMALMX	LOAD.W	(A4)+OIMDLY,(A6)+OMALMY	LOAD.W	D2,(A6)+OMANBB	MUL.WU	D2,(A6)+OMALMY	LOAD.L	(A4)+OIMNBB,D2	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	WRDATA		; crit l'en-tte	JUMP',NE CLOSE$	LOAD.L	A4,(A6)+OPMAT	LOAD.L	D4,D2	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	WRDATA		; crit l'imageCLOSE$:	PUSH.W	D7	BLOC_	WRCLOSE		; ferme le bloc-notes	POP.W	D7EXIT$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RETNAME$:	.ASCIZ	"EDICAR"	.EVENPREND:	CLR.B	(A6)+OBUFINPRENDL:	LOAD.L	A3,#(A6)+OBUFIN	CALL	DBOXEDITI	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ LOOP	LOAD.W	D0,#1		; D0 <-- avant de reprendre	CALL	DBOXSAVE	; sauve si ncessaire le dessin actuel	JUMP',EQ PRENDF		; ok => PRENDF	COMP.W	D7,#1		; (ANNULE) ?	JUMP,EQ LOOP		; oui => LOOP	JUMP	ERROR		; non => ERRORPRENDF:	CALL	WAITMOUSE	; met le sablier	.IF	DESSIN	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .IMAGE	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre l'image	JUMP',EQ 20$	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP	PUSH.W	D7	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	PRENDL20$:	LOAD.L	A2,#(A6)+OBUHIMA ; A2 <-- ^en-tte image	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 26$	COMP.B	(A4)+0,#H'82	; commence par en-tte binaire ?	JUMP',NE 22$		; non => 22$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute l'en-tte binaire	JUMP,NE 26$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 26$22$:	LOAD.W	D3,(A4)+OIMDLX	; D3 <-- largeur de l'image	LOAD.W	D4,(A4)+OIMDLY	; D4 <-- hauteur de l'image	CALL	NEWMEMMATRIX	; demande mmoire pour nouvelle image	JUMP,NE 26$	LOAD.L	A4,(A6)+OPMAT	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- taille de l'image	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 24$		; oui => 24$				; non =>	FOS	?RDBYTE		; lit tout le data de l'image	JUMP'	26$24$:				; image code =>	LOAD.L	A3,A4		; A3 <-- ^pour image dcode	LOAD.L	A4,#(A4)-IMLBUF	; A4 <-- ^pour image code	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 26$	GRA_	DECOIMA		; dcode l'image ...26$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7	JUMP,NE ERROR	LOAD.L	A3,#(A6)+OBUFIN	CALL	INDEF		; lit le fichier .DDES	JUMP',EQ 28$	LOAD.W	D4,#SCALE11	CLR.L	(A6)+OPMOVY	CLR.L	(A6)+OPMDIY	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices28$:	LOAD.L	A3,#(A6)+OBUFIN	CALL	SAVFILE		; OBUNAME <-- nom	CALL	DESINFFILE	; affiche le nom dans les infos	CLR.B	(A6)+OMAJ	; le dessin est  jour	JUMP	LOOP	.ELSE	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .GENC	CALL	RDGENC		; lit le gencar	JUMP',EQ 20$	TEST.L	D7:#16		; erreur d'ouverture ?	JUMP,BC ERROR		; non => ERROR				; oui =>	PUSH.W	D7	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	PRENDL20$:	CLR.L	(A6)+OSEPP1	CLR.L	(A6)+OSEPP2	; plus de sparateur	LOAD.W	D4,#SCALEMAX	CALL	IFSCALE		; tout est visible ?	JUMP',EQ 60$		; oui => 60$	LOAD.W	D4,#SCALELOUPE	CALL	IFSCALE		; tout est visible ?	JUMP',EQ 60$		; oui => 60$	LOAD.W	D4,#SCALEMIN60$:	CLR.L	(A6)+OPMOVY	CLR.L	(A6)+OPMDIY	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	LOAD.B	D3,#'A	CALL	CARSELECT	LOAD.L	A3,#(A6)+OBUFIN	CALL	SAVFILE		; OBUNAME <-- nom	CALL	DESINFFILE	; affiche le nom dans les infos	CLR.B	(A6)+OMAJ	; le dessin est  jour	JUMP	LOOP	.ENDIF	.IF	DESSINAJOUTE:	LOAD.L	A3,#(A6)+OBUFAJ	CALL	DBOXEDITA	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ LOOP	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .IMAGE	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre l'image	JUMP',EQ 20$	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP	PUSH.W	D7	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	AJOUTE20$:	LOAD.L	A2,#(A6)+OBUHIMA ; A2 <-- ^en-tte image	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 26$	COMP.B	(A4)+0,#H'82	; commence par en-tte binaire ?	JUMP',NE 22$		; non => 22$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute l'en-tte binaire	JUMP,NE 26$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 26$22$:	LOAD.L	D1,(A6)+OPMDIY	CALL	D1SCALEN	; D1 <-- agrandi si "tout"	LOAD.W	D7,#ERDIOUT	COMP.W	D1,(A6)+OBUHIMA+OIMDLX ; image trop large ?	JUMP,LS 26$	SWAP.W	D1	COMP.W	D1,(A6)+OBUHIMA+OIMDLY ; image trop haute ?	JUMP,LS 26$	LOAD.L	A3,(A6)+OPMAT	LOAD.L	A4,(A6)+OPMAC	CALL	XFERALL		; matrice copie <-- matrice principale	LOAD.L	A4,(A6)+OPMAM	CALL	CLEARALL	; efface toute la matrice masque	SET.B	(A6)+OMAJ	; une mise  jour sera ncessaire	CLR.L	D3	ADD.W	D3,#8		; <<<<<<<< pour SMAKY8 !	LOAD.L	A1,(A6)+OPMAM	CALL	TESTPOINT	; A1 <-- ^byte sup/gauche dans matrice	JUMP',NE 26$	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- taille de l'image	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 24$		; oui => 24$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP'	26$24$:	LOAD.L	A3,A1		; A3 <-- ^pour image dcode	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^pour image code	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 26$	GRA_	DECOIMA		; dcode l'image ...26$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7	JUMP,NE ERROR; Dplace chaque ligne de l'image pour avoir OMANBB bytes; d'une ligne  l'autre.	LOAD.L	A3,A1	LOAD.W	D3,(A2)+OIMDLX	MUL.WU	D3,(A2)+OIMDLY	SR.L	D3,#3	ADD.L	A3,D3		; A3 <-- ^fin de l'image lue	LOAD.L	A4,A1	LOAD.W	D3,(A6)+OMANBB	MUL.WU	D3,(A2)+OIMDLY	ADD.L	A4,D3		; A4 <-- ^fin o mettre l'image	LOAD.W	D3,(A2)+OIMDLX	SR.W	D3,#3	SUB.W	D3,(A6)+OMANBB	NEG.W	D3	SUB.W	A4,D3		; A4 <-- cale l'image  gauche	LOAD.W	D3,(A2)+OIMDLY	; D3 <-- compteur vertical	DEC.W	D350$:	LOAD.W	D4,(A2)+OIMDLX	SR.W	D4,#3		; D4 <-- compteur horizontal	DEC.W	D4	PUSH.L	A4	CLR.B	(A4)52$:	LOAD.B	(-A4),(-A3)	; dplace une ligne	DECJ.W,NMO D4,52$	CLR.B	(-A4)		; <<<<<<<< pour SMAKY8 !	POP.L	A4	SUB.W	A4,(A6)+OMANBB	DECJ.W,NMO D3,50$; Dplace le dessin ajout selon la souris ...	LOAD.W	D1,(A6)+OBUHIMA+OIMDLY	SWAP.W	D1	LOAD.W	D1,(A6)+OBUHIMA+OIMDLX	CALL	D1SCALEP	; D1 <-- diminue si "tout"	LOAD.L	D4,D1		; D4 <-- dimensions de l'image	LOAD.L	D1,(A6)+OPMOVY	; D1 <-- coin sup/gauche	LOAD.L	D2,D1	ADD.W	D2,D4	SWAP.W	D4	SWAP.W	D2	ADD.W	D2,D4		; D2 <-- coin inf/droite (o est la souris)	SWAP.W	D4	SWAP.W	D2	CLR.L	D5		; D5 <-- coin sup/gauche dans OPMAM	LOAD.L	D6,D4		; D6 <-- coin inf/droite dans OPMAM	ADD.W	D5,#8		; <<<<<<<< pour SMAKY8 !	ADD.W	D6,#8		; <<<<<<<< pour SMAKY8 !	ADD.W	D4,(A6)+OPMPOX	SWAP.W	D4	ADD.W	D4,(A6)+OPMPOY	SWAP.W	D4	CALL	PMOUSE		; positionne souris dans coin inf/droite	CLR.L	D0	CLR.B	(A6)+ODDOP	JUMP	ZONEMOVE	.ENDIF	.IF	EDGARPRENDAUTRE:10$:	LOAD.L	A3,#(A6)+OBUFADD	CALL	DBOXEDITA	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ LOOP	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .GENC	LOAD.W	D3,#2^BOPRD	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le gencar	POPM.L	D0	JUMP',EQ 20$	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP	PUSH.W	D7	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	10$20$:	LOAD.L	D4,#256	CLR.B	D3	FOS	?SPOS		; saute header binaire	JUMP,NE	80$	LOAD.L	A4,#(A6)+OBCHEAD ; A4 <-- ^place pour header	LOAD.L	D4,#256	FOS	?RDBYTE		; lit header gencar	JUMP,NE	80$	CLR.L	D2	LOAD.B	D2,(A4)+OGCFCA	; D2 <-- code premier caractre	CLR.L	D5	LOAD.B	D5,(A4)+OGCLCA	; D5 <-- code dernier caractre	SUB.B	D5,(A4)+OGCFCA	INC.B	D5		; D5 <-- nb de caractres	CLR.L	D4	LOAD.W	D4,(A4)+OGCMSB	; D4 <-- nb de byte d'un caractre	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour une seule matrice	JUMP,NE 80$	CALL	DBOXCAR		; D3 <-- caractre choisi ...	JUMP,NE 70$	SUB.B	D3,D2	JUMP',HS 30$	CLR.B	D330$:	COMP.B	D3,D5	JUMP',LO 32$	LOAD.B	D3,D5	DEC.B	D332$:	LOAD.W	D4,D5	MUL.WU	D4,#3	ADD.L	D4,#256+OGCWID	AND.W	D3,#H'7F	MUL.WU	D3,(A6)+OBCHEAD+OGCMSB	ADD.L	D4,D3	CLR.B	D3	FOS	?SPOS		; positionne au dbut de la matrice	JUMP,NE 70$	CLR.L	D4	LOAD.W	D4,(A6)+OBCHEAD+OGCMSB	FOS	?RDBYTE		; lit la matrice	JUMP,NE 70$	CALL	COPYALL		; fait une copie de la matrice	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	(A3)+6,A4	; source: <pppp>	CLR.W	D3	LOAD.B	D3,(A6)+OBCHEAD+OGCMWB	LOAD.W	(A3)+10,D3	; source: <ii>	CLR.L	(A3)+12		; destination: <xx> et <yy>	LOAD.L	(A3)+16,(A6)+OPMAT ; destination: <pppp>	LOAD.W	(A3)+20,(A6)+OMANBB ; destination: <ii>	CLR.W	D3	LOAD.B	D3,(A6)+OBCHEAD+OGCMWB	SL.W	D3,#3	COMP.W	D3,(A6)+OMALMX	JUMP',LS 40$	LOAD.W	D3,(A6)+OMALMX40$:	LOAD.W	(A3)+22,D3	; <dxx>	LOAD.W	D3,(A6)+OBCHEAD+OGCMHD	COMP.W	D3,(A6)+OMALMY	JUMP',LS 42$	LOAD.W	D3,(A6)+OMALMY42$:	LOAD.W	(A3)+24,D3	; <dyy>	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; matrice principale <-- caractre	CLR.W	D7		; D7 <-- ok (forcment)70$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire pour une matrice	POP.W	D780$:	PUSH.W	D7	FOS	?CLOSE		; ferme le gencar	POP.W	D7	JUMP,NE ERROR	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	JUMP	LOOP	.ENDIF	.IF	EDGARAJOUTEIMAGE:10$:	LOAD.L	A3,#(A6)+OBUFIMA	CALL	DBOXEDITIM	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ LOOP	TEST.L	(A6)+OPIM	JUMP',EQ 12$	LOAD.L	A4,(A6)+OPIM	LOAD.L	A4,#(A4)-IMLBUF	; A4 <-- saute la rserve pour codage	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancienne image	CLR.L	(A6)+OPIM	; y'a plus12$:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPRD	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre l'image	POPM.L	D0	JUMP',EQ 20$	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP	PUSH.W	D7	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	10$20$:	LOAD.L	A2,#(A6)+OBUHIMA ; A2 <-- ^en-tte image	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 26$	COMP.B	(A4)+0,#H'82	; commence par en-tte binaire ?	JUMP',NE 22$		; non => 22$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute l'en-tte binaire	JUMP,NE 26$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 26$22$:	LOAD.W	D4,(A2)+OIMDLX	; D4 <-- largeur de l'image	ADD.W	D4,#8-1	AND.B	D4,#B'11111000	MUL.WU	D4,(A2)+OIMDLY	; D4 <-- taille de l'image en points	SR.L	D4,#3		; D4 <-- taille de l'image en bytes	ADD.L	D4,#IMLBUF+10	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour nouvelle image	JUMP,NE 26$	LOAD.L	A4,#(A4)+IMLBUF	; A4 <-- saute la rserve pour codage	LOAD.L	(A6)+OPIM,A4	; OPIM <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- taille de l'image	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 24$		; oui => 24$				; non =>	FOS	?RDBYTE		; lit tout le data de l'image	JUMP'	26$24$:				; image code =>	LOAD.L	A3,A4		; A3 <-- ^pour image dcode	LOAD.L	A4,#(A4)-IMLBUF	; A4 <-- ^pour image code	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 26$	GRA_	DECOIMA		; dcode l'image ...26$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7	JUMP,NE ERROR	JUMP	TAKEIMAGE	; prend des bouts d'image ...	.ENDIF	.IF	DESSINIMPRIME:	CALL	WAITMOUSE	; met le sablier	LOAD.L	A3,#R16"TPRINT	CALL	WRIMAGE		; imprime l'image	JUMP,NE ERROR	JUMP	LOOP	.ENDIFSAUVE:	CLR.W	D2		; D2 <-- mode manuel	CALL	SAUVETOUT	; sauve toute l'image	JUMP,NE ERROR	JUMP	LOOP;----------\\; SAUVETOUT >;==========/; Sauve toute l'image.; in	D2.W	mode; out	D7.W	erreur; mod	D7.WSAUVETOUT:	PUSHM.L	D0..D5,A3,A4	LOAD.L	A3,#(A6)+OBUFOUT	CALL	GETFILE		; OBUFOUT <-- OBUNAME	CLR.L	D5	TEST.B	(A6)+OMAJ	; mise  jour ncessaire ?	JUMP',F	10$		; non => 10$				; oui =>	CALL	IFVIDE		; dessin vide ?	JUMP',NE 11$		; non => 11$10$:	TSET.L	D2:#BDBNMAJ	; D2 <-- touche (MET A JOUR) grise11$:	LOAD.L	A3,#(A6)+OBUFOUT	LOAD.L	D4,D5		; D4 <-- fanions	CALL	DBOXEDITO	JUMP,NE 95$	COMP.W	D3,#F0	JUMP,EQ 95$	LOAD.W	D1,D3		; D1 <-- F1/F4	LOAD.L	D5,D4		; D5 <-- fanions	CALL	WAITMOUSE	; met le sablier	.IF	DESSIN	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^extension	.ELSE	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^extension	.ENDIF	CALL	ADDEXT		; A3 <-- ^nom du fichier avec extension20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP,EQ 50$		; ok => 50$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	TEST.L	D2:#BDBAUTO	; sauvetage automatique ?	JUMP',BS 40$		; oui => 40$	COMP.W	D1,#F4		; touche (MET A JOUR) ?	JUMP',EQ 40$		; oui => 40$	CALL	NORMMOUSE	; remet la flche	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE 90$	COMP.W	D3,#'O	JUMP,NE 10$40$:	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE 90$	JUMP	20$50$:	CALL	WAITMOUSE	; met le sablier	.IF	DESSIN	CALL	WRIMAGE		; crit l'image	JUMP',NE 90$	TEST.L	D2:#BDBDEF	; sauve les dfinitions ?	JUMP',BC 90$		; non => 90$	CALL	OUTDEF		; oui => crit le fichier .DDES	.ENDIF	.IF	EDGAR	CALL	CHKGENC		; met  jour qq paramtres du gencar	LOAD.L	A4,(A6)+OPGC	CALL	WRGENC		; crit le gencar	.ENDIF90$:	TEST.W	D7		; ok =	JUMP',NE 95$		; non => 90$	LOAD.L	A3,#(A6)+OBUFOUT	CALL	SAVFILE		; OBUNAME <-- nom	CALL	DESINFFILE	; affiche le nom dans les infos	CLR.B	(A6)+OMAJ	; le dessin est  jour	CLR.W	D7		; D7 <-- ok95$:	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET	.IF	DESSIN;-----------;; SAUVERECT ;;===========;; Sauve sur disque le contenu d'une zone rectangulaire.; in	D1.L	coin sup/gauche (y;x);	D2.L	dimensions (dy;dx)SAUVERECT:	LOAD.W	D3,D1	AND.B	D1,#B'11111000	; D1 <-- modulo 8 en X !	SUB.W	D3,D1	ADD.W	D2,D3	ADD.W	D2,#8-1	AND.B	D2,#B'11111000	TEST.W	D2	JUMP,EQ BIP	SWAP.W	D1	SWAP.W	D2	LOAD.W	D3,D1	AND.B	D1,#B'11111110	; D1 <-- modulo 2 en Y !	SUB.W	D3,D1	ADD.W	D2,D3	ADD.W	D2,#2-1	AND.B	D2,#B'11111110	TEST.W	D2	JUMP,EQ BIP	SWAP.W	D1	SWAP.W	D2	CLR.B	(A6)+OBUFOUT	CLR.L	D510$:	LOAD.L	A3,#(A6)+OBUFOUT	LOAD.L	D4,D5		; D4 <-- fanions	CALL	DBOXEDITE	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ LOOP	LOAD.L	D5,D4		; D5 <-- fanions	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .IMAGE20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP',EQ 30$		; ok => 30$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	ERROR		; non => ERROR				; oui =>	CALL	NORMMOUSE	; remet la flche	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE ERROR	COMP.W	D3,#'O	JUMP,NE 10$	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE ERROR	JUMP	20$30$:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre l'image	JUMP,NE ERROR	LOAD.L	A2,#(A6)+OBUHIMA+LGHIMA	LOAD.W	D4,#LGHIMA-135$:	CLR.B	(-A2)		; en-tte <-- rempli de zro	DECJ.W,NMO D4,35$	LOAD.B	(A2)+OIMTYP,#H'81	LOAD.B	(A2)+OIMCOD,#H'00	LOAD.B	(A2)+OIMBIP,#H'01	LOAD.B	(A2)+OIMDIR,#H'02	CLR.L	D0	LOAD.W	D0,D2	SR.W	D0,#3		; D0 <-- largeur en bytes	LOAD.W	(A2)+OIMDLX,D2	SWAP.W	D2	LOAD.W	(A2)+OIMDLY,D2	LOAD.W	D3,D2	SWAP.W	D2	MUL.WU	D3,D0	LOAD.L	(A2)+OIMNBB,D3; Compresse l'image pour mettre les lignes bout  bout.	LOAD.L	D3,D1		; D3 <-- coordonne coin sup/gauche	LOAD.L	A1,(A6)+OPMAM	; A1 <-- ^matrice masque	CALL	TESTPOINT	; A1 <-- ^byte sup/gauche dans matrice	JUMP,NE 80$	LOAD.L	A3,A1	LOAD.L	A4,A1	LOAD.W	D3,(A2)+OIMDLY	; D3 <-- compteur vertical	DEC.W	D340$:	LOAD.W	D4,(A2)+OIMDLX	SR.W	D4,#3		; D4 <-- compteur horizontal	DEC.W	D4	PUSH.L	A442$:	LOAD.B	(A3+),(A4+)	; dplace une ligne	DECJ.W,NMO D4,42$	POP.L	A4	ADD.W	A4,(A6)+OMANBB	DECJ.W,NMO D3,40$	LOAD.L	A3,A1		; A3 <-- ^image dcode	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^pour image code	GRA_	CODEIMA		; code l'image ...	JUMP',NE 50$				; crit une image code =>	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE 80$	LOAD.L	A4,#(A1)-IMLBUF	LOAD.L	D4,(A2)+OIMNBB	FOS	?WRBYTE		; crit l'image code	JUMP'	70$50$:				; crit une image dcode =>	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE 80$	LOAD.L	A4,A1	LOAD.L	D4,(A2)+OIMNBB	FOS	?WRBYTE		; crit l'image dcode70$:	FOS	?CLOSE		; ferme l'image	JUMP,NE ERROR	JUMP	LOOP80$:				; erreur =>	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7	JUMP	ERROR	.ENDIF	.IF	DESSIN;--------\\; WRIMAGE >;========/; Sauve toute l'image.; in	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WWRIMAGE:	PUSHM.L	D0,D3,D4,D6,A2..A4	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre l'image	JUMP,NE 90$	LOAD.L	A2,#(A6)+OBUHIMA+LGHIMA	LOAD.W	D4,#LGHIMA-120$:	CLR.B	(-A2)		; en-tte <-- rempli de zro	DECJ.W,NMO D4,20$	LOAD.B	(A2)+OIMTYP,#H'81	LOAD.B	(A2)+OIMCOD,#H'00	LOAD.B	(A2)+OIMBIP,#H'01	LOAD.B	(A2)+OIMDIR,#H'02	LOAD.W	(A2)+OIMDLX,(A6)+OMALMX	LOAD.W	(A2)+OIMDLY,(A6)+OMALMY	LOAD.W	D3,(A6)+OMANBB	MUL.WU	D3,(A6)+OMALMY	LOAD.L	(A2)+OIMNBB,D3	LOAD.L	A3,(A6)+OPMAT	; A3 <-- ^image dcode	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^pour image code	GRA_	CODEIMA		; code l'image ...	JUMP,NE 50$; Ecrit une image code.	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE 40$	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^image code	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- nb total de bytes	FOS	?WRBYTE		; crit l'image code	JUMP',NE 40$	FOS	?CLOSE		; ferme l'image40$:	PUSH.W	D7	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^image code	GRA_	DECOIMA		; re-dcode l'image !	POP.W	D7	JUMP,NE 80$	JUMP	90$; Ecrit une image telle quelle, c'est--dire dcode.50$:	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE 80$	LOAD.L	A4,A3		; A4 <-- ^matrice principale	LOAD.L	D4,D3		; D4 <-- nb total de bytes	FOS	?WRBYTE		; crit le data de l'image	JUMP',NE 80$	FOS	?CLOSE		; ferme l'image	JUMP'	90$80$:				; erreur =>	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D790$:	POPM.L	D0,D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; OUTDEF  >;========/; Ecrit dans le fichier .DDES toutes les dfinitions.; in	A3.L	^nom du fichier .IMAGE; out	D7.W	erreur; mod	D7.WOUTDEF:	PUSHM.L	D0,D3,D4,D6,A1..A4; Rempli OBUHDEF en fonction de l'tat actuel du programme.	LOAD.L	A4,#(A6)+OBUHDEF+LGHDEF	LOAD.W	D4,#(LGHDEF/2)-110$:	CLR.W	(-A4)		; OBUHDEF <-- rempli de zro	DECJ.W,NMO D4,10$	LOAD.W	(A4)+OFSCALE,(A6)+OSCALE	LOAD.L	(A4)+OFPMOV,(A6)+OPMOVY	LOAD.L	(A4)+OFPMDI,(A6)+OPMDIY	LOAD.B	(A4)+OFOUTIL,(A6)+OOUTIL	LOAD.B	(A4)+OFMODE,(A6)+OMODE	LOAD.B	(A4)+OFOBJET,(A6)+OOBJET	LOAD.B	(A4)+OFSELECT,(A6)+OSELECT	LOAD.L	(A4)+OFFLAGS,(A6)+OFLAGS	LOAD.W	(A4)+OFPAS,(A6)+OPAS	LOAD.W	(A4)+OFNPDEF,(A6)+ONPDEF	LOAD.W	(A4)+OFNTDEF,(A6)+ONTDEF	LOAD.L	A1,#(A4)+OFPDEF	LOAD.L	A2,#(A6)+OPDEF	LOAD.W	D4,#((MAXDEF*(8+2))/2)-120$:	LOAD.W	(A1+),(A2+)	DECJ.W,NMO D4,20$	LOAD.L	A1,#(A4)+OFTDEF	LOAD.L	A2,#(A6)+OTDEF	LOAD.W	D4,#((MAXDEF*8)/2)-122$:	LOAD.W	(A1+),(A2+)	DECJ.W,NMO D4,22$	LOAD.W	(A4)+OFRRECT,(A6)+ORRECT	LOAD.B	(A4)+OFARC,(A6)+OARC	LOAD.L	A1,#(A4)+OFBUGC	LOAD.L	A2,#(A6)+OBUGC	LOAD.W	D4,#((LGGC*MAXGC)/2)-124$:	LOAD.W	(A1+),(A2+)	DECJ.W,NMO D4,24$	LOAD.L	(A4)+OFFAGC,(A6)+OFAGC; Ecrit le contenu de OBUHDEF dans le fichier .DDES	LOAD.L	A4,#R16"TEXDF	CALL	ADDEXT	LOAD.L	A4,#R16"TETDF	LOAD.L	A2,#R16"00$	EX.L	A3,A4	LIB	?CPSTRING	; fichier disque avec extension ?	EX.L	A4,A3	JUMP',NC 50$		; oui => 50$	CLR.W	D7		; non => #printer, etc.	JUMP'	90$50$:	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit si existe dj	LOAD.L	D3,#DEFATT	TCLR.L	D3:#BATTL	; ne met pas l'attribut "L" !	LOAD.W	D4,#TYPRAND	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP',NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',NE 90$	LOAD.L	A4,#(A6)+OBUHDEF	LOAD.L	D4,#LGHDEF	FOS	?WRBYTE		; crit le data	JUMP',NE 80$	FOS	?CLOSE		; ferme le fichier	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE		; ferme en cas d'erreur	POP.W	D790$:	POPM.L	D0,D3,D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	CR,0,-1	.EVEN;--------\\; INDEF   >;========/; Lit dans le fichier .DDES toutes les dfinitions.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WINDEF:	PUSHM.L	D0,D3,D4,D6,A1..A4; Lit le fichier .DDES dans le buffer OBUHDEF.	LOAD.L	A4,#R16"TEXDF	CALL	ADDEXT	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUHDEF	LOAD.L	D4,#LGHDEF	FOS	?RDBYTE		; lit le data	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7	JUMP,NE 90$; Initialise le programme en fonction du contenu de OBUHDEF.	LOAD.W	D4,(A4)+OFSCALE	LOAD.L	(A6)+OPMOVY,(A4)+OFPMOV	LOAD.L	(A6)+OPMDIY,(A4)+OFPMDI	CALL	CALSCALE	; calcul selon nouvelles dimensions	LOAD.B	(A6)+OMODE,(A4)+OFMODE	LOAD.B	(A6)+OOUTIL,(A4)+OFOUTIL	LOAD.B	(A6)+OOBJET,(A4)+OFOBJET	LOAD.B	D3,(A4)+OFSELECT	JUMP',NE 22$	LOAD.B	D3,#ICOZONE22$:	LOAD.B	(A6)+OSELECT,D3	LOAD.L	D3,(A4)+OFFLAGS	JUMP',NE 24$	LOAD.L	D3,#2^BFLP1!2^BFLAUTO24$:	LOAD.L	(A6)+OFLAGS,D3	LOAD.W	D3,(A4)+OFPAS	JUMP',NE 25$	LOAD.W	D3,#125$:	LOAD.W	(A6)+OPAS,D3	LOAD.L	A1,#(A4)+OFPDEF	LOAD.L	A2,#(A6)+OPDEF	LOAD.W	D4,#((MAXDEF*(8+2))/2)-130$:	LOAD.W	(A2+),(A1+)	DECJ.W,NMO D4,30$	LOAD.L	A1,#(A4)+OFTDEF	LOAD.L	A2,#(A6)+OTDEF	LOAD.W	D4,#((MAXDEF*8)/2)-132$:	LOAD.W	(A2+),(A1+)	DECJ.W,NMO D4,32$	LOAD.W	(A6)+ONPDEF,(A4)+OFNPDEF	LOAD.W	(A6)+ONTDEF,(A4)+OFNTDEF	LOAD.W	(A6)+ORRECT,(A4)+OFRRECT	LOAD.B	(A6)+OARC,(A4)+OFARC	CALL	DESWDO	LOAD.L	A1,#(A4)+OFBUGC	LOAD.L	A2,#(A6)+OBUGC	LOAD.W	D4,#MAXGC-140$:	PUSHM.L	D4,A1,A2	LOAD.L	A1,#(A1)+OGCTIT	LOAD.L	A2,#(A2)+OGCTIT	LOAD.W	D4,#LGTGC-141$:	LOAD.B	(A2+),(A1+)	; transfert le titre du gencar	DECJ.W,NMO D4,41$	POPM.L	D4,A1,A2	TEST.B	(A1)+OGCFLG:#BGCUSE	JUMP',BC 45$	CLR.B	(A1)+OGCCOD	CLR.B	(A2)+OGCCOD	LOAD.L	D3,(A1)+OGCCOD	COMP.L	D3,(A2)+OGCCOD	; mme gencar ?	JUMP',EQ 48$		; oui => 48$				; non =>	PUSHM.L	D4,A2..A4	LOAD.L	(A2)+OGCCOD,D3	LOAD.L	A4,A2		; A4 <-- ^gencar	LOAD.L	A3,#(A6)+OBUGC	; A3 <-- ^buffer des gencars	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A2,A0		; A2 <-- ^description de la fentre	DGENC_	NEW		; charge le nouveau gencar	POPM.L	D4,A2..A4	JUMP'	48$45$:	TEST.B	(A2)+OGCFLG:#BGCUSE	JUMP',BC 48$	PUSHM.L	D4,A2..A4	LOAD.L	A4,A2		; A4 <-- ^gencar	LOAD.L	A3,#(A6)+OBUGC	; A3 <-- ^buffer des gencars	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A2,A0		; A2 <-- ^description de la fentre	DGENC_	KILL		; libre le gencar inutile	POPM.L	D4,A2..A448$:	LOAD.L	A1,#(A1)+LGGC	LOAD.L	A2,#(A2)+LGGC	DECJ.W,NMO D4,40$	LOAD.L	(A6)+OFAGC,(A4)+OFFAGC	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D3,D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.ENDIF	.IF	EDGAR;--------\\; IFSCALE >;========/; Vrifie si toute la matrice est visible avec une chelle donne.; in	D4.W	chelle; out	D7.W	ok => tout est inclu; mod	D7.WIFSCALE:	PUSH.L	D3	LOAD.W	D7,#ERDIOUT	LOAD.W	D3,D4	MUL.WU	D3,(A6)+OMALMX	COMP.W	D3,(A6)+OGRDIX	JUMP',HS 90$	LOAD.L	D3,D4	MUL.WU	D3,(A6)+OMALMY	COMP.W	D3,(A6)+OGRDIY	JUMP',HS 90$	CLR.W	D7		; D7 <-- ok90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; CARSELECT >;==========/; Slectionne un caractre pour pouvoir l'diter.; in	D3.B	code du caractre (0..127); out	-; mod	D7.WCARSELECT:	PUSHM.L	D3,D4,A4; Vrifie si le nouveau caractre est dans les limites.	LOAD.L	A4,(A6)+OPGC	; A4 <-- ^gencar	COMP.B	D3,(A4)+OGCFCA	JUMP',HS 40$	LOAD.B	D3,(A4)+OGCFCA40$:	COMP.B	D3,(A4)+OGCLCA	JUMP',LS 45$	LOAD.B	D3,(A4)+OGCLCA45$:	CALL	CLRREPERE	; enlve les repres	LOAD.B	(A6)+OCAR,D3; Initialise le pointeur OPMAT dans le gencar.	LOAD.L	A4,(A6)+OPGC	; A4 <-- ^gencar	AND.W	D3,#H'FF	MUL.WU	D3,(A4)+OGCMSB	ADD.L	D3,#OGCMAT	ADD.L	A4,D3	LOAD.L	(A6)+OPMAT,A4	CALL	DESMATRIX	; dessine les deux matrices	CALL	DESCODE		; affiche "65: A" par exemple	POPM.L	D3,D4,A4	RET;--------\\; RDGENC  >;========/; Lit un gnrateur de caractre.; in	A3.L	^nom du gnrateur  lire; out	D7.W	erreur;		:#16 => erreur d'ouverture; mod	D7.WRDGENC:	PUSHM.L	D0..D6,A1..A4	LOAD.B	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre gencar en lecture	TSET.L	D7:#16		; D7 <-- erreur d'ouverture	TEST.W	D7	JUMP,NE	95$	LOAD.L	D4,#256	CLR.B	D3	FOS	?SPOS		; saute header binaire	JUMP,NE	80$	LOAD.L	A4,#(A6)+OBUHEAD ; A4 <-- ^place pour header	LOAD.L	D4,#256	FOS	?RDBYTE		; lit header gencar	JUMP,NE	80$	LOAD.W	D7,#ERFOS	; D7 <-- problme avec un fichier	COMP.W	(A4),#128	; gencar point par point ?	JUMP,HI 80$		; non => 80$	CLR.L	D2	LOAD.B	D2,(A4)+OGCFCA	; D2 <-- code premier caractre	CLR.L	D5	LOAD.B	D5,(A4)+OGCLCA	; D5 <-- code dernier caractre	SUB.B	D5,(A4)+OGCFCA	INC.B	D5		; D5 <-- nb de caractres	CLR.W	D3	LOAD.B	D3,(A4)+OGCMWB	SL.W	D3,#3		; D3 <-- largeur d'un caractre	LOAD.W	D4,(A4)+OGCMHD	; D4 <-- hauteur d'un caractre	CALL	NEWMEMMATRIX	; demande mmoire pour nouveau gencar	JUMP,NE 80$	LOAD.L	A4,(A6)+OPGC	; A4 <-- ^futur gencar	LOAD.L	A2,A4	LOAD.W	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMALMY	MUL.WU	D4,#128	ADD.L	D4,#OGCMAT	; D4 <-- lg totale	LOAD.L	A3,#(A6)+OBUHEAD ; A3 <-- ^header gencar	LOAD.W	D3,#256-130$:	LOAD.B	(A4+),(A3+)	; buffer <-- header gencar	DEC.L	D4		; D4 <-- lg - 256	DECJ.W,NMO D3,30$	LOAD.L	A1,A4		; A1 <-- ^place pour 128 largeurs	LOAD.W	D3,#128	LOAD.W	D0,(A6)+OBUHEAD+OGCMWI;;?	TEST.B	(A6)+OBUHEAD+OGCFLG:#0;;?	JUMP',BC 34$;;?	CLR.W	D034$:	LOAD.B	(A1+),D0	; init largeurs pour 128 caractres	DEC.W	D3	JUMP,NE	34$	LOAD.L	D3,D4	SUB.L	D3,#128		; table des largeurs dj remplie36$:	CLR.B	(A1+)		; rempli tout de zro	DEC.L	D3	JUMP,NE	36$	PUSHM.L	D4,A4	LOAD.L	D4,D5	ADD.L	A4,D2	FOS	?RDBYTE		; lit 1..128 x largeurs	POPM.L	D4,A4	JUMP,NE	80$	SUB.L	D4,#128	ADD.L	A4,#128		; A4 <-- ^place pour h1	PUSHM.L	D4,A4	LOAD.L	D4,D5	ADD.L	A4,D2	FOS	?RDBYTE		; lit 1..128 x h1	POPM.L	D4,A4	JUMP,NE	80$	SUB.L	D4,#128	ADD.L	A4,#128		; A4 <-- ^place pour h2	PUSHM.L	D4,A4	LOAD.L	D4,D5	ADD.L	A4,D2	FOS	?RDBYTE		; lit 1..128 x h2	POPM.L	D4,A4	JUMP,NE	80$	SUB.L	D4,#128	ADD.L	A4,#128		; A4 <-- ^place pour matrix	MUL.WU	D2,(A2)+OGCMSB	ADD.L	A4,D2	FOS	?RDBYTE		; lit gencar (matrix)	JUMP',EQ 60$	COMP.W	D7,#EROUTF	; accepte erreur "end of file"	JUMP',NE 80$60$:	LOAD.L	A4,A2		; A4 <-- ^gencar lu	FOS	?CLOSE		; ferme le gencar	CLR.W	D6		; D6 <-- canal impossible	TEST.W	D7	JUMP',EQ 90$80$:	PUSH.W	D7	FOS	?CLOSE		; ferme sans tester si erreur	POP.W	D790$:	TCLR.L	D7:#16		; D7 <-- pas une erreur d'ouverture95$:	POPM.L	D0..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRGENC  >;========/; Sauve un gnrateur de caractre.; in	A3.L	^nom du gnrateur  sauver;	A4.L	^gencar; out	D7.W	erreur; mod	D7.WWRGENC:	PUSHM.L	D0..D6,A1..A4	LOAD.B	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le gencar	JUMP,NE	90$	LOAD.L	A1,#(A6)+OBUHEAD	LOAD.W	D0,#(256/4)-130$:	CLR.L	(A1+)		; rempli OBUHEAD de zros	DECJ.W,NMO D0,30$	LOAD.L	A2,A4		; A2 <-- ^gencar	CLR.L	D2	LOAD.B	D2,(A2)+OGCFCA	; D2 <-- premier caractre	CLR.L	D5	LOAD.B	D5,(A2)+OGCLCA	; D5 <-- code dernier caractre	SUB.B	D5,(A2)+OGCFCA	INC.B	D5		; D5 <-- nb de caractres	LOAD.W	D4,(A2)+OGCMSB	; D4 <-- lg une matrix en bytes	MUL.WU	D4,D5		; D4 <-- lg matrix utilises	LOAD.L	D0,D4		; D0 <-- lg des matrix seules	ADD.L	D4,#256		; compte header gencar	ADD.L	D4,D5		; compte largeurs	ADD.L	D4,D5		; compte h1	ADD.L	D4,D5		; compte h2	LOAD.L	A4,#(A6)+OBUHEAD ; A4 <-- ^header binaire	LOAD.B	(A4)+OBXTYP,#2^BBXREL	LOAD.L	(A4)+OBXLG,D4	LOAD.L	D4,#256	FOS	?WRBYTE		; crit header binaire	JUMP,NE	80$	CLR.W	(A2)+OGCNBR	;  cause de GENCAR.LIB qui y met le nb de caractres !	LOAD.L	A4,A2		; A4 <-- ^gencar	LOAD.L	D4,#256	FOS	?WRBYTE		; crit header gencar	JUMP,NE	80$	ADD.L	A4,#256		; A4 <-- ^h1	PUSH.L	A4	LOAD.L	D4,D5	ADD.L	A4,D2	FOS	?WRBYTE		; crit largeurs	POPM.L	A4	JUMP,NE	80$	ADD.L	A4,#128		; A4 <-- ^h1	PUSH.L	A4	LOAD.L	D4,D5	ADD.L	A4,D2	FOS	?WRBYTE		; crit h1	POPM.L	A4	JUMP,NE	80$	ADD.L	A4,#128		; A4 <-- ^h2	PUSH.L	A4	LOAD.L	D4,D5	ADD.L	A4,D2	FOS	?WRBYTE		; crit h2	POPM.L	A4	JUMP,NE	80$	ADD.L	A4,#128		; A4 <-- ^matrix	MUL.WU	D2,(A2)+OGCMSB	; D1 (lg une matrix en bytes)	ADD.L	A4,D2	LOAD.L	D4,D0		; D4 <-- lg matrix	FOS	?WRBYTE		; crit matrix	JUMP',NE 80$	FOS	?CLOSE		; ferme le gencar	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE		; ferme sans tester si erreur	POP.W	D790$:	POPM.L	D0..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.ENDIF;--------\\; SAVFILE >;========/; Sauve un nom de fichier dans OBUNAME.; in	A3.L	^nom; out	-; mod	D7.WSAVFILE:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBUNAME10$:	LOAD.B	(A4+),(A3+)	; OBUNAME <-- nom	JUMP',EQ 90$	COMP.B	(A4)-1,#CR	JUMP,NE 10$	CLR.B	(A4)-190$:	POPM.L	A3,A4	RET;--------\\; GETFILE >;========/; Prend le nom de fichier dans OBUNAME.; in	A3.L	^buffer; out	-; mod	D7.WGETFILE:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBUNAME10$:	LOAD.B	(A3+),(A4+)	; buffer <-- OBUNAME	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 10$	CLR.B	(A3)-190$:	POPM.L	A3,A4	RET;--------\\; AFFFILE >;========/; Affiche un nom de fichier en minuscules et entre guillemets.; in	A3.L	^nom; out	-; mod	D7.WAFFFILE:	PUSHM.L	D2,D3,A3	LOAD.B	D3,#'"	LIB	?AFCAR	LOAD.W	D2,#2^BAFXMI	; D2 <-- en minuscules	LOAD.W	D3,#-1		; D3 <-- pas de maximum	LIB	?AFXFILE	LOAD.B	D3,#'"	LIB	?AFCAR	POPM.L	D2,D3,A3	RET;--------\\; ADDEXT  >;========/; Transfert le nom de fichier dans OBXFILE et force une extension.	.IF	EDGAR; Si le nom ne commence pas par "SYS_" ou "100_", force l'une de; ces chanes selon le type de la machine.;	TOTO		-->	TOTO.GENC;	NRF12			(SMA,SYS)_NRF12.GENC;	#MM1:NRF12		#MM1:(SMA,SYS)_NRF12.GENC;	#MM1:DR`NRF12		#MM1:DR`(SMA,SYS)_NRF12.GENC;	SYS_NRF12		SYS_NRF12.GENC;	XY_NRF12		XY_NRF12.GENC;	etc.	.ENDIF; in	A3.L	^nom sans extension;	A4.L	^extension  ajouter; out	A3.L	^nom avec extension (dans OBXFILE); mod	D7.W, A3.LADDEXT:	.IF	DESSIN	PUSHM.L	D3,A2	LOAD.L	A2,#(A6)+OBXFILE10$:	LOAD.B	(A2+),(A3+)	; OBXFILE <-- nom du fichier	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBXFILE	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	POPM.L	D3,A2	.ELSE	PUSHM.L	D3,D4,A1,A2,A4,A5	LOAD.L	A5,A4		; A5 <-- ^extension	LOAD.L	A4,A3		; A4 <-- ^fichier	LOAD.L	A1,#(A6)+OBXFILE	LOAD.L	A2,#R16"TEXGC	COMP.L	A5,A2		; ajoute .GENC ?	JUMP,NE 50$		; non => 50$				; oui =>	LOAD.L	A3,A4		; A3 <-- ^dbut du nom10$:	TEST.B	(A3+)		; A3 <-- ^fin du nom	JUMP,NE 10$14$:	COMP.L	A3,A4	JUMP',EQ 20$	LOAD.B	D3,(-A3)	; recule jusqu'au premier ":" ou "`"	COMP.B	D3,#':	JUMP',EQ 16$	COMP.B	D3,#'`	JUMP,NE 14$16$:	INC.L	A3		; A3 <-- ^aprs ":" ou "`"20$:	COMP.L	A4,A3	JUMP',EQ 22$	LOAD.B	(A1+),(A4+)	; OBXFILE <-- rep(s): et v. clef'	JUMP	20$22$:	LOAD.B	D3,(A4)+0	; D3 <-- fonte ?	LIB	?MINMAJ	COMP.B	D3,#'A	JUMP',LO 50$	COMP.B	D3,#'Z	JUMP',HI 50$	LOAD.B	D3,(A4)+1	; D3 <-- style ?	LIB	?MINMAJ	COMP.B	D3,#'A	JUMP',LO 50$	COMP.B	D3,#'Z	JUMP',HI 50$	LOAD.B	D3,(A4)+2	; D3 <-- chasse ?	LIB	?MINMAJ	COMP.B	D3,#'A	JUMP',LO 50$	COMP.B	D3,#'Z	JUMP',HI 50$	LOAD.B	D3,(A4)+3	; D3 <-- dizaine taille ?	LIB	?MINMAJ	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	LOAD.B	D3,(A4)+4	; D3 <-- unit taille ?	LIB	?MINMAJ	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	LOAD.B	(A1+),#'(	LOAD.B	(A1+),#'S	LOAD.B	(A1+),#'M	LOAD.B	(A1+),#'A	LOAD.B	(A1+),#',	NTREL	?GETMACHINE	; A3 <-- ^chane "SYS"/"100"40$:	LOAD.B	(A1+),(A3+)	; OBXFILE <-- "SYS"/"100"	JUMP,NE 40$	LOAD.B	(A1)-1,#')	LOAD.B	(A1+),#'_50$:	LOAD.B	(A1+),(A4+)	; OBXFILE <-- nom du fichier	JUMP,NE 50$	LOAD.L	A3,#(A6)+OBXFILE	LOAD.L	A4,A5	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	POPM.L	D3,D4,A1,A2,A4,A5	.ENDIF	RET	.IF	DESSIN;----------\\; RDSTPRINT >;==========/; Lit le status de l'imprimante. En cas d'erreur, prend; quand mme des valeurs par dfaut !; in	-; out	D7.W	erreur; mod	D7.WRDSTPRINT:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.W	(A6)+OFACX,#5	LOAD.W	(A6)+OFACY,#2	LOAD.W	(A6)+OMMX,#(254000/360)+1 ; 360e d'inch	LOAD.W	(A6)+OMMY,#(254000/144)+1 ; 144e d'inch	LOAD.L	A3,#R16"TPRINT	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre l'imprimante	JUMP,NE 90$	LOAD.W	D3,#TYPPRI	; D3 <-- type imprimante	LOAD.L	D4,#LGPRI0	; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OSTPRI	; A4 <-- ^buffer	FOS	?RSTATUS	JUMP,NE 80$	LOAD.W	D4,(A4)+OPRGLX	SR.W	D4,#3	LOAD.W	(A6)+OFACX,D4	LOAD.W	D4,(A4)+OPRGLY	SR.W	D4,#3	LOAD.W	(A6)+OFACY,D4	LOAD.W	(A6)+OMMX,(A4)+OPRUMX+2	LOAD.W	(A6)+OMMY,(A4)+OPRUMY+280$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'imprimante	POP.W	D790$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET	.ENDIF	.END