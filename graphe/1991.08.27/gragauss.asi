	.SBTTL	GRAGAUSS;---------\\; GETGAUSS >;=========/; Calcul le tableau pour les courbes de Gauss.; Le tableau, point par OPGAUSS, contient un byte; par case qui vaut de 0  n.; in	-; out	(A6)+OPGAUSS.L	^tableau pour courbe de Gauss;	D7.W		erreur; mod	D7.WGETGAUSS:	PUSHM.L	D0..D4,A4,A5	CLR.W	D7		; D7 <-- ok	TCLR.B	(A6)+OGAFAN+3:#BGAUSS ; courbe de Gauss ?	JUMP,BC 95$		; non => 95$				; oui =>	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	CALL	GIVMGAUSS	; libre la tableau prcdent	CALL	GACALCECH	; calcul l'chantillonnage	CALL	GETMINMAXGAUSS	; cherche min/max	CALL	GACALCNBE	; calcul le nb d'chantillons	LOAD.W	D7,#ERGTRVA	; D7 <-- trop de valeurs	LOAD.W	D4,(A6)+OGANBE	COMP.W	D4,#MAXXY	; trop d'chantillons ?	JUMP,HS 90$		; oui => 90$	MUL.WU	D4,(A6)+ODIMX	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour tableau de Gauss	JUMP,NE 90$	LOAD.L	(A6)+OPGAUSS,A410$:	CLR.B	(A4+)	DEC.L	D4	JUMP,NE 10$	CLR.L	D0		; D0 <-- coordonne Y initiale20$:	CLR.W	D0		; D0 <-- coordonne X initiale25$:	LOAD.L	D2,D0		; D2 <-- coordonne (y;x)	CALL	GETNB0		; D3D4 <-- nombre	JUMP',NE 30$	LOAD.L	D1,(A6)+OGAMIN+0	LOAD.L	D2,(A6)+OGAMIN+4	MATH64_	SUB		; D3D4 <-- nombre-min	LOAD.L	D1,(A6)+OGAECH+0	LOAD.L	D2,(A6)+OGAECH+4	MATH64_	DIV		; D3D4 <-- (nombre-min)/ech	LOAD.L	D1,#UN_MSPFP64	LOAD.L	D2,#UN_LSPFP64	MATH64_	ADD		; D3D4 <-- +1, voir (*)	MATH64_	FPBIN		; D4 <-- (nombre-min)/ech	DEC.W	D4		; D4 <-- -1, voir (*); (*)	A cause d'une erreur de MATH64_FPBIN.;	En effet: 1.9 donne 2 et 0.9 donne 0 !	LOAD.L	A4,(A6)+OPGAUSS	; A4 <-- ^position (0;0)	ADD.W	A4,D0		; A4 <-- ^position selon X	MUL.WU	D4,(A6)+ODIMX	ADD.L	A4,D4		; A4 <-- ^position selon X et Y	INC.B	(A4)		; OPGAUSS <-- un de plus30$:	INC.W	D0		; D0 <-- coordonne X suivante	COMP.W	D0,(A6)+ODIMX	JUMP,LO 25$	SWAP.W	D0	INC.W	D0		; D0 <-- coordonne Y suivante	LOAD.W	D2,D0	SWAP.W	D0	COMP.W	D2,(A6)+ODIMY	JUMP,LO 20$	LOAD.W	(A6)+ODIMY,(A6)+OGANBE	CLR.W	D7		; D7 <-- ok90$:	TSET.B	(A6)+OGAFAN+3:#BGAUSS ; remet le mode courbe de Gauss95$:	POPM.L	D0..D4,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; GIVMGAUSS >;==========/; Libre la mmoire utilise par le tableau de Gauss.; in	-; out	-; mod	D7.WGIVMGAUSS:	PUSHM.L	D1,A4	TEST.L	(A6)+OPGAUSS	JUMP',EQ 90$	LOAD.L	A4,(A6)+OPGAUSS	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OPGAUSS90$:	POPM.L	D1,A4	RET;---------------\\; GETMINMAXGAUSS >;---------------/; Cherche le plus petit et le plus grand nombre contenu; dans un tableau.; in	-; out	(A6)+OGAMIN.W	nombre le plus petit;	(A6)+OGAMAX.W	nombre le plus grand;	D7.W		erreur; mod	D7.WGETMINMAXGAUSS:	PUSHM.L	D0..D4,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	LOAD.L	(A6)+OGAMIN+0,#MAX_MSPFP64	LOAD.L	(A6)+OGAMIN+4,#MAX_LSPFP64	LOAD.L	(A6)+OGAMAX+0,#MIN_MSPFP64	LOAD.L	(A6)+OGAMAX+4,#MIN_LSPFP64	CLR.L	D0		; D0 <-- coordonne Y initiale10$:	CLR.W	D0		; D0 <-- coordonne X initiale20$:	LOAD.L	D2,D0		; D2 <-- coordonne (y;x)	CALL	GETNB0		; D3D4 <-- nombre	JUMP',NE 70$	LOAD.L	D1,(A6)+OGAMIN+0	LOAD.L	D2,(A6)+OGAMIN+4 ; D1D2 <-- minimum	MATH64_	COMP	JUMP',HS 40$	LOAD.L	(A6)+OGAMIN+0,D3	LOAD.L	(A6)+OGAMIN+4,D4 ; OMIN <-- minimum40$:	LOAD.L	D1,(A6)+OGAMAX+0	LOAD.L	D2,(A6)+OGAMAX+4 ; D1D2 <-- n1	MATH64_	COMP	JUMP',LS 70$	LOAD.L	(A6)+OGAMAX+0,D3	LOAD.L	(A6)+OGAMAX+4,D4 ; OMAX <-- maximum70$:	INC.W	D0		; D0 <-- coordonne X suivante	COMP.W	D0,(A6)+ODIMX	JUMP,LO 20$	SWAP.W	D0	INC.W	D0		; D0 <-- coordonne Y suivante	LOAD.W	D1,D0	SWAP.W	D0	COMP.W	D1,(A6)+ODIMY	JUMP,LO 10$; Arrondi par dfaut de la valeur minimale selon l'chantillonnage.	LOAD.L	D3,(A6)+OGAMIN+0	LOAD.L	D4,(A6)+OGAMIN+4 ; D3D4 <-- minimum	LOAD.L	D1,(A6)+OGAECH+0	LOAD.L	D2,(A6)+OGAECH+4 ; D1D2 <-- chantillonnage	MATH64_	DIV	TEST.L	D3:#31	JUMP',BC 80$	LOAD.L	D1,#UN_MSPFP64	LOAD.L	D2,#UN_LSPFP64	MATH64_	SUB80$:	MATH64_	SEP			 ; D3D4 <-- partie entire	LOAD.L	D1,(A6)+OGAECH+0	LOAD.L	D2,(A6)+OGAECH+4 ; D1D2 <-- chantillonnage	MATH64_	MUL	LOAD.L	(A6)+OGAMIN+0,D3	LOAD.L	(A6)+OGAMIN+4,D4 ; OMIN <-- minimum; Arrondi par excs de la valeur maximale selon l'chantillonnage.	LOAD.L	D3,(A6)+OGAMAX+0	LOAD.L	D4,(A6)+OGAMAX+4 ; D3D4 <-- maximum	LOAD.L	D1,(A6)+OGAECH+0	LOAD.L	D2,(A6)+OGAECH+4 ; D1D2 <-- chantillonnage	MATH64_	DIV	TEST.L	D3:#31	JUMP',BS 85$	LOAD.L	D1,#UN_MSPFP64	LOAD.L	D2,#UN_LSPFP64	MATH64_	ADD85$:	MATH64_	SEP			 ; D3D4 <-- partie entire	LOAD.L	D1,(A6)+OGAECH+0	LOAD.L	D2,(A6)+OGAECH+4 ; D1D2 <-- chantillonnage	MATH64_	MUL	LOAD.L	(A6)+OGAMAX+0,D3	LOAD.L	(A6)+OGAMAX+4,D4 ; OMIN <-- maximum	POPM.L	D0..D4,A5	CLR.W	D7		; D7 <-- toujours OK	RET;----------\\; GACALCECH >;==========/; Calcul la valeur d'chantillonnage.; in	(A6)+OGAFAN.L	fanions (1/4, 1/2 , etc. unit); out	(A6)+OGAECH.64	chantillonage; mod	D7.WGACALCECH:	PUSHM.L	D3,D4	LOAD.L	D3,#QUART_MSPFP64	LOAD.L	D4,#QUART_LSPFP64	TEST.B	(A6)+OGAFAN+2:#BGA14	JUMP',BS 20$	LOAD.L	D3,#DEMI_MSPFP64	LOAD.L	D4,#DEMI_LSPFP64	TEST.B	(A6)+OGAFAN+2:#BGA12	JUMP',BS 20$	LOAD.L	D3,#DEUX_MSPFP64	LOAD.L	D4,#DEUX_LSPFP64	TEST.B	(A6)+OGAFAN+2:#BGA2	JUMP',BS 20$	LOAD.L	D3,#QUATRE_MSPFP64	LOAD.L	D4,#QUATRE_LSPFP64	TEST.B	(A6)+OGAFAN+2:#BGA4	JUMP',BS 20$	LOAD.L	D3,#UN_MSPFP64	LOAD.L	D4,#UN_LSPFP6420$:	LOAD.L	(A6)+OGAECH+0,D3	LOAD.L	(A6)+OGAECH+4,D4	POPM.L	D3,D4	RET;----------\\; GACALCNBE >;==========/; Calcul le nombre d'chantillons.; in	(A6)+OGAECH.64	chantillonage; out	(A6)+OGANBE.W	nb d'chantillons; mod	D7.WGACALCNBE:	PUSHM.L	D1..D4	LOAD.L	D3,(A6)+OGAMAX+0	LOAD.L	D4,(A6)+OGAMAX+4	LOAD.L	D1,(A6)+OGAMIN+0	LOAD.L	D2,(A6)+OGAMIN+4	MATH64_	SUB		; D3D4 <-- max-min	LOAD.L	D1,(A6)+OGAECH+0	LOAD.L	D2,(A6)+OGAECH+4	MATH64_	DIV		; D3D4 <-- (max-min)/ech	MATH64_	FPBIN		; D4 <-- idem en binaire	INC.W	D4		; D4 <-- ((max-min)/ech)+1	LOAD.W	(A6)+OGANBE,D4	POPM.L	D1..D4	RET	.END