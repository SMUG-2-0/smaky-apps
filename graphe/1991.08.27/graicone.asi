	.SBTTL	GRAICONE;---------\\; DESICONE >;=========/; Dessine une liste d'icnes en colonne.; in	-; out	-; mod	D7.WDESICONE:	PUSHM.L	D0,A3	CLR.W	D0		; D0 <-- dessine	LOAD.L	A3,#R16"TICONES	CALL	XXXICONE	POPM.L	D0,A3	RET;---------\\; DETICONE >;=========/; Dtecte dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D3.B	icne o est la souris;	D7.W	ok/erreur; mod	D3.L, D7.WDETICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#1		; D0 <-- dtecte	LOAD.L	D5,D4		; D5 <-- position de la souris (y;x)	LOAD.L	A3,#R16"TICONES	CALL	XXXICONE	JUMP',NE 90$	LOAD.B	D3,D5		; D3 <-- code de l'icne90$:	POPM.L	D0,D5,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; INVICONE >;=========/; Inverse une icne.; in	D3.B	icne  inverser; out	-; mod	D7.WINVICONE:	PUSHM.L	D0,D3,D5,A3	COMP.B	D3,#ICOGEMP	JUMP',NE 10$	LOAD.B	D3,#ICOGCAC10$:	LOAD.W	D0,#2		; D0 <-- inverse	LOAD.B	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	LOAD.L	A3,#R16"TICONES	CALL	XXXICONE90$:	POPM.L	D0,D3,D5,A3	RET;---------\\; POSICONE >;=========/; Donne la position d'une icne.; in	D3.B	icne; out	D4.L	position coin sup/gauche (y;x);	D7.W	erreur; mod	D7.WPOSICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#3		; D0 <-- position	LOAD.B	D5,D3		; D5 <-- code de l'icne	LOAD.L	A3,#R16"TICONES	CALL	XXXICONE	JUMP',NE 90$	LOAD.L	D4,D5		; D4 <-- position90$:	POPM.L	D0,D5,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; XXXICONE >;---------/; Dessine une liste d'icnes en colonne.; in	A3.L	^liste;	D0.W	opration dessine/dtecte/inverse/position;	D5.L	position de la souris (si dtecte);	D5.B	code de l'icne (si inverse/position); out	D5.B	icne o est la souris (si dtecte);	D5.L	coordonne (si position);	D7.W	ok/erreur (si dtecte ou inverse); mod	D5.L, D7.WXXXICONE:	PUSHM.L	D3,D4,A3	LOAD.W	D4,#MARGY+GCIMY-1	ADD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LOAD.W	D4,#MARGX+GCIMX	TEST.W	D0		; dessine ?	JUMP',NE 15$		; non => 15$	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN15$:	LOAD.L	D3,D420$:	COMP.B	(A3),#IF	; fin de la table ?	JUMP',EQ 80$	COMP.B	(A3),#IL	; va  la ligne suivante ?	JUMP',EQ 40$	COMP.B	(A3),#IC	; va  la ligne suivante ?	JUMP',EQ 45$	COMP.W	D0,#1	JUMP',EQ 30$	COMP.W	D0,#2	JUMP',EQ 35$	COMP.W	D0,#3	JUMP',EQ 35$				; dessine =>	CALL	XXXONEICONE	; dessine une icne25$:	ADD.L	A3,#2	JUMP	20$30$:				; dtecte =>	CALL	XXXONEICONE	; dtecte si dans cette icne ?	JUMP,NE 25$		; non => 25$	LOAD.B	D5,(A3)+1	; D5 <-- code de l'icne	JUMP'	80$35$:				; inverse/position =>	CALL	XXXONEICONE	; inverse cette icne ?	JUMP,NE 25$		; non => 25$	JUMP'	80$40$:				; grand interligne =>	SWAP.W	D3	ADD.W	D3,#GCICY+GCIMY*2	SWAP.W	D3	LOAD.L	D4,D3	INC.L	A3	JUMP	20$45$:				; petit interligne =>	SWAP.W	D3	ADD.W	D3,#7		; aligne en bas sur Smaky 100 !	SWAP.W	D3	LOAD.L	D4,D3	INC.L	A3	JUMP	20$80$:	TEST.W	D0		; dessine ?	JUMP',NE 90$		; non => 90$	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN90$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; XXXONEICONE >;------------/; Dessine/dtecte/inverse une icne.; in	A3.L	^lment dans table;	D4.L	coordonne coin sup/gauche;	D0.W	opration dessine/dtecte/inverse/position;	D5.L	position de la souris (si dtecte);	D5.B	code de l'icne (si inverse/position); out	D4.L	coordonne suivante;	D5.L	coordonne coin (si position);	D7.W	ok/erreur (si dtecte ou inverse); mod	D4.L, D5.L, D7.WXXXONEICONE:	PUSHM.L	D1..D3	LOAD.L	D1,D4		; D1 <-- coin	LOAD.L	D3,D4	SUB.W	D3,#GCIMX	SWAP.W	D3	SUB.W	D3,#GCIMY	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SWAP.W	D4	LOAD.W	D4,#GCICX/2+GCIMX*2	COMP.B	(A3)+0,#ID	JUMP',NE 20$	ADD.W	D4,#GCICX/2+GCIMX*220$:	COMP.W	D0,#1	JUMP,EQ 40$	COMP.W	D0,#2	JUMP,EQ 50$	COMP.W	D0,#3	JUMP,EQ 60$				; dessine =>	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	PUSH.L	D4	CLR.L	D4	CALL	_DRMDEF	POP.L	D4	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour icne	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	LOAD.L	D3,D1		; D3 <-- coin	SUB.W	D3,#4	COMP.B	(A3)+0,#ID	JUMP',NE 30$	ADD.W	D3,#GCIMX+430$:	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,(A3)+1	; D3 <-- code	LIB	?AFCODE	JUMP	80$40$:				; dtecte =>	LOAD.W	D7,#ERDIOUT	COMP.W	D5,D3		; souris trop  gauche ?	JUMP,LO 80$	ADD.W	D3,D4	COMP.W	D5,D3		; souris trop  droite ?	JUMP,HS 80$	SWAP.W	D3	SWAP.W	D4	LOAD.L	D2,D5	SWAP.W	D2	COMP.W	D2,D3		; souris trop en haut ?	JUMP,LO 80$	ADD.W	D3,D4	COMP.W	D2,D3		; souris trop en bas ?	JUMP,HS 80$	CLR.W	D7		; D7 <-- dans l'icone	JUMP	80$50$:				; inverse =>	LOAD.W	D7,#ERDIOUT	COMP.B	D5,(A3)+1	JUMP,NE 80$	PUSH.L	D4	LOAD.L	D4,#-1	CALL	_DRMDEF	POP.L	D4	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#2+2	SWAP.W	D4	SUB.W	D4,#2+2	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	CLR.W	D7	JUMP	80$60$:				; position =>	LOAD.W	D7,#ERDIOUT	COMP.B	D5,(A3)+1	JUMP,NE 80$	LOAD.L	D5,D3		; D5 <-- position	CLR.W	D780$:	LOAD.L	D4,D1	ADD.W	D4,#GCICX/2+GCIMX*2	COMP.B	(A3)+0,#ID	JUMP',NE 90$	ADD.W	D4,#GCICX/2+GCIMX*290$:	POPM.L	D1..D3	TEST.W	D7		; retour EQ/NE	RET	.END