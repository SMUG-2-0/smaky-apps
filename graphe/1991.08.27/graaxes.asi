	.SBTTL	GRAAXES;--------\\; DESAXES >;========/; Dessine les axes.; in	-; out	-; mod	D7.WDESAXES:	PUSHM.L	D1..D5,A4	CALL	DESPOSAXES	; D3/D4 <-- pos/dim des axes; Dessine les axes.	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLAXE	CALL	DEFTRAIT	COMP.W	D2,#-1	JUMP,EQ 90$	OR.W	D2,#SETDOT	TEST.B	(A6)+OECFAN+3:#BECAXX	JUMP',BC 10$	PUSHM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	INC.W	D3	CLR.W	D4	SWAP.W	D4	SWAP.W	D3	CALL	ZPENTE	CALL	DRLINE		; trace l'axe X	POPM.L	D3,D410$:	TEST.B	(A6)+OECFAN+3:#BECAXY	JUMP',BC 15$	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP',BC 15$		; non => 15$	PUSHM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	INC.W	D3;	SWAP.W	D4	SWAP.W	D3	LOAD.W	D4,(A6)+OPERSY	SWAP.W	D4	LOAD.W	D4,(A6)+OPERSX	NEG.W	D4	CALL	DRLINE		; trace l'axe Y	POPM.L	D3,D415$:	TEST.B	(A6)+OECFAN+3:#BECAXZ	JUMP',BC 20$	PUSHM.L	D3,D4	CLR.W	D4	CALL	DRLINE		; trace l'axe Z	POPM.L	D3,D4; Dessine le fond des axes.20$:	TEST.B	(A6)+OECFAN+1:#BECFXZ	JUMP,BC 50$	PUSHM.L	D3,D4	LOAD.L	D5,D4	CLR.L	D4	LOAD.W	D4,D5	CALL	ZPENTE	CALL	DRLINE		; trace ligne suprieure	LOAD.L	D4,D5	CLR.W	D4	CALL	DRLINE		; trace ligne de droite	CLR.L	D4	LOAD.W	D4,D5	NEG.W	D4	CALL	ZPENTE	CALL	DRLINE		; trace ligne infrieure	LOAD.L	D4,D5	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DRLINE		; trace ligne de gauche	POPM.L	D3,D4	TEST.B	(A6)+OPEFAN+3:#BPEFIL ; fil de fer ?	JUMP',BS 50$		; oui => 50$	LOAD.L	A4,#(A6)+OTDDEF+8*RANGTFOND	CALL	DEFTRAME	COMP.W	D2,#-1	JUMP',EQ 50$	OR.W	D2,#SETDOT	TEST.W	(A6)+OPERSZ	; axe "Z" horizontal ?	JUMP',NE 40$		; non => 40$				; oui =>	CALL	DRTRAME		; met la trame de fond	JUMP'	50$40$:	PUSHM.L	D3,D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,(A6)+OPERSZ	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	CALL	DRFILL		; rempli la surface du fond	POPM.L	D3,D4; Dessine la perspective de l'axe vertical.50$:	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP,BC 90$		; non => 90$				; oui =>	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLAXE	CALL	DEFTRAIT	COMP.W	D2,#-1	JUMP,EQ 90$	OR.W	D2,#SETDOT	TEST.B	(A6)+OECFAN+1:#BECFYZ	JUMP,BC 90$	PUSHM.L	D3,D4	LOAD.L	D5,D4	LOAD.W	D4,(A6)+OPERSY	SWAP.W	D4	LOAD.W	D4,(A6)+OPERSX	NEG.W	D4	CALL	DRLINE		; /	LOAD.L	D4,D5	CLR.W	D4	CALL	DRLINE		; |	LOAD.W	D4,(A6)+OPERSY	NEG.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OPERSX	CALL	DRLINE		; /	LOAD.L	D4,D5	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DRLINE		; |	POPM.L	D3,D4	TEST.B	(A6)+OPEFAN+3:#BPEFIL ; fil de fer ?	JUMP',BS 90$		; oui => 90$	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLAXE	CALL	IFCTRAIT	; dlimit par un trait continu ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A4,#(A6)+OTDDEF+8*RANGTDROITE	CALL	DEFTRAME	COMP.W	D2,#-1	JUMP',EQ 90$	OR.W	D2,#SETDOT	PUSHM.L	D3,D4	LOAD.W	D4,(A6)+OPERSX	SR.W	D4,#1	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,(A6)+OPERSY	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	CALL	DRFILL		; rempli la surface  gauche	POPM.L	D3,D490$:	CALL	DESGRILLE	; dessine les grilles ventuelles	POPM.L	D1..D5,A4	RET;----------\\; DESGRILLE >;----------/; Dessine la grille sur les fonds de droite et de gauche sous; la forme de lignes horizontales et/ou verticales.; in	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDESGRILLE:	PUSHM.L	D0..D4,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	LOAD.L	(A6)+OGRPOS,D3	LOAD.L	(A6)+OGRDIM,D4	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLHGRILLE	CALL	DEFTRAIT	COMP.W	D2,#-1	JUMP,EQ 50$; Dessine la graduation en dessous du zro.	CALL	OKGRADZ		; graduation trop serre ?	JUMP,NE 50$		; oui => 50$	LOAD.L	D3,(A6)+OMAX+0	LOAD.L	D4,(A6)+OMAX+4	MATH64_	TEST	JUMP',LO 12$	CLR.L	D3	CLR.L	D412$:	LOAD.L	D1,D3	LOAD.L	D2,D4	LOAD.L	D3,(A6)+OMIN+0	LOAD.L	D4,(A6)+OMIN+4	MATH64_	TEST	JUMP,HI 25$	MATH64_	SUB		; D3D4 <-- MIN-MAX	MATH64_	NEG	LOAD.L	D1,(A6)+OGRAD+0	LOAD.L	D2,(A6)+OGRAD+4	MATH64_	DIV	MATH64_	SEP	MATH64_	FPBIN	INC.W	D4	LOAD.W	D0,D4		; D0 <-- nb de divisions	CLR.W	D1		; D1 <-- rang	CLR.L	D3	CLR.L	D4		; D3D4 <-- zro20$:	CALL	ONEGRILLEHOR	PUSHM.L	D1,D2	LOAD.L	D1,(A6)+OGRAD+0	LOAD.L	D2,(A6)+OGRAD+4	MATH64_	SUB		; D3D4 <-- valeur en dessous	POPM.L	D1,D2	INC.W	D1	DEC.W	D0	JUMP,NE 20$; Dessine la graduation en dessus du zro.25$:	LOAD.L	D3,(A6)+OMIN+0	LOAD.L	D4,(A6)+OMIN+4	MATH64_	TEST	JUMP',HI 26$	CLR.L	D3	CLR.L	D426$:	LOAD.L	D1,D3	LOAD.L	D2,D4	LOAD.L	D3,(A6)+OMAX+0	LOAD.L	D4,(A6)+OMAX+4	MATH64_	TEST	JUMP,LO 50$	MATH64_	SUB		; D3D4 <-- MAX-MIN	LOAD.L	D1,(A6)+OGRAD+0	LOAD.L	D2,(A6)+OGRAD+4	MATH64_	DIV	MATH64_	SEP	MATH64_	FPBIN	INC.W	D4	LOAD.W	D0,D4		; D0 <-- nb de divisions	CLR.W	D1		; D1 <-- rang	CLR.L	D3	CLR.L	D4		; D3D4 <-- zro30$:	CALL	ONEGRILLEHOR	PUSHM.L	D1,D2	LOAD.L	D1,(A6)+OGRAD+0	LOAD.L	D2,(A6)+OGRAD+4	MATH64_	ADD		; D3D4 <-- valeur en dessus	POPM.L	D1,D2	INC.W	D1	DEC.W	D0	JUMP,NE 30$50$:	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLVGRILLE	CALL	DEFTRAIT	COMP.W	D2,#-1	JUMP,EQ 90$	OR.W	D2,#SETDOT	CALL	DESBALARG	; OBALGn <-- largeurs	JUMP,NE 90$	LOAD.W	D0,(A6)+OBALG4	; D0 <-- largeur entre deux barres	LOAD.W	D1,(A6)+ODIMY	DEC.W	D1	COMP.B	(A6)+OGRAPHE,#ICOGBRI	JUMP',EQ 55$	INC.W	D155$:	LOAD.L	D3,(A6)+OGRPOS	SWAP.W	D3	ADD.W	D3,(A6)+OPERSZ	SWAP.W	D3	LOAD.L	D4,(A6)+OGRDIM	CLR.W	D460$:	ADD.W	D3,D0		; D3 <-- position suivante	SUB.W	(A6)+OPOSZ,D0	PUSH.L	D3	CALL	ZPOINT	CALL	DRLINE		; dessine une barre verticale	POP.L	D3	DEC.W	D1	JUMP,NE 60$90$:	POPM.L	D0..D4,A5	RET;-------------\\; ONEGRILLEHOR >;-------------/; Dessine une ligne horizontale dans le fond de droite.; in	D3D4	valeur; out	-; mod	D7.WONEGRILLEHOR:	PUSHM.L	D1..D4,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	CALL	CONVMULYA	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLHGRILLE	CALL	DEFTRAIT	OR.W	D2,#SETDOT	LOAD.L	D3,(A6)+OGRPOS	SWAP.W	D3	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	D1,D3	LOAD.L	D4,(A6)+OGRDIM	AND.L	D4,#H'FFFF	CALL	ZPENTE	CALL	DRLINE		; trace ligne _  droite	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP',BC 90$		; non => 90$				; oui =>	LOAD.L	D3,D1	LOAD.W	D4,(A6)+OPERSY	SWAP.W	D4	LOAD.W	D4,(A6)+OPERSX	NEG.W	D4	CALL	DRLINE		; trace ligne _  gauche90$:	POPM.L	D1..D4,A5	RET;-----------\\; DESAXEZERO >;===========/; Dessine la barre horizontale du zro.; in	-; out	-; mod	D7.WDESAXEZERO:	PUSHM.L	D1..D6,A3,A4	TEST.B	(A6)+OECFAN+1:#BECFXY	JUMP,BC 90$	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLAXE	CALL	DEFTRAIT	COMP.W	D2,#-1	JUMP,EQ 90$	CALL	DESPOSAXES	; D3/D4 <-- pos/dim des axes	PUSHM.L	D3,D4	CALL	POSZERO		; D3D4 <-- position du "zro"	CALL	CONVMULY	LOAD.W	D1,D4		; D1 <-- position du "zro"	POPM.L	D3,D4	SWAP.W	D3	ADD.W	D3,#MARGA+1	ADD.W	D3,D1	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,(A6)+OPERSY	SWAP.W	D4	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP,BS 20$		; oui => 20$				; non =>	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLAXE	CALL	DEFTRAIT	COMP.W	D2,#-1	JUMP,EQ 90$	OR.W	D2,#SETDOT	AND.L	D4,#H'FFFF	CALL	DRLINE		; dessine l'axe horizontal	JUMP	90$; Construit l'ombre en perspective de la ligne horizontale du zro.20$:	TEST.B	(A6)+OPEFAN+3:#BPEFIL ; fil de fer ?	JUMP,BS 50$		; oui => 50$	SUB.W	D3,(A6)+OPBIGX	SWAP.W	D3	SUB.W	D3,(A6)+OPBIGY	SWAP.W	D3	CALL	CLRDISMAT	CALL	OPEDISMAT	LOAD.L	D5,D4	LOAD.W	D2,#SETDOT	PUSHM.L	D3,D4	CLR.L	D4	LOAD.W	D4,D5	CALL	ZPENTE	CALL	DRLINE		; _	LOAD.W	D4,(A6)+OPERSY	SWAP.W	D4	LOAD.W	D4,(A6)+OPERSX	NEG.W	D4	CALL	DRLINE		; /	CLR.L	D4	LOAD.W	D4,D5	NEG.W	D4	CALL	ZPENTE	CALL	DRLINE		; _	LOAD.W	D4,(A6)+OPERSY	NEG.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OPERSX	CALL	DRLINE		; /	POPM.L	D3,D4	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	DRTRADEF	POPM.L	D3,D4	PUSHM.L	D3,D4	SUB.W	D4,(A6)+OPERSX	ASR.W	D4,#1	ADD.W	D3,D4		; D3 <-- au milieu en X	SWAP.W	D3	LOAD.W	D4,(A6)+OPERSY	ADD.W	D4,(A6)+OPERSZ	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- au milieu en Y	SWAP.W	D3	CALL	DRFILL	POPM.L	D3,D4	CALL	CLODISMAT; Efface l'ombre de la barre dans l'cran.	PUSHM.L	D3,D4	LOAD.L	D1,D4	ADD.W	D1,(A6)+OPERSX	SWAP.W	D1	LOAD.W	D1,(A6)+OPERSY	ADD.W	D1,(A6)+OPERSZ	SWAP.W	D1		; D1 <-- dimensions	SUB.W	D3,(A6)+OPERSX	; D3 <-- source: (y;x)	LOAD.L	A3,(A6)+OPMAT	LOAD.W	D5,(A6)+ODBIGX	SR.W	D5,#3	LOAD.L	D4,D3		; D4 <-- destination: (y;x)	ADD.W	D4,(A6)+OPBIGX	SWAP.W	D4	ADD.W	D4,(A6)+OPBIGY	SWAP.W	D4	LOAD.L	A4,#0	CLR.W	D6	LOAD.W	D2,#CLRDOT	CALL	DRRASTER	; efface dans l'cran	POPM.L	D3,D4	ADD.W	D3,(A6)+OPBIGX	SWAP.W	D3	ADD.W	D3,(A6)+OPBIGY	SWAP.W	D3; Dessine la barre dfinitive.50$:	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLAXE	CALL	DEFTRAIT	COMP.W	D2,#-1	JUMP,EQ 90$	OR.W	D2,#SETDOT	LOAD.L	D5,D4	PUSHM.L	D3,D4	CLR.L	D4	LOAD.W	D4,D5	CALL	ZPENTE	CALL	DRLINE		; _	LOAD.W	D4,(A6)+OPERSY	SWAP.W	D4	LOAD.W	D4,(A6)+OPERSX	NEG.W	D4	CALL	DRLINE		; /	CLR.L	D4	LOAD.W	D4,D5	NEG.W	D4	CALL	ZPENTE	CALL	DRLINE		; _	LOAD.W	D4,(A6)+OPERSY	NEG.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OPERSX	CALL	DRLINE		; /	POPM.L	D3,D4	TEST.B	(A6)+OPEFAN+3:#BPEFIL ; fil de fer ?	JUMP',BS 90$		; oui => 90$	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLAXE	CALL	IFCTRAIT	; dlimit par un trait continu ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A4,#(A6)+OTDDEF+8*RANGTHAUT	CALL	DEFTRAME	COMP.W	D2,#-1	JUMP',EQ 90$	OR.W	D2,#SETDOT;	PUSHM.L	D3,D4	SUB.W	D4,(A6)+OPERSX	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	LOAD.W	D4,(A6)+OPERSY	ADD.W	D4,(A6)+OPERSZ	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	CALL	DRFILL		; rempli la surface en bas;	POPM.L	D3,D490$:	POPM.L	D1..D6,A3,A4	RET;-----------\\; DESPOSAXES >;-----------/; Calcul la position et les dimensions pour les axes.; in	-; out	D3.L	position (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WDESPOSAXES:	LOAD.L	D3,(A6)+OPBIG	ADD.W	D3,(A6)+OMARGG	ADD.W	D3,(A6)+OPERSX;;?	SUB.W	D3,#MARGA	SWAP.W	D3	ADD.W	D3,(A6)+OMARGH	SUB.W	D3,#MARGA	SWAP.W	D3	LOAD.W	D4,(A6)+ODGRAY	SUB.W	D4,(A6)+OMARGH	SUB.W	D4,(A6)+OMARGB	SUB.W	D4,(A6)+OPERSY	SUB.W	D4,(A6)+OPERSZ	ADD.W	D4,#MARGA*2	SWAP.W	D4	LOAD.W	D4,(A6)+ODGRAX	SUB.W	D4,(A6)+OMARGG	SUB.W	D4,(A6)+OMARGD	SUB.W	D4,(A6)+OPERSX;;?	ADD.W	D4,#MARGA+2	RET	.END