	.SBTTL	GRACADRE;--------\\; DESWDO  >;========/; Grise toute la fentre et place les icnes.; in	-; out	-; mod	D7.WDESWDO:	PUSHM.L	D2..D4	CALL	_ERGMOUSE	; efface les flches dans les rgles	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface toute la fentre	LOAD.L	D3,#H'88882222	; D3 <-- trame pour cran entrelac	COMP.B	(A6)+OMACHINE,#SMAKY8	JUMP',EQ 20$	LOAD.L	D3,#H'88228822	; D3 <-- trame pour joli cran20$:	LOAD.L	D4,D3	CALL	_DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise toute la fentre	PUSH.L	D4	LOAD.L	D4,#-1	CALL	_DRMDEF	POP.L	D4	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LIB	?DRMATRIX	; dessine une bande blanche en haut	CALL	DESINFO		; affiche les informations	CALL	DESINFFILE	; affiche le nom du graphe	CLR.L	D4	CALL	_DRMDEF	CALL	DESICONE	; dessine toutes les icnes	LOAD.B	D3,(A6)+OGRAPHE	CALL	INVICONE	; graphe par dfaut	POPM.L	D2..D4	RET;--------\\; DESINFO >;========/; Dessine les informations tout en haut.; in	-; out	-; mod	D7.WDESINFO:	PUSHM.L	D3,D4,A3	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	AFINV		; vido inverse	.ASCII	" GRAPHE "	.B	GRAREV+'0,'.	.IF	GRAVERS<10	.B	GRAVERS+'0	.ELSE	.B	(GRAVERS/10)+'0,(GRAVERS-((GRAVERS/10)*10))+'0	.ENDIF	.B	0	.EVEN	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	POPM.L	D3,D4,A3	RET;---------\\; DESINF3B >;=========/; Affiche les fonctions des trois boutons de la souris.; in	A3.L	^texte; out	-; mod	D7.WDESINF3B:	PUSHM.L	D3,A3	LOAD.B	D3,#AFINV	LIB	?AFCAR	LOAD.W	D3,#LIHELP	MUL.WU	D3,(A0)+ODFCX	SUB.W	D3,(A0)+ODFDX	NEG.W	D3	AND.L	D3,#H'FFFF	LIB	?SETCURS	LIB	?AFTEXT		; affiche les 3 boutons de la souris	LOAD.B	D3,#AFDIR	LIB	?AFCAR	POPM.L	D3,A3	RET;---------\\; DESINFXY >;=========/; Affiche la position x,y de la souris dans les informations.; in	D3.L	position (y;x) ou -1 si hors de l'aire de dessin; out	-; mod	D7.WDESINFXY:	PUSHM.L	D2..D4	LOAD.L	D4,D3		; D4 <-- position (y;x)	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSXY	MUL.WU	D3,(A0)+ODFCX	AND.L	D3,#H'FFFF	LIB	?SETCURS	COMP.L	D4,#-1		; hors de l'aire de dessin ?	JUMP',EQ 50$		; oui => 50$				; non =>	LIB	?AFTIM	.ASCIZ	"X="	.EVEN	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode	LOAD.W	D3,#3		; D3 <-- nb digits pour 0..999	PUSH.L	D4	AND.L	D4,#H'FFFF	LIB	?AFDEC	POP.L	D4	LIB	?AFTIM	.ASCIZ	" Y="	.EVEN	CLR.W	D4	SWAP.W	D4	LIB	?AFDEC	JUMP'	80$50$:	LIB	?AFTIM	.B	MSPACE,6+6,0	; efface tout	.EVEN80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	POPM.L	D2..D4	RET;-----------\\; DESINFFILE >;===========/; Affiche le nom du fichier dans les informations.; in	-; out	-; mod	D7.WDESINFFILE:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#(A6)+OBUNAME	LIB	?BUCAR		; mode rapide	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSFILE	MUL.WU	D3,(A0)+ODFCX	AND.L	D3,#H'FFFF	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A0)+ODFDX	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb car dans toute la largeur	SUB.W	D4,#POSFILE	SUB.W	D4,#LIHELP+1	; D4 <-- nb car restants pour le nom	TEST.B	(A3)	JUMP',EQ 50$	COMP.B	(A3),#CR	JUMP',EQ 50$	LOAD.B	D3,#'"	LIB	?AFCAR	SUB.W	D4,#220$:	LOAD.B	D3,(A3+)	JUMP',EQ 40$	COMP.B	D3,#CR	JUMP',EQ 40$	COMP.B	D3,#'A	JUMP',LO 30$	COMP.B	D3,#'Z	JUMP',HI 30$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule30$:	LIB	?AFCAR	DEC.W	D4	JUMP,NE 20$40$:	LOAD.B	D3,#'"	LIB	?AFCAR50$:	TEST.W	D4	JUMP',EQ 80$	LOAD.B	D3,#MSPACE	LIB	?AFCAR		; efface la fin	LOAD.B	D3,D4	LIB	?AFCAR80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?NOBUCAR	; mode normal	POPM.L	D3,D4,A3,A4	RET;---------\\; DESCADRE >;=========/; Dessine le cadre du graphique avec les rgles.; in	-; out	-; mod	D7.WDESCADRE:	PUSHM.L	D2..D4	CALL	_ERGMOUSE	; efface les flches dans les rgles	CLR.L	D4	CALL	_DRMDEF	LOAD.L	D3,(A6)+OPBIG	LOAD.L	D4,(A6)+ODBIG	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface toute la grande matrice	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour grande matrice	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur; Dessine l'icne dans le carr en bas  droite.	CALL	DESDIM	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+ODGRAY	ADD.W	D3,#GCICY-GCICB	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+ODGRAX	SUB.W	D3,#GCICX/2	LIB	?SETCURS	LIB	?AFTIM	.B	MODCAR,INVDOT	.B	USEGC,GCICF,GCICS,GCICT	.B	AFTOUT	.B	ICODIM		; affiche l'icne	.B	AFNORM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	MODCAR,SETDOT	.B	0	.EVEN; Grise les surfaces inutilises en bas et  droite.	LOAD.L	D4,#H'00880022	CALL	_DRMDEF	LOAD.W	D4,(A6)+ODBIGY	SUB.W	D4,(A6)+ODGRAY	SUB.W	D4,#LGREGLE	JUMP',LE 60$	SWAP.W	D4	LOAD.W	D4,(A6)+ODGRAX	ADD.W	D4,#LGREGLE	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+ODGRAY	ADD.W	D3,#LGREGLE	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	LIB	?DRMATRIX	; grise en bas60$:	LOAD.W	D4,(A6)+ODBIGY	SWAP.W	D4	LOAD.W	D4,(A6)+ODBIGX	SUB.W	D4,(A6)+ODGRAX	SUB.W	D4,#LGREGLE	JUMP',LE 70$	LOAD.W	D3,(A6)+OPBIGY	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+ODGRAX	ADD.W	D3,#LGREGLE	LIB	?DRMATRIX	; grise  droite70$:	CALL	DESREGLE	; dessine les rgles	POPM.L	D2..D4	RET;--------\\; DETDIM  >;========/; Dtecte si la souris est dans l'icne de changement de dimensions.; in	D4.L	position de la souris (y;x); out	D7.W	ok/erreur; mod	D7.WDETDIM:	PUSH.L	D4	LOAD.W	D7,#1		; D7 <-- souris ailleur	SUB.W	D4,(A6)+OPBIGX	JUMP',LO 90$	SUB.W	D4,(A6)+ODGRAX	JUMP',LO 90$	COMP.W	D4,#LGREGLE	JUMP',HS 90$	SWAP.W	D4	SUB.W	D4,(A6)+OPBIGY	JUMP',LO 90$	SUB.W	D4,(A6)+ODGRAY	JUMP',LO 90$	COMP.W	D4,#LGREGLE	JUMP',HS 90$	CLR.W	D7		; D7 <-- ok, souris dedans90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLIPDIM >;========/; Modifie les dimensions pour ne pas obtenir qq chose d'absurde.; in	-; out	-; mod	D7.WCLIPDIM:	PUSHM.L	D3,D4	LOAD.L	D4,(A6)+ODGRA	COMP.W	D4,#DMINX	; largeur trop petite ?	JUMP',HS 10$	LOAD.W	D4,#DMINX10$:	LOAD.W	D3,(A6)+ODBIGX	SUB.W	D3,#LGREGLE	COMP.W	D4,D3		; largeur trop grande ?	JUMP',LS 15$	LOAD.W	D4,D315$:	SWAP.W	D4	COMP.W	D4,#DMINY	; hauteur trop petite ?	JUMP',HS 20$	LOAD.W	D4,#DMINY20$:	LOAD.W	D3,(A6)+ODBIGY	SUB.W	D3,#LGREGLE	COMP.W	D4,D3		; hauteur trop grande ?	JUMP',LS 25$	LOAD.W	D4,D325$:	SWAP.W	D4	LOAD.L	(A6)+ODGRA,D4	POPM.L	D3,D4	RET;--------\\; DESDIM  >;========/; Dessine les lignes de sparation en fonction des dimensions.; in	D2.W	mode de dessin; out	-; mod	D7.WDESDIM:	PUSHM.L	D3,D4; Dessine les lignes de sparations horizontales.	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+ODGRAY	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	CLR.L	D4	LOAD.W	D4,(A6)+ODGRAX	ADD.W	D4,#LGREGLE	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	SWAP.W	D3	ADD.W	D3,#LGREGLE	SWAP.W	D3	LIB	?DRSEG; Dessine les lignes de sparations verticales.	LOAD.W	D3,(A6)+OPBIGY	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+ODGRAX	LOAD.W	D4,(A6)+ODGRAY	ADD.W	D4,#LGREGLE	SWAP.W	D4	CLR.W	D4	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	ADD.W	D3,#LGREGLE	LIB	?DRSEG	POPM.L	D3,D4	RET;---------\\; DESREGLE >;=========/; Dessine les rgles centimtriques.; in	-; out	-; mod	D7.WDESREGLE:	PUSHM.L	D2..D4,A5	LOAD.L	A5,#(A6)+ORGVAR; Initialise les variables pour la rgle horizontale.	LOAD.W	(A5)+ORGHPO+2,(A6)+OPBIGX	LOAD.W	D4,(A6)+OPBIGY	ADD.W	D4,(A6)+ODGRAY	INC.W	D4	LOAD.W	(A5)+ORGHPO+0,D4	LOAD.W	D4,(A6)+ODGRAX	INC.W	D4	LOAD.W	(A5)+ORGHLG,D4	LOAD.L	D4,#10000*64	DIV.WU	D4,(A6)+OMMX	AND.L	D4,#H'FFFF	DIV.WU	D4,(A6)+OFACX	LOAD.W	(A5)+ORGHPA,D4	SET.B	(A5)+ORGHMI	; rgle en bas; Initialise les variables pour la rgle verticale.	LOAD.W	D4,(A6)+OPBIGX	ADD.W	D4,(A6)+ODGRAX	INC.W	D4	LOAD.W	(A5)+ORGVPO+2,D4	LOAD.W	(A5)+ORGVPO+0,(A6)+OPBIGY	LOAD.W	D4,(A6)+ODGRAY	INC.W	D4	LOAD.W	(A5)+ORGVLG,D4	LOAD.L	D4,#10000*64	DIV.WU	D4,(A6)+OMMY	AND.L	D4,#H'FFFF	DIV.WU	D4,(A6)+OFACY	LOAD.W	(A5)+ORGVPA,D4	SET.B	(A5)+ORGVHB	; graduation de haut en bas; Dessine ou grise les rgles.	TEST.B	(A6)+OREGLE	; rgles prsentes ?	JUMP',F	60$		; non => 60$				; oui =>	SCROLL_	RUPDATE		; dessine les rgles gradues	JUMP'	90$60$:	LOAD.L	D4,#H'00880022	CALL	_DRMDEF	LOAD.W	D2,#SETDOT	LOAD.L	D3,(A5)+ORGHPO	LOAD.W	D4,#LGREGLE	SWAP.W	D4	LOAD.W	D4,(A5)+ORGHLG	LIB	?DRMATRIX	; grise la rgle horizontale	LOAD.L	D3,(A5)+ORGVPO	LOAD.W	D4,(A5)+ORGVLG	SWAP.W	D4	LOAD.W	D4,#LGREGLE	LIB	?DRMATRIX	; grise la rgle verticale90$:	POPM.L	D2..D4,A5	RET;---------\\; CALCADRE >;=========/; Calcul la position et les dimensions du grand rectangle; dans la fentre.; in	-; out	(A6)+OPBIG?.W	coin sup/gauche;	(A6)+ODBIG?.W	dimensions;	(A6)+ODGRA?.W	dimensions pour graphique; mod	D7.WCALCADRE:	PUSHM.L	D3,D4	LOAD.W	D7,#ERDIOUT	; D7 <-- fentre trop petite	LOAD.W	D3,(A0)+ODFFDX	SUB.W	D3,#MARGX+(GCIMX+GCICX/2+GCIMX)*3+MARGX+MARGX	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X	LOAD.W	(A6)+ODBIGX,D3	LOAD.W	D3,(A0)+ODFFDY	SUB.W	D3,#MARGY+MARGY	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	AND.B	D3,#B'11111110	; D3 <-- modulo 2 en Y	LOAD.W	(A6)+ODBIGY,D3	LOAD.W	D3,#MARGX+(GCIMX+GCICX/2+GCIMX)*3+MARGX	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X	LOAD.W	(A6)+OPBIGX,D3	LOAD.W	D3,#MARGY	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	AND.B	D3,#B'11111110	; D3 <-- modulo 2 en Y	LOAD.W	(A6)+OPBIGY,D3	LOAD.W	D3,(A6)+ODBIGX	SUB.W	D3,#LGREGLE	LOAD.W	(A6)+ODGRAX,D3	LOAD.W	D3,(A6)+ODBIGY	SUB.W	D3,#LGREGLE	LOAD.W	(A6)+ODGRAY,D3	POPM.L	D3,D4	RET	.END