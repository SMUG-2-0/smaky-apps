	.SBTTL	GRAMISC;--------\\; STOPKEY >;========/; Vrifie s'il faut arrter d'urgence.; in	-; out	D7.W	ok/arrt; mod	D7.WSTOPKEY:	PUSH.L	D310$:	LIB	?IFCAR		; une touche presse ?	JUMP',NE 80$		; non => 80$	LOAD.W	D7,#1		; D7 <-- arrt d'urgence	COMP.W	D3,#END	JUMP',EQ 90$	COMP.W	D3,#F0	JUMP',EQ 90$	COMP.W	D3,#F0+SHIFT	JUMP',EQ 90$	COMP.W	D3,#SPACE	JUMP',EQ 90$	JUMP	10$80$:	CLR.W	D7		; D7 <-- on continue90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs LIB,?EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>90$:	POP.L	A3	RET;--------\\; PUTANUM >;--------/; Met un nombre dcimal dans un buffer.; in	D4.L	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;--------/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSHM.L	D2,D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	SL.L	D4,#1	LOAD.L	D2,D4	SL.L	D4,#2	ADD.L	D4,D2		; D4 <-- pousse d'un digit (*10)	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POPM.L	D2,D3	RET;--------\\; MMENU   >;========/; Attend un choix selon un mmenu.; in	A3.L	^mmenu;	D3.W	case initiale; out	D3.W	case choisie;	D7.W	erreur; mod	D3.L, D7.WMMENU:	LIB	?MMENU		; choix selon mmenu ...	RET;--------\\; RGMOUSE >;========/; Dessine la position de la souris dans les rgles.; in	D4.L	position de la souris; out	-; mod	D7.WRGMOUSE:	PUSHM.L	D2..D4,A5	TEST.B	(A6)+OREGLE	; rgles prsentes ?	JUMP',F 90$		; non => 90$				; oui =>	LOAD.L	A5,#(A6)+ORGVAR	LOAD.L	D2,D4		; D2 <-- position (y;x)	CLR.L	D4		; D4 <-- efface les flches	LOAD.W	D3,(A5)+ORGHPO+2	COMP.W	D2,D3		; trop  gauche ?	JUMP',LO 60$	ADD.W	D3,(A5)+ORGHLG	COMP.W	D2,D3		; trop  droite ?	JUMP',HS 60$	SWAP.W	D2	LOAD.W	D3,(A5)+ORGVPO+0	COMP.W	D2,D3		; trop en haut ?	JUMP',LO 60$	ADD.W	D3,(A5)+ORGVLG	COMP.W	D2,D3		; trop en bas ?	JUMP',HS 60$	SWAP.W	D2	LOAD.L	D4,D2		; D4 <-- position (y;x)60$:	SCROLL_	RMOUSE		; dplace les flches dans les rgles90$:	POPM.L	D2..D4,A5	RET;---------\\; ERGMOUSE >;=========/; Efface la position de la souris dans les rgles.; in	-; out	-; mod	D7.WERGMOUSE:	PUSHM.L	D4,A5	LOAD.L	A5,#(A6)+ORGVAR	CLR.L	D4		; D4 <-- efface	SCROLL_	RMOUSE		; efface les flches dans les rgles	POPM.L	D4,A5	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMOUSE  >;========/; Positionne la souris en (y;x).; in	D4.L	nouvelle position y;x; out	-; mod	D7.WPMOUSE:	PUSHM.L	D3,D4,D6,A4; Ramne la position dans la fentre si elle en sort.	TEST.W	D4		; trop  gauche ?	JUMP',NC 10$	CLR.W	D410$:	COMP.W	D4,(A0)+ODFDX	; trop  droite ?	JUMP',LT 15$	LOAD.W	D4,(A0)+ODFDX	DEC.W	D415$:	SWAP.W	D4	TEST.W	D4		; trop en haut ?	JUMP',NC 20$	CLR.W	D420$:	COMP.W	D4,(A0)+ODFDY	; trop en bas ?	JUMP',LT 25$	LOAD.W	D4,(A0)+ODFDY	DEC.W	D425$:	SWAP.W	D4; Calcul la position absolue dans le grand bitmap $DIS_0.	ADD.W	D4,(A0)+ODFX	SWAP.W	D4	ADD.W	D4,(A0)+ODFY	SWAP.W	D4		; D4 <-- position dans $DIS_0 !; Envoie la commande secrte et mystrieuse de positionnement. 	LOAD.L	A4,#(A6)+OBUDIS+1	LOAD.B	(A4)+0,#'P	; <P>	LOAD.L	(A4)+1,D4	; <yy> <xx>	CLR.B	(A4)+5	LOAD.W	D3,#TYPIO	; D3 <-- type du driver souris	LIB	?GCHMOU		; D6 <-- canal souris	FOS	?COMMAND	POPM.L	D3,D4,D6,A4	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; ATTENTION:	Le fait d'crire directement dans le descripteur;		de la fentre fait que la trame est inverse;		entre le Smaky 8 et 100 (gauche <--> droite) !;		Il ne faut donc utiliser que des trames simples;		(pas de hachures par exemple).; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	RET;--------\\; CCMO    >;========/; Enlve la souris.; in	-; out	-; mod	D7.WCCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',T 90$	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	SET.B	(A6)+OCCMO90$:	POP.W	D3	RET;--------\\; SCMO    >;========/; Remet la souris.; in	-; out	-; mod	D7.WSCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',F 90$	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	CLR.B	(A6)+OCCMO90$:	POP.W	D3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	-; out	-; mod	D7.WAFMENU:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#R16"TXMENU	LIB	?AFMENU	POPM.L	D3,D4,A3	RET;--------\\; DETICH  >;========/; Dtecte dans quelle petite image est la souris.; in	D4.L	position de la souris; out	D2.W	rang;	D7.W	erreur; mod	D2.L, D7.WDETICH:	PUSHM.L	D0,D1,D3,D4	LOAD.L	D1,D4		; D1 <-- position de la souris	CLR.W	D2	CLR.W	D7		; D7 <-- trouv10$:	CALL	POSICH		; D3/D4 <-- pos/dim	LOAD.W	D0,D1	SUB.W	D0,D3		; trop  gauche ?	JUMP',LO 50$	COMP.W	D0,D4		; trop  droite ?	JUMP',HS 50$	LOAD.L	D0,D1	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	SUB.W	D0,D3		; trop en haut ?	JUMP',LO 50$	COMP.W	D0,D4		; trop en bas ?	JUMP',LO 90$50$:	INC.W	D2	COMP.W	D2,#ICHNBX*ICHNBY	JUMP,LO 10$	LOAD.W	D2,#-1		; D2 <-- rang impossible	LOAD.W	D7,#ERGRAPH	; D7 <-- pas trouv90$:	POPM.L	D0,D1,D3,D4	RET;--------\\; INVICH  >;========/; Inverse une petite image.; in	D2.W	rang; out	-; mod	D7.WINVICH:	PUSHM.L	D2..D4	COMP.W	D2,#-1	JUMP',EQ 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	POSICH		; D3/D4 <-- pos/dim	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#3	SWAP.W	D4	SUB.W	D4,#3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX90$:	POPM.L	D2..D4	RET;--------\\; POSICH  >;--------/; Donne la position et les dimensions d'une petite image.; in	D2.W	rang; out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.LPOSICH:	PUSH.L	D2	AND.L	D2,#H'FFFF	DIV.WU	D2,#ICHNBX	LOAD.W	D3,D2	MUL.WU	D3,#ICHDIMY+16	ADD.W	D3,#ICHPOSY	SWAP.W	D3	SWAP.W	D2	MUL.WU	D2,#ICHDIMX+16	ADD.W	D2,#ICHPOSX	LOAD.W	D3,D2	LOAD.W	D2,(A0)+ODFDX	SUB.W	D2,#640	JUMP',LE 30$	SR.W	D2,#1	ADD.W	D3,D230$:	SWAP.W	D3	LOAD.W	D2,(A0)+ODFDY	SUB.W	D2,#340	JUMP',LE 40$	SR.W	D2,#1	ADD.W	D3,D240$:	SWAP.W	D3	LOAD.W	D4,#ICHDIMY	SWAP.W	D4	LOAD.W	D4,#ICHDIMX	POP.L	D2	RET;--------\\; AFIMAGE >;========/; Affiche une image dans la fentre.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie suprieure gauche.; in	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WAFIMAGE:	PUSHM.L	D0,D1,D3,D4,D6,A1..A4	LIB	?AFTIM	.B	NOCURS	.B	EOP	.B	0	.EVEN	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE 90$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE 84$	LOAD.L	A4,A2	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$	COMP.B	(A2)+OIMTYP,#H'82 ; image du LAMI ?	JUMP,NE 20$		; non => 20$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute la stupide en-tte de 256 bytes !	JUMP,NE 82$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$20$:	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE 82$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP,NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP,NE 80$	JUMP	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP,NE 80$	LOAD.L	A3,A1	GRA_	DECOIMA		; dcode l'image ...	JUMP,NE 80$35$:	LOAD.L	A3,A2		; A3 <-- prend buffer en-tte pour STRING	LOAD.W	D3,D0	SR.W	D3,#3	LOAD.W	(A3)+10,D3	; source: <ii>	CLR.W	(A3)+20		; destination: <ii>	LIB	?GETDIM		; D4 <-- dimensions de la fentre	COMP.W	D0,D4		; image trop large ?	JUMP,HI 50$		; oui => 50$	CLR.W	(A3)+2		; source: <xx>	LOAD.W	(A3)+22,D0	; image: <dxx>	SUB.W	D4,D0	SR.W	D4,#1	LOAD.W	(A3)+12,D4	; destination: <xx>	JUMP	55$50$:	CLR.W	(A3)+2		; source: <xx>	CLR.W	(A3)+12		; destination: <xx>	LOAD.W	(A3)+22,D4	; image: <dxx>55$:	SWAP.W	D4	COMP.W	D1,D4		; image trop haute ?	JUMP,HI 60$		; oui => 60$	CLR.W	(A3)+4		; source: <yy>	LOAD.W	(A3)+24,D1	; image: <dyy>	SUB.W	D4,D1	SR.W	D4,#1	LOAD.W	(A3)+14,D4	; destination: <yy>	JUMP	65$60$:	CLR.W	(A3)+4		; source: <yy>	CLR.W	(A3)+14		; destination: <yy>	LOAD.W	(A3)+24,D4	; image: <dyy>65$:	LOAD.W	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+6,A1	; source: <pppp>	CLR.L	(A3)+16		; destination: <pppp>	LOAD.B	(A3)+26,#SETDOT	; image: <mode>	LOAD.W	D3,#1+26	; D3 <-- longueur	LIB	?STRING		; affiche l'image	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D784$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POP.W	D790$:	POPM.L	D0,D1,D3,D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CONVMPX >;========/; Converti un nombre horizontal en millimtres --> en points.; in	D4.W	nombre [mm]; out	D4.W	nombre [p]; mod	D3.W, D4.LCONVMPX:	MUL.WA	D4,#10000	LOAD.W	D3,(A6)+OMMX	CALL	DIVD4D3	AND.L	D4,#H'FFFF	LOAD.W	D3,(A6)+OFACX	JUMP'	DIVD4D3;--------\\; CONVMPY >;========/; Converti un nombre vertical en millimtres --> en points.; in	D4.W	nombre [mm]; out	D4.W	nombre [p]; mod	D3.W, D4.LCONVMPY:	MUL.WA	D4,#10000	LOAD.W	D3,(A6)+OMMY	CALL	DIVD4D3	AND.L	D4,#H'FFFF	LOAD.W	D3,(A6)+OFACY	JUMP'	DIVD4D3;--------\\; CONVPMX >;========/; Converti un nombre horizontal en points --> en millimtres.; in	D4.W	nombre [p]; out	D4.W	nombre [mm]; mod	D3.W, D4.LCONVPMX:	MUL.WA	D4,(A6)+OFACX	MUL.WA	D4,(A6)+OMMX	LOAD.W	D3,#10000	JUMP'	DIVD4D3;--------\\; CONVPMY >;========/; Converti un nombre vertical en points --> en millimtres.; in	D4.W	nombre [p]; out	D4.W	nombre [mm]; mod	D3.W, D4.LCONVPMY:	MUL.WA	D4,(A6)+OFACY	MUL.WA	D4,(A6)+OMMY	LOAD.W	D3,#10000;	JUMP'	DIVD4D3;--------\\; DIVD4D3 >;--------/; Divise D4 par D3 avec un arrondi.; in	D4.L	nombre  diviser (+/-);	D3.W	diviseur (+); out	D4.L	reste/div; mod	D4.LDIVD4D3:	PUSH.W	D3	DIV.WA	D4,D3	JUMP',NS 40$	SR.W	D3,#1	SWAP.W	D4	COMP.W	D4,D3	JUMP',LE 20$	SWAP.W	D4	INC.W	D4		; D4 <-- arrondi (+1)	POP.W	D3	RET20$:	SWAP.W	D4	POP.W	D3	RET40$:	SR.W	D3,#1	SWAP.W	D4		; D4 <-- reste ngatif	NEG.W	D4		; D4 <-- reste positif	COMP.W	D4,D3	JUMP',LE 60$	SWAP.W	D4	DEC.W	D4		; D4 <-- arrondi (-1)	POP.W	D3	RET60$:	SWAP.W	D4	POP.W	D3	RET	.END