	.SBTTL	GRADBOXT;---------\\; DBOXOPEN >;---------/; Ouvre une dbox.; in	A2.L	table;	D2.W	mode; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WDBOXOPEN:	CALL'	DBOXOPEN1	DBOX_	OPEN		; ouvre la dbox	RETDBOXOPEN1:	CALL	ERGMOUSE	; efface les flches dans les rgles	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	RET;----------\\; DBOXCLOSE >;----------/; Ferme une dbox.; in	D5.L	canal; out	D7.W	erreur; mod	D7.WDBOXCLOSE:	DBOX_	CLOSE		; ferme la dboxDBOXCLOSE1:	CALL	AFMENU		; refait les soft-keys	RET;---------\\; DBOXGREY >;=========/; Affiche quelques objets en gris.; in	-; out	-; mod	D7.WDBOXGREY:	PUSHM.L	D1..D4,A4	LOAD.L	A4,(SP)+(4*5)	; A4 <-- adresse de retour	LOAD.W	D2,#2^BDBGCGREY	LOAD.B	D2,(A4+)	; D2 <-- rang premier objet	LOAD.B	D1,(A4+)	; D1 <-- nb d'objets	LOAD.L	(SP)+(4*5),A4	; corrige l'adresse de retour10$:	DBOX_	GETCO	INC.B	D2	DEC.B	D1	JUMP,NE 10$	POPM.L	D1..D4,A4	RET;---------\\; DBOXFULL >;=========/; Affiche quelques objets en normal (non gris).; in	-; out	-; mod	D7.WDBOXFULL:	PUSHM.L	D1..D4,A4	LOAD.L	A4,(SP)+(4*5)	; A4 <-- adresse de retour	LOAD.W	D2,#2^BDBGCFULL	LOAD.B	D2,(A4+)	; D2 <-- rang premier objet	LOAD.B	D1,(A4+)	; D1 <-- nb d'objets	LOAD.L	(SP)+(4*5),A4	; corrige l'adresse de retour10$:	DBOX_	GETCO	INC.B	D2	DEC.B	D1	JUMP,NE 10$	POPM.L	D1..D4,A4	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET; Tables; ------TDBOX_PREND:	.B	LDBOX_PREND	.B	ODBSQUARE,BDBGRA	.ASCIZ	" prend le graphique"	.B	ODBCR	.B	ODBSQUARE,BDBDEF	.ASCIZ	" prend les dfinitions"	.B	ODBCRLDBOX_PREND	=	.-TDBOX_PREND-1	.EVENTDBOX_SAUVE:	.B	LDBOX_SAUVE	.B	ODBSQUARE,BDBIMA	.ASCIZ	" sauve l'image"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"   ne sauve plus les dfinitions" @AD@	.B	ODBCR	.B	ODBSQUARE,BDBGRA	.ASCIZ	" sauve le graphique"	.B	ODBCRLDBOX_SAUVE	=	.-TDBOX_SAUVE-1	.EVENTDBOX_DEF:	.W	10$-TDBOX_DEF	.W	20$-TDBOX_DEF	.W	0,010$:	.B	ODBCR	.B	ODBSQUARE,0	.ASCIZ	" ne redessine pas chaque fois"	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEF:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DEF	.W	F1,F2,F3,CR,0		DOKF1-TKEY_DEF	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEF	.W	0TDBOX_XY:	.W	10$-TDBOX_XY	.W	20$-TDBOX_XY	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Dfinition de l'abscisse et de l'ordonne :"	.B	ODBCR,ODBCR	.B	ODBCIRCLE,BXYNORM	.ASCIZ	" mode normal "	.B	ODBTEXT	.ASCII	"     "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOXYNORM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	ODBCR,ODBCR	.B	ODBCIRCLE,BXYINV	.ASCIZ	" mode inverse"	.B	ODBTEXT	.ASCII	"     "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOXYINV	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	ODBCR,ODBCR	.B	ODBSQUARE,BXYINVX	.ASCIZ	" axe X invers"	.B	ODBCR	.B	ODBSQUARE,BXYINVY	.ASCIZ	" axe Y invers"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVEN