	.SBTTL	GRAIOBDBAUTO	=	15		; mode de sauvetage automatiqueBDBDEF	=	14		; les dfinitionsBDBIMA	=	13		; l'imageBDBGRA	=	12		; le graphiqueBDBNMAJ	=	11		; touche (MET A JOUR) grisePREND:	CLR.B	(A6)+OBUFINPRENDL:	LOAD.L	A3,#(A6)+OBUFIN	CALL	DBOXEDITI	JUMP,NE _ERROR	COMP.W	D3,#F0	JUMP,EQ _LOOP	LOAD.W	D5,D4		; D5 <-- fanions	LOAD.W	D0,#1		; D0 <-- avant de reprendre	CALL	DBOXSAVE	; sauve si ncessaire le dessin actuel	JUMP',EQ PRENDF		; ok => PRENDF	COMP.W	D7,#1		; (ANNULE) ?	JUMP,EQ _LOOP		; oui => LOOP	JUMP	_ERROR		; non => ERRORPRENDF:	CALL	WAITMOUSE	; met le sablier	CALL	IFPNAME		; pointeur direct ?	JUMP,EQ 70$		; oui => 70$	LOAD.L	A4,#R16"TEXGRA	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .IMAGE	TEST.L	D5:#BDBGRA	; prend le graphique ?	JUMP,BC 50$		; non => 50$	LOAD.W	D3,#2^BOPRD	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le graphique	POPM.L	D0	JUMP',EQ 20$	PUSH.W	D7	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	PRENDL20$:	CALL	WAITDBOX	; met la dbox "attendez..."	LOAD.L	D4,#-1	LOAD.L	D3,D4	FOS	?SPOS	LOAD.L	D2,D4		; D2 <-- longueur	CLR.L	D4	CLR.L	D3	FOS	?SPOS		; revient au dbut	JUMP',NE 40$	CALL	GIVPGRA		; rend mmoire pour graphique	LOAD.L	D4,D2	INC.L	D4		; D4 <-- +1 pour <0> terminateur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour graphique	JUMP',NE 40$	LOAD.L	(A6)+OPGRA,A4	LOAD.L	D4,D2	FOS	?RDBYTE		; lit tout le graphique	JUMP',NE 40$	CLR.B	(A4)+(D4.L)	; met le terminateur40$:	PUSH.W	D7	FOS	?CLOSE		; ferme le graphique	POP.W	D7	JUMP,NE 90$50$:	TEST.L	D5:#BDBDEF	; prend les dfinitions ?	JUMP',BC 60$		; non => 60$	LOAD.L	A3,#(A6)+OBUFIN	CLR.W	D2		; D2 <-- rang	CALL	INDEF		; lit le fichier .DGRA60$:	CALL	INIDIM	CALL	NORMDBOX	; enlve la dbox "attendez..."	LOAD.L	A3,#(A6)+OBUFIN	CALL	SAVFILE		; OBUNAME <-- nom	CALL	_DESINFFILE	; affiche le nom dans les infos	CALL	REFAIT		; dessine le graphique	SET.B	(A6)+OGAJ	; le graphique est  jour	JUMP	_LOOP70$:	CALL	GIVPGRA		; rend mmoire pour graphique	LOAD.L	(A6)+OPGRA,A4	SET.B	(A6)+OPPGRA	; signal pointeur direct	JUMP	60$90$:	CALL	NORMDBOX	; enlve la dbox "attendez..."	JUMP	_ERRORSAUVE:	CLR.W	D2		; D2 <-- mode manuel	CALL	SAUVETOUT	; sauve tout le graphique	JUMP,NE _ERROR	JUMP	_LOOP;----------\\; SAUVETOUT >;==========/; Sauve tout le graphique.; in	D2.W	mode; out	D7.W	erreur; mod	D7.WSAUVETOUT:	PUSHM.L	D1..D5,A3,A4	LOAD.L	A3,#(A6)+OBUFOUT	CALL	GETFILE		; OBUFOUT <-- OBUNAME	TEST.L	(A6)+OPGRA	; graphique existe ?	JUMP',EQ 10$		; non => 10$	TEST.B	(A6)+OGAJ	; mise  jour ncessaire ?	JUMP',F 11$		; oui => 11$10$:	TSET.L	D2:#BDBNMAJ	; D2 <-- touche (MET A JOUR) grise11$:	LOAD.L	A3,#(A6)+OBUFOUT	CALL	DBOXEDITO	; dite le nom ...	JUMP,NE 95$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ 95$		; non => 95$	LOAD.W	D1,D3		; D1 <-- F1/F4	TEST.L	D2:#BDBIMA	; sauve l'image ?	JUMP',BC 30$		; non => 30$	CALL	OUTIMA		; oui => crit le fichier .IMAGE	JUMP',NE 90$30$:	TEST.L	D2:#BDBDEF	; sauve les dfinitions ?	JUMP',BC 40$		; non => 40$	CALL	OUTDEF		; oui => crit le fichier .DGRA	JUMP',NE 90$40$:	TEST.L	D2:#BDBGRA	; sauve le graphique ?	JUMP',BC 90$		; non => 90$	CALL	OUTGRA		; oui => crit le fichier .GRAPH;	JUMP',NE 90$90$:	COMP.W	D7,#1		; rponse "non" ?	JUMP,EQ 10$		; oui => 10$	TEST.W	D7		; ok =	JUMP',NE 95$		; non => 90$	SET.B	(A6)+OGAJ	; le graphique est  jour	LOAD.L	A3,#(A6)+OBUFOUT	CALL	SAVFILE		; OBUNAME <-- nom	CALL	_DESINFFILE	; affiche le nom dans les infos	CLR.W	D7		; D7 <-- ok95$:	POPM.L	D1..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; OUTIMA  >;========/; Ecrit dans le fichier .IMAGE toute l'image.; in	A3.L	^nom du fichier;	D1.W	F1/F4 (SAUVE/MET A JOUR);	D2.L	mode; out	D7.W	erreur; mod	D7.WOUTIMA:	PUSHM.L	D3..D6,A3,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXIMA	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier avec extension20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	PUSH.L	D0	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	POPM.L	D0	JUMP,EQ 40$		; ok => 40$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	TEST.L	D2:#BDBAUTO	; sauvetage automatique ?	JUMP',BS 30$		; oui => 30$	COMP.W	D1,#F4		; touche (MET A JOUR) ?	JUMP',EQ 30$		; oui => 30$	CALL	NORMMOUSE	; remet la flche	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE 90$	LOAD.W	D7,#1		; D7 <-- rponse "non"	COMP.W	D3,#'O	JUMP,NE 90$30$:	PUSH.L	D0	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	POPM.L	D0	JUMP,NE 90$	JUMP	20$40$:	CALL	WAITMOUSE	; met le sablier	LOAD.L	D3,(A6)+OPBIG	LOAD.L	D4,(A6)+ODGRA	AND.L	D4,#H'FFFEFFF8	; D4 <-- modulos 2 en Y et 8 en X !	LIB	?CREWDO	JUMP',NE 90$	LIB	?USEWDO	CALL	CCMO		; enlve la souris	CLR.W	D3		; D3 <-- la swdo utilise	LIB	?PFDUMP		; crit le fichier ...	PUSH.W	D7	CALL	SCMO		; remet la souris	LOAD.W	D4,D5	CLR.W	D5	LIB	?USEWDO	LOAD.W	D5,D4	LIB	?KILWDO	POP.W	D790$:	POPM.L	D3..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; OUTGRA  >;========/; Ecrit dans le fichier .GRAPH tout le graphique.; in	A3.L	^nom du fichier;	D1.W	F1/F4 (SAUVE/MET A JOUR);	D2.L	mode; out	D7.W	erreur; mod	D7.WOUTGRA:	PUSHM.L	D3..D6,A3,A4	CLR.W	D7		; D7 <-- ok	TEST.L	(A6)+OPGRA	JUMP,EQ 90$	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXGRA	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier avec extension20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	PUSH.L	D0	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	POPM.L	D0	JUMP,EQ 40$		; ok => 40$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	TEST.L	D2:#BDBAUTO	; sauvetage automatique ?	JUMP',BS 30$		; oui => 30$	COMP.W	D1,#F4		; touche (MET A JOUR) ?	JUMP',EQ 30$		; oui => 30$	CALL	NORMMOUSE	; remet la flche	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE 90$	LOAD.W	D7,#1		; D7 <-- rponse "non"	COMP.W	D3,#'O	JUMP,NE 90$30$:	PUSH.L	D0	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	POPM.L	D0	JUMP,NE 90$	JUMP	20$40$:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	POPM.L	D0	JUMP',NE 90$	LOAD.L	A4,(A6)+OPGRA	LOAD.L	A3,A4	LOAD.L	D4,#-160$:	INC.L	D4		; D4 <-- longueur	TEST.B	(A3+)	JUMP,NE 60$	FOS	?WRBYTE		; crit le data	JUMP',NE 80$	FOS	?CLOSE		; ferme le fichier	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE		; ferme en cas d'erreur	POP.W	D790$:	POPM.L	D3..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; OUTDEF  >;========/; Ecrit dans le fichier .DGRA toutes les dfinitions.; in	A3.L	^nom du fichier .IMAGE; out	D7.W	erreur; mod	D7.WOUTDEF:	CLR.W	D7	; n'crit plus les dfinitions !!	RET;@AD@.if	0	PUSHM.L	D3..D6,A3,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXDEF	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier avec extension	PUSH.L	D0	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit si existe dj	POPM.L	D0	LOAD.L	D3,#DEFATT	TCLR.L	D3:#BATTL	; ne met pas l'attribut "L" !	LOAD.W	D4,#TYPRAND	PUSH.L	D0	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	POPM.L	D0	JUMP',NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	POPM.L	D0	JUMP',NE 90$	LOAD.L	A4,#(A6)+ODEF	LOAD.L	D4,#LDEF	FOS	?WRBYTE		; crit le data	JUMP',NE 80$	FOS	?CLOSE		; ferme le fichier	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE		; ferme en cas d'erreur	POP.W	D790$:	POPM.L	D3..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET.endif;--------\\; INDEF   >;========/; Lit dans le fichier .DGRA toutes les dfinitions.; in	A3.L	^nom du fichier;	D2.W	rang; out	D7.W	erreur; mod	D7.WINDEF:	PUSHM.L	D3,D4,D6,A1..A4	LOAD.B	D3,(A6)+OGRAPHE	CALL	INVICONE	; teint l'icne	LOAD.L	A1,#(A6)+OOBUGC	LOAD.L	A2,#(A6)+OBUGC	LOAD.W	D4,#((LGGC*MAXGC)/2)-110$:	LOAD.W	(A1+),(A2+)	; OOBUGC <-- OBUGC	DECJ.W,NMO D4,10$; Lit le fichier .DGRA dans les variables.	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture "systme"	LOAD.L	A4,#R16"TDEFCH	COMP.L	A3,A4	JUMP',EQ 15$	LOAD.L	A4,#R16"TEXDEF	CALL	ADDEXT	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture normal15$:	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	POPM.L	D0	JUMP,NE 90$	CLR.L	D4	LOAD.W	D4,D2	JUMP',EQ 20$	MUL.WU	D4,#OLDLDEF	; D4 <-- position  atteindre ; @AD@	CLR.W	D3	FOS	?SPOS	JUMP',NE 30$20$:	LOAD.L	A4,#(A6)+ODEF	LOAD.L	D4,#OLDLDEF ; @AD@	FOS	?RDBYTE		; lit le data30$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7	JUMP,NE 90$; Corrige les donnes lues (LDEF dpend de MAXXY et cette dernire valeur a t change !!); Il faut dplacer OZEMIN, OZEMAX, OGAFAN et OFILIY; @AD@	LOAD.L	D3,(A6)+ODEF+OLDZEMIN+4	; OZEMIN	LOAD.L	(A6)+OZEMIN+4,D3	LOAD.L	D3,(A6)+ODEF+OLDZEMIN	LOAD.L	(A6)+OZEMIN,D3	LOAD.L	D3,(A6)+ODEF+OLDZEMAX+4	; OZEMAX	LOAD.L	(A6)+OZEMAX+4,D3	LOAD.L	D3,(A6)+ODEF+OLDZEMAX	LOAD.L	(A6)+OZEMAX,D3	LOAD.L	D3,(A6)+ODEF+OLDGAFAN	; OGAFAN	LOAD.L	(A6)+OGAFAN,D3	LOAD.L	A1,#(A6)+ODEF+OLDFILIY	; OFILIY	LOAD.L	A2,#(A6)+OFILIY	LOAD.L	D3,#OLDMAXXY+2-1	ADD.L	A1,D3	ADD.L	A2,D334$:	LOAD.B	(-A2),(-A1)	DECJ.W,NMO D3,34$	LOAD.B	(A6)+OFILIX+OLDMAXXY,-1	; initialise correctement la fin des filtres	LOAD.B	(A6)+OFILIY+OLDMAXXY,-1; Initialise le programme en fonction des variables lues.	LOAD.L	A1,#(A6)+OOBUGC	LOAD.L	A2,#(A6)+OBUGC	LOAD.W	D4,#((LGGC*MAXGC)/2)-135$:	LOAD.W	D3,(A1)	LOAD.W	(A1+),(A2)	; OBUGC <--> OOBUGC	LOAD.W	(A2+),D3	DECJ.W,NMO D4,35$	LOAD.L	A1,#(A6)+OOBUGC	LOAD.L	A2,#(A6)+OBUGC	LOAD.W	D4,#MAXGC-140$:	TEST.B	(A1)+OGCFLG:#BGCUSE	JUMP',BC 45$	CLR.B	(A1)+OGCCOD	CLR.B	(A2)+OGCCOD	LOAD.L	D3,(A1)+OGCCOD	COMP.L	D3,(A2)+OGCCOD	; mme gencar ?	JUMP',EQ 48$		; oui => 48$				; non =>	PUSHM.L	D4,A2..A4	LOAD.L	(A2)+OGCCOD,D3	LOAD.L	A4,A2		; A4 <-- ^gencar	LOAD.L	A3,#(A6)+OBUGC	; A3 <-- ^buffer des gencars	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A2,A0		; A2 <-- ^description de la fentre	DGENC_	NEW		; charge le nouveau gencar	POPM.L	D4,A2..A4	JUMP'	48$45$:	TEST.B	(A2)+OGCFLG:#BGCUSE	JUMP',BC 48$	PUSHM.L	D4,A2..A4	LOAD.L	A4,A2		; A4 <-- ^gencar	LOAD.L	A3,#(A6)+OBUGC	; A3 <-- ^buffer des gencars	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A2,A0		; A2 <-- ^description de la fentre	DGENC_	KILL		; libre le gencar inutile	POPM.L	D4,A2..A448$:	LOAD.L	A1,#(A1)+LGGC	LOAD.L	A2,#(A2)+LGGC	DECJ.W,NMO D4,40$	CLR.W	D7		; D7 <-- ok90$:	PUSH.W	D7	LOAD.B	D3,(A6)+OGRAPHE	CALL	INVICONE	; allume l'icne	POP.W	D7	POPM.L	D3,D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; INIDIM  >;========/; Initialise les dimensions physiques totales du tableau..; in	-; out	-; mod	D7.WINIDIM:	PUSHM.L	D4,A4	CALL	GETALL		; cherche dimensions gnrales	TEST.W	(A6)+OFILIX	; qq chose dans les listes du filtre ?	JUMP',NE 20$		; oui => 20$				; non =>	CLR.B	(A6)+OFIXY	CALL	DBFIADDA	; OFILTX <-- tout	SET.B	(A6)+OFIXY	CALL	DBFIADDA	; OFILTY <-- tout	CALL	DBFIPUT		; OFILI[X,Y] <-- OFILT[X,Y]20$:	LOAD.L	A4,#(A6)+OFILIX	LOAD.W	D4,#MAXXY-122$:	COMP.B	(A4+),#-1	; filtre termin correctement ?	JUMP',EQ 23$		; oui => 23$	DECJ.W,NMO D4,22$	LOAD.B	(A4),#-1	; met le terminateur "oubli" !23$:	LOAD.L	A4,#(A6)+OFILIY	LOAD.W	D4,#MAXXY-125$:	COMP.B	(A4+),#-1	; filtre termin correctement ?	JUMP',EQ 50$		; oui => 50$	DECJ.W,NMO D4,25$	LOAD.B	(A4),#-1	; met le terminateur "oubli" !50$:	TEST.W	(A6)+OPEEL	JUMP',NE 52$	LOAD.W	(A6)+OPEEL,#5052$:	TEST.W	(A6)+OPEEP	JUMP',NE 54$	LOAD.W	(A6)+OPEEP,#2554$:	TEST.L	(A6)+OGAECH+0	JUMP',NE 60$	TEST.L	(A6)+OGAECH+4	JUMP',NE 60$	LOAD.L	(A6)+OGAECH+0,#UN_MSPFP64	LOAD.L	(A6)+OGAECH+4,#UN_LSPFP6460$:	POPM.L	D4,A4	RET;--------\\; SAVFILE >;========/; Sauve un nom de fichier dans OBUNAME.; in	A3.L	^nom; out	-; mod	D7.WSAVFILE:	PUSHM.L	A3,A4	CLR.B	(A6)+OBUNAME	; OBUNAME <-- pas de nom	CALL	IFPNAME		; pointeur direct ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	A4,#(A6)+OBUNAME10$:	LOAD.B	(A4+),(A3+)	; OBUNAME <-- nom	JUMP',EQ 90$	COMP.B	(A4)-1,#CR	JUMP,NE 10$	CLR.B	(A4)-190$:	POPM.L	A3,A4	RET;--------\\; GETFILE >;========/; Prend le nom de fichier dans OBUNAME.; in	A3.L	^buffer; out	-; mod	D7.WGETFILE:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBUNAME10$:	LOAD.B	(A3+),(A4+)	; buffer <-- OBUNAME	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 10$	CLR.B	(A3)-190$:	POPM.L	A3,A4	RET;--------\\; AFFFILE >;========/; Affiche un nom de fichier en minuscules et entre guillemets.; in	A3.L	^nom; out	-; mod	D7.WAFFFILE:	PUSHM.L	D3,A3,A4	LOAD.B	D3,#'"	LIB	?AFCAR20$:	LOAD.B	D3,(A3+)	JUMP',EQ 40$	COMP.B	D3,#CR	JUMP',EQ 40$	COMP.B	D3,#'A	JUMP',LO 30$	COMP.B	D3,#'Z	JUMP',HI 30$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule30$:	LIB	?AFCAR	JUMP	20$40$:	LOAD.B	D3,#'"	LIB	?AFCAR	POPM.L	D3,A3,A4	RET;--------\\; ADDEXT  >;========/; Transfert le nom de fichier dans OBXFILE et force une extension.; in	A3.L	^nom sans extension;	A4.L	^extension  ajouter; out	A3.L	^nom avec extension (dans OBXFILE); mod	D7.W, A3.LADDEXT:	PUSHM.L	D3,A2	LOAD.L	A2,#(A6)+OBXFILE10$:	LOAD.B	(A2+),(A3+)	; OBXFILE <-- nom du fichier	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBXFILE	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	POPM.L	D3,A2	RET;--------\\; IFPNAME >;========/; Vrifie si le nom est un pointeur direct du type "$$^=adresse$".; in	A3.L	^nom; out	A4.L	adresse;	D7.W	erreur; mod	D7.W, A4.LIFPNAME:	PUSHM.L	D4,A3	LOAD.W	D7,#1	COMP.B	(A3+),#'$	JUMP',NE 90$	COMP.B	(A3+),#'$	JUMP',NE 90$	COMP.B	(A3+),#'^	JUMP',NE 90$	COMP.B	(A3+),#'=	JUMP',NE 90$	CLR.L	D430$:	LOAD.B	D3,(A3+)	COMP.B	D3,#'$	JUMP',EQ 40$	SUB.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#16	JUMP',HS 90$	SL.L	D4,#4	OR.B	D4,D3	JUMP	30$40$:	LOAD.L	A4,D4		; A4 <-- adresse	CLR.W	D7		; D7 <-- adresse trouve90$:	POPM.L	D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; GIVPGRA >;========/; Libre la mmoire utilise par le texte du graphique.; in	-; out	-; mod	D7.WGIVPGRA:	PUSHM.L	D1,A4	TEST.L	(A6)+OPGRA	JUMP',EQ 80$	TEST.B	(A6)+OPPGRA	JUMP',NE 80$	LOAD.L	A4,(A6)+OPGRA	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend mmoire pour graphique80$:	CLR.L	(A6)+OPGRA	CLR.B	(A6)+OPPGRA	POPM.L	D1,A4	RET;----------\\; RDSTPRINT >;==========/; Lit le status de l'imprimante. En cas d'erreur, prend; quand mme des valeurs par dfaut !; in	-; out	D7.W	erreur; mod	D7.WRDSTPRINT:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.W	(A6)+OFACX,#5	LOAD.W	(A6)+OFACY,#2	LOAD.W	(A6)+OMMX,#(254000/360)+1 ; 360e d'inch	LOAD.W	(A6)+OMMY,#(254000/144)+1 ; 144e d'inch	LOAD.L	A3,#R16"TPRINT	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre l'imprimante	JUMP,NE 90$	LOAD.W	D3,#TYPPRI	; D3 <-- type imprimante	LOAD.L	D4,#LGPRI0	; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OSTPRI	; A4 <-- ^buffer	FOS	?RSTATUS	JUMP,NE 80$	LOAD.W	D4,(A4)+OPRGLX	SR.W	D4,#3	LOAD.W	(A6)+OFACX,D4	LOAD.W	D4,(A4)+OPRGLY	SR.W	D4,#3	LOAD.W	(A6)+OFACY,D4	LOAD.W	(A6)+OMMX,(A4)+OPRUMX+2	LOAD.W	(A6)+OMMY,(A4)+OPRUMY+280$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'imprimante	POP.W	D790$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET	.END