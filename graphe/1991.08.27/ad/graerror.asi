	.SBTTL	GRAERROR;---------\\; AFFERROR >;=========/; Affiche une erreur quelconque.; in	D7.W	erreur; out	-; mod	-AFFERROR:	PUSHM.L	D3,D4,D7,A3	LOAD.W	D4,D7		; D4 <-- code de l'erreur	COMP.W	D4,#1		; erreur "annule" ?	JUMP,EQ 90$		; oui => 90$	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.B	D3,#BIPERR	LIB	?BEEP		; fait un "mauvais" bruit	LOAD.W	D3,D4	SR.W	D3,#8	COMP.B	D3,#ERGRAPH/H'100 ; erreur interne  GRAPHE ?	JUMP,NE	50$		; non => 50$				; oui =>	LOAD.L	A3,#R16"TAERR20$:	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- saute comme .EVEN	LOAD.L	A3,D3	TEST.W	(A3+)		; fin de la table ?	JUMP',EQ 40$		; oui => 40$	COMP.W	D4,(A3)-2	; erreur trouve ?	JUMP',EQ 40$		; oui => 40$30$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE	30$	JUMP	20$40$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur	JUMP',EQ 80$	TCLR.L	D2:#BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur	JUMP'	80$50$:	LOAD.L	A3,#R16"00$	; A3 <-- ^nom inconnu;;?	TEST.L	(A6)+OPNERR	; nom inconnu ?;;?	JUMP',EQ 52$		; oui => 52$;;?	LOAD.L	A3,(A6)+OPNERR	; A3 <-- ^nom ayant caus l'erreur;;?52$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,D4		; D7 <-- no de l'erreur	DBOX_	MERROR		; affiche l'erreur PSos	JUMP',EQ 80$	TCLR.L	D2:#BDBSAV	; D2 <-- mode	LOAD.W	D7,D4		; D7 <-- no de l'erreur	DBOX_	MERROR		; affiche l'erreur PSos80$:;;?	CLR.L	(A6)+OPNERR	; ne connat plus le nom !	CALL	AFMENU		; remet les soft-keys90$:	POPM.L	D3,D4,D7,A3	RET00$:	.ASCIZ	"?"		; nom vide	.EVENTAERR:	.W	ERGSUTP	.ASCII	" La surface pour le graphique <CR>"	.ASCIZ	" est trop petite !            "	.EVEN	.W	ERGPERS	.ASCII	" Cette vue en perspective <CR>"	.ASCIZ	" n'est pas ralisable !   "	.EVEN	.W	ERGNNEG	.ASCII	" Les nombres ngatifs ne peu- <CR>"	.ASCIZ	" vent pas tre reprsents !  "	.EVEN	.W	ERGPAVA	.ASCII	" Le graphique ne contient <CR>"	.ASCIZ	" pas assez de valeurs !   "	.EVEN	.W	ERGTRVA	.ASCII	" Le graphique contient <CR>"	.ASCIZ	" trop de valeurs !     "	.EVEN	.W	ERGLETG	.ASCIZ	" La lgende est trop grande ! <CR>"	.EVEN	.W	0		; <-- terminateur	.ASCIZ	" Erreur ! "	.EVEN	.END