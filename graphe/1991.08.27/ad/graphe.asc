ns grande fentreODBIGY:	.BLKB	2ODBIGX:	.BLKB	2ODGRA:				; dimensions surface graphiqueODGRAY:	.BLKB	2ODGRAX:	.BLKB	2OMARGG:	.BLKB	2		; marge  gaucheOMARGD:	.BLKB	2		; marge  droiteOMARGH:	.BLKB	2		; marge en hautOMARGB:	.BLKB	2		; marge en basORGVAR:	.BLKB	LRGVAR		; variables des rglesOGAJ:	.BLKB	1		; 1 => graphique  jourORAPIDE:.BLKB	1		; 1 => ne redessine pas chaque foisONEG:	.BLKB	1		; 1 => valeurs ngativesOREGLE:	.BLKB	1		; 1 => rgles prsentesOSIMPLE:.BLKB	1		; 1 => traits/trames simples	.EVENOLICY0:	.BLKB	2		; liste: hauteur premire ligneOLICY1:	.BLKB	2		; liste: hauteurs lignesOLICX0:	.BLKB	2		; liste: largeur premire colonneOLICX1:	.BLKB	2*MAXXY		; liste: largeurs colonnesOLIMY:	.BLKB	2		; liste: marges en YOLIMX:	.BLKB	2		; liste: marges en XOLIMDE:	.BLKB	2		; liste: nb digits partie entireOLIMDF:	.BLKB	2		; liste: nb digits partie fractionnaire				; dbut des dfinitions sauves sur disqueODEF:				; -------------------------------------------OLDDEF=H'5FE ;@AD@OGRAPHE:.BLKB	1		; graphique slectionn	.EVEN	.BLKB	4		; rserveOXYFAN:	.BLKB	4		; mode X-Y: fanionsOPEFAN:	.BLKB	4		; perspective: fanionsOPELG:	.BLKB	2		; perspective: longueur perspectiveOPEAD:	.BLKB	2		; perspective: angle droite perspectiveOPEAG:	.BLKB	2		; perspective: angle gauche perspectiveOPESLG:	.BLKB	2		; perspective: idem temporaireOPESAD:	.BLKB	2		; perspective: idem temporaireOPESAG:	.BLKB	2		; perspective: idem temporaireOPEEL:	.BLKB	2		; prespective camembert: lvationOPEEP:	.BLKB	2		; prespective camembert: paisseur	.BLKB	6		; rserveOZEFAN:	.BLKB	4		; zro: fanionsOZEVAL:	.BLKB	8		; zro: valeur donne dans dbox	.BLKB	10		; rserveOLEFAN:	.BLKB	4		; lgende: fanionsOLEPOS:	.BLKB	4		; lgende: position relleOLEDIM:	.BLKB	4		; lgende: dimensions rellesOLECTR:	.BLKB	4		; lgende: position relative du centre	.BLKB	10		; rserveOECFAN:	.BLKB	4		; chelle: fanions	.BLKB	10		; rserveOTIFAN:	.BLKB	4		; titre: 