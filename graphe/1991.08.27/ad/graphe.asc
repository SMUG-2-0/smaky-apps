%OCMTT:	.BLKB	LCMTT*(MAXXY+1)	; camembert: table des tranchesOCMTF:	.BLKB	LCMTF*(MAXXY+1)*2 ; camembert: table des facesOGAECH:	.BLKB	8		; Gauss: chantillonageOGAMIN:	.BLKB	8		; Gauss: minimumOGAMAX:	.BLKB	8		; Gauss: maximumOGANBE:	.BLKB	2		; Gauss: nb d'chantillonsOGALEY:	.BLKB	32		; Gauss: texte lgende en YOOBUGC:	.BLKB	LGGC*MAXGC	; ancien OBUGCOGCLIST:.BLKB	MAXGENC*3	; liste des gencars contenus sur disqueOBUNAME:.BLKB	LBUFILE		; nom du graphe en mmoireOBUFIN:	.BLKB	LBUFILE		; nom du fichier en entreOBUFOUT:.BLKB	LBUFILE		; nom du fichier en sortieOBXFILE:.BLKB	LBUFILE		; nom du fichier avec extensionOTDOP:	.BLKB	2		; TDEF: opration sur un pointOTDLG:	.BLKB	2		; TDEF: dimension d'un "point"OPLDEF:	.BLKB	4		; ^trait/trame/point utilisOSTPRI:	.BLKB	LGPRI0		; status de l'imprimanteOFACX:	.BLKB	2		; facteur rduction en XOFACY:	.BLKB	2		; facteur rduction en YOMMX:	.BLKB	2		; nb de 1/10 de um pour un point en XOMMY:	.BLKB	2		; nb de 1/10 de um pour un point en YLGVAR:; Programme; ---------	.LOC	0	.INS	GRAMATRIX.ASI; Erreurs fatales; ---------------TXERFATREV:	.ASCIZ	"La rvision du systme est incompatible"TXERFATMEM:	.ASCIZ	"Problme avec la mmoire"TXERFATDIS:	.ASCIZ	"Driver d'cran incompatible"TXERFATGRA:	.ASCIZ	"Module GRA incompatible"TXERFATTXT:	.ASCIZ	"Erreur avec le gencar NEF11"TXERFATICO:	.ASCIZ	"Erreur avec le gencar IDP20"TXERFATDMA:	.ASCIZ	"Dfinition manquante dans module DESSIN"; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMDGENC:	.ASCIZ	"DGENC"NMDESSIN:	.ASCIZ	"DESSIN"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMSPLINE:	.ASCIZ	"SPLINE"NMMATH64:	.ASCIZ	"MATH64"	.EVEN; Dbut du code; -------------START:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CALL	_WAITMOUSE	; met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	NTREL	?GETMACHINE		 ; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*4+50	JUMP,LO ERFAT2	CALL	_RDSTPRINT	; lit le status de l'imprimante	LOAD.L	A3,#R16"TXERFATDIS	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT2	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	LOAD.L	A3,#R16"TXERFATTXT	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATICO	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A1,#R16"TXERFATGRA	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADRASTER,A3	LOAD.W	D3,#GRA_DOT	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADDOT,A3	LOAD.W	D3,#GRA_TRAME	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADTRAME,A3	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADLINE,A3	LOAD.W	D3,#GRA_ELLIPSE	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADELLIPSE,A3	LOAD.W	D3,#GRA_FILLO	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADFILLO,A3	LOAD.W	D3,#GRA_FILLC	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADFILLC,A3	LOAD.W	D3,#GRA_CLEAR	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADCLEAR,A3	LOAD.W	D3,#GRA_SET	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADSET,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADINV,A3	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADQXDOT,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMDGENC	LOAD.W	D3,#DGENC_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDGENC,D1	LOAD.L	A3,#R16"NMDESSIN	LOAD.W	D3,#DESSIN_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDESSIN,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMSPLINE	LOAD.W	D3,#SPLINE_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSPLINE,D1	LOAD.L	A3,#R16"NMMATH64	LOAD.W	D3,#MATH64_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHMATH64,D1	LOAD.L	D0,#2^BM64C7D	; D0 <-- mode par dfaut	MATH64_	OPEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OCHMATH,A5; Initialise quelques variables importantes.	LOAD.B	(A6)+OGRAPHE,#ICOGCAC	LOAD.L	A3,#R16"TXERFATDMA	LOAD.W	D4,#1	DESSIN_	DGET		; A4 <-- ^pinceaux par dfaut	JUMP,NE ERFAT2	LOAD.L	A3,#(A6)+OPDEF	LOAD.W	D4,#((MAXDEF*(8+2))/2)-150$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,50$	LOAD.L	A3,#(A6)+OPDDEF	LOAD.L	A4,#R16"TPDDEF	LOAD.W	D4,#((MAXDEF/4*(8+2))/2)-151$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,51$	LOAD.L	A3,#R16"TXERFATDMA	LOAD.W	D4,#1	DESSIN_	TGET		; A4 <-- ^trames par dfaut	JUMP,NE ERFAT2	LOAD.L	A3,#(A6)+OTDEF	LOAD.W	D4,#((MAXDEF*8)/2)-152$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,52$	LOAD.L	A3,#(A6)+OTDDEF	LOAD.L	A4,#R16"TTDDEF	LOAD.W	D4,#((MAXDEF/4*8)/2)-153$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,53$	LOAD.L	A3,#R16"TXERFATDMA	CLR.W	D4	DESSIN_	PGET		; A4 <-- ^points par dfaut	JUMP,NE ERFAT2	LOAD.L	A3,#(A6)+OXDEF	LOAD.W	D4,#((MAXDEF*8)/2)-154$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,54$	LOAD.L	A3,#R16"TXERFATMEM	CALL	CALCADRE	; calcul pos/dim du grand rectangle	LOAD.W	D4,(A6)+ODBIGX	MUL.WU	D4,(A6)+ODBIGY	SR.L	D4,#3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande matrice en mmoire	JUMP,NE ERFAT2	LOAD.L	(A6)+OPMAT,A4	LOAD.W	D4,(A6)+ODBIGX	MUL.WU	D4,(A6)+ODBIGY	SR.L	D4,#3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande matrice en mmoire	JUMP,NE ERFAT2	LOAD.L	(A6)+OPMAS,A4	LOAD.B	(A6)+OFTDEF,#2^BDF1AN	LOAD.B	(A6)+OFPDEF,#2^BDF1AN	LOAD.B	(A6)+OFXDEF,#2^BDF1AN	LOAD.L	(A6)+OXYFAN,#2^BXYNORM	LOAD.L	(A6)+OPEFAN,#2^BPENIV	LOAD.W	(A6)+OPELG,#25	LOAD.W	(A6)+OPEAD,#30	LOAD.W	(A6)+OPEAG,#15	LOAD.L	(A6)+OZEFAN,#2^BZENUL	LOAD.L	(A6)+ODCFAN,#2^BDF100	LOAD.L	(A6)+ODEFAN,#2^BDF075	LOAD.L	(A6)+ODBFAN,#2^BDBTRAN!2^BDBDR!2^BDBPT	LOAD.L	(A6)+OLEFAN,#2^BLEGR!2^BLEPR	LOAD.L	(A6)+OECFAN,#2^BECAXX!2^BECAXY!2^BECAXZ	OR.L	(A6)+OECFAN,#2^BECGRX!2^BECGRY!2^BECGRZ	OR.L	(A6)+OECFAN,#2^BECNOX!2^BECNOY!2^BECNOZ;;?	OR.L	(A6)+OECFAN,#2^BECFXY!2^BECFYZ!2^BECFXZ!2^BECGRE	OR.L	(A6)+OECFAN,#2^BECFXY!2^BECGRE	LOAD.L	(A6)+OTIFAN,#2^BTIOUI!2^BTICE	LOAD.B	(A6)+OGCLIST,#-1	CALL	_DEFGENCAR	; utilise tous les gencars par dfaut	CALL	_CCMO		; enlve la souris	CALL	DESWDO	CALL	DESCADRE	CALL	_AFMENU		; affiche les soft-keys	LIB	?BUZZ		; signal: c'est prt !	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SKPNAM	JUMP,NE LOOP	LOAD.L	A4,#(A6)+OBUFIN70$:	LOAD.B	D3,(A3+)	JUMP',EQ 75$	COMP.B	D3,#CR	JUMP',EQ 75$	COMP.B	D3,#SPACE	JUMP',EQ 75$	COMP.B	D3,#TAB	JUMP',EQ 75$	COMP.B	D3,#'/	JUMP',EQ 75$	LOAD.B	(A4+),D3	; OBUFIN <-- nom ligne de commande	JUMP	70$75$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUFIN	; A3 <-- ^nom	LOAD.L	D5,#2^BDBGRA!2^BDBDEF ; D5 <-- prend graphique et dfinitions	JUMP	_PRENDF		; essaye de prendre ce fichier ...LOOP:	CALL	_SCMO		; remet la souris	CALL	_NORMMOUSE	; enlve le sablier20$:	LIB	?GETKEY		; attend clavier/souris ...	TEST.L	D3:#BKPSEUDO	JUMP,BS 20$	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE EXECUTE	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	_RGMOUSE	; dessine la position dans les rgles	JUMP	20$EXECUTE:	COMP.W	D3,#F0+SHIFT	JUMP',LO 10$	COMP.W	D3,#F15+SHIFT	JUMP',HI 10$	SUB.W	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)10$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP	LOAD.B	(A6)+OKEY,D3	COMP.W	D3,#KEYICO+ICOCHOIX	JUMP,EQ MODIFCHOIX	COMP.W	D3,#KEYICO+ICOGCAC	JUMP,EQ NEWGRAPH	COMP.W	D3,#KEYICO+ICOGBRI	JUMP,EQ NEWGRAPH	COMP.W	D3,#KEYICO+ICOGCAM	JUMP,EQ NEWGRAPH	COMP.W	D3,#KEYICO+ICOGLIS	JUMP,EQ NEWGRAPH	COMP.W	D3,#KEYICO+ICODCAC	JUMP,EQ MODIFDCAC	COMP.W	D3,#KEYICO+ICODBRI	JUMP,EQ MODIFDBRI	COMP.W	D3,#KEYICO+ICODCAM	JUMP,EQ MODIFDCAM	COMP.W	D3,#KEYICO+ICODLIS	JUMP,EQ MODIFDLIS	COMP.W	D3,#KEYICO+ICOXY	JUMP,EQ MODIFXY	COMP.W	D3,#KEYICO+ICOGAUSS	JUMP,EQ MODIFGAUSS	COMP.W	D3,#KEYICO+ICOFILTRE	JUMP,EQ MODIFFILTRE	COMP.W	D3,#KEYICO+ICOPERS	JUMP,EQ MODIFPERS	COMP.W	D3,#KEYICO+ICOZERO	JUMP,EQ MODIFZERO	COMP.W	D3,#KEYICO+ICOTRAME	JUMP,EQ MODIFTRAME	COMP.W	D3,#KEYICO+ICOLIGNE	JUMP,EQ MODIFLIGNE	COMP.W	D3,#KEYICO+ICOPOINT	JUMP,EQ MODIFPOINT	COMP.W	D3,#KEYICO+ICODTRAME	JUMP,EQ MODIFTRAME	COMP.W	D3,#KEYICO+ICODLIGNE	JUMP,EQ MODIFLIGNE	COMP.W	D3,#KEYICO+ICOCARAC	JUMP,EQ MODIFCARAC	COMP.W	D3,#KEYICO+ICOLEGENDE	JUMP,EQ MODIFLEGENDE	COMP.W	D3,#KEYICO+ICOECHELLE	JUMP,EQ MODIFECHELLE	COMP.W	D3,#KEYICO+ICOTITRE	JUMP,EQ MODIFTITRE	COMP.W	D3,#F0	JUMP,EQ FINI	COMP.W	D3,#END	JUMP,EQ FINI	COMP.W	D3,#F1	JUMP,EQ _PREND	COMP.W	D3,#H'100*(2^BSHOW)+DEFINE	JUMP,EQ _PREND	COMP.W	D3,#F3	JUMP,EQ _SAUVE	COMP.W	D3,#H'100*(2^BCOPY)+DEFINE	JUMP,EQ _SAUVE	COMP.W	D3,#F4	JUMP,EQ DEFINI	COMP.W	D3,#F7	JUMP,EQ REDESSINE	COMP.W	D3,#F8	JUMP,EQ REDESSINE	COMP.W	D3,#F9	JUMP,EQ REDESSINE	COMP.W	D3,#F10	JUMP,EQ REGLE	COMP.W	D3,#F14	JUMP,EQ EFFACE	COMP.W	D3,#F15	JUMP,EQ IMPRIME	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC	JUMP	BIPCLIC:	LOAD.W	D2,D3		; D2 <-- bouton press	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP; Traite le cas o la souris est dans une icne.	CALL	DETICONE	; souris dans une icne ?	JUMP,NE 50$		; non => 50$	LOAD.B	D5,D3	JUMP'	34$32$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 35$		; non => 35$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 32$	CALL	DETICONE	; D3 <-- icne o est la souris	JUMP,NE 32$	COMP.B	D3,D5	JUMP,EQ 32$	EX.L	D3,D5	CALL	INVICONE	; teint l'ancienne icne34$:	LOAD.B	D3,D5	CALL	INVICONE	; allume la nouvelle icne	JUMP	32$35$:	LOAD.B	D3,D5	CALL	INVICONE	; teint l'ancienne icne	COMP.B	D3,#ICOVIDE	JUMP,EQ BIP	JUMP	PRESSKEY; Traite le cas o la souris modifie les dimensions.50$:	CALL	DETDIM		; dans l'icne ?	JUMP,NE 60$		; non => 60$				; oui =>	LOAD.L	D5,D4	SUB.W	D5,(A6)+OPBIGX	SUB.W	D5,(A6)+ODGRAX	SWAP.W	D5	SUB.W	D5,(A6)+OPBIGY	SUB.W	D5,(A6)+ODGRAY	SWAP.W	D5		; D5 <-- p'tite correction	LOAD.L	D1,(A6)+ODGRA52$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 55$		; non => 55$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 52$	SUB.W	D4,D5	SUB.W	D4,(A6)+OPBIGX	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D5	SUB.W	D4,(A6)+OPBIGY	SWAP.W	D4	SWAP.W	D5	LOAD.L	(A6)+ODGRA,D4	CALL	CLIPDIM	LOAD.L	D4,(A6)+ODGRA	LOAD.W	D2,#INVDOT	CALL	DESDIM		; dessine les nouvelle dimenions	LOAD.L	(A6)+ODGRA,D1	LOAD.W	D2,#INVDOT	CALL	DESDIM		; efface les anciennes dimensions	LOAD.L	(A6)+ODGRA,D4	LOAD.L	D1,D4	JUMP	52$55$:	CALL	DESCADRE	; dessine le cadre dfinitif	CALL	REFAIT3		; refait le graphique	JUMP	LOOP; Traite le cas o la souris bouge la lgende.60$:	TEST.L	(A6)+OLEDIM	; lgende existe ?	JUMP,EQ 80$		; non => 80$				; oui =>	LOAD.L	D3,D4		; D3 <-- position de la souris	SUB.W	D3,(A6)+OLEPOS+2	JUMP,LO 80$	COMP.W	D3,(A6)+OLEDIM+2	JUMP,HS 80$	SWAP.W	D3	SUB.W	D3,(A6)+OLEPOS+0	JUMP,LO 80$	COMP.W	D3,(A6)+OLEDIM+0	JUMP,HS 80$	CALL	_CLIPLEGENDE	; D4 <-- position de la lgende	CALL	_INVLEGENDE	; dessine le premier rectangle	LOAD.L	(A6)+OLEPOS,D462$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 65$		; non => 65$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 62$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	_CLIPLEGENDE	; D4 <-- position de la lgende	COMP.L	D4,(A6)+OLEPOS	JUMP,EQ 62$	CALL	_INVLEGENDE	; dessine le nouveau rectangle	LOAD.L	D3,(A6)+OLEPOS	LOAD.L	(A6)+OLEPOS,D4	LOAD.L	D4,D3	CALL	_INVLEGENDE	; efface l'ancien rectangle	JUMP	62$65$:	CALL	GIVGRA		; restitue le graphique sans lgende	LOAD.L	D3,(A6)+OLEPOS	LOAD.L	D4,(A6)+OLEDIM	CALL	_DESLEGENDE	; dessine la nouvelle lgende	JUMP	LOOP80$:	LOAD.W	D3,D2		; D3 <-- bouton press	COMP.W	D3,#KEYMGP	JUMP,EQ DROITE	COMP.W	D3,#KEYMMP	JUMP,EQ MILIEU	COMP.W	D3,#KEYMDP	JUMP,EQ ENTOURE	JUMP	BIPPRESSKEY:			; clic icne => touche presse	AND.W	D3,#H'FF	OR.W	D3,#KEYICO	; D3 <-- code "touche" presse	JUMP	EXECUTENEWGRAPH:	COMP.B	D3,#ICOGCAC	; histogramme cte  cte ?	JUMP',NE 10$		; non => 10$	TEST.B	(A6)+ODCFAN+3:#BDFEMP	JUMP',BC 10$	LOAD.B	D3,#ICOGEMP	; D3 <-- histogramme empil !10$:	COMP.B	D3,(A6)+OGRAPHE	JUMP,EQ BIPNEWGRAPH1:	PUSH.W	D3	LOAD.B	D3,(A6)+OGRAPHE	CALL	INVICONE	POP.W	D3	CALL	INVICONE	LOAD.B	(A6)+OGRAPHE,D3	CALL	REFAIT2		; refait le graphique	JUMP	LOOPMODIFCHOIX:	LOAD.B	D3,#SAVWDO	LIB	?AFCAR	LOAD.W	D6,D7		; D6 <-- ok/erreur	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#R16"TIMACH	CALL	_AFIMAGE	; affiche l'image	JUMP,NE 50$	CALL	_NORMMOUSE	; souris: remet la flche	LOAD.L	A3,#R16"TXMENUNIL	LIB	?AFMENU	LOAD.W	D1,#-120$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 30$		; non => 30$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	_DETICH		; D2 <-- rang o est la souris	COMP.W	D2,D1	JUMP,EQ 20$	EX.L	D1,D2	CALL	_INVICH		; efface l'ancien	LOAD.W	D2,D1	CALL	_INVICH		; allume le nouveau	JUMP	20$30$:	CLR.W	D7		; D7 <-- ok	LOAD.W	D2,D1		; D2 <-- rang50$:	PUSH.W	D7	TEST.W	D6		; sauvetage fentre ok ?	JUMP',NE 52$		; non => 52$	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue la fentre	JUMP'	55$52$:	CALL	_CCMO		; enlve la souris	CALL	DESWDO	CALL	DESCADRE55$:	CALL	_AFMENU		; remet les soft-keys	POP.W	D7	JUMP,NE ERROR	COMP.W	D2,#-1	JUMP,EQ LOOP	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#R16"TDEFCH	CALL	_INDEF		; lit le fichier .DGRA	JUMP,NE ERROR	CALL	_INIDIM	CALL	REFAIT		; refait le graphique	CLR.B	(A6)+OGAJ	; le graphique n'est plus  jour	JUMP	LOOPMODIFDCAC:	CALL	DBOXDCAC	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT2		; refait le graphique	JUMP	LOOPMODIFDBRI:	CALL	DBOXDBRI	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.B	D3,#ICOGBRI	JUMP	NEWGRAPH1MODIFDCAM:	CALL	DBOXDCAM	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.B	D3,#ICOGCAM	JUMP	NEWGRAPH1MODIFDLIS:	CALL	DBOXDLIS	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.B	D3,#ICOGLIS	JUMP	NEWGRAPH1MODIFXY:	CALL	DBOXXY	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT2		; refait le graphique	JUMP	LOOPMODIFGAUSS:	CALL	DBOXGAUSS	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT2		; refait le graphique	JUMP	LOOPMODIFFILTRE:	CALL	DBOXFILTRE	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT2		; refait le graphique	JUMP	LOOPMODIFPERS:	COMP.B	(A6)+OGRAPHE,#ICOGCAM	JUMP',EQ 40$	COMP.B	(A6)+OGRAPHE,#ICOGLIS	JUMP,EQ BIP	CALL	DBOXPERS	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT3		; refait le graphique	JUMP	LOOP40$:	CALL	DBOXPERSCAM	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT3		; refait le graphique	JUMP	LOOPMODIFZERO:	COMP.B	(A6)+OGRAPHE,#ICOGEMP	JUMP,EQ BIP	COMP.B	(A6)+OGRAPHE,#ICOGCAM	JUMP,EQ BIP	COMP.B	(A6)+OGRAPHE,#ICOGLIS	JUMP,EQ BIP	CALL	DBOXZERO	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT2		; refait le graphique	JUMP	LOOPMODIFTRAME:	CALL	DBOXTDEF	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT3		; refait le graphique	JUMP	LOOPMODIFLIGNE:	CALL	DBOXPDEF	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT3		; refait le graphique	JUMP	LOOPMODIFPOINT:	COMP.B	(A6)+OGRAPHE,#ICOGBRI	JUMP,NE BIP	CALL	DBOXXDEF	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT3		; refait le graphique	JUMP	LOOPMODIFCARAC:	CALL	_DBOXCARAC	JUMP,NE ERROR	CALL	REFAIT3		; refait le graphique	JUMP	LOOPMODIFLEGENDE:	COMP.B	(A6)+OGRAPHE,#ICOGLIS	JUMP,EQ BIP	CALL	DBOXLEGENDE	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT3		; refait le graphique	JUMP	LOOPMODIFECHELLE:	COMP.B	(A6)+OGRAPHE,#ICOGLIS	JUMP,EQ BIP	CALL	DBOXECHELLE	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT3		; refait le graphique	JUMP	LOOPMODIFTITRE:	COMP.B	(A6)+OGRAPHE,#ICOGLIS	JUMP,EQ BIP	CALL	DBOXTITRE	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	REFAIT3		; refait le graphique	JUMP	LOOPDROITE:	JUMP	BIPMILIEU:	JUMP	BIPENTOURE:	JUMP	BIPDEFINI:	CALL	DBOXDEF	JUMP,NE ERROR	JUMP	LOOPREDESSINE:	CALL	REFAIT		; refait tout le graphique	JUMP	LOOPREGLE:	CALL	_CCMO		; enlve la souris	NOT.B	(A6)+OREGLE	; met/enlve les rgles	CALL	DESCADRE	; redessine le cadre	CALL	REFAIT3		; redessine le graphique	JUMP	LOOPEFFACE:	CALL	DBOXEFFACE	; tes-vous sr ?	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	_GIVPGRA	; rend mmoire pour graphique	LOAD.L	A3,#(A6)+OBUFIN	CLR.B	(A3)	CALL	_SAVFILE	; OBUNAME <-- nom	CALL	DESINFFILE	; affiche le nom dans les infos	CALL	REFAIT		; dessine le graphique	SET.B	(A6)+OGAJ	; le graphique est  jour	JUMP	LOOPIMPRIME:	TEST.L	(A6)+OPGRA	JUMP,EQ BIP	LOAD.L	A3,#R16"TPRINT	; A3 <-- ^nom de l'imprimante	CLR.L	D2		; D2 <-- mode	CALL	_OUTIMA		; imprime ...	JUMP,NE ERROR	JUMP	LOOPBIP:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPERROR:	CALL	_AFFERROR	; affiche l'erreur ...	JUMP	LOOPFINI:	CLR.W	D0		; D0 <-- avant de quitter	CALL	DBOXSAVE	; sauve si ncessaire avant de quitter	JUMP',EQ 50$		; ok => 50$	COMP.W	D7,#1		; (ANNULE) ?	JUMP,EQ LOOP		; oui => LOOP	JUMP	ERROR		; non => ERROR50$:	CALL	DBOXQUITTE	; quitte GRAPHE ?	COMP.W	D3,#F1	JUMP,NE LOOPERFAT:	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	MATH64_	CLOSE	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDGENC	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDESSIN	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSPLINE	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHMATH64	LIB_	CLOSE	CALL	_KILGENCAR	; libre tous les gencars	LIB	?AFTIM	.B	KILLGC,GCTXF,GCTXS,GCTXT	.B	KILLGC,GCICF,GCICS,GCICT	.B	0	.EVENERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	GRACADRE.ASI	.INS	GRAICONE.ASI	.INS	GRADESSIN.ASI	.INS	GRACAMEMB.ASI	.INS	GRALISTE.ASI	.INS	GRAGAUSS.ASI	.INS	GRAAXES.ASI	.INS	GRACALCUL.ASI	.INS	GRAQUICK.ASI_WAITMOUSE:	JUMP	WAITMOUSE_NORMMOUSE:	JUMP	NORMMOUSE_CCMO:		JUMP	CCMO_SCMO:		JUMP	SCMO_IFMOUSE:	JUMP	IFMOUSE_RGMOUSE:	JUMP	RGMOUSE_ERGMOUSE:	JUMP	ERGMOUSE_RDSTPRINT:	JUMP	RDSTPRINT_AFMENU:	JUMP	AFMENU_AFIMAGE:	JUMP	AFIMAGE_DETICH:	JUMP	DETICH_INVICH:	JUMP	INVICH_DRMDEF:	JUMP	DRMDEF_INIDIM:	JUMP	INIDIM_SAUVE:		JUMP	SAUVE_PREND:		JUMP	PREND_PRENDF:	JUMP	PRENDF_OUTIMA:	JUMP	OUTIMA_DEFGENCAR:	JUMP	DEFGENCAR_KILGENCAR:	JUMP	KILGENCAR_INDEF:		JUMP	INDEF_GIVPGRA:	JUMP	GIVPGRA_SAVFILE:	JUMP	SAVFILE_AFFERROR:	JUMP	AFFERROR_DESLEGENDE:	JUMP	DESLEGENDE_INVLEGENDE:	JUMP	INVLEGENDE_CLIPLEGENDE:	JUMP	CLIPLEGENDE_DBOXCARAC:	JUMP	DBOXCARAC_LOOP:		JUMP	LOOP_ERROR:		JUMP	ERROR_DESINFFILE:	JUMP	DESINFFILE	.INS	GRADBOX.ASI	.INS	GRADBOXT.ASI	.INS	GRATABLE.ASI	.INS	GRACARAC.ASI	.INS	GRAIO.ASI	.INS	GRAERROR.ASI	.INS	GRAMISC.ASI	.END	START