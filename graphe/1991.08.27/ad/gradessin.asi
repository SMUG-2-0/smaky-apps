	.SBTTL	GRADESSIN;--------\\; REFAIT  >;========/; Redessine tout le graphique.; in	-; out	-; mod	D7.W; REFAIT2:	CLR.B	(A6)+OGAJ	; le graphique n'est plus  jour	TEST.B	(A6)+ORAPIDE	JUMP',F REFAIT	RETREFAIT3:	CLR.B	(A6)+OGAJ	; le graphique n'est plus  jour	TEST.B	(A6)+ORAPIDE	JUMP',F REFAITMIN	RET; Redessine tout compltement.REFAIT:	LOAD.L	D3,(A6)+OPBIG	LOAD.L	D4,(A6)+ODGRA	CALL	DRCLEAR		; efface l'ancien graphique	CALL	_SCMO		; remet la souris	CALL	_WAITMOUSE	; souris: met le sablier	CLR.W	D7		; D7 <-- ok	TEST.L	(A6)+OPGRA	; tableau existe ?	JUMP,EQ REFAITERR	; non => REFAITERR	CALL	GETDIM		; cherche les dimensions (dx et dy)	CALL	GETGAUSS	; gnre le tableau de Gauss	JUMP,NE REFAITERR	CALL	CHECKDIM	; dimensions ok ?	JUMP,NE REFAITERR	CALL	GETMINMAX	; cherche le minimum et le maximum	JUMP,NE REFAITERR	JUMP	REFAITCOM; Redessine tout, mais ne refait pas les calculs gnraux.REFAITMIN:	LOAD.L	D3,(A6)+OPBIG	LOAD.L	D4,(A6)+ODGRA	CALL	DRCLEAR		; efface l'ancien graphique	CALL	_SCMO		; remet la souris	CALL	_WAITMOUSE	; souris: met le sablier	CLR.W	D7		; D7 <-- ok	TEST.L	(A6)+OPGRA	; tableau existe ?	JUMP,EQ REFAITERR	; non => REFAITERR;	JUMP	REFAITCOMREFAITCOM:	COMP.B	(A6)+OGRAPHE,#ICOGCAM	JUMP,EQ 50$	COMP.B	(A6)+OGRAPHE,#ICOGLIS	JUMP,EQ 60$	CALL	GETMOYENNE	; cherche la moyenne gnrale	CALL	CALCZERO	; calcul la position du "zro"	CALL	DIMMARGES	; cherche les marges	CALL	DIMTITRE	; cherche la marge en haut	CALL	DIMGRADX	; cherche la graduation selon l'axe X	CALL	DIMGRADZ	; cherche la graduation selon l'axe Z	CALL	GETPERSPECTIVE	; cherche la perspective selon les angles	JUMP,NE REFAITERR	CALL	GETMULY		; cherche le facteur pour Y	CALL	DESTITRE	; dessine le titre	CALL	DESAXES		; dessine les axes	CALL	DESGRADZ	; dessine la graduation selon l'axe Z	CALL	DESGRAPHE	; dessine le graphique	JUMP,NE 80$	CALL	DESGRADX	; dessine la graduation selon l'axe X40$:	CALL	DIMLEGENDE	; D4 <-- dimensions pour la lgende	JUMP,NE 80$	TEST.L	D4	JUMP,EQ 90$	CALL	SAVGRA		; sauve tout le graphique	CALL	POSLEGENDE	LOAD.L	D3,(A6)+OLEPOS	CALL	DESLEGENDE	; dessine la lgende	JUMP	90$50$:				; camembert =>	CALL	DIMMARGES	; cherche les marges	CALL	DIMTITRE	; cherche la marge en haut	CALL	DESTITRE	; dessine le titre	CALL	DESGCAM		; dessine le camembert	JUMP',NE 80$	JUMP	40$60$:				; liste =>	CALL	DIMMARGES	; cherche les marges	CALL	DIMLISTE	; cherche les dimensions	JUMP',NE 80$	CALL	DESLISTE	; dessine la liste	JUMP'	90$80$:	CALL	AFFERROR	; affiche l'erreur ...90$:	RET; Biffe le graphique et affiche l'erreur.REFAITERR:	TEST.W	D7	JUMP',EQ 90$	PUSH.W	D7	LOAD.L	D3,(A6)+OPBIG	LOAD.L	D4,(A6)+ODGRA	LOAD.W	D2,#SETDOT	CALL	DRLINE		; biffe tout le graphique (crac)	LOAD.L	D3,(A6)+OPBIG;	LOAD.L	D4,(A6)+ODGRA	ADD.W	D3,D4	NEG.W	D4;	LOAD.W	D2,#SETDOT	CALL	DRLINE	POP.W	D7	CALL	AFFERROR	; affiche l'erreur ...90$:	RET;----------\\; DESGRAPHE >;==========/; Dessine un graphique cte  cte.; in	-; out	D7.W	erreur; mod	D7.WDESGRAPHE:	COMP.B	(A6)+OGRAPHE,#ICOGCAC	JUMP',EQ 10$	COMP.B	(A6)+OGRAPHE,#ICOGEMP	JUMP,EQ 20$	COMP.B	(A6)+OGRAPHE,#ICOGBRI	JUMP,EQ 30$	LOAD.W	D7,#ERGRAPH	JUMP	90$10$:				; graphique cte  cte =>	TEST.B	(A6)+OPEFAN+3:#BPEDER ; l'un derrire l'autre ?	JUMP',BC 15$		; non => 15$				; oui =>	SET.B	(A6)+ONEG	CALL	DESGCACDER	; dessine les valeurs ngatives	CALL	DESAXEZERO	; dessine la ligne du zro	CLR.B	(A6)+ONEG	CALL	DESGCACDER	; dessine les valeurs positives	JUMP	90$15$:	SET.B	(A6)+ONEG	CALL	DESGCACNIV	; dessine les valeurs ngatives	CALL	DESAXEZERO	; dessine la ligne du zro	CLR.B	(A6)+ONEG	CALL	DESGCACNIV	; dessine les valeurs positives	JUMP	90$20$:				; graphique empil =>	CALL	DESAXEZERO	; dessine la ligne du zro	CALL	DESGEMP		; dessine les valeurs	JUMP	90$30$:				; lignes brises =>	CALL	DESAXEZERO	; dessine la ligne du zro	CALL	DESGBRI		; dessine les valeurs;	JUMP	90$90$:	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DESGCACNIV >;-----------/; Dessine un graphique cte  cte, avec toutes les; barres sur le mme niveau.; in	-; out	D7.W	erreur; mod	D7.WDESGCACNIV:	PUSHM.L	D0..D5	CALL	DESBALARG	; OBALGn <-- largeurs	JUMP,NE 90$	CALL	POSZERO		; D3D4 <-- position du "zro"	CALL	CONVMULY	LOAD.W	D5,D4	ADD.W	D5,(A6)+OPBIGY	ADD.W	D5,(A6)+OMARGH	ADD.W	D5,(A6)+OPERSZ	ADD.W	D5,(A6)+OPERSY	SWAP.W	D5	LOAD.W	D5,(A6)+OPBIGX	ADD.W	D5,(A6)+OMARGG	; D5 <-- position (y;x) initiale	ADD.W	D5,(A6)+OBALG0	CLR.L	D0		; D0 <-- coordonne Y initiale10$:	CALL	STOPKEY		; arrt d'urgence ?	JUMP,NE 90$		; oui => 90$	CLR.W	D0		; D0 <-- coordonne X initiale20$:	SWAP.W	D5	PUSH.W	D5	SWAP.W	D5	LOAD.L	D3,D5	CALL	ZPOINT	LOAD.L	D5,D3	LOAD.L	D2,D0		; D2 <-- coordonne (y;x)	CALL	GETNB		; D3D4 <-- nombre	JUMP',NE 50$	TEST.B	(A6)+ONEG	JUMP',T 30$	TEST.L	D3:#31	JUMP',BS 50$	JUMP'	32$30$:	TEST.L	D3:#31	JUMP',BC 50$32$:	CALL	CONVMULY	; D4 <-- +/- hauteur	LOAD.L	D3,D5		; D3 <-- position sur ligne du zro	NEG.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OBALG1	; D4 <-- largeur	CALL	DESBARRE	; dessine une barre50$:	SWAP.W	D5	POP.W	D5	SWAP.W	D5	LOAD.W	D2,(A6)+OBALG2	ADD.W	D5,D2		; D5 <-- position suivante	SUB.W	(A6)+OPOSZ,D2	INC.W	D0		; D0 <-- coordonne X suivante	COMP.W	D0,(A6)+ODIMX	JUMP,LO 20$	LOAD.W	D2,(A6)+OBALG3	ADD.W	D5,D2		; D5 <-- position suivante	SUB.W	(A6)+OPOSZ,D2	SWAP.W	D0	INC.W	D0		; D0 <-- coordonne Y suivante	LOAD.W	D3,D0	SWAP.W	D0	COMP.W	D3,(A6)+ODIMY	JUMP,LO 10$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DESGCACDER >;-----------/; Dessine un graphique cte  cte, avec les barres; l'une derrire l'autre.; in	-; out	D7.W	erreur; mod	D7.WDESGCACDER:	PUSHM.L	D0..D5	CALL	DESBALARG	; OBALGn <-- largeurs	JUMP,NE 90$	CALL	POSZERO		; D3D4 <-- position du "zro"	CALL	CONVMULY	LOAD.W	D5,D4	ADD.W	D5,(A6)+OPBIGY	ADD.W	D5,(A6)+OMARGH	ADD.W	D5,(A6)+OPERSZ	ADD.W	D5,(A6)+OPERTY	SWAP.W	D5	LOAD.W	D5,(A6)+OPBIGX	ADD.W	D5,(A6)+OMARGG	ADD.W	D5,(A6)+OPERSX	SUB.W	D5,(A6)+OPERTX	; D5 <-- position (y;x) initiale	ADD.W	D5,(A6)+OBALG0	CLR.L	D0		; D0 <-- coordonne Y initiale10$:	CALL	STOPKEY		; arrt d'urgence ?	JUMP,NE 90$		; oui => 90$	PUSH.L	D5	LOAD.L	D3,D5	CALL	ZPOINT	LOAD.L	D5,D3	CLR.W	D0		; D0 <-- coordonne X initiale20$:	LOAD.L	D2,D0		; D2 <-- coordonne (y;x)	CALL	GETNB		; D3D4 <-- nombre	JUMP',NE 50$	TEST.B	(A6)+ONEG	JUMP',T 30$	TEST.L	D3:#31	JUMP',BS 50$	JUMP'	32$30$:	TEST.L	D3:#31	JUMP',BC 50$32$:	CALL	CONVMULY	; D4 <-- +/- hauteur	LOAD.L	D3,D5		; D3 <-- position sur ligne du zro	NEG.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OBALG1	; D4 <-- largeur	CALL	DESBARRE	; dessine une barre50$:	SUB.W	D5,(A6)+OPERTX	SWAP.W	D5	ADD.W	D5,(A6)+OPERTY	SWAP.W	D5		; D5 <-- position suivante	INC.W	D0		; D0 <-- coordonne X suivante	COMP.W	D0,(A6)+ODIMX	JUMP,LO 20$	POP.L	D5	LOAD.W	D2,(A6)+OBALG2	ADD.W	D5,D2		; D5 <-- position suivante	SUB.W	(A6)+OPOSZ,D2	SWAP.W	D0	INC.W	D0		; D0 <-- coordonne Y suivante	LOAD.W	D3,D0	SWAP.W	D0	COMP.W	D3,(A6)+ODIMY	JUMP,LO 10$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DESGEMP >;--------/; Dessine un graphique empil.; in	-; out	D7.W	erreur; mod	D7.WDESGEMP:	PUSHM.L	D0..D5	CALL	DESBALARG	; OBALGn <-- largeurs	JUMP,NE 90$	CALL	POSZERO		; D3D4 <-- position du "zro"	CALL	CONVMULY	LOAD.W	D5,D4	ADD.W	D5,(A6)+OPBIGY	ADD.W	D5,(A6)+OMARGH	ADD.W	D5,(A6)+OPERSZ	ADD.W	D5,(A6)+OPERSY	SWAP.W	D5	LOAD.W	D5,(A6)+OPBIGX	ADD.W	D5,(A6)+OMARGG	; D5 <-- position (y;x) initiale	ADD.W	D5,(A6)+OBALG0	CLR.L	D0		; D0 <-- coordonne Y initiale10$:	CALL	STOPKEY		; arrt d'urgence ?	JUMP,NE 90$		; oui => 90$	PUSH.L	D5	PUSH.W	(A6)+OPERTX	PUSH.W	(A6)+OPERTY	LOAD.W	(A6)+OPERTX,(A6)+OPERSX	LOAD.W	(A6)+OPERTY,(A6)+OPERSY	CLR.W	D0		; D0 <-- coordonne X initiale	LOAD.L	D3,D5	CALL	ZPOINT	LOAD.L	D5,D320$:	LOAD.L	D2,D0		; D2 <-- coordonne (y;x)	CALL	GETNB		; D3D4 <-- nombre	JUMP,NE 50$	CALL	CONVMULY	; D4 <-- hauteur	LOAD.L	D3,D5		; D3 <-- position sur ligne du zro	NEG.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OBALG1	; D4 <-- largeur	CALL	DESBARRE	; dessine une barre	SWAP.W	D4	SWAP.W	D5	ADD.W	D5,D4		; D5 <-- position dessus la suivante	SWAP.W	D5	TEST.B	(A6)+OPEFAN+3:#BPEDER ; l'un derrire l'autre ?	JUMP',BC 50$		; non => 50$				; oui =>	CLR.L	D4	LOAD.W	D4,(A6)+OPERSX	DIV.WU	D4,(A6)+ODIMX	SUB.W	(A6)+OPERTX,D4	ADD.W	D5,D4	CLR.L	D4	LOAD.W	D4,(A6)+OPERSY	DIV.WU	D4,(A6)+ODIMX	SUB.W	(A6)+OPERTY,D4	SWAP.W	D5	SUB.W	D5,D4	SWAP.W	D550$:	INC.W	D0		; D0 <-- coordonne X suivante	COMP.W	D0,(A6)+ODIMX	JUMP,LO 20$	POP.W	(A6)+OPERTY	POP.W	(A6)+OPERTX	POP.L	D5	LOAD.W	D2,(A6)+OBALG2	ADD.W	D5,D2		; D5 <-- position suivante	SUB.W	(A6)+OPOSZ,D2	SWAP.W	D0	INC.W	D0		; D0 <-- coordonne Y suivante	LOAD.W	D3,D0	SWAP.W	D0	COMP.W	D3,(A6)+ODIMY	JUMP,LO 10$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DESBARRE >;---------/; Dessine une barre.; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D0.L	coordonne de la case dans le tableau; out	-; mod	D7.WDESBARRE:	PUSHM.L	D0..D6,A4	SWAP.W	D3	SWAP.W	D4	TEST.W	D4	JUMP',NC 20$	NEG.W	D4	SUB.W	D3,D420$:	SWAP.W	D4	SWAP.W	D3	CALL	EFFBARRE	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLGRAPHE	CALL	DEFTRAIT	COMP.W	D2,#-1	JUMP,EQ 60$	OR.W	D2,#SETDOT				; dessine le pourtour =>	PUSHM.L	D3,D4	LOAD.L	D5,D4	CLR.L	D4	LOAD.W	D4,D5	CALL	ZPENTE	CALL	DRLINE		; trace ligne suprieure	LOAD.L	D4,D5	CLR.W	D4	CALL	DRLINE		; trace ligne de droite	CLR.L	D4	LOAD.W	D4,D5	NEG.W	D4	CALL	ZPENTE	CALL	DRLINE		; trace ligne infrieure	LOAD.L	D4,D5	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DRLINE		; trace ligne de gauche	POPM.L	D3,D4	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP,BC 60$		; non => 60$				; oui =>	PUSHM.L	D3,D4	LOAD.L	D5,D4	LOAD.W	D4,(A6)+OPERTY	NEG.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OPERTX	CALL	DRLINE		; /	CLR.L	D4	LOAD.W	D4,D5	CALL	ZPENTE	CALL	DRLINE		; _	PUSH.L	D3	LOAD.W	D4,(A6)+OPERTY	SWAP.W	D4	LOAD.W	D4,(A6)+OPERTX	NEG.W	D4	CALL	DRLINE		; /	POP.L	D3	LOAD.L	D4,D5	CLR.W	D4	CALL	DRLINE		; |	LOAD.W	D4,(A6)+OPERTY	SWAP.W	D4	LOAD.W	D4,(A6)+OPERTX	NEG.W	D4	CALL	DRLINE		; /	POPM.L	D3,D4	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLGRAPHE	CALL	IFCTRAIT	; dlimit par un trait continu ?	JUMP,NE 60$		; non => 60$				; oui =>	PUSH.L	D4	AND.L	D4,#H'FFFF	CALL	ZPENTE	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- dcalage en Y selon Z	POP.L	D4	TEST.B	(A6)+OPEFAN+3:#BPEFIL ; fil de fer ?	JUMP',BS 50$		; oui => 50$	LOAD.L	A4,#(A6)+OTDDEF+8*RANGTHAUT	CALL	DEFTRAME	COMP.W	D2,#-1	JUMP',EQ 50$	OR.W	D2,#SETDOT	PUSHM.L	D3,D4	ADD.W	D4,(A6)+OPERTX	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	ADD.W	D3,D6	LOAD.W	D4,D6	ADD.W	D4,(A6)+OPERTY	ASR.W	D4,#1	SUB.W	D3,D4	SWAP.W	D3	CALL	DRFILL		; rempli la surface en haut	POPM.L	D3,D450$:	TEST.B	(A6)+OPEFAN+3:#BPEFIL ; fil de fer ?	JUMP',BS 60$	LOAD.L	A4,#(A6)+OTDDEF+8*RANGTDROITE	CALL	DEFTRAME	COMP.W	D2,#-1	JUMP',EQ 60$	OR.W	D2,#SETDOT	PUSHM.L	D3,D4	ADD.W	D3,D4	LOAD.W	D4,(A6)+OPERTX	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SUB.W	D3,(A6)+OPERTY	ADD.W	D3,D6	SWAP.W	D4	ADD.W	D4,(A6)+OPERTY	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	CALL	DRFILL		; rempli la surface  droite	POPM.L	D3,D460$:	TEST.B	(A6)+OPEFAN+3:#BPEFIL ; fil de fer ?	JUMP',BS 90$		; oui => 90$	CALL	DEFPTRAME	; dfini la trame selon D0.L	COMP.W	D2,#-1	JUMP',EQ 90$	OR.W	D2,#SETDOT	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP',BC 65$		; non => 65$	TEST.W	(A6)+OPERSZ	; axe "Z" horizontal ?	JUMP',NE 70$		; non => 70$65$:	CALL	DRTRAME		; dessine l'intrieur du devant	JUMP'	90$70$:;	PUSHM.L	D3,D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D6	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	CALL	DRFILL		; rempli la surface de devant;	POPM.L	D3,D490$:	POPM.L	D0..D6,A4	RET;---------\\; EFFBARRE >;---------/; Efface sous la nouvelle barre. C'est cette petite routine; de rien du tout qui permet d'effacer les surfaces caches !; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WEFFBARRE:	PUSHM.L	D1..D6,A3,A4	TEST.B	(A6)+OPEFAN+3:#BPEFIL ; fil de fer ?	JUMP,BS 90$		; oui => 90$	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP',BS 20$		; oui => 20$				; non =>	CALL	DRCLEAR		; efface desous	JUMP	90$; Construit l'ombre de la barre en perspective dans; le bitmap en mmoire.20$:	SUB.W	D3,(A6)+OPBIGX	SWAP.W	D3	SUB.W	D3,(A6)+OPBIGY	SWAP.W	D3	CALL	CLRDISMAT	CALL	OPEDISMAT	LOAD.L	D5,D4	LOAD.W	D2,#SETDOT	PUSHM.L	D3,D4	CLR.W	D4	CALL	DRLINE		; |	CLR.L	D4	LOAD.W	D4,D5	CALL	ZPENTE	CALL	DRLINE		; _	LOAD.W	D4,(A6)+OPERTY	NEG.W	D4	SWAP.W	D4	LOAD.W	D4,(A6)+OPERTX	CALL	DRLINE		; /	LOAD.L	D4,D5	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DRLINE		; |	CLR.L	D4	LOAD.W	D4,D5	NEG.W	D4	CALL	ZPENTE	CALL	DRLINE		; _	LOAD.W	D4,(A6)+OPERTY	SWAP.W	D4	LOAD.W	D4,(A6)+OPERTX	NEG.W	D4	CALL	DRLINE		; /	POPM.L	D3,D4	PUSH.L	D4	AND.L	D4,#H'FFFF	CALL	ZPENTE	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- dcalage en Y selon Z	POP.L	D4	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	DRTRADEF	POPM.L	D3,D4	PUSH.L	D3	ADD.W	D3,D4	SWAP.W	D3	ADD.W	D3,D6	SWAP.W	D3	CALL	DRFILL	POP.L	D3	CALL	CLODISMAT; Efface l'ombre de la barre dans l'cran.	LOAD.L	D1,D5	ADD.W	D1,(A6)+OPERTX	SWAP.W	D1	ADD.W	D1,(A6)+OPERTY	ADD.W	D1,D6	SWAP.W	D1		; D1 <-- dimensions	SWAP.W	D3	SUB.W	D3,(A6)+OPERTY	SWAP.W	D3		; D3 <-- source: (y;x)	LOAD.L	A3,(A6)+OPMAT	LOAD.W	D5,(A6)+ODBIGX	SR.W	D5,#3	LOAD.L	D4,D3		; D4 <-- destination: (y;x)	ADD.W	D4,(A6)+OPBIGX	SWAP.W	D4	ADD.W	D4,(A6)+OPBIGY	SWAP.W	D4	LOAD.L	A4,#0	CLR.W	D6	LOAD.W	D2,#CLRDOT	CALL	DRRASTER	; efface dans l'cran90$:	POPM.L	D1..D6,A3,A4	RET;--------\\; DESGBRI >;--------/; Dessine un graphique lignes brises.; in	-; out	D7.W	erreur; mod	D7.WDESGBRI:	PUSHM.L	D0..D5,A3,A4	CALL	DESBALARG	; OBALGn <-- largeurs	JUMP,NE 90$	CALL	POSZERO		; D3D4 <-- position du "zro"	CALL	CONVMULY	LOAD.W	D5,D4	ADD.W	D5,(A6)+OPBIGY	ADD.W	D5,(A6)+OMARGH	ADD.W	D5,(A6)+OPERSZ	SWAP.W	D5	LOAD.W	D5,(A6)+OPBIGX	ADD.W	D5,(A6)+OMARGG	ADD.W	D5,(A6)+OPERSX	; D5 <-- position (y;x) initiale	CLR.W	D0		; D0 <-- coordonne X initiale10$:	CALL	STOPKEY		; arrt d'urgence ?	JUMP,NE 90$		; oui => 90$	PUSH.L	D5	AND.L	D0,#H'FFFF	; D0 <-- coordonne Y initiale	LOAD.W	D2,(A6)+ODGRAX	SUB.W	D2,(A6)+OMARGG	SUB.W	D2,(A6)+OMARGD	SUB.W	D2,(A6)+OPERSX	LOAD.W	(A6)+OPOSZ,D2	; OPOSZ <-- largeur disponible	LOAD.L	A3,#(A6)+OPBRIN	; A3 <-- ^points nouveaux	LOAD.L	A4,#(A6)+OPBRIA	; A4 <-- ^points anciens	CALL	BRIFOND		; efface le fond20$:	LOAD.L	D2,D0		; D2 <-- coordonne (y;x)	CALL	GETNB		; D3D4 <-- nombre	JUMP',EQ 22$	CLR.L	D3	CLR.L	D4		; D3D4 <-- zro en cas d'erreur22$:	CALL	CONVMULY	; D4 <-- hauteur	LOAD.L	D3,D5	SWAP.W	D3	SUB.W	D3,D4	SWAP.W	D3	CALL	ZPOINT	LOAD.L	(A3+),D3	ADD.L	A4,#4	CALL	DESLIGNE	; dessine une "ligne"	LOAD.W	D2,(A6)+OBALG2	ADD.W	D5,D2		; D5 <-- position suivante	SUB.W	(A6)+OPOSZ,D2	SWAP.W	D0	INC.W	D0		; D0 <-- coordonne Y suivante	LOAD.W	D3,D0	SWAP.W	D0	COMP.W	D3,(A6)+ODIMY	JUMP,LO 20$	CLR.L	(A3+)	ADD.L	A4,#4	CALL	DESLIGNE	; dessine la dernire "ligne"	POP.L	D5	SUB.W	D5,(A6)+OPERTX	SWAP.W	D5	ADD.W	D5,(A6)+OPERTY	SWAP.W	D5	LOAD.L	A3,#(A6)+OPBRIN	CALL	DESSPLINE	; dessine une spline si ncessaire;	LOAD.L	A3,#(A6)+OPBRIN	LOAD.L	A4,#(A6)+OPBRIA	LOAD.W	D3,(A6)+ODIMY70$:	LOAD.L	(A4+),(A3+)	; OPBRIA <-- OPBRIN	DECJ.W,NMO D3,70$	INC.W	D0		; D0 <-- coordonne X suivante	COMP.W	D0,(A6)+ODIMX	JUMP,LO 10$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; BRIFOND >;--------/; Efface le fond de la ligne brise.; in	D0.L	position initiale dans tableau (y;x);	D5.L	position initiale dans l'cran (y;x); out	-; mod	D7.WBRIFOND:	PUSHM.L	D0..D6	PUSH.W	(A6)+OPOSZ	TEST.B	(A6)+OPEFAN+3:#BPEDER ; l'un derrire l'autre ?	JUMP,BS 90$		; oui => 90$				; non =>	TEST.B	(A6)+ODBFAN+3:#BDBOPAQ ; opaque ?	JUMP,BC 90$		; non => 90$				; oui =>	SUB.W	D5,(A6)+OPBIGX	SWAP.W	D5	SUB.W	D5,(A6)+OPBIGY	SWAP.W	D5	LOAD.L	(A6)+OPBRIP,#-1	CLR.L	(A6)+OPBRIG	CALL	CLRDISMAT	CALL	OPEDISMAT	CLR.L	D1		; D1 <-- pas encore de point prcdent20$:	LOAD.L	D2,D0		; D2 <-- coordonne (y;x)	CALL	GETNB		; D3D4 <-- nombre	JUMP',EQ 22$	CLR.L	D3	CLR.L	D4		; D3D4 <-- zro en cas d'erreur22$:	CALL	CONVMULY	; D4 <-- hauteur	LOAD.L	D3,D5	SWAP.W	D3	SUB.W	D3,D4	SWAP.W	D3	CALL	ZPOINT	PUSH.L	D3	TEST.L	D1		; premier point ?	JUMP',NE 30$		; non => 30$				; oui =>	PUSH.L	D3	LOAD.L	D3,D5	CALL	ZPOINT	LOAD.L	D6,D3		; D6 <-- point d'origine	POP.L	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	CALL	DRLINE		; ligne | depuis l'origine	JUMP'	40$30$:	LOAD.L	D4,D3	LOAD.L	D3,D1	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	CALL	DRLINE		; ligne depuis le point prcdent40$:	POP.L	D3	CALL	EFFMMLIGNE	; mmorise min/max	LOAD.L	D1,D3		; D1 <-- point prcdent	LOAD.W	D2,(A6)+OBALG2	ADD.W	D5,D2		; D5 <-- position suivante	SUB.W	(A6)+OPOSZ,D2	SWAP.W	D0	INC.W	D0		; D0 <-- coordonne Y suivante	LOAD.W	D3,D0	SWAP.W	D0	COMP.W	D3,(A6)+ODIMY	JUMP,LO 20$	LOAD.L	D3,D5	SUB.W	D3,(A6)+OBALG2	CALL	EFFMMLIGNE	; mmorise min/max	LOAD.L	D4,D3	LOAD.L	D3,D1	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	CALL	DRLINE		; ligne | jusque sur l'axe zro	LOAD.L	D4,D6	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4;	LOAD.W	D2,#SETDOT	CALL	DRLINE		; ligne _ sur l'axe zro	CALL	EFFMSKLIGNE	; efface le fond90$:	POP.W	(A6)+OPOSZ	POPM.L	D0..D6	RET;---------\\; DESLIGNE >;---------/; Dessine une ligne ou une surface.; in	(A3)-4	n;	(A3)-8	n-1;	(A4)-4	n';	(A4)-8	n'-1;	D0.L	coordonne de la case dans le tableau; out	-; mod	D7.WDESLIGNE:	PUSHM.L	D1..D4	TEST.L	(A3)-4		; dernier point ?	JUMP,EQ 30$		; oui => 30$	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP',BC 20$		; non => 20$				; oui =>	TEST.B	(A6)+OPEFAN+3:#BPEDER ; l'un derrire l'autre ?	JUMP',BC 20$		; non => 20$				; oui =>	TEST.B	(A6)+ODBFAN+3:#BDBOPAQ ; opaque ?	JUMP',BC 10$		; non => 10$	CALL	EFFLIGNE	; oui => efface derrire la facette10$:	TEST.W	D0	JUMP',EQ 20$	TEST.B	(A6)+ODBFAN+3:#BDBSP ; dessine les splines ?	JUMP',BS 12$	TEST.B	(A6)+ODBFAN+3:#BDBDR ; dessine les droites ?	JUMP',BC 20$		; non => 20$12$:				; oui =>	LOAD.L	D3,(A3)-4	; D3 <-- n	LOAD.L	D4,(A4)-4	; D4 <-- n'	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	DEFPTRAIT	; dfini le trait selon D0.L	COMP.W	D2,#-1	JUMP',EQ 20$	OR.W	D2,#SETDOT	CALL	DRLINE		; lie au plan parallle20$:	LOAD.L	D1,D0	SWAP.W	D1	TEST.W	D1	JUMP',EQ 40$	TEST.B	(A6)+ODBFAN+3:#BDBDR ; dessine les droites ?	JUMP',BC 30$		; non => 30$				; oui =>	LOAD.L	D3,(A3)-4	; D3 <-- n	LOAD.L	D4,(A3)-8	; D4 <-- n-1	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	DEFPTRAIT	; dfini le trait selon D0.L	COMP.W	D2,#-1	JUMP',EQ 30$	OR.W	D2,#SETDOT	CALL	DRLINE		; lie au point prcdent30$:	TEST.B	(A6)+ODBFAN+3:#BDBSP ; dessine les splines ?	JUMP',BS 40$		; oui => 40$	TEST.B	(A6)+ODBFAN+3:#BDBPT ; dessine les points ?	JUMP',BC 40$		; non => 40$				; oui =>	LOAD.L	D3,(A3)-8	; D3 <-- n-1	CALL	DESPOINT	; dessine un point40$:	POPM.L	D1..D4	RET;----------\\; DESSPLINE >;----------/; Lie tous les points par une gracieuse spline (si, si !).; in	A3.L	^table des points;	D0.L	coordonne de la case dans le tableau; out	-; mod	D7.WDESSPLINE:	PUSHM.L	D2..D6,A2..A4	TEST.B	(A6)+ODBFAN+3:#BDBSP ; dessine les splines ?	JUMP',BC 90$		; non => 90$				; oui =>	CALL	DEFPTRAIT	; dfini le trait selon D0.L	COMP.W	D2,#-1	JUMP,EQ 90$	OR.W	D2,#SETDOT!NCTDOT	LOAD.L	A2,A320$:	TEST.L	(A2+)	JUMP,NE 20$	LOAD.L	(-A2),#-1	; met terminateur pour module SPLINE	LOAD.W	D3,#8	SPLINE_	OPEN		; A4/D6 <-- ^points/canal	JUMP',NE 60$	LOAD.L	D3,(A4+)	; D3 <-- premier point	COMP.L	D4,#-1	JUMP',EQ 60$40$:	LOAD.L	D4,(A4+)	; D4 <-- point suivant	COMP.L	D4,#-1	JUMP',EQ 60$	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	CALL	DRLINE		; dessine un fragment de spline	JUMP	40$60$:	SPLINE_	CLOSE	CLR.L	(A2)		; remet le terminateur normal	TEST.B	(A6)+ODBFAN+3:#BDBPT ; dessine les points ?	JUMP',BC 90$		; non => 90$65$:	LOAD.L	D3,(A3+)	JUMP',EQ 90$	CALL	DESPOINT	; dessine un point	JUMP	65$90$:	POPM.L	D2..D6,A2..A4	RET;---------\\; DESPOINT >;---------/; Dessine un point.; in	D3.L	origine (y;x); out	-; mod	D7.WDESPOINT:	PUSHM.L	D2..D4	CALL	DEFPPOINT	; dfini le point selon D0.L	COMP.W	D2,#-1	JUMP',EQ 90$	OR.W	D2,#SETDOT	PUSHM.L	D3,D4	SUB.W	D3,#5	SWAP.W	D3	SUB.W	D3,#5	SWAP.W	D3	LOAD.L	D4,#H'10000*10+10	CALL	DRCLEAR		; efface sous le point	POPM.L	D3,D4	CALL	DRDOT		; dessine un point90$:	POPM.L	D2..D4	RET;---------\\; EFFLIGNE >;---------/; Efface sous une facette de ligne brise.; in	(A3)-4	n;	(A3)-8	n-1;	(A4)-4	n';	(A4)-8	n'-1;	D0.L	coordonne de la case dans le tableau; out	-; mod	D7.WEFFLIGNE:	PUSHM.L	D0..D6,A3,A4	TEST.B	(A6)+OPEFAN+3:#BPEFIL ; fil de fer ?	JUMP,BS 90$		; oui => 90$	TEST.W	D0	JUMP,EQ 90$	SWAP.W	D0	TEST.W	D0	JUMP,EQ 90$	SWAP.W	D0	CALL	CLRDISMAT	CALL	OPEDISMAT	LOAD.L	(A6)+OPBRIP,#-1	CLR.L	(A6)+OPBRIG	LOAD.L	D3,(A3)-4	LOAD.L	D4,(A3)-8	CALL	EFFONELIGNE	; ligne n / n-1	LOAD.L	D3,(A3)-8	LOAD.L	D4,(A4)-8	CALL	EFFONELIGNE	; ligne n-1 / n'-1	LOAD.L	D3,(A4)-8	LOAD.L	D4,(A4)-4	CALL	EFFONELIGNE	; ligne  n'-1 / n'	LOAD.L	D3,(A4)-4	LOAD.L	D4,(A3)-4	CALL	EFFONELIGNE	; ligne n' / n	TEST.B	(A6)+OFTDEF:#BDFOMBRE ; ombr ?	JUMP',BC 60$		; non => 60$				; oui =>	CLR.L	D3	LOAD.W	D3,(A3)-4+0	ADD.W	D3,(A4)-4+0	ADD.W	D3,(A4)-8+0	DIV.WU	D3,#3		; D3 <-- moyenne de n, n' et n'-1	SUB.W	D3,(A3)-8+0	; D3 <-- dy	LOAD.W	D4,(A3)-4+2	SUB.W	D4,(A3)-8+2	; D4 <-- dx	MUL.WA	D3,#6	DIV.WA	D3,D4		; D3 <-- pente *6	ADD.W	D3,#4	JUMP',NC 50$	CLR.W	D350$:	COMP.W	D3,#8	JUMP',LS 52$	LOAD.W	D3,#852$:	LOAD.W	D0,D3		; D0 <-- surface (0..4..8)60$:	CALL	EFFMSKLIGNE	; efface la facette90$:	POPM.L	D0..D6,A3,A4	RET;------------\\; EFFONELIGNE >;------------/; Dessine une ligne dans la matrice principale.; in	D3.L	p1;	D4.L	p2; out	-; mod	D7.WEFFONELIGNE:	PUSHM.L	D2..D4	SUB.W	D4,D3		; D4 <-- dx	SUB.W	D3,(A6)+OPBIGX	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SUB.W	D3,(A6)+OPBIGY	SWAP.W	D3	SWAP.W	D4	CALL	EFFMMLIGNE	; mmorise min/max	LOAD.W	D2,#SETDOT	CALL	DRLINE	POPM.L	D2..D4	RET;-----------\\; EFFMMLIGNE >;-----------/; Mmorise le minimum et le maximum.; in	D3.L		point (y;x); out	(A6)+OPBRIP.L	coin sup/gauche;	(A6)+OPBRIG.L	coin inf/droite; mod	D7.WEFFMMLIGNE:	COMP.W	D3,(A6)+OPBRIP+2	JUMP',HS 10$	LOAD.W	(A6)+OPBRIP+2,D3 ; mm. x min10$:	COMP.W	D3,(A6)+OPBRIG+2	JUMP',LS 15$	LOAD.W	(A6)+OPBRIG+2,D3 ; mm. x max15$:	SWAP.W	D3	COMP.W	D3,(A6)+OPBRIP+0	JUMP',HS 20$	LOAD.W	(A6)+OPBRIP+0,D3 ; mm. y min20$:	COMP.W	D3,(A6)+OPBRIG+0	JUMP',LS 25$	LOAD.W	(A6)+OPBRIG+0,D3 ; mm. y max25$:	SWAP.W	D3	RET;------------\\; EFFMSKLIGNE >;------------/; Efface l'intrieur du polygone dessin dans la matrice principale.; in	D0.L	position dans le tableau; out	-; mod	D7.WEFFMSKLIGNE:	PUSHM.L	D0..D6,A3,A4	LOAD.L	D2,(A6)+OPBRIP	; D2 <-- coin sup/droite	LOAD.L	D1,(A6)+OPBRIG	; D1 <-- coin inf/gauche	SUB.W	D2,#4	AND.B	D2,#B'11111000	; D2 <-- x	ADD.W	D1,#4	SUB.W	D1,D2	ADD.W	D1,#8-1	AND.B	D1,#B'11111000	; D1 <-- dx	SWAP.W	D2	SWAP.W	D1	SUB.W	D2,#4	AND.B	D2,#B'11111110	; D2 <-- y	ADD.W	D1,#4	SUB.W	D1,D2	ADD.W	D1,#2-1	AND.B	D1,#B'11111110	; D1 <-- dy	SWAP.W	D2	SWAP.W	D1	PUSH.W	D2	LOAD.L	D3,D2		; D3 <-- position	LOAD.L	D4,D1		; D4 <-- dimensions	LOAD.W	D2,#SETDOT	CALL	DRRECT	POP.W	D2	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	DRTRADEF	LOAD.L	D3,D2	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	CALL	DRFILL		; rempli l'extrieur	PUSH.L	D2	LOAD.L	D3,D2		; D3 <-- position	LOAD.L	D4,D1		; D4 <-- dimensions	TEST.B	(A6)+ODBFAN+3:#BDBTR ; dessine les trames ?	JUMP',BC 40$		; non => 40$	CALL	DEFPTRAME	; dfini la trame selon D0.L	COMP.W	D2,#-1	JUMP',EQ 40$	LOAD.L	A3,(A6)+OPMAT	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAS	; A4 <-- ^matrice destination	CALL	MAXFER		; matrice secondaire <-- matrice principale	LOAD.L	A3,A4		; A3 <-- ^matrice secondaire	NOT.L	(A0)+ODFTRA+0	NOT.L	(A0)+ODFTRA+4	CALL	MATRAME		; trame le tout	CALL	MAINV		; inverse le tout40$:	POP.L	D2	LOAD.L	D3,D2		; D3 <-- position	LOAD.L	D4,D1		; D4 <-- dimensions	LOAD.L	A3,(A6)+OPMAT	; A3 <-- ^matrice	CALL	MAINV		; inverse le tout	CALL	CLODISMAT; Efface l'ombre de la facette dans l'cran.	LOAD.L	D3,D2		; D3 <-- source: (y;x)	LOAD.L	A3,(A6)+OPMAT	LOAD.W	D5,(A6)+ODBIGX	SR.W	D5,#3	LOAD.L	D4,D3		; D4 <-- destination: (y;x)	ADD.W	D4,(A6)+OPBIGX	SWAP.W	D4	ADD.W	D4,(A6)+OPBIGY	SWAP.W	D4	LOAD.L	A4,#0	CLR.W	D6	LOAD.W	D2,#CLRDOT	CALL	DRRASTER	; efface dans l'cran; Trame l'intrieur si ncessaire.	TEST.B	(A6)+ODBFAN+3:#BDBTR ; dessine les trames ?	JUMP',BC 90$		; non => 90$	CALL	DEFPTRAME	; dfini la trame selon D0.L	COMP.W	D2,#-1	JUMP',EQ 90$	LOAD.L	A3,(A6)+OPMAS	LOAD.W	D2,#SETDOT	CALL	DRRASTER	; trame dans l'cran90$:	POPM.L	D0..D6,A3,A4	RET;----------\\; DESBALARG >;----------/; Calcul la largeur d'une barre et la largeur entre deux barres.; in	-; out	(A6)+OBALG0.W	largeur  sauter au dbut;	(A6)+OBALG1.W	largeur d'une barre;	(A6)+OBALG2.W	largeur entre deux barres;	(A6)+OBALG3.W	largeur entre deux groupes de barres;	(A6)+OBALG4.W	largeur d'un groupe  l'autre;	D7.W		erreur; mod	D7.WDESBALARG:	PUSHM.L	D0..D2	CLR.L	D2	LOAD.W	D2,(A6)+ODGRAX	SUB.W	D2,(A6)+OMARGG	SUB.W	D2,(A6)+OMARGD	SUB.W	D2,(A6)+OPERSX	; D2 <-- largeur disponible	LOAD.W	(A6)+OPOSZ,D2	COMP.B	(A6)+OGRAPHE,#ICOGBRI ; ligne brise ?	JUMP,EQ 60$	LOAD.L	D0,(A6)+ODEFAN	COMP.B	(A6)+OGRAPHE,#ICOGEMP ; graphique empil ?	JUMP,EQ 40$		; oui => 	LOAD.L	D0,(A6)+ODCFAN	TEST.B	(A6)+OPEFAN+3:#BPEDER ; l'un derrire l'autre ?	JUMP,BS 40$		; oui => 				; non =>	TEST.L	D0:#BDF150	JUMP',BS 20$	TEST.L	D0:#BDF200	JUMP',BS 20$; Graphique cte  cte sans recouvrement des colonnes.	LOAD.W	D1,(A6)+ODIMX	INC.W	D1	MUL.WU	D1,(A6)+ODIMY	DIV.WU	D2,D1		; D2 <-- largeur entre deux barres	LOAD.W	(A6)+OBALG2,D2	CALL	DESBAMUL	; D2 <-- largeur d'une barre	LOAD.W	(A6)+OBALG1,D2	LOAD.W	(A6)+OBALG3,(A6)+OBALG2	JUMP'	25$; Graphique cte  cte avec recouvrement des colonnes.20$:	LOAD.W	D1,(A6)+ODIMX	ADD.W	D1,#2	MUL.WU	D1,(A6)+ODIMY	DIV.WU	D2,D1		; D2 <-- largeur entre deux barres	LOAD.W	(A6)+OBALG2,D2	CALL	DESBAMUL	LOAD.W	(A6)+OBALG1,D2	LOAD.W	D2,(A6)+OBALG2	SL.W	D2,#1	LOAD.W	(A6)+OBALG3,D225$:	LOAD.W	D2,(A6)+ODIMX	MUL.WU	D2,(A6)+OBALG2	ADD.W	D2,(A6)+OBALG3	LOAD.W	(A6)+OBALG4,D2	JUMP	80$40$:	TEST.L	D0:#BDF150	JUMP',BS 50$	TEST.L	D0:#BDF200	JUMP',BS 50$; Graphique empil sans recouvrement des colonnes.	LOAD.W	D1,(A6)+ODIMY	DIV.WU	D2,D1		; D2 <-- largeur entre deux barres	LOAD.W	(A6)+OBALG2,D2	CALL	DESBAMUL	LOAD.W	(A6)+OBALG1,D2	CLR.W	(A6)+OBALG3	JUMP'	55$; Graphique empil avec recouvrement des colonnes.50$:	LOAD.W	D1,(A6)+ODIMY	ADD.W	D1,#2	DIV.WU	D2,D1		; D2 <-- largeur entre deux barres	LOAD.W	(A6)+OBALG2,D2	CALL	DESBAMUL	LOAD.W	(A6)+OBALG1,D2	LOAD.W	(A6)+OBALG3,D255$:	LOAD.W	(A6)+OBALG4,(A6)+OBALG2	JUMP	80$; Graphique ligne brise.60$:	LOAD.W	D7,#ERGPAVA	LOAD.W	D1,(A6)+ODIMY	DEC.W	D1	JUMP,LE 90$	DIV.WU	D2,D1		; D2 <-- largeur entre deux lignes	LOAD.W	(A6)+OBALG2,D2	LOAD.W	(A6)+OBALG1,D2	CLR.W	(A6)+OBALG3	LOAD.W	(A6)+OBALG4,D2;	JUMP	80$; Calcul la distance initiale  sauter au dbut.80$:	LOAD.W	D2,(A6)+OBALG3	ADD.W	D2,(A6)+OBALG2	SUB.W	D2,(A6)+OBALG1	SR.W	D2,#1	LOAD.W	(A6)+OBALG0,D2	SUB.W	(A6)+OPOSZ,D2	LOAD.W	D7,#ERGSUTP	COMP.W	(A6)+OBALG1,#2	JUMP,LO 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; DESBAMUL >;---------/; Multiplie D2 par le facteur choisi.; in	D0.L	fanions pour le facteur;	D2.W	valeur; out	D2.W	valeur * 0.5  2.00; mod	D2.LDESBAMUL:	PUSH.L	D3	LOAD.W	D3,#25	TEST.L	D0:#BDF025	JUMP',BS 40$	LOAD.W	D3,#50	TEST.L	D0:#BDF050	JUMP',BS 40$	LOAD.W	D3,#75	TEST.L	D0:#BDF075	JUMP',BS 40$	LOAD.W	D3,#100	TEST.L	D0:#BDF100	JUMP',BS 40$	LOAD.W	D3,#150	TEST.L	D0:#BDF150	JUMP',BS 40$	LOAD.W	D3,#200	TEST.L	D0:#BDF200	JUMP',BS 40$	LOAD.W	D3,#10040$:	MUL.WU	D2,D3	DIV.WU	D2,#100	POP.L	D3	RET	.END