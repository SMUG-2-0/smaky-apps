	.SBTTL	GRALISTE;---------\\; DIMLISTE >;=========/; Cherche les dimensions pour dessiner la liste.; in	-; out	D7.W	ok/erreur; mod	D7.WDIMLISTE:	PUSHM.L	D2..D4,A3,A4	CALL	NBDLINUM	; cherche nb max de digits; Calcul les dimensions en hauteur.	LOAD.L	A3,#R16"TGCTIT	; A3 <-- ^titre gencar "Titre"	CALL	GETTGC		; A4 <-- ^dans OBUGC	LOAD.W	D4,(A4)+OGC1Y	ADD.W	D4,(A4)+OGC2Y	; D4 <-- hauteur d'un caractre	LOAD.L	A3,#R16"TGCAX	; A3 <-- ^titre gencar "Axe X"	CALL	GETTGC		; A4 <-- ^dans OBUGC	LOAD.W	D3,(A4)+OGC1Y	ADD.W	D3,(A4)+OGC2Y	; D3 <-- hauteur d'un caractre	COMP.W	D4,D3	JUMP',HS 10$	LOAD.W	D4,D3		; D4 <-- le plus haut10$:	INC.W	D4	LOAD.W	(A6)+OLICY0,D4	LOAD.L	A3,#R16"TGCAY	; A3 <-- ^titre gencar "Axe Y"	CALL	GETTGC		; A4 <-- ^dans OBUGC	LOAD.W	D4,(A4)+OGC1Y	ADD.W	D4,(A4)+OGC2Y	; D4 <-- hauteur d'un caractre	LOAD.L	A3,#R16"TGCFON	; A3 <-- ^titre gencar "Fond"	CALL	GETTGC		; A4 <-- ^dans OBUGC	LOAD.W	D3,(A4)+OGC1Y	ADD.W	D3,(A4)+OGC2Y	; D3 <-- hauteur d'un caractre	COMP.W	D4,D3	JUMP',HS 15$	LOAD.W	D4,D3		; D4 <-- le plus haut15$:	INC.W	D4	LOAD.W	(A6)+OLICY1,D4; Calcul les dimensions en largeur.	LOAD.L	A3,#R16"TGCAY	; A3 <-- ^titre gencar "Axe Y"	LOAD.W	D2,#-1	CALL	DIMLICOL	; D4 <-- largeur colonne "Axe Y"	INC.W	D4	LOAD.W	(A6)+OLICX0,D4	TEST.B	(A6)+ODLFAN+3:#BLIIDEM ; colonnes identiques ?	JUMP',BS 40$		; oui => 40$	LOAD.L	A3,#R16"TGCFON	; A3 <-- ^titre gencar "Fond"	LOAD.L	A4,#(A6)+OLICX1	CLR.W	D2		; D2 <-- coordonne X initiale30$:	CALL	DIMLICOL	; D4 <-- largeur colonne	TEST.W	D4	JUMP',EQ 35$	INC.W	D435$:	LOAD.W	(A4+),D4	INC.W	D2		; D2 <-- coordonne X suivante	COMP.W	D2,(A6)+ODIMX	JUMP,LO 30$	LOAD.W	(A4+),#-1	JUMP	50$40$:	LOAD.L	A3,#R16"TGCFON	; A3 <-- ^titre gencar "Fond"	CLR.W	D2		; D2 <-- coordonne X initiale	CLR.W	D3		; D3 <-- colonne la plus large42$:	CALL	DIMLICOL	; D4 <-- largeur colonne	TEST.W	D4	JUMP',EQ 44$	INC.W	D444$:	COMP.W	D3,D4	JUMP',HS 46$	LOAD.W	D3,D4		; D3 <-- colonne la plus large46$:	INC.W	D2		; D2 <-- coordonne X suivante	COMP.W	D2,(A6)+ODIMX	JUMP,LO 42$	LOAD.L	A4,#(A6)+OLICX1	LOAD.W	D2,(A6)+ODIMX48$:	LOAD.W	(A4+),D3	DEC.W	D2	JUMP,NE 48$	LOAD.W	(A4+),#-1; Vrifie si la liste n'est pas trop grande.50$:	LOAD.W	D7,#ERGSUTP	; D7 <-- surface trop petite	LOAD.W	D4,(A6)+OLICY1	MUL.WU	D4,(A6)+ODIMY	ADD.W	D4,(A6)+OLICY0	; D4 <-- hauteur de la liste	ADD.W	D4,(A6)+OMARGH	ADD.W	D4,(A6)+OMARGB	SUB.W	D4,(A6)+ODGRAY	JUMP,HS 90$	NEG.W	D4	LOAD.W	D3,(A6)+ODIMY	INC.W	D3	DIV.WU	D4,D3	LOAD.W	(A6)+OLIMY,D4	CLR.L	D4	LOAD.W	D4,(A6)+OLICX0	LOAD.L	A4,#(A6)+OLICX160$:	COMP.W	(A4),#-1	JUMP',EQ 65$	ADD.W	D4,(A4+)	; D4 <-- largeur de la liste	JUMP	60$65$:	ADD.W	D4,(A6)+OMARGG	ADD.W	D4,(A6)+OMARGD	SUB.W	D4,(A6)+ODGRAX	JUMP',HS 90$	NEG.W	D4	LOAD.W	D3,(A6)+ODIMX	INC.W	D3	DIV.WU	D4,D3	LOAD.W	(A6)+OLIMX,D4	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; NBDLINUM >;---------/; Cherche le nombre de digits maximum parmis tous les nombres.; in	-; out	(A6)+OLIMDE.W	nb max digits partie entire;	(A6)+OLIMDF.W	nb max digits partie fractionnaire; mod	D7.WNBDLINUM:	PUSHM.L	D0..D4,A3	CLR.W	D0	CLR.W	D1	CLR.L	D2		; D2 <-- coordonne Y initiale40$:	CLR.W	D2		; D2 <-- coordonne X initiale42$:	CALL	GETCH		; A3 <-- ^chane	JUMP',NE 48$	CALL	NBDLINUMONE	; D3/D4 <-- nb digits parties entire/frac	COMP.W	D0,D3	JUMP',HS 44$	LOAD.W	D0,D3		; D0 <-- nb max digits partie entire44$:	COMP.W	D1,D4	JUMP',HS 48$	LOAD.W	D1,D4		; D1 <-- nb max digits partie fractionnaire48$:	INC.W	D2		; D2 <-- coordonne X suivante	COMP.W	D2,(A6)+ODIMX	JUMP,LO 42$	SWAP.W	D2	INC.W	D2		; D2 <-- coordonne Y suivante	LOAD.W	D3,D2	SWAP.W	D2	COMP.W	D3,(A6)+ODIMY	JUMP,LO 40$	LOAD.W	(A6)+OLIMDE,D0	LOAD.W	(A6)+OLIMDF,D1	POPM.L	D0..D4,A3	RET;------------\\; NBDLINUMONE >;------------/; Cherche le nombre de digits d'un nombre.; in	A3.L	^nombre; out	D3.W	nb digits partie entire (avec le ".");	D4.W	nb digits partie fractionnaire; mod	D3.L, D4.L, D7.WNBDLINUMONE:	PUSHM.L	D1,D2,A3	CLR.W	D3	CLR.W	D4	CLR.B	D1		; D1 <-- dans partie entire10$:	LOAD.B	D2,(A3+)	JUMP',EQ 90$	COMP.B	D2,#TAB	JUMP',EQ 90$	COMP.B	D2,#CR	JUMP',EQ 90$	COMP.B	D2,#'.	JUMP',EQ 50$	INC.W	D3	TEST.B	D1		; dans partie entire ?	JUMP,EQ 10$		; oui => 10$	DEC.W	D3	INC.W	D4	JUMP	10$50$:	INC.W	D3		; D3 <-- compte le ".2	INC.B	D1		; D1 <-- dans partie fractionnaire	JUMP	10$90$:	POPM.L	D1,D2,A3	RET;---------\\; DIMLICOL >;---------/; Cherche les dimensions maximales d'une colonne.; in	A3.L	^titre gencar;	D2.W	coordonne X; out	D4.W	largeur; mod	D4.L, D7.WDIMLICOL:	PUSHM.L	D1..D3,A3,A4	CALL	GETTGC		; A4 <-- ^dans OBUGC	CLR.W	D3		; D3 <-- plus grande largeur	AND.L	D2,#H'FFFF20$:	CALL	GETCH		; A3 <-- ^chane	JUMP',NE 50$	COMP.W	D2,#-1		; est-ce une colonne de nombres ?	JUMP',EQ 30$		; non => 30$				; oui =>	CALL	DESLINUM	; A3 <-- ^nombre format30$:	CALL	GETLCH		; D4 <-- lg de la chane	COMP.W	D3,D4	JUMP',HS 50$	LOAD.W	D3,D4		; D3 <-- la plus grande largeur50$:	SWAP.W	D2	INC.W	D2		; D2 <-- coordonne Y suivante	LOAD.W	D1,D2	SWAP.W	D2	COMP.W	D1,(A6)+ODIMY	JUMP,LO 20$	LOAD.W	D4,D3		; D4 <-- la plus grande largeur	POPM.L	D1..D3,A3,A4	RET;---------\\; DESLISTE >;=========/; Dessine toute la liste.; in	-; out	-; mod	D7.WDESLISTE:	PUSHM.L	D1..D4,A2..A4	CALL	DESLICADRE	; dessine le cadre; Dessine le titre en haut  gauche.	LOAD.L	A3,#R16"TGCTIT	; A3 <-- ^titre gencar "Titre"	CALL	GETTGC		; A4 <-- ^dans OBUGC	LOAD.L	A3,#(A4)+OGCCOD	LOAD.B	(A3),#USEGC	LOAD.W	D3,#4	LIB	?STRING		; utilise le bon gencar	LOAD.L	D2,#-1	CALL	GETCH		; A3 <-- ^chane	JUMP',NE 15$	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+OMARGH	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+OMARGG	LOAD.W	D4,(A6)+OLIMX	SR.W	D4,#1	ADD.W	D3,D4	LOAD.W	D4,(A6)+OLICY0	ADD.W	D4,(A6)+OLIMY	; D4 <-- hauteur disponible	SWAP.W	D4	LOAD.W	D4,(A6)+OLICX0	; D4 <-- largeur disponible	CLR.W	D1		; D1 <-- mode align  gauche	CALL	DESLITEXT	; dessine le titre; Dessine les textes sur l'axe X.15$:	LOAD.L	A3,#R16"TGCAX	; A3 <-- ^titre gencar "Axe X"	CALL	GETTGC		; A4 <-- ^dans OBUGC	LOAD.L	A3,#(A4)+OGCCOD	LOAD.B	(A3),#USEGC	LOAD.W	D3,#4	LIB	?STRING		; utilise le bon gencar	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+OMARGH	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+OMARGG	ADD.W	D3,(A6)+OLICX0	ADD.W	D3,(A6)+OLIMX	LOAD.W	D2,#-1		; D2 <-- coordonne Y initiale	SWAP.W	D2	CLR.W	D2		; D2 <-- coordonne X initiale	LOAD.L	A2,#(A6)+OLICX122$:	CALL	GETCH		; A3 <-- ^chane	JUMP',NE 28$	LOAD.W	D4,(A6)+OLICY0	ADD.W	D4,(A6)+OLIMY	; D4 <-- hauteur disponible	SWAP.W	D4	LOAD.W	D4,(A2)	ADD.W	D4,(A6)+OLIMX	; D4 <-- largeur disponible	LOAD.W	D1,#2		; D1 <-- mode centr	CALL	DESLITEXT	; dessine le texte28$:	ADD.W	D3,(A2+)	ADD.W	D3,(A6)+OLIMX	; D3 <-- position X suivante	INC.W	D2		; D2 <-- coordonne X suivante	COMP.W	D2,(A6)+ODIMX	JUMP,LO 22$; Dessine les textes sur l'axe Y.	LOAD.L	A3,#R16"TGCAY	; A3 <-- ^titre gencar "Axe Y"	CALL	GETTGC		; A4 <-- ^dans OBUGC	LOAD.L	A3,#(A4)+OGCCOD	LOAD.B	(A3),#USEGC	LOAD.W	D3,#4	LIB	?STRING		; utilise le bon gencar	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+OMARGH	ADD.W	D3,(A6)+OLICY0	ADD.W	D3,(A6)+OLIMY	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+OMARGG	LOAD.W	D4,(A6)+OLIMX	SR.W	D4,#1	ADD.W	D3,D4	CLR.W	D2		; D2 <-- coordonne Y initiale	SWAP.W	D2	LOAD.W	D2,#-1		; D2 <-- coordonne X initiale32$:	CALL	GETCH		; A3 <-- ^chane	JUMP',NE 38$	LOAD.W	D4,(A6)+OLICY1	ADD.W	D4,(A6)+OLIMY	; D4 <-- hauteur disponible	SWAP.W	D4	LOAD.W	D4,(A6)+OLICX0	; D4 <-- largeur disponible	CLR.W	D1		; D1 <-- mode align  gauche	CALL	DESLITEXT	; dessine le texte38$:	SWAP.W	D3	ADD.W	D3,(A6)+OLICY1	ADD.W	D3,(A6)+OLIMY	; D3 <-- position Y suivante	SWAP.W	D3	SWAP.W	D2	INC.W	D2		; D2 <-- coordonne Y suivante	LOAD.W	D1,D2	SWAP.W	D2	COMP.W	D1,(A6)+ODIMY	JUMP,LO 32$; Dessine le contenu intrieur de la liste.	LOAD.L	A3,#R16"TGCFON	; A3 <-- ^titre gencar "Fond"	CALL	GETTGC		; A4 <-- ^dans OBUGC	LOAD.L	A3,#(A4)+OGCCOD	LOAD.B	(A3),#USEGC	LOAD.W	D3,#4	LIB	?STRING		; utilise le bon gencar	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+OMARGH	ADD.W	D3,(A6)+OLICY0	ADD.W	D3,(A6)+OLIMY	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+OMARGG	ADD.W	D3,(A6)+OLICX0	ADD.W	D3,(A6)+OLIMX	LOAD.W	D4,(A6)+OLIMX	SR.W	D4,#1	ADD.W	D3,D4	CLR.L	D2		; D2 <-- coordonne Y initiale40$:	PUSH.L	D3	CLR.W	D2		; D2 <-- coordonne X initiale	LOAD.L	A2,#(A6)+OLICX142$:	CALL	GETCH		; A3 <-- ^chane	JUMP',NE 48$	CALL	DESLINUM	; A3 <-- ^nombre format	LOAD.W	D4,(A6)+OLICY1	ADD.W	D4,(A6)+OLIMY	; D4 <-- hauteur disponible	SWAP.W	D4	LOAD.W	D4,(A2)		; D4 <-- largeur disponible	LOAD.W	D1,#1		; D1 <-- mode align  droite	CALL	DESLITEXT	; dessine le nombre48$:	ADD.W	D3,(A2+)	ADD.W	D3,(A6)+OLIMX	; D3 <-- position X suivante	INC.W	D2		; D2 <-- coordonne X suivante	COMP.W	D2,(A6)+ODIMX	JUMP,LO 42$	POP.L	D3	SWAP.W	D3	ADD.W	D3,(A6)+OLICY1	ADD.W	D3,(A6)+OLIMY	; D3 <-- position Y suivante	SWAP.W	D3	SWAP.W	D2	INC.W	D2		; D2 <-- coordonne Y suivante	LOAD.W	D1,D2	SWAP.W	D2	COMP.W	D1,(A6)+ODIMY	JUMP,LO 40$	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0	.EVEN	TEST.B	(A6)+ODLFAN+3:#BLITRAM ; met les trames ?	JUMP',BC 90$		; non => 90$	CALL	DESLITRAME	; oui => dessine les trames90$:	POPM.L	D1..D4,A2..A4	RET;---------\\; DESLINUM >;---------/; Formate un nombre pour le mettre dans une liste.; in	A3.L	^nombre; out	A3.L	^nombre format; mod	D7.W, A3.LDESLINUM:	PUSHM.L	D3,D4,A2,A4	TEST.L	(A6)+ODLFAN	JUMP,EQ 90$	TEST.B	(A6)+ODLFAN+3:#BLINID ; nombres identiques ?	JUMP,BS 90$		; oui => 90$	LOAD.L	A4,#(A6)+OBUDIS20$:	LOAD.B	D3,(A3)	JUMP,EQ 30$	COMP.B	D3,#TAB	JUMP,EQ 30$	COMP.B	D3,#CR	JUMP,EQ 30$	COMP.B	D3,#'.		; dbut partie fractionnaire ?	JUMP,EQ 30$		; oui => 30$	INC.L	A3	LOAD.B	(A4+),D3	; OBUDIS <-- partie entire	JUMP	20$30$:	LOAD.L	A2,A3	COMP.B	(A2),#'.	JUMP',NE 32$	INC.L	A232$:	LOAD.B	D3,(A2+)	JUMP',EQ 40$	COMP.B	D3,#TAB	JUMP',EQ 40$	COMP.B	D3,#CR	JUMP',EQ 40$	COMP.B	D3,#'0		; partie fractionnaire nulle ?	JUMP,NE 60$		; non => 60$	JUMP	32$40$:	LOAD.B	D3,#'-	TEST.B	(A6)+ODLFAN+3:#BLINTI	JUMP',BS 50$	LOAD.B	D3,#SPACE	TEST.B	(A6)+ODLFAN+3:#BLINES	JUMP',BS 50$	LOAD.B	D3,#'050$:	LOAD.W	D4,(A6)+OLIMDF	; D4 <-- nb digits partie fractionnaire	JUMP,EQ 80$	LOAD.B	(A4+),#'.	COMP.B	D3,#SPACE	JUMP',NE 52$	LOAD.B	(A4)-1,D352$:	LOAD.B	(A4+),D3	; OBUDIS <-- partie fractionnaire "artificielle"	COMP.B	D3,#'-	JUMP',NE 56$	LOAD.B	D3,#SPACE56$:	DEC.W	D4	JUMP,NE 52$	JUMP	80$60$:	LOAD.B	D3,(A3+)	JUMP',EQ 80$	COMP.B	D3,#TAB	JUMP',EQ 80$	COMP.B	D3,#CR	JUMP',EQ 80$	LOAD.B	(A4+),D3	; OBUDIS <-- partie fractionnaire telle quelle	JUMP	60$80$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^nombre format90$:	POPM.L	D3,D4,A2,A4	RET;----------\\; DESLITEXT >;----------/; Affiche un texte align  gauche,  droite ou centr.; in	D1.W	mode (0=gauche, 1=gauche et 2=centr);	D3.L	position coin sup/gauche (y;x);	D4.L	dimensions disponibles (dy;dx);	A3.L	^texte;	A4.L	^dans OBUGC; out	-; mod	D7.WDESLITEXT:	PUSHM.L	D0..D5	LOAD.L	D0,D3	LOAD.L	D5,D4	CALL	GETMCH		; D3/D4 <-- nb caractres/lg de la chane	LOAD.W	D2,D3		; D2 <-- nb caractres	JUMP,EQ 90$	LOAD.L	D3,D0	TEST.W	D1		; align  gauche ?	JUMP',EQ 35$		; oui => 35$	SUB.W	D5,D4		; D5 <-- largeur inutilise	COMP.W	D1,#2		; centr ?	JUMP',NE 30$		; non => 30$	SR.W	D5,#1		; D5 <-- seulement la moiti30$:	ADD.W	D3,D5		; D3 <-- avance vers la droite35$:	ADD.W	D3,(A4)+OGC1X	INC.W	D3	SWAP.W	D3	SWAP.W	D5	SUB.W	D5,(A4)+OGC1Y	SUB.W	D5,(A4)+OGC2Y	; D5 <-- hauteur inutilise	SR.W	D5,#1		; D5 <-- 1/2 en haut et 1/2 en bas	ADD.W	D5,(A4)+OGC1Y	; D5 <-- sur la ligne de base	ADD.W	D3,D5	INC.W	D3	SWAP.W	D3	LIB	?SETCURS	LOAD.W	D3,D2	LIB	?STRING		; affiche le texte90$:	POPM.L	D0..D5	RET;-----------\\; DESLICADRE >;-----------/; Dessine le cadre complet de la liste.; in	-; out	-; mod	D7.WDESLICADRE:	PUSHM.L	D1..D4,A4	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLAXE	CALL	DEFTRAIT	COMP.W	D2,#-1	JUMP,EQ 20$	OR.W	D2,#SETDOT; Dessine les lignes d'axes horizontales.	CLR.L	D4	LOAD.W	D4,(A6)+OLICX0	ADD.W	D4,(A6)+OLIMX	LOAD.L	A4,#(A6)+OLICX110$:	COMP.W	(A4),#-1	JUMP',EQ 12$	ADD.W	D4,(A4+)	; D4 <-- largeur de la liste	ADD.W	D4,(A6)+OLIMX	JUMP	10$12$:	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+OMARGH	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+OMARGG	PUSH.L	D3	CALL	DRLINE	POP.L	D3	SWAP.W	D3	ADD.W	D3,(A6)+OLICY0	ADD.W	D3,(A6)+OLIMY	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A6)+OLICX0	ADD.W	D4,(A6)+OLIMX	LOAD.W	D1,(A6)+ODIMY;	ADD.W	D1,#1-1		; D1 <-- -1  cause NMO14$:	PUSH.L	D3	CALL	DRLINE	POP.L	D3	SWAP.W	D3	ADD.W	D3,(A6)+OLICY1	ADD.W	D3,(A6)+OLIMY	SWAP.W	D3	DECJ.W,NMO D1,14$; Dessine les lignes d'axes verticales.	LOAD.W	D4,(A6)+OLICY1	ADD.W	D4,(A6)+OLIMY	MUL.WU	D4,(A6)+ODIMY	ADD.W	D4,(A6)+OLICY0	ADD.W	D4,(A6)+OLIMY	SWAP.W	D4	CLR.W	D4	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+OMARGH	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+OMARGG	PUSH.L	D3	CALL	DRLINE	POP.L	D3	ADD.W	D3,(A6)+OLICX0	ADD.W	D3,(A6)+OLIMX	LOAD.W	D4,(A6)+OLICY0	ADD.W	D4,(A6)+OLIMY	SWAP.W	D4	CLR.W	D4	LOAD.L	A4,#(A6)+OLICX1	LOAD.W	D1,(A6)+ODIMX;	ADD.W	D1,#1-1		; D1 <-- -1  cause NMO16$:	PUSH.L	D3	CALL	DRLINE	POP.L	D3	ADD.W	D3,(A4+)	ADD.W	D3,(A6)+OLIMX	DECJ.W,NMO D1,16$; Dessine le rectangle intrieur de la liste.20$:	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+OMARGH	ADD.W	D3,(A6)+OLICY0	ADD.W	D3,(A6)+OLIMY	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+OMARGG	ADD.W	D3,(A6)+OLICX0	ADD.W	D3,(A6)+OLIMX	LOAD.W	D4,(A6)+OLICY1	ADD.W	D4,(A6)+OLIMY	MUL.WU	D4,(A6)+ODIMY	; D4 <-- hauteur intrieure	SWAP.W	D4	CLR.W	D4	LOAD.L	A4,#(A6)+OLICX122$:	COMP.W	(A4),#-1	JUMP',EQ 24$	ADD.W	D4,(A4+)	; D4 <-- largeur intrieure	ADD.W	D4,(A6)+OLIMX	JUMP	22$24$:	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLGRAPHE	CALL	DEFTRAIT	COMP.W	D2,#-1	JUMP',EQ 30$	OR.W	D2,#SETDOT	CALL	DRRECT; Dessine les lignes horizontales de la grille.30$:	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLHGRILLE	CALL	DEFTRAIT	COMP.W	D2,#-1	JUMP',EQ 40$	OR.W	D2,#SETDOT	LOAD.W	D1,(A6)+ODIMY	SUB.W	D1,#1+1		; D1 <-- +1  cause NMO	JUMP',LO 40$	PUSHM.L	D3,D4	AND.L	D4,#H'FFFF34$:	SWAP.W	D3	ADD.W	D3,(A6)+OLICY1	ADD.W	D3,(A6)+OLIMY	SWAP.W	D3	PUSH.L	D3	CALL	DRLINE	POP.L	D3	DECJ.W,NMO D1,34$	POPM.L	D3,D4; Dessine les lignes verticales de la grille.40$:	LOAD.L	A4,#(A6)+OPDDEF+(8+2)*RANGLVGRILLE	CALL	DEFTRAIT	COMP.W	D2,#-1	JUMP',EQ 50$	OR.W	D2,#SETDOT	LOAD.W	D1,(A6)+ODIMX	SUB.W	D1,#1+1		; D1 <-- +1  cause NMO	JUMP',LO 50$	PUSHM.L	D3,D4	CLR.W	D4	LOAD.L	A4,#(A6)+OLICX144$:	ADD.W	D3,(A4+)	ADD.W	D3,(A6)+OLIMX	PUSH.L	D3	CALL	DRLINE	POP.L	D3	DECJ.W,NMO D1,44$	POPM.L	D3,D450$:	POPM.L	D1..D4,A4	RET;-----------\\; DESLITRAME >;-----------/; Dessine les trames ventuelles dans la liste.; in	-; out	-; mod	D7.WDESLITRAME:	PUSHM.L	D2..D4,A4; Dessine la trame d'axe horizontal.	LOAD.L	A4,#(A6)+OTDDEF+8*RANGTHAUT	CALL	DEFTRAME	COMP.W	D2,#-1	JUMP,EQ 20$	OR.W	D2,#SETDOT	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+OMARGH	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+OMARGG	ADD.W	D3,(A6)+OLICX0	ADD.W	D3,(A6)+OLIMX	LOAD.W	D4,(A6)+OLICY0	ADD.W	D4,(A6)+OLIMY	SWAP.W	D4	CLR.W	D4	LOAD.L	A4,#(A6)+OLICX110$:	COMP.W	(A4),#-1	JUMP',EQ 12$	ADD.W	D4,(A4+)	; D4 <-- largeur	ADD.W	D4,(A6)+OLIMX	JUMP	10$12$:	CALL	DRTRAME; Dessine la trame d'axe vertical.20$:	LOAD.L	A4,#(A6)+OTDDEF+8*RANGTDROITE	CALL	DEFTRAME	COMP.W	D2,#-1	JUMP,EQ 30$	OR.W	D2,#SETDOT	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+OMARGH	ADD.W	D3,(A6)+OLICY0	ADD.W	D3,(A6)+OLIMY	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+OMARGG	LOAD.W	D4,(A6)+OLICY1	ADD.W	D4,(A6)+OLIMY	MUL.WU	D4,(A6)+ODIMY	SWAP.W	D4	LOAD.W	D4,(A6)+OLICX0	ADD.W	D4,(A6)+OLIMX	CALL	DRTRAME; Dessine la trame de fond  l'intrieur.30$:	LOAD.L	A4,#(A6)+OTDDEF+8*RANGTFOND	CALL	DEFTRAME	COMP.W	D2,#-1	JUMP,EQ 40$	OR.W	D2,#SETDOT	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+OMARGH	ADD.W	D3,(A6)+OLICY0	ADD.W	D3,(A6)+OLIMY	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+OMARGG	ADD.W	D3,(A6)+OLICX0	ADD.W	D3,(A6)+OLIMX	LOAD.W	D4,(A6)+OLICY1	ADD.W	D4,(A6)+OLIMY	MUL.WU	D4,(A6)+ODIMY	; D4 <-- hauteur intrieure	SWAP.W	D4	CLR.W	D4	LOAD.L	A4,#(A6)+OLICX132$:	COMP.W	(A4),#-1	JUMP',EQ 34$	ADD.W	D4,(A4+)	; D4 <-- largeur intrieure	ADD.W	D4,(A6)+OLIMX	JUMP	32$34$:	CALL	DRTRAME40$:	POPM.L	D2..D4,A4	RET	.END