	.SBTTL	GRACARAC;----------\\; DIMMARGES >;==========/; Calcul les marges.; in	-; out	-; mod	D7.WDIMMARGES:	PUSHM.L	D3,D4	LOAD.W	(A6)+OMARGG,#MARGG	LOAD.W	(A6)+OMARGD,#MARGD	LOAD.W	(A6)+OMARGH,#MARGH	LOAD.W	(A6)+OMARGB,#MARGB	COMP.B	(A6)+OGRAPHE,#ICOGBRI	JUMP',NE 90$	TEST.B	(A6)+OECFAN+2:#BECNOX	JUMP',BC 90$; Avec les lignes brises ayant les noms affichs le long de; l'axe X, il faut de grandes marges  gauche et  droite !	CLR.L	D4	LOAD.W	D4,(A6)+ODGRAX	DIV.WU	D4,(A6)+ODIMY	SR.W	D4,#1	COMP.W	D4,#MARGG	JUMP',LO 90$	LOAD.W	(A6)+OMARGG,D4	LOAD.W	(A6)+OMARGD,D490$:	POPM.L	D3,D4	RET;---------\\; DIMTITRE >;=========/; Calcul la marge en haut ncessaire.; in	-; out	(A6)+OMARGH.W	marge en haut; mod	D7.WDIMTITRE:	PUSHM.L	D3,D4,A3,A4	TEST.B	(A6)+OTIFAN+3:#BTIOUI	JUMP',BC 90$	LOAD.L	A3,#R16"TGCTIT	; A3 <-- ^titre gencar "Titre"	CALL	GETTGC		; A4 <-- ^dans OBUGC	LOAD.W	D4,(A4)+OGC1Y	ADD.W	D4,(A4)+OGC2Y	; D4 <-- hauteur d'un caractre	ADD.W	(A6)+OMARGH,D4	; augmente la marge en haut90$:	POPM.L	D3,D4,A3,A4	RET;---------\\; DESTITRE >;=========/; Dessine le titre.; in	-; out	-; mod	D7.WDESTITRE:	PUSHM.L	D0..D4,A3,A4	TEST.B	(A6)+OTIFAN+3:#BTIOUI	JUMP,BC 90$	LOAD.L	A3,#R16"TGCTIT	; A3 <-- ^titre gencar "Titre"	CALL	GETTGC		; A4 <-- ^dans OBUGC	JUMP,NE 90$	LOAD.L	A3,#(A4)+OGCCOD	LOAD.B	(A3),#USEGC	LOAD.W	D3,#4	LIB	?STRING		; utilise le bon gencar	JUMP,NE 90$	LOAD.L	D2,#-1		; D2 <-- coordonne (-1;-1)	CALL	GETCH		; A3 <-- ^chane	JUMP,NE 80$	LOAD.W	D4,(A6)+ODGRAX	; D4 <-- lg max	SUB.W	D4,#MARGG+MARGD	LOAD.L	D0,D4	CALL	GETMCH		; D3/D4 <-- nb caractres/lg de la chane	LOAD.W	D1,D3		; D1 <-- nb caractres	JUMP,EQ 80$	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,#MARGH/2	ADD.W	D3,(A4)+OGC1Y	SWAP.W	D3	LOAD.W	D3,D0	SUB.W	D3,D4	TEST.B	(A6)+OTIFAN+3:#BTIDR	JUMP',BS 50$	SR.W	D3,#1	TEST.B	(A6)+OTIFAN+3:#BTICE	JUMP',BS 50$	CLR.W	D350$:	ADD.W	D3,#MARGG	ADD.W	D3,(A6)+OPBIGX	LIB	?SETCURS	LOAD.W	D3,D1		; D3 <-- nb de caractres	LIB	?STRING		; affiche le titre80$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0	.EVEN90$:	POPM.L	D0..D4,A3,A4	RET;---------\\; DIMGRADX >;=========/; Calcul la marge en bas ncessaire.; in	(A6)+OMARGH.W	marge en haut;	(A6)+OMARGB.W	marge en bas; out	(A6)+OMARGB.W	marge en bas; mod	D7.WDIMGRADX:	PUSHM.L	D3,D4,A3,A4	TEST.B	(A6)+OECFAN+2:#BECNOX	JUMP',BC 90$	LOAD.L	A3,#R16"TGCAX	; A3 <-- ^titre gencar "Axe X"	CALL	GETTGC		; A4 <-- ^dans OBUGC	LOAD.W	D4,(A4)+OGC1Y	ADD.W	D4,(A4)+OGC2Y	; D4 <-- hauteur d'un caractre	ADD.W	(A6)+OMARGB,D4	; augmente la marge en bas90$:	POPM.L	D3,D4,A3,A4	RET;---------\\; DESGRADX >;=========/; Dessine la graduation horizontale (axe X).; in	-; out	-; mod	D7.WDESGRADX:	PUSHM.L	D0..D4,A3..A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	CALL	POSGRADX	TEST.B	(A6)+OECFAN+2:#BECNOX	JUMP',BC 10$	LOAD.L	A3,#R16"TGCAX	; A3 <-- ^titre gencar "Axe X"	CALL	GETTGC		; A4 <-- ^dans OBUGC	JUMP,NE 90$	LOAD.L	A3,#(A4)+OGCCOD	LOAD.B	(A3),#USEGC	LOAD.W	D3,#4	LIB	?STRING		; utilise le bon gencar	JUMP,NE 90$10$:	CLR.W	D2	SWAP.W	D2	LOAD.W	D2,#-120$:	CALL	ONEGRADX	; affiche un nom	SWAP.W	D2	INC.W	D2	LOAD.W	D3,D2	SWAP.W	D2	COMP.B	(A6)+OGRAPHE,#ICOGBRI	JUMP',EQ 50$	COMP.W	D3,(A6)+ODIMY	JUMP,LS 20$		; LS car va un plus loin !	JUMP'	80$50$:	COMP.W	D3,(A6)+ODIMY	JUMP,LO 20$80$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0	.EVEN90$:	POPM.L	D0..D4,A3..A5	RET;---------\\; ONEGRADX >;---------/; Affiche un nom sous l'axe X.; in	D2.L	position dans le tableau (y;x);	A4.L	^dans OBUGC; out	-; mod	D7.WONEGRADX:	PUSHM.L	D0..D4,A3	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+ODGRAY	SUB.W	D3,(A6)+OMARGB	ADD.W	D3,#MARGA	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+OMARGG	LOAD.L	D1,D2	SWAP.W	D1	MUL.WU	D1,(A6)+OBALG4	ADD.W	D3,D1	LOAD.W	D1,(A6)+OPBIGX	ADD.W	D1,(A6)+ODGRAX	SUB.W	D1,(A6)+OMARGD	SUB.W	D1,(A6)+OPERSX	SUB.W	D1,D3	LOAD.W	(A6)+OPOSZ,D1	CALL	ZPOINT	LOAD.L	D0,D3		; D0 <-- position	TEST.B	(A6)+OECFAN+3:#BECGRX	JUMP,BC 50$	TEST.B	(A6)+OECFAN+1:#BECGRE	JUMP',BC 30$	PUSHM.L	D2..D4	LOAD.L	D3,D0	LOAD.W	D4,#+MARGB/2	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	CALL	DRLINE		; petite graduation externe	POPM.L	D2..D430$:	TEST.B	(A6)+OECFAN+1:#BECGRI	JUMP',BC 50$	PUSHM.L	D2..D4	LOAD.L	D3,D0	LOAD.W	D4,#-MARGB/2	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	CALL	DRLINE		; petite graduation interne	POPM.L	D2..D450$:	TEST.B	(A6)+OECFAN+2:#BECNOX	JUMP',BC 90$	LOAD.L	D3,D2	SWAP.W	D3	COMP.W	D3,(A6)+ODIMY	JUMP',HS 90$	CALL	GETCH		; A3 <-- ^chane	JUMP',NE 90$	LOAD.W	D4,(A6)+OBALG4	; D4 <-- lg max	CALL	GETMCH		; D3/D4 <-- nb caractres/lg de la chane	LOAD.W	D1,D3		; D1 <-- nb caractres	JUMP',EQ 90$	LOAD.L	D3,D0		; D3 <-- position	SWAP.W	D3	ADD.W	D3,#(MARGB/2)+3	ADD.W	D3,(A4)+OGC1Y	SWAP.W	D3	ADD.W	D3,(A6)+OBALG0	SR.W	D4,#1	SUB.W	D3,D4	LIB	?SETCURS	LOAD.W	D3,D1		; D3 <-- nb de caractres	LIB	?STRING		; affiche la (partie de) chane90$:	POPM.L	D0..D4,A3	RET;---------\\; POSGRADX >;---------/; Calcul les positions pour l'axe X.; in	-; out	(A6)+OBALG0.W	saut initial pour les noms;	(A6)+OBALG4.W	espacement; mod	D7.WPOSGRADX:	PUSH.L	D2	CALL	DESBALARG	; OBALGn <-- largeurs	JUMP',NE 90$	CLR.W	(A6)+OBALG0	COMP.B	(A6)+OGRAPHE,#ICOGBRI ; graphique ligne brise ?	JUMP',EQ 90$		; oui => 90$	LOAD.W	D2,(A6)+OBALG4	SR.W	D2,#1	LOAD.W	(A6)+OBALG0,D290$:	POP.L	D2	RET;---------\\; DIMGRADZ >;=========/; Calcul la marge gauche ncessaire.; in	(A6)+OMARGH.W	marge en haut;	(A6)+OMARGB.W	marge en bas; out	(A6)+OMARGG.W	marge  gauche; mod	D7.WDIMGRADZ:	PUSHM.L	D3,D4,A3,A4	CALL	CALCGRADZ	TEST.B	(A6)+OECFAN+2:#BECNOZ	JUMP',BC 90$	LOAD.L	A3,#R16"TGCAZ	; A3 <-- ^titre gencar "Axe Z"	CALL	GETTGC		; A4 <-- ^dans OBUGC	LOAD.L	A3,#R16"00$	CALL	GETLCH		; D4 <-- largeur d'un digit	MUL.WU	D4,(A6)+OGRADL	ADD.W	D4,#MARGG	COMP.W	D4,(A6)+OMARGG	; marge dj assez grande ?	JUMP',LS 90$		; oui => 90$				; non =>	LOAD.W	(A6)+OMARGG,D4	; augmente la marge gauche90$:	POPM.L	D3,D4,A3,A4	RET00$:	.ASCIZ	"0"		; juste un digit	.EVEN;--------\\; OKGRADZ >;========/; Vrifie si la graduation n'est pas trop serre.; in	-; out	D7.W	ok/erreur; mod	D7.WOKGRADZ:	PUSHM.L	D0..D4,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	LOAD.L	D3,(A6)+OMAX+0	LOAD.L	D4,(A6)+OMAX+4	PUSH.L	D4	CALL	CONVMULY	LOAD.L	D0,D4		; D0 <-- hauteur dans l'cran	POP.L	D4	LOAD.L	D1,(A6)+OGRAD+0	LOAD.L	D2,(A6)+OGRAD+4	MATH64_	DIV	MATH64_	SEP	MATH64_	FPBIN	INC.W	D4		; D4 <-- nb de divisions	LOAD.W	D7,#ERGSUTP	; D7 <-- trop serr	COMP.W	D4,D0	JUMP',HS 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D4,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DESGRADZ >;=========/; Dessine la graduation verticale (axe Z).; in	-; out	-; mod	D7.WDESGRADZ:	PUSHM.L	D0..D4,A3..A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	TEST.B	(A6)+OECFAN+2:#BECNOZ	JUMP',BC 10$	CALL	OKGRADZ		; graduation trop serre ?	JUMP,NE 90$		; oui => 90$	LOAD.L	A3,#R16"TGCAZ	; A3 <-- ^titre gencar "Axe Z"	CALL	GETTGC		; A4 <-- ^dans OBUGC	JUMP,NE 90$	LOAD.L	A3,#(A4)+OGCCOD	LOAD.B	(A3),#USEGC	LOAD.W	D3,#4	LIB	?STRING		; utilise le bon gencar	JUMP,NE 90$; Dessine la graduation en dessous du zro.10$:	LOAD.L	D3,(A6)+OMIN+0	LOAD.L	D4,(A6)+OMIN+4	MATH64_	NEG	LOAD.L	D1,(A6)+OGRAD+0	LOAD.L	D2,(A6)+OGRAD+4	MATH64_	DIV	MATH64_	SEP	MATH64_	FPBIN	INC.W	D4	LOAD.W	D0,D4		; D0 <-- nb de divisions	CLR.W	D1		; D1 <-- rang	CLR.L	D3	CLR.L	D4		; D3D4 <-- zro20$:	CALL	ONEGRADZ	PUSHM.L	D1,D2	LOAD.L	D1,(A6)+OGRAD+0	LOAD.L	D2,(A6)+OGRAD+4	MATH64_	SUB		; D3D4 <-- valeur en dessous	POPM.L	D1,D2	INC.W	D1	DEC.W	D0	JUMP,NE 20$; Dessine la graduation en dessus du zro.	LOAD.L	D3,(A6)+OMAX+0	LOAD.L	D4,(A6)+OMAX+4	LOAD.L	D1,(A6)+OGRAD+0	LOAD.L	D2,(A6)+OGRAD+4	MATH64_	DIV	MATH64_	SEP	MATH64_	FPBIN	INC.W	D4	LOAD.W	D0,D4		; D0 <-- nb de divisions	CLR.W	D1		; D1 <-- rang	CLR.L	D3	CLR.L	D4		; D3D4 <-- zro40$:	CALL	ONEGRADZ	PUSHM.L	D1,D2	LOAD.L	D1,(A6)+OGRAD+0	LOAD.L	D2,(A6)+OGRAD+4	MATH64_	ADD		; D3D4 <-- valeur en dessus	POPM.L	D1,D2	INC.W	D1	DEC.W	D0	JUMP,NE 40$80$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0	.EVEN90$:	POPM.L	D0..D4,A3..A5	RET;---------\\; ONEGRADZ >;---------/; Affiche une graduation pour l'axe Z.; in	D1.W	rang de la division;	D3D4	valeur;	A4.L	^dans OBUGC; out	-; mod	D7.WONEGRADZ:	PUSHM.L	D0..D4,A3,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	PUSHM.L	D1,D3,D4	LOAD.L	D1,D3	LOAD.L	D2,D4	LOAD.L	D3,(A6)+OMAX+0	LOAD.L	D4,(A6)+OMAX+4	MATH64_	SUB		; D3D4 <-- MAX-valeur	CALL	CONVMULY	LOAD.W	D3,D4	ADD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+OMARGH	ADD.W	D3,(A6)+OPERSY	SWAP.W	D3	LOAD.W	D3,(A6)+OPBIGX	LOAD.L	D0,D3		; D0 <-- position	POPM.L	D1,D3,D4	TEST.B	(A6)+OECFAN+3:#BECGRZ	JUMP,BC 40$	TEST.B	(A6)+OECFAN+1:#BECGRE	JUMP',BC 30$	PUSHM.L	D3,D4	LOAD.L	D3,D0		; D3 <-- position	ADD.W	D3,(A6)+OMARGG	CLR.L	D4	LOAD.W	D4,#-MARGG/2	TEST.L	D1:#0	JUMP',BC 25$	LOAD.W	D4,#-MARGG/425$:	LOAD.W	D2,#SETDOT	CALL	DRLINE		; petite graduation externe	POPM.L	D3,D430$:	TEST.B	(A6)+OECFAN+1:#BECGRI	JUMP',BC 40$	PUSHM.L	D3,D4	LOAD.L	D3,D0		; D3 <-- position	ADD.W	D3,(A6)+OMARGG	CLR.L	D4	LOAD.W	D4,#+MARGG/2	TEST.L	D1:#0	JUMP',BC 35$	LOAD.W	D4,#+MARGG/435$:	LOAD.W	D2,#SETDOT	CALL	DRLINE		; petite graduation interne	POPM.L	D3,D440$:	TEST.B	(A6)+OECFAN+2:#BECNOZ	JUMP,BC 90$	TEST.L	D1:#0	JUMP,BS 90$	PUSHM.L	D3,D4	LOAD.L	D3,D0		; D3 <-- position	SWAP.W	D3	LOAD.W	D4,(A4)+OGC1Y	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	ADD.W	D3,#MARGG/4	LIB	?SETCURS	; positionne le curseur	POPM.L	D3,D4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	D0,#2^BM64POW!2^BM64CDRT	LOAD.B	D0,(A6)+OGRADL+1 ; D0 <-- nb total de signes	SWAP.W	D0	LOAD.B	D0,(A6)+OGRADN+1 ; D0 <-- nb de dcimales	NEG.B	D0	SWAP.W	D0	MATH64_	FP_ASC		; OBUDIS <-- nb en ASCII	LIB	?AFTEXT		; affiche le nombre90$:	POPM.L	D0..D4,A3,A5	RET;-----------\\; DESLEGENDE >;===========/; Dessine toute la lgende.; in	D3.L	coin sup/gauche (y;x);	D4.L	dimensions; out	-; mod	D7.WDESLEGENDE:	PUSHM.L	D2..D4,A3,A4	LOAD.L	(A6)+OLEPOS,D3	CALL	CTRLEGENDE	; OLECTR <-- position relative	LOAD.W	D2,#SETDOT	CALL	DRCLEAR	TEST.B	(A6)+OLEFAN+3:#BLEGR	JUMP',BC 10$	CALL	DRRECT		; dessine le grand rectangle10$:	LOAD.L	D4,D3		; D4 <-- position	LOAD.L	A3,#R16"TGCLEG	; A3 <-- ^titre gencar lgende	CALL	GETTGC		; A4 <-- ^dans OBUGC	JUMP,NE 90$	LOAD.L	A3,#(A4)+OGCCOD	LOAD.B	(A3),#USEGC	LOAD.W	D3,#4	LIB	?STRING		; utilise le bon gencar	JUMP,NE 90$	LOAD.L	D3,D4	SWAP.W	D3	ADD.W	D3,#3	ADD.W	D3,(A4)+OGC1Y	; D3 <-- sur la ligne de base	SWAP.W	D3	LOAD.W	D2,#-1	SWAP.W	D2	CLR.W	D220$:	CALL	ONELEGENDE	; affiche une lgende	JUMP',NE 40$	SWAP.W	D3	ADD.W	D3,(A4)+OGC1Y	ADD.W	D3,(A4)+OGC2Y	; D3 <-- position ligne suivante	SWAP.W	D340$:	INC.W	D2	COMP.W	D2,(A6)+ODIMX	JUMP,LO 20$	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0	.EVEN90$:	POPM.L	D2..D4,A3,A4	RET;-----------\\; ONELEGENDE >;-----------/; Dessine une lgende d'une ligne.; in	D2.L	coordonne dans tableau (y;x);	D3.L	position dans l'cran (y;x);	A4.L	^dans OBUGC; out	D7.W	erreur si pas de lgende; mod	D7.WONELEGENDE:	PUSHM.L	D0..D4,A2,A3	CALL	GETCH		; A3 <-- ^chane	JUMP',NE 90$	LOAD.L	A2,A3	LOAD.W	D1,#-110$:	INC.W	D1	LOAD.B	D4,(A2+)	JUMP',EQ 20$	COMP.B	D4,#CR	JUMP',EQ 20$	COMP.B	D4,#TAB	JUMP,NE 10$20$:	LOAD.W	D7,#ERGRAPH	; D7 <-- y'a rien !	TEST.W	D1	JUMP,EQ 90$	CALL	GRALEGENDE	LOAD.W	D4,(A4)+OGCX	MUL.WU	D4,#1+3+1	ADD.W	D3,D4	LIB	?SETCURS	LOAD.W	D3,D1		; D3 <-- lg de la chane	LIB	?STRING		; affiche le texte de la lgende	CLR.W	D7		; D7 <-- lgende affiche90$:	POPM.L	D0..D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; GRALEGENDE >;-----------/; Dessine le symbole graphique d'une lgende.; in	D2.L	coordonne dans tableau (y;x);	D3.L	position dans l'cran (y;x);	A4.L	^dans OBUGC; out	-; mod	D7.WGRALEGENDE:	PUSHM.L	D0..D4	LOAD.L	D0,D2		; D0 <-- coordonne dans tableau	ADD.W	D3,(A4)+OGCX	; D3 <-- x	SWAP.W	D3	SUB.W	D3,(A4)+OGC1Y	; D3 <-- y	SWAP.W	D3	LOAD.W	D4,(A4)+OGCX	MUL.WU	D4,#3		; D4 <-- dx	SWAP.W	D4	LOAD.W	D4,(A4)+OGC1Y	INC.W	D4		; D4 <-- dy	SWAP.W	D4	TEST.B	(A6)+OLEFAN+3:#BLEPR	JUMP',BC 30$	LOAD.W	D2,#SETDOT	CALL	DRRECT		; dessine le petit rectangle autour30$:	COMP.B	(A6)+OGRAPHE,#ICOGBRI	JUMP',EQ 50$	CALL	DEFPTRAME	; dfini la trame selon D0.L	COMP.W	D2,#-1	JUMP,EQ 90$	OR.W	D2,#SETDOT	CALL	DRTRAME	JUMP	90$50$:	TEST.B	(A6)+OLEFAN+3:#BLELI	JUMP,BS 60$	CALL	DEFPPOINT	; dfini le point selon D0.L	COMP.W	D2,#-1	JUMP,EQ 90$	OR.W	D2,#SETDOT	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	CALL	DRDOT	JUMP'	90$60$:	CALL	DEFPTRAIT	; dfini le trait selon D0.L	COMP.W	D2,#-1	JUMP',EQ 90$	OR.W	D2,#SETDOT	ADD.W	D3,#2	SUB.W	D4,#2+2	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	CLR.W	D4	SWAP.W	D3	SWAP.W	D4	CALL	DRLINE90$:	POPM.L	D0..D4	RET;------------\\; CLIPLEGENDE >;============/; Inverse le rectangle de la lgende.; in	D4.L	position de la souris; out	D4.L	position pour la lgende (coin sup/gauche); mod	D4.L, D7.WCLIPLEGENDE:	PUSH.L	D3	LOAD.W	D3,(A6)+OLEDIM+2	SR.W	D3,#1	SUB.W	D4,D3	COMP.W	D4,(A6)+OPBIGX	; trop  gauche ?	JUMP',GE 10$	LOAD.W	D4,(A6)+OPBIGX10$:	LOAD.W	D3,(A6)+OPBIGX	ADD.W	D3,(A6)+ODGRAX	SUB.W	D3,(A6)+OLEDIM+2	COMP.W	D4,D3		; trop  droite ?	JUMP',LO 20$	LOAD.W	D4,D3	DEC.W	D420$:	SWAP.W	D4	LOAD.W	D3,(A6)+OLEDIM+0	SR.W	D3,#1	SUB.W	D4,D3	COMP.W	D4,(A6)+OPBIGY	; trop en haut ?	JUMP',GE 30$	LOAD.W	D4,(A6)+OPBIGY30$:	LOAD.W	D3,(A6)+OPBIGY	ADD.W	D3,(A6)+ODGRAY	SUB.W	D3,(A6)+OLEDIM+0	COMP.W	D4,D3		; trop en bas ?	JUMP',LO 40$	LOAD.W	D4,D3	DEC.W	D440$:	SWAP.W	D4	POP.L	D3	RET;------------\\; INVLEGENDE  >;============/; Inverse le rectangle de la lgende.; in	D4.L	position de la lgende; out	-; mod	D7.WINVLEGENDE:	PUSHM.L	D2..D4	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OLEDIM	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	.B	1	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT	POPM.L	D2..D4	RET;-----------\\; CTRLEGENDE >;===========/; Calcul la position relative.; in	(A6)+OLEPOS.L	position relle (y;x);	(A6)+OLEDIM.L	dimensions relle (dy;dx); out	(A6)+OLECTR.L	position relative du centre; mod	D7.WCTRLEGENDE:	PUSH.L	D3	LOAD.W	D3,(A6)+OLEDIM+2	SR.W	D3,#1	ADD.W	D3,(A6)+OLEPOS+2	SUB.W	D3,(A6)+OPBIGX	MUL.WU	D3,#1000	DIV.WU	D3,(A6)+ODGRAX	LOAD.W	(A6)+OLECTR+2,D3	LOAD.W	D3,(A6)+OLEDIM+0	SR.W	D3,#1	ADD.W	D3,(A6)+OLEPOS+0	SUB.W	D3,(A6)+OPBIGY	MUL.WU	D3,#1000	DIV.WU	D3,(A6)+ODGRAY	LOAD.W	(A6)+OLECTR+0,D3	POP.L	D3	RET;-----------\\; POSLEGENDE >;===========/; Calcul la position relle.; in	(A6)+OLECTR.L	position relative du centre;	(A6)+OLEDIM.L	dimensions relle (dy;dx); out	(A6)+OLEPOS.L	position relle (y;x); mod	D7.WPOSLEGENDE:	PUSHM.L	D3,D4	LOAD.W	D3,(A6)+OLECTR+2	MUL.WU	D3,(A6)+ODGRAX	DIV.WU	D3,#1000	LOAD.W	D4,(A6)+OLEDIM+2	SR.W	D4,#1	ADD.W	D3,D4	COMP.W	D3,(A6)+ODGRAX	JUMP',LO 20$	LOAD.W	D3,(A6)+ODGRAX	DEC.W	D320$:	SUB.W	D3,(A6)+OLEDIM+2	JUMP',HS 25$	CLR.W	D325$:	ADD.W	D3,(A6)+OPBIGX	LOAD.W	(A6)+OLEPOS+2,D3	LOAD.W	D3,(A6)+OLECTR+0	MUL.WU	D3,(A6)+ODGRAY	DIV.WU	D3,#1000	LOAD.W	D4,(A6)+OLEDIM+0	SR.W	D4,#1	ADD.W	D3,D4	COMP.W	D3,(A6)+ODGRAY	JUMP',LO 40$	LOAD.W	D3,(A6)+ODGRAY	DEC.W	D340$:	SUB.W	D3,(A6)+OLEDIM+0	JUMP',HS 45$	CLR.W	D345$:	ADD.W	D3,(A6)+OPBIGY	LOAD.W	(A6)+OLEPOS+0,D3	POPM.L	D3,D4	RET;-----------\\; DIMLEGENDE >;===========/; Calcul les dimensions ncessaires pour la lgende.; in	-; out	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D4.L, D7.WDIMLEGENDE:	PUSHM.L	D0..D3,A3,A4	CLR.W	D7		; D7 <-- ok	CLR.L	D4		; D4 <-- dimensions nulles	TEST.B	(A6)+OLEFAN+3:#BLEOUI	JUMP,BC 90$	LOAD.L	A3,#R16"TGCLEG	; A3 <-- ^titre gencar lgende	CALL	GETTGC		; A4 <-- ^dans OBUGC	JUMP,NE 90$	CLR.W	D7		; D7 <-- ok	TEST.L	(A6)+OPGRA	JUMP,EQ 90$	CLR.W	D0		; D0 <-- hauteur	CLR.W	D1		; D1 <-- largeur	LOAD.W	D2,#-1	SWAP.W	D2	CLR.W	D220$:	CALL	GETCH		; A3 <-- ^chane	JUMP',NE 50$	CALL	GETLCH		; D4 <-- lg de la chane	TEST.W	D4	JUMP',EQ 50$	ADD.W	D0,(A4)+OGC1Y	ADD.W	D0,(A4)+OGC2Y	; D0 <-- hauteur	COMP.W	D1,D4	JUMP',HS 50$	LOAD.W	D1,D4		; D1 <-- plus grande largeur50$:	INC.W	D2	COMP.W	D2,(A6)+ODIMX	JUMP,LO 20$	ADD.W	D0,#2+2	LOAD.W	D2,(A4)+OGCX	MUL.WU	D2,#1+3+1+1	ADD.W	D1,D2	LOAD.W	D4,D0	SWAP.W	D4	LOAD.W	D4,D1		; D4 <-- dimensions (dy;dx)	LOAD.W	D7,#ERGLETG	; D7 <-- trop grand	COMP.W	D4,(A6)+ODGRAX	; trop large ?	JUMP',HS 90$	SWAP.W	D4	COMP.W	D4,(A6)+ODGRAY	; trop haut ?	JUMP',HS 90$	SWAP.W	D4	CLR.W	D7		; D7 <-- ok90$:	LOAD.L	(A6)+OLEDIM,D4	POPM.L	D0..D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETLCH  >;========/; Calcul la longueur d'une chane, en tenant compte des; caractres  chasse variable.; in	A3.L	^chane termine par <0>, <CR> ou <TAB>;	A4.L	^dans OBUGC; out	D4.W	longueur de la chane; mod	D4.L, D7.WGETLCH:	PUSHM.L	D2,D3,A3,A4	LOAD.L	A4,(A4)+OGCPT	; A4 <-- ^gencar	CLR.W	D410$:	CLR.W	D3	LOAD.B	D3,(A3+)	JUMP',EQ 90$	COMP.B	D3,#CR	JUMP',EQ 90$	COMP.B	D3,#TAB	JUMP',EQ 90$;;?	SUB.B	D3,(A4)+OGCFCA	ADD.W	D3,#256	CLR.W	D2	LOAD.B	D2,(A4)+(D3.W)	; D2 <-- largeur	ADD.W	D4,D2		; D4 <-- somme des largeurs	JUMP	10$90$:	POPM.L	D2,D3,A3,A4	RET;--------\\; GETMCH  >;========/; Calcul la longueur d'une chane, en tenant compte des; caractres  chasse variable.; in	A3.L	^chane termine par <0>, <CR> ou <TAB>;	A4.L	^dans OBUGC;	D4.W	longueur maximale; out	D4.W	longueur de la chane;	D3.W	nb de caractres; mod	D3.L, D4.L, D7.WGETMCH:	PUSHM.L	D0..D2,A3,A4	LOAD.L	A4,(A4)+OGCPT	; A4 <-- ^gencar	LOAD.W	D0,D4		; D0 <-- lg max	CLR.W	D1		; D1 <-- nb de caractres	CLR.W	D410$:	CLR.W	D3	LOAD.B	D3,(A3+)	JUMP',EQ 90$	COMP.B	D3,#CR	JUMP',EQ 90$	COMP.B	D3,#TAB	JUMP',EQ 90$;;?	SUB.B	D3,(A4)+OGCFCA	ADD.W	D3,#256	CLR.W	D2	LOAD.B	D2,(A4)+(D3.W)	; D2 <-- largeur	SUB.W	D0,D2	JUMP',LO 90$	ADD.W	D4,D2		; D4 <-- somme des largeurs	INC.W	D1		; D1 <-- un caractre de plus	JUMP	10$90$:	LOAD.W	D3,D1		; D3 <-- nb de caractres	POPM.L	D0..D2,A3,A4	RET;--------\\; GETTGC  >;========/; Cherche le pointeur dans OBUGC en fonction d'un titre.; in	A3.L	^titre; out	A4.L	^dans OBUGC;	D7.W	erreur; mod	D7.W, A4.LGETTGC:	PUSH.L	D4	LOAD.L	A4,#(A6)+OBUGC	DGENC_	SEARCH	JUMP',EQ 90$	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- prend "Fond"90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETPGC  >;========/; Donne le pointeur dans OBUGC au gencar actullement utilis.; in	-; out	A4.L	^dans OBUGC; mod	A4.LGETPGC:	PUSHM.L	D3,D4	LOAD.L	D4,(A6)+OFAGC	; D4 <-- fanions dbox gencar	JUMP',EQ 50$	LOAD.W	D3,#-120$:	INC.W	D3		; D3 <-- compte le rang du bit dans D4	RR.L	D4	JUMP,CC 20$	LOAD.L	A4,#(A6)+OBUGC	MUL.WU	D3,#LGGC	ADD.L	A4,D3	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BS 90$		; oui => 90$50$:	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- prend "Fond"90$:	POPM.L	D3,D4	RET;----------\\; DBOXCARAC >;==========/; Dialogue pour la DBOX des gencars.; in	-; out	D7.W	erreur; mod	D7.WDBOXCARAC:	PUSHM.L	D0..D5,A0..A510$:	LOAD.L	D4,(A6)+OFAGC	; D4 <-- fanions	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A5,#(A6)+OGCLIST; A5 <-- ^liste des gencars sur disque	LOAD.W	D5,#MAXGENC*3	; D5 <-- lg pour la liste	LOAD.L	D1,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	DGENC_	MODIF		; modifie un/qq gencar(s) ...	JUMP',NE 90$	LOAD.L	(A6)+OFAGC,D4	; mm. derniers fanions utiliss	COMP.W	D3,#F1		; MODIFIE ?	JUMP,EQ 10$	COMP.W	D3,#F4		; SUPPRIME ?	JUMP',NE 90$	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	KILL		; libre le gencar	JUMP	10$90$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	POPM.L	D0..D5,A0..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DEFGENCAR >;==========/; Utilise tous les gencars par dfaut.; Conserve 20 Kbytes de mmoire libre !; in	-; out	-; mod	D7.WDEFGENCAR:	PUSHM.L	D3,D4,D5,A2..A5	LOAD.L	A5,#R16"TGDEF	LOAD.L	A4,#(A6)+OBUGC	LOAD.B	D3,#2^BGCPROT20$:	TEST.B	(A5)		; fin de la table ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	A3,#(A4)+OGCTIT30$:	LOAD.B	(A3+),(A5+)	; OBUGC <-- titre	JUMP,NE 30$	LOAD.B	(A4)+OGCFLG,D3	LOAD.B	(A4)+OGCF,(A5+)	; OBUGC <-- fonte	LOAD.B	(A4)+OGCS,(A5+)	; OBUGC <-- style	LOAD.B	(A4)+OGCT,(A5+)	; OBUGC <-- taille	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	NEW	JUMP',NE 60$	COMP.B	D3,#2^BGCPROT	; premier gencar (Fond) ?	JUMP',EQ 60$		; oui => 60$				; non =>	GESMEM	?ARGMEM		; D5 <-- zone libre conscutive	COMP.L	D5,#20000	; reste assez ?	JUMP',LO 80$		; non => 80$60$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- suivant dans OBUGC	CLR.B	D3		; D3 <-- protection seulement pour 1er	JUMP	20$80$:	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	KILL90$:	POPM.L	D3,D4,D5,A2..A5	RET;----------\\; KILGENCAR >;==========/; Libre tous les gencars.; in	-; out	-; mod	D7.WKILGENCAR:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#(A6)+OBUGC	LOAD.L	A4,A3	LOAD.W	D3,#MAXGC-120$:	CLR.L	D4	DGENC_	KILL	LOAD.L	A4,#(A4)+LGGC	; A4 <-- suivant dans OBUGC	DECJ.W,NMO D3,20$	POPM.L	D3,D4,A3,A4	RET	.END