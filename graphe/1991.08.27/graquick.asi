	.SBTTL	GRAQUICK;--------\\; SAVGRA  >;========/; Sauve tout le graphique.; in	-; out	-; mod	D7.WSAVGRA:	PUSHM.L	D1..D6,A3,A4	LOAD.L	D3,(A6)+OPBIG	LOAD.L	A3,#0	CLR.L	D4	LOAD.L	A4,(A6)+OPMAS	LOAD.W	D6,(A6)+ODBIGX	SR.W	D6,#3	LOAD.L	D1,(A6)+ODGRA	ADD.W	D1,#8-1	AND.B	D1,#B'11111000	SWAP.W	D1	ADD.W	D1,#2-1	AND.B	D1,#B'11111110	SWAP.W	D1	LOAD.W	D2,#LOADDOT	CALL	DRRASTER	POPM.L	D1..D6,A3,A4	RET;--------\\; GIVGRA  >;========/; Restitue tout le graphique sauv.; in	-; out	-; mod	D7.WGIVGRA:	PUSHM.L	D1..D6,A3,A4	CLR.L	D3	LOAD.L	A3,(A6)+OPMAS	LOAD.W	D5,(A6)+ODBIGX	SR.W	D5,#3	LOAD.L	D4,(A6)+OPBIG	LOAD.L	A4,#0	LOAD.L	D1,(A6)+ODGRA	ADD.W	D1,#8-1	AND.B	D1,#B'11111000	SWAP.W	D1	ADD.W	D1,#2-1	AND.B	D1,#B'11111110	SWAP.W	D1	LOAD.W	D2,#LOADDOT	CALL	DRRASTER	POPM.L	D1..D6,A3,A4	RET;--------\\; DBGGRA  >;========/; !!! ROUTINE POUR LE DEBUG !!!; Montre le contenu de la matrice OPMAT.; in	-; out	-; mod	D7.WDBGGRA:	PUSHM.L	D1..D6,A3,A4	LOAD.B	D3,#SAVWDO	LIB	?AFCAR	CLR.L	D3	LOAD.L	A3,(A6)+OPMAT	LOAD.W	D5,(A6)+ODBIGX	SR.W	D5,#3	LOAD.L	D4,(A6)+OPBIG	LOAD.L	A4,#0	LOAD.L	D1,(A6)+ODGRA	ADD.W	D1,#8-1	AND.B	D1,#B'11111000	SWAP.W	D1	ADD.W	D1,#2-1	AND.B	D1,#B'11111110	SWAP.W	D1	LOAD.W	D2,#LOADDOT	CALL	DRRASTER	LIB	?GETCAR		; attend une touche ...	LOAD.B	D3,#GETWDO	LIB	?AFCAR	POPM.L	D1..D6,A3,A4	RET;----------\\; DEFPTRAME >;==========/; Dfini une trame selon la position dans le tableau.; in	D0.L	position dans le tableau (y;x); out	D2.W	mode (-1 si rien  dessiner); mod	D2.L, D7.WDEFPTRAME:	PUSHM.L	D0,A4	LOAD.L	A4,#(A6)+OTDEF	ADD.W	D0,(A6)+ONTDEF	TEST.B	(A6)+OFTDEF:#BDFSEUL ; une seule trame ?	JUMP',BC 10$		; non => 10$	LOAD.W	D0,(A6)+ONTDEF	; oui => prend la trame slectionne10$:	AND.L	D0,#H'FFFF	DIV.WU	D0,#MAXDEF	SWAP.W	D0		; D0 <-- rang (0..MAXDEF-1)	MUL.WU	D0,#8	ADD.L	A4,D0	CALL	DEFTRAME	POPM.L	D0,A4	RET;----------\\; DEFPTRAIT >;==========/; Dfini une ligne selon la position dans le tableau.; in	D0.L	position dans le tableau (y;x); out	D2.W	mode (-1 si rien  dessiner); mod	D2.L, D7.WDEFPTRAIT:	PUSHM.L	D0,A4	LOAD.L	A4,#(A6)+OPDEF	ADD.W	D0,(A6)+ONPDEF	TEST.B	(A6)+OFPDEF:#BDFSEUL ; une seule ligne ?	JUMP',BC 10$		; non => 10$	LOAD.W	D0,(A6)+ONPDEF	; oui => prend la ligne slectionne10$:	AND.L	D0,#H'FFFF	DIV.WU	D0,#MAXDEF	SWAP.W	D0		; D0 <-- rang (0..MAXDEF-1)	MUL.WU	D0,#8+2	ADD.L	A4,D0	CALL	DEFTRAIT	POPM.L	D0,A4	RET;----------\\; DEFPPOINT >;==========/; Dfini un point selon la position dans le tableau.; in	D0.L	position dans le tableau (y;x); out	D2.W	mode (-1 si rien  dessiner); mod	D2.L, D7.WDEFPPOINT:	PUSHM.L	D0,A4	LOAD.L	A4,#(A6)+OXDEF	ADD.W	D0,(A6)+ONXDEF	TEST.B	(A6)+OFXDEF:#BDFSEUL ; un seul point ?	JUMP',BC 10$		; non => 10$	LOAD.W	D0,(A6)+ONXDEF	; oui => prend le point slectionn10$:	AND.L	D0,#H'FFFF	DIV.WU	D0,#MAXDEF	SWAP.W	D0		; D0 <-- rang (0..MAXDEF-1)	MUL.WU	D0,#8	ADD.L	A4,D0	CALL	DEFPOINT	POPM.L	D0,A4	RET;---------\\; DEFTRAME >;---------/; Dfini la bonne trame pour remplir une surface.; in	A4.L	^trame; out	D2.W	mode (-1 si rien  dessiner); mod	D2.L, D7.WDEFTRAME:	PUSHM.L	D1,A4	LOAD.L	(A6)+OPLDEF,A4	LOAD.W	D2,#-1		; D2 <-- rien  dessiner	TEST.B	(A6)+OSIMPLE	JUMP',T 90$	CLR.W	D1	DESSIN_	TDEF		; dfini la trame90$:	POPM.L	D1,A4	RET;---------\\; DEFTRAIT >;---------/; Dfini le bon pinceau pour tracer une ligne.; in	A4.L	^pinceau; out	D2.W	mode (-1 si rien  dessiner); mod	D2.L, D7.WDEFTRAIT:	PUSHM.L	D1,A4	LOAD.L	(A6)+OPLDEF,A4	LOAD.W	D2,#-1		; D2 <-- rien  dessiner	TEST.L	(A4)+0	JUMP',NE 20$	TEST.L	(A4)+4	JUMP,EQ 90$20$:	TEST.B	(A4)+8	JUMP,EQ 90$	CLR.W	D2	TEST.B	(A6)+OSIMPLE	JUMP',T	90$	CLR.W	D1	DESSIN_	DDEF		; dfini le trait90$:	POPM.L	D1,A4	RET;---------\\; IFCTRAIT >;=========/; Vrifie si un trait est continu.; in	A4.L	^pinceau; out	NE	pas un trait continu; mod	FIFCTRAIT:	LOAD.L	(A6)+OPLDEF,A4	COMP.B	(A4)+8,#B'11111111	JUMP',NE 90$	TEST.L	(A4)+0	JUMP',NE 80$	TEST.L	(A4)+480$:	NOTZ90$:	RET;---------\\; DEFPOINT >;---------/; Dfini le bon trait pour tracer un point.; in	A4.L	^point; out	D2.W	mode (-1 si rien  dessiner); mod	D2.L, D7.WDEFPOINT:	PUSHM.L	D1,A4	CLR.W	D1	DESSIN_	PDEF		; dfini le point	POPM.L	D1,A4	RET;--------\\; DRRECT  >;========/; Dessine un rectangle.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRRECT:	PUSHM.L	D3..D5	LOAD.L	D5,D4		; D5 <-- dimensions (dy;dx)	AND.L	D4,#H'FFFF	CALL	DRLINE		; trace ligne suprieure	LOAD.L	D4,D5	CLR.W	D4	CALL	DRLINE		; trace ligne de droite	LOAD.L	D4,D5	AND.L	D4,#H'FFFF	NEG.W	D4	CALL	DRLINE		; trace ligne infrieure	LOAD.L	D4,D5	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DRLINE		; trace ligne de gauche	POPM.L	D3..D5	RET;---------\\; DRRASTER >;=========/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D1.L	hauteur/largeur (y;x);	D2.B	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT); out	-; mod	D7.WDRRASTER:	PUSHM.L	D1,D2,A1,A2	TEST.W	D1		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D1	TEST.W	D1		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D1	CALL	CCMO		; enlve la souris	EX.L	D1,D2		; D2/D1 <-- mode/dimensions	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADRASTER	CALL	(A1)		; appel de GRA_RASTER90$:	POPM.L	D1,D2,A1,A2	RET;-------\\; DRDOT  >;=======/; Dessine un point.; in	D3.L	coordonne (y;x);	D2.W	mode; out	-; mod	D7.WDRDOT:	PUSHM.L	D1..D4,A1,A2	CALL	CCMO		; enlve la souris	LOAD.W	D1,D2		; D1 <-- mode	LOAD.L	D4,D3		; D4 <-- y;x	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADDOT	CALL	(A1)		; appel de GRA_DOT	POPM.L	D1..D4,A1,A2	RET;--------\\; DRLINE  >;========/; Dessine un segment de droite.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	D3.L	coordonne d'arrive (y;x); mod	D3.L, D7.WDRLINE:	PUSHM.L	D1,D2,D4,A1,A2	CALL	CCMO		; enlve la souris	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADLINE	CALL	(A1)		; appel de GRA_LINE	EX.L	D3,D4	ADD.W	D3,D4		; D3 <-- arrive en X	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- arrive en Y	SWAP.W	D3;	SWAP.W	D4	POPM.L	D1,D2,D4,A1,A2	RET;----------\\; DRELLIPSE >;==========/; Dessine une ellipse, ou un arc d'ellipse.; in	D3.L	coordonne centre (y;x);	D4.L	rayons (dy;dx);	D2.W	mode;	D1.B	bitmap des octants  dessiner; out	-; mod	D7.WDRELLIPSE:	PUSHM.L	D1..D4,A1,A2	CALL	CCMO		; enlve la souris	EX.L	D1,D2		; D2/D1 <-- mode/octants	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADELLIPSE	CALL	(A1)		; appel de GRA_ELLIPSE	POPM.L	D1..D4,A1,A2	RET;---------\\; DRTRADEF >;=========/; Dfinit une trame.; in	D3.L	trame;	D4.L	trame; out	-; mod	D7.WDRTRADEF:	PUSHM.L	D1..D4	COMP.B	(A6)+OMACHINE,#SMAKY100	JUMP',NE 80$				; si SMAKY100 =>	LOAD.W	D1,#4-120$:	CALL	FLIP	RR.L	D3,#8	DECJ.W,NMO D1,20$	EX.L	D3,D4	LOAD.W	D1,#4-130$:	CALL	FLIP	RR.L	D3,#8	DECJ.W,NMO D1,30$	EX.L	D4,D380$:	LOAD.L	(A0)+ODFTRA+0,D3	LOAD.L	(A0)+ODFTRA+4,D4	POPM.L	D1..D4	RET;--------\\; FLIP    >;--------/; Permute tous les bits de D3.B. Pas de boucle pour tre; rapide, et pas de table de 256 bytes pour conomiser la RAM !; in	D3.B	byte; out	D3.B	byte "flipp"; mod	D2.B, D3.BFLIP:	RLX.B	D3	RRX.B	D2		; D2 <-- bit 0	RLX.B	D3	RRX.B	D2		; D2 <-- bit 1	RLX.B	D3	RRX.B	D2		; D2 <-- bit 2	RLX.B	D3	RRX.B	D2		; D2 <-- bit 3	RLX.B	D3	RRX.B	D2		; D2 <-- bit 4	RLX.B	D3	RRX.B	D2		; D2 <-- bit 5	RLX.B	D3	RRX.B	D2		; D2 <-- bit 6	RLX.B	D3	RRX.B	D2		; D2 <-- bit 7	LOAD.B	D3,D2		; D3 <-- byte "flipp"	RET;---------\\; CPTRADEF >;=========/; Compte le nombre de points allums dans la trame courante.; in	-; out	D4.W	nb de points (0..64); mod	D4.L, D7.WCPTRADEF:	PUSHM.L	D1..D3,A4	LOAD.L	A4,#(A0)+ODFTRA	CLR.W	D4		; D4 <-- nb de points	LOAD.W	D1,#8-1		; D1 <-- compteur vertical10$:	LOAD.B	D3,(A4+)	; D3 <-- un byte	LOAD.W	D2,#8-1		; D2 <-- compteur horizontal20$:	RR.B	D3,#1	JUMP',CC 25$	INC.W	D4		; D4 <-- un point de plus25$:	DECJ.W,NMO D2,20$	DECJ.W,NMO D1,10$	POPM.L	D1..D3,A4	RET;---------\\; DRTRAME  >;=========/; Dessine une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRTRAME:	PUSHM.L	D1..D4,A1,A2,A4	TEST.W	D4		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D4	CALL	CCMO		; enlve la souris	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A4,#(A0)+ODFTRA	; A4 <-- ^trame utilisateur	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADTRAME	CALL	(A1)		; appel de GRA_TRAME90$:	POPM.L	D1..D4,A1,A2,A4	RET;--------\\; DRZONE  >;========/; Efface, allume ou inverse une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRZONE:	COMP.B	D2,#INVDOT	JUMP,EQ DRINV	COMP.B	D2,#SETDOT	JUMP,EQ DRSET;---------\\; DRCLEAR  >;=========/; Efface une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRCLEAR:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D4	CALL	CCMO		; enlve la souris	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADCLEAR	CALL	(A1)		; appel de GRA_SET90$:	POPM.L	D1..D4,A1,A2	RET;---------\\; DRSET    >;=========/; Allume une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRSET:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D4	CALL	CCMO		; enlve la souris	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADSET	CALL	(A1)		; appel de GRA_SET90$:	POPM.L	D1..D4,A1,A2	RET;---------\\; DRINV    >;=========/; Inverse une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRINV:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D4	CALL	CCMO		; enlve la souris	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADINV	CALL	(A1)		; appel de GRA_INV90$:	POPM.L	D1..D4,A1,A2	RET;--------\\; DRFILL  >;========/; Rempli une surface quelconque.; in	D3.L	point de remplissage (y;x); out	D7.W	erreur; mod	D7.WDRFILL:	PUSHM.L	D1..D4,A1,A2	CALL	CCMO		; enlve la souris	LOAD.L	D4,D3		; D4 <-- y;x	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADFILLO	CALL	(A1)		; appel de GRA_FILLO	PUSH.W	D7	LOAD.L	A1,(A6)+OADFILLC	CALL	(A1)		; appel de GRA_FILLC	POP.W	D7	POPM.L	D1..D4,A1,A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; CLRDISMAT >;==========/; Met toute la matrice bitmap  zro.; in	-; out	-; mod	D7.WCLRDISMAT:	PUSHM.L	D4,A4	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice bitmap	LOAD.W	D4,(A6)+ODBIGX	MUL.WU	D4,(A6)+ODBIGY	SR.L	D4,#3+1		; D4 <-- /2 car transfert par word10$:	CLR.W	(A4+)		; matrice <-- tous des zro	DEC.L	D4	JUMP,NE 10$	POPM.L	D4,A4	RET;----------\\; OPEDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	-; out	-; mod	D7.WOPEDISMAT:	PUSHM.L	D4,A2..A4	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice bitmap	LOAD.L	A2,#(A6)+OSDDIS	LOAD.L	A3,A0	LOAD.W	D4,#(LGDIS6/2)-110$:	LOAD.W	(A2+),(A3+)	; OSDDIS <-- descripteur de la fentre	DECJ.W,NMO D4,10$	LOAD.L	(A0)+ODFABS,A4	LOAD.W	(A0)+ODFIIX,#1	LOAD.W	D4,(A6)+ODBIGX	SR.W	D4,#3	LOAD.W	(A0)+ODFIIY,D4	LOAD.L	D4,(A6)+ODBIG	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	POPM.L	D4,A2..A4	RET;----------\\; CLODISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.WCLODISMAT:	PUSHM.L	D4,A3,A4	LOAD.L	A4,#(A6)+OSDDIS	LOAD.L	A3,A0	LOAD.W	D4,#(LGDIS6/2)-110$:	LOAD.W	(A3+),(A4+)	; descripteur de la fentre <-- OSDDIS	DECJ.W,NMO D4,10$	POPM.L	D4,A3,A4	RET;--------\\; MAXFER  >;========/; Transfert une surface rectangulaire d'une matrice dans une autre.; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	A3.L	^matrice source;	A4.L	^matrice destination; out	-; mod	D7.WMAXFER:	PUSHM.L	D3,D4,A3,A4	SR.W	D3,#3	ADD.W	A3,D3	ADD.W	A4,D3	SWAP.W	D3	MUL.WU	D3,(A6)+ODBIGX	SR.L	D3,#3	ADD.L	A3,D3	ADD.L	A4,D3	SWAP.W	D4		; D4 <-- dy20$:	PUSHM.L	D4,A3,A4	SWAP.W	D4		; D4 <-- dx	SR.W	D4,#3	DEC.W	D430$:	LOAD.B	(A4+),(A3+)	; transfert une ligne	DECJ.W,NMO D4,30$	POPM.L	D4,A3,A4	LOAD.W	D3,(A6)+ODBIGX	SR.W	D3,#3	ADD.W	A3,D3		; A3 <-- ^ligne suivante	ADD.W	A4,D3	DEC.W	D4	JUMP,NE 20$	POPM.L	D3,D4,A3,A4	RET;-------\\; MAINV  >;=======/; Inverse une surface rectangulaire dans une matrice.; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	A3.L	^matrice; out	-; mod	D7.WMAINV:	PUSHM.L	D3,D4,A3	SR.W	D3,#3	ADD.W	A3,D3	SWAP.W	D3	MUL.WU	D3,(A6)+ODBIGX	SR.L	D3,#3	ADD.L	A3,D3	SWAP.W	D4		; D4 <-- dy20$:	PUSHM.L	D4,A3	SWAP.W	D4		; D4 <-- dx	SR.W	D4,#3	DEC.W	D430$:	NOT.B	(A3+)		; inverse une ligne	DECJ.W,NMO D4,30$	POPM.L	D4,A3	LOAD.W	D3,(A6)+ODBIGX	SR.W	D3,#3	ADD.W	A3,D3		; A3 <-- ^ligne suivante	DEC.W	D4	JUMP,NE 20$	POPM.L	D3,D4,A3	RET;--------\\; MATRAME >;========/; Met une trame (en mode "ou") dans une surface rectangulaire; d'une matrice.; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	A3.L	^matrice; out	-; mod	D7.WMATRAME:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,#(A0)+ODFTRA	; A4 <-- ^trame	SR.W	D3,#3	ADD.W	A3,D3	SWAP.W	D3	LOAD.W	D2,D3	MUL.WU	D3,(A6)+ODBIGX	SR.L	D3,#3	ADD.L	A3,D3	AND.B	D2,#B'111	; D2 <-- position Y dans la trame	SWAP.W	D4		; D4 <-- dy20$:	PUSHM.L	D4,A3	SWAP.W	D4		; D4 <-- dx	SR.W	D4,#3	DEC.W	D4	LOAD.B	D3,(A4)30$:	OR.B	(A3+),D3	; trame une ligne	DECJ.W,NMO D4,30$	POPM.L	D4,A3	INC.L	A4		; A4 <-- ^ligne trame suivante	INC.B	D2	COMP.B	D2,#8	JUMP',LO 40$	CLR.B	D2	LOAD.L	A4,#(A0)+ODFTRA40$:	LOAD.W	D3,(A6)+ODBIGX	SR.W	D3,#3	ADD.W	A3,D3		; A3 <-- ^ligne suivante	DEC.W	D4	JUMP,NE 20$	POPM.L	D2..D4,A3,A4	RET	.END