	.SBTTL	GRABLOCBDMPFILE =	16		; fichierBDMPBLOC =	17		; bloc-notesBDMPIMAGE=	18		; image noir/blancBDMPCOLOR=	19		; image couleurCOUPE:	CALL	WAITMOUSE	; met le sablier	LOAD.L	D3,(A6)+OPBIG	LOAD.L	D4,(A6)+ODGRA	AND.L	D4,#H'FFFEFFF8	; D4 <-- modulos 2 en Y et 8 en X !	LIB	?CREWDO	JUMP,NE _ERROR	LIB	?USEWDO;;?	LOAD.L	D3,#2^BDMPBLOC!2^BDMPIMAGE!2^BDMPCOLOR	LOAD.L	D3,#2^BDMPBLOC!2^BDMPIMAGE	CALL	DUMPCREATE	; met l'image dans le bloc-notes ...	PUSH.W	D7	LOAD.W	D4,D5	CLR.W	D5	LIB	?USEWDO	LOAD.W	D5,D4	LIB	?KILWDO	POP.W	D7	JUMP,NE _ERROR	JUMP	_EFFACE2COPIE:	CALL	WAITMOUSE	; met le sablier	LOAD.L	D3,(A6)+OPBIG	LOAD.L	D4,(A6)+ODGRA	AND.L	D4,#H'FFFEFFF8	; D4 <-- modulos 2 en Y et 8 en X !	LIB	?CREWDO	JUMP,NE _ERROR	LIB	?USEWDO;;?	LOAD.L	D3,#2^BDMPBLOC!2^BDMPIMAGE!2^BDMPCOLOR	LOAD.L	D3,#2^BDMPBLOC!2^BDMPIMAGE	CALL	DUMPCREATE	; met l'image dans le bloc-notes ...	PUSH.W	D7	LOAD.W	D4,D5	CLR.W	D5	LIB	?USEWDO	LOAD.W	D5,D4	LIB	?KILWDO	POP.W	D7	JUMP,NE _ERROR	JUMP	_LOOPCOLLE:	CALL	WAITMOUSE	; met le sablier	LOAD.L	D3,#BNTTEXT	; D3 <-- type cherch (TEXT)	CALL	BLOCRDINFO	; D4 <-- longueur	JUMP,NE _BIP	BLOC_	RDOPEN		; dbut de la lecture dans le bloc-notes	JUMP,NE _BIP	CALL	GIVPGRA		; rend mmoire pour graphique	INC.L	D4		; D4 <-- +1 pour <0> terminateur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour graphique	JUMP',NE CLOSE$	LOAD.L	(A6)+OPGRA,A4	DEC.L	D4	BLOC_	RDDATA		; lit tout le graphique	JUMP',NE CLOSE$	CLR.B	(A4)+(D4.L)	; met le terminateur	LOAD.L	A3,A4CONV$:	LOAD.B	D3,(A3)	JUMP',EQ CLOSE$	BLOC_	CAR87		; D3 <-- caractre < 128	LOAD.B	(A3+),D3	JUMP	CONV$CLOSE$:	PUSH.W	D7	BLOC_	RDCLOSE		; ferme le bloc-notes	POP.W	D7	JUMP,NE _BIP	CALL	INIDIM	LOAD.L	A3,#(A6)+OBUFIN	CLR.B	(A3)	CALL	SAVFILE		; OBUNAME <-- nom	CALL	_DESINFFILE	; affiche le nom dans les infos	CALL	REFAIT		; dessine le graphique	SET.B	(A6)+OGAJ	; le graphique est  jour	JUMP	_LOOPCLASSEUR:	CALL	DBOXOPEN1	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	BLOC_	VISU		; accs au classeur ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	JUMP,NE _BIP	COMP.W	D3,#F1	JUMP,NE _LOOP	JUMP	COLLE;-----------\\; BLOCRDINFO >;-----------/; Cherche la longueur contenue dans le bloc-notes.; Fonctionne correctement mme si l'appel BLOC_RDINFO n'existe pas !; in	D3.L	type cherch; out	D4.L	longueur;	D7.W	erreur; mod	D4.L, D7.WBLOCRDINFO:	PUSHM.L	D3,D5,A3,A4	BLOC_	RDINFO		; D4/D5 <-- longueurs type/totale	JUMP',EQ EXIT$	BLOC_	RDOPEN	JUMP',NE EXIT$	CLR.L	D3LOOP$:	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D4,#LBUDIS	BLOC_	RDDATA	ADD.L	D3,D4		; D3 <-- longueur lue	TEST.W	D7	JUMP,EQ LOOP$	LOAD.L	D4,D3		; D4 <-- longueur totale lue	CLR.W	D7CLOSE$:	PUSH.W	D7	BLOC_	RDCLOSE	POP.W	D7EXIT$:	POPM.L	D3,D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DUMPCREATE >;===========/; Ecrit la sous-fentre dans un fichier ou dans le bloc-notes.; in	D3.L	mode (BDMP*);	A3.L	^nom du fichier (si BDMPFILE); out	D7.W	erreur; mod	D7.WDUMPCREATE:	PUSHM.L	D0..D6,A1..A5	LOAD.L	D6,D3		; D6 <-- mode; Sauve la sous-fentre dans un bitmap en mmoire point par A1.	CALL	DUMPSAVE	; sauve la sous-fentre ...	JUMP,NE EXIT$; Ouvre le fichier ou le classeur.	TEST.L	D6:#BDMPCOLOR	JUMP',BC MODE$	COMP.W	D2,#1		; image noir/blanc ?	JUMP',NE MODE$		; non => MODE$	TCLR.L	D6:#BDMPCOLOR	; D6 <-- y'a pas d'couleur !MODE$:	TEST.L	D6:#BDMPFILE	JUMP',BC FOPEN$	LOAD.L	D4,D6	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP,NE GIVMEM$	LOAD.W	D4,D6	LOAD.L	D6,D4FOPEN$:	TEST.L	D6:#BDMPBLOC	JUMP',BC GO$	LOAD.L	A3,#R16"NPGRA	LOAD.L	D3,#BNTIMAG	; D3 <-- type initiateur (IMAG)	TEST.L	D6:#BDMPCOLOR	JUMP',BC BOPEN$	LOAD.L	D3,#BNTCOLO	; D3 <-- type initiateur (COLO)BOPEN$:	LOAD.L	D4,D0	SWAP.W	D4	MUL.WU	D4,D0		; D4 <-- largeur*hauteur	SR.L	D4,#1		; D4 <-- /2 (trs approximatif !)	BLOC_	WROPEN		; dbut de l'criture dans le bloc-notes	JUMP,NE GIVMEM$GO$:	TEST.L	D6:#BDMPCOLOR	JUMP,BC CONV$; Met l'image couleur dans le classeur ou dans le fichier.	LOAD.L	A4,A1		; A4 <-- ^en-tte	LOAD.L	D4,#LGHIMA	GESMEM	?CLEARMEM	; efface l'en-tte	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.B	(A2)+OIMTYP,#H'82;	LOAD.B	(A2)+OIMCOD,#0	LOAD.B	(A2)+OIMBIP,D2	LOAD.B	(A2)+OIMDIR,#2	LOAD.W	(A2)+OIMSIZ,D2	LOAD.W	(A2)+OIMCNT,#1	TEST.L	D5		; y a-t-il une CLUT ?	JUMP',EQ NOCLUT$	; non => NOCLUT$	LOAD.W	D4,D2	MUL.WU	D4,D4		; D4 <-- nb de couleurs	MUL.WU	D4,#LCTDATA	ADD.L	D4,#LCTHEAD	; D4 <-- lg ncessaire	LOAD.L	(A2)+OIMLGC,D4NOCLUT$:	LOAD.W	D4,D1	LOAD.W	(A2)+OIMDLX,D0	SWAP.W	D0	MUL.WU	D4,D0	LOAD.W	(A2)+OIMDLY,D0	SWAP.W	D0	LOAD.L	(A2)+OIMNBB,D4	LOAD.L	A3,#(A1)+LGHIMA+IMLBUF	LOAD.L	A4,#(A1)+LGHIMA	PUSH.W	(A2)+OIMDLX	PUSH.B	(A2)+OIMBIP	LOAD.W	D4,(A2)+OIMDLX	MUL.WU	D4,D2	LOAD.W	(A2)+OIMDLX,D4	; OIMDLX <-- * nb bits/pixel	LOAD.B	(A2)+OIMBIP,#1	GRA_	CODEIMA		; code l'image couleur	POP.B	(A2)+OIMBIP	POP.W	(A2)+OIMDLX	TEST.W	D7	JUMP',EQ CCODE$	LOAD.L	A4,A3		; A4 <-- ^image dcodeCCODE$:	LOAD.L	A5,A4		; A5 <-- ^image code/dcode	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	LOAD.L	D3,#BNTCOLO	CALL	DUMPWRITE	; crit l'en-tte couleur	JUMP,NE CLOSE$	TEST.L	D5		; y a-t-il une CLUT ?	JUMP',EQ CDATA$		; non => CDATA$	PUSH.L	D1	LOAD.L	D4,(A2)+OIMLGC	; D4 <-- lg ncessaire	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer pour la CLUT	JUMP',NE CLEND$	PUSH.L	D6	LOAD.L	A3,A4	LOAD.L	D3,#2^BTCTABLE	; D3 <-- mode	LOAD.L	D6,D5		; D6 <-- canal pour TCOLOR	TCOL_	SAVECLUT	; buffer <-- CLUT	POP.L	D6	LOAD.L	D3,#BNTCOLO	CALL	DUMPWRITE	; crit la CLUT	PUSH.W	D7;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend buffer pour la CLUT	POP.W	D7CLEND$:	POP.L	D1	TEST.W	D7	JUMP,NE CLOSE$CDATA$:	LOAD.L	A4,A5	LOAD.L	D4,(A2)+OIMNBB	LOAD.L	D3,#BNTCOLO	CALL	DUMPWRITE	; crit l'image couleur	JUMP,NE CLOSE$	TEST.L	D6:#BDMPIMAGE	; faudra-t-il crire l'image noir/blanc ?	JUMP,BC CLOSE$		; non => CLOSE$	TEST.B	(A2)+OIMCOD	; image couleur code ?	JUMP',EQ CONV$		; non => CONV$	LOAD.L	A3,#(A1)+LGHIMA+IMLBUF	LOAD.L	A4,#(A1)+LGHIMA;	PUSH.W	(A2)+OIMDLX;	PUSH.B	(A2)+OIMBIP	LOAD.W	D4,(A2)+OIMDLX	MUL.WU	D4,D2	LOAD.W	(A2)+OIMDLX,D4	; OIMDLX <-- * nb bits/pixel	LOAD.B	(A2)+OIMBIP,#1	GRA_	DECOIMA		; dcode l'image couleur;	POP.B	(A2)+OIMBIP;	POP.W	(A2)+OIMDLX; Conversion du bitmap couleur en bitmap noir/blanc.CONV$:	TEST.L	D6:#BDMPIMAGE	; crit l'image noir/blanc ?	JUMP,BC CLOSE$		; non => CLOSE$	COMP.W	D2,#1		; image noir/blanc ?	JUMP,EQ NB$		; oui => NB$	CLR.W	D7	TEST.L	D5		; y a-t-il une CLUT ?	JUMP,EQ CLOSE$		; non => CLOSE$	PUSH.L	(A0)+ODFCPF	LOAD.L	(A0)+ODFCPF,D5	PUSHM.L	D2,D6	LOAD.W	D5,D1		; D5 <-- Iy	LOAD.W	D6,D2		; D6 <-- nb de bits/pixel	CLR.L	D2		; D2 <-- mode	LOAD.L	D4,D0		; D4 <-- dimensions	LOAD.L	A4,#(A1)+LGHIMA+IMLBUF ; A4 <-- ^image	LOAD.L	A5,A4		; A5 <-- ^destination (=source)	ICOL_	CONVNB		; conversion en noir/blanc	POPM.L	D2,D6	POP.L	(A0)+ODFCPF	TEST.W	D7	JUMP,NE CLOSE$	AND.L	D1,#H'FFFF	DIV.WU	D1,D2		; D1 <-- Iy noir/blanc; Met l'image noir/blanc dans le fichier et le classeur.NB$:	LOAD.L	A4,A1		; A4 <-- ^en-tte	LOAD.L	D4,#LGHIMA	GESMEM	?CLEARMEM	; efface l'en-tte	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.B	(A2)+OIMTYP,#H'81;	LOAD.B	(A2)+OIMCOD,#0	LOAD.B	(A2)+OIMBIP,#1	LOAD.B	(A2)+OIMDIR,#2	LOAD.W	D4,D1	LOAD.W	(A2)+OIMDLX,D0	SWAP.W	D0	MUL.WU	D4,D0	LOAD.W	(A2)+OIMDLY,D0	SWAP.W	D0	LOAD.L	(A2)+OIMNBB,D4	LOAD.L	A3,#(A1)+LGHIMA+IMLBUF	LOAD.L	A4,#(A1)+LGHIMA	GRA_	CODEIMA		; code l'image noir/blanc	JUMP',EQ NBCODE$	LOAD.L	A4,A3		; A4 <-- ^image dcodeNBCODE$:	LOAD.L	A5,A4		; A5 <-- ^image	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	LOAD.L	D3,#BNTIMAG	CALL	DUMPWRITE	; crit l'en-tte noir/blanc	JUMP',NE CLOSE$	LOAD.L	A4,A5	LOAD.L	D4,(A2)+OIMNBB;	LOAD.L	D3,#BNTIMAG	CALL	DUMPWRITE	; crit l'image noir/blanc;	JUMP',NE CLOSE$; Ferme le fichier et le classeur.CLOSE$:	TEST.L	D6:#BDMPBLOC	; classeur ouvert ?	JUMP',BC FCLOSE$	PUSH.W	D7	BLOC_	WRCLOSE		; ferme le classeur	POP.W	D7FCLOSE$:	TEST.L	D6:#BDMPFILE	; fichier ouvert ?	JUMP',BC GIVMEM$	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7GIVMEM$:	PUSH.W	D7	LOAD.L	A4,A1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'image	POP.W	D7EXIT$:	POPM.L	D0..D6,A1..A5	RET;----------\\; DUMPWRITE >;----------/; Ecrit une partie du data.; in	D3.L	type (BNTCOLO/BNTIMAG);	A4.L	^data;	D4.L	lg data;	D6.L	canal + flags; out	D7.W	erreur; mod	D7.WDUMPWRITE:	TEST.L	D6:#BDMPFILE	; fichier ouvert ?	JUMP',BC BLOC$		; non => BLOC$	FOS	?WRBYTE		; crit dans le fichier	JUMP',NE EXIT$BLOC$:	TEST.L	D6:#BDMPBLOC	; classeur ouvert ?	JUMP',BC EXIT$		; non => EXIT$	BLOC_	WRDATA		; crit dans le classeurEXIT$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; DUMPSAVE >;---------/; Sauve la sous-fentre dans un buffer.; in	-; out	A1.L	^copie du bitmap cran (en-tte + image dcode);	D0.L	dimensions;	D1.W	Iy;	D2.W	nb de bits/pixels;	D5.L	canal CLUT active;	D7.W	erreur; mod	D0.L, D1.L, D2.L, D5.L, D7.W, A1.LDUMPSAVE:	PUSHM.L	D3,D4,D6,A2..A4	CALL	CCMO		; enlve la souris	LOAD.L	D0,(A0)+ODFFDY	; D0 <-- dimensions de la fentre	LOAD.W	D4,D0	ADD.W	D4,#8-1	SR.W	D4,#3		; D4 <-- largeur [bytes]	CLR.W	D3	LOAD.B	D3,(A0)+ODFCNP	; D3 <-- nb de bits/pixel	MUL.WU	D4,D3	LOAD.W	D6,D4		; D6 <-- Iy buffer	SWAP.W	D0	MUL.WU	D4,D0		; D4 <-- largeur*hauteur [bytes]	SWAP.W	D0	ADD.L	D4,#LGHIMA+IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour l'image	JUMP,NE EXIT$	LOAD.L	A1,A4		; A1 <-- ^buffer pour image	LOAD.L	D3,(A0)+ODFY	; D3 <-- origine source	ADD.W	D3,(A0)+ODFFX	SWAP.W	D3	ADD.W	D3,(A0)+ODFFY	SWAP.W	D3	LOAD.W	D5,(A0)+ODFIIY	; D5 <-- Iy source	LOAD.L	A3,(A0)+ODFABS	; A3 <-- ^source	CLR.L	D4		; D4 <-- origine destination	LOAD.L	A4,#(A1)+LGHIMA+IMLBUF ; A4 <-- ^destination	LOAD.L	D2,D0		; D2 <-- dimensions	LOAD.L	A2,A0		; A2 <-- ^descripteur	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE XCOLOR$	; oui => XCOLOR$	LOAD.W	D1,#LOADDOT	; D1 <-- mode	GRA_	RASTER		; buffer <-- cran noir/blanc	JUMP'	XEND$XCOLOR$:	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL ; D1 <-- mode	GRA_	CRASTER		; buffer <-- cran couleurXEND$:	LOAD.W	D1,D6		; D1 <-- Iy buffer	CLR.W	D2	LOAD.B	D2,(A0)+ODFCNP	; D2 <-- nb de bits/pixel	LOAD.L	D5,(A0)+ODFCPF	; D5 <-- canal CLUT activeOK$:	CLR.W	D7		; D7 <-- okEXIT$:	PUSH.W	D7	CALL	SCMO		; remet la souris	POP.W	D7	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETNPGRA:	.ASCIZ	"GRAPHE"	.EVEN	.END