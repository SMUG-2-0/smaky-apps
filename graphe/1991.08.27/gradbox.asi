	.SBTTL	GRADBOX;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier;	D2.W	mode; out	D2.W	mode;	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXEDITO:	PUSHM.L	D1,D4,A2..A5	LOAD.W	D3,#F1		; D3 <-- comme si (SAUVE)	TEST.L	D2:#BDBAUTO	; mode automatique ?	JUMP,BS	90$		; oui => 90$	CALL	DBOXOPEN1	LOAD.L	D4,#2^BDBIMA!2^BDBDEF ; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_SAUVE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	TSET.L	D2:#BDBEXTEND	; D2 <-- sous-appel d'extension	TSET.L	D2:#BDBSAV	; D2 <-- sauve le fond	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ	TEST.L	D2:#BDBNMAJ	JUMP',BC 30$	TSET.L	D3:#BDBIONMAJ	; D3 <-- touche (MET A JOUR) grise30$:	DBOX_	EXTEND		; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,A2..A5	CALL	DBOXOPEN1	LOAD.L	D4,#2^BDBGRA!2^BDBDEF ; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXGRA	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXSAVE >;=========/; Sauve le dessin selon le choix de l'utilisateur.; in	D0.W	mode (0=quitte, 1=nouveau texte); out	D7.W	0	=> ok, on peut quitter;		1	=> (ANNULE), donc on reste;		autre	=> erreur grve; mod	D7.WDBOXSAVE:	PUSHM.L	D1..D4,A2..A5	TEST.L	(A6)+OPGRA	; graphique existe ?	JUMP,EQ	80$		; non => 80$	TEST.B	(A6)+OGAJ	; mise  jour ncessaire ?	JUMP,T	80$		; non => 80$ (quitte, snif)10$:	CALL	DBOXOPEN1	LOAD.L	D4,#2^BDBIMA!2^BDBDEF ; D4 <-- fanions	TEST.B	D0	JUMP',NE 25$	TSET.L	D3:#BDBIOQUIT	; D3 <-- texte "avant de quitter"25$:	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_SAUVE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_MAJ	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#2^BDBIOOBJ	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 85$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$	OR.W	D2,D4		; D2 <-- met aussi les fanions (pour BDBDEF)	CALL	SAUVETOUT	; sauve tout sur disque (in D2.W !)	JUMP'	90$80$:	CLR.W	D7		; D7 <-- quitte	JUMP'	90$85$:	LOAD.W	D7,#1		; D7 <-- reste90$:	POPM.L	D1..D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXDEF >;========/; Demande les dfinitions gnrales.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_DEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4	TEST.B	(A6)+ORAPIDE	JUMP',F 10$	TSET.L	D4:#010$:	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_DEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:				; D'ACCORD =>	CLR.B	(A6)+ORAPIDE	TEST.L	D4:#0	JUMP',BC 85$	SET.B	(A6)+ORAPIDE85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer le dessin.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXEFFACE:	PUSHM.L	D1,D2,D4,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande si l'on veut quitter GRAPHE.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXQUITTE:	PUSHM.L	D1,D2,D4,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXXY  >;========/; Demande comment dessiner les coordonnes.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXXY:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_XY	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OXYFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_XY	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:				; D'ACCORD =>	LOAD.L	(A6)+OXYFAN,D4	; sauve les fanions85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXGAUSS >;==========/; Demande comment dessiner les courbes de Gauss.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXGAUSS:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_GAUSS	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OGAFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	TEST.L	D4:#BGAUSS	JUMP',BS 20$	CALL	DBOXGREY	.B	1,620$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_GAUSS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$	COMP.W	D3,#KEYICO+BGAUSS	JUMP',EQ 40$	COMP.W	D3,#KEYICO+BGA14	JUMP',EQ 50$	COMP.W	D3,#KEYICO+BGA12	JUMP',EQ 50$	COMP.W	D3,#KEYICO+BGA1	JUMP',EQ 50$	COMP.W	D3,#KEYICO+BGA2	JUMP',EQ 50$	COMP.W	D3,#KEYICO+BGA4	JUMP',EQ 50$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:	TEST.L	D4:#BGAUSS	JUMP',BS 42$	TCLR.L	D4:#BGA14	TCLR.L	D4:#BGA12	TCLR.L	D4:#BGA1	TCLR.L	D4:#BGA2	TCLR.L	D4:#BGA4	CALL	DBOXGREY	.B	1,6	JUMP	20$42$:	TCLR.L	D4:#BGA14	TCLR.L	D4:#BGA12	TSET.L	D4:#BGA1	TCLR.L	D4:#BGA2	TCLR.L	D4:#BGA4	CALL	DBOXFULL	.B	1,6	JUMP	20$50$:	TSET.L	D4:#BGAUSS	TCLR.L	D4:#BGA14	TCLR.L	D4:#BGA12	TCLR.L	D4:#BGA1	TCLR.L	D4:#BGA2	TCLR.L	D4:#BGA4	TSET.L	D4:D3	JUMP	20$80$:				; D'ACCORD =>	LOAD.L	(A6)+OGAFAN,D4	; sauve les fanions85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXPERS >;=========/; Demande comment dessiner la perspective.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPERS:	PUSHM.L	D0..D2,D4,D5,A1..A4	CLR.W	(A6)+OPESLG	LOAD.L	A2,#R16"TDBOX_PERS	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OPEFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	TEST.L	D4:#BPEOUI	JUMP',BS 10$	CALL	DBOXGREY	.B	3,6	CALL	DBOXGREY	.B	10,110$:	LOAD.W	D2,#212$:	CALL	DBPEGET	CALL	DBPEAFF		; affiche toutes les cases	DEC.W	D2	JUMP,NE 12$15$:	CALL	DBPEGET		; A3/A4 <-- ^dbut/fin nom	CALL	DBPEAFF20$:	CALL	DBPEJOLI	; affiche la petite perspective mignonne	CALL	SCMO		; remet la souris	LOAD.W	D3,D2		; D3 <-- rang profondeur/hauteur	TEST.L	D4:#BPEOUI	JUMP',BS 22$	LOAD.W	D3,#-1		; D3 <-- rien d'ditable22$:	DBOX_	MEDIT	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_PERS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$	COMP.W	D3,#UNDO	JUMP,EQ 35$	COMP.W	D3,#CR	JUMP,EQ 40$	COMP.W	D3,#KEYICO+100	JUMP,EQ 45$	COMP.W	D3,#KEYICO+101	JUMP,EQ 45$	COMP.W	D3,#KEYICO+102	JUMP,EQ 45$	COMP.W	D3,#KEYICO+BPENIV	JUMP,EQ 54$	COMP.W	D3,#KEYICO+BPEDER	JUMP,EQ 55$	COMP.W	D3,#KEYICO+BPEFIL	JUMP,EQ 57$	COMP.W	D3,#KEYICO+BPEOUI	JUMP,EQ 64$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$35$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$40$:				; RETURN =>	CALL	DBPEPUT;	JUMP,NE 30$	CALL	DBPEGET	CALL	DBPEAFF	TEST.L	D4:#BPEOUI	JUMP,BC 30$	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,#3	JUMP,LO 15$	CLR.W	D2	JUMP	15$45$:				; clic dans case =>	CALL	DBPEPUT;	JUMP,NE 30$	CALL	DBPEGET	CALL	DBPEAFF	TEST.L	D4:#BPEOUI	JUMP,BC 30$	SUB.B	D3,#100	LOAD.B	D2,D3	JUMP	15$54$:				; clic dans cercle NIV =>	CALL	DBPEPUT;	JUMP,NE 30$	CALL	DBPEGET	CALL	DBPEAFF	TSET.L	D4:#BPENIV	TCLR.L	D4:#BPEDER	JUMP	15$55$:				; clic dans cercle DER =>	CALL	DBPEPUT;	JUMP,NE 30$	CALL	DBPEGET	CALL	DBPEAFF	TCLR.L	D4:#BPENIV	TSET.L	D4:#BPEDER	TEST.L	D4:#BPEOUI	JUMP,BS	15$	TSET.L	D4:#BPENIV	TCLR.L	D4:#BPEDER	JUMP	30$57$:				; clic dans fil de fer =>	JUMP	20$64$:				; clic dans perspective =>	TEST.L	D4:#BPEOUI	JUMP',BS 66$	TSET.L	D4:#BPENIV	TCLR.L	D4:#BPEDER	CALL	DBOXGREY	.B	3,6	CALL	DBOXGREY	.B	10,1	JUMP	10$66$:	LOAD.L	D3,(A6)+ODCFAN	TSET.L	D3:#BDF100	JUMP',BS 67$	TCLR.L	D3:#BDF150	JUMP',BS 67$	TCLR.L	D3:#BDF200	JUMP',BS 67$	TCLR.L	D3:#BDF10067$:	LOAD.L	(A6)+ODCFAN,D3	LOAD.L	D3,(A6)+ODEFAN	TSET.L	D3:#BDF100	JUMP',BS 68$	TCLR.L	D3:#BDF150	JUMP',BS 68$	TCLR.L	D3:#BDF200	JUMP',BS 68$	TCLR.L	D3:#BDF10068$:	LOAD.L	(A6)+ODEFAN,D3	CALL	DBOXFULL	.B	3,6	CALL	DBOXFULL	.B	10,1	JUMP	10$80$:				; D'ACCORD =>	CALL	DBPEPUT	JUMP,NE 30$	CALL	DBPEGET	CALL	DBPEAFF	LOAD.L	(A6)+OPEFAN,D4	; sauve les fanions85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBPEGET >;--------/; Prend une ligne ditable.; in	D2.W	rang (0..n);	D4.L	fanions; out	A3.L	^dbut nom;	A4.L	^fin nom; mod	D7.W, A3.L, A3.LDBPEGET:	PUSHM.L	D4,A2	LOAD.L	A3,#(A6)+OBUDIS	TEST.L	D4:#BPEOUI	JUMP,BC 50$	CLR.L	D4	LOAD.W	D4,(A6)+OPELG	TEST.W	D2	JUMP',EQ 20$	LOAD.W	D4,(A6)+OPEAD	COMP.W	D2,#1	JUMP',EQ 20$	LOAD.W	D4,(A6)+OPEAG20$:	LOAD.B	(A3+),#SPACE	LOAD.B	(A3+),#SPACE	LOAD.B	(A3+),#SPACE	LOAD.L	A4,A3	CALL	PUTANUM	CLR.B	(A4)	LOAD.L	D4,A4	SUB.L	D4,A3		; D4 <-- nb de digits	SUB.W	D4,#4	JUMP',HS 90$	NEG.W	D4	SUB.W	A3,D4		; A3 <-- cale le nombre  droite	JUMP'	90$50$:	LOAD.L	A4,A3	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	CLR.B	(A4)90$:	POPM.L	D4,A2	RET;--------\\; DBPEPUT >;--------/; Sauve une ligne dite.; in	D2.W	rang (0..n);	D4.L	fanions;	A3.L	^dbut nom; out	D7.W	erreur; mod	D7.WDBPEPUT:	PUSHM.L	D0..D2,D4,A2..A4	CLR.W	D7		; D7 <-- ok	TEST.L	D4:#BPEOUI	JUMP,BC 90$	LOAD.W	D0,#10	LOAD.W	D1,#90	LOAD.L	A2,#(A6)+OPELG	TEST.W	D2	JUMP',EQ 20$	LOAD.W	D0,#0	LOAD.W	D1,#75	LOAD.L	A2,#(A6)+OPEAD	COMP.W	D2,#1	JUMP',EQ 20$;	LOAD.W	D0,#0;	LOAD.W	D1,#75	LOAD.L	A2,#(A6)+OPEAG20$:	LOAD.L	A4,A330$:	COMP.B	(A4+),#SPACE	JUMP,EQ 30$	DEC.L	A4	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D7,#1	TEST.B	(A4)	JUMP',NE 90$	CLR.W	D7	COMP.W	D4,D0		; trop petit ?	JUMP',HS 40$	LOAD.W	D4,D0	LOAD.W	D7,#140$:	COMP.W	D4,D1		; trop grand ?	JUMP',LS 50$	LOAD.W	D4,D1	LOAD.W	D7,#150$:	LOAD.W	(A2),D490$:	POPM.L	D0..D2,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBPEAFF >;--------/; Affiche une ligne dite.; in	D2.W	rang (0..n);	A3.L	^dbut nom; out	-; mod	D7.WDBPEAFF:	PUSHM.L	D2..D4,A3	LOAD.W	D3,#3	TEST.W	D2	JUMP',EQ 20$	LOAD.W	D3,#5	COMP.W	D2,#1	JUMP',EQ 20$	LOAD.W	D3,#720$:	LOAD.W	D2,D3	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT	POPM.L	D2..D4,A3	RET;---------\\; DBPEJOLI >;---------/; Affiche les axes de la perspective obtenue.; in	D4.L	fanions; out	-; mod	D7.WDBPEJOLI:	PUSHM.L	D0..D4	CLR.W	D3	TEST.L	D4:#BPEOUI	JUMP',BC 10$	LOAD.W	D3,(A6)+OPELG10$:	COMP.W	D3,(A6)+OPESLG	JUMP',NE 12$	LOAD.W	D3,(A6)+OPEAD	COMP.W	D3,(A6)+OPESAD	JUMP',NE 12$	LOAD.W	D3,(A6)+OPEAG	COMP.W	D3,(A6)+OPESAG	JUMP,EQ 90$12$:	LOAD.L	D1,(A6)+ODGRA	SUB.W	D1,(A6)+OMARGG	SUB.W	D1,(A6)+OMARGD	SWAP.W	D1	SUB.W	D1,(A6)+OMARGH	SUB.W	D1,(A6)+OMARGB	SWAP.W	D1		; D1 <-- dimensions (dy;dx)	SET.B	(A6)+OSIMPLE	; dessin tout simple	PUSH.L	(A6)+OPEFAN	PUSH.L	(A6)+OPBIG	PUSH.L	(A6)+ODGRA	PUSH.W	(A6)+OMARGG	PUSH.W	(A6)+OMARGD	PUSH.W	(A6)+OMARGH	PUSH.W	(A6)+OMARGB	PUSH.B	(A6)+OPDDEF+(8+2)*RANGLHGRILLE+8	PUSH.B	(A6)+OPDDEF+(8+2)*RANGLVGRILLE+8	LOAD.L	(A6)+OPEFAN,D4	LOAD.W	D2,#1	DBOX_	GETCO	LOAD.W	(A6)+OPBIGX,D3	LOAD.W	D2,#2	DBOX_	GETCO	SUB.W	D3,(A6)+OPBIGX	LOAD.W	(A6)+ODGRAX,D3	SWAP.W	D1	MUL.WU	D3,D1	SWAP.W	D1	DIV.WU	D3,D1		; D3 <-- (ODGRAX*dy) / dx	LOAD.W	D4,(A0)+ODFFDY	SUB.W	D4,#8+8		; D4 <-- hauteur maximale	COMP.W	D3,D4	JUMP',LO 20$	LOAD.W	D3,D420$:	LOAD.W	(A6)+ODGRAY,D3	SUB.W	D3,(A0)+ODFFDY	NEG.W	D3	SR.W	D3,#1	LOAD.W	(A6)+OPBIGY,D3	LOAD.W	(A6)+OMARGG,#5	LOAD.W	(A6)+OMARGD,#5	LOAD.W	(A6)+OMARGH,#5	LOAD.W	(A6)+OMARGB,#5	CLR.B	(A6)+OPDDEF+(8+2)*RANGLHGRILLE+8	CLR.B	(A6)+OPDDEF+(8+2)*RANGLVGRILLE+8	LOAD.L	D3,(A6)+OPBIG	SUB.W	D3,#8	SWAP.W	D3	SUB.W	D3,#8	SWAP.W	D3	LOAD.L	D4,(A6)+ODGRA	ADD.W	D4,#8+8	SWAP.W	D4	ADD.W	D4,#8+8	SWAP.W	D4	CALL	DRCLEAR		; efface l'ancien dessin	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP',BC 80$		; non => 80$				; oui =>	CALL	GETPERSPECTIVE	; cherche la perspective selon les angles	JUMP',NE 50$	CALL	GETMULY		; cherche le facteur pour Y	CALL	DESAXES		; dessine les axes	CALL	DESAXEZERO	; dessine la ligne du zro	JUMP'	80$50$:	LOAD.W	D2,#SETDOT	LOAD.L	D3,(A6)+OPBIG	LOAD.L	D4,(A6)+ODGRA	CALL	DRLINE		; \	LOAD.L	D3,(A6)+OPBIG	LOAD.L	D4,(A6)+ODGRA	ADD.W	D3,D4	NEG.W	D4	CALL	DRLINE		; /80$:	LOAD.L	D4,(A6)+OPEFAN	POP.B	(A6)+OPDDEF+(8+2)*RANGLVGRILLE+8	POP.B	(A6)+OPDDEF+(8+2)*RANGLHGRILLE+8	POP.W	(A6)+OMARGB	POP.W	(A6)+OMARGH	POP.W	(A6)+OMARGD	POP.W	(A6)+OMARGG	POP.L	(A6)+ODGRA	POP.L	(A6)+OPBIG	POP.L	(A6)+OPEFAN	CLR.B	(A6)+OSIMPLE	; remet le mode normal	CLR.W	D3	TEST.L	D4:#BPEOUI	JUMP',BC 85$	LOAD.W	D3,(A6)+OPELG85$:	LOAD.W	(A6)+OPESLG,D3	LOAD.W	(A6)+OPESAD,(A6)+OPEAD	LOAD.W	(A6)+OPESAG,(A6)+OPEAG90$:	POPM.L	D0..D4	RET;------------\\; DBOXPERSCAM >;============/; Demande comment dessiner la perspective d'un camembert.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPERSCAM:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_PERSCAM	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OPEFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	TEST.L	D4:#BPEOUI	JUMP',BS 10$	CALL	DBOXGREY	.B	1,410$:	LOAD.W	D2,#112$:	CALL	DBPECGET	CALL	DBPECAFF	; affiche toutes les cases	DEC.W	D2	JUMP,NE 12$15$:	CALL	DBPECGET	; A3/A4 <-- ^dbut/fin nom	CALL	DBPECAFF20$:	LOAD.W	D3,D2		; D3 <-- rang profondeur/hauteur	TEST.L	D4:#BPEOUI	JUMP',BS 22$	LOAD.W	D3,#-1		; D3 <-- rien d'ditable22$:	DBOX_	MEDIT	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_PERSCAM	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$	COMP.W	D3,#UNDO	JUMP,EQ 35$	COMP.W	D3,#CR	JUMP,EQ 40$	COMP.W	D3,#KEYICO+100	JUMP,EQ 45$	COMP.W	D3,#KEYICO+101	JUMP,EQ 45$	COMP.W	D3,#KEYICO+BPEOUI	JUMP,EQ 64$	COMP.W	D3,#KEYICO+BPEFIL	JUMP,EQ 20$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$35$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$40$:				; RETURN =>	CALL	DBPECPUT;	JUMP,NE 30$	CALL	DBPECGET	CALL	DBPECAFF	TEST.L	D4:#BPEOUI	JUMP,BC 30$	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,#2	JUMP,LO 15$	CLR.W	D2	JUMP	15$45$:				; clic dans case =>	CALL	DBPECPUT;	JUMP,NE 30$	CALL	DBPECGET	CALL	DBPECAFF	TEST.L	D4:#BPEOUI	JUMP,BC 30$	SUB.B	D3,#100	LOAD.B	D2,D3	JUMP	15$64$:				; clic dans perspective =>	TEST.L	D4:#BPEOUI	JUMP',BS 65$	CALL	DBOXGREY	.B	1,4	JUMP	10$65$:	CALL	DBOXFULL	.B	1,4	JUMP	10$80$:				; D'ACCORD =>	CALL	DBPECPUT	JUMP,NE 30$	CALL	DBPECGET	CALL	DBPECAFF	LOAD.L	(A6)+OPEFAN,D4	; sauve les fanions85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBPECGET >;---------/; Prend une ligne ditable.; in	D2.W	rang (0..n);	D4.L	fanions; out	A3.L	^dbut nom;	A4.L	^fin nom; mod	D7.W, A3.L, A3.LDBPECGET:	PUSHM.L	D4,A2	LOAD.L	A3,#(A6)+OBUDIS	TEST.L	D4:#BPEOUI	JUMP,BC 50$	CLR.L	D4	LOAD.W	D4,(A6)+OPEEL	TEST.W	D2	JUMP',EQ 20$	LOAD.W	D4,(A6)+OPEEP20$:	LOAD.B	(A3+),#SPACE	LOAD.B	(A3+),#SPACE	LOAD.B	(A3+),#SPACE	LOAD.L	A4,A3	CALL	PUTANUM	CLR.B	(A4)	LOAD.L	D4,A4	SUB.L	D4,A3		; D4 <-- nb de digits	SUB.W	D4,#4	JUMP',HS 90$	NEG.W	D4	SUB.W	A3,D4		; A3 <-- cale le nombre  droite	JUMP'	90$50$:	LOAD.L	A4,A3	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	CLR.B	(A4)90$:	POPM.L	D4,A2	RET;---------\\; DBPECPUT >;---------/; Sauve une ligne dite.; in	D2.W	rang (0..n);	D4.L	fanions;	A3.L	^dbut nom; out	D7.W	erreur; mod	D7.WDBPECPUT:	PUSHM.L	D0..D2,D4,A2..A4	CLR.W	D7		; D7 <-- ok	TEST.L	D4:#BPEOUI	JUMP,BC 90$	LOAD.W	D0,#20	LOAD.W	D1,#90	LOAD.L	A2,#(A6)+OPEEL	TEST.W	D2	JUMP',EQ 20$	LOAD.W	D0,#5	LOAD.W	D1,#50	LOAD.L	A2,#(A6)+OPEEP20$:	LOAD.L	A4,A330$:	COMP.B	(A4+),#SPACE	JUMP,EQ 30$	DEC.L	A4	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D7,#1	TEST.B	(A4)	JUMP',NE 90$	CLR.W	D7	COMP.W	D4,D0		; trop petit ?	JUMP',HS 40$	LOAD.W	D4,D0	LOAD.W	D7,#140$:	COMP.W	D4,D1		; trop grand ?	JUMP',LS 50$	LOAD.W	D4,D1	LOAD.W	D7,#150$:	LOAD.W	(A2),D490$:	POPM.L	D0..D2,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBPECAFF >;---------/; Affiche une ligne dite.; in	D2.W	rang (0..n);	A3.L	^dbut nom; out	-; mod	D7.WDBPECAFF:	PUSHM.L	D2..D4,A3	LOAD.W	D3,#1	TEST.W	D2	JUMP',EQ 20$	LOAD.W	D3,#320$:	LOAD.W	D2,D3	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT	POPM.L	D2..D4,A3	RET;---------\\; DBOXDCAC >;=========/; Demande comment dessiner les graphiques cte  cte.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDCAC:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_DCAC	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+ODCFAN	; D4 <-- fanions	TSET.L	D4:#BDFCAC	TCLR.L	D4:#BDFEMP	COMP.B	(A6)+OGRAPHE,#ICOGEMP	JUMP',NE 10$	LOAD.L	D4,(A6)+ODEFAN	; D4 <-- fanions	TCLR.L	D4:#BDFCAC	TSET.L	D4:#BDFEMP10$:	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	TEST.B	(A6)+OPEFAN+3:#BPEOUI	JUMP',BC 20$	TCLR.L	D4:#BDF150	TCLR.L	D4:#BDF200	CALL	DBOXGREY	.B	9,220$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_DCAC	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$	COMP.W	D3,#KEYICO+BDFCAC	JUMP,EQ 40$	COMP.W	D3,#KEYICO+BDFEMP	JUMP,EQ 45$	COMP.W	D3,#KEYICO+BDF025	JUMP,EQ 50$	COMP.W	D3,#KEYICO+BDF050	JUMP,EQ 50$	COMP.W	D3,#KEYICO+BDF075	JUMP,EQ 50$	COMP.W	D3,#KEYICO+BDF100	JUMP,EQ 50$	COMP.W	D3,#KEYICO+BDF150	JUMP,EQ 50$	COMP.W	D3,#KEYICO+BDF200	JUMP,EQ 50$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; cte  cte =>	LOAD.L	(A6)+ODEFAN,D4	LOAD.L	D4,(A6)+ODCFAN	TSET.L	D4:#BDFCAC	TCLR.L	D4:#BDFEMP	JUMP	20$45$:				; empil =>	LOAD.L	(A6)+ODCFAN,D4	LOAD.L	D4,(A6)+ODEFAN	TCLR.L	D4:#BDFCAC	TSET.L	D4:#BDFEMP	JUMP	20$50$:				; clic dans cercle 0.25  2.00 =>	TCLR.L	D4:#BDF025	TCLR.L	D4:#BDF050	TCLR.L	D4:#BDF075	TCLR.L	D4:#BDF100	TCLR.L	D4:#BDF150	TCLR.L	D4:#BDF200	TSET.L	D4:D3		; D4 <-- allume le bon fanion	JUMP	20$80$:				; D'ACCORD =>	TEST.L	D4:#BDFEMP	JUMP',BS 82$	LOAD.L	(A6)+ODCFAN,D4	; sauve les fanions	TSET.B	(A6)+ODEFAN+3:#BDFCAC	TCLR.B	(A6)+ODEFAN+3:#BDFEMP	LOAD.B	(A6)+OGRAPHE,#ICOGCAC	JUMP'	85$82$:	LOAD.L	(A6)+ODEFAN,D4	; sauve les fanions	TCLR.B	(A6)+ODCFAN+3:#BDFCAC	TSET.B	(A6)+ODCFAN+3:#BDFEMP	LOAD.B	(A6)+OGRAPHE,#ICOGEMP;	JUMP'	85$85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXDBRI >;=========/; Demande comment dessiner les graphiques ligne brise.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDBRI:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_DBRI	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+ODBFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	TEST.L	D4:#BDBTRAN	JUMP',BC 15$	CALL	TRANSP$15$:	TEST.L	D4:#BDBOPAQ	JUMP',BC 20$	CALL	OPAQUE$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_DBRI	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$	COMP.W	D3,#KEYICO+BDBTRAN	JUMP,EQ 40$	COMP.W	D3,#KEYICO+BDBOPAQ	JUMP,EQ 42$	COMP.W	D3,#KEYICO+BDBPT	JUMP,EQ 50$	COMP.W	D3,#KEYICO+BDBDR	JUMP,EQ 51$	COMP.W	D3,#KEYICO+BDBSP	JUMP,EQ 52$	COMP.W	D3,#KEYICO+BDBTR	JUMP,EQ 54$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; met le mode transparent =>	TSET.L	D4:#BDBTRAN	TCLR.L	D4:#BDBOPAQ	TCLR.L	D4:#BDBTR	; enlve les trames	CALL	TRANSP$	JUMP	20$42$:				; met le mode opaque =>	TCLR.L	D4:#BDBTRAN	TSET.L	D4:#BDBOPAQ	TCLR.L	D4:#BDBSP	; enlve les splines	CALL	OPAQUE$	JUMP	20$50$:				; met/enlve les points =>	JUMP	20$51$:				; met/enlve les droites =>	TEST.L	D4:#BDBDR	JUMP,BC 20$	TCLR.L	D4:#BDBSP	; enlve les splines	JUMP	20$52$:				; met/enlve les splines =>	TEST.L	D4:#BDBSP	JUMP,BC 20$	TCLR.L	D4:#BDBDR	; enlve les droites	TCLR.L	D4:#BDBTR	; enlve les trames	TSET.L	D4:#BDBTRAN	TCLR.L	D4:#BDBOPAQ	; met le mode transparent	JUMP	20$54$:				; met/enlve les trames =>	TEST.L	D4:#BDBTR	JUMP,BC 20$	TCLR.L	D4:#BDBSP	; enlve les splines	TCLR.L	D4:#BDBTRAN	TSET.L	D4:#BDBOPAQ	; met le mode opaque	JUMP	20$80$:				; D'ACCORD =>	LOAD.L	(A6)+ODBFAN,D4	; sauve les fanions85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTRANSP$:	PUSHM.L	D2..D4	LOAD.W	D2,#4!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#5!2^BDBGCGREY	DBOX_	GETCO	POPM.L	D2..D4	RETOPAQUE$:	PUSHM.L	D2..D4	LOAD.W	D2,#4!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#5!2^BDBGCFULL	DBOX_	GETCO	POPM.L	D2..D4	RET;---------\\; DBOXDCAM >;=========/; Demande comment dessiner les graphiques camemberts.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDCAM:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_DCAM	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+ODTFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	TEST.L	D4:#BCA100	JUMP',BS 05$	CALL	DBOXGREY	.B	1,405$:	CLR.W	D210$:	CALL	DBDCTEXT	; affiche les lgendes	INC.W	D2	COMP.W	D2,#3*7	JUMP,LO 10$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_DCAM	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$	COMP.W	D3,#KEYICO+BCA100	JUMP,EQ 40$	COMP.W	D3,#KEYICO+BCALOAD	JUMP,EQ 50$	COMP.W	D3,#KEYICO+BCASET	JUMP,EQ 50$	COMP.W	D3,#KEYICO+BCACLR	JUMP,EQ 50$	COMP.W	D3,#KEYICO+BCAAUTO	JUMP,EQ 50$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:	TEST.L	D4:#BCA100	JUMP',BC 42$	TCLR.L	D4:#BCALOAD	TCLR.L	D4:#BCASET	TCLR.L	D4:#BCACLR	TSET.L	D4:#BCAAUTO	CALL	DBOXFULL	.B	1,4	JUMP	20$42$:	TCLR.L	D4:#BCALOAD	TCLR.L	D4:#BCASET	TCLR.L	D4:#BCACLR	TCLR.L	D4:#BCAAUTO	CALL	DBOXGREY	.B	1,4	JUMP	20$50$:	TSET.L	D4:#BCA100	TCLR.L	D4:#BCALOAD	TCLR.L	D4:#BCASET	TCLR.L	D4:#BCACLR	TCLR.L	D4:#BCAAUTO	TSET.L	D4:D3	JUMP	20$80$:				; D'ACCORD =>	LOAD.L	(A6)+ODTFAN,D4	; sauve les fanions85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBDCTEXT >;---------/; Affiche une lgende.; in	D2.W	rang; out	-; mod	D7.WDBDCTEXT:	PUSHM.L	D0..D4,A3,A4	LOAD.W	D0,D2	LOAD.W	D1,D2	MUL.WU	D1,#3	SUB.W	D2,#7	JUMP',LO 10$	LOAD.W	D1,D2	MUL.WU	D1,#3	INC.W	D1	SUB.W	D2,#7	JUMP',LO 10$	LOAD.W	D1,D2	MUL.WU	D1,#3	ADD.W	D1,#210$:	LOAD.W	D2,D1	ADD.W	D2,#6	LOAD.W	D1,D2	DBOX_	GETCO		; D3 <-- position du curseur	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	LIB	?SETCURS	LOAD.W	D2,#-1	SWAP.W	D2	LOAD.W	D2,D0	CALL	GETCH		; A3 <-- ^lgende	JUMP',NE 80$	LOAD.L	A4,A3	LOAD.W	D3,#-160$:	INC.W	D3		; D3 <-- longueur de la lgende	LOAD.B	D4,(A4+)	JUMP',EQ 65$	COMP.B	D4,#TAB	JUMP',EQ 65$	COMP.B	D4,#CR	JUMP,NE 60$65$:	TEST.W	D3		; texte trop court ?	JUMP',EQ 90$	COMP.W	D3,#20-4	; texte trop long ?	JUMP',LS 70$	LOAD.W	D3,#20-470$:	LIB	?STRING		; affiche la lgende	JUMP'	90$80$:	LOAD.W	D2,D1	TSET.L	D2:#BDBGCGREY	DBOX_	GETCO		; grise le bouton90$:	POPM.L	D0..D4,A3,A4	RET;---------\\; DBOXDLIS >;=========/; Demande comment dessiner les graphiques listes.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDLIS:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_DLIS	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+ODLFAN	; D4 <-- fanions	JUMP',NE 10$	LOAD.W	D4,#2^BLINID	; D4 <-- fanions par dfaut10$:	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_DLIS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:				; D'ACCORD =>	LOAD.L	(A6)+ODLFAN,D4	; sauve les fanions85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXLEGENDE >;============/; Demande comment dessiner la lgende.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXLEGENDE:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_LEGENDE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OLEFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	TEST.L	D4:#BLEOUI	JUMP',BS 20$	TCLR.L	D4:#BLEGR	TCLR.L	D4:#BLEPR	TCLR.L	D4:#BLELI	CALL	DBOXGREY	.B	1,320$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_LEGENDE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$	COMP.W	D3,#KEYICO+BLEOUI	JUMP',EQ 40$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:	TEST.L	D4:#BLEOUI	JUMP',BS 42$	TCLR.L	D4:#BLEGR	TCLR.L	D4:#BLEPR	TCLR.L	D4:#BLELI	CALL	DBOXGREY	.B	1,3	JUMP	20$42$:	TSET.L	D4:#BLEGR	TSET.L	D4:#BLEPR	CALL	DBOXFULL	.B	1,3	JUMP	20$80$:				; D'ACCORD =>	LOAD.L	(A6)+OLEFAN,D4	; sauve les fanions85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXECHELLE >;============/; Demande comment dessiner les chelles.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXECHELLE:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_ECHELLE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OECFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	TEST.B	(A6)+OPEFAN+3:#BPEOUI	JUMP',BS 20$	TCLR.L	D4:#BECAXY	TCLR.L	D4:#BECGRY	TCLR.L	D4:#BECNOY	TCLR.L	D4:#BECFYZ	CALL	DBOXGREY	.B	4,4	CALL	DBOXGREY	.B	13,120$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_ECHELLE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP,EQ 20$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:				; D'ACCORD =>	LOAD.L	(A6)+OECFAN,D4	; sauve les fanions85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXTITRE >;==========/; Demande comment dessiner le titre.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXTITRE:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_TITRE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OTIFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	TEST.L	D4:#BTIOUI	JUMP',BS 20$	CALL	DBOXGREY	.B	1,320$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_TITRE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$	COMP.W	D3,#KEYICO+BTIOUI	JUMP',EQ 40$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:	TEST.L	D4:#BTIOUI	JUMP',BS 42$	TCLR.L	D4:#BTIGA	TCLR.L	D4:#BTICE	TCLR.L	D4:#BTIDR	CALL	DBOXGREY	.B	1,3	JUMP	20$42$:	TCLR.L	D4:#BTIGA	TSET.L	D4:#BTICE	TCLR.L	D4:#BTIDR	CALL	DBOXFULL	.B	1,3	JUMP	20$80$:				; D'ACCORD =>	LOAD.L	(A6)+OTIFAN,D4	; sauve les fanions85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXZERO >;=========/; Demande comment dessiner la rfrence horizontale.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXZERO:	PUSHM.L	D0..D2,D4,D5,A1..A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	LOAD.L	A2,#R16"TDBOX_ZERO	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OZEFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	PUSH.L	D4	LOAD.L	D3,(A6)+OZEVAL+0	LOAD.L	D4,(A6)+OZEVAL+4 ; D3D4 <-- valeur du zro	LOAD.L	A3,#(A6)+OBUDIS+16*0	LOAD.L	D0,#2^BM64AVDER!2^BM64AVAVDER	SWAP.W	D0	LOAD.B	D0,#-4		; D0 <-- nb max de dcimales	SWAP.W	D0	LOAD.B	D0,#10		; D0 <-- nb max de caractres	MATH64_	FP_ASC		; OBUDIS <-- chiffre en clair	LOAD.L	D3,(A6)+OZEMAX+0	LOAD.L	D4,(A6)+OZEMAX+4 ; D3D4 <-- valeur maximale	LOAD.L	A3,#(A6)+OBUDIS+16*1	LOAD.L	D0,#2^BM64AVDER!2^BM64AVAVDER	SWAP.W	D0	LOAD.B	D0,#-4		; D0 <-- nb max de dcimales	SWAP.W	D0	LOAD.B	D0,#10		; D0 <-- nb max de caractres	MATH64_	FP_ASC		; OBUDIS <-- chiffre en clair	LOAD.L	D3,(A6)+OZEMIN+0	LOAD.L	D4,(A6)+OZEMIN+4 ; D3D4 <-- valeur minimale	LOAD.L	A3,#(A6)+OBUDIS+16*2	LOAD.L	D0,#2^BM64AVDER!2^BM64AVAVDER	SWAP.W	D0	LOAD.B	D0,#-4		; D0 <-- nb max de dcimales	SWAP.W	D0	LOAD.B	D0,#10		; D0 <-- nb max de caractres	MATH64_	FP_ASC		; OBUDIS <-- chiffre en clair	LOAD.L	D3,(A6)+OZEGRAD+0	LOAD.L	D4,(A6)+OZEGRAD+4 ; D3D4 <-- valeur graduation	LOAD.L	A3,#(A6)+OBUDIS+16*3	LOAD.L	D0,#2^BM64AVDER!2^BM64AVAVDER	SWAP.W	D0	LOAD.B	D0,#-4		; D0 <-- nb max de dcimales	SWAP.W	D0	LOAD.B	D0,#10		; D0 <-- nb max de caractres	MATH64_	FP_ASC		; OBUDIS <-- chiffre en clair	POP.L	D4	PUSH.L	D4	LOAD.W	D2,#(100+BZEQQ)!2^15	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS+16*0	LIB	?AFTEXT		; affiche la valeur quelconque	LOAD.W	D2,#(100+BZEMAX)!2^15	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS+16*1	LIB	?AFTEXT		; affiche la valeur maximale	LOAD.W	D2,#(100+BZEMIN)!2^15	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS+16*2	LIB	?AFTEXT		; affiche la valeur minimale	LOAD.W	D2,#(100+BZEGRAD)!2^15	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS+16*3	LIB	?AFTEXT		; affiche la valeur graduation	POP.L	D4	CLR.W	D2		; D2 <-- dite la valeur quelconque10$:	LOAD.L	A3,#(A6)+OBUDIS+16*0	TEST.W	D2	JUMP',EQ 12$	LOAD.L	A3,#(A6)+OBUDIS+16*1	COMP.W	D2,#1	JUMP',EQ 12$	LOAD.L	A3,#(A6)+OBUDIS+16*2	COMP.W	D2,#2	JUMP',EQ 12$	LOAD.L	A3,#(A6)+OBUDIS+16*312$:	LOAD.L	A4,A313$:	TEST.B	(A4+)	JUMP,NE 13$	DEC.L	A4	LOAD.W	D1,#BZEQQ	LOAD.W	D3,D2	JUMP',EQ 16$	LOAD.W	D1,#BZEMAX	COMP.W	D3,#1	JUMP',EQ 16$	LOAD.W	D1,#BZEMIN	COMP.W	D3,#2	JUMP',EQ 16$	LOAD.W	D1,#BZEGRAD16$:	TEST.L	D4:D1		; fanion correspondant allum ?	JUMP',BS 18$		; oui => 18$	LOAD.W	D3,#-1		; D3 <-- rien  diter18$:	DBOX_	MEDIT20$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_ZERO	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	89$	COMP.W	D3,#UNDO	JUMP,EQ 40$	COMP.W	D3,#CR	JUMP,EQ 45$	COMP.W	D3,#KEYICO+BZENUL	JUMP,EQ 20$	COMP.W	D3,#KEYICO+BZEMOY	JUMP,EQ 20$	COMP.W	D3,#KEYICO+BZEQQ	JUMP,EQ 50$	COMP.W	D3,#KEYICO+BZEMAX	JUMP,EQ 53$	COMP.W	D3,#KEYICO+BZEMIN	JUMP,EQ 55$	COMP.W	D3,#KEYICO+BZEGRAD	JUMP,EQ 57$	COMP.W	D3,#KEYICO+100+BZEQQ	JUMP,EQ 50$	COMP.W	D3,#KEYICO+100+BZEMAX	JUMP,EQ 52$	COMP.W	D3,#KEYICO+100+BZEMIN	JUMP,EQ 54$	COMP.W	D3,#KEYICO+100+BZEGRAD	JUMP,EQ 56$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	10$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	20$45$:				; RETURN =>	INC.W	D2		; D2 <-- rang uivant	COMP.W	D2,#4	JUMP,LO 10$	CLR.W	D2	JUMP	10$50$:				; clic dans valeur quelconque =>	TCLR.L	D4:#BZENUL	TCLR.L	D4:#BZEMOY	TSET.L	D4:#BZEQQ	CLR.W	D2	JUMP	10$52$:				; clic dans valeur maximale =>	TSET.L	D4:#BZEMAX	LOAD.W	D2,#1	JUMP	10$53$:	TEST.L	D4:#BZEMAX	JUMP,BC 20$	LOAD.W	D2,#1	JUMP	10$54$:				; clic dans valeur minimale =>	TSET.L	D4:#BZEMIN	LOAD.W	D2,#2	JUMP	10$55$:	TEST.L	D4:#BZEMIN	JUMP,BC 20$	LOAD.W	D2,#2	JUMP	10$56$:				; clic dans valeur graduation =>	TSET.L	D4:#BZEGRAD	LOAD.W	D2,#3	JUMP	10$57$:	TEST.L	D4:#BZEGRAD	JUMP,BC 20$	LOAD.W	D2,#3	JUMP	10$80$:				; D'ACCORD =>	TEST.B	(A3)	JUMP,EQ 30$	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBUDIS+16*0	MATH64_	ASC_FP		; D3D4 <-- valeur frappe	JUMP',VC 81$	POPM.L	D3,D4,A3	CLR.W	D2	JUMP	30$81$:	LOAD.L	(A6)+OZEVAL+0,D3	LOAD.L	(A6)+OZEVAL+4,D4	POPM.L	D3,D4,A3	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBUDIS+16*1	MATH64_	ASC_FP		; D3D4 <-- valeur frappe	JUMP',VC 82$	POPM.L	D3,D4,A3	LOAD.W	D2,#1	JUMP	30$82$:	LOAD.L	(A6)+OZEMAX+0,D3	LOAD.L	(A6)+OZEMAX+4,D4	POPM.L	D3,D4,A3	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBUDIS+16*2	MATH64_	ASC_FP		; D3D4 <-- valeur frappe	JUMP',VC 83$	POPM.L	D3,D4,A3	LOAD.W	D2,#2	JUMP	30$83$:	LOAD.L	(A6)+OZEMIN+0,D3	LOAD.L	(A6)+OZEMIN+4,D4	POPM.L	D3,D4,A3	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBUDIS+16*3	MATH64_	ASC_FP		; D3D4 <-- valeur frappe	JUMP',VC 84$	POPM.L	D3,D4,A3	LOAD.W	D2,#3	JUMP	30$84$:	MATH64_	ABS	LOAD.L	(A6)+OZEGRAD+0,D3	LOAD.L	(A6)+OZEGRAD+4,D4	POPM.L	D3,D4,A3	LOAD.L	(A6)+OZEFAN,D4	; sauve les fanions89$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXFILTRE >;===========/; Demande comment filtrer les lignes ou les colonnes.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXFILTRE:	PUSHM.L	D0..D2,D4,D5,A1..A5	LOAD.L	A2,#R16"TDBOX_FILTRE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,#B'01	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	CLR.B	(A6)+OFIXY	CALL	DBFIGET		; OFILT[X,Y] <-- OFILI[X,Y]15$:	LOAD.L	A5,#(A6)+OFISL	; A5 <-- ^variables de la scroll-liste	CALL	DBFIDSL		; dessine la scroll-liste	JUMP	45$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_FILTRE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	80$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	85$	COMP.W	D3,#F4	JUMP,EQ 70$	COMP.W	D3,#F5	JUMP,EQ 72$	COMP.W	D3,#F7	JUMP,EQ 60$	COMP.W	D3,#F10	JUMP,EQ 62$	COMP.W	D3,#F9	JUMP,EQ 50$	COMP.W	D3,#F12	JUMP,EQ 52$	COMP.W	D3,#KEYMGP	; clic ?	JUMP',EQ 40$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; clic ailleurs =>	PUSH.L	D4	LIB	?IFMOUSE	; D4 <-- position de la souris	LOAD.L	D3,D4	POP.L	D4	TEST.W	D7	JUMP,NE 30$	SUB.W	D3,(A0)+ODFFX	JUMP,LO 30$	SWAP.W	D3	SUB.W	D3,(A0)+ODFFY	; D3 <-- position dans swdo	JUMP,LO 30$	SWAP.W	D3	PUSH.L	D4	LOAD.L	D4,D3		; D4 <-- position de la souris	SCROLL_	LMOVE		; dans la scroll-liste ?	POPM.L	D4	JUMP,NE 30$45$:	SCROLL_	LUPDATE		; dessine le contenu	JUMP	20$50$:				; PREND UN =>	LOAD.W	D3,(A5)+OSLCYS	; D3 <-- case slectionne	CALL	DBFIADD	JUMP,NE 30$	JUMP	45$52$:				; FILTRE UN =>	LOAD.W	D3,(A5)+OSLCYS	; D3 <-- case slectionne	CALL	DBFISUB	JUMP,NE 30$	JUMP	45$60$:				; PREND TOUT =>	CALL	DBFIADDA	JUMP	45$62$:				; FILTRE TOUT =>	CALL	DBFISUBA	JUMP	45$70$:				; X =>	CLR.B	(A6)+OFIXY	JUMP	15$72$:				; Y =>	SET.B	(A6)+OFIXY	JUMP	15$80$:				; D'ACCORD =>	CALL	DBFIPUT		; OFILI[X,Y] <-- OFILT[X,Y]85$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBFIDSL >;--------/; Dessine la scroll-liste initiale.; in	A5.L	^variables scroll-liste;	D5.L	canal dbox; out	-; mod	D7.WDBFIDSL:	PUSHM.L	D2..D4,A3,A5	LOAD.W	D2,#0	DBOX_	GETCO		; D3 <-- coin sup/gauche	PUSH.L	D3	LOAD.W	D2,#8	DBOX_	GETCO	LOAD.L	D4,D3		; D4 <-- coin inf/droite	POP.L	D3	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A5)+OSLPOS,D3	LOAD.L	(A5)+OSLDIM,D4	SCROLL_	LDRAW		; dessine la scroll-liste vide	LOAD.W	(A5)+OSLCYN,(A6)+OALLX	TEST.B	(A6)+OFIXY	JUMP',EQ 50$	LOAD.W	(A5)+OSLCYN,(A6)+OALLY50$:	CLR.W	(A5)+OSLCYS	LOAD.L	A3,#R16"DBFIADL	LOAD.L	(A5)+OSLADL,A3	; donne ^routine DBFIADL	POPM.L	D2..D4,A3,A5	RET;--------\\; DBFIADL >;--------/; Donne le texte  afficher dans une case.; in	D3.W	rang de la case  afficher; out	A3.L	^texte;	D3.W	zro;	D7.W	erreur (si case vide); mod	D3.L, D7.W, A3.LDBFIADL:	PUSHM.L	D2,A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	A3,#R16"00$	CALL	DBFIUSE		; lment utilis ?	JUMP',EQ 10$		; oui => 10$	LOAD.L	A3,#R16"01$10$:	LOAD.B	(A4+),(A3+)	; OBUDIS <-- prend/filtre	JUMP,NE 10$	DEC.L	A4	LOAD.W	D2,#-1	SWAP.W	D2	LOAD.W	D2,D3	TEST.B	(A6)+OFIXY	JUMP',EQ 20$	LOAD.W	D2,D3	SWAP.W	D2	LOAD.W	D2,#-120$:	CALL	GETCHP		; A3 <-- ^chane30$:	LOAD.B	D3,(A3+)	JUMP',EQ 35$	COMP.B	D3,#TAB	JUMP',EQ 35$	COMP.B	D3,#CR	JUMP',EQ 35$	LOAD.B	(A4+),D3	; OBUDIS <-- chane	JUMP	30$35$:	CLR.B	(A4)		; OBUDIS <-- terminateur	LOAD.L	A3,#(A6)+OBUDIS	CLR.W	D3		; D3 <-- toujours zro	POPM.L	D2,A4	RET00$:	.ASCIZ	"Prend  "01$:	.ASCIZ	"Filtre "	.EVEN;--------\\; DBFIGET >;--------/; Transfert OFILI[X,Y] --> OFILT[X,Y]; in	-; out	-; mod	D7.WDBFIGET:	PUSHM.L	D4,A4,A5	LOAD.L	A4,#(A6)+OFILIX	LOAD.L	A5,#(A6)+OFILTX	LOAD.W	D4,#MAXXY+1-120$:	LOAD.B	(A5+),(A4+)	; OFILTX <-- OFILIX	DECJ.W,NMO D4,20$	LOAD.L	A4,#(A6)+OFILIY	LOAD.L	A5,#(A6)+OFILTY	LOAD.W	D4,#MAXXY+1-130$:	LOAD.B	(A5+),(A4+)	; OFILTY <-- OFILIY	DECJ.W,NMO D4,30$	POPM.L	D4,A4,A5	RET;--------\\; DBFIPUT >;--------/; Transfert OFILI[X,Y] <-- OFILT[X,Y]; in	-; out	-; mod	D7.WDBFIPUT:	PUSHM.L	D4,A4,A5	LOAD.L	A4,#(A6)+OFILIX	LOAD.L	A5,#(A6)+OFILTX	LOAD.W	D4,#MAXXY+1-120$:	LOAD.B	(A4+),(A5+)	; OFILIX <-- OFILTX	DECJ.W,NMO D4,20$	LOAD.L	A4,#(A6)+OFILIY	LOAD.L	A5,#(A6)+OFILTY	LOAD.W	D4,#MAXXY+1-130$:	LOAD.B	(A4+),(A5+)	; OFILIX <-- OFILTX	DECJ.W,NMO D4,30$	POPM.L	D4,A4,A5	RET;--------\\; DBFIADD >;--------/; Ajoute un lement dans une liste.; in	D3.B	rang; out	D7.W	erreur; mod	D7.WDBFIADD:	PUSHM.L	A4,A5	LOAD.W	D7,#1		; D7 <-- erreur	LOAD.L	A5,#(A6)+OFILTX	; A5 <-- ^dbut liste en X	TEST.B	(A6)+OFIXY	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OFILTY	; A5 <-- ^dbut liste en Y10$:	COMP.B	(A5),#-1	JUMP',EQ 20$	COMP.B	D3,(A5+)	JUMP,HI 10$	JUMP,EQ 90$	DEC.L	A520$:	LOAD.L	A4,A530$:	COMP.B	(A4+),#-1	JUMP,NE 30$40$:	LOAD.B	(A4),(A4)-1	DEC.L	A4	COMP.L	A4,A5	JUMP,NE 40$	LOAD.B	(A5),D3	CLR.W	D7		; D7 <-- ok90$:	POPM.L	A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBFISUB >;--------/; Supprime un lement dans une liste.; in	D3.B	rang; out	D7.W	erreur; mod	D7.WDBFISUB:	PUSH.L	A5	LOAD.W	D7,#1		; D7 <-- erreur	LOAD.L	A5,#(A6)+OFILTX	; A5 <-- ^dbut liste en X	TEST.B	(A6)+OFIXY	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OFILTY	; A5 <-- ^dbut liste en Y10$:	COMP.B	(A5),#-1	JUMP',EQ 90$	COMP.B	D3,(A5+)	JUMP,NE 10$30$:	LOAD.B	(A5)-1,(A5)	INC.L	A5	COMP.B	(A5)-1,#-1	JUMP,NE 30$	CLR.W	D7		; D7 <-- ok90$:	POP.L	A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBFIUSE >;--------/; Vrifie si un lement est utilis dans une liste.; in	D3.B	rang; out	D7.W	erreur si pas trouv; mod	D7.WDBFIUSE:	PUSH.L	A5	LOAD.W	D7,#1		; D7 <-- erreur	LOAD.L	A5,#(A6)+OFILTX	; A5 <-- ^dbut liste en X	TEST.B	(A6)+OFIXY	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OFILTY	; A5 <-- ^dbut liste en Y10$:	COMP.B	(A5),#-1	JUMP',EQ 90$	COMP.B	D3,(A5+)	JUMP,NE 10$	CLR.W	D7		; D7 <-- ok90$:	POP.L	A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBFIADDA >;---------/; Ajoute tous les lements dans une liste.; in	-; out	-; mod	D7.WDBFIADDA:	PUSHM.L	D4,A5	CLR.B	D4	LOAD.L	A5,#(A6)+OFILTX	; A5 <-- ^dbut liste en X	TEST.B	(A6)+OFIXY	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OFILTY	; A5 <-- ^dbut liste en Y10$:	LOAD.B	(A5+),D4	INC.B	D4	COMP.B	D4,#MAXXY	JUMP,LO 10$	LOAD.B	(A5),#-1	POPM.L	D4,A5	RET;---------\\; DBFISUBA >;---------/; Supprime tous les lements dans une liste.; in	-; out	-; mod	D7.WDBFISUBA:	PUSH.L	A5	LOAD.L	A5,#(A6)+OFILTX	; A5 <-- ^dbut liste en X	TEST.B	(A6)+OFIXY	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OFILTY	; A5 <-- ^dbut liste en Y10$:	LOAD.B	(A5),#-1	POP.L	A5	RET;---------\\; DBOXTDEF >;=========/; Dfini une trame 8x8 quelconque.; in	-; out	D3.L	d'accord/annule (F1/F0);	D7.W	erreur; mod	D3.L D7.WDBOXTDEF:	PUSHM.L	D2,D4,A2..A4	CALL	ERGMOUSE	; efface les flches dans les rgles	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	COMP.B	(A6)+OKEY,#ICODTRAME	JUMP',EQ 50$	CLR.W	D2	LOAD.B	D2,(A6)+OFTDEF	SWAP.W	D2	TCLR.L	D2:#BMAICO	LOAD.W	D2,#2^BDBSAV	LOAD.W	D4,(A6)+ONTDEF	LOAD.L	A3,#R16"04$	; A3 <-- ^trois textes	LOAD.L	A4,#(A6)+OTDEF	; A4 <-- ^trames	DESSIN_	TEDIT		; dite les trames ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	SWAP.W	D2	LOAD.B	(A6)+OFTDEF,D2;	SWAP.W	D2	LOAD.W	(A6)+ONTDEF,D4	JUMP'	90$50$:	LOAD.L	D2,#2^BDBSAV!2^BMAICO	CLR.W	D4	LOAD.L	A2,#R16"01$	; A2 <-- ^table d'icnes	COMP.B	(A6)+OGRAPHE,#ICOGLIS	JUMP',NE 60$	LOAD.L	A2,#R16"02$	; A2 <-- ^table d'icnes60$:	LOAD.L	A3,#R16"03$	; A3 <-- ^trois textes	LOAD.L	A4,#(A6)+OTDDEF	; A4 <-- ^trames	DESSIN_	TEDIT		; dite les trames ...90$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	POPM.L	D2,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOTFOND	.B	ICOTHAUT	.B	ICOTDROITE	.B	0	.EVEN02$:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLTFOND	.B	ICOLTHAUT	.B	ICOLTDROITE	.B	0	.EVEN03$:	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.EVEN04$:	.ASCIZ	"1..n"	.ASCIZ	"un seul"	.ASCIZ	"ombr"	.EVEN;---------\\; DBOXPDEF >;=========/; Dfini un pinceau 8x8 quelconque.; in	-; out	D3.L	d'accord/annule (F1/F0);	D7.W	erreur; mod	D3.L D7.WDBOXPDEF:	PUSHM.L	D2,D4,A2..A4	CALL	ERGMOUSE	; efface les flches dans les rgles	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	COMP.B	(A6)+OKEY,#ICODLIGNE	JUMP',EQ 50$	CLR.W	D2	LOAD.B	D2,(A6)+OFPDEF	SWAP.W	D2	TCLR.L	D2:#BMAICO	LOAD.W	D2,#2^BDBSAV	LOAD.W	D4,(A6)+ONPDEF	LOAD.L	A3,#R16"04$	; A3 <-- ^trois textes	LOAD.L	A4,#(A6)+OPDEF	; A4 <-- ^pinceaux	DESSIN_	DEDIT		; dite les pinceaux ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	SWAP.W	D2	LOAD.B	(A6)+OFPDEF,D2;	SWAP.W	D2	LOAD.W	(A6)+ONPDEF,D4	JUMP'	90$50$:	LOAD.L	D2,#2^BDBSAV!2^BMAICO	CLR.W	D4	LOAD.L	A2,#R16"01$	; A2 <-- ^table d'icnes	COMP.B	(A6)+OGRAPHE,#ICOGLIS	JUMP',NE 60$	LOAD.L	A2,#R16"02$	; A2 <-- ^table d'icnes60$:	LOAD.L	A3,#R16"03$	; A3 <-- ^trois textes	LOAD.L	A4,#(A6)+OPDDEF	; A4 <-- ^pinceaux	DESSIN_	DEDIT		; dite les pinceaux ...90$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	POPM.L	D2,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLGRAPHE	.B	ICOLAXE	.B	ICOLHGRILLE	.B	ICOLVGRILLE	.B	0	.EVEN02$:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLLGRAPHE	.B	ICOLLAXE	.B	ICOLLHGRILLE	.B	ICOLLVGRILLE	.B	0	.EVEN03$:	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.EVEN04$:	.ASCIZ	"1..n"	.ASCIZ	"un seul"	.ASCIZ	""	.EVEN;---------\\; DBOXXDEF >;=========/; Dfini un point 8x8 quelconque.; in	-; out	D3.L	d'accord/annule (F1/F0);	D7.W	erreur; mod	D3.L D7.WDBOXXDEF:	PUSHM.L	D2,D4,A2..A4	CALL	ERGMOUSE	; efface les flches dans les rgles	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.L	D2,#2^BDBSAV	SWAP.W	D2	LOAD.B	D2,(A6)+OFXDEF	SWAP.W	D2	LOAD.W	D4,(A6)+ONXDEF	LOAD.L	A3,#R16"03$	; A3 <-- ^trois textes	LOAD.L	A4,#(A6)+OXDEF	; A4 <-- ^points20$:	DESSIN_	PEDIT		; dite les points ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	SWAP.W	D2	LOAD.B	(A6)+OFXDEF,D2;	SWAP.W	D2	LOAD.W	(A6)+ONXDEF,D490$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	POPM.L	D2,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET03$:	.ASCIZ	"1..n"	.ASCIZ	"un seul"	.ASCIZ	""	.EVEN;---------\\; WAITDBOX >;=========/; Met la dbox "Attendez un instant ..."; in	-; out	D7.W	erreur; mod	D7.WWAITDBOX:	PUSHM.L	D2..D5,A2	CALL	NORMDBOX	; enlve si dj l	LOAD.L	A2,#R16"TDBOX_WAIT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE 90$	LOAD.L	(A6)+OCHDBW,D5	LIB	?GETWDO	LOAD.W	(A6)+ONWDBW,D5	CLR.W	D5	LIB	?USEWDO		; utilise la swdo principale90$:	POPM.L	D2..D5,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; NORMDBOX >;=========/; Enlve la dbox "Attendez un instant ..."; in	-; out	-; mod	-NORMDBOX:	PUSHM.L	D5,D7	TEST.L	(A6)+OCHDBW	JUMP',EQ 90$	LOAD.W	D5,(A6)+ONWDBW	LIB	?USEWDO		; utilise la bonne swdo	LOAD.L	D5,(A6)+OCHDBW	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys	CLR.L	(A6)+OCHDBW90$:	POPM.L	D5,D7	RET	.END