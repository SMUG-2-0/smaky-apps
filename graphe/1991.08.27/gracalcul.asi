	.SBTTL	GRACALCUL;---------\\; CALCZERO >;=========/; Calcul la position du "zro".; in	(A6)+OZEVAL.64	valeur donne dans dbox; out	(A6)+OZERO.64	valeur utilisable; mod	D7.WCALCZERO:	PUSHM.L	D1..D4,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	CLR.L	D3	CLR.L	D4		; D3D4 <-- zro	COMP.B	(A6)+OGRAPHE,#ICOGEMP	JUMP',EQ 20$	TEST.B	(A6)+OZEFAN+3:#BZEMOY	JUMP,BS 50$	TEST.B	(A6)+OZEFAN+3:#BZEQQ	JUMP',BC 20$	LOAD.L	D3,(A6)+OZEVAL+0	LOAD.L	D4,(A6)+OZEVAL+4 ; D3D4 <-- valeur demand20$:	LOAD.L	D1,(A6)+OMAX+0	LOAD.L	D2,(A6)+OMAX+4	MATH64_	COMP	JUMP',LS 30$	LOAD.L	D3,(A6)+OMAX+0	LOAD.L	D4,(A6)+OMAX+4	; D3D4 <-- maximum possible30$:	LOAD.L	D1,(A6)+OMIN+0	LOAD.L	D2,(A6)+OMIN+4	MATH64_	COMP	JUMP',HS 35$	LOAD.L	D3,(A6)+OMIN+0	LOAD.L	D4,(A6)+OMIN+4	; D3D4 <-- minimum possible35$:	LOAD.L	(A6)+OZERO+0,D3	LOAD.L	(A6)+OZERO+4,D4	JUMP'	90$50$:	LOAD.L	(A6)+OZERO+0,(A6)+OMOY+0	LOAD.L	(A6)+OZERO+4,(A6)+OMOY+490$:	POPM.L	D1..D4,A5	RET;----------\\; CALCGRADZ >;==========/; Calcul l'espacement pour la graduation verticale (axe Z).;	x = (MAX-MIN)*2Hcar / Hgra;	a = 10^INT( LOG(x) );	x'= a*INT(x/a); in	-; out	(A6)+OGRAD.64	x';	(A6)+OGRADL.W	nb de digits ncessaires;	(A6)+OGRADN.W	nb de dcimales; mod	D7.WCALCGRADZ:	PUSHM.L	D1..D6,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	LOAD.L	A3,#R16"TGCAZ	; A3 <-- ^titre gencar "Axe Z"	CALL	GETTGC		; A4 <-- ^dans OBUGC	CLR.L	D4	LOAD.W	D4,(A4)+OGC1Y	ADD.W	D4,(A4)+OGC2Y	; D4 <-- Hcar	SL.W	D4,#1		; D4 <-- 2Hcar	MATH64_	BINFP		; D3D4 <-- 2Hcar	LOAD.L	D5,D3	LOAD.L	D6,D4	LOAD.L	D3,(A6)+OMAX+0	LOAD.L	D4,(A6)+OMAX+4	LOAD.L	D1,(A6)+OMIN+0	LOAD.L	D2,(A6)+OMIN+4	MATH64_	SUB		; D3D4 <-- MAX-MIN	LOAD.L	D1,D5	LOAD.L	D2,D6	MATH64_	MUL		; D3D4 <-- (MAX-MIN)*2Hcar	PUSHM.L	D3,D4	CLR.L	D4	LOAD.W	D4,(A6)+ODGRAY	SUB.W	D4,(A6)+OMARGH	SUB.W	D4,(A6)+OMARGB	SUB.W	D4,(A6)+OPERSY	SUB.W	D4,(A6)+OPERSZ	; D4 <-- Hgra	MATH64_	BINFP		; D3D4 <-- Hgra	LOAD.L	D1,D3	LOAD.L	D2,D4	POPM.L	D3,D4	MATH64_	DIV		; D3D4 <-- x = (MAX-MIN)*2Hcar / Hgra	LOAD.L	D5,D3	LOAD.L	D6,D4		; D5D6 <-- x	MATH64_	LOG10		; D3D4 <-- LOG(x)	TEST.L	D3:#31		; nombre ngatif ?	JUMP',BC 30$		; non => 30$	LOAD.L	D1,#UN_MSPFP64	; oui =>	LOAD.L	D2,#UN_LSPFP64	MATH64_	SUB		; D3D4 <-- LOG(x)-130$:	MATH64_	SEP		; D3D4 <-- INT( LOG(x) )	PUSHM.L	D3,D4	MATH64_	FPBIN	TEST.L	D4	JUMP',NS 40$	CLR.W	(A6)+OGRADN	ADD.W	D4,#5		; D4 <-- place pour "+/-"	JUMP'	50$40$:	NEG.L	D4;;?	INC.W	D4	LOAD.W	(A6)+OGRADN,D4	ADD.W	D4,#5		; D4 <-- place pour "+/-" et "."50$:	LOAD.W	(A6)+OGRADL,D4	POPM.L	D3,D4	MATH64_	EXP10		; D3D4 <-- a = 10^INT( LOG(x) )	EX.L	D5,D3	EX.L	D6,D4		; D3D4 <-- x, D5D6 <-- a	LOAD.L	D1,D5	LOAD.L	D2,D6	MATH64_	DIV		; D3D4 <-- x/a	MATH64_	SEP		; D3D4 <-- INT(x/a)	LOAD.L	D1,D5	LOAD.L	D2,D6	MATH64_	MUL		; D3D4 <-- x'= a*INT(x/a)	TEST.B	(A6)+OZEFAN+3:#BZEGRAD	JUMP',BC GRAD$	LOAD.L	D1,(A6)+OZEGRAD+0	OR.L	D1,(A6)+OZEGRAD+4	JUMP',EQ GRAD$	LOAD.L	D3,(A6)+OZEGRAD+0	LOAD.L	D4,(A6)+OZEGRAD+4	LOAD.L	D1,#DEUX_MSPFP64	LOAD.L	D2,#DEUX_LSPFP64	MATH64_	DIV		; D3D4 <-- OZEGRAD/2GRAD$:	LOAD.L	(A6)+OGRAD+0,D3	LOAD.L	(A6)+OGRAD+4,D4	POPM.L	D1..D6,A5	RET;--------\\; ZPENTE  >;--------/; Incline une pente pour suivre l'axe "Z".; in	D4.L	(dy=0;dx); out	D4.L	(dy;dx); mod	D4.L, D7.WZPENTE:	PUSHM.L	D1,D2	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP',BC 90$		; non => 90$				; oui =>	LOAD.W	D2,(A6)+OPERSZ	MUL.WA	D2,D4	LOAD.W	D1,(A6)+ODGRAX	SUB.W	D1,(A6)+OMARGG	SUB.W	D1,(A6)+OMARGD	SUB.W	D1,(A6)+OPERSX	DIV.WA	D2,D1	SWAP.W	D4	LOAD.W	D4,D2	SWAP.W	D490$:	POPM.L	D1,D2	RET;--------\\; ZPOINT  >;--------/; Monte un point selon l'axe "Z".; in	D3.L	point (y;x); out	D3.L	point (y;x); mod	D3.L, D7.WZPOINT:	PUSHM.L	D1,D2	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP',BC 90$		; non => 90$				; oui =>	LOAD.W	D2,(A6)+OPERSZ	MUL.WU	D2,(A6)+OPOSZ	LOAD.W	D1,(A6)+ODGRAX	SUB.W	D1,(A6)+OMARGG	SUB.W	D1,(A6)+OMARGD	SUB.W	D1,(A6)+OPERSX	DIV.WU	D2,D1	SWAP.W	D3	SUB.W	D3,D2	SWAP.W	D390$:	POPM.L	D1,D2	RET;---------------\\; GETPERSPECTIVE >;===============/; Calcul les paramtres pour la perspective.; in	(A6)+OPELG.W	longueur [%];	(A6)+OPEAD.W	angle droite [deg];	(A6)+OPEAD.W	angle gauche [deg]; out	D7.W		erreur; mod	D7.WGETPERSPECTIVE:	PUSHM.L	D3,D4	CLR.W	(A6)+OPERSZ	CLR.L	(A6)+OPERSY	CLR.L	(A6)+OPERTY	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP,BC 50$		; non => 50$				; oui =>	LOAD.W	D4,(A6)+ODGRAX	SUB.W	D4,(A6)+OMARGG	SUB.W	D4,(A6)+OMARGD	MUL.WU	D4,(A6)+OPELG	DIV.WU	D4,#100	LOAD.W	(A6)+OPERSX,D4	LOAD.W	D3,(A6)+OPEAD	; D3 <-- angle droite;	LOAD.W	D4,(A6)+OPERSX	; D4 <-- longueur	CALL	GETPTAN	LOAD.W	(A6)+OPERSY,D4	LOAD.W	D3,(A6)+OPEAG	; D3 <-- angle gauche	LOAD.W	D4,(A6)+ODGRAX	SUB.W	D4,(A6)+OMARGG	SUB.W	D4,(A6)+OMARGD	SUB.W	D4,(A6)+OPERSX	; D4 <-- longueur	CALL	GETPTAN	LOAD.W	(A6)+OPERSZ,D4	LOAD.L	(A6)+OPERTY,(A6)+OPERSY	LOAD.W	D4,(A6)+ODIMX	DEC.W	D4	COMP.B	(A6)+OGRAPHE,#ICOGBRI ; ligne brise ?	JUMP',EQ 40$		; oui => 40$	INC.W	D4	TEST.B	(A6)+OPEFAN+3:#BPEDER ; l'un derrire l'autre ?	JUMP',BC 50$		; non => 50$40$:				; oui =>	TEST.W	D4	JUMP',EQ 50$	CLR.L	D3	LOAD.W	D3,(A6)+OPERTY	DIV.WU	D3,D4	LOAD.W	(A6)+OPERTY,D3	MUL.WU	D3,D4	LOAD.W	(A6)+OPERSY,D3	CLR.L	D3	LOAD.W	D3,(A6)+OPERTX	DIV.WU	D3,D4	LOAD.W	(A6)+OPERTX,D3	MUL.WU	D3,D4	LOAD.W	(A6)+OPERSX,D350$:	CALL	DESPOSAXES	; D3/D4 <-- pos/dim des axes	LOAD.W	D7,#ERGPERS	; D7 <-- a joue pas	SWAP.W	D4	COMP.W	D4,#10	JUMP',LT 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETPTAN >;--------/; Calcul la formule lg:=lg*TAN(a).; in	D3.W	angle [deg];	D4.W	longueur; out	D4.W	longueur oppose; mod	D4.L, D7.WGETPTAN:	PUSHM.L	D0..D3,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	LOAD.W	D0,D4		; D0 <-- longueur	CLR.L	D4	LOAD.W	D4,D3		; D4 <-- angle [deg]	MATH64_	BINFP		; D3D4 <-- angle [deg]	LOAD.L	D1,#PI_MSPFP64	LOAD.L	D2,#PI_LSPFP64	MATH64_	MUL		; D3D4 <-- angle * PI	PUSHM.L	D3,D4	LOAD.L	D4,#180	MATH64_	BINFP	LOAD.L	D1,D3	LOAD.L	D2,D4		; D1D2 <-- 180	POPM.L	D3,D4	MATH64_	DIV		; D3D4 <-- angle [rad]	MATH64_	TAN		; D3D4 <-- TAN(angle)	PUSHM.L	D3,D4	CLR.L	D4	LOAD.W	D4,D0		; D4 <-- longueur	MATH64_	BINFP	LOAD.L	D1,D3	LOAD.L	D2,D4		; D1D2 <-- longueur	POPM.L	D3,D4	MATH64_	MUL		; D3D4 <-- longueur * TAN(angle)	MATH64_	FPBIN	POPM.L	D0..D3,A5	RET;----------\\; CONVMULYA >;==========/; Converti un nombre sur un axe en une hauteur en Y.; in	D3D4	nombre en Y; out	D4.L	hauteur Y dans l'cran; mod	D4.L, D7.WCONVMULYA:	PUSHM.L	D1,D2,D3	LOAD.L	D1,D3	LOAD.L	D2,D4	LOAD.L	D3,(A6)+OMAX+0	LOAD.L	D4,(A6)+OMAX+4	MATH64_	TEST	JUMP',LO LOW$	LOAD.L	D3,(A6)+OMIN+0	LOAD.L	D4,(A6)+OMIN+4	MATH64_	TEST	JUMP',HI HIGH$	LOAD.L	D3,(A6)+OMAX+0	LOAD.L	D4,(A6)+OMAX+4	MATH64_	SUB		; D3D4 <-- MAX-valeur	JUMP'	CONV$HIGH$:	LOAD.L	D3,(A6)+OMAX+0	LOAD.L	D4,(A6)+OMAX+4	MATH64_	SUB		; D3D4 <-- MAX-valeur	LOAD.L	D1,(A6)+OMIN+0	LOAD.L	D2,(A6)+OMIN+4	MATH64_	SUB		; D3D4 <-- MAX-valeur-MIN	JUMP'	CONV$LOW$:	LOAD.L	D3,D1	LOAD.L	D4,D2	MATH64_	NEG		; D3D4 <-- -valeur;	JUMP'	CONV$CONV$:	CALL	CONVMULY	; D4 <-- hauteur Y dans l'cran	POPM.L	D1,D2,D3	RET;---------\\; CONVMULY >;=========/; Converti un nombre en une hauteur en Y.; in	D3D4	nombre en Y; out	D4.L	hauteur Y dans l'cran; mod	D4.L, D7.WCONVMULY:	PUSHM.L	D1..D3,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	LOAD.L	D1,(A6)+OMULY+0	LOAD.L	D2,(A6)+OMULY+4	MATH64_	MUL	MATH64_	FPBIN	POPM.L	D1..D3,A5	RET;--------\\; GETMULY >;========/; Calcul le facteur multiplicatif pour reprsenter graphiquement; un nombre  l'cran.; in	-; out	(A6)+OMULY.64	facteur en Y; mod	D7.WGETMULY:	PUSHM.L	D1..D4,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	CLR.L	D4	LOAD.W	D4,(A6)+ODGRAY	SUB.W	D4,(A6)+OMARGH	SUB.W	D4,(A6)+OMARGB	SUB.W	D4,(A6)+OPERSY	SUB.W	D4,(A6)+OPERSZ	MATH64_	BINFP		; D3D4 <-- hauteur  l'cran	PUSHM.L	D3,D4	LOAD.L	D3,(A6)+OMAX+0	LOAD.L	D4,(A6)+OMAX+4	LOAD.L	D1,(A6)+OMIN+0	LOAD.L	D2,(A6)+OMIN+4	MATH64_	SUB		; D3D4 <-- MAX-MIN	LOAD.L	D1,D3	LOAD.L	D2,D4	POPM.L	D3,D4	MATH64_	DIV		; D3D4 <-- hauteur_cran / (MAX-MIN)	LOAD.L	(A6)+OMULY+0,D3	LOAD.L	(A6)+OMULY+4,D4	POPM.L	D1..D4,A5	RET;--------\\; POSZERO >;========/; Donne la position du zro.; in	-; out	D3D4	position; mod	D3.L, D4.L, D7.WPOSZERO:	PUSHM.L	D1,D2,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	LOAD.L	D3,(A6)+OMAX+0	LOAD.L	D4,(A6)+OMAX+4	LOAD.L	D1,(A6)+OZERO+0	LOAD.L	D2,(A6)+OZERO+4	MATH64_	SUB	POPM.L	D1,D2,A5	RET;-----------\\; GETMOYENNE >;===========/; Calcul la moyenne gnrale de tous les nombres du tableau.; in	-; out	(A6)+OMOY.64	moyenne gnrale; mod	D7.WGETMOYENNE:	PUSHM.L	D0..D5,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	CLR.L	(A6)+OMOY+0	CLR.L	(A6)+OMOY+4	; OMOY <-- somme	CLR.L	D5		; D5 <-- n	TEST.B	(A6)+OZEFAN+3:#BZEMOY	JUMP',BC 90$	CLR.L	D0		; D0 <-- coordonne Y initiale10$:	CLR.W	D0		; D0 <-- coordonne X initiale20$:	LOAD.L	D2,D0		; D2 <-- coordonne (y;x)	CALL	GETNB0		; D3D4 <-- nombre	JUMP',NE 70$	LOAD.L	D1,(A6)+OMOY+0	LOAD.L	D2,(A6)+OMOY+4	MATH64_	ADD	LOAD.L	(A6)+OMOY+0,D3	LOAD.L	(A6)+OMOY+4,D4	INC.L	D5		; D5 <-- n+170$:	INC.W	D0		; D0 <-- coordonne X suivante	COMP.W	D0,(A6)+ODIMX	JUMP,LO 20$	SWAP.W	D0	INC.W	D0		; D0 <-- coordonne Y suivante	LOAD.W	D1,D0	SWAP.W	D0	COMP.W	D1,(A6)+ODIMY	JUMP,LO 10$	LOAD.L	D4,D5	MATH64_	BINFP	LOAD.L	D1,D3	LOAD.L	D2,D4		; D1D2 <-- n	LOAD.L	D3,(A6)+OMOY+0	LOAD.L	D4,(A6)+OMOY+4	MATH64_	DIV		; D3D4 <-- somme / n	LOAD.L	(A6)+OMOY+0,D3	LOAD.L	(A6)+OMOY+4,D490$:	POPM.L	D0..D5,A5	RET;----------\\; GETMINMAX >;==========/; Cherche le plus petit et le plus grand nombre contenu; dans un tableau.; Le nombre le plus petit est plus petit ou gal  zro.; Le nombre le plus grand est plus grand ou gal  zro.; in	-; out	(A6)+OMIN.64	nombre le plus petit (<0);	(A6)+OMAX.64	nombre le plus grand (>0);	D7.W		erreur; mod	D7.WGETMINMAX:	LOAD.L	(A6)+OMIN+0,#ZERO_MSPFP64	LOAD.L	(A6)+OMIN+4,#ZERO_LSPFP64	LOAD.L	(A6)+OMAX+0,#ZERO_MSPFP64	LOAD.L	(A6)+OMAX+4,#ZERO_LSPFP64	COMP.B	(A6)+OGRAPHE,#ICOGEMP	JUMP',EQ 30$	COMP.B	(A6)+OGRAPHE,#ICOGCAM	JUMP',EQ 30$	COMP.B	(A6)+OGRAPHE,#ICOGLIS	JUMP',EQ 30$	TEST.B	(A6)+OZEFAN+3:#BZEMIN	JUMP',BC 20$	LOAD.L	(A6)+OMIN+0,#MAX_MSPFP64	LOAD.L	(A6)+OMIN+4,#MAX_LSPFP6420$:	TEST.B	(A6)+OZEFAN+3:#BZEMAX	JUMP',BC 30$	LOAD.L	(A6)+OMAX+0,#MIN_MSPFP64	LOAD.L	(A6)+OMAX+4,#MIN_LSPFP6430$:	COMP.B	(A6)+OGRAPHE,#ICOGCAC	JUMP,EQ	GETMINMAXCAC	COMP.B	(A6)+OGRAPHE,#ICOGBRI	JUMP,EQ	GETMINMAXCAC	COMP.B	(A6)+OGRAPHE,#ICOGEMP	JUMP,EQ	GETMINMAXEMP	COMP.B	(A6)+OGRAPHE,#ICOGCAM	JUMP,EQ	GETMINMAXEMP	CALL	GETMINMAXDBOX	; mj. selon valeur de la dbox	CLR.W	D7		; D7 <-- ok	RET;-------------\\; GETMINMAXCAC >;-------------/; Cherche le plus petit et le plus grand nombre contenu; dans un tableau cte  cte.; in	-; out	(A6)+OMIN.64	nombre le plus petit (<0);	(A6)+OMAX.64	nombre le plus grand (>0);	D7.W		erreur; mod	D7.WGETMINMAXCAC:	PUSHM.L	D0..D4,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	CLR.L	D0		; D0 <-- coordonne Y initiale10$:	CLR.W	D0		; D0 <-- coordonne X initiale20$:	LOAD.L	D2,D0		; D2 <-- coordonne (y;x)	CALL	GETNB0		; D3D4 <-- nombre	JUMP',NE 70$	LOAD.L	D1,(A6)+OMIN+0	LOAD.L	D2,(A6)+OMIN+4	; D1D2 <-- minimum	MATH64_	COMP	JUMP',HS 40$	LOAD.L	(A6)+OMIN+0,D3	LOAD.L	(A6)+OMIN+4,D4	; OMIN <-- minimum40$:	LOAD.L	D1,(A6)+OMAX+0	LOAD.L	D2,(A6)+OMAX+4	; D1D2 <-- n1	MATH64_	COMP	JUMP',LS 70$	LOAD.L	(A6)+OMAX+0,D3	LOAD.L	(A6)+OMAX+4,D4	; OMAX <-- maximum70$:	INC.W	D0		; D0 <-- coordonne X suivante	COMP.W	D0,(A6)+ODIMX	JUMP,LO 20$	SWAP.W	D0	INC.W	D0		; D0 <-- coordonne Y suivante	LOAD.W	D1,D0	SWAP.W	D0	COMP.W	D1,(A6)+ODIMY	JUMP,LO 10$	CALL	GETMINMAXDBOX	; mj. selon valeur de la dbox	POPM.L	D0..D4,A5	CLR.W	D7		; D7 <-- toujours OK	RET;-------------\\; GETMINMAXEMP >;-------------/; Cherche le plus petit et le plus grand nombre contenu; dans un tableau empil.; in	-; out	(A6)+OMIN.64	nombre le plus petit (toujours 0);	(A6)+OMAX.64	nombre le plus grand (>0);	D7.W		erreur; mod	D7.WGETMINMAXEMP:	PUSHM.L	D0..D4,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	CLR.L	D0		; D0 <-- coordonne Y initiale10$:	CLR.W	D0		; D0 <-- coordonne X initiale	LOAD.L	D1,#ZERO_MSPFP64	LOAD.L	D2,#ZERO_LSPFP6420$:	PUSH.L	D2	LOAD.L	D2,D0		; D2 <-- coordonne (y;x)	CALL	GETNB0		; D3D4 <-- nombre	POPM.L	D2	JUMP',NE 40$	LOAD.W	D7,#ERGNNEG	TEST.L	D3:#31		; nombre ngatif ?	JUMP,BS 90$		; oui => 90$	MATH64_	ADD	LOAD.L	D1,D3		; D1D2 <-- somme des nombres en X	LOAD.L	D2,D440$:	INC.W	D0		; D0 <-- coordonne X suivante	COMP.W	D0,(A6)+ODIMX	JUMP,LO 20$	LOAD.L	D1,(A6)+OMAX+0	LOAD.L	D2,(A6)+OMAX+4	; D1D2 <-- n1	MATH64_	COMP	JUMP',LS 70$	LOAD.L	(A6)+OMAX+0,D3	LOAD.L	(A6)+OMAX+4,D4	; OMAX <-- maximum70$:	SWAP.W	D0	INC.W	D0		; D0 <-- coordonne Y suivante	LOAD.W	D1,D0	SWAP.W	D0	COMP.W	D1,(A6)+ODIMY	JUMP,LO 10$	CALL	GETMINMAXDBOX	; mj. selon valeur de la dbox	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D4,A5	TEST.W	D7		; retour EQ/NE	RET;--------------\\; GETMINMAXDBOX >;--------------/; Prend v. les valeurs min/max donnes dans la dbox.; in	-; out	-; mod	D7.WGETMINMAXDBOX:	PUSHM.L	D1..D4	TEST.B	(A6)+OZEFAN+3:#BZEMIN	JUMP',BC 40$	LOAD.L	D3,(A6)+OZEMIN+0	LOAD.L	D4,(A6)+OZEMIN+4 ; D3D4 <-- minimum selon dbox	LOAD.L	D1,(A6)+OMIN+0	LOAD.L	D2,(A6)+OMIN+4	; D1D2 <-- minimum	MATH64_	COMP	JUMP',HS 40$	LOAD.L	(A6)+OMIN+0,D3	LOAD.L	(A6)+OMIN+4,D4	; OMIN <-- minimum40$:	TEST.B	(A6)+OZEFAN+3:#BZEMAX	JUMP',BC 50$	LOAD.L	D3,(A6)+OZEMAX+0	LOAD.L	D4,(A6)+OZEMAX+4 ; D3D4 <-- maximum selon dbox	LOAD.L	D1,(A6)+OMAX+0	LOAD.L	D2,(A6)+OMAX+4	; D1D2 <-- n1	MATH64_	COMP	JUMP',LS 50$	LOAD.L	(A6)+OMAX+0,D3	LOAD.L	(A6)+OMAX+4,D4	; OMAX <-- maximum50$:	POPM.L	D1..D4	RET;--------\\; GETNB   >;========/; Cherche un nombre dans le tableau.; in	D2.L	coordonne (y;x); out	D3D4	nombre;	D7.W	erreur; mod	D3.L, D4.L, D7.WGETNB:	PUSHM.L	D1,D2,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	CALL	GETNB0		; D3D4 <-- nombre	JUMP',NE 90$	LOAD.L	D1,(A6)+OZERO+0	LOAD.L	D2,(A6)+OZERO+4	MATH64_	SUB		; D3D4 <-- nombre - "zro"	JUMP',VS 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D2,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETNB0  >;========/; Cherche un nombre dans le tableau.; in	D2.L	coordonne (y;x); out	D3D4	nombre;	D7.W	erreur; mod	D3.L, D4.L, D7.WGETNB0:	PUSHM.L	D2,A3,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	TEST.B	(A6)+OGAFAN+3:#BGAUSS ; courbe de Gauss ?	JUMP,BS 50$		; oui => 50$	LOAD.W	D7,#ERGRAPH	; D7 <-- hors du tableau	TEST.L	(A6)+OPGRA	JUMP,EQ 90$	CALL	GETCOOR		; D2 <-- coordonne physique	CALL	GETFILTRE	; D2 <-- coordonne selon filtre	TEST.L	(A3)+OPNUM	; tableau de nombre existe ?	JUMP',EQ 30$		; non => 30$				; oui =>	LOAD.L	A3,(A6)+OPNUM	; A3 <-- ^tableau de nombres FP	SL.W	D2,#3	ADD.W	A3,D2	SWAP.W	D2	MUL.WU	D2,(A6)+OALLX	SL.L	D2,#3	ADD.L	A3,D2	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3+)	; D3D4 <-- nombre	CLR.W	D7		; D7 <-- ok	COMP.L	D3,#H'FFFF0000	; erreur ?	JUMP,NE 90$		; non => 90$	LOAD.L	D7,D4		; D7 <-- code de l'erreur	JUMP	90$30$:	CALL	GETCHP		; A3 <-- ^nombre en ASCII	JUMP,NE 90$	MATH64_	ASC_FP		; D3D4 <-- nombre	JUMP,VS 90$	CLR.W	D7		; D7 <-- ok	JUMP	90$50$:				; courbe de Gauss =>	LOAD.W	D7,#ERGRAPH	; D7 <-- hors du tableau	TEST.L	(A6)+OPGAUSS	JUMP',EQ 90$	LOAD.L	A3,(A6)+OPGAUSS	COMP.W	D2,#-1	JUMP',EQ 90$	ADD.W	A3,D2	SWAP.W	D2	COMP.W	D2,#-1	JUMP',EQ 90$	MUL.WU	D2,(A6)+ODIMX	ADD.L	A3,D2	CLR.L	D4	LOAD.B	D4,(A3)		; D4 <-- nombre	MATH64_	BINFP		; D3D4 <-- nombre	JUMP',VS 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2,A3,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETCH   >;========/; Cherche une chane dans le tableau.; in	D2.L	coordonne (y;x); out	A3.L	^chane;	D7.W	erreur; mod	D7.W, A3.LGETCH:	PUSHM.L	D0..D4,A4,A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	TEST.B	(A6)+OGAFAN+3:#BGAUSS ; courbe de Gauss ?	JUMP',BS 50$		; oui => 50$20$:	CALL	GETCOOR		; D2 <-- coordonne physique	CALL	GETFILTRE	; D2 <-- coordonne selon filtre	CALL	GETCHP		; A3 <-- ^chane	JUMP	90$50$:				; courbe de Gauss =>	LOAD.L	D3,D2	SWAP.W	D3	COMP.W	D3,#-1		; dans la toute premire ligne ?	JUMP,EQ 20$		; oui => 20$	COMP.W	D2,#-1		; dans la toute premire colonne ?	JUMP',NE 60$		; non => 60$				; oui =>	LOAD.L	D4,D2	CLR.W	D4	SWAP.W	D4	MATH64_	BINFP	LOAD.L	D1,(A6)+OGAECH+0	LOAD.L	D2,(A6)+OGAECH+4	MATH64_	MUL	LOAD.L	D1,(A6)+OGAMIN+0	LOAD.L	D2,(A6)+OGAMIN+4	MATH64_	ADD		; D3D4 <-- (n*ech)+min	LOAD.L	A3,#(A6)+OGALEY	CLR.L	D0		; D0 <-- mode par dfaut	SWAP.W	D0	LOAD.B	D0,#-2		; D0 <-- nb max de dcimales	SWAP.W	D0	LOAD.B	D0,#10		; D0 <-- nb max de caractres	MATH64_	FP_ASC		; OGALEY <-- chiffre en clair	LOAD.L	A4,A355$:	LOAD.B	D3,(A4+)	JUMP',EQ 80$	COMP.B	D3,#'.		; partie fractionnaire ?	JUMP,NE 55$		; non => 55$				; oui =>	CLR.B	(A3)		; rend un texte vide !	JUMP'	80$60$:	LOAD.W	D7,#ERGRAPH	; D7 <-- hors du tableau	TEST.L	(A6)+OPGAUSS	JUMP',EQ 90$	LOAD.L	A4,(A6)+OPGAUSS	ADD.W	A4,D2	SWAP.W	D2	MUL.WU	D2,(A6)+ODIMX	ADD.L	A4,D2	CLR.L	D4	LOAD.B	D4,(A4)		; D4 <-- nombre (0..n)	LOAD.L	A4,#(A6)+OGALEY	CALL	PUTANUM		; OGALEY <-- nombre	CLR.B	(A4)		; OGALEY <-- terminateur80$:	LOAD.L	A3,#(A6)+OGALEY	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D4,A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETCHP  >;========/; Cherche une chane dans le tableau.; in	D2.L	coordonne physique (y;x); out	A3.L	^chane;	D7.W	erreur; mod	D7.W, A3.LGETCHP:	PUSHM.L	D2,D3	LOAD.W	D7,#ERGRAPH	; D7 <-- hors du tableau	TEST.L	(A6)+OPGRA	JUMP,EQ 90$	LOAD.L	A3,(A6)+OPGRA	; A3 <-- ^tableau	SWAP.W	D2	INC.W	D2		; D2 <-- ligne  atteindre	JUMP',EQ 30$20$:	LOAD.B	D3,(A3+)	JUMP,EQ 90$	COMP.B	D3,#CR	JUMP,NE 20$	DEC.W	D2	JUMP,NE 20$30$:	SWAP.W	D2	INC.W	D2		; D2 <-- colonne  atteindre	JUMP',EQ 80$40$:	LOAD.B	D3,(A3+)	JUMP,EQ 90$	COMP.B	D3,#CR	JUMP,EQ 90$	COMP.B	D3,#TAB	JUMP,NE 40$	DEC.W	D2	JUMP,NE 40$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETCOOR >;--------/; Transforme une coordonne pour obtenir la coordonne relle; physique dans le tableau.; in	D2.L	coordonne; out	D2.L	coordonne relle; mod	D2.LGETCOOR:	TEST.B	(A6)+OXYFAN+3:#BXYINVX ; mode X invers ?	JUMP',BC 10$		; non => 10$				; oui =>	COMP.W	D2,#-1	JUMP',EQ 10$	SUB.W	D2,(A6)+ODIMX	NEG.W	D2	DEC.W	D2		; D2 <-- inverse X10$:	SWAP.W	D2	TEST.B	(A6)+OXYFAN+3:#BXYINVY ; mode Y invers ?	JUMP',BC 20$		; non => 20$				; oui =>	COMP.W	D2,#-1	JUMP',EQ 20$	SUB.W	D2,(A6)+ODIMY	NEG.W	D2	DEC.W	D2		; D2 <-- inverse Y20$:	SWAP.W	D2	TEST.B	(A6)+OXYFAN+3:#BXYINV ; mode Y-X ?	JUMP',BC 40$		; non => 40$				; oui =>	SWAP.W	D2		; D2 <-- permute X et Y40$:	RET;----------\\; GETFILTRE >;----------/; Transforme une coordonne pour obtenir la coordonne relle; physique en fonction des filtres.; in	D2.L	coordonne; out	D2.L	coordonne relle; mod	D2.LGETFILTRE:	PUSH.L	A2	COMP.W	D2,#-1	JUMP',EQ 20$	LOAD.L	A2,#(A6)+OFILIX	LOAD.B	D2,(A2)+(D2.W)20$:	SWAP.W	D2	COMP.W	D2,#-1	JUMP',EQ 40$	LOAD.L	A2,#(A6)+OFILIY	LOAD.B	D2,(A2)+(D2.W)40$:	SWAP.W	D2	POP.L	A2	RET;---------\\; CHECKDIM >;=========/; Vrifie si les dimensions sont plausibles.; in	-; out	D7.W	ok/erreur; mod	D7.WCHECKDIM:	PUSHM.L	D3,D4	LOAD.W	D3,(A6)+ODIMX	LOAD.W	D4,(A6)+ODIMY	LOAD.W	D7,#ERGTRVA	; D7 <-- trop de valeurs	COMP.W	D3,#MAXXY	JUMP,HI 90$	COMP.W	D4,#MAXXY	JUMP,HI 90$	LOAD.W	D7,#ERGPAVA	; D7 <-- pas assez de valeurs	COMP.B	(A6)+OGRAPHE,#ICOGCAC	JUMP,EQ 20$	COMP.B	(A6)+OGRAPHE,#ICOGEMP	JUMP,EQ 30$	COMP.B	(A6)+OGRAPHE,#ICOGBRI	JUMP,EQ 40$	COMP.B	(A6)+OGRAPHE,#ICOGCAM	JUMP,EQ 50$	JUMP	80$20$:				; graphique cte  cte =>	TEST.W	D3	JUMP,EQ 90$	TEST.W	D4	JUMP,EQ 90$	JUMP	80$30$:				; graphique empil =>	TEST.W	D3	JUMP,EQ 90$	TEST.W	D4	JUMP,EQ 90$	JUMP	80$40$:				; graphique ligne brise =>	TEST.W	D3	JUMP,EQ 90$	COMP.W	D4,#1	JUMP,LE 90$	TEST.B	(A6)+OPEFAN+3:#BPEOUI ; perspective ?	JUMP,BC 80$		; non => 80$	COMP.W	D3,#1	JUMP,LE 90$	JUMP	80$50$:				; graphique camembert =>	COMP.W	D3,#1	JUMP,LE 90$	TEST.W	D4	JUMP,EQ 90$;	JUMP	80$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETDIM  >;========/; Cherche les dimensions du tableau selon les filtres.; in	-; out	(A6)+ODIMX.W	largeur;	(A6)+ODIMY.W	hauteur; mod	D7.WGETDIM:	PUSHM.L	D0..D2,A5	LOAD.L	A5,#(A6)+OFILIX	LOAD.W	D1,#-110$:	INC.W	D1		; D1 <-- largeur du tableau	LOAD.B	D2,(A5+)	COMP.B	D2,(A6)+OALLX+1	JUMP',HS 15$	COMP.B	D2,#-1	JUMP,NE 10$15$:	LOAD.L	A5,#(A6)+OFILIY	LOAD.W	D0,#-120$:	INC.W	D0		; D0 <-- hauteur du tableau	LOAD.B	D2,(A5+)	COMP.B	D2,(A6)+OALLY+1	JUMP',HS 25$	COMP.B	D2,#-1	JUMP,NE 20$25$:	TEST.B	(A6)+OXYFAN+3:#BXYINV ; mode Y-X ?	JUMP',BC 50$		; non => 50$				; oui =>	EX.L	D0,D150$:	LOAD.W	(A6)+ODIMX,D1	LOAD.W	(A6)+ODIMY,D0	POPM.L	D0..D2,A5	RET;--------\\; GETALL  >;========/; Cherche les dimensions totales du tableau.; in	(A6)+OPGRA.L	^tableau; out	(A6)+OALLX.W	largeur;	(A6)+OALLY.W	hauteur; mod	D7.WGETALL:	PUSHM.L	D0..D4,A3	CLR.W	D0	CLR.W	D1	TEST.L	(A6)+OPGRA	JUMP,EQ 80$	LOAD.L	A3,(A6)+OPGRA	; A3 <-- ^tableau20$:	CLR.W	D230$:	LOAD.B	D3,(A3+)	JUMP',EQ 60$	COMP.B	D3,#CR	JUMP',EQ 40$	COMP.B	D3,#TAB	JUMP,NE 30$	INC.W	D2		; D2 <-- un nb de plus en X	JUMP	30$40$:	COMP.W	D1,D2	JUMP',HS 45$	LOAD.W	D1,D2		; D1 <-- ligne la plus longue en X45$:	INC.W	D0		; D0 <-- une ligne de plus en Y	JUMP	20$60$:	TEST.W	D0	JUMP',EQ 80$	DEC.W	D080$:	LOAD.W	(A6)+OALLX,D1	LOAD.W	(A6)+OALLY,D0	CALL	GETPNUM		; gnre le tableau de nombres	POPM.L	D0..D4,A3	RET;---------\\; GETPNUM  >;---------/; Gnre le tableau de nombres FP.; Le tableau, point par OPNUM, contient huit bytes; par case (un nombre FP).; in	-; out	(A6)+OPNUM.L	^tableau de nombres;	D7.W		erreur; mod	D7.WGETPNUM:	PUSHM.L	D0..D4,A3..A5	LOAD.L	A5,(A6)+OCHMATH	; A5 <-- canal interne de math64	CALL	GIVMPNUM	; libre le tableau prcdent	LOAD.W	D4,(A6)+OALLX	MUL.WU	D4,(A6)+OALLY	; D4 <-- nb total de cases	SL.L	D4,#3		; D4 <-- *8 car nombre FP	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour tableau	JUMP,NE 90$	LOAD.L	(A6)+OPNUM,A4	CLR.L	D0		; D0 <-- coordonne Y initiale20$:	CLR.W	D0		; D0 <-- coordonne X initiale25$:	LOAD.L	D2,D0		; D2 <-- coordonne (y;x)	CALL	GETCHP		; A3 <-- ^nombre	JUMP',NE 30$	MATH64_	ASC_FP		; D3D4 <-- nombre	JUMP',VC 40$30$:	LOAD.L	D3,#H'FFFF0000	LOAD.L	D4,D740$:	LOAD.L	(A4+),D3	; tableau <-- nombre	LOAD.L	(A4+),D4	INC.W	D0		; D0 <-- coordonne X suivante	COMP.W	D0,(A6)+OALLX	JUMP,LO 25$	SWAP.W	D0	INC.W	D0		; D0 <-- coordonne Y suivante	LOAD.W	D2,D0	SWAP.W	D0	COMP.W	D2,(A6)+OALLY	JUMP,LO 20$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D4,A3..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; GIVMPNUM >;---------/; Libre la mmoire utilise par le tableau de nombres.; in	-; out	-; mod	D7.WGIVMPNUM:	PUSHM.L	D1,A4	TEST.L	(A6)+OPNUM	JUMP',EQ 90$	LOAD.L	A4,(A6)+OPNUM	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OPNUM90$:	POPM.L	D1,A4	RET	.END