\define g_Fond:\nef11;\g_Fond;	.TITLE	CIBLE		; $---;$bin:Cible	.PROC	M68020	.BASE	10	.REF	SMAKY	.ref	MON	.START	BASEdebug_debugger	=	false ;true;**************************************************************; Programme Cible pour Debugger; Projet de semestre; 0.0 Courtine 1990;**************************************************************; 0.1	RB 900810	fournit type de processeur; 0.2	RB 900823	trace dans pilote; 0.3	RB 900826	chargement du pilote et recherche de ces points d'entre; 0.4	RB 900827	met les trap 14 dans le cas d'un driver; 0.5	AD 901009	PC de base modifi; 0.6	DD 901101	renvoie la zone mmoire si modifie; 0.7	DD 901105	reprise modifs RB debug_debugger; 1.0	RB 9100302	Modif des formats des messages: la commade est envoye en premierrev	=	1ver	=	0	.rev	rev,ver	PC_CODE		=	0	PC_VAR		=	1	PC_RECORD	=	2	.APC	PC_CODE			; PC pour le programme	.LOC	0	.APC	PC_VAR			; PC pour les variables	.LOC	0.MACRO	MODSUP	move.32		#r16^Sup$,A5	ntrel		?IEP13TRP	trap		#13	jump		user$Sup$:.ENDMACRO.MACRO	MODUSER	popm.32		a0|d0	retsfuser$:.ENDMACRO.MACRO	ClearCache	comp.32		#68000,{a6}+oProcessor	jump,eq		fcc$	comp.32		#68010,{a6}+oProcessor	jump,eq		fcc$	comp.32		#68020,{a6}+oProcessor	jump,ne		cc30$;68020	push.32		d0	move.32		cacr,d0	or.32		#2**3,d0		; Clear instruction cache	move.32		d0,cacr	pop.32		d0	jump		r8^fcc$cc30$:	comp.32		#68030,{a6}+oProcessor	jump,ne		fcc$;68030	push.32		d0	move.32		cacr,d0	or.32		#2**3+2**11,d0		; Clear Data et instruction cache	move.32		d0,cacr	pop.32		d0fcc$:.ENDMACRO.MACRO	GCpushM.32	d3|D7lib		?getcarpopM.32		d3|D7.ENDMACRO;***********************************************************************************;***********************************************************************************;CONSTANTES DU PROGRAMME CIBLE.CODE;***********************************************************************************;***********************************************************************************;****************************************;CONSTANTES DU MODULE COMMUNICATION;****************************************.ins	message.asi;****************************************;CONSTANTES DU MODULE TRACE;****************************************BANQUEPRINC		=	MEMSIZE	; dimension de la mmoire principaleDEB_BANQUE2		=	SECBEGIN	; dbut de la mmoire secondaireFIN_BANQUE2		=	SECEND	; fin de la mmoire secondaire;***********************************************************************************;***********************************************************************************;VARIABLES DU PROGRAMME CIBLE.CODE;***********************************************************************************;***********************************************************************************NbMaxP	=	16			; nombre de pilotes maxNbPE	=	16			; nombre de points d'entre		.APC	PC_Record		.loc	0oInstr:		.blk.16		1	; Instruction sauve par point d'entre d'un pilote PEoAdSuite:	.blk.32		1	; Adresse suivante du TRAP (pour recherche du trap correspondant)LgDescPETrap	=	APC		.APC	PC_Record		.loc	0oAdBasePilote:	.blk.32		1	; ^Base d'un piloteoAdDescPETrap:	.blk.8		LgDescPETrap*NbPE	; Instructiion et adresse correspondante+2 							; pour chaque PELgDescTrapDriv	=	APC		.APC	PC_VAR		.LOC	0;****************************************;VARIABLES DU MODULE COMMUNICATION;****************************************OPCBASE:	.blk.32		1	; pointeur de base du code correspondant au listing @ADMESSAGE:	.BLK.8		LgMess	; buffer pour les messages entre HOTE et CIBLE				     ^ valeur du symbole indefinie		.EVENC_IN:		.BLK.16		1	; canal d'entreC_OUT:		.BLK.16		1	; canal de sortie;****************************************;VARIABLES DU MODULE TRACE;****************************************P_MESSAGE:	.BLK.32		1	; pointeur du tampon pour les messages de longueur LgMessP_CODE_TEST:	.BLK.32		1	; pointeur au dbut du code du programme TEST.CODEADRESSE:	.BLK.32		1	; adresse de l'instruction remplace par un TRAP #15INSTRUCTION:	.BLK.16		1	; instruction remplace par un TRAP #15C_HOTE:		.BLK.32		1	; pointeur du nom du programme qui a lanc le testTEST:		.BLK.8		1	; variable pour le test d'occupation de la mmoire		.EVENoLC:		.blk.8		LgMess	; Ligne de commande reue de l'hte				     ^ valeur du symbole indefinieoProcessor:	.blk.32		1	; processeur cibleoSavTrap14:	.blk.32		1	; sauvetage de l'exception 14oSavTrap15:	.blk.32		1	; sauvetage de l'exception 15oSavTrace:	.blk.32		1	; sauvetage de l'exception TraceoVBR:		.blk.32		1	; valeur de VBR, 0 si 68000oExt:		.blk.32		1	; Extension du programmeoSemStop:	.blk.32		1	; smaphore de fin en cas de DRIVoSemLockTrace:	.blk.32		1	; smaphore d'accs trace (driv)oSemLockTrap14:	.blk.32		1	; smaphore d'accs trap 14 (driv)oSemLockTrap15:	.blk.32		1	; smaphore d'accs trap 15 (driv) oBMPilote:	.blk.32		1	; Bit Map de pilotes (statique)oBMPE:		.blk.16		NbMaxP	; BitMap des points d'entresoBMPiloteTr:	.blk.32		1	; Bit Map de pilotes (statique)  traceroBMPETr:	.blk.16		NbMaxP	; BitMap des points d'entres  traceroDescTrapDriv:	.blk.8		NbMaxP*LgDescTrapDriv		.EVENOLD_MEM:	.blk.32		1		; adresse de la zone mmoire affiche @DDCOP_MEM:	.blk.32		LgMess		; tampon pour mmoire/envoie @DD				     ^ valeur du symbole indefinieLgVar	=	APC		.APC	PC_CODE		.LOC	0;***********************************************************************************;***********************************************************************************;Routines Globales;***********************************************************************************;***********************************************************************************;------------------\; GET_COMMUN_MEMORY >;==================/;;rend dans A6.32 le pointeur de la zone des variables;	; IN	-	; OUT	A6.32	^mmoire commune	; 	si D7.16 = #ERMOCC ==> la mmoire a dj t utilise au moins une fois	; MOD	A6.32, D7.16GET_COMMUN_MEMORY:	PUSHM.32	A4|D4	CLR.16	D7	MOVE.32	#LgVar,D4		; demande la mmoire commune	MOVE.32	#R16^BASE,A4	FOS	?GETCOMMEM		; demande de la mmoire et l'initialise la premire fois	JUMP,NE	FIN$	MOVE.32	A4,A6	TSET.8	{A6}+TEST:#0		; teste si elle est dj occupe	JUMP,EQ	FIN$	MOVE.32	#ERMOCC,D7		; si oui rend une erreurFIN$:	POPM.32	A4|D4	TEST.16	D7	RET;-------------\; GivProcessor >;=============/;;Sauve le type de processeur;;In	A6.32	^variables;Out	D4.32	processeur (68000, 68010, 680202, 68030, etc...);ModGivProcessor:	NTREL		?GETPROCESSOR	move.32		d4,{a6}+oProcessor	ret;***********************************************************************************;***********************************************************************************;MODULE DE COMMUNICATION;***********************************************************************************;***********************************************************************************;Ce module une fois ouvert fournit deux routines pour communiquer avec HOTE.CODE;****************************************;ROUTINES INTERNES DU MODULE COMMUNICATION;****************************************;---------\; OPEN_BAL >;=========/;;ouvre un canal Bote aux lettres;	; IN:	A2.32	^nom logique de la bal  ouvrir	; 	A3.32	^nom de l'ordinateur qui a lanc CIBLE.CODE termin par :	; 	D3.8 	attribut pour open	; 	D4.32 	longueur du nom logique	; OUT:	D6.16 	numro de canal	; MOD:	A2.32, A3.32, D4.32, D7.16OPEN_BAL:	PUSHM.32	A0|A4|D1	MOVE.32	A3,A0			; calcule la longueur de la variable pour le nom logiqueA$:	INC.32	D4			; de la bal	COMP.8	#":",{A0+}	JUMP,NE	A$	MOVE.16	#MTYPCP,D1		; rserve de la mmoire	GESMEM	?GETMEM	JUMP,NE	FIN$	MOVE.32	A4,A0B$:	MOVE.8	{A3},{A0+}		; construit le nom logique	COMP.8	#":",{A3+}	JUMP,NE	B$	MOVE.32	A0,A3C$:	MOVE.8	{A2+},{A3+}	JUMP,NE	C$	MOVE.32	A4,A3	FOS	?OPEN			; ouvre le canal	JUMP,NE	FIN$	GESMEM	?GIVMEM			; rend la mmoire	FIN$:	POPM.32	A0|A4|D1	TEST.16	D7	RET;****************************************;ROUTINES UTILISABLES DU MODULE COMMUNICATION;****************************************;----------------\; INIT_MODULE_COM >;================/;;initialise le module de communication;	; IN:	A6.32	^variables globales	; 	A3.32	^nom de l'ordinateur qui a install les bals	; OUT:	A4.32	^pointeur de la mmoire tampon pour les messages de longueur LgMess	; MOD:	A4.32, D7.16INIT_MODULE_COM:	PUSHM.32	A2|A3|A5|D1|D3..D6	MOVE.32		A3,A5			; ouvre une bal	MOVE.32		#R16^BAL_CIBLE_HOTE,A2;	MOVE.8		#2**BOPWR+2**BOPEXWR,D3	; en criture	MOVE.8		#2**BOPWR,D3		; en criture	MOVE.32		#LG_BAL_CIBLE_HOTE,D4	CALL		OPEN_BAL	JUMP,NE		FIN$	MOVE.16		D6,{A6}+C_OUT		; sauve le numro de canal de sortie	MOVE.32		A5,A3			; ouvre une bal	MOVE.32		#R16^BAL_HOTE_CIBLE,A2	MOVE.8		#2**BOPRD,D3		; en lecture	MOVE.32		#LG_BAL_HOTE_CIBLE,D4	CALL		OPEN_BAL	JUMP,NE		FIN$	MOVE.16		D6,{A6}+C_IN		; sauve le numro de canal d'entre	move.32		#{a6}+Message,A4	; ^buffer de message	MOVE.32		A4,{A6}+P_MESSAGE	; sauve ^buffer message	MOVE.16		#CIBLE_PRES,D0		; Cible ici	CALL		TO_HOTEFIN$:	POPM.32		A2|A3|A5|D1|D3..D6	TEST.16		D7			; si erreur	RET;-----------------\; CLOSE_MODULE_COM >;=================/;	; IN:	A6.32 pointeur des variables	; OUT:	-	; MOD:	D7.16CLOSE_MODULE_COM:	PUSHM.32	D1|D6	call		SndCible_Abs	MOVE.16		{A6}+C_IN,D6	FOS		?CLOSE	MOVE.16		{A6}+C_OUT,D6	FOS		?CLOSE	POPM.32		D1|D6	TEST.16		D7	RET;-------------\; SndCible_Abs >;=============/;;Envoi message cible absente;;In;Out;ModSndCible_Abs:	push.32		d0	MOVE.16		#CIBLE_ABS,D0		; Plus de cible, bye-bye	CALL		TO_HOTE	pop.32		d0	ret;-------------\; SndCiblePres >;=============/;;Envoi message cible absente;;In;Out;ModSndCiblePres:	push.32		d0	MOVE.16		#CIBLE_PRES,D0		; Cible de nouveau active	CALL		TO_HOTE	pop.32		d0	ret;--------\; TO_HOTE >;========/;;envoie une trame au programme HOTE.CODE;	; IN:	A6.32	^variables	; 	D0.16	 commande  transmettre	; OUT:	A4.32	^buffer de longueur LgMess	; MOD:	D7.16TO_HOTE:	move.32		#{a6}+Message,A4	; ^buffer de message @DD dplacTO_HOTEa4:				; @DD	PUSHM.32	D4|D6	MOVE.16		D0,{A4}+oCommande	; place la commande  transmettre				^ valeur du symbole indefinie	MOVE.16		{A6}+C_OUT,D6		; prpare le numro de canal	MOVE.32		#LgMess,D4		; et la longueur de la trame			 ^ valeur du symbole indefinie	FOS		?WRBYTE	POPM.32		D4|D6	TEST.16		D7	RET;----------\; FROM_HOTE >;==========/;;reoit une trame du programme HOTE.CODE;	; IN:	A6.32	^variables	; OUT:	A4.32	^buffer de longueur LgMess	; 	D0.16	 commande reue	; MOD:	{A4}, D0.16, D7.16 FROM_HOTE:	PUSHM.32	D4|D6	move.32		#{a6}+Message,A4	; ^buffer de message	MOVE.16		{A6}+C_IN,D6		; prpare le numro de canalA$:	MOVE.32		#LgMess,D4		; et la longueur de la trame			 ^ valeur du symbole indefinie	FOS		?RDBYTE	COMP.32		#0,D4	JUMP,EQ		A$	MOVE.16		{A4}+oCommande,D0	; sort la commande de la trame			     ^ valeur du symbole indefinie	POPM.32		D4|D6	TEST.16		D7	RET;****************************************;DEFINITIONS POUR LE MODULE COMMUNICATION;****************************************;pour la routine INIT_MODULE_COM.if	debug_debuggerBAL_HOTE_CIBLE:	.ASCIZE		"#BAL_HC"LG_BAL_HOTE_CIBLE		=	APC-BAL_HOTE_CIBLEBAL_CIBLE_HOTE:	.ASCIZE		"#BAL_CH"LG_BAL_CIBLE_HOTE		=	APC-BAL_CIBLE_HOTE.elseBAL_HOTE_CIBLE:	.ASCIZE		"#BAL_HOTE_CIBLE:"LG_BAL_HOTE_CIBLE		=	APC-BAL_HOTE_CIBLEBAL_CIBLE_HOTE:	.ASCIZE		"#BAL_CIBLE_HOTE:"LG_BAL_CIBLE_HOTE		=	APC-BAL_CIBLE_HOTE.endif	debug_debugger;***********************************************************************************;***********************************************************************************;MODULE TRACE;***********************************************************************************;***********************************************************************************;****************************************;ROUTINES INTERNES DU MODULE TRACE;****************************************;---------------\; LOAD_FILE_TEST >;===============/;;charge le programme  tester dans une zone de variables;	; IN:	A6.32	^variables	; 	A4.32	^nom du programme  tester	; OUT:	A0.32	^adresse de START	; 	A4.32	^adresse de base du code	; 	D2.32	 date de cration	; 	D3.32	 heure de cration	; MOD:	A0.32, A4.32, D7.16CODE	=	"C"*(2**24)+"O"*(2**16)+"D"*(2**8)+"E"DRIV	=	"D"*(2**24)+"R"*(2**16)+"I"*(2**8)+"V";etc...LOAD_FILE_TEST:	PUSHM.32	A3|D0|D1|D4..D6	MOVE.32		A4,A3;Lecture des arguments du fichier  charger	MOVE.16		#MTYPCP,D1		; demande de la mmoire pour ARGS sur un fichier CODE	MOVE.32		#LGARGS,D4	GESMEM		?GETMEM	JUMP,NE		FIN1$	MOVE.32		#2**BOPEXTEND+2**BOPRD+2**BOPSYS+2**BOPARGS,D3	; ouvre le fichier en lecture	FOS		?ARGSOPEN	JUMP,NE		FIN0$	MOVE.32		{A4}+OBACD,D2		; date de cration	SR.32		#8,D2	MOVE.32		{A4}+OBACH-1,D3		; heure de cration	AND.32		#16'00FFFFFF,D3	move.32		{A4}+oBALGF,D4		; longueur fichier -> D4	GESMEM		?GIVMEM			; rend la mmoire de ARGS	JUMP,NE		FIN1$;Chargement du fichier en mmoire, y compris entte	MOVE.16		#MTYPCP,D1	GESMEM		?GETMEM			; mmoire pour charger fichier avec entte	JUMP,NE		FIN1$	FOS		?RDBYTE			; lit le programme	JUMP,NE		FIN1$	FOS		?CLOSE	jump,ne		FIN0$ 	MOVE.32		{A4}+OBXSTA,A0		; A0 ^adresse de start	MOVE.32		{A4}+OBXLG,D0		; lit la longueur du programme	MOVE.32		{A4}+OBXSTK,D5		; longueur de pile dsire	move.32		#LgBlk,D0		; longueur entte max	test.8		{a4}+OBXTYP:#BBXHRR	; entte courte ?	jump,bc		s0$			; non -> s0$	move.32		#LgBxr,D0		; longueur entte mins0$:;Recherche du type de fichier (CODE, DRIV)	push.32		d3	call		GivExt			; extension -> D4;mon	?afx8	move.32		d4,{a6}+oExt		; sauve le type d'extension	comp.32		#CODE,D4	jump,ne		s10$	move.32		#CODE,{a6}+oExt		; sauve le type d'extension	move.32		#0,d3			; fichier excutable	jump		s50$s10$:	comp.32		#DRIV,D4	jump,ne		s20$	move.32		#DRIV,{a6}+oExt		; sauve le type d'extension	move.32		#erATTX,d3		; pas excutable	call		SearchDebNam	FOS		?MCACHE			; cache le programme;;mon	?aftim;;.ascize	"<CR>MCache ";trap	#0	move.16		#0,d4	ntrel		?cresem	move.32		a5, {a6}+oSemStop	; signal sur ce smaphore lorsque la cible s'arrte	move.16		#1,d4	ntrel		?cresem	move.32		a5, {a6}+oSemLockTrace	; smaphore d'accs au trace	move.16		#1,d4	ntrel		?cresem	move.32		a5, {a6}+oSemLockTrap14	; smaphore d'accs au trace	move.16		#1,d4	ntrel		?cresem	move.32		a5, {a6}+oSemLockTrap15	; smaphore d'accs au trace	jump		s50$;Extension pas supporte;************************s20$:	move.16		#ErFill,d7		; Erreur nom de fichier	jump		ERROR			; *%&%&??!!s50$:	add.32		d0,a4			; A4.32 <- ^dbut du code	pop.32		d3FIN0$:	POPM.32		A3|D0|D1|D4..D6	TEST.16		D7	RETFIN1$:	FOS		?CLOSE			; ferme le fichier	jump		Fin0$;------------\\; SearchDebNam >;=============/;;Recherche dbut nom d'un fichier sans rpertoire;;In	A3.32		^nom;Out	A3.32		^nom sans rpertoire;Mod	SearchDebNam:	pushm.32	a0	move.32		a3,a0l$:	comp.8		#".",{a0}	jump,eq		f$	comp.8		#":",{a0+}	jump,ne		l$	move.32		a0,a3			; peut tre ^dbut nom	jump		l$f$:pushm.32	a3;;mon	?aftextpopm.32		a3	popm.32		a0	ret;------\\; GivExt >;=======/;;Donne l'extension d'un fichier;;In	A3.32	^nom;Out	D4.32	extension ("CODE", "DRIV", ...);Mod	GivExt:	pushm.32	a3|d0	move.32		#0,d4	move.16		#4-1,d0		; 4 octets maxl$:	move.8		{A3+},D4	call		minMAJ	jump,eq		f$	comp.8		#".",d4	jump,ne		l$	l0$:	sl.32		#8,d4		; dcale d'un car  gauche	move.8		{a3+},d4	; met un car  droite	call		minMAJskip,eq	dj.16,nmo	d0,l0$f$:	popm.32		a3|d0	retminMAJ:	comp.8		#"a",d4	jump,lo		f$	comp.8		#"z",d4	jump,hi		f$	add.8		#"A"-"a",d4		; min -> MAJ (sans accents)f$:	test.8		d4	ret;--------\; GET_REG >;========/;;met les registres dans le buffer;	; IN:	A6.32	^variables	; 	A3.32	 adresse de base du programme	; 	A4.32	^buffer des registres	; 	A5.32	^registres sur la pile	; OUT:	-	; MOD:	D7.16GET_REG:	PUSHM.32	A0..A2|D1|D4	MOVE.32		A4,A2	MOVE.32		A5,A1	MOVE.16		#14,D1A$:	MOVE.32		{A1+},{A2+}		; met 15 registres exept USP	DJ.16,NMO	D1,A$	MOVE.16		#0,{A2+}		; met SF	MOVE.16		{A1+},{A2+}	MOVE.32		USP,A0	MOVE.32		A0,{A2+}	MOVE.32		{A6}+OProcessor,D4	COMP.32		#68000,D4	JUMP,EQ		P68000$	COMP.32		#68010,D4	JUMP,EQ		P68010$;.PROC	M68020	MOVE.32		ISP,A0	MOVE.32		A0,{A2+}	MOVE.32		MSP,A0	MOVE.32		A0,{A2+}	MOVE.32		VBR,D1	MOVE.32		D1,{A2+}	MOVE.32		SFC,D1	MOVE.32		D1,{A2+}	MOVE.32		DFC,D1	MOVE.32		D1,{A2+}	MOVE.32		CACR,D1	MOVE.32		D1,{A2+}	MOVE.32		CAAR,D1	MOVE.32		D1,{A2+};.PROC	M68000B$:	MOVE.32	{A6}+OPCBASE,{A2+}	; @AD  PC de base @AD	MOVE.32	{A1},A0			; @AD	MOVE.32	A0,{A2+}		; @AD  PC	SUB.32	{A6}+OPCBASE,A0		; @AD	MOVE.32	A0,{A2}			; @AD  PCREL = PC-PCB (toujours);;B$:	MOVE.32		{A1},A0			; PC;;	MOVE.32		{A1},{A2+};;	SUB.32		A3,A0;;	MOVE.32		A0,{A2}			; PCREL	POPM.32		A0..A2|D1|D4	CLR.16		D7	RETP68010$:	MOVE.32		0,{A2+}		; ISP	MOVE.32		0,{A2+}		; MSP;.PROC	M68020	MOVE.32		VBR,D1	MOVE.32		D1,{A2+};.proc	m68000	MOVE.32		0,{A2+}		; SFC	MOVE.32		0,{A2+}		; DFC	MOVE.32		0,{A2+}		; CACR	MOVE.32		0,{A2+}		; CAAR	jump		B$P68000$:	MOVE.16		#6,D4C$:	MOVE.32		#0,{A2+}	DJ.16,NMO	D4,C$	JUMP		B$;-----------\; CHANGE_REG >;===========/;;change le contenu des registres;	; IN:	A6.32	^variables	; 	A3.32 adresse de base du programme	; 	A4.32^buffer des registres	; 	A5.32^registres sur la pile	; OUT:	-	; MOD:	D7.16CHANGE_REG:	PUSHM.32	A0..A2|D1|D4	MOVE.32		A4,A2	MOVE.32		A5,A1	MOVE.16		#14,D1A$:	MOVE.32		{A2+},{A1+}		; met 15 registres exept USP	DJ.16,NMO	D1,A$	MOVE.16		{A2+},D1		; met SF	MOVE.16		{A2+},{A1+}	MOVE.32		{A2+},A0	MOVE.32		A0,USP	move.32		{a6}+oProcessor,d4	COMP.32		#68000,D4	JUMP,EQ		P68000$	COMP.32		#68010,D4	JUMP,EQ		P68010$;.PROC	M68020	MOVE.32		{A2+},A0	MOVE.32		A0,ISP	MOVE.32		{A2+},A0	MOVE.32		A0,MSP	MOVE.32		{A2+},D1	MOVE.32		D1,VBR	MOVE.32		{A2+},D1	MOVE.32		D1,SFC	MOVE.32		{A2+},D1	MOVE.32		D1,DFC	MOVE.32		{A2+},D1	MOVE.32		D1,CACR	MOVE.32		{A2+},D1	MOVE.32		A0,CAAR;.PROC	M68000B$:	PUSH.32	A3			; @AD	MOVE.32	{A2+},A3		; @AD  PC de base	MOVE.32	A3,{A6}+OPCBASE		; @AD 	MOVE.32	{A2+},A0		; @AD  PC absolu	MOVE.32	A0,{A1}			; @AD  PC mis sur la pile	SUB.32	A3,A0			; @AD	MOVE.32	A0,{A2}			; @AD  PC relatif recalcul	POP.32	A3;.PROC	M68000;;B$:	MOVE.32		{A2+},D1		; PC;;	ADD.32		{A2},A3			; adresse relative+base du programme;;	MOVE.32		A3,{A1}			; PC effectivement mis sur la pile	POPM.32		A0..A2|D1|D4	TEST.16		D7	RETP68010$:	MOVE.32		{A2+},A0		; ISP	MOVE.32		{A2+},A0		; MSP;.PROC	M68020	MOVE.32		{A2+},D1	MOVE.32		D1,VBR;.proc	m68000	MOVE.32		{A2+},D1		; SFC	MOVE.32		{A2+},D1		; DFC	MOVE.32		{A2+},D1		; CACR	MOVE.32		{A2+},D1		; CAAR	JUMP		B$P68000$:	MOVE.16		#7-1,D4		; ISP, MSP, VBR, SFC, DFC, CACR, CAARC$:	MOVE.32		{A2+},A0	DJ.16,NMO	D4,C$	JUMP		B$;-----------\; TRAITEMENT >;===========/;;permet le traitement des registres et de la mmoire du programme TEST.CODE;	; IN:	A6.32^de la zone de variable	; 	A5.32^des registres	; OUT:	-	; MOD:	sans importanceTRAITEMENT:	call		SndCiblePres	JUMP		SEND_REG		; envoie le contenu des registres au programme HOTE.CODE;********************************************************;Boucle principale dans les routines TRAP;********************************************************LOOP:	CALL		FROM_HOTE		; attend une commande	COMP.16		#HOTE_MEM,D0	JUMP,EQ		ShowMem	COMP.16		#HOTE_TCF,D0	JUMP,EQ		TCF	COMP.16		#HOTE_TIE,D0	JUMP,EQ		TIE	COMP.16		#HOTE_NOT,D0	JUMP,EQ		NOT	COMP.16		#HOTE_END,D0	JUMP,EQ		FINCible		; fin brutale	COMP.16		#HOTE_TRAP,D0	JUMP,EQ		TRAP	COMP.16		#HOTE_REG,D0	JUMP,EQ		REG	comp.16		#HOTE_PROC,D0	JUMP,eq		PROC	comp.16		#HOTE_TraceDriv,D0	JUMP,eq		IniTraceDriv	comp.16		#HOTE_COMMAND,D0	jump,eq		RcvCom	JUMP		LOOP;********************************************************;----\; REG >;====/;;change le contenu des registres;;In;Out;ModREG:	MOVE.32		{A6}+P_CODE_TEST,A3		CALL		CHANGE_REG	JUMP		LOOP;---------\; SEND_REG >;=========/;;envoie au programme HOTE.CODE le contenu des registres;;In;Out;ModSEND_REG:	MOVE.32		{A6}+P_CODE_TEST,A3	CALL		GET_REG	MOVE.16		#CIBLE_REG,D0	CALL		TO_HOTE	call		TstMemoire		; @DD le contenu de la mmoire a chang ?	jump,eq		LOOP			; non -> continu	move.32		{A6}+OLD_MEM, A1	JUMP		SEND_MEM			; oui -> redonne la zone;-----\; PROC >;=====/;;envoie le type de processeur de la cible  l'hote;;In;Out;ModPROC:	MOVE.32		{A6}+P_MESSAGE,A4		; pointeur de message	move.32		{a6}+oProcessor,{a4}+oTypProc	; numro du processeur					     ^ valeur du symbole indefinie	MOVE.16		#CIBLE_PROC,D0	CALL		TO_HOTE	JUMP		LOOP;--------\; ShowMem >;========/;;fournit des bytes;;In;Out;Mod; ??????ShowMem:	MOVE.32		{A6}+P_MESSAGE,A4	; pointeur de message	MOVE.32		#{A4}+oMem,A1		; adresse du dbut ATTENTION ELLE DOIT ETRE PAIRE 			      ^ valeur du symbole indefinie;			{a4},A1			; ??? avant	move.32		A1, {A6}+OLD_MEM	; @DD dernire adresse afficheSEND_MEM:				; @DD renvoie automatique; in A1 old_mem	CLR.32		D2			; compteur des registres faux @DD dplac ici	move.32		#{A6}+COP_MEM+oMem, A4	; @DD tampon pour mmoriser le message @RB +oMem			      ^ valeur du symbole indefinie	MOVE.32		#NBREG-5,D3			; @DD TCLR.32 D3:#31			 ^ valeur du symbole indefinie	MOVE.32		BANQUEPRINC,D4	MOVE.32		DEB_BANQUE2,D5	MOVE.32		FIN_BANQUE2,D6A$:	COMP.32		D4,A1	JUMP,LO		B$	COMP.32		D5,A1	JUMP,LO		X$	COMP.32		D6,A1	JUMP,LO		B$X$:	TSET.32		D2:D3	ADD.32		#4,A1	MOVE.32		#"?",{A4+}	JUMP		C$B$:	move.32		{A1+}, {A4+}C$:	DJ.16,NMO	D3,A$;@DD	MOVE.32		{A6}+P_MESSAGE,A4	move.32		#{A6}+COP_MEM, A4		; @DD	MOVE.32		D2,{A4}+oBitMapMem		; @RB				^ valeur du symbole indefinie	MOVE.16		#CIBLE_MEM,D0	CALL		TO_HOTEa4			; @DD utilise un autre tampon	JUMP		LOOP;-----\; TRAP >;=====/;;continue en mode TRAP;;In;Out;ModTRAP:	MOVE.32		{A6}+P_MESSAGE,A4		; adresse relative	MOVE.32		{A4}+oAdTrap,A0			     ^ valeur du symbole indefinie	ADD.32		{A6}+OPCBASE,A0			; @AD	MOVE.16		{A0},{A6}+INSTRUCTION		; lit le code de l'instruction	MOVE.32		A0,{A6}+ADRESSE			; sauve l'adresse	MOVE.16		#16'4E4F,{A0}			; Place TRAP #15  la place;et continue en se plaant en mode no trace ...	;----\; NOT >;====/;;no tracing;modifie sur la pile SF sauv;modifie sur la pile SF sauv;;In;Out;ModNOT:	MOVE.16		{A5}+(7+8)*4,D0		; saute sur la pile a0..a6, d0..d7	TCLR.32		D0:#15	TCLR.32		D0:#14	MOVE.16		D0,{A5}+(7+8)*4	JUMP		CONTINUE;----\; TCF >;====/;;trace on change of flow;mets les deux bits de trace de SF  0 1;modifie sur la pile SF sauv;;In;Out;ModTCF:	MOVE.16		{A5}+(7+8)*4,D0		; saute sur la pile a0..a6, d0..d7	TCLR.32		D0:#15	TSET.32		D0:#14	MOVE.16		D0,{A5}+(7+8)*4	JUMP		CONTINUE;----\; TIE >;====/;;trace on instruction execution;mets les deux bits de trace de SF  1 0;modifie sur la pile SF sauv;;In;Out;ModTIE:	MOVE.16		{A5}+(7+8)*4,D0		; saute sur la pile a0..a6, d0..d7	TCLR.32		D0:#14	TSET.32		D0:#15	MOVE.16		D0,{A5}+(7+8)*4;	JUMP		CONTINUE;---------\; CONTINUE >;=========/;;Continue l'excution;;In;Out;ModCONTINUE:	MOVE.16		#CIBLE_ABS,D0		; Plus de cible, bye-bye	CALL		TO_HOTE	RET;------\\; RcvCom >;=======/;; Rception de la commande  transmettre au programme  tester; ; In	; Out	; Mod	RcvCom:	MOVE.32		{A6}+P_MESSAGE,A4	; pointeur de message	move.32		#{a4}+oData,A4		; ^commande  transmettre			      ^ valeur du symbole indefinie	move.32		#{a6}+oLC,A0	move.16		#LgMess-1,d0			 ^ valeur du symbole indefiniel$:	move.8		{a4+},{a0+}	dj.16,nmo	d0,l$	jump		loop;-------------\; IniTraceDriv >;=============/;;Mise en place des TRAP 14 dans le pilote;Balaye dans la table des PE de chaque SP ceux qu'il faut tracer;Table:	.32		Bit-Map des SP utiliss;		.16 * NbMaxP	Bit-Map des PE  tracer pour chaque SP;Pour chacun des PE actif, un TRAP #14 est plac, le code de l'instruction est auparavent sauv;ainsi que l'adresse de l'instruction qui suit;Ceci permet  la routine de TRAP 14 de retrouver l'instruction  placer;Ne pas oublier de Clearer le cache d'instruction;In;Out;ModInstrTrap14	==	16'4E4EIniTraceDriv:	pushm.32	a0..a5|d0..d4	move.32		{a6}+P_Message,a0	; ^message reut	move.32		#{a0}+oData,a0			      ^ valeur du symbole indefinie	move.32		{a0+},{a6}+oBMPiloteTr	move.32		#{a6}+oBMPETr,A1	; copie de ce qui est  tracer	move.16		#NbMaxp-1,d0li$:	move.16		{a0+},{a1+}		; Copie message	dj.16,nmo	d0,li$GC;;	move.32		{a6}+oBMPiloteTr,d4	; map des sous-pilotes  tracer;;	and.32		#(2**NbMaxP)-1,D4	; en ralit 8 max	move.32		#{a6}+oBMPETr,A0	; ^bit map des points d'entre  tracer	move.32		#0,D0			; balayage des sous-pilotes 0.. NbMaxP-1l$:	move.32		d0,d2	sl.32		d2			; *2 (.16)	move.16		{a0}+A16^{D2},d1	; points d'entre  tracer -> D1.16	move.32		d0,d2	mul.16		#LgDescTrapDriv,d2	; ^table des trap de ce sous-pilote -> D2.32	move.32		#{a6}+oDescTrapDriv,a2	; ^descripteur des trap du driver -> A2.32	move.32		#{a2}+32^{d2},a2	; ^table trap et instr -> A2.32	move.32		{a2}+oAdBasePilote,A3	; adresse de base du pilote -> A3.32	move.32		a3,a4	sub.32		#16'56,A4		; adresse ID -> A4.32	move.32		#{a2}+oAdDescPETrap,A5	; adresse descr. PE trap 14 -> A5.32	move.32		#0,d3;recherche des points d'entre de ce sous-pilote;A3.32	^base du sous pilote;A4.32 balaye les PE;D4.16	offset par rapport  base du PE;A5.32	^descr sauvetage instr et adresse suivante pour ce PE;D1.16 Bit map des PE  tracer;d3.16	balayage du PE  testerl0$:	move.16		#0,{a5}+oInstr		; initialise 	move.32		#0,{a5}+oAdSuite	move.32		#0,d4	move.16		{a4+},d4		; offset premier PE	comp.16		#-1,d4	jump,eq		s0$			; -1 ? -> s0$ pas de PE	test.32		D1:d3			;  tracer ?	jump,bc		s0$			; non -> s0$;;?	move.16		{a3}+A16^{d4},{a5}+oInstr	; sauve instruction +/-32k;;?	move.16		#InstrTrap14,{a3}+A16^{d4}	; met l'instruction TRAP #14	move.16		{a3}+32^{d4},{a5}+oInstr	; sauve instruction +64k	move.16		#InstrTrap14,{a3}+32^{d4}	; met l'instruction TRAP #14	move.32		#{a3}+32^{d4}+2,a1	move.32		a1,{a5}+oAdSuites0$:	add.32		#LgDescPETrap,A5	; ^lment suivant de sauvetage	inc.16		d3	comp.16		#NbPE,d3		; tous les PE balays ?	jump,lo		l0$			; non -> l0$	inc.32		d0	comp.16		#NbMaxP,d0		; tous les sous-pilotes balays ?	jump,lo		l$			; non -> l$;;mon	?aftim;;.ascize	"<CR>Initrace"GC	popm.32		a0..a5|d0..d4;;?	jump		continue	ret;****************************************;ROUTINES UTILISABLES DU MODULE TRACE;****************************************;------\; TRACE >;======/;;Routine de l'exception TRACE;A chaque appel: ; - dialogue avec le programme hote;;In;Out;ModTRACE:	POPM.32	A0|D0			; met la pile dans le bon ordre	PUSHM.32	A0..A6|D0..D7;;mon	?aftim;;.ascize	"<CR>Trace "	MOVE.32	A7,A5			; A5^des registres sur la pile	CALL	GET_COMMUN_MEMORY	; redemande la mmoire commune		CALL	TRAITEMENT;.proc	m68020	ClearCache	POPM.32	A0..A6|D0..D7	RETSFTRACEDriv:	PUSHM.32	A0..A6|D0..D7mon	?aftim.ascize	"<CR>Trace "	MOVE.32	A7,A5			; A5 ^des registres sur la pile	CALL	GET_COMMUN_MEMORY	; redemande la mmoire commune	;;?	move.32	{a6}+oSemLockTrace,a5;;?	ntrel	?LOCKmove.32	{a5}+(7+8)*4+2,a4		; adresse de retour -> a4.32fos	?identcomp.32	{a6}+P_Code_Test,a2jump,ne	f$				; pas de traage dans ce driver;;mon	?aftim;;.ascize	" traitement "	CALL	TRAITEMENT	ClearCachef$:;;?	move.32	{a6}+oSemLockTrace,a5;;?	ntrel	?UNLOCK	POPM.32	A0..A6|D0..D7	RETSF;-------\; TRAP15 >;=======/;;Routine de l'exception TRAP 15;;In;Out;ModTRAP15:	POPM.32	A0|D0			; met la pile dans le bon ordre	PUSHM.32	A0..A6|D0..D7;;mon	?aftim;;.ascize	"<CR>Trap 15 "	MOVE.32	A7,A5			; A5^des registres sur la pile	CALL	GET_COMMUN_MEMORY	; redemande la mmoire commune	MOVE.32	{A6}+ADRESSE,A1		; remet la bonne instruction	MOVE.16	{A6}+INSTRUCTION,{A1}	MOVE.32	A1,{A5}+(7+8)*4+2	; modifie sur la pile l'adresse de retour	CALL	TRAITEMENT	ClearCache	POPM.32	A0..A6|D0..D7	RETSFTRAP15Driv:	PUSHM.32	A0..A6|D0..D7mon	?aftim.ascize	"<CR>Trap 15 "	MOVE.32	A7,A5			; A5^des registres sur la pile	CALL	GET_COMMUN_MEMORY	; redemande la mmoire commune;;?	move.32	{a6}+oSemLockTrap15,a5;;?	ntrel	?LOCK	MOVE.32	{A6}+ADRESSE,A1		; remet la bonne instruction	MOVE.16	{A6}+INSTRUCTION,{A1}	MOVE.32	A1,{A5}+(7+8)*4+2	; modifie sur la pile l'adresse de retour	CALL	TRAITEMENT	ClearCache;;?	move.32	{a6}+oSemLockTrap15,a5;;?	ntrel	?UNLOCK	POPM.32	A0..A6|D0..D7	RETSF;-------\; TRAP14  >;=======/;;Routine de l'exception TRAP 14;;In;Out;ModTRAP14Driv:	PUSHM.32	A0..A6|D0..D7mon	?aftim.ascize	"<CR>Trap 14 "	MOVE.32		A7,A5			; A5 ^des registres sur la pile	CALL		GET_COMMUN_MEMORY	; redemande la mmoire commune -> A6.32;;?	move.32		{a6}+oSemLockTrap14,a5;;?	ntrel		?LOCK	MOVE.32		{A5}+(7+8)*4+2,d4	; adresse de retour normale	call		SearchInstr		; recherche de l'instruction  excuter		jump,ne		err$	sub.32		#2,d4			; pointe  la place du TRAP remplac	move.32		d4,a0			; adresse du trap	move.16		{a1}+oInstr,{a0}	; on y met l'instruction remplace	MOVE.32		d4,{A5}+(7+8)*4+2	; modifie sur la pile l'adresse de retour	CALL		TRAITEMENT	ClearCachef$:;;?	move.32		{a6}+oSemLockTrap14,a5;;?	ntrel		?UNLOCK	POPM.32		A0..A6|D0..D7	RETSFerr$:	mon	?aftim	.ascii	"<CR>Problme avec CIBLE, TRAP pour Breakpoint adresse inconnue"	.ascize	"<CR>Vous continuez  vos risque et pril ! "	trap	#1	jump	f$;------------\; SearchInstr >;============/;; Recherche de l'instruction  excuter;;In	D4.32	adresse de retour;Out	A1.32	^descr avec instr trouv si D7=0;	D7.32	erreur;Mod	A0, A1, D0, D1SearchInstr:	move.32		#{a6}+oDescTrapDriv,A0		; ^descr trap driver	-> a0.32	move.16		#NbMaxP-1,d0l0$:	move.32		#{a0}+oAdDescPETrap,A1		; ^desc instr/suite	-> A1.32	move.16		#NbPE-1,d1l1$:	comp.32		{a1}+oAdSuite,d4	jump,eq		s0$	add.32		#LgDescPETrap,A1		; cherche desc suivant	dj.16,nmo	d1,l1$	add.32		#LgDescTrapDriv,A0		; ^sous pilote suivant	-> A0.32	dj.16,nmo	d0,l0$	move.32		#-1,d7	jump		f$s0$:	move.32		#0,d7f$:;;	test.16		d7	ret;------------------\; INIT_MODULE_TRACE  >;==================/;;initialise le module TRACE;Appel une fois au dmarrage;	; IN:	A6.32	^mmoire commune	; 	A4.32	^du tampon mmoire pour un message de longueur maximun LgMess	; 	A3.32	^du nom du programme qui a lanc CIBLE.CODE	; OUT:	sur la pile l'adresse du programme TEST.CODE	; 	D7.16 	si une erreur sinon A0.32..A6.32|D0.32..D7.32 sont mis  0	; MOD:	A0.32..A6.32|D0.32..D7.32INIT_MODULE_TRACE:	MOVE.32		A3,{A6}+C_HOTE		; sauve le pointeur au nom du programme	CALL		FROM_HOTE		; attend le nom du programme  tester;;pushm.32	a0|a1|d0|d1|d7|a3|a4;;move.32	a4,a3				; ^nom programme;;mon	?aftext;;popm.32		a0|a1|d0|d1|d7|a3|a4	CALL		LOAD_FILE_TEST		; charge le programme TEST.CODE	JUMP,NE		FIN$;;mon	?aftim;;.ascize	"<CR>LOAD_FILE_TEST ok"	PUSH.32		a4			; sauve A4	MOVE.32		{A6}+P_MESSAGE,A4	; envoie la date et l'heure de cration pour vrification	MOVE.32		D2,{A4}+oDate				^ valeur du symbole indefinie	MOVE.32		D3,{A4}+oHeure				^ valeur du symbole indefinie	MOVE.16		#CIBLE_DATE,D0	CALL		TO_HOTE	pop.32		A4	MOVE.32		A4,{A6}+P_CODE_TEST	; sauve l'adresse du dbut du code	MOVE.32		A4,{A6}+OPCBASE		; sauve le PC de BASE @AD	comp.32		#CODE,{a6}+OExt	jump,ne		s0$;.CODE;******	ADD.32		A4,A0			; A0^de l'adresse de START	MOVE.16		{A0},{A6}+INSTRUCTION	; sauve l'instruction suivante du programme  dverminer	MOVE.32		A0,{A6}+ADRESSE		; sauve l'adresse de l'instruction suivante	MOVE.16		#16'4E4F,{A0}		; celle-ci est remplace par un trap 15	MOVE.32		#R16^TRAP15,A5		; initialise TRAP 15	NTREL		?IEP15TRP	JUMP,NE		FIN$	MOVE.32		#R16^TRACE,A5		; initialise TRACE	NTREL		?IEPTRACE	JUMP,NE		FIN$	POP.32		A1			; inverse sur la pile l'adresse de START.CODE et de retour;*************************************************;Met l'adresse du dbut du programme  dverminer;	PUSH.32		A0			; sauve l'adresse de START.CODE sur la pile	PUSH.32		A1			; remet l'adresse de retour	jump		sc$s0$:	comp.32		#DRIV,{a6}+OExt	jump,ne		s1$;.DRIV;******	call		AnalDriv;;mon	?aftim;;.ascize	"<CR>AnalDriv"	call		SndDescDriv;;mon	?aftim;;.ascize	"<CR>SndDescDriv"	move.32		#0,a1	comp.32		#68000,{a6}+oProcessor	jump,eq		s10$MODSUP	move.32		VBR,A1MODUSERs10$:	move.32		a1,{a6}+oVBR		; ^de base des interruptions;;mon	?aftim;;.ascize	"<CR>VBR";;ex.32	a1,d4;;mon	?afx8;;ex.32	a1,d4	push.32		a1	call		SndCiblePres	call		Loop			; attend des ordres de l'hte	pop.32		a1	move.32		{a1}+4*46, {a6}+oSavTrap14	; sauve TRAP #14	MOVE.32		#R16^TRAP14Driv,A5	; initialise TRAP #14 (entre pilote)	move.32		A5,{a1}+4*46		; TRAP #14	move.32		{a1}+4*47, {a6}+oSavTrap15	; sauve TRAP #15	MOVE.32		#R16^TRAP15Driv,A5	; initialise TRAP 15	move.32		A5,{a1}+4*47		; TRAP #15	move.32		{a1}+4*9, {a6}+oSavTrace	; sauve TRACE	MOVE.32		#R16^TRACEDriv,A5	; initialise TRACE	move.32		A5,{a1}+4*9		; TRACE	jump		r8^sc$s1$:;Mettre ici les autres types de code  tester (LIB, etc..);**********************************************************	move.16		#ErFill,d7		; Erreur nom de fichier	jump		ERROR			; *%&%&??!!sc$:	Call		SndCible_AbsFin$:	TEST.16		D7	RET;--------\\; AnalDriv >;=========/;;Analyse entte driver;;In	;Out	;Mod	AnalDriv:	pushm.32	a0..A3|d0..d2|d4	move.32		{A6}+P_CODE_TEST,A0	; ^dbut code du driver;Initialisation	move.16		#NbMaxP-1,d0	move.32		#0,{a6}+oBMPilote	move.32		#{a6}+oBMPE,A1		; ^Bit map des points d'entres de chaque Pilotel$:	move.16		#0,{a1+}		; initialise BMPE	dj.16,nmo	d0,l$	move.32		a0,a2			; ^dbut code -> A2.32	move.16		#NbMaxP-1,d0l0$:	move.32		#0,d1	move.16		{a0+},d1		; no sous-pilote ($..._x) -> d1.16	comp.16		#2**7,d1	jump,eq		fs$;Sous-pilote existe (no -> d1.16)	move.32		{a6}+oBMPilote,d4	tset.32		d4:d1			; pilote disponible	move.32		d4,{a6}+oBMPilote;Cherche son adresse de base	move.32		#0,d2	move.16		{a0+},d2		; adresse de base du sous-pilote	move.32		#{A2}+32^{d2},A1	; adresse de base de ce sous-pilote (absolue)	push.32		d1	mul.16		#LgDescTrapDriv,d1	; no sous-pilote * lg table -> index dans table	move.32		#{a6}+oDescTrapDriv,a3	move.32		a1,{A3}+32^{D1}+oAdBasePilote	; adresse de base sauve	call		SearchPE		; bit-map des points d'entres -> D4	move.32		#{a6}+oBMPE,a3	pop.32		d1	sl.32		d1			; no sous-pilote * 2 -> index dans table .16	move.16		d4,{A3}+32^{D1}		; bit map des points d'entres	dj.16,nmo	d0,l0$fs$:	popm.32		a0..A3|d0..d2|d4	ret;--------\\; SearchPE >;=========/;;Recherche des points d'entres disponible pour ce sous-pilote;;In	A1.32	^Base;Out	D4.32	BitMap des points d'entres actifs;Mod	SearchPE:	pushm.32	d0|a1	move.32		#{a1}-16'56,a1	; ^dbut descr sous-pilote	move.32		#0,d4		; Bit map points d'entres actifs	move.16		#0,d0		; compteurl$:	comp.16		#-1,{a1+}	jump,eq		s$	tset.32		d4:d0		; active le bits$:	inc.16		d0	comp.16		#16,d0		; 16 points d'entres	jump,lo		l$	popm.32		d0|a1	ret;-----------\\; SndDescDriv >;============/;;Envoi les descripteurs des pilotes et points d'entres disponibles;;In	;Out	;Mod	SndDescDriv:	pushm.32	a0|d0|a4	move.32		#{a6}+Message+oBM_PI,A4	; ^buffer de message			      ^ valeur du symbole indefinie	move.32		{a6}+oBMPilote,{a4+}	; Bit Map des pilotes	move.16		#NbMaxP-1,d0	move.32		#{a6}+OBMPE,a0l$:	move.16		{a0+},{a4+}		; copie BitMap	dj.16,nmo	d0,l$;valeur par dfaut	move.32		#{a6}+Message+oBM_PT,A4	; ^buffer de message dfaut			      ^ valeur du symbole indefinie	move.32		{a6}+oBMPiloteTr,{a4+}	; Bit Map des pilotes	move.16		#NbMaxP-1,d0	move.32		#{a6}+OBMPETr,a0l1$:	move.16		{a0+},{a4+}		; copie BitMap	dj.16,nmo	d0,l1$	move.16		#CIBLE_DescDriv,d0	call		TO_HOTE	popm.32		a0|d0|a4	ret;***********************************************************************************;***********************************************************************************;PROGRAMME PRINCIPAL;***********************************************************************************;***********************************************************************************;*********************************;ROUTINES DU PROGRAMME PRINCIPAL;*********************************;---------\; FinCible >;=========/;; Fin du programme cible command par l'hote;; In; Out; ModFinCible:	comp.32		#CODE,{a6}+oExt	jump,eq		fin1	comp.32		#DRIV,{a6}+oExt	jump,eq		Fin_Driv	jump		fin1;---------\; Fin_Driv >;=========/;;Fin de cible dans le cas d'un pilote;;In;Out;ModFin_Driv:;;mon	?aftim;;.ascize	"<CR>Fin_Driv "	call		SndCible_Abs	call		RestTrap14	move.32		{a6}+oSavTrap14, {a0}+4*46	; rcupre TRAP #14	move.32		{a6}+oSavTrap15, {a0}+4*47	; rcupre TRAP #15	move.32		{a6}+oSavTrace, {a0}+4*9 	; rcupre TRACE	move.32		{a6}+oSemStop,a5	ntrel		?Signev	jump		Not				; plus de trace;-----------\; RestTrap14 >;===========/;; Remet les instructions de trap14 en place;; In; Out; ModRestTrap14:	move.32		#{a6}+oDescTrapDriv,A0		; ^descr trap driver	-> a0.32	move.16		#NbMaxP-1,d0l0$:	move.32		#{a0}+oAdDescPETrap,A1		; ^desc instr/suite	-> A1.32	move.16		#NbPE-1,d1l1$:	move.32		{a1}+oAdSuite,A2		; adresse suivant le trap	comp.32		#0,a2	jump,eq		s0$	move.16		{a1}+oInstr,{a2}-2		; met instr  l'adresse du traps0$:	add.32		#LgDescPETrap,A1		; cherche desc suivant	dj.16,nmo	d1,l1$	add.32		#LgDescTrapDriv,A0		; ^sous pilote suivant	-> A0.32	dj.16,nmo	d0,l0$	ClearCache	ret;------\; ERROR >;======/;;transmet une erreur  HOTE.CODE;	; IN	D7.16 numro de l'erreur  transmettre  HOTE.CODE	; OUT:	fin du programmeERROR:	MOVE.16	#CIBLE_ERR,D0		; commande d'afficher une erreur	MOVE.32	{A6}+P_MESSAGE,A4	move.32	#{a4}+oErreur,A4		      ^ valeur du symbole indefinie	FOS	?ERROR			; erreur envoye sous forme d'une chaine de caractres	CALL	TO_HOTE	JUMP	FIN1;--------\; ERR_LIB >;========/;;affiche une erreur et termine le programme;	; IN	D7.16 numro de l'erreur  afficher	; OUT	fin du programmeERR_LIB:	PUSH.32	D7	CLR.32	D7	LIB	?OPELIB			; ouvre la librairie	POP.32	D7	LIB	?AFERROR		; affiche l'erreur;;ex.32	a6,d4;;lib	?afx8;;ex.32	a6,d4	LIB	?GETCAR			; attend la frappe d'une touche;	jump	Fin1;-----\; FIN1 >;=====/;;Fin du programme cible;;In;Out;ModFIN1:	MOVE.32	{A6}+P_MESSAGE,A4	CALL	CLOSE_MODULE_COM	; ferme le module de communication	LIB	?CLOLIB			; ferme la librairie	FOS	?STOP			; termine le programme CIBLE.CODE;*********************************;PROGRAMME PRINCIPAL;*********************************;;Initialise le module de communication;Initialise le module trace;Saute dans le programme  dverminer;Sur la pile l'adresse de la premire instruction est place;In:	A3.32	^ligne de commande transmise par FOS ?REMOTEBASE:	call		GET_COMMUN_MEMORY	; ^variables glabales -> A6.32	jump,ne		ERR_LIB			; si impossible alors erreur fatale	call		GivProcessor		; demande le processeur utilis	CALL		INIT_MODULE_COM		; initialise les communications	JUMP,NE		ERR_LIB			; si impossible alors erreur fatale;;mon ?aftim;;.ascize	"<CR>init_module_com ok ";;ex.32	a6,d4;;mon	?afx8;;ex.32	a6,d4;;lib	?opelib	CALL		INIT_MODULE_TRACE	; initialise le module trap	JUMP,NE		ERROR			; si impossible alors erreur fatale;;mon ?aftim;;.ascize	"<CR>init_module_trace ok ";;move.32	{a6}+oExt,d4;;mon	?afx8	comp.32		#CODE,{a6}+oExt	jump,ne		s0$	MOVE.32		#0,A0			; mets tous les registres  0	MOVE.32		#0,A1	MOVE.32		#0,A2	MOVE.32		#{a6}+oLC,A3		; ^dbut d'une ligne de commande	MOVE.32		#0,A4	MOVE.32		#0,A5	MOVE.32		{a6}+P_CODE_TEST,A6	; ^dbut du code	CLR.32		D0	CLR.32		D1	CLR.32		D2	CLR.32		D3	CLR.32		D4	CLR.32		D5	CLR.32		D6	move.32		#16'10001,D7		; pour ne pas prendre le clavier	RET					; sinon commence le dverminage de CODEs0$:	comp.32		#DRIV,{a6}+oExt	jump,ne		s1$	move.32		#-1,d4	ntrel		?modtim	move.32		{a6}+oSemStop,A5	ntrel		?Waitev			; attend la fin de cible	jump		fin1			; et c'est finis1$:	move.16		#erFill,d7	jump		err_Lib???revoir offset des messages	  ^ code operatoire inconnuTstMemoire:	; @DD	pushm.32	A1|A2|A4|D0|D3	move.32		{A6}+OLD_MEM, A1	; ^ancienne position mmoire affiche	move.32		#{A6}+COP_MEM, A4	; tampon pour mmoriser le contenu	test.16		{A4}+LgMess			     ^ valeur du symbole indefinie	jump,eq		r$	MOVE.32		{A4}+oBitMapMem,D2			     ^ valeur du symbole indefinie	MOVE.16		#NBREG-5,D3			 ^ valeur du symbole indefinieA$:	TSET.32		D2:D3			; valable ?	jump,bc		r8^x$			; oui -> compare	ADD.32		#4, A1			; passe  la suivante	ADD.32		#4, A4	JUMP		C$x$:	move.32		{A4+}, d0	comp.32		{A1+}, d0		; correspond ici ?	jump,ne		r8^r$C$:	DJ.16,NMO	D3,A$	setZ					; EQ c'est tout pareilr$:	popm.32		A1|A2|A4|D0|D3	Ret.END