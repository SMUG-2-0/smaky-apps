; $flg:04010001 $erh:DEBUGGER; $---;	.TITLE	DEBUGGER	.PROC	M68000	.BASE	10	.REF	SMAKY	.REF	MODULES;	.REF	GENCAR;	.REF	SCROLL;	.REF	DBOX	.REF	UTILE	.ref	mon	.START	STARTassmile		=	falsedebug_debugger	=	?ascond ; false	; pour debugger le debugger; utilise CIBLED.code;***********************************************************************************;;				 D E B U G G E R;;			   pour programme CALM 680x0;;			 Travail de 8me semestre 1990;;			      L A M I  -  E P F L;;				 C O U R T I N E;;***********************************************************************************;; Ce programme permet de suivre  la trace un programme qu'il va lancer; sur la mme machine, ou sur une autre machine; Le programme espion CIBLE.code communique avec ce programme au moyen de deux ; botes aux lettres du driver BAL; modifications de Alwin Dieperink notes "@AD"; modifications de Denis Dumoulin notes "@DD"; Nouveauts, en dcroissant; 2.0	DD	92/10/30	Seconde excution BAL dj installes ouvertes correctement @@DD; Modif; 1.0	RB	90/07/??	Inverse vido pour registres modifis;				BAL_0, BAL_1 -> BAL;				recherche du programme cible dans le repertoire courant;				  ou systme (:,#:)cible.code;				le nom du fichier  debugger peut tre donn sur la ligne de commande; 1.1	RB	90/07/16	DBOX pour registres divers; 1.2	RB	90/07/26	DBOX pour nom de fichier;				DBOX pour quitter; 1.3	RB	90/07/27	dbut modif pour modif calcul adresse de base {Ax}+A16|32^{Rx}+dpl; 1.4	RB	90/07/27; 1.5	DD+RB	90/07/31	_ accept dans LST; 1.6	DD	90/07/31	recherche de chanes avec Define; 1.7	RB	90/08/10	CACR dpend du processeur; 1.8	RB	90/08/14	DBOX pour rafficher les registres sauvs; 1.9	RB	90/08/23	modif en liaison avec cible02; 1.10	RB	90/08/26	dbug pour .driv (cible03); 1.11	RB	90/08/30	envoi d'une ligne de commande  cible; 1.12	RB+DD	90/09/13	Modif DBOX Com. et priorit plus importante; 1.13	@AD	90/09/27	ajout PCB, affiche PCB au lieu de VBR dans certains cas; 1.14	@AD	90/10/09	positionnement rapide dans le listing;	@DD	90/11/01	divers dtails; 1.15	RB	90/10/24	multiple choix de zone mmoire (10); 1.16	RB	90/10/29	choix du mode de calcul de l'adresse de base; 1.17	DD	90/11/05	mise en commun modifs DD+RB; 1.18	RB	90/11/06	mise en overlay de debugger; 1.19	RB	91/04/02	?EXECUTE  la place de ?REMOTE Remote	=	falseREV	=	2VER	=	0	.rev	rev,ver	.ident	"Debugger pour 680x0, utilise CIBLE.CODE, R.Beuchat, Courtine"	.header	obxsover, .32 OVERLAY	.CODE	,11,2'100011	.HEADER	oBXGC,	.8	"N",2**7+"R", 7		; @@DD pour fentre moyenne !;***********************************************************************************;***********************************************************************************;CONSTANTES;***********************************************************************************;***********************************************************************************;CONSTANTES D'ASSEMBLAGEPC_CODE			=		0PC_VAR			=		1PC_RECORD		=		2	.APC		PC_CODE	.LOC		0	.APC		PC_VAR	.LOC		0;CONSTANTES DU MODULE OUTILSLONG_TIME		=		-1		;temps d'attente infiniSHORT_TIME		=		5		;temps d'attente de quelques millisecondes;CONSTANTES DU MODULE COMMUNICATIONNBREG			=		27		;nombre de registre @AD;CONSTANTES DU MODULE BOXDY_GRAND_ECRAN		=		934		;dimension maximale du grand cran du SMAKY 324DY_MOYEN_ECRAN		=		462		;dimension maximale du demi cran du SMAKY 324DX_WIN_DBOX0		=		595		;dimension de la fentre 0DY_WIN_DBOX0		=		266DY_WIN_DBOX300		=		326DX_WIN_DBOX1		=		800		;dimension de la fentre 1DY_WIN_DBOX1		=		380DX_WIN_DBOX2		=		800		;dimension de la fentre 2DY_WIN_DBOX2		=		820MARGE			=		5		;marge de la fentre SCROLLERR_HOTE		=		16'5500		;constante de base des erreurs personnelles;numro de la ligne ditable pour DBOX_ MEDITPLACE_LST		=		0		;premire ligne ditablePLACE_CODE		=		1		;deuxime ligne ditablePLACE_DOSSIER		=		2		;troisime ligne ditable							;il faut modifier ces valeurs si on change la disposition							;des lignes ditables  l'cranPLACE_COMMAND		=		3;position dans D4.32 des diffrents boutons et carrs pour l'appel DBOX_ EDITBIT_C			=		0BIT_V			=		1BIT_Z			=		2BIT_N			=		3BIT_X			=		4BIT_ABSOLU		=		8BIT_RELATIF		=		9BIT_TRACEI		=		10BIT_TRACEJ		=		11BIT_NOTRACE		=		12;valeur des cls  et des labels lorsqu'on sort de l'appel dbox_edit	;cliquer sur un des registres;registresKEYDBOX			=		16'7E		;la valeur des cls et la mme que celles des labelsKEY_A0			=		8		;pour faciliter la programmation,KEY_D0			=		0		;pour les registres cette valeur correspont encore auKEY_A1			=		9		;numro de la place du registre dans un messageKEY_D1			=		1		;pour trouver sa position il suffit de multiplierKEY_A2			=		10		;la valeur de sa place par 4KEY_D2			=		2		;la numrotation des registres ne peut pas tre changeKEY_A3			=		11		;sans une restructuration complte du programmeKEY_D3			=		3		;par contre les autres cls peuvent tre redfiniesKEY_A4			=		12		;sans autreKEY_D4			=		4KEY_A5			=		13KEY_D5			=		5KEY_A6			=		14KEY_D6			=		6KEY_A7			=		16KEY_USP			=		KEY_A7KEY_D7			=		7KEY_ISP			=		17KEY_MSP			=		18KEY_SR			=		15KEY_VBR			=		19KEY_SFC			=		20KEY_DFC			=		21KEY_CACR		=		22KEY_CAAR		=		23KEY_PCB			=		24 ; @ADKEY_PC			=		25 ; @ADKEY_PCREL		=		26 ; @AD; Label affichage des registres sauvsKEY_SavA0	=	30+8KEY_SavD0	=	30+0KEY_SavA1	=	30+9KEY_SavD1	=	30+1KEY_SavA2	=	30+10KEY_SavD2	=	30+2KEY_SavA3	=	30+11KEY_SavD3	=	30+3KEY_SavA4	=	30+12KEY_SavD4	=	30+4KEY_SavA5	=	30+13KEY_SavD5	=	30+5KEY_SavA6	=	30+14KEY_SavD6	=	30+6KEY_SavA7	=	30+16KEY_SavUSP	=	KEY_SavA7KEY_SavD7	=	30+7KEY_SavISP	=	30+17KEY_SavMSP	=	30+18KEY_SavSR	=	30+15KEY_SavVBR	=	30+19KEY_SavSFC	=	30+20KEY_SavDFC	=	30+21KEY_SavCACR	=	30+22KEY_SavCAAR	=	30+23KEY_SavPCB	=	30+24 ; @ADKEY_SavPC	=	30+25 ; @ADKEY_SavPCREL	=	30+26 ; @AD;labels des touches de choix de l'adresse de baseKEY_BASE		=	16'80 ;	30		;ces trois labels peuvent tre changer sans autreKEY_BASE2		=	16'81 ;	31Key_Depl		=	16'82 ;	32KEY_TOTAL		=	16'83 ;	33KEY_MEM			=	16'84 ;	34;affichage du contenu de la mmoire de la ligne 0  la ligne 10 (11 lignes * 8 = 88 octets)Dim_MemAf		=		11*8KEY_AD0			=		40		;l'ordre des labels pour l'affichage de la mmoireKEY_HEXAD0		=		41		;ne peut pas tre modifierKEY_ASCAD0		=		42KEY_AD1			=		43KEY_HEXAD1		=		44		;cliquer sur une des touches qui affichent le contenu KEY_ASCAD1		=		45		;de la mmoireKEY_AD2			=		46KEY_HEXAD2		=		47KEY_ASCAD2		=		48KEY_AD3			=		49KEY_HEXAD3		=		50KEY_ASCAD3		=		51KEY_AD4			=		52KEY_HEXAD4		=		53KEY_ASCAD4		=		54KEY_AD5			=		55KEY_HEXAD5		=		56KEY_ASCAD5		=		57KEY_AD6			=		58KEY_HEXAD6		=		59KEY_ASCAD6		=		60KEY_AD7			=		61KEY_HEXAD7		=		62KEY_ASCAD7		=		63KEY_AD8			=		64KEY_HEXAD8		=		65KEY_ASCAD8		=		66KEY_AD9			=		67KEY_HEXAD9		=		68KEY_ASCAD9		=		69KEY_AD10		=		70KEY_HEXAD10		=		71KEY_ASCAD10		=		72;lignes ditables pour le choix des nom de fichiers	;cliquer sur une des 3 lignes d'ditionKEY_LST			=		80		;les labels qui suivent peuvent tre redfinisKEY_CODE		=		81		;sans autreKEY_DOSSIER		=		82KEY_COMMAND		=		83		; commande  transmettre;touches d'ordreKEY_CIBLE		=		85		;cliquer sur la touche cibleKEY_HOTE		=		86		;cliquer sur la touche hoteKEY_CONTINUE		=		87		;cliquer sur la touche continue;boutonsKEY_FLAG		=		90		;cliquer sur un des flagsKEY_BIT_ABSOLU		=		91		;cliquer sur absKEY_BIT_RELATIF		=		92		;cliquer sur relKEY_TRACEI		=		93		;cliquer sur traceiKEY_TRACEJ		=		94		;cliquer sur tracejKEY_NOTRACE		=		95		;cliquer sur notrace;labels qui permettent de trouver les dimensions minimum et maximum pour la fentre SCROLLDEBUT_WIN_LST		=		100		;dbut de la fentre SCROLLFIN_WIN_LST		=		101		;fin de la fentre SCROLL;CONSTANTES DU MODULE REGISTRELG_REGISTRE		=		10		;longueur d'un registre;CONSTANTES DU MODULE LSTLGTEST			=		23		;nombre de caractre  tester dans une ligne de TEST.LSTLG_BUFFER_SCROLL_LST	=		150		;nombre de caractre d'une ligne passe comme paramtre au module SCROLL;CONSTANTES DU MODULE INTERPRETEUR.ins	message.asi;CONSTANTES DU PROGRAMME GENERAL;BIT DE TEST, voir TEST:NBCAR_BUFFER_NAME	=		4*NBREG		;longueur des tampons qui contiennent des noms de fichier; Structures:;************NbZone	=	10	.APC	PC_RECORD	.loc	0;VARIABLES DU MODULE MEMOIREoBASE:			.BLK.32		1		;adresse de base pour le calcul de l'adresse d'affichageoBASE2:			.BLK.32		1		;adresse de base pour le calcul de l'adresse d'affichageoDEPL:			.BLK.32		1		;dplacement  additionner  l'adresse de baseoAdMem:			.BLK.32		1		;adresse du milieu pour l'affichage de la mmoireoDeb_Aff:		.BLK.32		1		;1re adresse affiche  l'cranORegBase:		.blk.16		1		; Registre de base relatif  BUFFER_REGORegBase2:		.blk.16		1		; Registre de base relatif  BUFFER_REGOFlagBase2:		.blk.8		1		; A16^ = 0, 32^ = 1 FlA16	=	0 Fl32	=	1			.even; Variables MMENU multiple Touche base 2OSelBase:		.blk.16		1		; Mmorise position MMENU touche baseOMMenuBase2:		.blk.8		3*LMM		; 1 menu + 2 sous-menusLgDescZM	=	APC;***********************************************************************************;***********************************************************************************;VARIABLES;***********************************************************************************;***********************************************************************************LgMess	=	4*NBREG			.APC	PC_RECORD			.LOC	0oMessage:		.BLK.8		LgMess		;tampon pour les messages entre CIBLE et HOTEoORDRE:			.BLK.16		1		;place de la commande (tout de suite aprs MESSAGE)LG_MESSAGE	=	APC		;longueur du tampon de message			.APC		PC_VAR			.LOC		0;VARIABLE DE LA ROUTINE CHANGE_GENCAROBUCAR:			.BLK.8		8		;tampon pour le changement de genre de caractres			.EVENLGVAR_ROUT_CG		=		APC		;longueur de la variable; Variables Globales;********************			.LOC		0;VARIABLES MODULE DBOX_SCROLL_UTILEC_DBOX:			.BLK.16		1		;canal du module DBOXC_SCROLL:		.BLK.16		1		;canal du module SCROLLC_UTILE:		.BLK.16		1		;canal du module UTILE;VARIABLES MODULE COMMUNICATIONMESSAGEIn:		.blk.8		LG_MESSAGE	; message cible -> hoteMESSAGEOut:		.BLK.8		LG_MESSAGE	;tampon pour les messages HOTE -> cibleC_IN:			.BLK.16		1		;canal d'entreC_OUT:			.BLK.16		1		;canal de sortie;VARIABLE DU MODULE DBOXC_WIN_DBOX:		.BLK.32		1		;canal de la fentre DBOX couranteC_WIN_DBOXP:		.blk.32		1		; canal principalC_WIN_DBOXS:		.blk.32		1		; canal dbox par dessusBOUTON:			.BLK.32		1		;mmoire pour les boutons cliqus  l'cranOCanAffReg:		.blk.32		1		; canal dbox affichages registres;VARIABLES DU MODULE REGISTRELgBufferReg	=	Lg_Message-2BUFFER_REG:		.BLK.8		LgBufferReg	;tampon de stockage des registres de TEST.CODE			.EVENCOP_BUFFER_REG:		.BLK.8		LgBufferReg	;copie des registres pour voir ceux modifis  RB			.EVENOBuffSavReg:		.BLK.8		LgBufferReg	;copie des registres pour annul affichage  RB			.EVENREGISTRE:		.BLK.8		LG_REGISTRE	;variable pour les transformations intermdiaire			.EVEN				;lors des modifications des registresNBSAV	==	10OSAVREGISTRE:		.BLK.8		LgBufferReg*NBSAV			.EVENOMComp:			.blk.32		1		; Bitmap des menu gris Compare registre;VARIABLE DU MODULE FICHIER.CODEDATE_FILE_TEST:		.BLK.32		1		;contient la date de cration de TEST.CODE	HEURE_FILE_TEST:	.BLK.32		1		;contient l'heure de cratio de TEST.CODEFILE_CODE:		.BLK.8		NBCAR_BUFFER_NAME	;nom complet du programme  dverminer			.EVENBUT:			.BLK.8		NBCAR_BUFFER_NAME	;adresse du dossier o s'excute le programme  dverminer			.EVENCOMMANDE:		.BLK.8		NBCAR_BUFFER_NAME	;contient l'ordre pour le SMAKY qui contient le programme  tester			.EVEN				;de lancer le programme CIBLE.CODEoLC:			.BLK.8		NBCAR_BUFFER_NAME	; place pour une ligne de commande transmise  cible							; comme param. du prog  dpanner;VARIABLES DU MODULE FICHIER.LSTC_WIN_SCROLL_LST:	.BLK.32		1		;canal de la fentre SCROLL pour le fichier TEST.LSTDESCRIPTEUR_WINDOW:	.BLK.32		1		;pointeur du descripteur de la fentreBUFFER_SCROLL_LST:	.BLK.8		LG_BUFFER_SCROLL_LST	;variables pour le module SCROLL			.EVENVAR_SCROLL_LST:		.BLK.8		LSLVAR		;variables de la fentre SCROLL pour le fichie TEST.LST			.EVEN;variables pour le fichier +++.LSTDERNIERE_ADRESSE:	.BLK.32		1		;pointeur en mmoire  la dernire ligne affiche par SCROLLDERNIERE_LIGNE:		.BLK.16		1		;numro de la dernire ligne affiche par SCROLLNBCR_FILE_LST:		.BLK.16		1		;nombre de ligne du fichier TEST.LSTLONGUEUR_FILE_LST:	.BLK.32		1		;longueur du fichier TEST.LSTPOINTEUR_FILE_LST:	.BLK.32		1		;pointeur  l'adresse de base du fichier TEST.LSTARGUMENT_FILE_LST:	.BLK.8		LGARGS		;argument du fichier TEST.LSTFILE_LST:		.BLK.8		NBCAR_BUFFER_NAME	;contient l'adresse complte du fichier TEST.LST			.EVENPTR_TABL_FILE_LST:	.BLK.32		1		; ^ table des adresses/ligne du fichier TEST.LST @AD;VARIABLES DU MODULE MEMOIREoDescMemB:		.blk.8		LgDescZMoDescMemZ:		.blk.8		LgDescZM*NbZoneOMMENU?:		.blk.8		1		; MMenu slection propos? 0 -> oui			.EVEN				; @DD, pauvre Smaky 100OChoixMem:		.blk.32		1		; Fanion de choix de bitoNumChoixMem:		.blk.16		1		; Numro du choix de zone oMMenuMilieu:		.blk.8		4*LMM		; 1 menu + 3 sous-menu, touche du milieuoCalculAdBase:		.blk.32		1 bRegBase		=		0		; Registre de base dans le calcul de l'adresse de base bRegIndex		=		1		; registre d'index bDeplacement		=		2		; + dplacementTEST:			.BLK.8		1		;mmoire pour tester la prsence des programmes bCOMMUNICATION		=		0		 bLST			=		1		 bCODE			=		2		 bCIBLE			=		3		 bCOMMAND		=		4		OFLNAM:			.blk.8		1		; RB Nom donn en entre			.EVENOProcessor:		.blk.32		1		; Processeur en chiffre ex:68000; Recherche de chane (DD)RECHERCHE_ADRESSE:	.BLK.32		1		;pointeur en mmoire  la dernire ligne chercheRECHERCHE_LIGNE:	.BLK.16		1		;numro de la dernire ligne trouveCHERCHE_FILE_LST:	.BLK.8		NBCAR_BUFFER_NAME	;contient la chane de recherche			.EVENomenupr:		.blk.32		1		; ^touche menu principal avant overlayoexec:			.blk.16		1		; mode de fonctionnement, 0=overlay, -1=normalLGVAR			=		APC		;longueur des variables  rserver			.APC		PC_CODE			.LOC		0;***********************************************************************************;***********************************************************************************;MODULE UTILITAIRE;***********************************************************************************;***********************************************************************************;****************************************;ROUTINES UTILISABLES DU MODULE UTILITAIRE;****************************************;-----------\\;  GET_MEMORY >;============/;; ; ; In	; Out	; Mod	 GET_MEMORY:;cette routine rserve de la mmoire pour les variables du programme elle rend un pointeur de ;cette zone dans A6.32 ce pointeur n'est jamais modifi dans tout le programme;on peut toujours l'utiliser	;IN:	-	;OUT:	A6.32 pointeur des variables	;MOD:	A6.32, D7.16	PUSHM.32	D1|D4	MOVE.16	#MTYPCP,D1		;rserve de la place	MOVE.32	#LGVAR,D4		;pour les variables	GESMEM	?GETMEM	JUMP,NE	FIN$	MOVE.32	A4,A6			;pointeur des variables dans A6					;remplit la zone des variables de zros	MOVE.16	#LGVAR-1,D1A$:	CLR.8	{A4+}	DJ.16,NMO	D1,A$	call	IniMemFIN$:	POPM.32		D1|D4	TEST.16	D7			;si pas assez de mmoire une erreur est rendue	RET; initialisation mouse menu gris, touche milieu sourisIniMem:	move.32		#1,{a6}+OChoixMem				; dbox mmoire Zone 0 par dfaut	move.32		#2**bRegBase+2**bRegIndex+2**bDeplacement,{a6}+oCalculAdBase ; calcul de l'adresse de baseIniMMenuMilieu:	move.32		#-1,{a6}+OMComp	; RB, MMenu tout gris	move.32		#0,           {a6}+oMMenuMilieu+LMM*1+OMMINA	; sauve pas gris	move.32		#2'1111111111,{a6}+oMMenuMilieu+LMM*2+OMMINA	; compare gris	move.32		#2'1111111111,{a6}+oMMenuMilieu+LMM*3+OMMINA	; affiche gris	ret;------------\\; DELAI_INFINI >;=============/;; ; ; In	; Out	; Mod	DELAI_INFINI:;aprs excution de cette routine le dlai d'attente du programme  un vnement extrieur;est infini	;IN:	-	;OUT:	TIMEOUT	;MOD:	D7.16 TIMEOUT	PUSH.16	D4	MOVE.16	#LONG_TIME,D4	NTREL	?SETTIM	POP.16	D4	TEST.16	D7			;rend une erreur si problme	RET;-----------\\; DELAI_COURT >;============/;; ; ; In	; Out	; Mod	DELAI_COURT:;aprs excution de cette routine le dlai d'attente du programme  un vnement extrieur;est de quelques millisecondes	;IN:	-	;OUT:	TIMEOUT	;MOD:	D7.16 TIMEOUT	PUSH.16	D4	MOVE.16	#SHORT_TIME,D4	NTREL	?SETTIM	POP.16	D4	TEST.16	D7			;rend une erreur si problme	RET;---------\\; BIN_ASCII >;==========/;; ; ; In	; Out	; Mod	BIN_ASCII:;cette routine convertit un nombre binaire de 32 bits en une chane ascii de 8 caractres max; RB, les 0 non significatifs sont limins	;IN:	A4.32^dbut du buffer	;	D1.32 nombre  convertir	;OUT:	A4.32^fin du buffer	;MOD:	A4.32, D7.16	PUSHM.32	A0|D0|D3	move.32	#0,{a4}+0		; RB, initialise le buffer	move.32	#0,{a4}+4	move.8	#0,{a4}+8	MOVE.16	#8-1,D0A$:	RL.32	#4,D1	MOVE.32	D1,D3	AND.32	#16'0000000F,D3skip,ne	DJ.16,NMO	D0,A$	MOVE.8	R8^TABLE_HEX+A16^{D3},{A4+}	dec.16	d0	jump,ns	f$B$:	RL.32	#4,D1	MOVE.32	D1,D3	AND.32	#16'0000000F,D3	MOVE.8	R8^TABLE_HEX+A16^{D3},{A4+}	DJ.16,NMO	D0,B$f$:	MOVE.8	#0,{A4}	POPM.32	A0|D0|D3	CLR.16	D7			;aucune erreur est possible	RETTABLE_HEX:		.8	16'30		.8	16'31		.8	16'32		.8	16'33		.8	16'34		.8	16'35		.8	16'36		.8	16'37		.8	16'38		.8	16'39		.8	16'41		.8	16'42		.8	16'43		.8	16'44		.8	16'45		.8	16'46.EVEN;---------\\; ASCII_BIN >;==========/;;cette routine teste si un caractre ascii est un nombre si oui elle rend sa valeur binaire dans D1.4;auparavant D1 est dplac de 4 bits vers la gauche ce qui permet de faire des conversions; la chane. Cette routine peut aussi tre utilise pour savoir si un caractre ascii est un nombre;hexadcimal si non une erreur est rendue ;ATTENTION la routine reconnat les caractres minuscules (RB)	;IN:	D0.8	caractre	;	D1.32	nombre binaire  complter si possible	;OUT:	D1.32 	nombre binaire complt sur les quatre premiers bits	;	D7.16 = 1 si le caractre n'est pas un nombre	;MOD:	D7.16, D1.32ASCII_BIN:	COMP.8	#"0",D0			;est-ce un nombre de 0  9	JUMP,LT	HORS$	COMP.8	#"9",D0	JUMP,GT	A$	AND.8	#16'0F,D0	SL.32	#4,D1	OR.8	D0,D1	CLR.16	D7	RETA$:	COMP.8	#"A",D0			;est-ce une lettre de A  F	JUMP,LT	HORS$	COMP.8	#"F",D0	JUMP,GT	B$	SUB.8	#16'37,D0	SL.32	#4,D1	OR.8	D0,D1	CLR.16	D7	RETB$:	COMP.8	#"a",D0			;est-ce une lettre de a  f	JUMP,LT	HORS$	COMP.8	#"f",D0	JUMP,GT	HORS$	SUB.8	#16'37+16'20,D0	SL.32	#4,D1	OR.8	D0,D1	CLR.16	D7	RETHORS$:	MOVE.16	#1,D7			;si non rend une erreur	RET;***********************************************************************************;***********************************************************************************;MODULE DBOX_SCROLL_UTILE;***********************************************************************************;***********************************************************************************;****************************************;ROUTINES UTILISABLES DU MODULE DBOX_SCROLL_UTILE;****************************************;-------\\; AFERROR >;========/;; ; ; In	; Out	; Mod	AFERROR:;cette routine affiche les erreurs dont on lui donne le numro dans D7.16 elle est capable;de reconnatre des erreurs dfinies dans ce programme dont le numro est la somme de;#ERR_HOTE et du numro de l'erreur  condition videmment que cette erreur  t dfinie;la routine affiche l'erreur dans une box et attend que l'utilisateur clique sur VU	;IN:	D7.16 numro de l'erreur	;OUT:	-	;MOD:	D7.16 	PUSHM.32	A3|D2|D5		PUSH.16	D7	LIB	?PUSHMENU		;sauve le menu	POP.16	D7	push.32	d5	MOVE.16	D7,D2			;teste si l'erreur est une erreur de ce programme	AND.16	#16'FF00,D2	COMP.16	#ERR_HOTE,D2	JUMP,NE	A$	CLR.32	D2	AND.16	#16'00FF,D7.if 1	; @AD j'en ai marre de voir ces commentaires  chaque changement de fichier !!	COMP.16	#1,D7	JUMP,EQ	FIN$	COMP.16	#2,D7	JUMP,EQ	FIN$.endif	MOVE.32	#R16^BASE_ERR_HOTE,A3	MOVE.8	{A3}+A16^{D7},D2	ADD.32	D2,A3	MOVE.16	#2**BDBSAV,D2		;affiche l'erreur de ce programme	DBOX_	TERROR	JUMP	FIN$A$:	MOVE.16	#2**BDBSAV,D2		;affiche une erreur dfinie par le systme	DBOX_	MERRORFIN$:	pop.32	d5	LIB	?POPMENU		;rtablit la menu	POPM.32	A3|D2|D5	CLR.16	D7	RETBASE_ERR_HOTE:				;catalogue des erreurs de ce programme		.8	ERR_0-BASE_ERR_HOTE		.8	ERR_1-BASE_ERR_HOTE		.8	ERR_2-BASE_ERR_HOTE		.8	ERR_3-BASE_ERR_HOTE		.8	ERR_4-BASE_ERR_HOTEERR_0:		.ASCIZE	"Message de CIBLE.CODE inconnu "ERR_1:		.ASCIZE	"Attention les dates de cration ne concident pas ?"ERR_2:		.ASCIZE	"Attention les heures de cration ne concident pas ?"ERR_3:		.ASCIZE	"Attention ligne incorrecte"ERR_4:		.ASCIZE	"Dtruire le programme en excution";--------\\; AFTERROR >;=========/;; ; ; In	; Out	; Mod	AFTERROR:;affiche une erreur donne sous forme de texte;cette routine est utilise pour afficher des erreurs en provenance de CIBLE.CODE qui;sont fournies sous forme d'une chane d'ascii	;IN:	A3.32^pointeur du texte  afficher comme une erreur	;OUT	-	;MOD	D7.16	PUSHM.32	D2|D3|D5	LIB	?PUSHMENU		;sauve le menu	MOVE.16	#2**BDBSAV,D2		;affiche l'erreur en sauvant le bitmap	DBOX_	TERROR	LIB	?POPMENU		;remet le menu	POPM.32		D2|D3|D5	CLR.16	D7	RET;-----------------------------\\; OPEN_MODULE_DBOX_SCROLL_UTILE >;==============================/;; ; ; In	; Out	; Mod	OPEN_MODULE_DBOX_SCROLL_UTILE:;cette routine ouvre les modules SCROLL, DBOX et UTILE fournies par le systme	;IN:	-	;OUT:	{A6}+C_DBOX		canal de DBOX	;	{A6}+C_SCROLL		canal de SCROLL	;	{A6}+C_UTILE		canal d'UTILE	;MOD:	D7.16	PUSHM.32	A3|D0|D1|D3	MOVE.32	#R16^T_SCROLL,A3	;ouvre SCROLL	MOVE.16	#SCROLL_FIRST,D3	LIB_	OPEN	JUMP,NE	FIN$	MOVE.16	D1,{A6}+C_SCROLL	MOVE.32	#R16^T1_DBOX,A3		;ouvre DBOX	MOVE.16	#DBOX_FIRST,D3	LIB_	OPEN	JUMP,NE	FIN$	MOVE.16	D1,{A6}+C_DBOX	MOVE.32	#R16^T_UTILE,A3		;ouvre UTILE	MOVE.16	#UTILE_FIRST,D3	LIB_	OPEN	JUMP,NE	FIN$	MOVE.16	D1,{A6}+C_UTILEFIN$:	POPM.32		A3|D0|D1|D3	TEST.16	D7	RETT_SCROLL:			.ASCIZE		"SCROLL"T1_DBOX:			.ASCIZE		"DBOX"T_UTILE:			.ASCIZE		"UTILE";------------------------------\\; CLOSE_MODULE_DBOX_SCROLL_UTILE >;===============================/;; ; ; In	; Out	; Mod	CLOSE_MODULE_DBOX_SCROLL_UTILE:;Cette routine ferme les modules SCROLL, DBOX et UTILE dans l'ordre inverse dans lequel ils;ont t ouverts. Une erreur de canal et c'est la plante ???	;IN:	{A6}+C_DBOX		canal de DBOX	;	{A6}+C_SCROLL		canal de SCROLL	;	{A6}+C_UTILE		canal d'UTILE	;OUT:	-	;MOD:	D7.16	PUSH.16	D1	MOVE.16	{A6}+C_UTILE,D1	LIB_	CLOSE	MOVE.16	{A6}+C_DBOX,D1	LIB_	CLOSE	MOVE.16	{A6}+C_SCROLL,D1	LIB_	CLOSE	POP.16	D1	TEST.16	D7	RET;***********************************************************************************;***********************************************************************************;MODULE COMMUNICATION;***********************************************************************************;***********************************************************************************;****************************************;ROUTINES INTERNES DU MODULE COMMUNICATION;****************************************;--------\\; OPEN_BAL >;=========/; ;cette routine install un pilote de bals et l'ouvre selon le mode d'ouverture spcifi	;IN:	A3.32^nom logique	;	A4.32^nom physique	;	D3.16 numro de processus	;	D4.16 mode d'ouverture	;OUT:	D6.16 numro de canal	;MOD:	D6.16, D7.16OPEN_BAL:	FOS		?INSTALL		;installe le pilote	JUMP,NE		er$	MOVE.8		D4,D3	FOS		?OPEN			;ouvre la balFIN$:	RETer$:	comp.16		#erUUse,d7		; unit utilise (en gnral programme cible pas arrt)	jump,ne		fin$	MOVE.8		D4,D3	FOS		?OPEN			;ouvre la bal	jump,ne		fin$	comp.8		#2**bOpRd, D4		; c'est la BAL pour lecture ?	@@DD	jump,eq		fin$			; oui -> NOP			@@DD	MOVE.16		d6,{A6}+C_OUT		; canal pour WRITE_TO_CIBLE	MOVE.16		#HOTE_END,D0	CALL		Write_TO_CIBLE		; ordonne  CIBLE.CODE de se dtruire	call		Read_To_Cible		; relit l'ordre si cible ne le prend pas	clr.16		d7	jump		fin$	;---------\\; CLOSE_BAL >;==========/;;cette routine ferme une bal. Si la communication avec CIBLE.CODE est toujours ouverte on ne peut pas;dinstaller la bal ce qui va provoquer des problmes lorsque l'on va relancer le programme;HOTE.CODE. En gnral un reset de l'ordinateur rgle le problme ???	;IN:	A2.32^nom physique	;	A3.32^nom logique	;	D3.16 numro de procesus	;	D6.16 numro de canal	;OUT:	-	;MOD:	A3.32, D7.16CLOSE_BAL:	FOS		?CLOSE			;ferme la bal;	FOS		?DEASSIGN		;dassigne le nom logique du nom physique (inutile);	MOVE.32		A2,A3	FOS		?DEINSTALL		;dinstalle le pilote	RET;****************************************;ROUTINES UTILISABLES DU MODULE COMMUNICATION;****************************************;---------------\\; OPEN_MODULE_COM >;================/;; ; ; In	; Out	; Mod	OPEN_MODULE_COM:;cette routine fournit les lments ncessaires  l'ouverture des bals. Si elles sont dj ouvertes ou;installes le programme rend une erreur et se termine.	;IN:	-	;OUT:	{A6}+C_IN		canal d'entre	;	{A6}+C_OUT		canal de sortie	;MOD:	D7.16	PUSHM.32	A3|A6|D1|D3|D4|D6	CLR.16		D3	MOVE.32		#R16^BAL_HOTE_CIBLE,A3	;installe une bal	MOVE.32		#R16^BAL_PHYSIQUE0,A4;	MOVE.8		#2**BOPWR+2**BOPEXWR,D4	;en criture exclusive	MOVE.8		#2**BOPWR+2**BOpRd,D4	;en criture non exclusive et lecture	CALL		OPEN_BAL	JUMP,NE		FIN$	MOVE.16		D6,{A6}+C_OUT	CLR.16		D3	MOVE.32		#R16^BAL_CIBLE_HOTE,A3	;installe une deuxime bal	MOVE.32		#R16^BAL_PHYSIQUE1,A4	MOVE.8		#2**BOPRD,D4		;en lecture	CALL		OPEN_BAL	JUMP,NE		FIN$	MOVE.16		D6,{A6}+C_INFIN$:	POPM.32		A3|A6|D1|D3|D4|D6	TEST.16		D7			;si impossible rend une erreur	RET;----------------\\; CLOSE_MODULE_COM >;=================/;; ; ; In	; Out	; Mod	CLOSE_MODULE_COM:;cette routine fournit les lments ncessaires  la fermeture des bals	;IN:	{A6}+C_IN		canal d'entre	;	{A6}+C_OUT		canal de sortie	;OUT:	-	;MOD:	D7.16	PUSHM.32	A3|D1|D3|D6	MOVE.32		#R16^BAL_PHYSIQUE0,A2	;ferme la bal en criture	MOVE.32		#R16^BAL_HOTE_CIBLE,A3	CLR.16		D3	MOVE.16		{A6}+C_OUT,D6	CALL		CLOSE_BAL	MOVE.32		#R16^BAL_PHYSIQUE1,A2	;ferme la bal en lecture	MOVE.32		#R16^BAL_CIBLE_HOTE,A3	MOVE.16		{A6}+C_IN,D6	CALL		CLOSE_BAL	clr.16		d7				; RB	POPM.32		A3|D1|D3|D6	TEST.16		D7	RET;--------\\; TO_CIBLE >;=========/;;cette routine permet d'envoyer un message  CIBLE.CODE auparavant elle s'assure de la prsence;d'une communication car sinon elle met des messages qui vont remplir le tampon  la rception;et lorsque CIBLE.CODE va lire ces messages ils ne seront plus adapts et il va y avoir des problmes	;IN:	{A6}+MESSAGEOut+oMessage	mmoire tampon pour les messages	;	D0.16 				commande de HOTE.CODE	;OUT:	envoie un message au programme CIBLE.CODE	;MOD:	D7.16TO_CIBLE:	PUSHM.32	A4|D4|D6	CLR.16		D7			;teste la prsense de la communication	TEST.8		{A6}+TEST:#bCOMMUNICATION 	JUMP,BC		FIN$	MOVE.32		#{A6}+MESSAGEOut+oMessage,A4	;envoie le message	MOVE.16		D0,{A6}+MESSAGEOut+oORDRE	MOVE.32		#LG_MESSAGE,D4	MOVE.16		{A6}+C_OUT,D6	FOS		?WRBYTEFIN$:	POPM.32		A4|D4|D6	TEST.16		D7			;rend une erreur si problme	RET;--------\\; TO_CIBLE >;=========/;; Envoie un message  cible de toute faon, on verra bien s'il arrive !!	;IN:	{A6}+MESSAGEOut+oMessage	mmoire tampon pour les messages	;	D0.16 				commande de HOTE.CODE	;OUT:	envoie un message au programme CIBLE.CODE	;MOD:	D7.16Write_TO_CIBLE:	PUSHM.32	A4|D4|D6	CLR.16		D7			;teste la prsense de la communication	MOVE.32		#{A6}+MESSAGEOut+oMessage,A4	;envoie le message	MOVE.16		D0,{A6}+MESSAGEOut+oORDRE	MOVE.32		#LG_MESSAGE,D4	MOVE.16		{A6}+C_OUT,D6	FOS		?WRBYTEFIN$:	POPM.32		A4|D4|D6	TEST.16		D7			;rend une erreur si problme	RET;-------------\\; Read_To_Cible >;==============/;; Relit le message envoy  cible. Si le message est relut, c'est que cible n'existe plus !; ; In	; Out	D4.32	longueur lue;	D0.16	message; Mod	Read_To_Cible:	PUSHM.32	A4|D6;@@DD	CLR.16		D7			;teste la prsense de la communication	move.16		#5,d4	ntrel		?delms			; 100ms d'attente pour que cible puisse lire	CALL		DELAI_COURT		;l'attente n'est pas infinie	MOVE.32		#{A6}+MESSAGEIn+oMessage,A4	;lit le message	MOVE.32		#LG_MESSAGE,D4	MOVE.16		{A6}+C_Out,D6		; pour lire le message envoy	FOS		?RDBYTE;@@DD	push.16		d7	MOVE.16		{A6}+MESSAGEIn+oORDRE,D0	CALL		DELAI_INFINI		;attente infinie;@@DD	pop.16		d7	clr.16		D7			; @@DD toujours erOUTF	POPM.32		A4|D6	TEST.32		D4			; @@DD	NotZ					; @@DD si EQ relut message	RET;----------\\; FROM_CIBLE >;===========/;;cette routine lit le tampon de rcption pour savoir si un message a t reu de CIBLE.CODE;si la longueur du message est nulle c'est que rien n'a t reu	;IN:	{A6}+MESSAGEIn+oMessage		mmoire tampon du message	;OUT:	D0.16 commande de CIBLE.CODE	;	D4.32 longueur du message si 0 rien n'a t reu	;MOD:	D0.16, D7.16FROM_CIBLE:	PUSHM.32	A4|D6	CALL		DELAI_COURT		;l'attente n'est pas infinie	MOVE.32		#{A6}+MESSAGEIn+oMessage,A4	;lit le message	MOVE.32		#LG_MESSAGE,D4	MOVE.16		{A6}+C_IN,D6	FOS		?RDBYTE	MOVE.16		{A6}+MESSAGEIn+oORDRE,D0	CALL		DELAI_INFINI		;attente infinie	POPM.32		A4|D6	TEST.32		D4			;si EQ alors rien n'a t reu	RET;****************************************;DEFINITIONS POUR LE MODULE COMMUNICATION;****************************************.if	debug_debuggerBAL_HOTE_CIBLE:	.ASCIZE		"#BAL_HC"BAL_CIBLE_HOTE:	.ASCIZE		"#BAL_CH".elseBAL_HOTE_CIBLE:	.ASCIZE		"#BAL_HOTE_CIBLE"BAL_CIBLE_HOTE:	.ASCIZE		"#BAL_CIBLE_HOTE".endif	debug_debuggerBAL_PHYSIQUE0:	.ASCIZE		"$BAL"BAL_PHYSIQUE1:	.ASCIZE		"$BAL";***********************************************************************************;***********************************************************************************;MODULE BOX;***********************************************************************************;***********************************************************************************;****************************************;ROUTINES INTERNES DU MODULE BOX;****************************************;-------------\\; CHANGE_GENCAR >;==============/;; ; ; In	; Out		; Mod	CHANGE_GENCAR:;cette routine permet de changer le genre de caractre affich  l'cran	;IN:	-	;OUT:	change le genre de caractre	;MOD:	D7.16	PUSHM.32	A3|A4|D1|D3..D5	MOVE.16	#MTYPCP,D1		;rserve de la mmoire pour un tampon	MOVE.32	#LGVAR_ROUT_CG,D4	GESMEM	?GETMEM	JUMP,NE	FIN0$	MOVE.32	#R16^TGGENC,A3		;change le genre de caractre	LIB	?SYNGC	JUMP,NE	FIN1$	MOVE.32	A4,A3	MOVE.8	#LOADGC,{A3}+0	MOVE.8	D3,{A3}+1	MOVE.8	D4,{A3}+2	MOVE.8	D5,{A3}+3	MOVE.16	#4,D3	LIB	?STRING	JUMP,NE	FIN1$	MOVE.8	#USEGC,{A3}	MOVE.8	#4,D3	LIB	?STRINGFIN1$:	PUSH.16	D7			;rend la mmoire du tampon	GESMEM	?GIVMEM	POP.16	D7FIN0$:	POPM.32		A3|A4|D1|D3..D5	TEST.16	D7			;s'il y a eu une erreur l'annonce par exemple si le genre de	RET				;caractre n'a pas t trouvTGGENC:		.ASCIZE		"NRF05";--------\\; OPEN_BOX >;=========/;; ; ; In	; Out	; Mod	OPEN_BOX:;cette routine ouvre une bote de dialogue pour afficher les diffrents lments selon les trois ;tables de dfinitions qui suivent. La routine reconat trois types d'cran: le grand et le moyen cran;du SMAKY 324 et le petit cran du SMAKY 100.	;IN:	{A6}+BOUTON	;	D4.32 valeur initiale des boutons	;OUT:	D5.32 canal	;MOD:	{A6}+BOUTON, D5.32, D7.16	PUSHM.32	A2|D2|D3	MOVE.32	D4,D3	LIB	?GETDIM	JUMP,NE	FIN$	SWAP.32	D4	COMP.16	#DY_GRAND_ECRAN,D4	JUMP,LO	A$	MOVE.32	#R16^T_DBOX2,A2		;si grand cran	JUMP	D$A$:	COMP.16	#DY_MOYEN_ECRAN,D4	JUMP,NE	B$	MOVE.32	#R16^T_DBOX1,A2		;si cran moyen	JUMP	C$B$:	MOVE.32	#R16^T_DBOX0,A2		;sinon par dfaut le petit cran est choisis	comp.16	#10'410, D4	jump,lo	r8^cg$	MOVE.32	#R16^T_DBOX300,A2;;;d$:cg$:	CALL	CHANGE_GENCAR	JUMP,NE	FIN$	D$:C$:	Move.16	#0,D2			;ouvre la bote de dialogue	MOVE.32	D3,D4	DBOX_	OPENFIN$:	MOVE.32	D3,D4			;mme si problme rend la bonne valeur dans D4.32	POPM.32	A2|D2|D3	TEST.16	D7	RET;****************************************;BOX0 petit cran;****************************************T_DBOX0:	.16	DBOX0$-T_DBOX0		.16	MENU-T_DBOX0		.16	0		.16	0.EVENDBOX0$:		.8	ODBTEXT		.ASCIZ	" A0"		.8	ODBLABEL,KEY_A0		.8	ODBBOX		.8	KEYDBOX, KEY_A0, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"  D0"		.8	ODBLABEL,KEY_D0		.8	ODBBOX		.8	KEYDBOX, KEY_D0, TDBNORM		.ASCIZ	"         "		.8	ODBLCIRCLE, BIT_ABSOLU+2**BDBONOP+2**BDBOKEY, KEYDBOX, KEY_BIT_ABSOLU		.ASCIZ	" abs"		.8	ODBTEXT;;		.ASCIZ	"  adresse de base:"		.asciz	" adr. "		.8	ODBLABEL,KEY_BASE		.8	ODBBOX		.8	KEYDBOX, KEY_BASE, TDBOMBRE		.ASCIZ	"        ";RB		.8	ODBTEXT		.ASCIZ	"+"		.8	ODBLABEL,KEY_BASE2		.8	ODBBOX		.8	KEYDBOX, KEY_BASE2, TDBOMBRE		.ASCIZ	"        ";RB		.8	ODBTEXT		.ASCIZ	"+"		.8	ODBLABEL,KEY_DEPL		.8	ODBBOX		.8	KEYDBOX, KEY_DEPL, TDBOMBRE		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"="		.8	ODBLABEL,KEY_TOTAL		.8	ODBBOX		.8	KEYDBOX, KEY_TOTAL, TDBOMBRE		.ASCIZ	"         "		.8	ODBLABEL, KEY_MEM		.8	ODBBOX		.8	KEYDBOX, KEY_MEM, TDBMEV		.ASCIZ	"MEM"		.8	ODBCR		.8	ODBTEXT		.ASCIZ	" A1"		.8	ODBLABEL,KEY_A1		.8	ODBBOX		.8	KEYDBOX, KEY_A1, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"  D1"		.8	ODBLABEL,KEY_D1		.8	ODBBOX		.8	KEYDBOX, KEY_D1, TDBNORM		.ASCIZ	"         "		.8	ODBLCIRCLE, BIT_RELATIF+2**BDBONOP+2**BDBOKEY, KEYDBOX, KEY_BIT_RELATIF		.ASCIZ	" rel"		.8	ODBCR		.8	ODBTEXT		.ASCIZ	" A2"		.8	ODBLABEL,KEY_A2		.8	ODBBOX		.8	KEYDBOX, KEY_A2, TDBNORM		.ASC