XAD9, TDBNORM		.ASCIZ	"                       "		.8	ODBLABEL,KEY_ASCAD9		.8	ODBBOX		.8	KEYDBOX, KEY_ASCAD9, TDBNORM		.ASCIZ	"        "		.8	ODBCR;, ODBCR		.8	ODBTEXT		.ASCIZ	"rel"		.8	ODBLABEL, KEY_PCREL		.8	ODBBOX		.8	KEYDBOX, KEY_PCREL, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"CAAR"		.8	ODBLABEL,KEY_CAAR		.8	ODBBOX		.8	KEYDBOX, KEY_CAAR, TDBNORM		.ASCIZ	"         "		.8	ODBLABEL,KEY_AD10		.8	ODBBOX		.8	KEYDBOX, KEY_AD10, TDBNORM		.ASCIZ	"        "		.8	ODBLABEL,KEY_HEXAD10		.8	ODBBOX		.8	KEYDBOX, KEY_HEXAD10, TDBNORM		.ASCIZ	"                       "		.8	ODBLABEL,KEY_ASCAD10		.8	ODBBOX		.8	KEYDBOX, KEY_ASCAD10, TDBNORM		.ASCIZ	"        "		.8	ODBLABEL, KEY_CONTINUE		.8	ODBBOX		.8	KEYDBOX, KEY_CONTINUE, TDBMEV		.ASCIZ	"CONTINUE"		.8	ODBTEXT		.ASCIZ	" "		.8	ODBLABEL, KEY_HOTE		.8	ODBBOX		.8	KEYDBOX, KEY_HOTE, TDBMEV		.ASCIZ	"HOTE "		.8	ODBCR, ODBCR		.8	ODBLABEL, DEBUT_WIN_LST		.8	ODBTEXT		.ASCIZ	" "		.8	ODBTABXN		.16	DX_WIN_DBOX2-MARGE		.8	ODBTABYN		.16	DY_WIN_DBOX2		.8	ODBLABEL, FIN_WIN_LST		.8	ODBTEXT		.ASCIZ	" "		.8	ODBTABXN		.16	DX_WIN_DBOX2		.8	ODBTABYN		.16	DY_WIN_DBOX2 		.8	0.EVEN;****************************************;ROUTINES UTILISABLES DU MODULE BOX;****************************************;---------------\\; OPEN_MODULE_BOX >;================/;; ; ; In	; Out	; Mod	OPEN_MODULE_BOX:;cette routine ouvre la bote de dialogue et affiche les options par dfaut	;IN:	{A6}+C_WIN_DBOXP	numro de canal	;	{A6}+BOUTON		tampon des boutons	;OUT:	-	;MOD:	{A6}+C_WIN_DBOXP, {A6}+C_WIN_DBOX, D7.16	PUSHM.32	D1|D3..D5	MOVE.32	#2,D3			;utilise la souris par le clavier	LIB	?MOUSE	JUMP,NE	FIN$					;initialise les boutons	MOVE.32	#2**BIT_ABSOLU+2**BIT_TRACEI,D4	MOVE.32	D4,{A6}+BOUTON			CALL	OPEN_BOX		;ouvre la bote de dialogue	JUMP,NE	FIN$	MOVE.32	D5,{A6}+C_WIN_DBOXP	;sauve le numro de canal principal	MOVE.32	D5,{A6}+C_WIN_DBOX	;sauve le numro de canal principal	MOVE.16	#KEY_CIBLE+2**BDBGCLABEL+2**BDBGCGREY,D2	DBOX_	GETCO			;grise la touche cible	MOVE.16	#KEY_CONTINUE+2**BDBGCLABEL+2**BDBGCGREY,D2	DBOX_	GETCO			;grise la touche continue	MOVE.16	#KEY_MEM+2**BDBGCLABEL+2**BDBGCGREY,D2	DBOX_	GETCO			;grise la touche memFIN$:	POPM.32		D1|D3..D5	TEST.16	D7			;rend une erreur s'il y a eu un problme	RET;----------------\\; CLOSE_MODULE_BOX >;=================/;; ; ; In	; Out	; Mod	CLOSE_MODULE_BOX:;cette routine ferme la box. Il est indispensable de l'effectuer sinon le cadre de la bote;reste affich  l'cran ce qui peut tre gnant dans certaine situation	;IN:	{A6}+C_WIN_DBOXP		;numro de canal	;OUT:	-	;MOD:	D7.16	PUSH.32	D5	MOVE.32	{A6}+C_WIN_DBOXP,D5	;ferme la bote	DBOX_	CLOSE	POP.32	D5	TEST.16	D7	RET;--------\\; SET_CURS >;=========/;; ; ; In	; Out	; Mod	;cette routine place le curseur aprs un label fournit par d'autres routines qui veulent crire; l'cran. Cette routine permet de rendre toutes les autres indpendantes ;de la position  l'cran de l'objet qu'elles veulent modifier.	;IN:	D2.16 numro du label	;	{A6}+C_WIN_DBOX	;OUT:	;MOD:	D7.16SET_CURS:	PUSHM.32	A0|D2..D5	MOVE.32	{A6}+C_WIN_DBOX,D5		; canal DBOX courante !!	TSET.32	D2:#BDBGCLABEL	DBOX_	GETCO	JUMP,NE	FIN$	LIB	?SETCURSFIN$:	POPM.32		A0|D2..D5	TEST.16	D7	RET;------------\\; GET_SET_CURS >;=============/;;cette routine place le curseur aprs un label fournit par d'autres routines qui veulent crire; l'cran. Cette routine permet de rendre toutes les autres indpendantes ;de la position  l'cran de l'objet qu'elles veulent modifier.	;IN:	D2.16 numro du label	;	{A6}+C_WIN_DBOX	;OUT:	D3.32 coordonne de l'objet Y,X	;	+ curseur au dbut de l'objet	;MOD:	D7.16GET_SET_CURS:	PUSHM.32	A0|D2|D4|D5	MOVE.32		{A6}+C_WIN_DBOX,D5		; canal DBOX courante !!	TSET.32		D2:#BDBGCLABEL	DBOX_		GETCO	JUMP,NE		FIN$	LIB		?SETCURSFIN$:	POPM.32		A0|D2|D4|D5	TEST.16	D7	RET;------------------\\; DBOX_Prend_Fichier >;===================/;; Dbox pour prendre un fichier ; ; In	A3.32	^buffer	;	D3.16	Place_Lst ou Place_Code; Out	; Mod	DBOX_Prend_Fichier:	pushm.32	a0..a5|d1..d5	move.32		a3,a5	Lib		?PushMenu	push.32		d5	and.32		#16'FFFF,d3		; enlve bit <31..16>	comp.16		#Place_Lst,d3	jump,ne		r8^s0$	move.32		#r16^ExtLst,A4	move.32		#r16^TDBox_Lst,a3	jump		r8^s$s0$:	comp.16		#Place_Code,d3	jump,ne		r8^f$	move.32		#r16^ExtCode,A4	move.32		#r16^TDBox_Code,a3	tset.32		d3:#BDBIOFULL		; extension modifiable;;	jump		r8^s$s$:	move.16		#DBOX_PREND,D1	move.16		#(2**BDBEXTEND)+(2**BDBSAV),d2	move.16		#NbCar_Buffer_Name-Lg_Name_Cible,d3	tset.32		d3:#BDBIOEXT1		; A4.32 ^extension	dbox_		Extendf$:	pop.32		d5	Lib		?PopMenu	popm.32		a0..a5|d1..d5	retTDBox_Lst:	.asciz	"HOTE"		; nom du logiciel	.asciz	"Mlistage"	; type de fichier	.asciz	""	.8	0	.evenExtLst:	.ascize	".LST"TDBox_Code:	.asciz	"HOTE"		; nom du logiciel	.asciz	"Mprogramme"	; type de fichier	.asciz	""	.8	0	.evenExtCode:	.ascize	".CODE";--------\\; GET_FILE >;=========/;;cette routine agit comme SET_CURS mais pour les trois lignes ditables extensibles. On peut les atteindre;par un label, ou par l'ordre qu'elles occupent  l'cran. Si on change cette ordre il faut;modifier la valeur des labels. En plus elle rend un nom de fichier	;IN:	A3.32	^buffer	; 	D2.16	label				; RB	;	D3.16	label pour la recherche PLACE_LST, PLACE_CODE, PLACE_DOSSIER	;	{A6}+C_WIN_DBOX		numro de canal de la bote	;	{A6}+BOUTON		tampon des boutons	;OUT:	A4.32	^fin du buffer	;MOD:	D3.16, D7.16GET_FILE:	PUSHM.32	D4|D5A$:	MOVE.32	A3,A4B$:	TEST.8	{A4}	JUMP,EQ	C$	COMP.8	#CR,{A4}	JUMP,EQ	C$	INC.32	A4	JUMP	B$C$:	MOVE.32	{A6}+BOUTON,D4	MOVE.32	{A6}+C_WIN_DBOXP,D5test.8	{a6}+OFlNam		; RBjump,ne	af$			; RB	comp.16	#PLACE_COMMAND,D3	jump,eq	S0$	comp.16	#PLACE_DOSSIER,d3	jump,ne	db$S0$:	DBOX_	MEDITl$:	DBOX_	EDIT	COMP.16	#KEYMGP,D3	JUMP,EQ	ERR_GF$	COMP.16	#KEYMMP,D3	JUMP,EQ	ERR_GF$	COMP.16	#KEYMDP,D3	JUMP,EQ	ERR_GF$	COMP.16	#CR,D3	JUMP,NE	l$	jump	r8^fin$db$:	Call	DBOX_Prend_Fichieraf$:	pushm.32	d2..d5		; RB	dbox_	getco			; RB	lib	?setcurs		; RB	move.16	#2**BAFXND,d2		; extension pas affiche	move.16	#13,d3	lib	?afxfile		; RB	popm.32	d2..d5			; RB	FOS	?WHATFIN$:	POPM.32		D4|D5	TEST.16	D7	RETERR_GF$:	MOVE.16	#1,D7	JUMP	FIN$;----------\\; GET_TOUCHE >;===========/;;cette routine fournit la dernire touche frappe selon les cls des fichiers qui dfinissent;la bote de dialogue, en plus elle affiche la valeur des boutons et les modifie si on leur clique dessus	;IN:	{A6}+BOUTON		tampon des boutons	;	{A6}+C_WIN_DBOXP	canal de la bote de dialogue	;OUT:	D3.16 dernire touche frappe	;MOD:	{A6}+BOUTON, D3.16, D4.32, D7.16GET_TOUCHE:	PUSHM.32	D4|D5	CALL	DELAI_COURT		;temps d'attente de quelques millisecondes	MOVE.16	#-1,D3	MOVE.32	{A6}+BOUTON,D4		;affiche les boutons	MOVE.32	{A6}+C_WIN_DBOXP,D5	DBOX_	MEDIT	JUMP,NE	ERR_GT$	DBOX_	EDIT	JUMP,NE	ERR_GT$	MOVE.32	D4,{A6}+BOUTON		;reprend les boutons modifi par l'utilisateur	CALL	DELAI_INFINI		;temps d'attente infiniFIN$:	POPM.32		D4|D5	TEST.16	D7				RETERR_GT$:	CALL AFERROR			;affiche lui_mme les erreurs	JUMP	FIN$;***********************************************************************************;***********************************************************************************;MODULE REGISTRE;***********************************************************************************;***********************************************************************************;****************************************;ROUTINES INTERNES DU MODULE REGISTRE;****************************************;-----------\\; MODIFIE_REG >;============/;;cette routine modifie le contenu du registre cliqu  l'cran. Si le contenu modifi;n'est pas valide elle attend jusqu' ce que l'utilisateur l'ait corrig. Ds que la modification est;faite elle est transmise  CIBLE.CODE pour ne pas perdre du temps.	;IN:	D6.16 numro du registre	;	{A6}+BUFFER_REG		tampon qui contient les registres	;	{A6}+REGISTRE		tampon provisoire pour transformer le chiffre binaire en un nombre ASCII	;	{A6}+MESSAGEOut+oMessage tampon pour les messages	;OUT:	envoie la modification  CIBLE.CODE	;MOD:	{A6}+BUFFER_REG, {A6}+REGISTRE, D7.16MODIFIE_REG:	PUSHM.32	A0|A2..A5|D0..D4	MOVE.32	#{A6}+BUFFER_REG,A0	MOVE.16	D6,D2			;place le curseur au dbut de la case clique	CALL	SET_CURS	JUMP,NE	ERR_MR$	lib	?aftim	.ascize	"        "	MOVE.16	D6,D2			;place le curseur au dbut de la case clique	CALL	SET_CURS	JUMP,NE	ERR_MR$	MOVE.16	D6,D2			;calcul la position du registre	SL.16	#2,D2		MOVE.32	{A0}+A16^{D2},D1	;convertit l'hexa en ascii	MOVE.32	#{A6}+REGISTRE,A3	MOVE.32	A3,A4	CALL	BIN_ASCII	MOVE.32	#R16^KEYLST,A2		;dite la ligneA$:	MOVE.16	#LG_REGISTRE,D3	LIB	?EDIT	COMP.16	#KEYMGP,D3	JUMP,EQ	B$	COMP.16	#KEYMMP,D3	JUMP,EQ	B$	COMP.16	#KEYMDP,D3	JUMP,EQ	B$	COMP.16	#CR,D3	JUMP,NE	A$B$:	MOVE.32	A3,A5			;reconvertit l'ascii en hexa	CLR.32	D1C$:	MOVE.8	{A5+},D0	COMP.8	#CR,D0	JUMP,EQ	D$	CALL	ASCII_BIN	JUMP,NE	A$	JUMP	C$D$:	PUSH.16	D2			;replace le curseur	MOVE.16	D6,D2	CALL	SET_CURS	POP.16	D2	MOVE.32	D1,{A0}+A16^{D2}	;change la valeur du registre dans le buffer	MOVE.32	D1,D4	LIB	?AFX8	MOVE.16	#NBREG-1,D0		;et transmet la modification	MOVE.32	#{A6}+MESSAGEOut+oMessage,A2E$:	MOVE.32	{A0+},{A2+}	DJ.16,NMO	D0,E$	MOVE.16	#HOTE_REG,D0	CALL	TO_CIBLE	JUMP,NE	ERR_MR$FIN$:	call	Af_Reg			; RB pour afficher modification mmoire	POPM.32		A0|A2..A5|D0..D4	TEST.16	D7			;annonce une erreur	RETERR_MR$:	CALL	AFERROR			;affiche ses erreurs	JUMP	FIN$;****************************************;ROUTINES UTILISABLES DU MODULE REGISTRE;****************************************;------\\; AF_REG >;=======/;;cette routine affiche  l'cran tous les registres de TEST.CODE;d'un seul coup lorsqu'ils sont transmis par CIBLE.CODE y compris les fanions	;IN:	{A6}+BUFFER_REG		tampon des registres	;	{A6}+BOUTON		tampon des boutons  l'cran	;OUT:	affichage des registres	;MOD:	D7.17AF_REG:	PUSHM.32	A0|A1|D0|D2|D3|D4|D5|D6	MOVE.32	#{A6}+BUFFER_REG,A0	MOVE.32	#{A6}+COP_BUFFER_REG,A1	MOVE.32	{A0}+4*KEY_SR,D0	MOVE.32	{A6}+BOUTON,D1	MOVE.8	D0,D1	MOVE.32	D1,{A6}+BOUTON	MOVE.16	#NBREG-1,D6	MOVE.16	#4*(NBREG-1),D0A$:	MOVE.16	D6,D2	CALL	SET_CURS	JUMP,NE	C$	MOVE.32	{A0}+A16^{D0},D4		; Buffer des registres	MOVE.32	{A1}+A16^{D0},D5		; Copie des registres de l'aff prcdent RB	move.32	d4,{A1}+A16^{D0}		; Nouveau reg -> copie	comp.32	d4,d5	jump,eq	eq$	move.8	#AFINV,d3	lib	?afcareq$:	LIB	?AFX8	move.8	#AFDIR,d3	lib	?afcarC$:	DEC.16	D6	JUMP,NS	FIN$	SUB.32	#4,D0	JUMP	A$FIN$:	set.8		{a6}+OMMENU?	call		touche_base	call		touche_base2	clr.8		{a6}+OMMENU?	POPM.32		A0|A1|D0|D2|D3|D4|D5|D6	CLR.16	D7	RET;-------------\\; Af_and_Send  \\; BOUTON_FANION /;==============/;; ; ; In	; Out	; Mod	Af_and_Send:BOUTON_FANION:;cette routine modifie le buffer des registres et les fanions sur la pile de CIBLE.CODE en fonction;des fanions cliqus par l'utilisateur	;IN:	{A6}+BUFFER_REG		tampon des registres	;	{A6}+BOUTON		tampon des boutons  l'cran	;	{A6}+MESSAGEOut+oMessage	tampon des messages	;OUT:	-	;MOD	-	PUSHM.32	A0|A2|D0..D4	MOVE.32	#{A6}+BUFFER_REG,A0	MOVE.32	{A0}+4*KEY_SR,D4	;modifie {A6}+BUFFER_REG	MOVE.32	{A6}+BOUTON,D1	AND.8	#2'00011111,D1	MOVE.8	D1,D4	MOVE.32	D4,{A0}+4*KEY_SR	CALL	AF_REG	MOVE.16	#NBREG-1,D0		;envoie la modification  CIBLE.CODE	MOVE.32	#{A6}+MESSAGEOut+oMessage,A2A$:	MOVE.32	{A0+},{A2+}	DJ.16,NMO	D0,A$	MOVE.16	#HOTE_REG,D0	CALL	TO_CIBLEFIN$:	POPM.32		A0|A2|D0..D4	TEST.16	D7	RET; Routine affichant un registre sous forme de DBOX	;IN:	D6		numro du registre	;	A2		^descripteur de dbox	;	A0		^buffer des registres	;	D4		registre;--------\\; DBOX_Reg >;=========/;; ; ; In	A2.32	^table de description	; Out	; Mod	DBOX_Reg:	pushm.32	d2..d6	lib		?PushMenu		; D5.32 <- canal	push.32		d5	move.16		#2**BDBSAV,d2	DBOX_		OPEN	jump,ne		f$	move.16		#-1,d3	DBOX_		MEDIT	jump,ne		f0$l$:	DBOX_		EDIT	comp.16		#F1,d3	jump,eq		DAC$	comp.16		#F2,d3	jump,eq		DAC$	comp.16		#F3,d3	jump,eq		DAC$	comp.16		#F13,d3	jump,eq		ANN$	comp.16		#F14,d3	jump,eq		ANN$	comp.16		#F15,d3	jump,eq		ANN$	jump		l$DAC$:	DBOX_		CLOSE	sl.32		#2,d6				; *4 position registre	move.32		d4,{A0}+32^{d6}			; mise  jour	jump		r8^f$ANN$:f0$:	DBOX_		CLOSEf$:	pop.32		d5				; reprend canal afmenu	lib		?PopMenu	popm.32		d2..d6	ret;	Bote de dialogue gnre par EDBOX.;	------------------------------------TDBOX_SR:	.16	DBOX$-TDBOX_SR	.16	MENU$-TDBOX_SR	.16	0,0DBOX$:	.8	ODBTITLE	.ASCIZ	"Registre de status"	.8	ODBCR,ODBCR	.8	ODBTABX,16'0A	.8	ODBTEXT	.ASCIZ	"Trace"	.8	ODBTABX,16'19	.8	ODBTEXT	.ASCIZ	"Mode de fonctionnement"	.8	ODBTABX,16'34	.8	ODBTEXT	.ASCIZ	"Masque d'interruption       "	.8	ODBCR,ODBCR	.8	ODBTABX,16'08	.8	ODBLCIRCLE,16'0F.OR.2**BDBOKEY.OR.2**BDBONOP	.16	0	.ASCIZ	" "	.8	ODBTABX,16'0E	.8	ODBLCIRCLE,16'0E.OR.2**BDBOKEY.OR.2**BDBONOP	.16	0	.ASCIZ	" "	.8	ODBTABX,16'1C	.8	ODBLCIRCLE,16'0D.OR.2**BDBOKEY.OR.2**BDBONOP	.16	0	.ASCIZ	" "	.8	ODBTABX,16'2A	.8	ODBLCIRCLE,16'0C.OR.2**BDBOKEY.OR.2**BDBONOP	.16	0	.ASCIZ	" "	.8	ODBTABX,16'35	.8	ODBLCIRCLE,16'0A.OR.2**BDBOKEY.OR.2**BDBONOP	.16	0	.ASCIZ	" "	.8	ODBTABX,16'3D	.8	ODBLCIRCLE,16'09.OR.2**BDBOKEY.OR.2**BDBONOP	.16	0	.ASCIZ	" "	.8	ODBTABX,16'45	.8	ODBLCIRCLE,16'08.OR.2**BDBOKEY.OR.2**BDBONOP	.16	0	.ASCIZ	" "	.8	ODBCR,ODBCR2	.8	ODBTABX,16'29	.8	ODBTEXT	.ASCIZ	"Master"	.8	ODBCR2	.8	ODBTABX,16'08	.8	ODBTEXT	.ASCIZ	"T1"	.8	ODBTABX,16'0E	.8	ODBTEXT	.ASCIZ	"T0"	.8	ODBTABX,16'18	.8	ODBTEXT	.ASCIZ	"Superviseur"	.8	ODBTABX,16'35	.8	ODBTEXT	.ASCIZ	"I2"	.8	ODBTABX,16'3D	.8	ODBTEXT	.ASCIZ	"I1"	.8	ODBTABX,16'45	.8	ODBTEXT	.ASCIZ	"I0"	.8	ODBCR	.8	ODBTABX,16'26	.8	ODBTEXT	.ASCIZ	"Interruption"	.8	ODBCR,ODBCR2	.8	ODBTABX,16'18	.8	ODBTEXT	.ASCIZ	"Utilisateur"	.8	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR2	.8	ODBTABX,16'10	.8	ODBLCIRCLE,16'04.OR.2**BDBOKEY.OR.2**BDBONOP	.16	0	.ASCIZ	" X"	.8	ODBTABX,16'1B	.8	ODBLCIRCLE,16'03.OR.2**BDBOKEY.OR.2**BDBONOP	.16	0	.ASCIZ	" N"	.8	ODBTABX,16'25	.8	ODBLCIRCLE,16'02.OR.2**BDBOKEY.OR.2**BDBONOP	.16	0	.ASCIZ	" Z"	.8	ODBTABX,16'2F	.8	ODBLCIRCLE,16'01.OR.2**BDBOKEY.OR.2**BDBONOP	.16	0	.ASCIZ	" V"	.8	ODBTABX,16'39	.8	ODBLCIRCLE,16'00.OR.2**BDBOKEY.OR.2**BDBONOP	.16	0	.ASCIZ	" C"	.8	ODBCR,ODBCR,ODBCR,ODBCR	.8	ODBTABX,16'0C	.8	ODBBOX	.16.8	F1,TDBMEV	.ASCIZ	"  D'ACCORD  "	.8	ODBTABX,16'35	.8	ODBBOX	.16.8	F13,TDBNORM	.ASCIZ	"   ANNULE   "	.8	0	.EVENMENU$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVEN;	Bote de dialogue gnre par EDBOX.;	------------------------------------TDBOX_CACR_68020:	.16	DBOX$-TDBOX_CACR_68020	.16	MENU_cacr-TDBOX_CACR_68020	.16	0,0DBOX$:	.8	ODBTITLE	.ASCIZ	"Registre de Contrle du Cache"	.8	ODBCR	.8	ODBTABX,16'07	.8	ODBLCIRCLE,16'00.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Enable Cache        "	.8	ODBCR,ODBCR2	.8	ODBTABX,16'07	.8	ODBLCIRCLE,16'01.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Freeze Cache"	.8	ODBCR,ODBCR2	.8	ODBTABX,16'07	.8	ODBLCIRCLE,16'02.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Clear Entry"	.8	ODBCR,ODBCR2	.8	ODBTABX,16'07	.8	ODBLCIRCLE,16'03.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Clear Cache"	.8	ODBCR,ODBCR,ODBCR	.8	ODBTABX,16'02	.8	ODBBOX	.16.8	F1,TDBMEV	.ASCIZ	"  D'ACCORD  "	.8	ODBTABX,16'12	.8	ODBBOX	.16.8	F13,TDBNORM	.ASCIZ	"  ANNULE  "	.8	0	.EVENMENU_cacr:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVEN;	Bote de dialogue gnre par EDBOX.;	------------------------------------TDBOX_CACR_68030:	.16	DBOX$-TDBOX_CACR_68030	.16	MENU_cacr-TDBOX_CACR_68030	.16	0,0DBOX$:	.8	ODBTITLE	.ASCIZ	"Registre de Contrle de Cache"	.8	ODBCR	.8	ODBTABX,16'03	.8	ODBTEXT	.ASCIZ	"Cache de donnes"	.8	ODBTABX,16'1E	.8	ODBTEXT	.ASCIZ	"Cache d'instruction"	.8	ODBCR	.8	ODBTABX,16'03	.8	ODBTEXT	.ASCIZ	"****************"	.8	ODBTABX,16'1E	.8	ODBTEXT	.ASCIZ	"*******************"	.8	ODBCR,ODBCR2	.8	ODBTABX,16'03	.8	ODBTEXT	.ASCIZ	"ED"	.8	ODBTABX,16'07	.8	ODBLCIRCLE,16'08.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Enable Cache        "	.8	ODBTABX,16'1E	.8	ODBTEXT	.ASCIZ	"EI"	.8	ODBTABX,16'23	.8	ODBLCIRCLE,16'00.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Enable Cache        "	.8	ODBCR,ODBCR2	.8	ODBTABX,16'03	.8	ODBTEXT	.ASCIZ	"FD"	.8	ODBTABX,16'07	.8	ODBLCIRCLE,16'09.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Freeze Cache"	.8	ODBTABX,16'1E	.8	ODBTEXT	.ASCIZ	"FI"	.8	ODBTABX,16'23	.8	ODBLCIRCLE,16'01.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Freeze Cache"	.8	ODBCR,ODBCR2	.8	ODBTABX,16'03	.8	ODBTEXT	.ASCIZ	"CED"	.8	ODBTABX,16'07	.8	ODBLCIRCLE,16'0A.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Clear Entry"	.8	ODBTABX,16'1E	.8	ODBTEXT	.ASCIZ	"CEI"	.8	ODBTABX,16'23	.8	ODBLCIRCLE,16'02.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Clear Entry"	.8	ODBCR,ODBCR2	.8	ODBTABX,16'03	.8	ODBTEXT	.ASCIZ	"CD"	.8	ODBTABX,16'07	.8	ODBLCIRCLE,16'0B.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Clear Cache"	.8	ODBTABX,16'1E	.8	ODBTEXT	.ASCIZ	"CI"	.8	ODBTABX,16'23	.8	ODBLCIRCLE,16'03.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Clear Cache"	.8	ODBCR,ODBCR2	.8	ODBTABX,16'03	.8	ODBTEXT	.ASCIZ	"DBE"	.8	ODBTABX,16'07	.8	ODBLCIRCLE,16'0C.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Burst Enable"	.8	ODBTABX,16'1E	.8	ODBTEXT	.ASCIZ	"IBE"	.8	ODBTABX,16'23	.8	ODBLCIRCLE,16'04.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Burst Enable"	.8	ODBCR,ODBCR2	.8	ODBTABX,16'03	.8	ODBTEXT	.ASCIZ	"WA"	.8	ODBTABX,16'07	.8	ODBLCIRCLE,16'0D.OR.2**BDBOKEY.OR.2**BDBONOP,0,0	.ASCIZ	" Write Allocate"	.8	ODBCR,ODBCR,ODBCR	.8	ODBTABX,16'08	.8	ODBBOX	.16.8	F1,TDBMEV	.ASCIZ	"  D'ACCORD  "	.8	ODBTABX,16'24	.8	ODBBOX	.16.8	F13,TDBNORM	.ASCIZ	"  ANNULE  "	.8	0	.EVEN;toutes les petites routines qui suivent fournissent le label du registre cliqu  l'cran;qui doit tre modifi par MODIFIE_REGLIGNEA0:	MOVE.16	#KEY_A0,D6	CALL	MODIFIE_REG	RETLIGNED0:	MOVE.16	#KEY_D0,D6	CALL	MODIFIE_REG	RETLIGNEA1:	MOVE.16	#KEY_A1,D6	CALL	MODIFIE_REG	RETLIGNED1:	MOVE.32	#KEY_D1,D6	CALL	MODIFIE_REG	RETLIGNEA2:	MOVE.32	#KEY_A2,D6	CALL	MODIFIE_REG	RETLIGNED2:	MOVE.32	#KEY_D2,D6	CALL	MODIFIE_REG	RETLIGNEA3:	MOVE.32	#KEY_A3,D6	CALL	MODIFIE_REG	RETLIGNED3:	MOVE.32	#KEY_D3,D6	CALL	MODIFIE_REG	RETLIGNEA4:	MOVE.32	#KEY_A4,D6	CALL	MODIFIE_REG	RETLIGNED4:	MOVE.32	#KEY_D4,D6	CALL	MODIFIE_REG	RETLIGNEA5:	MOVE.32	#KEY_A5,D6	CALL	MODIFIE_REG	RETLIGNED5:	MOVE.32	#KEY_D5,D6	CALL	MODIFIE_REG	RETLIGNEA6:	MOVE.32	#KEY_A6,D6	CALL	MODIFIE_REG	RETLIGNED6:	MOVE.32	#KEY_D6,D6	CALL	MODIFIE_REG	RETLIGNEA7:	MOVE.32	#KEY_A7,D6	CALL	MODIFIE_REG	RETLIGNED7:	MOVE.32	#KEY_D7,D6	CALL	MODIFIE_REG	RETLIGNEISP:	MOVE.32	#KEY_ISP,D6	CALL	MODIFIE_REG	RETLIGNEMSP:	MOVE.32	#KEY_MSP,D6	CALL	MODIFIE_REG	RETLIGNESR:	pushm.32	a0|a2|d4	MOVE.32		#KEY_SR,D6	move.32		#r16^TDBOX_SR,A2	MOVE.32		#{A6}+BUFFER_REG,A0	MOVE.32		{A0}+4*KEY_SR,D4	;modifie {A6}+BUFFER_REG	CALL		DBOX_Reg	MOVE.32		{A6}+BOUTON,D1	MOVE.32		{A0}+4*KEY_SR,D4	;reprend {A6}+BUFFER_REG	move.8		d4,d1			; met  jour les boutons	MOVE.32		d1,{A6}+BOUTON	call		Af_and_Send	popm.32		a0|a2|d4	RETLIGNEVBR:	MOVE.32	#KEY_VBR,D6	CALL	MODIFIE_REG	RETLIGNESFC:	MOVE.32	#KEY_SFC,D6	CALL	MODIFIE_REG	RETLIGNEDFC:	MOVE.32	#KEY_DFC,D6	CALL	MODIFIE_REG	RETLIGNECACR:	pushm.32	a0|a2|d4	MOVE.32		#KEY_CACR,D6	comp.32		#68020,{a6}+OProcessor	jump,ne		r8^s0$	move.32		#r16^TDBOX_CACR_68020,A2	jump		r8^s$s0$:	comp.32		#68030,{a6}+OProcessor	jump,ne		r8^f$	move.32		#r16^TDBOX_CACR_68030,A2s$:	MOVE.32		#{A6}+BUFFER_REG,A0	MOVE.32		{A0}+4*KEY_CACR,D4	;modifie {A6}+BUFFER_REG	CALL		DBOX_Reg	call		Af_and_Sendf$:	popm.32		a0|a2|d4	RETLIGNECAAR:	MOVE.32	#KEY_CAAR,D6	CALL	MODIFIE_REG	RETLIGNEPCB:				; @AD pour le PCB	MOVE.32	#KEY_PCB,D6	CALL	MODIFIE_REG	RETLIGNEPC:	MOVE.32	#KEY_PC,D6	CALL	MODIFIE_REG	RETLIGNEPCREL:	MOVE.32	#KEY_PCREL,D6	CALL	MODIFIE_REG	RET;***********************************************************************************;***********************************************************************************;MODULE FICHIER.CODE;***********************************************************************************;***********************************************************************************;****************************************;ROUTINES INTERNES DU MODULE FICHIER.CODE;****************************************;----------------\\; TRAITE_FILE_CODE >;=================/;; ; ; In	; Out	; Mod	TRAITE_FILE_CODE:;fournit les diffrentes chanes d'ordre;cette routine fournit en fonction des chanes dir et code affiches  l'cran les chanes ncessaires;au lancement de CIBLE.CODE c'est--dire;le nom complet du programme  dverminer avec le dossier dans lequel il se trouve;la commande qui ordonne  l'ordinateur de test de lancer CIBLE.CODE	;IN:	A0.32^buffer nom du programme  dverminer ex:@JANET:#MM0:TEST:TEST.CODE	;	A1.32^buffer de la commande  excuter     ex:@GRAZIELLA:#MM0:CIBLE.CODE	;	A2.32^buffer du but  atteindre            ex:@JANET:#MM0:TEST:	;	A3.32^buffer du nom du programme complet   ex:@JANET:#MM0:TEST:TEST.CODE	;	A4.32^du dernier caractre du buffer A3	;OUT:	-	;MOD:	A0.32, A1.32, A2.32, A3.32, A4.32, D7.16	PUSH.32	A5	MOVE.32	A3,A5			;recopie le nom du programme dans un autre tamponA$:	MOVE.8	{A5+},{A0+}		;qui est normalement le tampon des messages	JUMP,NE	A$	TEST.16	{A2}			;si le tampon du but  atteindre est vide un but par dfaut	JUMP,NE	E$			;est donn: c'est le dossier dans lequel se trouve TEST.CODE					;si aucun dossier n'est spcifi pour TEST.CODE le dverminage					;s'effectue dans le dossier courant	MOVE.32	A3,A5			;place le pointeur A4 au dbut du nom du programme  testerB$:	COMP.32	A5,A4	JUMP,EQ	D$	COMP.8	#":",{-A4}	JUMP,NE	B$	INC.32	A4C$:	MOVE.8	{A5+},{A2+}		;copie le nom complet du dossier du programme  tester	COMP.32	A5,A4			;dans le tampon de but	JUMP,NE	C$D$:	MOVE.8	#0,{A2}E$:	FOS	?NETWNAME		;prpare la commande  excuter par l'ordinateur de TEST	JUMP,NE	G$			;d'abord le nom de l'ordinateur sur lequel se trouve CIBLE.CODEF$:	MOVE.8	{A3+},{A1+}		;et par la mme occasion HOTE.CODE	JUMP,NE	F$	DEC.32	A1	G$:.if	0				; rb pour que virus ne soit pas forcment dans dossier courant	FOS	?GDIR			;puis le nom du dossier	JUMP,NE	I$H$:	MOVE.8	{A3+},{A1+}	JUMP,NE	H$	DEC.32	A1.endifI$:	MOVE.32	#R16^NAME_CIBLE,A3	;et enfin le nom de l'espion du dvermineurJ$:	MOVE.8	{A3+},{A1+}	JUMP,NE	J$	POP.32	A5	CLR.16	D7	RET.if	debug_debuggerNAME_CIBLE:			.ASCIZE	"(:,#:)CIBLED.CODE".elseNAME_CIBLE:			.ASCIZE	"#:CIBLE.CODE"		;; "(:,#:)CIBLE.CODE".endif	debug_debuggerLG_NAME_CIBLE		=	APC-NAME_CIBLE;****************************************;ROUTINES UTILISABLES DU MODULE FICHIER.CODE;****************************************;-----------\\; LANCE_CIBLE >;============/;; ; ; In	; Out	; Mod	LANCE_CIBLE:;cette routine lance le programme CIBLE.CODE et lui transmet par les bals le nom complet;du programme  dverminer	;IN:	{A6}+FILE_CODE	;	{A6}+MESSAGEOut+oMessage	;	{A6}+COMMANDE	;	{A6}+BUT	;	{A6}+C_WIN_DBOXP	;	{A6}+BOUTON	;	{A6}+TEST	;OUT:	-	;MOD:	D7.16	PUSHM.32	A0|A3|A4|D2|D4|D5	call		IniMMenuMilieu	; initialise variable mmenumilieu	TEST.8	{A6}+TEST:#bCODE		;s'il y a dj un programme en train de se faire dverminer	JUMP,BC	B$			;affiche une erreur 	MOVE.16	#ERR_HOTE+4,D7	JUMP	ERR_LC$B$:	MOVE.16	#PLACE_CODE,D3	move.16	#2**BDBGCLABEL+KEY_CODE,d2	; RB	MOVE.32	#{A6}+FILE_CODE,A3	;attend le nom du programme  dverminer	CALL	GET_FILE	JUMP,EQ	A$	CLR.16	D7	JUMP	FIN$			;aucun nom n'a t donnA$:	MOVE.32	#{A6}+MESSAGEOut+oMessage,A0	;traite le nom du programme	MOVE.32	#{A6}+COMMANDE,A1	MOVE.32	#{A6}+BUT,A2	CALL	TRAITE_FILE_CODE	JUMP,NE	ERR_LC$	MOVE.32	#{A6}+BUT,A3		;lance le programme CIBLE.CODE	CALL	DELAI_COURT	MOVE.16	#PLACE_DOSSIER,D3	MOVE.32	{A6}+BOUTON,D4	MOVE.32	{A6}+C_WIN_DBOXP,D5	DBOX_	MEDIT	DBOX_	EDIT	CALL	DELAI_INFINI.if	remote	MOVE.32	#{A6}+COMMANDE,A4	FOS	?REMOTE.else	MOVE.32	#{A6}+COMMANDE,A3	FOS	?execute		; excution locale.endif	remote	JUMP,NE	ERR_LC$	TSET.8	{A6}+TEST:#bCOMMUNICATION	CALL	TO_CIBLE		;crit le nom du programme  dverminer dans la bal	MOVE.16	#HOTE_PROC,D0 	CALL	TO_CIBLE		; demande le processeur  la cible (RB)	TSET.8	{A6}+TEST:#bCODE		;annonce le programme charg	CALL	SNDCOMM?			; envoi une commande si ncessaire	TCLR.8	{A6}+TEST:#bCOMMUNICATIONFIN$:	POPM.32	A0|A3|A4|D2|D4|D5	TEST.16	D7	RETERR_LC$:	CALL	AFERROR			;affiche les erreurs	JUMP	FIN$;-----------\\; GET_COMMAND >;============/;; Attend une commande et l'envoi  cible; ; In	; Out	; Mod	GET_COMMAND:	PUSHM.32	A3|D3	MOVE.16		#PLACE_COMMAND,D3	move.16		#2**BDBGCLABEL+KEY_COMMAND,d2	; @DD	MOVE.32		#{A6}+oLC,A3	CALL		GET_FILE		;attend la commande	tset.8		{a6}+TEST:#bCommand	; Commande donne	CALL		SNDCOMM?	POPM.32		A3|D3	CLR.16	D7	ret;--------\\; SNDCOMM? >;=========/;; Envoi la commande si ncessaire; et si code dj charg; ; In	; Out	; Mod	SNDCOMM?:	pushm.32	a0|a1|d0	test.8		{a6}+TEST:#bCommand	; Y a-t-il une commande ?	jump,bc		f$	test.8		{a6}+TEST:#bCODE	; Y a-t-il un code charg ?	jump,bc		f$	move.32		#{a6}+oLC,A0	move.32		#{a6}+MessageOut+oMessage,A1	move.16		#LgMess-1,D0l$:		move.8		{a0+},{a1+}		; copie la commande	dj.16,nmo	d0,l$	move.16		#Hote_Command,d0	call		TO_CIBLE		; envoi la commande  la ciblef$:	popm.32		a0|a1|d0	ret;------------\\; GET_DIR_TEST >;=============/;; ; ; In	; Out	; Mod	GET_DIR_TEST:;cette routine cherche le dossier d'excution du programme TEST.CODE lorsque l'on clique;dans la ligne ditable dir	;IN:	{A6}+BUT	;OUT:	;MOD:	{A6}+BUT, D7.16	PUSHM.32	A3|D3	MOVE.16		#PLACE_DOSSIER,D3	MOVE.32		#{A6}+BUT,A3	CALL		GET_FILE		;attend le nom du dossier	POPM.32		A3|D3	CLR.16	D7	RET;--------------\\; BOUTON_NOTRACE >;===============/;; ; ; In	; Out	; Mod	BOUTON_NOTRACE:;cette routine s'excute lorsqu'on clique sur le bouton NOTRTACE. Elle efface les autres boutons 	;IN:	{A6}+BOUTON	;OUT:	-	;MOD:	D7.16	PUSH.32	D4	MOVE.32	{A6}+BOUTON,D4	TCLR.32	D4:#BIT_TRACEI	TCLR.32	D4:#BIT_TRACEJ	TSET.32	D4:#BIT_NOTRACE	MOVE.32	D4,{A6}+BOUTON	POP.32	D4	CLR.16	D7	RET;-------------\\; BOUTON_TRACEJ >;==============/;; ; ; In	; Out	; Mod	BOUTON_TRACEJ:;cette routine s'excute lorsqu'on clique sur le bouton TRACEJ. Elle efface les autres boutons 	;IN:	{A6}+BOUTON	;OUT:	-	;MOD:	D7.16	PUSH.32	D4	MOVE.32	{A6}+BOUTON,D4	TCLR.32	D4:#BIT_TRACEI	TSET.32	D4:#BIT_TRACEJ	TCLR.32	D4:#BIT_NOTRACE	MOVE.32	D4,{A6}+BOUTON	POP.32	D4	CLR.16	D7	RET;-------------\\; BOUTON_TRACEI >;==============/;; ; ; In	; Out	; Mod	BOUTON_TRACEI:;cette routine s'excute lorsqu'on clique sur le bouton TRACEI. Elle efface les autres boutons 	;IN:	{A6}+BOUTON	;OUT:	-	;MOD:	D7.16	PUSH.32	D4	MOVE.32	{A6}+BOUTON,D4	TSET.32	D4:#BIT_TRACEI	TCLR.32	D4:#BIT_TRACEJ	TCLR.32	D4:#BIT_NOTRACE	MOVE.32	D4,{A6}+BOUTON	POP.32	D4	CLR.16	D7	RET;---------------\\; TOUCHE_CONTINUE >;================/;; ; ; In	; Out	; Mod	TOUCHE_CONTINUE:;cette routine laisse CIBLE.CODE continuer selon le mode choisit par les boutons des 3 routines;prcdentes	;IN:	{A6}+BOUTON	;OUT:	-	;MOD:	D7.16	PUSHM.32	D0|D4	MOVE.32	{A6}+BOUTON,D4	TEST.32	D4:#BIT_TRACEI		;si trace on instruction	JUMP,BS	A$	TEST.32	D4:#BIT_TRACEJ		;si trace on jump	JUMP,BS	B$	MOVE.16	#HOTE_NOT,D0		;sinon rienFIN$:	CALL	TO_CIBLE		;envoie le message	POPM.32		D0|D4	TEST.16	D7	RETA$:	MOVE.16	#HOTE_TIE,D0	JUMP	FIN$	B$:	MOVE.16	#HOTE_TCF,D0	JUMP	FIN$	;---------\\; END_CIBLE >;==========/;;cette routine stoppe le programme CIBLE.CODE + TEST.CODE	;IN:	{A6}+C_WIN_DBOX	;	{A6}+TEST	;OUT:	-	;MOD:	D7.16END_CIBLE:	PUSHM.32	D0..D5|A1..A3	lib		?PushMenu	push.32		d5	move.16		#DBOX_Quitte,d1	move.16		#2**BDBEXTEND+2**BDBSAV,D2	move.32		#0,d3	move.32		#r16^quit_cible,a3	DBOX_		Extend	comp.16		#F1,d3	jump,ne		FIN$		; pas fini	MOVE.16	#HOTE_END,D0	CALL	TO_CIBLE		;ordonne  CIBLE.CODE de se dtruire	JUMP,NE	ERR_EC$	MOVE.16	#KEY_HOTE+2**BDBGCLABEL+2**BDBGCFULL,D2	MOVE.32	{A6}+C_WIN_DBOXP,D5	DBOX_	GETCO	JUMP,NE	ERR_EC$	TCLR.8	{A6}+TEST:#bCODEFIN$:	pop.32		d5	lib		?PopMenu	POPM.32		D0..D5|A1..A3	TEST.16		D7	RETERR_EC$:	CALL	AFERROR	JUMP	FIN$quit_cible:	.asciz	"CIBLE"		.asciz	"Fcible"		.asciz	""		.8	0		.even;--------\\; END_HOTE >;=========/;; ; ; In	; Out	D2.16 = -2 -> fin du programme; Mod	END_HOTE:;cette routine termine brutalement HOTE.CODE	PUSHM.32	D0..D5|A1..A3	lib		?PushMenu	push.32		d5	move.16		#DBOX_Quitte,d1	move.16		#2**BDBEXTEND+2**BDBSAV,D2	move.32		#0,d3	move.32		#r16^quit_Hote,a3	DBOX_		Extend	comp.16		#F1,d3	jump,ne		FIN$		; pas fini	MOVE.16	#HOTE_END,D0	CALL	TO_CIBLE	pop.32		d5	lib		?PopMenu	move.16		#50, d4	Ntrel		?DelMs				; @DD donne le temps  CIBLE							; de ferme la BAL	POPM.32		D0..D5|A1..A3	move.16		#-2,d2				; fin du programme	retFIN$:	pop.32		d5	lib		?PopMenu	POPM.32		D0..D5|A1..A3	TEST.16		D7	RETquit_Hote:	.asciz	"DEBUGGER"		.asciz	"Fdebugger"		.asciz	""		.8	0		.even;***********************************************************************************;***********************************************************************************;MODULE FICHIER.LST;***********************************************************************************;***********************************************************************************;****************************************;ROUTINES INTERNES DU MODULE FICHIER.LST;****************************************;-----------\\; TESTE_HEURE >;============/;; ; ; In	; Out	; Mod	TESTE_HEURE:;cette routine teste si la date et l'heure de TEST.LST et TEST.CODE ne sont pas diffrentes de plus;d'une minute. Si c'est le cas une erreur est affiche mais le programme est tout de mme charg.;Cette routine permet donc de savoir si les deux fichiers correspondent il est vident qu'elle n'est pas;infaillible et que seule une comparaison du code serait sre mais beaucoup trop longue.;cette routine est excute chaque fois qu'un nouveau programme TEST.LST ou TEST.CODE est charg.	;IN	{A6}+ARGUMENT_FILE_LST	;	{A6}+DATE_FILE_TEST	;	{A6}+HEURE_FILE_TEST	;OUT	-	;MOD	-	PUSHM.32	A4|D3|D4	MOVE.32	#{A6}+ARGUMENT_FILE_LST,A4	MOVE.32	{A4}+OBACD,D3	TEST.32	D3	JUMP,EQ	FIN$	MOVE.32	{A6}+DATE_FILE_TEST,D4	TEST.32	D4	JUMP,EQ	FIN$	SR.32	#8,D3	COMP.32	D4,D3			;compare les dates	JUMP,NE	ERR_DATE$	MOVE.32	{A4}+OBACH-1,D3		;compare les heures	AND.32	#16'00FFFFFF,D3	MOVE.32	{A6}+HEURE_FILE_TEST,D4	MOVE.32	#-1,A4	UTILE_	SUBH			;soustrait les heures	MOVE.32	D3,D4	AND.32	#16'00FFFF00,D3	TEST.32	D3	JUMP,NE	ERR_HEURE$FIN$:	POPM.32		A4|D3|D4	CLR.16	D7	RETERR_DATE$:				;affiche une diffrence de date	MOVE.16	#ERR_HOTE+1,D7	CALL	AFERROR	JUMP	FIN$ERR_HEURE$:				;affiche une diffrence d'heure	MOVE.16	#ERR_HOTE+2,D7	CALL	AFERROR	JUMP	FIN$;----------\\; AF_WIN_LST >  @AD pour toute la routine;===========/AF_WIN_LST:;cette routine passe une ligne  afficher  l'cran lors d'un SCROLL. Le calcul de la ligne suivante;s'effectue par rapport  la position de la dernire ligne calcule: Cette pratique est indispensable;si l'on ne veut pas perdre trop de temps lors de l'affichage de trs longs fichiers.; @AD : utilise la table de lignes, ce qui permet de faire un accs  la ligne par calcul;	et est donc plus rapide que la recherche actuelle	;IN:	A6.32^variables	;	D3.16 numro de la ligne  afficher	;	{A6}+BUFFER_SCROLL_LST	tampon de la ligne  afficher	;	{A6}+PTR_TABL_FILE_LST	^ table des lignes	;OUT:	D3.16=0 --> rien	;	A3.32^ligne  afficher	;	D7.16 erreur si la case est vide	;MOD:	D3.32, D7.16, A3.32	PUSHM.32	A0|D0|D1	AND.32		#16'0000FFFF,D3	SL.32		#3,D3			; *8 bytes	MOVE.32		{A6}+PTR_TABL_FILE_LST,A0comp.32		#0, A0	MOVE.32		{A0}+32^{D3}+0,A0	; A0 <- adresse du dbut de la ligne	MOVE.32		#{A6}+BUFFER_SCROLL_LST,A3	CLR.32		D0Loop$:	MOVE.8		{A0+},D1	COMP.8		#CR,D1	JUMP,EQ		Fin$	COMP.8		#TAB,D1	JUMP,NE		PasTab$	PUSH.32		D0			;remplace TAB par des espaces	DIV.16		#8,D0	SWAP.32		D0	MOVE.16		#8,D1	SUB.16		D0,D1	POP.32		D0	DEC.16		D1E$:	MOVE.8		#SPACE,{A3+}	INC.16		D0	COMP.16		#LG_BUFFER_SCROLL_LST-1,D0	JUMP,GE		Fin$	DJ.16,NMO	D1,E$	JUMP		Loop$PasTab$:	MOVE.8		D1,{A3+}	INC.16		D0	COMP.16		#LG_BUFFER_SCROLL_LST-1,D0	JUMP,NE		Loop$Fin$:	MOVE.8		#0,{A3}			;le dernier caractre doit tre un 0	MOVE.32		#{A6}+BUFFER_SCROLL_LST,A3	CLR.16		D3	POPM.32		A0|D0|D1	CLR.16		D7	RET;-----------------\\; CHERCHE_LIGNE_LST >  @AD pour toute la routine;==================/CHERCHE_LIGNE_LST:; cette routine donne le numro de la ligne en fonction de l'adresse relative.; @AD: cette routine utilise maintenant la table des lignes et est devenue ultra-rapide;      pour l'utilisateur. On ne sent plus qu'on est en fin de listing !!	;IN:	D2.32 contient l'adresse relative  trouver	;	{A6}+NBCR_FILE_LST	contient le nombre de ligne du fichier TEST.LST	;	{A6}+PTR_TABL_FILE_LST	pointe sur une table des lignes @AD	;OUT:	D0.16 contient le numro de la ligne	;MOD:	D0.16, D7.16	PUSHM.32	A0	CLR.16		D7	MOVE.32		{A6}+PTR_TABL_FILE_LST,A0comp.32		#0, A0	MOVE.32		#0,D0Loop$:	COMP.32		#-1,{A0}+4	JUMP,EQ		Next$	COMP.32		{A0}+4,D2	JUMP,EQ		Found$Next$:	ADD.32		#8,A0	INC.16		D0	COMP.16		{A6}+NBCR_FILE_LST,D0	JUMP,LS		Loop$	MOVE.16		#ERR_HOTE+1,D7Found$:	POPM.32		A0	TEST.16		D7	RET;--------\\; CODE_LST >;=========/; cette routine teste si une ligne de TEST.LST contient du code si oui elle rend l'adresse relative; contenue dans cette ligne. Si non elle rend une erreur.	;IN:	A0	^dbut de la ligne	;OUT:	D1.32 	adresse relative	;	D7.16 = 1 si la ligne ne contient pas d'adresse	;MOD:	D1.32, D7.16 CODE_LST:	PUSHM.32	D0|D2|D6|A0		; @AD (A0 sauv)	MOVE.16		#LGTEST,D2	CLR.32		D6L$:	CLR.32		D1	MOVE.16		#4-1,d6			; 4 chiffres minimum pour adresse !!A$:	TEST.32		D6:#31	JUMP,BS		C$			; nombre trouv -> C$B$:	MOVE.8		{A0+},D0	COMP.8		#CR,D0	JUMP,EQ		ERR_CL$			; fin de ligne -> ERR_Cl$	COMP.8		#";",D0	JUMP,EQ		ERR_CL$			; commentaire -> ERR_Cl$	DEC.16		D2			; dpassement de la ligne max -> Err_Cl$	JUMP,EQ		ERR_CL$	CALL		ASCII_BIN		; Chiffre HEXA -> BIN	JUMP,NE		A$	TSET.32		D6:#31			; un digit trouv	DEC.16		D6	JUMP		B$; Un nombre hexa trouvC$:	TCLR.32		D6:#31	test.16		d6	jump,PL		L$			; pas trouv 4 digit minimum on recommence	comp.8		#"_",D0			; pour instruction MACRO	jump,eq		s$	COMP.8		#SPACE,D0		; Instruction normale	JUMP,NE		L$s$:	MOVE.8		{A0},D0	PUSH.32		D1	CALL		ASCII_BIN	JUMP,EQ		D$	POP.32		D1	JUMP		L$D$:	POP.32		D1	CLR.16		D7FIN$:	POPM.32		D0|D2|D6|A0		; @AD	TEST.16		D7	RETERR_CL$:	MOVE.16		#ERR_HOTE+3,D7	JUMP		FIN$;----------\\; LOADER_LST >;===========/;; ; ; In	; Out	; Mod	LOADER_LST:;cette routine charge en mmoire un fichier TEST.LST pour l'afficher; @AD elle appelle aussi la routine qui calcule la table rapide	;IN:	A3.32^nom du programme	;	{A6}+ARGUMENT_FILE_LST	tampon pour les arguments de TEST.LST	;OUT:	A4.32 adresse	;	A2.32 ^ table des lignes (0 si absent) ; @AD	;	D4.32 longueur	;	D0.16 nombre de ligne	;	D7.16 = 1 s'il y a eu une erreur	;MOD:	A4.32, D0.32, D4.32, D7.16	PUSHM.32	A0|A1|D1|D3|D6	MOVE.32	#{A6}+ARGUMENT_FILE_LST,A4	MOVE.32	#2**BOPRD+2**BOPSYS+2**BOPEXTEND+2**BOPARGS,D3	;ouvre le fichier en lecture	FOS	?ARGSOPEN	JUMP,NE	FIN0$	MOVE.32	{A4}+OBALGF,D4		;lit la longueur du programme	MOVE.16	#MTYPCP,D1		;demande de la mmoire pour le programme	GESMEM	?GETMEM			;A4 ^mmoire	JUMP,NE	FIN1$	FOS	?RDBYTE			;charge le programme	JUMP,NE	FIN1$	CLR.32	D0			;compte le nombre de ligne	MOVE.32	A4,A0	MOVE.32	A4,A1	ADD.32	D4,A1A$:	COMP.32	A0,A1	JUMP,LE	FIN2$			; @AD	COMP.8	#EOP,{A0}		;remplace EOP par SPACE	JUMP,NE	B$	MOVE.8	#SPACE,{A0}B$:	COMP.8	#CR,{A0+}	JUMP,NE	A$	INC.32	D0	JUMP	A$FIN2$:	CALL	INIT_LINETABLE_LST	; @AD calcule la table des lignesFIN1$:	push.16	d7	FOS	?CLOSE	pop.16	d7FIN0$:	POPM.32		A0|A1|D1|D3|D6	TEST.16	D7	RET;-------------------\\; INIT_LINETABLE_LST > @AD pour toute la routine;===================/; initialise la table des lignes;; une ligne est reprsente par 2 long word :; - l'adresse absolue de dbut de ligne de listing en mmoire; - l'adresse relative du programme (si indfinie : -1); in	A4.32	^ listing;	D0.32	nombre de lignes; out	A2.32	^ table (0 si pas de table); mod	A2.32, D7.16INIT_LINETABLE_LST:	PUSHM.32	A0|A4|D0|D1|D4	MOVE.32		#0,A2		; pas encore de table	MOVE.32		A4,A0		; A3 <- ^ listing	MOVE.32		D0,D4	SL.32		#3,D4		; *8 bytes	ADD.32		#16,D4		; petite rserve	MOVE.16		#MTYPCP,D1	GESMEM		?GETMEM		; demande de la mmoire	JUMP,NE		END$	GESMEM		?CLEARMEM	; efface la mmoire	MOVE.32		A4,A2		; A2 <- ^ tableLoop$:	MOVE.32		A0,{A4+}	MOVE.32		#-1,{A4+}	CALL		CODE_LST	JUMP,NE		OK$	MOVE.32		D1,{A4}-4Ok$:	COMP.8		#CR,{A0+}	; saute la fin de ligne	JUMP,NE		Ok$	DEC.32		D0		; encore une ligne ?	JUMP,PL		Loop$		; oui	clr.16		d7END$:	POPM.32		A0|A4|D0|D1|D4	test.16		D7	RET	;------------\\; OPEN_WIN_LST >;=============/;; ; ; In	; Out	; Mod	OPEN_WIN_LST:;cette routine ouvre la fentre SCROLL	;IN:	{A6}+VAR_SCROLL_LST	pointeur des variables utiles  SCROLL	;	{A6}+DESCRIPTEUR_WINDOW	pointeur aux informations sur la fentre	;	{A6}+NBCR_FILE_LST	nombre de ligne  afficher	;OUT:	A5.32 numro de canal	;	D0.32 = Y,X	;MOD:	A5.32, D7.16	PUSHM.32	A0|D0|D2|D3	MOVE.32	#{A6}+VAR_SCROLL_LST,A5	;A5^des variables utiles  SCROLL	MOVE.16	#DEBUT_WIN_LST,D2	;D0 = Y,X	CALL	GET_SET_CURS	JUMP,NE	FIN$	MOVE.32	D3,D0	MOVE.16	#FIN_WIN_LST,D2		;D3 = DY,DX	CALL	GET_SET_CURS	JUMP,NE	FIN$	SUB.32	D0,D3	MOVE.32	D0,{A5}+OSLPOS		;X,Y	MOVE.32	D3,{A5}+OSLDIM		;DY,DX	MOVE.32	#R16^AF_WIN_LST,A0	;A4^routine d'affichage d'une ligne	MOVE.32	A0,{A5}+OSLADL	MOVE.32	{A6}+DESCRIPTEUR_WINDOW,A0	;A0^descripteur de la fentre	MOVE.16	{A6}+NBCR_FILE_LST,{A5}+OSLCYN	;nombre de ligne de la fentre	MOVE.16	#0,{A5}+OSLCYS			;numro de la premire ligne contraste 	MOVE.8	#1,{A5}+OSLASV+OSCPAGE	;mode page	SCROLL_	LDRAW	JUMP,NE	FIN$	SCROLL_	LUPDATEFIN$:	POPM.32		A0|D0|D2|D3	TEST.16	D7	RET;****************************************;ROUTINES UTILISABLES DU MODULE FICHIER.LST;****************************************;---------------\\; OPEN_MODULE_LST >;================/;; ; ; In	; Out	; Mod	OPEN_MODULE_LST:;cette routine ouvre la fentre SCROLL pour afficher le fichier TEST.LST	;IN:	{A6}+DESCRIPTEUR_WINDOW	;	{A6}+FILE_LST	;	{A6}+POINTEUR_FILE_LST	;	{A6}+LONGUEUR_FILE_LST	;	{A6}+NBCR_FILE_LST	;	{A6}+C_WIN_SCROLL_LST	;	{A6}+TEST	;OUT:	-	;MOD:	D7.16 +toutes les variables passes comme paramtres	PUSHM.32	A3..A5|D0..D2|D4	LIB	?GETPDIS	JUMP,NE	ERR_OML$	MOVE.32	A4,{A6}+DESCRIPTEUR_WINDOW	MOVE.16	#PLACE_LST,D3		;attend le nom du programme  lister	move.16	#2**BDBGCLABEL+KEY_LST,d2	; RB	MOVE.32	#{A6}+FILE_LST,A3	CALL	GET_FILE	JUMP,EQ	A$	CLR.16	D7	JUMP	FIN$A$:	TCLR.8	{A6}+TEST:#bLST		; @AD indique qu'il n'y a plus de fichier .LST (bug)	JUMP,BC	B$	MOVE.16	#MTYPCP,D1	MOVE.32	{A6}+POINTEUR_FILE_LST,A4	GESMEM	?GIVMEM	JUMP,NE	ERR_OML$	MOVE.32	{A6}+PTR_TABL_FILE_LST,A4 ; @AD dcharge aussi la table rapide	COMP.32	#0,A4	JUMP,EQ	B$	GESMEM	?GIVMEM			; .. @ADB$:	CALL	LOADER_LST		;charge le programme	JUMP,NE	ERR_OML$	MOVE.32	A4,{A6}+POINTEUR_FILE_LST	MOVE.32	A4,{A6}+DERNIERE_ADRESSE	MOVE.32	A4,{A6}+RECHERCHE_ADRESSE	; DD recherche prvue depuis le dbut du fichier	MOVE.32	A2,{A6}+PTR_TABL_FILE_LST	; ^ table rapide @AD	MOVE.16	#0,{A6}+DERNIERE_LIGNE	MOVE.16	#0,{A6}+RECHERCHE_LIGNE		; DD no ligne trouve pour recherche	MOVE.32	D4,{A6}+LONGUEUR_FILE_LST	MOVE.16	D0,{A6}+NBCR_FILE_LST	CALL	TESTE_HEURE		;compare les heures de cration de TEST.CODE et TEST.LST	CALL	OPEN_WIN_LST		;ouvre la fentre	JUMP,NE	ERR_OML$	MOVE.32	A5,{A6}+C_WIN_SCROLL_LST	TSET.8	{A6}+TEST:#bLSTFIN$:	POPM.32		A3..A5|D0..D2|D4	TEST.16	D7	RETERR_OML$:				;affiche les erreurs	CALL	AFERROR	JUMP	FIN$;-----------------\\; MGPMMP_SCROLL_LST >;==================/;; ; ; In	; Out	; Mod	MGPMMP_SCROLL_LST:;cette routine droule la fentre SCROLL si l'on clique dans la fentre avec les boutons de gauche	;IN:	{A6}+TEST	;	{A6}+DESCRIPTEUR_WINDOW	;	{A6}+C_WIN_SCROLL_LST	;OUT:	-	;MOD:	D7.16	PUSHM.32	A0|A5|D3|D4	CLR.16	D7	TEST.8	{A6}+TEST:#bLST		;si le fichier existe	JUMP,BC	FIN$	LIB	?IFMOUSE		;si la souris dans la fentre SCROLL	MOVE.32	{A6}+DESCRIPTEUR_WINDOW,A0	SUB.32	{A0}+ODFFY,D4	MOVE.32	{A6}+C_WIN_SCROLL_LST,A5	SCROLL_	LMOVE			;alors on scrolleFIN$:	POPM.32		A0|A5|D3|D4	TEST.16	D7	RET;-------------\\; MDP_ADRES_LST >;==============/;; ; ; In	; Out	; Mod	MDP_ADRES_LST:;cette routine fournit  CIBLE.CODE l'adresse relative d'une ligne  partir du fichier TEST.LST;pour qu'il place un point d'arrt.	;IN:	{A6}+TEST	;	{A6}+C_WIN_SCROLL_LST	;	{A6}+POINTEUR_FILE_LST	;	{A6}+MESSAGEOut+oMessage	;OUT:	-	;MOD:	{A6}+MESSAGEOut+oMessage, D7.16	PUSHM.32	A0|D0..D4	CLR.16	D7	TEST.8	{A6}+TEST:#bLST	JUMP,BC	FIN$	MOVE.32	{A6}+C_WIN_SCROLL_LST,A5	MOVE.16	{A5}+OSLCYS,D3	MOVE.32	{A6}+POINTEUR_FILE_LST,A0A$:	DEC.16	D3			;cherche la bonne ligne	JUMP,LT	C$B$:	COMP.8	#CR,{A0+}	JUMP,NE	B$	JUMP	A$C$:	CALL	CODE_LST		;cherche l'adresse relative	JUMP,NE	ERR_MAL$	MOVE.32	D1,{A6}+MESSAGEOut+oMessage	;et l'envoie  CIBLE.CODE	MOVE.16	#HOTE_TRAP,D0	CALL	TO_CIBLE	JUMP,NE	ERR_MAL$FIN$:	POPM.32	A0|D0..D4	TEST.16	D7	RETERR_MAL$:				;si la ligne est incorrecte il affiche l'erreur	CALL	AFERROR	JUMP	FIN$;***********************************************************************************;***********************************************************************************;MODULE MEMOIRE;***********************************************************************************;***********************************************************************************;----------\\; Select_Mem >;===========/;; A complter !!!;; Slectionne la fonction qui permet de choisir une zone mmoire; ; In	; Out	; Mod	Select_Mem:	pushm.32	a0..a4|d0..d6	lib		?PushMenu		; D5.32 <- canal	push.32		d5	MOVE.32		#R16^TDBoxMem,A2	; Description DBOX Mem	Move.16		#2**BDBSAV,D2			MOVE.32		{a6}+OChoixMem,D4	DBOX_		OPEN	move.32		D5,{a6}+C_WIN_DBOX	; Canal DBOX courant	set.8		{a6}+OMMENU?		; pas de menu demand (pour affichage)	move.32		#NbZone-1,d0	move.32		#r16^TDZ,A0l$:	move.32		{a0+},D6		; offset descripteur de zone 	move.16		{a0+},D5		; Key_Base	call		AfBase	move.16		{a0+},D5		; Key_Base2	call		AfBase2	move.16		{a0+},D5		; Key_Depl	call		AfDepl	move.16		{a0+},D5		; Key_Off	call		AfOff	dj.16,nmo	d0,l$	move.32		{a6}+C_WIN_DBOX,D5	; Canal DBOX courant	move.32		#-1,d3	dbox_		MEDITla$:	MOVE.32		{a6}+OChoixMem,D4	move.32		{a6}+C_WIN_DBOX,D5	; Canal DBOX courant	dbox_		Edit	move.32		d4,{a6}+OChoixMem	clr.8		{a6}+OMMENU?		; menu demand	clr.32		d5	clr.32		d6	move.8		d3,d5			; Key_label = touche	move.8		d3,d6	and.32		#16'F0,d6	sr.32		#4,d6			; numro de zone	mul.16		#LgDescZM,d6		; offset	add.32		#oDescMemZ,d6		; ne pas oublier l'offset de base !!	move.32		#r16^TRoutZ,A1	move.16		#0,d1	dbox_		CallC	comp.16		#end,d2	jump,ne		la$	move.32		{a6}+C_WIN_DBOX,D5	; Canal DBOX courant	dbox_		Close	move.32		{a6}+C_WIN_DBOXP,{a6}+C_WIN_DBOX	set.8		{a6}+OMMENU?		; pas de menu demand (pour affichage)	call		TOUCHE_BASE	call		TOUCHE_BASE2	call		TOUCHE_DEPLACEMENT	move.32		d1,{a6}+oDescMemB+oDeb_Aff	call		Show_mem	clr.8		{a6}+OMMENU?		; menu demand	pop.32		d5				; reprend canal afmenu	lib		?PopMenu	popm.32		a0..a4|d0..d6	retTDZ:	.32	oDescMemZ+LgDescZM*0	.16	Key_BaseZ0, Key_Base2Z0, Key_DeplZ0, Key_OffZ0	.32	oDescMemZ+LgDescZM*1	.16	Key_BaseZ1, Key_Base2Z1, Key_DeplZ1, Key_OffZ1	.32	oDescMemZ+LgDescZM*2	.16	Key_BaseZ2, Key_Base2Z2, Key_DeplZ2, Key_OffZ2	.32	oDescMemZ+LgDescZM*3	.16	Key_BaseZ3, Key_Base2Z3, Key_DeplZ3, Key_OffZ3	.32	oDescMemZ+LgDescZM*4	.16	Key_BaseZ4, Key_Base2Z4, Key_DeplZ4, Key_OffZ4	.32	oDescMemZ+LgDescZM*5	.16	Key_BaseZ5, Key_Base2Z5, Key_DeplZ5, Key_OffZ5	.32	oDescMemZ+LgDescZM*6	.16	Key_BaseZ6, Key_Base2Z6, Key_DeplZ6, Key_OffZ6	.32	oDescMemZ+LgDescZM*7	.16	Key_BaseZ7, Key_Base2Z7, Key_DeplZ7, Key_OffZ7	.32	oDescMemZ+LgDescZM*8	.16	Key_BaseZ8, Key_Base2Z8, Key_DeplZ8, Key_OffZ8	.32	oDescMemZ+LgDescZM*9	.16	Key_BaseZ9, Key_Base2Z9, Key_DeplZ9, Key_OffZ9TDB:	.32	oDescMemB	.16	Key_Base, Key_Base2, Key_DeplTRoutZ:	.8.8	KeyDBox,Key_BaseZ0	.8.8	KeyDBox,Key_BaseZ1	.8.8	KeyDBox,Key_BaseZ2	.8.8	KeyDBox,Key_BaseZ3	.8.8	KeyDBox,Key_BaseZ4	.8.8	KeyDBox,Key_BaseZ5	.8.8	KeyDBox,Key_BaseZ6	.8.8	KeyDBox,Key_BaseZ7	.8.8	KeyDBox,Key_BaseZ8	.8.8	KeyDBox,Key_BaseZ9	.16	0	.16	AfBase-TRoutZ	.8.8	KeyDBox,Key_Base2Z0	.8.8	KeyDBox,Key_Base2Z1	.8.8	KeyDBox,Key_Base2Z2	.8.8	KeyDBox,Key_Base2Z3	.8.8	KeyDBox,Key_Base2Z4	.8.8	KeyDBox,Key_Base2Z5	.8.8	KeyDBox,Key_Base2Z6	.8.8	KeyDBox,Key_Base2Z7	.8.8	KeyDBox,Key_Base2Z8	.8.8	KeyDBox,Key_Base2Z9	.16	0	.16	AfBase2-TRoutZ	.8.8	KeyDBox,Key_DeplZ0	.8.8	KeyDBox,Key_DeplZ1	.8.8	KeyDBox,Key_DeplZ2	.8.8	KeyDBox,Key_DeplZ3	.8.8	KeyDBox,Key_DeplZ4	.8.8	KeyDBox,Key_DeplZ5	.8.8	KeyDBox,Key_DeplZ6	.8.8	KeyDBox,Key_DeplZ7	.8.8	KeyDBox,Key_DeplZ8	.8.8	KeyDBox,Key_DeplZ9	.16	0	.16	AfDepl-TRoutZ	.8.8	KeyDBox,Key_TotalZ0	.8.8	KeyDBox,Key_TotalZ1	.8.8	KeyDBox,Key_TotalZ2	.8.8	KeyDBox,Key_TotalZ3	.8.8	KeyDBox,Key_TotalZ4	.8.8	KeyDBox,Key_TotalZ5	.8.8	KeyDBox,Key_TotalZ6	.8.8	KeyDBox,Key_TotalZ7	.8.8	KeyDBox,Key_TotalZ8	.8.8	KeyDBox,Key_TotalZ9	.16	0	.16	AfTotal-TRoutZ	.8.8	KeyDBox,Key_OffZ0	.8.8	KeyDBox,Key_OffZ1	.8.8	KeyDBox,Key_OffZ2	.8.8	KeyDBox,Key_OffZ3	.8.8	KeyDBox,Key_OffZ4	.8.8	KeyDBox,Key_OffZ5	.8.8	KeyDBox,Key_OffZ6	.8.8	KeyDBox,Key_OffZ7	.8.8	KeyDBox,Key_OffZ8	.8.8	KeyDBox,Key_OffZ9	.16	0	.16	AfOff-TRoutZ	.8.8	KeyDBox,Key_CirclZ0	.8.8	KeyDBox,Key_CirclZ1	.8.8	KeyDBox,Key_CirclZ2	.8.8	KeyDBox,Key_CirclZ3	.8.8	KeyDBox,Key_CirclZ4	.8.8	KeyDBox,Key_CirclZ5	.8.8	KeyDBox,Key_CirclZ6	.8.8	KeyDBox,Key_CirclZ7	.8.8	KeyDBox,Key_CirclZ8	.8.8	KeyDBox,Key_CirclZ9	.16	0	.16	CopAd-TRoutZ	.16	F1,F2,F3,CR,0,TRoutzOk-TRoutZ	.16	F13,F14,F15,End,0,TRoutzko-TRoutZ	.16	0; Bote de dialogue pour le choix de la mmoire  visualiserKey_BaseZ0	=	16'00Key_Base2Z0	=	16'01Key_DeplZ0	=	16'02Key_TotalZ0	=	16'03Key_OffZ0	=	16'04Key_CirclZ0	=	16'05Key_BaseZ1	=	16'10Key_Base2Z1	=	16'11Key_DeplZ1	=	16'12Key_TotalZ1	=	16'13Key_OffZ1	=	16'14Key_CirclZ1	=	16'15Key_BaseZ2	=	16'20Key_Base2Z2	=	16'21Key_DeplZ2	=	16'22Key_TotalZ2	=	16'23Key_OffZ2	=	16'24Key_CirclZ2	=	16'25Key_BaseZ3	=	16'30Key_Base2Z3	=	16'31Key_DeplZ3	=	16'32Key_TotalZ3	=	16'33Key_OffZ3	=	16'34Key_CirclZ3	=	16'35Key_BaseZ4	=	16'40Key_Base2Z4	=	16'41Key_DeplZ4	=	16'42Key_TotalZ4	=	16'43Key_OffZ4	=	16'44Key_CirclZ4	=	16'45Key_BaseZ5	=	16'50Key_Base2Z5	=	16'51Key_DeplZ5	=	16'52Key_TotalZ5	=	16'53Key_OffZ5	=	16'54Key_CirclZ5	=	16'55Key_BaseZ6	=	16'60Key_Base2Z6	=	16'61Key_DeplZ6	=	16'62Key_TotalZ6	=	16'63Key_OffZ6	=	16'64Key_CirclZ6	=	16'65Key_BaseZ7	=	16'70Key_Base2Z7	=	16'71Key_DeplZ7	=	16'72Key_TotalZ7	=	16'73Key_OffZ7	=	16'74Key_CirclZ7	=	16'75Key_BaseZ8	=	16'80Key_Base2Z8	=	16'81Key_DeplZ8	=	16'82Key_TotalZ8	=	16'83Key_OffZ8	=	16'84Key_CirclZ8	=	16'85Key_BaseZ9	=	16'90Key_Base2Z9	=	16'91Key_DeplZ9	=	16'92Key_TotalZ9	=	16'93Key_OffZ9	=	16'94Key_CirclZ9	=	16'95TDBoxMem:	.16	DBOX$-TDBoxMem	.16	MENU$-TDBoxMem	.16	0,0DBOX$:; Z0	.8	ODBTABX,16'02	.8	ODBLCIRCLE,16'00.OR.2**BDBOKEY,KeyDBox,Key_CirclZ0	.ASCIZ	" Zone 0  "	.8	ODBLABEL,Key_BaseZ0	.8	ODBBOX	.8.8.8	KeyDBox,Key_BaseZ0,TDBNORM	.ASCIZ	"        "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_Base2Z0	.8	ODBBOX	.8.8.8	KeyDBox,Key_Base2Z0,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_DeplZ0	.8	ODBBOX	.8.8.8	KeyDBox,Key_DeplZ0,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" = "	.8	ODBLABEL,Key_TotalZ0	.8	ODBBOX	.8.8.8	KeyDBox,Key_TotalZ0,TDBNORM	.ASCIZ	"          "	.8	ODBTABX,75	.8	ODBLABEL,Key_OffZ0	.8	ODBBOX	.8.8.8	KeyDBox,Key_OffZ0,TDBNORM	.ASCIZ	"          "	.8	ODBCR,ODBCR; Z1	.8	ODBTABX,16'02	.8	ODBLCIRCLE,16'01.OR.2**BDBOKEY,KeyDBox,Key_CirclZ1	.ASCIZ	" Zone 1  "	.8	ODBLABEL,Key_BaseZ1	.8	ODBBOX	.8.8.8	KeyDBox,Key_BaseZ1,TDBNORM	.ASCIZ	"        "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_Base2Z1	.8	ODBBOX	.8.8.8	KeyDBox,Key_Base2Z1,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_DeplZ1	.8	ODBBOX	.8.8.8	KeyDBox,Key_DeplZ1,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" = "	.8	ODBLABEL,Key_TotalZ1	.8	ODBBOX	.8.8.8	KeyDBox,Key_TotalZ1,TDBNORM	.ASCIZ	"          "	.8	ODBTABX,75	.8	ODBLABEL,Key_OffZ1	.8	ODBBOX	.8.8.8	KeyDBox,Key_OffZ1,TDBNORM	.ASCIZ	"          "	.8	ODBCR,ODBCR; Z2	.8	ODBTABX,16'02	.8	ODBLCIRCLE,16'02.OR.2**BDBOKEY,KeyDBox,Key_CirclZ2	.ASCIZ	" Zone 2  "	.8	ODBLABEL,Key_BaseZ2	.8	ODBBOX	.8.8.8	KeyDBox,Key_BaseZ2,TDBNORM	.ASCIZ	"        "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_Base2Z2	.8	ODBBOX	.8.8.8	KeyDBox,Key_Base2Z2,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_DeplZ2	.8	ODBBOX	.8.8.8	KeyDBox,Key_DeplZ2,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" = "	.8	ODBLABEL,Key_TotalZ2	.8	ODBBOX	.8.8.8	KeyDBox,Key_TotalZ2,TDBNORM	.ASCIZ	"          "	.8	ODBTABX,75	.8	ODBLABEL,Key_OffZ2	.8	ODBBOX	.8.8.8	KeyDBox,Key_OffZ2,TDBNORM	.ASCIZ	"          "	.8	ODBCR,ODBCR; Z3	.8	ODBTABX,16'02	.8	ODBLCIRCLE,16'03.OR.2**BDBOKEY,KeyDBox,Key_CirclZ3	.ASCIZ	" Zone 3  "	.8	ODBLABEL,Key_BaseZ3	.8	ODBBOX	.8.8.8	KeyDBox,Key_BaseZ3,TDBNORM	.ASCIZ	"        "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_Base2Z3	.8	ODBBOX	.8.8.8	KeyDBox,Key_Base2Z3,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_DeplZ3	.8	ODBBOX	.8.8.8	KeyDBox,Key_DeplZ3,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" = "	.8	ODBLABEL,Key_TotalZ3	.8	ODBBOX	.8.8.8	KeyDBox,Key_TotalZ3,TDBNORM	.ASCIZ	"          "	.8	ODBTABX,75	.8	ODBLABEL,Key_OffZ3	.8	ODBBOX	.8.8.8	KeyDBox,Key_OffZ3,TDBNORM	.ASCIZ	"          "	.8	ODBCR,ODBCR; Z4	.8	ODBTABX,16'02	.8	ODBLCIRCLE,16'04.OR.2**BDBOKEY,KeyDBox,Key_CirclZ4	.ASCIZ	" Zone 4  "	.8	ODBLABEL,Key_BaseZ4	.8	ODBBOX	.8.8.8	KeyDBox,Key_BaseZ4,TDBNORM	.ASCIZ	"        "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_Base2Z4	.8	ODBBOX	.8.8.8	KeyDBox,Key_Base2Z4,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_DeplZ4	.8	ODBBOX	.8.8.8	KeyDBox,Key_DeplZ4,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" = "	.8	ODBLABEL,Key_TotalZ4	.8	ODBBOX	.8.8.8	KeyDBox,Key_TotalZ4,TDBNORM	.ASCIZ	"          "	.8	ODBTABX,75	.8	ODBLABEL,Key_OffZ4	.8	ODBBOX	.8.8.8	KeyDBox,Key_OffZ4,TDBNORM	.ASCIZ	"          "	.8	ODBCR,ODBCR; Z5	.8	ODBTABX,16'02	.8	ODBLCIRCLE,16'05.OR.2**BDBOKEY,KeyDBox,Key_CirclZ5	.ASCIZ	" Zone 5  "	.8	ODBLABEL,Key_BaseZ5	.8	ODBBOX	.8.8.8	KeyDBox,Key_BaseZ5,TDBNORM	.ASCIZ	"        "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_Base2Z5	.8	ODBBOX	.8.8.8	KeyDBox,Key_Base2Z5,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_DeplZ5	.8	ODBBOX	.8.8.8	KeyDBox,Key_DeplZ5,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" = "	.8	ODBLABEL,Key_TotalZ5	.8	ODBBOX	.8.8.8	KeyDBox,Key_TotalZ5,TDBNORM	.ASCIZ	"          "	.8	ODBTABX,75	.8	ODBLABEL,Key_OffZ5	.8	ODBBOX	.8.8.8	KeyDBox,Key_OffZ5,TDBNORM	.ASCIZ	"          "	.8	ODBCR,ODBCR; Z6	.8	ODBTABX,16'02	.8	ODBLCIRCLE,16'06.OR.2**BDBOKEY,KeyDBox,Key_CirclZ6	.ASCIZ	" Zone 6  "	.8	ODBLABEL,Key_BaseZ6	.8	ODBBOX	.8.8.8	KeyDBox,Key_BaseZ6,TDBNORM	.ASCIZ	"        "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_Base2Z6	.8	ODBBOX	.8.8.8	KeyDBox,Key_Base2Z6,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_DeplZ6	.8	ODBBOX	.8.8.8	KeyDBox,Key_DeplZ6,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" = "	.8	ODBLABEL,Key_TotalZ6	.8	ODBBOX	.8.8.8	KeyDBox,Key_TotalZ6,TDBNORM	.ASCIZ	"          "	.8	ODBTABX,75	.8	ODBLABEL,Key_OffZ6	.8	ODBBOX	.8.8.8	KeyDBox,Key_OffZ6,TDBNORM	.ASCIZ	"          "	.8	ODBCR,ODBCR; Z7	.8	ODBTABX,16'02	.8	ODBLCIRCLE,16'07.OR.2**BDBOKEY,KeyDBox,Key_CirclZ7	.ASCIZ	" Zone 7  "	.8	ODBLABEL,Key_BaseZ7	.8	ODBBOX	.8.8.8	KeyDBox,Key_BaseZ7,TDBNORM	.ASCIZ	"        "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_Base2Z7	.8	ODBBOX	.8.8.8	KeyDBox,Key_Base2Z7,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_DeplZ7	.8	ODBBOX	.8.8.8	KeyDBox,Key_DeplZ7,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" = "	.8	ODBLABEL,Key_TotalZ7	.8	ODBBOX	.8.8.8	KeyDBox,Key_TotalZ7,TDBNORM	.ASCIZ	"          "	.8	ODBTABX,75	.8	ODBLABEL,Key_OffZ7	.8	ODBBOX	.8.8.8	KeyDBox,Key_OffZ7,TDBNORM	.ASCIZ	"          "	.8	ODBCR,ODBCR; Z8	.8	ODBTABX,16'02	.8	ODBLCIRCLE,16'08.OR.2**BDBOKEY,KeyDBox,Key_CirclZ8	.ASCIZ	" Zone 8  "	.8	ODBLABEL,Key_BaseZ8	.8	ODBBOX	.8.8.8	KeyDBox,Key_BaseZ8,TDBNORM	.ASCIZ	"        "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_Base2Z8	.8	ODBBOX	.8.8.8	KeyDBox,Key_Base2Z8,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_DeplZ8	.8	ODBBOX	.8.8.8	KeyDBox,Key_DeplZ8,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" = "	.8	ODBLABEL,Key_TotalZ8	.8	ODBBOX	.8.8.8	KeyDBox,Key_TotalZ8,TDBNORM	.ASCIZ	"          "	.8	ODBTABX,75	.8	ODBLABEL,Key_OffZ8	.8	ODBBOX	.8.8.8	KeyDBox,Key_OffZ8,TDBNORM	.ASCIZ	"          "	.8	ODBCR,ODBCR; Z9	.8	ODBTABX,16'02	.8	ODBLCIRCLE,16'09.OR.2**BDBOKEY,KeyDBox,Key_CirclZ9	.ASCIZ	" Zone 9  "	.8	ODBLABEL,Key_BaseZ9	.8	ODBBOX	.8.8.8	KeyDBox,Key_BaseZ9,TDBNORM	.ASCIZ	"        "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_Base2Z9	.8	ODBBOX	.8.8.8	KeyDBox,Key_Base2Z9,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" + "	.8	ODBLABEL,Key_DeplZ9	.8	ODBBOX	.8.8.8	KeyDBox,Key_DeplZ9,TDBNORM	.ASCIZ	"          "	.8	ODBTEXT	.ASCIZ	" = "	.8	ODBLABEL,Key_TotalZ9	.8	ODBBOX	.8.8.8	KeyDBox,Key_TotalZ9,TDBNORM	.ASCIZ	"          "	.8	ODBTABX,75	.8	ODBLABEL,Key_OffZ9	.8	ODBBOX	.8.8.8	KeyDBox,Key_OffZ9,TDBNORM	.ASCIZ	"          "	.8	ODBCR,ODBCR	.8	ODBTABX,16'12	.8	ODBBOX	.8.8.8	0,F1,TDBMEV	.ASCIZ	"   D'ACCORD   "	.8	ODBTABX,16'30;	.8	ODBBOX;	.8.8.8	0,F13,TDBNORM;	.ASCIZ	"   ANNULE   "	.8	0	.EVENMENU$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"     D'accord    "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.asciz	"";	.ASCIZ	"     Annule      "	.EVENTRoutzOk:	pushm.32	d0|d6|a0|a1	move.16		{a6}+oNumChoixMem,d6	mul.16		#LgDescZM,d6		; offset	add.32		#oDescMemZ,d6		; ne pas oublier l'offset de base !!	move.32		#{a6}+oDescMemB,A0	; descripteur de base	move.32		#{a6}+32^{d6},A1	move.32		{a1}+oDeb_Aff,d1	; offset choisit -> d1	move.16		#LgDescZM/2-1,d0l$:	move.16		{A1+},{A0+}		; Copie le descripteur choisit dans le descr de base	dj.16,nmo	d0,l$		move.16		#end,d2	popm.32		d0|d6|a0|a1	retTRoutzko:	move.16		#end,d2	retCopAd:	pushm.32	d6	move.8		d3,d6	and.32		#16'F0,d6	sr.32		#4,d6			; numro de zone	move.16		d6,{a6}+oNumChoixMem	popm.32		d6	ret; Dfinitions;************;-------\\; ShowDef >;========/;; Dfinitions gnrales; ; In	; Out	; Mod	ShowDef:	pushm.32	a0..a4|d0..d6	lib		?PushMenu		; D5.32 <- canal	push.32		d5	MOVE.32		#R16^TDBoxDef,A2	; Description DBOX Mem	Move.16		#2**BDBSAV,D2			MOVE.32		{a6}+oCalculAdBase,D4	DBOX_		OPEN	move.32		#-1,d3	dbox_		MEDITl$:	MOVE.32		{a6}+oCalculAdBase,D4	dbox_		Edit	MOVE.32		d4,{a6}+oCalculAdBase	move.32		#r16^TRoutD,A1	move.16		#0,d1	dbox_		CallC	comp.16		#end,d2	jump,ne		l$	dbox_		Close	call		Show_Mem	pop.32		d5	lib		?PopMenu	popm.32		a0..a4|d0..d6	retTRoutD:	.16	F1,F2,F3,CR,0,TRoutzDOk-TRoutD	.16	0TRoutzDOk:	move.16		#end,d2	retTDBoxDef:;	Bote de dialogue gnre par EDBOX.;	------------------------------------TDBOXDef:	.16	DBOX$-TDBOXDef	.16	MENU$-TDBOXDef	.16	0,0DBOX$:	.8	ODBTABX,16'01	.8	ODBTEXT	.ASCIZ	"Calcul de l'adresse mmoire de base:"	.8	ODBCR,ODBCR	.8	ODBTABX,16'01	.8	ODBSQUARE,16'00.OR.2**BDBOKEY	.16	0	.ASCIZ	"   Registre de base"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBSQUARE,16'01.OR.2**BDBOKEY	.16	1	.ASCIZ	" + Registre d'Index"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBSQUARE,16'02.OR.2**BDBOKEY	.16	2	.ASCIZ	" + Dplacement"	.8	ODBCR,ODBCR,ODBCR	.8	ODBTABX,16'08	.8	ODBBOX	.16.8	CR,TDBMEV	.ASCIZ	"   D'ACCORD   "	.8	0	.EVENMENU$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN;****************************************;ROUTINES INTERNES DU MODULE MEMOIRE;****************************************;-------------\\; AFFICHE_TOTAL >;==============/;;cette routine affiche l'adresse total qui correspond au pointeur de base du contenu de la mmoire	;IN:	D5.32			Label de la zone	;	D6.32			offset de descripteur de zone	;	{A6}+32^{D6}+oBase	;	{A6}+32^{d6}+oBase2	;	{A6}+32^{d6}+oDepl	;OUT:	-	;MOD:	D7.16AfTotal:AFFICHE_TOTAL:	PUSHM.32	D2..D4|A0	lib	?aftim	.ascize	"<NOCURS>"	MOVE.16		D5,D2	and.16		#16'FFF0,d2	add.16		#Key_TotalZ0,d2			; offset label total	CALL		SET_CURS	JUMP,NE		FIN$	move.32		#{a6},A0	MOVE.32		{A0}+32^{d6}+oBase,D4	MOVE.32		{A6}+32^{d6}+oBase2,D3	comp.8		#FlA16,{a6}+32^{d6}+OFlagBase2	jump,ne		s$	CONV.A16.32	D3		; D3.16 -> sign Ext -> .32s$:	add.32		d3,d4	ADD.32		{A6}+32^{d6}+oDepl,D4	LIB		?AFX8			; adresse mmoire totale 	comp.32		{A6}+32^{d6}+oAdMem,d4	; total prcdent	jump,eq		Fin$			; pas de raffichage	MOVE.32		D4,{A6}+32^{d6}+oAdMem	move.32		{a6}+C_WIN_DBOXP,D2	comp.32		{a6}+C_WIN_DBOX,D2	jump,ne		fin$			; affiche sur dbox principale seulement	call		Show_mem		; RB: affiche la mmoire directementFIN$:	POPM.32		D2..D4|A0	TEST.16		D7	RET.if	0;-------------\\; AF_MEMOIRESUB >;==============/;; ; ; In	; Out	; Mod	AF_MEMOIRESUB:;cette routine affiche le contenu de la mmoire	;IN:	A1.32 buffer de la mmoire	;OUT:	A2.32 adresse de base	;MOD:	A1.32, A2.32, D7.16	PUSHM.32	D0..D6	MOVE.32	{A1}+(4*NBREG)-4,D5	MOVE.32	#NBREG-5,D6	MOVE.16	#KEY_AD0,D2A$:	CALL	SET_CURS	JUMP,NE	FIN$	MOVE.32	A2,D4	LIB	?AFX8			; Affiche adresse	INC.16	D2	CALL	SET_CURS	JUMP,NE	FIN$	TEST.32	D5:D6	JUMP,BS	X$	DEC.32	D6	TEST.32	D5:D6	JUMP,BC	CC$	JUMP	Y$X$:	DEC.32	D6Y$:	LIB	?AFTIM	.ASCIZE	"  ILLEGAL     ILLEGAL  "	INC.32	D2	JUMP	CON$CC$:	CLR.16	D1	MOVE.16	#SPACE,D3	MOVE.16	#8-1,D0	JUMP	B$C$:	LIB	?AFCARB$:	MOVE.8	{A1}+A16^{D1},D4	LIB	?AFX2	INC.16	D1	DJ.16,NMO	D0,C$D$:	INC.16	D2	CALL	SET_CURS	JUMP,NE	FIN$	CLR.16	D1	MOVE.16	#7,D0E$:	MOVE.8	{A1}+A16^{D1},D3	LIB	?AFCODE	INC.16	D1	DJ.16,NMO	D0,E$CON$:	DEC.32	D6	ADD.32	#8,A1	ADD.32	#8,A2	INC.16	D2	COMP.16	#KEY_AD10+3,D2	JUMP,NE	A$FIN$:	POPM.32		D0..D6	TEST.16	D7	RET.else;-------------\\; AF_MEMOIRESUB >;==============/;; ; ; In	; Out	; Mod	AF_MEMOIRESUB:;cette routine affiche le contenu de la mmoire	;IN:	A1.32 buffer de la mmoire	;OUT:	A2.32 adresse de base	;MOD:	A1.32, A2.32, D7.16	PUSHM.32	D0..D6	MOVE.32	{A1}+(4*NBREG)-4,D5	MOVE.32	#NBREG-5,D6	lib	?aftim	.ascize	"<afdir>"	MOVE.16	#KEY_AD0,D2A$:	CALL	SET_CURS		; Adresse	JUMP,NE	FIN$	MOVE.32	A2,D4	LIB	?AFX8			; Affiche adresse	INC.16	D2	CALL	SET_CURS		; Mmoire Hexa	JUMP,NE	FIN$	CLR.16	D1	MOVE.16	#SPACE,D3	MOVE.16	#8-1,D0			; 8 octets par ligne	JUMP	B$C$:	LIB	?AFCARB$:	MOVE.8	{A1}+A16^{D1},D4	comp.8	#"?",D4	jump,ne	s0$	lib	?aftim	.ascize	"<afinv>??<afdir>"	; adresse invalide	jump	s1$s0$:	LIB	?AFX2s1$:	INC.16	D1	DJ.16,NMO	D0,C$D$:	INC.16	D2	CALL	SET_CURS		; Mmoire ASCII	JUMP,NE	FIN$	CLR.16	D1	MOVE.16	#8-1,D0E$:	MOVE.8	{A1}+A16^{D1},D3	LIB	?AFCODE	INC.16	D1	DJ.16,NMO	D0,E$CON$:	DEC.32	D6	ADD.32	#8,A1	ADD.32	#8,A2	INC.16	D2	COMP.16	#KEY_AD10+3,D2	JUMP,NE	A$FIN$:	POPM.32		D0..D6	TEST.16	D7	RET.endif;****************************************;ROUTINES UTILISABLES DU MODULE MEMOIRE;****************************************;----------\\; AF_MEMOIRE >;===========/;; ; ; In	; Out	; Mod	;cette routine affiche le contenu de la mmoire	;IN:	{A6}+oDescMemB+oDeb_Aff	;	{A6}+BOUTON	;	{A6}+oDescMemB+oBase	;	{A6}+MESSAGEIn+oMessage	;OUT:	-	;MOD:	D7.16AF_MEMOIRE:	PUSHM.32	A1|A2|D4	MOVE.32	{A6}+oDescMemB+oAdMem,A2	add.32	{A6}+oDescMemB+oDeb_Aff,A2		; +offset	MOVE.32	{A6}+BOUTON,D4	TEST.32	D4:#BIT_ABSOLU	JUMP,BS	A$; Relatif	move.32	{a6}+oCalculAdBase,d4	test.32	d4:#bRegBase	jump,bc	s0$	SUB.32	{A6}+oDescMemB+oBase,A2s0$:	test.32	d4:#bRegIndex	jump,bc	s1$	SUB.32	{A6}+oDescMemB+oBase2,A2s1$:	test.32	d4:#bDeplacement	jump,bc	s2$	SUB.32	{A6}+oDescMemB+oDepl,A2s2$:A$:	MOVE.32	#{A6}+MESSAGEIn+oMessage,A1	CALL	AF_MEMOIRESUB	JUMP,EQ	FIN$	CALL	AFERRORFIN$:	POPM.32		A1|A2|D4	TEST.16	D7	RET;--------\\; SHOW_MEM >;=========/;; cette routine fournit  CIBLE.CODE l'adresse de base des 22 quadlets de mmoire  fournir  HOTE.CODE;;IN:	{A6}+oDescMemB+oAdMem;OUT:	{A6}+oDescMemB+oDeb_Aff;MOD:	{A6}+oDescMemB+oDeb_Aff, {A6}+MESSAGEOut+oMessage, D7.16Show_Mem:	PUSH.32	D0	MOVE.32	{A6}+oDescMemB+oAdMem,D0;;	TCLR.32	D0:#0			;adresse paire	add.32	{A6}+oDescMemB+oDeb_Aff,D0			; + offset	MOVE.32	D0,{A6}+MESSAGEOut+oMessage	MOVE.16	#HOTE_MEM,D0	CALL	TO_CIBLE	JUMP,EQ	FIN$	CALL	AFERRORFIN$:	POP.32	D0	CLR.16	D7	RET;-------------\\; Show_MEM_Off0 >;==============/;; Met l'offset de visualisation  0 et affiche la mmoire; ; In	; Out	; Mod	Show_MEM_Off0:	move.32	#0,{A6}+oDescMemB+oDeb_Aff			; offset 0	call	Show_Mem	TEST.16	D7	RET;--------\\; DEC_MEM  >;=========/;;cette routine dcrmente l'affichage de la mmoire de 1	;IN:	{A6}+oDescMemB+oDeb_Aff	;	{A6}+MESSAGEOut+oMessage	;OUT:	-	;MOD:	{A6}+oDescMemB+oDeb_Aff, D7.16DEC_MEM:	SUB.32	#1,{A6}+oDescMemB+oDeb_Aff	call	Show_Mem	TEST.16	D7	RET;--------\\; INC_MEM  >;=========/;;cette routine incrmente l'affichage de la mmoire de 1	;IN:	{A6}+oDescMemB+oDeb_Aff	;	{A6}+MESSAGEOut+oMessage	;OUT:	-	;MOD:	{A6}+oDescMemB+oDeb_Aff, D7.16INC_MEM:	ADD.32	#1,{A6}+oDescMemB+oDeb_Aff	call	Show_Mem	TEST.16	D7	RET;--------\\; DEC_MEM1 >;=========/;;cette routine dcrmente l'affichage de la mmoire de 1 ligne (8 octets)	;IN:	{A6}+oDescMemB+oDeb_Aff	;	{A6}+MESSAGEOut+oMessage	;OUT:	-	;MOD:	{A6}+oDescMemB+oDeb_Aff, D7.16DEC_MEM1:	SUB.32	#1*8,{A6}+oDescMemB+oDeb_Aff	call	Show_Mem	TEST.16	D7	RET;--------\\; INC_MEM1 >;=========/;;cette routine incrmente l'affichage de la mmoire de 1	;IN:	{A6}+oDescMemB+oDeb_Aff	;	{A6}+MESSAGEOut+oMessage	;OUT:	-	;MOD:	{A6}+oDescMemB+oDeb_Aff, D7.16INC_MEM1:	ADD.32	#1*8,{A6}+oDescMemB+oDeb_Aff	call	Show_Mem	TEST.16	D7	RET;--------\\; DEC_MEM2 >;=========/;;cette routine dcrmente l'affichage de la mmoire de 2	;IN:	{A6}+oDescMemB+oDeb_Aff	;	{A6}+MESSAGEOut+oMessage	;OUT:	-	;MOD:	{A6}+oDescMemB+oDeb_Aff, D7.16DEC_MEM2:	SUB.32	#2*8,{A6}+oDescMemB+oDeb_Aff	call	Show_Mem	TEST.16	D7	RET;--------\\; INC_MEM2 >;=========/;;cette routine incrmente l'affichage de la mmoire de 2	;IN:	{A6}+oDescMemB+oDeb_Aff	;	{A6}+MESSAGEOut+oMessage	;OUT:	-	;MOD:	{A6}+oDescMemB+oDeb_Aff, D7.16INC_MEM2:	ADD.32	#2*8,{A6}+oDescMemB+oDeb_Aff	call	Show_Mem	TEST.16	D7	RET;--------\\; DEC_MEM4 >;=========/;;cette routine dcrmente l'affichage de la mmoire de 4	;IN:	{A6}+oDescMemB+oDeb_Aff	;	{A6}+MESSAGEOut+oMessage	;OUT:	-	;MOD:	{A6}+oDescMemB+oDeb_Aff, D7.16DEC_MEM4:	SUB.32	#4*8,{A6}+oDescMemB+oDeb_Aff	call	Show_Mem	TEST.16	D7	RET;--------\\; INC_MEM4 >;=========/;;cette routine incrmente l'affichage de la mmoire de 4	;IN:	{A6}+oDescMemB+oDeb_Aff	;	{A6}+MESSAGEOut+oMessage	;OUT:	-	;MOD:	{A6}+oDescMemB+oDeb_Aff, D7.16INC_MEM4:	ADD.32	#4*8,{A6}+oDescMemB+oDeb_Aff	call	Show_Mem	TEST.16	D7	RET;--------\\; DEC_MEM8 >;=========/;;cette routine dcrmente l'affichage de la mmoire de 8	;IN:	{A6}+oDescMemB+oDeb_Aff	;	{A6}+MESSAGEOut+oMessage	;OUT:	-	;MOD:	{A6}+oDescMemB+oDeb_Aff, D7.16DEC_MEM8:	SUB.32	#8*8,{A6}+oDescMemB+oDeb_Aff	call	Show_Mem	TEST.16	D7	RET;--------\\; INC_MEM8 >;=========/;;cette routine incrmente l'affichage de la mmoire de 8	;IN:	{A6}+oDescMemB+oDeb_Aff	;	{A6}+MESSAGEOut+oMessage	;OUT:	-	;MOD:	{A6}+oDescMemB+oDeb_Aff, D7.16INC_MEM8:	ADD.32	#8*8,{A6}+oDescMemB+oDeb_Aff	call	Show_Mem	TEST.16	D7	RET;-------------\\; BOUTON_ABSOLU >;==============/;;action lorsqu'on clique sur le bouton abs	;IN:	{A6}+BOUTON	;OUT:	-	;MOD:	{A6}+BOUTON, D7.16BOUTON_ABSOLU:	PUSH.32	D4	MOVE.32	{A6}+BOUTON,D4 	TCLR.32	D4:#BIT_RELATIF	TSET.32	D4:#BIT_ABSOLU	MOVE.32	D4,{A6}+BOUTON	call	Show_Mem			; RB: affiche la mmoire directement	POP.32	D4	CLR.16	D7	RET;--------------\\; BOUTON_RELATIF >;===============/;;action lorsqu'on clique sur le bouton rel	;IN:	{A6}+BOUTON	;OUT:	-	;MOD:	{A6}+BOUTON, D7.16BOUTON_RELATIF:	PUSH.32	D4	MOVE.32	{A6}+BOUTON,D4 	TSET.32	D4:#BIT_RELATIF	TCLR.32	D4:#BIT_ABSOLU	MOVE.32	D4,{A6}+BOUTON	call	Show_Mem			; RB: affiche la mmoire directement	POP.32	D4	CLR.16	D7	RET;-----------\\; TOUCHE_BASE >;============/;;action lorsqu'on clique sur base, la routine fournit le contenu de base qui est le contenu d'un registre	;IN:	{A6}+BUFFER_REG	;	{A6}+oDescMemB+oBase	;OUT:	-	;MOD:	{A6}+oDescMemB+oBase, {A6}+oDescMemB+oRegBase, D7.16TOUCHE_BASE:	pushm.32	d5|d6	move.32		#0,{a6}+oDescMemB+oDeb_Aff	move.32		#oDescMemB,D6	MOVE.16		#KEY_BASE,D5	call		AfBase	popm.32		d5|d6	ret;------\\; AfBase >;=======/;; Affiche un registre de base; ; In	D5.16	Key_Basexx;	D6.32	Offset descripteur de zone; Out	; Mod	AfBase:	PUSHM.32	A0|A1|A3|D2..D4	MOVE.32		#{A6}+BUFFER_REG,A0	CLR.16	D7	MOVE.16		{a6}+32^{D6}+OSelBase,D3	;affiche le menu	test.8		{a6}+OMMENU?	jump,ne		s$			; ne propose pas le menu	MOVE.32		#R16^TMMENU,A3	LIB		?MMENU	JUMP,NE		ERR_TB$	MOVE.16		d3,{a6}+32^{d6}+OSelBases$:	TEST.16		D3			;en fonction de la touche slectionne cherche sa valeur	JUMP,EQ		FIN$	COMP.16		#1,D3	JUMP,NE		A$	MOVE.32		#0,D4			; valeur 0	JUMP		C$A$:	COMP.16		#14,D3	JUMP,NE		B$	MOVE.32		{A0}+4*KEY_PC,D4	SUB.32		{A0}+4*KEY_PCREL,D4	; dbut programme	JUMP		C$B$:	MOVE.32		#R16^CONVERSION,A1	CLR.16		D2	MOVE.8		{A1}+A16^{D3},D2	MOVE.32		{A0}+A16^{D2},D4	move.16		d2,{a6}+32^{d6}+oRegBase	; Registre de base	C$:	MOVE.32		D4,{A6}+32^{d6}+oBase		; valeur du registre	MOVE.16		d5,D2	CALL		SET_CURS;	JUMP,NE	ERR_TB$;	LIB	?AFX8	call		AfTxtRegBase	CALL		AFFICHE_TOTAL			;affiche le total	JUMP,NE		ERR_TB$FIN$:;	call		Show_Mem			; RB: affiche la mmoire directement	POPM.32		A0|A1|A3|D2..D4	TEST.16		D7	RETERR_TB$:				;affiche les erreurs	CALL		AFERROR	JUMP		FIN$;------------\\; AfTxtRegBase >;=============/;; Affiche texte du registre de base slectionn; ; In	D3.16	no registre selon MMENU; Out	; Mod	AfTxtRegBase:	move.32	#r16^PntTxt,A1	sl.16	d3			; *2	move.16	{a1}+A16^{d3},d2	; offset du texte	move.32	#{A1}+A16^{d2},a3	lib	?aftext	retTMMENU:TXT_SP:		.ASCIZ		" "			; 0		.8		-1TXT_0:		.ASCIZ		"    0   "		; 1		.8		-1TXT_A0:		.ASCIZ		"  {A0}  "		; 2TXT_A1:		.ASCIZ		"  {A1}  "		; 3TXT_A2:		.ASCIZ		"  {A2}  "		; 4TXT_A3:		.ASCIZ		"  {A3}  "		; 5TXT_A4:		.ASCIZ		"  {A4}  "		; 6TXT_A5:		.ASCIZ		"  {A5}  "		; 7TXT_A6:		.ASCIZ		"  {A6}  "		; 8		.8		-1TXT_USP:	.ASCIZ		"  {USP} "		; 9TXT_ISP:	.ASCIZ		"  {ISP} "		; 10TXT_MSP:	.ASCIZ		"  {MSP} "		; 11TXT_VBR:	.ASCIZ		"  {VBR} "		; 12		.8		-1TXT_PCB:	.ASCIZ		"  {PCB} "		; @AD ajout PCB ; 13TXT_PC:		.ASCIZ		"  {PC}  "		; 14		.ASCIZ		"programme"		; 15		.8		0		.EVENTXT_PROGRAMME:	.ASCIZ		"program"PNTTXT:	.16	TXT_SP-pnttxt	.16	TXT_0-pnttxt	.16	TXT_A0-pnttxt	.16	TXT_A1-pnttxt	.16	TXT_A2-pnttxt	.16	TXT_A3-pnttxt	.16	TXT_A4-pnttxt	.16	TXT_A5-pnttxt	.16	TXT_A6-pnttxt	.16	TXT_USP-pnttxt	.16	TXT_ISP-pnttxt	.16	TXT_MSP-pnttxt	.16	TXT_VBR-pnttxt	.16	TXT_PCB-pnttxt				; @AD ajout PCB	.16	TXT_PC-pnttxt	.16	TXT_PROGRAMME-pnttxtCONVERSION:		.8		16'FF		.8		16'FF		.8		4*KEY_A0		.8		4*KEY_A1		.8		4*KEY_A2		.8		4*KEY_A3		.8		4*KEY_A4		.8		4*KEY_A5		.8		4*KEY_A6		.8		4*KEY_A7		.8		4*KEY_ISP		.8		4*KEY_MSP		.8		4*KEY_VBR		.8		4*KEY_PCB		; @AD ajout PCB		.8		4*KEY_PC		.8		16'FF		.EVEN;------------\\; TOUCHE_BASE2 >;=============/;;action lorsqu'on clique sur base, la routine fournit le contenu de base qui est le contenu d'un registre	;IN:	{A6}+BUFFER_REG	;	{A6}+oDescMemB+oBase2	;OUT:	-	;MOD:	{A6}+oDescMemB+oBase2, {A6}+oDescMemB+oRegBase2, {A6}+oDescMemB+OFlagBase2, D7.16TOUCHE_BASE2:	pushm.32	d5|d6	move.32		#0,{a6}+oDescMemB+oDeb_Aff	move.32		#oDescMemB,D6	MOVE.16		#KEY_BASE2,D5	call		AfBase2	popm.32		d5|d6	ret;-------\\; AfBase2 >;========/;; ; ; In	D5.16	Key_Basexx;	D6.32	Offset descripteur de zone; Out	; Mod	AfBase2:	PUSHM.32	A0..A4|D2..D4	MOVE.32		#{A6}+BUFFER_REG,A0	CLR.16		D7	MOVE.32		#R16^TMMENUS,A3	move.32		#{a6}+32^{d6}+OMMenuBase2,a4	test.8		{a6}+OMMENU?	jump,ne		s$			; ne propose pas le menu	pushm.32	d5	move.32		#0,d5	LIB		?MMENUS	popm.32		d5	JUMP,NE		ERR_TB$s$:	COMP.16		#0,{A4}+LMM*0+OMMSEL	; cas vide slectionne ?	JUMP,EQ		FIN$	COMP.16		#1,{A4}+LMM*0+OMMSEL	; 0 slectionn ?	JUMP,NE		A$	MOVE.32		#0,{A6}+32^{d6}+oBase2		; valeur 0A$:	MOVE.16		d5,D2			; Key_Base2xx	CALL		SET_CURS	move.32		#r16^PntTxt20,A1	move.16		{a4}+LMM*0+OMMSEL,d3	sl.16		d3			; *2	move.16		{a1}+A16^{d3},d2	; offset du texte	move.32		#{A1}+A16^{d2},a3	lib		?aftext			; 0, A16^, 32^	comp.16		#2,{a4}+LMM*0+OMMSEL	jump,ne		s32$	move.32		#r16^PntTxt21,A1	; A16^	move.16		{a4}+LMM*1+OMMSEL,d3	move.8		#FlA16,{a6}+32^{d6}+OFlagBase2	jump		sa$s32$:	comp.16		#3,{a4}+LMM*0+OMMSEL	jump,ne		saf$	move.32		#r16^PntTxt22,A1	; 32^	move.16		{a4}+LMM*1+OMMSEL,d3	; *1 car on pointe sur mme sous-menu !!	move.8		#Fl32,{a6}+32^{d6}+OFlagBase2sa$:	MOVE.32		#R16^CONVERSIONS,A2	CLR.16		D2	MOVE.8		{A2}+A16^{D3},D2	MOVE.32		{A0}+A16^{D2},D4	move.16		d2,{a6}+32^{d6}+oRegBase2	; Registre de base		MOVE.32		D4,{A6}+32^{d6}+oBase2	sl.16		d3			; *2	move.16		{a1}+A16^{d3},d2	; offset du texte	move.32		#{A1}+A16^{d2},a3	lib		?aftextsaf$:	CALL		AFFICHE_TOTAL		;affiche le total	JUMP,NE		ERR_TB$FIN$:;	call		Show_Mem			; RB: affiche la mmoire directement	POPM.32		A0..A4|D2..D4	TEST.16		D7	RETERR_TB$:				;affiche les erreurs	CALL		AFERROR	JUMP		FIN$TMMENUS:	.ASCIZ	"      "		.8	-1		.ASCIZ	"  0  "		.8	-1		.8.16	-2,TMMENUA16-TMMENUS		.ASCIZ	" A16^"		.8.16	-2,TMMENU32-TMMENUS		.ASCIZ	"  32^"		.8	0TMMENUA16:TMMENU32:		.ASCIZ		" {A0} "		.ASCIZ		" {A1} "		.ASCIZ		" {A2} "		.ASCIZ		" {A3} "		.ASCIZ		" {A4} "		.ASCIZ		" {A5} "		.ASCIZ		" {A6} "		.8		-1		.ASCIZ		" {D0} "		.ASCIZ		" {D1} "		.ASCIZ		" {D2} "		.ASCIZ		" {D3} "		.ASCIZ		" {D4} "		.ASCIZ		" {D5} "		.ASCIZ		" {D6} "		.ASCIZ		" {D7} "		.8		0Txt_SP_:	.ASCIZ	"        "Txt_0_:		.ASCIZ	"   0    "TXT_A16:	.ASCIZ	"A16^"TXT_32:		.ASCIZ	" 32^"TXT_A0_:	.ASCIZ		"{A0}"TXT_A1_:	.ASCIZ		"{A1}"TXT_A2_:	.ASCIZ		"{A2}"TXT_A3_:	.ASCIZ		"{A3}"TXT_A4_:	.ASCIZ		"{A4}"TXT_A5_:	.ASCIZ		"{A5}"TXT_A6_:	.ASCIZ		"{A6}"TXT_D0:		.ASCIZ		"{D0}"TXT_D1:		.ASCIZ		"{D1}"TXT_D2:		.ASCIZ		"{D2}"TXT_D3:		.ASCIZ		"{D3}"TXT_D4:		.ASCIZ		"{D4}"TXT_D5:		.ASCIZ		"{D5}"TXT_D6:		.ASCIZ		"{D6}"TXT_D7:		.ASCIZ		"{D7}"		.8		0PntTxt20:	.16	Txt_SP_-PntTxt20	.16	Txt_0_-PntTxt20	.16	TXT_A16-PntTxt20	.16	TXT_32-PntTxt20PntTxt21:PntTxt22:	.16	TXT_A0_-PntTxt21	.16	TXT_A1_-PntTxt21	.16	TXT_A2_-PntTxt21	.16	TXT_A3_-PntTxt21	.16	TXT_A4_-PntTxt21	.16	TXT_A5_-PntTxt21	.16	TXT_A6_-PntTxt21	.16	TXT_D0-PntTxt21	.16	TXT_D1-PntTxt21	.16	TXT_D2-PntTxt21	.16	TXT_D3-PntTxt21	.16	TXT_D4-PntTxt21	.16	TXT_D5-PntTxt21	.16	TXT_D6-PntTxt21	.16	TXT_D7-PntTxt21CONVERSIONS:		.8		4*KEY_A0		.8		4*KEY_A1		.8		4*KEY_A2		.8		4*KEY_A3		.8		4*KEY_A4		.8		4*KEY_A5		.8		4*KEY_A6		.8		4*KEY_D0		.8		4*KEY_D1		.8		4*KEY_D2		.8		4*KEY_D3		.8		4*KEY_D4		.8		4*KEY_D5		.8		4*KEY_D6		.8		4*KEY_D7		.EVEN;------------------\\; TOUCHE_DEPLACEMENT >;===================/;;cette routine recherche la valeur du dplacement pour le calcul de l'adresse;elle s'excute lorsque l'on clique sur la touche dplacement	;IN:	{A6}+REGISTRE	;	{A6}+oDescMemB+oDepl	;OUT:	-	;MOD:	{A6}+oDescMemB+oDepl, D7.16TOUCHE_DEPLACEMENT:	pushm.32	d5|d6	move.32		#0,{a6}+oDescMemB+oDeb_Aff	move.32		#oDescMemB,D6	MOVE.16		#Key_Depl,D5	call		AfDepl	popm.32		d5|d6	ret;------\\; AfDepl >;=======/;; ; ; In	D5.16	Key_Basexx;	D6.32	Offset descripteur de zone; Out	; Mod	AfDepl:	PUSHM.32	A2..A5|D0..D4	MOVE.16		D5,D2	;place le curseur dans la fentre	CALL		SET_CURS	JUMP,NE		ERR_TD$	lib		?aftim	.ascize		"        "	MOVE.16		D5,D2	;place le curseur dans la fentre	CALL		SET_CURS	MOVE.32		{A6}+32^{D6}+oDepl,D1	;convertit l'hexa en ascii	test.8		{a6}+Ommenu?	jump,ne		S$			; juste afficher !	MOVE.32		#{A6}+REGISTRE,A3	MOVE.32		A3,A4	CALL		BIN_ASCII		; A4.32 ^dbut buffer, D1.32 nombre hexa	MOVE.32		#R16^KEYLST,A2		;dite la ligneA$:	MOVE.16		#LG_REGISTRE,D3	LIB		?EDIT	COMP.16		#KEYMGP,D3	JUMP,EQ		B$	COMP.16		#KEYMMP,D3	JUMP,EQ		B$	COMP.16		#KEYMDP,D3	JUMP,EQ		B$	COMP.16		#CR,D3	JUMP,NE		A$B$:	MOVE.32		A3,A5			;transforme l'ascii en hexa	CLR.32		D1C$:	MOVE.8		{A5+},D0	COMP.8		#CR,D0	JUMP,EQ		D$	CALL		ASCII_BIN	JUMP,NE		A$			;si pas possible attend une modification	JUMP		C$D$:	MOVE.16		D5,D2			;replace le curseur au dbut de la case	CALL		SET_CURS	MOVE.32		D1,{A6}+32^{d6}+oDepl	;et affiche le nouveau nombre comme confirmationS$:	MOVE.32		D1,D4	LIB		?AFX8	JUMP,NE		ERR_TD$	CALL		AFFICHE_TOTAL	JUMP,NE		ERR_TD$FIN$:;	call		Show_Mem			; RB: affiche la mmoire directement	POPM.32		A2..A5|D0..D4	TEST.16		D7	RETERR_TD$:	CALL		AFERROR	JUMP		FIN$;------\\; AfOff  >;=======/;; ; ; In	D5.16	Key_Basexx;	D6.32	Offset descripteur de zone; Out	; Mod	AfOff:	PUSHM.32	A2..A5|D0..D4	MOVE.16		D5,D2	;place le curseur dans la fentre	CALL		SET_CURS	JUMP,NE		ERR_TD$	lib		?aftim	.ascize		"        "	MOVE.16		D5,D2	;place le curseur dans la fentre	CALL		SET_CURS	MOVE.32		{A6}+32^{D6}+oDeb_Aff,D1	;convertit l'hexa en ascii	test.8		{a6}+Ommenu?	jump,ne		S$			; juste afficher !	MOVE.32		#{A6}+REGISTRE,A3	MOVE.32		A3,A4	CALL		BIN_ASCII		; A4.32 ^dbut buffer, D1.32 nombre hexa	MOVE.32		#R16^KEYLST,A2		;dite la ligneA$:	MOVE.16		#LG_REGISTRE,D3	LIB		?EDIT	COMP.16		#KEYMGP,D3	JUMP,EQ		B$	COMP.16		#KEYMMP,D3	JUMP,EQ		B$	COMP.16		#KEYMDP,D3	JUMP,EQ		B$	COMP.16		#CR,D3	JUMP,NE		A$B$:	MOVE.32		A3,A5			;transforme l'ascii en hexa	CLR.32		D1C$:	MOVE.8		{A5+},D0	COMP.8		#CR,D0	JUMP,EQ		D$	CALL		ASCII_BIN	JUMP,NE		A$			;si pas possible attend une modification	JUMP		C$D$:	MOVE.16		D5,D2			;replace le curseur au dbut de la case	CALL		SET_CURS	MOVE.32		D1,{A6}+32^{d6}+oDeb_Aff	;et affiche le nouveau nombre comme confirmationS$:	MOVE.32		D1,D4	LIB		?AFX8	JUMP,NE		ERR_TD$;;	CALL		AFFICHE_TOTAL;;	JUMP,NE		ERR_TD$FIN$:;	call		Show_Mem			; RB: affiche la mmoire directement	POPM.32		A2..A5|D0..D4	TEST.16		D7	RETERR_TD$:	CALL		AFERROR	JUMP		FIN$;***********************************************************************************; Touche du milieu de  la souris;***********************************************************************************;------------\\; MMenu_Milieu >;=============/;; Mouse menu de slection de fonction avec la touche du milieu; ; In	; Out	; Mod	MMenu_Milieu:	MOVE.32	#R16^TMmenuMM,A3	move.32	#{a6}+oMMenuMilieu,a4	move.32	#0,d5	LIB	?MMENUS	JUMP,NE	fin$	COMP.16	#0,{A4}+LMM*0+OMMSEL	; cas vide slectionne ?	JUMP,EQ	FIN$	COMP.16	#1,{A4}+LMM*0+OMMSEL	; mmorise slectionn ?	JUMP,eq	Mem$	COMP.16	#2,{A4}+LMM*0+OMMSEL	; compare slectionn ?	JUMP,eq	Comp$	COMP.16	#3,{A4}+LMM*0+OMMSEL	; affiche slectionn ?	JUMP,eq	Aff$fin$:	ret;-----\; Mem$ >;=====/;; Sauve registre dans le groupe slectionn;; In; Out; ModMem$:	move.16	{A4}+LMM*1+OMMSEL,D3	; mmorise slectionn 	Call	SaveGroupe	move.32	{A4}+LMM*2+OMMINA,D0	tclr.32	d0:D3	move.32	d0,{A4}+LMM*2+OMMINA	; dgrise compare	move.32	d0,{A4}+LMM*3+OMMINA	; dgrise affiche	jump	fin$;------\; Comp$ >;======/;; Compare les registres avec le groupe slectionn et met en vidence les diffrences;; In; Out; ModComp$:	move.16	{A4}+LMM*2+OMMSEL,D3	; compare slectionn 	call	CompGroupe	jump	fin$;-----\; Aff$ >;=====/;; Affiche dans une dbox les registres courants et les registres du groupe sauv;; In; Out; ModAff$:	call	SavReg	lib	?pushmenu	push.32	d5	MOVE.32	#R16^T_DBOXAffReg,A2		;si grand cran	Move.16	#2**BDBSAV,D2			;ouvre la bote de dialogue	MOVE.32	#0,D4	DBOX_	OPEN	jump,ne	fa$	move.32	d5,{a6}+OCanAffReg	call	AF_REG_MM	move.16	{A4}+LMM*3+OMMSEL,D3	; Affichage slectionn 	call	AF_REG_MM_Sl$:	call	GET_TOUCHE_MM		; d3.16	 touche presse	move.32	#r16^t_call_MM,A1	move.16	#2**BDBCCFF,D1	DBOX_	CALLC	comp.16	#-1,d2	jump,ne	l$	dbox_	CLOSE	call	Af_and_Send		; raffiche registres normaux et envoi modiffa$:	pop.32	d5	lib	?popmenu	jump	fin$Annule:	call	GivReg			; Reprend registres	call	AF_REG_MM	retok:	move.16	#-1,d2	retT_CALL_MM:	.16	16'100*KEYDBOX+KEY_A0, 0, LIGNEA0_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_D0, 0, LIGNED0_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_A1, 0, LIGNEA1_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_D1, 0, LIGNED1_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_A2, 0, LIGNEA2_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_D2, 0, LIGNED2_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_A3, 0, LIGNEA3_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_D3, 0, LIGNED3_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_A4, 0, LIGNEA4_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_D4, 0, LIGNED4_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_A5, 0, LIGNEA5_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_D5, 0, LIGNED5_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_A6, 0, LIGNEA6_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_D6, 0, LIGNED6_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_A7, 0, LIGNEA7_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_D7, 0, LIGNED7_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_ISP, 0, LIGNEISP_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_MSP, 0, LIGNEMSP_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_SR, 0, LIGNESR_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_VBR, 0, LIGNEVBR_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_SFC, 0, LIGNESFC_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_DFC, 0, LIGNEDFC_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_CACR, 0, LIGNECACR_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_CAAR, 0, LIGNECAAR_MM-T_CALL_MM	.16	2**bPROGRA*16'100+"P"	.16	16'100*KEYDBOX+KEY_PCB, 0,  LIGNEPCB_MM-T_CALL_MM	; @AD ajout PCB	.16	16'100*KEYDBOX+KEY_PC, 0, LIGNEPC_MM-T_CALL_MM	.16	16'100*KEYDBOX+KEY_PCREL, 0, LIGNEPCREL_MM-T_CALL_MM	.16	F1, F2, F3, 0, OK-T_CALL_MM	.16	F13, F14, F15, 0, Annule-T_CALL_MM	.16	KEYMMP, 0, SlectAff-T_CALL_MM	.16	0;----------\; SlectAff >;==========/;; Slection du groupe  afficher;; In; Out	D3.16	groupe slectionn; ModSlectAff:	pushm.32	d4|a3	move.16	{A4}+LMM*3+OMMSEL,D3	; Affichage slectionn 	tset.32	d3:#15			; pour case grise	move.32	{A4}+LMM*3+OMMINA,D4	; Case inactive	move.32	#R16^TMMenuMMA,a3	; mmenu	Lib	?MMenu	call	AF_REG_MM_S	popm.32	d4|a3	Ret;-------\; SavReg >;=======/;; Sauve les registres dans un buffer temporaire;; In; Out; ModSavReg:	pushm.32	a0|a1|d0	MOVE.32	#{A6}+BUFFER_REG,A0	move.32	#{A6}+OBuffSavReg,A1	MOVE.16	#4*(NBREG-1),D0l$:	MOVE.32	{A0}+A16^{D0},{A1}+A16^{D0}	; Copie	SUB.32	#4,D0	JUMP,PL	l$	popm.32	a0|a1|d0	ret;-------\; GivReg >;=======/;; Reprend les registres sauvs;; In; Out; ModGivReg:	pushm.32	a0|a1|d0	MOVE.32		#{A6}+BUFFER_REG,A0	move.32		#{A6}+OBuffSavReg,A1	MOVE.16		#4*(NBREG-1),D0l$:	MOVE.32		{A1}+A16^{D0},{A0}+A16^{D0}	; reprend	SUB.32		#4,D0	JUMP,PL		l$	MOVE.32		{A6}+BOUTON,D1	MOVE.32		{A0}+4*KEY_SR,D4	;reprend {A6}+BUFFER_REG	move.8		d4,d1			; met  jour les boutons	MOVE.32		d1,{A6}+BOUTON	popm.32		a0|a1|d0	ret;---------\\; AF_REG_MM >;==========/;; Affichage registres principaux ; ; In	; Out	; Mod	AF_REG_MM:	PUSHM.32	A0|A1|D0|D2|D3|D4|D5|D6	MOVE.32	#{A6}+BUFFER_REG,A0	MOVE.16	#NBREG-1,D6	MOVE.16	#4*(NBREG-1),D0A$:	MOVE.16	D6,D2	CALL	SET_CURS_MM	JUMP,NE	C$	MOVE.32	{A0}+A16^{D0},D4		; Buffer des registres	LIB	?AFX8C$:	DEC.16	D6	JUMP,NS	FIN$	SUB.32	#4,D0	JUMP	A$FIN$:	POPM.32		A0|A1|D0|D2|D3|D4|D5|D6	CLR.16	D7	RET;-----------\\; AF_REG_MM_S >;============/;; Affichage des registres sauvs slectionns; ; In	D3.16	numro du groupe; Out	; Mod	AF_REG_MM_S:	PUSHM.32	A0|A1|D0|D2|D3|D4|D5|D6	MOVE.32	#{A6}+BUFFER_REG,A0	mul.16	#LgBufferReg,d3	MOVE.32	#{A6}+32^{d3},A1	move.32	#{A1}+OSAVREGISTRE,A1	MOVE.16	#NBREG-1,D6	MOVE.16	#4*(NBREG-1),D0A$:	MOVE.16	D6,D2	add.16	#30,d2				; offset registres sauvs	CALL	SET_CURS_MM	JUMP,NE	C$	MOVE.32	{A0}+A16^{D0},D5		; Buffer des registres	MOVE.32	{A1}+A16^{D0},D4		; Copie des registres de l'aff prcdent RB	comp.32	d4,d5	jump,eq	eq$	move.8	#AFINV,d3	lib	?afcareq$:	LIB	?AFX8	move.8	#AFDIR,d3	lib	?afcarC$:	DEC.16	D6	JUMP,NS	FIN$	SUB.32	#4,D0	JUMP	A$FIN$:	POPM.32		A0|A1|D0|D2|D3|D4|D5|D6	CLR.16	D7	RET;-----------\\; SET_CURS_MM >;============/;;cette routine place le curseur aprs un label fournit par d'autres routines qui veulent crire; l'cran. Cette routine permet de rendre toutes les autres indpendantes ;de la position  l'cran de l'objet qu'elles veulent modifier.	;IN:	D2.16 numro du label	;	{A6}+OCanAffReg	;OUT:	D3.32 coordonne de l'objet Y,X	;	+ curseur au dbut de l'objet	;MOD:	D7.16SET_CURS_MM:	PUSHM.32	A0|D2|D4|D5	MOVE.32	{A6}+OCanAffReg,D5	TSET.32	D2:#BDBGCLABEL	DBOX_	GETCO	JUMP,NE	FIN$	LIB	?SETCURSFIN$:	POPM.32		A0|D2|D4|D5	TEST.16	D7	RET;--------------\\; MODIFIE_REG_MM >;===============/;	;IN:	D6.16 numro du registre	;	{A6}+BUFFER_REG		tampon qui contient les registres	;	{A6}+REGISTRE		tampon provisoire pour transformer le chiffre binaire en un nombre ASCII	;	{A6}+MESSAGEOut+oMessage tampon pour les messages	;OUT:	envoie la modification  CIBLE.CODE	;MOD:	{A6}+BUFFER_REG, {A6}+REGISTRE, D7.16MODIFIE_REG_MM:	PUSHM.32	A0|A2..A5|D0..D4	MOVE.32	#{A6}+BUFFER_REG,A0	MOVE.16	D6,D2			;place le curseur au dbut de la case clique	CALL	set_curs_MM	JUMP,NE	ERR_MR$	lib	?aftim	.ascize	"        "	MOVE.16	D6,D2			;place le curseur au dbut de la case clique	CALL	set_curs_MM	JUMP,NE	ERR_MR$	MOVE.16	D6,D2			;calcul la position du registre	SL.16	#2,D2		MOVE.32	{A0}+A16^{D2},D1	;convertit l'hexa en ascii	MOVE.32	#{A6}+REGISTRE,A3	MOVE.32	A3,A4	CALL	BIN_ASCII	MOVE.32	#R16^KEYLST,A2		;dite la ligneA$:	MOVE.16	#LG_REGISTRE,D3	LIB	?EDIT	COMP.16	#KEYMGP,D3	JUMP,EQ	B$	COMP.16	#KEYMMP,D3	JUMP,EQ	B$	COMP.16	#KEYMDP,D3	JUMP,EQ	B$	COMP.16	#CR,D3	JUMP,NE	A$B$:	MOVE.32	A3,A5			;reconvertit l'ascii en hexa	CLR.32	D1C$:	MOVE.8	{A5+},D0	COMP.8	#CR,D0	JUMP,EQ	D$	CALL	ASCII_BIN	JUMP,NE	A$	JUMP	C$D$:	PUSH.16	D2			;replace le curseur	MOVE.16	D6,D2	CALL	set_curs_MM	POP.16	D2	MOVE.32	D1,{A0}+A16^{D2}	;change la valeur du registre dans le buffer	MOVE.32	D1,D4	LIB	?AFX8FIN$:	POPM.32		A0|A2..A5|D0..D4	TEST.16	D7			;annonce une erreur	RETERR_MR$:	CALL	AFERROR			;affiche ses erreurs	JUMP	FIN$;-------------\\; GET_TOUCHE_MM >;==============/;;cette routine fournit la dernire touche frappe selon les cls des fichiers qui dfinissent;la bote de dialogue, en plus elle affiche la valeur des boutons et les modifie si on leur clique dessus	;IN:	{A6}+BOUTON		tampon des boutons	;OUT:	D3.16 dernire touche frappe	;MOD:	{A6}+BOUTON, D3.16, D4.32, D7.16GET_TOUCHE_MM:	PUSHM.32	D4|D5	CALL	DELAI_COURT		;temps d'attente de quelques millisecondes	MOVE.16	#-1,D3	MOVE.32	#0,D4	MOVE.32	{A6}+oCanAffReg,D5	DBOX_	MEDIT	JUMP,NE	ERR_GT$	DBOX_	EDIT	JUMP,NE	ERR_GT$	CALL	DELAI_INFINI		;temps d'attente infiniFIN$:	POPM.32		D4|D5	TEST.16	D7				RETERR_GT$:	CALL AFERROR			;affiche lui_mme les erreurs	JUMP	FIN$LIGNEA0_MM:	MOVE.16	#KEY_A0,D6	CALL	MODIFIE_reg_MM	RETLIGNED0_MM:	MOVE.16	#KEY_D0,D6	CALL	MODIFIE_reg_MM	RETLIGNEA1_MM:	MOVE.16	#KEY_A1,D6	CALL	MODIFIE_reg_MM	RETLIGNED1_MM:	MOVE.32	#KEY_D1,D6	CALL	MODIFIE_reg_MM	RETLIGNEA2_MM:	MOVE.32	#KEY_A2,D6	CALL	MODIFIE_reg_MM	RETLIGNED2_MM:	MOVE.32	#KEY_D2,D6	CALL	MODIFIE_reg_MM	RETLIGNEA3_MM:	MOVE.32	#KEY_A3,D6	CALL	MODIFIE_reg_MM	RETLIGNED3_MM:	MOVE.32	#KEY_D3,D6	CALL	MODIFIE_reg_MM	RETLIGNEA4_MM:	MOVE.32	#KEY_A4,D6	CALL	MODIFIE_reg_MM	RETLIGNED4_MM:	MOVE.32	#KEY_D4,D6	CALL	MODIFIE_reg_MM	RETLIGNEA5_MM:	MOVE.32	#KEY_A5,D6	CALL	MODIFIE_reg_MM	RETLIGNED5_MM:	MOVE.32	#KEY_D5,D6	CALL	MODIFIE_reg_MM	RETLIGNEA6_MM:	MOVE.32	#KEY_A6,D6	CALL	MODIFIE_reg_MM	RETLIGNED6_MM:	MOVE.32	#KEY_D6,D6	CALL	MODIFIE_reg_MM	RETLIGNEA7_MM:	MOVE.32	#KEY_A7,D6	CALL	MODIFIE_reg_MM	RETLIGNED7_MM:	MOVE.32	#KEY_D7,D6	CALL	MODIFIE_reg_MM	RETLIGNEISP_MM:	MOVE.32	#KEY_ISP,D6	CALL	MODIFIE_reg_MM	RETLIGNEMSP_MM:	MOVE.32	#KEY_MSP,D6	CALL	MODIFIE_reg_MM	RETLIGNESR_MM:	pushm.32	a0|a2|d4	MOVE.32		#KEY_SR,D6	move.32		#r16^TDBOX_SR,A2	MOVE.32		#{A6}+BUFFER_reg,A0	MOVE.32		{A0}+4*KEY_SR,D4	;modifie {A6}+BUFFER_reg_MM	CALL		DBOX_reg	MOVE.32		{A6}+BOUTON,D1	MOVE.32		{A0}+4*KEY_SR,D4	;reprend {A6}+BUFFER_REG	move.8		d4,d1			; met  jour les boutons	MOVE.32		d1,{A6}+BOUTON	call		Af_Reg_MM	popm.32		a0|a2|d4	RETLIGNEVBR_MM:	MOVE.32	#KEY_VBR,D6	CALL	MODIFIE_reg_MM	RETLIGNESFC_MM:	MOVE.32	#KEY_SFC,D6	CALL	MODIFIE_reg_MM	RETLIGNEDFC_MM:	MOVE.32	#KEY_DFC,D6	CALL	MODIFIE_reg_MM	RETLIGNECACR_MM:	pushm.32	a0|a2|d4	MOVE.32		#KEY_CACR,D6	comp.32		#68020,{a6}+OProcessor	jump,ne		r8^s0$	move.32		#r16^TDBOX_CACR_68020,A2	jump		r8^s$s0$:	comp.32		#68030,{a6}+OProcessor	jump,ne		r8^f$	move.32		#r16^TDBOX_CACR_68030,A2s$:	MOVE.32		#{A6}+BUFFER_reg,A0	MOVE.32		{A0}+4*KEY_CACR,D4	;modifie {A6}+BUFFER_reg_MM	CALL		DBOX_reg	call		Af_Reg_MMf$:	popm.32		a0|a2|d4	RETLIGNECAAR_MM:	MOVE.32	#KEY_CAAR,D6	CALL	MODIFIE_reg_MM	RETLIGNEPCB_MM:					; @AD ajout PCB	MOVE.32	#KEY_PCB,D6	CALL	MODIFIE_reg_MM	RETLIGNEPC_MM:	MOVE.32	#KEY_PC,D6	CALL	MODIFIE_reg_MM	RETLIGNEPCREL_MM:	MOVE.32	#KEY_PCREL,D6	CALL	MODIFIE_reg_MM	RETTMMenuMM:		.ASCIZ	"      "		.8	-1		.8.16	-2,TMMenuMMS-TMMenuMM		.ASCIZ	"  Mmorise registres "		.8.16	-2,TMMenuMMC-TMMenuMM		.ASCIZ	"  Compare registres  "		.8.16	-2,TMMenuMMA-TMMenuMM		.ASCIZ	"  Affiche registres  "		.8	0TMMenuMMS:		.ASCIZ		" Groupe 0 "		.ASCIZ		" Groupe 1 "		.ASCIZ		" Groupe 2 "		.ASCIZ		" Groupe 3 "		.ASCIZ		" Groupe 4 "		.ASCIZ		" Groupe 5 "		.ASCIZ		" Groupe 6 "		.ASCIZ		" Groupe 7 "		.ASCIZ		" Groupe 8 "		.ASCIZ		" Groupe 9 "		.8		0TMMenuMMC:		.ASCIZ		" Groupe 0 "		.ASCIZ		" Groupe 1 "		.ASCIZ		" Groupe 2 "		.ASCIZ		" Groupe 3 "		.ASCIZ		" Groupe 4 "		.ASCIZ		" Groupe 5 "		.ASCIZ		" Groupe 6 "		.ASCIZ		" Groupe 7 "		.ASCIZ		" Groupe 8 "		.ASCIZ		" Groupe 9 "		.8		0TMMenuMMA:		.ASCIZ		" Groupe 0 "		.ASCIZ		" Groupe 1 "		.ASCIZ		" Groupe 2 "		.ASCIZ		" Groupe 3 "		.ASCIZ		" Groupe 4 "		.ASCIZ		" Groupe 5 "		.ASCIZ		" Groupe 6 "		.ASCIZ		" Groupe 7 "		.ASCIZ		" Groupe 8 "		.ASCIZ		" Groupe 9 "		.8		0T_DBOXAffReg:		.16	DBOX0$-T_DBOXAffReg		.16	MENU$-T_DBOXAffReg		.16	0		.16	0DBOX0$:		.8	ODBTEXT		.asciz	"          Registres courants                  Registres sauvs "		.8	ODBCR,ODBCR		.8	ODBTEXT		.ASCIZ	"   A0"		.8	ODBLABEL,KEY_A0		.8	ODBBOX		.8	KEYDBOX, KEY_A0, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"    D0"		.8	ODBLABEL,KEY_D0		.8	ODBBOX		.8	KEYDBOX, KEY_D0, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"    A0"		.8	ODBLABEL,KEY_SavA0		.8	ODBBOX		.8	KEYDBOX, KEY_SavA0, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"    D0"		.8	ODBLABEL,KEY_SavD0		.8	ODBBOX		.8	KEYDBOX, KEY_SavD0, TDBNORM		.ASCIZ	"         "		.8	odbcr,odbcr2		.8	ODBTEXT		.ASCIZ	"   A1"		.8	ODBLABEL,KEY_A1		.8	ODBBOX		.8	KEYDBOX, KEY_A1, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"    D1"		.8	ODBLABEL,KEY_D1		.8	ODBBOX		.8	KEYDBOX, KEY_D1, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"    A1"		.8	ODBLABEL,KEY_SavA1		.8	ODBBOX		.8	KEYDBOX, KEY_SavA1, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"    