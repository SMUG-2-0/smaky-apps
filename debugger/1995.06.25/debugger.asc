ODBBOX		.8	KEYDBOX, KEY_SavSFC, TDBNORM		.ASCIZ	"         "		.8	odbcr,odbcr2		.8	ODBTEXT				; @AD affiche PCB au lieu de VBR		.ASCIZ	"  PCB"		.8	ODBLABEL,KEY_PCB		.8	ODBBOX		.8	KEYDBOX, KEY_PCB, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"   DFC"		.8	ODBLABEL,KEY_DFC		.8	ODBBOX		.8	KEYDBOX, KEY_DFC, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT				; @AD affiche PCB au lieu de VBR		.ASCIZ	"   PCB"		.8	ODBLABEL,KEY_SavPCB		.8	ODBBOX		.8	KEYDBOX, KEY_SavPCB, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"   DFC"		.8	ODBLABEL,KEY_SavDFC		.8	ODBBOX		.8	KEYDBOX, KEY_SavDFC, TDBNORM		.ASCIZ	"         "		.8	odbcr,odbcr2		.8	ODBTEXT		.ASCIZ	"   PC"		.8	ODBLABEL,KEY_PC		.8	ODBBOX		.8	KEYDBOX, KEY_PC, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"  CACR"		.8	ODBLABEL,KEY_CACR		.8	ODBBOX		.8	KEYDBOX, KEY_CACR, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"    PC"		.8	ODBLABEL,KEY_SavPC		.8	ODBBOX		.8	KEYDBOX, KEY_SavPC, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"  CACR"		.8	ODBLABEL,KEY_SavCACR		.8	ODBBOX		.8	KEYDBOX, KEY_SavCACR, TDBNORM		.ASCIZ	"         "		.8	odbcr,odbcr2		.8	ODBTEXT		.ASCIZ	"  rel"		.8	ODBLABEL,KEY_PCrel		.8	ODBBOX		.8	KEYDBOX, KEY_PCrel, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"  CAAR"		.8	ODBLABEL,KEY_CAAR		.8	ODBBOX		.8	KEYDBOX, KEY_CAAR, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"   rel"		.8	ODBLABEL,KEY_SavPCrel		.8	ODBBOX		.8	KEYDBOX, KEY_SavPCrel, TDBNORM		.ASCIZ	"         "		.8	ODBTEXT		.ASCIZ	"  CAAR"		.8	ODBLABEL,KEY_SavCAAR		.8	ODBBOX		.8	KEYDBOX, KEY_SavCAAR, TDBNORM		.ASCIZ	"         "		.8	odbcr,odbcr2	.8	ODBCR	.8	ODBTABX,16'08	.8	ODBBOX	.16.8	F1,TDBMEV	.ASCIZ	"  D'ACCORD  "	.8	ODBTABX,16'35	.8	ODBBOX	.16.8	F13,TDBNORM	.ASCIZ	"   ANNULE   "	.8	0	.EVENMENU$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVEN;***********************************************************************************; Gestion des touches de contrle des registres;***********************************************************************************;--------\\; Save_Reg >;=========/;; ; ; In	; Out	; Mod	Save_Reg:	pushm.32	A3|d3|d4l$:	move.32		#r16^MRegistreS,a3	move.16		#0,d3	move.32		#0,d4	lib		?MMenu	comp.16		#erdiout,d7	jump,ne		s$	move.32		#(100*16'10000)+400,d4	lib		?PMOUSE	jump		l$s$:	test.16		d7	jump,ne		f$	test.16		d3	jump,eq		f$	move.32		{a6}+OMComp,d4	tclr.32		d4:d3			; Bit  dtramer	move.32		d4,{a6}+OMComp	dec.16		d3			; enlve ligne retour 0	call		SaveGroupef$:	popm.32		A3|d3|d4	ret;----------\\; SaveGroupe >;===========/;; Sauve les registres en mmoire; ; In	D3.16	numro du groupe  sauver; Out	; Mod	SaveGroupe:	PUSHM.32	A0|A1|D0|D3|D4|D6	MOVE.32	#{A6}+BUFFER_REG,A0	mul.16	#LgBufferReg,d3	MOVE.32	#{A6}+32^{d3},A1	move.32	#{A1}+OSAVREGISTRE,A1	MOVE.16	#NBREG-1,D6	MOVE.16	#4*(NBREG-1),D0A$:	MOVE.32	{A0}+A16^{D0},D4		; Buffer des registres	move.32	d4,{A1}+A16^{D0}		; Nouveau reg -> copieC$:	DEC.16	D6	JUMP,NS	FIN$	SUB.32	#4,D0	JUMP	A$FIN$:	POPM.32		A0|A1|D0|D3|D4|D6	ret;--------\\; Comp_Reg >;=========/;; ; ; In	; Out	; Mod	Comp_Reg:	pushm.32	A3|d3|d4l$:	move.32		#r16^MRegistreC,a3	move.16		#2**15,d3	move.32		{a6}+OMComp,d4	lib		?MMenu	comp.16		#erdiout,d7	jump,ne		s$	move.32		#(100*16'10000)+400,d4	lib		?PMOUSE	jump		l$s$:	test.16		d7	jump,ne		f$	dec.16		d3	jump,ns		f$	Call		CompGroupef$:	popm.32		A3|d3|d4	ret;----------\\; CompGroupe >;===========/;; Compare registre affich avec registres sauvs;; In	D3.16	numro du groupe  sauver; Out	; Mod	CompGroupe:	PUSHM.32	A0|A1|D0|D2|D3|D4|D5|D6	MOVE.32	#{A6}+COP_BUFFER_REG,A0	mul.16	#LgBufferReg,d3	MOVE.32	#{A6}+32^{d3},A1	move.32	#{A1}+OSAVREGISTRE,A1	MOVE.16	#NBREG-1,D6	MOVE.16	#4*(NBREG-1),D0A$:	MOVE.32	{A1}+A16^{D0},D4		; Buffer des registres	move.32	d4,{A0}+A16^{D0}		; Nouveau reg -> copieC$:	DEC.16	D6	JUMP,NS	FIN$	SUB.32	#4,D0	JUMP	A$FIN$:	call		AF_REG	POPM.32		A0|A1|D0|D2|D3|D4|D5|D6;--------\\; Repr_Reg >;=========/;; A faire peut tre; ; In	; Out	; Mod	Repr_Reg:	retMRegistreS:	.asciz	" "			; Touche vide	.8	-1	.ASCIZ	" Sauve 0 "	.ASCIZ	" Sauve 1 "	.ASCIZ	" Sauve 2 "	.ASCIZ	" Sauve 3 "	.ASCIZ	" Sauve 4 "	.ASCIZ	" Sauve 5 "	.ASCIZ	" Sauve 6 "	.ASCIZ	" Sauve 7 "	.ASCIZ	" Sauve 8 "	.ASCIZ	" Sauve 9 "	.8	0	.evenMRegistreC:	.asciz	" "			; Touche vide	.8	-1	.ASCIZ	" Compare 0 "	.ASCIZ	" Compare 1 "	.ASCIZ	" Compare 2 "	.ASCIZ	" Compare 3 "	.ASCIZ	" Compare 4 "	.ASCIZ	" Compare 5 "	.ASCIZ	" Compare 6 "	.ASCIZ	" Compare 7 "	.ASCIZ	" Compare 8 "	.ASCIZ	" Compare 9 "	.8	0	.evenMRegistreR:	.asciz	" "			; Touche vide	.8	-1	.ASCIZ	" Reprend 0 "	.ASCIZ	" Reprend 1 "	.ASCIZ	" Reprend 2 "	.ASCIZ	" Reprend 3 "	.ASCIZ	" Reprend 4 "	.ASCIZ	" Reprend 5 "	.ASCIZ	" Reprend 6 "	.ASCIZ	" Reprend 7 "	.ASCIZ	" Reprend 8 "	.ASCIZ	" Reprend 9 "	.8	0	.even;***********************************************************************************;***********************************************************************************;MODULE INTERPRETEUR;***********************************************************************************;***********************************************************************************;-----------------\\; INTERPRETE_TOUCHE >;==================/;;cette routine interprte une touche du clavier	;IN:	D3.16 touche frappe	;	D4.32 tat des fanions	;	D2.32 #-2 -> fin programme	;OUT:	-	;MOD:	D7.16INTERPRETE_TOUCHE:	PUSHM.32	A1|D1	MOVE.16		#2**BDBCCFF,d1		; Ne surtout pas mettre min -> maj	MOVE.32		#R16^T_CALLC,A1	DBOX_		CALLC	POPM.32		A1|D1	TEST.16		D7	RETT_CALLC:;touches de fonctions	.16	F0, 0, END_HOTE-T_CALLC	.16	F1, 0, Save_Reg-T_CALLC	.16	F2, 0, Comp_Reg-T_CALLC	.16	F3, 0, Repr_Reg-T_CALLC	.16	F4, 0, ShowDef-T_CALLC	.16	F7, 0, OPEN_MODULE_LST-T_CALLC	.16	F8, 0, LANCE_CIBLE-T_CALLC	.16	SHIFT+F8, 0, GET_COMMAND-T_CALLC	.16	F9, 0, GET_DIR_TEST-T_CALLC	.16	F10, F11, F12, ENTER, 0, TOUCHE_CONTINUE-T_CALLC	; @AD ajout ENTER pour Continue	.16	F13, 0, END_CIBLE-T_CALLC	.16	F14, 0, END_CIBLE-T_CALLC	.16	F15, 0, END_CIBLE-T_CALLC;modifications des registres	.16	16'100*KEYDBOX+KEY_A0, 0, LIGNEA0-T_CALLC	.16	16'100*KEYDBOX+KEY_D0, 0, LIGNED0-T_CALLC	.16	16'100*KEYDBOX+KEY_A1, 0, LIGNEA1-T_CALLC	.16	16'100*KEYDBOX+KEY_D1, 0, LIGNED1-T_CALLC	.16	16'100*KEYDBOX+KEY_A2, 0, LIGNEA2-T_CALLC	.16	16'100*KEYDBOX+KEY_D2, 0, LIGNED2-T_CALLC	.16	16'100*KEYDBOX+KEY_A3, 0, LIGNEA3-T_CALLC	.16	16'100*KEYDBOX+KEY_D3, 0, LIGNED3-T_CALLC	.16	16'100*KEYDBOX+KEY_A4, 0, LIGNEA4-T_CALLC	.16	16'100*KEYDBOX+KEY_D4, 0, LIGNED4-T_CALLC	.16	16'100*KEYDBOX+KEY_A5, 0, LIGNEA5-T_CALLC	.16	16'100*KEYDBOX+KEY_D5, 0, LIGNED5-T_CALLC	.16	16'100*KEYDBOX+KEY_A6, 0, LIGNEA6-T_CALLC	.16	16'100*KEYDBOX+KEY_D6, 0, LIGNED6-T_CALLC	.16	16'100*KEYDBOX+KEY_A7, 0, LIGNEA7-T_CALLC	.16	16'100*KEYDBOX+KEY_D7, 0, LIGNED7-T_CALLC	.16	16'100*KEYDBOX+KEY_ISP, 0, LIGNEISP-T_CALLC	.16	16'100*KEYDBOX+KEY_MSP, 0, LIGNEMSP-T_CALLC	.16	16'100*KEYDBOX+KEY_SR, 0, LIGNESR-T_CALLC	.16	16'100*KEYDBOX+KEY_VBR, 0, LIGNEVBR-T_CALLC	.16	16'100*KEYDBOX+KEY_SFC, 0, LIGNESFC-T_CALLC	.16	16'100*KEYDBOX+KEY_DFC, 0, LIGNEDFC-T_CALLC	.16	16'100*KEYDBOX+KEY_CACR, 0, LIGNECACR-T_CALLC	.16	16'100*KEYDBOX+KEY_CAAR, 0, LIGNECAAR-T_CALLC	.16	2**bPROGRA*16'100+"P"	.16	16'100*KEYDBOX+KEY_PCB, 0, LIGNEPCB-T_CALLC		; @AD ajout PCB	.16	16'100*KEYDBOX+KEY_PC, 0, LIGNEPC-T_CALLC	.16	16'100*KEYDBOX+KEY_PCREL, 0, LIGNEPCREL-T_CALLC;lecture de la mmoire	.16	16'100*KEYDBOX+KEY_BASE, 0, TOUCHE_BASE-T_CALLC	.16	16'100*KEYDBOX+KEY_BASE2, 0, TOUCHE_BASE2-T_CALLC	.16	16'100*KEYDBOX+Key_Depl, 0, TOUCHE_DEPLACEMENT-T_CALLC	.16	16'100*KEYDBOX+KEY_MEM, 0, Select_MEM-T_CALLC	.16	16'100*KEYDBOX+KEY_TOTAL, 0, Show_MEM_Off0-T_CALLC	.16	16'100*KEYDBOX+KEY_AD0	.8.8	2**BCursor,"W"	.8.8	2**BCursor,"w"	.16	 0, DEC_MEM8-T_CALLC	.16	16'100*KEYDBOX+KEY_AD1	.8.8	2**BCursor,"E"	.8.8	2**BCursor,"e"	.16	 0, DEC_MEM4-T_CALLC	.16	16'100*KEYDBOX+KEY_AD2, 0, DEC_MEM2-T_CALLC	.16	16'100*KEYDBOX+KEY_AD3	.8.8	2**BCursor,"R"	.8.8	2**BCursor,"r"	.16	 0, DEC_MEM1-T_CALLC	.16	16'100*KEYDBOX+KEY_AD4	.8.8	2**BCursor,"D"	.8.8	2**BCursor,"d"	.16	 0, Dec_MEM-T_CALLC	.16	16'100*KEYDBOX+KEY_AD5, 0, Show_MEM-T_CALLC	.16	16'100*KEYDBOX+KEY_AD6	.8.8	2**BCursor,"F"	.8.8	2**BCursor,"f"	.16	 0, Inc_MEM-T_CALLC	.16	16'100*KEYDBOX+KEY_AD7	.8.8	2**BCursor,"C"	.8.8	2**BCursor,"c"	.16	 0, INC_MEM1-T_CALLC	.16	16'100*KEYDBOX+KEY_AD8, 0, INC_MEM2-T_CALLC	.16	16'100*KEYDBOX+KEY_AD9	.8.8	2**BCursor,"X"	.8.8	2**BCursor,"x"	.16	 0, INC_MEM4-T_CALLC	.16	16'100*KEYDBOX+KEY_AD10	.8.8	2**BCursor,"Y"	.8.8	2**BCursor,"y"	.16	 0, INC_MEM8-T_CALLC;chargement et excution des programmes .CODE et .LST	.16	16'100*KEYDBOX+KEY_LST, 0, OPEN_MODULE_LST-T_CALLC	.16	16'100*KEYDBOX+KEY_CODE, 0, LANCE_CIBLE-T_CALLC	.16	16'100*KEYDBOX+KEY_DOSSIER, 0, GET_DIR_TEST-T_CALLC	.16	16'100*KEYDBOX+KEY_COMMAND, 0, GET_COMMAND-T_CALLC;fin des programmes	.16	16'100*KEYDBOX+KEY_CIBLE, 0, END_CIBLE-T_CALLC	.16	16'100*KEYDBOX+KEY_HOTE, 0, END_HOTE-T_CALLC	.16	16'100*KEYDBOX+KEY_CONTINUE, 0, TOUCHE_CONTINUE-T_CALLC;cliquer sur les boutons	.16	16'100*KEYDBOX+KEY_FLAG, 0, BOUTON_FANION-T_CALLC	.16	16'100*KEYDBOX+KEY_BIT_ABSOLU, 0, BOUTON_ABSOLU-T_CALLC	.16	16'100*KEYDBOX+KEY_BIT_RELATIF, 0, BOUTON_RELATIF-T_CALLC	.16	16'100*KEYDBOX+KEY_TRACEI, 0, BOUTON_TRACEI-T_CALLC	.16	16'100*KEYDBOX+KEY_TRACEJ, 0, BOUTON_TRACEJ-T_CALLC	.16	16'100*KEYDBOX+KEY_NOTRACE, 0, BOUTON_NOTRACE-T_CALLC	.16	DEFINE, 0, DEFINE_RECHERCHE-T_CALLC	.16	16'100*(2**BSEARCH)+"F", 0, RECHERCHE_APRES-T_CALLC	.16	16'100*(2**BSEARCH)+"D", 0, RECHERCHE_AVANT-T_CALLC	.16	16'100*(2**BSEARCH)+"f", 0, RECHERCHE_APRES-T_CALLC	.16	16'100*(2**BSEARCH)+"d", 0, RECHERCHE_AVANT-T_CALLC;cliquer sur les boutons de la souris dans la fentre SCROLL pour le fichier .LST	.16	KEYMGP, 0, MGPMMP_SCROLL_LST-T_CALLC	.16	KEYMMP, 0, MMenu_Milieu-T_CALLC	.16	KEYMDP, 0, MDP_ADRES_LST-T_CALLC	.16	0.EVEN;------------------\\; INTERPRETE_MESSAGE >;===================/;;cette routine interprte un message du prg CIBLE.CODE	;IN:	D0.16 commande du prg CIBLE.CODE	;OUT:	-	;MOD:	D7.16; ; In	; Out	; Mod	INTERPRETE_MESSAGE:	COMP.16	#CIBLE_ERR,D0	JUMP,EQ	C_ERR	COMP.16	#CIBLE_REG,D0	JUMP,EQ	C_REG	COMP.16	#CIBLE_MEM,D0	JUMP,EQ	C_DES	COMP.16	#CIBLE_DATE,D0	JUMP,EQ	C_DATE	COMP.16	#CIBLE_PRES,D0	JUMP,EQ	C_PRESENT	COMP.16	#CIBLE_ABS,D0	JUMP,EQ	C_ABSENT	comp.16	#CIBLE_PROC,D0	jump,eq	C_Processor	comp.16	#CIBLE_DescDriv,D0	jump,eq	C_CIBLE_DescDriv	MOVE.16	#ERR_HOTE+0,D7	CALL	AFERRORFIN:	RET;-----\\; C_ERR >;======/;; affiche une erreur en provenance de HOTE.CODE; ; In	; Out	; Mod	C_ERR:	TCLR.8	{A6}+TEST:#bCODE	MOVE.32	#{A6}+MESSAGEIn+oMessage,A3	CALL	AFTERROR	JUMP	FIN;-----\\; C_REG >;======/;; affiche les registres de TEST.CODE; ; In	; Out	; Mod	C_REG:	call	liaisonOk	MOVE.16	#NBREG-1,D0	MOVE.32	#{A6}+BUFFER_REG,A0	MOVE.32	#{A6}+MESSAGEIn+oMessage,A1A$:	MOVE.32	{A1+},{A0+}	DJ.16,NMO	D0,A$	CALL	AF_REG	TEST.8	{A6}+TEST:#bLST	JUMP,BC	FIN$	MOVE.32	#{A6}+BUFFER_REG,A0	MOVE.32	{A0}+4*KEY_PCREL,D2	CALL	CHERCHE_LIGNE_LST	JUMP,NE	FIN$	MOVE.32	{A6}+C_WIN_SCROLL_LST,A5	MOVE.32	{A6}+DESCRIPTEUR_WINDOW,A0	MOVE.16	D0,{A5}+OSLCYS	SCROLL_	LUPDATEFIN$:	JUMP	FIN;-----\\; C_DES >;======/;; affiche le contenu de la mmoire envoy par CIBLE.CODE; ; In	; Out	; Mod	C_DES:	CALL	AF_MEMOIRE	JUMP	FIN;------\\; C_DATE >;=======/;; reoit la date et l'heure de cration de TEST.CODE; ; In	; Out	; Mod	C_DATE:	MOVE.32	#{A6}+MESSAGEIn+oMessage,A0	MOVE.32	{A0},{A6}+DATE_FILE_TEST	MOVE.32	{A0}+4,{A6}+HEURE_FILE_TEST	CALL	TESTE_HEURE	JUMP	FIN;---------\\; C_PRESENT >;==========/;; annonce que la liaison est tablie; ; In	; Out	; Mod	C_PRESENT:	call	liaisonOk	jump	finLiaisonOk:	TSET.8	{A6}+TEST:#bCOMMUNICATION	MOVE.16	#KEY_CIBLE+2**BDBGCLABEL+2**BDBGCFULL,D2	MOVE.32	{A6}+C_WIN_DBOXP,D5	DBOX_	GETCO	MOVE.16	#KEY_CONTINUE+2**BDBGCLABEL+2**BDBGCFULL,D2	MOVE.32	{A6}+C_WIN_DBOXP,D5	DBOX_	GETCO	MOVE.16	#KEY_MEM+2**BDBGCLABEL+2**BDBGCFULL,D2	MOVE.32	{A6}+C_WIN_DBOXP,D5	DBOX_	GETCO	MOVE.16	#KEY_HOTE+2**BDBGCLABEL+2**BDBGCGREY,D2	MOVE.32	{A6}+C_WIN_DBOXP,D5	DBOX_	GETCO	ret;--------\\; C_ABSENT >;=========/;; annonce que la liaison est interrompue; ; In	; Out	; Mod	C_ABSENT:	TCLR.8	{A6}+TEST:#bCOMMUNICATION	MOVE.16	#KEY_CIBLE+2**BDBGCLABEL+2**BDBGCGREY,D2	MOVE.32	{A6}+C_WIN_DBOXP,D5	DBOX_	GETCO	MOVE.16	#KEY_CONTINUE+2**BDBGCLABEL+2**BDBGCGREY,D2	MOVE.32	{A6}+C_WIN_DBOXP,D5	DBOX_	GETCO	MOVE.16	#KEY_MEM+2**BDBGCLABEL+2**BDBGCGREY,D2	MOVE.32	{A6}+C_WIN_DBOXP,D5	DBOX_	GETCO	MOVE.16	#KEY_HOTE+2**BDBGCLABEL+2**BDBGCFULL,D2	MOVE.32	{A6}+C_WIN_DBOXP,D5	DBOX_	GETCO	JUMP	FIN;-----------\\; C_Processor >;============/;; Type de processeur cible; ; In	; Out	; Mod	C_Processor:	MOVE.32	#{A6}+MESSAGEIn+oMessage,A0	move.32	{A0},{A6}+OProcessor	; Type de processeur cible	jump	Fin;----------------\\; C_CIBLE_DescDriv >;=================/;; Points d'entre du pilote; ; In	; Out	; Mod	C_CIBLE_DescDriv:	MOVE.32		#{A6}+MESSAGEIn+oMessage,A0	MOVE.32		#{A6}+MESSAGEIn+oMessage+16*2+4,A1	; 16 sous-pilotes max dcrits	call		dbox_driv	MOVE.32		#{A6}+MESSAGEIn+oMessage+16*2+4,A0	MOVE.32		#{A6}+MESSAGEOut+oMessage,A1		; 16 sous-pilotes max dcrits	move.16		#16*2+4/2-1,d0li$:	move.16		{a0+},{a1+}				; copie les points d'entres  tracer	dj.16,nmo	d0,li$	move.16		#HOTE_TraceDriv,d0	call		to_cible	jump		fin;---------\\; DBOX_Driv >;==========/;; ; ; In	A0.32		^descr driver install;	A1.32		^descr driver  tracer; Out	; Mod	DBOX_Driv:	pushm.32	d0..d6	lib		?PushMenu		; D5.32 <- canal	push.32		d5	move.32		#R16^TDBOXDriv,A2	move.16		#2**BDBSAV,d2	MOVE.32		{a0}+0,D4		; Pilotes possibles 	and.32		#16'FF,d4		; (PREND 8 SEULEMENT)	move.32		d4,d6	sl.32		#8,d6	move.8		d4,d6			; d6.32:         !sp exist!sp exist!	swap.32		d6			; d6.32: !sp exist!sp exist! 0 ! 0 !;;	move.32		#24,d1;;	SL.32		d1,D4			; BIT 31..24	move.32	#0,d4	tset.32		d4:#16			; regarde le 0	move.16		{a1}+4+0*2,d4		; bitmap points d'entres dsir _0; D4.32:; bits 31..24: sous-pilote existants 0..7;      23..16: sous-pilote dont les points d'entres sont visualiss;      15..0:  points d'entre existants et  visualiser pour ce sous-pilote	move.16		{a0}+4+0*2,d6		; PE possible _0, d6.32 paramtres de griserie; D6.32:; bits 31..24: sous-pilote existants 0..7;      23..16: sous-pilote existants 0..7;      15..0:  points d'entre existants	DBOX_		OPEN			; d5.32 <- canal	jump,ne		f$	move.16		#-1,d3	DBOX_		MEDIT	jump,ne		f0$; Grise, dgrise points d'entres; utilise D6.32l0$:	move.32		#0,d0l$:	move.16		d0,d2	tset.32		d2:#bdbgclabel	test.32		D6:d0			; Points d'entre possible?	jump,bc		non$	tset.32		d2:#bdbgcfull	tclr.32		d2:#bdbgcgrey	jump		s0$non$:	tset.32		d2:#bdbgcgrey	tclr.32		d2:#bdbgcfulls0$:	pushm.32	d3|d4	DBOX_		GETCO	popm.32		d3|d4	inc.16		d0	comp.16		#16+8+8,d0	jump,lo		l$le$:	DBOX_		EDIT	move.16		d3,d2			; touche presse	and.16		#16'FF00,d2		; touche shift	comp.16		#(2**BSHOW)*16'100,d2	; SHOW + ... (Circle pilote  voir points d'entre)	jump,eq		Show$	comp.16		#(2**BCHANGE)*16'100,d2	; CHANGE + ... (square pilote  tester)	jump,eq		Change$	comp.16		#(2**BCURSOR)*16'100,d2	; CURSOR + ... (square points d'entre  tester)	jump,eq		Cursor$	comp.16		#F1,d3	jump,eq		DAC$	comp.16		#F2,d3	jump,eq		DAC$	comp.16		#F3,d3	jump,eq		DAC$	jump		le$DAC$:f0$:	DBOX_		CLOSEf$:	swap.32		d4	sr.32		#8,d4	and.32		#16'FF,d4			; 8 sp max	move.32		d4,{a1}+0			; points d'entres  tracer	pop.32		d5				; reprend canal afmenu	lib		?PopMenu	popm.32		d0..d6	ret; dsactive/active le traage d'un sp cliqu (SQUARE)CHANGE$:	move.16		d3,d2	and.16		#2'111,d2		; F0..F7 masqu	push.32		d2	add.16		#24,d2			; pour trouver bit square 31..24	test.32		D4:d2	popm.32		d2	jump,bs		sch$	sl.16		d2			; *2	move.16		#0,d4			; pas de trace sur ce pilote	jump		r8^sch0$sch$:	sl.16		d2			; *2	move.16		{a0}+A16^{d2}+4,d4	; bitmap points d'entres possibles _slectionnsch0$:	move.16		d4,{a1}+A16^{d2}+4	; bitmap points d'entres dsirs _slectionn;;	jump		Show$; Montre la slection des traces pour le sp cliqu (CIRCLE)SHOW$:	move.32		d4,d2	swap.32		d2			; d2:<7..0> bit du sp affich	move.32		#8-1,d3 lch$:	test.32		d2:d3			; lequel est-ce ?skip,bs	dj.16,nmo	d3,lch$	sl.32		d3			; *2	move.16		{a1}+A16^{d3}+4,d4	; bitmap points d'entres possibles  tracer	move.16		{a0}+A16^{d3}+4,d6	; modif poids PE de ce sous-pilote	jump		l0$; clic dans SQUARE des points d'entre du SP CURSOR$:	move.32		d4,d2	swap.32		d2	move.32		#8-1,d3lcu$:	test.32		d2:d3skip,bs	dj.16,nmo	d3,lcu$	push.32		d3	sl.32		d3			; *2	move.16		d4,{a1}+A16^{d3}+4	; bitmap points d'entres possibles  tracer	pop.32		d3	add.32		#24,d3	tset.32		D4:d3			; met croix dans square pilotes  tracer	jump		l0$;	Bote de dialogue gnre par EDBOX.;	------------------------------------TDBOXDriv:	.16	DBOX$-TDBOXDriv	.16	MENU$-TDBOXDriv	.16	0,0DBOX$:	.8	ODBCR,ODBCR,ODBCR2	.8	ODBTABX,16'01	.8	ODBTEXT	.ASCIZ	"Trace sur les appels:"	.8	ODBTABX,16'20	.8	ODBTEXT	.ASCIZ	"Pilote  tracer:"	.8	ODBCR,ODBCR,ODBCR2	.8	ODBTABX,16'01	.8	ODBLABEL,16'00	.8	ODBSQUARE,16'00.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F0	.ASCIZ	" Open"	.8	ODBLABEL,16'18	.8	ODBTABX,16'1D	.8	ODBSQUARE,16'18.OR.2**BDBOKEY	.16	(2**BCHANGE)*16'100+F0	.ASCIZ	""	.8	ODBTABX,16'20	.8	ODBLABEL,16'10	.8	ODBLCIRCLE,16'10.OR.2**BDBOKEY	.16	(2**BSHOW)*16'100+F0	.ASCIZ	" Pilote 0"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'01	.8	ODBSQUARE,16'01.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F1	.ASCIZ	" Command"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'02	.8	ODBSQUARE,16'02.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F2	.ASCIZ	" Status"	.8	ODBLABEL,16'19	.8	ODBTABX,16'1D	.8	ODBSQUARE,16'19.OR.2**BDBOKEY	.16	(2**BCHANGE)*16'100+F1	.ASCIZ	""	.8	ODBTABX,16'20	.8	ODBLABEL,16'11	.8	ODBLCIRCLE,16'11.OR.2**BDBOKEY	.16	(2**BSHOW)*16'100+F1	.ASCIZ	" Pilote 1"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'03	.8	ODBSQUARE,16'03.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F3	.ASCIZ	" Read"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'04	.8	ODBSQUARE,16'04.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F4	.ASCIZ	" Write"	.8	ODBLABEL,16'1A	.8	ODBTABX,16'1D	.8	ODBSQUARE,16'1A.OR.2**BDBOKEY	.16	(2**BCHANGE)*16'100+F2	.ASCIZ	""	.8	ODBTABX,16'20	.8	ODBLABEL,16'12	.8	ODBLCIRCLE,16'12.OR.2**BDBOKEY	.16	(2**BSHOW)*16'100+F2	.ASCIZ	" Pilote 2"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'05	.8	ODBSQUARE,16'05.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F5	.ASCIZ	" Close"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'06	.8	ODBSQUARE,16'06.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F6	.ASCIZ	" Stoptr"	.8	ODBLABEL,16'1B	.8	ODBTABX,16'1D	.8	ODBSQUARE,16'1B.OR.2**BDBOKEY	.16	(2**BCHANGE)*16'100+F3	.ASCIZ	""	.8	ODBTABX,16'20	.8	ODBLABEL,16'13	.8	ODBLCIRCLE,16'13.OR.2**BDBOKEY	.16	(2**BSHOW)*16'100+F3	.ASCIZ	" Pilote 3"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'07	.8	ODBSQUARE,16'07.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F7	.ASCIZ	" Startr"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'08	.8	ODBSQUARE,16'08.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F8	.ASCIZ	" Avort"	.8	ODBLABEL,16'1C	.8	ODBTABX,16'1D	.8	ODBSQUARE,16'1C.OR.2**BDBOKEY	.16	(2**BCHANGE)*16'100+F4	.ASCIZ	""	.8	ODBTABX,16'20	.8	ODBLABEL,16'14	.8	ODBLCIRCLE,16'14.OR.2**BDBOKEY	.16	(2**BSHOW)*16'100+F4	.ASCIZ	" Pilote 4"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'09	.8	ODBSQUARE,16'09.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F9	.ASCIZ	" Aux1"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'0A	.8	ODBSQUARE,16'0A.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F10	.ASCIZ	" Aux2"	.8	ODBLABEL,16'1D	.8	ODBTABX,16'1D	.8	ODBSQUARE,16'1D.OR.2**BDBOKEY	.16	(2**BCHANGE)*16'100+F5	.ASCIZ	""	.8	ODBTABX,16'20	.8	ODBLABEL,16'15	.8	ODBLCIRCLE,16'15.OR.2**BDBOKEY	.16	(2**BSHOW)*16'100+F5	.ASCIZ	" Pilote 5"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'0B	.8	ODBSQUARE,16'0B.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F11	.ASCIZ	" Reset (Install)"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'0C	.8	ODBSQUARE,16'0C.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F12	.ASCIZ	" Kill  (DeInstall)"	.8	ODBLABEL,16'1E	.8	ODBTABX,16'1D	.8	ODBSQUARE,16'1E.OR.2**BDBOKEY	.16	(2**BCHANGE)*16'100+F6	.ASCIZ	""	.8	ODBTABX,16'20	.8	ODBLABEL,16'16	.8	ODBLCIRCLE,16'16.OR.2**BDBOKEY	.16	(2**BSHOW)*16'100+F6	.ASCIZ	" Pilote 6"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'0D	.8	ODBSQUARE,16'0D.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F13	.ASCIZ	" Strt"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'0E	.8	ODBSQUARE,16'0E.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F14	.ASCIZ	" Tstrt"	.8	ODBLABEL,16'1F	.8	ODBTABX,16'1D	.8	ODBSQUARE,16'1F.OR.2**BDBOKEY	.16	(2**BCHANGE)*16'100+F7	.ASCIZ	""	.8	ODBTABX,16'20	.8	ODBLABEL,16'17	.8	ODBLCIRCLE,16'17.OR.2**BDBOKEY	.16	(2**BSHOW)*16'100+F7	.ASCIZ	" Pilote 7"	.8	ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'0F	.8	ODBSQUARE,16'0F.OR.2**BDBOKEY	.16	(2**BCURSOR)*16'100+F15	.ASCIZ	" Start"	.8	ODBCR,ODBCR,ODBCR2	.8	ODBTABX,16'0F	.8	ODBBOX	.16.8	F1,TDBMEV	.ASCIZ	"  D'ACCORD  "	.8	0	.EVENMENU$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENKEYLST:		.BLK.8		2**7	;liste nulle		.EVEN; DD *******************************************************************************; Recherche de chanes de caractres; ROUTINES DE RECHERCHE DANS LE FICHIER .LST; ==========================================DEFINE_RECHERCHE:	lib		?PUSHMENU	push.32		d5	move.32		#r16^DBOX_RECHERCHE, A2		; ^bote de dialogue	move.32		#2**BDBSAV, D2	DBOX_		OPEN				; ouvre la bote de demande	jump,ne		Ret$	move.32		#{A6}+CHERCHE_FILE_LST, A3	; ^chane de recherche prcdente	move.8		#"*", {A3+}			; n'importe quoi devant	move.32		A3, A4a$:	test.8		{A4}				; cherche la fin de la ligne	jump,eq		b$	comp.8		#Cr, {A4+}			; termine sur un cr ?	jump,ne		a$	clr.8		{-A4}				; supprime le crb$:	comp.8		#"*", {A4}-1			; propose n'importe quoi aprs ?	jump,ne		r8^b2$	comp.32		A3, A4				; dj au dbut	jump,eq		r8^b2$	clr.8		{-A4}				; supprime l'toileb2$:	DBOX_		EDIT				; fait l'dition	call		FiltreD3	comp.16		#CR, D3	jump,eq		r8^cherche$	comp.16		#END, D3	jump,eq		r8^annule$	comp.16		#UNDO, D3	jump,ne		r8^b2$	clr.8		{A3}				; efface la chane	move.32		A3, A4	jump		b2$				; revient  l'ditioncherche$:	DBOX_		CLOSE	move.32		A3, A4c$:	test.8		{A4}	jump,eq		d$	comp.8		#Cr, {A4+}			; supprime le cr	jump,ne		c$	dec.32		A4d$:	move.8		#"*", {A4+}			; n'importe quoi aprs	clr.8		{A4}	pop.32		d5	lib		?POPMENU; remet le pointeur au dbut du texte	MOVE.32		{A6}+POINTEUR_FILE_LST,A1	MOVE.32		A1,{A6}+RECHERCHE_ADRESSE	MOVE.16		#0,{A6}+RECHERCHE_LIGNE	jump		RECHERCHE_APRES			; fait la recherche du 1erannule$:	DBOX_		CLOSERet$:	pop.32		d5	lib		?POPMENU	RETRECHERCHE_APRES:	CLR.16		D7	TEST.8		{A6}+TEST:#bLST			; si le fichier n'existe pas	JUMP,BC		FIN				; -> RET	move.16		#0, D4	Lib		?WaitMouse			; @DD met le sablier	move.32		{A6}+RECHERCHE_ADRESSE, A0	; position  partir d'o chercher	move.16		{A6}+RECHERCHE_LIGNE, D0	; no ligne en question	move.16		{A6}+NBCR_FILE_LST, D5		; total dans le fichierav$:	inc.16		D0				; ligne suivante	comp.16		D5, d0				; passe la dernire ?	jump,hs		PAS_TROUVEa$:	comp.8		#Cr, {A0+}			; saute la ligne	jump,ne		a$	call		CHERCHE_COMPARE			; existe dans cette ligne ?	jump,ns		av$				; non -> avance  la suivanteRECHERCHE_MONTRE:	move.32		A0, {A6}+RECHERCHE_ADRESSE	; ^ligne trouve	move.16		D0, {A6}+RECHERCHE_LIGNE	; no ligne trouve	MOVE.32		{A6}+C_WIN_SCROLL_LST,A5	MOVE.32		{A6}+DESCRIPTEUR_WINDOW,A0	MOVE.16		D0,{A5}+OSLCYS			; position  atteindre	SCROLL_		LUPDATE				; met  jour l'affichage	move.16		#1, D4	Lib		?WaitMouse			; @DD enlve le sablier	RETRECHERCHE_AVANT:	CLR.16		D7	TEST.8		{A6}+TEST:#bLST			; si le fichier n'existe pas	JUMP,BC		FIN				; -> RET	move.16		#0, D4	Lib		?WaitMouse			; @DD met le sablier	move.16		{A6}+RECHERCHE_LIGNE, D0	; ligne prcdement trouve	move.16		{A6}+NBCR_FILE_LST, D5	move.32		{A6}+RECHERCHE_ADRESSE, A0av$:	dec.16		D0				; no ligne prcdente	jump,cs		PAS_TROUVE	jump,ne		r8^i$	MOVE.32		{A6}+POINTEUR_FILE_LST,A0	; ^toute premire ligne	jump		b$i$:	dec.32		A0				; saute le cr prcdenta$:	comp.8		#Cr, {-A0}			; saute la ligne	jump,ne		a$	inc.32		A0				; revient au dbut de la ligneb$:	call		CHERCHE_COMPARE			; existe dans cette ligne ?	jump,ns		av$	jump		RECHERCHE_MONTRE		; met l'affichage  jourCHERCHE_COMPARE:	pushm.32	A2..A4	move.32		#{A6}+CHERCHE_FILE_LST, A3	; ^ligne  comparer	move.32		A0, A4				; ^ligne dans le fichier	move.32		#r16^sep$, A2	Lib		?CpString			; chane existe dans la ligne ?	popm.32		A2..A4	RetSep$:	.8		CR, 0, -1	.evenPAS_TROUVE:	move.16		#1, D4	Lib		?WaitMouse			; @DD enlve le sablier	push.32		d5	lib		?PushMenu	push.32		d5	move.32		#r16^T$, A3	move.16		#2**BDBSAV, D2	DBOX_		TERROR				; affiche le message "pas trouv"	pop.32		d5	lib		?PopMenu	pop.32		d5	RetT$:	.ascize		"Pas trouv la chane"FiltreD3:	MOVE.16		#2**BDBCCFF+2**BDBCCMM,D1		;conversion SHIFT-FN FN	MOVE.32		#R16^T_Filtre,A1	DBOX_		CALLC	RETT_Filtre:rel$:	.16		F1, F2, F3, Cr, 0, DoCr-rel$	.16		F13, F14,F15, End, 0, DoEnd-rel$	.16		0Docr:	move.16		#CR, D3	retDoEnd:	move.16		#END, D3	retDBOX_RECHERCHE:	.16		Box$-DBOX_RECHERCHE	.16		Soft$-DBOX_RECHERCHE	.16		0	.16		0Box$:	.8		ODBTEXT	.asciz		"Critre de recherche :"	.8		ODBCR, ODBCR	.8		ODBXLINE	.8		40, NBCAR_BUFFER_NAME-2, 0, KEYDBOX, KEY_DOSSIER, TDBNORM	.8		ODBCR, ODBCR	.8		ODBBOX, 0, CR, TDBMEV	.asciz		"  CHERCHE  "	.8		ODBTABX, 25	.8		ODBBOX, 0, END, TDBNORM	.asciz		"  ANNULE  "	.8		0Soft$:	.asciz		""	.asciz		""	.asciz		""	.asciz		"Cherche"	.asciz		""	.asciz		""	.asciz		""	.asciz		""	.asciz		""	.asciz		""	.asciz		""	.asciz		"Annule";***********************************************************************************;***********************************************************************************;PROGRAMME PRINCIPAL;***********************************************************************************;***********************************************************************************START:	.if	.not.assmile	LIB		?OPELIB			;ouvre la librairie.endif	assmile	push.32		A3	move.32		#r16^TueNoTrap, A3	FOS		?Execute	pop.32		A3	move.32		#-1,d0	call		Normal.if	assmilel$:	exit	jump		l$.else	LIB		?CLOLIB			;rend l'cran et le clavier	FOS		?STOP			;termine le programme.endif	assmileTueNoTrap:	.ascize		"SMA_NOTRAP/K"; Point d'entre en overlayOVERLAY:	move.8		#"O",d3	lib		?ifswitch		; overlay pour ce programme (Debugger/O)	jump,eq		Normal	move.16		#-1,d7	ret					; retour au FOS -> pas d'overlayNormal:	CALL	GET_MEMORY	JUMP,NE	AF_ERR_FAT1	move.16	d0,{a6}+oexec	test.16	{a6}+oexec			; mode overlay ? non -> ov0$	jump,ne	ov0$	lib	?pushmenu	move.32	d5,{a6}+omenupr	move.8	#savwdo,d3	lib	?afcarov0$:	lib	?skpnam			; regarde si paramtre	; RB	jump,ne	s0$	move.32	#{a6}+FILE_LST,a0	; fichier listing	move.32	#{a6}+FILE_CODE,a1	; fichier code	move.32	#{A6}+oLC, a2		; ligne de commande	; @DDl0$:	move.8	{a3+},d0	call	tstsep			; @DD au lieu de tstterm	jump,eq	s1$	move.8	d0,{a0+}		; copie le nom du fichier	move.8	d0,{a1+}	move.8	d0,{a2+}		; @DD	jump	l0$l1$:	move.8	{a3+},d0		; @DDs1$:	move.8	d0, {a2+}		; @DD	call	tstterm			; @DD	jump,ne	l1$			; @DD	move.8	#".",{a0+}	move.8	#"L",{a0+}	move.8	#"S",{a0+}	move.8	#"T",{a0+}	move.8	#0,{a0+}	move.8	#".",{a1+}	move.8	#"C",{a1+}	move.8	#"O",{a1+}	move.8	#"D",{a1+}	move.8	#"E",{a1+}	move.8	#0,{a1+}	set.8	{a6}+OFlNam		; nom donn en entres0$:								; RB	CALL	OPEN_MODULE_DBOX_SCROLL_UTILE	;ouvre les modules	JUMP,NE	AF_ERR_FAT2	CALL	OPEN_MODULE_BOX		;ouvre la bote de dialogue	JUMP,NE	AF_ERR_FAT3	CALL	OPEN_MODULE_COM		;ouvre les bals	JUMP,NE	AF_ERR_FAT4	test.8	{a6}+OFlNam				; RB	jump,f	loop			; @DD	jump,eq	loop	call	OPEN_MODULE_LST	call	Get_command		; @DD	call	LANCE_CIBLE;@DD dplac	clr.8	{a6}+OFlNam		; prochain nom "demand  la main"	MOVE.16	#HOTE_PROC,D0	CALL	TO_CIBLE		; quel est le processeur de la cible?	clr.8	{a6}+OFlNam		; prochain nom "demand  la main" @DDLOOP:	CALL	GET_TOUCHE		;attend une touche	CALL	INTERPRETE_TOUCHE	;l'interprte	comp.16	#-2,d2	jump,eq	fin1			; fin du programme	CALL	FROM_CIBLE		;va voir si quelque chose a t reu de CIBLE.CODE	JUMP,EQ	LOOP			;si oui	CALL	INTERPRETE_MESSAGE	;l'interprte	JUMP	LOOPFIN4:	CALL	CLOSE_MODULE_COM	;ferme les bals	JUMP,NE	AF_ERR_FAT3FIN3:	CALL	CLOSE_MODULE_BOX	;ferme la bote de dialogue	JUMP,NE	AF_ERR_FAT2FIN2:	CALL	CLOSE_MODULE_DBOX_SCROLL_UTILE	;ferme les modules	JUMP,NE	AF_ERR_FAT1FIN1:	move.16	#0,d5	lib	?usewdo	test.16	{a6}+oexec			; mode overlay ? non -> ov0$	jump,ne	ov1$	move.32	{a6}+omenupr,d5	lib	?popmenu	move.8	#getwdo,d3			; rcupre fentre	lib	?afcarov1$:	clr.16		d7	retAF_ERR_FAT1:				;affiche les erreurs fatales	LIB	?AFERROR	LIB	?GETCAR	JUMP	FIN1AF_ERR_FAT2:	LIB	?AFERROR	LIB	?GETCAR	JUMP	FIN2AF_ERR_FAT3:	CALL	AFERROR	JUMP	FIN3AF_ERR_FAT4:	CALL	AFERROR	JUMP	FIN4;-------\\; tstterm >;========/;; ; ; In	; Out	; Mod	.if	false		; @DD spare term/septstterm:				; RB	comp.8	#"/",d0	jump,eq	f$	comp.8	#" ",d0	jump,eq	f$	comp.8	#TAB,d0	jump,eq	f$	comp.8	#CR,d0	jump,eq	f$	comp.8	#LF,d0	jump,eq	f$	comp.8	#0,d0	jump,eq	f$	comp.8	#".",d0;	jump,eq	f$f$:	ret				; RB.else		@DDtstsep:	comp.8	#".",d0	jump,eq	f$	comp.8	#"/",d0	jump,eq	f$	comp.8	#" ",d0	jump,eq	f$	comp.8	#TAB,d0	jump,ne	r8^tsttermf$:	Rettstterm:	comp.8	#CR,d0	jump,eq	f$	comp.8	#LF,d0	jump,eq	f$	comp.8	#0,d0;	jump,eq	f$f$:	ret.endif.END