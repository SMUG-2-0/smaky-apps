	.TITLE	DEBUG.ASL;	----------------------------------------;		(C) 1990 - Pierre Arnaud;	----------------------------------------;	Source du module de librairie de DEBUG.	.PROC	M68000	.REF	SMAKY	.REF	DOLIB	.REF	DEBUGREVMAJ	= 0REVMIN	= 0REVPRO	= "a"	.REV	REVMAJ, REVMIN	.CODE	800,11,2'000111,600,2000,300,2000,2,"N","E","F",11	.IDENT	"(C)  Pierre ARNAUD et EPSITEC-system SA"	.START	-1;	Variables;	---------OBALTRAP:	.BLK.32	1			; descripteur de la BALOSEMATRAP:	.BLK.32	1			; descripteur du smaphoreOTABLEPATCH:	.BLK.32	64OPTABLE:	.BLK.32	1LGVAR:;	En-tte du module de librairie;	------------------------------	.LOC	0BASE:	.16	DEBUG_FIRST	.16	DEBUG_LAST	.8	0	.FILL.8	(OHLREV-APC),0	.8	REVMAJ,REVMIN	.32	END_MODULE	.32	PATHLIB	.FILL.8	(OHLNAM-APC),0	.ASCII	"DEBUG"	.FILL.8	(LGHLIB-APC),0	.16	_DEBUG_GETBAL	.16	_DEBUG_KILL;----------------\\;  _DEBUG_GETBAL  >;================/; Rend le ^bal pour et le smaphore de synchronisation.; in	-; out	A4.32	BAL de TRAP;	A5.32	smaphore de TRAP; mod	A3.32, A4.32, A5.32_DEBUG_GETBAL:	PUSHM.32 A6	CALL	GETVAR	MOVE.32	{A6}+OBALTRAP,A4	MOVE.32	{A6}+OSEMATRAP,A5ERR$:	POPM.32	A6	RET;--------------\\;  _DEBUG_KILL  >;==============/; Supprime ce qui a t initialis.; in	-; out	-; mod	-_DEBUG_KILL:	PUSHM.32 D1|D7|A4|A5|A6	CALL	GETVAR	CALL	PATCHUNDO	MOVE.32	{A6}+OBALTRAP,A5	NTREL	?KILLBAL	MOVE.32	{A6}+OSEMATRAP,A5	NTREL	?KILLSEM	MOVE.32	#MTYPCP,D1	MOVE.32	A6,A4	GESMEM	?GIVMEM	MOVE.32	#R16^GLOBALVAR,A6	CLR.32	{A6}ERR$:	POPM.32	D1|D7|A4|A5|A6	RET;---------\\;  GETVAR  >;=========/; Cherche les variables globales de la librairie.; in	-; out	A6.32; mod	A6.32GETVAR:	MOVE.32	#R16^GLOBALVAR,A6	TEST.32	{A6}	JUMP,NE	OK$	PUSHM.32 D1|D4|D5|D7|A4|A5	MOVE.32	#MTYPCP,D1	MOVE.32	#LGVAR,D4	GESMEM	?GETMEM	GESMEM	?CLEARMEM	MOVE.32	A4,{A6}	MOVE.32	#-1,D4	NTREL	?CREBAL	MOVE.32	A5,{A4}+OBALTRAP	MOVE.32	#0,D4	NTREL	?CRESEM	MOVE.32	A5,{A4}+OSEMATRAP	MOVE.32	A4,A6	CALL	PATCHCALLS	POPM.32	D1|D4|D5|D7|A4|A5	RETOK$:	MOVE.32	{A6},A6	RETTRAP:	PUSHM.32 D0|A0	MOVE.32	{SP}+8,D0			; adresse de l'instruction	MOVE.32	#R16^BASE,A0	COMP.32	D0,A0	JUMP,HI	R8^DO$	MOVE.32	#R16^END_MODULE,A0	COMP.32	D0,A0	JUMP,LO	R8^DO$	POPM.32	D0|A0	RETSFDO$:	POPM.32	D0|A0	PUSHM.32 D0..D7|A0..A6	MOVE.32	USP,A6	PUSH.32	A6	SUB.A16	#LstDEPLUS,SP	MOVE.32	#R16^RET$,A3	MOVE.32	A3,{SP}+OstCALL	MOVE.32	#-1,D4	NTREL	?MODTIM	MOVE.16	D4,{SP}+OstTIMEOUT	NTREL	?GETPRIO	MOVE.16	D4,{SP}+OstPRIO	NTREL	?GETSTACK	MOVE.32	A5,{SP}+OstSTBASE	MOVE.32	D5,{SP}+OstSTSIZE	NTREL	?GTPNUM	MOVE.16	D4,{SP}+OstPNUM	NTREL	?GTPNAM	MOVE.32	A3,{SP}+OstPNAM	MOVE.32	#R16^GLOBALVAR,A6	MOVE.32	{A6},A6	MOVE.32	{A6}+OBALTRAP,A5	MOVE.32	A7,A4	MOVE.32	#2**BMSNBR,D3	NTREL	?GIVMS				; envoie adresse du STACK	MOVE.32	{A6}+OSEMATRAP,A5	NTREL	?WAITEV				; attend synchro.	MOVE.16	{SP}+OstTIMEOUT,D4	NTREL	?SETTIM	MOVE.32	{SP}+OstCALL,A3	CALL	{A3}	ADD.A16	#LstDEPLUS,SP	POP.32	A6	MOVE.32	A6,USP	POPM.32	D0..D7|A0..A6	RETSFRET$:	RET;-------------\\;  PATCHCALLS  >;=============/; Place des "patches" pour chaque vecteur d'exception  surveiller.; in	A6.32	^variables; out	-; mod	D7.16PATCHCALLS:	PUSHM.32 D4|D5|A0|A3|A4|A5	MOVE.32	#R16^TABLEPATCH,A4		; ^table comportant NMI	MOVE.32	#{A6}+OTABLEPATCH,A0		; table des copies des patches	MOVE.32	A4,{A6}+OPTABLE			; mmorise ^table des bitsets	CLR.32	D5DO$:	CALL	TESTPATCH			;  patcher ?	JUMP,BC	R8^NEXT$	MOVE.32	#R16^TRAP,A5	NTREL	?IEPSYSCALLS			; dvie les vecteurs	MOVE.32	A5,{A0}NEXT$:	INC.32	D5	ADD.A16	#4,A0	COMP.16	#64,D5	JUMP,LT	R8^DO$				; passe en revue 64 vecteursERR$:	POPM.32	D4|D5|A0|A3|A4|A5	TEST.16	D7	RET;------------\\;  PATCHUNDO  >;============/; Supprime les patches effectus avant; in	A6.32	^variables; out	-; mod	D7.16PATCHUNDO:	PUSHM.32 D5|A0|A4|A5	MOVE.32	#{A6}+OTABLEPATCH,A0		; table des copies des patches	MOVE.32	{A6}+OPTABLE,A4			; mmorise ^table des bitsets	CLR.32	D5DO$:	CALL	TESTPATCH			; patch ?	JUMP,BC	R8^NEXT$			; non => suivant	MOVE.32	{A0},A5	NTREL	?IEPSYSCALLS			; re-vie les vecteursNEXT$:	INC.32	D5	ADD.A16	#4,A0	COMP.16	#64,D5	JUMP,LT	R8^DO$				; passe en revue 64 vecteursERR$:	POPM.32	D5|A0|A4|A5	TEST.16	D7	RET;------------\\;  TESTPATCH  >;============/; Demande si l'on peut ou non "patcher" ce vecteur; in	D5.16	numro du vecteur;	A4.32	^table des patchs; out	BC	on ne peut pas patcher;	BS	on peut patcher; mod	-TESTPATCH:	PUSHM.32 D0|D4	MOVE.16	D5,D0	SR.16	#5,D0				; divise par 32 (prend le nime .32)	SL.16	#2,D0				; on fait un "modulo"	MOVE.32	{A4}+A16^{D0},D0		; cherche le bitset	TEST.32	D0:D5				; bit allum ?	POPM.32	D0|D4	RETTABLEPATCH:	.32	2'00000001000000001100101111111100	; 32 premiers traps	.32	2'00000000000000000111110000001111GLOBALVAR:	.32	0END_MODULE:	.END