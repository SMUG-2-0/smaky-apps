	.CHAP	message.asi; RB	1.19	90/11/10	message HOTE_PROG; RB		91/03/02	modif l'ordre des paramtre -> la commande est transmise en premierNBREG		=		27	;nombre de registres @ADLgData		=		4*NBREG	.APC	PC_RECORD	.loc	0oCommande:	.blk.16	1	; CommandeoRes1:		.blk.16	1	; RserveoRes2:		.blk.32	1	; encore une rserveoData:		.blk.8	LgData	; MessageLgMess	=	APC;VALEUR DES DIFFERENTES COMMANDES ENTRE LES PROGRAMMES HOTE ET CIBLE;commandes reues du programme cibleCIBLE_ERR		=		16'0120		;rception d'une erreur de CIBLE.CODECIBLE_DATE		=		16'0121		;rception de la date et de l'heure de cration de TEST.CODECIBLE_PRES		=		16'0122		;rception de communication valideCIBLE_ABS		=		16'0123		;rception de communication interrompueCIBLE_REG		=		16'0124		;rception et affichage des registres de TEST.CODECIBLE_MEM		=		16'0125		;rception du contenu de la mmoireCIBLE_PROC		=		16'0126		;rception du type de processeur (M68000, M68020, M68030)CIBLE_DescDriv		=		16'0127		; descripteur entte pilote;commandes envoyes par le programme hteHOTE_TCF		=		16'0040		;ordre de continuer en mode TCFHOTE_TIE		=		16'0041		;ordre de continuer en mode TIEHOTE_NOT		=		16'0042		;ordre de laisser continuer TEST.CODE sans supervisionHOTE_END		=		16'0043		;ordre  CIBLE.CODE de se suiciderHOTE_TRAP		=		16'0044		;ordre de continuer jusqu'au point d'arrt fournitHOTE_MEM		=		16'0045		;ordre de fournir 24 quadlets de mmoire  partir de l'adresse fournieHOTE_REG		=		16'0046		;ordre de fournir les registres de TEST.CODEHOTE_PROC		=		16'0047		;ordre de fournir le type de processeur cibleHOTE_TraceDriv		=		16'0048		; ordre de trace dans le driverHOTE_Command		=		16'0049		; commande transmiseHOTE_PROG		=		16'0050		; nom du programme  charger pour dverminage; CIBLE_ERR:	erreur en claire par l'appel FOS ?ERROR	.loc	oDataoErreur:; CIBLE_DATE	date de cration 3 octets BCD, heure de cration 3 octets BCD	.loc	oDataoDate:	.blk.32	1	;	!   0	! jour	! mois 	! anne	!oHeure:	.blk.32	1	;	!   0	! heure	! min.	! sec.	!;; CIBLE_PRES	-; CIBLE_ABS	-; CIBLE_REG	D0..D7, A0..A6, SR, USP, ISP, MSP, VBR, SFC, DFC, CACR, CAAR, PC, PCrel	.loc	oDataoD0:	.blk.32	1oD1:	.blk.32	1oD2:	.blk.32	1oD3:	.blk.32	1oD4:	.blk.32	1oD5:	.blk.32	1oD6:	.blk.32	1oD7:	.blk.32	1oA0:	.blk.32	1oA1:	.blk.32	1oA2:	.blk.32	1oA3:	.blk.32	1oA4:	.blk.32	1oA5:	.blk.32	1oA6:	.blk.32	1	.blk.16	1oSR:	.blk.16	1	; SR n'a que 16 bitsoUSP:	.blk.32	1oISP:	.blk.32	1oMSP:	.blk.32	1oVBR:	.blk.32	1oSFC:	.blk.32	1oDFC:	.blk.32	1oCACR:	.blk.32	1oCAAR:	.blk.32	1oPC:	.blk.32	1oPCrel:	.blk.32	1; CIBLE_MEM	22*4 positions mmoire depuis celle demande, bitmap.32 position illegale	.loc	oDataoMem:		.blk.32	22oBitMapMem:	.blk.32	1	; position illgale (1 bit par .32); CIBLE_PROC	processeur.32 (68000, 68010, 68020, 68030)	.loc	oDataoTypProc:	.blk.32	1; CIBLE_DescDriv descripteur de l'entte du driver	.loc	oDataoBM_PI:		.blk.32	1	; Bit Map des pilotes installs, 8 seulement utiliss par hoteoBM_PE_0:	.blk.16	1	; BM_PE_ BitMap des points d'entres existant pour chaque piloteoBM_PE_0:	.blk.16	1oBM_PE_1:	.blk.16	1oBM_PE_2:	.blk.16	1oBM_PE_3:	.blk.16	1oBM_PE_4:	.blk.16	1oBM_PE_5:	.blk.16	1oBM_PE_6:	.blk.16	1oBM_PE_7:	.blk.16	1oBM_PE_8:	.blk.16	1oBM_PE_9:	.blk.16	1oBM_PE_10:	.blk.16	1oBM_PE_11:	.blk.16	1oBM_PE_12:	.blk.16	1oBM_PE_13:	.blk.16	1oBM_PE_14:	.blk.16	1oBM_PE_15:	.blk.16	1oBM_PT:		.blk.32	1	; BitMap pilote tracsoBM_PEtr_0:	.blk.16	1oBM_PEtr_1:	.blk.16	1oBM_PEtr_2:	.blk.16	1oBM_PEtr_3:	.blk.16	1oBM_PEtr_4:	.blk.16	1oBM_PEtr_5:	.blk.16	1oBM_PEtr_6:	.blk.16	1oBM_PEtr_7:	.blk.16	1oBM_PEtr_8:	.blk.16	1oBM_PEtr_9:	.blk.16	1oBM_PEtr_10:	.blk.16	1oBM_PEtr_11:	.blk.16	1oBM_PEtr_12:	.blk.16	1oBM_PEtr_13:	.blk.16	1oBM_PEtr_14:	.blk.16	1oBM_PEtr_15:	.blk.16	1; HOTE_TCF	ordre de trace sur JUMP; HOTE_TIE	ordre de trace par instruction; HOTE_NOT	plus de trace; HOTE_END	cible: suicide-toi!; HOTE_TRAP	adresse relative.32 pour mettre un TRAP par rapport au dbut du code	.loc	oDataoAdTrap:	.blk.32	1	; adresse relative de TRAP; HOTE_MEM	adresse de dbut de mmoire.32  visualiser; HOTE_REG	registres modifis mme ordre que CIBLE_REG; HOTE_PROC	demande le type de processeur de la cible; HOTE_TraceDriv points d'entre  tracer	.loc	oDataoBM_PTr:	.blk.32	1	; Bit Map pilotes tracs, 8 seulement utiliss par hoteoBM_PETr_0:	.blk.16	1	; BM_PE_ BitMap des points d'entres  traceroBM_PETr_1:	.blk.16	1oBM_PETr_2:	.blk.16	1oBM_PETr_3:	.blk.16	1oBM_PETr_4:	.blk.16	1oBM_PETr_5:	.blk.16	1oBM_PETr_6:	.blk.16	1oBM_PETr_7:	.blk.16	1oBM_PETr_8:	.blk.16	1oBM_PETr_9:	.blk.16	1oBM_PETr_10:	.blk.16	1oBM_PETr_11:	.blk.16	1oBM_PETr_12:	.blk.16	1oBM_PETr_13:	.blk.16	1oBM_PETr_14:	.blk.16	1oBM_PETr_15:	.blk.16	1	.end