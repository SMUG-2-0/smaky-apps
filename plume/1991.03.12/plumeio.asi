	.SBTTL	PLUMEIOKPREND:	LOAD.W	D0,#1		; D0 <-- nouveau texte	CALL	DBOXSAVE	; sauve avant de reprendre ?	JUMP,NE ERROR	CALL	BINIT		; efface tout le texte	CALL	ADISPLAY	; montre que tout est vide20$:	CALL	DBOXPREND	; demande le nom ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP',NE 50$	LOAD.L	A3,#(A5)+ODZNAM	; A3 <-- ^nom du fichier	CALL	IOREAD		; lit le fichier	JUMP',EQ 40$	LOAD.W	D6,D7	CALL	DBOXERROR	; affiche l'erreur ...	JUMP,NE BIGBIP	COMP.W	D6,#EREBBOA	JUMP,NE 20$40$:	TCLR.B	(A5)+ODZMAJ:#BMAJIO50$:	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	CINFOFIL	; affiche le nom du fichier	JUMP	LOOPKAJOUTE:	CLR.B	(A6)+OBUTEMP20$:	CALL	DBOXAJOUTE	; demande le nom ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.L	A3,#(A6)+OBUTEMP ; A3 <-- ^nom du fichier	CALL	IOREAD		; lit le fichier	JUMP,EQ LOOP	LOAD.W	D6,D7	CALL	DBOXERROR	; affiche l'erreur ...	JUMP,NE BIGBIP	COMP.W	D6,#EREBBOA	JUMP,NE 20$	JUMP	LOOPKSAUVE:20$:	CALL	DBOXCREATE	; demande le nom ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP',NE 50$	LOAD.L	A3,#(A5)+ODZNAM	; A3 <-- ^nom du fichier	CALL	IOWRITE		; crit le fichier	JUMP',EQ 40$	CALL	DBOXERROR	; affiche l'erreur ...	JUMP,NE BIGBIP	JUMP	20$40$:	TCLR.B	(A5)+ODZMAJ:#BMAJIO50$:	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	CINFOFIL	; affiche le nom du fichier	JUMP	LOOP;--------\\; IOREAD  >;========/; Prend ou ajoute un fichier complet dans une zone.; in	A5.L	^description zone;	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WIOREAD:	CALL	DBOXOPWAIT	; met la dbox d'attenteIOREAD2:	PUSHM.L	D0..D6,A3	CALL	RDOPEN		; ouvre le fichier en entre	JUMP,NE 90$	CALL	BINFO		; D4 <-- position, D5 <-- nb car	LOAD.L	D5,D4	CLR.L	D6		; D6 <-- nb de commandes boa bouffes20$:	CALL	RDONE		; D3 <-- lit un caractre	JUMP,NE 80$	COMP.B	D3,#BOA		; commande boa ?	JUMP',EQ 30$		; oui => 30$22$:	LOAD.B	D4,D3	LOAD.L	D3,(A6)+OIOLC	LOAD.B	D3,D4	CALL	BINSERE		; buffer <-- un caractre	JUMP,NE 80$	JUMP	20$30$:	TEST.B	(A6)+OFANIO+0:#BDBLBOA-24 ; option "laisse les commandes boa" ?	JUMP,BS 22$		; oui => 22$	LOAD.L	A3,#(A6)+OBUBOA	; A3 <-- ^buffer pour commande "boa"	LOAD.W	D1,#LBUBOA-5	; D1 <-- lg max commande	LOAD.B	(A3+),D3	; buffer <-- <BOA>	CALL	RDONE		; D3 <-- premier caractre	JUMP,NE 80$	LOAD.B	(A3+),D3	; buffer <-- premier caractre	CLR.B	(A3)		; buffer <-- terminateur	CLR.W	D0		; D0 <-- nb de \; imbriqus	COMP.B	D3,#'0	JUMP',LO 42$	COMP.B	D3,#'9	JUMP',LS 35$	COMP.B	D3,#'A	JUMP',LO 42$	COMP.B	D3,#'Z	JUMP',LS 35$	COMP.B	D3,#'a	JUMP',LO 42$	COMP.B	D3,#'z	JUMP',HI 42$35$:	CALL	RDONE		; D3 <-- caractre	JUMP,NE 80$	LOAD.B	(A3+),D3	; buffer <-- caractre	CLR.B	(A3)		; buffer <-- terminateur	DEC.W	D1		; commande trop longue ?	JUMP',EQ 45$		; oui => 45$	COMP.B	D3,#CR		; fin de la commande ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#';	JUMP',EQ 38$	COMP.B	D3,#BOA		; dbut d'une commande \; imbrique ?	JUMP,NE 35$		; non => 35$	INC.W	D0		; D0 <-- un niveau de plus	JUMP	35$38$:	DEC.W	D0		; D0 <-- un niveau de moins	JUMP,NC 35$40$:	INC.L	D6		; D6 <-- une commande boa bouffe de plus	TEST.B	(A6)+OFANIO+0:#BDBFBOA-24 ; option "filtre les commandes boa" ?	JUMP,BS 20$		; oui => 20$	DEC.L	D6		; D6 <-- mais non42$:	LOAD.L	A3,#(A6)+OBUBOA	CALL	RDBOA		; cherche commande "boa"	JUMP,EQ	20$		; ok => 20$45$:				; commande <boa> inconnue =>	LOAD.L	A3,#(A6)+OBUBOA46$:	LOAD.L	D3,(A6)+OIOLC	LOAD.B	D3,(A3+)	JUMP,EQ	20$	CALL	BINSERE		; buffer <-- commande boa inconnue	JUMP,NE 80$	JUMP	46$80$:	PUSH.W	D7	LOAD.L	D4,D5	CALL	BPOSITIONNE	; revient au dbut du fichier lu	POP.W	D7	CALL	RDCLOSE		; ferme le fichier en entre	COMP.W	D7,#EROUTF	; fin du fichier ?	JUMP',NE 90$		; non => 90$	LOAD.W	D7,#EREBBOA	TEST.L	D6		; commandes boa bouffes ?	JUMP',NE 90$		; oui => 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D6,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDBOA   >;--------/; Cherche la routine  excuter en fonction d'une commande boa.; in	A3.L	^commande; out	D7.W	erreur; mod	D7.WRDBOA:	PUSHM.L	D0..D5,A0..A4	LOAD.W	D7,#EREOUTB	; D7 <-- commande inconnue	LOAD.L	A4,#R16"TABOA$10$:	TEST.B	(A4)		; fin de la table ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	A2,A3		; A2 <-- ^commande cherche20$:	TEST.B	(A4)	JUMP',EQ 50$	COMP.B	(A4+),(A2+)	JUMP,EQ 20$30$:	TEST.B	(A4+)		; A4 <-- saute fin du .ASCIZ	JUMP,NE	30$	EX.L	D4,A4	INC.L	D4	TCLR.L	D4:#0		; A4 <-- saute .EVEN	EX.L	A4,D4	ADD.L	A4,#2		; A4 <-- saute .W	JUMP	10$50$:	LOAD.L	A3,A2		; A3 <-- ^paramtres ventuels	INC.L	A4		; A4 <-- saute le <0>	EX.L	D4,A4	INC.L	D4	TCLR.L	D4:#0		; A4 <-- saute .EVEN	EX.L	A4,D4	CLR.L	D2	LOAD.W	D2,(A4)		; D2 <-- adresse relative	LOAD.L	A2,(A6)+OSTART	; A2 <-- adresse absolue dbut du code	ADD.L	A2,D2		; A2 <-- adresse absolue	CLR.W	D7		; D7 <-- ok	CALL	(A2)		; appel routine ...90$:	POPM.L	D0..D5,A0..A4	TEST.W	D7		; retour EQ/NE	RETTABOA$:	.ASCIZ	"<BOA>g_"	.EVEN	.W	RDBOAGC	.ASCIZ	"<BOA>_"	.EVEN	.W	RDBOASOUL	.ASCIZ	"<BOA>biff;"	.EVEN	.W	RDBOABIFF	.ASCIZ	"<BOA>surl;"	.EVEN	.W	RDBOASURL	.ASCIZ	"<BOA>up;"	.EVEN	.W	RDBOAUP	.ASCIZ	"<BOA>down;"	.EVEN	.W	RDBOADOWN	.ASCIZ	"<BOA>color "	.EVEN	.W	RDBOACOLOR	.ASCIZ	"<BOA>define g_"	.EVEN	.W	RDBOADEF	.B	0	.EVEN;---------\\; RDBOADEF >;---------/; Dfinition d'un nouveau gencar.; in	A3.L	^paramtres; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOADEF:	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	DGENC_	SEARCH		; cherche si titre existe dj ?	JUMP,EQ 20$	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	DGENC_	FREE		; cherche gencar libre	JUMP',NE 90$20$:	LOAD.W	D7,#EREOUTB	LOAD.L	A1,A3		; A1 <-- ^titre25$:	LOAD.B	D3,(A3+)	; A3 <-- saute le titre	COMP.B	D3,#':	JUMP',EQ 30$	COMP.B	D3,#';	JUMP,EQ 90$	COMP.B	D3,#CR	JUMP,EQ 90$	COMP.B	D3,#',	JUMP,EQ 90$	JUMP	25$30$:	COMP.B	(A3+),#BOA	JUMP',NE 90$	LOAD.L	A2,A3		; A2 <-- ^fsctt	DGENC_	GET		; D5 <-- "-fst"	JUMP',NE 90$		; syntaxe pas correcte => 90$	LOAD.W	D7,#EREOUTB	COMP.B	(A3+),#';	JUMP',NE 90$	COMP.B	(A3+),#CR	JUMP',NE 90$	LOAD.L	(A4)+OGCCOD,D5	; OBUGC <-- "fst" compactifi	LOAD.L	A3,#(A4)+OGCTIT50$:	LOAD.B	(A3+),(A1+)	; OBUGC <-- titre	COMP.B	(A1)-1,#':	JUMP,NE	50$	CLR.B	(A3)-1	LOAD.L	A3,#(A4)+OGCNAM60$:	LOAD.B	(A3+),(A2+)	; OBUGC <-- fsctt	COMP.B	(A2)-1,#';	JUMP,NE	60$	CLR.B	(A3)-1	CALL	LODGC		; charge gencar si ncessaire90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDBOAGC >;--------/; Changement de gencar.; in	A3.L	^paramtres; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOAGC:	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	DGENC_	SEARCH		; cherche	JUMP,NE 90$	SL.L	D4,#CCGCSHI	AND.L	D4,#CCGCMSK	AND.L	(A6)+OIOLC,#-1-CCGCMSK	OR.L	(A6)+OIOLC,D490$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; RDBOASOUL >;----------/; Dbut/fin de soulignement.; in	-; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOASOUL:	LOAD.B	D3,#1		; D3 <-- mode soulign	JUMP'	RDBOASBS;----------\\; RDBOABIFF >;----------/; Dbut/fin de biff.; in	-; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOABIFF:	LOAD.B	D3,#2		; D3 <-- mode biff	JUMP'	RDBOASBS;----------\\; RDBOASURL >;----------/; Dbut/fin de surlignement.; in	-; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOASURL:	LOAD.B	D3,#3		; D3 <-- mode surlign;	JUMP'	RDBOASBSRDBOASBS:	TEST.B	(A6)+OFANIO+0:#BDBFBOA-24 ; option "filtre les commandes boa" ?	JUMP',BS 90$		; oui => 90$	LOAD.L	D4,(A6)+OIOLC	AND.L	D4,#CCSOMSK;	SR.L	D4,#CCSOSHI	SR.L	D4,#8	SR.L	D4,#CCSOSHI-8	TEST.B	D4	JUMP',EQ 50$	CLR.B	D3		; D3 <-- mode normal50$:;	SL.L	D3,#CCSOSHI	SL.L	D3,#8	SL.L	D3,#CCSOSHI-8	AND.L	D3,#CCSOMSK	AND.L	(A6)+OIOLC,#-1-CCSOMSK	OR.L	(A6)+OIOLC,D390$:	RET;--------\\; RDBOAUP >;--------/; Dbut d'exposant ou fin d'indice.; in	-; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOAUP:	LOAD.B	D3,#1		; D3 <-- mode exposant	JUMP'	RDBOAUD;----------\\; RDBOADOWN >;----------/; Dbut d'indice ou fin d'exposant.; in	-; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOADOWN:	LOAD.B	D3,#2		; D3 <-- mode indice;	JUMP'	RDBOAUDRDBOAUD:	LOAD.L	D4,(A6)+OIOLC	AND.L	D4,#CCEXMSK;	SR.L	D4,#CCEXSHI	SWAP.W	D4	TEST.B	D4	JUMP',EQ 50$	CLR.B	D3		; D3 <-- mode normal50$:;	SL.L	D3,#CCEXSHI	SWAP.W	D3	AND.L	D3,#CCEXMSK	AND.L	(A6)+OIOLC,#-1-CCEXMSK	OR.L	(A6)+OIOLC,D3	RET;-----------\\; RDBOACOLOR >;-----------/; Changement de couleur.; in	A3.L	^paramtres; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOACOLOR:	LOAD.W	D7,#EREOUTB	LOAD.B	D3,(A3)	SUB.B	D3,#'1	JUMP',LO 90$	COMP.B	D3,#8	JUMP',HS 90$;	SL.L	D3,#CCCOSHI	SWAP.W	D3	SL.L	D3,#CCCOSHI-16	AND.L	D3,#CCCOMSK	AND.L	(A6)+OIOLC,#-1-CCCOMSK	OR.L	(A6)+OIOLC,D3	CLR.W	D7		; D7 <-- ok90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOWRITE >;========/; Sauve toute une zone dans un fichier sur disque.; in	A5.L	^description zone;	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WIOWRITE:	PUSHM.L	D3..D5,A3	CALL	DBOXOPWAIT	; met la dbox d'attente	CALL	WROPEN		; ouvre le fichier en sortie	JUMP',NE 90$	CALL	WRHEAD		; crit l'en-tte	JUMP',NE 80$	CALL	BPSAUVE		; D4 <-- position actuelle	LOAD.W	D5,D4	CLR.L	D4	CALL	BQPOSITIONNE	; va au tout dbut20$:	CALL	BAVANCE		; D3 <-- un caractre	JUMP',NE 70$	CALL	WRCAR		; crit un caractre	JUMP',NE 80$	JUMP	20$70$:	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	LOAD.W	D4,D5	CALL	BPPREND		; retourne o l'on tait	POP.W	D7	CALL	WRCLOSE		; ferme le fichier en sortie90$:	POPM.L	D3..D5,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; IOZWRITE >;=========/; Sauve une partie de zone dans un fichier sur disque.; in	A5.L	^description zone;	A3.L	^nom du fichier;	D4.L	position de dbut;	D5.L	nombre de caractres; out	D7.W	erreur; mod	D7.WIOZWRITE:	PUSHM.L	D2..D5,A3	CALL	DBOXOPWAIT	; met la dbox d'attente	LOAD.L	D2,D5		; D2 <-- nb de caractres	CALL	WROPEN		; ouvre le fichier en sortie	JUMP',NE 90$	CALL	WRHEAD		; crit l'en-tte	JUMP',NE 80$	PUSH.L	D4	CALL	BPSAUVE		; D4 <-- position actuelle	LOAD.W	D5,D4	POP.L	D4	CALL	BQPOSITIONNE	; va au dbut de la zone20$:	CALL	BAVANCE		; D3 <-- un caractre	JUMP',NE 70$	CALL	WRCAR		; crit un caractre	JUMP',NE 80$	DEC.L	D2	JUMP,NE	20$70$:	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	LOAD.W	D4,D5	CALL	BPPREND		; retourne o l'on tait	POP.W	D7	CALL	WRCLOSE		; ferme le fichier en sortie90$:	POPM.L	D2..D5,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRHEAD  >;--------/; Ecrit l'en-tte.; in	-; out	D7.W	erreur; mod	D7.WWRHEAD:	PUSHM.L	D3,D4,A3,A4	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFANIO+0:#BDBLBOA-24 ; option "laisse les commandes boa" ?	JUMP,BS 90$		; oui => 90$	TEST.B	(A6)+OFANIO+0:#BDBFBOA-24 ; option "filtre les commandes boa" ?	JUMP,BS 90$		; oui => 90$	LOAD.L	A4,#(A6)+OBUGC	LOAD.W	D4,#MAXGC-120$:	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP',BC 80$	LOAD.L	A3,#R16"DEF1$	CALL	WRTEXT		; crit "<BOA>define g_"	JUMP',NE 90$	LOAD.L	A3,#(A4)+OGCTIT	CALL	WRTEXT		; crit le titre	JUMP',NE 90$	LOAD.L	A3,#R16"DEF2$	CALL	WRTEXT		; crit ":<BOA>"	JUMP',NE 90$	LOAD.L	A3,#(A4)+OGCNAM	CALL	WRTEXT		; crit le nom	JUMP',NE 90$	LOAD.L	A3,#R16"DEF3$	CALL	WRTEXT		; crit ";<CR>"	JUMP',NE 90$80$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^gencar suivant	DECJ.W,NMO D4,20$90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RETDEF1$:	.ASCIZ	"<BOA>define g_"DEF2$:	.ASCIZ	":<BOA>"DEF3$:	.ASCIZ	";<CR>"	.EVEN;--------\\; WRCAR   >;--------/; Ecrit un caractre, avec ventuellement quelques commandes boa; juste avant selon son mode.; in	D3.L	caractre; out	D7.W	erreur; mod	D7.WWRCAR:	PUSHM.L	D1..D4,A3	LOAD.L	D2,D3		; D2 <-- nouveau caractre	LOAD.L	D1,(A6)+OIOLC	; D1 <-- ancien caractre	XOR.L	D1,D2		; D1 <-- changements	CLR.B	D1	TEST.L	D1		; y'a-t-il des changements ?	JUMP,EQ 80$		; non => 80$	TEST.B	(A6)+OFANIO+0:#BDBFBOA-24 ; option "filtre les commandes boa" ?	JUMP,BS 80$		; oui => 80$; Ecrit une commande de caractre.	LOAD.L	D3,D1	AND.L	D3,#CCGCMSK	JUMP',EQ 20$	LOAD.L	A3,#R16"GCD$	CALL	WRTEXT		; crit "<BOA>g_"	JUMP,NE 90$	LOAD.L	D3,D2		; D3 <-- nouveau caractre	AND.L	D3,#CCGCMSK	SR.L	D3,#CCGCSHI	; D3 <-- nouveau gencar	LOAD.L	A3,#(A6)+OBUGC+OGCTIT	MUL.WU	D3,#LGGC	ADD.L	A3,D3	CALL	WRTEXT		; crit le titre du gencar	JUMP,NE 90$	LOAD.L	A3,#R16"GCF$	CALL	WRTEXT		; crit ";"	JUMP,NE 90$; Ecrit une commande de soulignement.20$:	LOAD.L	D3,D1	AND.L	D3,#CCSOMSK	JUMP',EQ 30$	LOAD.L	A3,#R16"SOUL$	LOAD.L	D3,(A6)+OIOLC	AND.L	D3,#CCSOMSK;	SR.L	D3,#CCSOSHI	SR.L	D3,#8	SR.L	D3,#CCSOSHI-8	CALL	WRLBOA		; crit fin de soulignement	JUMP,NE 90$	LOAD.L	D3,D2	AND.L	D3,#CCSOMSK;	SR.L	D3,#CCSOSHI	SR.L	D3,#8	SR.L	D3,#CCSOSHI-8	CALL	WRLBOA		; crit dbut de soulignement	JUMP,NE 90$; Ecrit une commande d'indice/exposant.30$:	LOAD.L	D3,D1	AND.L	D3,#CCEXMSK	JUMP',EQ 40$	LOAD.L	A3,#R16"EXPD$	LOAD.L	D3,(A6)+OIOLC	AND.L	D3,#CCEXMSK;	SR.L	D3,#CCEXSHI	SWAP.W	D3	CALL	WRLBOA		; crit fin d'exposant	JUMP,NE 90$	LOAD.L	A3,#R16"EXPF$	LOAD.L	D3,D2	AND.L	D3,#CCEXMSK;	SR.L	D3,#CCEXSHI	SWAP.W	D3	CALL	WRLBOA		; crit dbut d'exposant	JUMP,NE 90$; Ecrit une commande de couleur.40$:	LOAD.L	D3,D1	AND.L	D3,#CCCOMSK	JUMP',EQ 80$	LOAD.L	A3,#R16"COUL$	LOAD.L	D3,D2	AND.L	D3,#CCCOMSK;	SR.L	D3,#CCCOSHI	SWAP.W	D3	SR.L	D3,#4	CALL	WRLBOA		; crit couleur	JUMP,NE 90$; Ecrit le caractre.80$:	LOAD.L	D3,D2		; D3 <-- caractre	CALL	WRONE		; crit un caractre	JUMP',NE 90$	LOAD.L	(A6)+OIOLC,D3	; OIOLC <-- dernier caractre90$:	POPM.L	D1..D4,A3	TEST.W	D7		; retour EQ/NE	RETGCD$:	.ASCIZ	"<BOA>g_"GCF$:	.ASCIZ	";"SOUL$:	.ASCIZ	""	.ASCIZ	"<BOA>_"	.ASCIZ	"<BOA>biff;"	.ASCIZ	"<BOA>surl;"EXPD$:	.ASCIZ	""	.ASCIZ	"<BOA>down;"	.ASCIZ	"<BOA>up;"EXPF$:	.ASCIZ	""	.ASCIZ	"<BOA>up;"	.ASCIZ	"<BOA>down;"COUL$:	.ASCIZ	"<BOA>color 1;"	.ASCIZ	"<BOA>color 2;"	.ASCIZ	"<BOA>color 3;"	.ASCIZ	"<BOA>color 4;"	.ASCIZ	"<BOA>color 5;"	.ASCIZ	"<BOA>color 6;"	.ASCIZ	"<BOA>color 7;"	.ASCIZ	"<BOA>color 8;"	.EVEN;--------\\; RDOPEN  >;========/; Ouvre le fichier en entre.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WRDOPEN:	PUSHM.L	D0,D3,D6	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',NE 90$	LOAD.W	(A6)+OIOCH,D6	; mm. canal	LOAD.W	(A6)+OIOPT,#LTMIO	CLR.L	(A6)+OIOLC90$:	POPM.L	D0,D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDONE   >;========/; Lit un byte dans le fichier d'entre.; in	-; out	D3.B	byte lu;	D7.W	erreur; mod	D3.L, D7.WRDONE:	PUSHM.L	D4,D6,A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer tampon	COMP.W	(A6)+OIOPT,#LTMIO ; reste qq chose ?	JUMP',LO 50$		; oui => 50$				; non =>	LOAD.L	D4,#LTMIO	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?RDBYTE		; lit tout le buffer	LOAD.W	(A6)+OIONB,#-1	CLR.W	(A6)+OIOPT	; buffer vide	TEST.W	D7		; lecture ok ?	JUMP',EQ 50$		; oui => 50$	COMP.W	D7,#EROUTF	; fin du fichier ?	JUMP',NE 90$		; non => 90$	CLR.W	D7		; D7 <-- ok pour l'instant	LOAD.W	(A6)+OIONB,D4	; mm. lg dernire tranche50$:	TEST.W	(A6)+OIONB	; reste qq chose ?	JUMP',NE 60$		; oui => 60$	LOAD.W	D7,#EROUTF	; D7 <-- fin du fichier	JUMP'	90$60$:	LOAD.W	D4,(A6)+OIOPT	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- un byte du buffer	INC.W	(A6)+OIOPT	; avance "pointeur"	DEC.W	(A6)+OIONB	; diminue reste90$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDCLOSE >;========/; Ferme le fichier en entre.; in	D7.W	ok/erreur; out	D7.W	erreur; mod	D7.WRDCLOSE:	PUSHM.L	D5,D6	LOAD.W	D5,D7		; D5 <-- ok/erreur	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?CLOSE		; ferme le fichier	COMP.W	D7,D5	JUMP',HS 90$	LOAD.W	D7,D5		; D7 <-- erreur la plus grve !90$:	POPM.L	D5,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; WROPEN  >;========/; Ouvre le fichier en sortie.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WWROPEN:	PUSHM.L	D0,D3,D6	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',NE 90$	LOAD.W	(A6)+OIOCH,D6	; mm. canal	CLR.W	(A6)+OIOPT	; buffer vide	LOAD.L	(A6)+OIOLC,#CCGCMSK90$:	POPM.L	D0,D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRLBOA  >;========/; Ecrit la n-ime commande boa d'une liste.; in	A3.L	^liste de commandes boa;	D3.W	rang (0..n); out	D7.W	erreur; mod	D7.WWRLBOA:	PUSHM.L	D3,A310$:	DEC.W	D3	JUMP',NS 40$20$:	TEST.B	(A3+)		; A3 <-- ^texte suivant	JUMP,NE 20$	JUMP	10$40$:	CALL	WRTEXT		; crit la commande boa	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRTEXT  >;========/; Ecrit un texte (.ASCIZ) dans le fichier de sortie.; in	A3.L	^texte termin par <0>; out	D7.W	erreur; mod	D7.WWRTEXT:	PUSHM.L	D4,A3,A4	LOAD.L	A4,A3	LOAD.W	D4,#-110$:	INC.W	D4	TEST.B	(A3+)	JUMP,NE 10$	CALL	WRMANY		; crit tout le .ASCIZ	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRMANY  >;========/; Ecrit plusieurs bytes dans le fichier de sortie.; in	A4.L	^bytes  crire;	D4.W	nombre de bytes  crire; out	D7.W	erreur; mod	D7.WWRMANY:	PUSHM.L	D3,D4,D6,A2..A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A3,A4		; A3 <-- ^bytes  crire	LOAD.W	D3,D4		; D3 <-- nombre	JUMP,EQ 90$10$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OIOPT	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer20$:	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4+),(A3+)	; buffer <-- un byte	INC.W	D4		; D4 <-- un byte de plus	DEC.W	D3	JUMP,NE	20$	LOAD.W	(A6)+OIOPT,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OIOPT	; signal buffer vide	JUMP	10$90$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRONE   >;========/; Ecrit un byte dans le fichier de sortie.; in	D3.B	byte  crire; out	D7.W	erreur; mod	D7.WWRONE:	PUSHM.L	D4,D6,A2,A410$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OIOPT	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4),D3		; buffer <-- le byte	INC.W	D4		; D4 <-- un byte de plus	LOAD.W	(A6)+OIOPT,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OIOPT	; signal buffer vide	JUMP	10$90$:	POPM.L	D4,D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRCLOSE >;========/; Ecrit le reste du fichier de sortie, puis ferme.; in	D7.W	ok/erreur; out	D7.W	erreur; mod	D7.WWRCLOSE:	PUSHM.L	D4..D6,A4	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	LOAD.W	D5,D7		; D5 <-- ok/erreur	JUMP',NE 50$		; erreur => 50$				; ok =>	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer tampon	CLR.L	D4	LOAD.W	D4,(A6)+OIOPT	; D4 <-- nb bytes dans buffer	JUMP',EQ 50$		; si vide => 50$				; si reste qq chose =>	FOS	?WRBYTE		; crit tout le buffer	LOAD.W	D5,D750$:	FOS	?CLOSE		; ferme le fichier	COMP.W	D7,D5	JUMP',HS 90$	LOAD.W	D7,D5		; D7 <-- erreur la plus grve !90$:	POPM.L	D4..D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRINFO  >;========/; Ecrit sur disque le fichier des informations.; in	-; out	D7.W	erreur; mod	D7.WWRINFO:	PUSHM.L	D3,D4,D6,A2..A4	LOAD.L	A4,#(A6)+OIOTM+LFINFO	LOAD.W	D4,#(LFINFO/4)-110$:	CLR.L	(-A4)	DECJ.W,NMO D4,10$	LOAD.B	(A4)+OFMAJR,#MAJREV	LOAD.B	(A4)+OFMINR,#MINREV	LOAD.B	(A4)+OFPROR,#PROREV	LOAD.W	(A4)+OFLXTAB,(A6)+OLXTAB	LOAD.L	(A4)+OFDEF,(A6)+ODEF	LOAD.L	(A4)+OFDISP,(A6)+ODISP	LOAD.L	(A4)+OFCHFAN,(A6)+OCHFAN	LOAD.L	(A4)+OFFANIO,(A6)+OFANIO	LOAD.L	A3,#(A4)+OFBUEXT	LOAD.L	A2,#(A6)+OBUEXT30$:	LOAD.B	(A3+),(A2+)	JUMP,NE 30$	LOAD.L	D6,(A6)+OCIDICO	JUMP',EQ 40$	LOAD.W	D3,#1		; D3 <-- get	DICO_	DEF		; D4 <-- dfinitions du dictionnaire	LOAD.L	(A4)+OFFDICO,D440$:	LOAD.L	A3,#R16"NFINFO	FOS	?DELETE	LOAD.L	D3,#DEFATT-2^BATTL	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE 90$	LOAD.L	D4,#LFINFO	FOS	?WRBYTE	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDINFO  >;========/; Lit sur disque le fichier des informations.; in	-; out	D7.W	erreur; mod	D7.WRDINFO:	PUSHM.L	D3,D4,D6,A2..A4	LOAD.L	A3,#R16"NFINFO	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',EQ 10$	LOAD.W	D3,#2^BOPRD!2^BOPSYS	FOS	?OPEN	JUMP',NE 90$10$:	LOAD.L	A4,#(A6)+OIOTM	LOAD.L	D4,#LFINFO	FOS	?RDBYTE	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	JUMP',NE 90$	LOAD.W	(A6)+OLXTAB,(A4)+OFLXTAB	LOAD.L	(A6)+ODEF,(A4)+OFDEF	LOAD.L	(A6)+ODISP,(A4)+OFDISP	LOAD.L	(A6)+OCHFAN,(A4)+OFCHFAN	LOAD.L	(A6)+OFANIO,(A4)+OFFANIO	LOAD.L	(A6)+ODIDEF,(A4)+OFFDICO	LOAD.L	A3,#(A4)+OFBUEXT	LOAD.L	A2,#(A6)+OBUEXT30$:	LOAD.B	(A2+),(A3+)	JUMP,NE 30$90$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDMACRO >;========/; Essaye de lire le fichier des macros.; in	-; out	D7.W	erreur; mod	D7.WRDMACRO:	PUSHM.L	D2,A3..A5	LOAD.W	D2,#MACZONE	CALL	ZUSE		; A5 <-- ^descripteur zone macro	JUMP',NE 90$	LOAD.L	A3,#R16"NFMAC1	LOAD.L	A4,#(A5)+ODZNAM20$:	LOAD.B	(A4+),(A3+)	; ODZNAM <-- "PLUME.MACRO"	JUMP,NE 20$	LOAD.L	A3,#R16"NFMAC1	CALL	IOREAD2	JUMP',EQ 80$	COMP.W	D7,#ERFDNE	JUMP',NE 80$	LOAD.L	A3,#R16"NFMAC2	CALL	IOREAD280$:	TCLR.B	(A5)+ODZMAJ:#BMAJIO90$:	POPM.L	D2,A3..A5	TEST.W	D7		; retour EQ/NE	RETNFINFO:	.ASCIZ	"PLUME.INFO"NFMAC2:	.ASCII	"#:"NFMAC1:	.ASCIZ	"PLUME.MACRO"	.EVEN	.END