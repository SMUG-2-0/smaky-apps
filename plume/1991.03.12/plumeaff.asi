	.SBTTL	PLUMEAFF;---------\\; AINVCURS >;=========/; Inverse le curseur d'une zone.; in	A5.L	^description zone;	D4.W	0=enlve, 1=met; out	-; mod	D7.WAINVCURS:	PUSHM.L	D2..D4,A4	TEST.L	(A5)+ODZFBT	; zone existe ?	JUMP,EQ 90$		; non => 90$	TEST.W	(A5)+ODZCUH	; curseur existe ?	JUMP,EQ 90$		; non => 90$	LOAD.L	A4,#(A6)+OZONE1	; A4 <-- ^descripteur zone principale	COMP.L	A5,A4		; est-on dans la zone principale ?	JUMP',NE 30$		; non => 30$	TEST.W	D4		; enlve ?	JUMP',EQ 20$		; oui => 20$	LIB	?GETSHIFT	; D3 <-- touches super-shift	LOAD.B	(A5)+ODZCUS,D320$:	LOAD.B	D2,(A5)+ODZCUS	; D2 <-- dernires touches super-shift	TEST.L	D2:#BCURSOR	; touche (CURSOR) enfonce ?	JUMP',BS 50$		; oui =>	TEST.L	D2:#BSEARCH	; touche (SEARCH) enfonce ?	JUMP',BS 50$		; oui =>	TEST.L	D2:#BCHANGE	; touche (CHANGE) enfonce ?	JUMP',BS 50$		; oui =>30$:				; non =>	LOAD.L	D3,(A5)+ODZCUP	ADD.W	D3,(A5)+ODZWPO+2	SWAP.W	D3	ADD.W	D3,(A5)+ODZWPO+0	SWAP.W	D3	LOAD.W	D4,(A5)+ODZCUH	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRSEG		; inverse un petit curseur	JUMP'	90$50$:	LOAD.W	D3,(A5)+ODZWPO+0	SWAP.W	D3	LOAD.W	D3,(A5)+ODZWPO+2	ADD.W	D3,(A5)+ODZCUP+2	LOAD.W	D4,(A5)+ODZWDI+0	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRSEG		; trait vertical	LOAD.W	D3,(A5)+ODZWPO+0	ADD.W	D3,(A5)+ODZCUP+0	ADD.W	D3,(A5)+ODZCUB	SWAP.W	D3	LOAD.W	D3,(A5)+ODZWPO+2	SUB.W	D3,#CMGG2+1	CLR.L	D4	LOAD.W	D4,(A5)+ODZWDI+2	ADD.W	D4,#CMGG2+1;	LOAD.W	D2,#INVDOT	LIB	?DRSEG		; trait horizontal90$:	POPM.L	D2..D4,A4	RET;--------\\; AREFAIT >;========/; Signale qu'une zone doit tre entirement repeinte.; in	A5.L	^description zone; out	-; mod	D7.WAREFAIT:	PUSHM.L	D3,D4,A3	TEST.L	(A5)+ODZFBT	; zone existe ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A3,#(A5)+ODZCL	; A3 <-- ^table des checks	LOAD.W	D3,#LCL*MAXCL	SR.W	D3,#2		; D3 <-- /4 car .L	DEC.W	D3		; D3 <-- -1 car NMO	CLR.L	D420$:	LOAD.L	(A3+),D4	DECJ.W,NMO D3,20$	TSET.B	(A5)+ODZMAJ:#BMAJAF ; affichage plus  jour90$:	POPM.L	D3,D4,A3	RET;---------\\; ADISPLAY >;=========/; Affiche une partie de texte dans une zone rectangulaire.; in	A5.L	^description zone; out	-; mod	D7.WADISPLAY:	PUSHM.L	D0..D6,A3,A4	LOAD.L	A3,#(A6)+OZONE1	COMP.L	A5,A3	JUMP',EQ 10$	LOAD.L	A3,#(A6)+OZONE2	COMP.L	A5,A3		; est-ce une zone visible ?	JUMP,NE 99$		; non => 99$10$:	TEST.L	(A5)+ODZFBT	; zone existe ?	JUMP,EQ 99$		; non => 99$	CALL	AOPEWDO		; ouvre la swdo	LOAD.L	(A5)+ODZCUL,(A5)+ODZPOS ; ODZCUL <-- position du curseur	LOAD.L	D4,(A5)+ODZWDI	; D4 <-- dimensions (dy;dx)	CALL	AQUICKLINES	; affichage rapide possible ?	JUMP,EQ 50$		; oui => 50$	LOAD.L	A4,(A5)+ODZALP	; A4 <-- ^premire ligne dans ODZAL	LOAD.L	D3,(A4)+OALPOS	; D3 <-- position premire ligne dans buffer	LOAD.L	D4,(A5)+ODZWDI	; D4 <-- dimensions (dy;dx)	CALL	ATABLINES	; ODZAL <-- dbuts des lignes	JUMP,NE 95$;	LOAD.L	D4,(A5)+ODZWDI	; D4 <-- dimensions (dy;dx)	CALL	ASLOWLINES	; affichage rapide possible ?	JUMP,EQ 50$		; oui => 50$	CALL	CCMO		; enlve la souris	CALL	BPSAUVE		; sauve la position du curseur	PUSH.W	D4	CLR.L	D3		; D3 <-- coin sup/gauche	LOAD.W	D6,(A5)+ODZWDI+2 ; D6 <-- largeur de la fentre; Affiche toutes les lignes.	LOAD.L	A4,(A5)+ODZALP	; A4 <-- ^premire ligne dans ODZAL	LOAD.L	A3,#(A5)+ODZCL	; A3 <-- ^table des checks20$:	LOAD.L	D4,(A4)+OALPOS	; D4 <-- position dans buffer	LOAD.L	D2,(A4)+LAL+OALPOS	SUB.L	D2,D4		; D2 <-- nombre de caractres	TEST.W	(A4)+OALH2	JUMP,EQ 30$	CLR.L	D5	LOAD.B	D5,(A4)+OALH2	SWAP.W	D5	LOAD.B	D5,(A4)+OALH1	; D5 <-- h2|h1	CALL	BQPOSITIONNE	; va (rapidement) au dbut de la ligne	LOAD.L	D0,D4	CALL	BCHECK	EX.L	D0,D4		; D0 <-- valeur de check	LOAD.L	D7,(A5)+ODZCUL	; D7 <-- position du curseur	SUB.L	D7,D4	JUMP',LO 23$	COMP.L	D7,D2		; curseur dans cette ligne ?	JUMP',LS 24$		; oui => 24$23$:	LOAD.L	D7,D3	SWAP.W	D7	COMP.W	D7,(A3)+OCLPOY	; mme position en Y ?	JUMP',NE 24$		; non => 24$	COMP.L	D0,(A3)+OCLCHK	; mme valeur de check ?	JUMP',EQ 25$		; oui => 25$24$:	CALL	ADISLINE	; affiche une ligne complte	LOAD.L	(A3)+OCLCHK,D0	LOAD.L	D0,D3	SWAP.W	D0	LOAD.W	(A3)+OCLPOY,D025$:	LOAD.L	A3,#(A3)+LCL	; A3 <-- ^check suivant	LOAD.L	A4,#(A4)+LAL	; A4 <-- ^ligne suivante	SWAP.W	D3	ADD.W	D3,D5	SWAP.W	D5	ADD.W	D3,D5		; D3 <-- coordonne plus basse	LOAD.W	D2,D3	SWAP.W	D3	COMP.W	D2,(A5)+ODZWDI+0 ; est-on tout en bas ?	JUMP,LO	20$		; non => 20$	JUMP'	40$30$:	CLR.W	D2		; D2 <-- aucun caractre	LOAD.L	D5,D3	CLR.W	D5	SWAP.W	D5	SUB.W	D5,(A5)+ODZWDI+0	NEG.W	D5		; D5 <-- zro|hauteur restante (pour h1|h2)	CALL	ADISLINE	; efface la fin de l'cran; Vide la fin de la table des checks.40$:	LOAD.L	A4,#(A5)+ODZCL	LOAD.L	D4,#LCL*MAXCL	ADD.L	D4,A4	SUB.L	D4,A3	SR.W	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMO42$:	CLR.W	(A3+)	DECJ.W,NMO D4,42$	POP.W	D4	CALL	BPPREND		; retourne o on tait au tout dbut	CALL	SCMO		; remet la souris	JUMP	90$; Affichage ultra-rapide, avec scroll si ncessaire.50$:	LOAD.W	D3,D4	CALL	CCMO		; enlve la souris	CALL	BPSAUVE		; sauve la position du curseur	PUSH.W	D4	LOAD.W	D4,D3	CALL	ADISROLL	; scroll de la fentre	TEST.W	D4	JUMP,EQ 82$	JUMP,NC 70$; Met encore  jour quelques lignes en haut de l'cran.60$:	LOAD.L	A4,(A5)+ODZALP	; A4 <-- ^premire ligne dans ODZAL	LOAD.W	D1,D4	NEG.W	D1	CLR.L	D3		; D3 <-- coin sup/gauche	LOAD.W	D6,(A5)+ODZWDI+2 ; D6 <-- largeur de la fentre66$:	LOAD.L	D4,(A4)+OALPOS	; D4 <-- position dans buffer	LOAD.L	D2,(A4)+LAL+OALPOS	SUB.L	D2,D4		; D2 <-- nombre de caractres	TEST.W	(A4)+OALH2	JUMP,EQ 80$	CLR.L	D5	LOAD.B	D5,(A4)+OALH2	SWAP.W	D5	LOAD.B	D5,(A4)+OALH1	; D5 <-- h2|h1	CALL	BQPOSITIONNE	; va (rapidement) au dbut de la ligne	CALL	ADISLINE	; affiche une ligne en haut de la fentre	LOAD.L	A4,#(A4)+LAL	; A4 <-- ^ligne suivante	SWAP.W	D3	ADD.W	D3,D5	SWAP.W	D5	ADD.W	D3,D5		; D3 <-- coordonne plus basse	LOAD.W	D2,D3	SWAP.W	D3	COMP.W	D2,D1		; a-t-on affich assez de lignes ?	JUMP,LO 66$		; non => 66$	JUMP	80$; Met encore  jour quelques lignes en bas de l'cran.70$:	LOAD.L	A4,(A5)+ODZALP	; A4 <-- ^premire ligne dans ODZAL	SUB.W	D4,(A5)+ODZWDI+0	NEG.W	D4		; D4 <-- hauteur dj  jour ( cause scroll)	CLR.W	D372$:	CLR.W	D2	ADD.B	D2,(A4)+OALH1	ADD.B	D2,(A4)+OALH2	; D2 <-- hauteur (h1+h2)	ADD.W	D3,D2		; D3 <-- position en Y suivante	COMP.W	D3,D4	JUMP',HI 74$	ADD.L	A4,#LAL	JUMP	72$74$:	SUB.W	D3,D2	SWAP.W	D3	CLR.W	D3		; D3 <-- coin sup/gauche	LOAD.W	D6,(A5)+ODZWDI+2 ; D6 <-- largeur de la fentre76$:	LOAD.L	D4,(A4)+OALPOS	; D4 <-- position dans buffer	LOAD.L	D2,(A4)+LAL+OALPOS	SUB.L	D2,D4		; D2 <-- nombre de caractres	TEST.W	(A4)+OALH2	JUMP,EQ 80$	CLR.L	D5	LOAD.B	D5,(A4)+OALH2	SWAP.W	D5	LOAD.B	D5,(A4)+OALH1	; D5 <-- h2|h1	CALL	BQPOSITIONNE	; va (rapidement) au dbut de la ligne	CALL	ADISLINE	; affiche une ligne en bas de la fentre	LOAD.L	A4,#(A4)+LAL	; A4 <-- ^ligne suivante	SWAP.W	D3	ADD.W	D3,D5	SWAP.W	D5	ADD.W	D3,D5		; D3 <-- coordonne plus basse	LOAD.W	D2,D3	SWAP.W	D3	COMP.W	D2,(A5)+ODZWDI+0 ; est-on tout en bas ?	JUMP,LO 76$		; non => 76$;	JUMP'	80$80$:	CALL	AREFAIT		; ODZCL n'est plus  jour !82$:	POP.W	D4	CALL	BPPREND		; retourne o on tait au tout dbut	CALL	SCMO		; remet la souris90$:	CALL	APOSCURS	; calcule la position du curseur	TCLR.B	(A5)+ODZMAJ:#BMAJAF ; affichage  jour95$:	CALL	ACLOWDO		; ferme la swdo99$:	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; ADISLINE >;---------/; Affiche juste une ligne.; in	D2.W	nombre de caractres  afficher (0..n);	D3.L	coordonne coin sup/gauche (y;x);	D4.L	position dbut ligne dans buffer;	D5.L	h2|h1, donc hauteur (dy);	D6.W	largeur (dx); out	-; mod	D7.WADISLINE:	PUSHM.L	D2..D4,A4	PUSH.L	D3		; stack <-- coin sup/gauche	LOAD.L	D4,D3		; D4 <-- position initiale	SWAP.W	D4	ADD.W	D4,D5	SWAP.W	D4	TEST.W	D2		; caractres  afficher ?	JUMP',EQ 50$		; non => 50$30$:	CALL	BAVANCE		; D3 <-- caractre suivant	JUMP',NE 50$	CALL	PTBGC		; A4 <-- ^dans OBUGC	LOAD.L	A4,(A4)+OGCPT	; A4 <-- ^gencar	CALL	ADISCAR		; bitmap <-- un caractre	DEC.W	D2	JUMP,NE	30$50$:	POP.L	D3		; D3 <-- coin sup/gauche	CALL	ADISEFEOL	; efface la fin de la ligne	POPM.L	D2..D4,A4	RET;--------\\; ADISCAR >;--------/; Dessine un caractre dans l'cran, en effaant ce qui s'y trouvait avant.; in	D3.L	caractre  afficher;	D4.L	position (y;x);	D5.L	h2|h1;	A4.L	^gencar; out	D3.L	caractre affich;	D4.L	position suivante (y;x); mod	D3.L, D4.L, D7.WADISCAR:	PUSHM.L	D5,D6	SWAP.W	D4	PUSH.W	D4	SWAP.W	D4	LOAD.L	D6,D3	AND.L	D6,#CCEXMSK	JUMP',EQ NOEXP$	SWAP.W	D6	COMP.W	D6,#2	JUMP',EQ IND$EXP$:				; exposant =>	CLR.L	D6	LOAD.W	D6,D5	DIV.WU	D6,#3		; D6 <-- 0.33*h1	SWAP.W	D4	SUB.W	D4,D6	SWAP.W	D4	SUB.W	D5,D6	SWAP.W	D5	ADD.W	D5,D6	SWAP.W	D5	JUMP'	NOEXP$IND$:				; indice =>	CLR.L	D6	LOAD.W	D6,D5	DIV.WU	D6,#3		; D6 <-- 0.33*h1	SWAP.W	D4	ADD.W	D4,D6	SWAP.W	D4	ADD.W	D5,D6	SWAP.W	D5	SUB.W	D5,D6	SWAP.W	D5NOEXP$:	LOAD.L	D6,D4		; D6 <-- position de dpart	COMP.B	D3,#TAB	JUMP',EQ TAB$	COMP.B	D3,#CR	JUMP',EQ CR$	COMP.B	D3,#LF	JUMP',EQ LF$	JUMP'	QQ$TAB$:	CALL	ADISTAB		; affiche un tabulateur	JUMP	90$CR$:	TEST.B	(A6)+ODISP+3:#BDICR-0	JUMP',BS QQ$	LOAD.B	D3,#SPACE	JUMP'	QQ$LF$:	TEST.B	(A6)+ODISP+3:#BDILF-0	JUMP',BS QQ$	LOAD.B	D3,#SPACE;	JUMP'	QQ$QQ$:	PUSHM.L	D0..D3,D5,A1..A4	PUSH.L	D4		; stack <-- position (y;x)	LOAD.L	A3,A4		; A3 <-- ^gencar; Cherche quel est le caractre  afficher, d'aprs le premier caractre; contenu dans le gnrateur (OGCFCA).	CLR.W	D0	LOAD.B	D0,D3		; D0 <-- code du caractre	COMP.B	D0,(A3)+OGCLCA	; code caractre trop grand ?	JUMP,HI 80$		; oui => 80$	SUB.B	D0,(A3)+OGCFCA	; code caractre trop petit ?	JUMP,LO 80$		; oui => 80$; Calcule la position sup/gauche et les dimensions du pav contenant; le caractre. La largeur dpend du caractre.;	SUB.W	D4,(A3)+OGCLMA	; D4 <-- coordonne  gauche	SWAP.W	D4	SUB.W	D4,(A3)+OGCMH1	; D4 <-- coordonne en haut	SWAP.W	D4	LOAD.W	D2,(A3)+OGCMHD	; D2 <-- hauteur du caractre	SWAP.W	D2	CLR.W	D2	LOAD.L	A2,#(A3)+OGCWID	; A2 <-- ^table des largeurs	LOAD.B	D2,(A2)+(D0.W)	; D2 <-- largeur du caractre	ADD.W	(SP)+2,D2	; stack <-- position suivante; Efface ventuellement en dessus et en dessous du caractre.	LOAD.L	D1,D5	SWAP.W	D1	ADD.W	D1,D5		; D1 <-- h1+h2	LOAD.L	D3,D2	SWAP.W	D3	COMP.W	D3,D1		; caractre occupe toute la hauteur ?	JUMP,EQ 50$		; oui => 50$				; non =>	PUSH.L	D4	LOAD.L	D3,D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,D5	SUB.W	D3,(A3)+OGCMH1	JUMP',EQ 40$	SUB.W	D4,D3	SWAP.W	D4	SWAP.W	D3	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OCLEAR	CALL	(A1)		; GRA_CLEAR: efface en-dessus40$:	POP.L	D4	PUSH.L	D4	LOAD.L	D3,D2	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D5	LOAD.W	D3,D5	SWAP.W	D5	SUB.W	D3,(A3)+OGCMH2	JUMP',EQ 45$	SWAP.W	D4	SWAP.W	D3	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OCLEAR	CALL	(A1)		; GRA_CLEAR: efface en-dessous45$:	POP.L	D4; Calcule les paramtres permettant d'appeler directement GRA_RASTER, et; non GRA_MATRIX, pour aller plus vite !50$:	CLR.L	D3		; D3 <-- position dans source	CLR.W	D5	LOAD.B	D5,(A3)+OGCMWB	; D5 <-- incrment Y dans gencar	CLR.L	D1	LOAD.B	D1,(A3)+OGCLCA	SUB.B	D1,(A3)+OGCFCA	INC.B	D1		; D1 <-- nb car dans gnrateur	LOAD.L	A2,#(A3)+OGCWID	; A2 <-- ^table des largeurs	ADD.L	A2,D1		; A2 <-- skip width(s)	ADD.L	A2,D1		; A2 <-- swip heigth(s) above baseline	ADD.L	A2,D1		; A2 <-- swip heigth(s) under baseline	MUL.WU	D0,(A3)+OGCMSB	; * matrix size (in bytes)	ADD.L	A2,D0		; A2 <-- ^matrix dans GENCAR	LOAD.L	A3,A2		; A3 <-- ^source	LOAD.L	A4,#0		; A4 <-- ^destination (dans l'cran)	LOAD.W	D1,#LOADDOT	; D1 <-- mode d'affichage	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; GRA_RASTER: dessine un caractre ...; Avance la position du caractre plus loin vers la droite.80$:	POP.L	D4		; D4 <-- position suivante	POPM.L	D0..D3,D5,A1..A490$:	CALL	ADISCARSOUL	; souligne v. le caractre	COMP.L	(A5)+ODZZOD,#-1	; zone slectionne existe ?	JUMP',EQ 95$		; non => 95$	CALL	ADISCARINV	; inverse v. le caractre95$:	SWAP.W	D4	POP.W	D4	SWAP.W	D4	POPM.L	D5,D6	RET;------------\\; ADISCARSOUL >;------------/; Souligne ventuellement un caractre.; in	D3.L	caractre  afficher;	D6.L	position dbut (y;x);	D4.L	position arrive (y;x);	D5.L	h2|h1; out	-; mod	D7.WADISCARSOUL:	PUSHM.L	D1..D4,A1,A2	AND.L	D3,#CCSOMSK	; D3 <-- masque	JUMP,EQ 90$	SR.L	D3,#8	SR.L	D3,#CCSOSHI-8	; D3 <-- type du soulign	LOAD.W	D2,D3	CLR.L	D3		; D3 <-- hauteur (dy)	LOAD.W	D3,D4	SUB.W	D3,D6		; D3 <-- longueur (dx)	LOAD.L	D4,D6		; D4 <-- origine (y;x)	SWAP.W	D4	DEC.W	D2	JUMP',EQ 30$	DEC.W	D2	JUMP',EQ 40$	DEC.W	D2	JUMP',EQ 50$	JUMP'	90$30$:				; soulign =>	INC.W	D4	JUMP'	70$40$:				; biff =>	CLR.L	D2	LOAD.W	D2,D5	DIV.WU	D2,#3	SUB.W	D4,D2	JUMP'	70$50$:				; surlign =>	SUB.W	D4,D5;	JUMP'	70$70$:	SWAP.W	D4	LOAD.W	D1,#SETDOT	; D1 <-- mode	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OLINE	CALL	(A1)		; GRA_LINE: souligne le caractre90$:	POPM.L	D1..D4,A1,A2	RET;-----------\\; ADISCARINV >;-----------/; Inverse un caractre s'il est dans la zone slectionne.; in	D6.L	position dbut (y;x);	D4.L	position arrive (y;x);	D5.L	h2|h1; out	-; mod	D7.WADISCARINV:	PUSHM.L	D3,D4,A1,A2	LOAD.L	D3,(A5)+ODZPOS	DEC.L	D3	COMP.L	D3,(A5)+ODZZOD	JUMP',LO 90$	COMP.L	D3,(A5)+ODZZOF	JUMP',HS 90$	LOAD.W	D3,D5	SWAP.W	D5	ADD.W	D3,D5		; D3 <-- hauteur dY	SWAP.W	D5	SWAP.W	D3	LOAD.W	D3,D4	SUB.W	D3,D6		; D3 <-- largeur dX	LOAD.L	D4,D6		; D4 <-- origine	SWAP.W	D4	SUB.W	D4,D5	SWAP.W	D4	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OINV	CALL	(A1)		; GRA_INV: inverse le caractre90$:	POPM.L	D3,D4,A1,A2	RET;--------\\; ADISTAB >;--------/; Dessine un tabulateur dans l'cran, en effaant ce qui s'y trouvait avant.; in	D4.L	position (y;x);	D5.L	h2|h1;	A4.L	^gencar; out	D4.L	position suivante (y;x); mod	D4.L, D7.WADISTAB:	PUSHM.L	D1,D3,A1,A2	PUSH.L	D4		; stack <-- position (y;x); Efface tout l'emplacement occup par le tabulateur.	CLR.L	D3	LOAD.W	D3,D4	DIV.WU	D3,(A6)+OLXTAB	INC.W	D3	MUL.WU	D3,(A6)+OLXTAB	; D3 <-- position suivante en X	LOAD.W	(SP)+2,D3	; stack <-- position suivante	SWAP.W	D4	SUB.W	D4,D5		; D4 <-- origine en Y	SWAP.W	D4	SUB.W	D3,D4		; D3 <-- largeur dX	SWAP.W	D3	LOAD.W	D3,D5	SWAP.W	D5	ADD.W	D3,D5		; D3 <-- hauteur dY (h1+h2)	SWAP.W	D5	SWAP.W	D3	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OCLEAR	CALL	(A1)		; GRA_CLEAR: affiche le tabulateur; Affiche une petite flche pointille dans le tabulateur.	TEST.B	(A6)+ODISP+3:#BDITAB-0	JUMP,BC 80$	LOAD.B	(A2)+ODFTTM,#B'00100010	LOAD.B	(A2)+ODFTTS,#1	ADD.W	D4,D3	DEC.W	D4	NEG.W	D3	SWAP.W	D3	SWAP.W	D4	SR.W	D3,#1	ADD.W	D4,D3	CLR.W	D3	SWAP.W	D4	SWAP.W	D3	LOAD.W	D1,#SETDOT!TTTDOT	LOAD.L	A1,(A6)+OLINE	CALL	(A1)		; GRA_LINE: ligne horizontale pointille	LOAD.B	(A2)+ODFTTM,#B'01010101;	LOAD.B	(A2)+ODFTTS,#1	LOAD.W	D3,#-3	SWAP.W	D3	LOAD.W	D3,#-5;	LOAD.W	D1,#SETDOT!TTTDOT;	LOAD.L	A1,(A6)+OLINE	CALL	(A1)		; GRA_LINE: partie suprieure flche	LOAD.W	D3,#+3	SWAP.W	D3	LOAD.W	D3,#-5;	LOAD.W	D1,#SETDOT!TTTDOT;	LOAD.L	A1,(A6)+OLINE	CALL	(A1)		; GRA_LINE: partie infrieure flche80$:	POP.L	D4		; D4 <-- position suivante	POPM.L	D1,D3,A1,A2	RET;----------\\; ADISEFEOL >;----------/; Efface la fin de la ligne.; in	D3.L	coordonne coin sup/gauche (y;x);	D4.L	position dernier caractre affich;	D5.L	h2|h1, donc hauteur (dy);	D6.W	largeur (dx); out	-; mod	D7.WADISEFEOL:	PUSHM.L	D3,D4,A1,A2	SWAP.W	D4	SUB.W	D4,D5		; D4 <-- origine en Y	SWAP.W	D4	ADD.W	D3,D6	SUB.W	D3,D4		; D3 <-- largeur dX	JUMP',LE 90$	SWAP.W	D3	LOAD.W	D3,D5	SWAP.W	D5	ADD.W	D3,D5		; D3 <-- hauteur dY (h1+h2)	SWAP.W	D5	SWAP.W	D3	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OCLEAR	CALL	(A1)		; GRA_CLEAR: efface la fin de la ligne90$:	POPM.L	D3,D4,A1,A2	RET;---------\\; ADISROLL >;---------/; Scroll rapide de la fentre contre en haut ou contre en bas.; in	D4.W	+/- amplitude du scroll; out	-; mod	D7.WADISROLL:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBUDIS+1	TEST.W	D4	JUMP',EQ 90$	JUMP',NS 20$	LOAD.B	(A3)+0,#ROLLUP	LOAD.W	(A3)+1,D4	JUMP'	30$20$:	LOAD.B	(A3)+0,#ROLLDOWN	NEG.W	D4	LOAD.W	(A3)+1,D430$:	LOAD.W	D3,#3	LIB	?STRING90$:	POPM.L	D3,D4,A3	RET;---------\\; APOSCURS >;=========/; Cherche la position (dans la fentre) et les dimensions du curseur.; in	A5.L	^description zone; out	-; mod	D7.WAPOSCURS:	PUSHM.L	D0..D5,A4	CALL	BPSAUVE		; sauve la position du curseur	PUSH.W	D4	CLR.W	(A5)+ODZCUH	; pas (encore) de curseur; Cherche dans quelle ligne est le curseur.	LOAD.L	A4,(A5)+ODZALP	; A4 <-- ^premire ligne dans ODZAL	LOAD.L	D0,(A5)+ODZCUL	; D0 <-- position du curseur	CLR.W	D1		; D1 <-- position Y20$:	TEST.W	(A4)+LAL+OALH2	JUMP',EQ 30$	COMP.L	D0,(A4)+LAL+OALPOS ; curseur dans cette ligne ?	JUMP',LO 30$		; oui => 30$	CLR.W	D2	ADD.B	D2,(A4)+OALH1	ADD.B	D2,(A4)+OALH2	; D2 <-- hauteur (h1+h2)	ADD.W	D1,D2		; D1 <-- position Y suivante	ADD.L	A4,#LAL	JUMP	20$; Cherche o mettre le curseur dans la ligne.30$:	LOAD.L	D4,(A4)+OALPOS	CALL	BQPOSITIONNE	; va (rapidement) en dbut de ligne	CLR.W	D2		; D2 <-- position X initiale40$:	COMP.L	D0,(A5)+ODZPOS	JUMP',EQ 50$	CALL	BAVANCE		; D3 <-- caractre suivant	JUMP',NE 50$	CALL	ADIMCAR		; D4 <-- largeur, D5 <-- h2|h1	ADD.W	D2,D4		; D2 <-- position suivante	JUMP	40$50$:	CLR.L	D5	LOAD.B	D5,(A4)+OALH2	SWAP.W	D5	LOAD.B	D5,(A4)+OALH1	; D5 <-- h2|h1	TEST.L	D5	JUMP',NE 52$	CLR.W	D2	LOAD.L	D3,#'A	CALL	ADIMCAR		; D4 <-- largeur, D5 <-- h2|h152$:	LOAD.W	(A5)+ODZCUB,D5	; ODZCUB <-- h1	LOAD.W	D4,D5	SWAP.W	D5	ADD.W	D4,D5	LOAD.W	(A5)+ODZCUH,D4	; ODZCUH <-- h1+h2	COMP.L	D0,(A5)+ODZNBC	; est-on tout  la fin ?	JUMP',NE 62$		; non => 62$	CALL	BRECULE		; D3 <-- dernier caractre	JUMP',NE 62$	COMP.B	D3,#CR	JUMP',EQ 60$	COMP.B	D3,#LF	JUMP',NE 62$60$:	ADD.W	D1,D4		; D1 <-- position Y suivante	CLR.W	D2		; D2 <-- position X tout  gauche62$:	LOAD.W	(A5)+ODZCUP+0,D1	LOAD.W	(A5)+ODZCUP+2,D2	POP.W	D4	CALL	BPPREND		; retourne o on tait au tout dbut	POPM.L	D0..D5,A4	RET;--------\\; AOPEWDO >;--------/; Ouvre la sous-fentre.; in	A5.L	^description zone; out	-; mod	D7.WAOPEWDO:	PUSHM.L	D3,D5,A3	LOAD.L	A3,#R16"MNO$	LOAD.W	D3,#2	LIB	?STRING		; plus de modulos	LOAD.W	D5,(A5)+ODZWNO	LIB	?USEWDO		; utilise la swdo	LOAD.L	A3,#R16"MYES$	LOAD.W	D3,#2	LIB	?STRING		; remet les modulos	POPM.L	D3,D5,A3	RETMNO$:	.B	MMODULO,1	; non pour les modulosMYES$:	.B	MMODULO,0	; oui pour les modulos	.EVEN;--------\\; ACLOWDO >;--------/; Ferme la sous-fentre.; in	A5.L	^description zone; out	-; mod	D7.WACLOWDO:	PUSH.L	D5	CLR.W	D5	LIB	?USEWDO		; utilise la swdo principale	POP.L	D5	RET;---------\\; AOPEZONE >;=========/; Dbut de l'inversion d'une zone.; in	A5.L	^description zone; out	-; mod	D7.WAOPEZONE:	PUSH.L	D4	CALL	BPSAUVE		; D4 <-- position du curseur	LOAD.W	(A5)+ODZZOP,D4	LOAD.L	(A5)+ODZZOD,#-1	POP.L	D4	RET;---------\\; AMODZONE >;=========/; Modifie (agrandi ou diminue) l'inversion d'une zone.; in	A5.L	^description zone;	D4.L	position dbut zone;	D5.L	position fin zone; out	-; mod	D7.WAMODZONE:	PUSHM.L	D4,D5	COMP.L	(A5)+ODZZOD,#-1	JUMP',EQ 40$	COMP.L	D4,D5		; D4 avant D5 ?	JUMP',LS 10$		; oui => 10$	EX.L	D4,D510$:	PUSH.L	D5	LOAD.L	D5,(A5)+ODZZOD	CALL	AINVZONE	POP.L	D5	PUSH.L	D4	LOAD.L	D4,(A5)+ODZZOF	CALL	AINVZONE	POP.L	D4	JUMP'	80$40$:	CALL	AINVZONE80$:	LOAD.L	(A5)+ODZZOD,D4	LOAD.L	(A5)+ODZZOF,D5	POPM.L	D4,D5	RET;---------\\; AGETZONE >;=========/; Donne des informations sur la zone inverse.; in	A5.L	^description zone; out	D4.L	position dbut;	D5.L	nombre de caractres; mod	D4.L, D5.L, D7.WAGETZONE:	LOAD.L	D4,(A5)+ODZZOD	; D4 <-- position de dbut	LOAD.L	D5,(A5)+ODZZOF	COMP.L	D4,D5	JUMP',LS 20$	EX.L	D4,D520$:	SUB.L	D5,D4		; D5 <-- nombre de caractres	RET;---------\\; ACLOZONE >;=========/; Fin de l'inversion d'une zone (efface).; in	A5.L	^description zone; out	-; mod	D7.WACLOZONE:	PUSHM.L	D4,D5	COMP.L	(A5)+ODZZOD,#-1	JUMP',EQ 90$	LOAD.L	D4,(A5)+ODZZOD	LOAD.L	D5,(A5)+ODZZOF	CALL	AINVZONE	; efface la dernire zone	LOAD.W	D4,(A5)+ODZZOP	; D4 <-- position o tait le curseur	CALL	BPPREND		; remet le curseur o il tait	LOAD.L	(A5)+ODZZOD,#-190$:	POPM.L	D4,D5	RET;---------\\; AINVZONE >;---------/; Inverse une zone mise en vidence avec la souris.; in	A5.L	^description zone;	D4.L	position dbut zone;	D5.L	position fin zone; out	-; mod	D7.WAINVZONE:	PUSHM.L	D1..D5,A4	COMP.L	D4,D5		; D4 avant D5 ?	JUMP,EQ 90$	JUMP',LO 10$		; oui => 10$	EX.L	D4,D510$:	LOAD.L	D2,D4	CALL	BPSAUVE		; sauve la position	PUSH.W	D4		; stack <-- position actuelle	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfini une trame pour inverser	LOAD.L	D4,D2	LOAD.L	A4,(A5)+ODZALP	; A4 <-- ^premire ligne dans ODZAL	CLR.W	D3		; D3 <-- coordonne Y20$:	TEST.W	(A4)+OALH2	; fin de la table ?	JUMP,EQ 80$		; oui => 80$	LOAD.L	D1,(A4)+OALPOS	; D1 <-- position dbut ligne	LOAD.L	D2,(A4)+LAL+OALPOS ; D2 <-- position fin ligne	COMP.L	D5,D1	JUMP',LO 30$	COMP.L	D4,D2	JUMP',HS 30$	PUSHM.L	D4,D5	COMP.L	D4,D1	JUMP',HS 25$	LOAD.L	D4,D125$:	COMP.L	D5,D2	JUMP',LS 26$	LOAD.L	D5,D226$:	CALL	AINVZLIN	; inverse dans la ligne	POPM.L	D4,D530$:	CLR.W	D2	LOAD.B	D2,(A4)+OALH1	ADD.W	D3,D2		; D3 <-- ajoute h1	LOAD.B	D2,(A4)+OALH2	ADD.W	D3,D2		; D3 <-- ajoute h2	COMP.W	D3,(A5)+ODZWDI+0 ; dpasse en bas ?	JUMP',HS 80$		; oui => 80$	ADD.L	A4,#LAL		; A4 <-- ^ligne suivante	JUMP	20$80$:	POP.W	D4		; D4 <-- position	CALL	BPPREND		; retourne o l'on tait90$:	POPM.L	D1..D5,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; AINVZLIN >;---------/; Inverse une zone dans une ligne.; in	A4.L	^ligne dans ODZAL;	D3.W	coordonne Y dbut ligne;	D4.L	position dbut;	D5.L	position fin; out	-; mod	D7.WAINVZLIN:	PUSHM.L	D0..D6	PUSH.W	D3		; stack <-- coordonne Y	LOAD.L	D6,D4	LOAD.W	D0,#-1		; D0 <-- position dbut pas trouve	LOAD.W	D1,D0		; D1 <-- position fin pas trouve	LOAD.L	D4,(A4)+OALPOS	CALL	BQPOSITIONNE	; va (rapidement) en dbut de ligne	CLR.W	D2		; D2 <-- position X initiale20$:	COMP.L	D6,(A5)+ODZPOS	JUMP',NE 22$	LOAD.W	D0,D2		; D0 <-- position X dbut22$:	COMP.L	D5,(A5)+ODZPOS	JUMP',NE 24$	LOAD.W	D1,D2		; D1 <-- position X fin	JUMP'	30$24$:	CALL	BAVANCE		; D3 <-- caractre suivant	JUMP',NE 30$	PUSH.L	D5	CALL	ADIMCAR		; D4 <-- largeur, D5 <-- h2|h1	POP.L	D5	ADD.W	D2,D4		; D2 <-- position suivante	JUMP	20$30$:	COMP.W	D0,#-1		; dbut trouv ?	JUMP,EQ 90$		; non => 90$	COMP.W	D1,#-1		; fin trouv ?	JUMP',NE 40$		; oui => 40$	LOAD.W	D1,D2		; D1 <-- fin tout  la fin de la ligne40$:	LOAD.W	D3,(SP)+0	; D3 <-- origine Y	ADD.W	D3,(A5)+ODZWPO+0	SWAP.W	D3	LOAD.W	D3,D0		; D3 <-- origine X	ADD.W	D3,(A5)+ODZWPO+2	CLR.W	D4	ADD.B	D4,(A4)+OALH1	ADD.B	D4,(A4)+OALH2	; D4 <-- hauteur dY	SWAP.W	D4	LOAD.W	D4,D1	SUB.W	D4,D0		; D4 <-- largeur dX	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A5)+ODZWPO+0	ADD.W	D2,(A5)+ODZWDI+0	SUB.W	D2,D3		; D2 <-- hauteur maximale	COMP.W	D4,D2		; zone trop haute ?	JUMP',LS 60$		; non => 60$	LOAD.W	D4,D2		; D4 <--maximum permis60$:	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	; inverse dans la ligne90$:	POP.W	D3		; ajuste le stack	POPM.L	D0..D6	RET;-----------\\; AROLLMOUSE >;===========/; Effectue un scroll si la souris dpasse en haut ou en bas dans le cadre.; in	A5.L	^description zone;	D4.L	position de la souris; out	-; mod	D7.WAROLLMOUSE:	PUSHM.L	D4,D5	SWAP.W	D4	LOAD.W	D5,#-1		; D5 <-- recule d'une ligne	SUB.W	D4,(A5)+ODZWPO+0	JUMP',LO 40$	LOAD.W	D5,#+1		; D5 <-- avance d'une ligne	SUB.W	D4,(A5)+ODZWDI+0	JUMP',LO 90$40$:	LOAD.W	D4,D5		; D4 <-- +/- dplacement	CLR.W	D5		; D5 <-- va au dbut de la ligne	CALL	AMOVEXY		; dplace le curseur	CALL	ADISPLAY	; met  jour l'cran90$:	POPM.L	D4,D5	TEST.W	D7		; retour EQ/NE	RET;----------\\; ADETMOUSE >;==========/; Dtecte sur quel caractre est la souris.; in	A5.L	^description zone;	D3.W	mode;		  2^0 --> normal / inclu le CR/LF;		  2^1 --> normal / ok mme si en dehors fentre;	D4.L	position de la souris; out	D4.L	position dans le texte;	D7.W	erreur; mod	D4.L, D7.WADETMOUSE:	PUSHM.L	D0..D3,D5,D6,A4	LOAD.W	D7,#EREOUTB	; D7 <-- pas trouv	TEST.L	(A5)+ODZFBT	; zone existe ?	JUMP,EQ 90$		; non => 90$	LOAD.W	D0,D3		; D0 <-- mode; Regarde si la souris est dans le rectangle de la fentre du texte.	LOAD.W	D3,(A5)+ODZWPO+2	SUB.W	D3,#CMGG2	COMP.W	D4,D3		; trop  gauche ?	JUMP,LO 90$	SUB.W	D4,(A5)+ODZWPO+2	JUMP',NC 10$	CLR.W	D410$:	COMP.W	D4,(A5)+ODZWDI+2 ; trop  droite ?	JUMP,HI 90$	SWAP.W	D4	SUB.W	D4,(A5)+ODZWPO+0 ; trop haut ?	JUMP',HS 12$	TEST.L	D0:#1		; ok mme si en dehors ?	JUMP,BC 90$		; non => 90$	CLR.W	D412$:	COMP.W	D4,(A5)+ODZWDI+0 ; trop bas ?	JUMP',LO 14$	TEST.L	D0:#1		; ok mme si en dehors ?	JUMP,BC 90$		; non => 90$	LOAD.W	D4,(A5)+ODZWDI+0	DEC.W	D414$:; Cherche dans quelle ligne est la souris.	LOAD.L	A4,(A5)+ODZALP	; A4 <-- ^premire ligne dans ODZAL	CLR.W	D320$:	TEST.W	(A4)+OALH2	; fin de la table ?	JUMP',EQ 40$		; oui => 40$	CLR.W	D2	LOAD.B	D2,(A4)+OALH1	ADD.W	D3,D2		; D3 <-- ajoute h1	LOAD.B	D2,(A4)+OALH2	ADD.W	D3,D2		; D3 <-- ajoute h2	COMP.W	D4,D3		; est-on dans cette ligne ?	JUMP',LO 40$		; oui => 40$	ADD.L	A4,#LAL		; A4 <-- ^ligne suivante	JUMP	20$; Cherche sur quel caractre est la souris.40$:	SWAP.W	D4	LOAD.W	D6,D4		; D6 <-- position en X de la souris	LOAD.L	D4,(A5)+ODZNBC	; D4 <-- position tout  la fin	TEST.W	(A4)+OALH2	; est-on tout  la fin ?	JUMP,EQ 80$		; oui => 80$	CALL	BPSAUVE		; sauve la position	PUSH.W	D4		; stack <-- position actuelle	LOAD.L	D4,(A4)+OALPOS	; D4 <-- position en dbut de ligne	CALL	BQPOSITIONNE	; va (rapidement) en dbut de ligne	LOAD.L	D1,(A4)+LAL+OALPOS	SUB.L	D1,D4		; D1 <-- nb max de caractres46$:	CLR.W	D2		; D2 <-- position X initiale50$:	CALL	BAVANCE		; D3 <-- caractre suivant	JUMP',NE 60$	CALL	ADIMCAR		; D4 <-- largeur, D5 <-- h2|h1	ADD.W	D2,D4		; D2 <-- position suivante	SR.W	D4,#1	SUB.W	D4,D2	NEG.W	D4		; D4 <-- position au milieu du caractre	COMP.W	D6,D4		; souris dans ce caractre ?	JUMP',LO 58$		; oui => 58$	DEC.W	D1		; encore un caractre ?	JUMP,NE 50$		; oui => 50$	TEST.L	D0:#0		; inclu le dernier CR/LF ?	JUMP',BC 58$		; non => 58$	COMP.B	D3,#CR	JUMP',EQ 60$	COMP.B	D3,#LF	JUMP',EQ 60$58$:	CALL	BRECULE60$:	LOAD.L	D3,(A5)+ODZPOS	POP.W	D4		; D4 <-- position	CALL	BPPREND		; retourne o l'on tait	LOAD.L	D4,D3		; D4 <-- position trouve80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D3,D5,D6,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; AGETPOSX >;=========/; Donne la position horizontale (en points) o est le curseur.; in	A5.L	^description zone; out	D5.W	position horizontale (positive et en points); mod	D5.L, D7.WAGETPOSX:	PUSHM.L	D1..D4,A4	CALL	BPSAUVE		; D4 <-- position du curseur	PUSH.W	D4; Cherche dans quelle ligne est le curseur.	LOAD.L	A4,(A5)+ODZALP	; A4 <-- ^premire ligne dans ODZAL	LOAD.L	D1,(A5)+ODZPOS	; D1 <-- position du curseur20$:	TEST.W	(A4)+LAL+OALH2	JUMP',EQ 30$	COMP.L	D1,(A4)+LAL+OALPOS ; curseur dans cette ligne ?	JUMP',LO 30$		; oui => 30$	ADD.L	A4,#LAL	JUMP	20$; Cherche o est le curseur dans la ligne.30$:	LOAD.L	D4,(A4)+OALPOS	CALL	BQPOSITIONNE	; va (rapidement) en dbut de ligne	CLR.W	D2		; D2 <-- position X initiale32$:	COMP.L	D1,(A5)+ODZPOS	JUMP',EQ 36$	CALL	BAVANCE		; D3 <-- caractre suivant	JUMP',NE 36$	CALL	ADIMCAR		; D4 <-- largeur, D5 <-- h2|h1	ADD.W	D2,D4		; D2 <-- position suivante	JUMP	32$36$:	LOAD.W	D5,D2		; D5 <-- position en X	POP.W	D4	CALL	BPPREND		; remet le curseur o il tait	POPM.L	D1..D4,A4	RET;--------\\; AMOVEXY >;========/; Dplace le curseur en x-y dans l'cran.; in	A5.L	^description zone;	D4.W	nombre de lignes  monter (-) ou descendre (+);	D5.W	position horizontale (positive et en points); out	D7.W	erreur; mod	D7.WAMOVEXY:	PUSHM.L	D1..D5,A3,A4	LOAD.W	D7,#EREOUTB	; D7 <-- impossible; Cherche dans quelle ligne est le curseur.	LOAD.L	A4,(A5)+ODZALP	; A4 <-- ^premire ligne dans ODZAL	LOAD.L	D3,(A5)+ODZPOS	; D3 <-- position du curseur20$:	TEST.W	(A4)+LAL+OALH2	JUMP',EQ 30$	COMP.L	D3,(A4)+LAL+OALPOS ; curseur dans cette ligne ?	JUMP',LO 30$		; oui => 30$	ADD.L	A4,#LAL	JUMP	20$; Monte ou descend de quelques lignes.30$:	TEST.W	D4	JUMP',EQ 50$	JUMP',NS 40$32$:				; descend =>	TEST.W	(A4)+OALH2	JUMP,EQ 90$	ADD.L	A4,#LAL		; A4 <-- ^ligne suivante	DEC.W	D4	JUMP,NE 32$	JUMP'	50$40$:				; monte =>	LOAD.L	A3,#(A5)+ODZAL42$:	COMP.L	A4,A3	JUMP,EQ 90$	SUB.L	A4,#LAL		; A4  <-- ^ligne prcdente	INC.W	D4	JUMP,NE 42$; Cherche o mettre le curseur dans la ligne.50$:	LOAD.L	D4,(A4)+OALPOS	CALL	BPOSITIONNE	; va en dbut de ligne	LOAD.L	D1,(A4)+LAL+OALPOS	SUB.L	D1,D4		; D1 <-- nb max de caractres  avancer	CLR.W	D2		; D2 <-- position X initiale52$:	COMP.W	D2,D5	JUMP',HS 56$	CALL	BAVANCE		; D3 <-- caractre suivant	JUMP',NE 56$	PUSH.L	D5	CALL	ADIMCAR		; D4 <-- largeur, D5 <-- h2|h1	POP.L	D5	ADD.W	D2,D4		; D2 <-- position suivante	DEC.L	D1	JUMP,NE	52$	CALL	BRECULE56$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; AQUICKLINES >;============/; Calcule rapidement tous les dbuts de lignes  afficher.; La table ODZAL n'est pas recalcule, car on sait qu'entre cet; affichage et le prcdent, il ne s'est produit que des; dplacements de curseur (ODZMAJ:#BMAJAF) !; in	A5.L	^description zone;	D4.L	dimensions de la fentre (dy;dx); out	D4.W	valeur du scroll (+/-);	D7.W	erreur; mod	D4.L, D7.WAQUICKLINES:	PUSHM.L	D3,D5,D6,A3,A4	LOAD.W	D7,#EREOUTB	; D7 <-- on n'y arrive pas avec cette table	LOAD.L	D6,D4		; D6 <-- dimensions de la fentre	TEST.B	(A5)+ODZMAJ:#BMAJAF ; affichage  jour ?	JUMP,BS 90$		; non => 90$; Cherche la premire ligne  afficher.; Cherche d'abord la ligne o est le curseur.	LOAD.L	A4,#(A5)+ODZAL	LOAD.L	A3,A4	LOAD.L	D4,(A5)+ODZCUL	; D4 <-- position du curseur20$:	TEST.W	(A4)+OALH2	JUMP,EQ 90$	LOAD.L	D3,(A4)+OALPOS	COMP.L	D4,D3		; curseur avant cette ligne ?	JUMP',LO 24$		; oui => 24$	LOAD.L	D3,(A4)+LAL+OALPOS	COMP.L	D4,D3		; curseur dans cette ligne ?	JUMP',LO 30$		; oui => 30$24$:	LOAD.L	A4,#(A4)+LAL	JUMP	20$; Descend ensuite de 1/2 hauteur contre le bas.30$:	LOAD.L	D5,D6	SWAP.W	D5	SR.W	D5,#1		; D5 <-- 1/2 hauteur	CLR.W	D432$:	TEST.W	(A4)+LAL+OALH2	JUMP',NE 34$	LOAD.L	D3,(A4)+OALPOS	COMP.L	D3,(A5)+ODZNBC	JUMP',EQ 40$	JUMP	90$34$:	CLR.W	D3	LOAD.B	D3,(A4)+OALH1	ADD.B	D3,(A4)+OALH2	ADD.W	D4,D3	LOAD.L	A4,#(A4)+LAL	; A4 <-- ^ligne suivante	COMP.W	D4,D5	JUMP,LO 32$; Remonte finalement de 1 hauteur contre le haut.40$:	LOAD.L	D5,D6	SWAP.W	D5		; D5 <-- 1 hauteur	CLR.W	D442$:	LOAD.L	A4,#(A4)-LAL	; A4 <-- ^ligne prcdente	CLR.W	D3	LOAD.B	D3,(A4)+OALH1	ADD.B	D3,(A4)+OALH2	ADD.W	D4,D3	COMP.W	D4,D5	JUMP',HS 44$	COMP.L	A4,A3	JUMP,NE 42$	TEST.L	(A4)+OALPOS	JUMP',EQ 50$	JUMP'	90$44$:	LOAD.L	A4,#(A4)+LAL	; A4 <-- ^ligne suivante; Calcule la valeur positive ou ngative du scroll  effectuer.50$:	LOAD.L	A3,(A5)+ODZALP	LOAD.L	(A5)+ODZALP,A4	; ODZALP <-- ^premire ligne	CALL	ASCROLLLINES	; D4 <-- +/- amplitude90$:	POPM.L	D3,D5,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ASLOWLINES >;===========/; Regarde, en fonction de la nouvelle table ODZAL calcule, s'il est; quand mme possible d'afficher "rapidement", c'est--dire avec un; scroll de la partie inchange.; in	A5.L	^description zone;	D4.L	dimensions de la fentre (dy;dx);	D3.L	position premire ligne dans buffer; out	D4.W	valeur du scroll (+/-);	D7.W	erreur; mod	D4.L, D7.WASLOWLINES:	PUSHM.L	D6,A3,A4	LOAD.W	D7,#EREOUTB	; D7 <-- on n'y arrive pas avec cette table	LOAD.L	D6,D4		; D6 <-- dimensions de la fentre	TEST.B	(A5)+ODZMAJ:#BMAJAF ; affichage  jour ?	JUMP',BS 90$		; non => 90$; Cherche dans la nouvelle table ODZAL l'lment qui correspondait;  l'ancien dbut d'affichage.	LOAD.L	A3,#(A5)+ODZAL20$:	TEST.W	(A3)+OALH2	JUMP',EQ 90$	COMP.L	D3,(A3)+OALPOS	JUMP',EQ 24$	ADD.L	A3,#LAL	JUMP	20$24$:	LOAD.L	A4,(A5)+ODZALP	; A4 <-- ^premire ligne dans ODZAL; Calcule la valeur positive ou ngative du scroll  effectuer.	CALL	ASCROLLLINES	; D4 <-- +/- amplitude90$:	POPM.L	D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; ASCROLLLINES >;-------------/; Calcule l'amplitude (+/-) ncessaire pour le scroll.; in	A3.L	^dans ODZAL ancien dbut d'affichage;	A4.L	^dans ODZAL nouveau dbut d'affichage;	D6.L	dimensions de la fentre (dy;dx); out	D4.W	valeur du scroll (+/-);	D7.W	erreur; mod	D4.L, D7.WASCROLLLINES:	PUSHM.L	D3,D5,A3,A4	LOAD.W	D7,#EREOUTB	; D7 <-- on n'y arrive pas	LOAD.L	D5,D6	SWAP.W	D5		; D5 <-- hauteur de la fentre	CLR.W	D4		; D4 <-- pas de scroll (idem)	COMP.L	A3,A4	JUMP',EQ 80$	JUMP',LO 40$30$:				; curseur mont =>	CLR.W	D3	ADD.B	D3,(A4)+OALH1	ADD.B	D3,(A4)+OALH2	; D3 <-- hauteur h1+h2	ADD.W	D4,D3	ADD.L	A4,#LAL	COMP.L	A4,A3	JUMP,NE 30$	COMP.W	D4,D5		; scroll trop grand ?	JUMP',HS 90$		; oui => 90$	NEG.W	D4	JUMP'	80$40$:				; curseur descendu =>	CLR.W	D3	ADD.B	D3,(A3)+OALH1	ADD.B	D3,(A3)+OALH2	; D3 <-- hauteur h1+h2	ADD.W	D4,D3	ADD.L	A3,#LAL	COMP.L	A3,A4	JUMP,NE 40$	COMP.W	D4,D5		; scroll trop grand ?	JUMP',HS 90$		; oui => 90$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; ATABLINES >;==========/; Calcule tous les dbuts de lignes  afficher.; in	A5.L	^description zone;	D4.L	dimensions de la fentre (dy;dx); out	D7.W	erreur; mod	D7.WATABLINES:	PUSHM.L	D1..D6,A3,A4	LOAD.L	D6,D4		; D6 <-- dimensions de la fentre	CALL	BPSAUVE		; sauve la position du curseur	PUSH.W	D4; Va au dbut du paragraphe courant.10$:	CALL	BRECULE		; revient au dbut du paragraphe	JUMP',NE 12$	COMP.B	D3,#CR	JUMP',EQ 11$	COMP.B	D3,#LF	JUMP,NE 10$11$:	CALL	BAVANCE12$:	CLR.W	(A6)+OAHSUP	CLR.W	(A6)+OAHINF	CLR.W	(A5)+ODZALN	; table ODZAL vide; Cherche tous les dbuts de lignes contre en haut.	CLR.W	D2		; D2 <-- premier paragraphe20$:	CALL	BPSAUVE	LOAD.W	D3,D4	CALL	ATABPARA	; comptabilise un paragraphe	COMP.W	D7,#ERELINE	JUMP,EQ 80$	TEST.W	D2		; est-ce le premier paragraphe ?	JUMP',NE 22$		; non => 22$	CALL	BPSAUVE	LOAD.W	D1,D4		; D1 <-- position fin du premier paragraphe22$:	LOAD.W	D4,D3	CALL	BPPREND		; revient au dbut du paragraphe	CALL	BRECULE	JUMP',NE 30$24$:	CALL	BRECULE		; va au dbut du paragraphe prcdent	JUMP',NE 26$	COMP.B	D3,#CR	JUMP',EQ 25$	COMP.B	D3,#LF	JUMP,NE 24$25$:	CALL	BAVANCE26$:	INC.W	D2		; D2 <-- plus le premier paragraphe	LOAD.L	D3,D6	SWAP.W	D3	COMP.W	D3,(A6)+OAHSUP	; est-on assez mont ?	JUMP,HS 20$		; non => 20$; Cherche tous les dbuts de lignes contre en bas.30$:	LOAD.W	D4,D1	CALL	BPPREND		; va  la fin du premier paragraphe32$:	CALL	ATABPARA	; comptabilise un paragraphe	COMP.W	D7,#ERELINE	JUMP,EQ 80$	TEST.W	D7	JUMP',NE 40$	LOAD.L	D3,D6	SWAP.W	D3	COMP.W	D3,(A6)+OAHINF	; est-on assez descendu ?	JUMP,HS 32$		; non => 32$40$:	LOAD.L	A4,#(A5)+ODZAL	LOAD.W	D4,(A5)+ODZALN	MUL.WU	D4,#LAL	ADD.L	A4,D4		; A4 <-- ^aprs le dernier lment dans ODZAL	LOAD.L	(A4)+OALPOS,(A4)+OALPOS-LAL	CLR.W	(A4)+OALH2; Cherche la premire ligne  afficher.; Cherche d'abord la ligne o est le curseur.	LOAD.L	A4,#(A5)+ODZAL	LOAD.L	A3,A4	LOAD.L	D4,(A5)+ODZCUL	; D4 <-- position du curseur50$:	TEST.W	(A4)+OALH2	JUMP',EQ 54$	LOAD.L	D3,(A4)+OALPOS	COMP.L	D4,D3		; curseur avant cette ligne ?	JUMP',LO 52$		; oui => 52$	LOAD.L	D3,(A4)+LAL+OALPOS	COMP.L	D4,D3		; curseur dans cette ligne ?	JUMP',LO 54$		; oui => 54$52$:	LOAD.L	A4,#(A4)+LAL	JUMP	50$; Descend ensuite de 1/2 hauteur contre le bas.54$:	LOAD.L	D5,D6	SWAP.W	D5	SR.W	D5,#1		; D5 <-- 1/2 hauteur	CLR.W	D456$:	TEST.W	(A4)+OALH2	JUMP',EQ 60$	CLR.W	D3	LOAD.B	D3,(A4)+OALH1	ADD.B	D3,(A4)+OALH2	ADD.W	D4,D3	LOAD.L	A4,#(A4)+LAL	; A4 <-- ^ligne suivante	COMP.W	D4,D5	JUMP,LO 56$; Remonte finalement de 1 hauteur contre le haut.60$:	LOAD.L	D5,D6	SWAP.W	D5		; D5 <-- 1 hauteur	CLR.W	D462$:	COMP.L	A4,A3	JUMP',EQ 66$	LOAD.L	A4,#(A4)-LAL	; A4 <-- ^ligne prcdente	CLR.W	D3	LOAD.B	D3,(A4)+OALH1	ADD.B	D3,(A4)+OALH2	ADD.W	D4,D3	COMP.W	D4,D5	JUMP,LO 62$	LOAD.L	A4,#(A4)+LAL	; A4 <-- ^ligne suivante66$:	CLR.W	D7		; D7 <-- ok80$:	LOAD.W	D6,D7	POP.W	D4	CALL	BPPREND		; retourne o on tait au tout dbut	LOAD.W	D7,D6		; D7 <-- ok/erreur	LOAD.L	(A5)+ODZALP,A4	; ODZALP <-- ^premire ligne	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; ATABPARA >;---------/; Comptabilise toutes les lignes d'un paragraphe.; in	A5.L	^description zone;	D6.L	dimensions de la fentre (dy;dx); out	D7.W	erreur; mod	D7.WATABPARA:	PUSHM.L	D1..D510$:	CALL	BINFO		; D4 <-- position, D5 <-- nb car	LOAD.L	D3,D4		; D3 <-- position dbut ligne	LOAD.W	D4,D6		; D4 <-- largeur pour la ligne	CALL	ANEXTLINE	; D4 <-- nb car, D5 <-- h2|h1	JUMP',EQ 20$	CLR.L	D5		; D5 <-- h2|h1 dernire ligne vide20$:	LOAD.W	D1,D7		; D1 <-- ok/fini	CALL	ATABINSL	; ODZAL <-- paramtres	JUMP',NE 90$	LOAD.W	D7,D1		; fini ?	JUMP',NE 90$		; oui => 90$	COMP.L	D3,(A5)+ODZCUL	; est-on en-dessous du curseur ?	JUMP',HI 40$		; oui => 40$	ADD.W	(A6)+OAHSUP,D5	SWAP.W	D5	ADD.W	(A6)+OAHSUP,D5	JUMP'	50$40$:	ADD.W	(A6)+OAHINF,D5	SWAP.W	D5	ADD.W	(A6)+OAHINF,D550$:	CALL	BRECULE	PUSH.W	D3	CALL	BAVANCE	POP.W	D3	COMP.B	D3,#CR		; fin du paragraphe ?	JUMP',EQ 80$		; oui => 10$	COMP.B	D3,#LF	JUMP,NE 10$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; ATABINSL >;---------/; Insre un lment dans la table OALxxx.; in	D3.L	position;	D5.L	h2|h1; out	D7.W	erreur; mod	D7.WATABINSL:	PUSHM.L	D4,A3,A4; Cherche o insrer dans la table.	LOAD.W	D7,#ERELINE	; D7 <-- trop de lignes	LOAD.L	A3,#(A5)+ODZAL	LOAD.W	D4,(A5)+ODZALN	JUMP',EQ 20$	COMP.W	D4,#MAXAL-1	JUMP,HS 90$10$:;	COMP.L	D3,(A3)+OALPOS	COMP.L	D3,(A3)	JUMP',LO 20$	ADD.L	A3,#LAL		; A3 <-- ^lment suivant	DEC.W	D4	JUMP,NE 10$; Insre dans la table.20$:	LOAD.L	A4,#(A5)+ODZAL	LOAD.W	D4,(A5)+ODZALN	MUL.WU	D4,#LAL	ADD.L	A4,D4		; A4 <-- ^fin du buffer	LOAD.L	D4,A4	SUB.L	D4,A3		; D4 <-- nb de bytes  pousser	JUMP',EQ 50$	DIV.WU	D4,#LAL		; D4 <-- nb d'lments  pousser	DEC.W	D4		; D4 <-- -1  cause NMO	LOAD.L	A3,#(A4)+LAL30$:	LOAD.W	(-A3),(-A4)	; pousse OALH2 et OALH1	LOAD.L	(-A3),(-A4)	; pousse OALPOS	DECJ.W,NMO D4,30$	LOAD.L	A3,A450$:	LOAD.L	(A3)+OALPOS,D3	; OALPOS <-- position dbut ligne	LOAD.B	(A3)+OALH1,D5	; OALH1  <-- h1	SWAP.W	D5	LOAD.B	(A3)+OALH2,D5	; OALH2  <-- h2	SWAP.W	D5	INC.W	(A5)+ODZALN	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; ANEXTLINE >;==========/; Avance le curseur au dbut de la ligne suivante.; in	A5.L	^description zone;	D4.W	largeur maximale pour la ligne (pts); out	D5.L	h2|h1 max;	D7.W	erreur; mod	D5.L, D7.WANEXTLINE:	PUSHM.L	D0..D4,D6	SUB.L	SP,#4		; stack <-- place pour variables	CLR.W	D2		; D2 <-- position dans la ligne	LOAD.W	D1,D4		; D1 <-- largeur maximale	CLR.L	D0		; D0 <-- flags	CLR.L	D6		; D6 <-- h2|h1 max10$:	CLR.W	D0		; D0 <-- dbut d'un mot	LOAD.L	(SP)+0,D6	; stack <-- h2|h1 max20$:	CALL	BAVANCE		; D3 <-- caractre suivant	JUMP,NE 70$	INC.W	D0	CALL	ADIMCAR		; D4 <-- largeur, D5 <-- h2|h1	ADD.W	D2,D4		; D2 <-- position suivante	COMP.W	D2,D1		; est-on au bout de la ligne ?	JUMP,HI 40$		; oui => 40$	COMP.W	D6,D5	JUMP',HS 22$	LOAD.W	D6,D5		; D6 <-- h1 max22$:	SWAP.W	D5	SWAP.W	D6	COMP.W	D6,D5	JUMP',HS 23$	LOAD.W	D6,D5		; D6 <-- h2 max23$:	SWAP.W	D5	SWAP.W	D6	COMP.B	D3,#CR	JUMP,EQ 80$	COMP.B	D3,#LF	JUMP,EQ 80$	COMP.B	D3,#SPACE	JUMP,EQ 20$30$:	CALL	BAVANCE		; D3 <-- caractre suivant	JUMP,NE 70$	INC.W	D0	CALL	ADIMCAR		; D4 <-- largeur, D5 <-- h2|h1	ADD.W	D2,D4		; D2 <-- position suivante	COMP.W	D2,D1		; est-on au bout de la ligne ?	JUMP,HI 40$		; oui => 40$	COMP.W	D6,D5	JUMP',HS 32$	LOAD.W	D6,D5		; D6 <-- h1 max32$:	SWAP.W	D5	SWAP.W	D6	COMP.W	D6,D5	JUMP',HS 33$	LOAD.W	D6,D5		; D6 <-- h2 max33$:	SWAP.W	D5	SWAP.W	D6	COMP.B	D3,#CR	JUMP',EQ 80$	COMP.B	D3,#LF	JUMP',EQ 80$	COMP.B	D3,#SPACE	JUMP,NE 30$	TSET.L	D0:#16		; D0 <-- au moins un espace	JUMP	10$40$:	TEST.L	D0:#16		; au moins un espace rencontr ?	JUMP',BC 44$		; non => 44$42$:	CALL	BRECULE		; recule le mot avanc en trop	DEC.W	D0	JUMP,NE 42$	LOAD.L	D6,(SP)+0	; D6 <-- h2|h1 max	JUMP'	80$44$:	CALL	BRECULE		; recule juste le caractre avanc en trop	JUMP'	80$70$:	TEST.W	D2		; au moins un caractre avanc ?	JUMP',EQ 90$		; non => 90$80$:	LOAD.L	D5,D6		; D5 <-- h2|h1 max	CLR.W	D7		; D7 <-- ok90$:	ADD.L	SP,#4		; stack <-- supprime les variables	POPM.L	D0..D4,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; ADIMCAR >;--------/; Donne les dimensions d'un caractre.; in	D2.W	position en X dans la ligne;	D3.L	caractre complet; out	D4.W	largeur;	D5.L	h2|h1; mod	D4.L, D5.L, D7.WADIMCAR:	PUSHM.L	D3,A4	CALL	PTBGC		; A4 <-- ^dans OBUGC	LOAD.W	D5,(A4)+OGC2Y	; D5 <-- h2	SWAP.W	D5	LOAD.W	D5,(A4)+OGC1Y	; D5 <-- h1	LOAD.L	D4,D3	AND.L	D4,#CCEXMSK	JUMP',EQ NOEXP$	SWAP.W	D4	COMP.W	D4,#2	JUMP',EQ IND$EXP$:				; exposant =>	LOAD.W	D4,D5	SR.W	D4,#1		; D4 <-- 0.5*h1	ADD.W	D5,D4	JUMP'	NOEXP$IND$:				; indice =>	LOAD.W	D4,D5	SR.W	D4,#1		; D4 <-- 0.5*h1	SWAP.W	D5	ADD.W	D5,D4	SWAP.W	D5NOEXP$:	CLR.W	D4		; D4 <-- largeur nulle	COMP.B	D3,#TAB	JUMP',EQ 40$	LOAD.L	A4,(A4)+OGCPT	; A4 <-- ^gencar	COMP.B	D3,(A4)+OGCLCA	JUMP',HI 90$	SUB.B	D3,(A4)+OGCFCA	JUMP',LO 90$	AND.W	D3,#H'FF	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.B	D4,(A4)+(D3.W)	; D4 <-- largeur du caractre	JUMP'	90$40$:				; tabulateur =>	CLR.L	D3	LOAD.W	D3,D2	DIV.WU	D3,(A6)+OLXTAB	INC.W	D3	MUL.WU	D3,(A6)+OLXTAB	; D3 <-- position suivante en X	LOAD.W	D4,D3	SUB.W	D4,D2		; D4 <-- largeur90$:	POPM.L	D3,A4	RET	.END