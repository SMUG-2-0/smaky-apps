	.SBTTL	PLUMEMOUSEKCLICG:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D5,D4	CLR.W	D3		; D3 <-- mode normal	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	LOAD.L	D4,D5	CALL	ADETMOUSE	; D4 <-- position dans le texte	JUMP',EQ POS0$	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	LOAD.L	D4,D5	CALL	ADETMOUSE	; D4 <-- position dans le texte	JUMP',EQ POS0$	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	LOAD.L	D4,D5	CALL	CASMOVE		; dplace l'ascenseur ?	JUMP,EQ LOOP	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	LOAD.L	D4,D5	CALL	CASMOVE		; dplace l'ascenseur ?	JUMP,EQ LOOP	LOAD.L	D4,D5	CALL	CICOMOVE	; dans une icne ?	JUMP,EQ MICONE	JUMP	BIPPOS0$:	PUSH.W	D4	LOAD.W	D4,#50/4	NTREL	?DELMS		; attend un peu ...	POP.W	D4POS1$:	LOAD.L	D5,D4	CALL	BPOSITIONNE	; positionne le curseur	CALL	ADISPLAY	; affiche tout correctement	LOAD.W	D4,#1	CALL	AINVCURS	; met le curseurPOS2$:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE POS8$	TEST.B	D3		; un bouton press ?	JUMP,EQ POS8$		; non => POS8$	CLR.W	D3		; D3 <-- mode normal	CALL	ADETMOUSE	; D4 <-- position dans le texte	JUMP,NE POS2$	COMP.L	D4,D5		; position change ?	JUMP,EQ POS2$		; non => POS2$	PUSH.W	D4	CLR.W	D4	CALL	AINVCURS	; enlve le curseur	POP.W	D4	JUMP	POS1$POS8$:	CLR.W	D4	CALL	AINVCURS	; enlve le curseur	JUMP	LOOPKCLICM:	LOAD.L	A3,#R16"TMMILIEU	LOAD.L	A4,#(A6)+OPARMM	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	CLR.L	(A4)+(LMM*1)+OMMINA	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA;	CLR.L	(A4)+(LMM*4)+OMMINA	CLR.L	(A4)+(LMM*5)+OMMINA	TEST.B	(A5)+ODZMAJ:#BMAJIO	JUMP',BS 10$	TSET.B	(A4)+(LMM*1)+OMMINA+3:#2 ; grise la case "sauve"10$:	TEST.L	(A5)+ODZNBC	JUMP',NE 11$	TSET.B	(A4)+(LMM*2)+OMMINA+3:#6 ; grise la case "change"	TSET.B	(A4)+(LMM*2)+OMMINA+3:#1 ; grise la case "efface"11$:	TEST.L	(A6)+OZONEU+ODZNBC ; qq chose  rcuprer ?	JUMP',NE 12$		; oui => 12$	TSET.B	(A4)+(LMM*2)+OMMINA+3:#0 ; grise la case "annule"12$:	LOAD.L	A2,#(A6)+OTAPOS	LOAD.W	D2,#MAXPOS-1	CLR.W	D3	CLR.L	D415$:	TEST.W	(A2)+OPOZON	JUMP',NC 16$	TSET.L	D4:D3		; grise une case de position16$:	INC.W	D3	ADD.L	A2,#LPO	DECJ.W,NMO D2,15$	LOAD.L	(A4)+(LMM*4)+OMMINA,D4	COMP.W	D4,#B'1111111111 ; toutes les positions grises ?	JUMP',NE 17$		; non => 17$	TSET.B	(A4)+(LMM*0)+OMMINA+3:#4 ; grise la case "position"17$:	TSET.B	(A4)+(LMM*0)+OMMINA+3:#5 ; grise la case "dictionnaire"	TEST.W	(A6)+OCHDICO	JUMP',EQ 18$	TCLR.B	(A4)+(LMM*0)+OMMINA+3:#5 ; dgrise la case "dictionnaire"	TSET.B	(A4)+(LMM*5)+OMMINA+3:#4 ; grise la case "met  jour"	LOAD.L	D6,(A6)+OCIDICO	JUMP',EQ 18$	DICO_	IFMAJ		; mise  jour ncessaire ?	JUMP',EQ 18$		; non => 18$	TCLR.B	(A4)+(LMM*5)+OMMINA+3:#4 ; dgrise la case "met  jour"18$:	TSET.B	(A4)+(LMM*5)+OMMINA+3:#5 ; grise la case "vide TEMP"	LOAD.L	D6,(A6)+OCIDICO	JUMP',EQ 19$	LOAD.W	D3,#1		; D3 <-- opration "get"	DICO_	VTEMP		; D4 <-- nb de mots dans TEMP	TEST.L	D4	JUMP',EQ 19$	TCLR.B	(A4)+(LMM*5)+OMMINA+3:#5 ; dgrise la case "vide TEMP"19$:	TEST.W	(A6)+OCHBLOC	; module BLOC charg ?	JUMP',NE 20$		; oui => 20$	TSET.B	(A4)+(LMM*2)+OMMINA+3:#2 ; grise la case "coupe"	TSET.B	(A4)+(LMM*2)+OMMINA+3:#3 ; grise la case "copie"	TSET.B	(A4)+(LMM*2)+OMMINA+3:#4 ; grise la case "colle"	TSET.B	(A4)+(LMM*2)+OMMINA+3:#5 ; grise la case "classeur"20$:	CALL	MMENUS		; attend choix selon menu hirarchique ...	JUMP,NE BIP	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	COMP.W	D3,#1	JUMP,EQ	FILE$	COMP.W	D3,#2	JUMP,EQ	EDIT$	COMP.W	D3,#3	JUMP,EQ	SHOW$	COMP.W	D3,#4	JUMP,EQ	POS$	COMP.W	D3,#5	JUMP,EQ	DICO$	COMP.W	D3,#6	JUMP,EQ	DEF$	COMP.W	D3,#7	JUMP,EQ	FRAPPE$	JUMP	LOOPFILE$:	CALL	ZUNDOANNULE	; plus de (UNDO) possible !	LOAD.W	D3,(A4)+(LMM*1)+OMMSEL	JUMP,EQ	KPREND	COMP.W	D3,#1	JUMP,EQ	KAJOUTE	COMP.W	D3,#2	JUMP,EQ	KSAUVE	COMP.W	D3,#3	JUMP,EQ	KFIN	JUMP	LOOPEDIT$:	LOAD.W	D3,(A4)+(LMM*2)+OMMSEL	JUMP,EQ	KUNDO	CALL	ZUNDOANNULE	; plus de (UNDO) possible !	COMP.W	D3,#1	JUMP,EQ	KEFFACE	COMP.W	D3,#2	JUMP,EQ	KCOUPE	COMP.W	D3,#3	JUMP,EQ	KCOPIE	COMP.W	D3,#4	JUMP,EQ	KCOLLE	COMP.W	D3,#5	JUMP,EQ	KCLASSEUR	COMP.W	D3,#6	JUMP,EQ	KCHERCHE	JUMP	LOOPSHOW$:	CALL	ZUNDOANNULE	; plus de (UNDO) possible !	LOAD.W	D3,(A4)+(LMM*3)+OMMSEL	JUMP,EQ	KZONE	COMP.W	D3,#1	JUMP,EQ	KCAR	JUMP	LOOPPOS$:	CALL	ZUNDOANNULE	; plus de (UNDO) possible !	LOAD.W	D3,(A4)+(LMM*4)+OMMSEL	LOAD.L	A4,#(A6)+OTAPOS	MUL.WU	D3,#LPO	ADD.L	A4,D3		; A4 <-- ^lment dans OTAPOS	LOAD.W	D2,(A4)+OPOZON	; D2 <-- zone o aller	JUMP,NS BIP	COMP.W	D2,(A5)+ODZNUM	; est-on dans la bonne zone ?	JUMP',EQ POS4$		; oui => POS4$	CALL	ZUN		; montre la bonne zone	JUMP,NE ERRORPOS4$:	LOAD.L	D4,(A4)+OPOPOS	; D4 <-- position o aller	CALL	BPOSITIONNE	; va  la bonne place	JUMP,NE BIP	JUMP	LOOPDICO$:	CALL	ZUNDOANNULE	; plus de (UNDO) possible !	LOAD.W	D3,(A4)+(LMM*5)+OMMSEL	JUMP,EQ	DICOVT$	COMP.W	D3,#1	JUMP,EQ	DICOVF$	COMP.W	D3,#2	JUMP,EQ	DICOMT$	COMP.W	D3,#3	JUMP,EQ	DICOMF$	COMP.W	D3,#4	JUMP,EQ	DICOMJ$	COMP.W	D3,#5	JUMP,EQ	DICOTM$	COMP.W	D3,#6	JUMP,EQ	DICODF$	JUMP	LOOPDICOVT$:			; dictionnaire-vrifie tout =>	CLR.L	D4	LOAD.L	D5,(A5)+ODZNBC	CALL	DICOVERIF	; vrifie tout ...	JUMP,NE ERROR	JUMP	LOOPDICOVF$:			; dictionnaire-vrifie fin =>	LOAD.L	D4,(A5)+ODZPOS	LOAD.L	D5,(A5)+ODZNBC	SUB.L	D5,D4	JUMP,EQ LOOP	CALL	DICOVERIF	; vrifie la fin ...	JUMP,NE ERROR	JUMP	LOOPDICOMT$:			; dictionnaire-marque tout =>	CLR.L	D4	LOAD.L	D5,(A5)+ODZNBC	CALL	DICOMARK	; marque tout ...	JUMP,NE ERROR	JUMP	LOOPDICOMF$:			; dictionnaire-marque fin =>	LOAD.L	D4,(A5)+ODZPOS	LOAD.L	D5,(A5)+ODZNBC	SUB.L	D5,D4	JUMP,EQ LOOP	CALL	DICOMARK	; marque la fin ...	JUMP,NE ERROR	JUMP	LOOPDICOMJ$:			; dictionnaire-met  jour =>	LOAD.L	D6,(A6)+OCIDICO	CALL	DBOXOPEN1	DICO_	MAJ		; effectue les mises  jour ...	CALL	DBOXCLOSE1	TEST.W	D7	JUMP,NE ERROR	JUMP	LOOPDICOTM$:	LOAD.L	D6,(A6)+OCIDICO	CLR.W	D3		; D3 <-- opration "clear"	DICO_	VTEMP		; D4 <-- nb de mots dans TEMP	JUMP,NE ERROR	JUMP	LOOPDICODF$:			; dictionnaire-dfinitions =>	CALL	DICOLOAD	; D6 <-- canal DICO	JUMP,NE ERROR	CLR.W	D3		; D3 <-- dite	CALL	DBOXOPEN1	DICO_	DEF		; choix des dfinitions ...	CALL	DBOXCLOSE1	TEST.W	D7	JUMP,NE ERROR	JUMP	LOOPDEF$:	CALL	ZUNDOANNULE	; plus de (UNDO) possible !	JUMP	KDEFFRAPPE$:	CALL	ZUNDOANNULE	; plus de (UNDO) possible !	JUMP	KFRAPPEKCLICD:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D5,D4	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	LOAD.L	D4,D5	CALL	CASMOVE		; dplace l'ascenseur ?	JUMP,EQ LOOP	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	LOAD.L	D4,D5	CALL	CASMOVE		; dplace l'ascenseur ?	JUMP,EQ LOOP	LOAD.W	D3,#B'01	; D3 <-- inclu le dernier CR/LF	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	LOAD.L	D4,D5	CALL	ADETMOUSE	; D4 <-- position dans le texte	JUMP',EQ ZONE0$	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	LOAD.L	D4,D5	CALL	ADETMOUSE	; D4 <-- position dans le texte	JUMP',EQ ZONE0$	LOAD.L	D4,D5	CALL	CICOMOVE	; dans une icne ?	JUMP,EQ MICONE	JUMP	BIPZONE0$:	LOAD.L	D1,D4		; D1 <-- dbut	LOAD.L	D2,D4		; D2 <-- fin	CALL	AOPEZONE	; ouvre la zoneZONE1$:	LOAD.L	D4,D1	LOAD.L	D5,D2	CALL	AMODZONE	; modifie la zoneZONE2$:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE ZONE2$	TEST.B	D3		; un bouton press ?	JUMP',EQ ZONE4$		; non => ZONE4$	CALL	AROLLMOUSE	LOAD.W	D3,#B'11	; D3 <-- inclu le dernier CR/LF	CALL	ADETMOUSE	; D4 <-- position dans le texte	JUMP,NE ZONE2$	COMP.L	D4,D2		; position change ?	JUMP,EQ ZONE2$		; non => ZONE2$	LOAD.L	D2,D4	JUMP	ZONE1$ZONE4$:	COMP.L	D1,D2		; slectionn qq chose ?	JUMP',NE ZONE6$		; oui => ZONE6$	COMP.W	D4,(A5)+ODZWPO+2	JUMP',LS ZONE5$	LOAD.L	D4,D1	CALL	ESELMOT		; D4/D5 <-- dbut/fin d'un mot	CALL	AMODZONE	; modifie la zone	JUMP'	ZONE6$ZONE5$:	LOAD.L	D4,D1	CALL	ESELPARA	; D4/D5 <-- dbut/fin d'un paragraphe	CALL	AMODZONE	; modifie la zoneZONE6$:	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	TEST.L	D5	JUMP,EQ BIP	LOAD.L	A3,#R16"TMDROITE	LOAD.L	A4,#(A6)+OPARMD	; A4 <-- ^paramtres	TEST.W	(A6)+OCHDICO	JUMP',NE ZONE72$	TSET.B	(A4)+(LMM*0)+OMMINA+2:#10-8 ; grise la case "dictionnaire"ZONE72$:	TEST.W	(A6)+OCHBLOC	; module BLOC charg ?	JUMP',NE ZONE74$	; oui => ZONE74$	TSET.B	(A4)+(LMM*0)+OMMINA+3:#4 ; grise la case "coupe"	TSET.B	(A4)+(LMM*0)+OMMINA+3:#5 ; grise la case "copie"ZONE74$:	CALL	MMENUS		; attend choix selon menu hirarchique ...	JUMP,NE ZONE8$	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	COMP.W	D3,#1	JUMP,EQ	DETRUIT$	COMP.W	D3,#2	JUMP,EQ	DEPLACE$	COMP.W	D3,#3	JUMP,EQ	DUPLIQUE$	COMP.W	D3,#4	JUMP,EQ	COUPE$	COMP.W	D3,#5	JUMP,EQ	COPIE$	COMP.W	D3,#6	JUMP,EQ	CAR$	COMP.W	D3,#7	JUMP,EQ	SOUL$	COMP.W	D3,#8	JUMP,EQ	EXP$	COMP.W	D3,#9	JUMP,EQ	COUL$	COMP.W	D3,#10	JUMP,EQ	POS$	COMP.W	D3,#11	JUMP,EQ	OPER$	COMP.W	D3,#12	JUMP,EQ	DICO$	COMP.W	D3,#13	JUMP,EQ	CHERCH$ZONE8$:	CALL	ACLOZONE	; efface la zone	JUMP	LOOPDETRUIT$:	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	BPOSITIONNE	; va au dbut de la zone  dtruireDETRUIT2$:	DEC.W	D5	JUMP,NS LOOP	CALL	ZADETRUIT	; dtruit un caractre	JUMP,NE ERROR	JUMP	DETRUIT2$DEPLACE$:	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	BPOSITIONNE	; va au dbut de la zone  dtruire	CALL	ZCOPY		; ouvre v. une zone secondaire	JUMP,NE ERROR	LOAD.L	A4,#(A6)+OZONE2	; A4 <-- ^descripteur de l'autre zone	COMP.L	A4,A5		; est-ce bien l'autre ?	JUMP',NE DEPLACE2$	; oui => DEPLACE2$	LOAD.L	A4,#(A6)+OZONE1	; A4 <-- ^descripteur de l'autre zoneDEPLACE2$:	DEC.W	D5	JUMP,NS LOOP	CALL	BAVANCE		; D3 <-- caractre de la zone source	JUMP,NE ERROR	CALL	BDETRUIT	; enlve le caractre de la zone source	EX.L	A5,A4		; A5 <-- ^descripteur zone destination	CALL	BINSERE		; met le caractre dans la zone destination	JUMP,NE ERROR	EX.L	A5,A4		; A5 <-- ^descripteur zone source	JUMP	DEPLACE2$DUPLIQUE$:	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	BPOSITIONNE	; va au dbut de la zone  dtruire	CALL	ZCOPY		; ouvre v. une zone secondaire	JUMP,NE ERROR	LOAD.L	A4,#(A6)+OZONE2	; A4 <-- ^descripteur de l'autre zone	COMP.L	A4,A5		; est-ce bien l'autre ?	JUMP',NE DUPLIQU2$	; oui => DUPLIQU2$	LOAD.L	A4,#(A6)+OZONE1	; A4 <-- ^descripteur de l'autre zoneDUPLIQU2$:	DEC.W	D5	JUMP,NS LOOP	CALL	BAVANCE		; D3 <-- caractre de la zone source	JUMP,NE ERROR	EX.L	A5,A4		; A5 <-- ^descripteur zone destination	CALL	BINSERE		; met le caractre dans la zone destination	JUMP,NE ERROR	EX.L	A5,A4		; A5 <-- ^descripteur zone source	JUMP	DUPLIQU2$COUPE$:	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	BPOSITIONNE	; va au dbut de la zone  couper	CALL	BLOCCOPY	; bloc-notes <-- caractres	JUMP,NE ERRORCOUP3$:	CALL	BDETRUIT	DEC.L	D5	JUMP,NE COUP3$	JUMP	LOOPCOPIE$:	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	BPOSITIONNE	; va au dbut de la zone  copier	CALL	BLOCCOPY	; bloc-notes <-- caractres	JUMP,NE ERROR	JUMP	LOOPCAR$:	CLR.L	D3	LOAD.W	D3,(A4)+(LMM*1)+OMMSEL	SL.L	D3,#CCGCSHI	; D3 <-- nouveau mode	LOAD.L	D2,#CCGCMSK	; D2 <-- masque	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	BMODE		; modifie le gencar de toute la zone	JUMP,NE ERROR	JUMP	LOOPSOUL$:	CLR.L	D3	LOAD.W	D3,(A4)+(LMM*2)+OMMSEL	SL.L	D3,#8	SL.L	D3,#CCSOSHI-8	; D3 <-- nouveau mode	LOAD.L	D2,#CCSOMSK	; D2 <-- masque	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	BMODE		; modifie le gencar de toute la zone	JUMP,NE ERROR	JUMP	LOOPEXP$:	CLR.L	D3	LOAD.W	D3,(A4)+(LMM*3)+OMMSEL	SL.L	D3,#8	SL.L	D3,#CCEXSHI-8	; D3 <-- nouveau mode	LOAD.L	D2,#CCEXMSK	; D2 <-- masque	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	BMODE		; modifie le gencar de toute la zone	JUMP,NE ERROR	JUMP	LOOPCOUL$:	CLR.L	D3	LOAD.W	D3,(A4)+(LMM*4)+OMMSEL	SL.L	D3,#8	SL.L	D3,#8	SL.L	D3,#CCCOSHI-8-8	; D3 <-- nouveau mode	LOAD.L	D2,#CCCOMSK	; D2 <-- masque	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	BMODE		; modifie le gencar de toute la zone	JUMP,NE ERROR	JUMP	LOOPPOS$:	LOAD.W	D3,(A4)+(LMM*5)+OMMSEL	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	LOAD.L	A4,#(A6)+OTAPOS	MUL.WU	D3,#LPO	ADD.L	A4,D3		; A4 <-- ^lment dans OTAPOS	LOAD.W	(A4)+OPOZON,(A5)+ODZNUM	LOAD.L	(A4)+OPOPOS,D4	JUMP	LOOPOPER$:	LOAD.W	D3,(A4)+(LMM*6)+OMMSEL;	COMP.W	D3,#0	JUMP,EQ	MINMAJ$	COMP.W	D3,#1	JUMP,EQ	PERM$	COMP.W	D3,#2	JUMP,EQ	TRI$	COMP.W	D3,#3	JUMP,EQ	SAUVE$	CALL	ACLOZONE	; efface la zone	JUMP	LOOPMINMAJ$:	LOAD.W	D3,(A4)+(LMM*7)+OMMSEL	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	BPOSITIONNE	; va au dbut de la zone	LOAD.B	D4,#'a	TEST.W	D3	JUMP',EQ MINMAJ2$	LOAD.B	D4,#'AMINMAJ2$:	LOAD.B	D3,D4	CALL	EMINMAJ	JUMP,NE ERROR	CALL	BAVANCE	JUMP,NE LOOP	DEC.L	D5	JUMP,NE MINMAJ2$	JUMP	LOOPPERM$:	LOAD.W	D6,(A4)+(LMM*8)+OMMSEL ; D6 <-- mode	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	OPERMUTE	; permute tous les caractres de la zone	JUMP,NE ERROR	JUMP	LOOPTRI$:	LOAD.W	D3,(A4)+(LMM*9)+OMMSEL	CALL	ACLOZONE	; efface la zone	JUMP	LOOPSAUVE$:	CALL	DBOXZCREATE	; cre le fichier ...	JUMP',NE SAUVE9$	COMP.W	D3,#F1	JUMP',NE SAUVE8$	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	LOAD.L	A3,#(A6)+OBUTEMP ; A3 <-- ^nom du fichier	CALL	IOZWRITE	; crit le fichier	JUMP,NE ERROR	JUMP	LOOPSAUVE8$:	CALL	ACLOZONE	; efface la zone	JUMP	LOOPSAUVE9$:	PUSH.W	D7	CALL	ACLOZONE	; efface la zone	POP.W	D7	JUMP	ERRORDICO$:	LOAD.W	D3,(A4)+(LMM*10)+OMMSEL;	COMP.W	D3,#0	JUMP,EQ	DICOVE$	COMP.W	D3,#1	JUMP,EQ	DICOMA$	COMP.W	D3,#2	JUMP,EQ	DICOAD$	COMP.W	D3,#3	JUMP,EQ	DICOAC$	COMP.W	D3,#4	JUMP,EQ	DICOCO$	COMP.W	D3,#5	JUMP,EQ	DICOSY$	COMP.W	D3,#6	JUMP,EQ	DICOFA$	COMP.W	D3,#7	JUMP,EQ	DICONB$	CALL	ACLOZONE	; efface la zone	JUMP	LOOPDICOVE$:			; dictionnaire-vrifie =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOVERIF	; vrifie l'orthographe ...	JUMP,NE ERROR	JUMP	LOOPDICOMA$:			; dictionnaire-marque =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOMARK	; marque l'orthographe ...	JUMP,NE ERROR	JUMP	LOOPDICOAD$:			; dictionnaire-conserve =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOADD		; ajoute un mot ...	JUMP,NE ERROR	JUMP	LOOPDICOAC$:			; dictionnaire-accorde =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOACCORD	; accorde le mot ...	JUMP,NE ERROR	JUMP	LOOPDICOCO$:			; dictionnaire-conjugue =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOCONJ	; conjugue le verbe ...	JUMP,NE ERROR	JUMP	LOOPDICOSY$:			; dictionnaire-synonymes =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOSYNO	; synonyme du mot ...	JUMP,NE ERROR	JUMP	LOOPDICOFA$:			; dictionnaire-familles =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOFAMILLE	; famille du mot ...	JUMP,NE ERROR	JUMP	LOOPDICONB$:			; dictionnaire-nombre =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICONOMB	; transforme le nombre ...	JUMP,NE ERROR	JUMP	LOOPCHERCH$:	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	BPOSITIONNE	JUMP,NE ERROR	LOAD.L	A3,#(A6)+OCH1	; A3 <-- ^chane de recherche	LOAD.W	D4,#MAXCH-2	LOAD.L	D6,D5CHERCH2$:	DEC.W	D4	JUMP',EQ CHERCH3$	CALL	BAVANCE	JUMP',NE CHERCH3$	LOAD.B	(A3+),D3	; chane de recherche <-- caractres	DEC.L	D5	JUMP,NE CHERCH2$CHERCH3$:	CLR.B	(A3)	CLR.B	(A6)+OCH2	; chane de substitution <-- vide	LOAD.W	D3,(A4)+(LMM*11)+OMMSEL;	COMP.W	D3,#0	JUMP',EQ CHERAR$	COMP.W	D3,#1	JUMP',EQ CHERAV$	COMP.W	D3,#2	JUMP',EQ CHANGE$	JUMP	LOOPCHERAR$:	CALL	BRECULE		; revient au dbut de la chane	DEC.L	D6	JUMP,NE CHERAR$	JUMP	ESEARCHAR	; cherche en arrireCHERAV$:	JUMP	ESEARCHAV	; cherche en avantCHANGE$:	LOAD.W	D3,#H'100*(2^BCHANGE)+0	JUMP	KCHERCHE	; change ...MICONE:	TEST.W	D2	JUMP,EQ MICOSEP	COMP.W	D2,#1	JUMP,EQ MICODEPL	COMP.W	D2,#2	JUMP,EQ MICODUPL	COMP.W	D2,#3	JUMP,EQ MICODETR	COMP.W	D2,#4	JUMP,EQ MICOFLIP	JUMP	BIPMICOSEP:	LOAD.W	D5,(A6)+OWDSEP	SWAP.W	D5	CLR.W	D520$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 40$		; non => 40$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	SWAP.W	D4	LOAD.W	D3,(A6)+OWDPOS+0	SR.W	D3,#1	ADD.W	D3,(A6)+OWDPOS+0	ADD.W	D3,#LGSCROLL*4	; D3 <-- valeur minimale	COMP.W	D4,D3	JUMP',HS 30$	LOAD.W	D4,D330$:	LOAD.W	D3,(A6)+OWDPOS+0	ADD.W	D3,(A6)+OWDDIM+0	SUB.W	D3,#LGSCROLL*4	; D3 <-- valeur maximale	COMP.W	D4,D3	JUMP',LS 32$	LOAD.W	D4,D332$:	SWAP.W	D4	LOAD.L	D2,D4	LOAD.L	D3,D5	SWAP.W	D2	SWAP.W	D3	COMP.W	D2,D3		; position change ?	JUMP,EQ 20$		; non => 20$	EX.L	D4,D5	CALL	CINVSEP2	; teint l'ancienne sparation	LOAD.L	D4,D5	CALL	CINVSEP2	; allume la nouvelle sparation	JUMP	20$40$:	SWAP.W	D5	COMP.W	D5,(A6)+OWDSEP	; sparateur boug ?	JUMP,EQ LOOP		; non => LOOP	LOAD.W	(A6)+OWDSEP,D5	LOAD.W	D2,(A6)+OZONE1+ODZNUM	LOAD.W	D1,(A6)+OZONE2+ODZNUM	LOAD.L	A5,#(A6)+OZONE1	CALL	ZAFFCLOSE	; ferme la zone principale	LOAD.L	A5,#(A6)+OZONE2	CALL	ZAFFCLOSE	; ferme la zone secondaire	CALL	ZDEUX		; remet les deux zones	JUMP,NE ERROR	JUMP	LOOPMICODEPL:	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone source	LOAD.L	A4,#(A6)+OZONE1	; A4 <-- ^descripteur zone destination	CLR.L	D4	CALL	BPOSITIONNE	; va au dbut de la zone source	JUMP,NE ERROR20$:	CALL	BAVANCE		; D3 <-- caractre de la zone source	JUMP',NE 40$	CALL	BDETRUIT	; dtruit caractre de la zone source	EX.L	A5,A4		; A5 <-- ^descripteur zone destination	CALL	BINSERE		; met caractre dans zone destination	JUMP,NE ERROR	EX.L	A5,A4		; A5 <-- ^descripteur zone source	JUMP	20$40$:	LOAD.W	D2,(A6)+OZONE1+ODZNUM	CALL	ZUN		; ne montre plus que la zone principale	JUMP	LOOPMICODUPL:	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone source	LOAD.L	A4,#(A6)+OZONE1	; A4 <-- ^descripteur zone destination	CLR.L	D4	CALL	BPOSITIONNE	; va au dbut de la zone source	JUMP,NE ERROR20$:	CALL	BAVANCE		; D3 <-- caractre de la zone source	JUMP,NE LOOP	EX.L	A5,A4		; A5 <-- ^descripteur zone destination	CALL	BINSERE		; met caractre dans zone destination	JUMP,NE ERROR	EX.L	A5,A4		; A5 <-- ^descripteur zone source	JUMP	20$MICODETR:	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone source	CALL	BINIT	LOAD.W	D2,(A6)+OZONE1+ODZNUM	CALL	ZUN		; ne montre plus que la zone principale	JUMP	LOOPMICOFLIP:	LOAD.W	D1,(A6)+OZONE1+ODZNUM	LOAD.W	D2,(A6)+OZONE2+ODZNUM	CALL	ZDEUX		; permute les deux zones	JUMP,NE ERROR	JUMP	LOOP;---------\\; BLOCCOPY >;=========/; Copie dans le bloc-notes tous les caractres de la zone.; in	D5.L	nb caractre; out	D7.W	erreur; mod	D7.WBLOCCOPY:	PUSHM.L	D0..D5,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D2,D5		; D2 <-- nb de caractres	LOAD.L	A3,#R16"NAME$	LOAD.L	D3,#BNTTEXT	; D3 <-- type "TEXT"	LOAD.L	D4,D2		; D4 <-- nb de caractres	BLOC_	WROPEN		; ouvre le bloc-notes	JUMP,NE EXIT$LOOP$:	CALL	BAVANCE		; D3 <-- caractre suivant	JUMP',NE CLOSE$	LOAD.L	A4,#(A5)+OIOTM	; A4 <-- ^buffer	LOAD.B	(A4),D3	LOAD.L	D4,#1	LOAD.L	D3,#BNTTEXT	; D3 <-- type "TEXT"	BLOC_	WRDATA		; met un caractre dans le bloc-notes	JUMP',NE CLOSE$	DEC.L	D2	JUMP,NE LOOP$CLOSE$:	PUSH.W	D7	BLOC_	WRCLOSE		; ferme le bloc-notes	POP.W	D7EXIT$:	POPM.L	D0..D5,A4	TEST.W	D7		; retour EQ/NE	RETNAME$:	.ASCIZ	"PLUME"	.EVEN;---------\\; BLOCPAST >;=========/; Colle les caractrves contenus dans le bloc-notes.; in	-; out	D7.W	erreur; mod	D7.WBLOCPAST:	PUSHM.L	D3,D4,A3,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D3,#BNTTEXT	; D3 <-- type "TEXT"	BLOC_	RDOPEN		; ouvre le bloc-notes "TEXT"	JUMP',NE EXIT$LOOP$:	LOAD.L	A4,#(A5)+OIOTM	LOAD.L	D4,#1	BLOC_	RDDATA		; lit un caractre	JUMP',NE END$	CLR.L	D3	LOAD.B	D3,(A4)	BLOC_	CAR87		; D3 <-- caractre < 128	CALL	BINSERE		; insre un caractre	JUMP',NE ERROR$	JUMP	LOOP$ERROR$:	PUSH.W	D7	BLOC_	RDCLOSE		; ferme le bloc-notes	POP.W	D7	JUMP'	EXIT$END$:	BLOC_	RDCLOSE		; ferme le bloc-notes	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; MMENUS  >;========/; Appel un mmenu hirarchique, avec mmorisation ventuelle de la case.; in	A3.L	^mmenu;	A4.L	^table des paramtres; out	D7.W	erreur; mod	D7.WMMENUS:	PUSHM.L	D3..D5,A2..A5	LOAD.L	A5,A4		; A5 <-- ^paramtres	LOAD.L	A4,A3		; A4 <-- ^mmenu	TEST.B	(A6)+ODEF+3:#BDFMDC-0	JUMP',BS 10$	CLR.W	(A5)+(LMM*0)+OMMSEL10$:	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^buffer pour construire m-menu	LOAD.L	A2,A3	CALL	MENUBUF		; buffer <-- menu principal	CALL	MENUAJUST	; buffer <-- tous les sous-(sous-)menus	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^mmenu	LOAD.L	A4,A5		; A4 <-- ^paramtres	CLR.L	D5		; D5 <-- mode	LIB	?MMENUS		; attend selon choix	POPM.L	D3..D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; MENUAJUST >;----------/; Ajuste les pointeurs relatifs du menu pre qui vient d'tre; mis dans le buffer.; in	A2.L	^dbut du menu pre;	A3.L	^buffer;	A4.L	^mmenu; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LMENUAJUST:	PUSHM.L	D3,D4,A1,A2	LOAD.L	A1,A220$:	TEST.B	(A2)		; fin du mmenu ?	JUMP,EQ 90$		; oui => 90$30$:	LOAD.B	D3,(A2+)	JUMP,EQ 20$	COMP.B	D3,#-2	JUMP,NE 30$				; ^sous-menu =>	LOAD.B	D3,(A2+)	SL.W	D3,#8	LOAD.B	D3,(A2+)	; D3 <-- ^relatif	LOAD.L	D4,A3	SUB.L	D4,A1	LOAD.B	(A2)-1,D4	RR.W	D4,#8	LOAD.B	(A2)-2,D4	; buffer <-- ^relatif au sous-menu	RR.W	D4,#8	PUSH.L	A2	PUSH.L	A3	TEST.W	D3		; .BW -2,-n  ?	JUMP',NS 50$		; oui => 50$				; non =>	CALL	MENUBUF		; buffer <-- sous-menu	JUMP'	52$50$:	CALL	MENUSPEC	; buffer <-- sous-menu52$:	POP.L	A2	CALL	MENUAJUST	; paf, rcursif !!!	POP.L	A2	JUMP	30$90$:	POPM.L	D3,D4,A1,A2	RET;--------\\; MENUBUF >;--------/; Met un mmenu dans un buffer.; in	A3.L	^buffer;	A4.L	^mmenu; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LMENUBUF:	PUSH.W	D310$:	TEST.B	(A4)		; fin du mmenu ?	JUMP',EQ 80$20$:	LOAD.B	D3,(A4+)	LOAD.B	(A3+),D3	; buffer <-- .ASCIZ	JUMP,EQ 10$	COMP.B	D3,#-2	JUMP,NE	20$	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-high>	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-low>	JUMP	20$80$:	INC.L	A4	CLR.B	(A3+)		; buffer <-- terminateur	POP.W	D3	RET;---------\\; MENUSPEC >;---------/; Met un mmenu spcial dans un buffer.; in	D3.W	type du menu spcial (-);	D4.W	^relatif;	A2.L	^pour mj. ^relatif;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LMENUSPEC:	PUSHM.L	D2..D4,A1,A2,A4	COMP.W	D3,#-1	JUMP',EQ 20$	COMP.W	D3,#-2	JUMP,EQ 30$	JUMP	90$; Construit le sous-menu des caractres.20$:	LOAD.L	A1,A2	PUSH.L	A3	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	DGENC_	MENU		; buffer <-- sous-menu des gencars	INC.L	A3		; A3 <-- saute le zro terminateur	POP.L	A422$:	INC.W	D4	COMP.B	(A4+),#-1	; A4 <-- saute la premire case vide	JUMP,NE 22$	LOAD.B	(A1)-1,D4	RR.W	D4,#8	LOAD.B	(A1)-2,D4	; buffer <-- ajuste le ^relatif	JUMP	90$; Construit le sous-menu des positions.30$:	LOAD.L	A4,#(A6)+OTAPOS	LOAD.W	D4,#MAXPOS-1	LOAD.B	D3,#ICOPOS32$:	COMP.B	D3,#ICOPOS+(MAXPOS/2)	JUMP',NE 33$	LOAD.B	(A3+),#-1	; buffer <-- ligne horizontale33$:	LOAD.B	(A3+),#SPACE	CALL	MENUICO		; buffer <-- icne IOCPOS	LOAD.B	(A3+),#SPACE	CLR.L	D2	LOAD.W	D2,(A4)+OPOZON	JUMP',NC 35$				; position libre =>	LOAD.L	A2,#R16"FREE$34$:	LOAD.B	(A3+),(A2+)	; buffer <-- texte	JUMP,NE 34$	DEC.L	A3	JUMP'	38$35$:				; position occupe =>	CALL	MENUASC		; buffer <-- petit ascenseur	LOAD.L	A2,#R16"USE$36$:	LOAD.B	(A3+),(A2+)	; buffer <-- texte	JUMP,NE 36$	DEC.L	A3	CALL	MENUNUM		; buffer <-- numro de la zone	LOAD.B	(A3+),#SPACE38$:	CLR.B	(A3+)		; buffer <-- terminateur de ligne	ADD.L	A4,#LPO		; A4 <-- ^lment suivant	INC.B	D3		; D3 <-- icne suivante	DECJ.W,NMO D4,32$	CLR.B	(A3+)		; buffer <-- terminateur gnral;	JUMP	90$90$:	POPM.L	D2..D4,A1,A2,A4	RETFREE$:	.ASCIZ	"libre  "USE$:	.ASCIZ	"dans zone "	.EVEN;--------\\; MENUASC >;--------/; Met un petit ascenseur (icne) dans un sous-menu.; in	D2.W	numro de la zone;	A4.L	^lment dans OTAPOS;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LMENUASC:	PUSHM.L	D2..D4,A5	CALL	ZCTRL		; A5 <-- ^description zone	JUMP,NE 90$	LOAD.L	D4,(A5)+ODZNBC	LOAD.W	D2,#6	COMP.L	D4,#2^20	JUMP',HS 20$	DEC.W	D2	COMP.L	D4,#2^19	JUMP',HS 20$	DEC.W	D2	COMP.L	D4,#2^18	JUMP',HS 20$	DEC.W	D2	COMP.L	D4,#2^17	JUMP',HS 20$	DEC.W	D2	COMP.L	D4,#2^16	JUMP',HS 20$	DEC.W	D2	COMP.L	D4,#2^15	JUMP',HS 20$	DEC.W	D220$:	LOAD.L	D4,(A4)+OPOPOS	SR.L	D4,D2	MUL.WU	D4,#6-1	LOAD.L	D3,(A5)+ODZNBC	SR.L	D3,D2	DIV.WU	D4,D3	LOAD.L	D2,D4	SWAP.W	D2	SR.W	D3,#1	COMP.W	D2,D3	JUMP',LO 30$	INC.W	D430$:	LOAD.B	D3,#ICOASC	ADD.B	D3,D4	CALL	MENUICO		; buffer <-- icne90$:	POPM.L	D2..D4,A5	RET;--------\\; MENUICO >;--------/; Met une icne dans un sous-menu.; in	D3.B	code de l'icne;	A3.L	^buffer; out	A3.L	^plus loin; mod	A3.LMENUICO:	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCICF	LOAD.B	(A3+),#GCICS	LOAD.B	(A3+),#GCICT	LOAD.B	(A3+),D3	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCTXF	LOAD.B	(A3+),#GCTXS	LOAD.B	(A3+),#GCTXT	RET;--------\\; MENUNUM >;--------/; Met un nombre dans un sous-menu.; in	D2.L	nombre;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LMENUNUM:	PUSHM.L	D2..D4	LOAD.L	D4,D2	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDCM	EX.L	A4,A3	LIB	?PUTDEC		; buffer <-- nombre	EX.L	A3,A4	POPM.L	D2..D4	RET; Menus pour la souris; --------------------TMDROITE:	.ASCIZ	" "	.B	-1	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICODETR,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" dtruit"	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICODEPL,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" dplace"	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICODUPL,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" duplique"	.B	-1	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICOCOUPE,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" coupe"	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICOCOPIE,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" copie"	.B	-1	.BW	-2,-1	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICOCAR,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" caractre"	.BW	-2,SOUL$-TMDROITE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICOSOUL,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" soulign"	.BW	-2,EXP$-TMDROITE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICOEXIN,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" exposant"	.BW	-2,COUL$-TMDROITE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICOCOUL,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" couleur"	.B	-1	.BW	-2,-2	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICOPOSR,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" position"	.BW	-2,OPER$-TMDROITE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICOOPER,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" opration"	.BW	-2,DICO$-TMDROITE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICODICO,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" dictionnaire"	.BW	-2,SEARCH$-TMDROITE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPACE,ICOCHERCHE,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	" cherche.."	.B	0SOUL$:	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOS