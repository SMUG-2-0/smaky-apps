	.TITLE	DICO_DD.ASC	.REF	DICOcaractre de marquage utiliss :MARKDM	=	4		; marque pour le dbut d'un mot fauxMARKFM	=	5		; marque pour la fin d'un mot fauxdfinition des icnes de IPP15 ( mettre dans ITP16) :ICODICO	=	28		; dictionnaireICODICOMA=	106		; dictionnaire: marqueICODICOVE=	107		; dictionnaire: vrifieICODICOAD=	108		; dictionnaire: conserveICODICOAC=	109		; dictionnaire: accordeICODICOCO=	110		; dictionnaire: conjugueICODICOSY=	111		; dictionnaire: synonymesICODICOVT=	112		; dictionnaire: vide TEMPvariables pour le dictionnaire :OCHDICO:.BLKB	2		; canal module DICOOCIDICO:.BLKB	4		; canal interne DICOchargement du module, avec dtection s'il n'existe pas :NMDICO:		.ASCIZ	"DICO"	LOAD.L	A3,#R16"NMDICO	LOAD.W	D3,#DICO_FIRST	LIB_	OPEN	JUMP',NE 40$	LOAD.W	(A6)+OCHDICO,D1	LOAD.W	D3,#DICO_VTEMP	LIB_	GETAD		; appel DICO_VTEMP existe ?	JUMP',EQ 40$		; oui => 40$				; non =>	LIB_	CLOSE	CLR.W	(A6)+OCHDICO40$:lorsque l'on appuye sur (F0) = (Fin), il faut mettre  jour les zonesde texte modifies, puis les dictionnaires privs comme suit :	LOAD.L	D6,(A6)+OCIDICO	JUMP',EQ 40$	DICO_	IFMAJ		; mises  jour ncessaires ?	JUMP',EQ 40$		; non => 40$	CALL	DBOXOPEN1	DICO_	MAJ		; effectue les mises  jour ...	CALL	DBOXCLOSE1	TEST.W	D7	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP40$:	CALL	DBOXQUITTE	; demande s'il faut quitter ...	JUMP,NE ERRORERFAT:	TEST.W	(A6)+OCHDICO	JUMP',EQ 20$	LOAD.L	D6,(A6)+OCIDICO	JUMP',EQ 20$	DICO_	CLOSE20$:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDGENC	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDICO	JUMP',EQ ERFAT1	LIB_	CLOSEERFAT1:	LIB	?CLOLIB	FOS	?STOPgestion du mmenu du bouton bu milieu de la souris :	LOAD.L	A3,#R16"TMMILIEU	LOAD.L	A4,#(A6)+OPARMM	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	CLR.L	(A4)+(LMM*1)+OMMINA	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA	CLR.L	(A4)+(LMM*4)+OMMINA	CLR.L	(A4)+(LMM*5)+OMMINA	TSET.B	(A4)+(LMM*0)+OMMINA+3:#5 ; grise la case "dictionnaire"	TEST.W	(A6)+OCHDICO	JUMP',EQ 18$	TCLR.B	(A4)+(LMM*0)+OMMINA+3:#5 ; dgrise la case "dictionnaire"	TSET.B	(A4)+(LMM*5)+OMMINA+3:#4 ; grise la case "met  jour"	LOAD.L	D6,(A6)+OCIDICO	JUMP',EQ 18$	DICO_	IFMAJ		; mise  jour ncessaire ?	JUMP',EQ 18$		; non => 18$	TCLR.B	(A4)+(LMM*5)+OMMINA+3:#4 ; dgrise la case "met  jour"18$:	TSET.B	(A4)+(LMM*5)+OMMINA+3:#5 ; grise la case "vide TEMP"	LOAD.L	D6,(A6)+OCIDICO	JUMP',EQ 19$	LOAD.W	D3,#1		; D3 <-- opration "get"	DICO_	VTEMP		; D4 <-- nb de mots dans TEMP	TEST.L	D4	JUMP',EQ 19$	TCLR.B	(A4)+(LMM*5)+OMMINA+3:#5 ; dgrise la case "vide TEMP"19$:	CALL	MMENUS		; attend choix selon menu hirarchique ...	JUMP,NE BIP	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	COMP.W	D3,#1	JUMP,EQ	FILE$	COMP.W	D3,#2	JUMP,EQ	EDIT$	COMP.W	D3,#3	JUMP,EQ	SHOW$	COMP.W	D3,#4	JUMP,EQ	POS$	COMP.W	D3,#5	JUMP,EQ	DICO$	COMP.W	D3,#6	JUMP,EQ	DEF$	COMP.W	D3,#7	JUMP,EQ	FRAPPE$	JUMP	LOOP...DICO$:	CALL	ZUNDOANNULE	; plus de (UNDO) possible !	LOAD.W	D3,(A4)+(LMM*5)+OMMSEL	JUMP,EQ	DICOVT$	COMP.W	D3,#1	JUMP,EQ	DICOVF$	COMP.W	D3,#2	JUMP,EQ	DICOMT$	COMP.W	D3,#3	JUMP,EQ	DICOMF$	COMP.W	D3,#4	JUMP,EQ	DICOMJ$	COMP.W	D3,#5	JUMP,EQ	DICOTM$	COMP.W	D3,#6	JUMP,EQ	DICODF$	JUMP	LOOPDICOVT$:			; dictionnaire-vrifie tout =>	CLR.L	D4	LOAD.L	D5,(A5)+ODZNBC	CALL	DICOVERIF	; vrifie tout ...	JUMP,NE ERROR	JUMP	LOOPDICOVF$:			; dictionnaire-vrifie fin =>	LOAD.L	D4,(A5)+ODZPOS	LOAD.L	D5,(A5)+ODZNBC	SUB.L	D5,D4	JUMP,EQ LOOP	CALL	DICOVERIF	; vrifie la fin ...	JUMP,NE ERROR	JUMP	LOOPDICOMT$:			; dictionnaire-marque tout =>	CLR.L	D4	LOAD.L	D5,(A5)+ODZNBC	CALL	DICOMARK	; marque tout ...	JUMP,NE ERROR	JUMP	LOOPDICOMF$:			; dictionnaire-marque fin =>	LOAD.L	D4,(A5)+ODZPOS	LOAD.L	D5,(A5)+ODZNBC	SUB.L	D5,D4	JUMP,EQ LOOP	CALL	DICOMARK	; marque la fin ...	JUMP,NE ERROR	JUMP	LOOPDICOMJ$:			; dictionnaire-met  jour =>	LOAD.L	D6,(A6)+OCIDICO	CALL	DBOXOPEN1	DICO_	MAJ		; effectue les mises  jour ...	CALL	DBOXCLOSE1	TEST.W	D7	JUMP,NE ERROR	JUMP	LOOPDICOTM$:	LOAD.L	D6,(A6)+OCIDICO	CLR.W	D3		; D3 <-- opration "clear"	DICO_	VTEMP		; D4 <-- nb de mots dans TEMP	JUMP,NE ERROR	JUMP	LOOPDICODF$:			; dictionnaire-dfinitions =>	CALL	DICOLOAD	; D6 <-- canal DICO	JUMP,NE ERROR	CLR.W	D3		; D3 <-- dite	CALL	DBOXOPEN1	DICO_	DEF		; choix des dfinitions ...	CALL	DBOXCLOSE1	TEST.W	D7	JUMP,NE ERROR	JUMP	LOOPgestion du mmenu du bouton de droite de la souris :	LOAD.L	A3,#R16"TMDROITE	LOAD.L	A4,#(A6)+OPARMD	; A4 <-- ^paramtres	TEST.W	(A6)+OCHDICO	JUMP',NE ZONE72$	TSET.B	(A4)+(LMM*0)+OMMINA+2:#10-8 ; grise la case "dictionnaire"ZONE72$:	CALL	MMENUS		; attend choix selon menu hirarchique ...	JUMP,NE ZONE8$	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	COMP.W	D3,#1	JUMP,EQ	DETRUIT$	COMP.W	D3,#2	JUMP,EQ	DEPLACE$	COMP.W	D3,#3	JUMP,EQ	DUPLIQUE$	COMP.W	D3,#4	JUMP,EQ	CAR$	COMP.W	D3,#5	JUMP,EQ	SOUL$	COMP.W	D3,#6	JUMP,EQ	EXP$	COMP.W	D3,#7	JUMP,EQ	COUL$	COMP.W	D3,#8	JUMP,EQ	POS$	COMP.W	D3,#9	JUMP,EQ	OPER$	COMP.W	D3,#10	JUMP,EQ	DICO$	COMP.W	D3,#11	JUMP,EQ	CHANGE$ZONE8$:	CALL	ACLOZONE	; efface la zone	JUMP	LOOP...DICO$:	LOAD.W	D3,(A4)+(LMM*10)+OMMSEL;	COMP.W	D3,#0	JUMP,EQ	DICOVE$	COMP.W	D3,#1	JUMP,EQ	DICOMA$	COMP.W	D3,#2	JUMP,EQ	DICOAD$	COMP.W	D3,#3	JUMP,EQ	DICOAC$	COMP.W	D3,#4	JUMP,EQ	DICOCO$	COMP.W	D3,#5	JUMP,EQ	DICOSY$	CALL	ACLOZONE	; efface la zone	JUMP	LOOPDICOVE$:			; dictionnaire-vrifie =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOVERIF	; vrifie l'orthographe ...	JUMP,NE ERROR	JUMP	LOOPDICOMA$:			; dictionnaire-marque =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOMARK	; marque l'orthographe ...	JUMP,NE ERROR	JUMP	LOOPDICOAD$:			; dictionnaire-conserve =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOADD		; ajoute un mot ...	JUMP,NE ERROR	JUMP	LOOPDICOAC$:			; dictionnaire-accorde =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOACCORD	; accorde le mot ...	JUMP,NE ERROR	JUMP	LOOPDICOCO$:			; dictionnaire-conjugue =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOCONJ	; conjugue le verbe ...	JUMP,NE ERROR	JUMP	LOOPDICOSY$:			; dictionnaire-synonymes =>	CALL	AGETZONE	; D4 <-- position, D5 <-- nb car	CALL	ACLOZONE	; efface la zone	CALL	DICOSYNO	; synonyme du mot ...	JUMP,NE ERROR	JUMP	LOOP	.SBTTL	PLUMEDICO;----------\\; DICOVERIF >;==========/; Vrifie l'orthographe d'une zone quelconque.; in	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOVERIF:	PUSHM.L	D0..D6,A1..A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP,NE 90$	LOAD.L	A1,A4	LOAD.L	D1,D4		; A1/D1 <-- ^texte/lg	LOAD.L	A2,A4	LOAD.L	D2,D4		; A2/D2 <-- ^texte/lg	CLR.W	(A6)+ODINBF	CLR.B	(A6)+OIOTM	; aucun mot  changer partout40$:	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,A1	LOAD.L	D4,D1		; A4/D4 <-- ^phrase complte	LOAD.L	A3,A2	LOAD.L	D3,D2		; A3/D3 <-- ^o vrifier;	CALL	DBOXOPEN1	LOAD.L	D6,(A6)+OCIDICO	DICO_	JUSTE		; est-ce juste ?	CALL	DBOXCLOSE1	TEST.W	D7	JUMP,EQ 80$	COMP.W	D7,#ERKSTO	JUMP,EQ 70$	ADD.L	D2,A2	SUB.L	D2,A4	SUB.L	D2,D4	LOAD.L	A2,A4	ADD.L	A2,D4		; A2 <-- ^plus loin	LOAD.L	D6,A4	LOAD.L	D5,D4	INC.W	(A6)+ODINBF	; une faute de plus	LOAD.L	D3,D0	ADD.L	D3,D6	SUB.L	D3,A1	CALL	DICOMASC	; met  jour l'ascenseur	LOAD.L	A3,A4	LOAD.L	D3,D4	CALL	DICOCTEXI	; mot  changer partout ?	JUMP',EQ 50$		; oui => 50$	LOAD.L	A3,A1	LOAD.L	D3,D1	CALL	DBOXOPEN1	PUSH.L	D6	LOAD.L	D6,(A6)+OCIDICO	DICO_	CHANGE		; change un mot ...	POP.L	D6	CALL	DBOXCLOSE1	TEST.W	D7	JUMP,NE 90$	COMP.W	D3,#F1		; remplace-un ?	JUMP',EQ 50$	COMP.W	D3,#F3		; remplace-tout ?	JUMP',EQ 60$	COMP.W	D3,#F10		; stoppe ?	JUMP,EQ 90$	JUMP'	40$50$:				; remplace-un =>	LOAD.L	D3,D0	ADD.L	D3,D6	SUB.L	D3,A1	CALL	DICOCHMOT	; change un mot	JUMP,NE 90$	JUMP	40$60$:				; remplace-tout =>	LOAD.L	D3,D0	ADD.L	D3,D6	SUB.L	D3,A1	CALL	DICOCHMOT	; change un mot	JUMP',NE 90$	LOAD.L	A3,D6	LOAD.L	D3,D5	CALL	DICOCTMEM	; mmorise le mot	JUMP	40$70$:				; stoppe =>	LOAD.L	D4,D0	ADD.L	D4,A4	SUB.L	D4,A1	CALL	BPOSITIONNE	JUMP'	85$80$:	LOAD.B	D3,#BIPDONE	LIB	?BEEP		; indique que c'est fini	TEST.W	(A6)+ODINBF	; y a-t-il eu des fautes ?	JUMP',NE 85$		; oui => 85$	CALL	DBOXOPEN1	LOAD.L	D6,(A6)+OCIDICO	DICO_	OK		; indique que tout est ok ...	CALL	DBOXCLOSE185$:	CLR.W	D7		; D7 <-- ok90$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICOMARK >;=========/; Marque les fautes d'orthographe d'une zone quelconque.; in	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOMARK:	PUSHM.L	D0..D6,A1..A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP,NE 90$	LOAD.L	A1,A4	LOAD.L	D1,D4		; A1/D1 <-- ^texte/lg	LOAD.L	A2,A4	LOAD.L	D2,D4		; A2/D2 <-- ^texte/lg	CLR.W	(A6)+ODINBF	LOAD.L	D5,#-140$:	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,A1	LOAD.L	D4,D1		; A4/D4 <-- ^phrase complte	LOAD.L	A3,A2	LOAD.L	D3,D2		; A3/D3 <-- ^o vrifier;	CALL	DBOXOPEN1	DICO_	JUSTE		; est-ce juste ?	CALL	DBOXCLOSE1	TEST.W	D7	JUMP,EQ 80$	COMP.W	D7,#ERKSTO	JUMP,EQ 70$	ADD.L	D2,A2	SUB.L	D2,A4	SUB.L	D2,D4	LOAD.L	A2,A4	ADD.L	A2,D4		; A2 <-- ^plus loin	INC.W	(A6)+ODINBF	; une faute de plus	LOAD.L	D3,D0	ADD.L	D3,A4	SUB.L	D3,A1	CALL	DICOMAMOT	; marque un mot	COMP.L	D5,#-1	JUMP',NE 50$	LOAD.L	D5,D3		; D5 <-- position premire faute50$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	40$70$:				; stoppe =>	LOAD.L	D4,D0	ADD.L	D4,A4	SUB.L	D4,A1	CALL	BPOSITIONNE	JUMP'	85$80$:	LOAD.B	D3,#BIPDONE	LIB	?BEEP		; indique que c'est fini	TEST.W	(A6)+ODINBF	; y a-t-il eu des fautes ?	JUMP',EQ 82$		; non => 82$				; oui =>	LOAD.L	D4,D5	INC.L	D4	CALL	BPOSITIONNE	; va au dbut de la premire faute	JUMP'	85$82$:	CALL	DBOXOPEN1	DICO_	OK		; indique que tout est ok ...	CALL	DBOXCLOSE185$:	CLR.W	D7		; D7 <-- ok90$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DICOADD >;========/; Ajoute un mot dans le dictionnaire.; in	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOADD:	PUSHM.L	D0..D6,A2..A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP',NE 90$	CALL	DBOXOPEN1	DICO_	ADD		; conserve un mot ...	CALL	DBOXCLOSE190$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICOCONJ >;=========/; Conjugue un verbe quelconque.; in	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOCONJ:	PUSHM.L	D0..D6,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP',NE 90$	LOAD.L	D5,D4	CALL	DBOXOPEN1	DICO_	CONJ		; conjugue un verbe ...	CALL	DBOXCLOSE1	COMP.W	D3,#F1		; remplace ?	JUMP',NE 90$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un mot90$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DICOACCORD >;===========/; Accorde un mot quelconque.; in	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOACCORD:	PUSHM.L	D0..D6,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP',NE 90$	LOAD.L	D5,D4	CALL	DBOXOPEN1	DICO_	ACCORD		; accorde le mot ...	CALL	DBOXCLOSE1	COMP.W	D3,#F1		; remplace ?	JUMP',NE 90$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un mot90$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICOSYNO >;=========/; Trouve le synonyme d'un mot quelconque.; in	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOSYNO:	PUSHM.L	D0..D6,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP',NE 90$	LOAD.L	D5,D4	CALL	DBOXOPEN1	DICO_	SYNO		; synonyme du mot ...	CALL	DBOXCLOSE1	COMP.W	D3,#F1		; remplace ?	JUMP',NE 90$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un mot90$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DICOOPTEXT >;-----------/; Ouvre le buffer de texte.; in	D4.L	position;	D5.L	nb de caractres; out	D4/D4.L	^texte/lg;	D6.L	canal DICO;	D7.W	erreur; mod	D4.L, D6.L, D7.W, A4.LDICOOPTEXT:	PUSHM.L	D1,D3	CALL	DICOLOAD	; D6 <-- canal	JUMP',NE 90$	CALL	BPOSITIONNE	; va au dbut de la zone  vrifier	JUMP',NE 90$	LOAD.L	D4,D5	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour texte	JUMP',NE 90$	LOAD.L	(A6)+ODIPBT,A420$:	CALL	BAVANCE	JUMP',NE 22$	LOAD.B	(A4+),D3	; buffer <-- caractres	DEC.L	D4	JUMP,NE 20$22$:	LOAD.L	A4,(A6)+ODIPBT	; A4 <-- ^texte	LOAD.L	D4,D5		; D4 <-- lg90$:	POPM.L	D1,D3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DICOCLTEXT >;-----------/; Ferme le buffer de texte.; in	-; out	-; mod	-DICOCLTEXT:	PUSHM.L	D1,D7,A4	TEST.L	(A6)+ODIPBT	JUMP',EQ 90$	LOAD.L	A4,(A6)+ODIPBT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le buffer de texte	CLR.L	(A6)+ODIPBT90$:	POPM.L	D1,D7,A4	RET;---------\\; DICOLOAD >;---------/; Donne le canal du dictionnaire, en le chargeant au pralable; si ncessaire.; in	-; out	D6.L	canal DICO;	D7.W	erreur; mod	D6.L, D7.WDICOLOAD:	PUSHM.L	D3,D4	LOAD.L	D6,(A6)+OCIDICO	JUMP',NE 80$	CALL	DBOXOPEN1	DICO_	OPEN		; ouvre le dictionnaire	CALL	DBOXCLOSE1	TEST.W	D7	JUMP',NE 90$	LOAD.L	(A6)+OCIDICO,D6	LOAD.L	D4,(A6)+ODIDEF	; D4 <-- dfinitions	JUMP',EQ 80$	LOAD.W	D3,#2		; D3 <-- put	DICO_	DEF		; donne les fanions au module DICO80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DICOCTEXI >;----------/; Cherche si c'est un mot  changer partout.; in	A3/D3.L	^ancien mot/lg; out	D7.W	ok;	 A4/D4.L ^nouveau mot/lg;	D7.W	erreur;	 A4/D4.L inchang; mod	D4.L, D7.W, A4.LDICOCTEXI:	PUSHM.L	D1,D2,A1,A2	LOAD.L	A2,#(A6)+OIOTM	CLR.B	D2	LOAD.W	D7,#1		; D7 <-- pas trouv20$:	COMP.B	D2,(A2)		; fin rencontre ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A1,A3	LOAD.L	D1,D330$:	COMP.B	D2,(A2)	JUMP',EQ 34$	DEC.L	D1	JUMP',NS 36$	COMP.B	(A2+),(A1+)	JUMP,EQ 30$	JUMP'	36$34$:	TEST.L	D1	JUMP',EQ 50$36$:	COMP.B	D2,(A2+)	; A2 <-- ^saute ancien mot	JUMP,NE 36$38$:	COMP.B	D2,(A2+)	; A2 <-- ^saute nouveau mot	JUMP,NE 38$	JUMP	20$50$:	LOAD.L	A4,#(A2)+1	; A4 <-- ^nouveau mot	LOAD.L	A2,A4	LOAD.L	D4,#-152$:	INC.L	D4		; D4 <-- lg nouveau mot	COMP.B	D2,(A2+)	JUMP,NE 52$	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D1,D2,A1,A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; DICOCTMEM >;----------/; Mmorise un mot  changer partout.; in	A3/D3.L	^ancien mot/lg;	A4/D4.L	^nouveau mot/lg; out	-; mod	D7.WDICOCTMEM:	PUSHM.L	D2..D4,A1..A4	LOAD.L	A2,#(A6)+OIOTM	LOAD.L	A1,A2	CLR.B	D220$:	COMP.B	D2,(A2)		; fin rencontre ?	JUMP',EQ 30$		; oui => 30$22$:	COMP.B	D2,(A2+)	; A2 <-- ^saute ancien mot	JUMP,NE 22$24$:	COMP.B	D2,(A2+)	; A2 <-- ^saute nouveau mot	JUMP,NE 24$	JUMP	20$30$:	ADD.L	A1,#LTMIO	SUB.L	A1,D3	SUB.L	A1,D4	SUB.L	A1,#2		; A1 <-- ^adresse  ne pas dpasser	COMP.L	A2,A1		; reste assez de place ?	JUMP,HS 90$		; non => 90$40$:	LOAD.B	(A2+),(A3+)	; OIOTM <-- ancien mot	DEC.W	D3	JUMP,NE 40$	CLR.B	(A2+)42$:	LOAD.B	(A2+),(A4+)	; OIOTM <-- nouveau mot	DEC.W	D4	JUMP,NE 42$	CLR.B	(A2+)	CLR.B	(A2+)90$:	POPM.L	D2..D4,A1..A4	RET;---------\\; DICOMASC >;---------/; Met  jour l'ascenseur  une position donne.; in	D3.L	position; out	-; mod	D7.WDICOMASC:	PUSH.L	D4	LOAD.L	D4,D3	CALL	BPOSITIONNE	; va au dbut du mot  changer	CALL	CASUPDATE	; met  jour l'ascenseur	POP.L	D4	RET;----------\\; DICOCHMOT >;----------/; Change un mot dans le texte.; in	D0.L	position dbut phrase;	D3.L	position dbut ancien mot;	A4/D4.L	^nouveau mot/lg;	D5.L	lg de l'ancien mot; out	D0.L	position dbut phrase;	D7.W	erreur; mod	D0.L, D7.WDICOCHMOT:	PUSHM.L	D3..D5,A4	ADD.L	D0,D4	SUB.L	D0,D5		; D0 <-- nouvelle position	EX.L	D4,D3	CALL	BPOSITIONNE	; va au dbut du mot  changer	EX.L	D3,D4	JUMP,NE 90$20$:	TEST.W	D5	JUMP',EQ 30$	CALL	BAVANCE	CALL	BDETRUIT	; dtruit un caractre de l'ancien mot	DEC.W	D5	COMP.B	D3,#'A	JUMP',LO 30$	COMP.B	D3,#'Z		; lettre majuscule ?	JUMP',HI 30$		; non => 30$	LOAD.B	D3,(A4+)	CALL	MINMAJ	JUMP'	40$30$:	LOAD.B	D3,(A4+)40$:	CALL	BINSERE		; insre un caractre du nouveau mot	JUMP',NE 90$	DEC.W	D4	JUMP,NE 20$50$:	DEC.W	D5	JUMP',NS 60$	CALL	BAVANCE	CALL	BDETRUIT	; dtruit un caractre de l'ancien mot	JUMP	50$60$:	CALL	ADISPLAY	; affiche tout correctement	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3..D5,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DICOMAMOT >;----------/; Marque un mot dans le texte (>...<).; in	D0.L	position dbut phrase;	D3.L	position dbut mot;	D4.L	lg du mot; out	D0.L	position dbut phrase;	D7.W	erreur; mod	D0.L, D7.WDICOMAMOT:	PUSHM.L	D3,D4	ADD.L	D0,#2		; D0 <-- nouvelle position	EX.L	D4,D3	CALL	BPOSITIONNE	; va au dbut du mot  marquer	EX.L	D3,D4	JUMP',NE 90$	CALL	BAVANCE	CALL	BRECULE	LOAD.B	D3,#MARKDM	CALL	BINSERE20$:	DEC.W	D4	JUMP',NS 30$	CALL	BAVANCE	JUMP	20$30$:	LOAD.B	D3,#MARKFM	CALL	BINSERE	CALL	ADISPLAY	; affiche tout correctement	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET	.END