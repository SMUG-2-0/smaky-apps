	.SBTTL	PLUMEMACROKPROGRA:	CALL	EXKEY	.WW	MACRO,MSTARTSTOP	.WW	0,BIPMSTARTSTOP:	TEST.B	(A6)+OFLAGS:#BMREC	JUMP',BS 50$				; start =>	LOAD.L	D3,#MACRO	CALL	MSTARTREC	; dbut enregistrement	JUMP,NE ERROR	TSET.B	(A6)+OFLAGS:#BMREC	CALL	CDESSINE1	; mj. les informations	JUMP	LOOP50$:				; stop =>	TCLR.B	(A6)+OFLAGS:#BMREC	CALL	CDESSINE1	; mj. les informations	CALL	MCOMPILE	; gnre la table OMAKEY	JUMP	LOOPKMACRO:	TCLR.B	(A6)+OFLAGS:#BMREC	JUMP',BC 20$	CALL	CDESSINE1	; mj. les informations	CALL	MCOMPILE	; gnre la table OMAKEY20$:	CALL	MSTARTPLAY	; dbut excution	JUMP,NE ERROR	JUMP	LOOPMERROR:	PUSH.W	D7	LOAD.W	D2,#MACZONE	CALL	ZUN		; zone principale = zone macro	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	MARRLINE	; recule au dbut de la ligne prcdente	CALL	ADISPLAY	; affiche la zone macro	POP.W	D7	JUMP	ERROR		; affiche l'erreur ...;-----------\\; MSTARTPLAY >;===========/; Dbut de l'excution d'une macro.; in	D3.L	touche; out	D7.W	erreur; mod	D7.WMSTARTPLAY:	PUSHM.L	D2..D4,A4,A5	LOAD.L	A4,#(A6)+OMAKEY-LMK	LOAD.W	D7,#EREMACR20$:	ADD.L	A4,#LMK		; A4 <-- ^suivant dans OMAKEY	TEST.L	(A4)+OMKCOD	JUMP',EQ 90$	COMP.W	D3,(A4)+OMKCOD+2	JUMP,NE 20$	LOAD.W	D2,#MACZONE	CALL	ZUSE		; A5 <-- ^descripteur zone macro	JUMP',NE 90$	CALL	MPUSH	JUMP',NE 90$	LOAD.L	D4,(A4)+OMKPOS	CALL	BPOSITIONNE	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; MSTARTREC >;==========/; Dbut de l'enregistrement d'une macro.; in	D3.L	touche; out	D7.W	erreur; mod	D7.WMSTARTREC:	PUSHM.L	D1..D4,A3,A5	LOAD.L	D1,D3		; D1 <-- touche	LOAD.W	D7,#ERPLUME	COMP.W	(A6)+OZONE1+ODZNUM,#MACZONE	JUMP,EQ 90$	LOAD.W	D2,#MACZONE	CALL	ZUSE		; A5 <-- ^descripteur zone macro	JUMP,NE 90$	TEST.L	(A5)+ODZNBC	; zone vide ?	JUMP',EQ 50$		; oui => 50$	LOAD.L	D3,D1		; D3 <-- touche cherche	CALL	MSEARCH	JUMP',NE 50$	CALL	MKILLINE	; dtruit la ligne "POUR [touche]"	CALL	MKVILINE	; dtruit la ligne vide juste avant30$:	CALL	MGETLINE	; A3 <-- ^ligne <CR>	JUMP',NE 50$	CALL	MDECOINS	; D3 <-- instruction (MOPxxx)	CALL	MKILLINE	; dtruit la ligne	COMP.W	D3,#MOPFIN	; instruction "FIN" ?	JUMP,NE 30$		; non => 30$50$:	LOAD.L	D3,#CR	CALL	BINSERE		; insre une ligne vide (avant le "POUR")	JUMP',NE 90$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3+),#'P	LOAD.B	(A3+),#'O	LOAD.B	(A3+),#'U	LOAD.B	(A3+),#'R	LOAD.B	(A3+),#SPACE	LOAD.L	D3,D1		; D3 <-- touche	CALL	MCODEKEY	; OBUDIS <-- touche code	LOAD.L	A3,#(A6)+OBUDIS	CALL	MINSLINE	; insre "POUR [touche]"	JUMP',NE 90$	LOAD.L	A3,#R16"FIN$	CALL	MINSLINE	; insre "FIN"	JUMP',NE 90$	LOAD.W	D4,#4-160$:	CALL	BRECULE		; recule entre le "POUR" et le "FIN"	DECJ.W,NMO D4,60$90$:	POPM.L	D1..D4,A3,A5	TEST.W	D7		; retour EQ/NE	RETFIN$:	.ASCIZ	"FIN<CR>"	.EVEN;--------\\; MSEARCH >;--------/; Cherche une ligne "POUR [touche]" dans la zone macro.; Le curseur est positionn au dbut de la ligne suivante !; in	A5.L	^descripteur zone macro;	D3.L	touche; out	D7.W	erreur; mod	D7.WMSEARCH:	PUSHM.L	D2..D4,A3	LOAD.L	D2,D3		; D2 <-- touche cherche	CLR.L	D4	CALL	BQPOSITIONNE	; va (rapidement) au dbut20$:	CALL	MGETLINE	; A3 <-- ^ligne <CR>	JUMP',NE 90$	CALL	MDECOINS	; D3 <-- instruction (MOPxxx)	COMP.W	D3,#MOPPOUR	; instruction "POUR" ?	JUMP,NE 20$		; non => 20$				; oui =>	CALL	MSKIPSEP	; A3 <-- saute sparateurs(s)	CALL	MDECOKEY	; D3 <-- touche aprs "POUR"	JUMP,NE 20$	COMP.W	D3,D2		; touche trouve ?	JUMP,NE 20$		; non => 20$90$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; MRECORD >;========/; Enregistre une touche dans la zone des macros.; in	D3.L	touche  enregistrer; out	D7.W	erreur; mod	D7.WMRECORD:	PUSHM.L	D2,D3,A3,A5	CLR.W	D7	COMP.B	D3,#MACRO	JUMP',EQ 90$	LOAD.W	D2,#MACZONE	CALL	ZUSE		; A5 <-- ^descripteur zone macro	JUMP',NE 90$	LOAD.L	A3,#(A6)+OBUDIS	CALL	MCODEKEY	; OBUDIS <-- touche code	LOAD.L	A3,#(A6)+OBUDIS	CALL	MINSLINE	; insre la touche code90$:	POPM.L	D2,D3,A3,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; MPLAY   >;========/; Lit une touche dans la zone des macros.; in	-; out	D3.L	touche lue (zro si rien);	D7.W	erreur (ERKSTO si macro termine); mod	D3.L, D7.WMPLAY:	PUSHM.L	D2,A3..A5	LOAD.W	D2,#MACZONE	CALL	ZUSE		; A5 <-- ^descripteur zone macro	JUMP,NE EXIT$	CALL	MGETLINE	; A3 <-- ^ligne <CR>	JUMP,NE EXIT$	PUSH.L	A3	CALL	MDECOKEY	; D3 <-- touche dcode	POPM.L	A3	JUMP,EQ EXIT$	LOAD.L	A4,A5	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	MDECOINS	; D3 <-- instruction (MOPxxx)	COMP.W	D3,#MOPPOUR	JUMP,EQ POUR$	COMP.W	D3,#MOPFIN	JUMP,EQ FIN$	COMP.W	D3,#MOPINS	JUMP,EQ INS$	COMP.W	D3,#MOPAFF	JUMP,EQ AFF$	JUMP	EXIT$POUR$:				; POUR =>	JUMP	OK$FIN$:				; FIN =>	LOAD.L	A5,A4		; A5 <-- ^descripteur macro	CALL	MPOP	JUMP,NE EXIT$	LOAD.W	D7,#ERKSTO	; D7 <-- fin de la macro	TEST.W	(A6)+OMASTN	; stack vide ?	JUMP,NE EXIT$		; oui => EXIT$	JUMP	OK$INS$:				; INS =>	CALL	MSKIPSEP	LOAD.W	D7,#EREMACR	LOAD.B	D2,(A3+)	COMP.B	D2,#'"	JUMP',EQ INS2$	COMP.B	D2,#''	JUMP',EQ INS2$	COMP.B	D2,#'/	JUMP,NE EXIT$INS2$:	LOAD.B	D3,(A3+)	LOAD.W	D7,#EREMACR	COMP.B	D3,#CR	JUMP,EQ EXIT$	COMP.B	D3,D2	JUMP,EQ OK$	CALL	EINSERE	JUMP,NE EXIT$	JUMP	INS2$AFF$:				; AFF =>	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	ADISPLAY	; affiche tout correctement	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	CALL	ADISPLAY	; affiche tout correctement;	JUMP	OK$OK$:	CLR.L	D3		; D3 <-- pas de touche	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,A3..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; MPUSH   >;--------/; Push effectue lors du dbut de l'excution d'une macro (instruction "POUR").; in	A5.L	^description zone macro; out	D7.W	erreur; mod	D7.WMPUSH:	PUSHM.L	D4,A4	LOAD.W	D7,#EREMACR	LOAD.L	A4,#(A6)+OMASTK	LOAD.W	D4,(A6)+OMASTN	COMP.W	D4,#MAXMS	JUMP',HS 90$	MUL.WU	D4,#LMS	LOAD.L	(A4)+(D4.L)+OMSPOS,(A5)+ODZPOS	INC.W	(A6)+OMASTN	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; MPOP    >;--------/; Pop effectue lors de la fin de l'excution d'une macro (instruction "FIN").; in	A5.L	^description zone macro; out	D7.W	erreur; mod	D7.WMPOP:	PUSHM.L	D4,A4	LOAD.W	D7,#EREMACR	LOAD.L	A4,#(A6)+OMASTK	LOAD.W	D4,(A6)+OMASTN	JUMP',EQ 90$	DEC.W	D4	LOAD.W	(A6)+OMASTN,D4	MUL.WU	D4,#LMS	LOAD.L	D4,(A4)+(D4.L)+OMSPOS	CALL	BPOSITIONNE	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MCOMPILE >;=========/; Gnre la table OMAKEY en fonction du contenu de la zone macro.; in	-; out	-; mod	D7.WMCOMPILE:	PUSHM.L	D2..D4,A3..A5	LOAD.W	D2,#MACZONE	CALL	ZUSE		; A5 <-- ^descripteur zone macro	JUMP,NE 90$	CALL	BPSAUVE	PUSH.W	D4	CLR.L	D4	CALL	BQPOSITIONNE	; va (rapidement) au dbut	LOAD.L	A4,#(A6)+OMAKEY	LOAD.W	D4,#MAXMK-120$:	CALL	MGETLINE	; A3 <-- ^ligne <CR>	JUMP',NE 50$	CALL	MDECOINS	; D3 <-- instruction (MOPxxx)	COMP.W	D3,#MOPPOUR	; instruction "POUR" ?	JUMP,NE 20$	CALL	MSKIPSEP	CALL	MDECOKEY	; D3 <-- touche aprs "POUR"	JUMP,NE 20$	LOAD.L	(A4)+OMKCOD,D3	LOAD.L	(A4)+OMKPOS,(A5)+ODZPOS	ADD.L	A4,#LMK		; A4 <-- ^suivant dans OMAKEY	DEC.W	D4	JUMP,NE 20$50$:	CLR.L	(A4)+OMKCOD80$:	POP.W	D4	CALL	BPPREND		; retourne o l'on tait90$:	POPM.L	D2..D4,A3..A5	RET;-----------\\; MDECOMPILE >;===========/; Vide la table OMAKEY, ce qui doit tre fait chaque fois que; la zone macro est visible (et donc succeptible d'tre modifie).; in	-; out	-; mod	D7.WMDECOMPILE:	CLR.L	(A6)+OMAKEY+OMKCOD	RET;---------\\; MSKIPSEP >;---------/; Saute ventuellement un ou plusieurs sparateurs.; in	A3.L	^texte <CR>; out	A3.L	^plus loin; mod	D7.W, A3.LMSKIPSEP:	PUSH.W	D310$:	LOAD.B	D3,(A3)	COMP.B	D3,#CR	JUMP',EQ 90$	INC.L	A3	COMP.B	D3,#SPACE	JUMP,EQ 10$	COMP.B	D3,#TAB	JUMP,EQ 10$	DEC.L	A390$:	POP.W	D3	RET;---------\\; MDECOINS >;---------/; Dcode une instruction.; in	A3.L	^texte <CR>; out	A3.L	^plus loin;	D3.W	numro instruction (MOPxxx);	D7.W	erreur; mod	D3.L, D7.W, A3.LMDECOINS:	PUSHM.L	A1,A2,A4	LOAD.L	A4,#R16"MINS20$:	TEST.W	(A4)		; fin de la table ?	JUMP,EQ 80$		; oui => 80$	LOAD.L	A2,#(A4)+2	LOAD.L	A1,A330$:	COMP.B	(A1+),(A2+)	JUMP,EQ 30$	TEST.B	(A2)-1	JUMP',NE 50$	LOAD.B	D3,(A1)-1	COMP.B	D3,#SPACE	JUMP',EQ 40$	COMP.B	D3,#TAB	JUMP',EQ 40$	COMP.B	D3,#CR	JUMP',NE 50$40$:	LOAD.L	A3,#(A1)-1	; A3 <-- ^plus loin	LOAD.W	D3,(A4)		; D3 <-- code partiel	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	ADD.L	A4,#2		; A4 <-- saute .W52$:	TEST.B	(A4+)		; A4 <-- saute .ASCIZ	JUMP,NE 52$	EX.L	D3,A4	INC.L	D3	TCLR.L	D3:#0		; A4 <-- saute .EVEN	EX.L	A4,D3	JUMP	20$80$:	CLR.W	D3		; D3 <-- zro si erreur	LOAD.W	D7,#EREMACR	; D7 <-- pas trouv90$:	POPM.L	A1,A2,A4	TEST.W	D7		; retour EQ/NE	RETMINS:	.W	MOPPOUR	.ASCIZ	"POUR"	.EVEN	.W	MOPFIN	.ASCIZ	"FIN"	.EVEN	.W	MOPINS	.ASCIZ	"INSERE"	.EVEN	.W	MOPAFF	.ASCIZ	"AFFICHE"	.EVEN	.W	0;---------\\; MDECOKEY >;---------/; Dcode une touche.; in	A3.L	^touche code <CR>; out	A3.L	^plus loin;	D3.L	touche dcode;	D7.W	erreur; mod	D3.L, D7.W, A3.LMDECOKEY:	PUSHM.L	D0..D2	CLR.L	D2		; D2 <-- touche lue	LOAD.W	D7,#EREMACR	COMP.B	(A3+),#'[	JUMP,NE 90$40$:	COMP.B	(A3),#']	; fin de la ligne ?	JUMP,EQ 70$		; oui => 70$	CALL	MDECOPAR	; D3 <-- code partiel	JUMP',NE 50$	OR.W	D2,D3	JUMP	40$50$:	LOAD.B	D3,(A3)	LOAD.B	D0,D3	COMP.B	(A3)+0,#'C	JUMP',NE 56$	COMP.B	(A3)+1,#'T	JUMP',NE 56$	COMP.B	(A3)+2,#'R	JUMP',NE 56$	COMP.B	(A3)+3,#'L	JUMP',NE 56$	COMP.B	(A3)+4,#'-	JUMP',NE 56$	ADD.L	A3,#5		; A3 <-- saute "CTRL-"	LOAD.B	D3,(A3)		; D3 <-- caractre aprs "CTRL-"	LOAD.B	D0,D3	LOAD.B	D1,#H'20	COMP.B	D3,#'0	JUMP',LO 56$	COMP.B	D3,#'9	JUMP',LS 54$	LOAD.B	D1,#H'40	COMP.B	D3,#'A	JUMP',LO 56$	COMP.B	D3,#'Z	JUMP',LS 54$	LOAD.B	D1,#H'60	COMP.B	D3,#'a	JUMP',LO 56$	COMP.B	D3,#'z	JUMP',HI 56$54$:	SUB.B	D3,D1		; D3 <-- H'00..H'2056$:	OR.B	D2,D3	LOAD.B	D3,D0	CALL	MINMAJ	COMP.B	D3,#'0	JUMP',LO 62$	COMP.B	D3,#'9	JUMP',LS 60$	COMP.B	D3,#'A	JUMP',LO 62$	COMP.B	D3,#'Z	JUMP',HI 62$60$:	SWAP.W	D2	LOAD.B	D2,D3		; D2 <-- pseudo-code	SWAP.W	D262$:	LOAD.W	D7,#EREMACR	INC.L	A3	COMP.B	(A3),#']	JUMP',NE 90$70$:	LOAD.W	D7,#EREMACR	INC.L	A3	COMP.B	(A3),#CR	JUMP',NE 90$	LOAD.L	D3,D2		; D3 <-- touche presse	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; MDECOPAR >;---------/; Dcode partiellement une touche.; in	A3.L	^ligne; out	A3.L	^plus loin;	D3.L	touche;	D7.W	erreur; mod	D3.L, D7.W, A3.LMDECOPAR:	PUSHM.L	A1,A2,A4	LOAD.L	A4,#R16"MTABLE	LOAD.W	D7,#EREMACR20$:	TEST.W	(A4)		; fin de la table ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A2,#(A4)+2	LOAD.L	A1,A330$:	COMP.B	(A1+),(A2+)	JUMP,EQ 30$	TEST.B	(A2)-1	JUMP',NE 50$	LOAD.B	D3,(A1)-1	COMP.B	D3,#'-	JUMP',EQ 40$	COMP.B	D3,#']	JUMP',EQ 40$	COMP.B	D3,#CR	JUMP',NE 50$40$:	LOAD.L	A3,#(A1)-1	; A3 <-- ^plus loin	COMP.B	D3,#'-	JUMP',NE 42$	INC.L	A342$:	CLR.L	D3	LOAD.W	D3,(A4)		; D3 <-- code partiel	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	ADD.L	A4,#2		; A4 <-- saute .W52$:	TEST.B	(A4+)		; A4 <-- saute .ASCIZ	JUMP,NE 52$	EX.L	D3,A4	INC.L	D3	TCLR.L	D3:#0		; A4 <-- saute .EVEN	EX.L	A4,D3	JUMP	20$90$:	POPM.L	A1,A2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MCODEKEY >;---------/; Code une touche dans un buffer.; in	D3.L	touche presse;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LMCODEKEY:	PUSHM.L	D1..D4,A4	LOAD.L	A4,A3	CLR.W	D1		; D1 <-- nb de "mots"	LOAD.L	D2,D3	LOAD.B	(A4+),#'[20$:	LOAD.L	D3,D2	CALL	MCODEPAR	; A3 <-- ^dans MTABLE	JUMP',NE 50$	LOAD.W	D3,(A3)	NOT.W	D3	AND.W	D2,D3		; D2 <-- code restant	TEST.W	D1		; est-ce le premier "mot" ?	JUMP',EQ 25$		; oui => 25$	LOAD.B	(A4+),#'-25$:	INC.W	D1	ADD.L	A3,#2		; A3 <-- saute .W30$:	LOAD.B	D3,(A3+)	JUMP,EQ 20$	LOAD.B	(A4+),D3	; insre un nom de touche	JUMP	30$50$:	TEST.W	D2		; reste qq chose ?	JUMP,EQ 80$		; non => 80$	TEST.W	D1		; est-ce le premier "mot" ?	JUMP',EQ 55$		; oui => 55$	LOAD.B	(A4+),#'-55$:	COMP.B	D2,#H'20	JUMP',HS 65$	LOAD.L	D3,D2	SWAP.W	D3		; D3 <-- pseudo-code	LOAD.B	D1,#H'20	COMP.B	D3,#'0	JUMP',LO 65$	COMP.B	D3,#'9	JUMP',LS 60$	LOAD.B	D1,#H'40	COMP.B	D3,#'A	JUMP',LO 65$	COMP.B	D3,#'Z	JUMP',HI 65$60$:	LOAD.B	(A4+),#'C	LOAD.B	(A4+),#'T	LOAD.B	(A4+),#'R	LOAD.B	(A4+),#'L	LOAD.B	(A4+),#'-	ADD.B	D2,D1		; D2 <-- "0".."9" ou "A".."Z"65$:	LOAD.B	(A4+),D2	; insre un code ASCII80$:	LOAD.B	(A4+),#']	LOAD.B	(A4+),#CR	LOAD.L	A3,A4	POPM.L	D1..D4,A4	RET;---------\\; MCODEPAR >;---------/; Code partiellement une touche.; in	D3.L	touche; out	A3.L	^lment dans MTABLE;	D7.W	erreur; mod	D7.W, A3.LMCODEPAR:	PUSHM.L	D2..D4	LOAD.W	D7,#EREMACR	COMP.W	D3,#H'100	; y a-t-il des touches super-shift ?	JUMP',HS 05$		; oui => 05$	LOAD.L	D4,D3	SWAP.W	D4		; D4 <-- pseudo-code	COMP.B	D4,#'0	JUMP',LO 05$	COMP.B	D4,#'9	JUMP,LS 90$	COMP.B	D4,#'A	JUMP',LO 05$	COMP.B	D4,#'Z	JUMP,LS 90$05$:	LOAD.L	A3,#R16"MTABLE	LOAD.W	D4,D3	AND.W	D4,#H'00FF	; D4 <-- code normal	AND.W	D3,#H'FF00	; D3 <-- code super-shift	JUMP',EQ 20$	LOAD.W	D2,#1610$:	DEC.W	D2		; D2 <-- bit suivant	RL.W	D3,#1	JUMP,CC 10$	CLR.W	D3	TSET.L	D3:D2		; D3 <-- une seule touche super-shift !20$:	LOAD.W	D2,(A3)		; fin de la table ?	JUMP',EQ 90$		; oui => 90$	COMP.W	D2,#H'100	JUMP',LO 30$	COMP.W	D2,D3	JUMP',EQ 80$	JUMP'	40$30$:	COMP.W	D2,D4	JUMP',EQ 80$40$:	ADD.L	A3,#2		; A3 <-- saute .W42$:	TEST.B	(A3+)		; A3 <-- saute .ASCIZ	JUMP,NE 42$	EX.L	D2,A3	INC.L	D2	TCLR.L	D2:#0		; A3 <-- saute .EVEN	EX.L	A3,D2	JUMP	20$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RETMTABLE:	.W	H'100*(2^BCURSOR)	.ASCIZ	"CURSOR"	.EVEN	.W	H'100*(2^BCOPY)	.ASCIZ	"COPY"	.EVEN	.W	H'100*(2^BKILL)	.ASCIZ	"KILL"	.EVEN	.W	H'100*(2^BPROGRA)	.ASCIZ	"PROGRA"	.EVEN	.W	H'100*(2^BSHOW)	.ASCIZ	"SHOW"	.EVEN	.W	H'100*(2^BSEARCH)	.ASCIZ	"SEARCH"	.EVEN	.W	H'100*(2^BCHANGE)	.ASCIZ	"CHANGE"	.EVEN	.W	UNDO	.ASCIZ	"UNDO"	.EVEN	.W	DEL	.ASCIZ	"DEL"	.EVEN	.W	BS	.ASCIZ	"SHIFT-DEL"	.EVEN	.W	TAB	.ASCIZ	"TAB"	.EVEN	.W	END	.ASCIZ	"END"	.EVEN	.W	CR	.ASCIZ	"RETURN"	.EVEN	.W	MACRO	.ASCIZ	"MACRO"	.EVEN	.W	FNCT	.ASCIZ	"FNCT"	.EVEN	.W	DEFINE	.ASCIZ	"DEFINE"	.EVEN	.W	CLEAR	.ASCIZ	"CLEAR"	.EVEN	.W	TRIZERO	.ASCIZ	"000"	.EVEN	.W	POINT	.ASCIZ	"."	.EVEN	.W	ENTER	.ASCIZ	"ENTER"	.EVEN	.W	CADRATIN	.ASCIZ	"CADRATIN"	.EVEN	.W	SPACE	.ASCIZ	"SPACE"	.EVEN	.W	CADRATIN	.ASCIZ	"CTRL-SPACE"	.EVEN	.W	CTAB	.ASCIZ	"CTRL-TAB"	.EVEN	.W	STAB	.ASCIZ	"SHIFT-TAB"	.EVEN	.W	LF	.ASCIZ	"CTRL-RETURN"	.EVEN	.W	EOP	.ASCIZ	"SHIFT-RETURN"	.EVEN	.W	F0	.ASCIZ	"F0"	.EVEN	.W	F1	.ASCIZ	"F1"	.EVEN	.W	F2	.ASCIZ	"F2"	.EVEN	.W	F3	.ASCIZ	"F3"	.EVEN	.W	F4	.ASCIZ	"F4"	.EVEN	.W	F5	.ASCIZ	"F5"	.EVEN	.W	F6	.ASCIZ	"F6"	.EVEN	.W	F7	.ASCIZ	"F7"	.EVEN	.W	F8	.ASCIZ	"F8"	.EVEN	.W	F9	.ASCIZ	"F9"	.EVEN	.W	F10	.ASCIZ	"F10"	.EVEN	.W	F11	.ASCIZ	"F11"	.EVEN	.W	F12	.ASCIZ	"F12"	.EVEN	.W	F13	.ASCIZ	"F13"	.EVEN	.W	F14	.ASCIZ	"F14"	.EVEN	.W	F15	.ASCIZ	"F15"	.EVEN	.W	0;---------\\; MGETLINE >;---------/; Lit une ligne complte, et avance au dbut de la suivante.; in	-; out	A3.L	^ligne lue <CR>;	D7.W	erreur; mod	D7.W, A3.LMGETLINE:	PUSH.L	D3	LOAD.L	A3,#(A6)+OBUDIS20$:	CALL	BAVANCE	JUMP',NE 90$	LOAD.B	(A3+),D3	; OBUDIS <-- une ligne	COMP.B	D3,#CR	JUMP,NE 20$90$:	LOAD.L	A3,#(A6)+OBUDIS	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; MINSLINE >;---------/; Insre une ligne complte.; in	A3.L	^ligne <CR>; out	D7.W	erreur; mod	D7.WMINSLINE:	PUSHM.L	D3,A320$:	CLR.L	D3	LOAD.B	D3,(A3+)	CALL	BINSERE		; insre la touche code	JUMP',NE 90$	COMP.B	D3,#CR	JUMP,NE 20$90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; MKVILINE >;---------/; Dtruit la ligne avant le curseur, si elle est vide.; in	-; out	-; mod	D7.WMKVILINE:	PUSH.L	D3	CALL	BRECULE	JUMP',NE 90$	COMP.B	D3,#CR	JUMP',NE 85$	CALL	BRECULE	JUMP',NE 50$	COMP.B	D3,#CR	JUMP',NE 80$	CALL	BAVANCE50$:	CALL	BAVANCE	CALL	BDETRUIT	JUMP'	90$80$:	CALL	BAVANCE85$:	CALL	BAVANCE90$:	POP.L	D3	RET;---------\\; MKILLINE >;---------/; Dtruit la ligne juste avant le curseur.; in	-; out	-; mod	D7.WMKILLINE:	PUSH.L	D3	CALL	BDETRUIT	JUMP',NE 90$20$:	CALL	BDETRUIT	JUMP',NE 90$	COMP.B	D3,#CR	JUMP,NE 20$	CALL	BINSERE90$:	POP.L	D3	RET;---------\\; MARRLINE >;---------/; Recule au dbut de la ligne prcdente.; in	-; out	-; mod	D7.WMARRLINE:	PUSH.L	D3	CALL	BRECULE	JUMP',NE 90$20$:	CALL	BRECULE	JUMP',NE 90$	COMP.B	D3,#CR	JUMP,NE 20$	CALL	BAVANCE90$:	POP.L	D3	RET	.END