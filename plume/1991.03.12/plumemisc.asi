	.SBTTL	PLUMEMISC;--------\\; EXKEY   >;========/; in	D3.B	touche presse; out	-; mod	A0.LEXKEY:	POP.L	A0		; A0 <-- ^table des .WW	PUSH.L	D3	COMP.B	D3,#'a		; minuscule ?	JUMP',LO 10$		; non => 10$	COMP.B	D3,#'z	JUMP',HI 10$	SUB.B	D3,#'a-'A	; oui => transforme10$:	SUB.L	A0,#4		; A0 <-- recule .WW20$:	ADD.L	A0,#4		; A0 <-- saute .WW	TEST.W	(A0)		; table termine ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.B	D3,(A0)+1	; code touche trouve ?	JUMP,NE	20$		; non => 20$50$:	CLR.L	D3	LOAD.W	D3,(A0)+2	LOAD.L	A0,D3		; A0 <-- adresse relative	ADD.L	A0,(A6)+OSTART	; A0 <-- adresse absolue	POP.L	D3	JUMP	(A0)		; excute ...;--------\\; EXFONC  >;========/; in	D3.W	touche fonction (dans high); out	-; mod	A0.LEXFONC:	POP.L	A0		; A0 <-- ^table des .WW	PUSH.L	D3	SR.W	D3,#8		; D3 <-- touche fonction	SUB.L	A0,#4		; A0 <-- recule .WW20$:	ADD.L	A0,#4		; A0 <-- saute .WW	TEST.W	(A0)		; table termine ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.B	D3,(A0)+1	; code touche fonction trouv ?	JUMP,NE	20$		; non => 20$50$:	CLR.L	D3	LOAD.W	D3,(A0)+2	LOAD.L	A0,D3		; A0 <-- adresse relative	ADD.L	A0,(A6)+OSTART	; A0 <-- adresse absolue	POP.L	D3	JUMP	(A0)		; excute ...;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; CCMO    >;========/; Enlve la souris.; in	-; out	-; mod	-CCMO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	POPM.L	D3,D7	RET;--------\\; SCMO    >;========/; Remet la souris.; in	-; out	-; mod	-SCMO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	POPM.L	D3,D7	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	-; out	-; mod	D7.WAFMENU:	PUSHM.L	D3,A3	LOAD.L	A3,#R16"TXMENU	LIB	?AFMENU	POPM.L	D3,A3	RETTXMENU:	.ASCIZ	""	.ASCIZ	" Fin "		;     ;     ;     ;	.ASCIZ	"      Ajoute     "	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" Df.            "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" Car. Frap.Change"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Zones Efface     "		;     ;     ;     ;	.EVEN;--------\\; MINMAJ  >;========/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMINMAJ:	TEST.L	D3:#7		; code "supplmentaire" ?	JUMP',NE 20$		; oui => 20$	COMP.B	D3,#SPACE-2	; lettre accentue ?	JUMP',LO 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+TABLE$ ; D3 <-- lettre majuscule	POP.W	D0	RETTABLE$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN	.END