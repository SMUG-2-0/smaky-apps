	.SBTTL	PLUMECADRE;---------\\; CDESSINE >;=========/; Dessine le cadre brut (sans ascenseur).; in	-; out	-; mod	D7.WCDESSINE:	PUSHM.L	D2..D6,A0	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LIB	?AFTIM	.B	EOP		; efface la fentre	.B	NOROLL		; pas de roll	.B	TRUNC		; tronque lignes trop longues	.B	NOEFLI		; n'efface pas les lignes	.B	NOCURS		; pas de curseur	.B	0	.EVEN	LOAD.L	D3,#-1		; D3 <-- trame "pleine"	LOAD.L	D4,D3		; D4 <-- trame "pleine"	LIB	?DRMDEF		; dfinit la trame	LOAD.W	D5,(A0)+ODFDX	; D5 <-- largeur de la fentre	LOAD.W	D6,(A0)+ODFDY	; D6 <-- hauteur de la fentre	LOAD.B	D2,#SETDOT	; D2 <-- <mode>	CLR.L	D3		; D3 <-- <xx> et <yy>	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	; D4 <-- <dyy>	LOAD.W	(A6)+OWDPOS+0,D4	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- <dxx>	LIB	?DRTRAME	; surface suprieure	LOAD.W	D4,#CLGY	; D4 <-- <dyy>	LOAD.W	D3,D6		; D3 <-- <yy>	SUB.W	D3,D4	SWAP.W	D3	CLR.W	D3		; D3 <-- <xx>	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- <dxx>	LIB	?DRTRAME	; surface infrieure	CLR.L	D3		; D3 <-- <xx> et <yy>	LOAD.W	D4,D6		; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,#CLGX	; D4 <-- <dxx>	LOAD.W	(A6)+OWDPOS+2,D4	LIB	?DRTRAME	; surface gauche	LOAD.W	D3,D5	SUB.W	D3,#CLGX	; D3 <-- <xx>	LOAD.W	D4,D6		; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,#CLGX	; D4 <-- <dxx>	LIB	?DRTRAME	; surface droite	LOAD.W	D4,D5	SUB.W	D4,#CLGX+CLGX	LOAD.W	(A6)+OWDDIM+2,D4	LOAD.W	D4,D6	SUB.W	D4,(A0)+ODFC1Y	SUB.W	D4,(A0)+ODFC2Y	SUB.W	D4,#CLGY	LOAD.W	(A6)+OWDDIM+0,D4	LOAD.W	D4,D6	SR.W	D4,#1	LOAD.W	(A6)+OWDSEP,D4	POPM.L	D2..D6,A0	RET;----------\\; CDESSINE1 >;==========/; Dessine les informations de la zone principale.; in	A5.L	^description zone; out	-; mod	D7.WCDESSINE1:	PUSHM.L	D3,A0	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.B	D3,#AFINV	LIB	?AFCAR	LOAD.W	D3,#1	CALL	CINFOPOS	TEST.B	(A6)+OFLAGS:#BMREC	JUMP',BS 30$	LIB	?AFTIM	.ASCII	"PLUME "	.B	MAJREV+'0,'.	.IF	MINREV<10	.B	MINREV+'0	.ELSE	.B	(MINREV/10)+'0,(MINREV-((MINREV/10)*10))+'0	.ENDIF	.B	PROREV	.B	0	.EVEN	JUMP'	35$30$:	LIB	?AFTIM	.ASCII	"   "	.B	AFDIR	.ASCII	" MACRO "	.B	AFINV	.ASCII	"  "	.B	0	.EVEN35$:	LOAD.W	D3,#INFPUSE	CALL	CINFOPOS	LIB	?AFTIM	.ASCIZ	"Utilis:"	.EVEN	LOAD.W	D3,#INFPZON	CALL	CINFOPOS	LIB	?AFTIM	.ASCIZ	"Zone:"	.EVEN	LOAD.L	(A5)+ODZINC,#-1	LOAD.L	(A5)+ODZINL,#-1	CALL	CINFOUSE	; affiche le nombre de caractres utiliss	CALL	CINFOZON	; affiche le numro de la zone	CALL	CINFOFIL	; affiche le nom du fichier	LOAD.B	D3,#AFDIR	LIB	?AFCAR	POPM.L	D3,A0	RET;----------\\; CDESSINE2 >;==========/; Dessine la sparation entre les zones principale et secondaire.; in	A5.L	^description zone; out	-; mod	D7.WCDESSINE2:	PUSHM.L	D2..D4,A0	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.L	D3,#-1		; D3 <-- trame "pleine"	LOAD.L	D4,D3		; D4 <-- trame "pleine"	LIB	?DRMDEF		; dfinit la trame	LOAD.W	D3,(A6)+OZONE2+ODZWPO+0	SUB.W	D3,(A6)+OWDPOS+0	SWAP.W	D3	LOAD.W	D3,(A6)+OZONE2+ODZWPO+2	SUB.W	D3,#CMGG	LOAD.W	D4,(A6)+OWDPOS+0	SWAP.W	D4	LOAD.W	D4,(A6)+OZONE2+ODZWDI+2	ADD.W	D4,#CMGG	LOAD.B	D2,#LOADDOT	; D2 <-- <mode>	LIB	?DRTRAME	; surface de sparation	CALL	CICODRAW	; dessine les icnes	LOAD.B	D3,#AFINV	LIB	?AFCAR	LOAD.W	D3,#INFPZON	CALL	CINFOPOS	LIB	?AFTIM	.ASCIZ	"Zone: "	.EVEN	CALL	CINFOZON	; affiche le numro de la zone	CALL	CINFOFIL	; affiche le nom du fichier	LOAD.B	D3,#AFDIR	LIB	?AFCAR	POPM.L	D2..D4,A0	RET;---------\\; CINVSEP2 >;=========/; Inverse la sparation entre les zones principale et secondaire.; in	D4.L	position de la souris (y;x); out	-; mod	D7.WCINVSEP2:	PUSHM.L	D2..D4	LOAD.L	D2,D4	SWAP.W	D2	LOAD.L	D3,#-1		; D3 <-- trame "pleine"	LOAD.L	D4,D3		; D4 <-- trame "pleine"	LIB	?DRMDEF		; dfinit la trame	LOAD.W	D3,(A6)+OWDPOS+0	SR.W	D3,#1	SUB.W	D3,D2	NEG.W	D3	SWAP.W	D3	LOAD.W	D3,(A6)+OZONE2+ODZWPO+2	SUB.W	D3,#CMGG	LOAD.W	D4,(A6)+OWDPOS+0	SWAP.W	D4	LOAD.W	D4,(A6)+OZONE2+ODZWDI+2	ADD.W	D4,#CMGG	LOAD.B	D2,#INVDOT	; D2 <-- <mode>	LIB	?DRTRAME	; surface de sparation	POPM.L	D2..D4	RET;---------\\; CINFOUSE >;=========/; Affiche les informations aprs "Utilis:".; in	A5.L	^description zone; out	-; mod	D7.WCINFOUSE:	PUSHM.L	D2..D4,A0	LOAD.L	D4,(A5)+ODZNBC	COMP.L	D4,(A5)+ODZINC	; nombre de caractres chang ?	JUMP',NE 20$	LOAD.L	D4,(A5)+ODZNBL	COMP.L	D4,(A5)+ODZINL	; nombre de lignes chang ?	JUMP,EQ 90$20$:	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.W	D3,#INFPUSE+9	CALL	CINFOPOS	LOAD.B	D3,#AFINV	LIB	?AFCAR	LOAD.W	D2,#8+1+8	LOAD.L	D4,(A5)+ODZNBC	LOAD.L	(A5)+ODZINC,D4	CALL	CINFOAFDEC	; affiche le nombre de caractres	SUB.W	D2,D3	LOAD.B	D3,#'/	LIB	?AFCAR	DEC.W	D2	LOAD.L	D4,(A5)+ODZNBL	LOAD.L	(A5)+ODZINL,D4	CALL	CINFOAFDEC	; affiche le nombre de lignes	SUB.W	D2,D3	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D2	LIB	?AFCAR		; efface la fin	LOAD.B	D3,#AFDIR	LIB	?AFCAR90$:	POPM.L	D2..D4,A0	RET;---------\\; CINFOZON >;=========/; Affiche les informations aprs "Zone:".; in	A5.L	^description zone; out	-; mod	D7.WCINFOZON:	PUSHM.L	D2..D4,A0	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.W	D3,#INFPZON+6	CALL	CINFOPOS	LOAD.B	D3,#AFINV	LIB	?AFCAR	LOAD.W	D2,#7	CLR.L	D4	LOAD.W	D4,(A5)+ODZNUM	CALL	CINFOAFDEC	; affiche le numro de la zone	SUB.W	D2,D3	SUB.W	D4,#10	JUMP',LO 70$	COMP.W	D4,#26	JUMP',HS 70$	LOAD.B	D3,#SPACE	LIB	?AFCAR	LOAD.B	D3,#'(	LIB	?AFCAR	LOAD.B	D3,#'A	ADD.B	D3,D4	LIB	?AFCAR		; affiche (A)..(Z)	LOAD.B	D3,#')	LIB	?AFCAR	SUB.W	D2,#370$:	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D2	LIB	?AFCAR		; efface la fin	LOAD.B	D3,#AFDIR	LIB	?AFCAR	POPM.L	D2..D4,A0	RET;---------\\; CINFOFIL >;=========/; Affiche le nom du fichier dans les informations.; in	A5.L	^description zone; out	-; mod	D7.WCINFOFIL:	PUSHM.L	D2..D4,A0,A3	LOAD.L	A3,#(A6)+OZONE1	COMP.L	A5,A3	JUMP',EQ 10$	LOAD.L	A3,#(A6)+OZONE2	COMP.L	A5,A3		; est-ce une zone visible ?	JUMP,NE 90$		; non => 90$10$:	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.W	D3,#INFPFIL	CALL	CINFOPOS	LOAD.B	D3,#AFINV	LIB	?AFCAR	LOAD.L	A3,#(A5)+ODZNAM	; A3 <-- ^nom du fichier	TEST.B	(A3)	JUMP,EQ 50$	LOAD.B	D3,#'"	LIB	?AFCAR	LOAD.W	D2,#2^BAFXMI!2^BAFXND	LOAD.W	D3,#INFLFIL-2	; D3 <-- nb de caractres	LIB	?AFXFILE	; affiche le nom du fichier	LOAD.W	D4,D3	LOAD.B	D3,#'"	LIB	?AFCAR	TEST.W	D4	JUMP',EQ 80$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin	JUMP'	80$50$:	LIB	?AFTIM	.B	MSPACE	.B	INFLFIL		; efface tout l'emplacement	.B	0	.EVEN80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR90$:	POPM.L	D2..D4,A0,A3	RET;---------\\; CINFOPOS >;---------/; Positionne le curseur dans les informations.; in	A5.L	^description zone;	A0.L	^description fentre;	D3.W	position; out	-; mod	D7.WCINFOPOS:	PUSH.L	D3	MUL.WU	D3,(A0)+ODFCX	SWAP.W	D3	LOAD.W	D3,(A5)+ODZWPO+0	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LIB	?SETCURS	POP.L	D3	RET;-----------\\; CINFOAFDEC >;-----------/; Affiche un nombre dcimal.; in	D4.L	nombre  afficher; out	D3.W	nombre de digits affichs; mod	D3.L, D7.WCINFOAFDEC:	PUSH.L	D2	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LOAD.W	D3,#1	COMP.L	D4,#10	JUMP',LO 90$	INC.W	D3	COMP.L	D4,#100	JUMP',LO 90$	INC.W	D3	COMP.L	D4,#1000	JUMP',LO 90$	INC.W	D3	COMP.L	D4,#10000	JUMP',LO 90$	INC.W	D3	COMP.L	D4,#100000	JUMP',LO 90$	INC.W	D3	COMP.L	D4,#1000000	JUMP',LO 90$	INC.W	D3	COMP.L	D4,#10000000	JUMP',LO 90$	INC.W	D3	COMP.L	D4,#100000000	JUMP',LO 90$	INC.W	D390$:	POP.L	D2	RET;---------\\; CICOMOVE >;=========/; Agit dans une icne avec la souris.; in	D4.L	position de la souris (y;x); out	D2.W	numro de l'icne;	D7.W	erreur; mod	D2.L, D7.WCICOMOVE:	PUSHM.L	D1,D3,D4	CALL	CICODET		; D2 <-- icne o est la souris	JUMP,NE 90$	TEST.W	D2		; est-on dans le sparateur ?	JUMP,EQ 90$		; oui => 90$	CALL	CICOINV		; allume la premire icne	LOAD.W	D1,D220$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 80$		; non => 80$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	CICODET		; D2 <-- icne o est la souris	COMP.W	D2,D1		; est-on dans une autre icne ?	JUMP,EQ 20$		; non => 20$	EX.L	D1,D2	CALL	CICOINV		; teint l'ancienne icne	LOAD.W	D2,D1	CALL	CICOINV		; allume la nouvelle icne	JUMP	20$80$:	LOAD.W	D2,D1	CALL	CICOINV		; teint la dernire icne	CLR.W	D790$:	POPM.L	D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CICODET >;--------/; Dtecte dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	numro de l'icne;	D7.W	erreur; mod	D2.L, D7.WCICODET:	PUSHM.L	D1,D3..D6	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- position en Y	LOAD.W	D5,D4		; D5 <-- position en X	CLR.W	D220$:	CALL	CICOPOS		; D1/D3/D4 <-- icne/position/dimensions	JUMP',NE 80$	COMP.W	D5,D3		; trop  gauche ?	JUMP',LO 50$	ADD.W	D3,D4	COMP.W	D5,D3		; trop  droite ?	JUMP',HS 50$	SWAP.W	D3	SWAP.W	D4	COMP.W	D6,D3		; trop haut ?	JUMP',LO 50$	ADD.W	D3,D4	COMP.W	D6,D3		; trop bas ?	JUMP',LO 90$50$:	INC.W	D2		; D2 <-- icne suivante	JUMP	20$80$:	LOAD.W	D2,#-190$:	POPM.L	D1,D3..D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; CICOINV >;--------/; Inverse une icne.; in	D2.W	numro de l'icne; out	-; mod	D7.WCICOINV:	PUSHM.L	D1..D4	TEST.W	D2		; est-on dans le sparateur ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	CICOPOS		; D1/D3/D4 <-- icne/position/dimensions	JUMP',NE 90$	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse l'icne90$:	POPM.L	D1..D4	RET;---------\\; CICODRAW >;=========/; Dessine toutes les icnes.; in	-; out	-; mod	D7.WCICODRAW:	PUSHM.L	D1..D4	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	AFINV	.B	0	.EVEN	CLR.W	D220$:	CALL	CICOPOS		; D1/D3/D4 <-- icne/position/dimensions	JUMP',NE 80$	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,D1	LIB	?AFCAR		; dessine une icne	INC.W	D2	JUMP	20$80$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	AFDIR	.B	0	.EVEN	POPM.L	D1..D4	RET;--------\\; CICOPOS >;--------/; Donne la position d'une icne.; in	D2.W	numro de l'icne; out	D1.W	code de l'icne;	D3.L	position coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D1.L, D3.L, D4.L, D7.WCICOPOS:	PUSHM.L	D2,A2	LOAD.W	D7,#EREOUTB	; D7 <-- icne inexistante	TEST.L	(A6)+OZONE2+ODZFBT	JUMP',EQ 90$	TEST.W	D2	JUMP',NS 90$	LOAD.L	A2,#R16"TAICO$	SL.W	D2,#2	ADD.W	A2,D2	TEST.W	(A2)	JUMP',EQ 90$	LOAD.W	D1,(A2)		; D1 <-- code de l'icne	LOAD.W	D3,(A6)+OZONE2+ODZWPO+0	SUB.W	D3,(A6)+OWDPOS+0	SWAP.W	D3	LOAD.W	D3,(A2)+2	LOAD.L	D4,#H'10000*GCICY+GCICX	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2,A2	TEST.W	D7		; retour EQ/NE	RETTAICO$:	.W	ICOZSEP,8*(1)	.W	ICOZDEPL,8*(4)	.W	ICOZDUPL,8*(4+5)	.W	ICOZDETR,8*(4+5+5)	.W	ICOZFLIP,8*(4+5+5+5)	.W	0;--------\\; CASDRAW >;========/; Dessine l'ascenseur vide pour une zone.; in	A5.L	^description zone; out	-; mod	D7.WCASDRAW:	PUSHM.L	D2..D4,A4,A5	TEST.L	(A5)+ODZFBT	; zone existe ?	JUMP,EQ 90$		; non => 90$	LOAD.L	A4,A5	LOAD.L	A5,#(A5)+ODZASC	; A5 <-- ^variables de l'ascenseur	LOAD.W	D4,(A4)+ODZWPO+0	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A4)+ODZWPO+2	SUB.W	D4,#CMGG+1	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A4)+ODZWDI+0	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	CLR.B	(A5)+OSCPAGE	COMP.W	D4,#LGSCROLL*6	JUMP',LO 50$	SET.B	(A5)+OSCPAGE50$:	CLR.W	(A5)+OSCHTV	SCROLL_	DRAW		; dessine la cage de l'ascenseur	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A4)+ODZWPO	SUB.W	D3,#CMGG2+1	LOAD.W	D4,(A4)+ODZWDI+0	SWAP.W	D4	LOAD.W	D4,#CMGG2+1	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface bande  ct de l'ascenseur90$:	POPM.L	D2..D4,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; CASUPDATE >;==========/; Met  jour l'ascenseur pour une zone.; in	A5.L	^description zone; out	-; mod	D7.WCASUPDATE:	PUSHM.L	D2..D4,A4,A5	TEST.L	(A5)+ODZFBT	; zone existe ?	JUMP,EQ 90$		; non => 90$	LOAD.L	A4,A5	LOAD.L	A5,#(A5)+ODZASC	; A5 <-- ^variables de l'ascenseur	LOAD.L	D3,(A4)+ODZNBL	LOAD.L	D4,(A4)+ODZPLI	LOAD.W	D2,#6	COMP.L	D3,#2^20	JUMP',HS 20$	DEC.W	D2	COMP.L	D3,#2^19	JUMP',HS 20$	DEC.W	D2	COMP.L	D3,#2^18	JUMP',HS 20$	DEC.W	D2	COMP.L	D3,#2^17	JUMP',HS 20$	DEC.W	D2	COMP.L	D3,#2^16	JUMP',HS 20$	DEC.W	D2	COMP.L	D3,#2^15	JUMP',HS 20$	DEC.W	D220$:	SR.L	D3,D2	SR.L	D4,D2	LOAD.W	(A5)+ODZASF,D2	; ODZASF <-- facteur (0..6)	COMP.W	D3,(A5)+OSCHTV	JUMP',NE 50$	COMP.W	D4,(A5)+OSCPOSV	JUMP',EQ 90$50$:	LOAD.W	(A5)+OSCHTV,D3	LOAD.W	(A5)+OSCPOSV,D4	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur90$:	POPM.L	D2..D4,A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; CASMOVE >;========/; Dplace l'ascenseur d'une zone.; in	A5.L	^description zone;	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WCASMOVE:	PUSHM.L	D2..D4,A4,A5	LOAD.W	D7,#EREOUTB	TEST.L	(A5)+ODZFBT	; zone existe ?	JUMP,EQ 90$		; non => 90$	LOAD.L	A4,A5	LOAD.L	A5,#(A5)+ODZASC	; A5 <-- ^variables de l'ascenseur	SCROLL_	MOVE		; dplace ...	JUMP,NE 90$	EX.L	A4,A5	COMP.W	D4,#SCROLLFUP	JUMP,EQ 40$	COMP.W	D4,#SCROLLFDOWN	JUMP,EQ 40$	COMP.W	D4,#SCROLLPUP	JUMP,EQ 40$	COMP.W	D4,#SCROLLPDOWN	JUMP,EQ 40$; Va  la ligne indique par l'ascenseur.	CLR.L	D2	LOAD.W	D2,(A4)+OSCPOSV	LOAD.W	D3,(A5)+ODZASF	; D3 <-- facteur (0..6)	SL.L	D2,D3		; D2 <-- ligne o aller	CLR.L	D4	CALL	BPOSITIONNE30$:	DEC.L	D2	JUMP,NS 80$32$:	CALL	BAVANCE	JUMP,NE 80$	COMP.B	D3,#CR	JUMP,EQ 30$	COMP.B	D3,#LF	JUMP,EQ 30$	JUMP	32$; Monte ou descend tant qu'un bouton est maintenu press.40$:	EX.L	A4,A5	SCROLL_	PRESS		; allume la flche	EX.L	A4,A5	LOAD.W	D2,D442$:	LIB	?IFMOUSE	TEST.B	D3		; un bouton press ?	JUMP',EQ 48$		; non => 48$	LOAD.W	D4,D2	CALL	CASMOVECURS	; monte ou descend le curseur	CALL	ADISPLAY	; met  jour la fentre	CALL	CASUPDATE	; met  jour l'ascenseur	JUMP	42$48$:	LOAD.W	D4,D2	EX.L	A4,A5	SCROLL_	PRESS		; teint la flche	EX.L	A4,A580$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A4,A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; CASMOVECURS >;------------/; Monte ou descend le curseur de qq lignes.; in	D4.W	SCROLL(F/P)(UP/DOWN); out	-; mod	D7.WCASMOVECURS:	PUSHM.L	D2..D4	LOAD.W	D2,#1	LOAD.W	D3,(A5)+ODZASF	; D3 <-- facteur (0..6)	SL.W	D2,D3		; D2 <-- nb de lignes (1..64)	COMP.W	D4,#SCROLLFUP	JUMP',EQ 10$	COMP.W	D4,#SCROLLFDOWN	JUMP',EQ 10$	MUL.WU	D2,#20		; D2 <-- avance 20 fois plus10$:	COMP.W	D4,#SCROLLFUP	JUMP',EQ 40$	COMP.W	D4,#SCROLLPUP	JUMP',EQ 40$20$:	CALL	BAVANCE	JUMP',NE 90$	COMP.B	D3,#CR	JUMP',EQ 22$	COMP.B	D3,#LF	JUMP,NE 20$22$:	DEC.W	D2	JUMP,NE 20$	JUMP'	90$40$:	CALL	BRECULE	JUMP',NE 90$	COMP.B	D3,#CR	JUMP',EQ 42$	COMP.B	D3,#LF	JUMP,NE 40$42$:	DEC.W	D2	JUMP,NE 40$90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET	.END