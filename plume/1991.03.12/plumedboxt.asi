	.SBTTL	PLUMEDBOXT;---------\\; DBOXPREF >;---------/; Travaille dans une DBOX prfabrique.; in	voir DBOX_EXTEND; out	idem; mod	idemDBOXPREF:	PUSH.W	D2	CALL	DBOXOPEN1	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	DBOX_	EXTEND		; travaille dans la DBOX ...	CALL	DBOXCLOSE1	POP.W	D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXOPEN >;---------/; Ouvre une DBOX.; in	voir DBOX_OPEN; out	idem; mod	idemDBOXOPEN:	CALL	DBOXOPEN1	DBOX_	OPEN		; ouvre la DBOX	TEST.W	D7		; retour EQ/NE	RETDBOXOPEN1:	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	NORMMOUSE	; souris: plus de sablier	RET;----------\\; DBOXCLOSE >;----------/; Ferme une DBOX.; in	voir DBOX_CLOSE; out	idem; mod	idemDBOXCLOSE:	DBOX_	CLOSE		; ferme la DBOXDBOXCLOSE1:	PUSH.W	D7	CALL	AFMENU		; remet les soft-keys	POP.W	D7	RET;-----------\\; DBOXOPWAIT >;===========/; Met la dbox d'attente.; in	-; out	D7.W	erreur; mod	D7.WDBOXOPWAIT:	PUSHM.L	D1,D2,D5	LOAD.W	D1,#DBOX_OPWAIT	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_OPWAIT	JUMP',NE 90$	LOAD.L	(A6)+OWAITCH,D590$:	POPM.L	D1,D2,D5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCLWAIT >;===========/; Enlve la dbox d'attente.; in	-; out	-; mod	-DBOXCLWAIT:	PUSHM.L	D1,D2,D5,D7	LOAD.L	D5,(A6)+OWAITCH	JUMP',EQ 90$	LOAD.W	D1,#DBOX_CLWAIT	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_CLWAIT	CALL	AFMENU		; remet les soft-keys	CLR.L	(A6)+OWAITCH90$:	POPM.L	D1,D2,D5,D7	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs LIB,?EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>90$:	POP.L	A3	RET;--------\\; DBOXEXT >;========/; Cre les tables d'objets et d'extensions.; in	D1.W	code du sous-appel (DBOX_xxx);	D3.L	flags;	D4.L	fanions;	A5.L	^nom du fichier; out	D3.L	flags;	D4.L	fanions;	A2.L	^<lg>table d'objets;	A4.L	^[extension<0>]<0>; mod	D3.L, D4.L, D7.W, A2.L, A4.LDBOXEXT:	PUSHM.L	D1,D2,A0,A1,A3	LOAD.L	D2,D3		; D2 <-- flags	TSET.L	D2:#BDBIOFULL	TSET.L	D2:#BDBIOOBJ	LOAD.L	A0,#R16"TDBOX_BOAP	COMP.W	D1,#DBOX_PREND	JUMP',EQ 05$	COMP.W	D1,#DBOX_AJOUTE	JUMP',EQ 05$	LOAD.L	A0,#R16"TDBOX_BOAS05$:	LOAD.L	A3,#(A6)+OBUEXT	; A3 <-- ^extension(s)	TEST.B	(A3)	JUMP',NE 10$	LOAD.L	A2,A0		; A2 <-- ^TDBOX_BOA(P,S)	LOAD.L	A4,#R16"DEF$	TSET.L	D2:#BDBIOEXT1	JUMP	80$10$:	LOAD.L	A1,A3	LOAD.L	A2,#(A6)+OBUDIS+100+1	LOAD.L	A4,#(A6)+OBUDIS+0	LOAD.W	D1,#15!2^7	; D1 <-- premier fanion20$:	LOAD.B	D3,(A3+)	JUMP,EQ 50$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP,LO 20$	COMP.B	D3,#'Z	JUMP,HI 20$	DEC.L	A3	LOAD.B	D3,#'.		; D3 <-- "." par dfaut	COMP.L	A3,A1	JUMP',EQ 25$	COMP.B	(A3)-1,#'.	JUMP',EQ 24$	COMP.B	(A3)-1,#'!	JUMP',NE 25$24$:	LOAD.B	D3,(A3)-1	; D3 <-- "." ou "!"25$:	LOAD.B	(A2+),#ODBLCIRCLE	LOAD.B	(A2+),D1	CLR.B	(A2+)	LOAD.B	(A2+),#1	LOAD.B	(A2+),#SPACE	LOAD.B	(A2+),#'f	LOAD.B	(A2+),#'i	LOAD.B	(A2+),#'c	LOAD.B	(A2+),#'h	LOAD.B	(A2+),#'i	LOAD.B	(A2+),#'e	LOAD.B	(A2+),#'r	LOAD.B	(A2+),#SPACE	LOAD.B	(A2+),D3	LOAD.B	(A4+),D330$:	LOAD.B	D3,(A3+)	JUMP',EQ 40$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP',LO 40$	COMP.B	D3,#'Z	JUMP',HI 40$	LOAD.B	(A2+),D3	LOAD.B	(A4+),D3	JUMP	30$40$:	DEC.L	A3	CLR.B	(A2+)	LOAD.B	(A2+),#ODBCR	CLR.B	(A4+)	DEC.W	D1		; D1 <-- fanion suivant	JUMP	20$50$:	LOAD.B	(A2+),#ODBLCIRCLE	LOAD.B	(A2+),D1	CLR.B	(A2+)	LOAD.B	(A2+),#1	LOAD.B	(A2+),#SPACE	LOAD.B	(A2+),#'a	LOAD.B	(A2+),#'u	LOAD.B	(A2+),#'t	LOAD.B	(A2+),#'r	LOAD.B	(A2+),#'e	CLR.B	(A2+)	LOAD.B	(A2+),#ODBCR	LOAD.B	(A4+),#'?	CLR.B	(A4+)	LOAD.B	(A2+),#ODBCR	LOAD.L	A3,A0		; A3 <-- ^TDBOX_BOA(P,S)	LOAD.B	D3,(A3+)52$:	LOAD.B	(A2+),(A3+)	; objets <-- bouton "le texte seul"	DEC.B	D3	JUMP,NE 52$	LOAD.L	A3,A2	LOAD.L	A2,#(A6)+OBUDIS+100+1	LOAD.L	D3,A3	SUB.L	D3,A2	LOAD.B	(-A2),D3	; objets <-- <lg>	CLR.B	(A4)	LOAD.L	A4,#(A6)+OBUDIS+0	TSET.L	D2:#BDBIOEXTM	CALL	DBOXEXTN	; D4 <-- fanion selon extension du nom80$:	LOAD.L	D3,D2		; D2 <-- flags	POPM.L	D1,D2,A0,A1,A3	RETDEF$:	.ASCIZ	""	.EVEN;---------\\; DBOXEXTN >;---------/; Cherche quel fanion allumer en fonction de l'extension du nom du fichier.; in	A4.L	^[extension<0>]<0>;	A5.L	^nom du fichier;	D4.L	fanions; out	D4.L	fanions; mod	D7.W, D4.LDBOXEXTN:	PUSHM.L	D2,D3,A1..A4	LOAD.L	D3,(A6)+OFANIO	AND.W	D3,#H'FF00	JUMP',NE 10$	LOAD.W	D3,#2^1510$:	OR.W	D4,D3		; D4 <-- par dfaut	LOAD.L	A3,A520$:	TEST.B	(A3+)	JUMP,NE 20$22$:	COMP.L	A3,A5	JUMP,EQ 90$	LOAD.B	D3,(-A3)	COMP.B	D3,#'.		; A3 <-- ^extension du nom	JUMP',EQ 26$	COMP.B	D3,#'!	JUMP,NE 22$26$:	LOAD.W	D2,#15		; D2 <-- fanion de l'extension40$:	LOAD.L	A1,A3		; A1 <-- ^extension du nom	LOAD.L	A2,A4		; A2 <-- ^extension de la liste	TEST.B	(A2)	JUMP',EQ 90$42$:	LOAD.B	D3,(A1+)	JUMP',EQ 48$	CALL	MINMAJ	COMP.B	D3,(A2+)	JUMP,EQ 42$46$:	TEST.B	(A4+)		; A4 <-- ^extension suivante	JUMP,NE 46$	DEC.W	D2		; D2 <-- fanion suivant	JUMP	40$48$:	TEST.B	(A2)	JUMP,NE 46$	AND.W	D4,#H'00FF	; D4 <-- enlve le fanion par dfaut	TSET.L	D4:D2		; D4 <-- met le bon fanion90$:	POPM.L	D2,D3,A1..A4	RET;--------\\; DOK...  >;========/DOKOUI:	LOAD.W	D3,#'O	RETDOKNON:	LOAD.W	D3,#'N	RETDOKOK:	LOAD.W	D3,#CR	RETDOKDEF:	LOAD.W	D3,#DEFINE	RETDOKANNULE:	LOAD.W	D3,#END	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RET; Tables pour DBOX; ----------------TDBOX_DEF:	.W	10$-TDBOX_DEF	.W	20$-TDBOX_DEF	.W	0,010$:	.B	ODBTEXT	.ASCIZ	" Extension(s) :"	.B	ODBTABX,28-2	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBTABX,28	.B	ODBTEXT	.ASCIZ	" Affiche les :"	.B	ODBCR,ODBCR	.B	ODBFILE,LBUEXT	.B	ODBTABX,28	.B	ODBSQUARE,BDICR+16	.ASCIZ	" fins de ligne  <CR>"	.B	ODBCR	.B	ODBTABX,28	.B	ODBSQUARE,BDILF+16	.ASCIZ	" fins de ligne  <LF>"	.B	ODBCR	.B	ODBTABX,28	.B	ODBSQUARE,BDITAB+16	.ASCIZ	" tabulateurs    <TAB>"	.B	ODBCR	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR	.B	ODBSQUARE,BDFMDC+0	.ASCIZ	" mmorise la dernire case"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" MEMORISE "	.B	ODBTABX,28+9	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Mmorise"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEF:	.W	CR,F1,F2,F3,0		DOKF1-TKEY_DEF	.W	F4,F5,F6,0		DOKF4-TKEY_DEF	.W	END,F0,F13,F14,F15,0	DOKF0-TKEY_DEF	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEF	.W	0TDBOX_SURE:	.W	10$-TDBOX_SURE	.W	20$-TDBOX_SURE	.W	0,010$:	.B	ODBLABEL,1	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,47	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,'O,TDBN