	.SBTTL	PLUMEORTHO;-----------\\; ORTHOVERIF >;===========/; Vrifie l'orthographe d'une zone quelconque.; in	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WORTHOVERIF:	PUSHM.L	D0..D6,A2..A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D6,(A6)+OCIORTHO	JUMP',NE 10$	ORTHO_	OPEN		; ouvre le dictionnaire	JUMP,NE 90$	LOAD.L	(A6)+OCIORTHO,D610$:	LOAD.L	D0,D4	CALL	BPOSITIONNE	; va au dbut de la zone  vrifier	JUMP,NE 90$	LOAD.L	A3,#(A6)+OIOTM	; A3 <-- ^buffer i/o	LOAD.W	D4,#LTMIO-2	CLR.L	D220$:	DEC.W	D4	JUMP',EQ 22$	CALL	BAVANCE	JUMP',NE 22$	LOAD.B	(A3+),D3	; buffer <-- caractres	INC.L	D2	DEC.L	D5	JUMP,NE 20$22$:	LOAD.L	A2,#(A6)+OIOTM	; A2 <-- ^buffer i/o	LOAD.L	A1,A2	LOAD.L	D1,D240$:	CALL	WAITMOUSE	; met le sablier	LOAD.L	A3,A2	LOAD.L	D3,D2;	CALL	DBOXOPEN1	LOAD.L	D6,(A6)+OCIORTHO	ORTHO_	JUSTE		; est-ce juste ?	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	JUMP,EQ 80$	ADD.L	D2,A2	SUB.L	D2,A4	SUB.L	D2,D4	LOAD.L	A2,A4	ADD.L	A2,D4		; A2 <-- ^plus loin	LOAD.L	D6,A4	LOAD.L	D5,D4	LOAD.L	A3,A1	LOAD.L	D3,D1	CALL	DBOXOPEN1	PUSH.L	D6	LOAD.L	D6,(A6)+OCIORTHO	ORTHO_	CHANGE		; change un mot ...	POP.L	D6	CALL	DBOXCLOSE1	COMP.W	D3,#F1		; remplace ?	JUMP',EQ 50$	COMP.W	D3,#F4		; passe ?	JUMP',EQ 40$	COMP.W	D3,#F7		; conserve ?	JUMP',EQ 60$	JUMP'	90$50$:				; remplace =>	LOAD.L	D3,D0	ADD.L	D3,D6	SUB.L	D3,A1	CALL	ORTHOCHMOT	; change un mot	JUMP',NE 90$	JUMP	40$60$:				; conserve =>	JUMP	40$80$:	LOAD.B	D3,#BIPDONE	LIB	?BEEP		; indique que c'est fini	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; ORTHOADD >;=========/; Ajoute un mot dans le dictionnaire.; in	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WORTHOADD:	PUSHM.L	D0..D6,A2..A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D6,(A6)+OCIORTHO	JUMP',NE 10$	ORTHO_	OPEN		; ouvre le dictionnaire	JUMP,NE 90$	LOAD.L	(A6)+OCIORTHO,D610$:	LOAD.L	D0,D4	CALL	BPOSITIONNE	; va au dbut de la zone  vrifier	JUMP,NE 90$	LOAD.L	A3,#(A6)+OIOTM	; A3 <-- ^buffer i/o	LOAD.W	D4,#LTMIO-2	CLR.L	D220$:	DEC.W	D4	JUMP',EQ 22$	CALL	BAVANCE	JUMP',NE 22$	LOAD.B	(A3+),D3	; buffer <-- caractres	INC.L	D2	DEC.L	D5	JUMP,NE 20$22$:	LOAD.L	A4,#(A6)+OIOTM	; A2 <-- ^buffer i/o	LOAD.L	D4,D2	CALL	DBOXOPEN1	ORTHO_	ADD		; conserve un mot ...	CALL	DBOXCLOSE190$:	POPM.L	D0..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; ORTHOCONJ >;==========/; Conjugue l'orthographe d'un verbe quelconque.; in	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WORTHOCONJ:	PUSHM.L	D0..D6,A2..A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D6,(A6)+OCIORTHO	JUMP',NE 10$	ORTHO_	OPEN		; ouvre le dictionnaire	JUMP,NE 90$	LOAD.L	(A6)+OCIORTHO,D610$:	LOAD.L	D0,D4	CALL	BPOSITIONNE	; va au dbut de la zone  vrifier	JUMP,NE 90$	LOAD.L	A3,#(A6)+OIOTM	; A3 <-- ^buffer i/o	LOAD.W	D4,#LTMIO-2	CLR.L	D220$:	DEC.W	D4	JUMP',EQ 22$	CALL	BAVANCE	JUMP',NE 22$	LOAD.B	(A3+),D3	; buffer <-- caractres	INC.L	D2	DEC.L	D5	JUMP,NE 20$22$:	LOAD.L	A4,#(A6)+OIOTM	; A2 <-- ^buffer i/o	LOAD.L	D4,D2	LOAD.L	D5,D2	CALL	DBOXOPEN1	ORTHO_	CONJ		; conjugue un verbe ...	CALL	DBOXCLOSE1	COMP.W	D3,#F1		; remplace ?	JUMP',EQ 50$	JUMP	90$50$:				; remplace =>	LOAD.L	D3,D0	CALL	ORTHOCHMOT	; change un mot90$:	POPM.L	D0..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; ORTHOACCORD >;============/; Accorde l'orthographe d'une zone quelconque.; in	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WORTHOACCORD:	PUSHM.L	D0..D6,A2..A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D6,(A6)+OCIORTHO	JUMP',NE 10$	ORTHO_	OPEN		; ouvre le dictionnaire	JUMP,NE 90$	LOAD.L	(A6)+OCIORTHO,D610$:	LOAD.L	D0,D4	CALL	BPOSITIONNE	; va au dbut de la zone  vrifier	JUMP,NE 90$	LOAD.L	A3,#(A6)+OIOTM	; A3 <-- ^buffer i/o	LOAD.W	D4,#LTMIO-2	CLR.L	D220$:	DEC.W	D4	JUMP',EQ 22$	CALL	BAVANCE	JUMP',NE 22$	LOAD.B	(A3+),D3	; buffer <-- caractres	INC.L	D2	DEC.L	D5	JUMP,NE 20$22$:	LOAD.L	A4,#(A6)+OIOTM	; A2 <-- ^buffer i/o	LOAD.L	D4,D2	LOAD.L	D5,D2	CALL	DBOXOPEN1	ORTHO_	ACCORD		; accorde le mot ...	CALL	DBOXCLOSE1	COMP.W	D3,#F1		; remplace ?	JUMP',EQ 50$	JUMP	90$50$:				; remplace =>	LOAD.L	D3,D0	CALL	ORTHOCHMOT	; change un mot90$:	POPM.L	D0..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ORTHOCHMOT >;-----------/; Change un mot dans le texte.; in	D0.L	position dbut phrase;	D3.L	position dbut ancien mot;	A4/D4.L	^nouveau mot/lg;	D5.L	lg de l'ancien mot; out	D0.L	position dbut phrase;	D7.W	erreur; mod	D0.L, D7.WORTHOCHMOT:	PUSHM.L	D3..D5,A4	ADD.L	D0,D4	SUB.L	D0,D5		; D0 <-- nouvelle position	EX.L	D4,D3	CALL	BPOSITIONNE	; va au dbut du mot  changer	EX.L	D3,D4	JUMP,NE 90$20$:	TEST.W	D5	JUMP',EQ 30$	CALL	BAVANCE	CALL	BDETRUIT	; dtruit un caractre de l'ancien mot	DEC.W	D5	COMP.B	D3,#'A	JUMP',LO 30$	COMP.B	D3,#'Z		; lettre majuscule ?	JUMP',HI 30$		; non => 30$	LOAD.B	D3,(A4+)	CALL	MINMAJ	JUMP'	40$30$:	LOAD.B	D3,(A4+)40$:	CALL	BINSERE		; insre un caractre du nouveau mot	JUMP',NE 90$	DEC.W	D4	JUMP,NE 20$50$:	DEC.W	D5	JUMP',NS 60$	CALL	BAVANCE	CALL	BDETRUIT	; dtruit un caractre de l'ancien mot	JUMP	50$60$:	CALL	ADISPLAY	; affiche tout correctement	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3..D5,A4	TEST.W	D7		; retour EQ/NE	RET	.END