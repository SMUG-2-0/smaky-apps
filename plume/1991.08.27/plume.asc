	.TITLE	PLUME.ASC;	--------------------------------------;		(C) 1988 - Daniel Roux;	--------------------------------------;	Source du programme PLUME	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	DICO	.REF	BLOC;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 1.2	11.03.91	couper/copier/coller...; 1.1	03.05.90	dictionnaire: familles; 1.0	14.07.89	prend/sauve: laisse -> montre et filtre -> enlve;			cherche: sous-menu avec cherchear/av/change;			macros lues (PLUME.MACRO) tout de suite utilisables; 0.3	10.07.89	dictionnaire: synonymes avec le contexte;			dictionnaire: nombre..;			dictionnaire: si "FENETR" change par "FENETRE" (dernier car. maj.); 0.2	27.01.89	clic milieu: vide TEMP; 0.1f	26.01.89	(SEARCH-CHANGE-,) et -.); 0.1e	20.01.89	dictionnaire: changement des dfinitions ok;			dictionnaire: vrifie/marque fin..; 0.1d	13.01.89	clic gauche: petite attente avant de dplacer;			dictionnaire: marque tout..;			(SEARCH-,) et -.);			(CHANGE-,) et -.);			(SEARCH-^);			(CHANGE-R) et -C); 0.1c	05.01.89	utilise le module DICO ...;			buffer i/o 4x plus grand (+rapide); 0.1b	07.10.88	COPY-[*]-SPACE: utilise dernire zone destination d'une copie;			erreur "mmoire dborde" corrige;			prend: signale si commandes boa filtres;			sauve: option "laisse les boa" ajoute;			COPY-CTRL-flche: laisse la zone secondaire visible; 0.1a	15.08.88	dbut des travaux ...MAJREV	=	1		; rvisionMINREV	=	2		; version;PROREV	=	'f		; rvision.version provisoirePROREV	=	SPACE		; rvision.version dfinitive	.REV	MAJREV,MINREV	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------CLGX	=	8		; largeur du cadreCLGY	=	8		; hauteur du cadre (en bas)CMGG1	=	LGSCROLL	; premire marge gaucheCMGG2	=	8		; deuxime marge gaucheCMGG	=	CMGG1+CMGG2	; marge gauche totaleINFPUSE	=	16		; info: position pour "Utiliss:"INFPZON	=	42		; info: position pour "Zone:"INFPFIL	=	56		; info: position pour nom du fichierINFLFIL	=	17		; info: longueur pour nom du fichierMAXZONE	=	10+26+1		; nb max de zones possiblesMACZONE	=	MAXZONE-1	; numro de la zone des macrosMAXCH	=	100		; lg max des chanes de recherche/substitutionLBUFILE	=	50		; lg max d'un nom de fichierLBUEXT	=	22		; lg max extensions par dfautLBUBOA	=	50		; lg max d'une commande boaLTMIO	=	256*32		; lg buffer tampon pour i/oMAXGENC	=	600		; nb max de gencar sur disqueBDBAUTO	=	31		; mode spcial pour DBOXBDBNMAJ	=	30		; mode avec (MET A JOUR) grisBDBLBOA	=	29		; laisse les commandes boaBDBFBOA	=	28		; filtre les commandes boaCADRATIN=	2		; CTRL-SPACEBOA	=	'\		; dbut d'une commandeCCIRCON	=	'		; touche circonflxeCTREMA	=	'		; touche trmaCIRCON	=	'^		; caractre circonflxeTREMA	=	'"		; caractre trmaMARKDM	=	4		; marque pour le dbut d'un mot fauxMARKFM	=	5		; marque pour la fin d'un mot fauxKEYDBOX	=	H'7E00		; "touche" spciale pour dbox; Touches fonction; ----------------CURSOR	=	2^BCURSORCOPY	=	2^BCOPYKILL	=	2^BKILLPROGRA	=	2^BPROGRASHOW	=	2^BSHOWSEARCH	=	2^BSEARCHCHANGE	=	2^BCHANGE; Codes des icnes de IPP15; -------------------------GCTXF	=	'N		; fonte du texte  NEF11GCTXS	=	'E!2^7		; style/chasse du texteGCTXT	=	11		; taille du texteGCICF	=	'I		; fonte des icnes IPP15GCICS	=	'P		; style/chasse des icnesGCICT	=	15		; taille des icnesGCICX	=	32		; largeur d'une icneGCICY	=	16		; hauteur d'une icneGCICB	=	2		; position ligne de baseICOSPACE=	1		; 1/4 espaceICODETR	=	16		; dtruitICODEPL	=	17		; dplaceICODUPL	=	18		; dupliqueICOCAR	=	19		; caractreICOSOUL	=	20		; soulignICOEXIN	=	21		; exposant-indiceICOCOUL	=	22		; couleurICOMIMA	=	23		; minmajICOPERM	=	24		; permuteICOTRIE	=	25		; trieICOPOSR	=	26		; enregistre la positionICOOPER	=	27		; oprationICODICO	=	28		; dictionnaireICOSNOR	=	32		; soulign: normalICOSSOU	=	33		; soulign: soulignICOSBIF	=	34		; soulign: biffICOSSUR	=	35		; soulign: surlignICOENOR	=	36		; exposant: normalICOEEXP	=	37		; exposant: exposantICOEIND	=	38		; exposant: indiceICOMMIN	=	39		; minmaj: minusculesICOMMAJ	=	40		; minmaj: majusculesICOMNOM	=	41		; minmaj: noms propresICODCAR	=	42		; dplacement: caractresICODMOT	=	43		; dplacement: motsICODLIN	=	44		; dplacement: lignesICOPOS	=	48;;57		; positions [A]..[J]ICOASC	=	58;;63		; ascenseurs 1..6ICOZSEP	=	64		; zone: sparateurICOZDEPL=	65		; zone: dplaceICOZDUPL=	66		; zone: dupliqueICOZDETR=	67		; zone: dtruitICOZFLIP=	68		; zone: permuteICOZONF	=	72		; zone  mettre  jourICOZONG	=	73		; zone  jourICOFILE	=	80		; fichier >ICOEDIT	=	81		; dite >ICOSHOW	=	82		; vue >ICOPOSG	=	83		; va  une position >ICOFRAP	=	84		; frappe..ICOPREND=	96		; prend..ICOAJOUTE=	97		; ajoute..ICOSAUVE=	98		; sauve..ICOPRINT=	99		; imprime..ICOQUITTE=	100		; quitte..ICOUNDO	=	101		; annule..ICOCHERCHE=	102		; cherche..ICOEFFACE=	103		; efface..ICOZONE	=	104		; zones..ICODEF	=	105		; dfinitions..ICODICOMA=	106		; dictionnaire: marqueICODICOVE=	107		; dictionnaire: vrifieICODICOAD=	108		; dictionnaire: conserveICODICOAC=	109		; dictionnaire: accordeICODICOCO=	110		; dictionnaire: conjugueICODICOSY=	111		; dictionnaire: synonymesICODICOVT=	112		; dictionnaire: vide TEMPICODICONB=	114		; dictionnaire: nombreICOCHERCHEAR=	116		; cherche: en arrireICOCHERCHEAV=	117		; cherche: en avantICOCHANGE=	118		; cherche: change..ICOCOUPE=	119		; coupeICOCOPIE=	120		; copieICOCOLLE=	121		; colleICOCLASSEUR=	122		; classeur..ICODICOFA=	127		; dictionnaire: familles; Erreurs; -------ERPLUME	=	H'A000		; erreur de PLUMEEREOUTB	=	H'A002		; hors de la zoneERECODE	=	H'A003		; codage impossibleERELINE	=	H'A004		; trop de lignesERESPOS	=	H'A005		; trop de positions sauvesEREZFUL	=	H'A006		; toutes les zones sont occupesERENOTF	=	H'A007		; chane pas trouveEREMACR	=	H'A008		; erreur dans une macroEREBBOA	=	H'A009		; commandes boa bouffes; Fanions gnraux; ----------------BDFMDC	=	0		; mmorise la dernire case; Fanions des caractres visibles; -------------------------------BDICR	=	0		; affiche les CRBDILF	=	1		; affiche les LFBDITAB	=	2		; affiche les TAB; Fanions des recherches/substitutions; ------------------------------------BCHMIMA	=	0		; min = majBCHMOT	=	1		; mots entiersBCHJOKER=	2		; jokerBCHAR	=	8		; en arrireBCHAV	=	9		; en avantBCHCAR1	=	16		; caractre (recherche)BCHMOD1	=	17		; mode (recherche)BCHCAR2	=	18		; caractre (substitution)BCHMOD2	=	19		; mode (substitution); Table des macros; ----------------MOPPOUR	=	1		; ONMOPFIN	=	2		; FINMOPINS	=	3		; INSEREMOPAFF	=	4		; AFFICHEMAXMS	=	10		; nb max de macros imbriques	.LOC	0OMSPOS:	.BLKB	4		; position dans la zone macroLMS:MAXMK	=	50		; nb max de ON..END	.LOC	0OMKCOD:	.BLKB	4		; code de la toucheOMKPOS:	.BLKB	4		; position dans la zone macroLMK:; Table des positions; -------------------MAXPOS	=	10		; nb max de positions	.LOC	0OPOZON:	.BLKB	2		; numro de la zoneOPOPOS:	.BLKB	4		; position dans le texteLPO:; Table des dbuts de lignes; --------------------------MAXAL	=	200		; nb max de lignes	.LOC	0OALPOS:	.BLKB	4		; position du dbut de la ligneOALH2:	.BLKB	1		; h2 max   \  dans cetOALH1:	.BLKB	1		; h1 max   /  ordre !LAL:; Table des checks de lignes; --------------------------MAXCL	=	MAXAL/2		; nb max de lignes visibles	.LOC	0OCLPOY:	.BLKB	2		; coordonne Y dbut ligneOCLCHK:	.BLKB	4		; checksumLCL:; Table des positions sauves; ---------------------------MAXSP	=	10		; nb max de positions sauvables	.LOC	0OSPPOS:	.BLKB	4		; position du curseurOSPPLI:	.BLKB	4		; ligne o est le curseurOSPPPB:	.BLKB	4		; ^bloc o est le curseurOSPPPR:	.BLKB	4		; position relative dans le blocLSP:; Descripteur d'une zone; ----------------------DZMMAX	=	256		; nb max de combinaisons possibles (8 bits)CCGCMSK	=	H'00000F00	; gencar: masqueCCGCSHI	=	8		; gencar: shiftCCSOMSK	=	H'0000F000	; soulign: masqueCCSOSHI	=	12		; soulign: shiftCCEXMSK	=	H'000F0000	; exposant: masqueCCEXSHI	=	16		; exposant: shiftCCCOMSK	=	H'00F00000	; couleur: masqueCCCOSHI	=	20		; couleur: shift	.LOC	0ODZFBT:	.BLKB	4		; ^premier bloc de texteODZNBC:	.BLKB	4		; nb de caractresODZNBL:	.BLKB	4		; nb de lignesODZNUM:	.BLKB	2		; numro de la zoneODZMAJ:	.BLKB	1		; mise  jour ncessaire ? BMAJIO	=  0			;  mise  jour sur disque BMAJAF	=  1			;  mise  jour  l'affichage	.EVENODZPOS:	.BLKB	4		; position du curseurODZPLI:	.BLKB	4		; ligne o est le curseurODZPPB:	.BLKB	4		; ^bloc o est le curseurODZPPR:	.BLKB	4		; position relative dans le blocODZCOD:	.BLKB	4*DZMMAX	; table de codageODZNAM:	.BLKB	LBUFILE		; nom du fichierODZSP:	.BLKB	LSP*MAXSP	; table des positions sauvesLDZC:ODZWNO:	.BLKB	2		; swdo: numroODZWPO:	.BLKB	4		; swdo: origine (y;x)ODZWDI:	.BLKB	4		; swdo: dimensions (dy;dx)ODZASC:	.BLKB	LSCVAR		; ascenseur: variablesODZASF:	.BLKB	2		; ascenseur: facteurODZCUL:	.BLKB	4		; curseur: position dans bufferODZCUP:	.BLKB	4		; curseur: coordonne (y;x)ODZCUH:	.BLKB	2		; curseur: hauteur (dy)ODZCUB:	.BLKB	2		; curseur: ligne de base (h1)ODZCUS:	.BLKB	1		; curseur: touches super-shift	.EVENODZZOD:	.BLKB	4		; zone: position dbutODZZOF:	.BLKB	4		; zone: position finODZZOP:	.BLKB	2		; zone: position sauve dans le bufferODZINC:	.BLKB	4		; info: dernier nombre de caractres affichODZINL:	.BLKB	4		; info: dernier nombre de lignes affichODZALP:	.BLKB	4		; ^premire ligne dans ODZALODZALN:	.BLKB	2		; nb d'lments dans ODZALODZAL:	.BLKB	LAL*MAXAL	; table des dbuts de lignesODZCL:	.BLKB	LCL*MAXCL	; table des checks de lignesLDZ:; En-tte d'un bloc de texte; --------------------------LBTCAR	=	500		; nb max de caractres dans un bloc	.LOC	0OBTNEXT:.BLKB	4		; ^bloc suivant/nilOBTPREV:.BLKB	4		; ^bloc prcdent/nilOBTNBC:	.BLKB	4		; nb de caractres contenusLBT:; Fichier PLUME.INFO; ------------------	.LOC	0OFMAJR:	.BLKB	1		; rvisionOFMINR:	.BLKB	1		; versionOFPROR:	.BLKB	1		; provisoire	.BLKB	1OFLXTAB:.BLKB	2		; avance pour un tabulateurOFDEF:	.BLKB	4		; fanions gnrauxOFDISP:	.BLKB	4		; fanions des caractres  afficherOFCHFAN:.BLKB	4		; change: fanionsOFBUEXT:.BLKB	LBUEXT		; extension(s) par dfautOFFANIO:.BLKB	4		; i/o: fanionsOFFDICO:.BLKB	4		; dico: fanions	.BLKB	208		; rserveLFINFO:; Variables; ---------LBUDIS	=	1000+((15+LGTGC)*MAXGC)	.LOC	0OSTART:	.BLKB	4		; adresse absolue du dbut du codeOCHDBOX:.BLKB	2		; canal module DBOXOCHDGENC:.BLKB	2		; canal module DGENCOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHDICO:.BLKB	2		; canal module DICOOCIDICO:.BLKB	4		; canal interne DICOOCHBLOC:.BLKB	2		; canal module BLOCOPLCOM:	.BLKB	4		; ^ligne de commandeOPDDIS:	.BLKB	4		; ^descripteur de la fentreOQXDOT:	.BLKB	4		; adresse de GRA_QXDOTORASTER:.BLKB	4		; adresse de GRA_RASTEROMATRIX:.BLKB	4		; adresse de GRA_MATRIXOTRAME:	.BLKB	4		; adresse de GRA_TRAMEOLINE:	.BLKB	4		; adresse de GRA_LINEOCLEAR:	.BLKB	4		; adresse de GRA_CLEAROSET:	.BLKB	4		; adresse de GRA_SETOINV:	.BLKB	4		; adresse de GRA_INVOBUDIS:	.BLKB	LBUDIS		; buffer write-displayOGCLIST:.BLKB	MAXGENC*3	; liste des gencars contenus sur disqueOBUGC:	.BLKB	LGGC*MAXGC	; table des gnrateurs de caractresOFAGC:	.BLKB	4		; fanions pour dbox des gencarsOFLAGS:	.BLKB	1		; flags divers BACC	=  0			;  frappe accent flottant en cours BMREC	=  1			;  macro en enregistrement	.EVENOPARMM:	.BLKB	LMM*8		; mmenus hirarchiques: paramtres milieuOPARMD:	.BLKB	LMM*12		; mmenus hirarchiques: paramtres droiteOWAITCH:.BLKB	4		; dbox wait: canalOWDPOS:	.BLKB	4		; wdo: coin sup/gauche (y;x)OWDDIM:	.BLKB	4		; wdo: dimensions (dy;dx)OWDSEP:	.BLKB	2		; wdo: position du sparateur principal/secondaireOZONEP:	.BLKB	MAXZONE*4	; ^zones compactesOZONE1:	.BLKB	LDZ		; zone principaleOZONE2:	.BLKB	LDZ		; zone secondaireOZONEU:	.BLKB	LDZC		; zone pour le undoONOZLC:	.BLKB	2		; no dernire zone destinatrice d'une copieOUNNBR:	.BLKB	4		; undo: nb de caractres dtruits en arrireOUNNBA:	.BLKB	4		; undo: nb de caractres dtruits en arrireOMASTN:	.BLKB	2		; macro: nb d'imbrications en excutionOMASTK:	.BLKB	MAXMS*LMS	; macro: stack pour les imbricationsOMAKEY:	.BLKB	MAXMK*LMK	; macro: table des positions selon les codesOTAPOS:	.BLKB	MAXPOS*LPO	; table des positionsOLXTAB:	.BLKB	2		; avance pour un tabulateurODEF:	.BLKB	4		; fanions gnrauxODISP:	.BLKB	4		; fanions des caractres  afficherOCH1:	.BLKB	MAXCH		; change: chane de rechercheOCH2:	.BLKB	MAXCH		; change: chane du substitutionOCHL1:	.BLKB	MAXCH		; change: dernire chane de rechercheOCHL2:	.BLKB	MAXCH		; change: dernire chane du substitutionOCHFAN:	.BLKB	4		; change: fanionsOCHSL1:	.BLKB	LSLVAR		; change: variables scroll-list 1OCHSL2:	.BLKB	LSLVAR		; change: variables scroll-list 2OCHSL3:	.BLKB	LSLVAR		; change: variables scroll-list 3OCHSL4:	.BLKB	LSLVAR		; change: variables scroll-list 4OCHCS1:	.BLKB	2		; change: case slectionne scroll-list 1OCHCS2:	.BLKB	2		; change: case slectionne scroll-list 2OCHCS3:	.BLKB	2		; change: case slectionne scroll-list 3OCHCS4:	.BLKB	2		; change: case slectionne scroll-list 4OCHM1:	.BLKB	4		; change: masque de rechercheOCHC1:	.BLKB	4		; change: caractre de rechercheOCHM2:	.BLKB	4		; change: masque de substitutionOCHC2:	.BLKB	4		; change: caractre de substitutionOFRSL1:	.BLKB	LSLVAR		; frappe: variables scroll-list 1OFRSL2:	.BLKB	LSLVAR		; frappe: variables scroll-list 2OFRSL3:	.BLKB	LSLVAR		; frappe: variables scroll-list 3OFRSL4:	.BLKB	LSLVAR		; frappe: variables scroll-list 4OFRMSK:	.BLKB	4		; frappe: masqueOFRCAR:	.BLKB	4		; frappe: caractreOZOSL:	.BLKB	LSLVAR		; zones: variables de la scroll-listOAHSUP:	.BLKB	2		; hauteur en-dessus du curseurOAHINF:	.BLKB	2		; hauteur en-dessous du curseurOBUTEMP:.BLKB	LBUFILE		; nom de fichier temporaireOBUEXT:	.BLKB	LBUEXT		; extension(s) par dfautOFANIO:	.BLKB	4		; i/o: fanionsOIOCH:	.BLKB	2		; canal pour entre/sortieOIOTM:	.BLKB	LTMIO		; buffer tamponOIOPT:	.BLKB	2		; ^relatif dans OTMIOOIONB:	.BLKB	2		; reste dans OTMIOOIOLC:	.BLKB	4		; dernier caractre completODINBF:	.BLKB	2		; dico: nb de fautes trouvesODIPBT:	.BLKB	4		; dico: ^buffer de texteODIDEF:	.BLKB	4		; dico: dfinitionsOBUBOA:	.BLKB	LBUBOA		; commande boaLGVAR:; Programme; ---------	.LOC	0ADCODE:	JUMP	START; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMDGENC:	.ASCIZ	"DGENC"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMDICO:		.ASCIZ	"DICO"NMBLOC:		.ASCIZ	"BLOC"	.EVEN; Routines .LIB rapides; ---------------------TAGETAD:	.W	GRA_QXDOT,OQXDOT	.W	GRA_RASTER,ORASTER	.W	GRA_MATRIX,OMATRIX	.W	GRA_TRAME,OTRAME	.W	GRA_LINE,OLINE	.W	GRA_CLEAR,OCLEAR	.W	GRA_SET,OSET	.W	GRA_INV,OINV	.W	0; Erreurs fatales; ---------------TXERFATREV:	.ASCIZ	"La rvision du systme est incompatible"TXERFATDIS:	.ASCIZ	"Driver d'cran incompatible"TXERFATGRA:	.ASCIZ	"Module GRA incompatible"TXERFATTXT:	.ASCIZ	"Erreur avec le gencar NEF11"TXERFATICO:	.ASCIZ	"Erreur avec le gencar IPP15"	.EVENSTART:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CALL	_WAITMOUSE	; met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	LOAD.B	(A6)+OGCLIST,#-1	LOAD.L	A4,#R16"ADCODE	LOAD.L	(A6)+OSTART,A4	; mm. ^absolu dbut du code	LOAD.L	A4,#(A6)+OTAPOS	LOAD.W	D4,#MAXPOS-112$:	LOAD.W	(A4)+OPOZON,#-1	ADD.L	A4,#LPO	DECJ.W,NMO D4,12$	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*5+6	; est-ce au moins 5.6 ?	JUMP,LO ERFAT2		; non => ERFAT2	LOAD.L	A3,#R16"TXERFATDIS	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT2	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	COMP.W	(A0)+ODFIIX,#1	; cran de type SMAKY100/324 ?	JUMP,NE ERFAT2		; non => patatras ...	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	LOAD.L	A3,#R16"TXERFATTXT	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATICO	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMDGENC	LOAD.W	D3,#DGENC_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDGENC,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMDICO	LOAD.W	D3,#DICO_FIRST	LIB_	OPEN	JUMP',NE NODICO$	LOAD.W	(A6)+OCHDICO,D1	LOAD.W	D3,#DICO_VTEMP	LIB_	GETAD		; appel DICO_VTEMP existe ?	JUMP',EQ NODICO$	; oui => NODICO$				; non =>	LIB_	CLOSE	CLR.W	(A6)+OCHDICONODICO$:	LOAD.L	A3,#R16"NMBLOC	LOAD.W	D3,#BLOC_FIRST	LIB_	OPEN	JUMP',NE NOBLOC$	LOAD.W	(A6)+OCHBLOC,D1	BLOC_	OPEN		; ouverture globaleNOBLOC$:; Demande les adresses des routines rapides des modules (.LIB).	LOAD.L	A1,#R16"TXERFATGRA	LOAD.L	A2,#R16"TAGETAD41$:	LOAD.W	D3,(A2+)	; D3 <-- code de l'appel	JUMP',EQ 42$	LIB_	GETAD		; A3 <-- ^routine	JUMP,NE ERFAT3	LOAD.W	D3,(A2+)	; D3 <-- offset variable	LOAD.L	(A6)+(D3.W),A3	; variable <-- ^routine	JUMP	41$42$:	LOAD.L	A4,#(A6)+OBUGC	TSET.B	(A4)+OGCFLG:#BGCPROT	LOAD.B	(A4)+OGCF,#GCTXF	LOAD.B	(A4)+OGCS,#GCTXS	LOAD.B	(A4)+OGCT,#GCTXT	LOAD.L	A3,#(A4)+OGCTIT	LOAD.B	(A3+),#'F	LOAD.B	(A3+),#'o	LOAD.B	(A3+),#'n	LOAD.B	(A3+),#'d	CALL	LODGC	LOAD.W	(A6)+OLXTAB,#64	LOAD.L	(A6)+ODISP,#2^BDICR!2^BDILF!2^BDITAB	CALL	RDINFO		; essaye de lire PLUME.INFO	CALL	RDMACRO		; essaye de lire PLUME.MACRO	CALL	MCOMPILE	; gnre la table OMAKEY	LOAD.L	A5,#(A6)+OZONEU	CALL	_BINIT		; initialise la zone pour le UNDO	JUMP,NE ERROR	LOAD.W	(A5)+ODZNUM,#MAXZONE ; donne un numro impossible !	CALL	CDESSINE	; dessine le cadre	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CLR.W	D2	LOAD.L	D3,(A6)+OWDPOS	LOAD.L	D4,(A6)+OWDDIM	CALL	ZAFFOPEN	; ouvre la zone numro zro	JUMP,NE ERROR	CALL	CDESSINE1	; dessine les informations	CALL	_AFMENU		; affiche les soft-keys	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SKPNAM		; A3 <-- saute le nom du logiciel	JUMP',NE LOOP	CALL	IOREAD		; lit ce fichier	JUMP',EQ 70$	COMP.W	D7,#EREBBOA	JUMP,NE ERROR70$:	LOAD.W	D6,D7	TCLR.B	(A5)+ODZMAJ:#BMAJIO	LOAD.L	A4,#(A5)+ODZNAM72$:	LOAD.B	(A4+),(A3+)	; ODZNAM <-- nom du fichier	JUMP,NE 72$	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	CINFOFIL	; affiche le nom du fichier	LOAD.W	D7,D6	JUMP,NE ERROR;	JUMP'	LOOPLOOP:	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	TEST.W	(A6)+OMASTN	; macro en excution ?	JUMP',EQ NOPLAY$	; non => NOPLAY$	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	MPLAY		; D3 <-- touche de la macro enregistre	JUMP,EQ	MACRO$	COMP.W	D7,#ERKSTO	; fin de l'excution ?	JUMP,EQ LOOP		; oui => LOOP	JUMP	MERRORNOPLAY$:	LIB	?IFCAR		; clavier/souris ?	JUMP,EQ KEY$		; oui => KEY$	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	ADISPLAY	; affiche tout correctement	LIB	?IFCAR		; clavier/souris ?	JUMP,EQ KEY$		; oui => KEY$	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	CALL	ADISPLAY	; affiche tout correctement	LIB	?IFCAR		; clavier/souris ?	JUMP,EQ KEY$		; oui => KEY$	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	CASUPDATE	; met  jour l'ascenseur	LIB	?IFCAR		; clavier/souris ?	JUMP,EQ KEY$		; oui => KEY$	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	CALL	CASUPDATE	; met  jour l'ascenseur	LIB	?IFCAR		; clavier/souris ?	JUMP,EQ KEY$		; oui => KEY$	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	CINFOUSE	; affiche le nombre utilis	LIB	?IFCAR		; clavier/souris ?	JUMP,EQ KEY$		; oui => KEY$	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	CALL	CINFOUSE	; affiche le nombre utilisSET$:	LOAD.W	D4,#1	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	AINVCURS	; met le curseur	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	CALL	AINVCURS	; met le curseurSETLOOP$:	LOAD.W	D4,#20	NTREL	?SETTIM	LIB	?GETKEY		; attend clavier/souris ...	PUSHM.L	D4,D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POPM.L	D4,D7	TEST.W	D7	JUMP',NE CLR$	TEST.L	D3:#BKRELEAS	; touche relche ?	JUMP,BS SETLOOP$	; oui => SETLOOP$	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ SETLOOP$	; oui => SETLOOP$	JUMP'	CLRLAST$CLR$:	CLR.W	D4	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	AINVCURS	; enlve le curseur	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	CALL	AINVCURS	; enlve le curseurCLRLOOP$:	LOAD.W	D4,#12	NTREL	?SETTIM	LIB	?GETKEY		; attend clavier/souris ...	PUSHM.L	D4,D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POPM.L	D4,D7	TEST.W	D7	JUMP,NE SET$	TEST.L	D3:#BKRELEAS	; touche relche ?	JUMP,BS CLRLOOP$	; oui => CLRLOOP$	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ CLRLOOP$	; oui => CLRLOOP$	JUMP'	KEY$CLRLAST$:	CLR.W	D4	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	AINVCURS	; enlve le curseur	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	CALL	AINVCURS	; enlve le curseurKEY$:	TEST.L	D3:#BKPSEUDO	; changement de touches super-shift ?	JUMP,BS SET$		; oui => SET$	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP	COMP.B	D3,#F0+SHIFT	JUMP',LO NOSHIFT$	COMP.B	D3,#F15+SHIFT	JUMP',HI NOSHIFT$	SUB.B	D3,#SHIFTNOSHIFT$:	LOAD.L	D2,D3	SWAP.W	D2		; D2 <-- pseudo-code	COMP.B	D2,#'A	JUMP',LO NOCTRL$	COMP.B	D2,#'Z	JUMP',HI NOCTRL$	LOAD.W	D2,D3	AND.W	D2,#H'FF00	; dj une touche super-shift ?	JUMP',NE NOCTRL$	; oui => NOCTRL$	COMP.B	D3,#'A-H'40	JUMP',LO NOCTRL$	COMP.B	D3,#'Z-H'40	JUMP',HI NOCTRL$	TSET.L	D3:#8+BCURSOR	; D3 <-- comme si (CURSOR) pressNOCTRL$:	TEST.B	(A6)+OFLAGS:#BMREC	JUMP',BC MACRO$	CALL	MRECORD		; enregistre la touche presse	JUMP,NE ERRORMACRO$:	TEST.W	D3	JUMP,EQ LOOP	LOAD.L	A4,#(A6)+OMAKEY-LMKMACRO2$:	ADD.L	A4,#LMK	TEST.L	(A4)+OMKCOD	JUMP',EQ MACRO5$	COMP.W	D3,(A4)+OMKCOD+2	JUMP,NE MACRO2$	JUMP	KMACROMACRO5$:	COMP.W	D3,#H'80	JUMP',HS NOACCENT$	COMP.B	D3,#DEL	JUMP',EQ NOACCENT$	COMP.B	D3,#BS	JUMP',NE ACCENT$NOACCENT$:	CALL	NOACCENT	; plus de frappe d'accent flottantACCENT$:	CALL	_EXFONC	.WW	CURSOR!KILL,KCURSKILL	.WW	0,NOKILL2$NOKILL2$:	LOAD.W	D2,D3	AND.W	D2,#H'FF00	; touche super-shift presse ?	JUMP',NE NOKILL4$	; oui => NOKILL4$	CALL	_EXKEY	.WW	DELETE,KDEL	.WW	DEL,KDEL	.WW	BS,KBS	.WW	UNDO,KUNDO	.WW	0,NOKILL4$NOKILL4$:	COMP.W	D3,#KEYMMP	JUMP,EQ KCLICM	CALL	ZUNDOANNULE	; plus de (UNDO) possible !	CALL	_EXFONC	.WW	CURSOR,KCURSOR	.WW	COPY,KCOPY	.WW	COPY!KILL,KCOPYKILL	.WW	KILL,KKILL	.WW	PROGRA,KPROGRA	.WW	PROGRA!SHOW,KPROGSHOW	.WW	PROGRA!CHANGE,KPROGCHAN	.WW	SHOW,KSHOW	.WW	SEARCH,KSEARCH	.WW	CHANGE,KCHANGE	.WW	SEARCH!CHANGE,KSEACHA	.WW	PROGRA!SHOW!SEARCH!CHANGE,KDEBUG	.WW	0,IFCLIC$IFCLIC$:	COMP.W	D3,#KEYMGP	JUMP,EQ KCLICG	COMP.W	D3,#KEYMDP	JUMP,EQ KCLICD	CALL	_EXKEY	.WW	CCIRCON,KCIRCON	.WW	CTREMA,KTREMA	.WW	TRIZERO,KTRIZERO	.WW	POINT,KPOINT	.WW	FNCT,KFLIP	.WW	DEFINE,KCHERCHE	.WW	MACRO,KMACRO	.WW	F0,KFIN	.WW	F1,KPREND	.WW	F2,KAJOUTE	.WW	F3,KSAUVE	.WW	F4,KDEF	.WW	F7,KCAR	.WW	F8,KFRAPPE	.WW	F9,KCHERCHE	.WW	F13,KZONE	.WW	F14,KEFFACE	.WW	0,INSERT$INSERT$:	COMP.W	D3,#H'80	JUMP,HS BIP	JUMP	KINSERTBIP:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPBIGBIP:				; erreur =>	LOAD.B	D3,#BIPERR	LIB	?BEEP		; grand bruit	JUMP	LOOPERROR:	CLR.W	(A6)+OMASTN	; stoppe v. la macro	PUSH.W	D7	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	CINFOFIL	; affiche le nom du fichier	POP.W	D7	CALL	DBOXERROR	; affiche l'erreur ...	JUMP,NE BIGBIP	JUMP	LOOPREFAIT:	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	AREFAIT		; faudra tout repeindre	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	CALL	AREFAIT		; faudra tout repeindre	JUMP	LOOPKDEF:	CALL	DBOXDEF		; choix des dfinitions ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,EQ REFAIT	COMP.W	D3,#F4	JUMP,NE LOOP	CALL	DBOXOPWAIT	; met la dbox d'attente	CALL	WRINFO		; mj. le fichier PLUME.INFO	JUMP,NE ERROR	JUMP	REFAITKCAR:	CALL	DBOXGENCAR	; choix des gencars ...	JUMP,NE ERROR	JUMP	LOOPKFRAPPE:	CALL	DBOXFRAPPE	; choix de la frappe ...	JUMP,NE ERROR	JUMP	LOOPKCHERCHE:	CALL	DBOXCHANGE	; dialogue pour recherche/substitution ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,EQ ECHERCHE	COMP.W	D3,#F4	JUMP,EQ ECOMPTE	COMP.W	D3,#F7	JUMP,EQ ECHANGE	JUMP	LOOPKZONE:	LOAD.W	D2,(A6)+OZONE1+ODZNUMLOOP$:	CALL	DBOXZONE	; dialogue pour les zones ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,EQ SHOW$	COMP.W	D3,#F4	JUMP,EQ PREND$	COMP.W	D3,#F7	JUMP,EQ SAUVE$	COMP.W	D3,#F10	JUMP,EQ EFFACE$	JUMP	LOOPSHOW$:	CALL	ZUN		; montre la zone demande	JUMP,NE ERROR	JUMP	LOOPPREND$:	CALL	ZUSE		; A5 <-- ^descripteur zone slectionne	JUMP,NE BIP	LOAD.W	D0,#1		; D0 <-- nouveau texte	CALL	DBOXSAVE	; sauve avant de reprendre ?	JUMP,NE ERROR	CALL	_BINIT		; efface tout le texte	CALL	ADISPLAY	; montre que tout est videPREND2$:	CALL	DBOXPREND	; demande le nom ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE REFAIT$	LOAD.L	A3,#(A5)+ODZNAM	; A3 <-- ^nom du fichier	CALL	IOREAD		; lit le fichier	JUMP',EQ PREND4$	CALL	DBOXERROR	; affiche l'erreur ...	JUMP,NE BIGBIP	JUMP	PREND2$PREND4$:	TCLR.B	(A5)+ODZMAJ:#BMAJIO	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	CINFOFIL	; affiche le nom du fichier	JUMP	REFAIT$SAUVE$:	CALL	ZCTRL		; A5 <-- ^descripteur zone slectionne	JUMP,NE BIPSAUVE2$:	CALL	DBOXCREATE	; demande le nom ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE REFAIT$	LOAD.L	A3,#(A5)+ODZNAM	; A3 <-- ^nom du fichier	CALL	IOWRITE		; crit le fichier	JUMP',EQ SAUVE4$	CALL	DBOXERROR	; affiche l'erreur ...	JUMP,NE BIGBIP	JUMP	SAUVE2$SAUVE4$:	TCLR.B	(A5)+ODZMAJ:#BMAJIO	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	CINFOFIL	; affiche le nom du fichier	JUMP	REFAIT$EFFACE$:	CALL	ZCTRL		; A5 <-- ^descripteur zone slectionne	JUMP,NE BIP	TEST.B	(A5)+ODZMAJ:#BMAJIO	JUMP',BC EFFACE2$	CALL	DBOXEFFACE	; demande si vraiment ...	JUMP',NE REFAIT$EFFACE2$:	CALL	_BINIT		; efface tout	CALL	CINFOFIL	; affiche le nom du fichier;	JUMP'	REFAIT$REFAIT$:	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	ADISPLAY	; affiche tout correctement	CALL	CASUPDATE	; met  jour l'ascenseur	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	CALL	ADISPLAY	; affiche tout correctement	CALL	CASUPDATE	; met  jour l'ascenseur	JUMP	LOOP$KEFFACE:	CALL	DBOXEFFACE	; demande si vraiment ...	JUMP,NE ERROR	CALL	_BINIT		; efface tout	CALL	CINFOFIL	; affiche le nom du fichier	JUMP	LOOPKCOUPE:	CALL	BINFO		; D4/D5 <-- position/nb car	CLR.L	D4	CALL	BPOSITIONNE	; va au dbut de la zone  copier	CALL	BLOCCOPY	; bloc-notes <-- caractres	JUMP,NE ERROR	CALL	_BINIT		; efface tout	JUMP	LOOPKCOPIE:	CALL	BINFO		; D4/D5 <-- position/nb car	CLR.L	D4	CALL	BPOSITIONNE	; va au dbut de la zone  copier	CALL	BLOCCOPY	; bloc-notes <-- caractres	JUMP,NE ERROR	JUMP	LOOPKCOLLE:	CALL	BLOCPAST	; colle tout le contenu du bloc-notes	JUMP,NE BIP	JUMP	LOOPKCLASSEUR:	TEST.W	(A6)+OCHBLOC	; module BLOC charg ?	JUMP,EQ BIP		; non => BIP	CALL	DBOXOPEN1	LOAD.W	D2,#2^BDBSAV	BLOC_	VISU		; accs au classeur ...	CALL	DBOXCLOSE1	; refait les soft-keys	TEST.W	D7	JUMP,NE BIP	COMP.W	D3,#F1	JUMP,NE LOOP	JUMP	KCOLLEKFIN:	CLR.W	D220$:	CALL	ZCTRL		; A5 <-- ^descripteur zone	JUMP',NE 24$	CLR.W	D0		; D0 <-- avant de quitter	CALL	DBOXSAVE	; sauve avant de reprendre ?	JUMP,NE ERROR24$:	INC.W	D2		; D2 <-- numro zone suivante	COMP.W	D2,#MAXZONE	JUMP,LO 20$	LOAD.L	D6,(A6)+OCIDICO	JUMP',EQ 40$	DICO_	IFMAJ		; mises  jour ncessaires ?	JUMP',EQ 40$		; non => 40$	CALL	DBOXOPEN1	DICO_	MAJ		; effectue les mises  jour ...	CALL	DBOXCLOSE1	TEST.W	D7	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP40$:	CALL	DBOXQUITTE	; demande s'il faut quitter ...	JUMP,NE ERRORERFAT:	TEST.W	(A6)+OCHDICO	JUMP',EQ 20$	LOAD.L	D6,(A6)+OCIDICO	JUMP',EQ 20$	DICO_	CLOSE20$:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDGENC	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDICO	JUMP',EQ NODICO$	LIB_	CLOSENODICO$:	LOAD.W	D1,(A6)+OCHBLOC	JUMP',EQ NOBLOC$	BLOC_	CLOSE		; fermeture globale	JUMP',NE NOBLOC$	LIB_	CLOSENOBLOC$:ERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	PLUMEDBOX.ASI	.INS	PLUMEDBOXT.ASI	.INS	PLUMEGENC.ASI	.INS	PLUMEIO.ASI	.INS	PLUMECADRE.ASI	.INS	PLUMEAFF.ASI	.INS	PLUMEMOUSE.ASI_WAITMOUSE:	JUMP	WAITMOUSE_AFMENU:	JUMP	AFMENU_BINIT:		JUMP	BINIT_EXFONC:	JUMP	EXFONC_EXKEY:		JUMP	EXKEY_MINMAJ:	JUMP	MINMAJ	.INS	PLUMEOPER.ASI	.INS	PLUMEDICO.ASI	.INS	PLUMEMACRO.ASI	.INS	PLUMEEDIT.ASI	.INS	PLUMEZONE.ASI	.INS	PLUMEBUFF.ASI	.INS	PLUMEMISC.ASI	.END	START