	.SBTTL	PLUMEEDITKINSERT:	CALL	ACCENT		; va sous un accent flottant ?	JUMP,EQ LOOP		; oui => LOOP	CALL	EINSERE	JUMP,NE ERROR	JUMP	LOOPKTRIZERO:			; insre 3x zro =>	LOAD.B	D3,#'0	CALL	EINSERE	JUMP,NE ERROR	CALL	EINSERE	JUMP,NE ERROR	CALL	EINSERE	JUMP,NE ERROR	JUMP	LOOPKPOINT:				; insre un "." =>	LOAD.B	D3,#'.	CALL	EINSERE	JUMP,NE ERROR	JUMP	LOOPKFLIP:				; permute deux caractres =>	CALL	BDETRUIT	JUMP,NE BIP	LOAD.L	D4,D3	CALL	BAVANCE	LOAD.L	D3,D4	CALL	BINSERE	CALL	BRECULE	JUMP	LOOPKDEBUG:	CALL	EXKEY	.WW	'Z,EDEBUG	.WW	'P,EPOS	.WW	0,BIPEDEBUG:	LOAD.B	D3,#EOP	LIB	?AFCAR	CALL	BDEBUG	LIB	?GETCAR	JUMP	LOOPEPOS:	CLR.L	D3	LIB	?SETCURS	LOAD.L	A2,#(A6)+OTAPOS	LOAD.W	D2,#MAXPOS-120$:	LOAD.W	D4,(A2)+OPOZON	LIB	?AFX4	LIB	?AFSPACE	LOAD.L	D4,(A2)+OPOPOS	LIB	?AFX8	LIB	?AFCR	ADD.L	A2,#LPO	DECJ.W,NMO D2,20$	LIB	?GETCAR	JUMP	LOOPKUNDO:	TEST.L	(A6)+OZONEU+ODZNBC ; qq chose  rcuprer ?	JUMP,EQ BIP		; non => BIP	CALL	ZUNDORECUP	; rcupre les caractres dtruits	JUMP,NE ERROR	JUMP	LOOPKDEL:	LOAD.B	D3,#'D	JUMP	ECURSKILLKBS:	LOAD.B	D3,#'F	JUMP	ECURSKILLKCURSOR:	CALL	EXKEY	.WW	'E,ECURSOR	.WW	'R,ECURSOR	.WW	'T,ECURSOR	.WW	'S,ECURSOR	.WW	'D,ECURSOR	.WW	'F,ECURSOR	.WW	'G,ECURSOR	.WW	'X,ECURSOR	.WW	'C,ECURSOR	.WW	'V,ECURSOR	.WW	'E-H'40,ECURSUP4	.WW	'R-H'40,ECURSUP1	.WW	'T-H'40,ECURSOR	.WW	'S-H'40,ECURSOR	.WW	'D-H'40,ECURSOR	.WW	'F-H'40,ECURSOR	.WW	'G-H'40,ECURSOR	.WW	'X-H'40,ECURSDOWN4	.WW	'C-H'40,ECURSDOWN1	.WW	'V-H'40,ECURSOR	.WW	SPACE,KCOLLE	.WW	0,BIPKCURSKILL:	CALL	EXKEY	.WW	'E,ECURSKILL	.WW	'R,ECURSKILL	.WW	'T,ECURSKILLQ	.WW	'S,ECURSKILL	.WW	'D,ECURSKILL	.WW	'F,ECURSKILL	.WW	'G,ECURSKILL	.WW	'X,ECURSKILL	.WW	'C,ECURSKILL	.WW	'V,ECURSKILLQ	.WW	0,BIPKKILL:	CALL	EXKEY	.WW	TAB,TAB$	.WW	CR,CR$	.WW	LF,LF$	.WW	SPACE,KCOUPE	.WW	0,10$10$:	CALL	ZKEYNUM		; D2 <-- numro de la zone	JUMP',EQ ZONE$	JUMP	BIPTAB$:	TCLR.B	(A6)+ODISP+3:#BDITAB-0	JUMP,BC BIP	JUMP	REFAITCR$:	TCLR.B	(A6)+ODISP+3:#BDICR-0	JUMP,BC BIP	JUMP	REFAITLF$:	TCLR.B	(A6)+ODISP+3:#BDILF-0	JUMP,BC BIP	JUMP	REFAITZONE$:	CALL	ZCTRL		; A5 <-- ^zone  effacer	JUMP,NE BIP	TEST.L	(A5)+ODZNBC	; zone contient qq chose ?	JUMP,EQ BIP		; non => BIP	CALL	DBOXEFFACE	; demande si vraiment ...	JUMP,NE ERROR	CALL	BINIT		; efface tout	LOAD.L	A4,#(A6)+OZONE1	COMP.L	A5,A4	JUMP',EQ ZONE5$	LOAD.L	A4,#(A6)+OZONE2	COMP.L	A5,A4	JUMP,NE LOOPZONE5$:	CALL	CINFOFIL	; affiche le nom du fichier	JUMP	LOOPKSHOW:	CALL	EXKEY	.WW	DEFINE,KPREND	.WW	TAB,TAB$	.WW	CR,CR$	.WW	LF,LF$	.WW	SPACE,KCLASSEUR	.WW	0,10$10$:	CALL	ZKEYNUM		; D2 <-- numro de la zone	JUMP',EQ ZONE$	JUMP	BIPTAB$:	TSET.B	(A6)+ODISP+3:#BDITAB-0	JUMP,BS BIP	JUMP	REFAITCR$:	TSET.B	(A6)+ODISP+3:#BDICR-0	JUMP,BS BIP	JUMP	REFAITLF$:	TSET.B	(A6)+ODISP+3:#BDILF-0	JUMP,BS BIP	JUMP	REFAITZONE$:	LOAD.W	D1,(A6)+OZONE1+ODZNUM	CALL	ZDEUX	JUMP,NE ERROR	JUMP	LOOPKPROGSHOW:	CALL	EXKEY	.WW	DEFINE,KAJOUTE	.WW	0,BIPKPROGCHAN:	CALL	EXKEY	.WW	'E,EPROGCHAN	.WW	'R,EPROGCHAN	.WW	'T,EPROGCHANQ	.WW	'S,EPROGCHAN	.WW	'D,EPROGCHAN	.WW	'F,EPROGCHAN	.WW	'G,EPROGCHAN	.WW	'X,EPROGCHAN	.WW	'C,EPROGCHAN	.WW	'V,EPROGCHANQ	.WW	0,BIPKCOPY:	CALL	EXKEY	.WW	DEFINE,KSAUVE	.WW	'F,ECOPY	.WW	'G,ECOPY	.WW	'X,ECOPY	.WW	'C,ECOPY	.WW	'V,ECOPYQ	.WW	SPACE,KCOPIE	.WW	0,10$10$:	CALL	ZKEYNUMI	; D2 <-- numro de la zone inverse	JUMP',EQ CTRL$	CALL	MINMAJ	COMP.B	D3,#'A	JUMP',LO 20$	COMP.B	D3,#'Z	JUMP,LS BIP20$:	CALL	ZKEYNUM		; D2 <-- numro de la zone	JUMP',EQ ZONE$	JUMP	BIPZONE$:	LOAD.W	D1,D2	LOAD.W	D2,(A6)+OZONE1+ODZNUM	CALL	ZDEUX	JUMP,NE ERROR	JUMP	LOOPCTRL$:	CALL	ZCTRL		; A5 <-- ^descripteur zone source	JUMP,NE BIP	LOAD.L	A4,#(A6)+OZONE1	; A4 <-- ^descripteur zone principale	COMP.L	A4,A5	JUMP,EQ BIP	CLR.L	D4	CALL	BPOSITIONNE	; va au dbut de la zone source	JUMP,NE ERRORCTRL2$:	CALL	BAVANCE		; D3 <-- caractre de la zone source	JUMP',NE CTRL4$	EX.L	A5,A4		; A5 <-- ^descripteur zone destination	CALL	BINSERE		; met caractre dans zone destination	JUMP,NE ERROR	EX.L	A5,A4		; A5 <-- ^descripteur zone source	JUMP	CTRL2$CTRL4$:;;?	LOAD.W	D2,(A6)+OZONE1+ODZNUM;;?	CALL	ZUN		; ne montre plus que la zone principale	JUMP	LOOPKCOPYKILL:	CALL	EXKEY	.WW	'F,ECOPYKILL	.WW	'G,ECOPYKILL	.WW	'X,ECOPYKILL	.WW	'C,ECOPYKILL	.WW	'V,ECOPYKILLQ	.WW	0,10$10$:	CALL	ZKEYNUMI	; D2 <-- numro de la zone inverse	JUMP',EQ CTRL$	JUMP	BIPCTRL$:	CALL	ZCTRL		; A5 <-- ^descripteur zone source	JUMP,NE BIP	LOAD.L	A4,#(A6)+OZONE1	; A4 <-- ^descripteur zone principale	COMP.L	A4,A5	JUMP,EQ BIP	CLR.L	D4	CALL	BPOSITIONNE	; va au dbut de la zone source	JUMP,NE ERRORCTRL2$:	CALL	BAVANCE		; D3 <-- caractre de la zone source	JUMP',NE CTRL4$	CALL	BDETRUIT	; dtruit caractre de la zone source	EX.L	A5,A4		; A5 <-- ^descripteur zone destination	CALL	BINSERE		; met caractre dans zone destination	JUMP,NE ERROR	EX.L	A5,A4		; A5 <-- ^descripteur zone source	JUMP	CTRL2$CTRL4$:	LOAD.W	D2,(A6)+OZONE1+ODZNUM	CALL	ZUN		; ne montre plus que la zone principale	JUMP	LOOPECURSUP4:	LOAD.W	D4,#-4	JUMP'	ECURSMOVEECURSUP1:	LOAD.W	D4,#-1	JUMP'	ECURSMOVEECURSDOWN4:	LOAD.W	D4,#+4	JUMP'	ECURSMOVEECURSDOWN1:	LOAD.W	D4,#+1;	JUMP'	ECURSMOVEECURSMOVE:	CALL	AGETPOSX	; D5 <-- position du curseur en X	CALL	AMOVEXY		; dplace le curseur gographiquement	JUMP,NE BIP	JUMP	LOOPECURSOR:	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP	JUMP,NS 40$20$:	CALL	BAVANCE	DEC.L	D2	JUMP,NE 20$	JUMP	LOOP40$:	CALL	BRECULE	INC.L	D2	JUMP,NE 40$	JUMP	LOOPECURSKILLQ:	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP	LOAD.L	D1,D2	JUMP',NC 10$	NEG.L	D110$:	COMP.L	D1,#10	JUMP,LO ECURSKILLN	CALL	DBOXSURE	; tes-vous sr ?	JUMP,NE LOOP	TEST.L	D2	JUMP',NS 40$20$:	CALL	BAVANCE	CALL	BDETRUIT	DEC.L	D2	JUMP,NE 20$	JUMP	LOOP40$:	CALL	BDETRUIT	INC.L	D2	JUMP,NE 40$	JUMP	LOOPECURSKILL:	CALL	EFLECHE		; D2 <-- +/- dplacementECURSKILLN:	TEST.L	D2	JUMP,EQ BIP	JUMP,NS 40$20$:	CALL	ZADETRUIT	JUMP,NE ERROR	DEC.L	D2	JUMP,NE 20$	JUMP	LOOP40$:	CALL	ZRDETRUIT	JUMP,NE ERROR	INC.L	D2	JUMP,NE 40$	JUMP	LOOPECOPYQ:	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP	LOAD.L	D1,D2	JUMP',NC 10$	NEG.L	D110$:	COMP.L	D1,#10	JUMP',LO ECOPYN	CALL	DBOXSURE	; tes-vous sr ?	JUMP,NE LOOP	JUMP'	ECOPYNECOPY:	CALL	EFLECHE		; D2 <-- +/- dplacementECOPYN:	TEST.L	D2	JUMP,NS BIP	CALL	ZCOPY		; ouvre v. une zone secondaire	JUMP,NE ERROR20$:	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	BAVANCE	JUMP,NE BIP	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	CALL	BINSERE	JUMP,NE ERROR	LOAD.W	(A6)+ONOZLC,(A5)+ODZNUM	DEC.L	D2	JUMP,NE 20$	JUMP	LOOPECOPYKILLQ:	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP	LOAD.L	D1,D2	JUMP',NC 10$	NEG.L	D110$:	COMP.L	D1,#10	JUMP',LO ECOPYKILLN	CALL	DBOXSURE	; tes-vous sr ?	JUMP,NE LOOP	JUMP'	ECOPYKILLNECOPYKILL:	CALL	EFLECHE		; D2 <-- +/- dplacementECOPYKILLN:	TEST.L	D2	JUMP,NS BIP	CALL	ZCOPY		; ouvre v. une zone secondaire	JUMP,NE ERROR20$:	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	CALL	BAVANCE	JUMP,NE BIP	CALL	BDETRUIT	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	CALL	BINSERE	JUMP,NE ERROR	LOAD.W	(A6)+ONOZLC,(A5)+ODZNUM	DEC.L	D2	JUMP,NE 20$	JUMP	LOOPEPROGCHANQ:	LOAD.B	D4,D3	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP	LOAD.L	D1,D2	JUMP',NC 10$	NEG.L	D110$:	COMP.L	D1,#10	JUMP',LO EPROGCHANN	CALL	DBOXSURE	; tes-vous sr ?	JUMP,NE LOOP	JUMP'	EPROGCHANNEPROGCHAN:	LOAD.B	D4,D3	CALL	EFLECHE		; D2 <-- +/- dplacementEPROGCHANN:	TEST.L	D2	JUMP,NS 40$20$:	LOAD.B	D3,D4	CALL	EMINMAJ	JUMP,NE BIP	CALL	BAVANCE	JUMP,NE LOOP	DEC.L	D2	JUMP,NE 20$	JUMP	LOOP40$:	CALL	BRECULE	JUMP,NE LOOP	LOAD.B	D3,D4	CALL	EMINMAJ	JUMP,NE BIP	INC.L	D2	JUMP,NE 40$	JUMP	LOOPKSEARCH:	CALL	EXKEY	.WW	'R,ECOMPTEAR	.WW	'D,ESEARCHAR	.WW	'F,ESEARCHAV	.WW	'C,ECOMPTEAV	.WW	',ESEARCHER	.WW	',,EDICOAR	.WW	'.,EDICOAV	.WW	0,BIPESEARCHAR:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE ERROR	JUMP	LOOPESEARCHAV:	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE ERROR	JUMP	LOOPESEARCHER:	PUSH.L	(A6)+OCH1	PUSH.L	(A6)+OCHM1	PUSH.L	(A6)+OCHC1	LOAD.L	(A6)+OCH1,#H'1000000*'^+H'10000*SPACE	CLR.L	(A6)+OCHM1	CLR.L	(A6)+OCHC1	CALL	ECHERCHEAV	; cherche "^ " en avant	POP.L	(A6)+OCHC1	POP.L	(A6)+OCHM1	POP.L	(A6)+OCH1	TEST.W	D7	JUMP,NE ERROR	JUMP	LOOPKCHANGE:	CALL	EXKEY	.WW	'D,ECHANGEAR	.WW	'F,ECHANGEAV	.WW	'R,ECHANGETR	.WW	'C,ECHANGETV	.WW	',,EDICOAR	.WW	'.,EDICOAV	.WW	DEFINE,KCHERCHE	.WW	0,BIPECHANGEAR:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE ERROR	CALL	ESUBSTITUEAR	; effectue la substitution	JUMP,NE ERROR	JUMP	LOOPECHANGEAV:	CALL	BRECULE	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE ERROR	CALL	ESUBSTITUEAV	; effectue la substitution	JUMP,NE ERROR	JUMP	LOOPECHANGETR:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE LOOP	CALL	ESUBSTITUEAR	; effectue la substitution	JUMP,NE ERROR	JUMP	ECHANGETRECHANGETV:	CALL	BRECULE	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE LOOP	CALL	ESUBSTITUEAV	; effectue la substitution	JUMP,NE ERROR	JUMP	ECHANGETVKSEACHA:	CALL	EXKEY	.WW	',,EDICOAR	.WW	'.,EDICOAV	.WW	0,BIPEDICOAV:	PUSH.L	(A6)+OCH1	PUSH.L	(A6)+OCHM1	PUSH.L	(A6)+OCHC1	LOAD.L	(A6)+OCH1,#H'1000000*MARKFM	CLR.L	(A6)+OCHM1	CLR.L	(A6)+OCHC1	CALL	ECHERCHEAV	; cherche fin faute en avant	POP.L	(A6)+OCHC1	POP.L	(A6)+OCHM1	POP.L	(A6)+OCH1	TEST.W	D7	JUMP,NE ERROR	JUMP'	EDICOAVAREDICOAR:	PUSH.L	(A6)+OCH1	PUSH.L	(A6)+OCHM1	PUSH.L	(A6)+OCHC1	LOAD.L	(A6)+OCH1,#H'1000000*MARKFM	CLR.L	(A6)+OCHM1	CLR.L	(A6)+OCHC1	CALL	ECHERCHEAR	; cherche fin faute en arrire	POP.L	(A6)+OCHC1	POP.L	(A6)+OCHM1	POP.L	(A6)+OCH1	TEST.W	D7	JUMP,NE ERROR;	JUMP'	EDICOAVAREDICOAVAR:	LOAD.W	D2,D3	SR.W	D2,#8		; D2 <-- touches super-shift	COMP.B	D2,#SEARCH	JUMP,EQ LOOP	LOAD.L	D4,(A5)+ODZPOS20$:	CALL	BRECULE	JUMP',NE 80$	COMP.B	D3,#MARKDM	JUMP,NE 20$	CALL	BAVANCE	CALL	BDETRUIT	; dtruit le MARKDM	LOAD.L	D0,(A5)+ODZPOS	LOAD.L	D1,#-140$:	INC.L	D1	CALL	BAVANCE	JUMP',NE 80$	COMP.B	D3,#MARKFM	JUMP,NE 40$	CALL	BDETRUIT	; dtruit le MARKFM	JUMP'	EDICODBOX80$:	CALL	BPOSITIONNE	JUMP	BIPEDICODBOX:	COMP.B	D2,#SEARCH!CHANGE	JUMP,NE LOOP	LOAD.L	D4,D0		; D4 <-- position	LOAD.L	D5,D1		; D5 <-- nb de caractres	CALL	DICOVERIF	; vrifie juste le mot	JUMP,NE ERROR	JUMP	LOOPECHERCHE:	TEST.B	(A6)+OCHFAN+2:#BCHAR-8	JUMP,BS AR2$AV2$:	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE ERROR	CALL	ADISPLAY	; affiche la chane trouve	CALL	AOPEZONE	LOAD.L	D5,D4	LOAD.L	D4,(A5)+ODZPOS	ADD.L	D5,D4	CALL	AMODZONE	; met en vidence les caractres trouvs	CALL	DBOXCHERCHE	; SUIVANT/STOP ...	PUSH.W	D7	CALL	ACLOZONE	; enlve la mise en vidence	POP.W	D7	JUMP,NE ERROR	COMP.W	D3,#F1		; suivant ?	JUMP,EQ AV2$		; oui => AV2$	JUMP	LOOPAR2$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE ERROR	CALL	ADISPLAY	; affiche la chane trouve	CALL	AOPEZONE	LOAD.L	D5,D4	LOAD.L	D4,(A5)+ODZPOS	ADD.L	D5,D4	CALL	AMODZONE	; met en vidence les caractres trouvs	CALL	DBOXCHERCHE	; SUIVANT/STOP ...	PUSH.W	D7	CALL	ACLOZONE	; enlve la mise en vidence	POP.W	D7	JUMP,NE ERROR	COMP.W	D3,#F1		; suivant ?	JUMP,EQ AR2$		; oui => AR2$	JUMP	LOOPECOMPTE:	TEST.B	(A6)+OCHFAN+2:#BCHAR-8	JUMP,BS ECOMPTEARECOMPTEAV:	CALL	BPSAUVE	PUSH.W	D4	CLR.L	D2		; D2 <-- nombre d'occurencesAV2$:	CALL	ECHERCHEAV	; cherche en avant	JUMP',NE AV3$	INC.L	D2		; D2 <-- une occurence de plus	JUMP	AV2$AV3$:	POP.W	D4	CALL	BPPREND		; remet le curseur o il tait	LOAD.L	D4,D2		; D4 <-- nombre d'occurences	CALL	DBOXOCCURENCE	; affiche le nombre d'occurences ...	JUMP,NE ERROR	JUMP	LOOPECOMPTEAR:	CALL	BPSAUVE	PUSH.W	D4	CLR.L	D2		; D2 <-- nombre d'occurencesAR2$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP',NE AR3$	INC.L	D2		; D2 <-- une occurence de plus	JUMP	AR2$AR3$:	POP.W	D4	CALL	BPPREND		; remet le curseur o il tait	LOAD.L	D4,D2		; D4 <-- nombre d'occurences	CALL	DBOXOCCURENCE	; affiche le nombre d'occurences ...	JUMP,NE ERROR	JUMP	LOOPECHANGE:	TEST.B	(A6)+OCHFAN+2:#BCHAR-8	JUMP,BS AR2$AV2$:	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE ERROR	PUSH.L	D4	CALL	ADISPLAY	; affiche la chane trouve	CALL	AOPEZONE	LOAD.L	D5,D4	LOAD.L	D4,(A5)+ODZPOS	ADD.L	D5,D4	CALL	AMODZONE	; met en vidence les caractres trouvs	POP.L	D4	CALL	DBOXSUBSTITUE	; CHANGE/SUIVANT/PARTOUT/UN/STOP ...	PUSH.W	D7	CALL	ACLOZONE	; enlve la mise en vidence	POP.W	D7	JUMP,NE ERROR	COMP.W	D3,#F1		; CHANGE ?	JUMP',EQ AVSUBS$	; oui => AVSUBS$	COMP.W	D3,#F4		; SUIVANT ?	JUMP,EQ AV2$		; oui => AV2$	COMP.W	D3,#F7		; PARTOUT ?	JUMP',EQ AVALL$		; oui => AVALL$	COMP.W	D3,#F10		; UN ?	JUMP',EQ AVSUBS$	; oui => AVSUBS$	JUMP	LOOPAVSUBS$:	CALL	ESUBSTITUEAV	; effectue la substitution	JUMP,NE ERROR	COMP.W	D3,#F1		; CHANGE ?	JUMP,EQ AV2$		; oui => AV2$	JUMP	LOOPAVALL$:	CALL	ESUBSTITUEAV	; effectue la substitution	JUMP,NE ERROR	CALL	ECHERCHEAV	; cherche en avant	JUMP,EQ AVALL$	JUMP	LOOPAR2$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE ERROR	PUSH.L	D4	CALL	ADISPLAY	; affiche la chane trouve	CALL	AOPEZONE	LOAD.L	D5,D4	LOAD.L	D4,(A5)+ODZPOS	ADD.L	D5,D4	CALL	AMODZONE	; met en vidence les caractres trouvs	POP.L	D4	CALL	DBOXSUBSTITUE	; CHANGE/SUIVANT/PARTOUT/UN/STOP ...	PUSH.W	D7	CALL	ACLOZONE	; enlve la mise en vidence	POP.W	D7	JUMP,NE ERROR	COMP.W	D3,#F1		; CHANGE ?	JUMP',EQ ARSUBS$	; oui => ARSUBS$	COMP.W	D3,#F4		; SUIVANT ?	JUMP,EQ AR2$		; oui => AR2$	COMP.W	D3,#F7		; PARTOUT ?	JUMP',EQ ARALL$		; oui => ARALL$	COMP.W	D3,#F10		; UN ?	JUMP',EQ ARSUBS$	; oui => ARSUBS$	JUMP	LOOPARSUBS$:	CALL	ESUBSTITUEAR	; effectue la substitution	JUMP,NE ERROR	COMP.W	D3,#F1		; CHANGE ?	JUMP,EQ AR2$		; oui => AR2$	JUMP	LOOPARALL$:	CALL	ESUBSTITUEAR	; effectue la substitution	JUMP,NE ERROR	CALL	ECHERCHEAR	; cherche en arrire	JUMP,EQ ARALL$	JUMP	LOOP;--------\\; EINSERE >;========/; Insre un caractre en mode "environnant".; in	D3.B	caractre  insrer; out	D7.W	erreur; mod	D7.WEINSERE:	PUSHM.L	D1..D4	LOAD.B	D1,D3		; D1 <-- caractre; Cherche le mode du caractre avant le curseur.	CALL	BPSAUVE		; D4 <-- position du curseur	CALL	BRECULE		; D3 <-- mode du caractre prcdent	JUMP',EQ 30$	CLR.L	D3		; D3 <-- mode par dfaut30$:	CALL	BPPREND		; remet le curseur o il tait	LOAD.L	D2,D3; Cherche le mode du caractre aprs le curseur.	CALL	BPSAUVE		; D4 <-- position du curseur	CALL	BAVANCE		; D3 <-- mode du caractre suivant	JUMP',EQ 40$	CLR.L	D3		; D3 <-- mode par dfaut40$:	CALL	BPPREND		; remet le curseur o il tait; Insre le caractre avec le mode le plus grand.	COMP.L	D3,D2	JUMP',HS 50$	LOAD.L	D3,D250$:	LOAD.L	D2,(A6)+OFRMSK	NOT.L	D2	AND.L	D3,D2		; D3 <-- masque selon frappe	OR.L	D3,(A6)+OFRCAR	; D3 <-- mode selon frappe	LOAD.B	D3,D1		; D3 <-- mode et caractre	CALL	BINSERE		; insre normalement	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ECHERCHEAV >;===========/; Cherche en avant selon le dialogue "change".; Si elle est trouve, le curseur est plac sur le premier caractre.; Si elle n'est pas trouve, le curseur reste immobile !; in	-; out	D4.L	longueur de la chane trouve;	D7.W	erreur; mod	D4.L, D7.WECHERCHEAV:	PUSHM.L	D0..D3,D5,A3	LOAD.L	A3,#(A6)+OCH1	; A3 <-- ^chane de recherche	LOAD.L	D2,(A6)+OCHM1	LOAD.B	D2,#H'FF	; D2 <-- masque de recherche	CALL	BPSAUVE	PUSH.W	D4		; stack <-- position actuelle10$:	CALL	BAVANCE	JUMP,NE 80$; Cherche rapidement le premier caractre de la chane.	LOAD.L	D3,(A6)+OCHC1	LOAD.B	D3,(A3)		; D3 <-- premier caractre	CLR.W	D5		; D5 <-- mode	TEST.B	(A6)+OCHFAN+3:#BCHMIMA-0	JUMP',BC 20$	TSET.L	D5:#020$:	CALL	BACHERCHE	; cherche le premier caractre	JUMP',NE 80$; Cherche normalement si le reste de la chane correspond.	CALL	ECHERCHECP	; chane complte trouve ?	JUMP,NE 10$; Fin de la recherche. En cas d'erreur, remet le curseur o il tait.80$:	LOAD.W	D3,D7	JUMP',NE 82$	POP.W	D4	CALL	BPANNULE	; annule le BPSAUVE	JUMP'	84$82$:	POP.W	D4	CALL	BPPREND		; remet le curseur o il tait	LOAD.W	D3,#ERENOTF	; D7 <-- pas trouv84$:	LOAD.W	D7,D3		; D7 <-- ok/erreur	LOAD.L	D4,D1		; D4 <-- nombre de caractres trouvs	POPM.L	D0..D3,D5,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ECHERCHEAR >;===========/; Cherche en arrire selon le dialogue "change".; Si elle est trouve, le curseur est plac sur le premier caractre.; Si elle n'est pas trouve, le curseur reste immobile !; in	-; out	D4.L	longueur de la chane trouve;	D7.W	erreur; mod	D4.L, D7.WECHERCHEAR:	PUSHM.L	D0..D3,D5,A3	LOAD.L	A3,#(A6)+OCH1	; A3 <-- ^chane de recherche	LOAD.L	D2,(A6)+OCHM1	LOAD.B	D2,#H'FF	; D2 <-- masque de recherche	CALL	BPSAUVE	PUSH.W	D4		; stack <-- position actuelle; Cherche rapidement le premier caractre de la chane.10$:	LOAD.L	D3,(A6)+OCHC1	LOAD.B	D3,(A3)		; D3 <-- premier caractre	CLR.W	D5		; D5 <-- mode	TEST.B	(A6)+OCHFAN+3:#BCHMIMA-0	JUMP',BC 20$	TSET.L	D5:#020$:	CALL	BRCHERCHE	; cherche le premier caractre	JUMP',NE 80$	CALL	BRECULE	JUMP',NE 80$; Cherche normalement si le reste de la chane correspond.	CALL	ECHERCHECP	; chane complte trouve ?	JUMP,NE 10$; Fin de la recherche. En cas d'erreur, remet le curseur o il tait.80$:	LOAD.W	D3,D7	JUMP',NE 82$	POP.W	D4	CALL	BPANNULE	; annule le BPSAUVE	JUMP'	84$82$:	POP.W	D4	CALL	BPPREND		; remet le curseur o il tait	LOAD.W	D3,#ERENOTF	; D7 <-- pas trouv84$:	LOAD.W	D7,D3		; D7 <-- ok/erreur	LOAD.L	D4,D1		; D4 <-- nombre de caractres trouvs	POPM.L	D0..D3,D5,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ECHERCHECP >;-----------/; Regarde si le curseur est au dbut de la chane de recherche complte.; in	A3.L	^chane de recherche;	D2.L	masque de recherche; out	D1.L	nombre de caractres trouvs;	D7.W	erreur; mod	D1.L, D7.WECHERCHECP:	PUSHM.L	D3,D4,A3	CALL	BPSAUVE	PUSH.W	D4		; stack <-- position dbut chane	TEST.B	(A6)+OCHFAN+3:#BCHMOT-0	JUMP',BC 10$	CALL	BRECULE	JUMP',NE 10$	CALL	ECHERCHEMO	; lettre ou chiffre ?	JUMP,EQ 75$		; oui => 75$	CALL	BAVANCE10$:	CLR.L	D1		; D1 <-- nombre de caractres trouvs20$:	LOAD.L	D4,(A6)+OCHC1	LOAD.B	D4,(A3+)	; D4 <-- caractre de la chane	JUMP,EQ 50$	COMP.B	D4,#'*	JUMP',NE 30$	TEST.B	(A6)+OCHFAN+3:#BCHJOKER-0	JUMP,BS 40$30$:	CALL	BAVANCE		; D3 <-- caractre du texte	JUMP,NE 75$	INC.L	D1		; D1 <-- un caractre de plus	COMP.B	D4,#'?	JUMP',NE 32$	TEST.B	(A6)+OCHFAN+3:#BCHJOKER-0	JUMP,BS 20$32$:	AND.L	D3,D2		; D3 <-- masque	AND.L	D4,D2		; D4 <-- masque	TEST.B	(A6)+OCHFAN+3:#BCHMIMA-0	JUMP',BC 36$	CALL	MINMAJ		; D3 <-- majuscule	EX.L	D4,D3	CALL	MINMAJ		; D4 <-- majuscule	EX.L	D3,D436$:	COMP.L	D3,D4		; compare deux caractres	JUMP,EQ 20$	JUMP'	75$40$:				; toile rencontre =>	LOAD.L	D4,(A6)+OCHC1	LOAD.B	D4,(A3+)	; D4 <-- caractre aprs l'toile	JUMP,EQ 50$	AND.L	D4,D2		; D4 <-- masque	TEST.B	(A6)+OCHFAN+3:#BCHMIMA-0	JUMP',BC 42$	EX.L	D4,D3	CALL	MINMAJ		; D4 <-- majuscule	EX.L	D3,D442$:	CALL	BAVANCE		; D3 <-- caractre du texte	JUMP,NE 75$	INC.L	D1		; D1 <-- un caractre de plus	TEST.B	(A6)+OCHFAN+3:#BCHMOT-0	JUMP',BC 44$	CALL	ECHERCHEMO	; lettre ou chiffre ?	JUMP,NE 75$		; non => 75$44$:	AND.L	D3,D2		; D3 <-- masque	TEST.B	(A6)+OCHFAN+3:#BCHMIMA-0	JUMP',BC 46$	CALL	MINMAJ		; D3 <-- majuscule46$:	COMP.L	D3,D4		; compare deux caractres	JUMP,NE 42$	JUMP	20$50$:				; fin chane de recherche =>	TEST.B	(A6)+OCHFAN+3:#BCHMOT-0	JUMP',BC 70$	CALL	BAVANCE	JUMP',NE 70$	CALL	ECHERCHEMO	; lettre ou chiffre ?	JUMP',EQ 75$		; oui => 75$70$:	CLR.W	D7		; D7 <-- trouv	JUMP'	80$75$:	LOAD.W	D7,#ERENOTF	; D7 <-- pas trouv80$:	LOAD.W	D3,D7	POP.W	D4	CALL	BPPREND		; revient au dbut de la chane	LOAD.W	D7,D3	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ECHERCHEMO >;-----------/; Regarde si un caractre est une lettre ou un chiffre.; in	D3.B	caractre; out	D7.W	EQ => c'est une lettre/chiffre;		NE => autre caractre; mod	D3.B, D7.WECHERCHEMO:	CALL	MINMAJ	LOAD.W	D7,#EREOUTB	; D7 <-- autre chose	COMP.B	D3,#'0	JUMP',LO 90$	COMP.B	D3,#'9	JUMP',LS 80$	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'Z	JUMP',HI 90$80$:	CLR.W	D7		; D7 <-- lettre ou chiffre90$:	TEST.W	D7		; retour EQ/NE	RET;-------------\\; ESUBSTITUEAR >;=============/; Remplace la chane de recherche par la chane de substitution.; Le curseur est plac au dbut de la chane substitue.; in	D4.L	longueur de la chane trouve; out	D4.L	longueur de la chane substitue;	D7.W	erreur; mod	D4.L, D7.WESUBSTITUEAR:	CALL	ESUBSTITUEAV	JUMP',EQ 20$	RET20$:	PUSHM.L	D3,D422$:	CALL	BRECULE		; recule au dbut	JUMP',NE 24$	DEC.L	D4	JUMP,NE 22$24$:	POPM.L	D3,D4	CLR.W	D7		; D7 <-- ok	RET;-------------\\; ESUBSTITUEAV >;=============/; Remplace la chane de recherche par la chane de substitution.; Le curseur est plac  la fin de la chane substitue.; in	D4.L	longueur de la chane trouve; out	D4.L	longueur de la chane substitue;	D7.W	erreur; mod	D4.L, D7.WESUBSTITUEAV:	PUSHM.L	D1..D3,A3; Supprime d'abord la chane de recherche.	CLR.L	D220$:	CALL	BAVANCE	JUMP',NE 30$	TEST.L	D2	JUMP',NE 22$	LOAD.L	D2,D3		; D2 <-- premier caractre dtruit22$:	CALL	BDETRUIT	; dtruit un caractre en avant	DEC.L	D4		; encore un caractre ?	JUMP,NE 20$		; oui => 20$; Insre la chane de substitution.30$:	LOAD.L	A3,#(A6)+OCH2	; A3 <-- ^chane de substitution	CLR.L	D450$:	LOAD.L	D3,D2	LOAD.B	D3,(A3+)	; D3 <-- caractre, avec mode du premier dtruit	JUMP',EQ 80$	LOAD.L	D1,(A6)+OCHM2	NOT.L	D1	AND.L	D3,D1	OR.L	D3,(A6)+OCHC2	CALL	BINSERE	JUMP',NE 90$	INC.L	D4		; D4 <-- longueur de la chane de substitution	JUMP	50$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D3,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; EMINMAJ >;========/; Transforme un caractre, en majuscule ou en minuscule.; in	D3.B	touche majuscule/minuscule; out	D7.W	erreur; mod	D7.WEMINMAJ:	PUSHM.L	D2..D4	LOAD.B	D2,D3	CALL	BDONNE		; D3 <-- caractre sous le curseur	JUMP',NE 90$	LOAD.B	D4,D3	COMP.B	D2,#'a	JUMP',LO 40$	COMP.B	D2,#'z	JUMP',HI 40$				; en minuscule =>	COMP.B	D3,#'A	JUMP',LO 60$	COMP.B	D3,#'Z	JUMP',HI 60$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule	JUMP'	60$40$:				; en majuscule =>	CALL	MINMAJ		; D3 <-- lettre majuscule60$:	COMP.B	D3,D4		; caractre chang ?	JUMP',EQ 90$		; non => 90$	CALL	BREMPLACE90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ESELMOT >;========/; Slectionne tout un mot.; in	D4.L	position n'importe o; out	D4.L	position dbut mot;	D5.L	position fin mot; mod	D4.L, D5.L, D7.WESELMOT:	PUSHM.L	D0..D3	LOAD.L	D0,D4	CALL	BPSAUVE		; D4 <-- numro position actuelle	EX.L	D0,D4	CALL	BQPOSITIONNE	; positionne (rapidement)	LOAD.B	D3,#'S	CALL	EFLECHE		; D2 <-- dplacement pour reculer au dbut du mot	LOAD.L	D1,D2	LOAD.B	D3,#'G	CALL	EFLECHE		; D2 <-- dplacement pour avancer  la fin du mot	LOAD.L	D5,D4	ADD.L	D5,D2		; D5 <-- position fin mot	ADD.L	D4,D1		; D4 <-- position dbut mot	EX.L	D0,D4	CALL	BPPREND		; remet le curseur o il tait	LOAD.L	D4,D0	POPM.L	D0..D3	RET;---------\\; ESELPARA >;=========/; Slectionne tout un paragraphe.; in	D4.L	position; out	D4.L	position dbut paragraphe;	D5.L	position fin paragraphe; mod	D4.L, D5.L, D7.WESELPARA:	PUSHM.L	D0..D3	LOAD.L	D0,D4	CALL	BPSAUVE		; D4 <-- numro position actuelle	EX.L	D0,D4	CALL	BQPOSITIONNE	; positionne (rapidement)	CALL	BAVANCE	LOAD.B	D3,#'R	CALL	EFLECHE		; D2 <-- dplacement pour reculer au dbut	LOAD.L	D1,D2	INC.L	D1	CALL	BRECULE	CALL	BRECULE	LOAD.B	D3,#'C	CALL	EFLECHE		; D2 <-- dplacement pour avancer  la fin	LOAD.L	D5,D4	ADD.L	D5,D2		; D5 <-- position fin mot	ADD.L	D4,D1		; D4 <-- position dbut mot	EX.L	D0,D4	CALL	BPPREND		; remet le curseur o il tait	LOAD.L	D4,D0	POPM.L	D0..D3	RET;---------\\; EFLECHE  >;---------/; Calcul l'amplitude d'un dplacement/destruction en fonction; d'une touche flche.; in	D3.B	touche flche; out	D2.L	dplacement (+/-n); mod	D2.L, D7.WEFLECHE:	PUSHM.L	D3..D6,A3	CALL	BPSAUVE		; D4 <-- numro position actuelle	PUSH.W	D4	CLR.L	D2		; D2 <-- dplacement	COMP.B	D3,#'A-H'40	JUMP',LO NOCTRL$	COMP.B	D3,#'Z-H'40	JUMP',HI NOCTRL$	ADD.B	D3,#H'40NOCTRL$:	CALL	MINMAJ	COMP.B	D3,#'F	JUMP,EQ AONE$	COMP.B	D3,#'D	JUMP,EQ RONE$	LOAD.W	D6,#1		; D6 <-- une fois	LOAD.L	A3,#R16"TWORD	; A3 <-- ^terminateurs de mots	COMP.B	D3,#'G	JUMP,EQ ALIST$	COMP.B	D3,#'S	JUMP,EQ RLIST$	LOAD.L	A3,#R16"TLINE	; A3 <-- ^terminateurs de lignes	COMP.B	D3,#'C	JUMP,EQ ALIST$	COMP.B	D3,#'R	JUMP,EQ RLIST$	LOAD.W	D6,#4		; D6 <-- quatre fois	COMP.B	D3,#'X	JUMP,EQ ALIST$	COMP.B	D3,#'E	JUMP,EQ RLIST$	COMP.B	D3,#'V	JUMP,EQ AEND$	COMP.B	D3,#'T	JUMP,EQ REND$	JUMP	EXIT$AONE$:				; +1 caractre =>	CALL	BAVANCE	JUMP,NE EXIT$	INC.L	D2	JUMP	EXIT$RONE$:				; -1 caractre =>	CALL	BRECULE	JUMP,NE EXIT$	DEC.L	D2	JUMP	EXIT$ALIST$:				; +1 mot/ligne =>	CALL	BAVANCE	JUMP,NE EXIT$	INC.L	D2	CALL	ETESTCAR	JUMP',NE ALIST2$	COMP.B	(A3),#CR	JUMP,NE ALIST$ALIST2$:	CALL	BAVANCE	JUMP,NE EXIT$	INC.L	D2	CALL	ETESTCAR	JUMP,NE ALIST2$	CALL	BRECULE	DEC.L	D2	DEC.W	D6	JUMP,NE ALIST$	JUMP	EXIT$RLIST$:				; -1 mot/ligne =>	CALL	BRECULE	JUMP,NE EXIT$	DEC.L	D2	CALL	ETESTCAR	JUMP',NE RLIST2$	COMP.B	(A3),#CR	JUMP,NE RLIST$RLIST2$:	CALL	BRECULE	JUMP,NE EXIT$	DEC.L	D2	CALL	ETESTCAR	JUMP,NE RLIST2$	CALL	BAVANCE	INC.L	D2	DEC.W	D6	JUMP,NE RLIST$	JUMP	EXIT$AEND$:				; fin =>	CALL	BINFO		; D4 <-- position, D5 <-- nb caractres	LOAD.L	D2,D5	SUB.L	D2,D4	JUMP'	EXIT$REND$:				; dbut =>	CALL	BINFO		; D4 <-- position, D5 <-- nb caractres	LOAD.L	D2,D4	NEG.L	D2;	JUMP'	EXIT$EXIT$:	POP.W	D4	CALL	BPPREND		; remet le curseur o il tait	POPM.L	D3..D6,A3	RETTWORD:	.B	SPACE		; terminateurs de mots	.B	TAB	.B	'+	.B	'-	.B	'*	.B	'/	.B	'^	.B	'(	.B	')	.B	'.	.B	':	.B	',	.B	';	.B	'!	.B	'?	.B	MARKDM	.B	MARKFMTLINE:	.B	CR		; terminateurs de lignes	.B	LF	.B	0	.EVEN;---------\\; ETESTCAR >;---------/; Test si le caractre dans D3.B est un terminateur.; in	D3.B	caractre;	A3.L	^liste de terminateurs; out	EQ	terminateur;	NE	autre chose; mod	FETESTCAR:	PUSH.L	A310$:	TEST.B	(A3)	NOTZ	JUMP',NE 90$	COMP.B	D3,(A3+)	JUMP,NE 10$90$:	POP.L	A3	RETKCIRCON:	LOAD.W	D4,#CIRCON	; met un circonflxe	JUMP'	KACCENTKTREMA:	LOAD.W	D4,#TREMA	; met qq chose comme un trma;	JUMP'	KACCENTKACCENT:	TEST.B	(A6)+OFLAGS:#BACC	JUMP,BS 60$	CALL	BDONNE		; D3 <-- car "sous" le curseur	JUMP',NE 50$		; rien => 50$	CALL	GETACCENT	; calcul lettre accentue	JUMP',NE 50$		; n'existe pas => 50$				; existe =>	TEST.B	D3	JUMP',EQ 50$	PUSH.L	D3	CALL	BAVANCE	CALL	BDETRUIT	; dtruit lettre non accentue	POP.L	D3	CALL	BINSERE		; remplace par lettre accentue	JUMP	LOOP50$:	LOAD.B	D3,D4		; D3 <-- accent	CALL	EINSERE		; insert un accent tout seul	CALL	BRECULE		; puis recule "dessus"	TSET.B	(A6)+OFLAGS:#BACC	JUMP	LOOP60$:	CALL	NOACCENT	; plus de frappe d'accent flottant	JUMP	LOOP;--------\\; ACCENT  >;========/; Caractre aprs un accent flottant frapp.; in	D3.B	caractre aprs accent; out	D7.W	erreur; mod	D7.WACCENT:	PUSHM.L	D3,D4	LOAD.W	D7,#EREOUTB	TCLR.B	(A6)+OFLAGS:#BACC ; clear flag des accents	JUMP,BC 90$	LOAD.L	D4,D3	CALL	BDONNE		; D3 <-- cherche car prcdent tap	EX.L	D3,D4		; D4 <-- accent, D3 <-- car qui ira "sous"	CALL	GETACCENT	; accent existe ?	JUMP',NE 40$		; non => 40$				; oui =>	TEST.B	D3		; laisse l'accent seul ?	JUMP',EQ 40$		; oui => 40$				; non =>	PUSH.L	D3	CALL	BAVANCE	CALL	BDETRUIT	; dtruit l'accent seul	POP.L	D3	CALL	EINSERE		; remplace par lettre accentue	JUMP'	90$40$:	PUSH.W	D7	CALL	BAVANCE		; saute '^' ou '"'	POP.W	D790$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; GETACCENT >;----------/; Calcul le code correspondant  une lettre (a,e,i,o,u) et ; un accent (^,").; in	D4.B	accent (^,");	D3.B	caractre; out	D7.W	zro => ok (lettre accentue existe);	 D3.B	 lettre accentue;	D7.W	EREOUTB => lettre accentue n'existe pas;	 D3.B	 caractre qui devait aller sous l'accent; mod	D3.B, D7.WGETACCENT:	PUSH.L	A3	LOAD.L	A3,#R16"ACCENT$-310$:	ADD.L	A3,#3		; A3 <-- ^suivant dans table	TEST.B	(A3)		; fin de la table ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,(A3)		; lettre trouve dans table ?	JUMP,NE 10$		; non => 10$				; oui =>	COMP.B	D4,#CIRCON	JUMP',EQ 30$	COMP.B	D4,#TREMA	JUMP',NE 50$	LOAD.B	D3,(A3)+2	; D3 <-- lettre accentue (")	CLR.W	D7		; D7 <-- ok	JUMP'	90$30$:	LOAD.B	D3,(A3)+1	; D3 <-- lettre accentue (^)	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.W	D7,#EREOUTB	; D7 <-- erreur90$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RETACCENT$:	.B	'a	' '	.B	'e	' '	.B	'i	' '	.B	'o	' '	.B	'u	' '	.B	SPACE	 0  0	.B	0	.EVEN;---------\\; NOACCENT >;=========/; Annule l'effet d'un ventuel accent flottant tap, alors; que la lettre devant aller "dessous" n'a pas encore t; tape.NOACCENT:	TCLR.B	(A6)+OFLAGS:#BACC	JUMP',BC 90$	PUSH.L	D3	CALL	BAVANCE		; saute l'accent flottant	POP.L	D390$:	RET	.END