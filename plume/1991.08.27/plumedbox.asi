	.SBTTL	PLUMEDBOX;--------\\; DBOXDEF >;========/; Demande les dfinitions.; in	-; out	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDEF:	PUSHM.L	D1,D2,D4,A0..A4	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.W	D4,(A6)+ODISP+2	SWAP.W	D4	LOAD.W	D4,(A6)+ODEF+2	LOAD.L	A2,#R16"TDBOX_DEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	PUSH.L	D4	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFC2Y	LOAD.W	D1,D3	SWAP.W	D3	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; trait horizontal	LOAD.W	D2,#101!2^BDBGCLABEL	DBOX_	GETCO	AND.L	D3,#H'FFFF	LOAD.W	D4,D1	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; trait vertical	POP.L	D4	LOAD.L	A3,#(A6)+OBUEXT	LOAD.L	A4,A310$:	TEST.B	(A4+)	JUMP,NE 10$	DEC.L	A420$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_DEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP',EQ 60$	COMP.W	D3,#F4	JUMP',EQ 60$	COMP.W	D3,#F0	JUMP',EQ 80$	COMP.W	D3,#UNDO	JUMP',EQ 40$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	20$60$:	LOAD.W	(A6)+ODEF+2,D4	SWAP.W	D4	LOAD.W	(A6)+ODISP+2,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,A0..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande s'il faut quitter TEXT.; in	-; out	D7.W	rponse; mod	D7.WDBOXQUITTE:	PUSHM.L	D1..D4,A2..A5	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	CLR.L	D3	CALL	DBOXPREF	; dbox: attend la rponse ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',EQ 90$	LOAD.W	D7,#ERKNO	; D7 <-- rponse "non"90$:	POPM.L	D1..D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer le texte.; in	A5.L	^description de la zone  effacer; out	D7.W	erreur (reste dans edit); mod	D7.WDBOXEFFACE:	PUSHM.L	D1..D4,A2..A5	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	LOAD.W	D3,(A5)+ODZNUM	LOAD.L	A5,#(A5)+ODZNAM	; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	CALL	DBOXPREF	; dbox: attend la rponse ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',EQ 90$	LOAD.W	D7,#ERKNO	; D7 <-- rponse "non"90$:	POPM.L	D1..D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXSURE >;=========/; Demande "Etes-vous sr ? "; in	D3.W	touche;	D2.L	+/- nombre (remplace le # du texte); out	D7.W	rponse; mod	D7.WDBOXSURE:	PUSHM.L	D1..D5,A0..A4	LOAD.L	D1,D2		; D1 <-- nombre	LIB	?BUZZ		; signal qq chose de spcial	LOAD.L	A2,#R16"TDBOX_SURE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	LOAD.L	A3,#R16"TABLE$	CALL	_MINMAJ10$:	TEST.W	(A3+)	JUMP',EQ 14$	COMP.W	D3,(A3)-2	JUMP',EQ 14$12$:	TEST.B	(A3+)	JUMP,NE 12$	LOAD.L	D2,A3	TEST.L	D2:#0	JUMP,BC 10$	INC.L	A3	JUMP	10$14$:	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LOAD.L	D2,D3	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre20$:	LOAD.L	D3,D2	LIB	?SETCURS	SWAP.W	D2	ADD.W	D2,(A0)+ODFCY	SWAP.W	D222$:	LOAD.B	D3,(A3+)	JUMP,EQ 50$	COMP.B	D3,#CR	JUMP,EQ 20$	COMP.B	D3,#'#	JUMP',EQ 26$	LIB	?AFCAR	JUMP	22$26$:	PUSH.W	D2	LOAD.L	D4,D1	JUMP',NC 27$	NEG.L	D427$:	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDCM!2^BAFDSP	LIB	?AFDEC	POP.W	D2	JUMP	22$50$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_SURE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	50$		; oui => 50$	CLR.W	D4		; D4 <-- rponse "oui"	COMP.W	D3,#'O	JUMP',EQ 80$	LOAD.W	D4,#ERKNO	; D4 <-- rponse "non"	COMP.W	D3,#'N	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	50$80$:	CALL	DBOXCLOSE	; ferme la DBOX	LOAD.W	D7,D4		; D7 <-- oui/non90$:	POPM.L	D1..D5,A0..A4	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	H'100*(CURSOR!KILL)+'V	.ASCII	"Voulez-vous dtruire les # caractres<CR>"	.ASCIZ	"situs entre le curseur et la fin du texte ?"	.EVEN	.W	H'100*(CURSOR!KILL)+'T	.ASCII	"Voulez-vous dtruire les # caractres<CR>"	.ASCIZ	"situs entre le curseur et le dbut du texte ?"	.EVEN	.W	H'100*(COPY)+'V	.ASCII	"Voulez-vous copier les # caractres<CR>"	.ASCIZ	"situs entre le curseur et la fin du texte ?"	.EVEN	.W	H'100*(COPY!KILL)+'V	.ASCII	"Voulez-vous copier les # caractres<CR>"	.ASCIZ	"situs entre le curseur et la fin du texte ?"	.EVEN	.W	H'100*(PROGRA!CHANGE)+'V	.ASCII	"Voulez-vous convertir les # caractres<CR>"	.ASCIZ	"situs entre le curseur et la fin du texte ?"	.EVEN	.W	H'100*(PROGRA!CHANGE)+'T	.ASCII	"Voulez-vous convertir les # caractres<CR>"	.ASCIZ	"situs entre le curseur et le dbut du texte ?"	.EVEN	.W	0	.ASCIZ	"Etes-vous sr ?<CR>"	.EVEN	.W	0;-----------\\; DBOXEXNAME >;===========/; Demande que faire ...; in	A3.L	^nom du fichier;	D4.W	numro de la zone; out	D7.W	rponse; mod	D7.WDBOXEXNAME:	PUSHM.L	D1..D5,A1..A4	CLR.L	D1	LOAD.W	D1,D4		; D1 <-- numro de la zone	LIB	?BUZZ		; signal qq chose de spcial	LOAD.L	A2,#R16"TDBOX_EXNAME	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.B	D3,#'"	LIB	?AFCAR	LOAD.W	D3,#45-11-1-1	LOAD.W	D2,#2^BAFXMI	LIB	?AFXFILE	; affiche le nom du fichier	LOAD.B	D3,#'"	LIB	?AFCAR	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,D1	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le numro de la zone	LOAD.B	D3,#'.	LIB	?AFCAR50$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_EXNAME	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	50$		; oui => 50$	CLR.W	D4		; D4 <-- rponse "oui"	COMP.W	D3,#'O	JUMP',EQ 80$	LOAD.W	D4,#ERKNO	; D4 <-- rponse "non"	COMP.W	D3,#'N	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	50$80$:	CALL	DBOXCLOSE	; ferme la DBOX	LOAD.W	D7,D4		; D7 <-- oui/non90$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCHANGE >;===========/; Dialogue pour les recherches/substitutions.; in	D3.W	touche actionne; out	D3.W	dernire touche (DEFINE/F1/F4/F7/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCHANGE:	PUSHM.L	D0..D2,D4..D6,A0..A5	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.W	D1,D3	LOAD.L	A2,#R16"TDBOX_CHANGE	LOAD.W	D2,#2^BDBSAV!2^BDBMAX	LOAD.L	D4,(A6)+OCHFAN	; D4 <-- fanions	TEST.L	D1:#BCHANGE+8	; actionn avec (CHANGE-DEFINE) ?	JUMP',BS OPEN2$		; oui => OPEN2$	AND.L	D4,#-1-(2^BCHCAR1!2^BCHMOD1!2^BCHCAR2!2^BCHMOD2)OPEN2$:	TEST.L	D4	JUMP',NE OPEN3$	LOAD.L	D4,#2^BCHAVOPEN3$:	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; ligne horizontale	LOAD.L	D4,D3	CLR.W	D4	CLR.L	D3	LOAD.W	D3,(A0)+ODFFDX	SR.W	D3,#1	LIB	?DRSEG		; ligne verticale	POP.L	D4	TEST.L	D1:#BCHANGE+8	; actionn avec (CHANGE-DEFINE) ?	JUMP',BS OPEN5$		; oui => OPEN5$	CLR.B	(A6)+OCH1	; chane de recherche vide	CLR.B	(A6)+OCH2	; chane de substitution vide	CLR.W	(A6)+OCHSL1+OSLCYS	CLR.W	(A6)+OCHSL2+OSLCYS	CLR.W	(A6)+OCHSL3+OSLCYS	CLR.W	(A6)+OCHSL4+OSLCYSOPEN5$:	CLR.W	D2		; D2 <-- rang ligne en dition	TEST.L	D1:#BCHANGE+8	; actionn avec (CHANGE-DEFINE) ?	JUMP',BC DRAW$		; non => DRAW$	TEST.B	D1		; mmenu "change" ?	JUMP',NE DRAW$		; non => DRAW$	INC.W	D2		; D2 <-- rang ligne en ditionDRAW$:	PUSH.W	D2	CLR.W	D2	LOAD.L	A3,#(A6)+OCH1	CALL	DBCHAFCH	; affiche la chane de recherche	INC.W	D2	LOAD.L	A3,#(A6)+OCH2	CALL	DBCHAFCH	; affiche la chane de substitution	POP.W	D2	LOAD.W	D3,#BCHCAR1DRAW1$:	CALL	DBCHLDRAW	; dessine une scroll-list	TEST.L	D4:D3		; fanion enclench ?	JUMP',BS DRAW2$		; oui => DRAW2$	CALL	DBCHLGREY	; grise la scroll-listDRAW2$:	INC.W	D3	COMP.W	D3,#BCHCAR1+4	JUMP,LO DRAW1$LINE$:	LOAD.W	D3,D2	DBOX_	MEDIT	LOAD.L	A3,#(A6)+OCH1	; A3 <-- ^chane de recherche	TEST.W	D2	JUMP',EQ LINE2$	LOAD.L	A3,#(A6)+OCH2	; A3 <-- ^chane de substitutionLINE2$:	LOAD.L	A4,A3LINE4$:	TEST.B	(A4+)	JUMP,NE LINE4$	DEC.L	A4		; A4 <-- ^fin de la chaneLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_CHANGE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F4	JUMP,EQ OK$	COMP.W	D3,#F7	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ ANNULE$	COMP.W	D3,#CR	JUMP,EQ INSERT$	COMP.W	D3,#LF	JUMP,EQ INSERT$	COMP.W	D3,#TAB	JUMP,EQ INSERT$	COMP.W	D3,#CADRATIN	JUMP,EQ INSERT$	COMP.W	D3,#EOP	JUMP,EQ INSERT$	COMP.W	D3,#'*	JUMP,EQ INSERTJ$	COMP.W	D3,#'?	JUMP,EQ INSERTJ$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#DEFINE	JUMP,EQ DEFINE$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEY$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$INSERTJ$:	TSET.L	D4:#BCHJOKERINSERT$:	LOAD.L	A5,#(A6)+OBUDIS	TSET.L	D3:#7	LOAD.B	(A5),D3	CLR.B	(A5)+1	LOAD.W	D3,#MAXCH	LIB	?INSERT	JUMP,NE BIP$	JUMP	LOOP$UNDO$:	LOAD.L	A3,#(A6)+OCH1	LOAD.L	A4,#(A6)+OCHL1UNDO1$:	LOAD.B	(A3+),(A4+)	; OCH1 <-- OCHL1	JUMP,NE UNDO1$	LOAD.L	A3,#(A6)+OCH2	LOAD.L	A4,#(A6)+OCHL2UNDO2$:	LOAD.B	(A3+),(A4+)	; OCH2 <-- OCHL2	JUMP,NE UNDO2$	LOAD.W	(A6)+OCHSL1+OSLCYS,(A6)+OCHCS1	LOAD.W	(A6)+OCHSL2+OSLCYS,(A6)+OCHCS2	LOAD.W	(A6)+OCHSL3+OSLCYS,(A6)+OCHCS3	LOAD.W	(A6)+OCHSL4+OSLCYS,(A6)+OCHCS4	LOAD.L	D4,(A6)+OCHFAN	; D4 <-- fanions originaux	JUMP	DRAW$KEY$:	COMP.B	D3,#BCHCAR1	JUMP',HS KEY2$	CLR.W	D2	LOAD.B	D2,D3		; D2 <-- rang o l'on a cliqu	JUMP	LINE$KEY2$:	TEST.L	D4:D3	JUMP',BS KEY4$	CALL	DBCHLGREY	; grise la scroll-list	JUMP	LOOP$KEY4$:	CALL	DBCHLDRAW	; dessine la scroll-list	JUMP	LOOP$DEFINE$:	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,#2	JUMP,LO LINE$	JUMP	OK$CLIC$:	PUSH.L	D4	LOAD.L	D1,D4	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE CLICBIP$	SUB.W	D4,(A0)+ODFFX	JUMP',LO CLICBIP$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',LO CLICBIP$	SWAP.W	D4	TEST.L	D1:#BCHCAR1	JUMP',BC CLIC2$	LOAD.L	A5,#(A6)+OCHSL1	SCROLL_	LMOVE		; dplace scroll-list ...	JUMP',EQ CLICOK$CLIC2$:	TEST.L	D1:#BCHMOD1	JUMP',BC CLIC3$	LOAD.L	A5,#(A6)+OCHSL2	SCROLL_	LMOVE		; dplace scroll-list ...	JUMP',EQ CLICOK$CLIC3$:	TEST.L	D1:#BCHCAR2	JUMP',BC CLIC4$	LOAD.L	A5,#(A6)+OCHSL3	SCROLL_	LMOVE		; dplace scroll-list ...	JUMP',EQ CLICOK$CLIC4$:	TEST.L	D1:#BCHMOD2	JUMP',BC CLICBIP$	LOAD.L	A5,#(A6)+OCHSL4	SCROLL_	LMOVE		; dplace scroll-list ...	JUMP',EQ CLICOK$CLICBIP$:	POP.L	D4	JUMP	BIP$CLICOK$:	POP.L	D4	JUMP	LOOP$OK$:	PUSH.L	D3	CLR.L	(A6)+OCHM1	CLR.L	(A6)+OCHC1	LOAD.W	D3,#BCHCAR1	CALL	DBCHLGET	; D0/D1 <-- masque/caractre	OR.L	(A6)+OCHM1,D0	OR.L	(A6)+OCHC1,D1	LOAD.W	D3,#BCHMOD1	CALL	DBCHLGET	; D0/D1 <-- masque/caractre	OR.L	(A6)+OCHM1,D0	OR.L	(A6)+OCHC1,D1	CLR.L	(A6)+OCHM2	CLR.L	(A6)+OCHC2	LOAD.W	D3,#BCHCAR2	CALL	DBCHLGET	; D0/D1 <-- masque/caractre	OR.L	(A6)+OCHM2,D0	OR.L	(A6)+OCHC2,D1	LOAD.W	D3,#BCHMOD2	CALL	DBCHLGET	; D0/D1 <-- masque/caractre	OR.L	(A6)+OCHM2,D0	OR.L	(A6)+OCHC2,D1	LOAD.W	(A6)+OCHCS1,(A6)+OCHSL1+OSLCYS	LOAD.W	(A6)+OCHCS2,(A6)+OCHSL2+OSLCYS	LOAD.W	(A6)+OCHCS3,(A6)+OCHSL3+OSLCYS	LOAD.W	(A6)+OCHCS4,(A6)+OCHSL4+OSLCYS	LOAD.L	(A6)+OCHFAN,D4	LOAD.L	A3,#(A6)+OCH1	LOAD.L	A4,#(A6)+OCHL1OK1$:	TCLR.B	(A3):#7	LOAD.B	(A4+),(A3+)	; OCHL1 <-- OCH1	JUMP,NE OK1$	LOAD.L	A3,#(A6)+OCH2	LOAD.L	A4,#(A6)+OCHL2OK2$:	TCLR.B	(A3):#7	LOAD.B	(A4+),(A3+)	; OCHL2 <-- OCH2	JUMP,NE OK2$	POP.L	D3ANNULE$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4..D6,A0..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBCHLDRAW >;----------/; Dessine une scroll-list.; in	D3.B	bit; out	-; mod	D7.WDBCHLDRAW:	PUSHM.L	D2..D4,A3,A5	LOAD.B	D2,D3	LOAD.L	A5,#(A6)+OCHSL1	COMP.B	D2,#BCHCAR1	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OCHSL2	COMP.B	D2,#BCHMOD1	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OCHSL3	COMP.B	D2,#BCHCAR2	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OCHSL410$:	AND.W	D2,#H'FF	TSET.L	D2:#BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#4	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#15	LOAD.W	(A5)+OSLDIM+2,D4	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#5+1	LOAD.W	(A5)+OSLDIM+0,D4	SCROLL_	LDRAW		; dessine la scroll-list vide	LOAD.L	A3,#R16"DBCHLGPT13	CALL	GNBGC		; D4 <-- nb de gencar utiliss	COMP.B	D2,#BCHCAR1	JUMP',EQ 40$	COMP.B	D2,#BCHCAR2	JUMP',EQ 40$	LOAD.L	A3,#R16"DBCHLGPT24	LOAD.W	D4,#4+3+840$:	LOAD.L	(A5)+OSLADL,A3	LOAD.W	(A5)+OSLCYN,D4	SCROLL_	LUPDATE		; dessine le contenu de la scroll-list	POPM.L	D2..D4,A3,A5	RET;-----------\\; DBCHLGPT13 >;-----------/; Donne le texte contenu dans les scroll-list 1 et 3.; in	D3.W	rang; out	A3.L	^texte;	D3.W	0=rien, 1=ligne;	D7.W; mod	D3.L, D7.W, A3.LDBCHLGPT13:	LOAD.L	A3,#(A6)+OBUGC+OGCTIT	MUL.WU	D3,#LGGC	ADD.L	A3,D3		; A3 <-- ^titre du gencar	CLR.W	D3		; D3 <-- pas de ligne	CLR.W	D7		; retour EQ/NE	RET;-----------\\; DBCHLGPT24 >;-----------/; Donne le texte contenu dans les scroll-list 2 et 4.; in	D3.W	rang; out	A3.L	^texte;	D3.W	0=rien, 1=ligne;	D7.W; mod	D3.L, D7.W, A3.LDBCHLGPT24:	LOAD.L	A3,#R16"DBCHTMODE	MUL.WU	D3,#12+2+8	ADD.L	A3,D3		; A3 <-- ^texte	LOAD.W	D3,(A3)+12	; D3 <-- 0/1	CLR.W	D7		; retour EQ/NE	RET;---------\\; DBCHLGET >;---------/; Donne le caractre et le masque d'une scroll-list.; in	D3.B	bit;	D4.L	fanions; out	D0.L	masque;	D1.L	caractre; mod	D0.L, D1.L, D7.WDBCHLGET:	PUSHM.L	D3,A3,A5	CLR.L	D0		; D0 <-- pas de masque	CLR.L	D1		; D1 <-- pas de caractre	TEST.L	D4:D3		; fanion enclench ?	JUMP,BC 90$		; non => 90$	LOAD.L	A5,#(A6)+OCHSL1	COMP.B	D3,#BCHCAR1	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OCHSL2	COMP.B	D3,#BCHMOD1	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OCHSL3	COMP.B	D3,#BCHCAR2	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OCHSL410$:	COMP.B	D3,#BCHMOD1	JUMP',EQ 40$	COMP.B	D3,#BCHMOD2	JUMP',EQ 40$				; caractre =>	LOAD.L	D0,#CCGCMSK	; D0 <-- masque;	CLR.L	D1	LOAD.W	D1,(A5)+OSLCYS	SL.L	D1,#CCGCSHI	; D1 <-- caractre	JUMP'	90$40$:				; mode =>	LOAD.L	A3,#R16"DBCHTMODE	LOAD.W	D3,(A5)+OSLCYS	MUL.WU	D3,#12+2+8	ADD.L	A3,D3		; A3 <-- ^texte	LOAD.L	D0,(A3)+12+2+0	; D0 <-- masque	LOAD.L	D1,(A3)+12+2+4	; D1 <-- caractre90$:	POPM.L	D3,A3,A5	RET;----------\\; DBCHLGREY >;----------/; Grise une scroll-list.; in	D3.B	bit; out	-; mod	D7.WDBCHLGREY:	PUSHM.L	D2..D4,A5	LOAD.L	A5,#(A6)+OCHSL1	COMP.B	D3,#BCHCAR1	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OCHSL2	COMP.B	D3,#BCHMOD1	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OCHSL3	COMP.B	D3,#BCHCAR2	JUMP',EQ 10$	LOAD.L	A5,#(A6)+OCHSL410$:	LOAD.W	D3,(A5)+OSLCYS	; D3 <-- case slectionne	SCROLL_	LINVCASE	; teint la case slectionne	LOAD.L	D3,#H'55AA55AA	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; grise la scroll-list	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A5)+OSLPOS	INC.W	D3	SWAP.W	D3	ADD.W	D3,#LGSCROLL	SWAP.W	D3	LOAD.L	D4,(A5)+OSLDIM	LOAD.W	D4,#LGSCROLL-2	SWAP.W	D4	SUB.W	D4,#LGSCROLL+LGSCROLL-1	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'ascenseur (sans les flches)	POPM.L	D2..D4,A5	RET;---------\\; DBCHAFCH >;---------/; Affiche un texte en dition.; in	D2.W	rang;	A3.L	^chane; out	-; mod	D7.WDBCHAFCH:	PUSHM.L	D2..D4,A0,A3,A4	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A4,#(A6)+OBUDIS10$:	LOAD.B	D3,(A3+)	JUMP',EQ 12$	TCLR.L	D3:#7	LOAD.B	(A4+),D3	; OBUDIS <-- chane sans bits 2^7 !	JUMP	10$12$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUDIS	TSET.L	D2:#BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	; positionne le curseur au dbut	PUSH.W	D3	LOAD.B	D3,#AFTOUT	LIB	?AFCAR	POP.W	D3	SUB.W	D4,D3	AND.L	D4,#H'FFFF	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb de caractres  afficher	LOAD.L	A4,A3	LOAD.W	D3,#-120$:	INC.W	D3		; D3 <-- nb de caractres du nom	TEST.B	(A4+)	JUMP,NE 20$	COMP.W	D3,D4		; place pour tout afficher ?	JUMP',LS 50$		; oui => 50$				; non =>	LIB	?AFTIM		; affiche flche "<-" inverse	.B	AFINV,5,AFDIR,0	.EVEN	DEC.W	D4	SUB.W	D3,D4	ADD.W	A3,D3	LOAD.W	D3,D4	LIB	?STRING		; affiche la fin du nom	LIB	?AFSPACE	JUMP'	80$50$:	LIB	?STRING		; affiche le nom	SUB.W	D4,D3	JUMP',EQ 80$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin80$:	LOAD.B	D3,#AFNORM	LIB	?AFCAR	POPM.L	D2..D4,A0,A3,A4	RET;-----------\\; DBOXFRAPPE >;===========/; Dialogue pour la frappe.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXFRAPPE:	PUSHM.L	D0..D2,D4..D6,A0..A5	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	CLR.L	D4		; D4 <-- fanions	LOAD.L	D3,(A6)+OFRMSK	AND.L	D3,#CCGCMSK	JUMP',EQ OPEN1$	TSET.L	D4:#0	LOAD.L	D3,(A6)+OFRCAR	AND.L	D3,#CCGCMSK	SR.L	D3,#CCGCSHI	LOAD.W	(A6)+OFRSL1+OSLCYS,D3OPEN1$:	LOAD.L	D3,(A6)+OFRMSK	AND.L	D3,#CCSOMSK	JUMP',EQ OPEN2$	TSET.L	D4:#1	LOAD.L	D3,(A6)+OFRCAR	AND.L	D3,#CCSOMSK;	SR.L	D3,#CCSOSHI	SR.L	D3,#8	SR.L	D3,#CCSOSHI-8	LOAD.W	(A6)+OFRSL2+OSLCYS,D3OPEN2$:	LOAD.L	D3,(A6)+OFRMSK	AND.L	D3,#CCEXMSK	JUMP',EQ OPEN3$	TSET.L	D4:#2	LOAD.L	D3,(A6)+OFRCAR	AND.L	D3,#CCEXMSK;	SR.L	D3,#CCEXSHI	SWAP.W	D3	LOAD.W	(A6)+OFRSL3+OSLCYS,D3OPEN3$:	LOAD.L	D3,(A6)+OFRMSK	AND.L	D3,#CCCOMSK	JUMP',EQ OPEN4$	TSET.L	D4:#3	LOAD.L	D3,(A6)+OFRCAR	AND.L	D3,#CCCOMSK;	SR.L	D3,#CCCOSHI	SWAP.W	D3	SR.L	D3,#CCCOSHI-16	LOAD.W	(A6)+OFRSL4+OSLCYS,D3OPEN4$:	LOAD.L	A2,#R16"TDBOX_FRAPPE	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$DRAW$:	CLR.W	D3DRAW1$:	CALL	DBFRLDRAW	; dessine une scroll-list	TEST.L	D4:D3		; fanion enclench ?	JUMP',BS DRAW2$		; oui => DRAW2$	CALL	DBFRLGREY	; grise la scroll-listDRAW2$:	INC.W	D3	COMP.W	D3,#4	JUMP,LO DRAW1$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_FRAPPE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ ANNULE$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEY$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$KEY$:	TEST.L	D4:D3	JUMP',BS KEY4$	CALL	DBFRLGREY	; grise la scroll-list	JUMP	LOOP$KEY4$:	CALL	DBFRLDRAW	; dessine la scroll-list	JUMP	LOOP$CLIC$:	PUSH.L	D4	LOAD.L	D1,D4	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE CLICBIP$	SUB.W	D4,(A0)+ODFFX	JUMP',LO CLICBIP$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',LO CLICBIP$	SWAP.W	D4	TEST.L	D1:#0	JUMP',BC CLIC2$	LOAD.L	A5,#(A6)+OFRSL1	SCROLL_	LMOVE		; dplace scroll-list ...	JUMP',EQ CLICOK$CLIC2$:	TEST.L	D1:#1	JUMP',BC CLIC3$	LOAD.L	A5,#(A6)+OFRSL2	SCROLL_	LMOVE		; dplace scroll-list ...	JUMP',EQ CLICOK$CLIC3$:	TEST.L	D1:#2	JUMP',BC CLIC4$	LOAD.L	A5,#(A6)+OFRSL3	SCROLL_	LMOVE		; dplace scroll-list ...	JUMP',EQ CLICOK$CLIC4$:	TEST.L	D1:#3	JUMP',BC CLICBIP$	LOAD.L	A5,#(A6)+OFRSL4	SCROLL_	LMOVE		; dplace scroll-list ...	JUMP',EQ CLICOK$CLICBIP$:	POP.L	D4	JUMP	BIP$CLICOK$:	POP.L	D4	JUMP	LOOP$OK$:	PUSH.L	D3	CLR.L	(A6)+OFRMSK	CLR.L	(A6)+OFRCAR	CLR.W	D3	CALL	DBFRLGET	; D0/D1 <-- masque/caractre	OR.L	(A6)+OFRMSK,D0	OR.L	(A6)+OFRCAR,D1	INC.W	D3	CALL	DBFRLGET	; D0/D1 <-- masque/caractre	OR.L	(A6)+OFRMSK,D0	OR.L	(A6)+OFRCAR,D1	INC.W	D3	CALL	DBFRLGET	; D0/D1 <-- masque/caractre	OR.L	(A6)+OFRMSK,D0	OR.L	(A6)+OFRCAR,D1	INC.W	D3	CALL	DBFRLGET	; D0/D1 <-- masque/caractre	OR.L	(A6)+OFRMSK,D0	OR.L	(A6)+OFRCAR,D1	POP.L	D3ANNULE$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4..D6,A0..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBFRLDRAW >;----------/; Dessine une scroll-list.; in	D3.B	bit; out	-; mod	D7.WDBFRLDRAW:	PUSHM.L	D1..D4,A3,A5	LOAD.B	D2,D3	LOAD.L	A5,#(A6)+OFRSL1	LOAD.L	A3,#R16"DBFRLGPT1	CALL	GNBGC		; D4 <-- nb de gencar utiliss	LOAD.W	D1,D4	DEC.B	D3	JUMP',NS 10$	LOAD.L	A5,#(A6)+OFRSL2	LOAD.L	A3,#R16"DBFRLGPT2	LOAD.W	D1,#4	DEC.B	D3	JUMP',NS 10$	LOAD.L	A5,#(A6)+OFRSL3	LOAD.L	A3,#R16"DBFRLGPT3	LOAD.W	D1,#3	DEC.B	D3	JUMP',NS 10$	LOAD.L	A5,#(A6)+OFRSL4	LOAD.L	A3,#R16"DBFRLGPT4	LOAD.W	D1,#810$:	AND.W	D2,#H'FF	TSET.L	D2:#BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#4	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#15	LOAD.W	(A5)+OSLDIM+2,D4	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#5+1	LOAD.W	(A5)+OSLDIM+0,D4	SCROLL_	LDRAW		; dessine la scroll-list vide	LOAD.L	(A5)+OSLADL,A3	LOAD.W	(A5)+OSLCYN,D1	SCROLL_	LUPDATE		; dessine le contenu de la scroll-list	POPM.L	D1..D4,A3,A5	RET;----------\\; DBFRLGPT1 >;----------/; Donne le texte contenu dans la scroll-list 1.; in	D3.W	rang; out	A3.L	^texte;	D3.W	0=rien, 1=ligne;	D7.W; mod	D3.L, D7.W, A3.LDBFRLGPT1:	LOAD.L	A3,#(A6)+OBUGC+OGCTIT	MUL.WU	D3,#LGGC	ADD.L	A3,D3		; A3 <-- ^titre du gencar	CLR.W	D3		; D3 <-- pas de ligne	CLR.W	D7		; retour EQ/NE	RET;----------\\; DBFRLGPT2 >;----------/; Donne le texte contenu dans la scroll-list 2.; in	D3.W	rang; out	A3.L	^texte;	D3.W	0=rien, 1=ligne;	D7.W; mod	D3.L, D7.W, A3.LDBFRLGPT2:	LOAD.L	A3,#R16"DBFRTSOUL	MUL.WU	D3,#12+2+8	ADD.L	A3,D3		; A3 <-- ^texte	CLR.W	D3		; D3 <-- pas de ligne	CLR.W	D7		; retour EQ/NE	RET;----------\\; DBFRLGPT3 >;----------/; Donne le texte contenu dans la scroll-list 3.; in	D3.W	rang; out	A3.L	^texte;	D3.W	0=rien, 1=ligne;	D7.W; mod	D3.L, D7.W, A3.LDBFRLGPT3:	LOAD.L	A3,#R16"DBFRTEXP	MUL.WU	D3,#12+2+8	ADD.L	A3,D3		; A3 <-- ^texte	CLR.W	D3		; D3 <-- pas de ligne	CLR.W	D7		; retour EQ/NE	RET;----------\\; DBFRLGPT4 >;----------/; Donne le texte contenu dans la scroll-list 4.; in	D3.W	rang; out	A3.L	^texte;	D3.W	0=rien, 1=ligne;	D7.W; mod	D3.L, D7.W, A3.LDBFRLGPT4:	LOAD.L	A3,#R16"DBFRTCOUL	MUL.WU	D3,#12+2+8	ADD.L	A3,D3		; A3 <-- ^texte	CLR.W	D3		; D3 <-- pas de ligne	CLR.W	D7		; retour EQ/NE	RET;---------\\; DBFRLGET >;---------/; Donne le caractre et le masque d'une scroll-list.; in	D3.B	bit;	D4.L	fanions; out	D0.L	masque;	D1.L	caractre; mod	D0.L, D1.L, D7.WDBFRLGET:	PUSHM.L	D3,A3,A5	CLR.L	D0		; D0 <-- pas de masque	CLR.L	D1		; D1 <-- pas de caractre	TEST.L	D4:D3		; fanion enclench ?	JUMP,BC 90$		; non => 90$	LOAD.L	A5,#(A6)+OFRSL1	DEC.B	D3	JUMP',NS 40$	LOAD.L	A5,#(A6)+OFRSL2	LOAD.L	A3,#R16"DBFRTSOUL	DEC.B	D3	JUMP',NS 10$	LOAD.L	A5,#(A6)+OFRSL3	LOAD.L	A3,#R16"DBFRTEXP	DEC.B	D3	JUMP',NS 10$	LOAD.L	A5,#(A6)+OFRSL4	LOAD.L	A3,#R16"DBFRTCOUL10$:				; mode =>	LOAD.W	D3,(A5)+OSLCYS	MUL.WU	D3,#12+2+8	ADD.L	A3,D3		; A3 <-- ^texte	LOAD.L	D0,(A3)+12+2+0	; D0 <-- masque	LOAD.L	D1,(A3)+12+2+4	; D1 <-- caractre	JUMP'	90$40$:				; caractre =>	LOAD.L	D0,#CCGCMSK	; D0 <-- masque;	CLR.L	D1	LOAD.W	D1,(A5)+OSLCYS	SL.L	D1,#CCGCSHI	; D1 <-- caractre90$:	POPM.L	D3,A3,A5	RET;----------\\; DBFRLGREY >;----------/; Grise une scroll-list.; in	D3.B	bit; out	-; mod	D7.WDBFRLGREY:	PUSHM.L	D2..D4,A5	LOAD.L	A5,#(A6)+OFRSL1	DEC.B	D3	JUMP',NS 10$	LOAD.L	A5,#(A6)+OFRSL2	DEC.B	D3	JUMP',NS 10$	LOAD.L	A5,#(A6)+OFRSL3	DEC.B	D3	JUMP',NS 10$	LOAD.L	A5,#(A6)+OFRSL410$:	LOAD.W	D3,(A5)+OSLCYS	; D3 <-- case slectionne	SCROLL_	LINVCASE	; teint la case slectionne	LOAD.L	D3,#H'55AA55AA	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; grise la scroll-list	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A5)+OSLPOS	INC.W	D3	SWAP.W	D3	ADD.W	D3,#LGSCROLL	SWAP.W	D3	LOAD.L	D4,(A5)+OSLDIM	LOAD.W	D4,#LGSCROLL-2	SWAP.W	D4	SUB.W	D4,#LGSCROLL+LGSCROLL-1	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'ascenseur (sans les flches)	POPM.L	D2..D4,A5	RETDBCHTMODE:DBFRTSOUL:	.ASCIZ	"Normal     "	.W	0	.L	CCSOMSK,(2^CCSOSHI)*0	.ASCIZ	"Soulign   "	.W	0	.L	CCSOMSK,(2^CCSOSHI)*1	.ASCIZ	"Biff      "	.W	0	.L	CCSOMSK,(2^CCSOSHI)*2	.ASCIZ	"Surlign   "	.W	1	.L	CCSOMSK,(2^CCSOSHI)*3DBFRTEXP:	.ASCIZ	"Normal     "	.W	0	.L	CCEXMSK,(2^CCEXSHI)*0	.ASCIZ	"Exposant   "	.W	0	.L	CCEXMSK,(2^CCEXSHI)*1	.ASCIZ	"Indice     "	.W	1	.L	CCEXMSK,(2^CCEXSHI)*2DBFRTCOUL:	.ASCIZ	"Noir       "	.W	0	.L	CCCOMSK,(2^CCCOSHI)*0	.ASCIZ	"Rouge      "	.W	0	.L	CCCOMSK,(2^CCCOSHI)*1	.ASCIZ	"Vert       "	.W	0	.L	CCCOMSK,(2^CCCOSHI)*2	.ASCIZ	"Bleu       "	.W	0	.L	CCCOMSK,(2^CCCOSHI)*3	.ASCIZ	"Violet     "	.W	0	.L	CCCOMSK,(2^CCCOSHI)*4	.ASCIZ	"Jaune      "	.W	0	.L	CCCOMSK,(2^CCCOSHI)*5	.ASCIZ	"Brun       "	.W	0	.L	CCCOMSK,(2^CCCOSHI)*6	.ASCIZ	"Blanc      "	.W	0	.L	CCCOMSK,(2^CCCOSHI)*7;--------------\\; DBOXOCCURENCE >;==============/; Demande comment compter.; in	D4.L	nombre d'occurences; out	D7.W	erreur; mod	D7.WDBOXOCCURENCE:	PUSHM.L	D1..D5,A1..A4	LOAD.L	D1,D4	LOAD.L	A2,#R16"TDBOX_OCCURENCE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,D1	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDCM!2^BAFDSP	LIB	?AFDEC20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OCCURENCE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXCHERCHE >;============/; Demande comment chercher.; in	-; out	D3.W	touche (F1/F13);	D7.W	erreur; mod	D3.L, D7.WDBOXCHERCHE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_CHERCHE	LOAD.W	D2,#2^BDBSAV!2^BDBPOS	LOAD.W	D3,#6	CALL	DBCSPOS		; D3 <-- position	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_CHERCHE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP',EQ 80$	COMP.W	D3,#F13	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------------\\; DBOXSUBSTITUE >;==============/; Demande comment chercher.; in	-; out	D3.W	touche (F1/F4/F7/F10/F13);	D7.W	erreur; mod	D3.L, D7.WDBOXSUBSTITUE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_SUBSTITUE	LOAD.W	D2,#2^BDBSAV!2^BDBPOS	LOAD.W	D3,#10	CALL	DBCSPOS		; D3 <-- position	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_SUBSTITUE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP',EQ 80$	COMP.W	D3,#F4	JUMP',EQ 80$	COMP.W	D3,#F7	JUMP',EQ 80$	COMP.W	D3,#F10	JUMP',EQ 80$	COMP.W	D3,#F13	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBCSPOS >;--------/; Calcule la position du centre de la dbox en fonction de la; position du curseur.; in	A5.L	^description zone;	D3.W	nombre de lignes de la dbox; out	D3.L	position pour centre dbox; mod	D3.L, D7.WDBCSPOS:	PUSHM.L	D2,D4,A0	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.W	D2,D3	LOAD.L	D3,(A5)+ODZCUP	; D3 <-- position du curseur	ADD.W	D3,(A5)+ODZWPO+2	SWAP.W	D3	ADD.W	D3,(A5)+ODZWPO+0	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	MUL.WU	D4,D2		; D4 <-- hauteur suppose de la dbox	COMP.W	D3,D4		; possible de mettre dbox au-dessus ?	JUMP',HS 20$		; oui => 20$	ADD.W	D3,D4	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y20$:	SR.W	D4,#1	SUB.W	D3,D4	SWAP.W	D3	POPM.L	D2,D4,A0	RET;---------\\; DBOXZONE >;=========/; Dialogue pour les zones.; in	D2.W	zone  slectionner; out	D2.W	zone slectionne;	D3.W	dernire touche (F1/F4/F7/F10/F13);	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXZONE:	PUSHM.L	D0,D1,D4..D6,A0..A5	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A5,#(A6)+OZOSL	; A5 <-- ^variables de la scroll-list	LOAD.W	(A5)+OSLCYS,D2	LOAD.L	A2,#R16"TDBOX_ZONE	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#65	LOAD.W	(A5)+OSLDIM+2,D4	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#13+1	LOAD.W	(A5)+OSLDIM+0,D4	LOAD.W	(A5)+OSLASV+OSCINC,#13	SET.B	(A5)+OSLASV+OSCPAGE	SCROLL_	LDRAW		; dessine la scroll-list vide	LOAD.L	A3,#R16"DBZOGET	LOAD.L	(A5)+OSLADA,A3	LOAD.W	(A5)+OSLCYN,#MAXZONE	SCROLL_	LUPDATE		; dessine le contenu de la scroll-listGREY$:	LOAD.L	A4,A5	LOAD.W	D2,(A5)+OSLCYS	; D2 <-- zone slectionne	CALL	ZCTRL		; A5 <-- ^description zone	JUMP',EQ GREY0$	LOAD.L	A5,#0GREY0$:	EX.L	A4,A5	LOAD.W	D2,#2!2^BDBGCLABEL!2^BDBGCFULL	LOAD.L	D4,A4	JUMP',EQ GREY2$	TEST.B	(A4)+ODZMAJ:#BMAJIO	JUMP',BC GREY2$	LOAD.W	D2,#2!2^BDBGCLABEL!2^BDBGCGREYGREY2$:	DBOX_	GETCO		; grise/dgrise (PREND)	LOAD.W	D2,#3!2^BDBGCLABEL!2^BDBGCGREY	LOAD.L	D4,A4	JUMP',EQ GREY3$	TEST.B	(A4)+ODZMAJ:#BMAJIO	JUMP',BC GREY3$	LOAD.W	D2,#3!2^BDBGCLABEL!2^BDBGCFULLGREY3$:	DBOX_	GETCO		; grise/dgrise (SAUVE)	LOAD.W	D2,#4!2^BDBGCLABEL!2^BDBGCGREY	LOAD.L	D4,A4	JUMP',EQ GREY4$	TEST.L	(A4)+ODZNBC	JUMP',EQ GREY4$	LOAD.W	D2,#4!2^BDBGCLABEL!2^BDBGCFULLGREY4$:	DBOX_	GETCO		; grise/dgrise (EFFACE)LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_ZONE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F4	JUMP,EQ OK$	COMP.W	D3,#F7	JUMP,EQ OK$	COMP.W	D3,#F10	JUMP,EQ OK$	COMP.W	D3,#F13	JUMP,EQ ANNULE$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	SUB.W	D4,(A0)+ODFFX	JUMP,LO BIP$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP,LO BIP$	SWAP.W	D4	SCROLL_	LMOVE		; dplace scroll-list ...	JUMP,NE BIP$	JUMP	GREY$OK$:	LOAD.W	D2,(A5)+OSLCYS	; D2 <-- zone slectionneANNULE$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0,D1,D4..D6,A0..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBZOGET >;--------/; Affiche le contenu d'une ligne de la scroll-list.; in	D3.W	rang de la case (0..OSLCYN-1);	D4.W	nb de caractres;	D5.W	rang du premier caractre  afficher; out	D3.W	zro; mod	D3.L, D7.WDBZOGET:	PUSHM.L	D1,D2,D4,A0,A3..A5	LIB	?FLUSH	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^buffer	CLR.L	D1	LOAD.W	D1,D4		; D1 <-- nb de caractres	PUSHM.L	D3,D4	CLR.L	D4	LOAD.W	D4,D3	LOAD.W	D3,#3	CLR.W	D2	LIB	?PUTDEC		; OBUDIS <-- numro de la zone	LOAD.B	(A4+),#':	LOAD.B	D2,#SPACE	LOAD.B	(A4+),D2	LOAD.W	D3,D4	SUB.W	D3,#10	JUMP',LO 20$	COMP.W	D3,#26	JUMP',HS 20$	ADD.W	D3,#'A	LOAD.B	(A4+),#'(	LOAD.B	(A4+),D3	LOAD.B	(A4+),#')	JUMP'	22$20$:	LOAD.B	(A4+),D2	LOAD.B	(A4+),D2	LOAD.B	(A4+),D222$:	LOAD.B	(A4+),D2	LOAD.W	D2,D4	CALL	ZCTRL		; A5 <-- ^descripteur de la zone	JUMP,NE 60$	LOAD.L	D4,(A5)+ODZNBC	JUMP,EQ 60$	LOAD.W	D3,#8	CLR.W	D2	LIB	?PUTDEC		; OBUDIS <-- nombre de caractres	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCICF	LOAD.B	(A4+),#GCICS	LOAD.B	(A4+),#GCICT	LOAD.W	D4,(A0)+ODFC2Y	SUB.W	D4,#GCICB	LOAD.B	(A4+),#TYPORY	LOAD.B	(A4+),D4	LOAD.B	(A4+),#ICOZONF	TEST.B	(A5)+ODZMAJ:#BMAJIO	JUMP',BS 30$	LOAD.B	(A4)-1,#ICOZONG30$:	NEG.W	D4	LOAD.B	(A4+),#TYPORY	LOAD.B	(A4+),D4	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCTXF	LOAD.B	(A4+),#GCTXS	LOAD.B	(A4+),#GCTXT	ADD.W	D1,#4+2-3+2+4	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	LOAD.L	A3,#(A5)+ODZNAM	; A3 <-- ^nom du fichier	TEST.B	(A3)		; nom existe ?	JUMP',EQ 60$		; non => 60$	LOAD.B	(A4+),#'"	LOAD.W	D2,#2^BAFXMI	LOAD.W	D3,#35	LIB	?PUTXFILE	; OBUDIS <-- nom du fichier	LOAD.B	(A4+),#'"60$:	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	D3,D1	ADD.L	D1,A3	SUB.L	D1,A462$:	DEC.L	D1	JUMP',NS 64$	LOAD.B	(A4+),#SPACE	JUMP	62$64$:	LOAD.W	D1,D3	POPM.L	D3,D4		; D3 <-- rang et D4 <-- nb de caractres	COMP.W	D3,#10-1	JUMP',EQ 70$	COMP.W	D3,#10+26-1	JUMP',EQ 70$	LOAD.W	D3,D1	LIB	?STRING		; affiche la ligne	JUMP'	80$70$:	LIB	?GETCURS	EX.L	D3,D1	LIB	?STRING		; affiche la ligne	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D3,D1	SWAP.W	D3	ADD.W	D3,(A0)+ODFC2Y	DEC.W	D3	SWAP.W	D3	MUL.WU	D4,(A0)+ODFCX	LOAD.W	D2,#SETDOT!TTTDOT	LIB	?DRSEG		; ligne pointille en bas80$:	CLR.W	D3		; D3 <-- rend toujours zro !	POPM.L	D1,D2,D4,A0,A3..A5	RET;---------\\; DBOXSAVE >;=========/; Sauve le texte d'une zone selon le choix de l'utilisateur.; in	A5.L	^description zone;	D0.W	mode (0=quitte, 1=nouveau texte); out	D7.W	erreur (reste dans edit); mod	D7.WDBOXSAVE:	PUSHM.L	D1..D4,A2..A5	TEST.B	(A5)+ODZMAJ:#BMAJIO ; texte  jour ?	JUMP,BC	80$		; oui => 80$ (quitte, snif)				; non =>	TEST.L	(A5)+ODZNBC	; buffer vide ?	JUMP,EQ 80$		; oui => 80$	LOAD.L	D4,(A6)+OFANIO	; D4 <-- fanions	LOAD.L	D3,#2^BDBIOOBJ	LOAD.W	D3,(A5)+ODZNUM	TEST.B	D0	JUMP',NE 25$	TSET.L	D3:#BDBIOQUIT	; D3 <-- texte "avant de quitter"25$:	PUSH.L	A5	LOAD.L	A5,#(A5)+ODZNAM	; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_BOAS	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_MAJ	; D1 <-- code du sous-appel	CALL	DBOXPREF	; dbox: attend la rponse ...	POP.L	A5	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 85$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$	LOAD.L	(A6)+OFANIO,D4	TSET.B	(A6)+OFANIO+0:#BDBAUTO-24	CALL	DBOXCREATE	; cre le fichier ...	TCLR.B	(A6)+OFANIO+0:#BDBAUTO-24	TEST.W	D7	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 85$	LOAD.L	A3,#(A5)+ODZNAM	; A3 <-- ^nom du fichier	CALL	IOWRITE		; sauve tout sur disque	JUMP',NE 90$	TCLR.B	(A5)+ODZMAJ:#BMAJIO	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	CINFOFIL	; affiche le nom du fichier80$:	CLR.W	D7		; D7 <-- quitte EDIT	JUMP'	90$85$:	LOAD.W	D7,#ERKSTO	; D7 <-- reste dans EDIT90$:	POPM.L	D1..D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCREATE >;===========/; Cre un fichier quelconque.; in	A5.L	^description zone; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCREATE:	PUSHM.L	D0..D2,D4,D5,A2..A4	TCLR.B	(A6)+OFANIO+0:#BDBNMAJ-24 ; touche (MET A JOUR) normale	TEST.B	(A5)+ODZMAJ:#BMAJIO ; texte  jour ?	JUMP',BS 10$		; non => 10$	TSET.B	(A6)+OFANIO+0:#BDBNMAJ-24 ; touche (MET A JOUR) grise10$:	CALL	DBOXSAUVE	; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F0	JUMP,EQ	90$	LOAD.W	D1,D3		; D1 <-- F1/F4	LOAD.L	D2,#DEFATT	; D2 <-- attributs par dfaut20$:	LOAD.L	A3,#(A5)+ODZNAM	; A3 <-- ^nom du fichier	LOAD.L	D3,D2		; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP,EQ	70$		; ok => 70$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	TEST.B	(A6)+OFANIO+0:#BDBAUTO-24 ; mode automatique ?	JUMP',BS 45$		; oui => 45$	COMP.W	D1,#F4		; touche (MET A JOUR) ?	JUMP',EQ 45$		; oui => 45$	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	JUMP',NE 90$	CALL	DBOXCLOSE1	; remet les soft-keys	COMP.W	D3,#'O	JUMP,NE 10$45$:	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D0,#FOS?ARGS	CALL	ERCALL		; demande les arguments du fichier	JUMP',NE 90$	LOAD.L	D2,(A4)+OBAATT	; D2 <-- arguments du fichier	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP',NE 90$	JUMP	20$70$:	LOAD.W	D3,#F1		; D3 <-- (RETURN)	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2,D4,D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXZCREATE >;============/; Cre un fichier quelconque.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXZCREATE:	PUSHM.L	D0..D2,D4,D5,A2..A410$:	CALL	DBOXEXTRAIT	; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F0	JUMP,EQ	90$	LOAD.L	D2,#DEFATT	; D2 <-- attributs par dfaut20$:	LOAD.L	A3,#(A6)+OBUTEMP ; A3 <-- ^nom du fichier	LOAD.L	D3,D2		; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP,EQ	70$		; ok => 70$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	JUMP',NE 90$	CALL	DBOXCLOSE1	; remet les soft-keys	COMP.W	D3,#'O	JUMP,NE 10$	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D0,#FOS?ARGS	CALL	ERCALL		; demande les arguments du fichier	JUMP',NE 90$	LOAD.L	D2,(A4)+OBAATT	; D2 <-- arguments du fichier	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP',NE 90$	JUMP	20$70$:	LOAD.W	D3,#F1		; D3 <-- (RETURN)	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2,D4,D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXPREND >;==========/; Edite un nom de fichier en entre.; in	A5.L	^description zone; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPREND:	PUSHM.L	D1,D2,D4,A2..A510$:	LOAD.L	D4,(A6)+OFANIO	; D4 <-- fanions	PUSH.L	A5	LOAD.L	A5,#(A5)+ODZNAM	; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.L	D3,#LBUFILE	CALL	DBOXEXT		; A2 <-- ^objets, A4 <-- ^extensions	CALL	DBOXPREF	; dbox: attend la rponse ...	POPM.L	A5	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	LOAD.L	(A6)+OFANIO,D4	CALL	DBPRNAME	; nom utilis dans une autre zone ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A3,#(A5)+ODZNAM	; A3 <-- ^nom du fichier	CALL	DBOXEXNAME	; demande quoi faire ...90$:	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBPRNAME >;---------/; Cherche si un nom est dj utilis dans une autre zone.; in	A5.L	^description zone; out	D4.W	numro o trouv (si erreur);	D7.W	erreur si rencontr; mod	D7.W, D4.LDBPRNAME:	PUSHM.L	D2,A2..A5	LOAD.L	A3,#(A5)+ODZNAM	; A3 <-- ^nom cherch	CLR.W	D220$:	CALL	ZCTRL		; A5 <-- ^description zone	JUMP',NE 60$	LOAD.L	A4,#(A5)+ODZNAM	COMP.L	A3,A4		; est-on dans cette zone ?	JUMP',EQ 60$		; oui => 60$	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; nom trouv ?	JUMP',NS 60$	LOAD.W	D4,(A5)+ODZNUM	; D4 <-- numro zone o trouv	LOAD.W	D7,#EREOUTB	; D7 <-- nom trouv !	JUMP'	90$60$:	INC.W	D2		; D2 <-- zone suivante	COMP.W	D2,#MAXZONE	JUMP,LO 20$	CLR.W	D7		; D7 <-- ok, pas trouv90$:	POPM.L	D2,A2..A5	TEST.W	D7		; retour EQ/NE	RETTERM$:	.B	0,-1	.EVEN;-----------\\; DBOXAJOUTE >;===========/; Edite un nom de fichier en entre.; in	A5.L	^description zone; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXAJOUTE:	PUSHM.L	D1,D2,D4,A2..A5	LOAD.L	D4,(A6)+OFANIO	; D4 <-- fanions	LOAD.L	A5,#(A6)+OBUTEMP ; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.L	D3,#LBUFILE	CALL	DBOXEXT		; A2 <-- ^objets, A4 <-- ^extensions	CALL	DBOXPREF	; dbox: attend la rponse ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	LOAD.L	(A6)+OFANIO,D490$:	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXSAUVE >;==========/; Edite un nom de fichier en sortie.; in	A5.L	^description zone; out	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXSAUVE:	PUSHM.L	D1,D2,D4,A2..A5	LOAD.L	D4,(A6)+OFANIO	; D4 <-- fanions	LOAD.L	A5,#(A5)+ODZNAM	; A5 <-- ^nom du fichier	TEST.B	(A5)		; nom existe ?	JUMP',EQ 20$		; non => 20$				; oui =>	CLR.W	D7	LOAD.W	D3,#F1		; D3 <-- comme si (SAUVE)	TEST.L	D4:#BDBAUTO	; mode automatique ?	JUMP',BS 90$		; oui => 90$20$:	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	LOAD.L	D3,#LBUFILE	TEST.L	D4:#BDBNMAJ	JUMP',BC 40$	TSET.L	D3:#BDBIONMAJ	; D3 <-- touche (MET A JOUR) grise40$:	CALL	DBOXEXT		; A2 <-- ^objets, A4 <-- ^extensions	CALL	DBOXPREF	; dbox: attend la rponse ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',EQ 80$	COMP.W	D3,#F4	JUMP',NE 90$80$:	LOAD.L	(A6)+OFANIO,D490$:	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXEXTRAIT >;============/; Edite un nom de fichier en entre.; in	A5.L	^description zone; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXEXTRAIT:	PUSHM.L	D1,D2,D4,A2..A5	LOAD.L	D4,(A6)+OFANIO	; D4 <-- fanions	LOAD.L	A5,#(A6)+OBUTEMP ; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_EXTRAIT ; D1 <-- code du sous-appel	LOAD.L	D3,#LBUFILE	CALL	DBOXEXT		; A2 <-- ^objets, A4 <-- ^extensions	CALL	DBOXPREF	; dbox: attend la rponse ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	LOAD.L	(A6)+OFANIO,D490$:	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXERROR >;==========/; Affiche une erreur.; in	D7.W	erreur; out	D7.W	erreur; mod	D7.WDBOXERROR:	PUSHM.L	D2..D4,A3	LOAD.W	D4,D7	JUMP',EQ 20$	COMP.W	D7,#ERKNO	JUMP',EQ 20$	COMP.W	D7,#ERKSTO	JUMP',NE 30$20$:	CLR.W	D7		; D7 <-- ok	JUMP'	90$30$:	CALL	DBOXOPEN1	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	CALL	DBERTEXT	; A3 <-- ^message interne  PLUME	JUMP',EQ 50$	LOAD.W	D7,D4		; D7 <-- code de l'erreur	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur "externe" ...	JUMP'	80$50$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur "interne" ...80$:	CALL	DBOXCLOSE1	; remet les soft-keys90$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBERTEXT >;---------/; Donne le texte d'une erreur interne  PLUME.; in	D4.W	erreur; out	A3.L	^message d'erreur;	D7.W	erreur; mod	D7.W, A3.LDBERTEXT:	PUSH.L	D3	LOAD.W	D7,#EREOUTB	; D7 <-- pas trouv	LOAD.W	D3,D4	SR.W	D3,#8	COMP.B	D3,#ERPLUME/H'100 ; erreur interne  PLUME ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A3,#R16"TABLE$20$:	TEST.W	(A3+)		; fin de la table ?	JUMP',EQ 80$		; oui => 80$	COMP.W	D4,(A3)-2	; erreur trouve ?	JUMP',EQ 80$		; oui => 80$30$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE	30$	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- saute comme .EVEN	LOAD.L	A3,D3	JUMP	20$80$:	CLR.W	D7		; D7 <-- trouv90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	ERECODE	.ASCII	"Cette zone contient trop<CR>"	.ASCIZ	"de combinaisons diffrentes !"	.EVEN	.W	ERELINE	.ASCIZ	"Trop de lignes  afficher !"	.EVEN	.W	EREZFUL	.ASCIZ	"Toutes les zones sont occupes !"	.EVEN	.W	ERENOTF	.ASCII	"Pas trouv dans la<CR>"	.ASCIZ	"direction choisie !"	.EVEN	.W	EREMACR	.ASCIZ	"Erreur dans la macro !"	.EVEN	.W	EREBBOA	.ASCII	/Une ou plusieurs commandes<CR>/	.ASCIZ	/"boa" ont t filtres !/	.EVEN	.W	0	.ASCIZ	"Erreur avec le logiciel PLUME !"	.EVEN	.END