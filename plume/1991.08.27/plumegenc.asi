	.SBTTL	PLUMEGENC;-----------\\; DBOXGENCAR >;===========/; Dialogue pour le choix des gencars.; in	-; out	D7.W	erreur; mod	D7.WDBOXGENCAR:	PUSHM.L	D0..D5,A0..A5	CLR.W	D0		; D0 <-- nb de modifications10$:	LOAD.L	D4,(A6)+OFAGC	; D4 <-- fanions	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A5,#(A6)+OGCLIST; A5 <-- ^liste des gencars sur disque	LOAD.W	D5,#MAXGENC*3	; D5 <-- lg pour la liste	LOAD.L	D1,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	DGENC_	MODIF		; modifie un/qq gencar(s) ...	JUMP',NE 90$	LOAD.L	(A6)+OFAGC,D4	; mm. derniers fanions utiliss	COMP.W	D3,#F1	JUMP',EQ 30$	COMP.W	D3,#F4	JUMP',EQ 50$	JUMP'	80$30$:				; MODIFIE =>	INC.W	D0		; D0 <-- une modification de plus	JUMP	10$50$:				; SUPPRIME =>	CALL	SUPGC		; supprime le gencar PARTOUT	INC.W	D0		; D0 <-- une modification de plus	JUMP	10$80$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D790$:	POPM.L	D0..D5,A0..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; SUPGC   >;--------/; Supprime un gencar partout o est utilis (dans toutes les zones).; in	A4.L	^dans OBUGC sur le gencar  supprimer; out	-; mod	D7.WSUPGC:	PUSHM.L	D0..D5,A3,A5	CALL	DBOXOPWAIT	; met la dbox d'attente	LOAD.L	A3,#(A6)+OBUGC	LOAD.L	D1,A4	SUB.L	D1,A3	DIV.WU	D1,#LGGC	; D1 <-- rang du gencar	SL.L	D1,#CCGCSHI	AND.L	D1,#CCGCMSK	; D1 <-- caractre  chercher	CLR.W	D0		; D0 <-- numro de la premire zone20$:	LOAD.W	D2,D0		; D2 <-- numro de la zone	CALL	ZCTRL		; A5 <-- ^description zone	JUMP,NE 60$	CALL	BPSAUVE		; D4 <-- position du curseur	PUSH.W	D4	CLR.L	D4	CALL	BQPOSITIONNE	; va (rapidement) au dbut30$:	LOAD.L	D3,D1		; D3 <-- gencar cherch	LOAD.L	D2,#CCGCMSK	; D2 <-- masque	CLR.W	D5		; D5 <-- flags	CALL	BACHERCHE	; cherche si utilis ?	JUMP',NE 50$	CALL	BDONNE		; D3 <-- caractre actuel	JUMP',NE 50$	AND.L	D3,#-1-CCGCMSK	; D3 <-- met le gencar "fond"	CALL	BREMPLACE	JUMP,EQ 30$50$:	POP.W	D4	CALL	BPPREND		; remet le curseur o il tait60$:	INC.W	D0		; D0 <-- zone suivante	COMP.W	D0,#MAXZONE	JUMP,LO 20$	TEST.B	(A4)+OGCFLG:#BGCPROT ; gencar indestructible ?	JUMP',BS 90$		; oui => 90$				; non =>	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	KILL		; libre le gencar	JUMP',NE 90$	TCLR.B	(A4)+OGCFLG:#BGCUSE ; signal gencar libre90$:	CALL	DBOXCLWAIT	; enlve la dbox d'attente	POPM.L	D0..D5,A3,A5	RET;--------\\; PTBGC   >;========/; Cherche le gencar d'un caractre quelconque.; in	D3.L	caractre complet; out	A4.L	^dans OBUGC; mod	A4.LPTBGC:	PUSH.L	D3	LOAD.L	A4,#(A6)+OBUGC	AND.W	D3,#CCGCMSK	SR.W	D3,#CCGCSHI	; D3 <-- numro du gencar	MUL.WU	D3,#LGGC	ADD.L	A4,D3		; A4 <-- ^gencar dans obugc	POP.L	D3	RET;--------\\; LODGC   >;========/; Si ncessaire, charge un nouveau gnrateur de caractre.; Il est interdit de librer le gencar, car il peut tre utilis; dans un buffer de texte !; in	A4.L	^lment dans OBUGC; out	D7.W	erreur; mod	D7.WLODGC:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	NEW		; charge nouveau gencar	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GNBGC   >;========/; Donne le nombre de gencar utiliss.; in	-; out	D4.W	nombre de gencar; mod	D4.L, D7.WGNBGC:	PUSH.L	A4	LOAD.L	A4,#(A6)+OBUGC+(LGGC*MAXGC)	LOAD.W	D4,#MAXGC20$:	LOAD.L	A4,#(A4)-LGGC	; A4 <-- ^prcdent	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP',BS 90$	DEC.W	D4	JUMP,NE 20$90$:	POP.L	A4	RET	.END