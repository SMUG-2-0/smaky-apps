	.SBTTL	PLUMEOPER;---------\\; OPERMUTE >;=========/; Permute tous les caractres d'une zone.; in	A5.L	^description zone;	D4.L	position dbut;	D5.L	nombre de caractres;	D6.W	mode (0=caractres, 1=mots, 2=lignes); out	D7.W	erreur; mod	D7.WOPERMUTE:	PUSHM.L	D0..D6,A4,A5	TEST.L	D5		; D5 <-- qq chose  faire ?	JUMP,EQ 80$		; non => 80$	CALL	OPERMZONE	; D5 <-- nb de caractres	TEST.L	D5	JUMP,EQ 80$	LOAD.L	A4,#(A6)+OZONEU	; A4 <-- ^descripteur zone UNDO	EX.L	A5,A4	CALL	BINIT		; vide toute la zone UNDO	EX.L	A5,A4; Dtruit tout en reculant (en fait, les caractres sont; insrs la zone UNDO).	LOAD.L	D0,D530$:	CALL	OPERMUNIT	; D2 <-- nombre de caractres	LOAD.L	D1,D234$:	CALL	BAVANCE	JUMP',NE 50$	CALL	BDETRUIT	; dtruit le mot/ligne de gauche  droite	JUMP',NE 50$	EX.L	A5,A4	CALL	BINSERE		; insre dans la zone UNDO	EX.L	A5,A4	JUMP',NE 50$	DEC.L	D1	JUMP,NE 34$	SUB.L	D0,D2	JUMP,NE 30$; Remet tous les caractres dans la zone d'o ils ont ts enlevs.50$:	EX.L	A5,A4	CLR.L	D4	CALL	BQPOSITIONNE	; va (rapidement) au dbut de la zone UNDO	EX.L	A5,A452$:	EX.L	A5,A4	CALL	BAVANCE	EX.L	A5,A4	JUMP',NE 80$	EX.L	A5,A4	CALL	BDETRUIT	; enlve de la zone UNDO	EX.L	A5,A4	CALL	BINSERE		; puis insre dans la zone principale	JUMP',NE 90$	JUMP	52$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D6,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; OPERMZONE >;----------/; Positionne le curseur  la fin de la zone, et rduit; ventuellement le nombre de caractres.; in	D4.L	position dbut;	D5.L	nombre de caractres;	D6.W	mode (0=caractres, 1=mots, 2=lignes); out	D5.L	nombre de caractres; mod	D5.L, D7.WOPERMZONE:	PUSHM.L	D3,D4	TEST.W	D6	JUMP,EQ 80$	CALL	BPOSITIONNE	; positionne au dbut20$:	CALL	BAVANCE	JUMP',NE 30$	CALL	OPERMCAR	; sparateur ?	JUMP',NE 30$		; non => 30$	INC.L	D4		; D4 <-- avance le dbut	DEC.L	D5		; D5 <-- diminue le nb de caractres	JUMP',EQ 80$	JUMP	20$30$:	PUSH.L	D4	ADD.L	D4,D5	CALL	BPOSITIONNE	; positionne  la fin	POP.L	D440$:	CALL	BRECULE	JUMP',NE 80$	CALL	OPERMCAR	; sparateur ?	JUMP',NE 80$		; non => 80$	DEC.L	D5		; D5 <-- diminue le nb de caractres	JUMP',EQ 80$	JUMP	40$80$:	ADD.L	D4,D5	CALL	BPOSITIONNE	; positionne  la fin	POPM.L	D3,D4	RET;----------\\; OPERMUNIT >;----------/; Recule d'une unit (caractre, mot ou ligne).; in	D0.L	nombre max de caractres reculables;	D6.W	mode (0=caractres, 1=mots, 2=lignes); out	D2.L	nombre de caractres reculs; mod	D2.L, D7.WOPERMUNIT:	PUSH.L	D3	CLR.L	D2	TEST.W	D6	JUMP,EQ 60$	CALL	BRECULE	JUMP,NE 90$	CALL	OPERMCAR	; sparateur ?	JUMP',EQ 40$20$:	COMP.L	D2,D0	JUMP',EQ 90$	INC.L	D2	CALL	BRECULE	JUMP',NE 90$	CALL	OPERMCAR	; sparateur ?	JUMP,NE 20$	CALL	BAVANCE	JUMP'	90$40$:	COMP.L	D2,D0	JUMP',EQ 90$	INC.L	D2	CALL	BRECULE	JUMP',NE 90$	CALL	OPERMCAR	; sparateur ?	JUMP,EQ 40$	CALL	BAVANCE	JUMP'	90$60$:	CALL	BRECULE	JUMP',NE 90$	INC.L	D290$:	POP.L	D3	RET;---------\\; OPERMCAR >;---------/; Teste si un caractre est un terminateur.; in	D3.B	caractre;	D6.W	mode (0=caractres, 1=mots, 2=lignes); out	EQ	terminateur;	NE	autre chose; mod	FOPERMCAR:	PUSHM.L	A3	LOAD.L	A3,#R16"TWORD	; A3 <-- ^terminateurs de mots	COMP.W	D6,#1	JUMP',EQ 10$	LOAD.L	A3,#R16"TLINE	; A3 <-- ^terminateurs de lignes10$:	CALL	ETESTCAR	POPM.L	A3	RET	.END