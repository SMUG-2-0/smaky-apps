	.SBTTL	PLUMEZONE;--------\\; ZCOPY   >;========/; Ouvre une zone secondaire si elle n'existe pas dj.; in	A5.L	^description zone; out	D7.W	erreur; mod	D7.WZCOPY:	PUSHM.L	D1,D2,A5	CLR.W	D7		; D7 <-- ok	TEST.L	(A6)+OZONE2+ODZFBT ; zone secondaire existe ?	JUMP',NE 90$		; oui => 90$				; non =>	LOAD.W	D1,(A5)+ODZNUM	; D1 <-- numro zone principale	LOAD.W	D2,D1		; D2 <-- numro zone secondaire20$:	INC.W	D2	COMP.W	D2,#MAXZONE	JUMP',LO 22$	SUB.W	D2,#MAXZONE22$:	LOAD.W	D7,#EREZFUL	; D7 <-- toutes les zones sont occupes	COMP.W	D2,D1	JUMP',EQ 90$	CALL	ZCTRL		; A5 <-- ^zone secondaire	JUMP',NE 50$		; n'existe pas => prend celle-l	TEST.L	(A5)+ODZNBC	; contient qq chose ?	JUMP,NE 20$		; oui => 20$50$:	EX.L	D1,D2		; D2 <-- principale, D2 <-- secondaire	CALL	ZDEUX		; ouvre deux zones90$:	POPM.L	D1,D2,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZUN     >;========/; Initialise une zone unique.; in	D2.W	numro zone principale; out	D7.W	erreur; mod	D7.WZUN:	PUSHM.L	D3,D4,A5	LOAD.L	A5,#(A6)+OZONE1	CALL	ZAFFCLOSE	; ferme la zone principale	LOAD.L	A5,#(A6)+OZONE2	CALL	ZAFFCLOSE	; ferme la zone secondaire	LOAD.L	D3,(A6)+OWDPOS	LOAD.L	D4,(A6)+OWDDIM	LOAD.L	A5,#(A6)+OZONE1	CALL	ZAFFOPEN	; ouvre la zone principale	JUMP',NE 90$	CALL	CDESSINE1	; dessine les informations	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZDEUX   >;========/; Initialise deux zone, une principale et une secondaire.; in	D2.W	numro zone principale;	D1.W	numro zone secondaire; out	D7.W	erreur; mod	D7.WZDEUX:	COMP.W	D2,D1		; deux fois la mme zone ?	JUMP,EQ ZUN		; oui => ZUN	PUSHM.L	D2..D5,A5	CLR.W	D7		; D7 <-- ok	TEST.L	(A6)+OZONE2+ODZFBT ; zone secondaire existe ?	JUMP',EQ 20$		; non => 20$				; oui =>	COMP.W	D2,(A6)+OZONE1+ODZNUM	JUMP',NE 20$	COMP.W	D1,(A6)+OZONE2+ODZNUM	JUMP,EQ 90$20$:	LOAD.L	A5,#(A6)+OZONE1	CALL	ZAFFCLOSE	; ferme la zone principale	LOAD.L	A5,#(A6)+OZONE2	CALL	ZAFFCLOSE	; ferme la zone secondaire	LOAD.L	D3,(A6)+OWDPOS	LOAD.L	D4,(A6)+OWDDIM	SWAP.W	D4	LOAD.W	D4,(A6)+OWDSEP	LOAD.W	D5,(A6)+OWDPOS+0	SUB.W	D4,D5	SR.W	D5,#1	SUB.W	D4,D5	SWAP.W	D4	LOAD.L	A5,#(A6)+OZONE1	CALL	ZAFFOPEN	; ouvre la zone principale	JUMP',NE 90$	CALL	CDESSINE1	; dessine les informations	LOAD.W	D2,D1	LOAD.L	D3,(A6)+OWDPOS	LOAD.L	D4,(A6)+OWDDIM	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OWDSEP	LOAD.W	D5,(A6)+OWDPOS+0	SR.W	D5,#1	ADD.W	D3,D5	SUB.W	D4,D3	ADD.W	D4,(A6)+OWDPOS+0	SWAP.W	D4	SWAP.W	D3	LOAD.L	A5,#(A6)+OZONE2	CALL	ZAFFOPEN	; ouvre la zone secondaire	JUMP',NE 90$	CALL	CDESSINE2	; dessine la sparation	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D5,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZUSE    >;========/; Donne le pointeur au descripteur d'une zone quelconque,; mme si elle n'est pas visible.; Cre le descripteur si ncessaire !; in	D2.W	numro de zone; out	A5.L	^descripteur zone;	D7.W	erreur; mod	D7.W, A5.LZUSE:	PUSHM.L	D1,D4,A4	CALL	ZCTRL		; A5 <-- ^descripteur zone	JUMP',EQ 90$	LOAD.L	A5,#(A6)+OZONEP	; A5 <-- ^^zones compacts	LOAD.W	D4,D2	SL.W	D4,#2	ADD.W	A5,D4	LOAD.L	D4,#LDZC	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour zone compacte	JUMP',NE 90$	LOAD.L	(A5),A4	SR.L	D4,#1		; D4 <-- /4 car .W	DEC.W	D4		; D4 <-- -1 car NMO20$:	CLR.W	(A4+)	DECJ.W,NMO D4,20$	LOAD.L	A5,(A5)		; A5 <-- ^descripteur zone	LOAD.W	(A5)+ODZNUM,D2	CALL	BINIT		; cre une zone vide mais prte  l'emploi90$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZCTRL   >;========/; Donne le pointeur au descripteur d'une zone quelconque,; mme si elle n'est pas visible.; in	D2.W	numro de zone; out	A5.L	^descripteur zone;	D7.W	erreur; mod	D7.W, A5.LZCTRL:	PUSH.L	D2	LOAD.W	D7,#EREOUTB	LOAD.L	A5,#(A6)+OZONE1	; A5 <-- ^descripteur zone principale	COMP.W	D2,(A5)+ODZNUM	; est-ce la zone principale ?	JUMP',EQ 80$		; oui => 80$	TEST.L	(A6)+OZONE2+ODZFBT ; zone secondaire existe ?	JUMP',EQ 20$		; non => 20$	LOAD.L	A5,#(A6)+OZONE2	; A5 <-- ^descripteur zone secondaire	COMP.W	D2,(A5)+ODZNUM	; est-ce la zone secondaire ?	JUMP',EQ 80$		; oui => 80$20$:	LOAD.L	A5,#(A6)+OZONEP	; A5 <-- ^^zones compactes	SL.W	D2,#2	ADD.W	A5,D2	TEST.L	(A5)		; zone existe ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A5,(A5)		; A5 <-- ^descripteur zone invisible80$:	CLR.W	D7		; D7 <-- ok90$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZKEYNUM >;========/; Donne le numro d'une zone en fonction d'une touche du clavier.; in	D3.L	touche; out	D2.W	numro de la zone;	D7.W	erreur; mod	D2.L, D7.WZKEYNUM:	PUSH.L	D3	LOAD.W	D7,#EREOUTB	; D7 <-- pas trouv	COMP.B	D3,#SPACE	JUMP',EQ 40$	COMP.B	D3,#MACRO	JUMP',EQ 50$	COMP.B	D3,#'0	JUMP,LO 90$	COMP.B	D3,#'9	JUMP',HI 20$	CLR.W	D2	SUB.B	D3,#'0	LOAD.B	D2,D3		; D2 <-- zone 0..9	JUMP	80$20$:	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'Z	JUMP',HI 22$	CLR.W	D2	SUB.B	D3,#'A-10	LOAD.B	D2,D3		; D2 <-- zone 10..35	JUMP'	80$22$:	COMP.B	D3,#'a	JUMP',LO 90$	COMP.B	D3,#'z	JUMP',HI 90$	CLR.W	D2	SUB.B	D3,#'a-10	LOAD.B	D2,D3		; D2 <-- zone 10..35	JUMP'	80$40$:	LOAD.W	D2,(A6)+OZONE2+ODZNUM	TEST.L	(A6)+OZONE2+ODZFBT	JUMP',NE 80$	LOAD.W	D2,(A6)+ONOZLC	; D2 <-- no dernire zone destination d'une copie	JUMP'	80$50$:	LOAD.W	D2,#MACZONE80$:	CLR.W	D7		; D7 <-- ok90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; ZKEYNUMI >;=========/; Donne le numro d'une zone en fonction d'une touche (CTRL) du clavier.; in	D3.L	touche; out	D2.W	numro de la zone;	D7.W	erreur; mod	D2.L, D7.WZKEYNUMI:	PUSH.L	D3	LOAD.W	D7,#EREOUTB	; D7 <-- pas trouv	COMP.B	D3,#H'20	JUMP,HS 90$	SWAP.W	D3		; D3 <-- pseudo-code	COMP.B	D3,#SPACE	JUMP',EQ 40$	COMP.B	D3,#'0	JUMP',LO 90$	COMP.B	D3,#'9	JUMP',HI 20$	CLR.W	D2	SUB.B	D3,#'0	LOAD.B	D2,D3		; D2 <-- zone 0..9	JUMP'	80$20$:	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'Z	JUMP',HI 90$	CLR.W	D2	SUB.B	D3,#'A-10	LOAD.B	D2,D3		; D2 <-- zone 10..35	JUMP'	80$40$:	LOAD.W	D2,(A6)+OZONE2+ODZNUM	TEST.L	(A6)+OZONE2+ODZFBT	JUMP',NE 80$	LOAD.W	D2,(A6)+ONOZLC	; D2 <-- no dernire zone destination d'une copie80$:	CLR.W	D7		; D7 <-- ok90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; ZAFFOPEN >;---------/; Ouvre une zone (compacte --> tendue).; in	A5.L	^emplacement pour zone tendue;	D2.W	numro de la zone;	D3.L	origine (y;x);	D4.L	dimensions (dy;dx); out	D7.W	erreur; mod	D7.WZAFFOPEN:	PUSHM.L	D0..D5,A2..A4	LOAD.L	D0,D4		; D0 <-- dimensions	LOAD.L	A2,#(A6)+OZONEP	; A2 <-- ^^zones compacts	LOAD.W	D4,D2	SL.W	D4,#2	ADD.W	A2,D4	TEST.L	(A2)	JUMP',NE 25$	LOAD.L	D4,#LDZC	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour zone compacte	JUMP,NE 90$	LOAD.L	(A2),A4	SR.L	D4,#1		; D4 <-- /4 car .W	DEC.W	D4		; D4 <-- -1 car NMO20$:	CLR.W	(A4+)	DECJ.W,NMO D4,20$	LOAD.L	A4,(A2)	LOAD.W	(A4)+ODZNUM,D225$:	LOAD.L	A4,(A2)		; A4 <-- ^zone compacte	LOAD.L	A3,A5		; A3 <-- ^zone tendue	LOAD.W	D4,#(LDZC/2)-130$:	LOAD.W	(A3+),(A4+)	; tendue <-- compacte	DECJ.W,NMO D4,30$	LOAD.W	D4,#((LDZ-LDZC)/2)-132$:	CLR.W	(A3+)		; tendue <-- efface	DECJ.W,NMO D4,32$	TEST.L	(A5)+ODZFBT	JUMP',NE 40$	CALL	BINIT		; cre une zone vide mais prte  l'emploi40$:	LOAD.L	D4,D0	ADD.W	D3,#CMGG	SUB.W	D4,#CMGG	LIB	?CREWDO		; cre la nouvelle swdo	LOAD.W	(A5)+ODZWNO,D5	LOAD.L	(A5)+ODZWPO,D3	LOAD.L	(A5)+ODZWDI,D4	CALL	CASDRAW		; dessine la cage de l'ascenseur	COMP.W	(A5)+ODZNUM,#MACZONE	JUMP',NE 80$	CALL	MDECOMPILE	; vide la table OMAKEY80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; ZAFFCLOSE >;----------/; Ferme une zone (tendue --> compacte).; in	A5.L	^description zone tendue; out	-; mod	D7.WZAFFCLOSE:	PUSHM.L	D4,D5,A2..A4	TEST.L	(A5)+ODZFBT	JUMP,EQ 90$	COMP.W	(A5)+ODZNUM,#MACZONE	JUMP',NE 10$	CALL	MCOMPILE	; gnre la table OMAKEY10$:	LOAD.W	D5,(A5)+ODZWNO	JUMP',EQ 20$	LIB	?KILWDO		; supprime l'ancienne swdo20$:	CLR.W	(A5)+ODZWNO	LOAD.L	A2,#(A6)+OZONEP	; A2 <-- ^^zones compactes	LOAD.W	D4,(A5)+ODZNUM	SL.W	D4,#2	ADD.W	A2,D4	LOAD.L	A4,A5		; A4 <-- ^zone tendue	LOAD.L	A3,(A2)		; A3 <-- ^zone compacte	LOAD.W	D4,#(LDZC/2)-140$:	LOAD.W	(A3+),(A4+)	; compacte <-- tendue	DECJ.W,NMO D4,40$	LOAD.L	A3,A5	LOAD.W	D4,#(LDZ/2)-142$:	CLR.W	(A3+)		; tendue <-- efface	DECJ.W,NMO D4,42$90$:	POPM.L	D4,D5,A2..A4	RET;----------\\; ZADETRUIT >;==========/; Dtruit un caractre en avant.; Les caractres dtruits sont transfrs dans la zone UNDO.; in	A5.L	^description zone; out	D3.L	caractre dtruit;	D7.W	erreur; mod	D3.L, D7.WZADETRUIT:	PUSHM.L	D4,A5	CALL	BAVANCE	JUMP,NE 90$	CALL	BDETRUIT	; D3 <-- caractre dtruit	JUMP,NE 90$	LOAD.L	A5,#(A6)+OZONEU	; A5 <-- ^descripteur zone UNDO	LOAD.L	D4,(A5)+ODZNBC	COMP.L	D4,(A5)+ODZPOS	; est-on  la fin ?	JUMP',EQ 50$		; oui => 50$	CALL	BQPOSITIONNE	; va  la fin50$:	CALL	BINSERE	JUMP',NE 90$	INC.L	(A6)+OUNNBA	; un caractre de plus dtruit en avant90$:	POPM.L	D4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; ZRDETRUIT >;==========/; Dtruit un caractre en arrire.; Les caractres dtruits sont transfrs dans la zone UNDO.; in	A5.L	^description zone; out	D3.L	caractre dtruit;	D7.W	erreur; mod	D3.L, D7.WZRDETRUIT:	PUSHM.L	D4,A5	CALL	BDETRUIT	; D3 <-- caractre dtruit	JUMP',NE 90$	LOAD.L	A5,#(A6)+OZONEU	; A5 <-- ^descripteur zone UNDO	TEST.L	(A5)+ODZPOS	; est-on au dbut ?	JUMP',EQ 50$		; oui => 50$	CLR.L	D4	CALL	BQPOSITIONNE	; revient au dbut50$:	CALL	BINSERE	JUMP',NE 90$	CALL	BRECULE	INC.L	(A6)+OUNNBR	; un caractre de plus dtruit en arrire90$:	POPM.L	D4,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ZUNDORECUP >;===========/; Rcupre tous les caractres dtruits.; in	A5.L	^description zone; out	D7.W	erreur; mod	D7.WZUNDORECUP:	PUSHM.L	D3,D4,A4,A5	LOAD.L	A4,A5	LOAD.L	A5,#(A6)+OZONEU	; A5 <-- ^descripteur zone UNDO	CLR.L	D4	CALL	BQPOSITIONNE	; revient au dbut20$:	CALL	BAVANCE	JUMP',NE 40$	CALL	BDETRUIT	EX.L	A4,A5	CALL	BINSERE	JUMP',NE 90$	EX.L	A4,A5	JUMP	20$40$:	EX.L	A4,A5	LOAD.L	D4,(A6)+OUNNBA	; D4 <-- nb de caractres dtruits en avant	JUMP',EQ 44$42$:	CALL	BRECULE	DEC.L	D4	JUMP,NE 42$44$:	CLR.L	(A6)+OUNNBA	; plus rien dtruit en avant	CLR.L	(A6)+OUNNBR	; plus rien dtruit en arrire	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A4,A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; ZUNDOANNULE >;============/; Annule la rcupration de tous les caractres dtruits.; in	A5.L	^description zone; out	-; mod	D7.WZUNDOANNULE:	PUSH.L	A5	LOAD.L	A5,#(A6)+OZONEU	; A5 <-- ^descripteur zone UNDO	TEST.L	(A5)+ODZNBC	; zone vide ?	JUMP',EQ 90$		; oui => 90$	CALL	BINIT		; vide toute la zone	CLR.L	(A6)+OUNNBA	; plus rien dtruit en avant	CLR.L	(A6)+OUNNBR	; plus rien dtruit en arrire90$:	POP.L	A5	RET	.END