	.TITLE	Handy_Scanner	.PROC	M68000	; Programme de gestion du scanner  main par l'intermdiaire de MUBUS	; (c) EPSITEC-SYSTEM et BIMIKO, Christophe KORBER, juillet 89	.REF	SMAKY	.REF	DBOX	.REF	xxxHARD	.BASE	10REV	= 1VER	= 1	.REV	REV,VER	.START	DEBUTINSMILE	= FALSENBENT	= 2		; Nb. de mots (16 bits) d'entte par ligneNB100	= 25		; Nb. de mots d'une image  100 DpiNB200	= 51		;  200 DpiNB300	= 77		;  300 DpiNB400	= 103		;  400 DpiNBCAR	= 50		; Nb. de caractres pour le nom du fichierLGECR	= 128		; Largeur de l'cran en octetsADBYT1	= 16		; Priphrique de lecture du 1er octetADBYT2	= 17		; Priphrique de lecture du 2me octetADSTAT	= 18		; Prifrique de lecture des statusAD12V	= 18		; Commande 12[V] scanner 0 = ON, 1 = OFFERFIN	= 1ERTOUT	= 2LOOP	= 16'80000			; Timeout de 4 sec	.LOC	0DEBUT:.IF	.NOT.INSMILE	LIB	?OPELIB.ENDIF	MOVE.32	#LGVAR,D4	MOVE.16	#MTYPCP,D1	GESMEM	?GETMEM		; Prend la mmoire des variables	MOVE.32	A4,A5	NTREL	?GETMACHINE	; Cherche le type de machine	RL.32	#8, D4	MOVE.8	D4,{A5}+OSMAKY	COMP.8	#Smaky100,D4	JUMP,EQ	D10$	COMP.8	#Smaky324,D4	JUMP,NE	SORTIE$	MOVE.32	#LOOP,D0	SL.32	#2,D0	MOVE.32	D0,{A5}+OTIMO	MOVE.32	#SM324ADMUBUS,D0	ADD.32	#ADBYT1,D0	MOVE.32	D0,{A5}+OMUBB1	MOVE.32	#SM324ADMUBUS,D0	ADD.32	#ADBYT2,D0	MOVE.32	D0,{A5}+OMUBB2	MOVE.32	#SM324ADMUBUS,D0	ADD.32	#ADSTAT,D0	MOVE.32	D0,{A5}+OMSTAT	MOVE.32	#SM324ADMUBUS,D0	ADD.32	#AD12V,D0	MOVE.32	D0,{A5}+OM12V	CLR.32	{A5}+ODENS	JUMP	D20$D10$:	MOVE.32	#LOOP,D0	MOVE.32	D0,{A5}+OTIMO	MOVE.32	#SM100ADMUBUS,D0	ADD.32	#2*ADBYT1,D0	MOVE.32	D0,{A5}+OMUBB1	MOVE.32	#SM100ADMUBUS,D0	ADD.32	#2*ADBYT2,D0	MOVE.32	D0,{A5}+OMUBB2	MOVE.32	#SM100ADMUBUS,D0	ADD.32	#2*ADSTAT,D0	MOVE.32	D0,{A5}+OMSTAT	MOVE.32	#SM100ADMUBUS,D0	ADD.32	#2*AD12V,D0	MOVE.32	#16,{A5}+ODENS	MOVE.32	D0,{A5}+OM12VD20$:	move.32	{a5}+om12V,a0	move.8	#1,{A0}		; 12V scanner OFF	GESMEM	?ARGMEM	SR.32	#2,D5	MOVE.32	D5,D4	ADD.32	D5,D4	ADD.32	D5,D4		; Prend les 3/4 du plus grand trou	MOVE.16	#MTYPCP,D1	GESMEM	?GETMEM		; Prend la mmoire du buffer d'image	MOVE.32	A4,A6	MOVE.32	D4,{A5}+OLGMEM	; Mmoire  disposition	CALL	R16^INIECR	MOVE.32	{A5}+ODENS,D4	TSET.32	D4:#1	; Densit 200 dpi	MOVE.32	D4,{A5}+ODENS	MOVE.16	#NB200,{A5}+OLARG	CALL	R16^CALCUL	MOVE.8	#5,D4	NTREL	?SETPRIO	; Met une priorit leve	CALL	R16^GETCOM	; Edite les commandes du programme	CLR.16	D5	LIB	?USEWDO	MOVE.16	{A5}+ONOWDO,D5	LIB	?KILWDO	MOVE.32	A6,A4	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM		; Rend la mmoire du buffer d'imageSORTIE$:	MOVE.32	A5,A4	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM		; Rend la mmoire des variables.IF	INSMILE	EXIT.ELSE	LIB	?CLOLIB	FOS	?STOP.ENDIFCALCUL:	PUSHM.32	D0|D1	MOVE.32	{A5}+OLGMEM,D1	; Mmoire  disposition	MOVE.16	{A5}+OLARG,D0	SL.16	#1,D0	DIV.16	D0,D1	SUB.16	#2,D1	MOVE.16	D1,{A5}+ONBLGN	; Nb. de ligne  disposition - 2	MOVE.16	{A5}+OLARG,D0	MOVE.16	{A5}+ODIMX,D1	SR.16	#4,D1	MOVE.16	D0,{A5}+ONBWRD	MOVE.16	#0,{A5}+ONBRES	COMP.16	D1,D0	JUMP,LS	C10$	MOVE.16	D1,{A5}+ONBWRD	SUB.16	D1,D0	MOVE.16	D0,{A5}+ONBRESC10$:	POPM.32	D0|D1	RETGETCOM:	PUSHM.32	D2|D3LOOP$:	LIB	?GETCAR	COMP.8	#END,D3	JUMP,EQ	FIN$	COMP.16	#F14,D3	JUMP,EQ	T30$	COMP.16	#F15,D3	JUMP,EQ	T30$	MOVE.32	#R16^TICOHOR,A3	MOVE.32	#0,A4	DBOX_	ICODET	JUMP,NE	BEEPER$	COMP.16	#0,D2	JUMP,EQ	FIN$	COMP.16	#6,D2	JUMP,NE	T05$	CALL	R16^PARAM	JUMP	LOOP$T05$:	COMP.16	#3,D2	JUMP,NE	T10$	CALL	R16^SAUVE	JUMP	LOOP$T10$:	COMP.16	#7,D2	JUMP,NE	T20$	CALL	R16^READIMA	; Lit une image	MOVE.8	#BIPEND,D3	LIB	?BEEP	JUMP	LOOP$T20$:	COMP.16	#13,D2	JUMP,NE	BEEPER$T30$:	LIB	?AFTIM	.ASCIZE	"<EOP>"	JUMP	LOOP$BEEPER$:	MOVE.8	#BIPLIT,D3	LIB	?BEEP	JUMP	LOOP$FIN$:	MOVE.8	#BIPDON,D3	LIB	?BEEP	POPM.32	D2|D3	RETPARAM:	PUSHM.32	A0..A6|D0..D6	MOVE.32	#R16^T_DBDENS,A2	MOVE.16	#2**BDBSAV,D2	MOVE.32	{A5}+ODENS,D4	DBOX_	OPENEDIT$:	DBOX_	EDIT	COMP.16	#F13,D3	JUMP,EQ	P99$	COMP.16	#F9,D3	JUMP,NE	P01$	TNOT.32	D4:#4	JUMP	EDIT$P01$:	COMP.16	#F4,D3	JUMP,NE	P02$	AND.32	#16'FFFFFFF0,D4	TSET.32	D4:#0	JUMP	EDIT$P02$:	COMP.16	#F5,D3	JUMP,NE	P04$	AND.32	#16'FFFFFFF0,D4	TSET.32	D4:#1	JUMP	EDIT$P04$:	COMP.16	#F6,D3	JUMP,NE	P06$	AND.32	#16'FFFFFFF0,D4	TSET.32	D4:#2	JUMP	EDIT$P06$:	COMP.16	#F7,D3	JUMP,NE	P08$	AND.32	#16'FFFFFFF0,D4	TSET.32	D4:#3	JUMP	EDIT$P08$:	COMP.16	#F1,D3	JUMP,NE	EDIT$	MOVE.32	D4,{A5}+ODENS	TEST.32	D4:#3	JUMP,BC	P10$	MOVE.16	#NB400,{A5}+OLARG	JUMP	P99$P10$:	TEST.32	D4:#2	JUMP,BC	P20$	MOVE.16	#NB300,{A5}+OLARG	JUMP	P99$P20$:	TEST.32	D4:#1	JUMP,BC	P30$	MOVE.16	#NB200,{A5}+OLARG	JUMP	P99$P30$:	MOVE.16	#NB100,{A5}+OLARGP99$:	DBOX_	CLOSE	CALL	R16^CALCUL	MOVE.32	#R16^TICOHOR,A3	MOVE.32	#0,A4	CALL	R16^AFFICO	POPM.32	A0..A6|D0..D6	RETSAUVE:	PUSHM.32	D1..D6|A1..A5	PUSH.32	A5	MOVE.32	#{A5}+OFILE,A5	MOVE.8	#0,{A5}	MOVE.32	#R16^TDBOX_IO,A3	MOVE.32	#R16^EXT,A4	MOVE.32	#R16^TICOSV,A1	CLR.32	D4	MOVE.16	#DBOX_EXTRAIT,D1	MOVE.16	#2**BDBSAV.OR.2**BDBEXTEND,D2	MOVE.32	#NBCAR.OR.2**BDBIOEXT1.OR.2**BDBIOICO,D3	DBOX_	EXTEND	POP.32	A5	COMP.16	#F1,D3	JUMP,NE	FIN$	MOVE.32	#{A5}+OFILE,A3	MOVE.32	#DEFATT,D3	FOS	?CHATR	JUMP,NE	SAUVE$	MOVE.16	#DBOX_DETRUIT,D1	MOVE.16	#2**BDBSAV.OR.2**BDBEXTEND,D2	MOVE.32	#2**BDBIOICO,D3	MOVE.32	#R16^TICODET,A1	MOVE.32	#R16^TDBOX_IO,A3	PUSH.32	A5	MOVE.32	#{A5}+OFILE,A5	DBOX_	EXTEND	POP.32	A5	COMP.16	#F4,D3	JUMP,EQ	FIN$	MOVE.32	#{A5}+OFILE,A3	FOS	?DELETESAUVE$:	MOVE.32	#{A5}+OFILE,A3	MOVE.32	#DEFATT,D3	MOVE.16	#TYPRAND,D4	FOS	?CREATE	MOVE.8	#2**BOPWR.OR.2**BOPEXWR,D3	FOS	?OPEN	MOVE.32	#{A5}+OIMTYP,A2	MOVE.8	#16'81,{A2}+OIMTYP	; signale type image	CLR.8	{A2}+OIMCOD	MOVE.8	#1,{A2}+OIMBIP		; 1 bit par point	MOVE.8	#2,{A2}+OIMDIR		; Y/X comme dans l'cran	CLR.32	D4	MOVE.16	{A5}+OLARG,D4	SL.32	#4,D4	MOVE.16	D4,{A2}+OIMDLX	MOVE.16	D5,{A2}+OIMDLY	CLR.32	D4	MOVE.16	D5,D4	MUL.16	{A5}+OLARG,D4	SL.32	#1,D4	MOVE.32	D4,{A2}+OIMNBB	MOVE.32	#LGIMA,D4	MOVE.32	#{A5}+OIMTYP,A4	FOS	?WRBYTE	MOVE.32	{A2}+OIMNBB,D4	MOVE.32	A6,A4	FOS	?WRBYTE	FOS	?CLOSEFIN$:	CALL	R16^AFFICO	POPM.32	D1..D6|A1..A5	RETTDBOX_IO:	.ASCIZ	"HANDY"	.ASCIZ	"Fimage"	.ASCIZ	""	.8	0	.EVENEXT:	.ASCIZE	".IMAGE"TICOSV:	.8	LDB_SVTICO2:	.8	USEGC,"I","H",24	.8	0	.8	10,10,10	.8	0,0,0	.8	0,0,0	.8	0,0,0	.8	11,11,11LDB_SV	=	APC-TICOSV-1	.EVENTICO3:	.8	USEGC,"I","H",24	.8	0	.8	10,10,10	.8	1,2,3	.8	4,0,12	.8	0,0,0	.8	11,11,11	.EVENTICODET:	.8	LDB_DET	.8	USEGC,"I","H",24	.8	0	.8	13,13,13	.8	14,14,14	.8	0,0,0	.8	0,0,0	.8	0,0,0LDB_DET	=	APC-TICODET-1	.EVENAFFICO:	PUSHM.32	A0|A3|A4	MOVE.32	#R16^MENU,A3	LIB	?AFMENU	LIB	?GETPDIS	MOVE.32	A4,A0	MOVE.32	#R16^TICOHOR,A3	MOVE.32	#0,A4	DBOX_	ICOAFF	POPM.32	A0|A3|A4	RETINIECR:	MOVE.32	#2,D3	LIB	?MOUSE	LIB	?AFTIM	.8	LOADGC,"I","H",24,0	LIB	?GETPDIS	MOVE.32	A4,A0	MOVE.32	#R16^TICOHOR,A3	MOVE.32	#0,A4	DBOX_	ICOCADRE	LIB	?CREWDO	MOVE.16	D5,{A5}+ONOWDO	CLR.32	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZE	"<AFINV> HANDY <48+REV>."	MOVE.32	#VER,D4	MOVE.16	#3,D3	MOVE.16	#2**BAFDCM,D2	LIB	?AFDEC	MOVE.8	#AFDIR,D3	LIB	?AFCAR	DBOX_	ICOAFF	MOVE.16	{A5}+ONOWDO,D5	LIB	?USEWDO	MOVE.8	#NOCURS,D3	LIB	?AFCAR	LIB	?GETWDO	MOVE.16	D4,{A5}+ODIMX	SR.32	#8,D4	SR.32	#8,D4	MOVE.16	D4,{A5}+ODIMY	LIB	?GETPDIS	MOVE.32	{A4}+ODFABS,A2	CLR.32	D4	MOVE.16	{A4}+ODFWBY,D4	MUL.16	#LGECR,D4	ADD.32	D4,A2	CLR.32	D4	MOVE.16	{A4}+ODFWBX,D4	DIV.16	#8,D4	ADD.32	D4,A2	MOVE.32	A2,{A5}+OECR	MOVE.32	A2,{A5}+PTECR	MOVE.32	#R16^MENU,A3	LIB	?AFMENU	RETREADIMA:	PUSHM.32 a0|a5	move.32	a5,a0	MOVE.32	#R16^RDIMA,a5	; Routine  excuter en IOF	ntrel	?iep15trp	jump,ne	l900$	move.32	a0,a5	TRAP	#15		; passe en mode "superviseur"l900$:	POPM.32	a0|a5	TEST.16	D7	RETRDIMA:	PUSHM.32	D6|A0..A4	OR.16	#16'0700,SF	; met IOF total	MOVE.32	#R16^MENUVIDE,A3	LIB	?AFMENU	LIB	?GETPDIS	MOVE.32	A4,A0	MOVE.32	#R16^TICOVIDE,A3	MOVE.32	#0,A4	DBOX_	ICOAFF	CLR.32	D5		; Compteur de ligne de l'image	CLR.32	D6		; Compteur de ligne sur l'cran	move.32	{a5}+om12V,a0	move.8	#0,{A0}		; 12V scanner ON	MOVE.32	{A5}+OECR,{A5}+PTECRLOOP$:	COMP.16	{A5}+ODIMY,D6	JUMP,LO	L10$	MOVE.32	{A5}+OECR,{A5}+PTECR	CLR.16	D6L10$:	CALL	R16^READLGN	; Lit une ligne sur le scanner	JUMP,NE	FIN$	INC.32	D5	INC.32	D6	ADD.32	#LGECR,{A5}+PTECR	move.32	{a5}+oclrlg,a1	MOVE.8	D0,{A1}		; Prpare pour la ligne suivante	COMP.16	{A5}+ONBLGN,D5	JUMP,LO	LOOP$FIN$:	move.32	{a5}+om12V,a0	move.8	#1,{A0}		; 12V scanner OFF	CALL	R16^AFFICO	POPM.32	D6|A0..A4	pop.32	a0	pop.32	d0	TEST.16	D7	RETSFREADLGN:	PUSHM.32	D0..D6|A0..A6	MOVE.32	{A5}+PTECR,A3	CLR.16	D7	MOVE.32	A6,A2	CLR.32	D2	MOVE.16	{A5}+OLARG,D2	SL.32	#1,D2	MUL.16	D5,D2	ADD.32	D2,A2		; Calcule l'offset en mmoire	MOVE.32	{A5}+OTIMO,D3	; Prpare un 'Time-out' de 2 sec.	move.32	{a5}+omubb1,a0	move.32	{a5}+omubb2,a1	move.32	{a5}+omstat,a4	MOVE.16	#NBENT,D1L10$:	TEST.8	{A4}:#6		; Prend une autre ligne ?	JUMP,BS	L20$	DEC.32	D3	JUMP,NE	L10$	MOVE.16	#ERTOUT,D7	; Si 'Time-out' => fin lecture	JUMP	FIN$L20$:	TEST.8	{A4}:#7		; 16 bits lus ?	JUMP,BC	L20$	MOVE.8	{A1},D4		; Mmorise les poids faibles	MOVE.8	{A0},D3		; puis les poids forts	MOVE.8	D0,{A0}	DEC.16	D1	JUMP,NE	L20$	MOVE.32	{A5}+ODENS,D1	TEST.32	D1:#4	JUMP,NE	L32$	MOVE.16	{A5}+ONBWRD,D1L30$:	TEST.8	{A4}:#7		; 16 bits lus ?	JUMP,BC	L30$	MOVE.8	{A1},D4		; Mmorise les poids faibles	MOVE.8	{A0},D3		; puis les poids forts	MOVE.8	D0,{A0}	MOVE.8	D4,{A2+}	MOVE.8	D3,{A2+}	MOVE.8	D4,{A3+}	MOVE.8	D3,{A3+}	DEC.16	D1	JUMP,NE	L30$	JUMP	L36$L32$:	MOVE.16	{A5}+ONBWRD,D1L34$:	TEST.8	{A4}:#7		; 16 bits lus ?	JUMP,BC	L34$	MOVE.8	{A1},D4		; Mmorise les poids faibles	MOVE.8	{A0},D3		; puis les poids forts	MOVE.8	D0,{A0}	MOVE.8	D4,{A2+}	MOVE.8	D3,{A2+}	NOT.8	D4	NOT.8	D3	MOVE.8	D4,{A3+}	MOVE.8	D3,{A3+}	DEC.16	D1	JUMP,NE	L34$L36$:	MOVE.16	{A5}+ONBRES,D1	JUMP,EQ	FIN$L40$:	TEST.8	{A4}:#7		; 16 bits lus ?	JUMP,BC	L40$	MOVE.8	{A1},D4		; Mmorise les poids faibles	MOVE.8	{A0},D3		; puis les poids forts	MOVE.8	D0,{A0}	MOVE.8	D4,{A2+}	MOVE.8	D3,{A2+}	DEC.16	D1	JUMP,NE	L40$FIN$:	POPM.32	D0..D6|A0..A6	RETTICOHOR:	.8	USEGC,"I","H",24	.8	15	.8	0,5,7	.8	0,0,8	.8	6,6,6	.8	0,0,0	.8	9,9,9	.EVENMENU:	.ASCIZ	""	.ASCIZ	"Fin"	.ASCIZ	""	.ASCIZ	"            Sauve"	.ASCIZ	""	.ASCIZ	"            Param"	.ASCIZ	""	.ASCIZ	"Lit une image"	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	"Efface l'cran"	.EVENTICOVIDE:	.8	USEGC,"I","H",24	.8	0	.8	0,0,0	.8	0,0,0	.8	0,0,0	.8	0,0,0	.8	0,0,0	.EVENT_DBDENS:	.16	DBDENS$-T_DBDENS	.16	MENUDENS$-T_DBDENS	.16	TICO3-T_DBDENS	.16	0DBDENS$:	.8	ODBCIRCLE,0	.ASCIZ	" 100 Dpi "	.8	ODBTABX,15	.8	ODBCIRCLE,1	.ASCIZ	" 200 Dpi "	.8	ODBCR,ODBCR	.8	ODBCIRCLE,2	.ASCIZ	" 300 Dpi "	.8	ODBTABX,15	.8	ODBCIRCLE,3	.ASCIZ	" 400 Dpi "	.8	ODBCR,ODBCR	.8	ODBSQUARE,4	.ASCIZ	" affiche l'image ngative "	.8	ODBCR,ODBCR,ODBCR	.8	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.8	ODBTABX,15	.8	ODBBOX,0,F13,TDBNORM	.ASCIZ	" ANNULE "	.8	0	.EVENMENUDENS$:	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	"D'accord"	.ASCIZ	""	.ASCIZ	" 100 | 200 | 300 "	.ASCIZ	""	.ASCIZ	" 400 |     | Ng."	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	"Annule"	.EVENMENUVIDE:	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.EVEN	.LOC	0OIMTYP:	.BLK.8	1OIMCOD:	.BLK.8	1OIMBIP:	.BLK.8	1	; := 1OIMDIR:	.BLK.8	1	; := 2OIMDLX:	.BLK.16	1OIMDLY:	.BLK.16	1OIMNBB:	.BLK.32	1	.BLK.8	10'20LGIMA:	.EVENOCLR16:			; ^ d'attente du wordOMUBB1:	.BLK.32	1	; ^ du 1er byte sur MUBUSOCLRLG:			; ^ de recherche du dbut de la ligneOMUBB2:	.BLK.32	1	; ^ du 2me byte dur MUBUSOMSTAT:	.BLK.32	1	; ^ status de l'interfaceOM12V:	.BLK.32	1	; ^ scanner ON-OFFODENS:	.BLK.32	1	; Densit de l'image lueOTIMO:	.BLK.32	1OLARG:	.BLK.16	1	; Largeur de l'image en wordOLGMEM:	.BLK.32	1	; Longeur du buffer de l'imageODIMX:	.BLK.16	1	; Largeur de l'cranODIMY:	.BLK.16	1	; Hauteur de l'cranONBLGN:	.BLK.16	1	; Nombre de lignes affichable de l'cranONBWRD:	.BLK.16	1	; Nombre de word  afficher  l'cranONBRES:	.BLK.16	1	; Nb. de word restant  lireONOWDO:	.BLK.16	1	; No. de la fentreOECR:	.BLK.32	1PTECR:	.BLK.32	1OFILE:	.BLK.8	NBCAR	.EVENOSMAKY:	.BLK.8	1	; Type de SMAKY	.EVENLGVAR:	.END