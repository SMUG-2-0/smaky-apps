	.CHAP	SCANIO.ASI;--------\\; IOSAUVE >;========/; Sauve l'image dans un fichier.; in	-; out	D7.16	erreur; mod	D7.16IOSAUVE:	PUSHM.32 D0..D6|A1|A3|A4	CALL	IOOPEN		; A1/D1 <-- ^image/lg	JUMP,NE	EXIT9$EDIT$:	CALL	NORMMOUSE	; remet la flche	CALL	DBOXSAUVE	; demande le nom ...	JUMP,NE	EXIT8$	COMP.16	#F1,D3	JUMP,NE EXIT8$	MOVE.32	#{A6}+OBUFIO,A3	; A3 <-- ^nom du fichierCREATE$:	MOVE.32	#DEFATT,D3	; D3 <-- attributs par dfaut	MOVE.16	#TYPRAND,D4	; D4 <-- type "random"	MOVE.32	#FOS?CREATE,D0	CALL	ERCALL		; cre le fichier	JUMP,EQ R8^WRITE$	; ok => WRITE$	COMP.16	#ERFAEX,D7	; fichier existe dj ?	JUMP,NE	EXIT8$		; non => EXIT8$				; oui =>	CALL	NORMMOUSE	; remet la flche	MOVE.16	#2**BDBSAV,D2	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	JUMP,NE EXIT8$	COMP.16	#"O",D3	JUMP,NE EDIT$	MOVE.32	#FOS?DELETE,D0	CALL	ERCALL		; dtruit le fichier	JUMP,NE EXIT8$	JUMP	CREATE$WRITE$:	CALL	WAITMOUSE	; met le sablier	MOVE.16	#2**BOPWR.OR.2**BOPEXCL,D3	MOVE.32	#FOS?OPEN,D0	CALL	ERCALL		; ouvre le fichier	JUMP,NE R8^EXIT8$	MOVE.32	A1,A4	MOVE.32	D1,D4	FOS	?WRBYTE		; crit toute l'image	JUMP,NE R8^EXIT7$	FOS	?CLOSE		; ferme l'image	JUMP	R8^EXIT8$EXIT7$:	PUSH.16	D7	FOS	?CLOSE		; ferme l'image	POP.16	D7EXIT8$:	CALL	IOCLOSE		; libre l'imageEXIT9$:	CALL	NORMMOUSE	; remet la flche	POPM.32	D0..D6|A1|A3|A4	TEST.16	D7		; retour EQ/NE	RET;--------\\; IOPRINT >;========/; Imprime l'image.; in	-; out	D7.16	erreur; mod	D7.16IOPRINT:	PUSHM.32 D1..D6|A1..A5	CLR.8	{A6}+OVIMAI	CALL	FLECMOUSE	; lutin souris = flche	CALL	IOOPEN		; A1/D1 <-- ^image/lg	JUMP,NE	R8^EXIT9$	CLR.32	D3	PRINTA_	OPEN		; A2 <-- canal	JUMP,NE	R8^EXIT8$	CALL	NORMMOUSE	; remet la flche	MOVE.32	#2**BPRNOFILE,D3 ; D3 <-- mode	MOVE.32	#R16^NAME$,A3	; A3 <-- ^nom du document	MOVE.32	#R16^NAME$,A5	; A5 <-- ^nom du logiciel	MOVE.32	#{A6}+OBUPRES,A4 ; A4 <-- ^nom de la prsentation	MOVE.32	D1,D2		; D2 <-- lg document	PRINTA_	OPPRINT	JUMP,NE	R8^EXIT7$	CALL	WAITMOUSE	; met le sablier	MOVE.32	A1,A4		; A4 <-- ^image	MOVE.32	D1,D4		; D4 <-- lg image	PRINTA_	WRPRINT		; imprime l'image	JUMP,NE	R8^EXIT6$	PRINTA_	CLPRINT	JUMP	R8^EXIT7$EXIT6$:	PUSH.16	D7	PRINTA_	CLPRINT	POP.16	D7EXIT7$:	PUSH.16	D7	PRINTA_	CLOSE		; ferme le module PRINT	POP.16	D7EXIT8$:	CALL	IOCLOSE		; libre l'imageEXIT9$:	CALL	NORMMOUSE	; remet la flche	POPM.32	D1..D6|A1..A5	TEST.16	D7		; retour EQ/NE	RETNAME$:	.ASCIZ	"SCAN"	.EVEN;--------\\; IOOPEN  >;--------/; Prpare l'image code pour l'crire sur disque.; in	-; out	A1.32	^image;	D1.32	lg image;	D7.16	erreur; mod	D1.32, D7.16, A1.32IOOPEN:	PUSHM.32 D0|D2..D6|A2..A4	CALL	WAITMOUSE	; met le sablier	MOVE.16	{A6}+OVICEX,D0	SUB.16	{A6}+OVICBX,D0	; D0 <-- largeur	ADD.16	#16-1,D0	SR.16	#4,D0	SL.16	#1,D0		; D0 <-- largeur en bytes (multiple de words)	MOVE.16	{A6}+OVICEY,D2	SUB.16	{A6}+OVICBY,D2	; D2 <-- hauteur	MOVE.16	D0,D4	MUL.16	D2,D4	ADD.32	#LGHIMA+IMLBUF,D4 ; D4 <-- lg ncessaire	MOVE.16	#MTYPCP,D1	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP,NE	EXIT$	GESMEM	?CLEARMEM	MOVE.32	A4,A1		; A1 <-- ^buffer pour image	MOVE.8	#16'81,{A1}+OIMTYP	MOVE.8	#16'00,{A1}+OIMCOD	MOVE.8	#16'01,{A1}+OIMBIP	MOVE.8	#16'02,{A1}+OIMDIR	SL.16	#3,D0	MOVE.16	D0,{A1}+OIMDLX	MOVE.16	D2,{A1}+OIMDLY	SUB.32	#LGHIMA+IMLBUF,D4	MOVE.32	D4,{A1}+OIMNBB	MOVE.16	{A6}+OVIDII+2,D5	SR.16	#3,D5		; D5 <-- iy source	MOVE.16	{A6}+OVICBY,D3	SUB.16	#IMMARG,D3	SWAP.32	D3	MOVE.16	{A6}+OVICBX,D3	SUB.16	#IMMARG,D3	; D3 <-- position source	CLR.32	D4		; D4 <-- position destination	MOVE.16	{A1}+OIMDLX,D6	SR.16	#3,D6		; D6 <-- iy destination	MOVE.16	{A1}+OIMDLY,D2	; D2 <-- hauteur	SWAP.32	D2	MOVE.16	{A6}+OVICEX,D2	SUB.16	{A6}+OVICBX,D2	; D2 <-- largeur	MOVE.32	{A6}+OVIPTI,A3	; A3 <-- ^source	TEST.32	{A6}+OPTMEF	; image filtre existe ?	JUMP,EQ	R8^NOF$		; non => NOF$	MOVE.32	{A6}+OPTMEF,A3	; A3 <-- ^source (image filtre)NOF$:	MOVE.32	#{A1}+LGHIMA+IMLBUF,A4 ; A4 <-- ^destination	MOVE.16	#SETDOT,D1	; D1 <-- mode	TEST.8	{A6}+OAFINV	; affichage invers ?	JUMP,EQ	R8^GO$		; non => GO$	MOVE.16	#SETDOT.OR.CPLDOT,D1 ; D1 <-- modeGO$:	MOVE.32	A0,A2		; A2 <-- ^descripteur fentre	GRA_	RASTER	MOVE.32	A1,A2		; A2 <-- ^en-tte image	MOVE.32	#{A1}+LGHIMA+IMLBUF,A3	MOVE.32	#{A1}+LGHIMA,A4	GRA_	CODEIMA		; code l'image	JUMP,EQ	R8^CODOK$	MOVE.32	{A1}+OIMNBB,D4	SR.32	#2,D4CODXF$:	MOVE.32	{A3+},{A4+}	DEC.32	D4	JUMP,NC	CODXF$CODOK$:	MOVE.32	{A1}+OIMNBB,D1	ADD.32	#LGHIMA,D1	; D1 <-- lg image	CLR.16	D7		; D7 <-- okEXIT$:	POPM.32	D0|D2..D6|A2..A4	TEST.16	D7		; retour EQ/NE	RET;--------\\; IOCLOSE >;--------/; Libre l'image.; in	A1.32	^image;	D1.32	lg image; out	-; mod	-IOCLOSE:	PUSHM.32 D1|D7|A4	MOVE.32	A1,A4	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM	POPM.32	D1|D7|A4	RET	.END