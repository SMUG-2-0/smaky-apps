	.CHAP	SCANVISU.ASI;--------\\; VISU    >;========/; Montre l'image scanne.; in	-; out	D3.32	dernire touche;	A4.32	^image coupe;	D4.32	dimensions (dy;dx);	D5.16	incrment ligne; mod	D3.32, D4.32, D5.32, D7.16, A4.32VISU:	PUSHM.32 A3	CLR.8	{A6}+OVIMAI	; main absente	MOVE.16	#IMMARG,{A6}+OVICBX	MOVE.16	#IMMARG,{A6}+OVICBY	MOVE.16	{A6}+OVIDII+2,D3	COMP.16	{A6}+OMAXDI+2,D3	JUMP,LE	R8^DIMX$	MOVE.16	{A6}+OMAXDI+2,D3	DEC.16	D3DIMX$:	ADD.16	#IMMARG,D3	MOVE.16	D3,{A6}+OVICEX	MOVE.16	{A6}+OVIDII+0,D3	COMP.16	{A6}+OMAXDI+0,D3	JUMP,LE	R8^DIMY$	MOVE.16	{A6}+OMAXDI+0,D3	DEC.16	D3DIMY$:	ADD.16	#IMMARG,D3	MOVE.16	D3,{A6}+OVICEY	CALL	VISUDRAW	; dessine les ascenseurs	CALL	VISUUPDATE	; dessine l'imageSK$:	MOVE.32	#R16^SKVISU,A3	LIB	?AFMENU		; affiche les soft-keysLOOP$:	LIB	?GETKEY		; attend souris/clavier ...	TEST.32	D3:#BKPSEUDO	; touche relche ?	JUMP,BS LOOP$		; oui => LOOP$	COMP.16	#KEYMPO,D3	JUMP,EQ	MOVE$	COMP.16	#KEYMGR,D3	JUMP,EQ	LOOP$	COMP.16	#KEYMMR,D3	JUMP,EQ	LOOP$	COMP.16	#KEYMDR,D3	JUMP,EQ	LOOP$	COMP.16	#KEYMGP,D3	JUMP,EQ	CLIC$	COMP.16	#KEYMMP,D3	JUMP,EQ	CLIC$	COMP.16	#KEYMDP,D3	JUMP,EQ	CLIC$	COMP.16	#F0+SHIFT,D3	JUMP,LO R8^NOSF$	COMP.16	#F15+SHIFT,D3	JUMP,HI R8^NOSF$	SUB.16	#SHIFT,D3NOSF$:	COMP.16	#F0,D3	JUMP,EQ	EXIT$	COMP.16	#F1,D3	JUMP,EQ	TAKE$	COMP.16	#F2,D3	JUMP,EQ	TAKE$	COMP.16	#F3,D3	JUMP,EQ	TAKE$	COMP.16	#F4,D3	JUMP,EQ SAUVE$	COMP.16	#F6,D3	JUMP,EQ RESOL$	COMP.16	#F7,D3	JUMP,EQ	EXIT$	COMP.16	#F8,D3	JUMP,EQ	EXIT$	COMP.16	#F9,D3	JUMP,EQ	EXIT$	COMP.16	#F10,D3	JUMP,EQ FILTRE$	COMP.16	#F12,D3	JUMP,EQ CONTRA$	COMP.16	#F13,D3	JUMP,EQ INV$	COMP.16	#F15,D3	JUMP,EQ PRINT$BIP$:	MOVE.16	#BIPLIT,D3	LIB	?BEEP		; p'tit bruit	JUMP	SK$ERROR$:	COMP.16	#ERKSTO,D7	JUMP,EQ	BIP$	PUSH.16	D7	MOVE.16	#BIPERR,D3	LIB	?BEEP		; vilain bruit	POP.16	D7	MOVE.16	#2**BDBSAV,D2	DBOX_	MERROR		; affiche l'erreur ...	JUMP	SK$MOVE$:	CALL	BASELUTIN	; change v. le lutin de la souris	JUMP	LOOP$SAUVE$:	CALL	IOSAUVE		; sauve l'image	JUMP,NE	ERROR$	JUMP	SK$RESOL$:	CALL	DBOXRESOL	; choix de la rsolution ...	JUMP,NE	ERROR$	JUMP	SK$FILTRE$:	CALL	FILTRE		; filtre l'image ...	JUMP,NE ERROR$	CALL	IMAGESHOW	; affiche l'image	CALL	COUPDRAW	; affiche les coupures	JUMP	SK$CONTRA$:	CALL	CONTRASTE	; contraste l'image ...	JUMP,NE ERROR$	CALL	IMAGESHOW	; affiche l'image	CALL	COUPDRAW	; affiche les coupures	JUMP	SK$INV$:	NOT.8	{A6}+OAFINV	CALL	IMAGESHOW	; affiche l'image	CALL	COUPDRAW	; affiche les coupures	JUMP	LOOP$PRINT$:	CALL	IOPRINT		; imprime l'image	JUMP,NE	ERROR$	JUMP	SK$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE	BIP$	CALL	VISUMOVE	; dplace l'image ...	JUMP,NE	BIP$	JUMP	LOOP$TAKE$:	CALL	SCANCOUPE	; coupe l'image selon les repres	JUMP,EQ	R8^EXIT$	CLR.8	{A6}+OVIMAI	CALL	FLECMOUSE	; lutin souris = flche	MOVE.16	#BIPERR,D3	LIB	?BEEP		; vilain bruit	MOVE.32	#R16^ERR1$,A3	CLR.16	D2	DBOX_	TERROR		; affiche l'erreur ...	CALL	IMAGESHOW	; affiche l'image	CALL	COUPDRAW	; affiche les coupures	JUMP	SK$EXIT$:	CALL	FLECMOUSE	; lutin souris = flche	POPM.32	A3	RETERR1$:	.ASCII	"L'image est trop grande !<CR>"	.ASCII	"Coupez-la avec les marques<CR>"	.ASCIZ	"en haut et  droite ..."	.EVEN;---------\\; VISUFOND >;=========/; Affiche le fond blanc ou noir.; in	-; out	-; mod	D7.16VISUFOND:	PUSHM.32 D2..D4|A3	CALL	VISUVIDE	CLR.32	D3	CLR.32	D4	LIB	?DRMDEF	MOVE.16	{A0}+ODFCY,D4	MUL.16	#10,D4		; D4 <-- hauteur	SWAP.32	D4	MOVE.16	{A0}+ODFCX,D3	MUL.16	#50,D3	MOVE.16	D3,D4		; D4 <-- largeur	MOVE.16	{A0}+ODFFDY,D3	SR.16	#1,D3	MOVE.32	D4,D2	SWAP.32	D2	SR.16	#1,D2	SUB.16	D2,D3	SWAP.32	D3	MOVE.16	{A0}+ODFFDX,D3	SR.16	#1,D3	MOVE.16	D4,D2	SR.16	#1,D2	SUB.16	D2,D3	MOVE.16	#CLRDOT,D2	LIB	?DRTRAME	MOVE.16	#SETDOT,D2	LIB	?DRRECT	ADD.16	{A0}+ODFCX,D3	ADD.16	{A0}+ODFCX,D3	ADD.16	{A0}+ODFCX,D3	ADD.16	{A0}+ODFCX,D3	SWAP.32	D3	ADD.16	{A0}+ODFC1Y,D3	ADD.16	{A0}+ODFCY,D3	ADD.16	{A0}+ODFCY,D3	SWAP.32	D3	MOVE.32	#R16^TEXT$,A3LOOP$:	TEST.8	{A3}	JUMP,EQ	R8^EXIT$	LIB	?SETCURS	SWAP.32	D3	ADD.16	{A0}+ODFCY,D3	SWAP.32	D3	LIB	?AFTEXT	JUMP	LOOP$EXIT$:	POPM.32	D2..D4|A3	RETTEXT$:	.ASCIZ	"1)  Positionnez le ""ScanMan"" en haut de"	.ASCIZ	"    l'image  saisir."	.ASCIZ	" "	.ASCIZ	"2)  Tout en pressant le bouton sur le ct"	.ASCIZ	"    gauche, dplacez lentement le ""ScanMan"""	.ASCIZ	"    vers le bas de l'image."	.8	0	.EVEN;---------\\; VISUVIDE >;=========/; Affiche le fond blanc ou noir.; in	-; out	-; mod	D7.16VISUVIDE:	PUSHM.32 D2..D4	CLR.32	D3	TEST.8	{A6}+OAFINV	JUMP,EQ	R8^DEF$	NOT.32	D3DEF$:	MOVE.32	D3,D4	LIB	?DRMDEF	MOVE.32	{A6}+OVIPOS,D3	MOVE.32	{A6}+OVIDIM,D4	MOVE.16	#LOADDOT,D2	LIB	?DRTRAME	POPM.32	D2..D4	RET;---------\\; VISUDRAW >;=========/; Dessine les ascenseurs vides.; in	-; out	-; mod	D7.16VISUDRAW:	PUSHM.32 D2..D4|A3|A5	LIB	?AFTIM	.8	EOP		; efface l'cran	.8	NOCURS		; plus de curseur	.8	0	.EVEN	MOVE.32	#16'88228822,D3	MOVE.32	D3,D4	LIB	?DRMDEF	MOVE.16	#SETDOT,D2	CLR.32	D3	MOVE.16	{A0}+ODFFDY,D4	SWAP.32	D4	MOVE.16	#VIMARG,D4	LIB	?DRTRAME	; trame grise  gauche	MOVE.16	{A0}+ODFFDX,D3	SUB.16	#VIMARG,D3	LIB	?DRTRAME	; trame grise  droite	MOVE.16	{A0}+ODFFDY,D3	SUB.16	#VIMARG,D3	SWAP.32	D3	CLR.16	D3	MOVE.16	#VIMARG,D4	SWAP.32	D4	MOVE.16	{A0}+ODFFDX,D4	LIB	?DRTRAME	; trame grise en bas	CLR.32	D3	SWAP.32	D4	MOVE.16	{A0}+ODFC1Y,D4	ADD.16	{A0}+ODFC2Y,D4	ADD.16	#VIMARG,D4	SWAP.32	D4	LIB	?DRTRAME	; trame grise en haut	MOVE.32	#-1,D3	MOVE.32	D3,D4	LIB	?DRMDEF	CLR.32	D3	MOVE.16	{A0}+ODFC1Y,D4	ADD.16	{A0}+ODFC2Y,D4	SWAP.32	D4	MOVE.16	{A0}+ODFFDX,D4	LIB	?DRTRAME	; trame noire en haut	LIB	?AFTIM	.ASCII	"<AFINV> SCAN "	.8	SCANREV+"0","."	.IF	SCANVERS.LT.10	.8	SCANVERS+"0"	.ELSE	.8	(SCANVERS/10)+"0",(SCANVERS-((SCANVERS/10)*10))+"0"	.ENDIF	.ASCIZ	"    Connexion: ""ScanMan""     (C) Daniel ROUX et EPSITEC-system sa<AFDIR>"	.EVEN	MOVE.16	{A0}+ODFC1Y,D3	ADD.16	{A0}+ODFC2Y,D3	ADD.16	#VIMARG+LGSCROLL,D3	MOVE.16	{A0}+ODFFDY,D4	SUB.16	D3,D4	SUB.16	#VIMARG+LGSCROLL,D4	SWAP.32	D3	SWAP.32	D4	MOVE.16	#VIMARG+LGSCROLL,D3	MOVE.16	{A0}+ODFFDX,D4	SUB.16	D3,D4	SUB.16	#VIMARG+LGSCROLL,D4	MOVE.32	D3,{A6}+OVIPOS	; OVIPOS <-- position pour afficher le fichier	MOVE.32	D4,{A6}+OVIDIM	; OVIDIM <-- dimensions pour afficher le fichier	SUB.16	#LGSCROLL,D3	ADD.16	#LGSCROLL+LGSCROLL-1,D4	SWAP.32	D3	SWAP.32	D4	SUB.16	#LGSCROLL,D3	ADD.16	#LGSCROLL+LGSCROLL-1,D4	SWAP.32	D3	SWAP.32	D4	MOVE.16	#SETDOT,D2	LIB	?DRRECT		; dessine rectangle du pourtour	DEC.16	D3	SWAP.32	D3	DEC.16	D3	SWAP.32	D3	ADD.16	#2,D4	SWAP.32	D4	ADD.16	#2,D4	SWAP.32	D4	LIB	?DRRECT		; dessine rectangle du pourtour double	MOVE.32	#{A6}+OVIASV,A5	; A5 <-- ^variables ascenseur vertical	MOVE.16	{A6}+OVIPOS+0,D4	DEC.16	D4	MOVE.16	D4,{A5}+OSCDEBO	MOVE.16	{A6}+OVIPOS+2,D4	SUB.16	#LGSCROLL,D4	MOVE.16	D4,{A5}+OSCDEBL	MOVE.16	{A6}+OVIDIM+0,D4	ADD.16	#2,D4	MOVE.16	D4,{A5}+OSCHTR;	CLR.8	{A5}+OSCHOR	SET.8	{A5}+OSCPAGE	SCROLL_	DRAW		; dessine l'ascenseur vertical	CLR.16	{A5}+OSCPOSV	MOVE.16	#16,{A5}+OSCINC	MOVE.32	#{A6}+OVIASH,A5	; A5 <-- ^variables ascenseur horizontal	MOVE.16	{A6}+OVIPOS+2,D4	DEC.16	D4	MOVE.16	D4,{A5}+OSCDEBO	MOVE.16	{A6}+OVIPOS+0,D4	ADD.16	{A6}+OVIDIM+0,D4	MOVE.16	D4,{A5}+OSCDEBL	MOVE.16	{A6}+OVIDIM+2,D4	ADD.16	#2,D4	MOVE.16	D4,{A5}+OSCHTR	SET.8	{A5}+OSCHOR	SET.8	{A5}+OSCPAGE	SCROLL_	DRAW		; dessine l'ascenseur horizontal	CLR.16	{A5}+OSCPOSV	MOVE.16	#16,{A5}+OSCINC	MOVE.32	{A6}+OVIPOS,D3	MOVE.32	{A6}+OVIDIM,D4	DEC.16	D3	INC.16	D4	SWAP.32	D3	SWAP.32	D4	SUB.16	#LGSCROLL,D3	MOVE.16	#LGSCROLL-1,D4	SWAP.32	D4	SWAP.32	D3	LIB	?DRRECT		; dessine rectangle de coupe horizontal	MOVE.32	{A6}+OVIPOS,D3	MOVE.32	{A6}+OVIDIM,D4	ADD.16	D4,D3	MOVE.16	#LGSCROLL-1,D4	SWAP.32	D3	SWAP.32	D4	DEC.16	D3	INC.16	D4	SWAP.32	D4	SWAP.32	D3	LIB	?DRRECT		; dessine rectangle de coupe vertical	MOVE.32	{A6}+OVIPOS,D3	SUB.16	#LGSCROLL,D3	SWAP.32	D3	SUB.16	#LGSCROLL,D3	SWAP.32	D3	MOVE.32	#R16^ARROWUL$,A3	CALL	BASEMOTIF	MOVE.32	{A6}+OVIPOS,D3	ADD.16	{A6}+OVIDIM+2,D3	SWAP.32	D3	SUB.16	#LGSCROLL,D3	SWAP.32	D3	MOVE.32	#R16^ARROWUR$,A3	CALL	BASEMOTIF	MOVE.32	{A6}+OVIPOS,D3	SUB.16	#LGSCROLL,D3	SWAP.32	D3	ADD.16	{A6}+OVIDIM+0,D3	SWAP.32	D3	MOVE.32	#R16^ARROWDL$,A3	CALL	BASEMOTIF	MOVE.32	{A6}+OVIPOS,D3	ADD.16	{A6}+OVIDIM+2,D3	SWAP.32	D3	ADD.16	{A6}+OVIDIM+0,D3	SWAP.32	D3	MOVE.32	#R16^ARROWDR$,A3	CALL	BASEMOTIF	POPM.32	D2..D4|A3|A5	RETARROWUL$:	.16	+3,+3	.16	0,+8	.16	+2,-2	.16	+4,+4	.16	+4,-4	.16	-4,-4	.16	+2,-2	.16	-8,0	.32	0ARROWUR$:	.16	+3,+12	.16	0,-8	.16	+2,+2	.16	+4,-4	.16	+4,+4	.16	-4,+4	.16	+2,+2	.16	-8,0	.32	0ARROWDL$:	.16	+12,+3	.16	0,+8	.16	-2,-2	.16	-4,+4	.16	-4,-4	.16	+4,-4	.16	-2,-2	.16	+8,0	.32	0ARROWDR$:	.16	+12,+12	.16	0,-8	.16	-2,+2	.16	-4,-4	.16	-4,+4	.16	+4,+4	.16	-2,+2	.16	+8,0	.32	0;-----------\\; VISUUPDATE >;===========/; Met  jour l'affichage de l'image et des ascenseurs.; in	-; out	-; mod	D7.WVISUUPDATE:	CALL	IMAGESHOW	; affiche l'image	CALL	COUPDRAW	; affiche les coupures	CALL	ASCUPDATE	; affiche les ascenseurs	RET;---------\\; VISUMOVE >;=========/; Dplace ventuellement l'image.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WVISUMOVE:	PUSH.32	A2	MOVE.32	#R16^IMAGESHOW,A2	CALL	BASEMOVEA	; dplace les ascenseurs ...	JUMP,EQ	R8^OK$	CALL	COINMOVE	; dplace selon les icnes coin ...	JUMP,EQ	R8^OK$	CALL	COUPMOVE	; dplace les coupures ...	JUMP,EQ	R8^OK$	MOVE.32	#R16^IMAGESHOW,A2	CALL	BASEMOVEM	; dplace le contenu ...	JUMP,NE	R8^EXIT$OK$:	CALL	IMAGESHOW	; affiche l'image	CALL	COUPDRAW	; affiche les coupures	CALL	ASCUPDATE	; affiche les ascenseurs	CLR.16	D7		; D7 <-- okEXIT$:	POP.32	A2	TEST.16	D7		; retour EQ/NE	RET;----------\\; ASCUPDATE >;----------/; Met  jour l'affichage des ascenseurs.; in	-; out	-; mod	D7.WASCUPDATE:	PUSHM.32 D4|A5	MOVE.32	#{A6}+OVIASV,A5	; A5 <-- ^variables ascenseur vertical	CLR.16	{A5}+OSCHTV	MOVE.16	{A6}+OVIDII+0,D4 ; D4 <-- hauteur de l'image	ADD.16	#IMMARG*2,D4	SUB.16	{A6}+OVIDIM+0,D4	JUMP,LS	R8^L40$	MOVE.16	D4,{A5}+OSCHTV	SCROLL_	UPDATE		; dessine l'ascenseur vertical pleinL40$:	MOVE.32	#{A6}+OVIASH,A5	; A5 <-- ^variables ascenseur horizontal	CLR.16	{A5}+OSCHTV	MOVE.16	{A6}+OVIDII+2,D4 ; D4 <-- largeur de l'image	ADD.16	#IMMARG*2,D4	SUB.16	{A6}+OVIDIM+2,D4	JUMP,LS	R8^L90$	MOVE.16	D4,{A5}+OSCHTV	SCROLL_	UPDATE		; dessine l'ascenseur horizontal pleinL90$:	POPM.32	D4|A5	RET;----------\\; IMAGESHOW >;----------/; Affiche une image dans la fentre.; in	-; out	-; mod	D7.WIMAGESHOW:	PUSHM.32 D4|A4	MOVE.32	{A6}+OVIPTI,A4	; A4 <-- ^data de l'image	MOVE.16	#BVIIMO,D4	; D4 <-- bit pour image originale	TEST.32	{A6}+OPTMEF	; image filtre existe ?	JUMP,EQ	R8^NOF$		; non => NOF$	MOVE.32	{A6}+OPTMEF,A4	; A4 <-- ^data de l'image filtre	MOVE.16	#BVIIMF,D4	; D4 <-- bit pour image filtreNOF$:	TEST.8	{A6}+OAFINV	; affichage invers ?	JUMP,NE	R8^INV$				; positif =>	TCLR.8	{A6}+OVIBIN:D4	; image ngative ?	JUMP,BC	R8^AFF$		; non => AFF$	CALL	IMAGEINV	; remet l'image en positif	JUMP	R8^AFF$INV$:				; ngatif =>	TSET.8	{A6}+OVIBIN:D4	; image ngative ?	JUMP,BS	R8^AFF$		; oui => AFF$	CALL	IMAGEINV	; met l'image en ngatifAFF$:	CALL	IMAGEAFF	; affiche l'image	POPM.32	D4|A4	RET;---------\\; IMAGEINV >;---------/; Inverse toute la matrice d'une image.; in	A4.L	^data de l'image; out	-; mod	D7.WIMAGEINV:	PUSHM.32 D0|D1|A1	MOVE.32	A4,A1		; A1 <-- ^data de l'image	MOVE.16	{A6}+OVIDII+2,D1 ; D1 <-- largeur de l'image	MUL.16	{A6}+OVIDII+0,D1 ; D1 <-- nb de points de l'image	SR.32	#3,D1		; D1 <-- /8 car en bytes	MOVE.16	D1,D0	AND.16	#2'11111,D0	SR.32	#5,D1		; D1 <-- /32 car par 8x.L	DEC.16	D1	JUMP,NS	R8^L22$L20$:	NOT.32	{A1+}		; inverse 32 bytes	NOT.32	{A1+}	NOT.32	{A1+}	NOT.32	{A1+}	NOT.32	{A1+}	NOT.32	{A1+}	NOT.32	{A1+}	NOT.32	{A1+}	DJ.16,NMO D1,L20$L22$:	DEC.16	D0	JUMP,NS	R8^L32$L30$:	NOT.8	{A1+}	DJ.16,NMO D0,L30$L32$:	POPM.32	D0|D1|A1	RET;---------\\; IMAGEAFF >;---------/; Affiche l'image.; in	-; out	-; mod	D7.16IMAGEAFF:	PUSHM.32 D2..D4|A4	MOVE.8	#AFCCMO,D3	LIB	?AFCAR		; enlve la flche de la souris	CLR.32	D3	MOVE.16	#IMMARG,D4	SWAP.32	D4	MOVE.16	{A6}+OVIDII+2,D4	ADD.16	#IMMARG+IMMARG+1000,D4	MOVE.16	#LOADDOT,D2	MOVE.32	#R16^TRAME0$,A4	CALL	IMAGETRAME	MOVE.16	#IMMARG,D3	MOVE.16	{A6}+OVIDII+0,D4	ADD.16	D3,D4	SWAP.32	D3	SWAP.32	D4	CLR.16	D3	MOVE.16	#IMMARG,D4;	MOVE.16	#LOADDOT,D2;	MOVE.32	#R16^TRAME0$,A4	CALL	IMAGETRAME	MOVE.16	#IMMARG,D3	MOVE.16	{A6}+OVIDII+0,D4	ADD.16	D3,D4	SWAP.32	D3	SWAP.32	D4	MOVE.16	#IMMARG,D3	ADD.16	{A6}+OVIDII+2,D3	MOVE.16	D3,D4	ADD.16	#IMMARG+1000,D4;	MOVE.16	#LOADDOT,D2;	MOVE.32	#R16^TRAME0$,A4	CALL	IMAGETRAME	MOVE.16	#IMMARG,D3	ADD.16	{A6}+OVIDII+0,D3	MOVE.16	D3,D4	ADD.16	#IMMARG+1000,D4	SWAP.32	D3	SWAP.32	D4	CLR.16	D3	MOVE.16	{A6}+OVIDII+2,D4	ADD.16	#IMMARG+IMMARG+1000,D4;	MOVE.16	#LOADDOT,D2;	MOVE.32	#R16^TRAME0$,A4	CALL	IMAGETRAME	MOVE.16	#IMMARG,D3	MOVE.16	{A6}+OVICBY,D4	SWAP.32	D3	SWAP.32	D4	MOVE.16	#IMMARG,D3	MOVE.16	D3,D4	ADD.16	{A6}+OVIDII+2,D4	MOVE.16	#LOADDOT.OR.GREDOT,D2 ; D2 <-- mode	CALL	IMAGEDATA	MOVE.16	{A6}+OVICBY,D3	MOVE.16	{A6}+OVICEY,D4	SWAP.32	D3	SWAP.32	D4	MOVE.16	#IMMARG,D3	MOVE.16	{A6}+OVICBX,D4	MOVE.16	#LOADDOT.OR.GREDOT,D2 ; D2 <-- mode	CALL	IMAGEDATA	MOVE.16	{A6}+OVICBX,D3	MOVE.16	{A6}+OVICEX,D4	MOVE.16	#LOADDOT,D2	; D2 <-- mode	CALL	IMAGEDATA	MOVE.16	{A6}+OVICEX,D3	MOVE.16	{A6}+OVIDII+2,D4	ADD.16	#IMMARG,D4	MOVE.16	#LOADDOT.OR.GREDOT,D2 ; D2 <-- mode	CALL	IMAGEDATA	MOVE.16	{A6}+OVICEY,D3	MOVE.16	{A6}+OVIDII+0,D4	ADD.16	#IMMARG,D4	SWAP.32	D3	SWAP.32	D4	MOVE.16	#IMMARG,D3	MOVE.16	D3,D4	ADD.16	{A6}+OVIDII+2,D4	MOVE.16	#LOADDOT.OR.GREDOT,D2 ; D2 <-- mode	CALL	IMAGEDATA	MOVE.8	#AFSCMO,D3	LIB	?AFCAR		; remet la flche de la souris	POPM.32	D2..D4|A4	RETTRAME0$:	.8	2'00000000	.8	2'00000000	.8	2'00000000	.8	2'00000000	.8	2'00000000	.8	2'00000000	.8	2'00000000	.8	2'00000000	.EVEN;-----------\\; IMAGETRAME >;-----------/; Dessine une trame dans l'image.; in	D2.16	mode de dessin;	D3.32	coin sup/gauche (y;x);	D4.32	coin inf/droite (y;x);	A4.32	^trame; out	-; mod	D7.16IMAGETRAME:	PUSHM.32 D0..D4|A2	MOVE.16	D2,D0	SUB.16	{A6}+OVIASH+OSCPOSV,D3	SWAP.32	D3	SUB.16	{A6}+OVIASV+OSCPOSV,D3	SWAP.32	D3	SUB.16	{A6}+OVIASH+OSCPOSV,D4	SWAP.32	D4	SUB.16	{A6}+OVIASV+OSCPOSV,D4	SWAP.32	D4	CLR.32	D1	MOVE.32	{A6}+OVIDIM,D2	CALL	RECTAND	JUMP,NE	R8^EXIT$	SUB.16	D3,D4	ADD.16	{A6}+OVIPOS+2,D3	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,D4	ADD.16	{A6}+OVIPOS+0,D3	SWAP.32	D3	SWAP.32	D4	EX.32	D3,D4	MOVE.16	D0,D1	MOVE.32	A0,A2		; A2 <-- ^descripteur	GRA_	TRAMEEXIT$:	POPM.32	D0..D4|A2	RET;----------\\; IMAGEDATA >;----------/; Dessine le data dans l'image.; in	D2.16	mode de dessin;	D3.32	coin sup/gauche (y;x);	D4.32	coin inf/droite (y;x); out	-; mod	D7.16IMAGEDATA:	PUSHM.32 D0..D5|A2..A4	MOVE.16	D2,D0		; D0 <-- mode de dessin	SUB.16	{A6}+OVIASH+OSCPOSV,D3	SWAP.32	D3	SUB.16	{A6}+OVIASV+OSCPOSV,D3	SWAP.32	D3	SUB.16	{A6}+OVIASH+OSCPOSV,D4	SWAP.32	D4	SUB.16	{A6}+OVIASV+OSCPOSV,D4	SWAP.32	D4	CLR.32	D1	MOVE.32	{A6}+OVIDIM,D2	CALL	RECTAND	JUMP,NE	EXIT$	MOVE.32	D4,D2	MOVE.32	D3,D4	SUB.16	D4,D2	ADD.16	{A6}+OVIPOS+2,D4	SWAP.32	D4	SWAP.32	D2	SUB.16	D4,D2	ADD.16	{A6}+OVIPOS+0,D4	SWAP.32	D4	SWAP.32	D2	ADD.16	{A6}+OVIASH+OSCPOSV,D3	SUB.16	#IMMARG,D3	SWAP.32	D3	ADD.16	{A6}+OVIASV+OSCPOSV,D3	SUB.16	#IMMARG,D3	SWAP.32	D3	MOVE.32	{A6}+OVIPTI,A3	; A3 <-- ^source (image)	TEST.32	{A6}+OPTMEF	; image filtre existe ?	JUMP,EQ	R8^NOF$		; non => NOF$	MOVE.32	{A6}+OPTMEF,A3	; A3 <-- ^source (image filtre)NOF$:	MOVE.32	#0,A4		; A4 <-- ^destination (cran)	MOVE.16	{A6}+OVIDII+2,D5	SR.16	#3,D5		; D5 <-- ii source	MOVE.16	D0,D1		; D1 <-- mode	MOVE.32	A0,A2		; A2 <-- ^descripteur	GRA_	RASTEREXIT$:	POPM.32	D0..D5|A2..A4	RET;----------\\; BASEMOVEA >;----------/; Dplace ventuellement les ascenseurs.; in	D4.32	position de la souris (y;x);	A2.32	^routine "xxxxSHOW"; out	D7.16	erreur (trop petit); mod	D7.16BASEMOVEA:	PUSHM.32 D1..D5|A5	MOVE.32	D4,D5		; D5 <-- position de la souris;	MOVE.16	#ERDIOUT,D7	MOVE.32	#{A6}+OVIASV,A5	; A5 <-- ^variables ascenseur vertical	TEST.16	{A5}+OSCHTV	JUMP,EQ	R8^L40$;	MOVE.32	D5,D4		; D4 <-- position de la souris	MOVE.16	{A6}+OVIDIM+0,D1	SR.16	#1,D1	MOVE.16	{A5}+OSCINC,D2	CLR.16	{A5}+OSCINC	SCROLL_	MOVE		; dplace l'ascenseur ...	MOVE.16	D2,{A5}+OSCINC	TEST.16	D7	JUMP,EQ	R8^L60$L40$:	MOVE.16	#ERDIOUT,D7	MOVE.32	#{A6}+OVIASH,A5	; A5 <-- ^variables ascenseur horizontal	TEST.16	{A5}+OSCHTV	JUMP,EQ L90$	MOVE.32	D5,D4		; D4 <-- position de la souris	MOVE.16	{A6}+OVIDIM+2,D1	SR.16	#1,D1	MOVE.16	{A5}+OSCINC,D2	CLR.16	{A5}+OSCINC	SCROLL_	MOVE		; dplace l'ascenseur ...	MOVE.16	D2,{A5}+OSCINC	TEST.16	D7	JUMP,NE L90$L60$:	SCROLL_	PRESS		; presse la petite flcheL62$:	MOVE.16	D2,D3		; D3 <-- avance	COMP.16	#SCROLLFDOWN,D4	JUMP,EQ	R8^L64$	NEG.16	D3		; D3 <-- recule	COMP.16	#SCROLLFUP,D4	JUMP,EQ	R8^L64$	MOVE.16	D1,D3		; D3 <-- avance	COMP.16	#SCROLLPDOWN,D4	JUMP,EQ	R8^L64$	NEG.16	D3		; D3 <-- recule	COMP.16	#SCROLLPUP,D4	JUMP,NE	R8^L68$L64$:	ADD.16	{A5}+OSCPOSV,D3	; D3 <-- nouvelle position	JUMP,NC	R8^L65$	CLR.16	D3L65$:	COMP.16	{A5}+OSCHTV,D3	JUMP,LS	R8^L66$	MOVE.16	{A5}+OSCHTV,D3L66$:	COMP.16	{A5}+OSCPOSV,D3	; position change ?	JUMP,EQ	R8^L74$		; non => 74$L67$:				; oui =>	MOVE.16	D3,{A5}+OSCPOSVL68$:	CALL	{A2}		; CALL xxxxSHOW	COMP.16	#SCROLLFDOWN,D4	JUMP,EQ	R8^L72$	COMP.16	#SCROLLFUP,D4	JUMP,EQ	R8^L72$	COMP.16	#SCROLLPDOWN,D4	JUMP,EQ	R8^L72$	COMP.16	#SCROLLPUP,D4	JUMP,NE	R8^L76$L72$:	SCROLL_	UPDATE		; bouge aussi l'ascenseurL74$:	LIB	?IFCAR		; bouton relch ?	JUMP,NE L62$		; non => 62$L76$:	SCROLL_	PRESS		; relche la petite flche	CLR.16	D7		; D7 <-- okL90$:	POPM.32	D1..D5|A5	TEST.16	D7		; retour EQ/NE	RET;----------\\; BASEMOVEM >;----------/; Dplace ventuellement le contenu avec la "main".; in	D4.L	position de la souris (y;x);	A2.32	^routine "xxxxUPDATE"; out	D7.W	erreur; mod	D7.WBASEMOVEM:	PUSHM.32 D3..D5	CALL	BASEPOSM	; souris dans le rectangle ?	JUMP,NE EXIT$		; non => EXIT$	MOVE.16	{A6}+OVIASH+OSCPOSV,D5	ADD.16	D4,D5	SWAP.32	D4	SWAP.32	D5	MOVE.16	{A6}+OVIASV+OSCPOSV,D5	ADD.16	D4,D5	SWAP.32	D4	SWAP.32	D5LOOP$:	CALL	IFMOUSE		; D4 <-- position de la souris	CALL	BASEPOSM	; D4 <-- position dans le rectangle	MOVE.16	D4,D3	SUB.16	D5,D3	NEG.16	D3		; D3 <-- nouvelle position en X	JUMP,NC	R8^MINX$	CLR.16	D3MINX$:	COMP.16	{A6}+OVIASH+OSCHTV,D3	JUMP,LS	R8^MAXX$	MOVE.16	{A6}+OVIASH+OSCHTV,D3MAXX$:	SWAP.32	D4	SWAP.32	D5	SUB.16	D5,D4	NEG.16	D4		; D4 <-- nouvelle position en Y	JUMP,NC	R8^MINY$	CLR.16	D4MINY$:	COMP.16	{A6}+OVIASV+OSCHTV,D4	JUMP,LS	R8^MAXY$	MOVE.16	{A6}+OVIASV+OSCHTV,D4MAXY$:	SWAP.32	D5	COMP.16	{A6}+OVIASH+OSCPOSV,D3	JUMP,NE	R8^MOVE$	COMP.16	{A6}+OVIASV+OSCPOSV,D4	JUMP,EQ	R8^NEXT$MOVE$:	MOVE.16	D3,{A6}+OVIASH+OSCPOSV	MOVE.16	D4,{A6}+OVIASV+OSCPOSV	CALL	{A2}		; CALL xxxxUPDATENEXT$:	LIB	?IFCAR		; bouton relch ?	JUMP,NE LOOP$		; non => LOOP$	CLR.16	D7		; D7 <-- okEXIT$:	POPM.32	D3..D5	TEST.16	D7		; retour EQ/NE	RET;----------\\; BASELUTIN >;----------/; Modifie v. le lutin de la souris selon la position.; in	-; out	-; mod	D7.WBASELUTIN:	PUSH.32	D4	PUSH.32	{A6}+OVIPCM	CLR.32	{A6}+OVIPCM	CALL	IFMOUSE		; D4 <-- position de la souris	POP.32	{A6}+OVIPCM	TEST.16	D7	JUMP,NE	R8^L20$	CALL	BASEPOSM	; souris dans le rectangle ?	JUMP,EQ	R8^L40$		; oui => 40$L20$:	TEST.8	{A6}+OVIMAI	JUMP,EQ	R8^L90$	CLR.8	{A6}+OVIMAI	CALL	FLECMOUSE	; lutin souris = flche	JUMP	R8^L90$L40$:	TEST.8	{A6}+OVIMAI	JUMP,NE	R8^L90$	SET.8	{A6}+OVIMAI	CALL	MAINMOUSE	; lutin souris = mainL90$:	POP.32	D4	RET;---------\\; BASEPOSM >;---------/; Donne la position relative dans le rectangle o agit la main.; in	D4.L	position de la souris (y;x); out	D4.L	position pour la main (y;x);	D7.16	erreur; mod	D4.L, D7.WBASEPOSM:	CLR.16	D7		; D7 <-- ok	SUB.16	{A6}+OVIPOS+2,D4 ; souris trop  gauche ?	JUMP,HS	R8^L10$	CLR.16	D4	MOVE.16	#ERDIOUT,D7L10$:	COMP.16	{A6}+OVIDIM+2,D4 ; souris trop  droite ?	JUMP,LO	R8^L12$	MOVE.16	{A6}+OVIDIM+2,D4	DEC.16	D4	MOVE.16	#ERDIOUT,D7L12$:	SWAP.32	D4	SUB.16	{A6}+OVIPOS+0,D4 ; souris trop en haut ?	JUMP,HS	R8^L20$	CLR.16	D4	MOVE.16	#ERDIOUT,D7L20$:	COMP.16	{A6}+OVIDIM+0,D4 ; souris trop en bas ?	JUMP,LO	R8^L22$	MOVE.16	{A6}+OVIDIM+0,D4	DEC.16	D4	MOVE.16	#ERDIOUT,D7L22$:	SWAP.32	D4	TEST.16	D7		; retour EQ/NE	RET;----------\\; BASEMOTIF >;----------/; Dessine un petit motif.; in	A3.32	^table des dplacements;	D3.32	origine (y;x);	D2.16	mode de dessin; out	-; mod	D7.16BASEMOTIF:	PUSHM.32 D3|D4|A3	SWAP.32	D3	ADD.16	{A3+},D3	SWAP.32	D3	ADD.16	{A3+},D3LOOP$:	MOVE.32	{A3+},D4	JUMP,EQ	R8^EXIT$	LIB	?DRSEG	JUMP	LOOP$EXIT$:	POPM.32	D3|D4|A3	RET;---------\\; COINMOVE >;=========/; Dplace v. selon une icne coin.; in	D4.32	position de la souris (y;x); out	D7.16	erreur; mod	D7.16COINMOVE:	PUSHM.32 D1..D4	CALL	COINDET		; D2 <-- coin o est la souris	JUMP,NE	EXIT$	CALL	COININV		; allume le coin o est la souris	MOVE.16	D2,D1LOOP$:	LIB	?GETKEY		; attend dplacement souris ...	COMP.16	#KEYMPO,D3	JUMP,NE	R8^END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE	LOOP$	CALL	COINDET		; D2 <-- coin o est la souris	COMP.16	D1,D2	JUMP,EQ	LOOP$	EX.32	D1,D2	CALL	COININV		; teint l'ancien coin	MOVE.16	D1,D2	CALL	COININV		; allume le nouveau coin	JUMP	LOOP$END$:	CALL	COININV		; teint le coin o est la souris	COMP.16	#-1,D2	JUMP,EQ	R8^EXIT$	CLR.16	D3	TEST.32	D2:#1	JUMP,BC	R8^OKY$	MOVE.16	{A6}+OVIASV+OSCHTV,D3OKY$:	MOVE.16	D3,{A6}+OVIASV+OSCPOSV	CLR.16	D3	TEST.32	D2:#0	JUMP,BC	R8^OKX$	MOVE.16	{A6}+OVIASH+OSCHTV,D3OKX$:	MOVE.16	D3,{A6}+OVIASH+OSCPOSV	CLR.16	D7		; D7 <-- okEXIT$:	POPM.32	D1..D4	TEST.16	D7		; retour EQ/NE	RET;--------\\; COINDET >;--------/; Dtecte dans quelle icne coin est la souris.; in	D4.32	position de la souris (y;x); out	D2.16	rang (0..3);	D7.16	erreur; mod	D2.32, D7.16COINDET:	PUSHM.32 D3..D6	MOVE.16	D4,D5		; D5 <-- position en X	MOVE.32	D4,D6	SWAP.32	D6		; D6 <-- position en Y	CLR.16	D2LOOP$:	CALL	COINPOS		; D3/D4 <-- position/dimensions	COMP.16	D3,D5	JUMP,LO	R8^NEXT$	ADD.16	D4,D3	COMP.16	D3,D5	JUMP,HS	R8^NEXT$	SWAP.32	D3	SWAP.32	D4	COMP.16	D3,D6	JUMP,LO	R8^NEXT$	ADD.16	D4,D3	COMP.16	D3,D6	JUMP,HS	R8^NEXT$	CLR.16	D7	JUMP	R8^EXIT$NEXT$:	INC.16	D2		; D2 <-- rang suivant	COMP.16	#4,D2	JUMP,LO	LOOP$	MOVE.16	#-1,D2		; D2 <-- rang inexistant	MOVE.16	#ERDIOUT,D7EXIT$:	POPM.32	D3..D6	TEST.16	D7		; retour EQ/NE	RET;--------\\; COININV >;--------/; Inverse une icne coin.; in	D2.16	rang (0..3); out	-; mod	D7.16COININV:	PUSHM.32 D2..D4	COMP.16	#-1,D2	JUMP,EQ	R8^EXIT$	MOVE.32	#-1,D3	MOVE.32	D3,D4	LIB	?DRMDEF	CALL	COINPOS		; D3/D4 <-- position/dimensions	MOVE.16	#INVDOT,D2	LIB	?DRTRAME	; inverse l'icne coinEXIT$:	POPM.32	D2..D4	RET;--------\\; COINPOS >;--------/; Donne la position d'une icne coin.;; Les rangs sont numrots comme suit :;;	0  1		00  01;	2  3		10  11; in	D2.16	rang (0..3); out	D3.32	position (y;x);	D4.32	dimensions (dy;dx); mod	D3.32, D4.32COINPOS:	MOVE.16	{A6}+OVIPOS+0,D3	SUB.16	#LGSCROLL-1,D3	TEST.32	D2:#1	JUMP,BC OKY$	MOVE.16	{A6}+OVIPOS+0,D3	ADD.16	{A6}+OVIDIM+0,D3	INC.16	D3OKY$:	SWAP.32	D3	MOVE.16	{A6}+OVIPOS+2,D3	SUB.16	#LGSCROLL-1,D3	TEST.32	D2:#0	JUMP,BC OKX$	MOVE.16	{A6}+OVIPOS+2,D3	ADD.16	{A6}+OVIDIM+2,D3	INC.16	D3OKX$:	MOVE.32	#16'10000*(LGSCROLL-2)+(LGSCROLL-2),D4	RET;---------\\; COUPMOVE >;=========/; Dplace une coupure.; in	D4.32	position de la souris (y;x); out	D7.16	erreur; mod	D7.16COUPMOVE:	PUSHM.32 D0..D5	MOVE.32	D4,D5		; D4 <-- position en X	SWAP.32	D5		; D5 <-- position en Y	MOVE.16	{A6}+OVIPOS+2,D3	COMP.16	D3,D4	JUMP,LO	NOH$	ADD.16	{A6}+OVIDIM+2,D3	COMP.16	D3,D4	JUMP,HS	NOH$	MOVE.16	{A6}+OVIPOS+0,D3	COMP.16	D3,D5	JUMP,HS	NOH$	SUB.16	#LGSCROLL,D3	COMP.16	D3,D5	JUMP,LO	NOH$	SUB.16	{A6}+OVIPOS+2,D4	ADD.16	{A6}+OVIASH+OSCPOSV,D4	MOVE.16	{A6}+OVICBX,D3	CALL	COUPDET	JUMP,EQ	R8^MOVEBX$	MOVE.16	{A6}+OVICEX,D3	CALL	COUPDET	JUMP,EQ	R8^MOVEEX$	MOVE.16	{A6}+OVIASH+OSCPOSV,D3	CALL	COUPDET	JUMP,EQ	R8^MOVESX$	MOVE.16	{A6}+OVIASH+OSCPOSV,D3	ADD.16	{A6}+OVIDIM+2,D3	CALL	COUPDET	JUMP,EQ	R8^MOVEIX$	JUMP	EXIT$MOVESX$:	COMP.16	{A6}+OVICEX,D3	JUMP,GE	R8^MOVEEX$	JUMP	R8^MOVEBX$MOVEIX$:	COMP.16	{A6}+OVICBX,D3	JUMP,GE	R8^MOVEEX$;	JUMP	R8^MOVEBX$MOVEBX$:	MOVE.16	{A6}+OVICEX,D0	SUB.16	{A6}+OMAXDI+2,D0	INC.16	D0	COMP.16	#IMMARG,D0	JUMP,GE	R8^MOVEBX2$	MOVE.16	#IMMARG,D0MOVEBX2$:	MOVE.16	{A6}+OVICEX,D1	SUB.16	#16,D1	MOVE.16	{A6}+OVICBX,D3	CALL	COUPMOVEX	; dplace ...	MOVE.16	D3,{A6}+OVICBX	JUMP	OK$MOVEEX$:	MOVE.16	{A6}+OVICBX,D0	ADD.16	#16,D0	MOVE.16	{A6}+OVIDII+2,D1	ADD.16	#IMMARG,D1	MOVE.16	{A6}+OVICBX,D2	ADD.16	{A6}+OMAXDI+2,D2	DEC.16	D2	COMP.16	D2,D1	JUMP,LE	R8^MOVEEX2$	MOVE.16	D2,D1MOVEEX2$:	MOVE.16	{A6}+OVICEX,D3	CALL	COUPMOVEX	; dplace ...	MOVE.16	D3,{A6}+OVICEX	JUMP	OK$NOH$:	MOVE.16	{A6}+OVIPOS+0,D3	COMP.16	D3,D5	JUMP,LO	NOV$	ADD.16	{A6}+OVIDIM+0,D3	COMP.16	D3,D5	JUMP,HS	NOV$	MOVE.16	{A6}+OVIPOS+2,D3	ADD.16	{A6}+OVIDIM+2,D3	COMP.16	D3,D4	JUMP,LO	NOV$	ADD.16	#LGSCROLL,D3	COMP.16	D3,D4	JUMP,HS	NOV$	SUB.16	{A6}+OVIPOS+0,D5	ADD.16	{A6}+OVIASV+OSCPOSV,D5	MOVE.16	D5,D4	MOVE.16	{A6}+OVICBY,D3	CALL	COUPDET	JUMP,EQ	R8^MOVEBY$	MOVE.16	{A6}+OVICEY,D3	CALL	COUPDET	JUMP,EQ	R8^MOVEEY$	MOVE.16	{A6}+OVIASV+OSCPOSV,D3	CALL	COUPDET	JUMP,EQ	R8^MOVESY$	MOVE.16	{A6}+OVIASV+OSCPOSV,D3	ADD.16	{A6}+OVIDIM+0,D3	CALL	COUPDET	JUMP,EQ	R8^MOVEIY$	JUMP	EXIT$MOVESY$:	COMP.16	{A6}+OVICEY,D3	JUMP,GE	R8^MOVEEY$	JUMP	R8^MOVEBY$MOVEIY$:	COMP.16	{A6}+OVICBY,D3	JUMP,GE	R8^MOVEEY$;	JUMP	R8^MOVEBY$MOVEBY$:	MOVE.16	{A6}+OVICEY,D0	SUB.16	{A6}+OMAXDI+0,D0	INC.16	D0	COMP.16	#IMMARG,D0	JUMP,GE	R8^MOVEBY2$	MOVE.16	#IMMARG,D0MOVEBY2$:	MOVE.16	{A6}+OVICEY,D1	SUB.16	#16,D1	MOVE.16	{A6}+OVICBY,D3	CALL	COUPMOVEY	; dplace ...	MOVE.16	D3,{A6}+OVICBY	JUMP	OK$MOVEEY$:	MOVE.16	{A6}+OVICBY,D0	ADD.16	#16,D0	MOVE.16	{A6}+OVIDII+0,D1	ADD.16	#IMMARG,D1	MOVE.16	{A6}+OVICBY,D2	ADD.16	{A6}+OMAXDI+0,D2	DEC.16	D2	COMP.16	D2,D1	JUMP,LE	R8^MOVEEY2$	MOVE.16	D2,D1MOVEEY2$:	MOVE.16	{A6}+OVICEY,D3	CALL	COUPMOVEY	; dplace ...	MOVE.16	D3,{A6}+OVICEY	JUMP	OK$NOV$:	JUMP	EXIT$OK$:	CLR.16	D7		; D7 <-- okEXIT$:	POPM.32	D0..D5	TEST.16	D7		; retour EQ/NE	RET;--------\\; COUPDET >;--------/; Dtecte si l'on est sur une coupure.; in	D3.16	position de la coupure;	D4.16	position de la souris; out	D7.16	erreur; mod	D3.16, D7.16COUPDET:	MOVE.16	#ERDIOUT,D7	SUB.16	#4,D3	COMP.16	D3,D4	JUMP,LO	R8^EXIT$	ADD.16	#4+4,D3	COMP.16	D3,D4	JUMP,HS	R8^EXIT$	CLR.16	D7EXIT$:	TEST.16	D7		; retour EQ/NE	RET;----------\\; COUPMOVEX >;----------/; Dplace une coupure horizontalement.; in	D0.16	minimum;	D1.16	maximum;	D3.16	position initiale; out	D3.16	nouvelle position; mod	D3.32, D7.16COUPMOVEX:	PUSHM.32 D2|D4|D5	MOVE.16	#INVDOT,D2	MOVE.16	D3,D5LOOP$:	LIB	?GETKEY		; attend dplacement souris ...	COMP.16	#KEYMPO,D3	JUMP,NE	END$	CALL	IFMOUSE	JUMP,NE	LOOP$	SUB.16	{A6}+OVIPOS+2,D4	ADD.16	{A6}+OVIASH+OSCPOSV,D4	COMP.16	D0,D4	JUMP,GE	R8^MIN$	MOVE.16	D0,D4MIN$:	COMP.16	D1,D4	JUMP,LE	R8^MAX$	MOVE.16	D1,D4MAX$:	COMP.16	D4,D5	JUMP,EQ	LOOP$	MOVE.16	D5,D3	CALL	COUPDRAWX	; efface l'ancienne	MOVE.16	D4,D3	CALL	COUPDRAWX	; allume la nouvelle	MOVE.16	D4,D5	JUMP	LOOP$END$:	MOVE.16	D5,D3	POPM.32	D2|D4|D5	RET;----------\\; COUPMOVEY >;----------/; Dplace une coupure verticalement.; in	D0.16	minimum;	D1.16	maximum;	D3.16	position initiale; out	D3.16	nouvelle position; mod	D3.32, D7.16COUPMOVEY:	PUSHM.32 D2|D4|D5	MOVE.16	#INVDOT,D2	MOVE.16	D3,D5LOOP$:	LIB	?GETKEY		; attend dplacement souris ...	COMP.16	#KEYMPO,D3	JUMP,NE	END$	CALL	IFMOUSE	JUMP,NE	LOOP$	SWAP.32	D4	SUB.16	{A6}+OVIPOS+0,D4	ADD.16	{A6}+OVIASV+OSCPOSV,D4	COMP.16	D0,D4	JUMP,GE	R8^MIN$	MOVE.16	D0,D4MIN$:	COMP.16	D1,D4	JUMP,LE	R8^MAX$	MOVE.16	D1,D4MAX$:	COMP.16	D4,D5	JUMP,EQ	LOOP$	MOVE.16	D5,D3	CALL	COUPDRAWY	; efface l'ancienne	MOVE.16	D4,D3	CALL	COUPDRAWY	; allume la nouvelle	MOVE.16	D4,D5	JUMP	LOOP$END$:	MOVE.16	D5,D3	POPM.32	D2|D4|D5	RET;---------\\; COUPDRAW >;=========/; Dessine les marques de coupe.; in	-; out	-; mod	D7.16COUPDRAW:	PUSHM.32 D1..D4	MOVE.32	#16'55AA55AA,D1	; D1 <-- trame comme ascenseur	TEST.8	{A0}+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP,BC	R8^BLACK$	; non => BLACK$	MOVE.32	#16'00110044,D1	; D1 <-- trame plus claireBLACK$:	CLR.16	D3	MOVE.16	{A6}+OVICBX,D4	MOVE.32	D1,D2	CALL	COUPDRAWTX	; bande horizontale: grise  gauche	MOVE.16	D4,D3	MOVE.16	{A6}+OVICEX,D4	CLR.32	D2	CALL	COUPDRAWTX	; bande horizontale: efface au milieu	MOVE.16	D4,D3	MOVE.16	{A6}+OVIDII+2,D4	ADD.16	#IMMARG+IMMARG+1000,D4	MOVE.32	D1,D2	CALL	COUPDRAWTX	; bande horizontale: grise  droite	CLR.16	D3	MOVE.16	{A6}+OVICBY,D4	MOVE.32	D1,D2	CALL	COUPDRAWTY	; bande verticale: grise en haut	MOVE.16	D4,D3	MOVE.16	{A6}+OVICEY,D4	CLR.32	D2	CALL	COUPDRAWTY	; bande verticale: efface au milieu	MOVE.16	D4,D3	MOVE.16	{A6}+OVIDII+0,D4	ADD.16	#IMMARG+IMMARG+1000,D4	MOVE.32	D1,D2	CALL	COUPDRAWTY	; bande verticale: grise en bas	MOVE.16	#SETDOT,D2	MOVE.16	{A6}+OVICBX,D3	CALL	COUPDRAWX	MOVE.16	{A6}+OVICEX,D3	CALL	COUPDRAWX	MOVE.16	{A6}+OVICBY,D3	CALL	COUPDRAWY	MOVE.16	{A6}+OVICEY,D3	CALL	COUPDRAWY	POPM.32	D1..D4	RET;-----------\\; COUPDRAWTX >;-----------/; Dessine une trame dans la bande horizontale.; in	D2.32	trame;	D3.16	dbut;	D4.16	fin; out	-; mod	D7.16COUPDRAWTX:	PUSHM.32 D2..D4	PUSHM.32 D3|D4	MOVE.32	D2,D3	MOVE.32	D2,D4	LIB	?DRMDEF		; dfini la trame	POPM.32	D3|D4	SUB.16	{A6}+OVIASH+OSCPOSV,D3	JUMP,HS	R8^BEG3$	CLR.16	D3BEG3$:	COMP.16	{A6}+OVIDIM+2,D3	JUMP,LO	R8^END3$	MOVE.16	{A6}+OVIDIM+2,D3END3$:	ADD.16	{A6}+OVIPOS+2,D3	SUB.16	{A6}+OVIASH+OSCPOSV,D4	JUMP,HS	R8^BEG4$	CLR.16	D4BEG4$:	COMP.16	{A6}+OVIDIM+2,D4	JUMP,LO	R8^END4$	MOVE.16	{A6}+OVIDIM+2,D4END4$:	ADD.16	{A6}+OVIPOS+2,D4	SUB.16	D3,D4	JUMP,EQ	R8^EXIT$	SWAP.32	D4	SWAP.32	D3	MOVE.16	{A6}+OVIPOS+0,D3	SUB.16	#LGSCROLL-1,D3	MOVE.16	#LGSCROLL-2,D4	SWAP.32	D4	SWAP.32	D3	MOVE.16	#LOADDOT,D2	LIB	?DRTRAMEEXIT$:	POPM.32	D2..D4	RET;-----------\\; COUPDRAWTY >;-----------/; Dessine une trame dans la bande verticale.; in	D2.32	trame;	D3.16	dbut;	D4.16	fin; out	-; mod	D7.16COUPDRAWTY:	PUSHM.32 D2..D4	PUSHM.32 D3|D4	MOVE.32	D2,D3	MOVE.32	D2,D4	LIB	?DRMDEF		; dfini la trame	POPM.32	D3|D4	SUB.16	{A6}+OVIASV+OSCPOSV,D3	JUMP,HS	R8^BEG3$	CLR.16	D3BEG3$:	COMP.16	{A6}+OVIDIM+0,D3	JUMP,LO	R8^END3$	MOVE.16	{A6}+OVIDIM+0,D3END3$:	ADD.16	{A6}+OVIPOS+0,D3	SUB.16	{A6}+OVIASV+OSCPOSV,D4	JUMP,HS	R8^BEG4$	CLR.16	D4BEG4$:	COMP.16	{A6}+OVIDIM+0,D4	JUMP,LO	R8^END4$	MOVE.16	{A6}+OVIDIM+0,D4END4$:	ADD.16	{A6}+OVIPOS+0,D4	SUB.16	D3,D4	JUMP,EQ	R8^EXIT$	SWAP.32	D4	SWAP.32	D3	MOVE.16	{A6}+OVIPOS+2,D3	MOVE.16	{A6}+OVIDIM+2,D4	ADD.16	D4,D3	INC.16	D3	MOVE.16	#LGSCROLL-2,D4	MOVE.16	#LOADDOT,D2	LIB	?DRTRAMEEXIT$:	POPM.32	D2..D4	RET;----------\\; COUPDRAWX >;----------/; Dessine une coupure dans la bande horizontale.; in	D2.16	mode de dessin;	D3.16	position en X; out	-; mod	D7.16COUPDRAWX:	PUSHM.32 D1|D3|D4	CLR.16	D1	SUB.16	{A6}+OVIASH+OSCPOSV,D3	JUMP,HS	R8^LEFT$	MOVE.16	#1,D3	INC.16	D1LEFT$:	COMP.16	{A6}+OVIDIM+2,D3	JUMP,LO	R8^RIGHT$	MOVE.16	{A6}+OVIDIM+2,D3	SUB.16	#2,D3	INC.16	D1RIGHT$:	ADD.16	{A6}+OVIPOS+2,D3	SWAP.32	D3	MOVE.16	{A6}+OVIPOS+0,D3	SUB.16	#LGSCROLL-1,D3	MOVE.16	#LGSCROLL-2,D4	SWAP.32	D3	SWAP.32	D4	CLR.16	D4	TEST.16	D1	JUMP,NE	R8^DEF$	PUSHM.32 D2..D4	SWAP.32	D3	SWAP.32	D4	MOVE.16	{A6}+OVIPOS+0,D3	MOVE.16	{A6}+OVIDIM+0,D4	SWAP.32	D4	SWAP.32	D3	MOVE.16	#INVDOT,D2	LIB	?DRSEG	POPM.32	D2..D4DEF$:	PUSH.32	D3	LIB	?DRSEG	POP.32	D3	DEC.16	D3	PUSH.32	D3	LIB	?DRSEG	POP.32	D3	ADD.16	#2,D3	LIB	?DRSEG	POPM.32	D1|D3|D4	RET;----------\\; COUPDRAWY >;----------/; Dessine une coupure dans la bande verticale.; in	D2.16	mode de dessin;	D3.16	position en Y; out	-; mod	D7.16COUPDRAWY:	PUSHM.32 D1|D3|D4	CLR.16	D1	SUB.16	{A6}+OVIASV+OSCPOSV,D3	JUMP,HS	R8^UP$	MOVE.16	#1,D3	INC.16	D1UP$:	COMP.16	{A6}+OVIDIM+0,D3	JUMP,LO	R8^DOWN$	MOVE.16	{A6}+OVIDIM+0,D3	SUB.16	#2,D3	INC.16	D1DOWN$:	ADD.16	{A6}+OVIPOS+0,D3	SWAP.32	D3	MOVE.16	{A6}+OVIPOS+2,D3	ADD.16	{A6}+OVIDIM+2,D3	INC.16	D3	MOVE.32	#LGSCROLL-2,D4	TEST.16	D1	JUMP,NE	R8^DEF$	PUSHM.32 D2..D4	MOVE.16	{A6}+OVIPOS+2,D3	MOVE.16	{A6}+OVIDIM+2,D4	MOVE.16	#INVDOT,D2	LIB	?DRSEG	POPM.32	D2..D4DEF$:	PUSH.32	D3	LIB	?DRSEG	POP.32	D3	SWAP.32	D3	DEC.16	D3	SWAP.32	D3	PUSH.32	D3	LIB	?DRSEG	POP.32	D3	SWAP.32	D3	ADD.16	#2,D3	SWAP.32	D3	LIB	?DRSEG	POPM.32	D1|D3|D4	RET	.END