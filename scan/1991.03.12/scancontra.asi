	.CHAP	SCANCONTRA.ASI;----------\\; CONTRASTE >;==========/; Contraste l'image scanne.; in	-; out	D7.16	erreur; mod	D7.16CONTRASTE:	PUSHM.32 D1|D3|D4|A4	MOVE.16	#ERKSTO,D7	TEST.16	{A6}+OCHDESS2	; module DESSIN2 charg ?	JUMP,EQ	EXIT$		; non => EXIT$	CALL	CONTDBOX	; choix du contraste ...	JUMP,NE	R8^EXIT$	COMP.16	#F1,D3	JUMP,EQ	R8^CONTRA$	COMP.16	#F4,D3	JUMP,EQ	R8^NORM$	JUMP	R8^OK$CONTRA$:	CALL	FILMEF		; rserve mmoire pour image filtre	JUMP,NE	R8^EXIT$	CALL	CONTXFER	; gnre l'image filtre	JUMP	R8^OK$NORM$:	TEST.32	{A6}+OPTMEF	; image filtre existe ?	JUMP,EQ	R8^OK$		; non => OK$	MOVE.32	{A6}+OPTMEF,A4	; A4 <-- ^buffer	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM		; libre la mmoire	CLR.32	{A6}+OPTMEFOK$:	CLR.16	D7EXIT$:	POPM.32	D1|D3|D4|A4	TEST.16	D7		; retour EQ/NE	RET;---------\\; CONTDBOX >;=========/; Choix du contraste.; in	-; out	D3.16	dernire touche;	D7.16	erreur; mod	D3.32, D7.16CONTDBOX:	PUSHM.32 D1|D2|D4|D5|A1..A4	CLR.8	{A6}+OVIMAI	CALL	FLECMOUSE	; lutin souris = flche	MOVE.32	#R16^TDBOX_CONTRA,A2	MOVE.16	#2**BDBSAV,D2	MOVE.32	{A6}+OFDBFAN,D4	DBOX_	OPEN	JUMP,NE	EXIT$	PUSH.32	D4	MOVE.32	#{A6}+OBUDIS+1,A3	MOVE.8	#DRAWMATRIX,{A3}+0	MOVE.8	#SETDOT,{A3}+9	MOVE.16	#2**BDBGCLABEL.OR.200,D2	DBOX_	GETCO	ADD.16	#5,D3	SWAP.32	D3	SUB.16	#10,D3	MOVE.32	D3,{A3}+1	MOVE.32	#R16^FILSM1,A4	MOVE.32	A4,{A3}+5	MOVE.16	#10,D3	LIB	?STRING	MOVE.16	{A0}+ODFCX,D4	MUL.16	#3,D4	INC.16	D4	ADD.16	D4,{A3}+1	MOVE.32	#R16^FILSM2,A4	MOVE.32	A4,{A3}+5	LIB	?STRING	ADD.16	D4,{A3}+1	MOVE.32	#R16^FILSM3,A4	MOVE.32	A4,{A3}+5	LIB	?STRING	ADD.16	D4,{A3}+1	MOVE.32	#R16^FILSM4,A4	MOVE.32	A4,{A3}+5	LIB	?STRING	MOVE.32	#{A6}+OBUDIS+1,A3;	MOVE.8	#DRAWMATRIX,{A3}+0;	MOVE.8	#SETDOT,{A3}+9	MOVE.16	#2**BDBGCLABEL.OR.210,D2	DBOX_	GETCO;	SUB.16	#0,D3	SWAP.32	D3	SUB.16	#20,D3	MOVE.32	D3,{A3}+1	MOVE.32	#R16^CONTL,A4	MOVE.32	A4,{A3}+5	MOVE.16	#10,D3	LIB	?STRING	MOVE.16	{A0}+ODFCX,D4	MUL.16	#6,D4	INC.16	D4	ADD.16	D4,{A3}+1	MOVE.32	#R16^CONTM,A4	MOVE.32	A4,{A3}+5	LIB	?STRING	ADD.16	D4,{A3}+1	MOVE.32	#R16^CONTD,A4	MOVE.32	A4,{A3}+5	LIB	?STRING	POP.32	D4LOOP$:	DBOX_	EDIT	MOVE.32	#R16^TKEY_CONTRA,A1	MOVE.16	#2**BDBCCMM.OR.2**BDBCCFF,D1	DBOX_	CALLC	COMP.16	#KEYMGR,D3	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.16	#F1,D3	JUMP,EQ	CONTRA$	COMP.16	#F4,D3	JUMP,EQ	CANCEL$	COMP.16	#F0,D3	JUMP,EQ	CANCEL$	MOVE.16	D3,D1	AND.16	#16'FF00,D1	COMP.16	#KEYDBOX,D1	JUMP,EQ	R8^KEYDBOX$BIP$:	MOVE.8	#BIPLIT,D3	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$KEYDBOX$:	MOVE.32	#16'FFFF0000,D2	COMP.8	#16,D3	JUMP,LO	R8^MASK$	SWAP.32	D2MASK$:	AND.32	D2,D4	TSET.32	D4:D3	JUMP	LOOP$CONTRA$:	MOVE.32	D4,{A6}+OFDBFANCANCEL$:	DBOX_	CLOSEEXIT$:	POPM.32	D1|D2|D4|D5|A1..A4	TEST.16	D7		; retour EQ/NE	RETTDBOX_CONTRA:	.16	TAB$-TDBOX_CONTRA	.16	SFK$-TDBOX_CONTRA	.16	0,0TAB$:	.8	ODBTEXT	.ASCIZ	"Augmente le contraste d'une photographie trop grise."	.8	ODBCR,ODBCR,ODBCR2	.8	ODBTABX,4	.8	ODBTEXT	.ASCIZ	"""ScanMan"" :"	.8	ODBTABX,30	.8	ODBTEXT	.ASCIZ	"Luminosit :"	.8	ODBCR,ODBCR	.8	ODBTABX,4	.8	ODBLABEL,200	.8	ODBTEXT,0	.8	ODBTABX,30	.8	ODBLABEL,210	.8	ODBTEXT,0	.8	ODBCR	.8	ODBTABX,4	.8	ODBLCIRCLE,0.OR.2**6.OR.2**7,KEYDBOX/16'100,0	.ASCIZ	""	.8	ODBTEXT	.ASCIZ	" "	.8	ODBLCIRCLE,1.OR.2**6.OR.2**7,KEYDBOX/16'100,1	.ASCIZ	""	.8	ODBTEXT	.ASCIZ	" "	.8	ODBLCIRCLE,2.OR.2**6.OR.2**7,KEYDBOX/16'100,2	.ASCIZ	""	.8	ODBTEXT	.ASCIZ	" "	.8	ODBLCIRCLE,3.OR.2**6.OR.2**7,KEYDBOX/16'100,3	.ASCIZ	""	.8	ODBTABX,30	.8	ODBLCIRCLE,16.OR.2**6.OR.2**7,KEYDBOX/16'100,16	.ASCIZ	""	.8	ODBTEXT	.ASCIZ	" "	.8	ODBLCIRCLE,17.OR.2**6.OR.2**7,KEYDBOX/16'100,17	.ASCIZ	""	.8	ODBTEXT	.ASCIZ	" "	.8	ODBLCIRCLE,18.OR.2**6.OR.2**7,KEYDBOX/16'100,18	.ASCIZ	""	.8	ODBTEXT	.ASCIZ	" "	.8	ODBLCIRCLE,19.OR.2**6.OR.2**7,KEYDBOX/16'100,19	.ASCIZ	""	.8	ODBTEXT	.ASCIZ	" "	.8	ODBLCIRCLE,20.OR.2**6.OR.2**7,KEYDBOX/16'100,20	.ASCIZ	""	.8	ODBCR,ODBCR,ODBCR2	.8	ODBTEXT	.ASCIZ	"Remarque: Cette opration demande beaucoup de temps."	.8	ODBCR	.8	ODBTEXT	.ASCIZ	"          Dplacez les coupures pour essayer d'abord"	.8	ODBCR	.8	ODBTEXT	.ASCIZ	"          sur un petit chantillon !"	.8	ODBCR,ODBCR,ODBCR2	.8	ODBBOX,0,F1,TDBMEV	.ASCIZ	" CONTRASTE "	.8	ODBTEXT	.ASCIZ	"  "	.8	ODBBOX,0,F4,TDBMEV	.ASCIZ	" INITIAL "	.8	ODBTEXT	.ASCIZ	"            "	.8	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.8	0SFK$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Contraste"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Initial"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CONTRA:	.16	F1,F2,F3,0,DOKF1-TKEY_CONTRA	.16	F4,F5,F6,0,DOKF4-TKEY_CONTRA	.16	F0,F13,F14,F15,END,0,DOKF0-TKEY_CONTRA	.16	KEYMGR,KEYMMR,KEYMDR,0,DOKMGR-TKEY_CONTRA	.16	KEYMGP,KEYMMP,KEYMDP,0,DOKMGP-TKEY_CONTRA	.16	0;---------\\; CONTXFER >;---------/; Gnre l'image contraste.; in	-; out	-; mod	D7.16CONTXFER:	PUSHM.32 D0..D6|A3|A4	CALL	WAITMOUSE	; met le sablier	CALL	FILPOSO		; rend l'image source positive si ncessaire	MOVE.32	{A6}+OVIPTI,A3	; A3 <-- ^bitmap source	MOVE.32	{A6}+OPTMEF,A4	; A4 <-- ^bitmap destination	MOVE.16	{A6}+OVIDII+2,D1 ; D1 <-- largeur de l'image	MUL.16	{A6}+OVIDII+0,D1 ; D1 <-- nb de points de l'image	SR.32	#3,D1		; D1 <-- /8 car en bytes	MOVE.16	D1,D0	AND.16	#2'11111,D0	SR.32	#5,D1		; D1 <-- /32 car par 8x.L	DEC.16	D1	JUMP,NS	R8^L22$L20$:	MOVE.32	{A3+},{A4+}	; inverse 32 bytes	MOVE.32	{A3+},{A4+}	MOVE.32	{A3+},{A4+}	MOVE.32	{A3+},{A4+}	MOVE.32	{A3+},{A4+}	MOVE.32	{A3+},{A4+}	MOVE.32	{A3+},{A4+}	MOVE.32	{A3+},{A4+}	DJ.16,NMO D1,L20$L22$:	DEC.16	D0	JUMP,NS	R8^L32$L30$:	MOVE.8	{A3+},{A4+}	DJ.16,NMO D0,L30$L32$:	CLR.32	D3	CLR.32	D4	LIB	?DRMDEF	MOVE.32	{A6}+OPTMEF,A4	; A4 <-- ^bitmap destination	MOVE.32	{A6}+OVIDII,D4	; D4 <-- dimensions de l'image	LIB	?OPEBITMAP	CLR.32	D3	MOVE.16	{A6}+OVICBY,D3	SUB.16	#IMMARG,D3	DIV.16	#6,D3	MUL.16	#6,D3	CLR.32	D4	MOVE.16	{A6}+OVICEY,D4	SUB.16	#IMMARG,D4	ADD.16	#6-1,D4	DIV.16	#6,D4	MUL.16	#6,D4	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	CLR.32	D2	MOVE.16	{A6}+OVICBX,D2	SUB.16	#IMMARG,D2	DIV.16	#6,D2	MUL.16	#6,D2	MOVE.16	D2,D3	CLR.32	D2	MOVE.16	{A6}+OVICEX,D2	SUB.16	#IMMARG,D2	ADD.16	#6-1,D2	DIV.16	#6,D2	MUL.16	#6,D2	MOVE.16	D2,D4	SUB.16	D3,D4	MOVE.16	#CLRDOT,D2	LIB	?DRTRAME	; efface la partie coupe	LIB	?CLOBITMAP	MOVE.32	D4,D2		; D2 <-- dimensions	MOVE.32	{A6}+OVIPTI,A3	; A3 <-- ^bitmap source	MOVE.32	{A6}+OVIDII,D5	; D5 <-- dimensions source;	MOVE.32	D3,D3		; D3 <-- origine source	MOVE.32	{A6}+OPTMEF,A4	; A4 <-- ^bitmap destination	MOVE.32	D5,D6		; D6 <-- dimensions destination	MOVE.32	D3,D4		; D4 <-- origine destination	MOVE.32	{A6}+OFDBFAN,D0	; D0 <-- fanions	MOVE.16	#-4,D1	TEST.32	D0:#16	JUMP,BS	R8^LUMIN$	MOVE.16	#-2,D1	TEST.32	D0:#17	JUMP,BS	R8^LUMIN$	MOVE.16	#0,D1	TEST.32	D0:#18	JUMP,BS	R8^LUMIN$	MOVE.16	#+2,D1	TEST.32	D0:#19	JUMP,BS	R8^LUMIN$	MOVE.16	#+4,D1LUMIN$:	SWAP.32	D1	MOVE.16	#2,D1	TEST.32	D0:#0	JUMP,BS	R8^PAS$	MOVE.16	#3,D1	TEST.32	D0:#1	JUMP,BS	R8^PAS$	MOVE.16	#4,D1	TEST.32	D0:#2	JUMP,BS	R8^PAS$	MOVE.16	#2,D1PAS$:	DESS2_	LISSE		; contraste l'image ...	TCLR.8	{A6}+OVIBIN:#BVIIMF ; l'image filtre est positive	CALL	NORMMOUSE	; enlve le sablier	POPM.32	D0..D6|A3|A4	RET	.END