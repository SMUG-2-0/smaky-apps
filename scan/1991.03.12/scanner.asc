	.TITLE	SCANNER.ASC;	--------------------------------------;		(C) 1989 - Daniel Roux;	--------------------------------------;	Source du module SMA_SCAN.LIB	.PROC	M68000	.REF	SMAKY	.REF	MODULES	.REF	xxxHARD	.BASE	10; Rev	Date		Amliorations; ---------------------------------------------------------------------------------------------; 1.0	27.11.89	reprise du programme HANDY de CKSCANREV	= 1SCANVERS= 0	.REV	SCANREV,SCANVERS	.IDENT	"(C)  Daniel ROUX et EPSITEC-system sa"	.START	START; Constantes; ----------NBENT	= 2		; nombre de words d'entte par ligneNB100	= 25		; nombre de words d'une image  100 pppNB200	= 51		; nombre de words d'une image  200 pppNB300	= 77		; nombre de words d'une image  300 pppNB400	= 103		; nombre de words d'une image  400 pppADBYT1	= 16		; priphrique de lecture du 1er octetADBYT2	= 17		; priphrique de lecture du 2me octetADSTAT	= 18		; priphrique de lecture des statusAD12V	= 18		; commande 12[V] scanner 0 = ON, 1 = OFFNBLOOP	= 16'80000	; timeout de 4 secondesVIMARG	= 8		; marges supp. autour du cadreIMMARG	= 20		; marges supp. autour de l'image; Variables; ---------	.LOC	0OPDDIS:	.BLK.32	1	; ^descripteur de la fentreOBUDIS:	.BLK.8	30	; buffer pour write-displayOSMAKY:	.BLK.8	1	; type de SMAKY	.EVENOMUBB1:	.BLK.32	1	; ^1er byte sur MUBUSOMUBB2:	.BLK.32	1	; ^2me byte dur MUBUSOMSTAT:	.BLK.32	1	; ^status de l'interfaceOM12V:	.BLK.32	1	; ^scanner ON-OFFOAFINV:	.BLK.8	1	; 1 => affichage invers	.EVENOPTMEM:	.BLK.32	1	; pointeur buffer de l'imageOLGMEM:	.BLK.32	1	; longeur buffer de l'imageOTIMO:	.BLK.32	1	; timeoutOLARG:	.BLK.16	1	; largeur de l'image en wordODIMX:	.BLK.16	1	; largeur de l'cranODIMY:	.BLK.16	1	; hauteur de l'cranONBWRD:	.BLK.16	1	; nombre de word  afficher  l'cranONBRES:	.BLK.16	1	; nb. de word restant  lireOSCRDB:	.BLK.32	1	; ^dbut de l'cranOVIPTI:	.BLK.32	1	; visu: ^data imageOVIDII:	.BLK.16	2	; visu: dimensions imageOVIASV:	.BLK.8	LSCVAR	; visu: ascenseur verticalOVIASH:	.BLK.8	LSCVAR	; visu: ascenseur horizontalOVIPOS:	.BLK.16	2	; visu: position coin sup/gaucheOVIDIM:	.BLK.16	2	; visu: dimensionsOVICBY:	.BLK.16	1	; visu: dbut coupe en YOVICBX:	.BLK.16	1	; visu: dbut coupe en XOVICEY:	.BLK.16	1	; visu: fin coupe en YOVICEX:	.BLK.16	1	; visu: fin coupe en XOVIPCM:	.BLK.16	2	; visu: position centre de la sourisOVIMAI:	.BLK.8	1	; visu: 1 => main prsenteOVIINV:	.BLK.8	1	; visu: 1 => image inverse	.EVENLGVAR:	.LOC	0START:	MOVE.16	#2,D3	LIB	?MOUSE	CALL	SCAN	EXIT;--------\\; SCAN    >;========/; ; in	-; out	A4.32	^image;	D4.32	dimensions (dy;dx);	D7.16	erreur; mod	D4.32, D7.16, A4.32SCAN:	PUSHM.32 D0..D6|A0..A6	MOVE.32	#LGVAR,D4	MOVE.16	#MTYPCP,D1	GESMEM	?GETMEM		; A4 <-- ^mmoire pour variables	JUMP,NE	EXIT9$	GESMEM	?CLEARMEM	MOVE.32	A4,A6		; A6 <-- ^variables	LIB	?GETPDIS	MOVE.32	A4,{A6}+OPDDIS	MOVE.32	A4,A0		; A0 <-- ^descripteur fentre	NTREL	?GETMACHINE	; Cherche le type de machine	RL.32	#8, D4	MOVE.8	D4,{A6}+OSMAKY	MOVE.16	#ERBIOS,D7	; D7 <-- erreur fatale	COMP.8	#SMAKY324,D4	JUMP,EQ	R8^OKSMAKY$	COMP.8	#SMAKY100,D4	JUMP,NE	EXIT7$OKSMAKY$:	TEST.8	{A0}+ODFMOD:#BFBLANC	JUMP,BS	R8^OKINV$	SET.8	{A6}+OAFINV	; affichage inversOKINV$:	MOVE.8	#SAVWDO,D3	LIB	?AFCAR		; sauve le contenu de l'cran	JUMP,NE	EXIT7$DRAW$:	CALL	VISUDRAW	; dessine les ascenseurs vides	CALL	VISUFOND	; dessine le fond blanc ou noirSK$:	MOVE.32	#R16^SKWAIT,A3	LIB	?AFMENU		; affiche les soft-keysLOOP$:	LIB	?GETCAR		; attend une touche ...	COMP.16	#KEYMGR,D3	JUMP,EQ	LOOP$	COMP.16	#KEYMMR,D3	JUMP,EQ	LOOP$	COMP.16	#KEYMDR,D3	JUMP,EQ	LOOP$	COMP.16	#F0+SHIFT,D3	JUMP,LO NOSF$	COMP.16	#F15+SHIFT,D3	JUMP,HI NOSF$	SUB.16	#SHIFT,D3NOSF$:	COMP.16	#F0,D3	JUMP,EQ END$	COMP.16	#F7,D3	JUMP,EQ SCAN$	COMP.16	#F8,D3	JUMP,EQ SCAN$	COMP.16	#F9,D3	JUMP,EQ SCAN$	COMP.16	#F12,D3	JUMP,EQ INV$BIP$:	MOVE.16	#BIPLIT,D3	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ERROR$:	PUSH.16	D7	MOVE.16	#BIPERR,D3	LIB	?BEEP		; vilain bruit	POP.16	D7	CLR.16	D2	DBOX_	MERROR		; affiche l'erreur	JUMP	DRAW$INV$:	NOT.8	{A6}+OAFINV	CALL	VISUFOND	; dessine le fond blanc ou noir	JUMP	LOOP$SCAN$:	MOVE.32	#R16^SKSCAN,A3	LIB	?AFMENU		; affiche les soft-keys	CALL	SCANINIT	; initialise pour la lecture	CALL	SCANIMAGE	; lit une image ...	JUMP,NE ERROR$	TEST.32	D4	JUMP,EQ RIEN$	MOVE.32	A4,{A6}+OVIPTI	MOVE.32	D4,{A6}+OVIDII	CLR.8	{A6}+OVIINV	; image positive	CALL	VISU		; montre l'image ...	MOVE.32	{A6}+OPTMEM,A4	; A4 <-- ^buffer	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM	CLR.32	{A6}+OPTMEM	CALL	VISUDRAW	; dessine les ascenseurs vides	CALL	VISUFOND	; dessine le fond blanc ou noir	COMP.16	#F0,D3	JUMP,EQ END$	COMP.16	#F7,D3	JUMP,EQ SCAN$	COMP.16	#F8,D3	JUMP,EQ SCAN$	COMP.16	#F9,D3	JUMP,EQ SCAN$	JUMP	SK$RIEN$:	MOVE.32	{A6}+OPTMEM,A4	; A4 <-- ^buffer	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM	CLR.32	{A6}+OPTMEM	JUMP	SK$END$:	PUSH.16	D7	MOVE.8	#GETWDO,D3	LIB	?AFCAR		; restitue le contenu de l'cran	POP.16	D7EXIT7$:	PUSH.16	D7	MOVE.32	A6,A4	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM		; libre les variables	POP.16	D7EXIT9$:	POPM.32	D0..D6|A0..A6	TEST.16	D7		; retour EQ/NE	RET;---------\\; SCANINIT >;=========/; Initialise pour la lecture du scanner.; in	-; out	-; mod	D7.16SCANINIT:	COMP.8	#SMAKY100,{A6}+OSMAKY	JUMP,EQ	SM100$SM324$:	MOVE.32	#NBLOOP*4,{A6}+OTIMO	MOVE.32	#SM324ADMUBUS+ADBYT1,{A6}+OMUBB1	MOVE.32	#SM324ADMUBUS+ADBYT2,{A6}+OMUBB2	MOVE.32	#SM324ADMUBUS+ADSTAT,{A6}+OMSTAT	MOVE.32	#SM324ADMUBUS+AD12V,{A6}+OM12V	JUMP	EXIT$SM100$:	MOVE.32	#NBLOOP,{A6}+OTIMO	MOVE.32	#SM100ADMUBUS+ADBYT1*2,{A6}+OMUBB1	MOVE.32	#SM100ADMUBUS+ADBYT2*2,{A6}+OMUBB2	MOVE.32	#SM100ADMUBUS+ADSTAT*2,{A6}+OMSTAT	MOVE.32	#SM100ADMUBUS+AD12V*2,{A6}+OM12V;	JUMP	EXIT$EXIT$:	RET;----------\\; SCANIMAGE >;==========/; Lit une image entire depuis le scanner.; in	-; out	A4.32	^image;	D4.32	dimensions (dy;dx);	D7.16	erreur; mod	D4.32, D7.16, A4.32SCANIMAGE:	PUSHM.32 D0|D1|D3|D5|A0|A5	MOVE.8	#AFCCMO,D3	LIB	?AFCAR		; enlve la souris	GESMEM	?ARGMEM		; D4/D5 <-- total libre/plus grand trou	MOVE.32	D5,D4	SUB.32	#10000,D4	; D4 <-- il doit rester 10 Kbytes !	MOVE.16	#ERNEMEM,D7	; D7 <-- pas assez de mmoire	COMP.32	#100000,D4	; reste au moins 100 Kbytes ?	JUMP,LT	EXIT$		; non => EXIT$	COMP.32	#1000000,D4	; reste plus de 1 Mbyte ?	JUMP,LT R8^MEM$		; non => R8^MEM$	MOVE.32	#1000000,D4	; D4 <-- pas plus que 1 MbyteMEM$:	ADD.32	#32,D4	MOVE.16	#MTYPCP,D1	GESMEM	?GETMEM		; A4 <-- mmoire du buffer d'image	JUMP,NE EXIT$	SUB.32	#32,D4	MOVE.32	A4,{A6}+OPTMEM	MOVE.32	D4,{A6}+OLGMEM	MOVE.32	{A6}+OPDDIS,A0	; A0 <-- ^descripteur fentre	MOVE.16	{A0}+ODFFDY,D0	SUB.16	{A0}+ODFC1Y,D0	SUB.16	{A0}+ODFC2Y,D0	SUB.16	#LGSCROLL+LGSCROLL+VIMARG,D0	MOVE.16	D0,{A6}+ODIMY	MOVE.16	{A0}+ODFFDX,D0	SUB.16	#VIMARG+LGSCROLL+LGSCROLL+VIMARG,D0	MOVE.16	D0,{A6}+ODIMX	MOVE.32	{A0}+ODFABS,A4	MOVE.16	{A0}+ODFWBX,D0	ADD.16	#VIMARG+LGSCROLL,D0	SR.16	#3,D0	ADD.A16	D0,A4	MOVE.16	{A0}+ODFWBY,D0	ADD.16	{A0}+ODFC1Y,D0	ADD.16	{A0}+ODFC2Y,D0	ADD.16	#LGSCROLL,D0	MUL.16	{A0}+ODFIIY,D0	ADD.32	D0,A4	MOVE.32	A4,{A6}+OSCRDB	MOVE.16	#NB400,{A6}+OLARG	MOVE.16	{A6}+OLARG,D0	; D0 <-- largeur image en words	MOVE.16	{A6}+ODIMX,D1	; D1 <-- largeur de l'cran en points	SR.16	#4,D1		; D1 <-- largeur de l'cran en words	MOVE.16	D0,{A6}+ONBWRD	CLR.16	{A6}+ONBRES	COMP.16	D1,D0	JUMP,LS	LGOK$	MOVE.16	D1,{A6}+ONBWRD	SUB.16	D1,D0	MOVE.16	D0,{A6}+ONBRESLGOK$:	MOVE.32	#R16^SCANALL,A5	; A5 <-- ^routine  excuter en IOF	NTREL	?IEP15TRP	; init le TRAP #15	JUMP,NE	END$	TRAP	#15		; passe en mode "superviseur"	MOVE.32	#0,A5	NTREL	?IEP15TRP	; init le TRAP #15	CLR.16	D7END$:	TEST.16	D7	JUMP,EQ EXIT$	PUSH.16	D7	MOVE.32	{A6}+OPTMEM,A4	; A4 <-- ^buffer	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM		; libre l'image lue	CLR.32	{A6}+OPTMEM	POP.16	D7EXIT$:	PUSH.16	D7	MOVE.8	#AFSCMO,D3	LIB	?AFCAR		; remet la souris	POP.16	D7	POPM.32	D0|D1|D3|D5|A0|A5	TEST.16	D7	RET;--------\\; SCANALL >;--------/; Lit toute l'image depuis le scanner.; in	-; out	A4.32	^image;	D4.32	dimensions (dy;dx); mod	D4.32, D7.16, A4.32SCANALL:	PUSHM.32 D3|D5|D6|A0..A3	OR.16	#16'0700,SF	; met IOF total	MOVE.32	{A6}+OM12V,A0	MOVE.8	#0,{A0}		; 12V scanner ON	MOVE.32	{A6}+OPDDIS,A0	; A0 <-- ^descripteur cran	MOVE.32	{A6}+OPTMEM,A2	; A2 <-- ^buffer	MOVE.32	{A6}+OSCRDB,A3	; A3 <-- ^cran	CLR.16	D6		; D6 <-- compteur de ligne sur l'cran	CLR.16	D5		; D5 <-- compteur de ligne dans buffer	CLR.16	D3		; D3 <-- lg max ligne lueLOOP$:	COMP.16	{A6}+ODIMY,D6	; est-on en bas de l'cran ?	JUMP,LO	R8^NOTOP$	; non => NOTOP$	MOVE.32	{A6}+OSCRDB,A3	; A3 <-- ^haut de l'cran	CLR.16	D6		; D6 <-- r-arme le compteur cranNOTOP$:	CALL	SCANLINE	; lit une ligne sur le scanner ...	JUMP,NE	R8^END$	INC.16	D5		; D5 <-- ligne suivante dans buffer	INC.16	D6		; D6 <-- ligne suivante dans l'cran	ADD.A16	{A0}+ODFIIY,A3	; A3 <-- ^ligne cran suivante	MOVE.32	{A6}+OMUBB2,A1	MOVE.8	D0,{A1}		; prpare pour la ligne suivante	ADD.16	#2,D4	COMP.16	D4,D3	JUMP,HS	R8^LITTLE$	MOVE.16	D4,D3		; D3 <-- lg max ligne lueLITTLE$:	MOVE.16	D3,D4	MUL.16	D5,D4		; D4 <-- place occupe une fois tendu	COMP.32	{A6}+OLGMEM,D4	JUMP,LO	LOOP$END$:	MOVE.32	{A6}+OM12V,A0	MOVE.8	#1,{A0}		; 12V scanner OFF	CALL	SCANEXTEND	; tend l'image	POPM.32	D3|D5|D6|A0..A3	POP.32	A0	POP.32	D0	RETSF;---------\\; SCANLINE >;---------/; Lit toute une ligne depuis le scanner.; in	A2.32	^dans buffer;	A3.32	^dans l'cran;	D5.16	compteur de ligne dans buffer; out	A2.32	^plus loin;	D4.16	lg ligne lue;	D7.16	erreur; mod	D4.32, D7.16, A2.32SCANLINE:	PUSHM.32 D1|D2|D3|A0|A1|A3|A4|A5	CLR.16	D7		; D7 <-- ok	MOVE.32	{A6}+OMUBB1,A0	MOVE.32	{A6}+OMUBB2,A1	MOVE.32	{A6}+OMSTAT,A4	MOVE.16	#NBENT-1,D1	; D1 <-- lg en-tte	MOVE.32	{A6}+OTIMO,D3	; D3 <-- prpare un timeout de 2 secondes	TEST.16	D5		; premire lecture ?	JUMP,NE	R8^WLINE$	; non => WLINE$	SL.32	#3,D3		; D3 <-- prpare un timeout de 16 secondesWLINE$:	TEST.8	{A4}:#6		; prend une autre ligne ?	JUMP,BS	R8^WHEAD$	; oui => WHEAD$	DEC.32	D3	JUMP,NE	WLINE$	MOVE.16	#ERTIMO,D7	; D7 <-- timeout	JUMP	EXIT$WHEAD$:	TEST.8	{A4}:#7		; 16 bits reus ?	JUMP,BC	WHEAD$	MOVE.8	{A1},D3		; D3 <-- lit les poids forts	MOVE.8	{A0},D3		; D3 <-- lit les poids faibles	MOVE.8	D3,{A0}	DJ.16,NMO D1,WHEAD$	MOVE.32	A2,A5		; A5 <-- ^dernier word non-nul	MOVE.32	A2,D4		; D4 <-- ^dbut ligne	MOVE.16	{A6}+ONBWRD,D1	; D1 <-- nb de words  lire	DEC.16	D1		; D1 <-- -1  cause NMO	TEST.8	{A6}+OAFINV	; affichage invers ?	JUMP,NE	R8^ILOOP$	; oui => ILOOP$NLOOP$:	TEST.8	{A4}:#7		; 16 bits reus ?	JUMP,BC	NLOOP$	MOVE.8	{A1},D3		; D3 <-- lit les poids forts	SL.16	#8,D3	MOVE.8	{A0},D3		; D3 <-- lit les poids faibles	MOVE.8	D3,{A0}	MOVE.16	D3,{A2+}	; buffer de lecture <-- 16 bits lus	JUMP,EQ	R8^NZERO$	MOVE.32	A2,A5		; A5 <-- ^dernier word non-nulNZERO$:	MOVE.16	D3,{A3+}	; cran <-- 16 bits lus	DJ.16,NMO D1,NLOOP$	JUMP	R8^LAST$ILOOP$:	TEST.8	{A4}:#7		; 16 bits reus ?	JUMP,BC	ILOOP$	MOVE.8	{A1},D3		; D3 <-- lit les poids forts	SL.16	#8,D3	MOVE.8	{A0},D3		; D3 <-- lit les poids faibles	MOVE.8	D3,{A0}	MOVE.16	D3,{A2+}	; buffer de lecture <-- 16 bits lus	JUMP,EQ	R8^IZERO$	MOVE.32	A2,A5		; A5 <-- ^dernier word non-nulIZERO$:	NOT.16	D3	MOVE.16	D3,{A3+}	; cran <-- 16 bits lus	DJ.16,NMO D1,ILOOP$;	JUMP	R8^LAST$LAST$:	MOVE.16	{A6}+ONBRES,D1	; D1 <-- nb de words restants	JUMP,EQ	R8^END$	DEC.16	D1		; D1 <-- -1  cause NMOLLOOP$:	TEST.8	{A4}:#7		; 16 bits reus ?	JUMP,BC	LLOOP$	MOVE.8	{A1},D3		; D3 <-- lit les poids forts	SL.16	#8,D3	MOVE.8	{A0},D3		; D3 <-- lit les poids faibles	MOVE.8	D3,{A0}	MOVE.16	D3,{A2+}	; buffer de lecture <-- 16 bits lus	JUMP,EQ	R8^LZERO$	MOVE.32	A2,A5		; A5 <-- ^dernier word non-nulLZERO$:	DJ.16,NMO D1,LLOOP$END$:	MOVE.32	A5,A2		; A2 <-- ^dernier word non-nul	SUB.32	A5,D4	NEG.32	D4		; D4 <-- lg	MOVE.16	D4,{A2+}	; buffer <-- lgEXIT$:	POPM.32	D1|D2|D3|A0|A1|A3|A4|A5	TEST.16	D7		; retour EQ/NE	RET;-----------\\; SCANEXTEND >;-----------/; Etend l'image compresse.; in	A2.32	^fin lecture dans buffer;	D3.16	lg max ligne;	D5.16	nb lignes lues; out	A4.32	^image;	D4.32	dimensions (dy;dx); mod	D4.32, D7.16, A4.32SCANEXTEND:	PUSHM.32 D1..D3|A2	MOVE.32	{A6}+OPTMEM,A4	ADD.32	{A6}+OLGMEM,A4	CLR.32	D4		; D4 <-- dimensions nulles	SUB.16	#2,D3	JUMP,NS	EXIT$	MOVE.16	D5,D4		; D4 <-- hauteur	SWAP.32	D4	MOVE.16	D3,D4		; D4 <-- largeur en bytes	SL.16	#3,D4		; D4 <-- largeur en pointsLOOP$:	MOVE.16	{-A2},D1	; D1 <-- lg ligne	MOVE.16	D3,D2	SUB.16	D1,D2		; D2 <-- lg  remplir de zros	JUMP,EQ	R8^MAX$	SR.16	#1,D2		; D2 <-- /2 car .16	DEC.16	D2		; D2 <-- -1 car NMOZERO$:	CLR.16	{-A4}	DJ.16,NMO D2,ZERO$MAX$:	SR.16	#1,D1		; D1 <-- /2 car .16	JUMP,EQ	R8^NEXT$	DEC.16	D1		; D1 <-- -1 car NMOXFER$:	MOVE.16	{-A2},{-A4}	DJ.16,NMO D1,XFER$NEXT$:	DEC.16	D5		; encore une ligne ?	JUMP,NE	LOOP$		; oui => LOOP$EXIT$:	POPM.32	D1..D3|A2	RETSKWAIT:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Scanne une image"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"          Ngatif"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;SKSCAN:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	"    Dplacez     "	.ASCIZ	"   le scanner... "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;SKVISU:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Scanne une image"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"          Ngatif"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"             Imp."		;     ;     ;     ;	.EVEN	.INS	SCANVISU.ASI	.INS	SCANMISC.ASI	.END