	.CHAP	SCANMISC.ASI;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.32	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.16	erreur (ERKSTO si annule); mod	D7.16ERCALL:	PUSHM.32 D1|D2	MOVE.16	#DBOX_ERCALL,D1	; D1 <-- numro de l'appel	MOVE.16	#2**BDBEXTEND,D2 ; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.32	D1|D2	TEST.16	D7		; retour EQ/NE	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.16	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.32	D3	LIB	?IFMOUSE	JUMP,NE	R8^L90$	ADD.16	{A6}+OVIPCM+2,D4	SUB.16	{A0}+ODFFX,D4	JUMP,HS	R8^L20$	CLR.16	D4	MOVE.16	#ERDIOUT,D7L20$:	SWAP.32	D4	ADD.16	{A6}+OVIPCM+0,D4	SUB.16	{A0}+ODFFY,D4	JUMP,HS	R8^L30$	CLR.16	D4	MOVE.16	#ERDIOUT,D7L30$:	SWAP.32	D4L90$:	POP.32	D3	TEST.16	D7		; retour EQ/NE	RET;----------\\; MAINMOUSE >;==========/; Remplace la flche de la souris par une main.; in	-; out	D4.L	position relative (y;x); mod	D4.L, D7.WMAINMOUSE:	PUSHM.32 D3|A3|A4	MOVE.32	#{A6}+OBUDIS+1,A3	MOVE.8	#DRAWPMOUSE,{A3}+0	MOVE.32	#R16^CHAIR$,A4	MOVE.32	A4,{A3}+1	MOVE.32	#R16^FOND$,A4	MOVE.32	A4,{A3}+5	MOVE.16	#9,D3	LIB	?STRING		; utilise un lutin spcial pour la souris	MOVE.32	#16'10000*(16/2)+(16/2),{A6}+OVIPCM	POPM.32	D3|A3|A4	RETCHAIR$:	.8	16,16	.16	2'0000000110000000	.16	2'0001101001110000	.16	2'0010011001001000	.16	2'0010011001001000	.16	2'0001001001001010	.16	2'0001001001001101	.16	2'0110100000001001	.16	2'1001100000001001	.16	2'1000100000000010	.16	2'0100000000000010	.16	2'0010000000000010	.16	2'0010000000000100	.16	2'0001000000000100	.16	2'0000100000001000	.16	2'0000010000001000	.16	2'0000010000001000FOND$:	.8	16,16	.16	2'0000000110000000	.16	2'0001101111110000	.16	2'0011111111111000	.16	2'0011111111111000	.16	2'0001111111111010	.16	2'0001111111111111	.16	2'0110111111111111	.16	2'1111111111111111	.16	2'1111111111111110	.16	2'0111111111111110	.16	2'0011111111111110	.16	2'0011111111111100	.16	2'0001111111111100	.16	2'0000111111111000	.16	2'0000011111111000	.16	2'0000011111111000	.EVEN;----------\\; FLECMOUSE >;==========/; Remet la flche comme lutin pour la souris.; in	-; out	-; mod	D7.WFLECMOUSE:	PUSHM.32 D3|A3	MOVE.32	#{A6}+OBUDIS+1,A3	MOVE.8	#DRAWPMOUSE,{A3}+0	CLR.32	{A3}+1	CLR.32	{A3}+5	MOVE.16	#9,D3	LIB	?STRING		; lutin de la souris de nouveau normal	CLR.32	{A6}+OVIPCM	POPM.32	D3|A3	RET;----------\\; NORMMOUSE >;==========/; in	-; out	-; mod	-NORMMOUSE:	PUSHM.32 D4|D7	MOVE.16	#1,D4	LIB	?WAITMOUSE	POPM.32	D4|D7	RET;----------\\; WAITMOUSE >;==========/; in	-; out	-; mod	-WAITMOUSE:	PUSHM.32 D4|D7	CLR.16	D4	LIB	?WAITMOUSE	POPM.32	D4|D7	RET;--------\\; RECTAND >;========/; Effectue un "et" (intersection) entre deux rectangles.; in	D1/D2	P1/P2 rectangle A;	D3/D4	P1/P2 rectangle B; out	D3/D4	P1/P2 rectangle A & B;	D7.16	erreur si pas d'intersection; mod	D3.32, D4.32, D7.16RECTAND:	MOVE.16	#ERDIOUT,D7	COMP.16	D1,D3	JUMP,GE	R8^L10$	MOVE.16	D1,D3L10$:	COMP.16	D2,D3	JUMP,LE	R8^L12$	MOVE.16	D2,D3L12$:	COMP.16	D1,D4	JUMP,GE	R8^L20$	MOVE.16	D1,D4L20$:	COMP.16	D2,D4	JUMP,LE	R8^L22$	MOVE.16	D2,D4L22$:	COMP.16	D3,D4	JUMP,EQ	R8^EXIT$	SWAP.32	D1	SWAP.32	D2	SWAP.32	D3	SWAP.32	D4	COMP.16	D1,D3	JUMP,GE	R8^L14$	MOVE.16	D1,D3L14$:	COMP.16	D2,D3	JUMP,LE	R8^L16$	MOVE.16	D2,D3L16$:	COMP.16	D1,D4	JUMP,GE	R8^L24$	MOVE.16	D1,D4L24$:	COMP.16	D2,D4	JUMP,LE	R8^L26$	MOVE.16	D2,D4L26$:	COMP.16	D3,D4	JUMP,EQ	R8^EXIT$	SWAP.32	D1	SWAP.32	D2	SWAP.32	D3	SWAP.32	D4	CLR.16	D7EXIT$:	TEST.16	D7		; retour EQ/NE	RET	.END