	.CHAP	SCANDBOX.ASI;----------\\; DBOXSAUVE >;==========/; Edite un nom d'image en sortie (sauve).; in	A4.L	^objet image; out	D3.W	dernire touche (F1/F0);	D7.16	erreur; mod	D3.L, D7.WDBOXSAUVE:	PUSHM.32 D1|D2|D4|D5|A2..A5	CLR.8	{A6}+OVIMAI	CALL	FLECMOUSE	; lutin souris = flche	MOVE.32	#{A6}+OBUFIO,A5	; A5 <-- ^nom du fichier	MOVE.32	#R16^TDBOX_IOIM,A3	MOVE.32	#R16^TEXIM$,A4	; A4 <-- ^critre de recherche (extension)	MOVE.16	#DBOX_EXTRAIT,D1 ; D1 <-- code du sous-appel	MOVE.16	#2**BDBSAV.OR.2**BDBEXTEND,D2	MOVE.32	#LBUFILE.OR.2**BDBIOEXT1,D3	DBOX_	EXTEND		; dbox: attend la rponse ...EXIT$:	POPM.32	D1|D2|D4|D5|A2..A5	TEST.16	D7		; retour EQ/NE	RETTEXIM$:	.ASCIZ	".IMAGE"TDBOX_IOIM:	.ASCIZ	"SCAN"		; nom du logiciel	.ASCIZ	"Fimage"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.8	0	.EVEN;----------\\; DBOXRESOL >;==========/; Choix de la rsolution.; in	-; out	D3.16	dernire touche;	D7.16	erreur; mod	D3.32, D7.16DBOXRESOL:	PUSHM.32 D1|D2|D4|D5|A1..A4	CLR.8	{A6}+OVIMAI	CALL	FLECMOUSE	; lutin souris = flche	MOVE.32	#R16^TDBOX_RESOL,A2	MOVE.16	#2**BDBSAV,D2	MOVE.32	{A6}+OREFAN,D4	DBOX_	OPEN	JUMP,NE	EXIT$LOOP$:	DBOX_	EDIT	MOVE.32	#R16^TKEY_RESOL,A1	MOVE.16	#2**BDBCCMM.OR.2**BDBCCFF,D1	DBOX_	CALLC	COMP.16	#KEYMGR,D3	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.16	#F1,D3	JUMP,EQ	R8^RESOL$	COMP.16	#F0,D3	JUMP,EQ	R8^CANCEL$	COMP.16	#F4,D3	JUMP,EQ	R8^PPP100$	COMP.16	#F5,D3	JUMP,EQ	R8^PPP200$	COMP.16	#F6,D3	JUMP,EQ	R8^PPP300$	COMP.16	#F7,D3	JUMP,EQ	R8^PPP400$BIP$:	MOVE.8	#BIPLIT,D3	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$PPP100$:	MOVE.32	#2**BRE100,D4	JUMP	LOOP$PPP200$:	MOVE.32	#2**BRE200,D4	JUMP	LOOP$PPP300$:	MOVE.32	#2**BRE300,D4	JUMP	LOOP$PPP400$:	MOVE.32	#2**BRE400,D4	JUMP	LOOP$RESOL$:	MOVE.32	D4,{A6}+OREFANCANCEL$:	DBOX_	CLOSEEXIT$:	POPM.32	D1|D2|D4|D5|A1..A4	TEST.16	D7		; retour EQ/NE	RETTDBOX_RESOL:	.16	TAB$-TDBOX_RESOL	.16	SFK$-TDBOX_RESOL	.16	0,0TAB$:	.8	ODBTEXT	.ASCIZ	"Indiquez o est plac le bouton situ "	.8	ODBCR	.8	ODBTEXT	.ASCIZ	"sur la droite du ""ScanMan"" :"	.8	ODBCR,ODBCR	.8	ODBLCIRCLE,BRE100	.ASCIZ	" 1  (100 ppp)"	.8	ODBCR	.8	ODBLCIRCLE,BRE200	.ASCIZ	" 2  (200 ppp)"	.8	ODBCR	.8	ODBLCIRCLE,BRE300	.ASCIZ	" 3  (300 ppp)"	.8	ODBCR	.8	ODBLCIRCLE,BRE400	.ASCIZ	" 4  (400 ppp)"	.8	ODBCR,ODBCR,ODBCR	.8	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.8	ODBTEXT	.ASCIZ	"   "	.8	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.8	0SFK$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" 100   200   300 "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" 400             "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_RESOL:	.16	F1,F2,F3,0,DOKF1-TKEY_RESOL	.16	F4,0,DOKF4-TKEY_RESOL	.16	F5,0,DOKF5-TKEY_RESOL	.16	F6,0,DOKF6-TKEY_RESOL	.16	F7,0,DOKF7-TKEY_RESOL	.16	F0,F13,F14,F15,END,0,DOKF0-TKEY_RESOL	.16	KEYMGR,KEYMMR,KEYMDR,0,DOKMGR-TKEY_RESOL	.16	KEYMGP,KEYMMP,KEYMDP,0,DOKMGP-TKEY_RESOL	.16	0DOKF1:	MOVE.16	#F1,D3	RETDOKF4:	MOVE.16	#F4,D3	RETDOKF5:	MOVE.16	#F5,D3	RETDOKF6:	MOVE.16	#F6,D3	RETDOKF7:	MOVE.16	#F7,D3	RETDOKF0:	MOVE.16	#F0,D3	RETDOKMGR:	MOVE.16	#KEYMGR,D3	RETDOKMGP:	MOVE.16	#KEYMGP,D3	RET	.END