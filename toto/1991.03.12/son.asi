;---------------\\; AUDIO_ACCORD   >;===============/;; Joue un accord, compatible avec l'appel LIB ?ACCORD;; In	D0.W	premire note;	D1.W	seconde note;	D2.W	troisme note;	D4.W	dure en [20ms];	D4.LH	enveloppe en [20ms];	A4.L	destination; Out	D4.L	longueur; Mod	D4.L, D7.W_AudioAccord:	PUSHM.L	D0..D3,D5..D6,A4	LOAD.L	D7,D4	SWAP.W	D7	MUL.WU	D4,#35000/50	; D4.W <- longueur	PUSH.L	D4	LOAD.W	D5,#SonNivMax/3	; coefficient	MUL.WU	D7,#35000/50	; D7.L <- enveloppe	DIV.WU	D7,#SonNivMax/3	LOAD.W	D6,D7	SWAP.W	D7	LOAD.W	D7,D6		; copie dans high word	TCLR.L	D6:#19	TEST.W	D0	JUMP,EQ	S1$	TSET.L	D6:#19S1$:	SWAP.W	D0		; mmorise dans le high word	LOAD.W	D0,#1		; rechargement au coup suivant	TCLR.L	D6:#20	TEST.W	D1	JUMP,EQ	S2$	TSET.L	D6:#20S2$:	SWAP.W	D1		; idem pour les 3 notes	LOAD.W	D1,#1	TCLR.L	D6:#21	TEST.W	D2	JUMP,EQ	S3$	TSET.L	D6:#21S3$:	SWAP.W	D2	LOAD.W	D2,#1	TCLR.L	D6:#16		; dpart  zro	TSET.L	D6:#17	TCLR.L	D6:#18Echant$:			; boucle des chantillons	DEC.W	D0	JUMP,NE	E1$	;AF	1	TNOT.L	D6:#16	SWAP.W	D0		; recharge le low word	LOAD.W	D6,D0	SWAP.W	D0	LOAD.W	D0,D6E1$:	DEC.W	D1	JUMP,NE	E2$	;AF	2	TNOT.L	D6:#17	SWAP.W	D1		; recharge le low word	LOAD.W	D6,D1	SWAP.W	D1	LOAD.W	D1,D6E2$:	DEC.W	D2	JUMP,NE	E3$	;AF	3	TNOT.L	D6:#18	SWAP.W	D2		; recharge le low word	LOAD.W	D6,D2	SWAP.W	D2	LOAD.W	D2,D6E3$:	DEC.W	D7	JUMP,NE	Val$	;AF	C	DEC.W	D5		; coef. diminue	SWAP.W	D7		; recharge le low word	LOAD.W	D6,D7	SWAP.W	D7	LOAD.W	D7,D6Val$:	LOAD.W	D3,D5	SR.W	D3		; 1/2 coef -> D3	NEG.W	D3	ADD.W	D3,#SonNivMax/2	; + niveau "zro"	TEST.L	D6:#19	JUMP,BC	B1$	TEST.L	D6:#16 		; calcul de la valeur	JUMP,BC	B1$	ADD.W	D3,D5B1$:	TEST.L	D6:#20	JUMP,BC	B2$	TEST.L	D6:#17	JUMP,BC	B2$	ADD.W	D3,D5B2$:	TEST.L	D6:#21	JUMP,BC	B3$	TEST.L	D6:#18	JUMP,BC	B3$	ADD.W	D3,D5B3$:	LOAD.B	(A4+),D3	; crit l'chantillon !!	DEC.L	D4		; compteur de dure	JUMP,NE	Echant$	POP.L	D4	POPM.L	D0..D3,D5..D6,A4	RET