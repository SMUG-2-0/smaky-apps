	.SBTTL	TSMEMORY.ASIMEMORY:	CALL	AFMENUJ		; affiche les soft-keys	CALL	CCMO		; enlve la souris	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	LOAD.L	A4,#R16"TMENU$	CALL	CHEXMEMORY	; OCHMAP <-- icnes existantes	CALL	CHDRAW		; dessine les choix	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	CALL	CLRFIFO		; vide le fifo du clavier	CALL	SCMO		; remet la sourisMENU$:	LOAD.L	A4,#R16"TMENU$	CALL	CHMENU		; choix selon menu ...	LOAD.W	D4,D3	SUB.W	D4,#'1	JUMP',LO NO18$	COMP.W	D4,#8	JUMP,LO GO$NO18$:	COMP.W	D3,#'9	JUMP,EQ LOOP	COMP.W	D3,#F0	JUMP,EQ LOOP	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	MENU$TMENU$:	.W	ICOMM+0	.W	ICOMM+1	.W	ICOMM+2	.W	ICOMM+3	.W	ICOMM+4	.W	ICOMM+5	.W	ICOMM+6	.W	ICOMM+7	.W	ICOANNULEGO$:	CALL	CCMO		; enlve la souris	CALL	MMINIT		; prpare un mmory	JUMP,NE ERROR	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	MMCADRE		; affiche le cadre	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	LOAD.L	A4,#R16"TAMVASC	CALL	ICOMALL		; va sur l'ascenseur ...	CALL	JGFULL		; rempli la jauge	CALL	JGBAGUETTE	; coup de baguette magique ...	CALL	MMSHOW		; affiche toutes les cartes retournes	LOAD.L	(A6)+OJGECT,(A6)+OTIME	CLR.W	(A6)+OJGECP	CALL	CLRFIFO		; vide le fifo du clavier	CALL	SCMO		; remet la sourisFIRST$:	LOAD.W	D1,#-1		; D1 <-- pas de premire carte retourneLOOP$:	CALL	JGECOULE	; coule la jauge	JUMP,NE BAD$	LOAD.W	D4,#2	NTREL	?SETTIM	LIB	?GETCAR		; clavier/souris ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE LOOP$KEY$:	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$BIP$:	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	LOOP$CLIC$:	CALL	MMMOVE		; choisit une carte ...	JUMP,NE BIP$	CALL	MMTOURNE	; tourne la carte ct face	LOAD.W	D2,#SETDOT	CALL	MMHILIF		; indique carte retourne	COMP.W	D1,#-1		; premire carte retourne ?	JUMP',NE SECOND$	; non => SECOND$				; oui =>	LOAD.W	D1,D3		; D1 <-- numro de la carte retourne	JUMP	LOOP$SECOND$:	LOAD.W	D0,D3		; D0 <-- deuxime carte retourne	LOAD.L	A4,#(A6)+OMMTAB	CLR.L	D2	LOAD.B	D2,(A4)+(D0.W)	TCLR.L	D2:#7	SUB.W	D2,#2	DIV.WU	D2,(A6)+OMMNBG	; D2 <-- premire carte	CLR.L	D3	LOAD.B	D3,(A4)+(D1.W)	TCLR.L	D3:#7	SUB.W	D3,#2	DIV.WU	D3,(A6)+OMMNBG	; D3 <-- deuxime carte	COMP.W	D2,D3		; tourne deux fois la mme ?	JUMP',EQ YOUPIE$	; oui => YOUPIE$	CALL	JGFAUX		; indique que c'est faux	LOAD.W	D2,#50*2/2	; D2 <-- 2 secondes	COMP.W	(A6)+OMMNBG,#1	JUMP',EQ VISU$	LOAD.W	D2,#50*4/2	; D2 <-- 4 secondesVISU$:	CALL	JGECOULE	; coule la jauge	JUMP,NE BAD0$	LOAD.W	D4,#2	NTREL	?SETTIM	LIB	?GETCAR		; clavier/souris ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP',EQ PRESS$	DECJ.W,NMO D2,VISU$	CLR.L	D3PRESS$:	LOAD.L	D2,D3		; D2 <-- touche presse	LOAD.W	D3,D0	CALL	MMTOURNE	; tourne la deuxime carte ct dos	LOAD.W	D3,D1	CALL	MMTOURNE	; tourne la premire carte ct dos	LOAD.W	D1,#-1		; D1 <-- plus de premire carte retourne	LOAD.L	D3,D2	JUMP,NE KEY$	JUMP	LOOP$YOUPIE$:	CALL	JGJUSTE		; indique que c'est juste	LOAD.W	D3,D0	LOAD.W	D2,#CLRDOT	CALL	MMHILIF		; enlve indication carte retourne	LOAD.W	D3,D1;	LOAD.W	D2,#CLRDOT	CALL	MMHILIF		; enlve indication carte retourne	CALL	MMTERM		; toutes les cartes retournes ?	JUMP,NE FIRST$		; non => FIRST$	CALL	CCMO		; enlve la souris	CALL	JGGAGNE		; victoire ...	JUMP	KILL$BAD0$:	LOAD.W	D3,D0	CALL	MMTOURNE	; tourne la deuxime carte ct dosBAD$:	COMP.W	D1,#-1		; premire carte retourne ?	JUMP',EQ BAD2$		; non => BAD2$	LOAD.W	D3,D1	CALL	MMTOURNE	; tourne la premire carte ct dosBAD2$:	CALL	CCMO		; enlve la souris	CALL	JGECTERM	; termine l'coulement de la jauge	CALL	MMSOLUTION	; montre la solution	LOAD.L	A4,#R16"TAMRASCP	CALL	ICOMALL		; revient de l'ascenseur ...	JUMP'	KILL$END$:	CALL	CCMO		; enlve la souris	CALL	JGECTERM	; termine l'coulement de la jauge	LOAD.L	A4,#R16"TAMRASC	CALL	ICOMALL		; revient de l'ascenseur ...KILL$:	CALL	MMKILL		; libre le puzzle	JUMP	MEMORY;--------\\; MMINIT  >;========/; Initialise un nouveau jeu de mmory.; in	D4.W	numro du mmory (0..n); out	D7.W	erreur; mod	D7.WMMINIT:	PUSHM.L	D0..D5,A3,A4	CALL	MMSEARCH	; A4 <-- ^dans OBKTAB	JUMP,NE EXIT$	LOAD.L	(A6)+OMMPIC,(A4)+OBKPIC	CLR.L	(A6)+OMMIMP	LOAD.L	(A6)+OMMIMD,(A4)+OBKDSI	LOAD.L	(A6)+OMMIMN,(A4)+OBKNSI	LOAD.L	D4,(A4)+OBKFAN	LOAD.W	D3,#3	TEST.L	D4:#BFAG3	JUMP',BS NBG$	DEC.W	D3	TEST.L	D4:#BFAG2	JUMP',BS NBG$	DEC.W	D3NBG$:	LOAD.W	(A6)+OMMNBG,D3	; OMMNBG <-- nb de cartes par groupe	LOAD.L	A4,(A6)+OMMPIC	CALL	IMAGEDECO	; A3 <-- ^image dcode	JUMP,NE EXIT$	LOAD.L	(A6)+OMMPID,A3	LOAD.L	D4,#LXWDO-20-60	DIV.WU	D4,(A6)+OMMIMD+2	LOAD.W	(A6)+OMMNBX,D4	LOAD.L	D4,#LYWDO-20	DIV.WU	D4,(A6)+OMMIMD+0	LOAD.W	(A6)+OMMNBY,D4	LOAD.W	D4,(A6)+OMMNBX	MUL.WU	D4,(A6)+OMMIMD+2	SUB.W	D4,#LXWDO-60	NEG.W	D4	SR.W	D4,#1	SUB.W	D4,#2	LOAD.W	(A6)+OMMPOS+2,D4	LOAD.W	D4,(A6)+OMMNBY	MUL.WU	D4,(A6)+OMMIMD+0	SUB.W	D4,#LYWDO	NEG.W	D4	SR.W	D4,#1	LOAD.W	(A6)+OMMPOS+0,D4	LOAD.W	D4,(A6)+OMMNBX	MUL.WU	D4,(A6)+OMMNBY	; D4 <-- nb max de cartes affichables	LOAD.W	D3,(A6)+OMMIMN+2	MUL.WU	D3,(A6)+OMMIMN+0	SUB.W	D3,#2		; D3 <-- nb max de cartes dans l'image	SL.W	D3,#1		; D3 <-- chaque carte apparat deux fois	COMP.W	D4,D3	JUMP',LS NBT$	LOAD.W	D4,D3NBT$:	TCLR.L	D4:#0		; D4 <-- toujours pair !	LOAD.W	(A6)+OMMNBT,D4HAZARD$:	COMP.W	(A6)+OMMNBG,#2	; indication "carte+lgende" ?	JUMP,EQ PAIR$		; oui => PAIR$	COMP.W	(A6)+OMMNBG,#3	; indication "carte+carte+lgende" ?	JUMP,EQ TER$		; oui => TER$	CLR.W	D3	LOAD.W	D4,(A6)+OMMNBT	LOAD.L	A4,#(A6)+OHAPUZ	CALL	RZHAZARD	; rz gnrateur alatoire pour positions	LOAD.L	A3,#(A6)+OMMTAB	LOAD.W	D1,(A6)+OMMNBT	SR.W	D1,#1ILOOP$:	CLR.W	D3	LOAD.W	D4,(A6)+OMMIMN+2	MUL.WU	D4,(A6)+OMMIMN+0	SUB.W	D4,#2	LOAD.L	A4,#(A6)+OHAMEM	CALL	EXHAZARD	; D4 <-- tire une carte	LOAD.W	D2,D4	ADD.W	D2,#2		; D2 <-- carte tire	CLR.W	D3	LOAD.W	D4,(A6)+OMMNBT	LOAD.L	A4,#(A6)+OHAPUZ	CALL	EXHAZARD	; D4 <-- o mettre la carte	LOAD.B	(A3)+(D4.W),D2	; OMMTAB <-- met la carte une premire fois;	CLR.W	D3	LOAD.W	D4,(A6)+OMMNBT;	LOAD.L	A4,#(A6)+OHAPUZ	CALL	EXHAZARD	; D4 <-- o mettre la carte	LOAD.B	(A3)+(D4.W),D2	; OMMTAB <-- met la carte une deuxime fois	DEC.W	D1	JUMP,NE ILOOP$	CALL	MMPLAUSIBLE	; est-ce plausible ?	JUMP,NE HAZARD$		; non => recommence !	JUMP	END$PAIR$:	CLR.W	D3	LOAD.W	D4,(A6)+OMMNBT	LOAD.L	A4,#(A6)+OHAPUZ	CALL	RZHAZARD	; rz gnrateur alatoire pour positions	LOAD.L	A3,#(A6)+OMMTAB	LOAD.W	D1,(A6)+OMMNBT	SR.W	D1,#1PLOOP$:	CLR.W	D3	LOAD.W	D4,(A6)+OMMIMN+2	MUL.WU	D4,(A6)+OMMIMN+0	SUB.W	D4,#2	SR.W	D4,#1	LOAD.L	A4,#(A6)+OHAMEM	CALL	EXHAZARD	; D4 <-- tire une carte	LOAD.W	D2,D4	INC.W	D2	SL.W	D2,#1		; D2 <-- carte tire	CLR.W	D3	LOAD.W	D4,(A6)+OMMNBT	LOAD.L	A4,#(A6)+OHAPUZ	CALL	EXHAZARD	; D4 <-- o mettre la carte	LOAD.B	(A3)+(D4.W),D2	; OMMTAB <-- met la carte "image";	CLR.W	D3	LOAD.W	D4,(A6)+OMMNBT;	LOAD.L	A4,#(A6)+OHAPUZ	CALL	EXHAZARD	; D4 <-- o mettre la carte	INC.W	D2	LOAD.B	(A3)+(D4.W),D2	; OMMTAB <-- met la carte "lgende"	DEC.W	D1	JUMP,NE PLOOP$	CALL	MMPLAUSIBLE	; est-ce plausible ?	JUMP,NE HAZARD$		; non => recommence !	JUMP	END$TER$:	CLR.W	D3	LOAD.W	D4,(A6)+OMMNBT	LOAD.L	A4,#(A6)+OHAPUZ	CALL	RZHAZARD	; rz gnrateur alatoire pour positions	LOAD.L	A3,#(A6)+OMMTAB	LOAD.W	D1,(A6)+OMMNBT	SR.W	D1,#1TLOOP$:	CLR.W	D3	LOAD.W	D4,(A6)+OMMIMN+2	MUL.WU	D4,(A6)+OMMIMN+0	SUB.L	D4,#2	DIV.WU	D4,#3	MUL.WU	D4,#2	LOAD.L	A4,#(A6)+OHAMEM	CALL	EXHAZARD	; D4 <-- tire une carte	CLR.L	D2	LOAD.W	D2,D4	DIV.WU	D2,#2	MUL.WU	D2,#3	LOAD.W	D0,D2	ADD.W	D0,#2+2		; D0 <-- carte "lgende" tire	AND.W	D4,#1	ADD.W	D2,D4	ADD.W	D2,#2		; D2 <-- carte "image" tire	CLR.W	D3	LOAD.W	D4,(A6)+OMMNBT	LOAD.L	A4,#(A6)+OHAPUZ	CALL	EXHAZARD	; D4 <-- o mettre la carte	LOAD.B	(A3)+(D4.W),D2	; OMMTAB <-- met la carte "image";	CLR.W	D3	LOAD.W	D4,(A6)+OMMNBT;	LOAD.L	A4,#(A6)+OHAPUZ	CALL	EXHAZARD	; D4 <-- o mettre la carte	LOAD.B	(A3)+(D4.W),D0	; OMMTAB <-- met la carte "lgende"	DEC.W	D1	JUMP,NE TLOOP$	CALL	MMPLAUSIBLE	; est-ce plausible ?	JUMP,NE HAZARD$		; non => recommence !END$:	LOAD.W	D3,#4		; D3 <-- 4 secondes par carte	COMP.W	(A6)+OMMNBG,#1	JUMP',EQ ECD$	LOAD.W	D3,#6		; D3 <-- 6 secondes par carteECD$:	LOAD.W	D4,(A6)+OMMNBT	MUL.WU	D4,D3		; D4 <-- n secondes par carte	LOAD.W	(A6)+OJGECD,D4	; OJGECD <-- dure du jeu	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	PUSH.W	D7	LOAD.L	A4,(A6)+OMMPIC	; A4 <-- ^image code des cartes	LOAD.L	A3,(A6)+OMMPID	; A4 <-- ^image dcode des cartes	CALL	IMAGECODE	; libre l'image dcode	POP.W	D7EXIT$:	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MMSEARCH >;---------/; Cherche une image pour le mmory dans la banque.; in	D4.W	numro du mmory (0..n); out	A4.L	^dans OBKTAB;	D7.W	erreur; mod	D7.W, A4.LMMSEARCH:	PUSHM.L	D2..D4	CLR.W	D7	LOAD.L	A4,#(A6)+OBKTAB	LOAD.W	D3,(A6)+OBKNBU	JUMP',EQ ERROR$LOOP$:	TEST.L	(A4)+OBKPIC	JUMP',EQ NEXT$	TEST.L	(A4)+OBKNSI	; y'a-t-il des sous-images ?	JUMP',EQ NEXT$		; non => NEXT$	TEST.L	(A4)+OBKPII	; y'a-t-il une image icne ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	D2,(A4)+OBKFAN	; D2 <-- fanions	TEST.L	D2:#BFAMEMORY	JUMP',BC NEXT$	DEC.W	D4	JUMP',NS EXIT$NEXT$:	LOAD.L	A4,#(A4)+LBK	; A4 <-- ^suivant	DEC.W	D3	JUMP,NE LOOP$ERROR$:	LOAD.W	D7,#ERTIMEXEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; MMPLAUSIBLE >;------------/; Vrifie si les cartes tires sont plausibles.; in	-; out	D7.W	erreur; mod	D7.WMMPLAUSIBLE:	PUSHM.L	D0..D4,A3,A4	LOAD.W	D7,#1		; D1 <-- a tient pas debout	LOAD.L	A3,#(A6)+OMMTAB	LOAD.W	D3,(A6)+OMMNBTLOOP$:	CLR.L	D2	LOAD.B	D2,(A3+)	; D2 <-- carte	SUB.W	D2,#2	DIV.WU	D2,(A6)+OMMNBG	LOAD.L	A4,#(A6)+OMMTAB	LOAD.W	D4,(A6)+OMMNBT	CLR.W	D1SEARCH$:	CLR.L	D0	LOAD.B	D0,(A4+)	SUB.W	D0,#2	DIV.WU	D0,(A6)+OMMNBG	COMP.W	D2,D0	JUMP',NE NEXT$	INC.W	D1		; D1 <-- une occurrence de plusNEXT$:	DEC.W	D4	JUMP,NE SEARCH$	COMP.W	D1,#2		; est-ce que la carte apparat deux fois ?	JUMP',NE EXIT$		; non => EXIT$	DEC.W	D3	JUMP,NE LOOP$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; MMCADRE >;========/; Affiche le cadre.; in	-; out	-; mod	D7.WMMCADRE:	PUSHM.L	D1..D4	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	CALL	COLORHAZARD	; choix de couleurs alatoires	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame toute la fentre	LIB	?COLORPOP	LOAD.W	D1,#B'0001101101100100	CLR.L	D3	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	LOAD.W	D4,(A6)+OMMNBY	MUL.WU	D4,(A6)+OMMIMD+0	SWAP.W	D4	LOAD.W	D3,(A6)+OMMNBX	MUL.WU	D3,(A6)+OMMIMD+2	LOAD.W	D4,D3	LOAD.L	D3,(A6)+OMMPOS	SUB.W	D3,#5	SWAP.W	D3	SUB.W	D3,#5	SWAP.W	D3	ADD.W	D4,#5+5	SWAP.W	D4	ADD.W	D4,#5+5	SWAP.W	D4;	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface sous les cartes	CALL	DESRECTM	; cadre autour des cartes	CALL	JGDRAW		; dessine la jauge pleine	POPM.L	D1..D4	RET;--------\\; MMTERM  >;========/; Vrifie si le mmory est termin.; in	-; out	D7.W	EQ si termin; mod	D7.WMMTERM:	PUSHM.L	D4,A4	LOAD.W	D7,#1		; D7 <-- pas correct	LOAD.L	A4,#(A6)+OMMTAB	LOAD.W	D4,(A6)+OMMNBTLOOP$:	TEST.B	(A4+):#7	; carte retourne ?	JUMP',BC EXIT$		; non => EXIT$	DEC.W	D4	JUMP,NE LOOP$	CLR.W	D7		; D7 <-- terminEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; MMMOVE  >;========/; Choisit une carte.; in	-; out	D3.W	numro de la carte;	D7.W	erreur; mod	D3.L, D7.WMMMOVE:	PUSHM.L	D1,D2,D4	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE EXIT$	CALL	MMDETECT	; D3 <-- carte o est la souris	JUMP,NE EXIT$	LOAD.W	D2,#SETDOT	CALL	MMHILIC		; allume la premire carte	LOAD.W	D1,D3		; D1 <-- carteLOOP$:	CLR.L	D3	CALL	JGECOULE	; coule la jauge	JUMP,NE END$	LOAD.W	D4,#2	NTREL	?SETTIM	LIB	?GETKEY		; attend souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE LOOP$	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	MMDETECT	; D3 <-- carte o est la souris	JUMP,NE LOOP$	COMP.W	D3,D1		; toujours dans la mme carte ?	JUMP,EQ LOOP$		; oui => LOOP$	EX.L	D3,D1	LOAD.W	D2,#CLRDOT	CALL	MMHILIC		; teint la carte	LOAD.W	D3,D1	LOAD.W	D2,#SETDOT	CALL	MMHILIC		; allume la carte	JUMP	LOOP$END$:	LOAD.W	D3,D1	LOAD.W	D2,#CLRDOT	CALL	MMHILIC		; teint la dernire carte	CLR.W	D7EXIT$:	POPM.L	D1,D2,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MMDETECT >;---------/; Dtecte dans quelle carte est la souris.; in	D4.L	position de la souris; out	D3.W	numro de la carte;	D7.W	erreur; mod	D3.L, D7.WMMDETECT:	PUSHM.L	D4,A4	LOAD.W	D7,#1	CLR.L	D3	LOAD.W	D3,D4	SUB.W	D3,(A6)+OMMPOS+2	JUMP',LO EXIT$	DIV.WU	D3,(A6)+OMMIMD+2	COMP.W	D3,(A6)+OMMNBX	JUMP',HS EXIT$	CLR.W	D4	SWAP.W	D4	SUB.W	D4,(A6)+OMMPOS+0	JUMP',LO EXIT$	DIV.WU	D4,(A6)+OMMIMD+0	COMP.W	D4,(A6)+OMMNBY	JUMP',HS EXIT$	MUL.WU	D4,(A6)+OMMNBX	ADD.W	D3,D4	COMP.W	D3,(A6)+OMMNBT	JUMP',HS EXIT$	LOAD.L	A4,#(A6)+OMMTAB	TEST.B	(A4)+(D3.W):#7	; carte dj retourne ?	JUMP',BS EXIT$		; oui => EXIT$	CLR.W	D7EXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; MMHILIC >;--------/; Met en vidence le cadre de la carte.; in	D3.W	numro de la carte;	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WMMHILIC:	PUSHM.L	D2..D4	COMP.W	D2,#CLRDOT	JUMP,EQ CLR$	CALL	MMPOSDIM	; D3/D4 <-- position/dimensions	JUMP,NE EXIT$	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	LIB	?COLORPUSH	LOAD.L	D3,#COLORHILI	LIB	?COLORSR	POPM.L	D3,D4	LOAD.W	D2,#LOADDOT	PUSHM.L	D3,D4	INC.W	D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	INC.W	D3	LOAD.W	D4,#LHILIC+2	SWAP.W	D3	SWAP.W	D4	LIB	?DRTRAME	POPM.L	D3,D4	PUSHM.L	D3,D4	INC.W	D3	LOAD.W	D4,#LHILIC+2	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#1+LHILIC+2	SUB.W	D4,#LHILIC+2+LHILIC+2+1	SWAP.W	D3	SWAP.W	D4	LIB	?DRTRAME	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,D4	SUB.W	D3,#LHILIC+2	LOAD.W	D4,#LHILIC+2	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#1+LHILIC+2	SUB.W	D4,#LHILIC+2+LHILIC+2+1	SWAP.W	D3	SWAP.W	D4	LIB	?DRTRAME	POPM.L	D3,D4	PUSHM.L	D3,D4	INC.W	D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SUB.W	D3,#LHILIC+2	LOAD.W	D4,#LHILIC+2	SWAP.W	D3	SWAP.W	D4	LIB	?DRTRAME	POPM.L	D3,D4	LIB	?COLORPOP	JUMP'	EXIT$CLR$:	CALL	MMCARTE		; raffiche la carteEXIT$:	POPM.L	D2..D4	RET;--------\\; MMHILIF >;--------/; Met en vidence finnement la carte.; in	D3.W	numro de la carte;	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WMMHILIF:	PUSHM.L	D1..D4	COMP.W	D2,#CLRDOT	JUMP',EQ CLR$	CALL	MMPOSDIM	; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	LOAD.W	D2,#SETDOT	CALL	INVMODE	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LOAD.W	D1,#6	LIB	?DRRECTA	JUMP'	EXIT$CLR$:	CALL	MMCARTE		; raffiche la carteEXIT$:	POPM.L	D1..D4	RET;---------\\; MMPOSDIM >;---------/; Donne la position et les dimensions d'une carte.; in	D3.W	numro de la carte; out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WMMPOSDIM:	PUSHM.L	D1,D2	CLR.L	D2	LOAD.W	D2,D3	LOAD.W	D7,#1	COMP.W	D2,(A6)+OMMNBT	JUMP',HS EXIT$	DIV.WU	D2,(A6)+OMMNBX	LOAD.L	D3,(A6)+OMMPOS	LOAD.W	D1,D2	MUL.WU	D1,(A6)+OMMIMD+0	SWAP.W	D3	ADD.W	D3,D1		; D3 <-- position dans l'cran en Y	SWAP.W	D3	SWAP.W	D2	MUL.WU	D2,(A6)+OMMIMD+2	ADD.W	D3,D2		; D3 <-- position dans l'cran en X	LOAD.L	D4,(A6)+OMMIMD+0 ; D4 <-- dimensions	CLR.W	D7EXIT$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MMSOLUTION >;===========/; Montre la solution.; in	-; out	-; mod	D7.WMMSOLUTION:	PUSHM.L	D0..D5,A4	LOAD.L	A4,#R16"TAMPASC	CALL	ICOMALL		; remet toto sur l'ascenseur	LOAD.W	(A6)+OSOUND,#TMUSPERDU	LOAD.W	D4,#50*2	NTREL	?DELMS	LOAD.L	A4,#R16"TAMRASCS	CALL	ICOMALL		; saute sur l'ascenseur ...	LOAD.W	D4,#50	NTREL	?DELMSNEXT$:	LOAD.L	A4,#(A6)+OMMTAB	LOAD.W	D4,(A6)+OMMNBT	CLR.W	D0LOOP$:	TEST.B	(A4+):#7	; carte retourne ?	JUMP',BC SHOW$		; non => SHOW$	INC.W	D0	DEC.W	D4	JUMP,NE LOOP$	JUMP	EXIT$SHOW$:	CLR.L	D3	LOAD.B	D3,(A4)-1	SUB.W	D3,#2	DIV.WU	D3,(A6)+OMMNBG	TSET.B	(A4)-1:#7	; tourne la premire carte	LOAD.L	A4,#(A6)+OMMTAB	LOAD.W	D4,(A6)+OMMNBT	CLR.W	D1PAIR$:	CLR.L	D2	LOAD.B	D2,(A4+)	JUMP',NS PNEXT$	SUB.W	D2,#2	DIV.WU	D2,(A6)+OMMNBG	COMP.W	D2,D3	JUMP',EQ FOUND$PNEXT$:	INC.W	D1	DEC.W	D4	JUMP,NE PAIR$	JUMP	EXIT$FOUND$:	TSET.B	(A4)-1:#7	; tourne la deuxime carte	LOAD.W	(A6)+OSOUND,#TMUSTAC	LOAD.W	D3,D0	CALL	MMCARTE	LOAD.W	D3,D1	CALL	MMCARTE	LOAD.W	D5,#10-1FLASH$:	LOAD.W	D2,#SETDOT	LOAD.W	D3,D0	CALL	MMHILIC		; allume la premire carte	LOAD.W	D3,D1	CALL	MMHILIC		; allume la deuxime carte	LOAD.W	D4,#8	NTREL	?DELMS	LOAD.W	D2,#CLRDOT	LOAD.W	D3,D0	CALL	MMHILIC		; teint la premire carte	LOAD.W	D3,D1	CALL	MMHILIC		; teint la deuxime carte	LOAD.W	D4,#8	NTREL	?DELMS	DECJ.W,NMO D5,FLASH$	LOAD.W	D4,#50	NTREL	?DELMS	JUMP	NEXT$EXIT$:	POPM.L	D0..D5,A4	RET;---------\\; MMTOURNE >;=========/; Retourne une carte (flip-flop) et affiche-la.; in	D3.W	numro de la carte  tourner; out	-; mod	D7.WMMTOURNE:	PUSHM.L	A4	LOAD.L	A4,#(A6)+OMMTAB	TNOT.B	(A4)+(D3.W):#7	CALL	MMCARTE		; affiche la carte retourne	POPM.L	A4	RET;--------\\; MMSHOW  >;========/; Affiche l'image du mmory.; in	-; out	-; mod	D7.WMMSHOW:	PUSHM.L	D3,D4	CLR.W	D3	LOAD.W	D4,(A6)+OMMNBTLOOP$:	CALL	MMCARTE		; affiche une carte	INC.W	D3	DEC.W	D4	JUMP,NE LOOP$	POPM.L	D3,D4	RET;--------\\; MMCARTE >;--------/; Affiche une carte du mmory.; in	D3.W	rang de la carte; out	-; mod	D7.WMMCARTE:	PUSHM.L	D1..D4,A3,A4	LOAD.L	D2,(A6)+OMMPOS	LOAD.L	A4,#(A6)+OMMTAB	; A4 <-- ^table des cartes	CLR.L	D4	LOAD.B	D4,(A4)+(D3.W)	; D4 <-- numro de la carte	TCLR.L	D4:#7	JUMP',BS FACE$	CLR.W	D4		; D4 <-- numro de la carte retourne (dos)FACE$:	PUSHM.L	D3,D4	LIB	?COLORPUSH	LOAD.L	D3,#COLORORANGE	SUB.W	D4,#2	JUMP',NS COLOR$	AND.L	D4,#H'FFFF	DIV.WU	D4,(A6)+OMMNBG	AND.L	D4,#H'FFFF	DIV.WU	D4,#4	SWAP.W	D4	LOAD.L	D3,#COLORVERT	DEC.W	D4	JUMP',NS COLOR$	LOAD.L	D3,#COLORCYAN	DEC.W	D4	JUMP',NS COLOR$	LOAD.L	D3,#COLORROSE	DEC.W	D4	JUMP',NS COLOR$	LOAD.L	D3,#COLORJAUNECOLOR$:	LIB	?COLORCR	POPM.L	D3,D4	AND.L	D3,#H'FFFF	DIV.WU	D3,(A6)+OMMNBX	LOAD.W	D1,D3	MUL.WU	D1,(A6)+OMMIMD+0	SWAP.W	D2	ADD.W	D2,D1		; D2 <-- position dans l'cran en Y	SWAP.W	D2	SWAP.W	D3	MUL.WU	D3,(A6)+OMMIMD+2	ADD.W	D2,D3		; D2 <-- position dans l'cran en X	DIV.WU	D4,(A6)+OMMIMN+2	LOAD.W	D3,D4	MUL.WU	D3,(A6)+OMMIMD+0 ; D3 <-- position dans l'image en Y	SWAP.W	D3	SWAP.W	D4	MUL.WU	D4,(A6)+OMMIMD+2	LOAD.W	D3,D4		; D3 <-- position dans l'image en X	LOAD.L	D4,(A6)+OMMIMD+0	INC.W	D2	SWAP.W	D2	INC.W	D2	SWAP.W	D2	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	A4,(A6)+OMMPIC	; A4 <-- ^image code	LOAD.L	A3,(A6)+OMMPID	; A3 <-- ^image dcode	CALL	IMAGEAFF	; affiche une carte du mmory	LIB	?COLORPOP	LOAD.L	D3,D2	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	CALL	INVMODE	LIB	?DRRECT	POPM.L	D1..D4,A3,A4	RET;--------\\; MMKILL  >;========/; Termine un mmory.; in	-; out	-; mod	D7.WMMKILL:	PUSHM.L	A3,A4	LOAD.L	A4,(A6)+OMMPIC	; A4 <-- ^image code	LOAD.L	A3,(A6)+OMMPID	; A3 <-- ^image dcode	CALL	IMAGECODE	; libre l'image dcode	POPM.L	A3,A4	RET	.END