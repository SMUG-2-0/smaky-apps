	.SBTTL	TSICONE.ASI;----------\\; ICOMGAGNE >;==========/; Petite action si l'on a gagn.; in	D4.W	gain (0..4); out	-; mod	D7.WICOMGAGNE:	PUSHM.L	D3,D4,A4	LOAD.W	(A6)+OTEST1,D4	COMP.W	D4,#2	JUMP',HS SAUTE$	TEST.B	(A6)+OFLAGS:#BFSON	JUMP',BC SAUTE$	CLR.W	D3	LOAD.W	D4,#10	LOAD.L	A4,#(A6)+OHAEXC	CALL	EXHAZARD	; D4 <-- action exceptionnelle	TEST.W	D4	JUMP',NE SAUTE$	LOAD.L	A4,#R16"TAM2DF	CALL	ICOMALL		; demi-tour dos -> face	CLR.W	D3	LOAD.W	D4,#9	LOAD.L	A4,#(A6)+OHAMUS	CALL	EXHAZARD	; D4 <-- musique (0..8)	LOAD.W	(A6)+OTEST1,D4	LOAD.L	A4,#R16"TAMMUSIC	CALL	ICOMALL		; joue une p'tite musique ...	LOAD.L	A4,#R16"TAM2FD	CALL	ICOMALL		; demi-tour face -> dos	JUMP'	EXIT$SAUTE$:	CLR.W	D3	LOAD.W	D4,#10	LOAD.L	A4,#(A6)+OHAEXC	CALL	EXHAZARD	; D4 <-- action exceptionnelle	LOAD.W	(A6)+OTEST2,D4	LOAD.L	A4,#R16"TAMPENDUG	CALL	ICOMALL		; saute ...EXIT$:	POPM.L	D3,D4,A4	RET;-----------\\; ICOMLITTLE >;===========/; Effectue une petite action.; in	-; out	-; mod	D7.WICOMLITTLE:	PUSHM.L	D3,D4,A4	CLR.W	D3	LOAD.W	D4,#10	LOAD.L	A4,#(A6)+OHALIT	CALL	EXHAZARD	; D4 <-- tire une action	LOAD.W	(A6)+OTEST1,D4	LOAD.L	A4,#R16"TAMLITTLE	CALL	ICOMALL	POPM.L	D3,D4,A4	RET;-----------\\; ICOMENLEVE >;===========/; Enlve toto lorsque l'cran changera.; in	-; out	-; mod	D7.WICOMENLEVE:	PUSHM.L	A2,A5	LOAD.L	A5,#(A6)+OOBJ1	LOAD.L	A2,(A5)+OOCHIM	; A2 <-- canal	CALL	ICOMCLEAR	; enlve toto	CALL	ICOMCLOSE	CLR.L	(A5)+OOCHIM	POPM.L	A2,A5	RET;----------\\; ICOMREMET >;==========/; Remet toto si l'cran a chang.; in	-; out	-; mod	D7.WICOMREMET:	PUSHM.L	D3,D4,A2,A5	LOAD.L	A5,#(A6)+OOBJ1	LOAD.L	D4,(A5)+OOLPOS	; D4 <-- dernire position	CALL	ICOMOPEN	LOAD.L	(A5)+OOCHIM,A2	LOAD.W	D3,(A5)+OOICON	; D3 <-- dernire icne	CALL	ICOMMOVE	; remet totoEXIT$:	POPM.L	D3,D4,A2,A5	RET;--------\\; ICOMALL >;========/; Mouvement complet pour l'objet 1.; in	A4.L	^table des mouvements; out	-; mod	D7.WICOMALL:	PUSH.L	A5	LOAD.L	A5,#(A6)+OOBJ1	CALL	ICOMBEGINLOOP$:	CALL	ICOMNEXT	JUMP,EQ LOOP$	POP.L	A5	RET;----------\\; ICOMBEGIN >;==========/; Dbut d'un mouvement d'objet anim.; in	A5.L	^descripteur objet anim;	A4.L	^table des mouvements; out	-; mod	D7.WICOMBEGIN:	LOAD.L	(A5)+OOMPTA,A4	CLR.W	(A5)+OOMCTN	RET;---------\\; ICOMNEXT >;=========/; Dplace un objet anim.; in	A5.L	^descripteur objet anim; out	D7.W	erreur si mouvement fini; mod	D7.WICOMNEXT:	PUSHM.L	D3,D4,A2,A4	TEST.W	(A5)+OOMCTN	JUMP,NE POS$; Cherche l'lment suivant dans la table.NEXT$:	LOAD.L	A4,(A5)+OOMPTA	LOAD.W	D7,#EROUTF	TEST.W	(A4)		; fin de la table ?	JUMP,EQ EXIT$		; oui => EXIT$	CALL	ICOMSPEC	; objet spcial TMxxxx ?	JUMP',NE NSPEC$		; non => NSPEC$	LOAD.L	(A5)+OOMPTA,A4	JUMP	NEXT$NSPEC$:	LOAD.L	(A5)+OOMPTB,A4	LOAD.W	(A5)+OOMCTN,(A4+)	ADD.L	A4,#4	LOAD.W	(A5)+OOMNBI,#-1NBI$:	INC.W	(A5)+OOMNBI	TEST.W	(A4+)	JUMP,NE NBI$	CLR.W	(A5)+OOMCTI	LOAD.L	(A5)+OOMPTA,A4; Cherche la nouvelle position et la nouvelle icne.POS$:	LOAD.L	A4,(A5)+OOMPTB	; A4 <-- ^lment prcdent	DEC.W	(A5)+OOMCTN	LOAD.W	D4,(A5)+OOLPOS+0	ADD.W	D4,(A4)+2	LOAD.W	(A5)+OONPOS+0,D4	LOAD.W	D4,(A5)+OOLPOS+2	ADD.W	D4,(A4)+4	LOAD.W	(A5)+OONPOS+2,D4	TEST.W	(A5)+OOMNBI	JUMP,EQ END$	LOAD.W	D3,(A5)+OOMCTI	SL.W	D3,#1	LOAD.W	(A5)+OOICON,(A4)+(D3.W)+6	SR.W	D3,#1	INC.W	D3	COMP.W	D3,(A5)+OOMNBI	JUMP',LO NLI$	CLR.W	D3NLI$:	LOAD.W	(A5)+OOMCTI,D3; Bouge l'objet sur l'cran.	LOAD.W	D3,(A5)+OOICON	LOAD.L	D4,(A5)+OONPOS	LOAD.L	A2,(A5)+OOCHIM	; A2 <-- canal	CALL	ICOMMOVE	; dplace l'icne	LOAD.W	D4,(A5)+OOMDEL	JUMP',EQ END$	NTREL	?DELMS		; attend un peuEND$:	LOAD.L	(A5)+OOLPOS,(A5)+OONPOS	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; ICOMSPEC >;---------/; Traite les objet spciaux TMxxx contenus dans la table.; in	A4.L	^dans table; out	A4.L	^plus loin;	D7.W	erreur; mod	D7.W, A4.LICOMSPEC:	PUSHM.L	D2..D4,A2,A3	LOAD.W	D7,#1		; D7 <-- pas un objet TMxxxx	TEST.W	(A4)	JUMP,NC EXIT$	LOAD.W	D4,(A4+)	; D4 <-- objet TMxxxx	COMP.W	D4,#TMOPEN	JUMP,EQ OPEN$	COMP.W	D4,#TMCLOSE	JUMP,EQ CLOSE$	COMP.W	D4,#TMDEL	JUMP,EQ DEL$	COMP.W	D4,#TMSOUND	JUMP,EQ SOUND$	COMP.W	D4,#TMSKIPNE	JUMP,EQ SKIPNE$	COMP.W	D4,#TMSKIPEQ	JUMP,EQ SKIPEQ$	JUMP	EXIT$OPEN$:	LOAD.L	(A5)+OOLPOS,(A4+)	LOAD.L	(A5)+OOMPTA,A4	CLR.W	(A5)+OOMCTN	LOAD.L	D4,(A5)+OOLPOS	; D4 <-- position initiale	CALL	ICOMOPEN	; A2 <-- canal	LOAD.L	(A5)+OOCHIM,A2	JUMP	OK$CLOSE$:	LOAD.L	A2,(A5)+OOCHIM	CALL	ICOMCLEAR	; enlve l'icne	CALL	ICOMCLOSE	; termine le dplacement	CLR.L	(A5)+OOCHIM	JUMP	OK$DEL$:	LOAD.W	(A5)+OOMDEL,(A4+)	JUMP	OK$SOUND$:	LOAD.W	(A6)+OSOUND,(A4+)	JUMP	OK$SKIPNE$:	ADD.L	A4,#+8		; A4 <-- saute SKIPNE et paramtres	LOAD.L	A3,A6	ADD.W	A3,(A4)-8+0	; A3 <-- ^variable	LOAD.W	D3,(A3)		; D3 <-- valeur variable	COMP.W	D3,(A4)-8+2	; effectue le test	JUMP',LO SKIP$	COMP.W	D3,(A4)-8+4	; effectue le test	JUMP',HI SKIP$	JUMP'	OK$SKIPEQ$:	ADD.L	A4,#+8		; A4 <-- saute SKIPEQ et paramtres	LOAD.L	A3,A6	ADD.W	A3,(A4)-8+0	; A3 <-- ^variable	LOAD.W	D3,(A3)		; D3 <-- valeur variable	COMP.W	D3,(A4)-8+2	; effectue le test	JUMP',LO OK$	COMP.W	D3,(A4)-8+4	; effectue le test	JUMP',HI OK$SKIP$:	CALL	_ADCODE		; A3 <-- R16"ADCODE	CLR.L	D3	LOAD.W	D3,(A4)-8+6	ADD.L	A3,D3		; A4 <-- adresse absolue si NE	LOAD.L	A4,A3;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; ICOMOPEN >;=========/; Dbut d'un dplacement d'icne.; in	D4.L	position initiale (y;x); out	A2.L	canal;	D7.W	erreur; mod	D7.W, A2.LICOMOPEN:	PUSHM.L	D1..D6,A3,A4	LOAD.L	D3,D4; Demande de la mmoire pour le canal.	LOAD.L	A2,#0	CLR.W	D4	LOAD.B	D4,(A0)+ODFCNP	; D4 <-- nb de bits/pixel (1,4)	MUL.WU	D4,#LMI	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP',NE EXIT$	LOAD.L	A2,A4		; A2 <-- "canal"; Transfert l'cran dans le bitmap original.	LOAD.L	A3,#0	LOAD.L	A4,#(A2)+OMIMAT	CLR.L	D4	LOAD.W	D6,#LXICO/8	LOAD.L	D1,#H'10000*LYICO+LXICO	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	LOAD.L	(A2)+OMIPOS,D3	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; ICOMMOVE >;=========/; Dplace une icne.; in	D3.W	code de l'icne;	D4.L	position sup/gauche (y;x);	A2.L	canal; out	-; mod	D7.WICOMMOVE:	PUSHM.L	D0..D6,A3,A4	SUB.L	SP,#4+2+2	; SP <-- ^variables	COMP.L	A2,#0	JUMP,EQ EXIT$	LOAD.W	(SP)+4,D3	; stack <-- icne	LOAD.L	D0,D4		; D0 <-- nouvelle position	LOAD.L	D1,D4	SUB.W	D1,(A2)+OMIPOS+2	JUMP',NC DIMX$	NEG.W	D1DIMX$:	COMP.W	D1,#LXICO	JUMP,HS EXIT$		; <<<<<<< PROVISOIRE <<<<<<<<<	ADD.W	D1,#LXICO	; D1 <-- largeur totale	SWAP.W	D1	SUB.W	D1,(A2)+OMIPOS+0	JUMP',NC DIMY$	NEG.W	D1DIMY$:	COMP.W	D1,#LYICO	JUMP,HS EXIT$		; <<<<<<< PROVISOIRE <<<<<<<<<	ADD.W	D1,#LYICO	; D1 <-- hauteur totale	SWAP.W	D1	LOAD.L	(SP)+0,D1	; stack <-- dimensions totales	CLR.W	(SP)+4+2	TEST.B	(A6)+OCCMO	; souris enleve ?	JUMP',T	P0$		; oui => P0$	CALL	IFMOUSE		; D4 <-- position de la souris	COMP.W	D4,#LXWDO-LXICO-20	JUMP',LO P0$	CALL	CCMO		; enlve la souris	INC.W	(SP)+4+2; Transfert le bitmap original dans le bitmap temporaire.P0$:	LOAD.L	A3,#(A2)+OMIMAT	CLR.L	D3	LOAD.W	D5,#LXICO/8	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,(A2)+OMIPOS+2	SUB.W	D4,D0	JUMP',NC P0DX$	CLR.W	D4P0DX$:	SWAP.W	D0	SWAP.W	D4	LOAD.W	D4,(A2)+OMIPOS+0	SUB.W	D4,D0	JUMP',NC P0DY$	CLR.W	D4P0DY$:	SWAP.W	D0	SWAP.W	D4	LOAD.W	D6,#(LXICO/8)*2	LOAD.L	D1,#H'10000*LYICO+LXICO	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER; Transfert l'image (1) dans le bitmap temporaire.	LOAD.L	A3,#0	LOAD.W	D3,(A2)+OMIPOS+2	COMP.W	D3,D0	JUMP',LE P1SX$	LOAD.W	D3,D0P1SX$:	SWAP.W	D0	SWAP.W	D3	LOAD.W	D3,D0	SWAP.W	D0	SWAP.W	D3;	LOAD.L	A4,#(A6)+OBUDIS	CLR.L	D4;	LOAD.W	D6,#(LXICO/8)*2	LOAD.W	D1,(SP)+2	SWAP.W	D0	SWAP.W	D1	LOAD.W	D1,(A2)+OMIPOS+0	SUB.W	D1,D0	SWAP.W	D1	SWAP.W	D0;	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER; Transfert l'image (2) dans le bitmap temporaire.;	LOAD.L	A3,#0	LOAD.W	D3,D0	SWAP.W	D3	LOAD.W	D3,(A2)+OMIPOS+0	SWAP.W	D3;	LOAD.L	A4,#(A6)+OBUDIS	CLR.W	D4	SWAP.W	D0	SWAP.W	D4	LOAD.W	D4,(A2)+OMIPOS+0	SUB.W	D4,D0	JUMP',NC P2DY$	CLR.W	D4P2DY$:	SWAP.W	D0	SWAP.W	D4;	LOAD.W	D6,#(LXICO/8)*2	LOAD.W	D1,(A2)+OMIPOS+2	SUB.W	D1,D0	SWAP.W	D1	LOAD.W	D1,#LYICO	SWAP.W	D1;	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER; Transfert l'image (3) dans le bitmap temporaire.;	LOAD.L	A3,#0	LOAD.W	D3,(A2)+OMIPOS+2	ADD.W	D3,#LXICO	SWAP.W	D3	LOAD.W	D3,(A2)+OMIPOS+0	SWAP.W	D3;	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,#LXICO	SWAP.W	D0	SWAP.W	D4	LOAD.W	D4,(A2)+OMIPOS+0	SUB.W	D4,D0	JUMP',NC P3DY$	CLR.W	D4P3DY$:	SWAP.W	D0	SWAP.W	D4;	LOAD.W	D6,#(LXICO/8)*2	LOAD.W	D1,D0	SUB.W	D1,(A2)+OMIPOS+2	SWAP.W	D1	LOAD.W	D1,#LYICO	SWAP.W	D1;	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER; Transfert l'image (4) dans le bitmap temporaire.;	LOAD.L	A3,#0	LOAD.W	D3,(A2)+OMIPOS+2	COMP.W	D3,D0	JUMP',LE P4SX$	LOAD.W	D3,D0P4SX$:	SWAP.W	D3	LOAD.W	D3,(A2)+OMIPOS+0	ADD.W	D3,#LYICO	SWAP.W	D3;	LOAD.L	A4,#(A6)+OBUDIS	CLR.W	D4	SWAP.W	D4	LOAD.W	D4,#LYICO	SWAP.W	D4;	LOAD.W	D6,#(LXICO/8)*2	LOAD.W	D1,(SP)+2	SWAP.W	D0	SWAP.W	D1	LOAD.W	D1,D0	SUB.W	D1,(A2)+OMIPOS+0	SWAP.W	D1	SWAP.W	D0;	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER; Transfert le bitmap temporaire dans le bitmap original.	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D3,D0	SUB.W	D3,(A2)+OMIPOS+2	JUMP',NC POSX$	CLR.W	D3POSX$:	SWAP.W	D0	SWAP.W	D3	LOAD.W	D3,D0	SUB.W	D3,(A2)+OMIPOS+0	JUMP',NC POSY$	CLR.W	D3POSY$:	SWAP.W	D0	SWAP.W	D3	LOAD.W	D5,#(LXICO/8)*2	LOAD.L	A4,#(A2)+OMIMAT	CLR.L	D4	LOAD.W	D6,#LXICO/8	LOAD.L	D1,#H'10000*LYICO+LXICO;	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER; Transfert l'icne de fond dans le bitmap temporaire.	LOAD.L	A4,(A6)+OPFICO	LOAD.W	D3,(SP)+4	; D3 <-- icne	CALL	COLORICO	; choix des couleurs pour l'icne	CALL	ICOGETPT	; A3/D3/D5/D1 <-- ^matrice/pos/Iy/dim	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,D0	SUB.W	D4,(A2)+OMIPOS+2	JUMP',NC PFDX$	CLR.W	D4PFDX$:	SWAP.W	D0	SWAP.W	D4	LOAD.W	D4,D0	SUB.W	D4,(A2)+OMIPOS+0	JUMP',NC PFDY$	CLR.W	D4PFDY$:	SWAP.W	D0	SWAP.W	D4	LOAD.W	D6,#(LXICO/8)*2	LOAD.W	D2,#CLRDOT!2^BDSTCOUL	CALL	INVMODE	CALL	DRRASTER; Transfert l'icne de chair dans le bitmap temporaire.	LOAD.L	A4,(A6)+OPGICO	LOAD.W	D3,(SP)+4	; D3 <-- icne	CALL	ICOGETPT	; A3/D3/D5/D1 <-- ^matrice/pos/Iy/dim	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D2,#SETDOT!2^BDSTCOUL	CALL	INVMODE	CALL	DRRASTER	LIB	?COLORPOP; Transfert le bitmap temporaire dans l'cran.	LOAD.L	A3,#(A6)+OBUDIS	CLR.L	D3	LOAD.W	D5,#(LXICO/8)*2	LOAD.L	A4,#0	LOAD.W	D4,(A2)+OMIPOS+2	COMP.W	D4,D0	JUMP',LE PEDX$	LOAD.W	D4,D0PEDX$:	SWAP.W	D0	SWAP.W	D4	LOAD.W	D4,(A2)+OMIPOS+0	COMP.W	D4,D0	JUMP',LE PEDY$	LOAD.W	D4,D0PEDY$:	SWAP.W	D0	SWAP.W	D4	LOAD.L	D1,(SP)+0	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	LOAD.L	(A2)+OMIPOS,D0	TEST.W	(SP)+4+2	JUMP',EQ EXIT$	CALL	SCMO		; remet la sourisEXIT$:	ADD.L	SP,#4+2+2	; ajuste le stack	POPM.L	D0..D6,A3,A4	RET;----------\\; ICOMCLEAR >;==========/; Enlve provisoirement l'icne.; in	A2.L	canal; out	-; mod	D7.WICOMCLEAR:	PUSHM.L	D1..D6,A3,A4	COMP.L	A2,#0	JUMP',EQ EXIT$; Transfert le bitmap orginal dans l'cran.	LOAD.L	A3,#(A2)+OMIMAT	CLR.L	D3	LOAD.W	D5,#LXICO/8	LOAD.L	A4,#0	LOAD.L	D4,(A2)+OMIPOS	LOAD.L	D1,#H'10000*LYICO+LXICO	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTEREXIT$:	POPM.L	D1..D6,A3,A4	RET;----------\\; ICOMCLOSE >;==========/; Termine un dplacement.; in	A2.L	canal; out	-; mod	D7.WICOMCLOSE:	PUSHM.L	D1,A4	COMP.L	A2,#0	JUMP',EQ EXIT$	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoireEXIT$:	POPM.L	D1,A4	RET;--------\\; ICODRAW >;========/; Dessine une icne de ITP84.; in	D3.W	code de l'icne;	D4.L	position (y;x); out	-; mod	D7.WICODRAW:	PUSHM.L	D0..D5,A2..A4	CALL	COLORICO	; choix des couleurs pour l'icne	LOAD.W	D0,D3	LOAD.L	A4,(A6)+OPFICO	; A4 <-- ^gencar fond	CALL	ICOGETPT	; A3/D3/D5/D1 <-- ^matrice/pos/Iy/dim	LOAD.L	A2,#(A6)+OBUDIS+1	LOAD.B	(A2)+0,#DRAWRASTER	SWAP.W	D3	LOAD.L	(A2)+1,D3	LOAD.L	(A2)+5,A3	LOAD.W	(A2)+9,D5	SWAP.W	D4	LOAD.L	(A2)+11,D4	CLR.L	(A2)+15	CLR.W	(A2)+19	SWAP.W	D1	LOAD.L	(A2)+21,D1	LOAD.W	D2,#CLRDOT	CALL	INVMODE	LOAD.B	(A2)+25,D2	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ CHAIR$		; non => CHAIR$	LOAD.L	A3,A2	LOAD.W	D3,#26	LIB	?STRING		; dessine le fondCHAIR$:	LOAD.W	D3,D0	LOAD.L	A4,(A6)+OPGICO	; A4 <-- ^gencar chair	CALL	ICOGETPT	; A3/D3/D5/D1 <-- ^matrice/pos/Iy/dim	LOAD.L	(A2)+5,A3	LOAD.W	D2,#SETDOT	CALL	INVMODE	LOAD.B	(A2)+25,D2	LOAD.L	A3,A2	LOAD.W	D3,#26	LIB	?STRING		; dessine la chair	LIB	?COLORPOP	POPM.L	D0..D5,A2..A4	RET;---------\\; ICOGETPT >;---------/; Cherche le pointeur  une icne.; in	A4.L	^gencar;	D3.W	code de l'icne; out	A3.L	^matrice;	D3.L	origine (y;x);	D5.W	Iy;	D1.L	dimensions (dy;dx); mod	D1.L, D3.L, D5.L, D7.W, A3.LICOGETPT:	LOAD.W	D1,(A4)+OGCMHD	; D1 <-- hauteur en points	SWAP.W	D1	CLR.W	D1	LOAD.B	D1,(A4)+OGCMWB	; D1 <-- largeur en bytes	SL.W	D1,#3		; D1 <-- largeur en points	LOAD.L	A3,#(A4)+256	; A3 <-- ^table des largeurs	CLR.W	D5	LOAD.B	D5,(A4)+OGCLCA	SUB.B	D5,(A4)+OGCFCA	INC.B	D5		; D5 <-- nb de caractres	ADD.W	A3,D5		; A3 <-- ^table des h1	ADD.W	A3,D5		; A3 <-- ^table des h2	ADD.W	A3,D5		; A3 <-- ^premire matrice	MUL.WU	D3,(A4)+OGCMSB	ADD.L	A3,D3		; A3 <-- ^la bonne matrice	CLR.L	D3		; D3 <-- origine source	CLR.W	D5	LOAD.B	D5,(A4)+OGCMWB	; D5 <-- Iy source	RET;---------\\; CALCFOND >;=========/; Fait un double de ITP84 (chair) pour gnrer les fonds.; in	-; out	D7.W	erreur; mod	D7.WCALCFOND:	PUSHM.L	D1..D4,A3,A4	LOAD.L	A3,(A6)+OPGICO	; A3 <-- ^gencar ITP84	LOAD.W	D4,#NBPCAR	MUL.WU	D4,(A3)+OGCMSB	ADD.L	D4,#OGCMAT	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour copie ITP84	JUMP,NE EXIT$	LOAD.L	(A6)+OPFICO,A4	; OPFICO <-- ^gencar "fond"	SR.L	D4,#2	DEC.W	D420$:	LOAD.L	(A4+),(A3+)	DECJ.W,NMO D4,20$	CALL	OPEDISMAT	; dessin en mmoire	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	DRTRADEF	LOAD.B	D3,#AFFILLA	; rempli tout	LIB	?AFCAR	LOAD.L	A4,(A6)+OPFICO	; A4 <-- ^gencar fond	LOAD.W	D4,(A4)+OGCMHD	; D4 <-- hauteur en points	SWAP.W	D4	CLR.W	D4	LOAD.B	D4,(A4)+OGCMWB	; D4 <-- largeur en bytes	SL.W	D4,#3		; D4 <-- largeur en points	LOAD.W	D3,(A4)+OGCMSB	; D3 <-- taille d'une matrice	ADD.L	A4,#OGCMAT	; A4 <-- ^premire matrice	LOAD.W	D2,#NBPCAR-140$:	CALL	CALCFONDONE	; calcule une matrice	ADD.W	A4,D3		; A4 <-- ^matrice suivante	DECJ.W,NMO D2,40$	CALL	CLODISMAT	; dessin dans l'cran	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; CALCFONDONE >;------------/; ; in	A4.L	^matrice;	D4.L	^dimensions (dy;dx); out	-; mod	D7.WCALCFONDONE:	PUSHM.L	D3,D4	CALL	NEWDISMAT	CLR.L	D3	CALL	DRFILL		; rempli	CALL	DRINV		; puis inverse	POPM.L	D3,D4	RET;-------------\\; DRAWOPENCOPY >;=============/; Dbut du dessin cach en mmoire.; On peut continuer le dessin commenc sur l'cran !; in	-; out	D7.W	erreur; mod	D7.WDRAWOPENCOPY:	PUSHM.L	D1..D6,A3,A4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE OK$		; oui => OK$	CLR.W	D4	LOAD.B	D4,(A0)+ODFCNP	; D4 <-- nb de bits/pixel (1,4)	MUL.WU	D4,#LXWDO*LYWDO/8	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire o dessiner	JUMP',NE EXIT$	LOAD.L	A3,#0	CLR.L	D3	CLR.L	D4	LOAD.W	D6,#LXWDO/8	LOAD.L	D1,#H'10000*LYWDO+LXWDO	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	; mmoire <-- copie de l'cran	LOAD.L	D4,#H'10000*LYWDO+LXWDO	CALL	OPEDISMAT	CALL	NEWDISMAT	; dessine en mmoireOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DRAWOPEN >;=========/; Dbut du dessin cach en mmoire.; Il faut commencer par tout effacer !; in	-; out	D7.W	erreur; mod	D7.WDRAWOPEN:	PUSHM.L	D1,D4,A4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE OK$		; oui => OK$	CLR.W	D4	LOAD.B	D4,(A0)+ODFCNP	; D4 <-- nb de bits/pixel (1,4)	MUL.WU	D4,#LXWDO*LYWDO/8	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire o dessiner	JUMP',NE EXIT$	LOAD.L	D4,#H'10000*LYWDO+LXWDO	CALL	OPEDISMAT	CALL	NEWDISMAT	; dessine en mmoireOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DRAWCLOSE >;==========/; Fin du dessin cach en mmoire.; in	-; out	-; mod	D7.WDRAWCLOSE:	PUSHM.L	D1,A3,A4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.L	A3,(A0)+ODFABS	; A3 <-- ^mmoire bitmap	CALL	CLODISMAT	; fin du dessin en mmoire	CALL	PROGRESS	; affiche la mmoire dans l'cran	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEMEXIT$:	POPM.L	D1,A3,A4	RET;----------\\; OPEDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	-; out	-; mod	D7.WOPEDISMAT:	LOAD.L	(A6)+OSDDIS+ODFABS,(A0)+ODFABS	LOAD.W	(A6)+OSDDIS+ODFIIX,(A0)+ODFIIX	LOAD.W	(A6)+OSDDIS+ODFIIY,(A0)+ODFIIY	LOAD.L	(A6)+OSDDIS+ODFY,(A0)+ODFY	LOAD.L	(A6)+OSDDIS+ODFDY,(A0)+ODFDY	LOAD.L	(A6)+OSDDIS+ODFFY,(A0)+ODFFY	LOAD.L	(A6)+OSDDIS+ODFFDY,(A0)+ODFFDY	LOAD.L	(A6)+OSDDIS+ODFWBY,(A0)+ODFWBY	LOAD.L	(A6)+OSDDIS+ODFWEY,(A0)+ODFWEY	RET;----------\\; NEWDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	A4.L	^matrice o dessiner;	D4.L	^dimensions (dy;dx); out	-; mod	D7.WNEWDISMAT:	PUSH.L	D4	LOAD.L	(A0)+ODFABS,A4	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	LOAD.W	(A0)+ODFIIX,#1	SR.W	D4,#3	LOAD.W	(A0)+ODFIIY,D4	POP.L	D4	RET;----------\\; CLODISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.WCLODISMAT:	LOAD.L	(A0)+ODFABS,(A6)+OSDDIS+ODFABS	LOAD.W	(A0)+ODFIIX,(A6)+OSDDIS+ODFIIX	LOAD.W	(A0)+ODFIIY,(A6)+OSDDIS+ODFIIY	LOAD.L	(A0)+ODFY,(A6)+OSDDIS+ODFY	LOAD.L	(A0)+ODFDY,(A6)+OSDDIS+ODFDY	LOAD.L	(A0)+ODFFY,(A6)+OSDDIS+ODFFY	LOAD.L	(A0)+ODFFDY,(A6)+OSDDIS+ODFFDY	LOAD.L	(A0)+ODFWBY,(A6)+OSDDIS+ODFWBY	LOAD.L	(A0)+ODFWEY,(A6)+OSDDIS+ODFWEY	RET;---------\\; COLORFPH >;=========/; Choix d'une couleur de fond pastel alatoirement.; in	-; out	-; mod	D7.WCOLORFPH:	PUSHM.L	D3,D4	LIB	?COLORPUSH	CLR.W	D3	LOAD.W	D4,#5	CALL	MMHAZARD	; D4 <-- nb alatoire	LOAD.L	D3,#COLORJAUNE	DEC.W	D4	JUMP',NS COLOR$	LOAD.L	D3,#COLORVERT	DEC.W	D4	JUMP',NS COLOR$	LOAD.L	D3,#COLORCYAN	DEC.W	D4	JUMP',NS COLOR$	LOAD.L	D3,#COLORROSE	DEC.W	D4	JUMP',NS COLOR$	LOAD.L	D3,#COLORORANGECOLOR$:	LIB	?COLORCR	POPM.L	D3,D4	RET;------------\\; COLORHAZARD >;============/; Choix des couleurs alatoirement.; in	-; out	-; mod	D7.WCOLORHAZARD:	PUSHM.L	D2..D4	LIB	?COLORPUSH	CLR.W	D3	LOAD.W	D4,#10	CALL	MMHAZARD	; D4 <-- nb alatoire	LOAD.W	D2,D4	CLR.L	D3	LOAD.W	D3,D4	ADD.W	D3,#COLORROUGE	LIB	?COLORSR	LOAD.L	(A6)+OCOLHS,D3LOOP$:	CLR.W	D3	LOAD.W	D4,#10	CALL	MMHAZARD	; D4 <-- nb alatoire	COMP.W	D4,D2	JUMP,EQ LOOP$	CLR.L	D3	LOAD.W	D3,D4	ADD.W	D3,#COLORROUGE	LIB	?COLORCR	LOAD.L	(A6)+OCOLHC,D3	POPM.L	D2..D4	RET;---------\\; COLORICO >;=========/; Choix de la couleur pour une icne.; in	D3.W	icne; out	-; mod	D7.WCOLORICO:	PUSHM.L	D3,A3	LIB	?COLORPUSH	LOAD.L	A3,#R16"TABLE$	SL.W	D3,#2		; D3 <-- *4 (car 2 x .W)	ADD.W	A3,D3	CLR.L	D3	LOAD.W	D3,(A3+)	LIB	?COLORSR	CLR.L	D3	LOAD.W	D3,(A3+)	LIB	?COLORCR	POPM.L	D3,A3	RETTABLE$:	.W	COLORNOIR,COLORROSE	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORVIOLET	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORROSE	.W	COLORCTOTO,COLORROUGE	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORROUGE,COLORBLANC	.W	COLORROSE,COLORBLANC	.W	COLORROSE,COLORBLANC	.W	COLORROSE,COLORBLANC	.W	COLORVIOLET,COLORBLANC	.W	COLORVIOLET,COLORBLANC	.W	COLORVIOLET,COLORBLANC	.W	COLORCYAN,COLORBLANC	.W	COLORCYAN,COLORBLANC	.W	COLORNOIR,COLORBLANC	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORVIOLET	.W	COLORNOIR,COLORVIOLET	.W	COLORNOIR,COLORVIOLET	.W	COLORROUGE,COLORBLANC	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORNOIR,COLORBRUN	.W	COLORCTOTO,COLORFTOTO	.W	COLORNOIR,COLORJAUNE	.W	COLORNOIR,COLORORANGE	.W	COLORNOIR,COLORROUGE	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORVIOLET	.W	COLORNOIR,COLORCYAN	.W	COLORNOIR,COLORVERT	.W	COLORNOIR,COLORBLEU	.W	COLORNOIR,COLORBRUN	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORCYAN	.W	COLORNOIR,COLORCYAN	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORNOIR,COLORCYAN	.W	COLORNOIR,COLORORANGE	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORVERT	.W	COLORNOIR,COLORVIOLET	.W	COLORNOIR,COLORCYAN	.W	COLORNOIR,COLORVERT	.W	COLORNOIR,COLORORANGE	.W	COLORNOIR,COLORVERT	.W	COLORNOIR,COLORCYAN	.W	COLORNOIR,COLORORANGE	.W	COLORNOIR,COLORROSE	.W	COLORROUGE,COLORJAUNE	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORVIOLET	.W	COLORNOIR,COLORVIOLET	.W	COLORNOIR,COLORCYAN	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORORANGE	.W	COLORNOIR,COLORCYAN	.W	COLORNOIR,COLORORANGE	.W	COLORNOIR,COLORVERT	.W	COLORNOIR,COLORROUGE	.W	COLORNOIR,COLORVIOLET	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORCYAN	.W	COLORNOIR,COLORCYAN	.W	COLORNOIR,COLORROUGE	.W	COLORNOIR,COLORCYAN	.W	COLORNOIR,COLORVERT	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORCTOTO,COLORFTOTO	.W	COLORNOIR,COLORORANGE	.W	COLORNOIR,COLORBLANC	.W	COLORNOIR,COLORORANGE	.W	COLORNOIR,COLORVERT	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORROSE	.W	COLORNOIR,COLORROSE;---------\\; DRINV    >;=========/; Inverse une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRINV:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE EXIT$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE EXIT$	SWAP.W	D4	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADINV	CALL	(A1)		; appel de GRA_INVEXIT$:	POPM.L	D1..D4,A1,A2	RET;--------\\; DRFILL  >;========/; Rempli une surface quelconque.; in	D3.L	point de remplissage (y;x); out	D7.W	erreur; mod	D7.WDRFILL:	PUSHM.L	D1..D4,A1,A2	LOAD.L	D4,D3		; D4 <-- y;x	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADFILLO	CALL	(A1)		; appel de GRA_FILLO	PUSH.W	D7	LOAD.L	A1,(A6)+OADFILLC	CALL	(A1)		; appel de GRA_FILLC	POP.W	D7	POPM.L	D1..D4,A1,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; DRRASTER >;=========/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D1.L	hauteur/largeur (y;x);	D2.W	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT); out	-; mod	D7.WDRRASTER:	PUSHM.L	D0..D6,A1,A2	TEST.W	D1		; dx <= 0 ?	JUMP',LE EXIT$	SWAP.W	D1	TEST.W	D1		; dy <= 0 ?	JUMP',LE EXIT$	SWAP.W	D1	EX.L	D1,D2		; D2/D1 <-- mode/dimensions	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	CLR.W	D0	LOAD.B	D0,(A0)+ODFCNP	; D0 <-- nb de bits/pixel (1,4)	COMP.W	D0,#1	JUMP',NE COUL$	LOAD.L	A1,(A6)+OADRASTER	CALL	(A1)		; appel de GRA_RASTER	JUMP'	EXIT$COUL$:	TEST.L	D1:#BSRCCOUL	JUMP',BC CSRC$	MUL.WU	D5,D0		; D5 <-- Iy sourceCSRC$:	TEST.L	D1:#BDSTCOUL	JUMP',BC CDST$	MUL.WU	D6,D0		; D6 <-- Iy destinationCDST$:	LOAD.L	A1,(A6)+OADCRASTER	CALL	(A1)		; appel de GRA_CRASTEREXIT$:	POPM.L	D0..D6,A1,A2	RET;--------\\; DRRECT  >;========/; Dessine un rectangle.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRRECT:	PUSHM.L	D3..D5	LOAD.L	D5,D4		; D5 <-- dimensions (dy;dx)	AND.L	D4,#H'FFFF	CALL	DRLINE		; trace ligne suprieure	LOAD.L	D4,D5	CLR.W	D4	CALL	DRLINE		; trace ligne de droite	LOAD.L	D4,D5	AND.L	D4,#H'FFFF	NEG.W	D4	CALL	DRLINE		; trace ligne infrieure	LOAD.L	D4,D5	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DRLINE		; trace ligne de gauche	POPM.L	D3..D5	RET;--------\\; DRLINE  >;========/; Dessine un segment de droite.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	D3.L	coordonne d'arrive (y;x); mod	D3.L, D7.WDRLINE:	PUSHM.L	D1,D2,D4,A1,A2	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADLINE	CALL	(A1)		; appel de GRA_LINE	EX.L	D3,D4	ADD.W	D3,D4		; D3 <-- arrive en X	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- arrive en Y	SWAP.W	D3;	SWAP.W	D4	POPM.L	D1,D2,D4,A1,A2	RET;---------\\; DRTRADEF >;=========/; Dfinit une trame.; ATTENTION: les bits sont retourns par-rapport  LIB,?DRMDEF !; in	D3.L	trame;	D4.L	trame; out	-; mod	D7.WDRTRADEF:	LOAD.L	(A0)+ODFTRA+0,D3	LOAD.L	(A0)+ODFTRA+4,D4	RET	.END