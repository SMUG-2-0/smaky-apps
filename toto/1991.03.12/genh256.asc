	.TITLE	GENH256	.PROC	M680002	.REF	SMAKY	.LOC	0OHAZA:	.BLKB	8		; registre 63 bits pour gnrateur alatoireOTABLE:	.BLKB	256LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	CALL	COUPSAC	LOAD.L	A3,#(A6)+OTABLE	CLR.W	D3LOOP:	CALL	HAZARD	CALL	EXIST	JUMP,NE LOOP	LOAD.B	(A3)+(D3.W),D4	INC.W	D3	COMP.W	D3,#256	JUMP,LO LOOP	LOAD.L	A3,#R16"NOM	FOS	?DELETE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	LOAD.L	A4,#(A6)+OTABLE	LOAD.L	D4,#256	FOS	?WRBYTE	FOS	?CLOSE	EXITNOM:	.ASCIZ	"JEUX:TOTO:H256.DATA"	.EVENEXIST:	PUSHM.L	D3,A3	CLR.W	D710$:	DEC.W	D3	JUMP',NS 90$	COMP.B	D4,(A3+)	JUMP,NE 10$	LOAD.W	D7,#190$:	POPM.L	D3,A3	TEST.W	D7	RET;--------\\; COUPSAC >;========/; Coup de sac pour le gnrateur alatoire.; in	-; out	-; mod	D7.WCOUPSAC:	PUSHM.L	D3,D4	LIB	?RDCLOCK	; D3/D4 <-- date et heure	RR.L	D3,#3	RL.L	D4,#7		; savante cuisine	NOT.L	D3	XOR.L	D4,D3	LOAD.L	(A6)+OHAZA+0,D3	LOAD.L	(A6)+OHAZA+4,D4	LOAD.W	D3,#10-120$:	CALL	HAZARD		; tire qq nombres	DECJ.W,NMO D3,20$	POPM.L	D3,D4	RET;--------\\; HAZARD  >;========/; Tire un nombre alatoire de 32 bits.; On utilise un registre  dcalage de 63 bits, avec un XNOR entre; les bits 0 et 60 pour calculer le nouveau bit inject.; in	-; out	D4.L	nombre; mod	D4.LHAZARD:	PUSHM.L	D2,D3	LOAD.W	D2,#32-1	LOAD.L	D3,(A6)+OHAZA+0	LOAD.L	D4,(A6)+OHAZA+410$:	TEST.L	D4:#1	JUMP,BC 20$	TEST.L	D3:#30	JUMP,BC 35$	JUMP	30$20$:	TEST.L	D3:#30	JUMP,BS 35$30$:	CLRX	RRX.L	D3,#1	RRX.L	D4,#1	JUMP	40$35$:	SETX	RRX.L	D3,#1	RRX.L	D4,#140$:	LOAD.L	(A6)+OHAZA+0,D3	LOAD.L	(A6)+OHAZA+4,D4	DECJ.W,NMO D2,10$	POPM.L	D2,D3	RETVAR:	.FILLB	LGVAR,0	.END	START