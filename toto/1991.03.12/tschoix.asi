	.SBTTL	TSCHOIX.ASI;---------\\; CHNIV123 >;=========/; Choix d'un niveau 1..3 ..; in	-; out	D3.W	touche presse;	D7.W	erreur; mod	D3.L, D7.WCHNIV123:	PUSHM.L	A4	CALL	_CCMO		; enlve la souris	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE EXIT$	CALL	ICOMENLEVE	; enlve toto de l'cran ...	LOAD.L	A4,#R16"TMENU$	CALL	CHDRAW		; dessine les choix	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	CALL	_CLRFIFO	; vide le fifo du clavier	CALL	_SCMO		; remet la sourisMENU$:	LOAD.L	A4,#R16"TMENU$	CALL	CHMENU		; choix selon menu ...	COMP.W	D3,#'1	JUMP',LO NO13$	COMP.W	D3,#'3	JUMP',LS OK$NO13$:	COMP.W	D3,#'9	JUMP',EQ OK$	COMP.W	D3,#F0	JUMP',EQ OK$	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	MENU$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	A4	TEST.W	D7		; retour EQ/NE	RETTMENU$:	.W	ICONIV2	.W	ICONIV4	.W	ICONIV6	.W	0	.W	0	.W	0	.W	0	.W	0	.W	ICOANNULE;------------\\; CHNIV123456 >;============/; Choix d'un niveau 1..6 ..; in	-; out	D3.W	touche presse;	D7.W	erreur; mod	D3.L, D7.WCHNIV123456:	PUSHM.L	A4	CALL	_CCMO		; enlve la souris	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE EXIT$	CALL	ICOMENLEVE	; enlve toto de l'cran ...	LOAD.L	A4,#R16"TMENU$	CALL	CHDRAW		; dessine les choix	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	CALL	_CLRFIFO	; vide le fifo du clavier	CALL	_SCMO		; remet la sourisMENU$:	LOAD.L	A4,#R16"TMENU$	CALL	CHMENU		; choix selon menu ...	COMP.W	D3,#'1	JUMP',LO NO16$	COMP.W	D3,#'6	JUMP',LS OK$NO16$:	COMP.W	D3,#'9	JUMP',EQ OK$	COMP.W	D3,#F0	JUMP',EQ OK$	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	MENU$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	A4	TEST.W	D7		; retour EQ/NE	RETTMENU$:	.W	ICONIV1	.W	ICONIV2	.W	ICONIV3	.W	ICONIV4	.W	ICONIV5	.W	ICONIV6	.W	0	.W	0	.W	ICOANNULE;---------\\; CHEXBASE >;=========/; Regarde les icnes de base qui existent.; in	-; out	-; mod	D7.WCHEXBASE:	PUSHM.L	D3,D4,A4	LOAD.W	(A6)+OCHMAP,#2^0!2^7	LOAD.L	A4,#(A6)+OBKTAB	LOAD.W	D4,(A6)+OBKNBU	JUMP',EQ MM9$MM2$:	TEST.L	(A4)+OBKPIC	; image existe ?	JUMP',EQ MM4$		; non => MM4$	TEST.L	(A4)+OBKNSI	; y'a-t-il des sous-images ?	JUMP',EQ MM4$		; non => MM4$	LOAD.L	D3,(A4)+OBKFAN	TEST.L	D3:#BFAMEMORY	JUMP',BS MM8$MM4$:	LOAD.L	A4,#(A4)+LBK	DEC.W	D4	JUMP,NE MM2$	JUMP'	MM9$MM8$:	TSET.B	(A6)+OCHMAP+1:#1MM9$:	LOAD.L	A4,#(A6)+OBKTAB	LOAD.W	D4,(A6)+OBKNBU	JUMP',EQ PZ9$PZ2$:	TEST.L	(A4)+OBKPIC	; image existe ?	JUMP',EQ PZ4$		; non => PZ4$	TEST.L	(A4)+OBKNSI	; y'a-t-il des sous-images ?	JUMP',EQ PZ8$		; non => PZ8$PZ4$:	LOAD.L	A4,#(A4)+LBK	DEC.W	D4	JUMP,NE PZ2$	JUMP'	PZ9$PZ8$:	TSET.B	(A6)+OCHMAP+1:#2PZ9$:	LOAD.W	D4,#BFALETTRE	CALL	_BKSEXIST	JUMP',NE LT$	TSET.B	(A6)+OCHMAP+1:#3LT$:	LOAD.W	D4,#BFAPENDU	CALL	_BKSEXIST	JUMP',NE PD$	TSET.B	(A6)+OCHMAP+1:#4PD$:	LOAD.W	D4,#BFAPERMU	CALL	_BKSEXIST	JUMP',NE PM$	TSET.B	(A6)+OCHMAP+1:#5PM$:	LOAD.W	D4,#BFAGRILLE	CALL	_BKSEXIST	JUMP',NE GR$	TSET.B	(A6)+OCHMAP+1:#6GR$:	LOAD.W	D4,(A6)+OACTIV	AND.W	(A6)+OCHMAP,D4	POPM.L	D3,D4,A4	RET;-----------\\; CHEXMEMORY >;===========/; Regarde les icnes des puzzles qui existent.; in	-; out	-; mod	D7.WCHEXMEMORY:	PUSHM.L	D4,A4	LOAD.W	(A6)+OCHMAP,#2^8	CLR.W	D4LOOP$:	CALL	MMSEARCH	; A4 <-- ^dans OBKTAB	JUMP',NE EXIT$	TSET.B	(A6)+OCHMAP+1:D4	INC.W	D4	COMP.W	D4,#8	JUMP,LO LOOP$EXIT$:	POPM.L	D4,A4	RET;-----------\\; CHEXPUZZLE >;===========/; Regarde les icnes des puzzles qui existent.; in	-; out	-; mod	D7.WCHEXPUZZLE:	PUSHM.L	D2..D4,A4	LOAD.W	(A6)+OCHMAP,#2^8	LOAD.L	A4,#(A6)+OBKTAB	LOAD.W	D4,(A6)+OBKNBU	JUMP',EQ EXIT$LOOP$:	TEST.L	(A4)+OBKPIC	; image existe ?	JUMP',EQ NEXT$		; non => NEXT$	TEST.L	(A4)+OBKNSI	; y'a-t-il des sous-images ?	JUMP',NE NEXT$		; oui => NEXT$	LOAD.L	D3,(A4)+OBKFAN	LOAD.B	D2,#-1	TEST.L	D3:#BFAP66	JUMP',BS MAP$	SR.B	D2,#1	TEST.L	D3:#BFAP55	JUMP',BS MAP$	SR.B	D2,#1	TEST.L	D3:#BFAP44	JUMP',BS MAP$	SR.B	D2,#1	TEST.L	D3:#BFAP43	JUMP',BS MAP$	SR.B	D2,#1	TEST.L	D3:#BFAP33	JUMP',BS MAP$	SR.B	D2,#1	TEST.L	D3:#BFAP32	JUMP',BS MAP$	SR.B	D2,#1	TEST.L	D3:#BFAP22	JUMP',BS MAP$	SR.B	D2,#1MAP$:	OR.B	(A6)+OCHMAP+1,D2NEXT$:	LOAD.L	A4,#(A4)+LBK	DEC.W	D4	JUMP,NE LOOP$EXIT$:	POPM.L	D2..D4,A4	RET;-------------\\; CHEXLETTRE13 >;=============/; Regarde les icnes des lettres qui existent.; in	A2.L	^routine LT*; out	-; mod	D7.WCHEXLETTRE13:	PUSHM.L	D2..D4,A3,A4	LOAD.W	(A6)+OCHMAP,#2^8	CLR.W	(A6)+OLTNIV	LOAD.W	D3,#-1NIV0L$:	CALL	_BKSNEXT	; D3/A3/A4 <-- suivant	JUMP',NE NIV0E$	CALL	(A2)		; CALL LT*	JUMP,NE NIV0L$	TSET.B	(A6)+OCHMAP+1:#0NIV0E$:	INC.W	(A6)+OLTNIV	LOAD.W	D3,#-1NIV1L$:	CALL	_BKSNEXT	; D3/A3/A4 <-- suivant	JUMP',NE NIV1E$	CALL	(A2)		; CALL LT*	JUMP,NE NIV1L$	TSET.B	(A6)+OCHMAP+1:#1NIV1E$:	INC.W	(A6)+OLTNIV	LOAD.W	D3,#-1NIV2L$:	CALL	_BKSNEXT	; D3/A3/A4 <-- suivant	JUMP',NE NIV2E$	CALL	(A2)		; CALL LT*	JUMP,NE NIV2L$	TSET.B	(A6)+OCHMAP+1:#2NIV2E$:	POPM.L	D2..D4,A3,A4	RET;-------------\\; CHEXLETTRE16 >;=============/; Regarde les icnes des lettres qui existent.; in	A2.L	^routine LT*; out	-; mod	D7.WCHEXLETTRE16:	PUSHM.L	D2..D4,A3,A4	LOAD.W	(A6)+OCHMAP,#2^8	CLR.W	(A6)+OLTNIV	LOAD.W	D3,#-1NIV0L$:	CALL	_BKSNEXT	; D3/A3/A4 <-- suivant	JUMP',NE NIV0E$	CALL	(A2)		; CALL LT*	JUMP,NE NIV0L$	TSET.B	(A6)+OCHMAP+1:#0NIV0E$:	INC.W	(A6)+OLTNIV	LOAD.W	D3,#-1NIV1L$:	CALL	_BKSNEXT	; D3/A3/A4 <-- suivant	JUMP',NE NIV1E$	CALL	(A2)		; CALL LT*	JUMP,NE NIV1L$	TSET.B	(A6)+OCHMAP+1:#1NIV1E$:	INC.W	(A6)+OLTNIV	LOAD.W	D3,#-1NIV2L$:	CALL	_BKSNEXT	; D3/A3/A4 <-- suivant	JUMP',NE NIV2E$	CALL	(A2)		; CALL LT*	JUMP,NE NIV2L$	TSET.B	(A6)+OCHMAP+1:#2NIV2E$:	INC.W	(A6)+OLTNIV	LOAD.W	D3,#-1NIV3L$:	CALL	_BKSNEXT	; D3/A3/A4 <-- suivant	JUMP',NE NIV3E$	CALL	(A2)		; CALL LT*	JUMP,NE NIV3L$	TSET.B	(A6)+OCHMAP+1:#3NIV3E$:	INC.W	(A6)+OLTNIV	LOAD.W	D3,#-1NIV4L$:	CALL	_BKSNEXT	; D3/A3/A4 <-- suivant	JUMP',NE NIV4E$	CALL	(A2)		; CALL LT*	JUMP,NE NIV4L$	TSET.B	(A6)+OCHMAP+1:#4NIV4E$:	INC.W	(A6)+OLTNIV	LOAD.W	D3,#-1NIV5L$:	CALL	_BKSNEXT	; D3/A3/A4 <-- suivant	JUMP',NE NIV5E$	CALL	(A2)		; CALL LT*	JUMP,NE NIV5L$	TSET.B	(A6)+OCHMAP+1:#5NIV5E$:	POPM.L	D2..D4,A3,A4	RET;--------\\; CHMENU  >;========/; Choix d'une case dans un menu.; in	A4.L	^table de description; out	D3.W	touche presse; mod	D3.L, D7.WCHMENU:	PUSHM.L	D4LOOP$:	LIB	?GETCAR		; clavier/souris ?	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	COMP.W	D3,#'1	JUMP',LO EXIT$	COMP.W	D3,#'9	JUMP',HI EXIT$	PUSH.L	D3	SUB.W	D3,#'1		; D3 <-- rang (0..8)	CALL	CHEXIST		; icne existe ?	POPM.L	D3	JUMP',EQ EXIT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	CALL	CHMOVE		; choix d'une case ...	JUMP,NE BIP$	ADD.W	D3,#'1		; D3 <-- '1..'9EXIT$:	POPM.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CHDRAW  >;========/; Dessine le cadre et toutes les icnes.; in	A4.L	^table de description; out	-; mod	D7.WCHDRAW:	PUSHM.L	D0..D4,A4	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	CALL	_INVTRAME	LIB	?DRMDEF	CALL	COLORHAZARD	; choix de couleurs alatoires	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame toute la fentre	LIB	?COLORPOP	LOAD.W	D1,#B'0000011000011001	LOAD.L	D3,#H'10000*20+20	LOAD.L	D4,#H'10000*(LYWDO-20-20)+(LXWDO-20-20)	CALL	_DESRECTM	; dessine le cadre	PUSHM.L	D3,D4	LOAD.L	D3,#H'55AA55AA	LOAD.L	D4,D3	CALL	_INVTRAME	LIB	?DRMDEF	POPM.L	D3,D4	CALL	COLORHAZARD	; choix de couleurs alatoires	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'intrieur	LIB	?COLORPOP	CLR.W	D0LOOP$:	LOAD.W	D3,D0	CALL	CHEXIST		; icne existe ?	JUMP,NE NEXT$		; non => NEXT$;	LOAD.W	D3,D0	CALL	CHPOSDIM	; D3/D4 <-- position/dimensions	PUSHM.L	D3,D4	CLR.L	D3	CLR.L	D4	CALL	_INVTRAME	LIB	?DRMDEF	POPM.L	D3,D4	PUSHM.L	D3,D4	SUB.W	D3,#4	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	ADD.W	D4,#4+4-1	SWAP.W	D4	ADD.W	D4,#4+4-1	SWAP.W	D4	LOAD.W	D2,#CLRDOT	CALL	_INVMODE	LIB	?DRTRAME	; efface dedans	LOAD.W	D2,#SETDOT	CALL	_INVMODE	LIB	?DRRECT		; dessine rectangle autour	POPM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,#LYICOP	ASR.W	D4,#1	ADD.W	D3,D4	SUB.W	D3,#LYICO-LYICOP;	SWAP.W	D4	SWAP.W	D3	LOAD.L	D4,D3	LOAD.W	D3,D0	ADD.W	D3,#ICOCH1	CALL	ICODRAW	ADD.W	D4,#LXICO+10	LOAD.W	D3,(A4)	CALL	CHICONENEXT$:	ADD.L	A4,#2	INC.W	D0	COMP.W	D0,#9	JUMP,LO LOOP$	POPM.L	D0..D4,A4	RET;--------\\; CHEXIST >;--------/; Regarde si une icne existe.; in	D3.W	rang de l'icne (0..8); out	D7.W	erreur si n'existe pas; mod	D7.WCHEXIST:	PUSH.W	D4	LOAD.W	D7,#1	LOAD.W	D4,(A6)+OCHMAP	TEST.L	D4:D3		; icne existe ?	JUMP',BC EXIT$		; non => EXIT$	CLR.W	D7EXIT$:	POP.W	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CHICONE >;--------/; Dessine une icne spciale.; in	D3.W	code de l'icne;	D4.L	position (y;x); out	-; mod	D7.WCHICONE:	PUSHM.L	D1..D4	TEST.L	D3:#15	JUMP',BS SPEC$	CALL	ICODRAW		; dessine une icne de ITP84	JUMP	EXIT$SPEC$:	SWAP.W	D4	ADD.W	D4,#LYICO-LYICOP	SWAP.W	D4	LOAD.W	D1,D3	LOAD.L	D3,#H'10000*1+4	COMP.W	D1,#ICOPZ41	JUMP',EQ PUZZLE$	LOAD.L	D3,#H'10000*2+2	COMP.W	D1,#ICOPZ22	JUMP',EQ PUZZLE$	LOAD.L	D3,#H'10000*2+3	COMP.W	D1,#ICOPZ32	JUMP',EQ PUZZLE$	LOAD.L	D3,#H'10000*3+3	COMP.W	D1,#ICOPZ33	JUMP',EQ PUZZLE$	LOAD.L	D3,#H'10000*3+4	COMP.W	D1,#ICOPZ43	JUMP',EQ PUZZLE$	LOAD.L	D3,#H'10000*4+4	COMP.W	D1,#ICOPZ44	JUMP',EQ PUZZLE$	LOAD.L	D3,#H'10000*5+5	COMP.W	D1,#ICOPZ55	JUMP',EQ PUZZLE$	LOAD.L	D3,#H'10000*6+6	COMP.W	D1,#ICOPZ66	JUMP',EQ PUZZLE$	COMP.W	D1,#ICOMM+0	JUMP',LO EXIT$	COMP.W	D1,#ICOMM+9	JUMP',LS MEMORY$	JUMP	EXIT$PUZZLE$:	CALL	CHPUZZLE	JUMP'	EXIT$MEMORY$:	LOAD.W	D3,D1	CALL	CHMEMORY;	JUMP'	EXIT$EXIT$:	POPM.L	D1..D4	RET;---------\\; CHPUZZLE >;---------/; Dessine un carr ombr et quadrill.; in	D4.L	position (y;x);	D3.L	nb de morceaux (ny;nx);	D2.W	mode de dessin; out	-; mod	D7.WCHPUZZLE:	PUSHM.L	D0..D5	LOAD.L	D0,D3	PUSH.L	D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	_INVTRAME	LIB	?DRMDEF	POP.L	D3	LOAD.L	D4,#H'10000*(LYICOP-2)+(LXICO-2)	LOAD.W	D1,#2	LIB	?DRRECTO	PUSHM.L	D3,D4	LOAD.L	D3,#H'11004400	LOAD.L	D4,D3	CALL	_INVTRAME	LIB	?DRMDEF	POPM.L	D3,D4	LIB	?DRTRAME	LOAD.W	D5,#1LOOPX$:	PUSHM.L	D3,D4	PUSH.L	D4	MUL.WU	D4,D5	DIV.WU	D4,D0	ADD.W	D3,D4	POP.L	D4	CLR.W	D4	LIB	?DRSEG	POPM.L	D3,D4	INC.W	D5	COMP.W	D5,D0	JUMP,LO LOOPX$	SWAP.W	D0	LOAD.W	D5,#1LOOPY$:	PUSHM.L	D3,D4	PUSH.L	D4	SWAP.W	D4	MUL.WU	D4,D5	DIV.WU	D4,D0	SWAP.W	D3	ADD.W	D3,D4	SWAP.W	D3	POP.L	D4	AND.L	D4,#H'FFFF	LIB	?DRSEG	POPM.L	D3,D4	INC.W	D5	COMP.W	D5,D0	JUMP,LO LOOPY$	POPM.L	D0..D5	RET;---------\\; CHMEMORY >;---------/; Dessine une image icne.; in	D4.L	position (y;x);	D3.W	icne (ICOMM+0..n);	D2.W	mode de dessin; out	-; mod	D7.WCHMEMORY:	PUSHM.L	D1..D4,A3,A4	LOAD.L	D1,D4	LOAD.W	D4,D3	SUB.W	D4,#ICOMM	; D4 <-- 0..n	CALL	MMSEARCH	; A4 <-- ^dans OBKTAB	JUMP,NE EXIT$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	CLR.L	(A3)+1	LOAD.L	(A3)+5,(A4)+OBKPII	LOAD.W	(A3)+9,#LXICO/8	SWAP.W	D1	LOAD.L	(A3)+11,D1	CLR.L	(A3)+15	CLR.W	(A3)+19	LOAD.W	(A3)+21,#LXICO	LOAD.W	(A3)+23,#LYICOP	LOAD.B	(A3)+25,D2	LOAD.W	D3,#26	LIB	?STRING	CLR.W	D7EXIT$:	POPM.L	D1..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CHMOVE  >;========/; Choisit une case.; in	A4.L	^table de description; out	D3.W	numro de la case;	D7.W	erreur; mod	D3.L, D7.WCHMOVE:	PUSHM.L	D1,D2,D4	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE EXIT$	CALL	CHDETECT	; D3 <-- case o est la souris	JUMP,NE EXIT$	LOAD.W	D2,#SETDOT	CALL	CHHILIC		; allume la premire case	LOAD.W	D1,D3		; D1 <-- caseLOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	CHDETECT	; D3 <-- case o est la souris	COMP.W	D3,D1		; toujours dans la mme case ?	JUMP,EQ LOOP$		; oui => LOOP$	EX.L	D3,D1	LOAD.W	D2,#CLRDOT	CALL	CHHILIC		; teint la case	LOAD.W	D3,D1	LOAD.W	D2,#SETDOT	CALL	CHHILIC		; allume la case	JUMP	LOOP$END$:	LOAD.W	D3,D1	LOAD.W	D2,#CLRDOT	CALL	CHHILIC		; teint la dernire case	CLR.W	D7EXIT$:	POPM.L	D1,D2,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; CHDETECT >;---------/; Dtecte dans quelle case est la souris.; in	D4.L	position de la souris;	A4.L	^table de description; out	D3.W	numro de la case;	D7.W	erreur; mod	D3.L, D7.WCHDETECT:	PUSHM.L	D2,D4..D6	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- position en Y	LOAD.W	D5,D4		; D5 <-- position en X	LOAD.W	D2,#-1LOOP$:	INC.W	D2	LOAD.W	D3,D2	CALL	CHPOSDIM	; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	COMP.W	D5,D3	JUMP,LO LOOP$	ADD.W	D3,D4	COMP.W	D5,D3	JUMP,HS LOOP$	SWAP.W	D3	SWAP.W	D4	COMP.W	D6,D3	JUMP,LO LOOP$	ADD.W	D3,D4	COMP.W	D6,D3	JUMP,HS LOOP$	LOAD.W	D3,D2	CALL	CHEXIST		; icne existe ?	JUMP,NE LOOP$		; non => LOOP$EXIT$:	POPM.L	D2,D4..D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; CHHILIC >;--------/; Met en vidence le cadre de la case.; in	D3.W	numro de la case;	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WCHHILIC:	PUSHM.L	D2..D4	CALL	CHPOSDIM	; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	SUB.W	D3,#4	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	ADD.W	D4,#4+4	SWAP.W	D4	ADD.W	D4,#4+4	SWAP.W	D4	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LIB	?COLORPUSH	LOAD.L	D3,#COLORHILI	LIB	?COLORSR	POPM.L	D3,D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	LIB	?COLORPOPEXIT$:	POPM.L	D2..D4	RET;---------\\; CHPOSDIM >;---------/; Donne la position et les dimensions d'une case.; in	D3.W	numro de la case; out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WCHPOSDIM:	PUSH.L	D2	CLR.L	D2	LOAD.W	D2,D3	LOAD.W	D7,#1	COMP.W	D2,#9	JUMP',HS EXIT$	DIV.WU	D2,#3;;?	SWAP.W	D2	LOAD.W	D3,D2	MUL.WU	D3,#(LYWDO-30-30)/3	ADD.W	D3,#30+10	; D3 <-- position dans l'cran en Y	SWAP.W	D3	SWAP.W	D2	MUL.WU	D2,#(LXWDO-30-30)/3	ADD.W	D2,#30+10	LOAD.W	D3,D2		; D3 <-- position dans l'cran en X	LOAD.W	D4,#((LYWDO-30-30)/3)-10-10	SWAP.W	D4	LOAD.W	D4,#((LXWDO-30-30)/3)-10-10	CLR.W	D7EXIT$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET	.END