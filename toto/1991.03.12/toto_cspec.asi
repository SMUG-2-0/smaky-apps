	.SBTTL	TOTO_CSPEC;---------\\; PROGRESS >;=========/; Effectue une progression quelconque.; in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	----;	D1.L	incrment/dlai;	----;	D0.W	type de progression (PROG*); out	-; mod	D7.WPROGRESS:	COMP.W	D0,#PROGHB	JUMP,EQ PROGRESSHB	COMP.W	D0,#PROGCN	JUMP,EQ PROGRESSCN	COMP.W	D0,#PROGCI	JUMP,EQ PROGRESSCI	COMP.W	D0,#PROGSV	JUMP,EQ PROGRESSSV	COMP.W	D0,#PROGAL	JUMP,EQ PROGRESSAL	JUMP	PROGRESSA;-----------\\; PROGRESSHB >;===========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: progression de haut en bas; in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	----;	D1.L	incrment/dlai; out	-; mod	D7.WPROGRESSHB:	PUSHM.L	D0..D6,A2..A4	CALL	PROGRESSI	; prpare les paramtres	LOAD.W	D4,D1		; D4 <-- dlai	CLR.W	D3		; D3 <-- compteur	LOAD.L	D0,D2	SR.W	D0,#5		; D0 <-- largeur /32 car par .L	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ 10$		; non => 10$	SL.W	D0,#2		; D0 <-- *4 (nb de bits/pixel)10$:	DEC.W	D0		; D0 <-- largeur -1 car NMO	LOAD.L	D2,D1	SWAP.W	D2		; D2 <-- incrment20$:	PUSHM.L	D0,A3,A430$:	LOAD.L	(A4+),(A3+)	; destination <-- source	DECJ.W,NMO D0,30$	POPM.L	D0,A3,A4	INC.W	D3	CLR.L	D1	LOAD.W	D1,D3	DIV.WU	D1,D2	SWAP.W	D1	TEST.W	D1	JUMP',NE 50$	NTREL	?DELMS		; attend un p'tit peu50$:	ADD.W	A3,D5		; A3 <-- ^ligne suivante	ADD.W	A4,D6		; A4 <-- ^ligne suivante	SWAP.W	D0	DEC.W	D0	LOAD.W	D1,D0	SWAP.W	D0	TEST.W	D1	JUMP,NE 20$	POPM.L	D0..D6,A2..A4	RET;-----------\\; PROGRESSCN >;===========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: carrs (zoom avant); in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	----;	D1.W	dlai; out	-; mod	D7.WPROGRESSCN:	PUSHM.L	D0..D6,A2..A4	CALL	PROGRESSI	; prpare les paramtres	LOAD.W	D4,D1		; D4 <-- dlai	CLR.W	D320$:	CALL	PROGRESSCC	; dessine un carr	CALL	PROGRESS1	; progresse un p'tit peu ...	TEST.W	D4	JUMP',EQ 50$	NTREL	?DELMS		; attend un p'tit peu50$:	INC.W	D3	COMP.W	D3,#16	JUMP,LO 20$	POPM.L	D0..D6,A2..A4	RET;-----------\\; PROGRESSCI >;===========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: carrs (zoom arrire); in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	----;	D1.W	dlai; out	-; mod	D7.WPROGRESSCI:	PUSHM.L	D0..D6,A2..A4	CALL	PROGRESSI	; prpare les paramtres	LOAD.W	D4,D1		; D4 <-- dlai	LOAD.W	D3,#1520$:	CALL	PROGRESSCC	; dessine un carr	CALL	PROGRESS1	; progresse un p'tit peu ...	TEST.W	D4	JUMP',EQ 50$	NTREL	?DELMS		; attend un p'tit peu50$:	DEC.W	D3	JUMP,NC 20$	POPM.L	D0..D6,A2..A4	RET;-----------\\; PROGRESSCC >;-----------/; Dessine un carr centr dans la matrice de transfert.; in	D3.W	rang (0..15); out	-; mod	D7.WPROGRESSCC:	PUSHM.L	D2..D4,A4	CALL	OPEDISMAT	; dessin en mmoire	LOAD.L	A4,A2		; A4 <-- ^matrice vide	LOAD.L	D4,#H'10000*32+32	CALL	NEWDISMAT	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ DRAW$		; non => DRAW$	CLR.W	D2	LOAD.B	D2,(A0)+ODFCNP	MUL.WU	D2,(A0)+ODFIIY	LOAD.W	(A0)+ODFIIY,D2	LOAD.B	(A0)+ODFCMD,#2DRAW$:	LOAD.W	D2,D3	INC.W	D2	SL.W	D2,#1	DEC.W	D2	LOAD.W	D4,D2	SWAP.W	D4	LOAD.W	D4,D2	LOAD.W	D2,D3	SUB.W	D2,#15	NEG.W	D2	LOAD.W	D3,D2	SWAP.W	D3	LOAD.W	D3,D2	LOAD.W	D2,#SETDOT	CALL	DRRECT	CALL	CLODISMAT	; dessin dans l'cran	POPM.L	D2..D4,A4	RET;-----------\\; PROGRESSSV >;===========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: stores vnitiens; in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	----;	D1.W	dlai; out	-; mod	D7.WPROGRESSSV:	PUSHM.L	D0..D6,A2..A4	CALL	PROGRESSI	; prpare les paramtres	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COLOR$	LOAD.W	D4,D1		; D4 <-- dlai	CLR.W	D3BLOOP$:	LOAD.L	A2,#(A6)+OMATPR	LOAD.W	D1,#32-1BCLR$:	CLR.L	(A2+)	DECJ.W,NMO D1,BCLR$	LOAD.L	A2,#(A6)+OMATPR	; A2 <-- ^matrice vide	LOAD.L	(A2)+(D3.W),#-1	CALL	PROGRESS1	; progresse un p'tit peu ...	TEST.W	D4	JUMP',EQ BNEXT$	NTREL	?DELMS		; attend un p'tit peuBNEXT$:	ADD.W	D3,#4	COMP.W	D3,#128	JUMP,LO BLOOP$	JUMP	EXIT$COLOR$:	LOAD.W	D4,D1		; D4 <-- dlai	CLR.W	D3CLOOP$:	LOAD.L	A2,#(A6)+OMATPR	LOAD.W	D1,#32-1CCLR$:	CLR.L	(A2+)	CLR.L	(A2+)	CLR.L	(A2+)	CLR.L	(A2+)	DECJ.W,NMO D1,CCLR$	LOAD.L	A2,#(A6)+OMATPR	; A2 <-- ^matrice vide	LOAD.L	(A2)+(D3.W)+0,#-1	LOAD.L	(A2)+(D3.W)+4,#-1	LOAD.L	(A2)+(D3.W)+8,#-1	LOAD.L	(A2)+(D3.W)+12,#-1	CALL	PROGRESS1	; progresse un p'tit peu ...	TEST.W	D4	JUMP',EQ CNEXT$	NTREL	?DELMS		; attend un p'tit peuCNEXT$:	ADD.W	D3,#4*4	COMP.W	D3,#128*4	JUMP,LO CLOOP$EXIT$:	POPM.L	D0..D6,A2..A4	RET;----------\\; PROGRESSA >;==========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: alatoire (fondu enchan); in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x); out	-; mod	D7.WPROGRESSA:	COMP.B	(A6)+OMACHINE,#SMAKY324	JUMP,EQ PROGRESSAL	PUSHM.L	D0..D6,A1..A4	CALL	PROGRESSI	; prpare les paramtres	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE COLOR$	LOAD.L	A1,#R16"TPR256	LOAD.W	D1,#(16*16)-1BLOOP$:	LOAD.L	A2,#(A6)+OMATPR	LOAD.W	D0,#(32/4)-1	CLR.L	D3BCLR$:	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	DECJ.W,NMO D0,BCLR$	LOAD.L	A2,#(A6)+OMATPR	LOAD.B	D3,(A1+)	; D3 <-- xxxxxxxx76543210	LOAD.W	D4,D3	SR.B	D4,#5		; D4 <-- xxxxxxxxooooo765	RR.W	D3,#1		; D3 <-- 0xxxxxxxo7654321	SL.B	D3,#1		; D3 <-- 0xxxxxxx7654321o	RL.W	D3,#1		; D3 <-- xxxxxxxx654321o0	AND.W	D3,#B'111101	; D3 <-- oooooooooo4321o0	TSET.B	(A2)+(D3.W):D4	ADD.W	D3,#2	TSET.B	(A2)+(D3.W):D4	ADD.W	D3,#64-2	TSET.B	(A2)+(D3.W):D4	ADD.W	D3,#2	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	DECJ.W,NMO D1,BLOOP$	JUMP	EXIT$COLOR$:	LOAD.L	A1,#R16"TPR256	LOAD.W	D1,#(16*16)-1CLOOP$:	LOAD.L	A2,#(A6)+OMATPR	CLR.W	D3	LOAD.B	D3,(A1+)	; D3 <-- oooooooo76543210	LOAD.W	D4,D3	SR.B	D4,#4		; D4 <-- oooooooooooo7654	AND.B	D3,#B'1111	; D3 <-- oooooooooooo3210	CALL	PROGRESSCSD	; OMATPR <-- met un pixel	ADD.W	D3,#16	CALL	PROGRESSCSD	; OMATPR <-- met un pixel	ADD.W	D4,#16	CALL	PROGRESSCSD	; OMATPR <-- met un pixel	SUB.W	D3,#16	CALL	PROGRESSCSD	; OMATPR <-- met un pixel	CALL	PROGRESS1	; progresse un p'tit peu ...	SUB.W	D4,#16	CALL	PROGRESSCCD	; OMATPR <-- enlve un pixel	ADD.W	D3,#16	CALL	PROGRESSCCD	; OMATPR <-- enlve un pixel	ADD.W	D4,#16	CALL	PROGRESSCCD	; OMATPR <-- enlve un pixel	SUB.W	D3,#16	CALL	PROGRESSCCD	; OMATPR <-- enlve un pixel	DECJ.W,NMO D1,CLOOP$EXIT$:	POPM.L	D0..D6,A1..A4	RET;-----------\\; PROGRESSAL >;===========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: alatoire lent (fondu enchan); in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x); out	-; mod	D7.WPROGRESSAL:	PUSHM.L	D0..D6,A1..A4	CALL	PROGRESSI	; prpare les paramtres	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE COLOR$	LOAD.L	A1,#R16"TPR256	LOAD.W	D1,#(16*16)-1BLOOP$:	LOAD.L	A2,#(A6)+OMATPR	LOAD.W	D0,#(32/4)-1	CLR.L	D3BCLR$:	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	DECJ.W,NMO D0,BCLR$	LOAD.L	A2,#(A6)+OMATPR	LOAD.B	D3,(A1+)	; D3 <-- xxxxxxxx76543210	LOAD.W	D4,D3	SR.B	D4,#5		; D4 <-- xxxxxxxxooooo765	RR.W	D3,#1		; D3 <-- 0xxxxxxxo7654321	SL.B	D3,#1		; D3 <-- 0xxxxxxx7654321o	RL.W	D3,#1		; D3 <-- xxxxxxxx654321o0	AND.W	D3,#B'111101	; D3 <-- oooooooooo4321o0	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	TCLR.B	(A2)+(D3.W):D4	ADD.W	D3,#2	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	TCLR.B	(A2)+(D3.W):D4	ADD.W	D3,#64-2	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	TCLR.B	(A2)+(D3.W):D4	ADD.W	D3,#2	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	TCLR.B	(A2)+(D3.W):D4	DECJ.W,NMO D1,BLOOP$	JUMP	EXIT$COLOR$:	LOAD.L	A1,#R16"TPR256	LOAD.W	D1,#(16*16)-1CLOOP$:	LOAD.L	A2,#(A6)+OMATPR	CLR.W	D3	LOAD.B	D3,(A1+)	; D3 <-- oooooooo76543210	LOAD.W	D4,D3	SR.B	D4,#4		; D4 <-- oooooooooooo7654	AND.B	D3,#B'1111	; D3 <-- oooooooooooo3210	CALL	PROGRESSCSD	; OMATPR <-- met un pixel	CALL	PROGRESS1	; progresse un p'tit peu ...	CALL	PROGRESSCCD	; OMATPR <-- enlve un pixel	ADD.W	D3,#16	CALL	PROGRESSCSD	; OMATPR <-- met un pixel	CALL	PROGRESS1	; progresse un p'tit peu ...	CALL	PROGRESSCCD	; OMATPR <-- enlve un pixel	ADD.W	D4,#16	CALL	PROGRESSCSD	; OMATPR <-- met un pixel	CALL	PROGRESS1	; progresse un p'tit peu ...	CALL	PROGRESSCCD	; OMATPR <-- enlve un pixel	SUB.W	D3,#16	CALL	PROGRESSCSD	; OMATPR <-- met un pixel	CALL	PROGRESS1	; progresse un p'tit peu ...	CALL	PROGRESSCCD	; OMATPR <-- enlve un pixel	DECJ.W,NMO D1,CLOOP$EXIT$:	POPM.L	D0..D6,A1..A4	RET;------------\\; PROGRESSCSD >;------------/; Met un point couleur dans la matrice transfert.; in	A2.L	^matrice 32x32;	D3.W	X (0..31);	D4.W	Y (0..31); out	-; mod	D7.WPROGRESSCSD:	PUSHM.L	D3,D4,A2	SL.W	D4,#4	ADD.W	A2,D4	SR.W	D3,#1	JUMP',CC RIGHT$	OR.B	(A2)+(D3.W),#B'11110000	JUMP'	EXIT$RIGHT$:	OR.B	(A2)+(D3.W),#B'00001111EXIT$:	POPM.L	D3,D4,A2	RET;------------\\; PROGRESSCCD >;------------/; Enlve un point couleur dans la matrice transfert.; in	A2.L	^matrice 32x32;	D3.W	X (0..31);	D4.W	Y (0..31); out	-; mod	D7.WPROGRESSCCD:	PUSHM.L	D3,D4,A2	SL.W	D4,#4	ADD.W	A2,D4	SR.W	D3,#1	JUMP',CC RIGHT$	AND.B	(A2)+(D3.W),#B'00001111	JUMP'	EXIT$RIGHT$:	AND.B	(A2)+(D3.W),#B'11110000EXIT$:	POPM.L	D3,D4,A2	RET; Cette table (gnre par GENH256.ASC) donne 256 valeurs alatoires,; toutes diffrentes.TPR256:	.L	H'034C7F21,H'598509BF,H'FEB9B36C,H'B80ED424	.L	H'1D5008FF,H'01D5C79D,H'35697871,H'262705FA	.L	H'CCCB7C34,H'D9F81CD6,H'DEE3CF5B,H'A3D2EFB7	.L	H'648FE094,H'1A9756E8,H'77B1F24D,H'46F4F598	.L	H'96425F55,H'5C5D1089,H'D714E27D,H'9A0CBC2B	.L	H'D10DC81E,H'88836BEA,H'A49012FD,H'99321682	.L	H'159EE91B,H'B2A2473A,H'0AACEE2E,H'7BED4E7A	.L	H'5EF3E7F1,H'BDA7E445,H'30E68165,H'3E2C9C48	.L	H'DC41C9DF,H'362D8C79,H'734F58A1,H'76510F49	.L	H'0B54FC28,H'A60453C3,H'1FC02922,H'ABBB2A18	.L	H'438D66C1,H'CAA0BAE1,H'F7E5CDAD,H'6E173CB0	.L	H'92D86325,H'D0B46D4A,H'7420AF3B,H'F9333707	.L	H'AAC4B557,H'066A8E8A,H'86615A23,H'6F753D11	.L	H'60007038,H'804052CE,H'4BF06784,H'95313991	.L	H'9BAEDD72,H'87A868D3,H'F6EC7EFB,H'44C59319	.L	H'A9622FC2,H'DABE1302,H'A53F8BDB,H'EB9FB6C6;----------\\; PROGRESSI >;----------/; Prpare les paramtres.; in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----; out	A3.L	^mmoire source;	D5.W	Iy source;	A4.L	^mmoire destination;	D6.W	Iy destination;	A2.L	^matrice de transfert (32x32); mod	D5.L, D6.L, D7.W, A2.L, A3.L, A4.LPROGRESSI:	PUSHM.L	D0,D1,D3,D4	CLR.W	D1	LOAD.B	D1,(A0)+ODFCNP	; D1 <-- nb de bits/pixel	LOAD.L	D0,A3		; source dans l'cran ?	JUMP',NE 10$		; non => 10$				; oui =>	LOAD.L	A3,(A0)+ODFABS	; A3 <-- adresse dbut cran	LOAD.W	D5,(A0)+ODFIIY	; D5 <-- Iy cran	ADD.W	D3,(A0)+ODFWBX	; D3 <-- dans (sous-)fentre en X	SWAP.W	D3	ADD.W	D3,(A0)+ODFWBY	; D3 <-- dans (sous-)fentre en Y	SWAP.W	D3	JUMP'	12$10$:	MUL.WU	D5,D1		; D5 <-- Iy bitmap12$:	LOAD.L	D0,D3	SWAP.W	D0	MUL.WU	D0,D5	ADD.L	A3,D0	LOAD.W	D0,D3	SR.W	D0,#3	MUL.WU	D0,D1	ADD.W	A3,D0		; A3 <-- ^byte source	LOAD.L	D0,A4		; destination dans l'cran ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A4,(A0)+ODFABS	; A4 <-- adresse dbut cran	LOAD.W	D6,(A0)+ODFIIY	; D6 <-- Iy cran	ADD.W	D4,(A0)+ODFWBX	; D4 <-- dans (sous-)fentre en X	SWAP.W	D4	ADD.W	D4,(A0)+ODFWBY	; D4 <-- dans (sous-)fentre en Y	SWAP.W	D4	JUMP'	22$20$:	MUL.WU	D6,D1		; D6 <-- Iy bitmap22$:	LOAD.L	D0,D4	SWAP.W	D0	MUL.WU	D0,D6	ADD.L	A4,D0	LOAD.W	D0,D4	SR.W	D0,#3	MUL.WU	D0,D1	ADD.W	A4,D0		; A4 <-- ^byte destination	LOAD.L	A2,#(A6)+OMATPR	LOAD.W	D0,#32-1	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE 40$30$:	CLR.L	(A2+)	DECJ.W,NMO D0,30$	JUMP'	80$40$:	CLR.L	(A2+)	CLR.L	(A2+)	CLR.L	(A2+)	CLR.L	(A2+)	DECJ.W,NMO D0,40$80$:	LOAD.L	A2,#(A6)+OMATPR	; A2 <-- ^matrice vide	POPM.L	D0,D1,D3,D4	RET;----------\\; PROGRESS1 >;----------/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais seulement les points allums dans la; matrice de transfert de 32x32 points.; in	A3.L	^mmoire source;	D5.W	Iy source;	A4.L	^mmoire destination;	D6.W	Iy destination;	D2.L	hauteur/largeur (y;x);	A2.L	^matrice de transfert (32x32); out	-; mod	D7.WPROGRESS1:	PUSHM.L	D0..D4,A1..A4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE COLOR$	LOAD.L	D0,D2	SR.W	D0,#5		; D0 <-- largeur /32 car par .L	DEC.W	D0		; D0 <-- largeur -1 car NMO	LOAD.L	A1,#(A2)+32*4	; A1 <-- ^fin matriceBLOOPY$:	COMP.L	A2,A1		; est-on  la fin de la matrice ?	JUMP',NE BMAT$		; non => BMAT$	LOAD.L	A2,#(A1)-32*4	; A2 <-- ^dbut de la matriceBMAT$:	LOAD.L	D2,(A2+)	; D2 <-- masque	JUMP',EQ BNEXTY$	LOAD.L	D1,D2	NOT.L	D1		; D1 <-- masque invers	PUSHM.L	D0,A3,A4BLOOPX$:	LOAD.L	D3,(A3+)	; D3 <-- source	AND.L	D3,D2	LOAD.L	D4,(A4)		; D4 <-- destination	AND.L	D4,D1	OR.L	D4,D3	LOAD.L	(A4+),D4	DECJ.W,NMO D0,BLOOPX$	POPM.L	D0,A3,A4BNEXTY$:	ADD.W	A3,D5		; A3 <-- ^ligne suivante	ADD.W	A4,D6		; A4 <-- ^ligne suivante	SWAP.W	D0	DEC.W	D0	LOAD.W	D1,D0	SWAP.W	D0	TEST.W	D1	JUMP,NE BLOOPY$	JUMP	EXIT$COLOR$:	LOAD.L	D0,D2	SR.W	D0,#5		; D0 <-- largeur /32 car par .L	DEC.W	D0		; D0 <-- largeur -1 car NMO	LOAD.L	A1,#(A2)+32*4*4	; A1 <-- ^fin matriceCLOOPY$:	COMP.L	A2,A1		; est-on  la fin de la matrice ?	JUMP',NE CMAT$		; non => CMAT$	LOAD.L	A2,#(A1)-32*4*4	; A2 <-- ^dbut de la matriceCMAT$:	PUSHM.L	A3,A4	LOAD.W	D7,#4-1CLOOPM$:	LOAD.L	D2,(A2+)	; D2 <-- masque	JUMP',EQ CNEXTM$	LOAD.L	D1,D2	NOT.L	D1		; D1 <-- masque invers	PUSHM.L	D0,D7,A3,A4	LOAD.W	D7,#4*4CLOOPX$:	LOAD.L	D3,(A3)		; D3 <-- source	AND.L	D3,D2	LOAD.L	D4,(A4)		; D4 <-- destination	AND.L	D4,D1	OR.L	D4,D3	LOAD.L	(A4),D4	ADD.W	A3,D7	ADD.W	A4,D7	DECJ.W,NMO D0,CLOOPX$	POPM.L	D0,D7,A3,A4CNEXTM$:	ADD.L	A3,#4	ADD.L	A4,#4	DECJ.W,NMO D7,CLOOPM$	POPM.L	A3,A4	ADD.W	A3,D5		; A3 <-- ^ligne suivante	ADD.W	A4,D6		; A4 <-- ^ligne suivante	SWAP.W	D0	DEC.W	D0	LOAD.W	D1,D0	SWAP.W	D0	TEST.W	D1	JUMP,NE CLOOPY$EXIT$:	POPM.L	D0..D4,A1..A4	RET;-----------\\; PROGRESSCO >;===========/; Progression avec un cran couleur !; in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x); out	-; mod	D7.WPROGRESSCO:	PUSHM.L	D1,D2	LOAD.L	D1,D2	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	POPM.L	D1,D2	RET;-----------\\; DRIMMEUBLE >;===========/; Dessine un immeuble opaque, avec des fentres.; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRIMMEUBLE:	PUSHM.L	D0..D6	PUSH.L	(A0)+ODFCSF	LOAD.W	D2,#SETDOT	LOAD.W	D5,#CLRDOT	CLR.L	D6	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',T	10$		; oui => 10$	LOAD.W	D2,#CLRDOT	LOAD.W	D5,#SETDOT	LOAD.L	D6,#-110$:;	LOAD.L	(A0)+ODFCSF,#COLOR_NOIR	CALL	DRRECT		; pourtour de l'immeuble	PUSHM.L	D3,D4	LOAD.L	D3,D6	LOAD.L	D4,D6	CALL	DRTRADEF	; trame pour effacer	POPM.L	D3,D4	LOAD.L	(A0)+ODFCSF,#COLOR_GRIS	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	EX.L	D2,D5	CALL	DRTRAME		; efface le fond	EX.L	D5,D2	POPM.L	D3,D4	CLR.L	D0	LOAD.W	D0,D4	DIV.WU	D0,#LIMMX	DEC.W	D0		; D0 <-- nombre de fentre horizontalement	JUMP,LE 90$	LOAD.L	D1,D4	CLR.W	D1	SWAP.W	D1	DIV.WU	D1,#LIMMY	DEC.W	D1		; D1 <-- nombre de fentre verticalement	JUMP,LE 90$	PUSHM.L	D3,D4	LOAD.L	D3,#-1	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE 20$		; oui => 20$	LOAD.L	D3,#H'11441144	XOR.L	D3,D620$:	LOAD.L	D4,D3	CALL	DRTRADEF	; trame pour les fentres	POPM.L	D3,D4	ADD.W	D3,#(LIMMX/2)+3	SWAP.W	D3	ADD.W	D3,#LIMMY/2	SWAP.W	D3	LOAD.L	D4,#H'10000*(LIMMY-6)+(LIMMX-3)30$:	PUSHM.L	D0,D332$:	LOAD.L	(A0)+ODFCSF,#COLOR_NOIR	CALL	DRRECT		; dessine une fentre	LOAD.L	(A0)+ODFCSF,#COLOR_GRISF	CALL	DRTRAME	ADD.W	D3,#LIMMX	DEC.W	D0	JUMP,NE 32$	POPM.L	D0,D3	SWAP.W	D3	ADD.W	D3,#LIMMY	SWAP.W	D3	DEC.W	D1	JUMP,NE 30$90$:	POP.L	(A0)+ODFCSF	POPM.L	D0..D6	RET;-----------\\; MOVEOISEAU >;===========/; Dplace un oiseau, naturellement !; in	A4.L	^objet "oiseau"; out	-; mod	D7.WMOVEOISEAU:	PUSHM.L	D3,D4	TEST.W	(A4)+OOIDIR+2	JUMP,EQ 90$	LOAD.W	D4,(A4)+OOIPTR	LOAD.B	D4,(A4)+(D4.W)+OOILST	LOAD.L	D3,(A4)+OOIPOS	CALL	DROISEAU	; efface l'ancien oiseau	LOAD.W	D4,(A4)+OOIPTR	INC.W	D4	COMP.W	D4,#4	JUMP',LO 20$	CLR.W	D420$:	LOAD.W	(A4)+OOIPTR,D4	LOAD.W	D3,#3	LOAD.W	D4,#10	CALL	MMHAZARD	TEST.W	(A4)+OOIDIR+2	JUMP',NC 30$	NEG.W	D430$:	ADD.W	(A4)+OOIPOS+2,D4	COMP.W	(A4)+OOIPOS+2,#240 ; tout prt de l'arbre ?	JUMP',HS 32$		; non => 32$	LOAD.W	(A4)+OOIDIR+2,#+1 ; va de droite  gauche32$:	TEST.W	(A4)+OOIDIR+2	; va de gauche  droite ?	JUMP',NS 34$		; non => 34$	COMP.W	(A4)+OOIPOS+2,#LXWDO ; dpasse  droite ?	JUMP',LO 34$		; non => 34$	CLR.W	(A4)+OOIDIR+2	JUMP	90$34$:	CLR.W	D3	LOAD.W	D4,#4	CALL	MMHAZARD	TEST.W	(A4)+OOIDIR+0	JUMP',NS 42$	LOAD.W	D3,(A4)+OOIPOS+0	ADD.W	D3,D4	COMP.W	D3,(A4)+OOILYI	JUMP',GT 44$	LOAD.W	(A4)+OOIPOS+0,D3	JUMP	60$42$:	LOAD.W	D3,(A4)+OOIPOS+0	SUB.W	D3,D4	COMP.W	D3,(A4)+OOILYS	JUMP',LT 44$	LOAD.W	(A4)+OOIPOS+0,D3	JUMP	60$44$:	NEG.W	(A4)+OOIDIR+0	CLR.W	D3	LOAD.W	D4,#(100/2)-5	CALL	MMHAZARD	LOAD.W	(A4)+OOILYS,D4	LOAD.W	D3,#(100/2)+5	LOAD.W	D4,#100	CALL	MMHAZARD	LOAD.W	(A4)+OOILYI,D460$:	LOAD.W	D4,(A4)+OOIPTR	LOAD.B	D4,(A4)+(D4.W)+OOILST	LOAD.L	D3,(A4)+OOIPOS	CALL	DROISEAU	; dessine le nouvel oiseau90$:	POPM.L	D3,D4	RET;---------\\; DROISEAU >;=========/; Dessine un oiseau.; in	D3.L	position (y;x);	D4.W	oiseau (0..7); out	-; mod	D7.WDROISEAU:	PUSHM.L	D1..D6,A3,A4	LOAD.L	D2,D3	LOAD.W	D3,#5		; D3 <-- icne de ITP83	LOAD.L	A4,(A6)+OPSICO	; A4 <-- ^gencar symboles	CALL	SRCPTGC		; A3/D3/D5/D1 <-- ^matrice/pos/Iy/dim	SR.W	D4,#1	JUMP',CC 20$	ADD.W	D3,#4020$:	SWAP.W	D3	MUL.WU	D4,#19	LOAD.W	D3,D4	SWAP.W	D3	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.L	D4,D2	LOAD.L	D1,#H'10000*19+40	LOAD.W	D2,#INVDOT!2^BDSTCOUL	CALL	DRRASTER	; dessine un oiseau	POPM.L	D1..D6,A3,A4	RET	.END