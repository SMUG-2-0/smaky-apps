	.SBTTL	TSLETTRE.ASILETTRE:	CALL	AFMENUJ		; affiche les soft-keys	LOAD.L	A2,#R16"LTMOT	CALL	CHEXLETTRE13	; OCHMAP <-- icnes existantes	CALL	CHNIV123	; choix d'un niveau 1,2,3 ...	JUMP,NE ERROR	COMP.W	D3,#'1	JUMP,LO LOOP	COMP.W	D3,#'3	JUMP,HI LOOP	SUB.W	D3,#'1		; D3 <-- 0..2	LOAD.W	(A6)+OLTNIV,D3	CALL	CCMO		; enlve la souris	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	LTCADRE		; dessine le cadre	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	CLR.W	D0		; D0 <-- rang de l'exercice (0..3)	CLR.W	D1		; D1 <-- nb de fautesNEXT$:	CALL	CCMO		; enlve la souris	LOAD.L	A4,#R16"TAMLETTRE0	COMP.W	D0,#0	JUMP',EQ GOTO$	LOAD.L	A4,#R16"TAMLETTRE1	COMP.W	D0,#1	JUMP',EQ GOTO$	LOAD.L	A4,#R16"TAMLETTRE2	COMP.W	D0,#2	JUMP',EQ GOTO$	LOAD.L	A4,#R16"TAMLETTRE3GOTO$:	CALL	ICOMALL		; va vers l'exercice ...	LOAD.L	A2,#R16"LTMOT	CALL	LTINIT		; choisit une carte	JUMP,NE ERROR	CALL	DRAWOPENCOPY	; continue de dessiner en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	CALL	LTPOSDIM	; D3/D4 <-- position/dimensions	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'exercice	CALL	LTSHOW		; montre la carte choisie	CALL	LTTEXT		; montre le mot	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A4,#R16"TAMLETTREM	CALL	ICOMALL		; toto montre ...	CALL	CLRFIFO		; vide le fifo du clavier;;?	CALL	SCMO		; remet la sourisLOOP$:	LOAD.W	D2,#SETDOT	CALL	LTHILIC		; allume la flche	LOAD.W	D4,#20	NTREL	?SETTIM	LIB	?GETCAR		; clavier/souris ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP',EQ KEY2$	LOAD.W	D2,#CLRDOT	CALL	LTHILIC		; teint la flche	LOAD.W	D4,#15	NTREL	?SETTIM	LIB	?GETCAR		; clavier/souris ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE LOOP$	JUMP'	KEY$KEY2$:	LOAD.W	D2,#CLRDOT	CALL	LTHILIC		; teint la flcheKEY$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#F0	JUMP,EQ RETOUR$	LIB	?MINMAJ	COMP.B	D3,#'A	JUMP',LO BIP$	COMP.B	D3,#'Z	JUMP',HI BIP$	LOAD.B	D4,D3	LOAD.L	A3,#(A6)+OLTMOT	LOAD.W	D3,(A6)+OLTLAT	LOAD.B	D3,(A3)+(D3.W)	LIB	?MINMAJ	COMP.B	D3,D4		; lettre trouve ?	JUMP',EQ FOUND$	CALL	CCMO		; enlve la souris	LOAD.L	A4,#R16"TAMLETTREF	CALL	ICOMALL		; rouspte ...	INC.W	D1		; D1 <-- une faute de plus	JUMP	LOOP$BIP$:	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	LOOP$FOUND$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	LOAD.W	(A6)+OLTLAT,#-1	CALL	LTTEXT		; montre le mot entier	CALL	LTKILL		; libre l'image de la carte	INC.W	D0	COMP.W	D0,#4	JUMP,LO NEXT$	CALL	CCMO		; enlve la souris	LOAD.L	A4,#R16"TAMLETTRE4	CALL	ICOMALL		; revient  la position de repos ...	TEST.W	D1		; y a-t-il eu des fautes ?	JUMP,NE LETTRE		; oui => LETTRE	TEST.B	(A6)+OFLAGS:#BFSON	JUMP,BC LETTRE	CLR.W	D3	LOAD.W	D4,#9	LOAD.L	A4,#(A6)+OHAMUS	CALL	EXHAZARD	; D4 <-- musique (0..8)	LOAD.W	(A6)+OTEST1,D4	LOAD.L	A4,#R16"TAMMUSIC	CALL	ICOMALL		; joue une p'tite musique ...	JUMP	LETTRERETOUR$:	CALL	LTKILL		; libre l'image de la carte	LOAD.L	A4,#R16"TAMCLOSE	CALL	ICOMALL		; enlve toto de l'cran ...	LOAD.L	A4,#R16"TAMOPEN	CALL	ICOMALL		; met toto sur l'cran ...	JUMP	LETTRE;--------\\; LTCADRE >;========/; Affiche le cadre.; in	-; out	-; mod	D7.WLTCADRE:	PUSHM.L	D0..D4,A3,A4	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	CALL	COLORHAZARD	; choix de couleurs alatoires	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame toute la fentre	LIB	?COLORPOP	LOAD.L	D3,#H'55AA55AA	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	CLR.W	D0	LOAD.W	D1,#B'0000011000011001LOOP$:	CALL	LTPOSDIM	; D3/D4 <-- position/dimensions	CALL	COLORHAZARD	; choix de couleurs alatoires	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	LIB	?COLORPOP	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	CALL	DESRECTM	; cadre	INC.W	D0	COMP.W	D0,#4	JUMP,LO LOOP$	POPM.L	D0..D4,A3,A4	RET;--------\\; LTSHOW  >;--------/; Affiche la carte du mmory choisie.; in	D0.W	exercice (0..3); out	-; mod	D7.WLTSHOW:	PUSHM.L	D2..D4,A3,A4	TEST.L	(A6)+OLTPIC	JUMP,EQ EXIT$	CALL	LTPOSDIM	; D3/D4 <-- position/dimensions	LOAD.W	D2,#60	SWAP.W	D2	LOAD.W	D2,D4	SUB.W	D2,(A6)+OLTDSI+2	ASR.W	D2,#1	ADD.W	D2,D3	CALL	LTRANG		; D4 <-- rang de l'image	JUMP',NE EXIT$	DIV.WU	D4,(A6)+OLTNSI+2	LOAD.W	D3,D4	MUL.WU	D3,(A6)+OLTDSI+0 ; D3 <-- position dans l'image en Y	INC.W	D3	SWAP.W	D3	SWAP.W	D4	MUL.WU	D4,(A6)+OLTDSI+2	LOAD.W	D3,D4		; D3 <-- position dans l'image en X	INC.W	D3	LOAD.L	D4,(A6)+OLTDSI	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	A4,(A6)+OLTPIC	; A4 <-- ^image code	LOAD.L	A3,(A6)+OLTPID	; A3 <-- ^image dcode	CALL	COLORFPH	; choix d'une couleur de fond pastelle	CALL	IMAGEAFF	; affiche une carte du mmory	LIB	?COLORPOPEXIT$:	POPM.L	D2..D4,A3,A4	RET;-------\\; LTRANG >;-------/; Calcule le rang de l'image.; in	-; out	D4.L	rang de l'image (2..n);	D7.W	erreur; mod	D4.L, D7.WLTRANG:	PUSH.L	D3	CLR.L	D4	LOAD.W	D4,(A6)+OLTRSI	SUB.W	D4,#2	LOAD.W	D3,(A6)+OLTNBG	DEC.W	D3	JUMP',EQ RANG$	DIV.WU	D4,D3	LOAD.L	D3,D4	SWAP.W	D3	MUL.WU	D4,(A6)+OLTNBG	ADD.W	D4,D3RANG$:	ADD.W	D4,#2	LOAD.W	D7,#ERTIMEX	LOAD.W	D3,(A6)+OLTNSI+2	MUL.WU	D3,(A6)+OLTNSI+0	COMP.W	D4,D3	JUMP',HS EXIT$	CLR.W	D7EXIT$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; LTTEXT  >;--------/; Affiche le mot de la carte choisie.; in	D0.W	exercice (0..3); out	-; mod	D7.WLTTEXT:	PUSHM.L	D1..D4,A3	CALL	LTPOSDIM	; D3/D4 <-- position/dimensions	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	LOAD.W	D3,#LYWDO-LYICO-10	SWAP.W	D3	LOAD.L	D1,D3	LIB	?AFTIM	.B	USEGC		; utilise les caractres NBP14	.B	GCTYF	.B	GCTYS	.B	GCTYT	.B	0	.EVEN	TEST.B	(A6)+OINV	; cran invers ?	JUMP',F INV$		; non => INV$	LOAD.B	D3,#AFINV	LIB	?AFCARINV$:	LOAD.L	A3,#(A6)+OLTMOT	CLR.W	D2CNT$:	LOAD.B	D3,(A3+)	JUMP',EQ POS$	LIB	?LGXCAR		; D4 <-- largeur d'un caractre	ADD.W	D2,D4		; D2 <-- largeur totale	JUMP	CNT$POS$:	LOAD.L	D3,D1	SR.W	D2,#1	SUB.W	D3,D2	LIB	?SETCURS	LOAD.L	A3,#(A6)+OLTMOT	LOAD.W	D1,#-1AFF$:	INC.W	D1	LOAD.B	D3,(A3+)	JUMP',EQ END$	COMP.W	D1,(A6)+OLTLAT	JUMP',NE CAR$	LIB	?LGXCAR		; D4 <-- largeur d'un caractre	AND.L	D4,#H'FFFF	LIB	?GETCURS	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRSEG	LIB	?SETCURS	SR.W	D4,#1	SUB.W	D3,D4	LOAD.L	(A6)+OLTPLT,D3	JUMP	AFF$CAR$:	CALL	AFFCAR	JUMP	AFF$END$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC		; utilise les caractres normaux	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	POPM.L	D1..D4,A3	RET;--------\\; LTHILIC >;========/; Mise en vidence de la lettre  trouver.; in	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WLTHILIC:	PUSHM.L	D2..D4	LIB	?AFTIM	.B	USEGC		; utilise les caractres NBP14	.B	GCTYF	.B	GCTYS	.B	GCTYT	.B	0	.EVEN	TEST.B	(A6)+OINV	; cran invers ?	JUMP',F INV$		; non => INV$	LOAD.B	D3,#AFINV	LIB	?AFCARINV$:	LOAD.B	D3,#H'0A	; D3 <-- flche contre en bas	LIB	?LGXCAR	SR.W	D4,#1		; D4 <-- demi-largeur flche	LOAD.L	D3,(A6)+OLTPLT	SUB.W	D3,D4	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,#H'0A	; D3 <-- flche contre en bas	COMP.W	D2,#SETDOT	JUMP',EQ CAR$	LOAD.B	D3,#SPACE	; D3 <-- rien du toutCAR$:	LIB	?AFCODE	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC		; utilise les caractres normaux	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	POPM.L	D2..D4	RET;---------\\; LTPOSDIM >;---------/; Donne la position et les dimensions d'un exercice.; in	D0.W	exercice (0..3); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WLTPOSDIM:	LOAD.L	D3,#(LXWDO-20)/4	MUL.WU	D3,D0	ADD.W	D3,#20	SWAP.W	D3	LOAD.W	D3,#20	SWAP.W	D3	LOAD.L	D4,#H'10000*(LYWDO-20-20)+(((LXWDO-20)/4)-20)	RET;--------\\; LTINIT  >;========/; Initialise une image pour une lettre.; in	A2.L	^routine LT*; out	D7.W	erreur; mod	D7.WLTINIT:	PUSHM.L	D2..D5,A3,A4	LOAD.W	D5,(A6)+OBKSNB	SL.W	D5,#1HAZARD$:	LOAD.W	D7,#ERTIMEX	DEC.W	D5	JUMP,NS EXIT$	CLR.W	D3	LOAD.W	D4,(A6)+OBKSNB	JUMP,EQ EXIT$	LOAD.L	A4,#(A6)+OHABKS	CALL	EXHAZARD	; D4 <-- image choisie	LOAD.W	D3,#-1SRC$:	CALL	BKSNEXT		; D3/A3/A4 <-- suivant	DEC.W	D4	JUMP,NC SRC$	CALL	(A2)		; CALL LT*	JUMP,NE HAZARD$	LOAD.W	(A6)+OLTRSI,D2	LOAD.L	(A6)+OLTNSI,(A4)+OBKNSI	LOAD.L	(A6)+OLTDSI,(A4)+OBKDSI	LOAD.L	D4,(A4)+OBKFAN	LOAD.W	D3,#3	TEST.L	D4:#BFAG3	JUMP',BS NBG$	DEC.W	D3	TEST.L	D4:#BFAG2	JUMP',BS NBG$	DEC.W	D3NBG$:	LOAD.W	(A6)+OLTNBG,D3	; OLTNBG <-- nb de cartes par groupe	LOAD.L	A4,(A4)+OBKPIC	LOAD.L	(A6)+OLTPIC,A4	; OLTPIC <-- ^image code	COMP.L	A4,#0	JUMP',EQ OK$	CALL	IMAGEDECO	; A3 <-- ^image dcode	JUMP',NE EXIT$	LOAD.L	(A6)+OLTPID,A3	; OLTPID <-- ^image dcodeOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; LTMOT   >;========/; Initialise un mot pour une lettre.; in	A3.L	^mot de la sous-image;	A4.L	^dans OBK*; out	D7.W	erreur; mod	D7.WLTMOT:	PUSHM.L	D0..D5,A2..A4	LOAD.L	D4,(A4)+OBKFAN	; D4 <-- fanions	TEST.L	D4:#BFALETTRE	JUMP,BC ERROR$	LOAD.L	A2,#(A6)+OLTMOT	CLR.W	D2MOT1$:	LOAD.B	D3,(A3+)	JUMP',EQ MOT3$	COMP.B	D3,#'|	JUMP',EQ MOT3$	COMP.B	D3,#CR	JUMP',EQ MOT3$	LOAD.B	(A2+),D3	; OLTMOT <-- mot de l'image	INC.W	D2	JUMP	MOT1$MOT3$:	CLR.B	(A2)	COMP.W	D2,#11		; mot de plus de 11 lettres ?	JUMP,HI ERROR$		; oui => ERROR$	TEST.W	(A6)+OLTNIV	; niveau zro ?	JUMP',NE NIV2$		; non => NIV2$	COMP.W	D2,#7		; mot de plus de 7 lettres ?	JUMP,HI ERROR$		; oui => ERROR$NIV2$:	COMP.W	(A6)+OLTNIV,#2	; niveau deux ?	JUMP',NE LETTRE$	; non => LETTRE$	COMP.W	D2,#6		; mot de moins de 6 lettres ?	JUMP,LO ERROR$		; oui => ERROR$LETTRE$:	CLR.W	D3	LOAD.W	D4,D2	LOAD.L	A4,#(A6)+OHALET	CALL	RZHAZARD	LOAD.W	D5,D2	SL.W	D5,#1HAZARD$:	DEC.W	D5	JUMP,NS ERROR$	CLR.W	D3	LOAD.W	D4,D2	LOAD.L	A4,#(A6)+OHALET	CALL	EXHAZARD	; D4 <-- rang lettre choisie	LOAD.L	A3,#(A6)+OLTMOT	CLR.B	D0	TEST.W	D4	JUMP',EQ LETP$	LOAD.B	D3,(A3)+(D4.W)-1 ; D3 <-- lettre prcdente	LIB	?MINMAJ	LOAD.B	D0,D3LETP$:	CLR.B	D1	LOAD.W	D3,D2	DEC.W	D3	COMP.W	D4,D3	JUMP',EQ LETS$	LOAD.B	D3,(A3)+(D4.W)+1 ; D3 <-- lettre suivante	LIB	?MINMAJ	LOAD.B	D1,D3LETS$:	LOAD.B	D3,(A3)+(D4.W)	; D3 <-- lettre choisie	LIB	?MINMAJ	TEST.W	(A6)+OLTNIV	JUMP,EQ LET0$	COMP.W	(A6)+OLTNIV,#1	JUMP',EQ LET1$	COMP.W	(A6)+OLTNIV,#2	JUMP,NE LETOK$LET2$:	CALL	IFVOYELLE	; faut-il trouver une voyelle ?	JUMP,NE LETOK$		; non => LETOK$	LOAD.B	D3,D0	CALL	IFVOYELLE	JUMP,EQ LETOK$	LOAD.B	D3,D1	CALL	IFVOYELLE	JUMP,EQ LETOK$	JUMP	HAZARD$LET1$:	COMP.B	D3,#'H		; ne permet certaines lettres difficiles !	JUMP,EQ LETTRE$	COMP.B	D3,#'J	JUMP,EQ LETTRE$	COMP.B	D3,#'K	JUMP,EQ LETTRE$	COMP.B	D3,#'Q	JUMP,EQ LETTRE$	COMP.B	D3,#'W	JUMP,EQ LETTRE$	COMP.B	D3,#'X	JUMP,EQ LETTRE$	COMP.B	D3,#'Y	JUMP,EQ LETTRE$	COMP.B	D3,#'Z	JUMP,EQ LETTRE$	COMP.B	D3,#'P	JUMP',EQ LET1XH$	COMP.B	D3,#'C	JUMP',NE LETOK$LET1XH$:	COMP.B	D1,#'H		; ne permet pas "ch" ou "ph" !	JUMP,EQ LETTRE$	JUMP'	LETOK$LET0$:	CALL	IFVOYELLE	; faut-il trouver une voyelle ?	JUMP,NE HAZARD$		; non => HAZARD$	LOAD.B	D3,D0	CALL	IFVOYELLE	JUMP,EQ HAZARD$	LOAD.B	D3,D1	CALL	IFVOYELLE	JUMP,EQ HAZARD$LETOK$:	LOAD.W	(A6)+OLTLAT,D4	; OLTLAT <-- rang lettre  trouver	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#ERTIMEXEXIT$:	POPM.L	D0..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; LTKILL  >;========/; Termine une lettre.; in	-; out	-; mod	D7.WLTKILL:	PUSHM.L	A3,A4	TEST.L	(A6)+OLTPIC	JUMP',EQ EXIT$	LOAD.L	A4,(A6)+OLTPIC	; A4 <-- ^image code	LOAD.L	A3,(A6)+OLTPID	; A3 <-- ^image dcode	CALL	IMAGECODE	; libre l'image dcodeEXIT$:	POPM.L	A3,A4	RET	.END