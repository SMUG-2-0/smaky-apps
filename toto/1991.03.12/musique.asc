	.TITLE	MUSIQUE.ASC	.PROC	M680002	.REF	SMAKY	.LOC	0ADCODE:START:	LOAD.L	A3,#R16"TMUSLOOP:	LIB	?AFTIM	.ASCIZ	"*"	.EVEN	LIB	?GETCAR	COMP.W	D3,#END	JUMP,EQ FINI	LOAD.W	D3,(A3+)	JUMP,EQ START	CALL	PATATRA	JUMP	LOOPFINI:	EXITTMUS:	.W	TMUSGLOUGLOU	.W	0	.W	TMUSASCENSEUR	.W	TMUSPAS	.W	TMUSGICLE	.W	TMUSTOMBE	.W	TMUSMAGIC	.W	TMUSCOULE	.W	TMUSMECONTANT	.W	0	.W	TMUSCOLB0	.W	TMUSCOLR0	.W	TMUSENDB0	.W	TMUSCOLB1	.W	TMUSCOLR1	.W	TMUSENDB1	.W	TMUSCOLB2	.W	TMUSCOLR2	.W	TMUSENDB2	.W	TMUSCOLB3	.W	TMUSCOLR3	.W	TMUSENDB3	.W	TMUSCOLB4	.W	TMUSCOLR4	.W	TMUSENDB4	.W	TMUSCOLB5	.W	TMUSCOLR5	.W	TMUSENDB5	.W	TMUSCOLB6	.W	TMUSCOLR6	.W	TMUSENDB6	.W	TMUSENDRAQ	.W	TMUSLANAV	.W	TMUSLANPR	.W	TMUSYOUPIE	.W	TMUSPERDU	.W	0; Gestion des bruits; ------------------;--------\\; PATATRA >;========/; Fait un bruit rigolo !; in	D3.W	#TMUSxxx; out	-; mod	D7.WPATATRA:	PUSH.L	A4	LOAD.L	A4,#R16"ADCODE	ADD.W	A4,D3	TEST.W	(A4)	JUMP,EQ 90$	LIB	?PLAY90$:	POP.L	A4	RETTMUSGLOUGLOU:	.W	PERIODE+800,SILENCE,SILENCE,H'100*1+1	.W	PERIODE+750,SILENCE,SILENCE,H'100*1+1	.W	PERIODE+700,SILENCE,SILENCE,H'100*1+1	.W	PERIODE+650,SILENCE,SILENCE,H'100*1+1	.W	PERIODE+600,SILENCE,SILENCE,H'100*1+1	.W	PERIODE+550,SILENCE,SILENCE,H'100*1+1	.W	PERIODE+500,SILENCE,SILENCE,H'100*1+1	.W	SILENCE,SILENCE,SILENCE,H'100*1+10	.W	0TMUSNAVIRE:	.W	NOTE+OCTAVE*4+SGMI,SILENCE,SILENCE,H'100*40+10	.W	NOTE+OCTAVE*4+SGMI,SILENCE,SILENCE,H'100*40+10	.W	NOTE+OCTAVE*4+SGMI,SILENCE,SILENCE,H'100*40+10	.W	NOTE+OCTAVE*3+SGSOL,SILENCE,SILENCE,H'100*40+20	.W	NOTE+OCTAVE*4+SGMI,SILENCE,SILENCE,H'100*40+20	.W	NOTE+OCTAVE*4+SGFA,SILENCE,SILENCE,H'100*40+10	.W	NOTE+OCTAVE*4+SGMI,SILENCE,SILENCE,H'100*40+10	.W	NOTE+OCTAVE*4+SGMI,SILENCE,SILENCE,H'100*40+20	.W	NOTE+OCTAVE*4+SGRE,SILENCE,SILENCE,H'100*20+10	.W	NOTE+OCTAVE*4+SGRE,SILENCE,SILENCE,H'100*40+10	.W	NOTE+OCTAVE*4+SGRE,SILENCE,SILENCE,H'100*40+10	.W	NOTE+OCTAVE*4+SGRE,SILENCE,SILENCE