	.SBTTL	TSPENDU.ASIPENDU:	CALL	AFMENUJ		; affiche les soft-keys	LOAD.L	A2,#R16"PDMOT	CALL	CHEXLETTRE13	; OCHMAP <-- icnes existantes	CALL	CHNIV123	; choix d'un niveau 1,2,3 ...	JUMP,NE ERROR	COMP.W	D3,#'1	JUMP,LO LOOP	COMP.W	D3,#'3	JUMP,HI LOOP	SUB.W	D3,#'1		; D3 <-- 0..2	LOAD.W	(A6)+OLTNIV,D3	CALL	CCMO		; enlve la souris	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	PDCADRE		; dessine le cadre	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	LOAD.L	A4,#R16"TAMPENDUI	CALL	ICOMALL		; initialisation ...	CLR.W	(A6)+OCCNBF	; zro faute	CLR.W	D1PARTIE$:	LOAD.L	A2,#R16"PDMOT	CALL	LTINIT		; choisit une carte	JUMP,NE ERROR	CALL	CCMO		; enlve la souris	CALL	DRAWOPENCOPY	; continue de dessiner en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	PDCLEAR		; efface l'exercice prcdent	CALL	PDTEXT		; dessine le texte	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A4,#R16"TAMPENDUM	CALL	ICOMALL		; montre ...	CLR.W	D0		; D0 <-- nb de parties perduesSHOW$:	CALL	PDSHOW		; dessine la carteLOOP$:;;?	CALL	SCMO		; remet la souris	CALL	CLRFIFO		; vide le fifo du clavier	LIB	?GETCAR		; attend clavier/souris ...	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#F0	JUMP,EQ ABORT$	LIB	?MINMAJ	COMP.B	D3,#'-	JUMP',EQ LETTRE$	COMP.B	D3,#'A	JUMP',LO BIP$	COMP.B	D3,#'Z	JUMP',LS LETTRE$BIP$:	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	LOOP$LETTRE$:	CALL	CCMO		; enlve la souris	CALL	PDLETTRE	; lettre trouve ?	JUMP,NE FAUX$	CALL	PDTEXT		; affiche la lettre trouve	CALL	PDTERM		; tout trouv ?	JUMP',EQ GAGNE$		; oui => GAGNE$	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	JUMP	LOOP$GAGNE$:	LOAD.W	(A6)+OSOUND,#TMUSGAGNE	PUSH.W	D0GSHOW$:	COMP.W	D0,#9	JUMP',HS GEND$	CALL	PDSHOW		; dessine la carte	INC.W	D0	JUMP	GSHOW$GEND$:	POP.W	D0	LOAD.W	(A6)+OTEST1,D1	LOAD.L	A4,#R16"TAMPENDUG1	CALL	ICOMALL		; va chercher un cadeau ...	LOAD.W	(A6)+OTEST2,#1	COMP.W	D0,#3	JUMP',HS GEXC$	CLR.W	D3	LOAD.W	D4,#10	LOAD.L	A4,#(A6)+OHAEXC	CALL	EXHAZARD	; D4 <-- action exceptionnelle	LOAD.W	(A6)+OTEST2,D4GEXC$:	LOAD.L	A5,#(A6)+OOBJ1	LOAD.L	A4,#R16"TAMPENDUG2	CALL	ICOMBEGIN	LOAD.L	A5,#(A6)+OOBJ2	LOAD.L	A4,#R16"TAMPENDUG320	COMP.W	D0,#3	JUMP',LO GTAIL$	LOAD.L	A4,#R16"TAMPENDUG321	COMP.W	D0,#6	JUMP',LO GTAIL$	LOAD.L	A4,#R16"TAMPENDUG322GTAIL$:	CALL	ICOMBEGINGCAD$:	LOAD.L	A5,#(A6)+OOBJ2	CALL	ICOMNEXT	; dplace le cadeau	LOAD.L	A5,#(A6)+OOBJ1	CALL	ICOMNEXT	; dplace toto	JUMP,EQ GCAD$	LOAD.L	A5,#(A6)+OOBJ2	LOAD.L	A2,(A5)+OOCHIM	CALL	ICOMCLOSE	; termine le cadeau, sans l'enlever	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	ICOMREMET	; remet toto sur l'cran ...	LOAD.L	A4,#R16"TAMPENDUG4	CALL	ICOMALL		; revient vers les lettres ...	JUMP	END$FAUX$:	INC.W	(A6)+OCCNBF	; une faute de plus	INC.W	D0		; D0 <-- perd une partie de plus	COMP.W	D0,#9	JUMP',HS PERDU$	LOAD.L	A4,#R16"TAMPENDU1	COMP.W	D0,#1	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU2	COMP.W	D0,#2	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU3	COMP.W	D0,#3	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU4	COMP.W	D0,#4	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU5	COMP.W	D0,#5	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU6	COMP.W	D0,#6	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU7	COMP.W	D0,#7	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU8FMOVE$:	CALL	ICOMALL		; perd qq chose ...	JUMP	SHOW$PERDU$:	LOAD.L	A4,#R16"TAMPENDU9	CALL	ICOMALL		; perd la dernire partie ...	CALL	PDSOLUTION	; montre la solution	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	ICOMREMET	; remet toto sur l'cran ...	LOAD.L	A4,#R16"TAMPENDUP	CALL	ICOMALL		; perdu ...;	JUMP'	END$END$:	CALL	LTKILL		; libre l'image de la carte	INC.W	D1	COMP.W	D1,#4	JUMP,LO PARTIE$	CALL	CCMO		; enlve la souris	CLR.L	D4	LOAD.W	D4,(A6)+OCCNBF	DIV.WU	D4,#5	COMP.W	D4,#4	JUMP',LS SAUTE$	LOAD.W	D4,#4SAUTE$:	CALL	ICOMGAGNE	; saute ...	JUMP'	ABORT2$ABORT$:	CALL	LTKILL		; libre l'image de la carteABORT2$:	CALL	CCMO		; enlve la souris	LOAD.L	A4,#R16"TAMPENDUR	CALL	ICOMALL		; revient  la position de repos ...	JUMP	PENDU;-----------\\; PDSOLUTION >;===========/; Montre la solution.; in	-; out	-; mod	D7.WPDSOLUTION:	PUSHM.L	D4,A3,A4NEXT$:	LOAD.L	A3,#(A6)+OLTMOT	LOAD.L	A4,#(A6)+OLTTRMLOOP$:	TEST.B	(A3)	JUMP',EQ EXIT$	COMP.B	(A3+),(A4+)	JUMP,EQ LOOP$	LOAD.W	(A6)+OSOUND,#TMUSTAC	LOAD.B	(-A4),(-A3)	CALL	PDTEXT		; affiche une lettre	LOAD.W	D4,#50	NTREL	?DELMS	JUMP	NEXT$EXIT$:	POPM.L	D4,A3,A4	RET;---------\\; PDLETTRE >;=========/; Regarde si une lettre est trouve.; in	D3.B	lettre; out	D7.W	erreur; mod	D7.WPDLETTRE:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#(A6)+OLTMOT	LOAD.L	A4,#(A6)+OLTTRM	LOAD.B	D4,D3	LOAD.W	D7,#1LOOP$:	LOAD.B	D3,(A3+)	JUMP',EQ EXIT$	COMP.B	D3,(A4+)	; lettre dj trouve ?	JUMP,EQ LOOP$		; oui => LOOP$	PUSH.W	D7	LIB	?MINMAJ	POP.W	D7	COMP.B	D3,D4	JUMP,NE LOOP$	LOAD.B	(A4)-1,(A3)-1	CLR.W	D7		; D7 <-- ok	JUMP	LOOP$EXIT$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; PDTERM >;=======/; Regarde si toutes les lettres sont trouves.; in	-; out	D7.W	erreur; mod	D7.WPDTERM:	PUSHM.L	A3,A4	LOAD.L	A3,#(A6)+OLTMOT	LOAD.L	A4,#(A6)+OLTTRM	CLR.W	D7		; D7 <-- okLOOP$:	TEST.B	(A3)	JUMP',EQ EXIT$	COMP.B	(A3+),(A4+)	JUMP,EQ LOOP$	LOAD.W	D7,#1EXIT$:	POPM.L	A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PDCADRE >;========/; Affiche le cadre.; in	-; out	-; mod	D7.WPDCADRE:	PUSHM.L	D0..D4,A3,A4	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	CALL	COLORHAZARD	; choix de couleurs alatoires	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame toute la fentre	LIB	?COLORPOP	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	LOAD.L	D3,#H'10000*40+40	LOAD.L	D4,#H'10000*(LYWDO-40-40)+(LXWDO-40-40)	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D1,#B'0000011000011001	CALL	DESRECTM	; cadre	POPM.L	D0..D4,A3,A4	RET;--------\\; PDCLEAR >;========/; Efface l'exercice prcdent.; in	-; out	-; mod	D7.WPDCLEAR:	PUSHM.L	D2..D4,A3	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	LOAD.L	D3,#H'10000*40+40	LOAD.L	D4,#H'10000*(LYWDO-40-LYICO)+(LXWDO-40-40)	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface	LOAD.L	A3,#R16"TEXT$	LOAD.L	D4,#H'10000*160+80	CALL	AFFBOX	POPM.L	D2..D4,A3	RETTEXT$:	.ASCII	"Devine<CR>"	.ASCII	"le mot ..."	.B	0	.EVEN;--------\\; PDSHOW  >;--------/; Affiche la carte du mmory choisie.; in	D0.W	rang (0..n); out	-; mod	D7.WPDSHOW:	PUSHM.L	D0..D6,A2..A4	TEST.W	(A6)+OLTPIC	JUMP,EQ EXIT$	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE COLOR$		; oui => COLOR$	DEC.W	D0	JUMP,NS EXIT$	COMP.W	D0,#8	JUMP,HS EXIT$	CALL	LTRANG		; D4 <-- rang de l'image	JUMP,NE EXIT$	LOAD.L	D2,D4	LOAD.W	D4,(A6)+OLTDSI+2	ADD.W	D4,#32-1	AND.B	D4,#B'11100000	SR.W	D4,#3	LOAD.W	D3,(A6)+OLTDSI+0	ADD.W	D3,#32-1	AND.B	D3,#B'11100000	MUL.WU	D4,D3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^bitmap temporaire	SR.L	D4,#2		; D4 <-- /4 car .L	DEC.W	D4		; D4 <-- -1 car NMO	CLR.L	D3	TEST.B	(A6)+OINV	JUMP',F CLR$	NOT.L	D3CLR$:	LOAD.L	(A4+),D3	; bitmap temporaire <-- rempli de zro/un	DECJ.W,NMO D4,CLR$	LOAD.L	A3,(A6)+OLTPID	; A3 <-- ^image dcode (source)	LOAD.L	D4,D2	DIV.WU	D4,(A6)+OLTNSI+2	LOAD.W	D3,D4	MUL.WU	D3,(A6)+OLTDSI+0 ; D3 <-- position dans l'image en Y	INC.W	D3	SWAP.W	D3	SWAP.W	D4	MUL.WU	D4,(A6)+OLTDSI+2	LOAD.W	D3,D4		; D3 <-- position dans l'image en X	INC.W	D3	LOAD.L	A4,(A6)+OLTPIC	; A4 <-- ^image code	LOAD.W	D5,(A4)+OIMDLX	SR.W	D5,#3		; D5 <-- "ii" image	LOAD.L	A4,A2		; A4 <-- ^destination	CLR.L	D4	LOAD.W	D6,(A6)+OLTDSI+2	ADD.W	D6,#32-1	AND.B	D6,#B'11100000	SR.W	D6,#3	LOAD.L	D1,(A6)+OLTDSI	DEC.W	D1	SWAP.W	D1	DEC.W	D1	SWAP.W	D1		; D1 <-- dimensions	LOAD.W	D2,#SETDOT	CALL	INVMODE	CALL	DRRASTER	; bitmap temporaire <-- carte choisie	LOAD.L	A3,A4	LOAD.L	D3,D4	LOAD.W	D5,D6	LOAD.L	A4,#0		; A4 <-- cran (destination)	LOAD.W	D4,#60	SWAP.W	D4	LOAD.W	D4,#LXWDO	SUB.W	D4,(A6)+OLTDSI+2	ASR.W	D4,#1		; D4 <-- position dans l'cran	ADD.W	D4,#16-1	AND.B	D4,#B'11110000	LOAD.L	D2,D1	ADD.W	D2,#32-1	AND.B	D2,#B'11100000	SWAP.W	D2	ADD.W	D2,#32-1	AND.B	D2,#B'11100000	SWAP.W	D2	LOAD.W	D1,D0	CALL	PROGRESSAX	; affiche un peu plus	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le bitmap temporaire	JUMP'	EXIT$COLOR$:	COMP.W	D0,#8	JUMP',NE EXIT$	LOAD.W	D2,#60	SWAP.W	D2	LOAD.W	D2,#LXWDO	SUB.W	D2,(A6)+OLTDSI+2	ASR.W	D2,#1		; D2 <-- position dans l'cran	ADD.W	D2,#16-1	AND.B	D2,#B'11110000	CALL	LTRANG		; D4 <-- rang de l'image	JUMP,NE EXIT$	DIV.WU	D4,(A6)+OLTNSI+2	LOAD.W	D3,D4	MUL.WU	D3,(A6)+OLTDSI+0 ; D3 <-- position dans l'image en Y	INC.W	D3	SWAP.W	D3	SWAP.W	D4	MUL.WU	D4,(A6)+OLTDSI+2	LOAD.W	D3,D4		; D3 <-- position dans l'image en X	INC.W	D3	LOAD.L	D4,(A6)+OLTDSI	LOAD.L	A4,(A6)+OLTPIC	; A4 <-- ^image code	LOAD.L	A3,(A6)+OLTPID	; A3 <-- ^image dcode	CALL	COLORFPH	; choix d'une couleur de fond pastelle	CALL	IMAGEAFF	; affiche une carte du mmory	LIB	?COLORPOPEXIT$:	POPM.L	D0..D6,A2..A4	RET;--------\\; PDTEXT  >;========/; Affiche le texte correspondant  la carte choisie.; in	-; out	-; mod	D7.WPDTEXT:	PUSHM.L	D0..D4,A3,A4	LIB	?AFTIM	.B	USEGC		; utilise les caractres NBP14	.B	GCTYF	.B	GCTYS	.B	GCTYT	.B	0	.EVEN	TEST.B	(A6)+OINV	; cran invers ?	JUMP',F INV$		; non => INV$	LOAD.B	D3,#AFINV	LIB	?AFCARINV$:	LOAD.L	A3,#(A6)+OLTMOT	LOAD.W	D4,#-1CNT$:	INC.W	D4		; D4 <-- nb de caractres	TEST.B	(A3+)	JUMP,NE CNT$	LOAD.W	D3,(A0)+ODFCX	ADD.W	D3,#8	MUL.WU	D4,D3		; D4 <-- largeur ncessaire	LOAD.W	D0,#LYWDO-LYICO-20	SUB.W	D0,(A0)+ODFC1Y	SWAP.W	D0	LOAD.W	D0,#LXWDO	SUB.W	D0,D4	SR.W	D0,#1		; D0 <-- position pour rectangle	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	LOAD.L	A3,#(A6)+OLTMOT	LOAD.L	A4,#(A6)+OLTTRMLOOP$:	LOAD.L	D3,D0	SUB.W	D3,#2	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#4	SWAP.W	D4	LOAD.W	D4,(A0)+ODFCX	ADD.W	D4,#2	LOAD.B	D2,(A3)	COMP.B	D2,(A4)	JUMP',EQ COLOR$	CLR.B	D2COLOR$:	CALL	PMCOLOR		; met une couleur  l'intrieur	LOAD.W	D2,#SETDOT	CALL	INVMODE	LOAD.W	D1,#2	LIB	?DRRECTO	COMP.B	(A3+),(A4+)	; lettre trouve ?	JUMP',NE NEXT$		; non => NEXT$	LOAD.B	D3,(A3)-1	LIB	?LGXCAR	SUB.W	D4,(A0)+ODFCX	NEG.W	D4	ASR.W	D4,#1	LOAD.L	D3,D0	ADD.W	D3,D4	SWAP.W	D3	ADD.W	D3,#3	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,(A3)-1	CALL	AFFCAR		; affiche le caractreNEXT$:	LIB	?COLORPOP	ADD.W	D0,(A0)+ODFCX	ADD.W	D0,#8		; D0 <-- position suivante	TEST.B	(A3)	JUMP,NE LOOP$	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC		; utilise les caractres normaux	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	POPM.L	D0..D4,A3,A4	RET;--------\\; PDMOT   >;========/; Initialise un mot pour le pendu.; in	A3.L	^mot de la sous-image;	A4.L	^dans OBK*; out	D7.W	erreur; mod	D7.WPDMOT:	PUSHM.L	D2..D4,A1..A4	LOAD.L	D4,(A4)+OBKFAN	; D4 <-- fanions	TEST.L	D4:#BFAPENDU	JUMP,BC ERROR$	LOAD.L	A2,#(A6)+OLTMOT	LOAD.L	A1,#(A6)+OLTTRM	CLR.W	D2MOT1$:	LOAD.B	D3,(A3+)	JUMP',EQ MOT3$	COMP.B	D3,#'|	JUMP',EQ MOT3$	COMP.B	D3,#CR	JUMP',EQ MOT3$	LOAD.B	(A2+),D3	; OLTMOT <-- mot de l'image	CLR.B	(A1+)		; OLTTRM <-- mot trouv	INC.W	D2	JUMP	MOT1$MOT3$:	CLR.B	(A2)	CLR.B	(A1)	TEST.W	(A6)+OLTNIV	JUMP',EQ NIV0$	COMP.W	(A6)+OLTNIV,#1	JUMP',EQ NIV1$NIV2$:	COMP.W	D2,#8	JUMP',LO ERROR$	JUMP'	NIVOK$NIV1$:	COMP.W	D2,#8	JUMP',HS ERROR$	COMP.W	D2,#4	JUMP',LS ERROR$	JUMP'	NIVOK$NIV0$:	COMP.W	D2,#4	JUMP',HI ERROR$	COMP.W	D2,#1	JUMP',LS ERROR$;	JUMP'	NIVOK$NIVOK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#ERTIMEXEXIT$:	POPM.L	D2..D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.END