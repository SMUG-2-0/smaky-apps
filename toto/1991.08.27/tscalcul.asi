	.SBTTL	TSCALCUL.ASICCDICX	=	130		; largeur d'une carteCCDICY	=	150		; hauteur d'une carteCALCUL:	CALL	AFMENUJ		; affiche les soft-keys	CALL	CCMO		; enlve la souris	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	LOAD.L	A4,#R16"TOMENU$	LOAD.W	(A6)+OCHMAP,#B'101111111	CALL	CHDRAW		; dessine les choix	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	CALL	CLRFIFO		; vide le fifo du clavier	CALL	SCMO		; remet la sourisOMENU$:	LOAD.L	A4,#R16"TOMENU$	CALL	CHMENU		; choix selon menu ...	LOAD.W	D4,#'+	COMP.W	D3,#'1	JUMP',EQ OGO$	LOAD.W	D4,#'-	COMP.W	D3,#'2	JUMP',EQ OGO$	LOAD.W	D4,#'&	COMP.W	D3,#'3	JUMP',EQ OGO$	LOAD.W	D4,#'*	COMP.W	D3,#'4	JUMP',EQ OGO$	LOAD.W	D4,#'/	COMP.W	D3,#'5	JUMP',EQ OGO$	LOAD.W	D4,#'%	COMP.W	D3,#'6	JUMP',EQ OGO$	LOAD.W	D4,#'?	COMP.W	D3,#'7	JUMP',EQ OGO$	COMP.W	D3,#'9	JUMP,EQ LOOP	COMP.W	D3,#F0	JUMP,EQ LOOP	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	OMENU$TOMENU$:	.W	ICOADD	.W	ICOSUB	.W	ICOADDSUB	.W	ICOMUL	.W	ICODIV	.W	ICOMULDIV	.W	ICOMEL	.W	0	.W	ICOANNULEOGO$:	LOAD.W	(A6)+OCCOP,D4NIVEAU$:	CALL	CCMO		; enlve la souris	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	LOAD.L	A4,#R16"TNMENU$	LOAD.W	(A6)+OCHMAP,#B'100111111	CALL	CHDRAW		; dessine les choix	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	CALL	CLRFIFO		; vide le fifo du clavier	CALL	SCMO		; remet la sourisNMENU$:	LOAD.L	A4,#R16"TNMENU$	CALL	CHMENU		; choix selon menu ...	CLR.B	(A6)+OCCMEL	CLR.W	D4	COMP.W	D3,#'1	JUMP',EQ NGO$	INC.W	D4	COMP.W	D3,#'2	JUMP',EQ NGO$	INC.W	D4	COMP.W	D3,#'3	JUMP',EQ NGO$	INC.B	(A6)+OCCMEL	CLR.W	D4	COMP.W	D3,#'4	JUMP',EQ NGO$	INC.W	D4	COMP.W	D3,#'5	JUMP',EQ NGO$	INC.W	D4	COMP.W	D3,#'6	JUMP',EQ NGO$	COMP.W	D3,#'9	JUMP,EQ CALCUL	COMP.W	D3,#F0	JUMP,EQ CALCUL	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	NMENU$TNMENU$:	.W	ICONIV2	.W	ICONIV4	.W	ICONIV6	.W	ICOINIV2	.W	ICOINIV4	.W	ICOINIV6	.W	0	.W	0	.W	ICOANNULENGO$:	LOAD.W	(A6)+OCCNIV,D4	CALL	CCMO		; enlve la souris	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	CCCADRE		; dessine le cadre	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	LOAD.L	A4,#R16"TAMPENDUJ	CALL	ICOMALL		; initialisation ...	SET.B	(A6)+OCCRST	; questions restent  l'cran	COMP.W	(A6)+OCCNIV,#2	JUMP',EQ RST$	COMP.W	(A6)+OCCNIV,#5	JUMP',EQ RST$	COMP.W	(A6)+OCCOP,#'*	JUMP',EQ RST$	COMP.W	(A6)+OCCOP,#'/	JUMP',EQ RST$	COMP.W	(A6)+OCCOP,#'%	JUMP',EQ RST$	COMP.W	(A6)+OCCOP,#'?	JUMP',EQ RST$	CLR.B	(A6)+OCCRST	; questions ne restent pas  l'cranRST$:	CLR.W	(A6)+OCCNBF	; zro faute	CLR.W	D1	LOAD.W	(A6)+OCCPOY,#LYWDO-LYICO-20	TEST.B	(A6)+OCCRST	; questions restent  l'cran ?	JUMP',F PARTIE$	LOAD.W	(A6)+OCCPOY,#LYWDO-LYICO-20-(3*47)PARTIE$:	CALL	CCMO		; enlve la souris	CALL	DRAWOPENCOPY	; continue de dessiner en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	CCCLEAR		; efface l'exercice prcdent	CALL	CCQUESTION	; dessine une question	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A4,#R16"TAMPENDUM	CALL	ICOMALL		; montre ...	CLR.W	D0		; D0 <-- nb de rponses faussesLOOP$:;;?	CALL	SCMO		; remet la souris	CALL	CLRFIFO		; vide le fifo du clavierLOOP2$:	LOAD.W	D2,#SETDOT	CALL	CCHILIC		; allume la flche	LOAD.W	D4,#20	NTREL	?SETTIM	LIB	?GETCAR		; clavier/souris ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP',EQ KEY2$	LOAD.W	D2,#CLRDOT	CALL	CCHILIC		; teint la flche	LOAD.W	D4,#15	NTREL	?SETTIM	LIB	?GETCAR		; clavier/souris ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE LOOP2$	JUMP'	KEY$KEY2$:	LOAD.W	D2,#CLRDOT	CALL	CCHILIC		; teint la flcheKEY$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#F0	JUMP,EQ ABORT$	COMP.W	D3,#DEL	JUMP',EQ ANNULE$	COMP.W	D3,#BS	JUMP',EQ ANNULE$	COMP.W	D3,#DELETE	JUMP',EQ ANNULE$	COMP.W	D3,#CLEAR	JUMP',EQ ANNULE$	LIB	?MINMAJ	COMP.B	D3,#'0	JUMP',LO BIP$	COMP.B	D3,#'9	JUMP',LS CHIFFRE$BIP$:	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	LOOP$ANNULE$:	CALL	CCANNULE	; annule la rponse actuelle	JUMP	LOOP$CHIFFRE$:	CALL	CCMO		; enlve la souris	CALL	CCCHIFFRE	; chiffre trouv ?	JUMP,NE FAUX$	CALL	CCTERM		; tout trouv ?	JUMP',EQ GAGNE$		; oui => GAGNE$	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	JUMP	LOOP$GAGNE$:	LOAD.W	(A6)+OSOUND,#TMUSGAGNE	CALL	CCCARTEREP	; montre la carte rponse	LOAD.W	(A6)+OTEST1,D1	LOAD.L	A4,#R16"TAMPENDUG1	CALL	ICOMALL		; va chercher un cadeau ...	LOAD.W	(A6)+OTEST2,#1	COMP.W	D0,#1	JUMP',HS GEXC$	CLR.W	D3	LOAD.W	D4,#10	LOAD.L	A4,#(A6)+OHAEXC	CALL	EXHAZARD	; D4 <-- action exceptionnelle	LOAD.W	(A6)+OTEST2,D4GEXC$:	LOAD.L	A5,#(A6)+OOBJ1	LOAD.L	A4,#R16"TAMPENDUG2	CALL	ICOMBEGIN	LOAD.L	A5,#(A6)+OOBJ2	LOAD.L	A4,#R16"TAMPENDUG310	COMP.W	D0,#1	JUMP',LO GTAIL$	LOAD.L	A4,#R16"TAMPENDUG311	COMP.W	D0,#2	JUMP',LO GTAIL$	LOAD.L	A4,#R16"TAMPENDUG312GTAIL$:	CALL	ICOMBEGINGCAD$:	LOAD.L	A5,#(A6)+OOBJ2	CALL	ICOMNEXT	; dplace le cadeau	LOAD.L	A5,#(A6)+OOBJ1	CALL	ICOMNEXT	; dplace toto	JUMP,EQ GCAD$	LOAD.L	A5,#(A6)+OOBJ2	LOAD.L	A2,(A5)+OOCHIM	CALL	ICOMCLOSE	; termine le cadeau, sans l'enlever	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	ICOMREMET	; remet toto sur l'cran ...	LOAD.L	A4,#R16"TAMPENDUG4	CALL	ICOMALL		; revient vers les lettres ...	JUMP	END$FAUX$:	INC.W	(A6)+OCCNBF	; une faute de plus	INC.W	D0		; D0 <-- une rponse fausse de plus	COMP.W	D0,#3	JUMP',HS PERDU$	LOAD.L	A4,#R16"TAMLETTREF	CALL	ICOMALL		; rouspte ...	JUMP	ANNULE$PERDU$:	LOAD.W	(A6)+OSOUND,#TMUSPERDU	LOAD.L	A4,#R16"TAMLETTREF	CALL	ICOMALL		; rouspte ...	CALL	CCCARTEREP	; montre la carte rponse	CALL	CCSOLUTION	; montre la solution;	JUMP'	END$END$:	TEST.B	(A6)+OCCRST	; questions restent  l'cran ?	JUMP',F ENDR$	ADD.W	(A6)+OCCPOY,#47ENDR$:	INC.W	D1	COMP.W	D1,#4	JUMP,LO PARTIE$	CALL	CCMO		; enlve la souris	LOAD.W	D4,(A6)+OCCNBF	COMP.W	D4,#4	JUMP',LS SAUTE$	LOAD.W	D4,#4SAUTE$:	CALL	ICOMGAGNE	; saute ...ABORT$:	CALL	CCMO		; enlve la souris	LOAD.L	A4,#R16"TAMPENDUR	CALL	ICOMALL		; revient  la position de repos ...	JUMP	NIVEAU$;-----------\\; CCCARTEREP >;===========/; Affiche la carte rponse.; in	-; out	-; mod	D7.WCCCARTEREP:	PUSHM.L	D3,D4	LOAD.W	D4,(A6)+OCCNBX	LOAD.W	D3,(A6)+OCCRGQ	CALL	CCSHOW		; affiche la carte rponse	POPM.L	D3,D4	RET;-----------\\; CCSOLUTION >;===========/; Affiche la solution.; in	-; out	-; mod	D7.WCCSOLUTION:	PUSHM.L	D3,D4	CALL	CCANNULE	; efface la rponse fausse	LOAD.W	D3,(A6)+OCCRGQ	LOAD.W	D4,(A6)+OCCNBX	CALL	CCAFNUM		; affiche la rponse	LOAD.W	D4,#50*4	NTREL	?DELMS	POPM.L	D3,D4	RET;----------\\; CCCHIFFRE >;==========/; Donne un chiffre.; in	D3.B	chiffre; out	D7.W	erreur; mod	D7.WCCCHIFFRE:	PUSHM.L	D2..D4,A3,A4	AND.W	D3,#H'FF	SUB.B	D3,#'0		; D3 <-- 0..9	LOAD.W	D4,(A6)+OCCRUS	MUL.WU	D4,#10	ADD.W	D4,D3		; D4 <-- rponse suppose	LOAD.W	(A6)+OCCRUS,D4	LOAD.W	D3,(A6)+OCCRGQ	CALL	CCAFNUM		; affiche la rponse suppose	LOAD.L	A4,#(A6)+OBUDIS+0	CLR.L	D4	LOAD.W	D4,(A6)+OCCNBX	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDCM	LIB	?PUTDEC		; OBUDIS+0 <-- rponse	LOAD.L	A4,#(A6)+OBUDIS+10;	CLR.L	D4	LOAD.W	D4,(A6)+OCCRUS;	LOAD.W	D3,#5;	LOAD.W	D2,#2^BAFDCM	LIB	?PUTDEC		; OBUDIS+10 <-- utilisateur	LOAD.L	A3,#(A6)+OBUDIS+0	LOAD.L	A4,#(A6)+OBUDIS+10	CLR.W	D7COMP$:	TEST.B	(A4)	JUMP',EQ EXIT$	COMP.B	(A3+),(A4+)	JUMP,EQ COMP$	LOAD.W	D7,#1EXIT$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CCTERM  >;========/; Regarde si la rponse est trouve.; in	-; out	D7.W	erreur; mod	D7.WCCTERM:	PUSH.W	D3	CLR.W	D7	LOAD.W	D3,(A6)+OCCNBX	COMP.W	D3,(A6)+OCCRUS	JUMP',EQ EXIT$	LOAD.W	D7,#1EXIT$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; CCANNULE >;=========/; Annule une rponse fausse.; in	-; out	-; mod	D7.WCCANNULE:	PUSHM.L	D2..D4	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	LOAD.W	D3,(A6)+OCCRGQ	CALL	CCPOS		; D3 <-- position en X	SUB.W	D3,#LXICO/2	SWAP.W	D3	LOAD.W	D3,(A6)+OCCPOY	SUB.W	D3,#20	SWAP.W	D3	LOAD.L	D4,#H'10000*30+LXICO	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface la rponse fausse	LOAD.B	D4,#'_	LOAD.W	D3,(A6)+OCCRGQ	CALL	CCAFCAR		; affiche un "_"	CLR.W	(A6)+OCCRUS	POPM.L	D2..D4	RET;--------\\; CCCADRE >;========/; Affiche le cadre.; in	-; out	-; mod	D7.WCCCADRE:	PUSHM.L	D1..D4	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	CALL	COLORHAZARD	; choix de couleurs alatoires	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame toute la fentre	LIB	?COLORPOP	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	LOAD.L	D3,#H'10000*40+40	LOAD.L	D4,#H'10000*(LYWDO-40-40)+(LXWDO-40-40)	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D1,#B'0000011000011001	CALL	DESRECTM	; cadre	POPM.L	D1..D4	RET;-----------\\; CCQUESTION >;===========/; Affiche une question complte.; in	-; out	-; mod	D7.WCCQUESTION:	PUSHM.L	D0..D4,A4	CALL	CCCLEAR		; efface la question prcdente	CLR.W	D3	LOAD.W	D4,#(ICOOBJ3-ICOOBJ1+1)*4	LOAD.L	A4,#(A6)+OHACOB	CALL	EXHAZARD	LOAD.W	(A6)+OCCOBJ,D4	; OCCOBJ <-- objet  utiliser	LOAD.W	D3,(A6)+OCCOP	CLR.W	D2	LOAD.W	D4,#2	COMP.W	D3,#'&	JUMP',EQ OPH$	LOAD.W	D2,#2	LOAD.W	D4,#4	COMP.W	D3,#'%	JUMP',EQ OPH$	CLR.W	D2;	LOAD.W	D4,#4	COMP.W	D3,#'?	JUMP',NE OPC$OPH$:	LOAD.W	D3,D2	LOAD.L	A4,#(A6)+OHACOP	CALL	EXHAZARD	LOAD.W	D3,#'+	DEC.W	D4	JUMP',NS OPC$	LOAD.W	D3,#'-	DEC.W	D4	JUMP',NS OPC$	LOAD.W	D3,#'*	DEC.W	D4	JUMP',NS OPC$	LOAD.W	D3,#'/OPC$:	LOAD.W	(A6)+OCCOPC,D3	; OCCOPC <-- opration choisie	LOAD.W	D4,#4		; D4 <-- rang de la rponse, aprs "="	TEST.B	(A6)+OCCMEL	JUMP',EQ RGQ$	CLR.W	D3	LOAD.W	D4,#2	CALL	MMHAZARD	; D4 <-- rang au hazard	SL.W	D4,#1		; D4 <-- 0,2RGQ$:	LOAD.W	(A6)+OCCRGQ,D4	; OCCRGQ <-- rang question choisi	LOAD.W	D2,(A6)+OCCNIV	; D2 <-- niveau (0..2)	COMP.W	(A6)+OCCOPC,#'*	JUMP',EQ MULDIV$	COMP.W	(A6)+OCCOPC,#'/	JUMP',EQ MULDIV$	CLR.W	D0	LOAD.W	D1,#5+1	DEC.W	D2	JUMP',NS HAZARD$	LOAD.W	D0,#3	LOAD.W	D1,#10+1	DEC.W	D2	JUMP',NS HAZARD$	LOAD.W	D0,#10	LOAD.W	D1,#100+1	DEC.W	D2	JUMP'	HAZARD$MULDIV$:	LOAD.W	D0,#1	LOAD.W	D1,#5+1	DEC.W	D2	JUMP',NS HAZARD$	LOAD.W	D0,#3	LOAD.W	D1,#10+1	DEC.W	D2	JUMP',NS HAZARD$	LOAD.W	D0,#5	LOAD.W	D1,#15+1	DEC.W	D2;	JUMP'	HAZARD$HAZARD$:	LOAD.W	D3,D0	LOAD.W	D4,D1	LOAD.L	A4,#(A6)+OHACNB	CALL	EXHAZARD	LOAD.W	(A6)+OCCNB1,D4	; OCCNB1 <-- premier nombre	LOAD.W	D3,D0	LOAD.W	D4,D1	CALL	EXHAZARD	LOAD.W	(A6)+OCCNB2,D4	; OCCNB2 <-- deuxime nombre	LOAD.W	D3,(A6)+OCCOPC	; D3 <-- opration choisie	COMP.W	D3,#'/	JUMP',EQ DIV$	COMP.W	D3,#'*	JUMP',EQ MUL$	COMP.W	D3,#'-	JUMP',EQ SUB$ADD$:	LOAD.W	D4,(A6)+OCCNB1	ADD.W	D4,(A6)+OCCNB2	LOAD.W	(A6)+OCCNB3,D4	; OCCNB3 <-- rponse	JUMP'	SHOW$SUB$:	LOAD.W	D3,(A6)+OCCNB1	LOAD.W	D4,(A6)+OCCNB2	LOAD.W	(A6)+OCCNB3,D3	; OCCNB3 <-- rponse	ADD.W	D3,D4	LOAD.W	(A6)+OCCNB1,D3	JUMP'	SHOW$MUL$:	LOAD.W	D4,(A6)+OCCNB1	MUL.WU	D4,(A6)+OCCNB2	LOAD.W	(A6)+OCCNB3,D4	; OCCNB3 <-- rponse	JUMP'	SHOW$DIV$:	LOAD.W	D3,(A6)+OCCNB1	LOAD.W	D4,(A6)+OCCNB2	LOAD.W	(A6)+OCCNB3,D3	; OCCNB3 <-- rponse	MUL.WU	D3,D4	LOAD.W	(A6)+OCCNB1,D3;	JUMP'	SHOW$SHOW$:	CLR.W	(A6)+OCCRUS	TEST.W	(A6)+OCCRGQ	JUMP',EQ SHOW1Q$	LOAD.W	D4,(A6)+OCCNB1	CLR.W	D3	CALL	CCSHOW		; affiche la premire carte	CALL	CCAFNUM		; affiche le premier nombre	JUMP'	SHOW2$SHOW1Q$:	CLR.W	D3	LOAD.B	D4,#'_	CALL	CCAFCAR		; affiche le "_"	LOAD.W	(A6)+OCCNBX,(A6)+OCCNB1SHOW2$:	COMP.W	(A6)+OCCRGQ,#2	JUMP',EQ SHOW2Q$	LOAD.W	D4,(A6)+OCCNB2	LOAD.W	D3,#2	CALL	CCSHOW		; affiche la deuxime carte	CALL	CCAFNUM		; affiche le deuxime nombre	JUMP'	SHOW3$SHOW2Q$:	LOAD.W	D3,#2	LOAD.B	D4,#'_	CALL	CCAFCAR		; affiche le "_"	LOAD.W	(A6)+OCCNBX,(A6)+OCCNB2SHOW3$:	COMP.W	(A6)+OCCRGQ,#4	JUMP',EQ SHOW3Q$	LOAD.W	D4,(A6)+OCCNB3	LOAD.W	D3,#4	CALL	CCSHOW		; affiche la troisime carte	CALL	CCAFNUM		; affiche le troisime nombre	JUMP'	SHOW4$SHOW3Q$:	LOAD.W	D3,#4	LOAD.B	D4,#'_	CALL	CCAFCAR		; affiche le "_"	LOAD.W	(A6)+OCCNBX,(A6)+OCCNB3SHOW4$:	LOAD.W	D3,#1	LOAD.W	D4,(A6)+OCCOPC	CALL	CCAFCAR		; affiche l'opration	LOAD.W	D3,#3	LOAD.B	D4,#'=	CALL	CCAFCAR		; affiche le "="	POPM.L	D0..D4,A4	RET;--------\\; CCCLEAR >;========/; Efface l'exercice prcdent.; in	-; out	-; mod	D7.WCCCLEAR:	PUSHM.L	D2..D4	TEST.B	(A6)+OCCRST	; questions restent  l'cran ?	JUMP',T	EXIT$		; oui => EXIT$	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	LOAD.L	D3,#H'10000*40+40	LOAD.L	D4,#H'10000*(LYWDO-40-LYICO)+(LXWDO-40-40)	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; effaceEXIT$:	POPM.L	D2..D4	RET;--------\\; CCAFNUM >;========/; Affiche un nombre sous une carte.; in	D4.W	nombre  afficher;	D3.W	position (0..4); out	-; mod	D7.WCCAFNUM:	PUSHM.L	D0..D4	LIB	?AFTIM	.B	USEGC		; utilise les caractres NBP14	.B	GCTYF	.B	GCTYS	.B	GCTYT	.B	0	.EVEN	TEST.B	(A6)+OINV	; cran invers ?	JUMP',F INV$		; non => INV$	LIB	?AFTIM	.B	AFINV,0	.EVENINV$:	LOAD.W	D0,D4	CALL	CCPOS		; D3 <-- position en X	LOAD.W	D1,D3	LOAD.W	D2,#1		; D2 <-- nb de digits	COMP.W	D0,#10	JUMP',LO CURS$	INC.W	D2	COMP.W	D0,#100	JUMP',LO CURS$	INC.W	D2	COMP.W	D0,#1000	JUMP',LO CURS$	INC.W	D2	COMP.W	D0,#10000	JUMP',LO CURS$	INC.W	D2CURS$:	LOAD.B	D3,#'0	LIB	?LGXCAR		; D4 <-- largeur du "0"	MUL.WU	D4,D2		; D4 <-- largeur totale	SR.W	D4,#1		; D4 <-- demi-largeur totale	LOAD.W	D3,(A6)+OCCPOY	SWAP.W	D3	LOAD.W	D3,D1	SUB.W	D3,D4	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,D0	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le nombre	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC		; utilise les caractres normaux	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	POPM.L	D0..D4	RET;--------\\; CCAFCAR >;========/; Affiche un caractre sous une carte.; in	D4.B	caractre  afficher;	D3.W	position (0..4); out	-; mod	D7.WCCAFCAR:	PUSHM.L	D1..D4	LIB	?AFTIM	.B	USEGC		; utilise les caractres NBP14	.B	GCTYF	.B	GCTYS	.B	GCTYT	.B	0	.EVEN	TEST.B	(A6)+OINV	; cran invers ?	JUMP',F INV$		; non => INV$	LIB	?AFTIM	.B	AFINV,0	.EVENINV$:	LOAD.B	D1,D4	CALL	CCPOS		; D3 <-- position en X	LOAD.W	D2,D3	LOAD.B	D3,D1	LIB	?LGXCAR		; D4 <-- largeur du caractre	SR.W	D4,#1		; D4 <-- demi-largeur du caractre	LOAD.W	D3,(A6)+OCCPOY	SWAP.W	D3	LOAD.W	D3,D2	SUB.W	D3,D4	LIB	?SETCURS	LOAD.B	D3,D1	LIB	?AFCODE		; affiche le caractre	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC		; utilise les caractres normaux	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	POPM.L	D1..D4	RET;--------\\; CCSHOW  >;--------/; Affiche la carte d'un nombre.; in	D4.W	nombre reprsent (0..n);	D3.W	position (0..4); out	-; mod	D7.WCCSHOW:	PUSHM.L	D0..D4,A4	TEST.B	(A6)+OCCRST	; questions restent  l'cran ?	JUMP,T	EXIT$		; oui => EXIT$	LOAD.W	D0,D4	LOAD.W	D1,D3	CALL	CCPOS		; D3 <-- position en X	SWAP.W	D3	LOAD.W	D3,#60	SWAP.W	D3	SUB.W	D3,#CCDICX/2	; D3 <-- position	LOAD.L	D4,#H'10000*CCDICY+CCDICX	PUSHM.L	D3,D4	CLR.W	D3	LOAD.W	D4,#4	CALL	MMHAZARD	SL.W	D4,#2	LOAD.L	A4,#R16"TRAMES$	LOAD.L	D3,(A4)+(D4.W)	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF		; trame grise au hazard	POPM.L	D3,D4	CALL	COLORHAZARD	; choix de couleurs alatoires	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRTRAME	; trame l'intrieur	LIB	?COLORPOP	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF		; trame noire pour l'ombre	POPM.L	D3,D4	PUSHM.L	D1,D3,D4	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRRECT		; dessine le pourtour	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LOAD.W	D1,#2	LIB	?DRRECTO	POPM.L	D1,D3,D4	COMP.W	D1,#2	JUMP',NE SRCI$	COMP.W	(A6)+OCCOPC,#'*	JUMP',EQ NUM$	COMP.W	(A6)+OCCOPC,#'/	JUMP',EQ NUM$SRCI$:	LOAD.L	A4,#R16"TABLE$SRC$:	COMP.W	(A4),#-1	; fin de la table ?	JUMP',EQ NUM$		; oui => NUM$	COMP.W	D0,(A4)	JUMP',EQ FOUND$NEXT$:	COMP.W	(A4+),#-1	JUMP,NE NEXT$	JUMP	SRC$FOUND$:	ADD.L	A4,#2	ADD.W	D3,#(CCDICX-((LXICO/2)*3))/2	SWAP.W	D3	ADD.W	D3,#(CCDICY-((LYICO/2)*3))/2	SWAP.W	D3ICON$:	COMP.W	(A4),#-1	JUMP,EQ EXIT$	LOAD.L	D4,D3	SWAP.W	D4	ADD.W	D4,(A4+)	SWAP.W	D4	ADD.W	D4,(A4+)	CALL	CCSHOWICON	; dessine une icne	JUMP	ICON$NUM$:	LIB	?AFTIM	.B	USEGC		; utilise les caractres NBP14	.B	GCTYF	.B	GCTYS	.B	GCTYT	.B	MODCAR,SETDOT!PENDOT	.B	0	.EVEN	TEST.B	(A6)+OINV	; cran invers ?	JUMP',F INV$		; non => INV$	LIB	?AFTIM	.B	MODCAR,CLRDOT!PENDOT	.B	0	.EVENINV$:	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LOAD.L	D1,D3	LOAD.W	D2,#1		; D2 <-- nb de digits	COMP.W	D0,#10	JUMP',LO CURS$	INC.W	D2	COMP.W	D0,#100	JUMP',LO CURS$	INC.W	D2	COMP.W	D0,#1000	JUMP',LO CURS$	INC.W	D2	COMP.W	D0,#10000	JUMP',LO CURS$	INC.W	D2CURS$:	LOAD.B	D3,#'0	LIB	?LGXCAR		; D4 <-- largeur du "0"	MUL.WU	D4,D2		; D4 <-- largeur totale	SR.W	D4,#1		; D4 <-- demi-largeur totale	LOAD.L	D3,D1	SUB.W	D3,D4	SWAP.W	D3	LOAD.W	D4,(A0)+ODFC1Y	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	D1,D3	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,D0	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le nombre	INC.W	D1	LOAD.L	D3,D1	LIB	?SETCURS	LOAD.W	D3,#5	LIB	?AFDEC	INC.W	D1	LOAD.L	D3,D1	LIB	?SETCURS	LOAD.W	D3,#5	LIB	?AFDEC	LIB	?AFTIM	.B	USEGC		; utilise les caractres normaux	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	MODCAR,SETDOT	.B	0	.EVENEXIT$:	POPM.L	D0..D4,A4	RETTRAMES$:	.L	H'01001000	.L	H'11004400	.L	H'11441144	.L	H'55AA55AATABLE$:	.W	0	.W	-1	.W	1	.W	40,40	.W	-1	.W	2	.W	20,30	.W	60,50	.W	-1	.W	3	.W	10,20	.W	30,60	.W	70,40	.W	-1	.W	4	.W	20,10	.W	10,60	.W	70,20	.W	60,70	.W	-1	.W	5	.W	10,0	.W	0,70	.W	40,40	.W	80,10	.W	70,80	.W	-1	.W	6	.W	0,0	.W	10,80	.W	30,30	.W	60,50	.W	70,0	.W	80,80	.W	-1	.W	7	.W	10,0	.W	0,40	.W	20,70	.W	40,40	.W	60,0	.W	80,50	.W	70,80	.W	-1	.W	8	.W	10,0	.W	0,40	.W	0,80	.W	50,20	.W	40,60	.W	80,0	.W	80,40	.W	70,80	.W	-1	.W	9	.W	0,0	.W	0,80	.W	10,50	.W	30,10	.W	40,40	.W	50,80	.W	70,0	.W	80,40	.W	80,80	.W	-1	.W	10	.W	0,0	.W	0,30	.W	0,80	.W	20,60	.W	40,40	.W	50,10	.W	50,80	.W	80,0	.W	80,40	.W	80,80	.W	-1	.W	-1;-----------\\; CCSHOWICON >;-----------/; Dessine l'icne d'un objet.; in	D4.L	position (y;x); out	-; mod	D7.WCCSHOWICON:	PUSHM.L	D1..D6,A3,A4	LOAD.W	D3,(A6)+OCCOBJ	SR.W	D3,#2	ADD.W	D3,#ICOOBJ1	CALL	COLORICO	; choix des couleurs pour l'icne	LOAD.L	A4,(A6)+OPFICO	; A4 <-- ^gencar fond	CALL	ICOGETPT	; A3/D3/D5/D1 <-- ^matrice/pos/Iy/dim	CLR.L	D3	TEST.B	(A6)+OCCOBJ+1:#0	JUMP',BC POSX$	LOAD.W	D3,#LXICO/2POSX$:	TEST.B	(A6)+OCCOBJ+1:#1	JUMP',BC POSY$	SWAP.W	D3	LOAD.W	D3,#LYICO/2	SWAP.W	D3POSY$:	LOAD.L	A4,#0	LOAD.L	D1,#H'10000*(LYICO/2)+(LXICO/2)	LOAD.W	D2,#CLRDOT!2^BDSTCOUL	CALL	INVMODE	CALL	DRRASTER	; efface le fond	LOAD.L	D2,D3	LOAD.W	D3,(A6)+OCCOBJ	SR.W	D3,#2	ADD.W	D3,#ICOOBJ1	LOAD.L	A4,(A6)+OPGICO	; A4 <-- ^gencar chair	CALL	ICOGETPT	; A3/D3/D5/D1 <-- ^matrice/pos/Iy/dim	LOAD.L	D3,D2	LOAD.L	A4,#0	LOAD.L	D1,#H'10000*(LYICO/2)+(LXICO/2)	LOAD.W	D2,#SETDOT!2^BDSTCOUL	CALL	INVMODE	CALL	DRRASTER	; dessine la chair	LIB	?COLORPOP	POPM.L	D1..D6,A3,A4	RET;--------\\; CCHILIC >;========/; Mise en vidence du chiffre  trouver.; in	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WCCHILIC:	PUSHM.L	D2..D4	LIB	?AFTIM	.B	USEGC		; utilise les caractres NBP14	.B	GCTYF	.B	GCTYS	.B	GCTYT	.B	0	.EVEN	TEST.B	(A6)+OINV	; cran invers ?	JUMP',F INV$		; non => INV$	LOAD.B	D3,#AFINV	LIB	?AFCARINV$:	LOAD.B	D3,#H'0A	; D3 <-- flche contre en bas	LIB	?LGXCAR	SR.W	D4,#1		; D4 <-- demi-largeur flche	LOAD.W	D3,(A6)+OCCRGQ	CALL	CCPOS		; D3 <-- position en X	SUB.W	D3,D4	SWAP.W	D3	LOAD.W	D3,(A6)+OCCPOY	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#4	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,#H'0A	; D3 <-- flche contre en bas	COMP.W	D2,#SETDOT	JUMP',EQ CAR$	LOAD.B	D3,#SPACE	; D3 <-- rien du toutCAR$:	LIB	?AFCODE	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC		; utilise les caractres normaux	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	POPM.L	D2..D4	RET;--------\\; CCPOS   >;--------/; Cherche la position horizontale d'une carte.; in	D3.W	position (0..4); out	D3.W	position cran (x); mod	D3.L, D7.WCCPOS:	TEST.B	(A6)+OCCRST	; questions restent  l'cran ?	JUMP',T RST$	INC.W	D3	MUL.WU	D3,#(LXWDO-80-80)/6	ADD.W	D3,#80	JUMP'	EXIT$RST$:	INC.W	D3	MUL.WU	D3,#(LXWDO-150-150)/6	ADD.W	D3,#150;	JUMP'	EXIT$EXIT$:	RET	.END