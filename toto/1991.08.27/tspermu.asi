	.SBTTL	TSPERMU.ASIPERMU:	CALL	AFMENUJ		; affiche les soft-keys	LOAD.L	A2,#R16"PMMOT	CALL	CHEXLETTRE13	; OCHMAP <-- icnes existantes	CALL	CHNIV123	; choix d'un niveau 1,2,3 ...	JUMP,NE ERROR	COMP.W	D3,#'1	JUMP,LO LOOP	COMP.W	D3,#'3	JUMP,HI LOOP	SUB.W	D3,#'1		; D3 <-- 0..2	LOAD.W	(A6)+OLTNIV,D3	CALL	CCMO		; enlve la souris	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	PDCADRE		; dessine le cadre	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	LOAD.L	A4,#R16"TAMPENDUI	CALL	ICOMALL		; initialisation ...	CLR.W	(A6)+OCCNBF	; zro faute	CLR.W	D1PARTIE$:	LOAD.L	A2,#R16"PMMOT	CALL	LTINIT		; choisit une carte	JUMP,NE ERROR	CALL	CCMO		; enlve la souris	CALL	DRAWOPENCOPY	; continue de dessiner en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	PMCLEAR		; efface l'exercice prcdent	CALL	PMMELANGE	; dessine les lettres mlanges	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A4,#R16"TAMPENDUM	CALL	ICOMALL		; montre ...	CLR.W	D0		; D0 <-- nb de parties perdues	CALL	PMTEXT		; dessine les lettres trouvesLOOP$:;;?	CALL	SCMO		; remet la souris	CALL	CLRFIFO		; vide le fifo du clavierLOOP2$:	LOAD.W	D2,#SETDOT	CALL	LTHILIC		; allume la flche	LOAD.W	D4,#20	NTREL	?SETTIM	LIB	?GETCAR		; clavier/souris ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP',EQ KEY2$	LOAD.W	D2,#CLRDOT	CALL	LTHILIC		; teint la flche	LOAD.W	D4,#15	NTREL	?SETTIM	LIB	?GETCAR		; clavier/souris ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE LOOP2$	JUMP'	KEY$KEY2$:	LOAD.W	D2,#CLRDOT	CALL	LTHILIC		; teint la flcheKEY$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP2$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP2$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP2$	COMP.W	D3,#F0	JUMP,EQ ABORT$	LIB	?MINMAJ	COMP.B	D3,#'-	JUMP',EQ LETTRE$	COMP.B	D3,#'A	JUMP',LO BIP$	COMP.B	D3,#'Z	JUMP',LS LETTRE$BIP$:	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	LOOP2$LETTRE$:	CALL	CCMO		; enlve la souris	CALL	PMLETTRE	; lettre trouve ?	JUMP,NE FAUX$	CALL	PMTEXT		; affiche la lettre trouve	CALL	PMTERM		; tout trouv ?	JUMP',EQ GAGNE$		; oui => GAGNE$	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	JUMP	LOOP$GAGNE$:	LOAD.W	(A6)+OSOUND,#TMUSGAGNE	CALL	PMIFSYN		; mot trouv exact ?	JUMP',NE GSHOW$		; non => GSHOW$	CALL	PMSHOW		; dessine la carteGSHOW$:	LOAD.W	(A6)+OTEST1,D1	LOAD.L	A4,#R16"TAMPENDUG1	CALL	ICOMALL		; va chercher un cadeau ...	LOAD.W	(A6)+OTEST2,#1	COMP.W	D0,#3	JUMP',HS GEXC$	CLR.W	D3	LOAD.W	D4,#10	LOAD.L	A4,#(A6)+OHAEXC	CALL	EXHAZARD	; D4 <-- action exceptionnelle	LOAD.W	(A6)+OTEST2,D4GEXC$:	LOAD.L	A5,#(A6)+OOBJ1	LOAD.L	A4,#R16"TAMPENDUG2	CALL	ICOMBEGIN	LOAD.L	A5,#(A6)+OOBJ2	LOAD.L	A4,#R16"TAMPENDUG330	COMP.W	D0,#3	JUMP',LO GTAIL$	LOAD.L	A4,#R16"TAMPENDUG331	COMP.W	D0,#6	JUMP',LO GTAIL$	LOAD.L	A4,#R16"TAMPENDUG332GTAIL$:	CALL	ICOMBEGINGCAD$:	LOAD.L	A5,#(A6)+OOBJ2	CALL	ICOMNEXT	; dplace le cadeau	LOAD.L	A5,#(A6)+OOBJ1	CALL	ICOMNEXT	; dplace toto	JUMP,EQ GCAD$	LOAD.L	A5,#(A6)+OOBJ2	LOAD.L	A2,(A5)+OOCHIM	CALL	ICOMCLOSE	; termine le cadeau, sans l'enlever	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	ICOMREMET	; remet toto sur l'cran ...	LOAD.L	A4,#R16"TAMPENDUG4	CALL	ICOMALL		; revient vers les lettres ...	JUMP	END$FAUX$:	INC.W	(A6)+OCCNBF	; une faute de plus	INC.W	D0		; D0 <-- perd une partie de plus	COMP.W	D0,#9	JUMP',HS PERDU$	LOAD.L	A4,#R16"TAMPENDU1	COMP.W	D0,#1	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU2	COMP.W	D0,#2	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU3	COMP.W	D0,#3	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU4	COMP.W	D0,#4	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU5	COMP.W	D0,#5	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU6	COMP.W	D0,#6	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU7	COMP.W	D0,#7	JUMP',EQ FMOVE$	LOAD.L	A4,#R16"TAMPENDU8FMOVE$:	CALL	ICOMALL		; perd qq chose ...	JUMP	LOOP$PERDU$:	LOAD.L	A4,#R16"TAMPENDU9	CALL	ICOMALL		; perd la dernire partie ...	CALL	PDSOLUTION	; montre la solution	CALL	PMSHOW		; dessine la carte	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	ICOMREMET	; remet toto sur l'cran ...	LOAD.L	A4,#R16"TAMPENDUP	CALL	ICOMALL		; perdu ...;	JUMP'	END$END$:	CALL	LTKILL		; libre l'image de la carte	INC.W	D1	COMP.W	D1,#4	JUMP,LO PARTIE$	CALL	CCMO		; enlve la souris	CLR.L	D4	LOAD.W	D4,(A6)+OCCNBF	DIV.WU	D4,#5	COMP.W	D4,#4	JUMP',LS SAUTE$	LOAD.W	D4,#4SAUTE$:	CALL	ICOMGAGNE	; saute ...	JUMP'	ABORT2$ABORT$:	CALL	LTKILL		; libre l'image de la carteABORT2$:	CALL	CCMO		; enlve la souris	LOAD.L	A4,#R16"TAMPENDUR	CALL	ICOMALL		; revient  la position de repos ...	JUMP	PERMU;---------\\; PMLETTRE >;=========/; Regarde si une lettre est trouve.; in	D3.B	lettre; out	D7.W	erreur; mod	D7.WPMLETTRE:	PUSHM.L	D3,D4,A3,A4	LOAD.B	D4,D3	LOAD.L	A3,#(A6)+OLTMOTOTHER$:	LOAD.L	A4,#(A6)+OLTTRMLOOP$:	TEST.B	(A4)	JUMP',EQ TERM$	COMP.B	(A3+),(A4+)	JUMP,EQ LOOP$	JUMP'	SYN$TERM$:	LOAD.B	D3,(A3)	LIB	?MINMAJ	LOAD.W	D7,#1	COMP.B	D3,D4	JUMP',EQ OK$SYN$:	TEST.B	(A3+)	JUMP,NE SYN$	TEST.B	(A3)	JUMP',EQ EXIT$	JUMP	OTHER$OK$:	LOAD.B	(A4),(A3)	LOAD.W	D3,(A6)+OLTESP	ADD.W	(A6)+OLTPLT+2,D3	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; PMTERM >;=======/; Regarde si toutes les lettres sont trouves.; Cherche aussi parmis les "synonymes" !; in	-; out	D7.W	erreur; mod	D7.WPMTERM:	PUSHM.L	A3,A4	LOAD.L	A3,#(A6)+OLTMOTOTHER$:	LOAD.L	A4,#(A6)+OLTTRM	CLR.W	D7		; D7 <-- okLOOP$:	TEST.B	(A3)	JUMP',EQ EXIT$	COMP.B	(A3+),(A4+)	JUMP,EQ LOOP$SYN$:	TEST.B	(A3+)	JUMP,NE SYN$	TEST.B	(A3)	JUMP,NE OTHER$	LOAD.W	D7,#1EXIT$:	POPM.L	A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMCLEAR >;========/; Efface l'exercice prcdent.; in	-; out	-; mod	D7.WPMCLEAR:	PUSHM.L	D2..D4,A3	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	LOAD.L	D3,#H'10000*40+40	LOAD.L	D4,#H'10000*(LYWDO-40-LYICO)+(LXWDO-40-40)	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface	LOAD.L	A3,#R16"TEXT$	LOAD.L	D4,#H'10000*(160-10)+70	CALL	AFFBOX	POPM.L	D2..D4,A3	RETTEXT$:	.ASCII	"Remets les<CR>"	.ASCII	"lettres<CR>"	.ASCII	"dans<CR>"	.ASCII	"l'ordre ..."	.B	0	.EVEN;--------\\; PMIFSYN >;========/; Regarde si le mot trouv est exact.; in	-; out	D7.W	erreur; mod	D7.WPMIFSYN:	PUSHM.L	A3,A4	LOAD.L	A3,#(A6)+OLTMOT	LOAD.L	A4,#(A6)+OLTTRM	LOAD.W	D7,#1LOOP$:	TEST.B	(A3)	JUMP',EQ TERM$	COMP.B	(A3+),(A4+)	JUMP,EQ LOOP$	JUMP'	EXIT$TERM$:	TEST.B	(A4)	JUMP',NE EXIT$	CLR.W	D7EXIT$:	POPM.L	A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMSHOW  >;--------/; Affiche la carte du mmory choisie.; in	D0.W	exercice (0..3); out	-; mod	D7.WPMSHOW:	PUSHM.L	D2..D4,A3,A4	TEST.L	(A6)+OLTPIC	JUMP,EQ EXIT$	LOAD.W	D2,#LYWDO	SUB.W	D2,(A6)+OLTDSI+0	SR.W	D2,#1	SWAP.W	D2	LOAD.W	D2,#LXWDO-50-20	SUB.W	D2,(A6)+OLTDSI+2	CALL	LTRANG		; D4 <-- rang de l'image	JUMP,NE EXIT$	DIV.WU	D4,(A6)+OLTNSI+2	LOAD.W	D3,D4	MUL.WU	D3,(A6)+OLTDSI+0 ; D3 <-- position dans l'image en Y	SWAP.W	D3	SWAP.W	D4	MUL.WU	D4,(A6)+OLTDSI+2	LOAD.W	D3,D4		; D3 <-- position dans l'image en X	LOAD.L	D4,(A6)+OLTDSI	INC.W	D2	SWAP.W	D2	INC.W	D2	SWAP.W	D2	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	A4,(A6)+OLTPIC	; A4 <-- ^image code	LOAD.L	A3,(A6)+OLTPID	; A3 <-- ^image dcode	CALL	COLORFPH	; choix d'une couleur de fond pastelle	CALL	IMAGEAFF	; affiche une carte du mmory	LIB	?COLORPOP	LOAD.L	D3,D2	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	CALL	INVMODE	LIB	?DRRECTEXIT$:	POPM.L	D2..D4,A3,A4	RET;----------\\; PMMELANGE >;==========/; Affiche le texte mlang correspondant  la carte choisie.; in	-; out	-; mod	D7.WPMMELANGE:	PUSHM.L	D0..D6,A3,A4	LIB	?AFTIM	.B	USEGC		; utilise les caractres NBP14	.B	GCTYF	.B	GCTYS	.B	GCTYT	.B	0	.EVEN	TEST.B	(A6)+OINV	; cran invers ?	JUMP',F INV$		; non => INV$	LOAD.B	D3,#AFINV	LIB	?AFCARINV$:	LOAD.L	A3,#(A6)+OLTMOT	LOAD.W	D5,#-1CNT$:	INC.W	D5		; D5 <-- nb de caractres	TEST.B	(A3+)	JUMP,NE CNT$	CLR.W	D3	LOAD.W	D4,D5	LOAD.L	A4,#(A6)+OHAPER	CALL	RZHAZARD	; rz le gnrateur alatoire	LOAD.W	D3,(A0)+ODFCX	ADD.W	D3,#8	LOAD.W	D4,D5	MUL.WU	D4,D3		; D4 <-- largeur ncessaire	LOAD.W	D0,#LXWDO	SUB.W	D0,D4	SR.W	D0,#1		; D0 <-- position pour rectangle	LOAD.W	D3,D0	LOAD.W	D4,(A0)+ODFCX	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	LOAD.W	D3,#LYWDO-LYICO-20	ADD.W	D3,(A0)+ODFC2Y	SUB.W	D3,#4	SWAP.W	D3	LOAD.L	(A6)+OLTPLT,D3	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	LOAD.L	A3,#(A6)+OLTMOT	LOAD.W	D6,D5LOOP$:	PUSH.L	D0	LOAD.W	D3,#-1	LOAD.W	D4,#+2	CALL	MMHAZARD	ADD.W	D0,D4	LOAD.W	D3,#60	LOAD.W	D4,#150	CALL	MMHAZARD	SWAP.W	D0	LOAD.W	D0,D4	SWAP.W	D0	CLR.W	D3	LOAD.W	D4,D5	LOAD.L	A4,#(A6)+OHAPER	CALL	EXHAZARD	; D4 <-- rang lettre  afficher	LOAD.W	D1,D4	LOAD.L	D3,D0	SUB.W	D3,#2	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#4	SWAP.W	D4	LOAD.W	D4,(A0)+ODFCX	ADD.W	D4,#2	LOAD.B	D2,(A3)+(D1.W)	CALL	PMCOLOR		; met une couleur  l'intrieur	LOAD.W	D2,#SETDOT	CALL	INVMODE	PUSH.W	D1	LOAD.W	D1,#2	LIB	?DRRECTO	POP.W	D1	LOAD.B	D3,(A3)+(D1.W)	LIB	?LGXCAR	SUB.W	D4,(A0)+ODFCX	NEG.W	D4	ASR.W	D4,#1	LOAD.L	D3,D0	ADD.W	D3,D4	SWAP.W	D3	ADD.W	D3,#3	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,(A3)+(D1.W)	CALL	AFFCAR		; affiche le caractre	LIB	?COLORPOP	POP.L	D0	ADD.W	D0,(A0)+ODFCX	ADD.W	D0,#8		; D0 <-- position suivante	DEC.W	D6	JUMP,NE LOOP$	LOAD.W	D3,(A0)+ODFCX	ADD.W	D3,#8	LOAD.W	(A6)+OLTESP,D3	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC		; utilise les caractres normaux	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	POPM.L	D0..D6,A3,A4	RET;--------\\; PMTEXT  >;========/; Affiche le texte correspondant  la carte choisie.; in	-; out	-; mod	D7.WPMTEXT:	PUSHM.L	D0..D4,A3	LIB	?AFTIM	.B	USEGC		; utilise les caractres NBP14	.B	GCTYF	.B	GCTYS	.B	GCTYT	.B	0	.EVEN	TEST.B	(A6)+OINV	; cran invers ?	JUMP',F INV$		; non => INV$	LOAD.B	D3,#AFINV	LIB	?AFCARINV$:	LOAD.L	A3,#(A6)+OLTMOT	LOAD.W	D4,#-1CNT$:	INC.W	D4		; D4 <-- nb de caractres	TEST.B	(A3+)	JUMP,NE CNT$	LOAD.W	D1,D4	LOAD.W	D3,(A0)+ODFCX	ADD.W	D3,#8	MUL.WU	D4,D3		; D4 <-- largeur ncessaire	LOAD.W	D0,#LYWDO-LYICO-20	SUB.W	D0,(A0)+ODFC1Y	SWAP.W	D0	LOAD.W	D0,#LXWDO	SUB.W	D0,D4	SR.W	D0,#1		; D0 <-- position pour rectangle	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	LOAD.L	A3,#(A6)+OLTTRMLOOP$:	LOAD.L	D3,D0	SUB.W	D3,#2	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#4	SWAP.W	D4	LOAD.W	D4,(A0)+ODFCX	ADD.W	D4,#2	LOAD.B	D2,(A3)	CALL	PMCOLOR		; met une couleur  l'intrieur	LOAD.W	D2,#SETDOT	CALL	INVMODE	PUSH.W	D1	LOAD.W	D1,#2	LIB	?DRRECTO	POP.W	D1	LOAD.B	D3,(A3+)	JUMP',EQ NEXT$	LIB	?LGXCAR	SUB.W	D4,(A0)+ODFCX	NEG.W	D4	ASR.W	D4,#1	LOAD.L	D3,D0	ADD.W	D3,D4	SWAP.W	D3	ADD.W	D3,#3	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,(A3)-1	CALL	AFFCAR		; affiche le caractreNEXT$:	LIB	?COLORPOP	ADD.W	D0,(A0)+ODFCX	ADD.W	D0,#8		; D0 <-- position suivante	DEC.W	D1	JUMP,NE LOOP$	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC		; utilise les caractres normaux	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	POPM.L	D0..D4,A3	RET;--------\\; PMCOLOR >;--------/; Met une couleur dans une lettre.; in	D2.B	caractre;	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WPMCOLOR:	PUSHM.L	D2..D4	LIB	?COLORPUSH	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ EXIT$		; non => EXIT$	PUSH.L	D3	LOAD.L	D3,#COLORJAUNE	TEST.B	D2	JUMP',EQ COLOR$	LOAD.B	D3,D2	LIB	?MINMAJ	CLR.L	D2	LOAD.B	D2,D3	SUB.B	D2,#'A	DIV.WU	D2,#4	SWAP.W	D2		; D2 <-- 0..3	LOAD.L	D3,#COLORVERT	DEC.W	D2	JUMP',NS COLOR$	LOAD.L	D3,#COLORCYAN	DEC.W	D2	JUMP',NS COLOR$	LOAD.L	D3,#COLORROSE	DEC.W	D2	JUMP',NS COLOR$	LOAD.L	D3,#COLORORANGECOLOR$:	LIB	?COLORCR	POP.L	D3	PUSHM.L	D3,D4	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; effaceEXIT$:	POPM.L	D2..D4	RET;--------\\; PMMOT   >;========/; Initialise une image pour les permutations.;;	OLTMOT  <--  mot<0> synonyme<0> synonyme<0> <0>; in	A3.L	^mot de la sous-image;	A4.L	^dans OBK*; out	D7.W	erreur; mod	D7.WPMMOT:	PUSHM.L	D2..D4,A1..A4	LOAD.L	D4,(A4)+OBKFAN	; D4 <-- fanions	TEST.L	D4:#BFAPERMU	JUMP,BC ERROR$	LOAD.L	A2,#(A6)+OLTMOT	LOAD.L	A1,#(A6)+OLTTRM	CLR.W	D2MOT1$:	LOAD.B	D3,(A3+)	JUMP',EQ MOT3$	COMP.B	D3,#'|	JUMP',EQ MOT2$	COMP.B	D3,#CR	JUMP',EQ MOT3$	LOAD.B	(A2+),D3	; OLTMOT <-- mot de l'image	CLR.B	(A1+)		; OLTTRM <-- mot trouv	INC.W	D2	JUMP	MOT1$MOT2$:	CLR.B	(A2+)MOT22$:	LOAD.B	D3,(A3+)	JUMP',EQ MOT3$	COMP.B	D3,#'|	JUMP',EQ MOT2$	COMP.B	D3,#CR	JUMP',EQ MOT3$	LOAD.B	(A2+),D3	; OLTMOT <-- mot "synonyme" (lettres mlanges)	JUMP	MOT22$MOT3$:	CLR.B	(A2+)	CLR.B	(A2)	CLR.B	(A1)	TEST.W	(A6)+OLTNIV	JUMP',EQ NIV0$	COMP.W	(A6)+OLTNIV,#1	JUMP',EQ NIV1$NIV2$:	COMP.W	D2,#12	JUMP',HS ERROR$	COMP.W	D2,#8	JUMP',LO ERROR$	JUMP'	NIVOK$NIV1$:	COMP.W	D2,#8	JUMP',HS ERROR$	COMP.W	D2,#4	JUMP',LS ERROR$	JUMP'	NIVOK$NIV0$:	COMP.W	D2,#4	JUMP',HI ERROR$	COMP.W	D2,#1	JUMP',LS ERROR$;	JUMP'	NIVOK$NIVOK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#ERTIMEXEXIT$:	POPM.L	D2..D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.END