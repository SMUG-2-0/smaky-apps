	.SBTTL	TSPROGRESS.ASI;---------\\; PROGRESS >;=========/; Affiche une image en mmoire selon une progression alatoire.; in	A3.L	^image source; out	-; mod	D7.WPROGRESS:	PUSHM.L	D1..D6,A3,A4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE EXIT$		; oui => EXIT$	CLR.W	D3	LOAD.W	D4,#10	LOAD.L	A4,#(A6)+OHAPRO	CALL	EXHAZARD	; D4 <-- type de progression	LOAD.W	D1,D4	CLR.L	D3	LOAD.W	D5,#LXWDO/8	LOAD.L	A4,#0	CLR.L	D4	LOAD.L	D2,#H'10000*LYWDO+LXWDO	DEC.W	D1	JUMP',EQ HB$	DEC.W	D1	JUMP',EQ CN$	DEC.W	D1	JUMP',EQ CI$	DEC.W	D1	JUMP',EQ V$	DEC.W	D1	JUMP',EQ A$	LOAD.L	D1,D2	LOAD.W	D2,#LOADDOT	CALL	DRRASTER	; affiche la mmoire dans l'cran	JUMP'	EXIT$HB$:	LOAD.L	D1,#H'10000*5+1	CALL	PROGRESSHB	JUMP'	EXIT$CN$:	CALL	PROGRESSCN	JUMP'	EXIT$CI$:	CALL	PROGRESSCI	JUMP'	EXIT$V$:	CALL	PROGRESSV	JUMP'	EXIT$A$:	CALL	PROGRESSA;	JUMP'	EXIT$EXIT$:	POPM.L	D1..D6,A3,A4	RET;-----------\\; PROGRESSHB >;===========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: progression de haut en bas; in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	----;	D1.L	incrment/dlai; out	-; mod	D7.WPROGRESSHB:	PUSHM.L	D0..D6,A2..A4	CALL	PROGRESSI	; prpare les paramtres	LOAD.W	D4,D1		; D4 <-- dlai	CLR.W	D3		; D3 <-- compteur	LOAD.L	D0,D2	SR.W	D0,#5		; D0 <-- largeur /32 car par .L	DEC.W	D0		; D0 <-- largeur -1 car NMO	LOAD.L	D2,D1	SWAP.W	D2		; D2 <-- incrment20$:	PUSHM.L	D0,A3,A430$:	LOAD.L	(A4+),(A3+)	; destination <-- source	DECJ.W,NMO D0,30$	POPM.L	D0,A3,A4	INC.W	D3	CLR.L	D1	LOAD.W	D1,D3	DIV.WU	D1,D2	SWAP.W	D1	TEST.W	D1	JUMP',NE 50$	NTREL	?DELMS		; attend un p'tit peu50$:	ADD.W	A3,D5		; A3 <-- ^ligne suivante	ADD.W	A4,D6		; A4 <-- ^ligne suivante	SWAP.W	D0	DEC.W	D0	LOAD.W	D1,D0	SWAP.W	D0	TEST.W	D1	JUMP,NE 20$	POPM.L	D0..D6,A2..A4	RET;-----------\\; PROGRESSCN >;===========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: carrs (zoom avant); in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	----;	D1.W	dlai; out	-; mod	D7.WPROGRESSCN:	PUSHM.L	D0..D6,A2	CALL	PROGRESSI	; prpare les paramtres	LOAD.W	D4,D1		; D4 <-- dlai	CLR.W	D320$:	CALL	PROGRESSCC	; dessine un carr	CALL	PROGRESS1	; progresse un p'tit peu ...	TEST.W	D4	JUMP',EQ 50$	NTREL	?DELMS		; attend un p'tit peu50$:	INC.W	D3	COMP.W	D3,#16	JUMP,LO 20$	POPM.L	D0..D6,A2	RET;-----------\\; PROGRESSCI >;===========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: carrs (zoom arrire); in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	----;	D1.W	dlai; out	-; mod	D7.WPROGRESSCI:	PUSHM.L	D0..D6,A2	CALL	PROGRESSI	; prpare les paramtres	LOAD.W	D4,D1		; D4 <-- dlai	LOAD.W	D3,#1520$:	CALL	PROGRESSCC	; dessine un carr	CALL	PROGRESS1	; progresse un p'tit peu ...	TEST.W	D4	JUMP',EQ 50$	NTREL	?DELMS		; attend un p'tit peu50$:	DEC.W	D3	JUMP,NC 20$	POPM.L	D0..D6,A2	RET;-----------\\; PROGRESSCC >;-----------/; Dessine un carr centr dans la matrice de transfert.; in	D3.W	rang (0..15); out	-; mod	D7.WPROGRESSCC:	PUSHM.L	D2..D4,A4	CALL	OPEDISMAT	; dessin en mmoire	LOAD.L	A4,A2		; A4 <-- ^matrice vide	LOAD.L	D4,#H'10000*32+32	CALL	NEWDISMAT	LOAD.W	D2,D3	INC.W	D2	SL.W	D2,#1	DEC.W	D2	LOAD.W	D4,D2	SWAP.W	D4	LOAD.W	D4,D2	LOAD.W	D2,D3	SUB.W	D2,#15	NEG.W	D2	LOAD.W	D3,D2	SWAP.W	D3	LOAD.W	D3,D2	LOAD.W	D2,#SETDOT	CALL	DRRECT	CALL	CLODISMAT	; dessin dans l'cran	POPM.L	D2..D4,A4	RET;----------\\; PROGRESSV >;==========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: stores vnitiens; in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	----;	D1.W	dlai; out	-; mod	D7.WPROGRESSV:	PUSHM.L	D0..D6,A2	CALL	PROGRESSI	; prpare les paramtres	LOAD.W	D4,D1		; D4 <-- dlai	CLR.W	D320$:	LOAD.L	A2,#(A6)+OMATPR	LOAD.W	D1,#32-130$:	CLR.L	(A2+)	DECJ.W,NMO D1,30$	LOAD.L	A2,#(A6)+OMATPR	; A2 <-- ^matrice vide	LOAD.L	(A2)+(D3.W),#-1	CALL	PROGRESS1	; progresse un p'tit peu ...	TEST.W	D4	JUMP',EQ 50$	NTREL	?DELMS		; attend un p'tit peu50$:	ADD.W	D3,#4	COMP.W	D3,#128	JUMP,LO 20$	POPM.L	D0..D6,A2	RET;----------\\; PROGRESSA >;==========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: alatoire (fondu enchan); in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x); out	-; mod	D7.WPROGRESSA:	COMP.B	(A6)+OMACHINE,#SMAKY324	JUMP,EQ PROGRESSAL	PUSHM.L	D0..D6,A1,A2	CALL	PROGRESSI	; prpare les paramtres	LOAD.L	A1,#R16"TPR256	LOAD.W	D1,#(16*16)-120$:	LOAD.L	A2,#(A6)+OMATPR	LOAD.W	D0,#(32/4)-1	CLR.L	D330$:	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	DECJ.W,NMO D0,30$	LOAD.L	A2,#(A6)+OMATPR	LOAD.B	D3,(A1+)	; D3 <-- xxxxxxxx76543210	LOAD.W	D4,D3	SR.B	D4,#5		; D4 <-- xxxxxxxxooooo765	RR.W	D3,#1		; D3 <-- 0xxxxxxxo7654321	SL.B	D3,#1		; D3 <-- 0xxxxxxx7654321o	RL.W	D3,#1		; D3 <-- xxxxxxxx654321o0	AND.W	D3,#B'111101	; D3 <-- oooooooooo4321o0	TSET.B	(A2)+(D3.W):D4	ADD.W	D3,#2	TSET.B	(A2)+(D3.W):D4	ADD.W	D3,#64-2	TSET.B	(A2)+(D3.W):D4	ADD.W	D3,#2	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	DECJ.W,NMO D1,20$	POPM.L	D0..D6,A1,A2	RET;-----------\\; PROGRESSAX >;===========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: alatoire (fondu enchan); in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	D1.W	rang (0..7); out	-; mod	D7.WPROGRESSAX:	PUSHM.L	D0..D6,A1,A2	CALL	PROGRESSI	; prpare les paramtres	LOAD.L	A1,#R16"TPR256	MUL.WU	D1,#(16*16)/8	ADD.L	A1,D1	LOAD.W	D1,#((16*16)/8)-1LOOP$:	LOAD.L	A2,#(A6)+OMATPR	LOAD.W	D0,#(32/4)-1	CLR.L	D3CLR$:	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	DECJ.W,NMO D0,CLR$	LOAD.L	A2,#(A6)+OMATPR	LOAD.B	D3,(A1+)	; D3 <-- xxxxxxxx76543210	LOAD.W	D4,D3	SR.B	D4,#5		; D4 <-- xxxxxxxxooooo765	RR.W	D3,#1		; D3 <-- 0xxxxxxxo7654321	SL.B	D3,#1		; D3 <-- 0xxxxxxx7654321o	RL.W	D3,#1		; D3 <-- xxxxxxxx654321o0	AND.W	D3,#B'111101	; D3 <-- oooooooooo4321o0	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	TCLR.B	(A2)+(D3.W):D4	ADD.W	D3,#2	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	TCLR.B	(A2)+(D3.W):D4	ADD.W	D3,#64-2	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	TCLR.B	(A2)+(D3.W):D4	ADD.W	D3,#2	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	TCLR.B	(A2)+(D3.W):D4	DECJ.W,NMO D1,LOOP$	POPM.L	D0..D6,A1,A2	RET;-----------\\; PROGRESSAL >;===========/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais progressivement !; Effet: alatoire lent (fondu enchan); in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x); out	-; mod	D7.WPROGRESSAL:	PUSHM.L	D0..D6,A1,A2	CALL	PROGRESSI	; prpare les paramtres	LOAD.L	A1,#R16"TPR256	LOAD.W	D1,#(16*16)-120$:	LOAD.L	A2,#(A6)+OMATPR	LOAD.W	D0,#(32/4)-1	CLR.L	D330$:	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	DECJ.W,NMO D0,30$	LOAD.L	A2,#(A6)+OMATPR	LOAD.B	D3,(A1+)	; D3 <-- xxxxxxxx76543210	LOAD.W	D4,D3	SR.B	D4,#5		; D4 <-- xxxxxxxxooooo765	RR.W	D3,#1		; D3 <-- 0xxxxxxxo7654321	SL.B	D3,#1		; D3 <-- 0xxxxxxx7654321o	RL.W	D3,#1		; D3 <-- xxxxxxxx654321o0	AND.W	D3,#B'111101	; D3 <-- oooooooooo4321o0	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	TCLR.B	(A2)+(D3.W):D4	ADD.W	D3,#2	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	TCLR.B	(A2)+(D3.W):D4	ADD.W	D3,#64-2	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	TCLR.B	(A2)+(D3.W):D4	ADD.W	D3,#2	TSET.B	(A2)+(D3.W):D4	CALL	PROGRESS1	; progresse un p'tit peu ...	TCLR.B	(A2)+(D3.W):D4	DECJ.W,NMO D1,20$	POPM.L	D0..D6,A1,A2	RET; Cette table (gnre par GENH256.ASC) donne 256 valeurs alatoires,; toutes diffrentes.TPR256:	.L	H'034C7F21,H'598509BF,H'FEB9B36C,H'B80ED424	.L	H'1D5008FF,H'01D5C79D,H'35697871,H'262705FA	.L	H'CCCB7C34,H'D9F81CD6,H'DEE3CF5B,H'A3D2EFB7	.L	H'648FE094,H'1A9756E8,H'77B1F24D,H'46F4F598	.L	H'96425F55,H'5C5D1089,H'D714E27D,H'9A0CBC2B	.L	H'D10DC81E,H'88836BEA,H'A49012FD,H'99321682	.L	H'159EE91B,H'B2A2473A,H'0AACEE2E,H'7BED4E7A	.L	H'5EF3E7F1,H'BDA7E445,H'30E68165,H'3E2C9C48	.L	H'DC41C9DF,H'362D8C79,H'734F58A1,H'76510F49	.L	H'0B54FC28,H'A60453C3,H'1FC02922,H'ABBB2A18	.L	H'438D66C1,H'CAA0BAE1,H'F7E5CDAD,H'6E173CB0	.L	H'92D86325,H'D0B46D4A,H'7420AF3B,H'F9333707	.L	H'AAC4B557,H'066A8E8A,H'86615A23,H'6F753D11	.L	H'60007038,H'804052CE,H'4BF06784,H'95313991	.L	H'9BAEDD72,H'87A868D3,H'F6EC7EFB,H'44C59319	.L	H'A9622FC2,H'DABE1302,H'A53F8BDB,H'EB9FB6C6;----------\\; PROGRESSI >;----------/; Prpare les paramtres.; in	A0.L	^description fentre;	----;	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----; out	A3.L	^mmoire source;	D5.W	Iy source;	A4.L	^mmoire destination;	D6.W	Iy destination;	A2.L	^matrice de transfert (32x32); mod	D5.L, D6.L, D7.W, A2.L, A3.L, A4.LPROGRESSI:	PUSHM.L	D0,D3,D4	LOAD.L	D0,A3		; source dans l'cran ?	JUMP',NE 10$		; non => 10$				; oui =>	LOAD.L	A3,(A0)+ODFABS	; A3 <-- adresse dbut cran	LOAD.W	D5,(A0)+ODFIIY	; D5 <-- Iy cran	ADD.W	D3,(A0)+ODFWBX	; D3 <-- dans (sous-)fentre en X	SWAP.W	D3	ADD.W	D3,(A0)+ODFWBY	; D3 <-- dans (sous-)fentre en Y	SWAP.W	D310$:	LOAD.L	D0,D3	SWAP.W	D0	MUL.WU	D0,D5	ADD.L	A3,D0	LOAD.W	D0,D3	SR.W	D0,#3	ADD.W	A3,D0		; A3 <-- ^byte source	LOAD.L	D0,A4		; destination dans l'cran ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A4,(A0)+ODFABS	; A4 <-- adresse dbut cran	LOAD.W	D6,(A0)+ODFIIY	; D6 <-- Iy cran	ADD.W	D4,(A0)+ODFWBX	; D4 <-- dans (sous-)fentre en X	SWAP.W	D4	ADD.W	D4,(A0)+ODFWBY	; D4 <-- dans (sous-)fentre en Y	SWAP.W	D420$:	LOAD.L	D0,D4	SWAP.W	D0	MUL.WU	D0,D6	ADD.L	A4,D0	LOAD.W	D0,D4	SR.W	D0,#3	ADD.W	A4,D0		; A4 <-- ^byte destination	LOAD.L	A2,#(A6)+OMATPR	LOAD.W	D0,#32-130$:	CLR.L	(A2+)	DECJ.W,NMO D0,30$	LOAD.L	A2,#(A6)+OMATPR	; A2 <-- ^matrice vide	POPM.L	D0,D3,D4	RET;----------\\; PROGRESS1 >;----------/; Transfert une matrice source dans un matrice destination; en mode LOAD, mais seulement les points allums dans la; matrice de transfert de 32x32 points.; in	A3.L	^mmoire source;	D5.W	Iy source;	A4.L	^mmoire destination;	D6.W	Iy destination;	D2.L	hauteur/largeur (y;x);	A2.L	^matrice de transfert (32x32); out	-; mod	D7.WPROGRESS1:	PUSHM.L	D0..D4,A1..A4	LOAD.L	D0,D2	SR.W	D0,#5		; D0 <-- largeur /32 car par .L	DEC.W	D0		; D0 <-- largeur -1 car NMO	LOAD.L	A1,#(A2)+32*4	; A1 <-- ^fin matrice20$:	COMP.L	A2,A1		; est-on  la fin de la matrice ?	JUMP',NE 22$		; non => 22$	LOAD.L	A2,#(A1)-32*4	; A2 <-- ^dbut de la matrice22$:	LOAD.L	D2,(A2+)	; D2 <-- masque	JUMP',EQ 50$	LOAD.L	D1,D2	NOT.L	D1		; D1 <-- masque invers	PUSHM.L	D0,A3,A430$:	LOAD.L	D3,(A3+)	; D3 <-- source	AND.L	D3,D2	LOAD.L	D4,(A4)		; D4 <-- destination	AND.L	D4,D1	OR.L	D4,D3	LOAD.L	(A4+),D4	DECJ.W,NMO D0,30$	POPM.L	D0,A3,A450$:	ADD.W	A3,D5		; A3 <-- ^ligne suivante	ADD.W	A4,D6		; A4 <-- ^ligne suivante	SWAP.W	D0	DEC.W	D0	LOAD.W	D1,D0	SWAP.W	D0	TEST.W	D1	JUMP,NE 20$	POPM.L	D0..D4,A1..A4	RET	.END