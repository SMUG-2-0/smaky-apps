	.SBTTL	TSPUZZLE.ASI; Gestion des puzzles; -------------------PUZZLE:	CALL	_AFMENUJ	; affiche les soft-keys	CALL	_CCMO		; enlve la souris	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	LOAD.L	A4,#R16"TMENU$	CALL	CHEXPUZZLE	; OCHMAP <-- icnes existantes	CALL	CHDRAW		; dessine les choix	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	CALL	_CLRFIFO	; vide le fifo du clavier	CALL	_SCMO		; remet la sourisMENU$:	LOAD.L	A4,#R16"TMENU$	CALL	CHMENU		; choix selon menu ...	LOAD.L	D4,#H'10000*1+4	COMP.W	D3,#'1	JUMP,EQ GO$	LOAD.L	D4,#H'10000*2+2	COMP.W	D3,#'2	JUMP,EQ GO$	LOAD.L	D4,#H'10000*2+3	COMP.W	D3,#'3	JUMP,EQ GO$	LOAD.L	D4,#H'10000*3+3	COMP.W	D3,#'4	JUMP,EQ GO$	LOAD.L	D4,#H'10000*3+4	COMP.W	D3,#'5	JUMP,EQ GO$	LOAD.L	D4,#H'10000*4+4	COMP.W	D3,#'6	JUMP,EQ GO$	LOAD.L	D4,#H'10000*5+5	COMP.W	D3,#'7	JUMP,EQ GO$	LOAD.L	D4,#H'10000*6+6	COMP.W	D3,#'8	JUMP,EQ GO$	COMP.W	D3,#'9	JUMP,EQ LOOP	COMP.W	D3,#F0	JUMP,EQ LOOP	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	MENU$TMENU$:	.W	ICOPZ41	.W	ICOPZ22	.W	ICOPZ32	.W	ICOPZ33	.W	ICOPZ43	.W	ICOPZ44	.W	ICOPZ55	.W	ICOPZ66	.W	ICOANNULEGO$:	CALL	_CCMO		; enlve la souris	CALL	PZINIT		; prpare un puzzle mlang	JUMP,NE ERROR	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	PZCADRE		; affiche le cadre	CALL	PZCORRECT	; affiche le puzzle correct	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	LOAD.W	D4,#50*1	NTREL	?DELMS	LOAD.L	A4,#R16"TAMVASC	CALL	ICOMALL		; va sur l'ascenseur de droite ...	LOAD.W	D4,#50*1	NTREL	?DELMS	CALL	JGFULL		; rempli la jauge ...	LOAD.W	D4,#50*2	NTREL	?DELMS	CALL	JGBAGUETTE	; coup de baguette magique ...	CALL	PZSHOW		; affiche le puzzle mlang initial	CALL	PZQUADRIL	; affiche le quadrillage	LOAD.L	(A6)+OJGECT,(A6)+OTIME	CLR.W	(A6)+OJGECP	CALL	_CLRFIFO	; vide le fifo du clavier	CALL	_SCMO		; remet la sourisLOOP$:	CALL	JGECOULE	; coule la jauge de droite	JUMP,NE BAD$	LOAD.W	D4,#2	NTREL	?SETTIM	LIB	?GETCAR		; clavier/souris ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE LOOP$	COMP.W	D3,#F0	JUMP',EQ END$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$BIP$:	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	LOOP$CLIC$:	CALL	PZMOVE		; dplace une pice ...	JUMP,NE BIP$	CALL	PZTERM		; puzzle termin ?	JUMP,NE LOOP$		; non => LOOP$	CALL	_CCMO		; enlve la souris	CALL	PZCORRECT	; affiche le puzzle correct	CALL	JGGAGNE		; victoire ...	JUMP	KILL$BAD$:	CALL	_CCMO		; enlve la souris	LOAD.W	(A6)+OSOUND,#TMUSPERDU	LOAD.L	A4,#R16"TAMRASCS	CALL	ICOMALL		; saute sur l'ascenseur ...	LOAD.W	D4,#50	NTREL	?DELMS		; attend 1 seconde ...	CALL	PZCORRECT	; affiche le puzzle correct	LOAD.W	D4,#50	NTREL	?DELMS		; attend 1 seconde ...	LOAD.L	A4,#R16"TAMRASCP	CALL	ICOMALL		; revient de l'ascenseur de droite ...	JUMP'	KILL$END$:	CALL	_CCMO		; enlve la souris	CALL	JGECTERM	; termine l'coulement de la jauge	LOAD.L	A4,#R16"TAMRASC	CALL	ICOMALL		; revient de l'ascenseur de droite ...KILL$:	CALL	PZKILL		; libre le puzzle	JUMP	PUZZLE;--------\\; PZINIT  >;========/; Initialise un nouveau puzzle.; in	D4.L	nb de pices (ny;nx); out	D7.W	erreur; mod	D7.WPZINIT:	PUSHM.L	D2..D4,A3,A4	LOAD.L	(A6)+OPZNBY,D4	LOAD.W	D2,#MAXIMA*2OTHER$:	LOAD.W	D7,#ERTIMEX	DEC.W	D2	JUMP,NS EXIT$	CLR.W	D3	LOAD.W	D4,(A6)+OBKNBU	JUMP,EQ EXIT$	LOAD.L	A4,#(A6)+OHABKI	CALL	_EXHAZARD	; D4 <-- nombre alatoire	LOAD.L	A3,#(A6)+OBKTAB	MUL.WU	D4,#LBK	ADD.L	A3,D4	TEST.L	(A3)+OBKPIC	; image existe ?	JUMP,EQ OTHER$		; non => OTHER$	TEST.L	(A3)+OBKNSI	; y'a-t-il des sous-images ?	JUMP,NE OTHER$		; oui => OTHER$	LOAD.L	D4,(A3)+OBKFAN	LOAD.L	D3,#H'10000*1+4	TEST.L	D4:#BFAP41	JUMP',BS DIM$	LOAD.L	D3,#H'10000*2+2	TEST.L	D4:#BFAP22	JUMP',BS DIM$	LOAD.L	D3,#H'10000*2+3	TEST.L	D4:#BFAP32	JUMP',BS DIM$	LOAD.L	D3,#H'10000*3+3	TEST.L	D4:#BFAP33	JUMP',BS DIM$	LOAD.L	D3,#H'10000*3+4	TEST.L	D4:#BFAP43	JUMP',BS DIM$	LOAD.L	D3,#H'10000*4+4	TEST.L	D4:#BFAP44	JUMP',BS DIM$	LOAD.L	D3,#H'10000*5+5	TEST.L	D4:#BFAP55	JUMP',BS DIM$	LOAD.L	D3,#H'10000*6+6DIM$:	COMP.W	D3,(A6)+OPZNBX	JUMP,LO OTHER$	SWAP.W	D3	COMP.W	D3,(A6)+OPZNBY	JUMP,LO OTHER$	LOAD.L	A4,(A3)+OBKPIC	; A4 <-- ^image code	LOAD.W	D4,(A4)+OIMDLX	COMP.W	D4,#200	JUMP,LO OTHER$	COMP.W	D4,#540	JUMP,HI OTHER$	LOAD.W	D4,(A4)+OIMDLY	COMP.W	D4,#150	JUMP,LO OTHER$	COMP.W	D4,#320	JUMP,HI OTHER$	LOAD.L	(A6)+OPZPIC,A4	CALL	IMAGEDECO	; A3 <-- ^image dcode	JUMP,NE EXIT$	LOAD.L	(A6)+OPZPID,A3	LOAD.W	D4,#LYWDO	SUB.W	D4,(A4)+OIMDLY	SR.W	D4,#1	LOAD.W	(A6)+OPZPOS+0,D4	LOAD.W	D4,#LXWDO-LXICO	SUB.W	D4,(A4)+OIMDLX	SR.W	D4,#1	LOAD.W	(A6)+OPZPOS+2,D4	CLR.L	D4	LOAD.W	D4,(A4)+OIMDLX	DIV.WU	D4,(A6)+OPZNBX	LOAD.W	(A6)+OPZDIMX,D4	CLR.L	D4	LOAD.W	D4,(A4)+OIMDLY	DIV.WU	D4,(A6)+OPZNBY	LOAD.W	(A6)+OPZDIMY,D4HAZARD$:	CLR.W	D3	LOAD.W	D4,(A6)+OPZNBX	MUL.WU	D4,(A6)+OPZNBY	LOAD.L	A4,#(A6)+OHAPUZ	CALL	_RZHAZARD	; rz gnrateur alatoire	LOAD.L	A3,#(A6)+OPZTAB	LOAD.W	D2,D4LOOP$:	CLR.W	D3	LOAD.W	D4,(A6)+OPZNBX	MUL.WU	D4,(A6)+OPZNBY;	LOAD.L	A4,#(A6)+OHAPUZ	CALL	_EXHAZARD	; D4 <-- nombre alatoire	LOAD.B	(A3+),D4	; OPZTAB <-- numro de pice	DEC.W	D2	JUMP,NE LOOP$	CALL	PZTERM		; D4 <-- nb de pices mal places	LOAD.W	D3,(A6)+OPZNBX	MUL.WU	D3,(A6)+OPZNBY	; D3 <-- nb de pices	LOAD.W	D2,D3	MUL.WU	D2,#3	DIV.WU	D2,#4		; D2 <-- le 3/4 du nombre total de pices	COMP.W	D4,D2		; y a-t-il assez de pices mal places ?	JUMP,LO HAZARD$		; non => HAZARD$	LOAD.W	D4,#20		; D4 <-- 20 secondes	COMP.W	D3,#4	JUMP',LS ECD$	LOAD.W	D4,#30		; D4 <-- 30 secondes	COMP.W	D3,#9	JUMP',LS ECD$	LOAD.W	D4,#70		; D4 <-- 70 secondes	COMP.W	D3,#16	JUMP',LS ECD$	LOAD.W	D4,#140		; D4 <-- 140 secondesECD$:	LOAD.W	(A6)+OJGECD,D4	; OJGECD <-- dure du jeu	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PZCADRE >;========/; Affiche le cadre.; in	-; out	-; mod	D7.WPZCADRE:	PUSHM.L	D1..D4	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	CALL	COLORHAZARD	; choix de couleurs alatoires	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame toute la fentre	LIB	?COLORPOP	LOAD.W	D1,#B'0000011000011001	LOAD.W	D4,(A6)+OPZNBY	MUL.WU	D4,(A6)+OPZDIMY	SWAP.W	D4	LOAD.W	D3,(A6)+OPZNBX	MUL.WU	D3,(A6)+OPZDIMX	LOAD.W	D4,D3	LOAD.L	D3,(A6)+OPZPOS	CALL	DESRECTM	; cadre autour de l'image du puzzle	CALL	JGDRAW		; dessine la jauge	POPM.L	D1..D4	RET;--------\\; PZTERM  >;========/; Vrifie si le puzzle est termin.; in	-; out	D4.W	nb de pices mal places (0..n);	D7.W	EQ si termin; mod	D4.L, D7.WPZTERM:	PUSHM.L	D2,D3,A4	LOAD.L	A4,#(A6)+OPZTAB	LOAD.W	D2,(A6)+OPZNBX	MUL.WU	D2,(A6)+OPZNBY	CLR.B	D3	CLR.W	D4LOOP$:	COMP.B	D3,(A4+)	JUMP',EQ NEXT$	INC.W	D4		; D4 <-- une pice mal place de plusNEXT$:	INC.B	D3	DEC.W	D2	JUMP,NE LOOP$	LOAD.W	D7,#1		; D7 <-- pas correct	TEST.W	D4	JUMP',NE EXIT$	CLR.W	D7		; D7 <-- terminEXIT$:	POPM.L	D2,D3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PZMOVE  >;========/; Dplace une pice.; in	-; out	D7.W	erreur; mod	D7.WPZMOVE:	PUSHM.L	D0..D4,A4	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE EXIT$	CALL	PZDETECT	; D3 <-- pice o est la souris	JUMP,NE EXIT$	LOAD.W	D2,#SETDOT	CALL	PZHILIC		; allume la pice de dpart	LOAD.W	D0,D3		; D0 <-- pice de dpart	LOAD.W	D1,D3		; D1 <-- pice d'arriveLOOP$:	CLR.L	D3	CALL	JGECOULE	; coule la jauge de droite	JUMP,NE END$	LOAD.W	D4,#2	NTREL	?SETTIM	LIB	?GETKEY		; attend souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE LOOP$	COMP.W	D3,#KEYMPO	JUMP,NE END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	PZDETECT	; D3 <-- pice o est la souris	JUMP,NE LOOP$	COMP.W	D3,D1		; toujours dans la mme pice ?	JUMP,EQ LOOP$		; oui => LOOP$	EX.L	D3,D1	COMP.W	D3,D0	JUMP',EQ NOCLR$	LOAD.W	D2,#CLRDOT	CALL	PZHILIA		; teint la pice d'arriveNOCLR$:	LOAD.W	D3,D1	COMP.W	D3,D0	JUMP,EQ LOOP$	LOAD.W	D2,#SETDOT	CALL	PZHILIA		; allume la pice d'arrive	JUMP	LOOP$END$:	COMP.W	D0,D1	JUMP',NE DAOK$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$DAOK$:	LOAD.W	D3,D1	COMP.W	D3,D0	JUMP',EQ NOCLRA$	LOAD.W	D2,#CLRDOT	CALL	PZHILIA		; teint la pice d'arriveNOCLRA$:	LOAD.W	D3,D0	LOAD.W	D2,#CLRDOT	CALL	PZHILIC		; teint la pice de dpart	LOAD.L	A4,#(A6)+OPZTAB	COMP.W	D0,D1	JUMP',EQ JF$	LOAD.B	D3,(A4)+(D0.W)	LOAD.B	(A4)+(D0.W),(A4)+(D1.W) ; EX.B (A4)+(D0.W),(A4)+(D1.W)	LOAD.B	(A4)+(D1.W),D3	LOAD.W	D3,D0	CALL	PZPIECE		; affiche la pice de dpart	LOAD.W	D3,D1	CALL	PZPIECE		; affiche la pice d'arriveJF$:	COMP.B	D1,(A4)+(D1.W)	JUMP',NE FAUX$JUSTE$:	CALL	PZTERM		; puzzle termin ?	JUMP',EQ OK$		; oui => OK$	CALL	JGJUSTE		; indique que c'est juste	JUMP'	OK$FAUX$:	CALL	JGFAUX		; indique que c'est faux;	JUMP'	OK$OK$:	CLR.W	D7EXIT$:	POPM.L	D0..D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; PZDETECT >;---------/; Dtecte dans quelle pice est la souris.; in	D4.L	position de la souris; out	D3.W	numro de la pice;	D7.W	erreur; mod	D3.L, D7.WPZDETECT:	PUSH.L	D4	LOAD.W	D7,#1	CLR.L	D3	LOAD.W	D3,D4	SUB.W	D3,(A6)+OPZPOS+2	JUMP',LO EXIT$	DIV.WU	D3,(A6)+OPZDIMX	COMP.W	D3,(A6)+OPZNBX	JUMP',HS EXIT$	CLR.W	D4	SWAP.W	D4	SUB.W	D4,(A6)+OPZPOS+0	JUMP',LO EXIT$	DIV.WU	D4,(A6)+OPZDIMY	COMP.W	D4,(A6)+OPZNBY	JUMP',HS EXIT$	MUL.WU	D4,(A6)+OPZNBX	ADD.W	D3,D4	CLR.W	D7EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PZHILIA >;--------/; Met en vidence toute la pice.; in	D3.W	numro de la pice;	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WPZHILIA:	PUSHM.L	D2..D4	COMP.W	D2,#CLRDOT	JUMP,EQ CLR$	CALL	PZPOSDIM	; D3/D4 <-- position/dimensions	JUMP,NE EXIT$	PUSHM.L	D3,D4	LOAD.L	D3,#H'11004400	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	LIB	?COLORPUSH	LOAD.L	D3,#COLORHILI	LIB	?COLORCR	LOAD.L	D3,#COLORNOIR	LIB	?COLORSR	POPM.L	D3,D4	INC.W	D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	INC.W	D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; grise tout l'intrieur	LIB	?COLORPOP	ADD.W	D3,#10	SWAP.W	D3	ADD.W	D3,#10	SWAP.W	D3	SUB.W	D4,#10+10+1	SWAP.W	D4	SUB.W	D4,#10+10+1	SWAP.W	D4	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRRECT	JUMP'	EXIT$CLR$:	CALL	PZPIECE		; raffiche la piceEXIT$:	POPM.L	D2..D4	RET;--------\\; PZHILIC >;--------/; Met en vidence le cadre de la pice.; in	D3.W	numro de la pice;	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WPZHILIC:	PUSHM.L	D2..D4	COMP.W	D2,#CLRDOT	JUMP,EQ CLR$	CALL	PZPOSDIM	; D3/D4 <-- position/dimensions	JUMP,NE EXIT$	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	LIB	?COLORPUSH	LOAD.L	D3,#COLORHILI	LIB	?COLORSR	POPM.L	D3,D4	CALL	INVMODE	PUSHM.L	D3,D4	INC.W	D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	INC.W	D3	LOAD.W	D4,#LHILIC	SWAP.W	D3	SWAP.W	D4	LIB	?DRTRAME	POPM.L	D3,D4	PUSHM.L	D3,D4	INC.W	D3	LOAD.W	D4,#LHILIC	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#1+LHILIC	SUB.W	D4,#LHILIC+LHILIC+1	SWAP.W	D3	SWAP.W	D4	LIB	?DRTRAME	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,D4	SUB.W	D3,#LHILIC	LOAD.W	D4,#LHILIC	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#1+LHILIC	SUB.W	D4,#LHILIC+LHILIC+1	SWAP.W	D3	SWAP.W	D4	LIB	?DRTRAME	POPM.L	D3,D4	PUSHM.L	D3,D4	INC.W	D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SUB.W	D3,#LHILIC	LOAD.W	D4,#LHILIC	SWAP.W	D3	SWAP.W	D4	LIB	?DRTRAME	POPM.L	D3,D4	LIB	?COLORPOP	JUMP'	EXIT$CLR$:	CALL	PZPIECE		; raffiche la piceEXIT$:	POPM.L	D2..D4	RET;---------\\; PZPOSDIM >;---------/; Donne la position et les dimensions d'une pice.; in	D3.W	numro de la pice; out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WPZPOSDIM:	PUSHM.L	D1,D2	CLR.L	D2	LOAD.W	D2,D3	LOAD.W	D7,#1	LOAD.W	D3,(A6)+OPZNBX	MUL.WU	D3,(A6)+OPZNBY	COMP.W	D2,D3	JUMP',HS EXIT$	DIV.WU	D2,(A6)+OPZNBX	LOAD.L	D3,(A6)+OPZPOS	LOAD.W	D1,D2	MUL.WU	D1,(A6)+OPZDIMY	SWAP.W	D3	ADD.W	D3,D1		; D3 <-- position dans l'cran en Y	SWAP.W	D3	SWAP.W	D2	MUL.WU	D2,(A6)+OPZDIMX	ADD.W	D3,D2		; D3 <-- position dans l'cran en X	LOAD.L	D4,(A6)+OPZDIMY	; D4 <-- dimensions	CLR.W	D7EXIT$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;----------\\; PZQUADRIL >;==========/; Affiche le quadrillage pour marquer les pices.; in	-; out	-; mod	D7.WPZQUADRIL:	PUSHM.L	D1..D4	LOAD.W	D2,#SETDOT	CALL	INVMODE	LOAD.W	D4,(A6)+OPZDIMX	MUL.WU	D4,(A6)+OPZNBX	INC.W	D4	LOAD.L	D3,(A6)+OPZPOS	LOAD.W	D1,(A6)+OPZNBYLOOPH$:	PUSH.L	D3	LIB	?DRSEG		; trace un trait horizontal	POP.L	D3	SWAP.W	D3	ADD.W	D3,(A6)+OPZDIMY	SWAP.W	D3	DECJ.W,NMO D1,LOOPH$	LOAD.W	D4,(A6)+OPZDIMY	MUL.WU	D4,(A6)+OPZNBY	INC.W	D4	SWAP.W	D4	LOAD.L	D3,(A6)+OPZPOS	LOAD.W	D1,(A6)+OPZNBXLOOPV$:	PUSH.L	D3	LIB	?DRSEG		; trace un trait vertical	POP.L	D3	ADD.W	D3,(A6)+OPZDIMX	DECJ.W,NMO D1,LOOPV$	POPM.L	D1..D4	RET;----------\\; PZCORRECT >;==========/; Affiche l'image du puzzle correcte (non-mlange).; in	-; out	-; mod	D7.WPZCORRECT:	PUSHM.L	D2..D4,A3,A4	LOAD.W	D4,(A6)+OPZNBY	MUL.WU	D4,(A6)+OPZDIMY	SWAP.W	D4	LOAD.W	D3,(A6)+OPZNBX	MUL.WU	D3,(A6)+OPZDIMX	LOAD.W	D4,D3	LOAD.L	D2,(A6)+OPZPOS	CLR.L	D3	LOAD.L	A4,(A6)+OPZPIC	; A4 <-- ^image code	LOAD.L	A3,(A6)+OPZPID	; A3 <-- ^image dcode	CALL	IMAGEAFF	LOAD.L	D3,D2	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRRECT		; affiche un rectangle autour	POPM.L	D2..D4,A3,A4	RET;--------\\; PZSHOW  >;========/; Affiche l'image du puzzle.; in	-; out	-; mod	D7.WPZSHOW:	PUSHM.L	D3,D4	CLR.W	D3	LOAD.W	D4,(A6)+OPZNBX	MUL.WU	D4,(A6)+OPZNBYLOOP$:	CALL	PZPIECE		; affiche une pice	INC.W	D3	DEC.W	D4	JUMP,NE LOOP$	POPM.L	D3,D4	RET;--------\\; PZPIECE >;--------/; Affiche une pice du puzzle.; in	D3.W	rang de la pice; out	-; mod	D7.WPZPIECE:	PUSHM.L	D1..D4,A3,A4	LOAD.L	D2,(A6)+OPZPOS	LOAD.L	A4,#(A6)+OPZTAB	; A4 <-- ^table des pices	CLR.L	D4	LOAD.B	D4,(A4)+(D3.W)	; D4 <-- numro de la pice	PUSH.L	D3	LIB	?COLORPUSH	COMP.B	D3,D4		; pice bien place ?	JUMP',EQ JUSTE$		; oui => JUSTE$FAUX$:	LOAD.L	D3,#COLORROSE	JUMP'	COLOR$JUSTE$:	LOAD.L	D3,#COLORVERT;	JUMP'	COLOR$COLOR$:	LIB	?COLORCR	; choix de la couleur du fond de la pice	POP.L	D3	AND.L	D3,#H'FFFF	DIV.WU	D3,(A6)+OPZNBX	LOAD.W	D1,D3	MUL.WU	D1,(A6)+OPZDIMY	SWAP.W	D2	ADD.W	D2,D1		; D2 <-- position dans l'cran en Y	SWAP.W	D2	SWAP.W	D3	MUL.WU	D3,(A6)+OPZDIMX	ADD.W	D2,D3		; D2 <-- position dans l'cran en X	DIV.WU	D4,(A6)+OPZNBX	LOAD.W	D3,D4	MUL.WU	D3,(A6)+OPZDIMY	; D3 <-- position dans l'image en Y	SWAP.W	D3	SWAP.W	D4	MUL.WU	D4,(A6)+OPZDIMX	LOAD.W	D3,D4		; D3 <-- position dans l'image en X	LOAD.L	D4,(A6)+OPZDIMY	ADD.W	D2,#2	SWAP.W	D2	ADD.W	D2,#2	SWAP.W	D2	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#3	SWAP.W	D4	SUB.W	D4,#3	SWAP.W	D4	LOAD.L	A4,(A6)+OPZPIC	; A4 <-- ^image code	LOAD.L	A3,(A6)+OPZPID	; A3 <-- ^image dcode	CALL	IMAGEAFF	; affiche une pice du puzzle	LIB	?COLORPOP	LOAD.L	D3,D2	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	CALL	INVMODE	LIB	?DRRECT	POPM.L	D1..D4,A3,A4	RET;--------\\; PZKILL  >;========/; Termine un puzzle.; in	-; out	-; mod	D7.WPZKILL:	PUSHM.L	A3,A4	LOAD.L	A4,(A6)+OPZPIC	; A4 <-- ^image code	LOAD.L	A3,(A6)+OPZPID	; A3 <-- ^image dcode	CALL	IMAGECODE	; libre l'image dcode	POPM.L	A3,A4	RET	.END