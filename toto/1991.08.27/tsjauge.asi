	.SBTTL	TSJAUGE.ASI; Gestion des jauges; ------------------;--------\\; JGGAGNE >;========/; Victoire, on a gagn.; in	-; out	-; mod	D7.WJGGAGNE:	PUSHM.L	D3,D4,A2,A3	LOAD.W	(A6)+OSOUND,#TMUSGAGNE	LOAD.L	A2,(A6)+OJGDAP	; A2 <-- ^descripteur ascenseur plein	LOAD.L	A3,#R16"TABLE$LOOP$:	LOAD.W	D3,(A3+)	JUMP',EQ DOWN$	LOAD.L	D4,(A2)+OMIPOS	; D4 <-- position	CALL	ICOMMOVE	LOAD.W	D4,#5	NTREL	?DELMS	JUMP	LOOP$DOWN$:	CALL	JGECTERM	; termine l'coulement de la jauge	LOAD.W	D3,#2	TEST.B	(A6)+OFLAGS:#BFTINFINI	JUMP',BS INFINI$	CLR.L	D3	LOAD.W	D3,(A6)+OJGECP	DIV.WU	D3,#100/5	; D3 <-- 0..4INFINI$:	LOAD.W	(A6)+OTEST1,D3	CALL	JGGAGNE2	; action ...	POPM.L	D3,D4,A2,A3	RETTABLE$:	.W	44,29,44,29,44,29,44,29,44,29	.W	44,29,44,29,44,29,44,29,44,29	.W	0;---------\\; JGGAGNE2 >;=========/; Action aprs avoir gagn.; in	-; out	-; mod	D7.WJGGAGNE2:	PUSHM.L	D3,D4,A4	COMP.W	(A6)+OTEST1,#2	JUMP',HS SAUTE$	TEST.B	(A6)+OFLAGS:#BFSON	JUMP',BC SAUTE$	CLR.W	D3	LOAD.W	D4,#10	LOAD.L	A4,#(A6)+OHAEXC	CALL	EXHAZARD	; D4 <-- action exceptionnelle	TEST.W	D4	JUMP',NE SAUTE$	LOAD.L	A4,#R16"TAMRASC	CALL	ICOMALL		; revient de l'ascenseur ...	CLR.W	D3	LOAD.W	D4,#9	LOAD.L	A4,#(A6)+OHAMUS	CALL	EXHAZARD	; D4 <-- musique (0..8)	LOAD.W	(A6)+OTEST1,D4	LOAD.L	A4,#R16"TAMMUSIC	CALL	ICOMALL		; joue une p'tite musique ...	JUMP'	EXIT$SAUTE$:	CLR.W	D3	LOAD.W	D4,#10	LOAD.L	A4,#(A6)+OHAEXC	CALL	EXHAZARD	; D4 <-- action exceptionnelle	LOAD.W	(A6)+OTEST2,D4	LOAD.L	A4,#R16"TAMRASCG	CALL	ICOMALL		; revient de l'ascenseur ...EXIT$:	POPM.L	D3,D4,A4	RET;--------\\; JGFAUX  >;========/; C'est faux.; in	-; out	-; mod	D7.WJGFAUX:	PUSHM.L	D3,D4,A2,A3	LOAD.W	(A6)+OSOUND,#TMUSFAUX	LOAD.L	A2,(A6)+OJGDAP	; A2 <-- ^descripteur ascenseur plein	LOAD.L	A3,#R16"TABLE$LOOP$:	LOAD.W	D3,(A3+)	JUMP',EQ EXIT$	LOAD.L	D4,(A2)+OMIPOS	; D4 <-- position	CALL	ICOMMOVE	LOAD.W	D4,#5	NTREL	?SETTIM	LIB	?GETKEY	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE LOOP$	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	LIB	?WRKEY	LOAD.W	D3,#45	LOAD.L	D4,(A2)+OMIPOS	; D4 <-- position	CALL	ICOMMOVEEXIT$:	LOAD.W	(A6)+OJGICO,#45	; OJGICO <-- pas content	POPM.L	D3,D4,A2,A3	RETTABLE$:	.W	46,45,47,45	.W	46,45,47,45	.W	46,45,47,45	.W	46,45,47,45	.W	46,45,47,45	.W	0;--------\\; JGJUSTE >;========/; C'est juste.; in	-; out	-; mod	D7.WJGJUSTE:	PUSHM.L	D3,D4,A2,A3	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	LOAD.L	A2,(A6)+OJGDAP	; A2 <-- ^descripteur ascenseur plein	LOAD.L	A3,#R16"TABLE$LOOP$:	LOAD.W	D3,(A3+)	JUMP',EQ EXIT$	LOAD.L	D4,(A2)+OMIPOS	; D4 <-- position	CALL	ICOMMOVE	LOAD.W	D4,#5	NTREL	?SETTIM	LIB	?GETKEY	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE LOOP$	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	LIB	?WRKEY	LOAD.W	D3,#29	LOAD.L	D4,(A2)+OMIPOS	; D4 <-- position	CALL	ICOMMOVEEXIT$:	LOAD.W	(A6)+OJGICO,#29	; OJGICO <-- content	POPM.L	D3,D4,A2,A3	RETTABLE$:	.W	44,29,44,29	.W	44,29,44,29	.W	44,29,44,29	.W	0;---------\\; JGECOULE >;=========/; Ecoule le temps avec la jauge.; in	-; out	D7.W	NE si temps coul; mod	D7.WJGECOULE:	PUSH.L	D3	CLR.W	D7	TEST.B	(A6)+OFLAGS:#BFTINFINI	JUMP',BS EXIT$	LOAD.L	D3,(A6)+OTIME	SUB.L	D3,(A6)+OJGECT	; D3 <-- temps coul depuis le dbut	MUL.WU	D3,#2	TEST.B	(A6)+OFLAGS:#BFTCOURT	JUMP',BC NORM$	MUL.WU	D3,#3NORM$:	DIV.WU	D3,(A6)+OJGECD	COMP.W	D3,(A6)+OJGECP	JUMP',EQ NOMOVE$	LOAD.W	(A6)+OJGECP,D3	CALL	JGEMPTY		; descend totoNOMOVE$:	CLR.W	D7	COMP.W	D3,#100	JUMP',LO EXIT$	INC.W	D7EXIT$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; JGECTERM >;=========/; Termine l'coulement de la jauge.; in	-; out	-; mod	D7.WJGECTERM:	PUSH.L	D3	LOAD.W	D3,(A6)+OJGECP	COMP.W	D3,#100	JUMP',HS EXIT$LOOP$:	COMP.W	D3,#100	JUMP',HS DOWN$	ADD.W	D3,#2	CALL	JGEMPTY		; descend toto	JUMP	LOOP$DOWN$:	CALL	JGEMPTY		; descend toto	LOAD.W	(A6)+OSOUND,#TMUSTOMBEEXIT$:	POP.L	D3	RET;--------\\; JGEMPTY >;========/; Vide la jauge (niveau 0 = plein, niveau 100 = vide).; in	D3.W	niveau (0..100); out	D7.W	erreur; mod	D7.WJGEMPTY:	PUSHM.L	D1..D4,A2	LOAD.L	A2,(A6)+OJGDAP	; A2 <-- ^descripteur ascenseur plein	COMP.W	D3,#100	JUMP',LS NO100$	LOAD.W	D3,#100NO100$:	LOAD.W	D2,D3	LOAD.W	D4,D3	MUL.WU	D4,#LYWDO-4-LYICO-4	DIV.WU	D4,#100	ADD.W	D4,#4	SWAP.W	D4	LOAD.W	D4,(A2)+OMIPOS+2	LOAD.W	D3,(A6)+OJGICO	COMP.W	D2,#90		; arrive sur 1 (dernire graduation) ?	JUMP',LO MOVE$		; non => MOVE$	LOAD.W	D3,#45		; D3 <-- pas contentMOVE$:	CALL	ICOMMOVE	; descend l'ascenseur	COMP.W	D2,#100		; est-on tout en bas ?	JUMP',NE EXIT$		; non => EXIT$				; oui =>	CALL	ICOMCLEAR	; enlve l'icne	CALL	ICOMCLOSE	; ferme l'ascenseur plein	CLR.L	(A6)+OJGDAP	LOAD.L	A2,(A6)+OJGDAV	; A2 <-- ^descripteur ascenseur vide	LOAD.L	D4,(A2)+OMIPOS	CALL	ICOMCLOSE	CALL	ICOMOPEN	LOAD.L	(A6)+OJGDAV,A2	LOAD.W	D3,#28	CALL	ICOMMOVE	; dessine l'ascenseur vide	LOAD.L	A2,(A6)+OOBJ1+OOCHIM ; A2 <-- ^descripteur objet toto	LOAD.L	D4,(A2)+OMIPOS	CALL	ICOMCLOSE	CALL	ICOMOPEN	LOAD.L	(A6)+OOBJ1+OOCHIM,A2EXIT$:	POPM.L	D1..D4,A2	RET;-----------\\; JGBAGUETTE >;===========/; Donne un coup de baguette magique.; in	-; out	-; mod	D7.WJGBAGUETTE:	PUSHM.L	D3,D4,A2,A3	LOAD.L	A2,(A6)+OJGDAP	; A2 <-- ^descripteur ascenseur plein	LOAD.W	(A6)+OSOUND,#TMUSMAGIC	LOAD.L	A3,#R16"TABLE$LOOP$:	LOAD.W	D3,(A3+)	JUMP',EQ EXIT$	LOAD.L	D4,(A2)+OMIPOS	; D4 <-- position	CALL	ICOMMOVE	LOAD.W	D4,#5	NTREL	?DELMS	JUMP	LOOP$EXIT$:	POPM.L	D3,D4,A2,A3	RETTABLE$:	.W	30,30,30,31,31,30,31,30,31,30,30,31,30,30,29	.W	0;--------\\; JGFULL  >;========/; Monte l'ascenseur (avec toto) juste tout en haut.; in	-; out	D7.W	erreur; mod	D7.WJGFULL:	PUSHM.L	D1..D4,A2..A5	LOAD.L	A3,(A6)+OJGDAV	; A3 <-- ^descripteur ascenseur vide	LOAD.L	D4,(A3)+OMIPOS	CALL	ICOMOPEN	; A2 <-- canal ascenseur plein	JUMP,NE EXIT$	LOAD.L	(A6)+OJGDAP,A2	PUSHM.L	A2,A3	LOAD.L	A3,#(A3)+OMIMAT	LOAD.L	A2,#(A2)+OMIMAT	CLR.W	D3	LOAD.B	D3,(A0)+ODFCNP	; D3 <-- nb de bits/pixel (1,4)	MUL.WU	D3,#((LXICO*LYICO)/8)/4	DEC.W	D3XFER$:	LOAD.L	(A2+),(A3+)	; bitmap original = celui sans ascenseur !	DECJ.W,NMO D3,XFER$	POPM.L	A2,A3	LOAD.W	D3,#29	CALL	ICOMMOVE	; dessine toto sur l'ascenseur	CLR.W	D3	LOAD.W	D4,#30	LOAD.L	A4,#(A6)+OHAJGP	CALL	EXHAZARD	COMP.W	D4,#2		; panne d'ascenseur ?	JUMP',HS PEND$		; non => PEND$	LOAD.W	(A6)+OTEST1,D4	LOAD.L	A4,#R16"TAMPANNE	LOAD.L	A5,#(A6)+OOBJ2	LOAD.L	(A5)+OOLPOS,(A3)+OMIPOS	LOAD.L	(A5)+OOCHIM,A2	CALL	ICOMBEGINPLOOP$:	CALL	ICOMNEXT	JUMP,EQ PLOOP$PEND$:	LOAD.W	(A6)+OSOUND,#TMUSASCMONTE	LOAD.L	D4,(A3)+OMIPOS	LOAD.W	D3,#29	LOAD.W	D2,#((LYWDO-4-LYICO-4)/4)-1UP$:	CALL	ICOMMOVE	; monte l'ascenseur	SWAP.W	D4	SUB.W	D4,#4	SWAP.W	D4	DECJ.W,NMO D2,UP$	LOAD.W	D3,#44	CALL	ICOMMOVE	; p'tit saut	PUSH.W	D4	LOAD.W	D4,#8	NTREL	?DELMS		; attend un p'tit peu ...	POP.W	D4	LOAD.W	(A6)+OSOUND,#TMUSTOMBE	LOAD.W	D3,#29	CALL	ICOMMOVE	; fin du p'tit saut	LOAD.W	D4,#30	NTREL	?DELMS		; attend un p'tit peu ...	LOAD.W	(A6)+OJGICO,#29	; OJGICO <-- content	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; JGDRAW  >;========/; Dessine une jauge pleine.; in	-; out	D7.W	erreur; mod	D7.WJGDRAW:	PUSHM.L	D1..D4,A2,A5	LOAD.L	A2,(A6)+OJGDAP	; A2 <-- ^descripteur ascenseur plein	CALL	ICOMCLOSE	; ferme l'ascenseur plein	CLR.L	(A6)+OJGDAP	LOAD.L	A2,(A6)+OJGDAV	; A2 <-- ^descripteur ascenseur vide	CALL	ICOMCLOSE	; ferme l'ascenseur vide	CLR.L	(A6)+OJGDAV	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,#H'10000*0+(LXWDO-5-LGREGLE)	LOAD.L	D4,#H'10000*LYWDO+LGREGLE	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	PUSH.L	D3	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POP.L	D3	PUSH.L	D3	ADD.W	D3,#LGREGLE	LIB	?DRSEG	POP.L	D3	LOAD.L	A5,#(A6)+OPZREG	CLR.B	(A5)+ORGVMI	INC.W	D3	LOAD.W	(A5)+ORGVPO+2,D3	LOAD.W	(A5)+ORGVPO+0,#4+LYICO	LOAD.W	D4,#LYWDO-4-LYICO-4	LOAD.W	(A5)+ORGVLG,D4	MUL.WU	D4,#64	DIV.WU	D4,#100	DEC.W	D4	LOAD.W	(A5)+ORGVPA,D4	SCROLL_	RUPDATE		; dessine une rgle	TEST.B	(A6)+OINV	JUMP',F NOINV$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D3,#H'10000*0+(LXWDO-5-LGREGLE)	LOAD.L	D4,#H'10000*LYWDO+(LGREGLE+1)	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse toute la jaugeNOINV$:	LOAD.W	D4,#LYWDO-4-LYICO	SWAP.W	D4	LOAD.W	D4,(A5)+ORGVPO+2	SUB.W	D4,#LXICO-LGREGLE-5	CALL	ICOMOPEN	; A2 <-- canal	JUMP',NE EXIT$	LOAD.L	(A6)+OJGDAV,A2	LOAD.W	D3,#28	CALL	ICOMMOVE	; dessine l'ascenseur vide	CLR.W	D7EXIT$:	POPM.L	D1..D4,A2,A5	RET	.END