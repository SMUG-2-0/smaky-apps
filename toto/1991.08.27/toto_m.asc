	.TITLE	TOTO_M.ASC;	--------------------------------------;		(C) 1988 - Daniel Roux;	--------------------------------------;	Date		Amliorations; --------------------------------------------------------------------------; 1.6	22.02.91	TOTO_M1.COLOR dfinitif, ok avec PICASSO.CODE; 1.5	23.11.90	TOTO_M1.COLOR sans CLUT aprs l'en-tte !; 1.4	12.11.90	n'efface plus une bande blanche en bas;			sons mieux grs avec nouveau pilote #AUDIO:; 1.3	07.11.90	parole avec fichiers .AUDIO cods; 1.2	22.10.90	version couleur pour SMAKY-300;			parole avec fichiers .SOUND non cods; 1.1	; 1.0		.PROC	M680002	.REF	SMAKY	.REF	MODULES	.REF	AUDIO	.REF	TCOLOR;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;GRA_CRASTER = H'A899		; raster-op couleurBSRCCOUL = 11BDSTCOUL = 12SMAKY300 = 7;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.REV	1,6	.CODE	800,10,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"DANIEL	=	0		; 1 => debugIFSMILE	=	0		; 1 => assemblage pour SMILE2; Dfinition de l'entte d'un gnrateur de caractres; ----------------------------------------------------OGCH1	=	256+128*1	; 128 x h1OGCH2	=	256+128*2	; 128 x h2OGCMAT	=	256+128*3	; 128 x matrix; Constantes; ----------LHIST	=	100		; lg max d'une histoireLBUFILE	=	50		; lg max nom de fichierKEYDBOX	=	H'7E00		; "touche" trs spciale !; Caractres standard; -------------------LXICO	=	80LYICO	=	80GCTXF	=	'N		; fonte (N)GCTXS	=	'R!2^7		; style/chasse (RF)GCTXT	=	14		; taille (14) normaleGCTXTP	=	09		; taille (09) petite; Icnes des ITP80; ----------------GCICF	=	'I		; fonte (I)GCICS	=	'T		; style/chasse (TP)GCICT	=	80		; taille (80)ICOASCV	=	1		; ascenseur videICOASCT	=	2		; ascenseur avec totoICOARRH	=	3		; toto assis en hautICOARRB	=	4		; toto assis en basICOSOLEIL =	43		; soleilICOLUNE	=	44		; luneICOBULLE=	48		; bulle pour textesICOSLEEP=	65		; toto dortICOVIDE	=	127		; icne videBICOMASK =	7		; icne de fondBICODEMIH =	8		; icne dans la moiti suprieureBICODEMIB =	9		; icne dans la moiti infrieureBICOSYMB =	10		; icne symbole dans ITP81BICOCOUL =	11		; icne symbole dans ITP90; Positions dans l'image; ----------------------LXWDO	=	640		; largeur de l'cranLYWDO	=	340		; hauteur de l'cranPARRHDX	=	426		; position  l'arrt en haut  droite (assis)PARRHDY	=	98		; position  l'arrt en haut  droite (assis)PARRHGX	=	189		; position  l'arrt en haut  gauche (debout)PARRHGY	=	98		; position  l'arrt en haut  gauche (debout)PARRBDX	=	324		; position  l'arrt en bas  droite (assis)PARRBDY	=	256		; position  l'arrt en bas  droite (assis)PARRBGX	=	189		; position  l'arrt en bas  gauche (debout)PARRBGY	=	213		; position  l'arrt en bas  gauche (debout)PARRLX	=	506		; position au litPARRLY	=	75		; position au litPASCHX	=	189		; position ascenseur en hautPASCHY	=	109		; position ascenseur en hautPASCBX	=	189		; position ascenseur en basPASCBY	=	224		; position ascenseur en basPSOLEX	=	530		; position soleilPSOLEY	=	0		; position soleilPLUNEX	=	0		; position lunePLUNEY	=	0		; position lunePECRANX	=	125		; position de l'cranPECRANY	=	82		; position de l'cranLECRANX	=	100		; largeur de l'cranLECRANY	=	95		; hauteur de l'cranPVARIX	=	506		; position varicelle couchPVARIY	=	75		; position varicelle couchLIMITX	=	300		; limite pour dterminer si gauche/droiteLIMITY	=	150		; limite pour dterminer si haut/basPTEXTX	=	29		; position pour textePTEXTY	=	305		; position pour texteLTEXTX	=	144		; largeur pour texteLTEXTY	=	23		; hauteur pour textePDESSX	=	353		; crayon: position pour dessiner au murPDESSY	=	77		; crayon: position pour dessiner au mur; Couleurs; --------COLOR_BLANC =	0COLOR_BRUN  =	1COLOR_FOND2 =	2COLOR_JAUNE =	3COLOR_FOND3 =	4COLOR_TOTO  =	5COLOR_FOND4 =	6COLOR_ROUGE =	7COLOR_FOND5 =	8COLOR_FOND1 =	9COLOR_FOND6 =	10COLOR_VERT  =	11COLOR_FOND7 =	12COLOR_FOND8 =	13COLOR_ROSE  =	14COLOR_NOIR  =	15; En-tte d'un fichier .IMAGE/.COLOR; ----------------------------------	.LOC	0	.BLKB	1		; OIMTYP: H'82	.BLKB	1		; OIMCOD: 0 ou 4	.BLKB	1		; OIMBIP: 4 bits/pixel	.BLKB	1		; OIMDIR: 2	.BLKB	2		; OIMDLX: largeur (multiple de 16)	.BLKB	2		; OIMDLY: hauteur	.BLKB	4		; OIMNBB: longueur du dataOIMSIZ:	.BLKB	2		; taille d'un pixel (4)OIMCNT:	.BLKB	2		; nb de pixels (1)OIMLGC:	.BLKB	4		; longueur de la CLUT	.BLKB	12		; rserve				; LGHIMA: longueur de l'en-tte; Musiques audio; --------------MA_YOUPIE =	100MA_AIE =	101MA_MIAM =	102MA_POUPEE =	103MA_GC	 =	104MA_TAMBOUR =	105MA_SYMB =	106MA_TOM =	107MA_COUP =	108MA_CLOCHE =	109MA_TUU =	110MA_HUU =	111MA_CLAP =	112MA_TOC =	113MA_TIC =	114MA_MARCHE =	115MA_FOLK =	116MA_SWING =	117MA_SAMBA =	118; Objets fixes; ------------BFOSOLEIL =	0		; soleilBFOLUNE	=	1		; luneBFOSLEEP=	2		; toto dort; Modes dans les tables; ---------------------TMBEGIN	=	-1		; dbut absolu      [y,x,del]TMLINK	=	-2		; suite de la table [ad]TMPLAN	=	-3		; plan o dessiner  [0=derrire, 1=devant]TMFLASH	=	-4		; clair            [t1,t2]TMDEL	=	-5		; nouveaux dlais   [dlai]TMLINOB	=	-6		; dessine une ligne [y,x,dy,dx,t]TMGETOB	=	-7		; prend un objet    [y,x,dy,dx]TMPUTOB	=	-8		; repose un objet   [y,x,dy,dx]TMSOUND	=	-9		; bruitage          [TMUSxxxx]TMTEXT	=	-10		; texte             [.ASCIZ "xyz" puis .EVEN]TMSKIPNE=	-11		; saut cond. si NE  [var,inf,sup,ad]TMSKIPEQ=	-12		; saut cond. si EQ  [var,inf,sup,ad]TMICOOB	=	-13		; icne             [y,x,chair,fond]TMCOLOR	=	-14		; couleur           [c,n,d,RGB,RGB]; Descripteur d'un objet anim; ----------------------------	.LOC	0OOICON:	.BLKB	2		; code de l'icneOOLPOS:	.BLKB	4		; dernire positionOONPOS:	.BLKB	4		; nouvelle positionOOMPTA:	.BLKB	4		; ^lment suivantOOMPTB:	.BLKB	4		; ^lment prcdentOOMCTN:	.BLKB	2		; compteur nb de dlacementsOOMCTI:	.BLKB	2		; compteur nb d'icneOOMNBI:	.BLKB	2		; nb max d'icnesOOMDEL:	.BLKB	2		; dlai (vitesse)LOBJ:; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOMACHINE:.BLKB	2		; type de la machine (SMAKYxxx)OINV:	.BLKB	1		; 1 => fond de l'cran blanc	.EVENOPDDIS:	.BLKB	4		; ^descripteur de la fentreOSDDIS:	.BLKB	LGDIS7		; copie du descripteur de la fentreOPGICO:	.BLKB	4		; ^gencar des icnes (ITP80)OPFICO:	.BLKB	4		; ^gencar des icnes (fonds calculs)OPSICO:	.BLKB	4		; ^gencar des icnes (ITP81)OPCICO:	.BLKB	4		; ^gencar des icnes (ITP90)OADRASTER:	.BLKB	4	;  adresse de GRA_RASTEROADCRASTER:	.BLKB	4	;  adresse de GRA_CRASTEROADMATRIX:	.BLKB	4	;  adresse de GRA_MATRIXOADDOT:		.BLKB	4	;  adresse de GRA_DOTOADTRAME:	.BLKB	4	;  adresse de GRA_TRAMEOADLINE:	.BLKB	4	;  adresse de GRA_LINEOADELLIPSE:	.BLKB	4	;  adresse de GRA_ELLIPSEOADFILLO:	.BLKB	4	;  adresse de GRA_FILLOOADFILLC:	.BLKB	4	;  adresse de GRA_FILLCOADCLEAR:	.BLKB	4	;  adresse de GRA_CLEAROADSET:		.BLKB	4	;  adresse de GRA_SETOADINV:		.BLKB	4	;  adresse de GRA_INVOADQXDOT:	.BLKB	4	;  adresse de GRA_QXDOTOBUDIS:	.BLKB	200		; buffer write-displayOBULUT:	.BLKB	1000		; buffer lutin sourisOPIFINI:.BLKB	4		; ^image principale du fond initialeOPIFFIX:.BLKB	4		; ^image principale du fond avec objets fixesOPIMAFI:.BLKB	4		; ^image de fond du masque (n/b)OPIMAF:	.BLKB	4		; ^image de fond du masqueOPIMAC:	.BLKB	4		; ^image de chair du masqueOPITEMP:.BLKB	4		; ^image temporaireOPSTEMP:.BLKB	4		; sauvetage de OPITEMPODIMA:	.BLKB	4		; dimensions imageOOIMA:	.BLKB	4		; origine coin sup/gauche imageOSNDP1:	.BLKB	4		; ^data de TOTO_M1.AUDIOOSNDP2:	.BLKB	4		; ^data de TOTO_M2.AUDIOOOBJET:	.BLKB	LOBJ		; objet totoOOBJSL:	.BLKB	LOBJ		; objet soleil/luneOFIXOB:	.BLKB	4		; objets fixesOFIXTR:	.BLKB	8		; ciel: trame fixeOFIXCS:	.BLKB	2		; ciel: couleur setOFIXCC:	.BLKB	2		; ciel: couleur clearOFIXCX:	.BLKB	2		; ciel: couleur pour FIXCIELOLETTRE:.BLKB	2		; lettre choisieOLASTLE:.BLKB	2		; dernire lettre choisieOERREUR:.BLKB	2		; lettre privilgie si erreurOFLAGS:	.BLKB	1		; flags divers BFMAJUS  =  0			;  majuscules BFMINUS  =  1			;  minuscules BFSON    =  2			;  son BFSOURIS =  3			;  sourisOPLAY:	.BLKB	1		; 1 => lit une histoire (fichier .TOTO)OABORT:	.BLKB	1		; 1 => abort des processus filsOSTEP:	.BLKB	1		; 1 => mode "pas  pas"OCLIC:	.BLKB	1		; 1 => avec un clic de la sourisOQUICK:	.BLKB	1		; 1 =>  toute vitesseOPLAN:	.BLKB	1		; 1 => devantOECRAN:	.BLKB	1		; 1 => cran droulOASC:	.BLKB	1		; flags pour l'ascenseur BASCH	=  0			;  ascenseur en haut BASCB	=  1			;  ascenseur en basOROBIN:	.BLKB	1		; 1 => le bain est coul	.EVENOOMENU:	.BLKB	2		; soft-keys: anciens bits BMNNOHIS =  0			;  pas d'histoire BMNRACON =  1			;  raconteOSOUND:	.BLKB	2		; son  effectuer par le processus filsOPGPOS:	.BLKB	4		; PUTOB/GETOB: positionOPGDIM:	.BLKB	4		; PUTOB/GETOB: dimensionsOHAASB:	.BLKB	10		; tirage exclusif: tombe dans la cage d'ascenseurOHAASH:	.BLKB	10		; tirage exclusif: ascenseur en panneOHAACR:	.BLKB	4		; tirage exclusif: acrobatieOHACUI:	.BLKB	2		; tirage exclusif: cuireOHADES:	.BLKB	4		; tirage exclusif: dessinOHAECR:	.BLKB	4		; tirage exclusif: cranOHAELE:	.BLKB	16		; tirage exclusif: animaux ou objetsOHAFET:	.BLKB	2		; tirage exclusif: fteOHAHI1:	.BLKB	6		; tirage exclusif: histoire (livre)OHAHI2:	.BLKB	6		; tirage exclusif: histoire (musique)OHAILL:	.BLKB	4		; tirage exclusif: illusionOHAROB:	.BLKB	2		; tirage exclusif: robinetOHAXYL:	.BLKB	4		; tirage exclusif: xylophoneOHATST:	.BLKB	2		; variable pour testsOHATST2:.BLKB	2		; variable pour testsOHAZA:	.BLKB	8		; registre 63 bits pour gnrateur alatoireOPHIST:	.BLKB	2		; ^relatif dans OHISTOHIST:	.BLKB	LHIST		; histoireOBUFILE:.BLKB	LBUFILE		; nom de l'histoireOBUSND:	.BLKB	200000		; buffer audioLGVAR:; Programme principal; -------------------	.LOC	0ADCODE:	JUMP	STARTNMDBOX:	.ASCIZ	"DBOX"NMLIST:	.ASCIZ	"LIST"NMIMA0:	.ASCIZ	"TOTO_M.IMAGE"NMIMA1:	.ASCIZ	"TOTO_M1.IMAGE"NMCOL1:	.ASCIZ	"TOTO_M1.COLOR"NMIMA2:	.ASCIZ	"TOTO_M2.IMAGE"NMSND1:	.ASCIZ	"TOTO_M1.AUDIO"NMSND2:	.ASCIZ	"TOTO_M2.AUDIO"	.EVENSTART:	.IF	~IFSMILE	LIB	?OPELIB	.ENDIF	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE ERFAT	GESMEM	?CLEARMEM	; met toutes les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT		; oui => ERFAT	COMP.W	D4,#H'100*5+4	; est-ce au moins 5.4 ?	JUMP,LO ERFAT		; non => ERFAT	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>;	CLR.B	(A6)+OINV	TEST.B	(A0)+ODFMOD:#BFBLANC	JUMP',BC 15$	SET.B	(A6)+OINV	; le fond de l'cran est blanc15$:	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	AND.W	D4,#H'FF	LOAD.W	(A6)+OMACHINE,D4	LOAD.B	D4,#2^BFMINUS!2^BFSON!2^BFSOURIS	COMP.W	(A6)+OMACHINE,#SMAKY324	JUMP',NE 20$	TCLR.L	D4:#BFSON20$:	LOAD.B	(A6)+OFLAGS,D4	LOAD.W	D4,#LYWDO	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,D4	SR.W	D3,#1	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,#LXWDO	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,D4	SR.W	D3,#1	LOAD.L	(A6)+OOIMA,D3	LIB	?CREWDO		; cre swdo (utile si grand cran)	LIB	?USEWDO	LIB	?AFTIM	.B	NOCURS		; pas de curseur !	.B	NOEFLI		; pas de EFLI automatique	.B	TRUNC		; tronque les lignes trop longues	.B	0	.EVEN	LOAD.W	D3,#3	LIB	?MOUSE		; souris par le clavier	CALL	CCMO		; enlve la souris	CALL	MMOUSE		; remet la souris au milieu de la fentre	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADRASTER,A3	LOAD.W	D3,#GRA_CRASTER	LIB_	GETAD	LOAD.L	(A6)+OADCRASTER,A3	LOAD.W	D3,#GRA_MATRIX	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADMATRIX,A3	LOAD.W	D3,#GRA_DOT	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADDOT,A3	LOAD.W	D3,#GRA_TRAME	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADTRAME,A3	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADLINE,A3	LOAD.W	D3,#GRA_ELLIPSE	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADELLIPSE,A3	LOAD.W	D3,#GRA_FILLO	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADFILLO,A3	LOAD.W	D3,#GRA_FILLC	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADFILLC,A3	LOAD.W	D3,#GRA_CLEAR	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADCLEAR,A3	LOAD.W	D3,#GRA_SET	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADSET,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADINV,A3	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADQXDOT,A3;;?	LOAD.L	A3,#R16"TCDEF;;?	CALL	DRCOLORTABLE	; initialise les fausses couleurs	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE NOIMA$		; oui => NOIMA$	LOAD.L	A3,#R16"NMIMA0	CALL	_AFIMAGE	; affiche l'image gnrique, si pas dj fait	JUMP,NE	ERFATNOIMA$:	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHLIST,D1	COMP.W	(A6)+OMACHINE,#SMAKY300	JUMP',NE NOSOUND$	LOAD.L	A3,#R16"NMSND1	CALL	_SNDREAD	; lit TOTO_M1.AUDIO	JUMP',NE NOSND1$	LOAD.L	(A6)+OSNDP1,A4NOSND1$:	LOAD.L	A3,#R16"NMSND2	CALL	_SNDREAD	; lit TOTO_M2.AUDIO	JUMP',NE NOSOUND$	LOAD.L	(A6)+OSNDP2,A4NOSOUND$:	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_BLANC	LIB	?AFTIM	.B	LOADGC		; charge les caractres standards	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	LOADGC		; charge les caractres standards	.B	GCTXF	.B	GCTXS	.B	GCTXTP	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	LOADGC		; charge les icnes ITP80	.B	GCICF	.B	GCICS	.B	GCICT	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	USEGC		; utilise les icnes ITP80	.B	GCICF	.B	GCICS	.B	GCICT	.B	0	.EVEN	LOAD.L	(A6)+OPGICO,(A0)+ODFPGC	LIB	?AFTIM	.B	LOADGC		; charge les icnes ITP81	.B	GCICF	.B	GCICS	.B	GCICT+1	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	USEGC		; utilise les icnes ITP81	.B	GCICF	.B	GCICS	.B	GCICT+1	.B	0	.EVEN	LOAD.L	(A6)+OPSICO,(A0)+ODFPGC	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOITP90$	LIB	?AFTIM	.B	LOADGC		; charge les icnes ITP90	.B	GCICF	.B	GCICS	.B	GCICT+10	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	USEGC		; utilise les icnes ITP90	.B	GCICF	.B	GCICS	.B	GCICT+10	.B	0	.EVEN	LOAD.L	(A6)+OPCICO,(A0)+ODFPGCNOITP90$:	LIB	?AFTIM	.B	USEGC		; utilise les caractres standard	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	CALL	CCMO		; enlve la souris	CALL	CALCFOND	; calcule le gencar des fonds	JUMP,NE ERFAT	NTREL	?GETPRIO	; D4 <-- priorit de START	DEC.B	D4		; D4 <-- fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP,NE ERFAT	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE IMA1C$		; oui => IMA1C$	LOAD.L	A3,#R16"NMIMA1	CALL	_LOADIMAGE	; charge l'image de fond initiale	JUMP,NE	ERFAT	LOAD.L	(A6)+OPIFINI,A4	LOAD.L	(A6)+ODIMA,D4	JUMP'	IMA2$IMA1C$:	LOAD.L	A3,#R16"NMCOL1	CALL	_LOADCOLOR	; charge l'image de fond initiale en couleur	JUMP,NE	ERFAT	LOAD.L	(A6)+OPIFINI,A4	LOAD.L	(A6)+ODIMA,D4IMA2$:	LOAD.L	A3,#R16"NMIMA2	CALL	_LOADIMAGE	; charge l'image de masque	JUMP,NE	ERFAT	LOAD.L	(A6)+OPIMAFI,A4	CALL	_CNBCIMAGE	; converti l'image en couleurs	JUMP,NE	ERFAT	LOAD.L	(A6)+OPIMAF,A4	LOAD.L	D3,D4	SWAP.W	D3	SR.W	D4,#3	MUL.WU	D4,D3	CLR.W	D1	LOAD.B	D1,(A0)+ODFCNP	; D1 <-- nb de bits/pixel	MUL.WU	D4,D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour image temporaire	JUMP,NE ERFAT	LOAD.L	(A6)+OPITEMP,A4	GESMEM	?GETMEM		; demande mmoire pour image avec objets fixes	JUMP,NE ERFAT	LOAD.L	(A6)+OPIFFIX,A4	GESMEM	?GETMEM		; demande mmoire pour chair du masque	JUMP,NE ERFAT	LOAD.L	(A6)+OPIMAC,A4	LOAD.L	A2,(A6)+OPIFINI	LOAD.L	A3,(A6)+OPIMAF	SR.L	D4,#240$:	LOAD.L	D3,(A2+)	AND.L	D3,(A3+)	LOAD.L	(A4+),D3	DEC.L	D4	JUMP,NE 40$	CALL	LMOUSE		; souris = main	CALL	CCMO		; enlve la souris	CALL	MMOUSE		; remet la souris au milieu de la fentre	CALL	AFMENU		; affiche les soft-keys	LOAD.L	(A6)+OFIXTR+0,#H'11441144	LOAD.L	(A6)+OFIXTR+4,#H'11441144	LOAD.W	(A6)+OFIXCS,#COLOR_BLANC	LOAD.W	(A6)+OFIXCC,#COLOR_FOND1REFAIT:	CLR.W	(A6)+OERREUR	LIB	?GETWDO	LOAD.W	D6,D5	CLR.W	D5	LIB	?USEWDO	LOAD.L	D3,#-1	TEST.B	(A6)+OINV	JUMP',T	20$	CLR.L	D320$:	LOAD.L	D4,D3	CALL	_DRTRADEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LOAD.W	D2,#LOADDOT	CALL	_DRTRAME	; efface toute la fentre	LOAD.W	D5,D6	LIB	?USEWDO	LOAD.W	(A6)+OOBJET+OOLPOS+0,#LIMITY-1 ; toto en haut	LOAD.W	(A6)+OOBJET+OOLPOS+2,#LIMITX+1 ; toto  droite	CALL	FIXIMAGE	; gnre et affiche l'image fixe	CALL	_COUPSAC	; gnrateur alatoire: coup de sacLOOP:	CALL	MAJMENU		; mj. les soft-keys	TEST.B	(A6)+OPLAY	; raconte une histoire ?	JUMP',T	LOOPS		; oui => LOOPS	CALL	_SNDDONELOOPS:	CALL	GETCAR		; attend une touche ...LOOPK:	CLR.B	(A6)+OCLIC	; pas avec la sourisLOOPM:	TEST.W	D3	JUMP,EQ LOOPS	COMP.W	D3,#KEYMGR	JUMP,EQ LOOPS	COMP.W	D3,#KEYMMR	JUMP,EQ LOOPS	COMP.W	D3,#KEYMDR	JUMP,EQ LOOPS	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC	CALL	CCMO		; enlve la souris	TEST.B	(A6)+OCLIC	; avec un clic de la souris ?	JUMP',T	20$		; oui => 20$	LIB	?MINMAJ20$:	COMP.W	D3,#F0+SHIFT	JUMP,EQ FINI	COMP.W	D3,#F1	JUMP,EQ PREND	COMP.W	D3,#F1+SHIFT	JUMP,EQ PREND	COMP.W	D3,#F3	JUMP,EQ SAUVE	COMP.W	D3,#F3+SHIFT	JUMP,EQ SAUVE	COMP.W	D3,#F4	JUMP,EQ DEFHIST	COMP.W	D3,#F4+SHIFT	JUMP,EQ DEFHIST	COMP.W	D3,#F5	JUMP,EQ DEFHIST	COMP.W	D3,#F5+SHIFT	JUMP,EQ DEFHIST	COMP.W	D3,#F6	JUMP,EQ DEFHIST	COMP.W	D3,#F6+SHIFT	JUMP,EQ DEFHIST	COMP.W	D3,#F7	JUMP,EQ RACONTE	COMP.W	D3,#F7+SHIFT	JUMP,EQ RACONTE	COMP.W	D3,#F8	JUMP,EQ RACONTE	COMP.W	D3,#F8+SHIFT	JUMP,EQ RACONTE	COMP.W	D3,#F9	JUMP,EQ RACONTE	COMP.W	D3,#F9+SHIFT	JUMP,EQ RACONTE; ATTENTION: comparaison avec D3.L pour tenir compte du pseudo-code,; et interdire ainsi les clic avec la souris dans les soft-keys !	COMP.L	D3,#H'10000*14+F14+SHIFT	JUMP,EQ LISTE	COMP.L	D3,#H'10000*15+F15+SHIFT	JUMP,EQ CHOIX	.IF	DANIEL	COMP.W	D3,#H'100*(2^BPROGRA)+'S	JUMP,EQ STEP$	.ENDIF	LOAD.W	(A6)+OLASTLE,(A6)+OLETTRE	LOAD.W	(A6)+OLETTRE,D3	CALL	AFLETTRE	; affiche juste la lettre	COMP.W	D3,#'S	JUMP,EQ SOLEIL	TEST.B	(A6)+OFIXOB+3:#BFOSLEEP-0	JUMP,BS LUNEERR	COMP.W	D3,#'A	JUMP,EQ ACROBATIE	COMP.W	D3,#'B	JUMP,EQ BAIN	COMP.W	D3,#'C	JUMP,EQ CUIRE	COMP.W	D3,#'D	JUMP,EQ DESSIN	COMP.W	D3,#'E	JUMP,EQ ECRAN	COMP.W	D3,#'F	JUMP,EQ FETE	COMP.W	D3,#'G	JUMP,EQ GALETAS	COMP.W	D3,#'H	JUMP,EQ HISTOIRE	COMP.W	D3,#'I	JUMP,EQ ILLUSION	COMP.W	D3,#'J	JUMP,EQ JUMEAUX	COMP.W	D3,#'K	JUMP,EQ KANGOUROU	COMP.W	D3,#'L	JUMP,EQ LUNE	COMP.W	D3,#'M	JUMP,EQ MELASSE	COMP.W	D3,#'N	JUMP,EQ NAVIRE	COMP.W	D3,#'O	JUMP,EQ ORAGE	COMP.W	D3,#'P	JUMP,EQ POUPEE	COMP.W	D3,#'Q	JUMP,EQ QUEUE	COMP.W	D3,#'R	JUMP,EQ ROBINET	COMP.W	D3,#'T	JUMP,EQ TELE	COMP.W	D3,#'U	JUMP,EQ URGENT	COMP.W	D3,#'V	JUMP,EQ VARICELLE	COMP.W	D3,#'W	JUMP,EQ WAGON	COMP.W	D3,#'X	JUMP,EQ XYLOPHONE	COMP.W	D3,#'Y	JUMP,EQ YOGOURT	COMP.W	D3,#'Z	JUMP,EQ ZIGZAG	COMP.W	D3,#KEYDBOX+1	JUMP,EQ HAUTGAUCHE	COMP.W	D3,#KEYDBOX+2	JUMP,EQ HAUTDROITE	COMP.W	D3,#KEYDBOX+3	JUMP,EQ BASGAUCHE	COMP.W	D3,#KEYDBOX+4	JUMP,EQ BASDROITE	JUMP	LOOPSTEP$:	NOT.B	(A6)+OSTEP	JUMP	LOOPPREND:	CALL	DBOXPREND	; prend une histoire ...	JUMP	LOOPSAUVE:	TEST.B	(A6)+OOMENU+1:#BMNNOHIS-0	JUMP,BS LOOP	CALL	DBOXSAUVE	; sauve l'histoire ...	JUMP	LOOPDEFHIST:	CALL	DBOXHISTOIRE	; dite l'histoire ...	JUMP	LOOPRACONTE:	TEST.B	(A6)+OOMENU+1:#BMNNOHIS-0	JUMP,BS LOOP	CLR.W	(A6)+OPHIST	SET.B	(A6)+OPLAY	; hop, raconte	JUMP	LOOPLISTE:	CLR.W	(A6)+OERREUR	LOAD.B	D3,#SAVWDO	LIB	?AFCAR	JUMP,NE LOOP	LIB	?AFTIM	.B	EOP,CR,CR	.ASCII	"	A = acrobatie *     N = navire<CR>"	.ASCII	"	B = bain            O = orage<CR>"	.ASCII	"	C = cuire           P = poupe<CR>"	.ASCII	"	D = dessin    **    Q = queue<CR>"	.ASCII	"	E = cran     **    R = robinet<CR>"	.ASCII	"	F = fte            S = soleil<CR>"	.ASCII	"	G = galetas         T = tlvision<CR>"	.ASCII	"	H = histoire  **    U = urgent<CR>"	.ASCII	"	I = illusion  *     V = varicelle<CR>"	.ASCII	"	J = jumeaux         W = wagon<CR>"	.ASCII	"	K = kangourou       X = xylophone  *<CR>"	.ASCII	"	L = lune            Y = yogourt<CR>"	.ASCII	"	M = mlasse         Z = zigzag<CR>"	.B	CR	.ASCII	"	* = plusieurs actions diffrentes !"	.B	0	.EVEN	LIB	?GETCAR		; attend une touche ...	LOAD.B	D3,#GETWDO	LIB	?AFCAR	JUMP	LOOPCHOIX:	CLR.W	(A6)+OERREUR	CALL	DBOXCHOIX	; demande choix ...	COMP.W	D3,#CR	JUMP,NE LOOP	JUMP	REFAITCLIC:	TEST.B	(A6)+OFLAGS:#BFSOURIS	JUMP,BC LOOP	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP	LOAD.W	D3,D4		; D3 <-- X	SWAP.W	D4		; D4 <-- Y	ADD.W	D3,#2	ADD.W	D4,#7		; selon le doigt de la main !	LOAD.L	A4,#R16"TACLIC20$:	TEST.W	(A4)		; fin de la table ?	JUMP,EQ LOOP		; oui => LOOP	LOAD.W	D2,(A4)+2	COMP.W	D3,D2	JUMP',LO 80$	ADD.W	D2,(A4)+6	COMP.W	D3,D2	JUMP',HS 80$	LOAD.W	D2,#LYWDO-1	SUB.W	D2,(A4)+4	COMP.W	D4,D2	JUMP',LO 80$	ADD.W	D2,(A4)+8	COMP.W	D4,D2	JUMP',HS 80$	LOAD.W	D3,(A4)+0	; D3 <-- touche	SET.B	(A6)+OCLIC	; avec la souris	CLR.W	(A6)+OERREUR	JUMP	LOOPM80$:	ADD.L	A4,#10		; A4 <-- ^suivant dans table	JUMP	20$		;	  x,y   dx,dy	<-- donns par DESSIN4TACLIC:	.W	'A	507,41	63,39	.W	'B	48,205	127,44	.W	'C	88,106	47,60	.W	'D	388,173	28,14	; le crayon par-terre	.W	'E	99,273	162,23	.W	'E	231,249	16,44	.W	'F	38,100	48,53	.W	'G	190,336	257,61	.W	'H	417,109	58,21;	.W	'I	;	.W	'J	;	.W	'K		.W	'L	2,338	119,77;	.W	'M		.W	'N	477,131	58,22;	.W	'O		.W	'P	391,223	36,43	.W	'D	349,264	56,66	; tableau noir derrire la poupe !;	.W	'Q		.W	'R	37,245	30,38	.W	'S	501,334	129,77	.W	'T	421,84	48,38;	.W	'U		.W	'V	500,229	91,71;	.W	'W		.W	'X	282,244	63,82	.W	'Y	138,130	48,83;	.W	'Z		.W	KEYDBOX+1	196,205	65,52	.W	KEYDBOX+2	449,218	46,57	.W	KEYDBOX+3	196,82	65,52	.W	KEYDBOX+4	327,66	59,62	.W	0	;-------;	;   A	;	;-------;ACROBATIE:	CLR.W	(A6)+OERREUR	CALL	VAPOSBD		; va en bas  droite	LOAD.L	A4,#(A6)+OHAACR	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#3		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	(A6)+OHATST,D4	CALL	GMACROBATIE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   B	;	;-------;BAIN:	CLR.W	(A6)+OERREUR	CALL	VAPOSHG		; va en haut  gauche	CALL	GMBAINS	TEST.B	(A6)+OROBIN	; le bain est-il coul ?	JUMP',F	20$		; non => 20$	CLR.B	(A6)+OROBIN	; le bain sera utilis	CALL	GMBAINA20$:	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   C	;	;-------;CUIRE:	CLR.W	(A6)+OERREUR	CALL	VAPOSBG		; va en bas  gauche	LOAD.L	A4,#(A6)+OHACUI	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#2		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..1	LOAD.W	(A6)+OHATST,D4	CALL	GMCUIRE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   D	;	;-------;DESSIN:	LOAD.W	D3,(A6)+OERREUR	CLR.W	(A6)+OERREUR	COMP.W	D3,#'D	JUMP,EQ BASDROITE	CALL	VAPOSHD		; va en haut  droite	LOAD.L	A4,#(A6)+OHADES	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#3		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	(A6)+OHATST,D4	CALL	GMDESSIN	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   E	;	;-------;ECRAN:	CLR.W	(A6)+OERREUR	CALL	IFHAUT		; est-on bien en haut ?	JUMP,NE LOOPK		; non => LOOPK	CALL	VAPOSHD		; va en haut  droite	LOAD.L	A4,#(A6)+OHAECR	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#4		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..3	LOAD.W	(A6)+OHATST,D4	SET.B	(A6)+OECRAN	CALL	FIXIMAGE	; fixe l'ascenseur dans OPIFFIX	CALL	GMECRAN1	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; avance vers l'cran ...	LOAD.W	(A6)+OSOUND,#TMUSECRDOWN	LOAD.W	D3,#LECRANY/2020$:	LOAD.W	D4,#4	NTREL	?DELMS	CALL	ECRAN$		; droule l'cran	ADD.W	D3,#5	COMP.W	D3,#LECRANY	JUMP,LS 20$	LOAD.W	(A6)+OSOUND,#MA_COUP	LOAD.W	D4,#50	NTREL	?DELMS	LOAD.W	D3,(A6)+OLASTLE	COMP.W	D3,(A6)+OLETTRE	; dj utilis "E" juste avant ?	JUMP',EQ 25$		; oui => 25$	LOAD.W	(A6)+OSOUND,#TMUSECRSHOW	LOAD.W	D3,#0!2^BICOSYMB	CALL	ECICONE$	; montre les lettres "E" et "e"	LOAD.W	D4,#50*3	NTREL	?DELMS	LOAD.W	D3,#ICOVIDE	; D3 <-- icne	CALL	ECICONE$	; efface l'cran	LOAD.W	D4,#50*1	NTREL	?DELMS25$:	LOAD.L	A2,#R16"TABLE1$	; A2 <-- ^table des animaux	TEST.B	(A6)+OHATST+1:#0	JUMP',BC 30$	LOAD.L	A2,#R16"TABLE2$	; A2 <-- ^table des objets30$:	LOAD.L	A4,#(A6)+OHAELE	; A4 <-- ^table pour tirage exclusif	CLR.L	(A4)+0	CLR.L	(A4)+4		; recommence un nouveau tirage exclusif !	CLR.L	(A4)+8	CLR.L	(A4)+12	LOAD.W	D2,(A2)-2	; D2 <-- nb d'animaux ou d'objets  montrer32$:	LOAD.L	A4,#(A6)+OHAELE	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,(A2)-4	; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..4	LOAD.L	A4,A234$:	DEC.W	D4	JUMP',NS 36$35$:	TEST.B	(A4+)	JUMP,NE 35$	JUMP	34$36$:	LOAD.W	(A6)+OSOUND,#TMUSECRSHOW	LOAD.W	D3,#2^BICOSYMB	LOAD.B	D3,(A4)		; D3 <-- icne	CALL	ECICONE$	; dessine un animal sur l'cran	LOAD.W	D4,#50*3	NTREL	?DELMS	LOAD.L	D3,#H'10000*50+189	LOAD.L	D4,#H'10000*20+100	LOAD.L	A3,#(A4)+1	CALL	AFBULLE		; affiche le nom de l'animal	LOAD.W	D3,#ICOVIDE	; D3 <-- icne	CALL	ECICONE$	; efface l'cran	LOAD.W	D4,#50*1	NTREL	?DELMS	DEC.W	D2		; encore ?	JUMP,NE 32$		; oui => 32$	CALL	GMECRAN2	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; secoue la ficelle ...	LOAD.W	(A6)+OSOUND,#TMUSECRUP	LOAD.W	D3,#LECRANY64$:	LOAD.W	D4,#3	NTREL	?DELMS	SUB.W	D3,#5	CALL	ECRAN$		; enroule l'cran	TEST.W	D3	JUMP,NE 64$	LOAD.W	(A6)+OSOUND,#MA_COUP	CALL	GMECRAN3	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va s'asseoir ...	CLR.B	(A6)+OECRAN	CALL	FIXIMAGE	; refait OPIFFIX sans ascenseur	LOAD.L	A3,#R16"TEXT$	CALL	AFTEXT	JUMP	LOOPTEXT$:	.ASCIZ	"cran"	.EVEN	.W	6,5		; max,visuTABLE1$:	.ASCIZ	"<1>cureuil"	.ASCIZ	"<2>lphant"	.ASCIZ	"<3>lan"	.ASCIZ	"<4>pervier"	.ASCIZ	"<5>escargot"	.ASCIZ	"<6>crevisse"	.EVEN	.W	8,6		; max,visuTABLE2$:	.ASCIZ	"<8>chelle"	.ASCIZ	"<9>escalier"	.ASCIZ	"<10>crou"	.ASCIZ	"<11>pe"	.ASCIZ	"<12>pingle"	.ASCIZ	"<13>chasses"	.ASCIZ	"<14>gal"	.ASCIZ	"<15>toiles"	.EVEN; in	D3.B	code de l'icne (0..127); out	-; mod	D7.WECICONE$:	PUSHM.L	D2,D4,A3	PUSH.L	D3	LOAD.L	A3,#R16"ECICT$	AND.L	D3,#H'7F	SL.W	D3,#1	LOAD.W	(A0)+ODFCSF+2,(A3)+(D3.W)	POP.L	D3	LOAD.L	D4,#H'10000*(PECRANY+5)+(PECRANX+10)	LOAD.W	D2,#LOADDOT	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',T	ECIC2$		; oui => ECIC2$	TSET.L	D2:#BCPLDOTECIC2$:	PUSH.L	(A6)+OPITEMP	CLR.L	(A6)+OPITEMP	CALL	_DRICONE	; affiche sur l'cran	POP.L	(A6)+OPITEMP	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_BLANC	POPM.L	D2,D4,A3	RETECICT$:	.W	COLOR_NOIR	; Ee	.W	COLOR_BRUN	; cureuil	.W	COLOR_NOIR	; lphant	.W	COLOR_BRUN	; lan	.W	COLOR_BRUN	; pervier	.W	COLOR_BRUN	; escargot	.W	COLOR_ROSE	; crevisse	.W	COLOR_NOIR	; 	.W	COLOR_BRUN	; chelle	.W	COLOR_FOND5	; escalier	.W	COLOR_NOIR	; crou	.W	COLOR_ROUGE	; pe	.W	COLOR_ROUGE	; pingle	.W	COLOR_NOIR	; chasses	.W	COLOR_NOIR	; gal	.W	COLOR_JAUNE	; toiles; in	D3.W	hauteur; out	-; mod	D7.WECRAN$:	PUSHM.L	D2..D4	LOAD.W	D4,D3	SWAP.W	D4	LOAD.W	D4,#LECRANX	LOAD.L	D3,#H'10000*PECRANY+PECRANX	PUSHM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	COMP.W	D4,#LECRANY	JUMP',HS ECRAN3$	ADD.W	D3,D4	SUB.W	D4,#LECRANY	NEG.W	D4	INC.W	D4	SWAP.W	D4	SWAP.W	D3	INC.W	D4	LOAD.L	A3,(A6)+OPIFFIX	; A3 <-- ^image source	LOAD.L	A4,#0		; A4 <-- ^destination dans l'cran	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	XFERZONE	; cran <-- un bout d'imageECRAN3$:	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',T	ECRAN4$		; oui => ECRAN4$	LOAD.W	D2,#CLRDOTECRAN4$:	LIB	?DRRECT		; dessine rectangle autour	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',T	ECRAN5$		; oui => ECRAN5$	CALL	_DRSET		; efface l'intrieur	JUMP'	ECRAN9$ECRAN5$:	CALL	_DRCLEAR	; efface l'intrieurECRAN9$:	POPM.L	D2..D4	RET	;-------;	;   F	;	;-------;FETE:	CLR.W	(A6)+OERREUR	CALL	VAPOSBG		; va en bas  gauche	LOAD.L	A4,#(A6)+OHAFET	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#2		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..1	LOAD.W	(A6)+OHATST,D4	CALL	GMFETE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   G	;	;-------;GALETAS:	CLR.W	(A6)+OERREUR	CALL	IFHAUT		; est-on bien en haut ?	JUMP,NE LOOPK		; non => LOOPK	CALL	VAPOSHD		; va en haut  droite	CALL	GMGALETAS	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   H	;	;-------;HISTOIRE:	CLR.W	(A6)+OERREUR	CALL	IFBAS		; est-on bien en bas ?	JUMP,NE LOOPK		; non => LOOPK	CALL	VAPOSBD		; va en bas  droite	LOAD.L	A4,#(A6)+OHAHI1	; A4 <-- ^table pour tirage exclusif	TEST.L	(A4)+0	JUMP',NE 20$	TEST.W	(A4)+4		; premier passage ici ?	JUMP',NE 20$		; non => 20$	CLR.W	D4	SET.B	(A4)+0	JUMP'	30$20$:	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#6		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..530$:	LOAD.W	(A6)+OHATST,D4	LOAD.L	A4,#(A6)+OHAHI2	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#4		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..3	LOAD.W	(A6)+OHATST2,D4	CALL	GMHISTOIRE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   I	;	;-------;ILLUSION:	CLR.W	(A6)+OERREUR	CALL	VAPOSBG		; va en bas  gauche	LOAD.L	A4,#(A6)+OHAILL	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#4		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..3	LOAD.W	(A6)+OHATST,D4	CALL	GMILLUSION	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   J	;	;-------;JUMEAUX:	CLR.W	(A6)+OERREUR	CALL	VAPOSBD		; va en bas  droite	CALL	GMJUMEAUX1	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	GMJUMEAUX2	LOAD.L	A5,#(A6)+OOBJSL	LOAD.L	(A5)+OOMPTA,A420$:	LOAD.L	A5,#(A6)+OOBJSL	CALL	MOVEOBJET	LOAD.L	A5,#(A6)+OOBJET	CALL	MOVEOBJET	JUMP,EQ 20$	JUMP	LOOP	;-------;	;   K	;	;-------;KANGOUROU:	CLR.W	(A6)+OERREUR	CALL	VAPOSBG		; va en bas  gauche	CALL	GMKANGOUROU	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   L	;	;-------;LUNE:	CLR.W	(A6)+OERREUR	CALL	VAPOSHD		; va en haut  droite	LOAD.W	(A6)+OSOUND,#TMUSLUNE	TCLR.B	(A6)+OFIXOB+3:#BFOSOLEIL-0	TCLR.B	(A6)+OFIXOB+3:#BFOLUNE-0	LOAD.L	A4,#R16"TTRLUNE20$:	TEST.L	(A4)	JUMP',EQ 30$	LOAD.L	(A6)+OFIXTR+0,(A4+)	LOAD.L	(A6)+OFIXTR+4,(A4+)	LOAD.W	(A6)+OFIXCS,(A4+)	LOAD.W	(A6)+OFIXCC,(A4+)	CALL	FIXIMAGE	; trame le ciel	JUMP	20$30$:	CALL	GMLUNE	LOAD.L	A5,#(A6)+OOBJSL	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	TSET.B	(A6)+OFIXOB+3:#BFOSLEEP-0	JUMP	LOOPTTRLUNE:	.L	H'55AA55AA	.L	H'55AA55AA	.W	COLOR_FOND3,COLOR_FOND2	.L	H'77DD77DD	.L	H'77DD77DD	.W	COLOR_FOND6,COLOR_FOND4	.L	H'77FFDDFF	.L	H'77FFDDFF	.W	COLOR_FOND8,COLOR_FOND6	.L	H'FEFFFFFF	.L	H'EFFFFFFF	.W	COLOR_NOIR,COLOR_FOND8	.L	0LUNEERR:	CALL	GMLUNEERR	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A420$:	CALL	IFCAR		; une touche presse ?	JUMP',NE 30$		; non => 30$	LIB	?MINMAJ	COMP.W	D3,#'S	JUMP',NE 30$	CLR.B	(A6)+OPLAN	JUMP	LOOPK30$:	CALL	MOVEOBJET	JUMP,EQ 20$	JUMP	LOOP	;-------;	;   M	;	;-------;MELASSE:	LOAD.W	D3,(A6)+OERREUR	CLR.W	(A6)+OERREUR	COMP.W	D3,#'M	JUMP,EQ HAUTDROITE	CALL	VAPOSBG		; va en bas  gauche	CALL	GMMELASSE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   N	;	;-------;NAVIRE:	CLR.W	(A6)+OERREUR	CALL	VAPOSBD		; va en bas  droite	CALL	GMNAVIRE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   O	;	;-------;ORAGE:	CLR.W	(A6)+OERREUR	TCLR.B	(A6)+OFIXOB+3:#BFOSOLEIL-0	TCLR.B	(A6)+OFIXOB+3:#BFOLUNE-0	LOAD.L	(A6)+OFIXTR+0,#H'77DD77DD	LOAD.L	(A6)+OFIXTR+4,#H'77DD77DD	LOAD.W	(A6)+OFIXCS,#COLOR_NOIR	LOAD.W	(A6)+OFIXCC,#COLOR_FOND8	CALL	FIXIMAGE	; trame le ciel	CALL	GMNUAGES	LOAD.L	A5,#(A6)+OOBJSL	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; met qq nuages ...	SET.B	(A6)+OQUICK	;  toute vapeur	CALL	VAPOSBD		; va en bas  droite	CLR.B	(A6)+OQUICK	; remet normal	CALL	GMORAGE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	LOAD.L	(A6)+OFIXTR+0,#H'11441144	LOAD.L	(A6)+OFIXTR+4,#H'11441144	LOAD.W	(A6)+OFIXCS,#COLOR_BLANC	LOAD.W	(A6)+OFIXCC,#COLOR_FOND1	CALL	FIXIMAGE	; trame le ciel	LOAD.L	A3,#R16"TEXT$	CALL	AFTEXT	JUMP	LOOPTEXT$:	.ASCIZ	"orage"	.EVEN	;-------;	;   P	;	;-------;POUPEE:	CLR.W	(A6)+OERREUR	CALL	VAPOSHD		; va en haut  droite	CALL	GMPOUPEE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   Q	;	;-------;QUEUE:	CLR.W	(A6)+OERREUR	CALL	VAPOSHG		; va en haut  gauche	CALL	GMQUEUE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   R	;	;-------;ROBINET:	CLR.W	(A6)+OERREUR	CALL	VAPOSHG		; va en haut  gauche	LOAD.L	A4,#(A6)+OHAROB	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#2		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..1	LOAD.W	(A6)+OHATST,D4	CALL	GMROBINET	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	SET.B	(A6)+OROBIN	; le bain est coul	JUMP	LOOP	;-------;	;   S	;	;-------;SOLEIL:	CLR.W	(A6)+OERREUR	TCLR.B	(A6)+OFIXOB+3:#BFOSOLEIL-0	TCLR.B	(A6)+OFIXOB+3:#BFOLUNE-0	LOAD.L	A4,#R16"TTRSOLEIL10$:	TEST.L	(A4)	JUMP',EQ 20$	LOAD.L	(A6)+OFIXTR+0,(A4+)	LOAD.L	(A6)+OFIXTR+4,(A4+)	LOAD.W	(A6)+OFIXCS,(A4+)	LOAD.W	(A6)+OFIXCC,(A4+)	CALL	FIXIMAGE	; trame le ciel	JUMP	10$20$:	CALL	GMSOLEIL	LOAD.L	A5,#(A6)+OOBJSL	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	TEST.B	(A6)+OFIXOB+3:#BFOSLEEP-0	JUMP,BC LOOP	CALL	GMLUNEEND	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; sort du lit ...	TCLR.B	(A6)+OFIXOB+3:#BFOSLEEP-0	JUMP	LOOPTTRSOLEIL:	.L	H'77FFDDFF	.L	H'77FFDDFF	.W	COLOR_FOND8,COLOR_FOND6	.L	H'77DD77DD	.L	H'77DD77DD	.W	COLOR_FOND6,COLOR_FOND4	.L	H'55AA55AA	.L	H'55AA55AA	.W	COLOR_FOND3,COLOR_FOND2	.L	H'11441144	.L	H'11441144	.W	COLOR_BLANC,COLOR_FOND1	.L	0	;-------;	;   T	;	;-------;TELE:	CLR.W	(A6)+OERREUR	CALL	IFBAS		; est-on bien en bas ?	JUMP,NE LOOPK		; non => LOOPK	CALL	VAPOSBD		; va en bas  droite	CALL	GMTELE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   U	;	;-------;URGENT:	CLR.W	(A6)+OERREUR	SET.B	(A6)+OQUICK	;  toute vapeur	CALL	VAPOSBD		; va en bas  droite	CLR.B	(A6)+OQUICK	; remet normal	CALL	GMURGENT	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   V	;	;-------;VARICELLE:	CLR.W	(A6)+OERREUR	CALL	VAPOSHD		; va en haut  droite	CALL	GMVARICE1	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; tombe malade ...	CLR.L	D3	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',T	20$		; oui => 20$	LOAD.L	D3,#-120$:	LOAD.L	D4,D3	CALL	_DRTRADEF	LOAD.L	A4,#R16"TABLE$30$:	TEST.L	(A4)		; fin de la table ?	JUMP',EQ 40$		; oui => 40$				; non =>	LOAD.W	(A6)+OSOUND,#TMUSTIC	LOAD.W	(A0)+ODFCSF+2,#COLOR_TOTO	LOAD.W	(A0)+ODFCCF+2,#COLOR_TOTO	LOAD.W	D3,#LYICO-1	SUB.W	D3,(A4)+2	ADD.W	D3,#PVARIY	SWAP.W	D3	LOAD.W	D3,(A4)+0	ADD.W	D3,#PVARIX	LOAD.L	D4,#H'10000*4+4	LOAD.W	D2,#LOADDOT	CALL	_DRTRAME	; enlve un bouton (mais si)	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_BLANC	LOAD.W	D4,(A4)+4	NTREL	?DELMS		; attend un peu	ADD.L	A4,#6		; A4 <-- ^suivant	JUMP	30$40$:	CALL	GMVARICE2	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; gurison ...	JUMP	LOOPTABLE$:	;	 x,y  t		<-- X=,Y= donns dans EDICAR, icne 78	.W	38,33,50	.W	58,20,20	.W	41,46,40	.W	25,13,60	.W	47,24,20	.W	52,12,25	.W	26,34,40	.W	39,17,50	.W	13,27,100	.W	0,0	;-------;	;   W	;	;-------;WAGON:	CLR.W	(A6)+OERREUR	CALL	VAPOSHD		; va en haut  droite	CALL	GMWAGON	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   X	;	;-------;XYLOPHONE:	CLR.W	(A6)+OERREUR	CALL	IFHAUT		; est-on bien en haut ?	JUMP,NE LOOPK		; non => LOOPK	CALL	VAPOSHD		; va en haut  droite	LOAD.L	A4,#(A6)+OHAXYL	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#3		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	(A6)+OHATST,D4	CALL	GMXYLOPHONE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   Y	;	;-------;YOGOURT:	CLR.W	(A6)+OERREUR	CALL	VAPOSBG		; va en bas  gauche	CALL	GMYOGOURT	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   Z	;	;-------;ZIGZAG:	CLR.W	(A6)+OERREUR	CALL	VAPOSHG		; va en haut  gauche	CALL	GMZIGZAG	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOPHAUTGAUCHE:	CALL	VAPOSHG		; va en haut  gauche	JUMP	LOOPHAUTDROITE:	CALL	VAPOSHD		; va en haut  droite	JUMP	LOOPBASGAUCHE:	CALL	VAPOSBG		; va en bas  gauche	JUMP	LOOPBASDROITE:	CALL	VAPOSBD		; va en bas  droite	JUMP	LOOP;--------\\; IFHAUT  >;========/; Vrifie si toto est bien en haut.; En fait, on rouspte seulement s'il est assis en bas !; in	-; out	D7.W	erreur (il est assis en bas);	D3.W	touche (0 si rien); mod	D3.L, D7.WIFHAUT:	PUSHM.L	A4,A5	LOAD.L	A5,#(A6)+OOBJET	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OCLIC	; avec un clic de la souris ?	JUMP,T	90$		; oui => 90$	TEST.B	(A6)+OPLAY	; raconte une histoire ?	JUMP,T	90$		; oui => 90$	COMP.W	(A5)+OOLPOS+0,#LIMITY	JUMP,LO 90$	COMP.W	(A5)+OOLPOS+2,#LIMITX	JUMP,LO 90$	CALL	GMMONTERR	LOAD.L	(A5)+OOMPTA,A420$:	CALL	IFCAR		; une touche presse ?	JUMP',EQ 30$25$:	CALL	MOVEOBJET	; explique qu'il faut descendre ...	JUMP,EQ 20$	CLR.W	D3		; D3 <-- pas de touche	JUMP	80$30$:	COMP.W	D3,#KEYMGR	JUMP,EQ 25$	COMP.W	D3,#KEYMMR	JUMP,EQ 25$	COMP.W	D3,#KEYMDR	JUMP,EQ 25$	COMP.W	D3,#KEYMGP	JUMP,EQ 25$	COMP.W	D3,#KEYMMP	JUMP,EQ 25$	COMP.W	D3,#KEYMDP	JUMP,EQ 25$	CALL	GMMONTERRS	LOAD.L	(A5)+OOMPTA,A432$:	CALL	MOVEOBJET	; dessine toto assis	JUMP,EQ 32$80$:	LOAD.W	(A6)+OERREUR,#'M	LOAD.W	D7,#190$:	POPM.L	A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFBAS   >;========/; Vrifie si toto est bien en bas.; En fait, on rouspte seulement s'il est assis en haut !; in	-; out	D7.W	erreur (il est assis en haut);	D3.W	touche (0 si rien); mod	D3.L, D7.WIFBAS:	PUSHM.L	A4,A5	LOAD.L	A5,#(A6)+OOBJET	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OCLIC	; avec un clic de la souris ?	JUMP,T	90$		; oui => 90$	TEST.B	(A6)+OPLAY	; raconte une histoire ?	JUMP,T	90$		; oui => 90$	COMP.W	(A5)+OOLPOS+0,#LIMITY	JUMP,HS 90$	COMP.W	(A5)+OOLPOS+2,#LIMITX	JUMP,LO 90$	CALL	GMDESCERR	LOAD.L	(A5)+OOMPTA,A420$:	CALL	IFCAR		; une touche presse ?	JUMP',EQ 30$25$:	CALL	MOVEOBJET	; explique qu'il faut descendre ...	JUMP,EQ 20$	CLR.W	D3		; D3 <-- pas de touche	JUMP	80$30$:	COMP.W	D3,#KEYMGR	JUMP,EQ 25$	COMP.W	D3,#KEYMMR	JUMP,EQ 25$	COMP.W	D3,#KEYMDR	JUMP,EQ 25$	COMP.W	D3,#KEYMGP	JUMP,EQ 25$	COMP.W	D3,#KEYMMP	JUMP,EQ 25$	COMP.W	D3,#KEYMDP	JUMP,EQ 25$	CALL	GMDESCERRS	LOAD.L	(A5)+OOMPTA,A432$:	CALL	MOVEOBJET	; dessine toto assis	JUMP,EQ 32$80$:	LOAD.W	(A6)+OERREUR,#'D	LOAD.W	D7,#190$:	POPM.L	A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; VAPOSHD >;========/; Amne toto en haut  droite s'il n'y est pas dj.; in	-; out	-; mod	D7.WVAPOSHD:	PUSHM.L	D3,D4,A4,A5	LOAD.L	A5,#(A6)+OOBJET	COMP.W	(A6)+OOBJET+OOLPOS+0,#LIMITY	JUMP',LO 30$	COMP.W	(A6)+OOBJET+OOLPOS+2,#LIMITX	JUMP',LO 20$	CALL	GM_BD_BG	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va en bas  gauche20$:	LOAD.L	A4,#(A6)+OHAASH	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#7		; D4 <-- max+1	CALL	EXHAZARD	; D4 <-- 0..6	TEST.W	D4	JUMP',NE 25$	CALL	GM_BG_HG_PANNE	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; assaie de monter (panne)25$:	CALL	GM_BG_HG	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; monte30$:	COMP.W	(A6)+OOBJET+OOLPOS+2,#LIMITX	JUMP',HS 40$	CALL	GM_HG_HD	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va en haut  droite40$:	POPM.L	D3,D4,A4,A5	RET;--------\\; VAPOSHG >;========/; Amne toto en haut  gauche s'il n'y est pas dj.; in	-; out	-; mod	D7.WVAPOSHG:	PUSHM.L	D3,D4,A4,A5	LOAD.L	A5,#(A6)+OOBJET	COMP.W	(A6)+OOBJET+OOLPOS+0,#LIMITY	JUMP',LO 30$	COMP.W	(A6)+OOBJET+OOLPOS+2,#LIMITX	JUMP',LO 20$	CALL	GM_BD_BG	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va en bas  gauche20$:	LOAD.L	A4,#(A6)+OHAASH	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#7		; D4 <-- max+1	CALL	EXHAZARD	; D4 <-- 0..6	TEST.W	D4	JUMP',NE 25$	CALL	GM_BG_HG_PANNE	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; assaie de monter (panne)25$:	CALL	GM_BG_HG	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; monte30$:	COMP.W	(A6)+OOBJET+OOLPOS+2,#LIMITX	JUMP',LO 40$	CALL	GM_HD_HG	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va en haut  gauche40$:	POPM.L	D3,D4,A4,A5	RET;--------\\; VAPOSBD >;========/; Amne toto en bas  droite s'il n'y est pas dj.; in	-; out	-; mod	D7.WVAPOSBD:	PUSHM.L	D3,D4,A4,A5	LOAD.L	A5,#(A6)+OOBJET	COMP.W	(A6)+OOBJET+OOLPOS+0,#LIMITY	JUMP,HS 30$	COMP.W	(A6)+OOBJET+OOLPOS+2,#LIMITX	JUMP',LO 20$	LOAD.L	A4,#(A6)+OHAASB	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#6		; D4 <-- max+1	CALL	EXHAZARD	; D4 <-- 0..5	TEST.W	D4	JUMP',NE 15$				; tombe =>	CALL	GM_HD_BG	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va en bas  gauche	JUMP'	30$15$:	CALL	GM_HD_HG	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va en haut  gauche20$:	CALL	GM_HG_BG	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; descend30$:	COMP.W	(A6)+OOBJET+OOLPOS+2,#LIMITX	JUMP',HS 40$	CALL	GM_BG_BD	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va en bas  droite40$:	POPM.L	D3,D4,A4,A5	RET;--------\\; VAPOSBG >;========/; Amne toto en bas  gauche s'il n'y est pas dj.; in	-; out	-; mod	D7.WVAPOSBG:	PUSHM.L	D3,D4,A4,A5	LOAD.L	A5,#(A6)+OOBJET	COMP.W	(A6)+OOBJET+OOLPOS+0,#LIMITY	JUMP,HS 30$	COMP.W	(A6)+OOBJET+OOLPOS+2,#LIMITX	JUMP',LO 20$	LOAD.L	A4,#(A6)+OHAASB	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#6		; D4 <-- max+1	CALL	EXHAZARD	; D4 <-- 0..5	TEST.W	D4	JUMP',NE 15$				; tombe =>	CALL	GM_HD_BG	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va en bas  gauche	JUMP'	30$15$:	CALL	GM_HD_HG	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va en haut  gauche20$:	CALL	GM_HG_BG	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; descend30$:	COMP.W	(A6)+OOBJET+OOLPOS+2,#LIMITX	JUMP',LO 40$	CALL	GM_BD_BG	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va en bas  gauche40$:	POPM.L	D3,D4,A4,A5	RET;--------\\; DOMOVE  >;========/; Dplace un objet.; in	A5.L	^objet  mettre en mouvement; out	-; mod	D7.WDOMOVE:	PUSHM.L	D3,D410$:	CALL	IFCAR		; une touche presse ?	JUMP',NE 30$		; non => 30$	LIB	?MINMAJ	.IF	DANIEL	COMP.W	D3,#H'100*(2^BPROGRA)+'I	JUMP,EQ ICONE$	COMP.W	D3,#H'100*(2^BPROGRA)+'A	JUMP,EQ 50$	.ENDIF30$:	CALL	MOVEOBJET	.IF	DANIEL	PUSH.W	D7	TEST.B	(A6)+OSTEP	JUMP',F	40$	LOAD.L	D4,(A5)+OOLPOS	CALL	AFXY	LIB	?AFTIM	.ASCIZ	" i="	.EVEN	LOAD.W	D4,(A5)+OOICON	LIB	?AFX4	LIB	?AFTIM	.ASCIZ	"     "	.EVEN	LIB	?GETCAR40$:	POP.W	D7	.ENDIF	JUMP,EQ 10$	JUMP	90$	.IF	DANIEL50$:	LOAD.L	D4,(A5)+OOLPOS	CALL	AFXY	LIB	?GETCAR	JUMP	10$	.ENDIF90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET	.IF	DANIELICONE$:	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Code de l'icne : "	.EVEN	LIB	?GETDEC	COMP.W	D3,#CR	JUMP,NE REFAIT	LOAD.B	D0,D4	LOAD.L	D1,#H'AAAAAAAA	CALL	CCMO	PUSH.L	(A6)+OPITEMP	CLR.L	(A6)+OPITEMPICO1$:	LIB	?IFCAR	JUMP',EQ ICO6$	CALL	IFMOUSE	JUMP,NE ICO1$	SUB.W	D4,#LXICO/2	SWAP.W	D4	SUB.W	D4,#LYICO/2	SWAP.W	D4	COMP.L	D4,D1	JUMP,EQ ICO1$	LOAD.B	D3,D0	LOAD.W	D2,#INVDOT	EX.L	D1,D4	COMP.L	D4,#H'AAAAAAAA	JUMP',EQ ICO2$	CALL	_DRICONEICO2$:	LOAD.L	D4,D1	CALL	_DRICONE	CALL	AFXY	JUMP	ICO1$ICO6$:	POP.L	(A6)+OPITEMP	CALL	SCMO	JUMP	10$; in	D4.L	coordonne (y;x); out	-; mod	D7.WAFXY:	PUSHM.L	D2..D4	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Y="	.EVEN	PUSH.L	D4	CLR.W	D4	SWAP.W	D4	TEST.W	D4	JUMP',NC 10$	NEG.W	D4	LOAD.B	D3,#'-	LIB	?AFCAR10$:	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	POP.L	D4	LIB	?AFTIM	.ASCIZ	" X="	.EVEN	AND.L	D4,#H'FFFF	TEST.W	D4	JUMP',NC 20$	NEG.W	D4	LOAD.B	D3,#'-	LIB	?AFCAR20$:	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"     "	.EVEN	POPM.L	D2..D4	RET	.ENDIF;---------\\; FIXIMAGE >;=========/; Gnre puis affiche l'image avec les objets fixes  partir; de l'image initiale.;;	OPIFFIX <-- OPIFINI; in	-; out	-; mod	D7.WFIXIMAGE:	PUSHM.L	D2..D4,A3,A4; Transfre toute l'image initiale (FINI) dans l'image fixe (FFIX).	LOAD.L	A4,(A6)+OPIFFIX	LOAD.L	A3,(A6)+OPIFINI	CLR.W	D4	LOAD.B	D4,(A0)+ODFCNP	; D4 <-- nb de bits/pixel	MUL.WU	D4,(A6)+ODIMA+2	SR.W	D4,#3	MUL.WU	D4,(A6)+ODIMA+0	SR.L	D4,#2		; D4 <-- /4 car .W	DEC.W	D4		; D4 <-- -1 car NMO10$:	LOAD.L	(A4+),(A3+)	; OPIFFIX <-- OPIFINI	DECJ.W,NMO D4,10$; Dessine tous les lments fixes dans l'image fixe (FFIX).	LOAD.L	(A6)+OPSTEMP,(A6)+OPITEMP	PUSH.L	(A6)+OPITEMP	LOAD.L	(A6)+OPITEMP,(A6)+OPIFFIX ; dessin dans OPIFFIX !	LOAD.W	(A6)+OFIXCX,(A6)+OFIXCS	CALL	FIXCIEL		; trame le ciel	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	NOT.L	(A6)+OFIXTR+0	NOT.L	(A6)+OFIXTR+4	LOAD.W	(A6)+OFIXCX,(A6)+OFIXCC	CALL	FIXCIEL		; trame le ciel	NOT.L	(A6)+OFIXTR+0	NOT.L	(A6)+OFIXTR+4NOCOUL$:	TEST.B	(A6)+OFIXOB+3:#BFOSOLEIL-0	JUMP',BC 20$	LOAD.L	D4,#H'10000*PSOLEY+PSOLEX	LOAD.W	D3,#ICOSOLEIL	CALL	DROBJET		; dessine le soleil20$:	TEST.B	(A6)+OFIXOB+3:#BFOLUNE-0	JUMP',BC 22$	LOAD.L	D4,#H'10000*PLUNEY+PLUNEX	LOAD.W	D3,#ICOLUNE	CALL	DROBJET		; dessine la lune22$:	TEST.B	(A6)+OECRAN	; cran droul ?	JUMP',F	24$		; non => 24$	LOAD.L	D4,#H'10000*PASCHY+PASCHX	LOAD.W	D3,#ICOASCV	CALL	DROBJET		; dessine l'ascenseur en haut24$:	POP.L	(A6)+OPITEMP; Dessine provisoirement tous les lments mobiles.	LOAD.L	A4,(A6)+OPITEMP	LOAD.L	A3,(A6)+OPIFFIX	CLR.W	D4	LOAD.B	D4,(A0)+ODFCNP	; D4 <-- nb de bits/pixel	MUL.WU	D4,(A6)+ODIMA+2	SR.W	D4,#3	MUL.WU	D4,(A6)+ODIMA+0	SR.L	D4,#2		; D4 <-- /4 car .W	DEC.W	D4		; D4 <-- -1 car NMO50$:	LOAD.L	(A4+),(A3+)	; OPITEMP <-- OPIFFIX	DECJ.W,NMO D4,50$	TEST.B	(A6)+OECRAN	; cran droul ?	JUMP,T	80$		; oui => 80$	COMP.W	(A6)+OOBJET+OOLPOS+0,#LIMITY	JUMP,HS BAS$HAUT$:	COMP.W	(A6)+OOBJET+OOLPOS+2,#LIMITX	JUMP',HS HD$HG$:	LOAD.L	D4,#H'10000*PASCHY+PASCHX	LOAD.W	D3,#ICOASCT	CALL	DROBJET		; dessine l'ascenseur avec toto en haut	LOAD.B	(A6)+OASC,#2^BASCH	JUMP	80$HD$:	LOAD.L	D4,#H'10000*PASCHY+PASCHX	LOAD.W	D3,#ICOASCV	CALL	DROBJET		; dessine l'ascenseur vide en haut	LOAD.B	(A6)+OASC,#2^BASCH	TEST.B	(A6)+OFIXOB+3:#BFOSLEEP-0	JUMP',BS HDS$	LOAD.L	D4,#H'10000*PARRHDY+PARRHDX	LOAD.W	D3,#ICOARRH	CALL	DROBJET		; dessine toto assis en haut	JUMP	80$HDS$:	LOAD.L	D4,#H'10000*PARRLY+PARRLX	LOAD.W	D3,#ICOSLEEP	CALL	DROBJET		; dessine toto qui dort au lit	JUMP	80$BAS$:	COMP.W	(A6)+OOBJET+OOLPOS+2,#LIMITX	JUMP',HS BD$BG$:	LOAD.L	D4,#H'10000*PASCBY+PASCBX	LOAD.W	D3,#ICOASCT	CALL	DROBJET		; dessine l'ascenseur avec toto en bas	LOAD.B	(A6)+OASC,#2^BASCB	JUMP'	80$BD$:	LOAD.L	D4,#H'10000*PASCBY+PASCBX	LOAD.W	D3,#ICOASCV	CALL	DROBJET		; dessine l'ascenseur vide en bas	LOAD.B	(A6)+OASC,#2^BASCB	LOAD.L	D4,#H'10000*PARRBDY+PARRBDX	LOAD.W	D3,#ICOARRB	CALL	DROBJET		; dessine toto assis en bas;	JUMP'	80$; Affiche l'image complte.80$:	LOAD.L	A3,(A6)+OPITEMP	; A3 <-- ^image	LOAD.L	A4,#0	CLR.L	D3	LOAD.L	D4,(A6)+ODIMA	; D4 <-- dimensions	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	XFERZONE	; affiche l'image	CALL	AFLETTRE	; affiche juste la lettre	POPM.L	D2..D4,A3,A4	RET;--------\\; FIXCIEL >;--------/; Trame le ciel selon la trame dans OFIXTR.; in	(A6)+OFIXTR	trame 8x8 pour le ciel; out	-; mod	D7.WFIXCIEL:	PUSHM.L	D2..D4,A3,A4	LOAD.B	D3,#AFFILLA	; rempli tout	LIB	?AFCAR	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COUL$		; oui => COUL$	LOAD.L	D3,(A6)+OFIXTR+0	LOAD.L	D4,(A6)+OFIXTR+4	CALL	_DRTRADEF	; dfini la trame	CALL	OPEDISMAT	; dessin en mmoire	LOAD.L	A4,(A6)+OPIFFIX	LOAD.L	D4,(A6)+ODIMA	CALL	NEWDISMATC	; dessin dans OPIFFIX en couleur	CLR.L	D3	CALL	DRFILL		; trame le ciel	CALL	CLODISMAT	; dessin dans l'cran	JUMP	EXIT$COUL$:	LOAD.L	D3,#H'55AA55AA	LOAD.W	D4,(A6)+OFIXCX	COMP.W	D4,(A6)+OFIXCS	JUMP',EQ CTRAME$	NOT.L	D3CTRAME$:	LOAD.L	D4,D3	CALL	_DRTRADEF	; dfini la trame	LOAD.L	A3,(A6)+OPIMAFI	LOAD.L	A4,(A6)+OPSTEMP	LOAD.W	D4,(A6)+ODIMA+2	SR.W	D4,#3	MUL.WU	D4,(A6)+ODIMA+0	SR.L	D4,#2		; D4 <-- /4 car .W	DEC.W	D4		; D4 <-- -1 car NMOCCOPY$:	LOAD.L	(A4+),(A3+)	; OPITEMP <-- OPIMAFI	DECJ.W,NMO D4,CCOPY$	CALL	OPEDISMAT	; dessin en mmoire	LOAD.L	A4,(A6)+OPSTEMP	LOAD.L	D4,(A6)+ODIMA	CALL	NEWDISMAT	; dessin dans OPITEMP en n/b	CLR.L	D3	CALL	DRFILL		; trame le ciel	CALL	CLODISMAT	; dessin dans l'cran	LOAD.L	A3,(A6)+OPIMAFI	LOAD.L	A4,(A6)+OPSTEMP	LOAD.W	D4,(A6)+ODIMA+2	SR.W	D4,#3	MUL.WU	D4,(A6)+ODIMA+0	SR.L	D4,#2		; D4 <-- /4 car .W	DEC.W	D4		; D4 <-- -1 car NMOCMASK$:	LOAD.L	D3,(A3+)	NOT.L	D3	AND.L	(A4+),D3	; OPITEMP <-- masque selon OPIMAFI	DECJ.W,NMO D4,CMASK$	LOAD.W	(A0)+ODFCSF+2,(A6)+OFIXCX	LOAD.L	A3,(A6)+OPSTEMP	LOAD.L	A4,(A6)+OPIFFIX	CLR.L	D3	LOAD.L	D4,(A6)+ODIMA	LOAD.W	D2,#SETDOT!2^BDSTCOUL	CALL	XFERZONE	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIREXIT$:	POPM.L	D2..D4,A3,A4	RETFINI:	CALL	DBOXQUITTE	; quitte TOTO ?	COMP.W	D3,#F1	JUMP,NE LOOP	TEST.L	(A6)+OPIFINI	JUMP',EQ 20$	LOAD.L	A4,(A6)+OPIFINI	CALL	KILLIMAGE	; libre l'image initiale20$:	TEST.L	(A6)+OPIMAF	JUMP',EQ 22$	LOAD.L	A4,(A6)+OPIMAF	CALL	KILLIMAGE	; libre l'image22$:	TEST.L	(A6)+OPITEMP	JUMP',EQ 30$	LOAD.L	A4,(A6)+OPITEMP	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire30$:	TEST.L	(A6)+OPIMAC	JUMP',EQ 32$	LOAD.L	A4,(A6)+OPIMAC	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire32$:	TEST.L	(A6)+OPIFFIX	JUMP',EQ 34$	LOAD.L	A4,(A6)+OPIFFIX	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire34$:	TEST.L	(A6)+OPFICO	JUMP',EQ 40$	LOAD.L	A4,(A6)+OPFICO	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire40$:ERFAT:	SET.B	(A6)+OABORT	; signal la fin au processus fils	NTREL	?WFABDESC	; attend leurs fins ...	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LIB	?AFTIM	.B	AFSCMO		; remet la flche-souris	.B	KILLGC		; libre les icnes ITP80	.B	GCICF	.B	GCICS	.B	GCICT	.B	KILLGC		; libre les icnes ITP81	.B	GCICF	.B	GCICS	.B	GCICT+1	.B	0	.EVEN	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire des variables	.IF	~IFSMILE	LIB	?CLOLIB	FOS	?STOP	.ELSE	EXIT	.ENDIF; Indirections; ------------_AFIMAGE:	JUMP	AFIMAGE_LOADIMAGE:	JUMP	LOADIMAGE_CNBCIMAGE:	JUMP	CNBCIMAGE_LOADCOLOR:	JUMP	LOADCOLOR_COUPSAC:	JUMP	COUPSAC_DRTRADEF:	JUMP	DRTRADEF_DRTRAME:	JUMP	DRTRAME_DRSET:		JUMP	DRSET_DRCLEAR:	JUMP	DRCLEAR_DRICONE:	JUMP	DRICONE_EXHAZARD:	JUMP	EXHAZARD_SNDREAD:	JUMP	SNDREAD_SNDDONE:	JUMP	SNDDONEGETADCODE:	LOAD.L	A3,#R16"ADCODE	RET; Gestion des objets utiliss; ---------------------------;---------\\; ICOOBJET >;=========/; Dessine une icne (n'est utilis que pour les bulles de "histoire").; in	D3.L	position (y;x);	D4.L	icne (chair,fond); out	-; mod	D7.WICOOBJET:	PUSHM.L	D2..D4	LOAD.L	(A6)+OPGPOS,D3	LOAD.L	(A6)+OPGDIM,#H'10000*LYICO+LXICO	PUSH.L	(A6)+OPITEMP	LOAD.L	(A6)+OPITEMP,(A6)+OPIFFIX	EX.L	D3,D4	LOAD.W	D2,#CLRDOT	CALL	DRICONE		; efface le fond	SWAP.W	D3	LOAD.W	D2,#SETDOT	CALL	DRICONE		; dessine la chair	POP.L	(A6)+OPITEMP	POPM.L	D2..D4	RET;---------\\; LINOBJET >;=========/; Dessine une ligne.; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D2.W	trait (0..n); out	-; mod	D7.WLINOBJET:	PUSHM.L	D1..D4,A3,A4	LOAD.W	D1,D2		; D1 <-- trait	PUSHM.L	D3,D4	TEST.W	D4	JUMP',NC 10$	NEG.W	D4	SUB.W	D3,D410$:	SUB.W	D3,#8/2	ADD.W	D4,#8	SWAP.W	D3	SWAP.W	D4	TEST.W	D4	JUMP',NC 12$	NEG.W	D4	SUB.W	D3,D412$:	SUB.W	D3,#8/2	ADD.W	D4,#8	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OPGPOS,D3	LOAD.L	(A6)+OPGDIM,D4	POPM.L	D3,D4	PUSH.L	D4	CALL	OPEDISMAT	; dessin en mmoire	LOAD.L	A4,(A6)+OPIFFIX	LOAD.L	D4,(A6)+ODIMA	CALL	NEWDISMATC	; dessin dans OPIFFIX en couleur	POP.L	D4	PUSH.L	D3	LOAD.L	A3,#R16"PEN1$	COMP.W	D1,#1	JUMP',EQ 40$	LOAD.L	A3,#R16"PEN2$	COMP.W	D1,#2	JUMP',NE 42$40$:	LOAD.W	D3,#9	LIB	?STRING		; dfinit le pinceau42$:	POP.L	D3	LOAD.W	D2,#CLRDOT	; D2 <-- mode	COMP.W	D1,#2	JUMP',EQ 50$	LOAD.W	D2,#SETDOT	; D2 <-- mode50$:	TEST.W	D1	JUMP',EQ 52$	TSET.L	D2:#BPENDOT	; D2 <-- utilise le pinceau52$:	CALL	DRLINE		; trace une ligne	CALL	CLODISMAT	; dessin dans l'cran	POPM.L	D1..D4,A3,A4	RETPEN1$:	.B	PEN	.B	B'00000000	.B	B'00111100	.B	B'01111110	.B	B'01111110	.B	B'01111110	.B	B'01111110	.B	B'00111100	.B	B'00000000PEN2$:	.B	PEN	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00011000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.EVEN;---------\\; GETOBJET >;=========/; Prend un objet. Son emplacement sera gris dans l'image fixe.; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WGETOBJET:	PUSHM.L	D0..D6,A3,A4	LOAD.L	(A6)+OPGPOS,D3	LOAD.L	(A6)+OPGDIM,D4	CALL	OPEDISMAT	; dessin en mmoire	LOAD.L	A4,(A6)+OPIFFIX	LOAD.L	D4,(A6)+ODIMA	CALL	NEWDISMATC	; dessin dans OPIFFIX en couleur	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COUL$	LOAD.L	D3,#H'55AA55AATRAME$:	LOAD.L	D4,D3	CALL	DRTRADEF	LOAD.L	D3,(A6)+OPGPOS	LOAD.L	D4,(A6)+OPGDIM	LOAD.W	D2,#LOADDOT	; D2 <-- mode	CALL	DRTRAME		; grise l'emplacement	JUMP	CLOSE$LIVRE$:	LOAD.W	(A0)+ODFCSF+2,#COLOR_BRUN ; met la couleur de la bibliothque !	LOAD.L	D3,#-1	JUMP	TRAME$COUL$:	LOAD.L	D4,(A6)+OPGPOS	COMP.W	D4,#430	JUMP',LO CGO$	COMP.W	D4,#470	JUMP',HS CGO$	SWAP.W	D4	COMP.W	D4,#230	JUMP',LO CGO$	COMP.W	D4,#240		; prend un livre ?	JUMP,LO LIVRE$		; oui => LIVRE$CGO$:	LOAD.L	D4,(A6)+OPGPOS	LOAD.L	D3,D4	LOAD.W	D0,(A6)+OPGDIM+2	ADD.W	D3,D0CLOOP$:	LOAD.L	A3,A4	LOAD.W	D5,(A6)+ODIMA+2	SR.W	D5,#3	LOAD.W	D6,D5	LOAD.L	D1,(A6)+OPGDIM	LOAD.W	D1,#2	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	ADD.W	D4,#2	SUB.W	D0,#2	JUMP,NC CLOOP$CLOSE$:	CALL	CLODISMAT	; dessin dans l'cran	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_BLANC	POPM.L	D0..D6,A3,A4	RET;---------\\; PUTOBJET >;=========/; Remet un objet d'aprs l'image initiale.; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WPUTOBJET:	PUSHM.L	D2,A3,A4	LOAD.L	(A6)+OPGPOS,D3	LOAD.L	(A6)+OPGDIM,D4	LOAD.L	A3,(A6)+OPIFINI	; A3 <-- ^source	LOAD.L	A4,(A6)+OPIFFIX	; A4 <-- ^destination	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	XFERZONE	POPM.L	D2,A3,A4	RET;--------\\; PGD3D4  >;--------/; Augmente l'emplacement pour englober aussi la surface utilise; par GETOBJET/PUTOBJET.; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WPGD3D4:	PUSHM.L	D1,D2	TEST.L	(A6)+OPGDIM	JUMP,EQ 90$	LOAD.L	D1,(A6)+OPGPOS	LOAD.L	D2,(A6)+OPGDIM	ADD.W	D2,D1	ADD.W	D4,D3	COMP.W	D3,D1	JUMP',LS 20$	LOAD.W	D3,D120$:	COMP.W	D4,D2	JUMP',HS 22$	LOAD.W	D4,D222$:	SUB.W	D2,D1	SUB.W	D4,D3	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	ADD.W	D2,D1	ADD.W	D4,D3	COMP.W	D3,D1	JUMP',LS 40$	LOAD.W	D3,D140$:	COMP.W	D4,D2	JUMP',HS 42$	LOAD.W	D4,D242$:	SUB.W	D2,D1	SUB.W	D4,D3	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	CLR.L	(A6)+OPGDIM90$:	POPM.L	D1,D2	RET; Gestion des bulles; ------------------;--------\\; AFBULLE >;========/; Affiche une bulle avec un texte un certain temps.; in	D3.L	position (y;x);	D4.L	frappe/dure (unit = 20ms);	A3.L	^texte (lg max = 9 caractres); out	-; mod	D7.WAFBULLE:	PUSHM.L	D1..D4,A2..A4	CALL	GCLITTLE	; utilise les petits caractres	LOAD.L	D1,D4		; D1 <-- dlais	LOAD.L	A2,A3		; A2 <-- ^texte	LOAD.L	A3,#0		; A3 <-- source dans l'cran	LOAD.L	A4,(A6)+OPITEMP	; A4 <-- ^image destination	LOAD.L	D4,#H'10000*LYICO+LXICO	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	XFERZONE	; OPITEMP <-- sauve partie de l'cran	PUSH.L	D3	LOAD.L	D4,D3	LOAD.W	D3,#ICOBULLE	PUSH.L	(A6)+OPITEMP	CLR.L	(A6)+OPITEMP	CALL	DRCOLORICO	; choix des couleurs	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',T	30$		; oui => 30$	TSET.L	D3:#BICOMASK	LOAD.W	D2,#SETDOT	CALL	DRICONE		; efface le fond	TCLR.L	D3:#BICOMASK	LOAD.W	D2,#CLRDOT	CALL	DRICONE		; dessine la chair	JUMP'	35$30$:	TSET.L	D3:#BICOMASK	LOAD.W	D2,#CLRDOT	CALL	DRICONE		; efface le fond	TCLR.L	D3:#BICOMASK	LOAD.W	D2,#SETDOT	CALL	DRICONE		; dessine la chair35$:	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_BLANC	POP.L	(A6)+OPITEMP	LOAD.L	A3,A2		; A3 <-- ^texte	LOAD.W	D2,#-137$:	INC.W	D2		; D2 <-- nb de caractres	TEST.B	(A3+)	JUMP,NE 37$	MUL.WU	D2,(A0)+ODFCX	; D2 <-- largeur totale	SR.W	D2,#1	LOAD.L	D3,D4	ADD.W	D3,#1+(LXICO/2)	SUB.W	D3,D2	SWAP.W	D3	ADD.W	D3,#2+14+12	SWAP.W	D3	LIB	?SETCURS	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_VERT	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',T	40$		; oui => 40$	LOAD.B	D3,#AFINV	LIB	?AFCAR40$:	LOAD.L	D4,D1	SWAP.W	D4		; D4 <-- frappe	NTREL	?DELMS		; attend un peu ...42$:	LOAD.B	D3,(A2+)	JUMP',EQ 48$	TEST.B	(A6)+OFLAGS:#BFMAJUS	JUMP',BC 44$	LIB	?MINMAJ44$:	LIB	?AFCAR		; affiche un caractre	COMP.B	D3,#SPACE	JUMP,EQ 42$	JUMP	40$48$:	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_BLANC	LOAD.B	D3,#AFDIR	LIB	?AFCAR	POP.L	D3	LOAD.W	D4,D1		; D4 <-- dure	NTREL	?DELMS		; attend un peu ...	LOAD.L	A3,(A6)+OPITEMP	; A3 <-- ^image source	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.L	D4,#H'10000*LYICO+LXICO	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	XFERZONE	; restitue partie de l'cran	CALL	GCBIG		; utilise les caractres standard	POPM.L	D1..D4,A2..A4	RET;---------\\; AFLETTRE >;=========/; Affiche juste une lettre.; in	-; out	-; mod	D7.WAFLETTRE:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS	CLR.W	(A3)	LOAD.W	D3,(A6)+OLETTRE	; D3 <-- lettre choisie	COMP.W	D3,#'A	JUMP',LO 50$	COMP.W	D3,#'Z	JUMP',HI 50$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule	LOAD.B	(A3),D350$:	CALL	AFTEXT	POPM.L	D3,A3	RET;--------\\; AFTEXT  >;========/; Affiche un texte, en bas  gauche.; in	A3.L	^texte; out	-; mod	D7.WAFTEXT:	PUSHM.L	D2..D4,A3,A4	LOAD.W	(A0)+ODFCSF+2,#COLOR_BLANC	LOAD.W	(A0)+ODFCCF+2,#COLOR_ROUGE	LOAD.L	D3,#-1	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',T	10$		; oui => 10$	CLR.L	D310$:	LOAD.L	D4,D3	CALL	DRTRADEF	LOAD.L	D3,#H'10000*PTEXTY+PTEXTX	LOAD.L	D4,#H'10000*LTEXTY+LTEXTX	LOAD.W	D2,#LOADDOT	CALL	DRTRAME		; efface	LOAD.L	A4,A3	LOAD.W	D4,#-120$:	INC.W	D4		; D4 <-- nb de caractres	TEST.B	(A4+)	JUMP,NE 20$	MUL.WU	D4,(A0)+ODFCX	; D4 <-- largeur	TEST.W	D4	JUMP,EQ 90$	LOAD.W	D3,#LTEXTY	SUB.W	D3,(A0)+ODFC1Y	TEST.B	(A6)+OFLAGS:#BFMAJUS	JUMP',BS 30$	SUB.W	D3,(A0)+ODFC2Y30$:	SR.W	D3,#1	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,#PTEXTY	SWAP.W	D3	LOAD.W	D3,#LTEXTX	SUB.W	D3,D4	SR.W	D3,#1	ADD.W	D3,(A0)+ODFC1X	ADD.W	D3,#PTEXTX	LIB	?SETCURS	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',F	50$		; non => 50$	LOAD.B	D3,#AFINV	LIB	?AFCAR50$:	LOAD.B	D3,(A3+)	JUMP',EQ 60$	TEST.B	(A6)+OFLAGS:#BFMAJUS	JUMP',BC 55$	LIB	?MINMAJ55$:	LIB	?AFCAR		; affiche le texte	JUMP	50$60$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR90$:	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_BLANC	POPM.L	D2..D4,A3,A4	RET; Gestion des dbox; ----------------;-----------\\; DBOXQUITTE >;===========/; Quitte TOTO ?; in	-; out	D3.W	F1/F4; mod	D7.WDBOXQUITTE:	PUSHM.L	D0..D2,D4..D6,A3..A5	CALL	GCLITTLE	; utilise les petits caractres	CALL	NMOUSE		; souris = flche normale	CALL	SCMO		; visible	LOAD.W	D1,#DBOX_QUITTE	LOAD.L	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	DBOX_	EXTEND		; demande s'il faut quitter ...	CALL	CCMO		; invisible	CALL	LMOUSE		; souris = main	CALL	AFMENU		; refait les soft-keys	CALL	GCBIG		; utilise les caractres standard	POPM.L	D0..D2,D4..D6,A3..A5	RET;----------\\; DBOXPREND >;==========/; Lit un fichier histoire .TOTO; in	-; out	-; mod	D7.WDBOXPREND:	PUSHM.L	D0..D6,A3..A5	CALL	GCLITTLE	; utilise les petits caractres	CALL	NMOUSE		; souris = flche normale	CALL	SCMO		; visible10$:	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	LOAD.W	D1,#DBOX_PREND	LOAD.L	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A5,#(A6)+OBUFILE ; A5 <-- ^nom  diter	DBOX_	EXTEND		; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP,NE 90$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#(A6)+OBUFILE ; A3 <-- ^nom	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier .TOTO	JUMP',EQ 40$	COMP.W	D7,#ERKSTO	; annule ?	JUMP,EQ 90$		; oui => 90$30$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	LOAD.W	D3,#BIPERR	LIB	?BEEP	POP.W	D7	LOAD.W	D2,#2^BDBSAV	DBOX_	MERROR		; affiche l'erreur ...	JUMP	10$40$:	LOAD.L	A4,#(A6)+OHIST	LOAD.L	D4,#LHIST	FOS	?RDBYTE		; lit le fichier .TOTO	LOAD.W	D5,D7	FOS	?CLOSE		; ferme le fichier .TOTO	LOAD.W	D7,#ERNEMEM	; D7 <-- mmoire pleine	TEST.W	D5	JUMP,EQ 30$	LOAD.W	D7,D5	COMP.W	D7,#EROUTF	JUMP,NE 30$	CLR.B	(A4)+(D4.L)	; met un <0> terminateur	CLR.W	(A6)+OPHIST	SET.B	(A6)+OPLAY	; hop, raconte90$:	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	CALL	CCMO		; invisible	CALL	LMOUSE		; souris = main	CALL	AFMENU		; refait les soft-keys	CALL	GCBIG		; utilise les caractres standard	POPM.L	D0..D6,A3..A5	RET;----------\\; DBOXSAUVE >;==========/; Sauve un fichier histoire .TOTO; in	-; out	-; mod	D7.WDBOXSAUVE:	PUSHM.L	D0..D6,A3..A5	CALL	GCLITTLE	; utilise les petits caractres	CALL	NMOUSE		; souris = flche normale	CALL	SCMO		; visible10$:	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	LOAD.W	D1,#DBOX_SAUVE	LOAD.L	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A5,#(A6)+OBUFILE ; A5 <-- ^nom  diter	DBOX_	EXTEND		; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP',EQ 15$	COMP.W	D3,#F4	JUMP,NE 90$15$:	LOAD.W	D1,D3		; D1 <-- F1/F4	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier20$:	LOAD.L	A3,#(A6)+OBUFILE ; A3 <-- ^nom	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier .TOTO	JUMP,EQ 25$		; ok => 25$	COMP.W	D7,#ERKSTO	; annule ?	JUMP,EQ 90$		; oui => 90$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	30$		; non => 30$				; oui =>	COMP.W	D1,#F4		; touche (MET A JOUR) ?	JUMP',EQ 22$		; oui => 22$	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	TEST.W	D7	JUMP',NE 30$	COMP.W	D3,#'O	JUMP,NE 10$22$:	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE 90$	JUMP	20$25$:	LOAD.L	A3,#(A6)+OBUFILE ; A3 <-- ^nom	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier .TOTO	JUMP',EQ 40$	COMP.W	D7,#ERKSTO	; annule ?	JUMP,EQ 90$		; oui => 90$30$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	LOAD.W	D3,#BIPERR	LIB	?BEEP	POP.W	D7	LOAD.W	D2,#2^BDBSAV	DBOX_	MERROR		; affiche l'erreur ...	JUMP	10$40$:	LOAD.L	A4,#(A6)+OHIST	LOAD.L	A3,A4	LOAD.L	D4,#-142$:	INC.L	D4	TEST.B	(A3+)	JUMP,NE 42$	FOS	?WRBYTE		; crit le fichier .TOTO	JUMP',EQ 50$	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier .TOTO	POP.W	D7	JUMP	30$50$:	FOS	?CLOSE		; ferme le fichier .TOTO	JUMP,NE 30$90$:	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	CALL	CCMO		; invisible	CALL	LMOUSE		; souris = main	CALL	AFMENU		; refait les soft-keys	CALL	GCBIG		; utilise les caractres standard	POPM.L	D0..D6,A3..A5	RET;-------------\\; DBOXHISTOIRE >;=============/; Dbox pour choisir l'histoire.; in	-; out	D3.W	dernire touche (CR/END);	D7.W	erreur; mod	D3.L, D7.WDBOXHISTOIRE:	PUSHM.L	D0..D2,D4,D5,A1..A5	CALL	GCLITTLE	; utilise les petits caractres	CALL	NMOUSE		; souris = flche normale	CALL	SCMO		; visible	LOAD.L	A3,#(A6)+OHIST	LOAD.L	A4,#(A6)+OBUDIS10$:	LOAD.B	(A4+),(A3+)	; OBUDIS <-- histoire	JUMP,NE 10$	DEC.L	A4	LOAD.L	A3,#(A6)+OBUDIS	CLR.L	D4	LOAD.L	A2,#R16"TDBOX_HISTOIRE	LOAD.W	D2,#2^BDBSAV!2^BDBMAX	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_HISTOIRE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP,EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP',EQ 40$	COMP.W	D3,#'A	JUMP',LO 30$	COMP.W	D3,#'Z	JUMP',LS 50$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:	LOAD.L	A4,A3	CLR.B	(A3)	JUMP	20$50$:	TEST.B	(A6)+OFLAGS:#BFMAJUS	JUMP',BS 52$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule52$:	LOAD.L	A5,#(A6)+OBUDIS+100	LOAD.B	(A5),D3	CLR.B	(A5)+1	LOAD.W	D3,#36	LIB	?INSERT		; insre une lettre	JUMP	20$70$:	LOAD.L	A3,#(A6)+OHIST	LOAD.L	A4,#(A6)+OBUDIS72$:	LOAD.B	(A3+),(A4+)	; OHIST <-- histoire	JUMP,NE 72$80$:	DBOX_	CLOSE		; ferme la DBOX90$:	CALL	CCMO		; invisible	CALL	LMOUSE		; souris = main	CALL	AFMENU		; refait les soft-keys	CALL	GCBIG		; utilise les caractres standard	POPM.L	D0..D2,D4,D5,A1..A5	RETTDBOX_HISTOIRE:	.W	10$-TDBOX_HISTOIRE	.W	20$-TDBOX_HISTOIRE	.W	0,010$:	.B	ODBCR	.B	ODBTABX,3	.B	ODBTEXT	.ASCIZ	" Script de l'histoire :"	.B	ODBTABX,3+26	.B	ODBLINE,36	.B	ODBTABX,3+1+62+2+3	.B	ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,'A,TDBOMBRE	.ASCIZ	"acrobatie "	.B	ODBBOX,0,'G,TDBOMBRE	.ASCIZ	" galetas  "	.B	ODBBOX,0,'M,TDBOMBRE	.ASCIZ	" mlasse  "	.B	ODBBOX,0,'S,TDBOMBRE	.ASCIZ	"  soleil  "	.B	ODBBOX,0,'Y,TDBOMBRE	.ASCIZ	" yogourt  "	.B	ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,'B,TDBOMBRE	.ASCIZ	"   bain   "	.B	ODBBOX,0,'H,TDBOMBRE	.ASCIZ	" histoire "	.B	ODBBOX,0,'N,TDBOMBRE	.ASCIZ	"  navire  "	.B	ODBBOX,0,'T,TDBOMBRE	.ASCIZ	"tlvision"	.B	ODBBOX,0,'Z,TDBOMBRE	.ASCIZ	"  zigzag  "	.B	ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,'C,TDBOMBRE	.ASCIZ	"  cuire   "	.B	ODBBOX,0,'I,TDBOMBRE	.ASCIZ	" illusion "	.B	ODBBOX,0,'O,TDBOMBRE	.ASCIZ	"  orage   "	.B	ODBBOX,0,'U,TDBOMBRE	.ASCIZ	"  urgent  "	.B	ODBBOX,0,'-,TDBOMBRE	.ASCIZ	"          "	.B	ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,'D,TDBOMBRE	.ASCIZ	"  dessin  "	.B	ODBBOX,0,'J,TDBOMBRE	.ASCIZ	" jumeaux  "	.B	ODBBOX,0,'P,TDBOMBRE	.ASCIZ	"  poupe  "	.B	ODBBOX,0,'V,TDBOMBRE	.ASCIZ	"varicelle "	.B	ODBBOX,0,'-,TDBOMBRE	.ASCIZ	"          "	.B	ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,'E,TDBOMBRE	.ASCIZ	"  cran   "	.B	ODBBOX,0,'K,TDBOMBRE	.ASCIZ	"kangourou "	.B	ODBBOX,0,'Q,TDBOMBRE	.ASCIZ	"  queue   "	.B	ODBBOX,0,'W,TDBOMBRE	.ASCIZ	"  wagon   "	.B	ODBBOX,0,'-,TDBOMBRE	.ASCIZ	"          "	.B	ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,'F,TDBOMBRE	.ASCIZ	"   fte   "	.B	ODBBOX,0,'L,TDBOMBRE	.ASCIZ	"   lune   "	.B	ODBBOX,0,'R,TDBOMBRE	.ASCIZ	" robinet  "	.B	ODBBOX,0,'X,TDBOMBRE	.ASCIZ	"xylophone "	.B	ODBBOX,0,'-,TDBOMBRE	.ASCIZ	"          "	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	"        D'ACCORD       "	.B	ODBTEXT	.ASCIZ	"             "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"        ANNULE         "	.B	ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_HISTOIRE:	.W	F1,F2,F3,CR,0		DOKCR-TKEY_HISTOIRE	.W	F0,F13,F14,F15,END,0	DOKEND-TKEY_HISTOIRE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_HISTOIRE	.W	0;----------\\; DBOXCHOIX >;==========/; Dbox pour choisir le mode.; in	-; out	D3.W	dernire touche (CR/END);	D7.W	erreur; mod	D3.L, D7.WDBOXCHOIX:	PUSHM.L	D0..D2,D4,D5,A1..A4	CALL	GCLITTLE	; utilise les petits caractres	CALL	NMOUSE		; souris = flche normale	CALL	SCMO		; visible	CLR.L	D4	LOAD.B	D4,(A6)+OFLAGS	LOAD.L	A2,#R16"TDBOX_CHOIX	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_CHOIX	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP',EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP',EQ 80$	COMP.W	D3,#KEYDBOX!BFMAJUS	JUMP',EQ 50$	COMP.W	D3,#KEYDBOX!BFMINUS	JUMP',EQ 51$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:	TSET.L	D4:#BFMAJUS	TCLR.L	D4:#BFMINUS	JUMP	20$51$:	TCLR.L	D4:#BFMAJUS	TSET.L	D4:#BFMINUS	JUMP	20$70$:	LOAD.B	(A6)+OFLAGS,D480$:	DBOX_	CLOSE		; ferme la DBOX90$:	CALL	CCMO		; invisible	CALL	LMOUSE		; souris = main	CALL	AFMENU		; refait les soft-keys	CALL	GCBIG		; utilise les caractres standard	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CHOIX:	.W	10$-TDBOX_CHOIX	.W	20$-TDBOX_CHOIX	.W	0,010$:	.B	ODBLCIRCLE,BFMINUS!2^7!2^6,KEYDBOX/H'100,BFMINUS	.ASCIZ	" lettres minuscules"	.B	ODBCR	.B	ODBLCIRCLE,BFMAJUS!2^7!2^6,KEYDBOX/H'100,BFMAJUS	.ASCIZ	" lettres MAJUSCULES"	.B	ODBCR	.B	ODBCR	.B	ODBSQUARE,BFSON	.ASCIZ	" musiques et bruitages"	.B	ODBCR	.B	ODBSQUARE,BFSOURIS	.ASCIZ	" choix aussi avec la souris (main)"	.B	ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CHOIX:	.W	F1,F2,F3,CR,0		DOKCR-TKEY_CHOIX	.W	F0,F13,F14,F15,END,0	DOKEND-TKEY_CHOIX	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CHOIX	.W	0;--------\\; ZEROCR  >;--------/; Remplace le terminateur <CR> par <0>.; Utile aprs DBOX_EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>90$:	POP.L	A3	RET;--------\\; ERCALL  >;--------/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RETDOKCR:	LOAD.W	D3,#CR	RETDOKEND:	LOAD.W	D3,#END	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETTEXT_IO:	.ASCIZ	".TOTO"		; extensionTDBOX_IO:	.ASCIZ	"TOTO"		; nom du logiciel	.ASCIZ	"Fhistoire"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN; Processus fils; --------------NFILS1:	.ASCIZ	"TOTO_SOUND"	.EVENPFILS1:LOOP$:	TEST.B	(A6)+OABORT	; fin ?	JUMP',T	END$		; oui => END$				; non =>	LOAD.W	D3,(A6)+OSOUND	JUMP',EQ DEL$	CLR.W	(A6)+OSOUND	COMP.W	(A6)+OMACHINE,#SMAKY300	JUMP',NE PLAY$	COMP.W	D3,#TMUSPINPON	JUMP',EQ PRIO$PLAY$:	CALL	PATATRA		; fait le bruit	JUMP	LOOP$PRIO$:	NTREL	?GETPRIO	INC.B	D4	NTREL	?SETPRIO	; moins prioritaire (comme pre)	CALL	PATATRA		; fait le bruit	DEC.B	D4	NTREL	?SETPRIO	; remet comme avant	JUMP	LOOP$DEL$:	LOAD.W	D4,#50/10	NTREL	?DELMS		; attend un peu	JUMP	LOOP$END$:	NTREL	?ABORT; Gestion des bruits; ------------------;--------\\; PATATRA >;========/; Fait un bruit rigolo !; in	D3.W	#TMUSxxx; out	-; mod	D7.WPATATRA:	PUSHM.L	D3,A4	TEST.B	(A6)+OFLAGS:#BFSON	JUMP,BC EXIT$	COMP.W	(A6)+OMACHINE,#SMAKY300	JUMP',EQ AUDIO$SIMPLE$:	COMP.W	D3,#200		; musique audio ?	JUMP,LO EXIT$		; oui => EXIT$	LOAD.L	A4,#R16"ADCODE	AND.L	D3,#H'FFFF	; ADD.W A4,D3 impossible si D3.W ngatif !	ADD.L	D3,A4	LOAD.L	A4,D3	TEST.W	(A4)	JUMP,EQ EXIT$	LIB	?PLAY		; joue avec le pilote $SYNT	JUMP	EXIT$AUDIO$:	COMP.W	D3,#200		; musique audio ?	JUMP',LO APLAY$		; oui => APLAY$	LOAD.L	A4,#R16"TABLE$-4ASRC$:	ADD.L	A4,#4		; A4 <-- ^suivant	TEST.W	(A4)		; fin de la table ?	JUMP',EQ AMUS$		; oui => AMUS$	COMP.W	D3,(A4)	JUMP,NE ASRC$	LOAD.W	D3,(A4)+2	; D3 <-- musique audioAPLAY$:	CALL	SNDPLAY		; fait entendre un son audio	JUMP'	EXIT$AMUS$:	LOAD.L	A4,#R16"ADCODE	AND.L	D3,#H'FFFF	; ADD.W A4,D3 impossible si D3.W ngatif !	ADD.L	D3,A4	LOAD.L	A4,D3	TEST.W	(A4)	JUMP',EQ EXIT$	CALL	SNDMUSIQUEEXIT$:	POPM.L	D3,A4	RETTABLE$:	.W	TMUSTAC,MA_TOC	.W	TMUSTIC,MA_TIC	.W	TMUSEFF1,MA_HUU	.W	TMUSEFF2,MA_HUU	.W	TMUSEFF3,MA_COUP	.W	TMUSBAD,MA_AIE	.W	TMUSECRSHOW,MA_TUU	.W	TMUSECRUP,MA_HUU	.W	TMUSECRDOWN,MA_SYMB	.W	TMUSESCALIER,MA_SYMB	.W	TMUSSPLAF,MA_AIE	.W	TMUSGLOUGLOU,MA_HUU	.W	TMUSBON,MA_MIAM	.W	TMUSFLIC,MA_SYMB	.W	TMUSFLAC,MA_TUU	.W	TMUSGICLE,MA_SYMB	.W	TMUSTOMBE,MA_GC	.W	TMUSMAGICF,MA_TOM	.W	TMUSMAGICC,MA_TOM	.W	TMUSMAGICA,MA_TOM	.W	TMUSMAGICE,MA_TOM	.W	TMUSCOULE,MA_TIC	.W	TMUSCUIRE,MA_COUP	.W	TMUSXYHAUT,MA_TOM	.W	TMUSXYBAS,MA_CLOCHE	.W	TMUSGYM1,MA_CLOCHE	.W	TMUSGYM2,MA_HUU	.W	TMUSFADA1,MA_AIE;	.W	TMUSFADA2,MA_AIE	.W	TMUSNUAGE1,MA_SYMB	.W	TMUSNUAGE2,MA_SYMB	.W	TMUSNUAGE3,MA_SYMB	.W	TMUSNUAGE4,MA_SYMB	.W	TMUSORAGE1,MA_CLAP	.W	TMUSORAGE2,MA_CLAP;	.W	TMUSFACHE,MA_SYMB	.W	0; Gestion du clavier; ------------------;--------\\; GETCAR  >;========/; Attend une action.; in	-; out	D3.W	touche presse; mod	D3.L, D7.WGETCAR:	PUSHM.L	D4,A4	TEST.B	(A6)+OPLAY	; raconte une histoire ?	JUMP',T	50$		; oui => 50$10$:	LIB	?IFCAR		; vide le fifo du clavier	JUMP,EQ 10$	CALL	SCMO		; remet la souris	LIB	?GETCAR		; attend une touche ...	JUMP	90$50$:	LIB	?IFCAR		; une touche presse ?	JUMP',NE 52$	COMP.W	D3,#END	JUMP',EQ 70$	COMP.W	D3,#F7	JUMP',EQ 70$	COMP.W	D3,#F7+SHIFT	JUMP',EQ 70$	COMP.W	D3,#F8	JUMP',EQ 70$	COMP.W	D3,#F8+SHIFT	JUMP',EQ 70$	COMP.W	D3,#F9	JUMP',EQ 70$	COMP.W	D3,#F9+SHIFT	JUMP',EQ 70$	JUMP	50$52$:	LOAD.L	A4,#(A6)+OHIST	LOAD.W	D4,(A6)+OPHIST	CLR.W	D3	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- touche de l'histoire	JUMP',EQ 70$	INC.W	(A6)+OPHIST	JUMP'	90$70$:	CLR.B	(A6)+OPLAY	; fin de l'histoire	CALL	MAJMENU		; mj. les soft-keys	CALL	_SNDDONE	JUMP	10$90$:	POPM.L	D4,A4	RET;--------\\; IFCAR   >;========/; Regarde si une touche est presse.; in	-; out	D3.W	touche presse;	D7.W	erreur; mod	D3.L, D7.WIFCAR:	LOAD.W	D7,#1	TEST.B	(A6)+OPLAY	; raconte une histoire ?	JUMP',T	90$		; oui => 90$	LIB	?IFCAR		; une touche presse ?90$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; GCLITTLE >;=========/; Utilise les petits caractres.; in	-; out	-; mod	D7.WGCLITTLE:	LIB	?AFTIM	.B	USEGC		; utilise les petits caractres	.B	GCTXF	.B	GCTXS	.B	GCTXTP	.B	0	.EVEN	RET;---------\\; GCBIG    >;=========/; Utilise les grands caractres.; in	-; out	-; mod	D7.WGCBIG:	LIB	?AFTIM	.B	USEGC		; utilise les caractres standard	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	RET; Gestion de la souris; --------------------;--------\\; CCMO    >;========/; Enlve la flche de la souris.; in	-; out	-; mod	-CCMO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	POPM.L	D3,D7	RET;--------\\; SCMO    >;========/; Remet la flche de la souris.; in	-; out	-; mod	-SCMO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	POPM.L	D3,D7	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; LMOUSE  >;========/; Souris = main.; in	-; out	-; mod	D7.WLMOUSE:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#(A6)+OBULUT	LOAD.B	(A3+),#58	; dx	LOAD.B	(A3+),#32	; dy	LOAD.L	A4,(A6)+OPGICO	; A4 <-- ^gencar chair	LOAD.L	A4,#(A4)+OGCMAT	; A4 <-- ^matrice icne zro	LOAD.W	D3,#32-120$:	LOAD.L	(A3+),(A4+)	LOAD.L	(A3+),(A4+)	ADD.L	A4,#2	DECJ.W,NMO D3,20$	LOAD.L	A3,#(A6)+OBULUT+500	LOAD.B	(A3+),#58	; dx	LOAD.B	(A3+),#32	; dy	LOAD.L	A4,(A6)+OPFICO	; A4 <-- ^gencar fond	LOAD.L	A4,#(A4)+OGCMAT	; A4 <-- ^matrice icne zro	LOAD.W	D3,#32-130$:	LOAD.L	(A3+),(A4+)	LOAD.L	(A3+),(A4+)	ADD.L	A4,#2	DECJ.W,NMO D3,30$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	LOAD.L	A4,#(A6)+OBULUT	LOAD.L	(A3)+1,A4	LOAD.L	A4,#(A6)+OBULUT+500	LOAD.L	(A3)+5,A4	LOAD.W	D3,#9	LIB	?STRING	POPM.L	D3,D4,A3,A4	RET;--------\\; NMOUSE  >;========/; Souris = flche normale.; in	-; out	-; mod	D7.WNMOUSE:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	CLR.L	(A3)+1	CLR.L	(A3)+5	LOAD.W	D3,#9	LIB	?STRING	POPM.L	D3,A3	RET;--------\\; MMOUSE  >;========/; Met la souris au milieu de la fentre.; in	-; out	-; mod	D7.WMMOUSE:	PUSH.L	D4	LOAD.W	D4,#306	ADD.W	D4,(A6)+OOIMA+0	SWAP.W	D4	LOAD.W	D4,#173	ADD.W	D4,(A6)+OOIMA+2	LIB	?PMOUSE	POP.L	D4	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	-; out	-; mod	-AFMENU:	LOAD.W	(A6)+OOMENU,#-1;	JUMP'	MAJMENU;--------\\; MAJMENU >;========/; Met  jour les soft-keys.; in	-; out	-; mod	-MAJMENU:	PUSHM.L	D3,D4,D7,A3,A4	CLR.L	D4	TEST.B	(A6)+OHIST	; histoire existe ?	JUMP',NE 10$		; oui => 10$	TSET.L	D4:#BMNNOHIS10$:	TEST.B	(A6)+OPLAY	; raconte une histoire ?	JUMP',F	12$		; non => 12$	TSET.L	D4:#BMNRACON12$:	COMP.W	D4,(A6)+OOMENU	; qq chose de chang ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A3,#R16"TXMENUR	TEST.L	D4:#BMNRACON	JUMP',BS 60$	LOAD.L	A3,#R16"TXMENU	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D3,#PTXM-120$:	LOAD.B	(A4+),(A3+)	; OBUDIS <-- .ASCIZ des soft-keys	DECJ.W,NMO D3,20$	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^menu dans les variables	TEST.L	D4:#BMNNOHIS	JUMP',BC 60$	LOAD.B	(A3)+PTXMSA,#AFGREY	LOAD.B	(A3)+PTXMRA,#AFGREY60$:	LIB	?AFMENU		; affiche les soft-keys	LOAD.W	(A6)+OOMENU,D490$:	POPM.L	D3,D4,D7,A3,A4	RETTXMENU:	.ASCIZ	"Fin"	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCII	"Prend       "PTXMSA	= .-TXMENU	.ASCIZ	"<AFFULL>Sauve<AFFULL>"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"     Histoire    "		;     ;     ;     ;	.ASCIZ	""PTXMRA	= .-TXMENU	.ASCIZ	"<AFFULL>     Raconte     <AFFULL>"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	"      Liste Choix"	.ASCIZ	""		;     ;     ;     ;PTXM	= .-TXMENUTXMENUR:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"  <'>><'>><'>> Arrt <'<><'<><'<>  "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN; Routines de construction d'icnes "fond"; ----------------------------------------;---------\\; CALCFOND >;=========/; Fait un double de ITP80 (chair) pour gnrer les fonds.; in	-; out	D7.W	erreur; mod	D7.WCALCFOND:	PUSHM.L	D1..D4,A3,A4	LOAD.L	A3,(A6)+OPGICO	; A3 <-- ^gencar ITP80	LOAD.W	D4,#128	MUL.WU	D4,(A3)+OGCMSB	ADD.L	D4,#OGCMAT	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour copie ITP80	JUMP,NE 90$	LOAD.L	(A6)+OPFICO,A4	; OPFICO <-- ^gencar "fond"	SR.L	D4,#2	DEC.W	D420$:	LOAD.L	(A4+),(A3+)	DECJ.W,NMO D4,20$	CALL	OPEDISMAT	; dessin en mmoire	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	DRTRADEF	LOAD.B	D3,#AFFILLA	; rempli tout	LIB	?AFCAR	LOAD.L	A4,(A6)+OPFICO	; A4 <-- ^gencar fond	LOAD.W	D4,(A4)+OGCMHD	; D4 <-- hauteur en points	SWAP.W	D4	CLR.W	D4	LOAD.B	D4,(A4)+OGCMWB	; D4 <-- largeur en bytes	SL.W	D4,#3		; D4 <-- largeur en points	LOAD.W	D3,(A4)+OGCMSB	; D3 <-- taille d'une matrice	ADD.L	A4,#OGCMAT	; A4 <-- ^premire matrice	LOAD.W	D2,#128-140$:	CALL	CALCFONDONE	; calcule une matrice	ADD.W	A4,D3		; A4 <-- ^matrice suivante	DECJ.W,NMO D2,40$	CALL	CLODISMAT	; dessin dans l'cran	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; CALCFONDONE >;------------/; in	A4.L	^matrice;	D4.L	^dimensions (dy;dx); out	-; mod	D7.WCALCFONDONE:	PUSHM.L	D3,D4	CALL	NEWDISMAT	CLR.L	D3	CALL	DRFILL		; rempli	CALL	DRINV		; puis inverse90$:	POPM.L	D3,D4	RET; Routines graphiques rapides; ---------------------------;----------\\; OPEDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	-; out	-; mod	D7.WOPEDISMAT:	LOAD.L	(A6)+OSDDIS+ODFABS,(A0)+ODFABS	LOAD.W	(A6)+OSDDIS+ODFIIX,(A0)+ODFIIX	LOAD.W	(A6)+OSDDIS+ODFIIY,(A0)+ODFIIY	LOAD.L	(A6)+OSDDIS+ODFY,(A0)+ODFY	LOAD.L	(A6)+OSDDIS+ODFDY,(A0)+ODFDY	LOAD.L	(A6)+OSDDIS+ODFFY,(A0)+ODFFY	LOAD.L	(A6)+OSDDIS+ODFFDY,(A0)+ODFFDY	LOAD.L	(A6)+OSDDIS+ODFWBY,(A0)+ODFWBY	LOAD.L	(A6)+OSDDIS+ODFWEY,(A0)+ODFWEY	LOAD.B	(A6)+OSDDIS+ODFCMD,(A0)+ODFCMD	RET;----------\\; NEWDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement en mmoire en mode n/b.; in	A4.L	^matrice o dessiner;	D4.L	^dimensions (dy;dx); out	-; mod	D7.WNEWDISMAT:	PUSH.L	D4	LOAD.L	(A0)+ODFABS,A4	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	LOAD.W	(A0)+ODFIIX,#1	SR.W	D4,#3	LOAD.W	(A0)+ODFIIY,D4	POP.L	D4	RET;-----------\\; NEWDISMATC >;===========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement en mmoire en couleur.; in	A4.L	^matrice o dessiner;	D4.L	^dimensions (dy;dx); out	-; mod	D7.WNEWDISMATC:	PUSHM.L	D3,D4	LOAD.L	(A0)+ODFABS,A4	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	LOAD.W	(A0)+ODFIIX,#1	SR.W	D4,#3	CLR.W	D3	LOAD.B	D3,(A0)+ODFCNP	; D3 <-- nb de bits/pixel	MUL.WU	D4,D3	LOAD.W	(A0)+ODFIIY,D4	LOAD.B	(A0)+ODFCMD,#2	; dessine en couleur	POPM.L	D3,D4	RET;----------\\; CLODISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.WCLODISMAT:	LOAD.L	(A0)+ODFABS,(A6)+OSDDIS+ODFABS	LOAD.W	(A0)+ODFIIX,(A6)+OSDDIS+ODFIIX	LOAD.W	(A0)+ODFIIY,(A6)+OSDDIS+ODFIIY	LOAD.L	(A0)+ODFY,(A6)+OSDDIS+ODFY	LOAD.L	(A0)+ODFDY,(A6)+OSDDIS+ODFDY	LOAD.L	(A0)+ODFFY,(A6)+OSDDIS+ODFFY	LOAD.L	(A0)+ODFFDY,(A6)+OSDDIS+ODFFDY	LOAD.L	(A0)+ODFWBY,(A6)+OSDDIS+ODFWBY	LOAD.L	(A0)+ODFWEY,(A6)+OSDDIS+ODFWEY	LOAD.B	(A0)+ODFCMD,(A6)+OSDDIS+ODFCMD	RET;----------\\; MOVEOBJET >;==========/; Dplace un objet sur l'cran.; in	A5.L	^objet; out	D7.W	erreur; mod	D7.WMOVEOBJET:	PUSHM.L	D2..D4,A3,A4BEGIN$:	LOAD.L	A4,(A5)+OOMPTA	COMP.W	(A4),#TMBEGIN	JUMP',NE BEGIN2$	ADD.L	A4,#2	LOAD.L	(A5)+OOLPOS,(A4+)	LOAD.W	(A5)+OOMDEL,(A4+)	LOAD.L	(A5)+OOMPTA,A4	CLR.W	(A5)+OOMCTNBEGIN2$:	TEST.W	(A5)+OOMCTN	JUMP,NE NEXT$; Cherche l'lment suivant dans la table.LOOP$:	LOAD.L	A4,(A5)+OOMPTA	LOAD.W	D7,#EROUTF	TEST.W	(A4)		; fin de la table ?	JUMP,EQ EXIT$		; oui => EXIT$	COMP.W	(A4),#TMLINK	JUMP',NE NOLINK$	CALL	GETADCODE	; LOAD.L A3,#R16"ADCODE	ADD.W	A3,(A4)+2	LOAD.L	(A5)+OOMPTA,A3	JUMP	BEGIN$NOLINK$:	CALL	MOVETM		; objet spcial TMxxxx ?	JUMP',NE NOSPEC$	; non => NOSPEC$	LOAD.L	(A5)+OOMPTA,A4	JUMP	LOOP$NOSPEC$:	LOAD.L	(A5)+OOMPTB,A4	LOAD.W	(A5)+OOMCTN,(A4+)	ADD.L	A4,#4	LOAD.W	(A5)+OOMNBI,#-1CNTICO$:	INC.W	(A5)+OOMNBI	TEST.W	(A4+)	JUMP,NE CNTICO$	CLR.W	(A5)+OOMCTI	LOAD.L	(A5)+OOMPTA,A4; Cherche la nouvelle position et la nouvelle icne.NEXT$:	LOAD.L	A4,(A5)+OOMPTB	; A4 <-- ^lment prcdent	DEC.W	(A5)+OOMCTN	LOAD.W	D4,(A5)+OOLPOS+0	ADD.W	D4,(A4)+2	LOAD.W	(A5)+OONPOS+0,D4	LOAD.W	D4,(A5)+OOLPOS+2	ADD.W	D4,(A4)+4	LOAD.W	(A5)+OONPOS+2,D4	TEST.W	(A5)+OOMNBI	; dplacement sans icne ?	JUMP',EQ MOVE$		; oui => MOVE$	LOAD.W	D3,(A5)+OOMCTI	SL.W	D3,#1	LOAD.W	(A5)+OOICON,(A4)+(D3.W)+6	SR.W	D3,#1	INC.W	D3	COMP.W	D3,(A5)+OOMNBI	JUMP',LO CTI$	CLR.W	D3CTI$:	LOAD.W	(A5)+OOMCTI,D3	COMP.W	(A5)+OOICON,#-1	JUMP,EQ DELEND$; Fait ventuellement un bruit.	LOAD.L	A4,#R16"TICOSOUND ; A4 <-- ^table des icnes-sons	LOAD.W	D4,(A5)+OOICON	AND.W	D4,#H'7F	SL.W	D4,#1	LOAD.W	D4,(A4)+(D4.W)	; D4 <-- son associ  l'icne	JUMP',EQ MOVE$	LOAD.W	(A6)+OSOUND,D4; Bouge l'objet sur l'cran.MOVE$:	TEST.W	(A5)+OOMNBI	; dplacement sans icne ?	JUMP',EQ MRIEN$		; oui => MRIEN$	LOAD.W	D3,(A5)+OONPOS+0	LOAD.W	D4,(A5)+OOLPOS+0	COMP.W	D3,D4	JUMP',LE MIY$	EX.L	D3,D4		; EX.W D3,D4MIY$:	ADD.W	D4,#LYICO	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A5)+OONPOS+2	LOAD.W	D4,(A5)+OOLPOS+2	COMP.W	D3,D4	JUMP',LE MIX$	LOAD.W	D2,D3	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D2MIX$:	ADD.W	D4,#LXICO	SUB.W	D4,D3	CALL	PGD3D4		; D3/D4 <-- position/dimensions selon GETOB/PUTOB	JUMP'	ORIGINE$MRIEN$:	LOAD.W	D3,(A5)+OOLPOS+0	LOAD.W	D4,(A5)+OONPOS+0	COMP.W	D3,D4	JUMP',EQ MRY1$	JUMP',LE MRY2$	EX.L	D3,D4		; EX.W D3,D4	ADD.W	D3,#LYICOMRY1$:	ADD.W	D4,#LYICOMRY2$:	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A5)+OOLPOS+2	LOAD.W	D4,(A5)+OONPOS+2	COMP.W	D3,D4	JUMP',EQ MRX1$	JUMP',LE MRX2$	LOAD.W	D2,D3	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D2	ADD.W	D3,#LXICOMRX1$:	ADD.W	D4,#LXICOMRX2$:	SUB.W	D4,D3ORIGINE$:	LOAD.L	A3,(A6)+OPIFFIX	LOAD.L	A4,(A6)+OPITEMP	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	XFERZONE	; OPITEMP <-- remet image originale	PUSHM.L	D3,D4	TEST.W	(A5)+OOMNBI	; dplacement sans icne ?	JUMP',EQ NOICO$		; oui => NOICO$	LOAD.L	D4,(A5)+OONPOS	; D4 <-- nouvelle position	LOAD.W	D3,(A5)+OOICON	; D3 <-- icne	CALL	DROBJET		; dessine l'objet	LOAD.W	D3,(A5)+OOICON	COMP.W	D3,#ICOASCV	; ascenseur vide ?	JUMP,EQ MEND$	COMP.W	D3,#ICOASCT	; ascenseur avec toto ?	JUMP,EQ MEND$	COMP.W	D3,#123	JUMP,EQ MEND$	COMP.W	D3,#124	JUMP,EQ MEND$	COMP.W	D3,#125	JUMP,EQ MEND$	COMP.W	D3,#126	JUMP,EQ MEND$NOICO$:	TEST.B	(A6)+OECRAN	; cran droul ?	JUMP,T	MEND$		; oui => MEND$	TEST.B	(A6)+OPLAN	; dessine devant ?	JUMP',NE ASCH$		; oui => ASCH$	LOAD.L	D3,(A5)+OONPOS	LOAD.L	D4,#H'10000*LYICO+LXICO	LOAD.L	A3,(A6)+OPIMAF	LOAD.L	A4,(A6)+OPITEMP	LOAD.W	D2,#CLRDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	XFERZONE	; OPITEMP <-- masque selon le fond	LOAD.L	A3,(A6)+OPIMAC	LOAD.L	A4,(A6)+OPITEMP	LOAD.W	D2,#SETDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	XFERZONE	; OPITEMP <-- masque selon la chairASCH$:	TEST.B	(A6)+OASC:#BASCH	JUMP',BC ASCB$	LOAD.W	D3,#ICOASCV	LOAD.L	D4,#H'10000*PASCHY+PASCHX	CALL	DROBJET		; dessine l'ascenseur en hautASCB$:	TEST.B	(A6)+OASC:#BASCB	JUMP',BC MEND$	LOAD.W	D3,#ICOASCV	LOAD.L	D4,#H'10000*PASCBY+PASCBX	CALL	DROBJET		; dessine l'ascenseur en basMEND$:	POPM.L	D3,D4	LOAD.L	A3,(A6)+OPITEMP	LOAD.L	A4,#0	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	XFERZONE	; met  jour l'cran	CALL	MMOUSE		; remet la souris au milieu de la fentre	CLR.W	D4	TEST.B	(A6)+OQUICK	;  toute vitesse ?	JUMP',T	DELGO$		; oui => DELGO$	LOAD.W	D4,(A5)+OOMDELDELGO$:	COMP.W	(A6)+OMACHINE,#SMAKY100	JUMP',EQ DELWAIT$	COMP.W	D4,#2	JUMP',HI DELWAIT$	LOAD.W	D4,#2DELWAIT$:	TEST.W	D4	JUMP',EQ DELEND$	NTREL	?DELMS		; attend un peu ...DELEND$:	LOAD.L	(A5)+OOLPOS,(A5)+OONPOS	TEST.W	(A5)+OOMNBI	; dplacement sans icne ?	JUMP,EQ OK$		; oui => OK$	COMP.W	(A5)+OOICON,#ICOASCV ; ascenseur vide ?	JUMP',EQ IFASC$		; oui => IFASC$	COMP.W	(A5)+OOICON,#ICOASCT ; toto sur l'ascenseur ?	JUMP',NE NOASC$		; non => NOASC$IFASC$:	LOAD.B	(A6)+OASC,#2^BASCH	COMP.W	(A5)+OOLPOS+0,#PASCHY ; ascenseur en haut ?	JUMP',EQ NOASC$	LOAD.B	(A6)+OASC,#2^BASCB	COMP.W	(A5)+OOLPOS+0,#PASCBY ; ascenseur en bas ?	JUMP',EQ NOASC$	CLR.B	(A6)+OASCNOASC$:	COMP.W	(A5)+OOICON,#ICOSOLEIL ; soleil ?	JUMP',NE NOSOLEIL$	TCLR.B	(A6)+OFIXOB+3:#BFOSOLEIL-0	COMP.L	(A5)+OOLPOS,#H'10000*PSOLEY+PSOLEX	JUMP',NE NOSOLEIL$	TSET.B	(A6)+OFIXOB+3:#BFOSOLEIL-0NOSOLEIL$:	COMP.W	(A5)+OOICON,#ICOLUNE ; lune ?	JUMP',NE NOLUNE$	TCLR.B	(A6)+OFIXOB+3:#BFOLUNE-0	COMP.L	(A5)+OOLPOS,#H'10000*PLUNEY+PLUNEX	JUMP',NE NOLUNE$	TSET.B	(A6)+OFIXOB+3:#BFOLUNE-0NOLUNE$:OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RETTICOSOUND:	.W	0		; 0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 8	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 16	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 24	.W	0	.W	0	.W	0	.W	TMUSFADA1	; s'est cass la figure	.W	TMUSFADA2	; s'est cass la figure	.W	0	.W	0	.W	0		; 32	.W	0	.W	0	.W	0	.W	0	.W	0	.W	MA_HUU		; fch	.W	0	.W	0		; 40	.W	TMUSXYHAUT	; xylophone	.W	TMUSXYBAS	; xylophone	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 48	.W	0	.W	MA_HUU		; la poupe boit	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 56	.W	TMUSTIC		; mange yogourt	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 64	.W	0	.W	0	.W	0	.W	0	.W	TMUSGYM1	; gymnastique	.W	TMUSGYM2	; gymnastique	.W	0	.W	0		; 72	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 80	.W	0	.W	0	.W	TMUSTAC		; allume la plaque	.W	0	.W	0	.W	0	.W	0	.W	0		; 88	.W	0	.W	0	.W	0	.W	0	.W	0	.W	TMUSTIC		; descend l'cran	.W	0	.W	0		; 96	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 104	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 112	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	TMUSFLIC	; splaf dans la crme	.W	TMUSFLAC	; idem	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0;--------\\; MOVETM  >;--------/; Traite les objet spciaux TMxxx contenus dans la table.; in	A4.L	^dans table; out	A4.L	^plus loin;	D7.W	erreur; mod	D7.W, A4.LMOVETM:	PUSHM.L	D2..D4,A3	LOAD.W	D7,#1		; D7 <-- pas un objet TMxxxx	TEST.W	(A4)	JUMP,NC EXIT$	LOAD.W	D4,(A4+)	; D4 <-- objet TMxxxx	COMP.W	D4,#TMPLAN	JUMP',EQ PLAN$	COMP.W	D4,#TMFLASH	JUMP,EQ FLASH$	COMP.W	D4,#TMDEL	JUMP,EQ DEL$	COMP.W	D4,#TMLINOB	JUMP,EQ LINOB$	COMP.W	D4,#TMGETOB	JUMP,EQ GETOB$	COMP.W	D4,#TMPUTOB	JUMP,EQ PUTOB$	COMP.W	D4,#TMSOUND	JUMP,EQ SOUND$	COMP.W	D4,#TMTEXT	JUMP,EQ TEXT$	COMP.W	D4,#TMSKIPNE	JUMP,EQ SKIPNE$	COMP.W	D4,#TMSKIPEQ	JUMP,EQ SKIPEQ$	COMP.W	D4,#TMICOOB	JUMP,EQ ICOOB$	COMP.W	D4,#TMCOLOR	JUMP,EQ COLOR$	JUMP	EXIT$PLAN$:	LOAD.W	D4,(A4+)	LOAD.B	(A6)+OPLAN,D4	JUMP	OK$FLASH$:	CLR.L	D3	LOAD.L	D4,(A6)+ODIMA	CALL	DRINV		; inverse tout l'cran	LOAD.W	D4,(A4+)	NTREL	?DELMS		; attente selon t1	CLR.L	D3	LOAD.L	D4,(A6)+ODIMA	CALL	DRINV		; inverse tout l'cran	LOAD.W	D4,(A4+)	NTREL	?DELMS		; attente selon t2	JUMP	OK$DEL$:	LOAD.W	(A5)+OOMDEL,(A4+)	JUMP	OK$LINOB$:	LOAD.L	D3,(A4+)	LOAD.L	D4,(A4+)	LOAD.W	D2,(A4+)	CALL	LINOBJET	; dessine une ligne	JUMP	OK$GETOB$:	LOAD.L	D3,(A4+)	LOAD.L	D4,(A4+)	CALL	GETOBJET	; prend un objet	JUMP	OK$PUTOB$:	LOAD.L	D3,(A4+)	LOAD.L	D4,(A4+)	CALL	PUTOBJET	; repose un objet	JUMP	OK$SOUND$:	LOAD.W	(A6)+OSOUND,(A4+)	JUMP	OK$TEXT$:	LOAD.L	A3,A4		; A3 <-- ^texte .ASCIZ	CALL	AFTEXT		; affiche texte en bas  gaucheTEXT2$:	TEST.B	(A4+)		; A4 <-- saute .ASCIZ	JUMP,NE TEXT2$	LOAD.L	D4,A4	TEST.L	D4:#0	JUMP,BC OK$	INC.L	A4		; A4 <-- saute .EVEN	JUMP	OK$SKIPNE$:	ADD.L	A4,#+8		; A4 <-- saute SKIPNE et paramtres	LOAD.L	A3,A6	ADD.W	A3,(A4)-8+0	; A3 <-- ^variable	LOAD.W	D3,(A3)		; D3 <-- valeur variable	COMP.W	D3,(A4)-8+2	; effectue le test	JUMP',LO SKIP$	COMP.W	D3,(A4)-8+4	; effectue le test	JUMP',HI SKIP$	JUMP	OK$SKIPEQ$:	ADD.L	A4,#+8		; A4 <-- saute SKIPEQ et paramtres	LOAD.L	A3,A6	ADD.W	A3,(A4)-8+0	; A3 <-- ^variable	LOAD.W	D3,(A3)		; D3 <-- valeur variable	COMP.W	D3,(A4)-8+2	; effectue le test	JUMP,LO OK$	COMP.W	D3,(A4)-8+4	; effectue le test	JUMP,HI OK$SKIP$:	CALL	GETADCODE	; LOAD.L A3,#R16"ADCODE	CLR.L	D4	LOAD.W	D4,(A4)-8+6	ADD.L	A3,D4		; A4 <-- adresse absolue si NE	LOAD.L	A4,A3	JUMP	OK$ICOOB$:	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_VERT	LOAD.L	D3,(A4+)	LOAD.L	D4,(A4+)	CALL	ICOOBJET	; dessine une bulle (histoire)	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_BLANC	JUMP'	OK$COLOR$:	LOAD.W	D2,(A4+)	; D2 <-- COLOR_*	LOAD.W	D3,(A4+)	; D3 <-- nb	LOAD.W	D4,(A4+)	; D4 <-- dlai	CALL	COLORCHANGE	; change une couleur	ADD.L	A4,#6+6		; A4 <-- saute RGB,RGB;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; COLORCHANGE >;============/; Change une couleur progressivement.; in	D2.W	COLOR_*;	D3.W	nb (1..n);	D4.W	dlai (0..n);	A4.L	^RGB dpart puis RGB arrive; out	-; mod	D7.WCOLORCHANGE:	PUSHM.L	D0..D5	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.W	D1,D2		; D1 <-- COLOR_*	LOAD.W	D0,D3		; D0 <-- nb	CLR.W	D2		; D2 <-- stepLOOP$:	PUSH.W	D4	LOAD.W	D3,(A4)+6+0	SUB.W	D3,(A4)+0	; D3 <-- a-d	MUL.WA	D3,D2		; D3 <-- (a-d)*s	DIV.WA	D3,D0		; D3 <-- [(a-d)*s]/n	ADD.W	D3,(A4)+0	LOAD.W	D4,(A4)+6+2	SUB.W	D4,(A4)+2	; D4 <-- a-d	MUL.WA	D4,D2		; D4 <-- (a-d)*s	DIV.WA	D4,D0		; D4 <-- [(a-d)*s]/n	ADD.W	D4,(A4)+2	LOAD.W	D5,(A4)+6+4	SUB.W	D5,(A4)+4	; D5 <-- a-d	MUL.WA	D5,D2		; D5 <-- (a-d)*s	DIV.WA	D5,D0		; D5 <-- [(a-d)*s]/n	ADD.W	D5,(A4)+4	CALL	DRCOLORMOD	; modifie une fausse couleur	POP.W	D4	TEST.W	D4	JUMP',EQ NEXT$	NTREL	?DELMS		; attend un p'tit peuNEXT$:	INC.W	D2		; D2 <-- step +1	COMP.W	D2,D0	JUMP,LS LOOP$EXIT$:	POPM.L	D0..D5	RET;---------\\; XFERZONE >;---------/; Transfert une partie d'image dans une autre.; in	A3.L	^image source;	A4.L	^image destination;	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WXFERZONE:	PUSHM.L	D1..D6	LOAD.L	D1,D4	LOAD.L	D4,D3	COMP.L	A3,#0		; source dans l'cran ?	JUMP',NE 10$		; non => 10$				; oui =>	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',T	10$		; oui => 10$	TSET.L	D2:#BCPLDOT10$:	COMP.L	A4,#0		; destination dans l'cran ?	JUMP',NE 20$		; non => 20$				; oui =>	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',T	20$		; oui => 20$	TSET.L	D2:#BCPLDOT20$:	LOAD.W	D5,(A6)+ODIMA+2	SR.W	D5,#3	LOAD.W	D6,D5	CALL	DRRASTER	POPM.L	D1..D6	RET;--------\\; DROBJET >;========/; Dessine un objet (icne chair et fond) dans l'image cache (OPITEMP).; in	D3.W	code de l'icne (0..127);	D4.L	position coin sup/gauche (y;x); out	-; mod	D7.WDROBJET:	PUSHM.L	D2,D3	COMP.W	D3,#-1	JUMP',EQ EXIT$	CALL	DRCOLORICO	; choix des couleurs	TSET.L	D3:#BICOMASK	LOAD.W	D2,#CLRDOT	CALL	DRICONE		; efface le fond	TCLR.L	D3:#BICOMASK	LOAD.W	D2,#SETDOT	CALL	DRICONE		; dessine la chair	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ END$		; non => END$	TEST.L	D3:#BICOSYMB	JUMP',BS END$	CALL	DRCOLOR90	; choix de la couleur	TSET.L	D3:#BICOCOUL	CALL	DRICONE		; dessine la couleurEND$:	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_BLANCEXIT$:	POPM.L	D2,D3	RET;-----------\\; DRCOLORICO >;===========/; Choix de la couleur pour une icne.; in	D3.W	icne; out	-; mod	D7.WDRCOLORICO:	PUSHM.L	D3,A3	LOAD.L	A3,#R16"TCITP90	AND.W	D3,#H'007F	MUL.WU	D3,#6	ADD.W	A3,D3	LOAD.W	(A0)+ODFCSF+2,(A3+)	LOAD.W	(A0)+ODFCCF+2,(A3+)	POPM.L	D3,A3	RET;----------\\; DRCOLOR90 >;==========/; Choix de la couleur pour une icne ITP90.; in	D3.W	icne; out	-; mod	D7.WDRCOLOR90:	PUSHM.L	D3,A3	LOAD.L	A3,#R16"TCITP90	AND.W	D3,#H'007F	MUL.WU	D3,#6	ADD.W	A3,D3	LOAD.W	(A0)+ODFCSF+2,(A3)+4	POPM.L	D3,A3	RETTCITP90:	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_JAUNE,COLOR_FOND1	; tlvision	.W	COLOR_NOIR,COLOR_JAUNE,COLOR_FOND1	.W	COLOR_NOIR,COLOR_JAUNE,COLOR_FOND1	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_ROSE,COLOR_BLANC	; toto voit des toiles	.W	COLOR_NOIR,COLOR_ROUGE,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BRUN	; toto ouvre l'armoire	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BRUN	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_ROSE,COLOR_BLANC	; toto est fch	.W	COLOR_NOIR,COLOR_ROUGE,COLOR_BLANC	.W	COLOR_NOIR,COLOR_ROSE,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	; toto joue du xylophone	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_JAUNE,COLOR_ROSE	; soleil	.W	COLOR_NOIR,COLOR_JAUNE,COLOR_BRUN	; lune	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_VERT,COLOR_BLANC	; bulle (pour l'cran)	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROSE	; toto tient la poupe	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROSE	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	; toto ouvre le frigo	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_BRUN,COLOR_FOND1,COLOR_BLANC	; nuage	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_ROUGE,COLOR_BLANC	; toto dit "robinet"	.W	COLOR_NOIR,COLOR_ROSE,COLOR_BLANC	; toto tombe	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	; toto est malade	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	; toto tourne (acrobatie)	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	; toto cuisine	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BRUN	; toto joue avec la mlasse	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BRUN	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BRUN	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BRUN	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BRUN	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	; toto lit un livre	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	; toto marche avec le livre	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_VERT	; toto tient le navire en bouteille	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	; coup de baguette magique	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	; idem, de face	.W	COLOR_NOIR,COLOR_ROSE,COLOR_BLANC	; toto est fch	.W	COLOR_NOIR,COLOR_ROSE,COLOR_BLANC	.W	COLOR_NOIR,COLOR_ROSE,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_ROUGE	; toto est malade	.W	COLOR_NOIR,COLOR_TOTO,COLOR_FOND1	; toto joue avec le wagon	.W	COLOR_NOIR,COLOR_TOTO,COLOR_FOND1	.W	COLOR_NOIR,COLOR_TOTO,COLOR_FOND1	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	; toto a une queue	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC	.W	COLOR_NOIR,COLOR_TOTO,COLOR_BLANC.IF 0;-------------\\; DRCOLORTABLE >;=============/; Modifie plusieurs fausses couleurs.; in	A3.L	^table des couleurs (TC*); out	-; mod	D7.WDRCOLORTABLE:	PUSHM.L	D1,D3..D5,A3LOOP$:	CLR.W	D1	LOAD.B	D1,(A3+)	; D1 <-- COLOR_*	JUMP',NS EXIT$	LOAD.B	D3,(A3+)	; D3 <-- rouge	LOAD.B	D4,(A3+)	; D4 <-- vert	LOAD.B	D5,(A3+)	; D5 <-- bleu	CALL	DRCOLORMOD	; modifie une fausse couleur	JUMP	LOOP$EXIT$:	POPM.L	D1,D3..D5,A3	RETTCDEF:	.B	COLOR_BLANC	255,255,255	.B	COLOR_JAUNE	255,205,68	.B	COLOR_ROUGE	255,0,0	.B	COLOR_ROSE	255,191,221	.B	COLOR_TOTO	255,255,0	.B	COLOR_BRUN	167,106,106	.B	COLOR_VERT	0,255,0	.B	COLOR_FOND1	0,255,255	.B	COLOR_FOND2	0,230,255	.B	COLOR_FOND3	0,200,255	.B	COLOR_FOND4	0,157,253	.B	COLOR_FOND5	0,90,248	.B	COLOR_FOND6	0,37,223	.B	COLOR_FOND7	0,13,200	.B	COLOR_FOND8	0,0,167	.B	-1	.EVEN.ENDIF;------------\\; DRCOLORMOD  >;------------/; Modifie une fausse couleur.; in	D1.W	fausse couleur (0..n);	D3.B	rouge;	D4.B	vert;	D5.B	bleu; out	-; mod	D7.WDRCOLORMOD:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+100+1	LOAD.B	(A3)+0,#COLORFALSE	CLR.W	(A3)+1	LOAD.W	(A3)+3,D1	LOAD.B	(A3)+5,D3	LOAD.B	(A3)+6,D3	LOAD.B	(A3)+7,D4	LOAD.B	(A3)+8,D4	LOAD.B	(A3)+9,D5	LOAD.B	(A3)+10,D5	LOAD.W	D3,#11	LIB	?STRING	POPM.L	D3,A3	RET;--------\\; DRICONE >;========/; Dessine une icne de chair (0..127) ou de fond (128..255); dans l'image cache (OPITEMP).; in	D3.W	code de l'icne (0..255);	D4.L	position coin sup/gauche (y;x);	D2.W	mode; out	-; mod	D7.WDRICONE:	PUSHM.L	D0..D6,A3,A4	LOAD.W	D0,D3	TEST.L	D3:#BICOSYMB	JUMP',BC 10$	LOAD.L	A4,(A6)+OPSICO	; A4 <-- ^gencar symboles	AND.W	D3,#H'7F	JUMP'	20$10$:	TEST.L	D3:#BICOCOUL	JUMP',BC 12$	LOAD.L	A4,(A6)+OPCICO	; A4 <-- ^gencar couleurs	AND.W	D3,#H'7F	JUMP'	20$12$:	LOAD.L	A4,(A6)+OPGICO	; A4 <-- ^gencar chair	AND.W	D3,#H'FF	TCLR.L	D3:#BICOMASK	JUMP',BC 20$	LOAD.L	A4,(A6)+OPFICO	; A4 <-- ^gencar fond20$:	LOAD.W	D1,(A4)+OGCMHD	; D1 <-- hauteur en points	SWAP.W	D1	CLR.W	D1	LOAD.B	D1,(A4)+OGCMWB	; D1 <-- largeur en bytes	SL.W	D1,#3		; D1 <-- largeur en points	LOAD.L	A3,#(A4)+256	; A3 <-- ^table des largeurs	CLR.W	D5	LOAD.B	D5,(A4)+OGCLCA	SUB.B	D5,(A4)+OGCFCA	INC.B	D5		; D5 <-- nb de caractres	ADD.W	A3,D5		; A3 <-- ^table des h1	ADD.W	A3,D5		; A3 <-- ^table des h2	ADD.W	A3,D5		; A3 <-- ^premire matrice	MUL.WU	D3,(A4)+OGCMSB	ADD.L	A3,D3		; A3 <-- ^la bonne matrice	CLR.L	D3		; D3 <-- origine source	CLR.W	D5	LOAD.B	D5,(A4)+OGCMWB	; D5 <-- Iy source	LOAD.L	A4,(A6)+OPITEMP	; A4 <-- ^destination	LOAD.W	D6,(A6)+ODIMA+2	SR.W	D6,#3		; D6 <-- Iy destination	TEST.L	D0:#BICODEMIH	JUMP',BC 40$	SWAP.W	D1	SUB.W	D1,#LYICO/2	SWAP.W	D1	SWAP.W	D4	ADD.W	D4,#LYICO/2	SWAP.W	D440$:	TEST.L	D0:#BICODEMIB	JUMP',BC 42$	SWAP.W	D1	SUB.W	D1,#(LYICO/2)+1	SWAP.W	D1	SWAP.W	D3	ADD.W	D3,#(LYICO/2)+1	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,#(LYICO/2)+1	SWAP.W	D442$:	TSET.L	D2:#BDSTCOUL	CALL	DRRASTER	; dessine l'icne	POPM.L	D0..D6,A3,A4	RET;--------\\; DRRECT  >;========/; Dessine un rectangle.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRRECT:	PUSHM.L	D3..D5	LOAD.L	D5,D4		; D5 <-- dimensions (dy;dx)	AND.L	D4,#H'FFFF	CALL	DRLINE		; trace ligne suprieure	LOAD.L	D4,D5	CLR.W	D4	CALL	DRLINE		; trace ligne de droite	LOAD.L	D4,D5	AND.L	D4,#H'FFFF	NEG.W	D4	CALL	DRLINE		; trace ligne infrieure	LOAD.L	D4,D5	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DRLINE		; trace ligne de gauche	POPM.L	D3..D5	RET;---------\\; DRRASTER >;=========/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D1.L	hauteur/largeur (y;x);	D2.W	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT); out	-; mod	D7.WDRRASTER:	PUSHM.L	D0..D6,A1,A2	TEST.W	D1		; dx <= 0 ?	JUMP,LE EXIT$	SWAP.W	D1	TEST.W	D1		; dy <= 0 ?	JUMP,LE EXIT$	SWAP.W	D1	EX.L	D1,D2		; D2/D1 <-- mode/dimensions	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	TEST.W	D4		; dpasse  gauche ?	JUMP',NC NoLeft$	ADD.W	D2,D4	JUMP,LE EXIT$	SUB.W	D3,D4	CLR.W	D4NoLeft$:	LOAD.W	D0,D4	ADD.W	D0,D2	SUB.W	D0,(A2)+ODFFDX	; dpasse  droite ?	JUMP',LS NoRight$	SUB.W	D2,D0	JUMP,LE EXIT$NoRight$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	TEST.W	D4		; dpasse en haut ?	JUMP',NC NoUp$	ADD.W	D2,D4	JUMP,LE EXIT$	SUB.W	D3,D4	CLR.W	D4NoUp$:	LOAD.W	D0,D4	ADD.W	D0,D2	SUB.W	D0,(A2)+ODFFDY	; dpasse en bas ?	JUMP',LS NoDown$	SUB.W	D2,D0	JUMP,LE EXIT$NoDown$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	CLR.W	D0	LOAD.B	D0,(A0)+ODFCNP	; D0 <-- nb de bits/pixel (1,4)	COMP.W	D0,#1	JUMP',NE COUL$	LOAD.L	A1,(A6)+OADRASTER	CALL	(A1)		; appel de GRA_RASTER	JUMP'	EXIT$COUL$:	TEST.L	D1:#BSRCCOUL	JUMP',BC CSRC$	MUL.WU	D5,D0		; D5 <-- Iy sourceCSRC$:	TEST.L	D1:#BDSTCOUL	JUMP',BC CDST$	MUL.WU	D6,D0		; D6 <-- Iy destinationCDST$:	LOAD.L	A1,(A6)+OADCRASTER	CALL	(A1)		; appel de GRA_CRASTEREXIT$:	POPM.L	D0..D6,A1,A2	RET;-------\\; DRDOT  >;=======/; Dessine un point.; in	D3.L	coordonne (y;x);	D2.W	mode; out	-; mod	D7.WDRDOT:	PUSHM.L	D1..D4,A1,A2	LOAD.W	D1,D2		; D1 <-- mode	LOAD.L	D4,D3		; D4 <-- y;x	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADDOT	CALL	(A1)		; appel de GRA_DOT	POPM.L	D1..D4,A1,A2	RET;--------\\; DRLINE  >;========/; Dessine un segment de droite.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	D3.L	coordonne d'arrive (y;x); mod	D3.L, D7.WDRLINE:	PUSHM.L	D1,D2,D4,A1,A2	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADLINE	CALL	(A1)		; appel de GRA_LINE	EX.L	D3,D4	ADD.W	D3,D4		; D3 <-- arrive en X	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- arrive en Y	SWAP.W	D3;	SWAP.W	D4	POPM.L	D1,D2,D4,A1,A2	RET;----------\\; DRELLIPSE >;==========/; Dessine une ellipse, ou un arc d'ellipse.; in	D3.L	coordonne centre (y;x);	D4.L	rayons (dy;dx);	D2.W	mode;	D1.B	bitmap des octants  dessiner; out	-; mod	D7.WDRELLIPSE:	PUSHM.L	D1..D4,A1,A2	EX.L	D1,D2		; D2/D1 <-- mode/octants	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADELLIPSE	CALL	(A1)		; appel de GRA_ELLIPSE	POPM.L	D1..D4,A1,A2	RET;---------\\; DRTRADEF >;=========/; Dfinit une trame.; ATTENTION: les bits sont retourns par-rapport  LIB,?DRMDEF !; in	D3.L	trame;	D4.L	trame; out	-; mod	D7.WDRTRADEF:	LOAD.L	(A0)+ODFTRA+0,D3	LOAD.L	(A0)+ODFTRA+4,D4	RET;---------\\; DRTRAME  >;=========/; Dessine une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRTRAME:	PUSHM.L	D1..D4,A1,A2,A4	TEST.W	D4		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D4	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A4,#(A0)+ODFTRA	; A4 <-- ^trame utilisateur	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADTRAME	CALL	(A1)		; appel de GRA_TRAME90$:	POPM.L	D1..D4,A1,A2,A4	RET;--------\\; DRZONE  >;========/; Efface, allume ou inverse une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRZONE:	COMP.B	D2,#INVDOT	JUMP,EQ DRINV	COMP.B	D2,#SETDOT	JUMP,EQ DRSET;---------\\; DRCLEAR  >;=========/; Efface une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRCLEAR:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D4	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADCLEAR	CALL	(A1)		; appel de GRA_SET90$:	POPM.L	D1..D4,A1,A2	RET;---------\\; DRSET    >;=========/; Allume une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRSET:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D4	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADSET	CALL	(A1)		; appel de GRA_SET90$:	POPM.L	D1..D4,A1,A2	RET;---------\\; DRINV    >;=========/; Inverse une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRINV:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE 90$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE 90$	SWAP.W	D4	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADINV	CALL	(A1)		; appel de GRA_INV90$:	POPM.L	D1..D4,A1,A2	RET;--------\\; DRFILL  >;========/; Rempli une surface quelconque.; in	D3.L	point de remplissage (y;x); out	D7.W	erreur; mod	D7.WDRFILL:	PUSHM.L	D1..D4,A1,A2	LOAD.L	D4,D3		; D4 <-- y;x	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADFILLO	CALL	(A1)		; appel de GRA_FILLO	PUSH.W	D7	LOAD.L	A1,(A6)+OADFILLC	CALL	(A1)		; appel de GRA_FILLC	POP.W	D7	POPM.L	D1..D4,A1,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; AFIMAGE >;========/; Affiche une image, sans la conserver en mmoire.; in	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WAFIMAGE:	PUSHM.L	D2..D4,A3,A4	PUSH.L	(A6)+ODIMA	CALL	LOADIMAGE	; charge l'image en mmoire	JUMP',NE 90$	LOAD.L	(A6)+ODIMA,D4	LOAD.L	A3,A4	LOAD.L	A4,#0	CLR.L	D3	LOAD.W	D2,#LOADDOT!2^BDSTCOUL	CALL	XFERZONE	LOAD.L	A4,A3	CALL	KILLIMAGE	; libre la mmoire	CLR.W	D7		; D7 <-- ok90$:	POP.L	(A6)+ODIMA	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; LOADIMAGE >;==========/; Charge une image en mmoire.; in	A3.L	^nom de l'image; out	A4.L	^image;	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	A4.L, D7.W, A4.LLOADIMAGE:	PUSHM.L	D0,D1,D3,D6,A1..A3	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE 90$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE 84$	LOAD.L	A4,A2	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$	COMP.B	(A2)+OIMTYP,#H'82 ; image du LAMI ?	JUMP',NE 20$		; non => 20$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute la stupide en-tte de 256 bytes !	JUMP,NE 82$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$20$:	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE 82$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP,NE 80$	JUMP'	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP,NE 80$	LOAD.L	A3,A1	GRA_	DECOIMA		; dcode l'image ...	JUMP,NE 80$35$:	LOAD.L	A4,A1		; A4 <-- ^image	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions de l'image	CLR.W	D7		; D7 <-- ok	JUMP'	82$80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D784$:	PUSHM.L	D7,A4	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POPM.L	D7,A490$:	POPM.L	D0,D1,D3,D6,A1..A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; CNBCIMAGE >;==========/; Converti une image n/b en couleurs.; in	A4.L	^image n/b;	D4.L	dimensions (dy;dx); out	A4.L	^image couleur;	D7.W	erreur; mod	D7.W, A4.LCNBCIMAGE:	PUSHM.L	D1..D4,A3	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ OK$		; non => OK$	LOAD.L	A3,A4	LOAD.L	D2,D4	LOAD.L	D3,D4	SWAP.W	D3	SR.W	D4,#3	MUL.WU	D4,D3	CLR.W	D1	LOAD.B	D1,(A0)+ODFCNP	; D1 <-- nb de bits/pixel	MUL.WU	D4,D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour image temporaire	JUMP',NE EXIT$	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_BLANC	CLR.L	D3	LOAD.L	D4,D2	LOAD.W	D2,#LOADDOT!2^BDSTCOUL	CALL	XFERZONE	; image couleur <-- image n/b	LOAD.W	(A0)+ODFCSF+2,#COLOR_NOIR	LOAD.W	(A0)+ODFCCF+2,#COLOR_BLANCOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; LOADCOLOR >;==========/; Charge une image couleur en mmoire.; in	A3.L	^nom de l'image; out	A4.L	^image;	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	A4.L, D7.W, A4.LLOADCOLOR:	PUSHM.L	D0..D3,D5,D6,A1..A3,A5	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE GIVHEAD$	LOAD.L	A4,A2	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE CLOSE$	LOAD.L	A5,#0	LOAD.L	D4,(A2)+OIMLGC	; CLUT existe ?	JUMP',EQ CEND$		; non => CEND$	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour la CLUT	JUMP,NE CLOSE$	LOAD.L	A5,A4		; A5 <-- ^buffer pour la CLUT	FOS	?RDBYTE		; lit la CLUT	JUMP,NE GIVCLUT$CEND$:	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	CLR.W	D2	LOAD.B	D2,(A2)+OIMBIP	; D2 <-- nb de bits/pixels	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D2	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF+10	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE GIVCLUT$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE DECO$		; oui => DECO$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP,NE GIVDATA$	JUMP'	DRAW$DECO$:	FOS	?RDBYTE		; lit toute l'image code	JUMP,NE GIVDATA$	LOAD.L	A3,A1;	PUSH.W	(A2)+OIMDLX;	PUSH.B	(A2)+OIMBIP	LOAD.W	D4,(A2)+OIMDLX	MUL.WU	D4,D2	LOAD.W	(A2)+OIMDLX,D4	LOAD.B	(A2)+OIMBIP,#1	GRA_	DECOIMA		; dcode l'image couleur ...;	POP.B	(A2)+OIMBIP;	POP.W	(A2)+OIMDLX	TEST.W	D7	JUMP,NE GIVDATA$DRAW$:	COMP.L	A5,#0		; CLUT existe ?	JUMP',EQ CLUT$		; non => CLUT$	PUSH.L	D6	LOAD.L	A3,A5		; A3 <-- ^CLUT lue	LOAD.L	D3,#2^BTCTABLE	; D3 <-- mode	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal pour TCOLOR	TCOL_	LOADCLUT	; change la CLUT de la fentre	POP.L	D6CLUT$:	LOAD.L	A4,A1		; A4 <-- ^image	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions de l'image	CLR.W	D7		; D7 <-- ok	JUMP'	GIVCLUT$GIVDATA$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D7GIVCLUT$:	COMP.L	A5,#0	JUMP',EQ CLOSE$	PUSHM.L	D7,A4	LOAD.L	A4,A5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de la CLUT	POPM.L	D7,A4CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7GIVHEAD$:	PUSHM.L	D7,A4	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POPM.L	D7,A4EXIT$:	POPM.L	D0..D3,D5,D6,A1..A3,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; KILLIMAGE >;==========/; Libre la mmoire d'une image.; in	A4.L	^image; out	-; mod	-KILLIMAGE:	PUSHM.L	D1,D7,A4	LOAD.L	A4,#(A4)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POPM.L	D1,D7,A4	RET; Tirage de nombres alatoires; ----------------------------;--------\\; COUPSAC >;========/; Coup de sac pour le gnrateur alatoire.; in	-; out	-; mod	D7.WCOUPSAC:	PUSHM.L	D3,D4	LIB	?RDCLOCK	; D3/D4 <-- date et heure	RR.L	D3,#3	RL.L	D4,#7		; savante cuisine	NOT.L	D3	XOR.L	D4,D3	LOAD.L	(A6)+OHAZA+0,D3	LOAD.L	(A6)+OHAZA+4,D4	LOAD.W	D3,#10-120$:	CALL	HAZARD		; tire qq nombres	DECJ.W,NMO D3,20$	POPM.L	D3,D4	RET;---------\\; EXHAZARD >;=========/; Tire un nombre alatoire exclusif.; in	D3.W	+/- borne infrieure (min);	D4.W	+/- borne suprieure (max+1);	A4.L	^table d'exclusion; out	D4.W	+/- nombre alatoire: D3 <= n < D4; mod	D4.L, D7.WEXHAZARD:	PUSHM.L	D0..D3,A3	LOAD.W	D2,D410$:	LOAD.W	D1,D2	SUB.W	D1,D3	MUL.WU	D1,#10		; D1 <-- nb max d'essais20$:	LOAD.W	D4,D2		; D4 <-- borne suprieure	CALL	MMHAZARD	; D4 <-- nombre alatoire	LOAD.W	D0,D4	SUB.W	D0,D3	TEST.B	(A4)+(D0.W)	; nombre dj sorti ?	JUMP',EQ 80$		; non => 80$				; oui =>	DEC.W	D1		; encore un essai ?	JUMP,NE 20$		; oui => 20$	LOAD.L	A3,A4	LOAD.W	D1,D2	SUB.W	D1,D340$:	CLR.B	(A3+)		; recommence le tirage exclusif	DEC.W	D1	JUMP,NE 40$	JUMP	10$80$:	SET.B	(A4)+(D0.W)	; celui-i est pris	POPM.L	D0..D3,A3	RET;---------\\; MMHAZARD >;=========/; Tire un nombre alatoire (16 bits) compris entre deux bornes.; in	D3.W	+/- borne infrieure (min);	D4.W	+/- borne suprieure (max+1); out	D4.W	+/- nombre alatoire: D3 <= n < D4; mod	D4.L, D7.WMMHAZARD:	PUSH.W	D2	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- sup - inf	CALL	HAZARD	AND.L	D4,#H'FFFF	DIV.WU	D4,D2	SWAP.W	D4		; D4 <-- reste de la division	ADD.W	D4,D3	POP.W	D2	RET;--------\\; HAZARD  >;========/; Tire un nombre alatoire de 32 bits.; On utilise un registre  dcalage de 63 bits, avec un XNOR entre; les bits 0 et 60 pour calculer le nouveau bit inject.; in	-; out	D4.L	nombre; mod	D4.L, D7.WHAZARD:	PUSHM.L	D2,D3	LOAD.W	D2,#32-1	LOAD.L	D3,(A6)+OHAZA+0	LOAD.L	D4,(A6)+OHAZA+410$:	TEST.L	D4:#1	JUMP',BC 20$	TEST.L	D3:#30	JUMP',BC 35$	JUMP'	30$20$:	TEST.L	D3:#30	JUMP',BS 35$30$:	CLRX	RRX.L	D3,#1	RRX.L	D4,#1	JUMP'	40$35$:	SETX	RRX.L	D3,#1	RRX.L	D4,#140$:	LOAD.L	(A6)+OHAZA+0,D3	LOAD.L	(A6)+OHAZA+4,D4	DECJ.W,NMO D2,10$	POPM.L	D2,D3	RET;--------\\; SNDREAD >;========/; Lit un fichier TOTO_M?.AUDIO; in	A3.L	^nom; out	A4.L	^data;	D4.L	lg data;	D7.W	erreur; mod	D4.L, D7.W, A4.LSNDREAD:	PUSHM.L	D1,D3,D6	LOAD.W	D3,#2^BOPRD!2^BOPSYS	FOS	?OPEN	JUMP',NE EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; D4 <-- longueur	PUSH.L	D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS	POP.L	D4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP',NE CLOSE$	FOS	?RDBYTECLOSE$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	POPM.L	D1,D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; SNDDONE >;========/; Indique la fin de qq chose.; in	-; out	-; mod	D7.WSNDDONE:	PUSHM.L	D3,D4	COMP.W	(A6)+OMACHINE,#SMAKY300	JUMP',NE SIMPLE$	LOAD.W	D3,#MA_MARCHE	LOAD.W	D4,#MA_SAMBA+1	CALL	MMHAZARD	LOAD.W	(A6)+OSOUND,D4	JUMP'	EXIT$SIMPLE$:	LOAD.W	(A6)+OSOUND,#TMUSDONEEXIT$:	POPM.L	D3,D4	RET;-----------\\; SNDMUSIQUE >;===========/; Joue une musique.; in	A4.L	^table; out	-; mod	D7.WSNDMUSIQUE:	PUSHM.L	D0..D4,D6,A2..A4	LOAD.L	A3,#R16"NMAUDIO	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre #AUDIO:	JUMP,NE QUIT$	LOAD.L	A3,A4	LOAD.L	A2,#R16"TABLE$LOOP$:	TEST.W	(A3)	JUMP,EQ EXIT$	CLR.L	D0	LOAD.W	D0,(A3+)	JUMP',EQ NOTE0$	SL.W	D0,#1	LOAD.W	D0,(A2)+(D0.W)	DIV.WU	D0,#3NOTE0$:	CLR.L	D1	LOAD.W	D1,(A3+)	JUMP',EQ NOTE1$	SL.W	D1,#1	LOAD.W	D1,(A2)+(D1.W)	DIV.WU	D1,#3NOTE1$:	CLR.L	D2	LOAD.W	D2,(A3+)	JUMP',EQ NOTE2$	SL.W	D2,#1	LOAD.W	D2,(A2)+(D2.W)	DIV.WU	D2,#3NOTE2$:;;?CLR.L D1	; <<<<<<< PARCE QUE LES ACCORDS SONNENT FAUX !!!!!CLR.L D2;;?	CLR.W	D4	LOAD.B	D4,(A3+)	; D4 <-- enveloppe	CLR.W	D3	LOAD.B	D3,(A3+)	; D3 <-- dure	JUMP',NE PLAY$	LOAD.W	D3,D4PLAY$:	SWAP.W	D4	LOAD.W	D4,D3	LOAD.L	A4,#(A6)+OBUSND	LOAD.W	D3,#(LADH/2)-1ZERO$:	CLR.W	(A4+)		; rempli l'en-tte de zro	DECJ.W,NMO D3,ZERO$	CALL	SNDACCORD	; calcule un accord	LOAD.L	A4,#(A4)-LADH	; A4 <-- ^en-tte	LOAD.B	(A4)+OADHTYP,#ADHTYPE	LOAD.L	(A4)+OADHLG,D4	LOAD.W	(A4)+OADHFREQ,#ADFREQ	ADD.L	D4,#LADH	FOS	?WRBYTE		; joue l'chantillon	JUMP	LOOP$EXIT$:	FOS	?CLOSE		; ferme #AUDIO:QUIT$:	POPM.L	D0..D4,D6,A2..A4	RET; Table des priodes pour les notes de la gamme tempre :TABLE$:	.W	3822.	3608.	3405.	3214.	3034.	2864.	.W	2703.	2551.	2408.	2273.	2145.	2025.	.W	1911.	1804.	1703.	1607.	1517.	1432.	.W	1351.	1276.	1204.	1136.	1073.	1012.	.W	956.	902.	851.	804.	758.	716.	.W	676.	638.	602.	568.	536.	506.	.W	478.	451.	426.	402.	379.	358.	.W	338.	319.	301.	284.	268.	253.	.W	239.	225.	213.	201.	190.	179.	.W	169.	159.	150.	142.	134.	127.	.W	119.	113.	106.	100.	95.	89.	.W	84.	80.	75.	71.	67.	63.	.W	60.	56.	53.	50.	47.	45.	.W	42.	40.	38.	36.	34.	32.	.W	30.	28.	27.	25.	24.	22.	.W	21.	20.	19.	18.	17.	16.	.W	15.	14.	13.	13.	12.	11.	.W	11.	10.	9.	9.	8.	8.	.W	7.	7.	7.	6.	6.	6.	.W	5.	5.	5.	4.	4.	4.	.W	4.	4.	3.	3.	3.	3.	.W	3.	2.	2.	2.	2.	2.	.W	2.	2.	2.	2.	1.	1.	.W	1.	1.	1.	1.	1.	1.	.W	1.	1.	1.	1.	1.	1.	.W	1.	1.	1.	1.	1.	1.;----------\\; SNDACCORD >;==========/; Joue un accord, compatible avec l'appel LIB ?ACCORD; in	D0.W	premire note;	D1.W	seconde note;	D2.W	troisme note;	D4.W	dure en [20ms];	D4.LH	enveloppe en [20ms];	A4.L	^destination; out	D4.L	longueur utilise; mod	D4.L, D7.WSNDACCORD:	PUSHM.L	D0..D3,D5,D6,A4	LOAD.L	D7,D4	SWAP.W	D7		; D7 <-- enveloppe	MUL.WU	D7,#ADFREQ/50	DIV.WU	D7,#ADNIVMAX/6	LOAD.W	D6,D7	SWAP.W	D7	LOAD.W	D7,D6		; D7 <-- copie dans high word	MUL.WU	D4,#ADFREQ/50	; D4 <-- longueur	PUSH.L	D4	LOAD.W	D5,#ADNIVMAX/6	; D5 <-- coefficient	CLR.L	D6		; D6 <-- clear flags	TEST.W	D0	JUMP',NE S1$	TSET.L	D6:#19		; D6 <-- la note 0 est un silenceS1$:	SWAP.W	D0		; D0 <-- mmorise dans le high word	LOAD.W	D0,#1		; D0 <-- rechargement au coup suivant	TEST.W	D1	JUMP',NE S2$	TSET.L	D6:#20		; D6 <-- la note 1 est un silenceS2$:	SWAP.W	D1		; D1 <-- mmorise dans le high word	LOAD.W	D1,#1		; D1 <-- rechargement au coup suivant	TEST.W	D2	JUMP',NE S3$	TSET.L	D6:#21		; D6 <-- la note 2 est un silenceS3$:	SWAP.W	D2		; D2 <-- mmorise dans le high word	LOAD.W	D2,#1		; D2 <-- rechargement au coup suivantLOOP$:	DEC.W	D0	JUMP',NE E1$	TNOT.L	D6:#16	SWAP.W	D0	LOAD.W	D6,D0	SWAP.W	D0	LOAD.W	D0,D6		; D0 <-- recharge le low wordE1$:	DEC.W	D1	JUMP',NE E2$	TNOT.L	D6:#17	SWAP.W	D1	LOAD.W	D6,D1	SWAP.W	D1	LOAD.W	D1,D6		; D1 <-- recharge le low wordE2$:	DEC.W	D2	JUMP',NE E3$	TNOT.L	D6:#18	SWAP.W	D2	LOAD.W	D6,D2	SWAP.W	D2	LOAD.W	D2,D6		; D2 <-- recharge le low wordE3$:	DEC.W	D7	JUMP',NE VAL$	TEST.W	D5	JUMP',EQ VAL$	DEC.W	D5		; D5 <-- coefficient diminue	SWAP.W	D7	LOAD.W	D6,D7	SWAP.W	D7	LOAD.W	D7,D6		; D7 <-- recharge le low wordVAL$:	LOAD.W	D3,#ADNIVMAX/2	; D3 <-- niveau "zro"	TEST.L	D6:#19		; note 0 = silence ?	JUMP',BS B1$	SUB.W	D3,D5	TEST.L	D6:#16	JUMP',BC B1$	ADD.W	D3,D5	ADD.W	D3,D5B1$:	TEST.L	D6:#20		; note 1 = silence ?	JUMP',BS B2$	SUB.W	D3,D5	TEST.L	D6:#17	JUMP',BC B2$	ADD.W	D3,D5	ADD.W	D3,D5B2$:	TEST.L	D6:#21		; note 2 = silence ?	JUMP',BS B3$	SUB.W	D3,D5	TEST.L	D6:#18	JUMP',BC B3$	ADD.W	D3,D5	ADD.W	D3,D5B3$:	LOAD.B	(A4+),D3	; buffer <-- crit l'chantillon	DEC.L	D4		; D4 <-- compteur de dure	JUMP,NE	LOOP$	POP.L	D4	POPM.L	D0..D3,D5,D6,A4	RET;--------\\; SNDPLAY >;========/; Fait entendre une parole (SMAKY-300).; in	D3.W	numro du son (1..n); out	D7.W	erreur; mod	D7.WSNDPLAY:	PUSHM.L	D2..D4,D6,A3,A4	COMP.W	(A6)+OMACHINE,#SMAKY300	JUMP,NE ERROR$	LOAD.L	A4,(A6)+OSNDP1	; A4 <-- ^data1	COMP.W	D3,#100	JUMP',LO DATA$	SUB.W	D3,#100-1	LOAD.L	A4,(A6)+OSNDP2	; A4 <-- ^data2DATA$:	LOAD.L	D4,A4		; data lu ?	JUMP,EQ ERROR$		; non => ERROR$SRC$:	DEC.W	D3	JUMP',EQ FOUND$	LOAD.L	D4,(A4)+OADHLG	; D4 <-- lg	LOAD.L	A4,#(A4)+(D4.L)+LADH ; A4 <-- ^suivant	JUMP	SRC$FOUND$:	LOAD.L	A3,#R16"NMAUDIO	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre #AUDIO:	JUMP',NE EXIT$	LOAD.L	D4,(A4)+OADHLG	; D4 <-- lg	ADD.L	D4,#LADH	FOS	?WRBYTE		; joue l'chantillon	FOS	?CLOSE		; ferme #AUDIO:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1EXIT$:	POPM.L	D2..D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RETNMAUDIO:.ASCIZ	"#AUDIO:"	.EVEN	.INS	TOTO_MTAB.ASI	.INS	TOTO_MMUS.ASI	.END	START