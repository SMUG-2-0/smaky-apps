	.SBTTL	RIGCOLOR.ASI;------------\\; COLORCHANGE >;============/; Change une couleur progressivement.; in	D2.W	COLOR_*;	D3.W	nb (1..n);	D4.W	dlai (0..n);	A4.L	^RGB dpart puis RGB arrive; out	-; mod	D7.WCOLORCHANGE:	PUSHM.L	D0..D5	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.W	D1,D2		; D1 <-- COLOR_*	LOAD.W	D0,D3		; D0 <-- nb	CLR.W	D2		; D2 <-- stepLOOP$:	PUSH.W	D4	LOAD.W	D3,(A4)+6+0	SUB.W	D3,(A4)+0	; D3 <-- a-d	MUL.WA	D3,D2		; D3 <-- (a-d)*s	DIV.WA	D3,D0		; D3 <-- [(a-d)*s]/n	ADD.W	D3,(A4)+0	LOAD.W	D4,(A4)+6+2	SUB.W	D4,(A4)+2	; D4 <-- a-d	MUL.WA	D4,D2		; D4 <-- (a-d)*s	DIV.WA	D4,D0		; D4 <-- [(a-d)*s]/n	ADD.W	D4,(A4)+2	LOAD.W	D5,(A4)+6+4	SUB.W	D5,(A4)+4	; D5 <-- a-d	MUL.WA	D5,D2		; D5 <-- (a-d)*s	DIV.WA	D5,D0		; D5 <-- [(a-d)*s]/n	ADD.W	D5,(A4)+4	CALL	DRCOLORMOD	; modifie une fausse couleur	POP.W	D4	TEST.W	D4	JUMP',EQ NEXT$	NTREL	?DELMS		; attend un p'tit peuNEXT$:	INC.W	D2		; D2 <-- step +1	COMP.W	D2,D0	JUMP,LS LOOP$EXIT$:	POPM.L	D0..D5	RET;------------\\; DRCOLORMOD  >;------------/; Modifie une fausse couleur.; in	D1.W	fausse couleur (0..n);	D3.B	rouge;	D4.B	vert;	D5.B	bleu; out	-; mod	D7.WDRCOLORMOD:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#COLORFALSE	CLR.W	(A3)+1	LOAD.W	(A3)+3,D1	LOAD.B	(A3)+5,D3	LOAD.B	(A3)+6,D3	LOAD.B	(A3)+7,D4	LOAD.B	(A3)+8,D4	LOAD.B	(A3)+9,D5	LOAD.B	(A3)+10,D5	LOAD.W	D3,#11	LIB	?STRING	POPM.L	D3,A3	RET	.END