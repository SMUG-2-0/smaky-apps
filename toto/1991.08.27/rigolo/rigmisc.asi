	.SBTTL	RIGMISC.ASI;---------\\; OPEDISBM >;=========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans le bitmap temporaire.; in	-; out	-; mod	D7.WOPEDISBM:	PUSH.L	D4	LOAD.L	(A6)+OSDDIS+ODFABS,(A0)+ODFABS	LOAD.W	(A6)+OSDDIS+ODFIIX,(A0)+ODFIIX	LOAD.W	(A6)+OSDDIS+ODFIIY,(A0)+ODFIIY	LOAD.L	(A6)+OSDDIS+ODFY,(A0)+ODFY	LOAD.L	(A6)+OSDDIS+ODFDY,(A0)+ODFDY	LOAD.L	(A6)+OSDDIS+ODFFY,(A0)+ODFFY	LOAD.L	(A6)+OSDDIS+ODFFDY,(A0)+ODFFDY	LOAD.L	(A6)+OSDDIS+ODFWBY,(A0)+ODFWBY	LOAD.L	(A6)+OSDDIS+ODFWEY,(A0)+ODFWEY	LOAD.B	(A6)+OSDDIS+ODFCMD,(A0)+ODFCMD	LOAD.L	(A0)+ODFABS,(A6)+OBMPT	LOAD.W	(A0)+ODFIIX,#1	LOAD.W	(A0)+ODFIIY,(A6)+OBMNBB	LOAD.L	D4,(A6)+OBMDIM	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	LOAD.B	(A0)+ODFCMD,#2	; dessine en couleur	POP.L	D4	RET;---------\\; CLODISBM >;=========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.WCLODISBM:	LOAD.L	(A0)+ODFABS,(A6)+OSDDIS+ODFABS	LOAD.W	(A0)+ODFIIX,(A6)+OSDDIS+ODFIIX	LOAD.W	(A0)+ODFIIY,(A6)+OSDDIS+ODFIIY	LOAD.L	(A0)+ODFY,(A6)+OSDDIS+ODFY	LOAD.L	(A0)+ODFDY,(A6)+OSDDIS+ODFDY	LOAD.L	(A0)+ODFFY,(A6)+OSDDIS+ODFFY	LOAD.L	(A0)+ODFFDY,(A6)+OSDDIS+ODFFDY	LOAD.L	(A0)+ODFWBY,(A6)+OSDDIS+ODFWBY	LOAD.L	(A0)+ODFWEY,(A6)+OSDDIS+ODFWEY	LOAD.B	(A0)+ODFCMD,(A6)+OSDDIS+ODFCMD	RET;--------\\; VISUBM  >;========/; Affiche le contenu du bitmap temporaire.; in	-; out	-; mod	D7.WVISUBM:	PUSHM.L	D1..D5,A2..A4	LOAD.L	A3,(A6)+OBMPT	CLR.L	D3	LOAD.W	D5,(A6)+OBMNBB	LOAD.L	A4,#0	CLR.L	D4	LOAD.L	D2,(A6)+OBMDIM	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	LOAD.L	A2,A0	GRA_	CRASTER	POPM.L	D1..D5,A2..A4	RET;--------\\; DECOIMA >;========/; Dcode une image.; in	A2.L	^en-tte;	A3.L	^buffer pour image dcode;	A4.L	^image code; out	D7.W; mod	D7.WDECOIMA:	PUSHM.L	D3,D4	PUSH.W	(A2)+OIMDLX	PUSH.B	(A2)+OIMBIP	CLR.W	D4	LOAD.B	D4,(A2)+OIMBIP	LOAD.W	D3,(A2)+OIMDLX	MUL.WU	D3,D4	LOAD.W	(A2)+OIMDLX,D3	LOAD.B	(A2)+OIMBIP,#1	GRA_	DECOIMA		; dcode l'image	POP.B	(A2)+OIMBIP	POP.W	(A2)+OIMDLX	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CODEIMA >;========/; Code une image.; in	A2.L	^en-tte;	A3.L	^image dcode;	A4.L	^buffer pour image code; out	D7.W	erreur; mod	D7.WCODEIMA:	PUSHM.L	D3,D4	PUSH.W	(A2)+OIMDLX	PUSH.B	(A2)+OIMBIP	CLR.W	D4	LOAD.B	D4,(A2)+OIMBIP	LOAD.W	D3,(A2)+OIMDLX	MUL.WU	D3,D4	LOAD.W	(A2)+OIMDLX,D3	LOAD.B	(A2)+OIMBIP,#1	GRA_	CODEIMA		; code l'image	POP.B	(A2)+OIMBIP	POP.W	(A2)+OIMDLX	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; CCMO    >;========/; Enlve la souris.; in	-; out	-; mod	D7.WCCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',T EXIT$	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	SET.B	(A6)+OCCMOEXIT$:	POP.W	D3	RET;--------\\; SCMO    >;========/; Remet la souris.; in	-; out	-; mod	D7.WSCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',F EXIT$	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	CLR.B	(A6)+OCCMOEXIT$:	POP.W	D3	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	RET	.END