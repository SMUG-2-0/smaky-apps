	.TITLE	RIGOLO.ASC;	--------------------------------------;		(C) 1991 - Daniel Roux;	--------------------------------------;	Source du programme RIGOLO.CODE;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 0.2	12.04.91	arrt par SHIFT-END ou SHIFT-F0 n'importe quand;			nouveaux bruits; 0.1	10.04.91	premire version pour CP91	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	TCOLOR	.REF	ICOLOR	.REF	AUDIO;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;GRA_CRASTER = H'A899		; raster-op couleurGRA_GDOT = H'A89A		; get-dotBSRCCOUL = 11BDSTCOUL = 12SMAKY300 = 7;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;RIGREV	=	0		; rvisionRIGVERS=	1		; version;RIGPROV=	'a		; rvision.version provisoireRIGPROV=	SPACE		; rvision.version dfinitive	.REV	RIGREV,RIGVERS	.CODE	800,11,B'0111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LXWDO	=	640		; largeur swdoLYWDO	=	272		; hauteur swdoMAXIMAGE=	100		; nb max d'imagesLBUDIS	=	250		; lg max de OBUDISKEYDBOX	=	H'7E00		; "touche" spciale; Numros des images; ------------------		.LOC	0IMTMARCHE:	.BLKB	2*12	; marcheIMTPROFIL:	.BLKB	2	; profilIMTPTOF:	.BLKB	2*5	; profil -> faceIMTFACE:	.BLKB	2	; face;;?IMTPARLE:	.BLKB	2*7	; parleIMTFACHE:	.BLKB	2	; fachIMTETONNE:	.BLKB	2*4	; tonnIMTDOS:		.BLKB	2*3	; dosIMTNEZ:		.BLKB	2	; nez rouge (profil)IMDSMAKY:	.BLKB	1IMDSM300:	.BLKB	1IMDCOCHON:	.BLKB	1IMDTEL:		.BLKB	1IMDFARCE1:	.BLKB	1IMDFARCE2:	.BLKB	1IMDCANON1:	.BLKB	1IMDCANON2:	.BLKB	1IMDMAISON:	.BLKB	1IMDROSE:	.BLKB	1IMDPLUME:	.BLKB	1IMDPLANTE:	.BLKB	1IMDCIRCULE:	.BLKB	1IMDCOUCOU1:	.BLKB	1IMDCOUCOU2:	.BLKB	1IMDMECHE:	.BLKB	8; Opration; ---------OPEND		=	0	; OPINIPDE	=	1	; [pos dcor]OPINIIMT	=	2	; [image toto]OPINIPOT	=	3	; [[position toto]]OPMARCHE	=	10	; [pas] [nb]OPDRAW		=	11	; OPDELMS		=	12	; [dure]OPAUDIO		=	13	; [MA_*]OPDECOR		=	14	; [old] [new]OPMOVE		=	15	; [image toto] [...] [0]OPCOLOR		=	16	; [couleur] [nb] [del] RGB,RGBOPSUPPL		=	17	; [image] [[pos]]; Musiques audio; --------------MA_TEL		=	1MA_RIRES1	=	2MA_CERF		=	3MA_RIRES2	=	4MA_FARCE	=	5MA_CANON	=	6MA_YOUPIE	=	7MA_ATCHOUM	=	8MA_RYTHME	=	9MA_ORGUE	=	10MA_CLAXON	=	11MA_COUCOU	=	12MA_COCHON1	=	13MA_COCHON2	=	14; Couleurs absolues; -----------------COLOR_GRIS	=	1COLOR_JAUNE	=	3COLOR_ORANGE	=	6COLOR_VERT	=	12; En-tte d'une image couleur (.COLOR); ------------------------------------	.LOC	0	.BLKB	1		; OIMTYP: H'82	.BLKB	1		; OIMCOD: 0 ou 4	.BLKB	1		; OIMBIP: 4 bits/pixel	.BLKB	1		; OIMDIR: 2	.BLKB	2		; OIMDLX: largeur (multiple de 16)	.BLKB	2		; OIMDLY: hauteur	.BLKB	4		; OIMNBB: longueur du dataOIMSIZ:	.BLKB	2		; taille d'un pixel (4)OIMCNT:	.BLKB	2		; nb de pixels (1)OIMLGC:	.BLKB	4		; longueur de la CLUT	.BLKB	12		; rserve				; LGHIMA: longueur de l'en-tte; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOPLCOM:	.BLKB	4		; ^ligne de commandeOPDDIS:	.BLKB	4		; ^descripteur de la fentreOSDDIS:	.BLKB	LGDIS8		; copie du descripteur de la fentreOLINE:	.BLKB	4		; adresse de GRA_LINEOBUDIS:	.BLKB	LBUDIS		; buffer write-displayOCCMO:	.BLKB	1		; 1 => souris enleveOMACHINE:.BLKB	1		; machine utilise (SMAKY*)OFIRST:	.BLKB	1		; pour CLUT premire image	.EVENOBMPT:	.BLKB	4		; bitmap: ^OBMDIM:	.BLKB	4		; bitmap: dimensions (dy;dx)OBMNBB:	.BLKB	2		; bitmap: IyOBUHEAD:.BLKB	LGHIMA		; buffer pour en-tte imageOPPIMA:	.BLKB	4*MAXIMAGE	; ^imagesOSNDP1:	.BLKB	4		; ^banque de sons 1OSNDP2:	.BLKB	4		; ^banque de sons 2OSSPDE:	.BLKB	2		; status: position dans le dcorOSSODE:	.BLKB	2		; status: ancienne image du dcorOSSNDE:	.BLKB	2		; status: nouvelle image du dcorOSSIMT:	.BLKB	2		; status: image pour totoOSSPOT:	.BLKB	4		; status: position de totoOSSIMS:	.BLKB	2		; status: image supplmentaireOSSPOS:	.BLKB	4		; status: position image supplmentaireLGVAR:; Programme; ---------	.LOC	0	JUMP	START; Erreurs fatales; ---------------TXERFAT300:	.ASCIZ	"Possible seulement avec un SMAKY300 en mode couleur !"; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMIMAGES:	.ASCIZ	"(:,#:)RIGOLO_C1.DATA"NMSOUND:	.ASCIZ	"(:,#:)RIGOLO_1.AUDIO"		.EVENSTART:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	CALL	CCMO		; enlve la souris	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	LOAD.L	(A6)+OPDDIS,A0	LOAD.L	A3,#R16"TXERFAT300	COMP.B	(A6)+OMACHINE,#SMAKY300	JUMP,NE ERFAT2	COMP.B	(A0)+ODFCNP,#4	JUMP,NE ERFAT2	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OLINE,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	PUSH.L	(A0)+ODFCSF	LOAD.L	(A0)+ODFCSF,#COLOR_GRIS	LOAD.L	D4,#-1	CALL	DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; grise toute la fentre	POP.L	(A0)+ODFCSF	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,#LYWDO	SR.W	D3,#1	ADD.W	D3,#LYWDO-1	SWAP.W	D3	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFDX	LOAD.W	D2,#SETDOT	LOAD.W	D1,#5-1HSEG$:	PUSH.L	D3	LIB	?DRSEG		; dessine le sol horizontal	POP.L	D3	ADD.L	D3,#H'10000*1	DECJ.W,NMO D1,HSEG$	LOAD.W	D4,#LYWDO	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,D4	SR.W	D3,#1	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,#LXWDO	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,D4	SR.W	D3,#1	AND.B	D3,#B'11110000	; D3 <-- utile pour SMAKY8 !	LIB	?CREWDO		; cre swdo (utile si grand cran)	LIB	?USEWDO	LOAD.L	D3,#H'10000*(LYWDO/2)+((LXWDO-8*44)/2)	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	" (C) 1991  Daniel ROUX et EPSITEC-system SA "	.EVEN	LOAD.L	(A6)+OBMDIM,(A0)+ODFFDY	LOAD.W	D4,(A0)+ODFFDX	SR.W	D4,#3	CLR.W	D3	LOAD.B	D3,(A0)+ODFCNP	MUL.WU	D4,D3	LOAD.W	(A6)+OBMNBB,D4	MUL.WU	D4,(A0)+ODFFDY	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour bitmap	JUMP,NE ERFAT2	LOAD.L	(A6)+OBMPT,A4	LOAD.L	A3,#R16"NMIMAGES	LOAD.L	A4,#(A6)+OPPIMA	CALL	IMAGEREADS	; lit toutes les images ...	JUMP,NE ERFAT2	LOAD.L	A3,#R16"NMSOUND	CALL	SNDREAD	JUMP,NE ERFAT2	LOAD.L	(A6)+OSNDP1,A4LOOP:	CALL	MAIN		; animation ...	JUMP,EQ LOOPERFAT:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSEERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	RIGIMAGE.ASI	.INS	RIGCOLOR.ASI	.INS	RIGAUDIO.ASI	.INS	RIGMISC.ASI	.INS	RIGTABLE.ASI	.END	START