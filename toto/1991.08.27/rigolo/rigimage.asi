	.SBTTL	RIGIMAGE.ASI;--------\\; MAIN    >;========/; ; in	-; out	-; mod	D7.WMAIN:	PUSHM.L	A4	LOAD.L	A4,#R16"TABLE1	CALL	IMAGEOPEREXIT$:	POPM.L	A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGEOPER >;==========/; Excute une table d'opration.; in	A4.L	^table d'opration; out	D7.W	erreur si (SHIFT-END); mod	D7.WIMAGEOPER:	PUSHM.L	D2..D4,A4LOOP$:	CLR.W	D3KEY$:	LOAD.W	D2,D3	LIB	?IFCAR		; une touche presse ?	JUMP,EQ KEY$	COMP.W	D2,#SHIFT+END	JUMP,EQ EXIT$	COMP.W	D2,#SHIFT+F0	JUMP,EQ EXIT$	LOAD.W	D4,(A4+)	; D4 <-- opration	COMP.W	D4,#OPINIPDE	JUMP,EQ INIPDE$	COMP.W	D4,#OPINIIMT	JUMP,EQ INIIMT$	COMP.W	D4,#OPINIPOT	JUMP,EQ INIPOT$	COMP.W	D4,#OPMARCHE	JUMP,EQ MARCHE$	COMP.W	D4,#OPDRAW	JUMP,EQ DRAW$	COMP.W	D4,#OPDELMS	JUMP,EQ DELMS$	COMP.W	D4,#OPAUDIO	JUMP,EQ AUDIO$	COMP.W	D4,#OPDECOR	JUMP,EQ DECOR$	COMP.W	D4,#OPMOVE	JUMP,EQ MOVE$	COMP.W	D4,#OPCOLOR	JUMP,EQ COLOR$	COMP.W	D4,#OPSUPPL	JUMP,EQ SUPPL$	CLR.W	D7		; D7 <-- ok	JUMP	EXIT$INIPDE$:	LOAD.W	(A6)+OSSPDE,(A4+)	JUMP	LOOP$INIIMT$:	LOAD.W	(A6)+OSSIMT,(A4+)	JUMP	LOOP$INIPOT$:	LOAD.L	(A6)+OSSPOT,(A4+)	JUMP	LOOP$MARCHE$:	LOAD.W	D3,(A4+)	LOAD.W	D4,(A4+)	CALL	IMAGEMARCHE	JUMP	LOOP$DRAW$:	CALL	IMAGEMOVE	JUMP	LOOP$DELMS$:	LOAD.W	D4,(A4+)	NTREL	?DELMS	JUMP	LOOP$AUDIO$:	LOAD.W	D3,(A4+)	CALL	SNDPLAY		; joli bruit	JUMP	LOOP$DECOR$:	LOAD.W	(A6)+OSSODE,(A4+)	LOAD.W	(A6)+OSSNDE,(A4+)	JUMP	LOOP$MOVE$:	LOAD.W	D4,(A4+)	JUMP,EQ LOOP$	LOAD.W	(A6)+OSSIMT,D4	CALL	IMAGEMOVE	; montre la situation	JUMP	MOVE$COLOR$:	LOAD.W	D2,(A4+)	; D2 <-- COLOR_*	LOAD.W	D3,(A4+)	; D3 <-- nb	LOAD.W	D4,(A4+)	; D4 <-- dlai	CALL	COLORCHANGE	; change une couleur	ADD.L	A4,#6+6		; A4 <-- saute RGB,RGB	JUMP	LOOP$SUPPL$:	LOAD.W	(A6)+OSSIMS,(A4+)	LOAD.L	(A6)+OSSPOS,(A4+)	CALL	IMAGEMOVE	; montre la situation	JUMP	LOOP$EXIT$:	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; IMAGEMARCHE >;============/; Fait avancer toto un p'tit bout.; in	D3.W	longueur d'un pas;	D4.W	nombre de pas; out	-; mod	D7.WIMAGEMARCHE:	PUSHM.L	D1..D4LOOP$:	ADD.W	(A6)+OSSPDE,D3	LOAD.W	D1,#+2		; D1 <-- +2 (marche en avant)	TEST.W	D3	JUMP',NC NEXT$	NEG.W	D1		; D1 <-- -2 (marche  reculons)NEXT$:	LOAD.W	D2,(A6)+OSSIMT	ADD.W	D2,D1	JUMP',NC POS$	LOAD.W	D2,#IMTMARCHE+11*2POS$:	COMP.W	D2,#IMTMARCHE+12*2	JUMP',LO IMT$	LOAD.W	D2,#IMTMARCHE+0IMT$:	LOAD.W	(A6)+OSSIMT,D2	CALL	IMAGEMOVE	; dessine la situation	DEC.W	D4	JUMP,NE LOOP$	POPM.L	D1..D4	RET;----------\\; IMAGEMOVE >;==========/; Dessine l'cran en fonction de son tat.; in	(A6)+OSS*; out	-; mod	D7.WIMAGEMOVE:	PUSHM.L	D0..D5,A3	CALL	OPEDISBM	; dessine dans le bitmap temporaire	LOAD.L	A3,#R16"TDECOR$	CLR.W	D3	LOAD.W	D4,(A6)+OSSPDEFSRC$:	LOAD.W	D2,D3	ADD.W	D2,(A3)+0	COMP.W	D4,D2	JUMP',LS FDRAW$	ADD.W	D3,(A3)+0	ADD.L	A3,#4		; A3 <-- ^suivant	TEST.W	(A3)+0	JUMP,NS SUPPL$	JUMP	FSRC$FDRAW$:	LOAD.W	D0,D3	CLR.L	D3		; D3 <-- position dans l'cran	CLR.L	D4	LOAD.W	D4,(A6)+OSSPDE	SUB.W	D4,D0		; D4 <-- offset dans l'imageFLOOP$:	LOAD.W	D5,(A3)+2	; D5 <-- numro de l'image	COMP.W	D5,(A6)+OSSODE	JUMP',NE FSHOW$	LOAD.W	D5,(A6)+OSSNDEFSHOW$:	LOAD.W	D1,(A3)+0	SUB.W	D1,D4		; D1 <-- largeur  afficher	LOAD.W	D2,#LOADDOT	CALL	IMAGESHOW	; affiche l'image de fond de gauche	CLR.W	D4	ADD.W	D3,D1		; D3 <-- position dans l'cran suivante	ADD.L	A3,#4		; A3 <-- ^suivant	COMP.W	D3,#LXWDO	JUMP,LO FLOOP$SUPPL$:	LOAD.W	D5,(A6)+OSSIMS	JUMP',EQ TOTO$	LOAD.L	D3,(A6)+OSSPOS	CLR.L	D4	LOAD.W	D2,#LOADDOT	CALL	IMAGESHOW	; affiche l'image supplmentaireTOTO$:	LOAD.W	D5,(A6)+OSSIMT	INC.W	D5	LOAD.L	D3,(A6)+OSSPOT	CLR.L	D4	LOAD.W	D2,#CLRDOT	CALL	IMAGESHOW	; masque le fond de toto	DEC.W	D5	LOAD.W	D2,#SETDOT	CALL	IMAGESHOW	; affiche toto	CALL	CLODISBM	; fin du dessin dans le bitmap temporaire	CALL	VISUBM		; montre le bitmap sur l'cran	POPM.L	D0..D5,A3	RETTDECOR$:	.W	912	-1	.W	224	IMDPLUME	.W	160	-1	.W	256	IMDTEL	.W	312	-1	.W	208	IMDMAISON	.W	376	-1	.W	272	IMDCOCHON	.W	382	-1	.W	224	IMDCIRCULE	.W	208	-1	.W	304	IMDPLANTE	.W	190	-1	.W	112	IMDCOUCOU1	.W	372	-1	.W	400	IMDCANON1	.W	224	-1	.W	208	IMDROSE	.W	368	-1	.W	192	IMDFARCE1	.W	240	-1	.W	640	IMDSMAKY	.W	272	-1	.W	496	IMDSM300	.W	1000	-1	.W	-1;----------\\; IMAGESHOW >;==========/; Affiche une image.; in	D5.W	numro de l'image (0..n,-1);	D4.L	position dans l'image (y;x);	D3.L	position dans l'cran (y;x);	D2.W	mode;	D1.W	largeur  afficher; out	-; mod	D7.WIMAGESHOW:	PUSHM.L	D0..D5,A2..A4	COMP.W	D5,#-1	JUMP,EQ TRAME$	LOAD.L	A3,#(A6)+OPPIMA	; A3 <-- ^^images	SL.W	D5,#2	LOAD.L	A3,(A3)+(D5.W)	; A3 <-- ^image	LOAD.W	D1,D2	EX.L	D4,D3	LOAD.W	D5,(A3)-(LGHIMA+IMLBUF)+OIMDLX	ADD.W	D5,#8-1	SR.W	D5,#3	CLR.W	D0	LOAD.B	D0,(A3)-(LGHIMA+IMLBUF)+OIMBIP ; D0 <-- nb de bits/pixel	MUL.WU	D5,D0	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	LOAD.W	D2,(A3)-(LGHIMA+IMLBUF)+OIMDLY	SWAP.W	D2	LOAD.W	D2,(A3)-(LGHIMA+IMLBUF)+OIMDLX	OR.W	D1,#2^BDSTCOUL	COMP.W	D0,#1	JUMP',EQ RASTER$	OR.W	D1,#2^BSRCCOULRASTER$:	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	GRA_	CRASTER		; affiche l'image	JUMP'	EXIT$TRAME$:	PUSH.L	(A0)+ODFCSF	LOAD.L	(A0)+ODFCSF,#COLOR_GRIS	LOAD.L	D4,#-1	CALL	DRMDEF		; trame 100%	LOAD.W	D4,#LYWDO	SWAP.W	D4	LOAD.W	D4,D1	LIB	?DRTRAME	; grise une partie de la fentre	POP.L	(A0)+ODFCSFEXIT$:	POPM.L	D0..D5,A2..A4	RET;-----------\\; IMAGEREADS >;===========/; Lit toutes les images contenues dans un fichier.; in	A3.L	^nom du fichier;	A4.L	^buffer pour ^images; out	D7.W	erreur; mod	D7.WIMAGEREADS:	PUSHM.L	D3,A3,A4	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE EXIT$	LOAD.L	A3,A4LOOP$:	CALL	IMAGEREAD	; lit une image	JUMP',NE EOF$	LOAD.L	(A3+),A4	JUMP	LOOP$EOF$:	COMP.W	D7,#EROUTF	JUMP',NE CLOSE$	CLR.W	D7CLOSE$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGEREAD >;==========/; Lit l'image suivante dans un fichier ouvert sur disque.; Si la CLUT existe, elle est saute !; in	D6.W	canal FOS; out	A4.L	^image (-en-tte +data);	D7.W	erreur; mod	D7.W, A4.LIMAGEREAD:	PUSHM.L	D0..D5,A1..A3	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; OBUHEAD <-- lit l'en-tte	JUMP,NE EXIT$	LOAD.W	D0,(A6)+OBUHEAD+OIMDLX ; D0 <-- largeur de l'image	LOAD.W	D1,(A6)+OBUHEAD+OIMDLY ; D1 <-- hauteur de l'image	LOAD.W	D4,D0	ADD.W	D4,#8-1	SR.W	D4,#3	CLR.W	D5	LOAD.B	D5,(A6)+OBUHEAD+OIMBIP ; D5 <-- nb de bits/pixel	MUL.WU	D4,D5	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#LGHIMA+IMLBUF+4 ; D4 <-- rserve pour en-tte et codage	PUSH.L	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.L	D1	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.L	A1,#(A4)+LGHIMA+IMLBUF ; A1 <-- ^image	LOAD.L	A3,#(A6)+OBUHEAD	LOAD.W	D4,#(LGHIMA/2)-1XFER$:	LOAD.W	(A4+),(A3+)	; buffer <-- en-tte	DECJ.W,NMO D4,XFER$	TEST.L	(A2)+OIMLGC	; CLUT existe ?	JUMP',EQ CLUT$		; non => CLUT$	TEST.B	(A6)+OFIRST	JUMP',EQ FIRST$	FOS	?GPOS	ADD.L	D4,(A2)+OIMLGC	; D4 <-- lg de la CLUT	FOS	?SPOS		; saute la CLUT	JUMP',NE ERROR$	JUMP'	CLUT$FIRST$:	CALL	IMAGECLUT	; init selon la CLUT	JUMP',NE ERROR$	SET.B	(A6)+OFIRSTCLUT$:	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE CODE$		; oui => CODE$DECO$:				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP',NE ERROR$	JUMP'	OK$CODE$:	LOAD.L	A4,#(A1)-IMLBUF	; A4 <-- ^o lire l'image	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE ERROR$	LOAD.L	A3,A1	CALL	DECOIMA		; dcode l'image couleur ...	JUMP',NE ERROR$OK$:	LOAD.L	A4,A1		; A4 <-- ^en-tte et image	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	PUSH.W	D7	LOAD.L	A4,#(A1)-(LGHIMA+IMLBUF)	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D7EXIT$:	POPM.L	D0..D5,A1..A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGECLUT >;----------/; Change la CLUT.; in	D6.W	canal FOS;	A2.L	^en-tte; out	D7.W	erreur; mod	D7.WIMAGECLUT:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D4,(A2)+OIMLGC	; D4 <-- lg de la CLUT	FOS	?RDBYTE	JUMP',NE EXIT$	LOAD.L	A3,A4	LOAD.L	D3,#2^BTCTABLE	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal pour TCOLOR	TCOL_	LOADCLUT	; change de CLUT	CLR.W	D7EXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET	.END