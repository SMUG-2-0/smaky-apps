LKB	2		; calcul: opration (+-*/?)OCCOBJ:	.BLKB	2		; calcul: objet  utiliser pour les cartesOCCRGQ:	.BLKB	2		; calcul: rang de la question (0,2,4)OCCNB1:	.BLKB	2		; calcul: premier nombreOCCNB2:	.BLKB	2		; calcul: deuxime nombreOCCNB3:	.BLKB	2		; calcul: troisime nombreOCCNBX:	.BLKB	2		; calcul: nombre  trouverOCCOPC:	.BLKB	2		; calcul: opration choisieOCCRUS:	.BLKB	2		; calcul: rponse de l'utilisateurOCCNBF:	.BLKB	2		; calcul: nb de fautesOGRPAR:	.BLKB	2		; grille: compteur des parties reussiesOGRPOY:	.BLKB	2		; grille: position origineOGRPOX:	.BLKB	2		; grille: position origineOGRDIY:	.BLKB	2		; grille: largeur d'une caseOGRDIX:	.BLKB	2		; grille: hauteur d'une caseOGRNBY:	.BLKB	2		; grille: nb de cases horizontalementOGRNBX:	.BLKB	2		; grille: nb de cases verticalementOGRNBT:	.BLKB	2		; grille: nb de cases totalOGRCHS:	.BLKB	4		; grille: couleur hazard setOGRCHC:	.BLKB	4		; grille: couleur hazard clearOGRTAS:	.BLKB	15*15		; grille: solutionOGRTAC:	.BLKB	15*15		; grille: recherche	.EVENOLANBY:	.BLKB	2		; labyrinthe: nb de cases verticalementOLANBX:	.BLKB	2		; labyrinthe: nb de cases horizontalementOLAIIY:	.BLKB	2		; labyrinthe: nb de bytesOLAPOY:	.BLKB	2		; labyrinthe: positionOLAPOX:	.BLKB	2		; labyrinthe: OLADIY:	.BLKB	2		; labyrinthe: dimensions d'une caseOLADIX:	.BLKB	2		; labyrinthe: OLADIM:	.BLKB	2		; labyrinthe: paisseur d'un murOLAARR:	.BLKB	4		; labyrinthe: arriveOLACHI:	.BLKB	4		; labyrinthe: hilightOLAPBM:	.BLKB	4		; labyrinthe: ^bitmapOLAPSO:	.BLKB	4		; labyrinthe: ^solutionOLAPRE:	.BLKB	4		; labyrinthe: ^rponseOHABKI:	.BLKB	(MAXIMA/8)+1	; hazard: banque d'imagesOHABKS:	.BLKB	(MAXSIMA/8)+1	; hazard: banque de sous-imagesOHAPUZ:	.BLKB	(256/8)+1	; hazard: puzzleOHAMEM:	.BLKB	(256/8)+1	; hazard: mmoryOHALET:	.BLKB	(40/8)+1	; hazard: lettreOHACOB:	.BLKB	(12/8)+1	; hazard: calcul objetOHACOP:	.BLKB	(4/8)+1		; hazard: calcul operationOHACNB:	.BLKB	(100/8)+1	; hazard: calcul nombreOHAPRO:	.BLKB	(10/8)+1	; hazard: progressionOHALIT:	.BLKB	(10/8)+1	; hazard: petites actionsOHAJGP:	.BLKB	(30/8)+1	; hazard: panne ascenseurOHAMUS:	.BLKB	(9/8)+1		; hazard: musiqueOHAEXC:	.BLKB	(10/8)+1	; hazard: exceptionOHAPER:	.BLKB	(40/8)+1	; hazard: permutations	.EVENOHAZA:	.BLKB	8		; registre 63 bits pour gnrateur alatoireOMATPR:	.BLKB	(32*32)/8	; matrice pour progressionsODAVSL:	.BLKB	LSLVAR		; data: scroll-listeOETCDB:	.BLKB	4		; dite-texte: canal dboxOETWD1:	.BLKB	2		; dite-texte: swdo 1OETWD2:	.BLKB	2		; dite-texte: swdo 2OBUNAM:	.BLKB	LBUNAM		; nom de fichier gnralOBUNIM:	.BLKB	LBUNAM		; nom de fichier imageOBUNTX:	.BLKB	LBUNAM		; nom de fichier texteOBUIO:	.BLKB	12		; buffer pour i/oLGVAR:; Programme; ---------	.LOC	0ADCODE:	JUMP	START; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMEPRO:		.ASCIZ	"EPRO"NMICOLOR:	.ASCIZ	"ICOLOR"NMTOTO:		.ASCIZ	"TOTO_S"NMDEF:		.ASCIZ	"(:,#:)TOTOS.TOTOS"		.EVEN; Couleurs relatives; ------------------TCOUL:	.L	COLORFTOTO	.W	-1,-1,0	.ASCIZE	"intrieur de toto"	.L	COLORCTOTO	.W	0,0,0	.ASCIZE	"extrieur de toto"	.L	COLORHILI	.W	-1,-1,0	.B	1	.ASCIZE	"mises en vidence"	.L	COLORBLANC	.W	-1,-1,-1	.ASCIZE	"blanc"	.L	COLORNOIR	.W	0,0,0	.ASCIZE	"noir"	.L	COLORROUGE	.W	-1,0,0	.ASCIZE	"rouge"	.L	COLORVERT	.W	0,-1,0	.ASCIZE	"vert"	.L	COLORBLEU	.W	0,0,-1	.ASCIZE	"bleu"	.L	COLORVIOLET	.W	-1,0,-1	.ASCIZE	"violet"	.L	COLORJAUNE	.W	-1,-1,0	.ASCIZE	"jaune"	.L	COLORBRUN	.W	40000,0,0	.ASCIZE	"brun"	.L	COLORCYAN	.W	0,-1,-1	.ASCIZE	"cyan"	.L	COLORROSE	.W	-1,45000,-1	.ASCIZE	"rose"	.L	COLORORANGE	.W	-1,45000,0	.ASCIZE	"orange"	.L	0GETTCOUL:	LOAD.L	A5,#R16"TCOUL	RET	.INS	TSMUSIQUE.ASI	.INS	TSTABLE.ASISTART:	.IF	~ASSMILE	LIB	?OPELIB	.ENDIF	LOAD.W	D3,#2	LIB	?MOUSE	LIB	?AFTIM	.B	NOCURS	.B	0	.EVEN	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	CALL	_CCMO		; enlve la souris	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LIB	?GETPDIS	LOAD.L	(A6)+OPDDIS,A4	LOAD.L	A0,A4	LOAD.B	(A6)+OFLAGS,#2^BFMINUS!2^BFSON!2^BFTNORMAL	LOAD.W	(A6)+OACTIV,#-1	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMEPRO	LOAD.W	D3,#EPRO_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHEPRO,D1	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	LOAD.L	A3,#R16"NMICOLOR	LOAD.W	D3,#ICOL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHICOLOR,D1	LOAD.L	A3,#R16"NMTOTO	LOAD.L	A5,#R16"TCOUL	LOAD.L	D3,#2^BICCRET	ICOL_	INIT		; charge TOTO_S.CRET	LOAD.L	(A6)+OIDCRET,D5NOCOUL$:	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADRASTER,A3	LOAD.W	D3,#GRA_CRASTER	LIB_	GETAD	LOAD.L	(A6)+OADCRASTER,A3	LOAD.W	D3,#GRA_MATRIX	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADMATRIX,A3	LOAD.W	D3,#GRA_DOT	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADDOT,A3	LOAD.W	D3,#GRA_TRAME	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADTRAME,A3	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADLINE,A3	LOAD.W	D3,#GRA_ELLIPSE	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADELLIPSE,A3	LOAD.W	D3,#GRA_FILLO	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADFILLO,A3	LOAD.W	D3,#GRA_FILLC	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADFILLC,A3	LOAD.W	D3,#GRA_CLEAR	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADCLEAR,A3	LOAD.W	D3,#GRA_SET	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADSET,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADINV,A3	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADQXDOT,A3	LIB	?AFTIM	.B	NOCURS		; pas de curseur !	.B	NOEFLI		; pas de EFLI automatique	.B	TRUNC		; tronque les lignes trop longues	.B	LOADGC		; charge les caractres standards	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	LOADGC		; charge les caractres NBF14	.B	GCTYF	.B	GCTYS	.B	GCTYT	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	LOADGC		; charge les icnes ITP84	.B	GCICF	.B	GCICS	.B	GCICT	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	USEGC		; utilise les icnes ITP84	.B	GCICF	.B	GCICS	.B	GCICT	.B	0	.EVEN	LOAD.L	(A6)+OPGICO,(A0)+ODFPGC	LIB	?AFTIM	.B	USEGC		; utilise les caractres standard	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	CALL	CALCFOND	; calcule le gencar des fonds	JUMP,NE ERFAT	LOAD.W	D4,#PRIOTIME	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#200		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils de mesure du temps	JUMP,NE ERFAT2	NTREL	?GETPRIO	; D4 <-- priorit de START	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS2	LOAD.L	A3,#R16"NFILS2	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils des bruitages	JUMP,NE ERFAT2	LOAD.W	D4,#LYWDO	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,D4	SR.W	D3,#1	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,#LXWDO	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,D4	SR.W	D3,#1	AND.B	D3,#B'11110000	; D3 <-- utile pour SMAKY8 !	LIB	?CREWDO		; cre swdo (utile si grand cran)	LIB	?USEWDO	CALL	_COUPSAC	; coup de sac pour le gnrateur alatoire	LOAD.L	A3,(A6)+OPLCOM	LIB	?SKPNAM	JUMP',EQ READ$	LOAD.L	A3,#R16"NMDEFREAD$:	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE RERR$	CALL	_BKREAD		; charge toute la banque d'images	JUMP,NE ERFAT2RERR$:	TEST.B	(A0)+ODFMOD:#BFBLANC	JUMP',BS REFAIT	SET.B	(A6)+OINV	; OINV <-- cran  fond noirREFAIT:	LIB	?GETWDO	LOAD.W	D6,D5	CLR.W	D5	LIB	?USEWDO	LOAD.L	D3,#-1	TEST.B	(A6)+OINV	JUMP,F	20$	CLR.L	D320$:	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface toute la fentre	LOAD.W	D5,D6	LIB	?USEWDO	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface toute la swdo	LIB	?BUZZ	LOAD.L	A4,#R16"TAMOPEN	CALL	ICOMALL		; met toto sur l'cran ...LOOP:	CALL	_AFMENU		; affiche les soft-keys	CALL	_CCMO		; enlve la souris	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	LOAD.L	A4,#R16"TMENU$	CALL	CHEXBASE	; OCHMAP <-- icnes existantes	CALL	CHDRAW		; dessine les choix	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	CALL	_CLRFIFO	; vide le fifo du clavier	CALL	_SCMO		; remet la sourisMENU$:	LOAD.L	A4,#R16"TMENU$	CALL	CHMENU		; choix selon menu ...; ATTENTION: comparaisons avec D3.L pour tenir compte du pseudo-code,; et interdire ainsi les clic avec la souris dans les soft-keys !	COMP.W	D3,#'1	JUMP,EQ CALCUL	COMP.W	D3,#'2	JUMP,EQ MEMORY	COMP.W	D3,#'3	JUMP,EQ PUZZLE	COMP.W	D3,#'4	JUMP,EQ LETTRE	COMP.W	D3,#'5	JUMP,EQ PENDU	COMP.W	D3,#'6	JUMP,EQ PERMU	COMP.W	D3,#'7	JUMP,EQ GRILLE	COMP.W	D3,#'8	JUMP,EQ LABY	COMP.L	D3,#H'10000*0+F0+SHIFT	JUMP,EQ FINI	COMP.L	D3,#H'10000*13+F13+SHIFT	JUMP,EQ CHOIX	COMP.L	D3,#H'10000*15+F15+SHIFT	JUMP,EQ DATA	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	MENU$TMENU$:	.W	ICOCALCUL	.W	ICOMEMORY	.W	ICOPUZZLE	.W	ICOLETTRE	.W	ICOPENDU	.W	ICOPERMU	.W	ICOGRILLE	.W	ICOLABY	.W	0CHOIX:	CALL	DBOXCHOIX	; demande choix ...	JUMP	LOOPDATA:	CALL	DBOXDATA	; demande donnes ...	JUMP	LOOPBIP:				; erreur =>	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	LOOPBIGBIP:				; erreur =>	LOAD.W	(A6)+OSOUND,#TMUSFAUX	JUMP	LOOPERROR:	CALL	DBOXERROR	; affiche l'erreur ...	LOAD.L	A4,#R16"TAMCLOSE	CALL	ICOMALL		; enlve toto de l'cran ...	LOAD.L	A4,#R16"TAMOPEN	CALL	ICOMALL		; met toto sur l'cran ...	JUMP	LOOPFINI:	TEST.B	(A6)+OMAJ	JUMP',EQ QUITTE$	LOAD.L	D3,#2^BDBIOQUIT	CALL	DBOXMTOTO	; met  jour ...	PUSH.W	D7	CALL	_AFMENU		; affiche les soft-keys	POP.W	D7	JUMP,NE ERROR	COMP.W	D3,#F4	JUMP',EQ QUITTE$	COMP.W	D3,#F1	JUMP,NE LOOP	TEST.B	(A3)	JUMP',NE MAJ$	CALL	DBOXSTOTO	; A3 <-- ^nom  sauver	PUSH.W	D7	CALL	_AFMENU		; affiche les soft-keys	POP.W	D7	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ LOOPMAJ$:	CALL	_WAITMOUSE	FOS	?DELETE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP,NE ERROR	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE ERROR	CALL	_BKWRITE	; crit le fichier gnral	JUMP,NE ERROR	CLR.B	(A6)+OMAJQUITTE$:	CALL	_NORMMOUSE	CALL	DBOXQUITTE	; quitte TOTO ?	COMP.W	D3,#F1	JUMP,NE LOOPERFAT:	SET.B	(A6)+OABORT	; signal la fin aux fils	.IF	~ASSMILE	NTREL	?WFABDESC	; attend la fin des fils ...	.ELSE	PUSH.L	D4	LOAD.W	D4,#50	NTREL	?DELMS	POP.L	D4	.ENDIF	CLR.W	D5	LIB	?USEWDO		; utilise la swdo principale	CALL	_BKKILL		; libre toute la banque d'images	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHEPRO	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHICOLOR	LIB_	CLOSE	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend les variablesERFAT1:	.IF	~ASSMILE	LIB	?CLOLIB	FOS	?STOP	.ELSE	EXIT	.ENDIFERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT; Processus de mesure du temps; ----------------------------NFILS1:	.ASCIZ	"TOTO_S_TIME"	.EVENPFILS1:	LOAD.L	A0,(A6)+OPDDIS	CLR.L	(A6)+OTIME	; OTIME <-- rz la mesure du tempsLOOP$:	TEST.B	(A6)+OABORT	; fin des fils ?	JUMP',T END$		; oui => END$	LOAD.W	D4,#50/5	NTREL	?DELMS	ADD.L	(A6)+OTIME,#5	; OTIME <-- inc la mesure du temps;;?	TEST.B	(A6)+OCCMO	; souris cache ?;;?	JUMP,F	LOOP$		; non => LOOP$;;?	CALL	MMOUSE		; remet la souris au milieu	JUMP	LOOP$END$:	NTREL	?ABORT; Processus de gnration des bruitages; -------------------------------------NFILS2:	.ASCIZ	"TOTO_S_SOUND"	.EVENPFILS2:LOOP$:	TEST.B	(A6)+OABORT	; fin ?	JUMP',T	END$		; oui => END$				; non =>	LOAD.W	D3,(A6)+OSOUND	JUMP',EQ WAIT$	CLR.W	(A6)+OSOUND	CALL	PATATRA		; fait le bruit	JUMP	LOOP$WAIT$:	LOAD.W	D4,#50/10	NTREL	?DELMS		; attend un peu	JUMP	LOOP$END$:	NTREL	?ABORT;--------\\; PATATRA >;========/; Fait un bruit rigolo !; in	D3.W	#TMUSxxx; out	-; mod	D7.WPATATRA:	PUSHM.L	D3,A4	TEST.B	(A6)+OFLAGS:#BFSON	JUMP',BC EXIT$	LOAD.L	A4,#R16"ADCODE	AND.L	D3,#H'FFFF	; ADD.W A4,D3 impossible si D3.W ngatif !	ADD.L	D3,A4	LOAD.L	A4,D3	TEST.W	(A4)	JUMP',EQ EXIT$	LIB	?PLAYEXIT$:	POPM.L	D3,A4	RET	.INS	TSCHOIX.ASI	.INS	TSPUZZLE.ASI	.INS	TSMEMORY.ASI	.INS	TSLETTRE.ASI	.INS	TSPENDU.ASI	.INS	TSPERMU.ASI	.INS	TSCALCUL.ASI	.INS	TSGRILLE.ASI_CCMO:		JUMP	CCMO_SCMO:		JUMP	SCMO_CLRFIFO:	JUMP	CLRFIFO_COUPSAC:	JUMP	COUPSAC_AFMENU:	JUMP	AFMENU_AFMENUJ:	JUMP	AFMENUJ_WAITMOUSE:	JUMP	WAITMOUSE_NORMMOUSE:	JUMP	NORMMOUSE_IFMOUSE:	JUMP	IFMOUSE_INVTRAME:	JUMP	INVTRAME_INVMODE:	JUMP	INVMODE_DESRECTM:	JUMP	DESRECTM_BKKILL:	JUMP	BKKILL_BKSNEXT:	JUMP	BKSNEXT_BKSEXIST:	JUMP	BKSEXIST_BKREAD:	JUMP	BKREAD_BKWRITE:	JUMP	BKWRITE_EXHAZARD:	JUMP	EXHAZARD_RZHAZARD:	JUMP	RZHAZARD_GETTCOUL:	JUMP	GETTCOUL_ADCODE:	LOAD.L	A3,#R16"ADCODE	RET	.INS	TSLABY.ASI	.INS	TSJAUGE.ASI	.INS	TSICONE.ASI	.INS	TSDBOX.ASI	.INS	TSPROGRESS.ASI	.INS	TSIMAGE.ASI	.INS	TSMISC.ASI	.END	START