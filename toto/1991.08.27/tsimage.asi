	.SBTTL	TSIMAGE.ASI;--------\\; BKREAD  >;========/; Lit le fichier gnral.; in	D6.W	canal FOS; out	D7.W	erreur; mod	D7.WBKREAD:	PUSHM.L	D1..D6,A2..A4	CALL	BKKILL		; libre toute la banque actuelle	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; D4 <-- longueur du fichier	LOAD.L	D2,D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP,NE ERROR$	GESMEM	?ARGMEM		; D4/D5 <-- libre/plus grand trou	LOAD.W	D7,#ERNEMEM	ADD.L	D2,#100000	; D2 <-- rserve de 100 k	COMP.L	D2,D4		; reste assez de mmoire ?	JUMP,HS ERROR$		; non => ERROR$	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D4,#256	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE ERROR$	LOAD.B	(A6)+OFLAGS,(A4)+4	LOAD.W	(A6)+OACTIV,(A4)+8	LOAD.L	A2,#(A6)+OBKTAB	CLR.W	D2LOOP$:	CLR.L	(A2)+OBKPIC	CLR.L	(A2)+OBKPTX	CLR.L	(A2)+OBKPII	CLR.L	(A2)+OBKNSI	CLR.L	(A2)+OBKDSI	LOAD.L	A4,#(A6)+OBUIO	LOAD.L	D4,#12	FOS	?RDBYTE		; lit les longueurs	JUMP,NE ERROR$	LOAD.L	(A2)+OBKFAN,(A6)+OBUIO+8	LOAD.L	D4,(A6)+OBUIO+0	JUMP',EQ PIC$	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE ERROR$	FOS	?RDBYTE		; lit une image	JUMP,NE ERROR$	LOAD.L	(A2)+OBKPIC,A4	CALL	IMAGEDECO	; A3 <-- ^image dcode	JUMP,NE ERROR$	CALL	BKSRCDIM	; D3/D4/D5 <-- origine/dim/nb	JUMP',NE CODE$	TEST.L	D3	JUMP',NE CODE$	LOAD.L	(A2)+OBKDSI,D4	LOAD.L	(A2)+OBKNSI,D5	CALL	BKPII		; D3 <-- ^image icne	LOAD.L	(A2)+OBKPII,D3CODE$:	CALL	IMAGECODE	; libre l'image dcodePIC$:	LOAD.L	D4,(A6)+OBUIO+4	JUMP',EQ PTX$	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE ERROR$	FOS	?RDBYTE		; lit un texte	JUMP,NE ERROR$	LOAD.L	(A2)+OBKPTX,A4PTX$:	INC.W	(A6)+OBKNBU	; OBKNBU <-- une image de plus	LOAD.L	A2,#(A2)+LBK	INC.W	D2	COMP.W	D2,#MAXIMA	JUMP,LO LOOP$ERROR$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	COMP.W	D7,#EROUTF	JUMP',NE EXIT$	CALL	BKSINIT		; init la recherche de sous-images avec mot	CLR.W	D7EXIT$:	POPM.L	D1..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; BKWRITE >;========/; Ecrit le fichier gnral.; in	D6.W	canal FOS; out	D7.W	erreur; mod	D7.WBKWRITE:	PUSHM.L	D2..D6,A2..A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D4,#256	GESMEM	?CLEARMEM	LOAD.L	(A4)+0,#H'0505	LOAD.B	(A4)+4,(A6)+OFLAGS	LOAD.W	(A4)+8,(A6)+OACTIV	FOS	?WRBYTE		; crit l'en-tte	JUMP,NE ERROR$	LOAD.L	A2,#(A6)+OBKTAB	CLR.W	D2	TEST.W	(A6)+OBKNBU	JUMP,EQ EXIT$LOOP$:	LOAD.L	A4,#(A6)+OBUIO	CLR.L	(A4)+0	CLR.L	(A4)+4	LOAD.L	(A4)+8,(A2)+OBKFAN	TEST.L	(A2)+OBKPIC	JUMP',EQ PIC$	LOAD.L	A3,(A2)+OBKPIC	; A3 <-- ^image code	LOAD.L	D3,(A3)+OIMNBB	ADD.L	D3,#LGHIMA	LOAD.L	(A4)+0,D3PIC$:	TEST.L	(A2)+OBKPTX	JUMP',EQ PTX$	LOAD.L	A3,(A2)+OBKPTX	; A3 <-- ^texte	CLR.L	D3LTX$:	INC.L	D3	TEST.B	(A3+)	JUMP,NE LTX$	LOAD.L	(A4)+4,D3PTX$:	LOAD.L	D4,#12	FOS	?WRBYTE		; crit les longueurs	JUMP',NE ERROR$	LOAD.L	A4,(A2)+OBKPIC	; A3 <-- ^image code	LOAD.L	D4,(A6)+OBUIO+0	JUMP',EQ WIC$	FOS	?WRBYTE		; crit l'image	JUMP',NE ERROR$WIC$:	LOAD.L	A4,(A2)+OBKPTX	; A3 <-- ^texte	LOAD.L	D4,(A6)+OBUIO+4	JUMP',EQ WTX$	FOS	?WRBYTE		; crit le texte	JUMP',NE ERROR$WTX$:	LOAD.L	A2,#(A2)+LBK	INC.W	D2	COMP.W	D2,(A6)+OBKNBU	JUMP,LO LOOP$	FOS	?CLOSE	JUMP'	EXIT$ERROR$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	POPM.L	D2..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; BKNEWIMAGE >;===========/; Charge une nouvelle image dans la banque.; in	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WBKNEWIMAGE:	PUSHM.L	D2..D5,A2..A4	LOAD.W	D7,#ERTIMTR	LOAD.L	A2,#(A6)+OBKTAB	LOAD.W	D2,(A6)+OBKNBU	COMP.W	D2,#MAXIMA	JUMP,HS EXIT$	MUL.WU	D2,#LBK	ADD.L	A2,D2		; A2 <-- ^dans OBKTAB	CALL	IMAGELOAD	; A4 <-- charge une image	JUMP',NE EXIT$	LOAD.L	(A2)+OBKPIC,A4	CLR.L	(A2)+OBKPII	CLR.L	(A2)+OBKPTX	CLR.L	(A2)+OBKNSI	CLR.L	(A2)+OBKDSI	LOAD.L	(A2)+OBKFAN,#2^BFAP66	CALL	IMAGEDECO	; A3 <-- ^image dcode	JUMP',NE EXIT$	CALL	BKSRCDIM	; D3/D4/D5 <-- origine/dim/nb	JUMP',NE CODE$	TEST.L	D3	JUMP',NE CODE$	LOAD.L	(A2)+OBKDSI,D4	LOAD.L	(A2)+OBKNSI,D5	LOAD.L	(A2)+OBKFAN,#2^BFAMEMORY!2^BFALETTRE!2^BFAPENDU!2^BFAPERMU!2^BFAGRILLE!2^BFAG1	CALL	BKPII		; D3 <-- ^image icne	LOAD.L	(A2)+OBKPII,D3CODE$:	CALL	IMAGECODE	; libre l'image dcode	TEST.L	(A2)+OBKNSI	JUMP',NE OK$	LOAD.W	D7,#ERTIMTP	COMP.W	(A4)+OIMDLX,#200	JUMP',LO EXIT$	COMP.W	(A4)+OIMDLY,#150	JUMP',LO EXIT$	LOAD.W	D7,#ERTIMTG	COMP.W	(A4)+OIMDLX,#540	JUMP',HI EXIT$	COMP.W	(A4)+OIMDLY,#320	JUMP',HI EXIT$OK$:	INC.W	(A6)+OBKNBU	; OBKNBU <-- une image de plus	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; BKREADTEXT >;===========/; Charge un nouveau texte dans la banque.; in	A3.L	^nom du texte;	A4.L	^dans OBKTAB; out	D7.W	erreur; mod	D7.WBKREADTEXT:	PUSHM.L	D1..D6,A2..A4	LOAD.L	A2,A4	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; D4 <-- longueur du fichier	LOAD.L	D2,D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP',NE CLOSE$	LOAD.L	D4,D2	INC.L	D4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer pour texte	JUMP',NE CLOSE$	DEC.L	D4	FOS	?RDBYTE		; lit le texte	JUMP',NE CLOSE$	CLR.B	(A4)+(D4.L)	FOS	?CLOSE	JUMP',NE EXIT$	LOAD.L	A3,A4	CALL	BKSYNTEXT	; syntaxe correcte ?	JUMP',NE EXIT$	TEST.L	(A2)+OBKPTX	JUMP',EQ RELOK$	LOAD.L	A4,(A2)+OBKPTX	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEMRELOK$:	LOAD.L	(A2)+OBKPTX,A3	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$CLOSE$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	POPM.L	D1..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; BKSYNTEXT >;==========/; Vrifie la syntaxe d'un texte.; in	A3.L	^texte; out	D7.W	erreur; mod	D7.WBKSYNTEXT:	PUSHM.L	D3,D4,A3,A4	COMP.L	A3,#0	JUMP',EQ OK$LOOP$:	LOAD.W	D4,#-1LINE$:	INC.W	D4	LOAD.B	D3,(A3+)	JUMP',EQ OK$	COMP.B	D3,#CR	JUMP',EQ END$	COMP.B	D3,#'|	JUMP',EQ END$	LIB	?MINMAJ	COMP.B	D3,#'*	JUMP,EQ LINE$	COMP.B	D3,#'-	JUMP,EQ LINE$	LOAD.W	D7,#ERTTXLI	COMP.B	D3,#SPACE	JUMP',EQ EXIT$	LOAD.W	D7,#ERTTXCA	COMP.B	D3,#'A	JUMP',LO EXIT$	COMP.B	D3,#'Z	JUMP',HI EXIT$	JUMP	LINE$END$:	LOAD.W	D7,#ERTTXTL	COMP.W	D4,#30	JUMP',HI EXIT$	JUMP	LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; BKDELETE  >;==========/; Supprime une image de la banque.; in	D3.W	rang de l'image  supprimer; out	-; mod	D7.WBKDELETE:	PUSHM.L	D1,D3,D4,A3,A4	TEST.W	(A6)+OBKNBU	JUMP',EQ EXIT$	CALL	BKKILLONE	; libre l'image	INC.W	D3	LOAD.W	D4,D3	SUB.W	D3,(A6)+OBKNBU	JUMP',HS LAST$	NEG.W	D3	LOAD.L	A4,#(A6)+OBKTAB	MUL.WU	D4,#LBK	ADD.L	A4,D4	LOAD.L	A3,#(A4)-LBKXFER2$:	LOAD.W	D4,#(LBK/2)-1XFER4$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,XFER4$	DEC.W	D3	JUMP,NE XFER2$LAST$:	DEC.W	(A6)+OBKNBU	; OBKNBU <-- une image de moinsEXIT$:	POPM.L	D1,D3,D4,A3,A4	RET;--------\\; BKPII   >;--------/; Met de ct l'image icne.; in	A4.L	^image code;	A3.L	^image dcode;	D4.L	dimensions d'une sous-image (dy;dx); out	D3.L	^image icne; mod	D3.L, D7.WBKPII:	PUSHM.L	D0,D1,D4,A1..A4	LOAD.L	A1,A3	LOAD.L	A2,A4	LOAD.L	D0,D4	JUMP,EQ ERROR$	ADD.W	D4,#LXICO/8	MUL.WU	D4,#LYICOP	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour image icne	JUMP',NE ERROR$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	INC.W	D0	LOAD.W	(A3)+1,D0	LOAD.W	(A3)+3,#1	LOAD.L	(A3)+5,A1	LOAD.W	D3,(A2)+OIMDLX	SR.W	D3,#3	LOAD.W	(A3)+9,D3	; source: <ii>	CLR.L	(A3)+11	LOAD.L	(A3)+15,A4	LOAD.W	(A3)+19,#LXICO/8	LOAD.W	(A3)+21,#LXICO	LOAD.W	(A3)+23,#LYICOP	LOAD.B	(A3)+25,#LOADDOT	LOAD.W	D3,#26	LIB	?STRING	LOAD.L	D3,A4		; D3 <-- ^image icne	JUMP'	EXIT$ERROR$:	CLR.L	D3EXIT$:	POPM.L	D0,D1,D4,A1..A4	RET;--------\\; BKKILL  >;========/; Libre toute la banque d'images.; in	-; out	-; mod	D7.WBKKILL:	PUSHM.L	D2,D3	CLR.W	D3	LOAD.W	D2,(A6)+OBKNBU	JUMP',EQ EXIT$LOOP$:	CALL	BKKILLONE	; libre une image	INC.W	D3	DEC.W	D2	JUMP,NE LOOP$	CLR.W	(A6)+OBKNBU	; plus aucune imageEXIT$:	POPM.L	D2,D3	RET;----------\\; BKKILLONE >;----------/; Libre une image de la banque.; in	D3.W	rang de l'image (0..n); out	-; mod	D7.WBKKILLONE:	PUSHM.L	D1,D3,A3,A4	LOAD.L	A3,#(A6)+OBKTAB	MUL.WU	D3,#LBK	ADD.L	A3,D3		; A3 <-- ^dans OBKTAB	TEST.L	(A3)+OBKPII	JUMP',EQ PII$	LOAD.L	A4,(A3)+OBKPII	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'image icnePII$:;	TEST.L	(A3)+OBKPIC;	JUMP',EQ PIC$	LOAD.L	A4,(A3)+OBKPIC	; A4 <-- ^image code	CALL	IMAGEKILL	; libre l'imagePIC$:	TEST.L	(A3)+OBKPTX	JUMP',EQ PTX$	LOAD.L	A4,(A3)+OBKPTX	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le textePTX$:	POPM.L	D1,D3,A3,A4	RET;---------\\; BKSRCDIM >;---------/; Fouille dans l'image pour trouver les dimensions d'une sous-image.; in	A4.L	^image (code);	A3.L	^image (dcode); out	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D5.L	nb de cartes (ny;nx);	D7.W	erreur; mod	D3.L, D4.L, D5.L, D7.WBKSRCDIM:	PUSHM.L	D1,D2	CLR.L	D4	LOAD.W	D2,#20-1LOOPY$:	CLR.W	D4	LOAD.W	D3,#20-1LOOPX$:	CALL	BKTESTPOINT	; point allum ?	JUMP',BS ORIGINE$	INC.W	D4	DECJ.W,NMO D3,LOOPX$	SWAP.W	D4	INC.W	D4	SWAP.W	D4	DECJ.W,NMO D2,LOOPY$ERROR$:	CLR.L	D3	CLR.L	D4	CLR.L	D5	LOAD.W	D7,#ERDIND	; D7 <-- image indcodable	JUMP	EXIT$ORIGINE$:	LOAD.L	D3,D4		; D3 <-- origine trouve;	LOAD.L	D4,D3	INC.W	D4	LOAD.W	D2,(A4)+OIMDLX	SUB.W	D2,D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4DIMX$:	CALL	BKTESTPOINT	; point allum ?	JUMP',BS DIMXOK$	INC.W	D4	DEC.W	D2	JUMP,NE DIMX$	JUMP	ERROR$DIMXOK$:	LOAD.W	D1,D4	SUB.W	D1,D3		; D1 <-- largeur d'une "carte"	COMP.W	D1,#10	JUMP,LO ERROR$	LOAD.L	D4,D3	INC.W	D4	SWAP.W	D4	INC.W	D4	LOAD.W	D2,(A4)+OIMDLY	SUB.W	D2,D4	SWAP.W	D4DIMY$:	CALL	BKTESTPOINT	; point allum ?	JUMP',BS DIMYOK$	SWAP.W	D4	INC.W	D4	SWAP.W	D4	DEC.W	D2	JUMP,NE DIMY$	JUMP	ERROR$DIMYOK$:	SWAP.W	D1	SWAP.W	D4	LOAD.W	D1,D4	SUB.W	D1,D3		; D1 <-- hauteur d'une "carte"	COMP.W	D1,#10	JUMP,LO ERROR$	CLR.L	D5	LOAD.W	D5,(A4)+OIMDLY	SWAP.W	D3	SUB.W	D5,D3	SWAP.W	D3	DIV.WU	D5,D1		; D5 <-- nb max possible	SWAP.W	D5	SWAP.W	D1	CLR.L	D2	LOAD.W	D2,(A4)+OIMDLX	SUB.W	D2,D3	DIV.WU	D2,D1		; D2 <-- nb max possible	LOAD.W	D5,D2	LOAD.L	D2,D5	SWAP.W	D2	MUL.WU	D2,D5	COMP.W	D2,#256	JUMP,HS ERROR$	LOAD.L	D4,D1	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;------------\\; BKTESTPOINT >;------------/; Teste si un point est allum dans une image.; in	A4.L	^image (code);	A3.L	^image (dcode);	D4.L	point (y;x); out	F	BC/BS si point teint/allum; mod	-BKTESTPOINT:	PUSHM.L	D2,D3	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- position en Y	LOAD.W	D2,(A4)+OIMDLX	SR.W	D2,#3		; D2 <-- largeur en bytes	MUL.WU	D3,D2	CLR.L	D2	LOAD.W	D2,D4		; D2 <-- position en X	SR.W	D2,#3	ADD.L	D3,D2	LOAD.W	D2,D4	NOT.B	D2	AND.B	D2,#B'111	TEST.B	(A3)+(D3.L):D2	; regarde si le point est allum	POPM.L	D2,D3	RET;--------\\; BKSINIT >;========/; Initialise la recherche de sous-images avec BKSNEXT.; in	-; out	-; mod	D7.WBKSINIT:	PUSHM.L	D2..D4,A3,A4	LOAD.W	D3,#-1	LOAD.W	D4,#-1CNT$:	INC.W	D4	CALL	BKSNEXT		; D3/A3/A4 <-- suivant	JUMP,EQ CNT$	COMP.W	D4,#MAXSIMA	JUMP',LS NBI$	LOAD.W	D4,#MAXSIMANBI$:	LOAD.W	(A6)+OBKSNB,D4	JUMP',EQ EXIT$	CLR.W	D3	LOAD.L	A4,#(A6)+OHABKS	CALL	RZHAZARDEXIT$:	POPM.L	D2..D4,A3,A4	RET;--------\\; BKSNEXT >;========/; Cherche la sous-image suivante, ayant un mot associ compos de lettres.; in	A3.L	^mot de la sous-image;	D3.W	numro de l'image;	D2.W	numro de la sous-image; out	A3.L	^mot de la sous-image;	D3.W	numro de l'image;	D2.W	numro de la sous-image;	A4.L	^dans OBK*;	D7.W	erreur; mod	D2.L, D3.L, D7.W, A3.L, A4.LBKSNEXT:	PUSH.L	D4	TEST.W	D3	JUMP',NC TEXT$IMAGE$:	LOAD.W	D7,#ERTIMEX	INC.W	D3		; D3 <-- image suivante	COMP.W	D3,(A6)+OBKNBU	JUMP,HS EXIT$	LOAD.L	A4,#(A6)+OBKTAB	LOAD.W	D4,D3	MUL.WU	D4,#LBK	ADD.L	A4,D4	TEST.L	(A4)+OBKPTX	; y a-t-il un texte ?	JUMP,EQ IMAGE$		; non => IMAGE$	LOAD.L	A3,(A4)+OBKPTX	; A3 <-- ^texte associ  l'image	LOAD.W	D2,#2	JUMP'	FIRST$TEXT$:	LOAD.B	D4,(A3+)	JUMP,EQ IMAGE$	COMP.B	D4,#CR	JUMP,NE TEXT$	INC.W	D2		; D2 <-- sous-image suivanteFIRST$:	LOAD.B	D4,(A3)	JUMP,EQ IMAGE$	EX.L	D3,D4	LIB	?MINMAJ	EX.L	D4,D3	COMP.B	D4,#'A	JUMP,LO TEXT$	COMP.B	D4,#'Z	JUMP,HI TEXT$	CLR.W	D7EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; BKSEXIST >;=========/; Regarde s'il existe une ou plusieurs images.; in	D4.W	bit fanion (FBA*); out	D7.W	erreur; mod	D7.WBKSEXIST:	PUSHM.L	D2,D3,A3	LOAD.W	D7,#ERTIMEX	LOAD.L	A3,#(A6)+OBKTAB	LOAD.W	D3,(A6)+OBKNBU	JUMP',EQ EXIT$LOOP$:	TEST.L	(A3)+OBKPTX	; texte existe ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	D2,(A3)+OBKFAN	TEST.L	D2:D4	JUMP',BS OK$NEXT$:	LOAD.L	A3,#(A3)+LBK	DEC.W	D3	JUMP,NE LOOP$	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGELOAD >;==========/; Charge une image en mmoire.; in	A3.L	^nom de l'image; out	A4.L	^image (code);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D4.L, D7.W, A4.LIMAGELOAD:	PUSHM.L	D1..D3,D6,A2,A3	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	A2,#R16"PREF$NAME1$:	LOAD.B	(A4+),(A2+)	; OBUDIS <-- prfixe	JUMP,NE NAME1$	DEC.L	A4NAME2$:	LOAD.B	(A4+),(A3+)	; OBUDIS <-- nom de l'image	JUMP,NE NAME2$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; D4 <-- longueur du fichier	LOAD.L	D2,D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP',NE CLOSE$	LOAD.L	D4,D2	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer pour image	JUMP',NE CLOSE$	FOS	?RDBYTE		; lit l'image	JUMP',NE GIVMEM$	LOAD.W	D4,(A4)+OIMDLY	; D4 <-- hauteur de l'image	SWAP.W	D4	LOAD.W	D4,(A4)+OIMDLX	; D4 <-- largeur de l'image	JUMP'	CLOSE$GIVMEM$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'image	POP.W	D7CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7EXIT$:	POPM.L	D1..D3,D6,A2,A3	TEST.W	D7		; retour EQ/NE	RETPREF$:	.ASCIZ	"(:,#:)"	; d'abord dans dossier courant, puis systme !	.EVEN;----------\\; IMAGESHOW >;==========/; Affiche une image.; in	A4.L	^image (code);	D3.L	coin sup/gauche (y;x); out	D7.W	erreur; mod	D7.WIMAGESHOW:	PUSHM.L	D2..D4,A3	CALL	IMAGEDECO	; A3 <-- ^image dcode	JUMP',NE EXIT$	LOAD.L	D2,D3		; D2 <-- position dans l'cran	CLR.L	D3		; D3 <-- position dans l'image	CLR.L	D4		; D4 <-- dimensions (tout)	CALL	IMAGEAFF	; affiche l'image	CALL	IMAGECODE	; libre l'image dcode	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGEDECO >;----------/; Dcode l'image lue.; in	A4.L	^image (code); out	A3.L	^image (dcode);	D7.W	erreur; mod	D7.W, A3.LIMAGEDECO:	PUSHM.L	D1,D4,A2,A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A3,#(A4)+LGHIMA	; A3 <-- ^data de l'image	TEST.B	(A4)+OIMCOD	; image code ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.L	A2,A4		; A2 <-- ^image code	LOAD.W	D4,(A2)+OIMDLX	SR.W	D4,#3	MUL.WU	D4,(A2)+OIMDLY	; D4 <-- largeur*hauteur/8	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	JUMP',NE EXIT$	EX.L	A3,A4	PUSH.B	(A2)+OIMCOD	PUSH.L	(A2)+OIMNBB;;?	GRA_	DECOIMA		; dcode l'image ...CALL _GRA_DECOIMA	POP.L	(A2)+OIMNBB	POP.B	(A2)+OIMCOD	TEST.W	D7	JUMP',EQ EXIT$	PUSH.W	D7	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'image	POP.W	D7EXIT$:	POPM.L	D1,D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGECODE >;----------/; Libre l'image dcode.; in	A4.L	^image (code);	A3.L	^image (dcode); out	-; mod	D7.WIMAGECODE:	PUSHM.L	D1,A4	TEST.B	(A4)+OIMCOD	; image code ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'image dcodeEXIT$:	POPM.L	D1,A4	RET;---------\\; IMAGEAFF >;---------/; Affiche une partie d'image.; in	A4.L	^image (code);	A3.L	^image (dcode);	D2.L	position dans l'cran (y;x);	D3.L	position dans l'image (y;x);	D4.L	dimensions (dy;dx)  (si zro => tout); out	-; mod	D7.WIMAGEAFF:	PUSHM.L	D2..D4,A2,A3	LOAD.L	A2,A3		; A2 <-- ^image dcode	TEST.L	D4	JUMP',NE DIMOK$	LOAD.W	D4,(A4)+OIMDLY	; D4 <-- hauteur de l'image	SWAP.W	D4	LOAD.W	D4,(A4)+OIMDLX	; D4 <-- largeur de l'imageDIMOK$:	COMP.W	D4,(A4)+OIMDLX	JUMP',LS DIMX$	LOAD.W	D4,(A4)+OIMDLXDIMX$:	SWAP.W	D4	COMP.W	D4,(A4)+OIMDLY	JUMP',LS DIMY$	LOAD.W	D4,(A4)+OIMDLYDIMY$:	SWAP.W	D4	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^buffer pour DRAWRASTER	LOAD.W	(A3)+12,D2	; destination: <xx>	SWAP.W	D2	LOAD.W	(A3)+14,D2	; destination: <yy>	LOAD.W	D2,(A4)+OIMDLX	SR.W	D2,#3	LOAD.W	(A3)+10,D2	; source: <ii>	CLR.W	(A3)+20		; destination: <ii>	LOAD.W	(A3)+2,D3	; source: <xx>	SWAP.W	D3	LOAD.W	(A3)+4,D3	; source: <yy>	LOAD.W	(A3)+22,D4	; image: <dxx>	SWAP.W	D4	LOAD.W	(A3)+24,D4	; image: <dyy>	LOAD.W	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+6,A2	; source: <pppp>	CLR.L	(A3)+16		; destination: <pppp>	LOAD.B	(A3)+26,#LOADDOT	TEST.B	(A6)+OINV	; affichage invers ?	JUMP',F DRAW$	LOAD.B	(A3)+26,#LOADDOT!CPLDOTDRAW$:	LOAD.W	D3,#1+26	; D3 <-- longueur	LIB	?STRING		; affiche l'image	POPM.L	D2..D4,A2,A3	RET;----------\\; IMAGEKILL >;==========/; Libre la mmoire d'une image.; in	A4.L	^image (code); out	-; mod	-IMAGEKILL:	PUSHM.L	D1,D7,A4	COMP.L	A4,#0	JUMP',EQ EXIT$	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'imageEXIT$:	POPM.L	D1,D7,A4	RET; ***************************************************************************************************; ***************************************************************************************************;	LE SMAKY-300 COULEUR A UN BUG DANS DECOIMA !!!; ***************************************************************************************************; ***************************************************************************************************DD_4 = 4;-------------\\; _GRA_DECOIMA >;=============/; dcodage d'une image en format DD-4;; in:	A3.32		^buffer image dcode	(suprieur ou gal  #{A4}+IMLBUF);	A4.32		^image code;	A2.32		^entte du fichier image; out:	{A3}+++		buffer rempli avec l'image decode;	{A2}+OIMCOD	signale image non code;	{A2}+OIMNBB	longueur image non code;	D7.16		erreur;			#ERDIBUF buffers incorrects;			#ERDIND image non dcodable (autre code);			#ERDIDD image dj dcode; mod	D7.16_GRA_DECOIMA:	PUSHM.L		A0,A1,D0..D5	; vrifie d'abord si l'image est code avec un code connu	; -------------------------------------------------------	LOAD.W		D7, #ERDIND		; erreur pas cod	TEST.B		(A2)+OIMCOD		; si COD=0	JUMP,EQ		RET$	LOAD.W		D7, #ERDIDD		; erreur mauvais code	COMP.B		(A2)+OIMCOD, #DD_4	; si pas DD_4	JUMP,NE		RET$	; Contrle l'espacement minimal des ^	; -----------------------------------	CALL		TSTSPACE		; A3-A4 suffisant?	JUMP,NE		RET$			; non -> erreur	; Dcode depuis le bas	; --------------------	LOAD.L		A1, A4			; ^image code	LOAD.L		D4, (A2)+OIMNBB		; nb de byte data cod	ADD.L		A1, D4			; ^fin du data cod	LOAD.W		D0, (A2)+OIMDLX		; largeur * hauteur	ADD.W		D0, #8-1		; image non multiple de 8 pts	SR.W		D0, #3			; /8 en octet	MUL.WU		D0, (A2)+OIMDLY		; surface image dcode	LOAD.L		A0, A3			; ^buffer image dcode	LOAD.L		(A2)+OIMNBB, D0		; lg data dcod	LOAD.L		D5, D0			; capacit destination	CLR.B		(A2)+OIMCOD		; signale plus cod	ADD.L		A0, D0			; ^fin buffer dcodage	CLR.L		D3	LOAD.B		D3, (-A1)		; valeur restante cpt au codage	DEC.L		D4NXTM$:	LOAD.B		D0, (-A1)		; MAP	DEC.L		D4			; fin data?	JUMP',CS	FIN$			; si fini juste avant MAPNXTP$:	TEST.L		D4			; fin des datas	JUMP',EQ	FIN$	JUMP',NS	FAT$			; contrle cohrence	DEC.L		D5			; vrifie buffer destination	JUMP',CS	FAT$			; pas possible	LOAD.B		(-A0), (-A1)		; copie paterne	DEC.L		D4			; fin data?;	JUMP',CS	FAT$			; pas possible	TEST.L		D0:D3			; code?	JUMP',F		NC$			; non -> saute	LOAD.B		D2, (-A1)		; nb d'identiques	DEC.L		D4	DEC.B		D2			; dj un en placeLP$:	DEC.L		D5			; reste de la place ?	JUMP',CS	FAT$			; pas possible	LOAD.B		(-A0), (A0)		; copie paterne	DEC.B		D2			; encore une copie?	JUMP,NE		LP$			; oui -> lp$NC$:	INC.L		D3			; ^MAP suivant	COMP.B		D3, #D'8		; 8 passs?	JUMP,LO		NXTP$			; lower -> boucle	LOAD.L		D3, #0			; init cpt MAP	JUMP		NXTM$			; -> nxtm$FIN$:	TEST.L		D5			; destination bien pleine ?	JUMP',EQ	RET$			; oui -> okFAT$:	LOAD.W		D7, #ERDIND		; pas possible!RET$:	TEST.W		D7	POPM.L		A0,A1,D0..D5	RET;---------\\; TSTSPACE >;---------/; test si les pointeurs sont corrects pour le fonctionnement;; in:	A3.32		^image dcode;	A4.32		^image code;	A2.32		^entte image; out:	D7.16		erreur/ok; mod:	D7.16, D0.32TSTSPACE:	LOAD.W		D7, #ERDIBUF		; buffer incorrect ?	LOAD.L		D0, A3			; ^image dcode	SUB.L		D0, A4			; ^image cod	JUMP',CS	50$			; A4>A3 -> test 2	COMP.L		D0, #IMLBUF		; pas la place?	JUMP',LO	90$			; non -> erreur	JUMP'		80$			; oui -> ok50$:	LOAD.W		D0, (A2)+OIMDLX		; largeur * hauteur	MUL.WU		D0, (A2)+OIMDLY		; = surface	SR.L		D0, #D'3		; /8 -> nb d'octets	ADD.L		D0, A3			; ^fin image	COMP.L		D0, A4			; fin>A4	JUMP',HI	90$			; oui -> erreur80$:	CLR.W		D7			; non -> correct90$:	TEST.W		D7	RET	.END