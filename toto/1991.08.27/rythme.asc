	.TITLE	RYTHME	.PROC	M680002	.REF	SMAKY; Dfinitions du hardware SMAKY100; --------------------------------SGDATA	=	H'FF9C01	; data pour le PSGSGADR	=	H'FF9E01	; adresse pour le PSGSGRP0	=	H'0		; priode gn. 0 (12 bits)SGRP1	=	H'2		; priode gn. 1 (12 bits)SGRP2	=	H'4		; priode gn. 2 (12 bits)SGRPN	=	H'6		; priode gn. bruit (5 bits)SGRMIX	=	H'7		; mixerSGRA0	=	H'8		; amplitude gn. 0 (1+4 bits)SGRA1	=	H'9		; amplitude gn. 1 (1+4 bits)SGRA2	=	H'A		; amplitude gn. 2 (1+4 bits)SGRPE	=	H'B		; priode enveloppe (16 bits)SGRENV	=	H'D		; mode de l'enveloppeSGRIO	=	H'E		; port i/o	.LOC	0OPS:	.BLKB	4LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.L	A3,#R16"NOM	CALL	LOADSOUND	JUMP,NE FIN	LOAD.L	(A6)+OPS,A4	LOAD.L	A4,#R16"TABLE	LOAD.W	D4,#1LOOP:	CALL	RYTHME	DEC.W	D4	JUMP,NE LOOPFIN:	TEST.L	(A6)+OPS	JUMP,EQ RETOUR	LOAD.L	A4,(A6)+OPS	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPSRETOUR:	EXITNOM:	.ASCIZ	"TOTO_C.SOUND"	.EVENTABLE:	.W	5,0,0,0,5,0,6,0	.W	5,0,0,0,5,6,6,6	.W	5,0,0,0,5,6,6,6	.W	1,0,2,0,1,0,2,2	.W	1,0,2,0,1,0,2!2^15,2!2^15,2!2^15,2!2^15	.W	1,0,2,0,1,0,2,2	.W	1,0,2,0,1,0,2!2^15,2!2^15,2!2^15,2!2^15	.W	1,0,2,8,1,0,2,8!2^15,8!2^15	.W	1,7,2,8,1,7,2,8!2^15,8!2^15	.W	1,0,2,8,1,0,2,8!2^15,8!2^15	.W	1,0,3,0,1,0,3,3	.W	1,0,3,0,1,2,3,3	.W	1,0,3,0,1,0,3,3	.W	1,0,3,0,1,2,3!2^15,3!2^15,3!2^15,3!2^15	.W	1,0,0,0,4,0,4,4	.W	3,0,0,0,1,0,1,2!2^15,2!2^15	.W	1,0,3,0,1,0,3,2!2^15,2!2^15	.W	1,0,0,2!2^15,2!2^15,1,0,0,2!2^15,2!2^15	.W	1,0,0,2,1,0,3,2	.W	1,0,0,2,1,0,3,2!2^15,2!2^15	.W	1,0,1,0,3,0,0,0	.W	3,0,3,3,1,0,0,1	.W	1,0,2,0,1,0,2,2	.W	1,0,2,0,1,0,2!2^15,2!2^15,2!2^15,2!2^15	.W	1,0,2,0,1,0,2,2	.W	1,0,2,0,1,0,2!2^15,2!2^15,2!2^15,2!2^15	.W	1,0,2,8,1,0,2,8!2^15,8!2^15	.W	1,7,2,8,1,7,2,8!2^15,8!2^15	.W	1,0,2,8,1,0,2,8!2^15,8!2^15	.W	1,0,3,0,1,0,3,3	.W	5,0,0,0,5,6,6,6	.W	5,0,0,0,5,6,6,6	.W	5,0,0,0,5,0,6,0	.W	-1	.W	1,0,0,0,1,0,0,0	.W	1,0,2,0,1,0,2,0	.W	1,0,2,3,1,0,2,3!2^15,3!2^15	.W	1,7,2,3,1,7,2,3!2^15,3!2^15	.W	1,8,2,3,1,8,2,3!2^15,3!2^15	.W	1,5,2,3,1,5,2,3!2^15,3!2^15	.W	1,6,2,3,1,6,2,3!2^15,3!2^15	.W	5,0,5,0,5,0,6,0	.W	5,0,6,0,5,0,6,0	.W	5,0,6,0,5,0,6,6	.W	5,0,6,0,5,6,6,6	.W	1,0,5,0,1,0,5,4	.W	1,0,5,0,1,0,5,4	.W	1,0,5,3,1,0,5,3	.W	1,0,2,3,1,0,2,3	.W	1,0,4,0,1,0,4,0	.W	1,0,4,0,1,2,4,0	.W	1,0,4,0,1,2,4,0	.W	7,0,8,0,7,0,8,8!2^15,8!2^15	.W	7,0,8,0,7,5,6,6	.W	4,0,8,8,4,0,8,7!2^15,7!2^15	.W	4,0,8,8,4,0,8,7!2^15,7!2^15	.W	1,0,8,0,1,0,1,0	.W	1,0,0,0,1,0,1,1	.W	1,0,2,2,1,0,7,7	.W	1,0,2,2,1,0,8,8	.W	1,0,2,2,1,0,8!2^15,8!2^15,8!2^15,8!2^15	.W	1,0,3,0,1,0,3,3	.W	1,0,3,0,1,0,3,7	.W	3,0,0,0,3,0,0,0	.W	3,0,0,0,0,0,0,0	.W	-1;--------\\; RYTHME  >;========/; ; in	A4.L	^rythme; out	-; mod	D7.WRYTHME:	PUSHM.L	D3,D4,A420$:	LOAD.W	D4,(A4+)	JUMP,EQ 50$	COMP.W	D4,#-1	JUMP,EQ 90$	LOAD.W	D3,#24	TCLR.L	D4:#15	JUMP',BC 30$	TSET.L	D3:#1530$:	ADD.W	D4,#14	CALL	ANALOG	JUMP	20$50$:	LOAD.W	D4,#8	NTREL	?DELMS	JUMP	20$90$:	POPM.L	D3,D4,A4	RET;----------\\; LOADSOUND >;==========/; Charge des sons en mmoire.; in	A3.L	^nom de sons; out	A4.L	^sons analogiques appondus;	D7.W	erreur; mod	D7.W, A4.LLOADSOUND:	PUSHM.L	D1,D3,D4,D6	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre les sons	JUMP,NE 90$	LOAD.L	D4,#-1	LOAD.B	D3,D4	FOS	?SPOS		; D4 <-- longueur du fichier	PUSH.L	D4	CLR.L	D4	CLR.B	D3	FOS	?SPOS		; revient au dbut	POP.L	D4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer pour le fichier sons	JUMP',NE 82$	FOS	?RDBYTE		; lit tout le fichier sons	JUMP',EQ 82$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire des sons	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme les sons	POP.W	D790$:	POPM.L	D1,D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; ANALOG  >;========/; Fait entendre un son analogique.; in	D4.W	rang du son;	D3.W	priode; out	-; mod	D7.WANALOG:	PUSHM.L	D2..D4,A1,A4	LOAD.L	A4,(A6)+OPS	; A4 <-- ^sons analogiques	DEC.W	D4	JUMP',NS 22$20$:	ADD.L	A4,(A4+)	; A4 <-- ^son suivant	DECJ.W,NMO D4,20$22$:	LOAD.L	D4,(A4+)	; D4 <-- longueur	LOAD.W	D2,#1		; D2 <-- nb de rptitions	TCLR.L	D3:#15	JUMP',BC 40$	SR.L	D4,#140$:	LOAD.L	A1,#R16"PLAY	CALL	EXIOF		; musique ...	JUMP'	90$50$:	DIV.WU	D4,#8000/50	; 8000 --> ~50 (une seconde)	NTREL	?DELMS		; attend un peu ...90$:	POPM.L	D2..D4,A1,A4	RET;--------\\; PLAY    >;========/; Fait entendre un son analogique (parole ou musique).; in	A4.L	^chantillons;	D4.L	nombre d'chantillons;	D3.W	priode;	D2.W	nombre de rptitions; out	-; mod	D7.WPLAY:	PUSHM.L	D0..D5,A4,A5	LOAD.B	SGADR,#SGRMIX	LOAD.B	SGDATA,#B'11000000	LOAD.B	SGADR,#SGRIO	LOAD.L	A5,A4	LOAD.L	D5,D420$:	LOAD.L	A4,A5	LOAD.L	D4,D530$:	LOAD.B	D0,(A4+)	LOAD.B	SGDATA,D0	LOAD.W	D1,D340$:	DECJ.W,NMO D1,40$	SR.B	D0,#4	LOAD.B	SGDATA,D0	LOAD.W	D1,D350$:	DECJ.W,NMO D1,50$	DEC.L	D4	JUMP,NE 30$	DEC.W	D2	JUMP,NE 20$	LOAD.B	SGADR,#SGRMIX	LOAD.B	SGDATA,#B'00000000	POPM.L	D0..D5,A4,A5	RET;--------\\; EXIOF   >;========/; Excute une routine quelconque IOF.; in	A1.L	^routine  excuter;	+	selon routine; out	+	selon routine; mod	D7.WEXIOF:	PUSHM.L	D0,A0	LOAD.L	A0,#R16"TRAP$	LOAD.L	D0,H'80+4*15	LOAD.L	H'80+4*15,A0	TRAP	#15		; passe en mode "superviseur"	LOAD.L	H'80+4*15,D0	POPM.L	D0,A0	RETTRAP$:	OR.W	SF,#H'0700	; met IOF total	CALL	(A1)		; excute la routine ...	RETSFVAR:	.FILLB	LGVAR,0	.END	START