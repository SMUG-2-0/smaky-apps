	.SBTTL	TSDBOX.ASIDAPSL	=	10DAPIM	=	DAPSL+14DALIM	=	32;---------\\; DBOXDATA >;=========/; Dialogue pour dfinir toutes les donnes de TOTO.; in	-; out	D7.W	erreur; mod	D7.WDBOXDATA:	PUSHM.L	D0..D6,A2..A5	CALL	SCMO		; visible	LOAD.L	A2,#R16"TDBOX_DATA	CLR.W	D2		; D2 <-- mode sans sauver le fond !	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	A5,#(A6)+ODAVSL	; A5 <-- ^variables scroll-liste	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#2	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	PUSH.L	D3	LOAD.W	D2,#101!2^BDBGCLABEL	DBOX_	GETCO	POP.L	D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	ADD.W	D3,(A0)+ODFC1Y	SUB.W	D3,#2	SWAP.W	D3;	SWAP.W	D4	LOAD.L	(A5)+OSLDIM,D3	SET.B	(A5)+OSLVID	LOAD.L	A3,#R16"TXVIDE$	SCROLL_	LDRAW		; dessine la scroll-liste videUPDATE$:	CLR.W	(A5)+OSLCYS	TEST.W	(A6)+OBKNBU	JUMP',NE UPDATE2$	DEC.W	(A5)+OSLCYSUPDATE2$:	LOAD.W	(A5)+OSLCYN,(A6)+OBKNBU	LOAD.L	A3,#R16"DBDAGETTX	LOAD.L	(A5)+OSLADL,A3	SCROLL_	LUPDATE		; dessine le contenu de la scroll-listeAFF$:	CALL	DBDASHOW	; affiche l'imageLOOP$:	CALL	NORMMOUSE	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_DATA	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#CR	JUMP,EQ CLOSE$	COMP.W	D3,#KEYDBOX+4	JUMP,EQ PREND$	COMP.W	D3,#KEYDBOX+5	JUMP,EQ SAUVE$	COMP.W	D3,#KEYDBOX+7	JUMP,EQ EDIT$	COMP.W	D3,#KEYDBOX+8	JUMP,EQ PTEXT$	COMP.W	D3,#KEYDBOX+9	JUMP,EQ PIMAGE$	COMP.W	D3,#KEYDBOX+10	JUMP,EQ INFO$	COMP.W	D3,#F11	JUMP,EQ SUPP$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ERROR$:	CALL	DBOXERROR	; affiche l'erreur ...	CALL	DBOXRSK	JUMP	UPDATE2$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	SCROLL_	LMOVE		; dplace la scroll-liste ...	JUMP,NE BIP$	JUMP	AFF$PREND$:	TEST.B	(A6)+OMAJ	JUMP',EQ PBEGIN$	CLR.L	D3	CALL	DBOXMTOTO	; met  jour ...	PUSH.W	D7	CALL	DBOXRSK	POP.W	D7	JUMP,NE ERROR$	COMP.W	D3,#F4	JUMP',EQ PBEGIN$	COMP.W	D3,#F1	JUMP,NE LOOP$	TEST.B	(A3)	JUMP',NE PMAJ$	CALL	DBOXSTOTO	; A3 <-- ^nom  sauver	PUSH.W	D7	CALL	DBOXRSK	POP.W	D7	JUMP,NE ERROR$	COMP.W	D3,#F0	JUMP,EQ LOOP$PMAJ$:	CALL	WAITMOUSE	FOS	?DELETE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP,NE ERROR$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE ERROR$	CALL	BKWRITE		; crit le fichier gnral	JUMP,NE ERROR$	CLR.B	(A6)+OMAJPBEGIN$:	CLR.B	(A6)+OBUNAMPLOOP$:	CALL	NORMMOUSE	CALL	DBOXPTOTO	; A3 <-- ^nom  prendre	PUSH.W	D7	CALL	DBOXRSK	POP.W	D7	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE UPDATE2$	CALL	WAITMOUSE	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE PERR$	CALL	BKREAD		; lit le fichier gnral	JUMP',NE PERR0$	CLR.B	(A6)+OMAJ	JUMP	UPDATE$PERR0$:	LOAD.W	(A5)+OSLCYS,#-1PERR$:	CALL	DBOXERROR	; affiche l'erreur ...	CALL	DBOXRSK	JUMP	PLOOP$SAUVE$:	CALL	DBOXSTOTO	; A3 <-- ^nom  sauver	PUSH.W	D7	CALL	DBOXRSK	POP.W	D7	JUMP,NE ERROR$	COMP.W	D3,#F0	JUMP,EQ LOOP$	LOAD.W	D2,D3SCREATE$:	CALL	WAITMOUSE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',EQ SWRITE$	COMP.W	D7,#ERFAEX	JUMP,NE ERROR$	COMP.W	D2,#F4	JUMP',EQ SDELETE$	CALL	NORMMOUSE	CALL	DBOXDTOTO	; faut-il dtruire ?	PUSH.W	D7	CALL	DBOXRSK	POP.W	D7	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE SAUVE$SDELETE$:	CALL	WAITMOUSE	FOS	?DELETE	JUMP,NE ERROR$	CLR.W	D2	JUMP	SCREATE$SWRITE$:	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE ERROR$	CALL	BKWRITE		; crit le fichier gnral	JUMP,NE ERROR$	CLR.B	(A6)+OMAJ	JUMP	LOOP$EDIT$:	LOAD.W	D4,(A5)+OSLCYS	JUMP',NS EDIT5$	LOAD.L	A3,#(A6)+OBKTAB	LOAD.W	D3,D4	MUL.WU	D3,#LBK	ADD.L	A3,D3	LOAD.L	A4,(A3)+OBKPTX	CALL	DBOXETEXTE	; dite le texte ...	PUSH.W	D7	CALL	DBOXRSK	POP.W	D7	JUMP,NE ERROR$	LOAD.L	(A3)+OBKPTX,A4	TEST.W	D3	JUMP,EQ LOOP$	SET.B	(A6)+OMAJ	JUMP	AFF$EDIT5$:	COMP.W	(A6)+OBKNBU,#MAXIMA	JUMP,HS BIP$	LOAD.L	A4,#0	CALL	DBOXETEXTE	; dite le texte ...	PUSH.W	D7	CALL	DBOXRSK	POP.W	D7	JUMP,NE ERROR$	LOAD.L	A3,#(A6)+OBKTAB	LOAD.W	D3,(A6)+OBKNBU	LOAD.W	(A5)+OSLCYS,D3	MUL.WU	D3,#LBK	ADD.L	A3,D3	CLR.L	(A3)+OBKPIC	CLR.L	(A3)+OBKPII	LOAD.L	(A3)+OBKPTX,A4	LOAD.L	(A3)+OBKFAN,#2^BFALETTRE!2^BFAPENDU!2^BFAPERMU!2^BFAGRILLE	CLR.L	(A3)+OBKNSI	CLR.L	(A3)+OBKDSI	INC.W	(A6)+OBKNBU	SET.B	(A6)+OMAJ	JUMP	UPDATE2$PTEXT$:	CALL	DBOXPTEXTE	; demande un nom de texte ...	PUSH.W	D7	CALL	DBOXRSK	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D4,(A5)+OSLCYS	JUMP',NS PTEXT5$	LOAD.L	A4,#(A6)+OBKTAB	MUL.WU	D4,#LBK	ADD.L	A4,D4	CALL	BKREADTEXT	; prend un texte	JUMP,NE PTEXT$	SET.B	(A6)+OMAJ	JUMP	AFF$PTEXT5$:	LOAD.L	A4,#(A6)+OBKTAB	LOAD.W	D4,(A6)+OBKNBU	LOAD.W	(A5)+OSLCYS,D4	MUL.WU	D4,#LBK	ADD.L	A4,D4	CLR.L	(A4)+OBKPIC	CLR.L	(A4)+OBKPII	LOAD.L	(A4)+OBKFAN,#2^BFALETTRE!2^BFAPENDU!2^BFAPERMU!2^BFAGRILLE	CLR.L	(A4)+OBKNSI	CLR.L	(A4)+OBKDSI	CALL	BKREADTEXT	; prend un texte	JUMP,NE PTEXT$	INC.W	(A6)+OBKNBU	SET.B	(A6)+OMAJ	JUMP	UPDATE2$PIMAGE$:	TEST.W	(A5)+OSLCYS	JUMP,NC BIP$	CALL	DBOXPIMAGE	; demande un nom d'image ...	PUSH.W	D7	CALL	DBOXRSK	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	WAITMOUSE	CALL	BKNEWIMAGE	; charge une nouvelle image	JUMP,NE ERROR$	LOAD.W	D3,(A6)+OBKNBU	DEC.W	D3	LOAD.W	(A5)+OSLCYS,D3	; montre l'image prise	SET.B	(A6)+OMAJ	JUMP	UPDATE2$INFO$:	LOAD.W	D3,(A5)+OSLCYS	JUMP,NS BIP$	CALL	DBOXINFO	; modifie les informations	PUSH.W	D7	CALL	DBOXRSK	POP.W	D7	COMP.W	D3,#END	JUMP,EQ LOOP$	SET.B	(A6)+OMAJ	JUMP	LOOP$SUPP$:	LOAD.W	D3,(A5)+OSLCYS	JUMP,NS BIP$	CALL	BKDELETE	; supprime l'image slectionne	LOAD.W	D3,(A6)+OBKNBU	COMP.W	D3,(A5)+OSLCYS	JUMP,HI UPDATE2$	DEC.W	D3	LOAD.W	(A5)+OSLCYS,D3	SET.B	(A6)+OMAJ	JUMP	UPDATE2$CLOSE$:	CALL	BKSINIT		; init la recherche de sous-images avec mot	DBOX_	CLOSE		; ferme la DBOXEXIT$:	CALL	CCMO		; invisible	CALL	AFMENU		; refait les soft-keys	POPM.L	D0..D6,A2..A5	TEST.W	D7		; retour EQ/NE	RETTXVIDE$:.ASCIZ	"  <'<>cre<'>>"	.EVEN;---------\\; DBDASHOW >;---------/; Affiche le fichier de la case slectionne.; in	A5.L	^scroll-liste; out	-; mod	D7.WDBDASHOW:	PUSHM.L	D0..D6,A2..A4	LOAD.L	A2,#(A6)+OBKTAB	LOAD.W	D2,(A5)+OSLCYS	MUL.WU	D2,#LBK	ADD.L	A2,D2		; A2 <-- ^image dans OBKTAB	LOAD.W	D2,#1!2^BDBGCLABEL!2^BDBGCFULL	TEST.W	(A5)+OSLCYS	JUMP',NS LAB1$	TEST.L	(A2)+OBKPIC	JUMP',EQ LAB1$	TEST.L	(A2)+OBKNSI	JUMP',NE LAB1$	LOAD.W	D2,#1!2^BDBGCLABEL!2^BDBGCGREYLAB1$:	DBOX_	GETCO		; (d)grise la case (EDITE TEXTE)	LOAD.W	D2,#2!2^BDBGCLABEL!2^BDBGCFULL	TEST.W	(A5)+OSLCYS	JUMP',NS LAB2$	TEST.L	(A2)+OBKPIC	JUMP',EQ LAB2$	TEST.L	(A2)+OBKNSI	JUMP',NE LAB2$	LOAD.W	D2,#2!2^BDBGCLABEL!2^BDBGCGREYLAB2$:	DBOX_	GETCO		; (d)grise la case (PREND TEXTE)	LOAD.W	D2,#3!2^BDBGCLABEL!2^BDBGCFULL	TEST.W	(A5)+OSLCYS	JUMP',NS LAB3$	TEST.L	(A2)+OBKPIC	JUMP',EQ LAB3$	LOAD.W	D2,#3!2^BDBGCLABEL!2^BDBGCGREYLAB3$:	DBOX_	GETCO		; (d)grise la case (PREND IMAGE)	LOAD.W	D2,#4!2^BDBGCLABEL!2^BDBGCGREY	TEST.W	(A5)+OSLCYS	JUMP',NS LAB4$	LOAD.W	D2,#4!2^BDBGCLABEL!2^BDBGCFULLLAB4$:	DBOX_	GETCO		; (d)grise la case (INFORMATIONS)	LOAD.W	D2,#5!2^BDBGCLABEL!2^BDBGCGREY	TEST.W	(A5)+OSLCYS	JUMP',NS LAB5$	LOAD.W	D2,#5!2^BDBGCLABEL!2^BDBGCFULLLAB5$:	DBOX_	GETCO		; (d)grise la case (SUPPRIME)	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	CALL	DBDALENGTH	; D4 <-- taille	ADD.L	D4,#1000-1	DIV.WU	D4,#1000	AND.L	D4,#H'FFFF	LOAD.W	D3,#4	CLR.W	D2	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" k"	.EVEN	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#DAPIM-DAPSL+2	ADD.W	D3,D2	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#DALIM-2-1	LOAD.W	D4,D2	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'ancienne surface	PUSHM.L	D3,D4	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine rectangle autour	POPM.L	D3,D4	TEST.W	(A5)+OSLCYS	; est-on dans <cre> ?	JUMP,NS EXIT$		; oui => EXIT$	TEST.L	(A2)+OBKPIC	; image existe ?	JUMP',EQ TEXT$		; non => TEXT$	LOAD.L	A4,(A2)+OBKPIC	; A4 <-- ^image code	CALL	IMAGEDECO	; A3 <-- ^image dcode	JUMP,NE EXIT$	LOAD.L	D2,D3	CLR.L	D3	CALL	IMAGEAFF	; affiche l'image	CALL	IMAGECODE	; libre l'image dcode	JUMP	EXIT$TEXT$:	TEST.L	(A2)+OBKPTX	; texte existe ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.L	A4,(A2)+OBKPTX	; A4 <-- ^texte	ADD.W	D3,(A0)+ODFC1X	SWAP.W	D3	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LOAD.L	D2,D3		; D2 <-- position	CLR.L	D1	LOAD.W	D1,D4	DIV.WU	D1,(A0)+ODFCX	; D1 <-- nb caractres/ligne	DEC.W	D1	LOAD.L	D0,D4	CLR.W	D0	SWAP.W	D0	LOAD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	DIV.WU	D0,D3		; D0 <-- nb lignesTLOOPY$:	LOAD.L	D3,D2	LIB	?SETCURS	LOAD.L	A3,A4	LOAD.W	D3,#-1TCNT$:	INC.W	D3	LOAD.B	D4,(A4)	JUMP',EQ TLINE$	INC.L	A4	COMP.B	D4,#CR	JUMP',NE TCNT$TLINE$:	TEST.W	D3	JUMP',EQ TNEXTY$	COMP.W	D3,D1	JUMP',LS TAFF$	LOAD.W	D3,D1TAFF$:	LIB	?AFSPACE	LIB	?STRING		; affiche une ligneTNEXTY$:	SWAP.W	D2	ADD.W	D2,(A0)+ODFC1Y	ADD.W	D2,(A0)+ODFC2Y	SWAP.W	D2	DEC.W	D0	JUMP,NE TLOOPY$EXIT$:	POPM.L	D0..D6,A2..A4	RET;-----------\\; DBDALENGTH >;-----------/; Regarde la taille ncessaire pour toutes les donnes.; in	-; out	D4.L	taille ncessaire; mod	D4.L, D7.WDBDALENGTH:	PUSHM.L	D5,A4,A5	LOAD.L	D4,#256	LOAD.L	A5,#(A6)+OBKTAB	LOAD.W	D5,(A6)+OBKNBU	JUMP',EQ EXIT$LOOP$:	TEST.L	(A5)+OBKPIC	JUMP',EQ NOIMA$	LOAD.L	A4,(A5)+OBKPIC	ADD.L	D4,(A4)+OIMNBBNOIMA$:	TEST.L	(A5)+OBKPTX	JUMP',EQ NOTXT$	LOAD.L	A4,(A5)+OBKPTXTCNT$:	INC.L	D4	TEST.B	(A4+)	JUMP,NE TCNT$NOTXT$:	ADD.L	D4,#12	LOAD.L	A5,#(A5)+LBK	DEC.W	D5	JUMP,NE LOOP$EXIT$:	POPM.L	D5,A4,A5	RET;----------\\; DBDAGETTX >;----------/; Donne le texte contenu dans une case de la scroll-liste.; in	D3.W	rang (0..n); out	D3.W	zro;	A3.L	^texte;	D7.W	erreur; mod	D3.L, D7.W, A3.LDBDAGETTX:	PUSHM.L	D4,A4	CLR.L	D4	LOAD.W	D4,D3	LOAD.L	A4,#(A6)+OBKTAB	MUL.WU	D3,#LBK	ADD.L	A4,D3		; A4 <-- ^image dans OBKTAB	LOAD.L	A3,#R16"NMOT$	TEST.L	(A4)+OBKPIC	JUMP',EQ TEXT$	LOAD.L	A3,#R16"NPUZ$	TEST.L	(A4)+OBKNSI	JUMP',EQ TEXT$	LOAD.L	A3,#R16"NMEM$TEXT$:	LOAD.L	A4,#(A6)+OBUDIS	INC.L	D4		; D4 <-- 1..n	LOAD.W	D3,#2	CLR.W	D2	LIB	?PUTDECPUT$:	LOAD.B	(A4+),(A3+)	JUMP,NE PUT$	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^texte	CLR.W	D3	POPM.L	D4,A4	CLR.W	D7		; retour EQ	RETNPUZ$:	.ASCIZ	": puzzle"NMEM$:	.ASCIZ	": cartes"NMOT$:	.ASCIZ	": mots"	.EVENTDBOX_DATA:	.W	10$-TDBOX_DATA	.W	20$-TDBOX_DATA	.W	0,010$:	.B	ODBBOX,KEYDBOX/H'100,4,TDBNORM	.ASCIZ	" PREND "	.B	ODBTABX,DAPSL	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBTABX,DAPIM+DALIM	.B	ODBLABEL,3	.B	ODBBOX,KEYDBOX/H'100,9,TDBOMBRE	.ASCIZ	" PREND IMAGE  "	.B	ODBCR,ODBCR	.B	ODBBOX,KEYDBOX/H'100,5,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBCR2	.B	ODBTABX,DAPIM+DALIM	.B	ODBLABEL,2	.B	ODBBOX,KEYDBOX/H'100,8,TDBOMBRE	.ASCIZ	" PREND TEXTE  "	.B	ODBCR,ODBCR	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBTABX,DAPIM+DALIM	.B	ODBLABEL,1	.B	ODBBOX,KEYDBOX/H'100,7,TDBOMBRE	.ASCIZ	" EDITE TEXTE  "	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,DAPIM+DALIM	.B	ODBLABEL,4	.B	ODBBOX,KEYDBOX/H'100,10,TDBOMBRE	.ASCIZ	" INFORMATIONS "	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	"TERMINE"	.B	ODBTABX,DAPIM+DALIM	.B	ODBLABEL,5	.B	ODBBOX,0,F11,TDBOMBRE	.ASCIZ	"   SUPPRIME   "	.B	ODBTABX,DAPIM	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Termine"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_DATA:	.W	F1,F2,F3,CR,0		DOKCR-TKEY_DATA	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DATA	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_DATA	.W	0;----------\\; DBOXPTOTO >;==========/; Demande un nom gnral  prendre.; in	-; out	A3.L	^nom;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.W, A3.LDBOXPTOTO:	PUSHM.L	D1,D2,D4,A2,A4,A5	LOAD.L	A5,#(A6)+OBUNAM	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_PREND	DBOX_	EXTEND	JUMP',NE EXIT$	LOAD.L	A3,A5		; A3 <-- ^nomEXIT$:	POPM.L	D1,D2,D4,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXSTOTO >;==========/; Demande un nom gnral  sauver.; in	-; out	A3.L	^nom;	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.W, A3.LDBOXSTOTO:	PUSHM.L	D1,D2,D4,A2,A4,A5	LOAD.L	A5,#(A6)+OBUNAM	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1	TEST.B	(A6)+OMAJ	JUMP',NE SAUVE$	TSET.L	D3:#BDBIONMAJ	; D3 <-- (MET A JOUR) grisSAUVE$:	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_SAUVE	DBOX_	EXTEND	JUMP',NE EXIT$	LOAD.L	A3,A5		; A3 <-- ^nomEXIT$:	POPM.L	D1,D2,D4,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXDTOTO >;==========/; Demande s'il faut dtruire.; in	-; out	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDTOTO:	PUSHM.L	D1,D2,D4,A2..A5	LOAD.L	A5,#(A6)+OBUNAM	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A3,#R16"TDBOX_IO	CLR.L	D3	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_DETRUIT	DBOX_	EXTENDEXIT$:	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXMTOTO >;==========/; Demande un nom gnral  mettre  jour.; in	D3.L	zro/2^BDBIOQUIT; out	A3.L	^nom;	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.W, A3.LDBOXMTOTO:	PUSHM.L	D1,D2,D4,A2,A4,A5	LOAD.L	A5,#(A6)+OBUNAM	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_MAJ	DBOX_	EXTEND	JUMP',NE EXIT$	LOAD.L	A3,A5		; A3 <-- ^nomEXIT$:	POPM.L	D1,D2,D4,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXPIMAGE >;===========/; Demande un nom d'image  prendre.; in	-; out	A3.L	^nom;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.W, A3.LDBOXPIMAGE:	PUSHM.L	D1,D2,D4,A2,A4,A5	LOAD.L	A5,#(A6)+OBUNIM	LOAD.L	A4,#R16"TEXT_IOIM	LOAD.L	A3,#R16"TDBOX_IOIM	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_PREND	DBOX_	EXTEND	JUMP',NE EXIT$	LOAD.L	A3,A5		; A3 <-- ^nomEXIT$:	POPM.L	D1,D2,D4,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXPTEXTE >;===========/; Demande un nom de texte  prendre.; in	-; out	A3.L	^nom;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.W, A3.LDBOXPTEXTE:	PUSHM.L	D1,D2,D4,A2,A4,A5	LOAD.L	A5,#(A6)+OBUNTX	LOAD.L	A4,#R16"TEXT_IOTX	LOAD.L	A3,#R16"TDBOX_IOTX	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1!2^BDBIOFULL	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_PREND	DBOX_	EXTEND	JUMP',NE EXIT$	LOAD.L	A3,A5		; A3 <-- ^nomEXIT$:	POPM.L	D1,D2,D4,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXETEXTE >;===========/; Edite un texte avec le module EPRO.; in	D4.W	case slectionne (-1,0..n);	A4.L	^texte/nil; out	A4.L	^texte/nil;	D3.W	1 => nise  jour ncessaire;	D7.W	erreur; mod	D3.L, D7.W, A4.LDBOXETEXTE:	PUSHM.L	D1,D2,D4..D6,A1..A3,A5	CALL	DBETOPTEXT	; A3/D3 <-- ^texte/lg	JUMP,NE EXIT9$	CALL	DBETOPWDO	; ouvre les swdo	JUMP,NE EXIT8$	LOAD.L	A4,A3OPEN$:	LOAD.W	D4,#2^BEPROMOUSE!2^BEPROAFCR!2^BEPROAFLF!2^BEPROAFTAB!2^BEPROQUITTE!2^BEPROTXT	PUSH.L	A0	LOAD.L	A0,#R16"TEXT0$	LOAD.L	A1,#R16"TEXT1$	LOAD.L	A2,#R16"TEXT2$	EPRO_	OPEN		; D6 <-- canal de l'dition	POPM.L	A0	JUMP,NE EXIT7$	LOAD.L	A3,#R16"TXMENU$	LIB	?AFMENUSHOW$:	CALL	DBETSHOW	; affiche l'image correspondanteLOOP$:	LOAD.L	A4,#R16"TERM$	; A4 <-- ^touches terminatrices	EPRO_	MAIN		; dite ...	JUMP',NE BIP$	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP',EQ END$	COMP.W	D3,#F1+SHIFT	JUMP',EQ END$	COMP.W	D3,#F2	JUMP',EQ END$	COMP.W	D3,#F2+SHIFT	JUMP',EQ END$	COMP.W	D3,#F3	JUMP',EQ END$	COMP.W	D3,#F3+SHIFT	JUMP',EQ END$	JUMP	SHOW$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	SHOW$END$:	CLR.W	D4	LOAD.W	D1,#EPRO_GETPDBUFF	EPRO_	EXTEND		; A5 <-- ^descripteur du texte	TEST.B	(A5)+OEPROSTATUS:#BEPROFILMOD	JUMP',BC MAJ$	INC.W	D4		; D4 <-- mise  jour ncessaireMAJ$:	EPRO_	CLOSE		; A3 <-- ^texte	CALL	BKSYNTEXT	; syntaxe correcte ?	JUMP',EQ EXIT7$	CALL	DBOXERROR	; affiche l'erreur ...	LOAD.W	D5,(A6)+OETWD2	LIB	?USEWDO	JUMP	OPEN$EXIT7$:	LOAD.W	D3,D4		; D3 <-- indication pour mise  jour	PUSH.W	D7	CALL	DBETCLWDO	; ferme les swdo	POP.W	D7EXIT8$:	PUSH.W	D7	CALL	DBETCLTEXT	; A4 <-- ^texte/nil	POP.W	D7EXIT9$:	POPM.L	D1,D2,D4..D6,A1..A3,A5	TEST.W	D7		; retour EQ/NE	RETTEXT0$:	.ASCIZ	""TEXT1$:	.ASCIZ	" TOTO   "TEXT2$:	.ASCIZ	""	.EVENTERM$:;	.BB	0,END	.W	0TXMENU$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN;-----------\\; DBETOPTEXT >;-----------/; Ouvre le buffer de texte.; in	D4.W	case slectionne (-1,0..n);	A4.L	^texte/nil; out	A3.L	^texte<0>;	D3.L	lg buffer;	D7.W	erreur; mod	D3.L, D7.W, A3.LDBETOPTEXT:	PUSHM.L	D1,D4,A1,A2,A4	LOAD.L	A2,A4		; A2 <-- ^texte/nil	CLR.L	(A6)+OLTPIC	CLR.L	(A6)+OLTPID	TEST.W	D4	JUMP',NS IMAGE$	LOAD.L	A1,#(A6)+OBKTAB	MUL.WU	D4,#LBK	ADD.L	A1,D4	TEST.L	(A1)+OBKPIC	JUMP',EQ IMAGE$	TEST.L	(A1)+OBKNSI	JUMP',EQ IMAGE$	LOAD.L	A4,(A1)+OBKPIC	CALL	IMAGEDECO	; A3 <-- ^image dcode	JUMP,NE EXIT$	LOAD.L	(A6)+OLTPIC,A4	LOAD.L	(A6)+OLTPID,A3	LOAD.L	(A6)+OLTNSI,(A1)+OBKNSI	LOAD.L	(A6)+OLTDSI,(A1)+OBKDSI	LOAD.L	D4,(A1)+OBKFAN	LOAD.W	D3,#3	TEST.L	D4:#BFAG3	JUMP',BS NBG$	DEC.W	D3	TEST.L	D4:#BFAG2	JUMP',BS NBG$	DEC.W	D3NBG$:	LOAD.W	(A6)+OLTNBG,D3	; OLTNBG <-- nb de cartes par groupeIMAGE$:	LOAD.L	A3,A2	CLR.L	D4	COMP.L	A4,#0	JUMP',EQ NIL$CNT$:	INC.L	D4		; D4 <-- longueur du texte	TEST.B	(A3+)	JUMP,NE CNT$NIL$:	ADD.L	D4,#1000	; D4 <-- 1000 caractres pour diter	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouveau buffer	JUMP,NE EXIT$	CLR.B	(A4)	LOAD.L	A3,A4	COMP.L	A2,#0	JUMP',EQ END$	LOAD.L	A1,A2XFER$:	LOAD.B	(A4+),(A1+)	JUMP,NE XFER$	LOAD.L	A4,A2;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancien bufferEND$:	LOAD.L	D3,D4		; D3 <-- lg buffer	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D4,A1,A2,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBETOPWDO >;----------/; Ouvre les sous-fentres.; in	-; out	D7.W	erreur; mod	D7.WDBETOPWDO:	PUSHM.L	D2..D5	LOAD.W	D4,(A0)+ODFFDY	ADD.W	D4,#8*2		; D4 <-- hauteur	SWAP.W	D4	LOAD.W	D4,(A0)+ODFFDX	ADD.W	D4,#8*2		; D4 <-- largeur	LOAD.W	D2,#2^BDBSAV	; D2 <-- sauve le fond	DBOX_	CADRE		; D5 <-- canal du cadre	JUMP',NE EXIT$	LOAD.L	(A6)+OETCDB,D5	LIB	?GETWDO	LOAD.W	(A6)+OETWD1,D5	PUSHM.L	D3,D4	CLR.L	D3	SR.W	D4,#1	LOAD.W	D3,D4	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; trait vertical de sparation	POPM.L	D3,D4	SR.W	D4,#1	LIB	?CREWDO	LIB	?USEWDO	LOAD.W	(A6)+OETWD2,D5	LOAD.W	(A6)+OLTRSI,#-1	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBETSHOW >;---------/; Affiche l'image correspondant  la ligne.; in	D6.L	canal EPRO; out	-; mod	D7.WDBETSHOW:	PUSHM.L	D1..D5,A4,A5	TEST.L	(A6)+OLTPIC	JUMP,EQ EXIT$	LOAD.W	D1,#EPRO_GETPDBUFF	EPRO_	EXTEND		; A5 <-- ^descripteur du texte	LOAD.L	A4,(A5)+OEPROPDB	LOAD.L	D2,(A5)+OEPROPDT	SUB.L	D2,A4	LOAD.B	D3,#CR	LOAD.W	D4,#2SRC2$:	DEC.W	D2	JUMP',NS SRC4$	COMP.B	D3,(A4+)	JUMP,NE SRC2$	INC.W	D4		; D4 <-- ligne o est le curseur	JUMP	SRC2$SRC4$:	COMP.W	D4,(A6)+OLTRSI	JUMP,EQ EXIT$	LOAD.W	(A6)+OLTRSI,D4	LOAD.W	D5,(A6)+OETWD1	LIB	?USEWDO	LOAD.W	D2,(A0)+ODFFDY	SR.W	D2,#1	LOAD.W	D3,(A6)+OLTDSI+0	SR.W	D3,#1	SUB.W	D2,D3	SWAP.W	D2	LOAD.W	D3,(A0)+ODFFDX	SR.W	D3,#2	MUL.WU	D3,#3	LOAD.W	D2,D3	LOAD.W	D3,(A6)+OLTDSI+2	SR.W	D3,#1	SUB.W	D2,D3	CALL	LTRANG		; D4 <-- rang de l'image	JUMP',NE CLEAR$	DIV.WU	D4,(A6)+OLTNSI+2	LOAD.W	D3,D4	MUL.WU	D3,(A6)+OLTDSI+0 ; D3 <-- position dans l'image en Y	INC.W	D3	SWAP.W	D3	SWAP.W	D4	MUL.WU	D4,(A6)+OLTDSI+2	LOAD.W	D3,D4		; D3 <-- position dans l'image en X	INC.W	D3	LOAD.L	D4,(A6)+OLTDSI	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	A4,(A6)+OLTPIC	; A4 <-- ^image code	LOAD.L	A3,(A6)+OLTPID	; A3 <-- ^image dcode	CALL	IMAGEAFF	; affiche une carte du mmory	JUMP'	CLOSE$CLEAR$:	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	CLR.L	D3	LOAD.W	D3,(A0)+ODFFDX	SR.W	D3,#1	INC.W	D3	LOAD.L	D4,(A0)+ODFFDY	SR.W	D4,#1	DEC.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface toutCLOSE$:	LOAD.W	D5,(A6)+OETWD2	LIB	?USEWDOEXIT$:	POPM.L	D1..D5,A4,A5	RET;-----------\\; DBETCLTEXT >;-----------/; Ferme le buffer de texte.; in	A3.L	^texte<0>; out	A4.L	^texte/nil;	D7.W	erreur; mod	D7.W, A4.LDBETCLTEXT:	PUSHM.L	D1,D4,A2,A3	LOAD.L	A4,A3	CLR.L	D4CNT$:	INC.L	D4		; D4 <-- longueur du texte	TEST.B	(A4+)	JUMP,NE CNT$	LOAD.L	A4,A3	LOAD.L	A3,#0	COMP.L	D4,#1	JUMP',EQ GIVE$	LOAD.L	A3,A4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouveau buffer	JUMP',NE EXIT$	LOAD.L	A2,A4	LOAD.L	A1,A3XFER$:	LOAD.B	(A2+),(A1+)	JUMP,NE XFER$	EX.L	A4,A3GIVE$:	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancien buffer	LOAD.L	A4,A3		; A4 <-- ^texte/nil	PUSH.L	A4	TEST.L	(A6)+OLTPIC	JUMP',EQ IMAGE$	LOAD.L	A4,(A6)+OLTPIC	LOAD.L	A3,(A6)+OLTPID	CALL	IMAGECODE	; libre l'image dcodeIMAGE$:	POP.L	A4EXIT$:	POPM.L	D1,D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBETCLWDO >;----------/; Ferme les sous-fentres.; in	-; out	-; mod	D7.WDBETCLWDO:	PUSHM.L	D3..D5	LOAD.W	D5,(A6)+OETWD1	LIB	?USEWDO	LOAD.W	D5,(A6)+OETWD2	LIB	?KILWDO	LOAD.L	D5,(A6)+OETCDB	DBOX_	CLOSE	POPM.L	D3..D5	RET;---------\\; DBOXINFO >;=========/; Modifie les informations.; in	D3.W	case slectionne (0..n); out	D3.W	dernire touche (CR/END);	D7.W	erreur; mod	D3.L, D7.WDBOXINFO:	PUSHM.L	D1,D2,D4,D5,A1..A5	LOAD.L	A5,#(A6)+OBKTAB	MUL.WU	D3,#LBK	ADD.L	A5,D3		; A5 <-- ^dans OBKTAB	LOAD.L	D4,(A5)+OBKFAN	; D4 <-- fanions	LOAD.L	A2,#R16"TDBOX_INFOM	TEST.L	(A5)+OBKPIC	JUMP',EQ OPEN$	LOAD.L	A2,#R16"TDBOX_INFOP	TEST.L	(A5)+OBKNSI	JUMP',EQ OPEN$	LOAD.L	A2,#R16"TDBOX_INFOCOPEN$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_INFO	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#CR	JUMP',EQ DACCORD$	COMP.W	D3,#END	JUMP',EQ CLOSE$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$DACCORD$:	LOAD.L	(A5)+OBKFAN,D4CLOSE$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_INFOP:	.W	10$-TDBOX_INFOP	.W	20$-TDBOX_INFOP	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Nombre maximal de pices :"	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,BFAP41	.ASCIZ	" 1 x 4"	.B	ODBTABX,11	.B	ODBLCIRCLE,BFAP33	.ASCIZ	" 3 x 3"	.B	ODBTABX,11+11	.B	ODBLCIRCLE,BFAP55	.ASCIZ	" 5 x 5"	.B	ODBCR	.B	ODBLCIRCLE,BFAP22	.ASCIZ	" 2 x 2"	.B	ODBTABX,11	.B	ODBLCIRCLE,BFAP43	.ASCIZ	" 4 x 3"	.B	ODBTABX,11+11	.B	ODBLCIRCLE,BFAP66	.ASCIZ	" 6 x 6"	.B	ODBCR	.B	ODBLCIRCLE,BFAP32	.ASCIZ	" 3 x 2"	.B	ODBTABX,11	.B	ODBLCIRCLE,BFAP44	.ASCIZ	" 4 x 4"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTDBOX_INFOC:	.W	10$-TDBOX_INFOC	.W	20$-TDBOX_INFOC	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Nombre de cartes par groupe :"	.B	ODBCR,ODBCR2	.B	ODBCIRCLE,BFAG1	.ASCIZ	" 1"	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBCIRCLE,BFAG2	.ASCIZ	" 2"	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBCIRCLE,BFAG3	.ASCIZ	" 3"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Utilise ces cartes dans les activits suivantes :"	.B	ODBCR,ODBCR2	.B	ODBSQUARE,BFAMEMORY	.ASCIZ	" memory"	.B	ODBTABX,22	.B	ODBSQUARE,BFAPERMU	.ASCIZ	" mot brouill"	.B	ODBCR	.B	ODBSQUARE,BFALETTRE	.ASCIZ	" lettre manquante"	.B	ODBTABX,22	.B	ODBSQUARE,BFAGRILLE	.ASCIZ	" mot cach"	.B	ODBCR	.B	ODBSQUARE,BFAPENDU	.ASCIZ	" pendu"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTDBOX_INFOM:	.W	10$-TDBOX_INFOM	.W	20$-TDBOX_INFOM	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Utilise ces mots dans les activits suivantes :"	.B	ODBCR,ODBCR2	.B	ODBSQUARE,BFALETTRE	.ASCIZ	" lettre manquante"	.B	ODBTABX,22	.B	ODBSQUARE,BFAPERMU	.ASCIZ	" mot brouill"	.B	ODBCR	.B	ODBSQUARE,BFAPENDU	.ASCIZ	" pendu"	.B	ODBTABX,22	.B	ODBSQUARE,BFAGRILLE	.ASCIZ	" mot cach"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_INFO:	.W	F1,F2,F3,CR,0		DOKCR-TKEY_INFO	.W	F13,F14,F15,END,0	DOKEND-TKEY_INFO	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_INFO	.W	0;-----------\\; DBOXQUITTE >;===========/; Quitte TOTO ?; in	-; out	D3.W	F1/F4; mod	D7.WDBOXQUITTE:	PUSHM.L	D0..D2,D4..D6,A3..A5	CALL	SCMO		; visible	LOAD.W	D1,#DBOX_QUITTE	LOAD.L	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	DBOX_	EXTEND		; demande s'il faut quitter ...	CALL	CCMO		; invisible	CALL	AFMENU		; refait les soft-keys	POPM.L	D0..D2,D4..D6,A3..A5	RET;----------\\; DBOXCHOIX >;==========/; Dbox pour choisir le mode.; in	-; out	D3.W	dernire touche (CR/END);	D2.W	nb de couleurs modofies;	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXCHOIX:	PUSHM.L	D0,D1,D4,D5,A1..A4	CALL	SCMO		; visible	LOAD.W	D4,(A6)+OACTIV	SWAP.W	D4	CLR.W	D4	LOAD.B	D4,(A6)+OFLAGS	TCLR.L	D4:#BFINV	TEST.B	(A6)+OINV	JUMP',F 10$	TSET.L	D4:#BFINV10$:	LOAD.L	A2,#R16"TDBOX_CHOIX	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#35-1	LOAD.W	D4,(A0)+ODFFDY	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	CLR.L	D4	LOAD.W	D4,D3	LOAD.W	D3,(A0)+ODFCY	SR.W	D3,#1	MUL.WU	D3,#7	SWAP.W	D3	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	SR.W	D3,#1	MUL.WU	D3,#7+7	SWAP.W	D3	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	SR.W	D3,#1	MUL.WU	D3,#7+7+7	ADD.W	D3,#8	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE EXCOUL$	; oui => EXCOUL$	LOAD.W	D2,#F7!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCOEXCOUL$:	POP.L	D4	CLR.W	D2		; D2 <-- aucune couleur modifieLOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_CHOIX	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP,EQ DACCORD$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ CLOSE$	COMP.W	D3,#F7	JUMP,EQ COUL$	COMP.W	D3,#KEYDBOX!BFMAJUS	JUMP',EQ 50$	COMP.W	D3,#KEYDBOX!BFMINUS	JUMP',EQ 50$	COMP.W	D3,#KEYDBOX!BFTCOURT	JUMP',EQ 51$	COMP.W	D3,#KEYDBOX!BFTNORMAL	JUMP',EQ 51$	COMP.W	D3,#KEYDBOX!BFTINFINI	JUMP',EQ 51$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$50$:	TCLR.L	D4:#BFMAJUS	TCLR.L	D4:#BFMINUS	TSET.L	D4:D3	JUMP	LOOP$51$:	TCLR.L	D4:#BFTCOURT	TCLR.L	D4:#BFTNORMAL	TCLR.L	D4:#BFTINFINI	TSET.L	D4:D3	JUMP	LOOP$COUL$:	PUSHM.L	D4,D5,A3,A5	LOAD.L	A3,#R16"NMTOTO$	CALL	_GETTCOUL	; A5 <-- ^TCOUL	LOAD.L	D5,(A6)+OIDCRET	LOAD.L	D4,#2^BICMPAL	; D4 <-- mode local	ICOL_	MODCRET		; modifie la CRET ...;	LOAD.L	A2,#R16"TDBOX_CHOIX	CALL	DBOXRSK		; refait les soft-keys	TEST.W	D7	JUMP',NE COUL8$	LOAD.L	(A6)+OIDCRET,D5	INC.W	D2		; D2 <-- une couleur modifieCOUL8$:	POPM.L	D4,D5,A3,A5	JUMP	LOOP$DACCORD$:	SWAP.W	D4	LOAD.W	(A6)+OACTIV,D4	SWAP.W	D4	LOAD.B	(A6)+OFLAGS,D4	CLR.B	(A6)+OINV	TEST.L	D4:#BFINV	JUMP',BC CLOSE$	SET.B	(A6)+OINVCLOSE$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	CALL	CCMO		; invisible	CALL	AFMENU		; refait les soft-keys	POPM.L	D0,D1,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETNMTOTO$:.ASCIZ	"TOTO_S"	.EVENTDBOX_CHOIX:	.W	10$-TDBOX_CHOIX	.W	20$-TDBOX_CHOIX	.W	0,010$:	.B	ODBLCIRCLE,BFMINUS!2^7!2^6,KEYDBOX/H'100,BFMINUS	.ASCIZ	" lettres minuscules"	.B	ODBTABX,35	.B	ODBTEXT	.ASCIZ	"Activits autorises :"	.B	ODBCR	.B	ODBLCIRCLE,BFMAJUS!2^7!2^6,KEYDBOX/H'100,BFMAJUS	.ASCIZ	" lettres MAJUSCULES"	.B	ODBCR2	.B	ODBTABX,35	.B	ODBSQUARE,16+0	.ASCIZ	" calcul"	.B	ODBCR	.B	ODBTABX,35	.B	ODBSQUARE,16+1	.ASCIZ	" memory"	.B	ODBCR2	.B	ODBTEXT	.ASCIZ	"Temps  disposition :"	.B	ODBCR2	.B	ODBTABX,35	.B	ODBSQUARE,16+2	.ASCIZ	" puzzle"	.B	ODBCR	.B	ODBCIRCLE,BFTCOURT!2^7!2^6,KEYDBOX/H'100,BFTCOURT	.ASCIZ	" court"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BFTNORMAL!2^7!2^6,KEYDBOX/H'100,BFTNORMAL	.ASCIZ	" normal"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BFTINFINI!2^7!2^6,KEYDBOX/H'100,BFTINFINI	.ASCIZ	" infini"	.B	ODBTABX,35	.B	ODBSQUARE,16+3	.ASCIZ	" lettre manquante"	.B	ODBCR	.B	ODBTABX,35	.B	ODBSQUARE,16+4	.ASCIZ	" pendu"	.B	ODBCR	.B	ODBSQUARE,BFSON	.ASCIZ	" musiques et bruitages"	.B	ODBTABX,35	.B	ODBSQUARE,16+5	.ASCIZ	" mot brouill"	.B	ODBCR	.B	ODBSQUARE,BFINV	.ASCIZ	" affichage invers"	.B	ODBTABX,35	.B	ODBSQUARE,16+6	.ASCIZ	" mot cach"	.B	ODBCR	.B	ODBTABX,35	.B	ODBSQUARE,16+7	.ASCIZ	" labyrinthe"	.B	ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	ODBTABX,35	.B	ODBLABEL,F7	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" COULEURS "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Couleurs"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CHOIX:	.W	F1,F2,F3,CR,0		DOKCR-TKEY_CHOIX	.W	F7,F8,F9,0		DOKF7-TKEY_CHOIX	.W	F0,F13,F14,F15,END,0	DOKEND-TKEY_CHOIX	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CHOIX	.W	0;----------\\; DBOXERROR >;==========/; Affiche une erreur.; in	D7.W	erreur; out	D7.W	erreur; mod	D7.WDBOXERROR:	PUSHM.L	D2..D4,A3	LOAD.W	D4,D7	JUMP',EQ 20$	COMP.W	D7,#ERKNO	JUMP',EQ 20$	COMP.W	D7,#ERKSTO	JUMP',NE 30$20$:	CLR.W	D7		; D7 <-- ok	JUMP'	90$30$:	CALL	SCMO		; remet la souris	CALL	NORMMOUSE	; enlve le sablier	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	DBERTEXT	; A3 <-- ^message interne  TOTO	JUMP',EQ 50$	LOAD.W	D7,D4		; D7 <-- code de l'erreur	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur "externe" ...	JUMP'	80$50$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur "interne" ...80$:90$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBERTEXT >;---------/; Donne le texte d'une erreur interne  TOTO.; in	D4.W	erreur; out	A3.L	^message d'erreur;	D7.W	erreur; mod	D7.W, A3.LDBERTEXT:	PUSH.L	D3	LOAD.W	D7,#1		; D7 <-- pas trouv	LOAD.W	D3,D4	SR.W	D3,#8	COMP.B	D3,#ERTOTO/H'100 ; erreur interne  TOTO ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A3,#R16"TABLE$20$:	TEST.W	(A3+)		; fin de la table ?	JUMP',EQ 80$		; oui => 80$	COMP.W	D4,(A3)-2	; erreur trouve ?	JUMP',EQ 80$		; oui => 80$30$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE	30$	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- saute comme .EVEN	LOAD.L	A3,D3	JUMP	20$80$:	CLR.W	D7		; D7 <-- trouv90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	ERTIMTR	.ASCII	"Trop d'images charges<CR>"	.ASCIZ	"(maximum = 100) !"	.EVEN	.W	ERTIMEX	.ASCIZ	"Pas trouv d'image !"	.EVEN	.W	ERTIMTP	.ASCII	"L'image pour un puzzle trop petite !<CR>"	.ASCII	"Le minimum possible est<CR>"	.ASCIZ	"de 200 x 150 points."	.EVEN	.W	ERTIMTG	.ASCII	"L'image pour un puzzle trop grande !<CR>"	.ASCII	"La maximum possible est<CR>"	.ASCIZ	"de 540 x 320 points."	.EVEN	.W	ERTTXTL	.ASCII	"Le texte contient un ou<CR>"	.ASCIZ	"plusieurs mots trop longs !"	.EVEN	.W	ERTTXCA	.ASCII	"Le texte contient un ou plusieurs caractres<CR>"	.ASCII	"incorrects. Les caractres autoriss sont :<CR>"	.ASCII	"- les lettres<CR>"	.ASCII	"- l'toile (si l'image n'a pas de nom)<CR>"	.ASCIZ	"- la barre verticale (tortue|tourte)"	.EVEN	.W	ERTTXLI	.ASCII	"Le texte ne doit contenir qu'un seul mot<CR>"	.ASCII	"par ligne !<CR>"	.ASCII	/Pour l'activit "mot brouill", il est<CR>/	.ASCII	"possible de sparer les diffrentes r-<CR>"	.ASCII	"ponses possibles par une barre verticale.<CR>"	.ASCIZ	"Par exemple: loupe|poule|polue"	.EVEN	.W	0	.ASCIZ	"Erreur avec le logiciel TOTO !"	.EVEN;--------\\; DBOXRSK >;========/; Refait les soft-keys.; in	A2.L	^table DBOX; out	-; mod	D7.WDBOXRSK:	PUSHM.L	D3,A3	LOAD.W	D3,(A2)+2	LOAD.L	A3,#(A2)+(D3.W)	LIB	?AFMENU		; refait les soft-keys	POPM.L	D3,A3	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF7:	LOAD.W	D3,#F7	RETDOKCR:	LOAD.W	D3,#CR	RETDOKEND:	LOAD.W	D3,#END	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETTEXT_IO:	.ASCIZ	".TOTOS"	; extensionTEXT_IOIM:	.ASCIZ	".IMAGE"	; extensionTEXT_IOTX:	.ASCIZ	".TEXT"		; extensionTDBOX_IO:	.ASCIZ	"TOTO"		; nom du logiciel	.ASCIZ	"Fbanque"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0TDBOX_IOIM:	.ASCIZ	"TOTO"		; nom du logiciel	.ASCIZ	"Fimage"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVENTDBOX_IOTX:	.ASCIZ	"TOTO"		; nom du logiciel	.ASCIZ	"Mtexte"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN	.END