	.TITLE	TOTO_C.ASC;	--------------------------------------;		(C) 1988 - Daniel Roux;	--------------------------------------;	Source du programme TOTO_C.CODE;	Date		Amliorations; --------------------------------------------------------------------------; 1.3	07.03.91	images en couleurs (.COLOR); 1.2	23.10.90	couleur pour SMAKY-300; 1.1	; 1.0		.PROC	M680002	.REF	SMAKY	.REF	MODULES	.REF	AUDIO	.REF	TCOLOR	.REF	ICOLOR;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;GRA_CRASTER = H'A899		; raster-op couleurGRA_GDOT = H'A89A		; get-dotBSRCCOUL = 11BDSTCOUL = 12OSTPIXEL = OSTRD3+4OSTTABLCOUL = OSTPIXEL+2SMAKY300 = 7;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.REV	1,3	.CODE	800,10,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"DANIEL	=	0		; 1 => debugIFSMILE	=	0		; 1 => assemblage pour SMILE2; En-tte d'un fichier .IMAGE/.COLOR; ----------------------------------	.LOC	0	.BLKB	1		; OIMTYP: H'82	.BLKB	1		; OIMCOD: 0 ou 4	.BLKB	1		; OIMBIP: 4 bits/pixel	.BLKB	1		; OIMDIR: 2	.BLKB	2		; OIMDLX: largeur (multiple de 16)	.BLKB	2		; OIMDLY: hauteur	.BLKB	4		; OIMNBB: longueur du dataOIMSIZ:	.BLKB	2		; taille d'un pixel (4)OIMCNT:	.BLKB	2		; nb de pixels (1)OIMLGC:	.BLKB	4		; longueur de la CLUT	.BLKB	12		; rserve				; LGHIMA: longueur de l'en-tte; Dfinition de l'entte d'un gnrateur de caractres; ----------------------------------------------------NBPCAR	=	96		; nb de caractres dans ITP82OGCH1	=	256+NBPCAR*1	; 128 x h1OGCH2	=	256+NBPCAR*2	; 128 x h2OGCMAT	=	256+NBPCAR*3	; 128 x matrix; Constantes; ----------LBUANA	=	5000		; lg max d'une note analogiqueLBS	=	(ADFREQ/2)*5	; lg max d'un sons pour SMAKY300LHIST	=	100		; lg max d'une histoireLBUFILE	=	50		; lg max nom de fichierKEYDBOX	=	H'7E00		; "touche" trs spciale !; Caractres standard; -------------------LXICO	=	80LYICO	=	80GCTXF	=	'N		; fonte (N)GCTXS	=	'R!2^7		; style/chasse (RF)GCTXT	=	14		; taille (14) normaleGCTXTP	=	09		; taille (09) petite; Icnes des ITP82; ----------------GCICF	=	'I		; fonte (I)GCICS	=	'T		; style/chasse (TP)GCICT	=	82		; taille (82)BICOMASK =	7		; icne de fondBICODEMIH =	8		; icne dans la moiti suprieureBICODEMIB =	9		; icne dans la moiti infrieureBICOSYMB =	10		; icne symbole dans ITP83; Couleurs; --------COLOR_BLANC =	0COLOR_JAUNE =	1		; totoCOLOR_ROUGE =	2COLOR_MAGENTA =	3COLOR_CYAN =	4COLOR_BLEU  =	5COLOR_VERT  =	6COLOR_VERTF  =	9COLOR_GRIS  =	12		; faade maisonCOLOR_GRISF  =	13		; ombre maisonCOLOR_NOIR  =	15; Positions dans l'image; ----------------------LXWDO	=	640		; largeur de l'cranLYWDO	=	340		; hauteur de l'cranLXIMA	=	1120		; largeur d'une imageLYIMA	=	340		; hauteur d'une imagePTEXTX	=	200		; position pour textePTEXTY	=	20		; position pour texteLTEXTX	=	144		; largeur pour texteLTEXTY	=	23		; hauteur pour textePARRGX	=	300		; position  l'arrt  gauchePARRGY	=	246		; position  l'arrt  gauchePARRDX	=	PARRGX+480	; position  l'arrt  droitePARRDY	=	PARRGY		; position  l'arrt  droiteLGALOX	=	208		; largeur d'une image du galopLGALOY	=	140		; hauteur d'une image du galopLTROTX	=	200		; largeur d'une image du trotLTROTY	=	132		; hauteur d'une image du trotLIMMX	=	16		; largeur d'une fentre d'immeubleLIMMY	=	12		; hauteur d'une fentre d'immeuble; Progressions; ------------PROGHB	=	1		; de haut en basPROGCN	=	2		; carrs en zoom avantPROGCI	=	3		; carrs en zoom arrirePROGSV	=	4		; stores vnitiensPROGA	=	5		; alatoire rapidePROGAL	=	6		; alatoire lent; Modes dans les tables; ---------------------TMBEGIN	=	-1		; dbut absolu      [y,x,del]TMBEGINX=	-2		; dbut immobile    [del]TMLINK	=	-3		; suite de la table [ad]TMPLAN	=	-4		; plan o dessiner  [0=derrire, 1=devant]TMFLASH	=	-5		; clair            [t1,t2]TMDEL	=	-6		; nouveaux dlais   [dlai]TMSOUND	=	-9		; bruitage          [TMUSxxxx]TMTEXT	=	-10		; texte             [.ASCIZ "xyz" puis .EVEN]TMSKIPNE=	-11		; saut cond. si NE  [var,inf,sup,ad]TMSKIPEQ=	-12		; saut cond. si EQ  [var,inf,sup,ad]TMICOOB	=	-13		; icne             [y,x,chair,fond]TMROLL	=	-14		; dplacement       [dx]TMIMAGE	=	-15		; image spciale    [dy,dx]TMMASK	=	-16		; icne masque      [y,x,icne]TMANALOG=	-17		; son analogique    [rang]; Descripteur d'un objet anim; ----------------------------	.LOC	0OOICON:	.BLKB	2		; code de l'icneOOLPOS:	.BLKB	4		; dernire positionOONPOS:	.BLKB	4		; nouvelle positionOOMPTA:	.BLKB	4		; ^lment suivantOOMPTB:	.BLKB	4		; ^lment prcdentOOMCTN:	.BLKB	2		; compteur nb de dlacementsOOMCTI:	.BLKB	2		; compteur nb d'icneOOMNBI:	.BLKB	2		; nb max d'icnesOOMDEL:	.BLKB	2		; dlai (vitesse)LOBJ:; Descripteur d'un oiseau; -----------------------MAXOISEAUX=	20		; nb max d'oiseaux simultans	.LOC	0OOIPOS:	.BLKB	4		; position (y;x)OOILYS:	.BLKB	2		; limite suprieure en YOOILYI:	.BLKB	2		; limite infrieure en YOOILST:	.BLKB	4		; rang des oiseaux (dans #5 de ITP83)OOIPTR:	.BLKB	2		; ^relatif dans OOILST (0..3)OOIDIR:	.BLKB	4		; direction (dy;dx)LOI:; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSTRE:.BLKB	2		; canal module STRETCHOCHICOL:.BLKB	2		; canal module ICOLOROMACHINE:.BLKB	1		; type de la machine (SMAKYxxx)OINV:	.BLKB	1		; 1 => fond de l'cran blanc	.EVENOPDDIS:	.BLKB	4		; ^descripteur de la fentreOSDDIS:	.BLKB	LGDIS7		; copie du descripteur de la fentreOPGICO:	.BLKB	4		; ^gencar des icnes (ITP82)OPFICO:	.BLKB	4		; ^gencar des icnes (fonds calculs)OPSICO:	.BLKB	4		; ^gencar des icnes (ITP83)OADRASTER:	.BLKB	4	;  adresse de GRA_RASTEROADCRASTER:	.BLKB	4	;  adresse de GRA_CRASTEROADMATRIX:	.BLKB	4	;  adresse de GRA_MATRIXOADDOT:		.BLKB	4	;  adresse de GRA_DOTOADTRAME:	.BLKB	4	;  adresse de GRA_TRAMEOADLINE:	.BLKB	4	;  adresse de GRA_LINEOADELLIPSE:	.BLKB	4	;  adresse de GRA_ELLIPSEOADFILLO:	.BLKB	4	;  adresse de GRA_FILLOOADFILLC:	.BLKB	4	;  adresse de GRA_FILLCOADCLEAR:	.BLKB	4	;  adresse de GRA_CLEAROADSET:		.BLKB	4	;  adresse de GRA_SETOADINV:		.BLKB	4	;  adresse de GRA_INVOBUDIS:	.BLKB	200		; buffer write-displayOBULUT:	.BLKB	1000		; buffer lutin sourisOPS:	.BLKB	4		; ^sons analogiquesOBS:	.BLKB	4		; ^buffer sons pour SMAKY300OCHS:	.BLKB	2		; canal #AUDIO pour SMAKY300OPICE:	.BLKB	4		; ^image code tOPICA:	.BLKB	4		; ^image code automneOPICH:	.BLKB	4		; ^image code hiverOPICP:	.BLKB	4		; ^image code printempsOPICG:	.BLKB	4		; ^image code galopOPICT:	.BLKB	4		; ^image code trotOPICR:	.BLKB	4		; ^image code rveOPICD:	.BLKB	4		; ^image code dinerOPIDESS:.BLKB	4		; ^image dessin principal dcodeOPICODE:.BLKB	4		; ^image dessin principal codeOPITEMP:.BLKB	4		; ^image temporaireOPISPEC:.BLKB	4		; ^image spciale (galop, trot, etc.)ODISPEC:.BLKB	4		; dimensions de l'image spcialeODIMA:	.BLKB	4		; dimensions imageOOIMA:	.BLKB	4		; origine coin sup/gauche imageOPIMAX:	.BLKB	2		; position dans l'image en XOIIMAX:	.BLKB	2		; incrment dans l'image en XOMATPR:	.BLKB	((32*32)/8)*4	; matrice pour progressions (*4 bits/pixel)OOBJET:	.BLKB	LOBJ		; objet totoOOBJET2:.BLKB	LOBJ		; objet toto (2me)OOITAB:	.BLKB	LOI*MAXOISEAUX	; table des oiseauxOIMCAR:	.BLKB	2		; icne masque: code du caractreOIMPOS:	.BLKB	4		; icne masque: positionOIMMAT:	.BLKB	LXICO*LYICO/8	; icne masque: matriceOISDY:	.BLKB	2		; image spciale: hauteurOISDX:	.BLKB	2		; image spciale: largeurOLETTRE:.BLKB	2		; lettre choisieOLASTLE:.BLKB	2		; dernire lettre choisieOFLAGS:	.BLKB	1		; flags divers BFMAJUS  =  0			;  majuscules BFMINUS  =  1			;  minuscules BFSON    =  2			;  son BFSOURIS =  3			;  sourisOPLAY:	.BLKB	1		; 1 => lit une histoire (fichier .TOTO)OABORT:	.BLKB	1		; 1 => abort des processus filsOSTEP:	.BLKB	1		; 1 => mode "pas  pas"OCLIC:	.BLKB	1		; 1 => avec un clic de la sourisOQUICK:	.BLKB	1		; 1 =>  toute vitesseOPLAN:	.BLKB	1		; 1 => devantOSAISON:.BLKB	1		; saison (E,A,H,P)	.EVENOOMENU:	.BLKB	2		; soft-keys: anciens bits BMNNOHIS =  0			;  pas d'histoire BMNRACON =  1			;  raconteOSOUND:	.BLKB	2		; son  effectuer par le processus filsOHACHE:	.BLKB	4		; tirage exclusif: chemineOHADI1:	.BLKB	8		; tirage exclusif: disparatreOHADI2:	.BLKB	8		; tirage exclusif: disparatreOHAGAL:	.BLKB	8		; tirage exclusif: galop/trotOHAIMM:	.BLKB	8		; tirage exclusif: immeubleOHAJAR:	.BLKB	8		; tirage exclusif: jardinOHAKAN:	.BLKB	4		; tirage exclusif: kangourouOHAINT:	.BLKB	4		; tirage exclusif: aller dans la maisonOHAMAN:	.BLKB	4		; tirage exclusif: mangerOHASOM:	.BLKB	4		; tirage exclusif: sommetOHAXYL:	.BLKB	4		; tirage exclusif: xylophoneOHAWAL:	.BLKB	10		; tirage exclusif: walkmanOHASOU:	.BLKB	10		; tirage exclusif: sonoritsOHATST:	.BLKB	2		; valeur pour testOHAZA:	.BLKB	8		; registre 63 bits pour gnrateur alatoireOFADEL:	.BLKB	2		; fatigu: dlaiOPHIST:	.BLKB	2		; ^relatif dans OHISTOHIST:	.BLKB	LHIST		; histoireOBUFILE:.BLKB	LBUFILE		; nom de l'histoireOSTVAR:	.BLKB	ST_LGTRECT	; variables pour stretchOBUAN1:	.BLKB	LBUANA		; buffer pour une note analogiqueOBUAN2:	.BLKB	LBUANA		; buffer pour une note analogiqueOBUAN3:	.BLKB	LBUANA		; buffer pour une note analogiqueLGVAR:; Programme principal; -------------------	.LOC	0ADCODE:	JUMP	START; Erreurs fatales; ---------------TXERFATREV:	.ASCIZ	"Rvision du systme incompatible"TXERFATTXT:	.ASCIZ	"Erreur avec NRF09"TXERFATTXTP:	.ASCIZ	"Erreur avec NRF14"TXERFATICO1:	.ASCIZ	"Erreur avec ITP82"TXERFATICO2:	.ASCIZ	"Erreur avec ITP83"TXERFATGRA:	.ASCIZ	"Erreur avec GRA"TXERFATMEM:	.ASCIZ	"Erreur avec la mmoire"; Noms divers; -----------NMDBOX:	.ASCIZ	"DBOX"NMLIST:	.ASCIZ	"LIST"NMSTRE:	.ASCIZ	"STRETCH"NMICOL:	.ASCIZ	"ICOLOR"NMS:	.ASCIZ	"TOTO_C.SOUND"NMI0:	.ASCIZ	"TOTO_C.IMAGE"NMIE:	.ASCIZ	"TOTO_CE.IMAGE"NMIA:	.ASCIZ	"TOTO_CA.IMAGE"NMIH:	.ASCIZ	"TOTO_CH.IMAGE"NMIP:	.ASCIZ	"TOTO_CP.IMAGE"NMIG:	.ASCIZ	"TOTO_CG.IMAGE"NMIT:	.ASCIZ	"TOTO_CT.IMAGE"NMIR:	.ASCIZ	"TOTO_CR.IMAGE"NMID:	.ASCIZ	"TOTO_CD.IMAGE"NMC0:	.ASCIZ	"TOTO_C.COLOR"NMCE:	.ASCIZ	"TOTO_CE.COLOR"NMCA:	.ASCIZ	"TOTO_CA.COLOR"NMCH:	.ASCIZ	"TOTO_CH.COLOR"NMCP:	.ASCIZ	"TOTO_CP.COLOR"NMCR:	.ASCIZ	"TOTO_CR.COLOR"NMCD:	.ASCIZ	"TOTO_CD.COLOR"	.EVENSTART:	.IF	~IFSMILE	LIB	?OPELIB	.ENDIF	LIB	?AFTIM	.B	NOCURS		; pas de curseur !	.B	NOEFLI		; pas de EFLI automatique	.B	TRUNC		; tronque les lignes trop longues	.B	MMODULO,1	; plus de modulos	.B	0	.EVEN	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	; met toutes les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*5+4	; est-ce au moins 5.4 ?	JUMP,LO ERFAT2		; non => ERFAT2	LIB	?GETPDIS	LOAD.L	(A6)+OPDDIS,A4	LOAD.L	A0,A4		; A0 <-- ^descripteur de la fentre <<PREMANANT>>	SET.B	(A6)+OINV	; le fond de l'cran est blanc	TEST.B	(A0)+ODFCMD	JUMP,NE 15$	TEST.B	(A0)+ODFMOD:#BFBLANC	JUMP,BS 15$	CLR.B	(A6)+OINV15$:	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LOAD.B	D4,#2^BFMINUS!2^BFSON!2^BFSOURIS;;?	COMP.B	(A6)+OMACHINE,#SMAKY324;;?	JUMP,NE 20$;;?	TCLR.L	D4:#BFSON;;?20$:	LOAD.B	(A6)+OFLAGS,D4	LOAD.W	(A6)+OISDY,#LYICO	LOAD.W	(A6)+OISDX,#LXICO	LOAD.W	D4,#LYWDO	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,D4	SR.W	D3,#1	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,#LXWDO	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,D4	SR.W	D3,#1	AND.B	D3,#B'11110000	; D3 <-- utile pour SMAKY8 !	LOAD.L	(A6)+OOIMA,D3	LIB	?CREWDO		; cre swdo (utile si grand cran)	LIB	?USEWDO	LOAD.W	D3,#3	LIB	?MOUSE		; souris par le clavier	CALL	CCMO		; enlve la souris	CALL	MMOUSE		; remet la souris au milieu de la fentre	LOAD.L	A3,#R16"NMC0	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE LI0$		; oui => LI0$	LOAD.L	A3,#R16"NMI0LI0$:	CALL	_AFIMAGE	; affiche l'image gnrique, si pas dj fait	JUMP,NE	ERFAT2	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSTRE	LOAD.W	D3,#ST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSTRE,D1	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOICOL$	LOAD.L	A3,#R16"NMICOL	LOAD.W	D3,#ICOL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHICOL,D1NOICOL$:	LOAD.L	A1,#R16"TXERFATGRA	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADRASTER,A3	LOAD.W	D3,#GRA_CRASTER	LIB_	GETAD	LOAD.L	(A6)+OADCRASTER,A3	LOAD.W	D3,#GRA_MATRIX	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADMATRIX,A3	LOAD.W	D3,#GRA_DOT	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADDOT,A3	LOAD.W	D3,#GRA_TRAME	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADTRAME,A3	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADLINE,A3	LOAD.W	D3,#GRA_ELLIPSE	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADELLIPSE,A3	LOAD.W	D3,#GRA_FILLO	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADFILLO,A3	LOAD.W	D3,#GRA_FILLC	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADFILLC,A3	LOAD.W	D3,#GRA_CLEAR	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADCLEAR,A3	LOAD.W	D3,#GRA_SET	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADSET,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADINV,A3	LOAD.L	A3,#R16"TXERFATTXT	LIB	?AFTIM	.B	LOADGC		; charge les caractres standards	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATTXTP	LIB	?AFTIM	.B	LOADGC		; charge les caractres standards	.B	GCTXF	.B	GCTXS	.B	GCTXTP	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATICO1	LIB	?AFTIM	.B	LOADGC		; charge les icnes ITP82	.B	GCICF	.B	GCICS	.B	GCICT	.B	0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC		; utilise les icnes ITP82	.B	GCICF	.B	GCICS	.B	GCICT	.B	0	.EVEN	LOAD.L	(A6)+OPGICO,(A0)+ODFPGC	LOAD.L	A3,#R16"TXERFATICO2	LIB	?AFTIM	.B	LOADGC		; charge les icnes ITP83	.B	GCICF	.B	GCICS	.B	GCICT+1	.B	0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC		; utilise les icnes ITP83	.B	GCICF	.B	GCICS	.B	GCICT+1	.B	0	.EVEN	LOAD.L	(A6)+OPSICO,(A0)+ODFPGC	LIB	?AFTIM	.B	USEGC		; utilise les caractres standard	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	CALL	CCMO		; enlve la souris	LOAD.L	A3,#R16"TXERFATICO1	CALL	CALCFOND	; calcule le gencar des fonds	JUMP,NE ERFAT2	NTREL	?GETPRIO	; D4 <-- priorit de START	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP,NE ERFAT2	LOAD.L	A3,#R16"NMS	CALL	_LOADSOUND	; charge les sons	JUMP,NE	ERFAT2	LOAD.L	(A6)+OPS,A4	COMP.B	(A6)+OMACHINE,#SMAKY300	JUMP',NE NOBS$	LOAD.L	A3,#R16"TXERFATMEM	LOAD.L	D4,#LADH+LBS	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande pour sons (SMAKY300)	JUMP,NE	ERFAT2	LOAD.L	(A6)+OBS,A4	LOAD.L	D4,#LADH	GESMEM	?CLEARMEM	; efface l'en-tte	LOAD.B	(A4)+OADHTYP,#ADHTYPENOBS$:	LOAD.L	A3,#R16"NMCE	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE LIETE$		; oui => LIETE$	LOAD.L	A3,#R16"NMIELIETE$:	CALL	_LOADIMAGE	; charge une image	JUMP,NE	ERFAT2	LOAD.L	(A6)+OPICE,A4	LOAD.L	A3,#R16"NMCA	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE LIAUT$		; oui => LIAUT$	LOAD.L	A3,#R16"NMIALIAUT$:	CALL	_LOADIMAGE	; charge une image	JUMP,NE	ERFAT2	LOAD.L	(A6)+OPICA,A4	LOAD.L	A3,#R16"NMCH	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE LIHIV$		; oui => LIHIV$	LOAD.L	A3,#R16"NMIHLIHIV$:	CALL	_LOADIMAGE	; charge une image	JUMP,NE	ERFAT2	LOAD.L	(A6)+OPICH,A4	LOAD.L	A3,#R16"NMCP	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE LIPRI$		; oui => LIPRI$	LOAD.L	A3,#R16"NMIPLIPRI$:	CALL	_LOADIMAGE	; charge une image	JUMP,NE	ERFAT2	LOAD.L	(A6)+OPICP,A4	LOAD.L	A3,#R16"NMIG	CALL	_LOADIMAGE	; charge une image	JUMP,NE	ERFAT2	LOAD.L	(A6)+OPICG,A4	LOAD.L	A3,#R16"NMIT	CALL	_LOADIMAGE	; charge une image	JUMP,NE	ERFAT2	LOAD.L	(A6)+OPICT,A4	LOAD.L	A3,#R16"NMCR	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE LIREV$		; oui => LIREV$	LOAD.L	A3,#R16"NMIRLIREV$:	CALL	_LOADIMAGE	; charge une image	JUMP,NE	ERFAT2	LOAD.L	(A6)+OPICR,A4	LOAD.L	A3,#R16"NMCD	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE LIDED$		; oui => LIDED$	LOAD.L	A3,#R16"NMIDLIDED$:	CALL	_LOADIMAGE	; charge une image	JUMP,NE	ERFAT2	LOAD.L	(A6)+OPICD,A4	LOAD.L	A3,#R16"NMCE	LOAD.L	A4,(A6)+OPICE	CLR.W	D3		; D3 <-- inverse si ncessaire	LOAD.L	(A6)+OPICODE,A4	CALL	_DECOIMAGE	; dcode l'image de l't	JUMP,NE ERFAT2	LOAD.L	(A6)+OPIDESS,A4	LOAD.L	(A6)+ODIMA,D4	LOAD.B	(A6)+OSAISON,#'E	LOAD.L	A4,(A6)+OPICODE	CALL	_CLUTIMAGE	; utilise la CLUT de l'image	LOAD.L	A3,#R16"TXERFATMEM	CLR.W	D2	LOAD.B	D2,(A0)+ODFCNP	; D2 <-- nb de bits/pixel	LOAD.L	D3,D4	SWAP.W	D3	SR.W	D4,#3	MUL.WU	D4,D2	MUL.WU	D4,D3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour image temporaire	JUMP,NE ERFAT2	LOAD.L	(A6)+OPITEMP,A4	CALL	COPYDT		; OPITEMP <-- OPIDESS	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OONPOS,#H'10000*PARRGY+PARRGX	LOAD.L	(A5)+OOLPOS,(A5)+OONPOS	LOAD.W	(A5)+OOICON,#32	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	LOAD.W	D3,(A5)+OOICON	; D3 <-- icne	CALL	DROBJET		; dessine toto	CALL	LMOUSE		; souris = main	CALL	CCMO		; enlve la souris	CALL	MMOUSE		; remet la souris au milieu de la fentre	CALL	AFMENU		; affiche les soft-keys	LOAD.L	A3,#R16"TXERFATMEM	GESMEM	?ARGMEM	COMP.L	D5,#70000	; reste encore 70 Kbytes au minimum ?	JUMP,LO ERFAT2		; non => ERFAT2REFAIT:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE 50$		; oui => 50$	LIB	?GETWDO	LOAD.W	D6,D5	CLR.W	D5	LIB	?USEWDO	LOAD.L	D3,#-1	TEST.B	(A6)+OINV	JUMP,T	20$	CLR.L	D320$:	LOAD.L	D4,D3	CALL	_DRTRADEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LOAD.W	D2,#LOADDOT	CALL	_DRTRAME	; efface toute la fentre	LOAD.W	D5,D6	LIB	?USEWDO50$:	LOAD.L	A4,(A6)+OPITEMP	LOAD.L	D4,(A6)+ODIMA	LOAD.W	D3,(A6)+OPIMAX	CALL	_SHOWIMAGE	; affiche l'image	LOAD.L	A3,A4	LOAD.W	D5,D4	SR.W	D5,#3	LOAD.L	D2,D4	CALL	_SHOWCADRE	; affiche le cadre	CALL	AFLETTRE	; affiche la lettre	CALL	_COUPSAC	; gnrateur alatoire: coup de sacLOOP:	CALL	MMOUSE		; remet la souris au milieu de la fentre	CALL	MAJMENU		; mj. les soft-keys	TEST.B	(A6)+OPLAY	; raconte une histoire ?	JUMP,T	LOOPS		; oui => LOOPS	LOAD.W	(A6)+OSOUND,#TMUSDONELOOPS:	CALL	GETCAR		; attend une touche ...LOOPK:	CLR.B	(A6)+OCLIC	; pas avec la sourisLOOPM:	TEST.W	D3	JUMP,EQ LOOPS	COMP.W	D3,#KEYMGR	JUMP,EQ LOOPS	COMP.W	D3,#KEYMMR	JUMP,EQ LOOPS	COMP.W	D3,#KEYMDR	JUMP,EQ LOOPS	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC	CALL	CCMO		; enlve la souris	TEST.B	(A6)+OCLIC	; avec un clic de la souris ?	JUMP,T	20$		; oui => 20$	LIB	?MINMAJ20$:	COMP.W	D3,#F0+SHIFT	JUMP,EQ FINI	COMP.W	D3,#F1	JUMP,EQ PREND	COMP.W	D3,#F1+SHIFT	JUMP,EQ PREND	COMP.W	D3,#F3	JUMP,EQ SAUVE	COMP.W	D3,#F3+SHIFT	JUMP,EQ SAUVE	COMP.W	D3,#F4	JUMP,EQ DEFHIST	COMP.W	D3,#F4+SHIFT	JUMP,EQ DEFHIST	COMP.W	D3,#F5	JUMP,EQ DEFHIST	COMP.W	D3,#F5+SHIFT	JUMP,EQ DEFHIST	COMP.W	D3,#F6	JUMP,EQ DEFHIST	COMP.W	D3,#F6+SHIFT	JUMP,EQ DEFHIST	COMP.W	D3,#F7	JUMP,EQ RACONTE	COMP.W	D3,#F7+SHIFT	JUMP,EQ RACONTE	COMP.W	D3,#F8	JUMP,EQ RACONTE	COMP.W	D3,#F8+SHIFT	JUMP,EQ RACONTE	COMP.W	D3,#F9	JUMP,EQ RACONTE	COMP.W	D3,#F9+SHIFT	JUMP,EQ RACONTE; ATTENTION: comparaison avec D3.L pour tenir compte du pseudo-code,; et interdire ainsi les clic avec la souris dans les soft-keys !	COMP.L	D3,#H'10000*14+F14+SHIFT	JUMP,EQ LISTE	COMP.L	D3,#H'10000*15+F15+SHIFT	JUMP,EQ CHOIX	.IF	DANIEL	COMP.W	D3,#H'100*(2^BPROGRA)+'S	JUMP,EQ STEP$	.ENDIF	LOAD.W	(A6)+OLASTLE,(A6)+OLETTRE	LOAD.W	(A6)+OLETTRE,D3	CALL	AFLETTRE	; affiche juste la lettre	COMP.W	D3,#'A	JUMP,EQ AUTOMNE	COMP.W	D3,#'B	JUMP,EQ BONJOUR	COMP.W	D3,#'C	JUMP,EQ CHEMINEE	COMP.W	D3,#'D	JUMP,EQ DISPARAITRE	COMP.W	D3,#'E	JUMP,EQ ETE	COMP.W	D3,#'F	JUMP,EQ FATIGUE	COMP.W	D3,#'G	JUMP,EQ GALOP	COMP.W	D3,#'H	JUMP,EQ HIVER	COMP.W	D3,#'I	JUMP,EQ IMMEUBLE	COMP.W	D3,#'J	JUMP,EQ JARDIN	COMP.W	D3,#'K	JUMP,EQ KANGOUROU	COMP.W	D3,#'L	JUMP,EQ LUMIERE	COMP.W	D3,#'M	JUMP,EQ MANGER	COMP.W	D3,#'N	JUMP,EQ NEZ	COMP.W	D3,#'O	JUMP,EQ OISEAUX	COMP.W	D3,#'P	JUMP,EQ PRINTEMPS	COMP.W	D3,#'Q	JUMP,EQ QUEUE	COMP.W	D3,#'R	JUMP,EQ REVE	COMP.W	D3,#'S	JUMP,EQ SOMMET	COMP.W	D3,#'T	JUMP,EQ TROT	COMP.W	D3,#'U	JUMP,EQ UN	COMP.W	D3,#'V	JUMP,EQ VIEUX	COMP.W	D3,#'W	JUMP,EQ WALKMAN	COMP.W	D3,#'X	JUMP,EQ XYLOPHONE	COMP.W	D3,#'Y	JUMP,EQ YEUX	COMP.W	D3,#'Z	JUMP,EQ ZUT	COMP.W	D3,#KEYDBOX+1	JUMP,EQ SAISON_NEXT	JUMP	LOOPSTEP$:	NOT.B	(A6)+OSTEP	JUMP	LOOPPREND:	CALL	DBOXPREND	; prend une histoire ...	JUMP	LOOPSAUVE:	TEST.B	(A6)+OOMENU+1:#BMNNOHIS-0	JUMP,BS LOOP	CALL	DBOXSAUVE	; sauve l'histoire ...	JUMP	LOOPDEFHIST:	CALL	DBOXHISTOIRE	; dite l'histoire ...	JUMP	LOOPRACONTE:	TEST.B	(A6)+OOMENU+1:#BMNNOHIS-0	JUMP,BS LOOP	CLR.W	(A6)+OPHIST	SET.B	(A6)+OPLAY	; hop, raconte	JUMP	LOOPLISTE:	LOAD.B	D3,#SAVWDO	LIB	?AFCAR	JUMP,NE LOOP	LIB	?AFTIM	.B	EOP,CR,CR	.ASCII	"	A = automne         N = nez<CR>"	.ASCII	"	B = bonjour         O = oiseaux<CR>"	.ASCII	"	C = chemine        P = printemps<CR>"	.ASCII	"	D = disparatre     Q = queue<CR>"	.ASCII	"	E = t             R = rve<CR>"	.ASCII	"	F = fatigu         S = sommet<CR>"	.ASCII	"	G = galop           T = trot<CR>"	.ASCII	"	H = hiver           U = un<CR>"	.ASCII	"	I = immeuble        V = vieux<CR>"	.ASCII	"	J = jardin          W = walkman<CR>"	.ASCII	"	K = kangourou       X = xylophone<CR>"	.ASCII	"	L = lumire         Y = yeux<CR>"	.ASCII	"	M = manger          Z = zut<CR>"	.B	CR	.ASCII	""	.B	0	.EVEN	LIB	?GETCAR		; attend une touche ...	LOAD.B	D3,#GETWDO	LIB	?AFCAR	JUMP	LOOPCHOIX:	CALL	DBOXCHOIX	; demande choix ...	COMP.W	D3,#CR	JUMP,NE LOOP	JUMP	REFAITCLIC:	TEST.B	(A6)+OFLAGS:#BFSOURIS	JUMP,BC LOOP	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP	LOAD.W	D3,D4		; D3 <-- X	ADD.W	D3,(A6)+OPIMAX	SWAP.W	D4		; D4 <-- Y	ADD.W	D3,#2	ADD.W	D4,#7		; selon le doigt de la main !	LOAD.L	A4,#R16"TACLIC20$:	TEST.W	(A4)		; fin de la table ?	JUMP,EQ LOOP		; oui => LOOP	LOAD.W	D2,(A4)+2	COMP.W	D3,D2	JUMP,LO 80$	ADD.W	D2,(A4)+6	COMP.W	D3,D2	JUMP,HS 80$	LOAD.W	D2,#LYWDO-1	SUB.W	D2,(A4)+4	COMP.W	D4,D2	JUMP,LO 80$	ADD.W	D2,(A4)+8	COMP.W	D4,D2	JUMP,HS 80$	LOAD.W	D3,(A4)+0	; D3 <-- touche	SET.B	(A6)+OCLIC	; avec la souris	JUMP	LOOPM80$:	ADD.L	A4,#10		; A4 <-- ^suivant dans table	JUMP	20$		;	  x,y		dx,dy	<-- donns par DESSIN4TACLIC:;	.W	'A		.W	'B	63,62		83,50	.W	'C	94,257		63,74;	.W	'D	;	.W	'E		.W	'F	389,84		44,71		; porte de droite;	.W	'G	;	.W	'H	;	.W	'K		.W	'L	234,86		51,73		; porte de gauche	.W	'M	62,108		66,45		; fentre de gauche	.W	'N	332,52		14,14	.W	'N	480+332,52	14,14	.W	'O	730,329		265,115	.W	'O	995,328		123,67;	.W	'P	;	.W	'Q	;	.W	'R		.W	'S	998,260		78,61;	.W	'T		.W	'U	322,29		34,18	.W	'U	480+322,29	34,18;	.W	'V	;	.W	'W		.W	'X	216,183		42,35		; fentre en haut au milieu	.W	'Y	328,71		24,24	.W	'Y	480+328,71	24,24;	.W	'Z		.W	'I	729,174		353,94	.W	'J	703,76		310,64	.W	KEYDBOX+1  399,329	309,226		; feuillage de l'arbre	.W	KEYDBOX+1  540,104	57,102		; tronc de l'arbre	.W	0	;-------;	;   A	;	;-------;AUTOMNE:	LOAD.W	D3,#'A	COMP.B	(A6)+OSAISON,#'E	JUMP,NE SAISON_ER	LOAD.L	A4,(A6)+OPICA	LOAD.L	A2,#R16"NOM$	LOAD.L	D1,#H'10000*28+2 ; D1 <-- l'automne	LOAD.W	D0,#50*2	LOAD.W	(A6)+OSOUND,#TMUSCOLCHIQUE	JUMP	SAISONNOM$:	.ASCIZ	"automne"	.EVENSAISON_ER:	CALL	GM_ERREURA	COMP.B	(A6)+OSAISON,#'E	JUMP',EQ 20$	CALL	GM_ERREURH	COMP.B	(A6)+OSAISON,#'A	JUMP',EQ 20$	CALL	GM_ERREURP	COMP.B	(A6)+OSAISON,#'H	JUMP',EQ 20$	CALL	GM_ERREURE20$:	CALL	ERREUR		; indique ce qu'il faut faire ...	TEST.W	D3	JUMP,NE LOOPK		; non => LOOPK	JUMP	LOOPSAISON_NEXT:	COMP.B	(A6)+OSAISON,#'E	JUMP,EQ AUTOMNE	COMP.B	(A6)+OSAISON,#'A	JUMP,EQ HIVER	COMP.B	(A6)+OSAISON,#'H	JUMP,EQ PRINTEMPS	JUMP	ETESAISON:	LOAD.B	(A6)+OSAISON,D3	CALL	EFLETTRE	; efface le texte	PUSH.W	D0	LOAD.W	D0,#PROGAL	CALL	PROGIMAGE	; affiche nouvelle saison	POP.W	D0	LOAD.L	A3,A2	CALL	AFTEXT		; affiche le nom de la saison	COMP.B	(A6)+OMACHINE,#SMAKY300	JUMP',EQ 60$	LOAD.W	D4,D0	JUMP',EQ 60$	NTREL	?DELMS		; attend un peu ...60$:	LOAD.W	D4,#0	LOAD.L	D3,D1	SWAP.W	D3	CALL	ANALOG		; prononce "c'est.."	LOAD.W	D4,#5	NTREL	?DELMS	LOAD.W	D4,D1	LOAD.W	D3,#28	CALL	ANALOG		; prononce le nom de la saison	LOAD.W	D4,#50	NTREL	?DELMS	JUMP	LOOP	;-------;	;   B	;	;-------;BONJOUR:	CALL	VAPOSG		; va  gauche	CALL	GMBONJOUR1	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; toto va  gauche	CALL	GMBONJOUR2	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; titi va vers toto	CALL	GMBONJOUR3	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	GMBONJOUR4	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A420$:	LOAD.L	A5,#(A6)+OOBJET2	CALL	MOVEOBJET	; titi se secoue la pogne	LOAD.L	A5,#(A6)+OOBJET	CALL	MOVEOBJET	; toto aussi	JUMP,EQ 20$	JUMP	LOOP	;-------;	;   C	;	;-------;CHEMINEE:	COMP.B	(A6)+OSAISON,#'H	JUMP,EQ SAISON_ER	CALL	VAPOSG		; va  gauche	LOAD.L	A4,#(A6)+OHACHE	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#3		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	(A6)+OHATST,D4	CALL	GMCHEMINEE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   D	;	;-------;DISPARAITRE:	CALL	VAPOSD		; va  droite	LOAD.L	A5,#(A6)+OOBJET	SUB.W	(A5)+OONPOS+2,#480	LOAD.L	A3,#R16"TABLE$	LOAD.W	D2,#5-120$:	LOAD.L	A4,#(A6)+OHADI1	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#5		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..4	MUL.WU	D4,#6	LOAD.W	D3,(A3)+(D4.W)+4 ; D3 <-- icne	LOAD.L	D4,(A3)+(D4.W)+0 ; D4 <-- position	CALL	GO$	DECJ.W,NMO D2,20$	LOAD.L	A3,#R16"NOM$	CALL	AFTEXT		; affiche "disparatre"	LOAD.L	D4,#H'10000*PARRGY+PARRGX	LOAD.W	D3,#32	CALL	GO$	ADD.W	(A5)+OONPOS+2,#480	JUMP	LOOPTABLE$:	.W	132,467,69	; sur colline  l'avant plan  droite	.W	138,287,53	; sur colline au milieu de l'cran	.W	246,0,7		; sous l'arbre,  gauche	.W	60,223,48	; sur montagne derrire, prs de l'arbre	.W	42,520,19	; sur montagne derrire,  droiteNOM$:	.ASCIZ	"disparatre"	.EVEN; in	D3.W	nouvelle icne;	D4.L	position; out	-; mod	D7.WGO$:	PUSHM.L	D0..D5,A3,A4	PUSHM.L	D3,D4	LOAD.L	A4,#(A6)+OHADI2	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#3		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	D0,D4	LOAD.W	(A6)+OSOUND,#TMUSDISPA	LOAD.L	A3,(A6)+OPIDESS	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	AND.W	D4,#H'FFF0	; D4 <-- position en X modulo 16 !	LOAD.L	D3,D4	ADD.W	D3,(A6)+OPIMAX	LOAD.W	D5,#LXIMA/8	LOAD.L	A4,#0	LOAD.L	D2,#H'10000*LYICO+(LXICO+16)	TEST.W	D0	JUMP',EQ GOH0$	COMP.W	D0,#1	JUMP',EQ GOH1$GOH2$:	LOAD.L	D1,#H'10000*1+1	CALL	PROGRESSHB	JUMP'	GOH$GOH1$:	LOAD.W	D1,#5	CALL	PROGRESSCN	JUMP'	GOH$GOH0$:	CALL	PROGRESSAL;	JUMP'	GOH$GOH$:	LOAD.W	D4,#50*2	NTREL	?DELMS	POPM.L	D3,D4	PUSH.L	(A6)+OPITEMP	CLR.L	(A6)+OPITEMP	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OONPOS,D4	LOAD.W	(A5)+OOICON,D3	CALL	DROBJET	POP.L	(A6)+OPITEMP	LOAD.W	(A6)+OSOUND,#TMUSMAGIC	LOAD.W	D4,#50*3	NTREL	?DELMS	POPM.L	D0..D5,A3,A4	RET	;-------;	;   E	;	;-------;ETE:	LOAD.W	D3,#'E	COMP.B	(A6)+OSAISON,#'P	JUMP,NE SAISON_ER	LOAD.L	A4,(A6)+OPICE	LOAD.L	A2,#R16"NOM$	LOAD.L	D1,#H'10000*28+1 ; D1 <-- l't	LOAD.W	D0,#50*5	LOAD.W	(A6)+OSOUND,#TMUSSOLEMIO	JUMP	SAISONNOM$:	.ASCIZ	"t"	.EVEN	;-------;	;   F	;	;-------;FATIGUE:	CALL	VAPOSG		; va  gauche	CALL	GMFATIGUE1	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	LOAD.W	D4,#3-120$:	CLR.W	(A6)+OFADEL	CALL	GMFATIGUE2	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	DECJ.W,NMO D4,20$	LOAD.W	(A6)+OFADEL,#2	CALL	GMFATIGUE2	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	LOAD.W	(A6)+OFADEL,#6	CALL	GMFATIGUE2	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	CALL	GMFATIGUE3	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	CALL	GMFATIGUE4	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   G	;	;-------;GALOP:	LOAD.L	A3,(A6)+OPICG	CALL	GMGALOP1	COMP.W	(A6)+OOBJET+OOLPOS+2,#PARRGX+100	JUMP,LO FILM	CALL	GMGALOP2FILM:	PUSH.L	A4	LOAD.L	A4,#(A6)+OHAGAL	; A4 <-- ^table pour tirage exclusif	LOAD.W	D3,#36		; D3 <-- min	LOAD.W	D4,#40		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	D0,D4	LOAD.L	A4,A3	LOAD.W	D3,#1		; D3 <-- n'inverse pas	CALL	DECOIMAGE	; dcode l'image du galop	JUMP,NE EXIT$	LOAD.L	(A6)+OPISPEC,A4	LOAD.L	(A6)+ODISPEC,D4	PUSH.L	(A6)+OPITEMP	LOAD.L	(A6)+OPITEMP,(A6)+OPIDESS	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	LOAD.W	D3,D0		; D3 <-- icne (tonn)	CALL	DROBJET		; dessine toto dans l'image principale !	POP.L	(A6)+OPITEMP	POP.L	A4	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	LOAD.L	A4,(A6)+OPISPEC	CALL	FREEIMAGE	; libre l'image du galop/trot	LOAD.L	A4,(A6)+OPIDESS	CALL	FREEIMAGE	; libre l'image dcode	LOAD.L	A4,(A6)+OPICODE	CLR.W	D3		; D3 <-- inverse si ncessaire	CALL	DECOIMAGE	; dcode l'image de la saison	JUMP,NE LOOP	LOAD.L	(A6)+OPIDESS,A4	CALL	COPYDT		; OPITEMP <-- OPIDESS	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	LOAD.W	D3,(A5)+OOICON	; D3 <-- icne	CALL	DROBJET		; dessine toto	JUMP	LOOPEXIT$:	POP.L	A4	JUMP	LOOP	;-------;	;   H	;	;-------;HIVER:	LOAD.W	D3,#'H	COMP.B	(A6)+OSAISON,#'A	JUMP,NE SAISON_ER	LOAD.L	A4,(A6)+OPICH	LOAD.L	A2,#R16"NOM$	LOAD.L	D1,#H'10000*28+3 ; D1 <-- l'hivers	CLR.W	D0		; D0 <-- pas d'attente	LOAD.W	(A6)+OSOUND,#TMUSHIVER	JUMP	SAISONNOM$:	.ASCIZ	"hiver"	.EVEN	;-------;	;   I	;	;-------;IMMEUBLE:	CALL	VAPOSD		; va  droite	CALL	GMIMMEUBLE1	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va  gauche	LOAD.W	D0,#48		; D0 <-- position maximale en Y	LOAD.W	D1,#20		; D1 <-- nb d'immeubles  dessiner20$:	PUSHM.L	D1,D2	LOAD.W	D3,D0		; D3 <-- hauteur minimale	LOAD.W	D4,#48+20*8+50	; D4 <-- hauteur maximale	CALL	MMHAZARD	LOAD.W	D1,D4	LOAD.W	D2,#PARRDY+LXICO	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	LOAD.W	D3,#244	LOAD.W	D4,#LXWDO-60	CALL	MMHAZARD	LOAD.W	D1,D4	LOAD.W	D3,#40		; D4 <-- largeur minimale	LOAD.W	D4,#LXWDO-10	SUB.W	D4,D1		; D4 <-- largeur maximale	CALL	MMHAZARD	COMP.W	D4,#100	JUMP',LS 40$	LOAD.W	D4,#10040$:	LOAD.W	D2,D4	LOAD.L	D3,D1	LOAD.L	D4,D2	CALL	DRIMMEUBLE	; dessine un immeuble	LOAD.L	D3,D4	SWAP.W	D3	SR.W	D3,#4	SUB.W	D3,#20	NEG.W	D3	LOAD.W	D4,#SILENCE	LOAD.W	D5,#SILENCE	LOAD.W	D6,#H'100*20+0	LIB	?ACCORD	LOAD.W	D3,#10	LOAD.W	D4,#40	CALL	MMHAZARD	NTREL	?DELMS		; attend un poil ...	POPM.L	D1,D2	ADD.W	D0,#8	DEC.W	D1	JUMP,NE 20$	LOAD.L	A3,#R16"NOM$	CALL	AFTEXT		; affiche "immeubles"	LOAD.L	A3,#0	LOAD.L	A4,(A6)+OPIDESS	CLR.L	D3	LOAD.W	D3,(A6)+OPIMAX	LOAD.L	D4,#H'10000*LYWDO+LXWDO	LOAD.W	D2,#LOADDOT	CALL	XFERZONE	LOAD.W	D4,#50*2	NTREL	?DELMS	CALL	GMIMMEUBLE2	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; voiture ->	LOAD.W	D4,#50	NTREL	?DELMS	CALL	NEWTOTO$	CALL	GMIMMEUBLE2	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; voiture ->	CALL	NEWTOTO$	CALL	GMIMMEUBLE3	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; voiture <-	CALL	NEWTOTO$	CALL	GMIMMEUBLE2	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; voiture ->	CALL	NEWTOTO$	CALL	GMIMMEUBLE3	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; voiture <-	CALL	NEWTOTO$	CALL	GMIMMEUBLE3	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; voiture <-	CALL	NEWTOTO$	CALL	GMIMMEUBLE3	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; voiture <-	CALL	NEWTOTO$	CALL	GMIMMEUBLE2	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; voiture ->	CALL	NEWTOTO$	CALL	GMIMMEUBLE2	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; voiture ->	CALL	NEWTOTO$	CALL	GMIMMEUBLE3	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; voiture <-	LOAD.L	A4,(A6)+OPIDESS	CALL	FREEIMAGE	; libre l'image dcode	LOAD.L	A4,(A6)+OPICODE	CLR.W	D3		; D3 <-- inverse si ncessaire	CALL	DECOIMAGE	; dcode l'image de la saison	JUMP,NE LOOP	LOAD.L	(A6)+OPIDESS,A4	CALL	COPYDT		; OPITEMP <-- OPIDESS	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	LOAD.W	D3,(A5)+OOICON	; D3 <-- icne	CALL	DROBJET		; dessine toto	CALL	EFLETTRE	; efface le texte	LOAD.L	A3,(A6)+OPITEMP	CLR.L	D3	LOAD.W	D3,(A6)+OPIMAX	LOAD.W	D5,#LXIMA/8	LOAD.L	A4,#0	CLR.L	D4	LOAD.L	D2,#H'10000*LYWDO+LXWDO	CALL	PROGRESSAL	LOAD.L	A3,#R16"NOM$	CALL	AFTEXT		; affiche "immeubles"	CALL	GMIMMEUBLE4	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; retourne en place	JUMP	LOOPNOM$:	.ASCIZ	"immeubles"	.EVENNEWTOTO$:	PUSH.L	(A6)+OPITEMP	LOAD.L	(A6)+OPITEMP,(A6)+OPIDESS	LOAD.L	A4,#(A6)+OHAIMM	; A4 <-- ^table pour tirage exclusif	LOAD.W	D3,#36		; D3 <-- min	LOAD.W	D4,#40		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	D3,D4	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	CALL	DROBJET		; dessine toto	POP.L	(A6)+OPITEMP	RET	;-------;	;   J	;	;-------;JARDIN:	COMP.B	(A6)+OSAISON,#'H	JUMP,EQ SAISON_ER	COMP.B	(A6)+OSAISON,#'A	JUMP,EQ SAISON_ER	CALL	VAPOSD		; va  droite	CALL	GMJARDIN1	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va  droite	LOAD.L	A5,#(A6)+OOBJET2	LOAD.W	(A5)+OOLPOS+0,#PARRDY	LOAD.W	D2,#6-120$:	LOAD.L	A4,#(A6)+OHAJAR	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#6		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..5	LOAD.W	(A6)+OHATST,D4	MUL.WU	D4,#80	ADD.W	D4,#LXIMA-500	LOAD.W	(A5)+OOLPOS+2,D4	CALL	GMJARDIN2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; a pousse	DECJ.W,NMO D2,20$	LOAD.L	A3,#R16"NOM$	CALL	AFTEXT		; affiche "jardin"	LOAD.W	D4,#50	NTREL	?DELMS	LOAD.L	A5,#(A6)+OOBJET2	LOAD.W	(A5)+OOLPOS+0,#PARRDY	LOAD.W	D2,#6-130$:	LOAD.L	A4,#(A6)+OHAJAR	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#6		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..5	LOAD.W	(A6)+OHATST,D4	MUL.WU	D4,#80	ADD.W	D4,#LXIMA-500	LOAD.W	(A5)+OOLPOS+2,D4	CALL	GMJARDIN3	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; v'la les fruits	DECJ.W,NMO D2,30$	LOAD.L	A3,#0	LOAD.L	A4,(A6)+OPIDESS	CLR.L	D3	LOAD.W	D3,(A6)+OPIMAX	LOAD.L	D4,#H'10000*LYWDO+LXWDO	LOAD.W	D2,#LOADDOT	CALL	XFERZONE	CALL	GMJARDIN4	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; revient manger un fruit	LOAD.L	A4,(A6)+OPIDESS	CALL	FREEIMAGE	; libre l'image dcode	LOAD.L	A4,(A6)+OPICODE	CLR.W	D3		; D3 <-- inverse si ncessaire	CALL	DECOIMAGE	; dcode l'image de la saison	JUMP,NE LOOP	LOAD.L	(A6)+OPIDESS,A4	CALL	COPYDT		; OPITEMP <-- OPIDESS	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	LOAD.W	D3,(A5)+OOICON	; D3 <-- icne	CALL	DROBJET		; dessine toto	LOAD.L	A3,(A6)+OPITEMP	LOAD.W	D3,#PARRDY	SWAP.W	D3	LOAD.W	D3,(A6)+OPIMAX	LOAD.W	D5,#LXIMA/8	LOAD.L	A4,#0	LOAD.W	D4,#PARRDY	SWAP.W	D4	CLR.W	D4	LOAD.L	D2,#H'10000*LYICO+LXWDO	LOAD.L	D1,#H'10000*1+2	CALL	PROGRESSHB	JUMP	LOOPNOM$:	.ASCIZ	"jardin"	.EVEN	;-------;	;   K	;	;-------;KANGOUROU:	CALL	VAPOSD		; va  droite	LOAD.L	A4,#(A6)+OHAKAN	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#3		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	(A6)+OHATST,D4	CALL	GMKANGOUROU	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   L	;	;-------;LUMIERE:	CALL	VAPOSG		; va  gauche	LOAD.L	A4,#(A6)+OHAINT	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#3		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	D0,#PROGHB	LOAD.L	D1,#H'10000*5+1	COMP.W	D4,#2	JUMP',EQ HAZ$	LOAD.W	D0,#PROGCN	LOAD.W	D1,#3	COMP.W	D4,#1	JUMP',EQ HAZ$	LOAD.W	D0,#PROGAHAZ$:	CALL	GMLUMIERE1	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va dans la porte	CALL	EFLETTRE	; efface le texte	LOAD.L	A4,(A6)+OPICD	CALL	PROGIMAGE	; dessine l'intrieur de la maison	CALL	AFLETTRE	; affiche la lettre	LOAD.W	D4,#50	NTREL	?DELMS	CALL	GMLUMIERE2	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; teint	LOAD.L	A3,(A6)+OPIDESS	LOAD.W	D4,#(LYWDO*LXWDO)/32-1	LOAD.L	D3,#-1	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',T	50$		; oui => 50$	CLR.L	D350$:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE 52$		; oui => 52$51$:	LOAD.L	(A3+),D3	DECJ.W,NMO D4,51$	JUMP'	55$52$:	LOAD.L	(A3+),D3	LOAD.L	(A3+),D3	LOAD.L	(A3+),D3	LOAD.L	(A3+),D3	DECJ.W,NMO D4,52$55$:	LOAD.L	A3,(A6)+OPIDESS	LOAD.L	A4,#0	CLR.L	D3	LOAD.L	D4,#H'10000*LYWDO+LXWDO	LOAD.W	D2,#LOADDOT	CALL	XFERZONE	; teint (rend l'cran tout noir)	CALL	GMLUMIERE3	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; clique des yeux	LOAD.L	A4,(A6)+OPIDESS	CALL	FREEIMAGE	; libre l'image dcode	LOAD.L	A4,(A6)+OPICD	CLR.W	D3		; D3 <-- inverse si ncessaire	LOAD.L	(A6)+OPICODE,A4	CALL	DECOIMAGE	; dcode l'image de l'intrieur	JUMP,NE LOOP	LOAD.L	(A6)+OPIDESS,A4	LOAD.L	(A6)+ODIMA,D4	CALL	COPYDT		; OPITEMP <-- OPIDESS	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	LOAD.W	D3,(A5)+OOICON	; D3 <-- icne	CALL	DROBJET		; dessine toto	LOAD.L	A3,(A6)+OPIDESS	LOAD.L	A4,#0	CLR.L	D3	LOAD.L	D4,#H'10000*LYWDO+LXWDO	LOAD.W	D2,#LOADDOT	CALL	XFERZONE	; rallume (remet l'cran initial)	CALL	GMLUMIERE4	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; allume	LOAD.L	A4,(A6)+OPICE	COMP.B	(A6)+OSAISON,#'E	JUMP',EQ 60$	LOAD.L	A4,(A6)+OPICA	COMP.B	(A6)+OSAISON,#'A	JUMP',EQ 60$	LOAD.L	A4,(A6)+OPICH	COMP.B	(A6)+OSAISON,#'H	JUMP',EQ 60$	LOAD.L	A4,(A6)+OPICP60$:	COMP.W	D0,#PROGCN	JUMP',NE 62$	LOAD.W	D0,#PROGCI62$:	CALL	PROGIMAGE	; affiche la bonne saison	LOAD.L	A3,#R16"NOM$	CALL	AFTEXT		; affiche "lumire"	CALL	GMLUMIERE5	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; retourne en place	JUMP	LOOPNOM$:	.ASCIZ	"lumire"	.EVEN	;-------;	;   M	;	;-------;MANGER:	CALL	VAPOSG		; va  gauche	LOAD.L	A4,#(A6)+OHAMAN	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#3		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	CALL	GMMANGER0A	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; sort pour appeler:  table	TEST.W	D4	JUMP',EQ 20$	CALL	GMMANGER0B	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; sort pour appeler:  table	COMP.W	D4,#1	JUMP',EQ 20$	CALL	GMMANGER0C	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; sort pour appeler:  table20$:	LOAD.L	A4,#(A6)+OHAINT	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#3		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	D0,#PROGHB	LOAD.L	D1,#H'10000*5+1	COMP.W	D4,#2	JUMP',EQ HAZ$	LOAD.W	D0,#PROGCN	LOAD.W	D1,#3	COMP.W	D4,#1	JUMP',EQ HAZ$	LOAD.W	D0,#PROGAHAZ$:	CALL	GMMANGER1	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va dans la maison	CALL	EFLETTRE	; efface le texte	LOAD.L	A4,(A6)+OPICD	CALL	PROGIMAGE	; affiche dans la maison	LOAD.L	A3,#R16"NOM$	CALL	AFTEXT		; affiche "diner"	LOAD.W	D4,#50	NTREL	?DELMS	CALL	GMMANGER2	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; retourne en place	CALL	GMMANGER3	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	GMMANGER4	LOAD.L	A5,#(A6)+OOBJET2	LOAD.L	(A5)+OOMPTA,A450$:	LOAD.L	A5,#(A6)+OOBJET2	CALL	MOVEOBJET	; titi mange	LOAD.L	A5,#(A6)+OOBJET	CALL	MOVEOBJET	; toto mange aussi	JUMP,EQ 50$	LOAD.L	A4,(A6)+OPICE	COMP.B	(A6)+OSAISON,#'E	JUMP',EQ 60$	LOAD.L	A4,(A6)+OPICA	COMP.B	(A6)+OSAISON,#'A	JUMP',EQ 60$	LOAD.L	A4,(A6)+OPICH	COMP.B	(A6)+OSAISON,#'H	JUMP',EQ 60$	LOAD.L	A4,(A6)+OPICP60$:	COMP.W	D0,#PROGCN	JUMP',NE 62$	LOAD.W	D0,#PROGCI62$:	CALL	PROGIMAGE	; affiche la bonne saison	LOAD.L	A3,#R16"NOM$	CALL	AFTEXT		; affiche "manger"	CALL	GMMANGER5	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; retourne en place	JUMP	LOOPNOM$:	.ASCIZ	"manger"	.EVEN	;-------;	;   N	;	;-------;NEZ:	CALL	GMNEZ	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   O	;	;-------;OISEAUX:	COMP.B	(A6)+OSAISON,#'H	JUMP,EQ SAISON_ER	CALL	VAPOSD		; va  droite	CALL	GMOISEAUX1	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; de dos	LOAD.L	A4,#(A6)+OOITAB	LOAD.W	D2,#MAXOISEAUX/2-110$:	LOAD.W	D3,#LXWDO	LOAD.W	D4,#LXWDO+200	CALL	MMHAZARD	LOAD.W	(A4)+OOIPOS+2,D4	LOAD.W	(A4)+OOIPOS+0,#60	CLR.W	(A4)+OOILYS	LOAD.W	(A4)+OOILYI,#100	LOAD.L	(A4)+OOILST,#H'1000000*0+H'10000*2+H'100*4+H'1*2	AND.W	D4,#B'11	LOAD.W	(A4)+OOIPTR,D4	LOAD.W	(A4)+OOIDIR+2,#-1	LOAD.W	(A4)+OOIDIR+0,#+1	ADD.L	A4,#LOI	DECJ.W,NMO D2,10$	LOAD.W	D2,#MAXOISEAUX/2-112$:	LOAD.W	D3,#LXWDO	LOAD.W	D4,#LXWDO+200	CALL	MMHAZARD	LOAD.W	(A4)+OOIPOS+2,D4	LOAD.W	(A4)+OOIPOS+0,#40	CLR.W	(A4)+OOILYS	LOAD.W	(A4)+OOILYI,#100	LOAD.L	(A4)+OOILST,#H'1000000*1+H'10000*3+H'100*5+H'1*3	AND.W	D4,#B'11	LOAD.W	(A4)+OOIPTR,D4	LOAD.W	(A4)+OOIDIR+2,#-1	LOAD.W	(A4)+OOIDIR+0,#+1	ADD.L	A4,#LOI	DECJ.W,NMO D2,12$30$:	LOAD.L	A4,#(A6)+OOITAB	LOAD.W	D2,#MAXOISEAUX-1	CLR.W	D332$:	CALL	MOVEOISEAU	TEST.W	(A4)+OOIDIR+2	JUMP',EQ 34$	INC.W	D334$:	ADD.L	A4,#LOI	DECJ.W,NMO D2,32$	TEST.W	D3		; tous les oiseaux rentrs ?	JUMP,NE 30$		; non => 30$	LOAD.L	A3,#R16"NOM$	CALL	AFTEXT		; affiche "oiseaux"	LOAD.W	D4,#50	NTREL	?DELMS	CALL	GMOISEAUX2	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; de face	JUMP	LOOPNOM$:	.ASCIZ	"oiseaux"	.EVEN	;-------;	;   P	;	;-------;PRINTEMPS:	LOAD.W	D3,#'P	COMP.B	(A6)+OSAISON,#'H	JUMP,NE SAISON_ER	LOAD.L	A4,(A6)+OPICP	LOAD.L	A2,#R16"NOM$	LOAD.L	D1,#H'10000*22+4 ; D1 <-- le printemps	LOAD.W	D0,#50*1	LOAD.W	(A6)+OSOUND,#TMUSMAI	JUMP	SAISONNOM$:	.ASCIZ	"printemps"	.EVEN	;-------;	;   Q	;	;-------;QUEUE:	CLR.W	(A6)+OHATST	COMP.W	(A6)+OOBJET+OOLPOS+2,#PARRGX+100	JUMP',LO 20$	LOAD.W	(A6)+OHATST,#120$:	CALL	GMQUEUE	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   R	;	;-------;REVE:	CALL	GMREVE1	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; se couche par-terre	LOAD.W (A6)+OSOUND,#TMUSDODO	LOAD.L	A3,(A6)+OPICODE	PUSH.W	(A6)+OPIMAX	CLR.W	(A6)+OPIMAX	LOAD.L	A4,(A6)+OPICR	LOAD.W	D0,#PROGSV	; D0 <-- stores vnitiens	LOAD.W	D1,#2	CALL	PROGIMAGE	; affiche le rve	POP.W	(A6)+OPIMAX	LOAD.W	D4,#50*3	NTREL	?DELMS		; montre le rve ...	LOAD.L	A4,A3	LOAD.W	D0,#PROGAL	; D0 <-- alatoire lent	CALL	PROGIMAGE	; fin du rve	LOAD.W	D4,#50*1	NTREL	?DELMS	CALL	GMREVE2	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; retourne en place	JUMP	LOOP	;-------;	;   S	;	;-------;SOMMET:	CALL	VAPOSD		; va  droite	LOAD.L	A4,#(A6)+OHASOM	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#3		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	(A6)+OHATST,D4	CALL	GMSOMMET	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   T	;	;-------;TROT:	LOAD.L	A3,(A6)+OPICT	CALL	GMTROT1	COMP.W	(A6)+OOBJET+OOLPOS+2,#PARRGX+100	JUMP,LO FILM	CALL	GMTROT2	JUMP	FILM	;-------;	;   U	;	;-------;UN:	CALL	GMUN	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   V	;	;-------;VIEUX:	CALL	GMVIEUX	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; dplace ...	JUMP	LOOP	;-------;	;   W	;	;-------;WALKMAN:	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	A3,(A6)+OPIDESS	LOAD.L	A4,(A6)+OPITEMP	LOAD.L	D3,(A5)+OONPOS	LOAD.L	D4,#H'10000*LYICO+LXICO	LOAD.W	D2,#LOADDOT	CALL	XFERZONE	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	ADD.W	D4,#10	LOAD.W	D3,#1		; D3 <-- icne	CALL	DROBJET		; dessine toto avec walkman	LOAD.L	A3,(A6)+OPITEMP	AND.W	D4,#H'FFF0	; D4 <-- position en X modulo 16 !	LOAD.L	D3,D4	SUB.W	D4,(A6)+OPIMAX	LOAD.W	D5,#LXIMA/8	LOAD.L	A4,#0	LOAD.L	D2,#H'10000*LYICO+(LXICO+16)	CALL	PROGRESSAL	LOAD.W	D4,#50	NTREL	?DELMS	LOAD.L	A4,#(A6)+OHAWAL	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#7		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..6	LOAD.L	A4,#R16"RYTHME1	DEC.W	D4	JUMP',NS 40$	LOAD.L	A4,#R16"RYTHME2	DEC.W	D4	JUMP',NS 40$	LOAD.L	A4,#R16"TMUSCLARINETTE	DEC.W	D4	JUMP',NS 42$	LOAD.L	A4,#R16"TMUSGUGUSSE	DEC.W	D4	JUMP',NS 42$	LOAD.L	A4,#R16"TMUSNAVIRE	DEC.W	D4	JUMP',NS 42$	LOAD.L	A4,#R16"TMUSMICHEL	DEC.W	D4	JUMP',NS 42$	LOAD.L	A4,#R16"TMUSALOUETTE	JUMP'	42$40$:	CALL	RYTHME	JUMP'	50$42$:	CALL	PLAYMORCEAU;	JUMP'	50$50$:	LOAD.L	A3,#R16"NOM$	CALL	AFTEXT		; affiche "walkman"	LOAD.W	D4,#50	NTREL	?DELMS	LOAD.L	A3,(A6)+OPIDESS	LOAD.L	A4,(A6)+OPITEMP	LOAD.L	D3,(A5)+OONPOS	ADD.W	D3,#10	LOAD.L	D4,#H'10000*LYICO+LXICO	LOAD.W	D2,#LOADDOT	CALL	XFERZONE	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	LOAD.W	D3,(A5)+OOICON	; D3 <-- icne	CALL	DROBJET		; dessine toto normal	LOAD.L	A3,(A6)+OPITEMP	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	AND.W	D4,#H'FFF0	; D4 <-- position en X modulo 16 !	LOAD.L	D3,D4	SUB.W	D4,(A6)+OPIMAX	LOAD.W	D5,#LXIMA/8	LOAD.L	A4,#0	LOAD.L	D2,#H'10000*LYICO+(LXICO+16+32)	CALL	PROGRESSAL	JUMP	LOOPNOM$:	.ASCIZ	"walkman"	.EVEN	;-------;	;   X	;	;-------;XYLOPHONE:	CALL	VAPOSG		; va  gauche	LOAD.L	A4,#(A6)+OHAXYL	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#3		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	(A6)+OHATST,D4	LOAD.L	A4,#(A6)+OHAINT	; A4 <-- ^table pour tirage exclusif	CLR.W	D3		; D3 <-- min	LOAD.W	D4,#3		; D4 <-- max+1	CALL	_EXHAZARD	; D4 <-- 0..2	LOAD.W	D0,#PROGHB	LOAD.L	D1,#H'10000*5+1	COMP.W	D4,#2	JUMP',EQ HAZ$	LOAD.W	D0,#PROGCN	LOAD.W	D1,#3	COMP.W	D4,#1	JUMP',EQ HAZ$	LOAD.W	D0,#PROGAHAZ$:	CALL	GMXYLOPHONE1	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va dans la porte	CALL	EFLETTRE	; efface le texte	LOAD.L	A4,(A6)+OPICD	CALL	PROGIMAGE	; affiche dans la maison	CALL	AFLETTRE	; affiche la lettre	LOAD.W	D4,#50*1	NTREL	?DELMS	CALL	GMXYLOPHONE2	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; joue du xylophone ...	LOAD.L	A4,(A6)+OPICE	COMP.B	(A6)+OSAISON,#'E	JUMP',EQ 60$	LOAD.L	A4,(A6)+OPICA	COMP.B	(A6)+OSAISON,#'A	JUMP',EQ 60$	LOAD.L	A4,(A6)+OPICH	COMP.B	(A6)+OSAISON,#'H	JUMP',EQ 60$	LOAD.L	A4,(A6)+OPICP60$:	COMP.W	D0,#PROGCN	JUMP',NE 62$	LOAD.W	D0,#PROGCI62$:	CALL	PROGIMAGE	; affiche la bonne saison	LOAD.L	A3,#R16"NOM$	CALL	AFTEXT		; affiche "xylophone"	CALL	GMXYLOPHONE3	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; retourne en place	JUMP	LOOPNOM$:	.ASCIZ	"xylophone"	.EVEN	;-------;	;   Y	;	;-------;YEUX:	LOAD.W (A6)+OSOUND,#TMUSMARI	LOAD.L	D3,#H'10000*170+180	LOAD.L	D4,#H'10000*170+320	CALL	ZOOM$	LOAD.L	D3,#H'10000*246+262	LOAD.L	D4,#H'10000*85+160	CALL	ZOOM$	LOAD.L	D3,#H'10000*260+300	LOAD.L	D4,#H'10000*42+80	CALL	ZOOM$	LOAD.L	D3,#H'10000*270+320	LOAD.L	D4,#H'10000*21+40	CALL	ZOOM$	LOAD.W	D4,#50*5	NTREL	?DELMS	LOAD.L	A4,(A6)+OPIDESS	CALL	FREEIMAGE	; libre l'image dcode	LOAD.L	A4,(A6)+OPICODE	CLR.W	D3		; D3 <-- inverse si ncessaire	CALL	DECOIMAGE	; dcode l'image de la saison	JUMP,NE LOOP	LOAD.L	(A6)+OPIDESS,A4	LOAD.L	A3,(A6)+OPITEMP	CLR.L	D3	LOAD.W	D3,(A6)+OPIMAX	LOAD.W	D5,#LXIMA/8	LOAD.L	A4,#0	CLR.L	D4	LOAD.L	D2,#H'10000*LYWDO+LXWDO	TEST.W	D0	LOAD.W	D1,#3	CALL	PROGRESSSV	CALL	SHOWCADRE	; affiche le cadre	LOAD.L	A3,#R16"NOM$	CALL	AFTEXT		; affiche "yeux"	JUMP	LOOPNOM$:	.ASCIZ	"yeux"	.EVEN; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	toutZOOM$:	PUSH.L	D4	LOAD.L	A4,(A6)+OPIDESS	LOAD.W	D4,#LXIMA*LYIMA/8	CLR.W	D2	LOAD.B	D2,(A0)+ODFCNP	; D2 <-- nb de bits/pixel	MUL.WU	D4,D2	GESMEM	?CLEARMEM	POP.L	D4	PUSH.L	A0	LOAD.L	A0,#(A6)+OSTVAR	LOAD.W	(A0)+OSTRTYP,#1	COMP.W	D2,#1	JUMP',EQ Z20$	LOAD.W	(A0)+OSTRTYP,#2Z20$:	LOAD.W	(A0)+OSTPIXEL,D2	LOAD.L	(A0)+OSTRSPT,(A6)+OPITEMP	LOAD.W	D1,#LXIMA/8	MUL.WU	D1,D2	LOAD.W	(A0)+OSTRSDX,D1	ADD.W	D3,(A6)+OPIMAX	LOAD.L	(A0)+OSTRS0,D3	ADD.W	D4,D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A0)+OSTRS2,D4	LOAD.L	(A0)+OSTRDPT,(A6)+OPIDESS	LOAD.W	D1,#LXIMA/8	MUL.WU	D1,D2	LOAD.W	(A0)+OSTRDDX,D1	LOAD.L	(A0)+OSTRD0,#H'10000*0+0	LOAD.L	(A0)+OSTRD1,#H'10000*0+(LXWDO-1)	LOAD.L	(A0)+OSTRD2,#H'10000*(LYWDO-1)+(LXWDO-1)	LOAD.L	(A0)+OSTRD3,#H'10000*(LYWDO-1)+0	ST_	RECT		; moteur ...	POP.L	A0	LOAD.L	A3,(A6)+OPIDESS	CLR.L	D3	LOAD.W	D5,#LXIMA/8	LOAD.L	A4,#0	CLR.L	D4	LOAD.L	D1,#H'10000*LYWDO+LXWDO	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	RET	;-------;	;   Z	;	;-------;ZUT:	CALL	VAPOSG		; va  gauche	CALL	GMZUT	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; toto casse son ballon	JUMP	LOOP;--------\\; ERREUR  >;========/; Affiche une erreur de saison.; in	A4.L	^table des mouvements; out	D3.W	touche (0 si rien); mod	D3.L, D7.WERREUR:	PUSHM.L	A4,A5	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	(A5)+OOMPTA,A420$:	CALL	IFCAR		; une touche presse ?	JUMP',EQ 30$25$:	CALL	MOVEOBJET	; explique ce qu'il faut faire ...	JUMP,EQ 20$	CLR.W	D3		; D3 <-- pas de touche	JUMP'	50$30$:	COMP.W	D3,#KEYMGR	JUMP,EQ 25$	COMP.W	D3,#KEYMMR	JUMP,EQ 25$	COMP.W	D3,#KEYMDR	JUMP,EQ 25$	COMP.W	D3,#KEYMGP	JUMP,EQ 25$	COMP.W	D3,#KEYMMP	JUMP,EQ 25$	COMP.W	D3,#KEYMDP	JUMP,EQ 25$50$:	CALL	GM_ERREURF	LOAD.L	(A5)+OOMPTA,A452$:	CALL	MOVEOBJET	; dessine toto debout normalement	JUMP,EQ 52$EXIT$:	POPM.L	A4,A5	RET;--------\\; VAPOSG  >;========/; Amne toto  gauche s'il n'y est pas dj.; in	-; out	-; mod	D7.WVAPOSG:	PUSHM.L	D3,D4,A4,A5	LOAD.L	A5,#(A6)+OOBJET	COMP.W	(A6)+OOBJET+OOLPOS+2,#PARRGX+100	JUMP',LO EXIT$	CALL	GM_GAUCHE	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va en haut  droite	CALL	AFLETTRE	; affiche la lettreEXIT$:	POPM.L	D3,D4,A4,A5	RET;--------\\; VAPOSD  >;========/; Amne toto  droite s'il n'y est pas dj.; in	-; out	-; mod	D7.WVAPOSD:	PUSHM.L	D3,D4,A4,A5	LOAD.L	A5,#(A6)+OOBJET	COMP.W	(A6)+OOBJET+OOLPOS+2,#PARRGX+100	JUMP',HS EXIT$	CALL	GM_DROITE	LOAD.L	(A5)+OOMPTA,A4	CALL	DOMOVE		; va en haut  droite	CALL	AFLETTRE	; affiche la lettreEXIT$:	POPM.L	D3,D4,A4,A5	RET;--------\\; COPYDT  >;========/; Copie l'image OPIDESS --> OPITEMP.; in	-; out	-; mod	D7.WCOPYDT:	PUSHM.L	D4,A3,A4	LOAD.L	A4,(A6)+OPIDESS	LOAD.L	A3,(A6)+OPITEMP	LOAD.W	D4,(A6)+ODIMA+2	SR.W	D4,#3	MUL.WU	D4,(A6)+ODIMA+0	SR.L	D4,#2	DEC.W	D4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE CLOOP$		; oui => CLOOP$BLOOP$:	LOAD.L	(A3+),(A4+)	DECJ.W,NMO D4,BLOOP$	JUMP'	EXIT$CLOOP$:	LOAD.L	(A3+),(A4+)	LOAD.L	(A3+),(A4+)	LOAD.L	(A3+),(A4+)	LOAD.L	(A3+),(A4+)	DECJ.W,NMO D4,CLOOP$EXIT$:	POPM.L	D4,A3,A4	RET;--------\\; DOMOVE  >;========/; Dplace un objet.; in	A5.L	^objet  mettre en mouvement; out	-; mod	D7.WDOMOVE:	PUSHM.L	D3,D410$:	CALL	IFCAR		; une touche presse ?	JUMP,NE 30$		; non => 30$	LIB	?MINMAJ	.IF	DANIEL	COMP.W	D3,#H'100*(2^BPROGRA)+'I	JUMP,EQ ICONE$	COMP.W	D3,#H'100*(2^BPROGRA)+'A	JUMP,EQ 50$	.ENDIF30$:	CALL	MOVEOBJET	PUSH.W	D7	TEST.B	(A6)+OSTEP	JUMP,F	40$	LOAD.L	D4,(A5)+OOLPOS	CALL	AFXY	LIB	?AFTIM	.ASCIZ	" i="	.EVEN	LOAD.W	D4,(A5)+OOICON	LIB	?AFX4	LIB	?AFTIM	.ASCIZ	"     "	.EVEN	LIB	?GETCAR40$:	POP.W	D7	JUMP,EQ 10$	JUMP	EXIT$50$:	LOAD.L	D4,(A5)+OOLPOS	CALL	AFXY	LIB	?GETCAR	JUMP	10$EXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RETICONE$:	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Code de l'icne : "	.EVEN	LIB	?GETDEC	COMP.W	D3,#CR	JUMP,NE REFAIT	LOAD.W	D0,D4	LOAD.L	D1,#H'AAAAAAAA	CALL	CCMO	PUSH.L	(A6)+OPITEMP	CLR.L	(A6)+OPITEMPICO1$:	LIB	?IFCAR	JUMP,EQ ICO6$	CALL	IFMOUSE	JUMP,NE ICO1$	SUB.W	D4,#LXICO/2	SWAP.W	D4	SUB.W	D4,#LYICO/2	SWAP.W	D4	COMP.L	D4,D1	JUMP,EQ ICO1$	LOAD.W	D3,D0	LOAD.W	D2,#INVDOT	EX.L	D1,D4	COMP.L	D4,#H'AAAAAAAA	JUMP,EQ ICO2$	CALL	_DRICONEICO2$:	LOAD.L	D4,D1	CALL	_DRICONE	CALL	AFXY	JUMP	ICO1$ICO6$:	POP.L	(A6)+OPITEMP	CALL	SCMO	JUMP	10$; in	D4.L	coordonne (y;x); out	-; mod	D7.WAFXY:	PUSHM.L	D2..D4	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Y="	.EVEN	PUSH.L	D4	CLR.W	D4	SWAP.W	D4	TEST.W	D4	JUMP,NC 10$	NEG.W	D4	LOAD.B	D3,#'-	LIB	?AFCAR10$:	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	POP.L	D4	LIB	?AFTIM	.ASCIZ	" X="	.EVEN	AND.L	D4,#H'FFFF	TEST.W	D4	JUMP,NC 20$	NEG.W	D4	LOAD.B	D3,#'-	LIB	?AFCAR20$:	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"     "	.EVEN	POPM.L	D2..D4	RETFINI:	CALL	DBOXQUITTE	; quitte TOTO ?	COMP.W	D3,#F1	JUMP,NE LOOPERFAT:	SET.B	(A6)+OABORT	; signal la fin au processus fils	NTREL	?WFABDESC	; attend leurs fins ...	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSTRE	LIB_	CLOSE	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOICOL$	LOAD.W	D1,(A6)+OCHICOL	LIB_	CLOSENOICOL$:	LIB	?AFTIM	.B	AFSCMO		; remet la flche-souris	.B	KILLGC		; libre les icnes ITP82	.B	GCICF	.B	GCICS	.B	GCICT	.B	KILLGC		; libre les icnes ITP83	.B	GCICF	.B	GCICS	.B	GCICT+1	.B	0	.EVEN	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire des variablesERFAT1:	.IF	~IFSMILE	LIB	?CLOLIB	FOS	?STOP	.ELSE	EXIT	.ENDIFERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT; Indirections; ------------_AFIMAGE:	JUMP	AFIMAGE_LOADIMAGE:	JUMP	LOADIMAGE_DECOIMAGE:	JUMP	DECOIMAGE_SHOWIMAGE:	JUMP	SHOWIMAGE_ADAPTIMAGE:	JUMP	ADAPTIMAGE_CLUTIMAGE:	JUMP	CLUTIMAGE_SHOWCADRE:	JUMP	SHOWCADRE_LOADSOUND:	JUMP	LOADSOUND_COUPSAC:	JUMP	COUPSAC_DRTRADEF:	JUMP	DRTRADEF_DRTRAME:	JUMP	DRTRAME_DRSET:		JUMP	DRSET_DRCLEAR:	JUMP	DRCLEAR_DRICONE:	JUMP	DRICONE_EXHAZARD:	JUMP	EXHAZARDGETADCODE:	LOAD.L	A3,#R16"ADCODE	RET; Gestion des objets utiliss; ---------------------------;---------\\; ICOOBJET >;=========/; Dessine une icne.; in	D3.L	position (y;x);	D4.W	icne (chair,fond); out	-; mod	D7.WICOOBJET:	PUSHM.L	D2..D4	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',F	50$		; non => 50$	EX.L	D3,D4	LOAD.W	D2,#CLRDOT	CALL	DRICONE		; efface le fond	SWAP.W	D3	LOAD.W	D2,#SETDOT	CALL	DRICONE		; dessine la chair	JUMP'	EXIT$50$:	EX.L	D3,D4	LOAD.W	D2,#SETDOT	CALL	DRICONE		; efface le fond	SWAP.W	D3	LOAD.W	D2,#CLRDOT	CALL	DRICONE		; dessine la chairEXIT$:	POPM.L	D2..D4	RET;--------\\; EFLETRE >;========/; Efface compltement le texte.; in	-; out	-; mod	D7.WEFLETTRE:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A3,(A6)+OPIDESS	LOAD.L	A4,#0	LOAD.L	D3,#H'10000*PTEXTY+PTEXTX	ADD.W	D3,(A6)+OPIMAX	LOAD.L	D4,#H'10000*LTEXTY+LTEXTX	LOAD.W	D2,#LOADDOT	CALL	XFERZONE		; remet l'image initiale	POPM.L	D2..D4,A3,A4	RET;---------\\; AFLETTRE >;=========/; Affiche juste une lettre.; in	-; out	-; mod	D7.WAFLETTRE:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS	CLR.W	(A3)	LOAD.W	D3,(A6)+OLETTRE	; D3 <-- lettre choisie	COMP.W	D3,#'A	JUMP',LO 50$	COMP.W	D3,#'Z	JUMP',HI 50$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule	LOAD.B	(A3),D350$:	CALL	AFTEXT	POPM.L	D3,A3	RET;--------\\; AFTEXT  >;========/; Affiche un texte, en bas  gauche.; in	A3.L	^texte; out	-; mod	D7.WAFTEXT:	PUSHM.L	D2..D4,A3,A4	LOAD.L	D3,#-1	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP,T	10$		; oui => 10$	CLR.L	D310$:	LOAD.L	D4,D3	CALL	DRTRADEF	LOAD.L	D3,#H'10000*PTEXTY+PTEXTX	LOAD.L	D4,#H'10000*LTEXTY+LTEXTX	LOAD.W	D2,#LOADDOT	CALL	DRTRAME		; efface	LOAD.L	A4,A3	LOAD.W	D4,#-120$:	INC.W	D4		; D4 <-- nb de caractres	TEST.B	(A4+)	JUMP,NE 20$	MUL.WU	D4,(A0)+ODFCX	; D4 <-- largeur	TEST.W	D4	JUMP,EQ EXIT$	LOAD.W	D3,#LTEXTY	SUB.W	D3,(A0)+ODFC1Y	TEST.B	(A6)+OFLAGS:#BFMAJUS	JUMP,BS 30$	SUB.W	D3,(A0)+ODFC2Y30$:	SR.W	D3,#1	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,#PTEXTY	SWAP.W	D3	LOAD.W	D3,#LTEXTX	SUB.W	D3,D4	SR.W	D3,#1	ADD.W	D3,(A0)+ODFC1X	ADD.W	D3,#PTEXTX	LIB	?SETCURS	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP,F	50$		; non => 50$	LOAD.B	D3,#AFINV	LIB	?AFCAR50$:	LOAD.B	D3,(A3+)	JUMP,EQ 60$	TEST.B	(A6)+OFLAGS:#BFMAJUS	JUMP,BC 55$	LIB	?MINMAJ55$:	LIB	?AFCAR		; affiche le texte	JUMP	50$60$:	LOAD.B	D3,#AFDIR	LIB	?AFCAREXIT$:	POPM.L	D2..D4,A3,A4	RET; Gestion des dbox; ----------------;-----------\\; DBOXQUITTE >;===========/; Quitte TOTO ?; in	-; out	D3.W	F1/F4; mod	D7.WDBOXQUITTE:	PUSHM.L	D0..D2,D4..D6,A3..A5	CALL	GCLITTLE	; utilise les petits caractres	CALL	NMOUSE		; souris = flche normale	CALL	SCMO		; visible	LOAD.W	D1,#DBOX_QUITTE	LOAD.L	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	DBOX_	EXTEND		; demande s'il faut quitter ...	CALL	CCMO		; invisible	CALL	LMOUSE		; souris = main	CALL	AFMENU		; refait les soft-keys	CALL	GCBIG		; utilise les caractres standard	POPM.L	D0..D2,D4..D6,A3..A5	RET;----------\\; DBOXPREND >;==========/; Lit un fichier histoire .TOTO; in	-; out	-; mod	D7.WDBOXPREND:	PUSHM.L	D0..D6,A3..A5	CALL	GCLITTLE	; utilise les petits caractres	CALL	NMOUSE		; souris = flche normale	CALL	SCMO		; visible10$:	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	LOAD.W	D1,#DBOX_PREND	LOAD.L	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A5,#(A6)+OBUFILE ; A5 <-- ^nom  diter	DBOX_	EXTEND		; demande le nom ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#(A6)+OBUFILE ; A3 <-- ^nom	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier .TOTO	JUMP,EQ 40$	COMP.W	D7,#ERKSTO	; annule ?	JUMP,EQ EXIT$		; oui => EXIT$30$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	LOAD.W	D3,#BIPERR	LIB	?BEEP	POP.W	D7	LOAD.W	D2,#2^BDBSAV	DBOX_	MERROR		; affiche l'erreur ...	JUMP	10$40$:	LOAD.L	A4,#(A6)+OHIST	LOAD.L	D4,#LHIST	FOS	?RDBYTE		; lit le fichier .TOTO	LOAD.W	D5,D7	FOS	?CLOSE		; ferme le fichier .TOTO	LOAD.W	D7,#ERNEMEM	; D7 <-- mmoire pleine	TEST.W	D5	JUMP,EQ 30$	LOAD.W	D7,D5	COMP.W	D7,#EROUTF	JUMP,NE 30$	CLR.B	(A4)+(D4.L)	; met un <0> terminateur	CLR.W	(A6)+OPHIST	SET.B	(A6)+OPLAY	; hop, raconteEXIT$:	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	CALL	CCMO		; invisible	CALL	LMOUSE		; souris = main	CALL	AFMENU		; refait les soft-keys	CALL	GCBIG		; utilise les caractres standard	POPM.L	D0..D6,A3..A5	RET;----------\\; DBOXSAUVE >;==========/; Sauve un fichier histoire .TOTO; in	-; out	-; mod	D7.WDBOXSAUVE:	PUSHM.L	D0..D6,A3..A5	CALL	GCLITTLE	; utilise les petits caractres	CALL	NMOUSE		; souris = flche normale	CALL	SCMO		; visible10$:	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	LOAD.W	D1,#DBOX_SAUVE	LOAD.L	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A5,#(A6)+OBUFILE ; A5 <-- ^nom  diter	DBOX_	EXTEND		; demande le nom ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,EQ 15$	COMP.W	D3,#F4	JUMP,NE EXIT$15$:	LOAD.W	D1,D3		; D1 <-- F1/F4	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier20$:	LOAD.L	A3,#(A6)+OBUFILE ; A3 <-- ^nom	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier .TOTO	JUMP,EQ 25$		; ok => 25$	COMP.W	D7,#ERKSTO	; annule ?	JUMP,EQ EXIT$		; oui => EXIT$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	30$		; non => 30$				; oui =>	COMP.W	D1,#F4		; touche (MET A JOUR) ?	JUMP,EQ 22$		; oui => 22$	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	TEST.W	D7	JUMP,NE 30$	COMP.W	D3,#'O	JUMP,NE 10$22$:	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE EXIT$	JUMP	20$25$:	LOAD.L	A3,#(A6)+OBUFILE ; A3 <-- ^nom	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier .TOTO	JUMP,EQ 40$	COMP.W	D7,#ERKSTO	; annule ?	JUMP,EQ EXIT$		; oui => EXIT$30$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	LOAD.W	D3,#BIPERR	LIB	?BEEP	POP.W	D7	LOAD.W	D2,#2^BDBSAV	DBOX_	MERROR		; affiche l'erreur ...	JUMP	10$40$:	LOAD.L	A4,#(A6)+OHIST	LOAD.L	A3,A4	LOAD.L	D4,#-142$:	INC.L	D4	TEST.B	(A3+)	JUMP,NE 42$	FOS	?WRBYTE		; crit le fichier .TOTO	JUMP,EQ 50$	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier .TOTO	POP.W	D7	JUMP	30$50$:	FOS	?CLOSE		; ferme le fichier .TOTO	JUMP,NE 30$EXIT$:	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	CALL	CCMO		; invisible	CALL	LMOUSE		; souris = main	CALL	AFMENU		; refait les soft-keys	CALL	GCBIG		; utilise les caractres standard	POPM.L	D0..D6,A3..A5	RET;-------------\\; DBOXHISTOIRE >;=============/; Dbox pour choisir l'histoire.; in	-; out	D3.W	dernire touche (CR/END);	D7.W	erreur; mod	D3.L, D7.WDBOXHISTOIRE:	PUSHM.L	D0..D2,D4,D5,A1..A5	CALL	GCLITTLE	; utilise les petits caractres	CALL	NMOUSE		; souris = flche normale	CALL	SCMO		; visible	LOAD.L	A3,#(A6)+OHIST	LOAD.L	A4,#(A6)+OBUDIS10$:	LOAD.B	(A4+),(A3+)	; OBUDIS <-- histoire	JUMP,NE 10$	DEC.L	A4	LOAD.L	A3,#(A6)+OBUDIS	CLR.L	D4	LOAD.L	A2,#R16"TDBOX_HISTOIRE	LOAD.W	D2,#2^BDBSAV!2^BDBMAX	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$20$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_HISTOIRE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP,EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP,EQ 40$	COMP.W	D3,#'A	JUMP,LO 30$	COMP.W	D3,#'Z	JUMP,LS 50$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:	LOAD.L	A4,A3	CLR.B	(A3)	JUMP	20$50$:	TEST.B	(A6)+OFLAGS:#BFMAJUS	JUMP,BS 52$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule52$:	LOAD.L	A5,#(A6)+OBUDIS+100	LOAD.B	(A5),D3	CLR.B	(A5)+1	LOAD.W	D3,#36	LIB	?INSERT		; insre une lettre	JUMP	20$70$:	LOAD.L	A3,#(A6)+OHIST	LOAD.L	A4,#(A6)+OBUDIS72$:	LOAD.B	(A3+),(A4+)	; OHIST <-- histoire	JUMP,NE 72$80$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	CALL	CCMO		; invisible	CALL	LMOUSE		; souris = main	CALL	AFMENU		; refait les soft-keys	CALL	GCBIG		; utilise les caractres standard	POPM.L	D0..D2,D4,D5,A1..A5	RETTDBOX_HISTOIRE:	.W	10$-TDBOX_HISTOIRE	.W	20$-TDBOX_HISTOIRE	.W	0,010$:	.B	ODBCR	.B	ODBTABX,3	.B	ODBTEXT	.ASCIZ	" Script de l'histoire :"	.B	ODBTABX,3+26	.B	ODBLINE,36	.B	ODBTABX,3+1+62+2+3	.B	ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,'A,TDBOMBRE	.ASCIZ	" automne  "	.B	ODBBOX,0,'G,TDBOMBRE	.ASCIZ	"  galop   "	.B	ODBBOX,0,'M,TDBOMBRE	.ASCIZ	"  manger  "	.B	ODBBOX,0,'S,TDBOMBRE	.ASCIZ	"  sommet  "	.B	ODBBOX,0,'Y,TDBOMBRE	.ASCIZ	"   yeux   "	.B	ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,'B,TDBOMBRE	.ASCIZ	" bonjour  "	.B	ODBBOX,0,'H,TDBOMBRE	.ASCIZ	"  hiver   "	.B	ODBBOX,0,'N,TDBOMBRE	.ASCIZ	"   nez    "	.B	ODBBOX,0,'T,TDBOMBRE	.ASCIZ	"   trot   "	.B	ODBBOX,0,'Z,TDBOMBRE	.ASCIZ	"   zut    "	.B	ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,'C,TDBOMBRE	.ASCIZ	" chemine "	.B	ODBBOX,0,'I,TDBOMBRE	.ASCIZ	" immeuble "	.B	ODBBOX,0,'O,TDBOMBRE	.ASCIZ	" oiseaux  "	.B	ODBBOX,0,'U,TDBOMBRE	.ASCIZ	"    un    "	.B	ODBBOX,0,'-,TDBOMBRE	.ASCIZ	"          "	.B	ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,'D,TDBOMBRE	.ASCIZ	"disparatr"	.B	ODBBOX,0,'J,TDBOMBRE	.ASCIZ	"  jardin  "	.B	ODBBOX,0,'P,TDBOMBRE	.ASCIZ	"printemps "	.B	ODBBOX,0,'V,TDBOMBRE	.ASCIZ	"  vieux   "	.B	ODBBOX,0,'-,TDBOMBRE	.ASCIZ	"          "	.B	ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,'E,TDBOMBRE	.ASCIZ	"   t    "	.B	ODBBOX,0,'K,TDBOMBRE	.ASCIZ	"kangourou "	.B	ODBBOX,0,'Q,TDBOMBRE	.ASCIZ	"  queue   "	.B	ODBBOX,0,'W,TDBOMBRE	.ASCIZ	" walkman  "	.B	ODBBOX,0,'-,TDBOMBRE	.ASCIZ	"          "	.B	ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,'F,TDBOMBRE	.ASCIZ	" fatigu  "	.B	ODBBOX,0,'L,TDBOMBRE	.ASCIZ	" lumire  "	.B	ODBBOX,0,'R,TDBOMBRE	.ASCIZ	"   rve   "	.B	ODBBOX,0,'X,TDBOMBRE	.ASCIZ	"xylophone "	.B	ODBBOX,0,'-,TDBOMBRE	.ASCIZ	"          "	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,3	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	"        D'ACCORD       "	.B	ODBTEXT	.ASCIZ	"             "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"        ANNULE         "	.B	ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_HISTOIRE:	.W	F1,F2,F3,CR,0		DOKCR-TKEY_HISTOIRE	.W	F0,F13,F14,F15,END,0	DOKEND-TKEY_HISTOIRE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_HISTOIRE	.W	0;----------\\; DBOXCHOIX >;==========/; Dbox pour choisir le mode.; in	-; out	D3.W	dernire touche (CR/END);	D7.W	erreur; mod	D3.L, D7.WDBOXCHOIX:	PUSHM.L	D0..D2,D4,D5,A1..A4	CALL	GCLITTLE	; utilise les petits caractres	CALL	NMOUSE		; souris = flche normale	CALL	SCMO		; visible	CLR.L	D4	LOAD.B	D4,(A6)+OFLAGS	LOAD.L	A2,#R16"TDBOX_CHOIX	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_CHOIX	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP,EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 80$	COMP.W	D3,#KEYDBOX!BFMAJUS	JUMP,EQ 50$	COMP.W	D3,#KEYDBOX!BFMINUS	JUMP,EQ 51$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:	TSET.L	D4:#BFMAJUS	TCLR.L	D4:#BFMINUS	JUMP	20$51$:	TCLR.L	D4:#BFMAJUS	TSET.L	D4:#BFMINUS	JUMP	20$70$:	LOAD.B	(A6)+OFLAGS,D480$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	CALL	CCMO		; invisible	CALL	LMOUSE		; souris = main	CALL	AFMENU		; refait les soft-keys	CALL	GCBIG		; utilise les caractres standard	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CHOIX:	.W	10$-TDBOX_CHOIX	.W	20$-TDBOX_CHOIX	.W	0,010$:	.B	ODBLCIRCLE,BFMINUS!2^7!2^6,KEYDBOX/H'100,BFMINUS	.ASCIZ	" lettres minuscules"	.B	ODBCR	.B	ODBLCIRCLE,BFMAJUS!2^7!2^6,KEYDBOX/H'100,BFMAJUS	.ASCIZ	" lettres MAJUSCULES"	.B	ODBCR	.B	ODBCR	.B	ODBSQUARE,BFSON	.ASCIZ	" musiques et bruitages"	.B	ODBCR	.B	ODBSQUARE,BFSOURIS	.ASCIZ	" choix aussi avec la souris (main)"	.B	ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CHOIX:	.W	F1,F2,F3,CR,0		DOKCR-TKEY_CHOIX	.W	F0,F13,F14,F15,END,0	DOKEND-TKEY_CHOIX	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CHOIX	.W	0;--------\\; ZEROCR  >;--------/; Remplace le terminateur <CR> par <0>.; Utile aprs DBOX_EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ EXIT$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>EXIT$:	POP.L	A3	RET;--------\\; ERCALL  >;--------/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RETDOKCR:	LOAD.W	D3,#CR	RETDOKEND:	LOAD.W	D3,#END	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETTEXT_IO:	.ASCIZ	".TOTO"		; extensionTDBOX_IO:	.ASCIZ	"TOTO"		; nom du logiciel	.ASCIZ	"Fhistoire"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN; Processus fils; --------------NFILS1:	.ASCIZ	"TOTO_SOUND"	.EVENPFILS1:10$:	TEST.B	(A6)+OABORT	; fin ?	JUMP,T	EXIT$		; oui => EXIT$				; non =>	LOAD.W	D3,(A6)+OSOUND	JUMP,EQ 40$	CLR.W	(A6)+OSOUND	CALL	PATATRA		; fait le bruit	JUMP	10$40$:	LOAD.W	D4,#50/10	NTREL	?DELMS		; attend un peu	JUMP	10$EXIT$:	NTREL	?ABORT; Gestion des bruits; ------------------;--------\\; PATATRA >;========/; Fait un bruit rigolo !; in	D3.W	#TMUSxxx; out	-; mod	D7.WPATATRA:	PUSHM.L	D3,A4	TEST.B	(A6)+OFLAGS:#BFSON	JUMP',BC EXIT$	LOAD.L	A4,#R16"ADCODE	AND.L	D3,#H'FFFF	; ADD.W A4,D3 impossible si D3.W ngatif !	ADD.L	D3,A4	LOAD.L	A4,D3	TEST.W	(A4)	JUMP',EQ EXIT$	LIB	?PLAYEXIT$:	POPM.L	D3,A4	RET; Gestion du clavier; ------------------;--------\\; GETCAR  >;========/; Attend une action.; in	-; out	D3.W	touche presse; mod	D3.L, D7.WGETCAR:	PUSHM.L	D4,A4	TEST.B	(A6)+OPLAY	; raconte une histoire ?	JUMP,T	50$		; oui => 50$10$:	LIB	?IFCAR		; vide le fifo du clavier	JUMP,EQ 10$	CALL	SCMO		; remet la souris	LIB	?GETCAR		; attend une touche ...	JUMP	EXIT$50$:	LIB	?IFCAR		; une touche presse ?	JUMP,NE 52$	COMP.W	D3,#END	JUMP,EQ 70$	COMP.W	D3,#F7	JUMP,EQ 70$	COMP.W	D3,#F7+SHIFT	JUMP,EQ 70$	COMP.W	D3,#F8	JUMP,EQ 70$	COMP.W	D3,#F8+SHIFT	JUMP,EQ 70$	COMP.W	D3,#F9	JUMP,EQ 70$	COMP.W	D3,#F9+SHIFT	JUMP,EQ 70$	JUMP	50$52$:	LOAD.L	A4,#(A6)+OHIST	LOAD.W	D4,(A6)+OPHIST	CLR.W	D3	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- touche de l'histoire	JUMP,EQ 70$	INC.W	(A6)+OPHIST	JUMP	EXIT$70$:	CLR.B	(A6)+OPLAY	; fin de l'histoire	CALL	MAJMENU		; mj. les soft-keys	LOAD.W	(A6)+OSOUND,#TMUSDONE	JUMP	10$EXIT$:	POPM.L	D4,A4	RET;--------\\; IFCAR   >;========/; Regarde si une touche est presse.; in	-; out	D3.W	touche presse;	D7.W	erreur; mod	D3.L, D7.WIFCAR:	LOAD.W	D7,#1	TEST.B	(A6)+OPLAY	; raconte une histoire ?	JUMP',T	EXIT$		; oui => EXIT$	LIB	?IFCAR		; une touche presse ?EXIT$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; GCLITTLE >;=========/; Utilise les petits caractres.; in	-; out	-; mod	D7.WGCLITTLE:	LIB	?AFTIM	.B	USEGC		; utilise les petits caractres	.B	GCTXF	.B	GCTXS	.B	GCTXTP	.B	0	.EVEN	RET;---------\\; GCBIG    >;=========/; Utilise les grands caractres.; in	-; out	-; mod	D7.WGCBIG:	LIB	?AFTIM	.B	USEGC		; utilise les caractres standard	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	RET; Gestion de la souris; --------------------;--------\\; CCMO    >;========/; Enlve la flche de la souris.; in	-; out	-; mod	-CCMO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	POPM.L	D3,D7	RET;--------\\; SCMO    >;========/; Remet la flche de la souris.; in	-; out	-; mod	-SCMO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	POPM.L	D3,D7	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE EXIT$	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D4EXIT$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; LMOUSE  >;========/; Souris = main.; in	-; out	-; mod	D7.WLMOUSE:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#(A6)+OBULUT	LOAD.B	(A3+),#58	; dx	LOAD.B	(A3+),#32	; dy	LOAD.L	A4,(A6)+OPGICO	; A4 <-- ^gencar chair	LOAD.L	A4,#(A4)+OGCMAT	; A4 <-- ^matrice icne zro	LOAD.W	D3,#32-120$:	LOAD.L	(A3+),(A4+)	LOAD.L	(A3+),(A4+)	ADD.L	A4,#2	DECJ.W,NMO D3,20$	LOAD.L	A3,#(A6)+OBULUT+500	LOAD.B	(A3+),#58	; dx	LOAD.B	(A3+),#32	; dy	LOAD.L	A4,(A6)+OPFICO	; A4 <-- ^gencar fond	LOAD.L	A4,#(A4)+OGCMAT	; A4 <-- ^matrice icne zro	LOAD.W	D3,#32-130$:	LOAD.L	(A3+),(A4+)	LOAD.L	(A3+),(A4+)	ADD.L	A4,#2	DECJ.W,NMO D3,30$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	LOAD.L	A4,#(A6)+OBULUT	LOAD.L	(A3)+1,A4	LOAD.L	A4,#(A6)+OBULUT+500	LOAD.L	(A3)+5,A4	LOAD.W	D3,#9	LIB	?STRING	POPM.L	D3,D4,A3,A4	RET;--------\\; NMOUSE  >;========/; Souris = flche normale.; in	-; out	-; mod	D7.WNMOUSE:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	CLR.L	(A3)+1	CLR.L	(A3)+5	LOAD.W	D3,#9	LIB	?STRING	POPM.L	D3,A3	RET;--------\\; MMOUSE  >;========/; Met la souris au milieu de la fentre.; in	-; out	-; mod	D7.WMMOUSE:	PUSH.L	D4	LOAD.W	D4,#PTEXTY	ADD.W	D4,(A6)+OOIMA+0	SWAP.W	D4	LOAD.W	D4,#PTEXTX+LTEXTX	ADD.W	D4,(A6)+OOIMA+2	LIB	?PMOUSE	POP.L	D4	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	-; out	-; mod	-AFMENU:	LOAD.W	(A6)+OOMENU,#-1;	JUMP	MAJMENU;--------\\; MAJMENU >;========/; Met  jour les soft-keys.; in	-; out	-; mod	-MAJMENU:	PUSHM.L	D3,D4,D7,A3,A4	CLR.L	D4	TEST.B	(A6)+OHIST	; histoire existe ?	JUMP,NE 10$		; oui => 10$	TSET.L	D4:#BMNNOHIS10$:	TEST.B	(A6)+OPLAY	; raconte une histoire ?	JUMP,F	12$		; non => 12$	TSET.L	D4:#BMNRACON12$:	COMP.W	D4,(A6)+OOMENU	; qq chose de chang ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.L	A3,#R16"TXMENUR	TEST.L	D4:#BMNRACON	JUMP,BS 60$	LOAD.L	A3,#R16"TXMENU	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D3,#PTXM-120$:	LOAD.B	(A4+),(A3+)	; OBUDIS <-- .ASCIZ des soft-keys	DECJ.W,NMO D3,20$	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^menu dans les variables	TEST.L	D4:#BMNNOHIS	JUMP,BC 60$	LOAD.B	(A3)+PTXMSA,#AFGREY	LOAD.B	(A3)+PTXMRA,#AFGREY60$:	LIB	?AFMENU		; affiche les soft-keys	LOAD.W	(A6)+OOMENU,D4EXIT$:	POPM.L	D3,D4,D7,A3,A4	RETTXMENU:	.ASCIZ	"Fin"	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCII	"Prend       "PTXMSA	= .-TXMENU	.ASCIZ	"<AFFULL>Sauve<AFFULL>"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"     Histoire    "		;     ;     ;     ;	.ASCIZ	""PTXMRA	= .-TXMENU	.ASCIZ	"<AFFULL>     Raconte     <AFFULL>"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	"      Liste Choix"	.ASCIZ	""		;     ;     ;     ;PTXM	= .-TXMENUTXMENUR:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"  <'>><'>><'>> Arrt <'<><'<><'<>  "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN; Routines de construction d'icnes "fond"; ----------------------------------------;---------\\; CALCFOND >;=========/; Fait un double de ITP82 (chair) pour gnrer les fonds.; in	-; out	D7.W	erreur; mod	D7.WCALCFOND:	PUSHM.L	D1..D4,A3,A4	LOAD.L	A3,(A6)+OPGICO	; A3 <-- ^gencar ITP82	LOAD.W	D4,#NBPCAR	MUL.WU	D4,(A3)+OGCMSB	ADD.L	D4,#OGCMAT	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour copie ITP82	JUMP,NE EXIT$	LOAD.L	(A6)+OPFICO,A4	; OPFICO <-- ^gencar "fond"	SR.L	D4,#2	DEC.W	D420$:	LOAD.L	(A4+),(A3+)	DECJ.W,NMO D4,20$	CALL	OPEDISMAT	; dessin en mmoire	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	DRTRADEF	LOAD.B	D3,#AFFILLA	; rempli tout	LIB	?AFCAR	LOAD.L	A4,(A6)+OPFICO	; A4 <-- ^gencar fond	LOAD.W	D4,(A4)+OGCMHD	; D4 <-- hauteur en points	SWAP.W	D4	CLR.W	D4	LOAD.B	D4,(A4)+OGCMWB	; D4 <-- largeur en bytes	SL.W	D4,#3		; D4 <-- largeur en points	LOAD.W	D3,(A4)+OGCMSB	; D3 <-- taille d'une matrice	ADD.L	A4,#OGCMAT	; A4 <-- ^premire matrice	LOAD.W	D2,#NBPCAR-140$:	CALL	CALCFONDONE	; calcule une matrice	ADD.W	A4,D3		; A4 <-- ^matrice suivante	DECJ.W,NMO D2,40$	CALL	CLODISMAT	; dessin dans l'cran	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; CALCFONDONE >;------------/; ; in	A4.L	^matrice;	D4.L	^dimensions (dy;dx); out	-; mod	D7.WCALCFONDONE:	PUSHM.L	D3,D4	CALL	NEWDISMAT	CLR.L	D3	CALL	DRFILL		; rempli	CALL	DRINV		; puis inverse	POPM.L	D3,D4	RET.IF 0;--------\\; INVGENC >;========/; Inverse toutes les matrices d'un gencar.; in	A4.L	^gencar; out	-; mod	D7.WINVGENC:	PUSHM.L	D3,D4,A4	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP,T	EXIT$		; oui => EXIT$	CLR.W	D3	LOAD.B	D3,(A4)+OGCLCA	SUB.B	D3,(A4)+OGCFCA	INC.B	D3		; D3 <-- nb de caractres	LOAD.W	D4,(A4)+OGCMSB	; D4 <-- taille d'une matrice	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- saute l'en-tte	ADD.W	A4,D3		; A4 <-- saute table des largeurs	ADD.W	A4,D3		; A4 <-- saute table des h1	ADD.W	A4,D3		; A4 <-- saute table des h2	MUL.WU	D4,D3	SR.L	D4,#2		; D4 <-- /4 car .L	DEC.W	D4		; D4 <-- -1 car NMO30$:	NOT.L	(A4+)	DECJ.W,NMO D4,30$EXIT$:	POPM.L	D3,D4,A4	RET.ENDIF; Routines graphiques rapides; ---------------------------;----------\\; OPEDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	-; out	-; mod	D7.WOPEDISMAT:	LOAD.L	(A6)+OSDDIS+ODFABS,(A0)+ODFABS	LOAD.W	(A6)+OSDDIS+ODFIIX,(A0)+ODFIIX	LOAD.W	(A6)+OSDDIS+ODFIIY,(A0)+ODFIIY	LOAD.L	(A6)+OSDDIS+ODFY,(A0)+ODFY	LOAD.L	(A6)+OSDDIS+ODFDY,(A0)+ODFDY	LOAD.L	(A6)+OSDDIS+ODFFY,(A0)+ODFFY	LOAD.L	(A6)+OSDDIS+ODFFDY,(A0)+ODFFDY	LOAD.L	(A6)+OSDDIS+ODFWBY,(A0)+ODFWBY	LOAD.L	(A6)+OSDDIS+ODFWEY,(A0)+ODFWEY	LOAD.B	(A6)+OSDDIS+ODFCMD,(A0)+ODFCMD	RET;----------\\; NEWDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	A4.L	^matrice o dessiner;	D4.L	^dimensions (dy;dx); out	-; mod	D7.WNEWDISMAT:	PUSH.L	D4	LOAD.L	(A0)+ODFABS,A4	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	LOAD.W	(A0)+ODFIIX,#1	SR.W	D4,#3	LOAD.W	(A0)+ODFIIY,D4	POP.L	D4	RET;----------\\; CLODISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.WCLODISMAT:	LOAD.L	(A0)+ODFABS,(A6)+OSDDIS+ODFABS	LOAD.W	(A0)+ODFIIX,(A6)+OSDDIS+ODFIIX	LOAD.W	(A0)+ODFIIY,(A6)+OSDDIS+ODFIIY	LOAD.L	(A0)+ODFY,(A6)+OSDDIS+ODFY	LOAD.L	(A0)+ODFDY,(A6)+OSDDIS+ODFDY	LOAD.L	(A0)+ODFFY,(A6)+OSDDIS+ODFFY	LOAD.L	(A0)+ODFFDY,(A6)+OSDDIS+ODFFDY	LOAD.L	(A0)+ODFWBY,(A6)+OSDDIS+ODFWBY	LOAD.L	(A0)+ODFWEY,(A6)+OSDDIS+ODFWEY	LOAD.B	(A0)+ODFCMD,(A6)+OSDDIS+ODFCMD	RET;----------\\; MOVEOBJET >;==========/; Dplace un objet sur l'cran.; in	A5.L	^objet; out	D7.W	erreur; mod	D7.WMOVEOBJET:	PUSHM.L	D2..D4,A3,A402$:	LOAD.L	A4,(A5)+OOMPTA	COMP.W	(A4),#TMBEGIN	JUMP',NE 04$	ADD.L	A4,#2	LOAD.L	(A5)+OOLPOS,(A4+)	LOAD.W	(A5)+OOMDEL,(A4+)	LOAD.L	(A5)+OOMPTA,A4	CLR.W	(A5)+OOMCTN04$:	COMP.W	(A4),#TMBEGINX	JUMP',NE 05$	ADD.L	A4,#2	LOAD.W	(A5)+OOMDEL,(A4+)	LOAD.L	(A5)+OOMPTA,A4	CLR.W	(A5)+OOMCTN05$:	TEST.W	(A5)+OOMCTN	JUMP,NE 20$; Cherche l'lment suivant dans la table.10$:	LOAD.L	A4,(A5)+OOMPTA	LOAD.W	D7,#EROUTF	TEST.W	(A4)		; fin de la table ?	JUMP,EQ EXIT$		; oui => EXIT$	COMP.W	(A4),#TMLINK	JUMP,NE 12$	CALL	GETADCODE	; LOAD.L A3,#R16"ADCODE	ADD.W	A3,(A4)+2	LOAD.L	(A5)+OOMPTA,A3	JUMP	02$12$:	CALL	MOVETM		; objet spcial TMxxxx ?	JUMP,NE 14$		; non => 14$	LOAD.L	(A5)+OOMPTA,A4	JUMP	10$14$:	LOAD.L	(A5)+OOMPTB,A4	LOAD.W	(A5)+OOMCTN,(A4+)	ADD.L	A4,#4	LOAD.W	(A5)+OOMNBI,#-118$:	INC.W	(A5)+OOMNBI	TEST.W	(A4+)	JUMP,NE 18$	CLR.W	(A5)+OOMCTI	LOAD.L	(A5)+OOMPTA,A4; Cherche la nouvelle position et la nouvelle icne.20$:	LOAD.L	A4,(A5)+OOMPTB	; A4 <-- ^lment prcdent	DEC.W	(A5)+OOMCTN	LOAD.W	D4,(A5)+OOLPOS+0	ADD.W	D4,(A4)+2	LOAD.W	(A5)+OONPOS+0,D4	LOAD.W	D4,(A5)+OOLPOS+2	ADD.W	D4,(A4)+4	LOAD.W	(A5)+OONPOS+2,D4	TEST.W	(A5)+OOMNBI	JUMP,EQ 50$	LOAD.W	D3,(A5)+OOMCTI	SL.W	D3,#1	LOAD.W	(A5)+OOICON,(A4)+(D3.W)+6	SR.W	D3,#1	INC.W	D3	COMP.W	D3,(A5)+OOMNBI	JUMP,LO 22$	CLR.W	D322$:	LOAD.W	(A5)+OOMCTI,D3; Fait ventuellement un bruit.	LOAD.L	A4,#R16"TICOSOUND ; A4 <-- ^table des icnes-sons	LOAD.W	D4,(A5)+OOICON	AND.W	D4,#H'7F	SL.W	D4,#1	LOAD.W	D4,(A4)+(D4.W)	; D4 <-- son associ  l'icne	JUMP,EQ 28$	LOAD.W	(A6)+OSOUND,D4; Bouge l'objet sur l'cran.28$:	LOAD.W	D3,(A5)+OONPOS+0	LOAD.W	D4,(A5)+OOLPOS+0	COMP.W	D3,D4	JUMP,LE 30$	EX.L	D3,D4		; EX.W D3,D430$:	ADD.W	D4,(A6)+OISDY	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A5)+OONPOS+2	LOAD.W	D4,(A5)+OOLPOS+2	COMP.W	D3,D4	JUMP,LE 35$	LOAD.W	D2,D3	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D235$:	ADD.W	D4,(A6)+OISDX	SUB.W	D4,D3	LOAD.L	A3,(A6)+OPIDESS	LOAD.L	A4,(A6)+OPITEMP	LOAD.W	D2,#LOADDOT	CALL	XFERZONE	; OPITEMP <-- remet image originale	PUSHM.L	D3,D4	LOAD.L	D4,(A5)+OONPOS	; D4 <-- nouvelle position	LOAD.W	D3,(A5)+OOICON	; D3 <-- icne	CALL	DROBJET		; dessine l'objet	TEST.B	(A6)+OPLAN	; dessine devant ?	JUMP,NE 40$		; oui => 40$	LOAD.L	D3,(A5)+OONPOS	LOAD.L	D4,(A6)+OISDY;;?	LOAD.L	A3,(A6)+OPI;;?	LOAD.L	A4,(A6)+OPITEMP;;?	LOAD.W	D2,#CLRDOT;;?	CALL	XFERZONE	; OPITEMP <-- masque selon le fond;;?	LOAD.L	A3,(A6)+OPI;;?	LOAD.L	A4,(A6)+OPITEMP;;?	LOAD.W	D2,#SETDOT;;?	CALL	XFERZONE	; OPITEMP <-- masque selon la chair40$:	POPM.L	D3,D4	LOAD.W	D2,(A6)+OIIMAX	JUMP,EQ 42$	ADD.W	(A6)+OPIMAX,D2	CLR.L	D3	LOAD.W	D3,(A6)+OPIMAX	LOAD.L	D4,#H'10000*LYWDO+LXWDO42$:	LOAD.L	A3,(A6)+OPITEMP	LOAD.L	A4,#0	LOAD.W	D2,#LOADDOT	CALL	XFERZONE	; met  jour l'cran	CALL	MMOUSE		; remet la souris au milieu de la fentre	TEST.B	(A6)+OQUICK	;  toute vitesse ?	JUMP,T	50$		; oui => 50$	LOAD.W	D4,(A5)+OOMDEL	JUMP,EQ 50$	NTREL	?DELMS		; attend un peu50$:	LOAD.L	(A5)+OOLPOS,(A5)+OONPOS80$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RETTICOSOUND:	.W	0		; 0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 8	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 16	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 24	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 32	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	TMUSTAC		; 40	.W	0	.W	0	.W	0	.W	TMUSTIC	.W	0	.W	0	.W	0	.W	0		; 48	.W	0	.W	TMUSTAC	.W	0	.W	0	.W	0	.W	TMUSPOUSSE1	.W	TMUSPOUSSE2	.W	TMUSPOUSSE3	; 56	.W	TMUSPOUSSE4	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 64	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 72	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 80	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 88	.W	0	.W	0	.W	0	.W	0	.W	0	.W	TMUSFADA1	; s'est cass la figure	.W	TMUSFADA2	; s'est cass la figure	.W	0		; 96	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 104	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0		; 112	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0	.W	0;--------\\; MOVETM  >;--------/; Traite les objet spciaux TMxxx contenus dans la table.; in	A4.L	^dans table; out	A4.L	^plus loin;	D7.W	erreur; mod	D7.W, A4.LMOVETM:	PUSHM.L	D2..D4,A3	LOAD.W	D7,#1		; D7 <-- pas un objet TMxxxx	TEST.W	(A4)	JUMP,NC EXIT$	LOAD.W	D4,(A4+)	; D4 <-- objet TMxxxx	COMP.W	D4,#TMPLAN	JUMP,EQ PLAN$	COMP.W	D4,#TMFLASH	JUMP,EQ FLASH$	COMP.W	D4,#TMDEL	JUMP,EQ DEL$	COMP.W	D4,#TMSOUND	JUMP,EQ SOUND$	COMP.W	D4,#TMANALOG	JUMP,EQ ANALOG$	COMP.W	D4,#TMTEXT	JUMP,EQ TEXT$	COMP.W	D4,#TMSKIPNE	JUMP,EQ SKIPNE$	COMP.W	D4,#TMSKIPEQ	JUMP,EQ SKIPEQ$	COMP.W	D4,#TMICOOB	JUMP,EQ ICOOB$	COMP.W	D4,#TMROLL	JUMP,EQ ROLL$	COMP.W	D4,#TMIMAGE	JUMP,EQ IMAGE$	COMP.W	D4,#TMMASK	JUMP,EQ MASK$	JUMP	EXIT$PLAN$:	LOAD.W	D4,(A4+)	LOAD.B	(A6)+OPLAN,D4	JUMP	OK$FLASH$:	CLR.L	D3	LOAD.L	D4,#H'10000*LYWDO+LXWDO	CALL	DRINV		; inverse tout l'cran	LOAD.W	D4,(A4+)	NTREL	?DELMS		; attente selon t1	CLR.L	D3	LOAD.L	D4,#H'10000*LYWDO+LXWDO	CALL	DRINV		; inverse tout l'cran	LOAD.W	D4,(A4+)	NTREL	?DELMS		; attente selon t2	JUMP	OK$DEL$:	LOAD.W	(A5)+OOMDEL,(A4+)	JUMP	OK$SOUND$:	LOAD.W	(A6)+OSOUND,(A4+)	JUMP	OK$ANALOG$:	LOAD.W	D4,(A4+)	LOAD.W	D3,(A4+)	CALL	ANALOG	JUMP	OK$TEXT$:	LOAD.L	A3,A4		; A3 <-- ^texte .ASCIZ	CALL	AFTEXT		; affiche texte en bas  gaucheTEXT2$:	TEST.B	(A4+)		; A4 <-- saute .ASCIZ	JUMP,NE TEXT2$	LOAD.L	D4,A4	TEST.L	D4:#0	JUMP,BC OK$	INC.L	A4		; A4 <-- saute .EVEN	JUMP	OK$SKIPNE$:	ADD.L	A4,#+8		; A4 <-- saute SKIPNE et paramtres	LOAD.L	A3,A6	ADD.W	A3,(A4)-8+0	; A3 <-- ^variable	LOAD.W	D3,(A3)		; D3 <-- valeur variable	COMP.W	D3,(A4)-8+2	; effectue le test	JUMP,LO SKIP$	COMP.W	D3,(A4)-8+4	; effectue le test	JUMP,HI SKIP$	JUMP	OK$SKIPEQ$:	ADD.L	A4,#+8		; A4 <-- saute SKIPEQ et paramtres	LOAD.L	A3,A6	ADD.W	A3,(A4)-8+0	; A3 <-- ^variable	LOAD.W	D3,(A3)		; D3 <-- valeur variable	COMP.W	D3,(A4)-8+2	; effectue le test	JUMP,LO OK$	COMP.W	D3,(A4)-8+4	; effectue le test	JUMP,HI OK$SKIP$:	CALL	GETADCODE	; LOAD.L A3,#R16"ADCODE	ADD.W	A3,(A4)-8+6	; A4 <-- adresse absolue si NE	LOAD.L	A4,A3	JUMP	OK$ICOOB$:	LOAD.L	D3,(A4+)	LOAD.L	D4,(A4+)	CALL	ICOOBJET	; prend un objet	JUMP	OK$ROLL$:	LOAD.W	(A6)+OIIMAX,(A4+)	JUMP	OK$IMAGE$:	LOAD.L	(A6)+OISDY,(A4+)	JUMP	OK$MASK$:	LOAD.L	(A6)+OIMPOS,(A4+)	LOAD.W	(A6)+OIMCAR,(A4+);	JUMP	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; XFERZONE >;---------/; Transfert une partie d'image dans une autre.; in	A3.L	^image source;	A4.L	^image destination;	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WXFERZONE:	PUSHM.L	D1..D6	LOAD.L	D1,D4	LOAD.L	D4,D3	COMP.L	A3,#0		; source dans l'cran ?	JUMP',NE 10$		; non => 10$				; oui =>	SUB.W	D3,(A6)+OPIMAX10$:	COMP.L	A4,#0		; destination dans l'cran ?	JUMP',NE 20$		; non => 20$				; oui =>	SUB.W	D4,(A6)+OPIMAX20$:	LOAD.W	D5,(A6)+ODIMA+2	SR.W	D5,#3	LOAD.W	D6,D5	OR.W	D2,#2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	POPM.L	D1..D6	RET;--------\\; DROBJET >;========/; Dessine un objet (icne chair et fond) dans l'image cache (OPITEMP).; in	D3.W	code de l'icne (0..127);	D4.L	position coin sup/gauche (y;x); out	-; mod	D7.WDROBJET:	PUSHM.L	D2..D4	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP',F	50$		; non => 50$	TSET.L	D3:#BICOMASK	LOAD.W	D2,#CLRDOT	CALL	DRICONE		; efface le fond	TCLR.L	D3:#BICOMASK	LOAD.W	D2,#SETDOT	CALL	DRICONE		; dessine la chair	JUMP'	EXIT$50$:	TSET.L	D3:#BICOMASK	LOAD.W	D2,#SETDOT	CALL	DRICONE		; efface le fond	TCLR.L	D3:#BICOMASK	LOAD.W	D2,#CLRDOT	CALL	DRICONE		; dessine la chairEXIT$:	POPM.L	D2..D4	RET;--------\\; DRICONE >;========/; Dessine une icne de chair ou de fond; dans l'image cache (OPITEMP).; in	D3.W	code de l'icne (0..127);	D4.L	position coin sup/gauche (y;x);	D2.W	mode; out	-; mod	D7.WDRICONE:	COMP.L	(A6)+OISDY,#H'10000*LYICO+LXICO ; image spciale ?	JUMP,NE DRIMAGE		; oui => DRIMAGE	PUSHM.L	D0..D6,A3,A4	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.W	D0,D3	TEST.L	D3:#BICOSYMB	JUMP',BC 10$	COMP.W	D2,#SETDOT	JUMP,NE EXIT$	LOAD.L	A4,(A6)+OPSICO	; A4 <-- ^gencar symboles	AND.W	D3,#H'7F	CALL	SRCPTGC		; A3/D3/D5/D1 <-- ^matrice/pos/Iy/dim	LOAD.W	D2,#LOADDOT	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP,T	30$		; oui => 30$	LOAD.W	D2,#LOADDOT!CPLDOT	JUMP	30$10$:	LOAD.L	A4,(A6)+OPGICO	; A4 <-- ^gencar chair	AND.W	D3,#H'FF	TCLR.L	D3:#BICOMASK	JUMP',BC 20$	LOAD.L	A4,#R16"TCOLOR$	LOAD.B	(A0)+ODFCCF+3,(A4)+(D3.W)	LOAD.L	A4,(A6)+OPFICO	; A4 <-- ^gencar fond20$:	CALL	SRCPTGC		; A3/D3/D5/D1 <-- ^matrice/pos/Iy/dim	TEST.W	(A6)+OIMCAR	; y a-t-il une icne de masque ?	JUMP,EQ 30$		; non => 30$	LOAD.L	D6,D4	SUB.W	D6,(A6)+OIMPOS+2	JUMP',NC 22$	NEG.W	D622$:	COMP.W	D6,#LXICO	JUMP,HS 30$	SWAP.W	D6	SUB.W	D6,(A6)+OIMPOS+0	JUMP',NC 23$	NEG.W	D623$:	COMP.W	D6,#LYICO	JUMP,HS 30$	PUSH.L	A4	LOAD.L	A4,#(A6)+OIMMAT	LOAD.W	D6,#(((LXICO*LYICO)/8)/32)-125$:	LOAD.L	(A4+),(A3+)	; OIMMAT <-- matrice de l'icne	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	DECJ.W,NMO D6,25$	POP.L	A4	PUSHM.L	D1..D4	LOAD.L	A4,(A6)+OPSICO	; A4 <-- ^gencar symbole	LOAD.W	D3,(A6)+OIMCAR	; D3 <-- code de l'icne de masque	CALL	SRCPTGC		; A3/D3/D5/D1 <-- ^matrice/pos/Iy/dim	LOAD.L	D3,(A6)+OIMPOS	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LOAD.L	D4,D3	CLR.L	D3	LOAD.L	A4,#(A6)+OIMMAT	; A4 <-- ^destination	LOAD.W	D6,D5	LOAD.W	D2,#CLRDOT	PUSH.L	(A6)+ODIMA	LOAD.L	(A6)+ODIMA,D1	CALL	DRRASTER	; masque l'icne dans OIMMAT	POP.L	(A6)+ODIMA	LOAD.L	A3,A4		; A3 <-- ^matrice masque	POPM.L	D1..D430$:	LOAD.L	A4,(A6)+OPITEMP	; A4 <-- ^destination	LOAD.W	D6,(A6)+ODIMA+2	SR.W	D6,#3		; D6 <-- Iy destination	TEST.L	D0:#BICODEMIH	JUMP',BC 40$	SWAP.W	D1	SUB.W	D1,#LYICO/2	SWAP.W	D1	SWAP.W	D4	ADD.W	D4,#LYICO/2	SWAP.W	D440$:	TEST.L	D0:#BICODEMIB	JUMP',BC 42$	SWAP.W	D1	SUB.W	D1,#(LYICO/2)+1	SWAP.W	D1	SWAP.W	D3	ADD.W	D3,#(LYICO/2)+1	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,#(LYICO/2)+1	SWAP.W	D442$:	OR.W	D2,#2^BDSTCOUL	CALL	DRRASTER	; dessine l'icneEXIT$:	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D0..D6,A3,A4	RETTCOLOR$:	.B	COLOR_JAUNE	; 0	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	; 16	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_ROUGE	; voiture ->	.B	COLOR_CYAN	; voiture <-	.B	COLOR_ROUGE	; =E	.B	COLOR_ROUGE	; =A	.B	COLOR_ROUGE	; =H	.B	COLOR_ROUGE	; =P	.B	COLOR_JAUNE	; 32	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	; 48	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	; plante..	.B	COLOR_VERT	.B	COLOR_VERTF	.B	COLOR_ROUGE	; ..plante	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_ROUGE	; sur le nez	.B	COLOR_JAUNE	.B	COLOR_CYAN	; 64	.B	COLOR_CYAN	.B	COLOR_CYAN	.B	COLOR_CYAN	; ..avec une queue	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_ROUGE	; le nez clate	.B	COLOR_ROUGE	.B	COLOR_JAUNE	.B	COLOR_ROUGE	; coup de baguette magique	.B	COLOR_JAUNE	; 80	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_ROUGE	; tombe avec le ballon	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_JAUNE	.B	COLOR_ROUGE	; voit les toiles	.B	COLOR_VERT	.EVEN;--------\\; SRCPTGC >;--------/; Cherche le pointeur  une icne.; in	A4.L	^gencar;	D3.W	code de l'icne; out	A3.L	^matrice;	D3.L	origine (y;x);	D5.W	Iy;	D1.L	dimensions (dy;dx); mod	D1.L, D3.L, D5.L, D7.W, A3.LSRCPTGC:	LOAD.W	D1,(A4)+OGCMHD	; D1 <-- hauteur en points	SWAP.W	D1	CLR.W	D1	LOAD.B	D1,(A4)+OGCMWB	; D1 <-- largeur en bytes	SL.W	D1,#3		; D1 <-- largeur en points	LOAD.L	A3,#(A4)+256	; A3 <-- ^table des largeurs	CLR.W	D5	LOAD.B	D5,(A4)+OGCLCA	SUB.B	D5,(A4)+OGCFCA	INC.B	D5		; D5 <-- nb de caractres	ADD.W	A3,D5		; A3 <-- ^table des h1	ADD.W	A3,D5		; A3 <-- ^table des h2	ADD.W	A3,D5		; A3 <-- ^premire matrice	MUL.WU	D3,(A4)+OGCMSB	ADD.L	A3,D3		; A3 <-- ^la bonne matrice	CLR.L	D3		; D3 <-- origine source	CLR.W	D5	LOAD.B	D5,(A4)+OGCMWB	; D5 <-- Iy source	RET;--------\\; DRIMAGE >;========/; Dessine une image spciale de chair ou de fond; dans l'image cache (OPITEMP).; in	D3.W	numro de l'image (1..127);	D4.L	position coin sup/gauche (y;x);	D2.W	mode; out	-; mod	D7.WDRIMAGE:	PUSHM.L	D0..D6,A3,A4	LOAD.L	A3,(A6)+OPISPEC	; A3 <-- ^image spciale (source)	LOAD.W	D6,D3	AND.W	D3,#H'007F	DEC.W	D3	MUL.WU	D3,(A6)+OISDX	INC.W	D3	SWAP.W	D3	LOAD.W	D3,#1	TEST.L	D6:#BICOMASK	JUMP',BC 20$	ADD.W	D3,(A6)+OISDY20$:	SWAP.W	D3	LOAD.W	D5,(A6)+ODISPEC+2	SR.W	D5,#3		; D5 <-- Iy source	LOAD.L	A4,(A6)+OPITEMP	; A4 <-- ^image temporaire (destination)	LOAD.W	D6,(A6)+ODIMA+2	SR.W	D6,#3		; D6 <-- Iy destination	LOAD.L	D1,(A6)+OISDY	; D1 <-- dimensions	DEC.W	D1	SWAP.W	D1	DEC.W	D1	SWAP.W	D1	OR.W	D2,#2^BDSTCOUL	CALL	DRRASTER	; dessine l'icne	POPM.L	D0..D6,A3,A4	RET;--------\\; DRRECT  >;========/; Dessine un rectangle.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRRECT:	PUSHM.L	D3..D5	LOAD.L	D5,D4		; D5 <-- dimensions (dy;dx)	AND.L	D4,#H'FFFF	CALL	DRLINE		; trace ligne suprieure	LOAD.L	D4,D5	CLR.W	D4	CALL	DRLINE		; trace ligne de droite	LOAD.L	D4,D5	AND.L	D4,#H'FFFF	NEG.W	D4	CALL	DRLINE		; trace ligne infrieure	LOAD.L	D4,D5	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DRLINE		; trace ligne de gauche	POPM.L	D3..D5	RET;---------\\; DRRASTER >;=========/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D1.L	hauteur/largeur (y;x);	D2.W	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT); out	-; mod	D7.WDRRASTER:	PUSHM.L	D0..D6,A1,A2	TEST.W	D1		; dx <= 0 ?	JUMP,LE EXIT$	SWAP.W	D1	TEST.W	D1		; dy <= 0 ?	JUMP,LE EXIT$	SWAP.W	D1	EX.L	D1,D2		; D2/D1 <-- mode/dimensions	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	TEST.W	D4		; dpasse  gauche ?	JUMP',NC NoLeft$	ADD.W	D2,D4	JUMP,LE EXIT$	SUB.W	D3,D4	CLR.W	D4NoLeft$:	LOAD.W	D0,D4	ADD.W	D0,D2	SUB.W	D0,(A6)+ODIMA+2	; dpasse  droite ?	JUMP',LS NoRight$	SUB.W	D2,D0	JUMP,LE EXIT$NoRight$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	TEST.W	D4		; dpasse en haut ?	JUMP',NC NoUp$	ADD.W	D2,D4	JUMP,LE EXIT$	SUB.W	D3,D4	CLR.W	D4NoUp$:	LOAD.W	D0,D4	ADD.W	D0,D2	SUB.W	D0,(A6)+ODIMA+0	; dpasse en bas ?	JUMP',LS NoDown$	SUB.W	D2,D0	JUMP,LE EXIT$NoDown$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COLOR$		; oui => COLOR$	LOAD.L	A1,(A6)+OADRASTER	CALL	(A1)		; appel de GRA_RASTER	JUMP'	EXIT$COLOR$:	CLR.W	D0	LOAD.B	D0,(A0)+ODFCNP	; D0 <-- nb de bits/pixel	TEST.L	D1:#BSRCCOUL	JUMP',BC CSRC$	MUL.WU	D5,D0		; D5 <-- Iy couleurCSRC$:	TEST.L	D1:#BDSTCOUL	JUMP',BC CDST$	MUL.WU	D6,D0		; D6 <-- Iy couleurCDST$:	LOAD.L	A1,(A6)+OADCRASTER	CALL	(A1)		; appel de GRA_CRASTEREXIT$:	POPM.L	D0..D6,A1,A2	RET;-------\\; DRDOT  >;=======/; Dessine un point.; in	D3.L	coordonne (y;x);	D2.W	mode; out	-; mod	D7.WDRDOT:	PUSHM.L	D1..D4,A1,A2	LOAD.W	D1,D2		; D1 <-- mode	LOAD.L	D4,D3		; D4 <-- y;x	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADDOT	CALL	(A1)		; appel de GRA_DOT	POPM.L	D1..D4,A1,A2	RET;--------\\; DRLINE  >;========/; Dessine un segment de droite.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	D3.L	coordonne d'arrive (y;x); mod	D3.L, D7.WDRLINE:	PUSHM.L	D1,D2,D4,A1,A2	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADLINE	CALL	(A1)		; appel de GRA_LINE	EX.L	D3,D4	ADD.W	D3,D4		; D3 <-- arrive en X	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- arrive en Y	SWAP.W	D3;	SWAP.W	D4	POPM.L	D1,D2,D4,A1,A2	RET;----------\\; DRELLIPSE >;==========/; Dessine une ellipse, ou un arc d'ellipse.; in	D3.L	coordonne centre (y;x);	D4.L	rayons (dy;dx);	D2.W	mode;	D1.B	bitmap des octants  dessiner; out	-; mod	D7.WDRELLIPSE:	PUSHM.L	D1..D4,A1,A2	EX.L	D1,D2		; D2/D1 <-- mode/octants	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADELLIPSE	CALL	(A1)		; appel de GRA_ELLIPSE	POPM.L	D1..D4,A1,A2	RET;---------\\; DRTRADEF >;=========/; Dfinit une trame.; in	D3.L	trame;	D4.L	trame; out	-; mod	D7.WDRTRADEF:	LOAD.L	(A0)+ODFTRA+0,D3	LOAD.L	(A0)+ODFTRA+4,D4	RET;---------\\; DRTRAME  >;=========/; Dessine une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRTRAME:	PUSHM.L	D1..D4,A1,A2,A4	TEST.W	D4		; dx <= 0 ?	JUMP',LE EXIT$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE EXIT$	SWAP.W	D4	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A4,#(A0)+ODFTRA	; A4 <-- ^trame utilisateur	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADTRAME	CALL	(A1)		; appel de GRA_TRAMEEXIT$:	POPM.L	D1..D4,A1,A2,A4	RET;--------\\; DRZONE  >;========/; Efface, allume ou inverse une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRZONE:	COMP.B	D2,#INVDOT	JUMP,EQ DRINV	COMP.B	D2,#SETDOT	JUMP,EQ DRSET;---------\\; DRCLEAR  >;=========/; Efface une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRCLEAR:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE EXIT$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE EXIT$	SWAP.W	D4	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADCLEAR	CALL	(A1)		; appel de GRA_SETEXIT$:	POPM.L	D1..D4,A1,A2	RET;---------\\; DRSET    >;=========/; Allume une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRSET:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE EXIT$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE EXIT$	SWAP.W	D4	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADSET	CALL	(A1)		; appel de GRA_SETEXIT$:	POPM.L	D1..D4,A1,A2	RET;---------\\; DRINV    >;=========/; Inverse une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRINV:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE EXIT$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE EXIT$	SWAP.W	D4	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADINV	CALL	(A1)		; appel de GRA_INVEXIT$:	POPM.L	D1..D4,A1,A2	RET;--------\\; DRFILL  >;========/; Rempli une surface quelconque.; in	D3.L	point de remplissage (y;x); out	D7.W	erreur; mod	D7.WDRFILL:	PUSHM.L	D1..D4,A1,A2	LOAD.L	D4,D3		; D4 <-- y;x	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADFILLO	CALL	(A1)		; appel de GRA_FILLO	PUSH.W	D7	LOAD.L	A1,(A6)+OADFILLC	CALL	(A1)		; appel de GRA_FILLC	POP.W	D7	POPM.L	D1..D4,A1,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; AFIMAGE >;========/; Affiche une image, sans la conserver en mmoire.; in	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WAFIMAGE:	PUSHM.L	D2..D5,A3,A4	CALL	LOADIMAGE	; A4.L	^image code	JUMP',NE EXIT$	LOAD.L	A3,A4	CLR.W	D3		; D3 <-- inverse si ncessaire	CALL	DECOIMAGE	; A4 <-- ^image dcode	JUMP',NE 80$	LOAD.W	D3,#-1		; D3 <-- centr en X	CALL	SHOWIMAGE	; affiche l'image	LOAD.L	A3,A4	LOAD.W	D5,D4	SR.W	D5,#3	LOAD.L	D2,D4	CALL	SHOWCADRE	; affiche le cadre	CLR.W	D7		; D7 <-- ok	CALL	FREEIMAGE	; libre l'image dcode80$:	LOAD.L	A4,A3	CALL	FREEIMAGE	; libre l'image codeEXIT$:	POPM.L	D2..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; LOADIMAGE >;==========/; Charge une image en mmoire.; in	A3.L	^nom de l'image; out	A4.L	^image code;	D7.W	erreur; mod	D7.W, A4.LLOADIMAGE:	PUSHM.L	D1,D3,D4,D6	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE EXIT$	LOAD.L	D4,#-1	LOAD.B	D3,D4	FOS	?SPOS		; D4 <-- longueur du fichier	PUSH.L	D4	CLR.L	D4	CLR.B	D3	FOS	?SPOS		; revient au dbut	POP.L	D4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer pour le fichier image	JUMP',NE 82$	FOS	?RDBYTE		; lit tout le fichier image	JUMP',EQ 82$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7EXIT$:	POPM.L	D1,D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; PROGIMAGE >;==========/; Affiche progressivement une nouvelle image principale.; in	A4.L	^nouvelle image code;	D0.W	progression (PROG*);	D1.L	incrment/dlai; out	-; mod	D7.WPROGIMAGE:	PUSHM.L	D2..D6,A3,A4	PUSH.L	A4	LOAD.L	A4,(A6)+OPIDESS	CALL	FREEIMAGE	; libre l'image dcode	POP.L	A4	CLR.W	D3		; D3 <-- inverse si ncessaire	LOAD.L	(A6)+OPICODE,A4	CALL	DECOIMAGE	; dcode l'image de la saison	LOAD.L	(A6)+OPIDESS,A4	LOAD.L	(A6)+ODIMA,D4	CALL	COPYDT		; OPITEMP <-- OPIDESS	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	LOAD.W	D3,(A5)+OOICON	; D3 <-- icne	CALL	DROBJET		; dessine toto (dans OPITEMP)	LOAD.L	A3,(A6)+OPICODE	; A3 <-- ^image code	LOAD.L	A4,(A6)+OPITEMP	; A4 <-- ^image dcode	CALL	ADAPTIMAGE	; adapte l'image  la CLUT actuelle	LOAD.W	D5,(A3)+OIMDLX	SR.W	D5,#3	LOAD.L	A3,(A6)+OPITEMP	CLR.L	D3	LOAD.W	D3,(A6)+OPIMAX	LOAD.L	A4,#0	CLR.L	D4	LOAD.L	D2,#H'10000*LYWDO+LXWDO	CALL	PROGRESS	; hop, progression ...	LOAD.L	A4,(A6)+OPICODE	; A4 <-- ^image code	COMP.B	(A4)+OIMBIP,#1	; image couleur ?	JUMP',EQ EXIT$		; non => EXIT$	CALL	COPYDT		; OPITEMP <-- OPIDESS	LOAD.L	A5,#(A6)+OOBJET	LOAD.L	D4,(A5)+OONPOS	; D4 <-- position	LOAD.W	D3,(A5)+OOICON	; D3 <-- icne	CALL	DROBJET		; dessine toto (dans OPITEMP);	LOAD.L	A4,(A6)+OPICODE	; A4 <-- ^image code	CALL	CLUTIMAGE	; utilise la CLUT de l'image	LOAD.L	A4,A3	LOAD.L	D4,(A6)+ODIMA	LOAD.W	D3,(A6)+OPIMAX	CALL	SHOWIMAGE	; affiche l'image	LOAD.L	D2,D4	CALL	SHOWCADRE	; affiche le cadreEXIT$:	POPM.L	D2..D6,A3,A4	RET;----------\\; DECOIMAGE >;==========/; Dcode une image noir/blanc ou couleur en mmoire.; in	A4.L	^image code;	D3.W	mode (1 => n'inverse pas); out	A4.L	^image dcode;	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D4.L, D7.W, A4.LDECOIMAGE:	PUSHM.L	D0..D3,A1..A3	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	COMP.B	(A2)+OIMBIP,#1	; image couleur ?	JUMP,NE COLOR$		; oui => COLOR$	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'image dcode	POPM.W	D1	JUMP,NE EXIT$	LOAD.L	A1,A4		; A1 <-- ^image	LOAD.L	A4,#(A2)+LGHIMA	; A4 <-- ^image code (source)	LOAD.L	A3,A1		; A3 <-- ^buffer (destination)	PUSH.B	(A2)+OIMCOD	PUSH.L	(A2)+OIMNBB	GRA_	DECOIMA		; dcode l'image ...	POP.L	(A2)+OIMNBB	POP.B	(A2)+OIMCOD	TEST.W	D7	JUMP,NE FREE$	LOAD.L	A4,A1		; A4 <-- ^image	COMP.W	D3,#1	JUMP,EQ OK$	TEST.B	(A6)+OINV	; fond de l'cran blanc ?	JUMP,T	OK$		; oui => OK$	SR.L	D4,#2+2	DEC.W	D4ILOOP$:	NOT.L	(A1+)		; inverse l'image	NOT.L	(A1+)	NOT.L	(A1+)	NOT.L	(A1+)	DECJ.W,NMO D4,ILOOP$	JUMP	OK$COLOR$:	CLR.W	D4	LOAD.B	D4,(A2)+OIMBIP	MUL.WU	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'image dcode	POPM.W	D1	JUMP,NE EXIT$	LOAD.L	A1,A4		; A1 <-- ^image	LOAD.L	A4,#(A2)+LGHIMA	; A4 <-- ^CLUT	ADD.L	A4,(A2)+OIMLGC	; A4 <-- ^image code (source)	LOAD.L	A3,A1		; A3 <-- ^buffer (destination)	PUSH.B	(A2)+OIMCOD	PUSH.L	(A2)+OIMNBB	PUSH.W	(A2)+OIMDLX	PUSH.B	(A2)+OIMBIP	CLR.W	D4	LOAD.B	D4,(A2)+OIMBIP	MUL.WU	D4,(A2)+OIMDLX	LOAD.W	(A2)+OIMDLX,D4	LOAD.B	(A2)+OIMBIP,#1	GRA_	DECOIMA		; dcode l'image ...	POP.B	(A2)+OIMBIP	POP.W	(A2)+OIMDLX	POP.L	(A2)+OIMNBB	POP.B	(A2)+OIMCOD	TEST.W	D7	JUMP',NE FREE$	LOAD.L	A4,A1		; A4 <-- ^imageOK$:	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions de l'image	JUMP'	EXIT$FREE$:	LOAD.L	A4,A1	CALL	FREEIMAGE	; rend la mmoire de l'imageEXIT$:	POPM.L	D0..D3,A1..A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ADAPTIMAGE >;===========/; Adapte une image  la CLUT active.; in	A3.L	^image code;	A4.L	^image dcode; out	-; mod	D7.WADAPTIMAGE:	PUSHM.L	D2..D6,A3,A4	COMP.B	(A3)+OIMBIP,#1	; image couleur ?	JUMP',EQ EXIT$		; non => EXIT$	CLR.L	D3	LOAD.W	D4,(A3)+OIMDLY	SWAP.W	D4	LOAD.W	D4,(A3)+OIMDLX	CLR.W	D6	LOAD.B	D6,(A3)+OIMBIP	; D6 <-- nb de bits/pixel	LOAD.W	D5,D4	SR.W	D5,#3	MUL.WU	D5,D6		; D5 <-- Iy	LOAD.L	A3,#(A3)+LGHIMA	; A3 <-- ^CLUT de l'image	CLR.L	D2		; D2 <-- mode	ICOL_	CONVC		; conversion selon la CLUT activeEXIT$:	POPM.L	D2..D6,A3,A4	RET;----------\\; CLUTIMAGE >;==========/; Modifie la CLUT pour une image donne.; in	A4.L	^image code; out	-; mod	D7.WCLUTIMAGE:	PUSHM.L	D3,D6,A3	COMP.B	(A4)+OIMBIP,#1	; image couleur ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A3,#(A4)+LGHIMA	; A3 <-- ^CLUT	LOAD.L	D3,#2^BTCTABLE	; D3 <-- mode	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal pour TCOLOR	TCOL_	LOADCLUT	; change la CLUTEXIT$:	POPM.L	D3,D6,A3	RET;----------\\; FREEIMAGE >;==========/; Libre la mmoire occupe par une image dcode-; in	A4.L	^image; out	-; mod	-FREEIMAGE:	PUSHM.L	D1,D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POPM.L	D1,D7	RET;----------\\; SHOWIMAGE >;==========/; Affiche une image dans la (sous-)fentre.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie centrale.; in	A4.L	^image;	D4.L	dimensions (dy;dx);	D3.W	origine (x) (-1 si centr); out	-; mod	D7.WSHOWIMAGE:	PUSHM.L	D0..D6,A3,A4	LOAD.W	D0,D4		; D0 <-- largeur de l'image	SWAP.W	D4	LOAD.W	D1,D4		; D1 <-- hauteur de l'image	LOAD.W	D2,D3		; D2 <-- origine	LOAD.W	D5,D0	SR.W	D5,#3		; D5 <-- source <ii>	LOAD.W	D6,(A0)+ODFFDY	; D6 <-- hauteur swdo	COMP.W	D1,D6		; image trop haute ?	JUMP',HI BIGY$		; oui => BIGY$	LOAD.W	D4,D6	SUB.W	D4,D1	SR.W	D4,#1		; D4 <-- destination <yy>	CLR.W	D3		; D3 <-- source <yy>	LOAD.W	D6,D1		; D6 <-- dimensions <dyy>	JUMP'	ENDY$BIGY$:	CLR.W	D4		; D4 <-- destination <yy>	SUB.W	D1,D6	SR.W	D1,#1	LOAD.W	D3,D1		; D3 <-- source <yy>ENDY$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D6	LOAD.W	D6,(A0)+ODFFDX	; D6 <-- largeur swdo	COMP.W	D0,D6		; image trop largeur ?	JUMP',HI BIGX$		; oui => BIGX$	LOAD.W	D4,D6	SUB.W	D4,D0	SR.W	D4,#1		; D4 <-- destination <xx>	CLR.W	D3		; D3 <-- source <xx>	LOAD.W	D6,D0		; D6 <-- dimensions <dxx>	JUMP'	ENDX$BIGX$:	CLR.W	D4		; D4 <-- destination <xx>	LOAD.W	D3,D2		; D3 <-- source <xx>	JUMP',NC ENDX$	SUB.W	D0,D6	SR.W	D0,#1	LOAD.W	D3,D0		; D3 <-- source <xx>ENDX$:	LOAD.L	A3,A4		; A3 <-- ^source	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	LOAD.L	D1,D6		; D1 <-- dimensions	LOAD.W	D2,#LOADDOT	; D2 <-- mode	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ RASTER$	; non => RASTER$	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOULRASTER$:	CALL	DRRASTER	POPM.L	D0..D6,A3,A4	RET;----------\\; SHOWCADRE >;==========/; Dessine le cadre, en fonction de l'image.; in	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	D2.L	hauteur/largeur (y;x); out	-; mod	D7.WSHOWCADRE:	PUSHM.L	D0..D6	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,EQ EXIT$		; non => EXIT$	COMP.L	A3,#0	JUMP,EQ EXIT$	CLR.L	D0	LOAD.B	D0,(A3)	SR.B	D0,#4		; D0 <-- couleur point sup/gauche	SWAP.W	D2	DEC.W	D2		; D2 <-- hauteur -1	CLR.W	D1	LOAD.B	D1,(A0)+ODFCNP	MUL.WU	D1,D5	MUL.WU	D1,D2	LOAD.B	D1,(A3)+(D1.L)	SR.B	D1,#4		; D1 <-- couleur point inf/gauche	AND.L	D1,#B'1111	LIB	?GETWDO		; D3/D4 <-- pos/dim swdo	LOAD.W	D6,D5	CLR.W	D5	LIB	?USEWDO	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	DRTRADEF	POPM.L	D3,D4	PUSH.L	(A0)+ODFCSF	LOAD.L	(A0)+ODFCSF,D0	PUSHM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,D3	CLR.W	D3	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame couleur dessus l'image	POPM.L	D3,D4	LOAD.L	(A0)+ODFCSF,D1	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,D3	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame couleur dessous l'image	POP.L	(A0)+ODFCSF	LOAD.W	D5,D6	LIB	?USEWDOEXIT$:	POPM.L	D0..D6	RET; Tirage de nombres alatoires; ----------------------------;--------\\; COUPSAC >;========/; Coup de sac pour le gnrateur alatoire.; in	-; out	-; mod	D7.WCOUPSAC:	PUSHM.L	D3,D4	LIB	?RDCLOCK	; D3/D4 <-- date et heure	RR.L	D3,#3	RL.L	D4,#7		; savante cuisine	NOT.L	D3	XOR.L	D4,D3	LOAD.L	(A6)+OHAZA+0,D3	LOAD.L	(A6)+OHAZA+4,D4	LOAD.W	D3,#10-120$:	CALL	HAZARD		; tire qq nombres	DECJ.W,NMO D3,20$	POPM.L	D3,D4	RET;---------\\; EXHAZARD >;=========/; Tire un nombre alatoire exclusif.; in	D3.W	+/- borne infrieure (min);	D4.W	+/- borne suprieure (max+1);	A4.L	^table d'exclusion; out	D4.W	+/- nombre alatoire: D3 <= n < D4; mod	D4.L, D7.WEXHAZARD:	PUSHM.L	D0..D3,A3	LOAD.W	D2,D410$:	LOAD.W	D1,D2	SUB.W	D1,D3	MUL.WU	D1,#10		; D1 <-- nb max d'essais20$:	LOAD.W	D4,D2		; D4 <-- borne suprieure	CALL	MMHAZARD	; D4 <-- nombre alatoire	LOAD.W	D0,D4	SUB.W	D0,D3	TEST.B	(A4)+(D0.W)	; nombre dj sorti ?	JUMP,EQ 80$		; non => 80$				; oui =>	DEC.W	D1		; encore un essai ?	JUMP,NE 20$		; oui => 20$	LOAD.L	A3,A4	LOAD.W	D1,D2	SUB.W	D1,D340$:	CLR.B	(A3+)		; recommence le tirage exclusif	DEC.W	D1	JUMP,NE 40$	JUMP	10$80$:	SET.B	(A4)+(D0.W)	; celui-i est pris	POPM.L	D0..D3,A3	RET;---------\\; MMHAZARD >;=========/; Tire un nombre alatoire (16 bits) compris entre deux bornes.; in	D3.W	+/- borne infrieure (min);	D4.W	+/- borne suprieure (max+1); out	D4.W	+/- nombre alatoire: D3 <= n < D4; mod	D4.L, D7.WMMHAZARD:	PUSH.W	D2	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- sup - inf	CALL	HAZARD	AND.L	D4,#H'FFFF	DIV.WU	D4,D2	SWAP.W	D4		; D4 <-- reste de la division	ADD.W	D4,D3	POP.W	D2	RET;--------\\; HAZARD  >;========/; Tire un nombre alatoire de 32 bits.; On utilise un registre  dcalage de 63 bits, avec un XNOR entre; les bits 0 et 60 pour calculer le nouveau bit inject.; in	-; out	D4.L	nombre; mod	D4.LHAZARD:	PUSHM.L	D2,D3	LOAD.W	D2,#32-1	LOAD.L	D3,(A6)+OHAZA+0	LOAD.L	D4,(A6)+OHAZA+410$:	TEST.L	D4:#1	JUMP,BC 20$	TEST.L	D3:#30	JUMP,BC 35$	JUMP	30$20$:	TEST.L	D3:#30	JUMP,BS 35$30$:	CLRX	RRX.L	D3,#1	RRX.L	D4,#1	JUMP	40$35$:	SETX	RRX.L	D3,#1	RRX.L	D4,#140$:	LOAD.L	(A6)+OHAZA+0,D3	LOAD.L	(A6)+OHAZA+4,D4	DECJ.W,NMO D2,10$	POPM.L	D2,D3	RET; Debug; -----DRD0:	PUSHM.L	D2..D4	LOAD.W	D2,#SETDOT	LOAD.L	D3,D0	SUB.W	D3,#10	CLR.L	D4	LOAD.W	D4,#20	LIB	?DRSEG	LOAD.L	D3,D0	SWAP.W	D3	SUB.W	D3,#10	SWAP.W	D3	LOAD.W	D4,#20	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	POPM.L	D2..D4	RETDRD0C:	PUSHM.L	D2..D4	LOAD.W	D2,#CLRDOT	LOAD.L	D3,D0	SUB.W	D3,#10	CLR.L	D4	LOAD.W	D4,#20	LIB	?DRSEG	LOAD.L	D3,D0	SWAP.W	D3	SUB.W	D3,#10	SWAP.W	D3	LOAD.W	D4,#20	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	POPM.L	D2..D4	RETAFCOOR:	PUSH.L	D4	LIB	?AFTIM	.ASCIZ	" x="	.EVEN	CALL	AFD4	SWAP.W	D4	LIB	?AFTIM	.ASCIZ	" y="	.EVEN	CALL	AFD4	POP.L	D4	RETAFD4:	PUSHM.L	D2..D4	AND.L	D4,#H'FFFF	TEST.W	D4	JUMP,NC 20$	LOAD.B	D3,#'-	LIB	?AFCAR	NEG.W	D420$:	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	POPM.L	D2..D4	RET	.INS	TOTO_CSPEC.ASI	.INS	TOTO_CTAB.ASI	.INS	TOTO_CMUS.ASI	.INS	TOTO_CANA.ASI	.END	START