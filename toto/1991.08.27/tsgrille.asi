	.SBTTL	PSGRILLE.ASIGRILLE:	CALL	AFMENUJ		; affiche les soft-keys	LOAD.L	A2,#R16"GRMOT	CALL	CHEXLETTRE16	; OCHMAP <-- icnes existantes	CALL	CHNIV123456	; choix d'un niveau 1,2,3,4,5,6 ...	JUMP,NE ERROR	COMP.W	D3,#'1	JUMP,LO LOOP	COMP.W	D3,#'6	JUMP,HI LOOP	SUB.W	D3,#'1		; D3 <-- 0..5	LOAD.W	(A6)+OLTNIV,D3	CALL	CCMO		; enlve la souris	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE ERROR	CALL	ICOMENLEVE	; enlve toto de l'cran ...	CALL	GRDEBUT		; fait qq calculs globaux	CALL	GRQUADRIL	; affiche le quadrillage	CALL	ICOMREMET	; remet toto sur l'cran ...	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	ICOMLITTLE	; effectue un p'tit rien ...	LOAD.L	A4,#R16"TAMVASC	CALL	ICOMALL		; va sur l'ascenseur de droite ...	CALL	JGFULL		; rempli la jauge	LOAD.L	(A6)+OJGECT,(A6)+OTIME	CLR.W	(A6)+OJGECPPARTIE$:	CALL	CCMO		; enlve la souris	LOAD.L	A2,#R16"GRMOT	CALL	LTINIT		; initialise une image	JUMP,NE ERROR	CALL	GRPLACE		; initialise la grille	CALL	GRCADRE		; dessine le cadre	CALL	CLRFIFO		; vide le fifo du clavier	CALL	SCMO		; remet la sourisLOOP$:	CALL	JGECOULE	; coule la jauge de droite	JUMP,NE BAD$	LOAD.W	D4,#2	NTREL	?SETTIM	LIB	?GETCAR		; clavier/souris ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE LOOP$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$BIP$:	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	LOOP$CLIC$:	CALL	GRMOVE		; allume selon la souris ...	JUMP,NE BIP$	CALL	GRTERM		; est-ce termin ?	JUMP,NE LOOP$	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	INC.W	(A6)+OGRPAR	; une partie reussie de plus	TEST.B	(A6)+OFLAGS:#BFTINFINI	JUMP',BS INFINI$	CALL	LTKILL		; libre l'image	JUMP	PARTIE$INFINI$:	COMP.W	(A6)+OGRPAR,#4	JUMP',HS IEND$	CALL	LTKILL		; libre l'image	JUMP	PARTIE$IEND$:	CALL	CCMO		; enlve la souris	CALL	JGECTERM	; termine l'coulement de la jauge	JUMP	GEND$BAD$:	CALL	CCMO		; enlve la souris	TEST.W	(A6)+OGRPAR	JUMP',NE GAGNE$	LOAD.W	(A6)+OSOUND,#TMUSPERDU	LOAD.L	A4,#R16"TAMRASCS	CALL	ICOMALL		; saute sur l'ascenseur ...	LOAD.W	D4,#50	NTREL	?DELMS		; attend 1 seconde ...	LOAD.L	A4,#(A6)+OGRTAS	CALL	GRAFFALL	; affiche la grille correcte	LOAD.W	D4,#50*2	NTREL	?DELMS		; attend 2 secondes ...	LOAD.L	A4,#R16"TAMRASCP	CALL	ICOMALL		; revient de l'ascenseur de droite ...	JUMP'	KILL$GAGNE$:	LOAD.W	(A6)+OSOUND,#TMUSFAUX	LOAD.L	A4,#R16"TAMNASC	CALL	ICOMALL		; remet toto sur l'ascenseur ...	LOAD.L	A4,#(A6)+OGRTAS	CALL	GRAFFALL	; affiche la grille correcte	LOAD.W	D4,#50*2	NTREL	?DELMS		; attend 2 secondes ...GEND$:	LOAD.W	D3,(A6)+OGRPAR	SR.W	D3,#1	COMP.W	D3,#4	JUMP',LS MAX$	LOAD.W	D3,#4MAX$:	SUB.W	D3,#4	NEG.W	D3	LOAD.W	(A6)+OTEST1,D3	CALL	JGGAGNE2	; revient de l'ascenseur ...	JUMP'	KILL$END$:	CALL	CCMO		; enlve la souris	CALL	JGECTERM	; termine l'coulement de la jauge	LOAD.L	A4,#R16"TAMRASC	CALL	ICOMALL		; revient de l'ascenseur de droite ...KILL$:	CALL	LTKILL		; libre l'image	JUMP	GRILLE;--------\\; GRTERM  >;========/; Regarde si c'est termin.; in	-; out	D7.W	erreur; mod	D7.WGRTERM:	PUSHM.L	D2,A3,A4	LOAD.L	A4,#(A6)+OGRTAS	LOAD.L	A3,#(A6)+OGRTAC	LOAD.W	D2,(A6)+OGRNBT	LOAD.W	D7,#1LOOP$:	COMP.B	(A3+),(A4+)	JUMP',NE EXIT$	DEC.W	D2	JUMP,NE LOOP$	CLR.W	D7EXIT$:	POPM.L	D2,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GRCADRE >;========/; Affiche le cadre.; in	-; out	-; mod	D7.WGRCADRE:	PUSHM.L	D0..D4,A3,A4	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	LIB	?COLORPUSH	LOAD.L	D3,(A6)+OGRCHS	LIB	?COLORSR	LOAD.L	D3,(A6)+OGRCHC	LIB	?COLORCR	; choix de couleurs alatoires	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	SUB.W	D4,#LXICO+10	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame toute la fentre, sauf l'ascenseur  droite	LIB	?COLORPOP	CALL	GRSHOW		; affiche la carte  trouver	LOAD.L	A4,#(A6)+OGRTAC	CALL	GRAFFALL	; affiche la grille	LOAD.L	A3,#R16"TEXT$	LOAD.L	D4,#H'10000*(LYWDO-100)+(50-10)	CALL	AFFBOX	POPM.L	D0..D4,A3,A4	RETTEXT$:	.ASCII	"Cherche<CR>"	.ASCII	"le mot ..."	.B	0	.EVEN;--------\\; GRSHOW  >;--------/; Affiche la carte du mmory choisie.; in	-; out	-; mod	D7.WGRSHOW:	PUSHM.L	D0..D4,A3,A4	LOAD.W	D2,(A6)+OGRPOY	ADD.W	D2,#4	SWAP.W	D2	LOAD.W	D2,#50	TEST.L	(A6)+OLTPIC	JUMP,EQ TEXT$	CALL	LTRANG		; D4 <-- rang de l'image	JUMP,NE TEXT$	PUSH.L	D4	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	POP.L	D4	DIV.WU	D4,(A6)+OLTNSI+2	LOAD.W	D3,D4	MUL.WU	D3,(A6)+OLTDSI+0 ; D3 <-- position dans l'image en Y	INC.W	D3	SWAP.W	D3	SWAP.W	D4	MUL.WU	D4,(A6)+OLTDSI+2	LOAD.W	D3,D4		; D3 <-- position dans l'image en X	INC.W	D3	LOAD.L	D4,(A6)+OLTDSI	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	PUSHM.L	D2..D4	LOAD.L	D3,D2	SUB.W	D3,#10	SWAP.W	D3	SUB.W	D3,#10	SWAP.W	D3	ADD.W	D4,#10+10	SWAP.W	D4	ADD.W	D4,#10+10	SWAP.W	D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface sous la carte	POPM.L	D2..D4	LOAD.L	A4,(A6)+OLTPIC	; A4 <-- ^image code	LOAD.L	A3,(A6)+OLTPID	; A3 <-- ^image dcode	CALL	COLORFPH	; choix d'une couleur de fond pastelle	CALL	IMAGEAFF	; affiche une carte du mmory	LIB	?COLORPOP	JUMP	EXIT$TEXT$:	LIB	?AFTIM	.B	USEGC		; utilise les caractres NBP14	.B	GCTYF	.B	GCTYS	.B	GCTYT	.B	0	.EVEN	TEST.B	(A6)+OINV	; cran invers ?	JUMP',F INV$		; non => INV$	LOAD.B	D3,#AFINV	LIB	?AFCARINV$:	LOAD.L	A3,#(A6)+OLTMOT	LOAD.W	D0,#-1CNT$:	INC.W	D0		; D0 <-- longueur du mot	TEST.B	(A3+)	JUMP,NE CNT$	LOAD.W	D3,#'.	LIB	?LGXCAR	MUL.WU	D4,D0	ADD.W	D4,#20+20	SWAP.W	D4	LOAD.W	D4,#100	SWAP.W	D4	LOAD.L	D3,D2	SUB.W	D3,#4	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	PUSHM.L	D3,D4	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF		; trame pour effacer	POPM.L	D3,D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'intrieur	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF		; trame noire pour l'ombre	POPM.L	D3,D4	PUSHM.L	D3,D4	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRRECT		; dessine le pourtour	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LOAD.W	D1,#2	LIB	?DRRECTO	POPM.L	D3,D4	ADD.W	D3,#20-2	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	LOAD.W	D4,(A0)+ODFC1Y	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A3,#(A6)+OLTMOT	LOAD.B	D3,(A3)	CALL	AFFCAR		; affiche le premier caractre	LOAD.W	D4,D0	SUB.W	D4,#2	JUMP',LE LAST$POINT$:	LOAD.B	D3,#'.	LIB	?AFCAR	DEC.W	D4	JUMP,NE POINT$LAST$:	LOAD.B	D3,(A3)+(D0.W)-1	CALL	AFFCAR		; affiche le dernier caractre	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC		; utilise les caractres normaux	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVENEXIT$:	POPM.L	D0..D4,A3,A4	RET;---------\\; GRAFFALL >;=========/; Affiche une grille complte.; in	A4.L	^grille  afficher; out	-; mod	D7.WGRAFFALL:	PUSHM.L	D1..D4,A4	CALL	GRQUADRIL	; affiche le quadrillage	COMP.W	(A6)+OGRDIY,#19	JUMP',LS LITTLE$	LIB	?AFTIM	.B	USEGC		; utilise les caractres NBP14	.B	GCTYF	.B	GCTYS	.B	GCTYT	.B	0	.EVENLITTLE$:	LIB	?AFTIM	.B	MODCAR,SETDOT!PENDOT	.B	0	.EVEN	TEST.B	(A6)+OINV	; cran invers ?	JUMP',F INV$		; non => INV$	LIB	?AFTIM	.B	MODCAR,CLRDOT!PENDOT	.B	0	.EVENINV$:	CLR.W	D1LOOP$:	LOAD.W	D2,D1	CALL	GRPOSDIM	; D3/D4 <-- position/dimensions	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- centre de la case	DEC.W	D3	SWAP.W	D3;	SWAP.W	D4	LOAD.L	D2,D3	LOAD.B	D3,(A4)		; D3 <-- caractre de la case	TCLR.L	D3:#7	LIB	?LGXCAR		; D4 <-- largeur du caractre	SR.W	D4,#1	SUB.W	D2,D4	SWAP.W	D2	LOAD.W	D4,(A0)+ODFC1Y	SR.W	D4,#1	SUB.W	D2,D4	ADD.W	D2,(A0)+ODFC1Y	SWAP.W	D2	EX.L	D3,D2	LIB	?SETCURS	LOAD.B	D3,D2	CALL	AFFCAR		; affiche le caractre	TEST.B	(A4+):#7	JUMP',BC NEXT$	LOAD.W	D2,D1	CALL	GRHILIA		; inverse la caseNEXT$:	INC.W	D1	COMP.W	D1,(A6)+OGRNBT	JUMP,LO LOOP$	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC		; utilise les caractres normaux	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	MODCAR,SETDOT	.B	0	.EVEN	POPM.L	D1..D4,A4	RET;----------\\; GRQUADRIL >;==========/; Affiche le quadrillage d'une grille.; in	-; out	-; mod	D7.WGRQUADRIL:	PUSHM.L	D1..D4	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	LOAD.W	D4,(A6)+OGRDIY	MUL.WU	D4,(A6)+OGRNBY	SWAP.W	D4	LOAD.W	D3,(A6)+OGRDIX	MUL.WU	D3,(A6)+OGRNBX	LOAD.W	D4,D3	LOAD.L	D3,(A6)+OGRPOY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface dans la grille	LOAD.W	D1,#B'0001101101100100	CALL	DESRECTM	; cadre autour de la grille	CLR.W	D1LOOP$:	LOAD.W	D2,D1	CALL	GRPOSDIM	; D3/D4 <-- position/dimensions	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRRECT	INC.W	D1	COMP.W	D1,(A6)+OGRNBT	JUMP,LO LOOP$	POPM.L	D1..D4	RET;--------\\; GRMOVE  >;========/; Allume selon la souris.; in	-; out	D7.W	erreur; mod	D7.WGRMOVE:	PUSHM.L	D0..D4,A4	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE EXIT$	CALL	GRDETECT	; D2 <-- case o est la souris	JUMP,NE EXIT$	LOAD.L	A4,#R16"GRHILIA	; A4 <-- ^routine d'inversion	LOAD.W	D1,D2		; D1 <-- dpart	LOAD.W	D0,D2		; D0 <-- dernire arrive	CALL	GRMOVEL		; inverse la caseLOOP$:	CLR.L	D3	CALL	JGECOULE	; coule la jauge de droite	JUMP,NE EXIT$	LOAD.W	D4,#2	NTREL	?SETTIM	LIB	?GETKEY		; attend souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE LOOP$	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	GRDETECT	; D2 <-- case o est la souris	COMP.W	D2,D0	JUMP,EQ LOOP$	EX.L	D0,D2	CALL	GRMOVEL		; efface l'ancien	LOAD.W	D2,D0	CALL	GRMOVEL		; allume le nouveau	JUMP	LOOP$END$:	LOAD.L	A4,#R16"INV$	LOAD.W	D2,D0	CALL	GRMOVEL		; allume aussi en mmoire	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A4	TEST.W	D7		; retour EQ/NE	RETINV$:	PUSH.L	A4	LOAD.L	A4,#(A6)+OGRTAC	TNOT.B	(A4)+(D2.W):#7	POP.L	A4	RET;--------\\; GRMOVEL >;--------/; Inverse plusieurs cases en ligne.; in	D1.W	case de dpart (0..n);	D2.W	case d'arrive (0..n);	A4.L	^routine (comme GRHILIC); out	-; mod	D7.WGRMOVEL:	PUSHM.L	D0..D6	COMP.W	D1,D2	JUMP,EQ ONE$	COMP.W	D2,#-1	JUMP,EQ ONE$	CLR.L	D3	LOAD.W	D3,D1	DIV.WU	D3,(A6)+OGRNBX	SWAP.W	D3		; D3 <-- dpart (y;x)	CLR.L	D4	LOAD.W	D4,D2	DIV.WU	D4,(A6)+OGRNBX	SWAP.W	D4		; D4 <-- arrive (y;x)	LOAD.W	D5,D3	SUB.W	D5,D4	JUMP',NC POSX$	NEG.W	D5		; D5 <-- |dx|POSX$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D6,D3	SUB.W	D6,D4	JUMP',NC POSY$	NEG.W	D6		; D6 <-- |dy|POSY$:	SWAP.W	D3	SWAP.W	D4	TEST.W	D6	JUMP',EQ HORIZ$	TEST.W	D5	JUMP',EQ VERTI$	COMP.W	D5,D6	JUMP,NE ONE$	LOAD.W	D2,D1	LOAD.W	D1,D5	LOAD.W	D0,#+1	COMP.W	D4,D3	JUMP',HI RIGHT$	NEG.W	D0RIGHT$:	LOAD.W	D5,(A6)+OGRNBX	SWAP.W	D3	SWAP.W	D4	COMP.W	D4,D3	JUMP',HI DOWN$	NEG.W	D5DOWN$:	ADD.W	D0,D5	JUMP'	MULTI$VERTI$:	LOAD.W	D2,D1	LOAD.W	D1,D6	LOAD.W	D0,(A6)+OGRNBX	SWAP.W	D3	SWAP.W	D4	COMP.W	D4,D3	JUMP',HI MULTI$	NEG.W	D0	JUMP'	MULTI$HORIZ$:	TEST.W	D5	JUMP',EQ ONE$	LOAD.W	D2,D1	LOAD.W	D1,D5	LOAD.W	D0,#+1	COMP.W	D4,D3	JUMP',HI MULTI$	NEG.W	D0;	JUMP'	MULTI$MULTI$:	CALL	(A4)		; inverse une case	ADD.W	D2,D0	DEC.W	D1	JUMP,NC MULTI$	JUMP'	EXIT$ONE$:	LOAD.W	D2,D1	CALL	(A4)		; inverse juste le dpartEXIT$:	POPM.L	D0..D6	RET;---------\\; GRDETECT >;=========/; Dtecte dans quelle case est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	case o est la souris (0..n,-1);	D7.W	erreur; mod	D2.L, D7.WGRDETECT:	PUSH.L	D4	CLR.L	D2	LOAD.W	D2,D4	SUB.W	D2,(A6)+OGRPOX	JUMP',LO OUT$	DIV.WU	D2,(A6)+OGRDIX	COMP.W	D2,(A6)+OGRNBX	JUMP',HS OUT$	CLR.W	D4	SWAP.W	D4	SUB.W	D4,(A6)+OGRPOY	JUMP',LO OUT$	DIV.WU	D4,(A6)+OGRDIY	COMP.W	D4,(A6)+OGRNBY	JUMP',HS OUT$	MUL.WU	D4,(A6)+OGRNBX	ADD.W	D2,D4	CLR.W	D7	JUMP'	EXIT$OUT$:	LOAD.W	D2,#-1	LOAD.W	D7,#1EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GRHILIA >;========/; Inverse une case.; in	D2.W	rang de la case (0..n,-1); out	-; mod	D7.WGRHILIA:	PUSHM.L	D2..D4	COMP.W	D2,#-1	JUMP',EQ EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LIB	?COLORPUSH	LOAD.L	D3,#COLORHILI	LIB	?COLORSR	CALL	GRPOSDIM	; D3/D4 <-- position/dimensions	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#3	SWAP.W	D4	SUB.W	D4,#3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse la case	LIB	?COLORPOPEXIT$:	POPM.L	D2..D4	RET;---------\\; GRPOSDIM >;---------/; Donne la position d'une case.; in	D2.W	rang de la case (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WGRPOSDIM:	PUSH.L	D2	AND.L	D2,#H'FFFF	DIV.WU	D2,(A6)+OGRNBX	LOAD.W	D3,D2	MUL.WU	D3,(A6)+OGRDIY	ADD.W	D3,(A6)+OGRPOY	SWAP.W	D3	SWAP.W	D2	MUL.WU	D2,(A6)+OGRDIX	ADD.W	D2,(A6)+OGRPOX	LOAD.W	D3,D2	LOAD.L	D4,(A6)+OGRDIY	POP.L	D2	RET;--------\\; GRPLACE >;========/; Place le mot dans la grille.; in	-; out	-; mod	D7.WGRPLACE:	PUSHM.L	D1..D5,A3,A4	LOAD.L	A4,#(A6)+OGRTAS	LOAD.W	D2,(A6)+OGRNBTHAZARD$:	LOAD.W	D3,#'a	LOAD.W	D4,#'w	CALL	MMHAZARD	; D4 <-- a..v	COMP.W	D4,#'j	JUMP,EQ HAZARD$	COMP.W	D4,#'k	JUMP,EQ HAZARD$	LOAD.B	(A4+),D4	; OGRTAS <-- une lettre	DEC.W	D2	JUMP,NE HAZARD$	LOAD.L	A4,#(A6)+OLTMOT	LOAD.W	D2,#-1CNT$:	INC.W	D2		; D2 <-- lg du mot  trouver	TEST.B	(A4+)	JUMP,NE CNT$	LOAD.W	D3,#6	LOAD.W	D4,#9	COMP.W	(A6)+OLTNIV,#3	JUMP',LO DIRH$	CLR.W	D3	LOAD.W	D4,#8DIRH$:	CALL	MMHAZARD	COMP.W	D4,#8	JUMP',LO DIRM$	SUB.W	D4,#8DIRM$:	LOAD.W	D5,D4		; D5 <-- direction (0..7)	LOAD.W	D4,(A6)+OGRNBX	COMP.W	D5,#2		; direction = sud ?	JUMP',EQ HAZX$	COMP.W	D5,#6		; direction = nord ?	JUMP',EQ HAZX$	CLR.W	D0		; D0 <-- offset en X	SUB.W	D4,D2	JUMP',LE POSX$	INC.W	D4HAZX$:	CLR.W	D3	CALL	MMHAZARD	LOAD.W	D0,D4POSX$:	LOAD.W	D4,(A6)+OGRNBY	COMP.W	D5,#0		; direction = est ?	JUMP',EQ HAZY$	COMP.W	D5,#4		; direction = ouest ?	JUMP',EQ HAZY$	CLR.W	D1		; D1 <-- offset en Y	SUB.W	D4,D2	JUMP',LE POSY$	INC.W	D4HAZY$:	CLR.W	D3	CALL	MMHAZARD	LOAD.W	D1,D4POSY$:	DEC.W	D5	JUMP,NS EST$	DEC.W	D5	JUMP,NS SE$	DEC.W	D5	JUMP',NS SUD$	DEC.W	D5	JUMP',NS SO$	DEC.W	D5	JUMP',NS OUEST$	DEC.W	D5	JUMP',NS NO$	DEC.W	D5	JUMP',NS NORD$NE$:	LOAD.W	D5,#+1	SWAP.W	D5	LOAD.W	D5,#+1	JUMP	PUT$NORD$:	LOAD.W	D5,#+1	SWAP.W	D5	LOAD.W	D5,#0	JUMP	PUT$NO$:	LOAD.W	D5,#+1	SWAP.W	D5	LOAD.W	D5,#-1	SUB.W	D0,(A6)+OGRNBX	INC.W	D0	NEG.W	D0	JUMP'	PUT$OUEST$:	LOAD.W	D5,#0	SWAP.W	D5	LOAD.W	D5,#-1	SUB.W	D0,(A6)+OGRNBX	INC.W	D0	NEG.W	D0	JUMP'	PUT$SO$:	LOAD.W	D5,#-1	SWAP.W	D5	LOAD.W	D5,#-1	SUB.W	D1,(A6)+OGRNBY	INC.W	D1	NEG.W	D1	SUB.W	D0,(A6)+OGRNBX	INC.W	D0	NEG.W	D0	JUMP'	PUT$SUD$:	LOAD.W	D5,#-1	SWAP.W	D5	LOAD.W	D5,#0	SUB.W	D1,(A6)+OGRNBY	INC.W	D1	NEG.W	D1	JUMP'	PUT$SE$:	LOAD.W	D5,#-1	SWAP.W	D5	LOAD.W	D5,#+1	SUB.W	D1,(A6)+OGRNBY	INC.W	D1	NEG.W	D1	JUMP'	PUT$EST$:	LOAD.W	D5,#0	SWAP.W	D5	LOAD.W	D5,#+1;	JUMP'	PUT$PUT$:	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- origine (y;x)	LOAD.L	A4,#(A6)+OGRTAS	LOAD.L	A3,#(A6)+OLTMOTPUT2$:	LOAD.B	D3,(A3+)	JUMP',EQ PUT4$	TSET.L	D3:#7	CALL	GRPLACECAR	; OGRTAS <-- un caractre	ADD.W	D4,D5		; D4 <-- position suivante	SWAP.W	D4	SWAP.W	D5	ADD.W	D4,D5	SWAP.W	D4	SWAP.W	D5	JUMP	PUT2$PUT4$:	LOAD.L	A4,#(A6)+OGRTAS	LOAD.L	A3,#(A6)+OGRTAC	LOAD.W	D2,(A6)+OGRNBTPUT6$:	LOAD.B	D3,(A4+)	TCLR.L	D3:#7	LOAD.B	(A3+),D3	; OGRTAC <-- grille, sans la solution	DEC.W	D2	JUMP,NE PUT6$	POPM.L	D1..D5,A3,A4	RET;-----------\\; GRPLACECAR >;-----------/; Met un caractre dans une grille.; in	A4.L	^grille;	D4.L	position (y;x);	D3.B	caractre; out	-; mod	D7.WGRPLACECAR:	PUSH.L	D2	LOAD.L	D2,D4	SWAP.W	D2	MUL.WU	D2,(A6)+OGRNBX	ADD.W	D2,D4	LOAD.B	(A4)+(D2.W),D3	POP.L	D2	RET;--------\\; GRDEBUT >;========/; Initialise qq paramtres globaux.; in	-; out	-; mod	D7.WGRDEBUT:	PUSHM.L	D2..D4,A3,A4	LOAD.W	D3,(A6)+OLTNIV	LOAD.W	D2,#40	LOAD.W	D4,#5	TEST.W	D3	JUMP',EQ NBC$	LOAD.W	D2,#45	LOAD.W	D4,#6	DEC.W	D3	JUMP',EQ NBC$	LOAD.W	D2,#50	LOAD.W	D4,#8	DEC.W	D3	JUMP',EQ NBC$	LOAD.W	D2,#60	LOAD.W	D4,#10	DEC.W	D3	JUMP',EQ NBC$	LOAD.W	D2,#80	LOAD.W	D4,#12	DEC.W	D3	JUMP',EQ NBC$	LOAD.W	D2,#100	LOAD.W	D4,#15NBC$:	LOAD.W	(A6)+OJGECD,D2	LOAD.W	(A6)+OGRNBX,D4	LOAD.W	(A6)+OGRNBY,D4	LOAD.W	D3,D4	MUL.WU	D3,D4	LOAD.W	(A6)+OGRNBT,D3	LOAD.W	D3,#LYWDO-100	DIV.WU	D3,D4	LOAD.W	(A6)+OGRDIY,D3	LOAD.W	(A6)+OGRDIX,D3	LOAD.W	(A6)+OGRPOX,#LXWDO-400	LOAD.W	D4,(A6)+OGRDIY	MUL.WU	D4,(A6)+OGRNBY	SUB.W	D4,#LYWDO	NEG.W	D4	SR.W	D4,#1	LOAD.W	(A6)+OGRPOY,D4	CLR.W	(A6)+OGRPAR	; aucune partie reussie	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	CALL	COLORHAZARD	; choix de couleurs alatoires	LOAD.L	(A6)+OGRCHS,(A6)+OCOLHS	LOAD.L	(A6)+OGRCHC,(A6)+OCOLHC	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame toute la fentre	LIB	?COLORPOP	CALL	JGDRAW		; dessine la jauge	POPM.L	D2..D4,A3,A4	RET;--------\\; GRMOT   >;========/; Initialise une image pour le pendu.; in	A3.L	^mot de la sous-image;	A4.L	^dans OBK*; out	D7.W	erreur; mod	D7.WGRMOT:	PUSHM.L	D2..D4,A1..A4	LOAD.L	D4,(A4)+OBKFAN	; D4 <-- fanions	TEST.L	D4:#BFAGRILLE	JUMP,BC ERROR$	LOAD.L	A2,#(A6)+OLTMOT	LOAD.L	A1,#(A6)+OLTTRM	CLR.W	D2MOT1$:	LOAD.B	D3,(A3+)	JUMP',EQ MOT3$	COMP.B	D3,#'|	JUMP',EQ MOT3$	COMP.B	D3,#CR	JUMP',EQ MOT3$	LOAD.B	(A2+),D3	; OLTMOT <-- mot de l'image	CLR.B	(A1+)		; OLTTRM <-- mot trouv	INC.W	D2	JUMP	MOT1$MOT3$:	CLR.B	(A2)	CLR.B	(A1)	LOAD.W	D3,(A6)+OLTNIV	JUMP',EQ NIV0$	DEC.W	D3	JUMP',EQ NIV1$	DEC.W	D3	JUMP',EQ NIV2$	DEC.W	D3	JUMP',EQ NIV3$	DEC.W	D3	JUMP',EQ NIV4$NIV5$:	COMP.W	D2,#14	JUMP',HI ERROR$	COMP.W	D2,#6	JUMP',LS ERROR$	JUMP'	NIVOK$NIV4$:	COMP.W	D2,#11	JUMP',HI ERROR$	COMP.W	D2,#5	JUMP',LS ERROR$	JUMP'	NIVOK$NIV3$:	COMP.W	D2,#9	JUMP',HI ERROR$	COMP.W	D2,#4	JUMP',LS ERROR$	JUMP'	NIVOK$NIV2$:	COMP.W	D2,#7	JUMP',HI ERROR$	COMP.W	D2,#3	JUMP',LS ERROR$	JUMP'	NIVOK$NIV1$:	COMP.W	D2,#4	JUMP',HI ERROR$	COMP.W	D2,#1	JUMP',LS ERROR$	JUMP'	NIVOK$NIV0$:	COMP.W	D2,#4	JUMP',HI ERROR$	COMP.W	D2,#1	JUMP',LS ERROR$;	JUMP'	NIVOK$NIVOK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#ERTIMEXEXIT$:	POPM.L	D2..D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.END