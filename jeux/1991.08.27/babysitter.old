	.TITLE	BABYSITTER.ASM;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------;	Source pour EPROM 2732 du processeur HD63P01	.PROC	M6801		; mmes instructions que le M6801; Principales adresses mmoires; -----------------------------REG	=	H'0000		; registres internesRAM	=	H'0080		; dbut de la RAM interneLRAM	=	H'0080		; lg de la RAM interneROM	=	H'F000		; dbut de l'EPROM 2732LROM	=	H'1000		; lg de l'EPROM 2732; Notes; -----DO	=	100RE	=	89MI	=	79FA	=	75SOL	=	67LA	=	59SI	=	53DO1	=	50; Touches du clavier; ------------------ENTER	=	H'0D		; RUN/STOP (touche verte)CLEAR	=	H'7F		; CLEARF1	=	'A		; TEL  (touche rouge)F2	=	'B		; DET  (touche rouge)F3	=	'C		; INFO (touche rouge); Caractres spciaux du LCD; --------------------------SPACE	=	H'20		; espaceLEFT	=	H'7F		; flche "<-"; Internal register area; ----------------------	.LOC	REGDDIR1:	.BLKB	1		; port1: directionDDIR2:	.BLKB	1		; port2: directionDATA1:	.BLKB	1		; port1: dataDATA2:	.BLKB	1		; port2: dataDDIR3:	.BLKB	1		; port3: directionDDIR4:	.BLKB	1		; port4: directionDATA3:	.BLKB	1		; port3: dataDATA4:	.BLKB	1		; port4: dataTIMER:	.BLKB	1		; timer: control and statusCOUNTH:	.BLKB	1		; counter (high)COUNTL:	.BLKB	1		; counter (low)COMPH:	.BLKB	1		; compare (high)COMPL:	.BLKB	1		; compare (low)CAPTH:	.BLKB	1		; capture (high)CAPTL:	.BLKB	1		; capture (low)CTRL3:	.BLKB	1		; port3: controlRATE:	.BLKB	1		; rate and modeTRSTA:	.BLKB	1		; transmit/receive statusRDATA:	.BLKB	1		; receive: dataTDATA:	.BLKB	1		; transmit: dataRAMCR:	.BLKB	1		; RAM control; Priphriques; -------------; Les [] indiquent l'tat de repos (inactif) !; N.C. = not connected; DATA1 bit0	<--	[1] on sonne; DATA1 bit1	<--	[1] on crie; DATA1 bit2	-->	[0] audio out; DATA1 bit3	<--	N.C.; DATA1 bit4	<--	[1] contact 1; DATA1 bit5	<--	[1] contact 2; DATA1 bit6	<--	[1] contact 3; DATA1 bit7	<--	[1] contact 4 (bouton d'appel  l'aide); DATA2 bit0	<--	N.C.; DATA2 bit1	<--	N.C.; DATA2 bit2	<--	N.C.; DATA2 bit3	<--	N.C.; DATA2 bit4	<--	N.C.; DATA3 bit0	-->	[0] relais "f" (fourchette); DATA3 bit1	-->	[0] relais "i" (impulsions); DATA3 bit2	-->	[1] LCD: E; DATA3 bit3	-->	[1] LCD: RS; DATA3 bit4	-->	[x] LCD: data bit 4; DATA3 bit5	-->	[x] LCD: data bit 5; DATA3 bit6	-->	[x] LCD: data bit 6; DATA3 bit7	-->	[x] LCD: data bit 7; DATA4 bit0	-->	[1] clavier: C1; DATA4 bit1	-->	[1] clavier: C2; DATA4 bit2	-->	[1] clavier: C4 (!); DATA4 bit3	-->	[1] clavier: C3 (!); DATA4 bit4	<--	[1] clavier: L1; DATA4 bit5	<--	[1] clavier: L2; DATA4 bit6	<--	[1] clavier: L3; DATA4 bit7	<--	[1] clavier: L4; Variables; ---------LBUTEL	=	8		; nb max digits numro tlphoneLBUDEL	=	3		; nb max digits autres numros	.LOC	RAMCPOS:	.BLKB	1		; position du curseur (0..15)SAVPOS:	.BLKB	1		; GETLINE: position du curseurSAVLGB:	.BLKB	1		; GETLINE: lg bufferSAVPTB:	.BLKB	2		; GETLINE: ^bufferFONC:	.BLKB	1		; touche fonction (F1, F2 ou F3)RANG:	.BLKB	1		; rang dans touche fonctionRANGS:	.BLKB	1		; rang suivantBUTEL:	.BLKB	LBUTEL+1	; numro de tlphoneBUAPP:	.BLKB	LBUDEL+1	; dure maximale d'un appelBUCRI:	.BLKB	LBUDEL+1	; dure minimale d'un criCODE:	.BLKB	1		; 1 => appel cod (2x)IFMIC:	.BLKB	1		; 1 => sensible au microIFCON1:	.BLKB	1		; 1 => sensible au contact 1IFCON2:	.BLKB	1		; 1 => sensible au contact 2IFCON3:	.BLKB	1		; 1 => sensible au contact 3IFCON4:	.BLKB	1		; 1 => sensible au contact 4COUNT0:	.BLKB	2		; SONNE?: compteur mono-stableCOUNT1:	.BLKB	2		; SONNE?: compteur dure des 1COUNT2:	.BLKB	2		; CRI?: compteurCONTACT:.BLKB	1		; CONTACT?: pour ragir au flan 1\0CONTNB:	.BLKB	1		; CONTACT?: contact ferm ('1..'4)NOTE:	.BLKB	1		; BIP: valeur de la noteMARQUE:	.BLKB	1		; marqueur de surveillanceNBRAP:	.BLKB	1		; nb d'appels reusNBEAP:	.BLKB	1		; nb d'appels reus sans codeNBSAP:	.BLKB	1		; nb d'appels envoysNBCON1:	.BLKB	1		; nb de contact 1 fermsNBCON2:	.BLKB	1		; nb de contact 2 fermsNBCON3:	.BLKB	1		; nb de contact 3 fermsNBCON4:	.BLKB	1		; nb de contact 4 fermsSURVS:	.BLKB	1		; SURVEILLE: compteur des secondes (*2)SURVM:	.BLKB	1		; SURVEILLE: compteur des minutesSURVH:	.BLKB	1		; SURVEILLE: compteur des heures; Dbut de l'EPROM 2732; ---------------------	.LOC	ROMSTART:	LOAD	SP,#RAM+LRAM-1	LOAD	IX,#TAINIT	CALL	INIPER	LOAD	A,#0	LOAD	BUTEL,A		; pas de numro de tlphone	LOAD	NBRAP,A		; pas d'appels reus	LOAD	NBEAP,A		; pas d'appels reus sans code	LOAD	NBSAP,A		; pas d'appels envoys	LOAD	NBCON1,A	; pas de contact 1 ferms	LOAD	NBCON2,A	; pas de contact 2 ferms	LOAD	NBCON3,A	; pas de contact 3 ferms	LOAD	NBCON4,A	; pas de contact 4 ferms	LOAD	SURVS,A		; zro secondes	LOAD	SURVM,A		; zro minutes	LOAD	SURVH,A		; zro heures	LOAD	A,#1	LOAD	CODE,A		; mode [CODE 2] par dfaut	LOAD	IFMIC,A		; micro [OUI] par dfaut	LOAD	IFCON1,A	; porte 1 [OUI] par dfaut	LOAD	IFCON2,A	; porte 2 [OUI] par dfaut	LOAD	IFCON3,A	; porte 3 [OUI] par dfaut	LOAD	IFCON4,A	; porte 4 [OUI] par dfaut	LOAD	A,#B'11111111	LOAD	CONTACT,A	LOAD	A,#'1	LOAD	BUAPP+0,A	; BUAPP <-- "120" (dure de l'appel)	LOAD	A,#'2	LOAD	BUAPP+1,A	LOAD	A,#'0	LOAD	BUAPP+2,A	LOAD	A,#0	LOAD	BUAPP+3,A	LOAD	A,#'1	LOAD	BUCRI+0,A	; BUCRI <-- "10" (dure des cris, unit = 0.1s)	LOAD	A,#'0	LOAD	BUCRI+1,A	LOAD	A,#0	LOAD	BUCRI+2,A	CALL	LCDINIT		; initialise le LCD	CALL	AFEOP		; efface tout	LOAD	IX,#TXBABY	CALL	AFTEXT		; p'tit texte de bienvenue	LOAD	A,#100*2	CALL	WAITMS		; attend 2s	LOAD	A,#F1	LOAD	FONC,A		; demande d'abord le numro de tlphoneLOOP0:	LOAD	A,#0	LOAD	RANG,A		; premier choix du bouton [F1], [F2] ou [F3]LOOP:	CALL	AFEOP	LOAD	A,FONC	COMP	A,#F3	JUMP,EQ 30$	LOAD	A,FONC	COMP	A,#F2	JUMP,NE DOF1		; touche [F1] => DOF1	JUMP	DOF2		; touche [F2] => DOF230$:	JUMP	DOF3		; touche [F3] => DOF3TXBABY:	.ASCIZ	" BABY-SITTER ..."; Traitement du bouton [F1] (tel).DOF1:	LOAD	A,RANG		; A <-- rang du sous-menu	COMP	A,#1	JUMP,EQ	DOF1B	COMP	A,#2	JUMP,EQ	DOF1CDOF1A:	LOAD	A,#1	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXTEL	CALL	AFTEXT	LOAD	IX,#BUTEL	LOAD	B,#LBUTEL	JUMP	DOFTXTEL:	.ASCIZ	"No tel: "DOF1B:	LOAD	A,#2	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXCOD0	LOAD	A,CODE	JUMP,EQ 10$	LOAD	IX,#TXCOD110$:	CALL	AFTEXT	LOAD	IX,#CODE	; IX <-- ^variable pour rponse	JUMP	DOOUINON	; traite rponse OUI/NONTXCOD0:	.ASCIZ	"Appels: [TOUS]  "TXCOD1:	.ASCIZ	"Appels: [CODE 2]"DOF1C:	LOAD	A,#0	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXDEL1	CALL	AFTEXT	LOAD	IX,#BUAPP	LOAD	B,#LBUDEL	JUMP	DOFTXDEL1:	.ASCIZ	"Duree appel: "; Traitement du bouton [F2] (det).DOF2:	LOAD	A,RANG		; A <-- rang du sous-menu	COMP	A,#5	JUMP,EQ	60$	COMP	A,#4	JUMP,EQ	50$	COMP	A,#3	JUMP,EQ	40$	COMP	A,#2	JUMP,EQ	30$	COMP	A,#1	JUMP,EQ	20$10$:	JUMP	DOF2A20$:	JUMP	DOF2B30$:	JUMP	DOF2C40$:	JUMP	DOF2D50$:	JUMP	DOF2E60$:	JUMP	DOF2FDOF2A:	LOAD	A,#1	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXDEL2	CALL	AFTEXT	LOAD	IX,#BUCRI	LOAD	B,#LBUDEL	JUMP	DOFTXDEL2:	.ASCIZ	"Duree cris: "DOF2B:	LOAD	A,#2	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXMICN	LOAD	A,IFMIC	JUMP,EQ 10$	LOAD	IX,#TXMICO10$:	CALL	AFTEXT	LOAD	IX,#IFMIC	; IX <-- ^variable pour rponse	JUMP	DOOUINON	; traite rponse OUI/NONTXMICN:	.ASCIZ	"Micro:     [NON]"TXMICO:	.ASCIZ	"Micro:     [OUI]"DOF2C:	LOAD	A,#3	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXCO1N	LOAD	A,IFCON1	JUMP,EQ 10$	LOAD	IX,#TXCO1O10$:	CALL	AFTEXT	LOAD	IX,#IFCON1	; IX <-- ^variable pour rponse	JUMP	DOOUINON	; traite rponse OUI/NONTXCO1N:	.ASCIZ	"Porte 1:   [NON]"TXCO1O:	.ASCIZ	"Porte 1:   [OUI]"DOF2D:	LOAD	A,#4	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXCO2N	LOAD	A,IFCON2	JUMP,EQ 10$	LOAD	IX,#TXCO2O10$:	CALL	AFTEXT	LOAD	IX,#IFCON2	; IX <-- ^variable pour rponse	JUMP	DOOUINON	; traite rponse OUI/NONTXCO2N:	.ASCIZ	"Porte 2:   [NON]"TXCO2O:	.ASCIZ	"Porte 2:   [OUI]"DOF2E:	LOAD	A,#5	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXCO3N	LOAD	A,IFCON3	JUMP,EQ 10$	LOAD	IX,#TXCO3O10$:	CALL	AFTEXT	LOAD	IX,#IFCON3	; IX <-- ^variable pour rponse	JUMP	DOOUINON	; traite rponse OUI/NONTXCO3N:	.ASCIZ	"Porte 3:   [NON]"TXCO3O:	.ASCIZ	"Porte 3:   [OUI]"DOF2F:	LOAD	A,#0	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXCO4N	LOAD	A,IFCON4	JUMP,EQ 10$	LOAD	IX,#TXCO4O10$:	CALL	AFTEXT	LOAD	IX,#IFCON4	; IX <-- ^variable pour rponse	JUMP	DOOUINON	; traite rponse OUI/NONTXCO4N:	.ASCIZ	"Porte 4:   [NON]"TXCO4O:	.ASCIZ	"Porte 4:   [OUI]"; Traitement du bouton [F3] (info).DOF3:	LOAD	A,RANG		; A <-- rang du sous-menu	COMP	A,#7	JUMP,EQ	80$	COMP	A,#6	JUMP,EQ	70$	COMP	A,#5	JUMP,EQ	60$	COMP	A,#4	JUMP,EQ	50$	COMP	A,#3	JUMP,EQ	40$	COMP	A,#2	JUMP,EQ	30$	COMP	A,#1	JUMP,EQ	20$10$:	JUMP	DOF3A20$:	JUMP	DOF3B30$:	JUMP	DOF3C40$:	JUMP	DOF3D50$:	JUMP	DOF3E60$:	JUMP	DOF3F70$:	JUMP	DOF3G80$:	JUMP	DOF3HDOF3A:	LOAD	A,#1	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXRAP	CALL	AFTEXT	LOAD	A,NBRAP	JUMP	DOFF3TXRAP:	.ASCIZ	"Appels recus: "DOF3B:	LOAD	A,#2	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXEAP	CALL	AFTEXT	LOAD	A,NBEAP	JUMP	DOFF3TXEAP:	.ASCIZ	"Appels faux:  "DOF3C:	LOAD	A,#3	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXSAP	CALL	AFTEXT	LOAD	A,NBSAP	JUMP	DOFF3TXSAP:	.ASCIZ	"Appels faits: "DOF3D:	LOAD	A,#4	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXCON1	CALL	AFTEXT	LOAD	A,NBCON1	JUMP	DOFF3TXCON1:	.ASCIZ	"Porte 1:      "DOF3E:	LOAD	A,#5	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXCON2	CALL	AFTEXT	LOAD	A,NBCON2	JUMP	DOFF3TXCON2:	.ASCIZ	"Porte 2:      "DOF3F:	LOAD	A,#6	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXCON3	CALL	AFTEXT	LOAD	A,NBCON3	JUMP	DOFF3TXCON3:	.ASCIZ	"Porte 3:      "DOF3G:	LOAD	A,#7	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXCON4	CALL	AFTEXT	LOAD	A,NBCON4	JUMP	DOFF3TXCON4:	.ASCIZ	"Porte 4:      "DOF3H:	LOAD	A,#0	LOAD	RANGS,A		; RANGS <-- rang du sous-menu suivant	LOAD	IX,#TXSURV	CALL	AFTEXT	LOAD	B,#'0	LOAD	A,SURVH	CALL	AFDECB		; affiche les heures	LOAD	A,#':	CALL	AFCAR		; affiche ":"	LOAD	A,SURVM	CALL	AFDECB		; affiche les minutes	LOAD	A,#':	CALL	AFCAR		; affiche ":"	LOAD	A,SURVS	SRC	A		; A <-- /2	CALL	AFDECB		; affiche les secondes	JUMP	DOFF3LTXSURV:	.ASCIZ	"Temps:  "		;        12:00:00;DOFF3:	LOAD	B,A	CALL	AFDEC		; affiche le nombre (information)	COMP	B,#10		; nombre  2 digits ?	JUMP,HS DOFF3L		; oui => DOFF3L	LOAD	A,#SPACE	; non =>	CALL	AFCAR		; affiche un espace pour enlever le curseur !DOFF3L:	CALL	GETCAR		; attend une touche ...	COMP	A,#F1	JUMP,EQ	DOFF	COMP	A,#F2	JUMP,EQ	DOFF	COMP	A,#F3	JUMP,EQ	DOFF	COMP	A,#ENTER	JUMP,EQ	DOFF	JUMP	DOFF3L                      DOOUINON:20$:	CALL	GETCAR		; attend une touche ...	COMP	A,#F1	JUMP,EQ	DOFF	COMP	A,#F2	JUMP,EQ	DOFF	COMP	A,#F3	JUMP,EQ	DOFF	COMP	A,#ENTER	JUMP,EQ	DOFF	COMP	A,#'0	JUMP,EQ 30$	COMP	A,#CLEAR	JUMP,NE 20$				; NON =>	LOAD	A,#0	LOAD	(IX),A		; rponse <-- zro	JUMP	LOOP30$:				; OUI =>	LOAD	A,#1	LOAD	(IX),A		; rponse <-- un	JUMP	LOOPDOF:	CALL	GETLINE		; attend une ligne ...DOFF:	COMP	A,#ENTER	JUMP,EQ SURVEILLE0	COMP	A,FONC	JUMP,EQ 20$	LOAD	FONC,A	JUMP	LOOP020$:	LOAD	A,RANGS	LOAD	RANG,A		; RANG <-- rang du sous-menu suivant	JUMP	LOOP; Traitement du bouton vert (run/stop).SURVEILLE0:	LOAD	A,#0	LOAD	SURVS,A		; zro secondes	LOAD	SURVM,A		; zro minutes	LOAD	SURVH,A		; zro heuresSURVEILLE:	LOAD	A,BUTEL	COMP	A,#0		; numro existe ?	JUMP,NE 05$		; oui => 05$				; non =>	CALL	AFEOP	LOAD	IX,#TXSUR2	CALL	AFTEXT		; affiche "numro inconnu !"	LOAD	A,#100*2	CALL	WAITMS		; attend 2s	LOAD	A,#F1	LOAD	FONC,A		; FONC <-- redemande le numro	JUMP	LOOP005$:	CALL	AFEOP	LOAD	IX,#TXSUR1	CALL	AFTEXT		; affiche "Je surveille..."	LOAD	A,#SPACE	LOAD	MARQUE,A	LOAD	IX,#110$:	DEC	IX	JUMP,NE 30$	LOAD	IX,#1488	; IX <-- frquence de clignotement (1s)	LOAD	A,#15	CALL	SETCURS		; met le curseur tout  droite	LOAD	A,MARQUE	CALL	AFCAR		; affiche la marque	LOAD	B,#SPACE	; B <-- blanc	COMP	A,B	JUMP,NE 20$	LOAD	B,#LEFT		; B <-- flche "<-"20$:	LOAD	MARQUE,B	LOAD	A,SURVS	INC	A		; SURVS <-- 1/2 seconde de plus	LOAD	SURVS,A	COMP	A,#60*2	JUMP,LO 30$	LOAD	A,#0	LOAD	SURVS,A	LOAD	A,SURVM	INC	A		; SURVM <-- une minute de plus	LOAD	SURVM,A	COMP	A,#60	JUMP,LO 30$	LOAD	A,#0	LOAD	SURVM,A	LOAD	A,SURVH	INC	A		; SURVH <-- une heure de plus	LOAD	SURVH,A30$:	CALL	CRI?		; un cri ?	JUMP,CS 50$	CALL	SONNE?		; quelqu'un sonne ?	JUMP,CS 51$	CALL	CONTACT?	; un contact ferm ?	JUMP,CS 52$	CALL	IFCAR		; une touche appuye ?	COMP	A,#ENTER	JUMP,NE 10$	JUMP	LOOP50$:	JUMP	DOCRI51$:	JUMP	DOSONNE52$:	JUMP	DOCONTACTTXSUR1:	.ASCIZ	"Je surveille..."TXSUR2:	.ASCIZ	"No tel inconnu !"DOCRI:				; on a cri =>	CALL	AFEOP	LOAD	IX,#TXCRI1	CALL	AFTEXT;;?	LOAD	A,#100;;?	CALL	WAITMS		; attend 1s ...	LOAD	A,NBSAP	INC	A		; NBSAP <-- un appel fait de plus	LOAD	NBSAP,A	CALL	APPEL		; appelle le numro choisi ...	JUMP	DOAPPELTXCRI1:	.ASCIZ	"On a crie !"DOSONNE:				; on a sonn =>	CALL	AFEOP	LOAD	IX,#TXSON1	CALL	AFTEXT	LOAD	B,#10*6		; B <-- 6 secondes20$:	LOAD	A,#10	CALL	WAITMS		; attend 0.1s ...	DEC	B	JUMP,EQ 80$	CALL	SONNE?		; deuxime coup de sonnerie ?	JUMP,CC 20$		; non => 20$	LOAD	A,CODE		; appels cods ?	JUMP,EQ 50$		; non => 50$				; oui =>	LOAD	B,#10*25	; B <-- 25 secondes30$:	LOAD	A,#10	CALL	WAITMS		; attend 0.1s ...	DEC	B	JUMP,EQ 80$	CALL	SONNE?		; troisime coup de sonnerie ?	JUMP,CC 30$		; non => 30$	COMP	B,#10*(25-6)	; troisime coup  la suite ?	JUMP,LO 50$		; non => 50$ (ok, t'a pig l'code)	LOAD	B,#10*25	; B <-- 25 secondes40$:	LOAD	A,#10	CALL	WAITMS		; attend 0.1s ...	DEC	B	JUMP,EQ 80$	CALL	SONNE?		; quatrime coup de sonnerie ?	JUMP,CC 40$		; non => 40$	COMP	B,#10*(25-6)	; quatrime coup  la suite ?	JUMP,HS 90$		; oui => DOFAUX (dsol, mais y'a un code)50$:	LOAD	A,NBRAP	INC	A		; NBSAP <-- un appel reu de plus	LOAD	NBRAP,A	CALL	DECROCHE	; dcroche la cornette	JUMP	DOAPPEL80$:	JUMP	SURVEILLE90$:	JUMP	DOFAUXTXSON1:	.ASCIZ	"Quelqu'un sonne"DOCONTACT:	COMP	A,#'4		; porte 4 ?	JUMP,EQ 40$	COMP	A,#'3		; porte 3 ?	JUMP,EQ 30$	COMP	A,#'2		; porte 2 ?	JUMP,EQ 20$10$:	LOAD	A,IFCON1	; sensible  cette porte ?	JUMP,EQ 80$		; non => 80$	CALL	AFEOP	LOAD	IX,#TXCOF1	CALL	AFTEXT	LOAD	A,NBCON1	INC	A		; NBCON1 <-- un contact ferm de plus	LOAD	NBCON1,A	JUMP	50$20$:	LOAD	A,IFCON2	; sensible  cette porte ?	JUMP,EQ 80$		; non => 80$	CALL	AFEOP	LOAD	IX,#TXCOF2	CALL	AFTEXT	LOAD	A,NBCON2	INC	A		; NBCON2 <-- un contact ferm de plus	LOAD	NBCON2,A	JUMP	50$30$:	LOAD	A,IFCON3	; sensible  cette porte ?	JUMP,EQ 80$		; non => 80$	CALL	AFEOP	LOAD	IX,#TXCOF3	CALL	AFTEXT	LOAD	A,NBCON3	INC	A		; NBCON3 <-- un contact ferm de plus	LOAD	NBCON3,A	JUMP	50$40$:	LOAD	A,IFCON4	; sensible  cette porte ?	JUMP,EQ 80$		; non => 80$	CALL	AFEOP	LOAD	IX,#TXCOF4	CALL	AFTEXT	LOAD	A,NBCON4	INC	A		; NBCON4 <-- un contact ferm de plus	LOAD	NBCON4,A;	JUMP	50$50$:	LOAD	A,#100*2	CALL	WAITMS		; attend 2s ...	LOAD	A,NBSAP	INC	A		; NBSAP <-- un appel fait de plus	LOAD	NBSAP,A	CALL	APPEL		; appelle le numro choisi ...	JUMP	DOAPPEL180$:	JUMP	SURVEILLETXCOF1:	.ASCIZ	"Porte 1 ouverte"TXCOF2:	.ASCIZ	"Porte 2 ouverte"TXCOF3:	.ASCIZ	"Porte 3 ouverte"TXCOF4:	.ASCIZ	"Porte 4 ouverte"; Appelle le numro de tlphone mmoris dans BUTEL, puis; attend le temps mmoris dans BUAPP.DOAPPEL:	LOAD	A,#0	LOAD	CONTNB,A	; CONTNB <-- pas un contact fermDOAPPEL1:	LOAD	IX,#TMU1	CALL	MUSIQUE		; musique de dbut ...	CALL	AFEOP	LOAD	IX,#TXAPP1	CALL	AFTEXT		; affiche "[F1] = raccroche"	LOAD	IX,#BUAPP	CALL	GETNUM		; A <-- nombre dans BUAPP	LOAD	B,A		; B <-- nb de secondes	LOAD	IX,#520$:	LOAD	A,#100/4	CALL	WAITMS		; attend 1/4 de seconde ...	DEC	B	JUMP,EQ 50$	DEC	IX		; encore 5 secondes de passes ?	JUMP,NE 35$		; non => 35$	LOAD	A,CONTNB	; A <-- contact ferm	LOAD	IX,#TMUC1	COMP	A,#'1	JUMP,EQ 30$	LOAD	IX,#TMUC2	COMP	A,#'2	JUMP,EQ 30$	LOAD	IX,#TMUC3	COMP	A,#'3	JUMP,EQ 30$	LOAD	IX,#TMUC4	COMP	A,#'4	JUMP,NE 32$30$:	CALL	MUSIQUE		; p'tite musique toute les 5s32$:	LOAD	IX,#535$:	CALL	IFCAR		; A <-- une touche presse ?	COMP	A,#F1		; [F1] = raccroche ?	JUMP,EQ 50$		; oui => 50$	LOAD	A,#100/4	CALL	WAITMS		; attend 1/4 de seconde ...	CALL	IFCAR		; A <-- une touche presse ?	COMP	A,#F1		; [F1] = raccroche ?	JUMP,EQ 50$		; oui => 50$	LOAD	A,#100/4	CALL	WAITMS		; attend 1/4 de seconde ...	CALL	IFCAR		; A <-- une touche presse ?	COMP	A,#F1		; [F1] = raccroche ?	JUMP,EQ 50$		; oui => 50$	LOAD	A,#100/4	CALL	WAITMS		; attend 1/4 de seconde ...	CALL	IFCAR		; A <-- une touche presse ?	COMP	A,#F1		; [F1] = raccroche ?	JUMP,NE 20$		; non => 20$50$:				; oui =>	CALL	AFEOP	LOAD	IX,#TXAPP2	CALL	AFTEXT	LOAD	IX,#TMU2	CALL	MUSIQUE		; musique de fin ...	CALL	RACCROCHE	; racroche la cornette	JUMP	SURVEILLETXAPP1:	.ASCIZ	"[F1] = raccroche"TXAPP2:	.ASCIZ	"OK, je raccroche"; En cas d'appel sans code, attend que l'appelant arrte de sonner.DOFAUX:	LOAD	A,NBEAP	INC	A		; NBEAP <-- un appel reu sans code de plus	LOAD	NBEAP,A	CALL	AFEOP	LOAD	IX,#TXERR1	CALL	AFTEXT20$:	LOAD	B,#10*6		; B <-- 6 secondes30$:	LOAD	A,#10	CALL	WAITMS		; attend 0.1s ...	DEC	B	JUMP,EQ 50$	CALL	SONNE?		; encore un coup de sonnerie ?	JUMP,CC 30$		; non => 30$	JUMP	20$		; oui => 20$50$:	JUMP	SURVEILLETXERR1:	.ASCIZ	"Appel sans code!"; Appels systme volus; ----------------------;--------\\; APPEL   >;========/; Appel le numro dans BUTEL.; in	-; out	-; mod	F,A,B,IXAPPEL:	CALL	AFEOP		; efface tout	LOAD	IX,#00$	CALL	AFTEXT	CALL	DECROCHE	; dcroche la cornette	LOAD	IX,#BUTEL20$:	LOAD	A,(IX)	INC	IX	COMP	A,#'0	JUMP,LO 25$	COMP	A,#'9	JUMP,HI 25$	CALL	AFCAR		; affiche le chiffre	SUB	A,#'0		; A <-- 0..9	CALL	COMPOSE		; compose un chiffre	JUMP	20$25$:90$:	RET00$:	.ASCIZ	"Fait le ";--------\\; GETLINE >;========/; Attend une ligne de chiffres.; in	IX	^buffer;	B	lg max du buffer; out	A	dernire touche; mod	F,AGETLINE:	PUSH	B	PUSH	IX	LOAD	A,CPOS	LOAD	SAVPOS,A	; SAVPOS <-- position du curseur	LOAD	SAVLGB,B	; SAVLGB <-- lg max buffer	LOAD	SAVPTB,IX	; SAVPTB <-- ^buffer	CALL	AFTEXT		; affiche le chiffre actuel	LOAD	A,SAVPOS;;?	DEC	A		; A <-- curseur juste devant	CALL	SETCURS	LOAD	IX,SAVPTB10$:	CALL	GETCAR		; A <-- attend une touche	COMP	A,#CLEAR	JUMP,EQ 50$	COMP	A,#'0	JUMP,LO 90$	COMP	A,#'9	JUMP,HI 90$				; 0..9 =>	COMP	B,#0	JUMP,EQ 10$	DEC	B	LOAD	(IX),A		; buffer <-- chiffre	INC	IX	LOAD	A,#0	LOAD	(IX),A	CALL	AFFLINE		; affiche toute la ligne	JUMP	10$50$:				; CLEAR =>	LOAD	IX,SAVPTB	LOAD	B,SAVLGB	LOAD	A,#0	LOAD	(IX),A	CALL	AFFLINE		; affiche toute la ligne	JUMP	10$90$:	POP	IX	POP	B	RET;--------\\; AFFLINE >;--------/; Pour GETLINE: Affiche toute la ligne.; in	-; out	-; mod	FAFFLINE:	PUSH	A	PUSH	B	PUSH	IX	LOAD	A,SAVPOS	CALL	SETCURS		; remet le curseur au dbut	LOAD	IX,SAVPTB	LOAD	B,SAVLGB20$:	LOAD	A,(IX)	INC	IX	COMP	A,#0		; fin du texte ?	JUMP,EQ 40$		; oui => 40$	CALL	AFCAR		; affiche un caractre	DEC	B	JUMP,NE 20$	JUMP	90$40$:	LOAD	A,CPOS	PUSH	A50$:	LOAD	A,#SPACE	CALL	AFCAR		; efface la fin de la ligne	DEC	B	JUMP,NE 50$	POP	A	CALL	SETCURS90$:	POP	IX	POP	B	POP	A	RET;--------\\; GETNUM  >;========/; in	IX	^nombre en ASCII; out	A	nombre; mod	F,A,IXGETNUM:	PUSH	B	LOAD	A,#0		; A <-- futur nombre10$:	LOAD	B,(IX)	COMP	B,#'0	JUMP,LO 90$	COMP	B,#'9	JUMP,HI 90$	SLC	A	LOAD	B,A	SLC	A	SLC	A	ADD	A,B		; A <-- A *10	LOAD	B,(IX)	SUB	B,#'0	ADD	A,B		; A <-- nouveau digit	INC	IX	JUMP	10$90$:	POP	B	RET; Gestion de l'affichage; ----------------------;--------\\; AFEOP   >;========/; Efface tout le LCD.; in	-; out	-; mod	F,AAFEOP:	LOAD	A,#0	LOAD	CPOS,A	LOAD	A,#B'00000001	; A <-- efface tout	CALL	AFCOMM	LOAD	A,#1640/10	; A <-- 1.64ms	JUMP	WAITUS;--------\\; AFDEC   >;========/; Affiche un nombre dcimal compris entre 0 et 99, sans; les zro non significatifs.; in	A	nombre; out	-; mod	F,AAFDEC:	PUSH	B	LOAD	B,#0		; B <-- n'affiche pas les zro non significatifs	CALL	AFDECB	POP	B	RET;--------\\; AFDECB  >;========/; Affiche un nombre dcimal compris entre 0 et 99.; Avec un peu plus de temps, on peut surement crire; beaucoup mieux cette routine !; in	A	nombre;	B	caractre  la place des zro non significafifs; out	-; mod	F,AAFDECB:	PUSH	B	COMP	A,#90	JUMP,HS 91$	COMP	A,#80	JUMP,HS 81$	COMP	A,#70	JUMP,HS 71$	COMP	A,#60	JUMP,HS 60$	COMP	A,#50	JUMP,HS 50$	COMP	A,#40	JUMP,HS 40$	COMP	A,#30	JUMP,HS 30$	COMP	A,#20	JUMP,HS 20$	COMP	A,#10	JUMP,HS 10$	COMP	B,#0	JUMP,EQ 95$	PUSH	A	LOAD	A,B	CALL	AFCAR	POP	A;	SUB	A,#0	JUMP	95$71$:	JUMP	70$81$:	JUMP	80$91$:	JUMP	90$10$:	PUSH	A	LOAD	A,#'1	CALL	AFCAR	POP	A	SUB	A,#10	JUMP	95$20$:	PUSH	A	LOAD	A,#'2	CALL	AFCAR	POP	A	SUB	A,#20	JUMP	95$30$:	PUSH	A	LOAD	A,#'3	CALL	AFCAR	POP	A	SUB	A,#30	JUMP	95$40$:	PUSH	A	LOAD	A,#'4	CALL	AFCAR	POP	A	SUB	A,#40	JUMP	95$50$:	PUSH	A	LOAD	A,#'5	CALL	AFCAR	POP	A	SUB	A,#50	JUMP	95$60$:	PUSH	A	LOAD	A,#'6	CALL	AFCAR	POP	A	SUB	A,#60	JUMP	95$70$:	PUSH	A	LOAD	A,#'7	CALL	AFCAR	POP	A	SUB	A,#70	JUMP	95$80$:	PUSH	A	LOAD	A,#'8	CALL	AFCAR	POP	A	SUB	A,#80	JUMP	95$90$:	PUSH	A	LOAD	A,#'9	CALL	AFCAR	POP	A	SUB	A,#90;	JUMP	95$95$:	ADD	A,#'0	CALL	AFCAR	POP	B	RET;--------\\; AFTEXT  >;========/; Affiche un texte termin par zro.; in	IX	^texte; out	IX	^plus loin; mod	F,A,IXAFTEXT:10$:	LOAD	A,(IX)	JUMP,EQ 90$	CALL	AFCAR		; affiche un caractre	INC	IX	JUMP	10$90$:	RET;--------\\; AFCAR   >;========/; Affiche un caractre sur le LCD.; in	A	caractre  afficher; out	-; mod	FAFCAR:	PUSH	A	PUSH	B	LOAD	B,A	PUSH	B	AND	B,#B'11110000	LOAD	A,DATA3	AND	A,#B'00001111	OR	A,#B'00001100	ADD	A,B	LOAD	DATA3,A	CALL	LCDPULSE	POP	B	RLC	B	RLC	B	RLC	B	RLC	B	AND	B,#B'11110000	AND	A,#B'00001111	OR	A,#B'00001100	ADD	A,B	LOAD	DATA3,A	CALL	LCDPULSE	LOAD	A,#40/10	; A <-- 40us	CALL	WAITUS	INC	CPOS	POP	B	POP	A	RET;--------\\; SETCURS >;========/; Positionne le curseur.; in	A	position (0..15); out	-; mod	F,ASETCURS:	LOAD	CPOS,A	OR	A,#B'10000000	; A <-- set DD RAM	JUMP	AFCOMM;--------\\; LCDINIT >;--------/; Reset le LCD. Il faut respecter tout un protocole pas; vraiment clair (voir manuel HITACHI) !; in	-; out	-; mod	F,ALCDINIT:	LOAD	A,#B'00110000	; A <-- fonction 8 bits	CALL	AFCOMM4	LOAD	A,#1		; A <-- 10ms	CALL	WAITMS	LOAD	A,#B'00110000	; A <-- fonction 8 bits	CALL	AFCOMM4	LOAD	A,#100/10	; A <-- 100us	CALL	WAITUS	LOAD	A,#B'00100000	; A <-- fonction 4 bits	CALL	AFCOMM4	LOAD	A,#B'00100000	; A <-- fonction 1 ligne et 5x7	CALL	AFCOMM	LOAD	A,#B'00001110	; A <-- display ON, cursor ON et blink OFF	CALL	AFCOMM	LOAD	A,#B'00000001	; A <-- efface tout	CALL	AFCOMM	LOAD	A,#1640/10	; A <-- 1.64ms	CALL	WAITUS	LOAD	A,#B'00000110	; A <-- mode d'entre incrmental	CALL	AFCOMM	LOAD	A,#0	LOAD	CPOS,A	RET;--------\\; AFCOMM  >;========/; Envoie une commande 8 bits au LCD.; in	A	commande; out	-; mod	FAFCOMM:	PUSH	A	PUSH	B	LOAD	B,A	PUSH	B	AND	B,#B'11110000	LOAD	A,DATA3	AND	A,#B'00000111	OR	A,#B'00000100	ADD	A,B	LOAD	DATA3,A	CALL	LCDPULSE	POP	B	RLC	B	RLC	B	RLC	B	RLC	B	AND	B,#B'11110000	AND	A,#B'00000111	OR	A,#B'00000100	ADD	A,B	LOAD	DATA3,A	CALL	LCDPULSE	LOAD	A,#40/10	; A <-- 40us	CALL	WAITUS	POP	B	POP	A	RET;--------\\; AFCOMM4 >;========/; Envoie une commande 4 bits au LCD.; in	A	commande; out	-; mod	FAFCOMM4:	PUSH	A	PUSH	B	LOAD	B,A	AND	B,#B'11110000	LOAD	A,DATA3	AND	A,#B'00000111	OR	A,#B'00000100	ADD	A,B	LOAD	DATA3,A	CALL	LCDPULSE	LOAD	A,#40/10	; A <-- 40us	CALL	WAITUS	POP	B	POP	A	RET;---------\\; LCDPULSE >;---------/; Effectue une pulse sur la ligne E du LCD d'au moins 450ns.; in	-; out	-; mod	FLCDPULSE:	PUSH	A	LOAD	A,DATA3	AND	A,#B'11111011	LOAD	DATA3,A		; flanc descendant	OR	A,#B'00000100	LOAD	DATA3,A		; flanc montant	POP	A	RET; Gestion du clavier; ------------------;--------\\; GETCAR  >;========/; Attend une touche du clavier.; in	-; out	A	touche presse; mod	F,AGETCAR:	PUSH	B10$:	CALL	BALCLA		; A <-- touche presse	COMP	A,#0		; une touche presse ?	JUMP,EQ 10$		; non => 10$	LOAD	B,A		; B <-- touche presse20$:	CALL	BALCLA		; A <-- touche presse	COMP	A,#0		; une touche presse ?	JUMP,NE 20$		; oui => 20$	LOAD	A,B		; A <-- touche presse	POP	B	RET;--------\\; IFCAR   >;========/; Regarde si une touche du clavier est presse.; in	-; out	A	touche presse; mod	F,AIFCAR:	PUSH	B	CALL	BALCLA		; A <-- touche presse	COMP	A,#0		; une touche presse ?	JUMP,EQ 90$		; non => 90$	LOAD	B,A		; B <-- touche presse20$:	CALL	BALCLA		; A <-- touche presse	COMP	A,#0		; une touche presse ?	JUMP,NE 20$		; oui => 20$	LOAD	A,B		; A <-- touche presse90$:	POP	B	RET;--------\\; BALCLA  >;--------/; Balaye le clavier pour trouver la premire touche presse.; in	-; out	A	touche presse; mod	F,ABALCLA:	PUSH	B	PUSH	IX	LOAD	IX,#TAKEY	; IX <-- ^table des touches	LOAD	B,#H'FE10$:	LOAD	DATA4,B		; slectionne une colonne	NOP	LOAD	A,DATA4		; A <-- lit une ligne	RLC	A	JUMP,CC	80$	INC	IX	RLC	A	JUMP,CC	80$	INC	IX	RLC	A	JUMP,CC	80$	INC	IX	RLC	A	JUMP,CC	80$	INC	IX	SETC	RLC	B		; B <-- colonne suivante	COMP	B,#H'EF	JUMP,NE 10$	LOAD	A,#0		; A <-- aucune touche presse	JUMP	90$80$:	LOAD	A,(IX)		; A <-- touche presse90$:	LOAD	B,#H'FF	LOAD	DATA4,B	POP	IX	POP	B	RET; Tables des touches du clavier; ----------------------------TAKEY:	.B	0	'1	'4	'7	; colonne 1	.B	'0	'2	'5	'8	; colonne 2	.B	ENTER	F1	F2	F3	; colonne 3	.B	CLEAR	'3	'6	'9	; colonne 4; Dtection d'vnements extrieurs; ---------------------------------;--------\\; CRI?    >;--------/; Regarde si quelqu'un crie (dans le micro).; in	-; out	CC	pas de cri;	CS	on a cri; mod	F,ACRI?:	PUSH	B	PUSH	IX	LOAD	A,IFMIC		; sensible au micro ?	JUMP,NE 05$		; oui => 05$				; non =>	NOP	NOP	NOP	JUMP	90$05$:	LOAD	A,DATA1	AND	A,#B'00000010	JUMP,NE 90$	LOAD	A,#15	CALL	SETCURS		; met le curseur tout  droite	LOAD	A,#'*	CALL	AFCAR		; affiche un "*"	LOAD	IX,#BUCRI	CALL	GETNUM		; A <-- nombre dans BUCRI	LOAD	COUNT1+1,A	; COUNT1+1 <-- dure des cris	LOAD	A,#0 	LOAD	COUNT1+0,A	; COUNT1+0 <-- zro	LOAD	IX,#4000	LOAD	COUNT2,IX10$:	LOAD	IX,COUNT2	DEC	IX	LOAD	COUNT2,IX	JUMP,NE 12$	LOAD	A,COUNT1+0	INC	A		; COUNT1+0 <-- temps o signal = 1	LOAD	COUNT1+0,A	COMP	A,COUNT1+1	; a-t-on cri assez longtemps ?	JUMP,HS 80$		; oui => 80$	LOAD	IX,#4000	LOAD	COUNT2,IX12$:	LOAD	A,DATA1	AND	A,#B'00000010	JUMP,EQ 10$	LOAD	IX,#5000	LOAD	COUNT0,IX15$:	LOAD	IX,COUNT2	DEC	IX	LOAD	COUNT2,IX	JUMP,NE 17$	LOAD	A,COUNT1+0	INC	A		; COUNT1+0 <-- temps o signal = 1	LOAD	COUNT1+0,A	COMP	A,COUNT1+1	; a-t-on cri assez longtemps ?	JUMP,HS 80$		; oui => 80$	LOAD	IX,#4000	LOAD	COUNT2,IX17$:	LOAD	IX,COUNT0	DEC	IX	LOAD	COUNT0,IX	JUMP,EQ 90$	LOAD	A,DATA1	AND	A,#B'00000010	JUMP,NE 15$	JUMP	10$80$:	POP	IX	POP	B	SETC			; CS => on a cri	RET90$:	POP	IX	POP	B	CLRC			; CC => pas de cris	RET;--------\\; SONNE?  >;--------/; Regarde si quelqu'un sonne.; in	-; out	CC	pas de sonnerie;	CS	on a sonn; mod	F,ASONNE?:	PUSH	IX	LOAD	A,DATA1	AND	A,#B'00000001	JUMP,NE 90$	LOAD	IX,#0 	LOAD	COUNT1,IX10$:	LOAD	IX,COUNT1	INC	IX		; COUNT1 <-- temps o signal = 1	LOAD	COUNT1,IX	LOAD	A,DATA1	AND	A,#B'00000001	JUMP,EQ 10$	LOAD	IX,#1000	LOAD	COUNT0,IX15$:	LOAD	IX,COUNT1	INC	IX		; COUNT1 <-- temps o signal = 1	LOAD	COUNT1,IX	LOAD	IX,COUNT0	DEC	IX	LOAD	COUNT0,IX	JUMP,EQ 20$	LOAD	A,DATA1	AND	A,#B'00000001	JUMP,NE 15$	JUMP	10$20$:	LOAD	IX,#10000	COMP	IX,COUNT1	JUMP,HS 90$80$:	POP	IX	SETC			; CS => on a sonn	RET90$:	POP	IX	CLRC			; CC => pas de sonnerie	RET;---------\\; CONTACT? >;---------/; Regarde si un flan 1\0 d'un contact survient.; in	-; out	CC	pas de contact;	CS	on a ferm un contact;	A	contact ferm ('1..'4); mod	F,ACONTACT?:	PUSH	B	PUSH	IX	LOAD	A,DATA1	LOAD	B,A	CPL	B	AND	B,CONTACT	LOAD	CONTACT,A	AND	B,#B'11110000	; B <-- 01000000 (1=contact ferm)	COMP	B,#0		; un nouveau contact ferm ?	JUMP,EQ 90$		; non => 90$	LOAD	CONTNB,B	LOAD	IX,#10000	; IX <-- dure des rebonds de contacts30$:	LOAD	A,DATA1	LOAD	CONTACT,A	CPL	A	AND	A,#B'11110000	AND	A,CONTNB	; contact toujours ferm ?	JUMP,EQ 90$		; non => 90$	DEC	IX	JUMP,NE 30$	LOAD	A,#'4+140$:	DEC	A	RLC	B	JUMP,CC 40$	LOAD	CONTNB,A	; CONTNB <-- contact ferm	POP	IX	POP	B	SETC			; CS => un contact ferm	RET90$:	POP	IX	POP	B	CLRC			; CC => pas de contact ferm	RET; Emission de bips; ----------------;--------\\; MUSIQUE >;========/; in	IX	^tyble musique; out	-; mod	F,A,IXMUSIQUE:10$:	LOAD	A,(IX)		; A <-- une note	INC	IX	COMP	A,#0		; fin de la table ?	JUMP,EQ 90$		; oui => 90$	CALL	BIP	JUMP	10$90$:	RET;--------\\; BIP     >;========/; in	A	note; out	-; mod	F,ABIP:	PUSH	B	LOAD	NOTE,A	LOAD	B,#10010$:	LOAD	A,NOTE	CALL	WAITUS		; attend ...	LOAD	A,DATA1	OR	A,#B'00000100	LOAD	DATA1,A	LOAD	A,NOTE	CALL	WAITUS		; attend ...	LOAD	A,DATA1	AND	A,#B'11111011	LOAD	DATA1,A	DEC	B	JUMP,NE 10$	POP	B	RETTMU1:	.B	DO,MI,SOL,DO1,DO1,DO,MI,SOL,DO1,DO1,0TMU2:	.B	DO1,SOL,MI,DO,DO,DO1,SOL,MI,DO,DO,0TMUC1:	.B	DO1/2,SOL/2,DO1/2,SOL/2,0TMUC2:	.B	DO1/2,SOL/2,DO1/2,0TMUC3:	.B	DO1/2,SOL/2,0TMUC4:	.B	DO1/2,0; Composition de numros; ----------------------;---------\\; DECROCHE >;=========/; Dcroche la cornette.; in	-; out	-; mod	F,ADECROCHE:	LOAD	A,DATA3	OR	A,#B'00000001	; A <-- tire le relai "f"	LOAD	DATA3,A	LOAD	A,#100*2	CALL	WAITMS		; attend 2s	RET;----------\\; RACCROCHE >;==========/; Repose la cornette.; in	-; out	-; mod	F,ARACCROCHE:	LOAD	A,DATA3	AND	A,#B'11111110	; A <-- relche le relai "f"	LOAD	DATA3,A	RET;--------\\; COMPOSE >;========/; Compose juste un chiffre.; in	A	numro (0..9); out	-; mod	F,ACOMPOSE:	PUSH	B	COMP	A,#0	JUMP,NE 10$	LOAD	A,#10		; A <-- 10 impulsions pour un zro10$:	LOAD	B,A20$:	LOAD	A,DATA3	OR	A,#B'00000010	; A <-- tire le relai "i"	LOAD	DATA3,A	LOAD	A,#6	CALL	WAITMS		; attend 60ms	LOAD	A,DATA3	AND	A,#B'11111101	; A <-- relche le relai "i"	LOAD	DATA3,A	LOAD	A,#4	CALL	WAITMS		; attend 40ms	DEC	B	JUMP,NE 20$	LOAD	A,#60	CALL	WAITMS		; attend 600ms	POP	B	RET;--------\\; WAITMS  >;--------/; Attend un peu ...; in	A	attente (unit: 10ms); out	-; mod	F,AWAITMS:	PUSH	IX10$:	LOAD	IX,#10000/4	; IX <-- 10ms/4us20$:	DEC	IX		;  1 cycle	JUMP,NE 20$		;  3 cycles				; ---	DEC	A		;  4 cycles au total	JUMP,NE 10$	POP	IX	RET;--------\\; WAITUS  >;--------/; Attend un peu ...; in	A	attente (unit: 10us); out	-; mod	F,AWAITUS:10$:	NOP			;  1 cycle	NOP			;  1 cycle	NOP			;  1 cycle	NOP			;  1 cycle	NOP			;  1 cycle	NOP			;  1 cycle	NOP			;  1 cycle	DEC	A		;  3 cycles	JUMP,NE	10$		; ---	RET			; 10 cycles au total; REMARQUE:	1 cycle du processeur dure 1us !; Initialisation; --------------;--------\\; INIPER  >;========/; in	IX	^table; out	-; mod	F,A,B,IXINIPER:10$:	LOAD	B,(IX)+0	; B <-- adresse	COMP	B,#-1	JUMP,EQ 90$	LOAD	A,(IX)+1	; A <-- data	PUSH	IX	LOAD	IX,#REG	ADD	IX,B		; IX <-- adresse	LOAD	(IX),A		; (adresse) <-- data	POP	IX	INC	IX	INC	IX	JUMP	10$90$:	RET; Dans le deuxime byte: 0=input 1=outputTAINIT:	.B	DDIR1,B'00000100	; dtecteurs + contacts	.B	DDIR2,B'00000000	.B	DDIR3,B'11111111	; LCD + relais	.B	DDIR4,B'00001111	; clavier	.B	DATA3,B'11111100	; tout le LCD  1 et relais relchs	.B	-1			; fin de la table; Vecteurs  la fin de la mmoire; -------------------------------	.LOC	ROM+LROM-H'10	.W	START		; SCI	.W	START		; TOF	.W	START		; OCF	.W	START		; ICF	.W	START		; IRQ	.W	START		; SWI	.W	START		; NMI	.W	START		; RESET	.END	START