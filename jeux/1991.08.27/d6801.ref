	.TITLE	DEF6801		; Dfinitions pour interface 6801	.PROC	M6801PCRAM	= 6PCROM	= 7SPACE	= H'20ON	= 1OFF	= 0IN	= 0OUT	= 1; Internal registers	.LOC	0DDR1:	.BLKB	1	; Data Direction Register port 1DDR2:	.BLKB	1	; Data Direction Register port 2PORT1:	.BLKB	1	; Adresse du port 1PORT2:	.BLKB	1	; Adresse du port 2P10	= 2^0		; Position du bit 0, port 1P11	= 2^1		; Position du bit 1, port 1P12	= 2^2		; Position du bit 2, port 1P13	= 2^3		; Position du bit 3, port 1P14	= 2^4		; Position du bit 4, port 1P15	= 2^5		; Position du bit 5, port 1P16	= 2^6		; Position du bit 6, port 1P17	= 2^7		; Position du bit 7, port 1P20	= 2^0		; Position du bit 0, port 2P21	= 2^1		; Position du bit 1, port 2P22	= 2^2		; Position du bit 2, port 2P23	= 2^3		; Position du bit 3, port 2P24	= 2^4		; Position du bit 4, port 2 IC_L	= P20		; Entre du "Input Capture" OC_L	= P21		; Sortie du "Output Compare" CK_L	= P22		; Entre/Sortie de l'horloge RX_L	= P23		; Ligne rception srie TX_L	= P24		; Ligne transmission srieDDR3:	.BLKB	1	; Data Direction Register port 3DDR4:	.BLKB	1	; Data Direction Register port 4PORT3:	.BLKB	1	; Adresse du port 3PORT4:	.BLKB	1	; Adresse du port 4TCSR:	.BLKB	1	; Timer Control and Status Register BOLVL	= 0		; Bit Output LeVeL  OLVL	= 2^0 BIEDG	= 1		; Bit Input EDGe  IEDG	= 2^1   DOWN	= 0		; Transfert sur flan descendant   UP	= 1		; Transfert sur flan montant BETOI	= 2		; Bit Enable Timer Overflow Int.  ETOI	= 2^2 BEOCI	= 3		; Bit Enable Output Compare Int.  EOCI	= 2^3 BEICI	= 4		; Bit Enable Input Capture Int.  EICI	= 2^4 BTOF	= 5		; Bit Timer Overflow Flag  TOF	= 2^5 BOCF	= 6		; Bit Output Compare Flag  OCF	= 2^6 BICF	= 7		; Bit Input Capture Flag  ICF	= 2^7CT:H_CT:	.BLKB	1	; High byte CounTerL_CT:	.BLKB	1	; Low byte CounTerOC:H_OC:	.BLKB	1	; High byte Output CompareL_OC:	.BLKB	1	; Low byte Output CompareIC:H_IC:	.BLKB	1	; High byte Input CaptureL_IC:	.BLKB	1	; Low byte Input CaptureP3CSR:	.BLKB	1	; I/O Port 3 Control and Status Register BLE	= 3		; Bit Latch enable  LE	= 2^3 BOSS	= 4		; Bit Output Strobe Select  OSS	= 2^4 BIS3E	= 6		; Bit IS3 Enable  IS3E	= 2^6 BIS3F	= 7		; Bit IS3 Flag  IS3F	= 2^7RMCR:	.BLKB	1	; Rate and Mode Control Register .RDX	4 MAXSPEED = 0		; Dbit maximum phi/16 MINSPEED = 1		; Dbit minimum BIPHASE  = 00		; Mode bi-phas, horloge interne NRZ      = 10		; Mode NRZ, horloge interne NRZ_OUT  = 20		; Mode NRZ, horloge interne en sortie NRZ_IN   = 30		; Mode NRZ, horloge externe .RDX	16.TRCSR:	.BLKB	1	; Transmit/Receive Control and Status Reg. BWU	= 0		; Bit Wake Up  WU	= 2^0 BTE	= 1		; Bit Transmit Enable  TE	= 2^1 BTIE	= 2		; Bit Transmit Int. Enable  TIE	= 2^2 BRE	= 3		; Bit Receive Enable  RE	= 2^3 BRIE	= 4		; Bit Receive Int. Enable  RIE	= 2^4 BTDRE	= 5		; Bit Transmit Data Register Empty  TDRE	= 2^5 BORFE	= 6		; Bit OverRun or Framimg Error  ORFE	= 2^6 BRDRF	= 7		; Bit Receive Data Register Full  RDRF	= 2^7SRDR:	.BLKB	1	; Serial Receive Data RegisterSTDR:	.BLKB	1	; Serial Tranmit Data RegisterRAMCR:	.BLKB	1	; RAM Control Register BRAME	= 6		; Bit RAM Enable (set for intern RAM use)  RAME	= 2^6 BSTBY	= 7		; Bit STand BY power (clear when no supply)  STBY	= 2^7	.PC	PCRAMBRAM	= H'80ERAM	= H'FF	.PC	PCROM	.LOC	H'FFF0		; Int. VectorsINT_VECT:SC_INT:	.BLKW	1		; Serial Input/OutputTOV_INT:.BLKB	1		; Timer OVerflow Int.TOC_INT:.BLKB	1		; Timer Output Compare Int.TIC_INT:.BLKB	1		; Timer Input Capture Int.IRQ1:	.BLKB	1		; Int. Strobe 3S_INT:	.BLKB	1		; Software Int.NMI:	.BLKB	1		; Non maskable Int.RESET:	.BLKB	1		; Restart	.END