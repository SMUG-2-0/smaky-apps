	.SBTTL	DESSPLINESPLINE:	CALL	_COPYALL	; fait une copie de la matrice	LOAD.B	(A6)+OXICO,#NIVSPLINE1 ; dbut du dessin d'une courbe	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TS1HELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	LOAD.L	A1,#(A6)+OSPLPT	LOAD.L	(A1)+0,#-1	; OSPLPT <-- termine la table des points	LOAD.L	(A1)+4,#-1	LOAD.L	(A1)+8,#-1	LOAD.W	D0,#MAXSPLINE-2	JUMP	CCLIC$		; met dj le premier pointCLOOP$:	CALL	FULLGREYICONE	; (d)grise qq icnes	CLR.B	D3	CALL	_SELMO		; utilise le lutin flche	CALL	_SCMO		; remet la souris	LIB	?GETKEY		; attend la souris ...	TEST.L	D3:#BKPSEUDO	; touche relche ?	JUMP,BS CLOOP$		; oui => CLOOP$	COMP.W	D3,#KEYMGR	JUMP,EQ CLOOP$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ CLOOP$		; oui => CLOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ CLOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CCLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ CMENU$	COMP.W	D3,#KEYMDP	JUMP,EQ CCLIC$	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ CMOVE$	COMP.W	D3,#F0	JUMP,EQ MODIF2$	COMP.W	D3,#F0+SHIFT	JUMP,EQ MODIF2$	COMP.W	D3,#END	JUMP,EQ MODIF2$	COMP.W	D3,#ENTER	JUMP,EQ MODIF2$	COMP.W	D3,#UNDO	; annule ?	JUMP,EQ ERR2$CBIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; signal que a va plus !	JUMP	CLOOP$CMOVE$:				; souris dplace =>	CALL	SPLAFXY		; affiche X= et Y= dans les informations	JUMP	CLOOP$CMENU$:	CALL	MENUICONE	; menu des icnes de gauche ...	JUMP,NE CBIP$	TEST.B	D3	JUMP,EQ CLOOP$	JUMP	CICONE$CCLIC$:				; ajoute un point =>	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE CBIP$	CALL	MOVICONE	; souris dans les icnes ?	JUMP',EQ CICONE$	; oui => CICONE$	CALL	DETGPOINT	; D3 <-- point o est la souris	JUMP,NE CBIP$	LOAD.L	D4,D3	TEST.W	D0		; encore de la place ?	JUMP,EQ CBIP$		; non => CBIP$	PUSH.L	A1	CALL	SPLDET		; est-on sur un point dj mis ?	POP.L	A1	JUMP,EQ MODIF1$		; oui => MODIF1$	LOAD.L	(A1+),D4	; OSPLPT <-- un point	LOAD.L	(A1),#-1	; OSPLPT <-- termine la table des points	DEC.W	D0	CALL	SPLINVP		; montre le point dans la petite matrice	JUMP	CLOOP$CICONE$:	COMP.B	D3,#ICOSPLINEO	JUMP',EQ CMODE$	COMP.B	D3,#ICOSPLINEF	JUMP',EQ CMODE$	COMP.B	D3,#ICOFLAGS	JUMP,EQ CFLAGS$	COMP.B	D3,#ICODACCORD	JUMP',EQ MODIF2$	COMP.B	D3,#ICOANNULE	JUMP,EQ ERR2$	JUMP	CBIP$CMODE$:	COMP.B	D3,(A6)+OSPLOF	JUMP,EQ CLOOP$	PUSH.W	D3	LOAD.B	D3,(A6)+OSPLOF	CALL	INVICONE	; teint l'ancien mode	POP.W	D3	LOAD.B	(A6)+OSPLOF,D3	CALL	INVICONE	; allume le nouveau mode	JUMP	CLOOP$CFLAGS$:	CALL	DBOXFLAGS	; change le mode ...	JUMP,NE CBIP$	JUMP	CLOOP$MODIF1$:	LOAD.B	(A6)+OSPLOF,#ICOSPLINEFMODIF2$:	CALL	SPLOPEN		; A4 <-- ^table des droites, D6 <-- canal	JUMP,NE	ERR2$	CLR.W	D0	CALL	SPLMI		; montre le spline dans la petite matrice	JUMP,NE	ERR1$	CALL	SPLMOVG		; montre le spline dans la grande matrice;	CALL	SPLCLOSE	; libre la table des droites	LIB	?BUZZ	LOAD.B	(A6)+OXICO,#NIVSPLINE2 ; suite du dessin d'une courbe	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TS2HELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	JUMP'	MLOOP$MREFAIT$:	CALL	SPLOPEN		; A4 <-- ^table des droites, D6 <-- canal	JUMP,NE	ERR2$	CLR.W	D0	CALL	SPLMI		; montre le spline dans la petite matrice	JUMP,NE	ERR1$	CALL	SPLMOVG		; montre le spline dans la grande matrice	CALL	_SCMO		; remet la souris normaleMLOOP$:	CALL	FULLGREYICONE	; (d)grise qq icnes	CLR.B	D3	CALL	_SELMO		; utilise le lutin flche	CALL	_SCMO		; remet la souris	LIB	?GETKEY		; attend la souris ...	TEST.L	D3:#BKPSEUDO	; touche relche ?	JUMP,BS MLOOP$		; oui => MLOOP$	COMP.W	D3,#KEYMGR	JUMP,EQ MLOOP$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ MLOOP$		; oui => MLOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ MLOOP$	COMP.W	D3,#KEYMGP	; clic gauche ?	JUMP,EQ MCLIC$	COMP.W	D3,#KEYMMP	; clic milieu ?	JUMP,EQ MMENU$	COMP.W	D3,#KEYMDP	; clic droite ?	JUMP,EQ MCLIC$	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ MMOVE$	COMP.W	D3,#F0		; termine ?	JUMP,EQ END$	COMP.W	D3,#F0+SHIFT	JUMP,EQ END$	COMP.W	D3,#END	JUMP,EQ END$	COMP.W	D3,#ENTER	JUMP,EQ END$	COMP.W	D3,#UNDO	; annule ?	JUMP,EQ ERR1$MBIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	MLOOP$MMOVE$:	CALL	SPLAFXY		; affiche X= et Y= dans les informations	JUMP	MLOOP$MMENU$:	CALL	MENUICONE	; menu des icnes de gauche ...	JUMP,NE MBIP$	TEST.B	D3	JUMP,EQ MLOOP$	JUMP	MICONE$MCLIC$:				; dplace =>	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE MBIP$	CALL	MOVICONE	; souris dans les icnes ?	JUMP,EQ MICONE$		; oui => MICONE$	CALL	DETGPOINTF	; D3 <-- point o est la souris (sans le pas)	JUMP,NE MBIP$	LOAD.L	D4,D3	CALL	SPLDET		; cherche le point montr	JUMP,NE MBIP$		; pas trouv => MBIP$	LOAD.L	D5,(A1)		; D5 <-- ancien point	LOAD.L	D0,D5MDLOOP$:	CALL	_SCMO		; remet la souris	LIB	?GETKEY		; attend la souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE MDEND$		; non => MDEND$				; oui =>	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE MDLOOP$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINT	; D3 <-- point o est la souris	JUMP,NE MDLOOP$	LOAD.L	D4,D3	COMP.B	(A6)+OSTRHV,#ICOHORIZ	JUMP',NE MDX$	SWAP.W	D5	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- bloque le dplacement en Y	SWAP.W	D4	SWAP.W	D5MDX$:	COMP.B	(A6)+OSTRHV,#ICOVERTI	JUMP',NE MDY$	LOAD.W	D4,D5		; D4 <-- bloque le dplacement en XMDY$:	COMP.L	D4,D5		; point dplac ?	JUMP,EQ MDLOOP$		; non => MDLOOP$	EX.L	D4,D5	CALL	SPLINVP		; efface l'ancien point dans la petite matrice	LOAD.L	D4,D5	CALL	SPLINVP		; dessine le nouveau point dans la petite matrice	CALL	DESINFXY	; affiche X et Y	JUMP	MDLOOP$MDEND$:	COMP.L	D0,D5		; souris dplace ?	JUMP',EQ MKILL$		; non => MKILL$				; oui =>	LOAD.L	D4,D5	CALL	SPLINVP	LOAD.L	D4,D0	CALL	SPLINVP	CALL	SPLMOVG		; efface le spline dans la grande matrice	LOAD.L	D4,D0	CALL	SPLINVP	LOAD.L	D4,D5	CALL	SPLINVP	CLR.W	D0	CALL	SPLMI		; efface le spline dans la petite matrice	CALL	SPLCLOSE	; libre la table des droites	LOAD.L	(A1),D5		; modifie juste le point	JUMP	MREFAIT$MKILL$:	CALL	SPLMOVG		; efface le spline dans la grande matrice	CLR.W	D0	CALL	SPLMI		; efface le spline dans la grande matrice	CALL	SPLCLOSE	; libre la table des droites	LOAD.L	D4,(A1)	CALL	SPLINVP		; efface le point	CALL	SPLKILL		; supprime juste le point	JUMP	MREFAIT$MICONE$:	COMP.B	D3,#ICOHORIZ	JUMP',EQ MBLOQUE$	COMP.B	D3,#ICOVERTI	JUMP',EQ MBLOQUE$	COMP.B	D3,#ICOFLAGS	JUMP,EQ MFLAGS$	COMP.B	D3,#ICODACCORD	JUMP,EQ END$	COMP.B	D3,#ICOANNULE	JUMP,EQ ERR1$	JUMP	MBIP$MBLOQUE$:	COMP.B	D3,(A6)+OSTRHV	JUMP',EQ MDEBLOQUE$	PUSH.W	D3	LOAD.B	D3,(A6)+OSTRHV	CALL	INVICONE	; teint l'ancien mode	POP.W	D3	LOAD.B	(A6)+OSTRHV,D3	CALL	INVICONE	; allume le nouveau mode	JUMP	MLOOP$MDEBLOQUE$:	CALL	INVICONE	CLR.B	(A6)+OSTRHV	JUMP	MLOOP$MFLAGS$:	CALL	DBOXFLAGS	; change le mode ...	JUMP,NE MBIP$	JUMP	MLOOP$END$:				; termine =>	CALL	SPLMOVG		; efface le spline provisoire dans la grande matrice	CLR.W	D0	CALL	SPLMI		; efface le spline provisoire dans la petite matrice	CALL	SPLINVC		; efface tous les points montrs	LOAD.W	D0,#1	CALL	SPLMI		; dessine le spline dfinitif dans la matrice principale	CALL	SPLCLOSE	; ferme la table des droites	CALL	DESMATRIX	; redessine les deux matrices	CLR.B	(A6)+OXICO	; fin de la courbe	CALL	REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; remet les 3 boutons de la souris	JUMP	LOOPERR1$:				; erreur grve =>	PUSH.W	D7	CALL	SPLCLOSE	; ferme la table des droites	POP.W	D7ERR2$:	PUSH.W	D7	CALL	DESMATRIX	; affiche les deux matrices	CLR.B	(A6)+OXICO	; fin de la courbe	CALL	REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; remet les 3 boutons de la souris	POP.W	D7	JUMP,EQ LOOP	JUMP	ERROR;--------\; SPLOPEN >;========/; Calcul les segments de droites pour suivre le spline.; in	(A6)+OSPLPT	table des points; out	A4.L		^table des droites;	D6.L		canal spline;	D7.W		erreur; mod	D6.L, D7.W, A4.LSPLOPEN:	PUSHM.L	D3,A1,A3	COMP.B	(A6)+OSPLOF,#ICOSPLINEO ; spline ouvert ?	JUMP',NE 10$				; spline ouvert =>	CLR.W	D7		; D7 <-- ok	CLR.L	D6		; D6 <-- "canal" impossible	LOAD.L	A4,#(A6)+OSPLPT	; A4 <-- ^table des points	COMP.L	(A4)+8,#-1	; seulement 2 points ?	JUMP',EQ 90$		; oui => 90$	JUMP'	20$10$:				; spline ferm =>	LOAD.L	A1,#(A6)+OSPLPT	; A1 <-- ^table des points15$:	COMP.L	(A1+),#-1	JUMP,NE	15$	LOAD.L	(A1)-4,(A6)+OSPLPT ; ferme la boucle	LOAD.L	(A1)+0,#-1	; et remet le terminateur20$:	LOAD.L	A3,#(A6)+OSPLPT	; A3 <-- ^table des points	LOAD.W	D3,#8		; D3 <-- prend un point sur huit !	SPLINE_	OPEN		; A4 <-- ^points, D6 <-- canal	COMP.B	(A6)+OSPLOF,#ICOSPLINEO ; spline ouvert ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	(A1)-4,#-1	; non => r-ouvre la boucle90$:	POPM.L	D3,A1,A3	TEST.W	D7		; retour EQ/NE	RET;--------\; SPLMI   >;========/; Montre les segments de droites pour suivre le spline.; in	A4.L	^table des droites;	D0.W	0 => provisoire, autre => dfinitif; out	D7.W	erreur; mod	D7.WSPLMI:	PUSHM.L	D1..D5,A4	CALL	_CCMO		; enlve la souris	LOAD.W	D7,#ERDIOUT	; D7 <-- erreur (pas assez de points)	LOAD.L	D4,(A4+)	COMP.L	D4,#-1	JUMP',EQ 90$	LOAD.L	D3,D4		; D3 <-- 1er point	LOAD.L	D4,(A4+)	COMP.L	D4,#-1	JUMP',EQ 90$	JUMP'	50$30$:	LOAD.L	D5,(A4+)	; D5 <-- 3me point	COMP.L	D5,#-1	JUMP',EQ 60$	PUSHM.L	D3,D4	LOAD.L	D3,D4	LOAD.L	D4,D5	CALL	SPLPENTE	; D2 <-- nouvelle pente	POPM.L	D3,D4	COMP.W	D2,D1		; toujours la mme pente ?	JUMP',NE 40$		; non => 40$	LOAD.L	D4,D5		; D4 <-- avance le 2me point	JUMP	30$40$:	CALL	SPLMIEL		; montre/insre lastique dans base	LOAD.L	D3,D4		; D3 <-- 1er point	LOAD.L	D4,D5		; D4 <-- 2me point50$:	CALL	SPLPENTE	LOAD.W	D1,D2		; D1 <-- pente de dpart	JUMP	30$60$:	CALL	SPLMIEL		; montre/insre dernire lastique90$:	POPM.L	D1..D5,A4	TEST.W	D7		; retour EQ/NE	RET;---------\; SPLCLOSE >;=========/; Ferme la table des droites.; in	D6.L	canal spline; out	-; mod	D7.WSPLCLOSE:	TEST.L	D6		; "canal" spcial ?	JUMP',EQ 90$		; oui => 90$	SPLINE_	CLOSE		; non => libre mmoire pour spline90$:	RET;---------\; SPLPENTE >;---------/; Calcul un coeficient proportionnel  la pente d'une droite.; in	D3.L	dpart;	D4.L	arrive; out	D2.W	"pente"; mod	D2.WSPLPENTE:	PUSHM.L	D1,D3	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- dx	LOAD.L	D1,D4	SWAP.W	D1	SWAP.W	D3	SUB.W	D1,D3		; D1 <-- dy	SL.W	D1,#1		; D1 <-- dy*2	JUMP',NE 50$	INC.W	D150$:	MUL.WA	D2,#64	DIV.WA	D2,D1		; D2 <-- pente*32	POPM.L	D1,D3	RET;---------\; SPLMIEL  >;---------/; Montre/insre une lastique.; in	D3.L	coordonne (y;x) dpart;	D4.L	coordonne (y;x) arrive;	D0.W	0 => provisoire, autre => dfinitif; out	-; mod	D7.WSPLMIEL:	PUSHM.L	D0..D6	COMP.L	D3,D4		; droite de longueur nulle ?	JUMP',EQ 90$		; oui => 90$	PUSH.B	(A6)+OOUTIL	LOAD.W	D2,#SETDOT!NCTDOT!2^15	COMP.B	(A6)+OMODE,#ICOSET	JUMP',EQ 20$	LOAD.W	D2,#CLRDOT!NCTDOT!2^1520$:	TEST.W	D0		; provisoire ?	JUMP',NE 25$		; non => 25$	LOAD.B	(A6)+OOUTIL,#ICOCRAYON	LOAD.W	D2,#INVDOT25$:	LOAD.L	D5,D3	LOAD.L	D6,D4	CALL	DESCOMMEPLAN	; dessine dans la petite matrice	POP.B	(A6)+OOUTIL90$:	POPM.L	D0..D6	RET;--------\; SPLDET  >;========/; Cherche le point montr par la souris.; in	D4.L	position de la souris; out	A1.L	^point dtect;	D7.W	erreur; mod	D7.W, A1.LSPLDET:	PUSHM.L	D0,D3	LOAD.L	D3,D4		; D4 <-- x souris	SWAP.W	D3		; D3 <-- y souris	LOAD.L	A1,#(A6)+OSPLPT-4	LOAD.W	D7,#110$:	ADD.L	A1,#4		; A1 <-- ^point suivant	COMP.L	(A1),#-1	; fin de la table ?	JUMP',EQ 90$		; oui => 90$	LOAD.W	D0,(A1)+2	; D0 <-- x point	SUB.W	D0,#DPOIGNEE	COMP.W	D4,D0	JUMP,LO	10$	ADD.W	D0,#DPOIGNEE*2	COMP.W	D4,D0	JUMP,HS	10$	LOAD.W	D0,(A1)+0	; D0 <-- y point	SUB.W	D0,#DPOIGNEE	COMP.W	D3,D0	JUMP,LO	10$	ADD.W	D0,#DPOIGNEE*2	COMP.W	D3,D0	JUMP,HS	10$	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D0,D3	TEST.W	D7		; retour EQ/NE	RET;--------\; SPLKILL >;========/; Supprime le point montr par la souris.; in	A1.L	^point  supprimer; out	-; mod	-SPLKILL:	PUSH.L	A110$:	LOAD.L	(A1)+0,(A1)+4	ADD.L	A1,#4	COMP.L	(A1),#-1	JUMP,NE	10$	POP.L	A1	RET;--------\; SPLINVC >;========/; Inverse tous les points avant le dessin d'un spline.; in	-; out	-; mod	D7.WSPLINVC:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OSPLPT10$:	COMP.L	(A4),#-1	; dernier point ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	D4,(A4+)	; D4 <-- coordonne d'un point	CALL	SPLINVP		; inverse le point	JUMP	10$90$:	POPM.L	D4,A4	RET;--------\; SPLINVP >;========/; Inverse un point avant le dessin d'un spline.; in	D4.L	coordonne (y;x) dans le dessin; out	-; mod	D7.WSPLINVP:	PUSH.L	D3	LOAD.L	D3,D4	CALL	CONVGPOINT	JUMP',NE 90$	CALL	INVPOIGNEE90$:	POP.L	D3	RET;--------\\; SPLAFXY >;========/; Affiche la position de la souris.; in	-; out	-; mod	D7.WSPLAFXY:	PUSHM.L	D3,D4	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP',NE 20$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINT	; D3 <-- point o est la souris	JUMP',EQ 30$20$:	LOAD.L	D3,#-1		; D3 <-- on est pas dans l'aire de dessin30$:	COMP.L	D3,(A6)+OLASTXY	JUMP',EQ 90$	LOAD.L	(A6)+OLASTXY,D3	CALL	DESINFXY	; affiche X= et Y= dans les informations90$:	POPM.L	D3,D4	RET;--------\\; SPLMOVG >;========/; Met  jour la grande matrice.; in	-; out	-; mod	D7.WSPLMOVG:	PUSHM.L	D2..D4	LOAD.L	D3,(A6)+OPMOVY	LOAD.L	D4,(A6)+OPMDIY	LOAD.W	D2,#SETDOT	CALL	MOVGMATRIX	; efface le spline provisoire dans la grande matrice	POPM.L	D2..D4	RET	.END