	.SBTTL	DESARC.ASI;----------\\; DRTRANCHE >;==========/; Dessine une tranche de gteau.; in	D0.W	angle de dpart (0..360);	D1.W	angle d'arrive (0..360);	D2.W	mode;	D3.L	centre (y;x);	D4.L	rayons (ry;rx); out	-; mod	D7.WDRTRANCHE:	PUSHM.L	D0..D6	TSET.L	D2:#BNCTDOT	; D2 <-- pas de rz du traitill	TEST.B	(A6)+OMCERC:#BMCETRA	JUMP',BC 10$	PUSHM.L	D0,D3,D4	LOAD.W	D0,D1	CALL	PCERCLE	LOAD.L	D4,D5	EX.L	D3,D4	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D4	SWAP.W	D3	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D4	SWAP.W	D3	CALL	DRLINE		; dessine la droite Da	POPM.L	D0,D3,D410$:	TEST.B	(A6)+OMCERC:#BMCETRA	JUMP',BC 15$	PUSHM.L	D0,D3,D4	CALL	PCERCLE	LOAD.L	D4,D5	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D4	SWAP.W	D3	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D4	SWAP.W	D3	CALL	DRLINE		; dessine la droite Dd	POPM.L	D0,D3,D415$:	CALL	DRARC	POPM.L	D0..D6	RET;--------\\; DRARC   >;========/; Dessine un arc de cercle.; in	D0.W	angle de dpart (0..360);	D1.W	angle d'arrive (0..360);	D2.W	mode;	D3.L	centre (y;x);	D4.L	rayons (ry;rx); out	-; mod	D7.WDRARC:	PUSHM.L	D0..D6	TSET.L	D2:#BNCTDOT	; D2 <-- pas de rz du traitill	CLR.L	D6		; D6 <-- position initiale;;?	LOAD.L	D5,#4*(360/6)	; D5 <-- L*(360/2PI);;?	DIV.WU	D5,D4;;?	TEST.W	D5;;?	JUMP',NE 20$;;?	INC.W	D5	LOAD.W	D5,#620$:	PUSHM.L	D3..D5	CALL	PCERCLE		; D5 <-- nouveau point	LOAD.L	D3,D6	JUMP',NE 30$	LOAD.L	D6,D5	JUMP'	35$30$:	LOAD.L	D4,D5	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D4	SWAP.W	D3	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D4	SWAP.W	D3	CALL	DRLINE	LOAD.L	D6,D3		; D6 <-- position suivante35$:	POPM.L	D3..D5	COMP.W	D0,D1	JUMP',HS 90$	ADD.W	D0,D5		; D0 <-- angle suivant	COMP.W	D0,D1	JUMP,LS 20$	LOAD.W	D0,D1	JUMP	20$90$:	POPM.L	D0..D6	RET;--------\\; DRLINE  >;--------/; ; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D2.B	mode de dessin; out	D3.L	position suivante (y;x); mod	D3.L, D7.WDRLINE:	LIB	?DRSEG	RET;--------\\; PCERCLE >;--------/; Calcul les coordonnes d'un point situ sur un cercle.; in	D0.W	angle;	D3.L	centre (y;x);	D4.L	rayons (ry;rx); out	D5.L	point (y;x); mod	D5.L, D7.WPCERCLE:	PUSH.L	D1	CALL	ASINUS	SWAP.W	D4	MUL.WA	D1,D4	SWAP.W	D4	ADD.L	D1,#10000/2	DIV.WA	D1,#10000	SWAP.W	D3	ADD.W	D1,D3	SWAP.W	D3	LOAD.W	D5,D1	SWAP.W	D5	CALL	ACOSINUS	MUL.WA	D1,D4	ADD.L	D1,#10000/2	DIV.WA	D1,#10000	ADD.W	D1,D3	LOAD.W	D5,D1	POP.L	D1	RET;---------\\; ACOSINUS >;---------/; Calcul rapidement un cosinus.; in	D0.W	angle (0..360); out	D1.W	cosinus (-10000..+10000); mod	D1.L, D7.WACOSINUS:	PUSH.L	D0	AND.L	D0,#H'FFFF	DIV.WU	D0,#360	SWAP.W	D0		; D0 <-- 0..360-1	SUB.W	D0,#90	NEG.W	D0	JUMP',NC 50$	ADD.W	D0,#36050$:	CALL	ASINUS	POP.L	D0	RET;--------\\; ASINUS  >;--------/; Calcul rapidement un sinus.; in	D0.W	angle (0..360); out	D1.W	sinus (-10000..+10000); mod	D1.L, D7.WASINUS:	PUSHM.L	D0,A3	LOAD.L	A3,#R16"TASINUS	AND.L	D0,#H'FFFF	DIV.WU	D0,#360	SWAP.W	D0		; D0 <-- 0..360-1	COMP.W	D0,#90	JUMP',LS 40$	COMP.W	D0,#180	JUMP',LS 30$	COMP.W	D0,#270	JUMP',LS 20$				; angle 270..360 =>	SUB.W	D0,#360	NEG.W	D0	SL.W	D0,#1	LOAD.W	D1,(A3)+(D0.W)	NEG.W	D1	JUMP'	90$20$:				; angle 180..270 =>	SUB.W	D0,#180	SL.W	D0,#1	LOAD.W	D1,(A3)+(D0.W)	NEG.W	D1	JUMP'	90$30$:				; angle 90..180 =>	SUB.W	D0,#180	NEG.W	D0	SL.W	D0,#1	LOAD.W	D1,(A3)+(D0.W)	JUMP'	90$40$:				; angle 0..90 =>	SL.W	D0,#1	LOAD.W	D1,(A3)+(D0.W);	JUMP'	90$90$:	POPM.L	D0,A3	RETTASINUS:	.W	0,175,349,523,698,872,1045,1219,1392,1564	.W	1736,1908,2079,2250,2419,2588,2756,2924,3090,3256	.W	3420,3584,3746,3907,4067,4226,4384,4540,4795,4848	.W	5000,5150,5299,5446,5592,5736,5878,6018,6157,6293	.W	6428,6561,6691,6820,6947,7071,7193,7314,7431,7547	.W	7660,7771,7880,7986,8090,8192,8290,8387,8480,8572	.W	8660,8746,8829,8910,8988,9063,9135,9205,9272,9336	.W	9397,9455,9511,9563,9613,9659,9703,9744,9781,9816	.W	9848,9877,9903,9925,9945,9962,9976,9986,9994,9998	.W	10000	.END