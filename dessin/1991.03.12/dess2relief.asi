	.SBTTL	DESS2RELIEF;--------------\\; _DESS2_RELIEF >;==============/; Transfert une zone rectangulaire source dans une zone rectangulaire destination; de mmes dimensions, en effectuant une opration de type relief.; in	A0.L	^descripteur de la fentre;	----;	A3.L	^bitmap source;	D5.L	dimensions bitmap (dy;dx);	D3.L	origine source (y;x);	----;	A4.L	^bitmap destination;	D6.L	dimensions bitmap (dy;dx);	D4.L	origine destination (y;x);	----;	D2.L	dimensions (dy;dx);	A2.L	^tables des oprations (ORELxxx);	----; out	D7.W	erreur; mod	D7.W_DESS2_RELIEF:	PUSHM.L	D0..D6,A3,A4,A6	CALL	OPEVOP		; A6 <-- ^variables	JUMP,NE 90$	LOAD.L	A3,(A6)+OOPPTS	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OOPPTD	; A4 <-- ^matrice destination	LOAD.L	D3,(A6)+OOPORS	; D3 <-- position source	LOAD.L	D6,(A6)+OOPORD	; D6 <-- position destination	LOAD.L	D5,(A6)+OOPDIM	; D5 <-- dimensions	LOAD.B	D2,(A2)+ORELX	SR.B	D2,#1		; D2 <-- 0/1/2	LOAD.W	D4,#8/2	SL.W	D4,D2	SUB.W	D6,D4	SWAP.W	D6	SUB.W	D6,D4	SWAP.W	D6	CLR.W	D0		; D0 <-- X initial20$:	CLR.W	D1		; D1 <-- Y initial22$:	PUSHM.W	D0,D1	SR.W	D0,D2	SR.W	D1,D2	TEST.B	(A2)+(D1.W)+ORELSET:D0	POPM.W	D0,D1	JUMP',BC 26$	LOAD.L	D4,D6	ADD.W	D4,D0	SWAP.W	D4	ADD.W	D4,D1	SWAP.W	D4	PUSH.W	D2	LOAD.W	D2,#SETDOT	CALL	CLIPXFERZONE	; matrice principale <-- matrice masque	POP.W	D226$:	LOAD.W	D4,#8	SL.W	D4,D2	INC.W	D1		; D1 <-- Y suivant	COMP.W	D1,D4	JUMP,LO	22$	INC.W	D0		; D0 <-- X suivant	COMP.W	D0,D4	JUMP,LO	20$	CLR.W	D0		; D0 <-- X initial40$:	CLR.W	D1		; D1 <-- Y initial42$:	PUSHM.W	D0,D1	SR.W	D0,D2	SR.W	D1,D2	TEST.B	(A2)+(D1.W)+ORELCLR:D0	POPM.W	D0,D1	JUMP',BC 46$	LOAD.L	D4,D6	ADD.W	D4,D0	SWAP.W	D4	ADD.W	D4,D1	SWAP.W	D4	PUSH.W	D2	LOAD.W	D2,#CLRDOT	CALL	CLIPXFERZONE	; matrice principale <-- matrice masque	POP.W	D246$:	LOAD.W	D4,#8	SL.W	D4,D2	INC.W	D1		; D1 <-- Y suivant	COMP.W	D1,D4	JUMP,LO	42$	INC.W	D0		; D0 <-- X suivant	COMP.W	D0,D4	JUMP,LO	40$	CLR.W	D7		; D7 <-- ok80$:	CALL	CLOVOP		; libre les variables90$:	POPM.L	D0..D6,A3,A4,A6	TEST.W	D7		; retour EQ/NE	RET;-------------\\; CLIPXFERZONE >;-------------/; Transfert une zone rectangulaire, avec clipping si la; destination dborde dans les quatre directions.; in	A3.L	^matrice source;	D3.L	(y;x) source;	A4.L	^matrice destination;	D4.L	(y;x) destination;	D5.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WCLIPXFERZONE:	PUSHM.L	D1..D6,A1,A2	TEST.W	D4		; dborde  gauche ?	JUMP',NC 10$	SUB.W	D3,D4	ADD.W	D5,D4	CLR.W	D410$:	LOAD.W	D1,(A6)+OOPDID+2	SUB.W	D1,D4	COMP.W	D5,D1		; dpasse  droite ?	JUMP',LS 15$	LOAD.W	D5,D115$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	TEST.W	D4		; dborde en haut ?	JUMP',NC 20$	SUB.W	D3,D4	ADD.W	D5,D4	CLR.W	D420$:	LOAD.W	D1,(A6)+OOPDID+0	SUB.W	D1,D4	COMP.W	D5,D1		; dpasse en bas ?	JUMP',LS 25$	LOAD.W	D5,D125$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	TEST.W	D5		; largeur nulle ou ngative ?	JUMP',LE 90$	SWAP.W	D5	TEST.W	D5		; hauteur nulle ou ngative ?	JUMP',LE 90$	SWAP.W	D5	LOAD.W	D1,D2		; D1 <-- mode	LOAD.L	D2,D5		; D2 <-- dimensions	LOAD.W	D5,(A6)+OOPIYS	; D5 <-- Iy source	LOAD.W	D6,(A6)+OOPIYD	; D5 <-- Iy destination	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OOPRAS	CALL	(A1)		; appel de GRA_RASTER90$:	POPM.L	D1..D6,A1,A2	RET	.END