	.SBTTL	DESMISC;---------\\; COPYZALL >;=========/; Copie toute la matrice principale dans la matrice copie; et dans la matrice masque.;; Si zone rectangulaire :;	matrice copie	<-- matrice principale;	matrice masque	<-- matrice principale; Si filet ou crochet :;	matrice copie	<-- matrice principale;	matrice masque	<-- matrice principale & matrice masque; in	-; out	-; mod	D7.WCOPYZALL:	PUSHM.L	A3,A4	CALL	COPYALL		; matrice copie <-- matrice principale	COMP.B	(A6)+OSELECT,#ICOZONE	JUMP',NE 50$				; zone rectangulaire =>	LOAD.L	A3,(A6)+OPMAT	LOAD.L	A4,(A6)+OPMAM	CALL	XFERALL		; matrice masque <-- matrice principale	JUMP'	90$50$:				; filet ou crochet =>	LOAD.L	A3,(A6)+OPMAT	LOAD.L	A4,(A6)+OPMAM	CALL	MASKALL		; matrice masque <-- matrice principale masque90$:	POPM.L	A3,A4	RET;--------\\; COPYALL >;========/; Copie toute la matrice principale dans la matrice copie.; in	-; out	-; mod	D7.WCOPYALL:	PUSHM.L	A3,A4	LOAD.L	A3,(A6)+OPMAT	LOAD.L	A4,(A6)+OPMAC	CALL	XFERALL	SET.B	(A6)+OMAJ	; une mise  jour sera ncessaire	POPM.L	A3,A4	RET;--------\\; UNDOALL >;========/; Echange toute la matrice copie dans la matrice principale,; pour permettre le UNDO du UNDO du UNDO du UNDO du ...; in	-; out	-; mod	D7.WUNDOALL:	PUSHM.L	A3,A4	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	XCHANGEALL	POPM.L	A3,A4	RET;---------\\; XFERZONE >;=========/; Transfert une zone rectangulaire.; in	A3.L	^matrice source;	D3.L	(y;x) source;	A4.L	^matrice destination;	D4.L	(y;x) destination;	D5.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WXFERZONE:	PUSH.W	(A6)+OMANBS	PUSH.W	(A6)+OMANBD	LOAD.W	(A6)+OMANBS,(A6)+OMANBB	LOAD.W	(A6)+OMANBD,(A6)+OMANBB	CALL	XFERZONESD	POP.W	(A6)+OMANBD	POP.W	(A6)+OMANBS	RETXFERZONESD:	PUSHM.L	D3..D6,A2,A3	TEST.W	D5		; largeur nulle ou ngative ?	JUMP,LE 90$	SWAP.W	D5	TEST.W	D5		; hauteur nulle ou ngative ?	JUMP,LE 90$	SWAP.W	D5	LOAD.L	D6,A3	JUMP',EQ 10$	LOAD.L	D6,A4		; source ou destination dans l'cran ?	JUMP',NE 15$		; non => 15$10$:				; oui =>	CALL	CCMO		; enlve la souris15$:	LOAD.L	A2,A3	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	SWAP.W	D3	LOAD.L	(A3)+2,D3	; source: <xx> et <yy>	LOAD.L	(A3)+6,A2	; source: <pppp>	LOAD.W	(A3)+10,(A6)+OMANBS ; source: <ii>	SWAP.W	D4	LOAD.L	(A3)+12,D4	; destination: <xx> et <yy>	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,(A6)+OMANBD ; destination: <ii>	SWAP.W	D5	LOAD.L	(A3)+22,D5	; <dxx> et <dyy>	LOAD.B	(A3)+26,D2	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; transfert90$:	POPM.L	D3..D6,A2,A3	RET;--------\\; XFERALL >;========/; Transfert toute une matrice dans une autre.; in	A3.L	^matrice source;	A4.L	^matrice destination; out	-; mod	D7.WXFERALL:	PUSHM.L	D3,D4,A3,A4	LOAD.W	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMALMY	TEST.L	D4:#1	JUMP',BC 10$	LOAD.W	(A4+),(A3+)	; destination <-- source	SUB.L	D4,#2		; D4 <-- reste10$:	SR.L	D4,#2		; D4 <-- /4 car transfert par long-word20$:	LOAD.L	D3,D4	COMP.L	D3,#32000	; 32000 = maximum pour DECJ.W,NMO !	JUMP',LS 30$	LOAD.L	D3,#3200030$:	SUB.L	D4,D3		; D4 <-- reste	DEC.W	D3		; D3 <-- -1  cause NMO40$:	LOAD.L	(A4+),(A3+)	; destination <-- source	DECJ.W,NMO D3,40$	TEST.L	D4		; reste qq chose ?	JUMP,NE 20$		; oui => 20$	POPM.L	D3,D4,A3,A4	RET;--------\\; BOLDALL >;========/; Epaissi toute une matrice (pour le filet).; in	A4.L	^matrice; out	-; mod	D7.WBOLDALL:	PUSHM.L	D3,D4,A3,A4	LOAD.W	D3,(A6)+OMANBB	LOAD.L	A3,A4	ADD.W	A4,D3	LOAD.W	D4,(A6)+OMALMY	DEC.W	D4		; D4 <-- moins une ligne !	MUL.WU	D4,D310$:	LOAD.B	D3,(A4+)	OR.B	(A3+),D3	DEC.L	D4	JUMP,NE 10$	POPM.L	D3,D4,A3,A4	RET;--------\\; MASKALL >;========/; Masque toute une matrice d'aprs une autre.; in	A3.L	^matrice source;	A4.L	^matrice destination/masque; out	-; mod	D7.WMASKALL:	PUSHM.L	D2..D4,A3,A4	LOAD.W	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMALMY	TEST.L	D4:#1	JUMP',BC 10$	LOAD.W	D2,(A3+)	AND.W	(A4+),D2	; destination <-- masque source	SUB.L	D4,#2		; D4 <-- reste10$:	SR.L	D4,#2		; D4 <-- /4 car transfert par long-word20$:	LOAD.L	D3,D4	COMP.L	D3,#32000	; 32000 = maximum pour DECJ.W,NMO !	JUMP',LS 30$	LOAD.L	D3,#3200030$:	SUB.L	D4,D3		; D4 <-- reste	DEC.W	D3		; D3 <-- -1  cause NMO40$:	LOAD.L	D2,(A3+)	AND.L	(A4+),D2	; destination <-- masque source	DECJ.W,NMO D3,40$	TEST.L	D4		; reste qq chose ?	JUMP,NE 20$		; oui => 20$	POPM.L	D2..D4,A3,A4	RET;-----------\\; XCHANGEALL >;===========/; Permute deux matrices.; in	A3.L	^matrice;	A4.L	^matrice; out	-; mod	D7.WXCHANGEALL:	PUSHM.L	D2..D4,A3,A4	LOAD.W	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMALMY	TEST.L	D4:#1	JUMP',BC 10$	LOAD.W	D2,(A3)	LOAD.W	(A3+),(A4)	; destination <--> source	LOAD.W	(A4+),D2	SUB.L	D4,#2		; D4 <-- reste10$:	SR.L	D4,#2		; D4 <-- /4 car transfert par long-word20$:	LOAD.L	D3,D4	COMP.L	D3,#32000	; 32000 = maximum pour DECJ.W,NMO !	JUMP',LS 30$	LOAD.L	D3,#3200030$:	SUB.L	D4,D3		; D4 <-- reste	DEC.W	D3		; D3 <-- -1  cause NMO40$:	LOAD.L	D2,(A3)	LOAD.L	(A3+),(A4)	; destination <--> source	LOAD.L	(A4+),D2	DECJ.W,NMO D3,40$	TEST.L	D4		; reste qq chose ?	JUMP,NE 20$		; oui => 20$	POPM.L	D2..D4,A3,A4	RET;---------\\; SETALL   >;=========/; Met toute une matrice  un.; in	A4.L	^matrice; out	-; mod	D7.WSETALL:	PUSHM.L	D2..D4,A4	LOAD.W	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMALMY	LOAD.L	D2,#-1	TEST.L	D4:#1	JUMP',BC 10$	LOAD.W	(A4+),D2	; matrice <-- tous des uns	SUB.L	D4,#2		; D4 <-- reste10$:	SR.L	D4,#2		; D4 <-- /4 car transfert par long-word20$:	LOAD.L	D3,D4	COMP.L	D3,#32000	; 32000 = maximum pour DECJ.W,NMO !	JUMP',LS 30$	LOAD.L	D3,#3200030$:	SUB.L	D4,D3		; D4 <-- reste	DEC.W	D3		; D3 <-- -1  cause NMO40$:	LOAD.L	(A4+),D2	; matrice <-- tous des uns	DECJ.W,NMO D3,40$	TEST.L	D4		; reste qq chose ?	JUMP,NE 20$		; oui => 20$	POPM.L	D2..D4,A4	RET;---------\\; INVALL   >;=========/; Inverse toute une matrice.; in	A4.L	^matrice; out	-; mod	D7.WINVALL:	PUSHM.L	D3,D4,A4	LOAD.W	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMALMY	TEST.L	D4:#1	JUMP',BC 10$	NOT.W	(A4+)		; matrice <-- inverse	SUB.L	D4,#2		; D4 <-- reste10$:	SR.L	D4,#2		; D4 <-- /4 car transfert par long-word20$:	LOAD.L	D3,D4	COMP.L	D3,#32000	; 32000 = maximum pour DECJ.W,NMO !	JUMP',LS 30$	LOAD.L	D3,#3200030$:	SUB.L	D4,D3		; D4 <-- reste	DEC.W	D3		; D3 <-- -1  cause NMO40$:	NOT.L	(A4+)		; matrice <-- inverse	DECJ.W,NMO D3,40$	TEST.L	D4		; reste qq chose ?	JUMP,NE 20$		; oui => 20$	POPM.L	D3,D4,A4	RET;---------\\; CLEARALL >;=========/; Met toute une matrice  zro.; in	A4.L	^matrice; out	-; mod	D7.WCLEARALL:	PUSHM.L	D2..D4,A4	LOAD.W	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMALMY	TEST.L	D4:#1	JUMP',BC 10$	CLR.W	(A4+)		; matrice <-- efface	SUB.L	D4,#2		; D4 <-- reste10$:	SR.L	D4,#2		; D4 <-- /4 car transfert par long-word20$:	LOAD.L	D3,D4	COMP.L	D3,#32000	; 32000 = maximum pour DECJ.W,NMO !	JUMP',LS 30$	LOAD.L	D3,#3200030$:	SUB.L	D4,D3		; D4 <-- reste	DEC.W	D3		; D3 <-- -1  cause NMO	CLR.L	D240$:	LOAD.L	(A4+),D2	; matrice <-- efface	DECJ.W,NMO D3,40$	TEST.L	D4		; reste qq chose ?	JUMP,NE 20$		; oui => 20$	POPM.L	D2..D4,A4	RET;--------\\; IFVIDE  >;========/; Vrifie si la matrice principale est toute  zro.; in	-; out	D7.W	erreur => pas vide; mod	D7.WIFVIDE:	PUSHM.L	D4,A4	LOAD.W	D7,#1		; D7 <-- pas vide	LOAD.L	A4,(A6)+OPMAT	LOAD.W	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMALMY	SR.L	D4,#1		; D4 <-- /2 car transfert par word10$:	TEST.W	(A4+)		; matrice vide ?	JUMP',NE 90$	DEC.L	D4	JUMP,NE 10$	CLR.W	D7		; D7 <-- c'est tout vide90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WAITMPO >;========/; Attend que la souris bouge.; in	-; out	D3.W	"touche"; mod	D3.L, D7.WWAITMPO:	PUSH.W	D4	LOAD.W	D4,#1	NTREL	?SETTIM		; met timeout trs court	LIB	?GETKEY		; qq chose tout de suite ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	JUMP',EQ 90$		; oui => 90$				; non =>	CALL	SCOMO		; remet la souris	LIB	?GETKEY		; attend souris ...90$:	POP.W	D4	RET;--------\\; MMENU   >;========/; Attend un choix selon un mmenu.; in	A3.L	^mmenu;	A4.L	^dernire case (.B);	D3.W	case initiale; out	D3.W	case choisie;	D7.W	erreur; mod	D3.L, D7.WMMENU:	PUSH.W	D3	CLR.B	D3	CALL	SELMO		; outil = flche	POP.W	D3	PUSH.W	D4	LOAD.W	D4,#2	NTREL	?DELMS		; attend que souris devienne flche !	POP.W	D4	TEST.B	(A6)+ODEF+3:#BDEFMDC	JUMP',BC 50$	EX.L	D4,A4	TEST.L	D4		; A4 = ^nil ?	EX.L	A4,D4	JUMP',EQ 50$		; oui => 50$	LOAD.B	D3,(A4)		; D3 <-- dernire case	LIB	?MMENU		; choix selon mmenu ...	JUMP',NE 90$	LOAD.B	(A4),D3		; mm. la dernire case	JUMP'	90$50$:	LIB	?MMENU		; choix selon mmenu ...90$:	RET;--------\\; MMENUS  >;========/; Attend un choix selon un mmenu hirarchique.; in	A3.L	^mmenu;	A4.L	^paramtres; out	D7.W	erreur; mod	D7.WMMENUS:	PUSHM.L	D3..D5	CLR.B	D3	CALL	SELMO		; outil = flche	LOAD.W	D4,#2	NTREL	?DELMS		; attend que souris devienne flche !	TEST.B	(A6)+ODEF+3:#BDEFMDC	JUMP',BS 50$	CLR.W	(A4)+OMMSEL	; slectionne la premire case50$:	CLR.L	D5		; D5 <-- flags	LIB	?MMENUS		; choix selon mmenu hirarchique ...90$:	POPM.L	D3..D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGMOUSE >;========/; Dessine la position de la souris dans les rgles.; in	D4.L	position de la souris; out	-; mod	D7.WRGMOUSE:	PUSHM.L	D2..D4,A5	TEST.B	(A6)+OREGLE	; rgles prsentes ?	JUMP',F 90$		; non => 90$				; oui =>	LOAD.L	A5,#(A6)+ORGVAR	LOAD.L	D2,D4		; D2 <-- position (y;x)	CLR.L	D4		; D4 <-- efface les flches	LOAD.W	D3,(A5)+ORGHPO+2	COMP.W	D2,D3		; trop  gauche ?	JUMP',LO 60$	ADD.W	D3,(A5)+ORGHLG	COMP.W	D2,D3		; trop  droite ?	JUMP',HS 60$	SWAP.W	D2	LOAD.W	D3,(A5)+ORGVPO+0	COMP.W	D2,D3		; trop en haut ?	JUMP',LO 60$	ADD.W	D3,(A5)+ORGVLG	COMP.W	D2,D3		; trop en bas ?	JUMP',HS 60$	SWAP.W	D2	LOAD.L	D4,D2		; D4 <-- position (y;x)60$:	SCROLL_	RMOUSE		; dplace les flches dans les rgles90$:	POPM.L	D2..D4,A5	RET;---------\\; ERGMOUSE >;=========/; Efface la position de la souris dans les rgles.; in	-; out	-; mod	D7.WERGMOUSE:	PUSHM.L	D4,A5	LOAD.L	A5,#(A6)+ORGVAR	CLR.L	D4		; D4 <-- efface	SCROLL_	RMOUSE		; efface les flches dans les rgles	POPM.L	D4,A5	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	ADD.W	D4,(A6)+OLUPX	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	ADD.W	D4,(A6)+OLUPY	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMOUSE  >;========/; Positionne la souris en (y;x).; in	D4.L	nouvelle position y;x; out	-; mod	D7.WPMOUSE:	LIB	?PMOUSE		; positionne la souris	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; ATTENTION:	Le fait d'crire directement dans le descripteur;		de la fentre fait que la trame est inverse;		entre le Smaky 8 et 100 (gauche <--> droite) !;		Il ne faut donc utiliser que des trames simples;		(pas de hachures par exemple).; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	RET;--------\\; CCMO    >;========/; Enlve la souris.; in	-; out	-; mod	D7.WCCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',T 90$	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	SET.B	(A6)+OCCMO90$:	POP.W	D3	RET;--------\\; SCOMO   >;========/; Remet l'outil slectionn et la souris.; in	-; out	-; mod	D7.WSCOMO:	PUSH.W	D3	LOAD.B	D3,(A6)+OOUTIL	CALL	SELMO		; utilise le bon lutin	CALL	SCMO		; remet la souris	POP.W	D3	RET;--------\\; SCMO    >;========/; Remet la souris.; in	-; out	-; mod	D7.WSCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',F 90$	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	CLR.B	(A6)+OCCMO90$:	POP.W	D3	RET;--------\\; SELMO   >;--------/; Slectionne un nouveau lutin pour la souris.; in	D3.B	outil en fonction; out	-; mod	D7.WSELMO:	PUSHM.L	D1..D5,A2..A5	COMP.B	D3,#ICOCRAYON	JUMP',EQ 03$	COMP.B	D3,#ICOPINCEAU	JUMP',NE 04$03$:	COMP.B	(A6)+OMODE,#ICOCLEAR	JUMP',NE 04$	TSET.L	D3:#7		; D3 <-- ICOCRAYON/PINCEAU!2^704$:	LOAD.L	A3,#R16"00$	LOAD.B	D2,D3	CLR.B	D3		; D3 <-- pas d'outil; Vrifie si la souris est dans la zone de dessin.; Si non, n'utilise pas l'outil slectionn.	LOAD.L	D1,#-1		; D1 <-- hors de la fentre	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE 10$	LOAD.L	D1,D4	SUB.W	D4,(A6)+OGRPOX	JUMP',LO 10$	COMP.W	D4,(A6)+OGRDIX	JUMP',HS 10$	SWAP.W	D4	SUB.W	D4,(A6)+OGRPOY	JUMP',LO 10$	COMP.W	D4,(A6)+OGRDIY	JUMP',HS 10$	LOAD.B	D3,D2		; D3 <-- outil slectionn10$:	TEST.B	(A3)+0		; fin de la table ?	JUMP',EQ 15$	COMP.B	D3,(A3)+0	; outil trouv ?	JUMP',EQ 15$	ADD.L	A3,#5		; A3 <-- ^suivant dans table	JUMP	10$15$:	CLR.W	D3	LOAD.B	D3,(A3)+1	; D3 <-- code de l'icne	LOAD.B	(A6)+OLUPX+1,(A3)+3	LOAD.B	(A6)+OLUPY+1,(A3)+4	COMP.B	D3,(A6)+OLUTIN	; toujours le mme outil ?	JUMP,EQ 90$		; oui => 90$	LOAD.B	(A6)+OLUTIN,D3	LOAD.L	A2,#(A6)+OLUMAM	TNOT.B	(A6)+OLUFLG:#BLUMAN	JUMP',BC 17$	LOAD.L	A2,#(A6)+OLUMAN17$:	LOAD.L	A4,#0		; A4 <-- utilise la flche normale	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	TEST.B	D3	JUMP',EQ 50$	COMP.B	D3,#-1	JUMP',EQ 40$	COMP.B	D3,#-2	JUMP',EQ 40$	TEST.B	(A3)+2	JUMP',NE 30$20$:	CALL	CMOUTIL		; A4/A5 <-- ^dx,dy,matrice de l'outil	JUMP'	50$30$:	CALL	CMOUTILFOND	; A4/A5 <-- ^dx,dy,matrice chair/fond	JUMP'	50$40$:	CALL	CMPINCEAU	; A4/A5 <-- ^dx,dy,matrice du pinceau50$:	NTREL	?GETPRIO	LOAD.W	D5,D4		; D5 <-- priorit actuelle	LOAD.W	D4,#1	NTREL	?SETPRIO	; met une trs forte priorit	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	LOAD.L	(A3)+1,A4	; <ssss> matrice chair	LOAD.L	(A3)+5,A5	; <cccc> matrice fond	LOAD.W	D3,#9	LIB	?STRING	COMP.L	D1,#-1		; hors de la fentre ?	JUMP,EQ 70$		; oui => 70$				; non =>	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 70$	SUB.W	D4,D1	JUMP',NC 60$	NEG.W	D4		; D4 <-- |dplacement horizontal|60$:	COMP.W	D4,#30		; souris beaucoup bouge "entre temps" ?	JUMP',HS 70$		; oui => 70$ (crac, pas de positionnement !!!)	LOAD.L	D4,D1	SUB.W	D4,(A6)+OLUPX	SWAP.W	D4	SUB.W	D4,(A6)+OLUPY	SWAP.W	D4	CALL	PMOUSE		; positionne pour ne pas bouger la "pointe"70$:	LOAD.W	D4,D5	NTREL	?SETPRIO	; remet la priorit initiale90$:	POPM.L	D1..D5,A2..A5	RET00$:	.B	ICOCRAYON,ICOCCRAYON,0			1+0,1+20	.B	ICOCRAYON!2^7,ICODCRAYON,ICOECRAYON	1+0,1+18	.B	ICOPINCEAU,-1,0				1+8,1+8	.B	ICOPINCEAU!2^7,-2,0			1+8,1+8	.B	ICOSPRAY,ICOCSPRAY,0			1+12,1+3	.B	ICOREMPLI,ICOCREMPLI,ICOFREMPLI		15,19	.B	ICOMAIN,ICOCMAIN,ICOFMAIN		8,10	.B	ICOPLOUPE,ICOCLOUPE,0			6,6	.B	ICOTEXTE,ICOCTEXTE,0			1,1	.B	ICOBLOC1,ICOCBLOC,ICOFBLOC		1,1	.B	ICOBLOC2,ICOCBLOC,ICOFBLOC		1,1	.B	ICOBLOC3,ICOCBLOC,ICOFBLOC		1,1	.B	ICOAJOUTE,ICOCAJOUTE,0			1,1	.B	ICOSCAN,ICOCSCAN,ICOFSCAN		1,1	.B	0,0,0					0,0	.EVEN;--------\\; CMOUTIL >;--------/; Construit la matrice d'un outil quelconque d'aprs; une icne contenue dans IDP20.; La matrice construite possde un point de plus de tous; les cts, pour permettre un calcul correct de la matrice; automatique de fond.; in	D3.W	code de l'icne;	A2.L	^buffer pour matrice; out	A4.L	^dx,dy,matrice chair;	A5.L	^dx,dy,matrice fond; mod	D7.W, A4.L, A5.LCMOUTIL:	PUSHM.L	D1..D4,A3	LOAD.L	A4,#0		; A4 <-- utilise la flche normale	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP,NE 90$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	A4,(A0)+ODFPGC	; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D3	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^bonne matrice	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#GCICX/8 ; source: <ii>	LOAD.L	A4,(A0)+ODFPGC	; A4 <-- ^gencar des icnes	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D2,#1+GCICY+1	; D2 <-- hauteur	SWAP.W	D2	CLR.W	D2	LOAD.B	D2,(A4)+(D3.W)	ADD.W	D2,#2		; D2 <-- largeur	LOAD.W	D1,D2	ADD.W	D1,#8-1	SR.W	D1,#3		; D1 <-- largeur en bytes	LOAD.W	(A3)+12,#1	; destination: <xx>	LOAD.W	(A3)+14,#1	; destination: <yy>	LOAD.L	A4,A2		; A4 <-- ^buffer pour matrice	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,D1	; destination: <ii>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D440$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,40$	SUB.W	D2,#2	LOAD.W	(A3)+22,D2	; <dxx>	SWAP.W	D2	SUB.W	D2,#2	LOAD.W	(A3)+24,D2	; <dyy>	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	LOAD.L	A4,A2		; A4 <-- ^dx,dy,matrice90$:	POPM.L	D1..D4,A3	RET;------------\\; CMOUTILFOND >;------------/; Construit les matrices chair et fond d'un outil quelconque d'aprs; une icne et la suivante contenue dans IDP20.; in	D3.W	code de l'icne;	A2.L	^buffer pour matrice; out	A4.L	^dx,dy,matrice chair;	A5.L	^dx,dy,matrice fond; mod	D7.W, A4.L, A5.LCMOUTILFOND:	PUSHM.L	D0..D4,A3	LOAD.W	D0,D3		; D0 <-- code de l'icne	LOAD.L	A4,#0		; A4 <-- utilise la flche normale	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP,NE 90$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	A4,(A0)+ODFPGC	; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D0	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^matrice chair	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#GCICX/8 ; source: <ii>	LOAD.L	A4,(A0)+ODFPGC	; A4 <-- ^gencar des icnes	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D2,#GCICY	; D2 <-- hauteur	SWAP.W	D2	CLR.W	D2	LOAD.B	D2,(A4)+(D0.W)	; D2 <-- largeur	LOAD.W	D1,D2	ADD.W	D1,#8-1	SR.W	D1,#3		; D1 <-- largeur en bytes	CLR.L	(A3)+12		; destination: <xx> et <yy>	LOAD.L	A4,A2		; A4 <-- ^buffer pour matrice	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx chair	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy chair	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,D1	; destination: <ii>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D440$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,40$	SWAP.W	D2	LOAD.L	(A3)+22,D2	; <dxx> et <dyy>	SWAP.W	D2	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne chair	LOAD.L	A5,A4		; A5 <-- ^futur dx,dy,matrice fond	LOAD.L	A4,(A0)+ODFPGC	; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	LOAD.W	D3,D0	INC.W	D3	MUL.WU	D4,D3	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^matrice suivante (fond)	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.L	A4,A5	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx fond	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy fond	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D460$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,60$	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne fond	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	LOAD.L	A4,A2		; A4 <-- ^dx,dy,matrice chair90$:	POPM.L	D0..D4,A3	RET;----------\\; CMPINCEAU >;----------/; Construit la matrice du pinceau en construisant une croix; avec la forme du pinceau.; En mode "gomme", la croix est vide.; in	D3.W	code de l'icne;	A2.L	^buffer pour matrice; out	A4.L	^dx,dy,matrice du pinceau;	A5.L	^dx,dy,matrice fond; mod	D7.W, A4.L, A5.LCMPINCEAU:	PUSHM.L	D0..D4,A3	LOAD.W	D0,D3		; D0 <-- code de l'icne	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	A4,#(A6)+OPDEF	LOAD.W	D4,(A6)+ONPDEF	MUL.WU	D4,#8+2	ADD.L	A4,D4		; A4 <-- ^bon pinceau	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#1	; source: <ii>	LOAD.L	A4,A2		; A4 <-- ^buffer pour matrice	LOAD.B	(A4+),#20	; OLUMAM/N <-- dx	LOAD.B	(A4+),#20	; OLUMAM/N <-- dy	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,#3	; destination: <ii>	LOAD.W	D4,#(3*20)-120$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,20$	LOAD.W	(A3)+22,#8	; <dxx>	LOAD.W	(A3)+24,#8	; <dyy>	LOAD.B	(A3)+26,#SETDOT	; <mode>; Construit l'horizontale de la croix.	LOAD.W	D2,#1+4		; D2 <-- <xx>	SWAP.W	D2	LOAD.W	D2,#1+4		; D2 <-- <yy>	LOAD.W	D4,#1-1	COMP.B	D0,#-2		; pinceau en mode gomme ?	JUMP',EQ 30$	LOAD.W	D2,#1		; D2 <-- <xx>	SWAP.W	D2	LOAD.W	D2,#1+4		; D2 <-- <yy>	LOAD.W	D4,#9-130$:	LOAD.L	(A3)+12,D2	; destination: <xx> et <yy>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- matrice du pinceau	SWAP.W	D2	INC.W	D2		; D2 <-- <xx> suivant	SWAP.W	D2	DECJ.W,NMO D4,30$; Construit la verticale de la croix.	LOAD.W	D2,#1+4		; D2 <-- <xx>	SWAP.W	D2	LOAD.W	D2,#1+4		; D2 <-- <yy>	LOAD.W	D4,#1-1	COMP.B	D0,#-2		; pinceau en mode gomme ?	JUMP',EQ 35$	LOAD.W	D2,#1+4		; D2 <-- <xx>	SWAP.W	D2	LOAD.W	D2,#1		; D2 <-- <yy>	LOAD.W	D4,#9-135$:	LOAD.L	(A3)+12,D2	; destination: <xx> et <yy>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- matrice du pinceau	INC.W	D2		; D2 <-- <yy> suivant	DECJ.W,NMO D4,35$	LOAD.L	A4,A2		; A4 <-- ^dx,dy,matrice	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	COMP.B	D0,#-2		; pinceau en mode gomme ?	JUMP,NE 90$; Construit la matrice grasse, en rptant 3x3 la matrice initiale.	LOAD.W	(A3)+2,#1	; source: <xx>	LOAD.W	(A3)+4,#1	; source: <yy>	LOAD.L	A5,#(A4)+2+(3*20)	LOAD.W	(A5+),(A4)	; OLUMAM/N <-- dx et dy matrice grasse	LOAD.L	(A3)+6,(A3)+16	; source: <pppp>	LOAD.W	(A3)+10,(A3)+20	; source: <ii>	LOAD.L	(A3)+16,A5	; destination: <pppp>	LOAD.W	D4,#(3*20)-140$:	CLR.B	(A5+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,40$	LOAD.W	(A3)+22,#18	; <dxx>	LOAD.W	(A3)+24,#18	; <dyy>	CLR.W	(A3)+14		; destination: <yy> initial50$:	CLR.W	(A3)+12		; destination: <xx> initial55$:	LOAD.W	D3,#1+26	LIB	?STRING		; construit la matrice grasse	INC.W	(A3)+12		; destination: <xx> suivant	COMP.W	(A3)+12,#3	JUMP,LO 55$	INC.W	(A3)+14		; destination: <yy> suivant	COMP.W	(A3)+14,#3	JUMP,LO 50$; Construit la matrice contour, en vidant la matrice grasse.	PUSH.L	A3	LOAD.L	A3,#(A4)+1*(2+(3*20))	LOAD.L	A5,#(A4)+2*(2+(3*20))	LOAD.W	D4,#2+(3*20)-160$:	LOAD.B	(A5+),(A3+)	; OLUMAM/N <-- matrice grasse (fond)	DECJ.W,NMO D4,60$	POP.L	A3	LOAD.L	(A3)+12,(A3)+2	; destination: <xx> et <yy>	LOAD.B	(A3)+26,#CLRDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; construit la matrice contour (chair)	LOAD.L	A5,#(A4)+2*(2+(3*20))	LOAD.L	A4,#(A4)+1*(2+(3*20))90$:	POPM.L	D0..D4,A3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	-; out	-; mod	D7.WAFMENU:	PUSHM.L	D3,A3	LOAD.B	D3,(A6)+OXICO	LOAD.L	A3,#R16"TXMTEXTE	COMP.B	D3,#NIVTEXTE	JUMP',EQ 10$	LOAD.L	A3,#R16"TXMPOIGNEE	COMP.B	D3,#NIVDEFORME	JUMP',EQ 10$	LOAD.L	A3,#R16"TXMSPLINE1	COMP.B	D3,#NIVSPLINE1	JUMP',EQ 10$	LOAD.L	A3,#R16"TXMSPLINE2	COMP.B	D3,#NIVSPLINE2	JUMP',EQ 10$	LOAD.L	A3,#R16"TXMHELP	COMP.B	D3,#NIVHELP	JUMP',EQ 10$	LOAD.L	A3,#R16"TXMRELIEF	COMP.B	D3,#NIVRELIEF	JUMP',EQ 10$	LOAD.L	A3,#R16"TXMTRAME	COMP.B	D3,#NIVTRAME	JUMP',EQ 10$	LOAD.L	A3,#R16"TXMLISSE	COMP.B	D3,#NIVLISSE	JUMP',EQ 10$	LOAD.L	A3,#R16"TXMENU10$:	LIB	?AFMENU	POPM.L	D3,A3	RET;--------\\; AFIMAGE >;========/; Affiche une image dans la fentre.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie suprieure gauche.; in	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WAFIMAGE:	PUSHM.L	D0..D4,D6,A1..A4	LIB	?AFTIM	.B	NOCURS;;?	.B	EOP	.B	0	.EVEN	CALL	DESMDEF		; D4 <-- trame grise pour le fond	CALL	DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise toute la fentre	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; grise toute la fentre	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE 90$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE 84$	LOAD.L	A4,A2	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$	COMP.B	(A2)+OIMTYP,#H'82 ; image du LAMI ?	JUMP,NE 20$		; non => 20$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute la stupide en-tte de 256 bytes !	JUMP,NE 82$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$20$:	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF+4	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE 82$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP,NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP,NE 80$	JUMP	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP,NE 80$	LOAD.L	A3,A1	GRA_	DECOIMA		; dcode l'image ...	JUMP,NE 80$35$:	TEST.B	(A0)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP',BS 45$		; oui => 45$				; non =>	LOAD.L	A3,A1		; A3 <-- ^image	LOAD.W	D3,D0	MUL.WU	D3,D1		; D3 <-- taille de l'image en points	SR.L	D3,#3+2		; D3 <-- /8 pour bytes et /4 pour .L;	ADD.W	D3,#1-1		; D3 <-- -1  cause NMO40$:	NOT.L	(A3+)		; inverse toute l'image	DECJ.W,NMO D3,40$45$:	LOAD.L	A3,A2		; A3 <-- prend buffer en-tte pour STRING	LOAD.W	D3,D0	SR.W	D3,#3	LOAD.W	(A3)+10,D3	; source: <ii>	CLR.W	(A3)+20		; destination: <ii>	LIB	?GETDIM		; D4 <-- dimensions de la fentre	COMP.W	D0,D4		; image trop large ?	JUMP,HI 50$		; oui => 50$	CLR.W	(A3)+2		; source: <xx>	LOAD.W	(A3)+22,D0	; image: <dxx>	SUB.W	D4,D0	SR.W	D4,#1	LOAD.W	(A3)+12,D4	; destination: <xx>	JUMP	55$50$:	CLR.W	(A3)+2		; source: <xx>	CLR.W	(A3)+12		; destination: <xx>	LOAD.W	(A3)+22,D4	; image: <dxx>55$:	SWAP.W	D4	COMP.W	D1,D4		; image trop haute ?	JUMP,HI 60$		; oui => 60$	CLR.W	(A3)+4		; source: <yy>	LOAD.W	(A3)+24,D1	; image: <dyy>	SUB.W	D4,D1	SR.W	D4,#1	LOAD.W	(A3)+14,D4	; destination: <yy>	JUMP	65$60$:	CLR.W	(A3)+4		; source: <yy>	CLR.W	(A3)+14		; destination: <yy>	LOAD.W	(A3)+24,D4	; image: <dyy>65$:	LOAD.W	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+6,A1	; source: <pppp>	CLR.L	(A3)+16		; destination: <pppp>	LOAD.B	(A3)+26,#LOADDOT ; image: <mode>	LOAD.W	D3,#1+26	; D3 <-- longueur	LIB	?STRING		; affiche l'image	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D784$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POP.W	D790$:	POPM.L	D0..D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; OPEDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	A4.L	^matrice o dessiner; out	-; mod	D7.WOPEDISMAT:	PUSH.L	D4	LOAD.L	(A6)+OSDDIS+ODFABS,(A0)+ODFABS	LOAD.W	(A6)+OSDDIS+ODFIIX,(A0)+ODFIIX	LOAD.W	(A6)+OSDDIS+ODFIIY,(A0)+ODFIIY	LOAD.L	(A6)+OSDDIS+ODFY,(A0)+ODFY	LOAD.L	(A6)+OSDDIS+ODFDY,(A0)+ODFDY	LOAD.L	(A6)+OSDDIS+ODFFY,(A0)+ODFFY	LOAD.L	(A6)+OSDDIS+ODFFDY,(A0)+ODFFDY	LOAD.L	(A6)+OSDDIS+ODFWBY,(A0)+ODFWBY	LOAD.L	(A6)+OSDDIS+ODFWEY,(A0)+ODFWEY;;?	LOAD.W	(A6)+OSDDIS+ODFTTC,(A0)+ODFTTC	LOAD.L	(A0)+ODFABS,A4	LOAD.W	(A0)+ODFIIX,#1	LOAD.W	(A0)+ODFIIY,(A6)+OMANBB	LOAD.L	D4,(A6)+OMALMY	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	POP.L	D4	RET;----------\\; CLODISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.WCLODISMAT:	LOAD.L	(A0)+ODFABS,(A6)+OSDDIS+ODFABS	LOAD.W	(A0)+ODFIIX,(A6)+OSDDIS+ODFIIX	LOAD.W	(A0)+ODFIIY,(A6)+OSDDIS+ODFIIY	LOAD.L	(A0)+ODFY,(A6)+OSDDIS+ODFY	LOAD.L	(A0)+ODFDY,(A6)+OSDDIS+ODFDY	LOAD.L	(A0)+ODFFY,(A6)+OSDDIS+ODFFY	LOAD.L	(A0)+ODFFDY,(A6)+OSDDIS+ODFFDY	LOAD.L	(A0)+ODFWBY,(A6)+OSDDIS+ODFWBY	LOAD.L	(A0)+ODFWEY,(A6)+OSDDIS+ODFWEY;;?	LOAD.W	(A0)+ODFTTC,(A6)+OSDDIS+ODFTTC	RET;--------\\; CONVMPX >;========/; Converti un nombre horizontal en millimtres --> en points.; in	D4.W	nombre [mm]; out	D4.W	nombre [p]; mod	D3.W, D4.LCONVMPX:	MUL.WA	D4,#10000	LOAD.W	D3,(A6)+OMMX	CALL	DIVD4D3	CONV.LA.WA D4	LOAD.W	D3,(A6)+OFACX	JUMP'	DIVD4D3;--------\\; CONVMPY >;========/; Converti un nombre vertical en millimtres --> en points.; in	D4.W	nombre [mm]; out	D4.W	nombre [p]; mod	D3.W, D4.LCONVMPY:	MUL.WA	D4,#10000	LOAD.W	D3,(A6)+OMMY	CALL	DIVD4D3	CONV.LA.WA D4	LOAD.W	D3,(A6)+OFACY	JUMP'	DIVD4D3;--------\\; CONVPMX >;========/; Converti un nombre horizontal en points --> en millimtres.; in	D4.W	nombre [p]; out	D4.W	nombre [mm]; mod	D3.W, D4.LCONVPMX:	MUL.WA	D4,(A6)+OFACX	MUL.WA	D4,(A6)+OMMX	LOAD.W	D3,#10000	JUMP'	DIVD4D3;--------\\; CONVPMY >;========/; Converti un nombre vertical en points --> en millimtres.; in	D4.W	nombre [p]; out	D4.W	nombre [mm]; mod	D3.W, D4.LCONVPMY:	MUL.WA	D4,(A6)+OFACY	MUL.WA	D4,(A6)+OMMY	LOAD.W	D3,#10000;	JUMP'	DIVD4D3;--------\\; DIVD4D3 >;--------/; Divise D4 par D3 avec un arrondi.; in	D4.L	nombre  diviser (+/-);	D3.W	diviseur (+); out	D4.L	reste/div; mod	D4.LDIVD4D3:	PUSH.W	D3	DIV.WA	D4,D3	JUMP',NS 40$	SR.W	D3,#1	SWAP.W	D4	COMP.W	D4,D3	JUMP',LE 20$	SWAP.W	D4	INC.W	D4		; D4 <-- arrondi (+1)	POP.W	D3	RET20$:	SWAP.W	D4	POP.W	D3	RET40$:	SR.W	D3,#1	SWAP.W	D4		; D4 <-- reste ngatif	NEG.W	D4		; D4 <-- reste positif	COMP.W	D4,D3	JUMP',LE 60$	SWAP.W	D4	DEC.W	D4		; D4 <-- arrondi (-1)	POP.W	D3	RET60$:	SWAP.W	D4	POP.W	D3	RET	.END