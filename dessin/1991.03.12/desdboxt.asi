	.SBTTL	DESDBOXT;---------\\; DBOXOPEN >;---------/; Ouvre une dbox.; in	A2.L	table;	D2.W	mode; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WDBOXOPEN:	PUSH.L	D3	CALL	DBOXOPEN1	CALL	DBOXPOS3	; D3 <-- centre de la dbox	DBOX_	OPEN		; ouvre la dbox	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETDBOXOPEN1:	PUSH.W	D3	CALL	ERGMOUSE	; efface les flches dans les rgles	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	POP.W	D3	RET;----------\\; DBOXCLOSE >;----------/; Ferme une dbox.; in	D5.L	canal; out	D7.W	erreur; mod	D7.WDBOXCLOSE:	DBOX_	CLOSE		; ferme la dboxDBOXCLOSE1:	CALL	AFMENU		; refait les soft-keys	RET;---------\\; DBOXPOS5 >;---------/; Centre ventuellement les dbox selon les icnes de gauche.; in	D2.W	mode d'ouverture; out	D2.W	mode d'ouverture;	D5.L	position (y;x); mod	D2.L, D5.L, D7.WDBOXPOS5:	PUSH.L	D3	CALL	DBOXPOS3	LOAD.L	D5,D3	POP.L	D3	RET;---------\\; DBOXPOS3 >;---------/; Centre ventuellement les dbox selon les icnes de gauche.; in	D2.W	mode d'ouverture; out	D2.W	mode d'ouverture;	D3.L	position (y;x); mod	D2.L, D3.L, D7.WDBOXPOS3:	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC 90$		; non => 90$				; oui =>	LOAD.W	D3,(A6)+ODICO+0	ADD.W	D3,#ICOLY/2	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#1	TSET.L	D2:#BDBPOS	; D2 <-- centre selon D3.L90$:	RET;--------\\; DBOXRSK >;========/; Refait les soft-keys.; in	A2.L	^table DBOX; out	-; mod	-DBOXRSK:	PUSHM.L	D3,D7,A3	LOAD.W	D3,(A2)+2	LOAD.L	A3,#(A2)+(D3.W)	LIB	?AFMENU		; refait les soft-keys	POPM.L	D3,D7,A3	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs DBOX_EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>90$:	POP.L	A3	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET; Tables; ------TDBOX_SAUVE:	.B	LDBOX_SAUVE	.B	ODBSQUARE,BDBDEF	.ASCIZ	" sauve les pinceaux et les trames"	.B	ODBCRLDBOX_SAUVE	=	.-TDBOX_SAUVE-1TDBOX_DEFINE:	.W	10$-TDBOX_DEFINE	.W	20$-TDBOX_DEFINE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Dimensions (l x h) "	.B	ODBTABX,19	.B	ODBLINE,(14+2)!2^7,0,0,TDBOMBRE	.B	ODBCR,ODBCR	.B	ODBSQUARE,BDEFZOOM	.ASCIZ	" zoom gnral"	.B	ODBTABX,19	.B	ODBBOX,0,FNCT,TDBOMBRE	.ASCIZ	" ECRAN "	.B	ODBBOX,0,DEFINE,TDBOMBRE	.ASCIZ	" PAGE "	.B	ODBCR	.B	ODBLCIRCLE,BDEFMM!2^7!2^6,KEYICO/H'100,BDEFMM	.ASCIZ	" millimtres"	.B	ODBCR	.B	ODBLCIRCLE,BDEFPG!2^7!2^6,KEYICO/H'100,BDEFPG	.ASCIZ	" points graphiques"	.B	ODBCR,ODBCR	.B	ODBSQUARE,BDEFICO	.ASCIZ	" utilise les icnes"	.B	ODBCR	.B	ODBSQUARE,BDEFASC	.ASCIZ	" utilise les ascenseurs"	.B	ODBCR	.B	ODBSQUARE,BDEFFILL	.ASCIZ	" remplissage jusque dans les bords"	.B	ODBCR	.B	ODBSQUARE,BDEFMDC	.ASCIZ	" mmorise la dernire case"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEFINE:	.W	F1,F2,F3,CR,0		DOKCR-TKEY_DEFINE	.W	F13,F14,F15,END,0	DOKEND-TKEY_DEFINE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEFINE	.W	0TDBOX_ZOOM:	.W	10$-TDBOX_ZOOM	.W	20$-TD