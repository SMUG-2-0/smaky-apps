	.SBTTL	DESICONE;--------\\; DESPDEF >;========/; Dessine la forme du pinceau dans les icnes.; in	-; out	-; mod	D7.WDESPDEF:	PUSHM.L	D2..D4,A3,A4	CLR.L	D4	CALL	DRMDEF	LOAD.B	D3,#ICOPDEF	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE 90$	LOAD.L	A4,#(A6)+OPDEF	LOAD.W	D3,(A6)+ONPDEF	MUL.WU	D3,#8+2	ADD.L	A4,D3		; A4 <-- ^bon pinceau	LOAD.L	D3,D4	ADD.W	D3,#((GCICX/2+GCIMX*2)-8)/2	SWAP.W	D3	ADD.W	D3,#((GCICY+GCIMY*2)-8)/2	SWAP.W	D3	LOAD.L	D4,#H'10000*8+8	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface l'ancien pinceau	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#1	; source: <ii>	SWAP.W	D3	LOAD.L	(A3)+12,D3	; destination: <xx> et <yy>	CLR.L	(A3)+16		; destination: <pppp>	SWAP.W	D4	LOAD.L	(A3)+22,D4	; <dxx> et <dyy>	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; cran <-- pinceau90$:	POPM.L	D2..D4,A3,A4	RET;--------\\; DESTDEF >;========/; Dessine la trame de remplissage dans les icnes.; in	-; out	-; mod	D7.WDESTDEF:	PUSHM.L	D2..D4,A4	CLR.L	D4	CALL	DRMDEF		; dfinit trame pour effacer	LOAD.B	D3,#ICOTDEF	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE 90$	LOAD.L	A4,#(A6)+OTDEF	LOAD.W	D3,(A6)+ONTDEF	MUL.WU	D3,#8	ADD.L	A4,D3		; A4 <-- ^bonne trame	LOAD.L	D3,D4	ADD.W	D3,#4	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2-4*2	SWAP.W	D4	LOAD.W	D4,#GCICX/2+GCIMX*2-4*2	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface l'ancienne trame	PUSHM.L	D3,D4	LOAD.L	D3,(A4)+0	LOAD.L	D4,(A4)+4	LIB	?DRMDEF		; dfinit la trame de remplissage	POPM.L	D3,D4	LOAD.W	D2,#SETDOT; Dessine la trame de remplissage en 5 morceaux pour raliser; les coins arrondis suivants :;;	. . . O O O O O O O           (1);	. O O O O O O O O O           (2);	. O O O O O O O O O           (2);	O O O O O O O O O O           (3);	O O O O O O O O O O           (3);	O O O O O O O O O O           ...	PUSHM.L	D3,D4	ADD.W	D3,#3	SUB.W	D4,#3*2	SWAP.W	D4	LOAD.W	D4,#1	SWAP.W	D4	LIB	?DRMATRIX	; haut (1)	POPM.L	D3,D4	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#1*2	SWAP.W	D4	LOAD.W	D4,#2	SWAP.W	D4	LIB	?DRMATRIX	; (2)	POPM.L	D3,D4	PUSHM.L	D3,D4	SWAP.W	D3	ADD.W	D3,#3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,#3*2	SWAP.W	D4	LIB	?DRMATRIX	; milieu (3)	POPM.L	D3,D4	PUSHM.L	D3,D4	INC.W	D3	SUB.W	D4,#1*2	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SUB.W	D3,#3	LOAD.W	D4,#2	SWAP.W	D3	SWAP.W	D4	LIB	?DRMATRIX	; (4)	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,#3	SUB.W	D4,#3*2	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	DEC.W	D3	LOAD.W	D4,#1	SWAP.W	D3	SWAP.W	D4	LIB	?DRMATRIX	; bas (5)	POPM.L	D3,D490$:	POPM.L	D2..D4,A4	RET	.IF	DESSIN;--------\\; DESZONE >;========/; Dessine le numro de la zone.; in	-; out	-; mod	D7.WDESZONE:	PUSHM.L	D2..D4	LOAD.B	D3,#ICOVZONE	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE 90$	LOAD.L	D3,D4	SWAP.W	D3	ADD.W	D3,#GCIMY+3	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LOAD.W	D4,#GCICX+GCIMX*4	SUB.W	D4,(A0)+ODFCX	ASR.W	D4,#1	ADD.W	D3,D4	LIB	?SETCURS	CLR.L	D4	CALL	DRMDEF		; dfinit trame pour effacer	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LOAD.W	D4,(A0)+ODFC1Y	SWAP.W	D4	LOAD.W	D4,(A0)+ODFCX	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface l'emplacement	LIB	?AFTIM	.B	MODCAR,INVDOT,0	.EVEN	LOAD.W	D3,(A6)+ONOZO	INC.B	D3	COMP.B	D3,#NBZONE	JUMP',NE 40$	CLR.B	D340$:	ADD.B	D3,#'0	LIB	?AFCAR		; affiche le numro de la zone	LIB	?AFTIM	.B	MODCAR,SETDOT,0	.EVEN90$:	POPM.L	D2..D4	RET	.ENDIF	.IF	EDGAR;--------\\; DESCODE >;========/; Dessine le caractre en dition et son numro de code; sous la forme :;			xxx C; in	-; out	-; mod	D7.WDESCODE:	PUSHM.L	D2..D4	LOAD.B	D3,#ICOCAR	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE 90$	LOAD.L	D3,D4	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SUB.W	D4,(A0)+ODFC1Y	ASR.W	D4,#1	ADD.W	D4,(A0)+ODFC1Y	ADD.W	D3,D4	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#5+1		; +1 pour mettre "A" plus au milieu	SUB.W	D4,#GCICX+GCIMX*4	NEG.W	D4	ASR.W	D4,#1	ADD.W	D3,D4	LIB	?SETCURS	TEST.L	(A6)+OPGC	; gencar existe ?	JUMP',EQ 80$		; non => 80$	CLR.L	D4	LOAD.B	D4,(A6)+OCAR	COMP.B	D4,#-1	JUMP',EQ 80$	LOAD.W	D3,#3		; D3 <-- nb digits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC	LIB	?AFSPACE	LOAD.B	D3,D4	LIB	?AFCODE	JUMP'	90$80$:	LIB	?AFTIM	.ASCIZ	"     "		; efface le prcdent	.EVEN90$:	POPM.L	D2..D4	RET;--------\\; DESMUL  >;========/; Dessine le nombre 1x.; in	-; out	-; mod	D7.WDESMUL:	PUSHM.L	D2..D4	LOAD.B	D3,#ICOMUL	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE 90$	LOAD.L	D3,D4	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SUB.W	D4,(A0)+ODFC1Y	SR.W	D4,#1	ADD.W	D4,(A0)+ODFC1Y	ADD.W	D3,D4	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#3+1		; +1 pour centrer plutt 1x que 10x	SUB.W	D4,#GCICX+GCIMX*4	NEG.W	D4	ASR.W	D4,#1	ADD.W	D3,D4	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A6)+OMUL	LOAD.W	D3,#2		; D3 <-- nb digits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC	LOAD.B	D3,#'x	LIB	?AFCAR90$:	POPM.L	D2..D4	RET	.ENDIF	.IF	DESSIN;---------\\; MEMICONE >;=========/; Mmorise toutes les icnes dessines  gauche.; in	-; out	D7.W	erreur; mod	D7.WMEMICONE:	PUSHM.L	D1..D6,A1..A4	CLR.W	D7	TEST.L	(A6)+OPICO	; icnes dj mmorises ?	JUMP,NE 90$		; oui => 90$	LOAD.L	D4,#ICOLY*(ICOLX/8)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour icnes	JUMP,NE 90$	LOAD.L	(A6)+OPICO,A4	LOAD.L	A3,#0		; A3 <-- ^source (dans l'cran)	LOAD.L	D3,(A6)+ODICO	SUB.W	D3,#GCIMX+6	SWAP.W	D3	SUB.W	D3,#GCIMY+5	SWAP.W	D3;	LOAD.L	A4,A4		; A4 <-- ^destination	CLR.L	D4	LOAD.W	D6,#ICOLX/8	LOAD.L	D2,#H'10000*ICOLY+ICOLX	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0		; A2 <-- ^descripteur WDO	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; appel GRA_RASTER	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; MENUICONE >;==========/; Propose le menu des icnes de gauche ...; in	-; out	D3.B	icne clique;	D7.W	erreur; mod	D3.L, D7.WMENUICONE:	PUSHM.L	D0..D2,D4..D6,A1..A4	LOAD.W	D7,#1	TEST.L	(A6)+OPICO	JUMP,EQ 90$	LIB	?GETWDO	LOAD.W	D6,D5		; D6 <-- no swdo actuelle	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 90$	CLR.B	D3	CALL	SELMO		; remet la flche	LOAD.L	D3,D4		; D3 <-- position de la souris	ADD.W	D3,#8		; D3 <-- souris toujours  gauche des icnes	LOAD.W	D4,(A0)+ODFDX	SUB.W	D4,#ICOLX	COMP.W	D3,D4		; trop  gauche ?	JUMP',LS 20$	LOAD.W	D3,D420$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,#ICOLY	COMP.W	D3,D4		; trop en bas ?	JUMP',LS 25$	LOAD.W	D3,D425$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	D4,#H'10000*ICOLY+ICOLX	LIB	?CREWDO	LIB	?USEWDO	LIB	?AFTIM	.B	SAVWDO		; sauve le contenu	.B	EOP		; puis efface tout	.B	0	.EVEN	CALL	CCMO		; enlve la souris	PUSHM.L	D5,D6	LOAD.L	A3,(A6)+OPICO	; A3 <-- ^source	CLR.L	D3	LOAD.W	D5,#ICOLX/8	LOAD.L	A4,#0		; A4 <-- ^destination (dans l'cran)	CLR.L	D4	LOAD.L	D2,#H'10000*ICOLY+ICOLX	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0		; A2 <-- ^descripteur WDO	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; appel GRA_RASTER	POPM.L	D5,D6	CLR.L	D3	LOAD.L	D4,#H'10000*(ICOLY-1)+(ICOLX-1)	LOAD.W	D2,#SETDOT	LIB	?DRRECT	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; dessine un joli cadre autour	PUSH.L	(A6)+ODICO	LOAD.L	(A6)+ODICO,#H'10000*8+12	TSET.B	(A6)+ODEF+3:#BDEFICO	CALL	MAJICONE	; mj. les icnes variables	CALL	SCMO		; remet la souris	CLR.B	D232$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 35$		; non => 35$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 32$	CALL	DETICONE	; D3 <-- icne o est la souris	JUMP,NE 32$	COMP.B	D3,D2	JUMP,EQ 32$	EX.L	D3,D2	CALL	INVICONE	; teint l'ancienne icne34$:	LOAD.B	D3,D2	CALL	INVICONE	; allume la nouvelle icne	JUMP	32$35$:	LOAD.B	D3,D2	CALL	INVICONE	; teint l'ancienne icne	TCLR.B	(A6)+ODEF+3:#BDEFICO	POP.L	(A6)+ODICO	LIB	?AFTIM	.B	GETWDO		; restitue le contenu	.B	0	.EVEN	EX.L	D5,D6	LIB	?USEWDO	EX.L	D5,D6	LIB	?KILWDO	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2,D4..D6,A1..A4	RET	.ENDIF;---------\\; DESICONE >;=========/; Dessine une liste d'icnes en colonne.; in	-; out	-; mod	D7.WDESICONE:	PUSHM.L	D0,A3	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC 90$		; non => 90$	CLR.W	D0		; D0 <-- dessine	LOAD.L	A3,#R16"TICOGAUCHE	CALL	XXXICONE	.IF	EDGAR	LOAD.L	A3,#R16"TICODROITE	CALL	XXXICONE	.ENDIF90$:	POPM.L	D0,A3	RET;---------\\; DETICONE >;=========/; Dtecte dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D3.B	icne o est la souris;	D7.W	ok/erreur; mod	D3.L, D7.WDETICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D7,#1	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC 90$		; non => 90$	LOAD.W	D0,#1		; D0 <-- dtecte	LOAD.L	D5,D4		; D5 <-- position de la souris (y;x)	LOAD.L	A3,#R16"TICOGAUCHE	CALL	XXXICONE	.IF	EDGAR	JUMP',EQ 50$	LOAD.L	A3,#R16"TICODROITE	CALL	XXXICONE	.ENDIF	JUMP',NE 90$50$:	LOAD.B	D3,D5		; D3 <-- code de l'icne90$:	POPM.L	D0,D5,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; INVICONE >;=========/; Inverse une icne.; in	D3.B	icne  inverser; out	-; mod	D7.WINVICONE:	PUSHM.L	D0,D5,A3	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC 90$		; non => 90$	LOAD.W	D0,#2		; D0 <-- inverse	LOAD.B	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	LOAD.L	A3,#R16"TICOGAUCHE	CALL	XXXICONE	.IF	EDGAR	JUMP',EQ 90$	LOAD.L	A3,#R16"TICODROITE	CALL	XXXICONE	.ENDIF90$:	POPM.L	D0,D5,A3	RET;---------\\; POSICONE >;=========/; Donne la position d'une icne.; in	D3.B	icne; out	D4.L	position coin sup/gauche (y;x);	D7.W	erreur; mod	D7.WPOSICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D7,#1	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC 90$		; non => 90$	LOAD.W	D0,#3		; D0 <-- position	LOAD.B	D5,D3		; D5 <-- code de l'icne	LOAD.L	A3,#R16"TICOGAUCHE	CALL	XXXICONE	.IF	EDGAR	JUMP',EQ 50$	LOAD.L	A3,#R16"TICODROITE	CALL	XXXICONE	.ENDIF	JUMP',NE 90$50$:	LOAD.L	D4,D5		; D4 <-- position90$:	POPM.L	D0,D5,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; XXXICONE >;---------/; Dessine une liste d'icnes en colonne.; in	A3.L	^liste;	D0.W	opration dessine/dtecte/inverse/position;	D5.L	position de la souris (si dtecte);	D5.B	code de l'icne (si inverse/position); out	D5.B	icne o est la souris (si dtecte);	D5.L	coordonne (si position);	D7.W	ok/erreur (si dtecte ou inverse); mod	D5.L, D7.WXXXICONE:	PUSHM.L	D3,D4,A3	LOAD.L	D4,(A6)+ODICO	TEST.B	(A3+)		;  gauche ?	JUMP',EQ 10$		; oui => 10$	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,#(GCIMX+GCICX/2+GCIMX)*4+MARGX10$:	TEST.W	D0		; dessine ?	JUMP',NE 15$		; non => 15$	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN15$:	LOAD.L	D3,D420$:	COMP.B	(A3),#IF	; fin de la table ?	JUMP',EQ 80$	COMP.B	(A3),#IL	; va  la ligne suivante ?	JUMP',EQ 40$	COMP.B	(A3),#IC	; va  la ligne suivante ?	JUMP',EQ 45$	COMP.W	D0,#1	JUMP',EQ 30$	COMP.W	D0,#2	JUMP',EQ 35$	COMP.W	D0,#3	JUMP',EQ 35$				; dessine =>	CALL	XXXONEICONE	; dessine une icne25$:	ADD.L	A3,#2	JUMP	20$30$:				; dtecte =>	CALL	XXXONEICONE	; dtecte si dans cette icne ?	JUMP,NE 25$		; non => 25$	LOAD.B	D5,(A3)+1	; D5 <-- code de l'icne	JUMP'	80$35$:				; inverse/position =>	CALL	XXXONEICONE	; inverse cette icne ?	JUMP,NE 25$		; non => 25$	JUMP'	80$40$:				; grand interligne =>	SWAP.W	D3	ADD.W	D3,#GCICY+GCIMY*2	SWAP.W	D3	LOAD.L	D4,D3	INC.L	A3	JUMP	20$45$:				; petit interligne =>	SWAP.W	D3	ADD.W	D3,#5		; aligne en bas sur Smaky 100 !	SWAP.W	D3	LOAD.L	D4,D3	INC.L	A3	JUMP	20$80$:	TEST.W	D0		; dessine ?	JUMP',NE 90$		; non => 90$	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN90$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; XXXONEICONE >;------------/; Dessine/dtecte/inverse une icne.; in	A3.L	^lment dans table;	D4.L	coordonne coin sup/gauche;	D0.W	opration dessine/dtecte/inverse/position;	D5.L	position de la souris (si dtecte);	D5.B	code de l'icne (si inverse/position); out	D4.L	coordonne suivante;	D5.L	coordonne coin (si position);	D7.W	ok/erreur (si dtecte ou inverse); mod	D4.L, D5.L, D7.WXXXONEICONE:	PUSHM.L	D1..D3	LOAD.L	D1,D4		; D1 <-- coin	LOAD.L	D3,D4	SUB.W	D3,#GCIMX	SWAP.W	D3	SUB.W	D3,#GCIMY	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SWAP.W	D4	LOAD.W	D4,#GCICX/2+GCIMX*2	COMP.B	(A3)+0,#ID	JUMP',NE 20$	ADD.W	D4,#GCICX/2+GCIMX*220$:	COMP.W	D0,#1	JUMP,EQ 40$	COMP.W	D0,#2	JUMP,EQ 50$	COMP.W	D0,#3	JUMP,EQ 60$				; dessine =>	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	PUSH.L	D4	CLR.L	D4	CALL	DRMDEF	POP.L	D4	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour icne	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	LOAD.L	D3,D1		; D3 <-- coin	COMP.B	(A3)+0,#ID	JUMP',NE 30$	ADD.W	D3,#GCIMX30$:	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,(A3)+1	; D3 <-- code	LIB	?AFCODE	JUMP	80$40$:				; dtecte =>	LOAD.W	D7,#ERDIOUT	COMP.W	D5,D3		; souris trop  gauche ?	JUMP,LO 80$	ADD.W	D3,D4	COMP.W	D5,D3		; souris trop  droite ?	JUMP,HS 80$	SWAP.W	D3	SWAP.W	D4	LOAD.L	D2,D5	SWAP.W	D2	COMP.W	D2,D3		; souris trop en haut ?	JUMP,LO 80$	ADD.W	D3,D4	COMP.W	D2,D3		; souris trop en bas ?	JUMP,HS 80$	CLR.W	D7		; D7 <-- dans l'icone	JUMP	80$50$:				; inverse =>	LOAD.W	D7,#ERDIOUT	COMP.B	D5,(A3)+1	JUMP,NE 80$	PUSH.L	D4	LOAD.L	D4,#-1	CALL	DRMDEF	POP.L	D4	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#2+2	SWAP.W	D4	SUB.W	D4,#2+2	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	CLR.W	D7	JUMP	80$60$:				; position =>	LOAD.W	D7,#ERDIOUT	COMP.B	D5,(A3)+1	JUMP,NE 80$	LOAD.L	D5,D3		; D5 <-- position	CLR.W	D780$:	LOAD.L	D4,D1	ADD.W	D4,#GCICX/2+GCIMX*2	COMP.B	(A3)+0,#ID	JUMP',NE 90$	ADD.W	D4,#GCICX/2+GCIMX*290$:	POPM.L	D1..D3	TEST.W	D7		; retour EQ/NE	RET	.END