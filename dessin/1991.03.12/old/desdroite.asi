	.SBTTL	DESDROITEMILIEU:	.IF	DESSIN	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP,BC 50$		; non => 50$	.ENDIF	LOAD.L	A3,#R16"TMENUMILIEU	CLR.L	D4		; D4 <-- toutes les cases	TEST.B	(A6)+OMAJ	; mise  jour ncessaire ?	JUMP',T 10$		; oui => 10$	TSET.L	D4:#3		; D4 <-- plus de case "sauve"10$:	.IF	DESSIN	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE 20$	TSET.L	D4:#7		; D4 <-- plus de case "chelle 1:1"20$:	COMP.W	(A6)+OSCALE,#SCALEMAX	JUMP',NE 22$	TSET.L	D4:#8		; D4 <-- plus de case "chelle +"22$:	TEST.W	(A6)+OASHOR+OSCHTV	JUMP',NE 24$	TEST.W	(A6)+OASVER+OSCHTV	JUMP',NE 24$	TSET.L	D4:#6		; D4 <-- plus de case "chelle -"	TSET.L	D4:#11		; D4 <-- plus de case "tout"24$:	.ELSE	COMP.W	(A6)+OSCALE,#SCALEMIN	JUMP',NE 20$	TSET.L	D4:#6		; D4 <-- plus de case "petit"20$:	COMP.W	(A6)+OSCALE,#SCALELOUPE	JUMP',NE 22$	TSET.L	D4:#7		; D4 <-- plus de case "moyen"22$:	COMP.W	(A6)+OSCALE,#SCALEMAX	JUMP',NE 24$	TSET.L	D4:#8		; D4 <-- plus de case "grand"24$:	.ENDIF	LOAD.W	D3,#2^15	; D3 <-- utilise D4 en entre	LOAD.L	A4,#(A6)+OMDCMI	; A4 <-- ^dernire case	CALL	MMENU		; action selon mmenu ...	DEC.W	D3	JUMP,NS LOOP	LOAD.L	A3,#R16"TCARMILIEU	SL.W	D3,#1		; D3 <-- *2 car table de .W	LOAD.W	D3,(A3)+(D3.W)	; D3 <-- touche presse	JUMP	EXECUTE	.IF	DESSIN50$:	CALL	MENUICONE	; menu des icnes de gauche ...	JUMP,NE LOOP	TEST.B	D3	JUMP,EQ LOOP	JUMP	CLICICONE	.ENDIFENTOURE:	LOAD.B	D3,(A6)+OSELECT	; D3 <-- type de slection choisie	COMP.B	D3,#ICOZONE	JUMP,EQ ENTOUREZONE	COMP.B	D3,#ICOFILET	JUMP,EQ ENTOUREFILET	COMP.B	D3,#ICOCROCHET	JUMP,EQ ENTOURECROCHET	JUMP	BIPENTOUREZONE:	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCOPY	; touche (COPY) enfonce ?	JUMP',BS 10$		; oui => 10$				; non =>	CALL	IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	LOAD.L	D1,D3		; D1 <-- coin initial	LOAD.L	D2,D3	LOAD.L	D5,D3	JUMP	20$10$:	CLR.B	D3	CALL	SELMO		; utilise le lutin flche	LOAD.L	D1,(A6)+OLASTP1	LOAD.L	D2,(A6)+OLASTP2	INC.W	D2	SWAP.W	D2	INC.W	D2	SWAP.W	D2	LOAD.L	D5,D2	LOAD.L	D3,D2	CALL	CONVGPOINT	JUMP',NE 15$	LOAD.L	D4,D3	CALL	PMOUSE		; remet la souris dans le bon coin15$:	CALL	INVENTOURE	; dessine le premier tour20$:	CLR.B	D3	CALL	SELMO		; utilise le lutin flche	CALL	WAITMOVE	; attend dplacement souris ...	COMP.W	D3,#'1	JUMP,EQ 60$	COMP.W	D3,#'2	JUMP,EQ 60$	COMP.W	D3,#'3	JUMP,EQ 60$	TEST.W	D7	JUMP,NE 50$		; fin du dplacement => 50$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 20$	.IF	DESSIN	CALL	RGMOUSE		; dessine la position dans les rgles	.ENDIF	CALL	DETGPOINTF	; D3 <-- point o est la souris	COMP.L	D3,D5		; souris dplace ?	JUMP,EQ 20$		; non => 20$	LOAD.L	D2,D3	EX.L	D2,D5	CALL	INVENTOURE	; efface l'ancien tour	LOAD.L	D2,D5	CALL	INVENTOURE	; dessine le nouveau tour	JUMP	20$50$:	LOAD.L	(A6)+OLASTP1,D1	LOAD.L	(A6)+OLASTP2,D2	CLR.L	D0		; D0 <-- souris dans le coin	JUMP	ENTOUREMENU60$:	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NS 20$		; oui => 20$	COMP.B	(A6)+OSELECT,#ICOZONE ; filet/crochet ?	JUMP,NE 20$		; oui => 20$	SUB.W	D3,#'1		; D3 <-- 0..2	CALL	INVENTOURE	; efface l'ancien tour	JUMP	QUICKBLOCENTOUREFILET:	CALL	IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	LOAD.L	A4,(A6)+OPMAM	CALL	CLEARALL	; efface toute la matrice masque	CALL	COPYALL		; fait une copie de la matrice	LOAD.L	D5,D3		; D5 <-- origine fixe	CLR.W	D0		; D0 <-- souris pas bouge	PUSH.B	(A6)+OOUTIL	PUSH.B	(A6)+OOBJET	LOAD.B	(A6)+OOUTIL,#ICOCRAYON	LOAD.B	(A6)+OOBJET,#ICOFILET	PUSH.L	D5		; stack <-- origine	CLR.B	D3	CALL	SELMO		; utilise le lutin flche	LOAD.W	D4,#2	NTREL	?DELMS		; attend qu'il change ... !	LOAD.L	D1,#-1		; D1 <-- coin sup/gauche	CLR.L	D2		; D2 <-- coin inf/droite20$:	CLR.B	D3	CALL	SELMO		; utilise le lutin flche	CALL	SCMO		; montre la flche	CALL	WAITMOVE	; attend dplacement souris ...	JUMP,NE 50$		; fin du dplacement => 50$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 20$	.IF	DESSIN	CALL	RGMOUSE		; dessine la position dans les rgles	.ENDIF	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE 20$	COMP.L	D3,D5		; souris dplace ?	JUMP,EQ 20$		; non => 20$				; oui =>	COMP.W	D1,D3	JUMP',LS 24$	LOAD.W	D1,D3		; D1 <-- extrme gauche24$:	COMP.W	D2,D3	JUMP',HS 25$	LOAD.W	D2,D3		; D2 <-- extrme droite25$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	COMP.W	D1,D3	JUMP',LS 26$	LOAD.W	D1,D3		; D1 <-- extrme haut26$:	COMP.W	D2,D3	JUMP',HS 27$	LOAD.W	D2,D3		; D2 <-- extrme bas27$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	LOAD.L	D6,D3		; D6 <-- arrive	PUSH.W	D2	LOAD.W	D2,#INVDOT!TTTDOT!NCTDOT	CALL	DESCOMMEPLAN	; petit: dessine droite de "origine"  "arrive"	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim de la droite	POP.W	D2	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE 30$	CALL	CPECRANMATRIX	; matrice principale <-- cran	JUMP'	35$30$:	PUSH.L	D1	CLR.L	D1		; D1 <-- pas de dplacement	CALL	SHOGMATRIX	; grand: dessine aussi la droite	POP.L	D135$:	LOAD.L	D5,D6		; D5 <-- future origine	INC.W	D0		; D0 <-- souris bouge	JUMP	20$50$:	POP.L	D6		; D6 <-- point initial	COMP.L	D6,D5	JUMP',EQ 65$				; lie le dpart  l'arrive =>	PUSH.W	D2	LOAD.W	D2,#INVDOT!TTTDOT!NCTDOT	CALL	DESCOMMEPLAN	; petit: dessine droite de "origine"  "arrive"	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim de la droite	POP.W	D2	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE 60$	CALL	CPECRANMATRIX	; matrice principale <-- cran	JUMP'	65$60$:	PUSH.L	D1	CLR.L	D1		; D1 <-- pas de dplacement	CALL	SHOGMATRIX	; grand: dessine aussi la droite	POP.L	D165$:	POP.B	(A6)+OOBJET	POP.B	(A6)+OOUTIL	TEST.W	D0		; souris bouge ?	JUMP,EQ BIP		; non => BIP				; oui =>	CALL	UNDOALL		; rcupre tout pour effacer le filet !	CALL	DESMATRIX	; redessine toutes les matrices	LOAD.L	D3,D5	CALL	DESFILET	; matrice masque <-- rempli le filet	JUMP,NE BIP	JUMP	ENTOURERMENUENTOURECROCHET:	CALL	IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	LOAD.L	A3,#R16"00$	; A3 <-- ^liste des points o chercher	LOAD.L	D0,D310$:	COMP.W	(A3),#100	; fin de la table ?	JUMP,EQ BIP		; oui => BIP (on a rien accroch)	LOAD.L	D3,D0	SWAP.W	D3	ADD.W	D3,(A3+)	SWAP.W	D3	ADD.W	D3,(A3+)	; D3 <-- point cherch	LOAD.L	A1,(A6)+OPMAT	CALL	TESTPOINT	JUMP,NE 10$	TEST.B	(A1):D1		; point montr allum ?	JUMP,BC 10$		; non => 10$				; oui =>	LOAD.L	D0,D3		; D0 <-- point "croch"	CALL	WAITMOUSE	; met le sablier	LOAD.L	A3,(A6)+OPMAT	LOAD.L	A4,(A6)+OPMAM	CALL	XFERALL		; matrice masque <-- matrice principale	CALL	BOLDALL		; matrice masque <-- plus pais	CALL	INVALL		; matrice masque <-- l'inverse;	LOAD.L	A4,(A6)+OPMAM	CALL	OPEDISMAT	; dessine dans la matrice masque	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	DRMDEF		; dfinit une trame pleine	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWFILLO	LOAD.L	D3,D0	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.W	D3,#5	LIB	?STRING		; rempli ...	JUMP,NE 40$;	LOAD.L	A4,(A6)+OPMAM	CALL	CLEARALL	; matrice masque <-- efface	LOAD.L	A3,(A0)+ODFFIP	LOAD.L	D1,#-1		; D1 <-- coin sup/gauche	CLR.L	D2		; D2 <-- coin inf/droite20$:	CLR.W	D7		; D7 <-- ok	LOAD.L	A3,#(A3)+LGRAF	; A3 <-- ^ligne suivante	COMP.W	(A3),#-1	JUMP,EQ 40$	LOAD.L	D3,(A3)+OGRAFY	CLR.L	D4	LOAD.W	D4,(A3)+OGRAFXF	SUB.W	D4,D3	INC.W	D4	PUSHM.L	D2,D3	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; redessine ligne par ligne	POPM.L	D2,D3	COMP.W	D1,D3	JUMP',LS 24$	LOAD.W	D1,D3		; D1 <-- extrme gauche24$:	COMP.W	D2,D3	JUMP',HS 25$	LOAD.W	D2,D3		; D2 <-- extrme droite25$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	COMP.W	D1,D3	JUMP',LS 26$	LOAD.W	D1,D3		; D1 <-- extrme haut26$:	COMP.W	D2,D3	JUMP',HS 27$	LOAD.W	D2,D3		; D2 <-- extrme bas27$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	ADD.W	D3,D4		; D3 <-- position d'arrive	COMP.W	D1,D3	JUMP',LS 34$	LOAD.W	D1,D3		; D1 <-- extrme gauche34$:	COMP.W	D2,D3	JUMP',HS 35$	LOAD.W	D2,D3		; D2 <-- extrme droite35$:	JUMP	20$40$:	PUSH.W	D7	LOAD.B	D3,#DRAWFILLC	LIB	?AFCAR		; libre le remplissage	CALL	CLODISMAT	; redessine dans l'cran	POP.W	D7	JUMP,NE BIGBIP50$:	LIB	?IFMOUSE	; attend que l'on relche les boutons ...	TEST.B	D3	JUMP,NE 50$	LOAD.L	D5,D0	JUMP	ENTOURERMENU00$:	.W	0,0	.W	0,1	.W	1,1	.W	1,0	.W	1,-1	.W	0,-1	.W	-1,-1	.W	-1,0	.W	-1,1	.W	-1,2	.W	0,2	.W	1,2	.W	2,2	.W	2,1	.W	2,0	.W	2,-1	.W	2,-2	.W	1,-2	.W	0,-2	.W	-1,-2	.W	-2,-2	.W	-2,-1	.W	-2,0	.W	-2,1	.W	-2,2	.W	100ENTOURERMENU:	CALL	INVENTOURE	; dessine le tour rectangulaire	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; enlve le sablier	LOAD.L	D0,D2	SUB.W	D0,D5	LOAD.W	D3,D0	MUL.WU	D3,(A6)+OSCALE	LOAD.W	D0,D3	SWAP.W	D0	SWAP.W	D5	SUB.W	D0,D5		; D0 <-- offset pour ne pas bouger la souris !	LOAD.W	D3,D0	MUL.WU	D3,(A6)+OSCALE	LOAD.W	D0,D3	SWAP.W	D0	SWAP.W	D5ENTOUREMENU:	CALL	IFMOUSE		; D4 <-- position souris avant mmenu	PUSH.L	D4	LOAD.L	A3,#R16"TMENUENTOURE	CLR.L	D4		; D4 <-- toutes les cases	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP',NC 10$		; non => 10$	TSET.L	D4:#4		; D4 <-- plus de case "bloc-notes"	TSET.L	D4:#8		; D4 <-- plus de case "dforme"10$:	COMP.B	(A6)+OSELECT,#ICOZONE ; filet/crochet ?	JUMP',EQ 20$		; non => 20$	TSET.L	D4:#4		; D4 <-- plus de case "bloc-notes"20$:	LOAD.W	D3,#2^15	; D3 <-- utilise D4 en entre	LOAD.L	A4,#(A6)+OMDCDR	; A4 <-- ^dernire case	CALL	MMENU		; action selon mmenu ...	POP.L	D4	DEC.W	D3	JUMP,EQ ZONEDETRUIT	DEC.W	D3	JUMP,EQ ZONEDEPLACE	DEC.W	D3	JUMP,EQ ZONEDUPLIQUE	DEC.W	D3	JUMP,EQ ZONEBLOC	DEC.W	D3	JUMP,EQ ZONEZOOM	DEC.W	D3	JUMP,EQ ZONETOURNE	DEC.W	D3	JUMP,EQ ZONEMIROIR	DEC.W	D3	JUMP,EQ ZONEDEFORME	DEC.W	D3	JUMP,EQ ZONERELIEF	DEC.W	D3	JUMP,EQ ZONENEGATIF	.IF	DESSIN	DEC.W	D3	JUMP,EQ ZONELOUPE	DEC.W	D3	JUMP,EQ ZONESAUVE	.ENDIF	CALL	INVENTOURE	; efface l'ancien tour	JUMP	LOOPMACRODETRUIT:	CALL	COPYZALL	; fait une copie de la matrice	CALL	GETPARAM	; D0..D6 <-- paramtres	JUMP	OPERDETRUITZONEDETRUIT:	CALL	COPYZALL	; fait une copie de la matrice	CALL	INVENTOURE	; efface l'ancien tour	CALL	POSDIM		; D1 <-- pos et D2 <-- dimOPERDETRUIT:	CALL	D1D2SCALEN	; D1/D2 <-- agrandi si "tout"	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; D4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- position source	LOAD.L	D4,D1		; D4 <-- position destination	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	XFERZONE	; inverse avec source = destination !	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	LOAD.L	D1,D4		; D1 <-- origine	LOAD.L	D2,D5		; D2 <-- dimensions	LOAD.W	D4,#KEYICO+ICODETRUIT	CALL	PUTPARAM	; macro <-- paramtres	JUMP,NE ERROR	JUMP	LOOPMACRODEPLACE:	CALL	COPYZALL	; fait une copie de la matrice	CALL	GETPARAM	; D0..D6 <-- paramtres	PUSHM.L	D1,D2	LOAD.L	D1,D5	LOAD.L	D2,D6	LOAD.W	D0,#INVDOT	CALL	DDPGMATRIX	; efface l'ancienne matrice	POPM.L	D1,D2	LOAD.B	(A6)+ODDOP,#ICODEPLACE	JUMP	OPERMOVEZONEDEPLACE:	CALL	COPYZALL	; fait une copie de la matrice	CALL	PMOUSE		; remet souris comme avant mmenu	LOAD.L	D5,D1		; D5 <-- origine	LOAD.L	D6,D2		; D6 <-- arrive (o est la souris)	LOAD.B	(A6)+ODDOP,#ICODEPLACE	JUMP	ZONEMOVEMACRODUPLIQUE:	CALL	COPYZALL	; fait une copie de la matrice	CALL	GETPARAM	; D0..D6 <-- paramtres	LOAD.B	(A6)+ODDOP,#ICODUPLIQUE	JUMP	OPERMOVEZONEDUPLIQUE:	CALL	COPYZALL	; fait une copie de la matrice	CALL	PMOUSE		; remet souris comme avant mmenu	LOAD.L	D5,D1		; D5 <-- origine	LOAD.L	D6,D2		; D6 <-- arrive (o est la souris)	LOAD.B	(A6)+ODDOP,#ICODUPLIQUE;	JUMP	ZONEMOVE; in	D1/D2		rectangle dans matrice principale;	D5/D6		rectangle dans matrice masque;	D4.L		position de la souris;	D0.L		offset position souris;	(A6)+ODDOP.B	opration (ICODEPLACE, etc.)ZONEMOVE:	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D4	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D4	CALL	DETGPOINTF	; D3 <-- point o est la souris	CALL	FIXPAS		; fixe l'origine pour le pas	COMP.B	(A6)+ODDOP,#ICODEPLACE	JUMP',NE 18$	CALL	DDISOURCE	; efface dans matrice copie18$:	CALL	DDINIT		; init pour dplacement20$:	CALL	SCMO	CLR.W	D4	NTREL	?SETTIM		; met timeout nul (trs trs court)	CALL	WAITMOVE	; attend dplacement souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	JUMP,NE 50$		; fin du dplacement => 50$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 20$	.IF	DESSIN	CALL	RGMOUSE		; dessine la position dans les rgles	.ENDIF	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D4	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D4	CALL	DETGPOINTOUT	; D3 <-- point o est la souris	CALL	RNDPAS		; D3 <-- arrondi selon le pas	COMP.L	D3,D2		; souris dplace ?	JUMP,EQ 20$		; non => 20$				; oui =>	CALL	DDINVENTOURE	; efface l'ancien tour	SUB.W	D3,D2	ADD.W	D1,D3	ADD.W	D2,D3	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SUB.W	D3,D2	ADD.W	D1,D3	ADD.W	D2,D3	SWAP.W	D1	SWAP.W	D2;	SWAP.W	D3	CALL	TESTBORD	; D1/D2 <-- ne dpassent pas les bords	CALL	DDMOVE		; dplace dans l'cran	CALL	DDINVENTOURE	; dessine le nouveau tour	JUMP	20$50$:	CALL	DDPRECT		; efface rectangle dans matrice masque	CALL	DDMOVE		; dplace dans l'cran	COMP.B	(A6)+ODDOP,#ICODEPLACE	JUMP',NE 52$	CALL	DDISOURCE	; remet dans matrice copie52$:	CALL	DDCCLOSE	; ferme la matrice contour	LOAD.L	(A6)+OLASTP1,D1	LOAD.L	(A6)+OLASTP2,D2	CALL	DDINVENTOURE	; efface le dernier tour	.IF	DESSIN	CALL	DESREGLE	; dessine les rgles	.ENDIF	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NC RECMOVE		; non => RECMOVEOPERMOVE:	PUSHM.L	D1,D2,D5,D6	LOAD.W	D0,#SETDOT	CALL	DDPGMATRIX	; dessine la matrice dfinitive	CALL	POSDIM		; D1 <-- pos et D2 <-- dim (nouveau)	CALL	D1D2SCALEN	; D1/D2 <-- agrandi si "tout"	EX.L	D1,D5	EX.L	D2,D6	CALL	POSDIM		; D5 <-- pos et D6 <-- dim (initial)	CALL	D1D2SCALEN	; D5/D6 <-- agrandi si "tout"	EX.L	D1,D5	EX.L	D2,D6	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice masque	LOAD.L	D3,D5	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D4,D1	LOAD.L	D5,D6		; D5 <-- dimensions	COMP.B	(A6)+ODDOP,#ICODEPLACE	JUMP',NE 40$	PUSHM.L	D4,A3;	LOAD.L	A3,A4	LOAD.L	D4,D3	LOAD.W	D2,#INVDOT	CALL	XFERZONE	; matrice principale <-- efface	POPM.L	D4,A340$:	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CALL	XFERZONE	; matrice principale <-- zone dplace	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP',NC 50$		; non => 50$	CALL	DESPMATRIX	; oui => redessine la matrice50$:	POPM.L	D1,D2,D5,D6RECMOVE:	CLR.W	D4	LOAD.B	D4,(A6)+ODDOP	JUMP,EQ LOOP	ADD.W	D4,#KEYICO	; D4 <-- par ex: #KEYICO+ICODEPLACE	CALL	PUTPARAM	; macro <-- paramtres	JUMP,NE ERROR	JUMP	LOOPMACROBLOC:	CALL	GETPARAM	; D0..D6 <-- paramtres	LOAD.L	A4,D0	JUMP'	OPERBLOCZONEBLOC:	LOAD.L	A3,#R16"TMENUBLOC	CLR.W	D3	LOAD.L	A4,#(A6)+OMDCBN	; A4 <-- ^dernire case	CALL	MMENU		; action selon mmenu ...	CALL	INVENTOURE	; efface l'ancien tour	DEC.W	D3	JUMP,NS LOOPQUICKBLOC:	LOAD.L	A4,#(A6)+OBLOC	LOAD.W	D4,D3		; D4 <-- 0..2	MUL.WU	D4,#LGBLOC	ADD.L	A4,D4		; A4 <-- ^bloc-notesOPERBLOC:	LOAD.L	(A4)+OBLKPT,(A6)+OPMAT	LOAD.L	(A4)+OBLKP1,D1	LOAD.L	(A4)+OBLKP2,D2	LOAD.W	(A4)+OBLKNBB,(A6)+OMANBB	LOAD.L	D0,A4	LOAD.W	D4,#KEYICO+ICOBLOC	CALL	PUTPARAM	; macro <-- paramtres	JUMP,NE ERROR	ADD.W	D3,#ICOBLOC1	; D3 <-- ICOBLOC1..3	JUMP	OBJETNEWMACROZOOM:	CALL	GETPARAM	; D0..D6 <-- paramtres	JUMP'	OPERZOOMZONEZOOM:	LOAD.L	A3,#R16"TMENUZOOM	CLR.L	D4		; D4 <-- toutes les cases	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP',NC 10$		; non => 10$	TSET.L	D4:#7		; D4 <-- plus de case "autre"10$:	LOAD.W	D3,#2^15	; D3 <-- utilise D4 en entre	LOAD.L	A4,#(A6)+OMDCZM	; A4 <-- ^dernire case	CALL	MMENU		; action selon mmenu ...	CALL	INVENTOURE	; efface l'ancien tour	TEST.W	D3	JUMP,EQ LOOP	LOAD.B	D4,#ICOZOOMQQ	COMP.W	D3,#7	JUMP,EQ QQDEFORMEOPERZOOM:	CALL	D1D2SCALEN	; D1/D2 <-- agrandi si "tout"	CALL	ZOOMMATRIX	JUMP,NE BIP	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	LOAD.W	D4,#KEYICO+ICOZOOM	CALL	PUTPARAM	; macro <-- paramtres	JUMP,NE ERROR	JUMP	LOOPMACROTOURNE:	CALL	GETPARAM	; D0..D6 <-- paramtres	JUMP'	OPERTOURNEZONETOURNE:	LOAD.L	A3,#R16"TMENUTOURNE	CLR.L	D4		; D4 <-- toutes les cases	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP',NC 10$		; non => 10$	TSET.L	D4:#4		; D4 <-- plus de case "autre"10$:	LOAD.W	D3,#2^15	; D3 <-- utilise D4 en entre	LOAD.L	A4,#(A6)+OMDCTN	; A4 <-- ^dernire case	CALL	MMENU		; action selon mmenu ...	CALL	INVENTOURE	; efface l'ancien tour	TEST.W	D3	JUMP,EQ LOOP	LOAD.B	D4,#ICOTOURNEQQ	COMP.W	D3,#4	JUMP,EQ QQDEFORMEOPERTOURNE:	CALL	D1D2SCALEN	; D1/D2 <-- agrandi si "tout"	CALL	TOURNEMATRIX	JUMP,NE BIP	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	LOAD.W	D4,#KEYICO+ICOTOURNE	CALL	PUTPARAM	; macro <-- paramtres	JUMP,NE ERROR	JUMP	LOOPMACROMIROIR:	CALL	GETPARAM	; D0..D6 <-- paramtres	JUMP'	OPERMIROIRZONEMIROIR:	LOAD.L	A3,#R16"TMENUMIROIR	CLR.W	D3	LOAD.L	A4,#(A6)+OMDCMR	; A4 <-- ^dernire case	CALL	MMENU		; action selon mmenu ...	CALL	INVENTOURE	; efface l'ancien tour	TEST.W	D3	JUMP,EQ LOOPOPERMIROIR:	CALL	D1D2SCALEN	; D1/D2 <-- agrandi si "tout"	CALL	MIROIRMATRIX	JUMP,NE BIP	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	LOAD.W	D4,#KEYICO+ICOMIROIR	CALL	PUTPARAM	; macro <-- paramtres	JUMP,NE ERROR	JUMP	LOOPZONEDEFORME:	LOAD.L	A3,#R16"TMENUDEFORME	CLR.W	D3	LOAD.L	A4,#(A6)+OMDCDF	; A4 <-- ^dernire case	CALL	MMENU		; action selon mmenu ...	CALL	INVENTOURE	; efface l'ancien tour	DEC.W	D3	JUMP,NS LOOP	LOAD.B	D4,#ICODEFORMETX	ADD.B	D4,D3QQDEFORME:	LOAD.L	A3,#R16"TXMPOIGNEE	LIB	?AFMENU	LOAD.L	A3,#R16"TPHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	CALL	COPYZALL	; fait une copie de la matrice	CALL	INIPOIGNEES	; init les 4 poigns	LOAD.B	D1,D4		; D1 <-- ICOxx	CALL	INVSELECT	; dessine la slection	LOAD.W	D0,#-1	CALL	INVPOIGNEES	; dessine les 4 poignes	CLR.B	(A6)+OSEBLX	CLR.B	(A6)+OSEBLYLOOP$:	LOAD.L	D3,#-1	CALL	DESINFXY	; efface les informations	CALL	SCMO		; montre la flche	LOAD.W	D0,#-1	LIB	?GETCAR		; attend souris ...	COMP.W	D3,#F0+SHIFT	JUMP',LO MAJ$	COMP.W	D3,#F15+SHIFT	JUMP',HI MAJ$	SUB.W	D3,#SHIFTMAJ$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	; clic-gauche ?	JUMP,EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP,EQ OK$	COMP.W	D3,#F1		; d'accord ?	JUMP,EQ OK$	COMP.W	D3,#F2	JUMP,EQ OK$	COMP.W	D3,#F3	JUMP,EQ OK$	COMP.W	D3,#UNDO	JUMP,EQ CANCEL$	COMP.W	D3,#END	JUMP,EQ CANCEL$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#F13		; annule ?	JUMP,EQ CANCEL$	COMP.W	D3,#F14	JUMP,EQ CANCEL$	COMP.W	D3,#F15	JUMP,EQ CANCEL$	COMP.W	D3,#F7		; <--> ?	JUMP,EQ BLOCX$	COMP.W	D3,#F8		; v ^  ?	JUMP,EQ BLOCY$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$BLOCX$:	NOT.B	(A6)+OSEBLX	SUB.W	D3,#F0	LIB	?INVBARRE	TEST.B	(A6)+OSEBLY	JUMP,F	LOOP$	CLR.B	(A6)+OSEBLY	LOAD.B	D3,#8	LIB	?INVBARRE	JUMP	LOOP$BLOCY$:	NOT.B	(A6)+OSEBLY	SUB.W	D3,#F0	LIB	?INVBARRE	TEST.B	(A6)+OSEBLX	JUMP,BC LOOP$	CLR.B	(A6)+OSEBLX	LOAD.B	D3,#7	LIB	?INVBARRE	JUMP	LOOP$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	CALL	DETPOIGNEES	; D0 <-- poigne o est la souris	JUMP,NE BIP$	PUSH.W	D0	LOAD.W	D0,#-1	CALL	INVPOIGNEES	; efface les 4 poignes	POP.W	D0	CALL	INVPOIGNEES	; redessine juste la bonne poigne	LOAD.L	D2,(A6)+OSEPHG	TEST.L	D0:#BPOIHG	JUMP',BS MOVE$	LOAD.L	D2,(A6)+OSEPHD	TEST.L	D0:#BPOIHD	JUMP',BS MOVE$	LOAD.L	D2,(A6)+OSEPBG	TEST.L	D0:#BPOIBG	JUMP',BS MOVE$	LOAD.L	D2,(A6)+OSEPBD;	TEST.L	D0:#BPOIBD;	JUMP',BS MOVE$MOVE$:	CALL	SCMO	CALL	WAITMOVE	; attend dplacement souris ...	JUMP,NE DEFORME$	; fin du dplacement => DEFORME$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE MOVE$	LOAD.W	D3,(A6)+OGMLPX	SR.W	D3,#1	ADD.W	D4,D3	SWAP.W	D4	LOAD.W	D3,(A6)+OGMLPY	SR.W	D3,#1	ADD.W	D4,D3	SWAP.W	D4	PUSH.W	(A6)+OGMDIX	PUSH.W	(A6)+OGMDIY	PUSH.W	(A6)+OMALMX	PUSH.W	(A6)+OMALMY	INC.W	(A6)+OGMDIX	INC.W	(A6)+OGMDIY	INC.W	(A6)+OMALMX	INC.W	(A6)+OMALMY	CALL	DETGPOINT	; D3 <-- position du point	POP.W	(A6)+OMALMY	POP.W	(A6)+OMALMX	POP.W	(A6)+OGMDIY	POP.W	(A6)+OGMDIX;;?	JUMP,NE MOVE$	TEST.B	(A6)+OSEBLX	JUMP',F MOVEX$	SWAP.W	D2	SWAP.W	D3	LOAD.W	D3,D2		; D3 <-- bloque le dplacement en Y	SWAP.W	D3	SWAP.W	D2MOVEX$:	TEST.B	(A6)+OSEBLY	JUMP',F MOVEY$	LOAD.W	D3,D2		; D4 <-- bloque le dplacement en XMOVEY$:	PUSH.L	(A6)+OSEPHG	PUSH.L	(A6)+OSEPHD	PUSH.L	(A6)+OSEPBG	PUSH.L	(A6)+OSEPBD	CALL	OPERPOIGNEE	; modifie rectangle	CALL	INVSELECT	; dessine la slection	JUMP,NE OUT$	CALL	INVPOIGNEES	; dessine la poigne	PUSH.L	(A6)+OSEPHG	PUSH.L	(A6)+OSEPHD	PUSH.L	(A6)+OSEPBG	PUSH.L	(A6)+OSEPBD	LOAD.L	(A6)+OSEPHG,(SP)+4*7	LOAD.L	(A6)+OSEPHD,(SP)+4*6	LOAD.L	(A6)+OSEPBG,(SP)+4*5	LOAD.L	(A6)+OSEPBD,(SP)+4*4	CALL	INVPOIGNEES	; efface la poigne	CALL	INVSELECT	; efface la slection	POP.L	(A6)+OSEPBD	POP.L	(A6)+OSEPBG	POP.L	(A6)+OSEPHD	POP.L	(A6)+OSEPHG	ADD.L	SP,#4*4	CALL	DESINFDEF	; affiche qq informations	JUMP	MOVE$OUT$:	CALL	INVSELECT	POP.L	(A6)+OSEPBD	POP.L	(A6)+OSEPBG	POP.L	(A6)+OSEPHD	POP.L	(A6)+OSEPHG	JUMP	MOVE$DEFORME$:	CALL	WAITMOUSE	; met le sablier	CALL	INVPOIGNEES	; efface la dernire poigne	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	XFERALL		; matrice principale <-- matrice copie	CALL	EXDEFORME	; hop, dforme ...	CALL	INVSELECT	; efface la slection	CALL	DESGMATRIX	; dessine la grande matrice	CALL	DESPMATRIX	; dessine la petite matrice	.IF	EDGAR	CALL	SETREPERE	; dessine les repres	.ENDIF	CALL	INVSELECT	; redessine la slection	LOAD.W	D0,#-1	CALL	INVPOIGNEES	; redessine les 4 poignes	CALL	NORMMOUSE	; enlve le sablier	JUMP	LOOP$OK$:	CALL	INVPOIGNEES	; efface les poignes	CALL	INVSELECT	; efface la slection	LOAD.W	D4,#KEYICO+ICODEFORME	LOAD.L	D0,(A6)+OSEPHG	LOAD.L	D1,(A6)+OSEPHD	LOAD.L	D2,(A6)+OSEPBG	LOAD.L	D3,(A6)+OSEPBD	LOAD.L	D5,(A6)+OSEOHG	LOAD.L	D6,(A6)+OSEOBD	CALL	PUTPARAM	; macro <-- paramtres	JUMP'	EXIT$CANCEL$:	CALL	INVPOIGNEES	; efface les poignes	CALL	INVSELECT	; efface la slection	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	XFERALL	CALL	DESGMATRIX	; dessine la grande matrice	CALL	DESPMATRIX	; dessine la petite matriceEXIT$:	CALL	AFMENU	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; remet les 3 boutons de la souris	JUMP	LOOPMACRODEFORME:	CALL	COPYZALL	; fait une copie de la matrice	CALL	GETPARAM	; D0..D6 <-- paramtres	LOAD.L	(A6)+OSEPHG,D0	LOAD.L	(A6)+OSEPHD,D1	LOAD.L	(A6)+OSEPBG,D2	LOAD.L	(A6)+OSEPBD,D3	LOAD.L	(A6)+OSEOHG,D5	LOAD.L	(A6)+OSEOBD,D6	CALL	EXDEFORME	; hop, dforme ...	CALL	DESGMATRIX	; dessine la grande matrice	CALL	DESPMATRIX	; dessine la petite matrice	JUMP	LOOP;----------\\; EXDEFORME >;----------/; Dforme une zone rectangulaire.; in	-; out	-; mod	D7.WEXDEFORME:	PUSHM.L	D1..D5,A0,A3,A4	LOAD.L	D1,(A6)+OSEOHG	LOAD.L	D2,(A6)+OSEOBD	CALL	D1D2SCALEN	; D1/D2 <-- agrandi si "tout"	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- position source	LOAD.L	D4,D1		; D4 <-- position destination	LOAD.L	D5,D2		; D5 <-- dimensions	DEC.W	D5	SWAP.W	D5	DEC.W	D5	SWAP.W	D5	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	XFERZONE	; efface dans matrice principale !	LOAD.L	A0,#(A6)+OSTRETCH	CLR.W	(A0)+OSTRTYP	CLR.W	(A0)+OSTROP	LOAD.L	(A0)+OSTRSPT,(A6)+OPMAM	LOAD.L	(A0)+OSTRSDX,(A6)+OMANBB	LOAD.L	(A0)+OSTRS0,(A6)+OSEOHG	LOAD.L	(A0)+OSTRS2,(A6)+OSEOBD	LOAD.L	(A0)+OSTRDPT,(A6)+OPMAT	LOAD.L	(A0)+OSTRDDX,(A6)+OMANBB	LOAD.L	(A0)+OSTRD0,(A6)+OSEPHG	LOAD.L	(A0)+OSTRD1,(A6)+OSEPHD	LOAD.L	(A0)+OSTRD2,(A6)+OSEPBD	LOAD.L	(A0)+OSTRD3,(A6)+OSEPBG	ST_	RECT		; ... et vive Francis !	POPM.L	D1..D5,A0,A3,A4	RETMACRONEGATIF:	CALL	COPYALL		; fait une copie de la matrice	CALL	GETPARAM	; D0..D6 <-- paramtres	JUMP'	OPERNEGATIFZONENEGATIF:	CALL	COPYALL		; fait une copie de la matrice	CALL	INVENTOURE	; efface l'ancien tour	CALL	POSDIM		; D1 <-- pos et D2 <-- dimOPERNEGATIF:	CALL	D1D2SCALEN	; D1/D2 <-- agrandi si "tout"	LOAD.L	A4,(A6)+OPMAM	COMP.B	(A6)+OSELECT,#ICOFILET	JUMP',EQ 10$	CALL	SETALL		; rempli la matrice-masque de un10$:	LOAD.L	A3,A4		; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- (y;x) source	LOAD.L	D4,D1		; D4 <-- (y;x) destination	LOAD.L	D5,D2		; D5 <-- (dy;dx)	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	XFERZONE	; inverse zone dans matrice principale	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	LOAD.L	D2,D5		; D2 <-- dimensions	LOAD.W	D4,#KEYICO+ICONEGATIF	CALL	PUTPARAM	; macro <-- paramtres	JUMP,NE ERROR	JUMP	LOOPMACRORELIEF:	CALL	GETPARAM	; D0..D6 <-- paramtres	JUMP'	OPERRELIEFZONERELIEF:	LOAD.L	A3,#R16"TMENURELIEF	CLR.W	D3	LOAD.L	A4,#(A6)+OMDCRF	; A4 <-- ^dernire case	CALL	MMENU		; action selon mmenu ...	CALL	INVENTOURE	; efface l'ancien tour	TEST.W	D3	JUMP,EQ LOOPOPERRELIEF:	CALL	D1D2SCALEN	; D1/D2 <-- agrandi si "tout"	CALL	COPYZALL	; fait une copie de la matrice	CALL	RELIEFMATRIX	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice	LOAD.W	D4,#KEYICO+ICORELIEF	CALL	PUTPARAM	; macro <-- paramtres	JUMP,NE ERROR	JUMP	LOOP	.IF	DESSINZONELOUPE:	CALL	INVENTOURE	; efface l'ancien tour	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	CALL	D1D2SCALEN	; D1/D2 <-- agrandi si "tout"	CLR.L	D3	LOAD.W	D3,(A6)+OGRDIX	DIV.WU	D3,D2	SWAP.W	D2	CLR.L	D4	LOAD.W	D4,(A6)+OGRDIY	DIV.WU	D4,D2	SWAP.W	D2	COMP.W	D4,D3	JUMP',LS 30$	LOAD.W	D4,D330$:	COMP.W	D4,#SCALE11	JUMP',GE 40$	LOAD.W	D4,#SCALE1140$:	LOAD.L	(A6)+OPMOVY,D1	LOAD.L	(A6)+OPMDIY,D2	CALL	CALSCALE	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	JUMP	LOOPZONESAUVE:	CALL	INVENTOURE	; efface l'ancien tour	CALL	D1D2SCALEN	; D1/D2 <-- agrandi si "tout"	PUSH.B	(A6)+OMAJ	CALL	COPYZALL	; fait une copie de la matrice	POP.B	(A6)+OMAJ	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	JUMP	SAUVERECT	; disque <-- contenu de la zone	.ENDIF;-----------\\; D1D2SCALEN >;===========/; Tient compte de la fonction tout pour dlimiter une modification.; in	D1.L	(y;x);	D2.L	(y;x); out	D1.L	(y;x) plus grand;	D2.L	(y;x) plus grand; mod	D1.L, D2.LD1D2SCALEN:	EX.L	D1,D2	CALL	D1SCALEN	; D2 <-- agrandi si "tout"	EX.L	D2,D1;	CALL	D1SCALEN	; D1 <-- agrandi si "tout";	RET;---------\\; D1SCALEN >;---------/; Tient compte de la fonction tout pour dlimiter une modification.; in	D1.L	(y;x); out	D1.L	(y;x) plus grand; mod	D1.LD1SCALEN:	PUSHM.L	D2,D3	LOAD.W	D2,(A6)+OSCALE	; chelle ngative (tout) ?	JUMP',NC 90$		; non => 90$				; oui =>	NEG.W	D2		; D2 <-- |chelle|	LOAD.W	D3,D1	MUL.WU	D3,D2	LOAD.W	D1,D3		; D1 <-- x	SWAP.W	D1	LOAD.W	D3,D1	MUL.WU	D3,D2	LOAD.W	D1,D3		; D1 <-- y	SWAP.W	D190$:	POPM.L	D2,D3	RET;-----------\\; D1D2SCALEP >;===========/; Tient compte de la fonction tout pour dlimiter une modification.; in	D1.L	(y;x);	D2.L	(y;x); out	D1.L	(y;x) plus petit;	D2.L	(y;x) plus petit; mod	D1.L, D2.LD1D2SCALEP:	EX.L	D1,D2	CALL	D1SCALEP	; D2 <-- agrandi si "tout"	EX.L	D2,D1;	CALL	D1SCALEP	; D1 <-- agrandi si "tout";	RET;---------\\; D1SCALEP >;---------/; Tient compte de la fonction tout pour dlimiter une modification.; in	D1.L	(y;x); out	D1.L	(y;x) plus petit; mod	D1.LD1SCALEP:	PUSHM.L	D2,D3	LOAD.W	D2,(A6)+OSCALE	; chelle ngative (tout) ?	JUMP',NC 90$		; non => 90$				; oui =>	NEG.W	D2		; D2 <-- |chelle|	CLR.L	D3	LOAD.W	D3,D1	DIV.WU	D3,D2	LOAD.W	D1,D3		; D1 <-- x	SWAP.W	D1	CLR.L	D3	LOAD.W	D3,D1	DIV.WU	D3,D2	LOAD.W	D1,D3		; D1 <-- y	SWAP.W	D190$:	POPM.L	D2,D3	RET;---------\\; WAITMOVE >;---------/; Attend un dplacement de la souris.; in	-; out	D3.L	touche presse;	D7.W	EQ si souris dplace; mod	D3.L, D7.WWAITMOVE:10$:	LIB	?GETKEY		; attend souris ...	JUMP',NE 20$		; si timeout => 20$	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP',BC 30$		; oui => 30$	JUMP	10$20$:	LOAD.W	D3,#KEYMPO	; D3 <-- dplacement	CLR.W	D7		; D7 <-- souris bouge	JUMP	90$30$:	LOAD.W	D7,#1		; D7 <-- fin du dplacement	COMP.W	D3,#KEYMGP	JUMP',EQ 90$	COMP.W	D3,#KEYMMP	JUMP',EQ 90$	COMP.W	D3,#KEYMDP	JUMP',EQ 90$	COMP.W	D3,#KEYMGR	JUMP',EQ 90$	COMP.W	D3,#KEYMMR	JUMP',EQ 90$	COMP.W	D3,#KEYMDR	JUMP',EQ 90$	CLR.W	D7		; D7 <-- souris bouge90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; FIXPAS  >;--------/; Fixe la position pour RNDPAS.; in	D3.L	position (y;x); out	-; mod	D7.WFIXPAS:	PUSHM.L	D3,D4	LOAD.L	D4,D3	CALL	PASGPOINT	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3;	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+ORNDPA,D4	POPM.L	D3,D4	RET;--------\\; RNDPAS  >;--------/; Arrondi la position selon FIXPAS.; in	D3.L	position (y;x); out	D3.L	position (y;x); mod	D3.LRNDPAS:	SUB.W	D3,(A6)+ORNDPA+2	SWAP.W	D3	SUB.W	D3,(A6)+ORNDPA+0	SWAP.W	D3	CALL	PASGPOINT	ADD.W	D3,(A6)+ORNDPA+2	SWAP.W	D3	ADD.W	D3,(A6)+ORNDPA+0	SWAP.W	D3	RET	.END