	.SBTTL	DESOPER;-----------\\; ZOOMMATRIX >;===========/; Zoom une zone rectangulaire d'aprs la matrice copie dans; la matrice principale.; in	D1/D2.L	emplacement  zoomer;	D3.W	zoom (1..6); out	D7.W	erreur; mod	D7.WZOOMMATRIX:	PUSHM.L	D0..D5,A3,A4	CALL	COPYZALL	; fait une copie de la matrice	LOAD.W	D0,D3		; D0 <-- genre du zoom	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	CALL	IFZZZ		; met le sablier si zone grande	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- position source	LOAD.L	D4,D1		; D4 <-- position destination	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	XFERZONE	; efface dans matrice principale !	LOAD.L	D2,D5	CALL	ISSTRETCH	; init source stretch	COMP.W	D0,#1	JUMP',EQ 20$	COMP.W	D0,#2	JUMP',NE 22$20$:				; *2 en X =>	LOAD.W	D3,D2	SR.W	D3,#1	SUB.W	D1,D3	SL.W	D2,#122$:	COMP.W	D0,#4	JUMP',EQ 24$	COMP.W	D0,#5	JUMP',NE 26$24$:				; */ en X =>	LOAD.W	D3,D2	SR.W	D3,#2	ADD.W	D1,D3	SR.W	D2,#126$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D0,#1	JUMP',EQ 30$	COMP.W	D0,#3	JUMP',NE 32$30$:				; *2 en Y =>	LOAD.W	D3,D2	SR.W	D3,#1	SUB.W	D1,D3	SL.W	D2,#132$:	COMP.W	D0,#4	JUMP',EQ 34$	COMP.W	D0,#6	JUMP',NE 36$34$:				; */ en Y =>	LOAD.W	D3,D2	SR.W	D3,#2	ADD.W	D1,D3	SR.W	D2,#136$:	SWAP.W	D1	SWAP.W	D2	CALL	IDSTRETCH	; init destination stretch	CALL	GOSTRETCH	; moteur ...	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; TOURNEMATRIX >;=============/; Tourne une zone rectangulaire d'aprs la matrice copie dans; la matrice principale.; in	D1/D2.L	emplacement  tourner;	D3.W	rotation (1..3); out	D7.W	erreur; mod	D7.WTOURNEMATRIX:	PUSHM.L	D0..D5,A3,A4	CALL	COPYZALL	; fait une copie de la matrice	LOAD.W	D0,D3		; D0 <-- genre de rotation	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	CALL	IFZZZ		; met le sablier si zone grande	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- position source	LOAD.L	D4,D1		; D4 <-- position destination	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	XFERZONE	; efface dans matrice principale !	LOAD.L	D2,D5	CALL	ISSTRETCH	; init source stretch	CALL	IDSTRETCH	; init destination stretch	LOAD.L	D3,(A6)+OSTRETCH+OSTRD0	CALL	TOURNEONEDOT	LOAD.L	(A6)+OSTRETCH+OSTRD0,D3	LOAD.L	D3,(A6)+OSTRETCH+OSTRD1	CALL	TOURNEONEDOT	LOAD.L	(A6)+OSTRETCH+OSTRD1,D3	LOAD.L	D3,(A6)+OSTRETCH+OSTRD2	CALL	TOURNEONEDOT	LOAD.L	(A6)+OSTRETCH+OSTRD2,D3	LOAD.L	D3,(A6)+OSTRETCH+OSTRD3	CALL	TOURNEONEDOT	LOAD.L	(A6)+OSTRETCH+OSTRD3,D3	CALL	GOSTRETCH	; moteur ...	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; TOURNEONEDOT >;-------------/; Tourne juste un point.; in	D0.W	rotation (1..3);	D1.L	position (y;x);	D2.L	dimensions (dy;dx);	D3.L	point  tourner (y;x); out	D3.L	point tourn (y;x); mod	D3.L, D7.WTOURNEONEDOT:	PUSHM.L	D0..D2	LOAD.W	D4,D2	SR.W	D4,#1	ADD.W	D4,D1		; D4 <-- centre de rotation X	SWAP.W	D1	SWAP.W	D2	LOAD.W	D5,D2	SR.W	D5,#1	ADD.W	D5,D1		; D5 <-- centre de rotation Y	SWAP.W	D1	SWAP.W	D220$:	LOAD.W	D2,D4	ADD.W	D2,D5	SUB.W	D2,D3		; D2 <-- origine en Y	SWAP.W	D2	LOAD.W	D2,D4	SUB.W	D2,D5	SWAP.W	D3	ADD.W	D2,D3		; D2 <-- origine en X	LOAD.L	D3,D2	DEC.W	D0		; encore un quart de tour ?	JUMP,NE 20$		; oui => 20$	POPM.L	D0..D2	RET;-------------\\; MIROIRMATRIX >;=============/; Symtrise une zone rectangulaire d'aprs la matrice copie dans; la matrice principale.; in	D1/D2.L	emplacement  mirer;	D3.W	miroir (1..4); out	D7.W	erreur; mod	D7.WMIROIRMATRIX:	PUSHM.L	D0..D5,A3,A4	CALL	COPYZALL	; fait une copie de la matrice	LOAD.W	D0,D3		; D0 <-- genre du miroir	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	CALL	IFZZZ		; met le sablier si zone grande	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- position source	LOAD.L	D4,D1		; D4 <-- position destination	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	XFERZONE	; efface dans matrice principale !	LOAD.L	D2,D5	CALL	ISSTRETCH	; init source stretch	CALL	IDSTRETCH	; init destination stretch	COMP.W	D0,#1	JUMP',NE 30$	LOAD.W	D3,(A6)+OSTRETCH+OSTRD0+0	LOAD.W	(A6)+OSTRETCH+OSTRD0+0,(A6)+OSTRETCH+OSTRD3+0	LOAD.W	(A6)+OSTRETCH+OSTRD3+0,D3	LOAD.W	D3,(A6)+OSTRETCH+OSTRD1+0	LOAD.W	(A6)+OSTRETCH+OSTRD1+0,(A6)+OSTRETCH+OSTRD2+0	LOAD.W	(A6)+OSTRETCH+OSTRD2+0,D330$:	COMP.W	D0,#2	JUMP',NE 35$	LOAD.W	D3,(A6)+OSTRETCH+OSTRD0+2	LOAD.W	(A6)+OSTRETCH+OSTRD0+2,(A6)+OSTRETCH+OSTRD1+2	LOAD.W	(A6)+OSTRETCH+OSTRD1+2,D3	LOAD.W	D3,(A6)+OSTRETCH+OSTRD2+2	LOAD.W	(A6)+OSTRETCH+OSTRD2+2,(A6)+OSTRETCH+OSTRD3+2	LOAD.W	(A6)+OSTRETCH+OSTRD3+2,D335$:	COMP.W	D0,#3	JUMP',NE 40$	LOAD.L	D3,(A6)+OSTRETCH+OSTRD1	LOAD.L	(A6)+OSTRETCH+OSTRD1,(A6)+OSTRETCH+OSTRD3	LOAD.L	(A6)+OSTRETCH+OSTRD3,D340$:	COMP.W	D0,#4	JUMP',NE 45$	LOAD.L	D3,(A6)+OSTRETCH+OSTRD0	LOAD.L	(A6)+OSTRETCH+OSTRD0,(A6)+OSTRETCH+OSTRD2	LOAD.L	(A6)+OSTRETCH+OSTRD2,D345$:	CALL	GOSTRETCH	; moteur ...	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; ISSTRETCH >;----------/; Initialise la source du module stretch.; in	D1.L	position (y;x);	D2.L	dimensions (dy;dx); out	-; mod	D7.WISSTRETCH:	PUSHM.L	D1,D2	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	CLR.W	(A6)+OSTRETCH+OSTRTYP	CLR.W	(A6)+OSTRETCH+OSTROP	LOAD.L	(A6)+OSTRETCH+OSTRSPT,(A6)+OPMAM	LOAD.W	(A6)+OSTRETCH+OSTRSDX,(A6)+OMANBB	LOAD.L	(A6)+OSTRETCH+OSTRS0,D1	LOAD.L	(A6)+OSTRETCH+OSTRS2,D2	POPM.L	D1,D2	RET;----------\\; IDSTRETCH >;----------/; Initialise la destination du module stretch.; in	D1.L	position (y;x);	D2.L	dimensions (dy;dx); out	-; mod	D7.WIDSTRETCH:	PUSHM.L	D1..D3	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	LOAD.L	(A6)+OSTRETCH+OSTRDPT,(A6)+OPMAT	LOAD.W	(A6)+OSTRETCH+OSTRDDX,(A6)+OMANBB	LOAD.L	(A6)+OSTRETCH+OSTRD0,D1	LOAD.L	(A6)+OSTRETCH+OSTRD2,D2	LOAD.W	D3,D1	LOAD.W	D1,D2	LOAD.W	D2,D3	LOAD.L	(A6)+OSTRETCH+OSTRD1,D1	LOAD.L	(A6)+OSTRETCH+OSTRD3,D2	POPM.L	D1..D3	RET;----------\\; GOSTRETCH >;----------/; Lance le "stretcheur" miracle ...; in	-; out	D7.W	erreur; mod	D7.WGOSTRETCH:	PUSHM.L	D3,A3,A4	LOAD.L	D3,(A6)+OSTRETCH+OSTRD0	CALL	IFSTRETCH	; point dpasse ?	JUMP,NE 50$	LOAD.L	D3,(A6)+OSTRETCH+OSTRD1	CALL	IFSTRETCH	; point dpasse ?	JUMP,NE 50$	LOAD.L	D3,(A6)+OSTRETCH+OSTRD2	CALL	IFSTRETCH	; point dpasse ?	JUMP,NE 50$	LOAD.L	D3,(A6)+OSTRETCH+OSTRD3	CALL	IFSTRETCH	; point dpasse ?	JUMP,NE 50$	PUSH.L	A0	LOAD.L	A0,#(A6)+OSTRETCH	ST_	RECT		; ... et vive Francis !	POP.L	A0	CLR.W	D7		; D7 <-- a baigne	JUMP'	90$50$:	LOAD.L	A3,(A6)+OPMAC	LOAD.L	A4,(A6)+OPMAT	CALL	XFERALL		; matrice principale <-- matrice copie	LOAD.W	D7,#1		; D7 <-- pas possible90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IFSTRETCH >;----------/; Regarde si un point dborde.; in	D3.L	point (y;x); out	D7.W	erreur; mod	D7.WIFSTRETCH:	PUSH.L	D3	LOAD.W	D7,#1		; D7 <-- a dborde	TEST.W	D3		; dborde  gauche ?	JUMP',NS 90$	COMP.W	D3,(A6)+OMALMX	; dborde  droite ?	JUMP',HS 90$	SWAP.W	D3	TEST.W	D3		; dborde en haut ?	JUMP',NS 90$	COMP.W	D3,(A6)+OMALMY	; dborde en bas ?	JUMP',HS 90$	CLR.W	D7		; D7 <-- ok90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;-------------\\; RELIEFMATRIX >;=============/; Extrait le contour d'une zone rectangulaire d'aprs la matrice copie; dans la matrice principale.; in	D1/D2.L	emplacement  extraire le contour;	D3.W	opration (1..n); out	-; mod	D7.WRELIEFMATRIX:	PUSHM.L	D1..D6,A2..A4	LOAD.L	A2,#R16"TOPRELIEF10$:	DEC.W	D3	JUMP',EQ 20$12$:	COMP.W	(A2+),#222	; A2 <-- ^opration suivante	JUMP,NE 12$	JUMP	10$20$:	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	CALL	IFZZZ		; met le sablier si zone grande	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D3,D1		; D3 <-- position source	LOAD.L	D4,D1		; D4 <-- position destination	LOAD.L	D5,D2		; D5 <-- dimensions	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	XFERZONE	; efface dans matrice principale !	LOAD.L	A3,(A6)+OPMAM	; A3 <-- ^matrice source	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	LOAD.L	D1,D450$:	LOAD.L	D4,D1	SWAP.W	D4	ADD.W	D4,(A2+)	; D4 <-- position en Y	SWAP.W	D4	ADD.W	D4,(A2+)	; D4 <-- position en X	LOAD.W	D2,(A2+)	; D2 <-- mode	CALL	CLIPXFERZONE	; matrice principale <-- matrice copie	COMP.W	(A2),#222	; fin des oprations ?	JUMP,NE 50$		; non => 50$	POPM.L	D1..D6,A2..A4	RET;		 y,x	modeTOPRELIEF:			; contour :	.W	-1,-1	SETDOT	.W	-1, 0	SETDOT	.W	-1,+1	SETDOT	.W	 0,-1	SETDOT	.W	 0, 0	SETDOT	.W	 0,+1	SETDOT	.W	+1,-1	SETDOT	.W	+1, 0	SETDOT	.W	+1,+1	SETDOT	.W	 0, 0	CLRDOT	.W	222				; ombr :	.W	-1,-1	SETDOT	.W	-1, 0	SETDOT	.W	-1,+1	SETDOT	.W	 0,-1	SETDOT	.W	 0, 0	SETDOT	.W	 0,+1	SETDOT	.W	+1,-1	SETDOT	.W	+1, 0	SETDOT	.W	+1,+1	SETDOT	.W	+2,+0	SETDOT	.W	+2,+1	SETDOT	.W	+2,+2	SETDOT	.W	+1,+2	SETDOT	.W	+0,+2	SETDOT	.W	+3,+1	SETDOT	.W	+3,+2	SETDOT	.W	+3,+3	SETDOT	.W	+2,+3	SETDOT	.W	+1,+3	SETDOT	.W	 0, 0	CLRDOT	.W	222				; perspective :	.W	 0, 0	SETDOT	.W	 1, 1	CLRDOT	.W	222				; gras :	.W	 0, 0	SETDOT	.W	 0,+1	SETDOT	.W	+1, 0	SETDOT	.W	+1,+1	SETDOT	.W	222;-------------\\; CLIPXFERZONE >;-------------/; Transfert une zone rectangulaire, avec clipping si la; destination dborde dans les quatre directions.; in	A3.L	^matrice source;	D3.L	(y;x) source;	A4.L	^matrice destination;	D4.L	(y;x) destination;	D5.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WCLIPXFERZONE:	PUSHM.L	D1,D3..D5	TEST.W	D4		; dborde  gauche ?	JUMP',NC 10$	SUB.W	D3,D4	ADD.W	D5,D4	CLR.W	D410$:	LOAD.W	D1,(A6)+OMALMX	SUB.W	D1,D4	COMP.W	D5,D1		; dpasse  droite ?	JUMP',LS 15$	LOAD.W	D5,D115$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	TEST.W	D4		; dborde en haut ?	JUMP',NC 20$	SUB.W	D3,D4	ADD.W	D5,D4	CLR.W	D420$:	LOAD.W	D1,(A6)+OMALMY	SUB.W	D1,D4	COMP.W	D5,D1		; dpasse en bas ?	JUMP',LS 25$	LOAD.W	D5,D125$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	CALL	XFERZONE	; moteur !	POPM.L	D1,D3..D5	RET;--------\\; IFZZZ   >;--------/; Met le sablier si la zone  "oprer" est grande.; in	D2.L	dimensions (dy;dx); out	-; mod	D7.WIFZZZ:	PUSHM.L	D2,D3	LOAD.W	D3,D2		; D3 <-- largeur zone	SWAP.W	D2		; D2 <-- hauteur zone	MUL.WU	D2,D3	COMP.L	D2,#20000	; D2 <-- trs empirique !	JUMP',LO 90$	CALL	WAITMOUSE	; met le sablier90$:	POPM.L	D2,D3	RET	.IF	EDGAR;------------\\; SHIFTMATRIX >;============/; Dcale toute la matrice dans l'une des quatre directions.; in	D3.B	opration (ICOSH..);	D4.W	quantit (1..n); out	-; mod	D7.WSHIFTMATRIX:	PUSHM.L	D1..D5,A3,A4	LOAD.W	D1,D4		; D1 <-- quantit	LOAD.B	D2,D3		; D2 <-- opration	LOAD.L	A3,(A6)+OPMAC	; A3 <-- ^matrice source	CLR.L	D3	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination	CLR.L	D4	LOAD.L	D5,(A6)+OMALMY	COMP.B	D2,#ICOSHLEFT	JUMP',EQ 20$	COMP.B	D2,#ICOSHRIGHT	JUMP',EQ 30$	COMP.B	D2,#ICOSHUP	JUMP',EQ 40$	COMP.B	D2,#ICOSHDOWN	JUMP',EQ 50$	JUMP	90$20$:				;  gauche =>	ADD.W	D3,D1	SUB.W	D5,D1	JUMP',LE 90$	JUMP'	80$30$:				;  droite =>	ADD.W	D4,D1	SUB.W	D5,D1	JUMP',LE 90$	JUMP'	80$40$:				; en haut =>	SWAP.W	D3	SWAP.W	D5	ADD.W	D3,D1	SUB.W	D5,D1	JUMP',LE 90$	SWAP.W	D3	SWAP.W	D5	JUMP'	80$50$:				; en bas =>	SWAP.W	D4	SWAP.W	D5	ADD.W	D4,D1	SUB.W	D5,D1	JUMP',LE 90$	SWAP.W	D4	SWAP.W	D5;	JUMP'	80$80$:	CALL	CLEARALL	LOAD.W	D2,#SETDOT	CALL	XFERZONE	; matrice principale <-- matrice copie	CALL	MAJGMATRIX	; met  jour la grande matrice	CALL	DESPMATRIX	; dessine aussi la petite matrice90$:	POPM.L	D1..D5,A3,A4	RET	.ENDIF	.IF	DESSIN;--------\\; REDUIT  >;========/; Rduit toute une matrice d'un facteur constant 2, 4 ou 8.; Super-rapide dans tous les cas, si si !; in	A3.L	^matrice source;	A4.L	^matrice destination (A4=A3 possible !); out	-; mod	D7.WREDUIT:	COMP.W	(A6)+OSCALE,#-2	JUMP,EQ REDUIT2	COMP.W	(A6)+OSCALE,#-4	JUMP,EQ REDUIT4	COMP.W	(A6)+OSCALE,#-8	JUMP,EQ REDUIT8	RETREDUIT2:	PUSHM.L	D0..D6,A1..A5	LOAD.L	A5,A4		; A5 <-- ^destination	LOAD.L	A1,#R16"TABLE$	; A1 <-- ^table	LOAD.W	D6,(A6)+ODARK	; D6 <-- seuil fonc	LOAD.W	D5,(A6)+OMALMY	; D5 <-- hauteur en bytes	SR.W	D5,#1		; D5 <-- hauteur /2	LOAD.W	D2,(A6)+OMANBB	; D2 <-- largeur en bytes10$:	LOAD.L	A4,A5		; A4 <-- ^destination	LOAD.W	D3,D2		; D3 <-- largeur en bytes	DEC.W	D3		; D3 <-- -1  cause NMO20$:	CLR.B	D4	LOAD.B	D0,(A3)+(D2.W)	LOAD.B	D1,(A3)	SR.B	D0,#6	SR.B	D1,#4	AND.W	D0,#B'0011	AND.W	D1,#B'1100	OR.W	D0,D1	COMP.B	D6,(A1)+(D0.W)	JUMP',HS 30$	TSET.L	D4:#730$:	LOAD.B	D0,(A3)+(D2.W)	LOAD.B	D1,(A3)	SR.B	D0,#4	SR.B	D1,#2	AND.W	D0,#B'0011	AND.W	D1,#B'1100	OR.W	D0,D1	COMP.B	D6,(A1)+(D0.W)	JUMP',HS 31$	TSET.L	D4:#631$:	LOAD.B	D0,(A3)+(D2.W)	LOAD.B	D1,(A3)	SR.B	D0,#2;	SR.B	D1,#0	AND.W	D0,#B'0011	AND.W	D1,#B'1100	OR.W	D0,D1	COMP.B	D6,(A1)+(D0.W)	JUMP',HS 32$	TSET.L	D4:#532$:	LOAD.B	D0,(A3)+(D2.W)	LOAD.B	D1,(A3);	SR.B	D0,#0	SL.B	D1,#2	AND.W	D0,#B'0011	AND.W	D1,#B'1100	OR.W	D0,D1	COMP.B	D6,(A1)+(D0.W)	JUMP',HS 33$	TSET.L	D4:#433$:	INC.L	A3	DEC.W	D3	JUMP,NS 50$	LOAD.B	D0,(A3)+(D2.W)	LOAD.B	D1,(A3)	SR.B	D0,#6	SR.B	D1,#4	AND.W	D0,#B'0011	AND.W	D1,#B'1100	OR.W	D0,D1	COMP.B	D6,(A1)+(D0.W)	JUMP',HS 40$	TSET.L	D4:#340$:	LOAD.B	D0,(A3)+(D2.W)	LOAD.B	D1,(A3)	SR.B	D0,#4	SR.B	D1,#2	AND.W	D0,#B'0011	AND.W	D1,#B'1100	OR.W	D0,D1	COMP.B	D6,(A1)+(D0.W)	JUMP',HS 41$	TSET.L	D4:#241$:	LOAD.B	D0,(A3)+(D2.W)	LOAD.B	D1,(A3)	SR.B	D0,#2;	SR.B	D1,#0	AND.W	D0,#B'0011	AND.W	D1,#B'1100	OR.W	D0,D1	COMP.B	D6,(A1)+(D0.W)	JUMP',HS 42$	TSET.L	D4:#142$:	LOAD.B	D0,(A3)+(D2.W)	LOAD.B	D1,(A3);	SR.B	D0,#0	SL.B	D1,#2	AND.W	D0,#B'0011	AND.W	D1,#B'1100	OR.W	D0,D1	COMP.B	D6,(A1)+(D0.W)	JUMP',HS 43$	TSET.L	D4:#043$:	INC.L	A3	LOAD.B	(A4+),D4	; destination <-- 8 points	DECJ.W,NMO D3,20$	JUMP'	60$50$:	LOAD.B	(A4+),D4	; destination <-- 4 points effectifs60$:	ADD.W	A3,D2		; A3 <-- y=y+2 source	ADD.W	A5,D2		; A5 <-- y=y+1 destination	DEC.W	D5	JUMP,NE 10$	POPM.L	D0..D6,A1..A5	RETTABLE$:	.B	0		; 0000 = 0	.B	1		; 0001 = 1	.B	1		; 0010 = 1	.B	2		; 0011 = 2	.B	1		; 0100 = 1	.B	2		; 0101 = 2	.B	2		; 0110 = 2	.B	3		; 0111 = 3	.B	1		; 1000 = 1	.B	2		; 1001 = 2	.B	2		; 1010 = 2	.B	3		; 1011 = 3	.B	2		; 1100 = 2	.B	3		; 1101 = 3	.B	3		; 1110 = 3	.B	4		; 1111 = 4.IF 0REDUIT2:	PUSHM.L	D0..D4,A2..A5	LOAD.L	A5,A4		; A5 <-- ^destination	LOAD.W	D1,(A6)+OMALMY	; D1 <-- hauteur en bytes	SR.W	D1,#1		; D1 <-- hauteur /2	LOAD.W	D2,(A6)+OMANBB	; D2 <-- largeur en bytes10$:	LOAD.L	A4,A5		; A4 <-- ^destination	LOAD.W	D3,D2		; D3 <-- largeur en bytes	DEC.W	D3		; D3 <-- -1  cause NMO20$:	LOAD.B	D0,(A3)+(D2.W)	OR.B	D0,(A3+)	JUMP',NE 30$	SL.B	D4,#4		; D4 <-- 4 points blancs	JUMP'	34$30$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 31$	TSET.L	D4:#031$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 32$	TSET.L	D4:#032$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 33$	TSET.L	D4:#033$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 34$	TSET.L	D4:#034$:	DEC.W	D3	JUMP',NS 50$	LOAD.B	D0,(A3)+(D2.W)	OR.B	D0,(A3+)	JUMP',NE 40$	SL.B	D4,#4		; D4 <-- 4 points blancs	JUMP'	44$40$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 41$	TSET.L	D4:#041$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 42$	TSET.L	D4:#042$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 43$	TSET.L	D4:#043$:	RLX.B	D0,#1	RLX.B	D4,#1	RL.B	D0,#1	JUMP',CC 44$	TSET.L	D4:#044$:	LOAD.B	(A4+),D4	; destination <-- 8 points	DECJ.W,NMO D3,20$	JUMP'	60$50$:	SL.B	D4,#4		; D4 <-- 4 points blancs	LOAD.B	(A4+),D4	; destination <-- 4 points effectifs60$:	ADD.W	A3,D2		; A3 <-- y=y+2 source	ADD.W	A5,D2		; A5 <-- y=y+1 destination	DEC.W	D1	JUMP,NE 10$	POPM.L	D0..D4,A2..A5	RET.ENDIFREDUIT4:	PUSHM.L	D0..D5,A2..A5	LOAD.L	A5,A4		; A5 <-- ^destination	LOAD.W	D1,(A6)+OMALMY	; D1 <-- hauteur en bytes	SR.W	D1,#2		; D1 <-- hauteur /4	LOAD.W	D2,(A6)+OMANBB	; D2 <-- largeur en bytes10$:	LOAD.L	A4,A5		; A4 <-- ^destination	LOAD.B	D4,#7		; D4 <-- destination tout  gauche	LOAD.W	D3,D2		; D3 <-- largeur en bytes	DEC.W	D3		; D3 <-- -1  cause NMO20$:	LOAD.L	A2,A3	LOAD.B	D0,(A2)	ADD.W	A2,D2	OR.B	D0,(A2)	ADD.W	A2,D2	OR.B	D0,(A2)	ADD.W	A2,D2	OR.B	D0,(A2)	LOAD.B	D5,D0	AND.B	D5,#B'11110000	JUMP',NE 30$	TCLR.B	(A4):D4		; teint le point destination	JUMP'	32$30$:	TSET.B	(A4):D4		; allume le point destination32$:	DEC.B	D4		; D4 <-- x=x+1 destination	JUMP',NC 34$	LOAD.B	D4,#7	INC.L	A4		; A4 <-- x=x+8 destination34$:	AND.B	D0,#B'00001111	JUMP',NE 40$	TCLR.B	(A4):D4		; teint le point destination	JUMP'	42$40$:	TSET.B	(A4):D4		; allume le point destination42$:	DEC.B	D4		; D4 <-- x=x+1 destination	JUMP',NC 44$	LOAD.B	D4,#7	INC.L	A4		; A4 <-- x=x+8 destination44$:	INC.L	A3		; A3 <-- x=x+8 source	DECJ.W,NMO D3,20$	LOAD.W	D3,D2	MUL.WU	D3,#4-1	ADD.L	A3,D3		; A3 <-- y=y+4 source	ADD.W	A5,D2		; A5 <-- y=y+1 destination	DEC.W	D1	JUMP,NE 10$	POPM.L	D0..D5,A2..A5	RETREDUIT8:	PUSHM.L	D1..D4,A2..A5	LOAD.L	A5,A4		; A5 <-- ^destination	LOAD.W	D1,(A6)+OMALMY	; D1 <-- hauteur en bytes	SR.W	D1,#3		; D1 <-- hauteur /8	LOAD.W	D2,(A6)+OMANBB	; D2 <-- largeur en bytes10$:	LOAD.L	A4,A5		; A4 <-- ^destination	LOAD.B	D4,#7		; D4 <-- destination tout  gauche	LOAD.W	D3,D2		; D3 <-- largeur en bytes	DEC.W	D3		; D3 <-- -1  cause NMO20$:	LOAD.L	A2,A3	TEST.B	(A2)		; points (0,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (1,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (2,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (3,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (4,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (5,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (6,0..7) allums ?	JUMP',NE 30$	ADD.W	A2,D2	TEST.B	(A2)		; points (7,0..7) allums ?	JUMP',NE 30$	TCLR.B	(A4):D4		; teint le point destination	JUMP'	32$30$:	TSET.B	(A4):D4		; allume le point destination32$:	DEC.B	D4		; D4 <-- x=x+1 destination	JUMP',NC 34$	LOAD.B	D4,#7	INC.L	A4		; A4 <-- x=x+8 destination34$:	INC.L	A3		; A3 <-- x=x+8 source	DECJ.W,NMO D3,20$	LOAD.W	D3,D2	MUL.WU	D3,#8-1	ADD.L	A3,D3		; A3 <-- y=y+8 source	ADD.W	A5,D2		; A5 <-- y=y+1 destination	DEC.W	D1	JUMP,NE 10$	POPM.L	D1..D4,A2..A5	RET	.ENDIF	.END