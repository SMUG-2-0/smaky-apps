	.SBTTL	DESIMAGETAKEIMAGE:	CALL	CLRREPERE	; enlve les repres	CALL	TIOPEWDO	; ouvre la swdo	JUMP,NE ERROR	LOAD.L	A3,(A6)+OPGC	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.W	D4,#OGCWID-1HEAD$:	LOAD.B	(A4+),(A3+)	; OBUHEAD <-- header	DECJ.W,NMO D4,HEAD$	CLR.W	D2		; D2 <-- flags	CALL	TIAFFCAR	; affiche les soft-keys	LOAD.L	A3,#R16"TIMHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	CALL	CCMO		; enlve la souris	CLR.L	D0		; D0 <-- offset image	LOAD.L	D1,#-1		; D1 <-- dernire position sourisSHOW$:	CALL	TIINVCAR	; efface	CALL	TISHOWIMA	; affiche l'image	CALL	TIINVCAR	; redessineLOOP$:	CLR.W	D4	NTREL	?SETTIM	LIB	?GETKEY		; attend clavier/souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE MOVE$	TEST.L	D3:#BKPSEUDO	JUMP,BS LOOP$	COMP.W	D3,#KEYMGR	; bouton relch ?	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ MOVE$	COMP.W	D3,#KEYMGP	JUMP,EQ TAKE$	COMP.W	D3,#F0	JUMP,EQ EXIT$	COMP.W	D3,#F0+SHIFT	JUMP,EQ EXIT$	COMP.W	D3,#END	JUMP,EQ EXIT$	COMP.W	D3,#KEYMDP	JUMP,EQ EXIT$	COMP.W	D3,#F1	JUMP,EQ CARM$	COMP.W	D3,#F1+SHIFT	JUMP,EQ CARM$	COMP.W	D3,#F3	JUMP,EQ CARP$	COMP.W	D3,#F3+SHIFT	JUMP,EQ CARP$	COMP.W	D3,#F7	JUMP,EQ HOR$	COMP.W	D3,#F7+SHIFT	JUMP,EQ HOR$	COMP.W	D3,#F8	JUMP,EQ VERT$	COMP.W	D3,#F8+SHIFT	JUMP,EQ VERT$	COMP.W	D3,#128	JUMP,LO SELECT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$MOVE$:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	TEST.L	D2:#0	JUMP',BC MOVEH$	SWAP.W	D1	SWAP.W	D4	LOAD.W	D4,D1		; D4 <-- bloque horizontalement	SWAP.W	D4	SWAP.W	D1MOVEH$:	TEST.L	D2:#1	JUMP',BC MOVEV$	LOAD.W	D4,D1		; D4 <-- bloque verticalementMOVEV$:	COMP.L	D4,D1		; souris dplace ?	JUMP',EQ IFMOVE$	; non => IFMOVE$				; oui =>	CALL	TIINVCAR	; efface l'ancien	LOAD.L	D1,D4	CALL	TIINVCAR	; dessine le nouveauIFMOVE$:	LOAD.L	D4,D0	CALL	TIIFMOVE	; D0 <-- nouvel offset image	COMP.L	D4,D0		; offset image chang ?	JUMP,NE SHOW$		; oui => SHOW$	JUMP	LOOP$		; non => LOOP$CARP$:	LOAD.B	D3,(A6)+OCAR	COMP.B	D3,#127	JUMP,EQ BIP$	INC.B	D3	JUMP'	SELECT$CARM$:	LOAD.B	D3,(A6)+OCAR	JUMP,EQ BIP$	DEC.B	D3SELECT$:	CALL	TIINVCAR	; efface	CALL	TISELECT	; slectionne le nouveau caractre	CALL	TIINVCAR	; redessine	CALL	TIAFFCAR	; affiche les soft-keys	JUMP	LOOP$HOR$:	TNOT.L	D2:#0	TCLR.L	D2:#1	CALL	TIAFFCAR	; affiche les soft-keys	JUMP	LOOP$VERT$:	TNOT.L	D2:#1	TCLR.L	D2:#0	CALL	TIAFFCAR	; affiche les soft-keys	JUMP	LOOP$TAKE$:	CALL	TIXFER		; gencar <-- image	JUMP,NE BIP$	JUMP	CARP$EXIT$:	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	CALL	TICLOWDO	; ferme la swdo	TEST.L	(A6)+OPIM	JUMP',EQ EXIT2$	LOAD.L	A4,(A6)+OPIM	LOAD.L	A4,#(A4)-IMLBUF	; A4 <-- saute la rserve pour codage	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'image	CLR.L	(A6)+OPIMEXIT2$:	CALL	DESMATRIX	; dessine les deux matrices	CALL	DESCODE		; affiche "65: A" par exemple	JUMP	LOOP;---------\\; TISELECT >;---------/; Slectionne un caractre pour pouvoir l'diter.; in	D3.B	code du caractre (0..127); out	-; mod	D7.WTISELECT:	PUSHM.L	D3,D4,A4; Vrifie si le nouveau caractre est dans les limites.	LOAD.L	A4,(A6)+OPGC	; A4 <-- ^gencar	COMP.B	D3,(A4)+OGCFCA	JUMP',HS 40$	LOAD.B	D3,(A4)+OGCFCA40$:	COMP.B	D3,(A4)+OGCLCA	JUMP',LS 45$	LOAD.B	D3,(A4)+OGCLCA45$:	LOAD.B	(A6)+OCAR,D3; Initialise le pointeur OPMAT dans le gencar.	LOAD.L	A4,(A6)+OPGC	; A4 <-- ^gencar	AND.W	D3,#H'FF	MUL.WU	D3,(A4)+OGCMSB	ADD.L	D3,#OGCMAT	ADD.L	A4,D3	LOAD.L	(A6)+OPMAT,A4	POPM.L	D3,D4,A4	RET;--------\\; TIXFER  >;--------/; Transfert un bout d'image dans le gencar.; in	D1.L	position de la souris;	D0.L	offset image; out	D7.W	erreur; mod	D7.WTIXFER:	PUSHM.L	D3,D4,A3,A4	LOAD.W	D7,#1		; D7 <-- a dborde	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.L	D3,D1	ADD.W	D3,D0	SUB.W	D3,(A6)+OALPOX	SUB.W	D3,(A6)+OBUHEAD+OGCLMA	JUMP,NS 90$	LOAD.W	(A3)+1,D3	; source: <xx>	SWAP.W	D3	SWAP.W	D0	ADD.W	D3,D0	SWAP.W	D0	SUB.W	D3,(A6)+OALPOY	ADD.W	D3,(A6)+OBUHEAD+OGCBLI	SUB.W	D3,(A6)+OBUHEAD+OGCMHD	JUMP,NS 90$	LOAD.W	(A3)+3,D3	; source: <yy>	LOAD.L	(A3)+5,(A6)+OPIM ; source: <pppp>	LOAD.W	D3,(A6)+OBUHIMA+OIMDLX	ADD.W	D3,#8-1	SR.W	D3,#3	LOAD.W	(A3)+9,D3	; source: <ii>	CLR.L	(A3)+11		; destination: <xx> <yy>	LOAD.L	(A3)+15,(A6)+OPMAT ; destination: <pppp>	CLR.W	D3	LOAD.B	D3,(A6)+OBUHEAD+OGCMWB	LOAD.W	(A3)+19,D3	; destination: <ii>	SL.W	D3,#3	LOAD.W	(A3)+21,D3	; <dxx>	LOAD.W	(A3)+23,(A6)+OBUHEAD+OGCMHD ; <dyy>	LOAD.B	(A3)+25,#LOADDOT ; <mode>	LOAD.W	D3,(A3)+1	ADD.W	D3,(A3)+21	COMP.W	D3,(A6)+OBUHIMA+OIMDLX ; dpasse  droite ?	JUMP',HS 90$	LOAD.W	D3,(A3)+3	ADD.W	D3,(A3)+23	COMP.W	D3,(A6)+OBUHIMA+OIMDLY ; dpasse en bas ?	JUMP',HS 90$	LOAD.W	D3,#26	LIB	?STRING		; gencar <-- image	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice	CALL	SEARCHLGV	; D4 <-- largeur maximale	LOAD.L	A4,(A6)+OPGC	; A4 <-- ^gencar	LOAD.L	A3,#(A4)+OGCWID	; A3 <-- ^table des largeurs	CLR.W	D3	LOAD.B	D3,(A6)+OCAR	LOAD.B	(A3)+(D3.W),D4	SET.B	(A6)+OMAJ	; une mise  jour sera ncessaire	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TIIFMOVE >;---------/; Dplace v. l'offset de l'image, si la souris; dpasse le bord de la fentre.; in	D1.L	position de la souris;	D0.L	offset image; out	D0.L	offset image; mod	D0.L, D7.WTIIFMOVE:	PUSHM.L	D1..D3	SUB.W	D1,(A6)+OBUHEAD+OGCLMA	COMP.W	D1,(A6)+OALPOX	JUMP',GE 20$	LOAD.W	D3,(A6)+OALPOX	SUB.W	D3,D1	SUB.W	D0,D3		; D0 <-- dplace vers la gauche	JUMP',NC 20$	CLR.W	D020$:	CLR.W	D3	LOAD.B	D3,(A6)+OBUHEAD+OGCMWB	SL.W	D3,#3	ADD.W	D1,D3	LOAD.W	D2,(A6)+OALPOX	ADD.W	D2,(A6)+OALDIX	COMP.W	D1,D2	JUMP',LE 30$	LOAD.W	D3,D1	SUB.W	D3,D2	ADD.W	D0,D3		; D0 <-- dplace vers la droite	LOAD.W	D2,(A6)+OBUHIMA+OIMDLX	SUB.W	D2,(A6)+OALDIX	JUMP',NC 25$	CLR.W	D225$:	COMP.W	D0,D2	JUMP',LS 30$	LOAD.W	D0,D230$:	SWAP.W	D0	SWAP.W	D1	ADD.W	D1,(A6)+OBUHEAD+OGCBLI	SUB.W	D1,(A6)+OBUHEAD+OGCMHD	COMP.W	D1,(A6)+OALPOY	JUMP',GE 40$	LOAD.W	D3,(A6)+OALPOY	SUB.W	D3,D1	SUB.W	D0,D3		; D0 <-- dplace vers le haut	JUMP',NC 40$	CLR.W	D040$:	ADD.W	D1,(A6)+OBUHEAD+OGCMHD	LOAD.W	D2,(A6)+OALPOY	ADD.W	D2,(A6)+OALDIY	COMP.W	D1,D2	JUMP',LE 50$	LOAD.W	D3,D1	SUB.W	D3,D2	ADD.W	D0,D3		; D0 <-- dplace vers le bas	LOAD.W	D2,(A6)+OBUHIMA+OIMDLY	SUB.W	D2,(A6)+OALDIY	JUMP',NC 45$	CLR.W	D245$:	COMP.W	D0,D2	JUMP',LS 50$	LOAD.W	D0,D250$:	SWAP.W	D0	POPM.L	D1..D3	RET;---------\\; TIINVCAR >;---------/; Inverse le marqueur du caractre.; in	D1.L	position de la souris; out	-; mod	D7.WTIINVCAR:	PUSHM.L	D1..D4	COMP.L	D1,#-1	JUMP,EQ 90$	LOAD.W	D2,#INVDOT	; D2 <-- mode	LOAD.L	D3,D1	SUB.W	D3,(A6)+OBUHEAD+OGCLMA	SWAP.W	D3	ADD.W	D3,(A6)+OBUHEAD+OGCBLI	SUB.W	D3,(A6)+OBUHEAD+OGCMHD	SWAP.W	D3	LOAD.L	D1,D3	LOAD.W	D4,(A6)+OBUHEAD+OGCMHD	SWAP.W	D4	CLR.W	D4	LOAD.B	D4,(A6)+OBUHEAD+OGCMWB	SL.W	D4,#3	LIB	?DRRECT		; dessine le rectangle englobant	TEST.W	(A6)+OBUHEAD+OGCBLI	JUMP',EQ 40$	LOAD.L	D3,D1	INC.W	D3	SWAP.W	D3	ADD.W	D3,(A6)+OBUHEAD+OGCMHD	SUB.W	D3,(A6)+OBUHEAD+OGCBLI	SWAP.W	D3	CLR.L	D4	LOAD.B	D4,(A6)+OBUHEAD+OGCMWB	SL.W	D4,#3	DEC.W	D4	LIB	?DRSEG		; dessine la ligne de base40$:	TEST.W	(A6)+OBUHEAD+OGCLMA	JUMP',EQ 50$	LOAD.L	D3,D1	ADD.W	D3,(A6)+OBUHEAD+OGCLMA	ADD.L	D3,#H'10000	LOAD.W	D4,(A6)+OBUHEAD+OGCMHD	DEC.W	D4	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; dessine la rfrence gauche50$:	LOAD.L	D3,D1	SUB.W	D3,#2	SUB.W	D3,(A0)+ODFCX	JUMP',NS 90$	SWAP.W	D3	ADD.W	D3,(A6)+OBUHEAD+OGCMHD	SUB.W	D3,(A6)+OBUHEAD+OGCBLI	JUMP',NS 90$	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.B	MODCAR,INVDOT	.B	AFTOUT	.B	0	.EVEN	LOAD.B	D3,(A6)+OCAR	JUMP',NE 60$	LOAD.B	D3,#SPACE60$:	LIB	?AFCAR		; dessine le caractre	LIB	?AFTIM	.B	AFNORM	.B	MODCAR,SETDOT	.B	0	.EVEN90$:	POPM.L	D1..D4	RET;----------\\; TISHOWIMA >;----------/; Affiche l'image dans la fentre.; in	D0.L	offset (y;x); out	-; mod	D7.WTISHOWIMA:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.L	D3,D0	SWAP.W	D3	LOAD.L	(A3)+1,D3	; source: <xx> <yy>	LOAD.L	(A3)+5,(A6)+OPIM; source: <pppp>	LOAD.W	D3,(A6)+OBUHIMA+OIMDLX	ADD.W	D3,#8-1	SR.W	D3,#3	LOAD.W	(A3)+9,D3	; source: <ii>	LOAD.W	(A3)+11,(A6)+OALPOX ; destination: <xx>	LOAD.W	(A3)+13,(A6)+OALPOY ; destination: <yy>	CLR.L	(A3)+15		; destination: <pppp>	CLR.W	(A3)+19		; destination: <ii>	LOAD.W	D3,(A6)+OALDIX	COMP.W	D3,(A6)+OBUHIMA+OIMDLX	JUMP',LS 40$	LOAD.W	D3,(A6)+OBUHIMA+OIMDLX40$:	LOAD.W	(A3)+21,D3	; <dxx>	LOAD.W	D3,(A6)+OALDIY	COMP.W	D3,(A6)+OBUHIMA+OIMDLY	JUMP',LS 45$	LOAD.W	D3,(A6)+OBUHIMA+OIMDLY45$:	LOAD.W	(A3)+23,D3	; <dyy>	LOAD.B	(A3)+25,#LOADDOT ; <mode>	LOAD.W	D3,#26	LIB	?STRING		; affiche l'image	POPM.L	D3,A3	RET;---------\\; TIAFFCAR >;---------/; Affiche les soft-keys.; in	-; out	-; mod	D7.WTIAFFCAR:	PUSHM.L	D1..D4,A3,A4	LOAD.L	A3,(A6)+OPMAT	LOAD.W	D3,(A6)+OBUHEAD+OGCMSB	DEC.W	D3	LOAD.W	D1,#1		; D1 <-- matrice pleine10$:	TEST.B	(A3+)	JUMP',NE 12$	DECJ.W,NMO D3,10$	CLR.W	D1		; D1 <-- matrice vide12$:	LOAD.L	A3,#R16"TXMTI	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,#12		; D4 <-- nb de .ASCIZ20$:	LOAD.B	(A4+),(A3+)	JUMP',NS 30$	JUMP,NE 20$	DEC.W	D4	JUMP,NE 20$	JUMP	50$30$:	DEC.L	A4	LOAD.B	D3,(A6)+OCAR	JUMP',NE 32$	LOAD.B	D3,#SPACE32$:	TEST.W	D1		; matrice vide ?	JUMP',EQ 40$		; oui => 40$				; non =>	LOAD.B	(A4+),#'(	LOAD.B	(A4+),D3	LOAD.B	(A4+),#')	JUMP	20$40$:	LOAD.B	(A4+),#AFINV	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),D3	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#AFDIR	JUMP	20$50$:	LOAD.L	A3,#(A6)+OBUDIS	LIB	?AFMENU		; affiche les soft-keys	TEST.L	D2:#0	JUMP',BC 60$	LOAD.W	D3,#7	LIB	?SETBARRE	; allume <-->60$:	TEST.L	D2:#1	JUMP',BC 65$	LOAD.W	D3,#8	LIB	?SETBARRE	; allume v^65$:	POPM.L	D1..D4,A3,A4	RET;---------\\; TIOPEWDO >;---------/; Ouvre la fentre pour l'image.; in	-; out	D7.W	erreur; mod	D7.WTIOPEWDO:	PUSHM.L	D2..D4,A3	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve le contenu sous la swdo	JUMP,NE 90$	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	ADD.W	D3,#10	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,D3	SUB.W	D4,#10		; D4 <-- <dyy>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,#10		; D3 <-- <xx>	LOAD.W	D4,(A0)+ODFDX	SUB.W	D4,D3	SUB.W	D4,#10		; D4 <-- <dxx>	LOAD.L	(A6)+OALPOY,D3	LOAD.L	(A6)+OALDIY,D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface toute la fentre	LOAD.W	D2,#SETDOT	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LIB	?DRRECT		; rectangle autour grande matrice	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; TICLOWDO >;---------/; Ferme la fentre de l'image.; in	-; out	-; mod	D7.WTICLOWDO:	PUSH.L	D3	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue sous la swdo	CALL	AFMENU		; refait les soft-keys	POP.L	D3	RET	.END