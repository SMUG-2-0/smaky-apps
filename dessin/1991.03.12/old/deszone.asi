	.SBTTL	DESZONE	.IF	DESSIN;--------\\; CMZONE  >;========/; Construit le mmenu pour changer de zone.; in	-; out	A3.L	^mmenu; mod	D7.W, A3.LCMZONE:	PUSHM.L	D3,D4,A4,A5	LOAD.W	D3,(A6)+ONOZO	; D3 <-- zone actuelle	CALL	CLOZONE		; sauve la zone actuelle	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,#R16"00$10$:	LOAD.B	(A3+),(A4+)	; buffer <-- case vide	JUMP,NE 10$	LOAD.B	(A3+),#-1	; buffer <-- trait ---------	LOAD.L	A5,#(A6)+OTAZO	CLR.W	D420$:	LOAD.B	(A3+),#SPACE	LOAD.B	(A3+),#'[	LOAD.B	D3,D4	INC.B	D3	COMP.B	D3,#NBZONE	JUMP',NE 22$	CLR.B	D322$:	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- [n]	LOAD.B	(A3+),#']	LOAD.B	(A3+),#SPACE	TEST.L	(A5)+OZOPM	; zone existe ?	JUMP,EQ 40$		; non => 40$				; oui =>	LOAD.L	A4,#(A5)+OZONAM	TEST.B	(A4)		; nom existe ?	JUMP',NE 30$		; oui => 30$	LOAD.L	A4,#R16"01$	; non => donne le nom "..."30$:	LOAD.B	D3,(A4+)	JUMP',EQ 34$	COMP.B	D3,#'A	JUMP',LO 32$	COMP.B	D3,#'Z	JUMP',HI 32$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule32$:	LOAD.B	(A3+),D3	; buffer <-- nom du fichier	JUMP	30$34$:	LOAD.B	(A3+),#SPACE40$:	CLR.B	(A3+)		; buffer <-- terminateur de la case	LOAD.L	A5,#(A5)+LZO	; A5 <-- ^descripteur zone suivante	INC.W	D4		; D4 <-- numro suivant	COMP.W	D4,#NBZONE	JUMP,LO 20$	CLR.B	(A3+)		; buffer <-- terminateur gnral	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^mmenu	POPM.L	D3,D4,A4,A5	RET00$:	.ASCIZ	"          "	; premire case vide01$:	.ASCIZ	"..."		; nom inconnu	.EVEN	.ENDIF	.IF	DESSIN;--------\\; NEWZONE >;========/; Change de zone, et crac !; in	D3.W	numro de la zoe (0..9); out	D7.W	erreur; mod	D7.WNEWZONE:	PUSHM.L	D1..D4,A4	LOAD.W	D1,#MTYPCP	CLR.W	D7	LOAD.W	D2,(A6)+ONOZO	; D2 <-- zone actuelle	COMP.W	D3,D2		; autre zone ?	JUMP,EQ 90$		; non => 90$				; oui =>	CALL	CLOMACM		; libre matrices copie et masque	EX.L	D3,D2	CALL	CLOZONE		; sauve la zone actuelle	EX.L	D2,D3	CALL	OPEZONE		; reprend la nouvelle zone	TCLR.L	D3:#16		; D3 <-- nouvelle zone existait	TEST.L	(A6)+OPMAT	; qq chose dans nouvelle zone ?	JUMP,NE 30$		; oui => 30$				; non =>	TSET.L	D3:#16		; D3 <-- nouvelle zone n'existait pas	LOAD.L	(A6)+OMALMY,(A6)+OGRDIY ; init dimensions par dfaut	CLR.L	(A6)+OPMOVY	CLR.L	(A6)+OPMDIY	LOAD.W	(A6)+OSCALE,#1	CLR.B	(A6)+OMAJ	; c'est  jour !	LOAD.W	D4,(A6)+OMALMY	INC.W	D4 ;;?	MUL.WU	D4,(A6)+OMALMX	SR.L	D4,#3		; D4 <-- longueur ncessaire	ADD.L	D4,#IMLBUF	; D4 <-- ajoute rserve pour codage	GESMEM	?GETMEM		; demande mmoire pour matrice principale	JUMP,NE 50$	LOAD.L	A4,#(A4)+IMLBUF	LOAD.L	(A6)+OPMAT,A4	LOAD.W	D4,(A6)+OMALMX	SR.W	D4,#3	LOAD.W	(A6)+OMANBB,D4	CALL	CLEARALL	; met la matrice principale  zro30$:	CALL	OPEMACM		; prend les matrices copie et masque	JUMP,NE 50$	LOAD.W	(A6)+ONOZO,D3	; mm. numro nouvelle zone	JUMP	90$; En cas d'erreur, reprend l'ancienne zone.50$:	PUSH.W	D7	TEST.L	D3:#16		; nouvelle zone existait ?	JUMP',BC 60$		; oui => 60$	TEST.L	(A6)+OPMAT	JUMP',EQ 60$	LOAD.L	A4,(A6)+OPMAT	GESMEM	?GIVMEM		; libre matrice principale (elle est vide)	CLR.L	(A6)+OPMAT60$:	CALL	CLOMACM		; libre matrices copie et masque	LOAD.W	D3,D2		; D3 <-- numro zone initiale	CALL	OPEZONE		; reprend la zone initiale	CALL	OPEMACM		; reprend les matrices copie et masque	JUMP,NE FATMEM	POP.W	D790$:	POPM.L	D1..D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; OPEZONE >;--------/; Reprend tous les paramtres d'une zone.; in	D3.W	numro de la zoe (0..9); out	-; mod	D7.WOPEZONE:	PUSHM.L	D3,A3..A5	LOAD.L	A5,#(A6)+OTAZO	MUL.WU	D3,#LZO	ADD.L	A5,D3		; A5 <-- ^descripteur zone	LOAD.L	(A6)+OPMAT,(A5)+OZOPM	LOAD.L	(A6)+OMALMY,(A5)+OZOLY	LOAD.W	(A6)+OSCALE,(A5)+OZOSCA	LOAD.L	(A6)+OPMOVY,(A5)+OZOOV	LOAD.L	(A6)+OPMDIY,(A5)+OZODI	LOAD.B	(A6)+OMAJ,(A5)+OZOMAJ	LOAD.W	D3,(A6)+OMALMX	SR.W	D3,#3	LOAD.W	(A6)+OMANBB,D3	LOAD.L	A3,#(A6)+OBUNAME	LOAD.L	A4,#(A5)+OZONAM40$:	LOAD.B	(A3+),(A4+)	JUMP,NE 40$	POPM.L	D3,A3..A5	RET;--------\\; CLOZONE >;--------/; Sauve tous les paramtres d'une zone, pour permettre; d'en ouvrir une nouvelle.; in	D3.W	numro de la zoe (0..9); out	-; mod	D7.WCLOZONE:	PUSHM.L	D3,A3..A5	LOAD.L	A5,#(A6)+OTAZO	MUL.WU	D3,#LZO	ADD.L	A5,D3		; A5 <-- ^descripteur zone	LOAD.L	(A5)+OZOPM,(A6)+OPMAT	LOAD.L	(A5)+OZOLY,(A6)+OMALMY	LOAD.W	(A5)+OZOSCA,(A6)+OSCALE	LOAD.L	(A5)+OZOOV,(A6)+OPMOVY	LOAD.L	(A5)+OZODI,(A6)+OPMDIY	LOAD.B	(A5)+OZOMAJ,(A6)+OMAJ	LOAD.L	A3,#(A6)+OBUNAME	LOAD.L	A4,#(A5)+OZONAM40$:	LOAD.B	(A4+),(A3+)	JUMP,NE 40$	POPM.L	D3,A3..A5	RET	.ENDIF;-------------\\; NEWMEMMATRIX >;=============/; Demande de la mmoire nouvelle pour les matrices.; in	D3.W	largeur de l'image;	D4.W	hauteur de l'image; out	D7.W	erreur; mod	D7.WNEWMEMMATRIX:	PUSHM.L	D1,D4	.IF	DESSIN	TEST.L	(A6)+OPMAT	JUMP',EQ 10$	LOAD.L	A4,(A6)+OPMAT	LOAD.L	A4,#(A4)-IMLBUF	; A4 <-- prend la rserve pour codage	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la matrice principale	CLR.L	(A6)+OPMAT	.ELSE	CALL	CLRREPERE	; efface les repres	TEST.L	(A6)+OPGC	JUMP',EQ 10$	LOAD.L	A4,(A6)+OPGC	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le gencar	CLR.L	(A6)+OPGC	.ENDIF10$:	POPM.L	D1,A4;	CALL	GETMEMMATRIX;	RET;-------------\\; GETMEMMATRIX >;=============/; Demande de la mmoire pour les matrices.; L'ancienne mmoire est transfre le mieux possible; dans la nouvelle.; in	D3.W		largeur de l'image;	D4.W		hauteur de l'image;	(A6)+OMASTR.B	flags transfert avec stretch; out	D7.W		erreur; mod	D7.WGETMEMMATRIX:	PUSHM.L	D0..D4,A2..A4	CALL	WAITMOUSE	; met le sablier	LOAD.W	D1,#MTYPCP	LOAD.W	D0,(A6)+OMANBB	; D0 <-- largeur actuelle [bytes]	LOAD.W	D2,(A6)+OMALMY	; D2 <-- hauteur actuelle [points]; Libre les matrices copie et masque pour ne garder que l'ancienne; matrice principale.	CALL	CLOMACM		; libre les matrices copie et masque; Demande de la mmoire pour la nouvelle matrice principale.	SWAP.W	D3	LOAD.W	D3,D4		; D3 <-- nouvelles largeur et hauteur	SWAP.W	D3	INC.W	D4	MUL.WU	D4,D3	SR.L	D4,#3		; D4 <-- nouvelle longueur en bytes	GESMEM	?GETMEM		; demande nouvelle matrice copie	JUMP,NE 50$	LOAD.L	(A6)+OPMAC,A4	.IF	DESSIN	ADD.L	D4,#IMLBUF	; D4 <-- ajoute rserve pour codage	GESMEM	?GETMEM		; demande nouvelle matrice masque	JUMP,NE 50$	LOAD.L	A4,#(A4)+IMLBUF	LOAD.L	(A6)+OPMAM,A4	GESMEM	?GETMEM		; demande nouvelle matrice principale	JUMP,NE 50$	LOAD.L	A3,(A6)+OPMAT	; A3 <-- ^ancienne matrice principale	LOAD.L	A4,#(A4)+IMLBUF	; A4 <-- saute la rserve pour codage	LOAD.L	(A6)+OPMAT,A4	.ELSE	GESMEM	?GETMEM		; demande nouvelle matrice masque	JUMP,NE 50$	LOAD.L	(A6)+OPMAM,A4	MUL.WU	D4,#128	ADD.L	D4,#OGCMAT	GESMEM	?GETMEM		; demande nouveau gencar	JUMP,NE 50$	LOAD.L	A3,(A6)+OPGC	; A3 <-- ^ancien gencar	LOAD.L	(A6)+OPGC,A4	LOAD.L	A4,#(A4)+OGCMAT	LOAD.L	(A6)+OPMAT,A4	.ENDIF	LOAD.L	(A6)+OMALMY,D3	SR.W	D3,#3	LOAD.W	(A6)+OMANBB,D3	.IF	DESSIN	CALL	CLEARALL	; met la matrice principale  zro	.ELSE	CALL	CLEARNEWGC	; init le nouveau gencar par dfaut	.ENDIF	PUSH.L	A4	LOAD.L	A4,(A6)+OPMAC	CALL	CLEARALL	; met la matrice copie  zro	POP.L	A4; Transfert l'ancienne matrice dans la nouvelle.	LOAD.L	D3,A3		; ancienne matrice existe ?	JUMP,EQ 90$		; non => 90$	.IF	DESSIN	CALL	XFERMA		; nouvelle <-- ancienne	.ELSE	PUSH.L	A3	LOAD.L	A2,A4	LOAD.W	D4,#OGCMAT-128$:	LOAD.B	(A4+),(A3+)	; nouveau header <-- ancien header	DECJ.W,NMO D4,28$	LOAD.W	D4,(A6)+OMANBB	LOAD.B	(A2)+OGCMWB,D4	MUL.WU	D4,(A6)+OMALMY	LOAD.W	(A2)+OGCMSB,D4	LOAD.W	(A2)+OGCMHD,(A6)+OMALMY	LOAD.W	D3,#128		; D3 <-- nb de caractres30$:	PUSHM.L	D2,A3,A4	COMP.W	D2,(A6)+OMALMY	JUMP',LS 32$	LOAD.W	D2,(A6)+OMALMY	; D2 <-- hauteur de la plus petite32$:	PUSHM.L	D0,A3,A4	COMP.W	D0,(A6)+OMANBB	JUMP',LS 35$	LOAD.W	D0,(A6)+OMANBB	; D0 <-- largeur de la plus petite35$:	LOAD.B	(A4+),(A3+)	; nouvelle <-- ancienne	DEC.W	D0	JUMP,NE 35$	POPM.L	D0,A3,A4	ADD.W	A3,D0		; A3 <-- ^ancienne ligne suivante	ADD.W	A4,(A6)+OMANBB	; A4 <-- ^nouvelle ligne suivante	DEC.W	D2	JUMP,NE 32$	POPM.L	D2,A3,A4	LOAD.W	D4,D0	MUL.WU	D4,D2	ADD.L	A3,D4		; A3 <-- ^caractre suivant	LOAD.W	D4,(A6)+OMANBB	MUL.WU	D4,(A6)+OMALMY	ADD.L	A4,D4		; A4 <-- ^caractre suivant	DEC.W	D3	JUMP,NE	30$	CALL	CHKGENC		; met  jour qq paramtres du gencar	POP.L	A3	.ENDIF	LOAD.L	A4,A3	.IF	DESSIN	LOAD.L	A4,#(A4)-IMLBUF	; A3 <-- prend la rserve pour codage	.ENDIF	GESMEM	?GIVMEM		; libre l'ancienne matrice principale	LOAD.L	A4,#(A6)+OBLOC	LOAD.W	D4,#NBBLOC-140$:	CLR.L	(A4)+OBLKPT	; vide tous les bloc-notes !	LOAD.L	A4,#(A4)+LGBLOC	DECJ.W,NMO D4,40$	JUMP	90$; Il n'y a pas assez de mmoire pour la nouvelle matrice principale.50$:	PUSH.W	D7	CALL	CLOMACM		; libre les matrices copie et masque	LOAD.W	D7,#ERNEMEM	TEST.W	(A6)+OMANBB	JUMP,EQ FATMEM	LOAD.W	D4,(A6)+OMALMY	INC.W	D4 ;;?	MUL.WU	D4,(A6)+OMANBB	GESMEM	?GETMEM		; redemande ancienne matrice copie	JUMP,NE FATMEM	LOAD.L	(A6)+OPMAC,A4	CALL	CLEARALL	; met la matrice copie  zro	.IF	DESSIN	ADD.L	D4,#IMLBUF	; D4 <-- ajoute rserve pour codage	GESMEM	?GETMEM		; redemande ancienne matrice masque	JUMP,NE FATMEM	LOAD.L	A4,#(A4)+IMLBUF	LOAD.L	(A6)+OPMAM,A4	TEST.L	(A6)+OPMAT	JUMP',NE 58$	GESMEM	?GETMEM		; redemande ancienne matrice principale	JUMP,NE FATMEM	LOAD.L	A4,#(A4)+IMLBUF	; A4 <-- saute rserve pour codage	LOAD.L	(A6)+OPMAT,A4	CALL	CLEARALL	; met la matrice principale  zro	.ELSE	GESMEM	?GETMEM		; redemande ancienne matrice masque	JUMP,NE FATMEM	LOAD.L	(A6)+OPMAM,A4	TEST.L	(A6)+OPGC	JUMP',NE 58$	MUL.WU	D4,#128	ADD.L	D4,#OGCMAT	GESMEM	?GETMEM		; redemande ancien gencar	JUMP,NE FATMEM	LOAD.L	(A6)+OPGC,A4	LOAD.L	A4,#(A4)+OGCMAT	LOAD.L	(A6)+OPMAT,A4	CALL	CLEARNEWGC	; init le nouveau gencar par dfaut	LOAD.B	D3,(A6)+OCAR	CALL	CARSELECT	; slectionne l'ancien caractre	.ENDIF58$:	POP.W	D790$:	.IF	EDGAR	TEST.W	D7	JUMP',NE 95$	LOAD.B	(A6)+OCAR,#-1	; y'a plus de caractre en dition95$:	.ENDIF	POPM.L	D0..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; XFERMA  >;--------/; Transfert l'ancienne matrice dans la nouvelle.; in	D0.W		ancienne largeur [bytes];	D2.W		ancienne hauteur [points];	A3.L		^ancienne matrice;	A4.L		^nouvelle matrice;	(A6)+OMASTR.B	flags transfert avec stretch; out	-; mod	D7.WXFERMA:	PUSHM.L	D0..D4,A3,A4	TEST.B	(A6)+OMASTR:#BMASTR ; transfert avec stretch ?	JUMP',BS 50$		; oui => 50$	COMP.W	D2,(A6)+OMALMY	JUMP',LS 20$	LOAD.W	D2,(A6)+OMALMY	; D2 <-- hauteur de la plus petite20$:	PUSHM.L	D0,A3,A4	COMP.W	D0,(A6)+OMANBB	JUMP',LS 30$	LOAD.W	D0,(A6)+OMANBB	; D0 <-- largeur de la plus petite30$:	LOAD.B	(A4+),(A3+)	; nouvelle <-- ancienne	DEC.W	D0	JUMP,NE 30$	POPM.L	D0,A3,A4	ADD.W	A3,D0		; A3 <-- ^ancienne ligne suivante	ADD.W	A4,(A6)+OMANBB	; A4 <-- ^nouvelle ligne suivante	DEC.W	D2	JUMP,NE 20$	JUMP	90$50$:	LOAD.L	D3,(A6)+OMALMY	TEST.B	(A6)+OMASTR:#BMAHOM ; strech homothtique ?	JUMP',BC 60$		; non => 60$				; oui =>	LOAD.W	D1,D0	SL.W	D1,#3	SWAP.W	D3	MUL.WU	D1,D3	SWAP.W	D3	DIV.WU	D1,D2		; D1 <-- old(x) * new(y) / old(y)	COMP.W	D3,D1	JUMP',LO 55$	LOAD.W	D3,D1	JUMP'	60$55$:	LOAD.W	D4,D3	MUL.WU	D4,D2	LOAD.W	D1,D0	SL.W	D1,#3	DIV.WU	D4,D1		; D1 <-- new(x) * old(y) / old(x)	SWAP.W	D3	LOAD.W	D3,D4	SWAP.W	D360$:	CLR.L	D1	SWAP.W	D2	LOAD.W	D2,D0	SL.W	D2,#3	CALL	ISSTRETCH	; init source stretch	LOAD.L	(A6)+OSTRETCH+OSTRSPT,A3	LOAD.W	(A6)+OSTRETCH+OSTRSDX,D0	CLR.L	D1	LOAD.L	D2,D3	COMP.W	D2,(A6)+OMALMX	JUMP',LO 70$	LOAD.W	D2,(A6)+OMALMX	DEC.W	D270$:	SWAP.W	D2	COMP.W	D2,(A6)+OMALMY	JUMP',LO 72$	LOAD.W	D2,(A6)+OMALMY	DEC.W	D272$:	SWAP.W	D2	CALL	IDSTRETCH	; init destination stretch	CALL	GOSTRETCH	; moteur ...90$:	POPM.L	D0..D4,A3,A4	RET;--------\\; OPEMACM >;--------/; Demande les matrices copie et masque.; in	-; out	D7.W	erreur; mod	D7.WOPEMACM:	PUSHM.L	D1,D4,A4	LOAD.W	D1,#MTYPCP	LOAD.W	D4,(A6)+OMALMY	INC.W	D4 ;;?	MUL.WU	D4,(A6)+OMANBB	GESMEM	?GETMEM		; demande la matrice copie	JUMP,NE 90$	LOAD.L	(A6)+OPMAC,A4	CALL	CLEARALL	; met la matrice copie  zro	.IF	DESSIN	ADD.L	D4,#IMLBUF	; D4 <-- ajoute rserve pour codage	GESMEM	?GETMEM		; demande la matrice masque	JUMP,NE 90$	LOAD.L	A4,#(A4)+IMLBUF	LOAD.L	(A6)+OPMAM,A4	.ELSE	GESMEM	?GETMEM		; demande la matrice masque	JUMP,NE 90$	LOAD.L	(A6)+OPMAM,A4	.ENDIF90$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOMACM >;--------/; Libre les matrices copie et masque.; in	-; out	-; mod	D7.WCLOMACM:	PUSHM.L	D1,A4	LOAD.W	D1,#MTYPCP	TEST.L	(A6)+OPMAC	JUMP',EQ 20$	LOAD.L	A4,(A6)+OPMAC	GESMEM	?GIVMEM	CLR.L	(A6)+OPMAC20$:	TEST.L	(A6)+OPMAM	JUMP',EQ 30$	LOAD.L	A4,(A6)+OPMAM	.IF	DESSIN	LOAD.L	A4,#(A4)-IMLBUF	.ENDIF	GESMEM	?GIVMEM	CLR.L	(A6)+OPMAM30$:	POPM.L	D1,A4	RET	.IF	EDGAR;-----------\\; CLEARNEWGC >;-----------/; Efface le gencar demand, et initialise les paramtres par dfaut.; in	-; out	-; mod	D3.L, D4.L, D7.WCLEARNEWGC:	LOAD.L	A4,(A6)+OPGC20$:	CLR.B	(A4+)		; met tout le gencar  zro	DEC.L	D4	JUMP,NE 20$	LOAD.L	A4,(A6)+OPGC	LOAD.W	D4,(A6)+OMALMY	LOAD.W	(A4)+OGCMHD,D4	; init hauteur matrice	SR.W	D4,#2	LOAD.W	(A4)+OGCBLI,D4	; init ligne de base (1/4 hauteur)	LOAD.W	D4,(A6)+OMANBB	LOAD.B	(A4)+OGCMWB,D4	; init largeur matrice (en bytes)	MUL.WU	D4,(A6)+OMALMY	LOAD.W	(A4)+OGCMSB,D4	; init nb de bytes d'une matrice;	CLR.B	(A4)+OGCFCA	LOAD.B	(A4)+OGCLCA,#127	LOAD.L	A4,#(A4)+OGCWID	LOAD.W	D4,#128-1	LOAD.W	D3,(A6)+OMALMX40$:	LOAD.B	(A4+),D3	; init la table des largeurs	DECJ.W,NMO D4,40$	CALL	CHKGENC		; met  jour qq paramtres du gencar	LOAD.L	A4,(A6)+OPGC	RET	.ENDIF; Erreur fatale avec la mmoire. On arrive mme plus reprendre; ce qu'on a libr y'a quelques centimes de secondes avant !FATMEM:	PUSH.W	D7	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPFAT	LIB	?BEEP		; fait un vilain bruit	POP.W	D7	CLR.W	D2		; D2 <-- mode (sans sauver dessous)	DBOX_	MERROR		; affiche l'erreur fatale	JUMP	ERFAT		; puis quitte brutalement (!)	.END