	.SBTTL	DDESSINEDIT;--------------\\; _DESSIN_TEDIT >;==============/; Edite une table de 4x7 trames quelconques.;; Table d'icnes en (A2):;	.B	USEGC,f,s,t;	.B	i1;	.B	i2;		etc.;	.B	0;	.EVEN;; Trois textes en (A3):;	.ASCIZ	"1..n";	.ASCIZ	"un seul";	.ASCIZ	"";	.EVEN;; Table des trames en (A4):;	.B	B'00010001	;;	.B	B'00100010	;;	.B	B'01000100	;;	.B	B'10001000	;;	.B	B'00010001	; une trame;	.B	B'00100010	;;	.B	B'01000100	;;	.B	B'10001000	;;	etc.; in	D2.L	flags divers (BMA...);	D4.W	trame slectionne;	A0.L	^descripteur de la fentre;	A2.L	^table d'icnes (si BMAICO dans D2.L);	A3.L	^trois textes;	A4.L	^table des 4x7 trames (1x7 trames si BMAICO dans D2.L); out	D2.L	flags divers;	D3.L	d'accord/annule (F1/F0);	D4.W	trame slectionne;	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W_DESSIN_TEDIT:	PUSHM.L	D0,D1,D5,D6,A0..A6	TSET.L	D2:#BMATR	TCLR.L	D2:#BMADR	TCLR.L	D2:#BMAPT	CALL	OPEVAR		; A6 <-- ^variables	JUMP,NE 99$	CALL	OPETDEF		; ouvre la DBOX	JUMP,NE	90$	LOAD.W	D0,D6	CALL	INVRECT4X7	; montre la trame slectionne05$:	LOAD.L	A4,A5		; A4 <-- ^table des trames	LOAD.W	D1,D6	MUL.WU	D1,#8	ADD.L	A4,D1		; A4 <-- ^bonne trame	CALL	ALLTDEF		; montre la trame actuelle	LOAD.W	D0,D610$:	CALL	SCMO		; remet la souris	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_TDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ	80$	COMP.W	D3,#F0	JUMP,EQ	85$	COMP.W	D3,#DEL	JUMP,EQ	50$	COMP.W	D3,#DEFINE	JUMP,EQ	60$	COMP.W	D3,#KEYMGP	JUMP',EQ 20$	COMP.W	D3,#KEYMMP	JUMP',EQ 20$	COMP.W	D3,#KEYMDP	JUMP',EQ 20$	COMP.W	D3,#KEYMGR	JUMP,EQ	10$	COMP.W	D3,#KEYMMR	JUMP,EQ	10$	COMP.W	D3,#KEYMDR	JUMP,EQ	10$15$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	10$20$:	CALL	MOUTDEF		; D0 <-- X et D1 <-- Y	JUMP',EQ 25$	CALL	SELTRECT4X7	; slectionne un rectangle 4 x 7 ?	JUMP,NE 15$	JUMP	05$25$:	LOAD.W	D2,#-1		; D2 <-- dernire coordonne X	LOAD.W	D3,D2		; D3 <-- dernire coordonne Y	LOAD.W	(A6)+OTDOP,#SETDOT	TEST.B	(A4)+(D1.W):D0	JUMP',BC 30$	LOAD.W	(A6)+OTDOP,#CLRDOT30$:	CALL	MOUTDEF		; D0 <-- X et D1 <-- Y	JUMP',NE 40$	COMP.W	D0,D2		; changement ?	JUMP',NE 32$		; oui => 32$	COMP.W	D1,D3		; non => 40$	JUMP',EQ 40$32$:	LOAD.W	D2,D0		; D2 <-- dernire coordonne X	LOAD.W	D3,D1		; D3 <-- dernire coordonne Y	COMP.W	(A6)+OTDOP,#SETDOT	JUMP',NE 35$	TSET.B	(A4)+(D1.W):D0	JUMP',BS 40$	CALL	DOTTDEF		; allume gros point	CALL	SHOTDEF		; montre dans rectangle droite	JUMP'	38$35$:	TCLR.B	(A4)+(D1.W):D0	JUMP',BC 40$	CALL	DOTTDEF		; teint gros point	CALL	SHOTDEF		; montre dans rectangle droite38$:	LOAD.W	D0,D6		; D0 <-- trame slectionne	CALL	DESTRECT4X7	; dessine la trame modifie40$:	CALL	SCMO		; remet la souris	PUSH.L	D3	LIB	?GETKEY		; attend souris ...	LOAD.W	D1,D3	POP.L	D3	COMP.W	D1,#KEYMPO	; souris dplace ?	JUMP,EQ	30$		; oui => 30$	COMP.W	D1,#KEYMGR	JUMP,EQ	10$	COMP.W	D1,#KEYMMR	; bouton relach ?	JUMP,EQ	10$		; oui => 10$	COMP.W	D1,#KEYMDR	JUMP,EQ	10$	JUMP	40$50$:				; EFFACE =>	CLR.L	(A4)+0	CLR.L	(A4)+4	JUMP'	65$60$:				; NEGATIF =>	NOT.L	(A4)+0	NOT.L	(A4)+465$:	CALL	ALLTDEF	LOAD.W	D0,D6		; D0 <-- trame slectionne	CALL	DESTRECT4X7	; dessine la trame modifie	JUMP	10$80$:				; D'ACCORD =>	LOAD.L	(A6)+OMODE,D4	LOAD.W	(A6)+OSELEC,D6	LOAD.L	A4,(A6)+OPOBJ	LOAD.L	A3,#(A6)+OBUFF	LOAD.W	D4,#((8*MAMAX)/4)-182$:	LOAD.L	(A4+),(A3+)	; objets <-- OBUFF	DECJ.W,NMO D4,82$85$:				; ANNULE =>	DBOX_	CLOSE		; ferme la DBOX90$:	CALL	CLOVAR		; libre les variables99$:	POPM.L	D0,D1,D5,D6,A0..A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; OPETDEF >;--------/; Ouvre la DBOX pour dfinir la trame.; in	-; out	D4.L	fanions;	D5.L	canal;	D6.W	trame slectionne;	A2.L	^table de la dbox;	A5.L	^table des trames;	D7.W	erreur; mod	D4.L, D5.L, D6.L, D7.W, A5.LOPETDEF:	PUSHM.L	D0..D3,A3	LOAD.L	A2,#R16"TDBOX_TDEF0	LOAD.L	A3,(A6)+OPTEXT	TEST.B	(A3)		; 3 textes existent ?	JUMP',NE 10$		; oui => 10$	LOAD.L	A2,#R16"TDBOX_TDEF110$:	LOAD.L	D1,(A6)+OMODE	; D1 <-- mode/fanions	LOAD.W	D2,D1		; D2 <-- mode d'ouverture	LOAD.L	D4,D1		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A5,#R16"00$	CALL	OPEAFTEXT	; affiche les 3 textes	LOAD.L	A5,#(A6)+OBUFF	; A5 <-- ^table des trames	LOAD.W	D6,(A6)+OSELEC	; D6 <-- trame slectionne	LIB	?GETDIM		; D3 <-- dim caractre	LOAD.L	D4,D3	SWAP.W	D4		; D4 <-- hauteur	SL.W	D3,#1		; D3 <-- largeur *2	COMP.W	D3,D4	JUMP',LS 20$	LOAD.W	D3,D4		; D3 <-- le plus petit20$:	LOAD.W	(A6)+OTDLG,D3	CALL	ALLRECT4X7	; dessine les rectangles 4 x 7	CLR.W	D030$:	CALL	DESTRECT4X7	; dessine les trames relles	INC.W	D0	COMP.W	D0,#MAMAX	JUMP,LO 30$	LOAD.W	D2,(A6)+OTDLG	LOAD.W	D3,D2	MUL.WU	D3,#1+8+2	SUB.W	D3,#2		; D3 <-- X	SWAP.W	D3	LOAD.W	D3,D2	SUB.W	D3,#2		; D3 <-- Y	SWAP.W	D3	SL.W	D2,#3	ADD.W	D2,#2	LOAD.W	D4,D2		; D4 <-- dY	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- dX	LOAD.W	D2,#SETDOT	; D2 <-- mode	CALL	DRRECT		; dessine rectangle gauche	LOAD.W	D2,(A6)+OTDLG	MUL.WU	D2,#1+8+2+8+2	SUB.W	D2,#2	LOAD.W	D3,D2	LOAD.W	D2,#SETDOT	; D2 <-- mode	CALL	DRRECT		; dessine rectangle droite	LOAD.L	D4,D1		; D4 <-- fanions90$:	POPM.L	D0..D3,A3	TEST.W	D7		; retour EQ/NE	RET00$:	.W	2,3,6;--------\\; MOUTDEF >;--------/; Lit la position de la souris.; in	-; out	D0.W	coordonne X (0..7);	D1.W	coordonne Y (0..7);	D7.W	erreur; mod	D0.L, D1.L, D4.LMOUTDEF:	PUSHM.L	D2..D5	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 90$	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	SUB.W	D4,(A0)+ODFFX	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A6)+OTDLG	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D0	LOAD.W	D0,D4	DIV.WU	D0,(A6)+OTDLG	; D0 <-- coordonne X (0..7)	SUB.W	D0,#8+2	JUMP',LO 90$	COMP.W	D0,#8	JUMP',HS 90$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A6)+OTDLG	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D1	LOAD.W	D1,D4	DIV.WU	D1,(A6)+OTDLG	; D1 <-- coordonne Y (0..7)	COMP.W	D1,#8	JUMP',HS 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; ALLTDEF >;--------/; Dessine toute la matrice.; in	A4.L	^trame; out	-; mod	D7.WALLTDEF:	PUSHM.L	D0,D1,D3	CLR.W	D010$:	CLR.W	D120$:	LOAD.W	(A6)+OTDOP,#SETDOT	TEST.B	(A4)+(D1.W):D0	JUMP',BS 30$	LOAD.W	(A6)+OTDOP,#CLRDOT30$:	CALL	DOTTDEF		; dessine un gros point	INC.W	D1	COMP.W	D1,#8	JUMP,LO	20$	INC.W	D0	COMP.W	D0,#8	JUMP,LO	10$	LOAD.W	(A6)+OTDOP,#LOADDOT	CALL	SHOTDEF		; montre tous les points	POPM.L	D0,D1,D3	RET;--------\\; DOTTDEF >;--------/; Dessine un point dans le rectangle de gauche.; in	D0.W	coordonne X (0..7);	D1.W	coordonne Y (0..7); out	-; mod	D7.WDOTTDEF:	PUSHM.L	D0,D1,D2,D3,D4	LOAD.W	D2,(A6)+OTDLG	MUL.WU	D0,D2	MUL.WU	D1,D2	LOAD.W	D3,D2	ADD.W	D3,D1	SWAP.W	D3	LOAD.W	D1,(A6)+OTDLG	MUL.WU	D1,#1+8+2	LOAD.W	D3,D1	ADD.W	D3,D0	LOAD.W	D4,D2	DEC.W	D4	SWAP.W	D4	LOAD.W	D4,D2	DEC.W	D4	LOAD.W	D2,(A6)+OTDOP	; D2 <-- opration	CALL	DRZONE		; allume/teint un gros point	POPM.L	D0,D1,D2,D3,D4	RET;--------\\; SHOTDEF >;--------/; Affiche la trame dans le rectangle de droite.; in	A4.L	^trame; out	-; mod	D7.WSHOTDEF:	PUSHM.L	D2,D3,D4,A3	LOAD.B	D3,#TRAME	LIB	?AFCAR	LOAD.L	A3,A4		; A3 <-- ^trame 8x8	LOAD.W	D3,#8	LIB	?STRING		; dfini la trame	LOAD.W	D2,(A6)+OTDLG	LOAD.W	D3,D2		; D3 <-- Y	SWAP.W	D3	MUL.WU	D2,#1+8+2+8+2	LOAD.W	D3,D2		; D3 <-- X	LOAD.W	D2,(A6)+OTDLG	SL.W	D2,#3	DEC.W	D2	LOAD.W	D4,D2		; D4 <-- dY	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- dX	LOAD.W	D2,(A6)+OTDOP	; D2 <-- opration	CALL	DRTRAME		; allume/teint qq points	POPM.L	D2,D3,D4,A3	RET;--------------\\; _DESSIN_DEDIT >;==============/; Edite une table de 4x7 pinceaux quelconques.;; Table d'icnes en (A2):;	.B	USEGC,f,s,t;	.B	i1;	.B	i2;		etc.;	.B	0;	.EVEN;; Trois textes en (A3):;	.ASCIZ	"1..n";	.ASCIZ	"un seul";	.ASCIZ	"";	.EVEN;; Table des pinceaux en (A4):;	.B	B'00000000	;;	.B	B'00000000	;;	.B	B'00011000	;;	.B	B'00111100	;;	.B	B'00111100	; un pinceau;	.B	B'00011000	;;	.B	B'00000000	;;	.B	B'00000000	;;	.B	B'00111111	; traitill;	.B	2		; pas;	etc.; in	D2.L	flags divers;	D4.W	trame slectionne;	A0.L	^descripteur de la fentre;	A2.L	^table d'icnes (si BMAICO dans D2.L);	A3.L	^trois textes;	A4.L	^table des 4x7 pinceaux (1x7 pinceaux si BMAICO dans D2.L); out	D2.L	flags divers;	D3.L	d'accord/annule (F1/F0);	D4.W	trame slectionne;	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W_DESSIN_DEDIT:	PUSHM.L	D0,D1,D5,D6,A0..A6	TCLR.L	D2:#BMATR	TSET.L	D2:#BMADR	TCLR.L	D2:#BMAPT	CALL	OPEVAR		; A6 <-- ^variables	JUMP,NE 99$	CALL	OPEDDEF		; ouvre la DBOX	JUMP,NE	90$	LOAD.W	D0,D6	CALL	INVRECT4X7	; montre le pinceau slectionn05$:	LOAD.L	A4,A5		; A4 <-- ^table des pinceaux	LOAD.W	D1,D6	MUL.WU	D1,#8+2	ADD.L	A4,D1		; A4 <-- ^bon pinceau	CALL	ALLDDEF		; montre le pinceau actuel	LOAD.W	D0,D610$:	CALL	SCMO		; remet la souris	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_DDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ	80$	COMP.W	D3,#F0	JUMP,EQ	85$	COMP.W	D3,#DEL	JUMP,EQ	50$	COMP.W	D3,#'+	JUMP,EQ	60$	COMP.W	D3,#'-	JUMP,EQ	65$	COMP.W	D3,#KEYMGP	JUMP',EQ 20$	COMP.W	D3,#KEYMMP	JUMP',EQ 20$	COMP.W	D3,#KEYMDP	JUMP',EQ 20$	COMP.W	D3,#KEYMGR	JUMP,EQ	10$	COMP.W	D3,#KEYMMR	JUMP,EQ	10$	COMP.W	D3,#KEYMDR	JUMP,EQ	10$15$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	10$20$:	CALL	MOUDDEF		; D0 <-- X et D1 <-- Y	JUMP',EQ 25$	CALL	SELPRECT4X7	; slectionne un rectangle 4 x 7 ?	JUMP,NE 15$	JUMP	05$25$:	LOAD.W	D2,#-1		; D2 <-- dernire coordonne X	LOAD.W	D3,D2		; D3 <-- dernire coordonne Y	LOAD.W	(A6)+OTDOP,#SETDOT	TEST.B	(A4)+(D1.W):D0	JUMP',BC 30$	LOAD.W	(A6)+OTDOP,#CLRDOT30$:	CALL	MOUDDEF		; D0 <-- X et D1 <-- Y	JUMP,NE 40$	COMP.W	D0,D2		; changement ?	JUMP',NE 32$		; oui => 32$	COMP.W	D1,D3		; non => 40$	JUMP',EQ 40$32$:	LOAD.W	D2,D0		; D2 <-- dernire coordonne X	LOAD.W	D3,D1		; D3 <-- dernire coordonne Y	COMP.W	(A6)+OTDOP,#SETDOT	JUMP',NE 35$	TSET.B	(A4)+(D1.W):D0	JUMP',BS 40$	CALL	DOTDDEF		; allume gros point	CALL	SHODDEF		; montre un trait rel	JUMP'	38$35$:	TCLR.B	(A4)+(D1.W):D0	JUMP',BC 40$	CALL	DOTDDEF		; teint gros point	CALL	SHODDEF		; montre un trait rel38$:	LOAD.W	D0,D6		; D0 <-- pinceau slectionn	PUSH.W	D2	LOAD.W	D2,#CLRDOT	CALL	DESDRECT4X7	; dessine le pinceau modifi	POP.W	D240$:	CALL	SCMO		; remet la souris	PUSH.L	D3	LIB	?GETKEY		; attend souris ...	LOAD.W	D1,D3	POP.L	D3	COMP.W	D1,#KEYMPO	; souris dplace ?	JUMP,EQ	30$		; oui => 30$	COMP.W	D1,#KEYMGR	JUMP,EQ	10$	COMP.W	D1,#KEYMMR	; bouton relach ?	JUMP,EQ	10$		; oui => 10$	COMP.W	D1,#KEYMDR	JUMP,EQ	10$	JUMP	40$50$:				; EFFACE =>	LOAD.L	(A4)+0,#DEFTR0	LOAD.L	(A4)+4,#DEFTR4	LOAD.W	(A4)+8,#DEFTR8	CALL	ALLDDEF	JUMP'	70$60$:				; [+] =>	COMP.B	(A4)+8+1,#9	; trop grand ?	JUMP,EQ	15$		; oui => 15$	INC.B	(A4)+8+1	; non => augmente	CALL	SHODPAS		; montre le pas	CALL	SHODDEF		; montre le trait rel	JUMP'	70$65$:				; [-] =>	COMP.B	(A4)+8+1,#1	; trop petit ?	JUMP,EQ	15$		; oui => 15$	DEC.B	(A4)+8+1	; non => diminue	CALL	SHODPAS		; montre le pas	CALL	SHODDEF		; montre le trait rel70$:	LOAD.W	D0,D6		; D0 <-- pinceau slectionn	LOAD.W	D2,#CLRDOT	CALL	DESDRECT4X7	; dessine le pinceau modifi	JUMP	10$80$:				; D'ACCORD =>	LOAD.L	(A6)+OMODE,D4	LOAD.W	(A6)+OSELEC,D6	LOAD.L	A4,(A6)+OPOBJ	LOAD.L	A3,#(A6)+OBUFF	LOAD.W	D4,#(((8+2)*MAMAX)/4)-182$:	LOAD.L	(A4+),(A3+)	; objets <-- OBUFF	DECJ.W,NMO D4,82$85$:				; ANNULE =>	DBOX_	CLOSE		; ferme la DBOX90$:	CALL	CLOVAR		; libre les variables99$:	POPM.L	D0,D1,D5,D6,A0..A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; OPEDDEF >;--------/; Ouvre la DBOX pour dfinir le pinceau.; in	-; out	D4.L	fanions;	D5.L	canal;	D6.W	pinceau slectionn;	A2.L	^table de la dbox;	A5.L	^table des pinceaux;	D7.W	erreur; mod	D4.L, D5.L, D6.L, D7.W, A5.LOPEDDEF:	PUSHM.L	D0..D3,A3	LOAD.L	A2,#R16"TDBOX_DDEF0	LOAD.L	A3,(A6)+OPTEXT	TEST.B	(A3)		; 3 textes existent ?	JUMP',NE 10$		; oui => 10$	LOAD.L	A2,#R16"TDBOX_DDEF110$:	LOAD.L	D1,(A6)+OMODE	; D1 <-- mode/fanions	LOAD.W	D2,D1		; D2 <-- mode d'ouverture	LOAD.L	D4,D1		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A5,#R16"00$	CALL	OPEAFTEXT	; affiche les 3 textes	LOAD.L	A5,#(A6)+OBUFF	; A5 <-- ^table des trames	LOAD.W	D6,(A6)+OSELEC	; D6 <-- trame slectionne	LIB	?GETDIM		; D3 <-- dim caractre	LOAD.L	D4,D3	SWAP.W	D4		; D4 <-- hauteur	SL.W	D3,#1		; D3 <-- largeur *2	COMP.W	D3,D4	JUMP',LS 20$	LOAD.W	D3,D4		; D3 <-- le plus petit20$:	LOAD.W	(A6)+OTDLG,D3	CALL	ALLRECT4X7	; dessine les rectangles 4 x 7	CLR.W	D030$:	LOAD.W	D2,#SETDOT	CALL	DESDRECT4X7	; dessine les pinceaux rels	INC.W	D0	COMP.W	D0,#MAMAX	JUMP,LO 30$	LOAD.W	D2,(A6)+OTDLG	LOAD.W	D3,D2	MUL.WU	D3,#1+8+2	SUB.W	D3,#2		; D3 <-- X	SWAP.W	D3	LOAD.W	D3,D2	SUB.W	D3,#2		; D3 <-- Y	SWAP.W	D3	SL.W	D2,#3	ADD.W	D2,#2	LOAD.W	D4,D2		; D4 <-- dY	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- dX	LOAD.W	D2,#SETDOT	; D2 <-- mode	CALL	DRRECT		; dessine rectangle gauche	LOAD.W	D2,(A6)+OTDLG	MUL.WU	D2,#1+8+2+8+2	SUB.W	D2,#2	LOAD.W	D3,D2		; D3 <-- X	SWAP.W	D3	LOAD.W	D2,(A6)+OTDLG	MUL.WU	D2,#8-1	ADD.W	D3,D2		; D3 <-- Y	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,(A6)+OTDLG	ADD.W	D4,#2		; D4 <-- dY	SWAP.W	D4	LOAD.W	D2,#SETDOT	; D2 <-- mode	CALL	DRRECT		; dessine rectangle droite	LOAD.L	D4,D1		; D4 <-- fanions90$:	POPM.L	D0..D3,A3	TEST.W	D7		; retour EQ/NE	RET00$:	.W	5,6,9;--------\\; MOUDDEF >;--------/; Lit la position de la souris dans le rectangle gauche / droite.; in	-; out	D0.W	coordonne X (0..7);	D1.W	coordonne Y (0..8);	D7.W	erreur; mod	D0.L, D1.L, D4.LMOUDDEF:	PUSHM.L	D2..D5	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 90$	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	SUB.W	D4,(A0)+ODFFX	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A6)+OTDLG	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D0	LOAD.W	D0,D4	DIV.WU	D0,(A6)+OTDLG	; D0 <-- coordonne X (0..n)	SUB.W	D0,#8+2	JUMP',LO 90$	COMP.W	D0,#8		; dans rectangle gauche (0..7) ?	JUMP',LO 50$		; oui => 50$	SUB.W	D0,#2		; D0 <-- enlve espace entre 2 rect.	COMP.W	D0,#8	JUMP',LO 90$	COMP.W	D0,#16	JUMP',HS 90$		; D0 <-- coordonne X (8..15)50$:	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A6)+OTDLG	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D1	LOAD.W	D1,D4	DIV.WU	D1,(A6)+OTDLG	; D1 <-- coordonne Y (0..7)	COMP.W	D1,#8	JUMP',HS 90$	COMP.W	D0,#8		; dans rectangle droite ?	JUMP',LO 80$		; non => 80$				; oui =>	SUB.W	D0,#8		; D0 <-- coordonne X (0..7)	COMP.W	D1,#7	JUMP',NE 90$	INC.W	D1		; D1 <-- coordonne Y (8)	JUMP'	85$80$:	NOT.B	D0		; D0 <-- bits 7..0 !	AND.B	D0,#B'11185$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; ALLDDEF >;--------/; Dessine toute la matrice du pinceau.; in	A4.L	^pinceau; out	-; mod	D7.WALLDDEF:	PUSHM.L	D0,D1,D3	CLR.W	D010$:	CLR.W	D120$:	LOAD.W	(A6)+OTDOP,#SETDOT	TEST.B	(A4)+(D1.W):D0	JUMP',BS 30$	LOAD.W	(A6)+OTDOP,#CLRDOT30$:	CALL	DOTDDEF		; dessine un gros point	INC.W	D1	COMP.W	D1,#8+1	JUMP,LO	20$	INC.W	D0	COMP.W	D0,#8	JUMP,LO	10$	CALL	SHODPAS		; montre le pas	CALL	SHODDEF		; montre un trait rel	POPM.L	D0,D1,D3	RET;--------\\; DOTDDEF >;--------/; Dessine un point dans le rectangle gauche / droite.; in	D0.W	coordonne X (0..7);	D1.W	coordonne Y (0..8); out	-; mod	D7.WDOTDDEF:	PUSHM.L	D0,D1,D2,D3,D4	COMP.W	D1,#8		; dans rectangle droite ?	JUMP',EQ 20$		; oui => 20$				; non =>	NOT.B	D0		; D0 <-- bits 7..0 !	AND.B	D0,#B'111	JUMP'	30$20$:	ADD.W	D0,#8+2		; D0 <-- ajoute espace entre 2 rect.	LOAD.W	D1,#7		; D1 <-- coordonne Y rect. droite30$:	ADD.W	D0,#8+2	LOAD.W	D2,(A6)+OTDLG	MUL.WU	D0,D2	MUL.WU	D1,D2	LOAD.W	D3,D2	ADD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,D2	ADD.W	D3,D0	LOAD.W	D4,D2	DEC.W	D4	SWAP.W	D4	LOAD.W	D4,D2	DEC.W	D4	LOAD.W	D2,(A6)+OTDOP	; D2 <-- opration	CALL	DRZONE		; allume/teint un gros point	POPM.L	D0,D1,D2,D3,D4	RET;--------\\; SHODDEF >;--------/; Affiche le pinceau en dessus du rectangle de droite.; in	A4.L	^pinceau; out	-; mod	D7.WSHODDEF:	PUSHM.L	D1..D4	LOAD.W	D2,(A6)+OTDLG	MUL.WU	D2,#5	LOAD.W	D3,D2		; D3 <-- Y	SWAP.W	D3	LOAD.W	D2,(A6)+OTDLG	MUL.WU	D2,#1+8+2+8+2	LOAD.W	D3,D2		; D3 <-- X	CLR.W	D4		; D4 <-- dY	SWAP.W	D4	LOAD.W	D2,(A6)+OTDLG	SL.W	D2,#3	DEC.W	D2	LOAD.W	D4,D2		; D4 <-- dX	PUSHM.L	D3,D4	SUB.W	D3,#8/2	SWAP.W	D3	SUB.W	D3,#8/2	SWAP.W	D3	ADD.W	D4,#8	SWAP.W	D4	ADD.W	D4,#8	SWAP.W	D4	CALL	DRCLEAR		; efface le trait prcdent	POPM.L	D3,D4	CLR.W	D1	CALL	_DESSIN_DDEF	; dfinit le nouveau trait	COMP.W	D2,#-1	JUMP',EQ 90$	OR.W	D2,#SETDOT	CALL	DRLINE		; dessine le nouveau trait90$:	POPM.L	D1..D4	RET;--------\\; SHODPAS >;--------/; Affiche le nombre juste aprs Pas=.; in	D5.W	canal dbox;	A4.L	^pinceau; out	-; mod	D7.WSHODPAS:	PUSHM.L	D2,D3,D4	LOAD.W	D2,#2		; D2 <-- rang aprs "Pas="	DBOX_	GETCO		; D3 <-- coordonne dbut	LIB	?SETCURS	CLR.L	D4	LOAD.B	D4,(A4)+8+1	; D4 <-- chelle	LOAD.W	D3,#1		; D3 <-- nb digits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC		; affiche le nombre	POPM.L	D2,D3,D4	RET;--------------\\; _DESSIN_PEDIT >;==============/; Edite une table de 4x7 points quelconques.;; Table d'icnes en (A2):;	.B	USEGC,f,s,t;	.B	i1;	.B	i2;		etc.;	.B	0;	.EVEN;; Trois textes en (A3):;	.ASCIZ	"1..n";	.ASCIZ	"un seul";	.ASCIZ	"";	.EVEN;; Table des points en (A4):;	.B	B'00000000	;;	.B	B'00011100	;;	.B	B'00100010	;;	.B	B'01000001	;;	.B	B'01000001	; un point;	.B	B'01000001	;;	.B	B'00100010	;;	.B	B'00011100	;;	etc.; in	D2.L	flags divers;	D4.W	trame slectionne;	A0.L	^descripteur de la fentre;	A2.L	^table d'icnes (si BMAICO dans D2.L);	A3.L	^trois textes;	A4.L	^table des 4x7 points (1x7 points si BMAICO dans D2.L); out	D2.L	flags divers;	D3.L	d'accord/annule (F1/F0);	D4.W	trame slectionne;	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W_DESSIN_PEDIT:	PUSHM.L	D0,D1,D5,D6,A0..A6	TCLR.L	D2:#BMATR	TCLR.L	D2:#BMADR	TSET.L	D2:#BMAPT	CALL	OPEVAR		; A6 <-- ^variables	JUMP,NE 99$	CALL	OPEPDEF		; ouvre la DBOX	JUMP,NE	90$	LOAD.W	D0,D6	CALL	INVRECT4X7	; montre le point slectionn05$:	LOAD.L	A4,A5		; A4 <-- ^table des points	LOAD.W	D1,D6	MUL.WU	D1,#8	ADD.L	A4,D1		; A4 <-- ^bon point	CALL	ALLPDEF		; montre le point actuel	LOAD.W	D0,D610$:	CALL	SCMO		; remet la souris	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_PDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ	80$	COMP.W	D3,#F0	JUMP,EQ	85$	COMP.W	D3,#DEL	JUMP,EQ	50$	COMP.W	D3,#KEYMGP	JUMP',EQ 20$	COMP.W	D3,#KEYMMP	JUMP',EQ 20$	COMP.W	D3,#KEYMDP	JUMP',EQ 20$	COMP.W	D3,#KEYMGR	JUMP,EQ	10$	COMP.W	D3,#KEYMMR	JUMP,EQ	10$	COMP.W	D3,#KEYMDR	JUMP,EQ	10$15$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	10$20$:	CALL	MOUPDEF		; D0 <-- X et D1 <-- Y	JUMP',EQ 25$	CALL	SELTRECT4X7	; slectionne un rectangle 4 x 7 ?	JUMP,NE 15$	JUMP	05$25$:	LOAD.W	D2,#-1		; D2 <-- dernire coordonne X	LOAD.W	D3,D2		; D3 <-- dernire coordonne Y	LOAD.W	(A6)+OTDOP,#SETDOT	TEST.B	(A4)+(D1.W):D0	JUMP',BC 30$	LOAD.W	(A6)+OTDOP,#CLRDOT30$:	CALL	MOUPDEF		; D0 <-- X et D1 <-- Y	JUMP,NE 40$	COMP.W	D0,D2		; changement ?	JUMP',NE 32$		; oui => 32$	COMP.W	D1,D3		; non => 40$	JUMP',EQ 40$32$:	LOAD.W	D2,D0		; D2 <-- dernire coordonne X	LOAD.W	D3,D1		; D3 <-- dernire coordonne Y	COMP.W	(A6)+OTDOP,#SETDOT	JUMP',NE 35$	TSET.B	(A4)+(D1.W):D0	JUMP',BS 40$	CALL	DOTPDEF		; allume gros point	JUMP'	38$35$:	TCLR.B	(A4)+(D1.W):D0	JUMP',BC 40$	CALL	DOTPDEF		; teint gros point38$:	LOAD.W	D0,D6		; D0 <-- point slectionn	PUSH.W	D2	LOAD.W	D2,#CLRDOT	CALL	DESPRECT4X7	; dessine le point modifi	POP.W	D240$:	CALL	SCMO		; remet la souris	PUSH.L	D3	LIB	?GETKEY		; attend souris ...	LOAD.W	D1,D3	POP.L	D3	COMP.W	D1,#KEYMPO	; souris dplace ?	JUMP,EQ	30$		; oui => 30$	COMP.W	D1,#KEYMGR	JUMP,EQ	10$	COMP.W	D1,#KEYMMR	; bouton relach ?	JUMP,EQ	10$		; oui => 10$	COMP.W	D1,#KEYMDR	JUMP,EQ	10$	JUMP	40$50$:				; EFFACE =>	CLR.L	(A4)+0	CLR.L	(A4)+4	CALL	ALLPDEF	LOAD.W	D0,D6		; D0 <-- point slectionn	LOAD.W	D2,#CLRDOT	CALL	DESPRECT4X7	; dessine le point modifi	JUMP	10$80$:				; D'ACCORD =>	LOAD.L	(A6)+OMODE,D4	LOAD.W	(A6)+OSELEC,D6	LOAD.L	A4,(A6)+OPOBJ	LOAD.L	A3,#(A6)+OBUFF	LOAD.W	D4,#((8*MAMAX)/4)-182$:	LOAD.L	(A4+),(A3+)	; objets <-- OBUFF	DECJ.W,NMO D4,82$85$:				; ANNULE =>	DBOX_	CLOSE		; ferme la DBOX90$:	CALL	CLOVAR		; libre les variables99$:	POPM.L	D0,D1,D5,D6,A0..A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; OPEPDEF >;--------/; Ouvre la DBOX pour dfinir le point.; in	-; out	D4.L	fanions;	D5.L	canal;	D6.W	point slectionn;	A2.L	^table de la dbox;	A5.L	^table des points;	D7.W	erreur; mod	D4.L, D5.L, D6.L, D7.W, A5.LOPEPDEF:	PUSHM.L	D0..D3,A3	LOAD.L	A2,#R16"TDBOX_PDEF0	LOAD.L	A3,(A6)+OPTEXT	TEST.B	(A3)		; 3 textes existent ?	JUMP',NE 10$		; oui => 10$	LOAD.L	A2,#R16"TDBOX_PDEF110$:	LOAD.L	D1,(A6)+OMODE	; D1 <-- mode/fanions	LOAD.W	D2,D1		; D2 <-- mode d'ouverture	LOAD.L	D4,D1		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A5,#R16"00$	CALL	OPEAFTEXT	; affiche les 3 textes	LOAD.L	A5,#(A6)+OBUFF	; A5 <-- ^table des trames	LOAD.W	D6,(A6)+OSELEC	; D6 <-- trame slectionne	LIB	?GETDIM		; D3 <-- dim caractre	LOAD.L	D4,D3	SWAP.W	D4		; D4 <-- hauteur	SL.W	D3,#1		; D3 <-- largeur *2	COMP.W	D3,D4	JUMP',LS 20$	LOAD.W	D3,D4		; D3 <-- le plus petit20$:	LOAD.W	(A6)+OTDLG,D3	CALL	ALLRECT4X7	; dessine les rectangles 4 x 7	CLR.W	D030$:	LOAD.W	D2,#SETDOT	CALL	DESPRECT4X7	; dessine les points rels	INC.W	D0	COMP.W	D0,#MAMAX	JUMP,LO 30$	LOAD.W	D2,(A6)+OTDLG	LOAD.W	D3,D2	MUL.WU	D3,#1+8+2	SUB.W	D3,#2		; D3 <-- X	SWAP.W	D3	LOAD.W	D3,D2	SUB.W	D3,#2		; D3 <-- Y	SWAP.W	D3	SL.W	D2,#3	ADD.W	D2,#2	LOAD.W	D4,D2		; D4 <-- dY	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- dX	LOAD.W	D2,#SETDOT	; D2 <-- mode	CALL	DRRECT		; dessine rectangle gauche	LOAD.L	D4,D1		; D4 <-- fanions90$:	POPM.L	D0..D3,A3	TEST.W	D7		; retour EQ/NE	RET00$:	.W	1,2,5;--------\\; MOUPDEF >;--------/; Lit la position de la souris.; in	-; out	D0.W	coordonne X (0..7);	D1.W	coordonne Y (0..7);	D7.W	erreur; mod	D0.L, D1.L, D4.LMOUPDEF:	CALL	MOUTDEF	JUMP',NE 90$	SUB.W	D0,#7	NEG.W	D090$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; ALLPDEF >;--------/; Dessine tout le point.; in	A4.L	^point; out	-; mod	D7.WALLPDEF:	PUSHM.L	D0,D1,D3	CLR.W	D010$:	CLR.W	D120$:	LOAD.W	(A6)+OTDOP,#SETDOT	TEST.B	(A4)+(D1.W):D0	JUMP',BS 30$	LOAD.W	(A6)+OTDOP,#CLRDOT30$:	CALL	DOTPDEF		; dessine un gros point	INC.W	D1	COMP.W	D1,#8	JUMP,LO	20$	INC.W	D0	COMP.W	D0,#8	JUMP,LO	10$	POPM.L	D0,D1,D3	RET;--------\\; DOTPDEF >;--------/; Dessine un point dans le rectangle de gauche.; in	D0.W	coordonne X (0..7);	D1.W	coordonne Y (0..7); out	-; mod	D7.WDOTPDEF:	PUSH.W	D0	SUB.W	D0,#7	NEG.W	D0	CALL	DOTTDEF	POP.W	D0	RET;------------\\; SELTRECT4X7 >;------------/; Slectionne une nouvelle trame 4 x 7.; in	D6.W	rectangle slectionn (0..n); out	D6.W	nouveau rectangle (0..n);	D7.W	erreur; mod	D6.L, D7.WSELTRECT4X7:	PUSHM.L	D0,D3,D4	CALL	DETRECT4X7	; est-on dans un rectangle ?	JUMP',NE 90$		; non => 90$	EX.L	D0,D6	CALL	INVRECT4X7	; efface l'ancien	LOAD.W	D0,D6	CALL	INVRECT4X7	; allume le nouveau10$:	CALL	SCMO		; remet la souris	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE 80$		; non => 80$	CALL	DETRECT4X7	; D0 <-- rectangle o est la souris	JUMP,NE 10$	COMP.W	D0,D6		; toujours dans le mme ?	JUMP,EQ 10$		; oui => 10$				; non =>	EX.L	D0,D6	CALL	INVRECT4X7	; efface l'ancien	LOAD.W	D0,D6	CALL	INVRECT4X7	; allume le nouveau	JUMP	10$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D3,D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; SELPRECT4X7 >;------------/; Slectionne un nouveau pinceau 4 x 7.; in	D6.W	rectangle slectionn (0..n); out	D6.W	nouveau rectangle (0..n);	D7.W	erreur; mod	D6.L, D7.WSELPRECT4X7:	PUSHM.L	D0,D3,D4	CALL	DETRECT4X7	; est-on dans un rectangle ?	JUMP',NE 90$		; non => 90$	EX.L	D0,D6	CALL	INVRECT4X7	; efface l'ancien	LOAD.W	D0,D6	CALL	INVRECT4X7	; allume le nouveau10$:	CALL	SCMO		; remet la souris	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE 80$		; non => 80$	CALL	DETRECT4X7	; D0 <-- rectangle o est la souris	JUMP,NE 10$	COMP.W	D0,D6		; toujours dans le mme ?	JUMP,EQ 10$		; oui => 10$				; non =>	EX.L	D0,D6	CALL	INVRECT4X7	; efface l'ancien	LOAD.W	D0,D6	CALL	INVRECT4X7	; allume le nouveau	JUMP	10$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D3,D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DETRECT4X7 >;-----------/; Dtecte dans quel rectangle 4 x 7 est la souris.; in	-; out	D0.W	rectangle (0..n);	D7.W	erreur; mod	D0.L, D7.WDETRECT4X7:	PUSHM.L	D1..D4	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 90$	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	SUB.W	D4,(A0)+ODFFX	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A6)+OTDLG	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D0	LOAD.W	D0,D4	DIV.WU	D0,(A6)+OTDLG	; D0 <-- coordonne X	SR.W	D0,#1	COMP.W	D0,#4	JUMP',HS 90$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A6)+OTDLG	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D1	LOAD.W	D1,D4	DIV.WU	D1,(A6)+OTDLG	; D1 <-- coordonne Y	SR.W	D1,#1	COMP.W	D1,#7	JUMP',HS 90$	TEST.B	(A6)+OMODE+1:#BMAICO ; icnes et seulement 7 trames ?	JUMP',BS 60$		; oui => 60$	MUL.WU	D1,#4	ADD.W	D0,D1		; D0 <-- no du rectangle	JUMP'	80$60$:	TEST.W	D0		; coordonne X = zro ?	JUMP',NE 90$		; non => 90$	LOAD.W	D0,D1		; D0 <-- coordonne Y80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; INVRECT4X7 >;-----------/; Inverse un rectangle 4 x 7.; in	D0.W	no du rectangle (0..n); out	-; mod	D7.WINVRECT4X7:	PUSHM.L	D2..D4	CALL	POSRECT4X7	JUMP',NE 90$	PUSHM.L	D3,D4	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#3	SWAP.W	D4	ADD.W	D4,#3	SWAP.W	D4	CALL	DRINV		; inverse un rectangle	POPM.L	D3,D4	TEST.B	(A6)+OMODE+0:#BMATR ; dite les trames ?	JUMP',BC 90$		; non => 90$				; oui =>	ADD.W	D3,#4	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	SUB.W	D4,#(4*2)-1	SWAP.W	D4	SUB.W	D4,#(4*2)-1	SWAP.W	D4	CALL	DRINV		; inverse l'emplacement90$:	POPM.L	D2..D4	RET;------------\\; DESTRECT4X7 >;------------/; Dessine une trame dans un rectangle 4 x 7.; in	D0.W	numro du rectangle; out	-; mod	D7.WDESTRECT4X7:	PUSHM.L	D2..D4,A4	CALL	POSRECT4X7	JUMP,NE 90$	ADD.W	D3,#4	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	SUB.W	D4,#(4*2)-1	SWAP.W	D4	SUB.W	D4,#(4*2)-1	SWAP.W	D4	PUSHM.L	D3,D4	LOAD.L	A4,A5		; A4 <-- ^table des trames	LOAD.W	D4,D0	MUL.WU	D4,#8	ADD.L	A4,D4		; A4 <-- ^bonne trame	LOAD.L	D3,(A4)+0	LOAD.L	D4,(A4)+4	CALL	DRTRADEF	; dfinit la bonne trame	POPM.L	D3,D4	LOAD.W	D2,#LOADDOT	CALL	DRTRAME		; dessine la bonne trame90$:	POPM.L	D2..D4,A4	RET;------------\\; DESDRECT4X7 >;------------/; Dessine un pinceau dans un rectangle 4 x 7.; in	D0.W	numro du rectangle;	D2.W	mode; out	-; mod	D7.WDESDRECT4X7:	PUSHM.L	D1..D4,A4	LOAD.W	D1,D2		; D1 <-- mode	CALL	POSRECT4X7	JUMP,NE 90$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	COMP.W	D1,#CLRDOT	JUMP',EQ 40$	CALL	DRCLEAR		; efface l'emplacement	JUMP	45$40$:	CALL	DRSET		; allume l'emplacement45$:	PUSH.W	D1	LOAD.L	A4,A5		; A4 <-- ^table des pinceaux	LOAD.W	D1,D0	CALL	_DESSIN_DDEF	; dfinit le bon pinceau	POP.W	D1	ADD.W	D3,#(8/2)+1	SUB.W	D4,#8+1	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#(8/2)+0	SUB.W	D4,#8+1	ADD.W	D3,D4		; droite dans le sens "/"	NEG.W	D4	SWAP.W	D3	SWAP.W	D4	COMP.W	D2,#-1	JUMP',EQ 90$	OR.W	D2,D1	CALL	DRLINE		; dessine le trait90$:	POPM.L	D1..D4,A4	RET;------------\\; DESPRECT4X7 >;------------/; Dessine un point dans un rectangle 4 x 7.; in	D0.W	numro du point;	D2.W	mode; out	-; mod	D7.WDESPRECT4X7:	PUSHM.L	D1..D4,A4	LOAD.W	D1,D2		; D1 <-- mode	CALL	POSRECT4X7	JUMP,NE 90$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	COMP.W	D1,#CLRDOT	JUMP',EQ 40$	CALL	DRCLEAR		; efface l'emplacement	JUMP	45$40$:	CALL	DRSET		; allume l'emplacement45$:	PUSH.W	D1	LOAD.L	A4,A5		; A4 <-- ^table des points	LOAD.W	D1,D0	CALL	_DESSIN_PDEF	; dfinit le bon point	POP.W	D1	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	COMP.W	D2,#-1	JUMP',EQ 90$	OR.W	D2,D1	CALL	DRDOT		; dessine le point90$:	POPM.L	D1..D4,A4	RET;-----------\\; POSRECT4X7 >;-----------/; Donne la position et les dimensions d'un rectangle 4 x 7.; in	D0.W	no du rectangle (0..n); out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WPOSRECT4X7:	PUSHM.L	D0,D1	LOAD.W	D7,#1		; D7 <-- erreur	TEST.B	(A6)+OMODE+1:#BMAICO ; icnes et seulement 7 trames ?	JUMP',BS 10$		; oui => 10$	COMP.W	D0,#MAMAX	JUMP,HS 90$	AND.L	D0,#H'FFFF	DIV.WU	D0,#4	LOAD.W	D1,D0		; D1 <-- Y	SWAP.W	D0		; D0 <-- X	JUMP'	20$10$:	COMP.W	D0,#MAMAX/4	JUMP,HS 90$	LOAD.W	D1,D0		; D1 <-- Y	CLR.W	D0		; D0 <-- X20$:	LOAD.W	D4,(A6)+OTDLG	SL.W	D4,#1	SWAP.W	D4	LOAD.W	D4,(A6)+OTDLG	SL.W	D4,#1	MUL.WU	D1,D4	ADD.W	D1,(A6)+OTDLG	MUL.WU	D0,D4	ADD.W	D0,(A6)+OTDLG	LOAD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,D0	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ALLRECT4X7 >;-----------/; Dessine les 4 x 7 rectangles pour entourer la palette; de trames ou de pinceaux.; in	-; out	-; mod	D7.WALLRECT4X7:	PUSHM.L	D0..D4,A2..A4	CLR.W	D0	TEST.B	(A6)+OMODE+1:#BMAICO ; icnes et seulement 7 trames ?	JUMP',BC 10$		; non => 10$				; oui =>	INC.W	D0	LOAD.L	A4,(A6)+OPICO	; A4 <-- ^liste des icnes	ADD.L	A4,#4		; A4 <-- saute 4 bytes (USEGC,f,s,t)10$:	LOAD.W	D2,(A6)+OTDLG	LOAD.W	D3,D2		; D3 <-- Y	SWAP.W	D3	LOAD.W	D3,D2		; D3 <-- X	LOAD.W	D4,D2	SL.W	D4,#1		; D4 <-- dY	SWAP.W	D4	LOAD.W	D4,D2	SL.W	D4,#1		; D4 <-- dX	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	LOAD.W	D1,#7		; D1 <-- compteur vertical30$:	PUSHM.L	D1,D3,D4	TEST.W	D0	JUMP',NE 40$	LOAD.W	D1,#4		; D1 <-- compteur horizontal35$:	CALL	DRRECT		; dessine rectangle autour d'une trame	ADD.W	D3,D4		; D3 <-- X suivant	DEC.W	D1	JUMP,NE 35$	JUMP	50$40$:	CALL	DRRECT		; dessine rectangle autour d'une trame	TEST.B	(A4)	JUMP,EQ 50$	ADD.W	D3,D4	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#2	ADD.W	D3,D4	ADD.W	D3,D4	ADD.W	D3,D4	SWAP.W	D4	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A2,(A6)+OPICO	LOAD.L	(A3+),(A2)	LOAD.B	(A3+),#AFTOUT	LOAD.B	(A3+),(A4+)	LOAD.B	(A3+),#AFNORM	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),(A0)+ODFGCF	LOAD.B	(A3+),(A0)+ODFGCS	LOAD.B	(A3+),(A0)+ODFGCT	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS	SUB.L	D3,A3	LIB	?STRING		; affiche l'icne50$:	POPM.L	D1,D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- Y suivant	SWAP.W	D4	SWAP.W	D3	DEC.W	D1	JUMP,NE 30$	POPM.L	D0..D4,A2..A4	RET;----------\\; OPEAFTEXT >;==========/; Affiche les 3 textes dans la dbox.; in	D5.L	canal dbox;	A3.L	^trois textes;	A5.L	^rangs; out	-; mod	D7.WOPEAFTEXT:	PUSHM.L	D1..D4,A3,A5	LOAD.W	D1,#3-120$:	TEST.B	(A3)		; texte existe ?	JUMP',EQ 90$		; non => 90$				; oui =>	LOAD.W	D2,(A5+)	; D2 <-- rang	DBOX_	GETCO		; D3/D4 <-- coordonnes	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	; D3 <-- saute le cercle	ADD.W	D3,(A0)+ODFCX	LIB	?SETCURS	; positionne le curseur	LIB	?AFTEXT		; affiche le texte	DECJ.W,NMO D1,20$90$:	POPM.L	D1..D4,A3,A5	RET	.END