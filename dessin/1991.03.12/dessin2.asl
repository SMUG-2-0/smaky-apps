	.TITLE	DESSIN2.ASL;	--------------------------------------;		(C) 1988 - Daniel Roux;	--------------------------------------;	Source du module SMA_DESSIN2.LIB;	Date		Amliorations; --------------------------------------------------------------------------; 1.1	01.12.89	collection de trames corrige; 1.0	17.03.88	premire version distribue	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcima	.REF	SMAKY	.REF	MODULES	.REF	DOLIB	.REV	1,1; Constantes; ----------KEYICO	=	H'7E00		; "touche" spciale icne; Variables pour DESS2_LISSE/TRAME; --------------------------------	.LOC	0OOPPTS:	.BLKB	4		; source: ^bitmapOOPDIS:	.BLKB	4		; source: dimensions bitmapOOPIYS:	.BLKB	2		; source: IyOOPORS:	.BLKB	4		; source: origineOOPPTD:	.BLKB	4		; destination: ^bitmapOOPDID:	.BLKB	4		; destination: dimensions bitmapOOPIYD:	.BLKB	2		; destination: IyOOPORD:	.BLKB	4		; destination: origineOOPDIM:	.BLKB	4		; dimensionsOOPMOD:	.BLKB	4		; modeOOPMAX:	.BLKB	2		; lisse: nb maxOOPPTR:	.BLKB	4		; trame: ^trames (16+1 x 8 bytes)OOPRGC:	.BLKB	4		; relief: gencar  utiliserOOPRLG:	.BLKB	2		; relief: dimension d'un pointOOPROP:	.BLKB	1		; relief: opration (0..2)	.EVENOOPRAS:	.BLKB	4		; ^routine GRA_RASTEROOPCDB:	.BLKB	4		; wait: canal dbox waitOOPASC:	.BLKB	LSCVAR		; wait: ascenseurOOPDIV:	.BLKB	2		; wait: facteur de divisionOOPCSK:	.BLKB	4		; wait: canal soft-keysLGVOP:; Dfinitions d'une opration relief; ----------------------------------	.LOC	0ORELSET:.BLKB	8		; matrice  allumerORELCLR:.BLKB	8		; matrice  teindreORELX:	.BLKB	1		; flagx (1x, 2x ou 4x)	.BLKB	1LREL:; En-tte du module LIB; ---------------------	.LOC	0	DESS2_	FIRST		; code du premier appel	DESS2_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	1,1		; rvision.version	.W	0,END_DESSIN2	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"DESSIN2"	; nom du module	.FILLB	(LGHLIB-.),0	.W	_DESS2_LISSE	.W	_DESS2_TRAME	.W	_DESS2_TGET	.W	_DESS2_RELIEF	.W	_DESS2_RGET	.W	_DESS2_REDIT	.W	_DESS2_RCAR; Gestion des variables; ---------------------;--------\\; OPEVOP  >;========/; Ouvre les variables.; in	?	voir DESS2_LISSE; out	A6.L	^variables;	D7.W	erreur; mod	D7.W, A6.LOPEVOP:	PUSHM.L	D1,D4,A4	LOAD.L	D4,#LGVOP	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP',EQ 20$	POPM.L	D1,D4,A4	RET20$:	LOAD.L	A6,A4		; A6 <-- ^variables	SR.W	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMO30$:	CLR.W	(A4+)		; met toutes les variables  zro !	DECJ.W,NMO D4,30$	POPM.L	D1,D4,A4	PUSHM.L	D3,D5,D6,A3	LOAD.L	(A6)+OOPPTS,A3	; OOPPTS <-- ^bitmap source	LOAD.L	(A6)+OOPDIS,D5	; OOPDIS <-- dimensions bitmap	ADD.W	D5,#8-1	SR.W	D5,#3	LOAD.W	(A6)+OOPIYS,D5	; OOPIYS <-- Iy bitmap source	LOAD.L	(A6)+OOPORS,D3	; OOPORS <-- origine source	LOAD.L	(A6)+OOPPTD,A4	; OOPPTD <-- ^bitmap destination	LOAD.L	(A6)+OOPDID,D6	; OOPDID <-- dimensions bitmap	ADD.W	D6,#8-1	SR.W	D6,#3	LOAD.W	(A6)+OOPIYD,D6	; OOPIYD <-- Iy bitmap destination	LOAD.L	(A6)+OOPORD,D4	; OOPORD <-- origine destination	LOAD.L	(A6)+OOPDIM,D2	; OOPDIM <-- dimensions	LOAD.L	(A6)+OOPMOD,D1	; OOPMOD <-- mode	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP',NE 90$	LOAD.L	(A6)+OOPRAS,A3	; OOPRAS <-- ^routine GRA_RASTER90$:	POPM.L	D3,D5,D6,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOVOP  >;========/; Ferme les variables.; in	A6.L	^variables; out	-; mod	-CLOVOP:	PUSHM.L	D1,D7,A4	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POPM.L	D1,D7,A4	RET	.INS	DESS2EDIT.ASI	.INS	DESS2LISSE.ASI	.INS	DESS2TRAME.ASI	.INS	DESS2RELIEF.ASI	.INS	DESS2DBOX.ASI	.INS	DESS2TABLE.ASIEND_DESSIN2:	.END