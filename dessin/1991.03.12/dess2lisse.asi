	.SBTTL	DESS2LISSE;-------------\\; _DESS2_LISSE >;=============/; Transfert une zone rectangulaire source dans une zone rectangulaire destination; de mmes dimensions, en effectuant un lissage.; in	A0.L	^descripteur de la fentre;	----;	A3.L	^bitmap source;	D5.L	dimensions bitmap (dy;dx);	D3.L	origine source (y;x);	----;	A4.L	^bitmap destination;	D6.L	dimensions bitmap (dy;dx);	D4.L	origine destination (y;x);	----;	D2.L	dimensions (dy;dx);	D1.L	mode: | bits | luminosit | bits | pas |;		 luminosit: -127..+127;		 pas: 2..10;	----; out	D7.W	erreur; mod	D7.W_DESS2_LISSE:	PUSHM.L	D0..D5,A4,A6	CALL	OPEVOP		; A6 <-- ^variables	JUMP,NE 90$	LOAD.L	D3,(A6)+OOPORS	; D3 <-- origine source	LOAD.L	D2,(A6)+OOPORD	; D2 <-- origine destination	CLR.L	D4	LOAD.B	D4,(A6)+OOPMOD+3 ; D4 <-- pas	SWAP.W	D4	LOAD.B	D4,(A6)+OOPMOD+3 ; D4 <-- pas	LOAD.L	D5,(A6)+OOPDIM	; D5 <-- dimensions	CALL	LISSEAJ		; D1 <-- nb max	LOAD.W	(A6)+OOPMAX,D1	; OOPMAX <-- nb max possible	LOAD.L	D0,D5	SWAP.W	D0		; D0 <-- hauteur	COMP.W	D0,#50	JUMP',LO 20$	CALL	WAITDBOX	; met la dbox d'attente20$:	CALL	AFFNDBOX	; mj la dbox d'attente	DEC.W	D0	PUSHM.L	D2,D3,D522$:	CALL	LISSENB		; D1 <-- nb de points contenus	CALL	LISSETR		; lisse en consquence	INC.W	D2		; D2 <-- point suivant en X	INC.W	D3		; D3 <-- point suivant en X	DEC.W	D5	JUMP,GT 22$	POPM.L	D2,D3,D5	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	INC.W	D2		; D2 <-- point suivant en Y	INC.W	D3		; D3 <-- point suivant en Y	DEC.W	D5	PUSH.W	F	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	POP.W	F	JUMP,GT 20$	CALL	NORMDBOX	; enlve la dbox d'attente	CLR.W	D7		; D7 <-- ok80$:	CALL	CLOVOP		; libre les variables90$:	POPM.L	D0..D5,A4,A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; LISSEAJ >;--------/; Calibre le nombre de points maximal pouvant tre contenu.; in	D4.L	dimensions o compter (dy;dx); out	D1.W	nb max de points contenus; mod	D1.L, D7.WLISSEAJ:	LOAD.L	D1,D4	SWAP.W	D1	MUL.WU	D1,D4		; D1 <-- dx * dy	RET.IF 0	PUSHM.L	D3,A3	PUSH.L	(A6)+OOPPTS	PUSH.W	(A6)+OOPIYS	LOAD.L	A3,#R16"00$	LOAD.L	(A6)+OOPPTS,A3	; OOPPTS <-- ^bitmap spcial rempli de 1	LOAD.W	(A6)+OOPIYS,#2	; OOPIYS <-- Iy bitmap spcial	CLR.L	D3	CALL	LISSENB		; D1 <-- nb de points contenus	POP.W	(A6)+OOPIYS	POP.L	(A6)+OOPPTS	POPM.L	D3,A3	RET00$:				; bitmap spcial pour calibrage :	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.B	B'11111111,B'11111111	.EVEN.ENDIF;--------\\; LISSENB >;--------/; Compte le nombre de points contenus dans une zone carre du bitmap source.; in	D3.L	coordonne (y;x);	D4.L	dimensions o compter (dy;dx); out	D1.W	nb de points contenus (0..dx*dy); mod	D1.L, D7.WLISSENB:	PUSHM.L	D0,D2..D6,A1	LOAD.L	A1,(A6)+OOPPTS	; A1 <-- ^bitmap source	LOAD.L	D1,D3		; D3 <-- position en X	SWAP.W	D1		; D1 <-- position en Y	MUL.WU	D1,(A6)+OOPIYS	ADD.L	A1,D1	LOAD.B	D2,D3	NOT.B	D2		; D2 <-- bit 2^7  gauche !	AND.B	D2,#B'111	; D2 <-- no du bit dans le byte	LOAD.W	D1,D3	SR.W	D1,#3	ADD.W	A1,D1		; A1 <-- ^byte	CLR.W	D1		; D1 <-- nb de points contenus	CLR.L	D3		; D3 <-- Yrel et Xrel initial20$:	PUSHM.L	D2,D3,D4,A1	DEC.W	D4		; D4 <--  cause NMO	LOAD.B	D0,(A1+)30$:	TEST.L	D0:D2		; point allum ?	JUMP',BC 40$		; non => 40$				; oui =>;;?	LOAD.L	D5,D3;;?	SWAP.W	D5;;?	COMP.W	D5,D3;;?	JUMP',LS 34$;;?	LOAD.W	D5,D3		; D5 <-- MIN(Xrel,Yrel);;?34$:;;?	INC.W	D5		; D5 <-- 1..n	INC.W	D1		; D1 <-- un point de plus40$:	DEC.B	D2	JUMP',NC 42$	LOAD.B	D2,#7	LOAD.B	D0,(A1+)42$:	INC.W	D3		; D3 <-- Xrel suivant	DECJ.W,NMO D4,30$	POPM.L	D2,D3,D4,A1	SWAP.W	D3	INC.W	D3		; D3 <-- Yrel suivant	SWAP.W	D3	ADD.W	A1,(A6)+OOPIYS	; A1 <-- ^byte en dessous	SWAP.W	D4	DEC.W	D4	LOAD.W	D0,D4	SWAP.W	D4	TEST.W	D0	JUMP,NE 20$	POPM.L	D0,D2..D6,A1	RET;--------\\; LISSETR >;--------/; Lisse quelques points dans une zone carre.; in	D1.W	nb de points contenus;	D2.L	coordonne (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WLISSETR:	PUSHM.L	D1..D4,A1	LOAD.L	D3,D2		; D3 <-- coordonne	AND.L	D1,#H'FFFF	SL.L	D1,#4		; D1 <-- *16	DIV.WU	D1,(A6)+OOPMAX	; D1 <-- 0..16	TEST.W	D1		; tout blanc ?	JUMP',EQ 25$	COMP.W	D1,#16		; tout noir ?	JUMP',EQ 25$	LOAD.B	D2,(A6)+OOPMOD+1 ; D2 <-- luminosit	CONV.WA.BA D2	SUB.W	D1,D2		; D1 <-- tient compte de la luminosit	JUMP',NC 20$	CLR.W	D120$:	COMP.W	D1,#16	JUMP',LS 25$	LOAD.W	D1,#1625$:	COMP.W	D1,#16/2	JUMP',LO 90$	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LOAD.L	A1,(A6)+OOPPTD	; A1 <-- ^bitmap destination	LOAD.L	D4,D3		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	MUL.WU	D4,(A6)+OOPIYD	LOAD.B	D1,D3	NOT.B	D1		; D1 <-- bit 2^7  gauche !	AND.B	D1,#B'111	; D1 <-- no du bit dans le byte	SR.W	D3,#3	ADD.W	A1,D3	ADD.L	A1,D4		; A1 <-- ^byte	TSET.B	(A1):D1		; allume un point90$:	POPM.L	D1..D4,A1	RET	.END