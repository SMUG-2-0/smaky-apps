	.SBTTL	DESCADRE;--------\\; DESWDO  >;========/; Grise toute la fentre et place les icnes.; in	-; out	-; mod	D7.WDESWDO:	PUSHM.L	D2..D4,A3	.IF	DESSIN	CALL	ERGMOUSE	; efface les flches dans les rgles	.ENDIF	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface toute la fentre	.IF	EDGAR	CLR.B	(A6)+OSREP	; les repres sont effacs	.ENDIF	LOAD.L	D3,#H'88882222	; D3 <-- trame pour cran entrelac	NTREL	?GETMACHINE		 ; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	COMP.B	D4,#SMAKY8	JUMP',EQ 20$	LOAD.L	D3,#H'88228822	; D3 <-- trame pour joli cran20$:	LOAD.L	D4,D3	CALL	DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise toute la fentre	PUSH.L	D4	LOAD.L	D4,#-1	CALL	DRMDEF	POP.L	D4	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LIB	?DRMATRIX	; dessine une bande blanche en haut	CALL	DESINFO		; affiche les informations	CALL	DESINFSC	; affiche l'chelle	CALL	DESINFFILE	; affiche le nom du dessin	CLR.L	D4	CALL	DRMDEF	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,#ICOLY	SWAP.W	D4	LOAD.W	D4,#MARGX+GCIMX	LOAD.L	(A6)+ODICO,D4	; ODICO <-- position pour icnes  gauche	CALL	DESICONE	; dessine toutes les icnes	.IF	DESSIN	CALL	MEMICONE	; mmorise les icnes de gauche	.ENDIF	CALL	MAJICONE	POPM.L	D2..D4,A3	RET;---------\\; MAJICONE >;=========/; Met  jour les icnes "variables".; in	-; out	-; mod	D7.WMAJICONE:	PUSH.L	D3	CALL	DESPDEF		; dessine l'icne du pinceau	CALL	DESTDEF		; dessine l'icne de la trame	.IF	DESSIN	CALL	DESZONE		; dessine l'icne de la zone	.ELSE	CALL	DESCODE		; dessine le caractre en dition	CALL	DESMUL		; dessine le nombre 1x	.ENDIF	TEST.W	(A6)+OSCALE	JUMP',NS 60$	LOAD.B	D3,(A6)+OMODE	CALL	INVICONE	; mode par dfaut	LOAD.B	D3,(A6)+OOUTIL	CALL	INVICONE	; outil par dfaut	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; objet par dfaut60$:	LOAD.B	D3,(A6)+OSELECT	CALL	INVICONE	; slection par dfaut	.IF	DESSIN	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE 70$	LOAD.B	D3,#ICOPLOUPE	CALL	INVICONE70$:	.ENDIF	POP.L	D3	RET;--------\\; DESINFO >;========/; Dessine les informations tout en haut.; in	-; out	-; mod	D7.WDESINFO:	PUSHM.L	D3,D4,A3	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	AFINV		; vido inverse	.IF	DESSIN	.ASCII	" DESSIN "	.ELSE	.ASCII	" EDICAR "	.ENDIF	.B	DESREV+'0,'.;;?	.IF	DESVERS<10	.B	DESVERS+'0;;?	.ELSE;;?	.B	(DESVERS/10)+'0,(DESVERS-((DESVERS/10)*10))+'0;;?	.ENDIF	.B	0	.EVEN	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	POPM.L	D3,D4,A3	RET;---------\\; DESINF3B >;=========/; Affiche les fonctions des trois boutons de la souris.; in	A3.L	^texte; out	-; mod	D7.WDESINF3B:	PUSHM.L	D3,A3	LOAD.W	D3,#LIHELP	MUL.WU	D3,(A0)+ODFCX	SUB.W	D3,(A0)+ODFDX	NEG.W	D3	AND.L	D3,#H'FFFF	LIB	?SETCURS	LIB	?AFTIM	.B	AFINV,AFTOUT,0	.EVEN	LIB	?AFTEXT		; affiche les 3 boutons de la souris	LIB	?AFTIM	.B	AFNORM,AFDIR,0	.EVEN	POPM.L	D3,A3	RET;---------\\; DESINFXY >;=========/; Affiche la position x,y de la souris dans les informations.; in	D3.L	position (y;x) ou -1 si hors de l'aire de dessin; out	-; mod	D7.WDESINFXY:	PUSHM.L	D2..D4	COMP.L	D3,#-1		; hors de l'aire de dessin ?	JUMP',EQ 10$		; oui => 10$				; non =>	EX.L	D1,D3	CALL	D1SCALEN	; D3 <-- augmente si "tout"	EX.L	D3,D110$:	LOAD.L	D4,D3		; D4 <-- position (y;x)	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSXY	MUL.WU	D3,(A0)+ODFCX	AND.L	D3,#H'FFFF	LIB	?SETCURS	COMP.L	D4,#-1		; hors de l'aire de dessin ?	JUMP',EQ 50$		; oui => 50$				; non =>	LIB	?AFTIM	.ASCIZ	"X="	.EVEN	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode	LOAD.W	D3,#3		; D3 <-- nb digits pour 0..999	PUSH.L	D4	AND.L	D4,#H'FFFF	LIB	?AFDEC	POP.L	D4	LIB	?AFTIM	.ASCIZ	" Y="	.EVEN	CLR.W	D4	SWAP.W	D4	SUB.W	D4,(A6)+OMALMY	NEG.W	D4	DEC.W	D4	LIB	?AFDEC	JUMP'	80$50$:	LIB	?AFTIM	.B	MSPACE,6+6,0	; efface tout	.EVEN80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	POPM.L	D2..D4	RET;---------\\; DESINFCP >;=========/; Affiche les dimensions pendant le dessin d'un objet; graphique (comme plan) dans les informations.; in	D5.L	P1(y;x);	D6.L	P2(y;x); out	-; mod	D7.WDESINFCP:	PUSHM.L	D2..D6	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSXY	MUL.WU	D3,(A0)+ODFCX	AND.L	D3,#H'FFFF	LIB	?SETCURS	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode	LOAD.W	D3,#3		; D3 <-- nb digits pour 0..999	LOAD.B	D4,(A6)+OOBJET	COMP.B	D4,#ICOCERCLE	JUMP,EQ 30$	COMP.B	D4,#ICOTRAIT	JUMP,EQ 70$				; droite/rectangle/etc. =>	LIB	?AFTIM	.ASCIZ	"L="	.EVEN	CLR.L	D4	LOAD.W	D4,D5	SUB.W	D4,D6	JUMP',NC 20$	NEG.W	D420$:	LIB	?AFDEC		; affiche la largeur	LIB	?AFTIM	.ASCIZ	" H="	.EVEN	SWAP.W	D5	SWAP.W	D6	CLR.L	D4	LOAD.W	D4,D5	SUB.W	D4,D6	JUMP',NC 22$	NEG.W	D422$:	LIB	?AFDEC		; affiche la hauteur	JUMP	80$30$:				; cercle =>	LIB	?AFTIM	.ASCIZ	"R="	.EVEN	CLR.L	D4	LOAD.W	D4,D5	SUB.W	D4,D6	JUMP',NC 32$	NEG.W	D432$:	SWAP.W	D5	SWAP.W	D6	SUB.W	D5,D6	JUMP',NC 34$	NEG.W	D534$:	ADD.W	D4,D5	LIB	?AFDEC		; affiche le rayon	LIB	?AFTIM	.B	MSPACE,6,0	.EVEN	JUMP'	80$70$:	LIB	?AFTIM	.B	MSPACE,6+6,0	; efface tout	.EVEN80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	POPM.L	D2..D6	RET;----------\\; DESINFDEF >;==========/; Affiche la dformation dans les informations.; in	D0.W	poigne;	D1.B	ICOxx; out	-; mod	D7.WDESINFDEF:	PUSHM.L	D2..D4	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSXY	MUL.WU	D3,(A0)+ODFCX	AND.L	D3,#H'FFFF	LIB	?SETCURS	COMP.B	D1,#ICOZOOMQQ	JUMP,EQ ZOOM$	COMP.B	D1,#ICOTOURNEQQ	JUMP,EQ TOURNE$	LOAD.L	D3,(A6)+OSEPHG	LOAD.L	D4,(A6)+OSEOHG	TEST.L	D0:#BPOIHG	JUMP',BS DELTA$	LOAD.L	D3,(A6)+OSEPHD	LOAD.L	D4,(A6)+OSEOHD	TEST.L	D0:#BPOIHD	JUMP',BS DELTA$	LOAD.L	D3,(A6)+OSEPBG	LOAD.L	D4,(A6)+OSEOBG	TEST.L	D0:#BPOIBG	JUMP',BS DELTA$	LOAD.L	D3,(A6)+OSEPBD	LOAD.L	D4,(A6)+OSEOBD;	TEST.L	D0:#BPOIBD;	JUMP',BS DELTA$DELTA$:	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode	LOAD.W	D3,#3		; D3 <-- nb digits pour 0..999	LIB	?AFTIM	.ASCIZ	"L="	.EVEN	PUSH.L	D4	AND.L	D4,#H'FFFF	TEST.W	D4	JUMP',NC DELTAX$	NEG.W	D4DELTAX$:	LIB	?AFDEC	POP.L	D4	LIB	?AFTIM	.ASCIZ	" H="	.EVEN	CLR.W	D4	SWAP.W	D4	TEST.W	D4	JUMP',NC DELTAY$	NEG.W	D4DELTAY$:	LIB	?AFDEC	JUMP	EXIT$ZOOM$:	LOAD.W	D4,(A6)+OSEPHG+2	SUB.W	D4,(A6)+OSEPHD+2	LOAD.W	D3,(A6)+OSEOHG+2	SUB.W	D3,(A6)+OSEOHD+2	CALL	DESINFZOOM	LIB	?AFSPACE	LOAD.W	D4,(A6)+OSEPHG+0	SUB.W	D4,(A6)+OSEPBG+0	LOAD.W	D3,(A6)+OSEOHG+0	SUB.W	D3,(A6)+OSEOBG+0	CALL	DESINFZOOM	JUMP	EXIT$TOURNE$:	CLR.L	D4	LOAD.W	D4,(A6)+OSEANG	; D4 <-- angle de rotation	JUMP',NC TOURNE1$	NEG.W	D4TOURNE1$:	DIV.WU	D4,#360	SWAP.W	D4	COMP.W	D4,#180	JUMP',LS TOURNE2$	SUB.W	D4,#360	NEG.W	D4TOURNE2$:	AND.L	D4,#H'FFFF	CLR.W	D2		; D2 <-- mode	LOAD.W	D3,#3		; D3 <-- nb digits pour 0..180	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" degrs "	.EVEN;	JUMP	EXIT$EXIT$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	POPM.L	D2..D4	RET;-----------\\; DESINFZOOM >;-----------/; Affiche un facteur de zoom positif ou ngatif.; in	D4.W	nouvelle longueur;	D3.W	ancienne longueur; out	-; mod	D7.WDESINFZOOM:	PUSHM.L	D2..D4	TEST.W	D4	JUMP',NC 10$	NEG.W	D410$:	TEST.W	D3	JUMP,EQ 80$	JUMP',NC 15$	NEG.W	D315$:	MUL.WU	D4,#1000	DIV.WU	D4,D3	COMP.W	D4,#10000	JUMP,HS 80$	AND.L	D4,#H'FFFF	LIB	?BINBCD	CLR.W	D220$:	RL.L	D4,#4	LOAD.L	D3,D4	SWAP.W	D3	AND.B	D3,#H'0F	ADD.B	D3,#'0	LIB	?AFCAR	TEST.W	D2	JUMP',NE 30$	LOAD.B	D3,#'.	LIB	?AFCAR30$:	INC.W	D2	COMP.W	D2,#4	JUMP,LO 20$	JUMP'	90$80$:	LIB	?AFTIM	.ASCIZ	"  ?  "	.EVEN90$:	POPM.L	D2..D4	RET;---------\\; DESINFSC >;=========/; Affiche l'chelle dans les informations.;	OSCALE positif	-->	n:1;	OSCALE ngatif	-->	1:n; in	(A6)+OSCALE.W; out	-; mod	D7.WDESINFSC:	PUSHM.L	D2..D4	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSSCALE	MUL.WU	D3,(A0)+ODFCX	AND.L	D3,#H'FFFF	LIB	?SETCURS	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LOAD.W	D3,#2		; D3 <-- 2 digits au maximum	CLR.L	D4	LOAD.W	D4,(A6)+OSCALE	; D4 <-- +/- chelle	JUMP',NS 50$				; chelle n:1 =>	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	":1"	.EVEN	JUMP'	60$50$:				; chelle 1:n =>	NEG.W	D4	LIB	?AFTIM	.ASCIZ	"1:"	.EVEN	LIB	?AFDEC60$:	COMP.W	D4,#10		; deux digits affichs ?	JUMP',HS 80$		; oui => 80$	LIB	?AFSPACE	; non => affiche encore un espace80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	POPM.L	D2..D4	RET;-----------\\; DESINFFILE >;===========/; Affiche le nom du fichier dans les informations.; in	-; out	-; mod	D7.WDESINFFILE:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A3,#(A6)+OBUNAME	LIB	?BUCAR		; mode rapide	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSFILE	MUL.WU	D3,(A0)+ODFCX	AND.L	D3,#H'FFFF	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A0)+ODFDX	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb car dans toute la largeur	SUB.W	D4,#POSFILE	SUB.W	D4,#LIHELP+1	; D4 <-- nb car restants pour le nom	TEST.B	(A3)	JUMP',EQ 50$	COMP.B	(A3),#CR	JUMP',EQ 50$	LOAD.B	D3,#'"	LIB	?AFCAR		; guillemet au dbut	SUB.W	D4,#2	LOAD.W	D2,#2^BAFXMI	; D2 <-- affiche en minuscules	LOAD.W	D3,D4		; D3 <-- lg max	LIB	?AFXFILE	; affiche le nom du fichier	LOAD.W	D4,D3		; D4 <-- lg restante	LOAD.B	D3,#'"	LIB	?AFCAR		; guillemet  la fin50$:	TEST.W	D4	JUMP',EQ 80$	LOAD.B	D3,#MSPACE	LIB	?AFCAR		; efface la fin	LOAD.B	D3,D4	LIB	?AFCAR80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?NOBUCAR	; mode normal	POPM.L	D2..D4,A3,A4	RET;---------\\; DESCADRE >;=========/; Dessine le cadre de la grande matrice, avec les ascenseurs; et la grille. Dessine aussi le "L" pour dlimiter le; petit rectangle.; in	-; out	-; mod	D7.WDESCADRE:	PUSHM.L	D2..D5,A5	.IF	DESSIN	CALL	ERGMOUSE	; efface les flches dans les rgles	.ENDIF	.IF	EDGAR	CLR.B	(A6)+OSREP	; les repres sont effacs	.ENDIF	CLR.L	D4	CALL	DRMDEF	LOAD.L	D3,(A6)+OGRPOY	LOAD.L	D4,(A6)+OGRDIY	.IF	DESSIN	TEST.B	(A6)+OREGLE	; rgles prsentes ?	JUMP',F 10$		; non => 10$	ADD.W	D4,#LGREGLE	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#LGREGLE	ADD.W	D4,#LGREGLE	SWAP.W	D3	SWAP.W	D410$:	.ENDIF	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 20$		; non => 20$	SUB.W	D3,#LGSCROLL-1	ADD.W	D4,#LGSCROLL-1	SWAP.W	D4	ADD.W	D4,#LGSCROLL-1	SWAP.W	D420$:	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface toute la grande matrice	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour grande matrice	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	CALL	DESGRILLE	; dessine la grille dans le grand rectangle	LOAD.L	A5,#(A6)+OASVER	LOAD.W	D4,(A6)+OGRPOY	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OGRPOX	SUB.W	D4,#LGSCROLL	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OGRDIY	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	CLR.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 40$		; non => 40$	SCROLL_	DRAW		; dessine la cage verticale40$:	LOAD.L	A5,#(A6)+OASHOR	LOAD.W	D4,(A6)+OGRPOX	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OGRPOY	ADD.W	D4,(A6)+OGRDIY	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OGRDIX	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 50$		; non => 50$	SCROLL_	DRAW		; dessine la cage horizontale50$:	CALL	MAJCADRE; Dessine le "L" pour dlimiter le petit rectangle.	LOAD.W	D5,(A6)+OPWDO	JUMP',EQ 65$	LIB	?KILWDO		; dtruit la swdo autour petite matrice65$:	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE 70$	LOAD.W	D3,(A6)+OPRPOY	LOAD.W	D4,(A6)+OPRDIY;;?	INC.W	D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OPRPOX	DEC.W	D3	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; dessine ligne verticale	CLR.L	D4	LOAD.W	D4,(A6)+OPRDIX	INC.W	D4;	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; dessine ligne horizontale70$:	LOAD.L	D3,(A6)+OPMPOY	LOAD.L	D4,(A6)+OPMDIY	LIB	?CREWDO		; cre swdo autour de la petite matrice	LOAD.W	(A6)+OPWDO,D5; Grise ventuellement les zones en haut et  droite qui dbordent.	.IF	DESSIN	LOAD.L	D4,#H'88882222	CALL	DRMDEF	LOAD.W	D4,(A6)+OPRDIY	; D4 <-- hauteur petit rectangle	SUB.W	D4,(A6)+OPMDIY	; D4 <-- hauteur  griser	JUMP',LS 74$	SWAP.W	D4	LOAD.W	D4,(A6)+OPRDIX	LOAD.L	D3,(A6)+OPRPOY	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise en haut74$:	LOAD.W	D4,(A6)+OPRDIX	; D4 <-- largeur petit rectangle	SUB.W	D4,(A6)+OPMDIX	; D4 <-- largeur  griser	JUMP',LS 76$	LOAD.W	D3,(A6)+OPRPOX	ADD.W	D3,(A6)+OPMDIX	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OPRPOY	ADD.W	D3,(A6)+OPRDIY	SUB.W	D3,(A6)+OPMDIY	LOAD.W	D4,(A6)+OPMDIY	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise  droite76$:	.ENDIF	POPM.L	D2..D5,A5	RET;---------\\; MAJCADRE >;=========/; Met  jour le cadre (ascenseurs et rgles).; in	-; out	-; mod	D7.WMAJCADRE:	PUSHM.L	D3,D4,A5	.IF	DESSIN	CALL	DESREGLE	; dessine les rgles	.ENDIF	LOAD.L	A5,#(A6)+OASVER	LOAD.W	D4,(A6)+OMALSY	CLR.L	D3	LOAD.W	D3,(A6)+OGMDIY	DIV.WU	D3,(A6)+OGMLPY	SUB.W	D4,D3	LOAD.W	(A5)+OSCHTV,D4	JUMP',EQ 40$	INC.W	(A5)+OSCHTV	LOAD.W	(A5)+OSCPOSV,(A6)+OGMOVY	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 40$		; non => 40$	SCROLL_	UPDATE		; dessine la cabine verticale40$:	LOAD.L	A5,#(A6)+OASHOR	LOAD.W	D4,(A6)+OMALSX	CLR.L	D3	LOAD.W	D3,(A6)+OGMDIX	DIV.WU	D3,(A6)+OGMLPX	SUB.W	D4,D3	.IF	EDGAR	CLR.L	D3	LOAD.W	D3,(A6)+OGMPOX	ADD.W	D3,(A6)+OGMDIX	SUB.W	D3,(A6)+OPRPOX	JUMP',LO 55$	DIV.WU	D3,(A6)+OGMLPX	ADD.W	D4,D355$:	.ENDIF	LOAD.W	(A5)+OSCHTV,D4	JUMP',EQ 60$	INC.W	(A5)+OSCHTV	LOAD.W	(A5)+OSCPOSV,(A6)+OGMOVX	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 60$		; non => 60$	SCROLL_	UPDATE		; dessine la cabine horizontale60$:	POPM.L	D3,D4,A5	RET;---------\\; ASCMOVEH >;=========/; Dplace l'ascenseur horizontal.; in	A5.L	^description ascenseur;	D4.L	SCROLL(F/P)(UP/DOWN); out	-; mod	D7.WASCMOVEH:	PUSHM.L	D2..D4	TEST.B	(A6)+ODEF+3:#BDEFASC	JUMP',BC 05$	SCROLL_	PRESS		; allume le "bouton"05$:	.IF	EDGAR	CALL	CLRREPERE	; enlve les repres	.ENDIF	LOAD.L	D2,D4		; D2 <-- "bouton" de l'ascenseur10$:	LOAD.W	D3,#+4		; D3 <-- +4 point	COMP.W	D2,#SCROLLFDOWN	JUMP,EQ 50$	NEG.W	D3		; D3 <-- -4 point	COMP.W	D2,#SCROLLFUP	JUMP,EQ 50$	LOAD.W	D3,(A6)+OPMDIX	; D3 <-- +1 cran	COMP.W	D2,#SCROLLPDOWN	JUMP,EQ 50$	NEG.W	D3		; D3 <-- -1 cran	COMP.W	D2,#SCROLLPUP	JUMP,EQ 50$; Dplacement absolu selon l'ascenseur.	LOAD.L	D4,(A6)+OGMOVY	LOAD.W	D4,(A5)+OSCPOSV	CALL	ASCMOVE		; dplace la partie visible	JUMP	80$; Dplacement selon la quantit dans D3.50$:	LOAD.L	D4,(A6)+OGMOVY	ADD.W	D4,D3	CALL	ASCMOVE		; dplace la partie visible	TEST.L	D2:#16		; juste une fois ?	JUMP',BS 80$		; oui => 80$				; non =>	LIB	?IFCAR		; bouton relach ?	JUMP,NE 10$		; non => 10$80$:	TEST.B	(A6)+ODEF+3:#BDEFASC	JUMP',BC 85$	LOAD.W	D4,D2	SCROLL_	PRESS		; teint le "bouton"85$:	.IF	DESSIN	CALL	DESREGLE	; dessine les rgles	.ENDIF	POPM.L	D2..D4	RET;---------\\; ASCMOVEV >;=========/; Dplace l'ascenseur vertical.; in	A5.L	^description ascenseur;	D4.L	SCROLL(F/P)(UP/DOWN); out	-; mod	D7.WASCMOVEV:	PUSHM.L	D2..D4	TEST.B	(A6)+ODEF+3:#BDEFASC	JUMP',BC 05$	SCROLL_	PRESS		; allume le "bouton"05$:	.IF	EDGAR	CALL	CLRREPERE	; enlve les repres	.ENDIF	LOAD.L	D2,D4		; D2 <-- "bouton" de l'ascenseur10$:	LOAD.W	D3,#+4		; D3 <-- +4 point	COMP.W	D2,#SCROLLFDOWN	JUMP,EQ 50$	NEG.W	D3		; D3 <-- -4 point	COMP.W	D2,#SCROLLFUP	JUMP,EQ 50$	LOAD.W	D3,(A6)+OPMDIY	; D3 <-- +1 cran	COMP.W	D2,#SCROLLPDOWN	JUMP,EQ 50$	NEG.W	D3		; D3 <-- -1 cran	COMP.W	D2,#SCROLLPUP	JUMP,EQ 50$; Dplacement absolu selon l'ascenseur.	LOAD.L	D4,(A6)+OGMOVY	SWAP.W	D4	LOAD.W	D4,(A5)+OSCPOSV	SWAP.W	D4	CALL	ASCMOVE		; dplace la partie visible	JUMP	80$; Dplacement selon la quantit dans D3.50$:	LOAD.L	D4,(A6)+OGMOVY	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D4	CALL	ASCMOVE		; dplace la partie visible	TEST.L	D2:#16		; juste une fois ?	JUMP',BS 80$		; oui => 80$				; non =>	LIB	?IFCAR		; bouton relach ?	JUMP,NE 10$		; non => 10$80$:	TEST.B	(A6)+ODEF+3:#BDEFASC	JUMP',BC 85$	LOAD.W	D4,D2	SCROLL_	PRESS		; teint le "bouton"85$:	.IF	DESSIN	CALL	DESREGLE	; dessine les rgles	.ENDIF	POPM.L	D2..D4	RET;--------\\; ASCMOVE >;--------/; Dplace la partie visible horizontalement ou verticalement.; in	A5.L	^description ascenseur;	D4.L	nouvelle position (y;x); out	-; mod	D7.WASCMOVE:	PUSHM.L	D3,D4	TEST.W	D4	JUMP',NC 20$	CLR.W	D420$:	COMP.W	D4,(A6)+OASHOR+OSCHTV	JUMP',LO 22$	LOAD.W	D4,(A6)+OASHOR+OSCHTV	JUMP',EQ 22$	DEC.W	D422$:	SWAP.W	D4	TEST.W	D4	JUMP',NC 30$	CLR.W	D430$:	COMP.W	D4,(A6)+OASVER+OSCHTV	JUMP',LO 32$	LOAD.W	D4,(A6)+OASVER+OSCHTV	JUMP',EQ 32$	DEC.W	D432$:	SWAP.W	D4	LOAD.L	(A6)+OGMOVY,D4	.IF	DESSIN	LOAD.L	(A6)+OPMOVY,D4	.ENDIF	LOAD.W	(A6)+OASHOR+OSCPOSV,D4	SWAP.W	D4	LOAD.W	(A6)+OASVER+OSCPOSV,D4	TEST.B	(A6)+ODEF+3:#BDEFASC	JUMP',BC 50$	SCROLL_	UPDATE		; dplace l'ascenseur50$:	.IF	EDGAR	CALL	DESGRILLE	; pour effacer v. qq points  droite	.ENDIF	CALL	DESPMATRIX	; dessine la petite matrice	CALL	DESGMATRIX	; dessine la grande matrice	POPM.L	D3,D4	RET	.IF	DESSIN;---------\\; DESREGLE >;=========/; Dessine les rgles centimtriques.; in	-; out	-; mod	D7.WDESREGLE:	PUSHM.L	D2..D4,A5	TEST.B	(A6)+OREGLE	; rgles prsentes ?	JUMP,F	90$		; non => 90$				; oui =>	LOAD.L	A5,#(A6)+ORGVAR; Initialise les variables pour la rgle horizontale.	LOAD.W	(A5)+ORGHPO+2,(A6)+OGRPOX	LOAD.W	D4,(A6)+OGRPOY	SUB.W	D4,#LGREGLE	LOAD.W	(A5)+ORGHPO+0,D4	LOAD.W	D4,(A6)+OGRDIX	INC.W	D4	LOAD.W	(A5)+ORGHLG,D4	LOAD.W	(A5)+ORGHOR,(A6)+OGMOVX	LOAD.W	(A5)+ORGHSC,(A6)+OSCALE	LOAD.L	D4,#10000*64	DIV.WU	D4,(A6)+OMMX	AND.L	D4,#H'FFFF	DIV.WU	D4,(A6)+OFACX	LOAD.W	(A5)+ORGHPA,D4; Initialise les variables pour la rgle verticale.	LOAD.W	D4,(A6)+OGRPOX	ADD.W	D4,(A6)+OGRDIX	INC.W	D4	LOAD.W	(A5)+ORGVPO+2,D4	LOAD.W	(A5)+ORGVPO+0,(A6)+OGRPOY	LOAD.W	D4,(A6)+OGRDIY	INC.W	D4	LOAD.W	(A5)+ORGVLG,D4	CLR.L	D3	LOAD.W	D3,(A6)+OGMDIY	LOAD.W	D2,(A6)+OSCALE	JUMP',NS 50$	DIV.WU	D3,D2		; D3 <-- nb points visibles en Y	JUMP'	55$50$:	NEG.W	D2	MUL.WU	D3,D2		; D3 <-- nb points visibles en Y55$:	CLR.W	(A5)+ORGVOR	LOAD.W	D4,(A6)+OMALMY	SUB.W	D4,(A6)+OGMOVY	SUB.W	D4,D3	JUMP',LO 60$	LOAD.W	(A5)+ORGVOR,D460$:	LOAD.W	(A5)+ORGVSC,(A6)+OSCALE	LOAD.L	D4,#10000*64	DIV.WU	D4,(A6)+OMMY	AND.L	D4,#H'FFFF	DIV.WU	D4,(A6)+OFACY	LOAD.W	(A5)+ORGVPA,D4	SCROLL_	RUPDATE		; dessine les rgles gradues90$:	POPM.L	D2..D4,A5	RET	.ENDIF;----------\\; DESGRILLE >;==========/; Dessine la grille de points dans toute la matrice.; in	-; out	-; mod	D7.WDESGRILLE:	PUSHM.L	D0..D5,A0..A2	COMP.W	(A6)+OSCALE,#SCALEMIN	JUMP,LT 90$	CALL	CCMO		; enlve la souris	LOAD.L	A2,A0		; A2 <-- ^description fentre	LOAD.L	A1,(A6)+OQXDOT	; A1 <-- adresse routine	LOAD.W	D4,(A6)+OGMPOY	; D4 <-- position initiale en Y	DEC.W	D4	SWAP.W	D4	CLR.L	D5	LOAD.W	D5,(A6)+OGMDIY	DIV.WU	D5,(A6)+OGMLPY	; D5 <-- nb points verticalement;	INC.W	D5		; D5 <-- va jusque tout en bas;	DEC.W	D5		; D5 <--  cause NMO10$:	LOAD.W	D4,(A6)+OGMPOX	; D4 <-- position initiale en X	ADD.W	D4,(A6)+OGMLPX	DEC.W	D4	CLR.L	D3	LOAD.W	D3,(A6)+OGMDIX	; D3 <-- largeur totale	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A6)+OPRDIY	COMP.W	D2,(A6)+OPRPOY	; petit rectangle  ct ?	JUMP',GT 12$		; non => 12$	LOAD.W	D2,(A6)+OPRPOX	; oui =>	SUB.W	D2,(A6)+OGRPOX	; D2 <-- largeur moins rectangle	COMP.W	D3,D2	JUMP',LS 12$	LOAD.W	D3,D212$:	DIV.WU	D3,(A6)+OGMLPX	; D3 <-- nb de points dans la largeur	LOAD.W	D2,(A6)+OMALMX	SUB.W	D2,(A6)+OGMOVX	LOAD.W	D1,D3	SUB.W	D1,D2		; D1 <-- nb de points  effacer ( droite)	JUMP',LS 15$	LOAD.W	D3,D215$:	DEC.W	D3		; D3 <--  cause NMO20$:	CALL	(A1)		; appel GRA_QXDOT	TSET.B	(A0):D0		; met un point	ADD.W	D4,(A6)+OGMLPX	; D4 <-- avance en X	DECJ.W,NMO D3,20$	TEST.W	D1		; qq points  effacer ?	JUMP',LE 40$		; non => 40$	DEC.W	D1		; D1 <--  cause NMO30$:	CALL	(A1)		; appel GRA_QXDOT	TCLR.B	(A0):D0		; efface un point	ADD.W	D4,(A6)+OGMLPX	; D4 <-- avance en X	DECJ.W,NMO D1,30$40$:	SWAP.W	D4	ADD.W	D4,(A6)+OGMLPY	; D4 <-- avance en Y	SWAP.W	D4	DECJ.W,NMO D5,10$90$:	POPM.L	D0..D5,A0..A2	RET;---------\\; CALSCALE >;=========/; Modifie l'chelle en centrant toujours le mieux possible; la partie visible.; in	D4.W		nouvelle chelle (1..n);	(A6)+OSCALE.W	ancienne chelle (1..n);	(A6)+OPMOV?.W	petite mat: ancien offset zone visible;	(A6)+OPMDI?.W	petite mat: anciennes dimensions; out	(A6)+OSCALE.W	nouvelle chelle (1..n);	(A6)+OPRPO?.W	petit rect: position;	(A6)+OPRDI?.W	petit rect: dimensions;	(A6)+OPMPO?.W	petite mat: position;	(A6)+OPMDI?.W	petite mat: dimensions;	(A6)+OPMOV?.W	petite mat: offset zone visible;	(A6)+OGMPO?.W	grande mat: position;	(A6)+OGMDI?.W	grande mat: dimensions;	(A6)+OGMOV?.W	grande mat: offset zone visible;	(A6)+OGMLP?.W	rect matrice: hauteur/largeur d'un point selon chelle; mod	D7.WCALSCALE:	PUSHM.L	D0..D5	COMP.W	D4,#SCALE11	; chelle 1:1 ?	JUMP',LE 15$		; oui => 15$ (ok)	COMP.W	D4,#SCALEMIN	JUMP',HS 10$	LOAD.W	D4,#SCALEMIN	; interdit les chelles 2..410$:	COMP.W	D4,#SCALEMAX	; chelle trop grande ?	JUMP',LS 15$		; non => 15$	LOAD.W	D4,#SCALEMAX	; oui => met le maximum; Allume ou teint la petite loupe dans les icnes.; La loupe doit tre allume si l'chelle n'est pas 1:1 !15$:	.IF	DESSIN	CALL	ICOSCALE	; allume/teint qq icnes	.ENDIF; Calcul les coordonnes du point actuellement au centre de la; petite matrice visible.	LOAD.W	D0,(A6)+OPMDIX	SR.W	D0,#1	ADD.W	D0,(A6)+OPMOVX	; D0 <-- point au centre zone visible en X	LOAD.W	D1,(A6)+OPMDIY	SR.W	D1,#1	ADD.W	D1,(A6)+OPMOVY	; D1 <-- point au centre zone visible en Y; Calcul la position et les dimensions du petit rectangle.	LOAD.W	D5,#1	TEST.W	D4		; chelle "tout" ?	JUMP',NS 25$		; oui => 25$	LOAD.W	D5,D425$:	.IF	DESSIN	CLR.L	D3	LOAD.W	D3,(A6)+OGRDIX	DIV.WU	D3,D5		; D3 <-- largeur visible	ADD.W	D3,#8-1	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X	LOAD.W	(A6)+OPRDIX,D3	SUB.W	D3,(A6)+OGRDIX	NEG.W	D3	ADD.W	D3,(A6)+OGRPOX	LOAD.W	(A6)+OPRPOX,D3	CLR.L	D3	LOAD.W	D3,(A6)+OGRDIY	DIV.WU	D3,D5		; D3 <-- largeur visible	ADD.W	D3,#2-1	AND.B	D3,#B'11111110	; D3 <-- modulo 2 en Y	LOAD.W	(A6)+OPRDIY,D3	LOAD.W	(A6)+OPRPOY,(A6)+OGRPOY	.ELSE	LOAD.W	D3,(A6)+OMALMX	ADD.W	D3,#8+8	LOAD.W	(A6)+OPRDIX,D3	SUB.W	D3,(A6)+OGRDIX	NEG.W	D3	ADD.W	D3,(A6)+OGRPOX	LOAD.W	(A6)+OPRPOX,D3	LOAD.W	D3,(A6)+OMALMY	ADD.W	D3,#8+8	LOAD.W	(A6)+OPRDIY,D3	LOAD.W	(A6)+OPRPOY,(A6)+OGRPOY	.ENDIF; Calcul les dimensions de la matrice visible si l'chelle est; ngative (fonction "tout").	LOAD.L	(A6)+OMALSY,(A6)+OMALMY	TEST.W	D4		; chelle ngative ?	JUMP',NC 30$		; non => 30$	LOAD.W	D3,D4	NEG.W	D3		; D3 <-- |chelle|	CLR.L	D2	LOAD.W	D2,(A6)+OMALMX	DIV.WU	D2,D3	LOAD.W	(A6)+OMALSX,D2	CLR.L	D2	LOAD.W	D2,(A6)+OMALMY	DIV.WU	D2,D3	LOAD.W	(A6)+OMALSY,D2; Calcul les nouvelles origine et dimension dans la matrice.30$:	.IF	DESSIN	LOAD.W	D3,(A6)+OPRDIX	; D3 <-- nouvelle largeur	LOAD.W	D2,D3	SR.W	D2,#1		; D2 <-- 1/2 nouvelle largeur	ADD.W	D0,D2	COMP.W	D0,(A6)+OMALSX	JUMP',LO 40$	LOAD.W	D0,(A6)+OMALSX40$:	SUB.W	D0,D3	JUMP',HS 42$	CLR.W	D042$:	LOAD.W	(A6)+OGMOVX,D0	LOAD.W	(A6)+OPMOVX,D0	SUB.W	D0,(A6)+OMALSX	NEG.W	D0	COMP.W	D3,D0	JUMP',LS 44$	LOAD.W	D3,D044$:	LOAD.W	(A6)+OPMDIX,D3	LOAD.W	(A6)+OPMPOX,(A6)+OPRPOX; Idem dans le sens de la hauteur.	LOAD.W	D3,(A6)+OPRDIY	; D3 <-- nouvelle hauteur	LOAD.W	D2,D3	SR.W	D2,#1		; D2 <-- 1/2 nouvelle hauteur	ADD.W	D1,D2	COMP.W	D1,(A6)+OMALSY	JUMP',LO 50$	LOAD.W	D1,(A6)+OMALSY50$:	SUB.W	D1,D3	JUMP',HS 52$	CLR.W	D152$:	LOAD.W	(A6)+OGMOVY,D1	LOAD.W	(A6)+OPMOVY,D1	SUB.W	D1,(A6)+OMALSY	NEG.W	D1	COMP.W	D3,D1	JUMP',LS 54$	LOAD.W	D3,D154$:	LOAD.W	(A6)+OPMDIY,D3	LOAD.W	D3,(A6)+OPRPOY	ADD.W	D3,(A6)+OPRDIY	SUB.W	D3,(A6)+OPMDIY	LOAD.W	(A6)+OPMPOY,D3	.ELSE	CLR.L	(A6)+OGMOVY	CLR.L	(A6)+OPMOVY	LOAD.L	(A6)+OPMDIY,(A6)+OMALMY	LOAD.L	(A6)+OPMPOY,(A6)+OPRPOY	ADD.W	(A6)+OPMPOX,#8	ADD.W	(A6)+OPMPOY,#8	.ENDIF; Met  jour les nouvelles dimensions d'un point.	LOAD.W	(A6)+OGMLPX,D5	LOAD.W	(A6)+OGMLPY,D5; Calcul l'emplacement de la matrice dans le grand rectangle; (utile au cas o le rectangle est trop grand).	LOAD.W	D3,(A6)+OGRDIX	LOAD.W	D2,(A6)+OMALSX	SUB.W	D2,(A6)+OGMOVX	MUL.WU	D2,(A6)+OGMLPX	COMP.W	D3,D2	JUMP',LS 60$	LOAD.W	D3,D260$:	LOAD.W	(A6)+OGMDIX,D3	LOAD.W	(A6)+OGMPOX,(A6)+OGRPOX	LOAD.W	D3,(A6)+OGRDIY	LOAD.W	D2,(A6)+OMALSY	SUB.W	D2,(A6)+OGMOVY	MUL.WU	D2,(A6)+OGMLPY	COMP.W	D3,D2	JUMP',LS 65$	LOAD.W	D3,D265$:	LOAD.W	(A6)+OGMDIY,D3	LOAD.W	D3,(A6)+OGRPOY	ADD.W	D3,(A6)+OGRDIY	SUB.W	D3,(A6)+OGMDIY	LOAD.W	(A6)+OGMPOY,D3; Met  jour la nouvelle chelle.	LOAD.W	(A6)+OSCALE,D4	CALL	DESINFSC	; affiche la nouvelle chelle	.IF	EDGAR	CALL	AFMENU		; montre la nouvelle chelle	.ENDIF	POPM.L	D0..D5	RET	.IF	DESSIN;---------\\; ICOSCALE >;---------/; Allume ou teint qq icnes en fonction d'un changement d'chelle.; in	D4.W		nouvelle chelle;	(A6)+OSCALE.W	ancienne chelle; out	-; mod	D7.WICOSCALE:	PUSHM.L	D3,D4,A3	COMP.W	D4,(A6)+OSCALE	; chelle change ?	JUMP,EQ 90$		; non => 90$; Allume ou teint la petite loupe dans les icnes.; La loupe doit tre allume si l'chelle est suprieure  1:1 !	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE 17$	COMP.W	D4,#SCALE11	JUMP',LE 18$	JUMP'	20$17$:	COMP.W	D4,#SCALE11	JUMP',LE 20$18$:	LOAD.B	D3,#ICOPLOUPE	CALL	INVICONE	; allume/teint la petite loupe; Eteint toutes les icnes si l'chelle est plus petite que 1:1.20$:	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LT 40$	COMP.W	D4,#SCALE11	JUMP,GE 90$				; teint tout =>	LOAD.L	A3,#R16"TJHELP	CALL	DESINF3B	; met les 3 boutons "rduits"	LOAD.B	D3,(A6)+OSELECT	COMP.B	D3,#ICOZONE	JUMP',EQ 50$	CALL	INVICONE	; teint l'ancienne slection	LOAD.B	D3,#ICOZONE	CALL	INVICONE	; allume la slection "rectangle"	LOAD.B	(A6)+OSELECT,D3	JUMP'	50$40$:	COMP.W	D4,#SCALE11	JUMP',LT 90$				; allume tout =>	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; remet les 3 boutons de la souris50$:	LOAD.B	D3,(A6)+OMODE	CALL	INVICONE	; allume/teint le mode	LOAD.B	D3,(A6)+OOUTIL	CALL	INVICONE	; allume/teint l'outil	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; allume/teint l'objet90$:	POPM.L	D3,D4,A3	RET	.ENDIF;---------\\; CALCADRE >;=========/; Calcul la position et les dimensions du grand rectangle; dans la fentre.; in	-; out	(A6)+OGRPO?.W	grand rect: coin sup/gauche;	(A6)+OGRDI?.W	grand rect: dimensions;	D7.W		erreur; mod	D7.WCALCADRE:	PUSHM.L	D1..D4	LOAD.W	D7,#ERDIOUT	; D7 <-- matrice trop grande	LOAD.W	D3,(A0)+ODFFDX	SUB.W	D3,#8+8	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC 10$		; non => 10$	LOAD.W	D3,(A0)+ODFFDX	SUB.W	D3,#MARGX+(GCIMX+GCICX/2+GCIMX)*3+MARGX10$:	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 12$		; non => 12$	SUB.W	D3,#LGSCROLL12$:	.IF	EDGAR	SUB.W	D3,#MARGX+(GCIMX+GCICX/2+GCIMX)*4+MARGX	.ENDIF	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X	LOAD.W	(A6)+OGRDIX,D3	LOAD.W	D3,(A0)+ODFFDY	SUB.W	D3,#MARGY+MARGY	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 22$		; non => 22$	SUB.W	D3,#LGSCROLL22$:	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	AND.B	D3,#B'11111110	; D3 <-- modulo 2 en Y	LOAD.W	(A6)+OGRDIY,D3	LOAD.W	D3,#8	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC 30$		; non => 30$	LOAD.W	D3,#MARGX+(GCIMX+GCICX/2+GCIMX)*3+MARGX30$:	TEST.B	(A6)+ODEF+3:#BDEFASC ; ascenseurs prsents ?	JUMP',BC 32$		; non => 32$	ADD.W	D3,#LGSCROLL32$:	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X	LOAD.W	(A6)+OGRPOX,D3	LOAD.W	D3,#MARGY	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	AND.B	D3,#B'11111110	; D3 <-- modulo 2 en Y	LOAD.W	(A6)+OGRPOY,D3	.IF	DESSIN	TEST.B	(A6)+OREGLE	; rgles prsentes ?	JUMP',F 80$		; non => 80$	ADD.W	(A6)+OGRPOY,#LGREGLE	SUB.W	(A6)+OGRDIX,#LGREGLE	SUB.W	(A6)+OGRDIY,#LGREGLE80$:	.ENDIF	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET	.END