	.TITLE	DESSIN.ASC;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------;	Source des programmes DESSIN et EDICAR;	PSos	Amliorations; --------------------------------------------------------------------------; 3.6		si chelle 1:2 => vue plus claire (pour CN); 3.5		si grand cran => icnes de gauche cales en bas;		dicar: "ajoute image" libre bien la mmoire; 3.4		df: option "zoom gnral" ne dforme plus (homothtie);		mise  niveau pour EDICAR ...; 3.3		F2 = Ajoute (et plus Modif);		utilisation de DBOX_ERCALL pour les appels FOS;		utilisation de LIB ?GETSHIFT;		utilisation de DBOX_PREND,AJOUTE,SAUVE,MAJ,QUITTE,etc.;		F0 demande s'il faut quitter;		vrifie la rvision du systme avec LIB,?GETREV;		F5 = Zoom (nouvelle fonction);		df: option "zoom gnral";		dplace: ne laisse plus de traines sur fond blanc !;		sauve (bouton de droite) => dessin toujours  jour; 3.2		(N)/(G): icne du crayon/pinceau change;		boulette avec GESMEM corrige;		raccourcis clavier: (C) = crayon, (P) = pinceau, etc.;		(SHOW-flches): dplace les ascenseurs;		HELP avec deux images;		df: mmorise la dernire case (mmenu);		jusqu' 300 gencars sur disque (150 anciennement); 3.1		dplace/duplique: ok sur SMAKY8;		df: utilise les icnes (si non => bouton du milieu);		df: utilise les ascenseurs; 3.0		si "tout" puis "loupe" => plus de Zero DIV !;		miroir: horizontal <--> vertical;		10 pages de travail !;		(SHOW-1..0) => visualisation directe;		nouvelle icne "page" en haut  gauche;		filet: ok avec traits fins;		crochet: sablier pendant recherche (remplissage);		changements de lutins plus rapides (SETPRIO #1);		bouton de droite: entoure puis (1), (2) ou (3) => met dans bloc-notes;		(1), (2) ou (3) => slectionne un bloc-notes;		zoom: option "autre...";		tourne: option "autre...";		bouton de droite: nouvelle opration "dforme" !;		bouton de droite: COPY-clic => reprend ancienne slection;		spline: poignes carres (comme dformations);		miroir: 2 oprations "diagonale" nouvelles;		main: nouvel outil !;		pas: nouveau mode avec 1, 2, 4, 8, 16 ou 32;		dplace/duplique: choix du mode (opaque, transparent, etc.);		dplace/duplique: dplacement sans  coup !;		dplace/duplique: scroll automatique si souris dpasse;		ascenseurs: dplacements par 4 points et par crans;		ascenseurs: dplacements rapide si bouton maintenu press; 2.4		EDICAR: transformation /2 possible; 2.3		EDICAR lit des SMA_ par dfaut;		affiche des XXXX dans les clefs des noms; 2.2		EDICAR ne se prend plus pour un auteur !; 2.1		rgles gradues en mm;		Df: cases (ECRAN) et (PAGE);		Df: units "points" ou "millimtres";		utilise le module DESSIN; 2.0		(F13) = fonction "tout" (zoom -2, -4 ou -8);		Sauve: sauve les pinceaux et les trames ?;		pinceau/gomme: la souris ne fait plus la croix; 1.6		cre les fichiers .DDES sans l'attribut "L";		i/o: fichiers .image cods;		help: accepte aussi les images codes; 1.5		nom dans ligne de commande (pour START);		HELP charge les images avec BOPSYS; 1.4		dessin: ok dans bitmap 1000x1000 (enfin ?); 1.3		edicar: permet de prendre "xyz_trp14";		dessin: ok dans bitmap 1000x1000; 1.2		( <-- ) identique  (UNDO);		edicar: dcalages dans les 4 directions ok; 1.1		nouvelles icnes pour pinceau et rempli;		spray: gicle mme sans bouger (gaz propulseur);		rempli: s'effectue en mmoire (invisible);		rempli: le travail est invisible;		rempli: en loupe, possible mme si trs grand;		rempli: possible sur du noir !;		contour: opration "ombr";		filet ( papillons) !;		crochet;		loupe: reste allume si chelle autre que 1:1;		ajoute: on peut appuyer sur AJOUTE puis dplacer;		ajoute: ok si grand dessin dcal vers la droite;		bloc-notes: mise dans un bloc-notes le slectionne;		HELP affiche le fichier dessin_h.image;		clic souris sans bouger inverse point avec tous les objets;		spline;		loupe: dessin "comme plan" beaucoup plus rapide;		gencar: au dmarrage, laisse 30k libre; 1.0	3.40	premire version distribue	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES; Assemblage conditionnel; -----------------------EDGAR	=	0		; 0=DESSIN et 1=EDICARDESSIN	=	~EDGARDESREV	=	3		; rvisionDESVERS	=	6		; version	.REV	DESREV,DESVERS	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------MARGX	=	16		; marge en XMARGY	=	12		; marge en YSCALE11	=	1		; chelle 1:1SCALEMIN=	5		; chelle minimaleSCALELOUPE=	8		; chelle pour la loupe par dfautSCALEMAX=	16		; chelle maximaleMAXSPLINE=	20+2		; nb max points pour splineDPOIGNEE=	5		; dimension d'une poigneLGMAC	=	500		; buffer pour les macrosMAXDEF	=	4*7		; nb max de trames/pinceauxMAXGENC	=	300		; nb max de gencar sur disqueLBUFILE	=	50		; lg max d'un nom de fichierPOSXY	=	13		; position pour afficher X= et Y=POSSCALE=	13+12		; position pour afficher 1:1POSFILE	=	13+12+5		; position pour afficher "fichier"BARC1	=	0		; cercle completBARC2	=	1		; 1/2 cercleBARC4	=	2		; 1/4 cercleGCTXF	=	'N!2^7		; fonte du texte  N(F)12GCTXS	=	2^BGCFIX	; style/chasse du texteGCTXT	=	12		; taille du texteGCICF	=	'I		; fonte des icnes  IDP20GCICS	=	'D		; style/chasse des icnesGCICT	=	20		; taille des icnesGCICX	=	32		; largeur d'une icneGCICY	=	GCICT		; hauteur d'une icneGCICB	=	6		; position ligne de baseGCIMX	=	6		; marges gauche/droiteGCIMY	=	3		; marges haut/basICOLX	=	96		; largeur des icnes de gaucheICOLY	=	310		; hauteur des icnes de gaucheKCIRCON	=	'		; touche circonflxeKTREMA	=	'		; touche trmaKEYICO	=	H'7E00		; "touche" spciale icne; Fanions pour ODEF; -----------------BDEFPG	=	0		; points graphiquesBDEFMM	=	1		; millimtresBDEFICO	=	2		; utilise les icnesBDEFASC	=	3		; utilise les ascenseursBDEFMDC	=	4		; mmorise la dernire caseBDEFZOOM=	5		; zoom gnral; Fanions pour OFLAGS; -------------------BFLAUTO	=	0		; automatiqueBFLLOAD	=	1		; dessusBFLCONT	=	2		; contour normalBFLBOLD	=	3		; contour grasBFLOR	=	4		; dessousBFLP1	=	8		; pas = 1BFLP2	=	9		; pas = 2BFLP4	=	10		; pas = 4BFLP8	=	11		; pas = 8BFLP16	=	12		; pas = 16BFLP32	=	13		; pas = 32; Codes des icnes de IDP20; -------------------------ICOVIDE	=	0		; demi-icne videICOSET	=	1		; allume les pointsICOCLEAR=	2		; teint les pointsICOCRAYON=	3		; crayonICOPINCEAU=	4		; pinceauICOREMPLI=	5		; rempliICOSPRAY=	6		; sprayICOOUTIL=	ICOSPRAY+1	; dernier outilICOTRAIT=	7		; trait  main leveICODROITE=	8		; droiteICORECTANGLE=	9		; rectangleICORRECTANGLE=	10		; rectangle arrondiICOCERCLE=	11		; cercleICOELLIPSE=	12		; ellipseICOTEXTE=	13		; texteICOSPLINE=	14		; splineICOMAIN	=	15		; mainICOSEP	=	16		; ligne de sparationICOBLOC1=	17		; bloc-notes 1ICOBLOC2=	18		; bloc-notes 2ICOBLOC3=	19		; bloc-notes 3ICOOBJET=	ICOBLOC3+1	; dernier objetICOZONE	=	20		; zone rectangulaireICOFILET=	21		; filetICOCROCHET=	22		; crochetICOSELECT=	ICOCROCHET+1ICOVZONE=	23		; zone visibleICOPLOUPE=	24		; petite loupeICORDEF	=	25		; dfinition rayon des rectanglesICOADEF	=	26		; dfinition des arcs de cercleICOFLAGS=	27		; mode pour le dessinICOGDEF	=	28		; dfinitions des caractresICOPDEF	=	30		; matrice du pinceauICOTDEF	=	31		; matrice de la trameICODEFORME=	32		; dformeICOBLOC	=	33		; bloc-notesICODETRUIT=	34		; dtruitICODEPLACE=	35		; dplaceICODUPLIQUE=	36		; dupliqueICOZOOM	=	37		; zoomICOTOURNE=	38		; tourneICOMIROIR=	39		; miroirICONEGATIF=	40		; ngatifICOLOUPE=	41		; grande loupeICOSAUVEP=	42		; sauvetage partielICORELIEF=	44		; reliefICOPERSP=	45		; perspectiveICOGRAS	=	46		; grasICOOMBRE=	47		; ombrICOZOOMAA=	48		; zoomsICOZOOMAI=	49		;ICOZOOMIA=	50		;ICOZOOMDD=	51		;ICOZOOMDI=	52		;ICOZOOMID=	53		;ICOTOURNE1=	54		; tournesICOTOURNE2=	55		;ICOTOURNE3=	56		;ICOMIROIRV=	57		; miroirsICOMIROIRH=	58		;ICOMIROIRX=	59		;ICOMIROIRY=	60		;ICOZOOMQQ=	61		; zoom "autre..."ICOTOURNEQQ=	62		; tourne "autre..."ICOPREND=	65		; prendICOAJOUTE=	66		; ajouteICOSAUVE=	67		; sauveICODEF	=	68		; df.ICOECHM	=	71		; chelle -ICOECH11=	72		; chelle 1:1ICOECHP	=	73		; chelle +ICOREGLE=	74		; rgleICONEG	=	76		; ngatifICOTOUT	=	77		; toutICOEFF	=	78		; effaceICOIMP	=	79		; imprimeICOCARM	=	80		; caractre +ICOCARP	=	81		; caractre -ICOCAR	=	82		; caractreICOLGVM	=	83		; largeur +ICOLGVP	=	84		; largeur -ICOLGV	=	85		; largeurICOSHLEFT=	86		; dcale  gaucheICOSHRIGHT=	87		; dcale  droiteICOSHUP	=	88		; dcale en hautICOSHDOWN=	89		; dcale en basICOMULM	=	90		; xn -ICOMULP	=	91		; xn +ICOMUL	=	92		; xnICOOPER	=	93		; operationICOMIN	=	94		; gnre les minuscules accentuesICOADDM	=	95		; additionne mme gencarICOADDA	=	96		; additionne autre gencarICOMACRO=	97		; enregistreICOPLAY	=	98		; rpteICOPLAYI=	99		; rpte  l'infiniICOCCRAYON=	102		; curseur: crayon (mode dessine)ICODCRAYON=	103		; curseur: crayon (mode efface chair)ICOECRAYON=	104		; curseur: crayon (mode efface fond)ICOCREMPLI=	105		; curseur: rempli (chair)ICOFREMPLI=	106		; curseur: rempli (fond)ICOCSPRAY=	107		; curseur: sprayICOCMAIN=	108		; curseur: main (chair)ICOFMAIN=	109		; curseur: main (fond)ICOEDEF	=	112		; Edgar: df.ICOECAR	=	113		; Edgar: car.ICOEECHP=	114		; Edgar: chelle petitICOEECHM=	115		; Edgar: chelle moyenICOEECHG=	116		; Edgar: chelle grandICOETOUT=	117		; Edgar: toutICOLITIMAGE=	118		; Edgar: lit imageICODEFORMETX=	120		; dformation trapze en XICODEFORMETY=	121		; dformation trapre en YICODEFORMEPX=	122		; dformation paralllogramme en XICODEFORMEPY=	123		; dformation paralllogramme en YICODEFORMEQQ=	124		; dformation quelconqueIS	=	1		; icne simple (largeur = GCICX/2)ID	=	2		; icne double (largeur = GCICX)IL	=	3		; passe  la ligneIC	=	4		; cale interligneIF	=	5		; fin; Poignes; --------BPOIHG	=	0		; poigne sup/gaucheBPOIHD	=	1		; poigne sup/droiteBPOIBG	=	2		; poigne inf/gaucheBPOIBD	=	3		; poigne inf/droite; En-tte d'un fichier .IMAGE; ---------------------------	.LOC	0;OIMTYP:.BLKB	1		; H'01 = indique type image;OIMCOD:.BLKB	1		; H'00 = indique pas de codage;OIMBIP:.BLKB	1		; H'01 = 1 bit par point;OIMDIR:.BLKB	1		; H'02 = coord. X-Y comme cran;OIMDLX:.BLKB	2		; largeur image en points;OIMDLY:.BLKB	2		; hauteur image en points;OIMNBB:.BLKB	4		; nb de byte pour l'image;	.BLKB	20		; rserve;LGHIMA:	.IF	DESSIN; En-tte d'un fichier .DDES; --------------------------	.LOC	0OFSCALE:.BLKB	2		; grande mat: chelle (1..n)OFPMOV:	.BLKB	4		; petite mat: offset zone visibleOFPMDI:	.BLKB	4		; petite mat: dimensionsOFOUTIL:.BLKB	1		; outil (crayon, pinceau, etc.)OFMODE:	.BLKB	1		; mode de dessin (peinture ou gomme)OFOBJET:.BLKB	1		; objet (trait, droite, cercle, etc.)OFSELECT:.BLKB	1		; slection (zone ou filet)	.EVENOFFLAGS:.BLKB	4		; flagsOFPAS:	.BLKB	2		; pas du dessin	.BLKB	26		; rserveOFNPDEF:.BLKB	2		; no trame du pinceauOFNTDEF:.BLKB	2		; no trame de remplissageOFPDEF:	.BLKB	32*(8+2)	; 32 x trames du pinceauOFTDEF:	.BLKB	32*8		; 32 x trames de remplissage	.BLKB	32*8		; rserveOFRRECT:.BLKB	2		; rayon des rectangles arrondisOFARC:	.BLKB	1		; arcs de cercle/ellipse	.EVEN	.BLKB	32		; rserveOFBUGC:	.BLKB	LGGC*MAXGC	; table des gnrateurs de caractresOFFAGC:	.BLKB	4		; fanions pour dbox des gencarsLGHDEF:	.ENDIF; Dfinition de l'entte d'un gnrateur de caractres; ----------------------------------------------------OGCH1	=	256+128*1	; 128 x h1OGCH2	=	256+128*2	; 128 x h2OGCMAT	=	256+128*3	; 128 x matrix; Variables d'un bloc-notes; -------------------------NBBLOC	=	3	.LOC	0OBLKPT:	.BLKB	4		; ^matrice du bloc-notesOBLKP1:	.BLKB	4		; P1(y;x)OBLKP2:	.BLKB	4		; P2(y;x)OBLKNBB:.BLKB	2		; nb bytes/ligneLGBLOC:	.IF	DESSIN; Variables pour les zones; ------------------------NBZONE	=	10	.LOC	0OZOPM:	.BLKB	4		; ^matriceOZOLY:	.BLKB	2		; hauteur (dy)OZOLX:	.BLKB	2		; largeur (dx)OZOSCA:	.BLKB	2		; chelleOZOOV:	.BLKB	4		; offset zone visibleOZODI:	.BLKB	4		; dimensions zone visibleOZONAM:	.BLKB	LBUFILE		; nom du dessinOZOMAJ:	.BLKB	1		; 1 => mise  jour ncessaire	.EVENLZO:	.ENDIF; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHDGENC:.BLKB	2		; canal module DGENCOCHDESSIN:.BLKB	2		; canal module DESSINOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHSPLINE:.BLKB	2		; canal module SPLINEOCHSTRETCH:.BLKB 2		; canal module STRETCHOPLCOM:	.BLKB	4		; ^ligne de commandeOPDDIS:	.BLKB	4		; ^descripteur de la fentreOSDDIS:	.BLKB	LGDIS6		; copie du descripteur de la fentreOQXDOT:	.BLKB	4		; adresse de GRA_QXDOTORASTER:.BLKB	4		; adresse de GRA_RASTEROTRAME:	.BLKB	4		; adresse de GRA_TRAMEOCLEAR:	.BLKB	4		; adresse de GRA_CLEAROSET:	.BLKB	4		; adresse de GRA_SETOINV:	.BLKB	4		; adresse de GRA_INVOCCMO:	.BLKB	1		; 1 => souris enleveOSREP:	.BLKB	1		; 1 => repres dessins	.EVENOPWDO:	.BLKB	2		; no swdo petite matrice	.IF	EDGAROAWDO:	.BLKB	2		; no swdo pour tous les caractres	.ENDIFOBUDIS:	.BLKB	400		; buffer write-displayOLUMAM:	.BLKB	200		; matrice(s) du lutin de la sourisOLUMAN:	.BLKB	200		; matrice(s) du lutin de la sourisOLUPX:	.BLKB	2		; centre du lutin en XOLUPY:	.BLKB	2		; centre du lutin en YOLUTIN:	.BLKB	1		; no lutin de la sourisOLUFLG:	.BLKB	1		; flags pour le lutin BLUMAN	=  0			;  0 => OLUMAM, 1 => OLUMAN	.EVENORNDPA:	.BLKB	4		; arrondi pour le pasOLASTD1:.BLKB	4		; dernire position pour dplace/dupliqueOLASTD2:.BLKB	4		; dernire position pour dplace/dupliqueOLASTXY:.BLKB	4		; dernire position X= et Y= afficheOMDCMI:	.BLKB	1		; dernire case: bouton du milieuOMDCDR:	.BLKB	1		; dernire case: bouton de droiteOMDCBN:	.BLKB	1		; dernire case: bloc-notesOMDCZM:	.BLKB	1		; dernire case: zoomOMDCTN:	.BLKB	1		; dernire case: tourneOMDCMR:	.BLKB	1		; dernire case: miroirOMDCDF:	.BLKB	1		; dernire case: dformeOMDCRF:	.BLKB	1		; dernire case: relief	.EVENODDPMA:	.BLKB	4		; dplace/duplique: ^matriceODDDIM:	.BLKB	4		; dplace/duplique: dimensionsODDNBB:	.BLKB	2		; dplace/duplique: nb bytes/ligneODDOP:	.BLKB	1		; dplace/duplique: opration (ICODEPLACE, etc.);	.EVENOMACHINE:.BLKB	1		; type de la machine (SMAKY8/SMAKY100)	.EVENOBUMAC:	.BLKB	LGMAC		; buffer pour enregistrer une macroOPTMAC:	.BLKB	2		; ^relatif dans OBUMACOPPMAC:	.BLKB	2		; ^relatif aux paramtresOMREC:	.BLKB	1		; 1 => macro en enregistrementOMPLAY:	.BLKB	1		; 1 => macro en excutionOMREP:	.BLKB	1		; 1 => excution  l'infini	.EVEN	.IF	DESSINONOZO:	.BLKB	2		; no de la zone visibleOTAZO:	.BLKB	LZO*NBZONE	; table des zones	.ENDIFOPICO:	.BLKB	4		; ^matrice des icnes de gaucheODICO:	.BLKB	4		; position des icnes de gaucheOPMAT:	.BLKB	4		; ^matriceOPMAC:	.BLKB	4		; ^matrice copie (pour UNDO)OPMAM:	.BLKB	4		; ^matrice masqueOMALMY:	.BLKB	2		; matrice: nb de points en YOMALMX:	.BLKB	2		; matrice: nb de points en XOMANBB:	.BLKB	2		; matrice: nb de bytes en XOMANBS:	.BLKB	2		; matrice: nb de bytes en X (source)OMANBD:	.BLKB	2		; matrice: nb de bytes en X (destination)OMALSY:	.BLKB	2		; matrice: nb de points en Y (si -OSCALE)OMALSX:	.BLKB	2		; matrice: nb de points en X (si -OSCALE)OMASTR:	.BLKB	1		; matrice: flags pour stretch BMASTR	=  0			;            stretch BMAHOM	=  1			;            homothtie	.EVENOGRPOY:	.BLKB	2		; grand rect: coin sup/gauche en YOGRPOX:	.BLKB	2		; grand rect: coin sup/gauche en XOGRDIY:	.BLKB	2		; grand rect: hauteurOGRDIX:	.BLKB	2		; grand rect: largeurOGMPOY:	.BLKB	2		; grande mat: coin sup/gauche en YOGMPOX:	.BLKB	2		; grande mat: coin sup/gauche en XOGMDIY:	.BLKB	2		; grande mat: hauteurOGMDIX:	.BLKB	2		; grande mat: largeurOGMOVY:	.BLKB	2		; grande mat: offset zone visible en YOGMOVX:	.BLKB	2		; grande mat: offset zone visible en XOGMLPY:	.BLKB	2		; grande mat: hauteur d'un point chelle nOGMLPX:	.BLKB	2		; grande mat: largeur d'un point chelle nOPRPOY:	.BLKB	2		; petit rect: coin sup/gauche en YOPRPOX:	.BLKB	2		; petit rect: coin sup/gauche en XOPRDIY:	.BLKB	2		; petit rect: hauteurOPRDIX:	.BLKB	2		; petit rect: largeurOPMPOY:	.BLKB	2		; petite mat: coin sup/gauche en YOPMPOX:	.BLKB	2		; petite mat: coin sup/gauche en XOPMDIY:	.BLKB	2		; petite mat: hauteurOPMDIX:	.BLKB	2		; petite mat: largeurOPMOVY:	.BLKB	2		; petite mat: offset zone visible en YOPMOVX:	.BLKB	2		; petite mat: offset zone visible en XODARK:	.BLKB	2		; foncOSCALE:	.BLKB	2		; grande mat: chelle (1..n)ODEF:	.BLKB	4		; dfinitionsOFLAGS:	.BLKB	4		; flagsOPAS:	.BLKB	2		; pas pour le dessinODD:	.BLKB	1		; mode de dplacementOREGLE:	.BLKB	1		; 1 => rgles prsentes	.EVEN	.IF	EDGAROALPOY:	.BLKB	2		; tout: coin sup/gauche en YOALPOX:	.BLKB	2		; tout: coin sup/gauche en XOALDIY:	.BLKB	2		; tout: hauteurOALDIX:	.BLKB	2		; tout: largeurOALNBY:	.BLKB	2		; tout: nb car visible en hauteurOALNBX:	.BLKB	2		; tout: nb car visible en largeur	.ENDIFOASVER:	.BLKB	LSCVAR		; variables de l'ascenseur verticalOASHOR:	.BLKB	LSCVAR		; variables de l'ascenseur horizontal	.IF	EDGAROALVER:	.BLKB	LSCVAR		; variables de l'ascenseur verticalOALHOR:	.BLKB	LSCVAR		; variables de l'ascenseur horizontal	.ENDIF	.IF	DESSINORGVAR:	.BLKB	LRGVAR		; variables des rgles	.ENDIFOLASTP1:.BLKB	4		; slection: P1 pour COPY-clicOLASTP2:.BLKB	4		; slection: P2 pour COPY-clicOSEOHG:	.BLKB	4		; slection: point original sup/gaucheOSEOHD:	.BLKB	4		; slection: point original sup/droiteOSEOBG:	.BLKB	4		; slection: point original inf/gaucheOSEOBD:	.BLKB	4		; slection: point original inf/droiteOSEPHG:	.BLKB	4		; slection: point courant sup/gaucheOSEPHD:	.BLKB	4		; slection: point courant sup/droiteOSEPBG:	.BLKB	4		; slection: point courant inf/gaucheOSEPBD:	.BLKB	4		; slection: point courant inf/droiteOSEPMI:	.BLKB	4		; slection: centre de symtrieOSEANG:	.BLKB	2		; slection: angle de la rotation [degrs]OSEBLX:	.BLKB	1		; slection: dplacement seulement en XOSEBLY:	.BLKB	1		; slection: dplacement seulement en Y	.EVENOMAJ:	.BLKB	1		; 1 => mise  jour ncessaireOOUTIL:	.BLKB	1		; outil (crayon, pinceau, etc.)OMODE:	.BLKB	1		; mode de dessin (peinture ou gomme)OOBJET:	.BLKB	1		; objet (trait, droite, cercle, etc.)OSELECT:.BLKB	1		; slection (zone ou filet)	.EVENONPDEF:	.BLKB	2		; no trame du pinceauONTDEF:	.BLKB	2		; no trame de remplissageONSDEF:	.BLKB	2		; no trame du sprayOPDEF:	.BLKB	MAXDEF*(8+2)	; trames du pinceauOTDEF:	.BLKB	MAXDEF*8	; trames de remplissageOSDEF:	.BLKB	8		; trame du sprayORRECT:	.BLKB	2		; rayon des rectangles arrondisOARC:	.BLKB	1		; arcs de cercle/ellipse	.EVENOBLOC:	.BLKB	LGBLOC*NBBLOC	; bloc-notesOSPLPT:	.BLKB	4*MAXSPLINE	; points pour splineOSTRETCH:.BLKB	ST_LGTRECT	; variables pour le module STRETCHOPOTEXT:.BLKB	4		; position ligne de texte en ditionOLGTEXT:.BLKB	2		; longueur de la ligneOLITEXT:.BLKB	200		; ligne de texte en ditionOACTEXT:.BLKB	1		; accent flottant en cours	.EVENOBUGC:	.BLKB	LGGC*MAXGC	; table des gnrateurs de caractresOGCLIST:.BLKB	MAXGENC*3	; liste des gencars contenus sur disqueOFAGC:	.BLKB	4		; fanions pour dbox des gencarsOBUNAME:.BLKB	LBUFILE		; nom du dessin/gencar en mmoireOBUFIN:	.BLKB	LBUFILE		; nom du fichier en entre (prend)OBUFAJ:	.BLKB	LBUFILE		; nom du fichier en entre (ajoute)OBUFOUT:.BLKB	LBUFILE		; nom du fichier en sortie	.IF	EDGAROBUFADD:.BLKB	LBUFILE		; nom du gencar secondaireOBUFIMA:.BLKB	LBUFILE		; nom de l'image lue	.ENDIFOBXFILE:.BLKB	LBUFILE		; nom du fichier avec extensionOBUHIMA:.BLKB	LGHIMA		; en-tte d'un fichier .image	.IF	DESSINOBUHDEF:.BLKB	LGHDEF		; en-tte d'un fichier .ddes	.ENDIF	.IF	EDGAROBUHEAD:.BLKB	OGCWID		; en-tte du gencarOBCHEAD:.BLKB	OGCWID		; en-tte du gencar secondaireOPGC:	.BLKB	4		; ^gencar en ditionOPIM:	.BLKB	4		; ^imageOCAR:	.BLKB	1		; caractre en dition	.EVENOSEPP1:	.BLKB	4		; P1(y;x) ligne de sparationOSEPP2:	.BLKB	4		; P2(y;x) ligne de sparationOMUL:	.BLKB	2		; xn	.ENDIF	.IF	DESSINOXZOOM:	.BLKB	2		; facteur de zoom spcial en X (*1000)OYZOOM:	.BLKB	2		; facteur de zoom spcial en Y (*1000)OBXZOOM:.BLKB	10		; buffer pour valeur de zoom en XOBYZOOM:.BLKB	10		; buffer pour valeur de zoom en Y	.ENDIF	.IF	DESSINOSTPRI:	.BLKB	LGPRI0		; status de l'imprimanteOFACX:	.BLKB	2		; facteur rduction en XOFACY:	.BLKB	2		; facteur rduction en YOMMX:	.BLKB	2		; nb de 1/10 de um pour un point en XOMMY:	.BLKB	2		; nb de 1/10 de um pour un point en Y	.ENDIFLGVAR:; Programme; ---------	.LOC	0	JUMP	START	.INS	DESTAB1.ASISTART:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CALL	_WAITMOUSE	; met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	LOAD.W	(A6)+OBUMAC,#-1	LOAD.B	(A6)+OGCLIST,#-1	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*4+50	JUMP,LO ERFAT2	.IF	DESSIN	CALL	RDSTPRINT	; lit le status de l'imprimante	.ENDIF	LOAD.L	A3,#R16"TXERFATDIS	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT2	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	LOAD.L	A3,#R16"TXERFATTXT	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATICO	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A1,#R16"TXERFATGRA	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OQXDOT,A3	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+ORASTER,A3	LOAD.W	D3,#GRA_TRAME	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OTRAME,A3	LOAD.W	D3,#GRA_CLEAR	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OCLEAR,A3	LOAD.W	D3,#GRA_SET	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OSET,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OINV,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMDGENC	LOAD.W	D3,#DGENC_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDGENC,D1	LOAD.L	A3,#R16"NMDESSIN	LOAD.W	D3,#DESSIN_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDESSIN,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMSPLINE	LOAD.W	D3,#SPLINE_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSPLINE,D1	LOAD.L	A3,#R16"NMSTRETCH	LOAD.W	D3,#ST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSTRETCH,D1	LOAD.B	(A6)+OMODE,#ICOSET	LOAD.B	(A6)+OOUTIL,#ICOCRAYON	LOAD.B	(A6)+OOBJET,#ICOTRAIT	LOAD.B	(A6)+OSELECT,#ICOZONE	LOAD.L	(A6)+ODEF,#2^BDEFPG!2^BDEFICO!2^BDEFASC	LOAD.L	(A6)+OFLAGS,#2^BFLP1!2^BFLAUTO	LOAD.W	(A6)+OPAS,#1	LOAD.L	A3,#R16"TXERFATMEM	CALL	CALCADRE	; calcul pos/dim du grand rectangle	.IF	DESSIN	LOAD.W	D3,(A6)+OGRDIX	; D3 <-- largeur visible	LOAD.W	D4,(A6)+OGRDIY	; D4 <-- hauteur visible	.ELSE	LOAD.W	D3,#32		; D3 <-- largeur visible	LOAD.W	D4,#32		; D4 <-- hauteur visible	.ENDIF	CALL	GETMEMMATRIX	; rserve mmoire pour matrices	JUMP,NE ERFAT2	CALL	_DEFGENCAR	; utilise tous les gencars par dfaut	.IF	DESSIN	LOAD.W	D4,#SCALE11	.ELSE	LOAD.W	D4,#SCALELOUPE	.ENDIF	LOAD.W	(A6)+OSCALE,D4	CALL	CALSCALE	; met l'chelle par dfaut	LOAD.W	(A6)+ODARK,#1	LOAD.L	A3,#(A6)+OPDEF	CLR.W	D4	DESSIN_	DGET	LOAD.W	D4,#((MAXDEF*(8+2))/2)-150$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,50$	LOAD.L	A3,#(A6)+OTDEF	CLR.W	D4	DESSIN_	TGET	LOAD.W	D4,#((MAXDEF*8)/2)-152$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,52$	LOAD.L	A3,#(A6)+OSDEF	LOAD.L	A4,#R16"TSDEF	LOAD.W	D4,#((1*8)/2)-154$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,54$	LOAD.W	(A6)+ONPDEF,#8	; utilise trame pinceau par dfaut	.IF	DESSIN	LOAD.W	(A6)+ONTDEF,#3	; utilise trame remplissage par dfaut	.ELSE	LOAD.W	(A6)+ONTDEF,#7	; utilise trame remplissage par dfaut	.ENDIF	CLR.W	(A6)+ONSDEF	; utilise trame spray par dfaut	LOAD.W	(A6)+ORRECT,#8	LOAD.B	(A6)+OARC,#2^BARC1	CALL	_CCMO		; enlve la souris	CALL	DESWDO	CALL	DESCADRE	.IF	EDGAR	LOAD.B	D3,#'A	CALL	CARSELECT	; montre le caractre "A"	LOAD.W	(A6)+OMUL,#1	CALL	DESMUL	.ENDIF	CALL	_AFMENU		; affiche les soft-keys	LIB	?BUZZ		; signal: c'est prt !	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SKPNAM	JUMP,NE LOOP	LOAD.L	A4,#(A6)+OBUFIN70$:	LOAD.B	D3,(A3+)	JUMP',EQ 75$	COMP.B	D3,#CR	JUMP',EQ 75$	COMP.B	D3,#SPACE	JUMP',EQ 75$	COMP.B	D3,#TAB	JUMP',EQ 75$	COMP.B	D3,#'/	JUMP',EQ 75$	LOAD.B	(A4+),D3	; OBUFIN <-- nom ligne de commande	JUMP	70$75$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUFIN	; A3 <-- ^nom	JUMP	PRENDF		; essaye de prendre ce fichier ...LOOP:	TEST.B	(A6)+OMPLAY	; macro en excution ?	JUMP',F 50$		; non => 50$				; oui =>	CALL	_GETMACRO	; D3 <-- touche enregistre	JUMP,EQ EXECUTE	CALL	_ABORTMACRO	; stoppe la macro	TEST.B	(A6)+OMREP	; excute  l'infini ?	JUMP,F	LOOP		; non => LOOP20$:	LIB	?IFCAR	JUMP',NE 30$	COMP.W	D3,#END		; touche (END) presse ?	JUMP,EQ LOOP		; oui => LOOP	JUMP	20$30$:	JUMP	MACROPLAYI	; on recommence  l'infini50$:	.IF	EDGAR	CALL	SETREPERE	; dessine les repres	.ENDIF	CALL	_SCMO		; remet la souris	CALL	_NORMMOUSE	; enlve le sablier60$:	LOAD.B	D3,(A6)+OOUTIL	CALL	_SELMO		; utilise le bon lutin	.IF	DESSIN	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP',NE 62$	CALL	RGMOUSE		; dessine la position dans les rgles	.ENDIF	TEST.L	(A6)+OPOTEXT	; ligne de texte en dition ?	JUMP',NE 70$		; oui => 70$ ( cause du curseur)	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP',NE 62$	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP',EQ 64$62$:	LOAD.L	D3,#-1		; D3 <-- on est pas dans l'aire de dessin64$:	COMP.L	D3,(A6)+OLASTXY	JUMP',EQ 70$	LOAD.L	(A6)+OLASTXY,D3	CALL	DESINFXY	; affiche X= et Y= dans les informations70$:	LIB	?GETKEY		; attend clavier/souris ...	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP,BS 70$		; non => 70$				; oui =>	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ 60$		; oui => 60$EXECUTE:	COMP.W	D3,#F0+SHIFT	JUMP',LO 10$	COMP.W	D3,#F15+SHIFT	JUMP',HI 10$	SUB.W	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)10$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP	TEST.B	(A6)+OMREC	; macro en enregistrement ?	JUMP',F 20$		; non => 20$	CALL	_PUTMACRO	; oui => enregistre	JUMP,NE ERROR20$:	.IF	EDGAR	COMP.W	D3,#KEYICO+ICOMACRO	JUMP,EQ MACROSTARTSTOP	COMP.W	D3,#H'100*(2^BPROGRA)+MACRO	JUMP,EQ MACROSTARTSTOP	COMP.W	D3,#KEYICO+ICOPLAY	JUMP,EQ MACROPLAY	COMP.W	D3,#MACRO	JUMP,EQ MACROPLAY	COMP.W	D3,#KEYICO+ICOPLAYI	JUMP,EQ MACROPLAYI	COMP.W	D3,#H'100*(2^BCURSOR)+MACRO	JUMP,EQ MACROPLAYI	.ENDIF	COMP.W	D3,#KEYICO+ICODETRUIT	JUMP,EQ MACRODETRUIT	COMP.W	D3,#KEYICO+ICODEPLACE	JUMP,EQ MACRODEPLACE	COMP.W	D3,#KEYICO+ICODUPLIQUE	JUMP,EQ MACRODUPLIQUE	COMP.W	D3,#KEYICO+ICOBLOC	JUMP,EQ MACROBLOC	COMP.W	D3,#KEYICO+ICOBLOC1	JUMP,EQ MACROBLOCNOTES	COMP.W	D3,#KEYICO+ICOBLOC2	JUMP,EQ MACROBLOCNOTES	COMP.W	D3,#KEYICO+ICOBLOC3	JUMP,EQ MACROBLOCNOTES	COMP.W	D3,#KEYICO+ICOZOOM	JUMP,EQ MACROZOOM	COMP.W	D3,#KEYICO+ICOTOURNE	JUMP,EQ MACROTOURNE	COMP.W	D3,#KEYICO+ICOMIROIR	JUMP,EQ MACROMIROIR	COMP.W	D3,#KEYICO+ICONEGATIF	JUMP,EQ MACRONEGATIF	COMP.W	D3,#KEYICO+ICORELIEF	JUMP,EQ MACRORELIEF	COMP.W	D3,#KEYICO+ICOOBJET	JUMP,EQ MACROCOMMEPLAN	COMP.W	D3,#KEYICO+ICOREMPLI	JUMP,EQ MACROREMPLI	COMP.W	D3,#KEYICO+ICODEFORME	JUMP,EQ MACRODEFORME	COMP.W	D3,#CR	JUMP,EQ ALALIGNE	COMP.W	D3,#DEL	JUMP,EQ ANNULE	COMP.W	D3,#BS	JUMP,EQ ANNULE	COMP.W	D3,#DELETE	JUMP,EQ ANNULE	COMP.W	D3,#POINT	JUMP',NE 30$	LOAD.W	D3,#'.30$:	COMP.W	D3,#TRIZERO	JUMP',NE 32$	LOAD.W	D3,#'0	LIB	?WRKEY		; <<< faudra faire mieux une fois !	LIB	?WRKEY32$:	TEST.L	(A6)+OPOTEXT	; ligne de texte en dition ?	JUMP',EQ 35$		; non => 35$	COMP.W	D3,#'	JUMP',LO 35$	COMP.W	D3,#H'7F	JUMP,LO FRAPPE35$:	CALL	_CLOTEXTE	; si texte en dition => termine	LOAD.L	A4,#R16"TAKEY-4	LOAD.W	D2,D3	COMP.B	D2,#'a	JUMP',LO 40$	COMP.B	D2,#'z	JUMP',HI 40$	SUB.B	D2,#'a-'A	; D2 <-- lettre MAJUSCULE40$:	ADD.L	A4,#4	TEST.W	(A4)+0	JUMP',EQ 42$	COMP.W	D2,(A4)+0	JUMP,NE 40$	LOAD.W	D3,(A4)+2	JUMP	CLICICONE42$:	LOAD.L	D4,#SCROLLFUP!2^16	COMP.W	D2,#H'100*(2^BSHOW)+'R	JUMP,EQ CLICAV	LOAD.L	D4,#SCROLLPUP!2^16	COMP.W	D2,#H'100*(2^BSHOW)+'E	JUMP,EQ CLICAV	LOAD.L	D4,#SCROLLFDOWN!2^16	COMP.W	D2,#H'100*(2^BSHOW)+'C	JUMP,EQ CLICAV	LOAD.L	D4,#SCROLLPDOWN!2^16	COMP.W	D2,#H'100*(2^BSHOW)+'X	JUMP,EQ CLICAV	LOAD.L	D4,#SCROLLFUP!2^16	COMP.W	D2,#H'100*(2^BSHOW)+'D	JUMP,EQ CLICAH	LOAD.L	D4,#SCROLLPUP!2^16	COMP.W	D2,#H'100*(2^BSHOW)+'S	JUMP,EQ CLICAH	LOAD.L	D4,#SCROLLFDOWN!2^16	COMP.W	D2,#H'100*(2^BSHOW)+'F	JUMP,EQ CLICAH	LOAD.L	D4,#SCROLLPDOWN!2^16	COMP.W	D2,#H'100*(2^BSHOW)+'G	JUMP,EQ CLICAH	COMP.W	D3,#UNDO	JUMP,EQ EXUNDO	COMP.W	D3,#HELP	JUMP,EQ DOHELP	.IF	DESSIN	COMP.W	D3,#KEYICO+ICOVZONE	JUMP,EQ MENUZONE	.ENDIF	COMP.W	D3,#KEYICO+ICOFLAGS	JUMP,EQ MENUFLAGS	COMP.W	D3,#KEYICO+ICOPDEF	JUMP,EQ MODIFPDEF	COMP.W	D3,#KEYICO+ICOTDEF	JUMP,EQ MODIFTDEF	COMP.W	D3,#KEYICO+ICORDEF	JUMP,EQ MODIFRDEF	COMP.W	D3,#KEYICO+ICOADEF	JUMP,EQ MODIFADEF	COMP.W	D3,#KEYICO+ICOGDEF	JUMP,EQ MODIFGDEF	.IF	EDGAR	COMP.W	D3,#SCR	JUMP,EQ CHANGECARM	COMP.W	D3,#KEYICO+ICOCARM	JUMP,EQ CHANGECARM	COMP.W	D3,#KEYICO+ICOCARP	JUMP,EQ CHANGECARP	COMP.W	D3,#KEYICO+ICOCAR	JUMP,EQ ALLCAR	COMP.W	D3,#KEYICO+ICOMULM	JUMP,EQ CHANGEMULM	COMP.W	D3,#KEYICO+ICOMULP	JUMP,EQ CHANGEMULP	COMP.W	D3,#KEYICO+ICOMUL	JUMP,EQ CHANGEMUL	COMP.W	D3,#KEYICO+ICOSHLEFT	JUMP,EQ SHIFTCAR	COMP.W	D3,#KEYICO+ICOSHRIGHT	JUMP,EQ SHIFTCAR	COMP.W	D3,#KEYICO+ICOSHUP	JUMP,EQ SHIFTCAR	COMP.W	D3,#KEYICO+ICOSHDOWN	JUMP,EQ SHIFTCAR	COMP.W	D3,#KEYICO+ICOLGVM	JUMP,EQ LARGECARM	COMP.W	D3,#KEYICO+ICOLGVP	JUMP,EQ LARGECARP	COMP.W	D3,#KEYICO+ICOLGV	JUMP,EQ LARGECAR	COMP.W	D3,#KEYICO+ICOADDM	JUMP,EQ ADDMCAR	COMP.W	D3,#KEYICO+ICOADDA	JUMP,EQ PRENDAUTRE	COMP.W	D3,#KEYICO+ICOOPER	JUMP,EQ OPERCAR	COMP.W	D3,#KEYICO+ICOMIN	JUMP,EQ OPERMIN	COMP.W	D3,#F5	JUMP,EQ CHANGECAR	COMP.W	D3,#F13	JUMP,EQ ALLCAR	COMP.W	D3,#KEYICO+ICOPLOUPE	JUMP,EQ ALLCAR	.ENDIF	COMP.W	D3,#F0	JUMP,EQ FINI	COMP.W	D3,#END	JUMP,EQ FINI	COMP.W	D3,#F1	JUMP,EQ PREND	COMP.W	D3,#H'100*(2^BSHOW)+DEFINE	JUMP,EQ PREND	.IF	DESSIN	COMP.W	D3,#F2	JUMP,EQ AJOUTE	.ELSE	COMP.W	D3,#F2	JUMP,EQ AJOUTEIMAGE	.ENDIF	COMP.W	D3,#F3	JUMP,EQ SAUVE	COMP.W	D3,#H'100*(2^BCOPY)+DEFINE	JUMP,EQ SAUVE	COMP.W	D3,#F4	JUMP,EQ MODIFDEF	.IF	DESSIN	COMP.W	D3,#F5	JUMP,EQ MODIFZOOM	.ENDIF	.IF	DESSIN	COMP.W	D3,#KEYICO+ICOPLOUPE	JUMP,EQ SCALEFLIP	COMP.W	D3,#F8	JUMP,EQ SCALEUNUN	COMP.W	D3,#F7	JUMP,EQ SCALEMOINS	COMP.W	D3,#F9	JUMP,EQ SCALEPLUS	COMP.W	D3,#F13	JUMP,EQ SCALETOUT	.ELSE	COMP.W	D3,#F7	JUMP,EQ SCALEPETIT	COMP.W	D3,#F8	JUMP,EQ SCALEMOYEN	COMP.W	D3,#F9	JUMP,EQ SCALEGRAND	.ENDIF	.IF	DESSIN	COMP.W	D3,#F10	JUMP,EQ DMOINS	COMP.W	D3,#F11	JUMP,EQ DNORM	COMP.W	D3,#F12	JUMP,EQ DPLUS	.ENDIF;;?	COMP.W	D3,#F13;;?	JUMP,EQ REFAIT	COMP.W	D3,#F14	JUMP,EQ EFFACE	.IF	DESSIN	COMP.W	D3,#F15	JUMP,EQ IMPRIME	.ENDIF	.IF	DESSIN	COMP.W	D3,#H'100*(2^BSHOW)+'0	JUMP',LO 60$	COMP.W	D3,#H'100*(2^BSHOW)+'9	JUMP,LS SHOWZONE60$:	.ENDIF	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC	JUMP	BIPMACROSTARTSTOP:	CALL	_STARTSTOPMACRO	JUMP,NE ERROR	JUMP	LOOPMACROPLAY:	CALL	_PLAYMACRO	JUMP,NE ERROR	JUMP	LOOPMACROPLAYI:	CALL	_PLAYIMACRO	JUMP,NE ERROR	JUMP	LOOPCLIC:	LOAD.W	D2,D3		; D2 <-- bouton press	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D1,D4		; D1 <-- position de la souris; Traite le cas o la souris est dans un ascenseur.	TEST.B	(A6)+ODEF+3:#BDEFASC	JUMP,BC CLICIC	LOAD.L	A5,#(A6)+OASVER	TEST.W	(A5)+OSCHTV	JUMP',EQ CLICA	LOAD.W	(A5)+OSCPOSV,(A6)+OGMOVY	SCROLL_	MOVE		; dans ascenseur vertical ?	JUMP',NE CLICA	TCLR.L	D4:#16		; D4 <-- avec rptitionCLICAV:	LOAD.L	A5,#(A6)+OASVER	TEST.W	(A5)+OSCHTV	JUMP,EQ BIP	CALL	ASCMOVEV	; dplace l'ascenseur vertical ...	JUMP	LOOPCLICA:	LOAD.L	D4,D1		; D4 <-- position de la souris	LOAD.L	A5,#(A6)+OASHOR	TEST.W	(A5)+OSCHTV	JUMP',EQ CLICIC	LOAD.W	(A5)+OSCPOSV,(A6)+OGMOVX	SCROLL_	MOVE		; dans ascenseur horizontal ?	JUMP',NE CLICIC	TCLR.L	D4:#16		; D4 <-- avec rptitionCLICAH:	LOAD.L	A5,#(A6)+OASHOR	TEST.W	(A5)+OSCHTV	JUMP,EQ BIP	CALL	ASCMOVEH	; dplace l'ascenseur horizontal ...	JUMP	LOOP; Traite le cas o la souris est dans une icne.CLICIC:	LOAD.L	D4,D1		; D4 <-- position de la souris	CALL	DETICONE	; souris dans une icne ?	JUMP,NE 50$		; non => 50$	LOAD.B	D5,D3	JUMP'	34$32$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 35$		; non => 35$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 32$	CALL	DETICONE	; D3 <-- icne o est la souris	JUMP,NE 32$	COMP.B	D3,D5	JUMP,EQ 32$	EX.L	D3,D5	CALL	INVICONE	; teint l'ancienne icne34$:	LOAD.B	D3,D5	CALL	INVICONE	; allume la nouvelle icne	JUMP	32$35$:	LOAD.B	D3,D5	CALL	INVICONE	; teint l'ancienne icne	JUMP	CLICICONE50$:	LOAD.W	D3,D2		; D3 <-- bouton press	COMP.W	D3,#KEYMGP	JUMP,EQ OUTIL	COMP.W	D3,#KEYMMP	JUMP,EQ MILIEU	COMP.W	D3,#KEYMDP	JUMP,EQ ENTOURE	JUMP	BIPCLICICONE:	.IF	DESSIN	COMP.B	D3,#ICOVZONE	JUMP,EQ	PRESSKEY	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NS SCALEUNUN	; oui => remet l'chelle 1:1	.ENDIF	COMP.B	D3,#ICOVIDE	JUMP,EQ BIP	COMP.B	D3,#ICOSET	JUMP,EQ MODENEW	COMP.B	D3,#ICOCLEAR	JUMP,EQ MODECLEAR	COMP.B	D3,#ICOMAIN	JUMP,EQ MAINNEW	COMP.B	D3,#ICOOUTIL	JUMP,LO OUTILNEW	COMP.B	D3,#ICOOBJET	JUMP,LO OBJETNEW	COMP.B	D3,#ICOSELECT	JUMP,LO SELECTNEW	JUMP	PRESSKEYMODECLEAR:			; tente de mettre le mode "teint" =>	COMP.B	(A6)+OOUTIL,#ICOREMPLI	JUMP,EQ BIPMODENEW:			; change de mode =>	COMP.B	D3,(A6)+OMODE	JUMP,EQ LOOP	PUSH.W	D3	LOAD.B	D3,(A6)+OMODE	CALL	INVICONE	; teint l'ancien mode	POP.W	D3	LOAD.B	(A6)+OMODE,D3	CALL	INVICONE	; allume le nouveau mode	COMP.B	(A6)+OOUTIL,#ICOMAIN	JUMP,NE LOOP	LOAD.B	D3,#ICOCRAYON	JUMP	OUTILNEWMAINNEW:	TEST.W	(A6)+OASVER+OSCHTV	JUMP',NE OUTILNEW	TEST.W	(A6)+OASHOR+OSCHTV	JUMP',NE OUTILNEW	JUMP	BIP		; si aucun ascenseur => BIPOUTILNEW:			; change d'outil =>	COMP.B	D3,(A6)+OOUTIL	JUMP,EQ LOOP	PUSH.W	D3	LOAD.B	D3,(A6)+OOUTIL	CALL	INVICONE	; teint l'ancien outil	POP.W	D3	LOAD.B	(A6)+OOUTIL,D3	CALL	INVICONE	; allume le nouvel outil	COMP.B	D3,#ICOMAIN	JUMP,EQ 40$	COMP.B	D3,#ICOREMPLI	JUMP,EQ 35$	COMP.B	D3,#ICOSPRAY	JUMP,NE 50$30$:				; vaporisateur =>	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; teint l'ancien objet	CLR.B	(A6)+OOBJET	TEST.B	(A6)+OMODE	JUMP,NE LOOP	LOAD.B	D3,#ICOSET	JUMP	MODENEW35$:				; bidon de peinture =>	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; teint l'ancien objet	CLR.B	(A6)+OOBJET				; force le mode "allume" =>	LOAD.B	D3,#ICOSET	COMP.B	D3,(A6)+OMODE	JUMP,EQ LOOP	JUMP	MODENEW40$:				; main =>	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; teint l'ancien objet	CLR.B	(A6)+OOBJET	LOAD.B	D3,(A6)+OMODE	CALL	INVICONE	; teint l'ancien mode	CLR.B	(A6)+OMODE	JUMP	LOOP50$:	TEST.B	(A6)+OMODE	; y'a-t-il un mode slectionn ?	JUMP',NE 55$		; oui => 55$	LOAD.B	D3,#ICOSET	CALL	INVICONE	; allume le mode par dfaut	LOAD.B	(A6)+OMODE,D355$:	LOAD.B	D3,(A6)+OOBJET	; y'a-t-il un objet slectionn ?	JUMP',EQ 60$		; non => 60$	COMP.B	D3,#ICOBLOC1	JUMP',EQ 60$	COMP.B	D3,#ICOBLOC2	JUMP',EQ 60$	COMP.B	D3,#ICOBLOC3	JUMP',EQ 60$	COMP.B	D3,#ICOTEXTE	JUMP,NE LOOP60$:	LOAD.B	D3,#ICOTRAIT	JUMP	OBJETNEW	; utilise l'objet traitOUTILNIL:			; y'a plus d'outil =>	TEST.B	(A6)+OOUTIL	JUMP,EQ LOOP	LOAD.B	D3,(A6)+OOUTIL	CALL	INVICONE	; teint l'ancien outil	CLR.B	(A6)+OOUTIL	JUMP	LOOPOBJETNEW:			; change d'objet =>	COMP.B	D3,(A6)+OOBJET	JUMP,EQ LOOP	COMP.B	D3,#ICOBLOC1	JUMP',LO 20$	COMP.B	D3,#ICOBLOC3	JUMP',HI 20$				; bloc-notes =>	LOAD.L	A4,#(A6)+OBLOC	CLR.W	D4	LOAD.B	D4,D3	SUB.B	D4,#ICOBLOC1	MUL.WU	D4,#LGBLOC	ADD.L	A4,D4		; A4 <-- ^bloc-notes	TEST.L	(A4)+OBLKPT	; bloc-notes contient qq chose ?	JUMP,EQ BIP		; non => BIP20$:	PUSH.W	D3	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; teint l'ancien objet	POP.W	D3	LOAD.B	(A6)+OOBJET,D3	CALL	INVICONE	; allume le nouvel objet	PUSH.W	D3	TEST.B	(A6)+OMODE	; y'a-t-il un mode slectionn ?	JUMP',NE 30$		; oui => 30$	LOAD.B	D3,#ICOSET	CALL	INVICONE	; allume le mode par dfaut	LOAD.B	(A6)+OMODE,D330$:	POP.W	D3	COMP.B	D3,#ICOTEXTE	JUMP,EQ OUTILNIL	COMP.B	D3,#ICOBLOC1	JUMP,EQ OUTILNIL	COMP.B	D3,#ICOBLOC2	JUMP,EQ OUTILNIL	COMP.B	D3,#ICOBLOC3	JUMP,EQ OUTILNIL	LOAD.B	D3,(A6)+OOUTIL	COMP.B	D3,#ICOREMPLI	JUMP',EQ 50$	COMP.B	D3,#ICOSPRAY	JUMP',EQ 50$	COMP.B	D3,#ICOMAIN	JUMP',EQ 50$	TEST.B	D3	JUMP,NE LOOP50$:	LOAD.B	D3,#ICOCRAYON	JUMP	OUTILNEW	; utilise l'outil crayonSELECTNEW:	COMP.B	D3,(A6)+OSELECT	JUMP,EQ LOOP	PUSH.W	D3	LOAD.B	D3,(A6)+OSELECT	CALL	INVICONE	; teint l'ancienne slection	POP.W	D3	LOAD.B	(A6)+OSELECT,D3	CALL	INVICONE	; allume la nouvelle slection	JUMP	LOOPPRESSKEY:			; clic icne => touche presse	AND.W	D3,#H'FF	OR.W	D3,#KEYICO	; D3 <-- code "touche" presse	JUMP	EXECUTEOUTIL:	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NS BIP		; oui => BIP				; non =>	LOAD.B	D3,(A6)+OOUTIL	; D3 <-- outil	COMP.B	D3,#ICOREMPLI	JUMP,EQ REMPLI	COMP.B	D3,#ICOSPRAY	JUMP,EQ SPRAY	COMP.B	D3,#ICOMAIN	JUMP,EQ MAIN	LOAD.B	D3,(A6)+OOBJET	; D3 <-- objet	COMP.B	D3,#ICOTRAIT	JUMP,EQ TRAIT	COMP.B	D3,#ICOSPLINE	JUMP,EQ SPLINE	COMP.B	D3,#ICODROITE	JUMP,EQ COMMEPLAN	COMP.B	D3,#ICOCERCLE	JUMP,EQ COMMEPLAN	COMP.B	D3,#ICOELLIPSE	JUMP,EQ COMMEPLAN	COMP.B	D3,#ICORECTANGLE	JUMP,EQ COMMEPLAN	COMP.B	D3,#ICORRECTANGLE	JUMP,EQ COMMEPLAN	COMP.B	D3,#ICOTEXTE	JUMP,EQ TEXTE	COMP.B	D3,#ICOBLOC1	JUMP,EQ BLOCNOTES	COMP.B	D3,#ICOBLOC2	JUMP,EQ BLOCNOTES	COMP.B	D3,#ICOBLOC3	JUMP,EQ BLOCNOTES	.IF	EDGAR	COMP.B	D3,#ICOSEP	JUMP,EQ SEP	.ENDIF	JUMP	BIPTRAIT:	LOAD.W	D2,#CLRDOT	COMP.B	(A6)+OMODE,#ICOCLEAR	JUMP',EQ 10$	LOAD.W	D2,#SETDOT10$:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	D5,D3		; D5 <-- origine	CLR.W	D0		; D0 <-- souris pas bouge20$:	CALL	_SCOMO	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 60$		; non => 60$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	.IF	DESSIN	CALL	RGMOUSE		; dessine la position dans les rgles	.ENDIF	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE 20$	COMP.L	D3,D5		; souris dplace ?	JUMP,EQ 20$		; non => 20$				; oui =>	LOAD.L	D6,D3		; D6 <-- arrive	CALL	DESCOMMEPLAN	; petit: dessine droite de "origine"  "arrive"	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim de la droite	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE 30$	CALL	CPECRANMATRIX	; matrice principale <-- cran	JUMP'	35$30$:	CLR.L	D1		; D1 <-- pas de dplacement	CALL	SHOGMATRIX	; grand: dessine aussi la droite35$:	LOAD.L	D5,D6		; D5 <-- future origine	OR.W	D2,#NCTDOT	; D2 <-- plus de rz traitill	INC.W	D0		; D0 <-- souris bouge	JUMP	20$60$:	TEST.W	D0		; souris bouge ?	JUMP,NE LOOP		; oui => LOOP				; non =>NOIRBLANC:	LOAD.L	D3,D5		; D3 <-- position	LOAD.W	D2,#INVDOT	LOAD.W	D1,#1	CALL	DESGPOINT	; allume/teint point dans grande matrice	CALL	DESPPOINT	; allume/teint point dans petite matrice	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	CALL	TESTPOINT	TNOT.B	(A1):D1		; allume/teint point dans matrice principale	JUMP	LOOPMACROREMPLI:	CALL	GETPARAM	; D0..D6 <-- paramtres	LOAD.L	D3,D0	JUMP	OPERREMPLIREMPLI:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE BIPOPERREMPLI:	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	A4,(A6)+OPMAT	CALL	_OPEDISMAT	; dessine dans la matrice principale	LOAD.L	D0,D3	LOAD.L	A4,#(A6)+OTDEF	LOAD.W	D4,(A6)+ONTDEF	MUL.WU	D4,#8	ADD.L	A4,D4		; A4 <-- ^bonne trame	LOAD.L	D3,(A4)+0	LOAD.L	D4,(A4)+4	LIB	?DRMDEF		; dfinit une trame pleine	LOAD.L	D3,D0	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	CALL	TESTPOINT	TEST.B	(A1):D1	JUMP',BS 40$				; point initial teint =>	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWFILLO	LOAD.L	D3,D0	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.B	(A3)+5,#DRAWFILLC	LOAD.W	D3,#5+1	LIB	?STRING		; rempli ...	JUMP'	50$40$:				; point initial allum =>	NOT.L	(A0)+ODFTRA+0	NOT.L	(A0)+ODFTRA+4	; inverse la trame !	LOAD.L	A4,(A6)+OPMAT	CALL	_INVALL		; inverse tout	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWFILLO	LOAD.L	D3,D0	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.B	(A3)+5,#DRAWFILLC	LOAD.W	D3,#5+1	LIB	?STRING		; rempli ...	PUSH.W	D7	CALL	_INVALL		; inverse tout	POP.W	D750$:	PUSH.W	D7	CALL	_CLODISMAT	; redessine dans l'cran	POP.W	D7	JUMP,NE BIGBIP	CALL	DESMATRIX	; dessine les deux matrices	LOAD.W	D4,#KEYICO+ICOREMPLI	CALL	PUTPARAM	; macro <-- paramtres	JUMP,NE ERROR	JUMP	LOOPSPRAY:	LOAD.W	D2,#SETDOT	COMP.B	(A6)+OMODE,#ICOSET	JUMP',EQ 10$	LOAD.W	D2,#CLRDOT10$:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	A4,#R16"00$	JUMP'	28$20$:	CALL	_SCOMO		; remet la souris	LOAD.W	D4,#2	NTREL	?SETTIM		; met timeout trs court	LIB	?GETKEY		; qq chose tout de suite ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	JUMP',EQ 25$		; oui => 25$				; non =>	TEST.L	(A4)		; fin de la table ?	JUMP',EQ 23$		; oui => 23$	LOAD.L	D3,D1		; D3 <-- "centre"	SWAP.W	D3	ADD.W	D3,(A4+)	; D3 <-- dviation en Y	SWAP.W	D3	ADD.W	D3,(A4+)	; D3 <-- dviation en X	JUMP'	30$23$:	LIB	?GETKEY		; attend souris ...25$:	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE LOOP		; non => LOOP	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	.IF	DESSIN	CALL	RGMOUSE		; dessine la position dans les rgles	.ENDIF	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE 20$28$:	LOAD.L	A4,#R16"00$	LOAD.L	D1,D3		; D1 <-- "centre"30$:				; oui =>	LOAD.L	A3,#(A6)+OSDEF	; A3 <-- ^matrice du spray	CALL	DESSPRAY	; dessine selon le spray	JUMP	20$00$:	.W	-2,-3	.W	1,2	.W	1,-1	.W	-3,1	.W	-2,-1	.W	2,0	.W	-1,1	.W	0,-2	.W	-2,1		; 10	.W	-1,-2	.W	0,1	.W	-3,-2	.W	1,-2	.W	-1,0	.W	-2,2	.W	0,-1	.W	-2,0	.W	1,1	.W	-1,-1		; 20	.W	-4,0	.W	2,-3	.W	-1,2	.W	-1,-4	.W	3,-1	.W	-2,-2	.W	-3,2	.W	0,-3	.W	1,3	.W	1,0		; 30	.W	-3,-1	.W	0,-4	.W	2,1	.W	-4,-2	.W	2,-1	.W	-2,3	.W	1,-3	.W	0,2	.W	3,0	.W	-1,3		; 40	.W	2,2	.W	-1,-3	.W	1,-4	.W	0,3	.W	-3,0	.W	2,-2	.W	3,1	.W	-3,-3	.W	-4,1	.W	3,-2		; 50	.W	-2,-4	.W	-4,-1	.W	0,0MAIN:	TEST.W	(A6)+OASVER+OSCHTV	JUMP',NE 10$	TEST.W	(A6)+OASHOR+OSCHTV	JUMP,EQ BIP10$:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	LOAD.L	D2,D3		; D2 <-- rfrence	LOAD.L	D1,(A6)+OGMOVY	LOAD.L	D0,(A6)+OPMOVY	CALL	_SCOMO		; met la main20$:	CALL	_SCMO		; remet la souris	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 50$		; non => 50$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	PUSH.L	(A6)+OGMOVY	PUSH.L	(A6)+OPMOVY	LOAD.L	(A6)+OGMOVY,D1	LOAD.L	(A6)+OPMOVY,D0	CALL	DETGPOINTOUT	; D3 <-- point o est la souris	POP.L	(A6)+OPMOVY	POP.L	(A6)+OGMOVY	TEST.W	D7	JUMP,NE 20$	LOAD.W	D5,(A6)+OASVER+OSCHTV	JUMP',EQ 25$	DEC.W	D525$:	SWAP.W	D5	LOAD.W	D5,(A6)+OASHOR+OSCHTV	JUMP',EQ 26$	DEC.W	D526$:	LOAD.L	D4,D1	ADD.W	D4,D2	SUB.W	D4,D3	JUMP',NC 30$	CLR.W	D430$:	COMP.W	D4,D5	JUMP',LS 31$	LOAD.W	D4,D531$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	ADD.W	D4,D2	SUB.W	D4,D3	JUMP',NC 32$	CLR.W	D432$:	COMP.W	D4,D5	JUMP',LS 33$	LOAD.W	D4,D533$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	COMP.L	D4,(A6)+OGMOVY	JUMP,EQ 20$	LOAD.L	(A6)+OGMOVY,D4	LOAD.L	D4,D0	ADD.W	D4,D2	SUB.W	D4,D3	JUMP',NC 34$	CLR.W	D434$:	COMP.W	D4,D5	JUMP',LS 35$	LOAD.W	D4,D535$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	ADD.W	D4,D2	SUB.W	D4,D3	JUMP',NC 36$	CLR.W	D436$:	COMP.W	D4,D5	JUMP',LS 37$	LOAD.W	D4,D537$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	LOAD.L	(A6)+OPMOVY,D4	CALL	DESPMATRIX	; dessine la petite matrice	CALL	DESGMATRIX	; dessine la grande matrice	JUMP	20$50$:	CALL	MAJCADRE	; met  jour ascenseurs et rgles	JUMP	LOOPMACROCOMMEPLAN:	PUSH.B	(A6)+OOBJET	PUSH.B	(A6)+OOUTIL	CALL	_COPYALL	; fait une copie de la matrice	CALL	GETPARAM	; D0..D6 <-- paramtres	LOAD.B	(A6)+OOBJET,D3	SR.W	D3,#8	LOAD.B	(A6)+OOUTIL,D3	CALL	DESCOMMEPLAN	; petit: dessine droite/cercle/etc.	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim objet	CALL	MOVGMATRIX	; grand: dessine droite/cercle/etc.	CALL	CPECRANMATRIX	; matrice principale <-- cran	POP.B	(A6)+OOUTIL	POP.B	(A6)+OOBJET	JUMP	LOOPCOMMEPLAN:	LOAD.W	D0,#CLRDOT	COMP.B	(A6)+OMODE,#ICOCLEAR	JUMP',EQ 10$	LOAD.W	D0,#SETDOT10$:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINT	; D3 <-- point o est la souris	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	D5,D3		; D5 <-- origine fixe	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE 30$	COMP.B	(A6)+OOBJET,#ICODROITE	JUMP',NE 30$	CALL	_CCMO		; enlve la souris	JUMP'	30$20$:	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE 22$	COMP.B	(A6)+OOBJET,#ICODROITE	JUMP',EQ 23$22$:	CALL	_SCOMO		; remet la souris23$:	CALL	DESINFCP	; affiche L= et H=	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 50$		; non => 50$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	.IF	DESSIN	CALL	RGMOUSE		; dessine la position dans les rgles	.ENDIF	CALL	DETGPOINT	; D3 <-- point o est la souris	COMP.L	D3,D6		; souris dplace ?	JUMP,EQ 20$		; non => 20$				; oui =>	PUSH.L	D3	LOAD.L	D3,D1		; D3 <-- ancienne pos	LOAD.L	D4,D2		; D4 <-- ancienne dim	LOAD.W	D2,D0		; D2 <-- mode de dessin	CALL	MOVGMATRIX	; grand: efface dernier droite/cercle/etc.	LOAD.W	D2,#INVDOT	CALL	DESCOMMEPLAN	; petit: efface dernier droite/cercle/etc.	POP.L	D330$:	LOAD.L	D6,D3		; D6 <-- nouvelle arrive	LOAD.W	D2,#INVDOT	CALL	DESCOMMEPLAN	; petit: dessine nouveau droite/cercle/etc.	LOAD.W	D2,D0		; D2 <-- mode de dessin	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim objet	CALL	MOVGMATRIX	; grand: dessine nouveau droite/cercle/etc.	LOAD.L	D1,D3		; D1 <-- pos	LOAD.L	D2,D4		; D2 <-- dim	JUMP	20$50$:	COMP.L	D5,D6		; souris bouge ?	JUMP,EQ NOIRBLANC	; non => NOIRBLANC				; oui =>	COMP.B	(A6)+OOUTIL,#ICOPINCEAU	JUMP',EQ 60$55$:				; fin avec crayon =>	LOAD.W	D2,D0	CALL	DESCOMMEPLAN	; petit: dessine droite/cercle/etc. dfinitif	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim objet	CALL	CPECRANMATRIX	; matrice principale <-- cran	JUMP	80$60$:				; fin avec pinceau =>	LOAD.L	D3,D1		; D3 <-- ancienne pos	LOAD.L	D4,D2		; D4 <-- ancienne dim	LOAD.W	D2,D0		; D2 <-- mode de dessin	CALL	MOVGMATRIX	; grand: efface dernier droite/cercle/etc.	LOAD.W	D2,#INVDOT	CALL	DESCOMMEPLAN	; petit: efface dernier droite/cercle/etc.	LOAD.W	D2,D0	CALL	DESCOMMEPLAN	; petit: dessine droite/cercle dfinitif	LOAD.W	D2,D0		; D2 <-- mode de dessin	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim objet	CALL	MOVGMATRIX	; grand: dessine droite/cercle/etc. dfinitif	CALL	CPECRANMATRIX	; matrice principale <-- cran80$:	LOAD.B	D3,(A6)+OOUTIL	SL.W	D3,#8	LOAD.B	D3,(A6)+OOBJET	; D3 <-- outil/objet	LOAD.W	D4,#KEYICO+ICOOBJET	CALL	PUTPARAM	; macro <-- paramtres	JUMP,NE ERROR	JUMP	LOOPMACROBLOCNOTES:	LOAD.L	A5,#(A6)+OBLOC	SUB.W	D3,#KEYICO+ICOBLOC1	MUL.WU	D3,#LGBLOC	ADD.L	A5,D3		; A5 <-- ^bloc-notes	TEST.L	(A5)+OBLKPT	; bloc-notes contient qq chose ?	JUMP,EQ BIP		; non => BIP	CALL	_COPYALL	; fait une copie de la matrice	CALL	GETPARAM	; D0..D6 <-- paramtres	LOAD.W	(A6)+OMANBS,(A5)+OBLKNBB	LOAD.W	(A6)+OMANBD,(A6)+OMANBB	LOAD.L	A4,(A5)+OBLKPT	; A4 <-- ^matrice source; >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> A TERMINER POUR EDICAR !!!	LOAD.B	(A6)+ODDOP,(A6)+OOBJET	JUMP	OPERMOVEBLOCNOTES:	LOAD.L	A5,#(A6)+OBLOC	CLR.W	D3	LOAD.B	D3,(A6)+OOBJET	SUB.B	D3,#ICOBLOC1	MUL.WU	D3,#LGBLOC	ADD.L	A5,D3		; A5 <-- ^bloc-notes	TEST.L	(A5)+OBLKPT	; bloc-notes contient qq chose ?	JUMP,EQ BIP		; non => BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	D1,(A5)+OBLKP1	; D1 <-- P1(y;x)	LOAD.L	D2,(A5)+OBLKP2	; D2 <-- P2(y;x)	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	COMP.W	D2,(A6)+OMALMX	JUMP,HS BIP	SWAP.W	D2	COMP.W	D2,(A6)+OMALMY	JUMP,HS BIP	SWAP.W	D2	LOAD.W	(A6)+OMANBS,(A5)+OBLKNBB	LOAD.W	(A6)+OMANBD,(A6)+OMANBB	LOAD.L	A3,(A5)+OBLKPT	; A3 <-- ^matrice source	LOAD.L	D3,D1	LOAD.L	A4,(A6)+OPMAM	; A4 <-- ^matrice destination	CLR.L	D4	LOAD.L	D5,D2		; D5 <-- dimensions	CALL	CLEARALL	; matrice masque <-- vide	LOAD.W	D2,#SETDOT	CALL	XFERZONESD	; matrice masque <-- contenu du bloc-notes	LOAD.L	D6,D5	CLR.L	D5	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	CALL	DETGPOINT	JUMP,NE BIP	LOAD.L	D1,D3	LOAD.L	D2,D3	SUB.W	D1,D6	JUMP',NC 40$	SUB.W	D2,D1	CLR.W	D140$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D6	SUB.W	D1,D6	JUMP',NC 42$	SUB.W	D2,D1	CLR.W	D142$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D6	CLR.L	D0	LOAD.B	(A6)+ODDOP,(A6)+OOBJET	JUMP	ZONEMOVETEXTE:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINT	; D3 <-- point o est la souris	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	CALL	_OPETEXTE	; dbute l'dition d'une ligne de texte	JUMP,NE BIP	JUMP	LOOP                                                   FRAPPE:	TEST.L	(A6)+OPOTEXT	; ligne de texte en dition ?	JUMP,EQ BIP		; non => BIP				; oui =>	LOAD.L	A3,#(A6)+OLITEXT20$:	TEST.B	(A3+)	JUMP,NE 20$	TEST.B	(A6)+OACTEXT	JUMP',T 40$	LOAD.W	D2,#'^	COMP.W	D3,#KCIRCON	JUMP,EQ 50$	LOAD.W	D2,#'"	COMP.W	D3,#KTREMA	JUMP,EQ 50$30$:	LOAD.B	(A3)-1,D3	; insre le caractre  la fin	CLR.B	(A3)	CALL	_DESTEXTE	; dessine la ligne de texte	JUMP	LOOP40$:	CLR.B	(A6)+OACTEXT	LOAD.B	D4,(A3)-2	; D4 <-- accent	CALL	GETACCENT	; D3 <-- cherche lettre accentue	JUMP,NE 30$	CLR.B	(A3)-2	CALL	_DESTEXTE	; dessine la ligne sans l'accent flottant	LOAD.B	(A3)-2,D3	CALL	_DESTEXTE	; dessine la ligne avec la lettre accentue	JUMP	LOOP50$:	SET.B	(A6)+OACTEXT	LOAD.B	D3,D2	JUMP	30$ALALIGNE:	LOAD.L	D3,(A6)+OPOTEXT	; ligne de texte en dition ?	.IF	DESSIN	JUMP,EQ BIP		; non => BIP	.ELSE	JUMP,EQ CHANGECARP	; non => passe au caractre suivant	.ENDIF	CALL	GETPGC		; A4 <-- ^dans OBUGC	SWAP.W	D3	ADD.W	D3,(A4)+OGCITL	; D3 <-- une ligne en dessous	SWAP.W	D3	CALL	_OPETEXTE	; recommence une ligne plus basse	JUMP,NE BIP	JUMP	LOOPANNULE:	TEST.L	(A6)+OPOTEXT	; ligne de texte en dition ?	JUMP,EQ EXUNDO		; non => comme (UNDO)	LOAD.L	A3,#(A6)+OLITEXT	CLR.W	D320$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE 20$	DEC.W	D3	JUMP,EQ BIP	CLR.B	(A3)-2		; supprime le dernier caractre frapp	CALL	_DESTEXTE	; dessine la ligne de texte	JUMP	LOOP	.IF	EDGARSEP:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE BIP	CALL	CLRREPERE	; enlve les repres	LOAD.L	D5,D3		; D5 <-- origine fixe	LOAD.L	D6,D3		; D6 <-- arrive variable20$:	CALL	_SCOMO	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 50$		; non => 50$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	DETGPOINTF	; D3 <-- point o est la souris	COMP.L	D3,D6		; souris dplace ?	JUMP,EQ 20$		; non => 20$				; oui =>	CALL	INVSEP		; efface l'ancienne	LOAD.L	D6,D3		; D6 <-- nouvelle arrive	CALL	INVSEP		; dessine la nouvelle	JUMP	20$50$:	CALL	INVSEP		; efface l'ancienne	LOAD.L	(A6)+OSEPP1,D5	LOAD.L	(A6)+OSEPP2,D6	JUMP	LOOP	.ENDIFMODIFDEF:	CALL	DBOXDEF	JUMP,NE ERROR	JUMP	LOOP	.IF	DESSINMODIFZOOM:	CALL	DBOXZOOM	JUMP,NE ERROR	JUMP	LOOP	.ENDIFMODIFPDEF:	CALL	DBOXPDEF	JUMP,NE ERROR	CALL	DESPDEF	LOAD.B	D3,#ICOPINCEAU	JUMP	OUTILNEW	; utilise le pinceauMODIFTDEF:	CALL	DBOXTDEF	JUMP,NE ERROR	CALL	DESTDEF	LOAD.B	D3,(A6)+OOUTIL	COMP.B	D3,#ICOREMPLI	JUMP,EQ LOOP	COMP.B	D3,#ICOSPRAY	JUMP,EQ LOOP	LOAD.B	D3,#ICOREMPLI	JUMP	OUTILNEW	; utilise le bidon de peintureMODIFRDEF:	CALL	DBOXRDEF	JUMP,NE ERROR	LOAD.B	D3,#ICORRECTANGLE	JUMP	OBJETNEW	; objet rectangle arrondiMODIFADEF:	CALL	DBOXADEF	JUMP,NE ERROR	LOAD.B	D3,(A6)+OOBJET	COMP.B	D3,#ICOCERCLE	JUMP,EQ LOOP	COMP.B	D3,#ICOELLIPSE	JUMP,EQ LOOP	LOAD.B	D3,#ICOCERCLE	JUMP	OBJETNEW	; objet cercleMODIFGDEF:	CALL	DBOXGENCAR	JUMP,NE ERROR	LOAD.B	D3,#ICOTEXTE	JUMP	OBJETNEW	; utilise l'objet texte	.IF	EDGARCHANGECARM:	LOAD.B	D3,(A6)+OCAR	JUMP,EQ MACROBIP	DEC.B	D3	CALL	CARSELECT	; montre le caractre prcdent	JUMP	LOOPCHANGECARP:	LOAD.B	D3,(A6)+OCAR	COMP.B	D3,#127	JUMP,EQ MACROBIP	INC.B	D3	CALL	CARSELECT	; montre le caractre suivant	JUMP	LOOPCHANGECAR:	CALL	DBOXCAR	JUMP,NE ERROR	CALL	CARSELECT	; montre le caractre choisit	JUMP	LOOPCHANGEMULM:	COMP.W	(A6)+OMUL,#1	JUMP,EQ BIP	DEC.W	(A6)+OMUL	CALL	DESMUL		; affiche 1x	JUMP	LOOPCHANGEMULP:	COMP.W	(A6)+OMUL,#99	JUMP,EQ BIP	INC.W	(A6)+OMUL	CALL	DESMUL		; affiche 1x	JUMP	LOOPCHANGEMUL:	LOAD.W	(A6)+OMUL,#1	CALL	DESMUL		; affiche 1x	JUMP	LOOPSHIFTCAR:	CALL	_COPYALL	; fait une copie de la matrice	LOAD.W	D4,(A6)+OMUL	; D4 <-- 1..n	CALL	SHIFTMATRIX	; dcale dans le sens demand et affiche	JUMP	LOOPLARGECARM:	LOAD.L	A4,(A6)+OPGC	; A4 <-- ^gencar	LOAD.L	A3,#(A4)+OGCWID	; A3 <-- ^table des largeurs	CLR.W	D3	LOAD.B	D3,(A6)+OCAR	CLR.W	D4	LOAD.B	D4,(A3)+(D3.W)	SUB.W	D4,(A6)+OMUL	JUMP',NC 20$	CLR.W	D420$:	COMP.B	D4,(A3)+(D3.W)	JUMP,EQ BIP	CALL	CLRREPERE	; enlve les repres	LOAD.B	(A3)+(D3.W),D4	SET.B	(A6)+OMAJ	; mise  jour ncessaire	JUMP	LOOPLARGECARP:	LOAD.L	A4,(A6)+OPGC	; A4 <-- ^gencar	LOAD.L	A3,#(A4)+OGCWID	; A3 <-- ^table des largeurs	CLR.W	D3	LOAD.B	D3,(A6)+OCAR	CLR.W	D4	LOAD.B	D4,(A3)+(D3.W)	ADD.W	D4,(A6)+OMUL	COMP.W	D4,(A6)+OMALMX	JUMP',LS 20$	LOAD.W	D4,(A6)+OMALMX20$:	COMP.B	D4,(A3)+(D3.W)	JUMP,EQ BIP	CALL	CLRREPERE	; enlve les repres	LOAD.B	(A3)+(D3.W),D4	SET.B	(A6)+OMAJ	; mise  jour ncessaire	JUMP	LOOPLARGECAR:	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice	CALL	SEARCHLGV	; D4 <-- largeur maximale	LOAD.L	A4,(A6)+OPGC	; A4 <-- ^gencar	LOAD.L	A3,#(A4)+OGCWID	; A3 <-- ^table des largeurs	CLR.W	D3	LOAD.B	D3,(A6)+OCAR	COMP.B	D4,(A3)+(D3.W)	; mme largeur ?	JUMP,EQ LOOP		; oui => LOOP	CALL	CLRREPERE	; enlve les repres	LOAD.B	(A3)+(D3.W),D4	SET.B	(A6)+OMAJ	; mise  jour ncessaire	JUMP	LOOP	.ENDIF	.IF	DESSINREGLE:	CALL	_CCMO		; enlve la souris	NOT.B	(A6)+OREGLE	; met/enlve les rgles	CALL	CALCADRE	LOAD.W	D4,(A6)+OSCALE	CALL	CALSCALE	CALL	DESCADRE	CALL	DESMATRIX	; redessine toutes les matrices	JUMP	LOOP	.ENDIFNEGATIF:	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	A4,(A6)+OPMAT	CALL	_INVALL		; inverse toute la matrice	CALL	DESMATRIX	; dessine toutes les matrices	JUMP	LOOPEFFACE:	.IF	DESSIN	CALL	DBOXEFFACE	; Voulez-vous effacer ?	COMP.W	D3,#F1	JUMP,NE LOOP	.ENDIF	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	A4,(A6)+OPMAT	CALL	CLEARALL	; efface toute la matrice	CALL	DESMATRIX	; dessine toutes les matrices	.IF	DESSIN	LOAD.L	A3,#(A6)+OBUFIN	CLR.B	(A3)	CALL	SAVFILE		; OBUNAME <-- plus de nom	CALL	DESINFFILE	; le dessin n'a plus de nom !	CLR.B	(A6)+OMAJ	; le dessin est  jour	.ENDIF	JUMP	LOOP	.IF	DESSINSCALEFLIP:	LOAD.W	D4,#SCALE11	COMP.W	D4,(A6)+OSCALE	JUMP',NE SCALEXY	LOAD.W	D4,#SCALELOUPESCALEXY:	CALL	CALSCALE	CALL	DESCADRE	CALL	DESMATRIX	; redessine toutes les matrices	JUMP	LOOPSCALEUNUN:	LOAD.W	D4,#SCALE11	COMP.W	D4,(A6)+OSCALE	JUMP,EQ LOOP	JUMP	SCALEXYSCALEPLUS:	LOAD.W	D4,(A6)+OSCALE	JUMP',NS 20$	COMP.W	D4,#SCALEMAX	JUMP,EQ BIP	SL.W	D4,#1	JUMP	SCALEXY20$:	COMP.W	D4,#-2	JUMP,EQ SCALEUNUN	ASR.W	D4,#1	JUMP	SCALEXYSCALEMOINS:	LOAD.W	D4,(A6)+OSCALE	JUMP',NS 20$	COMP.W	D4,#SCALE11	JUMP',EQ 30$	COMP.W	D4,#SCALEMIN	JUMP,EQ SCALEUNUN	SR.W	D4,#1	JUMP	SCALEXY20$:	COMP.W	D4,#-8	JUMP,LE BIP	ASL.W	D4,#1	JUMP	SCALEXY30$:	LOAD.W	D4,#-2	JUMP	SCALEXYSCALETOUT:	CLR.L	D3	LOAD.W	D3,(A6)+OMALMX	DIV.WU	D3,(A6)+OGRDIX	; D3 <-- chelle ncessaire en X	SWAP.W	D3	TEST.W	D3	JUMP',EQ 10$	ADD.L	D3,#H'1000010$:	SWAP.W	D3	CLR.L	D2	LOAD.W	D2,(A6)+OMALMY	DIV.WU	D2,(A6)+OGRDIY	; D2 <-- chelle ncessaire en Y	SWAP.W	D2	TEST.W	D2	JUMP',EQ 20$	ADD.L	D2,#H'1000020$:	SWAP.W	D2	COMP.W	D3,D2	JUMP',HS 30$	LOAD.W	D3,D2		; D3 <-- chelle la plus rduite30$:	LOAD.W	D4,#SCALE11	COMP.W	D3,#1	JUMP',LE 50$	LOAD.W	D4,#-2	COMP.W	D3,#2	JUMP',LE 50$	LOAD.W	D4,#-4	COMP.W	D3,#4	JUMP',LE 50$	LOAD.W	D4,#-850$:	COMP.W	D4,(A6)+OSCALE	JUMP,EQ LOOP	JUMP	SCALEXYDMOINS:	LOAD.W	D4,(A6)+ODARK	DEC.W	D4	JUMP,NS BIP	JUMP'	DARKDNORM:	LOAD.W	D4,#1	JUMP'	DARKDPLUS:	LOAD.W	D4,(A6)+ODARK	COMP.W	D4,#3	JUMP,HS BIP	INC.W	D4;	JUMP'	DARKDARK:	LOAD.W	(A6)+ODARK,D4	LOAD.W	D4,#-2	CALL	CALSCALE	CALL	DESCADRE	CALL	DESMATRIX	; redessine toutes les matrices	JUMP	LOOP	.ELSESCALEXY:	CALL	CALSCALE	CALL	DESCADRE	CALL	DESMATRIX	; redessine toutes les matrices	JUMP	LOOPSCALEPETIT:	LOAD.W	D4,#SCALEMIN	COMP.W	D4,(A6)+OSCALE	JUMP,EQ LOOP	JUMP	SCALEXYSCALEMOYEN:	LOAD.W	D4,#SCALELOUPE	COMP.W	D4,(A6)+OSCALE	JUMP,EQ LOOP	JUMP	SCALEXYSCALEGRAND:	LOAD.W	D4,#SCALEMAX	COMP.W	D4,(A6)+OSCALE	JUMP,EQ LOOP	JUMP	SCALEXY	.ENDIF	.IF	DESSINMENUZONE:	LOAD.B	D3,#ICOVZONE	CALL	INVICONE	; allume l'icne de la zone	CALL	CMZONE		; A3 <-- ^mmenu	CLR.L	D4	LOAD.W	D3,(A6)+ONOZO	INC.W	D3	TSET.L	D4:D3		; D4 <-- zone visible en gris	LOAD.W	D3,#2^15	; D3 <-- utilise D4.L en entre	LOAD.L	A4,#0		; A4 <-- pas de dernire case	CALL	MMENU		; attend selon mmenu ...	PUSHM.L	D3,D7	LOAD.B	D3,#ICOVZONE	CALL	INVICONE	; teint l'icne de la zone	POPM.L	D3,D7	TEST.W	D7	JUMP,NE BIP	DEC.W	D3		; D3 <-- 0..9	JUMP,NS LOOP	JUMP'	XZONESHOWZONE:	AND.W	D3,#H'00FF	SUB.B	D3,#'0		; D3 <-- 0..9	DEC.B	D3	JUMP',NC 20$	LOAD.B	D3,#NBZONE-120$:	COMP.W	D3,(A6)+ONOZO	; est-ce une autre zone ?	JUMP,EQ BIP		; non => BIPXZONE:	LOAD.W	D4,(A6)+OSCALE	CALL	NEWZONE		; utilise une nouvelle zone	JUMP,NE ERROR	CALL	DESZONE		; dessine l'icne de la zone	LOAD.W	D3,D4		; D3 <-- ancienne chelle	LOAD.W	D4,(A6)+OSCALE	; D4 <-- nouvelle chelle	LOAD.W	(A6)+OSCALE,D3	CALL	ICOSCALE	; allume/teint qq icnes	LOAD.W	(A6)+OSCALE,D4	CALL	DESINFFILE	; affiche le nom du dessin;	LOAD.W	D4,(A6)+OSCALE	CALL	CALSCALE	CALL	DESCADRE	; redessine le cadre	CALL	DESMATRIX	; redessine toutes les matrices	JUMP	LOOP	.ENDIFMENUFLAGS:	LOAD.B	D3,#ICOFLAGS	CALL	INVICONE	; allume l'icne	CALL	DBOXFLAGS	; change le mode ...	PUSH.W	D7	LOAD.B	D3,#ICOFLAGS	CALL	INVICONE	; teint l'icne	POP.W	D7	JUMP,NE BIP	JUMP	LOOPDOHELP:	CLR.W	D3	CALL	_SELMO		; utilise la flche	LOAD.L	A3,#R16"TXMHELP	LIB	?AFMENU		; affiche les soft-keys	CLR.W	D210$:	LOAD.L	A3,#R16"THELP1	.IF	DESSIN	TEST.W	D2	JUMP',EQ 20$	LOAD.L	A3,#R16"THELP2	.ENDIF20$:	CALL	_WAITMOUSE	; met le sablier	CALL	AFIMAGE		; affiche l'image d'aide	JUMP,NE 80$	CALL	_NORMMOUSE	; enlve le sablier30$:	LIB	?GETCAR		; attend une touche ...	COMP.W	D3,#F0+SHIFT	JUMP',LO 35$	COMP.W	D3,#F15+SHIFT	JUMP',HI 35$	SUB.W	D3,#SHIFT35$:	COMP.W	D3,#KEYMGR	JUMP,EQ 30$	COMP.W	D3,#KEYMMR	JUMP,EQ 30$	COMP.W	D3,#KEYMDR	JUMP,EQ 30$	CLR.W	D7		; D7 <-- ok	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#END	JUMP,EQ 80$	.IF	DESSIN	COMP.W	D3,#F1	JUMP',EQ 50$	COMP.W	D3,#F2	JUMP',EQ 50$	COMP.W	D3,#F3	JUMP',EQ 50$	COMP.W	D3,#SPACE	JUMP',EQ 50$	COMP.W	D3,#CR	JUMP',EQ 50$	COMP.W	D3,#HELP	JUMP',EQ 50$	COMP.W	D3,#KEYMGP	JUMP',EQ 50$	COMP.W	D3,#KEYMMP	JUMP',EQ 50$	COMP.W	D3,#KEYMDP	JUMP',EQ 50$	.ENDIF	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	30$	.IF	DESSIN50$:	INC.W	D2		; D2 <-- image suivante	COMP.W	D2,#2	JUMP,LO 10$	CLR.W	D2	JUMP	10$	.ENDIF80$:	PUSH.W	D7	CALL	DESWDO	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CALL	_AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE ERROR	JUMP	LOOPEXUNDO:	CALL	UNDOALL		; rcupre tout !REFAIT:	CALL	DESMATRIX	; redessine toutes les matrices	JUMP	LOOPMACROBIP:	CALL	_ABORTMACRO	; stoppe v. la macroBIP:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPBIGBIP:				; erreur =>	LOAD.B	D3,#BIPERR	LIB	?BEEP		; grand bruit	JUMP	LOOPERROR:	PUSH.W	D7	CALL	_ABORTMACRO	; v. stoppe excution macro	CLR.B	D3	CALL	_SELMO		; outil = flche	CALL	_SCMO		; remet la flche	CALL	_NORMMOUSE	; remet la flche	POP.W	D7	TEST.W	D7	JUMP,EQ LOOP	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	_AFMENU		; refait les soft-keys	JUMP	LOOPFINI:	.IF	DESSIN	LOAD.W	D3,(A6)+ONOZO	; D3 <-- zone actuelle	CALL	CLOZONE		; sauve la zone actuelle	LOAD.W	D4,D3		; D4 <-- zone actuelle	CLR.W	D3		; D3 <-- premire zone  sauver	.ENDIF20$:	.IF	DESSIN	CALL	OPEZONE		; prend une zone	LOAD.W	(A6)+ONOZO,D3	.ENDIF	CLR.W	D0		; D0 <-- avant de quitter	CALL	DBOXSAVE	; sauve si ncessaire avant de quitter	JUMP',EQ 50$		; ok => 50$	COMP.W	D7,#1		; (ANNULE) ?	JUMP',EQ 80$		; oui => 80$				; erreur =>	.IF	DESSIN	PUSH.W	D7	LOAD.W	D3,D4	CALL	OPEZONE		; reprend la zone initiale	LOAD.W	(A6)+ONOZO,D3	POP.W	D7	.ENDIF	JUMP	ERROR50$:	.IF	DESSIN	INC.W	D3		; D3 <-- numro zone suivante	COMP.W	D3,#NBZONE	JUMP,LO 20$	.ENDIF	CALL	DBOXQUITTE	; demande s'il faut quitter ...	COMP.W	D3,#F1	JUMP',EQ ERFAT80$:	.IF	DESSIN	LOAD.W	D3,D4	CALL	OPEZONE		; reprend la zone initiale	LOAD.W	(A6)+ONOZO,D3	.ENDIF	JUMP	LOOPERFAT:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDGENC	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDESSIN	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSPLINE	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSTRETCH	LIB_	CLOSEERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	DESDROITE.ASI	.IF	EDGAR	.INS	DESALL.ASI	.INS	DESSEP.ASI	.INS	DESIMAGE.ASI	.ENDIF	.INS	DESSELECT.ASI	.INS	DESMATH.ASI	.INS	DESGRA.ASI	.INS	DESSPLINE.ASI	.INS	DESOPER.ASI_WAITMOUSE:	JUMP	WAITMOUSE_NORMMOUSE:	JUMP	NORMMOUSE_SCMO:		JUMP	SCMO_CCMO:		JUMP	CCMO_SCOMO:		JUMP	SCOMO_SELMO:		JUMP	SELMO_AFMENU:	JUMP	AFMENU_IFMOUSE:	JUMP	IFMOUSE_GETMACRO:	JUMP	GETMACRO_PUTMACRO:	JUMP	PUTMACRO_ABORTMACRO:	JUMP	ABORTMACRO_OPEDISMAT:	JUMP	OPEDISMAT_CLODISMAT:	JUMP	CLODISMAT_DEFGENCAR:	JUMP	DEFGENCAR_OPETEXTE:	JUMP	OPETEXTE_DESTEXTE:	JUMP	DESTEXTE_CLOTEXTE:	JUMP	CLOTEXTE_STARTSTOPMACRO:JUMP	STARTSTOPMACRO_PLAYMACRO:	JUMP	PLAYMACRO_PLAYIMACRO:	JUMP	PLAYIMACRO_INVALL:	JUMP	INVALL_COPYALL:	JUMP	COPYALL_LOOP:		JUMP	LOOP_ERROR:		JUMP	ERROR_BIP:		JUMP	BIP	.INS	DESMATRIX.ASI	.INS	DESCADRE.ASI	.INS	DESICONE.ASI	.INS	DESIO.ASI	.INS	DESZONE.ASI	.INS	DESDBOX.ASI	.INS	DESDBOXT.ASI	.INS	DESGENC.ASI	.INS	DESMISC.ASI	.INS	DESTAB2.ASI	.END	START