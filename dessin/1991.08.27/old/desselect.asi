	.SBTTL	DESSELECT;---------\\; TESTBORD >;=========/; Vrifie que la zone rectangulaire dlimite par D1/D2 ne; dborde pas de la matrice.; in	D1.L	position d'un coin;	D2.L	position de l'autre coin; out	D1.L	position d'un coin;	D2.L	position de l'autre coin; mod	D1.L, D2.LTESTBORD:	PUSHM.L	D0,D3	CLR.W	D0		; D0 <-- flags; Met D1 en haut  gauche et D2 en bas  droite.	COMP.W	D1,D2	JUMP',LE 10$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D3	TSET.L	D0:#010$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,D2	JUMP',LE 15$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D3	TSET.L	D0:#115$:	SWAP.W	D1	SWAP.W	D2; Modifie D1 et D2 pour ne pas dpasser.	CLR.W	D3	COMP.W	D1,D3		; dpasse  gauche ?	JUMP',GE 20$	SUB.W	D3,D1	ADD.W	D1,D3	ADD.W	D2,D320$:	LOAD.W	D3,(A6)+OMALMX	COMP.W	D2,D3		; dpasse  droite ?;;?	JUMP',LT 25$	JUMP',LE 25$	SUB.W	D3,D2	NEG.W	D3;;?	INC.W	D3	SUB.W	D1,D3	SUB.W	D2,D325$:	SWAP.W	D1	SWAP.W	D2	CLR.W	D3	COMP.W	D1,D3		; dpasse en haut ?	JUMP',GE 30$	SUB.W	D3,D1	ADD.W	D1,D3	ADD.W	D2,D330$:	LOAD.W	D3,(A6)+OMALMY	COMP.W	D2,D3		; dpasse en bas ?;;?	JUMP',LT 35$	JUMP',LE 35$	SUB.W	D3,D2	NEG.W	D3;;?	INC.W	D3	SUB.W	D1,D3	SUB.W	D2,D335$:	SWAP.W	D1	SWAP.W	D2; Remet D1 et D2 comme ils taient initialement.	TEST.L	D0:#0	JUMP',BC 90$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D390$:	TEST.L	D0:#1	JUMP',BC 95$	SWAP.W	D1	SWAP.W	D2	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D3	SWAP.W	D1	SWAP.W	D295$:	POPM.L	D0,D3	RET;-----------\\; INVENTOURE >;===========/; Inverse le rectangle entourant la zone slectionne par la souris.; Le rectangle peut dpasser dans les quatre directions.; in	D1.L	position d'un coin;	D2.L	position de l'autre coin; out	-; mod	D7.WINVENTOURE:	PUSHM.L	D1..D4	COMP.L	D1,D2	JUMP,EQ 90$	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	LOAD.L	D3,D1	SWAP.W	D3	SUB.W	D3,(A6)+OGMOVY	; dpasse en haut ?	JUMP',HS 20$	SWAP.W	D2	ADD.W	D2,D3	SWAP.W	D2	CLR.W	D320$:	MUL.WU	D3,(A6)+OGMLPY	ADD.W	D3,(A6)+OGMPOY	DEC.W	D3	SWAP.W	D3	SUB.W	D1,(A6)+OGMOVX	; dpasse  gauche ?	JUMP',HS 25$	ADD.W	D2,D1	CLR.W	D125$:	MUL.WU	D1,(A6)+OGMLPX	ADD.W	D1,(A6)+OGMPOX	DEC.W	D1	LOAD.W	D3,D1	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,(A6)+OGMLPY	SWAP.W	D4	MUL.WU	D2,(A6)+OGMLPX	LOAD.W	D4,D2	LOAD.W	D2,(A6)+OGMPOX	ADD.W	D2,(A6)+OGMDIX	SUB.W	D2,D3	COMP.W	D4,D2		; dpasse  droite ?	JUMP',LS 40$	LOAD.W	D4,D240$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A6)+OGMPOY	ADD.W	D2,(A6)+OGMDIY	SUB.W	D2,D3	COMP.W	D4,D2		; dpasse en bas ?	JUMP',LS 45$	LOAD.W	D4,D245$:	SWAP.W	D3	SWAP.W	D4	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	0	.EVEN	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',GT 60$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D460$:	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT		; inverse le rectangle90$:	POPM.L	D1..D4	RET;------------\\; INIPOIGNEES >;============/; Initialise les 4 points pour les poignes.; in	D1.L	position d'un coin;	D2.L	position de l'autre coin; out	-; mod	D7.WINIPOIGNEES:	PUSHM.L	D1,D2	CALL	ORDONNE		; D1/D2 <-- coins opposs	INC.W	D2	SWAP.W	D2	INC.W	D2	SWAP.W	D2	LOAD.L	(A6)+OSEPHG,D1	LOAD.L	(A6)+OSEPBD,D2	LOAD.W	(A6)+OSEPHD+2,D2	LOAD.W	(A6)+OSEPBG+2,D1	SWAP.W	D1	SWAP.W	D2	LOAD.W	(A6)+OSEPHD+0,D1	LOAD.W	(A6)+OSEPBG+0,D2	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	SR.W	D2,#1	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	SR.W	D2,#1	ADD.W	D2,D1;	SWAP.W	D1	SWAP.W	D2	LOAD.L	(A6)+OSEPMI,D2	; OSEPMI <-- centre de symtrie	LOAD.L	(A6)+OSEOHG,(A6)+OSEPHG	LOAD.L	(A6)+OSEOHD,(A6)+OSEPHD	LOAD.L	(A6)+OSEOBG,(A6)+OSEPBG	LOAD.L	(A6)+OSEOBD,(A6)+OSEPBD	POPM.L	D1,D2	RET;------------\\; OPERPOIGNEE >;============/; Modifie le rectangle de slection pour un zoom.; in	D0.W	poigne;	D1.B	ICOxx;	D3.L	nouvelle coordonne; out	-; mod	D7.WOPERPOIGNEE:	COMP.B	D1,#ICOZOOMQQ	JUMP,EQ ZOOMPOIGNEE	COMP.B	D1,#ICOTOURNEQQ	JUMP,EQ TOURNEPOIGNEE	COMP.B	D1,#ICODEFORMETX	JUMP,EQ DEFTXPOIGNEE	COMP.B	D1,#ICODEFORMETY	JUMP,EQ DEFTYPOIGNEE	COMP.B	D1,#ICODEFORMEPX	JUMP,EQ DEFPXPOIGNEE	COMP.B	D1,#ICODEFORMEPY	JUMP,EQ DEFPYPOIGNEE	COMP.B	D1,#ICODEFORMEQQ	JUMP,EQ DEFQQPOIGNEE	RET;------------\\; ZOOMPOIGNEE >;------------/; Modifie le rectangle de slection pour un zoom.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WZOOMPOIGNEE:	PUSH.L	D3	TEST.L	D0:#BPOIHG	JUMP,BS 20$	TEST.L	D0:#BPOIHD	JUMP,BS 30$	TEST.L	D0:#BPOIBG	JUMP,BS 40$	TEST.L	D0:#BPOIBD	JUMP,BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.L	(A6)+OSEPHG,D3	LOAD.W	(A6)+OSEPBG+2,D3	SWAP.W	D3	LOAD.W	(A6)+OSEPHD+0,D3	JUMP	90$30$:				; sup/droite =>	LOAD.L	(A6)+OSEPHD,D3	LOAD.W	(A6)+OSEPBD+2,D3	SWAP.W	D3	LOAD.W	(A6)+OSEPHG+0,D3	JUMP	90$40$:				; inf/gauche =>	LOAD.L	(A6)+OSEPBG,D3	LOAD.W	(A6)+OSEPHG+2,D3	SWAP.W	D3	LOAD.W	(A6)+OSEPBD+0,D3	JUMP	90$50$:				; inf/droite =>	LOAD.L	(A6)+OSEPBD,D3	LOAD.W	(A6)+OSEPHD+2,D3	SWAP.W	D3	LOAD.W	(A6)+OSEPBG+0,D3;	JUMP	90$90$:	POP.L	D3	RET;--------------\\; TOURNEPOIGNEE >;--------------/; Modifie le rectangle de slection pour une rotation.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WTOURNEPOIGNEE:	PUSHM.L	D2..D4	TEST.L	D0:#BPOIHG	JUMP,BS 20$	TEST.L	D0:#BPOIHD	JUMP,BS 30$	TEST.L	D0:#BPOIBG	JUMP,BS 40$	TEST.L	D0:#BPOIBD	JUMP,BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OSEOHG	JUMP'	80$30$:				; sup/droite =>	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OSEOHD	JUMP'	80$40$:				; inf/gauche =>	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OSEOBG	JUMP'	80$50$:				; inf/droite =>	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OSEOBD;	JUMP'	80$80$:	CALL	XTOURNE		; D2 <-- angle de rotation	LOAD.W	(A6)+OSEANG,D2	LOAD.L	D3,(A6)+OSEOHG	CALL	QTOURNE	LOAD.L	(A6)+OSEPHG,D3	LOAD.L	D3,(A6)+OSEOHD	CALL	QTOURNE	LOAD.L	(A6)+OSEPHD,D3	LOAD.L	D3,(A6)+OSEOBG	CALL	QTOURNE	LOAD.L	(A6)+OSEPBG,D3	LOAD.L	D3,(A6)+OSEOBD	CALL	QTOURNE	LOAD.L	(A6)+OSEPBD,D390$:	POPM.L	D2..D4	RET;-------------\\; DEFTXPOIGNEE >;-------------/; Modifie le rectangle de slection pour une dformation en trapze.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WDEFTXPOIGNEE:	PUSHM.L	D3,D4	TEST.L	D0:#BPOIHG	JUMP,BS 20$	TEST.L	D0:#BPOIHD	JUMP,BS 30$	TEST.L	D0:#BPOIBG	JUMP,BS 40$	TEST.L	D0:#BPOIBD	JUMP,BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.W	D4,(A6)+OSEPHG+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPHG,D3	LOAD.W	D3,(A6)+OSEPHD+2	ADD.W	D3,D4	LOAD.L	(A6)+OSEPHD,D3	JUMP	90$30$:				; sup/droite =>	LOAD.W	D4,(A6)+OSEPHD+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPHD,D3	LOAD.W	D3,(A6)+OSEPHG+2	ADD.W	D3,D4	LOAD.L	(A6)+OSEPHG,D3	JUMP	90$40$:				; inf/gauche =>	LOAD.W	D4,(A6)+OSEPBG+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPBG,D3	LOAD.W	D3,(A6)+OSEPBD+2	ADD.W	D3,D4	LOAD.L	(A6)+OSEPBD,D3	JUMP	90$50$:				; inf/droite =>	LOAD.W	D4,(A6)+OSEPBD+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPBD,D3	LOAD.W	D3,(A6)+OSEPBG+2	ADD.W	D3,D4	LOAD.L	(A6)+OSEPBG,D3;	JUMP	90$90$:	POPM.L	D3,D4	RET;-------------\\; DEFTYPOIGNEE >;-------------/; Modifie le rectangle de slection pour une dformation en trapze.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WDEFTYPOIGNEE:	PUSHM.L	D3,D4	TEST.L	D0:#BPOIHG	JUMP,BS 20$	TEST.L	D0:#BPOIHD	JUMP,BS 30$	TEST.L	D0:#BPOIBG	JUMP,BS 40$	TEST.L	D0:#BPOIBD	JUMP,BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.W	D4,(A6)+OSEPHG+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPHG,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPBG+0	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPBG,D3	JUMP	90$30$:				; sup/droite =>	LOAD.W	D4,(A6)+OSEPHD+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPHD,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPBD+0	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPBD,D3	JUMP	90$40$:				; inf/gauche =>	LOAD.W	D4,(A6)+OSEPBG+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPBG,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPHG+0	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPHG,D3	JUMP	90$50$:				; inf/droite =>	LOAD.W	D4,(A6)+OSEPBD+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPBD,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPHD+0	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPHD,D3;	JUMP	90$90$:	POPM.L	D3,D4	RET;-------------\\; DEFPXPOIGNEE >;-------------/; Modifie le rectangle de slection pour une dformation en paralllogramme.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WDEFPXPOIGNEE:	PUSHM.L	D3,D4	TEST.L	D0:#BPOIHG	JUMP,BS 20$	TEST.L	D0:#BPOIHD	JUMP,BS 30$	TEST.L	D0:#BPOIBG	JUMP,BS 40$	TEST.L	D0:#BPOIBD	JUMP,BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.W	D4,(A6)+OSEPHG+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPHG,D3	LOAD.W	D3,(A6)+OSEPHD+2	SUB.W	D3,D4	LOAD.L	(A6)+OSEPHD,D3	JUMP	90$30$:				; sup/droite =>	LOAD.W	D4,(A6)+OSEPHD+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPHD,D3	LOAD.W	D3,(A6)+OSEPHG+2	SUB.W	D3,D4	LOAD.L	(A6)+OSEPHG,D3	JUMP	90$40$:				; inf/gauche =>	LOAD.W	D4,(A6)+OSEPBG+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPBG,D3	LOAD.W	D3,(A6)+OSEPBD+2	SUB.W	D3,D4	LOAD.L	(A6)+OSEPBD,D3	JUMP	90$50$:				; inf/droite =>	LOAD.W	D4,(A6)+OSEPBD+2	SUB.W	D4,D3	LOAD.L	(A6)+OSEPBD,D3	LOAD.W	D3,(A6)+OSEPBG+2	SUB.W	D3,D4	LOAD.L	(A6)+OSEPBG,D3;	JUMP	90$90$:	POPM.L	D3,D4	RET;-------------\\; DEFPYPOIGNEE >;-------------/; Modifie le rectangle de slection pour une dformation en paralllogramme.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WDEFPYPOIGNEE:	PUSHM.L	D3,D4	TEST.L	D0:#BPOIHG	JUMP,BS 20$	TEST.L	D0:#BPOIHD	JUMP,BS 30$	TEST.L	D0:#BPOIBG	JUMP,BS 40$	TEST.L	D0:#BPOIBD	JUMP,BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.W	D4,(A6)+OSEPHG+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPHG,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPBG+0	SUB.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPBG,D3	JUMP	90$30$:				; sup/droite =>	LOAD.W	D4,(A6)+OSEPHD+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPHD,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPBD+0	SUB.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPBD,D3	JUMP	90$40$:				; inf/gauche =>	LOAD.W	D4,(A6)+OSEPBG+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPBG,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPHG+0	SUB.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPHG,D3	JUMP	90$50$:				; inf/droite =>	LOAD.W	D4,(A6)+OSEPBD+0	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	LOAD.L	(A6)+OSEPBD,D3	SWAP.W	D3	LOAD.W	D3,(A6)+OSEPHD+0	SUB.W	D3,D4	SWAP.W	D3	LOAD.L	(A6)+OSEPHD,D3;	JUMP	90$90$:	POPM.L	D3,D4	RET;-------------\\; DEFQQPOIGNEE >;-------------/; Modifie le rectangle de slection pour une dformation quelconque.; in	D0.W	poigne;	D3.L	nouvelle coordonne; out	-; mod	D7.WDEFQQPOIGNEE:	PUSH.L	D3	TEST.L	D0:#BPOIHG	JUMP,BS 20$	TEST.L	D0:#BPOIHD	JUMP,BS 30$	TEST.L	D0:#BPOIBG	JUMP,BS 40$	TEST.L	D0:#BPOIBD	JUMP,BS 50$	JUMP	90$20$:				; sup/gauche =>	LOAD.L	(A6)+OSEPHG,D3	JUMP	90$30$:				; sup/droite =>	LOAD.L	(A6)+OSEPHD,D3	JUMP	90$40$:				; inf/gauche =>	LOAD.L	(A6)+OSEPBG,D3	JUMP	90$50$:				; inf/droite =>	LOAD.L	(A6)+OSEPBD,D3;	JUMP	90$90$:	POP.L	D3	RET;------------\\; DETPOIGNEES >;============/; Dtecte dans quelle poigne est la souris.; in	D4.L	position de la souris; out	D0.W	poigne o est la souris;	D7.W	erreur; mod	D0.L, D7.WDETPOIGNEES:	LOAD.W	D0,#2^BPOIHG	CALL	DETPOIGNEE	; dans la poigne sup/gauche ?	JUMP',EQ 90$	LOAD.W	D0,#2^BPOIHD	CALL	DETPOIGNEE	; dans la poigne sup/droite ?	JUMP',EQ 90$	LOAD.W	D0,#2^BPOIBG	CALL	DETPOIGNEE	; dans la poigne inf/gauche ?	JUMP',EQ 90$	LOAD.W	D0,#2^BPOIBD	CALL	DETPOIGNEE	; dans la poigne inf/droite ?;	JUMP',EQ 90$90$:	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DETPOIGNEE >;-----------/; Dtecte si la souris est dans une poigne bien prcise.; in	D0.W	poigne;	D4.L	position de la souris; out	D7.W	ok/erreur; mod	D7.WDETPOIGNEE:	PUSHM.L	D3,D4	CALL	POSPOIGNEE	; D3 <-- position de la poigne	JUMP,NE 90$	LOAD.W	D7,#1		; D7 <-- en dehors	SUB.W	D3,#DPOIGNEE	COMP.W	D4,D3		; trop  gauche ?	JUMP,LO 90$	ADD.W	D3,#DPOIGNEE*2	COMP.W	D4,D3		; trop  droite ?	JUMP,HS 90$	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#DPOIGNEE	COMP.W	D4,D3		; trop en haut ?	JUMP',LO 90$	ADD.W	D3,#DPOIGNEE*2	COMP.W	D4,D3		; trop en bas ?	JUMP',HS 90$	CLR.W	D7		; D7 <-- hop, sur la poigne90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; INVPOIGNEES >;============/; Inverse les poignes de la zone slectionne par la souris.; Le rectangle peut dpasser dans les quatre directions.; in	D0.W	poignes  inverser; out	-; mod	D7.WINVPOIGNEES:	PUSHM.L	D0..D4	LOAD.W	D4,D0		; D4 <-- poignes  inverser	TEST.L	D4:#BPOIHG	JUMP',BC 20$	LOAD.L	D0,#2^BPOIHG	CALL	POSPOIGNEE	JUMP',NE 20$	CALL	INVPOIGNEE	; inverse la poigne sup/gauche20$:	TEST.L	D4:#BPOIHD	JUMP',BC 30$	LOAD.L	D0,#2^BPOIHD	CALL	POSPOIGNEE	JUMP',NE 30$	CALL	INVPOIGNEE	; inverse la poigne sup/droite30$:	TEST.L	D4:#BPOIBG	JUMP',BC 40$	LOAD.L	D0,#2^BPOIBG	CALL	POSPOIGNEE	JUMP',NE 40$	CALL	INVPOIGNEE	; inverse la poigne inf/gauche40$:	TEST.L	D4:#BPOIBD	JUMP',BC 50$	LOAD.L	D0,#2^BPOIBD	CALL	POSPOIGNEE	JUMP',NE 50$	CALL	INVPOIGNEE	; inverse la poigne inf/droite50$:	POPM.L	D0..D4	RET;-----------\\; INVPOIGNEE >;-----------/; Inverse une poigne.; in	D3.L	coordonne dans l'cran; out	-; mod	D7.WINVPOIGNEE:	PUSHM.L	D2..D4	LOAD.L	D4,#-1	CALL	DRMDEF		; dfinit une trame pleine	SUB.W	D3,#DPOIGNEE/2	SWAP.W	D3	SUB.W	D3,#DPOIGNEE/2	SWAP.W	D3	LOAD.W	D4,#DPOIGNEE	SWAP.W	D4	LOAD.W	D4,#DPOIGNEE	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	; inverse la poigne	SUB.W	D3,#4/2	SWAP.W	D3	SUB.W	D3,#4/2	SWAP.W	D3	ADD.W	D4,#4-1	SWAP.W	D4	ADD.W	D4,#4-1	SWAP.W	D4	LIB	?DRRECT		; inverse rectangle autour	POPM.L	D2..D4	RET;-----------\\; POSPOIGNEE >;-----------/; Donne la position d'une poigne.; in	D0.W	poignes  inverser; out	D3.L	position dans la matrice; mod	D3.L, D7.WPOSPOIGNEE:	LOAD.L	D3,(A6)+OSEPHG	TEST.L	D0:#BPOIHG	; poigne sup/gauche ?	JUMP',BS 80$	LOAD.L	D3,(A6)+OSEPHD	TEST.L	D0:#BPOIHD	; poigne sup/droite ?	JUMP',BS 80$	LOAD.L	D3,(A6)+OSEPBG	TEST.L	D0:#BPOIBG	; poigne inf/gauche ?	JUMP',BS 80$	LOAD.L	D3,(A6)+OSEPBD	TEST.L	D0:#BPOIBD	; poigne inf/droite ?	JUMP',BS 80$	LOAD.W	D7,#1	JUMP'	90$80$:	CALL	CONVGPOINT	; D3 <-- coordonne90$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; INVSELECT >;==========/; Inverse toute la slection (quadrilatre quelconque).; in	-; out	D7.W	erreur; mod	D7.WINVSELECT:	PUSHM.L	D0..D6	LOAD.L	D3,(A6)+OSEPHG	CALL	CONVGPOINT	; D3 <-- coordonne	JUMP,NE 90$	LOAD.L	D0,D3	LOAD.L	D3,(A6)+OSEPHD	CALL	CONVGPOINT	; D3 <-- coordonne	JUMP,NE 90$	LOAD.L	D1,D3	LOAD.L	D3,(A6)+OSEPBG	CALL	CONVGPOINT	; D3 <-- coordonne	JUMP,NE 90$	LOAD.L	D5,D3	LOAD.L	D3,(A6)+OSEPBD	CALL	CONVGPOINT	; D3 <-- coordonne	JUMP,NE 90$	LOAD.L	D6,D3	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT	LOAD.L	D3,D0		; D3 <-- sup/gauche	LOAD.L	D4,D1		; D4 <-- sup/droite	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG	LOAD.L	D3,D1		; D3 <-- sup/droite	LOAD.L	D4,D6		; D4 <-- inf/droite	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG	LOAD.L	D3,D6		; D3 <-- inf/droite	LOAD.L	D4,D5		; D4 <-- inf/gauche	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG	LOAD.L	D3,D5		; D3 <-- inf/gauche	LOAD.L	D4,D0		; D4 <-- sup/gauche	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; POSDIM  >;========/; Ordonne D1.L et D2.L pour que D1 soit en haut  gauche et; D2 la longueur.; in	D1.L	position d'un coin;	D2.L	position de l'autre coin; out	D1.L	position coin sup/gauche;	D2.L	dimensions; mod	D1.L, D2.LPOSDIM:	CALL	ORDONNE	SUB.W	D2,D1	INC.W	D2	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	INC.W	D2	SWAP.W	D1	SWAP.W	D2	RET;--------\\; ORDONNE >;========/; Ordonne D1.L et D2.L pour que D1 soit en haut  gauche et; D2 en bas  droite (D1<D2).; in	D1.L	position d'un coin;	D2.L	position de l'autre coin; out	D1.L	position d'un coin;	D2.L	position de l'autre coin; mod	D1.L, D2.LORDONNE:	PUSH.W	D3	COMP.W	D1,D2	JUMP',LS 10$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D310$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,D2	JUMP',LS 15$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D315$:	SWAP.W	D1	SWAP.W	D2	POP.W	D3	RET	.END