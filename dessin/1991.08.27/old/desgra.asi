	.SBTTL	DESGRA;-------------\\; DIMCOMMEPLAN >;=============/; Donne les dimensions occupes par un objet graphique,; en tenant compte v. de l'paisseur du pinceau.; in	D5.L	origine (y;x);	D6.L	arrive (y;x); out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WDIMCOMMEPLAN:	PUSHM.L	D0..D2	LOAD.L	D3,D5	LOAD.L	D4,D6	LOAD.B	D0,(A6)+OOBJET	; D0 <-- objet slectionn	COMP.B	D0,#ICOCERCLE	JUMP',EQ 20$	COMP.B	D0,#ICOELLIPSE	JUMP',EQ 20$				; objet rectangulaire =>	SUB.W	D4,D3	JUMP',GE 12$	ADD.W	D3,D4		; D3 <-- x	NEG.W	D4		; D4 <-- dx12$:	INC.W	D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',GE 14$	ADD.W	D3,D4		; D3 <-- y	NEG.W	D4		; D4 <-- dy14$:	INC.W	D4	SWAP.W	D3	SWAP.W	D4	JUMP	50$20$:				; cercle/ellipse =>	SUB.W	D4,D3		; D4 <-- dx 	JUMP',GE 22$	NEG.W	D422$:	LOAD.W	D1,D4		; D1 <-- rx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	JUMP',GE 24$	NEG.W	D424$:	LOAD.W	D2,D4		; D2 <-- ry	SWAP.W	D3	SWAP.W	D4	COMP.B	D0,#ICOELLIPSE	JUMP',EQ 30$				; cercle =>	LOAD.W	D4,D1	ADD.W	D4,D2		; D4 <-- rayon	LOAD.W	D1,D4	SWAP.W	D4	LOAD.W	D4,D1	SWAP.W	D430$:	SUB.W	D3,D4		; D3 <-- x	SL.W	D4,#1		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4		; D3 <-- y	SL.W	D4,#1		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4;	JUMP'	50$; Tient compte ventuellement de l'paisseur du pinceau.50$:	COMP.B	(A6)+OOUTIL,#ICOPINCEAU	JUMP',NE 70$	SUB.W	D3,#8/2	ADD.W	D4,#8	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#8/2	ADD.W	D4,#8	SWAP.W	D3	SWAP.W	D4; Vrifie si les dimensions dpassent la partie visible.70$:	LOAD.W	D2,(A6)+OPMOVX	COMP.W	D3,D2	JUMP',GE 72$	LOAD.W	D3,D272$:	ADD.W	D2,(A6)+OPMDIX	SUB.W	D2,D3	COMP.W	D4,D2	JUMP',LE 73$	LOAD.W	D4,D273$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A6)+OPMOVY	COMP.W	D3,D2	JUMP',GE 74$	LOAD.W	D3,D274$:	ADD.W	D2,(A6)+OPMDIY	SUB.W	D2,D3	COMP.W	D4,D2	JUMP',LE 75$	LOAD.W	D4,D275$:	SWAP.W	D3	SWAP.W	D4	POPM.L	D0..D2	RET;-------------\\; DESCOMMEPLAN >;=============/; Dessine un objet graphique (droite/cercle/etc.) dans; la petite matrice.; in	D5.L	origine (y;x);	D6.L	arrive (y;x);	D2.W	mode de dessin; out	-; mod	D7.WDESCOMMEPLAN:	PUSHM.L	D0..D5,A3,A4	COMP.L	D5,D6		; origine = arrive ?	JUMP,EQ 95$		; oui => 95$	COMP.B	(A6)+OOUTIL,#ICOPINCEAU	JUMP',NE 05$	COMP.W	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ 05$		; oui => 05$ (pas encore de pinceau)	LOAD.W	D0,D2	LOAD.L	A4,#(A6)+OPDEF	LOAD.W	D1,(A6)+ONPDEF	DESSIN_	DDEF		; dfinit le bon pinceau avec traitill	COMP.W	D2,#-1		; qq chose  dessiner ?	JUMP,EQ 95$		; non => 95$	OR.W	D2,D0		; D2 <-- mode utilisant le pinceau05$:	LOAD.L	D3,D5	LOAD.L	D4,D6	SUB.W	D3,(A6)+OPMOVX	JUMP,LO 95$	SWAP.W	D3	SUB.W	D3,(A6)+OPMOVY	JUMP,LO 95$	SWAP.W	D3	SUB.W	D4,(A6)+OPMOVX	JUMP,LO 95$	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	JUMP,LO 95$	SWAP.W	D4	LOAD.W	D5,(A6)+OPWDO	LIB	?USEWDO		; utilise swdo autour de la petite matrice	LOAD.B	D0,(A6)+OOBJET	; D0 <-- objet slectionn	COMP.B	D0,#ICOTRAIT	JUMP',EQ 10$	COMP.B	D0,#ICODROITE	JUMP',EQ 10$	COMP.B	D0,#ICOSPLINE	JUMP',EQ 10$	COMP.B	D0,#ICOFILET	JUMP,EQ 15$	COMP.B	D0,#ICOCERCLE	JUMP,EQ 20$	COMP.B	D0,#ICOELLIPSE	JUMP,EQ 20$	COMP.B	D0,#ICORECTANGLE	JUMP,EQ 40$	COMP.B	D0,#ICORRECTANGLE	JUMP,EQ 50$	JUMP	90$10$:				; trait/droite =>	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine la droite	COMP.B	D0,#ICOSPLINE	JUMP,EQ 90$	COMP.B	(A6)+OOUTIL,#ICOCRAYON	JUMP,NE 90$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWDOT	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.B	(A3)+5,D2	; <mode>	LOAD.W	D3,#6	LIB	?STRING		; dessine le point d'arrive !	JUMP	90$15$:				; filet =>	LIB	?AFTIM	.B	MAPTT	.B	B'01010101	; map	.B	1		; chelle	.B	0	.EVEN	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	PUSH.L	D3	LIB	?DRSEG		; dessine la droite	POP.L	D3	LOAD.L	A4,(A6)+OPMAM	CALL	OPEDISMAT	; dessine dans la matrice masque	ADD.W	D3,(A6)+OPMOVX	SWAP.W	D3	ADD.W	D3,(A6)+OPMOVY	SWAP.W	D3	LOAD.W	D2,#SETDOT	; D2 <-- mode "set", sans pinceau !	LIB	?DRSEG		; dessine dans la matrice masque	CALL	CLODISMAT	; dessine  nouveau dans l'cran	JUMP	90$20$:				; cercle/ellipse =>	CLR.W	D0	SUB.W	D4,D3		; D4 <-- rx 	JUMP',HS 22$	NEG.W	D4	ADD.W	D0,#222$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- ry	JUMP',HS 24$	NEG.W	D4	ADD.W	D0,#424$:	SWAP.W	D3	SWAP.W	D4	TEST.L	D0:#2	JUMP',BC 26$	TNOT.L	D0:#1		; D0 <-- 0,2,4,6 selon cadrant26$:	LOAD.W	D1,#B'11000000	; D1 <-- arcs pour 1/4 cercle	TEST.B	(A6)+OARC:#BARC4	JUMP',BS 27$	LOAD.W	D1,#B'11110000	; D1 <-- arcs pour 1/2 cercle	TEST.B	(A6)+OARC:#BARC2	JUMP',BS 27$	LOAD.W	D1,#B'11111111	; D1 <-- arcs pour cercle complet27$:	RR.B	D1,D0		; D1 <-- tourne les arcs selon le cadrant	COMP.B	(A6)+OOBJET,#ICOELLIPSE	JUMP',EQ 30$				; cercle =>	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWARC	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.L	D0,D4	SWAP.W	D0	ADD.W	D4,D0		; D4 <-- rx + ry	LOAD.W	(A3)+5,D4	; <rr>	LOAD.W	(A3)+7,D1	; <aa>	LOAD.B	(A3)+9,D2	; <mode>	LOAD.W	D3,#10	LIB	?STRING		; dessine le cercle	JUMP	90$30$:				; ellipse =>	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWELLIPSE	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	SWAP.W	D4	LOAD.L	(A3)+5,D4	; <rxx> et <ryy>	LOAD.W	(A3)+9,D1	; <aa>	LOAD.B	(A3)+11,D2	; <mode>	LOAD.W	D3,#12	LIB	?STRING		; dessine l'ellipse	JUMP	90$40$:				; rectangle =>	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	LIB	?DRRECT		; dessine le rectangle	JUMP	90$50$:				; rectangle arrondi =>	LOAD.W	D0,(A6)+ORRECT	; D0 <-- rayon du rectangle	JUMP,EQ 40$	CALL	RRECTANGLE	; dessine le rectangle arrondi;	JUMP	90$90$:	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale95$:	POPM.L	D0..D5,A3,A4	RET;-----------\; RRECTANGLE >;-----------/; Dessine un rectangle aux coins arrondis.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.W	mode de dessin;	D0.W	rayon; out	-; mod	D7.WRRECTANGLE:	PUSHM.L	D0..D5,A3; Arrange D3 et D4 pour que D3 (x;y) soit toujours plus petit que; D4 (x;y). On ne peut pas utiliser ORDONNE car les coordonnes; peuvent tre +/- !	COMP.W	D3,D4		; D3 < D4 ?	JUMP',LT 20$		; oui => 20$	LOAD.W	D5,D3		; non =>	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D520$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4		; D3 < D4 ?	JUMP',LT 25$		; oui => 25$	LOAD.W	D5,D3		; non =>	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D525$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SR.W	D5,#1		; D5 <-- 1/2 largeur	COMP.W	D0,D5		; rayon trop grand ?	JUMP',LS 30$		; non => 30$	LOAD.W	D0,D5		; oui => diminue30$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SWAP.W	D4	SWAP.W	D3	SR.W	D5,#1		; D5 <-- 1/2 hauteur	COMP.W	D0,D5		; rayon trop grand ?	JUMP',LS 40$		; non => 40$	LOAD.W	D0,D5		; oui => diminue40$:	LOAD.L	A3,#(A6)+OBUDIS+1	TCLR.L	D2:#BNCTDOT	; rz des traitills	LOAD.B	(A3+),#DRAWSEG	; en haut	LOAD.W	D5,D3	ADD.W	D5,D0	INC.W	D5	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D3	LOAD.W	(A3+),D3	; <yy>	SWAP.W	D3	LOAD.W	D5,D4	SUB.W	D5,D3	SUB.W	D5,D0	SUB.W	D5,D0	LOAD.W	(A3+),D5	; <dxx>	CLR.W	(A3+)		; <dyy>	LOAD.B	(A3+),D2	; <mode>	TSET.L	D2:#BNCTDOT	; plus de rz des traitills	LOAD.B	(A3+),#DRAWARC	; en haut  droite	LOAD.W	D5,D4	SUB.W	D5,D0	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D3	LOAD.W	D5,D3	ADD.W	D5,D0	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D3	LOAD.W	(A3+),D0	; <rr>	LOAD.W	(A3+),#B'00000011	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWSEG	;  droite	LOAD.W	(A3+),D4	; <xx>	SWAP.W	D3	LOAD.W	D5,D3	ADD.W	D5,D0	INC.W	D5	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D3	CLR.W	(A3+)		; <dxx>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SUB.W	D5,D0	SUB.W	D5,D0	LOAD.W	(A3+),D5	; <dyy>	SWAP.W	D4	SWAP.W	D3	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWARC	; en bas  droite	LOAD.W	D5,D4	SUB.W	D5,D0	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D0	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D4	LOAD.W	(A3+),D0	; <rr>	LOAD.W	(A3+),#B'11000000	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWSEG	; en bas	LOAD.W	D5,D4	SUB.W	D5,D0	DEC.W	D5	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D4	LOAD.W	(A3+),D4	; <yy>	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SUB.W	D5,D0	SUB.W	D5,D0	NEG.W	D5	LOAD.W	(A3+),D5	; <dxx>	CLR.W	(A3+)		; <dyy>	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWARC	; en bas  gauche	LOAD.W	D5,D3	ADD.W	D5,D0	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D0	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D4	LOAD.W	(A3+),D0	; <rr>	LOAD.W	(A3+),#B'00110000	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWSEG	;  gauche	LOAD.W	(A3+),D3	; <xx>	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D0	DEC.W	D5	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D4	CLR.W	(A3+)		; <dxx>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SUB.W	D5,D0	SUB.W	D5,D0	NEG.W	D5	LOAD.W	(A3+),D5	; <dyy>	SWAP.W	D4	SWAP.W	D3	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWARC	; en haut  gauche	LOAD.W	D5,D3	ADD.W	D5,D0	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D3	LOAD.W	D5,D3	ADD.W	D5,D0	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D3	LOAD.W	(A3+),D0	; <rr>	LOAD.W	(A3+),#B'00001100	LOAD.B	(A3+),D2	; <mode>	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	SUB.L	D3,A3		; D3 <-- longueur	LIB	?STRING	POPM.L	D0..D5,A3	RET;---------\\; DESSPRAY >;=========/; Dessine un "point" avec le spray, et tenant compte de; la trame de remplissage.; in	D3.L	position du centre (y;x);	D2.W	mode de dessin;	A3.L	^motif 8x8 du spray; out	-; mod	D7.WDESSPRAY:	PUSHM.L	D0..D6,A1..A5	LOAD.W	D6,D2		; D6 <-- mode de dessin	LOAD.L	A4,#(A6)+OTDEF	LOAD.W	D4,(A6)+ONTDEF	MUL.WU	D4,#8	ADD.L	A4,D4		; A4 <-- ^dbut trame de remplissage	LOAD.L	A5,#(A4)+8	; A5 <-- ^fin trame de remplissage	SUB.W	D3,#8/2	SWAP.W	D3	SUB.W	D3,#8/2	LOAD.W	D4,D3	AND.W	D4,#B'111	LOAD.L	A2,A4	ADD.W	A2,D4		; A2 <-- ^bonne ligne matrice remplissage	SWAP.W	D3	LOAD.W	D4,#8-110$:	PUSHM.L	D3,D4	LOAD.B	D0,(A3+)	LOAD.W	D4,#8-120$:	SL.B	D0,#1		; point  dessiner selon matrice spray ?	JUMP',CC 50$		; non => 50$	TEST.B	(A2):D3		; point  dessiner selon matrice remplissage ?	JUMP',BC 50$		; non => 50$				; oui =>	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice	CALL	TESTPOINT	JUMP',NE 50$	COMP.W	D6,#CLRDOT	JUMP',EQ 40$	TSET.B	(A1):D1		; point dj allum ?	JUMP',BS 50$		; oui => 50$	JUMP'	45$40$:	TCLR.B	(A1):D1		; point dj teint ?	JUMP',BC 50$		; oui => 50$45$:	LOAD.W	D2,#INVDOT	LOAD.W	D1,#1	CALL	DESGPOINT	; allume/teint point dans grande matrice	CALL	DESPPOINT	; allume/teint point dans petite matrice50$:	INC.W	D3		; D3 <-- avance en X	DECJ.W,NMO D4,20$	POPM.L	D3,D4	SWAP.W	D3	INC.W	D3		; D3 <-- avance en Y	SWAP.W	D3	INC.L	A2		; A2 <-- ^ligne suivante matrice remplissage	COMP.L	A2,A5		; fin de la trame ?	JUMP',LO 60$		; non => 60$	LOAD.L	A2,A4		; A2 <-- ^premire ligne60$:	DECJ.W,NMO D4,10$	POPM.L	D0..D6,A1..A5	RET;---------\\; DESFILET >;=========/; Essaye de remplir le filet dans la matrice masque.; in	D3.L	point initial; out	D7.W	erreur; mod	D7.WDESFILET:	PUSHM.L	D0..D4,A1..A4	LOAD.L	D0,D3		; D0 <-- point initial	LOAD.L	D4,#-1	CALL	DRMDEF		; dfinit une trame pleine	LOAD.L	A4,(A6)+OPMAM	CALL	OPEDISMAT	; dessine dans la matrice copie	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWFILLO	LOAD.B	(A3)+5,#DRAWFILLC	LOAD.L	A2,#R16"00$	; A2 <-- ^liste des points  essayer20$:	LOAD.W	D7,#ERDIOUT	TEST.L	(A2)		; fin de la table ?	JUMP',EQ 80$		; oui => 80$				; non =>	LOAD.L	D3,D0	SWAP.W	D3	ADD.W	D3,(A2+)	SWAP.W	D3	ADD.W	D3,(A2+)	; D3 <-- point o essayer de remplir	LOAD.L	A1,(A6)+OPMAM	CALL	TESTPOINT	JUMP,NE 20$	TEST.B	(A1):D1		; point allum ici ?	JUMP,BS 20$		; oui => 20$				; non =>	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.W	D3,#5+1	LIB	?STRING		; rempli ...	JUMP,NE 20$		; y'a un trou => 20$80$:	PUSH.W	D7	CALL	CLODISMAT	; redessine dans l'cran	POP.W	D7	POPM.L	D0..D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.W	0,+2	.W	0,+4	.W	0,+6	.W	0,+8	.W	0,-2	.W	0,-4	.W	0,-6	.W	0,-8	.W	+2,0	.W	+4,0	.W	+6,0	.W	+8,0	.W	-2,0	.W	-4,0	.W	-6,0	.W	-8,0	.W	+2,+2	.W	+4,+4	.W	+6,+6	.W	+8,+8	.W	-2,+2	.W	-4,+4	.W	-6,+6	.W	-8,+8	.W	+2,-2	.W	+4,-4	.W	+6,-6	.W	+8,-8	.W	-2,-2	.W	-4,-4	.W	-6,-6	.W	-8,-8	.W	0,0	.END