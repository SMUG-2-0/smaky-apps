	.SBTTL	DESSEP;----------\\; CLRREPERE >;==========/; Efface toutes les lignes de repre existantes.; in	-; out	-; mod	D7.WCLRREPERE:	TEST.B	(A6)+OSREP	JUMP',F 90$	CALL	INVREPERE	; efface	CLR.B	(A6)+OSREP90$:	RET;----------\\; SETREPERE >;==========/; Dessine toutes les lignes de repre existantes.; in	-; out	-; mod	D7.WSETREPERE:	TEST.B	(A6)+OSREP	JUMP',T 90$	CALL	INVREPERE	; dessine	SET.B	(A6)+OSREP90$:	RET;----------\\; INVREPERE >;==========/; Inverse toutes les lignes de repre existantes.; in	-; out	-; mod	D7.WINVREPERE:	PUSHM.L	D1..D6,A3,A4	COMP.W	(A6)+OSCALE,#SCALE11	JUMP,EQ 90$	TEST.L	(A6)+OPGC	JUMP,EQ 90$	LOAD.L	A4,(A6)+OPGC	; A4 <-- ^gencar	LOAD.W	D2,#INVDOT; Dessine la ligne de base.	LOAD.W	D3,(A6)+OMALMY	SUB.W	D3,(A4)+OGCBLI	SWAP.W	D3	CLR.W	D3	CALL	CLIPHOR	JUMP',NE 20$	LOAD.L	D4,D3	LOAD.W	D3,(A6)+OMALMY	SUB.W	D3,(A4)+OGCBLI	SWAP.W	D3	LOAD.W	D3,(A6)+OMALMX	CALL	CLIPHOR	JUMP',NE 20$	EX.L	D3,D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine la ligne de base; Dessine la rfrence gauche.20$:	CLR.L	D3	LOAD.W	D3,(A4)+OGCLMA	JUMP',EQ 30$	CALL	CLIPVERT	JUMP',NE 30$	LOAD.L	D4,D3	LOAD.W	D3,(A6)+OMALMY	SWAP.W	D3	LOAD.W	D3,(A4)+OGCLMA	CALL	CLIPVERT	JUMP',NE 30$	EX.L	D3,D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine la rfrence gauche; Dessine la largeur du caractre.30$:	LOAD.L	A3,#(A4)+OGCWID	; A3 <-- ^table des largeurs	CLR.W	D3	LOAD.B	D3,(A6)+OCAR	COMP.B	D3,#-1	JUMP',EQ 40$	CLR.W	D1	LOAD.B	D1,(A3)+(D3.W)	; D1 <-- largeur du caractre	CLR.L	D3	LOAD.W	D3,D1	JUMP',EQ 40$	CALL	CLIPVERT	JUMP',NE 40$	LOAD.L	D4,D3	LOAD.W	D3,(A6)+OMALMY	SWAP.W	D3	LOAD.W	D3,D1	CALL	CLIPVERT	JUMP',NE 40$	EX.L	D3,D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine la largeur; Dessine la ligne de sparation variable.40$:	LOAD.L	D5,(A6)+OSEPP1	LOAD.L	D6,(A6)+OSEPP2	CALL	INVSEP		; dessine la ligne90$:	POPM.L	D1..D6,A3,A4	RET;--------\\; INVSEP  >;========/; Inverse la ligne de sparation.; in	D5.L	origine (y;x);	D6.L	arrive (y;x); out	-; mod	D7.WINVSEP:	PUSHM.L	D1..D4	COMP.L	D5,D6		; P1 = P2 ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	D3,D5		; D3 <-- origine	LOAD.L	D4,D6		; D4 <-- arrive	LOAD.W	D1,D3	SUB.W	D1,D4	JUMP',NC 20$	NEG.W	D1		; D1 <-- |dx|20$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,D3	SUB.W	D2,D4	JUMP',NC 25$	NEG.W	D2		; D2 <-- |dy|25$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,D2	JUMP',LO 50$				; droite horizontale =>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,D3		; Y arrive = Y origine	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#1	COMP.W	D3,D4	JUMP',LO 40$	NEG.W	D240$:	ADD.W	D4,D2		; allonge la droite d'un point	CALL	CLIPHOR	JUMP',NE 90$	EX.L	D3,D4	CALL	CLIPHOR	JUMP',NE 90$	EX.L	D3,D4	JUMP'	80$50$:				; droite verticale =>	LOAD.W	D4,D3		; X arrive = X origine	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#1	COMP.W	D3,D4	JUMP',LO 60$	NEG.W	D260$:	ADD.W	D4,D2		; allonge la droite d'un point	SWAP.W	D3	SWAP.W	D4	CALL	CLIPVERT	JUMP',NE 90$	EX.L	D3,D4	CALL	CLIPVERT	JUMP',NE 90$	EX.L	D3,D480$:	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	; D2 <-- mode	LIB	?DRSEG90$:	POPM.L	D1..D4	RET;---------\\; CLIPVERT >;---------/; Effectue le "clipping" d'un point plac sur une droite; verticale, pour qu'il soit dans le grand rectangle.; in	D3.L	coordonne matrice (y;x); out	D3.L	coordonne cran (y;x);	D7.W	erreur; mod	D3.L, D7.WCLIPVERT:	PUSH.L	D2; Effectue le clipping dans le grand rectangle.	LOAD.W	D7,#ERDIOUT	SUB.W	D3,(A6)+OGMOVX	; trop  gauche ?	JUMP,LS 90$	CLR.L	D2	LOAD.W	D2,(A6)+OGRDIX	DIV.WU	D2,(A6)+OGMLPX	COMP.W	D3,D2		; trop  droite ?	JUMP,HS 90$	SWAP.W	D3	SUB.W	D3,(A6)+OGMOVY	; trop en haut ?	JUMP',HS 20$	CLR.W	D320$:	CLR.L	D2	LOAD.W	D2,(A6)+OGMDIY	DIV.WU	D2,(A6)+OGMLPY	COMP.W	D3,D2		; trop en bas ?	JUMP',LS 25$	LOAD.W	D3,D225$:	SWAP.W	D3; Calcul les coordonnes en point cran.	LOAD.W	D2,D3	MUL.WU	D2,(A6)+OGMLPX	ADD.W	D2,(A6)+OGMPOX	DEC.W	D2	LOAD.W	D3,D2	SWAP.W	D3	LOAD.W	D2,D3	MUL.WU	D2,(A6)+OGMLPY	ADD.W	D2,(A6)+OGMPOY	DEC.W	D2	LOAD.W	D3,D2	SWAP.W	D3; Effectue le clipping hors du petit rectangle.	LOAD.W	D2,(A6)+OPRPOX	SUB.W	D2,#2	COMP.W	D3,D2	JUMP',LO 80$	SWAP.W	D3	LOAD.W	D2,(A6)+OPRPOY	ADD.W	D2,(A6)+OPRDIY	ADD.W	D2,#2	COMP.W	D3,D2	JUMP',HS 40$	LOAD.W	D3,D240$:	SWAP.W	D380$:	CLR.W	D7		; D7 <-- ok90$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; CLIPHOR  >;---------/; Effectue le "clipping" d'un point plac sur une droite; horizontale, pour qu'il soit dans le grand rectangle.; in	D3.L	coordonne matrice (y;x); out	D3.L	coordonne cran (y;x);	D7.W	erreur; mod	D3.L, D7.WCLIPHOR:	PUSHM.L	D1,D2; Effectue le clipping dans le grand rectangle.	LOAD.W	D7,#ERDIOUT	SWAP.W	D3	SUB.W	D3,(A6)+OGMOVY	; trop haut ?	JUMP,LS 90$	CLR.L	D2	LOAD.W	D2,(A6)+OGMDIY	DIV.WU	D2,(A6)+OGMLPY	COMP.W	D3,D2		; trop en bas ?	JUMP,HS 90$	SWAP.W	D3	SUB.W	D3,(A6)+OGMOVX	; trop  gauche ?	JUMP',HS 20$	CLR.W	D320$:	CLR.L	D2	LOAD.W	D2,(A6)+OGMDIX	DIV.WU	D2,(A6)+OGMLPX	COMP.W	D3,D2		; trop  droite ?	JUMP',LS 25$	LOAD.W	D3,D225$:; Calcul les coordonnes en point cran.	LOAD.W	D2,D3	MUL.WU	D2,(A6)+OGMLPX	ADD.W	D2,(A6)+OGMPOX	DEC.W	D2	LOAD.W	D3,D2	SWAP.W	D3	LOAD.W	D2,D3	MUL.WU	D2,(A6)+OGMLPY	ADD.W	D2,(A6)+OGMPOY	DEC.W	D2	LOAD.W	D3,D2	SWAP.W	D3; Effectue le clipping hors du petit rectangle.	LOAD.L	D1,D3	SWAP.W	D1	LOAD.W	D2,(A6)+OPRPOY	ADD.W	D2,(A6)+OPRDIY	ADD.W	D2,#2	COMP.W	D1,D2	JUMP',HS 80$	LOAD.W	D2,(A6)+OPRPOX	SUB.W	D2,#2	COMP.W	D3,D2	JUMP',LO 80$	LOAD.W	D3,D280$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET	.END