	.SBTTL	DESS2MOVE; Variables temporaires sur le stack; ----------------------------------OMVPTD	=	-4		; ^matrice de dpartOMVPTA	=	-8		; ^matrice d'arriveOMVPTI	=	-12		; ^matrice intermdiaireOMVPOS	=	-16		; position (y;x)OMVDIM	=	-20		; dimensions (dy;dx)LMV	=	-20; Macros rapides; --------------;MOVED_INCX:	.MACRO	MOVED_INCX	.LOCALMACRO END	DEC.B	D0		; x <-- x+1	JUMP',PL END	LOAD.L	D0,#7	INC.L	A0END:	.ENDMACRO;MOVED_DECX:	.MACRO	MOVED_DECX	.LOCALMACRO END	INC.B	D0		; x <-- x-1	COMP.B	D0,#8	JUMP',LT END	CLR.B	D0	DEC.L	A0END:	.ENDMACRO;MOVED_INCY:	.MACRO	MOVED_INCY	ADD.W	A0,A3		; y <-- y+1	.ENDMACRO;MOVED_DECY:	.MACRO	MOVED_DECY	SUB.W	A0,A3		; y <-- y-1	.ENDMACRO;MOVEA_INCX:	.MACRO	MOVEA_INCX	.LOCALMACRO END	DEC.B	D1		; x <-- x+1	JUMP',PL END	LOAD.L	D1,#7	INC.L	A1END:	.ENDMACRO;MOVEA_DECX:	.MACRO	MOVEA_DECX	.LOCALMACRO END	INC.B	D1		; x <-- x-1	COMP.B	D1,#8	JUMP',LT END	CLR.B	D1	DEC.L	A1END:	.ENDMACRO;MOVEA_INCY:	.MACRO	MOVEA_INCY	ADD.W	A1,A3		; y <-- y+1	.ENDMACRO;MOVEA_DECY:	.MACRO	MOVEA_DECY	SUB.W	A1,A3		; y <-- y-1	.ENDMACRO;------------\\; _DESS2_MOVE >;============/; ; in	A0.L	^matrice de dpart;	A1.L	^matrice d'arrive;	A2.L	^matrice intermdiaire ( calculer);	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D5.W	Iy; out	-; mod	D7.W_DESS2_MOVE:	PUSHM.L	D0..D6,A0..A3	LINK	A6,#LMV		; A6 <-- ^variables temporaires	LOAD.L	(A6)+OMVPTD,A0	LOAD.L	(A6)+OMVPTA,A1	LOAD.L	(A6)+OMVPTI,A2	LOAD.L	(A6)+OMVPOS,D3	LOAD.L	(A6)+OMVDIM,D4	LOAD.W	A3,D5		; A3 <-- Iy	CALL	MOVESCAN	LOAD.L	A0,(A6)+OMVPTD	LOAD.L	(A6)+OMVPTD,(A6)+OMVPTA	LOAD.L	(A6)+OMVPTA,A0	CALL	MOVESCAN	UNLINK	A6		; ajuste le stack	POPM.L	D0..D6,A0..A3	RET;---------\\; MOVESCAN >;---------/; ; in	; out	-; mod	D7.WMOVESCAN:	PUSHM.L	D0..D6,A0..A3	LOAD.L	A0,(A6)+OMVPTA	CALL	MOVEPB	LOAD.L	A1,A0	LOAD.W	D1,D0		; A1/D1 <-- origine dans arrive	LOAD.L	A0,(A6)+OMVPTD	CALL	MOVEPB		; A0/D0 <-- origine dans dpart	LOAD.L	D2,(A6)+OMVPOS	LOAD.L	D3,D2	LOAD.W	D5,(A6)+OMVDIM+0 ; D5 <-- hauteur	DEC.W	D510$:	PUSHM.L	D0,D1,D2,D3,D5,A0,A1	LOAD.W	D5,(A6)+OMVDIM+2 ; D5 <-- largeur	DEC.W	D520$:	TEST.B	(A0):D0		; point dans dpart ?	JUMP',BC 30$		; non => 30$	CALL	MOVESEARCH	; D4 <-- point le plus proche dans arrive	JUMP',NE 30$	CALL	MOVEPUT		; met point dans intermdiaire30$:	MOVED_INCX		; A0/D0 <-- x+1	INC.W	D2		; D2 <-- x+1	MOVEA_INCX		; A1/D1 <-- x+1	INC.W	D3		; D3 <-- x+1	DECJ.W,NMO D5,20$	POPM.L	D0,D1,D2,D3,D5,A0,A1	MOVED_INCY		; A0/D0 <-- y+1	SWAP.W	D2	INC.W	D2		; D2 <-- y+1	SWAP.W	D2	MOVEA_INCY		; A1/D1 <-- y+1	SWAP.W	D3	INC.W	D3		; D3 <-- y+1	SWAP.W	D3	DECJ.W,NMO D5,10$	POPM.L	D0..D6,A0..A3	RET;-----------\\; MOVESEARCH >;-----------/; Cherche le point le plus proche d'un autre, en parcourant; une spirale concentrique rectangulaire.;	      ^;	      |;	      |       i+1;	  i+2 |      o--->|;	      |    D3     | i+1;	      |           V;	      |<-----------;	           i+2; in	D3.L	centre (y;x);	A1/D1	centre (^/bit);	A3.W	Iy; out	D4.L	point trouv (y;x);	D7.W	ok/erreur; mod	D4.L, D7.WMOVESEARCH:	TEST.B	(A1):D1	JUMP',BC BEGIN$	LOAD.L	D4,D3		; D4 <-- point trouv	CLR.W	D7		; D7 <-- ok	RETBEGIN$:	PUSHM.L	D0,D1,D2,D3,D5,D6,A0,A1,A2	LOAD.L	D4,D3		; D3 <-- x	SWAP.W	D4		; D4 <-- y	LOAD.L	D0,(A6)+OMVPOS	LOAD.L	D2,(A6)+OMVDIM	; D0 <-- min x	ADD.W	D2,D0		; D2 <-- max x	SWAP.W	D0	SWAP.W	D2	ADD.W	D2,D0	LOAD.W	A0,D0		; A0 <-- min x	LOAD.W	A2,D2		; A2 <-- max y	SWAP.W	D0	SWAP.W	D2	CLR.W	D5		; D5 <-- iSPIRAL$:; Avance vers la droite.	LOAD.W	D6,D5RIGHT2$:	COMP.W	D4,A0		; dpasse en haut ?	JUMP',LT RIGHT3$	COMP.W	D3,D2		; dpasse  droite ?	JUMP',GE RIGHT3$	TEST.B	(A1):D1	JUMP,BS FOUND$RIGHT3$:	MOVEA_INCX		; A1/D1 <-- x+1	INC.W	D3		; D3 <-- x+1	DECJ.W,NMO D6,RIGHT2$; Avance vers le bas.	LOAD.W	D6,D5DOWN2$:	COMP.W	D3,D2		; dpasse  droite ?	JUMP',GE DOWN3$	COMP.W	D4,A2		; dpasse en bas ?	JUMP',GE DOWN3$	TEST.B	(A1):D1	JUMP,BS FOUND$DOWN3$:	MOVEA_INCY		; A1/D1 <-- y+1	INC.W	D4		; D3 <-- y+1	DECJ.W,NMO D6,DOWN2$; Avance vers la gauche.	INC.W	D5		; D5 <-- i+1	LOAD.W	D6,D5LEFT2$:	COMP.W	D4,A2		; dpasse en bas ?	JUMP',GE LEFT3$	COMP.W	D3,D0		; dpasse  gauche ?	JUMP',LT LEFT3$	TEST.B	(A1):D1	JUMP,BS FOUND$LEFT3$:	MOVEA_DECX		; A1/D1 <-- x-1	DEC.W	D3		; D3 <-- x-1	DECJ.W,NMO D6,LEFT2$; Avance vers le haut.	LOAD.W	D6,D5UP2$:	COMP.W	D3,D0		; dpasse  gauche ?	JUMP',LT UP3$	COMP.W	D4,A0		; dpasse en haut ?	JUMP',LT UP3$	TEST.B	(A1):D1	JUMP,BS FOUND$UP3$:	MOVEA_DECY		; A1/D1 <--y-1	DEC.W	D4		; D3 <-- y-1	DECJ.W,NMO D6,UP2$; Incrmente encore une fois (total = 2) le paramtre "i".	INC.W	D5		; D5 <-- i+1	COMP.W	D5,#100	JUMP,LO SPIRAL$	LOAD.W	D7,#1		; D7 <-- pas trouv	JUMP'	EXIT$FOUND$:	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- point trouv (y;x)	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0,D1,D2,D3,D5,D6,A0,A1,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; MOVEPUT >;--------/; Met un point dans le rsultat.; in	D3.L	point dpart (y;x);	D4.L	point arrive (y;x); out	-; mod	D7.WMOVEPUT:	PUSHM.L	D0,D3,D4,A0	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LOAD.L	A0,(A6)+OMVPTI	CALL	MOVEPB	TSET.B	(A0):D0	POPM.L	D0,D3,D4,A0	RET;--------\\; MOVEPB  >;--------/; ; in	D3.L	coordonne (y;x);	A0.L	^matrice;	A3.W	Iy; out	A0/D0	point (^/bit); mod	D0.L, A0.LMOVEPB:	PUSHM.L	D3,D4	LOAD.B	D0,D3	NOT.B	D0	AND.W	D0,#B'111	; D0 <-- no du bit dans le byte	SR.W	D3,#3		; dcale coordonne X	ADD.W	A0,D3	SWAP.W	D3	LOAD.W	D4,A3		; D4 <-- Iy	MUL.WU	D3,D4		; dcale coordonne Y	ADD.L	A0,D3		; A0 <-- ^bitmap	POPM.L	D3,D4	RET	.END