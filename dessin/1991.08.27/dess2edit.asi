	.SBTTL	DESS2EDIT;-------------\\; _DESS2_REDIT >;=============/; in	D1.L	<F><S><T><code> de l'icne;	D2.W	mode d'ouverture de la dbox;	D3.L	centre si BDBPOS;	A4.L	^oprations (2 trames 8x8);	A0.L	^descripteur de la fentre; out	D3.L	d'accord/annule (F1/F0);	D7.W	erreur; mod	D3.L, D7.W_DESS2_REDIT:	PUSHM.L	D0..D2,D4,D5,A1..A4,A6	CALL	OPEVOP		; A6 <-- ^variables	JUMP,NE 95$	LOAD.L	(A6)+OOPRGC,D1	; OOPRGC <-- gencar  utiliser	CLR.L	D4	LOAD.B	D4,(A4)+ORELX	; D4 <-- fanions	CALL	OPEXDEF		; ouvre la DBOX	JUMP,NE	90$	CALL	ALLXDEF		; montre la trame actuelle05$:	CALL	SHOXDEF		; montre le rsultat10$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_XDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ	80$	COMP.W	D3,#F0	JUMP,EQ	85$	COMP.W	D3,#DEL	JUMP,EQ	50$	COMP.W	D3,#KEYMGP	JUMP',EQ 20$	COMP.W	D3,#KEYMMP	JUMP',EQ 20$	COMP.W	D3,#KEYMDP	JUMP',EQ 20$	COMP.W	D3,#KEYMGR	JUMP,EQ	10$	COMP.W	D3,#KEYMMR	JUMP,EQ	10$	COMP.W	D3,#KEYMDR	JUMP,EQ	10$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP,EQ 60$15$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	10$20$:	CALL	MOUXDEF		; D0 <-- X et D1 <-- Y	JUMP,NE 15$	LOAD.W	D2,#-1		; D2 <-- dernire coordonne X	LOAD.W	D3,D2		; D3 <-- dernire coordonne Y	CLR.B	(A6)+OOPROP	TEST.B	(A4)+(D1.W)+ORELSET:D0	JUMP',BS 30$	LOAD.B	(A6)+OOPROP,#1	TEST.B	(A4)+(D1.W)+ORELCLR:D0	JUMP',BS 30$	LOAD.B	(A6)+OOPROP,#230$:	CALL	MOUXDEF		; D0 <-- X et D1 <-- Y	JUMP',NE 40$	COMP.W	D0,D2		; changement ?	JUMP',NE 32$		; oui => 32$	COMP.W	D1,D3		; non => 40$	JUMP',EQ 40$32$:	LOAD.W	D2,D0		; D2 <-- dernire coordonne X	LOAD.W	D3,D1		; D3 <-- dernire coordonne Y	COMP.B	(A6)+OOPROP,#2	JUMP',EQ 38$	COMP.B	(A6)+OOPROP,#1	JUMP',EQ 36$	TCLR.B	(A4)+(D1.W)+ORELSET:D0	TSET.B	(A4)+(D1.W)+ORELCLR:D0	CALL	DOTXDEF		; teint gros point	JUMP'	40$36$:	TCLR.B	(A4)+(D1.W)+ORELSET:D0	TCLR.B	(A4)+(D1.W)+ORELCLR:D0	CALL	DOTXDEF		; grise gros point	JUMP'	40$38$:	TSET.B	(A4)+(D1.W)+ORELSET:D0	TCLR.B	(A4)+(D1.W)+ORELCLR:D0	CALL	DOTXDEF		; allume gros point;	JUMP'	40$40$:	PUSH.L	D3	LIB	?GETKEY		; attend souris ...	LOAD.W	D1,D3	POP.L	D3	COMP.W	D1,#KEYMPO	; souris dplace ?	JUMP,EQ	30$		; oui => 30$	COMP.W	D1,#KEYMGR	JUMP,EQ	05$	COMP.W	D1,#KEYMMR	; bouton relach ?	JUMP,EQ	05$		; oui => 05$	COMP.W	D1,#KEYMDR	JUMP,EQ	05$	JUMP	40$50$:				; EFFACE =>	CLR.L	(A4)+ORELSET+0	CLR.L	(A4)+ORELSET+4	CLR.L	(A4)+ORELCLR+0	CLR.L	(A4)+ORELCLR+4	LOAD.B	D4,#B'001	LOAD.B	(A4)+ORELX,D4	CALL	ALLXDEF	CALL	CLRXDEF		; efface le rectangle de droite	JUMP	05$60$:	LOAD.B	(A4)+ORELX,D4	CALL	CLRXDEF		; efface le rectangle de droite	JUMP	05$80$:				; D'ACCORD =>85$:				; ANNULE =>	DBOX_	CLOSE		; ferme la DBOX90$:	CALL	CLOVOP		; libre les variables95$:	POPM.L	D0..D2,D4,D5,A1..A4,A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; OPEXDEF >;--------/; Ouvre la DBOX pour dfinir la trame.; in	D2.W	mode d'ouverture de la dbox;	D3.L	centre si BDBPOS;	D4.L	fanions; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WOPEXDEF:	PUSHM.L	D0..D4,A3	LOAD.L	A2,#R16"TDBOX_XDEF	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	LIB	?GETDIM		; D3 <-- dim caractre	LOAD.L	D4,D3	SWAP.W	D4		; D4 <-- hauteur	SL.W	D3,#1		; D3 <-- largeur *2	COMP.W	D3,D4	JUMP',LS 20$	LOAD.W	D3,D4		; D3 <-- le plus petit20$:	LOAD.W	(A6)+OOPRLG,D3	LOAD.W	D2,(A6)+OOPRLG	LOAD.W	D3,D2;	MUL.WU	D3,#1	SUB.W	D3,#2		; D3 <-- X	SWAP.W	D3	LOAD.W	D3,D2	SUB.W	D3,#2		; D3 <-- Y	SWAP.W	D3	SL.W	D2,#3	ADD.W	D2,#2	LOAD.W	D4,D2		; D4 <-- dY	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- dX	LOAD.W	D2,#SETDOT	; D2 <-- mode	LIB	?DRRECT		; dessine rectangle gauche	LOAD.W	D1,(A6)+OOPRLG	MUL.WU	D1,#8+2	ADD.W	D3,D1	LIB	?DRRECT		; dessine rectangle droite90$:	POPM.L	D0..D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLRXDEF >;--------/; Efface le rectangle de droite.; in	-; out	-; mod	D7.WCLRXDEF:	PUSHM.L	D2..D4	CLR.L	D4	CALL	DRMDEF		; dfinit trame pour effacer	LOAD.W	D2,(A6)+OOPRLG	LOAD.W	D3,D2	MUL.WU	D3,#1+8+2	; D3 <-- X	SWAP.W	D3	LOAD.W	D3,D2		; D3 <-- Y	SWAP.W	D3	SL.W	D2,#3	SUB.W	D2,#2	LOAD.W	D4,D2		; D4 <-- dY	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- dX	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface l'ancien	POPM.L	D2..D4	RET;--------\\; MOUXDEF >;--------/; Lit la position de la souris.; in	-; out	D0.W	coordonne X (0..7);	D1.W	coordonne Y (0..7);	D7.W	erreur; mod	D0.L, D1.L, D4.LMOUXDEF:	PUSHM.L	D2..D5	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 90$	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	SUB.W	D4,(A0)+ODFFX	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A6)+OOPRLG	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D0	LOAD.W	D0,D4	DIV.WU	D0,(A6)+OOPRLG	; D0 <-- coordonne X (0..7);	SUB.W	D0,#8+2	JUMP',LO 90$	COMP.W	D0,#8	JUMP',HS 90$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A6)+OOPRLG	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D1	LOAD.W	D1,D4	DIV.WU	D1,(A6)+OOPRLG	; D1 <-- coordonne Y (0..7)	COMP.W	D1,#8	JUMP',HS 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; ALLXDEF >;--------/; Dessine toute la matrice.; in	A4.L	^oprations (2 trames 8x8); out	-; mod	D7.WALLXDEF:	PUSHM.L	D0,D1	CLR.W	D010$:	CLR.W	D120$:	LOAD.B	(A6)+OOPROP,#2	TEST.B	(A4)+(D1.W)+ORELSET:D0	JUMP',BS 30$	CLR.B	(A6)+OOPROP	TEST.B	(A4)+(D1.W)+ORELCLR:D0	JUMP',BS 30$	LOAD.B	(A6)+OOPROP,#130$:	CALL	DOTXDEF		; dessine un gros point	INC.W	D1	COMP.W	D1,#8	JUMP,LO	20$	INC.W	D0	COMP.W	D0,#8	JUMP,LO	10$	POPM.L	D0,D1	RET;--------\\; DOTXDEF >;--------/; Dessine un point dans le rectangle de gauche.; in	D0.W	coordonne X (0..7);	D1.W	coordonne Y (0..7); out	-; mod	D7.WDOTXDEF:	PUSHM.L	D0..D5	CLR.L	D4		; D4 <-- blanc	LOAD.B	D3,(A6)+OOPROP	JUMP',EQ 10$	LOAD.L	D4,#H'00550055	; D4 <-- gris	DEC.B	D3	JUMP',EQ 10$	LOAD.L	D4,#-1		; D4 <-- noir10$:	CALL	DRMDEF		; dfinit la trame	LOAD.L	D5,D4	LOAD.W	D2,(A6)+OOPRLG	MUL.WU	D0,D2	MUL.WU	D1,D2	LOAD.W	D3,D2	ADD.W	D3,D1	SWAP.W	D3	LOAD.W	D1,(A6)+OOPRLG;	MUL.WU	D1,#1	LOAD.W	D3,D1	ADD.W	D3,D0	LOAD.W	D4,D2	DEC.W	D4	SWAP.W	D4	LOAD.W	D4,D2	DEC.W	D4	COMP.L	D5,#-1	JUMP',EQ 60$	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; teint qq points60$:	TEST.L	D5	JUMP',EQ 90$	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; allume qq points90$:	POPM.L	D0..D5	RET;--------\\; SHOXDEF >;--------/; Dessine le rsultat de l'opration.; in	A4.L	^matrices d'opration; out	-; mod	D7.WSHOXDEF:	PUSHM.L	D1..D4	LOAD.W	D2,(A6)+OOPRLG	LOAD.W	D3,D2	MUL.WU	D3,#1+8+2	SUB.W	D3,#2		; D3 <-- X	SWAP.W	D3	LOAD.W	D3,D2	SUB.W	D3,#2		; D3 <-- Y	SWAP.W	D3	SL.W	D2,#3	ADD.W	D2,#2	LOAD.W	D4,D2		; D4 <-- dY	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- dX	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LOAD.L	D1,(A6)+OOPRGC	; D1 <-- gencar  utiliser	CALL	_DESS2_RCAR	; dessine l'opration	POPM.L	D1..D4	RET;------------\\; _DESS2_RCAR >;============/; Dessine l'opration de relief avec une icne quelconque.; in	D1.L	<F><S><T><code> de l'icne;	D3.L	centre (y;x);	A4.L	^matrices d'opration;	A0.L	^descripteur de la fentre; out	-; mod	D7.W_DESS2_RCAR:	PUSHM.L	D0..D5,A3	LOAD.B	D5,D1		; D5 <-- code	LOAD.L	D2,D3		; D2 <-- position	LOAD.L	D0,(A0)+ODFGCF	LOAD.B	D0,#USEGC	RR.L	D0,#8	PUSH.L	D0		; stack <-- gencar initial	LOAD.B	D1,#USEGC	RR.L	D1,#8	PUSH.L	D1	LOAD.L	A3,SP		; A3 <-- ^<USEGC><F><S><T>	LOAD.W	D3,#4	LIB	?STRING		; utilise le gencar demand	POP.L	D1	LOAD.L	D4,D2		; D4 <-- position	CLR.W	D1	LOAD.B	D1,(A4)+ORELX	; D1 <-- 1/2/4	SL.W	D1,#2		; D1 <-- 4/8/16	LOAD.W	D0,(A0)+ODFCX	SR.W	D0,#1	SUB.W	D4,D0	SUB.W	D4,D1	ADD.W	D4,(A0)+ODFC1X	SWAP.W	D4	LOAD.W	D0,(A0)+ODFC1Y	ADD.W	D0,(A0)+ODFC2Y	SR.W	D0,#1	SUB.W	D4,D0	SUB.W	D4,D1	ADD.W	D4,(A0)+ODFC1Y	SWAP.W	D4	LIB	?BUCAR		; mode rapide	LIB	?AFTIM	.B	MODCAR	.B	SETDOT!PENDOT	.B	0	.EVEN	LOAD.B	D2,(A4)+ORELX	; D2 <-- 1/2/4	SR.B	D2,#1		; D2 <-- 0/1/2	CLR.W	D0		; D0 <-- X initial20$:	CLR.W	D1		; D1 <-- Y initial22$:	PUSHM.W	D0,D1	SR.W	D0,D2	SR.W	D1,D2	TEST.B	(A4)+(D1.W)+ORELSET:D0	POPM.W	D0,D1	JUMP',BC 26$	LOAD.L	D3,D4	ADD.W	D3,D0	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,D5	LIB	?AFCAR26$:	LOAD.W	D3,#8	SL.W	D3,D2	INC.W	D1		; D1 <-- Y suivant	COMP.W	D1,D3	JUMP,LO	22$	INC.W	D0		; D0 <-- X suivant	COMP.W	D0,D3	JUMP,LO	20$	LIB	?AFTIM	.B	MODCAR	.B	CLRDOT!PENDOT	.B	0	.EVEN	CLR.W	D0		; D0 <-- X initial40$:	CLR.W	D1		; D1 <-- Y initial42$:	PUSHM.W	D0,D1	SR.W	D0,D2	SR.W	D1,D2	TEST.B	(A4)+(D1.W)+ORELCLR:D0	POPM.W	D0,D1	JUMP',BC 46$	LOAD.L	D3,D4	ADD.W	D3,D0	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,D5	LIB	?AFCAR46$:	LOAD.W	D3,#8	SL.W	D3,D2	INC.W	D1		; D1 <-- Y suivant	COMP.W	D1,D3	JUMP,LO	42$	INC.W	D0		; D0 <-- X suivant	COMP.W	D0,D3	JUMP,LO	40$	LIB	?AFTIM	.B	MODCAR	.B	SETDOT	.B	0	.EVEN	LIB	?NOBUCAR	; remet le mode normal	LOAD.L	A3,SP		; A3 <-- ^<USEGC><F><S><T>	LOAD.W	D3,#4	LIB	?STRING		; utilise le gencar initial	POP.L	D0	POPM.L	D0..D5,A3	CLR.W	D7		; D7 <-- ok	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; ATTENTION:	Le fait d'crire directement dans le descripteur;		de la fentre fait que la trame est inverse;		entre le Smaky 8 et 100 (gauche <--> droite) !;		Il ne faut donc utiliser que des trames simples;		(pas de hachures par exemple).; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	RETTDBOX_XDEF:	.W	10$-TDBOX_XDEF	.W	20$-TDBOX_XDEF	.W	0,010$:	.B	ODBTABX,((8+2+8)*2)+1	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,DEL,TDBNORM	.ASCIZ	"  EFFACE  "	.B	ODBTABX,28	.B	ODBLCIRCLE,0!2^7,KEYICO/H'100,0	.ASCIZ	" 1x"	.B	ODBCR	.B	ODBTABX,28	.B	ODBLCIRCLE,1!2^7,KEYICO/H'100,1	.ASCIZ	" 2x"	.B	ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	ODBTABX,28	.B	ODBLCIRCLE,2!2^7,KEYICO/H'100,2	.ASCIZ	" 4x"	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_XDEF:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_XDEF	.W	F1,F2,F3,CR,0		DOKF1-TKEY_XDEF	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_XDEF	.W	0DOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RET	.END