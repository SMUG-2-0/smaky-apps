	.SBTTL	DESICONE;--------\\; DESPDEF >;========/; Dessine la forme du pinceau dans les icnes.; in	-; out	-; mod	D7.WDESPDEF:	PUSHM.L	D2..D4,A3,A4	CLR.L	D4	CALL	DRMDEF	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOROUTIL	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.B	D3,#ICOPDEF	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	LOAD.L	A4,#(A6)+OPDEF	LOAD.W	D3,(A6)+ONPDEF	MUL.WU	D3,#8+2	ADD.L	A4,D3		; A4 <-- ^bon pinceau	LOAD.L	D3,D4	ADD.W	D3,#((GCICX/2+GCIMX*2)-8)/2	SWAP.W	D3	ADD.W	D3,#((GCICY+GCIMY*2)-8)/2	SWAP.W	D3	LOAD.L	D4,#H'10000*8+8	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'ancien pinceau	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#1	; source: <ii>	SWAP.W	D3	LOAD.L	(A3)+12,D3	; destination: <xx> et <yy>	CLR.L	(A3)+16		; destination: <pppp>	SWAP.W	D4	LOAD.L	(A3)+22,D4	; <dxx> et <dyy>	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; cran <-- pinceauEXIT$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D2..D4,A3,A4	RET;--------\\; DESTDEF >;========/; Dessine la trame de remplissage dans les icnes.; in	-; out	-; mod	D7.WDESTDEF:	PUSHM.L	D0,D2..D6,A4	CLR.L	D4	CALL	DRMDEF		; dfinit trame pour effacer	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOROUTIL	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.B	D3,#ICOTDEF	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	LOAD.L	A4,#(A6)+OTDEF	LOAD.W	D3,(A6)+ONTDEF	MUL.WU	D3,#8	ADD.L	A4,D3		; A4 <-- ^bonne trame	LOAD.L	D5,(A4)+0	LOAD.L	D6,(A4)+4	; D5/D6 <-- trame de remplissage	LOAD.L	D3,D4	ADD.W	D3,#4	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2-4*2	SWAP.W	D4	LOAD.W	D4,#GCICX/2+GCIMX*2-4*2	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'ancienne trame	ADD.W	D4,D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,#2		; D0 <-- rayon	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CALL	RTRAMEEXIT$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D0,D2..D6,A4	RET;--------\\; DESRDEF >;========/; Dessine le rectangle dans les icnes.; in	-; out	-; mod	D7.WDESRDEF:	PUSHM.L	D0..D4	CLR.L	D4	CALL	DRMDEF		; dfinit trame pour effacer	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOROBJET	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.B	D3,#ICORDEF	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	LOAD.L	D3,D4	ADD.W	D3,#5	SWAP.W	D3	ADD.W	D3,#5	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2-5*2	SWAP.W	D4	LOAD.W	D4,#GCICX/2+GCIMX*2-5*2	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'ancien rectangle	PUSHM.L	D3,D4	SUB.W	D3,#5	ADD.W	D4,#5*2	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#3	SUB.W	D4,#3*2	ADD.W	D3,D4	DEC.W	D3	NEG.W	D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; dessine la diagonale	POPM.L	D3,D4	ADD.W	D4,D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,(A6)+ORRECT	; D0 <-- rayon	JUMP',EQ 40$	LOAD.W	D0,#340$:	LOAD.B	D1,(A6)+OTRECT	; D1 <-- type;	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CALL	RRECTTRAM	; dessine le rectangle arrondiEXIT$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D0..D4	RET;--------\\; DESADEF >;========/; Dessine le cercle dans les icnes.; in	-; out	-; mod	D7.WDESADEF:	PUSHM.L	D2..D6	CLR.L	D4	CALL	DRMDEF		; dfinit trame pour effacer	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOROBJET	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.B	D3,#ICOADEF	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	LOAD.L	D3,D4	ADD.W	D3,#4	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2-4*2	SWAP.W	D4	LOAD.W	D4,#GCICX/2+GCIMX*2-4*2	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'ancien cercle	INC.W	D3	SUB.W	D4,#2	SR.W	D4,#1		; D4 <-- Rx	ADD.W	D3,D4		; D3 <-- Cx	SWAP.W	D3	SWAP.W	D4	INC.W	D3	SUB.W	D4,#2	SR.W	D4,#1		; D4 <-- Ry	LOAD.W	D2,D4	ADD.W	D3,D4		; D3 <-- Cy	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- Rx = Ry	TEST.B	(A6)+OPOLY:#BPOLYE	JUMP',BC 30$	SWAP.W	D4	SUB.W	D4,#3		; D4 <-- Ry diminu	SWAP.W	D4	JUMP'	35$30$:	CLR.W	D4		; D4 <-- Rx nul	SWAP.W	D4	NEG.W	D4		; D4 <-- -Ry	SWAP.W	D435$:	LOAD.L	D5,D3	LOAD.L	D6,D4	ADD.W	D6,D5	SWAP.W	D5	SWAP.W	D6	ADD.W	D6,D5	SWAP.W	D5	SWAP.W	D6	PUSH.B	(A6)+OOBJET	PUSH.B	(A6)+OOUTIL	PUSH.B	(A6)+OMCERC	LOAD.B	(A6)+OOBJET,#ICOCERCLE	LOAD.B	(A6)+OOUTIL,#ICOCRAYON	TCLR.B	(A6)+OMCERC:#BMCEDIA	TSET.B	(A6)+OMCERC:#BMCERAY	LOAD.W	D2,#SETDOT!2^13	; D2 <-- dessine dans la fentre principale	CALL	DESCOMMEPLAN	; dessine un cercle quelconque	POP.B	(A6)+OMCERC	POP.B	(A6)+OOUTIL	POP.B	(A6)+OOBJETEXIT$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D2..D6	RET;--------\\; DESXDEF >;========/; Dessine l'opration de relief dans les icnes.; in	D3.W	opration (0..7); out	-; mod	D7.WDESXDEF:	PUSHM.L	D1..D4,A4	LOAD.W	D1,D3		; D1 <-- opration (0..7)	CLR.L	D4	CALL	DRMDEF		; dfinit trame pour effacer	LOAD.W	D4,D1	LOAD.L	A4,#(A6)+OOPREL	MUL.WU	D4,#LREL	ADD.L	A4,D4		; A4 <-- ^matrices d'opration	PUSH.B	(A4)+ORELX	LOAD.B	(A4)+ORELX,#B'001	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORMODIF	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.W	D3,D1	ADD.B	D3,#ICORELIEF1	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP',NE 80$	LOAD.L	D3,D4	PUSH.L	D3	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2-2	SWAP.W	D4	LOAD.W	D4,#GCICX+GCIMX*4-8	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'ancienne opration	POP.L	D3	ADD.W	D3,#(GCICX+GCIMX*4)/2	SWAP.W	D3	ADD.W	D3,#(GCICY+GCIMY*2)/2	SWAP.W	D3	LOAD.L	D1,#H'1000000*GCICF+H'10000*GCICS+H'100*GCICT+ICORELIEF1	DESS2_	RCAR		; dessine l'icne80$:	POP.B	(A4)+ORELX	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D1..D4,A4	RET;--------\\; DESZONE >;========/; Dessine le numro de la zone.; in	-; out	-; mod	D7.WDESZONE:	PUSHM.L	D2..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOROUTIL	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.B	D3,#ICOVZONE	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	LOAD.L	D3,D4	SWAP.W	D3	ADD.W	D3,#GCIMY+3	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LOAD.W	D4,#GCICX+GCIMX*4	SUB.W	D4,(A0)+ODFCX	ASR.W	D4,#1	ADD.W	D3,D4	LIB	?SETCURS	CLR.L	D4	CALL	DRMDEF		; dfinit trame pour effacer	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LOAD.W	D4,(A0)+ODFC1Y	SWAP.W	D4	LOAD.W	D4,(A0)+ODFCX	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'emplacement	LIB	?AFTIM	.B	MODCAR,INVDOT,0	.EVEN	LOAD.W	D3,(A6)+ONOZO	INC.B	D3	COMP.B	D3,#NBZONE	JUMP',NE 40$	CLR.B	D340$:	ADD.B	D3,#'0	LIB	?AFCAR		; affiche le numro de la zone	LIB	?AFTIM	.B	MODCAR,SETDOT,0	.EVENEXIT$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D2..D4	RET;---------\\; DESLOUPE >;=========/; Dessine la loupe.; in	-; out	-; mod	D7.WDESLOUPE:	PUSHM.L	D2..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOROUTIL	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.B	D3,#ICOPLOUPE	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN	LOAD.L	D3,D4	ADD.W	D3,#GCIMX-2	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB+GCIMY	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,#ICOPLOUPE	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE 40$	LOAD.B	D3,#ICOPLOUPE1140$:	LIB	?AFCAR		; affiche la loupe	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVENEXIT$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D2..D4	RET;---------\\; DESTRAP  >;=========/; Dessine le pas pour la trame.; in	-; out	-; mod	D7.WDESTRAP:	PUSHM.L	D2..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORMODIF	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.B	D3,#ICOTRAPX	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	LOAD.L	D3,D4	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SUB.W	D4,(A0)+ODFC1Y	ASR.W	D4,#1	ADD.W	D4,(A0)+ODFC1Y	ADD.W	D3,D4	DEC.W	D3	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#2	SUB.W	D4,#GCICX/2+GCIMX*2	NEG.W	D4	ASR.W	D4,#1	ADD.W	D3,D4	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A6)+OTRAPA	LOAD.W	D3,#2		; D3 <-- nb digits	CLR.W	D2		; D2 <-- mode	LIB	?AFDECEXIT$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D2..D4	RET;---------\\; DESTRAN  >;=========/; Dessine le niveau pour la trame.; in	-; out	-; mod	D7.WDESTRAN:	PUSHM.L	D2..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORMODIF	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.B	D3,#ICOTRANX	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	LOAD.L	D3,D4	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SUB.W	D4,(A0)+ODFC1Y	ASR.W	D4,#1	ADD.W	D4,(A0)+ODFC1Y	ADD.W	D3,D4	DEC.W	D3	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#2	SUB.W	D4,#GCICX/2+GCIMX*2	NEG.W	D4	ASR.W	D4,#1	ADD.W	D3,D4	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A6)+OTRANI	LOAD.W	D3,#2		; D3 <-- nb digits	CLR.W	D2		; D2 <-- mode	LIB	?AFDECEXIT$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D2..D4	RET;---------\\; DESTRAL  >;=========/; Dessine la luminosit pour la trame.; in	-; out	-; mod	D7.WDESTRAL:	PUSHM.L	D2..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORMODIF	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.B	D3,#ICOTRALX	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	LOAD.L	D3,D4	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SUB.W	D4,(A0)+ODFC1Y	ASR.W	D4,#1	ADD.W	D4,(A0)+ODFC1Y	ADD.W	D3,D4	DEC.W	D3	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#2	SUB.W	D4,#GCICX/2+GCIMX*2	NEG.W	D4	ASR.W	D4,#1	ADD.W	D3,D4	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A6)+OTRALU	LOAD.B	D3,#SPACE	TEST.W	D4	JUMP',EQ 30$	LOAD.B	D3,#'+	TEST.W	D4	JUMP',NC 30$	LOAD.B	D3,#'-	NEG.W	D430$:	LIB	?AFCAR		; affiche le signe	LOAD.W	D3,#1		; D3 <-- nb digits	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode	LIB	?AFDECEXIT$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D2..D4	RET;---------\\; DESITL   >;=========/; Dessine l'interligne.; in	-; out	-; mod	D7.WDESITL:	PUSHM.L	D2..D4,A4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORMODE	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.B	D3,#ICOITLX	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	CALL	GETPGC		; A4 <-- ^dans OBUGC	LOAD.L	D3,D4	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SUB.W	D4,(A0)+ODFC1Y	ASR.W	D4,#1	ADD.W	D4,(A0)+ODFC1Y	ADD.W	D3,D4	DEC.W	D3	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#2	SUB.W	D4,#GCICX/2+GCIMX*2	NEG.W	D4	ASR.W	D4,#1	ADD.W	D3,D4	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A6)+OILTEXT	COMP.W	D4,(A4)+OGCITL	JUMP',NE 40$	LOAD.B	D3,#AFGREY	; affiche en gris si =  l'interligne	LIB	?AFCAR40$:	LOAD.W	D3,(A4)+OGC1Y	ADD.W	D3,(A4)+OGC2Y	COMP.W	D4,D3	JUMP',HS 50$	LOAD.B	D3,#AFINV	; affiche en inverse si < h1+h2	LIB	?AFCAR50$:	LOAD.W	D3,#2		; D3 <-- nb digits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC	LIB	?AFTIM	.B	AFDIR	.B	AFFULL	.B	0	.EVENEXIT$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D2..D4,A4	RET;---------\\; DESITC   >;=========/; Dessine l'intercaractre.; in	-; out	-; mod	D7.WDESITC:	PUSHM.L	D2..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORMODE	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.B	D3,#ICOITCX	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	LOAD.L	D3,D4	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SUB.W	D4,(A0)+ODFC1Y	ASR.W	D4,#1	ADD.W	D4,(A0)+ODFC1Y	ADD.W	D3,D4	DEC.W	D3	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#3	SUB.W	D4,#GCICX/2+GCIMX*2	NEG.W	D4	ASR.W	D4,#1	ADD.W	D3,D4	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A6)+OICTEXT	LOAD.B	D3,#SPACE	TEST.W	D4	JUMP',EQ 30$	LOAD.B	D3,#'+	TEST.W	D4	JUMP',NC 30$	LOAD.B	D3,#'-	NEG.W	D430$:	LIB	?AFCAR		; affiche le signe	LOAD.W	D3,#2		; D3 <-- nb digits	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode	LIB	?AFDEC	COMP.W	D4,#10	JUMP',HS EXIT$	LIB	?AFSPACEEXIT$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D2..D4	RET;----------\\; DESCSPACE >;==========/; Dessine l'espacement entre les caractres.; in	-; out	-; mod	D7.WDESCSPACE:	PUSHM.L	D3,D4	LOAD.W	D4,(A6)+OECTEXT	ADD.B	D4,#ICOCURSY1	LOAD.B	D3,#ICOCSPACE	CALL	DESCURS15	POPM.L	D3,D4	RET;----------\\; DESCCOUPE >;==========/; Dessine le critre pour les coupures.; in	-; out	-; mod	D7.WDESCCOUPE:	PUSHM.L	D3,D4	LOAD.W	D4,(A6)+OCNTEXT	ADD.B	D4,#ICOCURSY1	LOAD.B	D3,#ICOCCOUPE	CALL	DESCURS15	POPM.L	D3,D4	RET;---------\\; DESESPCX >;=========/; Dessine l'espace pour le contour en X.; in	-; out	-; mod	D7.WDESESPCX:	PUSHM.L	D3,D4	LOAD.W	D4,(A6)+OCXTEXT	ADD.B	D4,#ICOCURSX1	LOAD.B	D3,#ICOESPCONTX	CALL	DESCURS15	POPM.L	D3,D4	RET;---------\\; DESESPCY >;=========/; Dessine l'espace pour le contour en Y.; in	-; out	-; mod	D7.WDESESPCY:	PUSHM.L	D3,D4	LOAD.W	D4,(A6)+OCYTEXT	ADD.B	D4,#ICOCURSY1	LOAD.B	D3,#ICOESPCONTY	CALL	DESCURS15	POPM.L	D3,D4	RET;----------\\; DESCURS15 >;----------/; Dessine un curseur dans une icne.; in	D3.B	code de l'icne;	D4.B	icne  dessiner (position du curseur); out	-; mod	D7.WDESCURS15:	PUSHM.L	D2..D4	PUSH.L	D3	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORMODE	LIB	?COLORCR	; donne la couleur relative pour effacer	POP.L	D3	LOAD.B	D2,D4	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP',NE EXIT$	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT+1	.B	0	.EVEN	LOAD.L	D3,D4	ADD.W	D3,#GCIMX-2	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB+GCIMY	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,D2	AND.B	D3,#H'7F	LIB	?AFCAR		; affiche le curseur	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVENEXIT$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D2..D4	RET;---------\\; DPLICONE >;=========/; Dplace ventuellement toutes les icnes de gauche.; in	D4.L	position de la souris (y;x); out	D7.W	ok/erreur; mod	D7.WDPLICONE:	PUSHM.L	D2..D4	LOAD.W	D7,#1	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP,BC EXIT$		; non => EXIT$	COMP.W	D4,#MARGX+ICOLX	; trop  droite ?	JUMP,HS EXIT$	CLR.W	D2		; D2 <-- nb de dplacements10$:	SWAP.W	D4	SUB.W	D4,#ICOLY/2	; D4 <-- la souris montre le milieu	LOAD.W	D3,#340-ICOLY	; D3 <-- minimum (340 = hauteur wdo SM100)	COMP.W	D4,D3		; trop haut ?	JUMP',GE 20$	LOAD.W	D4,D320$:	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,#ICOLY	; D3 <-- maximum	COMP.W	D4,D3		; trop bas ?	JUMP',LE 22$	LOAD.W	D4,D322$:	AND.B	D4,#B'11111110	; D4 <-- doit tre pair	COMP.W	D4,(A6)+ODICO+0	; nouvelle position ?	JUMP',EQ 40$		; non => 40$				; oui =>	JUMP',HI 30$	PUSH.W	D4	LOAD.W	D3,D4	ADD.W	D3,#ICOLY	SUB.W	D4,(A6)+ODICO+0	NEG.W	D4	CALL	CLRICONE	; efface la partie dcouverte en bas	POP.W	D4	JUMP'	35$30$:	PUSH.W	D4	LOAD.W	D3,(A6)+ODICO+0	SUB.W	D4,(A6)+ODICO+0	CALL	CLRICONE	; efface la partie dcouverte en haut	POP.W	D435$:	LOAD.W	(A6)+ODICO+0,D4	CALL	REQICONE	; remet rapidement les icnes	INC.W	D2		; D2 <-- un dplacement de plus40$:	CALL	WAITMOVE	; attend dplacement souris ...	JUMP',NE 50$		; fin du dplacement => 50$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 40$	JUMP	10$50$:	TEST.W	D2		; y a-t-il eu des dplacements	JUMP',EQ 80$		; non => 80$	CALL	MAJICONE	; mj. les icnes variables80$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MEMICONE >;=========/; Mmorise toutes les icnes dessines  gauche.; in	-; out	D7.W	erreur; mod	D7.WMEMICONE:	PUSHM.L	D1..D6,A3,A4	CLR.W	D7	TEST.L	(A6)+OPICO	; icnes dj mmorises ?	JUMP',NE EXIT$		; oui => EXIT$	CLR.W	D4	LOAD.B	D4,(A0)+ODFCNP	; D4 <-- nb de bits/pixel	MUL.WU	D4,#ICOLY*(ICOLX/8)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour icnes	JUMP',NE EXIT$	LOAD.L	(A6)+OPICO,A4	LOAD.L	A3,#0		; A3 <-- ^source (dans l'cran)	LOAD.L	D3,(A6)+ODICO	SUB.W	D3,#GCIMX+6	SWAP.W	D3	SUB.W	D3,#GCIMY+5	SWAP.W	D3;	LOAD.L	A4,A4		; A4 <-- ^destination	CLR.L	D4	LOAD.W	D6,#ICOLX/8	LOAD.L	D2,#H'10000*ICOLY+ICOLX	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; LIBICONE >;=========/; Libre les icnes.; in	-; out	-; mod	D7.WLIBICONE:	PUSHM.L	D1,A4	TEST.L	(A6)+OPICO	; icnes mmorises ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A4,(A6)+OPICO	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OPICOEXIT$:	POPM.L	D1,A4	RET;---------\\; REMICONE >;=========/; Remet toutes les icnes dessines  gauche.; in	-; out	-; mod	D7.WREMICONE:	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC EXIT$		; non => EXIT$	CALL	REQICONE	; remet toutes les icnes	CALL	MAJICONE	; mj. les icnes variablesEXIT$:	RET;---------\\; REQICONE >;=========/; Remet toutes les icnes dessines  gauche, rapidement,; c'est--dire sans mettre  jour les icnes.; in	-; out	-; mod	D7.WREQICONE:	PUSHM.L	D1..D6,A3,A4	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP,BC EXIT$		; non => EXIT$	TEST.L	(A6)+OPICO	; icnes mmorises ?	JUMP,EQ 60$		; non => 60$	CALL	CCMO		; enlve la souris	LOAD.L	A3,(A6)+OPICO	; A3 <-- ^source	CLR.L	D3	LOAD.W	D5,#ICOLX/8	LOAD.L	A4,#0		; A4 <-- ^destination (dans cran)	LOAD.L	D4,(A6)+ODICO	SUB.W	D4,#GCIMX+6	SWAP.W	D4	SUB.W	D4,#GCIMY+5	SWAP.W	D4	LOAD.L	D2,#H'10000*ICOLY+ICOLX	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	CALL	SCMO		; remet la souris	LOAD.L	A4,#(A6)+OTICO	LOAD.W	D4,#(256/8/4)-140$:	CLR.L	(A4+)		; OTICO <-- plus d'icnes grises	DECJ.W,NMO D4,40$	JUMP'	EXIT$60$:	CALL	DESICONE	; dessine normalementEXIT$:	POPM.L	D1..D6,A3,A4	RET;----------\\; MENUICONE >;==========/; Propose le menu des icnes de gauche ...; in	-; out	D3.B	icne clique;	D7.W	erreur; mod	D3.L, D7.WMENUICONE:	PUSHM.L	D1,D2,D4..D6,A3,A4	LOAD.W	D7,#1	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP,BS EXIT$		; oui => EXIT$	TEST.B	(A6)+OXICO	; icnes spciales ?	JUMP,NE 40$		; oui => 40$				; non =>	TEST.L	(A6)+OPICO	JUMP,EQ 40$	CALL	OPEMICONE	; ouvre la sous-fentre	JUMP,NE EXIT$	CALL	CCMO		; enlve la souris	PUSHM.L	D5,D6	LOAD.L	A3,(A6)+OPICO	; A3 <-- ^source	CLR.L	D3	LOAD.W	D5,#ICOLX/8	LOAD.L	A4,#0		; A4 <-- ^destination (dans l'cran)	CLR.L	D4	LOAD.L	D2,#H'10000*ICOLY+ICOLX	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	POPM.L	D5,D6	CLR.L	D3	LOAD.L	D4,#H'10000*(ICOLY-1)+(ICOLX-1)	LOAD.W	D2,#SETDOT	LIB	?DRRECT	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; dessine un joli cadre autour	LOAD.L	A4,#(A6)+OTICO	LOAD.W	D4,#(256/8/4)-120$:	CLR.L	(A4+)		; OTICO <-- plus d'icnes grises	DECJ.W,NMO D4,20$	PUSH.L	(A6)+ODICO	LOAD.L	(A6)+ODICO,#H'10000*8+12	TSET.B	(A6)+ODEF+3:#BDEFICO	CALL	MAJICONE	; mj. les icnes variables	CALL	FULLGREYICONE	; (d)grise qq icnes	CALL	SCMO		; remet la souris	CALL	MOVMICONE	; choisit une icne ...	TCLR.B	(A6)+ODEF+3:#BDEFICO	POP.L	(A6)+ODICO	CALL	CLOMICONE	; ferme la sous-fentre	CLR.W	D7		; D7 <-- ok	JUMP	EXIT$40$:	CALL	OPEMICONE	; ouvre la sous-fentre	JUMP,NE EXIT$	PUSH.L	(A6)+ODICO	LOAD.L	(A6)+ODICO,#H'10000*8+12	TSET.B	(A6)+ODEF+3:#BDEFICO	CALL	DESICONE	; dessine les icnes	CALL	MAJICONE	; mj. les icnes variables	CALL	FULLGREYICONE	; (d)grise qq icnes	CLR.L	D3	LOAD.L	D4,#H'10000*(ICOLY-1)+(ICOLX-1)	LOAD.W	D2,#SETDOT	LIB	?DRRECT	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; dessine un joli cadre autour	CALL	SCMO		; remet la souris	CALL	MOVMICONE	; choisit une icne ...	TCLR.B	(A6)+ODEF+3:#BDEFICO	POP.L	(A6)+ODICO	CALL	CLOMICONE	; ferme la sous-fentre	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2,D4..D6,A3,A4	RET;----------\\; OPEMICONE >;----------/; Ouvre la sous-fentre pour dessiner le menu des icnes.; in	-; out	D5.W	no swdo pour menu;	D6.W	no swdo initiale;	D7.W	erreur; mod	D6.L, D7.WOPEMICONE:	PUSHM.L	D3,D4	LIB	?GETWDO	LOAD.W	D6,D5		; D6 <-- no swdo actuelle	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE EXIT$	CLR.B	D3	CALL	SELMO		; remet la flche	LOAD.L	D3,D4		; D3 <-- position de la souris	ADD.W	D3,#8		; D3 <-- souris toujours  gauche des icnes	LOAD.W	D4,(A0)+ODFDX	SUB.W	D4,#ICOLX	COMP.W	D3,D4		; trop  gauche ?	JUMP',LS 20$	LOAD.W	D3,D420$:	SWAP.W	D3	SUB.W	D3,#ICOLY/2	; D3 <-- souris toujours au milieu des icnes	JUMP',NC 22$	CLR.W	D322$:	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,#ICOLY	COMP.W	D3,D4		; trop en bas ?	JUMP',LS 24$	LOAD.W	D3,D424$:	SWAP.W	D3	LOAD.L	D4,#H'10000*ICOLY+ICOLX	LIB	?CREWDO	LIB	?USEWDO	LIB	?AFTIM	.B	SAVWDO		; sauve le contenu	.B	EOP		; puis efface tout	.B	0	.EVEN	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; CLOMICONE >;----------/; Ferme la sous-fentre pour dessiner le menu des icnes.; in	D5.W	no swdo pour menu;	D6.W	no swdo initiale; out	-; mod	D7.WCLOMICONE:	PUSHM.L	D5,D6	LIB	?AFTIM	.B	GETWDO		; restitue le contenu	.B	0	.EVEN	EX.L	D5,D6	LIB	?USEWDO		; utilise la swdo initiale	EX.L	D5,D6	LIB	?KILWDO		; dtruit la swdo du menu	POPM.L	D5,D6	RET;----------\\; MOVMICONE >;----------/; Choisit une icne avec la souris.; in	-; out	D3.B	icne clique; mod	D3.L, D7.WMOVMICONE:	PUSHM.L	D2,D4	CLR.B	D220$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 50$		; non => 50$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 20$	CALL	DETICONE	; D3 <-- icne o est la souris	JUMP,NE 20$	COMP.B	D3,D2	JUMP,EQ 20$	EX.L	D3,D2	CALL	INVALLICONE	; teint l'ancienne icne	LOAD.B	D3,D2	CALL	INVALLICONE	; allume la nouvelle icne	JUMP	20$50$:	LOAD.B	D3,D2	CALL	INVALLICONE	; teint l'ancienne icne	CALL	XXXONETEST	; icne grise ?	JUMP',BC EXIT$		; non => EXIT$	CLR.B	D3EXIT$:	POPM.L	D2,D4	RET;---------\\; DESICONE >;=========/; Dessine une liste d'icnes en colonne.; in	-; out	-; mod	D7.WDESICONE:	PUSHM.L	D0..D4,A3	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP,BC EXIT$		; non => EXIT$	TEST.B	(A6)+OXICO	; icnes spciales ?	JUMP',EQ 20$		; non => 20$				; oui =>	LOAD.W	D3,(A6)+ODICO+0	LOAD.W	D4,#ICOLY	CALL	CLRICONE	; efface toutes les icnes20$:	LOAD.W	D0,#OPICODES	; D0 <-- dessine	LIB	?BUCAR	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE	LIB	?NOBUCAREXIT$:	POPM.L	D0..D4,A3	RET;---------\\; CLRICONE >;---------/; Efface toutes les icnes de gauche.; in	D3.W	origine (y);	D4.W	hauteur (dy); out	-; mod	D7.WCLRICONE:	PUSHM.L	D2..D4	LOAD.L	D2,D3	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORFOND	LIB	?COLORCR	; donne la couleur relative pour effacer	LOAD.L	D3,D2	LOAD.W	D2,D4	CALL	DESMDEF		; D4 <-- trame grise pour le fond	CALL	DRMDEF	LOAD.W	D4,D2	SUB.W	D3,#GCIMY+5	SWAP.W	D3	LOAD.W	D3,(A6)+ODICO+2	SUB.W	D3,#GCIMX+6	SWAP.W	D4	LOAD.W	D4,#ICOLX	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; grise toutes les icnes	LIB	?COLORPOP	POPM.L	D2..D4	RET;---------\\; MOVICONE >;=========/; Dplace une icne tant que le bouton est press.; in	D4.L	position de la souris (y;x); out	D3.B	icne o est la souris;	D7.W	ok/erreur; mod	D3.L, D7.WMOVICONE:	PUSHM.L	D4,D5	CALL	DETICONE	; souris dans une icne ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.B	D5,D3	JUMP'	30$20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 50$		; non => 50$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 20$	CALL	DETICONE	; D3 <-- icne o est la souris	JUMP,NE 20$	COMP.B	D3,D5	JUMP,EQ 20$	EX.L	D3,D5	CALL	INVALLICONE	; teint l'ancienne icne30$:	LOAD.B	D3,D5	CALL	INVALLICONE	; allume la nouvelle icne	JUMP	20$50$:	LOAD.B	D3,D5	CALL	INVALLICONE	; teint l'ancienne icne	CALL	XXXONETEST	; icne grise ?	JUMP',BC 80$		; non => 80$	CLR.B	D380$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DETICONE >;=========/; Dtecte dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D3.B	icne o est la souris;	D7.W	ok/erreur; mod	D3.L, D7.WDETICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D7,#1	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC EXIT$		; non => EXIT$	LOAD.W	D0,#OPICODET	; D0 <-- dtecte	LOAD.L	D5,D4		; D5 <-- position de la souris (y;x)	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE	JUMP',NE EXIT$50$:	LOAD.B	D3,D5		; D3 <-- code de l'icneEXIT$:	POPM.L	D0,D5,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; INVICONE >;=========/; Inverse une icne.; in	D3.B	icne  inverser; out	-; mod	D7.WINVICONE:	PUSHM.L	D0,D5,A3	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC EXIT$		; non => EXIT$	LOAD.W	D0,#OPICOINV	; D0 <-- inverse	LOAD.B	D5,D3		; D5 <-- code de l'icne	JUMP',EQ EXIT$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONEEXIT$:	POPM.L	D0,D5,A3	RET;------------\\; INVALLICONE >;============/; Inverse toute une icne.; in	D3.B	icne  inverser; out	-; mod	D7.WINVALLICONE:	PUSHM.L	D0,D5,A3	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC EXIT$		; non => EXIT$	LOAD.W	D0,#OPICOINVALL	; D0 <-- inverse	LOAD.B	D5,D3		; D5 <-- code de l'icne	JUMP',EQ EXIT$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONEEXIT$:	POPM.L	D0,D5,A3	RET;---------\\; POSICONE >;=========/; Donne la position d'une icne.; in	D3.B	icne; out	D4.L	position coin sup/gauche (y;x);	D7.W	erreur; mod	D7.WPOSICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D7,#1	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC EXIT$		; non => EXIT$	LOAD.W	D0,#OPICOPOS	; D0 <-- position	LOAD.B	D5,D3		; D5 <-- code de l'icne	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE	JUMP',NE EXIT$50$:	LOAD.L	D4,D5		; D4 <-- positionEXIT$:	POPM.L	D0,D5,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; GREYICONE >;==========/; Grise ou dgrise une icne.; in	D3.B	icne  (d)griser;	D7.W	EQ => dgrise;		NE => grise; out	-; mod	-GREYICONE:	PUSHM.L	D0,D5,D7,A3	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC EXIT$		; non => EXIT$	LOAD.B	D5,D3		; D5 <-- code de l'icne	JUMP',EQ EXIT$		; nil => ne fait rien	TEST.W	D7	JUMP',NE 20$	CALL	XXXONETEST	; est-ce dj plein ?	JUMP',BC EXIT$		; oui => EXIT$	LOAD.W	D0,#OPICOFULL	; D0 <-- dgrise	JUMP'	30$20$:	CALL	XXXONETEST	; est-ce dj gris ?	JUMP',BS EXIT$		; oui => EXIT$	LOAD.W	D0,#OPICOGREY	; D0 <-- grise30$:	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONEEXIT$:	POPM.L	D0,D5,D7,A3	RET;---------\\; PTGICONE >;---------/; Donne le pointeur aux icnes de gauche.; in	-; out	A3.L	^icnes de gauche; mod	A3.LPTGICONE:	LOAD.L	A3,#R16"TICOSPLINE1	COMP.B	(A6)+OXICO,#NIVSPLINE1	JUMP,EQ EXIT$	LOAD.L	A3,#R16"TICOSPLINE2	COMP.B	(A6)+OXICO,#NIVSPLINE2	JUMP,EQ EXIT$	COMP.B	(A6)+OXICO,#NIVDEFORME	JUMP',NE 30$	LOAD.L	A3,#R16"TICOZOOM	COMP.B	(A6)+OYICO,#ICOZOOM	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICOTOURNE	COMP.B	(A6)+OYICO,#ICOTOURNE	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICOMIROIR	COMP.B	(A6)+OYICO,#ICOMIROIR	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICODEFORME	JUMP'	EXIT$30$:	LOAD.L	A3,#R16"TICOTEXTE	COMP.B	(A6)+OXICO,#NIVTEXTE	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICORELIEF	COMP.B	(A6)+OXICO,#NIVRELIEF	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICOTRAME	COMP.B	(A6)+OXICO,#NIVTRAME	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICOLISSE	COMP.B	(A6)+OXICO,#NIVLISSE	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICOGAUCHEEXIT$:	RET;---------\\; XXXICONE >;---------/; Dessine une liste d'icnes en colonne.; in	A3.L	^liste;	D0.W	opration (OPICOxxx);	D5.L	position de la souris (si dtecte);	D5.B	code de l'icne (si inverse/position); out	D5.B	icne o est la souris (si dtecte);	D5.L	coordonne (si position);	D7.W	ok/erreur (si dtecte ou inverse); mod	D5.L, D7.WXXXICONE:	PUSHM.L	D1..D4,A3	LOAD.L	D4,(A6)+ODICO	LOAD.L	D3,D4	CLR.W	D2		; D2 <-- gencar du texte20$:	COMP.B	(A3),#IF	; fin de la table ?	JUMP,EQ 80$	COMP.B	(A3),#IL	; va  la ligne suivante ?	JUMP',EQ 40$	COMP.B	(A3),#IC	; va  la ligne suivante ?	JUMP',EQ 45$	COMP.W	D0,#OPICODET	JUMP',EQ 30$	COMP.W	D0,#OPICOINV	JUMP',EQ 35$	COMP.W	D0,#OPICOINVALL	JUMP',EQ 35$	COMP.W	D0,#OPICOPOS	JUMP',EQ 35$	COMP.W	D0,#OPICOGREY	JUMP',EQ 35$				; dessine/dgrise =>	LOAD.B	D1,#GCICT	TEST.B	(A3)+1	JUMP',NC 22$	INC.B	D122$:	COMP.B	D2,D1		; utilise toujours le mme gencar ?	JUMP',EQ 24$		; oui => 24$	LOAD.B	D2,D1	COMP.B	D2,#GCICT+1	JUMP',EQ 23$	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP'	24$23$:	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT+1	.B	0	.EVEN24$:	CALL	XXXONEICONE	; dessine une icne25$:	ADD.L	A3,#3	JUMP	20$30$:				; dtecte =>	CALL	XXXONEICONE	; dtecte si dans cette icne ?	JUMP,NE 25$		; non => 25$	LOAD.B	D5,(A3)+1	; D5 <-- code de l'icne	JUMP'	80$35$:				; inverse/position =>	CALL	XXXONEICONE	; inverse cette icne ?	JUMP,NE 25$		; non => 25$	JUMP'	80$40$:				; grand interligne =>	SWAP.W	D3	ADD.W	D3,#GCICY+GCIMY*2	SWAP.W	D3	LOAD.L	D4,D3	INC.L	A3	JUMP	20$45$:				; petit interligne =>	SWAP.W	D3	ADD.W	D3,#5		; aligne en bas sur Smaky 100 !	SWAP.W	D3	LOAD.L	D4,D3	INC.L	A3	JUMP	20$80$:	COMP.W	D0,#OPICODES	; dessine ?	JUMP',EQ 85$		; oui => 85$	COMP.W	D0,#OPICOFULL	; dgrise ?	JUMP',NE EXIT$		; non => EXIT$85$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVENEXIT$:	POPM.L	D1..D4,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; XXXONEICONE >;------------/; Dessine/dtecte/inverse une icne.; in	A3.L	^lment dans table;	D4.L	coordonne coin sup/gauche;	D0.W	opration (OPICOxxx);	D5.L	position de la souris (si dtecte);	D5.B	code de l'icne (si inverse/position/grise/dgrise); out	D4.L	coordonne suivante;	D5.L	coordonne coin (si position);	D7.W	ok/erreur (si dtecte ou inverse); mod	D4.L, D5.L, D7.WXXXONEICONE:	PUSHM.L	D1..D3	LOAD.L	D1,D4		; D1 <-- coin	LOAD.L	D3,D4	SUB.W	D3,#GCIMX	SWAP.W	D3	SUB.W	D3,#GCIMY	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SWAP.W	D4	LOAD.W	D4,#GCICX/2+GCIMX*2	COMP.B	(A3)+0,#ID	JUMP',NE 20$	ADD.W	D4,#GCICX/2+GCIMX*220$:	COMP.W	D0,#OPICODET	JUMP,EQ 40$	COMP.W	D0,#OPICOINV	JUMP,EQ 50$	COMP.W	D0,#OPICOINVALL	JUMP,EQ 50$	COMP.W	D0,#OPICOPOS	JUMP,EQ 60$	COMP.W	D0,#OPICOGREY	JUMP,EQ 70$	COMP.W	D0,#OPICOFULL	JUMP,EQ 75$22$:				; dessine =>	COMP.B	(A3)+1,#ICOVIDE	JUMP,EQ 80$	LIB	?COLORPUSH	; sauve les couleurs	PUSH.L	D3	LOAD.L	D3,#COLORBASE	LOAD.B	D3,(A3)+2	AND.B	D3,#H'0F	; D3 <-- couleur	JUMP',EQ 24$	LIB	?COLORCR	; donne la couleur relative pour effacer24$:	POP.L	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	PUSH.L	D4	CLR.L	D4	CALL	DRMDEF	POP.L	D4	PUSHM.L	D3,D4	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour icne	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	LOAD.L	D3,D1		; D3 <-- coin	SUB.W	D3,#2	COMP.B	(A3)+0,#ID	JUMP',NE 30$	ADD.W	D3,#2+GCIMX30$:	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,(A3)+1	; D3 <-- code	AND.B	D3,#H'7F	LIB	?AFCODE	POPM.L	D3,D4	CALL	DESACTION	; dessine ventuellement une action	LOAD.B	D3,(A3)+1	; D3 <-- code de l'icne	CALL	XXXONEFULL	; signal icne pleine	LIB	?COLORPOP	; remet les couleurs	JUMP	80$40$:				; dtecte =>	LOAD.W	D7,#ERDIOUT	LOAD.W	D2,D5	SUB.W	D2,D3		; souris trop  gauche ?	JUMP,LO 80$	COMP.W	D2,D4		; souris trop  droite ?	JUMP,HS 80$	SET.B	(A6)+OGICO	; on est  gauche	SR.W	D4,#1	COMP.W	D2,D4	JUMP',LO 42$	CLR.B	(A6)+OGICO	; on est  droite42$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	D2,D5	SWAP.W	D2	SUB.W	D2,D3		; souris trop en haut ?	JUMP,LO 80$	COMP.W	D2,D4		; souris trop en bas ?	JUMP,HS 80$	CLR.B	(A6)+OBICO	; on est en haut	SR.W	D4,#1	COMP.W	D2,D4	JUMP',LO 44$	SET.B	(A6)+OBICO	; on est en bas44$:	CLR.W	D7		; D7 <-- dans l'icone	JUMP	80$50$:				; inverse =>	LOAD.W	D7,#ERDIOUT	COMP.B	D5,(A3)+1	JUMP,NE 80$	LIB	?COLORPUSH	; sauve les couleurs	PUSH.L	D3	LOAD.L	D3,#COLORBASE	LOAD.B	D3,(A3)+2	AND.B	D3,#H'0F	; D3 <-- couleur	JUMP',EQ 51$	LIB	?COLORCR	; donne la couleur relative pour effacer51$:	POP.L	D3	PUSHM.L	D3,D4	LOAD.L	D4,#-1	LOAD.B	D3,(A3)+1	; D3 <-- code de l'icne	CALL	XXXONETEST	; icne grise ?	JUMP',BC 52$		; non => 52$;	LOAD.L	D4,#H'55AA55AA	; D4 <-- trame si gris	LOAD.L	D4,#H'00550055	; D4 <-- trame pour inverser52$:	CALL	DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#1	COMP.W	D0,#OPICOINVALL	JUMP',EQ 53$	INC.W	D253$:	ADD.W	D3,D2	SWAP.W	D3	ADD.W	D3,D2	SWAP.W	D3	SUB.W	D4,D2	SUB.W	D4,D2	SWAP.W	D4	SUB.W	D4,D2	SUB.W	D4,D2	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	LIB	?COLORPOP	; remet les couleurs	CLR.W	D7	JUMP	80$60$:				; position =>	LOAD.W	D7,#ERDIOUT	COMP.B	D5,(A3)+1	JUMP,NE 80$	LOAD.L	D5,D3		; D5 <-- position	CLR.W	D7	JUMP	80$70$:				; grise =>	LOAD.W	D7,#ERDIOUT	COMP.B	D5,(A3)+1	JUMP,NE 80$	PUSH.L	D4	LOAD.L	D4,#H'55AA55AA	CALL	DRMDEF	POP.L	D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; grise toute l'icne	LOAD.B	D3,(A3)+1	; D3 <-- code de l'icne	CALL	XXXONEGREY	; signal icne grise	CLR.W	D7	JUMP	80$75$:				; dgrise =>	LOAD.W	D7,#ERDIOUT	COMP.B	D5,(A3)+1	JUMP,EQ 22$;	JUMP	80$80$:	LOAD.L	D4,D1	ADD.W	D4,#GCICX/2+GCIMX*2	COMP.B	(A3)+0,#ID	JUMP',NE EXIT$	ADD.W	D4,#GCICX/2+GCIMX*2EXIT$:	POPM.L	D1..D3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; XXXONETEST >;-----------/; Regarde si une icne est pleine ou grise.; in	D3.B	code de l'icne; out	BC	plein;	BS	gris; mod	D7.WXXXONETEST:	PUSHM.L	D4,A4	CLR.W	D4	LOAD.B	D4,D3	LOAD.L	A4,#(A6)+OTICO	SR.W	D4,#3	TEST.B	(A4)+(D4.W):D3	POPM.L	D4,A4	RET;-----------\\; XXXONEFULL >;-----------/; Indique qu'une icne est pleine (non grise).; in	D3.B	code de l'icne; out	-; mod	D7.WXXXONEFULL:	PUSHM.L	D4,A4	CLR.W	D4	LOAD.B	D4,D3	LOAD.L	A4,#(A6)+OTICO	SR.W	D4,#3	TCLR.B	(A4)+(D4.W):D3	POPM.L	D4,A4	RET;-----------\\; XXXONEGREY >;-----------/; Indique qu'une icne est grise.; in	D3.B	code de l'icne; out	-; mod	D7.WXXXONEGREY:	PUSHM.L	D4,A4	CLR.W	D4	LOAD.B	D4,D3	LOAD.L	A4,#(A6)+OTICO	SR.W	D4,#3	TSET.B	(A4)+(D4.W):D3	POPM.L	D4,A4	RET;----------\\; DESACTION >;----------/; Dessine ventuellement une action.; in	A3.L	^ID/IS et code;	D3.L	origine rectangle;	D4.L	dimensions rectangle; out	-; mod	D7.WDESACTION:	PUSHM.L	D2..D4,A3,A4	LOAD.B	D2,(A3)+2	AND.B	D2,#H'F0	; D2 <-- type de l'icne	JUMP,EQ EXIT$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	A4,#R16"DIAL$	COMP.B	D2,#TDIAL	JUMP',EQ 20$	LOAD.L	A4,#R16"DOWN$	COMP.B	D2,#TDOWN	JUMP',EQ 20$	LOAD.L	A4,#R16"EFFET$;	COMP.B	D2,#TEFFET;	JUMP',EQ 20$20$:	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	ADD.W	D3,D4	SUB.W	D3,#8	LOAD.W	(A3)+1,D3	; <xx>	SWAP.W	D3	LOAD.W	(A3)+3,D3	; <yy>	LOAD.L	(A3)+5,A4	; <pppp>	LOAD.B	(A3)+9,#INVDOT	; <m>	LOAD.W	D3,#10	LIB	?STRING		; dessine le motifEXIT$:	POPM.L	D2..D4,A3,A4	RETDIAL$:	.B	8,24	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00110110	.B	B'00110110	.B	B'00000000DOWN$:	.B	8,24	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00001000	.B	B'00001000	.B	B'00111110	.B	B'00011100	.B	B'00001000	.B	B'00000000EFFET$:	.B	8,24	.B	B'00111111	.B	B'00011111	.B	B'00011111	.B	B'00001111	.B	B'00001111	.B	B'00000111	.B	B'00000111	.B	B'00000011	.B	B'00000011	.B	B'00000001	.B	B'00000001	.B	B'00000000	.B	B'00000000	.B	B'00000001	.B	B'00000001	.B	B'00000011	.B	B'00000011	.B	B'00000111	.B	B'00000111	.B	B'00001111	.B	B'00001111	.B	B'00011111	.B	B'00011111	.B	B'00111111	.EVEN;---------\\; DRRASTER >;=========/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D1.L	hauteur/largeur (y;x);	D2.W	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT); out	-; mod	D7.WDRRASTER:	PUSHM.L	D0,D5,D6,A1,A2	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	CLR.W	D0	LOAD.B	D0,(A0)+ODFCNP	; D0 <-- nb de bits/pixel (1,4)	COMP.W	D0,#1	JUMP',NE COUL$	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; appel de GRA_RASTER	JUMP'	EXIT$COUL$:	TEST.L	D1:#BSRCCOUL	JUMP',BC CSRC$	MUL.WU	D5,D0		; D5 <-- Iy sourceCSRC$:	TEST.L	D1:#BDSTCOUL	JUMP',BC CDST$	MUL.WU	D6,D0		; D6 <-- Iy destinationCDST$:	LOAD.L	A1,(A6)+OCRASTER	CALL	(A1)		; appel de GRA_CRASTEREXIT$:	POPM.L	D0,D5,D6,A1,A2	RET	.END