	.SBTTL	DESDBOX;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut;	D2.W	mode; out	D2.W	mode;	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXEDITO:	PUSHM.L	D1,D4,D5,A2..A5	TEST.B	(A3)		; nom du fichier existe ?	JUMP',EQ 10$		; non => 10$				; oui =>	CLR.W	D7		; D7 <-- ok	LOAD.W	D3,#F1		; D3 <-- comme si (SAUVE)	TEST.L	D2:#BDBAUTO	; mode automatique ?	JUMP,BS	EXIT$		; oui => EXIT$10$:	CALL	DBOXOPEN1	LOAD.W	D4,D2		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_SAUVE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	TSET.L	D2:#BDBEXTEND	; D2 <-- sous-appel d'extension	TSET.L	D2:#BDBSAV	; D2 <-- sauve le fond	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXT1	TEST.L	D2:#BDBNMAJ	JUMP',BC 30$	TSET.L	D3:#BDBIONMAJ	; D3 <-- touche (MET A JOUR) grise30$:	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITE >;==========/; Edite un nom de fichier en sortie (extraction).; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXEDITE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_SAUVE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_EXTRAIT; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre (prend).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITA >;==========/; Edite un nom de fichier en entre (ajoute).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITA:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEDITTX >;===========/; Edite un nom de texte en entre.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITTX:	PUSHM.L	D1,D2,D5,A2..A5	LOAD.B	D3,#ICOTPREND	CALL	INVALLICONE	; allume l'icne	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOTX	LOAD.L	A4,#R16"TEXTX	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOFULL	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSHM.L	D3,D7	CALL	DBOXCLOSE1	LOAD.B	D3,#ICOTPREND	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7EXIT$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXSAVE >;=========/; Sauve le dessin selon le choix de l'utilisateur.; in	D0.W	mode (0=quitte, 1=nouveau texte); out	D7.W	0	=> ok, on peut quitter;		1	=> (ANNULE), donc on reste;		autre	=> erreur grve; mod	D7.WDBOXSAVE:	PUSHM.L	D1..D5,A2..A5	TEST.B	(A6)+OMAJ	; mise  jour ncessaire ?	JUMP,F	80$		; non => 80$ (quitte, snif)				; oui =>	CALL	IFVIDE		; dessin vide ?	JUMP',NE 10$		; non => 10$				; oui =>	CLR.B	(A6)+OMAJ	; fait comme si dessin  jour	JUMP	80$10$:	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	LOAD.W	D3,(A6)+ONOZO	INC.B	D3		; D3 <-- numro de la page  afficher	COMP.B	D3,#NBZONE	JUMP',NE 20$	CLR.B	D320$:	TEST.B	D0	JUMP',NE 25$	TSET.L	D3:#BDBIOQUIT	; D3 <-- texte "avant de quitter"25$:	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_SAUVE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_MAJ	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	TSET.L	D3:#BDBIOOBJ	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 85$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$	OR.W	D2,D4		; D2 <-- met aussi les fanions (pour BDBDEF)	CALL	SAUVETOUT	; sauve tout sur disque (in D2.W !)	JUMP'	EXIT$80$:	CLR.W	D7		; D7 <-- quitte	JUMP'	EXIT$85$:	LOAD.W	D7,#1		; D7 <-- resteEXIT$:	POPM.L	D1..D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande si l'on veut quitter DESSIN.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXQUITTE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer le dessin.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXEFFACE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	LOAD.W	D3,(A6)+ONOZO	INC.B	D3		; D3 <-- numro de la page  afficher	COMP.B	D3,#NBZONE	JUMP',NE 20$	CLR.B	D320$:	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXTDEF >;=========/; Dfini une trame 8x8 quelconque.; in	-; out	D7.W	erreur; mod	D7.WDBOXTDEF:	PUSHM.L	D2..D4,A2..A4	LOAD.B	D3,#ICOTDEF	CALL	INVALLICONE	; allume l'icne	CALL	ERGMOUSE	; efface les flches dans les rgles	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.L	D2,#2^BDBSAV	LOAD.W	D4,(A6)+ONTDEF	LOAD.L	A4,#(A6)+OTDEF	LOAD.L	A3,#R16"00$	CALL	DBOXPOS3	; D3 <-- centre de la dbox	DESSIN_	TEDIT		; dite les trames ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	LOAD.W	(A6)+ONTDEF,D4EXIT$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	LOAD.B	D3,#ICOTDEF	CALL	INVALLICONE	; teint l'icne	POP.W	D7	POPM.L	D2..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0,0,0	.EVEN;----------\\; DBOXTTDEF >;==========/; Dfini une trame 8x8 quelconque.; in	-; out	D7.W	erreur; mod	D7.WDBOXTTDEF:	PUSHM.L	D1..D4,A2..A4	LOAD.B	D1,#ICOTRAM1	LOAD.L	A4,#(A6)+OTRAT1	TEST.W	(A6)+OTRAFA	JUMP',EQ 10$	LOAD.B	D1,#ICOTRAM2	LOAD.L	A4,#(A6)+OTRAT2	COMP.W	(A6)+OTRAFA,#1	JUMP',EQ 10$	LOAD.B	D1,#ICOTRAM3	LOAD.L	A4,#(A6)+OTRAT310$:	LOAD.B	D3,D1	CALL	INVALLICONE	; allume l'icne	CALL	DBTTSWAP	; tourne toutes les trames !	CALL	ERGMOUSE	; efface les flches dans les rgles	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.L	D2,#2^BDBSAV	LOAD.W	D4,#16;	LOAD.L	A4,#(A6)+OTRATn	LOAD.L	A3,#R16"00$	CALL	DBOXPOS3	; D3 <-- centre de la dbox	DESSIN_	TEDIT		; dite les trames ...	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	LOAD.B	D3,D1	CALL	INVALLICONE	; teint l'icne	POP.W	D7	CALL	DBTTSWAP	; tourne toutes les trames !	POPM.L	D1..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0,0,0	.EVEN;---------\\; DBTTSWAP >;---------/; Tourne toutes les trames.; in	A4.L	^trames; out	-; mod	D7.WDBTTSWAP:	PUSHM.L	D1..D4,A4	LOAD.W	D4,#(8*MAXDEF)-110$:	LOAD.B	D3,(A4)	LOAD.W	D1,#8-120$:	RRX.B	D3,#1	RLX.B	D2,#1	DECJ.W,NMO D1,20$	LOAD.B	(A4+),D2	DECJ.W,NMO D4,10$	POPM.L	D1..D4,A4	RET;---------\\; DBOXPDEF >;=========/; Dfini un pinceau 8x8 quelconque.; in	-; out	D7.W	erreur; mod	D7.WDBOXPDEF:	PUSHM.L	D2..D4,A2..A4	LOAD.B	D3,#ICOPDEF	CALL	INVALLICONE	; allume l'icne	CALL	ERGMOUSE	; efface les flches dans les rgles	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.L	D2,#2^BDBSAV	LOAD.W	D4,(A6)+ONPDEF	LOAD.L	A4,#(A6)+OPDEF	LOAD.L	A3,#R16"00$	CALL	DBOXPOS3	; D3 <-- centre de la dbox	DESSIN_	DEDIT		; dite les pinceaux ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	LOAD.W	(A6)+ONPDEF,D4EXIT$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	LOAD.B	D3,#ICOPDEF	CALL	INVALLICONE	; teint l'icne	POP.W	D7	POPM.L	D2..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0,0,0	.EVEN;--------\\; DBOXDEF >;========/; Change les dfinitions gnrales.; in	-; out	D7.W	erreur; mod	D7.WDBOXDEF:	PUSHM.L	D0..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_DEFINE	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+ODEF	; D4 <-- fanions	TCLR.L	D4:#BDEFZOOM	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	D2,D4		; D2 <-- fanions	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE EXCOUL$	; oui => EXCOUL$	PUSH.L	D2	LOAD.W	D2,#F7!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#F9!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	POP.L	D2EXCOUL$:	LOAD.L	D4,(A6)+OMALMY	; D4 <-- dimensions (y;x)REFAIT$:	TEST.L	D2:#BDEFMM	; unit "millimtre" ?	JUMP',BC NOMM$		; non => NOMM$	LOAD.L	D1,D4	CALL	CONVPMX		; D4 <-- largeur [mm]	EX.L	D4,D1	SWAP.W	D4	CALL	CONVPMY		; D4 <-- hauteur [mm]	SWAP.W	D4	LOAD.W	D4,D1NOMM$:	LOAD.L	A3,#(A6)+OBUFOUT	LOAD.L	A4,A3	CALL	PUTANUM	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'x	; sparateur	LOAD.B	(A4+),#SPACE	SWAP.W	D4	CALL	PUTANUM	CLR.B	(A4)		; terminateurLOOP$:	LOAD.L	D0,D2		; D0 <-- anciens fanions	LOAD.L	D4,D2		; D4 <-- fanions	DBOX_	EDIT		; attend action ...	LOAD.L	D2,D4		; D2 <-- fanions	LOAD.L	A1,#R16"TKEY_DEFINE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#CR	JUMP,EQ DACCORD$	COMP.W	D3,#END	JUMP,EQ CANCEL$	COMP.W	D3,#FNCT	JUMP',EQ ECRAN$	COMP.W	D3,#DEFINE	JUMP',EQ PAGE$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP,EQ UNIT$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ECRAN$:				; ECRAN =>	LOAD.L	D4,(A6)+OGRDIY	JUMP	REFAIT$PAGE$:				; PAGE =>	CALL	WAITMOUSE	; souris: met le sablier	CALL	RDSTPRINT	; lit le status de l'imprimante ...	CALL	NORMMOUSE	; souris: remet la flche	CLR.L	D4	LOAD.W	D4,(A6)+OSTPRI+OPRHTP	SUB.W	D4,(A6)+OSTPRI+OPRMGS	SUB.W	D4,(A6)+OSTPRI+OPRMGI;;?	SUB.W	D4,(A6)+OSTPRI+OPRITL ; <<<<<<<<<< A SUPPRIMER, VOIR AVEC FK <<<<<<<<<<	DIV.WU	D4,(A6)+OFACY	SWAP.W	D4	CLR.L	D3	LOAD.W	D3,(A6)+OSTPRI+OPRLGP	DIV.WU	D3,(A6)+OFACX	LOAD.W	D4,D3	JUMP	REFAIT$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	LOOP$UNIT$:				; changement d'unit =>	LOAD.B	D1,D3	LOAD.L	D2,D0		; D2 <-- anciens fanions	PUSH.L	D1	CALL	DBDEFPUT	; D3/D4 <-- largeur/hauteur	POPM.L	D1	JUMP,NE BIP$	TCLR.L	D2:#BDEFMM	TCLR.L	D2:#BDEFPG	TSET.L	D2:D1		; D2 <-- allume le bon fanion	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- nouvelle dimensions (y;x)	JUMP	REFAIT$DACCORD$:			; D'ACCORD =>	LOAD.L	D0,(A6)+ODEF	XOR.L	D0,D2		; D0 <-- fanions modifis	TCLR.L	D2:#BDEFZOOM	LOAD.L	(A6)+ODEF,D2	CALL	DBDEFPUT	; D3/D4 <-- largeur/hauteur	JUMP,NE BIP$	CALL	DBOXCLOSE	; ferme la DBOX	TEST.W	D1		; dimensions modifies ?	JUMP',NE MODDIM$	; oui => MODDIM$	TEST.L	D0:#BDEFICO	JUMP,BS MODICO$	TEST.L	D0:#BDEFASC	JUMP,BS MODASC$	CLR.W	D7	JUMP	EXIT$MODDIM$:;	LOAD.W	D3,		; D3 <-- largeur de l'image;	LOAD.W	D4,		; D4 <-- hauteur de l'image	TEST.L	D0:#BDEFZOOM	JUMP',BC NOZOOM$	LOAD.B	(A6)+OMASTR,#2^BMASTR!2^BMAHOMNOZOOM$:	CALL	GETMEMMATRIX	; demande mmoire pour nouvelle image	CLR.B	(A6)+OMASTR	TEST.W	D7	JUMP,NE EXIT$	SET.B	(A6)+OMAJ	; une mise  jour sera ncessaire	LOAD.W	D4,#SCALE11	LOAD.W	(A6)+OSCALE,D4	CLR.L	(A6)+OPMOVY	CLR.L	(A6)+OPMDIY	TEST.L	D0:#BDEFICO	JUMP',BS MODICO$	TEST.L	D0:#BDEFASC	JUMP',BS MODASC$	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CLR.W	D7		; D7 <-- ok	JUMP	EXIT$MODICO$:			; montre/cache les icnes =>	CALL	CCMO		; enlve la souris	CALL	CALCADRE	CALL	DESWDO	LOAD.W	D4,(A6)+OSCALE	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$MODASC$:			; montre/cache les ascenseurs =>	CALL	CALCADRE	LOAD.W	D4,(A6)+OSCALE	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBDEFPUT >;---------/; Met  jour les valeurs.; in	D2.L	fanions;	A3.L	^ligne en dition; out	D3.W	largeur;	D4.W	hauteur;	D1.W	0 => valeurs pas modifies;	D7.W	erreur (syntaxe); mod	D1.L, D3.L, D4.L, D7.WDBDEFPUT:	PUSHM.L	D2,A4	CLR.W	D1	LOAD.L	A4,A3		; A4 <-- ^1er nombre	CALL	GETANUM		; D4 <-- largeur	TEST.L	D2:#BDEFMM	JUMP',BC 10$	CALL	CONVMPX		; D4 <-- largeur [pg]10$:	COMP.W	D4,#8	JUMP',HS 20$	LOAD.W	D4,#820$:	AND.B	D4,#B'11111000	; D4 <-- modulo 8 en X !	COMP.W	D4,(A6)+OMALMX	; idem ?	JUMP',EQ 30$		; oui => 30$	INC.W	D1		; non => signal30$:	LOAD.W	D7,#1		; D7 <-- erreur de syntaxe	LOAD.B	D3,(A4+)	; D3 <-- sparateur	JUMP',EQ EXIT$	COMP.B	D3,#CR	JUMP',EQ EXIT$	COMP.B	D3,#'0	JUMP,LO	30$	COMP.B	D3,#'9	JUMP,HI	30$	DEC.L	A4		; A4 <-- ^2me nombre	LOAD.W	D3,D4		; D3 <-- largeur	CALL	GETANUM		; D4 <-- hauteur	TEST.L	D2:#BDEFMM	JUMP',BC 50$	PUSH.W	D3	CALL	CONVMPY		; D4 <-- hauteur [pg]	POP.W	D350$:	COMP.W	D4,#8	JUMP',HS 60$	LOAD.W	D4,#860$:	AND.B	D4,#B'11111110	; D4 <-- modulo 2 en Y !	COMP.W	D4,(A6)+OMALMY	; idem ?	JUMP',EQ 70$		; oui => 70$	INC.W	D1		; non => signal70$:	CLR.W	D7		; D7 <-- ok	LOAD.B	D2,(A4+)	JUMP',EQ EXIT$	COMP.B	D2,#CR	JUMP',EQ EXIT$	COMP.B	D2,#SPACE	JUMP,EQ 70$	LOAD.W	D7,#1		; D7 <-- erreur de syntaxeEXIT$:	POPM.L	D2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PUTANUM >;--------/; Met un nombre dcimal dans un buffer.; in	D4.W	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	AND.L	D4,#H'FFFF	; D4 <-- nombre binaire	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;--------/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSH.L	D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POP.L	D3	RET;----------\\; DBOXCOLOR >;==========/; Choix des couleurs.; in	-; out	D7.W	erreur; mod	D7.WDBOXCOLOR:	PUSHM.L	D3..D5,A3..A5	LOAD.L	A3,#R16"NMDES$	CALL	_GETTCOUL	; A5 <-- ^TCOUL	LOAD.L	D5,(A6)+OIDCRET	LOAD.L	D4,#2^BICMPAL	; D4 <-- mode local	ICOL_	MODCRET		; modifie la CRET ...	PUSH.W	D7	CALL	DBOXCLOSE1	; refait les soft-keys	POP.W	D7	JUMP',NE EXIT$	LOAD.L	(A6)+OIDCRET,D5	CALL	LIBICONE	; libre les icnes	CALL	CCMO		; enlve la souris	CALL	DESWDO	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3..D5,A3..A5	TEST.W	D7		; retour EQ/NE	RETNMDES$:	.ASCIZ	"DESSIN4"	.EVEN;----------\\; DBOXZOOM  >;==========/; Demande deux facteurs de zoom spciaux.; in	-; out	D7.W	erreur; mod	D7.WDBOXZOOM:	PUSHM.L	D1..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_ZOOM	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBYZOOM	LIB	?AFTEXT		; affiche le facteur vertical	CLR.W	D2		; D2 <-- dans facteur en X20$:	LOAD.L	A3,#(A6)+OBXZOOM	TEST.W	D2	JUMP',EQ 22$	LOAD.L	A3,#(A6)+OBYZOOM22$:	LOAD.L	A4,A323$:	TEST.B	(A4+)	JUMP,NE 23$	DEC.L	A4		; A4 <-- ^fin du dernier nombreLOOP$:	LOAD.W	D3,D2	DBOX_	MEDIT		; indique le facteur  diter	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_ZOOM	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#UNDO	JUMP',EQ 40$	COMP.W	D3,#KEYICO+0	JUMP',EQ 45$	COMP.W	D3,#KEYICO+1	JUMP',EQ 45$	COMP.W	D3,#CR	JUMP',EQ 47$	COMP.W	D3,#F1		; (ZOOM) ?	JUMP',EQ 50$	LOAD.W	D7,#ERKSTO	COMP.W	D3,#F0		; (ANNULE) ?	JUMP,EQ 80$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$45$:				; change =>	SUB.W	D3,#KEYICO	LOAD.W	D2,D3		; D2 <-- 0..1	JUMP	20$47$:				; suivant =>	INC.W	D2	COMP.W	D2,#2	JUMP,LO 20$	CLR.W	D2	JUMP	20$50$:				; ZOOM =>	CLR.W	D2	LOAD.L	A3,#(A6)+OBXZOOM	LOAD.L	A4,A3		; A4 <-- ^nombre prsum	CALL	ZRDNUM		; D4 <-- nombre *1000	JUMP,NE BIP$	LOAD.W	(A6)+OXZOOM,D4	INC.W	D2	LOAD.L	A3,#(A6)+OBYZOOM	LOAD.L	A4,A3		; A4 <-- ^nombre prsum	CALL	ZRDNUM		; D4 <-- nombre *1000	JUMP,NE BIP$	LOAD.W	(A6)+OYZOOM,D4	CALL	DBOXCLOSE	; ferme la DBOX	LOAD.W	D3,(A6)+OMALMX	MUL.WU	D3,(A6)+OXZOOM	DIV.WU	D3,#1000	; D3 <-- largeur de l'image	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X !	LOAD.W	D4,(A6)+OMALMY	MUL.WU	D4,(A6)+OYZOOM	DIV.WU	D4,#1000	; D4 <-- hauteur de l'image	AND.B	D4,#B'11111110	; D4 <-- modulo 2 en Y !	LOAD.B	(A6)+OMASTR,#2^BMASTR	CALL	GETMEMMATRIX	; demande mmoire pour nouvelle image	CLR.B	(A6)+OMASTR	TEST.W	D7	JUMP',NE EXIT$	SET.B	(A6)+OMAJ	; une mise  jour sera ncessaire	LOAD.W	D4,#SCALE11	LOAD.W	(A6)+OSCALE,D4	CLR.L	(A6)+OPMOVY	CLR.L	(A6)+OPMDIY	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$80$:				; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZRDNUM  >;--------/; Lit un nombre  trois dcimales, rendu 1000 fois plus grand.; S'il n'y a pas de nombre, rend 1 pour ne rien zoomer !; in	A4.L	^nombre prsum; out	A4.L	^plus loin;	D4.W	nombre (+/-);	D7.W	erreur; mod	D4.L, D7.W, A4.LZRDNUM:	PUSHM.L	D1..D3,A3	CLR.W	D1		; D1 <-- nb de dcimales	CLR.W	D2		; D2 <-- positif	COMP.B	(A4),#'-	; signe moins ?	JUMP',NE 05$		; non => 05$	INC.L	A4		; oui =>	INC.W	D2		; D2 <-- ngatif05$:	LOAD.W	D7,#ERSYNT	LOAD.L	A3,A4		; A3 <-- ^dbut du nombre	CLR.W	D4		; D4 <-- futur nombre10$:	CLR.W	D3	LOAD.B	D3,(A4+)	; D3 <-- caractre	COMP.B	D3,#'.	JUMP',EQ 30$	COMP.B	D3,#'0		; est un digit ?	JUMP',LO 40$		; non => 40$	COMP.B	D3,#'9	JUMP',HI 40$	TEST.L	D1:#15		; est-on dans les dcimales ?	JUMP',BC 20$		; non => 20$				; oui =>	COMP.B	D1,#3		; plus de 3 dcimales ?	JUMP,HS 10$		; oui => 10$ (ignore)	INC.B	D1		; non => une dcimale de plus20$:	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.W	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$30$:	TSET.L	D1:#15		; D1 <-- partie dcimale existe	JUMP,BS EXIT$		; si 2me point => EXIT$ (erreur)	JUMP	10$40$:	TEST.W	D2		; nombre positif ?	JUMP',EQ 45$		; oui => 45$	NEG.L	D4		; non => prend le complment45$:	TEST.B	D3		; nombre termin ?	JUMP',NE EXIT$		; non => EXIT$				; oui =>	DEC.L	A4	COMP.L	A4,A3		; au moins un digit ?	JUMP',NE 55$		; oui => 55$	LOAD.W	D4,#1		; non => pas de zoom, donc facteur 155$:	LOAD.W	D2,#1000	; D2 <-- aucune dcimale	TEST.B	D1	JUMP',EQ 60$	LOAD.W	D2,#100		; D2 <-- une dcimale	DEC.B	D1	JUMP',EQ 60$	LOAD.W	D2,#10		; D2 <-- deux dcimales	DEC.B	D1	JUMP',EQ 60$	LOAD.W	D2,#1		; D2 <-- trois dcimales60$:	MUL.WU	D4,D2		; D4 <-- simule les dcimales manquantes	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXFLAGS >;==========/; Change le mode.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXFLAGS:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.B	D3,#ICOFLAGS	CALL	INVALLICONE	; allume l'icne	LOAD.L	A2,#R16"TDBOX_FLAGS	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFLAGS	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	TEST.B	(A6)+OXICO	; icnes spciales ?	JUMP',EQ LOOP$		; non => LOOP$				; oui =>	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#2!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#3!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#4!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#5!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#6!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	POP.L	D4	CLR.B	D4		; D4 <-- plus de automatique/contour/etc.LOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_FLAGS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ 60$	COMP.W	D3,#F0	JUMP,EQ 80$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP,EQ 50$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$50$:	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO 52$	LOAD.L	D1,#H'FFFF00FF	COMP.B	D3,#16	JUMP',LO 52$	LOAD.L	D1,#H'FF00FFFF	COMP.B	D3,#24	JUMP',LO 52$	LOAD.L	D1,#H'00FFFFFF52$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon	JUMP	LOOP$60$:				; D'ACCORD =>	TEST.B	(A6)+OXICO	; icnes spciales ?	JUMP',EQ 62$		; non => 62$	LOAD.B	D4,(A6)+OFLAGS+362$:	LOAD.L	(A6)+OFLAGS,D4	LOAD.W	D1,#32	TEST.L	D4:#BFLP32	JUMP',BS 70$	LOAD.W	D1,#16	TEST.L	D4:#BFLP16	JUMP',BS 70$	LOAD.W	D1,#8	TEST.L	D4:#BFLP8	JUMP',BS 70$	LOAD.W	D1,#4	TEST.L	D4:#BFLP4	JUMP',BS 70$	LOAD.W	D1,#2	TEST.L	D4:#BFLP2	JUMP',BS 70$	LOAD.W	D1,#170$:	LOAD.W	(A6)+OPAS,D1	CALL	DBOXCLOSE	; ferme la DBOX	CALL	DESINFPA	; affiche le pas	JUMP'	EXIT$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	PUSHM.L	D3,D7	LOAD.B	D3,#ICOFLAGS	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXOKTEXT >;===========/; Dbox pour confirmer l'opration "texte".; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXOKTEXT:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_OKTEXT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OKTEXT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#CR		; OUI ?	JUMP',EQ 80$	COMP.W	D3,#END		; NON ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$80$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXRDEF >;=========/; Dbox pour choisir le mode pour les rectangles.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXRDEF:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.B	D3,#ICORDEF	CALL	INVALLICONE	; allume l'icne	CLR.L	D4	LOAD.B	D4,(A6)+OTRECT	LOAD.W	D2,#8	LOAD.W	D3,(A6)+ORRECT	JUMP',EQ 10$	INC.W	D2	COMP.W	D3,#4	JUMP',EQ 10$	INC.W	D2	COMP.W	D3,#8	JUMP',EQ 10$	INC.W	D2	COMP.W	D3,#12	JUMP',EQ 10$	INC.W	D2;	COMP.W	D3,#16;	JUMP',EQ 10$10$:	TSET.L	D4:D2	LOAD.L	A2,#R16"TDBOX_RDEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D2,#SETDOT	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#6	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#24	LIB	?DRSEG	AND.L	D3,#H'FFFF	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#12	SWAP.W	D4	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#12	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	POP.L	D4LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_RDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP,EQ 60$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 80$	COMP.W	D3,#KEYICO+BRECONT	JUMP,EQ 54$	COMP.W	D3,#KEYICO+BRETRAM	JUMP,EQ 55$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP',EQ 50$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$50$:	LOAD.L	D1,#H'FFFFFF00!2^BRECONT!2^BRETRAM	COMP.B	D3,#8	JUMP',LO 52$	LOAD.L	D1,#H'FFFF00FF	COMP.B	D3,#16	JUMP',LO 52$	LOAD.L	D1,#H'FF00FFFF	COMP.B	D3,#24	JUMP',LO 52$	LOAD.L	D1,#H'00FFFFFF52$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon	JUMP	LOOP$54$:	TEST.L	D4:#BRECONT	JUMP,BS LOOP$	TSET.L	D4:#BRETRAM	JUMP	LOOP$55$:	TEST.L	D4:#BRETRAM	JUMP,BS LOOP$	TSET.L	D4:#BRECONT	JUMP	LOOP$60$:	LOAD.B	(A6)+OTRECT,D4	CLR.W	D2	TEST.L	D4:#8	JUMP',BS 62$	LOAD.W	D2,#4	TEST.L	D4:#9	JUMP',BS 62$	LOAD.W	D2,#8	TEST.L	D4:#10	JUMP',BS 62$	LOAD.W	D2,#12	TEST.L	D4:#11	JUMP',BS 62$	LOAD.W	D2,#16;	TEST.L	D4:#12;	JUMP',BS 62$62$:	LOAD.W	(A6)+ORRECT,D280$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	PUSHM.L	D3,D7	LOAD.B	D3,#ICORDEF	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXADEF >;=========/; Dbox pour choisir le mode pour les cercles.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXADEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.B	D3,#ICOADEF	CALL	INVALLICONE	; allume l'icne	CLR.L	D4	LOAD.B	D4,(A6)+OARC	SL.L	D4,#8	LOAD.B	D4,(A6)+OMCERC	SL.L	D4,#8	LOAD.B	D4,(A6)+OPOLY	LOAD.L	A2,#R16"TDBOX_ADEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D2,#SETDOT	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#20	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#5	SWAP.W	D4	LIB	?DRSEG	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#20	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#40	LOAD.W	D4,(A0)+ODFFDY	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#10	LOAD.W	D3,D4	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,D3	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#12	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#40	LIB	?DRSEG	POP.L	D4	LOAD.L	A3,#(A6)+OBARC	LOAD.L	A4,A312$:	TEST.B	(A4+)	JUMP,NE 12$	DEC.L	A4		; A4 <-- ^fin du dernier nombre	JUMP	60$LOOP$:	CLR.W	D3	TEST.L	D4:#16+BARCQ	JUMP',BS 22$	DEC.W	D322$:	DBOX_	MEDIT	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_ADEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP,EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 80$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP',EQ 50$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$50$:	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO 52$	LOAD.L	D1,#H'FFFFF0FF	COMP.B	D3,#12	JUMP',LO 52$	LOAD.L	D1,#H'FFFF0FFF	COMP.B	D3,#16	JUMP',LO 52$	LOAD.L	D1,#H'FF00FFFF;	COMP.B	D3,#24;	JUMP',LO 52$;	LOAD.L	D1,#H'00FFFFFF52$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon60$:	CLR.W	D7		; D7 <-- grise	TEST.L	D4:#0+BPOLYE	JUMP',BS 62$	INC.W	D7		; D7 <-- dgrise62$:	LOAD.L	D0,#H'FFFFF0FF	LOAD.W	D1,#8+BMCERAY	LOAD.W	D2,#8+BMCEDIA	CALL	DBADGRISE	; grise/dgrise "diamtre"	CLR.W	D7		; D7 <-- grise	TEST.L	D4:#0+BPOLY3	JUMP',BS 64$	TEST.L	D4:#0+BPOLY4	JUMP',BS 64$	TEST.L	D4:#0+BPOLY5	JUMP',BS 64$	TEST.L	D4:#0+BPOLY6	JUMP',BS 64$	TEST.L	D4:#0+BPOLY8	JUMP',BS 64$	TEST.L	D4:#0+BPOLY10	JUMP',BS 64$	TEST.L	D4:#8+BMCEDIA	JUMP',BS 64$	INC.W	D7		; D7 <-- dgrise64$:	LOAD.L	D0,#H'FF00FFFF	LOAD.W	D1,#16+BARC1	LOAD.W	D2,#16+BARC2	CALL	DBADGRISE	; grise/dgrise "1/2"	LOAD.W	D2,#16+BARC4	CALL	DBADGRISE	; grise/dgrise "1/4"	LOAD.W	D2,#16+BARCQ	CALL	DBADGRISE	; grise/dgrise "[] degrs"	CLR.W	D7		; D7 <-- grise	TEST.L	D4:#0+BPOLY3	JUMP',BS 65$	TEST.L	D4:#0+BPOLY4	JUMP',BS 65$	TEST.L	D4:#0+BPOLY5	JUMP',BS 65$	TEST.L	D4:#0+BPOLY6	JUMP',BS 65$	TEST.L	D4:#0+BPOLY8	JUMP',BS 65$	TEST.L	D4:#0+BPOLY10	JUMP',BS 65$	TEST.L	D4:#8+BMCEDIA	JUMP',BS 65$	TEST.L	D4:#0+BPOLYE	JUMP',BS 65$	INC.W	D7		; D7 <-- dgrise65$:	LOAD.L	D0,#H'FF00FFFF	LOAD.W	D1,#16+BARC1	LOAD.W	D2,#16+BARCQ	CALL	DBADGRISE	; grise/dgrise "[] degrs"	CLR.W	D7		; D7 <-- grise	TEST.L	D4:#16+BARCQ	JUMP',BC 66$	INC.W	D7		; D7 <-- dgrise66$:	LOAD.L	D0,#H'FFFF0FFF	LOAD.W	D1,#-1	LOAD.W	D2,#8+BMCEARC	CALL	DBADGRISE	; grise/dgrise "arc"	LOAD.L	D0,#H'FFFF0FFF	LOAD.W	D1,#-1	LOAD.W	D2,#8+BMCETRA	CALL	DBADGRISE	; grise/dgrise "tranche"	TEST.W	D7	JUMP',EQ 67$	TEST.L	D4:#8+BMCEARC	JUMP',BS 67$	TEST.L	D4:#8+BMCETRA	JUMP',BS 67$	TSET.L	D4:#8+BMCEARC67$:	JUMP	LOOP$70$:	LOAD.B	(A6)+OPOLY,D4	SR.L	D4,#8	LOAD.B	(A6)+OMCERC,D4	SR.L	D4,#8	LOAD.B	(A6)+OARC,D4	LOAD.L	A4,A3	CALL	GETANUM		; D4 <-- arc quelconque	CONV.LA.WA D4	DIV.WA	D4,#360	SWAP.W	D4	LOAD.W	(A6)+ONARC,D480$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	PUSHM.L	D3,D7	LOAD.B	D3,#ICOADEF	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBADGRISE >;----------/; Grise ou dgrise une paire de labels.; in	D7.W	0	-->  grise;		autre	-->  dgrise;	D0.L	masque pour teindre;	D1.W	bit  allumer (-1 si aucun);	D2.W	bit  griser/dgriser;	D4.L	fanions; out	D4.L	fanions; mod	D4.LDBADGRISE:	PUSH.W	D7	TEST.W	D7	JUMP',EQ 50$				; dgrise =>	PUSHM.L	D2..D4	OR.W	D2,#2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	ADD.W	D2,#100	DBOX_	GETCO	POPM.L	D2..D4	JUMP'	EXIT$50$:				; grise =>	PUSHM.L	D2..D4	OR.W	D2,#2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	ADD.W	D2,#100	DBOX_	GETCO	POPM.L	D2..D4	TCLR.L	D4:D2		; D4 <-- teint le bit	JUMP',BC EXIT$	AND.L	D4,D0		; D4 <-- teint qq bits	COMP.W	D1,#-1	JUMP',EQ EXIT$	TSET.L	D4:D1		; D4 <-- rallume umn bitEXIT$:	POP.W	D7	RET	.END