prsentes	.EVENOASVER:	.BLKB	LSCVAR		; variables de l'ascenseur verticalOASHOR:	.BLKB	LSCVAR		; variables de l'ascenseur horizontalORGVAR:	.BLKB	LRGVAR		; variables des rglesOLASTP1:.BLKB	4		; slection: P1 pour COPY-clicOLASTP2:.BLKB	4		; slection: P2 pour COPY-clicOSEOHG:	.BLKB	4		; slection: point original sup/gaucheOSEOHD:	.BLKB	4		; slection: point original sup/droiteOSEOBG:	.BLKB	4		; slection: point original inf/gaucheOSEOBD:	.BLKB	4		; slection: point original inf/droiteOSEPHG:	.BLKB	4		; slection: point courant sup/gaucheOSEPHD:	.BLKB	4		; slection: point courant sup/droiteOSEPBG:	.BLKB	4		; slection: point courant inf/gaucheOSEPBD:	.BLKB	4		; slection: point courant inf/droiteOSEOMI:	.BLKB	4		; slection: centre de symtrie originalOSEPMI:	.BLKB	4		; slection: centre de symtrie courantOSEANG:	.BLKB	2		; slection: angle de la rotation [degrs]OSEBLX:	.BLKB	1		; slection: dplacement seulement en XOSEBLY:	.BLKB	1		; slection: dplacement seulement en Y	.EVENOCERAY:	.BLKB	2		; cercle: rayon  afficherOCEANG:	.BLKB	2		; cercle: angle  afficherOMAJ:	.BLKB	1		; 1 => mise  jour ncessaireOOUTIL:	.BLKB	1		; outil (crayon, pinceau, etc.)OMODE:	.BLKB	1		; mode de dessin (peinture ou gomme)OOBJET:	.BLKB	1		; objet (trait, droite, cercle, etc.)OSELECT:.BLKB	1		; slection (zone ou filet)OLOUTIL:.BLKB	1		; loupe: dernier outilOLMODE:	.BLKB	1		; loupe: dernier modeOLOBJET:.BLKB	1		; loupe: dernier objet	.EVENONPDEF:	.BLKB	2		; no trame du pinceauONTDEF:	.BLKB	2		; no trame de remplissageONSDEF:	.BLKB	2		; no trame du sprayOPDEF:	.BLKB	MAXDEF*(8+2)	; trames du pinceauOTDEF:	.BLKB	MAXDEF*8	; trames de remplissageOSDEF:	.BLKB	8		; trame du sprayORRECT:	.BLKB	2		; rectangle: rayon des arrondis (0..n)OTRECT:	.BLKB	1		; rectangle: type (BRExxxx)OPOLY:	.BLKB	1		; polygone: type (BPOLYx)OMCERC:	.BLKB	1		; mode cercle: type (BMCExxx)OARC:	.BLKB	1		; cercle: bits pour les arcs (BARCx)	.EVENONARC:	.BLKB	2		; arc: valeurOBARC:	.BLKB	10		; arc: buffer pour valeurOBLOC:	.BLKB	LGBLOC*NBBLOC	; bloc-notesOSPLPT:	.BLKB	4*MAXSPLINE	; points pour splineOSPLOF:	.BLKB	1		; ouvert/ferm	.EVENOSTRETCH:.BLKB	ST_LGTRECT	; variables pour le module STRETCHOSTRHV:	.BLKB	1		; horizontal/verticalOSTRDF:	.BLKB	1		; type de dformationOSTRRO:	.BLKB	1		; sens de la rotation	.EVENOTRAPA:	.BLKB	2		; trame: pas (2..64)OTRANI:	.BLKB	2		; trame: niveau (2..16)OTRALU:	.BLKB	2		; trame: luminosit (-8..+8)OTRAFA:	.BLKB	2		; trame: famille (0..1)OTRAT1:	.BLKB	MAXDEF*8	; trame: trames de remplissage famille 1OTRAT2:	.BLKB	MAXDEF*8	; trame: trames de remplissage famille 2OTRAT3:	.BLKB	MAXDEF*8	; trame: trames de remplissage famille 3OLISPA:	.BLKB	2		; lisse: pas (2..64)OLISLU:	.BLKB	2		; lisse: luminosit (-1..+1)OTAPAVE:.BLKB	(NBPAVE+1)*LPA	; liste des pavs de texteOPTTEXT:.BLKB	4		; ^ligne de texte en ditionONBTEXT:.BLKB	2		; nb de caractresOCUTEXT:.BLKB	2		; position du curseurOCPTEXT:.BLKB	4		; curseur: y;xOCHTEXT:.BLKB	2		; curseur: hOPOTEXT:.BLKB	4		; position ligne de texte en ditionOPSTEXT:.BLKB	4		; position de la souris pour EDDETECTOHTTEXT:.BLKB	2		; hauteur de la ligne \OLGTEXT:.BLKB	2		; largeur de la ligne /OOPTEXT:.BLKB	4		; ancienne positionOOHTEXT:.BLKB	2		; ancienne hauteur de la ligne \OOLTEXT:.BLKB	2		; ancienne largeur de la ligne /OILTEXT:.BLKB	2		; interligneOICTEXT:.BLKB	2		; intercaractreOECTEXT:.BLKB	2		; espace-caractresOCNTEXT:.BLKB	2		; critre pour les coupures dans les motsOCXTEXT:.BLKB	2		; espace pour le contour en XOCYTEXT:.BLKB	2		; espace pour le contour en YOBLTEXT:.BLKB	LBLTEXT		; ligne de points si pouse le contourOJUTEXT:.BLKB	1		; mode de justificationOCMTEXT:.BLKB	1		; coupures dans les motsOCTTEXT:.BLKB	1		; pouse le coutourO3PTEXT:.BLKB	1		; 3 poignes ?ODETEXT:.BLKB	1		; est-ce que le texte dborde ?OHVTEXT:.BLKB	1		; horizontal/verticalODATEXT:.BLKB	1		; d'accord/annuleOACTEXT:.BLKB	1		; accent flottant en coursOVIFDCR:.BLKB	1		; enable/disable <cr>ODTTEXT:.BLKB	1		; dtecte/affiche pour EDDETECTOQCTEXT:.BLKB	1		; normal/curseur pour EDAFTEXT	.EVENOBUMOT:	.BLKB	LBUMOT		; mot  couperOBULMO:	.BLKB	LBUMOT*2	; positions des caractres du mot  couperOBUCOUP:.BLKB	LBUCOUP+2	; coupures de motsOBUGC:	.BLKB	LGGC*MAXGC	; table des gnrateurs de caractresOGCLIST:.BLKB	MAXGENC*3	; liste des gencars contenus sur disqueOFAGC:	.BLKB	4		; fanions pour dbox des gencarsOBUNAME:.BLKB	LBUFILE		; nom du dessin en mmoireOBUPRES:.BLKB	16		; nom de la prsentationOBUFIN:	.BLKB	LBUFILE		; nom du fichier en entre (prend)OBUFAJ:	.BLKB	LBUFILE		; nom du fichier en entre (ajoute)OBUFOUT:.BLKB	LBUFILE		; nom du fichier en sortieOBUFTX:	.BLKB	LBUFILE		; nom du fichier texteOBXFILE:.BLKB	LBUFILE		; nom du fichier avec extensionOBUHIMA:.BLKB	LGHIMA		; en-tte d'un fichier .imageOBUHDEF:.BLKB	LGHDEF		; en-tte d'un fichier .ddesOXZOOM:	.BLKB	2		; facteur de zoom spcial en X (*1000)OYZOOM:	.BLKB	2		; facteur de zoom spcial en Y (*1000)OBXZOOM:.BLKB	10		; buffer pour valeur de zoom en XOBYZOOM:.BLKB	10		; buffer pour valeur de zoom en YOOPREL:	.BLKB	LREL*8		; relief: matrices d'oprationsOO1REL:	.BLKB	LREL		; relief: une matrice d'oprationsOPTREL:	.BLKB	2		; relief: ^relatifOBUREL:	.BLKB	MAXREL		; relief: buffer pour oprationsORDLG:	.BLKB	2		; relief: dimension d'un pointORDOP:	.BLKB	1		; relief: opration (0..2)	.EVENOSTPRI:	.BLKB	LGPRI0		; status de l'imprimanteOFACX:	.BLKB	2		; facteur rduction en XOFACY:	.BLKB	2		; facteur rduction en YOMMX:	.BLKB	2		; nb de 1/10 de um pour un point en XOMMY:	.BLKB	2		; nb de 1/10 de um pour un point en YLGVAR:; Programme; ---------	.LOC	0	JUMP	START	.INS	DESTAB1.ASISTART:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CALL	_WAITMOUSE	; met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	LOAD.B	(A6)+OGCLIST,#-1	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*5+1	; est-ce au moins 5.1 ?	JUMP,LO ERFAT2		; non => ERFAT2	LOAD.L	A3,#R16"TXERFATDIS	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT2	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	COMP.W	(A0)+ODFIIX,#1	; cran de type SMAKY100/324 ?	JUMP,NE ERFAT2		; non => patatras ...	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	LOAD.L	A3,#R16"TXERFATTXT	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATICO	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATICO1	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT+1	.B	0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A1,#R16"TXERFATGRA	LOAD.W	D3,#GRA_DOT	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+ODOT,A3	LOAD.W	D3,#GRA_GDOT	LIB_	GETAD	JUMP',NE GDOT$	LOAD.L	(A6)+OGDOT,A3GDOT$:	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OQXDOT,A3	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+ORASTER,A3	LOAD.W	D3,#GRA_CRASTER	LIB_	GETAD	JUMP',NE CRAST$	LOAD.L	(A6)+OCRASTER,A3CRAST$:	LOAD.W	D3,#GRA_MATRIX	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OMATRIX,A3	LOAD.W	D3,#GRA_TRAME	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OTRAME,A3	LOAD.W	D3,#GRA_CLEAR	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OCLEAR,A3	LOAD.W	D3,#GRA_SET	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OSET,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OINV,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMDGENC	LOAD.W	D3,#DGENC_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDGENC,D1	LOAD.L	A3,#R16"NMDESSIN	LOAD.W	D3,#DESSIN_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDESSIN,D1	LOAD.L	A3,#R16"NMDESS2	LOAD.W	D3,#DESS2_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDESS2,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMCOUPE	LOAD.W	D3,#COUPE_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHCOUPE,D1	LOAD.L	A3,#R16"NMSPLINE	LOAD.W	D3,#SPLINE_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSPLINE,D1	LOAD.L	A3,#R16"NMSTRETCH	LOAD.W	D3,#ST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSTRETCH,D1	LOAD.L	A3,#R16"NMBLOC	LOAD.W	D3,#BLOC_FIRST	LIB_	OPEN	JUMP',NE NOBLOC$	LOAD.W	(A6)+OCHBLOC,D1	BLOC_	OPEN		; ouverture globaleNOBLOC$:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	LOAD.L	A3,#R16"NMICOLOR	LOAD.W	D3,#ICOL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHICOLOR,D1	LOAD.L	A3,#R16"NMDESS4	LOAD.L	A5,#R16"TCOUL	LOAD.L	D3,#2^BICCRET	ICOL_	INIT		; charge DESSIN4.CRET	LOAD.L	(A6)+OIDCRET,D5NOCOUL$:	LOAD.L	A3,#R16"NMPRINTA	LOAD.W	D3,#PRINTA_FIRST	LIB_	OPEN	JUMP',NE 30$	LOAD.W	(A6)+OCHPRINTA,D1	CLR.L	D3	PRINTA_	OPEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OCAPRINT,A230$:	CALL	_RDSTPRINT	; lit le status de l'imprimante	LOAD.L	A3,#R16"NMSCAN	LOAD.W	D3,#SCAN_FIRST	LIB_	OPEN	JUMP',NE 32$	LOAD.W	(A6)+OCHSCAN,D1	SCAN_	OPEN	JUMP',NE 31$	LOAD.L	(A6)+OCASCAN,D6	JUMP'	32$31$:	LIB_	CLOSE32$:	LOAD.B	(A6)+OMODE,#ICOSET	LOAD.B	(A6)+OOUTIL,#ICOCRAYON	LOAD.B	(A6)+OOBJET,#ICOTRAIT	LOAD.B	(A6)+OSELECT,#ICOZONE	LOAD.L	(A6)+ODEF,#2^BDEFPG!2^BDEFICO!2^BDEFASC	LOAD.L	(A6)+OFLAGS,#2^BFLP1!2^BFLAUTO	LOAD.W	(A6)+OPAS,#1	LOAD.L	A3,#R16"TXERFATMEM	LOAD.L	D4,#MAXTEXT+2	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour pav de texte	JUMP,NE ERFAT2	LOAD.L	(A6)+OPTTEXT,A4	LOAD.B	(A6)+OSTRDF,#ICODEFORMEQQ	LOAD.B	(A6)+OSTRRO,#ICOTOURNEP	LOAD.B	(A6)+OSPLOF,#ICOSPLINEO	LOAD.B	(A6)+OJUTEXT,#ICOJUSTA	LOAD.W	(A6)+OCNTEXT,#5-1	LOAD.W	(A6)+OCXTEXT,#2	LOAD.W	(A6)+OCYTEXT,#2	LOAD.W	(A6)+OTRAPA,#8	LOAD.W	(A6)+OTRANI,#8;	LOAD.W	(A6)+OTRALU,#0	LOAD.L	A3,#(A6)+OTRAT1	CLR.W	D4	DESS2_	TGET	LOAD.W	D4,#((17*8)/2)-140$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,40$	LOAD.L	A3,#(A6)+OTRAT2	LOAD.W	D4,#1	DESS2_	TGET	LOAD.W	D4,#((17*8)/2)-141$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,41$	LOAD.L	A3,#(A6)+OTRAT3	LOAD.W	D4,#2	DESS2_	TGET	LOAD.W	D4,#((17*8)/2)-142$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,42$;	LOAD.L	A3,#R16"TXERFATMEM	CALL	CALCADRE	; calcul pos/dim du grand rectangle	LOAD.W	D3,(A6)+OGRDIX	; D3 <-- largeur visible	LOAD.W	D4,(A6)+OGRDIY	; D4 <-- hauteur visible	CALL	_GETMEMMATRIX	; rserve mmoire pour matrices	JUMP,NE ERFAT2	CALL	_DEFGENCAR	; utilise tous les gencars par dfaut	LOAD.W	D4,#SCALE11	LOAD.W	(A6)+OSCALE,D4	CALL	CALSCALE	; met l'chelle par dfaut	LOAD.L	A3,#(A6)+OPDEF	CLR.W	D4	DESSIN_	DGET	LOAD.W	D4,#((MAXDEF*(8+2))/2)-150$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,50$	LOAD.L	A3,#(A6)+OTDEF	CLR.W	D4	DESSIN_	TGET	LOAD.W	D4,#((MAXDEF*8)/2)-152$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,52$	LOAD.L	A3,#(A6)+OSDEF	LOAD.L	A4,#R16"TSDEF	LOAD.W	D4,#((1*8)/2)-154$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,54$	LOAD.L	A3,#(A6)+OOPREL	CLR.W	D4	DESS2_	RGET	LOAD.W	D4,#((LREL*8)/2)-156$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,56$	LOAD.W	(A6)+ONPDEF,#8	; utilise trame pinceau par dfaut	LOAD.W	(A6)+ONTDEF,#3	; utilise trame remplissage par dfaut	CLR.W	(A6)+ONSDEF	; utilise trame spray par dfaut	CLR.W	(A6)+ORRECT	LOAD.B	(A6)+OTRECT,#2^BRECONT!2^BRETRAN	LOAD.B	(A6)+OPOLY,#2^BPOLYC	LOAD.B	(A6)+OMCERC,#2^BMCERAY	LOAD.B	(A6)+OARC,#2^BARC1	LOAD.W	(A6)+ONARC,#90	LOAD.B	(A6)+OBARC+0,#'9	LOAD.B	(A6)+OBARC+1,#'0;	CLR.B	(A6)+OBARC+2	CALL	_CCMO		; enlve la souris	CALL	DESWDO	CALL	DESCADRE	CALL	_AFMENU		; affiche les soft-keys	LIB	?BUZZ		; signal: c'est prt !	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SKPNAM	JUMP,NE LOOP	LOAD.L	A4,#(A6)+OBUFIN70$:	LOAD.B	D3,(A3+)	JUMP',EQ 75$	COMP.B	D3,#CR	JUMP',EQ 75$	COMP.B	D3,#SPACE	JUMP',EQ 75$	COMP.B	D3,#TAB	JUMP',EQ 75$	COMP.B	D3,#'/	JUMP',EQ 75$	LOAD.B	(A4+),D3	; OBUFIN <-- nom ligne de commande	JUMP	70$75$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUFIN	; A3 <-- ^nom	JUMP	PRENDF		; essaye de prendre ce fichier ...LOOP:	CALL	FULLGREYICONE	; (d)grise qq icnes	CALL	_SCMO		; remet la souris	CALL	_NORMMOUSE	; enlve le sablier20$:	LOAD.B	D3,(A6)+OOUTIL	JUMP',NE 30$	LOAD.B	D3,(A6)+OOBJET30$:	CALL	_SELMO		; utilise le bon lutin	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP',NE 62$	CALL	_RGMOUSE	; dessine la position dans les rgles	TEST.L	(A6)+OPOTEXT	; ligne de texte en dition ?	JUMP',NE 70$		; oui => 70$ ( cause du curseur)	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP',NE 62$	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP',EQ 64$62$:	LOAD.L	D3,#-1		; D3 <-- on est pas dans l'aire de dessin64$:	COMP.L	D3,(A6)+OLASTXY	JUMP',EQ 70$	LOAD.L	(A6)+OLASTXY,D3	CALL	DESINFXY	; affiche X= et Y= dans les informations70$:	LIB	?GETKEY		; attend clavier/souris ...	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP,BS 70$		; non => 70$				; oui =>	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ 20$		; oui => 20$EXECUTE:	COMP.W	D3,#F0+SHIFT	JUMP',LO 10$	COMP.W	D3,#F15+SHIFT	JUMP',HI 10$	SUB.W	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)10$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC	LOAD.L	A4,#R16"TAKEY-4	LOAD.W	D2,D3	COMP.B	D2,#'a	JUMP',LO 40$	COMP.B	D2,#'z	JUMP',HI 40$	SUB.B	D2,#'a-'A	; D2 <-- lettre MAJUSCULE40$:	ADD.L	A4,#4	TEST.W	(A4)+0	JUMP',EQ 42$	COMP.W	D2,(A4)+0	JUMP,NE 40$	LOAD.W	D3,(A4)+2	JUMP	CLICICONE42$:	LOAD.L	A1,#0	CALL	DOKASCENSEUR	; agit dans ascenseurs selon touche	JUMP,EQ LOOP	COMP.W	D3,#UNDO	JUMP,EQ EXUNDO	COMP.W	D3,#BS	JUMP,EQ EXUNDO	COMP.W	D3,#DEL	JUMP,EQ EXUNDO	COMP.W	D3,#DELETE	JUMP,EQ EXUNDO	COMP.W	D3,#HELP	JUMP,EQ DOHELP	COMP.W	D3,#KEYICO+ICOVZONE	JUMP,EQ MENUZONE	COMP.W	D3,#KEYICO+ICOFLAGS	JUMP,EQ MENUFLAGS	COMP.W	D3,#KEYICO+ICOPDEF	JUMP,EQ MODIFPDEF	COMP.W	D3,#KEYICO+ICOTDEF	JUMP,EQ MODIFTDEF	COMP.W	D3,#KEYICO+ICORDEF	JUMP,EQ MODIFRDEF	COMP.W	D3,#KEYICO+ICOADEF	JUMP,EQ MODIFADEF	COMP.W	D3,#H'100*(2^BKILL)+SPACE	JUMP,EQ _COUPE	COMP.W	D3,#H'100*(2^BCOPY)+SPACE	JUMP,EQ _COPIE	COMP.W	D3,#H'100*(2^BCURSOR)+SPACE	JUMP,EQ _COLLE	COMP.W	D3,#KEYICO+ICOCOLLE	JUMP,EQ _COLLE	COMP.W	D3,#H'100*(2^BSHOW)+SPACE	JUMP,EQ _CLASSEUR	COMP.W	D3,#F0	JUMP,EQ FINI	COMP.W	D3,#END	JUMP,EQ FINI	COMP.W	D3,#F1	JUMP,EQ _PREND	COMP.W	D3,#H'100*(2^BSHOW)+DEFINE	JUMP,EQ _PREND	COMP.W	D3,#F2	JUMP,EQ _AJOUTE	COMP.W	D3,#F3	JUMP,EQ _SAUVE	COMP.W	D3,#H'100*(2^BCOPY)+DEFINE	JUMP,EQ _SAUVE	COMP.W	D3,#F4	JUMP,EQ MODIFDEF	COMP.W	D3,#F5	JUMP,EQ MODIFZOOM	COMP.W	D3,#F6	JUMP,EQ _SCAN	LOAD.B	D4,#'1	COMP.W	D3,#F8	JUMP,EQ SCALE	LOAD.B	D4,#'-	COMP.W	D3,#F7	JUMP,EQ SCALE	LOAD.B	D4,#'+	COMP.W	D3,#F9	JUMP,EQ SCALE	LOAD.B	D4,#'T	COMP.W	D3,#F13	JUMP,EQ SCALE	COMP.W	D3,#F10	JUMP,EQ REGLE	COMP.W	D3,#F12	JUMP,EQ NEGATIF	COMP.W	D3,#F14	JUMP,EQ EFFACE	COMP.W	D3,#F15	JUMP,EQ _IMPRIME	COMP.W	D3,#H'100*(2^BSHOW)+'0	JUMP',LO 60$	COMP.W	D3,#H'100*(2^BSHOW)+'9	JUMP,LS SHOWZONE60$:	JUMP	BIPCLIC:	LOAD.W	D2,D3		; D2 <-- bouton press	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP; Traite le cas o la souris est dans un ascenseur.	LOAD.L	A1,#0	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP; Traite le cas o la souris est dans une icne.	CALL	MOVICONE	; souris dans une icne ?	JUMP',EQ CLICICONE	; oui => CLICICONE				; non =>	CALL	DPLICONE	; dplace toutes les icnes ?	JUMP,EQ LOOP		; oui => LOOP	LOAD.W	D3,D2		; D3 <-- bouton press	COMP.W	D3,#KEYMGP	JUMP,EQ OUTIL	COMP.W	D3,#KEYMMP	JUMP,EQ MILIEU	COMP.W	D3,#KEYMDP	JUMP,EQ ENTOURE	JUMP	BIPCLICICONE:	COMP.B	D3,#ICOVZONE	JUMP,EQ	PRESSKEY	COMP.B	D3,#ICOCOLLE	JUMP,EQ	PRESSKEY	COMP.B	D3,#ICOVIDE	JUMP,EQ BIP	COMP.B	D3,#ICOSET	JUMP,EQ MODENEW	COMP.B	D3,#ICOCLEAR	JUMP,EQ MODECLEAR	COMP.B	D3,#ICOMAIN	JUMP,EQ MAINNEW	COMP.B	D3,#ICOPLOUPE	JUMP,EQ LOUPENEW	COMP.B	D3,#ICOOUTIL	JUMP,LO OUTILNEW	COMP.B	D3,#ICOOBJET	JUMP,LO OBJETNEW	COMP.B	D3,#ICOSELECT	JUMP,LO SELECTNEW	JUMP	PRESSKEYMODECLEAR:			; tente de mettre le mode "teint" =>	COMP.B	(A6)+OOUTIL,#ICOREMPLI	JUMP,EQ BIPMODENEW:			; change de mode =>	COMP.B	D3,(A6)+OMODE	JUMP,EQ LOOP	PUSH.W	D3	LOAD.B	D3,(A6)+OMODE	CALL	INVICONE	; teint l'ancien mode	POP.W	D3	LOAD.B	(A6)+OMODE,D3	CALL	INVICONE	; allume le nouveau mode	COMP.B	(A6)+OOUTIL,#ICOMAIN	JUMP,NE LOOP	LOAD.B	D3,#ICOCRAYON	JUMP	OUTILNEWMAINNEW:	TEST.W	(A6)+OASVER+OSCHTV	JUMP,NE OUTILNEW	TEST.W	(A6)+OASHOR+OSCHTV	JUMP,NE OUTILNEW	JUMP	BIP		; si aucun ascenseur => BIPLOUPENEW:	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE 40$	LOAD.W	D4,#SCALE11	CALL	CALSCALE	; remet l'chelle 1:1	CALL	DESCADRE	CALL	DESLOUPE	; redessine la loupe	CALL	DESMATRIX	; dessine les deux matrices	JUMP	LOOP40$:	COMP.B	D3,(A6)+OOUTIL	JUMP,EQ BIP	LOAD.B	(A6)+OLOUTIL,(A6)+OOUTIL	LOAD.B	(A6)+OLMODE,(A6)+OMODE	LOAD.B	(A6)+OLOBJET,(A6)+OOBJET;	JUMP'	OUTILNEWOUTILNEW:			; change d'outil =>	COMP.B	D3,(A6)+OOUTIL	JUMP,EQ LOOP	PUSH.W	D3	LOAD.B	D3,(A6)+OOUTIL	CALL	INVICONE	; teint l'ancien outil	POP.W	D3	LOAD.B	(A6)+OOUTIL,D3	CALL	INVICONE	; allume le nouvel outil	COMP.B	D3,#ICOMAIN	JUMP,EQ 40$	COMP.B	D3,#ICOPLOUPE	JUMP,EQ 40$	COMP.B	D3,#ICOREMPLI	JUMP,EQ 35$	COMP.B	D3,#ICOSPRAY	JUMP,NE 50$30$:				; vaporisateur =>	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; teint l'ancien objet	CLR.B	(A6)+OOBJET	TEST.B	(A6)+OMODE	JUMP,NE LOOP	LOAD.B	D3,#ICOSET	JUMP	MODENEW35$:				; bidon de peinture =>	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; teint l'ancien objet	CLR.B	(A6)+OOBJET				; force le mode "allume" =>	LOAD.B	D3,#ICOSET	COMP.B	D3,(A6)+OMODE	JUMP,EQ LOOP	JUMP	MODENEW40$:				; main/loupe =>	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; teint l'ancien objet	CLR.B	(A6)+OOBJET	LOAD.B	D3,(A6)+OMODE	CALL	INVICONE	; teint l'ancien mode	CLR.B	(A6)+OMODE	JUMP	LOOP50$:	TEST.B	(A6)+OMODE	; y'a-t-il un mode slectionn ?	JUMP',NE 55$		; oui => 55$	LOAD.B	D3,#ICOSET	CALL	INVICONE	; allume le mode par dfaut	LOAD.B	(A6)+OMODE,D355$:	LOAD.B	D3,(A6)+OOBJET	; y'a-t-il un objet slectionn ?	JUMP',EQ 60$		; non => 60$	COMP.B	D3,#ICOBLOC1	JUMP',EQ 60$	COMP.B	D3,#ICOBLOC2	JUMP',EQ 60$	COMP.B	D3,#ICOBLOC3	JUMP',EQ 60$	COMP.B	D3,#ICOTEXTE	JUMP,NE LOOP60$:	LOAD.B	D3,#ICOTRAIT	JUMP	OBJETNEW	; utilise l'objet traitOUTILNIL:			; y'a plus d'outil =>	TEST.B	(A6)+OOUTIL	JUMP,EQ LOOP	LOAD.B	D3,(A6)+OOUTIL	CALL	INVICONE	; teint l'ancien outil	CLR.B	(A6)+OOUTIL	JUMP	LOOPOBJETNEW:			; change d'objet =>	COMP.B	D3,(A6)+OOBJET	JUMP',NE 10$	COMP.B	D3,#ICOTEXTE	JUMP,NE LOOP	CLR.B	D3		; D3 <-- refait	JUMP	_TEXTE10$:	COMP.B	D3,#ICOBLOC1	JUMP',LO 20$	COMP.B	D3,#ICOBLOC3	JUMP',HI 20$				; bloc-notes =>	LOAD.L	A4,#(A6)+OBLOC	CLR.W	D4	LOAD.B	D4,D3	SUB.B	D4,#ICOBLOC1	MUL.WU	D4,#LGBLOC	ADD.L	A4,D4		; A4 <-- ^bloc-notes	TEST.L	(A4)+OBLKPT	; bloc-notes contient qq chose ?	JUMP,EQ BIP		; non => BIP20$:	PUSH.W	D3	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; teint l'ancien objet	POP.W	D3	LOAD.B	(A6)+OOBJET,D3	CALL	INVICONE	; allume le nouvel objet	PUSH.W	D3	TEST.B	(A6)+OMODE	; y'a-t-il un mode slectionn ?	JUMP',NE 30$		; oui => 30$	LOAD.B	D3,#ICOSET	CALL	INVICONE	; allume le mode par dfaut	LOAD.B	(A6)+OMODE,D330$:	POP.W	D3	COMP.B	D3,#ICOTEXTE	JUMP,EQ OUTILNIL	COMP.B	D3,#ICOBLOC1	JUMP,EQ OUTILNIL	COMP.B	D3,#ICOBLOC2	JUMP,EQ OUTILNIL	COMP.B	D3,#ICOBLOC3	JUMP,EQ OUTILNIL	LOAD.B	D3,(A6)+OOUTIL	COMP.B	D3,#ICOREMPLI	JUMP',EQ 50$	COMP.B	D3,#ICOSPRAY	JUMP',EQ 50$	COMP.B	D3,#ICOMAIN	JUMP',EQ 50$	COMP.B	D3,#ICOPLOUPE	JUMP',EQ 50$	TEST.B	D3	JUMP,NE LOOP50$:	LOAD.B	D3,#ICOCRAYON	JUMP	OUTILNEW	; utilise l'outil crayonSELECTNEW:	COMP.B	D3,(A6)+OSELECT	JUMP,EQ LOOP	PUSH.W	D3	LOAD.B	D3,(A6)+OSELECT	CALL	INVICONE	; teint l'ancienne slection	POP.W	D3	LOAD.B	(A6)+OSELECT,D3	CALL	INVICONE	; allume la nouvelle slection	JUMP	LOOPPRESSKEY:			; clic icne => touche presse	AND.W	D3,#H'FF	OR.W	D3,#KEYICO	; D3 <-- code "touche" presse	JUMP	EXECUTEOUTIL:	LOAD.B	D3,(A6)+OOUTIL	; D3 <-- outil	COMP.B	D3,#ICOREMPLI	JUMP,EQ REMPLI	COMP.B	D3,#ICOSPRAY	JUMP,EQ SPRAY	COMP.B	D3,#ICOMAIN	JUMP,EQ MAIN	COMP.B	D3,#ICOPLOUPE	JUMP,EQ LOUPE	LOAD.B	D3,(A6)+OOBJET	; D3 <-- objet	COMP.B	D3,#ICOTRAIT	JUMP,EQ TRAIT	COMP.B	D3,#ICOSPLINE	JUMP,EQ SPLINE	COMP.B	D3,#ICODROITE	JUMP,EQ COMMEPLAN	COMP.B	D3,#ICOCERCLE	JUMP,EQ COMMEPLAN	COMP.B	D3,#ICORECTANGLE	JUMP,EQ COMMEPLAN	COMP.B	D3,#ICOTEXTE	JUMP,EQ _TEXTE	COMP.B	D3,#ICOBLOC1	JUMP,EQ BLOCNOTES	COMP.B	D3,#ICOBLOC2	JUMP,EQ BLOCNOTES	COMP.B	D3,#ICOBLOC3	JUMP,EQ BLOCNOTES	JUMP	BIPTRAIT:	LOAD.W	D2,#CLRDOT	COMP.B	(A6)+OMODE,#ICOCLEAR	JUMP',EQ 10$	LOAD.W	D2,#SETDOT10$:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	D5,D3		; D5 <-- origine	CLR.W	D0		; D0 <-- souris pas bouge20$:	CALL	_SCOMO	CALL	WAITMOVE	; attend dplacement souris ...	JUMP,NE 60$		; fin du dplacement => 60$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE 20$	COMP.L	D3,D5		; souris dplace ?	JUMP,EQ 20$		; non => 20$				; oui =>	LOAD.L	D6,D3		; D6 <-- arrive	CALL	DESCOMMEPLAN	; petit: dessine droite de "origine"  "arrive"	TSET.L	D2:#15	CALL	DESCOMMEPLAN	; dessine directement dans la matrice principqle	TCLR.L	D2:#15	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',LE 30$	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim de la droite	CALL	SHOGMATRIX	; grand: dessine aussi la droite30$:	LOAD.L	D5,D6		; D5 <-- future origine	OR.W	D2,#NCTDOT	; D2 <-- plus de rz traitill	INC.W	D0		; D0 <-- souris bouge	JUMP	20$60$:	TEST.W	D0		; souris bouge ?	JUMP',EQ NOIRBLANC	; non => NOIRBLANC				; oui =>	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NC LOOP		; non => LOOP	CALL	DESMATRIX	; oui => redessine la matrice rduite	JUMP	LOOPNOIRBLANC:	LOAD.L	D3,D5		; D3 <-- position	LOAD.W	D2,#INVDOT	LOAD.W	D1,#1	CALL	DESGPOINT	; allume/teint point dans grande matrice	CALL	DESPPOINT	; allume/teint point dans petite matrice	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	CALL	TESTPOINT	TNOT.B	(A1):D1		; allume/teint point dans matrice principale	JUMP	LOOPREMPLI:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	A4,(A6)+OPMAT	CALL	_OPEDISMAT	; dessine dans la matrice principale	LOAD.L	D0,D3	LOAD.L	A4,#(A6)+OTDEF	LOAD.W	D4,(A6)+ONTDEF	MUL.WU	D4,#8	ADD.L	A4,D4		; A4 <-- ^bonne trame	LOAD.L	D3,(A4)+0	LOAD.L	D4,(A4)+4	LIB	?DRMDEF		; dfinit une trame pleine	LOAD.L	D3,D0	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice principale	CALL	TESTPOINT	TEST.B	(A1):D1	JUMP',BS 40$				; point initial teint =>	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3)+0,#AFFILLT	TEST.B	(A6)+ODEF+3:#BDEFFILL	JUMP',BC 30$	LOAD.B	(A3)+0,#AFFILLA30$:	LOAD.B	(A3)+1,#DRAWFILLO	LOAD.L	D3,D0	SWAP.W	D3	LOAD.L	(A3)+2,D3	; <xx> et <yy>	LOAD.B	(A3)+6,#DRAWFILLC	LOAD.W	D3,#1+5+1	LIB	?STRING		; rempli ...	JUMP'	50$40$:				; point initial allum =>	NOT.L	(A0)+ODFTRA+0	NOT.L	(A0)+ODFTRA+4	; inverse la trame !	LOAD.L	A4,(A6)+OPMAT	CALL	_INVALL		; inverse tout	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3)+0,#AFFILLT	TEST.B	(A6)+ODEF+3:#BDEFFILL	JUMP',BC 45$	LOAD.B	(A3)+0,#AFFILLA45$:	LOAD.B	(A3)+1,#DRAWFILLO	LOAD.L	D3,D0	SWAP.W	D3	LOAD.L	(A3)+2,D3	; <xx> et <yy>	LOAD.B	(A3)+6,#DRAWFILLC	LOAD.W	D3,#1+5+1	LIB	?STRING		; rempli ...	PUSH.W	D7	CALL	_INVALL		; inverse tout	POP.W	D750$:	PUSH.W	D7	CALL	_CLODISMAT	; redessine dans l'cran	POP.W	D7	JUMP,NE BIGBIP	CALL	DESMATRIX	; dessine les deux matrices	JUMP	LOOPSPRAY:	LOAD.W	D2,#SETDOT	COMP.B	(A6)+OMODE,#ICOSET	JUMP',EQ 10$	LOAD.W	D2,#CLRDOT10$:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	A4,#R16"00$	JUMP'	28$20$:	CALL	_SCOMO		; remet la souris	LOAD.W	D4,#2	NTREL	?SETTIM		; met timeout trs court	LIB	?GETKEY		; qq chose tout de suite ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	JUMP',EQ 25$		; oui => 25$				; non =>	TEST.L	(A4)		; fin de la table ?	JUMP',EQ 23$		; oui => 23$	LOAD.L	D3,D1		; D3 <-- "centre"	SWAP.W	D3	ADD.W	D3,(A4+)	; D3 <-- dviation en Y	SWAP.W	D3	ADD.W	D3,(A4+)	; D3 <-- dviation en X	JUMP'	30$23$:	LIB	?GETKEY		; attend souris ...25$:	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 50$		; non => 50$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINTF	; D3 <-- point o est la souris	JUMP,NE 20$28$:	LOAD.L	A4,#R16"00$	LOAD.L	D1,D3		; D1 <-- "centre"30$:				; oui =>	LOAD.L	A3,#(A6)+OSDEF	; A3 <-- ^matrice du spray	CALL	DESSPRAY	; dessine selon le spray	JUMP	20$50$:;;?	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?;;?	JUMP,NC LOOP		; non => LOOP;;?	CALL	DESMATRIX	; oui => redessine la matrice rduite	JUMP	LOOP00$:	.W	-2,-3	.W	1,2	.W	1,-1	.W	-3,1	.W	-2,-1	.W	2,0	.W	-1,1	.W	0,-2	.W	-2,1		; 10	.W	-1,-2	.W	0,1	.W	-3,-2	.W	1,-2	.W	-1,0	.W	-2,2	.W	0,-1	.W	-2,0	.W	1,1	.W	-1,-1		; 20	.W	-4,0	.W	2,-3	.W	-1,2	.W	-1,-4	.W	3,-1	.W	-2,-2	.W	-3,2	.W	0,-3	.W	1,3	.W	1,0		; 30	.W	-3,-1	.W	0,-4	.W	2,1	.W	-4,-2	.W	2,-1	.W	-2,3	.W	1,-3	.W	0,2	.W	3,0	.W	-1,3		; 40	.W	2,2	.W	-1,-3	.W	1,-4	.W	0,3	.W	-3,0	.W	2,-2	.W	3,1	.W	-3,-3	.W	-4,1	.W	3,-2		; 50	.W	-2,-4	.W	-4,-1	.W	0,0MAIN:	TEST.W	(A6)+OASVER+OSCHTV	JUMP',NE 10$	TEST.W	(A6)+OASHOR+OSCHTV	JUMP,EQ BIP10$:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	LOAD.L	D2,D3		; D2 <-- rfrence	LOAD.L	D1,(A6)+OGMOVY	LOAD.L	D0,(A6)+OPMOVY	CALL	_SCOMO		; met la main20$:	CALL	_SCMO		; remet la souris	CALL	WAITMOVE	; attend dplacement souris ...	JUMP,NE 50$		; fin du dplacement => 50$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	PUSH.L	(A6)+OGMOVY	PUSH.L	(A6)+OPMOVY	LOAD.L	(A6)+OGMOVY,D1	LOAD.L	(A6)+OPMOVY,D0	CALL	DETGPOINTOUT	; D3 <-- point o est la souris	POP.L	(A6)+OPMOVY	POP.L	(A6)+OGMOVY	TEST.W	D7	JUMP,NE 20$	LOAD.W	D5,(A6)+OASVER+OSCHTV	JUMP',EQ 25$	DEC.W	D525$:	SWAP.W	D5	LOAD.W	D5,(A6)+OASHOR+OSCHTV	JUMP',EQ 26$	DEC.W	D526$:	LOAD.L	D4,D1	ADD.W	D4,D2	SUB.W	D4,D3	JUMP',NC 30$	CLR.W	D430$:	COMP.W	D4,D5	JUMP',LS 31$	LOAD.W	D4,D531$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	ADD.W	D4,D2	SUB.W	D4,D3	JUMP',NC 32$	CLR.W	D432$:	COMP.W	D4,D5	JUMP',LS 33$	LOAD.W	D4,D533$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	COMP.L	D4,(A6)+OGMOVY	JUMP,EQ 20$	LOAD.L	(A6)+OGMOVY,D4	LOAD.L	D4,D0	ADD.W	D4,D2	SUB.W	D4,D3	JUMP',NC 34$	CLR.W	D434$:	COMP.W	D4,D5	JUMP',LS 35$	LOAD.W	D4,D535$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	ADD.W	D4,D2	SUB.W	D4,D3	JUMP',NC 36$	CLR.W	D436$:	COMP.W	D4,D5	JUMP',LS 37$	LOAD.W	D4,D537$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	LOAD.L	(A6)+OPMOVY,D4	CALL	DESPMATRIX	; dessine la petite matrice	CALL	DESGMATRIX	; dessine la grande matrice	JUMP	20$50$:	CALL	MAJCADRE	; met  jour ascenseurs et rgles	JUMP	LOOPLOUPE:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINTF	JUMP,NE BIP	LOAD.L	(A6)+OPMOVY,D3	CLR.L	(A6)+OPMDIY	LOAD.B	D3,#ICOPLOUPE	CALL	INVICONE	; teint la loupe	LOAD.B	(A6)+OOUTIL,(A6)+OLOUTIL	LOAD.B	(A6)+OMODE,(A6)+OLMODE	LOAD.B	(A6)+OOBJET,(A6)+OLOBJET	LOAD.B	D3,(A6)+OOUTIL	CALL	INVICONE	; allume le nouvel outil	LOAD.B	D3,(A6)+OMODE	CALL	INVICONE	; allume le nouveau mode	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; allume le nouvel objet	CLR.B	(A6)+OLOUTIL	CLR.B	(A6)+OLMODE	CLR.B	(A6)+OLOBJET	LOAD.W	D4,#SCALELOUPE	CALL	CALSCALE	CALL	DESCADRE	CALL	DESLOUPE	; dessine les jumelles	CALL	DESMATRIX	; dessine les deux matrices	JUMP	LOOP		; prononcez "loupe", ha ha ha !COMMEPLAN:	LOAD.W	D0,#CLRDOT	COMP.B	(A6)+OMODE,#ICOCLEAR	JUMP',EQ 10$	LOAD.W	D0,#SETDOT10$:	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DETGPOINT	; D3 <-- point o est la souris	JUMP,NE BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	D5,D3		; D5 <-- origine fixe	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE 30$	COMP.B	(A6)+OOBJET,#ICODROITE	JUMP',NE 30$	CALL	_CCMO		; enlve la souris	JUMP'	30$20$:	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE 22$	COMP.B	(A6)+OOBJET,#ICODROITE	JUMP',EQ 23$22$:	CALL	_SCOMO		; remet la souris23$:	CALL	DESINFCP	; affiche L= et H=24$:	CALL	WAITMOVES	; attend dplacement souris ...	JUMP,NE 50$		; fin du dplacement => 50$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 24$	CALL	_RGMOUSE	; dessine la position dans les rgles	CALL	DETGPOINTOUT	; D3 <-- point o est la souris	CALL	PASGPOINT	; D3 <-- tient compte du pas	COMP.L	D3,D6		; souris dplace ?	JUMP,EQ 24$		; non => 24$				; oui =>	PUSH.L	D3	LOAD.L	D3,D1		; D3 <-- ancienne pos	LOAD.L	D4,D2		; D4 <-- ancienne dim	LOAD.W	D2,D0		; D2 <-- mode de dessin	CALL	MOVGMATRIX	; grand: efface dernier droite/cercle/etc.	LOAD.W	D2,#INVDOT	CALL	DESCOMMEPLAN	; petit: efface dernier droite/cercle/etc.	POP.L	D330$:	CALL	SCROLLPOIGNEE	; dplace v. la partie visible	LOAD.L	D6,D3		; D6 <-- nouvelle arrive	LOAD.W	D2,#INVDOT	CALL	DESCOMMEPLAN	; petit: dessine nouveau droite/cercle/etc.	LOAD.W	D2,D0		; D2 <-- mode de dessin	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim objet	CALL	MOVGMATRIX	; grand: dessine nouveau droite/cercle/etc.	LOAD.L	D1,D3		; D1 <-- pos	LOAD.L	D2,D4		; D2 <-- dim	JUMP	20$50$:	COMP.L	D5,D6		; souris bouge ?	JUMP,EQ NOIRBLANC	; non => NOIRBLANC				; oui =>	LOAD.L	D3,D1		; D3 <-- ancienne pos	LOAD.L	D4,D2		; D4 <-- ancienne dim	LOAD.W	D2,D0		; D2 <-- mode de dessin	CALL	MOVGMATRIX	; grand: efface dernier droite/cercle/etc.	LOAD.W	D2,#INVDOT	CALL	DESCOMMEPLAN	; petit: efface dernier droite/cercle/etc.	LOAD.W	D2,D0	TSET.L	D2:#15		; D2 <-- dessine dans la matrice principale	CALL	DESCOMMEPLAN	; petit: dessine droite/cercle dfinitif	CALL	DIMCOMMEPLAN	; D3/D4 <-- pos/dim objet	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D1,D3	LOAD.L	D2,D4	LOAD.L	D5,D3	LOAD.L	D6,D4	LOAD.L	A4,(A6)+OPMAT	LOAD.W	D0,#LOADDOT	CALL	BBPGMATRIX	; affiche  l'cran (v. dans les deux fentres)	CALL	MAJREGLE	; met  jour les rgles	JUMP	LOOPBLOCNOTES:	LOAD.L	A5,#(A6)+OBLOC	CLR.W	D3	LOAD.B	D3,(A6)+OOBJET	SUB.B	D3,#ICOBLOC1	MUL.WU	D3,#LGBLOC	ADD.L	A5,D3		; A5 <-- ^bloc-notes	TEST.L	(A5)+OBLKPT	; bloc-notes contient qq chose ?	JUMP,EQ BIP		; non => BIP	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	D1,(A5)+OBLKP1	; D1 <-- P1(y;x)	LOAD.L	D2,(A5)+OBLKP2	; D2 <-- P2(y;x)	CALL	POSDIM		; D1 <-- pos et D2 <-- dim	COMP.W	D2,(A6)+OMALMX	JUMP,HS BIP	SWAP.W	D2	COMP.W	D2,(A6)+OMALMY	JUMP,HS BIP	SWAP.W	D2	LOAD.W	(A6)+OMANBS,(A5)+OBLKNBB	LOAD.W	(A6)+OMANBD,(A6)+OMANBB	LOAD.L	A3,(A5)+OBLKPT	; A3 <-- ^matrice source	LOAD.L	D3,D1	LOAD.L	A4,(A6)+OPMAM	; A4 <-- ^matrice destination	CLR.L	D4	LOAD.L	D5,D2		; D5 <-- dimensions	CALL	_CLEARALL	; matrice masque <-- vide	LOAD.W	D2,#SETDOT	CALL	_XFERZONESD	; matrice masque <-- contenu du bloc-notes	LOAD.L	D6,D5	CLR.L	D5	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	CALL	DETGPOINT	JUMP,NE BIP	LOAD.L	D1,D3	LOAD.L	D2,D3	ADD.W	D1,D6	LOAD.W	D3,D1	SUB.W	D3,(A6)+OMALMX	JUMP',LO 60$	SUB.W	D1,D3	SUB.W	D2,D360$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D6	ADD.W	D1,D6	LOAD.W	D3,D1	SUB.W	D3,(A6)+OMALMY	JUMP',LO 62$	SUB.W	D1,D3	SUB.W	D2,D362$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D6	CLR.L	D0	LOAD.B	(A6)+ODDOP,(A6)+OOBJET	JUMP	ZONEMOVEMODIFDEF:	CALL	_DBOXDEF	JUMP,NE ERROR	JUMP	LOOPMODIFZOOM:	CALL	_DBOXZOOM	JUMP,NE ERROR	JUMP	LOOPMODIFPDEF:	CALL	_DBOXPDEF	JUMP,NE ERROR	CALL	DESPDEF	LOAD.B	D3,#ICOPINCEAU	JUMP	OUTILNEW	; utilise le pinceauMODIFTDEF:	CALL	_DBOXTDEF	JUMP,NE ERROR	CALL	DESTDEF		; dessine l'icne de la trame	TEST.B	(A6)+OTRECT:#BRETRAM	JUMP',BC 20$	CALL	DESRDEF		; dessine l'icne du rectangle20$:	LOAD.B	D3,(A6)+OOUTIL	COMP.B	D3,#ICOREMPLI	JUMP,EQ LOOP	COMP.B	D3,#ICOSPRAY	JUMP,EQ LOOP	COMP.B	(A6)+OOBJET,#ICORECTANGLE	JUMP',NE 40$	TEST.B	(A6)+OTRECT:#BRETRAM	JUMP,BS LOOP40$:	LOAD.B	D3,#ICOREMPLI	JUMP	OUTILNEW	; utilise le bidon de peintureMODIFRDEF:	CALL	_DBOXRDEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	CALL	DESRDEF		; dessine l'icne du rectangle	LOAD.B	D3,#ICORECTANGLE	JUMP	OBJETNEW	; objet rectangleMODIFADEF:	CALL	_DBOXADEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	CALL	DESADEF		; dessine l'icne du cercle	LOAD.B	D3,#ICOCERCLE	JUMP	OBJETNEW	; objet cercleREGLE:	CALL	_CCMO		; enlve la souris	NOT.B	(A6)+OREGLE	; met/enlve les rgles	CALL	CALCADRE	LOAD.W	D4,(A6)+OSCALE	CALL	CALSCALE	CALL	DESCADRE	CALL	DESMATRIX	; redessine toutes les matrices	JUMP	LOOPNEGATIF:	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	A4,(A6)+OPMAT	CALL	_INVALL		; inverse toute la matrice	CALL	DESMATRIX	; dessine toutes les matrices	JUMP	LOOPEFFACE:	CALL	_DBOXEFFACE	; Voulez-vous effacer ?	COMP.W	D3,#F1	JUMP,NE LOOPEFFACEI:	CALL	_COPYALL	; fait une copie de la matrice	LOAD.L	A4,(A6)+OPMAT	CALL	_CLEARALL	; efface toute la matrice	CALL	DESMATRIX	; dessine toutes les matrices	LOAD.L	A3,#(A6)+OBUFIN	CLR.B	(A3)	CALL	SAVFILE		; OBUNAME <-- plus de nom	CALL	DESINFFILE	; le dessin n'a plus de nom !	CLR.B	(A6)+OMAJ	; le dessin est  jour	LOAD.L	A3,(A6)+OPMAT	LOAD.L	A4,#(A6)+OBLOC	LOAD.W	D4,#NBBLOC-140$:	COMP.L	A3,(A4)+OBLKPT	; bloc-notes dans cette zone ?	JUMP',NE 45$		; non => 45$	CLR.L	(A4)+OBLKPT	; vide ce bloc-notes !45$:	LOAD.L	A4,#(A4)+LGBLOC	; A4 <-- ^bloc-notes suivant	DECJ.W,NMO D4,40$	JUMP	LOOPSCALE:	CALL	DOSCALE		; change d'chelle	JUMP,NE BIP	JUMP	LOOPMENUZONE:	LOAD.B	D3,#ICOVZONE	CALL	INVALLICONE	; allume l'icne de la zone	CALL	CMZONE		; A3 <-- ^mmenu	CLR.L	D4	LOAD.W	D3,(A6)+ONOZO	INC.W	D3	TSET.L	D4:D3		; D4 <-- zone visible en gris	LOAD.W	D3,#2^15	; D3 <-- utilise D4.L en entre	LOAD.L	A4,#0		; A4 <-- pas de dernire case	CALL	_MMENU		; attend selon mmenu ...	PUSHM.L	D3,D7	LOAD.B	D3,#ICOVZONE	CALL	INVALLICONE	; teint l'icne de la zone	POPM.L	D3,D7	TEST.W	D7	JUMP,NE BIP	DEC.W	D3		; D3 <-- 0..9	JUMP,NS LOOP	JUMP'	XZONESHOWZONE:	AND.W	D3,#H'00FF	SUB.B	D3,#'0		; D3 <-- 0..9	DEC.B	D3	JUMP',NC 20$	LOAD.B	D3,#NBZONE-120$:	COMP.W	D3,(A6)+ONOZO	; est-ce une autre zone ?	JUMP,EQ BIP		; non => BIPXZONE:	LOAD.W	D4,(A6)+OSCALE	CALL	NEWZONE		; utilise une nouvelle zone	JUMP,NE ERROR	CALL	DESZONE		; dessine l'icne de la zone	LOAD.W	D3,D4		; D3 <-- ancienne chelle	LOAD.W	D4,(A6)+OSCALE	; D4 <-- nouvelle chelle	LOAD.W	(A6)+OSCALE,D3	CALL	ICOSCALE	; allume/teint qq icnes	LOAD.W	(A6)+OSCALE,D4	CALL	DESINFFILE	; affiche le nom du dessin;	LOAD.W	D4,(A6)+OSCALE	CALL	CALSCALE	CALL	DESCADRE	; redessine le cadre	CALL	DESMATRIX	; redessine toutes les matrices	JUMP	LOOPMENUFLAGS:	CALL	_DBOXFLAGS	; change le mode ...	JUMP,NE ERROR	JUMP	LOOPDOHELP:	CLR.W	D3	CALL	_SELMO		; utilise la flche	LOAD.B	(A6)+OXICO,#NIVHELP	CALL	_AFMENU		; refait les soft-keys	CLR.W	D210$:	LOAD.L	A3,#R16"THELP1	TEST.W	D2	JUMP',EQ 20$	LOAD.L	A3,#R16"THELP220$:	CALL	_WAITMOUSE	; met le sablier	CALL	_AFIMAGE	; affiche l'image d'aide	JUMP,NE 80$	CALL	_NORMMOUSE	; enlve le sablier30$:	LIB	?GETCAR		; attend une touche ...	COMP.W	D3,#F0+SHIFT	JUMP',LO 35$	COMP.W	D3,#F15+SHIFT	JUMP',HI 35$	SUB.W	D3,#SHIFT35$:	COMP.W	D3,#KEYMGR	JUMP,EQ 30$	COMP.W	D3,#KEYMMR	JUMP,EQ 30$	COMP.W	D3,#KEYMDR	JUMP,EQ 30$	CLR.W	D7		; D7 <-- ok	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#END	JUMP,EQ 80$	COMP.W	D3,#F1	JUMP',EQ 50$	COMP.W	D3,#F2	JUMP',EQ 50$	COMP.W	D3,#F3	JUMP',EQ 50$	COMP.W	D3,#SPACE	JUMP',EQ 50$	COMP.W	D3,#CR	JUMP',EQ 50$	COMP.W	D3,#HELP	JUMP',EQ 50$	COMP.W	D3,#KEYMGP	JUMP',EQ 50$	COMP.W	D3,#KEYMMP	JUMP',EQ 50$	COMP.W	D3,#KEYMDP	JUMP',EQ 50$	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	30$50$:	INC.W	D2		; D2 <-- image suivante	COMP.W	D2,#2	JUMP,LO 10$	CLR.W	D2	JUMP	10$80$:	PUSH.W	D7	CLR.B	(A6)+OXICO	CALL	DESWDO	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CALL	_AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE ERROR	JUMP	LOOPEXUNDO:	CALL	_UNDOALL	; rcupre tout !REFAIT:	CALL	DESMATRIX	; redessine toutes les matrices	JUMP	LOOPBIP:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPBIGBIP:				; erreur =>	LOAD.B	D3,#BIPERR	LIB	?BEEP		; grand bruit	JUMP	LOOPERROR:	PUSH.W	D7	CLR.B	D3	CALL	_SELMO		; outil = flche	CALL	_SCMO		; remet la flche	CALL	_NORMMOUSE	; remet la flche	POP.W	D7	TEST.W	D7	JUMP,EQ LOOP	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	_AFMENU		; refait les soft-keys	JUMP	LOOPFINI:	LOAD.W	D3,(A6)+ONOZO	; D3 <-- zone actuelle	CALL	CLOZONE		; sauve la zone actuelle	LOAD.W	D4,D3		; D4 <-- zone actuelle	CLR.W	D3		; D3 <-- premire zone  sauver20$:	CALL	OPEZONE		; prend une zone	LOAD.W	(A6)+ONOZO,D3	CLR.W	D0		; D0 <-- avant de quitter	CALL	_DBOXSAVE	; sauve si ncessaire avant de quitter	JUMP',EQ 50$		; ok => 50$	COMP.W	D7,#1		; (ANNULE) ?	JUMP',EQ 80$		; oui => 80$				; erreur =>	PUSH.W	D7	LOAD.W	D3,D4	CALL	OPEZONE		; reprend la zone initiale	LOAD.W	(A6)+ONOZO,D3	POP.W	D7	JUMP	ERROR50$:	INC.W	D3		; D3 <-- numro zone suivante	COMP.W	D3,#NBZONE	JUMP,LO 20$	CALL	_DBOXQUITTE	; demande s'il faut quitter ...	COMP.W	D3,#F1	JUMP',EQ ERFAT80$:	LOAD.W	D3,D4	CALL	OPEZONE		; reprend la zone initiale	LOAD.W	(A6)+ONOZO,D3	JUMP	LOOPERFAT:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDGENC	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDESSIN	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDESS2	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHCOUPE	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSPLINE	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSTRETCH	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHICOLOR	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHBLOC	JUMP',EQ 40$	BLOC_	CLOSE		; fermeture globale	JUMP',NE 40$	LIB_	CLOSE40$:	TEST.L	(A6)+OCAPRINT	JUMP',EQ 50$	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	CLOSE	LOAD.W	D1,(A6)+OCHPRINTA	LIB_	CLOSE50$:	TEST.L	(A6)+OCASCAN	JUMP',EQ 60$	LOAD.L	D6,(A6)+OCASCAN	SCAN_	CLOSE	LOAD.W	D1,(A6)+OCHSCAN	LIB_	CLOSE60$:ERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	DESDROITE.ASI	.INS	DESSELECT.ASI	.INS	DESMATH.ASI	.INS	DESGRA.ASI	.INS	DESSPLINE.ASI	.INS	DESOPER.ASI	.INS	DESMATRIX.ASI_WAITMOUSE:	JUMP	WAITMOUSE_NORMMOUSE:	JUMP	NORMMOUSE_SCMO:		JUMP	SCMO_CCMO:		JUMP	CCMO_SCOMO:		JUMP	SCOMO_SELMO:		JUMP	SELMO_AFMENU:	JUMP	AFMENU_IFMOUSE:	JUMP	IFMOUSE_OPEDISMAT:	JUMP	OPEDISMAT_CLODISMAT:	JUMP	CLODISMAT_DEFGENCAR:	JUMP	DEFGENCAR_TEXTE:		JUMP	TEXTE_INVALL:	JUMP	INVALL_COPYALL:	JUMP	COPYALL_COPYZALL:	JUMP	COPYZALL_RGMOUSE:	JUMP	RGMOUSE_AFIMAGE:	JUMP	AFIMAGE_CLEARALL:	JUMP	CLEARALL_SETALL:	JUMP	SETALL_XFERZONE:	JUMP	XFERZONE_XFERZONESD:	JUMP	XFERZONESD_MMENU:		JUMP	MMENU_MMENUS:	JUMP	MMENUS_PMOUSE:	JUMP	PMOUSE_UNDOALL:	JUMP	UNDOALL_DRMDEF:	JUMP	DRMDEF_XFERALL:	JUMP	XFERALL_BOLDALL:	JUMP	BOLDALL_DBOXDEF:	JUMP	DBOXDEF_DBOXZOOM:	JUMP	DBOXZOOM_DBOXPDEF:	JUMP	DBOXPDEF_DBOXTDEF:	JUMP	DBOXTDEF_DBOXRDEF:	JUMP	DBOXRDEF_DBOXADEF:	JUMP	DBOXADEF_DBOXEFFACE:	JUMP	DBOXEFFACE_DBOXFLAGS:	JUMP	DBOXFLAGS_DBOXSAVE:	JUMP	DBOXSAVE_DBOXQUITTE:	JUMP	DBOXQUITTE_DBOXCOLOR:	JUMP	DBOXCOLOR_GETMEMMATRIX:	JUMP	GETMEMMATRIX_RDSTPRINT:	JUMP	RDSTPRINT_SAUVE:		JUMP	SAUVE_PREND:		JUMP	PREND_AJOUTE:	JUMP	AJOUTE_IMPRIME:	JUMP	IMPRIME_SCAN:		JUMP	SCAN_COLLE:		JUMP	COLLE_COPIE:		JUMP	COPIE_COUPE:		JUMP	COUPE_CLASSEUR:	JUMP	CLASSEUR_LOOP:		JUMP	LOOP_ERROR:		JUMP	ERROR_BIP:		JUMP	BIP_WAITMOVE:	JUMP	WAITMOVE_WAITMOVES:	JUMP	WAITMOVES_WAITPRESS:	JUMP	WAITPRESS_D1SCALEN:	JUMP	D1SCALEN_D1SCALEP:	JUMP	D1SCALEP_INVPOIGNEE:	JUMP	INVPOIGNEE_SCROLLIPOIGNEE: JUMP	SCROLLIPOIGNEE_ERFAT:		JUMP	ERFAT_GETTCOUL:	JUMP	GETTCOUL_EFFACEI:	JUMP	EFFACEI	.INS	DESCADRE.ASI	.INS	DESICONE.ASI	.INS	DESIO.ASI	.INS	DESZONE.ASI	.INS	DESDBOX.ASI	.INS	DESDBOXT.ASI	.INS	DESGENC.ASI	.INS	DESAFTEXT.ASI	.INS	DESMISC.ASI	.INS	DESTAB2.ASI	.END	START