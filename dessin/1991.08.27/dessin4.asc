	.TITLE	DESSIN4.ASC;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------;	Source du programme DESSIN;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 4.8	25.01.91	version avec couper/copier/coller ...; 4.7	12.11.90	version pour SMAKY-300; 4.6	10.04.90	filet: meilleur remplissage; 4.5	29.11.89	utilise le module SCAN; 4.4	10.04.89	tourne: plus de dformation si 90 degrs (problme avec STRETCH);			si chelle n:1 => dplacement page ascenseur plus petit;			jusqu' 800 gencars sur disque (300 anciennement); 4.3	28.03.89	zoom: largeur image toujours modulo 8 !;			HELP: inversion image ok;			droite: ok si zone nulle puis stretch; 4.2	02.05.88	df: remplissage jusque dans les bords;			OMANBB toujours multiple de 2 (1 word = 16 points); 4.1	31.03.88	cercle: affiche le rayon correctement et l'angle;			mmenus: hirarchiques ...; 4.0e	15.03.88	habillage: largeur max = 4000 points;			menu de droite: divers --> sous-menu avec contour/trame/lisse;			nouveau module SMA_DESSIN2.LIB;			lisse: nouvelle opration ...;			cercle: triangle/carr/pentagone/hexagone/octogone/dcagone;			cercle: arc quelconque; 4.0d	09.03.88	trame: nouvelle opration ...; 4.0c			cercle: si par le rayon => rayon exact (r^2 = x^2 + y^2);			cercle: par le diamtre;			sauve partiel: ok si 1:n;			texte/bloc-notes/ajoute: souris avec jolie icne;			zoom, tourne, miroir, dforme: changement d'chelle possible;			trait, rectangle, etc.: de nouveau ok avec un pas > 1;			icnes de gauches: grises si ncessaire;			mmenus: ".." et indication si maintenir press;			loupe: agit vraiment comme un outil !; 4.0b			DESSIN.CODE --> DESSIN4.CODE;			relief: icnes  gauche avec redfinitions ...;			utilise PRINTA/PRINTB; 4.0a	01.01.88	ajoute: ok mme si tout;			en haut: affiche le pas (P=1 .. P=32);			en haut: si nom de l'image trop long => affiche la fin;			dition de pavs de textes ...;			spline, texte, image:          sous-menu --> icnes  gauche;			zoom, tourne, miroir, dforme: sous-menu --> icnes  gauche;			zoom, tourne, miroir, dforme: icne "dplace";			zoom: icne "homothtie";			tourne: icnes 10, 20, 30, 45, 60, 90 degrs;			zoom, tourne, miroir, dforme, spline: ascenseurs utilisables;			zoom, tourne, miroir, dforme: scroll si l'on dpasse;			slection avec bouton de droite: scroll si l'on dpasse;			dessin droite, rectangle, cercle: scroll si l'on dpasse;			dessin droite, rectangle, cercle: fait directement dans la matrice;			rectangle: pourtour+trame et transparent/opaque;			cercle: cercle/ellipse;			si grand cran => possibilit de dplacer les icnes de gauche;			dplace/duplique: si chelle n:1 => rectangle traitill fin;			tout est possible si 1:n (tout): dessin, modifications, etc,; 3.5			si grand cran => icnes de gauche cales en bas;			dicar: "ajoute image" libre bien la mmoire; 3.4			df: option "zoom gnral" ne dforme plus (homothtie);			mise  niveau pour EDICAR ...; 3.3			F2 = Ajoute (et plus Modif);			utilisation de DBOX_ERCALL pour les appels FOS;			utilisation de LIB ?GETSHIFT;			utilisation de DBOX_PREND,AJOUTE,SAUVE,MAJ,QUITTE,etc.;			F0 demande s'il faut quitter;			vrifie la rvision du systme avec LIB,?GETREV;			F5 = Zoom (nouvelle fonction);			df: option "zoom gnral";			dplace: ne laisse plus de traines sur fond blanc !;			sauve (bouton de droite) => dessin toujours  jour; 3.2			(N)/(G): icne du crayon/pinceau change;			boulette avec GESMEM corrige;			raccourcis clavier: (C) = crayon, (P) = pinceau, etc.;			(SHOW-flches): dplace les ascenseurs;			HELP avec deux images;			df: mmorise la dernire case (mmenu);			jusqu' 300 gencars sur disque (150 anciennement); 3.1			dplace/duplique: ok sur SMAKY8;			df: utilise les icnes (si non => bouton du milieu);			df: utilise les ascenseurs; 3.0	01.06.87	si "tout" puis "loupe" => plus de Zero DIV !;			miroir: horizontal <--> vertical;			10 pages de travail !;			(SHOW-1..0) => visualisation directe;			nouvelle icne "page" en haut  gauche;			filet: ok avec traits fins;			crochet: sablier pendant recherche (remplissage);			changements de lutins plus rapides (SETPRIO #1);			bouton de droite: entoure puis (1), (2) ou (3) => met dans bloc-notes;			(1), (2) ou (3) => slectionne un bloc-notes;			zoom: option "autre...";			tourne: option "autre...";			bouton de droite: nouvelle opration "dforme" !;			bouton de droite: COPY-clic => reprend ancienne slection;			spline: poignes carres (comme dformations);			miroir: 2 oprations "diagonale" nouvelles;			main: nouvel outil !;			pas: nouveau mode avec 1, 2, 4, 8, 16 ou 32;			dplace/duplique: choix du mode (opaque, transparent, etc.);			dplace/duplique: dplacement sans  coup !;			dplace/duplique: scroll automatique si souris dpasse;			ascenseurs: dplacements par 4 points et par crans;			ascenseurs: dplacements rapide si bouton maintenu press; 2.4			EDICAR: transformation /2 possible; 2.3			EDICAR lit des SMA_ par dfaut;			affiche des XXXX dans les clefs des noms; 2.2			EDICAR ne se prend plus pour un auteur !; 2.1	01.11.86	rgles gradues en mm;			Df: cases (ECRAN) et (PAGE);			Df: units "points" ou "millimtres";			utilise le module DESSIN; 2.0			(F13) = fonction "tout" (zoom -2, -4 ou -8);			Sauve: sauve les pinceaux et les trames ?;			pinceau/gomme: la souris ne fait plus la croix; 1.6			cre les fichiers .DDES sans l'attribut "L";			i/o: fichiers .image cods;			help: accepte aussi les images codes; 1.5			nom dans ligne de commande (pour START);			HELP charge les images avec BOPSYS; 1.4			dessin: ok dans bitmap 1000x1000 (enfin ?); 1.3	01.05.86	edicar: permet de prendre "xyz_trp14";			dessin: ok dans bitmap 1000x1000; 1.2			( <-- ) identique  (UNDO);			edicar: dcalages dans les 4 directions ok; 1.1			nouvelles icnes pour pinceau et rempli;			spray: gicle mme sans bouger (gaz propulseur);			rempli: s'effectue en mmoire (invisible);			rempli: le travail est invisible;			rempli: en loupe, possible mme si trs grand;			rempli: possible sur du noir !;			contour: opration "ombr";			filet ( papillons) !;			crochet;			loupe: reste allume si chelle autre que 1:1;			ajoute: on peut appuyer sur AJOUTE puis dplacer;			ajoute: ok si grand dessin dcal vers la droite;			bloc-notes: mise dans un bloc-notes le slectionne;			HELP affiche le fichier dessin_h.image;			clic souris sans bouger inverse point avec tous les objets;			spline;			loupe: dessin "comme plan" beaucoup plus rapide;			gencar: au dmarrage, laisse 30k libre; 1.0	13.01.86	premire version distribue	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	SCAN	.REF	ICOLOR	.REF	BLOC;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;GRA_CRASTER = H'A899		; raster-op couleurGRA_GDOT = H'A89A		; get-dotBSRCCOUL = 11BDSTCOUL = 12;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;DESREV	=	4		; rvisionDESVERS	=	8		; version;DESPROV=	'a		; rvision.version provisoireDESPROV=	SPACE		; rvision.version dfinitive	.REV	DESREV,DESVERS	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------MARGX	=	16		; marge en XMARGY	=	12		; marge en YSCALE11	=	1		; chelle 1:1SCALEMIN=	5		; chelle minimaleSCALELOUPE=	8		; chelle pour la loupe par dfautSCALEMAX=	16		; chelle maximaleMAXSPLINE=	20+2		; nb max points pour splineDPOIGNEE=	5		; dimension d'une poigneMAXREL	=	50		; nb max d'oprations pour "relief"MAXDEF	=	4*7		; nb max de trames/pinceauxMAXGENC	=	800		; nb max de gencar sur disqueLBUDIS	=	400		; lg max de OBUDISLBUFILE	=	50		; lg max d'un nom de fichierMAXTEXT	=	10000		; lg max d'un pav de texteLBUMOT	=	50		; lg max d'un motLBUCOUP	=	50		; nb max de coupures dans un motLBLTEXT