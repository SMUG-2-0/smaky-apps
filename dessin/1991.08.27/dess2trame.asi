	.SBTTL	DESS2TRAME;-------------\\; _DESS2_TRAME >;=============/; Transfert une zone rectangulaire source dans une zone rectangulaire destination; de mmes dimensions, en effectuant un tramage.; in	A0.L	^descripteur de la fentre;	----;	A3.L	^bitmap source;	D5.L	dimensions bitmap (dy;dx);	D3.L	origine source (y;x);	----;	A4.L	^bitmap destination;	D6.L	dimensions bitmap (dy;dx);	D4.L	origine destination (y;x);	----;	D2.L	dimensions (dy;dx);	D1.L	mode: | bits | luminosit | niveaux | pas |;		 luminosit: -10..+10;		 niveaux: 2..16;		 pas: 2..10;	A2.L	^famille de 17 trames (de 8 bytes);	----; out	D7.W	erreur; mod	D7.W_DESS2_TRAME:	PUSHM.L	D0..D5,A4,A6	CALL	OPEVOP		; A6 <-- ^variables	JUMP,NE 90$	LOAD.L	(A6)+OOPPTR,A2	; OOPPTR <-- ^trames	LOAD.L	D3,(A6)+OOPORS	; D3 <-- origine source	LOAD.L	D2,(A6)+OOPORD	; D2 <-- origine destination	CLR.L	D4	LOAD.B	D4,(A6)+OOPMOD+3 ; D4 <-- pas	SWAP.W	D4	LOAD.B	D4,(A6)+OOPMOD+3 ; D4 <-- pas	LOAD.L	D5,(A6)+OOPDIM	; D5 <-- dimensions20$:	PUSHM.L	D2,D3,D522$:	CALL	TRAMENB		; D2 <-- nb de points contenus	CALL	TRAMETR		; trame en consquence	ADD.W	D2,D4		; D2 <-- gros point suivant en X	ADD.W	D3,D4		; D3 <-- gros point suivant en X	SUB.W	D5,D4	JUMP,GT 22$	POPM.L	D2,D3,D5	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	ADD.W	D2,D4		; D2 <-- gros point suivant en Y	ADD.W	D3,D4		; D3 <-- gros point suivant en Y	SUB.W	D5,D4	PUSH.W	F	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	POP.W	F	JUMP,GT 20$	CLR.W	D7		; D7 <-- ok80$:	CALL	CLOVOP		; libre les variables90$:	POPM.L	D0..D5,A4,A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; TRAMENB >;--------/; Compte le nombre de points contenus dans une zone carre du bitmap source.; in	D3.L	coordonne (y;x);	D4.L	dimensions o compter (dy;dx); out	D1.W	nb de points contenus (0..dx*dy); mod	D1.L, D7.WTRAMENB:	PUSHM.L	D0,D2,D3,D4,A1	LOAD.L	A1,(A6)+OOPPTS	; A1 <-- ^bitmap source	LOAD.L	D1,D3		; D3 <-- position en X	SWAP.W	D1		; D1 <-- position en Y	MUL.WU	D1,(A6)+OOPIYS	LOAD.B	D2,D3	NOT.B	D2		; D2 <-- bit 2^7  gauche !	AND.B	D2,#B'111	; D2 <-- no du bit dans le byte	SR.W	D3,#3	ADD.W	A1,D3	ADD.L	A1,D1		; A1 <-- ^byte	CLR.W	D1		; D1 <-- nb de points contenus20$:	PUSHM.L	D2,D4,A1	DEC.W	D4		; D4 <--  cause NMO	LOAD.B	D0,(A1+)30$:	TEST.L	D0:D2		; point allum ?	JUMP',BC 32$		; non => 32$	INC.W	D1		; D1 <-- un point de plus32$:	DEC.B	D2	JUMP',NC 34$	LOAD.B	D2,#7	LOAD.B	D0,(A1+)34$:	DECJ.W,NMO D4,30$	POPM.L	D2,D4,A1	ADD.W	A1,(A6)+OOPIYS	; A1 <-- ^byte en dessous	SWAP.W	D4	DEC.W	D4	LOAD.W	D0,D4	SWAP.W	D4	TEST.W	D0	JUMP,NE 20$	POPM.L	D0,D2,D3,D4,A1	RET;--------\\; TRAMETR >;--------/; Trame quelques points dans une zone carre.; in	D1.W	nb de points contenus;	D2.L	coordonne (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WTRAMETR:	PUSHM.L	D1..D6,A1..A4	LOAD.L	D3,D2		; D3 <-- coordonne	LOAD.L	D2,D4	SWAP.W	D2	MUL.WU	D2,D4		; D2 <-- dx * dy	MUL.WU	D1,#16	DIV.WU	D1,D2		; D1 <-- 0..16	LOAD.L	D2,#16	CLR.W	D5	LOAD.B	D5,(A6)+OOPMOD+2 ; D5 <-- niveaux (2..16)	DIV.WU	D2,D5		; D2 <-- 1,2,4,8	AND.L	D1,#H'FFFF	DIV.WU	D1,D2	MUL.WU	D1,D2	TEST.W	D1		; tout blanc ?	JUMP',EQ 25$	COMP.W	D1,#16		; tout noir ?	JUMP',EQ 25$	LOAD.B	D5,(A6)+OOPMOD+1 ; D5 <-- luminosit	CONV.WA.BA D5	SUB.W	D1,D5		; D1 <-- tient compte de la luminosit	JUMP',NC 20$	CLR.W	D120$:	COMP.W	D1,#16	JUMP',LS 25$	LOAD.W	D1,#1625$:	LOAD.L	A3,(A6)+OOPPTR	; A3 <-- ^trames	MUL.WU	D1,#8	ADD.L	A3,D1		; A3 <-- ^source (trame)	TEST.L	(A3)+0	JUMP',NE 40$	TEST.L	(A3)+4		; trame toute vide ?	JUMP,EQ 90$		; oui => 90$40$:	LOAD.L	A4,(A6)+OOPPTD	; A4 <-- ^destination	LOAD.L	D2,D4		; D2 <-- dimensions (dy;dx)	LOAD.L	D4,D3		; D4 <-- coordonne destination; Rpte v. plusieurs fois le motif de la trame avec le raster-op.; Il n'est pas possible d'utiliser les trames  cause de l'alignement; qui doit tre relatif  chaque point.50$:	PUSHM.L	D2,D451$:	PUSHM.L	D2,D4	COMP.W	D2,#8	JUMP',LS 53$	LOAD.W	D2,#853$:	LOAD.W	D1,(A6)+OOPDID+2	SUB.W	D1,D4	COMP.W	D1,D2		; dpasse  droite ?	JUMP',LT 58$	SWAP.W	D2	SWAP.W	D4	COMP.W	D2,#8	JUMP',LS 54$	LOAD.W	D2,#854$:	LOAD.W	D1,(A6)+OOPDID+0	SUB.W	D1,D4	COMP.W	D1,D2		; dpasse en bas ?	JUMP',LT 58$	SWAP.W	D2	SWAP.W	D4	CLR.L	D3		; D3 <-- coordonne source	LOAD.W	D5,#1		; D5 <-- Iy source	LOAD.W	D6,(A6)+OOPIYD	; D6 <-- Iy destination	LOAD.W	D1,#SETDOT	; D1 <-- mode	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OOPRAS	CALL	(A1)		; appel de GRA_RASTER58$:	POPM.L	D2,D4	ADD.W	D4,#8	SUB.W	D2,#8	JUMP,GT 51$	POPM.L	D2,D4	SWAP.W	D2	SWAP.W	D4	ADD.W	D4,#8	SUB.W	D2,#8	PUSH.W	F	SWAP.W	D2	SWAP.W	D4	POP.W	F	JUMP,GT 50$90$:	POPM.L	D1..D6,A1..A4	RET	.END