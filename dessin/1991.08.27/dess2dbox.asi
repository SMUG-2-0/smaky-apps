	.SBTTL	DESS2DBOX; Gestion de la dbox d'attente; ----------------------------;---------\\; WAITDBOX >;=========/; Met la dbox d'attente.; in	-; out	D7.W	erreur; mod	D7.WWAITDBOX:	PUSHM.L	D2..D5,A2	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A2,#R16"TDBOX_WAIT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE 90$	LOAD.L	(A6)+OOPCDB,D5	CLR.W	(A6)+OOPASC+OSCHTV ; ascenseur pas dessin	LIB	?PUSHMENU	; sauve les soft-keys	LOAD.L	(A6)+OOPCSK,D5	TEST.W	D7	JUMP',EQ 90$	PUSH.W	D7	LOAD.L	D5,(A6)+OOPCDB	DBOX_	CLOSE		; ferme la DBOX	CLR.L	(A6)+OOPCDB	POP.W	D790$:	POPM.L	D2..D5,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; AFFNDBOX >;=========/; Affiche le nb de blocs restant dans la dbox d'attente.; in	D0.W	nb de blocs restant; out	-; mod	D7.WAFFNDBOX:	PUSHM.L	D2..D5,A5	TEST.L	(A6)+OOPCDB	; dbox existe ?	JUMP,EQ 90$		; non => 90$	LOAD.L	A5,#(A6)+OOPASC	; A5 <-- ^variables de l'ascenseur	TEST.W	(A5)+OSCHTV	; ascenseur dj dessin ?	JUMP,NE 50$		; oui => 50$				; non => 	LOAD.L	D5,(A6)+OOPCDB	; D5 <-- canal dbox	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	LOAD.W	(A5)+OSCDEBL,D3	SWAP.W	D3	LOAD.W	(A5)+OSCDEBO,D3	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,D3	SUB.W	D4,D3	LOAD.W	(A5)+OSCHTR,D4	LOAD.W	(A5)+OSCHTV,D0	SET.B	(A5)+OSCHOR	SCROLL_	DRAW		; dessine l'ascenseur	LOAD.W	(A6)+OOPDIV,#2	COMP.W	D0,D4	JUMP',LS 50$	PUSH.W	D0	AND.L	D0,#H'FFFF	DIV.WU	D0,D4	SL.W	D0,#2	LOAD.W	(A6)+OOPDIV,D0	POP.W	D050$:	CLR.L	D2	LOAD.W	D2,D0	DIV.WU	D2,(A6)+OOPDIV	SWAP.W	D2	TEST.W	D2	JUMP',NE 90$	LOAD.W	D3,(A5)+OSCHTV	SUB.W	D3,D0	LOAD.W	(A5)+OSCPOSV,D3	SCROLL_	UPDATE		; dplace l'ascenseur90$:	POPM.L	D2..D5,A5	RET;---------\\; NORMDBOX >;=========/; Enlve la dbox d'attente.; in	-; out	-; mod	-NORMDBOX:	PUSHM.L	D5,D7	LOAD.L	D5,(A6)+OOPCDB	JUMP',EQ 90$	DBOX_	CLOSE		; ferme la DBOX	LOAD.L	D5,(A6)+OOPCSK	LIB	?POPMENU	; refait les soft-keys	CLR.L	(A6)+OOPCDB90$:	POPM.L	D5,D7	RETTDBOX_WAIT:	.W	10$-TDBOX_WAIT	.W	20$-TDBOX_WAIT	.W	0,010$:	.B	ODBCR,ODBCR	.B	ODBLABEL,1	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"       Attendez un instant ...      "	.B	ODBCR,ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN	.END