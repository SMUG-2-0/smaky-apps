	.SBTTL	DDESSINDBOXTDBOX_TDEF0:	.W	10$-TDBOX_TDEF0	.W	20$-TDBOX_TDEF0	.W	0,010$:	.B	ODBTABX,((8+2+8+2+8)*2)+1	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBTABX,((8+2)*2)	.B	ODBBOX,0,DEL,TDBNORM	.ASCIZ	"  EFFACE  "	.B	ODBBOX,0,DEFINE,TDBNORM	.ASCIZ	"  INVERSE "	.B	ODBTABX,((8+2)*2)+27	.B	ODBLCIRCLE,BMATX1	.ASCIZ	"        "		; [2]	.B	ODBCR	.B	ODBTABX,((8+2)*2)+27	.B	ODBLCIRCLE,BMATX2	.ASCIZ	"        "		; [3]	.B	ODBCR	.B	ODBTABX,((8+2)*2)	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	ODBTABX,((8+2)*2)+27	.B	ODBLCIRCLE,BMATX3	.ASCIZ	"        "		; [6]	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTDBOX_TDEF1:	.W	10$-TDBOX_TDEF1	.W	20$-TDBOX_TDEF1	.W	0,010$:	.B	ODBTABX,((8+2+8+2+8)*2)+1	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBTABX,((8+2)*2)	.B	ODBBOX,0,DEL,TDBNORM	.ASCIZ	"  EFFACE  "	.B	ODBBOX,0,DEFINE,TDBNORM	.ASCIZ	"  INVERSE "	.B	ODBCR	.B	ODBCR	.B	ODBTABX,((8+2)*2)	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_TDEF:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_TDEF	.W	F1,F2,F3,CR,0		DOKF1-TKEY_TDEF	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_TDEF	.W	0TDBOX_DDEF0:	.W	10$-TDBOX_DDEF0	.W	20$-TDBOX_DDEF0	.W	0,010$:	.B	ODBTABX,((8+2+8+2+8)*2)+1	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBTABX,((8+2)*2)	.B	ODBBOX,0,DEL,TDBNORM	.ASCIZ	"  EFFACE  "	.B	