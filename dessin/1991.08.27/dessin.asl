	.TITLE	DESSIN.ASL;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------;	Source du module SMA_DESSIN.LIB;	Date		Amliorations; --------------------------------------------------------------------------; 1.3	13.05.91	BMAKHELP pour afficher le raccourci clavier; 1.2	20.05.88	utilise le mode LOAD pour les trames; 1.1	30.11.87	"flip" trame si pas Smaky 8; 1.0	03.11.86	premire version distribue	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal	.REF	SMAKY	.REF	MODULES	.REF	DOLIB;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;BMAKHELP=	21		; raccourci clavierDBOX_KHELP=	13		; affiche le raccourci clavierODBKHELP=	19		; raccourci clavier (en bas  droite);;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.REV	1,3; Constantes diverses; -------------------DEFTR0	=	H'00000000	; dfinitions d'un trait finDEFTR4	=	H'08000000DEFTR8	=	H'FF01; Modes internes; --------------BMATR	=	24		; dite des tramesBMADR	=	25		; dite des droitesBMAPT	=	26		; dite des points; Variables; ---------	.LOC	0OSELEC:	.BLKB	2		; objet slectionnOMODE:	.BLKB	4		; mode et fanionsOPKHELP:.BLKB	4		; ^texte raccourci clavierOPOBJ:	.BLKB	4		; ^table des objetsOPICO:	.BLKB	4		; ^table des icnesOPTEXT:	.BLKB	4		; ^trois textesOBUFF:	.BLKB	(8+2)*MAMAX	; buffer pour les objetsOBUDIS:	.BLKB	20		; buffer "write-display"OTDOP:	.BLKB	2		; TDEF: opration sur un pointOTDLG:	.BLKB	2		; TDEF: dimension d'un "point"OADDOT:	.BLKB	4		; adresse de GRA_DOTOADTRAME:.BLKB	4		; adresse de GRA_TRAMEOADLINE:.BLKB	4		; adresse de GRA_LINEOADCLEAR:.BLKB	4		; adresse de GRA_CLEAROADSET:	.BLKB	4		; adresse de GRA_SETOADINV:	.BLKB	4		; adresse de GRA_INVOADQXDOT:.BLKB	4		; adresse de GRA_QXDOTOCCMO:	.BLKB	1		; 1 => souris enleveOMACHINE:.BLKB	1		; type de la machine (SMAKY8/SMAKY100)	.EVENLGVAR:; En-tte du module LIB; ---------------------	.LOC	0	DESSIN_	FIRST		; code du premier appel	DESSIN_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	1,3		; rvision.version	.W	0,END_DESSIN	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"DESSIN"	; nom du module	.FILLB	(LGHLIB-.),0	.W	_DESSIN_TEDIT	.W	_DESSIN_DEDIT	.W	_DESSIN_PEDIT	.W	_DESSIN_TGET	.W	_DESSIN_DGET	.W	_DESSIN_PGET	.W	_DESSIN_TDEF	.W	_DESSIN_DDEF	.W	_DESSIN_PDEF	.INS	DDESSINEDIT.ASI	.INS	DDESSINMISC.ASI	.INS	DDESSINDBOX.ASI	.INS	DDESSINTABL.ASIEND_DESSIN:	.END