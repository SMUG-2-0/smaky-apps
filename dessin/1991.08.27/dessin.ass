	.TITLE		DESSIN.ASS	.PROC		M68000		; mnmonics CALM	.BASE		10'10		; base 10 par dfaut;	.LAYOUT		HEX		; listing en hexadcimal; Numros des appels; ------------------	.SYSCALL.16	DESSIN_DESSIN_TEDIT	=	16'AB60		; dite des tramesDESSIN_DEDIT	=	16'AB61		; dite des droitesDESSIN_PEDIT	=	16'AB62		; dite des pointsDESSIN_TGET	=	16'AB63		; donne des trames par dfautDESSIN_DGET	=	16'AB64		; donne des droites par dfautDESSIN_PGET	=	16'AB65		; donne des points par dfautDESSIN_TDEF	=	16'AB66		; dfini une trameDESSIN_DDEF	=	16'AB67		; dfini une droiteDESSIN_PDEF	=	16'AB68		; dfini un pointDESSIN_FIRST	=	DESSIN_TEDITDESSIN_LAST	=	DESSIN_PDEF; Modes d'ditions; ----------------BMATX1		= 16		; cercle correspondant au texte 1BMATX2		= 17		; cercle correspondant au texte 2BMATX3		= 18		; cercle correspondant au texte 3BMAICO		= 20		; icnes et seulement 7 objetsBMAKHELP	= 21		; raccourci clavierMAMAX		= 4*7		; nb max d'objets;--------------\\; _DESSIN_TEDIT >;==============/; Edite une table de 4x7 trames quelconques.;; Table d'icnes en (A2):;	.8	USEGC,f,s,t;	.8	i1;	.8	i2;		etc.;	.8	0;	.EVEN;; Trois textes en (A3):;	.ASCIZ	"1..n";	.ASCIZ	"un seul";	.ASCIZ	"";	.EVEN;; Table des trames en (A4):;	.8	2'00010001	;;	.8	2'00100010	;;	.8	2'01000100	;;	.8	2'10001000	;;	.8	2'00010001	; une trame;	.8	2'00100010	;;	.8	2'01000100	;;	.8	2'10001000	;;	etc.; in	D2.32	flags divers (BMA...);	D4.16	trame slectionne;	A0.32	^descripteur de la fentre;	A1.32	^raccourci clavier (si BMAKHELP dans D2.32);	A2.32	^table d'icnes (si BMAICO dans D2.32);	A3.32	^trois textes;	A4.32	^table des 4x7 trames (1x7 trames si BMAICO dans D2.32); out	D2.32	flags divers;	D3.32	d'accord/annule (F1/F0);	D4.16	trame slectionne;	D7.16	erreur; mod	D2.32, D3.32, D4.32, D7.16;--------------\\; _DESSIN_DEDIT >;==============/; Edite une table de 4x7 pinceaux quelconques.;; Table d'icnes en (A2):;	.8	USEGC,f,s,t;	.8	i1;	.8	i2;		etc.;	.8	0;	.EVEN;; Trois textes en (A3):;	.ASCIZ	"1..n";	.ASCIZ	"un seul";	.ASCIZ	"";	.EVEN;; Table des pinceaux en (A4):;	.8	2'00000000	;;	.8	2'00000000	;;	.8	2'00011000	;;	.8	2'00111100	;;	.8	2'00111100	; un pinceau;	.8	2'00011000	;;	.8	2'00000000	;;	.8	2'00000000	;;	.8	2'00111111	; traitill;	.8	2		; pas;	etc.; in	D2.32	flags divers;	D4.16	trame slectionne;	A0.32	^descripteur de la fentre;	A1.32	^raccourci clavier (si BMAKHELP dans D2.32);	A2.32	^table d'icnes (si BMAICO dans D2.32);	A3.32	^trois textes;	A4.32	^table des 4x7 pinceaux (1x7 pinceaux si BMAICO dans D2.32); out	D2.32	flags divers;	D3.32	d'accord/annule (F1/F0);	D4.16	trame slectionne;	D7.16	erreur; mod	D2.32, D3.32, D4.32, D7.16;--------------\\; _DESSIN_PEDIT >;==============/; Edite une table de 4x7 points quelconques.;; Table d'icnes en (A2):;	.8	USEGC,f,s,t;	.8	i1;	.8	i2;		etc.;	.8	0;	.EVEN;; Trois textes en (A3):;	.ASCIZ	"1..n";	.ASCIZ	"un seul";	.ASCIZ	"";	.EVEN;; Table des points en (A4):;	.8	2'00000000	;;	.8	2'00011100	;;	.8	2'00100010	;;	.8	2'01000001	;;	.8	2'01000001	; un point;	.8	2'01000001	;;	.8	2'00100010	;;	.8	2'00011100	;;	etc.; in	D2.32	flags divers;	D4.16	trame slectionne;	A0.32	^descripteur de la fentre;	A1.32	^raccourci clavier (si BMAKHELP dans D2.32);	A2.32	^table d'icnes (si BMAICO dans D2.32);	A3.32	^trois textes;	A4.32	^table des 4x7 points (1x7 points si BMAICO dans D2.32); out	D2.32	flags divers;	D3.32	d'accord/annule (F1/F0);	D4.16	trame slectionne;	D7.16	erreur; mod	D2.32, D3.32, D4.32, D7.16;-------------\\; _DESSIN_TDEF >;=============/; Dfini une trame selon son rang.; Aprs cet appel, on peut utiliser :;	LIB,?DRMATRIX	ou	DRAWTRAME;	--		ou	DRAWFILLO/DRAWFILLC; in	D1.16	rang de la trame;	A4.32	^liste de trames; out	A4.32	^trame;	D2.16	mode (-1 si rien  dessiner); mod	D2.32, D7.16, A4.32;-------------\\; _DESSIN_DDEF >;=============/; Dfini un pinceau selon son rang.; Aprs cet appel, on peut utiliser :;	LIB,?DRSEG	ou	DRAWSEG;	LIB,?DRRECT	ou	--;	LIB,?DRCERCLE	ou	DRAWCERCLE;	--		ou	DRAWARC;	etc.; in	D1.16	rang de la droite;	A4.32	^liste de droites; out	A4.32	^droite;	D2.16	mode (-1 si rien  dessiner); mod	D2.32, D7.16, A4.32;-------------\\; _DESSIN_PDEF >;=============/; Dfini un point selon son rang.; Aprs cet appel, on peut utiliser :;	--		ou	DRAWDOT; in	D1.16	rang du point;	A4.32	^liste de points; out	A4.32	^point;	D2.16	mode (-1 si rien  dessiner); mod	D2.32, D7.16, A4.32;-------------\\; _DESSIN_TGET >;=============/; Donne le pointeur  une collection de trames.;	Collection 0	-->	DESSIN.CODE;	Collection 1	-->	GRAPHE.CODE; in	D4.16	rang de la collection (0,1); out	A4.32	^trames;	D7.16	erreur; mod	D7.16, A4.32;-------------\\; _DESSIN_DGET >;=============/; Donne le pointeur  une collection de droites.;	Collection 0	-->	DESSIN.CODE;	Collection 1	-->	GRAPHE.CODE; in	D4.16	rang de la collection (0,1); out	A4.32	^droites;	D7.16	erreur; mod	D7.16, A4.32;-------------\\; _DESSIN_PGET >;=============/; Donne le pointeur  une collection de points.;	Collection 0	-->	GRAPHE.CODE; in	D4.16	rang de la collection (0); out	A4.32	^points;	D7.16	erreur; mod	D7.16, A4.32	.END