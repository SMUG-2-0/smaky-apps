	.SBTTL	DESAFTEXT;---------\\; EDCURSOR >;=========/; Effectue un dplacement.; in	D3.W	touche; out	D7.W	erreur; mod	D7.WEDCURSOR:	PUSHM.L	D2,D3	CALL	EDFLECHE	; D2 <-- +/- dplacement	LOAD.W	D7,#1	TEST.W	D2	JUMP',EQ 90$	ADD.W	(A6)+OCUTEXT,D2	CLR.W	D790$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; EDKILL  >;========/; Effectue une destruction.; in	D3.W	touche; out	D7.W	erreur; mod	D7.WEDKILL:	PUSHM.L	D2,D3	CALL	EDFLECHE	; D2 <-- +/- dplacement	LOAD.W	D7,#1	TEST.W	D2	JUMP',EQ 90$	JUMP',NS 50$20$:	CALL	EDKILCAR	DEC.W	D2	JUMP,NE 20$	JUMP'	80$50$:	DEC.W	(A6)+OCUTEXT	CALL	EDKILCAR	INC.W	D2	JUMP,NE 50$80$:	CLR.W	D790$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; EDFLECHE  >;----------/; Calcul l'amplitude d'un dplacement/destruction.; in	D3.W	touche; out	D2.W	dplacement (+/-n); mod	D2.W, D7.WEDFLECHE:	PUSHM.L	D3,A3,A4	LOAD.L	A4,(A6)+OPTTEXT	LOAD.W	D2,(A6)+OCUTEXT	LIB	?MINMAJ	COMP.B	D3,#'F	JUMP,EQ 20$	COMP.B	D3,#'D	JUMP,EQ 25$	LOAD.L	A3,#R16"01$	; A3 <-- ^terminateurs de mots	COMP.B	D3,#'G	JUMP,EQ 30$	COMP.B	D3,#'S	JUMP,EQ 35$	LOAD.L	A3,#R16"02$	; A3 <-- ^terminateurs de lignes	COMP.B	D3,#'C	JUMP,EQ 30$	COMP.B	D3,#'R	JUMP,EQ 35$	COMP.B	D3,#'X	JUMP,EQ 40$	COMP.B	D3,#'E	JUMP,EQ 45$	COMP.B	D3,#'V	JUMP,EQ 40$	COMP.B	D3,#'T	JUMP,EQ 45$	JUMP	80$20$:				; +1 caractre =>	COMP.W	D2,(A6)+ONBTEXT	JUMP,EQ 80$	INC.W	D2	JUMP	80$25$:				; -1 caractre =>	TEST.W	D2	JUMP,EQ 80$	DEC.W	D2	JUMP	80$30$:				; +1 mot/ligne =>	COMP.W	D2,(A6)+ONBTEXT	JUMP,EQ 80$	LOAD.B	D3,(A4)+(D2.W)	INC.W	D2	CALL	EDTESTCAR	JUMP,EQ 30$32$:	COMP.W	D2,(A6)+ONBTEXT	JUMP,EQ 80$	LOAD.B	D3,(A4)+(D2.W)	INC.W	D2	CALL	EDTESTCAR	JUMP,NE 32$	DEC.W	D2	JUMP	80$35$:				; -1 mot/ligne =>	TEST.W	D2	JUMP,EQ 80$	DEC.W	D2	LOAD.B	D3,(A4)+(D2.W)	CALL	EDTESTCAR	JUMP,EQ 35$37$:	TEST.W	D2	JUMP,EQ 80$	DEC.W	D2	LOAD.B	D3,(A4)+(D2.W)	CALL	EDTESTCAR	JUMP,NE 37$	INC.W	D2	JUMP	80$40$:				; fin =>	LOAD.W	D2,(A6)+ONBTEXT	JUMP	80$45$:				; dbut =>	CLR.W	D2;	JUMP	80$80$:	SUB.W	D2,(A6)+OCUTEXT	; D2 <-- +/- dplacement90$:	POPM.L	D3,A3,A4	RET01$:	.B	SPACE		; terminateurs de mots	.B	'+	.B	'-	.B	'*	.B	'/	.B	'^	.B	'(	.B	')	.B	',02$:	.B	CR		; terminateurs de lignes	.B	EOP	.B	0	.EVEN;----------\\; EDTESTCAR >;----------/; Test si le caractre dans D3.B est un terminateur.; in	D3.B	caractre;	A3.L	^liste de terminateurs; out	EQ	terminateur;	NE	autre chose; mod	FEDTESTCAR:	PUSH.L	A310$:	TEST.B	(A3)	NOTZ	JUMP',NE 90$	COMP.B	D3,(A3+)	JUMP,NE 10$90$:	POP.L	A3	RET;--------\\; EDCOPIE >;========/; Copie tous les caractres en dition.; in	-; out	D7.W	erreur; mod	D7.WEDCOPIE:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#R16"NAME$	LOAD.L	D3,#H'1000000*'T+H'10000*'E+H'100*'X+H'1*'T	CLR.L	D4	LOAD.W	D4,(A6)+ONBTEXT	BLOC_	WROPEN	JUMP',NE EXIT$	LOAD.L	A4,(A6)+OPTTEXT	LOAD.L	D3,#H'1000000*'T+H'10000*'E+H'100*'X+H'1*'T	BLOC_	WRDATA	PUSH.W	D7	BLOC_	WRCLOSE	POP.W	D7EXIT$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RETNAME$:	.ASCIZ	"DESSIN4"	.EVEN;--------\\; EDCOLLE >;========/; Colle tous les caractres du bloc-notes.; in	-; out	D7.W	erreur; mod	D7.WEDCOLLE:	PUSHM.L	D3,D4,A3,A4	LOAD.L	D3,#H'1000000*'T+H'10000*'E+H'100*'X+H'1*'T	BLOC_	RDOPEN	JUMP',NE EXIT$LOOP$:	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D4,#1	BLOC_	RDDATA		; lit un caractre	JUMP',NE CLOSE$	LOAD.B	D3,(A4)		; D3 <-- caractre lu	CALL	EDINSCAR	JUMP,EQ LOOP$CLOSE$:	BLOC_	RDCLOSE	CLR.W	D7EXIT$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EDINSCAR >;=========/; Ajoute un caractre  l'endroit du curseur.; in	D3.B	caractre; out	D7.W	erreur; mod	D7.WEDINSCAR:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,(A6)+OPTTEXT	COMP.B	D3,#EOP	JUMP',NE 10$	LOAD.W	D4,(A6)+OCUTEXT	JUMP',EQ 10$	COMP.B	(A3)+(D4.W)-1,#SPACE	JUMP',NE 10$	LOAD.B	(A3)+(D4.W)-1,#EOP ; remplace l'espace par l'EOP	JUMP	80$10$:	LOAD.W	D7,#1		; D7 <-- buffer trop petit	LOAD.W	D4,(A6)+ONBTEXT	COMP.W	D4,#MAXTEXT	; dj assez de caractres ?	JUMP',HS 90$		; oui => 90$	ADD.W	A3,D4		; A3 <-- ^fin de la ligne	SUB.W	D4,(A6)+OCUTEXT	JUMP',EQ 40$	LOAD.L	A4,#(A3)+1	DEC.W	D420$:	LOAD.B	(-A4),(-A3)	DECJ.W,NMO D4,20$40$:	LOAD.B	(A3),D3	INC.W	(A6)+OCUTEXT	INC.W	(A6)+ONBTEXT	LOAD.L	A3,(A6)+OPTTEXT	ADD.W	A3,(A6)+ONBTEXT	CLR.B	(A3)80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EDKILCAR >;=========/; Supprime un caractre  l'endroit du curseur.; in	-; out	-; mod	D7.WEDKILCAR:	PUSHM.L	D3,D4,A3,A4	TEST.W	(A6)+ONBTEXT	JUMP',EQ 90$	LOAD.L	A3,(A6)+OPTTEXT	ADD.W	A3,(A6)+OCUTEXT	LOAD.W	D4,(A6)+ONBTEXT	SUB.W	D4,(A6)+OCUTEXT	JUMP',EQ 90$	DEC.W	D4	JUMP',EQ 40$	LOAD.L	A4,#(A3)+1	DEC.W	D420$:	LOAD.B	(A3+),(A4+)	DECJ.W,NMO D4,20$40$:	DEC.W	(A6)+ONBTEXT	LOAD.L	A3,(A6)+OPTTEXT	ADD.W	A3,(A6)+ONBTEXT	CLR.B	(A3)	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A3,A4	RET;---------\\; EDIFPAVE >;=========/; Regarde si la souris est dans un pav de texte.; in	D4.L	position de la souris (y;x); out	D7.W	ok/erreur; mod	D7.WEDIFPAVE:	PUSHM.L	D1..D4	CALL	DETGPOINT	; D3 <-- position du point (y;x)	JUMP,NE 80$	LOAD.L	D1,D3	CLR.W	D2		; D2 <-- numro du premier pav20$:	LOAD.W	D3,D2	CALL	OPEPAVE		; utilise le bon pav	JUMP,NE 90$	LOAD.L	D3,D1		; D3 <-- position de la souris	LOAD.W	D4,(A6)+OPOTEXT+2	SUB.W	D4,#10	COMP.W	D3,D4		;  gauche du pav de texte ?	JUMP',LT 25$	ADD.W	D4,(A6)+OLGTEXT	ADD.W	D4,#10+10	COMP.W	D3,D4		;  droite du pav de texte ?	JUMP',GE 25$	SWAP.W	D3	LOAD.W	D4,(A6)+OPOTEXT+0	SUB.W	D4,#10+DPOIGNEE*2	COMP.W	D3,D4		; en haut du pav de texte ?	JUMP',LT 25$	ADD.W	D4,(A6)+OHTTEXT	ADD.W	D4,#10+DPOIGNEE*2+DPOIGNEE*2+10	COMP.W	D3,D4		; en bas du pav de texte ?	JUMP',LT 80$25$:	INC.W	D2		; D2 <-- numro du pav suivant	JUMP	20$80$:	CLR.W	D7		; D7 <-- souris dans pav90$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EDDETECT >;=========/; Dtecte o est la souris dans le texte.; in	D4.L	position de la souris (y;x); out	D7.W	ok/erreur; mod	D7.WEDDETECT:	PUSHM.L	D1..D4,A2..A4	CALL	DETGPOINT	; D3 <-- position du point (y;x)	JUMP,NE 90$	LOAD.L	(A6)+OPSTEXT,D3	CLR.W	D2		; D2 <-- numro du premier pav20$:	LOAD.W	D3,D2	CALL	OPEPAVE		; utilise le bon pav	JUMP,NE 90$	LOAD.L	D3,(A6)+OPSTEXT	; D3 <-- position de la souris	LOAD.W	D4,(A6)+OPOTEXT+2	COMP.W	D3,D4		;  gauche du pav de texte ?	JUMP',LT 25$	ADD.W	D4,(A6)+OLGTEXT	COMP.W	D3,D4		;  droite du pav de texte ?	JUMP',GE 25$	SWAP.W	D3	LOAD.W	D4,(A6)+OPOTEXT+0	COMP.W	D3,D4		; en haut du pav de texte ?	JUMP',LT 25$	ADD.W	D4,(A6)+OHTTEXT	COMP.W	D3,D4		; en bas du pav de texte ?	JUMP',LT 30$25$:	INC.W	D2		; D2 <-- numro du pav suivant	JUMP	20$30$:	LOAD.W	D3,(A6)+OCUTEXT	SET.B	(A6)+ODTTEXT	CALL	GETPGC		; A4 <-- ^dans OBUGC	LOAD.L	A2,A4		; A2 <-- ^dans OBUGC	LOAD.L	A3,(A6)+OPTTEXT	CALL	EDAFTEXT	; dtecte o est la souris	CLR.B	(A6)+ODTTEXT	LOAD.W	D7,#1		; D7 <-- souris ailleurs	COMP.W	D3,(A6)+OCUTEXT	JUMP',EQ 90$	CLR.W	D7		; D7 <-- trouv !90$:	POPM.L	D1..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EDAFTEXT >;=========/; Affiche tout un pav de texte.; in	A3.L		^texte <0>;	A2.L		^dans OBUGC;	(A6)+OPOTEXT.L	position (y;x);	(A6)+OLGTEXT.W	largeur (dx);	(A6)+OJUTEXT.B	mode de justification;	(A6)+OCMTEXT.B	divisions dans les mots; out	(A6)+OHTTEXT.W	hauteur (dy);	(A6)+OCPTEXT.L	position du curseur;	(A6)+OCHTEXT.W	hauteur du curseur;	(A6)+ODETEXT.B	est-ce que le texte dborde ?; mod	D7.WEDAFTEXT:	PUSHM.L	D1..D4,A3	LOAD.L	(A6)+OCPTEXT,#-1	LOAD.W	D2,(A2)+OGC1Y	ADD.W	D2,(A2)+OGC2Y	LOAD.W	(A6)+OCHTEXT,D2	SET.B	(A6)+ODETEXT	; le texte dborde !	CALL	EDBEGPAVE	; prpare l'affichage de tous les pavs	CLR.W	D1		; D1 <-- numro du premier pav10$:	CALL	EDOPEPAVE	; prpare l'affichage d'un pav	JUMP,NE 90$	PUSH.W	(A6)+OHTTEXT	PUSH.W	(A6)+OLGTEXT	LOAD.W	D2,(A6)+OICTEXT	ADD.W	(A6)+OLGTEXT,D2	CLR.L	D2		; Y <-- tout en haut20$:	CLR.B	D3	LOAD.L	D4,D2	SWAP.W	D4	ADD.W	D4,(A2)+OGC1Y	ADD.W	D4,(A2)+OGC2Y	TEST.B	(A6)+O3PTEXT	; 3me poigne existe ?	JUMP',T 25$		; oui => 25$				; non =>	ADD.W	D4,#DPOIGNEE*2+1	ADD.W	D4,(A6)+OPOTEXT+0	COMP.W	D4,(A6)+OMALMY	; dpasse en bas de la matrice ?	JUMP',HI 50$		; oui => 50$	JUMP'	30$25$:	COMP.W	D4,(A6)+OHTTEXT	; dpasse le bas du pav ?	JUMP',HI 50$		; oui => 50$30$:	CLR.W	D2		; X <-- au dbut de la ligne	CALL	EDAFLINE	; affiche une ligne	SWAP.W	D2	ADD.W	D2,(A6)+OILTEXT	; Y <-- ligne suivante	SWAP.W	D2	COMP.B	D3,#EOP	JUMP',EQ 50$	TEST.B	(A3)		; fin du pav de texte ?	JUMP,NE 20$		; non => 20$				; oui =>	CLR.B	(A6)+ODETEXT	; le texte ne dborde plus50$:	SWAP.W	D2	COMP.B	D3,#CR	JUMP',NE 52$	ADD.W	D2,(A6)+OILTEXT	; Y <-- ligne suivante	AND.L	D2,#H'FFFF	; X <-- au dbut de la ligne52$:	LOAD.W	(A6)+OHTTEXT,D2	SWAP.W	D2; Affiche ventuellement le curseur (s'il est tout  la fin).;;?	PUSH.W	D3;;?	CALL	MAXPAVE;;?	DEC.W	D3;;?	LOAD.W	D4,D3		; D4 <-- numro du dernier pav;;?	POP.W	D3;;?	COMP.W	D1,D4		; est-on dans le dernier pav ?;;?	JUMP',NE 70$		; non => 70$;;?				; oui =>	TEST.B	(A3)		; fin du pav de texte ?	JUMP',NE 70$		; non => 70$	COMP.L	(A6)+OCPTEXT,#-1 ; position du curseur dj trouve ?	JUMP',NE 70$		; oui => 70$				; non =>	SWAP.W	D2	SUB.W	D2,(A6)+OILTEXT	; Y <-- ligne suivante	SWAP.W	D2	PUSH.L	D2	ADD.W	D2,(A6)+OPOTEXT+2	SWAP.W	D2	ADD.W	D2,(A6)+OPOTEXT+0	SWAP.W	D2	LOAD.L	(A6)+OCPTEXT,D2	; OCPTEXT <-- position du curseur	POP.L	D270$:	LOAD.W	D2,(A6)+OILTEXT	SUB.W	D2,(A2)+OGC1Y	SUB.W	D2,(A2)+OGC2Y	SUB.W	(A6)+OHTTEXT,D2	COMP.B	D3,#EOP	JUMP',EQ 80$	TEST.B	(A6)+ODETEXT	; texte dborde ?	JUMP',F 80$		; non => 80$				; oui =>	LOAD.W	D2,(A6)+OMALMY	SUB.W	D2,#DPOIGNEE*2+1	SUB.W	D2,(A6)+OPOTEXT+0	LOAD.W	(A6)+OHTTEXT,D2	; OHTTEXT <-- jusque tout en bas !80$:	POP.W	(A6)+OLGTEXT	POP.W	D3		; D3 <-- OHTTEXT initial	TEST.B	(A6)+O3PTEXT	; 3me poigne existe ?	JUMP',F 82$		; non => 82$	LOAD.W	(A6)+OHTTEXT,D3	; oui => ne modifie pas OHTTEXT82$:	CALL	EDCLOPAVE	; termine l'affichage d'un pav	INC.W	D1		; D1 <-- numro du pav suivant	JUMP	10$90$:	CALL	EDENDPAVE	; termine l'affichage de tous les pavs	POPM.L	D1..D4,A3	RET;----------\\; EDBEGPAVE >;----------/; Prpare l'affichage de tous les pavs de texte.; in	-; out	-; mod	D7.WEDBEGPAVE:	PUSHM.L	D2..D5,A3,A4	TEST.B	(A6)+ODTTEXT	; dtecte ?	JUMP',T	90$		; oui => 90$	TEST.B	(A6)+OQCTEXT	; dplace le curseur ?	JUMP',T	90$		; oui => 90$	LOAD.L	A3,#(A6)+OTAPAVE20$:	TEST.L	(A3)+OPAPOS	JUMP',EQ 90$	LOAD.L	D3,(A3)+OPAOPO	; D3 <-- position source	LOAD.L	D4,D3		; D4 <-- position destination	LOAD.L	D5,(A3)+OPAODI	; D5 <-- dimensions	PUSH.L	A3	LOAD.L	A3,(A6)+OPMAC	; A3 <-- ^matrice source (copie)	LOAD.L	A4,(A6)+OPMAT	; A4 <-- ^matrice destination (principale)	LOAD.W	D2,#LOADDOT	CALL	XFERZONE	; remet le contenu initial selon copie	POP.L	A3	ADD.L	A3,#LPA		; A3 <-- ^pav suivant	JUMP	20$90$:	POPM.L	D2..D5,A3,A4	RET;----------\\; EDENDPAVE >;----------/; Termine l'affichage de tous les pavs de texte.; in	-; out	-; mod	D7.WEDENDPAVE:	PUSHM.L	D0..D6,A3,A4	TEST.B	(A6)+ODTTEXT	; dtecte ?	JUMP,T	90$		; oui => 90$	TEST.B	(A6)+OQCTEXT	; dplace le curseur ?	JUMP,T	90$		; oui => 90$; Regarde s'il y a un pav de modifi (position ou dimensions).; Si oui, enlve tous les rectangles englobants.	CLR.B	D1		; D1 <-- rectangles englobants subsistent	COMP.W	(A6)+OSCALE,#SCALE11	JUMP',NE 20$	LOAD.L	A3,#(A6)+OTAPAVE10$:	LOAD.L	D4,(A3)+OPAPOS	JUMP,EQ 30$	COMP.L	D4,(A3)+OPAOPO	; changement de position ?	JUMP',NE 20$		; oui => 20$	LOAD.L	D4,(A3)+OPADIM	COMP.L	D4,(A3)+OPAODI	; changement de dimension ?	JUMP',NE 20$		; oui => 20$	ADD.L	A3,#LPA		; A3 <-- ^pav suivant	JUMP	10$20$:	INC.B	D1		; D1 <-- rectangles englobants enlevs	CLR.W	D322$:	CALL	OPEPAVE		; utilise le bon pav	JUMP',NE 30$	LOAD.L	(A6)+OPOTEXT,(A6)+OOPTEXT	LOAD.L	(A6)+OHTTEXT,(A6)+OOHTEXT	CLR.W	D2		; D2 <-- les 3 poignes	CALL	IRETEXTE	; enlve le rectangle englobant	INC.W	D3		; D3 <-- numro du pav suivant	JUMP	22$; Affiche  l'cran (dans les deux matrices) la zone englobant tous; les pavs qui ont changs.30$:	TEST.W	(A6)+OSCALE	; chelle ngative (tout) ?	JUMP,NS 40$		; oui => 40$	LOAD.L	A3,#(A6)+OTAPAVE32$:	TEST.L	(A3)+OPAPOS	JUMP,EQ 50$	PUSH.W	D1	LOAD.L	D1,(A3)+OPAPOS	; D1 <-- <xx> gauche et <yy> haut	LOAD.L	D2,(A3)+OPADIM	ADD.W	D2,D1		; D2 <-- <xx> droite	LOAD.W	D3,(A3)+OPAOPO+2	COMP.W	D1,D3	JUMP',LS 34$	LOAD.W	D1,D334$:	ADD.W	D3,(A3)+OPAODI+2	COMP.W	D2,D3	JUMP',HS 35$	LOAD.W	D2,D335$:	SWAP.W	D1	SWAP.W	D2	ADD.W	D2,D1		; D2 <-- <yy> bas	LOAD.W	D3,(A3)+OPAOPO+0	COMP.W	D1,D3	JUMP',LS 36$	LOAD.W	D1,D336$:	ADD.W	D3,(A3)+OPAODI+0	COMP.W	D2,D3	JUMP',HS 37$	LOAD.W	D2,D337$:	SWAP.W	D1	SWAP.W	D2	LOAD.L	D5,D1	LOAD.L	D6,D2	LOAD.L	A4,(A6)+OPMAT	LOAD.W	D0,#LOADDOT	CALL	BBPGMATRIX	; affiche  l'cran (v. dans les deux fentres)	POP.W	D1	LOAD.L	(A3)+OPAOPO,(A3)+OPAPOS	LOAD.L	(A3)+OPAODI,(A3)+OPADIM	ADD.L	A3,#LPA		; A3 <-- ^pav suivant	JUMP	32$40$:				; chelle ngative =>	CALL	DESMATRIX	; redessine toutes les matrices	LOAD.L	A3,#(A6)+OTAPAVE42$:	TEST.L	(A3)+OPAPOS	JUMP',EQ 50$	LOAD.L	(A3)+OPAOPO,(A3)+OPAPOS	LOAD.L	(A3)+OPAODI,(A3)+OPADIM	ADD.L	A3,#LPA		; A3 <-- ^pav suivant	JUMP	42$; Si ncessaire, remet tous les rectangles englobants.50$:	TEST.B	D1		; rectangles englobants enlevs ?	JUMP',EQ 90$		; non => 90$				; oui =>	CALL	JRETEXTE	; remet les rectangles englobants90$:	POPM.L	D0..D6,A3,A4	RET;----------\\; EDOPEPAVE >;----------/; Prpare l'affichage d'un pav de texte.; in	D1.W	numro du pav de texte; out	D7.W	erreur; mod	D7.WEDOPEPAVE:	PUSHM.L	D3,A4	LOAD.W	D3,D1	CALL	OPEPAVE		; utilise le bon pav	JUMP',NE 90$	TEST.B	(A6)+ODTTEXT	; dtecte ?	JUMP',T	80$		; oui => 80$	TEST.B	(A6)+OQCTEXT	; dplace le curseur ?	JUMP',T	80$		; oui => 80$	LOAD.L	A4,(A6)+OPMAT	CALL	OPEDISMAT	; dessine dans la matrice principale80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; EDCLOPAVE >;----------/; Termine l'affichage d'un pav de texte.; in	D1.W	numro du pav de texte; out	-; mod	D7.WEDCLOPAVE:	PUSH.L	D3	TEST.B	(A6)+ODTTEXT	; dtecte ?	JUMP',T	80$		; oui => 80$	TEST.B	(A6)+OQCTEXT	; dplace le curseur ?	JUMP',T	80$		; oui => 80$	CALL	CLODISMAT	; dessine  nouveau dans l'cran80$:	LOAD.W	D3,D1	CALL	CLOPAVE		; met  jour le pav	POP.L	D3	RET;---------\\; EDAFLINE >;---------/; Affiche toute une ligne.; in	D2.L	position;	A3.L	^dbut ligne;	A2.L	^dans OBUGC; out	D2.L	^plus loin;	D3.B	dernier caractre;	A3.L	^ligne suivante; mod	D2.L, D3.L, D7.WEDAFLINE:	PUSHM.L	D0,D1,D4..D6,A4,A5	PUSH.W	(A6)+OLGTEXT	TEST.B	(A6)+OCTTEXT	; pouse le contour ?	JUMP',F 05$		; non => 05$				; oui =>	LOAD.L	D3,D2	ADD.W	D3,(A6)+OPOTEXT+2	SWAP.W	D3	ADD.W	D3,(A6)+OPOTEXT+0	SWAP.W	D3	LOAD.W	D4,(A2)+OGC1Y	ADD.W	D4,(A2)+OGC2Y	SWAP.W	D4	LOAD.W	D4,(A6)+OLGTEXT	LOAD.L	A4,(A6)+OPMAC	CALL	SEARCHPVIDE	; D1 <-- offset/largeur	LOAD.W	D0,(A2)+OGCX	MUL.WU	D0,#4	COMP.W	D1,D0		; y a-t-il au moins un minimum ?	JUMP,LT 85$		; non => 85$	LOAD.W	(A6)+OLGTEXT,D1	SWAP.W	D1	LOAD.W	D2,D105$:	LOAD.L	A4,A3	CALL	EDCOUPELINE	; D4/D5/D6 <-- paramtres	LOAD.L	A5,A3		; A5 <-- ^plus loin	EX.L	A3,A4		; A3 <-- ^dbut ligne	SUB.L	A4,A3		; A4 <-- nb de caractres	CALL	EDCALCSAJEX	; D0/D5 <-- reste/nb pour les SAJEXs; Met ventuellement quelques espaces au dbut de la ligne pour; justifier dans les modes drapeau  gauche et centr.	LOAD.W	D3,(A6)+OLGTEXT	SUB.W	D3,D4		; D3 <-- largeur laisse vide	JUMP,LO 15$	COMP.B	(A6)+OJUTEXT,#ICOJUSTG ; drapeau  gauche ?	JUMP',EQ 10$	SR.W	D3,#1	COMP.B	(A6)+OJUTEXT,#ICOJUSTC ; centr ?	JUMP',NE 15$10$:	PUSH.L	D5	CLR.L	D5	LOAD.W	D5,D3	CALL	EDAFSAJEX	; affiche un sajex au dbut de la ligne	POP.L	D5; Affiche tous les caractres de la ligne.15$:	LOAD.W	D4,A4		; D4 <-- nb de caractres	LOAD.B	D3,#SPACE20$:	LOAD.B	D1,D3		; D1 <-- dernier caractre	TEST.W	D4	JUMP',EQ 30$	DEC.W	D4	PUSHM.L	D0,D5	LOAD.L	D0,D2		; D0 <-- position avant le caractre	LOAD.B	D3,(A3+)	CALL	EDAFCAR		; affiche un caractre	LOAD.L	D5,A3	DEC.L	D5	LOAD.L	A4,(A6)+OPTTEXT	SUB.L	D5,A4	COMP.W	D5,(A6)+OCUTEXT	; est-on sur le curseur ?	JUMP',NE 23$		; non => 23$				; oui =>	ADD.W	D0,(A6)+OPOTEXT+2	SWAP.W	D0	ADD.W	D0,(A6)+OPOTEXT+0	SWAP.W	D0	LOAD.L	(A6)+OCPTEXT,D0	; OCPTEXT <-- position du curseur23$:	POPM.L	D0,D5	COMP.B	(A6)+OJUTEXT,#ICOJUSTA ; align ?	JUMP,NE 20$		; non => 20$				; oui =>	COMP.B	D3,#SPACE	JUMP',NE 26$	COMP.B	D3,D1		; dernier caractre tait dj un espace ?	JUMP',EQ 26$		; oui => 26$	TEST.W	(A6)+OECTEXT	; espacement entre les caractres ?	JUMP',EQ 27$		; non => 27$	LOAD.W	D3,(A6)+OECTEXT	; D3 <-- espacement entre les caractres	SUB.W	D3,#5-1	NEG.W	D3	MUL.WU	D3,#5		; D3 <-- 0,5,10,1525$:	CALL	EDAFSAJEX	; affiche un "sajex"	DEC.W	D3	JUMP,NC 25$	LOAD.B	D3,#SPACE	JUMP	20$26$:	TEST.W	(A6)+OECTEXT	; espacement entre les caractres ?	JUMP,EQ 20$		; non => 20$27$:	CALL	EDAFSAJEX	; affiche un "sajex"	JUMP	20$; Affiche l'ventuel caractre de fin de ligne.30$:	LOAD.B	D3,D6	JUMP',EQ 80$	COMP.B	D3,#CR	JUMP',EQ 80$	COMP.B	D3,#EOP	JUMP',EQ 80$	COMP.B	D3,#-1	JUMP',EQ 80$	COMP.B	D3,#SPACE	JUMP',EQ 80$	CALL	EDAFCAR80$:	LOAD.L	A3,A5		; A3 <-- ^plus loin85$:	POP.W	(A6)+OLGTEXT	POPM.L	D0,D1,D4..D6,A4,A5	RET;------------\\; EDCALCSAJEX >;------------/; Calcul la largeur des "sajex" en mode align.; in	A4.W	nb de caractres;	A5.L	^dbut ligne suivante;	D4.W	largeur de la ligne;	D5.W	nb d'espaces;	D6.B	dernier caractre (zro/SPACE/tiret/CR); out	D5.L	reste/nb pour les SAJEXs;	D0.L	rpartiteur du reste; mod	D0.L, D5.L, D7.WEDCALCSAJEX:	PUSHM.L	D3,D4	COMP.B	D6,#CR		; fin de ligne force ?	JUMP,EQ 80$		; oui => 80$;;?	COMP.B	D6,#EOP		; fin du texte ?;;?	JUMP,EQ 80$		; oui => 80$	COMP.B	D6,#-1		; fin du texte ?	JUMP,EQ 80$		; oui => 80$	LOAD.W	D3,(A6)+OECTEXT	; espaces entre tous les caractres ?	JUMP',EQ 40$		; non => 40$				; oui =>	SUB.W	D3,#5-1	NEG.W	D3	MUL.WU	D3,#5		; D3 <-- 0,5,10,15	MUL.WU	D5,D3	ADD.W	D5,A4		; D5 <-- nb de caractres + nb d'espaces	DEC.W	D5	COMP.B	(A5)-1,#SPACE	JUMP',NE 30$	DEC.W	D530$:	COMP.B	D6,#'-	JUMP',NE 40$	INC.W	D540$:	CLR.L	D3	LOAD.W	D3,(A6)+OLGTEXT	SUB.W	D3,D4		; D3 <-- largeur laisse vide	TEST.W	D5	JUMP',LE 80$	CLR.L	D0	LOAD.W	D0,D5	DIV.WU	D3,D5	LOAD.L	D5,D3		; D5 <-- reste/nb	SWAP.W	D3	TEST.W	D3	JUMP',EQ 85$	DIV.WU	D0,D3	LOAD.W	D3,D0	SWAP.W	D0	LOAD.W	D0,D3	SR.W	D0,#1		; D0 <-- rpartiteur du reste	JUMP',NE 90$	INC.W	D0	JUMP'	90$80$:	CLR.L	D5		; D5 <-- n'aligne pas !85$:	CLR.L	D090$:	POPM.L	D3,D4	RET;------------\\; EDCOUPELINE >;------------/; Dtermine o il faut couper dans une ligne trop longue.; in	A3.L	^ligne;	A2.L	^dans OBUGC; out	A3.L	^plus loin;	D4.W	largeur de la ligne;	D5.W	nb d'espaces;	D6.B	dernier caractre (zro/SPACE/tiret/CR/EOP/-1); mod	D4.L, D5.L, D6.L, D7.W, A3.LEDCOUPELINE:	PUSHM.L	D1..D3,A4	LOAD.L	A4,A3		; A4 <-- ^dbut de la ligne	CLR.W	D2		; D2 <-- nb caractres dans dernier mot	CLR.W	D5		; D5 <-- nb d'espaces	CLR.W	D4		; D4 <-- position dans la ligne10$:	COMP.W	D4,(A6)+OLGTEXT	; largeur ligne atteinte ?	JUMP,HI 40$		; oui => 40$	LOAD.B	D3,(A3+)	JUMP,EQ 75$	COMP.B	D3,#CR	JUMP,EQ 70$	COMP.B	D3,#EOP	JUMP,EQ 70$	INC.W	D2		; D2 <-- +1 caractre	CALL	EDGETLGC	; D1 <-- largeur du caractre	ADD.W	D4,D1		; D4 <-- avance dans la ligne	COMP.B	D3,#SPACE	JUMP,EQ 10$20$:	COMP.W	D4,(A6)+OLGTEXT	; largeur ligne atteinte ?	JUMP,HI 40$		; oui => 40$	LOAD.B	D3,(A3+)	JUMP,EQ 75$	COMP.B	D3,#CR	JUMP,EQ 70$	COMP.B	D3,#EOP	JUMP,EQ 70$	INC.W	D2		; D2 <-- +1 caractre	CALL	EDGETLGC	; D1 <-- largeur du caractre	ADD.W	D4,D1		; D4 <-- avance dans la ligne	COMP.B	D3,#SPACE	JUMP,NE 20$	CLR.W	D2		; D2 <-- rz avance dans mot	INC.W	D5		; D5 <-- +1 espace	JUMP	10$40$:	TEST.W	D5		; un seul mot ?	JUMP',NE 50$		; non => 50$				; oui =>	LOAD.B	D3,(-A3)	; A3 <-- recule le dernier caractre	CALL	EDGETLGC	; D1 <-- largeur du caractre	SUB.W	D4,D1		; D4 <-- recule dans la ligne	CLR.B	D6	EX.L	A3,A4		; A3 <-- ^dbut de la ligne	LOAD.W	D2,(A6)+OLGTEXT	; D2 <-- lg max coupable	CALL	EDCOUPEMOT	; essaye de couper dans le mot suivant	EX.L	A4,A3	JUMP,NE 90$	LOAD.L	A3,A4		; A3 <-- ^plus loin	LOAD.W	D4,D2		; D4 <-- largeur de la ligne	JUMP'	58$50$:	DEC.W	D5		; D5 <-- ne compte pas le dernier espace	TEST.W	D2	JUMP',EQ 54$52$:	LOAD.B	D3,(-A3)	; A3 <-- recule le dernier mot	CALL	EDGETLGC	; D1 <-- largeur du caractre	SUB.W	D4,D1		; D4 <-- recule dans la ligne	DEC.W	D2	JUMP,NE 52$54$:	LOAD.W	D2,(A6)+OLGTEXT	SUB.W	D2,D4		; D2 <-- lg max coupable	LOAD.B	D3,#SPACE	CALL	EDGETLGC	; D1 <-- largeur du dernier espace	SUB.W	D4,D1		; D4 <-- n'affiche pas le dernier espace	LOAD.B	D6,#SPACE	CALL	EDCOUPEMOT	; essaye de couper dans le mot suivant	JUMP',NE 90$	INC.W	D5		; D5 <-- un mot de plus	ADD.W	D4,D2		; D4 <-- reste	LOAD.B	D3,#SPACE	CALL	EDGETLGC	; D1 <-- largeur du dernier espace	ADD.W	D4,D158$:	LOAD.B	D6,#'-	TEST.L	D2:#16		; tiret dj dans le mot ?	JUMP',BC 90$		; non => 90$	CLR.B	D6	JUMP'	90$70$:	LOAD.B	D6,D3	JUMP'	90$75$:	DEC.L	A3		; A3 <-- ^sur le terminateur	LOAD.B	D6,#-190$:	POPM.L	D1..D3,A4	RET;-----------\\; EDCOUPEMOT >;-----------/; Essaye de couper dans un mot.;;	   D2;	|<---->|;	 construction;	 ^;	 A3; in	A3.L	^dbut du mot;	A2.L	^dans OBUGC;	D2.W	lg max coupable; out	A3.L	^aprs coupure (v.);	D2.W	lg rcupre grce  la coupure;		si 2^16 = 1 --> tiret dj dans le mot;	D7.W	ok/erreur; mod	D2.L, D7.W, A3.LEDCOUPEMOT:	PUSHM.L	D0,D1,D3,D4,D5,A1,A4,A5	LOAD.L	A1,A3		; A1 <-- ^dbut du mot	LOAD.W	D5,D2		; D5 <-- lg max coupable	TEST.B	(A6)+OCMTEXT	; autorise les divisions dans les mots ?	JUMP,F	80$		; non => 80$	COMP.W	D5,(A2)+OGCX	; reste au moins un caractre ?	JUMP,LT 80$		; non => 80$	COMP.W	(A6)+OCNTEXT,#5-1	JUMP',EQ 05$	CLR.L	D4	LOAD.W	D4,(A6)+OLGTEXT	DIV.WU	D4,D5	SR.W	D4,#2	COMP.W	D4,(A6)+OCNTEXT	JUMP,HS 80$05$:	LOAD.L	A3,#(A6)+OBUMOT	; A3 <-- ^buffer pour mot	LOAD.L	A5,#(A6)+OBULMO	; A5 <-- ^buffer pour lg caractres	LOAD.L	A4,A1		; A4 <-- ^mot	LOAD.W	D4,#LBUMOT-1	; D4 <-- nb car. max pour le mot	CLR.W	D0		; D0 <-- position dans le mot	CLR.W	D2		; D2 <-- compte nb car. avancs10$:	LOAD.B	D3,(A4+)	; D3 <-- caractre en avant	JUMP',EQ 20$	COMP.B	D3,#SPACE	; fin du mot ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D3,#CR	JUMP',EQ 20$	COMP.B	D3,#EOP	JUMP',EQ 20$	INC.W	D2		; D2 <-- +1 caractre avanc	LOAD.B	(A3+),D3	; OBUMOT <-- un caractre	LOAD.W	(A5+),D0	; OBULMO <-- position	CALL	EDGETLGC	; D1 <-- largeur du caractre	ADD.W	D0,D1		; D0 <-- position dans le mot	DEC.W	D4	JUMP,NE	10$	JUMP	80$20$:	TEST.W	D2	JUMP,EQ 80$	LOAD.L	A3,#(A6)+OBUMOT	; A3 <-- ^mot	LOAD.W	D3,D2		; D3 <-- lg mot	LOAD.L	A4,#(A6)+OBUCOUP ; A4 <-- ^buffer	LOAD.W	D4,#LBUCOUP	; D4 <-- lg buffer	COUPE_	HASH		; cherche la liste des coupures	JUMP,NE 80$; Cherche la coupure optimale dans la liste rendue.	LOAD.B	D3,#'-	CALL	EDGETLGC	; D1 <-- largeur d'un "-"	CLR.W	D430$:	INC.W	D4	TEST.B	(A4+)	JUMP,NE	30$	DEC.L	A4		; A4 <-- ^dernire coupure	LOAD.L	A5,#(A6)+OBULMO	; A5 <-- ^buffer pour lg caractres40$:	DEC.W	D4	JUMP,EQ 80$	CLR.W	D3	LOAD.B	D3,(-A4)	; D3 <-- position coupure (nb car)	JUMP,EQ 80$	JUMP',NS 50$				; coupe en ajoutant un tiret =>	SL.W	D3,#1	LOAD.W	D2,(A5)+(D3.W)	; D2 <-- lg du mot jusque l	ADD.W	D2,D1		; D2 <-- lg du mot avec le tiret	COMP.W	D2,D5		; reste assez de place en bout de ligne ?	JUMP,HI 40$		; non => 40$	SR.W	D3,#1	TCLR.L	D2:#16	JUMP'	60$50$:				; coupe sans ajouter de tiret =>	TCLR.L	D3:#7	SL.W	D3,#1	LOAD.W	D2,(A5)+(D3.W)	; D2 <-- lg du mot jusque l	COMP.W	D2,D5		; reste assez de place en bout de ligne ?	JUMP,HI 40$		; non => 40$	SR.W	D3,#1	TSET.L	D2:#1660$:	ADD.W	A1,D3		; A1 <-- ^plus loin	CLR.W	D7		; D7 <-- coupure effectue	JUMP'	90$80$:	LOAD.W	D7,#1		; D7 <-- coupure pas faite !90$:	LOAD.L	A3,A1		; A3 <-- ^v. plus loin	POPM.L	D0,D1,D3,D4,D5,A1,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; EDAFSAJEX >;----------/; Affiche un sajex.; in	D2.L	position (y;x);	D5.L	reste/nb;	D0.L	rpartiteur du reste;	A2.L	^dans OBUGC; out	D2.L	position suivante (y;x);	D5.L	nouveau reste;	D0.L	nouvelle rpartition du reste; mod	D0.L, D2.L, D5.L, D7.WEDAFSAJEX:	ADD.W	D2,D5		; D2 <-- avance selon "nb"	TEST.W	D0	JUMP',EQ 20$	DEC.W	D0	JUMP',NE 90$	SWAP.W	D0	PUSH.W	D0	SWAP.W	D0	POP.W	D0		; D0[low] <-- D0[high]20$:	SWAP.W	D5	TEST.W	D5		; encore un reste ?	JUMP',EQ 30$		; non => 30$	DEC.W	D5		; D5 <-- un reste de moins	INC.W	D2		; D2 <-- avance selon "reste"30$:	SWAP.W	D590$:	RET;--------\\; EDAFCAR >;--------/; Affiche un caractre.; in	D3.B	caractre/nil;	D2.L	position (y;x);	A2.L	^dans OBUGC;	A3.L	^aprs le caractre; out	D2.L	position suivante (y;x); mod	D2.L, D7.WEDAFCAR:	PUSHM.L	D0,D1,D3..D6,A2..A4	COMP.B	D3,#2		; cadratin ?	JUMP',NE 10$		; non => 10$	LOAD.B	D3,#SPACE	; oui => comme un espace10$:	COMP.B	D3,#CR		; fin de ligne ?	JUMP',NE 11$		; non => 11$	LOAD.B	D3,#SPACE	; oui => comme un espace11$:	COMP.B	D3,#EOP		; fin de ligne ?	JUMP',NE 12$		; non => 12$	LOAD.B	D3,#SPACE	; oui => comme un espace12$:	TEST.B	(A6)+ODTTEXT	; dtecte ?	JUMP,T	60$		; oui => 60$	TEST.B	(A6)+OQCTEXT	; dplace le curseur ?	JUMP,T	60$		; oui => 60$	PUSH.L	D2		; stack <-- position (y;x)	LOAD.L	D4,D2		; D4 <-- position (y;x)	ADD.W	D4,(A6)+OPOTEXT+2	SWAP.W	D4	ADD.W	D4,(A6)+OPOTEXT+0	SWAP.W	D4	LOAD.L	A3,(A2)+OGCPT	; A3 <-- ^gencar	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	CLR.W	D0	LOAD.B	D0,D3		; D0 <-- code du caractre; Vrifie si le caractre fait partie des caractres contenus; dans le gnrateur.	CLR.W	D6		; D6 <-- largeur du caractre	CLR.B	D2		; D2 <-- op de non inversion	TCLR.L	D0:#7		; caractre  inverser ?	JUMP',BC 30$		; non => 30$	NOT.B	D2		; D2 <-- op d'inversion30$:	COMP.B	D0,(A3)+OGCLCA	; code caractre trop grand ?	JUMP,HI 50$		; oui => 50$	SUB.B	D0,(A3)+OGCFCA	; code caractre trop petit ?	JUMP,LO 50$		; oui => 50$; Cherche les informations utiles dans les 3 tables d'entte; du gnrateur (largeur, hauteur 1 et 2).	LOAD.W	D3,(A3)+OGCMHD	; D3 <-- hauteur totale matrice	SWAP.W	D3	LOAD.L	A4,#(A3)+OGCWID	; A4 <-- ^table des largeurs	CLR.W	D3	LOAD.B	D3,(A4)+(D0.W)	; D3 <-- largeur matrice	PUSH.W	D3		; stack <-- largeur caractre	CLR.L	D1	LOAD.B	D1,(A3)+OGCLCA	SUB.B	D1,(A3)+OGCFCA	INC.B	D1		; D1 <-- nb car dans gnrateur	ADD.L	A4,D1		; skip width(s)	ADD.L	A4,D1		; swip heigth(s) above baseline	ADD.L	A4,D1		; swip heigth(s) under baseline	MUL.WU	D0,(A3)+OGCMSB	; * matrix size (in bytes)	ADD.L	A4,D0		; A4 <-- ^matrix dans GENCAR	LOAD.W	D1,#SETDOT!PENDOT ; D1 <-- mode d'affichage	CLR.L	D5	LOAD.B	D5,(A3)+OGCMWB	; D5 <-- incrment Y ds GENCAR	PUSH.L	A0	LOAD.L	A0,(A6)+OMATRIX	CALL	(A0)		; appel de GRA_MATRIX	POP.L	A0	POP.W	D6		; D6 <-- largeur caractre	ADD.W	D6,(A6)+OICTEXT	; D6 <-- ajoute l'intercaractre	JUMP',NC 50$	CLR.W	D650$:	POP.L	D2		; D2 <-- position (y;x)	ADD.W	D2,D6		; D2 <-- avance dans la ligne	JUMP	90$60$:				; dtecte =>	CALL	EDGETLGC	; D1 <-- largeur du caractre	TEST.B	(A6)+OQCTEXT	; dplace le curseur ?	JUMP',T	80$		; oui => 80$	LOAD.L	D4,D2		; D4 <-- position (y;x)	ADD.W	D4,(A6)+OPOTEXT+2	SWAP.W	D4	ADD.W	D4,(A6)+OPOTEXT+0	SWAP.W	D4	LOAD.L	D0,(A6)+OPSTEXT	; D0 <-- position de la souris	COMP.W	D0,D4		; trop  gauche ?	JUMP',LT 80$	ADD.W	D4,D1	COMP.W	D0,D4		; trop  droite ?	JUMP',GE 80$	SWAP.W	D0	SWAP.W	D4	COMP.W	D0,D4		; trop en haut ?	JUMP',LT 80$	ADD.W	D4,(A2)+OGC1Y	ADD.W	D4,(A2)+OGC2Y	COMP.W	D0,D4		; trop en bas ?	JUMP',GE 80$	LOAD.L	A4,(A6)+OPTTEXT	DEC.L	A3	SUB.L	A3,A4	LOAD.W	(A6)+OCUTEXT,A3	; OCUTEXT <-- position du curseur80$:	ADD.W	D2,D1		; D2 <-- avance dans la ligne90$:	POPM.L	D0,D1,D3..D6,A2..A4	RET;---------\\; EDGETLGC >;---------/; Calcule la largeur d'un caractre  chasse variable.; in	D3.B	caractre;	A2.L	^dans OBUGC; out	D1.W	largeur du caractre; mod	D1.L, D7.WEDGETLGC:	PUSHM.L	D3,A3	CLR.W	D1		; D1 <-- largeur nulle	COMP.B	D3,#2		; cadratin ?	JUMP',NE 10$		; non => 10$	LOAD.B	D3,#SPACE	; oui => comme un espace10$:	COMP.B	D3,#CR		; fin de ligne ?	JUMP',NE 11$		; non => 11$	LOAD.B	D3,#SPACE	; oui => comme un espace11$:	COMP.B	D3,#EOP		; fin de ligne ?	JUMP',NE 12$		; non => 12$	LOAD.B	D3,#SPACE	; oui => comme un espace12$:	AND.W	D3,#H'7F	LOAD.L	A3,(A2)+OGCPT	; A3 <-- ^gencar	COMP.B	D3,(A3)+OGCLCA	; aprs le dernier caractre ?	JUMP',HI 90$	SUB.B	D3,(A3)+OGCFCA	; avant le premier caractre ?	JUMP',LO 90$	LOAD.L	A3,#(A3)+OGCWID	; A3 <-- ^table des largeurs	CLR.W	D1	LOAD.B	D1,(A3)+(D3.W)	; D1 <-- largeur	ADD.W	D1,(A6)+OICTEXT	; D1 <-- ajoute l'intercaractre	JUMP',NC 90$	CLR.W	D190$:	POPM.L	D3,A3	RET;------------\\; SEARCHPVIDE >;============/; Cherche la plus grande place vide dans une ligne permettant de; placer du texte.; in	A4.L	^matrice;	D3.L	origine sup/gauche (y;x);	D4.L	dimensions (dy;dx); out	D1.L	offset/largeur maximale; mod	D1.L, D7.WSEARCHPVIDE:	PUSHM.L	D0,D2..D6,A3,A4; Augmente ventuellement les dimensions de la zone rectangulaire s'il; existe un espace autour du contour.	CLR.L	D6		; D6 <-- ajustages gauche/droite	CLR.W	D2	COMP.W	(A6)+OCXTEXT,#5-1	JUMP',EQ 06$	LOAD.W	D2,(A6)+OCXTEXT	; D2 <-- espace pour contour	MUL.WU	D2,#1006$:	ADD.W	D4,D2	ADD.W	D4,D2		; D4 <-- largeur + espace pour contour	SUB.W	D3,D2		; D3 <-- origine - espace pour contour	JUMP',NC 10$	NEG.W	D3	SWAP.W	D6	LOAD.W	D6,D3		; D6 <-- ajustage gauche (>0)	SWAP.W	D6	SUB.W	D4,D3	CLR.W	D310$:	LOAD.W	D1,(A6)+OMALMX	SUB.W	D1,D3	COMP.W	D4,D1	JUMP',LS 11$	LOAD.W	D6,D4	SUB.W	D6,D1		; D6 <-- ajustage droite (>0)	LOAD.W	D4,D111$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A6)+OCYTEXT	MUL.WU	D2,#5	ADD.W	D4,D2	ADD.W	D4,D2		; D4 <-- hauteur + espace pour contour	SUB.W	D3,D2		; D3 <-- origine - espace pour contour	JUMP',NC 12$	ADD.W	D4,D3	CLR.W	D312$:	LOAD.W	D1,(A6)+OMALMY	SUB.W	D1,D3	COMP.W	D4,D1	JUMP',LS 13$	LOAD.W	D4,D113$:	SWAP.W	D4	SWAP.W	D3; Arrondi position et dimension en X sur des multiples de 8 points (un byte).	LOAD.W	D5,D4		; D5 <-- largeur exacte	LOAD.W	D0,D3	AND.W	D0,#B'111	; D0 <-- correction pour origine	SUB.W	D3,D0		; D3 <-- origine en X arrondie	ADD.W	D4,D0	ADD.W	D4,#8-1	AND.B	D4,#B'11111000	; D4 <-- largeur dx arrondie; Calcule l'adresse du byte en haut  gauche.	LOAD.W	D1,(A6)+OMANBB	SR.W	D3,#3	ADD.W	A4,D3	SWAP.W	D3	MUL.WU	D3,D1	ADD.L	A4,D3		; A4 <-- ^byte en haut  gauche; Construit la ligne de bits.	CLR.B	D2	LOAD.L	A3,#(A6)+OBLTEXT	SR.W	D4,#3		; D4 <-- largeur en bytes	COMP.W	D4,#LBLTEXT	JUMP',LS 20$	LOAD.W	D4,#LBLTEXT20$:	PUSHM.L	D4,A4	CLR.B	D3	SWAP.W	D4		; D4 <-- hauteur	DEC.W	D4		; D4 <-- -1  cause NMO25$:	OR.B	D3,(A4)	ADD.W	A4,D1		; A4 <-- ^byte en dessous	DECJ.W,NMO D4,25$	LOAD.B	(A3+),D3	; buffer <-- 8 points d'une ligne	OR.B	D2,D3		; D2 <-- permet de savoir si tout est  zro	POPM.L	D4,A4	INC.L	A4		; A4 <-- ^byte  droite	DEC.W	D4	JUMP,NE 20$	COMP.W	(A6)+OCXTEXT,#5-1	JUMP',NE 30$	CLR.L	D1	TEST.B	D2		; est-ce que tout est  zro ?	JUMP,NE 90$		; non => 90$; Cherche l'espace vide le plus grand dans la ligne de points.30$:	LOAD.L	A3,#(A6)+OBLTEXT	CLR.L	D1		; D1 <-- largeur maximale	LOAD.W	D3,D0		; D3 <-- origine	DEC.W	D3	TEST.W	D0	JUMP',NE 40$	DEC.L	A340$:	INC.W	D3	LOAD.B	D4,D3	AND.B	D4,#B'111	JUMP',NE 41$	INC.L	A341$:	DEC.W	D5	JUMP',NS 52$	LOAD.B	D4,D3	NOT.B	D4	TEST.B	(A3):D4	JUMP,BS 40$	LOAD.W	D2,D3	SUB.W	D2,D0		; D2 <-- offset	SWAP.W	D2	CLR.W	D2		; D2 <-- largeur45$:	INC.W	D2		; D2 <-- augmente la largeur	INC.W	D3	LOAD.B	D4,D3	AND.B	D4,#B'111	JUMP',NE 46$	INC.L	A346$:	DEC.W	D5	JUMP',NS 50$	LOAD.B	D4,D3	NOT.B	D4	TEST.B	(A3):D4	JUMP,BC 45$	COMP.W	D1,D2	JUMP,HS 40$	LOAD.L	D1,D2		; D1 <-- offset/largeur maximale	JUMP	40$50$:	COMP.W	D1,D2	JUMP',HS 52$	LOAD.L	D1,D2		; D1 <-- offset/largeur maximale52$:	LOAD.W	D2,(A6)+OCXTEXT	; D2 <-- espace pour contour	COMP.W	D2,#5-1	JUMP',EQ 90$	MUL.WU	D2,#10	ADD.W	D1,D6		; D1 <-- ajoute ajustage droite	SWAP.W	D6	ADD.W	D1,D6		; D1 <-- ajoute ajustage gauche	SUB.W	D1,D2	SUB.W	D1,D2		; D1 <-- largeur	JUMP',NC 90$	CLR.W	D190$:	POPM.L	D0,D2..D6,A3,A4	RET;--------\\; CLRPAVE >;========/; Efface tous les pavs de texte.; in	-; out	-; mod	D7.WCLRPAVE:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OTAPAVE	LOAD.W	D3,#NBPAVE-110$:	CLR.L	(A3)+OPAPOS	ADD.L	A3,#LPA	DECJ.W,NMO D3,10$	POPM.L	D3,A3	RET;--------\\; OPEPAVE >;========/; Ouvre un pav de texte.; in	D3.W	numro du pav; out	D7.W	erreur; mod	D7.WOPEPAVE:	PUSHM.L	D3,D4,A3	LOAD.W	D7,#1	COMP.W	D3,#NBPAVE	JUMP',HS 90$	LOAD.W	D4,D3	MUL.WU	D3,#LPA	LOAD.L	A3,#(A6)+OTAPAVE	ADD.L	A3,D3	TEST.L	(A3)+OPAPOS	JUMP',EQ 90$	LOAD.L	(A6)+OPOTEXT,(A3)+OPAPOS	LOAD.L	(A6)+OHTTEXT,(A3)+OPADIM	LOAD.L	(A6)+OOPTEXT,(A3)+OPAOPO	LOAD.L	(A6)+OOHTEXT,(A3)+OPAODI	CLR.B	(A6)+O3PTEXT	; 3me poigne n'existe pas	CALL	MAXPAVE	DEC.W	D3		; D3 <-- numro du dernier pav	COMP.W	D3,D4		; est-on dans le dernier pav ?	JUMP',EQ 80$		; oui => 80$				; non =>	SET.B	(A6)+O3PTEXT	; 3me poigne existe80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOPAVE >;========/; Ferme un pav de texte.; in	D3.W	numro du pav; out	-; mod	D7.WCLOPAVE:	PUSHM.L	D3,A3	MUL.WU	D3,#LPA	LOAD.L	A3,#(A6)+OTAPAVE	ADD.L	A3,D3	LOAD.L	(A3)+OPAPOS,(A6)+OPOTEXT	LOAD.L	(A3)+OPADIM,(A6)+OHTTEXT	LOAD.L	(A3)+OPAOPO,(A6)+OOPTEXT	LOAD.L	(A3)+OPAODI,(A6)+OOHTEXT	POPM.L	D3,A3	RET;--------\\; MAXPAVE >;========/; Donne le numro du prochain pav libre.; in	-; out	D3.W	numro du pav;	D7.W	erreur; mod	D3.L, D7.WMAXPAVE:	PUSH.L	A3	LOAD.L	A3,#(A6)+OTAPAVE	CLR.W	D310$:	TEST.L	(A3)+OPAPOS	; pav libre ?	JUMP',EQ 50$	ADD.L	A3,#LPA	INC.W	D3	JUMP	10$50$:	LOAD.W	D7,#1	COMP.W	D3,#NBPAVE	JUMP',HS 90$	CLR.W	D790$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET	.END