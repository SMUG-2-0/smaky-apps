	.SBTTL	DESIOBDBAUTO	=	15		; mode de sauvetage automatiqueBDBDEF	=	14		; sauve les dfinitionsBDBNMAJ	=	13		; touche (MET A JOUR) grisePREND:	CLR.B	(A6)+OBUFINPRENDL:	LOAD.L	A3,#(A6)+OBUFIN	CALL	DBOXEDITI	JUMP,NE _ERROR	COMP.W	D3,#F0	JUMP,EQ _LOOP	LOAD.W	D0,#1		; D0 <-- avant de reprendre	CALL	DBOXSAVE	; sauve si ncessaire le dessin actuel	JUMP',EQ PRENDF		; ok => PRENDF	COMP.W	D7,#1		; (ANNULE) ?	JUMP,EQ _LOOP		; oui => _LOOP	JUMP	_ERROR		; non => _ERRORPRENDF:	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .IMAGE	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre l'image	JUMP',EQ 20$	COMP.W	D7,#ERKSTO	JUMP,EQ _LOOP	PUSH.W	D7	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	PRENDL20$:	LOAD.L	A2,#(A6)+OBUHIMA ; A2 <-- ^en-tte image	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 26$	COMP.B	(A4)+0,#H'82	; commence par en-tte binaire ?	JUMP',NE 22$		; non => 22$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute l'en-tte binaire	JUMP,NE 26$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 26$22$:	LOAD.W	D3,(A4)+OIMDLX	; D3 <-- largeur de l'image	LOAD.W	D4,(A4)+OIMDLY	; D4 <-- hauteur de l'image	CALL	NEWMEMMATRIX	; demande mmoire pour nouvelle image	JUMP,NE 26$	LOAD.L	A4,(A6)+OPMAT	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- taille de l'image	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 24$		; oui => 24$				; non =>	FOS	?RDBYTE		; lit tout le data de l'image	JUMP'	26$24$:				; image code =>	LOAD.L	A3,A4		; A3 <-- ^pour image dcode	LOAD.L	A4,#(A4)-IMLBUF	; A4 <-- ^pour image code	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 26$	GRA_	DECOIMA		; dcode l'image ...26$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7	JUMP,NE _ERROR	CALL	MATRIXEVEN	; rend toutes les lignes multiples de 16 points	LOAD.L	A3,#(A6)+OBUFIN	CALL	INDEF		; lit le fichier .DDES	JUMP',EQ 28$	LOAD.W	D4,#SCALE11	CLR.L	(A6)+OPMOVY	CLR.L	(A6)+OPMDIY	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices28$:	LOAD.L	A3,#(A6)+OBUFIN	CALL	SAVFILE		; OBUNAME <-- nom	CALL	DESINFFILE	; affiche le nom dans les infos	CLR.B	(A6)+OMAJ	; le dessin est  jour	JUMP	_LOOPPRENDBLOC:	TEST.W	(A6)+OCHBLOC	; module BLOC charg ?	JUMP,EQ _BIP		; non => BIP	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	RDOPEN		; dbut de la lecture (IMAG)	JUMP,NE _BIP	LOAD.L	A2,#(A6)+OBUHIMA ; A2 <-- ^en-tte image	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	BLOC_	RDDATA		; lit l'en-tte	JUMP',NE 26$	LOAD.W	D3,(A4)+OIMDLX	; D3 <-- largeur de l'image	LOAD.W	D4,(A4)+OIMDLY	; D4 <-- hauteur de l'image	CALL	NEWMEMMATRIX	; demande mmoire pour nouvelle image	JUMP',NE 26$	LOAD.L	A4,(A6)+OPMAT	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- taille de l'image	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 24$		; oui => 24$				; non =>	BLOC_	RDDATA		; lit tout le data de l'image	JUMP'	26$24$:				; image code =>	LOAD.L	A3,A4		; A3 <-- ^pour image dcode	LOAD.L	A4,#(A4)-IMLBUF	; A4 <-- ^pour image code	BLOC_	RDDATA		; lit toute l'image code	JUMP',NE 26$	GRA_	DECOIMA		; dcode l'image ...26$:	PUSH.W	D7	BLOC_	RDCLOSE		; ferme le bloc-notes	POP.W	D7	JUMP,NE _BIP	CALL	MATRIXEVEN	; rend toutes les lignes multiples de 16 points	LOAD.W	D4,#SCALE11	CLR.L	(A6)+OPMOVY	CLR.L	(A6)+OPMDIY	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	SET.B	(A6)+OMAJ	; le dessin n'est pas  jour	JUMP	_LOOPCLASSEUR:	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN1	CALL	DBOXPOS3	; D3 <-- centre de la dbox	BLOC_	VISU		; accs au classeur ...	PUSH.W	D7	CALL	DBOXCLOSE1	; refait les soft-keys	POP.W	D7	JUMP,NE _BIP	COMP.W	D3,#F1	JUMP,NE _LOOP	JUMP'	COLLECOUPE:	CALL	WRIMAGEBLOC	; met l'image dans le bloc-notes	JUMP,NE _BIP	JUMP	_EFFACEICOPIE:	CALL	WRIMAGEBLOC	; met l'image dans le bloc-notes	JUMP,NE _BIP	JUMP	_LOOPCOLLE:	TEST.W	(A6)+OCHBLOC	; module BLOC charg ?	JUMP,EQ _BIP		; non => BIP	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	RDTEST		; type "IMAG" existe ?	JUMP',EQ COLLEIM	LOAD.L	D3,#H'1000000*'T+H'10000*'E+H'100*'X+H'1*'T	BLOC_	RDTEST		; type "TEXT" existe ?	JUMP,NE _BIPCOLLETX:	LOAD.B	D3,#1		; D3 <-- colle	JUMP	TEXTECOLLEIM:	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	RDOPEN		; dbut de la lecture (IMAG)	JUMP,NE _BIP	LOAD.L	A2,#(A6)+OBUHIMA ; A2 <-- ^en-tte image	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	BLOC_	RDDATA		; lit l'en-tte	JUMP,NE CLOSE$	LOAD.W	D7,#ERKSTO	LOAD.L	D1,(A6)+OPMDIY	CALL	D1SCALEN	; D1 <-- agrandi si "tout"	LOAD.W	D7,#ERDIOUT	COMP.W	D1,(A6)+OBUHIMA+OIMDLX ; image trop large ?	JUMP,LS BIG$	SWAP.W	D1	COMP.W	D1,(A6)+OBUHIMA+OIMDLY ; image trop haute ?	JUMP,LS BIG$	LOAD.L	A3,(A6)+OPMAT	LOAD.L	A4,(A6)+OPMAC	CALL	XFERALL		; matrice copie <-- matrice principale	LOAD.L	A4,(A6)+OPMAM	CALL	CLEARALL	; efface toute la matrice masque	SET.B	(A6)+OMAJ	; une mise  jour sera ncessaire	CLR.L	D3	LOAD.L	A1,(A6)+OPMAM	CALL	TESTPOINT	; A1 <-- ^byte sup/gauche dans matrice	JUMP',NE CLOSE$	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- taille de l'image	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 24$		; oui => 24$				; non =>	LOAD.L	A4,A1	BLOC_	RDDATA		; lit le data	JUMP'	CLOSE$24$:	LOAD.L	A3,A1		; A3 <-- ^pour image dcode	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^pour image code	BLOC_	RDDATA		; lit le data	JUMP',NE CLOSE$	GRA_	DECOIMA		; dcode l'image ...CLOSE$:	PUSH.W	D7	BLOC_	RDCLOSE		; fin de la lecture	POP.W	D7	JUMP,NE _BIP	JUMP	AJOUTEDATABIG$:	BLOC_	RDCLOSE		; fin de la lecture	CALL	IFVIDE		; image toute blanche (vide) ?	JUMP,NE _BIP		; non => BIP	JUMP	PRENDBLOCAJOUTE:	LOAD.L	A3,#(A6)+OBUFAJ	CALL	DBOXEDITA	JUMP,NE _ERROR	COMP.W	D3,#F0	JUMP,EQ _LOOP	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .IMAGE	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre l'image	JUMP',EQ 20$	COMP.W	D7,#ERKSTO	JUMP,EQ _LOOP	PUSH.W	D7	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	AJOUTE20$:	LOAD.L	A2,#(A6)+OBUHIMA ; A2 <-- ^en-tte image	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 26$	COMP.B	(A4)+0,#H'82	; commence par en-tte binaire ?	JUMP',NE 22$		; non => 22$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute l'en-tte binaire	JUMP,NE 26$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 26$22$:	LOAD.L	D1,(A6)+OPMDIY	CALL	D1SCALEN	; D1 <-- agrandi si "tout"	LOAD.W	D7,#ERDIOUT	COMP.W	D1,(A6)+OBUHIMA+OIMDLX ; image trop large ?	JUMP,LS 26$	SWAP.W	D1	COMP.W	D1,(A6)+OBUHIMA+OIMDLY ; image trop haute ?	JUMP,LS 26$	LOAD.L	A3,(A6)+OPMAT	LOAD.L	A4,(A6)+OPMAC	CALL	XFERALL		; matrice copie <-- matrice principale	LOAD.L	A4,(A6)+OPMAM	CALL	CLEARALL	; efface toute la matrice masque	SET.B	(A6)+OMAJ	; une mise  jour sera ncessaire	CLR.L	D3	LOAD.L	A1,(A6)+OPMAM	CALL	TESTPOINT	; A1 <-- ^byte sup/gauche dans matrice	JUMP',NE 26$	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- taille de l'image	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 24$		; oui => 24$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP'	26$24$:	LOAD.L	A3,A1		; A3 <-- ^pour image dcode	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^pour image code	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 26$	GRA_	DECOIMA		; dcode l'image ...26$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7	JUMP,NE _ERROR; Dplace chaque ligne de l'image pour avoir OMANBB bytes; d'une ligne  l'autre.AJOUTEDATA:	LOAD.L	A3,A1	LOAD.W	D3,(A2)+OIMDLX	MUL.WU	D3,(A2)+OIMDLY	SR.L	D3,#3	ADD.L	A3,D3		; A3 <-- ^fin de l'image lue	LOAD.L	A4,A1	LOAD.W	D3,(A6)+OMANBB	MUL.WU	D3,(A2)+OIMDLY	ADD.L	A4,D3		; A4 <-- ^fin o mettre l'image	LOAD.W	D3,(A2)+OIMDLX	SR.W	D3,#3	SUB.W	D3,(A6)+OMANBB	NEG.W	D3	SUB.W	A4,D3		; A4 <-- cale l'image  gauche	LOAD.W	D3,(A2)+OIMDLY	; D3 <-- compteur vertical	DEC.W	D350$:	LOAD.W	D4,(A2)+OIMDLX	SR.W	D4,#3		; D4 <-- compteur horizontal	DEC.W	D4	PUSH.L	A4	CLR.B	(A4)52$:	LOAD.B	(-A4),(-A3)	; dplace une ligne	DECJ.W,NMO D4,52$	POP.L	A4	SUB.W	A4,(A6)+OMANBB	DECJ.W,NMO D3,50$; Dplace le dessin ajout selon la souris ...	LOAD.W	D4,(A6)+OBUHIMA+OIMDLY	SWAP.W	D4	LOAD.W	D4,(A6)+OBUHIMA+OIMDLX ; D4 <-- dimensions de l'image	LOAD.B	D0,#ICOAJOUTEAJDEPL:	LOAD.L	D1,(A6)+OPMOVY	; D1 <-- coin sup/gauche	CALL	D1SCALEN	; D1 <-- plus grand si "tout"	LOAD.L	D2,D1	ADD.W	D1,D4	SWAP.W	D4	SWAP.W	D1	ADD.W	D1,D4		; D1 <-- coin inf/droite (o est la souris)	SWAP.W	D4	SWAP.W	D1	CLR.L	D5		; D5 <-- coin sup/gauche dans OPMAM	LOAD.L	D6,D4		; D6 <-- coin inf/droite dans OPMAM	CLR.L	D4	EX.L	D1,D4	CALL	D1SCALEP	; D1 <-- plus petit si "tout"	EX.L	D4,D1	ADD.W	D4,(A6)+OGMPOX	SWAP.W	D4	ADD.W	D4,(A6)+OGMPOY	SWAP.W	D4	CALL	PMOUSE		; positionne souris dans coin inf/droite	LOAD.B	D3,D0	CLR.L	D0	CLR.B	(A6)+ODDOP	CALL	SELMO		; utilise une jolie icne	JUMP	ZONEMOVESCAN:	LOAD.L	D6,(A6)+OCASCAN	; D6 <-- canal SCAN	JUMP,EQ	_BIP		; scanner absent => BIP	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve tout l'cran	JUMP,NE	_BIP	CLR.B	D3	CALL	SELMO		; outil = flche	LOAD.L	D1,(A6)+OPMDIY	CALL	D1SCALEN	; D1 <-- agrandi si "tout"	LOAD.L	D4,D1		; D4 <-- dimensions maximales	CLR.L	D3		; D3 <-- mode	SCAN_	READ		; lit une image avec le scanner ...	LOAD.L	A2,A4		; A2 <-- ^image	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue tout l'cran	CALL	AFMENU		; refait les soft-keys	TEST.L	D4		; y a-t-il une image lue ?	JUMP,EQ	_LOOP		; non => LOOP	LOAD.L	D1,(A6)+OPMDIY	CALL	D1SCALEN	; D1 <-- agrandi si "tout"	LOAD.W	D7,#ERDIOUT	COMP.W	D1,D4		; image trop large ?	JUMP,LS 40$	SWAP.W	D1	SWAP.W	D4	COMP.W	D1,D4		; image trop haute ?	JUMP,LS 40$	SWAP.W	D4	LOAD.L	A3,(A6)+OPMAT	LOAD.L	A4,(A6)+OPMAC	CALL	XFERALL		; matrice copie <-- matrice principale	LOAD.L	A4,(A6)+OPMAM	CALL	CLEARALL	; efface toute la matrice masque	SET.B	(A6)+OMAJ	; une mise  jour sera ncessaire	CLR.L	D3	LOAD.L	A1,(A6)+OPMAM	CALL	TESTPOINT	; A1 <-- ^byte sup/gauche dans matrice	JUMP',NE 40$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	(A3)+6,A2	; source: <pppp>	LOAD.W	(A3)+10,D5	; source: <ii>	CLR.L	(A3)+12		; destination: <xx> et <yy>	LOAD.L	(A3)+16,A1	; destination: <pppp>	LOAD.W	(A3)+20,(A6)+OMANBB ; destination: <ii>	SWAP.W	D4	LOAD.L	(A3)+22,D4	; <dxx> et <dyy>	SWAP.W	D4	LOAD.B	(A3)+26,#LOADDOT ; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; transfert	CLR.W	D740$:	PUSH.W	D7	SCAN_	RELEASE		; libre l'image lue	POP.W	D7	JUMP,NE _ERROR	LOAD.B	D0,#ICOSCAN	JUMP	AJDEPLIMPRIME:	CLR.L	D3		; D3 <-- mode	TSET.L	D3:#BPRNOFILE	; D3 <-- pas de fichier en sortie	TSET.L	D3:#BPRNOINTERV	; D3 <-- pas de page de ..  ..	TSET.L	D3:#BPRCHOIX	; D3 <-- case (CHOIX) active	LOAD.L	A3,#(A6)+OBUNAME ; A3 <-- ^nom du fichier	LOAD.L	A4,#(A6)+OBUPRES ; A4 <-- ^nom de la prsentation	CLR.B	(A4)	LOAD.L	A5,#R16"00$	; A5 <-- ^nom du logiciel	CLR.L	D2		; D2 <-- longueur du document (!)	LOAD.L	A2,(A6)+OCAPRINT	CALL	DBOXOPEN1	PRINTA_	OPPRINT		; ouvre l'impression	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	JUMP,NE _ERROR	CALL	WAITMOUSE	; met le sablier	CALL	PRIMAGE		; imprime l'image	JUMP,NE _ERROR	JUMP	_LOOP00$:	.ASCIZ	"DESSIN"	.EVENSAUVE:	CLR.W	D2		; D2 <-- mode manuel	CALL	SAUVETOUT	; sauve toute l'image	JUMP,NE _ERROR	JUMP	_LOOP;----------\\; SAUVETOUT >;==========/; Sauve toute l'image.; in	D2.W	mode; out	D7.W	erreur; mod	D7.WSAUVETOUT:	PUSHM.L	D0..D5,A3,A4	LOAD.L	A3,#(A6)+OBUFOUT	CALL	GETFILE		; OBUFOUT <-- OBUNAME	CLR.L	D5	TEST.B	(A6)+OMAJ	; mise  jour ncessaire ?	JUMP',F	10$		; non => 10$				; oui =>	CALL	IFVIDE		; dessin vide ?	JUMP',NE 11$		; non => 11$10$:	TSET.L	D2:#BDBNMAJ	; D2 <-- touche (MET A JOUR) grise11$:	LOAD.L	A3,#(A6)+OBUFOUT	LOAD.L	D4,D5		; D4 <-- fanions	CALL	DBOXEDITO	JUMP,NE 95$	COMP.W	D3,#F0	JUMP,EQ 95$	LOAD.W	D1,D3		; D1 <-- F1/F4	LOAD.L	D5,D4		; D5 <-- fanions	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier avec extension20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP,EQ 50$		; ok => 50$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	TEST.L	D2:#BDBAUTO	; sauvetage automatique ?	JUMP',BS 40$		; oui => 40$	COMP.W	D1,#F4		; touche (MET A JOUR) ?	JUMP',EQ 40$		; oui => 40$	CALL	NORMMOUSE	; remet la flche	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE 90$	COMP.W	D3,#'O	JUMP,NE 10$40$:	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE 90$	JUMP	20$50$:	CALL	WAITMOUSE	; met le sablier	CALL	WRIMAGE		; crit l'image	JUMP',NE 90$	TEST.L	D2:#BDBDEF	; sauve les dfinitions ?	JUMP',BC 90$		; non => 90$	CALL	OUTDEF		; oui => crit le fichier .DDES90$:	TEST.W	D7		; ok =	JUMP',NE 95$		; non => 90$	LOAD.L	A3,#(A6)+OBUFOUT	CALL	SAVFILE		; OBUNAME <-- nom	CALL	DESINFFILE	; affiche le nom dans les infos	CLR.B	(A6)+OMAJ	; le dessin est  jour	CLR.W	D7		; D7 <-- ok95$:	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------;; SAUVERECT ;;===========;; Sauve sur disque le contenu d'une zone rectangulaire.; in	D1.L	coin sup/gauche (y;x);	D2.L	dimensions (dy;dx)SAUVERECT:	LOAD.W	D3,D1	AND.B	D1,#B'11111000	; D1 <-- modulo 8 en X !	SUB.W	D3,D1	ADD.W	D2,D3	ADD.W	D2,#8-1	AND.B	D2,#B'11111000	TEST.W	D2	JUMP,EQ _BIP	SWAP.W	D1	SWAP.W	D2	LOAD.W	D3,D1	AND.B	D1,#B'11111110	; D1 <-- modulo 2 en Y !	SUB.W	D3,D1	ADD.W	D2,D3	ADD.W	D2,#2-1	AND.B	D2,#B'11111110	TEST.W	D2	JUMP,EQ _BIP	SWAP.W	D1	SWAP.W	D2	CLR.B	(A6)+OBUFOUT	CLR.L	D510$:	LOAD.L	A3,#(A6)+OBUFOUT	LOAD.L	D4,D5		; D4 <-- fanions	CALL	DBOXEDITE	JUMP,NE _ERROR	COMP.W	D3,#F0	JUMP,EQ _LOOP	LOAD.L	D5,D4		; D5 <-- fanions	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .IMAGE20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP',EQ 30$		; ok => 30$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	_ERROR		; non => _ERROR				; oui =>	CALL	NORMMOUSE	; remet la flche	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE _ERROR	COMP.W	D3,#'O	JUMP,NE 10$	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE _ERROR	JUMP	20$30$:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre l'image	JUMP,NE _ERROR	LOAD.L	A2,#(A6)+OBUHIMA+LGHIMA	LOAD.W	D4,#LGHIMA-135$:	CLR.B	(-A2)		; en-tte <-- rempli de zro	DECJ.W,NMO D4,35$	LOAD.B	(A2)+OIMTYP,#H'81	LOAD.B	(A2)+OIMCOD,#H'00	LOAD.B	(A2)+OIMBIP,#H'01	LOAD.B	(A2)+OIMDIR,#H'02	CLR.L	D0	LOAD.W	D0,D2	SR.W	D0,#3		; D0 <-- largeur en bytes	LOAD.W	(A2)+OIMDLX,D2	SWAP.W	D2	LOAD.W	(A2)+OIMDLY,D2	LOAD.W	D3,D2	SWAP.W	D2	MUL.WU	D3,D0	LOAD.L	(A2)+OIMNBB,D3; Compresse l'image pour mettre les lignes bout  bout.	LOAD.L	D3,D1		; D3 <-- coordonne coin sup/gauche	LOAD.L	A1,(A6)+OPMAM	; A1 <-- ^matrice masque	CALL	TESTPOINT	; A1 <-- ^byte sup/gauche dans matrice	JUMP,NE 80$	LOAD.L	A3,A1	LOAD.L	A4,A1	LOAD.W	D3,(A2)+OIMDLY	; D3 <-- compteur vertical	DEC.W	D340$:	LOAD.W	D4,(A2)+OIMDLX	SR.W	D4,#3		; D4 <-- compteur horizontal	DEC.W	D4	PUSH.L	A442$:	LOAD.B	(A3+),(A4+)	; dplace une ligne	DECJ.W,NMO D4,42$	POP.L	A4	ADD.W	A4,(A6)+OMANBB	DECJ.W,NMO D3,40$	LOAD.L	A3,A1		; A3 <-- ^image dcode	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^pour image code	GRA_	CODEIMA		; code l'image ...	JUMP',NE 50$				; crit une image code =>	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE 80$	LOAD.L	A4,#(A1)-IMLBUF	LOAD.L	D4,(A2)+OIMNBB	FOS	?WRBYTE		; crit l'image code	JUMP'	70$50$:				; crit une image dcode =>	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE 80$	LOAD.L	A4,A1	LOAD.L	D4,(A2)+OIMNBB	FOS	?WRBYTE		; crit l'image dcode70$:	FOS	?CLOSE		; ferme l'image	JUMP,NE _ERROR	JUMP	_LOOP80$:				; erreur =>	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7	JUMP	_ERROR;----------\\; SAUVEBLOC >;==========/; Sauve dans le bloc-notes le contenu d'une zone rectangulaire.; in	D1.L	coin sup/gauche (y;x);	D2.L	dimensions (dy;dx); out	D7.W	erreur; mod	D7.WSAUVEBLOC:	PUSHM.L	D0..D4,A1..A4	CALL	WAITMOUSE	; met le sablier	LOAD.W	D7,#ERKSTO	LOAD.W	D3,D1	AND.B	D1,#B'11111000	; D1 <-- modulo 8 en X !	SUB.W	D3,D1	ADD.W	D2,D3	ADD.W	D2,#8-1	AND.B	D2,#B'11111000	TEST.W	D2	JUMP,EQ EXIT$	SWAP.W	D1	SWAP.W	D2	LOAD.W	D3,D1	AND.B	D1,#B'11111110	; D1 <-- modulo 2 en Y !	SUB.W	D3,D1	ADD.W	D2,D3	ADD.W	D2,#2-1	AND.B	D2,#B'11111110	TEST.W	D2	JUMP,EQ EXIT$	SWAP.W	D1	SWAP.W	D2	LOAD.L	A2,#(A6)+OBUHIMA+LGHIMA	LOAD.W	D4,#LGHIMA-135$:	CLR.B	(-A2)		; en-tte <-- rempli de zro	DECJ.W,NMO D4,35$	LOAD.B	(A2)+OIMTYP,#H'81	LOAD.B	(A2)+OIMCOD,#H'00	LOAD.B	(A2)+OIMBIP,#H'01	LOAD.B	(A2)+OIMDIR,#H'02	CLR.L	D0	LOAD.W	D0,D2	SR.W	D0,#3		; D0 <-- largeur en bytes	LOAD.W	(A2)+OIMDLX,D2	SWAP.W	D2	LOAD.W	(A2)+OIMDLY,D2	LOAD.W	D3,D2	SWAP.W	D2	MUL.WU	D3,D0	LOAD.L	(A2)+OIMNBB,D3; Compresse l'image pour mettre les lignes bout  bout.	LOAD.L	D3,D1		; D3 <-- coordonne coin sup/gauche	LOAD.L	A1,(A6)+OPMAM	; A1 <-- ^matrice masque	CALL	TESTPOINT	; A1 <-- ^byte sup/gauche dans matrice	JUMP,NE EXIT$	LOAD.L	A3,A1	LOAD.L	A4,A1	LOAD.W	D3,(A2)+OIMDLY	; D3 <-- compteur vertical	DEC.W	D340$:	LOAD.W	D4,(A2)+OIMDLX	SR.W	D4,#3		; D4 <-- compteur horizontal	DEC.W	D4	PUSH.L	A442$:	LOAD.B	(A3+),(A4+)	; dplace une ligne	DECJ.W,NMO D4,42$	POP.L	A4	ADD.W	A4,(A6)+OMANBB	DECJ.W,NMO D3,40$	LOAD.L	A3,A1		; A3 <-- ^image dcode	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^pour image code	GRA_	CODEIMA		; code l'image ...	JUMP',NE 50$				; crit une image code =>	LOAD.L	A3,#R16"NMDESS	; A3 <-- ^nom du logiciel	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G ; D3 <-- type initiateur	LOAD.L	D4,(A2)+OIMNBB	ADD.L	D4,#LGHIMA	BLOC_	WROPEN		; dbut de l'criture dans le bloc-notes	JUMP,NE EXIT$	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA;	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	WRDATA		; crit l'en-tte	JUMP',NE CLOSE$	LOAD.L	A4,#(A1)-IMLBUF	LOAD.L	D4,(A2)+OIMNBB;	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	WRDATA		; crit l'image code	JUMP'	CLOSE$50$:				; crit une image dcode =>	LOAD.L	A3,#R16"NMDESS	; A3 <-- ^nom du logiciel	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G ; D3 <-- type initiateur	LOAD.L	D4,(A2)+OIMNBB	ADD.L	D4,#LGHIMA	BLOC_	WROPEN		; dbut de l'criture dans le bloc-notes	JUMP',NE EXIT$	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA;	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	WRDATA		; crit l'en-tte	JUMP',NE CLOSE$	LOAD.L	A4,A1	LOAD.L	D4,(A2)+OIMNBB;	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	WRDATA		; crit l'image dcode;	JUMP'	CLOSE$CLOSE$:	PUSH.W	D7	BLOC_	WRCLOSE		; ferme le bloc-notes	POP.W	D7EXIT$:	POPM.L	D0..D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PRIMAGE >;========/; Imprime toute l'image.; in	A2.L	canal de PRINTA; out	D7.W	erreur; mod	D7.WPRIMAGE:	PUSHM.L	D0,D3,D4,A1..A4	CALL	MATRIXODD	; rend toutes les lignes multiples de 8 points	LOAD.L	A1,A2		; A1 <-- canal de PRINTA	LOAD.L	A2,#(A6)+OBUHIMA+LGHIMA	LOAD.W	D4,#LGHIMA-120$:	CLR.B	(-A2)		; en-tte <-- rempli de zro	DECJ.W,NMO D4,20$	LOAD.B	(A2)+OIMTYP,#H'81	LOAD.B	(A2)+OIMCOD,#H'00	LOAD.B	(A2)+OIMBIP,#H'01	LOAD.B	(A2)+OIMDIR,#H'02	LOAD.W	(A2)+OIMDLX,(A6)+OMALMX	LOAD.W	(A2)+OIMDLY,(A6)+OMALMY	LOAD.W	D3,(A6)+OMALMX	SR.W	D3,#3	MUL.WU	D3,(A6)+OMALMY	LOAD.L	(A2)+OIMNBB,D3	LOAD.L	A3,(A6)+OPMAT	; A3 <-- ^image dcode	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^pour image code	GRA_	CODEIMA		; code l'image ...	JUMP,NE 50$; Imprime une image code.	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	EX.L	A2,A1	PRINTA_	WRPRINT		; crit l'en-tte	EX.L	A1,A2	JUMP',NE 40$	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^image code	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- nb total de bytes	EX.L	A2,A1	PRINTA_	WRPRINT		; crit l'image code	EX.L	A1,A2	JUMP',NE 40$	EX.L	A2,A1	PRINTA_	CLPRINT		; ferme l'imprimante	EX.L	A1,A240$:	PUSH.W	D7	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^image code	GRA_	DECOIMA		; re-dcode l'image !	POP.W	D7	JUMP',NE 80$	JUMP'	90$; Imprime une image telle quelle, c'est--dire dcode.50$:	LOAD.L	A4,A2	LOAD.L	A2,A1	LOAD.L	D4,#LGHIMA	PRINTA_	WRPRINT		; crit l'en-tte	JUMP',NE 80$	LOAD.L	A4,A3		; A4 <-- ^matrice principale	LOAD.L	D4,D3		; D4 <-- nb total de bytes	PRINTA_	WRPRINT		; crit le data de l'image	JUMP',NE 80$	PRINTA_	CLPRINT		; ferme l'imprimante	JUMP'	90$80$:				; erreur =>	PUSH.W	D7	LOAD.L	A2,A1	PRINTA_	CLPRINT		; ferme l'imprimante	POP.W	D790$:	CALL	MATRIXEVEN	; rend toutes les lignes multiples de 16 points	POPM.L	D0,D3,D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; WRIMAGEBLOC >;============/; Sauve toute l'image dans le bloc-notes.; in	-; out	D7.W	erreur; mod	D7.WWRIMAGEBLOC:	PUSHM.L	D3,D4,A1..A4	CALL	WAITMOUSE	; met le sablier	CALL	MATRIXODD	; rend toutes les lignes multiples de 8 points	LOAD.L	A2,#(A6)+OBUHIMA+LGHIMA	LOAD.W	D4,#LGHIMA-120$:	CLR.B	(-A2)		; en-tte <-- rempli de zro	DECJ.W,NMO D4,20$	LOAD.B	(A2)+OIMTYP,#H'81	LOAD.B	(A2)+OIMCOD,#H'00	LOAD.B	(A2)+OIMBIP,#H'01	LOAD.B	(A2)+OIMDIR,#H'02	LOAD.W	(A2)+OIMDLX,(A6)+OMALMX	LOAD.W	(A2)+OIMDLY,(A6)+OMALMY	LOAD.W	D3,(A6)+OMALMX	SR.W	D3,#3	MUL.WU	D3,(A6)+OMALMY	LOAD.L	(A2)+OIMNBB,D3	LOAD.L	A3,(A6)+OPMAT	; A3 <-- ^image dcode	LOAD.L	A1,A3	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^pour image code	GRA_	CODEIMA		; code l'image ...	JUMP,NE 50$; Ecrit une image code.	LOAD.L	A3,#R16"NMDESS	; A3 <-- ^nom du logiciel	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	LOAD.L	D4,(A2)+OIMNBB	ADD.L	D4,#LGHIMA	BLOC_	WROPEN		; dbut de l'criture dans le bloc-notes	JUMP',NE 40$	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA;	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	WRDATA		; crit l'en-tte	JUMP',NE 40$	LOAD.L	A4,#(A1)-IMLBUF	LOAD.L	D4,(A2)+OIMNBB;	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	WRDATA		; crit l'image code	JUMP',NE 40$	BLOC_	WRCLOSE		; ferme40$:	PUSH.W	D7	LOAD.L	A3,A1	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^image code	GRA_	DECOIMA		; re-dcode l'image !	POP.W	D7	JUMP,NE 80$	JUMP	90$; Ecrit une image telle quelle, c'est--dire dcode.50$:	LOAD.L	A3,#R16"NMDESS	; A3 <-- ^nom du logiciel	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	LOAD.L	D4,(A2)+OIMNBB	ADD.L	D4,#LGHIMA	BLOC_	WROPEN		; dbut de l'criture dans le bloc-notes	JUMP',NE 90$	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA;	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	WRDATA		; crit l'en-tte	JUMP',NE 80$	LOAD.L	A4,A1	LOAD.L	D4,(A2)+OIMNBB;	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	WRDATA		; crit l'image code	JUMP',NE 80$	BLOC_	WRCLOSE		; ferme	JUMP'	90$80$:				; erreur =>	PUSH.W	D7	BLOC_	WRCLOSE		; ferme	POP.W	D790$:	CALL	MATRIXEVEN	; rend toutes les lignes multiples de 16 points	POPM.L	D3,D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRIMAGE >;========/; Sauve toute l'image.; in	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WWRIMAGE:	PUSHM.L	D0,D3,D4,D6,A2..A4	CALL	MATRIXODD	; rend toutes les lignes multiples de 8 points	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre l'image	JUMP,NE 90$	LOAD.L	A2,#(A6)+OBUHIMA+LGHIMA	LOAD.W	D4,#LGHIMA-120$:	CLR.B	(-A2)		; en-tte <-- rempli de zro	DECJ.W,NMO D4,20$	LOAD.B	(A2)+OIMTYP,#H'81	LOAD.B	(A2)+OIMCOD,#H'00	LOAD.B	(A2)+OIMBIP,#H'01	LOAD.B	(A2)+OIMDIR,#H'02	LOAD.W	(A2)+OIMDLX,(A6)+OMALMX	LOAD.W	(A2)+OIMDLY,(A6)+OMALMY	LOAD.W	D3,(A6)+OMALMX	SR.W	D3,#3	MUL.WU	D3,(A6)+OMALMY	LOAD.L	(A2)+OIMNBB,D3	LOAD.L	A3,(A6)+OPMAT	; A3 <-- ^image dcode	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^pour image code	GRA_	CODEIMA		; code l'image ...	JUMP,NE 50$; Ecrit une image code.	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE 40$	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^image code	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- nb total de bytes	FOS	?WRBYTE		; crit l'image code	JUMP',NE 40$	FOS	?CLOSE		; ferme l'image40$:	PUSH.W	D7	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^image code	GRA_	DECOIMA		; re-dcode l'image !	POP.W	D7	JUMP,NE 80$	JUMP	90$; Ecrit une image telle quelle, c'est--dire dcode.50$:	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE 80$	LOAD.L	A4,A3		; A4 <-- ^matrice principale	LOAD.L	D4,D3		; D4 <-- nb total de bytes	FOS	?WRBYTE		; crit le data de l'image	JUMP',NE 80$	FOS	?CLOSE		; ferme l'image	JUMP'	90$80$:				; erreur =>	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D790$:	CALL	MATRIXEVEN	; rend toutes les lignes multiples de 16 points	POPM.L	D0,D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; OUTDEF  >;========/; Ecrit dans le fichier .DDES toutes les dfinitions.; in	A3.L	^nom du fichier .IMAGE; out	D7.W	erreur; mod	D7.WOUTDEF:	PUSHM.L	D0,D3,D4,D6,A2..A4	CALL	MAJDEF		; OBUHDEF <-- dfinitions; Ecrit le contenu de OBUHDEF dans le fichier .DDES	LOAD.L	A4,#R16"TEXDF	CALL	ADDEXT	LOAD.L	A4,#R16"TETDF	LOAD.L	A2,#R16"00$	EX.L	A3,A4	LIB	?CPSTRING	; fichier disque avec extension ?	EX.L	A4,A3	JUMP',NC 50$		; oui => 50$	CLR.W	D7		; non => #printer, etc.	JUMP'	90$50$:	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit si existe dj	LOAD.L	D3,#DEFATT	TCLR.L	D3:#BATTL	; ne met pas l'attribut "L" !	LOAD.W	D4,#TYPRAND	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP',NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',NE 90$	LOAD.L	A4,#(A6)+OBUHDEF	LOAD.L	D4,#LGHDEF	FOS	?WRBYTE		; crit le data	JUMP',NE 80$	FOS	?CLOSE		; ferme le fichier	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE		; ferme en cas d'erreur	POP.W	D790$:	POPM.L	D0,D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	CR,0,-1	.EVEN;--------\\; MAJDEF  >;--------/; Met  jour toutes les dfinitions.; in	-; out	OBUHDEF	toutes les dfinitions; mod	D7.WMAJDEF:	PUSHM.L	D3,D4,A1..A4; Rempli OBUHDEF en fonction de l'tat actuel du programme.	LOAD.L	A4,#(A6)+OBUHDEF+LGHDEF	LOAD.W	D4,#(LGHDEF/2)-110$:	CLR.W	(-A4)		; OBUHDEF <-- rempli de zro	DECJ.W,NMO D4,10$	LOAD.W	(A4)+OFSCALE,(A6)+OSCALE	LOAD.L	(A4)+OFPMOV,(A6)+OPMOVY	LOAD.L	(A4)+OFPMDI,(A6)+OPMDIY	LOAD.B	(A4)+OFOUTIL,(A6)+OOUTIL	LOAD.B	(A4)+OFMODE,(A6)+OMODE	LOAD.B	(A4)+OFOBJET,(A6)+OOBJET	LOAD.B	(A4)+OFSELECT,(A6)+OSELECT	LOAD.L	(A4)+OFFLAGS,(A6)+OFLAGS	LOAD.W	(A4)+OFPAS,(A6)+OPAS	LOAD.W	(A4)+OFNPDEF,(A6)+ONPDEF	LOAD.W	(A4)+OFNTDEF,(A6)+ONTDEF	LOAD.L	A1,#(A4)+OFPDEF	LOAD.L	A2,#(A6)+OPDEF	LOAD.W	D4,#((MAXDEF*(8+2))/2)-120$:	LOAD.W	(A1+),(A2+)	DECJ.W,NMO D4,20$	LOAD.L	A1,#(A4)+OFTDEF	LOAD.L	A2,#(A6)+OTDEF	LOAD.W	D4,#((MAXDEF*8)/2)-122$:	LOAD.W	(A1+),(A2+)	DECJ.W,NMO D4,22$	LOAD.W	(A4)+OFRRECT,(A6)+ORRECT	LOAD.B	(A4)+OFARC,(A6)+OARC	LOAD.B	(A4)+OFTRECT,(A6)+OTRECT	LOAD.B	(A4)+OFPOLY,(A6)+OPOLY	LOAD.B	(A4)+OFMCERC,(A6)+OMCERC	LOAD.L	A1,#(A4)+OFBUGC	LOAD.L	A2,#(A6)+OBUGC	LOAD.W	D4,#((LGGC*MAXGC)/2)-124$:	LOAD.W	(A1+),(A2+)	DECJ.W,NMO D4,24$	LOAD.L	(A4)+OFFAGC,(A6)+OFAGC	LOAD.L	A1,#(A4)+OFOPREL	LOAD.L	A2,#(A6)+OOPREL	LOAD.W	D4,#((LREL*8)/2)-126$:	LOAD.W	(A1+),(A2+)	DECJ.W,NMO D4,26$	POPM.L	D3,D4,A1..A4	RET;--------\\; INDEF   >;========/; Lit dans le fichier .DDES toutes les dfinitions.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WINDEF:	PUSHM.L	D0,D3,D4,D6,A1..A4	CALL	MAJDEF		; utile si vieux .DDES trop court !; Lit le fichier .DDES dans le buffer OBUHDEF.	LOAD.L	A4,#R16"TEXDF	CALL	ADDEXT	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUHDEF	LOAD.L	D4,#LGHDEF	FOS	?RDBYTE		; lit le data	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7	JUMP',EQ 15$	COMP.W	D7,#EROUTF	JUMP,NE 90$; Initialise le programme en fonction du contenu de OBUHDEF.15$:	LOAD.W	D4,(A4)+OFSCALE	LOAD.L	(A6)+OPMOVY,(A4)+OFPMOV	LOAD.L	(A6)+OPMDIY,(A4)+OFPMDI	CALL	CALSCALE	; calcul selon nouvelles dimensions	LOAD.B	(A6)+OMODE,(A4)+OFMODE	LOAD.B	(A6)+OOUTIL,(A4)+OFOUTIL	LOAD.B	(A6)+OOBJET,(A4)+OFOBJET	LOAD.B	D3,(A4)+OFSELECT	JUMP',NE 22$	LOAD.B	D3,#ICOZONE22$:	LOAD.B	(A6)+OSELECT,D3	LOAD.L	D3,(A4)+OFFLAGS	JUMP',NE 24$	LOAD.L	D3,#2^BFLP1!2^BFLAUTO24$:	LOAD.L	(A6)+OFLAGS,D3	LOAD.W	D3,(A4)+OFPAS	JUMP',NE 25$	LOAD.W	D3,#125$:	LOAD.W	(A6)+OPAS,D3	LOAD.L	A1,#(A4)+OFPDEF	LOAD.L	A2,#(A6)+OPDEF	LOAD.W	D4,#((MAXDEF*(8+2))/2)-130$:	LOAD.W	(A2+),(A1+)	DECJ.W,NMO D4,30$	LOAD.L	A1,#(A4)+OFTDEF	LOAD.L	A2,#(A6)+OTDEF	LOAD.W	D4,#((MAXDEF*8)/2)-132$:	LOAD.W	(A2+),(A1+)	DECJ.W,NMO D4,32$	LOAD.W	(A6)+ONPDEF,(A4)+OFNPDEF	LOAD.W	(A6)+ONTDEF,(A4)+OFNTDEF	LOAD.W	(A6)+ORRECT,(A4)+OFRRECT	LOAD.B	(A6)+OARC,(A4)+OFARC	LOAD.B	(A6)+OTRECT,(A4)+OFTRECT	JUMP',NE 36$	LOAD.B	(A6)+OTRECT,#2^BRECONT!2^BRETRAN36$:	TEST.B	(A4)+OFPOLY	JUMP',EQ 37$	LOAD.B	(A6)+OPOLY,(A4)+OFPOLY37$:	TEST.B	(A4)+OFMCERC	JUMP',EQ 38$	LOAD.B	(A6)+OMCERC,(A4)+OFMCERC38$:	CALL	DESWDO	LOAD.L	A1,#(A4)+OFBUGC	LOAD.L	A2,#(A6)+OBUGC	LOAD.W	D4,#MAXGC-140$:	PUSHM.L	D4,A1,A2	LOAD.L	A1,#(A1)+OGCTIT	LOAD.L	A2,#(A2)+OGCTIT	LOAD.W	D4,#LGTGC-141$:	LOAD.B	(A2+),(A1+)	; transfert le titre du gencar	DECJ.W,NMO D4,41$	POPM.L	D4,A1,A2	TEST.B	(A1)+OGCFLG:#BGCUSE	JUMP',BC 45$	CLR.B	(A1)+OGCCOD	CLR.B	(A2)+OGCCOD	LOAD.L	D3,(A1)+OGCCOD	COMP.L	D3,(A2)+OGCCOD	; mme gencar ?	JUMP',EQ 48$		; oui => 48$				; non =>	PUSHM.L	D4,A2..A4	LOAD.L	(A2)+OGCCOD,D3	LOAD.L	A4,A2		; A4 <-- ^gencar	LOAD.L	A3,#(A6)+OBUGC	; A3 <-- ^buffer des gencars	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A2,A0		; A2 <-- ^description de la fentre	DGENC_	NEW		; charge le nouveau gencar	POPM.L	D4,A2..A4	JUMP'	48$45$:	TEST.B	(A2)+OGCFLG:#BGCUSE	JUMP',BC 48$	PUSHM.L	D4,A2..A4	LOAD.L	A4,A2		; A4 <-- ^gencar	LOAD.L	A3,#(A6)+OBUGC	; A3 <-- ^buffer des gencars	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A2,A0		; A2 <-- ^description de la fentre	DGENC_	KILL		; libre le gencar inutile	POPM.L	D4,A2..A448$:	LOAD.L	A1,#(A1)+LGGC	LOAD.L	A2,#(A2)+LGGC	DECJ.W,NMO D4,40$	LOAD.L	(A6)+OFAGC,(A4)+OFFAGC	LOAD.L	A1,#(A4)+OFOPREL	LOAD.L	A2,#(A6)+OOPREL	LOAD.W	D4,#((LREL*8)/2)-152$:	LOAD.W	(A2+),(A1+)	DECJ.W,NMO D4,52$	CALL	DESCADRE	CALL	DESMATRIX	; dessine les deux matrices	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D3,D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TEXTREAD >;=========/; Lit un fichier .TEXT (ASCII) sur disque, sans l'afficher.; in	A3.L	^nom du fichier; out	A4.L	^texte <0>;	D7.W	erreur; mod	D7.W, A4.LTEXTREAD:	PUSHM.L	D0,D1,D3,D4,D6,A2,A3	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre le fichier ASCII	JUMP,NE 90$	LOAD.W	D3,#-1	LOAD.L	D4,#-1	FOS	?SPOS		; va tout  la fin	LOAD.L	D1,D4		; D1 <-- longueur du fichier	CLR.W	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP,NE 82$	LOAD.L	D4,D1	INC.L	D4		; D4 <-- place pour <0> terminateur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour fichier ASCII complet	JUMP,NE 82$	LOAD.L	A2,A4		; A2 <-- ^buffer pour fichier ASCII	DEC.L	D4	FOS	?RDBYTE		; lit le fichier ASCII	JUMP',NE 80$	CLR.B	(A4)+(D4.L)	; met le <0> terminateur	FOS	?CLOSE		; ferme le fichier ASCII	LOAD.L	A3,A2		; A3 <-- ^source	LOAD.L	A4,A2		; A4 <-- ^destination	CLR.B	(A6)+OVIFDCR	; enable <cr>40$:	CALL	TEXTCAR		; D3 <-- caractre suivant	LOAD.B	(A4+),D3	; destination <-- caractre	JUMP,NE 40$	LOAD.L	A4,A2		; A4 <-- ^texte <0>	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire du fichier ASCII	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier ASCII	POP.W	D790$:	POPM.L	D0,D1,D3,D4,D6,A2,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; TEXTCAR >;--------/; Lit un caractre, en ignorant les commandes "boa".; in	A3.L	^texte source; out	A3.L	^plus loin;	D3.B	caractre lu; mod	D3.L, D7.W, A3.LTEXTCAR:	PUSHM.L	D4,A410$:	LOAD.B	D3,(A3+)	; D3 <-- lit un caractre	JUMP,EQ 90$	TEST.L	D3:#7	JUMP,BS 10$	COMP.B	D3,#CR	JUMP',NE 12$	TEST.B	(A6)+OVIFDCR	; disable <cr> ?	JUMP,T	10$		; oui => 10$12$:	LOAD.B	D4,D3	LOAD.B	D3,#CR	COMP.B	D4,#H'0A	; pseudo-CR ?	JUMP,EQ 10$	COMP.B	D4,#H'06	; pseudo-FF ?	JUMP,EQ 10$	COMP.B	D4,#H'0C	; FF ?	JUMP,EQ 90$	LOAD.B	D3,#'-	COMP.B	D4,#H'0B	; pseudo-tiret ?	JUMP,EQ 10$	LOAD.B	D3,#H'02	COMP.B	D4,#H'02	; cadratin ?	JUMP,EQ 90$	LOAD.B	D3,D4	COMP.B	D3,#'\	JUMP,NE 90$; Lit toute une commande "boa".	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,#LBUDIS-2	LOAD.B	D3,(A3+)	; D3 <-- lit 1er caractre d'une "boa"	JUMP,EQ 90$	LOAD.B	(A4+),D3	; OBUDIS <-- commande "boa"	DEC.W	D4	LIB	?MINMAJ	COMP.B	D3,#'\		; double "boa" ?	JUMP,EQ 90$		; oui => 90$	COMP.B	D3,#'A		; commence par une lettre ?	JUMP,LO 10$		; non => 10$	COMP.B	D3,#'Z	JUMP,HI 10$20$:	LOAD.B	D3,(A3+)	; D3 <-- lit une "boa"	JUMP,EQ 90$	TEST.W	D4	JUMP',EQ 22$	LOAD.B	(A4+),D3	; OBUDIS <-- commande "boa"	DEC.W	D422$:	COMP.B	D3,#';		; fin de la "boa" ?	JUMP',EQ 24$	COMP.B	D3,#':	JUMP,NE 20$24$:	CLR.B	(A4)		; OBUDIS <-- terminateur	LOAD.L	A4,#(A6)+OBUDIS	CALL	TEXTBOA		; D3 <-- no commande "boa"	TEST.B	D3	JUMP,EQ 10$	COMP.B	D3,#1	JUMP',EQ 30$	COMP.B	D3,#2	JUMP',EQ 31$	COMP.B	D3,#3	JUMP',EQ 35$	JUMP	10$30$:				; disable <cr> =>	SET.B	(A6)+OVIFDCR	JUMP	10$31$:				; enable <cr> =>	CLR.B	(A6)+OVIFDCR	JUMP	10$35$:				; define =>	LOAD.B	D3,(A3+)	JUMP',EQ 90$	COMP.B	D3,#CR	JUMP,NE 35$	JUMP	10$90$:	POPM.L	D4,A4	RET;--------\\; TEXTBOA >;--------/; Cherche s'il s'agit d'une commande "boa" spciale.; in	A4.L	^commande "boa"; out	D3.B	no commande (zro si pas trouv); mod	D3.L, D7.WTEXTBOA:	PUSHM.L	A2..A4	LOAD.L	A3,#R16"00$10$:	LOAD.B	D3,(A3+)	; D3 <-- no commande	JUMP,EQ 90$	LOAD.L	A2,A420$:	TEST.B	(A3)	JUMP,EQ 90$	COMP.B	(A3+),(A2+)	JUMP,EQ 20$30$:	TEST.B	(A3+)	JUMP,NE 30$	JUMP	10$90$:	POPM.L	A2..A4	RET00$:	.B	1	.ASCIZ	"disable <'<>cr<'>>"	.B	2	.ASCIZ	"enable <'<>cr<'>>"	.B	3	.ASCIZ	"define "	.B	0	.EVEN;--------\\; SAVFILE >;========/; Sauve un nom de fichier dans OBUNAME.; in	A3.L	^nom; out	-; mod	D7.WSAVFILE:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBUNAME10$:	LOAD.B	(A4+),(A3+)	; OBUNAME <-- nom	JUMP',EQ 90$	COMP.B	(A4)-1,#CR	JUMP,NE 10$	CLR.B	(A4)-190$:	POPM.L	A3,A4	RET;--------\\; GETFILE >;========/; Prend le nom de fichier dans OBUNAME.; in	A3.L	^buffer; out	-; mod	D7.WGETFILE:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBUNAME10$:	LOAD.B	(A3+),(A4+)	; buffer <-- OBUNAME	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 10$	CLR.B	(A3)-190$:	POPM.L	A3,A4	RET;--------\\; AFFFILE >;========/; Affiche un nom de fichier en minuscules et entre guillemets.; in	A3.L	^nom; out	-; mod	D7.WAFFFILE:	PUSHM.L	D2,D3,A3	LOAD.B	D3,#'"	LIB	?AFCAR	LOAD.W	D2,#2^BAFXMI	; D2 <-- en minuscules	LOAD.W	D3,#-1		; D3 <-- pas de maximum	LIB	?AFXFILE	LOAD.B	D3,#'"	LIB	?AFCAR	POPM.L	D2,D3,A3	RET;--------\\; ADDEXT  >;========/; Transfert le nom de fichier dans OBXFILE et force une extension.; in	A3.L	^nom sans extension;	A4.L	^extension  ajouter; out	A3.L	^nom avec extension (dans OBXFILE); mod	D7.W, A3.LADDEXT:	PUSHM.L	D3,A2	LOAD.L	A2,#(A6)+OBXFILE10$:	LOAD.B	(A2+),(A3+)	; OBXFILE <-- nom du fichier	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBXFILE	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	POPM.L	D3,A2	RET;----------\\; RDSTPRINT >;==========/; Lit le status de l'imprimante.; in	-; out	D7.W	erreur; mod	D7.WRDSTPRINT:	PUSHM.L	D3,D4,A2..A4	LOAD.W	(A6)+OFACX,#5	LOAD.W	(A6)+OFACY,#2	LOAD.W	(A6)+OMMX,#(254000/360)+1 ; 360e d'inch	LOAD.W	(A6)+OMMY,#(254000/144)+1 ; 144e d'inch	LOAD.L	A2,(A6)+OCAPRINT	LOAD.L	D4,#LGPRI0	; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OSTPRI	; A4 <-- ^buffer	PRINTA_	RSTATUS		; OPRSTA <-- status de l'imprimante	JUMP',NE 90$	LOAD.W	D4,(A4)+OPRGLX	SR.W	D4,#3	LOAD.W	(A6)+OFACX,D4	LOAD.W	D4,(A4)+OPRGLY	SR.W	D4,#3	LOAD.W	(A6)+OFACY,D4	LOAD.W	(A6)+OMMX,(A4)+OPRUMX+2	LOAD.W	(A6)+OMMY,(A4)+OPRUMY+290$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETNMDESS:	.ASCIZ	"DESSIN4"	.EVEN	.END