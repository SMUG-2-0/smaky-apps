	.SBTTL	DESGRA;-------------\\; DIMCOMMEPLAN >;=============/; Donne les dimensions occupes par un objet graphique,; en tenant compte v. de l'paisseur du pinceau.; in	D5.L	origine (y;x);	D6.L	arrive (y;x); out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WDIMCOMMEPLAN:	PUSHM.L	D0..D2	LOAD.L	D3,D5	LOAD.L	D4,D6	LOAD.B	D0,(A6)+OOBJET	; D0 <-- objet slectionn	COMP.B	D0,#ICOCERCLE	JUMP',EQ 20$				; objet rectangulaire =>	SUB.W	D4,D3	JUMP',GE 12$	ADD.W	D3,D4		; D3 <-- x	NEG.W	D4		; D4 <-- dx12$:	INC.W	D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',GE 14$	ADD.W	D3,D4		; D3 <-- y	NEG.W	D4		; D4 <-- dy14$:	INC.W	D4	SWAP.W	D3	SWAP.W	D4	JUMP	50$20$:				; cercle/ellipse =>	SUB.W	D4,D3		; D4 <-- dx 	JUMP',GE 22$	NEG.W	D422$:	LOAD.W	D1,D4		; D1 <-- rx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	JUMP',GE 24$	NEG.W	D424$:	LOAD.W	D2,D4		; D2 <-- ry	SWAP.W	D3	SWAP.W	D4	TEST.B	(A6)+OPOLY:#BPOLYE	JUMP',BS 30$				; cercle =>	LOAD.W	D4,D1	ADD.W	D4,D2		; D4 <-- rayon	LOAD.W	D1,D4	SWAP.W	D4	LOAD.W	D4,D1	SWAP.W	D430$:	SUB.W	D3,D4		; D3 <-- x	SL.W	D4,#1		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4		; D3 <-- y	SL.W	D4,#1		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4;	JUMP'	50$; Tient compte ventuellement de l'paisseur du pinceau.50$:	COMP.B	(A6)+OOUTIL,#ICOPINCEAU	JUMP',NE 70$	SUB.W	D3,#8/2	ADD.W	D4,#8	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#8/2	ADD.W	D4,#8	SWAP.W	D3	SWAP.W	D4; Vrifie si les dimensions dpassent la partie visible.70$:	LOAD.W	D2,(A6)+OPMOVX	COMP.W	D3,D2	JUMP',GE 72$	LOAD.W	D3,D272$:	ADD.W	D2,(A6)+OPMDIX	SUB.W	D2,D3	COMP.W	D4,D2	JUMP',LE 73$	LOAD.W	D4,D273$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A6)+OPMOVY	COMP.W	D3,D2	JUMP',GE 74$	LOAD.W	D3,D274$:	ADD.W	D2,(A6)+OPMDIY	SUB.W	D2,D3	COMP.W	D4,D2	JUMP',LE 75$	LOAD.W	D4,D275$:	SWAP.W	D3	SWAP.W	D4	POPM.L	D0..D2	RET;-------------\\; DESCOMMEPLAN >;=============/; Dessine un objet graphique (droite/cercle/etc.) dans; la petite matrice.; in	D5.L	origine (y;x);	D6.L	arrive (y;x);	D2.W	mode de dessin;		 si 2^15=1 --> dessine dans matrice principale;		 si 2^14=1 --> dessine dans matrice masque;		 si 2^13=1 --> dessine directement dans la fentre principale; out	-; mod	D7.WDESCOMMEPLAN:	PUSHM.L	D0..D6,A3,A4	COMP.L	D5,D6		; origine = arrive ?	JUMP,EQ 95$		; oui => 95$	COMP.B	(A6)+OOUTIL,#ICOPINCEAU	JUMP',NE 02$	COMP.W	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ 02$		; oui => 02$ (pas encore de pinceau)	LOAD.W	D0,D2	LOAD.L	A4,#(A6)+OPDEF	LOAD.W	D1,(A6)+ONPDEF	DESSIN_	DDEF		; dfinit le bon pinceau avec traitill	OR.W	D2,D0		; D2 <-- mode utilisant le pinceau02$:	LOAD.L	D3,D5	LOAD.L	D4,D6	LOAD.L	A4,(A6)+OPMAT	TEST.L	D2:#15		; dessine dans la matrice principale ?	JUMP',BS 06$		; oui => 06$	LOAD.L	A4,(A6)+OPMAM	TEST.L	D2:#14		; dessine dans la matrice masque ?	JUMP',BS 06$		; oui => 06$	TEST.L	D2:#13		; dessine directement dans l'cran ?	JUMP,BS 08$		; oui => 08$	LOAD.W	(A6)+OSDDIS+ODFTTC,(A0)+ODFTTC	TEST.W	(A6)+OSCALE	JUMP',NS 03$	SUB.W	D3,(A6)+OPMOVX	SWAP.W	D3	SUB.W	D3,(A6)+OPMOVY	SWAP.W	D3	SUB.W	D4,(A6)+OPMOVX	SWAP.W	D4	SUB.W	D4,(A6)+OPMOVY	SWAP.W	D4	JUMP'	04$03$:	CALL	CONVGPOINT	SUB.W	D3,(A6)+OGMPOX	SWAP.W	D3	SUB.W	D3,(A6)+OGMPOY	SWAP.W	D3	EX.L	D3,D4	CALL	CONVGPOINT	SUB.W	D3,(A6)+OGMPOX	SWAP.W	D3	SUB.W	D3,(A6)+OGMPOY	SWAP.W	D3	EX.L	D3,D404$:	TEST.L	D2:#BPENDOT	JUMP',BS 05$	COMP.B	(A6)+OOBJET,#ICOTRAIT	JUMP,EQ 12$05$:	LOAD.W	D5,(A6)+OPWDO	LIB	?USEWDO		; utilise swdo autour de la petite matrice	JUMP'	08$06$:	CALL	_OPEDISMAT	; dessine dans la matrice principale/masque	LOAD.W	(A0)+ODFTTC,(A6)+OSDDIS+ODFTTC08$:	LOAD.B	D0,(A6)+OOBJET	; D0 <-- objet slectionn	COMP.B	D0,#ICOTRAIT	JUMP',EQ 10$	COMP.B	D0,#ICODROITE	JUMP',EQ 10$	COMP.B	D0,#ICOSPLINE	JUMP',EQ 10$	COMP.B	D0,#ICOFILET	JUMP,EQ 15$	COMP.B	D0,#ICOCERCLE	JUMP,EQ 20$	COMP.B	D0,#ICORECTANGLE	JUMP,EQ 40$	JUMP	90$10$:				; trait/droite =>	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine la droite	COMP.B	D0,#ICOSPLINE	JUMP,EQ 90$	COMP.B	(A6)+OOUTIL,#ICOCRAYON	JUMP,NE 90$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWDOT	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.B	(A3)+5,D2	; <mode>	LOAD.W	D3,#6	LIB	?STRING		; dessine le point d'arrive !	JUMP	90$12$:	SUB.W	D4,D3		; D4 <-- dx	ADD.W	D3,(A6)+OPMPOX	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	ADD.W	D3,(A6)+OPMPOY	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine la droite	COMP.B	(A6)+OOUTIL,#ICOCRAYON	JUMP,NE 90$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWDOT	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.B	(A3)+5,D2	; <mode>	LOAD.W	D3,#6	LIB	?STRING		; dessine le point d'arrive !	JUMP	95$15$:				; filet =>	LIB	?AFTIM	.B	MAPTT	.B	B'01010101	; map	.B	1		; chelle	.B	0	.EVEN	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine la droite	JUMP	90$20$:				; cercle/ellipse =>	TEST.B	(A6)+OMCERC:#BMCEDIA	JUMP',BC 21$	PUSH.L	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	POP.L	D421$:	TEST.B	(A6)+OARC:#BARCQ	JUMP,BS 32$	LOAD.W	D1,#3	TEST.B	(A6)+OPOLY:#BPOLY3	JUMP,BS 35$	INC.W	D1	TEST.B	(A6)+OPOLY:#BPOLY4	JUMP,BS 35$	INC.W	D1	TEST.B	(A6)+OPOLY:#BPOLY5	JUMP,BS 35$	INC.W	D1	TEST.B	(A6)+OPOLY:#BPOLY6	JUMP,BS 35$	ADD.W	D1,#2	TEST.B	(A6)+OPOLY:#BPOLY8	JUMP,BS 35$	ADD.W	D1,#2	TEST.B	(A6)+OPOLY:#BPOLY10	JUMP,BS 35$	TEST.B	(A6)+OPOLY:#BPOLYE	JUMP',BS 22$	CALL	CALCRAYON	; D5 <-- rayon	LOAD.W	(A6)+OCERAY,D522$:	CLR.W	D0	SUB.W	D4,D3		; D4 <-- rx 	JUMP',HS 23$	NEG.W	D4	ADD.W	D0,#223$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- ry	JUMP',HS 24$	NEG.W	D4	ADD.W	D0,#424$:	SWAP.W	D3	SWAP.W	D4	TEST.L	D0:#2	JUMP',BC 26$	TNOT.L	D0:#1		; D0 <-- 0,2,4,6 selon cadrant26$:	LOAD.W	D1,#B'11000000	; D1 <-- arcs pour 1/4 cercle	TEST.B	(A6)+OARC:#BARC4	JUMP',BS 27$	LOAD.W	D1,#B'11110000	; D1 <-- arcs pour 1/2 cercle	TEST.B	(A6)+OARC:#BARC2	JUMP',BS 27$	LOAD.W	D1,#B'11111111	; D1 <-- arcs pour cercle complet27$:	RR.B	D1,D0		; D1 <-- tourne les arcs selon le cadrant	TEST.B	(A6)+OPOLY:#BPOLYE	JUMP',BS 30$	LOAD.W	D4,D5		; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- Rx30$:	LIB	?DRELLIPSE	; dessine un cercle ou une ellipse	JUMP'	90$32$:	CALL	ARCQQ		; dessine un arc de cercle	JUMP'	90$35$:	CALL	POLYGONE	; dessine le polygone  n cts	JUMP'	90$40$:				; rectangle =>	LOAD.W	D0,(A6)+ORRECT	; D0 <-- rayon du rectangle	LOAD.B	D1,(A6)+OTRECT	COMP.B	D2,#INVDOT	; dessin "provisoire" ?	JUMP',NE 42$		; non => 42$	LOAD.B	D1,#2^BRECONT	; D1 <-- dessine seulement le pourtour42$:	CALL	RRECTTRAM;	JUMP'	90$90$:	TEST.L	D2:#15		; dessine dans la matrice principale ?	JUMP',BS 92$		; oui => 92$	TEST.L	D2:#14		; dessine dans la matrice masque ?	JUMP',BS 92$		; oui => 92$	TEST.L	D2:#13		; dessine directement dans l'cran ?	JUMP',BS 95$		; oui => 95$				; non =>	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	JUMP'	95$92$:	CALL	_CLODISMAT	; dessine  nouveau dans l'cran95$:	POPM.L	D0..D6,A3,A4	RET;----------\\; RRECTTRAM >;----------/; Dessine un rectangle tram aux coins arrondis.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D1.B	type (BRExxxx);	D0.W	rayon; out	-; mod	D7.WRRECTTRAM:	PUSHM.L	D0,D5,D6,A4	LOAD.L	D5,D3	LOAD.L	D6,D4	SUB.W	D5,D6	JUMP',NC 10$	NEG.W	D5		; D5 <-- |largeur|10$:	SWAP.W	D5	SWAP.W	D6	SUB.W	D6,D5	JUMP',NC 12$	NEG.W	D6		; D6 <-- |hauteur|12$:	SWAP.W	D5	COMP.W	D5,D6	JUMP',LS 14$	LOAD.W	D5,D6		; D5 <-- MIN(largeur,hauteur)14$:	SR.W	D5,#1		; D5 <-- rayon minimum	SUB.W	D5,#2	COMP.W	D0,D5	JUMP',LE 20$	CLR.W	D0	COMP.W	D5,#3	JUMP',LE 20$	LOAD.W	D0,#3	COMP.W	D5,#4	JUMP',LE 20$	LOAD.W	D0,#4	COMP.W	D5,#8	JUMP',LE 20$	LOAD.W	D0,#8	COMP.W	D5,#12	JUMP',LE 20$	LOAD.W	D0,#12	COMP.W	D5,#16	JUMP',LE 20$	LOAD.W	D0,#1620$:	PUSH.W	D2	TCLR.L	D2:#BTTTDOT	TCLR.L	D2:#BPENDOT	TEST.L	D1:#BRETRAM	JUMP',BC 40$	LOAD.L	A4,#(A6)+OTDEF	LOAD.W	D5,(A6)+ONTDEF	MUL.WU	D5,#8	ADD.L	A4,D5		; A4 <-- ^bonne trame	LOAD.L	D5,(A4)+0	LOAD.L	D6,(A4)+4	; D5/D6 <-- trame	CALL	RTRAME		; trame le rectangle arrondi	TEST.L	D1:#BREOPAQ	JUMP',BC 50$	NOT.L	D5	NOT.L	D6		; D5/D6 <-- trame inverse	CALL	INVMODE		; D2 <-- mode inverse	CALL	RTRAME		; laisse le fond opaque	JUMP'	50$40$:	TEST.L	D1:#BREOPAQ	JUMP',BC 50$	LOAD.L	D5,#-1	LOAD.L	D6,D5		; D5/D6 <-- trame blanche	CALL	INVMODE		; D2 <-- mode inverse	CALL	RTRAME		; laisse le fond opaque50$:	POP.W	D2	TEST.L	D1:#BRECONT	JUMP',BC 90$	CALL	RRECTANGLE	; dessine le rectangle arrondi90$:	POPM.L	D0,D5,D6,A4	RET;--------\\; INVMODE >;--------/; Inverse le mode de dessin.; in	D2.B	mode de dessin; out	D2.B	mode de dessin inverse; mod	D2.B, D7.WINVMODE:	PUSH.W	D3	LOAD.B	D3,#SETDOT	COMP.B	D2,#CLRDOT	JUMP',EQ 80$	LOAD.B	D3,#CLRDOT	COMP.B	D2,#SETDOT	JUMP',EQ 80$	LOAD.B	D3,D280$:	LOAD.B	D2,D3	POP.W	D3	RET;-----------\; RRECTANGLE >;-----------/; Dessine un rectangle aux coins arrondis.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D0.W	rayon; out	-; mod	D7.WRRECTANGLE:	PUSHM.L	D1..D4	EX.L	D1,D3	EX.L	D2,D4	CALL	ORDONNE	EX.L	D3,D1	EX.L	D4,D2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D0		; D1 <-- rayon	LIB	?DRRECTA	; dessine un rectangle arrondi	POPM.L	D1..D4	RET;--------\\; RTRAME  >;--------/; Dessine une trame rectangulaire, ventuellement avec les coins arrondis !; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D0.W	rayon;	D5/D6	trame; out	-; mod	D7.WRTRAME:	PUSHM.L	D1..D4	PUSHM.L	D3,D4	LOAD.L	D3,D5	LOAD.L	D4,D6	COMP.B	D2,#CLRDOT	JUMP',NE 10$	NOT.L	D3	NOT.L	D410$:	LIB	?DRMDEF		; dfinit la trame	POPM.L	D3,D4	EX.L	D1,D3	EX.L	D2,D4	CALL	ORDONNE	EX.L	D3,D1	EX.L	D4,D2	SUB.W	D4,D3	INC.W	D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	INC.W	D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D0		; D1 <-- rayon	LIB	?DRTRAMEA	; dessine une trame arrondie	POPM.L	D1..D4	RET;---------\\; ARCQQ    >;=========/; Dessine un arc de cercle quelconque.; in	D3.L	origine (y;x);	D4.L	arrive (y;x);	D2.B	mode de dessin; out	-; mod	D7.WARCQQ:	PUSHM.L	D1,D4,D5	TEST.W	(A6)+ONARC	JUMP,EQ 90$	CALL	CALCRAYON	; D5 <-- rayon	LOAD.W	(A6)+OCERAY,D5	PUSHM.L	D2,D3	LOAD.L	(A6)+OSEPMI,D3	ADD.W	D3,D5	CALL	XTOURNE		; D2 <-- angle initial	LOAD.W	(A6)+OCEANG,D2	LOAD.W	D1,D2	LOAD.W	D2,(A6)+ONARC	SR.W	D2,#1	SUB.W	D1,D2		; D1 <-- angle de dpart	JUMP',NC 20$	ADD.W	D1,#36020$:	LOAD.W	D2,D1	ADD.W	D2,(A6)+ONARC	; D2 <-- angle d'arrive	SWAP.W	D1	LOAD.W	D1,D2		; D1 <-- angles (a;d)	SWAP.W	D1	POPM.L	D2,D3	LOAD.W	D4,D5		; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- Rx	TEST.B	(A6)+OMCERC:#BMCETRA	JUMP',BS 60$	LIB	?DRARC		; dessine un arc de cercle	JUMP'	90$60$:	LIB	?DRTRANCHE	; dessine un tranche de gteau (miam)90$:	POPM.L	D1,D4,D5	RET;---------\\; POLYGONE >;=========/; Dessine un polygone avec un nombre quelconque de cts.; in	D3.L	origine (y;x);	D4.L	arrive (y;x);	D2.B	mode de dessin;	D1.W	nombre de cts (3..n); out	-; mod	D7.WPOLYGONE:	PUSHM.L	D1,D4,D5	CALL	CALCRAYON	; D5 <-- rayon	LOAD.W	(A6)+OCERAY,D5	PUSHM.L	D2,D3	LOAD.L	(A6)+OSEPMI,D3	ADD.W	D3,D5	CALL	XTOURNE		; D2 <-- angle initial	LOAD.W	(A6)+OCEANG,D2	SWAP.W	D1		; D1 <-- nb de cts	LOAD.W	D1,D2		; D1 <-- angle	POPM.L	D2,D3	LOAD.W	D4,D5		; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- Rx	LIB	?DRPOLYGONE	; dessine un polygone	POPM.L	D1,D4,D5	RET;---------\\; DESSPRAY >;=========/; Dessine un "point" avec le spray, et tenant compte de; la trame de remplissage.; in	D3.L	position du centre (y;x);	D2.B	mode de dessin;	A3.L	^motif 8x8 du spray; out	-; mod	D7.WDESSPRAY:	PUSHM.L	D0..D6,A1..A5	LOAD.B	D6,D2		; D6 <-- mode de dessin	LOAD.L	A4,#(A6)+OTDEF	LOAD.W	D4,(A6)+ONTDEF	MUL.WU	D4,#8	ADD.L	A4,D4		; A4 <-- ^dbut trame de remplissage	LOAD.L	A5,#(A4)+8	; A5 <-- ^fin trame de remplissage	SUB.W	D3,#8/2	SWAP.W	D3	SUB.W	D3,#8/2	LOAD.W	D4,D3	AND.W	D4,#B'111	LOAD.L	A2,A4	ADD.W	A2,D4		; A2 <-- ^bonne ligne matrice remplissage	SWAP.W	D3	LOAD.W	D4,#8-110$:	PUSHM.L	D3,D4	LOAD.B	D0,(A3+)	LOAD.W	D4,#8-120$:	SL.B	D0,#1		; point  dessiner selon matrice spray ?	JUMP',CC 50$		; non => 50$	TEST.B	(A2):D3		; point  dessiner selon matrice remplissage ?	JUMP',BC 50$		; non => 50$				; oui =>	LOAD.L	A1,(A6)+OPMAT	; A1 <-- ^matrice	CALL	TESTPOINT	JUMP',NE 50$	COMP.B	D6,#CLRDOT	JUMP',EQ 40$	TSET.B	(A1):D1		; point dj allum ?	JUMP',BS 50$		; oui => 50$	JUMP'	45$40$:	TCLR.B	(A1):D1		; point dj teint ?	JUMP',BC 50$		; oui => 50$45$:	LOAD.W	D2,#INVDOT	LOAD.W	D1,#1	CALL	DESGPOINT	; allume/teint point dans grande matrice	LOAD.B	D2,D6	CALL	DESPPOINT	; allume/teint point dans petite matrice50$:	INC.W	D3		; D3 <-- avance en X	DECJ.W,NMO D4,20$	POPM.L	D3,D4	SWAP.W	D3	INC.W	D3		; D3 <-- avance en Y	SWAP.W	D3	INC.L	A2		; A2 <-- ^ligne suivante matrice remplissage	COMP.L	A2,A5		; fin de la trame ?	JUMP',LO 60$		; non => 60$	LOAD.L	A2,A4		; A2 <-- ^premire ligne60$:	DECJ.W,NMO D4,10$	POPM.L	D0..D6,A1..A5	RET;---------\\; DESFILET >;=========/; Essaye de remplir le filet dans la matrice masque.; in	D1.L	coin sup/gauche;	D2.L	coin inf/droite; out	D7.W	erreur; mod	D7.WDESFILET:	PUSHM.L	D2..D4,A3,A4	LOAD.L	D4,#-1	CALL	_DRMDEF		; dfinit une trame pleine	LOAD.L	A4,(A6)+OPMAM	CALL	_OPEDISMAT	; dessine dans la matrice copie	LOAD.L	D3,D1	LOAD.L	D4,D2	TEST.W	D3	JUMP',EQ DX$	DEC.W	D3DX$:	AND.B	D3,#B'11111000	ADD.W	D4,#8-1+1	AND.B	D4,#B'11111000	COMP.W	D4,(A6)+OMALMX	JUMP',LS FX$	LOAD.W	D4,(A6)+OMALMXFX$:	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	TEST.W	D3	JUMP',EQ DY$	DEC.W	D3DY$:	AND.B	D3,#B'11111110	ADD.W	D4,#2-1+1	AND.B	D4,#B'11111110	COMP.W	D4,(A6)+OMALMY	JUMP',LS FY$	LOAD.W	D4,(A6)+OMALMYFY$:	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A0)+ODFFY,D3	LOAD.L	(A0)+ODFWBY,D3	LOAD.L	(A0)+ODFFDY,D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A0)+ODFWEY,D4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3)+0,#AFFILLA	LOAD.B	(A3)+1,#DRAWFILLO	CLR.L	(A3)+2	LOAD.B	(A3)+6,#DRAWFILLC	LOAD.W	D3,#1+5+1	LIB	?STRING		; rempli ...	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	CALL	_CLODISMAT	; redessine dans l'cran	POPM.L	D2..D4,A3,A4	CLR.W	D7		; retour EQ	RET	.END