	.TITLE	EXDDESSIN	.PROC	M680002	.REF	SM8	.REF	DRIVERS	.REF	LIB	.REF	FOS	.REF	DBOX	.REF	DESSIN	.LOC	0OCHDESSIN:.BLKB	2OCHDBOX:.BLKB	2OPDDIS:	.BLKB	4LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.W	D3,#2	.W	LIB,?MOUSE	.W	LIB,?GCHDIS	; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	.W	FOS,?RSTATUS	; demande le ^rel !	JUMP,NE ERROR	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	.W	LIB_OPEN	JUMP,NE ERROR	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMDESSIN	LOAD.W	D3,#DESSIN_FIRST	.W	LIB_OPEN	JUMP,NE ERROR	LOAD.W	(A6)+OCHDESSIN,D1LOOP:;;?	LOAD.L	D2,#2^BDBSAV!2^BMAICO	LOAD.L	D2,#2^BDBSAV!2^BMATX1	LOAD.W	D4,#1	LOAD.L	A2,#R16"TICO	LOAD.L	A3,#R16"TTEXT	LOAD.L	A4,#R16"TXDEF	.W	DESSIN_PEDIT	JUMP,NE ERROR	JUMP	FINERROR:	.W	LIB,?AFERRORFIN:	LOAD.W	D1,(A6)+OCHDBOX	.W	LIB_CLOSE	LOAD.W	D1,(A6)+OCHDESSIN	.W	LIB_CLOSE	EXITTICO:	.B	USEGC,0,0,0	.B	'A,'B,'C,0	.EVENTTEXT:	.ASCIZ	"oui"	.ASCIZ	"non"	.ASCIZ	"autre"	.EVENTPDEF:				; 0	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'11111111	.B	1				; 1	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00111111	.B	1				; 2	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'01011111	.B	1				; 3	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'01010101	.B	1				; 4	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00011000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'11111111	.B	1				; 5	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00011000	