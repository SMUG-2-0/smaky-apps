	.TITLE	COULEURS	.PROC	M680002	.REF	SM8	.REF	LIB	.REF	DRIVERS	.REF	FOS	.REF	NTREL	.REF	GESMEM	.REF	COLORS	.LOC	0OCNDIS:	.BLKB	2		; canal de la fentre $DIS_nOC0DIS:	.BLKB	2		; canal de la fentre $DIS_0LGVAR:	.LOC	0START:	LIB	?OPELIB	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LIB	?AFTIM	.B	NOCURS,EOP,CR,CR	.ASCIZ	"Initialisation des couleurs ...<CR>"	.EVEN	LIB	?GCHDIS	LOAD.W	(A6)+OCNDIS,D6	LOAD.L	A3,#R16"NPDIS	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre $DIS_0	LOAD.W	(A6)+OC0DIS,D6	LIB	?PCHDIS		; donne canal  la librairie	LOAD.L	A3,#R16"TABLE	CALL	INICOUL		; initialise les couleurs	LOAD.W	D6,(A6)+OC0DIS	FOS	?CLOSE		; ferme $DIS_0	LOAD.W	D6,(A6)+OCNDIS	LIB	?PCHDISERFAT1:	LIB	?AFTIM	.ASCIZ	"C'est fini !<CR>"	.EVEN	LOAD.W	D4,#50	NTREL	?DELMS	LIB	?AFTIM	.B	EOP,0	.EVEN	LIB	?CLOLIB	FOS	?STOP;--------\\; INICOUL >;========/; ; in	A3.L	^table; out	-; mod	D7.WINICOUL:	PUSHM.L	D3,A310$:	TEST.L	(A3)		; fin de la table ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.B	D3,#COLORLINK	LIB	?AFCAR	LOAD.W	D3,#4+2+2+2	LIB	?STRING	ADD.W	A3,D3	JUMP	10$90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RETTABLE:	.L	COLOR_PPCLEAR	.W	H'FFFF,H'FFFF,H'FFFF	; pp: fond	.L	COLOR_PPSET	.W	H'0000,H'0000,H'0000	; pp: dessin	.L	COLOR_PPHILI	.W	H'FFFF,H'0000,H'FFFF	; pp: mises en vidence	.L	COLOR_PPCMOUSE	.W	H'FFFF,H'FFFF,H'0000	; pp: lutin de la souris (fond)	.L	COLOR_PPSMOUSE	.W	H'0000,H'0000,H'FFFF	; pp: lutin de la souris (chair)	.L	COLOR_SKCADRE	.W	H'FF00,H'FF00,H'FF00	; soft-keys: cadre (SNF11)	.L	COLOR_SKTEXT	.W	H'FF00,H'FF00,H'FF00	; soft-keys: texte	.L	COLOR_SKBARRE	.W	H'FF00,H'FF00,H'FF00	; soft-keys: barres	.L	COLOR_MMCLEAR	.W	H'C000,H'FFFF,H'C000	; mmenu: fond	.L	COLOR_MMSET	.W	H'0000,H'0000,H'C000	; mmenu: dessin par dfaut	.L	COLOR_MMCADRE	.W	H'FFFF,H'0000,H'FFFF	; mmenu: cadre	.L	COLOR_MMSEP	.W	H'0000,H'0000,H'FF00	; mmenu: trait horizontaux de sparation	.L	COLOR_DBCLEAR	.W	H'C000,H'FFFF,H'C000	; dbox: fond	.L	COLOR_DBSET	.W	H'0000,H'0000,H'C000	; dbox: dessin des objets	.L	COLOR_DBCADRE	.W	H'FFFF,H'0000,H'FFFF	; dbox: cadre	.L	COLOR_DBTITLE	.W	H'FFFF,H'0000,H'FFFF	; dbox: titre	.L	COLOR_DBTRAME	.W	H'0000,H'FFFF,H'0000	; dbox: trame de fond	.L	COLOR_DBSEL	.W	H'FFFF,H'8000,H'FFFF	; dbox: slection (boutons carrs et ronds)	.L	COLOR_DBERROR	.W	H'0000,H'0000,H'0000	; dbox: erreurs	.L	COLOR_DBICOCADRE	.W	H'FFFF,H'FFFF,H'FFFF	; dbox: cadre des icnes	.L	COLOR_DBICODESS	.W	H'0000,H'FFFF,H'0000	; dbox: dessin des icnes	.L	COLOR_SCCLEAR	.W	H'FFFF,H'FFFF,H'A000	; ascenseur: fond	.L	COLOR_SCSET	.W	H'0000,H'0000,H'0000	; ascenseur: dessin par dfaut	.L	COLOR_SCOBJ	.W	H'8000,H'0000,H'FFFF	; ascenseur: flches et pages aux extrmits	.L	COLOR_SCPOS	.W	H'FFFF,H'0000,H'0000	; ascenseur: intrieur de la cabine	.L	COLOR_SCSCALE	.W	H'FF00,H'FF00,H'FF00	; ascenseur: chelles	.L	COLOR_RUCLEAR	.W	H'0000,H'0000,H'0000	; rgle: fond	.L	COLOR_RUSET	.W	H'FF00,H'FF00,H'FF00	; rgle: dessin par dfaut	.L	COLOR_RULINE	.W	H'FF00,H'FF00,H'FF00	; rgle: lignes de la graduation	.L	COLOR_RUCAR	.W	H'FF00,H'FF00,H'FF00	; rgle: caractres de l'chelle	.L	COLOR_RUMARK	.W	H'FF00,H'FF00,H'FF00	; rgle: marques de la souris (triangles)	.L	COLOR_PLNOIR	.W	H'0000,H'0000,H'0000	; plan: noir	.L	COLOR_PLROUGE	.W	H'FF00,H'0000,H'0000	; plan: rouge	.L	COLOR_PLVERT	.W	H'0000,H'FF00,H'0000	; plan: vert	.L	COLOR_PLBLEU	.W	H'0000,H'0000,H'FF00	; plan: bleu	.L	COLOR_PLVIOLET	.W	H'FF00,H'0000,H'FF00	; plan: violet	.L	COLOR_PLJAUNE	.W	H'FF00,H'FF00,H'0000	; plan: jaune	.L	COLOR_PLBRUN	.W	H'0000,H'FF00,H'FF00	; plan: brun	.L	COLOR_PLBLANC	.W	H'D000,H'D000,H'D000	; plan: blanc	.L	COLOR_PLINVIS	.W	H'FFFF,H'E000,H'E000	; plan: invisible	.L	COLOR_DEOUTIL	.W	H'FFFF,H'8000,H'8000	; dessin: outils	.L	COLOR_DEMODE	.W	H'FFFF,H'FFFF,H'8000	; dessin: modes	.L	COLOR_DEOBJET	.W	H'FFFF,H'8000,H'FFFF	; dessin: objets	.L	COLOR_DEMODIF	.W	H'8000,H'FFFF,H'FFFF	; dessin: modifications	.L	0NPDIS:	.ASCIZ	"$DIS_20"	.EVEN	.END	START