	.TITLE	T.ASC	.PROC	M680002	.REF	SMAKY	.REF	BLOC	.LOC	0LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.L	D2,#-1LOOP$:	LIB	?IFCAR	JUMP,EQ END$	BLOC_	REGENLOAD.W D4,D7LIB ?AFX4LIB ?AFSPACE	COMP.L	D3,D2;;?	JUMP,EQ LOOP$	LOAD.L	D2,D3	LOAD.L	D4,D3	LIB	?AFX8	LIB	?AFSPACE	LOAD.L	D3,#BNTTEXT	BLOC_	RDINFO	LIB	?AFX8	LIB	?AFSPACE	LOAD.L	D4,D5	LIB	?AFX8	LIB	?AFCR	JUMP	LOOP$END$:	EXITVAR:	.FILLB	LGVAR,0	.END	START