\define g_Fond:\nef11;\g_Fond;		.TITLE	LDIma.ASC		.PROC	M68000		.REF	SMAKY		.REF	DBOX		.REF	GRA2		.REF	DRIVERS		.REF	RASTER		.REF	GRAMISC; Programme 'remplaant' SMA_LDIMA.CODE, cherchant galement une image; couleur .COLOR pour l'afficher.Nil		=		0PCCode		=		0PCVar		=		1PCDef		=		2MaxNameLg	=		16+2+1		; Longueur du nom maximum.MaxExtLg	=		5		; Place  reserver pour l'extensionRadius		=		32		; Rayon des coins.APC	PCCode.LOC	Nil;-------------\\; SetupScreen  >;-------------/; Prpare l'cran pour recevoir l'image de dmarrage.; In:	A2 ^descripteur d'cran; Out:	D7.16 erreur; Mod:	D7.16 FSetupScreen:	PUSHM.32 	D1|D3|D4|A4	MOVE.8		#NoCurs,D3			; Plus de curseur	LIB		?AFCAR	TEST.8		{A2}+ODFMod:#BFBlanc		; Ecran  fond blanc ?	JUMP,BS		FondBlanc$	MOVE.8		#EOP,D3				; Non => on efface simplement.	LIB		?AFCAR	JUMP		Exit$FondBlanc$:	MOVE.32		#R16^Fond,A4	MOVE.32		{A2}+ODFDy,D4	CLR.32		D3	MOVE.32		#LoadDot,D1	GRA2_		TrameExit$:	POPM.32 	D1|D3|D4|A4	RET;----------\\; CopyName  >;----------/; Copie le premier nom de fichier de la ligne de commande,; en supprimant les dossiers ventuels.; In:	A4 ^destination; 	A3 ^ligne de commande; Out:	A4 ^nom de fichier termin par un <0>; 	D7.16 erreur; Mod:	A3 D7.16 FCopyName:	PUSH.32		A0	PUSH.32		D0	CLR.16		D7				; Pas d'erreurResetDestination$:	MOVE.32		A4,A0				; A0 ^nom de fichier construit	MOVE.32		#MaxNameLg-MaxExtLg-1,D0	; D0.16 garde-fou.CopyLoop$:	MOVE.8		{A3+},D3	JUMP,EQ		endCopy$	COMP.8		#":",D3				; Dbut de dossier ?	JUMP,EQ		ResetDestination$		; Oui => on oublie le dbut.	COMP.8		#CR,D3				; Teste une multitude de	JUMP,EQ		endCopy$			; terminateurs divers.	COMP.8		#Space,D3	JUMP,EQ		endCopy$	COMP.8		#"/",D3	JUMP,EQ		endCopy$	COMP.8		#Tab,D3	JUMP,EQ		endCopy$	MOVE.8		D3,{A0+}			; Copie dans nos variables	DJ.16,NMO 	D0,CopyLoop$			; Encore de la place ?	MOVE.16		#ErToLo,D7			; "Nom trop long"	JUMP		Exit$endCopy$:	CLR.8		{A0}				; Termine le nomExit$:	POP.32		D0	POP.32		A0	TEST.16		D7	RET;-------------\\; CenterImage  >;-------------/; Dcoupe l'image de telle manire  ce qu'elle tienne; dans l'cran; le cas chant, centre l'image dans l'cran.; In:	D2.32 dimensions de l'image {y;x};	A2 ^descripteur d'cran; Out:	D2.32 dimensions du transfert; 	D4.32 origine dans l'cran; Mod:	D2.32 D4.32 FCenterImage:	SWAP.32		D2	MOVE.16		D2,D4				; D4.16 <- hauteur	SUB.16		{A2}+ODFDy,D4			; D4.16 <- hauteur - hcran	JUMP,LO		R8^CenterY$	MOVE.16		{A2}+ODFDy,D2			; Trop haut => hauteur <- hcran	CLR.16		D4				; et origine <- 0	JUMP		DoX$CenterY$:	NEG.16		D4	SR.16		D4				; Origine selon l'cranDoX$:	SWAP.32		D2	SWAP.32		D4	MOVE.16		D2,D4				; D4.16 <- largeur	SUB.16		{A2}+ODFDX,D4			; D4.16 <- largeur - lcran	JUMP,LO		R8^CenterX$	MOVE.16		{A2}+ODFDX,D2	CLR.16		D4	JUMP		Exit$CenterX$:	NEG.16		D4	SR.16		D4Exit$:	RET;---------------\\; SetupClipping  >;---------------/; Dfinit la rgion de dcoupage de l'cran comme tant un; rectangle  coins arrondis.; In:	A2 ^descripteur d'cran; 	D2.32 dimensions du rectangle; 	D4.32 origine du rectangle; Out:	D7.16 erreur; Mod:	D7.16 FSetupClipping:.APC	PCDef.LOC	NilClipRect$:	.BLK.8		LgGRectRoundRect$:	.BLK.8		LgGRect.EVENlLocal$		=	APC.LOC	-lLocal$Local$:		.BLK.8		lLocal$oldA6$:		.BLK.32		1retAddr$:	.BLK.32		1.APC	PCCode	LINK.32 	A6,#Local$	PUSH.32		D0; Dfinit le rectangle de clipping de la rgion, qui englobe l'cran.	MOVE.32		#0,{A6}+Local$+ClipRect$+OGRectTL	MOVE.16		{A2}+ODFDX,{A6}+Local$+ClipRect$+OGRectBR+OGPtX	MOVE.16		{A2}+ODFDY,{A6}+Local$+ClipRect$+OGRectBR+OGPtY; Dfinit le rectangle qui aura les coins arrondis selon D2.32 et D4.32; donns par l'appelant.	MOVE.32		D2,D0	SWAP.32		D4	SWAP.32		D0	MOVE.16		D4,{A6}+Local$+RoundRect$+OGRectTL+OGPtY	ADD.16		D4,D0	MOVE.16		D0,{A6}+Local$+RoundRect$+OGRectBR+OGPtY	SWAP.32		D4	SWAP.32		D0	MOVE.16		D4,{A6}+Local$+RoundRect$+OGRectTL+OGPtX	ADD.16		D4,D0	MOVE.16		D0,{A6}+Local$+RoundRect$+OGRectBR+OGPtX; Cre la rgion de dcoupage. Attention, nous allons faire trs attention; au rsultat du premier appel  GRAMISC, car nous risquons de nous retrouver; avec une erreur ErLibOpe et il nous faudra nettoyer la pile.	SUB.A16		#2,SP	PUSH.32		#{A2}+ODFCRg	GMI_		NewRgn	TEST.16		D7	JUMP,NC		R8^LibOK$	ADD.A16		#4+2,SP				; Boum !	JUMP		R8^Exit$LibOK$:	POP.16		D7	JUMP,NS		Exit$; Ouvre la rgion en mode enregistrement de primitives.	SUB.A16		#2,SP	PUSH.32		{A2}+ODFCRg	PUSH.16		#GFillXOR	PUSH.32		#{A6}+Local$+ClipRect$	GMI_		OpenRgn	POP.16		D7	JUMP,NS		ExitDispose$; Ajoute le rectangle.	SUB.A16		#2,SP	PUSH.32		{A2}+ODFCRg	PUSH.32		#{A6}+Local$+RoundRect$	PUSH.16		#Radius	PUSH.16		#Radius	PUSH.8		#0	GMI_		PutOval	POP.16		D7	JUMP,NS		ExitDispose$; Referme la rgion.	SUB.A16		#2,SP	PUSH.32		{A2}+ODFCRG	GMI_		CloseRgn	POP.16		D7	JUMP,NC		R8^Exit$ExitDispose$:	PUSH.16		D7				; Ya eu une couille, on	CALL		ClearClipping	POP.16		D7Exit$:	POP.32		D0	UNLINK.32 	A6	TEST.16 	D7	RET;---------------\\; ClearClipping  >;---------------/; Dtruit la rgion de dcoupage de l'cran.; In:	A2 ^descripteur de fentre; Out:	D7.16 erreur; Mod:	D7.16 FClearClipping:	SUB.A16		#2,SP	PUSH.32		{A2}+ODFCRg	CLR.32		{A2}+ODFCRg	GMI_		DisposeRgn	POP.16		D7	RET;---------\\; SetCLUT  >;---------/; Charge la table des fausses couleurs d'une image.; In:	A4 ^table des fausses couleurs.; Out:	D7.16 erreur; Mod:	D7.16 FSetCLUT:.APC	PCDef.LOC	Nil.ODDBuffer$:	.BLK.8		10'11.EVENlLocal$		=	APC.LOC	-lLocal$Local$:		.BLK.8		lLocal$oldA6$:		.BLK.32		1retAddr$:	.BLK.32		1.APC	PCCode	LINK.32 	A6,#Local$	PUSHM.32 	D0..D3|A3|A4	MOVE.32		#16-1,D0	CLR.32		D1Loop$:	MOVE.32		#{A6}+Local$+Buffer$,A3	MOVE.8		#ColorFalse,{A3}	MOVE.32		D1,{A3}+1	INC.32		D1	MOVE.8		{A4+},D2	SL.16		#8,D2	MOVE.16		D2,{A3}+1+4+0	MOVE.8		{A4+},D2	SL.16		#8,D2	MOVE.16		D2,{A3}+1+4+2	MOVE.8		{A4+},D2	SL.16		#8,D2	MOVE.16		D2,{A3}+1+4+4	MOVE.32		#11,D3	LIB		?StringSKIP,NS DJ.16,NMO 	D0,Loop$	POPM.32		D0..D3|A3|A4	UNLINK.32 	A6	TEST.16		D7	RET;----------------\\; LoadColorImage  >;----------------/; Charge une image couleur (extension .IMAGE) et l'affiche au centre de; l'cran.; In:	A3 ^nom du fichier  charger, extension pas obligatoire.; 	A2 ^descripteur d'cran; Out:	D7.16 erreur; Mod:	D7.16 FLoadColorImage:.APC	PCDef.LOC	NilHeader$:	.BLK.8		LGHImageCLUT$:		.BLK.8		16*3.EVENlLocal$		=	APC.LOC	-lLocal$Local$:		.BLK.8		lLocal$oldA6$:		.BLK.32		1retAddr$:	.BLK.32		1.APC	PCCode	LINK.32 	A6,#Local$	PUSHM.32 	A0|A3|A4|D0..D6	MOVE.32		#R16^extColor,A4		; Ajoute l'extension	MOVE.32		#1,D3	LIB		?AddExt	MOVE.32		#2**BOpSys.OR.2**BOpRD,D3	; Ouvre le fichier dans le	FOS		?Open				; dossier systme	JUMP,NS		Exit$Again$:	MOVE.32		#{A6}+Local$+Header$,A4		; Lit l'en-tte	MOVE.32		#LGHImage,D4	FOS		?RDByte	JUMP,NS		CloseExit$	TEST.32		{A4}+OImageCLUT			; Table des fausses couleurs ?	JUMP,EQ		noCLUT$				; non => on oublie...	MOVE.32		#{A6}+Local$+CLUT$,A4	MOVE.32		#16*3,D4	FOS		?RDByte	JUMP,NS		CloseExit$	CALL		SetCLUT				; On charge la table...	JUMP,NS		CloseExit$noCLUT$:	MOVE.16		{A6}+Local$+Header$+OImageWidth,D4	ADD.16		#1,D4	SR.16		D4	MUL.16		{A6}+Local$+Header$+OImageHeight,D4	MOVE.32		D4,D0	INC.32		D4	TCLR.32		D4:#0				; Arrondi	MOVE.32		#MTypCP,D1	GESMEM		?GetMem				; Demande de la mmoire.	JUMP,NS		CloseExit$	MOVE.32		D0,D4	FOS		?RDByte	JUMP,NS		GivMCloseExit$	MOVE.32		A4,A3				; A3 ^data	MOVE.32		{A6}+Local$+Header$+OImageWidth,D2	SWAP.32		D2	CALL		CenterImage			; Centre l'image dans l'cran	CALL		SetupClipping	JUMP,NS		GivmCloseExit$	MOVE.16		{A6}+Local$+Header$+OImageWidth,D5	INC.16		D5	SR.16		D5				; D5.16 <- rowBytes source	MOVE.32		#Nil,A0				; Destination = cran	MOVE.32		#0,D0	MOVE.32		#0,D3				; coord. source = {0;0}	MOVE.32		#LoadDot.OR.2**BSrcCoul.OR.2**BDstCoul,D1 ; Mode = chargement	LIB		?AFTIM.ASCIZE	"<AFCCMO>"	EX.32		A0,A4				; Registres "de rechange".	EX.32		D0,D6	Gra2_		CRaster	EX.32		D0,D6	EX.32		A0,A4	PUSH.16		D7	LIB		?AFTIM.ASCIZE	"<AFSCMO>"	POP.16		D7	JUMP,NS		GivMCloseExit$	CALL		ClearClippingGivMCloseExit$:	PUSH.16		D7	MOVE.32		#MTypCP,D1	GESMEM		?GivMem	POP.16		D7CloseExit$:	PUSH.16		D7	FOS		?Close	POP.16		D7Exit$:	POPM.32 	A0|A3|A4|D0..D6	UNLINK.32 	A6	RET;-----------\\; LoadImage  >;-----------/; Charge une image noir/blanc (extension .IMAGE) et l'affiche au centre de; l'cran.; In:	A3 ^nom du fichier  charger, extension pas obligatoire.; 	A2 ^descripteur d'cran; Out:	D7.16 erreur; Mod:	D7.16 FLoadImage:.APC	PCDef.LOC	NilHeader$:	.BLK.8		LGHImagelLocal$		=	APC.LOC	-lLocal$Local$:		.BLK.8		lLocal$oldA6$:		.BLK.32		1retAddr$:	.BLK.32		1.APC	PCCode	LINK.32 A6,#Local$	PUSHM.32 A0|A3|A4|D0..D6	MOVE.32	#R16^extImage,A4		; Ajoute l'extension	MOVE.32	#1,D3	LIB	?AddExt	MOVE.32	#2**BOpSys.OR.2**BOpRD,D3	; Ouvre le fichier dans le	FOS	?Open				; dossier systme	JUMP,NS	Exit$Again$:	MOVE.32	#{A6}+Local$+Header$,A4		; Lit l'en-tte	MOVE.32	#LGHImage,D4	FOS	?RDByte	JUMP,NS	Exit$	COMP.8	#16'82,{A4}			; Ancien format avec en-tte binaire ?	JUMP,NE	Ok$	CLR.32	D3				; Oui => on saute cette en-tte	MOVE.32	#LGBlk,D4	FOS	?SPos	JUMP,NS	Exit$	JUMP	Again$				; Et on re-tente notre chance...Ok$:	MOVE.16	{A4}+OImageWidth,D4	ADD.16	#7,D4	SR.16	#3,D4	MUL.16	{A4}+OImageHeight,D4	ADD.32	#ImLBuf+1,D4			; Place pour le dcodage	TCLR.32	D4:#0				; et arrondi	MOVE.32	#MTypCP,D1	GESMEM	?GetMem				; Demande de la mmoire.	JUMP,NS	CloseExit$	MOVE.32	{A6}+Local$+Header$+OImageFileSize,D4	FOS	?RDByte	JUMP,NS	GivMCloseExit$	MOVE.32	A4,A3				; A3 ^data	TEST.8	{A6}+Local$+Header$+OImageCompress	JUMP,EQ	NotCompressed$	MOVE.32	#{A4}+ImLBuf,A3			; On dcode l'image...	MOVE.32	#{A6}+Local$+Header$,A0	EX.32	A0,A2	Gra2_	DecoIma	EX.32	A0,A2	JUMP,NS	GivMCloseExit$NotCompressed$:	MOVE.32	{A6}+Local$+Header$+OImageWidth,D2	SWAP.32	D2	CALL	CenterImage			; Centre l'image dans l'cran	CALL	SetupClipping	JUMP,NS	GivMCloseExit$	MOVE.16	{A6}+Local$+Header$+OImageWidth,D5	ADD.16	#7,D5	SR.16	#3,D5				; D5.16 <- rowBytes source	MOVE.32	#Nil,A0				; Destination = cran	MOVE.32	#0,D0	MOVE.32	#0,D3				; coord. source = {0;0}	MOVE.32	#LoadDot,D1			; Mode = chargement	TEST.8	{A2}+ODFMod:#BFBlanc		; Dans le cas d'un cran	JUMP,BS	Black$			;  fond noir, on inverse	TSET.32	D1:#BCplDot			; la source.Black$:	LIB	?AFTIM.ASCIZE	"<AFCCMO>"	EX.32	A0,A4				; Registres "de rechange".	EX.32	D0,D6	Gra2_	Raster	EX.32	D0,D6	EX.32	A0,A4	PUSH.16	D7	LIB	?AFTIM.ASCIZE	"<AFSCMO>"	POP.16	D7	JUMP,NS	GivMCloseExit$	CALL	ClearClippingGivMCloseExit$:	PUSH.16	D7	MOVE.32	#MTypCP,D1	GESMEM	?GivMem	POP.16	D7CloseExit$:	PUSH.16	D7	FOS	?Close	POP.16	D7Exit$:	POPM.32 A0|A3|A4|D0..D6	UNLINK.32 A6	RET;--------------\\; DisplayImage  >;--------------/; Affiche une image couleur et/ou noir/blanc.; In:	A2 ^descripteur de fentre; 	A3 ^ligne de commande; Out:	D7.16 erreur; Mod:	D7.16 FDisplayImage:.APC	PCDef.LOC	NilFile$:		.BLK.8		MaxNameLg	; Nom de fichier construit..EVENlLocal$		=	APC.LOC	-lLocal$Local$:		.BLK.8		lLocal$oldA6$:		.BLK.32		1retAddr$:	.BLK.32		1.APC	PCCode	LINK.32 A6,#Local$			; A6 ^variables locales	PUSH.32	A3	PUSH.32	A4	CALL	SetupScreen			; Prpare l'cran	JUMP,NS	Exit$	MOVE.32	#{A6}+Local$+File$,A4		; Trouve le nom du fichier	CALL	CopyName			;  charger.	JUMP,NS	Exit$	MOVE.32	A4,A3				; A3 ^nom de l'image sans extension.	TEST.8	{A2}+ODFCMD			; Ecran couleur ?	JUMP,F	TryBW$	CALL	LoadColorImage			; Essaie en couleur...	JUMP,NC	Exit$				; C'est bon...TryBW$:	CALL	LoadImage			; Essaie en noir/blancExit$:	POP.32	A4	POP.32	A3	UNLINK.32 A6	TEST.16	D7	RET;----------------\\; NewCommandLine  >;----------------/; Effectue une copie de la ligne de commande  un endroit; modifiable (pas dans la ROM, par exemple).; In:	A3 ^ligne de commande; Out:	D7.16 erreur; 	A4 ^ligne de commande o on peut crire; Mod:	D7.16 A4 FNewCommandLine:	PUSH.32	D4	PUSH.32	D1	MOVE.32	#1,D4	MOVE.32	A3,A4Length$:	TEST.8	{A4+}	JUMP,EQ	LengthFound$	INC.32	D4	JUMP	Length$LengthFound$:	INC.32	D4	TCLR.32	D4:#0	MOVE.32	#MTypCP,D1	GESMEM	?GetMem	JUMP,NS	Exit$	PUSH.32	A4	PUSH.32	A3Copy$:	MOVE.8	{A3+},{A4+}	DEC.32	D4	JUMP,NE	Copy$	POP.32	A3	POP.32	A4Exit$:	POP.32	D1	POP.32	D4	TEST.16	D7	RET	.START	StartStart:	LIB	?OpeLib				; Ouvre la librairie	LIB	?GetPDis			; A2 ^descripteur d'cran	JUMP,NS	NoDisplay$			; Pas d'cran ?!	MOVE.32	A4,A2	CALL	DisplayImage			; Affiche une imageNoDisplay$:	CALL	NewCommandLine			; Demande une copie de la ligne de cmd.	TSET.8	{A4}:#7				; Pas d'appel rcursif...	EX.32	A3,A4	LIB	?OExecute	EX.32	A3,A4	JUMP,EQ	Exit$	MOVE.32	A3,A0				; Sauve ^ligne de commande	MOVE.16	D7,D0				; Sauve erreur	MOVE.32	#BipFat,D3			; Programme pas excutable	LIB	?Beep				; => on crie un peu.	MOVE.32	#3,D3				; Souris new look	LIB	?Mouse	MOVE.32	#R16^DBoxName,A3		; Essaie d'ouvrir la librairie	MOVE.16	#DBox_First,D3	LIB_	Open	JUMP,NS	Exit$	MOVE.16	D0,D7	MOVE.32	A0,A3	MOVE.32	#0,D2				; On ne sauve pas le dessous	DBox_	MError				; Affiche un message d'erreur fatale	LIB_	Close				; On referme DBoxExit$:	MOVE.8	#EOP,D3	LIB	?AFCAR	LIB	?CloLib	FOS	?StopFond:						; Trame pour un cran  fond	.32	16'88228822			; blanc.	.32	16'88228822DBoxName:	.ASCIZ	"DBOX"extImage:	.ASCIZ	"IMAGE"extColor:	.ASCIZ	"COLOR"	.EVEN.END