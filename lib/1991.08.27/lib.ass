e;	D3.32	centre (y;x);	D4.32	rayons (ry;rx); out	D5.32	point (y;x); mod	D5.32, D7.16;-------------\\; LIB ?CALCCOS >;=============/; Calcule rapidement un cosinus.; in	D1.16	angle (0..360), dans le sens des aiguilles de la montre; out	D2.16	cosinus (-10000..+10000); mod	D2.32, D7.16;-------------\\; LIB ?CALCSIN >;=============/; Calcule rapidement un sinus.; in	D1.16	angle (0..360), dans le sens des aiguilles de la montre; out	D2.16	sinus (-10000..+10000); mod	D2.32, D7.16; Gestion des m-menus; -------------------;------------\\; LIB ?MMENUS >;============/; Choix dans un m-menu hirarchique avec la souris.; L'exemple ci-dessous montre une table pointe par A3 :;; MENU:;	.ASCIZ	" ";	.8	-1;	.ASCIZ	" dtruit ";	.ASCIZ	" dplace ";	.ASCIZ	" duplique ";	.8	-1;	.8.16	-2,MENU11$-MENU;	.ASCIZ	" opration "		; > suite en MENU11$;	.8.16	-2,MENU12$-MENU;	.ASCIZ	" divers "		; > suite en MENU12$;	.8	0;; MENU11$:;	.ASCIZ	" tourne ";	.ASCIZ	" zoom ";	.ASCIZ	" dforme ";	.8	0;; MENU12$:;	.ASCIZ	" contour ";	.ASCIZ	" trame ";	.8.16	-2,MENU21$-MENU12$;	.ASCIZ	" lisse "		; > suite en MENU21$;	.8	0;; MENU21$:;	.ASCIZ	" fin ";	.ASCIZ	" moyen ";	.ASCIZ	" grossier ";	.8	0;; REMARQUES:;	- Dans le  .8.16 -2,ad  l'adresse peut tre impaire !;	- C'est LIB ?MMENUS qui affiche les triangles ">"  droite,;	  dans les cases o cela est ncessaire.;; L'exemple ci-dessous montre les paramtres points par A4.32 :;; OPARAM: .BLK.8  LMM*4		; *4 car il y a 1 menu et 3 sous-menus;; in	A3.32	^m-menus hirarchiques;	A4.32	^table pour les paramtres (in+out);	D5.32	flags (BMSxxx);	D2.32	coin sup/gauche (si D5:#BMSPOSx=1); out	D7.16	erreur; mod	D7.16;------------\\; LIB ?MMENU  >;============/; Choix dans un m-menu unique (non hirarchique) avec la souris,; jusqu' ce que l'tat des boutons change.; in	A3.32	^textes .ASCIZ termins par zro;	D3.16	choix par dfaut;	D4.32	bitmap des cases inactives (si D3:#15=1