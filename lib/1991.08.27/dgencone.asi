	.SBTTL	DGENCONE; Constantes; ----------NBCRX	=	20		; largeur du rectangleNBCZX	=	20		; largeur de la zoneNBCZY	=	4		; hauteur de la zoneBFADOUB	=	8		; fanion "double"BFAAFF	=	16		; fanion "affiche"BFATOUT	=	17		; fanion "tout"BFAORIG	=	18		; fanion "original"BFAANAL	=	19		; fanion "analytique" (taille=00);------------\\; _DGENC_LIST >;============/; Fait la liste de tous les gencar disponibles.; Pour vider ou initialiser la liste, il faut la mettre; dans l'un des tats suivants :;	a)	<-1>;	b)	<-2> nom <0> <-1>	(nom de l'imprimante);; La liste peut avoir les tats suivants :;;	             |-------|  |-------|  |-------|  |-------|;	OMDPLN --|-->|  -1   |  |   0   |  |  -2   |  |  -2   |    ^;	OMDPLF --|   |-------|  |-------|  |-------|  |-------|    |;	             |       |  |       |  |       |  |       |    |;	             |       |  |       |  |  nom  |  |  nom  |    |;	             |       |  |       |  |       |  |       |    |;	             |       |  |       |  |-------|  |-------|    | LGMN;	             |       |  |       |  |   0   |  |   0   |    |;	             |       |  |       |  |-------|  |-------|    |;	OMDPLF --------------------------->|  -1   |  |   0   |    |;	             |       |  |       |  |-------|  |-------|    |;	             |       |  |       |  |       |  |       |    v;	             |-------|  |-------|  |-------|  |-------|;	OMDPLV ----->|       |  |       |  |       |  |       |    ^;	             |       |  |       |  |       |  |       |    |;	             |  var  |  |  var  |  |  var  |  |  var  |    | LGMV;	             |       |  |       |  |       |  |       |    |;	             |       |  |       |  |       |  |       |    v;	             |-------|  |-------|  |-------|  |-------|;	OMDPLI ----->|       |  | gencar|  |       |  | gencar|;	             |       |  |       |  |       |  |       |;	             |       |  |-------|  |       |  |-------|;	             |       |  | gencar|  |       |  | gencar|;	             |       |  |       |  |       |  |       |;	             |       |  |-------|  |       |  |-------|;	             |       |  | gencar|  |       |  | gencar|;	             |       |  |       |  |       |  |       |;	             |       |  |-------|  |       |  |-------|;	             |       |  |   0   |  |       |  |   0   |;	             |       |  |-------|  |       |  |-------|;	             |       |  |       |  |       |  |       |;	             |       |  |       |  |       |  |       |;;	nom:       nom de l'imprimante (OKI, LQ, etc.);	var:       qq variables permanantes concerves chez l'utilisateur;	gencar:    3 bytes pour coder un gencar; in	A4.L	^buffer;	D4.W	longueur du buffer (3 bytes par gencar); out	D7.W	erreur; mod	D7.W_DGENC_LIST:	PUSHM.L	D1..D6,A0..A5	LOAD.W	D2,D4		; D2 <-- lg du buffer	SUB.W	D2,#LGMN+LGMV	PUSH.L	A4	LOAD.L	A5,#R16"00$	; A5 <-- ^pas de nom d'imprimante	COMP.B	(A4),#-2	; liste commence par un nom d'imprimante ?	JUMP',NE 06$		; non => 06$				; oui =>	INC.L	A4	LOAD.L	A5,A4		; A5 <-- ^nom de l'imprimante04$:	TEST.B	(A4+)		; A4 <-- saute le nom	JUMP,NE 04$06$:	CLR.B	(A4)		; clear flag en OMDPLF	POP.L	A4	LOAD.L	A4,#(A4)+LGMN+LGMV	LOAD.L	A1,A4		; A1 <-- ^dbut buffer des gencar	LOAD.L	A0,A4		; A0 <-- ^dans buffer des gencar	CLR.B	(A0)		; buffer <-- terminateur	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	FOS	?OPINFO	LOAD.L	A2,A4		; A2 <-- ^informations	CLR.W	D4		; D4 <-- pas de mise  jour	FOS	?CLINFO	LOAD.L	A3,#R16"TGC	; A3 <-- ^critre *.GENC	LOAD.W	D3,#2^BOPRD!2^BOPSYS!2^BOPNEXT ; D3 <-- mode d'ouverture de SYS_LIST	LIST_	SOPEN		; D6 <-- canal	JUMP,NE 90$	DEC.W	D2		; D2 <-- place pour le <0> terminateur20$:	LIST_	NEXT		; A3 <-- ^nom et A4 <-- ^arguments	JUMP,NE 70$		; y'en a plus => 70$	LOAD.L	D1,(A4)+OBAATT	; D1 <-- attributs	CALL	IFIMPGC		; gencar de l'imprimante ?	JUMP',NE 30$		; non => 30$				; oui =>	LIB	?SYNGC		; D3,D4,D5 <-- gencar	JUMP,NE 20$	COMP.B	D3,#'D		; fonte rserve pour l'imprimante ?	JUMP',EQ 45$		; oui => 45$	COMP.B	D3,#'Q	JUMP',EQ 45$	JUMP	20$30$:	PUSH.L	A5	LOAD.L	A5,#R16"TGCSMA	CALL	IFIMPGC		; gencar de la machine (SMA) ?	POP.L	A5	JUMP,NE 20$		; non => 20$				; oui =>	LIB	?SYNGC		; D3,D4,D5 <-- gencar	JUMP,NE 20$	COMP.B	D3,#'D		; fonte rserve pour l'imprimante ?	JUMP,EQ 20$		; oui => 20$	COMP.B	D3,#'Q	JUMP,EQ 20$40$:	TEST.L	D1:#BATTL	; attribut "L" prsent ?	JUMP',BC 50$		; non => 50$45$:				; oui =>	TSET.L	D5:#7		; D5 <-- met l'attribut "L" avec la taille !50$:	CALL	IFUSEGC		; gencar dj dans la liste ?	JUMP,NE 20$		; oui => 20$	SUB.W	D2,#3		; encore de la place dans le buffer ?	JUMP',LO 70$		; non => 70$	LOAD.B	(A0+),D3	; buffer <-- fonte	LOAD.B	(A0+),D4	; buffer <-- chasse	LOAD.B	(A0+),D5	; buffer <-- taille	CLR.B	(A0)		; buffer <-- terminateur	JUMP	20$70$:	LIST_	CLOSE		; ferme le canal de liste	CLR.W	D7		; D7 <-- ok90$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	POP.W	D7	POPM.L	D1..D6,A0..A5	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0	.EVEN;----------\\; DBOXCARAC >;==========/; Demande  l'utilisateur quel caractre il veut avec une jolie dbox.; in	A4.L	^dans buffer gencar; out	D7.W	erreur; mod	D7.WDBOXCARAC:	PUSHM.L	D0..D5,A0..A5	LOAD.L	A5,#(A6)+OMDASL	; A5 <-- ^variables de la scroll-liste	LOAD.L	A0,(A6)+OMDPDD	; A0 <-- ^description de la fentre	LOAD.L	(A6)+OMDPGM,A4	LOAD.L	D4,(A4)+OGCCOD	; D4 <-- gencar actuel	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP',BS INIT2$	LOAD.L	A4,(A6)+OMDPGC	; A4 <-- ^buffer des gencars	LOAD.L	D4,(A4)+OGCCOD	; D4 <-- gencar du "Fond"INIT2$:	LOAD.L	(A6)+OMDGEN,D4	; mm. gencar actuel; Met le titre actuel dans OMDNGC pour qu'en cas d'annulation; ou d'erreur le titre original donn en entre ne soit pas modifi.	CALL	DBCAPTIT	; OMDNGC <-- titre	LOAD.L	A4,(A6)+OMDPLV	; A4 <-- ^variables permanantes	CLR.L	D0	LOAD.B	D0,(A4)+OMVFAN	SWAP.W	D0		; D0 <-- fanions par dfaut	LOAD.L	A2,#R16"TDBOX_CARAC	LOAD.W	D2,(A6)+OMDMOD	; D2 <-- mode	LOAD.L	D3,(A6)+OMDPOS	; D3 <-- position	LOAD.L	D4,D0		; D4 <-- fanions	DBOX_	OPEN		; D5 <-- canal	JUMP,NE EXIT$; Dessine le rectangle autour de la zone pour afficher les; caractres rels.	LOAD.W	D2,#102!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,#3	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	INC.W	D3	SWAP.W	D3	LOAD.L	(A6)+OMDPOZ,D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#NBCZX	PUSH.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	MUL.WU	D4,#NBCZY	SUB.W	D4,(A0)+ODFC2Y	DEC.W	D4	SWAP.W	D4	POP.W	D4	LOAD.L	(A6)+OMDDIZ,D4	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine le rectangle autour de la zone; Dessine le rectangle autour des noms des gencars, coll contre; l'ascenseur.	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#NBCRX	ADD.W	D4,#LGSCROLL	LOAD.W	(A5)+OSLDIM+2,D4	LOAD.W	D2,#101!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A5)+OSLPOS+0	LOAD.W	(A5)+OSLDIM+0,D3	SET.B	(A5)+OSLASV+OSCPAGERELOOP$:	SCROLL_	LDRAW		; dessine la scroll-liste	LOAD.L	A4,(A6)+OMDPLF	; A4 <-- ^flag	COMP.B	(A4),#-1	; liste dj faite ?	JUMP',NE OKLIST$	; oui => OKLIST$				; non =>	LOAD.L	A4,(A6)+OMDPLN	; A4 <-- ^nom imprimante puis liste des gencars	LOAD.W	D4,(A6)+OMDLLI	; D4 <-- lg max	CALL	_DGENC_LIST	; fait la liste des gencars sur disque	JUMP,NE CANCEL$OKLIST$:	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	CALL	SORTGC		; trie tous les gencars	CALL	COUNTGC		; compte tous les gencars	CALL	SEARCHGC	; cherche le gencar initial	JUMP',EQ FIND$		; trouv => FIND$				; cach =>	TSET.L	D0:#BFATOUT	; D0 <-- affiche tout	CALL	SORTGC		; re-trie tous les gencars	CALL	COUNTGC		; re-compte tous les gencars	CALL	SEARCHGC	; re-cherche le gencar initialFIND$:	LOAD.L	A4,#R16"GTXONEGC	LOAD.L	(A5)+OSLADL,A4	SCROLL_	LUPDATE		; dessine le contenu de la scroll-liste	LOAD.W	(A6)+OMDLGR,#-1	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier; Met le pointeur  la fin du titre actuel.	CLR.W	D2		; D2 <-- dite la fonctionEDIT0$:	LOAD.L	A4,#R16"TDBOX_CARAC	LOAD.W	A3,(A4)+2	; A3 <-- ^relatif table menu	ADD.L	A3,A4		; A4 <-- ^table menu	LIB	?AFMENU		; affiche les soft-keysEDIT$:	LOAD.L	A4,(A6)+OMDPLI	; A4 <-- ^liste des gencars	LOAD.W	D4,(A5)+OSLCYS	MUL.WU	D4,#3	ADD.L	A4,D4		; A4 <-- ^gencar slectionn	LOAD.B	D4,(A4)+2	AND.B	D4,#H'7F	; taille 00 ?	JUMP',EQ EDIT1$		; oui => EDIT$	CLR.W	D2EDIT1$:	LOAD.L	A3,#(A6)+OMDNGC	; A3 <-- ^dbut du titre	TEST.W	D2	JUMP',EQ EDIT2$	LOAD.L	A3,#(A6)+OMDNTA	; A3 <-- ^dbut de la tailleEDIT2$:	LOAD.L	A4,A3EDIT3$:	TEST.B	(A4+)	JUMP,NE	EDIT3$	DEC.L	A4		; A4 <-- ^fin titre/taille	LOAD.W	D3,D2	DBOX_	MEDITLOOP0$:	CALL	IFCALCGC	; supprime v. styles cumuls	CALL	AFGREYGC	; affiche qq textes gris/plein	CALL	DISPLAYGC	; affiche le gencar relLOOP$:	LOAD.L	D4,D0		; D4 <-- fanions	DBOX_	EDIT		; attend une action ...	LOAD.L	D0,D4		; D0 <-- fanions; Remplace tout de suite le <CR> terminant le titre par un <0>.	LOAD.L	A1,A3ZEROCR2$:	TEST.B	(A1)	JUMP',EQ ZEROCR3$	COMP.B	(A1+),#CR	; remplace le <CR> terminateur	JUMP,NE	ZEROCR2$	; par un <0>	CLR.B	(A1)-1ZEROCR3$:	LOAD.L	A1,#R16"TKEYCARAC	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	; bouton souris press ?	JUMP',EQ CLIC$		; oui => CLIC$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ NEXT$	COMP.W	D3,#KEYDBOX+0	JUMP,EQ ED0$	COMP.W	D3,#KEYDBOX+1	JUMP,EQ ED1$	COMP.W	D3,#KEYDBOX+7	JUMP,EQ LOOP0$	COMP.W	D3,#KEYDBOX+8	JUMP,EQ LOOP0$	COMP.W	D3,#KEYDBOX+9	JUMP,EQ RELOOP$	COMP.W	D3,#ENTER	JUMP,EQ LOOP0$	CLR.W	D7		; D7 <-- ok	COMP.W	D3,#F1		; ok ?	JUMP,EQ OK$	COMP.W	D3,#F4	JUMP,EQ REFAIT$	COMP.W	D3,#END		; annule ?	JUMP,EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:				; clic =>	LIB	?IFMOUSE	; D4 <-- position de la souris	SUB.W	D4,(A0)+ODFFX	JUMP,LO BIP$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- position relative dans swdo	JUMP,LO BIP$	SWAP.W	D4	SCROLL_	LMOVE		; dplace la scroll-liste ...	JUMP,EQ EDIT$	SUB.W	D4,(A6)+OMDPOZ+2	JUMP,LO BIP$	COMP.W	D4,(A6)+OMDDIZ+2	JUMP,HS BIP$	SWAP.W	D4	SUB.W	D4,(A6)+OMDPOZ+0	JUMP,LO BIP$	COMP.W	D4,(A6)+OMDDIZ+0	JUMP,HS BIP$	TSET.L	D0:#BFAAFF	; D0 <-- met "affiche"	JUMP	LOOP0$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A3)	JUMP	LOOP$NEXT$:				; suivant =>	TEST.L	D0:#BFAANAL	JUMP,BC BIP$	INC.W	D2	COMP.W	D2,#2	JUMP,LO EDIT$	CLR.W	D2	JUMP	EDIT$ED0$:	CLR.W	D2	JUMP	EDIT$ED1$:	TEST.L	D0:#BFAANAL	JUMP,BC BIP$	LOAD.W	D2,#1	JUMP	EDIT$REFAIT$:			; refait =>;;?	LIB	?FLUSHNGC	; vide le contenu de SMA_GENC.INFO	LOAD.L	A4,(A6)+OMDPLF	; A4 <-- ^flag	LOAD.B	(A4),#-1	; liste plus  jour	JUMP	RELOOP$OK$:				; OK =>	TEST.L	D0:#BFAANAL	JUMP',BC OK2$	LOAD.L	A4,#(A6)+OMDNTA	; A4 <-- ^taille en ASCII	CALL	GETANUM		; D4 <-- taille dite	TEST.B	D4	JUMP,EQ BIP$	LOAD.B	(A6)+OMDGEN+3,D4OK2$:	LOAD.L	A4,(A6)+OMDPGM	; A4 <-- ^gencar  modifier	LOAD.L	(A4)+OGCCOD,(A6)+OMDGEN	LOAD.L	A2,#R16"TERGNN	LOAD.L	A3,#(A6)+OMDNGC	; A3 <-- ^nom de la fonction	TEST.B	(A3)		; titre existe ?	JUMP,EQ ERROR$		; non => ERROR$	LOAD.L	A1,#(A4)+OGCTIT	; A1 <-- ^titre dans buffer des gencars	PUSH.B	(A1)	CLR.B	(A1)	LOAD.L	A2,#R16"TERGNE	LOAD.L	A4,(A6)+OMDPGC	; A4 <-- ^buffer des gencars	CALL	_DGENC_SEARCH	; titre dj utilis ?	POP.B	(A1)	TEST.W	D7	JUMP,EQ ERROR$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.W	D4,#10	NTREL	?DELMS		; attend que le sablier s'affiche !	PUSH.L	A3	LOAD.L	A4,(A6)+OMDPGM	; A4 <-- ^dans le buffer des gencars	LOAD.L	D4,(A6)+OMDNOK	; D4 <-- gencar  ne jamais dtruire	LOAD.L	A2,(A6)+OMDPDD	; A2 <-- ^descripteur de la fentre	LOAD.L	A3,(A6)+OMDPGC	; A3 <-- ^buffer des gencars	CALL	_DGENC_NEW	; charge gencar si ncessaire	POP.L	A3	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	POP.W	D7	JUMP',EQ OK7$		; ok => OK7$	LOAD.L	A2,#R16"TERGFN	COMP.W	D7,#ERDIGC	; gencar inexistant ?	JUMP',EQ ERROR$		; oui => ERROR$	JUMP'	OK9$OK7$:	LOAD.L	A2,#(A4)+OGCTIT	; A2 <-- ^titre du gencar  modifierOK8$:	LOAD.B	(A2+),(A3+)	JUMP,NE	OK8$OK9$:	LOAD.L	A4,(A6)+OMDPLV	; A4 <-- ^variables permanantes	SWAP.W	D0	LOAD.B	(A4)+OMVFAN,D0	; mm. les fanions par dfaut	JUMP'	CANCEL$ERROR$:				; erreur =>	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP	POP.W	D7	LOAD.L	A3,A2		; A3 <-- ^texte de l'erreur	LOAD.W	D2,(A6)+OMDMOD	; D2 <-- mode d'ouverture	LOAD.L	D3,(A6)+OMDPOS	; D3 <-- position	DBOX_	TERROR		; affiche l'erreur	CLR.W	D2		; D2 <-- dite le nom de la fonction	JUMP	EDIT0$CANCEL$:			; ANNULE =>	PUSH.W	D7	DBOX_	CLOSE		; ferme la dbox	POP.W	D7EXIT$:	POPM.L	D0..D5,A0..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBCAPTIT >;---------/; Cherche le titre du gencar.; in	-; out	-; mod	D7.WDBCAPTIT:	PUSHM.L	D4,A3,A4	LOAD.L	A3,#(A6)+OMDNGC	; A3 <-- ^buffer temporaire	LOAD.L	A4,(A6)+OMDPGM	; A4 <-- ^gencar  modifier	LOAD.L	A4,#(A4)+OGCTIT	; A4 <-- ^titre du gencar  modifier	TEST.B	(A4)		; titre existe ?	JUMP',NE XFER$		; oui => XFER$	LOAD.L	D4,(A6)+OMDPGM	SUB.L	D4,(A6)+OMDPGC	DIV.WU	D4,#LGGC	; D4 <-- rang (0..n)	LOAD.L	A4,#R16"TDEF$DEF$:	TEST.B	(A4)	JUMP',EQ XFER$	DEC.W	D4	JUMP',NS XFER$NEXT$:	TEST.B	(A4+)		; A4 <-- ^nom suivant	JUMP,NE NEXT$	JUMP	DEF$XFER$:	LOAD.B	(A3+),(A4+)	; buffer temporaire <-- titre	JUMP,NE	XFER$	POPM.L	D4,A3,A4	RETTDEF$:	.ASCIZ	"Fond"	.ASCIZ	"Evidence"	.ASCIZ	"Italique"	.ASCIZ	"Titre"	.ASCIZ	"Sous-titre"	.ASCIZ	"Lgende"	.ASCIZ	"Liste"	.ASCIZ	"Encart"	.ASCIZ	"Spcial"	.ASCIZ	"Grec"	.B	0	.EVEN;---------\\; GTXONEGC >;---------/; Donne le texte d'une case de la scroll-liste.; Appel directement depuis SCROLL_LUPDATE !; in	D3.W	rang de la case (0..OSLCYN-1); out	D3.W	zro/un;	A3.L	^contenu de la case termin par <0> ou <CR>;	D7.W	erreur si la case est vide; mod	D3.L, D7.W, A3.LGTXONEGC:	PUSHM.L	D1,D2,D4,A4	LOAD.L	A4,(A6)+OMDPLI	; A4 <-- ^liste des gencars	LOAD.W	D2,D3	MUL.WU	D3,#3	ADD.L	A4,D3		; A4 <-- ^premier gencar  afficher	LOAD.B	D3,(A4)+0	; D3 <-- fonte	CLR.W	D1		; D1 <-- pas de trait horizontal	COMP.W	(A5)+OSLCYN,#20	; au moins 20 cases ?	JUMP',LO 20$		; non => 20$	INC.W	D2	COMP.W	D2,(A5)+OSLCYN	; dernire case ?	JUMP',HS 20$		; oui => 20$	COMP.B	D3,(A4)+3+0	; changement de fonte ?	JUMP',EQ 20$		; non => 20$	INC.W	D1		; D1 <-- trace un trait horizontal20$:;	LOAD.B	D3,(A4)+0	; D3 <-- fonte	SL.L	D3,#8	LOAD.B	D3,(A4)+1	; D3 <-- style	SL.L	D3,#8	LOAD.B	D3,(A4)+2	; D3 <-- taille	TCLR.L	D3:#7		; D3 <-- enlve l'attribut "L"	CLR.W	D2		; D2 <-- mode	LOAD.L	A3,#(A6)+OMDDIS	LOAD.L	A4,A3	LOAD.W	D4,#20	LIB	?TEXTGC		; OMDDIS <-- nom du gencar	CLR.B	(A4)	LOAD.W	D3,D1		; D3 <-- zro/un	POPM.L	D1,D2,D4,A4	CLR.W	D7	RET;---------\\; SEARCHGC >;=========/; Cherche le gencar actuellement utilis.; in	D0.L	fanions; out	D0.L	fanions;	D7.W	erreur si pas trouv; mod	D7.W, D0.LSEARCHGC:	PUSHM.L	D1..D5,A4	LOAD.W	D7,#1		; D7 <-- pas trouv	CLR.W	(A5)+OSLCYS	CLR.W	D0	TCLR.L	D0:#BFAANAL	; teint le fanion "analytique"; Cherche le gencar en taille simple (1x).SRC1$:	LOAD.B	D1,(A6)+OMDGEN+1	LOAD.B	D2,(A6)+OMDGEN+2	LOAD.B	D3,(A6)+OMDGEN+3	TCLR.L	D1:#7		; fonte construite ?	JUMP',BC SRC12$		; non => SRC12$	AND.B	D2,#H'80	OR.B	D2,#'RSRC12$:	LOAD.L	A4,(A6)+OMDPLI	; A4 <-- ^liste des gencars	LOAD.W	D4,(A5)+OSLCYNSRC14$:	TEST.W	D4	JUMP',EQ SRC2$	COMP.B	D1,(A4)+0	JUMP',NE SRC18$	COMP.B	D2,(A4)+1	JUMP',NE SRC18$	LOAD.B	D5,(A4)+2	AND.B	D5,#H'7F	COMP.B	D3,D5	JUMP,EQ FOUND$SRC18$:	DEC.W	D4	ADD.L	A4,#3	JUMP	SRC14$; Cherche le gencar en taille double (2x).SRC2$:	LOAD.B	D1,(A6)+OMDGEN+1	LOAD.B	D2,(A6)+OMDGEN+2	LOAD.B	D3,(A6)+OMDGEN+3	SR.B	D3,#1		; D3 <-- cherche gencar 2x plus petit !	TCLR.L	D1:#7		; fonte construite ?	JUMP',BC SRCX$		; non => SRCX$	AND.B	D2,#H'80	OR.B	D2,#'R	LOAD.L	A4,(A6)+OMDPLI	; A4 <-- ^liste des gencars	LOAD.W	D4,(A5)+OSLCYNSRC22$:	TEST.W	D4	JUMP',EQ SRCX$	COMP.B	D1,(A4)+0	JUMP',NE SRC28$	COMP.B	D2,(A4)+1	JUMP',NE SRC28$	LOAD.B	D5,(A4)+2	AND.B	D5,#H'7F	COMP.B	D3,D5	JUMP',EQ SRC29$SRC28$:	DEC.W	D4	ADD.L	A4,#3	JUMP	SRC22$SRC29$:	TSET.L	D0:#BFADOUB	; allume le fanion "double"	JUMP	FOUND$; Cherche le gencar en taille 00.SRCX$:	LOAD.B	D1,(A6)+OMDGEN+1	LOAD.B	D2,(A6)+OMDGEN+2	LOAD.B	D3,(A6)+OMDGEN+3	TCLR.L	D1:#7		; fonte construite ?	JUMP',BS EXIT$		; oui => EXIT$	LOAD.L	A4,(A6)+OMDPLI	; A4 <-- ^liste des gencars	LOAD.W	D4,(A5)+OSLCYNSRCX2$:	TEST.W	D4	JUMP',EQ EXIT$	COMP.B	D1,(A4)+0	JUMP',NE SRCX8$	COMP.B	D2,(A4)+1	JUMP',NE SRCX8$	LOAD.B	D5,(A4)+2	AND.B	D5,#H'7F	; taille 00 ?	JUMP',EQ SRCX9$SRCX8$:	DEC.W	D4	ADD.L	A4,#3	JUMP	SRCX2$SRCX9$:	TSET.L	D0:#BFAANAL	; allume le fanion "analytique"	TCLR.L	D0:#BFAORIG	PUSH.W	D4	LOAD.L	A4,#(A6)+OMDNTA	CLR.L	D4	LOAD.B	D4,D3	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?PUTDEC		; OMDNTA <-- taille en ASCII	POP.W	D4;	JUMP'	FOUND$; Le gencar a t trouv dans la liste.FOUND$:	CLR.W	D7		; D7 <-- ok, trouv	SUB.W	D4,(A5)+OSLCYN	NEG.W	D4	LOAD.W	(A5)+OSLCYS,D4	TEST.L	D0:#BFAANAL	; fonte "analytique"	JUMP',BS EXIT$		; oui => EXIT$	TSET.L	D0:#BFAORIG	TEST.B	(A6)+OMDGEN+1:#7 ; fonte construite ?	JUMP',BC EXIT$		; non => EXIT$	TCLR.L	D0:#BFAORIG	LOAD.B	D0,(A6)+OMDGEN+2	AND.B	D0,#H'7FEXIT$:	POPM.L	D1..D5,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SORTGC  >;========/; Trie tous les gencars selon les critres :;	- fonte;	- taille;	- style;	- chasse; S'il ne faut lister que les gencars visibles, met tous les; gencars invisibles  la fin !; in	D0.L	fanions; out	-; mod	D7.WSORTGC:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,(A6)+OMDPLI	; A4 <-- ^liste des gencars10$:	LOAD.L	A3,A4		; A3 <-- ^dbut du buffer	CLR.W	D2		; D2 <-- pas encore de permutations	TEST.B	(A3)+0	JUMP,EQ 60$	TEST.B	(A3)+3	JUMP,EQ 60$20$:	LOAD.B	D3,(A3)+0	TEST.L	D0:#BFATOUT	JUMP',BS 22$	TEST.B	(A3)+2:#7	; attribut "L" prsent ?	JUMP',BS 22$		; oui => 22$	LOAD.B	D3,#-122$:	LOAD.B	D4,(A3)+3+0	TEST.L	D0:#BFATOUT	JUMP',BS 32$	TEST.B	(A3)+3+2:#7	; attribut "L" prsent ?	JUMP',BS 32$		; oui => 32$	LOAD.B	D4,#-132$:	COMP.B	D3,D4		; fontes ?	JUMP',LO 50$	JUMP',HI 40$	LOAD.B	D3,(A3)+1	AND.B	D3,#H'7F	LOAD.B	D4,(A3)+3+1	AND.B	D4,#H'7F	COMP.B	D3,D4		; styles ?	JUMP',LO 50$	JUMP',HI 40$	LOAD.B	D3,(A3)+2	AND.B	D3,#H'7F	LOAD.B	D4,(A3)+3+2	AND.B	D4,#H'7F	COMP.B	D3,D4		; taille ?	JUMP',LO 50$	JUMP',HI 40$	LOAD.B	D3,(A3)+1	AND.B	D3,#H'80	LOAD.B	D4,(A3)+3+1	AND.B	D4,#H'80	COMP.B	D3,D4		; chasses ?	JUMP',LS 50$40$:				; permute deux gencars =>	LOAD.B	D3,(A3)+0	LOAD.B	(A3)+0,(A3)+3+0	LOAD.B	(A3)+3+0,D3	LOAD.B	D3,(A3)+1	LOAD.B	(A3)+1,(A3)+3+1	LOAD.B	(A3)+3+1,D3	LOAD.B	D3,(A3)+2	LOAD.B	(A3)+2,(A3)+3+2	LOAD.B	(A3)+3+2,D3	INC.W	D2		; D2 <-- une permutation de plus50$:	ADD.L	A3,#3		; A3 <-- ^gencars suivants	TEST.B	(A3)+3	JUMP,NE 20$60$:	TEST.W	D2		; au moins une bermutation (alors, ce rhube) ?	JUMP,NE 10$		; oui => 10$	POPM.L	D2..D4,A3,A4	RET;--------\\; COUNTGC >;========/; Compte le nombre de gencar  afficher.; in	D0.L	fanions; out	-; mod	D7.WCOUNTGC:	PUSHM.L	D3,D4,A4	LOAD.L	A4,(A6)+OMDPLI	; A4 <-- ^liste des gencars	CLR.W	D410$:	TEST.B	(A4)	JUMP',EQ 20$	TEST.L	D0:#BFATOUT	; affiche tout ?	JUMP',BS 15$		; oui => 15$	TEST.B	(A4)+2:#7	; attribut "L" prsent ?	JUMP',BC 20$		; non => 20$15$:	ADD.L	A4,#3	INC.W	D4	JUMP	10$20$:	LOAD.W	(A5)+OSLCYN,D4	POPM.L	D3,D4,A4	RET;---------\\; IFCALCGC >;=========/; Interdit les styles cumuls si le style n'est pas roman,; et met  jour OMDGEN en fonction du gencar slectionn.; in	D0.L	fanions; out	D0.L	fanions; mod	D7.W, D0.LIFCALCGC:	PUSHM.L	D2..D4,A4	LOAD.L	A4,(A6)+OMDPLI	; A4 <-- ^liste des gencars	LOAD.W	D4,(A5)+OSLCYS	MUL.WU	D4,#3	ADD.L	A4,D4		; A4 <-- ^gencar slectionn	LOAD.B	D4,(A4)+0	AND.B	D4,#H'7F	; D4 <-- fonte	COMP.B	D4,#'D		; fonte rserve pour l'imprimante ?	JUMP',EQ 30$		; oui => 30$	COMP.B	D4,#'Q	JUMP',NE 35$30$:	TCLR.L	D0:#BGCOUTL	TCLR.L	D0:#BGCSHAD	TCLR.L	D0:#BGCLARG	TCLR.L	D0:#BFADOUB	TCLR.L	D0:#BFAORIG	TCLR.L	D0:#BFAANAL35$:	TCLR.L	D0:#BFAANAL	LOAD.B	D4,(A4)+2	AND.B	D4,#H'7F	; D4 <-- taille	JUMP',EQ 37$	LOAD.B	D4,(A4)+1	AND.B	D4,#H'7F	; D4 <-- style	COMP.B	D4,#'R		; style roman ?	JUMP',EQ 50$		; oui => 50$				; non =>	CLR.W	D0		; supprime tous les styles cumuls	TCLR.L	D0:#BFAORIG	JUMP'	50$37$:	CLR.W	D0		; supprime tous les styles cumuls	TCLR.L	D0:#BFAORIG	TSET.L	D0:#BFAANAL	TEST.B	(A6)+OMDNTA	; dj une taille connue ?	JUMP',NE 50$		; oui => 50$	LOAD.B	(A6)+OMDNTA+0,#'2	LOAD.B	(A6)+OMDNTA+1,#'0 ; OMDNTA <-- taille 20 par dfaut !	CLR.B	(A6)+OMDNTA+2; Met  jour OMDGEN en fonction du gencar slectionn.50$:	LOAD.B	D4,(A4)+0	; D4 <-- fonte	LOAD.B	D3,(A4)+1	; D3 <-- style	TEST.L	D0:#BFAANAL	; fanion "analytique" allum ?	JUMP',BS 60$		; oui => 60$	TEST.L	D0:#BFAORIG	; fanion "original" allum ?	JUMP',BC 55$		; non => 55$				; oui =>	CLR.W	D0		; D0 <-- enlve tous les styles calculs	JUMP'	60$55$:	LOAD.B	D2,D3	AND.B	D2,#H'7F	COMP.B	D2,#'R		; style roman ?	JUMP',NE 60$		; non => 60$	TSET.L	D4:#7	AND.B	D3,#H'80	OR.B	D3,D060$:	LOAD.B	(A6)+OMDGEN+1,D4	LOAD.B	(A6)+OMDGEN+2,D3	LOAD.B	D4,(A4)+2	; D4 <-- taille	AND.B	D4,#H'7F	TEST.L	D0:#BFADOUB	JUMP',BC 70$	SL.B	D4,#170$:	LOAD.B	(A6)+OMDGEN+3,D4	POPM.L	D2..D4,A4	RET;---------\\; AFGREYGC >;=========/; Affiche quelques textes en gris/plein selon les fanions.; in	D0.L	fanions; out	-; mod	D7.WAFGREYGC:	PUSHM.L	D1..D4,A3,A4	TEST.L	D0:#BFAANAL	; fanion "analytique" allum ?	JUMP,BS ANAL$		; oui => ANAL$	LOAD.L	A4,(A6)+OMDPLI	; A4 <-- ^liste des gencars	LOAD.W	D4,(A5)+OSLCYS	MUL.WU	D4,#3	ADD.L	A4,D4		; A4 <-- ^gencar slectionn	LOAD.B	D4,(A4)+0	AND.B	D4,#H'7F	; D4 <-- fonte	COMP.B	D4,#'D		; fonte rserve pour l'imprimante ?	JUMP',EQ PRINT$		; oui => PRINT$	COMP.B	D4,#'Q	JUMP',EQ PRINT$		; oui => PRINT$	LOAD.B	D4,(A4)+1	AND.B	D4,#H'7F	; D4 <-- style	COMP.B	D4,#'R		; style roman ?	JUMP',EQ ROMAN$		; oui => ROMAN$	LOAD.L	D1,#BDBGCGREY*H'1000000+BDBGCGREY*H'10000+BDBGCGREY*H'100+BDBGCGREY*H'1	JUMP'	GREY$PRINT$:	LOAD.L	D1,#BDBGCGREY*H'1000000+BDBGCGREY*H'10000+BDBGCGREY*H'100+BDBGCFULL*H'1	JUMP'	GREY$ROMAN$:	LOAD.L	D1,#BDBGCGREY*H'1000000+BDBGCFULL*H'10000+BDBGCGREY*H'100+BDBGCGREY*H'1	TEST.L	D0:#BFAORIG	; fanion "original" allum ?	JUMP',BS GREY$		; oui => GREY$	LOAD.L	D1,#BDBGCGREY*H'1000000+BDBGCFULL*H'10000+BDBGCFULL*H'100+BDBGCFULL*H'1	JUMP'	GREY$ANAL$:	LOAD.L	D1,#BDBGCFULL*H'1000000+BDBGCGREY*H'10000+BDBGCGREY*H'100+BDBGCGREY*H'1;	JUMP'	GREY$GREY$:	LOAD.W	D2,#BGCBOLD!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO		; grise/dgrise "gras"	LOAD.W	D2,#BGCITAL!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO		; grise/dgrise "italique"	SR.L	D1,#8	LOAD.W	D2,#BGCOUTL!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO		; grise/dgrise "relief"	LOAD.W	D2,#BGCSHAD!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO		; grise/dgrise "ombr"	LOAD.W	D2,#BGCLARG!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO		; grise/dgrise "largeur x 2"	LOAD.W	D2,#BGCDOUB!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO		; grise/dgrise "dimensions x 2"	SR.L	D1,#8	LOAD.W	D2,#BFAORIG!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO		; grise/dgrise "original"	SR.L	D1,#8	LOAD.W	D2,#BFAANAL!2^7!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO		; grise/dgrise "Taille"	LOAD.W	D2,#BFAANAL!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"   "		; efface le chiffre contenu	.EVEN	LOAD.W	D2,#BFAANAL!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO		; grise/dgrise "analytique"	COMP.B	D1,#BDBGCFULL	JUMP',NE EXIT$	LOAD.W	D2,#BFAANAL!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OMDNTA	LIB	?AFTEXT		; affiche la tailleEXIT$:	POPM.L	D1..D4,A3,A4	RET;--------\\; IFIMPGC >;--------/; Vrifie si un nom de gencar commence par une chane donne.; in	A3.L	^nom du fichier gencar (SMA_TRP14.GENC);	A5.L	^nom de l'imprimante (SMA, OKI, LQ, etc.); out	D7.W	EQ => ok, a correspond;	 A3.L	 ^fonte, style, etc. (TRP14);	D7.W	NE => autre chose; mod	D7.W, A3.LIFIMPGC:	PUSHM.L	A4,A5	LOAD.W	D7,#1		; D7 <-- autre chose	LOAD.L	A4,A310$:	TEST.B	(A5)	JUMP,EQ 50$	COMP.B	(A5+),(A4+)	JUMP,EQ 10$	JUMP	90$50$:	COMP.B	(A4),#'_	JUMP,NE 90$	LOAD.L	A3,#(A4)+1	; A3 <-- saute jusqu'aprs le "_"	CLR.W	D7		; D7 <-- a colle90$:	POPM.L	A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFUSEGC >;--------/; Cherche si un gencar est dj dans la liste.; in	A1.L	^buffer des gencars;	D3.B	fonte;	D4.B	style/chasse;	D5.B	taille; out	D7.W	1 => dj dans la liste; mod	D7.WIFUSEGC:	PUSHM.L	D2,D5,A1	CLR.W	D7		; D7 <-- pas dans la liste	AND.B	D5,#H'7F10$:	TEST.B	(A1)		; fin de la liste ?	JUMP',EQ 90$		; oui => 90$				; non =>	COMP.B	D3,(A1)+0	JUMP',NE 40$	COMP.B	D4,(A1)+1	; mme gencar ?	JUMP',NE 40$		; non => 40$	LOAD.B	D2,(A1)+2	; oui => 80$	AND.B	D2,#H'7F	COMP.B	D5,D2	JUMP',EQ 80$40$:	ADD.L	A1,#3		; A1 <-- ^gencar suivant	JUMP	10$80$:	LOAD.W	D7,#1		; D7 <-- dj dans la liste90$:	POPM.L	D2,D5,A1	TEST.W	D7		; retour EQ/NE	RETTDBOX_CARAC:	.W	10$-TDBOX_CARAC	.W	20$-TDBOX_CARAC	.W	0,010$:	.B	ODBTABX,2	.B	ODBTEXT	.ASCIZ	"Fonction du caractre :   "	.B	ODBCLINE,LGTGC!2^7,KEYDBOX/H'100,0,TDBNORM	.B	ODBTABX,2+40	.B	ODBCR,ODBCR	.B	ODBTABX,2	.B	ODBLABEL,100	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,2+2+NBCRX+4	.B	ODBLABEL,BGCBOLD	.B	ODBSQUARE,BGCBOLD!2^7,KEYDBOX/H'100,7	.ASCIZ	" gras"	.B	ODBTABX,2+2+NBCRX+4+12	.B	ODBLABEL,BGCOUTL	.B	ODBSQUARE,BGCOUTL!2^7,KEYDBOX/H'100,7	.ASCIZ	" relief"	.B	ODBCR	.B	ODBTABX,2+2+NBCRX+4	.B	ODBLABEL,BGCITAL	.B	ODBSQUARE,BGCITAL!2^7,KEYDBOX/H'100,7	.ASCIZ	" italique"	.B	ODBTABX,2+2+NBCRX+4+12	.B	ODBLABEL,BGCSHAD	.B	ODBSQUARE,BGCSHAD!2^7,KEYDBOX/H'100,7	.ASCIZ	" ombr"	.B	ODBCR	.B	ODBTABX,2+2+NBCRX+4	.B	ODBLABEL,BGCLARG	.B	ODBSQUARE,BGCLARG!2^7,KEYDBOX/H'100,7	.ASCIZ	" largeur    x 2"	.B	ODBCR	.B	ODBTABX,2+2+NBCRX+4	.B	ODBLABEL,BGCDOUB	.B	ODBSQUARE,BFADOUB!2^7,KEYDBOX/H'100,7	.ASCIZ	" dimensions x 2"	.B	ODBCR	.B	ODBTABX,2+2+NBCRX+4	.B	ODBLABEL,BFAORIG	.B	ODBSQUARE,BFAORIG!2^7,KEYDBOX/H'100,7	.ASCIZ	" original"	.B	ODBCR	.B	ODBCR2	.B	ODBTABX,2+2+NBCRX+4	.B	ODBLABEL,BFAANAL!2^7	.B	ODBTEXT	.ASCIZ	"Taille "	.B	ODBLABEL,BFAANAL	.B	ODBCLINE,(2+2)!2^7,KEYDBOX/H'100,1,TDBNORM	.B	ODBCR2	.B	ODBCR	.B	ODBTABX,2+2+NBCRX+4	.B	ODBLABEL,102	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,2	.B	ODBLABEL,101	.B	ODBTABX,2+2+NBCRX+4	.B	ODBSQUARE,BFAAFF!2^7,KEYDBOX/H'100,8	.ASCIZ	" affiche"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBSQUARE,BFATOUT!2^7,KEYDBOX/H'100,9	.ASCIZ	" tout"	.B	ODBCR,ODBCR	.B	ODBTABX,2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  CREE  "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,F4,TDBOMBRE	.ASCIZ	" REFAIT "	.B	ODBTABX,39	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Cre"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Refait"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"		;     ;     ;     ;	.EVENTKEYCARAC:	.W	F1,F2,F3,0		DOF1-TKEYCARAC	.W	F4,F5,F6,0		DOF4-TKEYCARAC	.W	END,F13,F14,F15,0	DOAN-TKEYCARAC	.W	KEYMGP,KEYMMP,KEYMDP,0	DOMP-TKEYCARAC	.W	KEYMGR,KEYMMR,KEYMDR,0	DOMR-TKEYCARAC	.W	0	.END