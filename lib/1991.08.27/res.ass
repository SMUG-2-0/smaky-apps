	.TITLE	RES.ASS	.BASE	10'10;	Symboles pour le module de librairie RES;	----------------------------------------	.SYSCALL.16 RES_RES_BASE	= 16'A7A0RES_OPEN	= RES_BASE+0			; ouvre & charge un fichier de ressourcesRES_GETTYPE	= RES_BASE+1			; cherche le handle d'un typeRES_GET		= RES_BASE+2			; cherche les donnes contenues dans une ressourceRES_CLOSE	= RES_BASE+3			; ferme un fichier de ressourcesRES_DEF		= RES_BASE+4			; dfinitionsRES_FIRST	= RES_OPENRES_LAST	= RES_DEFRESLIBREVMAJ	= 1RESLIBREVMIN	= 7RESLIBREVPRO	= " ";	Un fichier de ressources porte toujours l'extension .RS et;	se prsente comme un binaire cachable contenant :;	1) L'en-tte binaire;	2) L'en-tte du fichier de ressources;	3) L'en-ttes d'un type;	4) Ses donnes;	+ 3) et 4) rpts;	Lorsque l'on rencontre le mot "offset" ci-dessous, cela sous-entend;	"offset par rapport au dbut du fichier".;	Dfinition de l'en-tte d'un fichier de ressources;	--------------------------------------------------		.LOC	0ORFILEPATTERN:	.BLK.32	1			; chane d'identification "<RS>"ORFILEREV:	.BLK.16	1			; rvisionORFILEVERS:	.BLK.16	1			; versionORFILEATTR:	.BLK.32	1			; attributs spciaux		.BLK.8	4ORFILENAME:	.BLK.8	16			; nom du fichier considrORFILELANG:	.BLK.8	16			; langue parleORFILENBTYPES:	.BLK.32	1			; nombre de types contenusORFILENBRES:	.BLK.32	1			; nombre de ressources contenues		.BLK.8	8LRFILE:;	Dfinition de l'en-tte d'un type;	---------------------------------		.LOC	0ORTYPIDENT:	.BLK.32	1			; identificateur unique de ce typeORTYPNBRES:	.BLK.32	1			; nombre de ressourcesORTYPDATASIZE:	.BLK.32	1			; taille des donnes qui suiventORTYPATTR:	.BLK.16	1			; attributs (ROM-..) BRSTYPSUBRES	= 0				; possde des sous-ressources		.BLK.8	2			; rserveORTYPNAME:	.BLK.8	16			; nom du type (pour le debug et ERES.CODE)LRTYP:;	Dfinition de la table d'accs;	------------------------------		.LOC	0ORTADATAKIND:	.BLK.8	1			; genre de donneORTASIZE:	.BLK.8	3			; taille de la donne + info complmentaireORTAOFFSET:	.BLK.32	1			; offset  la donneORTAREGENUM:	.BLK.32	1			; numro de rgnrationLRTA:;	Genre de donnes disponibles (Data Kind);	----------------------------------------RESDKDATA	= 16'00				; donne pureRESDKBUILD	= 16'08				; donne construite  partir de synonymesRESDKPROGVAR	= 16'10				; contenu dans variable du programme RDKAUTOZERO	= 0				; taille calcule automatiquement au <0> RDKAUTO2ZERO	= -1				; taille calcule automatiquement au <0><0> RDKAUTOINDATA	= -2				; taille donne dans le .16 au dbut des donnesRESDKSUBRES	= 16'20				; ressource de dfinition des sous-ressourcesRESDKINVALID	= 16'FF				; invalide;	La premire ressource d'un type peut tre du genre RESDKSUBRES.;	Dans ce cas, elle contient une description des tables contenant;	les sous-ressources. Le format d'une telle ressource est le;	suivant :		.LOC	0ORSRKEY:	.BLK.32	1			; clef d'accsORSROFFSET:	.BLK.32	1			; offset du premier lment de la table d'accsORSRNBRES:	.BLK.32	1			; nombre de sous-ressourcesORSRNAME:	.BLK.8	32			; nom (pour le debugger et ERES)ORSRRES:	.BLK.8	4			; rserveLRSR:;	Pour le genre BUILD, on a des dfinitions supplmentaires;	---------------------------------------------------------RBEND		= 0				; finRBINSERT	= 2				; ressource insre (df. 4 octets)RBPOINTER	= 4				; pointeur  la ressourceRBLABEL		= 6				; insre une tiquetteRBREF32		= 8				; rfrence 32 bits au labelRBREF16		= 10				; rfrence relative sur 16 bits au labelRB2REF16	= 12				; rfrence relative sur 16 bits par 2 labels;	Bits pour le mode d'ouverture;	-----------------------------BRSOPCACHE	= 0				; fichier mis en cache, accs multipleBRSOPPRIVE	= 1				; fichier charg de faon priveBRSOPSYSTEM	= 2				; fichier systme non d-chargeableBRSOPMTYP	= 3				; dfinit le compte mmoire  utiliser pour le canal;	Bits pour le mode d'accs GET;	-----------------------------BRSGETPOINTER	= 0				; cherche le pointeur directBRSGETCOPY	= 1				; cherche une copieBRSGETSIZE	= 2				; cherche la tailleBRSGETnoHAND	= 3				; on n'a pas de handle au typeBRSGETAUX	= 4				; demande ^sur .32 libre en criture/lectureBRSGETSUBRES	= 5				; accs selon clef dans sous-ressources;	Bits pour le mode de DEF;	------------------------BRSDEFPROGVAR	= 0				; dfinition du ^variables;	Bits pour le mode de OPER;	-------------------------BRSOPERUPDATE	= 0				; met  jour la ressource au CLOSEBRSOPERFORGET	= 1				; oublie les modifications lors du CLOSE;	Sous-appels pour OPER;	---------------------RES_opCLONESELF	= 0				; clne la ressourceRES_opPUTPOINTER= 2				; dfinit un pointeurRES_opPUTHANDLE	= 4				; dfinit un handleRES_opPUTRES	= 6				; dfinit une ressource externeRES_opMODBEGIN	= 8				; dbut des modificationsRES_opMODRESIZE	= 10				; redimensionne en cours de modif.RES_opMODEND	= 12				; fin des modificationsRES_opLOCK	= 14				; bloque/dbloque une ressourceRES_opUNDOMODIF	= 16				; annule toutes les modifications sur une ressourceRES_opDEFUPDATE	= 18				; dfinit s'il faut ou non mettre  jour une ressource;	Constantes;	----------RESPATTERN	= ("<"+128)*16'1000000+("R"+128)*16'10000+("S"+128)*16'100+(">"+128);	Types de ressources dfinis;	---------------------------RtypSTRING	= 16'00000010		; chane de caractres ASCIIRtypPASTRING	= 16'00000011		; chane de caractres PASCAL (prcde de <taille>)RtypDISPLAY	= 16'00000018		; commandes graphiques pour l'cranRtypSOFTKEYS	= 16'0000001A		; touches de fonctionsRtypMMENUS	= 16'00000020		; menu hirarchique (ou non)RtypDBOX	= 16'00000030		; donnes d'une bote de dialogueRtypRASTER	= 16'00000080		; raster de points prcd par <dx><dy>RtypIMAGECOD	= 16'00000081		; image codeRtypICOPALETTE	= 16'00000082		; palette d'icnes selon SMA_ICO.LIBRtypSOUND	= 16'000000F0		; sons diversRtypAUDIO	= 16'000000F1		; son au format AUDIORtypByteList	= 16'00000100		; liste