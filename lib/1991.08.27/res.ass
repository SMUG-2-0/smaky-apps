oire prise sur le compte MTYPCP;		 2**BRSGETSIZE, cherche la taille;		 2**BRSGETnoHAND, accs sans handle au type;		 2**BRSGETAUX, demande le ^au .32 associ (usage libre par le programmeur);		 2**BRSGETSUBRES, accs  une sous-ressource selon une clef donne;	A0.32	handle au type (sauf si D2:#BRSGETnoHAND);	D0.32	type (si D2:#BRSGETnoHAND);	D1.32	numro de la ressource;	D3.32	clef d'accs (si D2:#BRSGETSUBRES); out	A3.32	^au .32 associ (si D2:#BRSGETAUX);	A4.32	^ressource (si D2:#BRSGETPOINTER);	A4.32	^copie  rendre sur le compte MTYPCP (si D2:#BRSGETCOPY);	D4.32	taille de la ressource [0..23] et genre [24..31] (si D2:#BRSGETSIZE);	D7.16	erreur; mod	(A4.32), (D4.32), D7.16;----------\\;  RES_DEF  >;==========/; Dfinitions diverses; in	A2.32	canal;	A4.32	^variables du programme ou nil (pour genre RESDKPROGVAR);	D2.32	mode de dfinition;		 2**BRSDEFPROGVAR; out	D7.16	(?); mod	D7.16;------------\\;  RES_CLOSE  >;============/; Libre un fichier de ressources.; in	A2.32	canal;	D2.32	mode de fermeture;		 2**BRSCLUPDATE, met  jour sur disque les ressources modifies; out	D7.16	erreur; mod	D7.16	.END