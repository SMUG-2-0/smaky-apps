	.SBTTL	LIBL10; Module systme; --------------MODULE:	.W	H'A100		; code du premier appel	.W	H'A108		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	OHLREV-(.-MODULE),0	.B	1,0		; rvision.version	.W	0,0		; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	OHLNAM-(.-MODULE),0	.ASCII	"LIB"		; nom du module	.FILLB	LGHLIB-(.-MODULE),0	.W	NIL-MODULE		; H'A100	.W	_LIB_GETAD-MODULE	; H'A101	.W	_LIB_OPEN-MODULE	; H'A102	.W	_LIB_CLOSE-MODULE	; H'A103	.W	_LIB_ADD-MODULE		; H'A104	.W	_LIB_SUB-MODULE		; H'A105	.W	_OLD_OPEN-MODULE	; H'A106 <<<< PROVISOIRE <<<<	.W	_LIB_CLOSE-MODULE	; H'A107 <<<< PROVISOIRE <<<<	.W	_LIB_DEBUG-MODULE	; H'A108NIL:				; appels pas implments	LOAD.W	D7,#ERLMNO	; D7 <-- module pas ouvert	RET;----------\\; _OLD_OPEN >;==========/; <<<< PROVISOIRE <<<<; Dbut d'utilisation d'un module.; Appel compatible avec les anciennes dfinitions !; Les cas de multi-utilisations ne sont pas rsolus.; in	A3.L	^nom du module; out	D1.W	canal (= offset dans TABLE1);	D7.W	erreur; mod	D1.W, D7.W_OLD_OPEN:	PUSH.W	D3	CLR.W	D3		; D3 <-- code bidon	CALL	_LIB_OPEN	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; _LIB_OPEN >;==========/; Dbut d'utilisation d'un module.; in	A3.L	^nom du module;	D3.W	code du premier appel; out	D1.W	canal (= offset dans TABLE1);	D7.W	erreur; mod	D1.W, D7.W_LIB_OPEN:	PUSHM.L	D0,A0,A4,A5	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEML10	NTREL	?LOCK		; dbut de zone critique	JUMP,NE 95$;	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OTABLE0	LOAD.W	D0,D3		; D0 <-- code du premier appel	AND.W	D0,#H'0FFF	; D0 <-- numro premier appel	SR.W	D0,#PNBT	; D0 <-- numro premire tranche	LOAD.B	D0,(A0)+(D0.W)	; module dj charg ?	JUMP',NE 50$		; oui => 50$				; non =>	.IF	SM100&LIBROM	CALL	SRCROM		; module en ROM ?	JUMP',EQ 30$		; oui => 30$	.ENDIF	CALL	RDMODULE	; lit le module en mmoire	JUMP',NE 90$30$:	CALL	LIBADD		; ajoute dans TABLE0 et TABLE1	JUMP',EQ 80$		; ok => 80$	PUSH.W	D7	CALL	KLMODULE	; si erreur => libre mmoire	POP.W	D7	JUMP'	90$50$:	LOAD.W	D1,D0		; D1 <-- "canal"	ADD.W	D0,#OTABLE1-OTABLE0	LOAD.L	A4,(A0)+(D0.W)	; A4 <-- ^base du module80$:	CALL	LIBGETP2	; A0 <-- ^compteur d'utilisations	JUMP',NE 90$	INC.B	(A0)		; une installation de plus90$:	PUSH.W	D7	NTREL	?UNLOCK		; fin de zone critique	POP.W	D795$:	POPM.L	D0,A0,A4,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; _LIB_CLOSE >;===========/; Fin d'utilisation d'un module.; in	D1.W	canal (= offset dans TABLE1); out	D7.W	erreur; mod	D7.W_LIB_CLOSE:	PUSHM.L	D0,D1,A0,A4,A5	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEML10	NTREL	?LOCK		; dbut de zone critique	JUMP',NE 95$	LOAD.W	D7,#ERLMNO	; D7 <-- module pas ouvert	TEST.W	D1		; canal = zro ?	JUMP',EQ 90$		; oui => 90$;	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OTABLE1 ; A0 <-- ^table des ^base	LOAD.L	D0,(A0)+(D1.W)	JUMP',EQ 90$	LOAD.L	A4,D0		; A4 <-- ^base du module	CALL	LIBGETP2	; A0 <-- ^compteur d'utilisations	JUMP',NE 90$	DEC.B	(A0)		; une installation de moins	JUMP',NE 90$	CALL	LIBSUB		; enlve dans TABLE0 et TABLE1	CALL	KLMODULE	; libre la mmoire90$:	PUSH.W	D7	NTREL	?UNLOCK		; fin de zone critique	POP.W	D795$:	POPM.L	D0,D1,A0,A4,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; RDMODULE >;=========/; Lit effectivement en mmoire un module.; in	A3.L	^nom du module; out	A4.L	^base du module;	D7.W	erreur; mod	D7.W, A4.LRDMODULE:	PUSHM.L	D3,D4,A3	CALL	NMMODULE	; A3 <-- ^nom du fichier .LIB	LOAD.L	D3,#2^BEXNHEAD	; D3 <-- ne charge pas l'en-tte	FOS	?CLOAD		; charge en mmoire	POPM.L	D3,D4,A3;	TEST.W	D7		; retour EQ/NE	RET;---------\\; KLMODULE >;=========/; Libre un module en mmoire.; in	A4.L	^base du module; out	D7.W	erreur; mod	D7.WKLMODULE:	PUSH.L	A3	.IF	SM100&LIBROM	CLR.W	D7		; D7 <-- ok	COMP.L	A4,#ADROM0	JUMP',LO 20$	COMP.L	A4,#ADROM1+LGROM ; adresse en ROM ?	JUMP',LO 90$		; oui => 90$20$:	.ENDIF	LOAD.L	A3,#(A4)+OHLNAM	CALL	NMMODULE	; A3 <-- ^nom du fichier .LIB	FOS	?CUNLOAD	; libre la mmoire90$:	POP.L	A3;	TEST.W	D7		; retour EQ/NE	RET;---------\\; NMMODULE >;---------/; Construit le nom complet d'un module LIB.;	(SMA,xxx)_nom.LIB; in	A3.L	^nom abrg; out	A3.L	^nom du fichier complet; mod	D7.W, A3.LNMMODULE:	PUSHM.L	D4,A0,A4	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A4,#(A0)+ONAML10	LOAD.B	(A4+),#'(	LOAD.B	(A4+),#'S	LOAD.B	(A4+),#'M	LOAD.B	(A4+),#'A	LOAD.B	(A4+),#',	PUSH.L	A3	NTREL	?GETMACHINE	LOAD.B	(A4+),(A3+)	LOAD.B	(A4+),(A3+)	LOAD.B	(A4+),(A3+)	POP.L	A3	LOAD.B	(A4+),#')	LOAD.B	(A4+),#'_20$:	LOAD.B	(A4+),(A3+)	JUMP,NE 20$	DEC.L	A4	LOAD.B	(A4+),#'.	LOAD.B	(A4+),#'L	LOAD.B	(A4+),#'I	LOAD.B	(A4+),#'B	CLR.B	(A4)	LOAD.L	A3,#(A0)+ONAML10 ; A3 <-- ^nom du fichier	POPM.L	D4,A0,A4	RET;---------\\; _LIB_ADD >;=========/; Ajoute dans TABLE0 et TABLE1 un nouveau module.; in	A4.L	^base du module; out	D7.W	erreur; mod	D7.W_LIB_ADD:	PUSHM.L	D1,A0,A5	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEML10	NTREL	?LOCK		; dbut de zone critique	JUMP',NE 95$	CALL	LIBGETP2	; A0 <-- ^compteur d'utilisations	JUMP',EQ 50$	CALL	LIBADD		; ajoute dans TABLE0 et TABLE1	JUMP',NE 90$	CALL	LIBGETP2	; A0 <-- ^compteur d'utilisations	JUMP',NE 90$50$:	INC.B	(A0)		; une installation de plus90$:	PUSH.W	D7	NTREL	?UNLOCK		; fin de zone critique	POP.W	D795$:	POPM.L	D1,A0,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; LIBADD  >;--------/; Ajoute dans TABLE0 et TABLE1 un nouveau module.; in	A4.L	^base du module; out	D1.W	canal (= offset dans TABLE1);	D7.W	erreur; mod	D1.L, D7.WLIBADD:	PUSHM.L	D0,A0	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OTABLE1 ; A0 <-- ^table des ^base	CLR.W	D1		; D1 <-- offset dans TABLE1	LOAD.W	D0,#MAXMODU-110$:	TEST.L	(A0+)		; place libre ?	JUMP',EQ 20$		; oui => 20$	ADD.W	D1,#4		; D1 <-- offset suivant (+4 car .L)	DECJ.W,NMO D0,10$	LOAD.W	D7,#ERLMFU	; D7 <-- trop de modules ouverts	JUMP'	90$20$:	LOAD.L	(A0)-4,A4	; TABLE1 <-- ^base du module	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OTABLE0 ; A0 <-- ^table des offsets dans TABLE1	LOAD.W	D0,(A4)+OHLFCO	AND.L	D0,#H'0FFF	; D0 <-- numro premier appel	SR.W	D0,#PNBT	; D0 <-- numro premire tranche	ADD.L	A0,D0	LOAD.W	D0,(A4)+OHLLCO	SUB.W	D0,(A4)+OHLFCO	; D0 <-- nb d'appels -1	ADD.W	D0,#NBT	SR.W	D0,#PNBT	; D0 <-- nb de tranches50$:	LOAD.B	(A0+),D1	; mm. offset dans TABLE1	DEC.W	D0	JUMP,NE	50$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,A0	TEST.W	D7		; retour EQ/NE	RET;---------\\; _LIB_SUB >;=========/; Supprime dans TABLE0 et TABLE1 un ancien module.; in	A4.L	^base du module; out	D7.W	erreur; mod	D7.W_LIB_SUB:	PUSHM.L	D1,A0,A5	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEML10	NTREL	?LOCK		; dbut de zone critique	JUMP',NE 95$	CALL	LIBGETP2	; A0 <-- ^compteur d'utilisations	JUMP',NE 90$	DEC.B	(A0)		; une installation de moins	JUMP',NE 90$	CALL	LIBSUB		; enlve dans TABLE0 et TABLE190$:	PUSH.W	D7	NTREL	?UNLOCK		; fin de zone critique	POP.W	D795$:	POPM.L	D1,A0,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; LIBSUB  >;--------/; Supprime dans TABLE0 et TABLE1 un ancien module.; in	A4.L	^base du module; out	D1.W	canal (= offset dans TABLE1);	D7.W	erreur; mod	D1.L, D7.WLIBSUB:	PUSHM.L	D0,A0	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OTABLE1 ; A0 <-- ^table des ^base	CLR.W	D1		; D1 <-- offset dans TABLE1	LOAD.W	D0,#MAXMODU-110$:	COMP.L	A4,(A0+)	; module trouv ?	JUMP',EQ 20$		; oui => 20$	ADD.W	D1,#4		; D1 <-- offset suivant (+4 car .L)	DECJ.W,NMO D0,10$	LOAD.W	D7,#ERLMNO	; D7 <-- module pas ouvert	JUMP'	90$20$:	CLR.L	(A0)-4		; TABLE1 <-- libre l'entre	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OTABLE0 ; A0 <-- ^table des offsets dans TABLE1	LOAD.W	D0,(A4)+OHLFCO	AND.L	D0,#H'0FFF	; D0 <-- numro premier appel	SR.W	D0,#PNBT	; D0 <-- numro premire tranche	ADD.L	A0,D0	LOAD.W	D0,(A4)+OHLLCO	SUB.W	D0,(A4)+OHLFCO	; D0 <-- nb d'appels -1	ADD.W	D0,#NBT	SR.W	D0,#PNBT	; D0 <-- nb de tranches50$:	CLR.B	(A0+)		; libre offset dans TABLE1	DEC.W	D0	JUMP,NE	50$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,A0	TEST.W	D7		; retour EQ/NE	RET;---------\\; LIBGETP2 >;---------/; Donne le pointeur au compteur (un byte) en fonction; du pointeur  la base du module.; in	A4.L	^base du module; out	A0.L	^compteur d'utilisation dans OTABLE2;	D7.W	erreur; mod	D7.W, A0.LLIBGETP2:	PUSH.L	D4	LOAD.W	D7,#ERLMNO	; D7 <-- module pas ouvert	LOAD.W	D4,(A4)+OHLFCO	; D4 <-- code du premier appel	AND.W	D4,#H'0FFF	; D4 <-- numro de l'appel	SR.W	D4,#PNBT	; D4 <-- numro de la tranche	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OTABLE0 ; A0 <-- ^table des offsets dans TABLE1	LOAD.B	D4,(A0)+(D4.W)	; D4 <-- offset dans TABLE1	JUMP',EQ 90$	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OTABLE2 ; A0 <-- ^table des compteurs	SR.W	D4,#2	ADD.W	A0,D4		; A0 <-- ^compteur	CLR.W	D7		; D7 <-- ok90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; _LIB_DEBUG >;===========/; Donne qq adresses utiles pour DEBUG_LIB.; in	-; out	D4.W	nb max de modules;	A3.L	^table des offsets dans (A4);	A4.L	^table des ^base des modules;	A5.L	^table des compteurs;	D7.W	ok; mod	D4.L, D7.W, A3.L, A4.L, A5.L_LIB_DEBUG:	PUSH.L	A0	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A3,#(A0)+OTABLE0	LOAD.L	A4,#(A0)+OTABLE1	LOAD.L	A5,#(A0)+OTABLE2	LOAD.W	D4,#MAXMODU	POP.L	A0	CLR.W	D7		; D7 <-- ok	RET;-----------\\; _LIB_GETAD >;===========/; Donne l'adresse d'un appel pur permettre de l'accder; trs rapidement.; in	D3.W	code d'un appel; out	A3.L	adresse de l'appel;	D7.W	erreur; mod	D7.W, A3.L_LIB_GETAD:	PUSHM.L	D3,D4	LOAD.W	D7,#ERLMNO	; D7 <-- module pas ouvert	LOAD.W	D4,D3		; D4 <-- code de l'appel	AND.W	D4,#H'0FFF	; D4 <-- numro de l'appel	SR.W	D4,#PNBT	; D4 <-- numro de la tranche	LOAD.L	A3,_VARLIB	; A3 <-- ^variables globales	LOAD.L	A3,#(A3)+OTABLE0 ; A3 <-- ^table des offsets dans TABLE1	LOAD.B	D4,(A3)+(D4.W)	; D4 <-- offset dans TABLE1	JUMP',EQ 90$	ADD.W	D4,#OTABLE1-OTABLE0	LOAD.L	A3,(A3)+(D4.W)	; A3 <-- ^base du module	COMP.W	D3,(A3)+OHLLCO	JUMP',HI 90$	SUB.W	D3,(A3)+OHLFCO	JUMP',LO 90$	SL.W	D3,#1		; *2 car table de .W	ADD.W	A3,(A3)+(D3.W)+LGHLIB	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET	.IF	SM100&LIBROM;--------\\; SRCROM  >;========/; Cherche si un module est en ROM.; in	D3.W	premier code cherch; out	A4.L	^base du module en ROM;	D7.W	erreur; mod	D7.W, A4.LSRCROM:	PUSHM.L	D0,D1,A0	LOAD.W	D7,#1		; D7 <-- pas en ROM	LOAD.L	A0,#R16"TANROM10$:	TEST.W	(A0)		; fin de la table ?	JUMP',EQ 20$		; oui => 20$	COMP.W	D3,(A0+)	; dans la table ?	JUMP,NE	10$		; non => 10$	JUMP'	90$		; oui => 90$ (pas en ROM)20$:	LOAD.L	A0,#ADROM0	; A0 <-- adresse dbut ROM 025$:	LOAD.W	D0,#(LGROM/2)-1	; -1  cause NMO	LOAD.W	D1,#(PATHLIB&H'FFFF0000)/H'1000030$:	COMP.W	D1,(A0+)	JUMP',EQ 40$35$:	DECJ.W,NMO D0,30$	COMP.L	A0,#ADROM1	; fin recherche dans 2me ROM ?	JUMP',HI 90$		; oui => 90$	LOAD.L	A0,#ADROM1	; A0 <-- adresse dbut ROM 1	JUMP'	25$40$:	COMP.W	(A0),#PATHLIB&H'FFFF	JUMP,NE	35$	LOAD.L	A4,#(A0)-(OHLPAT+2) ; A4 <-- ^base du module	COMP.W	D3,(A4)+OHLFCO	; est-ce le bon module ?	JUMP,NE	35$		; non => 35$	COMP.W	(A4)+OHLLCO,#H'AFFF	JUMP,HI	35$	CLR.W	D7		; D7 <-- module trouv90$:	POPM.L	D0,D1,A0	TEST.W	D7		; retour EQ/NE	RET	.ENDIF;--------\\; INIL10  >;========/; Initialise le vecteur "line emulator 10".; in	-; out	-; mod	-INIL10:	PUSHM.L	D1,D4,D5,A0,A4,A5	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	(A0)+OTABLE1,#-1 ; premire tranche jamais utilise (moniteur en ROM)	LOAD.L	A5,#R16"RSTL10	LOAD.W	D5,#10	NTREL	?IEPSYSLINEA	; init nouvelle adresse	LOAD.L	(A0)+OSAVL10,A5	; sauve adresse moniteur	LOAD.W	D4,#1		; D4 <-- smaphore d'exclusion	NTREL	?CRESEM		; cre un smaphore	LOAD.L	(A0)+OSEML10,A5	; mm. ^smaphore	LOAD.L	A4,#R16"MODULE	CALL	LIBADD		; ajoute le module systme	POPM.L	D1,D4,D5,A0,A4,A5	RET;========\\; RSTL10  >;========/; Le vecteur "line emulator 10" arrive ici.; Mode "user" :;;	   SSP		   SSP		   USP;	|	|;	|-------|;	| PUSHM	|;	| .L	|;	| D0,D1	|;	| A0,A1	|	|	|;	|-------|	|-------|;	|  SF	|	|  SF	|	|	|;	|-------|	|-------|	|-------|;	| ad.	|	| ad.	|	| retour|<-- out;	| retour|	| appel	|	|   +2	|;	|-------|	|-------|	|-------|; in -->					 <-- in; Mode "superviseur" :;;	   SSP		   SSP;	|	|;	|-------|;	| PUSHM	|	|	|;	| .L	|	|-------|;	| D0,D1	|	| ad.	|;	| A0,A1	|	| appel	|;	|-------|	|-------|;	|	|	| ad.	|;	|	|	| RETSF |;	|-------|	|-------|;	|  SF	|	|  SF	|;	|-------|	|-------|;	| ad.	|	| retour|;	| retour|	|   +2	|;	|-------|	|-------|; in -->RSTL10:	TEST.B	(SP):#5		; tait-on en mode "superviseur" ?	JUMP',BS RSTSUPV	; oui => 20$; mode "user":	PUSHM.L	D0,D1,A0,A1	LOAD.L	A0,(SP)+(4*4)+2	; A0 <-- PC de retour	LOAD.W	D0,(A0+)	; D0 <-- op code (H'Axxx)	LOAD.L	A1,USP	LOAD.L	(-A1),A0	; met l'adresse de retour sur USP	LOAD.L	USP,A1	LOAD.W	D1,D0		; D1 <-- code de l'appel	AND.W	D1,#H'0FFF	; D1 <-- numro de l'appel	SR.W	D1,#PNBT	; D1 <-- numro de la tranche	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OTABLE0 ; A0 <-- ^table des offsets dans TABLE1	LOAD.B	D1,(A0)+(D1.W)	; D1 <-- offset dans TABLE1	JUMP',EQ 50$	ADD.W	D1,#OTABLE1-OTABLE0	LOAD.L	A0,(A0)+(D1.W)	; A0 <-- ^base du module	COMP.W	D0,(A0)+OHLLCO	JUMP',HI 80$	SUB.W	D0,(A0)+OHLFCO	JUMP',LO 80$	SL.W	D0,#1		; *2 car table de .W	ADD.W	A0,(A0)+(D0.W)+LGHLIB40$:	LOAD.L	(SP)+(4*4)+2,A0	POPM.L	D0,D1,A0,A1	RETSF			; fin du mode superviseur50$:	COMP.W	D0,#H'A080	; appel au moniteur ?	JUMP',HS 80$		; non (appel inexistant) => 80$				; oui =>	ADD.L	A1,#4	LOAD.L	USP,A1	POPM.L	D0,D1,A0,A1	PUSH.L	A0	PUSH.L	A0	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	(SP)+4,(A0)+OSAVL10	POP.L	A0	RET			; JUMP _VARLIB+OSAVL1080$:	LOAD.W	D7,#ERLMNO	; D7 <-- module pas ouvert	LOAD.L	A0,#R16"ROUTNOMOD	JUMP	40$RSTSUPV:; mode "superviseur":	SUB.L	SP,#2*4	PUSHM.L	D0,D1,A0,A1	LOAD.L	A0,(SP)+(4*6)+2	; A0 <-- PC de retour	LOAD.W	D0,(A0+)	; D0 <-- op code (H'Axxx)	LOAD.L	(SP)+(4*6)+2,A0	; corrige l'adresse de retour	LOAD.W	D1,D0		; D1 <-- code de l'appel	AND.W	D1,#H'0FFF	; D1 <-- numro de l'appel	SR.W	D1,#PNBT	; D1 <-- numro de la tranche	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OTABLE0 ; A0 <-- ^table des offsets dans TABLE1	LOAD.B	D1,(A0)+(D1.W)	; D1 <-- offset dans TABLE1	JUMP',EQ 50$	ADD.W	D1,#OTABLE1-OTABLE0	LOAD.L	A0,(A0)+(D1.W)	; A0 <-- ^base du module	COMP.W	D0,(A0)+OHLLCO	JUMP',HI 80$	SUB.W	D0,(A0)+OHLFCO	JUMP',LO 80$	SL.W	D0,#1		; *2 car table de .W	ADD.W	A0,(A0)+(D0.W)+LGHLIB40$:	LOAD.L	(SP)+(4*4),A0	LOAD.L	A0,#R16"45$	LOAD.L	(SP)+(4*5),A0	POPM.L	D0,D1,A0,A1	RET45$:	PUSH.W	F	LOAD.B	(SP)+3,(SP)+1	; mj le F de l'appellant	POP.W	F	RETSF			; retour  l'appellant50$:	COMP.W	D0,#H'A080	; appel au moniteur ?	JUMP',HS 80$		; non (appel inexistant) => 80$				; oui =>60$:				; appel moniteur si "superviseur" =>	LOAD.L	A0,(SP)+(4*6)+2	SUB.L	A0,#2	LOAD.L	(SP)+(4*6)+2,A0	; remet l'adresse de retour initiale	POPM.L	D0,D1,A0,A1	LOAD.L	(SP)+0,A0	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	(SP)+4,(A0)+OSAVL10	POP.L	A0	RET			; JUMP _VARLIB+OSAVL1080$:	LOAD.W	D7,#ERLMNO	; D7 <-- module pas ouvert	LOAD.L	A0,#R16"ROUTNOMOD	JUMP	40$ROUTNOMOD:	TEST.W	D7		; retour EQ/NE	RET; Tables; ------	.IF	SM100&LIBROMTANROM:				; modules  ne pas chercher en ROM	.W	0		; terminateur	.ENDIF	.END