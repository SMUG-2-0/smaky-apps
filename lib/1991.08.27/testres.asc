	.TITLE	TESTRES.ASC;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du programme TESTRES.CODE	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	RESTOTO		= 0TITI		= 1; Variables; ---------LBUDIS	=	100	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHRES:	.BLKB	2		; canal module RESOCARES:	.BLKB	4		; canal du fichier de ressourcesOBUDIS:	.BLKB	LBUDIS		; buffer pour "write-display"LGVAR:; Programme; ---------	.LOC	0ADCODE:	JUMP	START; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMRES:		.ASCIZ	"RES"		.EVENSTART:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMRES	LOAD.W	D3,#RES_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A6)+OCHRES,D1	LOAD.L	A3,#R16"NMRESF	LOAD.L	D2,#2^BRSOPPRIVE	CLR.L	D4	RES_	OPEN	JUMP,NE ERROR	LOAD.L	(A6)+OCARES,A2	LOAD.L	D0,#RtypSTRING	LOAD.L	D1,#TOTO	CALL	RESGET	JUMP,NE ERROR	LOAD.L	A3,A4	LIB	?AFTEXT	LIB	?AFCR	LOAD.L	D0,#RtypSTRING	LOAD.L	D1,#TITI	CALL	RESGET	JUMP,NE ERROR	LOAD.L	A3,A4	LIB	?AFTEXT	LIB	?AFCR	LIB	?GETCAR	LOAD.L	A2,(A6)+OCARES	CLR.L	D2	RES_	CLOSEERROR:	LIB	?AFERROR	LIB	?GETCARERFAT:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHRES	LIB_	CLOSE	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend les variablesERFAT1:	LIB	?CLOLIB	FOS	?STOP;--------\\; RESGET  >;========/; ; in	D0.L	type;	D1.L	numro; out	A4.L	^ressource;	D7.W	erreur; mod	D7.W, A4.LRESGET:	PUSHM.L	D2,A2	LOAD.L	A2,(A6)+OCARES	LOAD.L	D2,#2^BRSGETPOINTER!2^BRSGETnoHAND	RES_	GET	POPM.L	D2,A2	TEST.W	D7		; retour EQ/NE	RETNMRESF:	.ASCIZ	"TOTO.RS"	.EVEN	.END	START