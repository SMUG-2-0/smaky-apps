	.TITLE		LIST.ASS	.PROC		M68000		; mnmonics CALM	.BASE		10'10		; base 10 par dfaut;	.LAYOUT		HEX		; listing en hexadcima; Numros des appels; ------------------	.SYSCALL.16	LIST_LIST_OPEN	=	16'A810			; dbut d'un listageLIST_NEXT	=	16'A811			; donne le fichier suivantLIST_CLOSE	=	16'A812			; fin d'un listageLIST_AFFILE	=	16'A813			; affiche un fichierLIST_DBOX	=	16'A814			; choix fichier avec une dboxLIST_MODIF	=	16'A815			; modifie un fichierLIST_DELETE	=	16'A816			; dtruit un fichier ?LIST_SOPEN	=	16'A817			; dbut d'un listage systme ou nonLIST_NBMAX	=	16'A818			; donne le nb max de fichiersLIST_PUTFILE	=	16'A819			; met un nom de fichier dans un bufferLIST_VISU	=	16'A81A			; visualise un fichier quelconqueLIST_FIRST	=	LIST_OPENLIST_LAST	=	LIST_VISU; Modes pour LIST_AFFILE/PUTFILE; ------------------------------BLISTALG	=	0	; affiche la longueurBLISTADC	=	1	; affiche la date de crationBLISTAHC	=	2	; affiche l'heure de crationBLISTADM	=	3	; affiche la date de modificationBLISTAHM	=	4	; affiche l'heure de modificationBLISTADU	=	5	; affiche la date d'utilisationBLISTAHU	=	6	; affiche l'heure d'utilisation; Modes pour LIST_DBOX; --------------------BLIDBNOM	=	0	; donne le nom de la touche (CHOISIT); Oprations pour LIST_VISU; -------------------------VISU_OPEN	=	10	; ouvertureVISU_PARAM	=	15	; paramtresVISU_USER	=	16	; variables pour l'utilisateurVISU_HEAD	=	17	; donne le ^ l'en-tteVISU_DRAW	=	20	; dessin du canevasVISU_UPDATE	=	30	; dessin du contenuVISU_MOVE	=	40	; dplacement selon sourisVISU_INFO	=	50	; dessin des informationsVISU_CLOSE	=	60	; fermetureVISU_TYPE	=	70	; donne le type; Modes pour LIST_VISUOPEN; ------------------------BLIVOMERR	=	8	; si erreur => affiche message et retour ok; Modes pour LIST_VISUDRAW; ------------------------BLIVDRECT	=	8	; affiche le rectangle englobantBLIVDINFO	=	9	; affiche les informationsBLIVDASC	=	10	; affiche les ascenseursBLIVDMSET	=	16	; mode SETDOTBLIVDMCLR	=	17	; mode CLRDOTBLIVDMINV	=	18	; mode INVDOT; Modes pour LIST_VISUUPDATE; --------------------------BLIVUOPT1	=	9	; option 1 (tout, petit)BLIVUOPT2	=	10	; option 2 (ngatif)BLIVUOPT3	=	11	; option 3 (caractres)BLIVUNPOS	=	16	; ne tient pas compte de la position dans D3.32BLIVUNCLR	=	17	; n'efface pas le dessous; Modes pour LIST_VISUINFO; ------------------------BLIVIINV	=	8	; affiche le nom en invers;-----------\\; LIST_OPEN  >;===========/; Dbut d'une recherche dans SYS_LIST.; in	A3.32	^critre de recherche; out	D6.32	canal;	D7.16	erreur; mod	D6.32, D7.16;------------\\; _LIST_SOPEN >;============/; Dbut d'une recherche dans SYS_LIST.; in	A3.32	^critre de recherche;	D3.32	mode d'ouverture pour SYS_LIST; out	D6.32	canal;	D7.16	erreur; mod	D6.32, D7.16;------------\\; _LIST_NBMAX >;============/; Donne le nombre de fichiers correspondants au critre.; in	D6.32	canal; out	D4.16	nb de fichiers (0..n); mod	D4.32, D7.16;-----------\\; LIST_NEXT  >;===========/; Cherche le fichier suivant dans SYS_LIST.; in	D6.32	canal; out	A3.32	^nom trouv;	A4.32	^arguments;	D7.16	erreur (EROUTF quand c'est fini); mod	D7.16, A3.32, A4.32;------------\\; LIST_CLOSE  >;============/; Termine une recherche dans SYS_LIST.; in	D6.32	canal; out	-; mod	-;-------------\\; LIST_AFFILE  >;=============/; Affiche un nom de fichier.; Voil le format si tous les bits du mode sont prsents :;;        16           8       10        9        10        9    ...; <--------------><------><--------><-------><--------><------->...; LETTRE.TEXT        5'123  21.06.85 10.50.30  21.06.85 10.50.30...;; ...    10        9; ...<--------><------->; ...  22.06.85 15.23.44;; Si un ou plusieurs bits sont absents, les caractres correspondants; ne sont simplement pas affichs.; L'appel n'affiche pas le CR  la fin de la ligne, pour permettre; de cumuler plusieurs fichiers sur une mme ligne.; in	A3.32	^nom;	A4.32	^arguments;	D4.16	mode d'affichage;		  BLISTALG  :  affiche la longueur;		  BLISTADC  :  affiche la date de cration;		  BLISTAHC  :  affiche l'heure de cration;		  BLISTADM  :  affiche la date de modification;		  BLISTAHM  :  affiche l'heure de modification;		  BLISTADU  :  affiche la date d'utilisation;		  BLISTAHU  :  affiche l'heure d'utilisation; out	D7.16	erreur; mod	D7.16;-----------\\; LIST_DBOX  >;===========/; Demande  l'utilisateur quel fichier il veut avec une jolie dbox.; Cette dbox est utilisable  100% avec le clavier ou la souris.; Il faudra redessiner les soft-keys (LIB,?AFMENU).; Gnralement, une dbox "Prend" contient :;;	.ASCIZ	" Nom du ...  lire :";	.B	ODBCR,ODBCR;	.B	ODBFILE,longueur;	.B	ODBBOX,0,Fx,TDBNORM;	.ASCIZ	"LISTE";	.B	ODBCR,ODBCR;	...;; La touche (Fx) excute le code :;;	DBOX_	CLOSE		; ferme la dbox "Prend";	MOVE.32	A3,A4		; A4 <-- ^buffer pour nom;	MOVE.32	...,A3		; A3 <-- ^critre de recherche (extension);	CLR.32	D4;	MOVE.16	#2**BDBSAV,D2	; D2 <-- mode (avec sauvetage);	LIST_	DBOX		; liste puis choix selon dbox ...;	JUMP,NE error		; pas assez de mmoire pour sauver dessous !;	CALL	afmenu		; remet les soft-keys;	JUMP	recommence	; ouvre de nouveau la dbox "Prend"; in	A3.32	critre avec * et ? (.ext est quivalent  *.ext);	A4.32	^buffer pour nom;	D2.16	mode d'ouverture pour la dbox;	D3.32	position centre (y;x) si BDBPOS dans D2.16;	D4.32	zro (pour l'instant); out	D3.16	dernire touche (RETURN/END);	D7.16	erreur; mod	D3.32, D7.16;------------\\; LIST_MODIF  >;============/; Ne plus utiliser cet appel !;-------------\\; LIST_DELETE  >;=============/; Demande  l'utilisateur s'il faut dtruit ou non un fichier,; en posant la question :;;	Supprime l'ancien "xxx.yy" ?;	(OUI)  (NON);; Ne fait pas l'appel FOS,?DELETE !; Il faudra redessiner les soft-keys (LIB,?AFMENU).; in	A3.32	^nom du fichier;	D2.16	mode d'ouverture pour la dbox;	D3.32	position centre (y;x) si BDBPOS dans D2.16; out	D3.16	dernire touche (O/N);	D7.16	erreur; mod	D3.32, D7.16;---------------\\; LIST_VISUOPEN  >;===============/; Lit un fichier sur disque, sans l'afficher.; in	D2.L	#VISU_OPEN + mode (BLIVOxxx);	A3.L	^nom du fichier;	A0.L	^descripteur de la fentre; out	D6.L	canal;	D7.W	erreur; mod	D6.L, D7.W;----------------\\; LIST_VISUPARAM  >;================/; Donne quelques paramtres, en fonction du type du fichier.; in	D2.L	#VISU_PARAM;	D6.L	canal;	A0.L	^descripteur de la fentre; out	D2.L	rserve;	D3.L	position relative par dfaut;	D4.L	fanions par dfaut (BLIVUxxxx);	A4.L	^textes des options (tout<0>ngatif<0>divers<0><0>);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A4.L;---------------\\; LIST_VISUUSER  >;===============/; Donne le pointeur  une petite zone de variables (16 bytes); libre pour l'utilisateur.; in	D2.L	#VISU_USER;	D6.L	canal;	A0.L	^descripteur de la fentre; out	A4.L	^16 bytes libres pour l'utilisateur;	D7.W	erreur; mod	D7.W, A4.L;---------------\\; LIST_VISUHEAD  >;===============/; Donne le pointeur  l'en-tte.; in	D2.L	#VISU_HEAD;	D6.L	canal;	A0.L	^descripteur de la fentre; out	A4.L	^en-tte, si image => (A4)+OIMxxx; out	D3.W	type (0=text, 1=image, 2=plan, 3=genc);	D7.W	erreur; mod	D3.L, D7.W, A4.L;---------------\\; LIST_VISUDRAW  >;===============/; Dessine le canevas, sans le contenu.; Cet appel est ncessaire avant LIST_VISUUPDATE ou LIST_VISUMOVE !; in	D2.L	#VISU_DRAW + mode (BLIVDxxx);	D6.L	canal;	D3.L	origine coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	A0.L	^descripteur de la fentre; out	D7.W	erreur; mod	D7.W;-----------------\\; LIST_VISUUPDATE  >;=================/; Dessine ou met  jour le contenu.; in	D2.L	#VISU_UPDATE + mode (BLIVUxxx);	D6.L	canal;	D3.L	position relative -10000..0..+10000 (y;x);	A0.L	^descripteur de la fentre; out	D7.W	erreur; mod	D7.W;---------------\\; LIST_VISUMOVE  >;===============/; Dplace le contenu, avec la souris.; in	D2.L	#VISU_MOVE;	D6.L	canal;	D4.L	position de la souris (y;x);	A0.L	^descripteur de la fentre; out	D3.L	position relative -10000..0..+10000 (y;x);	D7.W	erreur; mod	D3.L, D7.W;---------------\\; LIST_VISUINFO  >;===============/; Dessine ou met  jour les informations.; in	D2.L	#VISU_INFO + mode (BLIVIxxx);	D6.L	canal;	A0.L	^descripteur de la fentre; out	D7.W	erreur; mod	D7.W;----------------\\; LIST_VISUCLOSE  >;================/; Libre la mmoire utilise par un fichier.; in	D2.L	#VISU_CLOSE;	D6.L	canal;	A0.L	^descripteur de la fentre; out	D7.W	erreur; mod	D7.W;---------------\\; LIST_VISUTYPE  >;===============/; Cherche le type d'un fichier selon son extension.; Toutes les extensions qui ne sont pas des images, des plans; ou des gencars sont considres comme du texte !; in	D2.L	#VISU_TYPE;	A3.L	^nom de fichier; out	D3.W	type (0=text, 1=image, 2=plan, 3=genc); mod	D3.L, D7.W	.END