	.SBTTL	LIBWDO; Gestion des sous-fentres; -------------------------;--------\; _CREWDO >;========/; Cre une nouvelle fentre dans la librairie. Si les; dimensions ne sont pas correctes, aucune erreur n'est; rendue (c'est lors du ?USEWDO que l'erreur sera rendue).; La fentre utilise reste la mme.; in	D3.L	point en haut  gauche (y;x);	D4.L	dimensions (dy;dx); out	D5.W	numro (0..n);	D7.W	erreur; mod	D5.W, D7.W_CREWDO:	PUSHM.L	D0,D3,D4,A0	LOAD.L	A0,#(A6)+OTASWDO	LOAD.W	D0,#MAXSWDO10$:	TSET.B	(A0)+OSWFLG:#BSWUSE ; lment libre ?	JUMP',BC 20$		; oui => 20$	ADD.L	A0,#LGSWDO	; A0 <-- ^suivant dans table	DEC.W	D0		; encore un lment ?	JUMP,NE	10$		; oui => 10$	LOAD.W	D7,#ERLWFU	; non => erreur	JUMP'	90$20$:	LOAD.W	D5,#MAXSWDO	SUB.W	D5,D0		; D5 <-- 0..MAXSWDO-1	LOAD.W	(A0)+OSWSX,D3	; mm. start fentre X	SWAP.W	D3	LOAD.W	(A0)+OSWSY,D3	; mm. start fentre Y	LOAD.W	(A0)+OSWDX,D4	; mm. largeur fentre X	SWAP.W	D4	LOAD.W	(A0)+OSWDY,D4	; mm. hauteur fentre Y	CLR.W	(A0)+OSWPX	; init position typo X	CLR.W	(A0)+OSWPY	; init position typo Y	CLR.W	(A0)+OSWGX	; init position graph. X	CLR.W	(A0)+OSWGY	; init position graph. Y	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D3,D4,A0	RET;--------\; _KILWDO >;========/; Dtruit une sous-fentre. Il n'est pas possible de dtruire; la sous-fentre utilise actuellement.; in	D5.W	numro (0..n); out	D7.W	erreur; mod	D7.W_KILWDO:	PUSHM.L	D0,A0	LOAD.W	D7,#ERLWUS	COMP.W	D5,(A6)+ONOSWDO	; dtruit s-wdo utilise ?	JUMP',EQ 90$		; oui => 90$	CALL	GPTWDO		; A0 <-- ^dans OTASWDO	JUMP',NE 90$	TCLR.B	(A0)+OSWFLG:#BSWUSE	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,A0	RET;--------\; _USEWDO >;========/; Utilise une nouvelle sous-fentre, en sauvant au pralable; l'tat (positions des curseurs typo et graph.) de la sous-; fentre actuelle.; Si les dimensions ne sont pas correctes, une erreur est; rendue, et la fentre utilise n'est pas change. Il faut; alors dtruire la fentre incorrecte (avec ?KILWDO), puis; la re-crer (avec ?CREWDO).; in	D5.W	numro (0..n); out	D7.W	erreur; mod	D7.W_USEWDO:	PUSHM.L	D0,D5,A0	CALL	GWDO		; sauve l'tat s-wdo actuelle	JUMP',NE 90$		; erreur => 90$	CALL	PWDO		; reprend l'tat nouvelle s-wdo	JUMP',EQ 80$		; ok => 80$	PUSH.W	D7	CALL	GPTWDO		; A0 <-- ^dans OTASWDO	JUMP',NE 60$	TCLR.B	(A0)+OSWFLG:#BSWUSE ; libre s-wdo incorrecte60$:	LOAD.W	D5,(A6)+ONOSWDO	; D5 <-- no s-wdo actuelle	CALL	PWDO		; reprend l'tat s-wdo actuelle	POP.W	D7	JUMP'	90$80$:	LOAD.W	(A6)+ONOSWDO,D5	; mm. no nouvelle s-wdo	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D5,A0	RET;--------\; _MODWDO >;========/; Modifie les dimensions d'une sous-fentre existante.; in	D3.L	point en haut  gauche (y;x);	D4.L	dimensions (dy;dx);	D5.W	numro (0..n); out	D7.W	erreur; mod	D5.W, D7.W_MODWDO:	PUSHM.L	D0,D3,D4,D5,A0	CALL	GPTWDO		; A0 <-- ^dans OTASWDO	JUMP',NE 90$	LOAD.W	(A0)+OSWSX,D3	; mm. start fentre X	SWAP.W	D3	LOAD.W	(A0)+OSWSY,D3	; mm. start fentre Y	LOAD.W	(A0)+OSWDX,D4	; mm. largeur fentre X	SWAP.W	D4	LOAD.W	(A0)+OSWDY,D4	; mm. hauteur fentre Y	CLR.W	(A0)+OSWPX	; init position typo X	CLR.W	(A0)+OSWPY	; init position typo Y	CLR.W	(A0)+OSWGX	; init position graph. X	CLR.W	(A0)+OSWGY	; init position graph. Y	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D3,D4,D5,A0	RET;--------\; _GETWDO >;========/; Donne des informations sur la sous-fentre utilise.; in	-; out	D3.L	point en haut  gauche (y;x);	D4.L	dimensions (dy;dx);	D5.W	numro (0..n);	D7.W	erreur; mod	D3.L, D4.L, D5.W, D7.W_GETWDO:	PUSHM.L	D0,A0	LOAD.W	D5,(A6)+ONOSWDO	; D5 <-- no s-wdo utilise	CALL	GPTWDO		; A0 <-- ^dans OTASWDO	JUMP',NE 90$	LOAD.W	D3,(A0)+OSWSY	; D3 <-- start fentre Y	SWAP.W	D3	LOAD.W	D3,(A0)+OSWSX	; D3 <-- start fentre X	LOAD.W	D4,(A0)+OSWDY	; D4 <-- hauteur fentre Y	SWAP.W	D4	LOAD.W	D4,(A0)+OSWDX	; D4 <-- largeur fentre X	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,A0	RET;--------\; GWDO    >;--------/; Sauve l'tat de la sous-fentre actuelle dans la table; correspondante.; in	-; out	D7.W	erreur; mod	D7.WGWDO:	PUSHM.L	D0,D5,A0,A4	LOAD.W	D5,(A6)+ONOSWDO	; D5 <-- no s-wdo utilise	CALL	GPTWDO		; A0 <-- ^dans OTASWDO	JUMP',NE 90$	LOAD.L	A4,(A6)+OPDDIS	; A4 <-- ^descripteur de la fentre	LOAD.W	(A0)+OSWPX,(A4)+ODFPX	LOAD.W	(A0)+OSWPY,(A4)+ODFPY ; sauve curseur typo	LOAD.W	(A0)+OSWGX,(A4)+ODFPGX	LOAD.W	(A0)+OSWGY,(A4)+ODFPGY ; sauve curseur graph.90$:	POPM.L	D0,D5,A0,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; PWDO    >;--------/; Donne au driver d'cran tout ce qu'il faut pour pouvoir; travailler dans une nouvelle sous-fentre.; in	D5.W	numro; out	D7.W	erreur; mod	D7.WPWDO:	PUSHM.L	D0,D3,A0,A3	CALL	GPTWDO		; A0 <-- ^dans OTASWDO	JUMP,NE 90$	LOAD.L	A3,#(A6)+OBUWRI+1	LOAD.B	(A3)+0,#DIMWDO	LOAD.W	(A3)+1,(A0)+OSWSX	LOAD.W	(A3)+3,(A0)+OSWSY	LOAD.W	(A3)+5,(A0)+OSWDX	LOAD.W	(A3)+7,(A0)+OSWDY	LOAD.W	D3,#1+8	LIB	?STRING		; slectionne dim. s-wdo	JUMP',NE 90$	LOAD.L	A3,#(A6)+OBUWRI	LOAD.W	(A3)+0,#TYPOAX	LOAD.W	(A3)+2,(A0)+OSWPX	LOAD.W	(A3)+4,#TYPOAY	LOAD.W	(A3)+6,(A0)+OSWPY	LOAD.W	(A3)+8,#GRAXY	LOAD.W	(A3)+10,(A0)+OSWGX	LOAD.W	(A3)+12,(A0)+OSWGY	LOAD.W	D3,#4+4+6	LIB	?STRING		; pos. curseurs typo + graph. et color-set/clear	CLR.W	D7		; D7 <-- ok, mme si ERDIOUT !90$:	POPM.L	D0,D3,A0,A3	TEST.W	D7		; retour EQ/NE	RET;--------\; GPTWDO  >;--------/; Cherche le ^dans OTASWDO en fonction d'un numro de; sous-fentre.; in	D5.W	numro de sous-fentre; out	A0.L	^dans OTASWDO;	D7.W	erreur; mod	D0.L, D7.W, A0.LGPTWDO:	LOAD.W	D7,#ERLWNI	COMP.W	D5,#MAXSWDO	; numro trop grand ?	JUMP',HS 90$		; oui => 90$	LOAD.L	A0,#(A6)+OTASWDO	LOAD.W	D0,D5	MUL.WU	D0,#LGSWDO	ADD.L	A0,D0		; A0 <-- ^table s-wdo	TEST.B	(A0)+OSWFLG:#BSWUSE ; lment utilis ?	JUMP',BC 90$		; non => 90$ (erreur)	CLR.W	D7		; D7 <-- ok90$:	TEST.W	D7		; retour EQ/NE	RET	.END