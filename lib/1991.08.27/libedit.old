	.SBTTL	LIBEDIT;--------\; _INSERT >;========/; Insre une chane de caractres (termine par zro) dans; une ligne.;			    D3;	<---------------------------------------->;	      A4-A3;	<--------------->;	|---------------|-------|;	|		|	|<CR><0>;	|---------------|-------|;			|;			|-----<------ insre ici; in	A3.L	^dbut ligne;	D3.W	longueur maximale de la ligne;	A4.L	^position o insrer dans la ligne;	A5.L	^chane  insrer (termine par zro); out	A4.L	^plus loin;	D7.W	erreur; mod	D0..A1, D7.W, A4.L_INSERT:; Calcul la longueur de la chane  insrer dans D0.	LOAD.L	A0,A5		; A0 <-- ^chane  insrer	CLR.L	D0	LOAD.W	D0,#-110$:	INC.W	D0		; D0 <-- nb de car  insrer	TEST.B	(A0+)	JUMP,NE 10$	CLR.W	D7		; D7 <-- ok	TEST.W	D0		; chane nulle ?	JUMP,EQ 90$		; oui => 90$ (ok); Calcul la longueur de la chane actuelle dans D1.	LOAD.L	A0,A3		; A0 <-- ^dbut texte	CLR.W	D120$:	TEST.B	(A0+)		; fin ?	JUMP',EQ 25$		; oui => 25$	COMP.B	(A0)-1,#CR	JUMP',EQ 25$	INC.W	D1		; D1 <-- nb de car dans texte	JUMP	20$25$:	INC.L	A0		; A0 <-- ^aprs 2me term.	LOAD.W	D7,#1		; D7 <-- erreur quelconque	ADD.W	D1,#2		; D1 <-- compte place <CR><0>	ADD.W	D1,D0		; D1 <-- lg actuelle + nouvelle	COMP.W	D1,D3		; trop grand ?	JUMP,HI	90$		; oui => 90$ (erreur); Pousse la fin du texte pour faire de la place pour la chane;  insrer.	LOAD.L	A1,A0		; A0 <-- ^fin actuelle	ADD.L	A1,D0		; A1 <-- ^fin nouvelle50$:	LOAD.B	(-A1),(-A0)	; pousse la fin du texte	COMP.L	A0,A4	JUMP,NE 50$; Insre la nouvelle chane.	LOAD.L	A1,A5		; A1 <-- ^chane  insrer60$:	LOAD.B	(A4+),(A1+)	; insre un caractre	DEC.W	D0	JUMP,NE 60$	CLR.W	D7		; D7 <-- ok90$:	RET;---------\\; _CLREDIT >;=========/; Appel  effectuer avant chaque ?EDIT dans une nouvelle ligne !; in	-; out	-; mod	D7.W_CLREDIT:	CLR.L	(A6)+OPOEDI	CLR.W	D7		; retour EQ	RET;--------\; _EDIT   >;========/; Attend une ligne avec possibilits d'ditions.; in	A3.L	^dbut ligne;	D3.W	longueur maximale de la ligne;		:#15 --> efface ligne lorsque premier caractre frapp;		:#14 --> si largeur en points dans D3 <31..16>;		:#13 --> si rend ERLEDN/ERLEDM;	A4.L	^position du curseur dans la ligne;	A2.L	^liste des touches terminales; out	A4.L	^nouvelle position du curseur;	D3.W	dernire touche presse;	D7.W	erreur; mod	D0..A1, D3.W, D7.W, A4.L; Utilise de faon interne les registres suivants:;	D2.L	position (y;x) dbut ligne dans l'cran;	A1.L	^liste des touches terminales de l'utilisateur;	A2.L	^dbut du buffer (DB);	A3.L	^dbut du trou   (DT);	A4.L	^fin du trou     (FT);	A5.L	^fin du buffer   (FB)_EDIT:	PUSHM.L	D2,D4,D5,A2,A3,A5	LOAD.L	A1,A2		; A1 <-- ^liste touches finales	LOAD.L	A2,A3		; A2 <-- ^dbut du buffer	LOAD.L	A3,A4		; A3 <-- ^dbut du trou	LOAD.W	D0,#-110$:	INC.W	D0		; D0 <-- lg du curseur  la fin	LOAD.B	D1,(A4+)	JUMP',EQ 20$	COMP.B	D1,#CR	JUMP,NE 10$20$:	DEC.L	A4	LOAD.L	D5,D3		; D5 <-- flags d'entres	TCLR.L	D3:#15	SUB.W	D3,#2		; laisse place pour <CR><0>	AND.L	D3,#H'FFFF	LOAD.L	A5,A2	ADD.L	A5,D3		; A5 <-- ^fin du buffer	LOAD.L	A0,A5	TEST.W	D0		; curseur tout  la fin ?	JUMP',EQ 50$		; oui => 50$30$:				; non =>	LOAD.B	(-A0),(-A4)	; cre le trou ...	DEC.W	D0	JUMP,NE 30$50$:	LOAD.L	A4,A0		; A4 <-- ^fin du trou	LOAD.B	D3,#NOCURS	; plus de curseur standard	CALL	_AFCAR		; pendant l'dition !	CALL	_GETCURS	LOAD.L	D2,D3		; D2 <-- position dbut ligne	COMP.L	D2,(A6)+OPOEDI	; mme position que prcdent ?	JUMP',EQ 80$		; oui => 80$	LOAD.L	(A6)+OPOEDI,D2	; mm. position dbut ligne	CLR.W	(A6)+OLGEDI	; longueur ligne inconnue !80$:	CLR.L	(A6)+OPOCUR	; pas encore de curseur	CLR.W	D1		; D1 <-- affichage  jour	CLR.B	D4		; D4 <-- pas d'accent en coursEDIT0:	INC.W	D1		; D1 <-- affichage en retard	CALL	_IFCAR		; test si touche sans attendre	TEST.W	D7		; touche dj presse ?	JUMP',EQ 02$		; oui => 02$	COMP.W	D7,#ERTIMO	; faut-il encore attendre ?	JUMP,NE	EDIT9		; non => EDIT9				; oui =>	CALL	EDAFLI		; affiche la ligne	CALL	_GETCAR		; attend une touche du clavier	TEST.W	D7		; erreur de lecture ?	JUMP,NE	EDIT9		; oui => EDIT902$:	LOAD.W	D0,D3	PUSH.L	D0	SR.W	D0,#8	COMP.B	D0,#KEYMPO/H'100 ; "touche" concernant la souris ?	POPM.L	D0	JUMP',EQ 04$		; oui => 04$				; non =>	CALL	_MINMAJ		; D3 <-- lettre telle quelle	EX.L	D0,D3		; D0 <-- lettre MAJUSCULE04$:	TEST.B	D4		; accent en cours ?	JUMP',EQ 08$		; non => 08$	CALL	DOACCENT	; oui => DOACCENT	JUMP,EQ	EDIT008$:	CLR.B	D4		; D4 <-- accent trait; Cherche si la touche presse fait partie de la liste; terminale de l'utilisateur.	LOAD.L	A0,A1		; A0 <-- ^liste touches user10$:	ADD.L	A0,#2		; A0 <-- ^suivant	TEST.B	(A0)-2		; fin de la table ?	JUMP',NS 15$		; oui => 15$	COMP.W	D0,(A0)-2	; trouv en MAJUSCULE ?	JUMP,EQ	EDIT9		; oui => EDIT9	COMP.W	D3,(A0)-2	; trouv telle quelle ?	JUMP,EQ	EDIT9		; oui => EDIT9	JUMP	10$		; non => 10$; Cherche si la touche presse fait partie de la liste des; commandes d'ditions.15$:	COMP.W	D3,#KCIRCON	; touche circonflxe ?	JUMP,EQ	DOCIRCON	COMP.W	D3,#KTREMA	; touche trma ?	JUMP,EQ	DOTREMA	COMP.W	D3,#TAB		; TAB sans touche fonction ?	JUMP',EQ 60$		; oui => 60$				; non =>	LOAD.L	A0,#R16"TAEKEY-420$:	ADD.L	A0,#1+1+2	; A0 <-- ^suivant dans TAEKEY	TEST.B	(A0)		; fin de la table ?	JUMP',NS 50$		; oui => 50$	COMP.W	D0,(A0)		; fonction+touche trouvs ?	JUMP,NE 20$		; non => 20$				; oui =>	CLR.L	D0	LOAD.W	D0,(A0)+2	; D0 <-- adresse relative	LOAD.L	A0,#R16"VAR	; A0 <-- ^variables globales	ADD.L	D0,(A0)+OSTART	; D0 <-- adresse absolue	LOAD.L	A0,D0		; A0 <-- idem	LOAD.L	D0,D3	CALL	(A0)		; appel routine d'dition	JUMP,NE	EDIT0		; si pas fini => EDIT0	LOAD.L	D3,D0		; D3 <-- dernire touche	JUMP	EDIT950$:	COMP.W	D3,#H'80	; touche fonction ou suppl ?	JUMP',HS EDIT9		; oui => EDIT9	COMP.B	D3,#'		; touche spciale ?	JUMP',LO EDIT9		; oui => EDIT960$:	CALL	INSERT		; insre un caractre	JUMP,NE	EDIT0		; ok => EDIT0				; buffer plein =>EDIT9:	PUSHM.L	D3,D7	TEST.W	D1		; affichage en retard ?	JUMP',EQ 05$		; non => 05$	CALL	EDAFLI		; oui => affiche la ligne05$:	CALL	EDINVC		; efface le curseur	LOAD.L	D3,D2		; D3 <-- pos dbut de la ligne	CALL	_SETCURS	; remet curseur dbut ligne	LOAD.B	D3,#CURS	CALL	_AFCAR		; remet le curseur standard	POPM.L	D3,D7	LOAD.L	A0,A3		; A0 <-- ^position du curseur10$:	COMP.L	A4,A5		; est-on  la fin du buffer ?	JUMP',EQ 20$	LOAD.B	(A3+),(A4+)	JUMP	10$20$:	LOAD.B	(A3+),#CR	CLR.B	(A3)		; termine ligne par <CR><0>	LOAD.L	A4,A0		; A4 <-- ^position du curseur	POPM.L	D2,D4,D5,A2,A3,A5	RETTAEKEY:	.BBW	0 DEL			DRECULE	.BBW	0 BS			DAVANCE	.BBW	0 UNDO			DOUNDO	.BBW	0 DELETE		DRECULE	.BBW	0 CLEAR			DOUNDO	.BBW	0 TRIZERO		DO000	.BBW	0 POINT			DOPOINT	.BBW	2^BCURSOR 'D		RECULE	.BBW	2^BCURSOR 'F		AVANCE	.BBW	2^BCURSOR 'S		DOCUS	.BBW	2^BCURSOR 'G		DOCUG	.BBW	2^BCURSOR 'R		DOCUR	.BBW	2^BCURSOR 'C		DOCUC	.BBW	2^BCURSOR 'E		DOCUE	.BBW	2^BCURSOR 'X		DOCUX	.BBW	2^BCURSOR 'T		DOCUT	.BBW	2^BCURSOR 'V		DOCUV	.BBW	2^BCURSOR!2^BKILL 'D	DRECULE	.BBW	2^BCURSOR!2^BKILL 'F	DAVANCE	.BBW	2^BCURSOR!2^BKILL 'S	DOCUKS	.BBW	2^BCURSOR!2^BKILL 'G	DOCUKG	.BBW	2^BCURSOR!2^BKILL 'R	DOCUKR	.BBW	2^BCURSOR!2^BKILL 'C	DOCUKC	.BBW	2^BCURSOR!2^BKILL 'E	DOCUKE	.BBW	2^BCURSOR!2^BKILL 'X	DOCUKX	.BBW	2^BCURSOR!2^BKILL 'T	DOCUKT	.BBW	2^BCURSOR!2^BKILL 'V	DOCUKV	.B	2^7	.EVENDOCUS:10$:	CALL	RECULE		; saute sparateur(s)	JUMP',EQ 90$	CALL	TSTSEP	JUMP,EQ 10$20$:	CALL	RECULE		; saute "mot"	JUMP',EQ 80$	CALL	TSTSEP	JUMP,NE 20$	CALL	AVANCE80$:	CLRZ			; NE <-- ok90$:	RETDOCUG:10$:	CALL	AVANCE		; saute sparateur(s)	JUMP',EQ 90$	CALL	TSTSEP	JUMP,EQ 10$20$:	CALL	AVANCE		; saute "mot"	JUMP',EQ 80$	CALL	TSTSEP	JUMP,NE 20$	CALL	RECULE80$:	CLRZ			; NE <-- ok90$:	RETDOCUT:DOCUE:	CALL	DOCUR	SETZ			; EQ <-- dbordement	RETDOCUR:10$:	CALL	RECULE	JUMP',EQ 90$20$:	CALL	RECULE	JUMP,NE 20$	CLRZ			; NE <-- ok90$:	RETDOCUV:DOCUX:	CALL	DOCUC	SETZ			; EQ <-- dbordement	RETDOCUC:10$:	CALL	AVANCE	JUMP',EQ 90$20$:	CALL	AVANCE	JUMP,NE 20$	CLRZ			; NE <-- ok90$:	RETDOCUKS:	LOAD.L	A0,A4	CALL	DOCUS	LOAD.L	A4,A0	RETDOCUKG:	LOAD.L	A0,A3	CALL	DOCUG	LOAD.L	A3,A0	RETDOCUKT:DOCUKE:	LOAD.L	A0,A4	CALL	DOCUT	LOAD.L	A4,A0	RETDOCUKR:	LOAD.L	A0,A4	CALL	DOCUR	LOAD.L	A4,A0	RETDOCUKV:DOCUKX:	LOAD.L	A0,A3	CALL	DOCUV	LOAD.L	A3,A0	RETDOCUKC:	LOAD.L	A0,A3	CALL	DOCUC	LOAD.L	A3,A0	RETDOUNDO:	LOAD.L	A3,A2	LOAD.L	A4,A5	CLRZ			; NE <-- ok	RETDOPOINT:	LOAD.B	D3,#'.	JUMP	INSERTDO000:	LOAD.B	D3,#'0	CALL	INSERT	CALL	INSERT	JUMP	INSERT		; insre 3x zroDOCIRCON:	LOAD.B	D4,#CIRCON	; D4 <-- accent en cours	JUMP	DOACQQDOTREMA:	LOAD.B	D4,#TREMA	; D4 <-- accent en coursDOACQQ:	LOAD.B	D3,D4	CALL	INSERT		; insre circonflxe ou trma	CALL	RECULE		; puis recule dessus.	JUMP	EDIT0DOACCENT:	COMP.W	D3,#CR		; (RETURN) ?	JUMP',EQ 80$		; oui => 80$	COMP.W	D3,#DEL		; (DEL) ?	JUMP',EQ 80$		; oui => 80$	COMP.W	D3,#H'80	; touche spciale ?	JUMP',HS 80$		; oui => 80$	CALL	GETACC		; cherche si accent existe	JUMP',NE 50$		; si n'existe pas =>				; si existe (a,e,i,o,u,etc) =>	PUSH.W	D3	CALL	DAVANCE		; dtruit circonflxe ou trma	POP.W	D3	JUMP'	60$		; puis insre caractre50$:	PUSH.W	D3	CALL	AVANCE		; saute l'accent	POP.W	D360$:	CALL	INSERT		; puis insre caractre	CLR.B	D4		; D4 <-- accent trait	RET			; retour EQ80$:	PUSH.W	D3	CALL	AVANCE		; saute l'accent	POP.W	D3	CLRZ			; retour NE	RET;--------\; GETACC  >;========/; Calcul le code correspondant  une lettre (a,e,i,o,u) et ; un accent (^,").; in	D4.B	accent (^,");	D3.B	caractre; out	D7.W	zro => ok (lettre accentue existe);	 D3.B	 lettre accentue;	D7.W	un => lettre accentue n'existe pas;	 D3.B	 caractre qui devait aller sous l'accent; mod	D7.W, D3.BGETACC:	PUSH.L	A1	LOAD.L	A1,#R16"TABMIN-310$:	ADD.L	A1,#3		; A1 <-- ^suivant dans table	TEST.B	(A1)		; fin de la table ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,(A1)		; lettre trouve dans table ?	JUMP,NE 10$		; non => 10$				; oui =>	COMP.B	D4,#CIRCON	JUMP',EQ 30$	COMP.B	D4,#TREMA	JUMP',NE 50$	LOAD.B	D3,(A1)+2	; D3 <-- lettre accentue (")	CLR.W	D7		; D7 <-- ok	JUMP'	90$30$:	LOAD.B	D3,(A1)+1	; D3 <-- lettre accentue (^)	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.W	D7,#1		; D7 <-- erreur quelconque90$:	POP.L	A1	TEST.W	D7		; retour EQ/NE	RETTABMIN:	.B	'a	' '	.B	'e	' '	.B	'i	' '	.B	'o	' '	.B	'u	' '	.B	SPACE	'^ '"	.B	KCIRCON	'^ '^	.B	KTREMA	'" '"	.B	0	.EVEN;--------\; INSERT  >;========/; Insre un caractre dans le buffer de texte.; in	D3.B	caractre  insrer;	D5.W	flags; out	EQ	buffer plein;	D7.W	erreur; mod	D7.WINSERT:	TCLR.L	D5:#15	JUMP',BC 20$	LOAD.L	A3,A2	LOAD.L	A4,A520$:	LOAD.W	D7,#ERLBFU	; D7 <-- buffer plein	COMP.L	A3,A4		; trou plein ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.B	(A3+),D3	; insre un caractre	CLR.W	D7		; D7 <-- ok	CLRZ			; NE90$:	RET;--------\; AVANCE  >;========/; in	-; out	D3.B	caractre avanc;	EQ	fin du buffer; mod	D3.BAVANCE:	TCLR.L	D5:#15	CLR.B	D3	COMP.L	A4,A5		; est-on  la fin ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.B	D3,(A4+)	LOAD.B	(A3+),D390$:	TEST.B	D3		; EQ si BOT/EOT	RET;--------\; RECULE  >;========/; in	-; out	D3.B	caractre recul;	EQ	dbut du buffer; mod	D3.BRECULE:	TCLR.L	D5:#15	CLR.B	D3	COMP.L	A3,A2		; est-on au dbut ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.B	D3,(-A3)	LOAD.B	(-A4),D390$:	TEST.B	D3		; EQ si BOT/EOT	RET;--------\; DAVANCE >;========/; in	-; out	D3.B	caractre dtruit;	EQ	fin du buffer; mod	D3.BDAVANCE:	TCLR.L	D5:#15	CLR.B	D3	COMP.L	A4,A5		; est-on  la fin ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.B	D3,(A4+)90$:	TEST.B	D3		; EQ si BOT/EOT	RET;--------\; DRECULE >;========/; in	-; out	D3.B	caractre dtruit;	EQ	dbut du buffer; mod	D3.BDRECULE:	TCLR.L	D5:#15	CLR.B	D3	COMP.L	A3,A2		; est-on au dbut ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.B	D3,(-A3)90$:	TEST.B	D3		; EQ si BOT/EOT	RET;--------\; TSTSEP  >;========/; Teste si le caractre dans D3 est un sparateur pour les; dplacements de mots.; in	D3.B	caractre; out	EQ	sparateur;	NE	autrement; mod	-TSTSEP:	TEST.B	D3	JUMP',EQ 90$	COMP.B	D3,#SPACE	JUMP',EQ 90$	COMP.B	D3,#TAB	JUMP',EQ 90$	COMP.B	D3,#'.	JUMP',EQ 90$	COMP.B	D3,#',	JUMP',EQ 90$	COMP.B	D3,#':	JUMP',EQ 90$	COMP.B	D3,#';;	JUMP',EQ 90$90$:	RET;--------\; EDAFLI  >;========/; Affiche sur l'cran la ligne dite.; in	D2.L		position (y;x) dbut ligne;	D5.W		flags;	A2.L		^DB;	A3.L		^DT;	A4.L		^FT;	A5.L		^FB;	(A6)+OPOCUR.L	position du curseur proportionnel; out	(A6)+OPOCUR.L	position du curseur proportionnel;	(A6)+OCACUR.W	caractre sous le curseur;	(A6)+OLGEDI.W	longueur de la ligne;	D1.W		zro (affichage  jour); mod	D1.W, D3.LEDAFLI:	PUSHM.L	D0,D4,D6,A0,A1,A2	CALL	_BUCAR		; passe en mode rapide	TEST.L	(A6)+OPOCUR	; dj un curseur dessin ?	JUMP',EQ 05$		; non => 05$	CALL	EDINVC		; oui => efface le curseur05$:	CALL	EDOFFSET	; A0 <-- ^dbut pour affichage	CLR.W	D1		; D1 <-- largeur ligne	PUSH.L	A0	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.B	D6,(A0)+ODFMOD	; D6 <-- sauve ODFMOD	POP.L	A0	LOAD.B	D3,#TRUNC	; tronque les caractres qui	CALL	_AFCAR		; dbordent  droite !	LOAD.L	D3,D2		; D3 <-- position dbut ligne	CALL	_SETCURS	COMP.L	A0,A2		; affiche depuis le dbut ?	JUMP',EQ 10$		; oui => 10$				; non =>	CALL	_AFTIM		; affiche flche <- inverse	.B	AFINV,AFTOUT,5,AFNORM,AFDIR,0	.EVEN	INC.L	A0		; A0 <-- saute 1er caractre	PUSH.L	A0	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.W	D1,(A0)+ODFCX	; D1 <-- lg max flche	POP.L	A010$:	COMP.L	A0,A3		; dbut du trou rencontr ?	JUMP',NE 20$		; non => 20$				; oui =>	CALL	_GETCURS	LOAD.L	(A6)+OPOCUR,D3	; mm position du curseur	LOAD.L	A0,A4		; A0 <-- saute le trou (hop)	LOAD.B	(A6)+OCACUR,#SPACE ; larg si curseur  la fin	COMP.L	A0,A5		; curseur  la fin du buffer ?	JUMP',EQ 20$		; oui => 20$	LOAD.B	(A6)+OCACUR,(A0) ; mm caractre sous curseur20$:	COMP.L	A0,A5		; fin du buffer rencontre ?	JUMP',EQ 50$		; oui => 50$				; non =>	CLR.W	D3	LOAD.B	D3,(A0+)	; D3 <-- un caractre	CALL	_AFCAR		; affiche un caractre	CLR.W	D4	LOAD.B	D4,(A1)+(D3.W)	; D4 <-- largeur du caractre	ADD.W	D1,D4		; D1 <-- calcul largeur ligne	JUMP	10$50$:	COMP.W	D1,D0		; dborde fentre  droite ?	JUMP',LS 55$		; non => 55$				; oui =>	LOAD.B	D3,#TYPORX	CALL	_AFCAR		; recule d'un caractre	PUSH.L	A0	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.W	D3,(A0)+ODFCX	POP.L	A0	NEG.B	D3		; D3 <-- largeur ngative	CALL	_AFCAR	CALL	_AFTIM		; affiche flche -> inverse	.B	AFINV,AFTOUT,4,AFNORM,AFDIR,0	.EVEN55$:;;?	LOAD.B	D3,#SPACE;;?	CALL	_AFCAR		; affiche encore un SPACE !	LOAD.W	D0,(A6)+OLGEDI	; D0 <-- largeur dernire ligne	LOAD.W	(A6)+OLGEDI,D1	; mm. nouvelle largeur ligne;;?	CLR.W	D3;;?	LOAD.B	D3,(A1)+SPACE	; D3 <-- largeur d'un SPACE;;?	ADD.W	D0,D3		; D0 <-- largeur + un caractre60$:	COMP.W	D1,D0	JUMP',HS 70$		; si ligne plus longue => 70$				; si ligne plus courte =>	LOAD.W	D3,#SPACE	CALL	_AFCAR		; affiche un espace	CLR.W	D3	LOAD.B	D3,(A1)+SPACE	; D3 <-- largeur d'un SPACE	ADD.W	D1,D3		; D1 <-- calcul largeur ligne	JUMP	60$70$:;;	LOAD.B	D3,#EFLI;;	CALL	_AFCAR		; EFFACE LA FIN DE LA LIGNE !!!	CALL	EDINVC		; dessine curseur proportionnel	TEST.L	D6:#BFTRUNC	; mode original AUTOCR/TRUNC ?	JUMP',BS 90$		; TRUNC => 90$	LOAD.B	D3,#AUTOCR	; AUTOCR =>	CALL	_AFCAR		; remet-le pour ne rien changer90$:	CALL	_NOBUCAR	; remet le mode non-interractif	CLR.W	D1		; D1 <-- affichage  jour	POPM.L	D0,D4,D6,A0,A1,A2	RET;--------\; EDINVC  >;========/; Inverse le curseur proportionnel.; in	-; out	-; mod	D3.L, D7.WEDINVC:	LOAD.L	D3,(A6)+OPOCUR	; D3 <-- position du curseur	CALL	_SETCURS	; positionne curseur invisible	LOAD.B	D3,#PROCURS	CALL	_AFCAR		; efface curseur proportionnel	LOAD.B	D3,(A6)+OCACUR	; D3 <-- caractre sous curseur	CALL	_AFCAR		; donne car pour la largeur	RET;---------\; EDOFFSET >;---------/; Calcul un ventuel offset au dbut de la ligne si elle; est trop longue pour simuler un "shift" horizontal.; in	D2.L		position (y;x) dbut ligne;	D5.W		flags;	A2.L		^DB;	A3.L		^DT;	A4.L		^FT;	A5.L		^FB; out	A0.L		^dbut pour affichage;	D0.W		place pour ligne;	A1.L		^table des largeurs des caractres; mod	D0.L, A0.L, A1.LEDOFFSET:	PUSHM.L	D1,D2,D3,D4	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.L	A1,(A0)+ODFPGC	; A1 <-- ^dbut GENCAR	ADD.L	A1,#OGCWID	; A1 <-- ^table des largeurs	LOAD.W	D3,(A0)+ODFFDX	; D3 <-- largeur s-wdo	TEST.L	D5:#14	JUMP',BC 05$	LOAD.L	D0,D5	SWAP.W	D0		; D0 <-- largeur maximale	COMP.W	D3,D0	JUMP',LS 05$	LOAD.W	D3,D0		; D3 <-- largeur  ne pas dpasser05$:	SUB.W	D3,D2		; D3 <-- place pour la ligne	LOAD.W	D0,D3		; D0 <-- place pour la ligne	SUB.W	D3,(A0)+ODFCX	; D3 <-- idem - rserve !	CLR.W	D1		; D1 <-- lg avant trou	CLR.W	D2		; D2 <-- lg totale	LOAD.L	A0,A2		; A0 <-- ^dbut buffer10$:	COMP.L	A0,A3		; dbut du trou rencontr ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.L	A0,A4		; A0 <-- saute le trou (hop)	LOAD.W	D1,D2		; D1 <-- lg avant trou20$:	COMP.L	A0,A5		; fin du buffer rencontre ?	JUMP',EQ 30$		; oui => 30$				; non =>	CLR.W	D4	LOAD.B	D4,(A0+)	; D4 <-- un caractre	LOAD.B	D4,(A1)+(D4.W)	; D4 <-- largeur du caractre	AND.W	D4,#H'FF	ADD.W	D2,D4		; D2 <-- calcul largeur ligne	JUMP	10$30$:	COMP.L	A4,A5		; curseur tout  la fin ?	JUMP',NE 35$		; non => 35$	PUSH.L	A0	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	ADD.W	D2,(A0)+ODFCX	; compte place du curseur	POP.L	A035$:	LOAD.L	A0,A2		; A0 <-- ^dbut buffer	COMP.W	D2,D3		; place pour toute la ligne ?	JUMP',LS 90$		; oui => 90$				; non =>	LOAD.W	D4,D3	SR.W	D4,#1		; D4 <-- moiti de la place	ADD.W	D1,D4		; avance de 1/2 lg place	COMP.W	D1,D2		; trop  droite ?	JUMP',LS 50$		; non => 50$	LOAD.W	D1,D2		; D1 <-- maximum possible50$:	SUB.W	D1,D3		; recule de lg place	JUMP',LS 90$		; trop  gauche => 90$	CLR.W	D2		; D2 <-- position dans ligne60$:	COMP.L	A0,A3		; dbut du trou rencontr ?	JUMP',EQ 90$		; oui => 90$	CLR.W	D4	LOAD.B	D4,(A0+)	; D4 <-- un caractre	LOAD.B	D4,(A1)+(D4.W)	; D4 <-- largeur du caractre	AND.W	D4,#H'FF	ADD.W	D2,D4		; D2 <-- position dans ligne	COMP.W	D2,D1		; offset dpass ?	JUMP,LO	60$		; non => 60$				; oui =>	DEC.L	A0		; A0 <-- ^dbut90$:	POPM.L	D1,D2,D3,D4	RET	.END