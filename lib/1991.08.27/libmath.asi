	.SBTTL	LIBMATH;----------\\; _CALCHYPO >;==========/; Calcule l'hypothnuse d'un triangle rectangle.; Cet appel permet, par exemple, de trouver le rayon d'un cercle; en fonction de la position de la souris.; L'astuce consiste  calculer la racine carr par itrations !;;	         Px;	     |-------/;	     |      /;	     |     /;	  Py |    /;	     |   / H;	     |  /;	     | /;	     |/;;	H = SQR( Px^2 + Py^2 );; Pour minimiser les itrations, on utilise les constatations suivantes :;;	H > MAX(Px,Py);	H < Px+Py; in	D3.L	P(y,x); out	D4.W	H; mod	D4.L, D7.W_CALCHYPO:	PUSHM.L	D0..D3	LOAD.W	D4,D3		; D4 <-- Px	SWAP.W	D3		; D3 <-- Py	TEST.W	D4	JUMP',NC 10$	NEG.W	D4		; D4 <-- |Px|10$:	TEST.W	D3	JUMP',NC 12$	NEG.W	D3		; D3 <-- |Py|12$:	LOAD.W	D0,D4	COMP.W	D0,D3	JUMP',HS 14$	LOAD.W	D0,D3		; D0=Bi <-- MAX(Px,Py)14$:	LOAD.W	D1,D3	ADD.W	D1,D4		; D1=Bs <-- Px+Py	MUL.WU	D3,D3	MUL.WU	D4,D4	ADD.L	D4,D3		; D4 <-- Px^2 + Py^220$:	COMP.W	D0,D1		; borne infrieure = borne suprieure ?	JUMP',EQ 80$		; oui => 80$	DEC.W	D1	COMP.W	D0,D1		; borne infrieure ~ borne suprieure ?	JUMP',EQ 80$		; oui => 80$	INC.W	D1	LOAD.W	D2,D1	SUB.W	D2,D0	SR.W	D2,#1	ADD.W	D2,D0		; D2=Bx <-- Bi+(Bs-Bi)/2	LOAD.W	D3,D2	MUL.WU	D3,D3		; D3 <-- Bx^2	COMP.L	D3,D4		; Bx^2 = Px^2 + Py^2  ?	JUMP',EQ 70$	JUMP',HI 40$	LOAD.W	D0,D2		; D0=Bi <-- Bx	JUMP	20$40$:	LOAD.W	D1,D2		; D1=Bs <-- Bx	JUMP	20$70$:	LOAD.W	D0,D280$:	LOAD.W	D4,D0		; D4 <-- H	POPM.L	D0..D3	RETPASTOURNE =	20		; valeur minimale pour n=(360*p)+p;-----------\\; _CALCANGLE >;===========/; Dtermine l'angle de rotation en fonction de la position de la souris.; Le point P5 est situ sur un cercle de centre P3. Le point P4; (position de la souris) dtermine une rotation pour amener P5 sur P4.; ATTENTION: P4 n'est pas forcment situ sur le cercle P3/P5 !; in	D3.L	centre (y;x);	D4.L	position de la souris (y;x);	D5.L	point  tourner (y;x); out	D2.W	angle (0..360), dans le sens des aiguilles de la montre; mod	D2.L, D7.W_CALCANGLE:	PUSHM.L	D0,D1,D3..D6	LOAD.L	D2,D4		; D2 <-- position de la souris	PUSH.L	D5		; stack <-- point  tourner; Balaye les angles par incrments de PASTOURNE degrs en cherchant; la distance minimale.	CLR.W	D1		; D1 <-- angle initial	LOAD.W	D0,#360/PASTOURNE	LOAD.W	D5,#-1		; D5 <-- distance minimale10$:	LOAD.L	D4,(SP)	CALL	_CALCPSYM	; D4 <-- tourne selon l'angle D1	SUB.W	D4,D2	JUMP',NC 20$	NEG.W	D420$:	LOAD.W	D7,D4	SWAP.W	D4	SWAP.W	D2	SUB.W	D4,D2	JUMP',NC 22$	NEG.W	D422$:	SWAP.W	D2	ADD.W	D4,D7		; D4 <-- |dx| + |dy|	COMP.W	D4,D5		; distance plus courte ?	JUMP',HS 30$		; non => 30$	LOAD.W	D5,D4	LOAD.W	D6,D1		; D6 <-- angle le meilleur30$:	ADD.W	D1,#PASTOURNE	; D1 <-- angle suivant	DEC.W	D0	JUMP,NE 10$; Balaye tous les angles possibles autour du multiple de PASTOURNE degrs; en cherchant la distance minimale.	LOAD.W	D1,D6	SUB.W	D1,#(PASTOURNE/2)+1	LOAD.W	D0,#(PASTOURNE)+2	LOAD.W	D5,#-1		; D5 <-- distance minimale40$:	LOAD.L	D4,(SP)	CALL	_CALCPSYM	; D4 <-- tourne selon l'angle D1	SUB.W	D4,D2	JUMP',NC 50$	NEG.W	D450$:	LOAD.W	D7,D4	SWAP.W	D4	SWAP.W	D2	SUB.W	D4,D2	JUMP',NC 52$	NEG.W	D452$:	SWAP.W	D2	ADD.W	D4,D7		; D4 <-- |dx| + |dy|	COMP.W	D4,D5		; distance plus courte ?	JUMP',HS 60$		; non => 60$	LOAD.W	D5,D4	LOAD.W	D6,D1		; D6 <-- angle le meilleur60$:	INC.W	D1		; D1 <-- angle suivant	DEC.W	D0	JUMP,NE 40$	POP.L	D5		; ajuste le stack	LOAD.W	D2,D6		; D2 <-- angle	JUMP',NC 80$	ADD.W	D2,#36080$:	COMP.W	D2,#360	JUMP',LO 90$	SUB.W	D2,#36090$:	POPM.L	D0,D1,D3..D6	CLR.W	D7		; D7 <-- ok	RET;----------\\; _CALCPSYM >;==========/; Tourne un point d'un angle quelconque (symtrie centrale),; selon la formule suivante :;;	x' = x*cos(a) - y*sin(a);	y' = x*sin(a) + y*cos(a); in	D1.W	angle (0..360), dans le sens des aiguilles de la montre;	D3.L	centre (y;x);	D4.L	point  tourner (y;x); out	D4.L	point tourn (y;x); mod	D4.L, D7.W_CALCPSYM:	PUSHM.L	D0,D1,D2,D5,D6	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	CALL	_CALCCOS	; D2 <-- 10000*cos(a)	LOAD.W	D5,D2	CALL	_CALCSIN	; D2 <-- 10000*sin(a)	LOAD.W	D0,D2		; D0 <-- 10000*sin(a)	LOAD.W	D1,D5		; D1 <-- 10000*cos(a)	LOAD.W	D5,D4	MUL.WA	D5,D1	JUMP',NS 30$	ADD.L	D5,#10000/2	JUMP'	32$30$:	SUB.L	D5,#10000/232$:	DIV.WA	D5,#10000	; D5 <-- x*cos(a)	LOAD.L	D6,D4	SWAP.W	D6	MUL.WA	D6,D0	JUMP',NS 40$	ADD.L	D6,#10000/2	JUMP'	42$40$:	SUB.L	D6,#10000/242$:	DIV.WA	D6,#10000	; D6 <-- y*sin(a)	LOAD.W	D2,D5	SUB.W	D2,D6		; D2 <-- x*cos(a) - y*sin(a)	LOAD.W	D5,D4	MUL.WA	D5,D0	JUMP',NS 50$	ADD.L	D5,#10000/2	JUMP'	52$50$:	SUB.L	D5,#10000/252$:	DIV.WA	D5,#10000	; D5 <-- x*sin(a)	LOAD.L	D6,D4	SWAP.W	D6	MUL.WA	D6,D1	JUMP',NS 60$	ADD.L	D6,#10000/2	JUMP'	62$60$:	SUB.L	D6,#10000/262$:	DIV.WA	D6,#10000	; D6 <-- y*cos(a)	ADD.W	D5,D6		; D5 <-- x*sin(a) + y*cos(a)	LOAD.W	D4,D5		; D4 <-- dy	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- dx	ADD.W	D4,D3		; D4 <-- x	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3		; D4 <-- y	SWAP.W	D3	SWAP.W	D4	POPM.L	D0,D1,D2,D5,D6	RET;-----------\\; _CALCPELLI >;===========/; Calcul les coordonnes d'un point situ sur une ellipse.; in	D1.W	angle (0..360), dans le sens des aiguilles de la montre;	D3.L	centre (y;x);	D4.L	rayons (ry;rx); out	D5.L	point (y;x); mod	D5.L, D7.W_CALCPELLI:	PUSH.L	D2	CALL	_CALCSIN	; D2 <-- 10000*sin(a)	SWAP.W	D4	MUL.WA	D2,D4	SWAP.W	D4	ADD.L	D2,#10000/2	DIV.WA	D2,#10000	SWAP.W	D3	ADD.W	D2,D3	SWAP.W	D3	LOAD.W	D5,D2	SWAP.W	D5	CALL	_CALCCOS	; D2 <-- 10000*cos(a)	MUL.WA	D2,D4	ADD.L	D2,#10000/2	DIV.WA	D2,#10000	ADD.W	D2,D3	LOAD.W	D5,D2	POP.L	D2	RET;---------\\; _CALCCOS >;=========/; Calcul rapidement un cosinus.; in	D1.W	angle (0..360), dans le sens des aiguilles de la montre; out	D2.W	cosinus (-10000..+10000); mod	D2.L, D7.W_CALCCOS:	PUSH.L	D1	TEST.W	D1	JUMP',NC 10$	ADD.W	D1,#36010$:	CONV.LA.WA D1	DIV.WU	D1,#360	SWAP.W	D1		; D1 <-- 0..360-1	SUB.W	D1,#90	NEG.W	D1	JUMP',NC 50$	ADD.W	D1,#36050$:	CALL	_CALCSIN	POP.L	D1	RET;---------\\; _CALCSIN >;=========/; Calcul rapidement un sinus.; in	D1.W	angle (0..360), dans le sens des aiguilles de la montre; out	D2.W	sinus (-10000..+10000); mod	D2.L, D7.W_CALCSIN:	PUSHM.L	D1,A1	LOAD.L	A1,#R16"TSINUS	TEST.W	D1	JUMP',NC 10$	ADD.W	D1,#36010$:	CONV.LA.WA D1	DIV.WU	D1,#360	SWAP.W	D1		; D1 <-- 0..360-1	COMP.W	D1,#90	JUMP',LS 40$	COMP.W	D1,#180	JUMP',LS 30$	COMP.W	D1,#270	JUMP',LS 20$				; angle 270..360 =>	SUB.W	D1,#360	NEG.W	D1	SL.W	D1,#1	LOAD.W	D2,(A1)+(D1.W)	NEG.W	D2	JUMP'	90$20$:				; angle 180..270 =>	SUB.W	D1,#180	SL.W	D1,#1	LOAD.W	D2,(A1)+(D1.W)	NEG.W	D2	JUMP'	90$30$:				; angle 90..180 =>	SUB.W	D1,#180	NEG.W	D1	SL.W	D1,#1	LOAD.W	D2,(A1)+(D1.W)	JUMP'	90$40$:				; angle 0..90 =>	SL.W	D1,#1	LOAD.W	D2,(A1)+(D1.W);	JUMP'	90$90$:	POPM.L	D1,A1	RETTSINUS:	.W	0,175,349,523,698,872,1045,1219,1392,1564		; 0..9	.W	1736,1908,2079,2250,2419,2588,2756,2924,3090,3256	; 10..19	.W	3420,3584,3746,3907,4067,4226,4384,4540,4695,4848	; 20..29	.W	5000,5150,5299,5446,5592,5736,5878,6018,6157,6293	; 30..39	.W	6428,6561,6691,6820,6947,7071,7193,7314,7431,7547	; 40..49	.W	7660,7771,7880,7986,8090,8192,8290,8387,8480,8572	; 50..59	.W	8660,8746,8829,8910,8988,9063,9135,9205,9272,9336	; 60..69	.W	9397,9455,9511,9563,9613,9659,9703,9744,9781,9816	; 70..79	.W	9848,9877,9903,9925,9945,9962,9976,9986,9994,9998	; 80..89	.W	10000							; 90	.END