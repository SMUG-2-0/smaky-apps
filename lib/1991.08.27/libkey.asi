	.SBTTL	LIBKEY; Routines utilitaires pour le clavier; ------------------------------------;---------\; _GETFILE >;=========/; Attend une ligne du clavier, avec facilits d'ditions; propres aux noms de fichiers.; in	A3.L	^buffer;	A4.L	^dans buffer;	A5.L	^table d'insertion pour les soft keys;	D3.L	lg max buffer; out	D3.W	dernire touche (RETURN,UNDO,END,SPACE);	A4.L	^dans buffer;	D7.W	erreur; mod	D3.W, D7.W, A4.L_GETFILE:	PUSHM.L	D0,D1,A1,A2,A3,A5	LOAD.L	D1,D3		; D1 <-- lg max ligne	LOAD.L	A1,A5		; A1 <-- ^table pour soft keys	LOAD.L	A2,#R16"TKGETL	JUMP'	11$10$:	TEST.L	D1:#13	JUMP',BC 11$	CLR.L	D3		; D3 <-- rend une touche spciale	JUMP	90$11$:	LOAD.L	D3,D1		; D3 <-- lg max ligne	LIB	?EDIT	TEST.W	D7		; erreur de lecture ?	JUMP,NE	90$		; oui => 90$;;?	COMP.W	D3,#BS		; efface tout ?;;?	JUMP,EQ 50$		; oui => 50$	COMP.W	D3,#(2^BPROGRA)*H'100+'-	JUMP,EQ 60$	COMP.W	D3,#(2^BPROGRA)*H'100+'_	JUMP,EQ 65$	COMP.W	D3,#SPACE	JUMP,EQ 80$	TEST.W	D3	JUMP,EQ 90$	COMP.W	D3,#UNDO	JUMP,EQ 90$	COMP.W	D3,#END	JUMP,EQ 90$	COMP.W	D3,#CR		; ligne termine ?	JUMP,EQ 90$		; oui => 90$	COMP.W	D3,#H'100	; touche fonction ou autre ?	JUMP,HS	90$		; oui => 90$				; non =>	LOAD.L	A5,#R16"TTGETL22$:	LOAD.B	D0,(A5+)	JUMP',EQ 30$		; fin table => 30$	COMP.B	D0,D3		; trouv ?	JUMP',EQ 40$		; oui => 40$25$:	TEST.B	(A5+)		; A5 <-- ^suivant dans TTGETL	JUMP,NE 25$	JUMP	22$30$:	LOAD.L	D0,A1		; A5 user = zro ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A5,A1		; A5 <-- ^table utilisateur32$:	LOAD.B	D0,(A5+)	JUMP,EQ 90$		; fin table => 90$	COMP.B	D0,D3		; trouv ?	JUMP',EQ 40$		; oui => 40$35$:	TEST.B	(A5+)		; A5 <-- ^suivant dans table	JUMP,NE 35$	JUMP	32$40$:	LOAD.B	D3,(A5)		; D3 <-- 1er car de la chane	COMP.B	D3,#'/	JUMP,EQ	70$	COMP.B	D3,#',	JUMP,EQ	70$	COMP.B	D3,#SPACE	; chane commence par espace ?	JUMP',NE 43$		; non => 43$				; oui =>	COMP.L	A4,A3		; est-on au dbut de la ligne ?	JUMP',EQ 42$		; oui => 42$	LOAD.B	D3,(A4)-1	; D3 <-- caractre juste avant	COMP.B	D3,#SPACE	; espace juste avant ?	JUMP',EQ 42$		; oui => 42$	COMP.B	D3,#'{		;  cause  {#DISPLAY=...	JUMP',EQ 42$	COMP.B	D3,#'=		;  cause  {$DIS_2=#DISPLAY...	JUMP',EQ 42$	COMP.B	D3,#',		;  cause  {2,#OUT=...	JUMP',EQ 42$	COMP.B	D3,#'>		;  cause  >#PRINTER	JUMP',EQ 42$	COMP.B	D3,#'<		;  cause  <#PR	JUMP',EQ 42$	COMP.B	D3,#'(		;  cause  (#MM0:,#MM1:)...	JUMP',EQ 42$	CALL	IFNETW		; nom de rseau juste avant ?	JUMP',NE 43$42$:	INC.L	A5		; n'insre pas l'espace43$:	LOAD.L	D3,D1		; D3 <-- lg max ligne	LIB	?INSERT		; insre la chane fixe45$:	TEST.B	(A5+)		; cherche fin chane .ASCIZ	JUMP,NE 45$	COMP.B	(A5)-2,#SPACE	; chane termine par SPACE ?	JUMP',EQ 85$		; oui => 85$	LOAD.W	D3,#CR	COMP.B	(A5)-2,#CR	; chane termine par RETURN ?	JUMP,NE	10$		; non => 10$	CLR.B	(A4)		; met <CR><0> juste aprs	JUMP	90$;;?50$:				; (BS);;?	LOAD.L	A4,A3		; A4 <-- ^dbut ligne;;?	CLR.B	(A3)		; vide la ligne;;?	JUMP	10$60$:				; (PROGRA-tiret)	LOAD.B	D3,#GCURS	LIB	?AFCAR		; init gros curseur	JUMP	10$65$:				; (PROGRA-soulign)	LOAD.B	D3,#PCURS	LIB	?AFCAR		; init petit curseur	JUMP	10$70$:				; "colle" le caractre	CALL	KILSPA		; dtruit espace(s) ventuel(s)	JUMP	43$		; puis insre le caractre80$:	LOAD.L	A5,#R16"00$	; A5 <-- ^SPACE	LOAD.L	D3,D1		; D3 <-- lg max ligne	LIB	?INSERT		; insre un espace85$:	LOAD.W	D3,#SPACE	; D3 <-- code dernire touche90$:	POPM.L	D0,D1,A1,A2,A3,A5	RET00$:	.B	SPACE,0	.EVEN;--------\; IFNETW  >;--------/; Test s'il y a un nom de rseau juste avant le pointeur.; in	A3.L	^dbut ligne;	D4.L	^dans ligne; out	EQ	nom de rseau @...:; mod	-IFNETW:	PUSH.L	A4	LOAD.W	D7,#1		; D7 <-- pas trouv @...:	COMP.B	(-A4),#':	; rseau/unit/rpertoire ?	JUMP',NE 90$		; non => 90$10$:	COMP.L	A4,A3		; est-on au dbut ligne ?	JUMP',EQ 90$		; oui => 90$	COMP.B	(-A4),#'@	; dbut nom rseau ?	JUMP',EQ 80$		; oui => 80$	COMP.B	(A4),#'#	JUMP',EQ 90$	COMP.B	(A4),#'$	JUMP',EQ 90$	COMP.B	(A4),#':	JUMP',EQ 90$	COMP.B	(A4),#SPACE	JUMP',EQ 90$	JUMP	10$80$:	CLR.W	D7		; D7 <-- nom de rseau trouv90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;--------\; KILSPA  >;--------/; Dtruit un ou plusieurs espaces situs avant le curseur.; in	A3.L	^dbut ligne;	A4.L	^position curseur dans ligne; out	A4.L	^nouvelle position; mod	-KILSPA:	PUSHM.L	D3,A0,A1	LOAD.L	A0,A410$:	COMP.L	A0,A3		; dbut de la ligne ?	JUMP',EQ 20$		; oui => 20$	COMP.B	(A0)-1,#SPACE	; espace juste avant ?	JUMP',NE 20$		; non => 20$	DEC.L	A0		; oui => recule sur l'espace	JUMP	10$20$:	COMP.L	A0,A4		; espace(s)  dtruire ?	JUMP',EQ 90$		; non => 90$				; oui =>	LOAD.L	A1,A4	LOAD.L	A4,A0		; A4 <-- ^nouvelle position30$:	LOAD.B	(A0+),(A1+)	; "compactifie" le texte	JUMP,NE 30$90$:	POPM.L	D3,A0,A1	RETTKGETL:	.B	0,SPACE	.B	0,UNDO;;?	.B	0,BS	.B	0,TAB	.B	0,'/;;-	.B	0,';;-	.B	0,'	.B	0,'#	.B	0,'$	.B	0,'@;;-	.B	0,'	.B	0,'\	.B	0,',;;-	.B	0,''	.B	2^BCURSOR,'E	.B	2^BCURSOR,'X	.B	2^BCURSOR,'T	.B	2^BCURSOR,'V	.B	2^7	.EVENTTGETL:;;-	.ASCIZ	"<'>_"	.ASCIZ	"<'/>/";;-	.ASCIZ	"<'>/"	.ASCIZ	"<',>,";;-	.ASCIZ	"<''>`"	.ASCIZ	"<'@> @";;-	.ASCIZ	"<'> @"	.ASCIZ	"<'#> #"	.ASCIZ	"<'\> #"	.ASCIZ	"<'$> $"	.ASCIZ	"<TAB> #mm1:"	.ASCIZ	"<STAB> #mm0:"	.ASCIZ	"<CTAB> #mm2:"	.B	0	.EVEN;---------\; _GETLINE >;=========/; in	A3.L	^buffer;	D3.W	longueur maximale de la ligne; out	D3.W	dernier caractre tap;	D7.W	erreur; mod	D3.W, D7.W_GETLINE:	PUSHM.L	A2,A4	LOAD.L	A4,A3		; A4 <-- ^curseur dans ligne	CLR.B	(A3)		; donne une ligne vide	LOAD.L	A2,#R16"00$	; A2 <-- ^liste nulle	CALL	_EDIT		; attend une ligne	PUSH.W	D7	CALL	_AFCR	POP.W	D7	POPM.L	A2,A4	RET00$:	.B	2^7		; liste de touches nulle	.EVEN;--------\; _IFCAR  >;========/; Lit un caractre du clavier sans attendre.; Ne modifie pas le mode de la souris (en attente ou pas).; in	-; out	D3.W	touche et touche fonction associe;	D7.W	erreur (timeout); mod	D3.W, D7.W_IFCAR:	PUSHM.L	D4,D5	NTREL	?GETTIM		; D4 <-- timeout utilisateur	LOAD.W	D5,D4	CLR.W	D4	NTREL	?SETTIM		; init timeout nul10$:	CALL	_RDKEY		; attend n'importe quoi ...	TEST.L	D3:#BKPSEUDO	; touche presse ?	JUMP,BS 10$		; non => 10$				; oui =>	COMP.W	D3,#KEYMPO	; dplacement de la souris ?	JUMP,EQ	10$		; oui => 10$ (filtre)	PUSH.W	D7	LOAD.W	D4,D5	NTREL	?SETTIM		; remet timeout initial	POP.W	D7	POPM.L	D4,D5	RET;--------\; _GETCAR >;========/; Attend un caractre du clavier.; Clear le compteur de ligne si une touche est lue; correctement (sans timeout).; in	-; out	D3.L	touche, touche fonction associe et pseudo code;	D7.W	erreur (timeout); mod	D3.L, D7.W_GETCAR:10$:	CALL	_GETKEY		; attend n'importe quoi ...	TEST.L	D3:#BKPSEUDO	; touche presse ?	JUMP,BS 10$		; non => 10$				; oui =>	COMP.W	D3,#KEYMPO	; dplacement de la souris ?	JUMP,EQ	10$		; oui => 10$ (filtre)	RET;--------\; _GETKEY >;========/; Met la souris normale, attend un caractre du clavier puis; remet la souris en attente.; in	-; out	D3.L	touche, touche fonction associe et pseudo code;	D7.W	erreur (timeout); mod	D3.L, D7.W_GETKEY:	PUSH.W	D4	LOAD.W	D4,#1	CALL	_WAITMOUSE	; remet la souris normale	CALL	_RDKEY		; attend une touche ...	POP.W	D4	RET;----------\; _GETSHIFT >;==========/; Lit l'tat des touches super-shift (sans attendre).; in	-; out	D3.B	touches super-shift presses; mod	D3.L, D7.W_GETSHIFT:	LOAD.B	D3,(A6)+OSHIFT	; D3 <-- touches super-shift	CLR.W	D7		; D7 <-- ok	RET;--------\; _RDKEY  >;========/; Attend un caractre du clavier, en laissant passer quatre; cas particuliers :;;	 pseudo   fonc    code;	!-------!-------!-------!; D3.L	!0	!0	!	!  touche presse;	!-------!-------!-------!;	   idem;	!-------!-------!-------!; D3.L	!1	!1	!0000000!  touche relache;	!-------!-------!-------!;;	!-------!-------!-------!; D3.L	!0	!1	!0000000!  changement touches fonctions;	!-------!-------!-------!;;	!-------!-------!-------!; D3.L	!0	!0111111!	!  envoi de la souris;	!-------!-------!-------!;	 !	 !;     BKRELEA BKPSEUDO;	; Clear le compteur de ligne si une touche est lue; correctement (sans timeout).; in	-; out	D3.L	touche, touche fonction associe et pseudo code;	D7.W	erreur (timeout); mod	D3.L, D7.W_RDKEY:	PUSHM.L	D4,D6,A4	COMP.B	(A6)+OTYPKEY,#TYPKEY ; type clavier ?	JUMP',NE 50$		; non => 50$	LOAD.W	D6,(A6)+OCHKEY	LOAD.L	A4,#(A6)+OBUREA	; A4 <-- ^buffer read	LOAD.L	D4,#3	FOS	?RDBYTE		; lit 3 bytes du clavier	JUMP',EQ 20$		; si ok => 20$				; si erreur (timeout)	CLR.L	D3		; D3 <-- "rien"	JUMP'	90$		; retour avec erreur20$:	CLR.L	D3	LOAD.B	D3,(A4)+2	; D3 <-- pseudo code	SL.W	D3,#8	LOAD.B	D3,(A4)+1	; D3 <-- code touche fonction	SL.L	D3,#8	LOAD.B	D3,(A4)+0	; D3 <-- code touche clavier	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP',BC 30$		; oui => 30$	TEST.L	D3:#BKRELEAS	JUMP',BS 30$	LOAD.B	(A6)+OSHIFT,(A4)+1 ; OSHIFT <-- touches super-shift30$:	TEST.L	D3:#BKPSEUDO	; pseudo code/touche relache ?	JUMP',BS 90$		; oui => 90$	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',EQ 90$		; oui => 90$	COMP.W	D3,#KEYMGR	; bouton gauche relach ?	JUMP',EQ 90$		; oui => 90$	COMP.W	D3,#KEYMMR	; bouton milieu relach ?	JUMP',EQ 90$		; oui => 90$	COMP.W	D3,#KEYMDR	; bouton droite relach ?	JUMP',EQ 90$		; oui => 90$	JUMP'	80$50$:	LOAD.W	D6,(A6)+OCHKEY	LOAD.L	A4,#(A6)+OBUREA	; A4 <-- ^buffer read	LOAD.L	D4,#1	FOS	?RDBYTE		; lit 1 byte du "clavier"	CLR.L	D3		; D3 <-- "rien"	TEST.W	D7		; lecture ok ?	JUMP',NE 90$		; non => 90$	LOAD.B	D3,(A4)		; D3 <-- code "touche" lue80$:	CLR.W	(A6)+OCNTLI	; clear compteur de lignes90$:	POPM.L	D4,D6,A4	RET;--------\; EXCADRE >;========/; in	D3.W	touche; out	D7.W	zro => commande effectue correctement; mod	D7.W;;EXCADRE:;;	PUSHM.L	D3,D4,D6,A4;;;;	LOAD.W	D7,#ERILOP	; D7 <-- erreur;;	LOAD.L	A4,#(A6)+OBUCOM	; A4 <-- ^buffer des commandes;;;;	COMP.W	D3,#(2^BSHOW)*H'100+'D;;	JUMP,NE 10$;;	LOAD.B	(A4+),#SCRLEFT;;10$:;;	COMP.W	D3,#(2^BSHOW)*H'100+'F;;	JUMP,NE 12$;;	LOAD.B	(A4+),#SCRRIGHT;;12$:;;	COMP.W	D3,#(2^BSHOW)*H'100+'R;;	JUMP,NE 14$;;	LOAD.B	(A4+),#SCRUP;;14$:;;	COMP.W	D3,#(2^BSHOW)*H'100+'C;;	JUMP,NE 16$;;	LOAD.B	(A4+),#SCRDOWN;;16$:;;	COMP.W	D3,#(2^BSHOW!2^BPROGRA)*H'100+'D;;	JUMP,NE 20$;;	LOAD.B	(A4+),#SCRGHOR;;20$:;;	COMP.W	D3,#(2^BSHOW!2^BPROGRA)*H'100+'F;;	JUMP,NE 22$;;	LOAD.B	(A4+),#SCRDHOR;;22$:;;	COMP.W	D3,#(2^BSHOW!2^BPROGRA)*H'100+'R;;	JUMP,NE 24$;;	LOAD.B	(A4+),#SCRMVERT;;24$:;;	COMP.W	D3,#(2^BSHOW!2^BPROGRA)*H'100+'C;;	JUMP,NE 26$;;	LOAD.B	(A4+),#SCRDVERT;;26$:;;	COMP.W	D3,#(2^BSHOW!2^BPROGRA)*H'100+DEFINE;;	JUMP,NE 30$;;	LOAD.B	(A4+),#SCRCADRE;;30$:;;	CLR.B	(A4)		; termine commande;;;;	LOAD.L	A4,#(A6)+OBUCOM	; A4 <-- ^buffer des commandes;;	TEST.B	(A4)		; au moins une commande ?;;	JUMP,EQ 90$		; non => 90$;;				; oui =>;;	LOAD.W	D6,(A6)+OCHDIS	; D6 <-- canal de l'cran;;	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre;;	.W	FOS,?COMMAND;;90$:;;	POPM.L	D3,D4,D6,A4;;	RET;--------\; _WRKEY  >;========/; Envoie une commande KEYLWRI au clavier pour simuler; le fait qu'une touche a t presse.; La commande est toujours reue dans le mme clavier o; la commande a t donne.; in	D3.L	touche + touche fonction  envoyer + pseudo code; out	D7.W	erreur; mod	D7.W_WRKEY:	PUSHM.L	D3,D6,A4	LOAD.L	A4,#(A6)+OBUCOM	; A4 <-- ^buffer pour commande	LOAD.L	(A4)+0,D3	; <pseudo> <fonction> <code>	LOAD.B	(A4)+0,#KEYLWRI	; <KEYLWRI>	CLR.B	(A4)+4		; <terminateur>	LOAD.W	D6,(A6)+OCHKEY	; D6 <-- canal clavier	LOAD.W	D3,#TYPKEY	; D3 <-- type driver clavier	FOS	?COMMAND	; envoie la commande ...	POPM.L	D3,D6,A4	RET;--------\; _WRAKEY >;========/; Envoie une commande KEYSND au clavier pour simuler; le fait qu'une touche a t presse.; La commande est reue dans le clavier actuellement assign.; in	D3.W	touche + touche fonction  envoyer; out	D7.W	erreur; mod	D7.W_WRAKEY:	PUSHM.L	D3,D6,A4	LOAD.L	A4,#(A6)+OBUCOM	; A4 <-- ^buffer pour commande	LOAD.B	(A4)+0,#KEYSND	; <KEYSND>	LOAD.B	(A4)+1,D3	; <touche>	SR.W	D3,#8	LOAD.B	(A4)+2,D3	; <fonction>	CLR.B	(A4)+3		; <terminateur>	LOAD.W	D6,(A6)+OCHKEY	; D6 <-- canal clavier	LOAD.W	D3,#TYPKEY	; D3 <-- type driver clavier	FOS	?COMMAND	; envoie la commande ...	POPM.L	D3,D6,A4	RET;--------\\; _REPKEY >;========/; Modifie les 2 dlais de tous les claviers ouverts.; in	D3.W	premier dlai (si -1 => plus de repeat);	D4.W	deuxime dlai (si D4:#15=1 => tous les claviers); out	D7.W	erreur; mod	D7.W_REPKEY:	PUSHM.L	D0,D3,D6,A0,A1,A4	LOAD.L	A4,#(A6)+OBUCOM	LOAD.B	(A4)+0,#KEYNRP	; <KEYNRP>	CLR.B	(A4)+1	COMP.W	D3,#-1	JUMP',EQ 10$	LOAD.B	(A4)+0,#KEYDRP	; <KEYDRP>	LOAD.B	(A4)+1,D3	; <d1>	LOAD.B	(A4)+2,D4	; <d2>	CLR.B	(A4)+310$:	TEST.L	D4:#15		;  tous les claviers ?	JUMP,BC 40$		; non => 40$				; oui =>	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OPUVAR	; A0 <-- ^^variables	LOAD.W	D0,#MAXUSER-120$:	TEST.B	(A0)+0:#0	; lment occup ?	JUMP',BC 30$		; non => 30$	LOAD.L	A1,(A0)+2	; A1 <-- ^variables	LOAD.W	D6,(A1)+OCHKEY	; D6 <-- canal du clavier	LOAD.W	D3,#TYPKEY	FOS	?COMMAND30$:	ADD.L	A0,#2+4		; A0 <-- ^suivant	DECJ.W,NMO D0,20$	JUMP'	50$40$:	LOAD.W	D6,(A6)+OCHKEY	; D6 <-- canal du clavier	LOAD.W	D3,#TYPKEY	FOS	?COMMAND; Il faut encore changer d'assignation de clavier pour mettre  jour; le repeat du clavier courant !50$:	CALL	_VASSKEY	; D3 <-- no clavier assign actuellement	LOAD.B	(A4)+0,#KEYASS	CLR.B	(A4)+1	LOAD.B	(A4)+2,#KEYASS	LOAD.B	(A4)+3,D3	CLR.B	(A4)+4	LOAD.W	D6,(A6)+OCHKEY	; D6 <-- canal du clavier	LOAD.W	D3,#TYPKEY	FOS	?COMMAND	POPM.L	D0,D3,D6,A0,A1,A4	CLR.W	D7		; retour EQ	RET;-----------\\; _ASSBITMAP >;===========/; Assigne le clavier  un bitmap donn.; Utilis par CLE1_CONTROL et 100_MOUSE.CODE !; in	D3.B	no du bitmap (0..3);	A2.L	^descripteur de la fentre; out	D7.W	erreur; mod	D7.W_ASSBITMAP:	PUSHM.L	D1..D4,D6,A3,A4	LOAD.B	D2,D3	ADD.B	D2,#'1		; D2 <-- '1 .. '4; Cherche si la fentre active (associe au clavier assign) correspond; au bitmap actuellement visible.	CALL	_VASSKEY	; D3 <-- no clavier assign actuellement	TEST.W	D7	JUMP,NE 40$	CALL	_SRCKEY		; D4 <-- no fentre correspondante	TEST.W	D7	JUMP,NE 40$	LOAD.L	A4,(A2)+ODFPDE	; A4 <-- ^^descripteurs	LOAD.W	D3,D4	SL.W	D3,#2	ADD.W	A4,D3	TEST.L	(A4)	JUMP,EQ 40$	LOAD.L	A3,(A4)		; A3 <-- ^descripteur fentre	COMP.B	D2,(A3)+ODFCAD+0 ; fentre utilise le mme bitmap ?	JUMP,NE 40$		; non => 40$; Si la fentre active correspond au bitmap visible, cherche la fentre; occupe suivante utilisant le mme bitmap, pour lui assigner le clavier.	LOAD.W	D1,#32-1-120$:	ADD.L	A4,#4		; A4 <-- ^^descripteur suivant	INC.W	D4	COMP.W	D4,#32	JUMP',LO 25$	LOAD.L	A4,(A2)+ODFPDE	; A4 <-- ^^descripteurs	CLR.W	D425$:	TEST.W	D4		; $DIS_0 ?	JUMP',EQ 30$		; oui => 30$	TEST.L	(A4)		; fentre utilise ?	JUMP',EQ 30$		; non => 30$	LOAD.L	A3,(A4)		; A3 <-- ^descripteur fentre suivante	COMP.B	D2,(A3)+ODFCAD+0 ; utilise le mme bitmap ?	JUMP',EQ 70$		; oui => 70$30$:	DECJ.W,NMO D1,20$; Cherche la premire fentre occupe utilisant le bitmap demand.40$:	LOAD.L	A4,(A2)+ODFPDE	; A4 <-- ^^descripteurs	LOAD.W	D4,#32-1-150$:	ADD.L	A4,#4		; A4 <-- ^^descripteur suivant	TEST.L	(A4)		; fentre utilise ?	JUMP',EQ 60$		; non => 60$	LOAD.L	A3,(A4)		; A3 <-- ^descripteur suivant	COMP.B	D2,(A3)+ODFCAD+0	JUMP',EQ 70$60$:	DECJ.W,NMO D4,50$	LOAD.W	D7,#ERDNTF	; D7 <-- driver introuvable	JUMP'	90$; Assigne le clavier  la fentre dont le ^descripteur est dans A3.70$:	CLR.W	D3	LOAD.B	D3,(A3)+ODFNOW	; D3 <-- no fentre	CALL	_SRCWDO		; D4 <-- no clavier	TEST.W	D7	JUMP',NE 90$	LOAD.W	D3,D4	CALL	_ASSKEY		; assigne le clavier90$:	POPM.L	D1..D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; _ASSKEY >;========/; Assigne le clavier  un autre processus.;  1)	Donne une commande d'assignation au clavier $KEY_1;	avec les buffers du processus appelant.;  2)	Donne une commande de centrage  la fentre utilise;	par le nouveau clavier assign.;  3)	Affiche les soft keys du nouveau processus.; in	D3.W	numro de clavier logique;		 si 2^15=1	=> effectue seulement le point 1);		 si zro	=> assigne au programme appelant; out	D7.W	erreur; mod	D7.W_ASSKEY:	PUSHM.L	D2,D3,D4,D6,A0,A3,A4,A5	LOAD.W	D2,D3		; D2 <-- flags	TCLR.L	D3:#15	TEST.W	D3		; numro connu ?	JUMP',NE 10$		; oui => 10$	LOAD.W	D3,(A6)+ONUKEY	; D3 <-- son propre clavier10$:	LOAD.W	D7,#H'8000	; !!! NUMERO !!!	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	TEST.W	(A0)+OASBLK	; appel ASSKEY bloqu ?	JUMP,NE 90$		; oui => 90$	COMP.W	D3,(A0)+OASKEY	; clavier dj assign ?	JUMP,EQ 90$		; oui => 90$	CLR.B	(A6)+OSHIFT	; plus de touches super-shift presses !	PUSH.W	D3	LOAD.W	D3,#1	CALL	SRCNKEY		; A0 <-- ^varibles de $KEY_1	POP.W	D3	CLR.B	(A0)+OSHIFT	; plus de touches super-shift presses !	LOAD.L	A4,#(A6)+OBUCOM	; A4 <-- ^buffer pour commande	LOAD.B	(A4)+0,#KEYASS	; <KEYASS>	LOAD.B	(A4)+1,D3	; <n>	CLR.B	(A4)+2		; <terminateur>	LOAD.W	D6,(A0)+OCHKEY	; D6 <-- canal clavier $KEY_1	PUSH.W	D3	LOAD.W	D3,#TYPKEY	; D3 <-- type clavier	FOS	?COMMAND	; donne commande d'assignation	POP.W	D3;;?	TEST.W	D7		; assignation ok ?;;?	JUMP,NE 90$		; non => 90$				; oui =>	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	(A0)+OASKEY,D3	; mm clavier utilis	TEST.L	D2:#15		; effectue seulement le point 1) ?	JUMP,BS 80$		; oui => 80$	CALL	SRCNKEY		; A0 <-- ^var utilisateur clav.	JUMP,NE 90$	CLR.B	(A0)+OSHIFT	; plus de touches super-shift presses !	LOAD.W	D6,(A0)+OCHDIS	; D6 <-- canal fentre	LOAD.L	A4,#(A6)+OBUCOM	; A4 <-- ^buffer pour commande	LOAD.B	(A4)+0,#SCRCENTRE ; centre la fentre	LOAD.B	(A4)+1,#SCRCOIN   ; met les "coins"	LOAD.B	(A4)+2,(A0)+ONUDIS+1	CLR.B	(A4)+3		; <terminateur>	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre	FOS	?COMMAND	; centre la fentre	LOAD.L	A5,(A0)+OSEMAM	; A5 <-- ^smaphore souris	NTREL	?RACSEM	NTREL	?SIGNAL		; dbloque RDMOUSE ...	NTREL	?RLASEM	LOAD.L	A3,#(A0)+OTXMENU ; A3 <-- ^menu mmoris	CALL	AFMENU		; mj la fentre du menu	CLR.B	D3		; D3 <-- rang soft key	LOAD.W	D4,(A0)+OMAPBAR	; D4 <-- map des barres50$:	TEST.L	D4:D3		; barre allume ?	JUMP',BC 60$		; non => 60$	TSET.L	D3:#7		; D3 <-- pour qq'un d'autre !	LIB	?INVBARRE	; remet la barre (voir *)	TCLR.L	D3:#760$:	INC.B	D3	COMP.B	D3,#16	JUMP,LO	50$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2,D3,D4,D6,A0,A3,A4,A5	RET; (*)	Il faut absolument utiliser ?INVBARRE (et non ?SETBARRE);	car il s'agit en fait de mettre les barres d'un autre;	programme (le programme appelant est vraissemblablement;	SYS_MOUSE, mais il pourrat s'agir aussi bien de n'importe;	qui d'autre).;---------\; _VASSKEY >;=========/; in	-; out	D3.W	numro du clavier ayant la "parole"; mod	D3.W, D7.W_VASSKEY:	PUSHM.L	A0	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	D3,(A0)+OASKEY	; D3 <-- no clavier	CLR.W	D7		; D7 <-- ok	POPM.L	A0	RET;---------\\; _BASSKEY >;=========/; Bloque ou dbloque l'appel LIB ?ASSKEY.; in	D3.W	0 => dbloque et 1 => bloque; out	-; mod	D7.W_BASSKEY:	PUSH.L	A0	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	(A0)+OASBLK,D3	POP.L	A0	CLR.W	D7		; retour EQ	RET; Gestion de la souris; --------------------;--------\; _MOUSE  >;========/; Signal que le programme utilise la souris. Plus prcisment,; que le programme utilise les boutons de droite et du; centre pour des fonctions internes.; in	D3.B	zro  =>  utilise la souris normalement;		deux  =>  utilise la souris par le clavier;		trois =>  idem;		autre =>  n'utilise plus la souris; out	D7.W	erreur; mod	D7.W_MOUSE:	PUSH.L	A4	LOAD.L	A4,(A6)+OPDDIS	; A4 <-- ^descripteur de la fentre	TCLR.B	(A6)+OFLAGS:#BUSEMO	TCLR.B	(A6)+OFLAGS:#BKEYMO	LOAD.B	(A6)+OMOUSE,D3	TEST.B	D3	JUMP',EQ 20$	COMP.B	D3,#2	JUMP',EQ 10$	COMP.B	D3,#3	JUMP',NE 90$10$:	TSET.B	(A6)+OFLAGS:#BKEYMO20$:	TSET.B	(A6)+OFLAGS:#BUSEMO90$:	POP.L	A4	RET;--------\\; _GMOUSE >;========/; Rend la valeur donne par ?MOUSE.; in	-; out	D3.W	valeur donne par ?MOUSE; mod	D3.W, D7.W_GMOUSE:	CLR.W	D3	LOAD.B	D3,(A6)+OMOUSE	CLR.W	D7		; D7 <-- ok	RET;-----------\\; _WAITMOUSE >;===========/; Signal  SYS_MOUSE.CODE s'il faut dessiner une autre flche-lutin; pour indiquer une attente.; in	D4.W	0 => attente; out	-; mod	D7.W_WAITMOUSE:	PUSH.L	A4	LOAD.L	A4,(A6)+OPDDIS	; A4 <-- ^descripteur de la fentre	TEST.W	D4	JUMP',NE 50$	TSET.B	(A4)+ODFFLG:#BFWMOU	JUMP'	90$50$:	TCLR.B	(A4)+ODFFLG:#BFWMOU90$:	POP.L	A4	RET;---------\; _PXMOUSE >;=========/; Positionne la souris en X seulement, relativement  la; fentre utilise par le processus.; in	D4.W	coordonne X; out	D7.W	erreur; mod	D7.W_PXMOUSE:	COMP.W	D4,#H'AAAA	; demande la rvision ?	JUMP,EQ _GETREV		; oui => _GETREV				; non =>	.IF	PMOUSE	PUSHM.L	D3,D4,D6,A0,A4	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	COMP.W	D4,(A6)+ODISDX	JUMP',HS 90$	ADD.W	D4,(A6)+ODISOX	; D4 <-- coordonne absolue	LOAD.L	A4,#(A6)+OBUMOU+1	LOAD.B	(A4)+0,#MOUPOX	LOAD.W	(A4)+1,D4	CLR.B	(A4)+3	LOAD.W	D3,#TYPIO	LOAD.W	D6,(A0)+OCHMOU	; D6 <-- canal souris	FOS	?COMMAND90$:	POPM.L	D3,D4,D6,A0,A4	.ELSE	CLR.W	D7		; D7 <-- ok !	.ENDIF	RET;---------\; _PYMOUSE >;=========/; Positionne la souris en Y seulement, relativement  la; fentre utilise par le processus.; in	D4.W	coordonne Y; out	D7.W	erreur; mod	D7.W_PYMOUSE:	COMP.W	D4,#H'AAAA	; demande la rvision ?	JUMP,EQ _GETREVL	; oui => _GETREVL				; non =>	.IF	PMOUSE	PUSHM.L	D3,D4,D6,A0,A4	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	COMP.W	D4,(A6)+ODISDY	JUMP',HS 90$	ADD.W	D4,(A6)+ODISOY	; D4 <-- coordonne absolue	LOAD.L	A4,#(A6)+OBUMOU+1	LOAD.B	(A4)+0,#MOUPOY	LOAD.W	(A4)+1,D4	CLR.B	(A4)+3	LOAD.W	D3,#TYPIO	LOAD.W	D6,(A0)+OCHMOU	; D6 <-- canal souris	FOS	?COMMAND90$:	POPM.L	D3,D4,D6,A0,A4	.ELSE	CLR.W	D7		; D7 <-- ok !	.ENDIF	RET;--------\\; _GETREV >;========/; Donne le numro de rvision du systme.; in	-; out	D4.W	15..8 = rvision, 7..0 = version;	D7.W	erreur; mod	D0..A1, D4.W, D7.W_GETREV:	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	D4,(A0)+OSYREV	; D4 <-- rvision/version	CLR.W	D7		; retour EQ	RET;---------\\; _GETREVL >;=========/; Donne le numro de rvision de la librairie.; in	-; out	D4.W	15..8 = rvision, 7..0 = version;	D7.W	erreur; mod	D0..A1, D4.W, D7.W_GETREVL:	LOAD.W	D4,#H'100*LIBREV+LIBVERS	CLR.W	D7		; retour EQ	RET;---------\; _RDMOUSE >;=========/; Lit la souris, avec bloquage si le clavier n'est pas; assign au processus voulant lire la souris, ou si la; souris ne bouge pas.; Lorsque le curseur n'est pas dans la fentrre, l'erreur; ERDIOUT est rendue, et D4.L contient les coordonnes absolues; dans le bitmap 1024 x 1024.; in	-; out	D4.L	coordonne;	D3.B	boutons;	D7.W	erreur; mod	D3.W, D4.L, D7.W_RDMOUSE:	PUSHM.L	D0,A0,A3,A4,A5	LOAD.W	D4,#1;;?	CALL	_WAITMOUSE	; remet la souris normale	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	D4,(A0)+OASKEY	; D3 <-- numro du clavier	COMP.W	D4,(A6)+ONUKEY	; utilis actuellement ?	JUMP',EQ 50$		; oui => 50$				; non =>	NTREL	?GETTIM		; D4 <-- timeout actuel	LOAD.W	D3,D4		; D3 <-- timeout actuel	LOAD.W	D4,#-1	NTREL	?SETTIM		; init timeout infini (!)	LOAD.L	A5,(A6)+OSEMAM	; A5 <-- ^smaphore souris	NTREL	?RACSEM	NTREL	?SWAIT		; attend ...	NTREL	?RLASEM	LOAD.W	D4,D3	NTREL	?SETTIM		; remet timeout utilisateur50$:	LOAD.L	A5,(A0)+OSEMAC	; A5 <-- ^smaphore	NTREL	?RACSEM	NTREL	?SWAIT		; attend que la souris bouge	PUSH.W	D7	NTREL	?RLASEM	POP.W	D7	JUMP',NE 90$		; si timeout => 90$	CALL	_IFMOUSE	; D3/D4 <-- boutons/position90$:	POPM.L	D0,A0,A3,A4,A5	RET;----------\; _IFMOUSE  >;==========/; Identique  ?RDMOUSE, mais sans attendre.; in	-; out	D4.L	coordonne;	D3.B	boutons;	D7.W	erreur; mod	D3.W, D4.L, D7.W_IFMOUSE:	PUSHM.L	D0,A0	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	D4,(A0)+OSOPOS	; D4 <-- dernire position	LOAD.B	D3,(A0)+OSOKEY+1 ; D3 <-- dernier tat boutons	LOAD.W	D7,#ERDIOUT	; D7 <-- "out of screen"	LOAD.W	D0,(A6)+ODISOX	; D0 <-- X minimum	COMP.W	D4,D0	JUMP',LO 60$	ADD.W	D0,(A6)+ODISDX	; D0 <-- X maximum	COMP.W	D4,D0	JUMP',HS 60$	SWAP.W	D4		; D4 <-- (X;Y)	LOAD.W	D0,(A6)+ODISOY	; D0 <-- Y minimum	COMP.W	D4,D0	JUMP',LO 50$	ADD.W	D0,(A6)+ODISDY	; D0 <-- Y maximum	COMP.W	D4,D0	JUMP',HS 50$	SWAP.W	D4		; D4 <-- (Y;X)	SUB.W	D4,(A6)+ODISOX	; D4 <-- coordonne X relative	SWAP.W	D4		; D4 <-- (X;Y)	SUB.W	D4,(A6)+ODISOY	; D4 <-- coordonne Y relative	CLR.W	D7		; D7 <-- ok50$:	SWAP.W	D4		; D4 <-- (Y;X)60$:	TEST.W	D4	JUMP',NC 70$	CLR.W	D470$:	SWAP.W	D4	TEST.W	D4	JUMP',NC 80$	CLR.W	D480$:	SWAP.W	D4	POPM.L	D0,A0	RET;--------\\; _PMOUSE >;========/; Positionne la souris.; in	D4.L	nouvelle position (y;x); out	D7.W	erreur; mod	D7.W_PMOUSE:	PUSHM.L	D3,D4,D6,A0,A1,A4	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A1,(A6)+OPDDIS	; A1 <-- ^descripteur de la fentre; Ramne la position dans la fentre si elle en sort.	TEST.W	D4		; trop  gauche ?	JUMP',NC 10$	CLR.W	D410$:	COMP.W	D4,(A1)+ODFDX	; trop  droite ?	JUMP',LT 15$	LOAD.W	D4,(A1)+ODFDX	DEC.W	D415$:	SWAP.W	D4	TEST.W	D4		; trop en haut ?	JUMP',NC 20$	CLR.W	D420$:	COMP.W	D4,(A1)+ODFDY	; trop en bas ?	JUMP',LT 25$	LOAD.W	D4,(A1)+ODFDY	DEC.W	D425$:	SWAP.W	D4; Calcule la position absolue par rapport aux crans virtuels.	.IF	COLOR	ADD.W	D4,(A0)+OVSPOS+2	SWAP.W	D4	ADD.W	D4,(A0)+OVSPOS+0	SWAP.W	D4	.ENDIF; Calcul la position absolue dans le grand bitmap $DIS_0.	ADD.W	D4,(A1)+ODFX	SWAP.W	D4	ADD.W	D4,(A1)+ODFY	SWAP.W	D4		; D4 <-- position dans $DIS_0 !; Envoie la commande secrte et mystrieuse de positionnement. 	LOAD.L	A4,#(A6)+OBUCOM+1	LOAD.B	(A4)+0,#'P	; <P>	LOAD.L	(A4)+1,D4	; <yy> <xx>	CLR.B	(A4)+5	LOAD.W	D3,#TYPIO	; D3 <-- type du driver souris	LOAD.W	D6,(A0)+OCHMOU	; D6 <-- canal de la souris	FOS	?COMMAND	; positionne la souris ...	POPM.L	D3,D4,D6,A0,A1,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; _PPMOUSE >;=========/; Indique la position et les dimensions de l'cran virtuel;  la librairie.; ATTENTION: rserv  100_MOUSE.CODE !; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.W_PPMOUSE:	.IF	COLOR	PUSH.L	A0	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	(A0)+OVSPOS,D3	LOAD.L	(A0)+OVSDIM,D4	POP.L	A0	.ENDIF	RET;-----------\; _MRDMOUSE  >;===========/; Lit la souris, en attendant si elle ne bouge pas.; in	-; out	A3.L	^tat de la souris,  savoir:;		coordonne Y;		coordonne X;		boutons master;		boutons user; mod	D7.W, A4.L_MRDMOUSE:	PUSHM.L	D3,D4,D6,A0,A4,A5	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A4,#(A6)+OBUMOU	LOAD.L	D4,#4+1	LOAD.W	D6,(A0)+OCHMOU	; D6 <-- canal souris	FOS	?RDBYTE	JUMP',NE 90$	LOAD.L	A3,#(A0)+OSOPOS	LOAD.W	(A3)+0,(A4)+2	; mm Y	LOAD.W	(A3)+2,(A4)+0	; mm X	LOAD.B	(A3)+4,(A4)+4	; mm boutons	LOAD.L	A5,(A0)+OSEMAC	NTREL	?RACSEM	NTREL	?SSIGNAL	; signal souris bouge	NTREL	?RLASEM90$:	POPM.L	D3,D4,D6,A0,A4,A5	RET	.END