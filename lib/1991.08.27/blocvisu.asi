	.SBTTL	BLOCVISU.ASIARDX	=	12		; flche: 1/2 largeurARDY	=	18		; flche: 1/4 hauteur;-----------\\; _BLOC_VISU >;===========/; Visualisation du bloc-notes, et transferts ventuels avec le classeur.; Les touches fonctions devront tre redessines.; in	D2.W	mode d'ouverture de la dbox;	D3.L	position (si D2:#BDBMOU); out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.W_BLOC_VISU:	PUSHM.L	D0..D2,D4,D5,A0..A6	CALL	OPENVAR		; A6 <-- ^variables globales	JUMP,NE EXIT$	TEST.W	(A6)+OVNBUSE	; premire utilisation ?	JUMP',EQ FIRST$		; oui => FIRST$	PUSH.W	D3	LOAD.W	D3,#BIPERR	LIB	?BEEP	POP.W	D3	LOAD.L	A3,#R16"TERROR$	DBOX_	TERROR		; affiche l'erreur ...	LOAD.W	D3,#F0	JUMP	QUIT$FIRST$:	INC.W	(A6)+OVNBUSE	; une utilisation de plus	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	LOAD.L	A2,#R16"TDBOX_VISU	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	LOAD.L	(A6)+OVBNPOS,D3	LOAD.W	D2,#11!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A6)+OVBNPOS+2	SWAP.W	D3	SUB.W	D3,(A6)+OVBNPOS+0	SWAP.W	D3	LOAD.L	(A6)+OVBNDIM,D3	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OVBNPOS	LOAD.W	D2,#SETDOT	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LIB	?DRRECT	SUB.W	D3,#3	SWAP.W	D3	SUB.W	D3,#3	SWAP.W	D3	ADD.W	D4,#6	SWAP.W	D4	ADD.W	D4,#6	SWAP.W	D4	LIB	?DRRECT	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO	LOAD.L	(A6)+OVCLPOS,D3	LOAD.W	D2,#21!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A6)+OVCLPOS+2	SWAP.W	D3	SUB.W	D3,(A6)+OVCLPOS+0	SWAP.W	D3	LOAD.L	(A6)+OVCLDIM,D3	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OVCLPOS	LOAD.W	D2,#SETDOT	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LIB	?DRRECT	LOAD.W	D1,#4	CALL	VISUOMBRE	ADD.W	D3,D1	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D3	CALL	VISUOMBRE	CLR.W	D1	CALL	VISUADRAW	; dessine la flche ->	INC.W	D1	CALL	VISUADRAW	; dessine la flche <-	LOAD.L	A5,#(A6)+OSCVAR	; A5 <-- ^variables ascenseur	LOAD.W	D2,#30!2^BDBGCLABEL	DBOX_	GETCO	LOAD.W	(A6)+OSCVAR+OSCDEBL,D3	SWAP.W	D3	LOAD.W	(A6)+OSCVAR+OSCDEBO,D3	LOAD.W	D2,#31!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A6)+OSCVAR+OSCDEBO	ADD.W	D3,(A0)+ODFC2Y	ADD.W	D3,#3	LOAD.W	(A6)+OSCVAR+OSCHTR,D3;	CLR.B	(A6)+OSCVAR+OSCHOR	LOAD.W	(A6)+OSCVAR+OSCINC,#1	SCROLL_	DRAW		; dessine l'ascenseur vide	CALL	DISKCOUNT	; mj OSCHTV si ncessaireUPDATE$:	COMP.W	(A6)+OSCVAR+OSCHTV,#1	JUMP',LS UPDBN$	SCROLL_	UPDATE		; dessine l'ascenseur plein	CALL	VISUSCNUM	; dessine le numro dans la cabineUPDBN$:	LOAD.W	D2,#-3	LOAD.L	D3,(A6)+OVBNPOS	LOAD.L	D4,(A6)+OVBNDIM	CALL	VISUPADRAW	; dessine le bloc-notes	CLR.W	(A6)+OBNMOD	; bloc-notes  jourUPDCL$:	LOAD.W	D2,(A6)+OSCVAR+OSCPOSV	LOAD.L	D3,(A6)+OVCLPOS	LOAD.L	D4,(A6)+OVCLDIM	CALL	VISUPADRAW	; dessine le classeur	CALL	VISUPANB	; affiche le nombre de pagesLOOP$:	CALL	NORMMOUSE	; enlve le sablierLOOP2$:	LOAD.W	D4,#50	NTREL	?SETTIM	DBOX_	EDIT		; attend une action ...	LOAD.W	D4,#-1	NTREL	?SETTIM	TEST.W	D3	JUMP',EQ TIMO$	LOAD.L	A1,#R16"TKEY_VISU	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#DEL	JUMP,EQ DEL$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$TIMO$:	TEST.W	(A6)+OBNMOD	; bloc-notes modifi ?	JUMP,EQ LOOP2$		; non => LOOP2$	CLR.W	(A6)+OBNMOD	; bloc-notes  jour	JUMP	UPDATE$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	CALL	VISUAMOVE	; action dans une flche ...	JUMP',EQ ARROW$	COMP.W	(A6)+OSCVAR+OSCHTV,#1 ; ascenseur actif ?	JUMP,LS BIP$		; non => BIP$	SCROLL_	MOVE		; dplace l'ascenseur ...	JUMP,NE BIP$	CALL	VISUSCNUM	; dessine le numro dans la cabine	JUMP	UPDCL$ARROW$:				; clic dans flche =>	COMP.W	D1,#1	JUMP',EQ LEFT$	TEST.W	D1	JUMP,NE LOOP$RIGHT$:				; ->	COMP.W	(A6)+OSCVAR+OSCHTV,#99-1	JUMP,HS BIP$	LOAD.W	D3,(A6)+OSCVAR+OSCHTV	CALL	XFERWRITE	; bloc-notes --> fichier	JUMP,NE BIP$	LOAD.W	(A6)+OSCVAR+OSCPOSV,(A6)+OSCVAR+OSCHTV	INC.W	(A6)+OSCVAR+OSCHTV	COMP.W	(A6)+OSCVAR+OSCHTV,#1	JUMP,LS UPDCL$	SCROLL_	UPDATE		; mj l'ascenseur	CALL	VISUSCNUM	; dessine le numro dans la cabine	JUMP	UPDCL$LEFT$:				; <-	LOAD.W	D3,(A6)+OSCVAR+OSCPOSV	CALL	XFERREAD	; bloc-notes <-- fichier	JUMP,NE BIP$	LOAD.W	D2,#-3	LOAD.L	D3,(A6)+OVBNPOS	LOAD.L	D4,(A6)+OVBNDIM	CALL	VISUPADRAW	; dessine le bloc-notes	CLR.W	(A6)+OBNMOD	; bloc-notes  jour	JUMP	LOOP$DEL$:				; supprime page =>	TEST.W	(A6)+OSCVAR+OSCHTV	JUMP,EQ BIP$	LOAD.W	D3,(A6)+OSCVAR+OSCPOSV	CALL	XFERDEL		; supprime une page	TEST.W	(A6)+OSCVAR+OSCHTV	JUMP',EQ DEL3$	COMP.W	D3,(A6)+OSCVAR+OSCHTV	JUMP',NE DEL3$	DEC.W	(A6)+OSCVAR+OSCPOSVDEL3$:	COMP.W	(A6)+OSCVAR+OSCHTV,#1	JUMP',LS DEL6$	SCROLL_	UPDATE		; dessine l'ascenseur plein	CALL	VISUSCNUM	; dessine le numro dans la cabine	JUMP	UPDCL$DEL6$:	SCROLL_	DRAW		; dessine l'ascenseur vide	JUMP	UPDCL$OK$:END$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	CLR.W	(A6)+OVNBUSE	; plus d'utilisationQUIT$:	POPM.L	D0..D2,D4,D5,A0..A6	TEST.W	D7		; retour EQ/NE	RETTERROR$:	.ASCII	"Le classeur ne peut pas tre<CR>"	.ASCII	"ouvert, car il est dj utilis<CR>"	.ASCII	"dans une autre fentre !"	.B	0	.EVEN;----------\\; VISUSCNUM >;==========/; Affiche le numro dans l'ascenseur.; in	-; out	-; mod	D7.WVISUSCNUM:	PUSHM.L	D3,D4	LOAD.W	D4,(A6)+OSCVAR+OSCDEBO	ADD.W	D4,(A6)+OSCVAR+OSCPOSR	ADD.W	D4,#LGSCROLL+LGSCROLL/2	SWAP.W	D4	LOAD.W	D4,(A6)+OSCVAR+OSCDEBL	ADD.W	D4,#LGSCROLL/2	LOAD.W	D3,(A6)+OSCVAR+OSCPOSV	INC.W	D3		; D3 <-- page (1..n)	CALL	NUMCHIFFRE	POPM.L	D3,D4	RET;----------\\; VISUAMOVE >;==========/; Action dans une flche.; in	D4.L	position de la souris (y;x); out	D1.W	rang (0,1);	D7.W	erreur; mod	D1.L, D7.WVISUAMOVE:	PUSHM.L	D2..D4	CALL	VISUADET	; D1 <-- flche clique	JUMP',NE EXIT$	CALL	VISUAINV	; allume la flche	LOAD.W	D2,D1LOOP$:	LIB	?GETKEY		; attend dplacement souris ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	VISUADET	; D1 <-- flche montre	COMP.W	D1,D2		; toujours la mme ?	JUMP,EQ LOOP$		; oui => LOOP$	EX.L	D1,D2	CALL	VISUAINV	; teint la flche	LOAD.W	D1,D2	CALL	VISUAINV	; allume la flche	JUMP	LOOP$END$:	LOAD.W	D1,D2	CALL	VISUAINV	; teint la flche	LOAD.W	D7,#1	COMP.W	D1,#2	JUMP',HS EXIT$	CLR.W	D7EXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; VISUADET >;=========/; Dtecte dans quelle flche est la souris.; in	D4.L	position de la souris (y;x); out	D1.W	rang (0,1);	D7.W	erreur; mod	D1.L, D7.WVISUADET:	PUSHM.L	D0,D2..D4,A4	LOAD.W	D0,D4	LOAD.L	D2,D4	SWAP.W	D2	CLR.W	D1LOOP$:	CALL	VISUAPOS	; D3/D4/A4 <-- position/dimensions/^motif	JUMP',NE EXIT$	SUB.W	D3,#2	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	ADD.W	D4,#2+2	SWAP.W	D4	ADD.W	D4,#2+2	SWAP.W	D4	COMP.W	D3,D0	JUMP',HI NEXT$	ADD.W	D3,D4	COMP.W	D3,D0	JUMP',LO NEXT$	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D2	JUMP',HI NEXT$	ADD.W	D3,D4	COMP.W	D3,D2	JUMP',HS EXIT$NEXT$:	INC.W	D1	JUMP	LOOP$EXIT$:	POPM.L	D0,D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; VISUAINV >;=========/; Inverse une flche.; in	D1.W	rang (0,1); out	-; mod	D7.WVISUAINV:	PUSHM.L	D2..D4,A4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	VISUAPOS	; D3/D4/A4 <-- position/dimensions/^motif	JUMP',NE EXIT$	SUB.W	D3,#2	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	ADD.W	D4,#2+2	SWAP.W	D4	ADD.W	D4,#2+2	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse une flcheEXIT$:	POPM.L	D2..D4,A4	RET;----------\\; VISUADRAW >;==========/; Dessine une flche.; in	D1.W	rang (0,1); out	-; mod	D7.WVISUADRAW:	PUSHM.L	D2..D4,A4	CALL	VISUAPOS	; D3/D4/A4 <-- position/dimensions/^motif	LOAD.W	D2,#SETDOT	CALL	VISUMOTIF	; dessine une flche	POPM.L	D2..D4,A4	RET;---------\\; VISUAPOS >;---------/; Donne la position d'une flche.; in	D1.W	rang (0,1); out	D3.L	position (y;x);	D4.L	dimensions (y;x);	A4.L	^motif; mod	D3.L, D4.L, D7.W, A4.LVISUAPOS:	LOAD.W	D7,#1	COMP.W	D1,#2	JUMP',HS EXIT$	LOAD.W	D3,(A6)+OVBNPOS+2	ADD.W	D3,(A6)+OVBNDIM+2	ADD.W	D3,(A6)+OVCLPOS+2	SR.W	D3,#1	SUB.W	D3,#ARDX-1	LOAD.L	D4,#H'10000*(ARDY*4)+(ARDX*2)	TEST.W	D1	JUMP',NE LEFT$RIGHT$:	SWAP.W	D3	LOAD.W	D3,(A6)+OVBNPOS+0	SWAP.W	D3	LOAD.L	A4,#R16"TARRIGHT	JUMP'	OK$LEFT$:	SWAP.W	D3	LOAD.W	D3,(A6)+OVBNPOS+0	ADD.W	D3,(A6)+OVBNDIM+0	SUB.W	D3,#ARDY*4	SWAP.W	D3	LOAD.L	A4,#R16"TARLEFTOK$:	CLR.W	D7		; D7 <-- okEXIT$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; VISUMOTIF >;==========/; Dessine un petit motif constitu de droites.; in	A4.L	^motif;	D3.L	position (y;x); out	-; mod	D7.WVISUMOTIF:	PUSHM.L	D3,D4,A4	SWAP.W	D3	ADD.W	D3,(A4+)	SWAP.W	D3	ADD.W	D3,(A4+)LOOP$:	LOAD.L	D4,(A4+)	JUMP',EQ EXIT$	LIB	?DRSEG	JUMP	LOOP$EXIT$:	POPM.L	D3,D4,A4	RETTARRIGHT:	.W	0,+ARDX	.W	+ARDY*2,+ARDX	.W	+ARDY*2,-ARDX	.W	-ARDY,0	.W	0,-ARDX	.W	-ARDY*2,0	.W	0,+ARDX	.W	-ARDY,0	.W	0,0TARLEFT:	.W	+ARDY*4,+ARDX	.W	-ARDY*2,-ARDX	.W	-ARDY*2,+ARDX	.W	+ARDY,0	.W	0,+ARDX	.W	+ARDY*2,0	.W	0,-ARDX	.W	+ARDY,0	.W	0,0;----------\\; VISUOMBRE >;==========/; Dessine l'ombre d'un rectangle.; in	D2.W	mode de dessin;	D3.L	position (y;x);	D4.L	dimensions (y;x);	D1.W	paisseur; out	-; mod	D7.WVISUOMBRE:	PUSHM.L	D0..D4	LOAD.L	D0,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SWAP.W	D4	SWAP.W	D3	ADD.W	D3,D1	LOAD.W	D4,D1	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	CLR.L	D4	LOAD.W	D4,D0	LIB	?DRSEG	LOAD.L	D4,D0	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	CLR.L	D4	LOAD.W	D4,D1	NEG.W	D4	LIB	?DRSEG	POPM.L	D0..D4	RET;-----------\\; VISUPADRAW >;===========/; Affiche le contenu du bloc-notes.; in	D2.W	page (-3,0..n);	D3.L	position (y;x);	D4.L	dimensions (y;x); out	-; mod	D7.WVISUPADRAW:	PUSHM.L	D1..D4,A3,A4	CALL	VISUCLEAR	; efface l'emplacement	CALL	IMAGEOPEN	; A4 <-- ^image	JUMP',NE TEXT$	CALL	IMAGESHOW	; affiche l'image	CALL	IMAGECLOSE	; libre l'image	JUMP'	TYPE$TEXT$:	CALL	TEXTOPEN	; A4 <-- ^texte	JUMP',NE ERROR$	CALL	TEXTSHOW	; affiche le texte	CALL	TEXTCLOSE	; libre le texte	JUMP'	TYPE$ERROR$:	CALL	VISUERROR	; met une grande croixTYPE$:	LOAD.L	D1,(A0)+ODFGCF	LOAD.B	D1,#USEGC	RR.L	D1,#8	PUSH.L	D1		; stack <-- <USEGC><F><S><T> initial	LIB	?AFTIM	.B	LOADGC,'N,'E!2^7,07	.B	USEGC,'N,'E!2^7,07 ; utilise le gencar NEF07	.B	0	.EVEN	ADD.W	D3,#5	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	ADD.W	D3,#14	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.B	MSPACE,38,0	.EVEN	LIB	?SETCURS	LOAD.L	A4,#(A6)+OBUFF	LOAD.L	D4,#LBUFF	LOAD.W	D3,D2		; D3 <-- pyge (-3,0..n)	CALL	RDLIST		; A3/D3 <-- ^logiciel/type initiateur	JUMP',NE END$	LIB	?AFTEXT		; affiche le nom du logiciel	LIB	?AFTIM	.ASCIZ	": "	.EVENTLOOP$:	LOAD.L	D3,(A4)		; D3 <-- type	JUMP',EQ END$	CALL	VISUTYPE	; affiche un type	TEST.L	(A4)+4	JUMP',EQ TNEXT$	LOAD.B	D3,#',	LIB	?AFCARTNEXT$:	ADD.L	A4,#4	JUMP	TLOOP$END$:	LOAD.L	A3,SP		; A3 <-- ^<USEGC><F><S><T>	LOAD.W	D3,#4	LIB	?STRING		; remet le gencar initial	POP.L	D4		; ajuste le stack	POPM.L	D1..D4,A3,A4	RET;---------\\; VISUTYPE >;---------/; Affiche un type.; in	D3.L	type; out	-; mod	D7.WVISUTYPE:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#R16"IMAG$	COMP.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	JUMP',EQ STR$	LOAD.L	A3,#R16"TEXT$	COMP.L	D3,#H'1000000*'T+H'10000*'E+H'100*'X+H'1*'T	JUMP',EQ STR$	LOAD.L	A3,#R16"COLO$	COMP.L	D3,#H'1000000*'C+H'10000*'O+H'100*'L+H'1*'O	JUMP',EQ STR$	LOAD.L	A3,#R16"AUDI$	COMP.L	D3,#H'1000000*'A+H'10000*'U+H'100*'D+H'1*'I	JUMP',EQ STR$	LOAD.L	A3,#R16"FICH$	COMP.L	D3,#H'1000000*'F+H'10000*'I+H'100*'C+H'1*'H	JUMP',EQ STR$	LOAD.W	D4,#4-1LOOP$:	RL.L	D3,#8	TEST.B	D3	JUMP',EQ NEXT$	COMP.B	D3,#SPACE	JUMP',EQ NEXT$	LIB	?AFCODENEXT$:	DECJ.W,NMO D4,LOOP$	JUMP'	EXIT$STR$:	LIB	?AFTEXTEXIT$:	POPM.L	D3,D4,A3	RETIMAG$:	.ASCIZ	"IMAGE"TEXT$:	.ASCIZ	"TEXTE"COLO$:	.ASCIZ	"COULEUR"AUDI$:	.ASCIZ	"AUDIO"FICH$:	.ASCIZ	"FICHE"	.EVEN;---------\\; VISUPANB >;=========/; Affiche le nombre de pages.; in	-; out	-; mod	D7.WVISUPANB:	PUSHM.L	D2..D4	LOAD.W	D2,#50!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A6)+OSCVAR+OSCHTV ; D4 <-- nb de pages	JUMP',NE FULL$	LIB	?AFTIM	.ASCIZ	"(vide)<EFLI>"	.EVEN	JUMP'	EXIT$FULL$:	LIB	?AFTIM	.ASCIZ	"("	.EVEN	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" feuille"	.EVEN	COMP.W	D4,#1	JUMP',LS FEND$	LIB	?AFTIM	.ASCIZ	"s"	.EVENFEND$:	LIB	?AFTIM	.ASCIZ	")<EFLI>"	.EVENEXIT$:	POPM.L	D2..D4	RET;----------\\; VISUCLEAR >;==========/; Efface un emplacement.; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WVISUCLEAR:	PUSH.W	D2	PUSHM.L	D3,D4	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	POP.W	D2	RET;----------\\; VISUERROR >;==========/; Affiche une erreur (grande croix).; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WVISUERROR:	PUSHM.L	D2..D4	LOAD.W	D2,#SETDOT	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	ADD.W	D3,D4	DEC.W	D3	NEG.W	D4	LIB	?DRSEG	POPM.L	D2..D4	RET;----------\\; IMAGEOPEN >;==========/; Lit une image dans le bloc-notes.; in	D2.W	page (-3,0..n); out	A4.L	^image (en-tte);	D7.W	erreur; mod	D7.W, A4.LIMAGEOPEN:	PUSHM.L	D0..D4,A1..A3	LOAD.W	D4,D2	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	CALL	RDOPEN		; ouvre le bloc-notes	JUMP,NE EXIT$	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE CLOSE$	LOAD.L	A2,A4		; A2 <-- ^en-tte;	LOAD.L	A4,A2;	LOAD.L	D4,#LGHIMA	BLOC_	RDDATA		; lit l'en-tte	JUMP,NE GIVHEAD$	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	LOAD.W	D4,D0	ADD.W	D4,#8-1	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF+4	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE GIVHEAD$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	(A2)+LGHIMA-4,A1	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE CODE$		; oui => CODE$				; non =>	LOAD.L	A4,A1	BLOC_	RDDATA		; lit toute l'image dcode	JUMP',NE GIVDATA$	JUMP'	OK$CODE$:	BLOC_	RDDATA		; lit toute l'image code	JUMP',NE GIVDATA$	LOAD.L	A3,A1	GRA_	DECOIMA		; dcode l'image ...	JUMP',NE GIVDATA$OK$:	LOAD.L	A4,A2		; A4 <-- ^en-tte	JUMP'	CLOSE$GIVDATA$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D7GIVHEAD$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'en-tte	POP.W	D7CLOSE$:	PUSH.W	D7	BLOC_	RDCLOSE		; ferme le bloc-notes	POP.W	D7EXIT$:	POPM.L	D0..D4,A1..A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGESHOW >;==========/; Affiche une image quelconque.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie centrale.; in	A4.L	^image;	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WIMAGESHOW:	PUSHM.L	D1..D5,A2..A4	CALL	CCMO		; enlve la souris	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.L	A3,(A2)+LGHIMA-4 ; A3 <-- ^data	LOAD.L	D2,D4		; D2 <-- dimensions	LOAD.L	D4,D3		; D4 <-- origine (destination)	CLR.L	D3		; D3 <-- origine (source)	COMP.W	D2,(A2)+OIMDLX	; image trop large ?	JUMP',LO OUTX$		; oui => OUTX$	SUB.W	D2,(A2)+OIMDLX	SR.W	D2,#1	ADD.W	D4,D2	LOAD.W	D2,(A2)+OIMDLX	JUMP'	DIMX$OUTX$:	LOAD.W	D1,(A2)+OIMDLX	SUB.W	D1,D2	SR.W	D1,#1	ADD.W	D3,D1DIMX$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	COMP.W	D2,(A2)+OIMDLY	; image trop haute ?	JUMP',LO OUTY$		; oui => OUTY$	SUB.W	D2,(A2)+OIMDLY	SR.W	D2,#1	ADD.W	D4,D2	LOAD.W	D2,(A2)+OIMDLY	JUMP'	DIMY$OUTY$:	LOAD.W	D1,(A2)+OIMDLY	SUB.W	D1,D2	SR.W	D1,#1	ADD.W	D3,D1DIMY$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D5,(A2)+OIMDLX	ADD.W	D5,#8-1	SR.W	D5,#3		; D5 <-- Iy de l'image	LOAD.L	A4,#0		; A4 <-- destination (cran)	LOAD.W	D1,#LOADDOT	; D1 <-- mode	LOAD.L	A2,A0		; A2 <-- ^descripteur	GRA_	RASTER		; affiche l'image	CALL	SCMO		; remet la souris	POPM.L	D1..D5,A2..A4	RET;-----------\\; IMAGECLOSE >;===========/; Ferme une image.; in	A4.L	^image; out	-; mod	D7.WIMAGECLOSE:	PUSHM.L	D1,A3,A4	LOAD.L	A3,A4	LOAD.L	A4,(A3)+LGHIMA-4	LOAD.L	A4,#(A4)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	LOAD.L	A4,A3;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'en-tte	POPM.L	D1,A3,A4	RET;---------\\; TEXTOPEN >;=========/; Lit un texte dans le bloc-notes.; in	D2.W	page (-3,0..n); out	A4.L	^texte;	D7.W	erreur; mod	D7.W, A4.LTEXTOPEN:	PUSHM.L	D1,D3,D4,A3	LOAD.W	D4,D2	LOAD.L	D3,#H'1000000*'T+H'10000*'E+H'100*'X+H'1*'T	CALL	RDOPEN		; ouvre le bloc-notes	JUMP',NE EXIT$	LOAD.L	D4,#12*40	; D4 <-- 12 lignes de 40 caractres au maximum !	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire du texte	JUMP',NE CLOSE$	DEC.L	D4	BLOC_	RDDATA		; lit le dbut du texte	CLR.B	(A4)+(D4.L)	; met un terminateur	LOAD.L	A3,A4FILTRE$:	LOAD.B	D3,(A3)	JUMP',EQ OK$	CALL	_BLOC_CAR87	; D3 <-- caractre < 128	LOAD.B	(A3+),D3	JUMP	FILTRE$OK$:	CLR.W	D7		; D7 <-- okCLOSE$:	PUSH.W	D7	BLOC_	RDCLOSE		; ferme le bloc-notes	POP.W	D7EXIT$:	POPM.L	D1,D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; TEXTSHOW >;=========/; Affiche un texte quelconque.; in	A4.L	^texte;	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WTEXTSHOW:	PUSHM.L	D0..D4,A3,A4	ADD.W	D3,#4	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	SUB.W	D4,#4+1	SWAP.W	D4	SUB.W	D4,#4+1	SWAP.W	D4	LOAD.L	D2,D3		; D2 <-- position	LOAD.L	D3,(A0)+ODFGCF	LOAD.B	D3,#USEGC	RR.L	D3,#8	PUSH.L	D3		; stack <-- <USEGC><F><S><T> initial	LIB	?AFTIM	.B	LOADGC,'N,'E!2^7,07	.B	USEGC,'N,'E!2^7,07 ; utilise le gencar NEF07	.B	0	.EVEN	CLR.L	D0	LOAD.W	D0,D4	DIV.WU	D0,(A0)+ODFCX	; D0 <-- nb car/ligne	LOAD.L	D1,D4	CLR.W	D1	SWAP.W	D1	DIV.WU	D1,(A0)+ODFCY	; D1 <-- nb lignes	ADD.W	D2,(A0)+ODFC1X	SWAP.W	D2	ADD.W	D2,(A0)+ODFC1Y	SWAP.W	D2LOOP$:	LOAD.L	D3,D2	LIB	?SETCURS	; positionne au dbut de la ligne	LOAD.L	A3,A4	CLR.W	D4CNT$:	LOAD.B	D3,(A4)	JUMP',EQ LG$	INC.L	A4	COMP.B	D3,#CR	JUMP',EQ LG$	INC.W	D4	COMP.W	D4,D0	JUMP,LO CNT$LG$:	LOAD.W	D3,D4	JUMP',EQ NEXT$	LIB	?AFTIM	.B	AFTOUT,0	LIB	?STRING		; affiche une ligne de texte	LIB	?AFTIM	.B	AFNORM,0NEXT$:	SWAP.W	D2	ADD.W	D2,(A0)+ODFCY	SWAP.W	D2	DEC.W	D1	JUMP,NE LOOP$	LOAD.L	A3,SP		; A3 <-- ^<USEGC><F><S><T>	LOAD.W	D3,#4	LIB	?STRING		; remet le gencar initial	POP.L	D4		; ajuste le stack	POPM.L	D0..D4,A3,A4	RET;----------\\; TEXTCLOSE >;==========/; Ferme un texte.; in	A4.L	^texte; out	-; mod	D7.WTEXTCLOSE:	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire du texte	POP.W	D1	RETTDBOX_VISU:	.W	10$-TDBOX_VISU	.W	20$-TDBOX_VISU	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Classeur :"	.B	ODBTABX,28+5	.B	ODBLABEL,50		; nombre de pages	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLABEL,10		; dbut bloc-notes	.B	ODBTEXT,0	.B	ODBTABX,28+5	.B	ODBLABEL,20		; dbut classeur	.B	ODBTEXT,0	.B	ODBTABX,28+5+28+2	.B	ODBLABEL,30		; dbut ascenseur	.B	ODBTEXT,0	.B	ODBTABX,28+5+28+2+3	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,28	.B	ODBLABEL,11		; fin bloc-notes	.B	ODBTEXT,0	.B	ODBTABX,28+5+28	.B	ODBLABEL,21		; fin classeur	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"   COLLE   "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  TERMINE  "	.B	ODBTABX,28+5	.B	ODBBOX,0,DEL,TDBOMBRE	.ASCIZ	"     SUPPRIME FEUILLE      "	.B	ODBTABX,28+5+28+2	.B	ODBLABEL,31		; fin ascenseur	.B	ODBTEXT,0	.B	ODBKHELP	.ASCIZ	"(SHOW-espace)"	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Colle"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Termine"	.EVENTKEY_VISU:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_VISU	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_VISU	.W	DEL,BS,DELETE,CLEAR,0	DOKDEL-TKEY_VISU	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_VISU	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_VISU	.W	0	.END