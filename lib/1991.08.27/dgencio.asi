	.SBTTL	DGENCIO;--------\\; PREND   >;========/; Prend une liste de 10 caractres.; in	-; out	A4.L	^contenu du fichier .DGENC lu;	D7.W	erreur; mod	D7.W, A4.LPREND:	PUSHM.L	D0..D6,A3,A5	LOAD.W	D1,#DBOX_PREND	LOAD.W	D2,(A6)+OMDMOD	; D2 <-- mode d'ouverture	TSET.L	D2:#BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CLR.L	D4		; D4 <-- fanions	LOAD.L	D5,(A6)+OMDPOS	; D5 <-- position	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A5,#(A6)+OMDFIL	; A5 <-- ^nom  diter	DBOX_	EXTEND		; demande le nom ...	JUMP,NE 90$	LOAD.W	D7,#ERKSTO	COMP.W	D3,#F1	JUMP,NE 90$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#(A6)+OMDFIL	; A3 <-- ^nom	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier .DGENC	JUMP,NE 90$	LOAD.W	D3,#-1	LOAD.L	D4,#-1	FOS	?SPOS		; va tout  la fin	LOAD.L	D1,D4		; D1 <-- longueur du fichier	CLR.W	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP,NE 85$	LOAD.L	D4,D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour fichier complet	JUMP,NE 85$	LOAD.L	A3,A4	LOAD.L	D4,#LGGC*MAXGC	FOS	?RDBYTE		; lit la liste des gencars	JUMP,NE 80$	FOS	?CLOSE		; ferme le fichier .DGENC	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	A4,A3	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D785$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier .DGENC	POP.W	D790$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	POP.W	D7	POPM.L	D0..D6,A3,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; PRENDMAJ >;=========/; Met  jour un gencar en fonction du fichier .DGENC lu.; in	-; out	D7.W	ok;	 D3.W	 dernire touche (zro/F1/F4);		  zro => cre;		  F1   => modifie (et pas cre);		  F4   => supprime;	 A4.L	 ^gencar modifi/supprim (utile si D3=F1/F4);	 D2.L	 ancien gencar "-fst" (utile si D3=F1);	D7.W	erreur; mod	D2.L, D3.L, D7.W, A4.LPRENDMAJ:	PUSHM.L	D1,D4,A0..A3	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A0,(A6)+OMDPLV	; A0 <-- ^variables permanantes	LOAD.L	A1,(A0)+OMVPFI	; A1 <-- ^nouvelle table lue	LOAD.L	A2,(A6)+OMDPGC	; A2 <-- ^ancienne table	CLR.W	D4	LOAD.B	D4,(A0)+OMVNOG	COMP.W	D4,#MAXGC	; est-ce fini ?	JUMP,HS 80$		; oui => 80$	MUL.WU	D4,#LGGC	ADD.L	A1,D4		; A1 <-- ^nouveau gencar	ADD.L	A2,D4		; A2 <-- ^ancien gencar	PUSHM.L	A1,A2	LOAD.L	A1,#(A1)+OGCTIT	LOAD.L	A2,#(A2)+OGCTIT	LOAD.W	D4,#LGTGC-120$:	LOAD.B	(A2+),(A1+)	; transfert le titre du gencar	DECJ.W,NMO D4,20$	POPM.L	A1,A2	TEST.B	(A1)+OGCFLG:#BGCUSE	JUMP',BC 40$	TEST.B	(A2)+OGCFLG:#BGCUSE	JUMP',BC 30$	CLR.B	(A1)+OGCCOD	CLR.B	(A2)+OGCCOD	LOAD.L	D3,(A1)+OGCCOD	COMP.L	D3,(A2)+OGCCOD	; mme gencar ?	JUMP',EQ 60$		; oui => 60$30$:				; non =>	LOAD.L	D2,(A2)+OGCCOD	; D2 <-- gencar v. modifi	AND.L	D2,#H'FFFFFF	PUSH.L	A2	LOAD.L	(A2)+OGCCOD,(A1)+OGCCOD	LOAD.L	A4,A2		; A4 <-- ^gencar	LOAD.L	A3,(A6)+OMDPGC	; A3 <-- ^buffer des gencars	LOAD.L	D4,(A6)+OMDNOK	; D4 <-- gencar  ne pas dtruire	LOAD.L	A2,(A6)+OMDPDD	; A2 <-- ^description de la fentre	DGENC_	NEW		; charge le nouveau gencar	POP.L	A2	LOAD.L	A4,A2		; A4 <-- ^gencar	LOAD.W	D3,#F1		; D3 <-- modifie	JUMP'	70$40$:	TEST.B	(A2)+OGCFLG:#BGCUSE	JUMP',BC 60$	LOAD.L	A4,A2		; A4 <-- ^gencar	LOAD.W	D3,#F4		; D3 <-- supprime	JUMP'	70$60$:	CLR.W	D3		; D3 <-- modifie70$:	INC.B	(A0)+OMVNOG	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	LOAD.L	A4,(A0)+OMVPFI	; A4 <-- ^nouvelle table lue	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire du fichier .DGENC	CLR.L	(A0)+OMVPFI	LOAD.W	D7,#1		; D7 <-- c'est fini90$:	POPM.L	D1,D4,A0..A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; SAUVE   >;========/; Sauve la liste des 10 caractres.; in	-; out	D7.W	erreur; mod	D7.WSAUVE:	PUSHM.L	D0..D6,A3..A510$:	LOAD.W	D1,#DBOX_SAUVE	LOAD.W	D2,(A6)+OMDMOD	; D2 <-- mode d'ouverture	TSET.L	D2:#BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CLR.L	D4		; D4 <-- fanions	LOAD.L	D5,(A6)+OMDPOS	; D5 <-- position	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A5,#(A6)+OMDFIL	; A5 <-- ^nom  diter	DBOX_	EXTEND		; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP',EQ 15$	COMP.W	D3,#F4	JUMP,NE 90$15$:	LOAD.W	D1,D3		; D1 <-- F1/F4	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier20$:	LOAD.L	A3,#(A6)+OMDFIL	; A3 <-- ^nom	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier .DGENC	JUMP',EQ 50$		; ok => 50$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	COMP.W	D1,#F4		; touche (MET A JOUR) ?	JUMP',EQ 40$		; oui => 40$	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	TEST.W	D7	JUMP,NE 90$	COMP.W	D3,#'O	JUMP,NE 10$40$:	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE 90$	JUMP	20$50$:	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier .DGENC	JUMP',NE 90$	LOAD.L	A4,(A6)+OMDPGC	; A4 <-- ^buffer des gencars	LOAD.L	D4,#LGGC*MAXGC	FOS	?WRBYTE		; crit la liste des gencars	JUMP',NE 80$	FOS	?CLOSE		; ferme le fichier .DGENC	JUMP',NE 90$	CALL	SAUVELIST	; sauve le fichier "!DGENC"	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier .DGENC	POP.W	D790$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	POP.W	D7	POPM.L	D0..D6,A3..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; SAUVELIST >;----------/; Sauve le fichier "nom!DGENC".; in	A3.L	^nom du fichier .DGENC; out	D7.W	erreur; mod	D7.WSAUVELIST:	PUSHM.L	D1..D4,D6,A2..A5	LOAD.L	D4,#(20*12)+(4*10)+10	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire temporaire	JUMP,NE 90$	LOAD.L	A5,A4		; A5 <-- ^buffer temporaire20$:	LOAD.B	D3,(A3+)	JUMP',EQ 24$	COMP.B	D3,#'.	JUMP',NE 22$	LOAD.B	D3,#'!22$:	CALL	MINMAJ	LOAD.B	(A4+),D3	; buffer <-- "nom!DGENC"	JUMP	20$24$:	CLR.B	(A4)	LOAD.L	A3,A5	FOS	?DELETE	LOAD.L	D3,#DEFATT-(2^BATTL)	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier "nom!DGENC"	JUMP,NE 85$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier "nom!DGENC"	JUMP,NE 85$	LOAD.L	A4,A530$:	TEST.B	(A4+)		; buffer <-- "nom!DGENC/D -CL"	JUMP,NE 30$	DEC.L	A4	LOAD.B	(A4+),#'/	LOAD.B	(A4+),#'D	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'-	LOAD.B	(A4+),#'C	LOAD.B	(A4+),#'L	LOAD.B	(A4+),#CR	LOAD.L	A3,A5	CALL	SKIPREP	LOAD.L	D1,A3	SUB.L	D1,A5		; D1 <-- lg de la chane "unit:rep:rep:"40$:	LOAD.B	D3,(A3+)	COMP.B	D3,#'/	JUMP,EQ 44$	COMP.B	D3,#'!	JUMP',NE 42$	LOAD.B	D3,#'.42$:	LOAD.B	(A4+),D3	; buffer <-- "nom.DGENC/D -C+L"	JUMP	40$44$:	LOAD.B	(A4+),#'/	LOAD.B	(A4+),#'D	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'-	LOAD.B	(A4+),#'C	LOAD.B	(A4+),#'+	LOAD.B	(A4+),#'L	LOAD.B	(A4+),#CR	LOAD.L	A2,(A6)+OMDPGC	; A2 <-- ^buffer des gencars	LOAD.W	D2,#MAXGC-1	CLR.L	(A5)+(20*12)	; aucun gencar rencontr50$:	TEST.B	(A2)+OGCFLG:#BGCUSE ; gencar occup ?	JUMP,BC 58$		; non => 58$				; oui =>	LOAD.L	D4,(A2)+OGCCOD	; D4 <-- "-fst"	AND.L	D4,#H'00FFFFFF	TCLR.L	D4:#16+7	; gencar calcul ?	JUMP',BC 52$		; non => 52$	AND.W	D4,#H'80FF	OR.W	D4,#H'100*'R	; D4 <-- met un style "roman"52$:	CALL	SAUVEGCEX	; gencar dj rencontr ?	JUMP,EQ 58$		; oui => 58$	LOAD.L	A3,#R16"TXT1$53$:	LOAD.B	(A4+),(A3+)	; buffer <-- "#:SMA_"	JUMP,NE 53$	DEC.L	A4	LOAD.L	A3,A4	CALL	_DGENC_PUT	; buffer <-- "fsctt"54$:	LOAD.B	D3,(A4)	CALL	MINMAJ	LOAD.B	(A4+),D3	JUMP,NE 54$	DEC.L	A4	LOAD.L	A3,#R16"TXT2$55$:	LOAD.B	(A4+),(A3+)	; buffer <-- ".GENC<CR>"	JUMP,NE 55$	DEC.L	A458$:	LOAD.L	A2,#(A2)+LGGC	; A2 <-- ^gencar suivant	DECJ.W,NMO D2,50$	LOAD.L	D4,A4	SUB.L	D4,A5	SUB.L	D4,D1	LOAD.L	A4,#(A5)+(D1.L)	FOS	?WRBYTE		; crit le fichier "nom!DGENC"	JUMP',NE 80$	FOS	?CLOSE		; ferme le fichier "nom!DGENC"	JUMP'	85$80$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier "nom!DGENC"	POP.W	D785$:	PUSH.W	D7	LOAD.L	A4,A5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire temporaire	POP.W	D790$:	POPM.L	D1..D4,D6,A2..A5	TEST.W	D7		; retour EQ/NE	RETTXT1$:	.ASCIZ	"#:SMA_"TXT2$:	.ASCIZ	".GENC<CR>"	.EVEN;----------\\; SAUVEGCEX >;----------/; Regarde si le gencar a dj t rencontr une fois.; in	D4.L	"-fst"; out	D7.W	EQ si existe dj; mod	D7.WSAUVEGCEX:	PUSH.L	A4	LOAD.L	A4,#(A5)+(20*12)10$:	TEST.L	(A4)		; fin ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.L	D4,(A4+)	; gencar trouv ?	JUMP,NE 10$		; non => 10$				; oui =>	CLR.W	D7		; D7 <-- gencar trouv	JUMP'	90$50$:	LOAD.L	(A4+),D4	; buffer <-- gencar	CLR.L	(A4)		; buffer <-- terminateur	LOAD.W	D7,#1		; D7 <-- gencar n'existe pas90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SKIPREP >;========/; Saute tous les noms d'units et de rpertoires devant; un nom de fichier.; in	A3.L	^unit:rp:rp:nom.ext; out	A3.L	^nom.ext; mod	A3.LSKIPREP:	PUSH.W	D3	CLR.W	D310$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE 10$20$:	DEC.W	D3	JUMP,NS 90$	COMP.B	(-A3),#':	JUMP,NE 20$	INC.L	A390$:	POP.W	D3	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RETTEXT_IO:	.ASCIZ	".DGENC"		; extensionTDBOX_IO:	.ASCIZ	"DGENC"			; nom du logiciel	.ASCIZ	"Fliste de caractres"	; [M,F] nom des lments manipuls	.ASCIZ	""			; [M,F] nom du contenant	.B	0	.EVEN	.END