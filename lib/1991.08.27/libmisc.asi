	.SBTTL	LIBMISC;----------\; _CPSTRING >;==========/BCPSEQ	= 0	; 1 => chanes pas identiques (flag Z)BCPSNE	= 15	; 1 => chanes diffrentes    (flag N)BCPSTI	= 2	; caractre "*" trouvBCPSFI	= 3	; comparaison termine; Compare deux chanes de caractres, l'une pouvant contenir; une information incomplte,  savoir:;   "*"  remplace une chane quelconque (ventuellement nulle);   "?"  remplace un caractre quelconque;   "["  dbut d'une liste;   "]"  fin d'une liste;   "-"  interval dans une liste;   ".." idem; Les majuscules sont quivalentes aux minuscules dans la; comparaison.;; in	A2.L	^liste de terminateurs termine par -1 (H'FF);	A3.L	^chane contenant "*", "?" et "[...]";	A4.L	^autre chane; out	NC+EQ	A4^ strictement gal  A3^;	NC+NE	A4^ inclu dans A3^;	NS+NE	A4^ diffrent de A3^; mod	D7.W_CPSTRING:	PUSHM.L	D0,D3,D4,A1,A3,A4	CLR.W	D7		; clear tous les flags01$:	TEST.L	D7:#BCPSTI	; "*" trouv ?	JUMP,BS 10$		; oui => 10$	COMP.B	(A3),#METAANY	; non => "*" en (A3) ?	JUMP,NE 10$	COMP.B	(A4),#METAANY	; aussi un "*" en (A4.L) ?	JUMP,EQ 10$	INC.L	A3		; si oui, A3.L ^suivant	TSET.L	D7:#BCPSTI	; et indique un "*" trouv.10$:	PUSHM.L	A3,A4		; sauve A3.L et A4.L20$:	LOAD.B	D3,(A3)		; fin chane ^par A3 ?	CALL	CPTERM	JUMP,EQ 50$	COMP.B	D3,#METAANY	; fin comparaison partielle ?	JUMP,NE 25$		; non => 25$	COMP.B	(A4),#METAANY	; "*" en (A4) ?	JUMP,EQ 25$		; oui => caractres gaux	TSET.L	D7:#BCPSEQ	; non => pas strictement gales	JUMP	60$25$:	LOAD.B	D3,(A4)		; fin chane ^par A4 ?	CALL	CPTERM	JUMP,EQ 30$	CALL	CPCAR		; compare deux caractres	JUMP,EQ	20$		; gaux => 20$30$:				; non	TEST.L	D7:#BCPSTI	; "*" trouv ?	JUMP,BC 32$		; non => set bfini	LOAD.B	D3,(A4)		; oui => chane (A4.L) finie ?	CALL	CPTERM	JUMP,NE 33$32$:	TSET.L	D7:#BCPSFI	; fini si A4 fini ou "*" trouv33$:	POPM.L	A3,A4		; chanes partielles pas gales	TSET.L	D7:#BCPSNE	; chanes diffrentes	TSET.L	D7:#BCPSEQ	; chanes pas strictement gale	JUMP	80$50$:				; (A3.L) fini	LOAD.B	D3,(A4)		; (A4.L) aussi fini ?	CALL	CPTERM	JUMP,NE 30$		; non => chanes differentes	TSET.L	D7:#BCPSFI	; (A4) et (A3) fini => fini60$:				; chanes partielles gales.	POP.L	D3		; pops bidon pour compenser le	POP.L	D3		; PUSHM.L A3,A4	TCLR.L	D7:#BCPSNE	; chanes peut-tre gales	TCLR.L	D7:#BCPSTI	; annule le "*" trouv	JUMP	90$80$:	TEST.L	D7:#BCPSTI	; si "*" trouv et chanes pas	JUMP,BC 90$		; gales => INC.L A4.L (cherche	INC.L	A4		; plus loin).90$:	TEST.L	D7:#BCPSFI	; recommence jusqu'a ce que ce	JUMP,BC 01$		; soit fini !	AND.W	D7,#2^BCPSNE!2^BCPSEQ ; conserve juste N et Z	POPM.L	D0,D3,D4,A1,A3,A4	TEST.W	D7		; retour Z+N (si interne LIB)	RET;--------\; CPCAR   >;--------/; Compare deux caractres.; Rsoud les cas suivants en (A3) :;   M		accepte Mm	(majuscules et minuscules);   ?		accepte tout;   [123]	accepte 123;   [1-5]	accepte 12345;   [15-9]	accepte 156789;   [a-d]	accepte ABCD;   [1-5XA-D]	accepte 12345XABCD;   etc.; Remarque:  ".." peut remplacer "-" dans une liste.;   [1..5]	accepte 12345;   [A..DXYZ]	accepte ABCDXYZ;   [A.DXYZ]	accepte A.DXYZ; in	A3.L	^caractre (ventuellement ?, [a-z], etc);	A4.L	^caractre;	D7.W	flags divers; out	A3.L	^aprs liste [...] si elle existe;	A4.L	^un caractre plus loin (+1);	D7.W	flags divers;	EQ	caractres gaux;	NE	l'inverse; mod	D0.B, D3.B, D4.B, D7.W, A3.L, A4.LCPCAR:	LOAD.B	D0,#-1		; retour NE par dfaut	LOAD.B	D3,(A4+)	CALL	_MINMAJ	LOAD.B	D4,D3		; D4 <-- car. majuscule en (A4)	LOAD.B	D3,(A3+)	CALL	_MINMAJ		; D3 <-- car. majuscule en (A3)	COMP.B	D3,#METAONE	; accepte n'importe quoi ?	JUMP,EQ	10$		; oui => 10$	COMP.B	D3,#METABLI	; dbut d'une liste ?	JUMP,EQ	20$		; oui => 20$				; non =>	COMP.B	D3,D4		; compare deux caractres	JUMP,NE	90$		; pas gaux => retour NE	CLR.B	D0		; gaux => retour EQ	JUMP	90$10$:	CLR.B	D0		; retour EQ	COMP.B	D4,#METAONE	; "?" aussi dans l'autre ?	JUMP,EQ	90$		; oui => 90$	TSET.L	D7:#BCPSEQ	; chanes pas strictement gale	JUMP	90$20$:	LOAD.B	D3,(A3)		; D3 <-- un car. de la liste	CALL	CPTERM	JUMP,EQ	90$	INC.L	A3	COMP.B	D3,#METAELI	; fin de la liste ?	JUMP,EQ	90$		; oui => retour NE	CALL	_MINMAJ	COMP.B	(A3),#METAILI	; interval ?	JUMP,EQ	40$		; oui => 40$	COMP.B	(A3),#'.	JUMP,EQ	30$25$:	COMP.B	D3,D4		; compare deux caractres	JUMP,NE	20$		; si diffrents => 20$	CLR.B	D0		; gaux => retour EQ	TSET.L	D7:#BCPSEQ	; chanes pas strictement gale	JUMP	80$		; avance encore aprs "]"30$:	COMP.B	(A3)+1,#'.	; interval ".." ?	JUMP,NE	25$		; non => 25$	INC.L	A3		; A3 <-- saute premier "."40$:	INC.L	A3		; A3 <-- saute "-" ou "."	COMP.B	D4,D3		; compare avec borne inf.	JUMP,LO 20$		; plus petit => 20$ (!)	LOAD.B	D3,(A3)		; D3 <-- borne suprieure	CALL	CPTERM	JUMP,EQ	90$	INC.L	A3	COMP.B	D3,#METAELI	; fin de la liste ?	JUMP,EQ	90$		; oui => retour NE	CALL	_MINMAJ	COMP.B	D4,D3		; compare avec borne sup.	JUMP,HI 20$		; plus grand => 20$	CLR.B	D0		; retour EQ	TSET.L	D7:#BCPSEQ	; chanes pas strictement gale80$:	LOAD.B	D3,(A3)	CALL	CPTERM		; fin de la chane ?	JUMP,EQ	90$		; oui => 90$	INC.L	A3	COMP.B	D3,#METAELI	; fin de la liste ?	JUMP,NE	80$		; non => 80$90$:	TEST.B	D0		; retour EQ/NE	RET;--------\; CPTERM  >;--------/; Test si le caractre dans D3 est un terminateur gnral.; in	D3.B	caractre;	A2.L	^liste de terminateurs; out	EQ	c'est un terminateur;	NE	c'est autre chose; mod	A1.LCPTERM:	LOAD.L	A1,A2		; A1 <-- ^liste terminateurs10$:	COMP.B	(A1),#-1	; fin de la liste ?	JUMP,EQ	90$		; oui => 90$	COMP.B	D3,(A1+)	; terminateur ?	JUMP,NE	10$		; non => 10$	RET			; oui => retour EQ90$:	NOTZ			; retour NE	RET;--------\; _GETLAN >;========/; in	-; out	D3.W	langue du systme;	D7.W	erreur; mod	D7.W_GETLAN:	PUSHM.L	D4,A4	FOS	?OPINFO		; ouvre SYS_INFO	CLR.W	D3	LOAD.B	D3,(A4)+OINLAN	; D3 <-- langue F,E,D,I,etc.	JUMP,NE	50$		; si langue existe => 50$	LOAD.B	D3,#'F		; autrement => FRANCAIS !50$:	CLR.W	D4	FOS	?CLINFO		; ferme SYS_INFO	POPM.L	D4,A4	RET;--------\; _MINMAJ >;========/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.B_MINMAJ:	TEST.L	D3:#7		; code "supplmentaire" ?	JUMP',NE 20$		; oui => 20$	COMP.B	D3,#SPACE-2	; lettre accentue ?	JUMP',LO 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+70$  ; D3 <-- lettre majuscule	POP.W	D0	RET70$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN;--------\; _BINBCD >;========/; in	D4.L	nombre binaire; out	D4.L	nombre BCD; 	D7.W	erreur; mod	D0..A1, D4.L, D7.W_BINBCD:	PUSH.L	D2	PUSH.W	D6	DIV.WU	D4,#10000.	JUMP,VS 80$	COMP.W	D4,#10000.	JUMP',HS 80$	PUSH.W	D4		; stack <-- quotient	SWAP.W	D4	PUSH.W	D4		; stack <-- reste	CLR.L	D2	LOAD.W	D6,#2-1		; -1  cause du test NMO10$:	POP.W	D0		; D0 <-- reste puis quotient; Module de calcul de 4 digits par div succ de D0 par 1010 et; copie  du reste dans D2 aprs dcalage	LOAD.W	D7,#4-120$:	AND.L	D0,#H'FFFF	DIV.WU	D0,#10.	LOAD.L	D1,D0	SWAP.W	D1	AND.W	D1,#H'F	OR.W	D2,D1	RR.L	D2,#4	DECJ.W,NMO D7,20$	DECJ.W,NMO D6,10$	LOAD.L	D4,D2	CLR.W	D7		; D7 <-- ok40$:	POP.W	D6	POP.L	D2	RET80$:	LOAD.W	D7,#-1		; D7 <-- erreur	JUMP	40$;--------\; _BCDBIN >;========/; Converti 8 digits BCD en un nombre binaire de 30 bits max.; in	D4.L	nombre BCD; out	D4.L	nombre binaire; 	D7.W	erreur; mod	D0..A1, D4.L, D7.W_BCDBIN:	CLR.L	D0	LOAD.W	D7,#8-1		; D7 <-- compteur10$:	RL.L	D4,#4	LOAD.W	D1,D4	AND.L	D1,#H'F		; D1 <-- digit isol	COMP.B	D1,#H'A	JUMP',HS 80$	SL.L	D0,#1		;	LOAD.L	A0,D0		; multiplie par 1010	SL.L	D0,#2		;	ADD.L	D0,A0		;	ADD.L	D0,D1		; ajoute le digit	DECJ.W,NMO D7,10$	LOAD.L	D4,D0	CLR.W	D7		; D7 <-- ok	RET80$:	LOAD.W	D7,#-1		; D7 <-- erreur	RET;---------\; _RDCLOCK >;=========/; Lit la date et l'heure d'aprs le driver horloge du systme.; in	-; out	D3.L	heure en BCD	!   ! h ! m ! s !;	D4.L	date en BCD	! w ! j ! m ! a !;	D7.W	erreur; mod	D3.L, D4.L, D7.W_RDCLOCK:	PUSHM.L	D6,A3,A4	LOAD.L	A3,#R16"NLCLOCK	LOAD.B	D3,#2^BOPRD	FOS	?OPEN		; ouvre l'horloge	JUMP,NE 80$	LOAD.L	A4,#(A6)+OBUCOM	LOAD.L	D4,#3+3+1	FOS	?RDBYTE		; lit la date et l'heure	JUMP',NE 70$	FOS	?CLOSE		; ferme l'horloge	JUMP',NE 80$	CLR.W	D3	LOAD.B	D3,(A6)+OBUCOM+2 ; heures	SL.L	D3,#8	LOAD.B	D3,(A6)+OBUCOM+1 ; minutes	SL.L	D3,#8	LOAD.B	D3,(A6)+OBUCOM+0 ; secondes	LOAD.B	D4,(A6)+OBUCOM+6 ; jour de la semaine	SL.L	D4,#8	LOAD.B	D4,(A6)+OBUCOM+3 ; jour	SL.L	D4,#8	LOAD.B	D4,(A6)+OBUCOM+4 ; mois	SL.L	D4,#8	LOAD.B	D4,(A6)+OBUCOM+5 ; anne	JUMP'	90$70$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'horloge	POP.W	D780$:	CLR.L	D3		; rend zro en cas d'erreur	CLR.L	D490$:	POPM.L	D6,A3,A4	RET	.END