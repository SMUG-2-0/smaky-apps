	.SBTTL	DBOXIO; (*)	Textes de description en (A3) :;;	.ASCIZ	"DESSIN"	; nom du logiciel;	.ASCIZ	"Fimage"	; [M,F] nom des lments manipuls;	.ASCIZ	"Fpage"		; [M,F] nom du contenant;	.B	0;	.EVEN;;	.ASCIZ	"TEXT"		; nom du logiciel;	.ASCIZ	"Mtexte"	; [M,F] nom des lments manipuls;	.ASCIZ	"Fzone"		; [M,F] nom du contenant;	.B	0;	.EVEN;;	.ASCIZ	"GRAPHE"	; nom du logiciel;	.ASCIZ	"Mgraphique"	; [M,F] nom des lments manipuls;	.ASCIZ	""		; [M,F] nom du contenant;	.B	0;	.EVEN;;	etc.; (%)	Liste d'extensions multiples en (A4) :;;	.ASCIZ	".FICHE"	; fanion D4:#15  <-- ATTENTION !!!;	.ASCIZ	".TEXT"		; fanion D4:#14;	.ASCIZ	".GRAPHE"	; etc.;	.ASCIZ	"*.TABLE"	; permet de mettre "*" et "?" dans le nom;	.ASCIZ	"-"		; pas d'extension;	.ASCIZ	"?"		; autre extension dite (si D3:#BDBIOFULL);	.B	0;-------------\\; _DBOX_IOEDIT >;=============/; Demande un nom de fichier  prendre, ajouter, sauver ou extraire.; in	D1.W	numro de l'appel;	D2.W	mode d'ouverture de la dbox;	D3.L	lg max du nom (D3.W) et flags (BDBIOFULL si dite extension);	D4.L	fanions;	D5.L	position centre de la dbox (si D2:#BDBPOS);	A0.L	^texte @ "Nom du fichier  ajouter @ :" (si D3:#BDBIOTXT);	A1.L	^<lg>icnes (si D3:#BDBIOICO);	A2.L	^<lg>table d'objets de l'utilisateur (si D3:#BDBIOOBJ);	A3.L	^textes de description, voir (*);	A4.L	^extension<0> (si D3:#BDBIOEXT1);	A4.L	^[extension<0>]<0> (si D3:#BDBIOEXTM), voir (%);	A5.L	^buffer contenant le nom  diter <0>; out	D3.W	dernire touche (F1/F4/F0);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.W_DBOX_IOEDIT:	PUSHM.L	D0..D2,D5,A0..A6	CALL	IOOPEVAR	; A6 <-- ^variables	JUMP,NE ERFAT$	LOAD.L	(A6)+OIOPEX,A4	LOAD.L	(A6)+OIOPNA,A5	LOAD.L	(A6)+OIOFAN,D4	CALL	IOEDITTXT	; A3 <-- ^texte<0>	LOAD.L	A0,#R16"TDBPREND	COMP.W	(A6)+OIOAPP,#DBOX_PREND	JUMP',EQ OPEN1$	LOAD.L	A0,#R16"TDBAJOUTE	COMP.W	(A6)+OIOAPP,#DBOX_AJOUTE	JUMP',EQ OPEN1$	LOAD.L	A0,#R16"TDBSAUVE	COMP.W	(A6)+OIOAPP,#DBOX_SAUVE	JUMP',EQ OPEN1$	LOAD.L	A0,#R16"TDBEXTRAITOPEN1$:	CALL	IODBOPEN	; construit et ouvre la dbox	JUMP,NE EXIT$	CLR.W	D0		; D0 <-- flags (touches pas grises)	LOAD.L	A4,#(A6)+OIOTXTOPEN2$:	LOAD.B	(A4+),(A5+)	; OIOTXT <-- nom original	JUMP,NE OPEN2$	CALL	IOEDITSEP	; spare le nom et l'extension	CLR.W	D2		; D2 <-- dite le nomREFAIT$:	PUSH.W	D2	CLR.W	D2	CALL	IOEDITAFF	; affiche le nom	INC.W	D2	CALL	IOEDITAFF	; affiche l'extension	POP.W	D2	LOAD.W	D3,D2	DBOX_	MEDIT		; signal le rang du ODBXFILE	LOAD.L	A3,#(A6)+OIONAM	TEST.W	D2	JUMP',EQ REFAIT1$	LOAD.L	A3,#(A6)+OIOEXTREFAIT1$:	LOAD.L	A4,A3REFAIT2$:	TEST.B	(A4+)		; A4 <-- ^fin du nom/extension	JUMP,NE	REFAIT2$	DEC.L	A4	JUMP	EDIT$LOOP$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_IOEDIT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	TEST.W	D3	JUMP,EQ EDIT$	COMP.W	D3,#1	JUMP,EQ CHANGE$	COMP.W	D3,#SPACE	JUMP,EQ EDIT$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ	OK$	COMP.W	D3,#F4		; MET A JOUR ?	JUMP,EQ MAJ$	COMP.W	D3,#F7		; LISTE ?	JUMP,EQ	LIST$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ	ANNULE$	COMP.W	D3,#DEFINE	JUMP,EQ DEFINE$	COMP.W	D3,#KEYDBOX+0	JUMP,EQ KNAME$	COMP.W	D3,#KEYDBOX+1	JUMP,EQ KEXT$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne;	JUMP'	EDIT$EDIT$:	CALL	IOEDITIFP	PUSH.W	D7	CALL	IOEDITFEX	; D4 <-- v. fanion selon l'extension frappe	POP.W	D7	JUMP,EQ REFAIT$	CALL	IOEDITASS	; assemble le nom et l'extension	CALL	IOEDITGRE	; affiche v. en gris	JUMP	LOOP$CHANGE$:	CALL	IOEDITIFP	PUSH.W	D7	CALL	IOEDITCEX	; OIOEXT <-- v. extension selon fanion	POP.W	D7	JUMP,EQ REFAIT$	CALL	IOEDITASS	; assemble le nom et l'extension	CALL	IOEDITGRE	; affiche v. en gris	JUMP	REFAIT$DEFINE$:			; DEFINE =>	TEST.B	(A6)+OIOFLG+0:#BDBIOFULL-24 ; dite l'extension ?	JUMP,BC BIP$	INC.W	D2	COMP.W	D2,#2	JUMP,LO REFAIT$	CLR.W	D2	JUMP	REFAIT$KNAME$:	CLR.W	D2	JUMP	REFAIT$KEXT$:	TEST.B	(A6)+OIOFLG+0:#BDBIOFULL-24 ; dite l'extension ?	JUMP,BC BIP$	LOAD.W	D2,#1	JUMP	REFAIT$LIST$:				; LISTE =>	COMP.W	(A6)+OIOAPP,#DBOX_SAUVE	JUMP,EQ BIP$	COMP.W	(A6)+OIOAPP,#DBOX_EXTRAIT	JUMP,EQ BIP$	TEST.B	(A6)+OIOFLG+0:#BDBIOFULL-24 ; dite l'extension ?	JUMP',BS LISTEE$	CALL	IOEDITEXT	; A2 <-- ^extension	JUMP,NE BIP$	COMP.B	(A2),#'?	JUMP',NE LIST0$LISTEE$:	LOAD.L	A2,#(A6)+OIOEXT	; A2 <-- ^extension en dition	COMP.B	(A2),#'?	JUMP',NE LIST0$	LOAD.L	A2,#R16"LISTALL$LIST0$:	COMP.B	(A2),#'*	JUMP',NE LIST1$	INC.L	A2		; A2 <-- ^aprs l'toileLIST1$:	DBOX_	CLOSE		; ferme la DBOX	PUSH.L	D4	CALL	IOEDITASS	; assemble le nom et l'extension	LOAD.L	A4,(A6)+OIOPNA	; A4 <-- ^buffer pour nom	LOAD.L	A3,A2		; A3 <-- ^extension	LOAD.L	D4,#2^BLIDBNOM	; D4 <-- mode	LOAD.L	A2,#R16"PREND$	; A2 <-- ^nom de la touche principale	COMP.W	(A6)+OIOAPP,#DBOX_PREND	JUMP',EQ LIST2$	LOAD.L	A2,#R16"AJOUTE$	; A2 <-- ^nom de la touche principaleLIST2$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode (avec sauvetage)	LIST_	DBOX		; liste puis choix selon dbox ...	POPM.L	D4	JUMP,NE EXIT$	LOAD.L	A3,A4		; A3 <-- ^nom du fichier	LOAD.W	D2,D3	LOAD.W	D3,#F1	COMP.W	D2,#CR	JUMP,EQ EXIT$	LOAD.W	D3,#F0	JUMP	EXIT$OK$:				; D'ACCORD =>	TEST.L	D0:#0		; touche grise ?	JUMP,BS BIP$		; oui => BIP$	CALL	IOEDITASS	; assemble le nom et l'extension	JUMP'	ASS$MAJ$:				; MET A JOUR =>	COMP.W	(A6)+OIOAPP,#DBOX_SAUVE	JUMP,NE BIP$	TEST.L	D0:#1		; touche grise ?	JUMP,BS BIP$		; oui => BIP$ASS$:	CALL	IOEDITASS	; assemble le nom et l'extension	JUMP'	CLOSE$ANNULE$:			; ANNULE =>	CALL	IOEDITOLD	; remet le nom originalCLOSE$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	CALL	IOCLOVAR	; rend la mmoire des variablesERFAT$:	POPM.L	D0..D2,D5,A0..A6	TEST.W	D7		; retour EQ/NE	RETPREND$:	.ASCIZ	"PREND"AJOUTE$:.ASCIZ	"AJOUTE"LISTALL$:	.ASCIZ	".*"	.EVEN;----------\\; IOEDITAFF >;----------/; Affiche un texte en dition.; in	D2.W	rang; out	-; mod	D7.WIOEDITAFF:	PUSHM.L	D2..D4,A0,A2..A4	LOAD.L	A0,(A6)+OIOPDI	; A0 <-- ^descripteur fentre	LOAD.L	A3,#(A6)+OIONAM	; A3 <-- ^nom	TEST.W	D2	JUMP',EQ 10$	LOAD.L	A3,#(A6)+OIOEXT	; A3 <-- ^extension	TEST.B	(A6)+OIOFLG+0:#BDBIOFULL-24 ; dite l'extension ?	JUMP',BS 10$	LOAD.B	D3,#AFGREY	LIB	?AFCAR	TEST.B	(A6)+OIOFLG+1:#BDBIOEXTM-16	JUMP',BC 10$	CLR.B	(A3)	CALL	IOEDITEXT	; A2 <-- ^extension	LOAD.L	A4,A3	COMP.B	(A2),#'*	JUMP',NE 05$	INC.L	A2		; A2 <-- ^aprs l'toile05$:	LOAD.B	D3,(A2+)	LIB	?MINMAJ	LOAD.B	(A4+),D3	; OIOEXT <-- extension selon fanion	JUMP,NE 05$10$:	TSET.L	D2:#BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	; positionne le curseur au dbut	SUB.W	D4,D3	AND.L	D4,#H'FFFF	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb de caractres  afficher	LOAD.L	A4,A3	LOAD.W	D3,#-120$:	INC.W	D3		; D3 <-- nb de caractres du nom	TEST.B	(A4+)	JUMP,NE 20$	COMP.W	D3,D4		; place pour tout afficher ?	JUMP',LS 50$		; oui => 50$				; non =>	LIB	?AFTIM		; affiche flche "<-" inverse	.B	AFINV,AFTOUT,5,AFNORM,AFDIR,0	.EVEN	DEC.W	D4	SUB.W	D3,D4	ADD.W	A3,D3	LOAD.W	D3,D4	LIB	?STRING		; affiche la fin du nom	LIB	?AFSPACE	JUMP'	90$50$:	LIB	?STRING		; affiche le nom	SUB.W	D4,D3	JUMP',EQ 90$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin90$:	LOAD.B	D3,#AFFULL	LIB	?AFCAR	POPM.L	D2..D4,A0,A2..A4	RET;----------\\; IOEDITTXT >;----------/; Construit le(s) texte(s).; in	D3.L	flags;	A0.L	^texte @ "Nom du fichier  ajouter @ :" (si D3:#BDBIOTXT);	A3.L	^textes de description, voir (*); out	A3.L	^texte<0>; mod	D7.W, A3.LIOEDITTXT:	PUSHM.L	D4,A4,A5	LOAD.L	A5,A3		; A5 <-- ^(*)	LOAD.L	A3,#(A6)+OIOTXT	LOAD.L	A4,#R16"01$	CALL	PUTTEXTE	; buffer <-- "Nom"	LOAD.W	D4,#1	CALL	SEARCHTXT	; A4 <-- ^[M,F] mot	CALL	PUTARTCONT	; buffer <-- "de l'image"	LOAD.L	A4,#R16"02$	COMP.W	(A6)+OIOAPP,#DBOX_PREND	JUMP',EQ 20$	LOAD.L	A4,#R16"03$	COMP.W	(A6)+OIOAPP,#DBOX_AJOUTE	JUMP',EQ 20$	LOAD.L	A4,#R16"04$20$:	CALL	PUTTEXTE	; buffer <-- " ajouter"	TEST.L	D3:#BDBIOTXT	JUMP',BC 30$	LOAD.B	(A3+),#SPACE	LOAD.L	A4,A0	CALL	PUTTEXTE	; buffer <-- texte supplmentaire30$:	LOAD.L	A4,#R16"05$	CALL	PUTTEXTE	; buffer <-- " :"	LOAD.L	A3,#(A6)+OIOTXT	; A3 <-- ^texte<0>	POPM.L	D4,A4,A5	RET01$:	.ASCIZ	" Nom "02$:	.ASCIZ	"  prendre"03$:	.ASCIZ	"  ajouter"04$:	.ASCIZ	"  sauver"05$:	.ASCIZ	" :"	.EVEN;----------\\; IOEDITEXT >;----------/; Cherche une extension en fonction des fanions.; in	D4.L	fanions; out	A2.L	^extension choisie;	D7.W	erreur; mod	D7.W, A2.LIOEDITEXT:	PUSH.L	D4	CLR.W	D7		; D7 <-- extension existe	LOAD.L	A2,(A6)+OIOPEX	; A2 <-- ^critre de recherche (extension)	TEST.B	(A6)+OIOFLG+1:#BDBIOEXT1-16	JUMP',BS 90$	TEST.B	(A6)+OIOFLG+1:#BDBIOEXTM-16	JUMP',BC 80$10$:	RL.W	D4,#1	JUMP',CS 30$20$:	TEST.B	(A2+)		; A2 <-- ^extension suivante	JUMP,NE 20$	TEST.B	(A2)		; extension suivante existe ?	JUMP',EQ 80$		; non => 80$	JUMP	10$30$:	COMP.B	(A2),#'-	; extension valide ?	JUMP',NE 90$		; oui => 90$80$:				; non =>	LOAD.W	D7,#1		; D7 <-- extension invalide90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOEDITFEX >;----------/; Cherche quel fanion allumer en fonction de l'extension dite.; in	D2.W	rang (0/1);	D4.L	fanions; out	D4.L	fanions; mod	D4.L, D7.WIOEDITFEX:	PUSHM.L	D0..D3,A2..A4	TEST.B	(A6)+OIOFLG+1:#BDBIOEXTM-16	JUMP,BC 90$	TEST.B	(A6)+OIOFLG+0:#BDBIOFULL-24 ; dite l'extension ?	JUMP,BC 90$	TEST.W	D2		; dite le nom ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A3,#(A6)+OIOEXT	; A3 <-- ^extension dite	LOAD.L	A2,(A6)+OIOPEX	; A2 <-- ^table des extensions	LOAD.W	D1,#16		; D1 <-- nouveau fanion	CLR.W	D0		; D0 <-- fanion pour "autre"20$:	DEC.W	D1		; D1 <-- fanion suivant (15, 14, 13, etc.)	TEST.B	(A2)		; encore une extension ?	JUMP',EQ 50$	LOAD.L	A4,A3	COMP.B	(A2),#'?	; extension "autre" ?	JUMP',NE 30$		; non => 30$	LOAD.W	D0,D1		; D0 <-- fanion pour "autre"	JUMP'	34$30$:	LOAD.B	D2,(A2+)	JUMP',EQ 36$	LOAD.B	D3,(A4+)	LIB	?MINMAJ	COMP.B	D3,D2		; compare les extensions	JUMP,EQ 30$34$:	TEST.B	(A2+)	JUMP,NE 34$	JUMP	20$36$:	TEST.B	(A4)	JUMP,NE 20$	JUMP'	60$50$:	LOAD.W	D1,D0		; fanion pour "autre" trouv ?	JUMP',EQ 90$		; non => 90$60$:				; oui =>	AND.W	D4,#H'00FF	TSET.L	D4:D1		; D4 <-- nouveau fanion90$:	POPM.L	D0..D3,A2..A4	RET;----------\\; IOEDITCEX >;----------/; Met dans l'extension en dition l'extension qui correspond; exactement au fanion slectionn.; in	D4.L	fanions; out	-; mod	D7.WIOEDITCEX:	PUSHM.L	A2,A3	TEST.B	(A6)+OIOFLG+1:#BDBIOEXTM-16	JUMP',BC 90$	TEST.B	(A6)+OIOFLG+0:#BDBIOFULL-24 ; dite l'extension ?	JUMP',BC 90$	CALL	IOEDITEXT	; A2 <-- ^extension	JUMP',NE 90$	COMP.B	(A2),#'?	JUMP',EQ 90$	COMP.B	(A2),#'*	JUMP',NE 40$	INC.L	A240$:	LOAD.L	A3,#(A6)+OIOEXT42$:	LOAD.B	(A3+),(A2+)	; OIOEXT <-- extension	JUMP,NE 42$90$:	POPM.L	A2,A3	RET;----------\\; IOEDITGRE >;----------/; Affiche la touche principale v. en gris.; in	D4.L	fanions;	D0.W	flags; out	D0.W	flags; mod	D0.L, D7.WIOEDITGRE:	PUSHM.L	D1..D4,A2..A4	LOAD.W	D1,#B'10	TEST.B	(A6)+OIOFLG+1:#BDBIOEXTM-16	JUMP',BC 10$	CALL	IOEDITEXT	; A2 <-- ^extension	JUMP',NE 50$	COMP.B	(A2),#'*	JUMP',EQ 50$10$:	LOAD.W	D1,#B'11	; D1 <-- tout en gris	TEST.B	(A6)+OIONAM	; nom existe ?	JUMP',EQ 50$		; non => 50$	LOAD.L	A3,(A6)+OIOPNA	; A3 <-- ^nom complet	CALL	IOEDITSYN	; syntaxe correcte ?	JUMP',NE 50$		; non => 50$	LOAD.W	D1,#B'10	; D1 <-- (SAUVE)  (...)	COMP.W	(A6)+OIOAPP,#DBOX_SAUVE	JUMP',NE 50$	COMP.L	D4,(A6)+OIOFAN	; est-ce que les fanions ont changs ?	JUMP',NE 50$		; oui => 50$	TEST.B	(A6)+OIOTXT	; nom original existe ?	JUMP',EQ 50$		; non => 50$	LOAD.L	A4,(A6)+OIOPNA	; A4 <-- ^nom dit	LOAD.L	A3,#(A6)+OIOTXT	; A3 <-- ^nom original	LOAD.L	A2,#R16"00$	LIB	?CPSTRING	; est-ce que le nom a chang ?	JUMP',NE 50$		; oui => 50$;;?	LOAD.W	D1,#B'11	; D1 <-- (...)  (...)	TEST.B	(A6)+OIOFLG+0:#BDBIONMAJ-24	JUMP',BS 50$	LOAD.W	D1,#B'01	; D1 <-- (...)  (MET A JOUR); Grise ou dgrise la touche principale.50$:	TEST.L	D1:#0	JUMP',BC 60$	TSET.L	D0:#0		; dj affich en gris ?	JUMP',BS 70$		; oui => 70$	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO		; grise	JUMP'	70$60$:	TCLR.L	D0:#0		; dj affich en plein ?	JUMP',BC 70$		; oui => 70$	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO		; dgrise; Grise ou dgrise la touche (MET A JOUR).70$:	COMP.W	(A6)+OIOAPP,#DBOX_SAUVE	JUMP',NE 90$	TEST.L	D1:#1	JUMP',BC 80$	TSET.L	D0:#1		; dj affich en gris ?	JUMP',BS 90$		; oui => 90$	LOAD.W	D2,#11!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO		; grise	JUMP'	90$80$:	TCLR.L	D0:#1		; dj affich en plein ?	JUMP',BC 90$		; oui => 90$	LOAD.W	D2,#11!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO		; dgrise90$:	POPM.L	D1..D4,A2..A4	RET00$:	.B	0,-1	.EVEN;----------\\; IOEDITSYN >;----------/; Vrifie si la syntaxe d'un nom de fichier et correcte.; in	A3.L	^nom de fichier; out	EQ	syntaxe ok;	NE	pas correct; mod	D7.WIOEDITSYN:	PUSHM.L	D2..D4,A2..A4	FOS	?WHAT		; D3 <-- type du nom de fichier	JUMP',NE ERROR$	LOAD.B	D2,D3	CLR.B	D4	TCLR.L	D2:#BWHLOGI	TCLR.L	D2:#BWHNETW	JUMP',BS NET$	FOS	?TYPEUNIT	; D3/D4 <-- type/attributs du pilote	JUMP',NE ERROR$	LOAD.B	D4,#2^BWHUNIT!2^BWHREP	COMP.B	D3,#TYPMM	JUMP',NE NET$	CLR.B	D4NET$:	COMP.B	D4,D2ERROR$:	POPM.L	D2..D4,A2..A4	RET;----------\\; IOEDITIFP >;----------/; Vrifie si le nom (sans l'extension) contient un "."; pour indiquer un dbut d'extension.; in	D2.W	rang (0/1); out	D2.W	rang (0/1);	D7.W	EQ si contient un "." ou "!"; mod	D2.L, D7.WIOEDITIFP:	PUSHM.L	D3,A3,A4	LOAD.L	A3,#(A6)+OIONAM10$:	LOAD.B	D3,(A3+)	JUMP',EQ 15$	COMP.B	D3,#SPACE	JUMP',EQ 12$	COMP.B	D3,#TAB	JUMP',EQ 12$	COMP.B	D3,#'/	JUMP,NE 10$12$:	LOAD.B	(A3)-1,#'_	JUMP	10$15$:	LOAD.W	D7,#1		; D7 <-- pas de "."	TEST.W	D2		; dite le nom ?	JUMP,NE 90$		; non => 90$	LOAD.L	A3,#(A6)+OIONAM	LOAD.L	A4,A320$:	TEST.B	(A4+)	JUMP,NE 20$30$:	COMP.L	A4,A3	JUMP',EQ 90$	LOAD.B	D3,(-A4)	COMP.B	D3,#':	JUMP',EQ 90$	COMP.B	D3,#'.	JUMP',EQ 40$	COMP.B	D3,#'!	JUMP,NE 30$40$:	CLR.B	(A4)		; coupe aprs l'extension	TEST.B	(A6)+OIOFLG+0:#BDBIOFULL-24 ; dite l'extension ?	JUMP',BS 60$		; oui => 60$				; non =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP'	80$60$:	LOAD.L	A4,#(A6)+OIOEXT	LOAD.B	(A4+),D3	; efface l'extension	CLR.B	(A4)	LOAD.W	D2,#1		; D2 <-- dite l'extension80$:	CLR.W	D7		; D7 <-- le nom contenait un "."90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOEDITSEP >;----------/; Spare le nom en deux (nom/extension).; in	(A6)+OIOPNA	^nom complet;	(A6)+OIOPEX	^extension(s) (utile si le nom complet n'a pas d'extension);	D4.L		fanions; out	(A6)+OIOOLD	nom complet original (pour annule);	(A6)+OIONAM	nom;	(A6)+OIOEXT	extension; mod	D7.WIOEDITSEP:	PUSHM.L	D3,A2..A4	LOAD.L	A2,(A6)+OIOPNA	; A2 <-- ^buffer contenant le nom complet	LOAD.L	A3,#(A6)+OIOOLD05$:	LOAD.B	(A3+),(A2+)	; OIOOLD <-- nom original	JUMP,NE 05$	LOAD.L	A2,(A6)+OIOPNA	; A2 <-- ^buffer contenant le nom complet	LOAD.L	A3,#(A6)+OIONAM	LOAD.L	A4,A310$:	LOAD.B	D3,(A2+)	LIB	?MINMAJ	LOAD.B	(A4+),D3	; OIONAM <-- nom complet	JUMP,NE 10$20$:	COMP.L	A4,A3	JUMP',EQ 40$	LOAD.B	D3,(-A4)	COMP.B	D3,#':	JUMP',EQ 40$	COMP.B	D3,#'.	JUMP',EQ 25$	COMP.B	D3,#'!	JUMP,NE 20$25$:	LOAD.L	A3,#(A6)+OIOEXT	LOAD.B	(A3+),(A4+)	; OIOEXT <-- "." ou "!"	CLR.B	(A4)-1		; OIONAM <-- nom sans l'extension30$:	LOAD.B	(A3+),(A4+)	; OIOEXT <-- extension	JUMP,NE 30$	JUMP'	90$40$:	LOAD.L	A3,#(A6)+OIOEXT	CLR.B	(A3)	CALL	IOEDITEXT	; A2 <-- ^extension	JUMP',NE 90$	COMP.B	(A2),#'*	JUMP',NE 50$	INC.L	A2		; A2 <-- ^aprs l'toile50$:	LOAD.B	D3,(A2+)	LIB	?MINMAJ	LOAD.B	(A3+),D3	; OIOEXT <-- extension	JUMP,NE 50$90$:	POPM.L	D3,A2..A4	RET;----------\\; IOEDITASS >;----------/; Assemble le nom et l'extension.; in	(A6)+OIONAM	nom;	(A6)+OIOEXT	extension; out	(A6)+OIOPNA	^nom complet; mod	D7.WIOEDITASS:	PUSHM.L	D3,A3,A4	LOAD.L	A3,(A6)+OIOPNA	LOAD.L	A4,#(A6)+OIONAM10$:	LOAD.B	(A3+),(A4+)	; buffer <-- nom	JUMP,NE 10$	TEST.B	(A6)+OIONAM	; nom existe ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A3,(A6)+OIOPNA	LOAD.L	A4,#(A6)+OIOEXT	LOAD.W	D3,#1		; D3 <-- force	LIB	?ADDEXT		; buffer <-- ajoute l'extension90$:	POPM.L	D3,A3,A4	RET;----------\\; IOEDITOLD >;----------/; Remet le nom original.; in	(A6)+OIOOLD	nom complet original (pour annule); out	(A6)+OIOPNA	^nom complet; mod	D7.WIOEDITOLD:	PUSHM.L	A2,A3	LOAD.L	A2,(A6)+OIOPNA	; A2 <-- ^buffer contenant le nom complet	LOAD.L	A3,#(A6)+OIOOLD10$:	LOAD.B	(A2+),(A3+)	; OIOPNA <-- nom original	JUMP,NE 10$	POPM.L	A2,A3	RET;----------\\; _DBOX_MAJ >;==========/; Demande s'il faut mettre  jour.; in	D1.W	numro de l'appel;	D2.W	mode d'ouverture de la dbox;	D3.L	numro de la zone (D3.W) et flags (BDBIOQUIT si "quitte");	D4.L	fanions;	D5.L	position centre de la dbox (si D2:#BDBPOS);	A1.L	^<lg>icnes (si D3:#BDBIOICO);	A2.L	^<lg>table d'objets de l'utilisateur (si D3:#BDBIOOBJ);	A3.L	^textes de description, voir (*);	A5.L	^nom du fichier <0>; out	D3.W	dernire touche (F0/F1/F4);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.W_DBOX_MAJ:	PUSHM.L	D0..D2,D5,A0..A6	CALL	IOOPEVAR	; A6 <-- ^variables	JUMP,NE 95$	CALL	IOMAJTXT	; A3 <-- ^texte<0>	LIB	?BUZZ		; signal qq chose de spcial !	LOAD.L	A0,#R16"TDBMAJ	CALL	IODBOPEN	; construit et ouvre la dbox	JUMP,NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUINON	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 80$	COMP.W	D3,#F1		; OUI ?	JUMP',EQ 80$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	DBOX_	CLOSE		; ferme la DBOX90$:	CALL	IOCLOVAR	; rend la mmoire des variables95$:	POPM.L	D0..D2,D5,A0..A6	TEST.W	D7		; retour EQ/NE	RET;---------\\; IOMAJTXT >;---------/; Construit le(s) texte(s).; in	D3.L	numro et flags;	A3.L	^textes de description, voir (*);	A5.L	^nom  diter; out	A3.L	^texte<0>; mod	D7.W, A3.LIOMAJTXT:	PUSHM.L	D2,D4,A2,A4,A5	LOAD.L	A2,A5		; A2 <-- ^nom  diter	LOAD.L	A5,A3		; A5 <-- ^(*)	LOAD.L	A3,#(A6)+OIOTXT; Construit la premire ligne "Mise  jour de l'image".	LOAD.L	A4,#R16"01$	CALL	PUTTEXTE	; buffer <-- "Mise  jour"	TEST.B	(A2)		; nom existe ?	JUMP',EQ 20$		; non => 20$				; oui =>	LOAD.L	A4,#R16"02$	CALL	PUTTEXTE	; buffer <-- "de"	LOAD.L	A4,A2	CALL	PUTFILE		; buffer <-- nom du fichier	LOAD.B	D2,#'M	JUMP'	25$20$:	LOAD.W	D4,#1	CALL	SEARCHTXT	; A4 <-- ^[M,F] mot	LOAD.B	D2,(A4)	CALL	PUTARTCONT	; buffer <-- "de l'image"25$:	LOAD.B	(A3+),#CR; Construit la deuxime ligne "contenue dans la page numro 1".	LOAD.W	D4,#2	CALL	SEARCHTXT	; A4 <-- ^[M,F] mot	TEST.B	(A4)	JUMP,EQ 40$	LOAD.L	A4,#R16"03$	CALL	PUTTEXTE	; buffer <-- "contenu"	COMP.B	D2,#'F	JUMP',NE 30$	LOAD.B	(A3+),#'e	; buffer <-- fminin30$:	COMP.B	D2,#'a	JUMP',LO 32$	LOAD.B	(A3+),#'s	; buffer <-- pluriel32$:	LOAD.L	A4,#R16"04$	CALL	PUTTEXTE	; buffer <-- "dans"	LOAD.W	D4,#2	CALL	SEARCHTXT	; A4 <-- ^[M,F] mot	CALL	PUTARTDEF	; buffer <-- "la page"	LOAD.L	A4,#R16"05$	CALL	PUTTEXTE	; buffer <-- "numro"	LOAD.W	D4,D3	CALL	PUTNUM		; buffer <-- "00"	LOAD.B	(A3+),#CR; Construit la troisime ligne "avant de reprendre la nouvelle image ?".40$:	LOAD.L	A4,#R16"06$	CALL	PUTTEXTE	; buffer <-- "avant de"	TEST.L	D3:#BDBIOQUIT	JUMP,BS 50$	LOAD.L	A4,#R16"07$	CALL	PUTTEXTE	; buffer <-- "reprendre"	LOAD.W	D4,#1	CALL	SEARCHTXT	; A4 <-- ^[M,F] mot	LOAD.B	D2,(A4+)	PUSH.L	A4	LOAD.L	A4,#R16"11$	COMP.B	D2,#'f	JUMP',EQ 44$	LOAD.L	A4,#R16"10$	COMP.B	D2,#'m	JUMP',EQ 44$	LOAD.L	A4,#R16"09$	COMP.B	D2,#'F	JUMP',EQ 44$	LOAD.L	A4,#R16"08$44$:	CALL	PUTTEXTE	; buffer <-- "le nouveau"	POP.L	A4	CALL	PUTTEXTE	; buffer <-- "image"	JUMP'	55$50$:	LOAD.L	A4,#R16"12$	CALL	PUTTEXTE	; buffer <-- "quitter"55$:	LOAD.L	A4,#R16"13$	CALL	PUTTEXTE	; buffer <-- "?"	LOAD.L	A3,#(A6)+OIOTXT	; A3 <-- ^texte<0>	POPM.L	D2,D4,A2,A4,A5	RET01$:	.ASCIZ	"Mise  jour "02$:	.ASCIZ	"de "03$:	.ASCIZ	"contenu"04$:	.ASCIZ	" dans "05$:	.ASCIZ	" numro "06$:	.ASCIZ	"avant de "07$:	.ASCIZ	"reprendre "08$:	.ASCIZ	"le nouveau "09$:	.ASCIZ	"la nouvelle "10$:	.ASCIZ	"les nouveaux "11$:	.ASCIZ	"les nouvelles "12$:	.ASCIZ	"quitter"13$:	.ASCIZ	" ?"	.EVEN;-------------\\; _DBOX_QUITTE >;=============/; Demande s'il faut quitter.; in	D1.W	numro de l'appel;	D2.W	mode d'ouverture de la dbox;	D3.L	flags;	D4.L	fanions;	D5.L	position centre de la dbox (si D2:#BDBPOS);	A1.L	^<lg>icnes (si D3:#BDBIOICO);	A2.L	^<lg>table d'objets de l'utilisateur (si D3:#BDBIOOBJ);	A3.L	^textes de description, voir (*); out	D3.W	dernire touche (F1/F4);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.W_DBOX_QUITTE:	PUSHM.L	D0..D2,D5,A0..A6	CALL	IOOPEVAR	; A6 <-- ^variables	JUMP,NE 95$	CALL	IOQUITTETXT	; A3 <-- ^texte<0>	LIB	?BUZZ		; signal qq chose de spcial !	LOAD.L	A0,#R16"TDBOUINON	CALL	IODBOPEN	; construit et ouvre la dbox	JUMP,NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUINON	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; OUI ?	JUMP',EQ 80$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	DBOX_	CLOSE		; ferme la DBOX90$:	CALL	IOCLOVAR	; rend la mmoire des variables95$:	POPM.L	D0..D2,D5,A0..A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; IOQUITTETXT >;------------/; Construit le(s) texte(s).; in	A3.L	^textes de description, voir (*); out	A3.L	^texte<0>; mod	D7.W, A3.LIOQUITTETXT:	PUSHM.L	D4,A4,A5	LOAD.L	A5,A3		; A5 <-- ^(*)	LOAD.L	A3,#(A6)+OIOTXT	LOAD.L	A4,#R16"01$	CALL	PUTTEXTE	; buffer <-- "Voulez-vous quitter"	LOAD.L	A4,A5	CALL	PUTTEXTE	; buffer <-- "DESSIN"	LOAD.L	A4,#R16"02$	CALL	PUTTEXTE	; buffer <-- "?"	LOAD.L	A3,#(A6)+OIOTXT	; A3 <-- ^texte<0>	POPM.L	D4,A4,A5	RET01$:	.ASCIZ	"Voulez-vous quitter le logiciel "02$:	.ASCIZ	" ?"	.EVEN;--------------\\; _DBOX_DETRUIT >;==============/; Demande s'il faut quitter.; in	D1.W	numro de l'appel;	D2.W	mode d'ouverture de la dbox;	D3.L	flags;	D4.L	fanions;	D5.L	position centre de la dbox (si D2:#BDBPOS);	A0.L	^texte @ "Dtruit @ TOTO ?" (si D3:#BDBIOTXT);	A1.L	^<lg>icnes (si D3:#BDBIOICO);	A2.L	^<lg>table d'objets de l'utilisateur (si D3:#BDBIOOBJ);	A3.L	^textes de description, voir (*);	A5.L	^nom du fichier <0>; out	D3.W	dernire touche (F1/F4);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.W_DBOX_DETRUIT:	PUSHM.L	D0..D2,D5,A0..A6	CALL	IOOPEVAR	; A6 <-- ^variables	JUMP,NE 95$	CALL	IODETRUITTXT	; A3 <-- ^texte<0>	LIB	?BUZZ		; signal qq chose de spcial !	LOAD.L	A0,#R16"TDBOUINON	CALL	IODBOPEN	; construit et ouvre la dbox	JUMP,NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUINON	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1		; OUI ?	JUMP',EQ 80$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	DBOX_	CLOSE		; ferme la DBOX90$:	CALL	IOCLOVAR	; rend la mmoire des variables95$:	POPM.L	D0..D2,D5,A0..A6	TEST.W	D7		; retour EQ/NE	RET;-------------\\; IODETRUITTXT >;-------------/; Construit le(s) texte(s).; in	D3.L	flags;	A0.L	^texte @ "Dtruit @ TOTO ?" (si D3:#BDBIOTXT);	A3.L	^textes de description, voir (*); out	A3.L	^texte<0>; mod	D7.W, A3.LIODETRUITTXT:	PUSHM.L	D4,A4,A5	LOAD.L	A3,#(A6)+OIOTXT	LOAD.L	A4,#R16"01$	CALL	PUTTEXTE	; buffer <-- "Dtruit"	TEST.L	D3:#BDBIOTXT	JUMP',BC 30$	LOAD.L	A4,A0	CALL	PUTTEXTE	; buffer <-- texte supplmentaire	LOAD.B	(A3+),#SPACE30$:	LOAD.L	A4,A5	CALL	PUTFILE		; buffer <-- "TOTO"	LOAD.L	A4,#R16"02$	CALL	PUTTEXTE	; buffer <-- "?"	LOAD.L	A3,#(A6)+OIOTXT	; A3 <-- ^texte<0>	POPM.L	D4,A4,A5	RET01$:	.ASCIZ	"Dtruit "02$:	.ASCIZ	" ?"	.EVEN;-------------\\; _DBOX_EFFACE >;=============/; Demande s'il faut effacer.; in	D1.W	numro de l'appel;	D2.W	mode d'ouverture de la dbox;	D3.L	numro de la zone (D3.W) et flags;	D4.L	fanions;	D5.L	position centre de la dbox (si D2:#BDBPOS);	A1.L	^<lg>icnes (si D3:#BDBIOICO);	A2.L	^<lg>table d'objets de l'utilisateur (si D3:#BDBIOOBJ);	A3.L	^textes de description, voir (*);	A5.L	^nom du fichier <0>; out	D3.W	dernire touche (F0/F1/F4);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.W_DBOX_EFFACE:	PUSHM.L	D0..D2,D5,A0..A6	CALL	IOOPEVAR	; A6 <-- ^variables	JUMP,NE 95$	CALL	IOEFFACETXT	; A3 <-- ^texte<0>	LIB	?BUZZ		; signal qq chose de spcial !	LOAD.L	A0,#R16"TDBOUINON	CALL	IODBOPEN	; construit et ouvre la dbox	JUMP,NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OUINON	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 80$	COMP.W	D3,#F1		; OUI ?	JUMP',EQ 80$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	DBOX_	CLOSE		; ferme la DBOX90$:	CALL	IOCLOVAR	; rend la mmoire des variables95$:	POPM.L	D0..D2,D5,A0..A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; IOEFFACETXT >;------------/; Construit le(s) texte(s).; in	D3.L	numro et flags;	A3.L	^textes de description, voir (*);	A5.L	^nom  diter; out	A3.L	^texte<0>; mod	D7.W, A3.LIOEFFACETXT:	PUSHM.L	D2,D4,A2,A4,A5	LOAD.L	A2,A5		; A2 <-- ^nom  diter	LOAD.L	A5,A3		; A5 <-- ^(*)	LOAD.L	A3,#(A6)+OIOTXT; Construit la premire ligne "Efface l'image contenue".	LOAD.L	A4,#R16"01$	CALL	PUTTEXTE	; buffer <-- "Efface"	TEST.B	(A2)		; nom existe ?	JUMP',EQ 20$		; non => 20$				; oui =>	LOAD.L	A4,A2	CALL	PUTFILE		; buffer <-- nom du fichier	LOAD.B	D2,#'M	JUMP'	25$20$:	LOAD.W	D4,#1	CALL	SEARCHTXT	; A4 <-- ^[M,F] mot	LOAD.B	D2,(A4)	CALL	PUTARTDEF	; buffer <-- "l'image"25$:	LOAD.W	D4,#2	CALL	SEARCHTXT	; A4 <-- ^[M,F] mot	TEST.B	(A4)	JUMP,EQ 50$	LOAD.L	A4,#R16"02$	CALL	PUTTEXTE	; buffer <-- "contenu"	COMP.B	D2,#'F	JUMP',NE 28$	LOAD.B	(A3+),#'e28$:	LOAD.B	(A3+),#CR; Construit la deuxime ligne "dans la page numro 1".	LOAD.L	A4,#R16"03$	CALL	PUTTEXTE	; buffer <-- "dans"	LOAD.W	D4,#2	CALL	SEARCHTXT	; A4 <-- ^[M,F] mot	CALL	PUTARTDEF	; buffer <-- "la page"	LOAD.L	A4,#R16"04$	CALL	PUTTEXTE	; buffer <-- "numro"	LOAD.W	D4,D3	CALL	PUTNUM		; buffer <-- "00"50$:	LOAD.L	A4,#R16"05$	CALL	PUTTEXTE	; buffer <-- "?"	LOAD.L	A3,#(A6)+OIOTXT	; A3 <-- ^texte<0>	POPM.L	D2,D4,A2,A4,A5	RET01$:	.ASCIZ	"Efface "02$:	.ASCIZ	" contenu"03$:	.ASCIZ	"dans "04$:	.ASCIZ	" numro "05$:	.ASCIZ	" ?"	.EVEN;---------\\; IODBOPEN >;---------/; Construit et ouvre la dbox.; in	D2.W	mode d'ouverture de la dbox;	D3.L	lg max des noms de fichiers et flags;	D4.L	fanions;	D5.L	position centre de la dbox (si D2:#BDBPOS);	A0.L	^3 tables d'objets;	A1.L	^<lg>icnes (si D3:#BDBIOICO);	A2.L	^<lg>table d'objets de l'utilisateur (si D3:#BDBIOOBJ);	A3.L	^texte<CR>texte<CR>texte<0>; out	D5.L	canal de la dbox;	D7.W	erreur; mod	D5.L, D7.WIODBOPEN:	PUSHM.L	D0..D3,A1..A5	LOAD.L	A4,#(A6)+OIOTAB	; A4 <-- ^buffer pour table	LOAD.L	A5,A4; Construit les 4 premiers .W relatifs.	LOAD.W	(A4+),#8	; buffer <-- ^objets (relatif)	CLR.W	(A4+)		; buffer <-- ^soft-keys (relatif)	CLR.W	(A4+)		; buffer <-- ^icnes (relatif)	CLR.W	(A4+)		; buffer <-- ^rserve (relatif); Construit les premiers textes fixes.20$:	TEST.B	(A3)	JUMP',EQ 28$	LOAD.B	(A4+),#ODBTEXT22$:	COMP.B	(A3+),#CR	JUMP',EQ 24$	LOAD.B	(A4+),(A3)-1	JUMP,NE 22$	DEC.L	A3	DEC.L	A424$:	CLR.B	(A4+)	LOAD.B	(A4+),#ODBCR	JUMP	20$28$:; Construit les premiers objets spcifiques.	LOAD.B	D1,(A0+)30$:	LOAD.B	(A4+),(A0+)	COMP.B	(A0)-1,#ODBXFILE	JUMP',NE 32$	COMP.B	(A0),#7	JUMP',NE 32$	CALL	IODBOPLX	; D0 <-- extension la plus longue	LOAD.B	(A4+),D0	INC.L	A0	DEC.B	D132$:	DEC.B	D1	JUMP,NE 30$; Construit les objets de l'utilisateur.	TEST.L	D3:#BDBIOOBJ	JUMP',BC 48$	LOAD.B	D1,(A2+)	JUMP',EQ 48$40$:	LOAD.B	(A4+),(A2+)	DEC.B	D1	JUMP,NE 40$48$:; Construit les deuximes objets spcifiques.	LOAD.B	D1,(A0+)50$:	LOAD.B	(A4+),(A0+)	DEC.B	D1	JUMP,NE 50$; Construit les noms des soft-keys.	LOAD.L	D1,A4	SUB.L	D1,A5	LOAD.W	(A5)+2,D1	; buffer <-- ^soft-keys (relatif)	LOAD.B	D1,(A0+)60$:	LOAD.B	(A4+),(A0+)	DEC.B	D1	JUMP,NE 60$; Construit les icnes des soft-keys.	TEST.L	D3:#BDBIOICO	JUMP',BC 78$	LOAD.L	D1,A4	SUB.L	D1,A5	LOAD.W	(A5)+4,D1	; buffer <-- ^icnes (relatif)	LOAD.B	D1,(A1+)70$:	LOAD.B	(A4+),(A1+)	DEC.B	D1	JUMP,NE 70$78$:; Ouvre la dbox dans l'cran.	LOAD.L	A2,A5		; A2 <-- ^table construite	TCLR.L	D2:#BDBEXTEND	; D2 <-- mode (pour vraiment ouvrir)	LOAD.L	D3,D5		; D3 <-- position si D2:#BDBPOS	DBOX_	OPEN		; ouvre la dbox	POPM.L	D0..D3,A1..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; IODBOPLX >;---------/; Cherche la longueur de l'extension la plus longue.; in	D3.L	lg max des noms de fichiers et flags; out	D0.W	lg max d'une extension; mod	D0.L, D7.WIODBOPLX:	PUSHM.L	D1,A3	LOAD.L	A3,(A6)+OIOPEX	; A3 <-- ^extension(s)	CLR.W	D0		; D0 <-- lg max	TEST.L	D3:#BDBIOEXT1	JUMP',BS 20$	TEST.L	D3:#BDBIOEXTM	JUMP,BC 80$20$:	TEST.B	(A3)	JUMP',EQ 80$	LOAD.W	D1,#-1	COMP.B	(A3+),#'*	; si "*.TOTO" => ne compte pas "*" !	JUMP',EQ 30$	DEC.L	A330$:	INC.W	D1		; D1 <-- lg d'une extension	TEST.B	(A3+)	JUMP,NE 30$	COMP.W	D0,D1	JUMP',HS 40$	LOAD.W	D0,D1		; D0 <-- lg max40$:	TEST.L	D3:#BDBIOEXTM	JUMP,BS 20$80$:	INC.W	D0	COMP.W	D0,#7	JUMP',HS 90$	LOAD.W	D0,#790$:	POPM.L	D1,A3	RETTDBPREND:TDBPREND1:	.B	LDBPREND1	.B	ODBCR	.B	ODBLABEL,0	.B	ODBXFILE,24,LIONAM,2^(13-8),KEYDBOX/H'100,0,TDBNORM	.B	ODBTABX,24+1	.B	ODBLABEL,1	.B	ODBXFILE,7,LIONAM,2^(13-8),KEYDBOX/H'100,1,TDBNORM	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	"LISTE"	.B	ODBCR,ODBCRLDBPREND1	=	.-TDBPREND1-1TDBPREND2:	.B	LDBPREND2	.B	ODBCR,ODBCR	.B	ODBLABEL,10	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  PREND  "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	0LDBPREND2	=	.-TDBPREND2-1TDBPREND3:	.B	LDBPREND3	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Liste"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENLDBPREND3	=	.-TDBPREND3-1TDBAJOUTE:TDBAJOUTE1:	.B	LDBAJOUTE1	.B	ODBCR	.B	ODBLABEL,0	.B	ODBXFILE,24,LIONAM,2^(13-8),KEYDBOX/H'100,0,TDBNORM	.B	ODBTABX,24+1	.B	ODBLABEL,1	.B	ODBXFILE,7,LIONAM,2^(13-8),KEYDBOX/H'100,1,TDBNORM	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	"LISTE"	.B	ODBCR,ODBCRLDBAJOUTE1	=	.-TDBAJOUTE1-1TDBAJOUTE2:	.B	LDBAJOUTE2	.B	ODBCR,ODBCR	.B	ODBLABEL,10	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" AJOUTE "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	0LDBAJOUTE2	=	.-TDBAJOUTE2-1TDBAJOUTE3:	.B	LDBAJOUTE3	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Ajoute"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Liste"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENLDBAJOUTE3	=	.-TDBAJOUTE3-1TDBSAUVE:TDBSAUVE1:	.B	LDBSAUVE1	.B	ODBCR	.B	ODBLABEL,0	.B	ODBXFILE,31,LIONAM,2^(13-8),KEYDBOX/H'100,0,TDBNORM	.B	ODBTABX,31+1	.B	ODBLABEL,1	.B	ODBXFILE,7,LIONAM,2^(13-8),KEYDBOX/H'100,1,TDBNORM	.B	ODBCR,ODBCRLDBSAUVE1	=	.-TDBSAUVE1-1TDBSAUVE2:	.B	LDBSAUVE2	.B	ODBCR,ODBCR	.B	ODBLABEL,10	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  SAUVE  "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBLABEL,11	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" MET A JOUR "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	0LDBSAUVE2	=	.-TDBSAUVE2-1TDBSAUVE3:	.B	LDBSAUVE3	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Met  jour"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENLDBSAUVE3	=	.-TDBSAUVE3-1TDBEXTRAIT:TDBEXTRAIT1:	.B	LDBEXTRAIT1	.B	ODBCR	.B	ODBLABEL,0	.B	ODBXFILE,24,LIONAM,2^(13-8),KEYDBOX/H'100,0,TDBNORM	.B	ODBTABX,24+1	.B	ODBLABEL,1	.B	ODBXFILE,7,LIONAM,2^(13-8),KEYDBOX/H'100,1,TDBNORM	.B	ODBCR,ODBCRLDBEXTRAIT1	=	.-TDBEXTRAIT1-1TDBEXTRAIT2:	.B	LDBEXTRAIT2	.B	ODBCR,ODBCR	.B	ODBLABEL,10	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  SAUVE  "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	0LDBEXTRAIT2	=	.-TDBEXTRAIT2-1TDBEXTRAIT3:	.B	LDBEXTRAIT3	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENLDBEXTRAIT3	=	.-TDBEXTRAIT3-1TDBMAJ:TDBMAJ1:	.B	LDBMAJ1	.B	ODBCRLDBMAJ1		=	.-TDBMAJ1-1TDBMAJ2:	.B	LDBMAJ2	.B	ODBCR,ODBCR	.B	ODBBOX,0,'O,TDBMEV	.ASCIZ	"   OUI   "	.B	ODBCR,ODBCR	.B	ODBBOX,0,'N,TDBNORM	.ASCIZ	"   NON   "	.B	ODBTEXT	.ASCIZ	"      "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	" ANNULE "	.B	0LDBMAJ2		=	.-TDBMAJ2-1TDBMAJ3:	.B	LDBMAJ3	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Oui"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Non"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENLDBMAJ3		=	.-TDBMAJ3-1TDBOUINON:TDBOUINON1:	.B	LDBOUINON1	.B	ODBCRLDBOUINON1	=	.-TDBOUINON1-1TDBOUINON2:	.B	LDBOUINON2	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	"  OUI  "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	"  NON  "	.B	0LDBOUINON2	=	.-TDBOUINON2-1TDBOUINON3:	.B	LDBOUINON3	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Oui"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Non"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENLDBOUINON3	=	.-TDBOUINON3-1TKEY_IOEDIT:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_IOEDIT	.W	F1,F2,F3,CR,0		DOKF1-TKEY_IOEDIT	.W	F4,F5,F6,0		DOKF4-TKEY_IOEDIT	.W	F7,F8,F9,0		DOKF7-TKEY_IOEDIT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_IOEDIT	.W	0TKEY_OUINON:	.W	F1,F2,F3,'O,'Y,0	DOKF1-TKEY_OUINON	.W	F4,F5,F6,'N,0		DOKF4-TKEY_OUINON	.W	END,F0,F13,F14,F15,0	DOKF0-TKEY_OUINON	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_OUINON	.W	0;-------\\; PUTNUM >;=======/; Met un nom de fichier.; in	A3.L	^buffer;	D4.W	nombre; out	A3.L	^plus loin; mod	D7.W, A3.LPUTNUM:	PUSHM.L	D2..D4	AND.L	D4,#H'FFFF	; D4 <-- nombre binaire	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A3+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	POPM.L	D2..D4	RET;--------\\; PUTFILE >;========/; Met un nom de fichier entre guillemets.; in	A3.L	^buffer;	A4.L	^nom du fichier<0>; out	A3.L	^plus loin; mod	D7.W, A3.LPUTFILE:	PUSHM.L	D2,D3,A4	LOAD.B	(A3+),#'"	LOAD.W	D2,#2^BAFXMA	; D2 <-- en majuscules	LOAD.W	D3,#-1		; D3 <-- pas de lg max	EX.L	A3,A4	LIB	?PUTXFILE	EX.L	A4,A3	LOAD.B	(A3+),#'"	POPM.L	D2,D3,A4	RET;---------\\; PUTTEXTE >;=========/; Met un texte.; in	A3.L	^buffer;	A4.L	^texte<0>; out	A3.L	^plus loin; mod	D7.W, A3.LPUTTEXTE:	PUSH.L	A410$:	LOAD.B	(A3+),(A4+)	; buffer <-- texte	JUMP,NE 10$	DEC.L	A3	POP.L	A4	RET;----------\\; SEARCHTXT >;==========/; Cherche un texte d'aprs son rang.; in	D4.W	rang (0..n);	A5.L	^description (*); out	A4.L	^texte<0>; mod	D7.W, A4.LSEARCHTXT:	PUSH.W	D4	LOAD.L	A4,A510$:	DEC.W	D4	JUMP',NS 90$20$:	TEST.B	(A4+)		; A4 <-- ^texte suivant	JUMP,NE 20$	JUMP	10$90$:	POP.W	D4	RET;----------\\; PUTARTDEF >;==========/; Met un article dfini (le, la) suivit d'un mot.; in	A3.L	^buffer;	A4.L	^[M,F]mot<0>; out	A3.L	^plus loin; mod	D7.W, A3.LPUTARTDEF:	PUSH.L	A2	LOAD.L	A2,#R16"ARTDEF$	CALL	PUTARTICLE	POP.L	A2	RETARTDEF$:	.ASCIZ	"le "		; masculin singulier si consonne	.ASCIZ	"l'"		; masculin singulier si voyelle	.ASCIZ	"la "		; fminin singulier si consonne	.ASCIZ	"l'"		; fminin singulier si voyelle	.ASCIZ	"les "		; masculin pluriel si consonne	.ASCIZ	"les "		; masculin pluriel si voyelle	.ASCIZ	"les "		; fminin pluriel si consonne	.ASCIZ	"les "		; fminin pluriel si voyelle	.EVEN;------------\\; PUTARTINDEF >;============/; Met un article indfini (un, une) suivit d'un mot.; in	A3.L	^buffer;	A4.L	^[M,F]mot<0>; out	A3.L	^plus loin; mod	D7.W, A3.LPUTARTINDEF:	PUSH.L	A2	LOAD.L	A2,#R16"ARTINDEF$	CALL	PUTARTICLE	POP.L	A2	RETARTINDEF$:	.ASCIZ	"un "		; masculin singulier si consonne	.ASCIZ	"un "		; masculin singulier si voyelle	.ASCIZ	"une "		; fminin singulier si consonne	.ASCIZ	"une "		; fminin singulier si voyelle	.ASCIZ	"des "		; masculin pluriel si consonne	.ASCIZ	"des "		; masculin pluriel si voyelle	.ASCIZ	"des "		; fminin pluriel si consonne	.ASCIZ	"des "		; fminin pluriel si voyelle	.EVEN;-----------\\; PUTARTCONT >;===========/; Met un article contract (du, de la) suivit d'un mot.; in	A3.L	^buffer;	A4.L	^[M,F]mot<0>; out	A3.L	^plus loin; mod	D7.W, A3.LPUTARTCONT:	PUSH.L	A2	LOAD.L	A2,#R16"ARTCONT$	CALL	PUTARTICLE	POP.L	A2	RETARTCONT$:	.ASCIZ	"du "		; masculin singulier si consonne	.ASCIZ	"de l'"		; masculin singulier si voyelle	.ASCIZ	"de la "	; fminin singulier si consonne	.ASCIZ	"de l'"		; fminin singulier si voyelle	.ASCIZ	"des "		; masculin pluriel si consonne	.ASCIZ	"des "		; masculin pluriel si voyelle	.ASCIZ	"des "		; fminin pluriel si consonne	.ASCIZ	"des "		; fminin pluriel si voyelle	.EVEN;-----------\\; PUTARTICLE >;-----------/; Met un article suivit d'un mot.; in	A4.L	^[M,F]mot<0>;	A2.L	^table "MMFF";	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LPUTARTICLE:	PUSHM.L	D3,D4,A2,A4	CLR.W	D4		; D4 <-- rang	LOAD.B	D3,(A4+)	; D3 <-- M/F/m/f	COMP.B	D3,#'m	JUMP',EQ PLUR$	COMP.B	D3,#'f	JUMP',NE SING$PLUR$:	ADD.W	D4,#4		; D4 <-- +4 si pluriel	LIB	?MINMAJ		; D3 <-- M/FSING$:	COMP.B	D3,#'F	JUMP',NE MASC$	ADD.W	D4,#2		; D4 <-- +2 si fmininMASC$:	LOAD.B	D3,(A4)	LIB	?MINMAJ	CALL	IFVOYELLE	JUMP',NE CONS$	INC.W	D4		; D4 <-- +1 si voyelleCONS$:	CALL	ARTSKIP		; A2 <-- ^articleXFART$:	LOAD.B	(A3+),(A2+)	; buffer <-- article	JUMP,NE XFART$	DEC.L	A3XFMOT$:	LOAD.B	(A3+),(A4+)	; buffer <-- mot	JUMP,NE XFMOT$	DEC.L	A3	POPM.L	D3,D4,A2,A4	RET;--------\\; ARTSKIP >;--------/; Saute un ou plusieurs .ASCIZ; in	D4.W	nb de .ASCIZ  sauter;	A2.L	^table; out	A2.L	^plus loin; mod	D4.L, A2.LARTSKIP:LOOP$:	DEC.W	D4	JUMP',NS EXIT$SKIP$:	TEST.B	(A2+)	JUMP,NE SKIP$	JUMP	LOOP$EXIT$:	RET;----------\\; IFVOYELLE >;----------/; Regarde si un caractre est une voyelle.; in	D3.B	caractre (en minuscule); out	EQ	si c'est une voyelle; mod	FIFVOYELLE:	COMP.B	D3,#'A	JUMP',EQ 90$	COMP.B	D3,#'E	JUMP',EQ 90$	COMP.B	D3,#'I	JUMP',EQ 90$	COMP.B	D3,#'O	JUMP',EQ 90$	COMP.B	D3,#'U	JUMP',EQ 90$	COMP.B	D3,#'H;	JUMP',EQ 90$90$:	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs LIB,?EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>90$:	POP.L	A3	RET;---------\\; IOOPEVAR >;=========/; Demande de la mmoire pour les variables.; in	D1.W	numro de l'appel;	D3.L	flags; out	A6.L	^variables;	D7.W	erreur; mod	D7.W, A6.LIOOPEVAR:	PUSHM.L	D1..D4,D6,A4	LOAD.W	D2,D1	LOAD.L	D4,#LGVARIO	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP',NE 90$	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.W	(A6)+OIOAPP,D2	LOAD.L	(A6)+OIOFLG,D3	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OIOPDI	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !90$:	POPM.L	D1..D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; IOCLOVAR >;=========/; Rend la mmoire pour les variables.; in	A6.L	^variables; out	-; mod	-IOCLOVAR:	PUSHM.L	D1,D7,A4	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend mmoire des variables	POPM.L	D1,D7,A4	RET	.END