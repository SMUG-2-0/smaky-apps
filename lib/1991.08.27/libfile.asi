	.SBTTL	LIBFILE;----------\; _OEXECUTE >;==========/; Excute un programme dans la mme fentre, et attend qu'il; soit termin.; in	A3.L	^ligne de commande (qui sera tendue !);		si (A3)+0:#7=1, n'affiche pas l'image;		si (A3)+1:#7=1, n'efface pas la fentre; out	D7.W	erreur; mod	D7.W_OEXECUTE:	PUSHM.L	D2..D4,A0,A3,A5	TSET.B	(A6)+OFLAGS:#BCACHE ; fentre "pre" cache	LOAD.B	D2,(A3)+1	; D2 <-- bit de (A3)+1	TCLR.B	(A3)+1:#7	SL.W	D2,#8	LOAD.B	D2,(A3)		; D2 <-- bit de (A3)+0	TCLR.B	(A3):#7	LOAD.L	A5,#0		; A5 <-- pas de smaphore	LOAD.L	D4,#2^BEXOVER	; D4 <-- mode sans image	TEST.L	D2:#7	JUMP',BS 20$	TSET.L	D4:#BEXIMA	; D4 <-- affiche l'image	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface la fentre20$:	LOAD.W	D4,(A6)+OPRNUM	; D4 <-- no precessus pre	FOS	?NEXECUTE	; excute le programme ...	TCLR.B	(A6)+OFLAGS:#BCACHE ; fentre "pre" dcouverte	PUSH.W	D7	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAT	; A5 <-- ^smaphore +/- task	NTREL	?RACSEM	NTREL	?SSIGNAL	; signal une tche diffrente	NTREL	?RLASEM	TEST.L	D2:#7+8	JUMP',BS 80$	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface la fentre80$:	POP.W	D7	POPM.L	D2..D4,A0,A3,A5	RET	.IF	0	PUSHM.L	D2..D6,A0,A3..A5	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP,NE 90$		; non => 90$;;?	LOAD.L	A4,(A6)+OPDDIS	; A4 <-- ^descripteur de la fentre;;?	LOAD.L	D2,(A4)+ODFGCF	; D2 <-- gencar utilis (fst-)	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	D2,(A0)+OASKEY	; D2 <-- no clavier utilis	COMP.W	D2,(A6)+ONUKEY	; utilis actuellement ?	JUMP',EQ 20$		; oui => 20$	CLR.W	D2		; non => il ne faudra pas rassigner20$:	LOAD.W	D6,(A6)+OCHDIS	FOS	?CLOSE		; ferme la fentre (fait froid)JUMP,NE EXFAT1	LOAD.W	D6,(A6)+OCHKEY	FOS	?CLOSE		; ferme le clavierJUMP,NE EXFAT1	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	(A0)+OASKEY,#-1	; faudra refaire l'assignation !	TSET.B	(A6)+OFLAGS:#BCACHE ; fentre "pre" cache	LOAD.L	A5,#0		; A5 <-- pas de smaphore;;?	LOAD.L	D4,#2^BEXOVER!2^BEXOINS!2^BEXIMA	LOAD.L	D4,#2^BEXOVER!2^BEXIMA	LOAD.W	D4,(A6)+OPRNUM	; D4 <-- no precessus pre	FOS	?NEXECUTE	; excute le programme ...	TCLR.B	(A6)+OFLAGS:#BCACHE ; fentre "pre" dcouverte	PUSH.W	D7	LOAD.L	A3,#R16"NLDIS	; A3 <-- ^nom logique	LOAD.B	D3,#2^BOPWR!2^BOPRD	FOS	?OPEN		; ouvre l'cranJUMP,NE EXFAT4	LOAD.W	(A6)+OCHDIS,D6	LOAD.L	A3,#R16"NLKEY	; A3 <-- ^nom logique	LOAD.B	D3,#2^BOPRD	FOS	?OPEN		; ouvre le clavierJUMP,NE EXFAT4	LOAD.W	(A6)+OCHKEY,D6	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer pour ^descripteur	LOAD.L	D4,#4	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.W	D6,(A6)+OCHDIS	; D6 <-- canal cran	FOS	?RSTATUSJUMP,NE EXFAT5;;?	LOAD.L	A0,#(A6)+OBUWRI;;?	SR.L	D2,#8		; D2 <-- gencar initial (-fst);;?	LOAD.L	(A0+),D2;;?	LOAD.B	(A0)-4,#LOADGC;;?	LOAD.L	(A0+),D2;;?	LOAD.B	(A0)-4,#USEGC;;?	CALL	WRBUF		; remet le gencar initial;;?TEST.W D7;;?JUMP,NE EXFAT6	TEST.W	D2		; le pre avait-il le clavier ?	JUMP',EQ 60$		; non => 60$				; oui =>	LOAD.L	A3,#R16"NLKEY	; A3 <-- ^nom logique	LOAD.W	D3,(A6)+OPRNUM	; D3 <-- no processus	FOS	?VASSIGN	; A4 <-- ^nom physique du clavierJUMP,NE EXFAT6	CALL	GETNPH		; D3 <-- no clavier du "pre"	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	(A0)+OASKEY,#-1	; faudra refaire l'assignation !	CALL	_ASSKEY		; re-assigne le clavier60$:	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAT	; A5 <-- ^smaphore +/- task	NTREL	?RACSEM	NTREL	?SSIGNAL	; signal une tche diffrente	NTREL	?RLASEM	POP.W	D790$:	POPM.L	D2..D6,A0,A3..A5	RETEXFAT1:	.W	H'A042	.ASCIZ	"#1"	.EVEN	JUMP'	EXFATEXFAT2:	.W	H'A042	.ASCIZ	"#2"	.EVEN	JUMP'	EXFATEXFAT3:	.W	H'A042	.ASCIZ	"#3"	.EVEN	JUMP'	EXFATEXFAT4:	.W	H'A042	.ASCIZ	"#4"	.EVEN	JUMP'	EXFATEXFAT5:	.W	H'A042	.ASCIZ	"#5"	.EVEN	JUMP'	EXFATEXFAT6:	.W	H'A042	.ASCIZ	"#6"	.EVEN;	JUMP'	EXFATEXFAT:	.W	H'A042	.ASCIZ	" Erreur fatale dans ?OEXECUTE ...<CR>"	.EVEN	TRAP	#0	.ENDIF;--------\; PUTNWP  >;--------/; Met un numro d'un ou deux digits dcimaux dans un buffer.; in	A4.L	^buffer;	D4.W	numro; out	A4.L	^plus loin; mod	A4.LPUTNWP:	PUSHM.L	D3,D4	COMP.B	D4,#10		; plus d'un digit ?	JUMP',LO 40$		; non => 40$	CLR.L	D3		; oui =>	LOAD.B	D3,D4	DIV.WU	D3,#10	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	; met les dizaines	SWAP.W	D3	LOAD.B	D4,D3		; D4 <-- reste40$:	ADD.B	D4,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D4	; met les units	POPM.L	D3,D4	RET;---------\; _FCHANGE >;=========/; Permet de changer une disquette.; in	A3.L	^nom de l'unit  changer; out	D7.W	erreur (ERKSTO si touche END comme rponse); mod	D7.W_FCHANGE:	PUSHM.L	D3,D4	FOS	?LRELEASE	; release l'unit	JUMP,NE 90$	LOAD.W	D4,D3		; D4 <-- global/local	LIB	?MAFTIM	.ASCIZ	/<'F>Changez de disquette, puis appuyez sur une touche ... /	.ASCIZ	/<'E>Please change floppy-disk, and strike any key ... /	.ASCIZ	/<'D>... /	.B	0	.EVEN	LIB	?GETCAR		; attend une touche ...	PUSH.W	D7	LIB	?AFCR		; passe  la ligne	POP.W	D7	JUMP',NS 90$		; erreur grave ds GETCAR => 90$	LOAD.W	D7,#ERKSTO	COMP.W	D3,#END		; touche (END) seule ?	JUMP',EQ 90$		; oui => 90$	LOAD.W	D3,D4		; D3 <-- global/local	FOS	?LENTER		; r-init l'unit90$:	POPM.L	D3,D4	RET;--------\; _GETUPH >;========/; Cherche le nom physique correspondant  un nom logique; quelconque. Cherche en premire priorit en fonction du; processus appelant, puis en deuxime priorit en fonction; d'une assignation globale (pour tous).; in	A3.L	^nom physique ou logique; out	A4.L	^nom physique; mod	D7.W, A4.L_GETUPH:	PUSHM.L	D3,D4,D5,A3	CALL	GETPNUM		; D4 <-- no processus pre	LOAD.W	D5,D4	LOAD.L	A4,A310$:	CLR.W	D7		; D7 <-- ok	LOAD.L	A3,A4		; A3 <-- ^nom	COMP.B	(A3),#'$	; nom commence par "$" ?	JUMP',EQ 90$		; oui => 90$	LOAD.W	D3,D5		; D3 <-- processus appelant	FOS	?VASSIGN	; cherche assignation locale	JUMP,EQ 10$	CLR.W	D3		; D3 <-- tout le monde	FOS	?VASSIGN	; cherche assignation globale	JUMP,EQ 10$90$:	POPM.L	D3,D4,D5,A3	RET;--------\; _GETLGF >;========/; Calcul la longueur en bytes d'un fichier quelconque.; in	A4.L	^BD du fichier (rendu par FOS,?ARGS); out	D4.L	longueur en bytes; mod	D4.L_GETLGF:	PUSH.L	D0	LOAD.L	D4,(A4)+OBALG	; D4 <-- longueur en blocs	SL.L	D4,#8		; D4 <-- idem mais en bytes	SUB.L	D4,#LGBLK	; D4 <-- nb de blocs entier	CLR.L	D0	LOAD.W	D0,(A4)+OBALGB	; D0 <-- nb bytes dernier bloc	JUMP',NE 50$		; lg = zro ?	LOAD.W	D0,#LGBLK	; oui => bloc plein (!)50$:	ADD.L	D4,D0		; D4 <-- lg totale en bytes	POP.L	D0	RET;--------\; _SKPNAM >;========/; Cherche le nom suivant dans une commande.; in	A3.L	^nom de fichier; out	D7.W	zro;	 A3.L	 ^nom suivant;	D7.W	ERLSYN (pas de suivant);	 A3.L	 inchang; mod	D7.W, A3.L_SKPNAM:	PUSHM.L	D3,A0	LOAD.W	D7,#ERLSYN	; D7 <-- erreur	LOAD.L	A0,A3		; A0 <-- ^nom10$:	LOAD.B	D3,(A0+)	; D3 <-- caractre suivant	JUMP',EQ 90$	COMP.B	D3,#CR		; fin du nom ?	JUMP',EQ 90$		; oui => 90$	COMP.B	D3,#SPACE	JUMP',EQ 20$	COMP.B	D3,#TAB	JUMP,NE	10$20$:	COMP.B	(A0+),#SPACE	; saute si plusieurs SPACEs	JUMP,EQ	20$	COMP.B	(A0)-1,#TAB	JUMP,EQ	20$	LOAD.B	D3,(-A0)	; D3 <-- 1er car. nom suivant	JUMP',EQ 90$	COMP.B	D3,#CR		; nom suivant existe ?	JUMP',EQ 90$		; non => 90$				; oui =>	LOAD.L	A3,A0		; A3 <-- ^nom suivant	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,A0	RET;----------\; _IFSWITCH >;==========/; Vrifie si un nom de fichier est termin par un switch; donn.; in	A3.L	^nom de fichier;	D3.B	switch cherch (lettre maj. ou min.); out	EQ	switch existe		(D7=zro);	NE	switch n'existe pas	(D7=ERLSYN); mod	D7.W_IFSWITCH:	PUSHM.L	D0,D3,A3	CALL	_MINMAJ		; D3 <-- switch MAJUSCULE	LOAD.B	D0,D3		; D0 <-- switch cherch10$:	LOAD.B	D3,(A3+)	; D3 <-- caractre suivant	JUMP',EQ 80$	COMP.B	D3,#CR		; fin du nom ?	JUMP',EQ 80$		; oui => 80$	COMP.B	D3,#SPACE	JUMP',EQ 80$	COMP.B	D3,#METASWI	; switch ?	JUMP,NE 10$		; non => 10$				; oui =>	LOAD.B	D3,(A3)		; D3 <-- lettre aprs switch	CALL	_MINMAJ		; D3 <-- lettre MAJUSCULE	COMP.B	D0,D3		; switch trouv ?	JUMP,NE 10$		; non => 10$				; oui =>	CLR.W	D7		; D7 <-- zro pour retour EQ	JUMP'	90$80$:	LOAD.W	D7,#ERLSYN	; D7 <-- valeur pour retour NE90$:	POPM.L	D0,D3,A3	TEST.W	D7		; retour EQ/NE (si interne LIB)	RET;--------\; _SWITCH >;========/; Cherche tous les switchs trouvs aprs un nom.; Dtecte les cas suivants:;   -	switch qui n'est pas une lettre => ERLSYN;   -	deux fois le mme switch => ERLSYN; in	A3.L	^nom de fichier; out	D3.L	bits pour les lettres trouves (0..25);	D7.W	erreur (ERLSYN); mod	D3.L, D7.W_SWITCH:	PUSHM.L	D0,A3	CLR.L	D0		; D0 <-- switch(s) trouv(s)	CLR.W	D7		; D7 <-- ok10$:	LOAD.B	D3,(A3+)	; D3 <-- caractre suivant	JUMP',EQ 80$	COMP.B	D3,#CR		; fin du nom ?	JUMP',EQ 80$		; oui => 80$	COMP.B	D3,#SPACE	JUMP',EQ 80$	COMP.B	D3,#METASWI	; switch ?	JUMP,NE 10$		; non => 10$				; oui =>	LOAD.B	D3,(A3)		; D3 <-- lettre aprs switch	CALL	_MINMAJ		; D3 <-- lettre MAJUSCULE	COMP.B	D3,#'A	JUMP',LO 50$	COMP.B	D3,#'Z		; lettre ?	JUMP',HI 50$		; non => 50$				; oui =>	SUB.B	D3,#'A		; D3 <-- 0..25	TSET.L	D0:D3		; D0 <-- ajoute le bon bit	JUMP,BC	10$		; switch jamais trouv => 10$50$:	LOAD.W	D7,#ERLSYN	; D7 <-- valeur pour retour NE	JUMP	10$80$:	LOAD.L	D3,D0		; D3 <-- bit(s) trouv(s)	POPM.L	D0,A3	RET;---------\; _AFFILE  >;=========/; Affiche un nom de fichier.; La clef est transforme en XXXX` !; in	A3	^nom du fichier  afficher; out	D7.W	erreur; mod	D7.W_AFFILE:	PUSHM.L	D2,D3	LOAD.W	D2,#2^BAFXMA	; D2 <-- en majuscules	LOAD.W	D3,#-1		; D3 <-- pas de lg max	CALL	_AFXFILE	; affiche le nom	POPM.L	D2,D3	RET;---------\; _AFXFILE >;=========/; Affiche un nom de fichier avec diffrents modes.; in	D2.W	modes (BAFX..);	D3.W	lg max;	A3	^nom du fichier  afficher; out	D3.W	lg restante (lg max - lg utilise);	D7.W	erreur; mod	D3.L, D7.W_AFXFILE:	PUSH.L	A4	LOAD.L	A4,#(A6)+OBUWRI	; A4 <-- ^buffer	CALL	_PUTXFILE	; OBUWRI <-- nom	LOAD.L	A0,A4	CALL	WRBUF	POP.L	A4	RET;----------\; _PUTXFILE >;==========/; Met dans un buffer un nom de fichier avec diffrents modes.; in	D2.W	modes (BAFX..);	D3.W	lg max;	A3	^nom du fichier  afficher;	A4.L	^buffer; out	A4.L	^plus loin;	D3.W	lg restante (lg max - lg utilise);	D7.W	erreur; mod	D3.L, D7.W, A4.L_PUTXFILE:	PUSHM.L	D4,A2,A3	LOAD.W	D4,D3		; D4 <-- lg max	LOAD.L	A2,A3		; A2 <-- ^noms des dossiers10$:	LOAD.B	D3,(A3+)	JUMP',EQ 12$	COMP.B	D3,#CR		; terminateur ?	JUMP',EQ 12$		; oui => 12$	COMP.B	D3,#SPACE	JUMP',EQ 12$	COMP.B	D3,#METASWI	JUMP,NE 10$12$:	COMP.L	A3,A2	JUMP',EQ 14$	COMP.B	(-A3),#':	JUMP,NE 12$	INC.L	A3		; A3 <-- ^dbut du nom (aprs v. dossiers)14$:	TEST.L	D2:#BAFXND	; affiche les dossiers ?	JUMP',BS 30$		; non => 30$20$:	COMP.L	A2,A3	JUMP',EQ 30$	LOAD.B	D3,(A2+)	CALL	AFXFCAR		; affiche "unit:rep:rep:"	JUMP	20$30$:	TEST.L	D2:#BAFXCL	; affiche la clef ?	JUMP',BS 40$		; oui => 40$	LOAD.L	A2,A332$:	LOAD.B	D3,(A2+)	JUMP',EQ 40$	COMP.B	D3,#CR		; terminateur ?	JUMP',EQ 40$		; oui => 40$ (pas de clef)	COMP.B	D3,#SPACE	JUMP',EQ 40$	COMP.B	D3,#METASWI	JUMP',EQ 40$	COMP.B	D3,#METACLEF	; clef au dbut du nom ?	JUMP,NE 32$		; non => 32$				; oui =>	LOAD.L	A3,A2		; A3 <-- ^aprs la clef	LOAD.B	D3,#'X	CALL	AFXFCAR		; affiche "X`"	LOAD.B	D3,#METACLEF	CALL	AFXFCAR40$:	LOAD.B	D3,(A3+)	JUMP',EQ 80$	COMP.B	D3,#CR		; terminateur ?	JUMP',EQ 80$		; oui => 90$	COMP.B	D3,#SPACE	JUMP',EQ 80$	COMP.B	D3,#METASWI	JUMP',EQ 80$	COMP.B	D3,#'.	JUMP',NE 50$	TEST.L	D2:#BAFXNE	; affiche l'extension ?	JUMP',BS 80$		; non => 80$50$:	CALL	AFXFCAR		; affiche le nom du fichier	JUMP	40$80$:	CLR.B	(A4)		; buffer <-- terminateur	LOAD.W	D3,D4		; D3 <-- lg restante	POPM.L	D4,A2,A3	RET;--------\\; AFXFCAR >;--------/; Affiche un caractre pour _AFXFILE.; in	D2.W	mode;	D3.B	caractre;	D4.W	lg restante; out	D4.W	lg restante; mod	D3.L, D4.L, D7.WAFXFCAR:	TEST.W	D4	JUMP',NE 10$	RET10$:	DEC.W	D4	TEST.L	D2:#BAFXMA	JUMP',BC 20$	CALL	_MINMAJ		; D3 <-- lettre majuscule20$:	TEST.L	D2:#BAFXMI	JUMP',BC 30$	COMP.B	D3,#'A	JUMP',LO 30$	COMP.B	D3,#'Z	JUMP',HI 30$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule30$:	LOAD.B	(A4+),D3	; buffer <-- caractre	RET;---------\; _FCREATE >;=========/; Cre un fichier, puis fait un open en ouverture exclusive.;	fichier/D  dtruit sans demander si existe dj;	fichier/A  appond (open-write puis spos max);	fichier/N  rponse "non" si question pose; in	A3.L	^nom du fichier;	D3.L	attributs; out	D6.W	canal;	D7.W	erreur; mod	D6.W, D7.W_FCREATE:	PUSHM.L	D0,D3,D4,D5,A3	LOAD.L	D0,D3		; D0 <-- attributs	NTREL	?GETTIM		; D4 <-- timeout actuel	LOAD.W	D5,D4		; D5 <-- timeout actuel	LOAD.B	D3,#'Q	LIB	?IFSWITCH	; fichier/Q ?	JUMP',NE 05$		; non => 50$				; oui =>	LOAD.W	D4,#50*2	; D4 <-- 2 secondes	NTREL	?SETTIM		; modifie le timeout05$:	LOAD.B	D3,#'A	LIB	?IFSWITCH	; fichier/A ?	JUMP,EQ 50$		; oui => 50$10$:	LOAD.L	D3,D0		; D3 <-- attributs	LOAD.B	D4,#TYPRAND	; D4 <-- type random	FOS	?CREATE	JUMP,EQ 30$		; cration ok => 30$	COMP.W	D7,#ERFAEX	JUMP,NE 90$	LOAD.B	D3,#'N	LIB	?IFSWITCH	; fichier/N ?	JUMP,EQ 25$		; oui => 25$				; non =>	LOAD.B	D3,#'D	LIB	?IFSWITCH	; fichier/D ?	JUMP',EQ 20$		; oui => 20$				; non =>	LIB	?MAFTIM	.ASCIZ	/<'F>Supprime l'ancien /	.ASCIZ	/<'E>Delete old /	.ASCIZ	/<'D>Lschen /	.B	0	.EVEN	LIB	?AFFILE		; affiche le nom du fichier	LIB	?AFTIM	.ASCIZ	/ ? /	.EVEN	LIB	?YESNO		; attend une rponse ...	JUMP',NE 90$		; non => 90$20$:				; oui =>	FOS	?DELETE	JUMP',NE 90$		; si indestructible => 90$	JUMP	10$25$:	LOAD.W	D7,#ERFAEX	JUMP'	90$30$:	LOAD.B	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP'	90$50$:	LOAD.B	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE 90$	LOAD.B	D3,#-1	LOAD.L	D4,#-1		; D3,D4 <-- pos maximale	FOS	?SPOS	COMP.W	D7,#EROUTF	JUMP',NE 90$	CLR.W	D7		; D7 <-- ok90$:	PUSH.W	D7	LOAD.W	D4,D5		; D4 <-- timeout initial	NTREL	?SETTIM		; remet timeout comme avant	POP.W	D7	POPM.L	D0,D3,D4,D5,A3	RET;--------\; _ADDEXT >;========/; Ajoute l'extension par dfaut  un nom de fichier.; in	A3.L	^nom de fichier;	A4.L	^extension  ajouter (termine par zro);	D3.W	mode	0 => laisse si dj;			1 => force; out	D7.W	erreur; mod	D7.W_ADDEXT:	PUSHM.L	D2..D5,A2..A4	LOAD.W	D2,D3		; D2 <-- mode	LOAD.L	A2,A3		; A2 <-- ^nom	CALL	70$		; A3 <-- ^fin du nom	COMP.L	A2,A3		; nom existe ?	JUMP,EQ	80$		; non => 80$	COMP.B	(A3)-1,#':	; nom termin par ":" (#printer:) ?	JUMP,EQ 80$		; oui => c'est un streamer	CLR.W	D5		; D5 <-- flag10$:	LOAD.B	D3,(-A3)	; D3 <-- caractre prcdent	COMP.B	D3,#':		; ":" trouv ?	JUMP',NE 11$		; non => 11$	INC.W	D5		; oui => met flag  un11$:	COMP.B	D3,#'#		; "#" trouv ?	JUMP',NE 12$		; non => 12$	TEST.W	D5		; oui => ":" trouv avant ?	JUMP,EQ	80$		; non => c'est un streamer12$:	COMP.L	A2,A3		; sommes-nous au debut du nom ?	JUMP,NE	10$		; non => reboucle	LOAD.L	A3,A2		; A3 <-- ^debut du nom	CALL	70$		; A3 <-- ^fin du nom20$:	LOAD.B	D3,(-A3)	; D3 <-- caractre prcdent	COMP.B	D3,#':		; ":" trouv ?	JUMP',EQ 25$		; oui => 25$	COMP.B	D3,#'.		; "." trouv ?	JUMP',EQ 30$		; oui => 30$	COMP.B	D3,#'!		; "!" trouv ?	JUMP',EQ 30$		; oui => 30$	COMP.L	A2,A3		; est-on au debut ?	JUMP,NE	20$		; non => reboucle25$:	CALL	70$		; va  la fin	JUMP'	35$30$:	COMP.W	D2,#1		; faut-il forcer l'extension ?	JUMP,NE	80$		; non => fait rien35$:	COMP.B	(A4),#'.	; extension commence par "." ?	JUMP',EQ 40$		; oui => 40$	COMP.B	(A4),#'!	; extension commence par "!" ?	JUMP',EQ 40$		; oui => 40$				; non =>	LOAD.B	(A3+),#'. 	; met le point au nom40$:	LOAD.B	(A3+),(A4+)	; met l'extension	JUMP,NE	40$80$:	LOAD.L	A3,A2		; A3 <-- ^debut du nom	CALL	70$		; A3 <-- ^fin du nom	CLR.B	(A3)		; force le terminateur <0>	POPM.L	D2..D5,A2..A4	CLR.W	D7		; D7 <-- toujours ok	RET; Va  la fin du nom, quelque soit le terminateur.70$:	LOAD.B	D3,(A3+)	; D3 <-- caractre suivant	JUMP,EQ 75$	COMP.B	D3,#CR	JUMP,EQ	75$	COMP.B	D3,#SPACE	JUMP,EQ	75$	COMP.B	D3,#'/	JUMP,EQ	75$	COMP.B	D3,#TAB	JUMP,NE	70$75$:	DEC.L	A3	RET	.END