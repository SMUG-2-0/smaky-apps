	.SBTTL	LIBSYNT;--------\; _PLAY   >;========/; Joue une mlodie o chaque note peut tre un accord de; trois notes au maximum.; Exemple de table:;	.WWWBB	NOTE+3*OCTAVE+SGMI+SILENCE+SILENCE,50,50;	.WWWBB	BRUIT+16,SILENCE,SILENCE,100,20;	.W	0; in	A4.L	^table d'accords; out	D7.W	erreur; mod	D7.W_PLAY:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,#R16"NLSYNT	LOAD.B	D3,#2^BOPWR	FOS	?OPEN		; ouvre le synthtiseur	JUMP',NE 90$20$:	TEST.W	(A4)		; fin de la table ?	JUMP',EQ 80$		; oui => 80$				; non =>	PUSH.L	A4	LOAD.L	A4,#(A6)+OBUSYN	LOAD.B	(A4),#BIPACCORD	LOAD.L	D4,#1	FOS	?WRBYTE		; crit byte BIPACCORD	POP.L	A4	JUMP',NE 80$	LOAD.L	D4,#2+2+2+1+1	; D4 <-- longueur .WWWBB	FOS	?WRBYTE		; crit bytes  nn nn nn e t	JUMP',NE 80$	ADD.L	A4,D4		; A4 <-- ^suivant dans table	JUMP	20$80$:	PUSH.W	D7	FOS	?CLOSE		; ferme le synthtiseur	POP.W	D790$:	POPM.L	D3,D4,D6,A3,A4	RET;--------\; _ACCORD >;========/; Joue un accord de trois notes au maximum.; in	D3.W	premire note;	D4.W	deuxime note;	D5.W	troisime note;	D6.W	bits 0..7: dure totale;		bits 8..15: enveloppe; out	D7.W	erreur; mod	D7.W_ACCORD:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A4,#(A6)+OBUSYN+1	LOAD.B	(A4)+0,#BIPACCORD	LOAD.W	(A4)+1,D3	; <nn>	LOAD.W	(A4)+3,D4	; <nn>	LOAD.W	(A4)+5,D5	; <nn>	LOAD.W	(A4)+7,D6	; <e> puis <t>	LOAD.L	A3,#R16"NLSYNT	LOAD.B	D3,#2^BOPWR	FOS	?OPEN		; ouvre le synthtiseur	JUMP',NE 90$	LOAD.L	D4,#1+2+2+2+1+1	FOS	?WRBYTE		; "crit" un accord	PUSH.W	D7	FOS	?CLOSE		; ferme le synthtiseur	POP.W	D790$:	POPM.L	D3,D4,D6,A3,A4	RET;--------\; _BUZZ   >;========/; in	-; out	D7.W	erreur; mod	D7.W_BUZZ:	PUSHM.L	D3	LOAD.B	D3,#BIPBIG	; D3 <-- beep standard	CALL	_BEEP	POPM.L	D3	RET;--------\; _BEEP   >;========/; in	D3.B	valeur du beep; out	D7.W	erreur; mod	D7.W_BEEP:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.B	D4,D3		; D4 <-- "valeur"	LOAD.L	A3,#R16"NLSYNT	LOAD.B	D3,#2^BOPWR	FOS	?OPEN		; ouvre le synthtiseur	JUMP',NE 90$	LOAD.L	A4,#(A6)+OBUSYN	; A4 <-- ^valeur du beep	LOAD.B	(A4),D4		; met la valeur en (A4)	LOAD.L	D4,#1		; D4 <-- un beep  crire	FOS	?WRBYTE	PUSH.W	D7	FOS	?CLOSE		; ferme le synthtiseur	POP.W	D790$:	POPM.L	D3,D4,D6,A3,A4	RET	.END