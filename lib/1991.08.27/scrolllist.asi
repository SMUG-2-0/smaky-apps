	.SBTTL	SCROLLLIST;--------------\\; _SCROLL_LMOVE >;==============/; Dplace l'ascenseur ou une case jusqu' ce qu'un bouton; soit press ou relch.; Si la souris n'est pas dans le rectangle, on revient tout; de suite avec une erreur (D7=ERDIOUT).; OSLCYS.W contient -1 lorsque la case vide tout en haut; est slectionne.; in	D4.L		position de la souris;	A5.L		^variables de la liste;	A0.L		^description de la fentre;	(A5)+OSLADL.L	adresse routine liste, voir (*);	(A5)+OSLADA.L	adresse routine liste, voir (%); out	(A5)+OSLCYS.W	case slectionne (-1, 0..OSLCYN-1);	D7.W		erreur (souris pas dans la liste); mod	D7.W_SCROLL_LMOVE:	PUSHM.L	D1..D4	LOAD.B	D3,#NOCURS	LIB	?AFCAR		; enlve le curseur	CALL	DETCASE		; D3 <-- case o est la souris	JUMP,EQ CASE$	TEST.B	(A5)+OSLCABV	; cabine de l'ascenseur existe ?	JUMP',EQ VSKIP$		; non => VSKIP$	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASV	CALL	_SCROLL_MOVE	; dplace dans l'ascenseur vertical ?	POP.L	A5	JUMP',EQ VMOVE$VSKIP$:	LOAD.W	D7,#ERDIOUT	TEST.B	(A5)+OSLHOR	; ascenseur horizontal existe ?	JUMP,EQ EXIT$		; non => EXIT$	TEST.B	(A5)+OSLCABH	; cabine de l'ascenseur existe ?	JUMP,EQ EXIT$		; non => EXIT$	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASH	CALL	_SCROLL_MOVE	; dplace dans l'ascenseur horizontal ?	POP.L	A5	JUMP,EQ HMOVE$	JUMP	EXIT$VMOVE$:	COMP.W	D4,#SCROLLFUP	; flche en haut ?	JUMP,EQ VPRESS$	COMP.W	D4,#SCROLLFDOWN	; flche en bas ?	JUMP,EQ VPRESS$	COMP.W	D4,#SCROLLPUP	; page en haut ?	JUMP,EQ VPRESS$	COMP.W	D4,#SCROLLPDOWN	; page en bas ?	JUMP,EQ VPRESS$; Dplace l'ascenseur vertical selon un clic quelque part dans; la zone active.	LOAD.W	D3,(A5)+OSLASV+OSCPOSV ; est-on tout en haut ?	JUMP',EQ VPOS$		; oui => VPOS$	LOAD.W	D4,(A5)+OSLASV+OSCHTV	DEC.W	D4	COMP.W	D3,D4		; est-on tout en bas ?	JUMP',HS VDOWN$		; oui => VDOWN$	LOAD.W	D4,(A5)+OSLNBY	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- va au milieu	JUMP'	VPOS$VDOWN$:	LOAD.W	D3,(A5)+OSLCYN	DEC.W	D3		; D3 <-- va tout en basVPOS$:	LOAD.W	D2,(A5)+OSLCYS	; D2 <-- ancienne valeur de OSLCYS	SWAP.W	D2	LOAD.W	D2,(A5)+OSLCYA	; D2 <-- ancienne valeur de OSLCYA	LOAD.W	(A5)+OSLCYS,D3	CALL	MAJCYA		; OSLCYA <-- premire case  afficher	CLR.W	D1		; D1 <-- mode normal	CALL	MVCASE		; affiche toutes les cases	JUMP	OK$; Dplace l'ascenseur vertical tant que le bouton de la souris; est maintenu press dans la flche.VPRESS$:	LOAD.W	D7,#ERDIOUT	COMP.W	(A5)+OSLCYS,#-1	; est-on dans la case vide ?	JUMP,EQ EXIT$		; oui => EXIT$				; non =>	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la souris	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASV	CALL	_SCROLL_PRESS	; allume la flche up/down	POP.L	A5	LOAD.W	D3,(A5)+OSLCYS	CALL	_SCROLL_LINVCASE ; enlve la slection	COMP.W	D3,#-1	JUMP',NE VLOOP$	CLR.B	(A5)+OSLVII	; case vide teinteVLOOP$:	LOAD.W	D3,#+1		; D3 <-- +1 ligne	COMP.W	D4,#SCROLLFDOWN	JUMP',EQ VFP$	NEG.W	D3		; D3 <-- -1 ligne	COMP.W	D4,#SCROLLFUP	JUMP',EQ VFP$	LOAD.W	D3,(A5)+OSLNBY	; D3 <-- +1 page	COMP.W	D4,#SCROLLPDOWN	JUMP',EQ VFP$	NEG.W	D3		; D3 <-- -1 page;	COMP.W	D4,#SCROLLPUP;	JUMP',EQ VFP$VFP$:	ADD.W	D3,(A5)+OSLCYS	; D3 <-- nouvelle position	JUMP',NC VNOTUP$	CLR.W	D3VNOTUP$:	COMP.W	D3,(A5)+OSLCYN	JUMP',LO VNOTDOWN$	LOAD.W	D3,(A5)+OSLCYN	DEC.W	D3VNOTDOWN$:	COMP.W	D3,(A5)+OSLCYS	; position change ?	JUMP',EQ VNEXT$		; non => VNEXT$				; oui =>	LOAD.W	D2,(A5)+OSLCYS	; D2 <-- ancienne valeur de OSLCYS	SWAP.W	D2	LOAD.W	D2,(A5)+OSLCYA	; D2 <-- ancienne valeur de OSLCYA	LOAD.W	(A5)+OSLCYS,D3	CALL	MAJCYA		; OSLCYA <-- premire case  afficher	LOAD.W	D1,#1		; D1 <-- mode sans slection	CALL	MVCASE		; affiche toutes les cases	LOAD.W	(A5)+OSLASV+OSCPOSV,(A5)+OSLCYA	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASV	CALL	_SCROLL_UPDATE	; dplace l'ascenseur	POP.L	A5VNEXT$:	LIB	?IFCAR		; bouton relch ?	JUMP,NE VLOOP$		; non => VLOOP$				; oui =>	LOAD.W	D3,(A5)+OSLCYS	CALL	_SCROLL_LINVCASE ; remet la slection	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASV	CALL	_SCROLL_PRESS	; teint la flche up/down	POP.L	A5	LOAD.B	D3,#AFSCMO	LIB	?AFCAR		; remet la souris	JUMP	OK$; Dplace l'ascenseur horizontal selon un clic quelque part dans; la zone active.HMOVE$:	COMP.W	D4,#SCROLLFUP	; flche en haut ?	JUMP',EQ HPRESS$	COMP.W	D4,#SCROLLFDOWN	; flche en bas ?	JUMP',EQ HPRESS$				; dplacement =>	LOAD.W	(A5)+OSLCXA,(A5)+OSLASH+OSCPOSV	CALL	AFCASE		; affiche toutes les cases	JUMP	OK$; Dplace l'ascenseur horizontal tant que le bouton de la souris; est maintenu press dans la flche.HPRESS$:	LOAD.W	D7,#ERDIOUT	COMP.W	(A5)+OSLCYS,#-1	; est-on dans la case vide ?	JUMP,EQ EXIT$		; oui => EXIT$				; non =>	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASH	CALL	_SCROLL_PRESS	; allume la flche up/down	POP.L	A5	LOAD.W	D2,(A5)+OSLNBX	SR.W	D2,#1		; D2 <-- demi-largeur visibleHLOOP$:	LOAD.W	D3,(A5)+OSLCXA	COMP.W	D4,#SCROLLFUP	JUMP',EQ HFUP$				; descend =>	ADD.W	D3,D2	COMP.W	D3,(A5)+OSLASH+OSCHTV	JUMP',LO HGO$	LOAD.W	D3,(A5)+OSLASH+OSCHTV	DEC.W	D3	JUMP'	HGO$HFUP$:				; monte =>	SUB.W	D3,D2	JUMP',NC HGO$	CLR.W	D3HGO$:	COMP.W	D3,(A5)+OSLCXA	JUMP',EQ HNEXT$	LOAD.W	(A5)+OSLCXA,D3	CALL	AFCASE		; affiche toutes les cases	LOAD.W	(A5)+OSLASH+OSCPOSV,(A5)+OSLCXA	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASH	CALL	_SCROLL_UPDATE	; dplace l'ascenseur	POP.L	A5HNEXT$:	LIB	?IFCAR		; bouton relch ?	JUMP,NE HLOOP$		; non => HLOOP$				; oui =>	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASH	CALL	_SCROLL_PRESS	; teint la flche up/down	POP.L	A5	JUMP	OK$; Dplace la case montre par la souris tant que le bouton; est maintenu press.CASE$:	LOAD.W	D2,(A5)+OSLCYS	JUMP'	CASE4$CASE2$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE CASE8$		; non => CASE8$				; oui =>	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE CASE2$	SUB.W	D4,(A0)+ODFFX	JUMP,LO CASE2$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP,LO CASE2$	SWAP.W	D4	CALL	DETCASE		; D3 <-- case o est la sourisCASE4$:	COMP.W	D3,D2		; dans une autre case ?	JUMP,EQ CASE2$		; non => CASE2$				; oui =>	EX.L	D2,D3	CALL	_SCROLL_LINVCASE ; efface l'ancienne case	LOAD.W	D3,D2	CALL	_SCROLL_LINVCASE ; allume la nouelle case	JUMP	CASE2$CASE8$:	LOAD.W	(A5)+OSLCYS,D2	CLR.B	(A5)+OSLVII	; case vide teinte	COMP.W	D2,#-1	JUMP',NE OK$	SET.B	(A5)+OSLVII	; case vide allumeOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;----------------\\; _SCROLL_LUPDATE >;================/; Met  jour la liste et l'ascenseur.; On utilise cet appel lorsque la liste change ou bouge; par un vnement extrieur au module SCROLL.; Lorsque l'ascenseur bouge avec SCROLL_LMOVE, cet appel n'est pas; ncessaire.; in	A5.L		^variables de la liste;	A0.L		^description de la fentre;	(A5)+OSLADL.L	adresse routine liste, voir (*);	(A5)+OSLADA.L	adresse routine liste, voir (%);	(A5)+OSLCYN.W	nombre total de cases;	(A5)+OSLCXN.W	idem, horizontalement;	(A5)+OSLCYS.W	case slectionne (-1, 0..OSLCYN-1); out	(A5)+OSLCYA.W	premire case affiche;	(A5)+OSLCXA.W	idem, horizontalement;	D7.W		erreur; mod	D7.W_SCROLL_LUPDATE:	PUSH.W	D3	LOAD.B	D3,#NOCURS	LIB	?AFCAR		; enlve le curseur	CALL	MAJCYA		; OSLCYA <-- premire case  afficher	CALL	AFCASE		; affiche toutes les cases	CALL	AFASCV		; affiche l'ascenseur vertical	CALL	AFASCH		; affiche l'ascenseur horizontal	POP.W	D3	CLR.W	D7		; retour EQ	RET; (*)	OSLADL.L doit contenir l'adresse d'une routine extrieure;	au module SCROLL qui doit ragir comme suit :;; Donne le pointeur au texte  afficher dans une case.;; in	A6.L	^vos variables;	D3.W	rang de la case (0..OSLCYN-1); out	D3.W	zro;	A3.L	^contenu de la case termin par <0> ou <CR>;	D7.W	erreur si la case est vide; mod	D3.L, D7.W, A3.L;; ATTENTION:	Cette routine ne doit en aucun cas modifier;		d'autres registres !; (%)	OSLADA.L doit contenir l'adresse d'une routine extrieure;	au module SCROLL qui doit ragir comme suit :;; Affiche le texte dans une case. Il est conseill de mettre un; espace avant le texte et un autre aprs. Il faut toujours; afficher un nombre de caractres exactement gal  D4.;; in	A6.L	^vos variables;	D3.W	rang de la case (0..OSLCYN-1);	D4.W	nb de caractres;	D5.W	rang du premier caractre  afficher; out	D3.W	zro; mod	D3.L, D7.W;; ATTENTION:	Cette routine ne doit en aucun cas modifier;		d'autres registres !; Il faut utiliser OSLADL.L ou OSLADA.L selon vos besions.; Celle qui n'est pas utilise doit contenir zro.;--------------\\; _SCROLL_LDRAW >;==============/; Dessine le rectangle avec la cage de l'ascenseur vide.; L'cran sous le rectangle est effac automatiquement.; in	A5.L		^variables de la liste;	A0.L		^description de la fentre;	(A5)+OSLVID.B	1 => case vide en haut;	(A5)+OSLHOR.B	1 => ascenseur horizontal;	(A5)+OSLPOS.L	coin sup/gauche (y;x);	(A5)+OSLDIM.L	dimensions (dy;dx);	A3.L		^texte pour case vide (si OSLVID=1); out	(A5)+OSLDIM.L	dimensions arrondies;	D7.W		erreur (ERDIOUT = trop petit); mod	D7.W_SCROLL_LDRAW:	PUSHM.L	D2..D4,A3,A4	LOAD.B	D3,#NOCURS	LIB	?AFCAR		; enlve le curseur	CALL	_SCROLL_LDIM	; calcul les dimensions	JUMP,NE EXIT$; Efface puis dessine le rectangle extrieur.	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_SLCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_SLSET	LIB	?COLORSR	; donne la couleur du cadre	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A5)+OSLPOS	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.L	D4,(A5)+OSLDIM	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'intrieur du rectangle	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine le rectangle; Dessine ventuellement les lignes de sparations pour la case vide.	TEST.B	(A5)+OSLVID	; case vide tout en haut ?	JUMP,EQ 50$		; non => 50$				; oui =>	LOAD.L	D3,(A5)+OSLPOS	SWAP.W	D3	ADD.W	D3,(A5)+OSLCAR+0	INC.W	D3	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A5)+OSLDIM+2	LIB	?DRSEG		; dessine trait horizontal; Affiche le texte dans la case vide tout en haut.	LOAD.L	D3,(A5)+OSLPOS	ADD.W	D3,#LGSCROLL-1	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.W	D4,(A5)+OSLCAR+0	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; dessine trait vertical	LOAD.L	D3,(A5)+OSLPOS	ADD.W	D3,#LGSCROLL	ADD.W	D3,(A5)+OSLCAR+2	ADD.W	D3,(A5)+OSLC1X	SWAP.W	D3	INC.W	D3	ADD.W	D3,(A5)+OSLC1Y	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A4,A3	LOAD.W	D3,#-140$:	INC.W	D3		; D3 <-- nb caractres	TEST.B	(A4+)	JUMP,NE 40$	COMP.W	D3,(A5)+OSLNBX	; dpasse  droite ?	JUMP',LO 45$		; non => 45$	LOAD.W	D3,(A5)+OSLNBX	; oui => tronque	DEC.W	D345$:	LIB	?STRING		; affiche le texte dans la case vide	CLR.B	(A5)+OSLVII	; case vide teinte; Dessine l'ascenseur  gauche du rectangle.50$:	LIB	?COLORPOP	LOAD.W	(A5)+OSLASV+OSCDEBL,(A5)+OSLPOS+2	LOAD.W	D4,(A5)+OSLPOS+0	TEST.B	(A5)+OSLVID	JUMP',EQ 52$	ADD.W	D4,(A5)+OSLCAR+0	INC.W	D452$:	LOAD.W	(A5)+OSLASV+OSCDEBO,D4	LOAD.W	D4,(A5)+OSLDIM+0	TEST.B	(A5)+OSLVID	JUMP',EQ 54$	SUB.W	D4,(A5)+OSLCAR+0	DEC.W	D454$:	TEST.B	(A5)+OSLHOR	JUMP',EQ 55$	SUB.W	D4,#LGSCROLL-155$:	INC.W	D4	LOAD.W	(A5)+OSLASV+OSCHTR,D4	CLR.B	(A5)+OSLASV+OSCHOR ; ascenseur vertical;;?	CLR.B	(A5)+OSLASV+OSCPAGE ; pas de pages	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASV	CALL	_SCROLL_DRAW	; dessine la cage de l'ascenseur	POP.L	A5	CLR.B	(A5)+OSLCABV	; cabine efface; Dessine l'ascenseur en bas du rectangle.	TEST.B	(A5)+OSLHOR	; ascenseur horizontal ?	JUMP',EQ OK$		; non => OK$				; oui =>	LOAD.W	D4,(A5)+OSLPOS+0	ADD.W	D4,(A5)+OSLDIM+0	SUB.W	D4,#LGSCROLL-1	LOAD.W	(A5)+OSLASH+OSCDEBL,D4	LOAD.W	D4,(A5)+OSLPOS+2	ADD.W	D4,#LGSCROLL-1	LOAD.W	(A5)+OSLASH+OSCDEBO,D4	LOAD.W	D4,(A5)+OSLDIM+2	SUB.W	D4,#LGSCROLL-2	LOAD.W	(A5)+OSLASH+OSCHTR,D4	SET.B	(A5)+OSLASH+OSCHOR ; ascenseur horizontal	CLR.B	(A5)+OSLASH+OSCPAGE ; pas de pages	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASH	CALL	_SCROLL_DRAW	; dessine la cage de l'ascenseur	POP.L	A5	CLR.B	(A5)+OSLCABH	; cabine effaceOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; _SCROLL_LDIM >;=============/; Arrondi les dimensions du rectangle extrieur en fonction; du caractre utilis. Les dimensions rendues sont toujours; plus petites ou gales aux dimensions fournies.; in	A5.L		^variables de la liste;	A0.L		^description de la fentre;	(A5)+OSLVID.B	1 => case vide en haut;	(A5)+OSLHOR.B	1 => ascenseur horizontal;	(A5)+OSLPOS.L	coin sup/gauche (y;x);	(A5)+OSLDIM.L	dimensions (dy;dx); out	(A5)+OSLDIM.L	dimensions arrondies;	D7.W		erreur (ERDIOUT = trop petit); mod	D7.W_SCROLL_LDIM:	PUSHM.L	D3,D4	LOAD.W	D7,#ERDIOUT	; D7 <-- trop petit,  priori; Mmorise les dimensions d'un caractre.	LOAD.W	(A5)+OSLC1X,(A0)+ODFC1X	LOAD.W	(A5)+OSLC1Y,(A0)+ODFC1Y	LOAD.W	(A5)+OSLC2Y,(A0)+ODFC2Y	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	; D4 <-- hauteur d'un caractre	LOAD.W	(A5)+OSLCAR+0,D4	LOAD.W	(A5)+OSLCAR+2,(A0)+ODFCX; Arrondi la largeur en fonction du caractre utilis.	CLR.L	D4	LOAD.W	D4,(A5)+OSLDIM+2	SUB.W	D4,#LGSCROLL	JUMP,LO EXIT$	COMP.W	D4,#LGSCROLL*4	JUMP',HS 10$	CLR.B	(A5)+OSLHOR	; ascenseur horizontal impossible10$:	DIV.WU	D4,(A5)+OSLCAR+2	COMP.W	D4,#3	JUMP,LO EXIT$	LOAD.W	(A5)+OSLNBX,D4	MUL.WU	D4,(A5)+OSLCAR+2	ADD.W	D4,#LGSCROLL	LOAD.W	(A5)+OSLDIM+2,D4; Arrondi la hauteur en fonction du caractre utilis.	CLR.W	D3	TEST.B	(A5)+OSLVID	; case vide tout en haut ?	JUMP',EQ 20$	ADD.W	D3,(A5)+OSLCAR+0	INC.W	D320$:	TEST.B	(A5)+OSLHOR	; ascenseur horizontal ?	JUMP',EQ 25$	ADD.W	D3,#LGSCROLL-125$:	CLR.L	D4	LOAD.W	D4,(A5)+OSLDIM+0	SUB.W	D4,D3	JUMP',LO EXIT$	COMP.W	D4,#LGSCROLL*4	JUMP',LO EXIT$	DEC.W	D4	DIV.WU	D4,(A5)+OSLCAR+0	COMP.W	D4,#3	JUMP',LO EXIT$	LOAD.W	(A5)+OSLNBY,D4	MUL.WU	D4,(A5)+OSLCAR+0	INC.W	D4	ADD.W	D4,D3	LOAD.W	(A5)+OSLDIM+0,D4	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; AFASCV  >;========/; Affiche l'ascenseur vertical si ncessaire.; in	(A5)+OSLCYN.W	nb de cases;	(A5)+OSLCYA.W	premire case affiche; out	-; mod	D7.WAFASCV:	PUSH.L	D4	LOAD.W	D4,(A5)+OSLCYN	SUB.W	D4,(A5)+OSLNBY	JUMP',LE 50$				; ascenseur avec cabine =>	INC.W	D4	LOAD.W	(A5)+OSLASV+OSCHTV,D4	TEST.B	(A5)+OSLCABV	; cabine dessine ?	JUMP',EQ 30$		; non => 30$				; oui =>	LOAD.W	D4,(A5)+OSLCYA	COMP.W	D4,(A5)+OSLASV+OSCPOSV ; cabine bouge ?	JUMP',EQ EXIT$		; non => EXIT$30$:	LOAD.W	(A5)+OSLASV+OSCPOSV,(A5)+OSLCYA	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASV	CALL	_SCROLL_UPDATE	; dessine la cabine	POP.L	A5	SET.B	(A5)+OSLCABV	JUMP'	EXIT$50$:				; ascenseur sans cabine =>	CLR.W	(A5)+OSLASV+OSCPOSV	CLR.W	(A5)+OSLASV+OSCHTV ; cabine pas ncessaire !	TEST.B	(A5)+OSLCABV	; cabine dessine ?	JUMP',EQ EXIT$		; non => EXIT$				; oui =>	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASV	CALL	_SCROLL_DRAW	; efface la cabine	POP.L	A5	CLR.B	(A5)+OSLCABVEXIT$:	POP.L	D4	RET;--------\\; AFASCH  >;========/; Affiche l'ascenseur horizontal si ncessaire.; in	(A5)+OSLCXN.W	nb de cases;	(A5)+OSLCXA.W	premire case affiche; out	-; mod	D7.WAFASCH:	PUSH.L	D4	TEST.B	(A5)+OSLHOR	; ascenseur horizontal existe ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.W	D4,(A5)+OSLCXN	SUB.W	D4,(A5)+OSLNBX	JUMP',LE 50$				; ascenseur avec cabine =>	INC.W	D4	LOAD.W	(A5)+OSLASH+OSCHTV,D4	TEST.B	(A5)+OSLCABH	; cabine dessine ?	JUMP',EQ 30$		; non => 30$				; oui =>	LOAD.W	D4,(A5)+OSLCXA	COMP.W	D4,(A5)+OSLASH+OSCPOSV ; cabine bouge ?	JUMP',EQ EXIT$		; non => EXIT$30$:	LOAD.W	(A5)+OSLASH+OSCPOSV,(A5)+OSLCXA	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASH	CALL	_SCROLL_UPDATE	; dessine la cabine	POP.L	A5	SET.B	(A5)+OSLCABH	JUMP'	EXIT$50$:				; ascenseur sans cabine =>	CLR.W	(A5)+OSLASH+OSCPOSV	CLR.W	(A5)+OSLASH+OSCHTV ; cabine pas ncessaire !	TEST.B	(A5)+OSLCABH	; cabine dessine ?	JUMP',EQ EXIT$		; non => EXIT$				; oui =>	PUSH.L	A5	LOAD.L	A5,#(A5)+OSLASH	CALL	_SCROLL_DRAW	; efface la cabine	POP.L	A5	CLR.B	(A5)+OSLCABHEXIT$:	POP.L	D4	RET;--------\\; MVCASE  >;========/; Affiche le contenu de toutes les cases, aprs un dplacement; vertical.; in	D1.W	mode (1 => sans slection);	D2.L	anciennes valeurs de OSLCYS/OSLCYA; out	-; mod	D7.WMVCASE:	PUSHM.L	D0..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_SLCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_SLTEXT	LIB	?COLORSR	; donne la couleur du texte	LOAD.W	D0,D1		; D0 <-- mode	LOAD.L	D1,D2	SWAP.W	D1		; D1 <-- ancienne valeur de OSLCYS	LOAD.W	D4,D2		; D4 <-- ancienne valeur de OSLCYA	SUB.W	D2,(A5)+OSLCYA	; D2 <-- +/- nb de lignes	JUMP,EQ IDEM$	TEST.W	D0		; mode sans slection ?	JUMP',NE CLRCASE$	; oui => CLRCASE$	LOAD.W	D3,D1	PUSH.W	(A5)+OSLCYA	LOAD.W	(A5)+OSLCYA,D4	CALL	_SCROLL_LINVCASE ; enlve la slection	POP.W	(A5)+OSLCYA	COMP.W	D3,#-1	JUMP',NE CLRCASE$	CLR.B	(A5)+OSLVII	; case vide teinteCLRCASE$:	LOAD.W	D3,D2		; D3 <-- +/- nb de lignes	JUMP,NC UP$DOWN$:				; contre en bas =>	NEG.W	D3	COMP.W	D3,(A5)+OSLNBY	JUMP,HS DRAWALL$	CALL	MVCASEROLL	; effectue un scroll contre le haut	CLR.L	D2	LOAD.W	D2,(A5)+OSLCYA	ADD.W	D2,(A5)+OSLNBY	SUB.W	D2,D3	LOAD.W	D1,D3DLOOP$:	TCLR.L	D2:#17		; D2 <-- vido normale	TEST.W	D0		; mode sans slection ?	JUMP',NE DDRAW$		; oui => DDRAW$	COMP.W	D2,(A5)+OSLCYS	; case slectionne ?	JUMP',NE DDRAW$		; non => DDRAW$	TSET.L	D2:#17		; D2 <-- vido inverse	TSET.L	D2:#16DDRAW$:	CALL	AFONECASE	; affiche le contenu d'une case	INC.W	D2	DEC.W	D1	JUMP,NE DLOOP$	TEST.L	D2:#16	JUMP,BS EXIT$	JUMP	SETCASE$	; remet la slectionUP$:				; contre en haut =>	COMP.W	D3,(A5)+OSLNBY	JUMP,HS DRAWALL$	NEG.W	D3	CALL	MVCASEROLL	; effectue un scroll contre le bas	NEG.W	D3	CLR.L	D2	LOAD.W	D2,(A5)+OSLCYA	LOAD.W	D1,D3ULOOP$:	TCLR.L	D2:#17		; D2 <-- vido normale	TEST.W	D0		; mode sans slection ?	JUMP',NE UDRAW$		; oui => UDRAW$	COMP.W	D2,(A5)+OSLCYS	; case slectionne ?	JUMP',NE UDRAW$		; non => UDRAW$	TSET.L	D2:#17		; D2 <-- vido inverse	TSET.L	D2:#16UDRAW$:	CALL	AFONECASE	; affiche le contenu d'une case	INC.W	D2	DEC.W	D1	JUMP,NE ULOOP$	TEST.L	D2:#16	JUMP',BS EXIT$	JUMP'	SETCASE$	; remet la slectionIDEM$:	COMP.W	D1,(A5)+OSLCYS	; slection change ?	JUMP',EQ EXIT$		; non => EXIT$				; oui =>	TEST.W	D0		; mode sans slection ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.W	D3,D1	CALL	_SCROLL_LINVCASE ; enlve la slection	COMP.W	D3,#-1	JUMP',NE SETCASE$	CLR.B	(A5)+OSLVII	; case vide teinteSETCASE$:	TEST.W	D0		; mode sans slection ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.W	D3,(A5)+OSLCYS	CALL	_SCROLL_LINVCASE ; remet la slection	JUMP'	EXIT$DRAWALL$:	PUSH.W	(A5)+OSLCYS	TEST.W	D0		; mode sans slection ?	JUMP',EQ ADRAW$		; non => ADRAW$	LOAD.W	(A5)+OSLCYS,#-2	; n'inverse jamais la slection !ADRAW$:	CALL	AFCASE		; affiche toutes les cases	POP.W	(A5)+OSLCYSEXIT$:	LIB	?COLORPOP	POPM.L	D0..D4	RET;-----------\\; MVCASEROLL >;-----------/; Dcale la scroll-liste vers le haut (+) ou vers le bas (-).; in	D3.W	nb de lignes (+/-1..n); out	-; mod	D7.WMVCASEROLL:	PUSHM.L	D2..D6,A3	LOAD.W	D2,D3		; D2 <-- nb de lignes	LOAD.L	A3,#R16"01$	LOAD.W	D3,#2	LIB	?STRING		; plus de modulos	LIB	?GETWDO	LOAD.W	D6,D5		; D6 <-- swdo actuelle	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	SWAP.W	D3	SWAP.W	D4	TEST.B	(A5)+OSLVID	; case vide tout en haut ?	JUMP',EQ 20$		; non => 20$	ADD.W	D3,(A5)+OSLCAR+0	INC.W	D3	SUB.W	D4,(A5)+OSLCAR+0	DEC.W	D420$:	INC.W	D3	DEC.W	D4	TEST.B	(A5)+OSLHOR	; ascenseur horizontal ?	JUMP',EQ 25$		; non => 25$	SUB.W	D4,#LGSCROLL-125$:	ADD.W	D3,(A0)+ODFFY	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#LGSCROLL	; D3 <-- position coin sup/gauche	SUB.W	D4,#LGSCROLL	; D4 <-- dimensions	ADD.W	D3,(A0)+ODFFX	LIB	?CREWDO	LIB	?USEWDO	SUB.L	SP,#4	LOAD.L	A3,#(SP)+1	LOAD.B	(A3)+0,#ROLLUP	TEST.W	D2	JUMP',NC 40$	NEG.W	D2	LOAD.B	(A3)+0,#ROLLDOWN40$:	MUL.WU	D2,(A5)+OSLCAR+0	LOAD.W	(A3)+1,D2	LOAD.W	D3,#3	LIB	?STRING	ADD.L	SP,#4	EX.L	D5,D6	LIB	?USEWDO		; rutilise le swdo initiale	LOAD.W	D5,D6	LIB	?KILWDO	LOAD.L	A3,#R16"02$	LOAD.W	D3,#2	LIB	?STRING		; remet les modulos	POPM.L	D2..D6,A3	RET01$:	.B	MMODULO,102$:	.B	MMODULO,0	.EVEN;--------\\; AFCASE  >;========/; Affiche le contenu de toutes les cases.; in	-; out	-; mod	D7.WAFCASE:	PUSHM.L	D1..D3	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_SLCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_SLTEXT	LIB	?COLORSR	; donne la couleur du texte	LIB	?BUCAR		; mode rapide, hum	LOAD.W	D1,(A5)+OSLNBY	; D1 <-- nb de cases  afficher	LOAD.W	D2,(A5)+OSLCYA	; D2 <-- no de la case affiche10$:	TCLR.L	D2:#17		; D2 <-- vido normale	COMP.W	D2,(A5)+OSLCYS	; case slectionne ?	JUMP',NE 15$		; non => 15$	TSET.L	D2:#17		; D2 <-- vido inverse15$:	CALL	AFONECASE	; affiche le contenu d'une case	INC.W	D2		; D2 <-- no de la case suivante	DEC.W	D1		; encore une case  afficher ?	JUMP,NE 10$		; oui => 10$	LIB	?NOBUCAR	; remet le mode normal	LIB	?COLORPOP; Regarde encore s'il faut teindre ou allumer la case vide.	COMP.W	(A5)+OSLCYS,#-1	JUMP',EQ 70$				; on n'est pas dans la case vide =>	TEST.B	(A5)+OSLVII	; case vide allume ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.W	D3,#-1		; oui =>	CALL	_SCROLL_LINVCASE ; teint la case vide	CLR.B	(A5)+OSLVII	; case vide teinte	JUMP'	EXIT$70$:				; on est dans la case vide =>	TEST.B	(A5)+OSLVII	; case vide allume ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.W	D3,#-1		; non =>	CALL	_SCROLL_LINVCASE ; allume la case vide	SET.B	(A5)+OSLVII	; case vide allumeEXIT$:	POPM.L	D1..D3	RET;----------\\; AFONECASE >;----------/; Affiche le contenu d'une case.; in	D2.W	rang de la case (0..n);		 si D2:#17 = 1  -->  affiche en vido inverse; out	-; mod	D7.WAFONECASE:	PUSHM.L	D0..D6,A3,A4	PUSH.L	D2	LOAD.L	D1,D2		; D1 <-- rang de la case	SUB.W	D2,(A5)+OSLCYA	JUMP,LO SETCASE$	COMP.W	D2,(A5)+OSLNBY	JUMP,HS SETCASE$	LOAD.L	D3,(A5)+OSLPOS	SWAP.W	D3	TEST.B	(A5)+OSLVID	; case vide tout en haut ?	JUMP',EQ 10$		; non => 10$	ADD.W	D3,(A5)+OSLCAR+0	INC.W	D310$:	INC.W	D3	MUL.WU	D2,(A5)+OSLCAR+0	ADD.W	D3,D2	SWAP.W	D3	ADD.W	D3,#LGSCROLL	; D3 <-- position coin sup/gauche20$:	LOAD.L	D0,D3	SWAP.W	D3	ADD.W	D3,(A5)+OSLC1Y	; D3 <-- sur la ligne de base	SWAP.W	D3	ADD.W	D3,(A5)+OSLC1X	; D3 <-- tient compte de la rfrence gauche	LIB	?SETCURS	; positionne sur la ligne de base	CLR.W	D2	COMP.W	D1,(A5)+OSLCYN	JUMP',HS 30$	LOAD.W	D3,D1		; D3 <-- no de la case	TEST.L	(A5)+OSLADL	JUMP,EQ 60$	LOAD.L	A3,(A5)+OSLADL	CALL	(A3)		; A3 <-- ^texte de la case	LOAD.W	D2,D3		; D2 <-- D3 rendu	TEST.W	D7	JUMP',NE 30$	TEST.B	(A5)+OSLCABV	; cabine de l'ascenseur existe ?	JUMP',NE 35$		; oui => 35$	INC.W	D1	COMP.W	D1,(A5)+OSLCYN	; est-on dans la dernire case ?	JUMP',NE 35$		; non => 35$	LOAD.W	D2,#2		; D2 <-- trace une ligne pleine en bas	JUMP'	35$30$:	LOAD.L	A3,#R16"TXVIDE$	; A3 <-- ^texte pour case vide35$:	LOAD.W	D4,(A5)+OSLCXA40$:	TEST.W	D4	JUMP',EQ 42$	DEC.W	D4	LOAD.B	D3,(A3)	JUMP',EQ 42$	COMP.B	D3,#CR	JUMP',EQ 42$	INC.L	A3	JUMP	40$42$:	LOAD.W	D4,(A5)+OSLNBX	LIB	?AFSPACE	DEC.W	D4	LOAD.L	A4,A3	LOAD.W	D3,#-146$:	INC.W	D3		; D3 <-- lg du texte  afficher	TEST.B	(A4+)	JUMP',EQ 48$	COMP.B	(A4)-1,#CR	JUMP,NE 46$48$:	COMP.W	D3,D4	JUMP',LS 50$	LOAD.W	D3,D4		; D3 <-- lg  afficher50$:	LIB	?STRING		; affiche le texte	SUB.W	D4,D3		; D4 <-- reste  effacer	JUMP',EQ 54$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface jusqu'au bout54$:	LOAD.W	D1,D2	LOAD.W	D2,#SETDOT	COMP.W	D1,#2		; trace une ligne pleine en bas ?	JUMP',EQ 56$		; oui => 56$	COMP.W	D1,#3		; trace une ligne double en bas ?	JUMP',EQ 56$		; oui => 56$	COMP.W	D1,#1		; trace une ligne pointille en bas ?	JUMP',NE SETCASE$	; non => SETCASE$				; oui =>	TSET.L	D2:#BTTTDOT	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; <map>	.B	1		; <chelle>	.B	0	.EVEN56$:	LOAD.L	D3,D0	SWAP.W	D3	ADD.W	D3,(A5)+OSLCAR+0 ; D3 <-- en bas des caractres	DEC.W	D3	SWAP.W	D3	LOAD.W	D4,(A5)+OSLNBX	MUL.WU	D4,(A5)+OSLCAR+2	PUSH.L	D3	LIB	?DRSEG		; trace une ligne horizontale	POP.L	D3	COMP.W	D1,#3		; trace une ligne double en bas ?	JUMP',NE SETCASE$	SUB.L	D3,#H'10000*1	LIB	?DRSEG		; trace une ligne en double paisseur	JUMP'	SETCASE$60$:	TEST.L	(A5)+OSLADA	JUMP',EQ SETCASE$	LOAD.L	A3,(A5)+OSLADA	LOAD.W	D4,(A5)+OSLNBX	; D4 <-- nb de caractres	LOAD.W	D5,(A5)+OSLCXA	; D5 <-- rang du premier caractre	CALL	(A3)		; affiche le texte dans la caseSETCASE$:	POP.L	D3	TEST.L	D3:#17		; affiche en vido inverse ?	JUMP',BC QUIT$		; non => QUIT$	CALL	_SCROLL_LINVCASE ; allume la caseQUIT$:	POPM.L	D0..D6,A3,A4	RETTXVIDE$:.ASCIZ	""		; texte pour case vide	.EVEN;--------\\; MAJCYA  >;========/; Calcul la premire case  afficher.; in	(A5)+OSLCYS.W	case slectionne;	(A5)+OSLCYN.W	nb de cases; out	(A5)+OSLCYA.W	premire case  afficher; mod	D7.WMAJCYA:	PUSHM.L	D3,D4	LOAD.W	D4,(A5)+OSLCYN	COMP.W	(A5)+OSLCYS,#-1	; est-on dans la case vide ?	JUMP',EQ 10$		; oui => 10$	LOAD.W	D4,(A5)+OSLCYS	; D4 <-- case slectionne10$:	LOAD.W	D3,(A5)+OSLNBY	SR.W	D3,#1	ADD.W	D4,D3		; D4 <-- descend d'une demi-hauteur	COMP.W	D4,(A5)+OSLCYN	JUMP',LS 20$	LOAD.W	D4,(A5)+OSLCYN20$:	SUB.W	D4,(A5)+OSLNBY	; D4 <-- remonte d'une hauteur complte	JUMP',HS 30$	CLR.W	D430$:	LOAD.W	(A5)+OSLCYA,D4	POPM.L	D3,D4	RET;--------\\; DETCASE >;========/; Dtecte dans quelle case est la souris.; in	D4.L	position de la souris (y;x); out	D3.W	case o est la souris (-1, 0..n);	D7.W	erreur; mod	D3.L, D7.WDETCASE:	PUSH.L	D4	CLR.W	D7		; D7 <-- ok,  priori	LOAD.W	D3,(A5)+OSLPOS+2	ADD.W	D3,#LGSCROLL	SUB.W	D4,D3		; trop  gauche ?	JUMP',HS 10$		; non => 10$	CLR.W	D4	LOAD.W	D7,#ERDIOUT	; D7 <-- on est ailleurs10$:	LOAD.W	D3,(A5)+OSLDIM+2	SUB.W	D3,#LGSCROLL	COMP.W	D4,D3		; trop  droite ?	JUMP',LO 20$		; non => 20$	LOAD.W	D7,#ERDIOUT	; D7 <-- on est ailleurs20$:	LOAD.L	D3,D4	CLR.W	D3	SWAP.W	D3	SUB.W	D3,(A5)+OSLPOS+0 ; trop haut ?	JUMP',HS 30$		; non => 30$	CLR.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- on est ailleurs30$:	DIV.WU	D3,(A5)+OSLCAR+0	TEST.B	(A5)+OSLVID	JUMP',NE 50$				; case vide n'existe pas =>	COMP.W	D3,(A5)+OSLNBY	; trop bas ?	JUMP',LO 40$		; non => 40$	LOAD.W	D3,(A5)+OSLNBY	DEC.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- on est ailleurs40$:	ADD.W	D3,(A5)+OSLCYA	COMP.W	D3,(A5)+OSLCYN	JUMP',LO EXIT$	LOAD.W	D3,(A5)+OSLCYN	DEC.W	D3	LOAD.W	D7,#ERDIOUT	; D7 <-- on est ailleurs	JUMP'	EXIT$50$:				; case vide existe =>	COMP.W	D3,(A5)+OSLNBY	; trop bas ?	JUMP',LS 60$		; non => 60$	LOAD.W	D3,(A5)+OSLNBY	LOAD.W	D7,#ERDIOUT	; D7 <-- on est ailleurs60$:	TEST.W	D3	JUMP',EQ 70$	ADD.W	D3,(A5)+OSLCYA	COMP.W	D3,(A5)+OSLCYN	JUMP',LS 70$	LOAD.W	D3,(A5)+OSLCYN	LOAD.W	D7,#ERDIOUT	; D7 <-- on est ailleurs70$:	DEC.W	D3		; D3 <-- -1..nEXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-----------------\\; _SCROLL_LINVCASE >;=================/; Inverse une case.; in	A5.L	^variables de la liste;	D3.W	rang de la case (-1, 0..n); out	-; mod	D7.W_SCROLL_LINVCASE:	PUSHM.L	D2..D4	LOAD.W	D2,D3	LOAD.W	D3,(A5)+OSLNBY	TEST.B	(A5)+OSLVID	JUMP',EQ 10$	INC.W	D3	INC.W	D2		; D2 <-- 0..n	JUMP',EQ 12$10$:	SUB.W	D2,(A5)+OSLCYA	JUMP,LO EXIT$12$:	COMP.W	D2,D3	JUMP,HS EXIT$	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_SLCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_SLHILI	LIB	?COLORSR	; donne la couleur des mises en vidence	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfini une trame pleine	LOAD.W	D3,D2	MUL.WU	D3,(A5)+OSLCAR+0	ADD.W	D3,(A5)+OSLPOS+0	INC.W	D3	TEST.B	(A5)+OSLVID	JUMP',EQ 30$	TEST.W	D2	JUMP',EQ 30$	INC.W	D330$:	SWAP.W	D3	LOAD.W	D3,(A5)+OSLPOS+2	ADD.W	D3,#LGSCROLL	LOAD.W	D4,(A5)+OSLCAR+0	SWAP.W	D4	LOAD.W	D4,(A5)+OSLDIM+2	SUB.W	D4,#LGSCROLL	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse la case	LIB	?COLORPOPEXIT$:	POPM.L	D2..D4	CLR.W	D7		; D7 <-- ok	RET	.END