	.SBTTL	LIBMENU;----------\\; _PUSHMENU >;==========/; Sauve le menu affich actuellement.; in	-; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.W_PUSHMENU:	PUSHM.L	D1,D3,D4,A3,A4	CLR.L	D5		; D5 <-- canal incorrect	LOAD.L	A3,#(A6)+OTXMENU ; A3 <-- ^12 x .ASCIZ	LOAD.L	A4,A3	CLR.L	D4	LOAD.B	D3,#(1+5)*2	; D3 <-- nb de .ASCIZ20$:	INC.W	D4		; D4 <-- nb de caractres	TEST.B	(A4+)	JUMP,NE 20$	DEC.B	D3	JUMP,NE 20$	ADD.W	D4,#2	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour sauver	JUMP',NE 90$	LOAD.L	D5,A4		; D5 <-- canal	LOAD.W	(A4+),(A6)+OMAPBAR ; sauve le map des barres	SUB.W	D4,#2+1		; D4 <-- +1  cause NMO40$:	LOAD.B	(A4+),(A3+)	; sauve tous les .ASCIZ	DECJ.W,NMO D4,40$90$:	POPM.L	D1,D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; _POPMENU >;=========/; Restitue le menu.; in	D5.L	canal; out	-; mod	D7.W_POPMENU:	PUSHM.L	D1,D3,D4,A3,A4	TEST.L	D5	JUMP,EQ 90$	LOAD.L	A4,D5		; A4 <-- ^sauvetage	LOAD.L	A3,#(A4)+2	; A3 <-- ^12 x .ASCIZ	CALL	_AFMENU		; restitue les soft-keys	CLR.B	D3		; D3 <-- rang soft key	LOAD.W	D4,(A4)+0	; D4 <-- map des barres50$:	TEST.L	D4:D3		; barre allume ?	JUMP',BC 60$		; non => 60$	CALL	_SETBARRE	; oui => remet la barre	TCLR.L	D3:#760$:	INC.B	D3	COMP.B	D3,#16	JUMP,LO	50$	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; restitue la mmoire90$:	POPM.L	D1,D3,D4,A3,A4	CLR.W	D7		; retour EQ	RET;--------\; _AFMENU >;========/; Affiche dans les 4 dernires lignes de l'cran un menu; pour les touches supplmentaires.; Le menu n'est affich que si le processus excutant l'appel; ?AFMENU est assign au clavier. Par contre, il est toujours; mmois en (A6)+OTXMENU.; in	A3.L	^liste de 2+2*5 textes .ASCIZ; out	D7.W	erreur; mod	D7.W_AFMENU:	PUSHM.L	D0,A0,A3,A4	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	D0,(A0)+OASKEY	; D0 <-- clavier actuel utilis	COMP.W	D0,(A6)+ONUKEY	; proc utilisant le clavier ?	JUMP',NE 10$		; non => 10$				; oui =>	CALL	AFMENU		; affiche le menu normalement10$:	LOAD.L	A4,#(A6)+OTXMENU	LOAD.W	D0,#12-1	; D0 <-- nb de .ASCIZ30$:	LOAD.B	(A4+),(A3+)	; transfert un .ASCIZ	JUMP,NE 30$	DECJ.W,NMO D0,30$	CLR.W	(A6)+OMAPBAR	; clear map des barres	POPM.L	D0,A0,A3,A4	RET;--------\; _PTMENU >;========/; Permet de sauver l'tat actuel du menu pour les; touches programmables.; in	-; out	A3.L	^liste de 12 .ASCIZ;	D3.W	barres affiches;	D7.W	erreur; mod	D3.W, D7.W, A3.L_PTMENU:	LOAD.L	A3,#(A6)+OTXMENU ; A3 <-- ^12 x .ASCIZ	LOAD.W	D3,(A6)+OMAPBAR	; D3 <-- map des barres	RET;--------\; AFMENU  >;========/; Affiche dans les 4 dernires lignes de l'cran un menu; pour les touches supplmentaires, sans redessiner les; cases vides (ce qui peut tre fait par AFCVIDE).; in	A3.L	^liste de 2+2*5 textes .ASCIZ; out	D7.W	erreur; mod	D7.WAFMENU:	PUSHM.L	D0..D4,D6,A0,A1,A3,A4	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A1,(A0)+OPTTSK	; A1 <-- ^table des soft-keys	ADD.W	A1,(A1)+0	; A1 <-- ^table des positions en X	LOAD.L	A4,A3		; A4 <-- ^liste des .ASCIZ	LOAD.L	A3,#R16"NPDISM	LOAD.B	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre fentre pour menu	JUMP,NE 90$	LOAD.L	A3,#(A0)+OBUMENU+1 ; A3 <-- ^dans OBUMENU	CALL	CLRBARRES	; efface toutes les barres;;?	LOAD.L	D3,#COLOR_SKTEXT;;?	CALL	_COLORSR	; donne la couleur pour les textes	CLR.W	D0		; D0 <-- rang pour (SHIFT-F0)	CALL	AFUMENU		; setcurs	LOAD.W	D4,#5		; D4 <-- longueur pour le texte	CALL	AFLMENU		; affiche ligne du haut	INC.W	D0		; D0 <-- rang pour (F0)	CALL	AFUMENU		; setcurs	LOAD.W	D4,#5		; D4 <-- longueur pour le texte	CALL	AFLMENU		; affiche ligne du bas20$:	INC.W	D0		; D0 <-- rang pour (SHIFT-Fn)	CALL	AFUMENU		; setcurs	LOAD.W	D4,#5+1+5+1+5	; D4 <-- longueur pour le texte	CALL	AFLMENU		; affiche ligne du haut	INC.W	D0		; D0 <-- rang pour (Fn)	CALL	AFUMENU		; setcurs	LOAD.W	D4,#5+1+5+1+5	; D4 <-- longueur pour le texte	CALL	AFLMENU		; affiche ligne du bas	ADD.W	D0,#4	COMP.W	D0,#32-1	JUMP,LO 20$	LOAD.L	A4,#(A0)+OBUMENU+1 ; A4 <-- ^dbut du buffer	LOAD.L	D4,A3		; D4 <-- ^fin du buffer	SUB.L	D4,A4		; D4 <-- longueur du buffer	FOS	?WRBYTE		; crit le contenu du buffer	FOS	?CLOSE		; ferme fentre pour menu90$:	POPM.L	D0..D4,D6,A0,A1,A3,A4	RET;--------\; AFUMENU >;--------/; Effectue un setcurs dans le menu.; in	D0.W	rang (0..31);	A1.L	^table des soft-keys;	A3.L	^dans buffer; out	A3.L	^plus loin dans le buffer; mod	D7.WAFUMENU:	PUSHM.L	D0,D3	LOAD.W	D3,(A1)+(16*2)+2	TCLR.L	D0:#0	JUMP',BC 10$	ADD.W	D3,(A1)+(16*2)+210$:	ADD.W	D3,(A1)+(16*2)+10 ; D3 <-- position sur la ligne de base	SWAP.W	D3	LOAD.W	D3,(A1)+(D0.W)	LOAD.B	(A3+),#TYPOAX	LOAD.B	(A3)+1,D3	; <xx> low	SR.W	D3,#8	LOAD.B	(A3)+0,D3	; <xx> high	ADD.L	A3,#2	SWAP.W	D3	LOAD.B	(A3+),#TYPOAY	LOAD.B	(A3)+1,D3	; <yy> low	SR.W	D3,#8	LOAD.B	(A3)+0,D3	; <yy> high	ADD.L	A3,#2	POPM.L	D0,D3	RET;--------\; AFLMENU >;--------/; Affiche une partie de ligne dans la fentre du menu, en; tronquant si le texte est trop long, et en remplissant le; reste si le texte est trop court.;  in	A4.L	^texte .ASCIZ;	D4.W	longueur pour le texte;	A3.L	^dans buffer;  out	A4.L	^suivant;	A3.L	^plus loin dans buffer;  mod	A3.L, A4.LAFLMENU:	PUSHM.L	D1,D3,D4,A0	COMP.B	(A4),#SPACE	; texte commence par un blanc ?	JUMP',EQ 50$		; oui => 50$				; non =>	LOAD.L	A0,A4		; A0 <-- ^.ASCIZ	LOAD.B	D1,#-110$:	TEST.B	(A0):#7		; caractre spcial ?	JUMP',BS 15$		; oui => 15$	INC.B	D1		; D1 <-- longueur du texte15$:	TEST.B	(A0+)	JUMP,NE 10$	TEST.B	D1		; texte nul ?	JUMP',EQ 50$		; oui => 50$				; non =>	SUB.B	D1,D4	JUMP',GT 50$	NEG.B	D1	SR.B	D1,#1		; D1 <-- D1 / 2	JUMP',EQ 50$30$:	LOAD.B	(A3+),#SPACE	; met qq blanc pour centrer	DEC.W	D4	DEC.B	D1	JUMP,NE 30$50$:	LOAD.B	(A3+),#AFTOUT	; affiche entre H'00 et H'7F52$:	LOAD.B	D3,(A4+)	JUMP',EQ 60$	LOAD.B	(A3+),D3	; affiche un caractre	TEST.L	D3:#7		; caractre spcial ?	JUMP,BS	52$		; oui => 52$	DEC.W	D4	JUMP,NE 52$54$:	TEST.B	(A4):#7	JUMP',BC 55$	LOAD.B	(A3+),(A4+)	JUMP	54$55$:	TEST.B	(A4+)		; saute fin du .ASCIZ	JUMP,NE 55$60$:	TEST.W	D4		; case dj pleine ?	JUMP',EQ 90$		; oui => 90$70$:	LOAD.B	(A3+),#SPACE	; rempli reste avec des espaces	DEC.W	D4	JUMP,NE 70$90$:	LOAD.B	(A3+),#AFNORM	; annule <AFTOUT> si oubli !	POPM.L	D1,D3,D4,A0	RET;--------\; AFCVIDE >;========/; Affiche dans les 4 dernires lignes de l'cran des cases; vides pour les touches supplmentaires.; in	-; out	D7.W	erreur; mod	D7.WAFCVIDE:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,#R16"NPDISM	LOAD.B	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre fentre pour menu	JUMP',NE 90$;;?	LOAD.L	D3,#COLOR_SKCADRE;;?	CALL	_COLORSR	; donne la couleur pour les cadres	LOAD.L	A4,_VARLIB	; A4 <-- ^variables globales	LOAD.L	A4,(A4)+OPTTSK	; A4 <-- ^table des soft-keys	ADD.W	A4,(A4)+2	; A4 <-- ^<<lg>> texte	CLR.L	D4	LOAD.W	D4,(A4+)	; D4 <-- longueur	FOS	?WRBYTE		; affiche tous les cadres vides	FOS	?CLOSE		; ferme fentre pour menu90$:	POPM.L	D3,D4,D6,A3,A4	RET;----------\; CLRBARRES >;----------/; Met dans le buffer d'criture ce qu'il faut pour effacer; toutes les barres.; in	A3.L	^dans buffer d'criture (doit tre impair); out	A3.L	^plus loin (aussi impair); mod	D0.L, A3.LCLRBARRES:	PUSH.L	A1	LOAD.B	(A3+),#TRAME	CLR.L	(A3+)		; init trame "vide"	CLR.L	(A3+)	CLR.B	(A3+)	LOAD.L	A1,(A0)+OPTTSK	; A1 <-- ^table des soft-keys	ADD.W	A1,(A1)+0	; A1 <-- ^table des positions en X	LOAD.B	(A3+),#DRAWTRAME	CLR.W	(A3+)		; <xx>	LOAD.W	(A3+),(A1)+(16*2)+4 ; <yy>	LOAD.W	(A3+),(A1)+(16*2)+8 ; <dxx>	LOAD.W	(A3+),(A1)+(16*2)+6 ; <dyy>	LOAD.B	(A3+),#CLRDOT	; <mode>	LOAD.B	(A3+),#TRAME	LOAD.L	(A3+),#-1	; init trame "pleine"	LOAD.L	(A3+),#-1	CLR.B	(A3+)	POP.L	A1	RET;----------\; _SETBARRE >;==========/; in	D3.B	numro de la barre  mettre (0..15); out	D7.W	erreur; mod	D7.W_SETBARRE:	PUSHM.L	D0,D3,D4,D6,A0,A3,A4	CLR.B	D4		; D4 <-- mode normal	AND.W	D3,#H'000F	; masque si trop grand	LOAD.W	D0,(A6)+OMAPBAR	; D0 <-- map des barres	TSET.L	D0:D3	JUMP,BS	BARRE9	JUMP	BARRE0;----------\; _CLRBARRE >;==========/; in	D3.B	numro de la barre  mettre (0..15); out	D7.W	erreur; mod	D7.W_CLRBARRE:	PUSHM.L	D0,D3,D4,D6,A0,A3,A4	CLR.B	D4		; D4 <-- mode normal	AND.W	D3,#H'000F	; masque si trop grand	LOAD.W	D0,(A6)+OMAPBAR	; D0 <-- map des barres	TCLR.L	D0:D3	JUMP,BC	BARRE9	JUMP	BARRE0;----------\; _INVBARRE >;==========/; in	D3.B	numro de la barre  mettre (0..15);		si 2^7=1 --> ne mmorise pas (pour qq'un d'autre); out	D7.W	erreur; mod	D7.W_INVBARRE:	PUSHM.L	D0,D3,D4,D6,A0,A3,A4	LOAD.B	D4,D3		; D4 <-- mode normal/spcial	AND.W	D3,#H'000F	; masque si trop grand	LOAD.W	D0,(A6)+OMAPBAR	; D0 <-- map des barres	TNOT.L	D0:D3BARRE0:	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	TEST.L	D4:#7		; pour qq'un d'autre ?	JUMP',BS 10$		; oui => 10$	LOAD.W	(A6)+OMAPBAR,D0	; met  jour le map	LOAD.W	D0,(A0)+OASKEY	; D0 <-- numro du clavier	COMP.W	D0,(A6)+ONUKEY	; utilis actuellement ?	JUMP,NE BARRE9		; non => BARRE910$:	LOAD.W	D0,D3		; D0 <-- no de la barre	LOAD.L	A3,#R16"NPDISM	; A3 <-- ^nom $DIS_7	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre fentre pour menu	JUMP',NE BARRE9;;?	LOAD.L	D3,#COLOR_SKBARRE;;?	CALL	_COLORSR	; donne la couleur pour les barres	LOAD.L	A3,#(A0)+OBUMENU+1 ; A3 <-- ^dans OBUMENU	LOAD.L	A4,A3	CALL	INVBARRE	; inverse une barre	LOAD.L	D4,A3		; D4 <-- ^fin du buffer	SUB.L	D4,A4		; D4 <-- longueur du buffer	FOS	?WRBYTE		; crit le contenu du buffer	PUSH.W	D7	FOS	?CLOSE		; ferme fentre pour menu	POP.W	D7BARRE9:	POPM.L	D0,D3,D4,D6,A0,A3,A4	RET;---------\; INVBARRE >;---------/; Met dans le buffer d'criture ce qu'il faut pour inverser; une barre selon la trame dfinie.; in	A3.L	^dans buffer d'criture (doit tre impair);	D0.W	numro de la barre; out	A3.L	^plus loin (aussi impair); mod	A3.LINVBARRE:	PUSHM.L	D0,D3,D4,A1	LOAD.L	A1,(A0)+OPTTSK	; A1 <-- ^table des soft-keys	ADD.W	A1,(A1)+0	; A1 <-- ^table des positions en X	SL.W	D0,#1		; D0 <-- *2 car .W	LOAD.B	(A3+),#DRAWTRAME	LOAD.W	D3,(A1)+(D0.W)	LOAD.W	D4,(A1)+(2*2)	SUB.W	D4,(A1)+(1*2)	SUB.W	D4,(A1)+(16*2)+0	SR.W	D4,#1	SUB.W	D3,D4	LOAD.W	(A3+),D3	; <xx>	LOAD.W	(A3+),(A1)+(16*2)+4 ; <yy>	LOAD.W	D3,(A1)+(2*2)	SUB.W	D3,(A1)+(1*2)	LOAD.W	(A3+),D3	; <dxx>	LOAD.W	(A3+),(A1)+(16*2)+6 ; <dyy>	LOAD.B	(A3+),#INVDOT	; <mode>	POPM.L	D0,D3,D4,A1	RET	.END