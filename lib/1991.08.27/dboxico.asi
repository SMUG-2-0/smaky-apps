	.SBTTL	DBOXICO; Constantes; ----------MXICONE	=	2		; marge en X pour rectangle autour icneMYICONE	=	3		; marge en Y pour rectangle autour icneCXICONE	=	4		; marge en X pour le cadre gauche/droiteCYICONE	=	4		; marge en Y pour le cadre sup/inf;-------------\\; _DBOX_ICODET >;=============/; Inverse l'icne o est la souris, tant que la souris est bouge.; Si la souris n'est pas dans une icne, on ressort tout de suite !; Il n'est pas ncessaire d'utiliser la sous-fentre zro avant cet; appel, et la sous-fentre utilise est conserve.; in	A3.L	^liste des icnes horizontaux;	A4.L	^liste des icnes verticaux/^nil;	A0.L	^description de la fentre;	D3.W	touche presse; out	D2.W	rang de l'icne o est la souris (0..15,16..n);		-1 si relch pas dans une icne;	D7.W	erreur ;		ERDIOUT	=> clic pas dans une icne;		ERSYNT	=> touche inconnue;		ERNEME	=> pas assez de mmoire;		autre	=> fatal; mod	D2.L, D7.W_DBOX_ICODET:	PUSHM.L	D1,D3..D6,A2..A5	LOAD.L	A2,#(A3)+4	; A2 <-- ^liste des icnes horizontaux	LOAD.L	A5,A4		; A5 <-- ^liste des icnes verticaux	COMP.W	D3,#F0	JUMP',LO 05$	COMP.W	D3,#F15	JUMP',LS 03$	COMP.W	D3,#F0+SHIFT	JUMP',LO 05$	COMP.W	D3,#F15+SHIFT	JUMP',HI 05$	SUB.W	D3,#SHIFT03$:	LOAD.W	D2,D3	SUB.W	D2,#F0		; D2 <-- 0..15	CALL	IFGICONE	; groupe de trois ?	JUMP',NE 04$		; non => 04$	LOAD.W	D2,D3		; D2 <-- premire icone du groupe04$:	CLR.W	D7		; D7 <-- ok	JUMP	95$05$:	LOAD.W	D7,#ERSYNT	; D7 <-- rien de connu	COMP.W	D3,#KEYMGP	; bouton press ?	JUMP',EQ 06$	COMP.W	D3,#KEYMMP	JUMP',EQ 06$	COMP.W	D3,#KEYMDP	JUMP,NE 95$06$:				; bouton press =>	LOAD.L	D4,#30	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- buffer d'criture	JUMP,NE 95$	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_DBICOCADRE	LIB	?COLORSR	; donne la couleur du cadre	LOAD.L	D3,#COLOR_DBICODESS	LIB	?COLORCR	; donne la couleur du dessin	LIB	?GETWDO	LOAD.W	D6,D5		; D6 <-- no swdo initiale	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	PUSH.L	(A0)+ODFGCF	; stack <-- gencar actuel	LOAD.W	D3,#4	LIB	?STRING		; utilise le gencar des icnes	LOAD.L	A2,#(A3)+4	; A2 <-- ^liste des icnes	LOAD.W	D2,#-1		; D2 <-- on est pas dans une icne	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 90$	CALL	WHATICONE	; D2 <-- icne o est la souris	JUMP',NE 90$	LOAD.W	D1,#-1		; D1 <-- pas encore d'icne allume	JUMP'	20$		; prend le train en marche !10$:	LIB	?GETKEY		; attend clavier/souris ...	COMP.W	D3,#KEYMPO	JUMP',NE 50$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 10$	CALL	WHATICONE	; D2 <-- icne o est la souris20$:	COMP.W	D2,D1		; est-on toujours dans la mme ?	JUMP,EQ 10$		; oui => 10$				; non =>	EX.L	D1,D2	CALL	INVICONE	; efface l'ancienne	LOAD.W	D2,D1	CALL	INVICONE	; allume la nouvelle	JUMP	10$50$:	LOAD.W	D2,D1		; D2 <-- icne o est la souris	CALL	INVICONE	; efface l'ancienne	CLR.W	D7		; D7 <-- ok90$:	POP.L	D3		; D3 <-- "fst-" initial	PUSH.W	D7	LOAD.B	D3,#USEGC	RR.L	D3,#8	LOAD.L	A3,A4		; A3 <-- ^buffer d'criture	LOAD.L	(A3),D3	LOAD.W	D3,#4	LIB	?STRING		; r-utilise le gencar initial	LOAD.W	D5,D6	LIB	?USEWDO		; r-utilise swdo initiale	LIB	?COLORPOP	; restitue les couleurs	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire	POP.W	D795$:	POPM.L	D1,D3..D6,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; WHATICONE >;----------/; Dtecte dans quelle icne est la souris.; in	A2.L	^liste des icnes horizontaux;	A5.L	^liste des icnes verticaux;	D4.L	position de la souris; out	D2.W	rang de l'icne (0..15,16..n);		-1 si pas dans icne;	D7.W	erreur; mod	D2.L, D7.WWHATICONE:	PUSHM.L	D3..D6	LOAD.W	D5,D4		; D5 <-- position de la souris en X	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- position de la souris en Y	CLR.W	D210$:	CALL	DIMICONE	; D3/D4 <-- pos/dim de l'icne	JUMP',NE 80$	COMP.W	D5,D3		; trop  gauche ?	JUMP',LO 50$	ADD.W	D3,D4	COMP.W	D5,D3		; trop  droite ?	JUMP',HS 50$	SWAP.W	D3	SWAP.W	D4	COMP.W	D6,D3		; trop en haut ?	JUMP',LO 50$	ADD.W	D3,D4	COMP.W	D6,D3		; trop en bas ?	JUMP',HS 50$	COMP.W	D2,#NBICONE	; icne verticale ?	JUMP',HS 30$		; oui => 30$				; non => horizontale	TEST.B	(A2)+(D2.W)	; est-on dans une icne vide ?	JUMP',EQ 80$		; oui => 80$30$:				; non =>	CLR.W	D7		; D7 <-- trouv	JUMP'	90$50$:	INC.W	D2		; D2 <-- rang suivant	JUMP	10$80$:	LOAD.W	D2,#-1		; D2 <-- on n'est pas dans une icne	LOAD.W	D7,#ERDIOUT	; D7 <-- pas trouv90$:	POPM.L	D3..D6	TEST.W	D7		; retour EQ/NE	RET;-------------\\; _DBOX_ICOPOS >;=============/; Donne la position et les dimensions d'une icne.; La position correspond au coin suprieur gauche.; Les dimensions occupent une ou trois cases selon les cas.; in	A3.L	^liste des icnes horizontaux;	A4.L	^liste des icnes verticaux/^nil;	A0.L	^description de la fentre;	D2.W	rang de l'icne cherche (0..15,16..n); out	D3.L	coin suprieur gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur (pas assez de mmoire); mod	D3.L, D4.L, D7.W_DBOX_ICOPOS:	PUSHM.L	D2,A2..A5	LOAD.L	A5,A4		; A5 <-- ^liste des icnes verticaux	PUSH.L	(A0)+ODFGCF	; stack <-- gencar actuel	LOAD.W	D3,#4	LIB	?STRING		; utilise le gencar des icnes	LOAD.L	A2,#(A3)+4	; A2 <-- ^liste des icnes	CALL	DIMICONE	; D3/D4 <-- position/dimensions	LOAD.L	D2,D3	POP.L	D3		; D3 <-- "fst-" initial	LOAD.B	D3,#USEGC	RR.L	D3,#8	PUSH.L	D3	LOAD.L	A3,SP		; A3 <-- ^buffer d'criture (mais oui)	LOAD.W	D3,#4	LIB	?STRING		; r-utilise le gencar initial	POP.L	D3	LOAD.L	D3,D2	ADD.W	D3,#MXICONE	SWAP.W	D3	ADD.W	D3,#MYICONE	SWAP.W	D3	SUB.W	D4,#MXICONE+MXICONE	SWAP.W	D4	SUB.W	D4,#MYICONE+MYICONE	SWAP.W	D4	CLR.W	D7		; D7 <-- ok	POPM.L	D2,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-------------\\; _DBOX_ICOINV >;=============/; Inverse une icne, par exemple pour indiquer un mode.; Il n'est pas ncessaire d'utiliser la sous-fentre zro avant cet; appel, et la sous-fentre utilise est conserve.; in	A3.L	^liste des icnes horizontaux;	A4.L	^liste des icnes verticaux/^nil;	A0.L	^description de la fentre;	D2.W	rang de l'icne  inverser (0..15,16..n); out	D7.W	erreur (pas assez de mmoire); mod	D7.W_DBOX_ICOINV:	PUSHM.L	D1,D3..D6,A2..A5	LOAD.L	A5,A4		; A5 <-- ^liste des icnes verticaux	LOAD.L	D4,#30	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- buffer d'criture	JUMP,NE 95$	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_DBICOCADRE	LIB	?COLORSR	; donne la couleur du cadre	LOAD.L	D3,#COLOR_DBICODESS	LIB	?COLORCR	; donne la couleur du dessin	LIB	?GETWDO	LOAD.W	D6,D5		; D6 <-- no swdo initiale	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	PUSH.L	(A0)+ODFGCF	; stack <-- gencar actuel	LOAD.W	D3,#4	LIB	?STRING		; utilise le gencar des icnes	LOAD.L	A2,#(A3)+4	; A2 <-- ^liste des icnes	CALL	INVICONE	; inverse une icne	POP.L	D3		; D3 <-- "fst-" initial	LOAD.B	D3,#USEGC	RR.L	D3,#8	LOAD.L	A3,A4		; A3 <-- ^buffer d'criture	LOAD.L	(A3),D3	LOAD.W	D3,#4	LIB	?STRING		; r-utilise le gencar initial	LOAD.W	D5,D6	LIB	?USEWDO		; r-utilise swdo initiale	LIB	?COLORPOP	; restitue les couleurs	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire	CLR.W	D7		; D7 <-- ok95$:	POPM.L	D1,D3..D6,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; INVICONE >;---------/; Inverse une icne.; in	A2.L	^liste des icnes horizontaux;	A5.L	^liste des icnes verticaux;	D2.W	rang de l'icne (0..15,16..n);		-1 ne fait rien;	A4.L	^buffer d'criture; out	-; mod	D7.WINVICONE:	PUSHM.L	D2..D4,A3	COMP.W	D2,#-1	JUMP',EQ 90$	LOAD.L	A3,A4		; A3 <-- ^buffer d'criture	LOAD.W	(A3+),#TRAME	; dfinit une trame pleine	LOAD.L	(A3+),#-1	LOAD.L	(A3+),#-1	LOAD.W	(A3+),#DRAWTRAME	CALL	DIMICONE	; D3/D4 <-- pos/dim de l'icne	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	LOAD.L	(A3+),D3	; buffer <-- <xx> <yy>	SUB.W	D4,#4	SWAP.W	D4	SUB.W	D4,#4	LOAD.L	(A3+),D4	; buffer <-- <dxx> <dyy>	LOAD.B	(A3+),#INVDOT	LOAD.L	D3,A3		; D3 <-- ^fin du buffer	LOAD.L	A3,A4		; A3 <-- ^dbut du buffer	SUB.L	D3,A3		; D3 <-- lg du buffer	LIB	?STRING		; crit tout le buffer d'un coup !90$:	POPM.L	D2..D4,A3	RET;-------------\\; _DBOX_ICOAFF >;=============/; Affiche les icnes en bas du cadre, sans qu'il soit ncessaire; de redessiner tout le cadre.; Il n'est pas ncessaire d'utiliser la sous-fentre zro avant cet; appel, et la sous-fentre utilise est conserve.; in	A3.L	^liste des icnes horizontaux;	A4.L	^liste des icnes verticaux/^nil;	A0.L	^description de la fentre; out	D7.W	erreur (pas assez de mmoire); mod	D7.W_DBOX_ICOAFF:	PUSHM.L	D1..D6,A2..A5	LOAD.L	A5,A4		; A5 <-- ^liste des icnes verticaux	LOAD.L	D4,#(16+40+10)*(NBICONE+16)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- buffer d'criture	JUMP,NE 95$	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_DBICOCADRE	LIB	?COLORSR	; donne la couleur du cadre	LOAD.L	D3,#COLOR_DBICODESS	LIB	?COLORCR	; donne la couleur du dessin	LIB	?GETWDO	LOAD.W	D6,D5		; D6 <-- no swdo initiale	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	PUSH.L	(A0)+ODFGCF	; stack <-- gencar actuel	LOAD.W	D3,#4	LIB	?STRING		; utilise le gencar des icnes	LOAD.L	A2,#(A3)+4	; A2 <-- ^liste des icnes	LOAD.L	A3,A4		; A3 <-- ^buffer d'criture	LOAD.W	(A3+),#TRAME	; dfinit une trame pleine	LOAD.L	(A3+),#-1	LOAD.L	(A3+),#-1	LOAD.W	(A3+),#DRAWTRAME	CLR.W	D2	CALL	DIMICONE	; D3/D4 <-- pos/dim de l'icne	CLR.W	D3	LOAD.W	D4,(A0)+ODFDX	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- <xx> <yy>	SWAP.W	D4	LOAD.L	(A3+),D4	; buffer <-- <dxx> <dyy>	LOAD.B	(A3+),#SETDOT	CLR.B	(A3+)10$:	CLR.W	D220$:	CALL	IFGICONE	; un groupe de trois ?	JUMP',NE 40$		; non => 40$				; oui =>	INC.W	D2	CALL	ONEICONE	; affiche une icne dans un groupe	ADD.W	D2,#2	JUMP'	50$40$:	CALL	ONEICONE	; affiche une icne solitaire	INC.W	D2		; D2 <-- rang icne suivante50$:	COMP.W	D2,#NBICONE	; passe aux icnes verticaux ?	JUMP',NE 60$		; non => 60$	LOAD.L	D1,A5		; icnes verticaux existent ?	JUMP',EQ 60$		; non => 60$				; oui =>	LOAD.W	(A3+),#DRAWTRAME	CLR.W	(A3+)		; <xx>	LOAD.W	(A3+),#LYCADRE	; <yy>	LOAD.W	(A3+),#LXICONE+CXICONE+CXICONE ; <dxx>	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,#LYCADRE+(2*CYICONE)	SUB.W	D3,(A0)+ODFCY	LOAD.W	(A3+),D3	; <dyy>	LOAD.B	(A3+),#SETDOT	CLR.B	(A3+)60$:	TEST.W	D7		; icne existe ?	JUMP,EQ 20$		; oui => 20$	POP.L	D3		; D3 <-- "fst-" initial	LOAD.B	D3,#USEGC	RR.L	D3,#8	LOAD.L	(A3+),D3	; r-utilise le gencar standard	LOAD.L	D3,A3		; D3 <-- ^fin du buffer	LOAD.L	A3,A4		; A3 <-- ^dbut du buffer	SUB.L	D3,A3		; D3 <-- lg du buffer	LIB	?STRING		; crit tout le buffer d'un coup !	LOAD.W	D5,D6	LIB	?USEWDO		; r-utilise swdo initiale	LIB	?COLORPOP	; restitue les couleurs	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire	CLR.W	D7		; D7 <-- ok95$:	POPM.L	D1..D6,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; ONEICONE >;---------/; Affiche une icne en bas dans le cadre.; in	A2.L	^liste des icnes horizontaux;	A5.L	^liste des icnes verticaux;	D2.W	rang de l'icne (0..15,16..n);	A3.L	^buffer (pair); out	A3.L	^plus loin (pair);	D7.W	icne n'existe pas; mod	D7.W, A3.LONEICONE:	PUSHM.L	D0..D4,A4	COMP.W	D2,#NBICONE	; icne verticale ?	JUMP',HS 30$		; oui => 30$				; non => horizontale	LOAD.B	D0,(A2)+(D2.W)	; D0 <-- code de l'icne	JUMP,EQ 90$		; icne n'existe pas => 90$	JUMP'	50$30$:				; icne verticale =>	LOAD.W	D1,D2	SUB.W	D1,#NBICONE-1	; D1 <-- 1..n	LOAD.L	A4,A535$:	LOAD.B	D0,(A4+)	; D0 <-- code de l'icne	JUMP',EQ 50$	COMP.B	D0,#-1		; sparateur vertical ?	JUMP,EQ 35$		; oui => 35$	DEC.W	D1	JUMP,NE 35$50$:	CALL	DIMICONE	; D3/D4 <-- pos/dim de l'icne	JUMP,NE 95$	PUSHM.L	D3,D4	SUB.W	D4,#LXICONE	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- centre l'icne en X	LOAD.W	(A3+),#TYPOAX	LOAD.W	(A3+),D3	LOAD.W	(A3+),#TYPOAY	SWAP.W	D3	ADD.W	D3,#MYICONE	ADD.W	D3,(A0)+ODFC1Y	LOAD.W	(A3+),D3	LOAD.B	(A3+),#MODCAR	LOAD.B	(A3+),#INVDOT	LOAD.B	(A3+),#AFTOUT	LOAD.B	(A3+),D0	; met le code de l'icne	LOAD.B	(A3+),#AFNORM	LOAD.B	(A3+),#MODCAR	LOAD.B	(A3+),#SETDOT	POPM.L	D3,D4		; D3/D4 <-- pos/dim de l'icne	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	CALL	RECTANGLE	; joli rectangle autour de l'icne	CLR.B	(A3+);;?	TEST.B	(A0)+ODFMOD:#BFBLANC ; cran  fond blanc ?;;?	JUMP',BC 90$		; non => 90$;;?				; oui =>;;?	LOAD.W	(A3+),#DRAWTRAME;;?	ADD.W	D3,#2;;?	SWAP.W	D3;;?	ADD.W	D3,#2;;?	LOAD.L	(A3+),D3	; buffer <-- <xx> <yy>;;?	SUB.W	D4,#4-1;;?	SWAP.W	D4;;?	SUB.W	D4,#4-1;;?	LOAD.L	(A3+),D4	; buffer <-- <dxx> <dyy>;;?	LOAD.B	(A3+),#INVDOT;;?	CLR.B	(A3+)90$:	CLR.W	D7		; D7 <-- icne existe95$:	POPM.L	D0..D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; RECTANGLE >;----------/; Trace un rectangle quelconque.; in	D3.L	origine d'un coin y;x;	D4.L	dimensions dy;dx;	D2.B	mode;	A3.L	^buffer (impair); out	A3.L	^plus loin (impair); mod	A3.LRECTANGLE:	PUSHM.L	D3..D5	LOAD.L	D5,D4		; D5 <-- dimensions dy;dx	AND.L	D4,#H'FFFF	CALL	DROITE		; trace ligne suprieure	LOAD.L	D4,D5	CLR.W	D4	CALL	DROITE		; trace ligne de droite	LOAD.L	D4,D5	AND.L	D4,#H'FFFF	NEG.W	D4	CALL	DROITE		; trace ligne infrieure	LOAD.L	D4,D5	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DROITE		; trace ligne de gauche	POPM.L	D3..D5	RET;--------\\; DROITE  >;--------/; Trace une droite quelconque.; in	D3.L	origine droite y;x;	D4.L	dimensions droite dy;dx;	D2.B	mode;	A3.L	^buffer (impair); out	D3.L	origine ligne suivante;	A3.L	^plus loin (impair); mod	D3.L, A3.LDROITE:	LOAD.B	(A3+),#DRAWSEG	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- <xx> <yy>	SWAP.W	D4	LOAD.L	(A3+),D4	; buffer <-- <dxx> <dyy>	ADD.W	D3,D4		; D3 <-- arrive en Y	SWAP.W	D4	SWAP.W	D3	ADD.W	D3,D4		; D3 <-- arrive en X	LOAD.B	(A3+),D2	; buffer <-- <mode>	RET;---------\\; DIMICONE >;---------/; Donne la position et les dimensions d'une icne, en tenant; compte des icnes solitaires, ou groupes par trois.; in	A2.L	^liste des icnes horizontaux;	A5.L	^liste des icnes verticaux;	D2.W	rang de l'icne (0..15,16..n); out	D3.L	coin suprieur gauche;	D4.L	dimensions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDIMICONE:	PUSHM.L	D1,D2,A1,A5	LOAD.L	A1,(A0)+ODFPSK	; A1 <-- ^table des soft-keys	ADD.W	A1,(A1)+0	; A1 <-- ^table des positions en X	COMP.W	D2,#NBICONE	; icne verticale ?	JUMP,HS 50$		; oui => 50$				; non =>	LOAD.W	D1,#1	CALL	IFGICONE	; un groupe de trois ?	JUMP',NE 20$		; non => 20$	LOAD.W	D2,D3	LOAD.W	D1,#320$:	LOAD.W	D3,D2	SL.W	D3,#1		; D3 <-- *2 car table de .W	LOAD.W	D3,(A1)+(D3.W)	; D3 <-- position en X	ADD.W	D3,(A1)+(16*2)+12	LOAD.W	D4,(A1)+(2*2)	SUB.W	D4,(A1)+(1*2)	SUB.W	D4,(A1)+(16*2)+0	SR.W	D4,#1	SUB.W	D3,D4	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDY	; D3 <-- hauteur de la fentre	SUB.W	D3,#CYICONE+MYICONE	SUB.W	D3,(A0)+ODFCY	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCY	ADD.W	D4,#MYICONE+MYICONE	SWAP.W	D4	LOAD.W	D2,(A1)+(2*2)	SUB.W	D2,(A1)+(1*2)	MUL.WU	D2,D1		; D2 <-- largeur *1 ou *3	LOAD.W	D4,D2	INC.W	D4	LOAD.W	D2,(A0)+ODFDX	SUB.W	D2,D3		; D2 <-- largeur maximale	SUB.W	D2,#2	COMP.W	D4,D2		; trop large ?	JUMP',LS 90$		; non => 90$	LOAD.W	D4,D2		; D4 <-- maximum possible	JUMP'	90$50$:				; icne vertical =>	LOAD.W	D7,#1	LOAD.L	D1,A5		; icnes verticaux existent ?	JUMP',EQ 95$		; non => 95$				; oui =>	SUB.W	D2,#NBICONE-1	; D2 <-- 1..n	LOAD.W	D3,#LYCADRE+CYICONE70$:	LOAD.B	D1,(A5+)	; D1 <-- code de l'icne	JUMP',EQ 95$	COMP.B	D1,#-1		; -1 (pour espace vertical) ?	JUMP',NE 72$		; non => 72$	ADD.W	D3,#CYICONE	; oui => avance un p'tit peu	JUMP	70$72$:	DEC.W	D2	JUMP',EQ 74$	ADD.W	D3,(A0)+ODFCY	ADD.W	D3,#MYICONE+MYICONE	JUMP	70$74$:	SWAP.W	D3	LOAD.W	D3,#CXICONE-MXICONE	LOAD.W	D4,(A0)+ODFCY	ADD.W	D4,#MYICONE+MYICONE+1	SWAP.W	D4	LOAD.W	D4,#LXICONE+MXICONE+MXICONE90$:	CLR.W	D7		; D7 <-- ok95$:	POPM.L	D1,D2,A1,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; IFGICONE >;---------/; Vrifie si l'icne fait partie d'un groupe de trois.; in	A2.L	^liste des icnes horizontaux;	A5.L	^liste des icnes verticaux;	D2.W	rang de l'icne (0..15,16..n); out	D3.W	rang premire icne du groupe;	EQ	groupe de trois; mod	D3.L, D7.WIFGICONE:	PUSH.W	D4	LOAD.W	D7,#1		; D7 <-- pas un groupe	COMP.W	D2,#NBICONE	; icne verticale ?	JUMP',HS 90$		; oui => 90$ (pas un groupe)				; non =>	CLR.L	D3	LOAD.W	D3,D2	JUMP',EQ 90$		; soft-key (F0) => 90$	DEC.W	D3	DIV.WU	D3,#3	MUL.WU	D3,#3	INC.W	D3		; D3 <-- rang 1re icne du groupe de trois	LOAD.B	D4,(A2)+(D3.W)+0	COMP.B	D4,(A2)+(D3.W)+1	JUMP',NE 90$	COMP.B	D4,(A2)+(D3.W)+2	JUMP',NE 90$	CLR.W	D7		; D7 <-- groupe de trois90$:	POP.W	D4	TEST.W	D7		; retour EQ/NE	RET;---------------\\; _DBOX_ICOCADRE >;===============/; Efface toute la fentre, et met un cadre autour.; On peut faire LIB,?CREWDO juste aprs si ncessaire.; L'affichage de XYZ rev 1.0 en haut  gauche se comme suit:;	CLR.L	D3;	LIB	?SETCURS	; positionne en tout en haut  gauche;	LIB	?AFTIM;	.B	AFINV		; en inverse vido;	.B	SPACE		; toujours un espace;	.ASCII	"XYZ rev 1.0";	.B	AFDIR		; remet vido normale;	.B	0;	.EVEN; in	A3.L	^liste des icnes horizontaux;	A4.L	^liste des icnes verticaux/^nil;	A0.L	^description de la fentre; out	D3.L	coin suprieur gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.W_DBOX_ICOCADRE:	PUSHM.L	D1,D2,D5,D6,A3	LIB	?AFTIM	.B	EOP		; efface la fentre	.B	NOROLL		; pas de roll	.B	TRUNC		; tronque lignes trop longues	.B	NOEFLI		; n'efface pas les lignes	.B	NOCURS		; pas de curseur	.B	0	.EVEN	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_DBICOCADRE	LIB	?COLORSR	; donne la couleur du cadre	PUSH.L	(A0)+ODFGCF	; stack <-- gencar actuel	LOAD.W	D3,#4	LIB	?STRING		; utilise le gencar des icnes	LOAD.L	D3,#-1		; D3 <-- trame "pleine"	LOAD.L	D4,D3		; D4 <-- trame "pleine"	LIB	?DRMDEF		; dfinit la trame	LOAD.W	D5,(A0)+ODFDX	; D5 <-- largeur de la fentre	LOAD.W	D6,(A0)+ODFDY	; D6 <-- hauteur de la fentre	LOAD.B	D2,#SETDOT	; D2 <-- <mode>	CLR.L	D3		; D3 <-- <xx> et <yy>	LOAD.W	D4,#LYCADRE	; D4 <-- <dyy>	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- <dxx>	LIB	?DRMATRIX	; surface suprieure	LOAD.W	D4,(A0)+ODFCY	ADD.W	D4,#2*CYICONE	; D4 <-- <dyy>	LOAD.W	D3,D6		; D3 <-- <yy>	SUB.W	D3,D4	SWAP.W	D3	CLR.W	D3		; D3 <-- <xx>	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- <dxx>	LIB	?DRMATRIX	; surface infrieure	LOAD.W	D3,#LYCADRE	; D3 <-- <yy>	SWAP.W	D3	CLR.W	D3		; D3 <-- <xx>	LOAD.W	D4,D6		; D4 <-- <dyy>	SUB.W	D4,#LYCADRE+(2*CYICONE)	SUB.W	D4,(A0)+ODFCY	SWAP.W	D4	LOAD.W	D4,#LXCADRE	; D4 <-- <dxx>	LOAD.L	D1,A4		; icnes verticaux existent ?	JUMP',EQ 40$		; non => 40$	LOAD.W	D4,#LXICONE+CXICONE+CXICONE40$:	LOAD.W	D1,D4		; D1 <-- largeur du cadre  gauche	LIB	?DRMATRIX	; surface gauche	LOAD.W	D3,D5	SUB.W	D3,#LXCADRE	; D3 <-- <xx>	LOAD.W	D4,D6		; D4 <-- <dyy>	SUB.W	D4,#LYCADRE+(2*CYICONE)	SUB.W	D4,(A0)+ODFCY	SWAP.W	D4	LOAD.W	D4,#LXCADRE	; D4 <-- <dxx>	LIB	?DRMATRIX	; surface droite	LOAD.W	D4,D6	SUB.W	D4,#LYCADRE+(2*CYICONE)	SUB.W	D4,(A0)+ODFCY	; D4 <-- hauteur pour swdo	SWAP.W	D4	LOAD.W	D4,D5	SUB.W	D4,#LXCADRE	SUB.W	D4,D1		; D4 <-- largeur pour swdo	POP.L	D3		; D3 <-- "fst-" initial	LOAD.B	D3,#USEGC	RR.L	D3,#8	PUSH.L	D3	LOAD.L	A3,SP		; A3 <-- ^buffer d'criture (mais oui)	LOAD.W	D3,#4	LIB	?STRING		; r-utilise le gencar initial	POP.L	D3	LOAD.W	D3,#LYCADRE	; D3 <-- <yy>	SWAP.W	D3	LOAD.W	D3,D1		; D3 <-- <xx> (largeur du cadre  gauche)	LIB	?COLORPOP	; restitue les couleurs	CLR.W	D7		; D7 <-- toujours ok	POPM.L	D1,D2,D5,D6,A3	TEST.W	D7		; retour EQ/NE	RET	.END