	.SBTTL	LIBGRA; Routines utilitaires graphiques; -------------------------------;------------\\; _DRPOLYGONE >;============/; Trace un polygone  "n" cts.; Le polygone est inscrit dans l'ellipse D3/D4.; Un sommet est toujours prsent  l'angle de dpart.; in	D3.L	origine centre (y;x);	D4.L	rayons (ry;rx);	D2.B	mode;	D1.L	angles de dpart en degrs et nombre de cts (n;d);		 d: 0..360 (dans le sens des aiguilles de la montre);		 n: 3,4,5,6,8,9,10; out	D7.W	erreur; mod	D7.W_DRPOLYGONE:	PUSHM.L	D0..D6,A3	LOAD.L	D0,D1		; D1 <-- angle de dpart	SWAP.W	D0		; D0 <-- nb de cts	LOAD.W	D7,#ERDIOUT	; D7 <-- a va pas la tte !	COMP.W	D0,#3		; moins qu'un triangle ?	JUMP,LO 90$	COMP.W	D0,#10		; max=10 avec LGBUFF=100 !	JUMP,HI 90$	LOAD.L	D6,#360	DIV.WU	D6,D0		; D6 <-- incrment pour l'angle	SWAP.W	D6	TEST.W	D6		; reste  la division ?	JUMP,NE 90$		; oui => 90$	SWAP.W	D6	LOAD.L	A3,#(A6)+OBUWRI+1	CALL	_CALCPELLI	; D5 <-- point sur l'ellipse20$:	ADD.W	D1,D6		; D1 <-- angle suivant	PUSHM.L	D0,D3	LOAD.L	D0,D5		; D0 <-- origine	CALL	_CALCPELLI	; D5 <-- arrive (point sur l'ellipse)	LOAD.B	(A3+),#DRAWSEG	SWAP.W	D0	LOAD.L	(A3+),D0	; <xx> et <yy>	SWAP.W	D0	LOAD.L	D3,D5	SUB.W	D3,D0	LOAD.W	(A3+),D3	; <dxx>	SWAP.W	D3	SWAP.W	D0	SUB.W	D3,D0	LOAD.W	(A3+),D3	; <dyy>	LOAD.B	(A3+),D2	; <mode>	TSET.L	D2:#BNCTDOT	; plus de rz des traitills	POPM.L	D0,D3	DEC.W	D0		; encore un ct ?	JUMP,NE 20$		; oui => 20$	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBUWRI+1	SUB.L	D3,A3		; D3 <-- longueur	CALL	_STRING		; dessine un polygone90$:	POPM.L	D0..D6,A3	RET;-----------\\; _DRTRANCHE >;===========/; Trace une tranche de gteau en forme de cercle ou d'ellipse quelconque.; in	D3.L	origine centre (y;x);	D4.L	rayons (ry;rx);	D2.B	mode;	D1.L	angles de dpart et d'arrive en degrs (a;d);		 d: 0..360 (dans le sens des aiguilles de la montre);		 a: 0..360 (>d); out	D7.W	erreur; mod	D7.W_DRTRANCHE:	PUSHM.L	D0..D5	LOAD.L	D0,D1		; D1 <-- angle de dpart	SWAP.W	D0		; D0 <-- angle d'arrive	PUSHM.L	D1,D3,D4	LOAD.W	D1,D0	CALL	_CALCPELLI	; D5 <-- point sur l'ellipse	LOAD.L	D4,D5	EX.L	D3,D4	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D4	SWAP.W	D3	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D4	SWAP.W	D3	CALL	_DRSEG		; dessine la droite Da	POPM.L	D1,D3,D4	COMP.W	D1,D0		; dpart = arrive ?	JUMP',EQ 90$		; oui => 90$;	PUSHM.L	D1,D3,D4	CALL	_CALCPELLI	; D5 <-- point sur l'ellipse	LOAD.L	D4,D5	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D4	SWAP.W	D3	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D4	SWAP.W	D3	CALL	_DRSEG		; dessine la droite Dd;	POPM.L	D1,D3,D490$:	POPM.L	D0..D5;	CALL	_DRARC		; dessine l'arc;	RET;--------\\; _DRARC  >;========/; Trace un arc de cercle ou d'ellipse quelconque.; in	D3.L	origine centre (y;x);	D4.L	rayons (ry;rx);	D2.B	mode;	D1.L	angles de dpart et d'arrive en degrs (a;d);		 d: 0..360 (dans le sens des aiguilles de la montre);		 a: 0..360 (>d); out	D7.W	erreur; mod	D7.W_DRARC:	PUSHM.L	D0..D6,A3	LOAD.L	D0,D1		; D1 <-- angle de dpart	SWAP.W	D0		; D0 <-- angle d'arrive	COMP.W	D1,D0		; dpart = arrive ?	JUMP,EQ 90$		; oui => 90$	TCLR.L	D2:#BNCTDOT	; rz des traitills	CLR.L	D6		; D6 <-- position initiale	LOAD.L	A3,#(A6)+OBUWRI+1	CLR.W	D5		; D5 <-- lg dans OBUWRI20$:	PUSHM.L	D3..D5	CALL	_CALCPELLI	; D5 <-- nouveau point	LOAD.L	D4,D5		; D4 <-- arrive segment	LOAD.L	D3,D6		; D3 <-- dpart segment	LOAD.L	D6,D5		; D6 <-- position suivante	TEST.L	D3	JUMP',NE 25$	POPM.L	D3..D5	JUMP'	50$25$:	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D4	SWAP.W	D3	SUB.W	D4,D3		; D4 <-- dy	LOAD.B	(A3+),#DRAWSEG	LOAD.L	(A3+),D3	; <xx> et <yy>	LOAD.L	(A3+),D4	; <dxx> et <dyy>	LOAD.B	(A3+),D2	; <mode>	TSET.L	D2:#BNCTDOT	; plus de rz des traitills	POPM.L	D3..D5	ADD.W	D5,#10		; D5 <-- lg dans OBUWRI	COMP.W	D5,#LGBUFF-10	; reste de la place ?	JUMP',LO 50$		; oui => 50$				; non =>	PUSH.L	D3	LOAD.W	D3,D5	LOAD.L	A3,#(A6)+OBUWRI+1	CALL	_STRING		; dessine qq lignes droites	CLR.W	D5		; D5 <-- lg dans OBUWRI	POP.L	D350$:	COMP.W	D1,D0	JUMP',HS 80$	ADD.W	D1,#6		; D1 <-- angle suivant	COMP.W	D1,D0	JUMP,LS 20$	LOAD.W	D1,D0	JUMP	20$80$:	LOAD.W	D3,D5	JUMP',EQ 90$	LOAD.L	A3,#(A6)+OBUWRI+1	CALL	_STRING		; dessine qq lignes droites90$:	POPM.L	D0..D6,A3	RET;-----------\\; _DRELLIPSE >;===========/; Trace une ellipse ou un cercle quelconque, ventuellement; par octants, c'est--dire par tranches de 45 degrs.; Si rx=ry, un cercle optimis est dessin !; in	D3.L	origine centre (y;x);	D4.L	rayons (ry;rx);	D2.B	mode;	D1.W	octants  dessiner :;		 bit 0 --> 315..360 degrs;		 bit 1 --> 270..315 degrs;		 bit 2 --> 225..270 degrs;		 bit 3 --> 180..225 degrs;		 bit 4 --> 135..180 degrs;		 bit 5 -->  90..135 degrs;		 bit 6 -->  45.. 90 degrs;		 bit 7 -->   0.. 45 degrs; out	D7.W	erreur; mod	D7.W_DRELLIPSE:	PUSHM.L	D0,D3,D4,A3	TEST.W	D4		; rx nul ?	JUMP',EQ 40$		; oui => 40$	SWAP.W	D4	TEST.W	D4		; ry nul ?	JUMP,EQ 60$		; oui => 60$	SWAP.W	D4	LOAD.L	D0,D4	SWAP.W	D0	COMP.W	D0,D4		; rx = ry ?	JUMP',EQ 20$				; ellipse =>	LOAD.L	A3,#(A6)+OBUWRI+1	LOAD.B	(A3)+0,#DRAWELLIPSE	LOAD.W	(A3)+1,D3	; <xx>	SWAP.W	D3	LOAD.W	(A3)+3,D3	; <yy>	LOAD.W	(A3)+5,D4	; <rxx>	SWAP.W	D4	LOAD.W	(A3)+7,D4	; <ryy>	LOAD.W	(A3)+9,D1	; <aa>	LOAD.B	(A3)+11,D2	; <mode>	LOAD.W	D3,#12	CALL	_STRING		; dessine une ellipse	JUMP	90$20$:				; cercle =>	LOAD.L	A3,#(A6)+OBUWRI+1	LOAD.B	(A3)+0,#DRAWARC	LOAD.W	(A3)+1,D3	; <xx>	SWAP.W	D3	LOAD.W	(A3)+3,D3	; <yy>	LOAD.W	(A3)+5,D4	; <rr>	LOAD.W	(A3)+7,D1	; <aa>	LOAD.B	(A3)+9,D2	; <mode>	LOAD.W	D3,#10	CALL	_STRING		; dessine un cercle	JUMP'	90$40$:	SWAP.W	D4	TEST.W	D4		; ry nul ?	JUMP',EQ 90$				; rx nul =>	SWAP.W	D3	SUB.W	D3,D4	ASL.W	D4,#1	SWAP.W	D4	SWAP.W	D3	CALL	_DRSEG		; dessine une ligne verticale	JUMP'	90$60$:				; ry nul =>	SWAP.W	D4	SUB.W	D3,D4	ASL.W	D4,#1	CALL	_DRSEG		; dessine une ligne horizontale;	JUMP'	90$90$:	POPM.L	D0,D3,D4,A3	RET;----------\; _DRCERCLE >;==========/; Trace un cercle quelconque.; in	D3.L	origine centre (y;x);	D4.W	rayon (r);	D2.B	mode; out	D7.W	erreur; mod	D7.W_DRCERCLE:	PUSHM.L	D3,D4,A3	TEST.W	D4		; rayon = zro ?	JUMP',EQ 90$		; oui => 90$				; non =>	LOAD.L	A3,#(A6)+OBUWRI+1	LOAD.B	(A3)+0,#GRAXY	LOAD.W	(A3)+1,D3	; <xx>	SWAP.W	D3	LOAD.W	(A3)+3,D3	; <yy>	CLR.B	(A3)+5		; <null>	LOAD.B	(A3)+6,#DRAWCERCLE	LOAD.W	(A3)+7,D4	; <rayon>	LOAD.B	(A3)+9,D2	; <mode>	LOAD.W	D3,#5+1+4	CALL	_STRING		; dessine un cercle90$:	POPM.L	D3,D4,A3	RET;--------\; _DRMDEF >;========/; Dfinit une trame quelconque.; in	D3.L	1re partie trame;	D4.L	2me partie trame; out	D7.W	erreur; mod	D7.W_DRMDEF:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBUWRI+1	LOAD.B	(A3)+0,#TRAME	LOAD.L	(A3)+1,D3	LOAD.L	(A3)+5,D4	LOAD.W	D3,#1+8	CALL	_STRING		; dfinit la trame90$:	POPM.L	D3,D4,A3	RET;----------\\; _DRTRAMEA >;==========/; Rempli une zone rectangulaire avec une trame,; ventuellement avec les coins arrondis !; La trame est dfinie avec LIB,?DRMDEF.; in	D3.L	origine coin suprieur gauche (y;x);	D4.L	dimensions (dy;dx);	D2.B	mode;	D1.W	rayon pour les 4 coins (2,3,4,8,12,16); out	D7.W	erreur; mod	D7.W_DRTRAMEA:	PUSHM.L	D2..D4,A3,A4	TEST.W	D1		; rayon nul ?	JUMP',NE 15$	CALL	_DRTRAME	; trame un rectangle aux coins droits	JUMP	90$15$:	LOAD.L	A3,#(A6)+OBUWRI+1	LOAD.B	(A3)+0,#DRAWTRAME	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	SWAP.W	D4	LOAD.L	(A3)+5,D4	; <dxx> et <dyy>	LOAD.B	(A3)+9,D2	; <mode>	LOAD.W	D3,#10	LOAD.L	A4,#R16"SEIZE$	COMP.W	D1,#16	JUMP',EQ 20$	LOAD.L	A4,#R16"DOUZE$	COMP.W	D1,#12	JUMP',EQ 20$	LOAD.L	A4,#R16"HUIT$	COMP.W	D1,#8	JUMP',EQ 20$	LOAD.L	A4,#R16"QUATRE$	COMP.W	D1,#4	JUMP',EQ 20$	LOAD.L	A4,#R16"TROIS$	COMP.W	D1,#3	JUMP',EQ 20$	LOAD.L	A4,#R16"DEUX$	COMP.W	D1,#2	JUMP',EQ 20$	LOAD.W	D7,#ERDIOUT	; D7 <-- j'sais pas faire c'truc l !	JUMP	90$20$:	CLR.W	D2		; D2 <-- <yy> initial30$:	TEST.W	(A4)	JUMP,NS 40$	PUSH.L	(A3)+1	PUSH.L	(A3)+5	ADD.W	(A3)+3,D2	; <yy>	LOAD.W	D4,(A4)+2	ADD.W	(A3)+1,D4	; <xx>	SL.W	D4,#1	SUB.W	(A3)+5,D4	; <dxx>	LOAD.W	(A3)+7,(A4)+0	; <dyy>	CALL	_STRING	POP.L	(A3)+5	POP.L	(A3)+1	PUSH.L	(A3)+1	PUSH.L	(A3)+5	LOAD.W	D4,(A3)+7	SUB.W	D4,D2	SUB.W	D4,(A4)+0	ADD.W	(A3)+3,D4	; <yy>	LOAD.W	D4,(A4)+2	ADD.W	(A3)+1,D4	; <xx>	SL.W	D4,#1	SUB.W	(A3)+5,D4	; <dxx>	LOAD.W	(A3)+7,(A4)+0	; <dyy>	CALL	_STRING	POP.L	(A3)+5	POP.L	(A3)+1	ADD.W	D2,(A4)+0	; D2 <-- <yy> suivant	ADD.L	A4,#4	JUMP	30$40$:;	PUSH.L	(A3)+1;	PUSH.L	(A3)+5	ADD.W	(A3)+3,D2	; <yy>	SL.W	D2,#1	SUB.W	(A3)+7,D2	; <dyy>	CALL	_STRING;	POP.L	(A3)+5;	POP.L	(A3)+190$:	POPM.L	D2..D4,A3,A4	RET;	o o o;	o;	oDEUX$:	;	dy,dx	.W	1,3	.W	2,1	.W	-1;	o o o o;	o o;	o;	oTROIS$:	;	dy,dx	.W	1,4	.W	1,2	.W	2,1	.W	-1;	o o o o o;	o o o;	o o;	o;	oQUATRE$: ;	dy,dx	.W	1,5	.W	1,3	.W	1,2	.W	2,1	.W	-1;	o o o o o o o o o;	o o o o o o;	o o o o;	o o o;	o o;	o o;	o;	o;	oHUIT$:	;	dy,dx	.W	1,9	.W	1,6	.W	1,4	.W	1,3	.W	2,2	.W	3,1	.W	-1;	o o o o o o o o o o o o o;	o o o o o o o o o;	o o o o o o o;	o o o o o;	o o o o;	o o o;	o o o;	o o;	o o;	o;	o;	o;	oDOUZE$:	;	dy,dx	.W	1,13	.W	1,9	.W	1,7	.W	1,5	.W	1,4	.W	2,3	.W	2,2	.W	4,1	.W	-1;	o o o o o o o o o o o o o o o o o;	o o o o o o o o o o o o o;	o o o o o o o o o o;	o o o o o o o o;	o o o o o o o;	o o o o o o;	o o o o o;	o o o o;	o o o;	o o o;	o o;	o o;	o o;	o;	o;	o;	oSEIZE$:	;	dy,dx	.W	1,17	.W	1,13	.W	1,10	.W	1,8	.W	1,7	.W	1,6	.W	1,5	.W	1,4	.W	2,3	.W	3,2	.W	4,1	.W	-1;---------\; _DRTRAME >	(identique  l'ancien nom _DRMATRIX);=========/; Rempli une zone rectangulaire avec une trame.; La trame est dfinie avec LIB,?DRMDEF.; in	D3.L	origine coin suprieur gauche (y;x);	D4.L	dimensions (dy;dx);	D2.B	mode; out	D7.W	erreur; mod	D7.W_DRTRAME:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBUWRI+1	LOAD.B	(A3)+0,#DRAWTRAME	LOAD.W	(A3)+1,D3	; <xx>	SWAP.W	D3	LOAD.W	(A3)+3,D3	; <yy>	LOAD.W	(A3)+5,D4	; <dxx>	TEST.W	D4	JUMP',EQ 90$	SWAP.W	D4	LOAD.W	(A3)+7,D4	; <dyy>	TEST.W	D4	JUMP',EQ 90$	LOAD.B	(A3)+9,D2	; <mode>	LOAD.W	D3,#1+8+1	CALL	_STRING		; rempli avec la trame90$:	POPM.L	D3,D4,A3	RET;---------\; _DRRECTA >;=========/; Trace un rectangle aux coins arrondis.; in	D3.L	origine coin suprieur gauche (y;x);	D4.L	dimensions (dy;dx);	D2.B	mode;	D1.W	rayon pour les 4 coins (0..n); out	D7.W	erreur; mod	D7.W_DRRECTA:	PUSHM.L	D1..D5,A3	TEST.W	D1		; rayon nul ?	JUMP',NE 20$	CALL	_DRRECT		; dessine le rectangle	JUMP	90$20$:	ADD.W	D4,D3		; D4 <-- x oppos	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3		; D4 <-- y oppos	SWAP.W	D3	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SR.W	D5,#1		; D5 <-- 1/2 largeur	COMP.W	D1,D5		; rayon trop grand ?	JUMP',LS 30$		; non => 30$	LOAD.W	D1,D5		; oui => diminue30$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SWAP.W	D4	SWAP.W	D3	SR.W	D5,#1		; D5 <-- 1/2 hauteur	COMP.W	D1,D5		; rayon trop grand ?	JUMP',LS 40$		; non => 40$	LOAD.W	D1,D5		; oui => diminue40$:	LOAD.L	A3,#(A6)+OBUWRI+1	TCLR.L	D2:#BNCTDOT	; rz des traitills	LOAD.B	(A3+),#DRAWSEG	; en haut	LOAD.W	D5,D3	ADD.W	D5,D1	INC.W	D5	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D3	LOAD.W	(A3+),D3	; <yy>	SWAP.W	D3	LOAD.W	D5,D4	SUB.W	D5,D3	SUB.W	D5,D1	SUB.W	D5,D1	LOAD.W	(A3+),D5	; <dxx>	CLR.W	(A3+)		; <dyy>	LOAD.B	(A3+),D2	; <mode>	TSET.L	D2:#BNCTDOT	; plus de rz des traitills	LOAD.B	(A3+),#DRAWARC	; en haut  droite	LOAD.W	D5,D4	SUB.W	D5,D1	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D3	LOAD.W	D5,D3	ADD.W	D5,D1	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D3	LOAD.W	(A3+),D1	; <rr>	LOAD.W	(A3+),#B'00000011	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWSEG	;  droite	LOAD.W	(A3+),D4	; <xx>	SWAP.W	D3	LOAD.W	D5,D3	ADD.W	D5,D1	INC.W	D5	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D3	CLR.W	(A3+)		; <dxx>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SUB.W	D5,D1	SUB.W	D5,D1	LOAD.W	(A3+),D5	; <dyy>	SWAP.W	D4	SWAP.W	D3	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWARC	; en bas  droite	LOAD.W	D5,D4	SUB.W	D5,D1	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D1	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D4	LOAD.W	(A3+),D1	; <rr>	LOAD.W	(A3+),#B'11000000	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWSEG	; en bas	LOAD.W	D5,D4	SUB.W	D5,D1	DEC.W	D5	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D4	LOAD.W	(A3+),D4	; <yy>	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SUB.W	D5,D1	SUB.W	D5,D1	NEG.W	D5	LOAD.W	(A3+),D5	; <dxx>	CLR.W	(A3+)		; <dyy>	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWARC	; en bas  gauche	LOAD.W	D5,D3	ADD.W	D5,D1	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D1	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D4	LOAD.W	(A3+),D1	; <rr>	LOAD.W	(A3+),#B'00110000	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWSEG	;  gauche	LOAD.W	(A3+),D3	; <xx>	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D1	DEC.W	D5	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D4	CLR.W	(A3+)		; <dxx>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D5,D4	SUB.W	D5,D3	SUB.W	D5,D1	SUB.W	D5,D1	NEG.W	D5	LOAD.W	(A3+),D5	; <dyy>	SWAP.W	D4	SWAP.W	D3	LOAD.B	(A3+),D2	; <mode>	LOAD.B	(A3+),#DRAWARC	; en haut  gauche	LOAD.W	D5,D3	ADD.W	D5,D1	LOAD.W	(A3+),D5	; <xx>	SWAP.W	D3	LOAD.W	D5,D3	ADD.W	D5,D1	LOAD.W	(A3+),D5	; <yy>	SWAP.W	D3	LOAD.W	(A3+),D1	; <rr>	LOAD.W	(A3+),#B'00001100	LOAD.B	(A3+),D2	; <mode>	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBUWRI+1	SUB.L	D3,A3		; D3 <-- longueur	CALL	_STRING		; dessine le rectangle90$:	POPM.L	D1..D5,A3	RET;---------\; _DRRECTO >;=========/; Trace un rectangle ombr.; L'ombre est une trame dfinie avec LIB,?DRMDEF !; in	D3.L	origine coin suprieur gauche (y;x);	D4.L	dimensions (dy;dx);	D2.B	mode;	D1.W	paisseur de l'ombre (1..n); out	D7.W	erreur; mod	D7.W_DRRECTO:	PUSHM.L	D3,D4	ADD.W	D3,D4	INC.W	D3	LOAD.W	D4,D1	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D1	INC.W	D4	SWAP.W	D4	SWAP.W	D3	CALL	_DRTRAME	; dessine l'ombre  droite	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,D1	SUB.W	D4,D1	INC.W	D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	INC.W	D3	LOAD.W	D4,D1	SWAP.W	D4	SWAP.W	D3	CALL	_DRTRAME	; dessine l'ombre en bas	POPM.L	D3,D4;	CALL	_DRRECT		; dessine le rectangle;	RET;--------\; _DRRECT >;========/; Trace un rectangle quelconque.; in	D3.L	origine coin suprieur gauche (y;x);	D4.L	dimensions (dy;dx);	D2.B	mode; out	D7.W	erreur; mod	D7.W_DRRECT:	PUSHM.L	D3..D6,A3	LOAD.L	A3,#(A6)+OBUWRI+1	LOAD.L	D5,D3		; D5 <-- origine	LOAD.L	D6,D4		; D6 <-- dimensions;	LOAD.L	D3,D5	CLR.L	D4	LOAD.W	D4,D6	LOAD.B	(A3+),#DRAWSEG	SWAP.W	D3	LOAD.L	(A3+),D3	; <xx> et <yy>	SWAP.W	D4	LOAD.L	(A3+),D4	; <dxx> et <dyy>	LOAD.B	(A3+),D2	; <mode>	LOAD.L	D3,D5	ADD.W	D3,D6	LOAD.L	D4,D6	CLR.W	D4	LOAD.B	(A3+),#DRAWSEG	SWAP.W	D3	LOAD.L	(A3+),D3	; <xx> et <yy>	SWAP.W	D4	LOAD.L	(A3+),D4	; <dxx> et <dyy>	LOAD.B	(A3+),D2	; <mode>	LOAD.L	D3,D5	LOAD.L	D4,D6	ADD.W	D3,D4	NEG.W	D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	CLR.W	D4	SWAP.W	D4	SWAP.W	D3	LOAD.B	(A3+),#DRAWSEG	SWAP.W	D3	LOAD.L	(A3+),D3	; <xx> et <yy>	SWAP.W	D4	LOAD.L	(A3+),D4	; <dxx> et <dyy>	LOAD.B	(A3+),D2	; <mode>	LOAD.L	D3,D5	LOAD.L	D4,D6	CLR.W	D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	NEG.W	D4	SWAP.W	D4	SWAP.W	D3	LOAD.B	(A3+),#DRAWSEG	SWAP.W	D3	LOAD.L	(A3+),D3	; <xx> et <yy>	SWAP.W	D4	LOAD.L	(A3+),D4	; <dxx> et <dyy>	LOAD.B	(A3+),D2	; <mode>	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBUWRI+1	SUB.L	D3,A3		; D3 <-- longueur	CALL	_STRING		; dessine un rectangle	POPM.L	D3..D6,A3	RET;--------\; _DRSEG  >;========/; Trace une ligne quelconque.; in	D3.L	origine ligne (y;x);	D4.L	dimensions ligne (dy;dx);	D2.B	mode; out	D3.L	origine ligne suivante;	D7.W	erreur; mod	D3.L, D7.W_DRSEG:	PUSHM.L	D1,D4,A3	LOAD.L	D1,D3		; D3 <-- point de dpart	LOAD.L	A3,#(A6)+OBUWRI+1	LOAD.B	(A3)+0,#DRAWSEG	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	SWAP.W	D4	LOAD.L	(A3)+5,D4	; <dxx> et <dyy>	LOAD.B	(A3)+9,D2	; <mode>	LOAD.W	D3,#10	CALL	_STRING		; dessine une ligne	LOAD.L	D3,D1		; D3 <-- point de dpart	SWAP.W	D3	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- point d'arrive	POPM.L	D1,D4,A3	RET	.END