	.SBTTL	LISTMISC;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; MAINMOUSE >;==========/; Remplace la flche de la souris par une main.; in	-; out	D4.L	position relative (y;x); mod	D4.L, D7.WMAINMOUSE:	PUSHM.L	D3,A3,A4	LOAD.L	A3,#(A6)+OHVBUF+1	LOAD.B	(A3)+0,#DRAWPMOUSE	LOAD.L	A4,#R16"CHAIR$	LOAD.L	(A3)+1,A4	LOAD.L	A4,#R16"FOND$	LOAD.L	(A3)+5,A4	LOAD.W	D3,#9	LIB	?STRING		; utilise un lutin spcial pour la souris	LOAD.L	D4,#H'10000*(16/2)+(16/2)	POPM.L	D3,A3,A4	RETCHAIR$:	.B	16,16        .B      B'00000001,B'10000000        .B      B'00011010,B'01110000        .B      B'00100110,B'01001000        .B      B'00100110,B'01001000        .B      B'00010010,B'01001010        .B      B'00010010,B'01001101        .B      B'01101000,B'00001001        .B      B'10011000,B'00001001        .B      B'10001000,B'00000010        .B      B'01000000,B'00000010        .B      B'00100000,B'00000010        .B      B'00100000,B'00000100        .B      B'00010000,B'00000100        .B      B'00001000,B'00001000        .B      B'00000100,B'00001000        .B      B'00000100,B'00001000FOND$:	.B	16,16        .B      B'00000001,B'10000000        .B      B'00011011,B'11110000        .B      B'00111111,B'11111000        .B      B'00111111,B'11111000        .B      B'00011111,B'11111010        .B      B'00011111,B'11111111        .B      B'01101111,B'11111111        .B      B'11111111,B'11111111        .B      B'11111111,B'11111110        .B      B'01111111,B'11111110        .B      B'00111111,B'11111110        .B      B'00111111,B'11111100        .B      B'00011111,B'11111100        .B      B'00001111,B'11111000        .B      B'00000111,B'11111000        .B      B'00000111,B'11111000	.EVEN;----------\\; FLECMOUSE >;==========/; Remet la flche comme lutin pour la souris.; in	-; out	-; mod	D7.WFLECMOUSE:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OHVBUF+1	LOAD.B	(A3)+0,#DRAWPMOUSE	CLR.L	(A3)+1	CLR.L	(A3)+5	LOAD.W	D3,#9	LIB	?STRING		; lutin de la souris de nouveau normal	POPM.L	D3,A3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	D7.WWAITMOUSE:	PUSH.W	D4	CLR.W	D4	LIB	?WAITMOUSE	POP.W	D4	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	D7.WNORMMOUSE:	PUSH.W	D4	LOAD.W	D4,#1	LIB	?WAITMOUSE	POP.W	D4	RET;-------------\\; CALCPOURCENT >;=============/; Calcul le pourcentage utilis connaissant la quantit utilise; et la quantit restante.;	      U;	P = ----- * 100;	     U+R; in	D0.L	reste;	D1.L	utilis; out	D4.L	pourcent (0..100); mod	D4.L, D7.WCALCPOURCENT:	PUSHM.L	D0..D2	ADD.L	D0,D1		; D0 <-- U+R, D1 <-- U	CLR.W	D2	COMP.L	D0,#10000	JUMP',LO 20$		;	  0 ..   9'999 => /1	LOAD.W	D2,#3		;    10'000 ..  99'999 => /8	COMP.L	D0,#100000	;   100'000 .. 999'999 => /64	JUMP',LO 20$		; 1'000'000 .. infini  => /512	LOAD.W	D2,#6	COMP.L	D0,#1000000	JUMP',LO 20$	LOAD.W	D2,#920$:	SR.L	D0,D2		; D0 <-- R/1 ou R/8 ou R/64	SR.L	D1,D2		; D1 <-- U/1 ou U/8 ou U/64	MUL.WU	D1,#100	DIV.WU	D1,D0		; D1 <-- (U*100)/(U+R)	CLR.L	D4	LOAD.W	D4,D1		; D4 <-- utilis en %	POPM.L	D0..D2	RET;--------\; MINMAJ  >;========/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMINMAJ:	TEST.L	D3:#7		; code "supplmentaire" ?	JUMP',NE 20$		; oui => 20$	COMP.B	D3,#SPACE-2	; lettre accentue ?	JUMP',LO 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+70$  ; D3 <-- lettre majuscule	POP.W	D0	RET70$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN	.END