	.TITLE	DGENC.ASL	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal	.REF	SMAKY	.REF	MODULES	.REF	XCAR	.REF	DOLIB;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;LIB?FLUSHNGC = LIB_BASE+147;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; Date		Rev	Amliorations; ---------------------------------------------------------------------------------; 04.05.90	2.26	DGENC_MODIF: propose des noms de fonctions par dfaut; 30.03.90	2.25	DGENC_MODIF: propose un nom de fonction si oubli;			DGENC_MODIF: affichage "Abc" ok mais si FCA=32 et LCA=63 !; 11.07.89	2.24	DGENC_MODIF: affiche les car. construits selon la taille; 04.07.89	2.23	DGENC_MODIF: (ANNULE) et (REFAIT) permuts; 29.06.89	2.22	DGENC_MODIF: (SAUVE) cre un fichier avec #:*.GENC; 23.06.89	2.21	DGENC_MODIF: (SAUVE) cre un fichier "nom!DGENC";			DGENC_MODIF: affiche aussi les gencars "soft";			DGENC_LIST: ne liste plus que les gencars SMA_; 15.06.89	2.20	DGENC_MODIF: utilise XCAR_SHOW pour "Abc"; 14.06.89	2.19	DGENC_MODIF: ne met plus ".." si taille nulle; 06.06.89	2.18	DGENC_MODIF: fait LIB,?FLUSHNGC si (REFAIT); 18.04.89	2.17	ok selon SMA_GENC.INFO;			choix de la taille pour les gencars "analytiques"; 28.11.88	2.16	DGENC_MODIF: n'affiche plus le gencar en clair !; 19.10.88	2.15	DGENC_MODIF: n'affiche plus 2x le mme gencar; 17.10.88	2.14	DGENC_MODIF: ne tient plus compte des assignations; 05.07.88	2.13	PREND/SAUVE fichiers .DGENC;			DGENC_MODIF: nouvelle case REFAIT; 25.05.88	2.12	utilise les scroll-liste; 03.12.87	2.11	utilise LIB,?TEXTGC pour le noms de gencars; 25.11.87	2.10	POP32 = "Polka"; 21.10.87	2.9	utilise DBOX_GETCO avec BDBGCGREY/FULL; 30.07.87	2.8	message d'erreurs adapts  DBOX_TERROR; 26.06.87	2.7	DGENC_MODIF: liste toutes les options (FOS);			DGENC_MODIF: pages dans l'ascenseur;			DGENC_MODIF: si fonte D/Q => interdit ombr, etc.;			DGENC_MODIF: option "affiche" dclenche par dfaut;			DGENC_MODIF: affiche les fontes "Palatino", etc.;			DGENC_MODIF: gras, italique, etc. en plein/gris;			OGCVAR false si DRF ou QRF (true si DRP ou QRP); 26.02.87	2.6	(SUPPRIME) en gris si invalide; 26.01.87	2.5	Abc: ouvre le fichier (SMA,100)_NRF09.GENC;			Abc: affichage ok mme si trs grand;		2.4	affiche mme si pas style roman;			affiche "Univers   URP16";		2.3	jamais 2x le mme gencar dans la liste;			affiche toujours les gencars LQ_, OKI_, etc.; 		2.2	case "Laser" force les noms sans ( );			affiche aussi les fichiers SMA_*.GENC;			n'affiche plus les fichiers sans attribut "L";			ok avec caractres ayant une rf gauche non nulle	.REV	2,26	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------KEYDBOX	=	H'7E00		; "touche" spciale; Dfinition de l'entte d'un gnrateur de caractres; ----------------------------------------------------OGCDATA	=	H'180		; dbut data matrices; Variables; ---------LBUFILE	=	50	.LOC	0OMDMOD:	.BLKB	2		; mode d'ouvertureOMDPOS:	.BLKB	4		; position centre si BDBPOS dans modeOMDPDD:	.BLKB	4		; ^descripteur de la fentreOMDDIS:	.BLKB	30		; buffer pour write-displayOMDPLN:	.BLKB	4		; ^nom de l'imprimanteOMDPLF:	.BLKB	4		; ^flag (-1 si vide, autre si plein)OMDPLV:	.BLKB	4		; ^qq variables permamantesOMDPLI:	.BLKB	4		; ^liste des gencarsOMDLLI:	.BLKB	2		; lg liste des gencarsOMDPGC:	.BLKB	4		; ^buffer des gencarsOMDNOK:	.BLKB	4		; gencar  ne jamais dtruireOMDPGM:	.BLKB	4		; ^gencar  modifierOMDGEN:	.BLKB	4		; -fst choisitOMDNGC:	.BLKB	LGTGC		; nom du gencarOMDNTA:	.BLKB	6		; nom de la tailleOMDPOZ:	.BLKB	4		; coin sup/gauche zoneOMDDIZ:	.BLKB	4		; dimensions zoneOMDASL:	.BLKB	LSLVAR		; variables de la scroll-listeOMDLGR:	.BLKB	2		; rang du dernier gencar rduitOMDLGT:	.BLKB	2		; taille du dernier gencar rduitOMDPGR:	.BLKB	4		; ^gencar rduitOMDFIL:	.BLKB	LBUFILE		; nom du fichier .DGENCLGMD:; Variables dans la liste; -----------------------LGMN	=	10		; lg pour nom de l'imprimante	.LOC	0OMVPFI:	.BLKB	4		; ^contenu du fichier .DGENCOMVNOG:	.BLKB	1		; rang du gencar  mettre  jourOMVFAN:	.BLKB	1		; fanionsLGMV:				; lg pour qq variables permanantes; En-tte du module LIB; ---------------------	.LOC	0	DGENC_	FIRST		; code du premier appel	DGENC_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	2,26		; rvision.version	.W	0,END_DGENC	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"DGENC"		; nom du module	.FILLB	(LGHLIB-.),0	.W	_DGENC_MODIF	.W	_DGENC_LIST	.W	_DGENC_NIL	.W	_DGENC_DISGC	.W	_DGENC_ENAGC	.W	_DGENC_SEARCH	.W	_DGENC_FREE	.W	_DGENC_NEW	.W	_DGENC_KILL	.W	_DGENC_PUT	.W	_DGENC_GET	.W	_DGENC_MENU_DGENC_NIL:	CLR.W	D7		; retour EQ	RET	.INS	DGENCMOD.ASI	.INS	DGENCIO.ASI	.INS	DGENCONE.ASI	.INS	DGENCABC.ASI;--------\\; GETANUM >;--------/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSHM.L	D2,D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	SL.L	D4,#1	LOAD.L	D2,D4	SL.L	D4,#2	ADD.L	D4,D2		; D4 <-- pousse d'un digit (*10)	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POPM.L	D2,D3	RET;--------\; MINMAJ  >;========/; N'utilise pas LIB,?MINMAJ pour tre plus rapide !; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.WMINMAJ:	TEST.L	D3:#7		; code "supplmentaire" ?	JUMP',NE 20$		; oui => 20$	COMP.B	D3,#SPACE-2	; lettre accentue ?	JUMP',LO 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	SUB.B	D3,#'	AND.W	D3,#H'FF	LOAD.B	D3,(PC)+(D3)+70$  ; D3 <-- lettre majuscule	RET70$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN;--------\\; MAJMIN  >;========/; Effectue une conversion MAJUSCULE --> minuscule.; in	D3.B	caractre; out	D3.B	caractre; mod	D3.BMAJMIN:	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'Z	JUMP',HI 90$	ADD.B	D3,#'a-'A90$:	RETDOF1:	LOAD.W	D3,#F1	RETDOF4:	LOAD.W	D3,#F4	RETDOOK:	LOAD.W	D3,#CR	RETDOAN:	LOAD.W	D3,#END	RETDOMP:	LOAD.W	D3,#KEYMGP	RETDOMR:	LOAD.W	D3,#KEYMGR	RET; Textes; ------TERGNN:	.ASCII	"Vous devez encore indiquer<CR>"	.ASCIZ	"la fonction du caractre !"TERGNE:	.ASCIZ	"Cette fonction existe dj !"TERGFN:	.ASCIZ	"Ce caractre n'existe pas !"NAMDBOX:.ASCIZ	"DBOX"TGC:	.ASCIZ	"*.GENC"	; fichiers  listerTGCSMA:	.ASCIZ	"SMA"		; prfixe gnral	.EVENEND_DGENC:	.END