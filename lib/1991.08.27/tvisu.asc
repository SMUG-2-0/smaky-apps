	.TITLE	TVISU	.PROC	M680002	.REF	SMAKY	.REF	MODULES	.LOC	0OCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOBUNAME:.BLKB	50LGVAR:	.LOC	0START:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.B	D3,#EOP	LIB	?AFCAR	LOAD.L	A6,#R16"VAR	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE EXIT	LOAD.W	(A6)+OCHLIST,D1	LIB	?GETPDIS	LOAD.L	A0,A4	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE EXIT	LOAD.W	(A6)+OCHSCROLL,D1LOOP:	LIB	?AFTIM	.ASCIZ	"<CR>Nom de fichier : "	.EVEN	LOAD.L	A3,#(A6)+OBUNAME	LOAD.W	D3,#50	LIB	?GETLINE	COMP.W	D3,#CR	JUMP,NE EXIT	LOAD.L	A4,A310$:	COMP.B	(A4+),#CR	JUMP,NE 10$	CLR.B	(A4)-1	LOAD.L	D2,#VISU_OPEN	LIST_	VISU	JUMP,NE ERROR	LOAD.L	D2,#VISU_DRAW!2^BLIVDRECT!2^BLIVDINFO!2^BLIVDASC	LOAD.L	D3,#H'10000*10+50	LOAD.L	D4,#H'10000*300+500	LIST_	VISU	CLR.L	D3	LOAD.L	D2,#VISU_UPDATE	LIST_	VISU	LOAD.L	D2,#VISU_INFO	LIST_	VISU50$:	LIB	?GETCAR	COMP.W	D3,#END	JUMP,EQ 60$	COMP.W	D3,#KEYMGP	JUMP,NE 50$	LIB	?IFMOUSE	LOAD.L	D2,#VISU_MOVE	LIST_	VISU	JUMP	50$60$:	LOAD.L	D2,#VISU_CLOSE	LIST_	VISU	JUMP	LOOPERROR:	LIB	?AFERROR	LIB	?GETCAREXIT:	LOAD.B	D3,#EOP	LIB	?AFCAR	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LIB	?CLOLIB	FOS	?STOPNMLIST:	.ASCIZ	"LIST"NMSCROLL:.ASCIZ	"SCROLL"	.EVENVAR:	.FILLB	LGVAR,0	.END	START