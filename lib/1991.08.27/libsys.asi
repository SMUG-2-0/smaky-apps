	.SBTTL	LIBSYSBNOA6	=	15		; appel n'utilisant pas (A6);--------\; INIRST  >;========/; Initialise l'indirection du restart LIB.; in	D0.W	zro  => pas d'overlays;		autre => overlays; out	-; mod	-INIRST:	PUSHM.L	D3..D6,A3..A6	LOAD.L	A5,#R16"START	; A5 <-- adr absolue librairie	LOAD.L	A6,_VARLIB	; A6 <-- ^variables globales	LOAD.L	(A6)+OSTART,A5	; init (A6)+OSTART	LOAD.L	A5,#R16"RSTSYS	LOAD.W	D5,#32+6	; D5 <-- trap #6	NTREL	?IEPSYSLINEA	; init restart;;?	LOAD.L	H'80+6*4,A5	; init restart;	CLR.L	(A6)+OSOPOS	; clear position souris;	CLR.W	(A6)+OSOKEY	; clear boutons souris	LOAD.L	A3,#R16"NAME$	CLR.L	D3	FOS	?CLOAD		; charge SYSTEM.CODE	JUMP',NE 30$	LOAD.W	(A6)+OSYREV,(A4)-256+OBXREV	FOS	?CUNLOAD	; dcharge SYSTEM.CODE	JUMP'	90$30$:	COMP.W	D7,#EROUTF	JUMP',NE 80$	LOAD.W	D3,#2^BOPRD!2^BOPSYS	FOS	?OPEN		; ouvre SYSTEM.CODE	JUMP',NE 80$	LOAD.L	A4,#(A6)+OSYREV	LOAD.L	D4,#2	FOS	?RDBYTE		; lit SYSTEM.CODE	PUSH.W	D7	FOS	?CLOSE		; ferme SYSTEM.CODE	POP.W	D780$:	TEST.W	D7		; lecture de la rvision ok ?	JUMP',EQ 90$		; oui => 90$	CLR.W	(A6)+OSYREV	; non => met zro !90$:	POPM.L	D3..D6,A3..A6	RETNAME$:	.ASCIZ	"SYSTEM.CODE"	.EVEN;--------\; RSTSYS  >;========/; Modifie A0 et D0.; Mais sauve D0,D1,A0,A1.RSTSYS:	PUSHM.L	D0,D1,A0,A1,A6	LOAD.L	A0,(SP)+5*4+2	; A0 <-- adresse de retour	CLR.L	D0	LOAD.W	D0,(A0+)	; D0 <-- numro de l'appel	LOAD.L	(SP)+5*4+2,A0	; ajuste l'adresse de retour	COMP.W	D0,#LIBMXC	; no d'appel correct ?	JUMP,HS FATCALL		; non => erreur fatale	SL.L	D0,#1		; *2 car ADSYS contient des .W	LOAD.W	D0,(PC)+(D0.W)+ADSYS ; D0 <-- adresse routine	TCLR.L	D0:#BNOA6	; appel utilisant (A6) ?	JUMP',BS 40$		; non => 40$				; oui =>	PUSH.W	D7	CALL	GETUVAR		; A6 <-- ^variables locales	JUMP',EQ 30$		; ok => 30$	POP.W	D0		; erreur => 90$	JUMP'	90$30$:	POP.W	D740$:	LOAD.L	A0,#R16"START	; A0 <-- ^dbut code lib.	CALL	(A0)+(D0.W)	; excute l'appel systme ...90$:	POPM.L	D0,D1,A0,A1,A6	TEST.W	D7	PUSH.W	F	LOAD.B	(SP)+3,(SP)+1	POP.W	F	RETSFADSYS:	.W	_OPELIB!2^BNOA6		; 0	.W	_CLOLIB			; 1	.W	_AFCAR			; 2	.W	_AFCODE			; 3	.W	_AFCR			; 4	.W	_AFSPACE		; 5	.W	_AFTAB			; 6	.W	_AFBS			; 7	.W	_AFTEXT			; 8	.W	_SAFTIM			; 9	.W	_MAFTEXT		; 10	.W	_SMAFTIM		; 11	.W	_AFX2			; 12	.W	_AFX4			; 13	.W	_AFX8			; 14	.W	_AFB8			; 15	.W	_AFDEC			; 16	.W	_GETCAR			; 17	.W	_GETLINE		; 18	.W	_GETHEX			; 19	.W	_GETDEC			; 20	.W	_BUZZ			; 21	.W	_BEEP			; 22	.W	_MINMAJ!2^BNOA6		; 23	.W	_BCDBIN!2^BNOA6		; 24	.W	_BINBCD!2^BNOA6		; 25	.W	_YESNO			; 26	.W	_SURE?			; 27	.W	_SETCURS		; 28	.W	_GETCURS		; 29	.W	_AFMENU			; 30	.W	_AFERROR		; 31	.W	_EDIT			; 32	.W	_INSERT!2^BNOA6		; 33	.W	_GCHDIS			; 34	.W	_GCHKEY			; 35	.W	_GETKEY			; 36	.W	_PCHDIS			; 37	.W	_PCHKEY			; 38	.W	_GETUPH			; 39	.W	_LGXCAR			; 40	.W	_GETDIM			; 41	.W	_RDCLOCK		; 42	.W	_GETLGF			; 43	.W	_GETFILE		; 44	.W	_PLAY			; 45	.W	_BUCAR			; 46	.W	_NOBUCAR		; 47	.W	_FLUSH			; 48	.W	_STRING			; 49	.W	_ASSKEY			; 50	.W	_SRCWDO			; 51	.W	_IFCAR			; 52	.W	_ACCORD			; 53	.W	_RDMOUSE		; 54	.W	_MRDMOUSE		; 55	.W	_GCHMOU			; 56	.W	_PCHMOU			; 57	.W	_PXMOUSE		; 58	.W	_PYMOUSE		; 59	.W	_PDUMP			; 60	.W	_DISWKEY		; 61	.W	_WOCLIB			; 62	.W	_GETLAN!2^BNOA6		; 63	.W	_SETBARRE		; 64	.W	_CLRBARRE		; 65	.W	_INVBARRE		; 66	.W	_GTCOMM			; 67	.W	_TRCOMM			; 68	.W	_SNCOMM			; 69	.W	_VASSKEY		; 70	.W	_MOUSE			; 71	.W	_SRCKEY			; 72	.W	_IFMOUSE		; 73	.W	_FCREATE		; 74	.W	_FCHANGE		; 75	.W	_IFSWITCH		; 76	.W	_CPSTRING!2^BNOA6	; 77	.W	_AFFILE			; 78	.W	_WRKEY			; 79	.W	_GTRSMM			; 80	.W	_CREWDO			; 81	.W	_KILWDO			; 82	.W	_USEWDO			; 83	.W	_MODWDO			; 84	.W	_GETWDO			; 85	.W	_SWITCH!2^BNOA6		; 86	.W	_SKPNAM!2^BNOA6		; 87	.W	_RSTGC			; 88	.W	NIET			; 89	.W	NIET			; 90	.W	_DRSEG			; 91	.W	_DRRECT			; 92	.W	_DRMDEF			; 93	.W	_DRTRAME		; 94	.W	_MMENU			; 95	.W	_DRCERCLE		; 96	.W	_SYNGC!2^BNOA6		; 97	.W	_PTMENU			; 98	.W	NIET			; 99	.W	NIET			; 100	.W	_OEXECUTE		; 101	.W	_PFDUMP			; 102	.W	_ADDEXT!2^BNOA6		; 103	.W	_SRCCHK			; 104	.W	_WAITMOUSE		; 105	.W	_DRRECTO		; 106	.W	_GMOUSE			; 107	.W	_ASSBITMAP		; 108	.W	_CLOLIBK		; 109	.W	_WRAKEY			; 110	.W	_CLREDIT		; 111	.W	_SRCKNP			; 112	.W	_AFXFILE		; 113	.W	_REPKEY			; 114	.W	_BASSKEY		; 115	.W	_GETSHIFT		; 116	.W	_PUTDEC			; 117	.W	_PUTXFILE		; 118	.W	_PUSHMENU		; 119	.W	_POPMENU		; 120	.W	_TEXTGC!2^BNOA6		; 121	.W	_GTABGC!2^BNOA6		; 122	.W	_OPEBITMAP		; 123	.W	_CLOBITMAP		; 124	.W	_DRRECTA		; 125	.W	_DRTRAMEA		; 126	.W	_DRARC			; 127	.W	_DRTRANCHE		; 128	.W	_DRELLIPSE		; 129	.W	_DRPOLYGONE		; 130	.W	_CALCHYPO!2^BNOA6	; 131	.W	_CALCANGLE!2^BNOA6	; 132	.W	_CALCPSYM!2^BNOA6	; 133	.W	_CALCPELLI!2^BNOA6	; 134	.W	_CALCSIN!2^BNOA6	; 135	.W	_CALCCOS!2^BNOA6	; 136	.W	_MMENUS			; 137	.W	_COLORSA		; 138	.W	_COLORCA		; 139	.W	_COLORSR		; 140	.W	_COLORCR		; 141	.W	_COLORPUSH		; 142	.W	_COLORPOP		; 143	.W	_PPMOUSE		; 144	.W	_PMOUSE			; 145	.W	_GETPDIS		; 146	.W	_FLUSHNGC!2^BNOA6	; 147	.W	_ADDNGC!2^BNOA6		; 148	.W	_SUBNGC!2^BNOA6		; 149	.W	_MAJNGC!2^BNOA6		; 150FATCALL:	.W	H'A042		; appel MON,?AFTIM	.ASCIZ  /<CR>Numro d'appel LIB incorrect<CR>/	.EVEN	TRAP	#1		; illegal system trap callNIET:	CLR.W	D7		; D7 <-- ok	RET	.END