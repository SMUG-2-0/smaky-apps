	.SBTTL	LISTDBOXBLISTAFF  =	16		; afficheBLISTALL  =	17		; liste les fichiers cachsBLISTINIT =	31BINFLRD	=	25		; liste rduite dans les dossiers (voir START);-----------\\; _LIST_DBOX >;===========/; Demande  l'utilisateur quel fichier il veut avec une jolie dbox.; in	A3.L	critre avec * et ? (.ext est quivalent  *.ext);	A4.L	^buffer pour nom;	D2.W	mode d'ouverture pour la dbox;	D3.L	position centre (y;x) si BDBPOS dans D2.W;	D4.L	modes (BLIDB..);	A2.L	^nom de la touche (CHOISIT), si BLIDBNOM dans D4.L; out	D3.W	dernire touche (RETURN/END);	D7.W	erreur; mod	D3.L, D7.W_LIST_DBOX:	PUSHM.L	D0..D2,D4..D6,A0..A6	LOAD.L	A0,A3		; A0 <-- ^critre	LOAD.L	A1,A4		; A1 <-- ^buffer pour nom	LOAD.L	D0,D4		; D0 <-- modes	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	D4,#LGDBOX	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE EXIT9$	LOAD.L	A6,A4		; A6 <-- ^variables	SR.L	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMOCLRMEM$:	CLR.W	(A4+)		; met toutes les variables  zro	DECJ.W,NMO D4,CLRMEM$	LOAD.W	(A6)+ODBOPM,D2	; mm. mode	LOAD.L	(A6)+ODBOPP,D3	; mm. position	LOAD.L	(A6)+ODBMOD,D0	; mm. modes	LOAD.L	(A6)+ODBPNK,A2	; mm. ^nom pour (CHOISIT)	LOAD.L	(A6)+ODBPBN,A1	; mm ^buffer pour nom	LOAD.L	(A6)+ODBPCR,A0	; mm ^critre	LOAD.L	A3,#R16"NAMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN		; ouvre le module dbox	JUMP,NE EXIT7$	LOAD.W	(A6)+ODBCHD,D1	LOAD.L	A3,#R16"NAMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN		; ouvre le module scroll	JUMP,NE EXIT6$	LOAD.W	(A6)+ODBCHS,D1	CALL	PREPCRIT	; ODBCRI <-- critre	LOAD.L	A3,(A6)+ODBPCR	LOAD.L	A4,#(A6)+ODBTYP	; A4 <-- ^buffer pour liste des typesTLOOP$:	CALL	_LIST_VISUTYPE	; D3 <-- type	LOAD.W	(A4+),D3	; ODBTYP <-- un typeTNEXT$:	LOAD.B	D3,(A3+)	JUMP',EQ TEND$	COMP.B	D3,#CR	JUMP',EQ TEND$	COMP.B	D3,#'|	JUMP,NE TNEXT$	JUMP	TLOOP$TEND$:	LOAD.W	(A4),#-1	; ODBTYP <-- terminateur; Affiche dj la dbox vide pour faire patienter un peu.	LIB	?GETPDIS	; A4 <-- ^descripteur	LOAD.L	A0,A4		; A0 <-- ^descripteur	LOAD.L	A2,#R16"TDBOXLIST	LOAD.W	D2,(A6)+ODBOPM	; D2 <-- mode	TSET.L	D2:#BDBMAX	LOAD.L	D3,(A6)+ODBOPP	; D3 <-- position	LOAD.L	D4,#2^BLISTALG!2^BLISTINIT	LOAD.L	(A6)+ODBFAN,D4	DBOX_	OPEN		; D5 <-- canal	JUMP,NE EXIT5$REFAIT$:	CALL	WAITMOUSE	; souris: met le sablier	TEST.L	(A6)+ODBPLI	JUMP',EQ GIVLIST$	LOAD.L	A4,(A6)+ODBPLI	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de la listeGIVLIST$:	LOAD.W	D2,#101!2^BDBGCLABEL	DBOX_	GETCO		; D3 <-- coordonne dbut	SUB.L	D3,#H'10000*6	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#NBLI	SWAP.W	D4	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#LGNAME+LGSUITE	ADD.W	D2,#LGSCROLL	LOAD.W	D4,D2		; D4 <-- largeur X	LOAD.L	A5,#(A6)+ODBVSL	; A5 <-- ^variables	LOAD.L	(A5)+OSLPOS,D3	LOAD.L	(A5)+OSLDIM,D4	SET.B	(A5)+OSLASV+OSCPAGE ; met les pages	SCROLL_	LDRAW		; dessine le grand rectangle	PUSH.L	(A6)+ODBFAN	TCLR.B	(A6)+ODBFAN+1:#BLISTAFF-16 ; n'affiche pas	CLR.W	D1		; D1 <-- mode DRAW	CALL	DBOXVISU	; dessine juste le cadre	POP.L	(A6)+ODBFAN; Met tous les fichiers  lister dans un grand buffer avec leurs; attributs.	LOAD.L	A3,#(A6)+ODBCRI	; A3 <-- ^critre	LOAD.L	D3,#2^BOPEXTEND!2^BLIDOSSIER!2^BLICEXT!2^BOPNAME	CALL	_LIST_SOPEN	; D6 <-- canal	JUMP',EQ LISTOK$	; ok => LISTOK$				; erreur =>	PUSH.W	D7	DBOX_	CLOSE		; ferme la dbox	CALL	NORMMOUSE	; souris: enlve le sablier	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un vilain bruit	POP.W	D7	LOAD.W	D2,(A6)+ODBOPM	; D2 <-- mode	LOAD.L	D3,(A6)+ODBOPP	; D3 <-- position	DBOX_	MERROR		; affiche l'erreur ...	LOAD.W	D3,#END		; D3 <-- comme si (ANNULE)	JUMP	EXIT5$LISTOK$:	CALL	IFVERROU	CALL	_LIST_NBMAX	; D4 <-- nb max de noms	LOAD.W	(A6)+ODBNBF,D4	MUL.WU	D4,#LGARGS	; D4 <-- place pour tous les fichiers	INC.L	D4		; D4 <-- place pour le terminateur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour liste	JUMP,NE ANNULE$	LOAD.L	(A6)+ODBPLI,A4	; mm. ^liste	LOAD.L	A5,A4		; A5 <-- ^buffer des noms	LOAD.W	D4,(A6)+ODBNBF	; D4 <-- nb max de noms	CLR.W	D2		; D2 <-- nb de noms  lister	CLR.W	D1		; D1 <-- idem, mais sans les dossiersLISTNXT$:	CALL	_LIST_NEXT	; A3 <-- ^nom et A4 <-- ^arguments	JUMP',NE LISTEND$	; y'en a plus => LISTEND$	TEST.B	(A4)+OBAATT+2:#BATTP-8 ; dossier ?	JUMP',BS LISTDIR$	; oui => LISTDIR$	TEST.B	(A6)+ODBFAN+1:#BLISTALL-16 ; liste tout ?	JUMP',BS LISTPUT$	; oui => LISTPUT$	TEST.B	(A4)+OBAATT+2:#BATTL-8 ; fichier visible ?	JUMP',BC LISTCAC$	; non => LISTCAC$	JUMP'	LISTPUT$LISTDIR$:	TEST.B	(A4)+OBAATT+2:#BATTL-8 ; dossier visible ?	JUMP',BC LISTCAC$	; non => LISTCAC$	CALL	DBOXIFDOS	; dossier DOSSIER: ?	JUMP',EQ LISTCAC$	; oui => LISTCAC$	DEC.W	D1		; D1 <-- annule l'effet du INC.W plus basLISTPUT$:	LOAD.W	D3,#(LGNAME/4)-1LISTNAM$:	LOAD.L	(A5+),(A3+)	; buffer <-- nom du fichier	DECJ.W,NMO D3,LISTNAM$	LOAD.W	D3,#((LGARGS-LGNAME)/4)-1LISTARG$:	LOAD.L	(A5+),(A4+)	; buffer <-- arguments	DECJ.W,NMO D3,LISTARG$	INC.W	D2		; D2 <-- un fichier de plus	INC.W	D1		; D1 <-- un fichier de plusLISTCAC$:	DEC.W	D4	JUMP,NE LISTNXT$LISTEND$:	CLR.B	(A5)		; buffer <-- terminateur	LOAD.W	(A6)+ODBNBF,D2	LOAD.W	(A6)+ODBNBD,D1	CALL	_LIST_CLOSE	; ferme le canal de liste	CALL	DBOXAFCRIT	; affiche le critre	CALL	DBOXAFDIR	; grise/dgrise (DOSSIER COURANT); Dialogue avec l'utilisateur au moyen d'une dbox.	LOAD.W	(A6)+ODBVSL+OSLCYN,(A6)+ODBNBF	CLR.W	(A6)+ODBVSL+OSLCYS	LOAD.L	A3,#R16"AFCASE	LOAD.L	(A6)+ODBVSL+OSLADL,A3	LOAD.L	A5,#(A6)+ODBVSL	; A5 <-- ^variables	SCROLL_	LUPDATE		; met les noms dans le rectangleLOOP$:	CALL	DBOXAFKEY	; affiche la touche (CHOISIT)	CLR.W	D1		; D1 <-- mode DRAWLOOP1$:	CALL	DBOXVISU	; visualise le fichier	CALL	DBOXVMAJ	; met  jour les textes d'optionsLOOP2$:	CALL	NORMMOUSE	; souris: enlve le sablierLOOP3$:	LOAD.W	D4,#1	NTREL	?SETTIM		; met timeout trs court	LOAD.L	D4,(A6)+ODBFAN	; D4 <-- fanions	DBOX_	EDIT		; attend action ...	LOAD.L	(A6)+ODBFAN,D4	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	TEST.W	D3	JUMP,EQ TIMEOUT$	LOAD.L	A1,#R16"TKEYLIST	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ LOOP2$	COMP.W	D3,#KEYMGP	; bouton souris press ?	JUMP,EQ CLIC$	CLR.W	D7		; D7 <-- ok	COMP.W	D3,#CR		; (PREND) ou (OUVRE) ?	JUMP,EQ OK$		; oui => OK$	COMP.W	D3,#END		; (ANNULE) ?	JUMP,EQ ANNULE$		; oui => ANNULE$	COMP.W	D3,#KEYDBOX+102	JUMP,EQ MENU$	COMP.W	D3,#KEYDBOX+103	JUMP,EQ CRIT$	COMP.W	D3,#F7	JUMP,EQ DIR$	CLR.W	D1		; D1 <-- mode DRAW	COMP.W	D3,#KEYDBOX+BLISTAFF	JUMP,EQ LOOP1$	INC.W	D1		; D1 <-- mode UPDATE	COMP.W	D3,#KEYDBOX+BLIVUOPT1	JUMP,EQ LOOP1$	COMP.W	D3,#KEYDBOX+BLIVUOPT2	JUMP,EQ LOOP1$	COMP.W	D3,#KEYDBOX+BLIVUOPT3	JUMP,EQ LOOP1$	COMP.W	D3,#KEYDBOX+BLISTALG	JUMP',EQ CIRCLE$	COMP.W	D3,#KEYDBOX+BLISTADC	JUMP',EQ CIRCLE$	COMP.W	D3,#KEYDBOX+BLISTADM	JUMP',EQ CIRCLE$	COMP.W	D3,#KEYDBOX+BLISTADU	JUMP',EQ CIRCLE$BIP$:	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP2$	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP2$TIMEOUT$:	LOAD.L	D6,(A6)+ODBCHV	JUMP,EQ LOOP3$	CALL	_LIST_VISULUTIN	; modifie v. le lutin de la souris	JUMP	LOOP3$CIRCLE$:	LOAD.L	A5,#(A6)+ODBVSL	; A5 <-- ^variables	SCROLL_	LUPDATE		; met les noms dans le rectangle	JUMP	LOOP2$CLIC$:	LOAD.L	A5,#(A6)+ODBVSL	; A5 <-- ^variables	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	SCROLL_	LMOVE		; dplace dans la scroll-list ...	JUMP,EQ LOOP$	LOAD.L	D6,(A6)+ODBCHV	JUMP,EQ BIP$	CALL	_LIST_VISUMOVE	; dplace la visualisation ...	JUMP,EQ LOOP2$	JUMP	BIP$MENU$:	CALL	MENUCRIT	; redescend selon mmenu ...	JUMP,NE BIP$	JUMP	REFAIT$CRIT$:	CALL	DBOXCRIT	; modifie le critre ...	JUMP,NE BIP$	COMP.W	D3,#CR	JUMP,NE LOOP2$	JUMP	REFAIT$DIR$:	LOAD.L	A3,#0	FOS	?REL		; annule tous les DIR	LOAD.L	A3,#(A6)+ODBCRI	; A3 <-- ^critre	CALL	SKIPREP		; A3 <-- ^rep(s): et A4 <-- ^nom	PUSH.B	(A4)+0	PUSH.B	(A4)+1	LOAD.B	(A4)+0,#',	CLR.B	(A4)+1	FOS	?DIR		; nouveau DIR	POP.B	(A4)+1	POP.B	(A4)+0	CALL	DBOXAFDIR	; grise/dgrise (DOSSIER COURANT)	JUMP	LOOP2$OK$:				; PREND/OUVRE =>	TEST.B	(A6)+ODBNOP	JUMP,NE BIP$	LOAD.L	A3,(A6)+ODBPLI	; A3 <-- ^premier nom	LOAD.W	D0,(A6)+ODBVSL+OSLCYS	MUL.WU	D0,#LGARGS	ADD.L	A3,D0		; A3 <-- ^nom slectionn	TEST.B	(A3)+OBLATT+2:#BATTP-8 ; est-ce un dossier ?	JUMP',BC PREND$		; non => PREND$				; OUVRE =>	CALL	ADDDCRIT	; ODBCRI <-- ajoute un nom de dossier	JUMP	REFAIT$PREND$:				; PREND =>	LOAD.L	A4,(A6)+ODBPBN	; A4 <-- ^buffer pour nom	CALL	PUTCRIT		; ODBPBN <-- nom choisit	CLR.W	D7		; D7 <-- okANNULE$:	LOAD.L	D6,(A6)+ODBCHV	; canal existe ?	JUMP',EQ EXIT2$		; non => EXIT2$	PUSH.W	D7	CALL	_LIST_VISUCLOSE	; ferme la dernire visualisation	CLR.L	(A6)+ODBCHV	POP.W	D7EXIT2$:	PUSH.W	D7	DBOX_	CLOSE		; ferme la dbox	POP.W	D7EXIT5$:	PUSH.W	D7	LOAD.W	D1,(A6)+ODBCHS	LIB_	CLOSE		; ferme le module scroll	POP.W	D7EXIT6$:	PUSH.W	D7	LOAD.W	D1,(A6)+ODBCHD	LIB_	CLOSE		; ferme le module dbox	POP.W	D7EXIT7$:	TEST.L	(A6)+ODBPLI	JUMP',EQ EXIT8$	PUSH.W	D7	LOAD.L	A4,(A6)+ODBPLI	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de la liste	POP.W	D7EXIT8$:	PUSH.W	D7	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire des variables	POP.W	D7EXIT9$:	PUSH.W	D7	CALL	NORMMOUSE	; souris: enlve le sablier	POP.W	D7	LOAD.L	A4,A3		; A4 <-- ^nom (si D7.W=0)	POPM.L	D0..D2,D4..D6,A0..A6	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXIFDOS >;----------/; Regarde s'il s'agit du dossier DOSSIER: ?; in	A3.L	^nom de dossier; out	EQ	si c'est DOSSIER:; mod	-DBOXIFDOS:	PUSHM.L	A3,A4	LOAD.L	A4,#R16"TEXT$10$:	TEST.B	(A3)	JUMP',EQ 30$	COMP.B	(A3+),(A4+)	JUMP,EQ 10$	JUMP'	90$30$:	TEST.B	(A4)90$:	POPM.L	A3,A4	RETTEXT$:	.ASCIZ	"DOSSIER:"	.EVEN;----------\\; DBOXAFKEY >;----------/; Affiche le texte dans la touche (CHOISIT).; in	-; out	-; mod	D7.WDBOXAFKEY:	PUSHM.L	D2..D4,A2..A4	TEST.B	(A6)+ODBNOP	JUMP',EQ 10$	LOAD.W	D2,#110!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO10$:	LOAD.W	D2,#110!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	LIB	?SETCURS	LOAD.L	A3,#R16"DEF$	; A3 <-- ^texte (CHOISIT)	TEST.B	(A6)+ODBMOD+3:#BLIDBNOM	JUMP',BC 20$	LOAD.L	A3,(A6)+ODBPNK	; A3 <-- A2 donn en entre20$:	TEST.W	(A6)+ODBVSL+OSLCYN	JUMP',EQ 25$	LOAD.L	A4,(A6)+ODBPLI	LOAD.W	D4,(A6)+ODBVSL+OSLCYS	MUL.WU	D4,#LGARGS	ADD.L	A4,D4		; A4 <-- ^nom et arguments	TEST.B	(A4)+OBLATT+2:#BATTP-8 ; est-ce un dossier ?	JUMP',BC 25$		; non => 25$	PUSH.L	A3	LOAD.L	A3,#R16"SYSL$	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; est-ce le fichier "SYS_LIST" ?	POPM.L	A3	JUMP',NE 24$	CLR.L	(A4)+OBLATT	JUMP'	25$24$:	LOAD.L	A3,#R16"DIR$	; A3 <-- ^texte (OUVRE)25$:	LOAD.L	A4,A3	LOAD.W	D4,#-130$:	INC.W	D4	TEST.B	(A4+)	JUMP,NE 30$	COMP.W	D4,#9	JUMP',LS 32$	LOAD.W	D4,#932$:	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.W	D3,#9	SUB.W	D3,D4	SR.W	D3,#1	LIB	?AFCAR		; affiche qq espaces pour centrer	LOAD.W	D3,D4	LIB	?STRING		; affiche la touche (CHOISIT)	TEST.W	(A6)+ODBVSL+OSLCYN	JUMP',EQ 80$	CLR.B	(A6)+ODBNOP	LOAD.L	A3,(A6)+ODBPLI	LOAD.W	D3,(A6)+ODBVSL+OSLCYS	MUL.WU	D3,#LGARGS	ADD.L	A3,D3		; A3 <-- ^nom et arguments	TEST.L	(A3)+OBLATT	; est-ce "SYS_LIST" ?	JUMP',EQ 80$		; oui => 80$	TEST.B	(A3)+OBLATT+2:#BATTP-8 ; est-ce un dossier ?	JUMP',BS 90$		; oui => 90$	CALL	_LIST_VISUTYPE	; D3 <-- type	LOAD.L	A4,#(A6)+ODBTYP	; A4 <-- ^liste des types40$:	LOAD.W	D4,(A4+)	; D4 <-- l'un des types accepts	COMP.W	D4,#-1	JUMP',EQ 80$	COMP.W	D3,D4		; est-ce le bon type ?	JUMP',EQ 90$		; oui => 90$	JUMP	40$80$:	SET.B	(A6)+ODBNOP	LOAD.W	D2,#110!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO90$:	POPM.L	D2..D4,A2..A4	RETSYSL$:	.ASCIZ	"SYS_LIST"TERM$:	.B	0,CR,-1DEF$:	.ASCIZ	"CHOISIT"DIR$:	.ASCIZ	" OUVRE "	.EVEN;----------\\; DBOXAFDIR >;----------/; Grise ou dgrise la touche (DOSSIER COURANT).; in	-; out	-; mod	D7.WDBOXAFDIR:	PUSHM.L	D2..D4	LOAD.W	D2,#111!2^BDBGCLABEL!2^BDBGCGREY	CALL	DBOXIFDIR	; est-on dans le dossier courant ?	JUMP',EQ 20$		; oui => 20$	LOAD.W	D2,#111!2^BDBGCLABEL!2^BDBGCFULL20$:	DBOX_	GETCO		; grise ou dgrise	POPM.L	D2..D4	RET;----------\\; DBOXIFDIR >;----------/; Regarde si l'on est dans le dossier courant.; in	-; out	D7.W	EQ => dossier courant;		NE => ailleurs; mod	D7.WDBOXIFDIR:	PUSHM.L	D2..D4,D6,A2..A4	FOS	?GDIR		; A3 <-- ^rpertoire courant	JUMP,NE 90$	LOAD.L	A2,#(A6)+ODBDIS	COMP.B	(A3),#'#	JUMP',EQ 20$	COMP.B	(A3),#'@	JUMP',EQ 20$	LOAD.L	A4,#R16"MM0$10$:	LOAD.B	(A2+),(A4+)	; ODBDIS <-- "#MM0:"	JUMP,NE 10$	DEC.L	A220$:	LOAD.L	D4,#LDBDIS-8	; D4 <-- lg buffer en (A2)	LOAD.L	D3,#2^BOPNEXT!2^BOPNAME!2^BOPNDIR	CLR.L	D2		; D2 <-- premier option	FOS	?ARGSOPEN	; ODBDIS <-- premire option	JUMP',NE 90$	LOAD.L	A2,#(A6)+ODBDIS	; A2 <-- ^dossier (?GDIR amlior)	LOAD.L	A3,#(A6)+ODBCRI	; A3 <-- ^critre	CALL	SKIPREP		; A3 <-- ^rep(s): et A4 <-- ^nom	LOAD.W	D7,#1		; D7 <-- ailleurs30$:	COMP.L	A3,A4	JUMP',EQ 40$	COMP.B	(A3+),(A2+)	JUMP,EQ 30$	JUMP'	90$40$:	TEST.B	(A2)	JUMP',NE 90$	CLR.W	D7		; D7 <-- dossier courant90$:	POPM.L	D2..D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETMM0$:	.ASCIZ	"#MM0:"	.EVEN;-----------\\; DBOXAFCRIT >;-----------/; Affiche le dernier dossier et le critre.; in	-; out	-; mod	D7.WDBOXAFCRIT:	PUSHM.L	D2,A2..A4	LOAD.L	A3,#(A6)+ODBCRI	; A3 <-- ^critre	CALL	SKIPREP		; A3 <-- ^rep(s): et A4 <-- ^nom	LOAD.L	A2,A4		; A2 <-- ^critre	COMP.L	A3,A4	JUMP',EQ 12$	DEC.L	A410$:	COMP.L	A3,A4	JUMP',EQ 12$	COMP.B	(-A4),#':	JUMP,NE 10$	INC.L	A412$:	LOAD.L	A3,#(A6)+ODBDIS	LOAD.B	(A3+),#SPACE14$:	LOAD.B	D2,(A4+)	COMP.B	D2,#':	JUMP',EQ 16$	LOAD.B	(A3+),D2	; ODBDIS <-- nom du dernier dossier	JUMP	14$16$:	LOAD.B	(A3+),#':	CLR.B	(A3)	LOAD.L	A3,#(A6)+ODBDIS	LOAD.W	D2,#102!2^BDBGCLABEL	CALL	DBOXAFTEXT	; affiche le dernier dossier	LOAD.L	A3,A2	LOAD.W	D2,#103!2^BDBGCLABEL	CALL	DBOXAFTEXT	; affiche le critre	POPM.L	D2,A2..A4	RET;-----------\\; DBOXAFTEXT >;-----------/; Affiche un texte dans une dbox.; in	D2.W	rang;	A3.L	^texte; out	-; mod	D7.WDBOXAFTEXT:	PUSHM.L	D2..D4,A3,A4	TSET.L	D2:#BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	; positionne le curseur au dbut	SUB.W	D4,D3	AND.L	D4,#H'FFFF	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb de caractres  afficher	DEC.W	D4	LOAD.L	A4,A3	LOAD.W	D3,#-120$:	INC.W	D3		; D3 <-- nb de caractres du nom	TEST.B	(A4+)	JUMP,NE 20$	COMP.W	D3,D4		; place pour tout afficher ?	JUMP',LS 50$		; oui => 50$				; non =>	LIB	?AFTIM		; affiche flche "<-" inverse	.B	AFINV,AFTOUT,5,AFNORM,AFDIR,0	.EVEN	DEC.W	D4	SUB.W	D3,D4	ADD.W	A3,D3	LOAD.W	D3,D4	LIB	?STRING		; affiche la fin du nom	LIB	?AFSPACE	JUMP'	90$50$:	LIB	?STRING		; affiche le nom	SUB.W	D4,D3	JUMP',EQ 90$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin90$:	POPM.L	D2..D4,A3,A4	RET;---------\\; DBOXVISU >;---------/; Visualise le fichier slectionn.; in	D1.W	0 => DRAW et 1 => UPDATE; out	-; mod	D7.WDBOXVISU:	PUSHM.L	D2..D4,D6,A3,A4	TEST.B	(A6)+ODBFAN+1:#BLISTAFF-16 ; affiche ?	JUMP',BC 10$		; non => 10$	COMP.W	D1,#1		; mode UPDATE ?	JUMP',NE 10$		; non => 10$	LOAD.L	D6,(A6)+ODBCHV	; canal existe ?	JUMP,NE 30$		; oui => 30$10$:	LOAD.L	D6,(A6)+ODBCHV	; canal existe ?	JUMP',EQ 15$		; non => 15$	CALL	_LIST_VISUCLOSE	; ferme la dernire visualisation	CLR.L	(A6)+ODBCHV15$:	TEST.B	(A6)+ODBFAN+1:#BLISTAFF-16 ; affiche ?	JUMP,BC 80$		; non => 80$	LOAD.L	A3,(A6)+ODBPLI	; A3 <-- ^premier nom	LOAD.W	D2,(A6)+ODBVSL+OSLCYS	MUL.WU	D2,#LGARGS	ADD.L	A3,D2		; A3 <-- ^nom slectionn	TEST.B	(A3)+OBLATT+2:#BATTP-8 ; est-ce un dossier ?	JUMP,BS 80$		; oui => 80$	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A4,#(A6)+ODBDIS	; A4 <-- ^buffer pour nom	CALL	PUTCRIT		; ODBDIS <-- nom choisit	LOAD.L	A3,A4		; A3 <-- ^nom choisit	LOAD.L	D2,#2^BLIVOMERR	; D2 <-- affiche les v. erreurs	CALL	_LIST_VISUOPEN	; ouvre une nouvelle visualisation	JUMP,NE 90$	LOAD.L	(A6)+ODBCHV,D6	LOAD.W	D2,#104!2^BDBGCLABEL	DBOX_	GETCO		; D3 <-- coordonne dbut	SUB.L	D3,#H'10000*6	LOAD.L	D4,(A6)+ODBVSL+OSLDIM ; D4 <-- dimensions	LOAD.L	D2,#2^BLIVDRECT!2^BLIVDASC	CALL	_LIST_VISUDRAW	; dessine le canevas30$:	CALL	_LIST_VISUPARAM	; D2/D3/D4/A4 <-- paramtres (D3 position relative)	LOAD.L	D2,(A6)+ODBFAN	TCLR.L	D2:#BLISTINIT	; premire initialisation ?	JUMP',BC 32$		; non => 32$	OR.L	D2,D4		; D2 <-- fanions par dfaut	LOAD.L	(A6)+ODBFAN,D232$:	AND.L	D2,#2^BLIVUOPT1!2^BLIVUOPT2!2^BLIVUOPT3	COMP.W	D1,#1		; mode UPDATE ?	JUMP',NE 35$	TSET.L	D2:#BLIVUNPOS35$:	CALL	_LIST_VISUUPDATE ; dessine le contenu	CLR.W	D7		; D7 <-- ok	JUMP	90$80$:	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfinit trame pour effacer	LOAD.W	D2,#104!2^BDBGCLABEL	DBOX_	GETCO		; D3 <-- coordonne dbut	SUB.L	D3,#H'10000*6	LOAD.L	D4,(A6)+ODBVSL+OSLDIM ; D4 <-- dimensions	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine le grand rectangle	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface tout	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXVMAJ >;---------/; Affiche les textes d'option dans les boutons carrs.; in	D1.W	0 => DRAW et 1 => UPDATE; out	-; mod	D7.WDBOXVMAJ:	PUSHM.L	D2..D4,A4	TEST.W	D1		; mode DRAW ?	JUMP',NE 90$		; non => 90$	LOAD.L	A4,#R16"NIL$	; A4 <-- ^textes vides	LOAD.L	D6,(A6)+ODBCHV	; canal existe ?	JUMP',EQ 20$		; non => 20$	CALL	_LIST_VISUPARAM	; D2/D3/D4/A4 <-- paramtres20$:	LOAD.W	D2,#BLIVUOPT1	CALL	DBOXVMONE	; grise/dgrise	LOAD.W	D2,#BLIVUOPT2	CALL	DBOXVMONE	; grise/dgrise	LOAD.W	D2,#BLIVUOPT3	CALL	DBOXVMONE	; grise/dgrise90$:	POPM.L	D2..D4,A4	RETNIL$:	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.EVEN;----------\\; DBOXVMONE >;----------/; Affiche un texte d'option pour un bouton carr.; in	D2.W	rang;	A4.L	^texte; out	A4.L	^texte suivant; mod	D7.W, A3.LDBOXVMONE:	PUSHM.L	D2..D4,A3	TEST.B	(A4)	JUMP',EQ 50$	TSET.L	D2:#BDBGCLABEL	TSET.L	D2:#BDBGCFULL	DBOX_	GETCO		; dgrise	TCLR.L	D2:#BDBGCFULL	DBOX_	GETCO		; D3 <-- coordonne dbut	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	LIB	?SETCURS	LOAD.L	A3,A4	LIB	?AFTEXT	JUMP'	80$50$:	LOAD.L	D4,(A6)+ODBFAN	TCLR.L	D4:D2	LOAD.L	(A6)+ODBFAN,D4	TSET.L	D2:#BDBGCLABEL	TSET.L	D2:#BDBGCGREY	DBOX_	GETCO		; grise80$:	TEST.B	(A4+)		; A4 <-- ^texte suivant	JUMP,NE 80$	POPM.L	D2..D4,A3	RET;---------\\; ADDDCRIT >;---------/; Ajoute un dossier dans le critre, par exemple :;;	(A3)	=	TITI:;	ODBCRI	=	#MM1:TOTO:*.TEXT;; Donne le critre suivant :;;	ODBCRI	=	#MM1:TOTO:TITI:*.TEXT; in	A3.L	^dossier  ajouter; out	-; mod	D7.WADDDCRIT:	PUSHM.L	D4,A2..A4	LOAD.L	A2,A3		; A2 <-- ^nom du dossier	LOAD.W	D4,#-120$:	INC.W	D4		; D4 <-- lg du nom de dossier  ajouter	TEST.B	(A3+)	JUMP,NE 20$	LOAD.L	A3,#(A6)+ODBCRI	CALL	SKIPREP		; A3 <-- ^rep(s): et A4 <-- ^nom	LOAD.L	A3,A430$:	TEST.B	(A3+)	JUMP,NE 30$40$:	COMP.L	A3,A4	JUMP',EQ 50$	DEC.L	A3	LOAD.B	(A3)+(D4.W),(A3) ; pousse le critre pour pouvoir insrer le dossier	JUMP	40$50$:	LOAD.B	(A4+),(A2+)	; insre le nom du dossier	DEC.W	D4	JUMP,NE 50$	POPM.L	D4,A2..A4	RET;--------\\; PUTCRIT >;--------/; Prpare le nom  rendre  l'utilisateur.; in	A3.L	^nom choisit;	A4.L	^buffer pour nom; out	-; mod	D7.WPUTCRIT:	PUSHM.L	A1..A4	LOAD.L	A1,A4		; A1 <-- ^buffer pour nom	LOAD.L	A2,A3	CALL	DBOXIFDIR	; est-on dans le dossier courant ?	JUMP',EQ 30$		; oui => 30$	LOAD.L	A3,#(A6)+ODBCRI	CALL	SKIPREP		; A3 <-- ^rep(s): et A4 <-- ^nom20$:	COMP.L	A3,A4	JUMP',EQ 30$	LOAD.B	(A1+),(A3+)	; buffer pour nom <-- rep(s):	JUMP	20$30$:	LOAD.B	(A1+),(A2+)	; buffer pour nom <-- nom	JUMP,NE	30$	POPM.L	A1..A4	RET;---------\\; IFVERROU >;---------/; Regarde combien de niveaux doivent tre verrouills.; in	(A6)+ODBCRI	critre; out	-; mod	D7.WIFVERROU:	PUSHM.L	D3,D4,A3,A4	FOS	?OPINFO		; A4 <-- ^contenu de SYS_INFO	LOAD.L	D3,(A4)+OINSTA	; D3 <-- informations pour START	CLR.W	D4		; D4 <-- pas de mise  jour	FOS	?CLINFO	TEST.L	D3:#BINFLRD	; START/D ?	JUMP,BC 90$		; non => 90$				; oui =>	TEST.W	(A6)+ODBVER	JUMP,NE 90$	LOAD.L	A3,#(A6)+ODBCRI	CLR.W	D4		; D4 <-- nb de ":"20$:	LOAD.B	D3,(A3+)	JUMP',EQ 30$	COMP.B	D3,#':	JUMP,NE 20$	INC.W	D4		; D4 <-- un ":" de plus	JUMP	20$30$:	LOAD.W	(A6)+ODBVER,D490$:	POPM.L	D3,D4,A3,A4	RET;---------\\; PREPCRIT >;---------/; Prpare le critre en fonction de l'ancien nom de fichier choisit.;	ODBPCR:     -->     .TEXT  ou  *.TEXT;	ODBPBN:     -->     #MM0:REP:;	ODBCRI:     <--      #MM0:REP:*.TEXT;;	ODBPCR:     -->     .TEXT  ou  *.TEXT;	ODBPBN:     -->     #MM0:REP:ESSAI.IMAGE;	ODBCRI:     <--      #MM0:REP:*.TEXT;;	ODBPCR:     -->     .TEXT  ou  *.TEXT;	ODBPBN:     -->     #MM0:REP:*.IMAGE;	ODBCRI:     <--      #MM0:REP:*.IMAGE; in	(A6)+ODBPCR.L	^critre;	(A6)+ODBPBN.L	^ancien nom; out	(A6)+ODBCRI	critre retenu; mod	D7.WPREPCRIT:	PUSHM.L	D3,D4,A1..A4	CLR.W	D4		; D4 <-- rien dans le critre	LOAD.L	A2,#(A6)+ODBCRI	LOAD.L	A1,(A6)+ODBPCR	LOAD.L	A3,(A6)+ODBPBN	CALL	SKIPREP		; A3 <-- ^rep(s): et A4 <-- ^nom10$:	COMP.L	A3,A4	JUMP',EQ 15$	LOAD.B	D3,(A3+)	CALL	MINMAJ	LOAD.B	(A2+),D3	; ODBCRI <-- rep(s):	LOAD.W	D4,#1		; D4 <-- rpertoire(s) dans le critre	JUMP	10$15$:	LOAD.B	D3,(A3+)	CALL	IFTERM	JUMP',EQ 50$	COMP.B	D3,#'*	JUMP',EQ 20$	COMP.B	D3,#'?	JUMP',EQ 20$	COMP.B	D3,#'[	JUMP,NE 15$20$:				; le nom est un critre =>	LOAD.B	D3,(A4+)	CALL	IFTERM	JUMP',EQ 50$	COMP.B	D3,#'.	JUMP',EQ 30$	CALL	MINMAJ	LOAD.B	(A2+),D3	; ODBCRI <-- nom	LOAD.W	D4,#2		; D4 <-- nom dans le critre	JUMP	20$30$:	CALL	MINMAJ	LOAD.B	(A2+),D3	; ODBCRI <-- extension	LOAD.W	D4,#3		; D4 <-- extension dans le critre	LOAD.B	D3,(A4+)	CALL	IFTERM	JUMP,NE 30$; Met le reste du critre, en fonction de D4 :;	D4 = 0     -->     critre ne contient rien;	D4 = 1     -->     critre contient dj "rep:";	D4 = 2     -->     critre contient dj "rep:nom";	D4 = 3     -->     critre contient dj "rep:nom.ext"50$:	COMP.W	D4,#3		; critre dj complet ?	JUMP',EQ 80$		; oui => 80$	TEST.W	D4		; qq chose dans le critre ?	JUMP',EQ 70$		; non => 70$	LOAD.L	A3,A1	CALL	SKIPREP		; A1 <-- ^aprs rep(s):	LOAD.L	A1,A4	COMP.W	D4,#1		; rpertoire(s) dans le critre ?	JUMP',EQ 70$		; oui => 70$60$:	LOAD.B	D3,(A4+)	CALL	IFTERM	JUMP',EQ 80$	COMP.B	D3,#'.	JUMP,NE 60$	DEC.L	A4	LOAD.L	A1,A4		; A1 <-- ^aprs l'extension70$:	LOAD.B	D3,(A1+)	CALL	IFTERM	JUMP',EQ 80$	CALL	MINMAJ	LOAD.B	(A2+),D3	; ODBCRI <-- critre	JUMP	70$80$:	CLR.B	(A2)		; ODBCRI <-- terminateur	LOAD.L	A3,#(A6)+ODBCRI	CALL	SKIPREP		; A4 <-- ^critre (aprs rep:)	COMP.B	(A4),#'.	; ".ext" sans "*" ?	JUMP',NE 90$		; non => 90$	LOAD.B	D3,#'*		; oui => pousse pour ajouter l'toile85$:	LOAD.B	D4,(A4)	LOAD.B	(A4+),D3	LOAD.B	D3,D4	CALL	IFTERM	JUMP,NE 85$	LOAD.B	(A4),D390$:	POPM.L	D3,D4,A1..A4	RET;--------\\; AFCASE  >;--------/; Affiche un nom de fichier dans une case.; in	D3.W	rang du fichier (0..n); out	A3.L	^nom;	D3.W	zro; mod	D3.L, D7.W, A3.LAFCASE:	PUSHM.L	D2,D4,A4,A5	LOAD.L	A3,(A6)+ODBPLI	LOAD.W	D4,D3	MUL.WU	D3,#LGARGS	ADD.L	A3,D3		; A3 <-- ^nom	CLR.W	D2		; D2 <-- pas de trait horizontal	INC.W	D4	COMP.W	D4,(A5)+OSLCYN	; dernire case ?	JUMP',HS 20$		; oui => 20$	TEST.B	(A3)+OBLATT+2:#BATTP-8 ; est-ce un dossier ?	JUMP',BS 20$		; oui => 20$	LOAD.W	D2,#3		; D2 <-- trace un gros trait horizontal	TEST.B	(A3)+LGARGS+OBLATT+2:#BATTP-8 ; suivant est un dossier ?	JUMP',BS 20$		; oui => 20$	CLR.W	D2		; D2 <-- pas de trait horizontal	COMP.W	(A6)+ODBNBD,#20	; au moins 20 cases pour des fichiers ?	JUMP',LO 20$		; non => 20$	LOAD.B	D3,(A3)	COMP.B	D3,(A3)+LGARGS	; changement de la premire lettre ?	JUMP',EQ 20$		; non => 20$	INC.W	D2		; D2 <-- trace un traitill horizontal20$:	LOAD.L	D4,(A6)+ODBFAN	; D4 <-- fanions	TEST.B	(A3)+OBLATT+2:#BATTP-8 ; est-ce un dossier ?	JUMP',BC 30$		; non => 30$	CLR.L	D4		; D4 <-- pas de longueur ni de date !30$:	LOAD.L	A4,#(A3)+LGNAME	; A4 <-- ^arguments	LOAD.L	A5,#(A6)+ODBDIS	; A5 <-- ^buffer	CALL	_LIST_PUTFILE	; affiche un nom de fichier	LOAD.L	A3,#(A6)+ODBDIS	; A3 <-- ^nom dans buffer	LOAD.W	D3,D2		; rend zro/un en sortie !	POPM.L	D2,D4,A4,A5	CLR.W	D7		; D7 <-- ok	RET;---------\\; MENUCRIT >;=========/; Demande dans un mmenu  quel niveau il faut remonter.; in	-; out	D7.W	erreur; mod	D7.WMENUCRIT:	PUSHM.L	D0..D6,A0..A5	LOAD.L	A5,#(A6)+ODBVSL	; A5 <-- ^variables	LOAD.W	D3,(A5)+OSLCYS	; D3 <-- case slectionne	SCROLL_	LINVCASE	; teint la case slectionne	LOAD.L	A3,#R16"FREE$	LOAD.W	D3,#2	LIB	?STRING		; y'a plus de modulos	LOAD.W	D2,#102!2^BDBGCLABEL	DBOX_	GETCO	LOAD.W	D2,(A0)+ODFCX	SR.W	D2,#1	SUB.W	D3,D2	INC.W	D3		; D3 <-- recule de CX/2-1 en X	ADD.W	D3,(A0)+ODFFX	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	DEC.W	D3		; D3 <-- recule de C1Y+C2Y+1 en Y	ADD.W	D3,(A0)+ODFFY	SWAP.W	D3	LOAD.L	D0,D3		; D0 <-- position coin sup/gauche; Demande de la mmoire pour le menu hirarchique.	LOAD.L	D4,#1000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour mmenu	JUMP,NE 95$	LOAD.L	A0,A4		; A0 <-- ^mmoire pour mmenu; Construit le menu principal avec les noms de dossiers depuis; le dernier jusqu'au premier.	LOAD.L	A1,A0	CLR.W	D1		; D1 <-- nb de cases du menu principal	LOAD.L	A3,#(A6)+ODBCRI	CALL	SKIPREP		; A4 <-- ^critre (aprs rep:)10$:	COMP.L	A4,A3	JUMP',EQ 16$	DEC.L	A412$:	COMP.L	A4,A3	JUMP',EQ 13$	COMP.B	(-A4),#':	; A4 <-- ^dossier prcdent	JUMP,NE 12$	INC.L	A413$:	LOAD.L	A2,A4	LOAD.B	(A1+),#SPACE14$:	LOAD.B	(A1+),(A2+)	; buffer <-- un nom de dossier	COMP.B	(A1)-1,#':	JUMP,NE 14$	LOAD.B	(A1+),#SPACE	CLR.B	(A1+)	INC.W	D1		; D1 <-- une case de plus	JUMP	10$16$:	LOAD.L	A2,A1		; A2 <-- ^case du sous-menu	LOAD.B	(A1+),#-2	ADD.L	A1,#2		; buffer <-- place pour ^relatif sous-menu	LOAD.L	A3,#R16"LAST$18$:	LOAD.B	(A1+),(A3+)	; buffer <-- dernire case	JUMP,NE 18$	CLR.B	(A1+)		; buffer <-- terminateur menu principal; Construit le sous-menu pour les units physiques.	LOAD.L	D3,A1	SUB.L	D3,A0		; D3 <-- ^relatif	LOAD.B	(A2)+2,D3	RR.W	D3,#8	LOAD.B	(A2)+1,D3	; buffer <-- ^relatif sous-menu	LOAD.L	A3,#R16"UNIT$	; A3 <-- ^nom "$"	CLR.L	D3		; D3 <-- mode	CALL	_LIST_SOPEN	; D6 <-- canal liste des units physiques	JUMP,NE 90$	PUSH.L	A1	CLR.W	D2		; D2 <-- nb de cases du sous-menu	CLR.L	D4		; D4 <-- cases inactives20$:	CALL	_LIST_NEXT	; A3/A4 <-- ^nom d'unit suivant	JUMP',NE 26$	CALL	MENUUSE		; unit actuellement utilise ?	JUMP',NE 22$		; non => 22$	TSET.L	D4:D2		; D4 <-- une case inactive22$:	LOAD.B	(A1+),#SPACE24$:	LOAD.B	(A1+),(A3+)	; buffer <-- un nom d'unit	JUMP,NE 24$	DEC.L	A1	LOAD.B	(A1+),#SPACE	CLR.B	(A1+)	INC.W	D2		; D2 <-- une case de plus	JUMP	20$26$:	CALL	_LIST_CLOSE	; ferme la liste	CLR.B	(A1+)		; buffer <-- terminateur sous-menu	POP.L	A1		; A1 <-- ^dbut du sous-menu	LOAD.L	A4,#(A6)+ODBDIS	LOAD.W	D3,#((LMM*2)/4)-128$:	CLR.L	(A4+)		; met tous les paramtres  zro	DECJ.W,NMO D3,28$	LOAD.L	A4,#(A6)+ODBDIS	; A4 <-- ^paramtres	LOAD.L	(A4)+(LMM*1)+OMMINA,D4	LOAD.L	D5,#2^0		; D5 <-- coin sup/gauche dans D2.L; Propose le mmenu, ventuellement sans le sous-menu des units physiques; s'il y a moins de deux units physiques.	LOAD.W	D7,#ERKSTO	; D7 <-- annule	TEST.W	D1		; au moins un dossier ?	JUMP,EQ 90$		; non => 90$	TEST.W	(A6)+ODBVER	JUMP',EQ 32$	LOAD.W	D3,D1	SUB.W	D3,(A6)+ODBVER	JUMP,LS 90$	INC.W	D3	LOAD.L	D4,#-1	SL.L	D4,D3	LOAD.L	(A4)+(LMM*0)+OMMINA,D432$:	COMP.W	D2,#2		; au moins deux units physiques ?	JUMP',HS 35$		; oui => 35$	COMP.W	D1,#1		; un seul dossier ?	JUMP,LS 90$		; oui => 90$	CLR.B	(A2)		; buffer <-- supprime le sous-menu35$:	LOAD.L	A3,A0		; A3 <-- ^mmenu principal avec/sans sous-menu	LOAD.L	D2,D0		; D2 <-- coin sup/gauche	LIB	?MMENUS		; choix selon mmenu ...	JUMP,NE 90$	LOAD.W	D7,#ERKSTO	; D7 <-- annule	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	JUMP,EQ 90$	COMP.W	D3,D1		; dans la case "units physiques" ?	JUMP',NE 50$		; non => 50$	LOAD.W	D3,(A4)+(LMM*1)+OMMSEL	JUMP'	60$; Annule un ou plusieurs dossiers dans le critre depuis la fin.50$:	LOAD.L	A3,#(A6)+ODBCRI	CALL	SKIPREP		; A4 <-- ^critre (aprs rep:)	LOAD.L	A2,A452$:	COMP.L	A4,A3	JUMP',EQ 90$	DEC.L	A454$:	COMP.L	A4,A3	JUMP',EQ 56$	COMP.B	(-A4),#':	; A4 <-- ^dossier prcdent	JUMP,NE 54$	INC.L	A456$:	DEC.W	D3	JUMP,NE 52$58$:	LOAD.B	(A4+),(A2+)	JUMP,NE 58$	JUMP	80$; Change d'unit physique.60$:	LOAD.L	A3,#(A6)+ODBCRI	CALL	SKIPREP		; A4 <-- ^critre (aprs rep:)	LOAD.L	A3,#(A6)+ODBDIS62$:	LOAD.B	(A3+),(A4+)	; ODBDIS <-- critre	JUMP,NE 62$64$:	DEC.W	D3	JUMP',NS 66$65$:	TEST.B	(A1+)	JUMP,NE 65$	JUMP	64$66$:	COMP.B	(A1+),#SPACE	JUMP,EQ 66$	DEC.L	A1	LOAD.L	A3,#(A6)+ODBCRI67$:	LOAD.B	D3,(A1+)	JUMP',EQ 68$	COMP.B	D3,#SPACE	JUMP',EQ 68$	COMP.B	D3,#'/	JUMP',EQ 68$	LOAD.B	(A3+),D3	; ODBCRI <-- unit physique	JUMP	67$68$:	LOAD.L	A4,#(A6)+ODBDIS69$:	LOAD.B	(A3+),(A4+)	; ODBCRI <-- critre	JUMP,NE 69$; Fin de la routine, sans oublier de rendre la mmoire.80$:	CLR.W	D7		; D7 <-- ok90$:	PUSH.W	D7	LOAD.L	A4,A0	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire pour mmenu	POP.W	D795$:	PUSH.W	D7	LOAD.L	A3,#R16"INIT$	LOAD.W	D3,#2	LIB	?STRING		; remet les modulos;	LOAD.L	A5,#(A6)+ODBVSL	; A5 <-- ^variables	LOAD.W	D3,(A5)+OSLCYS	; D3 <-- case slectionne	SCROLL_	LINVCASE	; rallume la case slectionne	POP.W	D7	POPM.L	D0..D6,A0..A5	TEST.W	D7		; retour EQ/NE	RETLAST$:	.B	-1	.ASCIZ	" units    "UNIT$:	.ASCIZ	"$"FREE$:	.B	MMODULO,1INIT$:	.B	MMODULO,0	.EVEN;--------\\; MENUUSE >;--------/; Regarde si une unit est utilise par le critre.; in	A3.L	^nom d'unit; out	D7.W	EQ => unit utilise;		NE => unit pas (encore) utilise; mod	D7.WMENUUSE:	PUSHM.L	D3,A3,A4	LOAD.W	D7,#1		; D7 <-- noms diffrents	LOAD.L	A4,#(A6)+ODBCRI10$:	LOAD.B	D3,(A3+)	COMP.B	D3,#':	JUMP',EQ 20$	COMP.B	D3,(A4+)	JUMP,EQ 10$	JUMP'	90$20$:	COMP.B	(A4),#':	JUMP',NE 90$	CLR.W	D7		; D7 <-- noms gaux90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXCRIT >;=========/; Demande  l'utilisateur les fichiers  lister.; in	-; out	D3.W	dernire touche (RETURN/END);	D7.W	erreur; mod	D3.L, D7.WDBOXCRIT:	PUSHM.L	D1,D2,D4,D5,A1..A5	LOAD.L	A2,#R16"TDBOXCRIT	LOAD.W	D2,(A6)+ODBOPM	; D2 <-- mode	LOAD.L	D3,(A6)+ODBOPP	; D3 <-- position	LOAD.L	D4,(A6)+ODBFAN	; D4 <-- fanions	DBOX_	OPEN		; D5 <-- canal	JUMP,NE 95$	LOAD.L	A3,#(A6)+ODBCRI	CALL	SKIPREP		; A4 <-- ^critre (aprs les dossiers)	LOAD.L	A3,#(A6)+ODBDIS10$:	LOAD.B	(A3+),(A4+)	; ODBDIS <-- critre	JUMP,NE 10$	LOAD.L	A3,#(A6)+ODBDIS	LOAD.L	A4,A320$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,A322$:	TEST.B	(A1+)	JUMP,NE	22$	CLR.B	(A1)-2		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEYCRIT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ 20$	COMP.W	D3,#CR		; (LISTE) ?	JUMP',EQ 80$		; oui => 80$	COMP.W	D3,#END		; (ANNULE) ?	JUMP',EQ 90$		; oui => 90$	COMP.W	D3,#UNDO	JUMP',EQ 50$	COMP.W	D3,#F7	JUMP',EQ 40$	COMP.W	D3,#F8	JUMP',EQ 42$30$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:	LOAD.L	A5,#R16"00$	JUMP'	45$42$:	LOAD.L	A5,#R16"01$45$:	LOAD.W	D3,#LGNAME	LIB	?INSERT		; insre */?	JUMP,NE 30$	JUMP	20$50$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	20$80$:				; LISTE =>	TEST.B	(A3)		; critre existe ?	JUMP,EQ 30$		; non => 30$	LOAD.L	(A6)+ODBFAN,D4	LOAD.L	A3,#(A6)+ODBCRI	CALL	SKIPREP		; A4 <-- ^critre (aprs les dossiers)	LOAD.L	A3,#(A6)+ODBDIS82$:	LOAD.B	D3,(A3+)	JUMP',EQ 84$	CALL	MINMAJ	LOAD.B	(A4+),D3	; ODBCRI <-- critre	JUMP	82$84$:	CLR.B	(A4)	LOAD.W	D3,#CR90$:				; ANNULE =>	PUSH.W	D7	DBOX_	CLOSE		; ferme la dbox	LOAD.L	A3,#R16"TDBOXMENU	LIB	?AFMENU		; refait les soft-keys	POP.W	D795$:	POPM.L	D1,D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET00$:	.ASCIZ	"*"01$:	.ASCIZ	"?"	.EVEN; Tables; ------TDBOXLIST:	.W	10$-TDBOXLIST	.W	TDBOXMENU-TDBOXLIST	.W	0,010$:	.B	ODBCR	.B	ODBTABX,2	.B	ODBLABEL,102	.B	ODBBOX,KEYDBOX/H'100,102,TDBOMBRE	.ASCIZ	"              "	.B	ODBLABEL,103	.B	ODBBOX,KEYDBOX/H'100,103,TDBOMBRE	.ASCIZ	"           "	.B	ODBCR	.B	ODBTABX,2+LGNAME+LGSUITE+4	.B	ODBSQUARE,BLISTAFF!2^7,KEYDBOX/H'100,BLISTAFF	.ASCIZ	" affiche"	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBLABEL,BLIVUOPT2	.B	ODBSQUARE,BLIVUOPT2!2^7,KEYDBOX/H'100,BLIVUOPT2	.ASCIZ	"        "	.B	ODBCR	.B	ODBTABX,2	.B	ODBLCIRCLE,BLISTALG!2^7,KEYDBOX/H'100,BLISTALG	.ASCIZ	" taille"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLCIRCLE,BLISTADC!2^7,KEYDBOX/H'100,BLISTADC	.ASCIZ	" date de cration"	.B	ODBTABX,2+LGNAME+LGSUITE+4	.B	ODBLABEL,BLIVUOPT1	.B	ODBSQUARE,BLIVUOPT1!2^7,KEYDBOX/H'100,BLIVUOPT1	.ASCIZ	"        "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBLABEL,BLIVUOPT3	.B	ODBSQUARE,BLIVUOPT3!2^7,KEYDBOX/H'100,BLIVUOPT3	.ASCIZ	"        "	.B	ODBCR	.B	ODBTABX,2	.B	ODBLABEL,101	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,2+LGNAME+LGSUITE+4	.B	ODBLABEL,104	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,2+LGNAME+LGSUITE+4+LGNAME+LGSUITE+5	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,2	.B	ODBLABEL,111	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	"       DOSSIER COURANT      "	.B	ODBTABX,2+LGNAME+LGSUITE+4	.B	ODBLABEL,110	.B	ODBBOX,0,CR,TDBMEV	;	"   CHOISIT   "	.ASCIZ	"             "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	ODBCR	.B	0TDBOXMENU:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Dossier courant"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"		;     ;     ;     ;	.EVENTKEYLIST:	.W	CR,F1,F2,F3,0		DOOK-TKEYLIST	.W	F7,F8,F9,0		DOKF7-TKEYLIST	.W	END,F13,F14,F15,0	DOAN-TKEYLIST	.W	KEYMGP,KEYMMP,KEYMDP,0	DOMP-TKEYLIST	.W	KEYMGR,KEYMMR,KEYMDR,0	DOMR-TKEYLIST	.W	0TDBOXCRIT:	.W	10$-TDBOXCRIT	.W	20$-TDBOXCRIT	.W	0,010$:	.B	ODBTEXT	.ASCIZ	" Fichiers  lister :"	.B	ODBCR,ODBCR	.B	ODBXFILE,33,LDBDIS-2,0,0,0,TDBNORM	.B	ODBCR,ODBCR	.B	ODBBOX,0,F7,TDBOMBRE	.ASCIZ	"   *   "	.B	ODBTEXT	.ASCIZ	"  remplace n'importe quoi"	.B	ODBCR,ODBCR	.B	ODBBOX,0,F8,TDBOMBRE	.ASCIZ	"   ?   "	.B	ODBTEXT	.ASCIZ	"  remplace un caractre"	.B	ODBCR,ODBCR	.B	ODBSQUARE,BLISTALL	.ASCIZ	" liste les fichiers cachs"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,CR,TDBMEV	.ASCIZ	" LISTE "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Liste"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"  *     ?"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"		;     ;     ;     ;	.EVENTKEYCRIT:	.W	CR,F1,F2,F3,0		DOOK-TKEYCRIT	.W	END,F13,F14,F15,0	DOAN-TKEYCRIT	.W	KEYMGP,KEYMMP,KEYMDP,0	DOMP-TKEYCRIT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOMR-TKEYCRIT	.W	0	.END