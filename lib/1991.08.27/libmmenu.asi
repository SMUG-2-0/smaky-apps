	.SBTTL	LIBMMENU; Gestion des m-menus; -------------------BMSPOSL	=	0		; donne la position sup/gauche dans D2.LBMSPOSR	=	1		; donne la position sup/droite dans D2.LBMSNEXT	=	2		; sous-menuBMSLEFT	=	3		; sous-menu va  gauche "<"MSTEMP	=	4		; sous-menu pas tout de suiteMSDEL	=	50/10		; dlai avant d'afficher le sous-menuMSCARR	=	4		; caractre triangle ">"MSCARL	=	5		; caractre triangle "<";	-------------------;	   M  M  E  N  U;	-------------------;;	Reprsentation des grandeurs horizontales d'un "mmenu";	avec son cadre. Les mmes grandeurs existent verticalement,;	avec une marge suprieure invisible pour modulo 2.;;	. = vide autour du cadre;	o = cadre double;	! = marge invisible pour modulo 8;	l = sparations entre les colonnes;	t = texte dans les cases;;	NCX = 3;	            largeur swdo (modulo 8);	<---------------------------------------------->;	. . . . . . . . . . . . . . . . . . . . . . . .;	. . . . . . . . . . . . . . . . . . . . . . . .;	. . o o o o o o o o o o o o o o o o o o o o . .;	. . o o o o o o o o o o o o o o o o o o o o . .;	. . o o   !         l         l         o o . .;	. . o o   !         l         l         o o . .;	. . o o   !         l         l         o o . .;	. . o o   !   t t   l   t t   l   t t   o o . .;	. . o o   !         l         l         o o . .;	<------><--><--------><--------><--------><---->;	   4    AJX    LGX       LGX       LGX      3;	       (0..7);	etc.;	. . o o   !         l         l         o o . .;	. . o o   !         l         l         o o . .;	. . o o o o o o o o o o o o o o o o o o o o . .;	. . o o o o o o o o o o o o o o o o o o o o . .;	. . . . . . . . . . . . . . . . . . . . . . . .;	. . . . . . . . . . . . . . . . . . . . . . . .;--------\\; _MMENUS >;========/; Choix dans un m-menu hirarchique avec la souris.; L'exemple ci-dessous montre une table pointe par A3.L :;; MENU:;	.ASCIZ	" ";	.B	-1;	.ASCIZ	" dtruit ";	.ASCIZ	" dplace ";	.ASCIZ	" duplique ";	.B	-1;	.BW	-2,MENU11$-MENU;	.ASCIZ	" opration "		; > suite en MENU11$;	.BW	-2,MENU12$-MENU;	.ASCIZ	" divers "		; > suite en MENU12$;	.B	0;; MENU11$:;	.ASCIZ	" tourne ";	.ASCIZ	" zoom ";	.ASCIZ	" dforme ";	.B	0;; MENU12$:;	.ASCIZ	" contour ";	.ASCIZ	" trame ";	.BW	-2,MENU21$-MENU12$;	.ASCIZ	" lisse "		; > suite en MENU21$;	.B	0;; MENU21$:;	.ASCIZ	" fin ";	.ASCIZ	" moyen ";	.ASCIZ	" grossier ";	.B	0;; REMARQUES:;	- Dans le  .BW -2,ad  l'adresse peut tre impaire !;	- C'est LIB,?MMENUS qui affiche les triangles ">"  droite,;	  dans les cases o cela est ncessaire.;; L'exemple ci-dessous montre les paramtres points par A4.L :;; OPARAM: .BLKB	LMM*4			; *4 car il y a 1 menu et 3 sous-menus;; in	A3.L	^m-menus hirarchiques;	A4.L	^table pour les paramtres (in+out);	D5.L	flags (BMSxxx);	D2.L	coin sup/gauche (si D5:#BMSPOSx=1); out	D7.W	erreur; mod	D7.W_MMENUS:	PUSHM.L	D5,A5	LOAD.L	(A6)+OMGPMN,A3	; OMGPMN <-- ^mmenu	LOAD.L	(A6)+OMGPPA,A4	; OMGPPA <-- ^table des paramtres	SET.B	(A6)+OMGINI	; initialisation	LOAD.L	A5,#0		; A5 <-- y'a pas d'pre !	CALL	MMENU		; attend selon choix ...	POPM.L	D5,A5	RET;--------\; _MMENU  >;========/; Choix dans un m-menu avec la souris jusqu' ce que; l'tat des boutons change.; in	A3.L	^textes .ASCIZ termins par zro;	D3.W	choix par dfaut;	D4.L	bitmap des cases inactives (si D3:#15=1); out	D3.W	choix effectu (0..n);	D7.W	erreur; mod	D3.L, D7.W_MMENU:	PUSHM.L	D5,A4,A5	LOAD.L	A4,#(A6)+OMGVPA	; A4 <-- ^paramtres	CLR.L	(A4)+OMMINA	TCLR.L	D3:#15	JUMP',BC 10$	LOAD.L	(A4)+OMMINA,D4	; OMMINA <-- cases inactives10$:	LOAD.W	(A4)+OMMSEL,D3	; OMMSEL <-- case par dfaut	LOAD.L	(A6)+OMGPMN,A3	; OMGPMN <-- ^mmenu	LOAD.L	(A6)+OMGPPA,A4	; OMGPPA <-- ^table des paramtres	CLR.B	(A6)+OMGINI	; pas d'initialisation	CLR.L	D5		; D5 <-- flags	LOAD.L	A5,D5		; A5 <-- y'a pas d'pre !	CALL	MMENU		; attend selon choix ...	LOAD.W	D3,(A4)+OMMSEL	; D3 <-- case slectionne	POPM.L	D5,A4,A5	RET;--------\; MMENU   >;========/; Choix dans un m-menu avec la souris jusqu' ce que; l'tat des boutons change.; in	A3.L		^m-menu;	D2.L		coin sup/gauche (si D5:#BMSPOSx=1);	D5.L		flags (BMSxxx);	A5.L		^variables du pre;	(A6)+OMGPMN.L	^m-menu principal;	(A6)+OMGPPA.L	^table des paramtres; out	D3.W		choix effectu (0..n);	D7.W		erreur; mod	D3.L, D7.WMMENU:	PUSHM.L	D0..D6,A0,A3..A5	LOAD.L	D4,#LGMVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables locales	JUMP,NE 95$	LOAD.L	(A4)+OMSPVP,A5	; OMSPVP <-- ^variables du pre	LOAD.L	A5,A4		; A5 <-- ^variables locales	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.L	(A5)+OMSORY,D2	; OMSORY <-- coin sup/gauche	LOAD.L	(A5)+OMSFLG,D5	; OMSFLG <-- flags	CALL	MSSRCRANG	; OMSRAN <-- rang pour les paramtres	LOAD.L	A4,(A6)+OMGPPA	LOAD.W	D4,(A5)+OMSRAN	MUL.WU	D4,#LMM	ADD.L	A4,D4		; A4 <-- ^paramtres (OMMxxx)	LOAD.L	(A5)+OMSMAG,(A4)+OMMINA ; OMSMAG <-- cases inactives	LOAD.W	D6,(A4)+OMMSEL	; D6 <-- case par dfaut	CALL	_IFMOUSE	; D4 <-- coordonne souris	TEST.W	D7	JUMP,NE	90$	LOAD.B	D1,D3		; D1 <-- boutons initiaux	CALL	OPEBMM		; cre s-wdo pour menu	TEST.W	D7	JUMP,NE	90$	TEST.B	(A6)+OMGINI	; initialisation ?	JUMP',F 08$		; non => 08$	LOAD.W	D3,D6	CALL	PSMBMM		; A4 <-- ^sous-menu	JUMP',NE 07$	LOAD.L	D2,(A5)+OMSMAG	TEST.L	D2:D3		; case inactive ?	JUMP',BS 07$		; oui => 07$	CALL	MSINVB		; "allume" case ..	JUMP	33$		; .. puis ouvre tout de suite le sous-menu !07$:	CLR.B	(A6)+OMGINI	; fin de l'initialisation08$:	CALL	_IFMOUSE	; D4 <-- coordonne souris	LOAD.W	D2,#-2		; D2 <-- pas d'ancienne case	LOAD.L	D0,D4		; D0 <-- sous-menu pas tout de suite10$:	CALL	DETBMM		; D3 <-- case 0..n	COMP.W	D3,#-1	JUMP',EQ 15$	TEST.B	(A5)+OMSFLG+3:#BMSNEXT ; est-on dans un sous-menu ?	JUMP',BC 15$		; non => 15$	COMP.W	D2,#-2	JUMP',EQ 15$	TEST.L	D3:#14		; trop  gauche (dans sous-menu du pre) ?	JUMP',BC 15$		; non => 15$	LOAD.L	A4,(A5)+OMSPVP	; A4 <-- ^variables pre	COMP.W	D3,(A4)+OMSCAP	; est-on dans la case pre ?	JUMP',EQ 15$		; oui => 15$				; non =>	LOAD.W	D2,#-1	JUMP	70$15$:	COMP.W	D3,D2		; mme case ?	JUMP',EQ 30$		; oui => 30$20$:	EX.L	D2,D3		; D2 <-- old, D3 <-- new	CALL	MSINVB		; "teint" ancienne case	LOAD.W	D3,D2		; D3 <-- new	CALL	MSINVB		; "allume" nouvelle case	LOAD.L	D0,D4		; D0 <-- sous-menu pas tout de suite30$:	LOAD.W	D5,D0	SUB.W	D5,D4	JUMP',NC 32$	NEG.W	D5		; D5 <-- |dx|32$:	COMP.W	D5,#MSTEMP	; assez attendu pour sous-menu ?	JUMP,LO 40$		; non => 40$	CALL	PSMBMM		; A4 <-- ^sous-menu	JUMP,NE 40$33$:	PUSHM.L	D3,A3	TSET.L	D3:#14	LOAD.W	(A5)+OMSCAP,D3	; OMSCAP <-- case pre	LOAD.L	A3,A4		; A3 <-- ^sous-menu	CLR.W	D3	LOAD.L	D5,#2^BMSNEXT!2^BMSPOSR	TEST.B	(A5)+OMSFLG+3:#BMSLEFT ; sous-menu vers la gauche ?	JUMP',BS 34$		; oui => 34$	LOAD.W	D5,#2^BMSNEXT!2^BMSPOSL34$:	LOAD.L	D2,(A5)+OMSPSM	; D2 <-- position coin sup/gauche	CALL	MMENU		; paf, hop et tralala (rcursif ...)	POPM.L	D3,A3	COMP.W	D7,#ERKSTO	JUMP,NE 80$	LOAD.W	D2,D3		; D2 <-- no case "allume"	CALL	_IFMOUSE	; D4 <-- coordonne souris	LOAD.L	D0,D4		; D0 <-- sous-menu pas tout de suite	LOAD.B	D1,D3		; D1 <-- nouveaux boutons initiaux	JUMP	10$40$:	LOAD.W	D2,D3		; D2 <-- no case "allume"	CALL	MSRDMOUSE	; D3 <-- boutons, D4 <-- position	JUMP',EQ 45$	LOAD.L	D0,D4	ADD.W	D0,#100		; D0 <-- sous-menu tout de suite	JUMP	10$45$:	COMP.B	D3,D1		; boutons changs ?	JUMP,EQ	10$		; non => 10$	TEST.B	(A5)+OMSFLG+3:#BMSNEXT ; est-on dans un sous-menu ?	JUMP',BC 70$		; non => 70$	TEST.W	D2	JUMP',NS 62$	TEST.L	D2:#14	JUMP',BC 70$62$:	LOAD.B	D1,D3		; D1 <-- nouveaux boutons initiaux	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; fait un p'tit bruit	JUMP	10$		; puis refuse de sortir !70$:	CLR.W	D7		; D7 <-- ok	LOAD.W	D3,D2		; case 0..n "allume" ?	JUMP',NC 80$		; oui => 80$	LOAD.W	D7,#ERKSTO	; non => erreur	CLR.W	D3		; D3 <-- case vide tout en haut !80$:	LOAD.L	A4,(A6)+OMGPPA	LOAD.W	D4,(A5)+OMSRAN	MUL.WU	D4,#LMM	ADD.L	A4,D4		; A4 <-- ^paramtres (OMMxxx)	LOAD.W	(A4)+OMMSEL,D3	; OMMSEL <-- case slectionne	CALL	CLOBMM		; restitue s-wdo90$:	PUSH.W	D7	LOAD.L	A4,A5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire pour variables locales	POP.W	D795$:	POPM.L	D0..D6,A0,A3..A5	RET;----------\\; MSRDMOUSE >;----------/; Lit la souris, avec un timeout.; in	-; out	D3.B	boutons;	D4.L	position;	D7.W	erreur (timeout); mod	D3.L, D4.L, D7.WMSRDMOUSE:	LOAD.W	D4,#MSDEL	NTREL	?SETTIM		; met un petit timeout 	TEST.B	(A6)+OFLAGS:#BKEYMO ; souris par le clavier ?	JUMP',BS 40$		; oui => 40$	CALL	_RDMOUSE	; attend sur la souris	TEST.W	D7	JUMP',NE 50$	PUSHM.L	D4,D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POPM.L	D4,D7	JUMP'	90$40$:	CALL	_GETKEY		; attend sur la souris50$:	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	CALL	_IFMOUSE	; D3 <-- boutons, D4 <-- position	POP.W	D790$:	TEST.W	D7		; retour EQ/NE	RET;--------\; OPEBMM  >;--------/; Cre la sous-fentre pour un m-menu.; in	A3.L	^textes .ASCIZ termins par zro;	D4.L	coordonne y;x o crer le m-menu;	D6.W	case par dfaut; out	D7.W	erreur; mod	D7.WOPEBMM:	PUSHM.L	D0..D6	CALL	OPCBMM		; effectue quelques calculs; Cre la sous-fentre temporaire.	LOAD.L	D0,D4	LOAD.W	D4,(A5)+OMSLGY	MUL.WU	D4,(A5)+OMSNCY	ADD.W	D4,#4+3	LOAD.W	D2,D4	TEST.B	(A0)+ODFFL2:#BFNOMOD	JUMP',BS 10$	INC.W	D4	AND.B	D4,#B'11111110	; D4 <-- arrondi au multiple de 2 sup.10$:	SUB.W	D2,D4	NEG.W	D2		; D2 <-- ajustage en Y	LOAD.W	(A5)+OMSAJY,D2	SWAP.W	D4	LOAD.W	D3,(A5)+OMSLGX	MUL.WU	D3,(A5)+OMSNCX	ADD.W	D3,#4+3	LOAD.W	D2,D3	TEST.B	(A0)+ODFFL2:#BFNOMOD	JUMP',BS 12$	ADD.W	D3,#8-1	AND.B	D3,#B'11111000	; D3 <-- arrondi au multiple de 8 sup.12$:	LOAD.W	D4,D3	SUB.W	D2,D4	NEG.W	D2		; D2 <-- ajustage en X	LOAD.W	(A5)+OMSAJX,D2	LOAD.L	D3,D0		; D3 <-- origine sous-fentre	LOAD.W	D7,#ERDIOUT	TEST.B	(A5)+OMSFLG+3:#BMSPOSL	JUMP,BS 40$	TEST.B	(A5)+OMSFLG+3:#BMSPOSR	JUMP,BS 40$; Calcule la position du coin sup/gauche du m-menu.	AND.L	D6,#H'FFFF	DIV.WU	D6,(A5)+OMSNCY	; D6 <-- position (y;x)	SWAP.W	D6		; D6 <-- position (x;y)	CLR.L	D5		; D5 <-- pas encore de correction	SWAP.W	D3	SWAP.W	D4	COMP.W	D4,(A0)+ODFDY	; fentre trop haute ?	JUMP,HS	90$		; oui => 90$	LOAD.W	D2,(A5)+OMSLGY	; D2 <-- hauteur d'une case	LOAD.W	D1,D2	SR.W	D2,#1		; D2 <-- 1/2 largeur	MUL.WU	D1,D6	ADD.W	D2,D1	SUB.W	D3,D2		; D3 <-- remonte origine Y	JUMP',NC 32$		; dpasse pas haut => 32$	LOAD.W	D5,D3		; D5 <-- descend un peu la souris	CLR.W	D3		; D3 <-- colle en haut32$:	LOAD.W	D2,D3	ADD.W	D2,D4		; D2 <-- extrmit infrieure	SUB.W	D2,(A0)+ODFDY	; dpasse en bas ?	JUMP',LO 34$		; non => 34$	LOAD.W	D3,D2	LOAD.W	D5,D3		; D5 <-- monte un peu la souris	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,D4		; D3 <-- maximum possible34$:	TEST.B	(A0)+ODFFL2:#BFNOMOD	JUMP',BS 35$	AND.B	D3,#B'11111110	; alligne sur un word35$:	LOAD.W	(A5)+OMSORY,D3	; mm. origine Y	SWAP.W	D4	SWAP.W	D3	SWAP.W	D5	SWAP.W	D6		; D6 <-- position (y;x)	COMP.W	D4,(A0)+ODFDX	; fentre trop large ?	JUMP,HS	90$		; oui => 90$	LOAD.W	D2,(A5)+OMSLGX	; D2 <-- largeur d'une case	LOAD.W	D1,D2	SR.W	D2,#1		; D2 <-- 1/2 largeur	MUL.WU	D1,D6	ADD.W	D2,D1	SUB.W	D3,D2		; D3 <--  gauche origine X	JUMP',NC 36$		; dpasse pas  gauche => 36$	LOAD.W	D5,D3		; D5 <-- pousse un peu la souris  droite	CLR.W	D3		; D3 <-- colle  gauche36$:	LOAD.W	D2,D3	ADD.W	D2,D4		; D2 <-- extrmit droite	SUB.W	D2,(A0)+ODFDX	; dpasse  droite ?	JUMP',LO 38$		; non => 38$	LOAD.W	D3,D2	LOAD.W	D5,D3		; D5 <-- pousse un peu la souris  gauche	LOAD.W	D3,(A0)+ODFDX	; oui =>	SUB.W	D3,D4		; D3 <-- maximum possible38$:	TEST.B	(A0)+ODFFL2:#BFNOMOD	JUMP',BS 39$	AND.B	D3,#B'11111000	; aligne sur un byte39$:	LOAD.W	(A5)+OMSORX,D3	; mm. origine X	CALL	MPOBMM		; corrige la position de la souris	JUMP	50$; Regarde si la position sup/gauche du m-menu est possible.40$:	LOAD.L	D3,(A5)+OMSORY	TEST.B	(A5)+OMSFLG+3:#BMSPOSR	JUMP',BC 42$	SUB.W	D3,D4	JUMP',NC 42$	CLR.W	D342$:	TEST.B	(A0)+ODFFL2:#BFNOMOD	JUMP',BS 43$	AND.B	D3,#B'11111000	; aligne sur un byte43$:	LOAD.W	D2,(A0)+ODFDX	SUB.W	D2,D4	JUMP,LO 90$	COMP.W	D3,D2		; dpasse  droite ?	JUMP',LS 44$		; non => 44$	LOAD.W	D3,D244$:	SWAP.W	D3	SWAP.W	D4	TEST.B	(A0)+ODFFL2:#BFNOMOD	JUMP',BS 45$	AND.B	D3,#B'11111110	; alligne sur un word45$:	LOAD.W	D2,(A0)+ODFDY	SUB.W	D2,D4	JUMP,LO 90$	COMP.W	D3,D2		; dpasse en bas ?	JUMP',LS 46$		; non => 46$	LOAD.W	D3,D246$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A5)+OMSORY,D3	TEST.B	(A6)+OMGINI	; initialisation ?	JUMP',F 50$		; non => 50$				; oui =>	PUSHM.L	D3,D4	LOAD.L	D2,D3	LOAD.W	D3,D6	CALL	MSPOSB		; D3/D4 <-- position/dimensions	SR.W	D4,#1	ADD.W	D4,D3	ADD.W	D4,D2	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D4,D3	ADD.W	D4,D2	SWAP.W	D4	CALL	_PMOUSE		; positionne la souris	POPM.L	D3,D4; Regarde si le sous-menu doit aller vers la gauche.50$:	PUSHM.L	D3,D4	ADD.W	D3,D4	SUB.W	D3,(A0)+ODFDX	NEG.W	D3		; D3 <-- place libre  droite	COMP.W	D3,(A5)+OMSLGX	; reste pour une case entire ?	JUMP',HS 60$		; oui => 60$				; non =>	TSET.B	(A5)+OMSFLG+3:#BMSLEFT ; indique sous-menu vers la gauche; Cre la sous fentre (s-wdo) selon D3/D4.60$:	CALL	_GETWDO	POPM.L	D3,D4	LOAD.W	(A5)+OMSWDO,D5	; OMSWDO <-- no s-wdo actuelle	CALL	_CREWDO		; cre sous-fentre	TEST.W	D7	JUMP',NE 90$	CALL	_USEWDO		; utilise sous-fentre cre	TEST.W	D7	JUMP',NE 90$	LOAD.B	(A5)+OMSSVM,(A0)+ODFMOD	CALL	_COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_MMSET	CALL	_COLORSR	; donne la couleur de dessin	LOAD.L	D3,#COLOR_MMCLEAR	CALL	_COLORCR	; donne la couleur de fond	CALL	_AFTIM	.B	NOCURS		; pas de curseur	.B	SAVWDO		; sauve contenu actuel	.B	0	.EVEN	TEST.W	D7		; sauvetage ok ?	JUMP',NS 80$		; non => 80$	LOAD.B	D3,#EOP	CALL	_AFCAR		; efface tout	CALL	MSCADRE		; trace tous les cadres	CALL	OPTBMM		; affiche tous les textes	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	CALL	CLOBMM		; libre sous-fentre si erreur90$:	POPM.L	D0..D6	RET;--------\\; OPCBMM  >;--------/; Effectue quelques calculs.; in	A3.L		^textes .ASCIZ termins par zro;	D6.W		case par dfaut; out	D6.W		case par dfaut;	(A5)+OMSLGX.W	largeur d'une case;	(A5)+OMSLGY.W	hauteur d'une case;	(A5)+OMSL1X.W	largeur de la rfrence gauche;	(A5)+OMSL1Y.W	hauteur dessus ligne de base;	(A5)+OMSNBC.W	nombre total de cases;	(A5)+OMSNCX.W	nb de colonnes;	(A5)+OMSNCY.W	nb de cases par colonne; mod	D6.L, D7.WOPCBMM:	PUSHM.L	D0..D5,A1,A3; Cherche la largeur et la hauteur de la ligne la plus grande,; en tenant compte de caractres  chasses variables et de; changements de gencars.	CLR.W	D1		; D1 <-- largeur la plus grande	CLR.W	D2		; D2 <-- h1 la plus grande	CLR.W	D5		; D5 <-- h2 la plus grande	CLR.W	D4		; D4 <-- nb de .ASCIZ	LOAD.L	A1,(A0)+ODFPGC	; A1 <-- ^dbut GENCAR	ADD.L	A1,#OGCWID	; A1 <-- ^table des largeurs20$:	TEST.B	(A3)		; fin ?	JUMP,EQ 50$		; oui => 50$	CLR.W	D0		; D0 <-- largeur d'un .ASCIZ	INC.W	D4		; D4 <-- un .ASCIZ de plus30$:	CLR.W	D3	LOAD.B	D3,(A3+)	; D3 <-- un caractre	JUMP,EQ 48$	COMP.B	D3,#-1		; ligne horizontale ?	JUMP,EQ	30$		; oui => 30$	COMP.B	D3,#-2		; sous-menu ?	JUMP',EQ 36$		; oui => 36$	COMP.B	D3,#USEGC	; changement de gencar ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#TYPOAX	; positionnement absolu en X ?	JUMP,EQ 42$		; oui => 42$	COMP.B	D3,#COLORSA	; changement de couleur ?	JUMP,EQ 44$		; oui => 44$	COMP.B	D3,#COLORSR	; changement de couleur ?	JUMP,EQ 45$		; oui => 45$	TEST.L	D3:#7		; caractre de commande (AFINV, AFGREY, etc.) ?	JUMP,BS 30$		; oui => 30$;	CLR.W	D3	LOAD.B	D3,(A1)+(D3.W)	; D3 <-- largeur du caractre	ADD.W	D0,D3		; D0 <-- ajoute largeur	COMP.W	D2,(A0)+ODFC1Y	JUMP',GE 34$	LOAD.W	D2,(A0)+ODFC1Y34$:	COMP.W	D5,(A0)+ODFC2Y	JUMP,GE 30$	LOAD.W	D5,(A0)+ODFC2Y	JUMP	30$36$:				; sous-menu =>;	CLR.W	D3	LOAD.B	D3,(A1)+SPACE	; D3 <-- largeur d'un espace	ADD.W	D0,D3		; D0 <-- ajoute largeur	LOAD.B	D3,(A1)+4	; D3 <-- largeur du triangle ">"	ADD.W	D0,D3		; D0 <-- ajoute largeur	ADD.L	A3,#2		; A3 <-- saute <<^sous-menu>>	JUMP	30$40$:				; <USEGC> =>	DEC.L	A3		; A3 <-- ^<usegc> <f> <s/c> <t>	LOAD.W	D3,#4		; D3 <-- lg	CALL	_STRING		; utilise le nouveau gencar	ADD.L	A3,#4		; A3 <-- saute <usegc> <f> <s/c> <t>	LOAD.L	A1,(A0)+ODFPGC	; A1 <-- ^dbut GENCAR	ADD.L	A1,#OGCWID	; A1 <-- ^table des largeurs	JUMP	30$42$:				; <TYPOAX> =>	LOAD.B	D0,(A3+)	SL.W	D0,#8	LOAD.B	D0,(A3+)	; D0 <-- position absolue en X	JUMP	30$44$:				; <COLORSA> =>	ADD.L	A3,#6		; A3 <-- saute <rr> <gg> <bb>	JUMP	30$45$:				; <COLORSR> =>	ADD.L	A3,#4		; A3 <-- saute <cccc>	JUMP	30$48$:	COMP.W	D0,D1		; plus large que le prcdent ?	JUMP,LO	20$		; non => 20$	LOAD.W	D1,D0		; D1 <-- la plus grande largeur	JUMP	20$50$:	ADD.W	D1,#2+2+1	; D1 <-- p'tites marges	LOAD.W	(A5)+OMSLGX,D1	LOAD.W	(A5)+OMSL1Y,D2	ADD.W	D2,D5		; D2 <-- hauteur d'un car.	ADD.W	D2,#1+1+1	; D2 <-- p'tite marges	LOAD.W	(A5)+OMSLGY,D2	LOAD.W	(A5)+OMSL1X,(A0)+ODFC1X	LOAD.W	(A5)+OMSNBC,D4	COMP.W	D6,D4		; case par dfaut existe ?	JUMP',LO 53$		; oui => 53$	CLR.W	D6		; non => prend la premire !53$:; Vrifie s'il faut mettre plusieurs colonnes.	CLR.L	D4	LOAD.W	D4,(A0)+ODFDY	DIV.WU	D4,(A5)+OMSLGY	; D4 <-- nb max de cases en hauteur	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- reste	COMP.W	D3,#4+3		; reste assez ?	JUMP',HS 54$		; oui => 54$	DEC.W	D4		; non => une case de moins !54$:	CLR.W	D2		; D2 <-- nb de colonnes55$:	INC.W	D2		; D2 <-- une colonne de plus	CLR.L	D3	LOAD.W	D3,(A5)+OMSNBC	; D3 <-- nb de case	DIV.WU	D3,D2	SWAP.W	D3	TEST.W	D3		; reste qq chose ?	JUMP',EQ 57$		; non => 57$	ADD.L	D3,#H'10000	; oui => arrondi  l'unit suprieure57$:	SWAP.W	D3	COMP.W	D3,D4		; y a-t-il la place en hauteur ?	JUMP,HI 55$		; non => 55$				; oui =>	LOAD.W	(A5)+OMSNCX,D2	LOAD.W	(A5)+OMSNCY,D3	POPM.L	D0..D5,A1,A3	RET;--------\\; OPTBMM  >;--------/; Affiche tous les textes dans les cases.; in	A3.L	^textes .ASCIZ termins par zro; out	-; mod	D7.WOPTBMM:	PUSHM.L	D0..D5,A2,A3	CLR.W	D0		; D0 <-- case en X	CLR.W	D1		; D1 <-- case en Y	CLR.W	D5		; D5 <-- no case	LOAD.W	D3,#4+1	ADD.W	D3,(A5)+OMSL1Y	ADD.W	D3,(A5)+OMSAJY	SWAP.W	D3	LOAD.W	D3,#4+2		; D3 <-- coordonne initiale	ADD.W	D3,(A0)+ODFC1X	ADD.W	D3,(A5)+OMSAJX20$:	TCLR.L	D5:#16		; D5 <-- pas de sous-menu21$:	LOAD.B	D2,(A3)		; encore un .ASCIZ ?	JUMP,EQ 80$		; non => 80$	COMP.B	D2,#-1		; ligne horizontale ?	JUMP',NE 23$		; non => 23$				; oui =>	INC.L	A3	CALL	MSLIGNE		; trace la ligne	JUMP	21$23$:	COMP.B	D2,#-2		; sous-menu ?	JUMP',NE 24$		; non => 24$	ADD.L	A3,#1+2		; A3 <-- saute <<^sous-menu>>	TSET.L	D5:#16		; D5 <-- y'a un sous-menu	JUMP	21$24$:	CALL	_SETCURS	; positionne curseur typo	PUSH.L	D3	LOAD.L	A2,#(A6)+OBUFFER	LOAD.B	(A2+),#AFTOUT	; buffer <-- affiche tous les codes	COMP.W	D5,#32	JUMP',HS 30$	LOAD.L	D3,(A5)+OMSMAG	TEST.L	D3:D5		; case inactive ?	JUMP',BC 30$		; non => 30$	LOAD.B	(A2+),#AFGREY	; buffer <-- affiche la ligne en gris30$:	LOAD.B	D3,(A3+)	JUMP',EQ 35$	LOAD.B	(A2+),D3	; buffer <-- un caractre	COMP.B	D3,#USEGC	JUMP',EQ TROIS$	COMP.B	D3,#COLORSA	JUMP',EQ SIX$	COMP.B	D3,#COLORSR	JUMP',EQ QUATRE$	COMP.B	D3,#TYPOAX	JUMP,NE 30$				; TYPOAX =>	LOAD.B	D3,(A3+)	SL.W	D3,#8	LOAD.B	D3,(A3+)	; D3 <-- <xx> aprs <typoax>	LOAD.W	D4,D0	MUL.WU	D4,(A5)+OMSLGX	; D4 <-- offset dbut colonne en X	ADD.W	D4,(A5)+OMSAJX	ADD.W	D3,D4		; D3 <-- <xx> dans la bonne colonne	RR.W	D3,#8	LOAD.B	(A2+),D3	RR.W	D3,#8	LOAD.B	(A2+),D3	; buffer <-- <xx> + correction	JUMP	30$SIX$:	LOAD.B	(A2+),(A3+)	; buffer <-- data	LOAD.B	(A2+),(A3+)	; buffer <-- dataQUATRE$:LOAD.B	(A2+),(A3+)	; buffer <-- dataTROIS$:	LOAD.B	(A2+),(A3+)	; buffer <-- data	LOAD.B	(A2+),(A3+)	; buffer <-- data	LOAD.B	(A2+),(A3+)	; buffer <-- data	JUMP	30$35$:	TEST.L	D5:#16		; y'a-t-il un sous-menu ?	JUMP',BC 38$		; non => 38$				; oui =>	LOAD.B	D2,#MSCARL	; D2 <-- triangle "<"	LOAD.W	D3,#5		; D3 <--  gauche	TEST.B	(A5)+OMSFLG+3:#BMSLEFT ; sous-menu vers la gauche ?	JUMP',BS 36$		; oui => 36$	LOAD.B	D2,#MSCARR	; D2 <-- triangle ">"	LOAD.W	D3,(A5)+OMSLGX	SUB.W	D3,(A0)+ODFCX	ADD.W	D3,(A5)+OMSAJX	ADD.W	D3,#2		; D3 <--  droite36$:	ADD.W	D3,(A0)+ODFC1X	LOAD.W	D4,D0	MUL.WU	D4,(A5)+OMSLGX	; D4 <-- offset dbut colonne en X	ADD.W	D3,D4		; D3 <-- <xx> dans la bonne colonne	LOAD.B	(A2+),#TYPOAX	RR.W	D3,#8	LOAD.B	(A2+),D3	RR.W	D3,#8	LOAD.B	(A2+),D3	; buffer <-- <xx> + correction	LOAD.B	(A2+),D2	; buffer <-- code pour triangle ">" ou "<"38$:	LOAD.B	(A2+),#AFNORM	; buffer <-- remet le mode normal	LOAD.B	(A2+),#AFFULL	; buffer <-- remet le mode plein	LOAD.L	D3,A2	TEST.L	D3:#0	JUMP',BS 40$	CLR.B	(A2+)		; A2 doit tre impair !40$:	LOAD.B	(A2+),#COLORSR	; buffer <-- remet la couleur de dessin	LOAD.L	(A2+),#COLOR_MMSET	EX.L	A2,A3	LOAD.L	D3,A3		; D3 <-- ^fin du buffer	LOAD.L	A3,#(A6)+OBUFFER; A3 <-- ^dbut du buffer	SUB.L	D3,A3		; D3 <-- lg dans buffer	CALL	_STRING		; affiche un .ASCIZ	LOAD.L	A3,A2	POP.L	D3	INC.W	D5		; D5 <-- no case suivante	SWAP.W	D3	ADD.W	D3,(A5)+OMSLGY	; D3 <-- descend  la case en dessous	SWAP.W	D3	INC.W	D1		; D1 <-- case en Y suivante	COMP.W	D1,(A5)+OMSNCY	; est-on en bas de la colonne ?	JUMP,LO 20$		; non => 20$				; oui =>	CLR.W	D1	INC.W	D0		; D0 <-- case en X suivante	ADD.W	D3,(A5)+OMSLGX	; D3 <-- va  la vase  droite	SWAP.W	D3	LOAD.W	D3,#4+1	ADD.W	D3,(A5)+OMSL1Y	; D3 <-- revient en haut	ADD.W	D3,(A5)+OMSAJY	SWAP.W	D3	JUMP	20$80$:	LOAD.W	D4,(A5)+OMSNCX	MUL.WU	D4,(A5)+OMSNCY	COMP.W	D4,(A5)+OMSNBC	; toutes les cases occupes ?	JUMP',EQ 90$		; oui => 90$	CALL	MSLIGNE		; non => trace une dernire ligne90$:	POPM.L	D0..D5,A2,A3	RET;--------\; MPOBMM  >;--------/; Positionne la souris pour pointer la case par dfaut.; in	D5.L	distance Y;X  corriger (+/-);	D0.L	coordonne initiale; out	-; mod	D7.WMPOBMM:	PUSHM.L	D4,D5	TEST.L	D5		; correction  effectuer ?	JUMP',EQ 90$		; non => 90$	LOAD.L	D4,D0		; D4 <-- coordonne initiale	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D5		; D4 <-- monte/descend	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D5		; D4 <-- gauche/droite	CALL	_PMOUSE		; positionne la souris90$:	POPM.L	D4,D5	RET;--------\; CLOBMM  >;--------/; Supprime la sous-fentre pour un m-menu.; in	-; out	-; mod	-CLOBMM:	PUSHM.L	D3..D5,D7	LOAD.B	D3,#GETWDO	CALL	_AFCAR		; restitue contenu sous-fentre	CALL	_GETWDO		; D5 <-- no s-wdo pour menu	LOAD.W	D4,D5	LOAD.W	D5,(A5)+OMSWDO	; D5 <-- no s-wdo originale	CALL	_USEWDO		; utilise s-wdo originale	LOAD.W	D5,D4	CALL	_KILWDO		; dtruit s-wdo menu	CALL	_COLORPOP	; restitue les couleurs	TEST.B	(A5)+OMSSVM:#BFNOCU	JUMP',BS 90$	LOAD.B	D3,#CURS	CALL	_AFCAR		; remet curseur s'il existait90$:	POPM.L	D3..D5,D7	RET;--------\; DETBMM  >;--------/; Dtecte dans quelle case est la souris.; in	D4.L	coordonnes de la souris; out	D3.W	case montre (0..n);		-1 si en dehors;		:#15 si case inactive (grise);		:#14 si trop  gauche (dans sous-menu du pre); mod	D3.L, D7.WDETBMM:	PUSHM.L	D2,A5	CLR.W	D2		; D2 <-- ne met pas le bit 2^14	CALL	DETTBMM		; dans le menu actuel ?	COMP.W	D3,#-1	JUMP',NE 80$20$:	TEST.L	(A5)+OMSPVP	; y a-t-il un pre ?	JUMP',EQ 80$		; non => 80$	LOAD.L	A5,(A5)+OMSPVP	; A5 <-- ^variables du pre	LOAD.W	D2,#2^14	; D2 <-- met le bit 2^14	CALL	DETTBMM		; dans le menu du pre ?	COMP.W	D3,#-1	JUMP,EQ 20$80$:	OR.W	D3,D2		; D3 <-- met v. le bit 2^14	POPM.L	D2,A5	RET;--------\; DETTBMM >;--------/; Dtecte dans quelle case est la souris.; in	D4.L	coordonnes de la souris; out	D3.W	case montre (0..n);		-1 si en dehors;		:#15 si case inactive (grise); mod	D3.L, D7.WDETTBMM:	PUSHM.L	D4,D5,A5	LOAD.L	D5,D4	AND.L	D4,#H'FFFF	; D4 <-- position X	LOAD.W	D3,#-1		; D3 <-- en dehors	SUB.W	D4,(A5)+OMSORX	; souris trop  gauche ?	JUMP',LO 80$		; oui => 80$				; non =>	SUB.W	D4,#4		; souris dans marge gauche ?	JUMP',LO 80$		; oui => 80$	SUB.W	D4,(A5)+OMSAJX	JUMP',HS 20$	CLR.W	D420$:	DIV.WU	D4,(A5)+OMSLGX	COMP.W	D4,(A5)+OMSNCX	; souris trop  droite ?	JUMP',HS 80$		; oui => 80$				; non =>				; D4 <-- case en X (0..n)	CLR.W	D5	SWAP.W	D5		; D5 <-- position Y	LOAD.W	D3,#-1		; D3 <-- en dehors	SUB.W	D5,(A5)+OMSORY	; souris trop haute ?	JUMP',LO 80$		; oui => 80$				; non =>	SUB.W	D5,#4		; souris dans marge suprieure ?	JUMP',LO 80$		; oui => 80$	SUB.W	D5,(A5)+OMSAJY	JUMP',HS 40$	CLR.W	D540$:	DIV.WU	D5,(A5)+OMSLGY	COMP.W	D5,(A5)+OMSNCY	; souris trop basse ?	JUMP',HS 80$		; oui => 80$				; non =>				; D5 <-- case en Y (0..n)	LOAD.W	D3,D4	MUL.WU	D3,(A5)+OMSNCY	ADD.W	D3,D5		; D3 <-- case dans le "tableau"	COMP.W	D3,(A5)+OMSNBC	; est-on dans une case "vide" ?	JUMP',LO 80$		; non => 80$				; oui =>	LOAD.W	D3,(A5)+OMSNBC	; D3 <-- met le maximum (en bas  droite)	DEC.W	D380$:	COMP.W	D3,#-1	JUMP',EQ 90$	COMP.W	D3,#32	JUMP',HS 90$	LOAD.L	D4,(A5)+OMSMAG	TEST.L	D4:D3		; case inactive ?	JUMP',BC 90$		; non => 90$	TSET.L	D3:#1590$:	POPM.L	D4,D5,A5	RET;--------\; PSMBMM  >;--------/; Cherche s'il existe un sous-menu pour une case donne.; in	A3.L	^textes .ASCIZ termins par zro;	D3.W	case montre (0..n); out	A4.L	^sous-menu suivant;	D7.W	erreur; mod	D7.W, A4.LPSMBMM:	PUSHM.L	D3,D4,A3	LOAD.W	D7,#ERDIOUT	; D7 <-- pas trouv	LOAD.L	A4,A3	LOAD.W	D4,D3		; D4 <-- case montre	JUMP,NS 90$	TEST.L	D4:#14		; trop  gauche (dans sous-menu du pre) ?	JUMP,BS 90$		; oui => 90$10$:	LOAD.B	D3,(A3)		; fin du m-menu ?	JUMP,EQ 90$		; oui => 90$	COMP.B	D3,#-1		; ligne horizontale ?	JUMP',NE 12$		; non => 12$	INC.L	A3	JUMP	10$12$:	TEST.W	D4		; est-on dans la case montre ?	JUMP',NE 20$		; non => 20$	COMP.B	D3,#-2		; sous-menu existe ?	JUMP,NE 90$		; non => 90$	LOAD.B	D4,(A3)+1	SL.W	D4,#8	LOAD.B	D4,(A3)+2	; D4 <-- <<^sous-menu>>	ADD.W	A4,D4		; A4 <-- ^sous-menu	CLR.W	D7		; D7 <-- trouv	JUMP	90$20$:	LOAD.B	D3,(A3+)	; D3 <-- un caractre	JUMP',EQ 50$;	COMP.B	D3,#-1		; ligne horizontale ?;	JUMP,EQ	20$		; oui => 20$	COMP.B	D3,#-2		; sous-menu ?	JUMP',EQ 24$		; oui => 24$	COMP.B	D3,#USEGC	; changement de gencar ?	JUMP',EQ 25$		; oui => 25$	COMP.B	D3,#TYPOAX	; positionnement absolu en X ?	JUMP',EQ 26$		; oui => 26$	COMP.B	D3,#COLORSA	; changement de couleur ?	JUMP',EQ 28$		; oui => 28$	COMP.B	D3,#COLORSR	; changement de couleur ?	JUMP',EQ 29$		; oui => 29$	JUMP	20$24$:				; sous-menu =>	ADD.L	A3,#2		; A3 <-- saute <<^sous-menu>>	JUMP	20$25$:				; <USEGC> =>	ADD.L	A3,#3		; A3 <-- saute <f> <s/c> <t>	JUMP	20$26$:				; <TYPOAX> =>	ADD.L	A3,#2		; A3 <-- saute <<xx>>	JUMP	20$28$:				; <COLORSA> =>	ADD.L	A3,#6		; A3 <-- saute <rr> <gg> <bb>	JUMP	20$29$:				; <COLORSR> =>	ADD.L	A3,#4		; A3 <-- saute <cccc>	JUMP	20$50$:	DEC.W	D4	JUMP	10$90$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; MSSRCRANG >;----------/; Cherche le rang en parcourant tout l'arbre des menus, sous-menus, etc.; in	A3.L		^mmenu; out	(A5)+OMSRAN.W	rang (0..n); mod	D7.WMSSRCRANG:	PUSHM.L	D2..D4,A2..A4	LOAD.L	A4,A3		; A4 <-- ^mmenu cherch	LOAD.L	A3,(A6)+OMGPMN	; A3 <-- ^mmenu principal; Parcourt toutes les feuilles (menus) de l'arbre jusqu'au fond.	CLR.W	D2		; D2 <-- niveau dans l'arbre	CLR.W	(A5)+OMSRAN	; OMSRAN <-- rang	LOAD.L	A2,A3		; A2 <-- ^dbut du menu10$:	COMP.L	A4,A3		; trouv ?	JUMP,EQ 90$		; oui => youpie12$:	LOAD.B	D3,(A3)	JUMP,EQ 40$	COMP.B	D3,#-1		; ligne horizontale ?	JUMP',NE 15$		; non => 15$	INC.L	A3	JUMP	12$15$:	COMP.B	D3,#-2		; sous-menu existe ?	JUMP',NE 20$		; non => 20$				; oui =>	ADD.L	A3,#1+2		; A3 <-- saute <-2> <<^sous-menu>>	PUSHM.L	A2,A3	INC.W	D2		; D2 <-- niveau +1	INC.W	(A5)+OMSRAN	; OMSRAN <-- rang +1	LOAD.B	D3,(A3)-2	SL.W	D3,#8	LOAD.B	D3,(A3)-1	; D3 <-- <<^sous-menu>>	ADD.W	A2,D3		; A2 <-- ^sous-menu	LOAD.L	A3,A2	JUMP	10$20$:	LOAD.B	D3,(A3+)	; A3 <-- saute un .ASCIZ	JUMP,EQ 10$	COMP.B	D3,#USEGC	JUMP',EQ 22$	COMP.B	D3,#TYPOAX	JUMP',EQ 23$	COMP.B	D3,#COLORSA	JUMP',EQ 25$	COMP.B	D3,#COLORSR	JUMP',EQ 26$	JUMP	20$22$:				; USEGC =>	ADD.L	A3,#3		; A3 <-- saute <f> <s/c> <t>	JUMP	20$23$:				; TYPOAX =>	ADD.L	A3,#2		; A3 <-- saute <<xx>>	JUMP	20$25$:				; COLORSA =>	ADD.L	A3,#6		; A3 <-- saute <rr> <gg> <bb>	JUMP	20$26$:				; COLORSR =>	ADD.L	A3,#4		; A3 <-- saute <cccc>	JUMP	20$40$:	TEST.W	D2	JUMP',EQ 90$	DEC.W	D2		; D2 <-- niveau -1	POPM.L	A2,A3	JUMP	20$; Ajuste le stack si ncessaire !90$:	DEC.W	D2	JUMP',NS 95$	POPM.L	A2,A3		; ajuste le stack	JUMP	90$95$:	POPM.L	D2..D4,A2..A4	RET;--------\; MSINVB  >;--------/; Inverse une case entire selon son numro.; in	D3.W	numro de la case 0..n;		si -1/-2 => ne fait rien;		:#15 si case inactive (grise); out	-; mod	D7.WMSINVB:	PUSHM.L	D2..D4	COMP.W	D3,#-1	JUMP,EQ 90$	COMP.W	D3,#-2	JUMP,EQ 90$	TEST.L	D3:#14		; trop  gauche (dans sous-menu du pre) ?	JUMP,BS 90$		; oui => 90$	LOAD.L	D4,#-1		; D4 <-- trame pleine	TCLR.L	D3:#15		; case inactive ?	JUMP',BC 05$		; non => 05$;;?	LOAD.L	D4,#H'55005500	; D4 <-- trame grise	LOAD.L	D4,#H'40000400	; D4 <-- trame grise05$:	PUSH.L	D3	LOAD.L	D3,D4	CALL	_DRMDEF		; dfinit la trame pleine/grise	POP.L	D3	CALL	MSPOSB		; D3/D4 <-- position/dimensions	LOAD.B	D2,#INVDOT	; D2 <-- <mode>	CALL	_DRTRAME	; inverse une case	ADD.W	D3,#8	TEST.B	(A5)+OMSFLG+3:#BMSLEFT ; sous-menu vers la gauche ?	JUMP',BS 50$		; oui => 50$	SUB.W	D3,#8	ADD.W	D3,D450$:	ADD.W	D3,(A0)+ODFFX	SWAP.W	D3	SUB.W	D3,#4	ADD.W	D3,(A0)+ODFFY	SWAP.W	D3	LOAD.L	(A5)+OMSPSM,D3	; OMSPSM <-- position pour sous-menu90$:	POPM.L	D2..D4	RET;--------\\; MSPOSB  >;--------/; Cherche la position et les dimensions d'une case.; in	D3.W	numro de la case 0..n; out	D3.L	coin sup/gauche de la case (y;x);	D4.L	dimensions de la case (dy;dx); mod	D3.L, D4.LMSPOSB:	PUSHM.L	D1,D2	CLR.L	D4	LOAD.W	D4,D3		; D4 <-- case 0..n	DIV.WU	D4,(A5)+OMSNCY	; D4 <-- case (y;x)	LOAD.W	D1,D4		; D1 <-- case en X	LOAD.L	D2,D4	SWAP.W	D2		; D2 <-- case en Y	LOAD.W	D3,D2	MUL.WU	D3,(A5)+OMSLGY	ADD.W	D3,#4		; D3 <-- <yy>	TEST.W	D2		; premire case ?	JUMP',EQ 10$		; oui => 10$	ADD.W	D3,(A5)+OMSAJY	; non => compte premire plus haute10$:	SWAP.W	D3	LOAD.W	D4,D1	MUL.WU	D4,(A5)+OMSLGX	ADD.W	D4,#4	TEST.W	D1		; premire case ?	JUMP',EQ 20$		; oui => 20$	ADD.W	D4,(A5)+OMSAJX	; non => compte premire plus large20$:	LOAD.W	D3,D4		; D3 <-- <xx>	LOAD.W	D4,(A5)+OMSLGY	DEC.W	D4		; D4 <-- <dyy>	TEST.W	D2		; premire case ?	JUMP',NE 30$		; non => 30$	ADD.W	D4,(A5)+OMSAJY	; oui => compte premire plus haute30$:	SWAP.W	D4	LOAD.W	D4,(A5)+OMSLGX	DEC.W	D4		; D4 <-- <dxx>	TEST.W	D1		; premire case ?	JUMP',NE 40$		; non => 40$	ADD.W	D4,(A5)+OMSAJX	; oui => compte premire plus large40$:	POPM.L	D1,D2	RET;--------\; MSCADRE >;--------/; Trace tous les rectangles pour les cases.; in	-; out	D7.W	erreur; mod	D7.WMSCADRE:	PUSHM.L	D1..D4	LOAD.L	D3,#COLOR_MMCADRE	CALL	_COLORSR	; donne la couleur du cadre	LOAD.W	D4,(A5)+OMSLGY	MUL.WU	D4,(A5)+OMSNCY	ADD.W	D4,#2	ADD.W	D4,(A5)+OMSAJY	SWAP.W	D4	LOAD.W	D3,(A5)+OMSLGX	MUL.WU	D3,(A5)+OMSNCX	ADD.W	D3,#2	ADD.W	D3,(A5)+OMSAJX	LOAD.W	D4,D3	LOAD.W	D3,#2	SWAP.W	D3	LOAD.W	D3,#2	LOAD.B	D2,#SETDOT	CALL	_DRRECT		; trace rectangle extrieur	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	CALL	_DRRECT		; trace rectangle intrieur	LOAD.W	D3,#4-1		; D3 <-- <xx> initial	ADD.W	D3,(A5)+OMSAJX	CLR.W	D4		; D4 <-- <dxx> pour ligne verticale	LOAD.W	D1,(A5)+OMSNCX50$:	DEC.W	D1	JUMP',EQ 80$	ADD.W	D3,(A5)+OMSLGX	; D3 <-- <xx> colonne suivante	PUSH.L	D3	CALL	_DRSEG		; trace segment vertical entre colonnes	POP.L	D3	JUMP	50$80$:	LOAD.L	D3,#COLOR_MMSET	CALL	_COLORSR	; donne la couleur de dessin	POPM.L	D1..D4	RET;--------\; MSLIGNE >;--------/; Trace une ligne horizontale pour sparer les cases.; in	D3.L	coordonne pour caractre;	D0.W	rang case en X; out	D7.W	erreur; mod	D7.WMSLIGNE:	PUSHM.L	D2..D4	CALL	_AFTIM	.B	MAPTT	.B	B'10101010	; map des traits - - -	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D2,D3	LOAD.L	D3,#COLOR_MMSEP	CALL	_COLORSR	; donne la couleur des sparateurs	LOAD.L	D3,D2	SWAP.W	D3	SUB.W	D3,(A5)+OMSL1Y	SUB.W	D3,#2		; D3 <-- en haut de la case	SWAP.W	D3	SUB.W	D3,(A5)+OMSL1X	SUB.W	D3,#2		; D3 <--  gauche de la case	CLR.L	D4	LOAD.W	D4,(A5)+OMSLGX	TEST.W	D0		; premire case ?	JUMP',NE 50$		; non => 50$	ADD.W	D4,(A5)+OMSAJX	; oui => compte premire case plus large	SUB.W	D3,(A5)+OMSAJX	; D3 <-- recule aussi l'origine en X50$:	LOAD.B	D2,#SETDOT!TTTDOT	CALL	_DRSEG		; trace ligne horizontale - - -	LOAD.L	D3,#COLOR_MMSET	CALL	_COLORSR	; donne la couleur de dessin	POPM.L	D2..D4	RET	.END