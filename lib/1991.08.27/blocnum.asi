	.SBTTL	BLOCNUM.ASI;-----------\\; NUMCHIFFRE >;===========/; Dessine un petit chiffre.; in	D3.W	chiffre (0..999);	D4.L	position centre (y;x); out	-; mod	D7.WNUMCHIFFRE:	PUSHM.L	D1..D4	CALL	CCMO		; enlve la souris	COMP.W	D3,#999	JUMP,HI EXIT$	LOAD.W	D2,#10	COMP.W	D3,#999	JUMP',HI ADDX$	LOAD.W	D2,#7	COMP.W	D3,#99	JUMP',HI ADDX$	LOAD.W	D2,#5	COMP.W	D3,#9	JUMP',HI ADDX$	LOAD.W	D2,#2ADDX$:	SUB.W	D4,D2		; D4 <-- centre en X	SWAP.W	D4	SUB.W	D4,#3		; D4 <-- centre en Y	SWAP.W	D4	LOAD.L	D2,D4	CLR.L	D4	LOAD.W	D4,D3	LIB	?BINBCD		; D4 <-- chiffre en BCD	EX.L	D2,D4	LOAD.L	D1,#4LOOP$:	RL.W	D2,#4		; D2 <-- pousse d'un digit	LOAD.W	D3,D2	AND.W	D3,#B'1111	; D3 <-- digit	JUMP',NE DIGIT$	COMP.W	D1,#1		; est-ce le dernier digit (units) ?	JUMP',EQ DIGIT$		; oui => DIGIT$	TEST.L	D1:#16		; dj affich qq chose ?	JUMP',BC NEXT$		; non => NEXT$DIGIT$:	CALL	NUMDIGIT	; dessine un digit	ADD.W	D4,#4+1		; D4 <-- position suivante	TSET.L	D1:#16		; D1 <-- signale affich qq choseNEXT$:	DEC.W	D1	JUMP,NE LOOP$EXIT$:	CALL	SCMO		; remet la souris	POPM.L	D1..D4	RET;---------\\; NUMDIGIT >;---------/; Dessine un digit.; in	D3.W	chiffre (0..9);	D4.L	position (y;x); out	-; mod	D7.WNUMDIGIT:	PUSHM.L	D1..D5,A2..A4	LOAD.L	A3,#R16"MAT09$	LOAD.L	D2,#H'10000*7+4	MUL.WU	D3,#7	ADD.L	A3,D3		; A3 <-- ^matrice du chiffre	CLR.L	D3	LOAD.W	D5,#1	LOAD.L	A4,#0	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; dessine le digit	POPM.L	D1..D5,A2..A4	RETMAT09$:	.B	B'01100000	.B	B'10010000	.B	B'10010000	.B	B'10010000	.B	B'10010000	.B	B'10010000	.B	B'01100000	.B	B'00100000	.B	B'01100000	.B	B'00100000	.B	B'00100000	.B	B'00100000	.B	B'00100000	.B	B'01110000	.B	B'01100000	.B	B'10010000	.B	B'00010000	.B	B'00100000	.B	B'01000000	.B	B'10000000	.B	B'11110000	.B	B'01100000	.B	B'10010000	.B	B'00010000	.B	B'01100000	.B	B'00010000	.B	B'10010000	.B	B'01100000	.B	B'00100000	.B	B'01100000	.B	B'10100000	.B	B'10100000	.B	B'11110000	.B	B'00100000	.B	B'00100000	.B	B'11100000	.B	B'10000000	.B	B'11100000	.B	B'10010000	.B	B'00010000	.B	B'10010000	.B	B'01100000	.B	B'01100000	.B	B'10000000	.B	B'11100000	.B	B'10010000	.B	B'10010000	.B	B'10010000	.B	B'01100000	.B	B'11110000	.B	B'00010000	.B	B'00010000	.B	B'00100000	.B	B'00100000	.B	B'01000000	.B	B'01000000	.B	B'01100000	.B	B'10010000	.B	B'10010000	.B	B'01100000	.B	B'10010000	.B	B'10010000	.B	B'01100000	.B	B'01100000	.B	B'10010000	.B	B'10010000	.B	B'10010000	.B	B'01110000	.B	B'00010000	.B	B'01100000	.EVEN	.END