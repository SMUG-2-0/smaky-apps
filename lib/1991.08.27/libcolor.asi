	.SBTTL	LIBCOLOR;-----------\\; _COLORPUSH >;===========/; Sauve les couleurs actuelles.; in	-; out	D7.W	erreur; mod	D7.W_COLORPUSH:	.IF	COLOR	PUSH.L	A0	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP',NE 90$		; non => 90$	LOAD.L	A0,#(A6)+OBUWRI	; A0 <-- ^petit buffer	LOAD.B	(A0+),#COLOROP	LOAD.B	(A0+),#COLOROPPUSH	CALL	WRBUF90$:	POP.L	A0	.ENDIF	RET;----------\\; _COLORPOP >;==========/; Restitue les couleurs sauves.; in	-; out	D7.W	erreur; mod	D7.W_COLORPOP:	.IF	COLOR	PUSH.L	A0	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP',NE 90$		; non => 90$	LOAD.L	A0,#(A6)+OBUWRI	; A0 <-- ^petit buffer	LOAD.B	(A0+),#COLOROP	LOAD.B	(A0+),#COLOROPPOP	CALL	WRBUF90$:	POP.L	A0	.ENDIF	RET;---------\; _COLORSA >;=========/; Donne la couleur absolue pour dessiner (color-set); in	D3.W	intensit de la couleur rouge;	D4.W	intensit de la couleur verte;	D5.W	intensit de la couleur bleue; out	D7.W	erreur; mod	D7.W_COLORSA:	.IF	COLOR	PUSH.L	A0	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP',NE 90$		; non => 90$	LOAD.L	A0,#(A6)+OBUWRI	; A0 <-- ^petit buffer	LOAD.W	(A0+),#COLORSA	LOAD.W	(A0+),D3	LOAD.W	(A0+),D4	LOAD.W	(A0+),D5	CALL	WRBUF90$:	POP.L	A0	.ENDIF	RET;---------\; _COLORCA >;=========/; Donne la couleur absolue pour effacer (color-clear); in	D3.W	intensit de la couleur rouge;	D4.W	intensit de la couleur verte;	D5.W	intensit de la couleur bleue; out	D7.W	erreur; mod	D7.W_COLORCA:	.IF	COLOR	PUSH.L	A0	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP',NE 90$		; non => 90$	LOAD.L	A0,#(A6)+OBUWRI	; A0 <-- ^petit buffer	LOAD.W	(A0+),#COLORCA	LOAD.W	(A0+),D3	LOAD.W	(A0+),D4	LOAD.W	(A0+),D5	CALL	WRBUF90$:	POP.L	A0	.ENDIF	RET;---------\; _COLORSR >;=========/; Donne la couleur relative pour dessiner (color-set); in	D3.L	couleur relative; out	D7.W	erreur; mod	D7.W_COLORSR:	.IF	COLOR	PUSH.L	A0	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP',NE 90$		; non => 90$	LOAD.L	A0,#(A6)+OBUWRI	; A0 <-- ^petit buffer	LOAD.W	(A0+),#COLORSR	LOAD.L	(A0+),D3	CALL	WRBUF90$:	POP.L	A0	.ENDIF	RET;---------\; _COLORCR >;=========/; Donne la couleur relative pour effacer (color-clear); in	D3.L	couleur relative; out	D7.W	erreur; mod	D7.W_COLORCR:	.IF	COLOR	PUSH.L	A0	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP',NE 90$		; non => 90$	LOAD.L	A0,#(A6)+OBUWRI	; A0 <-- ^petit buffer	LOAD.W	(A0+),#COLORCR	LOAD.L	(A0+),D3	CALL	WRBUF90$:	POP.L	A0	.ENDIF	RET	.END