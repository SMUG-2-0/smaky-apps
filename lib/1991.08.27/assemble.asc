	.TITLE	ASSEMBLE.ASC	.PROC	M680002	.REF	SMAKY	.REF	MODULESOVERLAY	=	0	.IF	OVERLAY	.CODE	,,B'100000		; signale routine overlay	.ELSE	.CODE	800,23,B'0111,600,2000,300,2000,2,'N,'R,'F,09	.ENDIF	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------TYPEC	=	1			; .ASCTYPEL	=	2			; .ASLTYPES	=	3			; .ASSTYPEB	=	4			; .ASBTYPED	=	5			; .ASDTYPEOP	=	6			; .ASOPTYPER	=	7			; .ASRBSMAKY	=	0			; BSM8	=	1			; BSM100	=	2			; BSM32P	=	3			; BSM324	=	4			; BSM300	=	5			; BDIR	=	8			; BSDIR	=	9			; BCALM2	=	16			; BCALM3	=	17			; BCALM	=	18			; BLIST	=	24			; BCROSS	=	25			; BOPTIM	=	26			; KEYDBOX	=	H'7E00			; "touche" pour dbox; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2			; canal module DBOXOCHSOFT:.BLKB	4			; canal des soft-keysOMOUSE:	.BLKB	2			; mode de la sourisOTYPE:	.BLKB	2			; type  assembler (TYPEx)OLICOM:	.BLKB	100			; ligne de commandeOEXCOM:	.BLKB	100			; ligne de commandeOOLDN:	.BLKB	50			; ancien nomONEWN:	.BLKB	50			; nouveau nomOSYMB:	.BLKB	16*10			; fichier .SYMBOLASTC:	.BLKB	1			; dernier caractre	.EVENLGVAR:; Programme; ---------	.LOC	0START:	.IF	OVERLAY	PUSHM.L	D0..D6,A0..A6		; sauve tous les registres	.ELSE	LIB	?OPELIB	.ENDIF	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE 99$	LOAD.L	A6,A4			; A6 <-- ^variables10$:	CLR.B	(A4+)			; met toutes les variables  zro	DEC.L	D4	JUMP,NE 10$	LOAD.L	A4,#(A6)+OLICOM20$:	LOAD.B	(A4+),(A3+)		; OLICOM <-- ligne de commande	JUMP,NE 20$	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN			; ouvre le module DBOX	JUMP,NE 98$	LOAD.W	(A6)+OCHDBOX,D1	LIB	?PUSHMENU		; sauve les soft-keys	JUMP,NE 97$	LOAD.L	(A6)+OCHSOFT,D5		; mm. canal des soft-keys	LIB	?GMOUSE	LOAD.W	(A6)+OMOUSE,D3	LOAD.W	D3,#2	LIB	?MOUSE			; souris par le clavier	CALL	ANALYSE	LOAD.W	D7,#ERILOP	TEST.W	(A6)+OTYPE		; type reconnu ?	JUMP,EQ 90$			; non => 90$	CALL	DBOXASS			; pose la question ...	JUMP,NE 90$	LOAD.W	D7,#ERKSTO	COMP.W	D3,#F1	JUMP,NE 90$	CALL	CREESYMB		; cre MACHINE.SYMB	JUMP,NE 80$	CALL	CONSTRUIT		; construit la ligne de commande	LOAD.L	A3,#(A6)+OEXCOM	LIB	?OEXECUTE		; assemble ...	JUMP,NE 80$	CALL	RENOMME			; renomme le fichier dfinitif80$:	TEST.W	D7	JUMP,EQ 90$	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP	POP.W	D7	DBOX_	ERROR			; affiche l'erreur90$:	PUSH.W	D7	LOAD.W	D3,(A6)+OMOUSE	LIB	?MOUSE			; remet le mode de la souris	LOAD.L	D5,(A6)+OCHSOFT		; D5 <-- canal des soft-keys	LIB	?POPMENU		; restitue les soft-keys	POP.W	D797$:	PUSH.W	D7	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE			; ferme le module DBOX	POP.W	D798$:	PUSH.W	D7	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM			; rend les variables	POP.W	D799$:	.IF	OVERLAY	POPM.L	D0..D6,A0..A6		; restitue tous les registres	RET				; retourne au programme appelant	.ELSE	LIB	?CLOLIB	FOS	?STOP	.ENDIF;--------\\; ANALYSE >;========/; Analyse le type du fichier  assembler.; in	-; out	(A6)+OTYPE; mod	D7.WANALYSE:	PUSHM.L	A2..A4	LOAD.L	A4,#(A6)+OLICOM	LOAD.L	A2,#R16"TERM$	LOAD.W	(A6)+OTYPE,#TYPEC	LOAD.L	A3,#R16"ASC$	LIB	?CPSTRING	JUMP,NC 90$	LOAD.W	(A6)+OTYPE,#TYPEL	LOAD.L	A3,#R16"ASL$	LIB	?CPSTRING	JUMP,NC 90$	LOAD.W	(A6)+OTYPE,#TYPES	LOAD.L	A3,#R16"ASS$	LIB	?CPSTRING	JUMP,NC 90$	LOAD.W	(A6)+OTYPE,#TYPEB	LOAD.L	A3,#R16"ASB$	LIB	?CPSTRING	JUMP,NC 90$	LOAD.W	(A6)+OTYPE,#TYPED	LOAD.L	A3,#R16"ASD$	LIB	?CPSTRING	JUMP,NC 90$	LOAD.W	(A6)+OTYPE,#TYPEOP	LOAD.L	A3,#R16"ASOP$	LIB	?CPSTRING	JUMP,NC 90$	LOAD.W	(A6)+OTYPE,#TYPER	LOAD.L	A3,#R16"ASR$	LIB	?CPSTRING	JUMP,NC 90$	CLR.W	(A6)+OTYPE90$:	POPM.L	A2..A4	TEST.W	D7		; retour EQ/NE	RETASC$:	.ASCIZ	"*.ASC*"ASL$:	.ASCIZ	"*.ASL*"ASS$:	.ASCIZ	"*.ASS*"ASB$:	.ASCIZ	"*.ASB*"ASD$:	.ASCIZ	"*.ASD*"ASOP$:	.ASCIZ	"*.ASOP*"ASR$:	.ASCIZ	"*.ASR*"TERM$:	.B	0,-1	.EVEN;--------\\; DBOXASS >;========/; Demande comment assembler.; in	-; out	D3.W	dernire touche (F1/F0);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXASS:	PUSHM.L	D1,D2,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_ASS	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,#2^BSMAKY!2^BSDIR!2^BCALM2	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$	PUSH.L	D4	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#R16"ASC$	COMP.W	(A6)+OTYPE,#TYPEC	JUMP,EQ 12$	LOAD.L	A3,#R16"ASL$	COMP.W	(A6)+OTYPE,#TYPEL	JUMP,EQ 12$	LOAD.L	A3,#R16"ASS$	COMP.W	(A6)+OTYPE,#TYPES	JUMP,EQ 12$	LOAD.L	A3,#R16"ASB$	COMP.W	(A6)+OTYPE,#TYPEB	JUMP,EQ 12$	LOAD.L	A3,#R16"ASD$	COMP.W	(A6)+OTYPE,#TYPED	JUMP,EQ 12$	LOAD.L	A3,#R16"ASOP$	COMP.W	(A6)+OTYPE,#TYPEOP	JUMP,EQ 12$	LOAD.L	A3,#R16"ASR$	COMP.W	(A6)+OTYPE,#TYPER	JUMP,EQ 12$	LOAD.L	A3,#R16"AUTRE$12$:	LIB	?AFTEXT	POP.L	D4	COMP.W	(A6)+OTYPE,#TYPES	JUMP,EQ 13$	COMP.W	(A6)+OTYPE,#TYPEOP	JUMP,EQ 13$	COMP.W	(A6)+OTYPE,#TYPER	JUMP,NE 14$13$:	AND.L	D4,#H'FFFFFF00	PUSH.L	D4;	LOAD.W	D2,#100!2^BDBGCLABEL!2^BDBGCGREY;	DBOX_	GETCO	LOAD.W	D2,#BSMAKY!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BSM8!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BSM100!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BSM32P!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BSM324!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BSM300!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	POP.L	D414$:	COMP.W	(A6)+OTYPE,#TYPES	JUMP,NE 16$	PUSH.L	D4	LOAD.W	D2,#BOPTIM!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	POP.L	D416$:20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_ASS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; ASSEMBLE ?	JUMP',EQ 70$	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 80$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP,LO 42$	LOAD.L	D1,#H'FFFF00FF	COMP.B	D3,#16	JUMP,LO 42$	LOAD.L	D1,#H'FF00FFFF	COMP.B	D3,#24	JUMP,LO 42$	JUMP	20$42$:	AND.L	D4,D1	TSET.L	D4:D3	JUMP	20$70$:				; ASSEMBLE =>80$:				; ANNULE =>	DBOX_	CLOSE		; ferme la DBOX90$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETASC$:	.ASCIZ	"Programme pour :"ASL$:	.ASCIZ	"Librairie pour :"ASS$:	.ASCIZ	"Symboles"ASB$:	.ASCIZ	"Binaire pour :"ASD$:	.ASCIZ	"Pilote pour :"ASOP$:	.ASCIZ	"Objet PAGE"ASR$:	.ASCIZ	"Ressources"AUTRE$:	.ASCIZ	"Fichier pour :"	.EVEN;----------\\; CONSTRUIT >;==========/; Construit la ligne de commande.; in	D4.L		fanions; out	(A6)+OEXCOM	ligne de commande; mod	D7.WCONSTRUIT:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,#(A6)+OEXCOM	LOAD.L	A3,#R16"CALM2$	TEST.L	D4:#BCALM2	JUMP,BS 10$	LOAD.L	A3,#R16"CALM3$	TEST.L	D4:#BCALM3	JUMP,BS 10$	LOAD.L	A3,#R16"CALM$10$:	LOAD.B	(A4+),(A3+)		; OEXCOM <-- "AS.CODE"	JUMP,NE 10$	DEC.L	A4	TEST.L	D4:#BOPTIM	JUMP,BC 15$	LOAD.B	(A4+),#'/	LOAD.B	(A4+),#'O15$:	LOAD.B	(A4+),#SPACE	LOAD.L	A3,#(A6)+OLICOM	LIB	?SKPNAM20$:	LOAD.B	D3,(A3+)	JUMP,EQ 22$	COMP.B	D3,#CR	JUMP,EQ 22$	COMP.B	D3,#SPACE	JUMP,EQ 22$	LOAD.B	(A4+),D3		; OEXCOM <-- "fichier.ASx"	JUMP	20$22$:	TEST.L	D4:#BLIST	JUMP,BC 24$	LOAD.B	(A4+),#'/	LOAD.B	(A4+),#'L24$:	TEST.L	D4:#BCROSS	JUMP,BC 25$	LOAD.B	(A4+),#'/	LOAD.B	(A4+),#'X25$:	LOAD.B	(A4+),#SPACE	TEST.L	D4:#BSDIR	JUMP,BC 30$	LOAD.B	(A4+),#'#	LOAD.B	(A4+),#':		; OEXCOM <-- "#:"30$:	LOAD.L	A3,#R16"SM8$	TEST.L	D4:#BSM8	JUMP,BS 32$	LOAD.L	A3,#R16"SM100$	TEST.L	D4:#BSM100	JUMP,BS 32$	LOAD.L	A3,#R16"SM324$	TEST.L	D4:#BSM324	JUMP,BS 32$	LOAD.L	A3,#R16"SM32P$	TEST.L	D4:#BSM32P	JUMP,BS 32$	LOAD.L	A3,#R16"SM300$	TEST.L	D4:#BSM300	JUMP,BS 32$	LOAD.L	A3,#R16"SMAKY$	COMP.W	(A6)+OTYPE,#TYPEC	JUMP,EQ 33$	COMP.W	(A6)+OTYPE,#TYPES	JUMP,EQ 33$	COMP.W	(A6)+OTYPE,#TYPEOP	JUMP,EQ 33$	COMP.W	(A6)+OTYPE,#TYPER	JUMP,EQ 33$32$:	LOAD.B	(A4+),(A3+)		; OEXCOM <-- "100_"	JUMP,NE 32$	DEC.L	A433$:	LOAD.L	A3,#(A6)+OLICOM	LIB	?SKPNAM	TEST.L	D4:#BDIR	JUMP,BS 40$	CALL	SKIPREP40$:	LOAD.B	D3,(A3+)	JUMP,EQ 42$	COMP.B	D3,#'.	JUMP,EQ 42$	LOAD.B	(A4+),D3		; OEXCOM <-- "fichier"	JUMP	40$42$:	COMP.W	(A6)+OTYPE,#TYPEC	JUMP,EQ 44$	COMP.W	(A6)+OTYPE,#TYPES	JUMP,EQ 44$	COMP.W	(A6)+OTYPE,#TYPEOP	JUMP,EQ 44$	COMP.W	(A6)+OTYPE,#TYPER	JUMP,EQ 44$	LOAD.B	(A6)+OLASTC,(-A4)44$:	LOAD.L	A3,#R16"ASC$	COMP.W	(A6)+OTYPE,#TYPEC	JUMP,EQ 50$	LOAD.L	A3,#R16"ASL$	COMP.W	(A6)+OTYPE,#TYPEL	JUMP,EQ 50$	LOAD.L	A3,#R16"ASS$	COMP.W	(A6)+OTYPE,#TYPES	JUMP,EQ 50$	LOAD.L	A3,#R16"ASB$	COMP.W	(A6)+OTYPE,#TYPEB	JUMP,EQ 50$	LOAD.L	A3,#R16"ASD$	COMP.W	(A6)+OTYPE,#TYPED	JUMP,EQ 50$	LOAD.L	A3,#R16"ASOP$	COMP.W	(A6)+OTYPE,#TYPEOP	JUMP,EQ 50$	LOAD.L	A3,#R16"ASR$50$:	LOAD.B	(A4+),(A3+)		; OEXCOM <-- ".CODE/B" ou ".SYMB/S"	JUMP,NE 50$	DEC.L	A490$:	POPM.L	D3,D4,A3,A4	RETCALM2$:	.ASCIZ	"AS2"CALM3$:	.ASCIZ	"AS"CALM$:	.ASCIZ	"ASCALM"SMAKY$:	.ASCIZ	"SMA_"SM8$:	.ASCIZ	"SYS_"SM100$:	.ASCIZ	"100_"SM324$:	.ASCIZ	"324_"SM32P$:	.ASCIZ	"32P_"SM300$:	.ASCIZ	"300_"ASC$:	.ASCIZ	".CODE/B"ASL$:	.ASCIZ	".CODE/B"ASS$:	.ASCIZ	".SYMB/S"ASB$:	.ASCIZ	".CODE/B"ASD$:	.ASCIZ	".CODE/B"ASOP$:	.ASCIZ	".CODE/B"ASR$:	.ASCIZ	".CODE/B"	.EVEN;--------\\; RENOMME >;========/; ; in	-; out	D7.W	erreur; mod	D7.WRENOMME:	PUSHM.L	D3,D4,A3,A4	COMP.W	(A6)+OTYPE,#TYPEC	JUMP,EQ 90$	COMP.W	(A6)+OTYPE,#TYPES	JUMP,EQ 90$	LOAD.L	A4,#(A6)+OOLDN	LOAD.L	A3,#(A6)+OEXCOM	LIB	?SKPNAM		; A3 <-- saute "AS2"	LIB	?SKPNAM		; A3 <-- saute "fichier.ASx"20$:	LOAD.B	D3,(A3+)	JUMP,EQ 22$	COMP.B	D3,#CR	JUMP,EQ 22$	COMP.B	D3,#SPACE	JUMP,EQ 22$	COMP.B	D3,#'/	JUMP,EQ 22$	LOAD.B	(A4+),D3	; OOLDN <-- nom	JUMP	20$22$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OOLDN	LOAD.L	A4,#(A6)+ONEWN30$:	LOAD.B	D3,(A3+)	JUMP,EQ 32$	COMP.B	D3,#'.	JUMP,EQ 32$	LOAD.B	(A4+),D3	; ONEWN <-- nom sans extension	JUMP	30$32$:	COMP.W	(A6)+OTYPE,#TYPEOP	JUMP,EQ 33$	COMP.W	(A6)+OTYPE,#TYPER	JUMP,EQ 33$	LOAD.B	(A4+),(A6)+OLASTC33$:	LOAD.L	A3,#R16"ASL$	COMP.W	(A6)+OTYPE,#TYPEL	JUMP,EQ 40$	LOAD.L	A3,#R16"ASB$	COMP.W	(A6)+OTYPE,#TYPEB	JUMP,EQ 40$	LOAD.L	A3,#R16"ASD$	COMP.W	(A6)+OTYPE,#TYPED	JUMP,EQ 40$	LOAD.L	A3,#R16"ASOP$	COMP.W	(A6)+OTYPE,#TYPEOP	JUMP,EQ 40$	LOAD.L	A3,#R16"ASR$40$:	LOAD.B	(A4+),(A3+)	; ONEWN <-- nouvelle extension	JUMP,NE 40$	LOAD.L	A3,#(A6)+ONEWN	FOS	?DELETE		; dtruit l'ancien nouveau !	JUMP,EQ 60$	COMP.W	D7,#ERFDNE	JUMP,NE 90$60$:	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OOLDN	FOS	?RENAME		; renomme en nouveau90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RETASL$:	.ASCIZ	".LIB"ASB$:	.ASCIZ	".BIN"ASD$:	.ASCIZ	".DRIV"ASOP$:	.ASCIZ	".OPAGE"ASR$:	.ASCIZ	".RS"	.EVEN;---------\\; CREESYMB >;=========/; Cre le fichier #:MACHINE.SYMB.; in	D4.L	fanions; out	D7.W	erreur; mod	D7.WCREESYMB:	PUSHM.L	D2..D4,D6,A3,A4	LOAD.L	A4,#(A6)+OSYMB	LOAD.L	A3,#R16"SM8$	CLR.L	D3	TEST.L	D4:#BSM8	JUMP,BC 10$	INC.L	D310$:	CALL	PUTSYMB		; OSYMB <-- SM8	LOAD.L	A3,#R16"SM324L$	CLR.L	D3	TEST.L	D4:#BSM32P	JUMP,BC 20$	INC.L	D320$:	CALL	PUTSYMB		; OSYMB <-- SM324LIT	LOAD.L	A3,#R16"SM324B$	CLR.L	D3	TEST.L	D4:#BSM324	JUMP,BC 30$	INC.L	D330$:	CALL	PUTSYMB		; OSYMB <-- SM324BIG	LOAD.L	A3,#R16"SM324$	LOAD.L	D3,#1	TEST.L	D4:#BSM324	JUMP,BS 40$	TEST.L	D4:#BSM32P	JUMP,BS 40$	DEC.L	D340$:	CALL	PUTSYMB		; OSYMB <-- SM324	LOAD.L	A3,#R16"SM100$	CLR.L	D3	TEST.L	D4:#BSM100	JUMP,BC 50$	INC.L	D350$:	CALL	PUTSYMB		; OSYMB <-- SM100	LOAD.L	A3,#R16"SM300$	CLR.L	D3	TEST.L	D4:#BSM300	JUMP,BC 60$	INC.L	D360$:	CALL	PUTSYMB		; OSYMB <-- SM300	LOAD.L	A3,#(A6)+OSYMB	LOAD.L	D2,A4	SUB.L	D2,A3		; D2 <-- longueur	LOAD.L	A3,#R16"FILE$	FOS	?DELETE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP,NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	LOAD.L	A4,#(A6)+OSYMB	LOAD.L	D4,D2	FOS	?WRBYTE	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D2..D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RETSM8$:	.ASCIZ	"_SM8"SM324L$:.ASCIZ	"_SM324LIT"SM324B$:.ASCIZ	"_SM324BIG"SM324$:	.ASCIZ	"_SM324"SM100$:	.ASCIZ	"_SM100"SM300$:	.ASCIZ	"_SM300"FILE$:	.ASCIZ	"#:MACHINE.SYMB"	.EVEN;--------\\; PUTSYMB >;--------/; Met un symbole dans un buffer, au format .SYMB !; in	D3.L	valeur;	A3.L	^nom;	A4.L	^buffer; out	A4.L	^plus loin; mod	D7.W, A4.LPUTSYMB:	PUSHM.L	D3,A3,A5	LOAD.L	(A4+),D3	LOAD.L	(A4+),#H'20202020	LOAD.L	(A4+),#H'20202020	LOAD.L	(A4+),#H'20202020	; tout des espaces	LOAD.L	A5,A420$:	LOAD.B	D3,(A3+)	JUMP,EQ 30$	LOAD.B	(-A5),D3	JUMP	20$30$:	TSET.B	(A4)-1:#7	TSET.B	(A4)-2:#7	TSET.B	(A4)-8:#7		; met qq bits mystrieux !	POPM.L	D3,A3,A5	RET;--------\\; SKIPREP >;--------/; Saute tous les noms d'units et de rpertoires devant; un nom de fichier.; in	A3.L	^unit:rp:rp:nom.ext; out	A3.L	^nom.ext; mod	A3.LSKIPREP:	PUSH.W	D3	CLR.W	D310$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE 10$20$:	DEC.W	D3	JUMP',NS 90$	COMP.B	(-A3),#':	JUMP,NE 20$	INC.L	A390$:	POP.W	D3	RETTDBOX_ASS:	.W	10$-TDBOX_ASS	.W	20$-TDBOX_ASS	.W	0	.W	010$:	.B	ODBTABX,3	.B	ODBLABEL,100	.B	ODBTEXT	.ASCIZ	"                  "		;Programme pour :"	.B	ODBCR	.B	ODBLABEL,BSMAKY	.B	ODBLCIRCLE,BSMAKY!2^7!2^6,KEYDBOX/H'100,BSMAKY	.ASCIZ	" toutes les machines"	.B	ODBTABX,35	.B	ODBLCIRCLE,BCALM2!2^7!2^6,KEYDBOX/H'100,BCALM2	.ASCIZ	" CALM-2"	.B	ODBCR	.B	ODBLABEL,BSM8	.B	ODBLCIRCLE,BSM8!2^7!2^6,KEYDBOX/H'100,BSM8	.ASCIZ	" SMAKY 8"	.B	ODBTABX,35	.B	ODBLCIRCLE,BCALM3!2^7!2^6,KEYDBOX/H'100,BCALM3	.ASCIZ	" CALM-3"	.B	ODBCR	.B	ODBLABEL,BSM100	.B	ODBLCIRCLE,BSM100!2^7!2^6,KEYDBOX/H'100,BSM100	.ASCIZ	" SMAKY 100"	.B	ODBTABX,35	.B	ODBLCIRCLE,BCALM!2^7!2^6,KEYDBOX/H'100,BCALM	.ASCIZ	" CALM"	.B	ODBCR	.B	ODBLABEL,BSM32P	.B	ODBLCIRCLE,BSM32P!2^7!2^6,KEYDBOX/H'100,BSM32P	.ASCIZ	" SMAKY 324 petit cran"	.B	ODBCR	.B	ODBLABEL,BSM324	.B	ODBLCIRCLE,BSM324!2^7!2^6,KEYDBOX/H'100,BSM324	.ASCIZ	" SMAKY 324 grand cran"	.B	ODBCR	.B	ODBLABEL,BSM300	.B	ODBLCIRCLE,BSM300!2^7!2^6,KEYDBOX/H'100,BSM300	.ASCIZ	" SMAKY 300"	.B	ODBTABX,35	.B	ODBLABEL,BLIST	.B	ODBSQUARE,BLIST!2^7!2^6,KEYDBOX/H'100,BLIST	.ASCIZ	" listing"	.B	ODBCR	.B	ODBTABX,35	.B	ODBLABEL,BCROSS	.B	ODBSQUARE,BCROSS!2^7!2^6,KEYDBOX/H'100,BCROSS	.ASCIZ	" cross-rfrence"	.B	ODBCR	.B	ODBTABX,3	.B	ODBTEXT	.ASCIZ	"Rsultat dans le dossier :"	.B	ODBTABX,35	.B	ODBLABEL,BOPTIM	.B	ODBSQUARE,BOPTIM!2^7!2^6,KEYDBOX/H'100,BOPTIM	.ASCIZ	" optimise"	.B	ODBCR	.B	ODBLCIRCLE,BDIR!2^7!2^6,KEYDBOX/H'100,BDIR	.ASCIZ	" courant"	.B	ODBCR	.B	ODBLCIRCLE,BSDIR!2^7!2^6,KEYDBOX/H'100,BSDIR	.ASCIZ	" systme"	.B	ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" ASSEMBLE "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Assemble"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_ASS:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_ASS	.W	F1,F2,F3,CR,0		DOKF1-TKEY_ASS	.W	0DOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RET; Noms des modules; ----------------NMDBOX:	.ASCIZ	"DBOX"	.EVEN;;?	.END	START-1			; si OVERLAY=1 !!!	.END	START