	.SBTTL	LIBGENC;--------\; _RSTGC  >;========/; R-utilise le gnrateur de caractres initial.; in	-; out	D7.W	erreur; mod	D0..A1, D7.W_RSTGC:	LOAD.L	A0,#(A6)+OBUWRI	LOAD.B	(A0+),#USEGC	LOAD.B	(A0+),(A6)+OIGENC+0 ; fonte	LOAD.B	(A0+),(A6)+OIGENC+1 ; style	LOAD.B	(A0+),(A6)+OIGENC+2 ; taille	JUMP	WRBUF;--------\; _SYNGC  >;========/; Transforme une chane ASCII "fsctt" en 3 bytes pour $DIS.; in	A3.L	^nom d'un gnrateur de caractres;		terminateurs: <0> <CR> <SPACE> <'.>; out	D3.B	fonte;	D4.B	style/chasse;	D5.B	taille;	D7.W	erreur; mod	D3.L, D4.L, D5.L, D7.W_SYNGC:	PUSHM.L	D0,D1,A310$:	COMP.B	(A3+),#SPACE	; A3 <-- saute SPACE(s)	JUMP,EQ	10$	DEC.L	A3	LOAD.B	D3,(A3+)	; D3 <-- fonte	LIB	?MINMAJ		; D3 <-- fonte MAJUSCULE	CLR.B	D1		; D1 <-- fonte quelconque	COMP.B	D3,#METAANY	JUMP',EQ 20$	COMP.B	D3,#METAONE	JUMP',EQ 20$	COMP.B	D3,#'A	JUMP,LO 85$	COMP.B	D3,#'Z		; lettre ?	JUMP,HI	85$		; non => 85$	LOAD.B	D1,D3		; D1 <-- fonte20$:	LOAD.B	D3,(A3+)	; D3 <-- style	LIB	?MINMAJ		; D3 <-- style MAJUSCULE	COMP.B	D3,#'(	JUMP',NE 40$	TSET.L	D1:#7		; D1 <-- fonte "soft"	CLR.B	D430$:	LOAD.B	D3,(A3+)	; D3 <-- style "soft"	LIB	?MINMAJ		; D3 <-- style MAJUSCULE	COMP.B	D3,#'B		; bold ?	JUMP',EQ 32$	COMP.B	D3,#'I		; italique ?	JUMP',EQ 33$	COMP.B	D3,#'O		; outline ?	JUMP',EQ 34$	COMP.B	D3,#'S		; shadow ?	JUMP',EQ 35$	COMP.B	D3,#'L		; large ?	JUMP',EQ 36$	COMP.B	D3,#'F		; fix ?	JUMP',EQ 37$	COMP.B	D3,#'P		; proportionnel ?	JUMP,EQ 30$	COMP.B	D3,#')	JUMP,NE	85$	JUMP'	60$32$:	TSET.L	D4:#BGCBOLD	JUMP	30$33$:	TSET.L	D4:#BGCITAL	JUMP	30$34$:	TSET.L	D4:#BGCOUTL	JUMP	30$35$:	TSET.L	D4:#BGCSHAD	JUMP	30$36$:	TSET.L	D4:#BGCLARG	JUMP	30$37$:	TSET.L	D4:#BGCFIX	JUMP	30$40$:	CLR.B	D4		; D4 <-- style quelconque	COMP.B	D3,#METAANY	JUMP',EQ 50$	COMP.B	D3,#METAONE	JUMP',EQ 50$	COMP.B	D3,#'A	JUMP,LO	85$	COMP.B	D3,#'Z		; lettre ?	JUMP,HI	85$		; non => 85$	LOAD.B	D4,D3		; D4 <-- style proportionnel50$:	LOAD.B	D3,(A3+)	; D3 <-- chasse	LIB	?MINMAJ		; D3 <-- chasse MAJUSCULE	COMP.B	D3,#METAANY	JUMP',EQ 60$	COMP.B	D3,#METAONE	JUMP',EQ 60$	COMP.B	D3,#'P	JUMP',EQ 60$	COMP.B	D3,#'F		; prop/fix ?	JUMP,NE	85$		; non => 85$	TSET.L	D4:#7		; D4 <-- style fixe60$:	CLR.W	D5		; D5 <-- futur taille	LOAD.B	D3,(A3)	COMP.B	D3,#METAANY	JUMP',EQ 80$	COMP.B	D3,#METAONE	JUMP',EQ 80$70$:	CLR.W	D3	LOAD.B	D3,(A3+)	; D3 <-- digit pour taille	JUMP',EQ 80$	COMP.B	D3,#CR		; fin ?	JUMP',EQ 80$		; oui => 80$	COMP.B	D3,#SPACE	JUMP',EQ 80$	COMP.B	D3,#'.	JUMP',EQ 80$	COMP.B	D3,#'0		; chiffre ?	JUMP',LO 85$		; non => 85$	COMP.B	D3,#'9	JUMP',HI 85$	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D5,#10		; D5 <-- "pousse" d'un digit	ADD.W	D5,D3		; D5 <-- nouveau digit	JUMP	70$80$:	COMP.W	D5,#99.		; taille trop grande ?	JUMP',HI 85$		; oui => 85$				; non =>	LOAD.B	D3,D1		; D3 <-- fonte	CLR.W	D7		; D7 <-- ok	JUMP'	90$85$:	LOAD.W	D7,#ERLSYN	; D7 <-- erreur de syntaxe90$:	POPM.L	D0,D1,A3	RET;--------\\; _TEXTGC >;========/; Donne le texte correspondant  un gencar.;;	A4 (in)           A4 (out);	 |                 |;	\|/               \|/;	 Times        TRP14;	 SanFransisco SFP23;	 etc.;	 <-----------><--->;	       13       5;; Ne fonctionne pas avec les gencars soft (bit 2^7 de la fonte  1) !; in	D3.L	gencar (-fst);	D2.W	mode;		  2^0=1  -->  seulement la fonte (13 caractres);		  2^1=1  -->  seulement "fsctt" (5 caractres);	A4.L	^buffer;	D4.W	lg du buffer; out	A4.L	^plus loin; mod	D7.W, A4.L_TEXTGC:	PUSHM.L	D0..D5,A3	LOAD.W	D0,D2		; D0 <-- mode	LOAD.L	D1,D3		; D1 <-- gencar (-fst)	TEST.L	D0:#1		; seulment "fsctt" ?	JUMP,BS 20$		; oui => 20$; Affiche le nom de la fonte, en clair si possible.	LOAD.W	D5,#13		; D5 <-- longueur	CALL	SNGCINFO	; A3 <-- ^nom (fs<TAB>"nom"<CR>)	JUMP',NE 16$	ADD.L	A3,#2	COMP.B	(A3+),#TAB	JUMP',NE 16$	COMP.B	(A3+),#'"	JUMP',NE 16$14$:	LOAD.B	D3,(A3+)	JUMP',EQ 18$	COMP.B	D3,#CR	JUMP',EQ 18$	COMP.B	D3,#'"	JUMP',EQ 18$	DEC.W	D4	JUMP,NS 90$	LOAD.B	(A4+),D3	; buffer <-- nom de la fonte	DEC.W	D5	JUMP,NE 14$	JUMP'	20$16$:	SWAP.W	D3	DEC.W	D4	JUMP,NS 90$	LOAD.B	(A4+),D3	; buffer <-- lettre de la fonte	DEC.W	D518$:	DEC.W	D4	JUMP,NS 90$	LOAD.B	(A4+),#SPACE	; buffer <-- efface la fin du nom	DEC.W	D5	JUMP,NE 18$; Affiche le nom complet du gencar.20$:	TEST.L	D0:#0		; seulement la fonte ?	JUMP,BS 90$		; oui => 90$	LOAD.L	D3,D1		; D3 <-- "-fst"	SWAP.W	D3		; D3 <-- "f"	AND.B	D3,#H'7F	DEC.W	D4	JUMP,NS 90$	LOAD.B	(A4+),D3	; buffer <-- fonte	LOAD.L	D3,D1		; D3 <-- "-fst"	SR.W	D3,#8		; D3 <-- "s"	AND.B	D3,#H'7F	; D3 <-- style	DEC.W	D4	JUMP',NS 90$	LOAD.B	(A4+),D3	; buffer <-- style	LOAD.B	D3,#'P	TEST.L	D1:#8+7	JUMP',BC 40$	LOAD.B	D3,#'F40$:	DEC.W	D4	JUMP',NS 90$	LOAD.B	(A4+),D3	; buffer <-- chasse	CLR.L	D3	LOAD.B	D3,D1		; D3 <-- "000t"	JUMP',EQ 50$	DIV.WU	D3,#10	ADD.B	D3,#'0	DEC.W	D4	JUMP',NS 90$	LOAD.B	(A4+),D3	; buffer <-- dizaines taille	SWAP.W	D3	ADD.B	D3,#'0	DEC.W	D4	JUMP',NS 90$	LOAD.B	(A4+),D3	; buffer <-- units taille	JUMP'	90$50$:	LOAD.B	(A4+),#'.	LOAD.B	(A4+),#'.	; buffer <-- ".." si taille 0090$:	POPM.L	D0..D5,A3	CLR.W	D7		; retour EQ	RET;--------\\; _GTABGC >;========/; Donne le pointeur au contenu de SMA_GENC.INFO en mmoire.; in	-; out	A3.L	^contenu de SMA_GENC.INFO;	D7.W	erreur; mod	D7.W, A3.L_GTABGC:	PUSH.L	A0	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales; Lit SMA_GENC.INFO en mmoire si ce n'est pas dj fait.	TEST.L	(A0)+OPGCIN	; SMA_GENC.INFO dj en mmoire ?	JUMP',NE 20$		; oui => 20$	CALL	RDGCINFO	; lit SMA_GENC.INFO en mmoire	JUMP',NE 90$20$:	LOAD.L	A3,(A0)+OPGCIN	; A3 <-- ^contenu de SMA_GENC.INFO	LOAD.L	A3,#(A3)+LNG	; A3 <-- ^texte90$:	POP.L	A0	TEST.W	D7		; retour EQ/NE	RET;----------\\; _FLUSHNGC >;==========/; Vide compltement le contenu de SMA_GENC.INFO en mmoire.; in	-; out	-; mod	D7.W_FLUSHNGC:	PUSHM.L	D1,D4,A0,A1,A4	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	TEST.L	(A0)+OPGCIN	; SMA_GENC.INFO dj en mmoire ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A4,(A0)+OPGCIN	LOAD.L	A1,(A0)+OCTMEM	LOAD.W	D1,#MTYPUSER	GESMEM	?GIVMEM		; libre l'ancien contenu de SMA_GENC.INFO	CLR.L	(A0)+OPGCIN	LOAD.L	D4,#LNG+NGLRES	; D4 <-- longueur pour en-tte et rserve	LOAD.L	A1,(A0)+OCTMEM	LOAD.W	D1,#MTYPUSER	GESMEM	?GETMEM		; demande mmoire pour SMA_GENC.INFO vide	JUMP,NE 90$	CLR.W	(A4)+ONGLGU	LOAD.W	(A4)+ONGLGT,#NGLRES	CLR.B	(A4)+LNG	; met le terminateur <0>	LOAD.L	(A0)+OPGCIN,A4	SET.B	(A0)+OMGCIN	; mise  jour de SMA_GENC.INFO ncessaire !90$:	POPM.L	D1,D4,A0,A1,A4	CLR.W	D7		; retour EQ	RET;--------\\; _ADDNGC >;========/; Ajoute une quivalence nom court ("fs" dans D3) avec nom complet (A4).; in	D3.L	gencar  ajouter (-fs-);	A4.L	^nom complet  ajouter; out	D7.W	erreur; mod	D7.W_ADDNGC:	PUSHM.L	A0,A2..A4	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales; Regarde s'il s'agit d'un nom d'exception.	LOAD.L	A3,#R16"TAGCINFO	CALL	SRCGCINFO	; A3 <-- ^ligne trouve	JUMP',EQ 90$; Lit SMA_GENC.INFO en mmoire si ce n'est pas dj fait.	TEST.L	(A0)+OPGCIN	; SMA_GENC.INFO dj en mmoire ?	JUMP',NE 20$		; oui => 20$	CALL	RDGCINFO	; lit SMA_GENC.INFO en mmoire	JUMP',NE 90$; Cherche s'il existe dj un nom court identique  celui qui doit; tre ajout. Si oui, regarde si le nom complet est le mme. Dans ce; cas, il n'y a rien  faire. Dans le cas contraire, supprime le nom; court existant pour le remplacer par le nouveau.20$:	LOAD.L	A3,(A0)+OPGCIN	; A3 <-- ^contenu actuel de SMA_GENC.INFO	LOAD.L	A3,#(A3)+LNG	; A3 <-- ^texte	CALL	SRCGCINFO	; A3 <-- ^ligne trouve	JUMP',NE 50$25$:	COMP.B	(A3+),#'"	; A3 <-- avance jusqu'aprs le premier "	JUMP,NE 25$	LOAD.L	A2,A430$:	COMP.B	(A2+),(A3+)	; noms complets identiques ?	JUMP,EQ 30$		; oui => 90$	TEST.B	(A2)-1		; non => 40$	JUMP',NE 40$	COMP.B	(A3)-1,#'"	JUMP',EQ 90$40$:	CALL	SUBGCINFO	; enlve dans SMA_GENC.INFO	JUMP',NE 90$; Ajoute le nouveau nom court - nom complet.50$:	CALL	ADDGCINFO	; ajoute dans SMA_GENC.INFO90$:	POPM.L	A0,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; _SUBNGC >;========/; Supprime une quivalence nom court ("fs" dans D3) avec nom complet.; in	D3.L	gencar  ajouter (-fs-); out	D7.W	erreur; mod	D7.W_SUBNGC:	PUSHM.L	A0,A3	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales; Regarde s'il s'agit d'un nom d'exception.	LOAD.L	A3,#R16"TAGCINFO	CALL	SRCGCINFO	; A3 <-- ^ligne trouve	JUMP',EQ 90$; Lit SMA_GENC.INFO en mmoire si ce n'est pas dj fait.	TEST.L	(A0)+OPGCIN	; SMA_GENC.INFO dj en mmoire ?	JUMP',NE 50$		; oui => 50$	CALL	RDGCINFO	; lit SMA_GENC.INFO en mmoire	JUMP',NE 90$; Supprime le nom court - nom complet.50$:	CALL	SUBGCINFO	; enlve dans SMA_GENC.INFO90$:	POPM.L	A0,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; SNGCINFO >;=========/; Cherche le nom complet d'un gencar, en fonction du nom court.; in	D3.L	gencar (-fst); out	A3.L	^nom (fs<TAB>"nom"<CR>);	D7.W	erreur; mod	D7.W, A3.LSNGCINFO:	PUSHM.L	A0,A4	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A3,#R16"TAGCINFO	CALL	SRCGCINFO	; A3 <-- ^ligne trouve	JUMP',EQ 90$; Lit SMA_GENC.INFO en mmoire si ce n'est pas dj fait.	TEST.L	(A0)+OPGCIN	; SMA_GENC.INFO dj en mmoire ?	JUMP',NE 20$		; oui => 20$	CALL	RDGCINFO	; lit SMA_GENC.INFO en mmoire	JUMP',NE 90$; Cherche la fonte/style dans SMA_GENC.INFO.20$:	LOAD.L	A3,(A0)+OPGCIN	; A3 <-- ^contenu de SMA_GENC.INFO	LOAD.L	A3,#(A3)+LNG	; A3 <-- ^texte	CALL	SRCGCINFO	; A3 <-- ^ligne trouve	JUMP',EQ 90$; Cherche un nouveau nom, puis ajoute-le dans SMA_GENC.INFO.	LOAD.L	A4,#(A0)+ONGCIN	; A4 <-- ^buffer	CALL	SFGCINFO	; lit le nom du gencar	CALL	ADDGCINFO	; ajoute dans SMA_GENC.INFO90$:	POPM.L	A0,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; SFGCINFO >;---------/; Cherche le nom d'un gencar en lisant son en-tte sur disque.; in	D3.L	gencar (-fst);	A4.L	^buffer pour nom; out	(A4)++	nom complet; mod	D7.WSFGCINFO:	PUSHM.L	D2..D4,D6,A3,A4	SUB.L	SP,#16	LOAD.L	D2,D3		; D2 <-- gencar (-fst)	LOAD.L	A3,SP		; A3 <-- ^buffer sur le stack	LOAD.B	(A3+),#'S	LOAD.B	(A3+),#'M	LOAD.B	(A3+),#'A	LOAD.B	(A3+),#'_	LOAD.L	D4,D3	SWAP.W	D4	AND.B	D4,#H'7F	LOAD.B	(A3+),D4	; buffer <-- fonte	LOAD.W	D4,D3	SR.W	D4,#8	AND.B	D4,#H'7F	LOAD.B	(A3+),D4	; buffer <-- style	LOAD.B	(A3+),#'P	; buffer <-- chasse	TEST.L	D3:#8+7	JUMP',BC 20$	LOAD.B	(A3)-1,#'F20$:	CLR.L	D4	LOAD.B	D4,D3	DIV.WU	D4,#10	ADD.B	D4,#'0	LOAD.B	(A3+),D4	; buffer <-- dizaine taille	SWAP.W	D4	ADD.B	D4,#'0	LOAD.B	(A3+),D4	; buffer <-- unit taille	LOAD.B	(A3+),#'.	LOAD.B	(A3+),#'G	LOAD.B	(A3+),#'E	LOAD.B	(A3+),#'N	LOAD.B	(A3+),#'C	CLR.B	(A3)	LOAD.L	A3,SP	LOAD.W	D3,#2^BOPRD!2^BOPSYS	FOS	?OPEN		; ouvre le fichier gencar	JUMP',NE 32$	CLR.W	D3	LOAD.L	D4,#256+OGCCNM	FOS	?SPOS		; va au dbut du nom	JUMP',NE 30$	LOAD.L	D4,#32	FOS	?RDBYTE		; lit le nom du gencar30$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier gencar	POP.W	D732$:	TEST.W	D7		; lecture du gencar ok ?	JUMP',NE 50$		; non => 50$	TEST.B	(A4)		; nom existe ?	JUMP',NE 90$		; oui => 90$50$:	LOAD.W	(A4),(A3)+4	; nom = "FS" !	CLR.B	(A4)+290$:	ADD.L	SP,#16	POPM.L	D2..D4,D6,A3,A4	RET;----------\\; SUBGCINFO >;----------/; Supprime une ligne  SMA_GENC.INFO, si elle existe.; in	D3.L	gencar  supprimer (-fs-); out	D7.W	erreur; mod	D7.WSUBGCINFO:	PUSHM.L	D4,A2..A4	LOAD.L	A2,(A0)+OPGCIN	; A2 <-- ^contenu actuel de SMA_GENC.INFO	LOAD.L	A3,#(A2)+LNG	; A3 <-- ^texte	CALL	SRCGCINFO	; A3 <-- ^ligne trouve	JUMP',NE 90$	LOAD.L	A4,A3	CLR.W	D420$:	INC.W	D4		; D4 <-- lg  supprimer	COMP.B	(A4+),#CR	JUMP,NE 20$	SUB.W	(A2)+ONGLGU,D440$:	LOAD.B	(A3+),(A4+)	; bouche le trou	JUMP,NE 40$	SET.B	(A0)+OMGCIN	; mise  jour de SMA_GENC.INFO ncessaire !90$:	POPM.L	D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; ADDGCINFO >;----------/; Ajoute une ligne  SMA_GENC.INFO, sans vrifier si elle est; dj dfinie !; in	D3.L	gencar  ajouter (-fs-);	A4.L	^nom complet  ajouter; out	A3.L	^nom (fs<TAB>"nom"<CR>);	D7.W	erreur; mod	D7.W, A3.LADDGCINFO:	PUSHM.L	D1..D4,A1,A2,A4,A5	LOAD.L	A5,A4		; A5 <-- ^nom complet	LOAD.L	A2,(A0)+OPGCIN	; A2 <-- ^contenu actuel de SMA_GENC.INFO	LOAD.L	A1,A4	LOAD.W	D4,#2+4+2	; 2=fs  4=<TAB>""<CR>  2=rserve20$:	INC.W	D4		; D4 <-- place ncessaire	TEST.B	(A1+)	JUMP,NE 20$	LOAD.W	D2,(A2)+ONGLGT	SUB.W	D2,(A2)+ONGLGU	; D2 <-- place restante	COMP.W	D4,D2		; reste assez de place ?	JUMP,LO 50$		; oui => 50$; Demande une nouvelle tranche mmoire plus grande que l'ancienne,; et transfert-zi le contenu de l'ancienne.	CLR.L	D4	LOAD.W	D4,(A2)+ONGLGU	ADD.W	D4,#LNG+NGLRES	LOAD.L	A1,(A0)+OCTMEM	LOAD.W	D1,#MTYPUSER	GESMEM	?GETMEM		; demande mmoire pour nouveau SMA_GENC.INFO	JUMP,NE 90$	SUB.W	D4,#LNG	LOAD.W	(A4)+ONGLGT,D4	SUB.W	D4,#NGLRES	LOAD.W	(A4)+ONGLGU,D4	LOAD.L	A2,A4		; A2 <-- ^nouveau contenu de SMA_GENC.INFO	LOAD.W	D4,(A2)+ONGLGU	SR.W	D4,#2		; D4 <-- /4 car .L	INC.W	D4		; D4 <-- +2 pour arrondir (+1 implicite car NMO)	LOAD.L	A4,#(A4)+LNG	; A4 <-- ^nouveau texte	LOAD.L	A1,(A0)+OPGCIN	LOAD.L	A1,#(A1)+LNG	; A1 <-- ^ancien texte40$:	LOAD.L	(A4+),(A1+)	; nouveau <-- ancien	DECJ.W,NMO D4,40$	LOAD.L	A4,(A0)+OPGCIN	LOAD.L	A1,(A0)+OCTMEM	LOAD.W	D1,#MTYPUSER	GESMEM	?GIVMEM		; libre mmoire pour ancien SMA_GENC.INFO	LOAD.L	(A0)+OPGCIN,A2; Ajoute le nouveau nom  la fin de SMA_GENC.INFO.50$:	LOAD.L	A1,#(A2)+LNG	; A1 <-- ^texte	ADD.W	A1,(A2)+ONGLGU	; A1 <-- ^fin de SMA_GENC.INFO	LOAD.L	A3,A1		; A3 <-- ^nom (fs<TAB>"nom"<CR>)	LOAD.L	D2,D3	SWAP.W	D2	AND.B	D2,#H'7F	; D2 <-- fonte	LOAD.B	(A1+),D2	; SMA_GENC.INFO <-- fonte	LOAD.W	D2,D3	SR.W	D2,#8	AND.B	D2,#H'7F	; D2 <-- style	LOAD.B	(A1+),D2	; SMA_GENC.INFO <-- style	LOAD.B	(A1+),#TAB	LOAD.B	(A1+),#'"54$:	LOAD.B	(A1+),(A5+)	; SMA_GENC.INFO <-- nom complet	JUMP,NE 54$	DEC.L	A1	LOAD.B	(A1+),#'"	LOAD.B	(A1+),#CR	CLR.B	(A1)	LOAD.L	D4,A1	SUB.L	D4,A3		; D4 <-- lg ajoute	ADD.W	(A2)+ONGLGU,D4	SET.B	(A0)+OMGCIN	; mise  jour de SMA_GENC.INFO ncessaire !	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4,A1,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; SRCGCINFO >;----------/; Cherche fonte/style dans un texte.; in	D3.L	gencar (-fs-);	A3.L	^texte o chercher; out	A3.L	^ligne trouve;	D7.W	erreur; mod	D7.W, A3.LSRCGCINFO:	PUSHM.L	D0..D2	LOAD.L	D1,D3	SWAP.W	D1	AND.B	D1,#H'7F	; D1 <-- fonte	LOAD.W	D2,D3	SR.W	D2,#8	AND.B	D2,#H'7F	; D2 <-- style	LOAD.B	D0,#CR		; D0 <-- pour trouver rapidement la ligne suivante	CLR.W	D7		; D7 <-- ok30$:	TEST.B	(A3)		; fin de SMA_GENC.INFO ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D1,(A3)		; fonte trouve ?	JUMP',NE 36$		; non => 36$	COMP.B	D2,(A3)+1	; style trouv ?	JUMP',EQ 90$		; oui => 90$	COMP.B	(A3)+1,#'*	JUMP',EQ 90$36$:	COMP.B	D0,(A3+)	; A3 <-- ^ligne suivante	JUMP,NE 36$	JUMP	30$40$:	LOAD.W	D7,#ERSYNT	; D7 <-- pas trouv90$:	POPM.L	D0..D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; _MAJNGC >;========/; Ecrit (ou met  jour) SMA_GENC.INFO si ncessaire.; in	-; out	D7.W	erreur; mod	D7.W_MAJNGC:	PUSHM.L	A0,A3,A4	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	CLR.W	D7		; D7 <-- ok	TEST.L	(A0)+OPGCIN	JUMP',EQ 90$	TEST.B	(A0)+OMGCIN	; mise  jour ncessaire ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A3,#R16"NMGCINFO	FOS	?DELETE	LOAD.L	A4,(A0)+OPGCIN	CALL	WRTXFILE	; crit le contenu de SMA_GENC.INFO	JUMP',NE 90$	CLR.B	(A0)+OMGCIN	; mise  jour plus ncessaire90$:	POPM.L	A0,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; RDGCINFO >;=========/; Lit (ou relit) SMA_GENC.INFO en mmoire.; in	-; out	D7.W	erreur; mod	D7.WRDGCINFO:	PUSHM.L	D1,A0,A1,A3,A4	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	TEST.L	(A0)+OPGCIN	JUMP',EQ 20$	LOAD.L	A4,(A0)+OPGCIN	LOAD.L	A1,(A0)+OCTMEM	LOAD.W	D1,#MTYPUSER	GESMEM	?GIVMEM		; libre l'ancien SMA_GENC.INFO	CLR.L	(A0)+OPGCIN20$:	LOAD.L	A3,#R16"NMGCINFO	CALL	RDTXFILE	; A4 <-- ^contenu de SMA_GENC.INFO	JUMP',NE 90$	LOAD.L	(A0)+OPGCIN,A4	CLR.B	(A0)+OMGCIN	; mise  jour pas (encore) ncessaire90$:	POPM.L	D1,A0,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; WRTXFILE >;=========/; Ecrit un texte entirement en mmoire sur disque.; La mmoire contenant le texte n'est pas libre.; in	A3.L	^nom du fichier de texte;	A4.L	^texte termin par <0>; out	D7.W	erreur; mod	D7.WWRTXFILE:	PUSHM.L	D3,D4,D6,A4,A3	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier de texte	JUMP',NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier de texte	JUMP',NE 90$	CLR.L	D4	LOAD.W	D4,(A4)+ONGLGU	; D4 <-- longueur utilise	LOAD.L	A4,#(A4)+LNG	; A4 <-- ^texte	FOS	?WRBYTE		; crit tout le texte	JUMP',NE 85$	FOS	?CLOSE	JUMP'	90$85$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier de texte	POP.W	D790$:	POPM.L	D3,D4,D6,A4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; RDTXFILE >;=========/; Lit entirement un fichier de texte en mmoire.; La mmoire contenant le texte est rserve sur le; compte de la librairie.; in	A3.L	^nom du fichier de texte;	A0.L	^variables globales; out	A4.L	^texte termin par <0>;	D7.W	erreur; mod	D7.W, A4.LRDTXFILE:	PUSHM.L	D1,D3,D4,D6,A1	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier de texte	JUMP',EQ 20$	COMP.W	D7,#ERFDNE	JUMP,NE 90$	LOAD.L	D4,#LNG+NGLRES	; D4 <-- longueur pour en-tte et rserve	LOAD.L	A1,(A0)+OCTMEM	LOAD.W	D1,#MTYPUSER	GESMEM	?GETMEM		; demande mmoire SMA_GENC.INFO vide	JUMP,NE 90$	CLR.W	(A4)+ONGLGU	LOAD.W	(A4)+ONGLGT,#NGLRES	CLR.B	(A4)+LNG	; met le terminateur <0>	JUMP	90$20$:	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; va  la fin	LOAD.L	D1,D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	LOAD.L	D4,D1		; D4 <-- longueur du texte	ADD.W	D4,#LNG+NGLRES	; D4 <-- place pour en-tte et rserve	LOAD.L	A1,(A0)+OCTMEM	LOAD.W	D1,#MTYPUSER	GESMEM	?GETMEM		; demande mmoire pour le texte	JUMP',NE 85$	SUB.W	D4,#LNG	LOAD.W	(A4)+ONGLGT,D4	SUB.W	D4,#NGLRES	LOAD.W	(A4)+ONGLGU,D4	LOAD.L	A4,#(A4)+LNG	FOS	?RDBYTE		; lit tout le texte	JUMP',NE 80$	CLR.B	(A4)+(D4.L)	; met le terminateur <0>	LOAD.L	A4,#(A4)-LNG	JUMP'	85$80$:	PUSH.W	D7	LOAD.L	A4,#(A4)-LNG	LOAD.L	A1,(A0)+OCTMEM	LOAD.W	D1,#MTYPUSER	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D785$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier de texte	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A1	TEST.W	D7		; retour EQ/NE	RETTAGCINFO:	.ASCII	/I*<TAB>"Icnes"<CR>/	.ASCII	/J*<TAB>"Icnes_U"<CR>/	.ASCII	/X*<TAB>"Utilisateur"<CR>/	.B	0NMGCINFO:	.ASCIZ	"#:SMA_GENC.INFO"	.EVEN	.END