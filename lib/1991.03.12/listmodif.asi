	.SBTTL	LISTMODIF;------------\\; _LIST_MODIF >;============/; Permet  l'utilisateur de dtruire, dplacer ou dupliquer un fichier.; in	A3.L	critre avec * et ? (.ext est quivalent  *.ext);	A4.L	^nom initial;	D2.W	mode d'ouverture pour la dbox;	D3.L	position centre (y;x) si BDBPOS dans D2.W;	D4.L	zro (pour l'instant); out	D7.W	erreur; mod	D7.W_LIST_MODIF:	PUSHM.L	D3,A3	LOAD.W	D3,#BIPERR	LIB	?BEEP	LOAD.L	A3,#R16"00$	DBOX_	TERROR		; affiche une erreur ...	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET00$:	.ASCII	"Veuillez utiliser le logiciel START<CR>"	.ASCII	"pour dtruire, dplacer ou dupliquer<CR>"	.ASCIZ	"des fichiers !"	.EVEN.IF 0	PUSHM.L	D0..D6,A0..A6	LOAD.L	A1,A4		; A1 <-- ^nom initial; Demande de la mmoire pour les variables internes  LIST_MODIF.	LOAD.L	D4,#LGMODIF	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE 99$	LOAD.L	A6,A4		; A6 <-- ^variables02$:	CLR.B	(A4+)		; met toutes les variables  zro	DEC.W	D4	JUMP,NE	02$	LOAD.W	(A6)+OMODM,D2	; mm. mode	LOAD.L	(A6)+OMODP,D3	; mm. position	LOAD.L	(A6)+OMODPC,A3	; mm. ^critre	LOAD.L	A3,#(A6)+OMODF105$:	LOAD.B	D3,(A1+)	JUMP',EQ 06$	COMP.B	D3,#CR	JUMP',EQ 06$	LOAD.B	(A3+),D3	; OMODF1 <-- fichier initial	JUMP	05$06$:	CLR.B	(A3); Ouvre le module "dbox" au cas o ce ne serait pas fait par le; programme principal.	LOAD.L	A3,#R16"NAMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN		; ouvre le module dbox	JUMP,NE 97$	LOAD.W	(A6)+OMODC,D1; Ouvre et dessine la dbox principale. Si le deuxime nom de fichier; ditable existe, dessine-le juste aprs !10$:	LOAD.L	A2,#R16"TDBOXMODIF	LOAD.W	D2,(A6)+OMODM	; D2 <-- mode	LOAD.L	D3,(A6)+OMODP	; D3 <-- position	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; D5 <-- canal	JUMP,NE 95$	TEST.B	(A6)+OMODF2	; deuxime nom de fichier existe ?	JUMP',EQ 14$		; non => 14$	LOAD.W	D2,#4		; oui =>	DBOX_	GETCO		; D3 <-- coordonne dans dbox	LIB	?SETCURS	LOAD.L	A3,#(A6)+OMODF2	LIB	?AFTEXT		; affiche le deuxime nom14$:	CLR.W	D2		; D2 <-- dite le premier fichier; Initialise A3/A4 en fonction du fichier ditable contenu dans D2.15$:	LOAD.L	A3,#(A6)+OMODF1	; A3 <-- ^premier fichier	TEST.W	D2	JUMP',EQ 16$	LOAD.L	A3,#(A6)+OMODF2	; A3 <-- ^deuxime fichier16$:	LOAD.L	A4,A317$:	TEST.B	(A4+)	JUMP,NE 17$	DEC.L	A4		; A4 <-- ^fin du nom; Boucle principale lorsque le fichier ditable n'a pas chang.20$:	LOAD.W	D3,D2		; D3 <-- rang fichier  diter (0..1)	DBOX_	MEDIT		; signal fichier  diter	DBOX_	EDIT		; attend action ...	LOAD.L	A1,A322$:	TEST.B	(A1+)	JUMP,NE	22$	CLR.B	(A1)-2		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEYMODIF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ 20$	COMP.W	D3,#F1		; DETRUIT ?	JUMP',EQ 40$	COMP.W	D3,#F4		; DEPLACE ?	JUMP,EQ 50$	COMP.W	D3,#F7		; DUPLIQUE ?	JUMP,EQ 60$	COMP.W	D3,#F10		; LISTE ?	JUMP,EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP',EQ 33$	COMP.W	D3,#FNCT	JUMP',EQ 35$	COMP.W	D3,#DEFINE	JUMP',EQ 36$	COMP.W	D3,#CR	JUMP',EQ 37$30$:				; erreur =>	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$31$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	15$33$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	20$35$:	CLR.W	D2		; D2 <-- dite le premier fichier	JUMP	15$36$:	LOAD.W	D2,#1		; D2 <-- dite le deuxime fichier	JUMP	15$37$:	TNOT.L	D2:#0		; D2 <-- change le fichier  diter	JUMP	15$40$:				; DETRUIT =>	CLR.W	D2	TEST.B	(A6)+OMODF1	; premier fichier existe ?	JUMP,EQ 31$		; non => 31$	INC.W	D2	TEST.B	(A6)+OMODF2	; deuxime fichier existe ?	JUMP,NE 31$		; oui => 31$	DBOX_	CLOSE		; ferme la DBOX	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	CALL	DOFILE1		; prpare le premier nom	LOAD.L	A3,#(A6)+OMODF1	; A3 <-- ^nom du fichier  dtruire	LOAD.L	A4,#(A6)+OMODAR	; A4 <-- ^buffer pour arguments	FOS	?ARGS		; fichier existe ?	JUMP,NE 90$		; non => 90$	LOAD.W	D2,(A6)+OMODM	; D2 <-- mode	LOAD.L	D3,(A6)+OMODP	; D3 <-- position	CALL	_LIST_DELETE	; demande s'il faut dtruire ?	JUMP,NE 10$	COMP.W	D3,#'O	JUMP,NE 10$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#(A6)+OMODF1	; A3 <-- ^nom du fichier  dtruire	FOS	?DELETE	JUMP	90$50$:				; DEPLACE =>	CLR.W	D2	TEST.B	(A6)+OMODF1	; premier fichier existe ?	JUMP,EQ 31$		; non => 31$	INC.W	D2	TEST.B	(A6)+OMODF2	; deuxime fichier existe ?	JUMP,EQ 31$		; non => 31$	DBOX_	CLOSE		; ferme la DBOX	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	CALL	DOFILE1		; prpare le premier nom	CALL	DOFILE2		; prpare le deuxime nom	CALL	IFRENAME	; "rename" possible ?	JUMP',EQ 55$		; oui => 55$	CALL	DOXFER		; transvase ...	JUMP,NE 90$	LOAD.L	A3,#(A6)+OMODF1	; A3 <-- ^nom du fichier  dtruire	FOS	?DELETE		; dtruit encore le premier fichier	JUMP	90$55$:				; RENOMME =>	LOAD.L	A3,#(A6)+OMODF1	LOAD.L	A4,#(A6)+OMODF2	FOS	?RENAME	JUMP,EQ 90$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE 90$		; non => 90$	LOAD.L	A3,#(A6)+OMODF2	; A3 <-- ^nom du fichier  dtruire	LOAD.W	D2,(A6)+OMODM	; D2 <-- mode	LOAD.L	D3,(A6)+OMODP	; D3 <-- position	CALL	_LIST_DELETE	; demande s'il faut dtruire ?	JUMP,NE 10$	COMP.W	D3,#'O	JUMP,NE 10$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	FOS	?DELETE	JUMP,NE 90$	LOAD.L	A3,#(A6)+OMODF1	LOAD.L	A4,#(A6)+OMODF2	FOS	?RENAME	JUMP	90$60$:				; DUPLIQUE =>	CLR.W	D2	TEST.B	(A6)+OMODF1	; premier fichier existe ?	JUMP,EQ 31$		; non => 31$	INC.W	D2	TEST.B	(A6)+OMODF2	; deuxime fichier existe ?	JUMP,EQ 31$		; non => 31$	DBOX_	CLOSE		; ferme la DBOX	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	CALL	DOFILE1		; prpare le premier nom	CALL	DOFILE2		; prpare le deuxime nom	CALL	DOXFER		; transvase ...	JUMP'	90$70$:				; LISTE =>	DBOX_	CLOSE		; ferme la DBOX	LOAD.L	A4,#(A6)+OMODF1	; A4 <-- ^buffer pour nom	LOAD.L	A3,(A6)+OMODPC	; A3 <-- ^critre de recherche (extension)	CLR.L	D4	LOAD.W	D2,(A6)+OMODM	; D2 <-- mode	LOAD.L	D3,(A6)+OMODP	; D3 <-- position	LIST_	DBOX		; liste puis choix selon dbox ...	JUMP	10$80$:				; ANNULE =>	DBOX_	CLOSE		; ferme la DBOX	JUMP'	95$90$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: remet la flche	POP.W	D7		; erreur ?	JUMP',EQ 95$		; non => 95$				; oui =>	COMP.W	D7,#ERKNO	; rponse "non" ?	JUMP,EQ 10$		; oui => 10$	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP	POP.W	D7	LOAD.W	D2,(A6)+OMODM	; D2 <-- mode	LOAD.L	D3,(A6)+OMODP	; D3 <-- position	DBOX_	MERROR		; affiche l'erreur ...	JUMP	10$95$:	PUSH.W	D7	LOAD.W	D1,(A6)+OMODC	LIB_	CLOSE		; ferme le module dbox	POP.W	D797$:	PUSH.W	D7	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire	POP.W	D799$:	POPM.L	D0..D6,A0..A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; DOFILE1 >;--------/; Prpare le premier nom de fichier.; in	-; out	-; mod	?DOFILE1:	LOAD.L	A3,#(A6)+OMODF1	LOAD.L	A4,(A6)+OMODPC	; A4 <-- ^extension	CLR.W	D3		; D3 <-- ne force pas	LIB	?ADDEXT	RET;--------\\; DOFILE2 >;--------/; Prpare le deuxime nom de fichier. Si le nom donn est uniquement; un nom d'unit et/ou de rpertoire, ajoute-lui le premier nom (sans; l'unit et/ou rpertoire bien sr).; in	-; out	-; mod	?DOFILE2:	LOAD.L	A3,#(A6)+OMODF210$:	LOAD.B	D3,(A3+)	JUMP',EQ 50$	COMP.B	D3,#':	JUMP,NE 10$	TEST.B	(A3)		; nom termin par ":" ?	JUMP,NE 10$		; non => 10$; Saute tous les "unit:" et "rep:" dans le premier nom.	LOAD.L	A4,#(A6)+OMODF1	CLR.W	D320$:	INC.W	D3	TEST.B	(A4+)	JUMP,NE 20$	INC.W	D325$:	DEC.W	D3	JUMP',EQ 30$	COMP.B	(-A4),#':	JUMP,NE 25$	INC.L	A4; Ajoute le premier nom dans le deuxime.30$:	LOAD.B	(A3+),(A4+)	JUMP,NE 30$50$:	LOAD.L	A3,#(A6)+OMODF2	LOAD.L	A4,(A6)+OMODPC	; A4 <-- ^extension	CLR.W	D3		; D3 <-- ne force pas	LIB	?ADDEXT	RET;---------\\; IFRENAME >;---------/; Vrifie s'il est possible de faire un RENAME au lieu d'un XFER.; in	-; out	EQ	RENAME au lieu de XFER possible; mod	?IFRENAME:	LOAD.L	A3,#(A6)+OMODF110$:	LOAD.B	D3,(A3+)	JUMP',EQ 15$	COMP.B	D3,#':	JUMP,NE 10$15$:	LOAD.L	A4,#(A6)+OMODF220$:	LOAD.B	D4,(A4+)	JUMP',EQ 25$	COMP.B	D4,#':	JUMP,NE 20$25$:	LOAD.W	D7,#1	COMP.B	D3,D4		; mmes terminateurs ?	JUMP',NE 90$		; non => 90$	CLR.W	D7	OR.B	D3,D4	JUMP',EQ 90$	LOAD.L	A3,#(A6)+OMODF1	LOAD.L	A4,#(A6)+OMODF2	LOAD.L	A2,#R16"LUTERM	; A2 <-- ^liste de terminateurs	LIB	?CPSTRING	; units/rpertoires ok ?90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; DOXFER  >;--------/; Transfert le premier fichier dans le deuxime.; in	-; out	D7.W	erreur; mod	?DOXFER:	CLR.W	(A6)+OMODCI	; pas encore de fichier en entre	CLR.W	(A6)+OMODCO	; pas encore de fichier en sortie	CLR.L	(A6)+OMODLB	; pas encore de buffer	LOAD.L	A3,#(A6)+OMODF1	LOAD.L	A4,#(A6)+OMODAR	; A4 <-- ^buffer pour arguments	FOS	?ARGS		; lit arguments fichier source	JUMP,NE 90$	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le premier fichier	JUMP,NE 90$	LOAD.W	(A6)+OMODCI,D610$:	LOAD.L	A3,#(A6)+OMODF2	LOAD.L	D3,(A6)+OMODAR+OBAATT ; D3 <-- arguments premier fichier	OR.W	D3,#2^BATTE!2^BATTM!2^BATTW	LOAD.W	D4,#TYPRAND	; D4 <-- type	FOS	?CREATE		; cre le deuxime fichier	JUMP',EQ 15$	COMP.W	D7,#ERFAEX	JUMP,NE 90$	CALL	_LIST_DELETE	; dtruit le deuxime fichier ?	JUMP,NE 90$	LOAD.W	D7,#ERKNO	COMP.W	D3,#'O	JUMP,NE 90$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	FOS	?DELETE	JUMP,NE 90$	JUMP	10$15$:	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le deuxime fichier	JUMP,NE 90$	LOAD.W	(A6)+OMODCO,D6	LOAD.W	D3,#16/3*2	; D3 <-- fraction	LOAD.L	D4,#256		; D4 <-- lg minimale	LOAD.L	D5,#256*100	; D5 <-- lg maximale	LOAD.W	D1,#MTYPCP	GESMEM	?GETPMEM	; demande buffer temporaire	JUMP,NE 90$	LOAD.L	(A6)+OMODLB,D420$:	LOAD.L	A3,#(A6)+OMODF1	; A3 <-- ^nom premier fichier (si erreur)	LOAD.L	D4,(A6)+OMODLB	LOAD.W	D6,(A6)+OMODCI	FOS	?RDBYTE		; lit une tranche	JUMP',EQ 40$	COMP.W	D7,#EROUTF	JUMP,NE 90$	CLR.W	D7	TEST.L	D4		; qq chose lu ?	JUMP',EQ 90$		; non => 90$40$:	LOAD.L	A3,#(A6)+OMODF2	; A3 <-- ^nom deuxime fichier (si erreur)	LOAD.W	D6,(A6)+OMODCO	FOS	?WRBYTE		; crit une tranche	JUMP,EQ 20$90$:	TEST.L	(A6)+OMODLB	JUMP',EQ 92$	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer	POP.W	D792$:	LOAD.W	D6,(A6)+OMODCO	JUMP',EQ 94$	PUSH.W	D7	LOAD.B	D3,(A6)+OMODAR+OBACH+0 ; D3 <-- heure fichier source	SL.L	D3,#8	LOAD.B	D3,(A6)+OMODAR+OBACH+1 ; D3 <-- minute fichier source	SL.L	D3,#8	LOAD.B	D3,(A6)+OMODAR+OBACH+2 ; D3 <-- seconde fichier source	LOAD.B	D4,(A6)+OMODAR+OBACD+0 ; D4 <-- jour fichier source	SL.L	D4,#8	LOAD.B	D4,(A6)+OMODAR+OBACD+1 ; D4 <-- mois fichier source	SL.L	D4,#8	LOAD.B	D4,(A6)+OMODAR+OBACD+2 ; D4 <-- anne fichier source	FOS	?CLOMDC		; ferme le deuxime fichier	POP.W	D794$:	LOAD.W	D6,(A6)+OMODCI	JUMP',EQ 96$	PUSH.W	D7	FOS	?CLOSE		; ferme le premier fichier	POP.W	D796$:	TEST.W	D7		; retour EQ/NE	RET; Tables; ------TDBOXMODIF:	.W	10$-TDBOXMODIF	.W	20$-TDBOXMODIF	.W	0,010$:	.B	ODBTEXT	.ASCIZ	" Nom du fichier  modifier :"	.B	ODBCR,ODBCR	.B	ODBFILE,LGMFILE!2^7,0,FNCT,TDBNORM	.B	ODBBOX,0,F10,TDBNORM	.ASCIZ	"LISTE"	.B	ODBCR,ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	" Nouveau nom :"	.B	ODBCR,ODBCR	.B	ODBFILE,LGMFILE!2^7,0,DEFINE,TDBNORM	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" DETRUIT "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" DEPLACE "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,F7,TDBMEV	.ASCIZ	" DUPLIQUE "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Dtruit"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Dplace"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Duplique"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Liste"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"		;     ;     ;     ;	.EVENTKEYMODIF:	.W	F1,F2,F3,0		DOKF1-TKEYMODIF	.W	F4,F5,F6,0		DOKF4-TKEYMODIF	.W	F7,F8,F9,0		DOKF7-TKEYMODIF	.W	F10,F11,F12,0		DOKF10-TKEYMODIF	.W	END,F13,F14,F15,0	DOAN-TKEYMODIF	.W	KEYMGP,KEYMMP,KEYMDP,0	DOMP-TKEYMODIF	.W	KEYMGR,KEYMMR,KEYMDR,0	DOMR-TKEYMODIF	.W	0.ENDIF	.END