\define g_Fond:\nef11;\define g_ev:\n(bf)09;\define g_titre:\m(f)17;\define g_it:\n(if)07;\g_Fond;	.TITLE	 	STRETCH.ASS;	--------------------------------------;		(C) 1987 - Francis Klay;	--------------------------------------;	--------------------------------------;		(C) 1991 - Denis Dumoulin;	--------------------------------------	.PROC		M68000	 		; Mnmonics CALM	.BASE	 	10'10			; Base 10 par dfaut;	.LAYOUT		HEX			; Listing en hexadcimal; Numros des appels; ------------------	.SYSCALL.16	ST_ST_RECT		= 	16'A620			; Dforme un rectangle lastiqueST_FIRST	= 	ST_RECT			; Premier appelST_LAST		=	ST_RECT 		; Dernier appel; Dclaration constante :; -----------------------ST_LGTRECT	= 	256			; Lg table pour transf rectangle;--------------\\;   ST_RECT	>;==============/; Transformation d'un rectangle lastique. Si un paramtre de la table; est incorrecte la routine est sans effet.; in	A0.32		 ^Table paramtres de transformation.; out	D7.16		 #1 si des paramtres sont incorrects; mod	D7.16, F; Type de transformation :; ------------------------;;;   (S0x,S0y)        (S1x,S1y)     (D0x,D0y) (D1x,D1y);	o----------------o             o---------o;       |                |     ---\    |          \;       |                |     ---/    |           \;       o----------------o             o------------o;   (S3x,S3y)        (S2x,S2y)     (D3x,D3y)     (D2x,D2y);	    rectangle		->	 quelconque;; ATTENTION; =========; avec le nouveau module, il faut mettre OSTRTYP=#1 alors tous les points; donns le sont  l'intrieur de la forme; par ex. petit carr de 2*2 origine S0=(0,0) limite S2=(1,1); zoom de ce petit carr 8*8 D0=(0,0) et D2=(7,7); avec OSTRTYP = #0 l'opration se fait sans atteindre les limites; avec OSTRTYP = #2 il est possible de stretcher des images couleurs;		    avec 4 bits par pixel (ou 1 bit par pixel = noir/blanc); Format de la table :; --------------------.LOC	0OSTRTYP:	.BLK.16		1		; Type de transformation   (new, #1)						; #2 pour COULEUROSTROP:		.BLK.16		1		; Type opration sur point (inutilis, #0)OSTRSPT:	.BLK.32		1		; ^matrice sourceOSTRSDX:	.BLK.16		1		; Dim X matrice source (bytes)OSTRS0:		.BLK.32		1		; S0 (y,x)OSTRS2:		.BLK.32		1		; S2 (y,x)OSTRDPT:	.BLK.32		1		; ^matrice destinationOSTRDDX:	.BLK.16		1		; Dim X matrice destination (bytes)OSTRD0:		.BLK.32		1		; D0 (y,x)OSTRD1:		.BLK.32		1		; D1 (y,x)OSTRD2:		.BLK.32		1		; D2 (y,x)OSTRD3:		.BLK.32		1		; D3 (y,x)OSTPIXEL:	.BLK.16		1		; nombre de bit par pixel si type = #2						; valeurs possibles : 4 (couleur) et 1 (noir/blanc)OSTTABLCOUL:	.BLK.32		1		; ^table de mixage des couleurs (voir **)						; une table par dfaut est mise si #0.LOC	ST_LGTRECT				; Zone utilise par la routine						; (initialisation pas ncessaire).; (**) La table pointe par OSTTABLCOUL est forme de 256 octets formant une matrice 16 x 16; chaque octet ne doit contenir qu'un nibble 16'00  16'0F fixant la couleur rsultant  l'cran.; La couleur du point plac  l'cran dpend de la couleur du point source (ssss) et; de la couleur du point dj plac  destination (dddd) par l'accs  la table; en concatnant les 2 nibbles (ddddssss) -> new dddd;; La table par dfaut transforme :; 0000ssss -> ssss	dddd0000 -> dddd	1111ssss -> 1111	dddd1111 -> 1111; soit : blanc + couleur -> couleur	couleur + noir -> noir; pour les autres cas la couleur du fond reste inchange..END