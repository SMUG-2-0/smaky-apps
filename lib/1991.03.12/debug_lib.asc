	.TITLE	DEBUG_LIB	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcima	.REF	SM8		; df diverses	.REF	NTREL		; df noyau temps rel	.REF	GESMEM		; df gestionnaire de mmoire	.REF	FOS		; df file operating system	.REF	LIB		; df librairie	.REF	DRIVERS		; df drivers	.REF	DOLIB; Constantes; ----------LIB_DEBUG=	H'A108		; code appel spcialNBT	=	2^4		; nombre d'appels par tranche; Dbut du code; -------------	.LOC	0START:	LIB	?OPELIB	LIB	?AFTIM	.B	NOCURS,CR	.ASCIZ	"DEBUG_LIB rev 5.2<CR><CR>"	.EVEN	LOAD.W	D3,#-1	LIB	?DISWKEY	LIB	?BUCAR	LIB	?AFCR	CALL	AFTABLE0	LIB	?AFCR	CALL	AFTABLE1	LIB	?AFCR	LIB	?NOBUCAR	LIB	?AFTIM	.ASCIZ	"Appuyez sur une touche ..."	.EVEN	LIB	?GETCAR		; attend une touche	LOAD.B	D3,#EOP	LIB	?AFCAR	LIB	?CLOLIB	FOS	?STOPAFTABLE0:	LIB_	DEBUG	LOAD.L	A0,A3	LOAD.W	D0,#(4096/NBT)/3210$:	LOAD.W	D1,#3220$:	LOAD.B	D4,(A0+)	JUMP,EQ	40$	LIB	?AFX2	JUMP	50$40$:	LIB	?AFTIM	.ASCIZ	"--"	.EVEN50$:	DEC.W	D1	JUMP,NE	20$	LIB	?AFCR	DEC.W	D0	JUMP,NE	10$	RETAFTABLE1:	LIB	?AFTIM	.ASCII	"      ^base   first last  use name<CR>"	.ASCIZ	"--------------------------------------------<CR>"	.EVEN	LOAD.W	D4,#H'1234	LIB_	DEBUG	COMP.W	D4,#H'1234	JUMP,EQ 80$	LOAD.L	A0,A4	LOAD.W	D0,D4	CLR.W	D110$:	LOAD.L	D4,(A0+)	JUMP,EQ	50$	COMP.L	D4,#-1	JUMP,EQ 50$	LOAD.L	A4,D4	LOAD.B	D4,D1	LIB	?AFX2	LIB	?AFTIM	.ASCIZ	":  "	.EVEN	LOAD.L	D4,A4	LIB	?AFX8	LIB	?AFSPACE	LIB	?AFSPACE	LOAD.W	D4,(A4)+OHLFCO	LIB	?AFX4	LIB	?AFSPACE	LOAD.W	D4,(A4)+OHLLCO	LIB	?AFX4	LIB	?AFSPACE	LIB	?AFSPACE	LOAD.B	D4,(A5+)	LIB	?AFX2	LIB	?AFSPACE	LIB	?AFSPACE	LOAD.L	A3,#(A4)+OHLNAM	LIB	?AFTEXT	LIB	?AFCR50$:	ADD.W	D1,#4	DEC.W	D0	JUMP,NE	10$	JUMP	90$80$:	LIB	?AFTIM	.ASCIZ	"<CR><TAB>*** Librairie trop ancienne ***<CR><CR>"	.EVEN90$:	RET	.END	START