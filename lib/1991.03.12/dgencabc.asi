	.SBTTL	DGENCABC;----------\\; DISPLAYGC >;==========/; Affiche "Abc" dans la zone avec le caractre rel.; in	D0.L	fanions; out	-; mod	D7.WDISPLAYGC:	TEST.L	D0:#BFAAFF	; affiche les caractres rels ?	JUMP',BS AFF$		; oui => AFF$	LOAD.W	(A6)+OMDLGR,#-1	JUMP	DISCLEARAFF$:	TEST.L	D0:#BFAANAL	; gencar "analytique" ?	JUMP,BS DISANAL		; oui => DISANAL	JUMP	DISSOFT		; non => DISSOFT;--------\\; DISSOFT >;--------/; Affiche un caractre standard, avec ou sans construction.; in	D0.L	fanions; out	-; mod	D7.WDISSOFT:	PUSHM.L	D0..D5,A3,A4	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	CALL	DISCLEAR	; efface l'emplacement; Lit si ncessaire le gencar rduit.	TEST.L	(A6)+OMDPGR	; y'a-t-il un gencar rduit dj lu ?	JUMP',EQ 20$		; non => 20$	LOAD.W	D4,(A5)+OSLCYS	COMP.W	D4,(A6)+OMDLGR	; est-ce que celui qui est lu est le bon ?	JUMP',EQ 25$		; oui => 25$	LOAD.L	A4,(A6)+OMDPGR	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le mauvais gencar rduit	CLR.L	(A6)+OMDPGR20$:	CALL	DISRD3CHAR	; A4 <-- ^gencar rduit	JUMP,NE 80$	LOAD.L	(A6)+OMDPGR,A4	LOAD.W	(A6)+OMDLGR,(A5)+OSLCYS25$:	LOAD.L	A4,(A6)+OMDPGR	; A4 <-- ^gencar rduit	TEST.L	D0:#BGCBOLD	JUMP',BS 40$	TEST.L	D0:#BGCITAL	JUMP',BS 40$	TEST.L	D0:#BGCOUTL	JUMP',BS 40$	TEST.L	D0:#BGCSHAD	JUMP',BS 40$	TEST.L	D0:#BGCLARG	JUMP',BS 40$	TEST.L	D0:#BGCDOUB	JUMP',BS 40$	CALL	DISSHOW		; affiche le gencar rduit	JUMP	90$; Construit le gencar soft d'aprs le gencar rduit.40$:	LOAD.L	A3,(A6)+OMDPLI	; A3 <-- ^liste des gencars	LOAD.W	D4,(A5)+OSLCYS	MUL.WU	D4,#3	ADD.L	A3,D4		; A3 <-- ^gencar slectionn	LOAD.L	D4,D0		; D4 <-- style soft	LOAD.B	D0,(A3)+0	; D0 <-- fonte	LOAD.B	D1,(A3)+1	; D1 <-- style/chasse	LOAD.B	D2,(A3)+2	AND.B	D2,#H'7F	; D2 <-- taille	LOAD.B	D3,D0	LOAD.B	D5,D2	TEST.L	D4:#BFADOUB	JUMP',BC 44$	SL.B	D5,#1		; D5 <-- taille *244$:	AND.L	D4,#H'FF	GENCAR_	CREATE		; A4 <-- ^gencar soft construit	JUMP',EQ 50$	COMP.W	D7,#ERLMNO	; module pas ouvert ?	JUMP',NE 80$		; non => 80$	PUSHM.L	D1,D3	LOAD.L	A3,#R16"NMGENC	; A3 <-- ^nom du module gencar	LOAD.W	D3,#GENCAR_FIRST; D3 <-- code du premier appel	LIB_	OPEN		; charge le module GENCAR	POPM.L	D1,D3	JUMP',NE 80$	GENCAR_	CREATE		; A4 <-- ^gencar soft construit	JUMP',NE 80$50$:	CALL	DISSHOW		; affiche le gencar soft construit	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour gencar construit	JUMP'	90$80$:	CALL	DISERROR	; affiche une grande croix90$:	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	POPM.L	D0..D5,A3,A4	RET;--------\\; DISSHOW >;--------/; Affiche les 3 premiers caractres du gencar rduit.; in	A4.L	^gencar  afficher; out	-; mod	D7.WDISSHOW:	PUSHM.L	D2..D4,A3	LOAD.W	D4,(A6)+OMDDIZ+0	SUB.W	D4,(A4)+OGCMHD	JUMP',NC 22$	CLR.W	D422$:	SR.W	D4,#1	ADD.W	D4,(A6)+OMDPOZ+0	SWAP.W	D4	CLR.W	D4	LOAD.B	D4,(A4)+OGCWID+0	CLR.W	D3	LOAD.B	D3,(A4)+OGCWID+1	ADD.W	D4,D3;	CLR.W	D3	LOAD.B	D3,(A4)+OGCWID+2	ADD.W	D4,D3		; D4 <-- largeur totale pour "Abc"	SUB.W	D4,(A6)+OMDDIZ+2	NEG.W	D4	JUMP',NC 24$	CLR.W	D424$:	SR.W	D4,#1	ADD.W	D4,(A6)+OMDPOZ+2	LOAD.L	A3,#(A4)+OGCWID	; A3 <-- ^table des largeurs	CLR.W	D350$:	CALL'	DISCAR		; affiche un caractre	CLR.W	D2	LOAD.B	D2,(A3+)	; D2 <-- largeur du caractre	ADD.W	D4,D2		; D4 <-- position suivante	INC.W	D3		; D3 <-- caractre suivant	COMP.W	D3,#3		; encore un ?	JUMP,LO 50$		; non => 50$90$:	POPM.L	D2..D4,A3	RET;--------\\; DISCAR  >;--------/; Affiche un caractre.; in	D3.W	code du caractre;	D4.L	position (y;x);	A4.L	^gencar; out	-; mod	D7.WDISCAR:	PUSHM.L	D2..D4,A2,A3	LOAD.W	D2,(A6)+OMDPOZ+2	ADD.W	D2,(A6)+OMDDIZ+2 ; D2 <-- max  ne pas dpasser	LOAD.L	A3,#(A6)+OMDDIS	LOAD.W	(A3)+0,#DRAWRASTER	SUB.W	D2,D4		; D2 <-- largeur maximale	JUMP,LE 90$		; dpasse compltement  droite => 90$	SWAP.W	D4	LOAD.L	(A3)+12,D4	CLR.L	(A3)+16	CLR.W	(A3)+20	CLR.W	D4	LOAD.B	D4,(A4)+OGCMWB	LOAD.W	(A3)+10,D4	SL.W	D4,#3	COMP.W	D4,D2		; dpasse  droite ?	JUMP',LS 30$		; non => 30$	LOAD.W	D4,D2		; D4 <-- largeur maximale30$:	LOAD.W	(A3)+22,D4	LOAD.W	D4,(A4)+OGCMHD	COMP.W	D4,(A6)+OMDDIZ+0 ; dpasse en bas ?	JUMP',LS 32$		 ; non => 32$	LOAD.W	D4,(A6)+OMDDIZ+0 ; D4 <-- hauteur maximale32$:	LOAD.W	(A3)+24,D4	CLR.L	(A3)+2	LOAD.L	A2,#(A4)+OGCWID+(4*3)	MUL.WU	D3,(A4)+OGCMSB	ADD.L	A2,D3	LOAD.L	(A3)+6,A2	LOAD.B	(A3)+26,#SETDOT	LOAD.W	D3,#1+26	LIB	?STRING		; affiche le caractre90$:	POPM.L	D2..D4,A2,A3	RET;-----------\\; DISRD3CHAR >;-----------/; Cre le gencar rduit (3 caractres) en lisant le gencar complet.; En fait, le gencar cr contient 4 caractres, pour que les tables; (l,h1,h2) soient d'une logueur paire, car GENCAR n'aime pas du; tout autrement !; in	-; out	A4.L	^gencar rduit;	D7.W	erreur; mod	D7.W, A4.LDISRD3CHAR:	PUSHM.L	D0..D6,A1..A3; Demande de la mmoire pour l'en-tte et la table des largeurs.	LOAD.L	D4,#OGCDATA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour en-tte	JUMP,NE 95$	LOAD.L	A1,A4		; A1 <-- ^buffer pour en-tte; Ouvre le fichier gencar et lit l'en-tte et la table de chasse.	EX.L	A0,A1	CALL	DISNAME		; A3 <-- ^nom du fichier gencar	EX.L	A1,A0	LOAD.W	D3,#2^BOPRD!2^BOPSYS	FOS	?OPEN		; ouvre le gencar	JUMP,NE 90$	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute l'en-tte binaire	JUMP,NE 85$;	LOAD.L	A4,A1	LOAD.L	D4,#OGCDATA	FOS	?RDBYTE		; lit l'en-tte du gencar + table des largeurs	JUMP,NE 85$; Cre un gencar rduit comportant juste les 3 caractres "Abc".	LOAD.W	D4,(A1)+OGCMSB	MUL.WU	D4,#4	ADD.L	D4,#OGCWID+(4*3)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour gencar rduit	JUMP,NE 85$	LOAD.L	A2,A4		; A2 <-- ^buffer pour gencar rduit	LOAD.L	A3,A1;	LOAD.L	A4,A2	LOAD.W	D4,#(OGCWID/4)-120$:	LOAD.L	(A4+),(A3+)	; gencar rduit <-- en-tte	DECJ.W,NMO D4,20$	CLR.B	(A2)+OGCFCA	LOAD.B	(A2)+OGCLCA,#4-1	LOAD.L	A3,#(A6)+OMDDIS	LOAD.L	(A3),#H'1000000*'A+H'10000*'b+H'100*'c	LOAD.B	D2,(A1)+OGCFCA	; gencar normal de 128 caractres ?	JUMP',NE 31$		; non => 31$	COMP.B	(A1)+OGCLCA,#127	JUMP',EQ 33$31$:	INC.B	D2	LOAD.B	(A3),D2	INC.B	D2	LOAD.B	(A3)+1,D2	INC.B	D2	LOAD.B	(A3)+2,D233$:	CLR.W	D234$:	LOAD.B	D1,(A3+)	JUMP',EQ 36$	CALL	DISXFER		; gencar rduit <-- une matrice	JUMP',NE 80$	INC.W	D2	JUMP	34$36$:	LOAD.L	A4,A2		; A4 <-- ^gencar rduit	JUMP'	85$80$:	PUSHM.L	D7,A4	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour gencar rduit	POPM.L	D7,A485$:	PUSH.W	D7	FOS	?CLOSE		; ferme le gencar	POP.W	D790$:	PUSHM.L	D7,A4	LOAD.L	A4,A1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour en-tte	POPM.L	D7,A495$:	POPM.L	D0..D6,A1..A3	RET;--------\\; DISXFER >;--------/; Transfert une matrice du gencar original dans le gencar rduit.; in	D1.B	code du caractre original (0..127);	D2.W	code du caractre rduit (0..2);	A1.L	^en-tte originale;	A2.L	^en-tte rduite;	D6.W	canal du fichier gencar; out	D7.W	erreur; mod	D7.WDISXFER:	PUSHM.L	D1..D4,A4	LOAD.W	D7,#1	SUB.B	D1,(A1)+OGCFCA	JUMP,LO 90$	AND.W	D1,#H'FF	PUSHM.L	A1,A2	LOAD.L	A1,#(A1)+OGCWID	LOAD.L	A2,#(A2)+OGCWID	LOAD.B	(A2)+(D2.W),(A1)+(D1.W)	POPM.L	A1,A2	LOAD.W	D4,D1	MUL.WU	D4,(A1)+OGCMSB	CLR.W	D3	LOAD.B	D3,(A1)+OGCLCA	SUB.B	D3,(A1)+OGCFCA	INC.W	D3		; D3 <-- nb total de caractres	MUL.WU	D3,#3	ADD.L	D4,D3	ADD.L	D4,#256+OGCWID	CLR.W	D3	FOS	?SPOS		; positionne au dbut de la matrice	JUMP',NE 90$	CLR.L	D4	LOAD.W	D4,(A2)+OGCMSB	LOAD.L	A4,#(A2)+OGCWID+(4*3)	MUL.WU	D2,D4	ADD.L	A4,D2	FOS	?RDBYTE		; lit la matrice du caractre90$:	POPM.L	D1..D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DISANAL >;--------/; Affiche un caractre analytique, construit.; in	-; out	-; mod	D7.WDISANAL:	PUSHM.L	D0..D4,A4	LOAD.L	A4,#(A6)+OMDNTA	; A4 <-- ^taille en ASCII	CALL	GETANUM		; D4 <-- taille dite	LOAD.W	D2,D4		; D2 <-- taille dite	LOAD.W	D4,(A5)+OSLCYS	COMP.W	D4,(A6)+OMDLGR	; dj affich ?	JUMP',NE 20$		; non => 20$	COMP.W	D2,(A6)+OMDLGT	; dans la mme taille ?	JUMP',EQ 90$		; oui => 90$20$:	LOAD.W	(A6)+OMDLGR,D4	LOAD.W	(A6)+OMDLGT,D2	CALL	DISCLEAR	; efface l'emplacement	COMP.W	D2,#5		; trs petite taille ?	JUMP',LO 80$		; oui => 80$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A4,(A6)+OMDPLI	; A4 <-- ^liste des gencars	LOAD.W	D4,(A5)+OSLCYS	MUL.WU	D4,#3	ADD.L	A4,D4		; A4 <-- ^gencar slectionn	LOAD.B	D0,(A4)+0	; D0 <-- fonte	CLR.L	D1	LOAD.B	D1,(A4)+1	; D1 <-- style/chasse	LOAD.L	D3,(A6)+OMDPOZ	; D3 <-- position	LOAD.L	D4,(A6)+OMDDIZ	; D4 <-- dimensions	XCAR_	SHOW		; affiche "Abc"	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	JUMP'	90$80$:	CALL	DISERROR	; affiche une grande croix90$:	POPM.L	D0..D4,A4	RET;---------\\; DISERROR >;---------/; Effiche une erreur dans l'emplacement pour le caractre.; in	-; out	-; mod	D7.WDISERROR:	PUSHM.L	D2..D4	LOAD.W	D2,#SETDOT	LOAD.L	D3,(A6)+OMDPOZ	LOAD.L	D4,(A6)+OMDDIZ	LIB	?DRSEG	LOAD.L	D3,(A6)+OMDPOZ	ADD.W	D3,D4	DEC.W	D3	NEG.W	D4	LIB	?DRSEG	POPM.L	D2..D4	RET;---------\\; DISCLEAR >;---------/; Efface l'emplacement pour le caractre.; in	-; out	-; mod	D7.WDISCLEAR:	PUSHM.L	D2..D4	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A6)+OMDPOZ	LOAD.L	D4,(A6)+OMDDIZ	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface le dernier gencar	POPM.L	D2..D4	RET;---------\\; DISNAME  >;---------/; Construit le nom du fichier gencar.; Tient compte des ventuels liens !; in	A0.L	^buffer temporaire; out	A3.L	^nom; mod	D7.W, A3.LDISNAME:	PUSHM.L	D3..D5,A4	LOAD.L	A4,(A6)+OMDPLI	; A4 <-- ^liste des gencars	LOAD.W	D4,(A5)+OSLCYS	MUL.WU	D4,#3	ADD.L	A4,D4		; A4 <-- ^gencar slectionn	LOAD.B	D3,(A4)+0	; D3 <-- fonte	LOAD.B	D4,(A4)+1	; D4 <-- style/chasse	LOAD.B	D5,(A4)+2	; D5 <-- taille	AND.B	D5,#H'7F	LOAD.L	A3,A0		; A3 <-- ^buffer o mettre le nom	LOAD.L	A4,(A6)+OMDPLN	COMP.B	D3,#'D	JUMP',EQ 12$	COMP.B	D3,#'Q		; fonte de l'imprimante ?	JUMP',NE 15$		; non => 15$12$:				; oui =>	COMP.B	(A4+),#-2	; nom de l'imprimante existe ?	JUMP',NE 15$		; non => 15$13$:	LOAD.B	(A3+),(A4+)	; nom <-- LQ_, OKI_, etc.	JUMP,NE 13$	LOAD.B	(A3)-1,#'_	JUMP'	20$15$:	LOAD.L	A4,#R16"PREF$16$:	LOAD.B	(A3+),(A4+)	; nom <-- SMA_	JUMP,NE 16$	DEC.L	A320$:	LOAD.B	(A3+),D3	; nom <-- fonte	LOAD.B	D3,D4	AND.B	D3,#H'7F	LOAD.B	(A3+),D3	; nom <-- style	LOAD.B	(A3+),#'P	; nom <-- chasse	TEST.L	D4:#7	JUMP',BC 30$	LOAD.B	(A3)-1,#'F	; nom <-- chasse30$:	AND.L	D5,#H'FF	DIV.WU	D5,#10	ADD.B	D5,#'0	LOAD.B	(A3+),D5	; nom <-- taille	SWAP.W	D5	ADD.B	D5,#'0	LOAD.B	(A3+),D5	; nom <-- taille	LOAD.L	A4,#R16"EXT$40$:	LOAD.B	(A3+),(A4+)	; nom <-- .GENC	JUMP,NE 40$	LOAD.L	A3,A0		; A3 <-- ^dbut du nom	POPM.L	D3..D5,A4	RETPREF$:	.ASCIZ	"SMA_"		; prfixeEXT$:	.ASCIZ	".GENC"		; extensionNMGENC:	.ASCIZ	"GENCAR"	; nom du module GENCAR	.EVEN	.END