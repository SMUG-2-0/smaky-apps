	.SBTTL	LIBCLA;--------\; _SURE?  >;========/; Demmande "Etes-vous sr ?"; in	-; out	D7.W	comme appel ?YESNO; mod	D7.W_SURE?:	LIB	?MAFTIM	.ASCIZ	/<'F>Etes-vous sr ? /	.ASCIZ	/<'E>Are you sure ? /	.ASCIZ	/<'D>Sind sie sicher ? /	.B	0	.EVEN;	JUMP	_YESNO;--------\; _YESNO  >;========/; Attend une rponse du type "oui/non/stop/quoi".; in	-; out	D7.W	ERKYES => rponse "oui" (O),(Y),(J),(S);		ERKNO  => rponse "non" (N);		ERKSTO => rponse "j'en ai marre" (END);		ERKWHA => rponse "j'en sais rien" (SPACE);		ERKOTH => autre rponse; mod	D7.W_YESNO:	PUSHM.L	D3,D4,A3,A4	CALL	SVMENU		; A4/D4 <-- menu actuel	JUMP,NE	95$	LOAD.B	D3,#BIPYES	LIB	?BEEP	LIB	?GETLAN		; D3 <-- langue parle	LOAD.L	A3,#R16"TXYESE	; A3 <-- ^texte anglais	COMP.B	D3,#'E	JUMP',EQ 10$	LOAD.L	A3,#R16"TXYESD	; A3 <-- ^texte allemand	COMP.B	D3,#'D	JUMP',EQ 10$	LOAD.L	A3,#R16"TXYESF	; A3 <-- ^franais par dfaut10$:	LIB	?AFMENU		; affiche nouveau menu12$:	LIB	?GETCAR		; attend une touche ...	TEST.W	D7		; erreur de lecture ?	JUMP,NE	90$		; oui => 90$	COMP.W	D3,#KEYMGR	JUMP,EQ	12$	COMP.W	D3,#KEYMMR	; bouton souris relach ?	JUMP,EQ	12$		; oui => 12$	COMP.W	D3,#KEYMDR	JUMP,EQ	12$	LIB	?MINMAJ		; D3 <-- lettre MAJUSCULE	COMP.B	D3,#F0+SHIFT	JUMP',LO 15$	COMP.B	D3,#F15+SHIFT	JUMP',HI 15$	SUB.B	D3,#SHIFT	; D3 <-- (F0)..(F15)15$:	LOAD.L	A3,#R16"01$	; A3 <-- ^textes "oui"	LOAD.W	D7,#ERKYES	; D7 <-- "oui"	COMP.B	D3,#'O		; oui ?	JUMP',EQ 20$	COMP.B	D3,#'Y		; yes ?	JUMP',EQ 20$	COMP.B	D3,#'J		; ja ?	JUMP',EQ 20$	COMP.B	D3,#'S		; si ?	JUMP',EQ 20$	COMP.B	D3,#F1	JUMP',EQ 20$	COMP.B	D3,#F2	JUMP',EQ 20$	COMP.B	D3,#F320$:	JUMP,EQ 80$	LOAD.L	A3,#R16"02$	; A3 <-- ^textes "non"	LOAD.W	D7,#ERKNO	; D7 <-- "non"	COMP.B	D3,#'N		; non, no, nein ?	JUMP',EQ 30$	COMP.B	D3,#F4	JUMP',EQ 30$	COMP.B	D3,#F5	JUMP',EQ 30$	COMP.B	D3,#F630$:	JUMP,EQ 80$	LOAD.L	A3,#R16"03$	; A3 <-- ^textes "stop"	LOAD.W	D7,#ERKSTO	; D7 <-- "stop"	COMP.B	D3,#END		; j'en ai marre ?	JUMP',EQ 40$	COMP.B	D3,#F7	JUMP',EQ 40$	COMP.B	D3,#F8	JUMP',EQ 40$	COMP.B	D3,#F940$:	JUMP,EQ 80$	LOAD.L	A3,#R16"04$	; A3 <-- ^textes "pas compris"	LOAD.W	D7,#ERKWHA	; D7 <-- "quoi"	COMP.B	D3,#SPACE	; j'en sais rien ?	JUMP',EQ 50$	COMP.B	D3,#F10	JUMP',EQ 50$	COMP.B	D3,#F11	JUMP',EQ 50$	COMP.B	D3,#F1250$:	JUMP,EQ 80$	LOAD.L	A3,#R16"05$	; A3 <-- ^textes "autre"	LOAD.W	D7,#ERKOTH	; D7 <-- "autre"80$:	PUSH.W	D7	LIB	?MAFTEXT	; affiche "oui/non/stop/..."	LIB	?AFCR		; puis passe  la ligne	POP.W	D790$:	PUSH.W	D7	CALL	RSMENU		; remet menu utilisateur	POP.W	D795$:	POPM.L	D3,D4,A3,A4	RET01$:	.ASCIZ	/<'F>oui/	.ASCIZ	/<'E>yes/	.ASCIZ	/<'D>ja/	.ASCIZ	/<'I>si/	.B	002$:	.ASCIZ	/<'F>non/	.ASCIZ	/<'E>no/	.ASCIZ	/<'D>nein/	.ASCIZ	/<'I>no/	.B	003$:	.ASCIZ	/<'F>stop/	.ASCIZ	/<'E>stop/	.ASCIZ	/<'D>halt/	.ASCIZ	/<'I>stop/	.B	004$:	.ASCIZ	/<'F>pas compris/	.ASCIZ	/<'E>what/	.ASCIZ	/<'D>was/	.ASCIZ	/<'I>no capito/	.B	005$:	.ASCIZ	/<'F>-/	.B	0TXYESF:	.ASCIZ	//	.ASCIZ	//	.ASCIZ	//	.ASCIZ	/oui/	.ASCIZ	//	.ASCIZ	/non/	.ASCIZ	//	.ASCIZ	/stop/	.ASCIZ	//	.ASCIZ	/pas compris/	.ASCIZ	//	.ASCIZ	//TXYESE:	.ASCIZ	//	.ASCIZ	//	.ASCIZ	//	.ASCIZ	/yes/	.ASCIZ	//	.ASCIZ	/no/	.ASCIZ	//	.ASCIZ	/stop/	.ASCIZ	//	.ASCIZ	/what/	.ASCIZ	//	.ASCIZ	//TXYESD:	.ASCIZ	//	.ASCIZ	//	.ASCIZ	//	.ASCIZ	/ja/	.ASCIZ	//	.ASCIZ	/nein/	.ASCIZ	//	.ASCIZ	/halt/	.ASCIZ	//	.ASCIZ	/was/	.ASCIZ	//	.ASCIZ	//	.EVEN;--------\; SVMENU  >;--------/; Sauve l'tat du menu actuel.; in	-; out	A4.L	^ancien menu;	D4.W	anciennes barres;	D7.W	erreur; mod	D4.L, D7.W, A4.LSVMENU:	PUSHM.L	D1,D3,A2,A3	LIB	?PTMENU		; A3 <-- ^.ASCIZ  D3 <-- barres	LOAD.L	A4,A3	CLR.L	D4	LOAD.B	D1,#12		; D1 <-- nb de .ASCIZ10$:	INC.W	D4	TEST.B	(A4+)		; compte un .ASCIZ	JUMP,NE	10$	DEC.B	D1	JUMP,NE	10$	LOAD.W	D1,#MTYPCP	; D1 <-- type du compte	GESMEM	?SGETMEM	; demande mmoire SYSTEME (!)	JUMP,NE	90$	LOAD.L	A2,A4		; A2 <-- ^buffer temporaire40$:	LOAD.B	(A2+),(A3+)	; sauve l'tat actuel	DEC.W	D4	JUMP,NE	40$	LOAD.W	D4,D3		; D4 <-- barres90$:	POPM.L	D1,D3,A2,A3	TEST.W	D7		; retour EQ/NE	RET;--------\; RSMENU  >;--------/; Remet le menu initial.; in	A4.L	^ancien menu;	D4.W	anciennes barres; out	-; mod	D7.WRSMENU:	PUSHM.L	D1,D3,D4,A3,A4	LOAD.L	A3,A4		; A3 <-- ^menu	LIB	?AFMENU		; remet menu sans les barres	CLR.B	D3		; D3 <-- no 1re barre20$:	RR.W	D4,#1		; carry <-- rien/barre	JUMP',CC 30$		; si rien => 30$	LIB	?SETBARRE	; si barre => remet barre30$:	INC.B	D3		; D3 <-- no barre suivante	COMP.B	D3,#16	JUMP,LO	20$	LOAD.W	D1,#MTYPCP	; D1 <-- type du compte	GESMEM	?GIVMEM		; rend la mmoire	POPM.L	D1,D3,D4,A3,A4	RET;--------\; _GETDEC >;========/; Attend un nombre dcimal, avec la possibilit d'effacer; le dernier caractre tap.; in	-; out	D3.W	touche terminateur (non 0..9);	D4.L	nombre tap;	D7.W	erreur; mod	D3.W, D4.W, D7.W_GETDEC:	PUSHM.L	D0,D1	CLR.L	D4		; D4 <-- futur nombre	CLR.B	D1		; D1 <-- nb digits taps10$:	LIB	?GETCAR		; attend une touche	TEST.W	D7		; erreur de lecture ?	JUMP,NE	90$		; oui => 90$	COMP.W	D3,#H'100	; touche fonction presse ?	JUMP,HS 90$		; oui => 90$				; non =>	COMP.B	D3,#DELETE	JUMP,EQ 50$	COMP.B	D3,#BS	JUMP,EQ 50$	COMP.B	D3,#DEL		; (DEL) ou (<=) ?	JUMP,EQ 50$		; oui => 50$	COMP.B	D3,#CLEAR	; (CLEAR) ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#CR	JUMP,EQ 80$	COMP.B	D3,#ENTER	; (CR) ou (ENTER) ?	JUMP,EQ 80$		; oui => 80$	COMP.B	D3,#TRIZERO	; (000) ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D3:#7		; (END) (HELP) (DEFINE) etc ?	JUMP,NE 90$		; oui => 90$	LIB	?AFCAR		; affiche caractre frapp	COMP.B	D3,#'0	JUMP,LO 90$	COMP.B	D3,#'9		; (0)..(9) ?	JUMP,HI 90$		; non => 90$	SUB.B	D3,#'0		; D3 <-- 0..9	AND.L	D3,#H'FF	MUL.WU	D4,#10.		; fait place pour un digit	ADD.L	D4,D3		; ajoute nouveau digit	INC.B	D1		; D1 <-- un digit de plus	JUMP	10$40$:				; ajoute 3x zro :	LOAD.B	D3,#'0	LIB	?AFCAR	LIB	?AFCAR	LIB	?AFCAR		; affiche "000"	MUL.WU	D4,#1000.	; met 3 digits  zro	ADD.B	D1,#3		; D1 <-- 3 digits de plus	JUMP	10$50$:				; supprime dernier digit tap :	TEST.B	D1	JUMP,EQ 10$	LIB	?AFBS		; efface dernier caractre	DEC.B	D1		; D1 <-- un digit de moins	TEST.L	D4		; chiffre zro ?	JUMP,EQ 10$		; oui => pas de division !	DIV.WU	D4,#10.		; supprime le dernier digit	AND.L	D4,#H'FFFF	; masque le reste (high word)	JUMP	10$60$:				; annule le nombre tap :	CLR.L	D4		; D4 <-- zro65$:	TEST.B	D1	JUMP,EQ 10$	DEC.B	D1		; D1 <-- un digit de moins	LIB	?AFBS		; efface un caractre	JUMP	65$80$:	LIB	?AFCR		; passe  la ligne90$:	POPM.L	D0,D1	RET;--------\; _GETHEX >;========/; Attend un nombre hexadcimal, avec la possibilit d'effacer; le dernier caractre tap.; in	-; out	D3.W	touche terminateur (non 0..F);	D4.L	nombre tap;	D7.W	erreur; mod	D3.W, D4.W, D7.W_GETHEX:	PUSHM.L	D0,D1	CLR.L	D4		; D4 <-- futur nombre	CLR.B	D1		; D1 <-- nb digits taps10$:	LIB	?GETCAR		; attend une touche	TEST.W	D7		; erreur de lecture ?	JUMP,NE	90$		; oui => 90$	COMP.W	D3,#H'100	; touche fonction presse ?	JUMP,HS 90$		; oui => 90$				; non =>	COMP.B	D3,#DELETE	JUMP,EQ 50$	COMP.B	D3,#BS	JUMP,EQ 50$	COMP.B	D3,#DEL		; (DEL) ou (<=) ?	JUMP,EQ 50$		; oui => 50$	COMP.B	D3,#CLEAR	; (CLEAR) ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#CR	JUMP,EQ 80$	COMP.B	D3,#ENTER	; (CR) ou (ENTER) ?	JUMP,EQ 80$		; oui => 80$	COMP.B	D3,#TRIZERO	; (000) ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D3:#7		; (END) (HELP) (DEFINE) etc ?	JUMP,NE 90$		; oui => 90$	LIB	?MINMAJ		; D3 <-- caractre MAJUSCULE	LIB	?AFCAR		; affiche caractre frapp	COMP.B	D3,#'0	JUMP,LO 90$	COMP.B	D3,#'9		; (0)..(9) ?	JUMP',LS 20$		; oui => 20$	COMP.B	D3,#'A	JUMP,LO 90$	COMP.B	D3,#'F		; (A)..(F) ?	JUMP,HI 90$		; non => 90$	SUB.B	D3,#'A-'9-120$:	SUB.B	D3,#'0		; D3 <-- 0..15	SL.L	D4,#4		; fait place pour 4 bits	OR.B	D4,D3		; ajoute nouveaux 4 bits	INC.B	D1		; D1 <-- un digit de plus	JUMP	10$40$:				; ajoute 3x zro :	LOAD.B	D3,#'0	LIB	?AFCAR	LIB	?AFCAR	LIB	?AFCAR		; affiche "000"	SL.L	D4,#4+4	SL.L	D4,#4		; met 3*4 bits  zro	ADD.B	D1,#3		; D1 <-- 3 digits de plus	JUMP	10$50$:				; supprime dernier digit tap :	TEST.B	D1	JUMP,EQ 10$	DEC.B	D1		; D1 <-- un digit de moins	SR.L	D4,#4		; D4 <-- "supprime" 4 bits	LIB	?AFBS		; efface dernier caractre	JUMP	10$60$:				; annule le nombre tap :	CLR.L	D4		; D4 <-- zro65$:	TEST.B	D1	JUMP,EQ 10$	DEC.B	D1		; D1 <-- un digit de moins	LIB	?AFBS		; efface un caractre	JUMP	65$80$:	LIB	?AFCR		; passe  la ligne90$:	POPM.L	D0,D1	RET	.END