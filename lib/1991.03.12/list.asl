	.TITLE	LIST.ASL	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal	.REF	SMAKY	.REF	MODULES	.REF	PLAN	.REF	XCAR	.REF	ICOLOR;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;OGCCNM = H'C0GRA_CRASTER = H'A899		; raster-op couleurGRA_GDOT = H'A89A		; get-dotBSRCCOUL = 11BDSTCOUL = 12;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; Date		Rev	Amliorations; -------------------------------------------------------------------------------------------; 20.02.91	5.15	LIST_VISU: affiche aussi les images couleurs (.COLOR);			LIST_DBOX: accepte un critre *.COLOR|*.IMAGE; 06.03.90	5.14	LIST_DBOX: ok si zro fichiers/dossiers; 05.07.89	5.13	LIST_VISU: affiche aussi les *00.GENC (avec XCAR_SHOWF); 23.06.89	5.12	LIST_NEXT: met les noms physiques en sens inverse de ?VLOGIC; 09.06.89	5.11	LIST_VISU: si binaire, option "dtail"; 05.06.89	5.10	LIST_VISU: affiche aussi les fichiers binaires; 28.04.89	5.9	LIST_VISU: ok avec les gencars analytiques (SMA_*00.GENC); 06.03.89	5.8	LIST_NEXT: FOS,?VLOGIC avec A3=0 !; 28.02.89	5.7	LIST_VISU: ngatif grandes images ok; 24.11.88	5.6	LIST_VISU: ok si largeur image pas multiple de 8; 26.10.88	5.5	LIST_NEXT: si ASSIGN @.. @.. => montre toujours; 06.10.88	5.4	LIST_NEXT: FOS,?VLOGIC dborde son buffer (?);			LIST_NEXT: ne liste plus si #TOTO: TITI: (dossier);			LIST_DBOX: si affiche .DI => message "Affichage impossible";			LIST_VISU: HEAD = nouvel appel; 08.07.88	5.3	LIST_DBOX: (DOSSIER PAR DEFAUT) --> (DOSSIER COURANT);			LIST_DBOX: ne montre jamais DOSSIER:;			LIST_DBOX: si on est dans dossier courant => rend nom tout nu !; 05.07.88	5.2	LIST_DBOX: si changement de type => PREND gris; 01.07.88	5.1	LIST_DBOX: changement d'unit physique ok;			LIST_DBOX: ne liste plus fichiers/dossiers cachs; 02.06.88	5.0	LIST_VISU: nouvel appel;			LIST_DBOX: entirement refait ...; 25.05.88	4.6	LIST_PUTFILE: nouvel appel; 21.10.87	4.5	LIST_DELETE: utilise DBOX_DETRUIT; 12.09.87	4.4	LIST_DBOX: petite correction pour FICHE; 04.09.87	4.3	LIST_MODIF: supprim !; 24.06.87	4.2	LIST_DBOX: pages dans l'ascenseur; 16.12.86	4.1	nouvel appel LIST_NBMAX;			LIST_DBOX: n'est plus limit  100 fichiers;			LIST_DBOX: supprime monte/descend dans (Fn); 12.12.86	4.0	utilise les listes du FOS	.REV	5,15	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------KEYDBOX	=	H'7E00		; "touche" pour dboxNBLI	=	12		; nb fichiers/ligneLGSUITE	=	12		; lg aprs un nom de fichierLGMFILE	=	41		; lg max nom fichier  modifier; Variables pour LIST_OPEN/NEXT/CLOSE; -----------------------------------LLINAM	=	64LLIUVL	=	2000	.LOC	0OLIREP:	.BLKB	LLINAM		; nom de rpertoireOLICRI:	.BLKB	LLINAM		; critre de rechercheOLIPCR:	.BLKB	4		; ^critre donn par l'utilisateurOLIMOD:	.BLKB	4		; modes (BOPSYS, BOPNEXT, etc.)OLICH:	.BLKB	4		; canal liste du FOSOLIOP:	.BLKB	2		; option (0..n)OLINBM:	.BLKB	2		; nb max de fichiersLGVAR:OLIUAR:	.BLKB	LGARGS		; units physiques: argumentsOLIUPT:	.BLKB	4		; units physiques: ^dans OLIUVLOLIUVL:	.BLKB	LLIUVL		; units physiques: buffer pour ?VLOGICLGVARU:; Variables pour LIST_DBOX; ------------------------LDBDIS	=	64	.LOC	0ODBCHD:	.BLKB	2		; canal du module DBOXODBCHS:	.BLKB	2		; canal du module SCROLLODBCHV:	.BLKB	4		; canal pour LIST_VISUxxxODBVSL:	.BLKB	LSLVAR		; variables pour scroll-listODBOPM:	.BLKB	2		; mode d'ouvertureODBOPP:	.BLKB	4		; position centre si BDBPOS dans modeODBFAN:	.BLKB	4		; fanionsODBMOD:	.BLKB	4		; modesODBPNK:	.BLKB	4		; ^nom pour (CHOISIT)ODBPLI:	.BLKB	4		; ^noms et arguments des fichiersODBNBF:	.BLKB	2		; nb de nomsODBNBD:	.BLKB	2		; nb de noms, mais sans les dossiersODBPBN:	.BLKB	4		; ^buffer pour nom en sortieODBPCR:	.BLKB	4		; ^critre donn en entreODBCRI:	.BLKB	64		; critreODBTYP:	.BLKB	2*10		; type des fichiersODBNOP:	.BLKB	1		; 1 => PREND impossible (gris)	.EVENODBVER:	.BLKB	2		; nb d'imbrications  verrouillerODBDIS:	.BLKB	LDBDIS		; buffer pour "write display"LGDBOX:; Variables pour LIST_MODIF; -------------------------	.LOC	0OMODC:	.BLKB	2		; canal du module DBOXOMODM:	.BLKB	2		; mode d'ouvertureOMODP:	.BLKB	4		; position centre si BDBPOS dans modeOMODPC:	.BLKB	4		; ^critreOMODF1:	.BLKB	LGMFILE		; premier nom de fichierOMODF2:	.BLKB	LGMFILE		; deuxime nom de fichierOMODCI:	.BLKB	2		; canal en entreOMODCO:	.BLKB	2		; canal en sortieOMODLB:	.BLKB	4		; lg buffer temporaireOMODAR:	.BLKB	LGARGS		; argumentsLGMODIF:; En-tte d'un fichier .IMAGE; ---------------------------	.LOC	0	.BLKB	1		; OIMTYP: H'01 = indique type image	.BLKB	1		; OIMCOD: H'00 = indique pas de codage	.BLKB	1		; OIMBIP: H'01 = 1 bit par point	.BLKB	1		; OIMDIR: H'02 = coord. X-Y comme cran	.BLKB	2		; OIMDLX: largeur image en points	.BLKB	2		; OIMDLY: hauteur image en points	.BLKB	4		; OIMNBB: nb de byte pour l'image	.BLKB	19		; rserveOIMINV:	.BLKB	1		; flag spcial pour LIST_VISU				; LGHIMA:; En-tte d'une image couleur .COLOR; ----------------------------------	.LOC	0	.BLKB	1		; OIMTYP: H'82	.BLKB	1		; OIMCOD: 0 ou 4	.BLKB	1		; OIMBIP: 4 bits/pixel	.BLKB	1		; OIMDIR: 2	.BLKB	2		; OIMDLX: largeur (multiple de 16)	.BLKB	2		; OIMDLY: hauteur	.BLKB	4		; OIMNBB: longueur du dataOIMSIZ:	.BLKB	2		; taille d'un pixel (4)OIMCNT:	.BLKB	2		; nb de pixels (1)OIMLGC:	.BLKB	4		; longueur de la CLUT	.BLKB	12		; rserve				; LGHIMA: longueur de l'en-tte; En-tte d'un fichier .TEXT (calcule); -------------------------------------	.LOC	0OTXBIN:	.BLKB	1		; 1 => fichier binaire	.EVENOTXLGT:	.BLKB	4		; lg totaleOTXLGB:	.BLKB	4		; lg sans les BOAsOTXNBL:	.BLKB	2		; nb de lignesOTXNBC:	.BLKB	2		; nb de caractres/ligne (si binaire)OTXCY:	.BLKB	2		; hauteur d'un caractreOTXCX:	.BLKB	2		; largeur d'un caractreOTXC1Y:	.BLKB	2		; offset en YOTXC1X:	.BLKB	2		; offset en XOTXLFL:	.BLKB	2		; dernire premire ligne afficheOTXLNL:	.BLKB	2		; dernier numro pour OTXLPLOTXLPL:	.BLKB	4		; dernier ^ligne; Variables pour les appels LIST_VISUxxxx; ---------------------------------------LHVBUF	=	256		; lg buffer	.LOC	0OHVTYP:	.BLKB	2		; type du fichier (TYPxxx)OHVPT:	.BLKB	4		; ^data du fichierOHVLG:	.BLKB	4		; longueur du fichierOHVHD:	.BLKB	LGHIMA		; en-tte (pas forcment image)OHVNAM:	.BLKB	50		; nom complet du fichierOHVPOS:	.BLKB	4		; coin sup/gaucheOHVDIM:	.BLKB	4		; dimensionsOHVPOF:	.BLKB	4		; coin sup/gauche pour fichierOHVDIF:	.BLKB	4		; dimensions pour fichierOHVWDI:	.BLKB	2		; no swdo initialeOHVWDJ:	.BLKB	2		; no swdo de travailOHVMOO:	.BLKB	4		; mode pour LIST_VISUOPENOHVMOD:	.BLKB	4		; mode pour LIST_VISUDRAWOHVMOU:	.BLKB	4		; mode pour LIST_VISUUPDATEOHVMOI:	.BLKB	4		; mode pour LIST_VISUINFOOHVERR:	.BLKB	2		; code de l'erreurOHVPOR:	.BLKB	4		; position relative (+/- y;x)OHVNCM:	.BLKB	2		; compteur pour CCMO/SCMOOHVFLG:	.BLKB	1		; flags divers : BHVMAIN =  0			;  lutin souris = mainOHVDCR:	.BLKB	1		; 1 => disable <cr>	.EVENOHVASV:	.BLKB	LSCVAR		; ascenseur vertical ( gauche)OHVASH:	.BLKB	LSCVAR		; ascenseur horizontal (en bas)OHVCHS:	.BLKB	2		; canal du module STRETCHOHVCHP:	.BLKB	2		; canal du module PLANAOHVBUF:	.BLKB	LHVBUF		; buffer pour diverses utilisationsOHVUSE:	.BLKB	16		; qq variables pour l'utilisateurLHV:; En-tte du module LIB; ---------------------	.LOC	0	LIST_	FIRST		; code du premier appel	LIST_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	5,15		; rvision.version	.W	0,END_LIST	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"LIST"		; nom du module	.FILLB	(LGHLIB-.),0	.W	_LIST_OPEN	.W	_LIST_NEXT	.W	_LIST_CLOSE	.W	_LIST_AFFILE	.W	_LIST_DBOX	.W	_LIST_MODIF	.W	_LIST_DELETE	.W	_LIST_SOPEN	.W	_LIST_NBMAX	.W	_LIST_PUTFILE	.W	_LIST_VISU; Codes des appels; ----------------;-----------\; _LIST_OPEN >;===========/; Dbut d'une recherche dans SYS_LIST.; in	A3.L	^critre de recherche; out	D6.L	canal;	D7.W	erreur; mod	D6.L, D7.W_LIST_OPEN:	PUSH.W	D3	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	CALL	_LIST_SOPEN	; dbut d'une recherche	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;------------\; _LIST_SOPEN >;============/; Dbut d'une recherche dans SYS_LIST.; in	A3.L	^critre de recherche ($ = units physiques);	D3.L	mode d'ouverture pour SYS_LIST; out	(A3)++	critre avec accs complet (si D3:#BOPNAME);	D6.L	canal;	D7.W	erreur; mod	D6.L, D7.W_LIST_SOPEN:	PUSHM.L	D1..D4,A2..A4,A6	LOAD.L	D4,#LGVAR	; D4 <-- lg des variables	COMP.B	(A3),#'$	; liste des units physiques ?	JUMP',NE 10$		; non => 10$	TEST.B	(A3)+1	JUMP',NE 10$	LOAD.L	D4,#LGVARU	; D4 <-- plus de variables !10$:	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE	95$	GESMEM	?CLEARMEM	; variables <-- rempli de zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OLIMOD,D3	; OLIMOD <-- modes	LOAD.L	(A6)+OLIPCR,A3	; OLIPCR <-- ^critre de l'utilisateur	CLR.W	(A6)+OLIOP	; OLIOP <-- premire option; Spare les noms de rpertoires du critre.	CALL	SKIPREP		; A3 <-- ^rep(s): et A4 <-- ^nom (critre)	LOAD.L	A2,#(A6)+OLIREP20$:	COMP.L	A3,A4	JUMP',EQ 22$	LOAD.B	(A2+),(A3+)	; OLIREP <-- noms de rpertoires	JUMP	20$22$:;	CLR.B	(A2)	LOAD.L	A2,#(A6)+OLICRI30$:	LOAD.B	D3,(A4+)	CALL	IFTERM	JUMP',EQ 32$	LOAD.B	(A2+),D3	; OLICRI <-- critres	JUMP	30$32$:;	CLR.B	(A2); Demande au FOS d'ouvrir la liste.	COMP.W	(A6)+OLICRI,#H'100*'$ ; liste des units physiques ?	JUMP,EQ 60$		; oui => 60$	LOAD.L	A3,#(A6)+OLIREP	; A3 <-- ^rpertoires	LOAD.L	A2,A3		; A2 <-- ^buffer pour accs (si D3:#BOPNAME)	LOAD.W	D4,#LLINAM	; D4 <-- lg buffer (si D3:#BOPNAME)	LOAD.L	A4,#(A6)+OLICRI	; A4 <-- ^critres	LOAD.L	D3,(A6)+OLIMOD	; D3 <-- mode d'ouverture	LOAD.W	D2,(A6)+OLIOP	; D2 <-- premire option	FOS	?LISTOP		; ouvre la liste	JUMP',NE 90$	LOAD.W	(A6)+OLIOP,D2	; OLIOP <-- option suivante	LOAD.L	(A6)+OLICH,D6	; mm. le canal FOS	LOAD.W	(A6)+OLINBM,D4	; mm. le nb max de fichiers; Retourne ventuellement le critre avec la chane d'accs complte; rendue par le FOS.	TEST.L	D3:#BOPNAME	; rend l'accs complet ?	JUMP',BC 80$		; non => 80$				; oui =>	LOAD.L	A3,(A6)+OLIPCR	; A3 <-- ^buffer de l'utilisateur	LOAD.L	A4,#(A6)+OLIREP50$:	LOAD.B	(A3+),(A4+)	; critre <-- accs complet (rpertoires)	JUMP,NE 50$	DEC.L	A3	LOAD.L	A4,#(A6)+OLICRI52$:	LOAD.B	(A3+),(A4+)	; critre <-- *.xxx	JUMP,NE 52$	JUMP'	80$60$:				; units physiques =>	LOAD.L	A3,#0		; A3 <-- ^nom physique	LOAD.L	A4,#(A6)+OLIUVL	; A4 <-- ^buffer pour les noms	LOAD.L	D4,#LLIUVL	; D4 <-- lg buffer	CLR.W	D3		; D3 <-- pour tous	LOAD.B	D2,#-1		; D2 <-- chanes d'assignations compltes	FOS	?VLOGIC		; OLIUVL <-- tous les noms	JUMP',NE 90$	LOAD.L	(A6)+OLIUPT,A4	; OLIUPT <-- ^dbut de OLIUVL80$:	LOAD.L	D6,A6		; D6 <-- canal du module LIST	JUMP'	95$90$:	PUSH.W	D7	LOAD.L	A4,A6		; A4 <-- ^zone des variables	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire des variables	POP.W	D795$:	POPM.L	D1..D4,A2..A4,A6	TEST.W	D7		; retour EQ/NE	RET;------------\; _LIST_NBMAX >;============/; Donne le nombre de fichiers correspondants au critre.; in	D6.L	canal; out	D4.W	nb de fichiers (0..n); mod	D4.L, D7.W_LIST_NBMAX:	PUSH.L	A6	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.W	D4,(A6)+OLINBM	; D4 <-- nb de fichiers	POP.L	A6	CLR.W	D7		; retour EQ	RET;-----------\; _LIST_NEXT >;===========/; Cherche le fichier suivant dans SYS_LIST.; in	D6.L	canal; out	A3.L	^nom trouv;	A4.L	^arguments;	D7.W	erreur (EROUTF quand c'est fini); mod	D7.W, A3.L, A4.L_LIST_NEXT:	PUSHM.L	D2..D5,D6,A2,A6	LOAD.L	A6,D6		; A6 <-- ^variables	COMP.W	(A6)+OLICRI,#H'100*'$ ; liste des units physiques ?	JUMP',EQ 50$		; oui => 50$10$:	LOAD.L	D6,(A6)+OLICH	; D6 <-- canal du FOS	FOS	?LISTNXT	; A3 <-- ^nom et A4 <-- ^arguments	JUMP',EQ 90$	COMP.W	D7,#EROUTF	JUMP',NE 90$	LOAD.L	D3,(A6)+OLIMOD	; D3 <-- mode d'ouverture	TEST.L	D3:#BOPNEXT	; cherche toutes les options ?	JUMP',BC 90$		; non => 90$				; oui =>	LOAD.L	D6,(A6)+OLICH	; D6 <-- canal du FOS	FOS	?LISTCLO	; ferme la liste de l'option prcdente	LOAD.L	A3,#(A6)+OLIREP	; A3 <-- ^rpertoires	LOAD.L	A4,#(A6)+OLICRI	; A4 <-- ^critres;	LOAD.L	D3,(A6)+OLIMOD	; D3 <-- mode d'ouverture	TCLR.L	D3:#BOPNAME	; D3 <-- rend seulement le premier accs !	LOAD.W	D2,(A6)+OLIOP	; D2 <-- option	FOS	?LISTOP		; ouvre la liste de la nouvelle option	JUMP',NE 90$	LOAD.W	(A6)+OLIOP,D2	; OLIOP <-- option suivante	LOAD.L	(A6)+OLICH,D6	; mm. le canal FOS	LOAD.W	(A6)+OLINBM,D4	; mm. le nb max de fichiers	JUMP	10$50$:				; unit physique =>	LOAD.L	A2,(A6)+OLIUPT	; A2 <-- ^dans OLIUVL52$:	LOAD.W	D7,#EROUTF	TEST.B	(A2)		; fin de la table ?	JUMP',EQ 56$		; oui => 56$	CALL	LISTNEXTPUT	; A3/A4 <-- ^noms/^arguments	JUMP,NE 52$56$:	LOAD.L	(A6)+OLIUPT,A290$:	POPM.L	D2..D5,D6,A2,A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; LISTNEXTPUT >;------------/; Cherche les noms et les arguments d'une unit physique.; Met les noms en sens inverse de ce que donne FOS,?VLOGIC.; Par exemple :;	?VLOGIC	-->	#DANIEL<0>#MM1<0><0>;	nom	-->	#MM1:/#DANIEL:<0>; in	A2.L	^nom physique<0> logique<0> .. <0>; out	A2.L	^nom suivant;	A3.L	^nom trouv;	A4.L	^arguments;	D7.W	erreur; mod	D7.W, A2.L, A3.L, A4.LLISTNEXTPUT:	PUSH.W	D3	LOAD.L	A4,#(A6)+OLIUAR+OBLLG10$:	LOAD.B	(A4+),(A2+)	; OBLLG <-- nom physique !	JUMP,NE 10$; Filtre les assignations #.. -> @..	COMP.B	(A2),#'#	JUMP',NE 30$	COMP.B	(A6)+OLIUAR+OBLLG,#'@	JUMP',NE 30$20$:	TEST.B	(A2+)	JUMP',EQ 24$22$:	TEST.B	(A2+)	JUMP,NE 22$	JUMP	20$24$:	LOAD.W	D7,#EROUTF	; D7 <-- pas trouv	JUMP'	90$; Met tous les noms logiques.30$:	LOAD.L	A4,#(A6)+OLIUAR+OBLNAM	LOAD.L	A3,A4	CLR.L	(A3+)	CLR.L	(A3+)	CLR.L	(A3+)	CLR.L	(A3+)		; vide tout le buffer (LGNAME)	LOAD.L	A3,A2		; A3 <-- ^noms logiques	CLR.B	D3		; D3 <-- pas de terminateur32$:	CALL	LISTNEXTONE	; OBLNAM <-- ajoute un nom	LOAD.B	D3,#'/		; D3 <-- terminateur "/"	TEST.B	(A3)		; encore un nom ?	JUMP,NE 32$		; oui => 32$	LOAD.L	A2,#(A3)+1	; A2 <-- ^suivant	LOAD.L	A3,#(A6)+OLIUAR+OBLNAM ; A3 <-- ^noms	LOAD.L	A4,#(A6)+OLIUAR+OBLTYP ; A4 <-- ^arguments	CLR.W	D7		; D7 <-- ok90$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;------------\\; LISTNEXTONE >;------------/; Met un nom, en poussant ceux qui y sont dj !; in	A3.L	^nom  ajouter <0>;	A4.L	^buffer (lg=LGNAME=16);	D3.B	caractre terminateur/nil (si premier); out	A3.L	^nom suivant; mod	D7.W, A3.LLISTNEXTONE:	PUSHM.L	D1,D2,A1,A2	LOAD.L	A2,A3	LOAD.W	D2,#-1+1	; D2 <-- +1  cause place pour ":"20$:	INC.W	D2	TEST.B	(A2+)	JUMP,NE 20$	TEST.B	D3	JUMP',EQ 24$	INC.W	D2		; D2 <-- +1  cause place pour terminateur24$:	LOAD.L	A1,#(A4)+LGNAME	LOAD.L	A2,#(A4)+LGNAME	SUB.W	A2,D2	LOAD.W	D1,#LGNAME-1	; D1 <-- -1  cause NMO	SUB.W	D1,D230$:	LOAD.B	(-A1),(-A2)	; buffer <-- pousse les noms existants	DECJ.W,NMO D1,30$;	LOAD.L	A2,A440$:	LOAD.B	(A2+),(A3+)	JUMP,NE 40$	LOAD.B	(A2)-1,#':	TEST.B	D3	JUMP',EQ 44$	LOAD.B	(A2),D3		; buffer <-- caractre terminateur44$:	TEST.B	(A4)+LGNAME-1	JUMP',EQ 90$	CLR.B	(A4)+LGNAME-1	LOAD.B	(A4)+LGNAME-2,#'>90$:	POPM.L	D1,D2,A1,A2	RET;------------\; _LIST_CLOSE >;============/; Termine une recherche dans SYS_LIST.; in	D6.L	canal; out	-; mod	-_LIST_CLOSE:	PUSHM.L	D1,D6,D7,A4,A6	LOAD.L	A6,D6		; A6 <-- ^variables	COMP.W	(A6)+OLICRI,#H'100*'$ ; liste des units physiques ?	JUMP',EQ 50$		; oui => 50$	LOAD.L	D6,(A6)+OLICH	; D6 <-- canal du FOS	FOS	?LISTCLO	; ferme la liste50$:	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend les variables	POPM.L	D1,D6,D7,A4,A6	RET;-------------\\; _LIST_AFFILE >;=============/; Affiche un nom de fichier.; in	A3.L	^nom;	A4.L	^arguments;	D4.W	mode d'affichage; out	D7.W	erreur; mod	D7.W_LIST_AFFILE:	PUSHM.L	D1,D2,D3,D4,A3	LOAD.W	D1,D4		; D1 <-- mode d'affichage	LOAD.W	D2,#16		; D2 <-- place pour le nom10$:	LOAD.B	D3,(A3+)	JUMP',EQ 20$	LIB	?AFCAR	DEC.W	D2	JUMP,NE	10$20$:	TEST.W	D2	JUMP',EQ 30$	LOAD.B	D3,#MSPACE	LIB	?AFCAR		; bourre le reste avec des espaces	LOAD.B	D3,D2		; D3 <-- nb d'espace(s)	LIB	?AFCAR30$:	TEST.L	D1:#BLISTALG	JUMP',BC 40$	LOAD.B	D2,#2^BAFDSP	; D2 <-- mode d'affichage	LOAD.B	D3,#8		; D3 <-- nb de digits	LOAD.L	D4,(A4)+OBALGF	LIB	?AFDEC		; affiche la taille40$:	TEST.L	D1:#BLISTADC	JUMP',BC 50$	LIB	?AFSPACE	LOAD.L	A3,#(A4)+OBACD	LOAD.B	D3,#'/	CALL	AFDATIM		; affiche la date de cration50$:	TEST.L	D1:#BLISTAHC	JUMP',BC 51$	LOAD.L	A3,#(A4)+OBACH	LOAD.B	D3,#':	CALL	AFDATIM		; affiche l'heure de cration51$:	TEST.L	D1:#BLISTADM	JUMP',BC 52$	LIB	?AFSPACE	LOAD.L	A3,#(A4)+OBAWD	LOAD.B	D3,#'/	CALL	AFDATIM		; affiche la date de modification52$:	TEST.L	D1:#BLISTAHM	JUMP',BC 53$	LOAD.L	A3,#(A4)+OBAWH	LOAD.B	D3,#':	CALL	AFDATIM		; affiche l'heure de modification53$:	TEST.L	D1:#BLISTADU	JUMP',BC 54$	LIB	?AFSPACE	LOAD.L	A3,#(A4)+OBARD	LOAD.B	D3,#'/	CALL	AFDATIM		; affiche la date d'utilisation54$:	TEST.L	D1:#BLISTAHU	JUMP',BC 55$	LOAD.L	A3,#(A4)+OBARH	LOAD.B	D3,#':	CALL	AFDATIM		; affiche l'heure d'utilisation55$:	POPM.L	D1,D2,D3,D4,A3	RET;--------\\; AFDATIM >;--------/; Affiche une date ou une heure.; in	A3.L	^date/heure (.BBB);	D3.B	caractre de sparation; out	-; mod	D4.W, D7.WAFDATIM:	LIB	?AFSPACE	; met d'abord un espace	LOAD.B	D4,(A3)+0	LIB	?AFX2		; affiche heures/jour	LIB	?AFCAR		; affiche ":" ou "/"	LOAD.B	D4,(A3)+1	LIB	?AFX2		; affiche minutes/mois	LIB	?AFCAR		; affiche ":" ou "/"	LOAD.B	D4,(A3)+2	LIB	?AFX2		; affiche secondes/anne	RET;--------------\\; _LIST_PUTFILE >;==============/; Affiche un nom de fichier.; in	A3.L	^nom;	A4.L	^arguments;	D4.W	mode d'affichage;	A5.L	^buffer; out	A5.L	^plus loin;	D7.W	erreur; mod	D7.W, A5.L_LIST_PUTFILE:	PUSHM.L	D1,D2,D3,D4,A3,A4	EX.L	A4,A5	LOAD.W	D1,D4		; D1 <-- mode d'affichage	LOAD.W	D2,#16		; D2 <-- place pour le nom10$:	LOAD.B	D3,(A3+)	JUMP',EQ 20$	LOAD.B	(A4+),D3	DEC.W	D2	JUMP,NE	10$20$:	TEST.W	D2	JUMP',EQ 30$22$:	LOAD.B	(A4+),#SPACE	; bourre le reste avec des espaces	DEC.W	D2	JUMP,NE 22$30$:	TEST.L	D1:#BLISTALG	JUMP',BC 40$	LOAD.B	D2,#2^BAFDSP	; D2 <-- mode d'affichage	LOAD.B	D3,#8		; D3 <-- nb de digits	LOAD.L	D4,(A5)+OBALGF	LIB	?PUTDEC		; affiche la taille40$:	TEST.L	D1:#BLISTADC	JUMP',BC 50$	LOAD.B	(A4+),#SPACE	LOAD.L	A3,#(A5)+OBACD	LOAD.B	D3,#'/	CALL	PUTDATIM	; affiche la date de cration50$:	TEST.L	D1:#BLISTAHC	JUMP',BC 51$	LOAD.L	A3,#(A5)+OBACH	LOAD.B	D3,#':	CALL	PUTDATIM	; affiche l'heure de cration51$:	TEST.L	D1:#BLISTADM	JUMP',BC 52$	LOAD.B	(A4+),#SPACE	LOAD.L	A3,#(A5)+OBAWD	LOAD.B	D3,#'/	CALL	PUTDATIM	; affiche la date de modification52$:	TEST.L	D1:#BLISTAHM	JUMP',BC 53$	LOAD.L	A3,#(A5)+OBAWH	LOAD.B	D3,#':	CALL	PUTDATIM	; affiche l'heure de modification53$:	TEST.L	D1:#BLISTADU	JUMP',BC 54$	LOAD.B	(A4+),#SPACE	LOAD.L	A3,#(A5)+OBARD	LOAD.B	D3,#'/	CALL	PUTDATIM	; affiche la date d'utilisation54$:	TEST.L	D1:#BLISTAHU	JUMP',BC 55$	LOAD.L	A3,#(A5)+OBARH	LOAD.B	D3,#':	CALL	PUTDATIM	; affiche l'heure d'utilisation55$:	CLR.B	(A4)	EX.L	A5,A4	POPM.L	D1,D2,D3,D4,A3,A4	RET;---------\\; PUTDATIM >;---------/; Affiche une date ou une heure.; in	A3.L	^date/heure (.BBB);	D3.B	caractre de sparation;	A4.L	^buffer; out	A4.L	^plus loin; mod	D4.W, D7.W, A4.LPUTDATIM:	LOAD.B	(A4+),#SPACE	; met d'abord un espace	LOAD.B	D4,(A3)+0	CALL	PUTX2		; affiche heures/jour	LOAD.B	(A4+),D3	; affiche ":" ou "/"	LOAD.B	D4,(A3)+1	CALL	PUTX2		; affiche minutes/mois	LOAD.B	(A4+),D3	; affiche ":" ou "/"	LOAD.B	D4,(A3)+2;	CALL	PUTX2		; affiche secondes/anne;	RET;--------\\; PUTX2   >;--------/; Affiche un nombre en BCD.; in	D4.B	nombre BCD;	A4.L	^buffer; out	A4.L	^plus loin; mod	D7.W, A4.LPUTX2:	PUSH.W	D3	LOAD.B	D3,D4	SR.B	D3,#4	ADD.B	D3,#'0	LOAD.B	(A4+),D3	LOAD.B	D3,D4	AND.B	D3,#H'0F	ADD.B	D3,#'0	LOAD.B	(A4+),D3	POP.W	D3	RET	.INS	LISTDBOX.ASI	.INS	LISTMODIF.ASI	.INS	LISTVISU.ASI	.INS	LISTMISC.ASI;-------------\\; _LIST_DELETE >;=============/; Demande  l'utilisateur s'il faut dtruire ou non un fichier.; Ne fait pas l'appel FOS,?DELETE !; in	A3.L	^nom du fichier;	D2.W	mode d'ouverture pour la dbox;	D3.L	position centre (y;x) si BDBPOS dans D2.W; out	D3.W	dernire touche (O/N);	D7.W	erreur; mod	D3.L, D7.W_LIST_DELETE:	PUSHM.L	D1,D2,D4,A3,A5	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"01$	; A3 <-- ^textes de description	CLR.L	D4		; D4 <-- fanions	CLR.L	D3		; D3 <-- flags	TSET.L	D2:#BDBEXTEND	LOAD.W	D1,#DBOX_DETRUIT	DBOX_	EXTEND		; dialogue ...	JUMP',NE 90$	LOAD.W	D2,D3	LOAD.W	D3,#'O	COMP.W	D2,#F1	JUMP',EQ 90$	LOAD.W	D3,#'N90$:	POPM.L	D1,D2,D4,A3,A5	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	""		; nom du logiciel	.ASCIZ	"Mfichier"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN;--------\\; SKIPREP >;========/; Saute "unit:rep:rep:" au dbut d'un nom de fichier.; in	A3.L	^nom de fichier; out	A4.L	^nom sans unit:rep:; mod	A4.LSKIPREP:	PUSHM.L	D3,A310$:	LOAD.L	A4,A3		; A4 <-- ^dbut/^aprs ":"20$:	LOAD.B	D3,(A3+)	CALL	IFTERM	JUMP',EQ 90$	COMP.B	D3,#':	JUMP,EQ 10$	JUMP	20$90$:	POPM.L	D3,A3	RET;--------\\; IFTERM  >;========/; Teste si le caractre dans D3 est un terminateur de nom de fichier.; in	D3.B	caractre; out	EQ	terminateur; mod	-IFTERM:	TEST.B	D3	JUMP',EQ 90$	COMP.B	D3,#CR	JUMP',EQ 90$	COMP.B	D3,#SPACE	JUMP',EQ 90$	COMP.B	D3,#TAB	JUMP',EQ 90$	COMP.B	D3,#'/;	JUMP',EQ 90$90$:	RET; Tables; ------DOOK:	LOAD.W	D3,#CR	RETDOAN:	LOAD.W	D3,#END	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF13:	LOAD.W	D3,#F13	RETDOOUI:	LOAD.W	D3,#'O	RETDONON:	LOAD.W	D3,#'N	RETDOMP:	LOAD.W	D3,#KEYMGP	RETDOMR:	LOAD.W	D3,#KEYMGR	RET; Textes et tables; ----------------NAMDBOX:	.ASCIZ	"DBOX"NAMSCROLL:	.ASCIZ 	"SCROLL"LUTERM:	.B	':LITERM:	.B	0,CR,SPACE,TAB,'/,-1	.EVENEND_LIST:	.END