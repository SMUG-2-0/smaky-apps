	.SBTTL	LIBDUMP;--------\; _PDUMP  >;========/; Imprime une fentre de l'cran, en utilisant le nom; logique #PRINTER.; in	D3.B	numro fentre  imprimer;		 0  --> imprime la fentre utilise;		 1  --> imprime $DIS_1;		 2  --> imprime $DIS_2;		 etc.;		-1  --> imprime toute la partie visible; out	D7.W	erreur; mod	D7.W_PDUMP:	PUSH.L	A3	LOAD.L	A3,#R16"NLPRIN	CALL	_PFDUMP	POP.L	A3	RET;--------\; _PFDUMP >;========/; Imprime une fentre de l'cran, en utilisant un nom de; fichier quelconque (pas forcment #PRINTER).; in	A3.L	^nom de l'imprimante;	D3.B	numro fentre  imprimer;		 0  --> imprime la fentre utilise;		 1  --> imprime $DIS_1;		 2  --> imprime $DIS_2;		 etc.;		-1  --> imprime toute la partie visible; out	D7.W	erreur; mod	D7.W_PFDUMP:	PUSHM.L	D0..D6,A0..A5; Sauve tout l'cran ou seulement une fentre dans un bitmap; en mmoire point par A1.	CALL	DUMPSAVE	; sauve l'cran	JUMP,NE EXIT$; Ouvre le fichier et le classeur.	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	AND.L	D6,#H'FFFF	; D6 <-- clear flags	TEST.W	D7	JUMP',NE FOPEN$	TSET.L	D6:#16		; D6 <-- fichier ouvertFOPEN$:	LOAD.L	A3,#R16"NPDUMP	LOAD.L	D3,#BNTIMAG	; D3 <-- type initiateur (IMAG)	COMP.W	D2,#1		; image noir/blanc ?	JUMP',EQ BOPEN$		; oui => BOPEN$	LOAD.L	D3,#BNTCOLO	; D3 <-- type initiateur (COLO)BOPEN$:	LOAD.L	D4,D0	SWAP.W	D4	MUL.WU	D4,D0		; D4 <-- largeur*hauteur	SR.L	D4,#1		; D4 <-- /2 (trs approximatif !)	BLOC_	WROPEN		; dbut de l'criture dans le bloc-notes	JUMP',NE GO$	TSET.L	D6:#18		; D6 <-- classeur ouvertGO$:	COMP.W	D2,#1		; image noir/blanc ?	JUMP,EQ NB$		; oui => NB$; Met l'image couleur dans le classeur, mais pas dans le fichier.	LOAD.L	A4,A1		; A4 <-- ^en-tte	LOAD.L	D4,#LGHIMA	GESMEM	?CLEARMEM	; efface l'en-tte	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.B	(A2)+OIMTYP,#H'82;	LOAD.B	(A2)+OIMCOD,#0	LOAD.B	(A2)+OIMBIP,D2	LOAD.B	(A2)+OIMDIR,#2	LOAD.W	(A2)+OIMSIZ,D2	LOAD.W	(A2)+OIMCNT,#1	TEST.L	D5		; y a-t-il une CLUT ?	JUMP',EQ NOCLUT$	; non => NOCLUT$	LOAD.W	D4,D2	MUL.WU	D4,D4		; D4 <-- nb de couleurs	MUL.WU	D4,#LCTDATA	ADD.L	D4,#LCTHEAD	; D4 <-- lg ncessaire	LOAD.L	(A2)+OIMLGC,D4NOCLUT$:	LOAD.W	D4,D1	LOAD.W	(A2)+OIMDLX,D0	SWAP.W	D0	MUL.WU	D4,D0	LOAD.W	(A2)+OIMDLY,D0	SWAP.W	D0	LOAD.L	(A2)+OIMNBB,D4	LOAD.L	A3,#(A1)+LGHIMA+IMLBUF	LOAD.L	A4,#(A1)+LGHIMA	PUSH.W	(A2)+OIMDLX	PUSH.B	(A2)+OIMBIP	LOAD.W	D4,(A2)+OIMDLX	MUL.WU	D4,D2	LOAD.W	(A2)+OIMDLX,D4	; OIMDLX <-- * nb bits/pixel	LOAD.B	(A2)+OIMBIP,#1	GRA_	CODEIMA		; code l'image couleur	POP.B	(A2)+OIMBIP	POP.W	(A2)+OIMDLX	TEST.W	D7	JUMP',EQ CCODE$	LOAD.L	A4,A3		; A4 <-- ^image dcodeCCODE$:	LOAD.L	A5,A4		; A5 <-- ^image code/dcode;	TCLR.L	D6:#17		; D6 <-- rien dans le fichier	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	LOAD.L	D3,#BNTCOLO	CALL	DUMPWRITE	; crit l'en-tte couleur	JUMP,NE CLOSE$	TEST.L	D5		; y a-t-il une CLUT ?	JUMP',EQ CDATA$		; non => CDATA$	PUSH.L	D1	LOAD.L	D4,(A2)+OIMLGC	; D4 <-- lg ncessaire	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer pour la CLUT	JUMP',NE CLEND$	PUSH.L	D6	LOAD.L	A3,A4	LOAD.L	D3,#2^BTCTABLE	; D3 <-- mode	LOAD.L	D6,D5		; D6 <-- canal pour TCOLOR	TCOL_	SAVECLUT	; buffer <-- CLUT	POP.L	D6	LOAD.L	D3,#BNTCOLO	CALL	DUMPWRITE	; crit la CLUT	PUSH.W	D7;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend buffer pour la CLUT	POP.W	D7CLEND$:	POP.L	D1	TEST.W	D7	JUMP,NE CLOSE$CDATA$:	LOAD.L	A4,A5	LOAD.L	D4,(A2)+OIMNBB	LOAD.L	D3,#BNTCOLO	CALL	DUMPWRITE	; crit l'image couleur	JUMP,NE CLOSE$	TEST.B	(A2)+OIMCOD	; image couleur code ?	JUMP',EQ CONV$		; non => CONV$	LOAD.L	A3,#(A1)+LGHIMA+IMLBUF	LOAD.L	A4,#(A1)+LGHIMA;	PUSH.W	(A2)+OIMDLX;	PUSH.B	(A2)+OIMBIP	LOAD.W	D4,(A2)+OIMDLX	MUL.WU	D4,D2	LOAD.W	(A2)+OIMDLX,D4	; OIMDLX <-- * nb bits/pixel	LOAD.B	(A2)+OIMBIP,#1	GRA_	DECOIMA		; dcode l'image couleur;	POP.B	(A2)+OIMBIP;	POP.W	(A2)+OIMDLX; Conversion du bitmap couleur en bitmap noir/blanc.CONV$:	CLR.W	D7	TEST.L	D5		; y a-t-il une CLUT ?	JUMP,EQ CLOSE$		; non => CLOSE$	PUSH.L	(A0)+ODFCPF	LOAD.L	(A0)+ODFCPF,D5	PUSHM.L	D2,D6	LOAD.W	D5,D1		; D5 <-- Iy	LOAD.W	D6,D2		; D6 <-- nb de bits/pixel	CLR.L	D2		; D2 <-- mode	LOAD.L	D4,D0		; D4 <-- dimensions	LOAD.L	A4,#(A1)+LGHIMA+IMLBUF ; A4 <-- ^image	LOAD.L	A5,A4		; A5 <-- ^destination (=source)	ICOL_	CONVNB		; conversion en noir/blanc	POPM.L	D2,D6	POP.L	(A0)+ODFCPF	TEST.W	D7	JUMP,NE CLOSE$	AND.L	D1,#H'FFFF	DIV.WU	D1,D2		; D1 <-- Iy noir/blanc; Met l'image noir/blanc dans le fichier et le classeur.NB$:	LOAD.L	A4,A1		; A4 <-- ^en-tte	LOAD.L	D4,#LGHIMA	GESMEM	?CLEARMEM	; efface l'en-tte	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.B	(A2)+OIMTYP,#H'81;	LOAD.B	(A2)+OIMCOD,#0	LOAD.B	(A2)+OIMBIP,#1	LOAD.B	(A2)+OIMDIR,#2	LOAD.W	D4,D1	LOAD.W	(A2)+OIMDLX,D0	SWAP.W	D0	MUL.WU	D4,D0	LOAD.W	(A2)+OIMDLY,D0	SWAP.W	D0	LOAD.L	(A2)+OIMNBB,D4	LOAD.L	A3,#(A1)+LGHIMA+IMLBUF	LOAD.L	A4,#(A1)+LGHIMA	GRA_	CODEIMA		; code l'image noir/blanc	JUMP',EQ NBCODE$	LOAD.L	A4,A3		; A4 <-- ^image dcodeNBCODE$:	LOAD.L	A5,A4		; A5 <-- ^image	TSET.L	D6:#17		; D6 <-- crit dans le fichier	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	LOAD.L	D3,#BNTIMAG	CALL	DUMPWRITE	; crit l'en-tte noir/blanc	JUMP',NE CLOSE$	LOAD.L	A4,A5	LOAD.L	D4,(A2)+OIMNBB;	LOAD.L	D3,#BNTIMAG	CALL	DUMPWRITE	; crit l'image noir/blanc;	JUMP',NE CLOSE$; Ferme le fichier et le classeur.CLOSE$:	TEST.L	D6:#18		; classeur ouvert ?	JUMP',BC FCLOSE$	PUSH.W	D7	BLOC_	WRCLOSE		; ferme le classeur	POP.W	D7FCLOSE$:	TEST.L	D6:#16		; fichier ouvert ?	JUMP',BC GIVMEM$	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7GIVMEM$:	PUSH.W	D7	LOAD.L	A4,A1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'image	POP.W	D7EXIT$:	POPM.L	D0..D6,A0..A5	RET;----------\\; DUMPWRITE >;----------/; Ecrit une partie du data.; in	D3.L	type (BNTCOLO/BNTIMAG);	A4.L	^data;	D4.L	lg data;	D6.L	canal + flags; out	D7.W	erreur; mod	D7.WDUMPWRITE:	TEST.L	D6:#16		; fichier ouvert ?	JUMP',BC BLOC$		; non => BLOC$	TEST.L	D6:#17		; met dans le fichier ?	JUMP',BC BLOC$		; non => BLOC$	FOS	?WRBYTE		; crit dans le fichier	JUMP',NE EXIT$BLOC$:	TEST.L	D6:#18		; classeur ouvert ?	JUMP',BC EXIT$		; non => EXIT$	BLOC_	WRDATA		; crit dans le classeurEXIT$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; DUMPSAVE >;---------/; Sauve l'cran demand dans un buffer.; in	D3.B	numro fentre (-1,0..n); out	A0.L	^descripteur fentre;	A1.L	^copie du bitmap cran (en-tte + image dcode);	D0.L	dimensions;	D1.W	Iy;	D2.W	nb de bits/pixels;	D5.L	canal CLUT active;	D7.W	erreur; mod	D0.L, D1.L, D2.L, D5.L, D7.W, A1.LDUMPSAVE:	PUSHM.L	D3,D4,D6,A2..A4	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre courante	COMP.B	D3,#-1	JUMP',EQ ALL$	TEST.B	D3	JUMP',EQ USE$	LOAD.W	D7,#ERDIS	; D7 <-- erreur	AND.W	D3,#H'FF	SL.W	D3,#2		; D3 <-- *4 car table de .L	LOAD.L	A0,(A0)+ODFPDE	; A0 <-- ^descripteurs	LOAD.L	D3,(A0)+(D3.W)	JUMP,EQ EXIT$	LOAD.L	A0,D3		; A0 <-- ^descripteur demandUSE$:	LOAD.L	D0,(A0)+ODFDY	; D0 <-- dimensions de la fentre	JUMP'	GO$ALL$:	LOAD.L	A1,_VARLIB	; A1 <-- ^variables globales	LOAD.L	A0,(A1)+OPDDI0	; A0 <-- ^descripteur $DIS_0	LOAD.L	A1,(A1)+OPTTSK	; A1 <-- ^table des soft-keys	ADD.W	A1,(A1)+6	; A1 <-- ^table des dimensions	LOAD.L	D0,(A1)		; D0 <-- dimensions de l'cranGO$:	LOAD.W	D4,D0	ADD.W	D4,#8-1	SR.W	D4,#3		; D4 <-- largeur [bytes]	CLR.W	D3	LOAD.B	D3,(A0)+ODFCNP	; D3 <-- nb de bits/pixel	MUL.WU	D4,D3	LOAD.W	D6,D4		; D6 <-- Iy buffer	SWAP.W	D0	MUL.WU	D4,D0		; D4 <-- largeur*hauteur [bytes]	SWAP.W	D0	ADD.L	D4,#LGHIMA+IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour l'image	JUMP,NE EXIT$	LOAD.L	A1,A4		; A1 <-- ^buffer pour image	LOAD.L	D3,(A0)+ODFY	; D3 <-- origine source	COMP.B	(A0)+ODFCAD+1,#'R ; partie visible cale  droite ?	JUMP',NE SOR$		; non => SOR$	ADD.W	D3,(A0)+ODFDX	SUB.W	D3,D0		; D3 <-- origine source (cal  droite)SOR$:	LOAD.W	D5,(A0)+ODFIIY	; D5 <-- Iy source	LOAD.L	A3,(A0)+ODFABS	; A3 <-- ^source	CLR.L	D4		; D4 <-- origine destination	LOAD.L	A4,#(A1)+LGHIMA+IMLBUF ; A4 <-- ^destination	LOAD.L	D2,D0		; D2 <-- dimensions	LOAD.L	A2,A0		; A2 <-- ^descripteur	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE XCOLOR$	; oui => XCOLOR$	LOAD.W	D1,#LOADDOT	; D1 <-- mode	GRA_	RASTER		; buffer <-- cran noir/blanc	JUMP'	XEND$XCOLOR$:	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL ; D1 <-- mode	GRA_	CRASTER		; buffer <-- cran couleurXEND$:	LOAD.W	D1,D6		; D1 <-- Iy buffer	CLR.W	D2	LOAD.B	D2,(A0)+ODFCNP	; D2 <-- nb de bits/pixel	CLR.L	D5		; D5 <-- pas de CLUT active	LOAD.L	D6,(A0)+ODFCPF	JUMP',EQ OK$	TCOL_	GETACTIVE	; D6 <-- canal CLUT active	JUMP',NE OK$	LOAD.L	D5,D6		; D5 <-- canal CLUT active;;?	LOAD.L	A2,A0;;?	CLR.L	D5;;?	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales;;?	LOAD.W	D3,(A0)+OASKEY	; D3 <-- no clavier;;?	CALL	SRCNKEY		; A0 <-- ^variables utilisateur;;?	JUMP',NE DESC$;;?	LOAD.L	A2,(A0)+OPDDIS	; A2 <-- ^descripteur;;?DESC$:;;?	LOAD.L	A0,A2		; A0 <-- ^descripteur fentre activeOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;.IF 0; use	D0.W	canal de la fentre;	D1.W	compteur vertical;	D2.L	coordonne Y;X;	D5.W	nombre de ligne(s);	D6.W	canal de l'imprimante;	A4.L	^buffer tampon de(s) ligne(s);	A5.L	^status de la fentre;	A6.L	^variables locales	PUSHM.L	D0..D6,A0,A1,A3..A5; Cherche le canal de la fentre concerne.	COMP.B	D3,#-1		; toute la partie visible ?	JUMP',NE PART$		; non => PART$	PUSH.L	A3		; oui =>	LOAD.L	A3,#R16"NPDIS0	; A3 <-- ^nom $DIS_0	LOAD.W	D3,#2^BOPRD!2^BOPWR ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre le grand bitmap	POPM.L	A3	JUMP,NE	EXIT$	LOAD.W	D0,D6	TSET.L	D0:#31		; D0 <-- utilise grand bitmap	JUMP'	OPEPRI$PART$:	TCLR.L	D0:#31		; D0 <-- n'utilise pas bitmap	LOAD.W	D0,(A6)+OCHDIS	; D0 <-- canal pour l'cran	TEST.B	D3		; fentre utilise ?	JUMP',EQ OPEPRI$	; oui => OPEPRI$				; non =>	AND.W	D3,#H'FF	LIB	?SRCWDO		; D6 <-- canal de cette fentre	JUMP,NE	CLODIS$	LOAD.W	D0,D6		; D0 <-- canal pour l'cran; Ouvre l'imprimante (ou un fichier quelconque) en criture; exclusive.OPEPRI$:	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre l'imprimante (D6=canal)	JUMP,NE	CLODIS$; Demande les status de la fentre pour connatre la largeur; et la hauteur.	LOAD.L	D4,#LGDIS3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour status wdo	JUMP,NE	CLOPRI$	LOAD.L	A5,A4		; A5 <-- ^status fentre	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	TEST.L	D0:#31		; utilise le grand bitmap ?	JUMP',BC RDSTA$		; non => RDSTA$	LOAD.W	D3,#TYPDIS	; D3 <-- type grand bitmapRDSTA$:	PUSH.W	D6	LOAD.W	D6,D0		; D6 <-- canal de l'cran	FOS	?RSTATUS	POPM.W	D6	JUMP,NE GIVSTA$; S'il s'agit de toute la partie visible, initialise les; paramtres directement dans le buffer du status.	CLR.W	(A5)+ODFFX	; clear origine X	CLR.W	(A5)+ODFFY	; clear origine Y	TEST.L	D0:#31		; utilise le grand bitmap ?	JUMP',BC GETBUF$	; non => GETBUF$				; oui =>	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,(A0)+OPTTSK	; A0 <-- ^table des soft-keys	ADD.W	A0,(A0)+6	; A0 <-- ^table des dimensions	LOAD.L	(A5)+ODFFDY,(A0) ; init largeur/hauteur cran; Demande de la mmoire pour une ligne graphique de la; fentre et pour le header du fichier image.GETBUF$:	LOAD.W	D3,#8		; D3 <-- prend la moiti (pas plus !)	LOAD.L	D4,#LGHIMA+LGPRI0 ; D4 <-- lg minimale (buffer status)	LOAD.L	D5,#10000	; D5 <-- lg maximale (10 Kbytes)	LOAD.W	D1,#MTYPCP	; D1 <-- type compte mmoire	GESMEM	?GETPMEM	; A4 <-- ^tranche mmoire	JUMP,NE	GIVSTA$	LOAD.W	D5,(A5)+ODFFDX	; D5 <-- largeur fentre en pts	COMP.W	D5,(A5)+ODFFDY	; plus haut que large ?	JUMP',HS GETBUH$	; non => GETBUH$	LOAD.W	D5,(A5)+ODFFDY	; oui => prend la hauteurGETBUH$:	SR.W	D5,#3		; D5 <-- idem en bytes	INC.W	D5	DIV.WU	D4,D5		; D4 <-- nb de lignes	LOAD.W	D7,#ERNEMEM	LOAD.W	D5,D4		; D5 <-- nb de lignes	JUMP,EQ	GIVBUF$		; si aucune tranche => GIVBUF$; Vrifie s'il est possible d'effectuer le dump horizontalement,; en fonction de la largeur du papier de l'imprimante.	PUSH.L	A4	LOAD.W	D4,#(LGHIMA/2)-1CLR$:	CLR.W	(A4+)		; rempli header de zro	DECJ.W,NMO D4,CLR$	POP.L	A4	LOAD.B	(A4)+OIMTYP,#H'81	LOAD.B	(A4)+OIMBIP,#1	; 1 bit/point	LOAD.B	(A4)+OIMDIR,#2	; sens pour X et Y	LOAD.L	D4,#LGPRI0	LOAD.W	D3,#TYPPRI	; D3 <-- type driver printer	LOAD.L	A4,#(A4)+LGHIMA	FOS	?RSTATUS	LOAD.L	A4,#(A4)-LGHIMA	TEST.W	D7	JUMP',NE HORIZ$	LOAD.W	D1,(A4)+LGHIMA+OPRLGP ; D1 <-- largeur imprimable page	LOAD.W	D2,(A5)+ODFFDX	; D2 <-- largeur image en points	COMP.W	D2,(A5)+ODFFDY	; fentre plus haute que large ?	JUMP',LO HORIZ$		; oui => HORIZ$	SR.W	D2,#3		; D2 <-- idem /8	MUL.WU	D2,(A4)+LGHIMA+OPRGLX ; D2 <-- largeur image en 240me d'inch	COMP.W	D2,D1		; dump horizontal possible ?	JUMP,HI	VERT$		; non => VERT$; Met dans la tranche de mmoire toutes les informations; pour le header de l'image, puis crit le tout.HORIZ$:				; DUMP HORIZONTAL =>	LOAD.W	(A4)+OIMDLX,(A5)+ODFFDX	LOAD.W	(A4)+OIMDLY,(A5)+ODFFDY	LOAD.W	D1,(A5)+ODFFDX	SR.W	D1,#3	MUL.WU	D1,(A5)+ODFFDY	LOAD.L	(A4)+OIMNBB,D1	; nb total de bytes	LOAD.L	D4,#LGHIMA	; D4 <-- lg header image	FOS	?WRBYTE		; crit header image	JUMP,NE	GIVBUF$; Lit la fentre puis crit dans l'imprimante ligne par ligne.	LOAD.W	D1,(A5)+ODFFDY	; D1 <-- hauteur de l'image	LOAD.W	D2,(A5)+ODFFY	; D2 <-- coordonne Y	SWAP.W	D2	LOAD.W	D2,(A5)+ODFFX	; D2 <-- coordonne X	LOAD.L	A0,A4		; A0 <-- ^dbut du buffer	LOAD.W	A1,D5		; A1 <-- nb lignesHLOOPT$:	LOAD.L	A4,A0		; A4 <-- ^dbut du buffer	LOAD.W	D5,A1		; D5 <-- nb lignesHLOOPL$:	PUSHM.L	D6,A4	LOAD.L	D4,A4	INC.L	D4	TCLR.L	D4:#0		; A4 <-- fait comme .EVEN !	LOAD.L	A4,D4	LOAD.B	(A4)+0,#NUL	LOAD.B	(A4)+1,#GRAXY	; <GRAXY>	LOAD.W	(A4)+2,D2	; <xx>	SWAP.W	D2	LOAD.W	(A4)+4,D2	; <yy>	SWAP.W	D2	LOAD.L	D4,#1+5	LOAD.W	D6,D0		; D6 <-- canal de l'cran	FOS	?WRBYTE		; positionne curseur graphique	POPM.L	D6,A4	JUMP,NE	GIVBUF$	CLR.L	D4	LOAD.W	D4,(A5)+ODFFDX	; D4 <-- largeur fentre en pts	TSET.L	D4:#31		; D4 <-- graphique hor. demand	PUSH.W	D6	LOAD.W	D6,D0		; D6 <-- canal de l'cran	FOS	?RDBYTE		; lit une ligne graphique	POPM.W	D6	JUMP,NE	GIVBUF$	SR.W	D4,#3		; D4 <-- longueur en bytes	ADD.W	A4,D4		; A4 <-- ^pour ligne suivante	SWAP.W	D2	INC.W	D2		; D2 <-- coordonne Y suivante	SWAP.W	D2	DEC.W	D1		; encore une ligne ?	JUMP',EQ HWRITE$	; non => HWRITE$	DEC.W	D5		; encore place pour une ligne ?	JUMP,NE	HLOOPL$		; oui => HLOOPL$HWRITE$:			; non =>	LOAD.L	D4,A4	SUB.L	D4,A0		; D4 <-- longueur de toutes les lignes	LOAD.L	A4,A0		; A4 <-- ^dbut des lignes	FOS	?WRBYTE		; crit dans l'imprimante	JUMP,NE	GIVBUF$	TEST.W	D1		; encore une(des) ligne(s) ?	JUMP,NE	HLOOPT$		; oui => HLOOPT$	JUMP	GIVBUF$		; non => GIVBUF$VERT$:				; DUMP VERTICAL =>	LOAD.W	(A4)+OIMDLY,(A5)+ODFFDX	LOAD.W	D1,(A5)+ODFFDY	; D1 <-- hauteur en points	LOAD.B	D3,D1	SR.W	D1,#3		; D1 <-- hauteur en bytes	AND.B	D3,#B'111	; reste qq points ?	JUMP',EQ VHEAD$		; non => VHEAD$	INC.W	D1		; oui => faut un byte de plusVHEAD$:	CLR.L	D3	LOAD.W	D3,D1		; D3 <-- hauteur en bytes	SL.W	D3,#3		; D3 <-- hauteur en points	LOAD.W	(A4)+OIMDLX,D3	; init largeur (modulo byte)	SR.W	D3,#3		; D3 <-- hauteur en bytes	MUL.WU	D1,(A5)+ODFFDX	LOAD.L	(A4)+OIMNBB,D1	; nb total de bytes	LOAD.L	D4,#LGHIMA	; D4 <-- lg header image	FOS	?WRBYTE		; crit header image	JUMP,NE	GIVBUF$; Lit la fentre puis crit dans l'imprimante ligne par ligne.	LOAD.W	D1,(A5)+ODFFDX	; D1 <-- largeur de l'image	LOAD.W	D2,(A5)+ODFFY	; D2 <-- coordonne Y coin inf/gauche	ADD.W	D2,(A5)+ODFFDY	DEC.W	D2	SWAP.W	D2	LOAD.W	D2,(A5)+ODFFX	; D2 <-- coordonne X coin inf/gauche	LOAD.L	A0,A4		; A0 <-- ^dbut du buffer	LOAD.W	A1,D5		; A1 <-- nb lignesVLOOPT$:	LOAD.L	A4,A0		; A4 <-- ^dbut du buffer	LOAD.W	D5,A1		; D5 <-- nb lignesVLOOPL$:	PUSHM.L	D6,A4	LOAD.L	D4,A4	INC.L	D4	TCLR.L	D4:#0		; A4 <-- fait comme .EVEN !	LOAD.L	A4,D4	LOAD.B	(A4)+0,#NUL	LOAD.B	(A4)+1,#GRAXY	; <GRAXY>	LOAD.W	(A4)+2,D2	; <xx>	SWAP.W	D2	LOAD.W	(A4)+4,D2	; <yy>	SWAP.W	D2	LOAD.L	D4,#1+5	LOAD.W	D6,D0		; D6 <-- canal de l'cran	FOS	?WRBYTE		; positionne curseur graphique	POPM.L	D6,A4	JUMP,NE	GIVBUF$	CLR.L	D4	LOAD.W	D4,(A5)+ODFFDY	; D4 <-- hauteur fentre en pts	TSET.L	D4:#30		; D4 <-- graphique vert. demand	PUSH.W	D6	LOAD.W	D6,D0		; D6 <-- canal de l'cran	FOS	?RDBYTE		; lit une colonne graphique	POPM.W	D6	JUMP,NE	GIVBUF$	ADD.W	A4,D3		; A4 <-- ^pour colonne suivante	INC.W	D2		; D2 <-- coordonne X suivante	DEC.W	D1		; encore une colonne ?	JUMP',EQ VWRITE$	; non => VWRITE$	DEC.W	D5		; encore place pour une colonne ?	JUMP,NE	VLOOPL$		; oui => VLOOPL$VWRITE$:			; non =>	LOAD.L	D4,A4	SUB.L	D4,A0		; D4 <-- longueur de toutes les colonnes	LOAD.L	A4,A0		; A4 <-- ^dbut des colonnes	FOS	?WRBYTE		; crit dans l'imprimante	JUMP',NE GIVBUF$	TEST.W	D1		; encore une(des) colonne(s) ?	JUMP,NE	VLOOPT$		; oui => VLOOPT$				; non =>GIVBUF$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	; D1 <-- type compte mmoire	GESMEM	?GIVMEM		; rend la tranche mmoire	POP.W	D7GIVSTA$:	PUSH.W	D7	LOAD.L	A4,A5		; A4 <-- ^buffer status	LOAD.W	D1,#MTYPCP	; D1 <-- type compte mmoire	GESMEM	?GIVMEM		; rend la tranche mmoire	POP.W	D7CLOPRI$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'imprimante	POP.W	D7CLODIS$:	TEST.L	D0:#31		; utilise le grand bitmap ?	JUMP,BC	EXIT$		; non => EXIT$	PUSH.W	D7		; oui =>	LOAD.W	D6,D0		; D6 <-- canal de l'cran	FOS	?CLOSE		; ferme la fentre $DIS_0	POP.W	D7EXIT$:	POPM.L	D0..D6,A0,A1,A3..A5	RET.ENDIFNPDIS0:	.ASCIZ	/$DIS_0/	; nom physique grand bitmapNLPRIN:	.ASCIZ	/#PRINTER/	; nom de l'imprimante	.EVEN	.END