	.SBTTL	BLOCXFER.ASI;----------\\; XFERWRITE >;==========/; Ecrit le bloc-notes dans un fichier.; in	D3.W	page (0..n); out	D7.W	erreur; mod	D7.WXFERWRITE:	PUSHM.L	D3,A3,A4	CALL	WAITMOUSE	; met le sablier	TEST.L	(A6)+OPLIST	; liste existe ?	JUMP',EQ DISK$		; non => DISK$MEM$:	LOAD.L	A3,#(A6)+OFILE2	CALL	DISKNAME	; A3 <-- ^nom destination	CALL	XFERLISTWRITE	; bloc-notes --> fichier	JUMP'	EXIT$DISK$:	LOAD.L	A3,#(A6)+OFILE2	CALL	DISKNAME	; A3 <-- ^nom destination	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OFILE	LOAD.W	D3,#-1	CALL	DISKNAME	; A3 <-- ^nom source	CALL	XFERDUPLIQUE	; bloc-notes --> fichierEXIT$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; XFERREAD >;=========/; Lit un fichier dans le bloc-notes.; in	D3.W	page (0..n); out	D7.W	erreur; mod	D7.WXFERREAD:	PUSHM.L	D3,A3,A4	CALL	WAITMOUSE	; met le sablier	CALL	MEMFLUSH	; vide la liste	CALL	DISKFLUSH	; vide le fichier	LOAD.L	A3,#(A6)+OFILE2	CALL	DISKNAME	; A3 <-- ^nom source	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OFILE	LOAD.W	D3,#-1	CALL	DISKNAME	; A3 <-- ^nom destination	EX.L	A3,A4	CALL	XFERDUPLIQUE	; bloc-notes <-- fichier	CLR.B	(A6)+OIONF	; fichier existe	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------------\\; XFERLISTWRITE >;==============/; Ecrit le bloc-notes en mmoire dans un fichier.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WXFERLISTWRITE:	PUSHM.L	D3,D4,D6,A3,A4	FOS	?DELETE		; dtruit le fichier	LOAD.L	D3,#DEFATT-(2^BATTL)	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier	JUMP,NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP,NE EXIT$	LOAD.L	A4,#(A6)+ONAME	LOAD.L	A3,#(A6)+OHEAD+ODHNAMENAME$:	LOAD.B	(A3+),(A4+)	JUMP,NE NAME$	LOAD.L	(A6)+OHEAD+ODHTYPI,(A6)+OTYPI	LOAD.L	A4,#(A6)+OHEAD	LOAD.W	(A4)+ODHID,#IDENT	LOAD.L	D4,#LDH	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE CLOSE$	LOAD.L	A3,(A6)+OPLISTLOOP$:	LOAD.L	A4,#(A3)+OLILUSE	LOAD.L	D4,(A3)+OLILUSE	ADD.L	D4,#LDI	FOS	?WRBYTE		; crit une tranche	JUMP',NE CLOSE$	LOAD.L	D3,(A3)+OLINEXT	; D3 <-- ^bloc suivant	JUMP',EQ CLOSE$	LOAD.L	A3,D3		; A4 <-- ^bloc suivant	JUMP	LOOP$CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7EXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; XFERDUPLIQUE >;=============/; Duplique un fichier dans un autre.; in	A3.L	^nom du fichier source;	A4.L	^nom du fichier destination; out	D7.W	erreur; mod	D7.WXFERDUPLIQUE:	PUSHM.L	D1..D6,A1..A4	LOAD.L	A2,A3		; A2 <-- ^nom source	LOAD.L	A3,A4		; A3 <-- ^nom destination	LOAD.L	D4,#DISKLGB	LOAD.L	D1,#MTYPUSER	LOAD.L	A1,(A6)+OCTMEM	GESMEM	?GETMEM		; demande mmoire pour buffer	JUMP,NE EXIT$	LOAD.L	A1,A4		; A1 <-- ^buffer	FOS	?DELETE		; dtruit le fichier	LOAD.L	D3,#DEFATT-(2^BATTL)	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier	JUMP,NE GIVE$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier destination	JUMP,NE GIVE$	LOAD.W	D5,D6	LOAD.L	A3,A2	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier source	JUMP,NE CLWR$LOOP$:	LOAD.L	A4,A1	LOAD.L	D4,#DISKLGB	FOS	?RDBYTE		; lit une tranche	LOAD.W	D3,D7	TEST.L	D4	JUMP',EQ END$	EX.L	D5,D6	FOS	?WRBYTE		; crit une tranche	EX.L	D6,D5	JUMP',NE CLRD$END$:	LOAD.W	D7,D3	JUMP,EQ LOOP$	COMP.W	D7,#EROUTF	JUMP',NE CLRD$	CLR.W	D7CLRD$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier source	POP.W	D7CLWR$:	PUSH.W	D7	LOAD.W	D6,D5	FOS	?CLOSE		; ferme le fichier destination	POP.W	D7GIVE$:	PUSH.W	D7	LOAD.L	A4,A1		; A4 <-- ^buffer	LOAD.L	D1,#MTYPUSER	LOAD.L	A1,(A6)+OCTMEM	GESMEM	?GIVMEM		; libre mmoire pour buffer	POP.W	D7EXIT$:	POPM.L	D1..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; XFERDEL >;========/; Supprime une page.; in	D3.W	page  supprimer (0..n); out	-; mod	D7.WXFERDEL:	PUSHM.L	D3,D4,A3,A4	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#(A6)+OFILE	CALL	DISKNAME	; A3 <-- ^nom actuel	FOS	?DELETE	LOAD.W	D4,(A6)+OSCVAR+OSCHTVLOOP$:	LOAD.L	A3,#(A6)+OFILE2	CALL	DISKNAME	; A3 <-- ^nouveau nom	LOAD.L	A4,A3	INC.W	D3	LOAD.L	A3,#(A6)+OFILE	CALL	DISKNAME	; A3 <-- ^nom actuel	FOS	?RENAME	COMP.W	D3,D4	JUMP,LO LOOP$END$:	DEC.W	(A6)+OSCVAR+OSCHTV	POPM.L	D3,D4,A3,A4	RET;----------\\; DISKCOUNT >;==========/; Compte le nombre de pages du classeur, si ncessaire.; in	-; out	-; mod	D7.WDISKCOUNT:	PUSHM.L	D2..D4,D6,A3	COMP.W	(A6)+OSCVAR+OSCHTV,#-1 ; nb de pages connus ?	JUMP',NE EXIT$		; oui => EXIT$	CALL	WAITMOUSE	; souris: met le sablier	CLR.W	D2	CLR.W	D4LOOP$:	LOAD.L	A3,#(A6)+OFILE	LOAD.W	D3,D2	CALL	DISKNAME	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; fichier existe ?	JUMP',NE END$		; non => END$	FOS	?CLOSE	INC.W	D2		; D2 <-- numro suivant	INC.W	D4		; D4 <-- un fichier de plus	JUMP	LOOP$END$:	LOAD.W	(A6)+OSCVAR+OSCHTV,D4EXIT$:	POPM.L	D2..D4,D6,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DISKNAME >;=========/; Construit le nom du fichier bloc-notes.; in	A3.L	^buffer;	D3.W	numro (-1,0..n); out	(A3)++	^nom du fichier bloc-notes; mod	D7.WDISKNAME:	PUSHM.L	D1..D4,A3,A4	LOAD.L	A4,A3		; A4 <-- ^buffer pour le nom	LOAD.W	D1,D3	LOAD.L	A3,#R16"NAME1$XFER1$:	LOAD.B	(A4+),(A3+)	; OFILE <-- dbut	JUMP,NE XFER1$	DEC.L	A4	NTREL	?GETMACHINE	; D4/A3 <-- numro/nom	AND.L	D4,#H'00FFFFFF	LOAD.W	D3,#6	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LIB	?PUTDEC		; OFILE <-- numro de la machine	LOAD.B	(A4+),#'_	TEST.W	D1	JUMP',NS BN$	CLR.L	D4	LOAD.W	D4,D1	INC.W	D4		; D4 <-- 1..n	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode tout	LIB	?PUTDEC		; OFILE <-- numro	JUMP'	NUM$BN$:	LOAD.B	(A4+),#'X	LOAD.B	(A4+),#'XNUM$:	LOAD.L	A3,#R16"NAME2$XFER2$:	LOAD.B	(A4+),(A3+)	; OFILE <-- fin	JUMP,NE XFER2$	POPM.L	D1..D4,A3,A4	RETNAME1$:	.ASCIZ	"#:"NAME2$:	.ASCIZ	".BLOC"	.EVEN	.END