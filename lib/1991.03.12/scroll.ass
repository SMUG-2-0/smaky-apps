	.TITLE		SCROLL.ASS	.PROC		M68000			; mnmonics CALM 	.BASE		10'10			; base 10 par dfaut;	.LAYOUT		HEX			; listing en hexadcima; Numros des appels; ------------------	.SYSCALL.16	SCROLL_SCROLL_DRAW	=	16'A8C0			; dessine la cage de l'ascenseurSCROLL_UPDATE	=	16'A8C1			; dessine la cabine de l'ascenseurSCROLL_MOVE	=	16'A8C2			; dplace l'ascenseur avec la sourisSCROLL_PRESS	=	16'A8C3			; presse/relche un "bouton"SCROLL_SCALE	=	16'A8C4			; dessine une chelleSCROLL_LDIM	=	16'A8C5			; arrondi les dimensionsSCROLL_LDRAW	=	16'A8C6			; dessine le rectangle de la listeSCROLL_LUPDATE	=	16'A8C7			; dessine la listeSCROLL_LMOVE	=	16'A8C8			; dplace dans la listeSCROLL_LINVCASE	=	16'A8C9			; inverse une caseSCROLL_RUPDATE	=	16'A8CA			; dessine les rgles graduesSCROLL_RMOUSE	=	16'A8CB			; dessine la position de la sourisSCROLL_FIRST	=	SCROLL_DRAWSCROLL_LAST	=	SCROLL_RMOUSE; Constantes; ----------LGSCROLL	=	16			; largeur/hauteur de l'ascenseurLGREGLE		=	16			; largeur d'une rgleGCRGF		=	"N"			; fonte des rgles (NEF07)GCRGS		=	"E".OR.2**7		; style des rglesGCRGT		=	07			; taille des rgles; "Boutons" rendus dans D4.16 par SCROLL_MOVE; ------------------------------------------SCROLLFUP	=	1			; flche suprieure "clique"SCROLLFDOWN	=	2			; flche infrieure "clique"SCROLLPUP	=	3			; page suprieure "clique"SCROLLPDOWN	=	4			; page infrieure "clique"; Variables d'un ascenseur; ------------------------	.LOC	0OSCHOR:		.BLK.8		1		; 0 => vertical et 1 => horizontalOSCPAGE:	.BLK.8		1		; 1 => avance par pages possible	.EVENOSCDEB:OSCDEBO:	.BLK.16		1		; dbut parallle  l'ascenseurOSCDEBL:	.BLK.16		1		; dbut perpendiculaire  l'ascenseurOSCHTR:		.BLK.16		1		; hauteur relle de l'ascenseurOSCHTV:		.BLK.16		1		; hauteur virtuelle de l'ascenseurOSCPOSR:	.BLK.16		1		; position relle de l'ascenseurOSCPOSV:	.BLK.16		1		; position virtuelle de l'ascenseurOSCINC:		.BLK.16		1		; incrment avec les flchesOSCMARK:	.BLK.8		1		; 1 => marqueur dans la cabine		.BLK.8		1		; rserveOSCHTC:		.BLK.16		1		; hauteur de la cabine		.BLK.8		16		; rserveLSCVAR:; Variables d'une liste; ---------------------	.LOC	0OSLASV:		.BLK.8		LSCVAR		; ascenseur  gauche du rectangleOSLCABV:	.BLK.8		1		; 1 => cabine dessine	.EVENOSLASH:		.BLK.8		LSCVAR		; ascenseur en bas du rectangleOSLCABH:	.BLK.8		1		; 1 => cabine dessine	.EVENOSLVID:		.BLK.8		1		; 1 => case vide en haut existeOSLHOR:		.BLK.8		1		; 1 => ascenseur horizontal existeOSLVII:		.BLK.8		1		; 1 => case vide inverse	.EVENOSLADL:		.BLK.32		1		; adresse routine donne texteOSLADA:		.BLK.32		1		; adresse routine affiche texteOSLPOS:		.BLK.32		1		; coin sup/gaucheOSLDIM:		.BLK.32		1		; dimensions du rectangle en pointsOSLCAR:		.BLK.32		1		; dimensions d'un caractreOSLC1X:		.BLK.16		1		; rfrence gaucheOSLC1Y:		.BLK.16		1		; hauteur dessus la ligne de baseOSLC2Y:		.BLK.16		1		; hauteur dessous la ligne de baseOSLNBY:		.BLK.16		1		; nb de lignes visiblesOSLNBX:		.BLK.16		1		; nb de caractres visiblesOSLCYN:		.BLK.16		1		; nb de cases (0..n)OSLCYS:		.BLK.16		1		; case slectionne (0..OSLCYN-1)OSLCYA:		.BLK.16		1		; premire case afficheOSLCXN:		.BLK.16		1		; nb de cases (0..n)OSLCXA:		.BLK.16		1		; premire case affiche		.BLK.8		32		; rserveLSLVAR:; Variables d'une double rgle; ----------------------------	.LOC	0ORGHPO:		.BLK.32		1		; position coin sup/gaucheORGHLG:		.BLK.16		1		; longueur (zro = pas d'chelle)ORGHPA:		.BLK.16		1		; pas (nb points par mm)*64ORGHOR:		.BLK.16		1		; origine (points)ORGHSC:		.BLK.16		1		; chelle (-rduction et +agrandissement)ORGHMI:		.BLK.8		1		; 1 => rgle en bas		.BLK.8		10		; rserve	.EVENORGVPO:		.BLK.32		1		; position coin sup/gaucheORGVLG:		.BLK.16		1		; longueur (zro = pas d'chelle)ORGVPA:		.BLK.16		1		; pas (nb points par mm)*64ORGVOR:		.BLK.16		1		; origine (points)ORGVSC:		.BLK.16		1		; chelle (-rduction et +agrandissement)ORGVMI:		.BLK.8		1		; 1 => rgle  gaucheORGVHB:		.BLK.8		1		; 1 => graduation de haut en bas		.BLK.8		10		; rserve	.EVENORGPOS:		.BLK.32		1		; position de la souris		.BLK.8		4		; rserveORGBUF:		.BLK.8		30		; buffer temporaireORGFLE:		.BLK.8		1		; 1 => flches prsentes	.EVEN		.BLK.8		32		; rserveLRGVAR:; REMARQUE:	les variables d'un ascenseur, d'une liste ou;		d'une rgle doivent tre remplies intgralement;		de zro avant emploi !;------------\\; SCROLL_DRAW >;============/; Dessine la cage de l'ascenseur vide, avec les flches suprieure; et infrieure, et ventuellement les pages.; L'cran sous la cage de l'ascenseur est effac automatiquement.; La trame et la cabine ne sont pas dessines. Un ascenseur dans cet tat; correspond  un ascenseur inactif, soit parce qu'il n'est pas possible; de cliquer dedans avec la souris, soit parce que la fentre reprsente; la totalit de l'information.; in	A5.32		^variables de l'ascenseur;	{A5}+OSCDEB.32	coin sup/gauche;	{A5}+OSCHTR.16	hauteur relle;	{A5}+OSCHOR.8	T => horizontal et F => vertical;	{A5}+OSCPAGE.8	T => avance par pages possible; out	-; mod	D7.16;-------------\\; SCROLL_SCALE >;=============/; Dessine  droite ou en bas d'un ascenseur une chelle gradue.; in	A5.32		^variables de l'ascenseur;	{A5}+OSCDEB.32	coin sup/gauche;	{A5}+OSCHTR.16	hauteur relle;	{A5}+OSCHOR.8	T => horizontal et F => vertical;	{A5}+OSCPAGE.8	T => avance par pages possible;	D3.16		nombre de divisions (2..n);	D4.16		longueur des divisions (1..n);	A3.32		^liste des textes/^nil;			 n .ASCIZ  la suite (n=D3+1);			 seulement si ascenseur vertical !;	A0.32		^description de la fentre; out	-; mod	D7.16;--------------\\; SCROLL_UPDATE >;==============/; Met  jour la cabine de l'ascenseur.; On utilise cet appel lorsque l'ascenseur bouge (OSCPOSV ou OSCHTV; modifis par un vnement extrieur au module SCROLL).; Lorsque l'ascenseur bouge avec SCROLL_MOVE, cet appel n'est pas; ncessaire.; (m) = peut tre modifi; in	A5.32		^variables de l'ascenseur;	{A5}+OSCDEB.32	coin sup/gauche;	{A5}+OSCHTR.16	hauteur relle;	{A5}+OSCHOR.8	T => horizontal et F => vertical;	{A5}+OSCPAGE.8	T => avance par pages possible;	{A5}+OSCMARK.8	T => marqueur dans la cabine;	{A5}+OSCHTV.16	hauteur virtuelle (m);	{A5}+OSCPOSV.16	position virtuelle (m); out	{A5}+OSCPOSR.16	position relle; mod	D7.16;------------\\; SCROLL_MOVE >;============/; Dplace l'ascenseur jusqu' ce qu'un bouton de la souris soit press; ou relch.; Si la souris n'est pas dans la cage de l'ascenseur, on revient tout; de suite avec une erreur (D7=ERDIOUT).; Si la souris est dans un bouton (flche/page), on revient tout de suite; (sans attendre que la souris soit relche) avec SCROLL(F/P)(UP/DOWN).; On peut alors utiliser SCROLL_PRESS (pour allumer le bouton), attendre; que la souris soit relche, puis utiliser SCROLL_PRESS une deuxime fois; (pour teindre le bouton). Pendant ce temps, il est possible de faire; dfiler l'cran, comme dans TEXT.; (m) = peut tre modifi; in	D4.32		position de la souris;	A5.32		^variables de l'ascenseur;	{A5}+OSCDEB.32	coin sup/gauche;	{A5}+OSCHTR.16	hauteur relle;	{A5}+OSCHOR.8	T => horizontal et F => vertical;	{A5}+OSCPAGE.8	T => avance par pages possible;	{A5}+OSCMARK.8	T => marqueur dans la cabine;	{A5}+OSCHTV.16	hauteur virtuelle (m);	{A5}+OSCPOSV.16	position virtuelle (m);	{A5}+OSCINC.16	incrment si flche (m); out	D3.16		touche presse ou bouton press/relch;	D4.16		bouton press SCROLL(F/P)(UP/DOWN);			zro => souris pas dans un bouton;	{A5}+OSCPOSV.16	nouvelle position virtulle;	{A5}+OSCPOSR.16	nouvelle position relle;	D7.16		erreur (souris pas dans l'ascenseur); mod	D3.32, D4.32, D7.16;-------------\\; SCROLL_PRESS >;=============/; Inverse un bouton (flche/page).; Il faut toujours utiliser deux fois cet appel, la premire fois; pour allumer et la deuxime fois pour teindre.; in	D4.16		bouton press SCROLL(F/P)(UP/DOWN);	A5.32		^variables de l'ascenseur;	{A5}+OSCDEB.32	coin sup/gauche;	{A5}+OSCHTR.16	hauteur relle;	{A5}+OSCHOR.8	T => horizontal et F => vertical;	{A5}+OSCPAGE.8	T => avance par pages possible; out	-; mod	D7.16;-------------\\; _SCROLL_LDIM >;=============/; Arrondi les dimensions du rectangle extrieur en fonction; du caractre utilis. Les dimensions rendues sont toujours; plus petites ou gales aux dimensions fournies.; in	A5.32		^variables de la liste;	A0.32		^description de la fentre;	{A5}+OSLVID.8	1 => case vide en haut;	{A5}+OSLHOR.8	1 => ascenseur horizontal;	{A5}+OSLPOS.32	coin sup/gauche (y;x);	{A5}+OSLDIM.32	dimensions (dy;dx); out	{A5}+OSLDIM.32	dimensions arrondies;	D7.16		erreur (ERDIOUT = trop petit); mod	D7.16;--------------\\; _SCROLL_LDRAW >;==============/; Dessine le rectangle avec la cage de l'ascenseur vide.; L'cran sous le rectangle est effac automatiquement.; in	A5.32		^variables de la liste;	A0.32		^description de la fentre;	{A5}+OSLVID.8	1 => case vide en haut;	{A5}+OSLHOR.8	1 => ascenseur horizontal;	{A5}+OSLPOS.32	coin sup/gauche (y;x);	{A5}+OSLDIM.32	dimensions (dy;dx);	A3.32		^texte pour case vide (si OSLVID=1); out	{A5}+OSLDIM.32	dimensions arrondies;	D7.16		erreur (ERDIOUT = trop petit); mod	D7.16;----------------\\; _SCROLL_LUPDATE >;================/; Met  jour la liste et l'ascenseur.; On utilise cet appel lorsque la liste change ou bouge; par un vnement extrieur au module SCROLL.; Lorsque l'ascenseur bouge avec SCROLL_LMOVE, cet appel n'est pas; ncessaire.; in	A5.32		^variables de la liste;	A0.32		^description de la fentre;	{A5}+OSLADL.32	adresse routine liste, voir (*);	{A5}+OSLADA.32	adresse routine liste, voir (%);	{A5}+OSLCYN.16	nombre total de cases;	{A5}+OSLCXN.16	idem, horizontalement;	{A5}+OSLCYS.16	case slectionne (-1, 0..OSLCYN-1); out	{A5}+OSLCYA.16	premire case affiche;	{A5}+OSLCXA.16	idem, horizontalement;	D7.16		erreur; mod	D7.16; (*)	OSLADL.32 doit contenir l'adresse d'une routine extrieure;	au module SCROLL qui doit ragir comme suit :;; Donne le pointeur au texte  afficher dans une case.;; in	A6.32	^vos variables;	D3.16	rang de la case (0..OSLCYN-1); out	D3.16	zro	-->	rien;		un	-->	ligne pointille horizontale en bas de la case;		deux	-->	ligne pleine horizontale en bas de la case;		trois	-->	ligne double horizontale en bas de la case;	A3.32	^contenu de la case termin par <0> ou <CR>;	D7.16	erreur si la case est vide; mod	D3.32, D7.16, A3.32;; ATTENTION:	Cette routine ne doit en aucun cas modifier;		d'autres registres !; (%)	OSLADA.32 doit contenir l'adresse d'une routine extrieure;	au module SCROLL qui doit ragir comme suit :;; Affiche le texte dans une case. Il est conseill de mettre un; espace avant le texte et un autre aprs. Il faut toujours; afficher un nombre de caractres exactement gal  D4.;; in	A6.32	^vos variables;	D3.16	rang de la case (0..OSLCYN-1);	D4.16	nb de caractres;	D5.16	rang du premier caractre  afficher; out	D3.16	zro; mod	D3.32, D7.16;; ATTENTION:	Cette routine ne doit en aucun cas modifier;		d'autres registres !; Il faut utiliser OSLADL.32 ou OSLADA.32 selon vos besions.; Celle qui n'est pas utilise doit contenir zro.;--------------\\; _SCROLL_LMOVE >;==============/; Dplace l'ascenseur ou une case jusqu' ce qu'un bouton; soit press ou relch.; Si la souris n'est pas dans le rectangle, on revient tout; de suite avec une erreur (D7=ERDIOUT).; OSLCYS.16 contient -1 lorsque la case vide tout en haut; est slectionne.; in	D4.32		position de la souris;	A5.32		^variables de la liste;	A0.32		^description de la fentre;	{A5}+OSLADL.32	adresse routine liste, voir (*);	{A5}+OSLADA.32	adresse routine liste, voir (%); out	{A5}+OSLCYS.16	case slectionne (-1, 0..OSLCYN-1);	D7.16		erreur (souris pas dans la liste); mod	D7.16;-----------------\\; _SCROLL_LINVCASE >;=================/; Inverse une case.; in	A5.32	^variables de la liste;	D3.16	rang de la case (-1, 0..n); out	-; mod	D7.16;---------------\\; _SCROLL_RMOUSE >;===============/; Dessine la position de la souris dans les rgles horizontales; et verticales, sous la forme de deux petites flches.; Avant d'effacer la fentre, ne pas oublier d'effacer les; flches (avec D4.32=0) !; Les flches utilisent les lutins numros 14 et 15, qui ne; peuvent donc pas tre utiliss dans le programme appelant.; in	D4.32		position de la souris (y;x);			(zro efface les flches);	A5.32		^variables;	{A5}+ORGPOS.32	ancienne position de la souris;			rgle horizontale :;	{A5}+ORGHPO.32	position coin sup/gauche (y;x);	{A5}+ORGHLG.16	largeur (dx), zro = pas de rgle;	{A5}+ORGHMI.8	1 => rgle en bas;			rgle verticale :;	{A5}+ORGVPO.32	position coin sup/gauche (y;x);	{A5}+ORGVLG.16	hauteur (dy), zro = pas de rgle;	{A5}+ORGVMI.8	1 => rgle  gauche;	A0.32		^descripteur de la fentre; out	{A5}+ORGPOS.32	nouvelle position de la souris;	D7.16		erreur; mod	D7.16;----------------\\; _SCROLL_RUPDATE >;================/; Dessine les rgles horizontales et verticales, gradues; en centimtres.; Un rectangle est dessin autour de chaque rgle.; Utilise le gencar NEF07 pour les graduations, qui doit ; exister sur disque. Le gencar courant n'est pas chang.; La rgle horizontale doit tre distante d'au moins huit; points des bords gauche et droite de la (sous-)fentre.; La rgle verticale doit tre distante d'au moins huit; points des bords suprieur et infrieur de la (sous-)fentre.; Le "pas" correspond  la distance (en points) entre deux; graduations millimtriques, multipli par 64 pour viter les; erreurs cumules d'arrondis.; L'"origine" (en points) dtermine o dbute la graduation.; L'"chelle" influence le "pas". Par exemple, -2 correspond;  une rduction de deux (les graduations seront donc deux fois; plus serres). +1 ou 0 correspond  l'chelle 1:1.; in	A5.32		^variables;	{A5}+ORGPOS.32	ancienne position de la souris;			rgle horizontale :;	{A5}+ORGHPO.32	position coin sup/gauche (y;x);	{A5}+ORGHLG.16	largeur (dx), zro = pas de rgle;	{A5}+ORGHPA.16	pas (nb points par mm)*64;	{A5}+ORGHOR.16	origine (points);	{A5}+ORGHSC.16	chelle (-rduction et +agrandissement);	{A5}+ORGHMI.8	1 => rgle en bas;			rgle verticale :;	{A5}+ORGVPO.32	position coin sup/gauche (y;x);	{A5}+ORGVLG.16	hauteur (dy), zro = pas de rgle;	{A5}+ORGVPA.16	pas (nb points par mm)*64;	{A5}+ORGVOR.16	origine (points);	{A5}+ORGVSC.16	chelle (-rduction et +agrandissement);	{A5}+ORGVMI.8	1 => rgle  gauche;	{A5}+ORGVHB.8	1 => graduation de haut en bas;	A0.32		^descripteur de la fentre; out	D7.16		erreur; mod	D7.16;---------------\\; _SCROLL_RMOUSE >;===============/; Dessine la position de la souris dans les rgles horizontales; et verticales, sous la forme de deux petites flches.; Avant d'effacer la fentre, ne pas oublier d'effacer les; flches (avec D4.32=0) !; Les flches utilisent les lutins numros 14 et 15, qui ne; peuvent donc pas tre utiliss dans le programme appelant.; in	D4.32		position de la souris (y;x);			(zro efface les flches);	A5.32		^variables;	{A5}+ORGPOS.32	ancienne position de la souris;			rgle horizontale :;	{A5}+ORGHPO.32	position coin sup/gauche (y;x);	{A5}+ORGHLG.16	largeur (dx), zro = pas de rgle;	{A5}+ORGHMI.8	1 => rgle en bas;			rgle verticale :;	{A5}+ORGVPO.32	position coin sup/gauche (y;x);	{A5}+ORGVLG.16	hauteur (dy), zro = pas de rgle;	{A5}+ORGVMI.8	1 => rgle  gauche;	A0.32		^descripteur de la fentre; out	{A5}+ORGPOS.32	nouvelle position de la souris;	D7.16		erreur; mod	D7.16	.END