	.TITLE	PUTREV.ASC;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY; Variables; ---------	.LOC	0OHEAD:	.BLKB	256LGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.B	(A6)+OHEAD+OBXTYP,#2^BBXREL	LOAD.L	A3,#R16"TEXTID	LOAD.L	A4,#(A6)+OHEAD+OBXIDE20$:	LOAD.B	(A4+),(A3+)	JUMP,NE 20$	LIB	?AFTIM	.B	EOP,CR,CR	.ASCIZ	"Numro de rvision : "	.EVEN	LIB	?GETDEC	COMP.W	D3,#CR	JUMP,NE FINI	LOAD.B	(A6)+OHEAD+OBXREV,D4	LIB	?AFTIM	.B	CR,CR	.ASCIZ	"Numro de version  : "	.EVEN	LIB	?GETDEC	COMP.W	D3,#CR	JUMP,NE FINI	LOAD.B	(A6)+OHEAD+OBXVER,D4	LOAD.L	A3,#R16"NAME	FOS	?DELETE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	LOAD.L	A4,#(A6)+OHEAD	LOAD.L	D4,#256	FOS	?WRBYTE	FOS	?CLOSEFINI:ERFAT1:	LIB	?CLOLIB	FOS	?STOPTEXTID:	.ASCIZ	"(C) EPSITEC system sa"NAME:	.ASCIZ	"SYSTEM.CODE"	.EVEN	.END	START