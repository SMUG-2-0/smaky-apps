	.SBTTL	LIBOMODU	.IF	OLDMODU;-----------\; _OPEMODULE >;===========/; Ouvre un module. Si ncessaire, le module est charg en; mmoire.; in	A3.L	^nom du module; out	A5.L	^adresse de base du module;	D7.W	erreur; mod	D7.W, A5.L_OPEMODULE:	PUSHM.L	D0,D1,D2,D3,D4,A0,A1,A2,A3,A4	LOAD.L	A0,(A6)+OPGLOB	; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAO	NTREL	?LOCK		; dbut zone critique	JUMP,NE	95$; Cherche si le module demand est dj utilis par quelqu'un; d'autre.	CALL	SRCMODULE	; cherche le module	JUMP,EQ	50$		; dj utilis => 50$; Cherche une place libre dans la table pour stocker le; nouveau module.	LOAD.L	A1,#(A0)+OBUMOD	; A1 <-- ^buffer modules	LOAD.W	D1,#MAXMOD	; D1 <-- nb max modules30$:	TEST.W	(A1)+OMODCP	; lment utilis ?	JUMP',EQ 40$		; non => 40$	ADD.L	A1,#LGMOD	; A1 <-- ^lment suivant	DEC.W	D1	JUMP,NE	30$	LOAD.W	D7,#ERLMFU	; D7 <-- "trop de modules"	JUMP	90$; Occupe un nouvel lment dans la table pour un module.40$:	FOS	?LOAD		; charge le module en mmoire	JUMP,NE	90$	LOAD.L	(A1)+OMODAD,A4	; mm. adresse de base	LOAD.W	D1,#MTYPCP	; D1 <-- type compte source	LOAD.W	D2,#MTYPAB	; D2 <-- type compte dest.	LOAD.L	A2,ADGSMC	; A2 <-- ^compte dest. (FOS !)	GESMEM	?TRAMEM		; transfert mmoire du module	JUMP,NE	90$	LOAD.L	A4,#(A1)+OMODNA	; A4 <-- ^place pour nom42$:	LOAD.B	D3,(A3+)	JUMP',EQ 45$	COMP.B	D3,#CR	JUMP',EQ 45$	COMP.B	D3,#SPACE	JUMP',EQ 45$	LOAD.B	(A4+),D3	; buffer <-- nom	JUMP	42$45$:	CLR.B	(A4)		; termine le nom; Utilise une fois de plus un module dj utilis.50$:	INC.W	(A1)+OMODCP	; une utilisation de plus	LOAD.L	A5,(A1)+OMODAD	; A5 <-- adresse de base	CLR.W	D7		; D7 <-- ok90$:	PUSHM.L	D7,A5	LOAD.L	A5,(A0)+OSEMAO	NTREL	?UNLOCK		; fin zone critique	POPM.L	D7,A595$:	POPM.L	D0,D1,D2,D3,D4,A0,A1,A2,A3,A4	RET;-----------\; _CLOMODULE >;===========/; Ferme un module. Si ncessaire, le module est libr de; la mmoire.; in	A3.L	^nom du module; out	D7.W	erreur; mod	D7.W_CLOMODULE:	PUSHM.L	D1,A0,A1,A4,A5	LOAD.L	A0,(A6)+OPGLOB	; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAO	NTREL	?LOCK		; dbut zone critique	JUMP',NE 95$	CALL	SRCMODULE	; cherche le module	JUMP',NE 90$		; pas trouv => 90$	DEC.W	(A1)+OMODCP	; une utilisation de moins	JUMP',NE 90$		; si encore d'autres => 90$				; si plus personne =>	LOAD.L	A4,(A1)+OMODAD	; A4 <-- ^base du module	LOAD.W	D1,#MTYPAB	; D1 <-- type compte dest.	LOAD.L	A1,ADGSMC	; A1 <-- ^compte dest. (FOS !)	GESMEM	?GIVMEM		; rend la mmoire du module90$:	PUSH.W	D7	LOAD.L	A5,(A0)+OSEMAO	NTREL	?UNLOCK		; fin zone critique	POP.W	D795$:	POPM.L	D1,A0,A1,A4,A5	RET;----------\; SRCMODULE >;----------/; Cherche un module dans la table en fonction de son nom.; in	A3.L	^nom; out	A1.L	^dans table module;	D7.W	erreur; mod	D7.W, A1.LSRCMODULE:	PUSHM.L	D1,A2,A4	LOAD.L	A1,#(A0)+OBUMOD	; A1 <-- ^buffer modules	LOAD.W	D1,#MAXMOD	; D1 <-- nb max modules10$:	TEST.W	(A1)+OMODCP	; lment utilis ?	JUMP',EQ 15$		; non => 15$	LOAD.L	A4,#(A1)+OMODNA	; A4 <-- ^nom de l'lment	LOAD.L	A2,#R16"00$	; A2 <-- ^terminateurs	LIB	?CPSTRING	; mme nom ?	TEST.W	D7	JUMP',EQ 90$		; oui => 90$15$:	ADD.L	A1,#LGMOD	; A1 <-- ^lment suivant	DEC.W	D1	JUMP,NE	10$	LOAD.W	D7,#ERLMNO	; D7 <-- "module pas ouvert"90$:	POPM.L	D1,A2,A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0,CR,SPACE,-1	.EVEN	.ELSE_OPEMODULE:_CLOMODULE:	LOAD.W	D7,#ERLMNO	; D7 <-- erreur (!)	RET	.ENDIF	.END