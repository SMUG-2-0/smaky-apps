	.TITLE	SCROLL.ASL	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcima	.REF	SMAKY	.REF	MODULES	.REF	COLORS; Date		Rev	Amliorations; -------------------------------------------------------------------------------------; 13.09.88	2.8	SCROLL_LUPDATE met toujours trait fin dernire case; 24.05.88	2.7	SCROLL_LMOVE utilise scroll up/down;			si CALL (OSLADL) retourne D3=1 --> ligne pointille; 13.04.88	2.6	et vive la couleur ...; 02.03.88	2.5	rgles: dizaines en gras; 16.02.88	2.4	rgles: plus jolies (n'utilisent plus NEF07);			rgles: graduation ok jusqu' 2 mtres; 14.12.87	2.3	SCROLL_RUPDATE ok si hauteur > 512; 24.06.87	2.2	liste: pages dans ascenseur vertical possibles; 20.01.87	2.1	ascenseur: possible mme si trs court	.REV	2,8	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; En-tte du module LIB; ---------------------	.LOC	0	SCROLL_	FIRST		; code du premier appel	SCROLL_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	2,8		; rvision.version	.W	0,END_SCROLL	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"SCROLL"	; nom du module	.FILLB	(LGHLIB-.),0	.W	_SCROLL_DRAW	.W	_SCROLL_UPDATE	.W	_SCROLL_MOVE	.W	_SCROLL_PRESS	.W	_SCROLL_SCALE	.W	_SCROLL_LDIM	.W	_SCROLL_LDRAW	.W	_SCROLL_LUPDATE	.W	_SCROLL_LMOVE	.W	_SCROLL_LINVCASE	.W	_SCROLL_RUPDATE	.W	_SCROLL_RMOUSE; Codes des appels; ----------------;-------------\\; _SCROLL_MOVE >;=============/; Dplace l'ascenseur jusqu' ce qu'un bouton soit press ou relch.; Si la souris n'est pas dans la cage de l'ascenseur, on revient tout; de suite avec une erreur (D7=ERDIOUT).; (m) = peut tre modifi; in	D4.L		position de la souris;	A5.L		^variables de l'ascenseur;	(A5)+OSCDEB.L	coin sup/gauche;	(A5)+OSCHTR.W	hauteur relle;	(A5)+OSCHOR.B	T => horizontal et F => vertical;	(A5)+OSCPAGE.B	T => avance par pages possible;	(A5)+OSCMARK.B	T => marqueur dans la cabine;	(A5)+OSCHTV.W	hauteur virtuelle (m);	(A5)+OSCPOSV.W	position virtuelle (m);	(A5)+OSCINC.W	incrment si flche (m); out	D3.W		touche presse ou bouton press/relch;	D4.W		SCROLL(F/P)(UP/DOWN);	(A5)+OSCPOSV.W	nouvelle position virtulle;	(A5)+OSCPOSR.W	nouvelle position relle;	D7.W		erreur (souris pas dans l'ascenseur); mod	D3.L, D4.L, D7.W_SCROLL_MOVE:	PUSHM.L	D0..D2	TEST.B	(A5)+OSCHOR	JUMP',F	05$	SWAP.W	D4		; X <--> Y05$:	LOAD.W	D7,#ERDIOUT	; D7 <-- souris pas dans l'ascenseur	LOAD.L	D3,(A5)+OSCDEB	; D3 <-- position coin sup/gauche	COMP.W	D4,D3		; souris trop  gauche ?	JUMP,LO 90$		; oui => 90$	ADD.W	D3,#LGSCROLL	COMP.W	D4,D3		; souris trop  droite ?	JUMP,HS 90$		; oui => 90$	SWAP.W	D3	SWAP.W	D4	TEST.B	(A5)+OSCPAGE	JUMP',T	10$	COMP.W	D4,D3		; souris trop haute ?	JUMP,LO 90$		; oui => 90$	ADD.W	D3,#LGSCROLL	COMP.W	D4,D3		; souris dans la flche suprieure ?	JUMP,LO 25$		; oui => 25$	ADD.W	D3,(A5)+OSCHTR	SUB.W	D3,#LGSCROLL*2	COMP.W	D4,D3		; souris dans l'ascenseur ?	JUMP,LO 40$		; oui => 40$	ADD.W	D3,#LGSCROLL	COMP.W	D4,D3		; souris dans la flche infrieure ?	JUMP',LO 20$		; oui => 20$	JUMP	90$10$:	COMP.W	D4,D3		; souris trop haute ?	JUMP,LO 90$		; oui => 90$	ADD.W	D3,#LGSCROLL	COMP.W	D4,D3		; souris dans la flche suprieure ?	JUMP',LO 25$		; oui => 25$	ADD.W	D3,#LGSCROLL	COMP.W	D4,D3		; souris dans la page suprieure ?	JUMP',LO 17$		; oui => 17$	ADD.W	D3,(A5)+OSCHTR	SUB.W	D3,#LGSCROLL*4	COMP.W	D4,D3		; souris dans l'ascenseur ?	JUMP',LO 40$		; oui => 40$	ADD.W	D3,#LGSCROLL	COMP.W	D4,D3		; souris dans la page infrieure ?	JUMP',LO 15$		; oui => 15$	ADD.W	D3,#LGSCROLL	COMP.W	D4,D3		; souris dans la flche infrieure ?	JUMP',LO 20$		; oui => 20$	JUMP	90$15$:				; page infrieure =>	LOAD.W	D4,#SCROLLPDOWN	JUMP	85$17$:				; page suprieure =>	LOAD.W	D4,#SCROLLPUP	JUMP	85$20$:				; flche infrieure =>	LOAD.W	D4,#SCROLLFDOWN	LOAD.W	D2,(A5)+OSCPOSV	ADD.W	D2,(A5)+OSCINC	LOAD.W	D3,(A5)+OSCHTV	COMP.W	D2,D3		; est-on trop bas ?	JUMP',LO 30$		; non => 30$	LOAD.W	D2,D3	DEC.W	D2	JUMP'	30$25$:				; flche suprieure =>	LOAD.W	D4,#SCROLLFUP	LOAD.W	D2,(A5)+OSCPOSV	SUB.W	D2,(A5)+OSCINC	JUMP',HS 30$		; est-on trop haut, non => 30$	CLR.W	D230$:	LOAD.W	(A5)+OSCPOSV,D2	CALL	_SCROLL_UPDATE	; dessine l'ascenseur  la nouvelle position	JUMP	85$40$:	LIB	?COLORPUSH	; sauve les couleurs	LIB	?AFTIM	.B	NOCURS		; supprime le curseur	.B	AFCCMO		; supprime la flche de la souris	.B	0	.EVEN	LOAD.W	D0,(A5)+OSCHTC	; D0 <-- hauteur de la cabine	SR.W	D0,#1	SUB.W	D4,D0	LOAD.W	D0,D4		; D0 <-- position Y initiale	LOAD.W	D1,#1		; D1 <-- dessine	CALL	MOVEASCENSEUR	; dessine le premier ascenseur50$:	LIB	?GETKEY		; attend souris/clavier ...	TEST.L	D3:#BKPSEUDO	; touche relache ?	JUMP,BS	50$		; oui => 50$	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 60$		; non => 60$				; oui =>	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE 50$	SWAP.W	D4	LOAD.W	D3,(A5)+OSCHTC	; D3 <-- hauteur de la cabine	SR.W	D3,#1	SUB.W	D4,D3	COMP.W	D4,D0		; mme position verticale ?	JUMP,EQ	50$		; oui => 50$				; non =>	CLR.W	D1		; D1 <-- efface	CALL	MOVEASCENSEUR	; efface l'ancien ascenseur	LOAD.W	D0,D4	LOAD.W	D1,#1		; D1 <-- dessine	CALL	MOVEASCENSEUR	; dessine le nouveau ascenseur	JUMP	50$60$:	CLR.W	D1		; D1 <-- efface	CALL	MOVEASCENSEUR	; efface l'ancien ascenseur	SUB.W	D0,(A5)+OSCDEBO	SUB.W	D0,#LGSCROLL	TEST.B	(A5)+OSCPAGE	JUMP',F	70$	SUB.W	D0,#LGSCROLL70$:	LOAD.W	(A5)+OSCPOSR,D0	CALL	CALPOSV		; OSCPOSV <-- position virtuelle	CALL	_SCROLL_UPDATE	; dessine le nouvelle ascenseur dfinitif	LIB	?AFTIM	.B	AFSCMO		; remet la flche de la souris	.B	0	.EVEN	LIB	?COLORPOP	; restitue les couleurs	CLR.W	D4		; D4 <-- flche/page sup/inf85$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2	TEST.W	D7		; retour EQ/NE	RET;--------------\\; _SCROLL_PRESS >;==============/; Inverse un bouton (flche/page).; in	D4.W		bouton press SCROLL(F/P)(UP/DOWN);	A5.L		^variables de l'ascenseur;	(A5)+OSCDEB.L	coin sup/gauche;	(A5)+OSCHTR.W	hauteur relle;	(A5)+OSCHOR.B	T => horizontal et F => vertical;	(A5)+OSCPAGE.B	T => avance par pages possible; out	-; mod	D7.W_SCROLL_PRESS:	PUSHM.L	D1..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_SCCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_PPHILI	LIB	?COLORSR	; donne la couleur des mises en vidence	LOAD.W	D2,D4		; D2 <-- bouton press	LOAD.L	D3,#-1		; D3 <-- trame	LOAD.L	D4,D3		; D4 <-- trame	LIB	?DRMDEF		; dfinit la trame	LOAD.L	D3,(A5)+OSCDEB	SWAP.W	D3	INC.W	D3	LOAD.W	D4,#LGSCROLL-2	COMP.W	D2,#SCROLLFUP	JUMP',EQ 20$	ADD.W	D3,#LGSCROLL-1	INC.W	D4	COMP.W	D2,#SCROLLPUP	JUMP',EQ 20$	ADD.W	D3,(A5)+OSCHTR	SUB.W	D3,#(LGSCROLL*2)-1	LOAD.W	D4,#LGSCROLL-2	COMP.W	D2,#SCROLLFDOWN	JUMP',EQ 20$	SUB.W	D3,#LGSCROLL	INC.W	D4	COMP.W	D2,#SCROLLPDOWN	JUMP',NE 90$20$:	SWAP.W	D3	INC.W	D3	SWAP.W	D4	LOAD.W	D4,#LGSCROLL-2	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	DRMATRIX	; inverse le bouton90$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D1..D4	CLR.W	D7		; retour EQ	RET;--------------\\; MOVEASCENSEUR >;--------------/; Dplace l'ascenseur.; in	D0.W	position Y de la souris;	D1.W	0 => efface et 1 => dessine; out	D0.W	position Y possible; mod	D0.L, D7.WMOVEASCENSEUR:	PUSHM.L	D1..D6	LOAD.W	D6,#LGSCROLL	; D6 <-- hauteur flche	TEST.B	(A5)+OSCPAGE	JUMP',F	05$	LOAD.W	D6,#LGSCROLL*2	; D6 <-- hauteur flche/page05$:	LOAD.W	D4,(A5)+OSCDEBO	ADD.W	D4,D6	COMP.W	D0,D4		; souris trop haute ?	JUMP',HS 10$		; non => 10$	LOAD.W	D0,D4		; oui => met en haut au maximum10$:	LOAD.W	D4,(A5)+OSCDEBO	ADD.W	D4,(A5)+OSCHTR	SUB.W	D4,D6	SUB.W	D4,(A5)+OSCHTC	DEC.W	D4	COMP.W	D0,D4		; souris trop basse ?	JUMP',LO 20$		; non => 20$	LOAD.W	D0,D4		; oui => met en bas au maximum20$:	LOAD.W	D3,D0		; D3 <-- dbut Y	SWAP.W	D3	LOAD.W	D3,(A5)+OSCDEBL	INC.W	D3		; D3 <-- dbut X	LOAD.W	D4,(A5)+OSCHTC	; D4 <-- hauteur de la cabine	SWAP.W	D4	LOAD.W	D4,#LGSCROLL-(2+1)	TEST.W	D1	JUMP',EQ 50$	PUSH.L	D3	LOAD.L	D3,#COLOR_SCSET	LIB	?COLORSR	; donne la couleur du dessin	POP.L	D3	LOAD.W	D2,#SETDOT	CALL	DRRECT		; dessine la cabine de l'ascenseur	CALL	DESCABINE	; dessine l'intrieur	JUMP	90$50$:	LOAD.W	D5,(A5)+OSCPOSR	ADD.W	D5,(A5)+OSCDEBO	ADD.W	D5,D6	SUB.W	D5,D0	JUMP',NC 52$	NEG.W	D5		; D5 <-- |distance|52$:	COMP.W	D5,(A5)+OSCHTC	; chevauchement ?	JUMP',LS 60$		; oui => 60$				; non =>	INC.W	D4		; largeur <-- +1	SWAP.W	D4	INC.W	D4		; hauteur <-- +1	SWAP.W	D4	PUSH.L	D3	LOAD.L	D3,#COLOR_SCCLEAR	LIB	?COLORCR	; donne la couleur du fond	CALL	DEFTRAME	; dfinit la trame du fond	POP.L	D3	LOAD.W	D2,#CLRDOT	CALL	DRMATRIX	; efface le rectangle	JUMP'	90$60$:	LOAD.W	D4,(A5)+OSCPOSR	CALL	MAJASCENSEUR	; re-affiche tout l'ascenseur90$:	POPM.L	D1..D6	RET;---------------\\; _SCROLL_UPDATE >;===============/; Met  jour la cabine de l'ascenseur.; On utilise cet appel lorsque l'ascenseur bouge (OSCPOSV ou OSCHTV; modifis par un vnement extrieur au module SCROLL).; Lorsque l'ascenseur bouge avec SCROLL_MOVE, cet appel n'est pas; ncessaire.; (m) = peut tre modifi; in	A5.L		^variables de l'ascenseur;	(A5)+OSCDEB.L	coin sup/gauche;	(A5)+OSCHTR.W	hauteur relle;	(A5)+OSCHOR.B	T => horizontal et F => vertical;	(A5)+OSCPAGE.B	T => avance par pages possible;	(A5)+OSCMARK.B	T => marqueur dans la cabine;	(A5)+OSCHTV.W	hauteur virtuelle (m);	(A5)+OSCPOSV.W	position virtuelle (m); out	(A5)+OSCPOSR.W	position relle; mod	D7.W_SCROLL_UPDATE:	PUSH.L	D4	LIB	?COLORPUSH	; sauve les couleurs	CALL	CALPOSR		; OSCPOSR <-- position relle	LOAD.W	D4,(A5)+OSCPOSR	CALL	MAJASCENSEUR	LIB	?COLORPOP	; restitue les couleurs	POP.L	D4	CLR.W	D7		; retour EQ	RET;-------------\\; MAJASCENSEUR >;-------------/; Met  jour l'affichage de l'ascenseur.; in	D4.W	position Y; out	-; mod	D7.WMAJASCENSEUR:	PUSHM.L	D1..D4	LOAD.L	D3,#COLOR_SCCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_SCSET	LIB	?COLORSR	; donne la couleur du dessin	LOAD.W	(A5)+OSCPOSR,D4	LOAD.W	D1,#LGSCROLL	; D1 <-- hauteur flche	TEST.B	(A5)+OSCPAGE	JUMP',F	10$	LOAD.W	D1,#LGSCROLL*2	; D1 <-- hauteur flche/page10$:	CALL	DEFTRAME	; dfinit la trame du fond	LOAD.L	D3,(A5)+OSCDEB	; D3 <-- position coin sup/gauche	INC.W	D3	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D3	LOAD.W	D4,(A5)+OSCPOSR	; D4 <-- hauteur partie suprieure	JUMP',LE 30$	SWAP.W	D4	LOAD.W	D4,#LGSCROLL-2	; D4 <-- largeur	LOAD.W	D2,#LOADDOT	; D2 <-- mode	CALL	DRMATRIX	; dessine la trame30$:	SWAP.W	D3	ADD.W	D3,(A5)+OSCPOSR	ADD.W	D3,(A5)+OSCHTC	SWAP.W	D3	LOAD.W	D4,(A5)+OSCHTR	SUB.W	D4,(A5)+OSCPOSR	SUB.W	D4,D1	SUB.W	D4,D1	SUB.W	D4,(A5)+OSCHTC	; D4 <-- hauteur partie infrieure	JUMP',LE 50$	SWAP.W	D4	LOAD.W	D4,#LGSCROLL-2	; D4 <-- largeur	LOAD.W	D2,#LOADDOT	; D2 <-- mode	CALL	DRMATRIX	; dessine la trame50$:	LOAD.W	D3,(A5)+OSCPOSR	; D3 <-- dbut Y marqueur	ADD.W	D3,(A5)+OSCDEBO	ADD.W	D3,#LGSCROLL	TEST.B	(A5)+OSCPAGE	JUMP',F	60$	ADD.W	D3,#LGSCROLL60$:	SWAP.W	D3	LOAD.W	D3,(A5)+OSCDEBL	INC.W	D3		; D3 <-- dbut X marqueur	LOAD.W	D4,(A5)+OSCHTC	; D4 <-- hauteur de la cabine	SWAP.W	D4	LOAD.W	D4,#LGSCROLL-(2+1)	LOAD.W	D2,#SETDOT	CALL	DRRECT		; dessine la cabine de l'ascenseur	PUSHM.L	D3,D4	LOAD.L	D3,#COLOR_SCPOS	LIB	?COLORCR	; donne la couleur de la position	CLR.L	D3		; D3 <-- trame	CLR.L	D4		; D4 <-- trame	LIB	?DRMDEF		; dfinit la trame	POPM.L	D3,D4	PUSHM.L	D3,D4	INC.W	D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	INC.W	D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#CLRDOT	CALL	DRMATRIX	; efface l'intrieur	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	CALL	DESCABINE	; dessine l'intrieur de la cabine	POPM.L	D1..D4	RET;---------\\; DEFTRAME >;---------/; Dfinit la trame grise pour les ascenseurs.; in	-; out	-; mod	D7.WDEFTRAME:	PUSHM.L	D3,D4,A4	LIB	?GETPDIS	; A4 <-- ^descripteur	JUMP',NE 90$	LOAD.L	D3,#H'55AA55AA	; D3 <-- trame	TEST.B	(A4)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP',BC 40$		; non => 40$	LOAD.L	D3,#H'00110044	; D3 <-- trame plus claire40$:	LOAD.L	D4,D3		; D4 <-- trame	LIB	?DRMDEF		; dfinit la trame du fond90$:	POPM.L	D3,D4,A4	RET;-------------\\; _SCROLL_DRAW >;=============/; Dessine la cage de l'ascenseur vide, avec les flches suprieure; et infrieure, et ventuellement les pages.; L'cran sous la cage de l'ascenseur est effac automatiquement.; in	A5.L		^variables de l'ascenseur;	(A5)+OSCDEB.L	coin sup/gauche;	(A5)+OSCHTR.W	hauteur relle;	(A5)+OSCHOR.B	T => horizontal et F => vertical;	(A5)+OSCPAGE.B	T => avance par pages possible; out	-; mod	D7.W_SCROLL_DRAW:	PUSHM.L	D2..D4,A3	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_SCCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_SCSET	LIB	?COLORSR	; donne la couleur du dessin	CLR.L	D3		; D3 <-- trame	CLR.L	D4		; D4 <-- trame	LIB	?DRMDEF		; dfinit la trame	LOAD.L	D3,(A5)+OSCDEB	; D3 <-- position coin sup/gauche	LOAD.W	D4,(A5)+OSCHTR	; D4 <-- hauteur	DEC.W	D4	SWAP.W	D4	LOAD.W	D4,#LGSCROLL-1	; D4 <-- largeur	LOAD.W	D2,#CLRDOT	CALL	DRMATRIX	; efface l'intrieur	LOAD.W	D2,#SETDOT	; D2 <-- mode	CALL	DRRECT		; met un rectangle autour	LOAD.L	D3,#COLOR_SCOBJ	LIB	?COLORSR	; donne la couleur des objets	LOAD.L	D3,(A5)+OSCDEB	; D3 <-- position coin sup/gauche	LOAD.L	A3,#R16"TAFLUP	CALL	DESMOTIF	; dessine la flche suprieure	PUSH.L	D3	LOAD.L	D3,#COLOR_SCSET	LIB	?COLORSR	; donne la couleur du dessin	POP.L	D3	SWAP.W	D3	ADD.W	D3,#LGSCROLL-1	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,#LGSCROLL	PUSH.L	D3	CALL	DRSEG	POP.L	D3	TEST.B	(A5)+OSCPAGE	JUMP',F	40$	PUSH.L	D3	LOAD.L	D3,#COLOR_SCOBJ	LIB	?COLORSR	; donne la couleur des objets	POP.L	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.L	A3,#R16"TAPGUP	CALL	DESMOTIF	; dessine la page suprieure	PUSH.L	D3	LOAD.L	D3,#COLOR_SCSET	LIB	?COLORSR	; donne la couleur du dessin	POP.L	D3	SWAP.W	D3	ADD.W	D3,#LGSCROLL-1	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,#LGSCROLL	CALL	DRSEG40$:	LOAD.L	D3,#COLOR_SCOBJ	LIB	?COLORSR	; donne la couleur des objets	LOAD.L	D3,(A5)+OSCDEB	; D3 <-- position coin sup/gauche	SWAP.W	D3	ADD.W	D3,(A5)+OSCHTR	; D3 <-- position coin inf/gauche	DEC.W	D3	SWAP.W	D3	LOAD.L	A3,#R16"TAFLDOWN	CALL	DESMOTIF	; dessine la flche infrieure	PUSH.L	D3	LOAD.L	D3,#COLOR_SCSET	LIB	?COLORSR	; donne la couleur du dessin	POP.L	D3	SWAP.W	D3	SUB.W	D3,#LGSCROLL-1	SWAP.W	D3	PUSH.L	D3	CALL	DRSEG	POP.L	D3	TEST.B	(A5)+OSCPAGE	JUMP',F	60$	PUSH.L	D3	LOAD.L	D3,#COLOR_SCOBJ	LIB	?COLORSR	; donne la couleur des objets	POP.L	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	LOAD.L	A3,#R16"TAPGDOWN	CALL	DESMOTIF	; dessine la page infrieure	PUSH.L	D3	LOAD.L	D3,#COLOR_SCSET	LIB	?COLORSR	; donne la couleur du dessin	POP.L	D3	SWAP.W	D3	SUB.W	D3,#LGSCROLL-1	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,#LGSCROLL	CALL	DRSEG60$:	LOAD.W	(A5)+OSCHTC,#LGSCROLL ; une cabine normale	LOAD.W	D4,#(LGSCROLL*3)+2	TEST.B	(A5)+OSCPAGE	JUMP',F	70$	ADD.W	D4,#LGSCROLL*270$:	COMP.W	D4,(A5)+OSCHTR	JUMP',LO 90$	LOAD.W	(A5)+OSCHTC,#4	; une cabine minuscule90$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D2..D4,A3	CLR.W	D7		; retour EQ	RET;--------------\\; _SCROLL_SCALE >;==============/; Dessine  droite ou en bas d'un ascenseur une chelle gradue.; in	A5.L		^variables de l'ascenseur;	(A5)+OSCDEB.L	coin sup/gauche;	(A5)+OSCHTR.W	hauteur relle;	(A5)+OSCHOR.B	T => horizontal et F => vertical;	(A5)+OSCPAGE.B	T => avance par pages possible;	D3.W		nombre de divisions (2..n);	D4.W		longueur des divisions (1..n);	A3.L		^liste des textes/^nil;			 n .ASCIZ  la suite (n=D3+1);			 seulement si ascenseur vertical !;	A0.L		^description de la fentre; out	-; mod	D7.W_SCROLL_SCALE:	PUSHM.L	D0..D5,A3	LOAD.W	D2,D3	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_SCSCALE	LIB	?COLORSR	; donne la couleur des graduations	LOAD.W	D3,D2	LOAD.W	D0,(A5)+OSCHTR	SUB.W	D0,(A5)+OSCHTC	SUB.W	D0,#LGSCROLL*2	; D0 <-- hauteur de l'ascenseur	TEST.B	(A5)+OSCPAGE	JUMP',F 10$	SUB.W	D0,#LGSCROLL*210$:	CLR.W	D1		; D1 <-- rang de la barette	AND.L	D4,#H'FFFF	; D4 <-- dimensions (dy;dx)	LOAD.W	D5,D3		; D5 <-- nb de divisions40$:	LOAD.W	D3,D0	MUL.WU	D3,D1	DIV.WU	D3,D5	ADD.W	D3,(A5)+OSCDEBO	ADD.W	D3,#LGSCROLL+LGSCROLL/2	TEST.B	(A5)+OSCPAGE	JUMP',F 45$	ADD.W	D3,#LGSCROLL45$:	SWAP.W	D3	LOAD.W	D3,(A5)+OSCDEBL	ADD.W	D3,#LGSCROLL	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CALL	DRSEG		; dessine une barette	LOAD.L	D2,A3		; liste de textes existe ?	JUMP',EQ 60$		; non => 60$	INC.W	D3		; D3 <-- <xx>	SWAP.W	D3	LOAD.W	D2,(A0)+ODFC1Y	; D2 <-- hauteur d'une lettre	SR.W	D2,#1		; D2 <-- demi-hauteur	ADD.W	D3,D2		; D3 <-- <yy>	SWAP.W	D3	LIB	?SETCURS	; positionne le curseur	LIB	?AFTEXT		; affiche un texte60$:	INC.W	D1		; D1 <-- rang suivant	COMP.W	D1,D5	JUMP,LS 40$	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D0..D5,A3	CLR.W	D7		; retour EQ	RET;----------\\; DESCABINE >;----------/; Dessine la cabine de l'ascenseur.; in	D3.L	position (y;x);	D4.L	dimensions (y;x);	D2.W	mode de dessin; out	-; mod	D7.WDESCABINE:	PUSH.L	A3	TEST.B	(A5)+OSCMARK	; marqueur dans la cabine ?	JUMP',F 90$		; non => 90$				; oui =>	PUSH.L	D3	LOAD.L	D3,#COLOR_SCSCALE	LIB	?COLORSR	; donne la couleur des graduations	POP.L	D3	LOAD.L	A3,#R16"TAMARK	CALL	DESMOTIF	; met marqueur dans la cabine90$:	POP.L	A3	RET;---------\\; DESMOTIF >;---------/; Dessine un motif constitu de lignes droites.; in	D3.L	coordonne initiale;	D2.W	mode;	A3.L	^table (dy;dx); out	-; mod	D7.WDESMOTIF:	PUSHM.L	D3,D4,A3	SWAP.W	D3	ADD.W	D3,(A3+)	; saute au dpart	SWAP.W	D3	ADD.W	D3,(A3+)10$:	LOAD.L	D4,(A3+)	JUMP',EQ 90$	CALL	DRSEG	JUMP	10$90$:	POPM.L	D3,D4,A3	RETTAFLUP:				; flche suprieure	.W	2,7	.W	6,-6	.W	0,3	.W	4,0	.W	0,6	.W	-4,0	.W	0,3	.W	-6,-6	.W	0,0TAFLDOWN:			; flche infrieure	.W	-2,7	.W	-6,-6	.W	0,3	.W	-4,0	.W	0,6	.W	4,0	.W	0,3	.W	6,-6	.W	0,0TAPGUP:				; page suprieure	.W	5,3	.W	0,4	.W	-4,0	.W	4,-4	.W	8,0	.W	0,9	.W	-12,0	.W	0,-5	.W	0,0TAPGDOWN:			; page infrieure	.W	-5,3	.W	0,4	.W	4,0	.W	-4,-4	.W	-8,0	.W	0,9	.W	12,0	.W	0,-5	.W	0,0TAMARK:				; marque dans la cabine	.W	8,11	.W	0,-9	.W	0,9	.W	-3,-3	.W	3,3	.W	4,-4	.W	0,0;--------\\; CALPOSV >;--------/; Calcul la position virtuelle en fonction de la position relle.; in	-; out	-; mod	-CALPOSV:	PUSHM.L	D2..D4	LOAD.W	D3,(A5)+OSCHTR	SUB.W	D3,(A5)+OSCHTC	SUB.W	D3,#LGSCROLL*2	TEST.B	(A5)+OSCPAGE	JUMP',F	20$	SUB.W	D3,#LGSCROLL*220$:	LOAD.W	D4,(A5)+OSCPOSR	INC.W	D4	COMP.W	D4,D3		; est-on tout en bas ?	JUMP',EQ 50$		; oui => 50$				; non =>	TEST.W	D3	JUMP',EQ 40$	DEC.W	D4	LOAD.W	D2,(A5)+OSCHTV	DEC.W	D2	MUL.WU	D4,D2	DIV.WU	D4,D3	JUMP'	80$40$:	CLR.W	D4		; D4 <-- met le minimum	JUMP'	80$50$:	LOAD.W	D4,(A5)+OSCHTV	DEC.W	D4		; D4 <-- met le maximum80$:	LOAD.W	(A5)+OSCPOSV,D4	POPM.L	D2..D4	RET;--------\\; CALPOSR >;--------/; Calcul la position relle en fonction de la position virtuelle.; in	-; out	-; mod	-CALPOSR:	PUSHM.L	D2..D4	LOAD.W	D3,(A5)+OSCHTR	SUB.W	D3,(A5)+OSCHTC	SUB.W	D3,#LGSCROLL*2	TEST.B	(A5)+OSCPAGE	JUMP',F	20$	SUB.W	D3,#LGSCROLL*220$:	LOAD.W	D4,(A5)+OSCPOSV	MUL.WU	D4,D3	LOAD.W	D2,(A5)+OSCHTV	DEC.W	D2	JUMP',EQ 30$	DIV.WU	D4,D2	COMP.W	D4,D3		; dpasse la fin ?	JUMP',LO 40$		; non => 40$	LOAD.W	D4,D3		; oui => ne va pas plus loin	DEC.W	D4	JUMP'	40$30$:	CLR.W	D4		; D4 <-- met le minimum40$:	LOAD.W	(A5)+OSCPOSR,D4	POPM.L	D2..D4	RET;--------\\; IFMOUSE >;--------/IFMOUSE:	PUSH.L	D5	LIB	?GETWDO	LOAD.L	D5,D3		; D5 <-- origine swdo	LIB	?IFMOUSE	; D3 <-- boutons et D4 <-- position	LOAD.W	D7,#ERDIOUT	SUB.W	D4,D5		; D4 <-- origine en X dans swdo	JUMP',LO 90$	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D5		; D4 <-- origine en Y dans swdo	JUMP',LO 90$	SWAP.W	D4;	SWAP.W	D5	CLR.W	D7	TEST.B	(A5)+OSCHOR	JUMP',F	90$	SWAP.W	D4		; X <--> Y90$:	POP.L	D5	TEST.W	D7	RET;-------\\; DRRECT >;-------/DRRECT:	TEST.B	(A5)+OSCHOR	JUMP',T 50$	LIB	?DRRECT	RET50$:	SWAP.W	D3		; X <--> Y	SWAP.W	D4		; dX <-- dY	LIB	?DRRECT	SWAP.W	D4		; dX <-- dY	SWAP.W	D3		; X <--> Y	RET;---------\\; DRMATRIX >;---------/DRMATRIX:	TEST.B	(A5)+OSCHOR	JUMP',T 50$	LIB	?DRMATRIX	RET50$:	SWAP.W	D3		; X <--> Y	SWAP.W	D4		; dX <-- dY	LIB	?DRMATRIX	SWAP.W	D4		; dX <-- dY	SWAP.W	D3		; X <--> Y	RET;------\\; DRSEG >;------/DRSEG:	TEST.B	(A5)+OSCHOR	JUMP',T 50$	LIB	?DRSEG	RET50$:	SWAP.W	D3		; X <--> Y	SWAP.W	D4		; dX <-- dY	LIB	?DRSEG	SWAP.W	D4		; dX <-- dY	SWAP.W	D3		; X <--> Y	RET	.INS	SCROLLLIST.ASI	.INS	SCROLLREGLE.ASI	.INS	SCROLL09.ASIEND_SCROLL:	.END