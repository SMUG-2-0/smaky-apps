	.TITLE	DBOX.ASL	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcima	.REF	SMAKY	.REF	MODULES	.REF	COLORS;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;FOS?FOS = FOS_BASE+106		      ^ Multiple ass.FOS?TYPEUNIT = FOS_BASE+107			   ^ Multiple ass.BerUNAM = 6;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; DBOX	Date		Amliorations; -----------------------------------------------------------------------------------------; 2.11	06.07.89	DBOX_ERCALL: ne force plus le terminateur; 2.10	04.07.89	DBOX_PREND: accepte un nom du type "#PP" ou "#PP:";			DBOX_ERCALL: FOS,?XERROR avec BERUNAM; 2.9	28.06.89	DBOX_ERCALL: FOS,?ERRNAME remplac par FOS,?XERROR;			DBOX_ERCALL: BIOS,?DREAD et ?DWRITE supprims; 2.8	28.04.89	DBOX_ERCALL: utilise FOS,?FOS; 2.7	11.04.89	DBOX_ERCALL: plus de code excut sur le stack (cache du 68020 !); 2.6	25.01.89	DBOX_SAUVE: jamais (SAUVE) et (MET A JOUR) griss les deux; 2.5	19.12.88	DBOX_SAUVE: ok si ni BDBIOEXT1 ni BDBIOEXTM; 2.4	05.10.88	DBOX_PREND: si LISTE et extension "?" => prend celle en dition;			DBOX_PREND: si lg extension > 7 => ODBXFILE plus large;			ODBCR2: nouvel objet = 0.5 x ODBCR;			ODBTAB[X,Y]N: nouveaux objets de positionnement en points; 2.3	05.09.88	DBOX_PREND: accepte extensions "!";			DBOX_PREND: si annule => ne change pas le nom;			DBOX_PREND: BDBIOFULL!BDBIOEXTM possible (pour PLUME); 2.2	12.07.88	DBOX_AJOUTE: si BDBIOEXTM et *.TABLE => AJOUTE jamais gris; 2.1	05.07.88	DBOX_MERROR: ok si position dans D3.L; 2.0	13.04.88	et vive la couleur !; 1.30	17.02.88	ODBCIRCLE/ODBSQUARE: position en X modulo 2;			DBOX_SAUVE: plus gris si fanions changs; 1.29	19.01.88	DBOX_PREND, etc. avec D5=position si D2:#BDBPOS; 1.28	25.11.87	DBOX_ERROR: fond blanc seulement si ncessaire;			DBOX_ICOxx selon ODFPSK.L; 1.27	20.11.87	DBOX_ERCALL: si protect => refait toujours l'enter; 1.26	17.11.87	DBOX_ERCALL: si formate => message plus court; 1.25	12.11.87	DBOX_ERCALL utilise LIB,?PUSHMENU/LIB,?POPMENU; 1.24	27.10.87	DBOX_PREND,AJOUTE,SAUVE,EXTRAIT avec nom + extension;			DBOX_ERROR avec joli "blup" !; 1.23	15.10.87	DBOX_PREND,AJOUTE,SAUVE,MAJ,QUITTE,DETRUIT,EFFACE;			ODBXLINE,ODBXFILE;			DBOX_GETCO avec BDBGCGREY/BDBGCFULL; 1.22	25.09.87	DBOX_MERROR utilise FOS,?XERROR; 1.21	11.09.87	DBOX_TERROR avec BDBDET pour la case (DETAILS); 1.20	31.08.87	DBOX_EXTEND pour rajouter 2^16 appels  DBOX;			DBOX_ERCALL essaye de rsoudre qq problmes;			DBOX_OPWAIT et DBOX_CLWAIT; 1.19	04.08.87	ODBLCIRCLE avec petit cercle autour;			OFADESS pour dessiner les fanions + rapidement; 1.18	29.07.87	DBOX_TERROR s'adapte selon le texte (en X et Y);			DBOX_ERROR utilise DBOX_TERROR (donc + joli);			ODBLABEL nouvel objet pour DBOX_GETCO; 1.17	27.05.87	ODBSQUARE aligns avec les ODBCIRCLE; 1.16	12.01.87	DBOX_OPEN avec BDBMAX => plus de marges; 1.15	19.12.86	DBOX_AFFILE utilise LIB,?AFXFILE (cache la clef); 1.14			DBOX_OPEN fait un LIB,?CLREDIT	.REV	2,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------MARGGD	=	2		; marge gauche/droiteMARGSI	=	2		; marge suprieure/infrieureMTERRX	=	4		; marge en X pour DBOX_TERRORMTERRY	=	6		; marge en Y pour DBOX_TERRORKEYDBOX	=	H'7E00		; "touche" spciale pour DBOX; Table pour les fichiers/lignes ditables; ----------------------------------------MAXFILE	=	20	.LOC	0OFITYP:	.BLKB	1		; type 0=fichier/1=ligne	.EVENOFIPOS:	.BLKB	4		; position dbut pour ditionOFILG:	.BLKB	4		; longueur et flagsLGFI:; Variables pour IO; -----------------LIONAM	=	50		; lg max pour nomLIOEXT	=	20		; lg max pour extension	.LOC	0OIOAPP:	.BLKB	2		; code du sous-appelOIOFLG:	.BLKB	4		; flagsOIOFAN:	.BLKB	4		; fanionsOIOPDI:	.BLKB	4		; ^descripteur de la fentreOIOPNA:	.BLKB	4		; ^buffer pour nomOIOPEX:	.BLKB	4		; ^extension(s)OIOOLD:	.BLKB	LIONAM		; nom initialOIONAM:	.BLKB	LIONAM		; nom en ditionOIOEXT:	.BLKB	LIOEXT		; extension en ditionOIOTXT:	.BLKB	150		; texte construitOIOTAB:	.BLKB	500		; table de description de la dboxLGVARIO:; Variables pour ERCALL; ---------------------	.LOC	0OECPPM:	.BLKB	4		; canal LIB,?PUSHMENU/?POPMENUOECTIM:	.BLKB	2		; timeoutOECWDO:	.BLKB	2		; numro swdoOECCDB:	.BLKB	4		; canal dboxOECNAM:	.BLKB	50		; nom du fichierOECTXT:	.BLKB	50		; texte quelconqueLGVAREC:; Variables; ---------	.LOC	0OFLAGS:	.BLKB	1		; flags divers BNODES =  0			;  pas de dessin BFADES	=  1			;  dessine les fanions BTITLE	=  2			;  titre dans swdoOSVMOD:	.BLKB	1		; sauvetage de ODFMODOSVFLG:	.BLKB	1		; sauvetage de ODFFLG	.EVENOSVWDO:	.BLKB	2		; no swdo initialeOSVOPM:	.BLKB	2		; mode d'ouvertureOPTABLE:.BLKB	4		; ^tableONOWDO:	.BLKB	2		; numro de la swdoODIMWDO:.BLKB	4		; dimensions de la swdoOPOSEXT:.BLKB	4		; position swdo extrieureODIMEXT:.BLKB	4		; dimensions swdo extrieureOMARGY:	.BLKB	2		; marges sup/infOMARGX:	.BLKB	2		; marges gauche/droiteONBFILE:.BLKB	2		; nb max de fichiers/lignesONOFILE:.BLKB	2		; no du fichier/ligneOUSFILE:.BLKB	2		; fichier/ligne utilisOTAFILE:.BLKB	MAXFILE*LGFI	; table des fichiers/lignes ditablesOFANION:.BLKB	4		; tats des fanionsOFACIRC:.BLKB	4		; fanions pour les cerclesOFADESS:.BLKB	4		; fanions dessins  l'cranOPDDIS:	.BLKB	4		; ^description relle de la fentreOCX:	.BLKB	2		; copie de ODFCXOCY:	.BLKB	2		; copie de ODFCYOC1Y:	.BLKB	2		; copie de ODFC1YOC2Y:	.BLKB	2		; copie de ODFC2YOMAPGR:	.BLKB	256/8		; map des objets grissLGVAR:; En-tte du module LIB; ---------------------	.LOC	0	DBOX_	FIRST		; code du premier appel	DBOX_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	2,11		; rvision.version	.W	0,END_DBOX	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"DBOX"		; nom du module	.FILLB	(LGHLIB-.),0	.W	_DBOX_OPEN	.W	_DBOX_EDIT	.W	_DBOX_CLOSE	.W	_DBOX_CADRE	.W	_DBOX_GETCO	.W	_DBOX_CALLC	.W	_DBOX_ERROR	.W	_DBOX_MEDIT	.W	_DBOX_TERROR	.W	_DBOX_MERROR	.W	_DBOX_AFFILE	.W	_DBOX_ICOCADRE	.W	_DBOX_ICOAFF	.W	_DBOX_ICODET	.W	_DBOX_ICOINV	.W	_DBOX_ICOPOS; Codes des appels; ----------------;-------------\\; _DBOX_TERROR >;=============/; Affiche une erreur sous forme d'un texte dans une dbox.; Le texte peut contenir plusieurs lignes de longueurs diffrentes; (la DBOX s'adapte automatiquement). Par exemple:;	.ASCII	"L'espace disque est insuffisant<CR>";	.ASCIZ	"pour cette opration !"; Le texte est affich en vido-inverse, sauf s'il commence par; un AFDIR. Par exemple:;	.ASCIZ	"<AFDIR>Fin du transfert"; Il faudra redessiner les soft-keys (LIB,?AFMENU).; Il faut faire LIB,?BEEP avec D3=BIPERR avant cet appel.; in	A3.L	^texte de l'erreur (.ASCIZ avec CRs admis);	D2.W	mode d'ouverture (BDBDET si case DETAILS);	D3.L	position centre (si BDBPOS); out	D3.W	dernire touche (F1/DEFINE) si BDBDET;	D7.W	erreur; mod	D3.L, D7.W_DBOX_TERROR:	PUSHM.L	D1,D2,D4,D5,A1..A4	PUSH.L	D3	SUB.W	SP,#100		; rserve 100 bytes sur le stack (PUSH)	LOAD.L	A2,SP		; A2 <-- ^buffer sur le stack; Calcule le nombre de lignes/colonnes dans le texte donn en entre.	CLR.L	D1		; D1 <-- (dy;dx)	LOAD.L	A4,A3		; A4 <-- ^texteCNTY$:	ADD.L	D1,#H'10000	; D1 <-- une ligne de plus (+dy)	CLR.W	D5CNTX$:	LOAD.B	D4,(A4+)	JUMP,NS CNTX$		; ignore les AFINV, AFDIR, etc.	JUMP',EQ CNT3$	INC.W	D5		; D5 <-- une colonne de plus (+dx)	COMP.B	D4,#CR	JUMP,NE CNTX$	DEC.W	D5CNT3$:	COMP.W	D1,D5	JUMP',HS CNT4$	LOAD.W	D1,D5		; D1 <-- ligne la plus large (>dx)CNT4$:	TEST.B	D4	JUMP,NE CNTY$	ADD.W	D1,#2		; D1 <-- espaces  gauche et  droite; Construit dynamiquement la table pour la DBOX.	LOAD.L	A1,A2		; A1 <-- ^buffer (sur le stack)	LOAD.W	(A1+),#4*2	; buffer <-- .W  DESC_TERROR-TABLE_TERROR	CLR.W	(A1+)		; buffer <-- .W  MENU_ERROR-TABLE_TERROR	CLR.L	(A1+)		; buffer <-- .W  0  (2x)	LOAD.L	A4,#R16"TDBOX_TERR0	LOAD.W	D4,#LDBOX_TERR0-1ERR0$:	LOAD.B	(A1+),(A4+)	; buffer <-- dbut de la table	DECJ.W,NMO D4,ERR0$	LOAD.L	D4,D1		; D4 <-- dimensions (dy;dx)	SWAP.W	D4	DEC.W	D4	JUMP',EQ PUTYT$PUTY$:	LOAD.B	(A1+),#ODBCR	; buffer <-- .B  ODBCRs (selon dy)	DEC.W	D4	JUMP,NE PUTY$PUTYT$:	LOAD.B	(A1+),#ODBTABX	SWAP.W	D4	ADD.W	D4,#10	LOAD.B	(A1+),D4	; buffer <-- .B  ODBTABX,dx	LOAD.L	A4,#R16"TDBOX_TERR1	LOAD.W	D4,#LDBOX_TERR1-1ERR1$:	LOAD.B	(A1+),(A4+)	; buffer <-- reste de la table	DECJ.W,NMO D4,ERR1$	TEST.L	D2:#BDBDET	; case dtails ?	JUMP',BC MENU$	DEC.L	A1	LOAD.L	A4,#R16"TDBOX_TERR2	LOAD.W	D4,#LDBOX_TERR2-1ERR2$:	LOAD.B	(A1+),(A4+)	; buffer <-- case (DETAILS)	DECJ.W,NMO D4,ERR2$MENU$:	LOAD.L	D4,A1	SUB.L	D4,A2	LOAD.W	(A2)+2,D4	; buffer <-- .W  MENU_ERROR-TABLE_TERROR	LOAD.L	A4,#R16"TDBOX_TERR3	LOAD.W	D4,#LDBOX_TERR3-1ERR3$:	LOAD.B	(A1+),(A4+)	; buffer <-- menu pour les soft-keys	DECJ.W,NMO D4,ERR3$	TEST.L	D2:#BDBDET	; case dtails ?	JUMP',BC OPEN$	DEC.L	A1	LOAD.L	A4,#R16"TDBOX_TERR4	LOAD.W	D4,#LDBOX_TERR4-1ERR4$:	LOAD.B	(A1+),(A4+)	; buffer <-- dtails	DECJ.W,NMO D4,ERR4$	; Ouvre la DBOX construite dynamiquement.OPEN$:	DBOX_	OPEN		; ouvre la swdo	JUMP,NE	EXIT$; Affiche le texte (message d'erreur) dans la DBOX.	CALL	GETPSW		; A1 <-- ^descripteur de la fentre	LOAD.L	D3,#COLOR_DBERROR	LIB	?COLORSR	; met la couleur des erreurs	PUSH.W	D2	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO		; D3 <-- dbut 1er texte	LOAD.L	D4,D3		; D4 <-- position	ADD.W	D4,(A1)+ODFCX	POP.W	D2	LOAD.L	A2,A3		; A2 <-- ^dbut du texte	COMP.B	(A2),#AFDIR	; faut-il ne pas inverser le texte ?	JUMP',NE AFFY$		; non => AFFY$	INC.L	A3		; A3 <-- saute le AFDIRAFFY$:	LOAD.L	A4,A3	LOAD.W	D3,#-1AFFX$:	INC.W	D3		; D3 <-- compte le nb de caractres	TEST.B	(A4+)	JUMP',EQ AFF3$	COMP.B	(A4)-1,#CR	JUMP,NE	AFFX$AFF3$:	PUSH.L	D3	LOAD.L	D3,D4		; D3 <-- position	LIB	?SETCURS	POP.L	D3	LIB	?STRING		; affiche une ligne	TEST.B	(A4)-1		; fin des lignes ?	JUMP',EQ CADRE$		; oui => CADRE$				; non =>	LOAD.L	A3,A4		; A3 <-- ^ligne suivante	SWAP.W	D4	ADD.W	D4,(A1)+ODFCY	; D4 <-- position ligne suivante	SWAP.W	D4	JUMP	AFFY$; Inverse tout le texte affich.CADRE$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; on n'sait jamais !	CLR.W	D1		; D1 <-- mode	COMP.B	(A2),#AFDIR	; faut-il ne pas inverser le texte ?	JUMP',EQ NORM$		; oui => NORM$	TSET.L	D1:#0		; D1 <-- inverse le texteNORM$:	CALL	CADRE		; dessine le cadre	CALL	DRBLUP		; dessine l'icne du "blup"	CALL	INVWDO		; inverse toute la dbox; Attend tranquillement que l'on clique sur (VU).LOOP$:	DBOX_	EDIT		; attend touche/souris ...	LOAD.L	A1,#R16"TKEY_ERROR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC		; touche admise ?	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP',EQ QUIT$	COMP.W	D3,#DEFINE	JUMP',EQ QUIT$	LOAD.B	D3,#BIPLIT	; non =>	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$QUIT$:	DBOX_	CLOSE		; ferme la swdoEXIT$:	ADD.W	SP,#100		; reprend le buffer sur le stack (POP)	POP.L	D4	TEST.L	D2:#BDBDET	; case dtails ?	JUMP',BS OUT$	LOAD.L	D3,D4		; D3 <-- restitue la valeur initialeOUT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DRBLUP  >;--------/; Dessine l'icne "blup" dans une dbox.; in	D3.L	position rectangle (y;x);	D4.L	dimensions rectangle (dy;dx);	D5.L	canal dbox; out	-; mod	D7.WDRBLUP:	PUSHM.L	D0..D4,A3,A4	LOAD.L	D1,D3	ADD.W	D1,#8	SWAP.W	D4	LOAD.W	D0,D4	SWAP.W	D1	ADD.W	D1,D4	SUB.W	D1,#2	SWAP.W	D1		; D1 <-- P1 droite	SUB.W	SP,#12		; rserve 12 bytes sur le stack (PUSH)	LOAD.L	A3,#(SP)+1	; A3 <-- ^buffer sur le stack	LOAD.B	(A3)+0,#DRAWMATRIX	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,#4	SWAP.W	D3	ADD.W	D3,#-15	ADD.W	D3,D0	LOAD.L	(A3)+1,D3	; <xx> et <yy>	ADD.W	D3,#27	SWAP.W	D3	ADD.W	D3,#48	LOAD.L	D0,D3		; D0 <-- P2 droite	LOAD.L	A4,#R16"BLUP	LOAD.L	(A3)+5,A4	; <pppp>	LOAD.B	(A3)+9,#INVDOT	; <m>	LOAD.W	D3,#10	LIB	?STRING	ADD.W	SP,#12		; reprend le buffer sur le stack (POP)	LIB	?BUCAR	LOAD.L	D3,D0	LOAD.L	D4,D1	LOAD.W	D1,#17	LOAD.W	D2,#SETDOT	CALL	DRTRIANGLE	INC.W	D3	CALL	DRTRIANGLE	INC.W	D3	CALL	DRTRIANGLE	INC.W	D3	CALL	DRTRIANGLE	LOAD.W	D2,#CLRDOT	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	PUSHM.L	D3,D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine droite de liaison pour la bulle	CLR.L	D4	LOAD.W	D4,#-3	LIB	?DRSEG	POPM.L	D3,D4	ADD.W	D4,#12	PUSHM.L	D3,D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine droite de liaison pour la bulle	LOAD.L	D4,#+3	LIB	?DRSEG	POPM.L	D3,D4	LIB	?NOBUCAR	POPM.L	D0..D4,A3,A4	RET;-----------\\; DRTRIANGLE >;-----------/; Dessine un triangle plein.; in	D3.L	bas;	D4.L	haut;	D1.W	largeur au sommet;	D2.W	mode; out	-; mod	D7.WDRTRIANGLE:	PUSHM.L	D1,D3,D410$:	PUSHM.L	D3,D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine droite de liaison pour la bulle	POPM.L	D3,D4	INC.W	D4	DEC.W	D1	JUMP,NE 10$	POPM.L	D1,D3,D4	RETTDBOX_TERR0:	.B	ODBLABEL,10	; label pour le signe BLUP	.B	ODBTEXT,0	.B	ODBTABX,10	.B	ODBLABEL,1	.B	ODBLABEL,20	.B	ODBTEXT,0LDBOX_TERR0	=  .-TDBOX_TERR0TDBOX_TERR1:	.B	ODBLABEL,21	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCR	.B	ODBCR,ODBCR	.B	ODBTABX,10	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"   VU   "	.B	0LDBOX_TERR1	=  .-TDBOX_TERR1TDBOX_TERR2:	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,DEFINE,TDBNORM	.ASCIZ	" DETAILS "	.B	0LDBOX_TERR2	=  .-TDBOX_TERR2TDBOX_TERR3:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Vu"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""LDBOX_TERR3	=  .-TDBOX_TERR3TDBOX_TERR4:	.ASCIZ	"Dtails"LDBOX_TERR4	=  .-TDBOX_TERR4	.EVENTKEY_ERROR:	.W	KEYMGP,KEYMMP,KEYMDP	.W	F0,F1,F2,F3,CR,END,SPACE,0	DOKF1-TKEY_ERROR	.W	F13,F14,F15,DEFINE,0		DOKDEF-TKEY_ERROR	.W	KEYMGR,KEYMMR,KEYMDR,0		DOKMGR-TKEY_ERROR	.W	0;------------\\; _DBOX_ERROR >;============/; Affiche une erreur.; Il faudra redessiner les soft-keys (LIB,?AFMENU).; in	D7.W	code de l'erreur;	A3.L	^nom du fichier; out	-; mod	-_DBOX_ERROR:	PUSHM.L	D1,D2,D7	LOAD.W	D1,D7		; D1 <-- erreur	LOAD.W	D2,#2^BDBSAV	CALL	_DBOX_MERROR	; affiche en sauvant dessous	JUMP',EQ 90$	COMP.W	D7,#ERNEMEM	JUMP',NE 90$	LOAD.W	D7,D1	CLR.W	D2	CALL	_DBOX_MERROR	; affiche sans sauver dessous90$:	POPM.L	D1,D2,D7	RET;-------------\\; _DBOX_MERROR >;=============/; Affiche une erreur.; Il faudra redessiner les soft-keys (LIB,?AFMENU).; in	D7.W	code de l'erreur;	A3.L	^nom du fichier;	D2.W	mode d'ouverture;	D3.L	position centre (si BDBPOS); out	D7.W	erreur; mod	D7.W_DBOX_MERROR:	PUSHM.L	D1..D4,A3,A4	LOAD.W	D1,D7		; D1 <-- erreur	CLR.W	D7		; D7 <-- ok	TEST.W	D1	JUMP,EQ 90$	COMP.W	D1,#ERKYES	JUMP,EQ 90$	COMP.W	D1,#ERKNO	JUMP,EQ 90$	COMP.W	D1,#ERKSTO	JUMP,EQ 90$	COMP.W	D1,#ERKWHA	JUMP,EQ 90$	COMP.W	D1,#ERKOTH	JUMP,EQ 90$	SUB.W	SP,#50		; rserve 50 bytes sur le stack (PUSH)	LOAD.L	A4,SP		; A4 <-- ^buffer sur le stack	PUSHM.L	D2,D3	LOAD.W	D2,#2^BERSNAM	; D2 <-- mode "nom court"	LOAD.W	D3,#50-2	; D3 <-- nb cars/ligne	LOAD.W	D4,#1		; D4 <-- nb lignes	LOAD.W	D7,D1		; D7 <-- numro de l'erreur	FOS	?XERROR		; buffer <-- message d'erreur	POPM.L	D2,D3	LOAD.L	A3,A4		; A3 <-- ^texte de l'erreur	TSET.L	D2:#BDBDET	; D2 <-- affiche la case (DETAILS)	CALL	_DBOX_TERROR	; affiche la dbox ...	ADD.W	SP,#50		; reprend le buffer sur le stack (POP)	TEST.W	D7	JUMP',NE 90$	COMP.W	D3,#DEFINE	; choix de (DETAILS) ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.W	D7,D1		; D7 <-- numro de l'erreur	CALL	DBOXDETAILS	; affiche les dtails ...	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXDETAILS >;============/; Affiche une erreur de faon dtaille.; in	D7.W	code de l'erreur;	D2.W	mode d'ouverture;	D3.L	position centre (si BDBPOS); out	D7.W	erreur; mod	D7.WDBOXDETAILS:	PUSHM.L	D1..D5,A1..A4	LOAD.W	D1,D7		; D1 <-- code de l'erreur	LOAD.L	A2,#R16"TDBOX_DETAILS	DBOX_	OPEN		; ouvre la swdo	JUMP,NE	90$	SUB.W	SP,#50		; rserve 50 bytes sur le stack (PUSH)	LOAD.L	A4,SP		; A4 <-- ^buffer sur le stack	LOAD.W	D2,#1!2^15	DBOX_	GETCO	LIB	?SETCURS	LOAD.B	D3,#AFINV	LIB	?AFCAR	LOAD.W	D2,#2^BERSNAM	LOAD.W	D3,#50-2	; D3 <-- nb cars/ligne	LOAD.W	D4,#1		; D4 <-- nb lignes	LOAD.W	D7,D1		; D7 <-- numro de l'erreur	FOS	?XERROR		; buffer <-- message d'erreur	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le message	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LOAD.W	D2,#2!2^15	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D3,D1	SR.W	D3,#8	LOAD.L	A3,#R16"00$20$:	TEST.B	(A3)	JUMP',EQ 25$	COMP.B	D3,(A3+)	JUMP',EQ 23$22$:	TEST.B	(A3+)	JUMP,NE 22$	JUMP	20$23$:	LIB	?AFTEXT		; affiche la provenance	JUMP'	29$25$:	LIB	?AFTIM	.ASCIZ	"?"	.EVEN29$:	LOAD.W	D2,#3!2^15	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D4,D1	LIB	?AFX4		; affiche le numro	LOAD.W	D2,#4!2^15	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D3,D1	AND.W	D3,#H'FF00	COMP.W	D3,#ERFOS	JUMP',NE 47$	LOAD.W	D2,#2^BERLNAM!2^BERLOGIQ!2^BERNOTXT	LOAD.W	D3,#50-2	; D3 <-- nb cars/ligne	LOAD.W	D4,#1		; D4 <-- nb lignes	LOAD.W	D7,D1		; D7 <-- numro de l'erreur	FOS	?XERROR		; buffer <-- nom du fichier	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le nom du fichier	JUMP'	49$47$:	LIB	?AFTIM	.ASCIZ	"---"	.EVEN49$:	ADD.W	SP,#50		; reprend le buffer sur le stack (POP)50$:	DBOX_	EDIT		; attend touche/souris ...	LOAD.L	A1,#R16"TKEY_DETAILS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC		; touche admise ?	COMP.W	D3,#KEYMGR	JUMP,EQ 50$	COMP.W	D3,#F1	JUMP',EQ 80$60$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	50$80$:	DBOX_	CLOSE		; ferme la swdo90$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.ASCIZ	"<H'04>$DIS (cran)"			; $DIS	.ASCIZ	"<H'05>#PRINTER (imprimante)"		; $OKI ...	.ASCIZ	"<H'81>NTREL (noyau temps rel)"	; NTREL	.ASCIZ	"<H'82>BIOS (priphrique)"		; BIOS	.ASCIZ	"<H'83>GESMEM (mmoire)"		; GESMEM	.ASCIZ	"<H'85>FOS (gestionnaire de fichiers)"	; FOS	.ASCIZ	"<H'86>LIB (librairie)"			; LIB	.ASCIZ	"<H'88>MM (disque)"			; MM	.ASCIZ	"<H'89>@NETWORK (rseau)"		; $NANET ...	.B	0	.EVENTDBOX_DETAILS:	.W	10$-TDBOX_DETAILS	.W	20$-TDBOX_DETAILS	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Message :    "	.B	ODBLABEL,1	.B	ODBTEXT	.ASCIZ	"                                        "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Provenance : "	.B	ODBLABEL,2	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Numro :     "	.B	ODBLABEL,3	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Fichier :    "	.B	ODBLABEL,4	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"   VU   "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Vu"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_DETAILS:	.W	F0,F1,F2,F3,CR,END,SPACE,0	DOKF1-TKEY_DETAILS	.W	KEYMGR,KEYMMR,KEYMDR,0		DOKMGR-TKEY_DETAILS	.W	0;-------------\\; _DBOX_AFFILE >;=============/; Affiche un nom de fichier, quel que soit son terminateur,; en minuscules et entre guillemets.; in	A3.L	^nom du fichier; out	-; mod	D7.W_DBOX_AFFILE:	PUSHM.L	D2,D3	LOAD.B	D3,#'"	LIB	?AFCAR	LOAD.W	D2,#BAFXMI	; D2 <-- affiche en minuscule	LOAD.W	D3,#-1		; D3 <-- pas de lg max	LIB	?AFXFILE	; affiche le nom du fichier	LOAD.B	D3,#'"	LIB	?AFCAR	POPM.L	D2,D3	RET;-----------\\; _DBOX_OPEN >;===========/; Affiche une bote de dialogue.; in	A2.L	^table de description;	D2.W	mode d'ouverture;	D3.L	position centre (si BDBPOS);	D4.L	tats des fanions; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.W_DBOX_OPEN:	TEST.L	D2:#BDBEXTEND	JUMP,BS _DBOX_EXTEND	COMP.L	A2,#0	JUMP,EQ _DBOX_EXTEND	PUSHM.L	D1,D2,D3,D4,A0,A3,A4,A6	CALL	OPEVAR		; A6 <-- ^variables	JUMP',NE 95$	LOAD.L	(A6)+OPTABLE,A2	; mm ^table	LIB	?CLREDIT	; clear pour LIB,?EDIT	CALL	RSTWDO		; lit le ^description de la fentre	JUMP',NE 90$	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^description de la fentre	LOAD.W	A4,(A2)+0	; A4 <-- ^relatif table	ADD.L	A4,A2		; A4 <-- ^table	LOAD.L	(A6)+OFANION,D4	; mm. les fanions	CLR.L	(A6)+OFADESS	; aucun fanion dessin	CALL	DIMALL		; D4 <-- dimensions maximales	CALL	CREWDO		; cre la swdo	JUMP',NE 90$	TCLR.B	(A6)+OFLAGS:#BNODES	CALL	DESALL		; dessine selon la table	TEST.W	(A2)+2		; table menu existe ?	JUMP',EQ 50$		; non => 50$	LOAD.W	A3,(A2)+2	; A3 <-- ^relatif table menu	ADD.L	A3,A2		; A3 <-- ^table menu	LIB	?AFMENU		; affiche les soft-keys50$:	TEST.W	(A2)+4		; table icnes existe ?	JUMP',EQ 90$		; non => 90$	LOAD.W	A3,(A2)+4	; A3 <-- ^relatif table icnes	ADD.L	A3,A2		; A3 <-- ^table icnes horizontaux	LOAD.L	A4,#0		; A4 <-- ^nil (icnes verticaux)	CALL	_DBOX_ICOAFF	; affiche les icnes90$:	TEST.W	D7		; ok ?	JUMP',EQ 95$		; oui => 95$	CALL	CLOVAR		; non => rend les variables95$:	LOAD.L	D5,A6		; D5 <-- "canal"	POPM.L	D1,D2,D3,D4,A0,A3,A4,A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; _DBOX_MEDIT >;============/; Modifie le fichier/ligne ditable dans une bote de dialogue.; in	D3.W	rang fichier/ligne ditable (0..n);		-1 => rien d'ditable;	D5.L	canal; out	-; mod	D7.W_DBOX_MEDIT:	PUSHM.L	D3,A6	LOAD.L	A6,D5		; A6 <-- ^variables	COMP.W	D3,#-1	JUMP',EQ 20$	COMP.W	D3,(A6)+ONBFILE	JUMP',LO 20$	LOAD.W	D3,(A6)+ONBFILE	JUMP',EQ 20$	DEC.W	D320$:	LOAD.W	(A6)+OUSFILE,D3	POPM.L	D3,A6	CLR.W	D7		; retour EQ	RET;-----------\\; _DBOX_EDIT >;===========/; Edite une bote de dialogue.; in	A3.L	^dbut ligne  diter;	A4.L	^dans la ligne;	D4.L	tat des fanions;	D5.L	canal; out	D3.W	dernire touche frappe;	D4.L	tat des fanions;	A4.L	^dans la ligne; mod	D3.L, D4.L, D7.W, A4.L_DBOX_EDIT:	PUSHM.L	D2,D5,A0,A1,A2,A3,A5,A6	LOAD.L	A6,D5		; A6 <-- ^variables	LOAD.L	A2,(A6)+OPTABLE	; A2 <-- ^table	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^description de la fentre	LOAD.W	D5,(A6)+ONOWDO	LIB	?USEWDO		; utilise la bonne swdo	COMP.L	D4,(A6)+OFANION	; fanions changs ?	JUMP',EQ 10$		; non => 10$				; oui =>	LOAD.L	(A6)+OFANION,D4	; mm. les nouveaux fanions	PUSH.L	A4	LOAD.W	A4,(A2)+0	; A4 <-- ^relatif table	ADD.L	A4,A2		; A4 <-- ^table	TSET.B	(A6)+OFLAGS:#BNODES	CALL	DESALL		; redessine tous les fanions	POP.L	A410$:	LOAD.L	A1,A4		; A1 <-- ^dans la ligne  diter20$:	TEST.W	(A6)+ONBFILE	; un/qq fichiers/lignes ditables ?	JUMP,EQ 26$		; non => 26$				; oui =>	LOAD.L	A5,#(A6)+OTAFILE	LOAD.W	D3,(A6)+OUSFILE	COMP.W	D3,#-1		; rien d'ditable ?	JUMP,EQ 26$		; oui => 26$	MUL.WU	D3,#LGFI	ADD.L	A5,D3		; A5 <-- ^dans OTAFILE	LOAD.L	D3,(A5)+OFIPOS	; D3 <-- position	LIB	?SETCURS	; positionne au dbut	LOAD.L	D3,(A5)+OFILG	; D3 <-- lg buffer	TEST.B	(A5)+OFITYP	JUMP',NE 24$	LOAD.L	A4,A1		; A4 <-- ^dans buffer	LOAD.L	A5,#0		; A5 <-- pas de table pour soft-keys	LIB	?GETFILE	; attend fichier/souris ...	LOAD.L	A1,A4		; A1 <-- ^dans buffer	JUMP'	30$24$:	LOAD.L	A4,A1		; A4 <-- ^dans buffer	LOAD.L	A5,A2	LOAD.L	A2,#R16"00$	; A2 <-- table des touches de sortie	LIB	?EDIT		; attend fichier/souris ...	LOAD.L	A2,A5	LOAD.L	A1,A4		; A1 <-- ^dans buffer	JUMP'	30$26$:	LIB	?GETCAR		; attend touche/souris ...30$:	LIB	?AFTIM	.B	NOCURS,0	; plus de curseur	.EVEN	PUSH.L	A3	LOAD.L	A4,(A6)+OPTABLE	TEST.W	(A4)+4		; table icnes existe ?	JUMP',EQ 35$		; non => 35$	LOAD.W	A3,(A4)+4	; A3 <-- ^relatif table icnes	ADD.L	A3,A4		; A3 <-- ^table icnes horizontaux	LOAD.L	A4,#0		; A4 <-- ^nil (icnes verticaux)	CALL	_DBOX_ICODET	; dtecte si on est dans une icne ?	JUMP',NE 35$		; non => 35$	COMP.W	D2,#-1	JUMP',EQ 35$	ADD.W	D2,#F0	LOAD.W	D3,D2		; D3 <-- nouvelle touche (F0)..(F15)35$:	POP.L	A3	COMP.W	D3,#KEYMGP	JUMP',EQ 40$	COMP.W	D3,#KEYMMP	; bouton press ?	JUMP',EQ 40$		; oui => 40$	COMP.W	D3,#KEYMDP	JUMP,NE	90$40$:	PUSH.W	D3	LIB	?IFMOUSE	; D4 <-- position de la souris	POPM.W	D3	JUMP,NE	80$	LOAD.W	A4,(A2)+0	; A4 <-- ^relatif table	ADD.L	A4,A2		; A4 <-- ^table	CALL	DETALL		; dtecte o est la souris	JUMP,NE	90$	LOAD.W	D2,#SETDOT	CALL	PRESOBJET	; presse l'objet slectionn	LOAD.L	A5,A4		; A5 <-- ^objet slectionn	LOAD.L	D5,D4		; D5 <-- position45$:	LIB	?GETKEY		; attend touche/souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',EQ 50$		; oui => 50$	COMP.W	D3,#KEYMGR	JUMP',EQ 60$	COMP.W	D3,#KEYMMR	; bouton relach ?	JUMP',EQ 60$		; oui => 60$	COMP.W	D3,#KEYMDR	JUMP',EQ 60$	JUMP	45$50$:				; souris dplace =>	PUSH.W	D3	LIB	?IFMOUSE	; D4 <-- position de la souris	POPM.W	D3	JUMP,NE	45$	LOAD.W	A4,(A2)+0	; A4 <-- ^relatif table	ADD.L	A4,A2		; A4 <-- ^table	CALL	DETALL		; dtecte o est la souris	COMP.L	A4,A5		; mme objet slectionn ?	JUMP,EQ	45$		; oui => 45$				; non =>	EX.L	A4,A5	EX.L	D4,D5	LOAD.W	D2,#CLRDOT	CALL	PRESOBJET	; relache l'ancien objet	LOAD.L	A4,A5	LOAD.L	D4,D5	LOAD.W	D2,#SETDOT	CALL	PRESOBJET	; presse le nouvel objet	JUMP	45$60$:	TEST.L	D4		; un objet slectionn ?	JUMP,EQ	20$		; non => 20$				; oui =>	CALL	INVOBJET	; inverse l'objet slectionn	LOAD.W	D2,#CLRDOT	CALL	PRESOBJET	; relache l'objet slectionn	PUSH.L	A4	LOAD.W	A4,(A2)+0	; A4 <-- ^relatif table	ADD.L	A4,A2		; A4 <-- ^table	TSET.B	(A6)+OFLAGS:#BNODES	CALL	DESALL		; redessine tous les fanions	POP.L	A4	COMP.B	(A4),#ODBXFILE	; "clic" dans un fichier ditable ?	JUMP',EQ 67$		; oui => 67$	COMP.B	(A4),#ODBXLINE	; "clic" dans une ligne ditable ?	JUMP',EQ 67$		; oui => 67$	COMP.B	(A4),#ODBFILE	; "clic" dans un fichier ditable ?	JUMP',EQ 65$		; oui => 65$	COMP.B	(A4),#ODBLINE	; "clic" dans une ligne ditable ?	JUMP',EQ 65$		; oui => 65$	COMP.B	(A4),#ODBCLINE	; "clic" dans une ligne ditable ?	JUMP',EQ 65$		; oui => 65$	COMP.B	(A4),#ODBBOX	; "clic" dans une bote ?	JUMP',EQ 70$		; oui => 70$	COMP.B	(A4),#ODBCIRCLE	; "clic" dans un cercle ?	JUMP',EQ 65$		; oui => 65$	COMP.B	(A4),#ODBLCIRCLE; "clic" dans un petit cercle ?	JUMP',EQ 65$		; oui => 65$	COMP.B	(A4),#ODBSQUARE	; "clic" dans un carr ?	JUMP,NE	20$		; non => 20$65$:	TEST.B	(A4)+1:#7	; <bit> spcial ?	JUMP,BC	20$		; non => 20$	INC.L	A4	JUMP'	70$67$:	ADD.L	A4,#370$:	CLR.L	D3	LOAD.B	D3,(A4)+1	; D3 <-- <fonc>	SL.W	D3,#8	LOAD.B	D3,(A4)+2	; D3 <-- <touche>	JUMP'	90$80$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$90$:	LOAD.L	D4,(A6)+OFANION	; D4 <-- tats des fanions	LOAD.L	A4,A1		; A4 <-- ^dans la ligne	CLR.W	D7		; D7 <-- ok	POPM.L	D2,D5,A0,A1,A2,A3,A5,A6	TEST.W	D7		; retour EQ/NE	RET00$:				; table pour LIB,?EDIT	.B	0,UNDO	.B	0,TAB	.B	2^7	.EVEN;------------\\; _DBOX_CLOSE >;============/; Ferme une bote de dialogue.; in	D5.L	canal; out	-; mod	D7.W_DBOX_CLOSE:	PUSHM.L	D5,A0,A6	LOAD.L	A6,D5		; A6 <-- ^variables	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^description de la fentre	LOAD.W	D5,(A6)+ONOWDO	LIB	?USEWDO		; utilise la bonne swdo	CALL	CLOWDO		; ferme la swdo	CALL	CLOVAR		; rend les variables	POPM.L	D5,A0,A6	RET;------------\\; _DBOX_CADRE >;============/; Ouvre une sous-fentre et dessine juste son cadre.; in	D2.W	mode d'ouverture;	D3.L	centre (Y;X) si BDBPOS;	D4.L	dimensions (dY,dX); out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.W_DBOX_CADRE:	PUSHM.L	A0,A6	CALL	OPEVAR		; A6 <-- ^variables	JUMP',NE 80$	CALL	RSTWDO		; lit le ^description de la fentre	JUMP',NE 80$	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^description de la fentre	CALL	CREWDO		; cre la swdo	JUMP',EQ 80$	CALL	CLOVAR		; rend les variables80$:	LOAD.L	D5,A6		; D5 <-- "canal"	POPM.L	A0,A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; _DBOX_GETCO >;============/; Donne les coordonnes d'un objet quelconque.; Lorsque D2:#BDBGCLABEL = 0, compte les objets depuis le premier; (les objets ODBCR*, ODBTAB*, ODBTRAME et ODBLABEL ne sont pas compts).; Lorsque D2:#BDBGCLABEL = 1, cherche l'objet plac juste aprs le ODBLABEL.; in	D2.W	si BDBGCLABEL=0  -->  rang de l'objet (0..n);		si BDBGCLABEL=1  -->  label recherch;		si BDBGCGREY=1   -->  "grise" l'objet;		si BDBGCFULL=1   -->  "dgrise" l'objet;	D5.W	canal; out	D3.L	coordonne dbut;	D4.L	coordonne fin;	D7.W	erreur; mod	D3.L, D4.L, D7.W_DBOX_GETCO:	PUSHM.L	D1,D2,A0,A2,A3,A4,A6	LOAD.L	A6,D5		; A6 <-- ^variables	LOAD.L	A2,(A6)+OPTABLE	; A2 <-- ^table	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^description de la fentre	LOAD.W	A4,(A2)+0	; A4 <-- ^relative table	ADD.L	A4,A2		; A4 <-- ^table	LOAD.L	D4,(A6)+OMARGY	CLR.W	(A6)+ONOFILE	TSET.B	(A6)+OFLAGS:#BNODES	TCLR.B	(A6)+OFLAGS:#BFADES	CLR.W	D1		; D1 <-- rang	TEST.L	D2:#BDBGCLABEL	; recherche d'un label ?	JUMP,BC 20$		; non => 20$; Cherche un objet d'aprs son label.10$:	LOAD.W	D7,#ERDIOUT	TEST.B	(A4)		; encore un objet ?	JUMP,EQ	90$		; non => 90$	LOAD.L	A3,A4		; A3 <-- ^l'objet	PUSH.L	D4	CALL	DESOBJET	; D4 <-- position fin	POP.L	D3		; D3 <-- position dbut	INC.W	D1		; D1 <-- rang suivant	COMP.B	(A3),#ODBLABEL	; objet LABEL trouv ?	JUMP,NE	10$		; non => 10$	COMP.B	D2,(A3)+1	; est-ce le bon label ?	JUMP,NE 10$		; non => 10$				; oui =>	CLR.B	D2		; D2 <-- cherche le prochain objet; Cherche un objet d'aprs son rang.20$:	INC.B	D2		; D2 <-- rang 1..n22$:	LOAD.W	D7,#ERDIOUT	TEST.B	(A4)		; encore un objet ?	JUMP,EQ	90$		; non => 90$	LOAD.L	A3,A4		; A3 <-- ^l'objet	PUSH.L	D4	CALL	DESOBJET	; D4 <-- position fin	POP.L	D3		; D3 <-- position dbut	INC.W	D1		; D1 <-- rang suivant	COMP.B	(A3),#ODBCR	; ignore les CR	JUMP,EQ	22$	COMP.B	(A3),#ODBCR2	; ignore les CR	JUMP,EQ	22$	COMP.B	(A3),#ODBTABX	; ignore les TABX	JUMP,EQ	22$	COMP.B	(A3),#ODBTABXN	; ignore les TABXN	JUMP,EQ	22$	COMP.B	(A3),#ODBTABYN	; ignore les TABYN	JUMP,EQ	22$	COMP.B	(A3),#ODBTRAME	; ignore les TRAMEs	JUMP,EQ	22$	COMP.B	(A3),#ODBLABEL	; ignore les LABELs	JUMP,EQ	22$	DEC.B	D2		; objet trouv ?	JUMP,NE	22$		; non => 22$	TEST.L	D2:#BDBGCGREY	JUMP,BS 40$	TEST.L	D2:#BDBGCFULL	JUMP,BS 50$; Prend les coordonnes de l'objet trouv.	COMP.B	(A3),#ODBBOX	; bote rectangulaire ?	JUMP',EQ 30$		; oui => 30$	COMP.B	(A3),#ODBFILE	JUMP',EQ 30$	COMP.B	(A3),#ODBLINE	JUMP',EQ 30$	COMP.B	(A3),#ODBCLINE	JUMP',EQ 30$	COMP.B	(A3),#ODBXLINE	JUMP',EQ 30$	COMP.B	(A3),#ODBXFILE	JUMP,NE 80$30$:	LOAD.W	D2,(A6)+OCX	ADD.W	D3,D2	SUB.W	D4,D2	SUB.W	D4,D2	JUMP	80$; Grise un objet quelconque.40$:	PUSHM.L	D0,A0	CALL	GETMAP		; A0/D0 <-- ^map/bit	TSET.B	(A0):D0	POPM.L	D0,A0	JUMP,BS 80$	PUSHM.L	D3,D4	LOAD.L	D3,#H'55AA55AA	LOAD.L	D4,D3	LIB	?DRMDEF		; dfini une trame grise	POPM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	LOAD.W	D2,(A0)+ODFC2Y	ADD.W	D2,#5	COMP.B	(A3),#ODBBOX	; bote rectangulaire ?	JUMP',EQ 44$		; oui => 44$	COMP.B	(A3),#ODBFILE	JUMP',EQ 44$	COMP.B	(A3),#ODBLINE	JUMP',EQ 44$	COMP.B	(A3),#ODBCLINE	JUMP',EQ 44$	COMP.B	(A3),#ODBXLINE	JUMP',EQ 44$	COMP.B	(A3),#ODBXFILE	JUMP',EQ 44$	LOAD.W	D2,#144$:	SUB.W	D3,D2	DEC.W	D2	ADD.W	D4,D2	SUB.W	D4,D3	LOAD.W	D2,(A0)+ODFFDY	SUB.W	D2,D3	COMP.W	D4,D2		; dpasse le bas de la swdo ?	JUMP',LO 45$		; non => 45$	LOAD.W	D4,D245$:	SWAP.W	D4	SWAP.W	D3	SUB.W	D4,D3	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; grise toute la surface (carrment)	JUMP'	80$; Dgrise un objet quelconque.50$:	PUSHM.L	D0,A0	CALL	GETMAP		; A0/D0 <-- ^map/bit	TCLR.B	(A0):D0	POPM.L	D0,A0	JUMP',BC 80$	LOAD.L	A4,A3	LOAD.L	D4,D3	COMP.B	(A4),#ODBCIRCLE	JUMP',EQ 53$	COMP.B	(A4),#ODBLCIRCLE	JUMP',EQ 53$	COMP.B	(A4),#ODBSQUARE	JUMP',NE 54$53$:	LOAD.L	D3,(A6)+OFADESS	LOAD.B	D2,(A4)+1	TCLR.L	D3:D2		; il faudra redessiner l'intrieur !	LOAD.L	(A6)+OFADESS,D354$:	TCLR.B	(A6)+OFLAGS:#BNODES	TSET.B	(A6)+OFLAGS:#BFADES	CALL	DESOBJET	; redessine l'objet normalement80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D2,A0,A2,A3,A4,A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; _DBOX_CALLC >;============/; Appel une routine selon une touche presse.; in	A1.L	^table .W t1,t2,t3,0,adr termine par .W 0;	D1.W	mode de convertion;	D3.W	touche presse; out	NE	pas trouv; mod	D7.W_DBOX_CALLC:	PUSHM.L	D0,A0	LOAD.W	D0,D3	CLR.B	D0	COMP.W	D0,#KEYMPO	; bouton de la souris ?	JUMP',NE 05$		; non => 05$	LOAD.W	D0,D3		; oui =>	JUMP'	15$05$:	LOAD.W	D0,D3		; D0 <-- touche presse	TEST.L	D1:#BDBCCMM	JUMP',BC 10$	EX.L	D3,D0	LIB	?MINMAJ		; (min) --> MAJ	EX.L	D0,D310$:	TEST.L	D1:#BDBCCFF	JUMP',BC 15$	COMP.B	D0,#SHIFT+F0	JUMP',LO 15$	COMP.B	D0,#SHIFT+F15	JUMP',HI 15$	SUB.B	D0,#SHIFT	; (SHIFT-Fn) --> (Fn)15$:	LOAD.W	D7,#1		; D7 <-- pas trouv	LOAD.L	A0,A1		; A0 <-- ^table clavier20$:	TEST.W	(A0)		; fin table clavier ?	JUMP',EQ 90$		; oui => 90$30$:	TEST.W	(A0)		; fin liste de touches ?	JUMP',EQ 40$		; oui => 40$	COMP.W	D0,(A0+)	; touche trouve ?	JUMP,NE	30$		; non => 30$	JUMP'	50$		; oui => 50$40$:	ADD.L	A0,#4		; A0 <-- saute <<0>> <<adresse>>	JUMP	20$50$:	TEST.W	(A0+)		; A0 <-- saute jusqu'au <<0>>	JUMP,NE	50$	LOAD.W	A0,(A0)		; A0 <-- adresse relative	ADD.L	A0,A1		; A0 <-- adresse absolue	CALL	(A0)		; appel routine utilisateur	CLR.W	D7		; D7 <-- routine appele90$:	POPM.L	D0,A0	TEST.W	D7		; retour EQ/NE	RET;--------\\; DIMALL  >;========/; Calcul les dimensions pour la fentre.; in	A4.L	^table;	D2.W	mode d'ouverture; out	D4.L	dimensions; mod	D4.LDIMALL:	PUSHM.L	D0,D1,D3,A4	CLR.W	(A6)+OMARGX	LOAD.W	(A6)+OMARGY,#10	TEST.L	D2:#BDBMAX	; pas de marges ?	JUMP',BS 05$		; oui => 05$	LOAD.W	D4,(A6)+OCX	MUL.WU	D4,#MARGGD	LOAD.W	(A6)+OMARGX,D4	LOAD.W	D4,(A6)+OCY	MUL.WU	D4,#MARGSI	LOAD.W	(A6)+OMARGY,D405$:	CLR.W	D0		; D0 <-- largeur	CLR.W	D1		; D1 <-- hauteur	LOAD.L	D4,(A6)+OMARGY	CLR.W	(A6)+ONOFILE	TSET.B	(A6)+OFLAGS:#BNODES	TCLR.B	(A6)+OFLAGS:#BFADES10$:	TEST.B	(A4)	JUMP',EQ 50$	CALL	DESOBJET	COMP.W	D4,D0		; plus large que prcdent ?	JUMP',LS 20$		; non => 20$	LOAD.W	D0,D4		; oui => mm. le maximum20$:	SWAP.W	D4	COMP.W	D4,D1		; plus haut que prcdent ?	JUMP',LS 30$		; non => 30$	LOAD.W	D1,D4		; oui => mm. le maximum30$:	SWAP.W	D4	JUMP	10$50$:	LOAD.W	(A6)+ONBFILE,(A6)+ONOFILE	LOAD.W	D4,D1		; D4 <-- hauteur maximale	ADD.W	D4,(A6)+OMARGY	INC.W	D4	AND.W	D4,#H'FFFE	; D4 <-- modulo 2	LOAD.W	(A6)+ODIMWDO+0,D4	ADD.W	D4,#16		; D4 <-- ajoute marges swdo	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- largeur maximale	ADD.W	D4,(A6)+OMARGX	SUB.W	D4,(A6)+OCX	ADD.W	D4,#8-1	AND.W	D4,#H'FFF8	; D4 <-- modulo 8	LOAD.W	(A6)+ODIMWDO+2,D4	ADD.W	D4,#16		; D4 <-- ajoute marges swdo	POPM.L	D0,D1,D3,A4	RET;--------\\; DETALL  >;========/; Dtecte o est la souris.; in	A4.L	^table;	D4.L	position de la souris; out	A4.L	^objet trouv;	D4.L	coordonne dbut;	D7.W	erreur; mod	D4.L, D7.W, A4.LDETALL:	PUSHM.L	D0,D1,D2,D3,D5,D6,A3	LOAD.W	D0,D4		; D0 <-- position X souris	SUB.W	D0,(A0)+ODFFX	JUMP,LO	90$	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- position Y souris	SUB.W	D6,(A0)+ODFFY	JUMP,LO	90$	LOAD.L	D4,(A6)+OMARGY	CLR.W	(A6)+ONOFILE	TSET.B	(A6)+OFLAGS:#BNODES	TCLR.B	(A6)+OFLAGS:#BFADES	CLR.W	D1		; D1 <-- rang10$:	TEST.B	(A4)	JUMP,EQ	90$	LOAD.L	A3,A4		; A3 <-- ^objet	LOAD.L	D2,D4		; D2 <-- position dbut	CALL	DESOBJET	; D4 <-- position fin	LOAD.L	D5,D4		; D5 <-- position fin	INC.W	D1		; D1 <-- rang suivant	COMP.B	(A3),#ODBFILE	JUMP',EQ 20$	COMP.B	(A3),#ODBLINE	JUMP',EQ 20$	COMP.B	(A3),#ODBCLINE	JUMP',EQ 20$	COMP.B	(A3),#ODBXLINE	JUMP',EQ 20$	COMP.B	(A3),#ODBXFILE	JUMP',EQ 20$	COMP.B	(A3),#ODBCIRCLE	JUMP',EQ 20$	COMP.B	(A3),#ODBLCIRCLE	JUMP',EQ 20$	COMP.B	(A3),#ODBSQUARE	JUMP',EQ 20$	COMP.B	(A3),#ODBBOX	JUMP,NE 10$	SUB.W	D5,(A6)+OCX20$:	SWAP.W	D5	SUB.W	D5,(A6)+OC1Y	SUB.W	D5,(A6)+OC2Y;;?	SUB.W	D5,#2	COMP.W	D6,D5		; souris plus haute ?	JUMP,LO	10$	ADD.W	D5,(A6)+OC2Y	ADD.W	D5,(A6)+OC1Y	ADD.W	D5,(A6)+OC2Y;;?	ADD.W	D5,#2+2	COMP.W	D6,D5		; souris plus basse ?	JUMP,HI	10$	SWAP.W	D5	COMP.W	D0,D2		; souris plus  doite ?	JUMP,LO	10$	COMP.W	D0,D5		; souris plus  gauche ?	JUMP,HI	10$	PUSHM.L	D0,A0	CALL	GETMAP		; A0/D0 <-- ^map/bit	TEST.B	(A0):D0		; objet gris ?	POPM.L	D0,A0	JUMP,BS 10$		; oui => 10$	LOAD.L	D4,D2		; D4 <-- position dbut	LOAD.L	A4,A3		; A4 <-- ^objet	CLR.W	D7		; D7 <-- trouv	JUMP'	95$90$:	CLR.L	D4		; D4 <-- position "nil"	LOAD.L	A4,D4		; A4 <-- ^nil	LOAD.W	D7,#1		; D7 <-- pas trouv95$:	POPM.L	D0,D1,D2,D3,D5,D6,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETMAP  >;--------/; Donne le pointeur et le numro du bit dans le map.; in	D1.W	rang; out	A0/D0	^map/bit; mod	D0.L, A0.LGETMAP:	PUSH.W	D1	COMP.W	D1,#256	JUMP',LO 10$	LOAD.W	D1,#256-110$:	LOAD.L	A0,#(A6)+OMAPGR	LOAD.B	D0,D1	AND.B	D0,#B'111	; D0 <-- rang du bit	SR.W	D1,#3	ADD.W	A0,D1		; A0 <-- ^byte dans map	POP.W	D1	RET;--------\\; DESALL  >;========/; Dessine tous les objets.; in	A4.L	^table; out	-; mod	-DESALL:	PUSHM.L	D3,D4,A3,A4	LIB	?BUCAR	LOAD.L	(A6)+OFACIRC,#-1	LOAD.L	D4,(A6)+OMARGY	CLR.W	(A6)+ONOFILE	TSET.B	(A6)+OFLAGS:#BFADES	TCLR.B	(A6)+OFLAGS:#BTITLE10$:	TEST.B	(A4)	JUMP',EQ 80$	LOAD.L	A3,A4		; A3 <-- ^objet	CALL	DESOBJET	; dessine un objet	JUMP	10$80$:	LOAD.L	A3,A4	INC.L	A3		; A3 <-- ^textes pour soft-keys	LIB	?NOBUCAR	POPM.L	D3,D4,A3,A4	RET;----------\\; PRESOBJET >;==========/; Presse/relache un objet quelconque.; in	A4.L	^dans table;	D4.L	position;	D2.W	mode de dessin (SETDOT/CLRDOT); out	-; mod	-PRESOBJET:	TEST.L	D4		; objet existe ?	JUMP',EQ 90$		; non => 90$	COMP.B	(A4),#ODBFILE	JUMP,EQ	PRESFILE	COMP.B	(A4),#ODBLINE	JUMP,EQ	PRESFILE	COMP.B	(A4),#ODBCLINE	JUMP,EQ	PRESFILE	COMP.B	(A4),#ODBXLINE	JUMP,EQ	PRESFILE	COMP.B	(A4),#ODBXFILE	JUMP,EQ	PRESFILE	COMP.B	(A4),#ODBBOX	JUMP,EQ	PRESBOX	COMP.B	(A4),#ODBCIRCLE	JUMP,EQ	PRESCIRCLE	COMP.B	(A4),#ODBLCIRCLE	JUMP,EQ	PRESLCIRCLE	COMP.B	(A4),#ODBSQUARE	JUMP,EQ	PRESSQUARE90$:	RET;---------\\; INVOBJET >;=========/; Inverse un objet quelconque.; in	A4.L	^dans table;	D4.L	position; out	-; mod	-INVOBJET:	PUSHM.L	D1,D2,D3,D4,A4	LOAD.B	D3,(A4+)	; D3 <-- objet	COMP.B	D3,#ODBSQUARE	JUMP',EQ 20$	COMP.B	D3,#ODBCIRCLE	JUMP',EQ 10$	COMP.B	D3,#ODBLCIRCLE	JUMP',NE 90$10$:	LOAD.B	D3,(A4)		; D3 <-- no du fanion	TEST.L	D3:#6		; relche les autres boutons ?	JUMP',BS 20$		; non => 20$ (c'est fait manuellement)	LOAD.L	D1,(A6)+OFANION	AND.L	D1,(A6)+OFACIRC	; teint tous les fanions	LOAD.L	(A6)+OFANION,D120$:	LOAD.B	D3,(A4)		; D3 <-- no du fanion	LOAD.L	D1,(A6)+OFANION	; D1 <-- tats des fanions	TNOT.L	D1:D3		; inverse le fanion	LOAD.L	(A6)+OFANION,D190$:	POPM.L	D1,D2,D3,D4,A4	RET;---------\\; DESOBJET >;=========/; Dessine un objet quelconque.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D3.B, D4.L, A4.LDESOBJET:	LOAD.B	D3,(A4+)	; D3 <-- objet	COMP.B	D3,#ODBTITLE	JUMP,EQ	DESTITLE	COMP.B	D3,#ODBTEXT	JUMP,EQ	DESTEXT	COMP.B	D3,#ODBFILE	JUMP,EQ	DESFILE	COMP.B	D3,#ODBLINE	JUMP,EQ	DESLINE	COMP.B	D3,#ODBCLINE	JUMP,EQ	DESCLINE	COMP.B	D3,#ODBXLINE	JUMP,EQ	DESXLINE	COMP.B	D3,#ODBXFILE	JUMP,EQ	DESXFILE	COMP.B	D3,#ODBBOX	JUMP,EQ	DESBOX	COMP.B	D3,#ODBCIRCLE	JUMP,EQ	DESCIRCLE	COMP.B	D3,#ODBLCIRCLE	JUMP,EQ	DESCIRCLE	COMP.B	D3,#ODBSQUARE	JUMP,EQ	DESSQUARE	COMP.B	D3,#ODBCR	JUMP,EQ	DESCR	COMP.B	D3,#ODBCR2	JUMP,EQ	DESCR2	COMP.B	D3,#ODBTABX	JUMP,EQ	DESTABX	COMP.B	D3,#ODBTABXN	JUMP,EQ	DESTABXN	COMP.B	D3,#ODBTABYN	JUMP,EQ	DESTABYN	COMP.B	D3,#ODBTRAME	JUMP,EQ	DESTRAME	COMP.B	D3,#ODBLABEL	JUMP,EQ	DESLABEL	RET;---------\\; DESTITLE >;=========/; Dessine l'objet titre.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESTITLE:	PUSHM.L	D1,D2,D3,A3	TSET.B	(A6)+OFLAGS:#BTITLE	TEST.B	(A6)+OFLAGS:#BNODES	JUMP,BS	70$	LOAD.L	D1,D4	LOAD.W	D4,(A6)+OC1Y	SWAP.W	D4	CLR.W	D4	LOAD.L	A3,A4		; A3 <-- ^.ASCIZ	LOAD.W	D3,#-120$:	INC.W	D3		; D3 <-- nb de caractres	TEST.B	(A3+)	JUMP,NE	20$	ADD.W	D3,#1+1	MUL.WU	D3,(A6)+OCX	SUB.W	D3,(A6)+ODIMWDO+2	NEG.W	D3	SR.W	D3,#1		; D3 <-- lg pour une trame	CALL	DESTITRAME	; trame	ADD.W	D4,(A6)+OCX	; espace	CALL	DESASCIZ	; titre au centre	ADD.W	D4,(A6)+OCX	; espace	CALL	DESTITRAME	; trame	LOAD.L	D4,D1	JUMP'	80$70$:	CALL	DESASCIZ	; A4 <-- saute .ASCIZ	LOAD.W	D3,(A6)+OCX	MUL.WU	D3,#2+2		; au moins 2 car gauche/droite	ADD.W	D4,D380$:	CALL	DESCR		; passe  la ligne	POPM.L	D1,D2,D3,A3	RET;--------\\; DESTEXT >;========/; Dessine l'objet texte.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESTEXT:;;?	CALL	DESBASCIZ	; efface autour	JUMP	DESASCIZ	; dessine le texte;--------\\; DESFILE >;========/; Dessine l'objet nom de fichier.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESFILE:	PUSHM.L	D1..D3,A3	LOAD.L	A3,#(A6)+OTAFILE	LOAD.W	D3,(A6)+ONOFILE	MUL.WU	D3,#LGFI	ADD.L	A3,D3		; A3 <-- ^dans OTAFILE	CLR.B	(A3)+OFITYP	; table <-- type "fichier"DESFILI:	LOAD.L	D2,D4		; D2 <-- position de dpart	LOAD.B	D1,#TDBNORM	; D1 <-- type normal	CLR.L	D3	LOAD.B	D3,(A4+)	; D3 <-- nb caractres	JUMP',NC 30$	TCLR.L	D3:#7		; D3 <-- idem, mais positif	ADD.L	A4,#2		; A4 <-- saute <fonc> <touche>	LOAD.B	D1,(A4+)	; D1 <- <type>30$:	COMP.B	(A3)+OFITYP,#2	; type "clear-ligne" ?	JUMP',NE 40$	LOAD.B	(A3)+OFITYP,#1	; table <-- type "ligne"	TSET.L	D3:#15		; D3 <-- met le mode "clear-ligne"40$:	LOAD.L	(A3)+OFILG,D3	; table <-- longueur	AND.W	D3,#H'0FFF	MUL.WU	D3,(A6)+OCXDESYFILI:	CALL	DESBIG		; dessine mise en vidence selon D1	COMP.B	D1,#TDBSCAD	; objet sans cadre ?	JUMP',EQ 40$		; oui => 40$	CALL	DESRECT		; dessine rectangle englobant	JUMP'	50$40$:	PUSH.B	(A6)+OFLAGS	TSET.B	(A6)+OFLAGS:#BNODES	CALL	DESRECT		; "saute" rectangle englobant	POP.B	(A6)+OFLAGS50$:	ADD.W	D2,(A6)+OCX	LOAD.L	(A3)+OFIPOS,D2	; table <-- position pour ligne	INC.W	(A6)+ONOFILE	; un fichier ditable de plus	POPM.L	D1..D3,A3	RET;--------\\; DESLINE >;========/; Dessine l'objet ligne de texte.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESLINE:	PUSHM.L	D1..D3,A3	LOAD.L	A3,#(A6)+OTAFILE	LOAD.W	D3,(A6)+ONOFILE	MUL.WU	D3,#LGFI	ADD.L	A3,D3		; A3 <-- ^dans OTAFILE	LOAD.B	(A3)+OFITYP,#1	; table <-- type "ligne"	JUMP	DESFILI;---------\\; DESCLINE >;=========/; Dessine l'objet ligne de texte.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESCLINE:	PUSHM.L	D1..D3,A3	LOAD.L	A3,#(A6)+OTAFILE	LOAD.W	D3,(A6)+ONOFILE	MUL.WU	D3,#LGFI	ADD.L	A3,D3		; A3 <-- ^dans OTAFILE	LOAD.B	(A3)+OFITYP,#2	; table <-- type "clear-ligne"	JUMP	DESFILI;---------\\; DESXFILE >;=========/; Dessine l'objet nom de fichier.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESXFILE:	PUSHM.L	D1..D3,A3	LOAD.L	A3,#(A6)+OTAFILE	LOAD.W	D3,(A6)+ONOFILE	MUL.WU	D3,#LGFI	ADD.L	A3,D3		; A3 <-- ^dans OTAFILE	CLR.B	(A3)+OFITYP	; table <-- type "fichier"DESXFILI:	LOAD.L	D2,D4		; D2 <-- position de dpart	CLR.W	D3	LOAD.B	D3,(A4+)	; D3 <-- lg cran	MUL.WU	D3,(A6)+OCX	SWAP.W	D3	LOAD.B	D3,(A4+)	; D3 <-- lg buffer	RR.W	D3,#8	LOAD.B	D3,(A4+)	; D3 <-- flags	RR.W	D3,#8	TSET.L	D3:#14		; D3 <-- signal largeur dans D3 <31..16>	LOAD.L	(A3)+OFILG,D3	; table <-- longueur	SWAP.W	D3	ADD.L	A4,#2		; A4 <-- saute <fonc> <touche>	LOAD.B	D1,(A4+)	; D1 <- <type>	JUMP	DESYFILI;---------\\; DESXLINE >;=========/; Dessine l'objet nom de fichier.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESXLINE:	PUSHM.L	D1..D3,A3	LOAD.L	A3,#(A6)+OTAFILE	LOAD.W	D3,(A6)+ONOFILE	MUL.WU	D3,#LGFI	ADD.L	A3,D3		; A3 <-- ^dans OTAFILE	LOAD.B	(A3)+OFITYP,#1	; table <-- type "ligne"	JUMP	DESXFILI;--------\\; DESBOX  >;========/; Dessine l'objet bote.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESBOX:	PUSHM.L	D1,D2,D3	LOAD.L	D2,D4		; D2 <-- position de dpart	ADD.L	A4,#3		; A4 <-- saute <fonc><touche><type>	PUSH.L	A4	CALL	LGASCIZ		; D3 <-- longueur en points	POP.L	A4	LOAD.B	D1,(A4)-1	; D1 <-- type de mise en vidence ?	JUMP',EQ 30$		; normal => 30$	CALL	DESBIG		; spcial => dessine mise en vidence30$:	COMP.B	D1,#TDBSCAD	; BOX sans cadre ?	JUMP',EQ 40$		; oui => 40$	CALL	DESRECT		; dessine rectangle englobant	JUMP'	50$40$:	PUSH.B	(A6)+OFLAGS	TSET.B	(A6)+OFLAGS:#BNODES	CALL	DESRECT		; "saute" rectangle englobant	POP.B	(A6)+OFLAGS50$:	EX.L	D2,D4	ADD.W	D4,(A6)+OCX	CALL	DESASCIZ	; met le texte  l'intrieur	LOAD.L	D4,D2		; D4 <-- position aprs rectangle	ADD.W	D4,(A6)+OCX	POPM.L	D1,D2,D3	RET;----------\\; DESCIRCLE >;==========/; Dessine l'objet cercle.; in	A4.L	^dans table;	D4.L	position;	D3.B	objet (ODBCIRCLE ou ODBLCIRCLE); out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESCIRCLE:	PUSHM.L	D0,D1,D2,D3	LOAD.B	D0,D3		; D0 <-- objet	TEST.B	(A6)+OFLAGS:#BNODES	JUMP',BS 10$	COMP.B	D0,#ODBLCIRCLE	; petit cercle ?	JUMP',EQ 10$		; oui => 10$	LOAD.L	D1,D4	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfini une trame vide	LOAD.L	D3,D1	SWAP.W	D3	SUB.W	D3,(A6)+OC1Y	SUB.W	D3,#2+3		; D3 <-- coin sup/gauche Y	SWAP.W	D3	SUB.W	D3,#3		; D3 <-- coin sup/gauche X	LOAD.W	D4,(A6)+OC1Y	ADD.W	D4,#(2+3)*2	; D4 <-- dY	LOAD.W	D2,D4	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- dX	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface autour du cercle	LOAD.L	D4,D110$:	LOAD.B	D3,(A4+)	; D3 <-- no du fanion	JUMP',NC 12$	ADD.L	A4,#2		; A4 <-- saute <fonc> <touche>12$:	TEST.B	(A6)+OFLAGS:#BFADES	JUMP,BC 30$	LOAD.L	D1,(A6)+OFACIRC	; D1 <-- fanions des cercles	TCLR.L	D1:D3		; un fanion cercle de plus	LOAD.L	(A6)+OFACIRC,D1	; mj.	LOAD.L	D1,(A6)+OFANION	; D1 <-- fanions	TEST.L	D1:D3		; fanion allum ?	JUMP',BS 20$		; oui => 20$				; non =>	LOAD.L	D1,(A6)+OFADESS	TCLR.L	D1:D3	JUMP',BC 30$	LOAD.L	(A6)+OFADESS,D1	LOAD.W	D2,#CLRDOT	CALL	INVCIRCLE	; teint le fanion	JUMP'	30$20$:	LOAD.L	D1,(A6)+OFADESS	TSET.L	D1:D3	JUMP',BS 30$	LOAD.L	(A6)+OFADESS,D1	LOAD.W	D2,#SETDOT	CALL	INVCIRCLE	; allume le fanion30$:	LOAD.L	D1,D4	LOAD.L	D3,D4	LOAD.W	D2,(A6)+OC1Y	SR.W	D2,#1	SWAP.W	D3	SUB.W	D3,D2	SWAP.W	D3	ADD.W	D2,#2	ADD.W	D3,D2	LOAD.W	D4,D2		; D4 <-- rayon	TEST.B	(A6)+OFLAGS:#BNODES	JUMP',BS 60$	LOAD.W	D2,#SETDOT	LIB	?DRCERCLE60$:	ADD.W	D1,D4	ADD.W	D1,D4	INC.W	D1	LOAD.L	D4,D1		; D4 <-- position d'arrive	COMP.B	D0,#ODBLCIRCLE	; petit cercle ?	JUMP',EQ 80$		; oui => 80$	CALL	DESBASCIZ	; non => efface autour80$:	CALL	DESASCIZ	; dessine le texte aprs	POPM.L	D0,D1,D2,D3	RET;----------\\; DESSQUARE >;==========/; Dessine l'objet carr.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESSQUARE:	PUSHM.L	D0,D1,D2,D3	TCLR.L	D4:#0	LOAD.L	D0,D4		; D0 <-- position dpart	LOAD.L	D3,D4	LOAD.W	D1,(A6)+OC1Y	LOAD.W	D4,D1		; D4 <-- dY	SWAP.W	D4	LOAD.W	D4,D1		; D4 <-- dX	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	TEST.B	(A6)+OFLAGS:#BNODES	JUMP',BS 10$	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine le carr vide10$:	LOAD.L	D4,D0		; D4 <-- position dpart	SR.W	D1,#1	ADD.W	D4,D1	ADD.W	D4,D1		; D4 <-- position arrive	ADD.W	D4,#4+1	LOAD.B	D3,(A4+)	; D3 <-- no du fanion	JUMP',NC 12$	ADD.L	A4,#2		; A4 <-- saute <fonc> <touche>12$:	TEST.B	(A6)+OFLAGS:#BFADES	JUMP',BC 30$	LOAD.L	D1,(A6)+OFANION	; D1 <-- fanions	TEST.L	D1:D3		; fanion allum ?	JUMP',BS 20$		; oui => 20$				; non =>	LOAD.L	D1,(A6)+OFADESS	TCLR.L	D1:D3	JUMP',BC 30$	LOAD.L	(A6)+OFADESS,D1	LOAD.W	D2,#CLRDOT	EX.L	D4,D0	CALL	INVSQUARE	; teint le fanion	LOAD.L	D4,D0	JUMP'	30$20$:	LOAD.L	D1,(A6)+OFADESS	TSET.L	D1:D3	JUMP',BS 30$	LOAD.L	(A6)+OFADESS,D1	LOAD.W	D2,#SETDOT	EX.L	D4,D0	CALL	INVSQUARE	; allume le fanion	LOAD.L	D4,D030$:;;?	CALL	DESBASCIZ	; efface autour	CALL	DESASCIZ	; dessine le texte aprs	POPM.L	D0,D1,D2,D3	RET;--------\\; DESCR   >;========/; Dessine l'objet passe  la ligne.; in	D4.L	position; out	D4.L	position suivante; mod	D4.LDESCR:	LOAD.W	D4,(A6)+OMARGX	SWAP.W	D4	ADD.W	D4,(A6)+OCY	SWAP.W	D4	RET;--------\\; DESCR2  >;========/; Dessine l'objet passe  la demi-ligne.; in	D4.L	position; out	D4.L	position suivante; mod	D4.LDESCR2:	PUSH.W	D3	LOAD.W	D4,(A6)+OMARGX	SWAP.W	D4	LOAD.W	D3,(A6)+OCY	SR.W	D3,#1	ADD.W	D4,D3	SWAP.W	D4	POP.W	D3	RET;--------\\; DESTABX >;========/; Dessine l'objet tabulateur horizontal.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESTABX:	PUSH.L	D3	CLR.W	D3	LOAD.B	D3,(A4+)	; D3 <-- position tabulateur	MUL.WU	D3,(A6)+OCX	ADD.W	D3,(A6)+OMARGX	; D3 <-- ajoute marge gauche	LOAD.W	D4,D3	POP.L	D3	RET;---------\\; DESTABXN >;=========/; Dessine l'objet tabulateur horizontal en points.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESTABXN:	LOAD.B	D4,(A4+)	SL.W	D4,#8	LOAD.B	D4,(A4+)	; D4 <-- position tabulateur	ADD.W	D4,(A6)+OMARGX	; D4 <-- ajoute marge gauche	RET;---------\\; DESTABYN >;=========/; Dessine l'objet tabulateur vertical en points.; in	A4.L	^dans table;	D4.L	position; out	A4.L	^plus loin;	D4.L	position suivante; mod	D4.L, A4.LDESTABYN:	SWAP.W	D4	LOAD.B	D4,(A4+)	SL.W	D4,#8	LOAD.B	D4,(A4+)	; D4 <-- position tabulateur	ADD.W	D4,(A6)+OMARGY	; D4 <-- ajoute marge suprieure	SWAP.W	D4	RET;---------\\; DESTRAME >;=========/; Dessine une trame dans toute la bote.; in	A4.L	^dans table; out	A4.L	^plus loin; mod	A4.LDESTRAME:	PUSHM.L	D2,D3,D4,A3	TEST.B	(A6)+OFLAGS:#BNODES	JUMP,BS	80$	LOAD.L	D3,#COLOR_DBTRAME	LIB	?COLORSR	; met la couleur de la trame	CLR.L	D2		; D2 <-- cran entrelac	NTREL	?GETMACHINE	RL.L	D4,#8		; D4 <-- type de machine	COMP.B	D4,#1		; Smaky 8 ?	JUMP',EQ 20$		; oui => 20$	INC.W	D2		; D2 <-- cran non-entrelac20$:	LOAD.L	A3,A4		; A3 <-- ^<trame> 8x	LOAD.B	D3,(A3)	ADD.L	A3,D2	SL.L	D3,#8	LOAD.B	D3,(A3+)	SL.L	D3,#8	LOAD.B	D3,(A3)	ADD.L	A3,D2	SL.L	D3,#8	LOAD.B	D3,(A3+)	LOAD.B	D4,(A3)	ADD.L	A3,D2	SL.L	D4,#8	LOAD.B	D4,(A3+)	SL.L	D4,#8	LOAD.B	D4,(A3)	ADD.L	A3,D2	SL.L	D4,#8	LOAD.B	D4,(A3+)	LIB	?DRMDEF		; dfini la trame	CLR.L	D3		; D3 <-- origine	LOAD.L	D4,(A6)+ODIMWDO	; D4 <-- dimensions	TEST.B	(A6)+OFLAGS:#BTITLE	JUMP',BC 50$	SWAP.W	D3	ADD.W	D3,(A6)+OCY	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,(A6)+OCY	SWAP.W	D450$:	LOAD.W	D2,#SETDOT	; D2 <-- mode	LIB	?DRMATRIX	; dessine la trame	LOAD.L	D3,#COLOR_DBSET	LIB	?COLORSR	; remet la couleur pour dessiner80$:	ADD.L	A4,#8		; A4 <-- saute <trame> 8x	POPM.L	D2,D3,D4,A3	RET;---------\\; DESLABEL >;=========/; Dessine un label !; in	A4.L	^dans table; out	A4.L	^plus loin; mod	A4.LDESLABEL:	INC.L	A4		; A4 <-- saute le no du label	RET;---------\\; DESASCIZ >;---------/; Affiche un .ASCIZ; in	D4.L	position;	A4.L	^texte; out	D4.L	position suivante;	A4.L	^plus loin; mod	D4.L, A4.LDESASCIZ:	PUSHM.L	D2,D3,A3	COMP.B	(A4),#-1	; caractres graphiques ?	JUMP',EQ 50$		; oui => 50$	TEST.B	(A6)+OFLAGS:#BNODES	JUMP',BS 20$	LOAD.L	D3,D4	LIB	?SETCURS	; positionne curseur au dbut	LOAD.B	D3,#AFTOUT	LIB	?AFCAR		; affiche tout	LOAD.L	A3,A4		; A3 <-- ^texte	LIB	?AFTEXT		; affiche le texte	LOAD.B	D3,#AFNORM	LIB	?AFCAR		; affiche normalement20$:	CALL	LGASCIZ		; D3 <-- longueur en points	ADD.W	D4,D3		; D4 <-- position suivante	JUMP'	90$50$:	INC.L	A4		; A4 <-- saute <-1>	CLR.L	D3	LOAD.B	D3,(A4+)	; D3 <-- nb bytes	CLR.W	D2	LOAD.B	D2,(A4+)	; D2 <-- longueur (en points)	TEST.B	(A6)+OFLAGS:#BNODES	JUMP',BS 60$	LOAD.L	A3,A4		; A3 <-- ^bytes	LIB	?STRING		; affiche qq bytes60$:	ADD.L	A4,D3		; A4 <-- saute qq bytes	ADD.W	D4,D2		; D4 <-- position suivante90$:	POPM.L	D2,D3,A3	RET;----------\\; DESBASCIZ >;==========/; Efface autour d'un .ASCIZ; in	D4.L	position;	A4.L	^texte; out	-; mod	-DESBASCIZ:	PUSHM.L	D1,D2,D3,D4,A4	TEST.B	(A6)+OFLAGS:#BNODES	JUMP,BS	90$	LOAD.L	D1,D4	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfini une trame vide	CALL	LGASCIZ		; D3 <-- longueur en points	LOAD.W	D4,D3	SWAP.W	D4	LOAD.W	D4,(A6)+OC1Y	ADD.W	D4,(A6)+OC2Y	ADD.W	D4,(A6)+OC2Y	SWAP.W	D4	LOAD.L	D3,D1	SWAP.W	D3	SUB.W	D3,(A6)+OC1Y	SUB.W	D3,(A6)+OC2Y	SWAP.W	D3	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface tout autour90$:	POPM.L	D1,D2,D3,D4,A4	RET;--------\\; LGASCIZ >;--------/; Calcul la longueur d'un .ASCIZ; in	A4.L	^texte<0>; out	A4.L	^plus loin;	D3.W	longueur (en points); mod	D3.L, A4.LLGASCIZ:	PUSH.L	D4	COMP.B	(A4),#-1	; caractres graphiques ?	JUMP',EQ 50$		; oui => 50$	LOAD.W	D3,#-120$:	INC.W	D3		; D3 <-- nb de caractres	TEST.B	(A4+)		; A4 <-- saute le .ASCIZ	JUMP,NE	20$	MUL.WU	D3,(A6)+OCX	JUMP'	90$50$:	INC.L	A4		; A4 <-- saute <-1>	CLR.L	D4	LOAD.B	D4,(A4+)	; D4 <-- nb bytes	CLR.W	D3	LOAD.B	D3,(A4+)	; D3 <-- longueur	ADD.L	A4,D4		; A4 <-- saute bytes90$:	POP.L	D4	RET;--------\\; DESRECT >;--------/; Dessine un rectangle de longueur quelconque.; in	D4.L	position;	D3.W	longueur du rectangle; out	D4.L	position suivante; mod	D4.LDESRECT:	PUSHM.L	D1,D2,D3	LOAD.W	D2,(A6)+OCX	LOAD.L	D1,D4		; D1 <-- position origine	ADD.W	D1,D3		; D1 <-- position suivante	ADD.W	D1,D2	ADD.W	D1,D2	EX.L	D3,D4	ADD.W	D4,D2	SR.W	D2,#1		; D2 <-- largeur 1/2 caractre	ADD.W	D3,D2	SWAP.W	D3	SUB.W	D3,(A6)+OC1Y	SUB.W	D3,(A6)+OC2Y	SUB.W	D3,#2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,(A6)+OC1Y	ADD.W	D4,(A6)+OC2Y	ADD.W	D4,(A6)+OC2Y	ADD.W	D4,#2+2	SWAP.W	D4	TEST.B	(A6)+OFLAGS:#BNODES	JUMP',BS 70$	PUSHM.L	D3,D4	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfini une trame vide	POPM.L	D3,D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface tout le rectangle	LOAD.W	D2,#SETDOT	LIB	?DRRECT70$:	LOAD.L	D4,D1		; D4 <-- position suivante	POPM.L	D1,D2,D3	RET;--------\\; DESBIG  >;--------/; Dessine un rectangle de mise en vidence.; in	D4.L	position;	D3.W	longueur du rectangle;	D1.B	type de mise en vidence; out	-; mod	-DESBIG:	PUSHM.L	D1,D2,D3,D4	TEST.B	(A6)+OFLAGS:#BNODES	JUMP,BS 90$	EX.L	D3,D4	COMP.B	D1,#TDBMEV	JUMP,EQ	50$		; mise en vidence => 50$	COMP.B	D1,#TDBOMBRE	JUMP,NE	90$				; ombre =>	LOAD.W	D2,(A6)+OCX	ADD.W	D4,D2	SR.W	D2,#1		; D2 <-- largeur 1/2 caractre	ADD.W	D3,D2	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,(A6)+OC2Y	ADD.W	D3,#2+1	SWAP.W	D3	DEC.W	D4	AND.L	D4,#H'0000FFFF	LOAD.W	D2,#SETDOT	PUSH.L	D3	LIB	?DRSEG		; 1re ligne horizontale	POP.L	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	PUSH.L	D3	LIB	?DRSEG		; 2me ligne horizontale	POP.L	D3	ADD.W	D3,D4	LOAD.W	D4,(A6)+OC1Y	ADD.W	D4,(A6)+OC2Y	ADD.W	D4,(A6)+OC2Y	ADD.W	D4,#2+2	NEG.W	D4	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	PUSH.L	D3	LIB	?DRSEG		; 1re ligne verticale	POP.L	D3	INC.W	D3	LIB	?DRSEG		; 2me ligne verticale	JUMP	90$50$:	LOAD.W	D2,(A6)+OCX	ADD.W	D4,D2	ADD.W	D4,#1+1	SR.W	D2,#1		; D2 <-- largeur 1/2 caractre	ADD.W	D3,D2	DEC.W	D3	SWAP.W	D3	SUB.W	D3,(A6)+OC1Y	SUB.W	D3,(A6)+OC2Y	SUB.W	D3,#2+1	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,(A6)+OC1Y	ADD.W	D4,(A6)+OC2Y	ADD.W	D4,(A6)+OC2Y	ADD.W	D4,#3+3	SWAP.W	D4	TEST.B	(A6)+OFLAGS:#BNODES	JUMP,BS	90$	LOAD.W	D2,#CLRDOT	LIB	?DRRECT	LOAD.W	D1,#2		; D1 <-- paisseur60$:	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT	DEC.W	D1	JUMP,NE	60$90$:	POPM.L	D1,D2,D3,D4	RET;-----------\\; DESTITRAME >;-----------/; Dessine une trame pour le titre.; in	D4.L	position;	D3.W	longueur pour la trame; out	D4.L	position suivante; mod	D4.LDESTITRAME:	PUSHM.L	D1,D2,D3,A3	PUSHM.L	D3,D4	LOAD.L	D3,#COLOR_DBTITLE	LIB	?COLORSR	; met la couleur du titre	NTREL	?GETMACHINE	RL.L	D4,#8		; D4 <-- type de machine	LOAD.L	D3,#H'00FF00FF	; D3 <-- trame non "entrelace"	COMP.B	D4,#2		; smaky 100 ?	JUMP',EQ 10$		; oui => 10$	LOAD.L	D3,#H'0000FFFF	; D3 <-- trame "entrelace"10$:	LOAD.L	D4,D3		; D4 <-- suite trame	LIB	?DRMDEF		; dfini la trame	POPM.L	D3,D4	LOAD.L	D1,D4		; D1 <-- position origine	ADD.W	D1,D3		; D1 <-- position suivante	EX.L	D3,D4	SWAP.W	D3	SUB.W	D3,(A6)+OC1Y	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,(A6)+OC1Y	ADD.W	D4,(A6)+OC2Y	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	LOAD.L	D3,#COLOR_DBSET	LIB	?COLORSR	; remet la couleur pour dessiner	LOAD.L	D4,D1		; D4 <-- position suivante	POPM.L	D1,D2,D3,A3	RET;----------\\; INVCIRCLE >;==========/; Inverse un objet cercle.; in	A4.L	^objet;	D4.L	position;	D2.W	mode de dessin; out	-; mod	-INVCIRCLE:	PUSHM.L	D1,D2,D3,D4	LOAD.L	D3,#COLOR_DBSEL	LIB	?COLORSR	; met la couleur pour slectionner	LOAD.L	D3,D4	LOAD.W	D1,(A6)+OC1Y	SR.W	D1,#1	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	ADD.W	D1,#2	ADD.W	D3,D1	LOAD.W	D4,D1		; D4 <-- rayon	SUB.W	D4,#3	JUMP',HI 50$	LOAD.W	D4,#350$:	LIB	?DRCERCLE	; fait qq cercles	DEC.W	D4	JUMP,NE	50$	PUSHM.L	D3,D4	CLR.L	D3	CLR.L	D4	COMP.B	D2,#CLRDOT	JUMP',EQ 60$	NOT.L	D3	NOT.L	D460$:	LIB	?DRMDEF	POPM.L	D3,D4	SR.W	D1,#2		; D1 <-- ~ (R*sin(45))/2	SUB.W	D3,D1	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	SL.W	D1,#1	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D1	LIB	?DRMATRIX	; amliore les cercles	LOAD.L	D3,#COLOR_DBSET	LIB	?COLORSR	; remet la couleur pour dessiner	POPM.L	D1,D2,D3,D4	RET;----------\\; INVSQUARE >;==========/; Inverse un objet carr.; in	A4.L	^objet;	D4.L	position;	D2.W	mode de dessin; out	-; mod	-INVSQUARE:	PUSHM.L	D1,D2,D3,D4	LOAD.L	D3,#COLOR_DBSEL	LIB	?COLORSR	; met la couleur pour slectionner	LOAD.L	D3,D4	ADD.W	D3,#2+1	SWAP.W	D3	SUB.W	D3,(A6)+OC1Y	INC.W	D3	SWAP.W	D3	LOAD.W	D1,(A6)+OC1Y	DEC.W	D1	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D1	PUSH.L	D3	LIB	?DRSEG		; fait une diagonale	POP.L	D3	ADD.W	D3,D4	DEC.W	D3	NEG.W	D4	LIB	?DRSEG		; fait l'autre diagonale	LOAD.L	D3,#COLOR_DBSET	LIB	?COLORSR	; remet la couleur pour dessiner	POPM.L	D1,D2,D3,D4	RET;---------\\; PRESFILE >;=========/; Presse un objet fichier/ligne.; in	A4.L	^objet;	D4.L	position;	D2.W	mode de dessin; out	-; mod	-PRESFILE:	PUSHM.L	D1,D2,D3,D4	LOAD.L	D3,#COLOR_PPHILI	LIB	?COLORSR	; met la couleur pour mettre en vidence	LOAD.L	D1,D4	LOAD.L	D3,#-1	LOAD.L	D4,#-1	LIB	?DRMDEF		; dfini une trame pleine	LOAD.L	D3,D1	LOAD.W	D2,(A6)+OCX	SR.W	D2,#1	ADD.W	D3,D2	INC.W	D3		; D3 <-- origine en X	SWAP.W	D3	SUB.W	D3,(A6)+OC1Y	SUB.W	D3,(A6)+OC2Y	DEC.W	D3		; D3 <-- origine en Y	SWAP.W	D3	LOAD.W	D4,(A6)+OC1Y	ADD.W	D4,(A6)+OC2Y	ADD.W	D4,(A6)+OC2Y	ADD.W	D4,#1+2		; D4 <-- hauteur	SWAP.W	D4	LOAD.B	D2,(A4)+1	; D2 <-- nb caractres	AND.W	D2,#H'7F	MUL.WU	D2,(A6)+OCX	LOAD.W	D4,D2	ADD.W	D4,(A6)+OCX	DEC.W	D4		; D4 <-- largeur	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	; inverse la bote	LOAD.L	D3,#COLOR_DBSET	LIB	?COLORSR	; remet la couleur pour dessiner	POPM.L	D1,D2,D3,D4	RET;--------\\; PRESBOX >;========/; Presse un objet bote.; in	A4.L	^objet;	D4.L	position;	D2.W	mode de dessin; out	-; mod	-PRESBOX:	PUSHM.L	D1,D2,D3,D4,A4	LOAD.L	D3,#COLOR_PPHILI	LIB	?COLORSR	; met la couleur pour mettre en vidence	LOAD.L	D1,D4	LOAD.L	D3,#-1	LOAD.L	D4,#-1	LIB	?DRMDEF		; dfini une trame pleine	LOAD.L	D3,D1	LOAD.W	D2,(A6)+OCX	SR.W	D2,#1	ADD.W	D3,D2	INC.W	D3		; D3 <-- origine en X	SWAP.W	D3	SUB.W	D3,(A6)+OC1Y	SUB.W	D3,(A6)+OC2Y	DEC.W	D3		; D3 <-- origine en Y	SWAP.W	D3	LOAD.W	D4,(A6)+OC1Y	ADD.W	D4,(A6)+OC2Y	ADD.W	D4,(A6)+OC2Y	ADD.W	D4,#1+2		; D4 <-- hauteur	SWAP.W	D4	ADD.L	A4,#4		; A4 <-- saute <ODBBOX><fonc><touche><type>	PUSH.L	D3	CALL	LGASCIZ		; D3 <-- longueur	LOAD.W	D4,D3	POP.L	D3	ADD.W	D4,(A6)+OCX	DEC.W	D4		; D4 <-- largeur	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	; inverse la bote	LOAD.L	D3,#COLOR_DBSET	LIB	?COLORSR	; remet la couleur pour dessiner	POPM.L	D1,D2,D3,D4,A4	RET;-----------\\; PRESCIRCLE >;===========/; Presse un objet cercle.; in	A4.L	^objet;	D4.L	position;	D2.W	mode de dessin; out	-; mod	-PRESCIRCLE:	PUSHM.L	D1,D2,D3,D4	LOAD.L	D3,#COLOR_PPHILI	LIB	?COLORSR	; met la couleur pour mettre en vidence	LOAD.L	D3,D4	LOAD.W	D1,(A6)+OC1Y	SR.W	D1,#1	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	ADD.W	D1,#2	ADD.W	D3,D1	LOAD.W	D4,D1		; D4 <-- rayon	LOAD.B	D1,#250$:	INC.W	D4	LIB	?DRCERCLE	; fait qq cercles	DEC.B	D1	JUMP,NE	50$	LOAD.L	D3,#COLOR_DBSET	LIB	?COLORSR	; remet la couleur pour dessiner	POPM.L	D1,D2,D3,D4	RET;------------\\; PRESLCIRCLE >;============/; Presse un objet petit cercle.; in	A4.L	^objet;	D4.L	position;	D2.W	mode de dessin; out	-; mod	-PRESLCIRCLE:	PUSHM.L	D1,D2,D3,D4	LOAD.L	D3,#COLOR_PPHILI	LIB	?COLORSR	; met la couleur pour mettre en vidence	LOAD.L	D3,D4	LOAD.W	D1,(A6)+OC1Y	SR.W	D1,#1	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	ADD.W	D1,#2	ADD.W	D3,D1	LOAD.W	D4,D1		; D4 <-- rayon	INC.W	D4	LIB	?DRCERCLE	; fait juste un cercle	LOAD.L	D3,#COLOR_DBSET	LIB	?COLORSR	; remet la couleur pour dessiner	POPM.L	D1,D2,D3,D4	RET;-----------\\; PRESSQUARE >;===========/; Presse un objet carr.; in	A4.L	^objet;	D4.L	position;	D2.W	mode de dessin; out	-; mod	-PRESSQUARE:	PUSHM.L	D1,D2,D3,D4	LOAD.L	D3,#COLOR_PPHILI	LIB	?COLORSR	; met la couleur pour mettre en vidence	TCLR.L	D4:#0	LOAD.L	D3,D4	ADD.W	D3,#2	LOAD.W	D1,(A6)+OC1Y	LOAD.W	D4,D1		; D4 <-- dY	SWAP.W	D4	LOAD.W	D4,D1		; D4 <-- dX	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	LOAD.B	D1,#250$:	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT	DEC.B	D1	JUMP,NE	50$	LOAD.L	D3,#COLOR_DBSET	LIB	?COLORSR	; remet la couleur pour dessiner	POPM.L	D1,D2,D3,D4	RET;--------\\; CREWDO  >;========/; Cre une sous-fentre (swdo).; in	D2.W	mode d'ouverture;	D3.L	position centre (si BDBPOS);	D4.L	dimensions; out	D7.W	erreur; mod	D7.WCREWDO:	PUSHM.L	D1,D2,D3,D4	LOAD.L	D1,D4		; D1 <-- dimensions	TEST.L	D2:#BDBPOS	; position selon D3.L ?	JUMP',BS 10$		; oui => 10$	LOAD.W	D3,(A0)+ODFDY	SR.W	D3,#1		; D3 <-- milieu selon Y	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#1		; D3 <-- milieu selon X	TEST.L	D2:#BDBMOU	; position selon la souris ?	JUMP',BC 10$		; non => 10$				; oui =>	LIB	?IFMOUSE	JUMP,NE	90$	LOAD.L	D3,D4		; D3 <-- position souris10$:	LOAD.L	D4,D1		; D4 <-- dimensions;	LOAD.W	D1,D4		; D1 <-- largeur	SR.W	D1,#1		; D1 <-- 1/2 largeur	SUB.W	D3,D1		; D3 <-- recule l'origine en X	JUMP',HS 20$	CLR.W	D320$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D4		; D1 <-- hauteur	SR.W	D1,#1		; D1 <-- 1/2 hauteur	SUB.W	D3,D1		; D3 <-- remonte l'origine en Y	JUMP',HS 30$	CLR.W	D330$:	SWAP.W	D4	SWAP.W	D3	LOAD.W	D7,#ERDIOUT	COMP.W	D4,(A0)+ODFDX	; swdo trop large ?	JUMP,HS	90$	LOAD.W	D1,D3	ADD.W	D1,D4	COMP.W	D1,(A0)+ODFDX	; swdo trop  droite ?	JUMP',LS 40$	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,D440$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#ERDIOUT	COMP.W	D4,(A0)+ODFDY	; swdo trop haute ?	JUMP,HS	90$	LOAD.W	D1,D3	ADD.W	D1,D4	COMP.W	D1,(A0)+ODFDY	; swdo trop basse ?	JUMP',LS 50$	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,D450$:	SWAP.W	D4	SWAP.W	D3	CALL	OPEWDO		; ouvre la swdo90$:	POPM.L	D1,D2,D3,D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; OPEWDO >;=======/; Ouvre une sous-fentre (swdo) et dessine son cadre.; in	D2.W	mode d'ouverture;	D3.L	origine (Y;X);	D4.L	dimensions (dY,dX); out	D7.W	erreur; mod	D7.WOPEWDO:	PUSHM.L	D0,D1,D2,D3,D4,D5,D6,A4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.W	(A6)+OSVOPM,D2	LOAD.W	D1,D2		; D1 <-- mode d'ouverture	PUSHM.L	D3,D4	LIB	?GETWDO		; D5 <-- no swdo actuelle	POPM.L	D3,D4	LOAD.W	(A6)+OSVWDO,D5	LOAD.B	(A6)+OSVMOD,(A0)+ODFMOD	LOAD.B	(A6)+OSVFLG,(A0)+ODFFLG	LIB	?AFTIM	.B	AFDIR		; met vido normale	.B	PCURS		; met petit curseur "_"	.B	NOCURS		; pas de curseur	.B	0	.EVEN	AND.L	D3,#H'FFFEFFF8	AND.L	D4,#H'FFFEFFF8	LOAD.L	(A6)+OPOSEXT,D3	LOAD.L	(A6)+ODIMEXT,D4	LIB	?CREWDO		; cre swdo "extrieure"	JUMP,NE	90$	LOAD.W	D6,D5		; D6 <-- numro swdo	LIB	?USEWDO	JUMP,NE	80$	LOAD.L	D0,D3		; D0 <-- origine swdo	TEST.L	D1:#BDBSAV	; sauve sous la swdo ?	JUMP',BC 20$		; non => 20$	LOAD.B	D3,#SAVWDO	; oui =>	LIB	?AFCAR		; sauve le contenu actuel	JUMP,NE	80$20$:	LOAD.L	D3,#COLOR_DBCLEAR	LIB	?COLORCR	; met la couleur du fond	LOAD.L	D3,#COLOR_DBCADRE	LIB	?COLORSR	; met la couleur du cadre	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface tout	CLR.B	D5		; D5 <-- "bitmap" des cadres (ext..int)	TEST.L	D1:#BDBNOC	; pas de cadre du tout ?	JUMP',BS 30$		; oui => 30$	LOAD.B	D5,#B'00110000	; D5 <-- "bitmap" des cadres (ext..int)	TEST.L	D1:#BDBCAS	; un seul cadre ?	JUMP',BS 30$		; oui => 30$	LOAD.B	D5,#B'00100110	; D5 <-- "bitmap" des cadres (ext..int)30$:	CLR.L	D3		; D3 <-- Y;X origine	DEC.W	D4		; D4 <-- dX-1 pour tre dedans	SWAP.W	D4	DEC.W	D4		; D4 <-- dY-1 pour tre dedans	SWAP.W	D4	LOAD.W	D2,#SETDOT	; D2 <-- mode40$:	SL.B	D5,#1		; C <-- cadre ou pas	JUMP',CC 45$	LIB	?DRRECT		; dessine un rectangle45$:	INC.W	D3		; X <-- X+1	SWAP.W	D3	INC.W	D3		; Y <-- Y+1	SWAP.W	D3	SUB.W	D4,#2		; dX <-- dX-2	SWAP.W	D4	SUB.W	D4,#2		; dY <-- dY-2	SWAP.W	D4	COMP.W	D3,#8		; encore un ?	JUMP,LO	40$		; oui => 40$				; non =>	LOAD.L	D3,#COLOR_DBSET	LIB	?COLORSR	; met la couleur pour dessiner	LOAD.L	D3,D0		; D3 <-- origine swdo	ADD.W	D3,#8	SWAP.W	D3	ADD.W	D3,#8	SWAP.W	D3	INC.W	D4		; D4 <-- dimensions intrieures	SWAP.W	D4	INC.W	D4	SWAP.W	D4	CLR.W	D5	LIB	?USEWDO	LOAD.W	D5,D6	LIB	?KILWDO	LIB	?CREWDO		; cre swdo incluse	LIB	?USEWDO		; utilise swdo incluse	LOAD.W	(A6)+ONOWDO,D5	; mm. numro swdo	JUMP'	90$80$:	PUSH.W	D7	CLR.W	D5	LIB	?USEWDO		; utilise swdo principale	LOAD.W	D5,D6	LIB	?KILWDO		; dtruit swdo cre	POP.W	D790$:	TEST.W	D7		; ok ?	JUMP',EQ 95$		; oui => 95$				; erreur =>	PUSH.W	D7	LIB	?COLORPOP	; restitue les couleurs	POP.W	D795$:	POPM.L	D0,D1,D2,D3,D4,D5,D6,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; CLOWDO >;=======/; Ferme une sous-fentre et restitue son contenu.; in	-; out	D7.W	erreur; mod	D7.WCLOWDO:	PUSHM.L	D3,D4,D5	LIB	?COLORPOP	; restitue les couleurs	LOAD.W	D3,(A6)+OSVOPM	; D3 <-- mode d'ouverture	TEST.L	D3:#BDBSAV	; sauve sous la swdo ?	JUMP',BC 10$		; non => 10$				; oui =>	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue contenu sous-fentre	LOAD.W	D5,(A6)+OSVWDO	LIB	?USEWDO		; utilise s-wdo initiale	LOAD.W	D5,(A6)+ONOWDO	LIB	?KILWDO		; dtruit s-wdo menu	JUMP'	30$10$:	LOAD.W	D5,(A6)+OSVWDO	LIB	?USEWDO		; utilise s-wdo initiale	LOAD.W	D5,(A6)+ONOWDO	LIB	?KILWDO		; dtruit s-wdo menu	LOAD.L	D3,(A6)+OPOSEXT	LOAD.L	D4,(A6)+ODIMEXT	LIB	?CREWDO		; re-cre s-wdo extrieure	LIB	?USEWDO	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface la sous-fentre	PUSH.W	D5	LOAD.W	D5,(A6)+OSVWDO	LIB	?USEWDO		; utilise s-wdo initiale	POP.W	D5	LIB	?KILWDO		; dtruit s-wdo extrieure30$:	LOAD.B	D3,#AFDIR	TEST.B	(A6)+OSVFLG:#BFVIDI	JUMP',BC 40$	LOAD.B	D3,#AFINV40$:	LIB	?AFCAR		; remet vido normale/inverse	LOAD.B	D3,#GCURS	TEST.B	(A6)+OSVMOD:#BFPCUR	JUMP',BC 42$	LOAD.B	D3,#PCURS42$:	LIB	?AFCAR		; remet gros/petit curseur	LOAD.B	D3,#CURS	TEST.B	(A6)+OSVMOD:#BFNOCU	JUMP',BC 44$	LOAD.B	D3,#NOCURS44$:	LIB	?AFCAR		; remet/enlve le curseur	POPM.L	D3,D4,D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; RSTWDO  >;========/; Lit le status de la swdo actuelle.; in	-; out	D7.W	erreur; mod	D7.WRSTWDO:	PUSHM.L	D3,D4,D6,A4	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer pour ^	LOAD.L	D4,#4		; D4 <-- lg demande pour ^	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre	LIB	?GCHDIS		; D6 <-- canal fentre	FOS	?RSTATUS	; lit le status	JUMP',NE 90$	LOAD.L	A4,(A4)		; A4 <-- ^description de la fentre	LOAD.W	(A6)+OCX,(A4)+ODFCX	LOAD.W	(A6)+OCY,(A4)+ODFCY	LOAD.W	(A6)+OC1Y,(A4)+ODFC1Y	LOAD.W	(A6)+OC2Y,(A4)+ODFC2Y90$:	POPM.L	D3,D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; OPEVAR  >;========/; Demande de la mmoire pour les variables.; in	-; out	A6.L	^zone mmoire;	D7.W	erreur; mod	D7.W, A6.LOPEVAR:	PUSHM.L	D1,D4,A4	LOAD.L	D4,#LGVAR	; D4 <-- longueur	LOAD.W	D1,#MTYPCP	; D1 <-- type compte mmoire	GESMEM	?GETMEM		; demande mmoire	JUMP',NE 80$	LOAD.L	A6,A4		; A6 <-- ^zone30$:	CLR.B	(A4+)		; met toutes les variables  zro	DEC.W	D4	JUMP,NE 30$	JUMP'	90$80$:	LOAD.L	A6,#0		; A6 <-- ^nil (!)90$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOVAR  >;========/; Rend la mmoire pour les variables.; in	A6.L	^zone mmoire; out	-; mod	CLOVAR:	PUSHM.L	D1,D7,A4	LOAD.L	A4,A6		; A4 <-- ^zone	LOAD.W	D1,#MTYPCP	; D1 <-- type compte mmoire	GESMEM	?GIVMEM		; rend la mmoire	POPM.L	D1,D7,A4	RET	.INS	DBOXEXTEND.ASI^ 	FOS	?UNAMDRIV	; D2 <-- no driver			 ^ Undefined symbol^ 	FOS	?UOPEN		; tente une ouverture		      ^ Undefined symbol^ 	BIOS	?DCOMMAND	; formatage physique ...		^ Unknown instruction^ 	FOS	?UCLOSE		; ferme		       ^ Undefined symbol	.INS	DBOXIO.ASI	.INS	DBOXICO.ASI	.INS	ATTENTION.ASI	.INS	BLUP.ASIDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF7:	LOAD.W	D3,#F7	RETDOKDEF:	LOAD.W	D3,#DEFINE	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETEND_DBOX:	.END