	.PROC	M680002	.REF	SMAKY	.LOC	0START:	LOAD.L	D4,#1234567890	CALL	_BINBCD	EXIT;--------\; _BINBCD >;========/; in	D4.L	nombre binaire; out	D4.L	nombre BCD; 	D7.W	erreur; mod	D0..A1, D4.L, D7.W_BINBCD:	PUSHM.L	D1..D4,A4	LOAD.L	A4,#R16"TABLE$20$:	LOAD.L	D3,(A4+)	JUMP,EQ 90$	LOAD.L	D2,(A4+)	LOAD.L	D1,(A4+)30$:	COMP.L	D4,D2	JUMP,HS 40$	SUB.L	D2,D1	DEC.W	D3	JUMP	30$40$:	SUB.L	D4,D2	CALL	PUT$	JUMP	20$90$:	POPM.L	D1..D4,A4	RETPUT$:	PUSH.W	D3	ADD.B	D3,#'0	LIB	?AFCAR	POP.W	D3	RETTABLE$:	.L	4,4000000000,1000000000	.L	9,900000000,100000000	.L	9,90000000,10000000	.L	9,9000000,1000000	.L	9,900000,100000	.L	9,90000,10000	.L	9,9000,1000	.L	9,900,100	.L	9,90,10	.L	9,9,1	.L	0	.END	START