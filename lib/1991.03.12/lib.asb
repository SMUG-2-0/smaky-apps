	.TITLE	LIB.ASB;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------	.PROC	M680002; Assemblage conditionnel; -----------------------	.REF	MACHINESM100	=	_SM100		; Smaky 8/100SM324	=	_SM324		; Smaky 324SM300	=	_SM300		; Smaky 300  SM324LIT =	  _SM324LIT	;  petit cran Smaky 100  SM324BIG =	  _SM324BIG	;  grand cran 80 MHz	.IF	SM300COLOR	=	1		; youpie, comme c'est beau	.ELSECOLOR	=	0		; beurk ...	.ENDIFPMOUSE	=	0		; appels ?PXMOUSE/?PYMOUSELIBROM	=	0		; modules .LIB en ROM (si SM100)LIBREV	=	5		; rvisionLIBVERS	=	19		; version	.REV	LIBREV,LIBVERS	.CODE	0,0,0,0,0,0,0,0,'?,'?,'F,0	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Date		Rev	Amliorations; -----------------------------------------------------------------------------------------; 20.02.91	5.19	?PFDUMP: ok si couleur et met dans le classeur; 25.01.91	5.18	?EDIT: (COPY-espace) = copie et (CURSOR-espace) = colle ...; 09.04.90	5.17	?SNCOMM: ok mme sur unit locale (#DISPLAY); 29.03.90	5.16	?ASSKEY: clear OSHIFT pour ?GETSHIFT;			?OEXECUTE: si (A3)+1:#7, n'efface pas la fentre;			?SNCOMM: refait pour utiliser FOS,?ARGSOPEN; 04.07.89	5.15	?ADDNGC/?SUBNGC/?MAJNGC: nouveaux appels;			?GETREVL: donne la rvision de la librairie;			?ASSKEY: si D3=0 => assigne au programme appelant; 14.06.89	5.14	?TEXTGC: met ".." si taille nulle; 09.06.89	5.13	?TEXTGC: met le nom "FS" s'il n'existe rien de mieux; 06.06.89	5.12	?FLUSHNGC: nouvel appel pour le module DGENC; 18.04.89	5.11	?TEXTGC: selon le contenu de SMA_GENC.INFO;			?MMENUS: flches ">" ou "<" mieux places; 11.04.89	5.10	?CALCPSYM: arrondi juste dans tous les cadrans;			init trap #6 (LIB) avec NTREL,?IEPSYSLINEA; 13.03.89	5.9	?PDUMP: petite correction si 324; 08.03.89	5.8	?PUTDEC/?AFDEC: ok jusqu' 10 digits;			?PDUMP: plus tourn si 324 grand cran; 25.01.89	5.7	?EDIT: si D3:#13=1, ne sort pas si accent flottant; 06.10.88	5.6	?GETREV: fait un FOS,?CLOAD de SYSTEM.CODE; 15.08.88	5.5	?GTRSMM: ok avec grandes valeurs (>65000);			?EDIT: buffer peut contenir CR!2^7 (par exemple); 11.07.88	5.4	?MMENUS: mmorise la dernire case => fonctionne;			LIB_CLOSE: ok si D1=zro (canal);			?AFXFILE: nouveaux modes BAFXND et BAFXNE; 06.07.88	5.3	?AFMENU: ok si AFGREY/AFINV dans .ASCIZ; 04.07.88	5.2	?PDUMP: plus de .IF (utilise ODFPSK pour les dimensions); 20.05.88	5.1	code romable (utilise _VARLIB.L);			?GETPDIS: nouvel appel; 06.04.88	5.0	?MMENUS: nouvel appel pour m-menus hirarchiques;			?COLORxx: nouveaux appels pour la couleur (ouah...);			?PMOUSE: nouvel appel; 31.03.88	4.13	?DRARC: petite erreur corrige; 25.03.88	4.12	?DRRECTA: nouvel appel;			?DRTRAMEA: nouvel appel;			?DRARC: nouvel appel;			?DRTRANCHE: nouvel appel;			?DRELLIPSE: nouvel appel;			?DRPOLYGONE: nouvel appel;			?CALCHYPO: nouvel appel;			?CALCANGLE: nouvel appel;			?CALCPSYM: nouvel appel;			?CALCPELLI: nouvel appel;			?CALCSIN: nouvel appel;			?CALCCOS: nouvel appel; 11.02.88	4.11	?GETFILE conserve les lettres accentues; 01.02.88	4.10	?OPEBITMAP/?CLOBITMAP;			LIB_ADD/LIB_SUB: ok pour plusieurs BASIC; 26.11.87	4.9	utilise ODFPSK pour les soft-keys;			?TEXTGC: nouvel appel;			?GTABGC: nouvel appel; 12.11.87	4.8	?USELIB/?RELLIB: retournent D7=0;			?PUSHMENU/?POPMENU: nouveaux appels; 23.10.87	4.7	?MMENU: grise les cases grises;			?PUTDEC: comme ?AFDEC mais en (A4+);			?PUTXFILE: comme ?AFXFILE mais en (A4+);			?MINMAJ, etc. possibles sans ?OPELIB (sans A6);			?GETREV: donne la rvision du systme; 19.10.87	4.6	?EDIT: revu et corrig (plus de trou); 05.09.87	4.5	?BASSKEY: bloque tous les ?ASSKEY (pour START);			?GETSHIFT: donne les touches super-shift; 03.03.87	4.4	?REPKEY: modifie 2 dlais de repeat  tous les claviers;			?AFXFILE: affiche un seul X` dans les clefs; 26.02.87	4.3	?MMENU: cases inactives dans D4.W (si D3:#15=1);			?INVBARRE: ne fait rien si clavier pas assign; 19.02.87	4.2	p'tite rserve aprs NAMMDL (!); 19.12.86	4.1	?AFFILE: cache les clefs XXX'TOTO.IMAGE;			?AFXFILE: nouvel appel;			?GETFILE: frappe de ' donne ` (pour les clefs); 12.12.86	4.0	nom des modules: (SMA,100)_DBOX.LIB; 09.12.86		?OEXECUTE: si (A3):#7=1, n'affiche pas l'image; 01.12.86		?OEXECUTE: ne ferme plus clavier/cran;			?OPELIB: n'ouvre plus clavier/cran si pas ncessaire;			?CLOLIB: ne ferme plus clavier/cran si pas ncessaire; 21.11.86		?SRCKNP: nouvel appel;			?OPELIB: ne fait plus ?ASSKEY si le pre n'a pas le clavier;			?OEXECUTE: fait FOS,?NEXECUTE sans le bit BEXOINS; 07.11.86		?CLREDIT: nouvel appel pour ?EDIT; 22.08.86		?WRKEY utilise KEYLWRI au lieu de KEYSND;			?WRAKEY (nouvel appel) utilise KEYSND (pour mouse); 19.08.86		?ADDEXT accepte "." et "!"; 30.06.86		?CLOLIBK pour LDIMA; 09.06.86		?ASSBITMAP assigne le clavier  un bitmap donn; 16.04.86		?RDMOUSE et ?IFMOUSE ne rendent jamais des coor. ngatives;			modules .LIB chargs avec FOS,?CLOAD/?CUNLOAD;			?OEXECUTE fait avec l'appel FOS,?NEXECUTE; 14.04.86		?ADDEXT refait sans FOS,?ARGS => donc sans accs disque; 16.01.86		?PDUMP avec OPRLGP = largeur imprimable dans la page; 16.11.85		?EDIT avec bit 2^15 de D3 => efface lors du 1er caractre; 07.11.85		Souris: suppression du mode "sablier automatique"; 22.10.85		?OEXECUTE libre et reprend aussi clavier/synthtiseur;			?OEXECUTE signal changement au CLE pour soft-keys "Wind.";			?CLOLIB ne rend pas le clavier au pre s'il n'existe plus	.REF	SM8	.REF	BIOS	.REF	BIOSDRIV	.REF	NTREL	.REF	GESMEM	.REF	FOS	.REF	DRIVERS	.REF	LIB	.REF	GRA	.REF	DOLIB	.REF	GENCAR	.REF	TCOLOR	.REF	ICOLOR	.REF	COLORS	.REF	BLOC;----------------------------------------------------------------------------------------- PROV_VARLIB	= H'108CFOS?UOPEN = FOS_BASE+38FOS?UCLOSE = FOS_BASE+40GRA_CRASTER = H'A899		; raster-op couleurGRA_GDOT = H'A89A		; get-dotBSRCCOUL = 11BDSTCOUL = 12;----------------------------------------------------------------------------------------- PROV	.HEX	.RDX	10.; Dfinitions diverses; --------------------ADGSMC	=	H'6100		; compte mmoire du FOS pour				; les codes excutables !!!BNTCOLO =	H'1000000*'C+H'10000*'O+H'100*'L+H'1*'O; Dfinitions des mta-caractres; -------------------------------METASWI	=	'/		; switchMETAANY	=	'*		; remplace qq caractresMETAONE	=	'?		; remplace un caractreMETABLI	=	'[		; dbut listeMETAELI	=	']		; fin listeMETAILI	=	'-		; interval dans listeMETACLEF=	'`		; termine un nom de clefCIRCON	=	'^		; circonflxeTREMA	=	'"		; trmaKCIRCON	=	'		; touche circonflxeKTREMA	=	'		; touche trma; Dfinition de la table des sous-fentres; ----------------------------------------MAXSWDO	=	10		; 10 sous-fentres par fentre	.LOC	0OSWFLG:	.BLKB	2		; flags divers BSWUSE	=  0			;  sous-fentre utiliseOSWSY:	.BLKB	2		; start YOSWSX:	.BLKB	2		; start XOSWDY:	.BLKB	2		; largeur YOSWDX:	.BLKB	2		; hauteur XOSWPY:	.BLKB	2		; position typo YOSWPX:	.BLKB	2		; position typo XOSWGY:	.BLKB	2		; position graphique YOSWGX:	.BLKB	2		; position graphique XLGSWDO:; En-tte d'un fichier "image"; ----------------------------	.LOC	0OIMTYP:	.BLKB	1		; H'01 = indique type imageOIMCOD:	.BLKB	1		; H'00 = indique pas de codageOIMBIP:	.BLKB	1		; H'01 = 1 bit par pointOIMDIR:	.BLKB	1		; H'02 = coord. X-Y comme cranOIMDLX:	.BLKB	2		; largeur image en pointsOIMDLY:	.BLKB	2		; hauteur image en pointsOIMNBB:	.BLKB	4		; nb de byte pour l'imageOIMSIZ:	.BLKB	2		; taille d'un pixel (4)OIMCNT:	.BLKB	2		; nb de pixels (1)OIMLGC:	.BLKB	4		; longueur de la CLUT	.BLKB	12		; rserveLGHIMA:; Constantes pour les modules .LIB; --------------------------------	.IF	SM100&LIBROMADROM0	=	H'E00000	; dbut de la ROM 0ADROM1	=	H'E40000	; dbut de la ROM 1LGROM	=	H'10000		; longueur de la ROM	.ENDIFMAXMODU	=	50		; nb max de modules simultansPNBT	=	4NBT	=	2^PNBT		; nombre d'appels par tranche; Dfinition des variables des noms de gencars; --------------------------------------------NGLRES	=	100		; longueur de la rserve (LGT-LGU)	.LOC	0ONGLGU:	.BLKB	2		; longueur utiliseONGLGT:	.BLKB	2		; longueur totaleLNG:; Dfinition des variables globales; ---------------------------------MAXUSER	=	20		; nb max d'utilisateur	.LOC	0OSTART:	.BLKB	4		; adr dbut code librairieOCTMEM:	.BLKB	4		; compte mmoire de la librairieOASKEY:	.BLKB	2		; no clavier utilisOASBLK:	.BLKB	2		; bloque ASSKEY ?OCHMOU:	.BLKB	2		; canal pour la sourisOSEMAC:	.BLKB	4		; ^smaphore communicationOSOPOS:	.BLKB	4		; dernire position sourisOSOKEY:	.BLKB	2		; dernier tat des boutonsOSEMAT:	.BLKB	4		; ^smaphore +/- taskOSYREV:	.BLKB	2		; rvision du systmeOPDDI0:	.BLKB	4		; ^descripteur $DIS_0OPTTSK:	.BLKB	4		; ^table des soft-keys	.IF	COLOROVSPOS:	.BLKB	4		; cran virtuel: positionOVSDIM:	.BLKB	4		; cran virtuel: dimensions	.ENDIFOBUMENU:.BLKB	500		; qq caractres pour menuOPUVAR:	.BLKB	MAXUSER*(2+4)	; ^variables utilisateursOSAVL10:.BLKB	4		; vecteur pour moniteurOSEML10:.BLKB	4		; ^smaphore d'exclusionOTABLE0:.BLKB	4096/NBT	; table des offsets dans TABLE1OTABLE1:.BLKB	MAXMODU*4	; table des ^base des modulesOTABLE2:.BLKB	MAXMODU*1	; table des compteurs d'utilisationONAML10:.BLKB	32		; nom d'un module .LIBOPGCIN:	.BLKB	4		; ^contenu de SMA_GENC.INFOONGCIN:	.BLKB	32		; nouveau nomOMGCIN:	.BLKB	1		; 1 => mise  jour ncessaire	.EVENOBLOC:	.BLKB	2		; 1 => module BLOC chargLGVAR:; Dfinition des variables locales  ?MMENU; -----------------------------------------	.LOC	0OMSORY:	.BLKB	2		; origine Y suprieureOMSORX:	.BLKB	2		; origine X gaucheOMSMAG:	.BLKB	4		; bitmap des cases inactivesOMSNBC:	.BLKB	2		; nb de casesOMSLGX:	.BLKB	2		; largeur d'une caseOMSLGY:	.BLKB	2		; hauteur d'une caseOMSL1X:	.BLKB	2		; largeur de la rfrence gaucheOMSL1Y:	.BLKB	2		; hauteur dessus ligne de baseOMSNCX:	.BLKB	2		; nb de colonnesOMSNCY:	.BLKB	2		; nb de cases par colonneOMSAJX:	.BLKB	2		; largeur suppl. 1re case pour modulo 8OMSAJY:	.BLKB	2		; hauteur suppl. 1re case pour modulo 2OMSSVM:	.BLKB	2		; sauvetage du modeOMSWDO:	.BLKB	2		; swdo originaleOMSFLG:	.BLKB	4		; flags diversOMSPSM:	.BLKB	4		; position pour sous-menuOMSCAP:	.BLKB	2		; case preOMSPVP:	.BLKB	4		; ^variables du menu preOMSRAN:	.BLKB	2		; rang pour les paramtresLGMVAR:; Dfinition des variables utilisateurs; -------------------------------------LGBUFF	=	100		; lg max buffer OBUFFER et OBUWRI	.LOC	0OPGLOB:	.BLKB	4		; ^variables globalesOLSTART:.BLKB	4		; ^dbut code librairieOSYMAP:	.BLKB	(LIBMXC/8)+1	; map des overlays utilissOFLAGS:	.BLKB	1		; flags BMBUFF	=  0			;  mode bufferis BAFTOUT=  1			;  mode AFTOUT BWDKEY	=  2			;  attend touche si fen. pleine BUSEMO	=  3			;  utilise la souris BKEYMO	=  4			;  boutons souris par le clavier BCACHE	=  6			;  fentre cache par OEXECUTEOMOUSE:	.BLKB	1		; type d'utilisation de la sourisOSHIFT:	.BLKB	1		; touches super-shift presses	.EVENOPPNUM:	.BLKB	2		; numro du processus preOPRNUM:	.BLKB	2		; numro du processusOPRNOM:	.BLKB	16		; nom du processusOCHDIS:	.BLKB	2		; canal pour l'cranOCHKEY:	.BLKB	2		; canal pour le clavierOCHSYNT:.BLKB	2		; canal pour le haut-parleurOTYPDIS:.BLKB	1		; type de l'cranOTYPKEY:.BLKB	1		; type du clavierONUDIS:	.BLKB	2		; numro du driver cranONUKEY:	.BLKB	2		; numro du driver clavierONSKEY:	.BLKB	2		; numro du clavier preOIGENC:	.BLKB	4		; gnrateur de car. initialOPTBUF:	.BLKB	2		; ^dans OBUFFEROBUFFER:.BLKB	LGBUFF		; buffer pour ?WRBYTE cranOPDDIS:	.BLKB	4		; ^descripteur de la fentre relOSDFABS:.BLKB	4		; copie de ODFABSOSDFIIX:.BLKB	2		; copie de ODFIIXOSDFIIY:.BLKB	2		; copie de ODFIIYOSDFY:	.BLKB	4		; copie de ODFYOSDFDY:	.BLKB	4		; copie de ODFDYOSDFFY:	.BLKB	4		; copie de ODFFYOSDFFDY:.BLKB	4		; copie de ODFFDYOSDFWBY:.BLKB	4		; copie de ODFWBYOSDFWEY:.BLKB	4		; copie de ODFWEYOSDFTTC:.BLKB	2		; copie de ODFTTCOBUWRI:	.BLKB	LGBUFF+2	; buffer pour ?WRBYTE cranOBUSYN:	.BLKB	10		; buffer pour ?WRBYTE synthOBUREA:	.BLKB	20		; buffer pour ?RDBYTE clavierOBUCOM:	.BLKB	20		; valeurs  pour FOS,?COMMANDOBUWPR:	.BLKB	10		; buffer pour ?WRBYTE printerOBUMOU:	.BLKB	20		; buffer pour ?RDBYTE sourisOBULINE:.BLKB	100		; buffer pour une ligne texteOPOCUR:	.BLKB	4		; position du curseur prop.OCACUR:	.BLKB	2		; caractre sous le curseurOPOEDI:	.BLKB	4		; pos. dernire ligne diteOLGEDI:	.BLKB	2		; longueur ligne diteOMAPBAR:.BLKB	2		; map pour barres des soft keysOTXMENU:.BLKB	220		; texte du menu (soft keys)OSEMAM:	.BLKB	4		; ^smaphore pour la sourisONOSWDO:.BLKB	2		; no sous-fentre utiliseOTASWDO:.BLKB	MAXSWDO*LGSWDO	; table des sous-fentresODISOX:	.BLKB	2		; origine fentre en XODISOY:	.BLKB	2		; origine fentre en YODISDX:	.BLKB	2		; largeur fentre XODISDY:	.BLKB	2		; hauteur fentre YOMAXLI:	.BLKB	2		; nb de lignes dans fentreOCNTLI:	.BLKB	2		; compteur de lignesOMGPMN:	.BLKB	4		; mmenus: ^table du mmenuOMGPPA:	.BLKB	4		; mmenus: ^table des paramtresOMGVPA:	.BLKB	LMM		; mmenus: paramtresOMGINI:	.BLKB	1		; mmenus: initialisation	.EVENLGUVAR:; Programme; ---------	.LOC	0START:	PUSHM.L	D1,D4,A0..A5	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables globales	GESMEM	?CLEARMEM	; met toutes les variables  zro	LOAD.L	_VARLIB,A4	; _VARLIB <-- ^variables globales	LOAD.L	A3,#R16"NAME$	LOAD.W	D1,#MTYPSYS	GESMEM	?CREMCPT	; cre un nouveau compte mmoire	LOAD.L	(A4)+OCTMEM,A2	CALL	INIRST		; init restart et variables	CALL	INIL10		; init restart L10	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales;	CLR.W	(A0)+OCHMOU	; init canal souris impossible;	CLR.W	(A0)+OASBLK	; appel ASSKEY dbloqu !	LOAD.W	D4,#0	NTREL	?CRESEM		; cre smaphore pour RDMOUSE	LOAD.L	(A0)+OSEMAC,A5	; init ^smaphore	LOAD.W	D4,#0	NTREL	?CRESEM		; cre smaphore +/- task	LOAD.L	(A0)+OSEMAT,A5	; init ^smaphore	POPM.L	D1,D4,A0..A5	CLR.W	D7		; D7 <-- ok	RETNAME$:	.ASCIZ	"LIB"	.EVEN	.INS	LIBSYS.ASI;--------\; _OPELIB >;========/; in	A2.L		^paramtres pour l'cran;	D7.L		no processus pre (2x); out	(A6)+OCHDIS.W	canal pour l'cran;	(A6)+OCHKEY.W	canal pour le clavier;	(A6)+OCHSYNT.W	canal pour le haut-parleur;	D3.W		zro (utile pour ?MOUSE);	D7.W		erreur; mod	D3.W, D7.W_OPELIB:	PUSHM.L	D1,D4,D6,A0,A3,A4,A5	LOAD.L	D4,D7		; D4 <-- no processus pre	CALL	PUTUVAR		; A6 <-- ^variables user	JUMP,NE 90$		; si PUVAR plein => 90$	LOAD.L	D3,D4	SWAP.W	D3	COMP.W	D3,D4		; 2x le mme numro ?	JUMP',NE 10$		; non => 10$	LOAD.W	(A6)+OPPNUM,D4	; oui => mm. no du processus pre10$:	CALL	IFUSEWDO	; fentre dj utilise ?	JUMP',NE 15$		; non => 15$				; oui =>	LOAD.W	D6,(A0)+OCHDIS	LOAD.W	(A6)+OCHDIS,D6	CALL	MTYPDIS		; cherche type de l'cran	CALL	RACDIS		; request acces display	LOAD.W	D6,(A0)+OCHKEY	LOAD.W	(A6)+OCHKEY,D6	CALL	MTYPKEY		; cherche type du clavier	CALL	RACKEY		; request acces keyboard	JUMP'	40$15$:	LOAD.L	A3,#R16"NLDIS	LOAD.B	D3,#2^BOPWR!2^BOPRD	FOS	?OPEN		; ouvre l'cran	JUMP',NE 20$	LOAD.W	(A6)+OCHDIS,D6	CALL	MTYPDIS		; cherche type de l'cran	CALL	RACDIS		; request acces display20$:	LOAD.L	A3,#R16"NLKEY	LOAD.B	D3,#2^BOPRD	FOS	?OPEN		; ouvre le clavier	JUMP',NE 40$	LOAD.W	(A6)+OCHKEY,D6	CALL	MTYPKEY		; cherche type du clavier	CALL	RACKEY		; request acces keyboard40$:	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAT	; A5 <-- ^smaphore +/- task	NTREL	?RACSEM	NTREL	?SSIGNAL	; signal une tche en plus	NTREL	?RLASEM	CLR.W	D4	CALL	_WAITMOUSE	; met la souris en attente	TEST.W	(A0)+OBLOC	; module BLOC dj charg ?	JUMP',NE NOBLOC$	; oui => NOBLOC$	INC.W	(A0)+OBLOC	LOAD.L	A3,#R16"BLOC$	LOAD.W	D3,#BLOC_FIRST	LIB_	OPEN		; charge le module BLOC	JUMP',NE NOBLOC$	BLOC_	OPEN		; ouverture globaleNOBLOC$:	CLR.W	D7		; D7 <-- ok90$:	CLR.W	D3		; D3 <-- toujours zro	POPM.L	D1,D4,D6,A0,A3,A4,A5	RETBLOC$:	.ASCIZ	"BLOC"	.EVEN;--------\; _CLOLIB >;========/; in	(A6)+OCHDIS.W	canal pour l'cran;	(A6)+OCHKEY.W	canal pour le clavier;	(A6)+OCHSYNT.W	canal pour le haut-parleur; out	D7.W		erreur; mod	D7.W_CLOLIB:	PUSHM.L	D3,D4,D6,A0,A3,A4,A5	CALL	_MAJNGC		; met  jour SMA_GENC.INFO si ncessaire	PUSH.W	(A6)+ONUDIS	CLR.W	(A6)+ONUDIS	CALL	IFUSEWDO	; fentre dj utilise ?	POP.W	(A6)+ONUDIS	TEST.W	D7	JUMP',EQ 40$		; oui => 40$				; non =>	TEST.W	(A6)+OCHDIS	; canal cran existe ?	JUMP',EQ 20$		; non => 20$	LOAD.W	D6,(A6)+OCHDIS	; D6 <-- canal de l'cran	FOS	?CLOSE20$:	TEST.W	(A6)+OCHKEY	; canal clavier existe ?	JUMP',EQ 40$		; non => 40$	CALL	RLAKEY		; release acces keyboard	LOAD.W	D6,(A6)+OCHKEY	; D6 <-- canal du clavier	FOS	?CLOSE40$:	CALL	KILUVAR		; libre l'lment dans PUVAR	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAT	; A5 <-- ^smaphore +/- task	NTREL	?RACSEM	NTREL	?SSIGNAL	; signal une tche en moins	NTREL	?RLASEM	CLR.W	D7		; D7 <-- ok	POPM.L	D3,D4,D6,A0,A3,A4,A5	RET;---------\; _CLOLIBK >;=========/; Identique  ?CLOLIB, mais sans r-assigner le clavier !; in	(A6)+OCHDIS.W	canal pour l'cran;	(A6)+OCHKEY.W	canal pour le clavier;	(A6)+OCHSYNT.W	canal pour le haut-parleur; out	D7.W		erreur; mod	D7.W_CLOLIBK:	PUSHM.L	D3,D4,D6,A0,A3,A4,A5	PUSH.W	(A6)+ONUDIS	CLR.W	(A6)+ONUDIS	CALL	IFUSEWDO	; fentre dj utilise ?	POP.W	(A6)+ONUDIS	TEST.W	D7	JUMP',EQ 40$		; oui => 40$				; non =>	TEST.W	(A6)+OCHDIS	; canal cran existe ?	JUMP',EQ 20$		; non => 20$	LOAD.W	D6,(A6)+OCHDIS	; D6 <-- canal de l'cran	FOS	?CLOSE20$:	TEST.W	(A6)+OCHKEY	; canal clavier existe ?	JUMP',EQ 40$		; non => 40$	CALL	RLAKEYP		; release acces keyboard	LOAD.W	D6,(A6)+OCHKEY	; D6 <-- canal du clavier	FOS	?CLOSE40$:	CALL	KILUVAR		; libre l'lment dans PUVAR	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAT	; A5 <-- ^smaphore +/- task	NTREL	?RACSEM	NTREL	?SSIGNAL	; signal une tche en moins	NTREL	?RLASEM	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,D6,A0,A3,A4,A5	RET;---------\\; IFUSEWDO >;---------/; Cherche si un programme utilise dj la mme fentre.; in	-; out	D7.W	zro;	 A0.L	 ^variables;	D7.W	erreur; mod	D7.W, A0.LIFUSEWDO:	PUSHM.L	D3,D4,A3,A4	CALL	GETPNUM		; D4 <-- no processus pre	LOAD.W	D3,D4	LOAD.L	A3,#R16"NLDIS	; A3 <-- ^nom logique fentre	FOS	?VASSIGN	; cherche nom physique fentre	JUMP,NE 90$		; erreur => 90$				; ok =>	CALL	GETNPH		; D3 <-- no fentre physique	LOAD.L	A3,_VARLIB	; A3 <-- ^variables globales	LOAD.L	A3,#(A3)+OPUVAR	; A3 <-- ^^variables	LOAD.W	D4,#MAXUSER-1	CLR.W	D7		; D7 <-- ok10$:	TEST.B	(A3)+0:#0	; lment occup ?	JUMP',BC 20$		; non => 20$	LOAD.L	A0,(A3)+2	; A0 <-- ^variables	COMP.W	D3,(A0)+ONUDIS	; fentre trouve ?	JUMP',EQ 90$		; oui => 90$20$:	ADD.L	A3,#2+4		; A3 <-- ^suivant	DECJ.W,NMO D4,10$	LOAD.W	D7,#ERLNWD	; D7 <-- "fentre pas utilise"90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; _GCHDIS >;========/; in	-; out	D6.W	canal de l'cran;	D7.W	erreur; mod	D6.W, D7.W_GCHDIS:	LOAD.W	D6,(A6)+OCHDIS	RET;--------\; _GCHKEY >;========/; in	-; out	D6.W	canal du clavier;	D7.W	erreur; mod	D6.W, D7.W_GCHKEY:	LOAD.W	D6,(A6)+OCHKEY	RET;--------\; _PCHDIS >;========/; in	D6.W	canal de l'cran; out	D7.W	erreur; mod	D7.W_PCHDIS:	LOAD.W	(A6)+OCHDIS,D6	JUMP	MTYPDIS		; cherche type de l'cran;--------\; _PCHKEY >;========/; in	D6.W	canal du clavier; out	D7.W	erreur; mod	D7.W_PCHKEY:	LOAD.W	(A6)+OCHKEY,D6	JUMP	MTYPKEY		; cherche type du clavier;--------\; _GCHMOU >;========/; in	-; out	D6.W	canal de la souris;	D7.W	erreur; mod	D6.W, D7.W_GCHMOU:	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	D6,(A0)+OCHMOU	; D6 <-- canal de la souris	CLR.W	D7		; D7 <-- ok	RET;--------\; _PCHMOU >;========/; in	D6.W	canal pour la souris; out	D7.W	erreur; mod	D7.W_PCHMOU:	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	(A0)+OCHMOU,D6	; init canal souris	CLR.W	D7		; D7 <-- ok	RET;--------\; MTYPDIS >;========/; in	D6.W	canal pour l'cran; out	-; mod	-MTYPDIS:	PUSHM.L	D2,D3	CLR.B	(A6)+OTYPDIS	FOS	?GETTYPE	; D3 <-- type correspondant	JUMP',NE 90$	LOAD.B	(A6)+OTYPDIS,D3	; mm. type de l'cran90$:	POPM.L	D2,D3	RET;--------\; MTYPKEY >;========/; in	D6.W	canal pour le clavier; out	-; mod	-MTYPKEY:	PUSHM.L	D2,D3	CLR.B	(A6)+OTYPKEY	FOS	?GETTYPE	; D3 <-- type correspondant	JUMP',NE 90$	LOAD.B	(A6)+OTYPKEY,D3	; mm. type du clavier90$:	POPM.L	D2,D3	RET;--------\; _WOCLIB >;========/; Attend un ?OPELIB ou ?CLOLIB (pour CLE2_CONTROL).; in	-; out	D7.W	erreur (timeout); mod	D7.W_WOCLIB:	PUSHM.L	A0,A5	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A5,(A0)+OSEMAT	; A5 <-- ^smaphore +/- task	NTREL	?RACSEM	NTREL	?SWAIT		; attend OPELIB ou CLOLIB	PUSH.W	D7	NTREL	?RLASEM	POP.W	D7	POPM.L	A0,A5	RET; Modules; -------	.INS	LIBL10.ASI	.INS	LIBKEY.ASI	.INS	LIBCLA.ASI	.INS	LIBEDIT.ASI	.INS	LIBDIS.ASI	.INS	LIBCOLOR.ASI	.INS	LIBGRA.ASI	.INS	LIBMATH.ASI	.INS	LIBMMENU.ASI	.INS	LIBWDO.ASI	.INS	LIBGENC.ASI	.INS	LIBDUMP.ASI	.INS	LIBMENU.ASI	.INS	LIBSYNT.ASI	.INS	LIBFILE.ASI	.INS	LIBCOM.ASI	.INS	LIBMISC.ASI; Request/release accs clavier ou cran; --------------------------------------;--------\; _SRCWDO >;========/; in	D3.W	numro fentre physique; out	D4.W	numro clavier physique associ;		D4:#16  1 => utilise la souris;		D4:#17	1 => souris par le clavier;	D6.W	canal de la fentre;	A4.L	^nom processus associ;	D7.W	erreur; mod	D4.L, D6.W, D7.W, A4.L_SRCWDO:	PUSHM.L	A0	CALL	SRCNDIS		; A0 <-- ^var utilisateur	JUMP',NE 90$	CLR.L	D4	TEST.B	(A0)+OFLAGS:#BUSEMO	JUMP',BC 40$	TSET.L	D4:#1640$:	TEST.B	(A0)+OFLAGS:#BKEYMO	JUMP',BC 50$	TSET.L	D4:#1750$:	LOAD.W	D4,(A0)+ONUKEY	; D4 <-- numro driver clavier	LOAD.W	D6,(A0)+OCHDIS	; D6 <-- canal de la fentre	LOAD.L	A4,#(A0)+OPRNOM	; A4 <-- ^nom du processus90$:	POPM.L	A0	RET;--------\; _SRCKEY >;========/; in	D3.W	numro clavier physique; out	D4.W	numro fentre physique associe;		D4:#16  1 => utilise la souris;		D4:#17	1 => souris par le clavier;	A4.L	^nom processus associ;	D7.W	erreur; mod	D4.L, D7.W, A4.L_SRCKEY:	PUSH.W	D6	CALL	_SRCCHK	POP.W	D6	RET;--------\; _SRCCHK >;========/; in	D3.W	numro clavier physique; out	D4.W	numro fentre physique associe;		D4:#16  1 => utilise la souris;		D4:#17	1 => souris par le clavier;	D6.W	canal du clavier;	A4.L	^nom processus associ;	D7.W	erreur; mod	D4.L, D6.W, D7.W, A4.L_SRCCHK:	PUSHM.L	A0	CALL	SRCNKEY		; A0 <-- ^var utilisateur	JUMP',NE 90$	CLR.L	D4	TEST.B	(A0)+OFLAGS:#BUSEMO	JUMP',BC 40$	TSET.L	D4:#1640$:	TEST.B	(A0)+OFLAGS:#BKEYMO	JUMP',BC 50$	TSET.L	D4:#1750$:	LOAD.W	D4,(A0)+ONUDIS	; D4 <-- numro driver cran	LOAD.W	D6,(A0)+OCHKEY	; D6 <-- canal du clavier	LOAD.L	A4,#(A0)+OPRNOM	; A4 <-- ^nom du processus90$:	POPM.L	A0	RET;--------\; _SRCKNP >;========/; in	D3.W	numro clavier physique; out	D4.W	numro processus associ;	A4.L	^nom processus associ;	D7.W	erreur; mod	D4.L, D7.W, A4.L_SRCKNP:	PUSHM.L	A0	CALL	SRCNKEY		; A0 <-- ^var utilisateur	JUMP',NE 90$	CLR.L	D4	LOAD.W	D4,(A0)+OPRNUM	; D4 <-- numro du processus	LOAD.L	A4,#(A0)+OPRNOM	; A4 <-- ^nom du processus90$:	POPM.L	A0	RET;--------\; RACDIS  >;========/; Request acces for display.; in	A6.L	^variables; out	D7.W	erreur; mod	D7.WRACDIS:	PUSHM.L	D3,D4,D6,A0,A3,A4	CLR.W	(A6)+ODISOX	CLR.W	(A6)+ODISOY	LOAD.W	(A6)+ODISDX,#500	LOAD.W	(A6)+ODISDY,#-1	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP,NE	90$		; non => 90$	CALL	GETPNUM		; D4 <-- no processus pre	LOAD.W	D3,D4	LOAD.L	A3,#R16"NLDIS	; A3 <-- ^nom logique fentre	FOS	?VASSIGN	; cherche nom physique fentre	JUMP,NE 90$		; erreur => 90$				; ok =>	CALL	GETNPH		; D3 <-- no fentre physique	LOAD.W	(A6)+ONUDIS,D3	; mm numro fentre physique	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer pour ^descripteur	LOAD.L	D4,#4	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.W	D6,(A6)+OCHDIS	; D6 <-- canal pour l'cran	FOS	?RSTATUS	JUMP,NE 90$	LOAD.L	A4,(A6)+OPDDIS	; A4 <-- ^descripteur de la fentre	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	(A0)+OPTTSK,(A4)+ODFPSK ; init ^table des soft-keys	LOAD.L	A3,(A4)+ODFPDE	; A3 <-- ^^descripteurs	LOAD.L	(A0)+OPDDI0,(A3)+0 ; init ^descripteur $DIS_0	LOAD.W	(A6)+ODISOX,(A4)+ODFX	LOAD.W	(A6)+ODISOY,(A4)+ODFY	LOAD.W	(A6)+ODISDX,(A4)+ODFDX	LOAD.W	(A6)+ODISDY,(A4)+ODFDY	TSET.B	(A6)+OTASWDO+OSWFLG:#BSWUSE	LOAD.W	(A6)+OTASWDO+OSWSX,(A4)+ODFFX	LOAD.W	(A6)+OTASWDO+OSWSY,(A4)+ODFFY	LOAD.W	(A6)+OTASWDO+OSWDX,(A4)+ODFFDX	LOAD.W	(A6)+OTASWDO+OSWDY,(A4)+ODFFDY	LOAD.W	(A6)+OTASWDO+OSWPX,(A4)+ODFPX	LOAD.W	(A6)+OTASWDO+OSWPY,(A4)+ODFPY	LOAD.W	(A6)+OTASWDO+OSWGX,(A4)+ODFPGX	LOAD.W	(A6)+OTASWDO+OSWGY,(A4)+ODFPGY	LOAD.L	(A6)+OIGENC,(A4)+ODFGCF ; mm. "fstt" initial90$:	POPM.L	D3,D4,D6,A0,A3,A4	RET;--------\; RACKEY  >;========/; Request acces for keyboard.; in	A6.L	^variables; out	D7.W	erreur; mod	D7.WRACKEY:	PUSHM.L	D3,D4,A0,A3,A4	CLR.W	D7		; D7 <-- ok	COMP.B	(A6)+OTYPKEY,#TYPKEY ; type clavier ?	JUMP',NE 90$		; non => 90$	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	(A6)+ONSKEY,(A0)+OASKEY ; mm. clavier actuel	CALL	GETPNUM		; D4 <-- no processus pre	LOAD.W	D3,D4	LOAD.L	A3,#R16"NLKEY	; A3 <-- ^nom logique clavier	FOS	?VASSIGN	; cherche nom physique clavier	JUMP',NE 90$		; erreur => 90$				; ok =>	CALL	GETNPH		; D3 <-- no clavier physique	LOAD.W	(A6)+ONUKEY,D3	; mm numro clavier physique	TEST.W	(A6)+OPPNUM	; processus pre connu ?	JUMP',EQ 60$		; non => 60$	LOAD.W	D3,(A0)+OASKEY	; D3 <-- no clavier actuel	CALL	_SRCKNP		; D4/A4 <-- no/^nom du processus	TEST.W	D7	JUMP',NE 90$	COMP.W	D4,(A6)+OPPNUM	; est-ce le pre qui a le clavier ?	JUMP',NE 90$		; non => 90$60$:				; oui =>	LOAD.W	D3,(A6)+ONUKEY	CALL	_ASSKEY		; assigne le clavier	CALL	AFCVIDE		; affiche cases vides pour menu	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A0,A3,A4	RET;--------\; RLAKEY  >;========/; Release acces for keyboard.; in	A6.L	^variables; out	D7.W	erreur; mod	D7.WRLAKEY:	PUSHM.L	D3,D4,A0	CLR.W	D7		; D7 <-- ok	COMP.B	(A6)+OTYPKEY,#TYPKEY ; type clavier ?	JUMP',NE 90$		; non => 90$	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	D3,(A0)+OASKEY	; D3 <-- no clavier utilis	COMP.W	D3,(A6)+ONUKEY	; utilis actuellement ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.W	D3,(A6)+ONSKEY	; D3 <-- no clavier "pre"	CALL	_SRCKEY		; D4 <-- fentre du pre	TEST.W	D7		; pre existe toujours ?	JUMP',EQ 50$		; oui => 50$ (parfait)	LOAD.W	D3,#1		; non => assigne le clavier au CLE !50$:	CALL	_ASSKEY		; assigne clavier au pre90$:	POPM.L	D3,D4,A0	RET;--------\; RLAKEYP >;========/; Release acces for keyboard.; Idem  RLAKEY, mais sans commuter de fentre !; in	A6.L	^variables; out	D7.W	erreur; mod	D7.WRLAKEYP:	PUSHM.L	D3,D4,A0	CLR.W	D7		; D7 <-- ok	COMP.B	(A6)+OTYPKEY,#TYPKEY ; type clavier ?	JUMP',NE 90$		; non => 90$	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.W	D3,(A0)+OASKEY	; D3 <-- no clavier utilis	COMP.W	D3,(A6)+ONUKEY	; utilis actuellement ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.W	D3,(A6)+ONSKEY	; D3 <-- no clavier "pre"	CALL	_SRCKEY		; D4 <-- fentre du pre	TEST.W	D7		; pre existe toujours ?	JUMP',EQ 50$		; oui => 50$ (parfait)	LOAD.W	D3,#1		; non => assigne le clavier au CLE !50$:	TSET.L	D3:#15		; D3 <-- ne commute pas de fentre !	CALL	_ASSKEY		; assigne clavier au pre90$:	POPM.L	D3,D4,A0	RET;--------\; GETNPH  >;--------/; Donne le numro d'une unit physique.; in	A4.L	^nom physique ($KEY_2, $DIS_5, etc); out	D3.W	numro (2, 5, etc); mod	D3.WGETNPH:	PUSHM.L	D4,A4	CLR.W	D4		; D4 <-- futur numro10$:	LOAD.B	D3,(A4+)	; cherche le "_"	JUMP',EQ 80$	COMP.B	D3,#CR	JUMP',EQ 80$	COMP.B	D3,#'_	JUMP,NE 10$20$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'0		; digit ?	JUMP',LO 80$		; non => 80$	COMP.B	D3,#'9	JUMP',HI 80$	SUB.B	D3,#'0		; D3 <-- digit 0..9	AND.W	D3,#H'FF	MUL.WU	D4,#10.	ADD.W	D4,D3		; D4 <-- ajoute un digit	JUMP	20$80$:	LOAD.W	D3,D4		; D3 <-- numro	POPM.L	D4,A4	RET; Gestion de la table PUVAR; -------------------------;--------\; PUTUVAR >;--------/; Cherche un lment libre dans PUVAR et initialise-le.; in	-; out	A6.L	^variables de l'utilisateur;	D7.W	erreur; mod	D7.W, A6.LPUTUVAR:	PUSHM.L	D0,D1,D4,A0,A3,A4,A5	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OPUVAR	; A0 <-- ^^variables	LOAD.W	D0,#MAXUSER-110$:	TSET.B	(A0)+0:#0	; lment libre ?	JUMP',BC 30$		; oui => 30$	ADD.L	A0,#2+4		; A0 <-- ^suivant	DECJ.W,NMO D0,10$	LOAD.W	D7,#ERLFUL	; D7 <-- "full ..."	JUMP	90$30$:	LOAD.L	D4,#LGUVAR	; D4 <-- lg ncessaire	LOAD.W	D1,#MTYPCP	; D1 <-- type du compte mmoire	GESMEM	?SGETMEM	; demande mmoire pour vars	JUMP,NE	85$		; erreur => 85$	GESMEM	?CLEARMEM	; variables <-- zro (TOUT)	LOAD.L	(A0)+2,A4	; mm. ^variables	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A4,_VARLIB	; A4 <-- ^variables globales	LOAD.L	(A6)+OPGLOB,A4	LOAD.L	A4,#R16"START	; A4 <-- ^dbut code lib.	LOAD.L	(A6)+OLSTART,A4	CALL	GETPNUM		; D4 <-- numro processus	LOAD.W	(A6)+OPRNUM,D4	; init numro processus	CLR.W	D4		; valeur initiale pour "e"	NTREL	?CRESEM		; cre sma. pour la souris	JUMP,NE 80$	LOAD.L	(A6)+OSEMAM,A5	; init ^smaphore	NTREL	?GTPNAM		; A3 <-- ^nom du processus	LOAD.L	(A6)+OPRNOM+0,(A3)+0	LOAD.L	(A6)+OPRNOM+4,(A3)+4	LOAD.L	(A6)+OPRNOM+8,(A3)+8	LOAD.L	(A6)+OPRNOM+12,(A3)+12;	CLR.W	(A6)+OCHDIS;	CLR.W	(A6)+OCHKEY;	CLR.W	(A6)+OCHSYNT	LOAD.W	(A6)+ONUDIS,#-1	LOAD.W	(A6)+ONUKEY,#-1;	CLR.B	(A6)+OFLAGS	; clear les flags;	CLR.W	(A6)+OPTBUF	; clear "pointeur" dans OBUWRI;	CLR.L	(A6)+OPOEDI	; clear dernire pos. EDIT;	CLR.W	(A6)+OLGEDI	; clear dernire lg EDIT;	CLR.W	(A6)+OMAPBAR	; pas de barres;	CLR.L	(A6)+OTXMENU+0	; texte nul pour le menu;	CLR.L	(A6)+OTXMENU+4;	CLR.L	(A6)+OTXMENU+8	; met (1+5)*2 = 12 zros (!);	CLR.W	(A6)+ONOSWDO	; utilise sous-fentre no zro;	LOAD.L	A3,#(A6)+OTASWDO ; A3 <-- ^table des sous-fen.;	LOAD.B	D0,#MAXSWDO	 ; D0 <-- nb max de sous-fen.;60$:;	CLR.B	(A3)+OSWFLG	; clear les flags internes;	ADD.L	A3,#LGSWDO	; A3 <-- ^lment suivant;	DEC.B	D0;	JUMP,NE	60$	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	A4,A6		; A4 <-- ^zone mmoire	LOAD.W	D1,#MTYPCP	; D1 <-- type du compte mmoire	GESMEM	?GIVMEM		; rend mmoire pour variables	POP.W	D785$:	TCLR.B	(A0)+0:#0	; libre l'lment90$:	POPM.L	D0,D1,D4,A0,A3,A4,A5	TEST.W	D7		; EQ <-- si ok	RET;--------\; GETUVAR >;--------/; Cherche l'lment dans PUVAR correspondant au processus; appelant.; in	-; out	A6.L	^variables de l'utilisateur;	D7.W	erreur; mod	D7.W, A6.LGETUVAR:	PUSHM.L	D0,D4,A0	CALL	GETPNUM		; D4 <-- numro processus	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OPUVAR	; A0 <-- ^^variables	LOAD.W	D0,#MAXUSER-1	CLR.W	D7		; D7 <-- ok10$:	TEST.B	(A0)+0:#0	; lment occup ?	JUMP',BC 20$		; non => 20$	LOAD.L	A6,(A0)+2	; A6 <-- ^variables	COMP.W	D4,(A6)+OPRNUM	; numro trouv ?	JUMP',EQ 90$		; oui => 90$20$:	ADD.L	A0,#2+4		; A0 <-- ^suivant	DECJ.W,NMO D0,10$	LOAD.W	D7,#ERLNOP	; D7 <-- "lib. pas ouverte"90$:	POPM.L	D0,D4,A0	TEST.W	D7		; EQ <-- si ok	RET;--------\; KILUVAR >;--------/; Libre un lment dans PUVAR.; in	A6.L	^variables de l'utilisateur; out	-; mod	-KILUVAR:	PUSHM.L	D0,D1,A0,A4,A5	LOAD.L	A0,_VARLIB	; A0 <-- ^variables globales	LOAD.L	A0,#(A0)+OPUVAR	; A0 <-- ^^variables	LOAD.W	D0,#MAXUSER-110$:	TEST.B	(A0)+0:#0	; lment occup ?	JUMP',BC 20$		; non => 20$	COMP.L	A6,(A0)+2	; variables trouves ?	JUMP',EQ 50$		; oui => 50$20$:	ADD.L	A0,#2+4		; A0 <-- ^suivant	DECJ.W,NMO D0,10$	JUMP'	90$50$:	LOAD.L	A5,(A6)+OSEMAM	; A5 <-- ^smaphore souris	NTREL	?RACSEM	NTREL	?KILLSEM	; dtruit le smaphore	NTREL	?RLASEM	LOAD.L	A4,A6		; A4 <-- ^zone mmoire	LOAD.W	D1,#MTYPCP	; D1 <-- type du compte mmoire	GESMEM	?GIVMEM		; rend mmoire pour variables	TCLR.B	(A0)+0:#0	; libre l'lment90$:	POPM.L	D0,D1,A0,A4,A5	RET;--------\; SRCNDIS >;--------/; Cherche l'lment dans PUVAR utilisant une fentre donne.; in	D3.W	numro de fentre physique; out	A0.L	^variables de l'utilisateur;	D7.W	erreur; mod	D7.W, A0.LSRCNDIS:	PUSHM.L	D0,A1	LOAD.L	A1,_VARLIB	; A1 <-- ^variables globales	LOAD.L	A1,#(A1)+OPUVAR	; A1 <-- ^^variables	LOAD.W	D0,#MAXUSER-1	CLR.W	D7		; D7 <-- ok10$:	TEST.B	(A1)+0:#0	; lment occup ?	JUMP',BC 20$		; non => 20$	LOAD.L	A0,(A1)+2	; A0 <-- ^variables	TEST.B	(A0)+OFLAGS:#BCACHE ; fentre cache ?	JUMP',BS 20$		; oui => 20$	COMP.W	D3,(A0)+ONUDIS	; fentre trouve ?	JUMP',EQ 90$		; oui => 90$20$:	ADD.L	A1,#2+4		; A1 <-- ^suivant	DECJ.W,NMO D0,10$	LOAD.W	D7,#ERLNWD	; D7 <-- "fentre pas utilise"90$:	POPM.L	D0,A1	TEST.W	D7		; EQ <-- si ok	RET;--------\; SRCNKEY >;--------/; Cherche l'lment dans PUVAR utilisant un clavier donn.; in	D3.W	numro de clavier physique; out	A0.L	^variables de l'utilisateur;	D7.W	erreur; mod	D7.W, A0.LSRCNKEY:	PUSHM.L	D0,A1	LOAD.L	A1,_VARLIB	; A1 <-- ^variables globales	LOAD.L	A1,#(A1)+OPUVAR	; A1 <-- ^^variables	LOAD.W	D0,#MAXUSER-1	CLR.W	D7		; D7 <-- ok10$:	TEST.B	(A1)+0:#0	; lment occup ?	JUMP',BC 20$		; non => 20$	LOAD.L	A0,(A1)+2	; A0 <-- ^variables	TEST.B	(A0)+OFLAGS:#BCACHE ; fentre cache ?	JUMP',BS 20$		; oui => 20$	COMP.W	D3,(A0)+ONUKEY	; clavier trouv ?	JUMP',EQ 90$		; oui => 90$20$:	ADD.L	A1,#2+4		; A1 <-- ^suivant	DECJ.W,NMO D0,10$	LOAD.W	D7,#ERLNKY	; D7 <-- "clavier pas utilis"90$:	POPM.L	D0,A1	TEST.W	D7		; EQ <-- si ok	RET;--------\; GETPNUM >;--------/; Donne le numro du processus pre.; in	-; out	D4.W	numro du processus pre; mod	D4.WGETPNUM:	PUSHM.L	D2,D7,A4	NTREL	?GETTPT		; A4 <-- ^descr proc appelant	NTREL	?GTFATP		; D4 <-- numro du pre	POPM.L	D2,D7,A4	RET; Textes fixes; ------------NLDIS:	.ASCIZ	/#DISPLAY/	; nom de l'cranNLKEY:	.ASCIZ	/#KEYBOARD/	; nom du clavierNLSYNT:	.ASCIZ	/#SYNTHESIZER/	; nom du haut-parleurNLCLOCK:.ASCIZ	/#CLOCK/	; nom de l'horlogeNLMOU:	.ASCIZ	/#MOUSE/	; nom de la sourisNPMOU:	.ASCIZ	/$MOUSE/NPDIS:	.ASCIZ	/$DIS/NPKEY:	.ASCIZ	/$KEY/NPSYNT:	.ASCIZ	/$SYNT/NPDISM:	.ASCIZ	/$DIS_7/	; fentre pour le menuNPLIB:	.ASCIZ	/LIB/		; nom de la librairieNPDUMP:	.ASCIZ	/SHIFT-M3/	; nom de la librairie (?PFDUMP)	.EVEN	.END