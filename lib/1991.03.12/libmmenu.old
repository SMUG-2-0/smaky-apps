	.SBTTL	LIBMMENU; Gestion des m-menus; -------------------;	-------------------;	   M  M  E  N  U;	-------------------;;	Reprsentation des grandeurs horizontales d'un "mmenu";	avec son cadre. Les mmes grandeurs existent verticalement,;	avec une marge suprieure invisible pour modulo 2.;;	. = vide autour du cadre;	o = cadre double;	! = marge invisible pour modulo 8;	l = sparations entre les colonnes;	t = texte dans les cases;;	NCX = 3;	            largeur swdo (modulo 8);	<---------------------------------------------->;	. . . . . . . . . . . . . . . . . . . . . . . .;	. . . . . . . . . . . . . . . . . . . . . . . .;	. . o o o o o o o o o o o o o o o o o o o o . .;	. . o o o o o o o o o o o o o o o o o o o o . .;	. . o o   !         l         l         o o . .;	. . o o   !         l         l         o o . .;	. . o o   !         l         l         o o . .;	. . o o   !   t t   l   t t   l   t t   o o . .;	. . o o   !         l         l         o o . .;	<------><--><--------><--------><--------><---->;	   4    AJX    LGX       LGX       LGX      3;	       (0..7);	etc.;	. . o o   !         l         l         o o . .;	. . o o   !         l         l         o o . .;	. . o o o o o o o o o o o o o o o o o o o o . .;	. . o o o o o o o o o o o o o o o o o o o o . .;	. . . . . . . . . . . . . . . . . . . . . . . .;	. . . . . . . . . . . . . . . . . . . . . . . .;--------\; _MMENU  >;========/; Choix dans un m-menu avec la souris jusqu' ce que; l'tat des boutons change.; in	A3.L	^textes .ASCIZ termins par zro;	D3.W	choix par dfaut;	D4.L	bitmap des cases inactives (si D3:#15=1); out	D3.W	choix effectu (0..n);	D7.W	erreur; mod	D3.L, D7.W_MMENU:	PUSHM.L	D0,D1,D2,D4,D6	CLR.L	(A6)+OMSMAG	; OMSMAG <-- toutes les cases sont actives	TCLR.L	D3:#15	JUMP',BC 02$	LOAD.L	(A6)+OMSMAG,D4	; OMSMAG <-- cases inactives02$:	LOAD.W	D6,D3		; D6 <-- case par dfaut	CALL	_IFMOUSE	; D4 <-- coordonne souris	TEST.W	D7	JUMP,NE	90$	LOAD.B	D1,D3		; D1 <-- boutons initiaux;;?	LOAD.L	D0,D4		; D0 <-- position initiale	CALL	OPEBMM		; cre s-wdo pour menu	TEST.W	D7	JUMP,NE	90$	CALL	_IFMOUSE	; D4 <-- coordonne souris	LOAD.W	D2,#-2		; D2 <-- pas d'ancienne case10$:	CALL	DETBMM		; D3 <-- case 0..n	COMP.W	D3,D2		; mme case ?	JUMP',EQ 40$		; oui => 40$				; non =>;;?	TEST.W	D3		; case valide ?;;?	JUMP',NC 20$		; oui => 20$;;?				; non =>;;?	LOAD.W	D3,D2		; D3 <-- garde ancienne case;;?	JUMP'	40$20$:	EX.L	D2,D3		; D2 <-- old, D3 <-- new	CALL	MSINVB		; "teint" ancienne case	LOAD.W	D3,D2		; D3 <-- new	CALL	MSINVB		; "allume" nouvelle case40$:	LOAD.W	D2,D3		; D2 <-- no case "allume"	TEST.B	(A6)+OFLAGS:#BKEYMO ; souris par le clavier ?	JUMP',BS 50$		; oui => 50$	CALL	_RDMOUSE	; attend sur la souris	JUMP'	60$50$:	CALL	_GETKEY		; attend sur la souris	CALL	_IFMOUSE	; D3 <-- boutons, D4 <-- position60$:	COMP.B	D3,D1		; boutons changs ?	JUMP,EQ	10$		; non => 10$				; oui =>;;?	LOAD.B	D1,D3		; D1 <-- nouveaux boutons attendus;;?	COMP.L	D4,D0		; souris bouge ?;;?	JUMP,EQ 10$		; non => 10$;;?				; oui =>	CLR.W	D7		; D7 <-- ok	LOAD.W	D3,D2		; case 0..n "allume" ?	JUMP',NC 80$		; oui => 80$	LOAD.W	D7,#ERKSTO	; non => erreur	CLR.W	D3		; D3 <-- case vide tout en haut !80$:	CALL	CLOBMM		; restitue s-wdo90$:	POPM.L	D0,D1,D2,D4,D6	RET;--------\; OPEBMM  >;--------/; Cre la sous-fentre pour un m-menu.; in	A3.L	^textes .ASCIZ termins par zro;	D4.L	coordonne y;x o crer le m-menu;	D6.W	case par dfaut; out	D7.W	erreur; mod	D7.WOPEBMM:	PUSHM.L	D0..D6,A1..A4	LOAD.L	D0,D4		; D0 <-- coordonne	LOAD.L	A4,(A6)+OPDDIS	; A4 <-- ^descripteur de la fentre; Cherche la largeur et la hauteur de la ligne la plus grande,; en tenant compte de caractres  chasses variables et de; changements de gencars.	CLR.W	D1		; D1 <-- largeur la plus grande	CLR.W	D2		; D2 <-- h1 la plus grande	CLR.W	D5		; D5 <-- h2 la plus grande	CLR.W	D4		; D4 <-- nb de .ASCIZ	PUSHM.L	D0,A3	LOAD.L	A1,(A4)+ODFPGC	; A1 <-- ^dbut GENCAR	ADD.L	A1,#OGCWID	; A1 <-- ^table des largeurs20$:	TEST.B	(A3)		; fin ?	JUMP',EQ 50$		; oui => 50$	CLR.W	D0		; D0 <-- largeur d'un .ASCIZ	INC.W	D4		; D4 <-- un .ASCIZ de plus30$:	CLR.W	D3	LOAD.B	D3,(A3+)	; D3 <-- un caractre	JUMP',EQ 45$	COMP.B	D3,#-1		; ligne horizontale ?	JUMP,EQ	30$		; oui => 30$	COMP.B	D3,#USEGC	; changement de gencar ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#TYPOAX	; positionnement absolu en X ?	JUMP',EQ 42$		; oui => 42$	TEST.L	D3:#7		; caractre de commande (AFINV, AFGREY, etc.) ?	JUMP,BS 30$		; oui => 30$	LOAD.B	D3,(A1)+(D3.W)	; D3 <-- largeur du caractre	ADD.W	D0,D3		; D0 <-- ajoute largeur	COMP.W	D2,(A4)+ODFC1Y	JUMP',GE 35$	LOAD.W	D2,(A4)+ODFC1Y35$:	COMP.W	D5,(A4)+ODFC2Y	JUMP,GE 30$	LOAD.W	D5,(A4)+ODFC2Y	JUMP	30$40$:				; <USEGC> =>	DEC.L	A3		; A3 <-- ^<usegc> <f> <s/c> <t>	LOAD.W	D3,#4		; D3 <-- lg	CALL	_STRING		; utilise le nouveau gencar	ADD.L	A3,#4		; A3 <-- saute <usegc> <f> <s/c> <t>	LOAD.L	A1,(A4)+ODFPGC	; A1 <-- ^dbut GENCAR	ADD.L	A1,#OGCWID	; A1 <-- ^table des largeurs	JUMP	30$42$:				; <TYPOAX> =>	LOAD.B	D0,(A3+)	SL.W	D0,#8	LOAD.B	D0,(A3+)	; D0 <-- position absolue en X	JUMP	30$45$:	COMP.W	D0,D1		; plus large que le prcdent ?	JUMP,LO	20$		; non => 20$	LOAD.W	D1,D0		; D1 <-- la plus grande largeur	JUMP	20$50$:	ADD.W	D1,#2+2+1	; D1 <-- p'tites marges	LOAD.W	(A6)+OMSLGX,D1	LOAD.W	(A6)+OMSL1Y,D2	ADD.W	D2,D5		; D2 <-- hauteur d'un car.	ADD.W	D2,#1+1+1	; D2 <-- p'tite marges	LOAD.W	(A6)+OMSLGY,D2	LOAD.W	(A6)+OMSNBC,D4	COMP.W	D6,D4		; case par dfaut existe ?	JUMP',LO 53$		; oui => 53$	CLR.W	D6		; non => prend la premire !53$:	POPM.L	D0,A3; Vrifie s'il faut mettre plusieurs colonnes.	CLR.L	D4	LOAD.W	D4,(A4)+ODFDY	DIV.WU	D4,(A6)+OMSLGY	; D4 <-- nb max de cases en hauteur	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- reste	LOAD.W	D2,#4+3	ADD.W	D2,(A6)+OMSAJY	; D2 <-- reste ncessaire	COMP.W	D3,D2		; reste assez ?	JUMP',HS 54$		; oui => 54$	DEC.W	D4		; non => une case de moins !54$:	CLR.W	D2		; D2 <-- nb de colonnes55$:	INC.W	D2		; D2 <-- une colonne de plus	CLR.L	D3	LOAD.W	D3,(A6)+OMSNBC	; D3 <-- nb de case	DIV.WU	D3,D2	SWAP.W	D3	TEST.W	D3		; reste qq chose ?	JUMP',EQ 57$		; non => 57$	ADD.L	D3,#H'10000	; oui => arrondi  l'unit suprieure57$:	SWAP.W	D3	COMP.W	D3,D4		; y a-t-il la place en hauteur ?	JUMP,HI 55$		; non => 55$				; oui =>	LOAD.W	(A6)+OMSNCX,D2	LOAD.W	(A6)+OMSNCY,D3; Cre la sous-fentre temporaire.	LOAD.W	D4,(A6)+OMSLGY	MUL.WU	D4,(A6)+OMSNCY	ADD.W	D4,#4+3	LOAD.W	D2,D4	INC.W	D4	AND.B	D4,#B'11111110	; D4 <-- arrondi au multiple de 2 sup.	SUB.W	D2,D4	NEG.W	D2		; D2 <-- ajustage en Y	LOAD.W	(A6)+OMSAJY,D2	SWAP.W	D4	LOAD.W	D3,(A6)+OMSLGX	MUL.WU	D3,(A6)+OMSNCX	ADD.W	D3,#4+3	LOAD.W	D2,D3	ADD.W	D3,#8-1	AND.B	D3,#B'11111000	; D3 <-- arrondi au multiple de 8 sup.	LOAD.W	D4,D3	SUB.W	D2,D4	NEG.W	D2		; D2 <-- ajustage en X	LOAD.W	(A6)+OMSAJX,D2	LOAD.L	D3,D0		; D3 <-- origine sous-fentre	AND.L	D6,#H'FFFF	DIV.WU	D6,(A6)+OMSNCY	; D6 <-- position (y;x)	SWAP.W	D6		; D6 <-- position (x;y)	CLR.L	D5		; D5 <-- pas encore de correction	LOAD.W	D7,#ERDIOUT	SWAP.W	D3	SWAP.W	D4	COMP.W	D4,(A4)+ODFDY	; fentre trop haute ?	JUMP,HS	90$		; oui => 90$	LOAD.W	D2,(A6)+OMSLGY	; D2 <-- hauteur d'une case	LOAD.W	D1,D2	SR.W	D2,#1		; D2 <-- 1/2 largeur	MUL.WU	D1,D6	ADD.W	D2,D1	SUB.W	D3,D2		; D3 <-- remonte origine Y	JUMP',NC 62$		; dpasse pas haut => 62$	LOAD.W	D5,D3		; D5 <-- descend un peu la souris	CLR.W	D3		; D3 <-- colle en haut62$:	LOAD.W	D2,D3	ADD.W	D2,D4		; D2 <-- extrmit infrieure	SUB.W	D2,(A4)+ODFDY	; dpasse en bas ?	JUMP',LO 64$		; non => 64$	LOAD.W	D3,D2	LOAD.W	D5,D3		; D5 <-- monte un peu la souris	LOAD.W	D3,(A4)+ODFDY	SUB.W	D3,D4		; D3 <-- maximum possible64$:	AND.B	D3,#B'11111110	; alligne sur un word	LOAD.W	(A6)+OMSORY,D3	; mm. origine Y	SWAP.W	D4	SWAP.W	D3	SWAP.W	D5	SWAP.W	D6		; D6 <-- position (y;x)	COMP.W	D4,(A4)+ODFDX	; fentre trop large ?	JUMP,HS	90$		; oui => 90$	LOAD.W	D2,(A6)+OMSLGX	; D2 <-- largeur d'une case	LOAD.W	D1,D2	SR.W	D2,#1		; D2 <-- 1/2 largeur	MUL.WU	D1,D6	ADD.W	D2,D1	SUB.W	D3,D2		; D3 <--  gauche origine X	JUMP',NC 66$		; dpasse pas  gauche => 66$	LOAD.W	D5,D3		; D5 <-- pousse un peu la souris  droite	CLR.W	D3		; D3 <-- colle  gauche66$:	LOAD.W	D2,D3	ADD.W	D2,D4		; D2 <-- extrmit droite	SUB.W	D2,(A4)+ODFDX	; dpasse  droite ?	JUMP',LO 68$		; non => 68$	LOAD.W	D3,D2	LOAD.W	D5,D3		; D5 <-- pousse un peu la souris  gauche	LOAD.W	D3,(A4)+ODFDX	; oui =>	SUB.W	D3,D4		; D3 <-- maximum possible68$:	AND.B	D3,#B'11111000	; aligne sur un byte	LOAD.W	(A6)+OMSORX,D3	; mm. origine X	CALL	MPOBMM		; corrige la position de la souris	CALL	_CREWDO		; cre sous-fentre	TEST.W	D7	JUMP,NE	90$	CALL	_USEWDO		; utilise sous-fentre cre	TEST.W	D7	JUMP,NE	90$	LOAD.B	(A6)+OMSSVM,(A4)+ODFMOD	CALL	_AFTIM	.B	SAVWDO		; sauve contenu actuel	.B	NOCURS		; pas de curseur	.B	0	.EVEN	TEST.W	D7		; sauvetage ok ?	JUMP,NS	80$		; non => 80$	LOAD.B	D3,#EOP	CALL	_AFCAR		; efface tout	CALL	MSCADRE		; trace tous les cadres	CLR.W	D0		; D0 <-- case en X	CLR.W	D1		; D1 <-- case en Y	CLR.W	D5		; D5 <-- no case	LOAD.W	D3,#4+1	ADD.W	D3,(A6)+OMSL1Y	ADD.W	D3,(A6)+OMSAJY	SWAP.W	D3	LOAD.W	D3,#4+2		; D3 <-- coordonne initiale	ADD.W	D3,(A4)+ODFC1X	ADD.W	D3,(A6)+OMSAJX70$:	LOAD.B	D2,(A3)		; encore un .ASCIZ ?	JUMP,EQ 77$		; non => 77$	COMP.B	D2,#-1		; ligne horizontale ?	JUMP',NE 71$		; non => 71$	INC.L	A3		; oui =>	CALL	MSLIGNE		; trace la ligne	JUMP	70$71$:	CALL	_SETCURS	; positionne curseur typo	PUSH.L	D3	LOAD.L	A2,#(A6)+OBUFFER	LOAD.B	(A2+),#AFTOUT	; buffer <-- affiche tous les codes	COMP.W	D5,#32	JUMP',HS 72$	LOAD.L	D3,(A6)+OMSMAG	TEST.L	D3:D5		; case inactive ?	JUMP',BC 72$		; non => 72$	LOAD.B	(A2+),#AFGREY	; buffer <-- affiche la ligne en gris72$:	LOAD.B	D3,(A3+)	JUMP',EQ 75$	LOAD.B	(A2+),D3	; buffer <-- un caractre	COMP.B	D3,#USEGC	JUMP',EQ 74$	COMP.B	D3,#TYPOAX	JUMP,NE 72$	LOAD.B	D3,(A3+)	SL.W	D3,#8	LOAD.B	D3,(A3+)	; D3 <-- <xx> aprs <typoax>	LOAD.W	D4,D0	MUL.WU	D4,(A6)+OMSLGX	; D4 <-- offset dbut colonne en X	ADD.W	D4,(A6)+OMSAJX	ADD.W	D3,D4		; D3 <-- <xx> dans la bonne colonne	RR.W	D3,#8	LOAD.B	(A2+),D3	RR.W	D3,#8	LOAD.B	(A2+),D3	; buffer <-- <xx> + correction	JUMP	72$74$:	LOAD.B	(A2+),(A3+)	; buffer <-- <f>	LOAD.B	(A2+),(A3+)	; buffer <-- <s>	LOAD.B	(A2+),(A3+)	; buffer <-- <t>	JUMP	72$75$:	LOAD.B	(A2+),#AFNORM	; buffer <-- remet le mode normal	LOAD.B	(A2+),#AFFULL	; buffer <-- remet le mode plein	EX.L	A2,A3	LOAD.L	D3,A3		; D3 <-- ^fin du buffer	LOAD.L	A3,#(A6)+OBUFFER; A3 <-- ^dbut du buffer	SUB.L	D3,A3		; D3 <-- lg dans buffer	CALL	_STRING		; affiche un .ASCIZ	LOAD.L	A3,A2	POP.L	D3	INC.W	D5		; D5 <-- no case suivante	SWAP.W	D3	ADD.W	D3,(A6)+OMSLGY	; D3 <-- descend  la case en dessous	SWAP.W	D3	INC.W	D1		; D1 <-- case en Y suivante	COMP.W	D1,(A6)+OMSNCY	; est-on en bas de la colonne ?	JUMP,LO 70$		; non => 70$				; oui =>	CLR.W	D1	INC.W	D0		; D0 <-- case en X suivante	ADD.W	D3,(A6)+OMSLGX	; D3 <-- va  la vase  droite	SWAP.W	D3	LOAD.W	D3,#4+1	ADD.W	D3,(A6)+OMSL1Y	; D3 <-- revient en haut	ADD.W	D3,(A6)+OMSAJY	SWAP.W	D3	JUMP	70$77$:	LOAD.W	D4,(A6)+OMSNCX	MUL.WU	D4,(A6)+OMSNCY	COMP.W	D4,(A6)+OMSNBC	; toutes les cases occupes ?	JUMP',EQ 78$		; oui => 78$	CALL	MSLIGNE		; non => trace une dernire ligne78$:	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	CALL	CLOBMM		; libre sous-fentre si erreur90$:	POPM.L	D0..D6,A1..A4	RET;--------\; MPOBMM  >;--------/; Positionne la souris pour pointer la case par dfaut.; in	D5.L	distance Y;X  corriger (+/-);	D0.L	coordonne initiale;	A4.L	^descripteur de la fentre; out	-; mod	D7.WMPOBMM:	PUSHM.L	D3..D6,A0,A4	TEST.L	D5		; correction  effectuer ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A0,#R16"VAR	; A0 <-- ^variables globales	LOAD.L	D4,D0		; D4 <-- coordonne initiale	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D5		; D4 <-- monte/descend	ADD.W	D4,(A4)+ODFY	; D4 <-- position dans $DIS_0	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D5		; D4 <-- gauche/droite	ADD.W	D4,(A4)+ODFX	; D4 <-- position dans $DIS_0	LOAD.L	A4,#(A6)+OBUMOU+1	LOAD.B	(A4)+0,#'P	LOAD.L	(A4)+1,D4	CLR.B	(A4)+5	LOAD.W	D3,#TYPIO	LOAD.W	D6,(A0)+OCHMOU	; D6 <-- canal souris	FOS	?COMMAND90$:	POPM.L	D3..D6,A0,A4	RET;--------\; CLOBMM  >;--------/; Supprime la sous-fentre pour un m-menu.; in	-; out	-; mod	-CLOBMM:	PUSHM.L	D3,D4,D5,D7	LOAD.B	D3,#GETWDO	CALL	_AFCAR		; restitue contenu sous-fentre	CALL	_GETWDO		; D5 <-- no s-wdo pour menu	LOAD.W	D4,D5	CLR.W	D5	CALL	_USEWDO		; utilise s-wdo principale	LOAD.W	D5,D4	CALL	_KILWDO		; dtruit s-wdo menu	TEST.B	(A6)+OMSSVM:#BFNOCU	JUMP',BS 90$	LOAD.B	D3,#CURS	CALL	_AFCAR		; remet curseur s'il existait90$:	POPM.L	D3,D4,D5,D7	RET;--------\; DETBMM  >;--------/; Dtecte dans quelle case est la souris.; in	D4.L	coordonnes de la souris;	A3.L	^mmenu; out	D3.W	case montre (0..n);		-1 si en dehors;		:#15 si case inactive (grise); mod	D3.L, D7.WDETBMM:	PUSHM.L	D4,D5	LOAD.L	D5,D4	AND.L	D4,#H'FFFF	; D4 <-- position X	LOAD.W	D3,#-1		; D3 <-- en dehors	SUB.W	D4,(A6)+OMSORX	; souris trop  gauche ?	JUMP',LO 80$		; oui => 80$				; non =>	SUB.W	D4,#4		; souris dans marge gauche ?	JUMP',LO 80$		; oui => 80$	SUB.W	D4,(A6)+OMSAJX	JUMP',HS 20$	CLR.W	D420$:	DIV.WU	D4,(A6)+OMSLGX	COMP.W	D4,(A6)+OMSNCX	; souris trop  droite ?	JUMP',HS 80$		; oui => 80$				; non =>				; D4 <-- case en X (0..n)	CLR.W	D5	SWAP.W	D5		; D5 <-- position Y	LOAD.W	D3,#-1		; D3 <-- en dehors	SUB.W	D5,(A6)+OMSORY	; souris trop haute ?	JUMP',LO 80$		; oui => 80$				; non =>	SUB.W	D5,#4		; souris dans marge suprieure ?	JUMP',LO 80$		; oui => 80$	SUB.W	D5,(A6)+OMSAJY	JUMP',HS 40$	CLR.W	D540$:	DIV.WU	D5,(A6)+OMSLGY	COMP.W	D5,(A6)+OMSNCY	; souris trop basse ?	JUMP',HS 80$		; oui => 80$				; non =>				; D5 <-- case en Y (0..n)	LOAD.W	D3,D4	MUL.WU	D3,(A6)+OMSNCY	ADD.W	D3,D5		; D3 <-- case dans le "tableau"	COMP.W	D3,(A6)+OMSNBC	; est-on dans une case "vide" ?	JUMP',LO 80$		; non => 80$				; oui =>	LOAD.W	D3,(A6)+OMSNBC	; D3 <-- met le maximum (en bas  droite)	DEC.W	D380$:	COMP.W	D3,#-1	JUMP',EQ 90$	COMP.W	D3,#32	JUMP',HS 90$	LOAD.L	D4,(A6)+OMSMAG	TEST.L	D4:D3		; case inactive ?	JUMP',BC 90$		; non => 90$	TSET.L	D3:#1590$:	POPM.L	D4,D5	RET;--------\; MSINVB  >;--------/; Inverse une case entire selon son numro.; in	D3.W	numro de la case 0..n;		si -1/-2 => ne fait rien;		:#15 si case inactive (grise); out	-; mod	D7.WMSINVB:	PUSHM.L	D1..D4	COMP.W	D3,#-1	JUMP,EQ 90$	COMP.W	D3,#-2	JUMP,EQ 90$	LOAD.L	D4,#-1		; D4 <-- trame pleine	TCLR.L	D3:#15		; case inactive ?	JUMP',BC 05$		; non => 05$;;?	LOAD.L	D4,#H'55005500	; D4 <-- trame grise	LOAD.L	D4,#H'40000400	; D4 <-- trame grise05$:	PUSH.L	D3	LOAD.L	D3,D4	CALL	_DRMDEF		; dfinit la trame pleine/grise	POP.L	D3	CLR.L	D4	LOAD.W	D4,D3		; D4 <-- case 0..n	DIV.WU	D4,(A6)+OMSNCY	; D4 <-- case (y;x)	LOAD.W	D1,D4		; D1 <-- case en X	LOAD.L	D2,D4	SWAP.W	D2		; D2 <-- case en Y	LOAD.W	D3,D2	MUL.WU	D3,(A6)+OMSLGY	ADD.W	D3,#4		; D3 <-- <yy>	TEST.W	D2		; premire case ?	JUMP',EQ 10$		; oui => 10$	ADD.W	D3,(A6)+OMSAJY	; non => compte premire plus haute10$:	SWAP.W	D3	LOAD.W	D4,D1	MUL.WU	D4,(A6)+OMSLGX	ADD.W	D4,#4	TEST.W	D1		; premire case ?	JUMP',EQ 20$		; oui => 20$	ADD.W	D4,(A6)+OMSAJX	; non => compte premire plus large20$:	LOAD.W	D3,D4		; D3 <-- <xx>	LOAD.W	D4,(A6)+OMSLGY	DEC.W	D4		; D4 <-- <dyy>	TEST.W	D2		; premire case ?	JUMP',NE 30$		; non => 30$	ADD.W	D4,(A6)+OMSAJY	; oui => compte premire plus haute30$:	SWAP.W	D4	LOAD.W	D4,(A6)+OMSLGX	DEC.W	D4		; D4 <-- <dxx>	TEST.W	D1		; premire case ?	JUMP',NE 40$		; non => 40$	ADD.W	D4,(A6)+OMSAJX	; oui => compte premire plus large40$:	LOAD.B	D2,#INVDOT	; D2 <-- <mode>	CALL	_DRTRAME	; inverse une case90$:	POPM.L	D1..D4	RET;--------\; MSCADRE >;--------/; Trace tous les rectangles pour les cases.; in	-; out	D7.W	erreur; mod	D7.WMSCADRE:	PUSHM.L	D1..D4	LOAD.W	D4,(A6)+OMSLGY	MUL.WU	D4,(A6)+OMSNCY	ADD.W	D4,#2	ADD.W	D4,(A6)+OMSAJY	SWAP.W	D4	LOAD.W	D3,(A6)+OMSLGX	MUL.WU	D3,(A6)+OMSNCX	ADD.W	D3,#2	ADD.W	D3,(A6)+OMSAJX	LOAD.W	D4,D3	LOAD.W	D3,#2	SWAP.W	D3	LOAD.W	D3,#2	LOAD.B	D2,#SETDOT	CALL	_DRRECT		; trace rectangle extrieur	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	CALL	_DRRECT		; trace rectangle intrieur	LOAD.W	D3,#4-1		; D3 <-- <xx> initial	ADD.W	D3,(A6)+OMSAJX	CLR.W	D4		; D4 <-- <dxx> pour ligne verticale	LOAD.W	D1,(A6)+OMSNCX50$:	DEC.W	D1	JUMP',EQ 90$	ADD.W	D3,(A6)+OMSLGX	; D3 <-- <xx> colonne suivante	PUSH.L	D3	CALL	_DRSEG		; trace segment vertical entre colonnes	POP.L	D3	JUMP	50$90$:	POPM.L	D1..D4	RET;--------\; MSLIGNE >;--------/; Trace une ligne horizontale pour sparer les cases.; in	D3.L	coordonne pour caractre;	D0.W	rang case en X; out	D7.W	erreur; mod	D7.WMSLIGNE:	PUSHM.L	D2..D4	CALL	_AFTIM	.B	MAPTT	.B	B'10101010	; map des traits - - -	.B	1		; chelle	.B	0	.EVEN	SWAP.W	D3	SUB.W	D3,(A6)+OMSL1Y	SUB.W	D3,#2		; D3 <-- en haut de la case	SWAP.W	D3	SUB.W	D3,#2		; D3 <--  gauche de la case	CLR.L	D4	LOAD.W	D4,(A6)+OMSLGX	TEST.W	D0		; premire case ?	JUMP',NE 50$		; non => 50$	ADD.W	D4,(A6)+OMSAJX	; oui => compte premire case plus large	SUB.W	D3,(A6)+OMSAJX	; D3 <-- recule aussi l'origine en X50$:	LOAD.B	D2,#SETDOT!TTTDOT	CALL	_DRSEG		; trace ligne horizontale - - -	POPM.L	D2..D4	RET	.END