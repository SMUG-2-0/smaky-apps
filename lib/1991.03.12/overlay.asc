\define g_Fond:\nef11;\define g_ev:\n(bf)09;\define g_titre:\m(f)17;\define g_it:\n(if)07;\g_Fond;	.TITLE		OVERLAY.ASC; test d'un programme tournant en overlay total; le fos fait un call {A4} pour excuter ce programme !; le programme dispose galement d'une entre normale; pouvant tre utilise de diverses manires. Voir + loin	.PROC		M68000	.REF		SMAKY	.REF		MODULES	.START		START_NORMAL	; point d'entre normal	.HEADER		OBXSOVER, .32	START_OVERLAY					; point d'entre overlay					; ATTENTION, NON NUL	.CODE		,,2'100111			;   |			;   ORISKD	Overlay en priorit;--------------\\; START_NORMAL  >;==============/; Entre utilise par FOS ?EXECUTE en absence du bit 5 (.CODE); utilise galement par FOS ?NEXECUTE avec D4:#BEXSNORM set; utilise aussi si START_OVERLAY retourne D7=-1START_NORMAL:	LIB		?OPELIB		; ouvre la librairie	MOVE.16		#-1, D0		; repre pour savoir d'o l'on vient	CALL		START_OVERLAY	; mme routine en overlay !	LIB		?CLOLIB		; referme la librairie	FOS		?STOP		; termine le processus; ATTENTION    OVERLAY    ATTENTION; =========    +++++++    =========; un tel logiciel est excut comme routine du programme appelant.; il faut par consquent,; - ne pas excuter les appels LIB?OPELIB, LIB?CLOLIB et FOS?STOP; - ne pas excuter ?WFABDESC et tuer les processus avant le RET; - rendre la mmoire rserve avant le RET au logiciel appelant; - TOUS LES REGISTRES SONT SAUVEGARDES PAR LE FOS; - A L'ENTREE LES REGISTRES SONT INITIALISES A ZERO SAUF:; -	A3.32 ^ligne de commande (non copie); -	A4.32 ^APC le FOS fait un CALL {A4}; -	A6.32 ^adresse absolue de dbut du code; - ne pas modifier, ( moins de le rtablir), les modes d'affichages; - rtablir galement les softkeys si modifies; - de mme pour le timout et la priorit; - le programme doit tester correctement TOUTES les erreurs car;   > on peut essayer de l'excuter dans le CLE (fentre trop petite);   > on peut l'excuter dans le filer (modules pas ouverts);   > il peut tre appel par un programme n'utilisant pas la librairie;   ...; - En sortie : rtablir la pile comme  l'entre pour faire le RET;	il est galement possible de conserver {SP}  l'entre;	pour faire le jump {Ai}  la fin.; - En sortie, si D7.16 = -1;   > le FOS rexcute le logiciel sur le point d'entre normal!;     ( Ncessaire pour #DISPLAY, #KEYBOARD, #SYNTHESIZER );---------------\\; START_OVERLAY  >;===============/; Entre utilise par FOS ?EXECUTE en prsence du bit 5 (.CODE); utilise galement par FOS ?NEXECUTE avec D4:#BEXSOVER set;; in	A3.32	^ligne de commande (^original du logiciel appelant);	A4.43	APC, point d'entre;	A6.32	^adresse absolue de dbut du code;		les autres registres  zro si appele par FOS; out	D7.16	erreur;		#-1, s'il faut reprendre le logiciel sur START_NORMAL; mod	tous;START_OVERLAY:	LIB		?PUSHMENU	; sauve les soft-keys -> D5.32	MOVE.32		#2**BDBSAV, D2	; mode d'ouverture de la DBOX	DBOX_		TERROR		; affiche le texte ^A3 (ligne de commande)	push.16		D7	LIB		?POPMENU	; rtabli les soft-keys	pop.16		D7		; out : erreur du module DBOX !	RET				; RETOURNE AU PROGRAMME APPELANT	.END