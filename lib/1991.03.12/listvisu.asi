	.SBTTL	LISTVISU; Constantes; ----------FACPOSR	=	10000		; facteur pour les positions relativesMARIFY	=	8		; marge pour les infos en YMINWDOX	=	LGSCROLL*5	; fentre minimale en XMINWDOY	=	LGSCROLL*5	; fentre minimale en Y; Types de fichier; ----------------TYPIMAGE =	1		; fichier .IMAGETYPPLAN =	2		; fichier .PLANTYPGENCAR =	3		; fichier .GENCTYPCOLOR =	4		; fichier .COLOR;-----------\\; _LIST_VISU >;===========/; Appel de dbranchement.; in	selon appel; out	selon appel; mod	selon appel_LIST_VISU:	COMP.B	D2,#VISU_OPEN	JUMP,EQ _LIST_VISUOPEN	COMP.B	D2,#VISU_PARAM	JUMP,EQ _LIST_VISUPARAM	COMP.B	D2,#VISU_USER	JUMP,EQ _LIST_VISUUSER	COMP.B	D2,#VISU_HEAD	JUMP,EQ _LIST_VISUHEAD	COMP.B	D2,#VISU_DRAW	JUMP,EQ _LIST_VISUDRAW	COMP.B	D2,#VISU_UPDATE	JUMP,EQ _LIST_VISUUPDATE	COMP.B	D2,#VISU_MOVE	JUMP,EQ _LIST_VISUMOVE	COMP.B	D2,#VISU_INFO	JUMP,EQ _LIST_VISUINFO	COMP.B	D2,#VISU_CLOSE	JUMP,EQ _LIST_VISUCLOSE	COMP.B	D2,#VISU_TYPE	JUMP,EQ _LIST_VISUTYPE	LOAD.W	D7,#ERDIOUT	RET;---------------\\; _LIST_VISUOPEN >;===============/; Lit un fichier sur disque, sans l'afficher.; in	D2.L	#VISU_OPEN + mode (BLIVOxxx);	A3.L	^nom du fichier;	A0.L	^descripteur de la fentre; out	D6.L	canal;	D7.W	erreur; mod	D6.L, D7.W_LIST_VISUOPEN:	PUSHM.L	D1,D3,D4,A3,A4,A6	LOAD.L	D4,#LHV		; D4 <-- lg	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour variables	JUMP,NE 90$	GESMEM	?CLEARMEM	; met toutes les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OHVMOO,D2	; OHVMOO <-- mode	LOAD.W	(A6)+OHVCHS,#-1	; module STRETCH pas ouvert	LOAD.W	(A6)+OHVCHP,#-1	; module PLANA pas ouvert	LOAD.L	A4,#(A6)+OHVNAM20$:	LOAD.B	(A4+),(A3+)	; OHVNAM <-- nom du fichier	JUMP,NE 20$	LOAD.L	A3,#(A6)+OHVNAM	; A3 <-- ^nom du fichier dans OHVNAM	CALL	_LIST_VISUTYPE	; OHVTYP <-- type du fichier	LOAD.W	(A6)+OHVTYP,D3	COMP.W	D3,#TYPIMAGE	JUMP',EQ 41$	COMP.W	D3,#TYPPLAN	JUMP',EQ 42$	COMP.W	D3,#TYPGENCAR	JUMP',EQ 43$	COMP.W	D3,#TYPCOLOR	JUMP',EQ 44$	CALL	ASCIIOPEN	JUMP'	50$41$:	CALL	IMAGEOPEN	JUMP'	50$42$:	CALL	PLANOPEN	JUMP'	50$43$:	CALL	GENCAROPEN	JUMP'	50$44$:	CALL	COLOROPEN;	JUMP'	50$50$:	TEST.B	(A6)+OHVMOO+2:#BLIVOMERR-8 ; affiche si erreur ?	JUMP',BC 80$		; non => 80$				; oui =>	LOAD.W	(A6)+OHVERR,D7	; OHVERR <-- code de l'erreur v.	CLR.W	D7		; D7 <-- fait comme si tout tait ok !80$:	LOAD.L	D6,A6		; D6 <-- canal !	TEST.W	D7		; est-ce que tout est ok ?	JUMP',EQ 90$		; oui => 90$	PUSH.W	D7	LOAD.L	A4,A6		; A4 <-- ^variables	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire des variables	POP.W	D790$:	PUSH.W	D7	CALL	NORMMOUSE	; souris: enlve le sablier	POP.W	D7	POPM.L	D1,D3,D4,A3,A4,A6	TEST.W	D7		; retour EQ/NE	RET;----------------\\; _LIST_VISUPARAM >;================/; Donne quelques paramtres, en fonction du type du fichier.; in	D2.L	#VISU_PARAM;	D6.L	canal;	A0.L	^descripteur de la fentre; out	D2.L	rserve;	D3.L	position relative par dfaut;	D4.L	fanions par dfaut (BLIVUxxxx);	A4.L	^textes des options (tout<0>ngatif<0>divers<0><0>);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A4.L_LIST_VISUPARAM:	PUSH.L	A6	LOAD.W	D7,#ERILCH	TEST.L	D6	JUMP',EQ 80$	LOAD.L	A6,D6		; A6 <-- ^variables	COMP.W	(A6)+OHVTYP,#TYPIMAGE	JUMP',EQ 41$	COMP.W	(A6)+OHVTYP,#TYPPLAN	JUMP',EQ 42$	COMP.W	(A6)+OHVTYP,#TYPGENCAR	JUMP',EQ 43$	COMP.W	(A6)+OHVTYP,#TYPCOLOR	JUMP',EQ 44$	CALL	ASCIIPARAM	JUMP'	80$41$:	CALL	IMAGEPARAM	JUMP'	80$42$:	CALL	PLANPARAM	JUMP'	80$43$:	CALL	GENCARPARAM	JUMP'	80$44$:	CALL	COLORPARAM;	JUMP'	80$80$:	POP.L	A6	TEST.W	D7		; retour EQ/NE	RET;---------------\\; _LIST_VISUUSER >;===============/; Donne le pointeur  une petite zone de variables (16 bytes); libre pour l'utilisateur.; in	D2.L	#VISU_USER;	D6.L	canal;	A0.L	^descripteur de la fentre; out	A4.L	^16 bytes libres pour l'utilisateur;	D7.W	erreur; mod	D7.W, A4.L_LIST_VISUUSER:	PUSH.L	A6	LOAD.W	D7,#ERILCH	TEST.L	D6	JUMP',EQ 80$	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	A4,#(A6)+OHVUSE	; A4 <-- ^petite zone pour l'utilisateur	CLR.W	D7		; D7 <-- ok80$:	POP.L	A6	TEST.W	D7		; retour EQ/NE	RET;---------------\\; _LIST_VISUHEAD >;===============/; Donne le pointeur  l'en-tte.; in	D2.L	#VISU_HEAD;	D6.L	canal;	A0.L	^descripteur de la fentre; out	A4.L	^en-tte, si image => (A4)+OIMxxx; out	D3.W	type (0=text, 1=image, 2=plan, 3=genc, 4=color);	D7.W	erreur; mod	D3.L, D7.W, A4.L_LIST_VISUHEAD:	PUSH.L	A6	LOAD.W	D7,#ERILCH	TEST.L	D6	JUMP',EQ 80$	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	A4,#(A6)+OHVHD	; A4 <-- ^en-tte	LOAD.W	D3,(A6)+OHVTYP	; D3 <-- type	CLR.W	D7		; D7 <-- ok80$:	POP.L	A6	TEST.W	D7		; retour EQ/NE	RET;----------------\\; _LIST_VISULUTIN >;================/; Modifie v. le lutin de la souris en fonction de sa position.; in	D2.L	#VISU_LUTIN;	D6.L	canal;	A0.L	^descripteur de la fentre; out	D7.W	erreur; mod	D7.W_LIST_VISULUTIN:	PUSH.L	A6	LOAD.W	D7,#ERILCH	TEST.L	D6	JUMP',EQ 80$	LOAD.L	A6,D6		; A6 <-- ^variables	TEST.W	(A6)+OHVERR	; y a-t-il eu une erreur ?	JUMP',NE 80$		; oui => 80$	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche tout ?	JUMP',BS 80$	TEST.W	(A6)+OHVASV+OSCHTV	JUMP',NE 20$	TEST.W	(A6)+OHVASH+OSCHTV	JUMP',EQ 80$20$:	CALL	BASELUTIN	; modifie v. le lutin de la souris80$:	POP.L	A6	TEST.W	D7		; retour EQ/NE	RET;---------------\\; _LIST_VISUDRAW >;===============/; Dessine le canevas, sans le contenu.; Cet appel est ncessaire avant LIST_VISUUPDATE ou LIST_VISUMOVE !; in	D2.L	#VISU_DRAW + mode (BLIVDxxx);	D6.L	canal;	D3.L	origine coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	A0.L	^descripteur de la fentre; out	D7.W	erreur; mod	D7.W_LIST_VISUDRAW:	PUSHM.L	D1,A6	LOAD.W	D7,#ERILCH	TEST.L	D6	JUMP',EQ 80$	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	(A6)+OHVPOS,D3	; OHVPOS <-- coin sup/gauche	LOAD.L	(A6)+OHVDIM,D4	; OHVDIM <-- dimensions	LOAD.L	(A6)+OHVMOD,D2	; OHVMOD <-- mode	LOAD.L	D1,#2!2^16!2^17	COMP.W	(A6)+OHVTYP,#TYPIMAGE	JUMP',EQ 40$	COMP.W	(A6)+OHVTYP,#TYPCOLOR	JUMP',EQ 40$	LOAD.L	D1,#2	COMP.W	(A6)+OHVTYP,#TYPPLAN	JUMP',EQ 40$	LOAD.L	D1,#3	COMP.W	(A6)+OHVTYP,#TYPGENCAR	JUMP',EQ 40$	LOAD.L	D1,#1!2^1640$:	CALL	BASEDRAW	; hop, routine commune80$:	POPM.L	D1,A6	TEST.W	D7		; retour EQ/NE	RET;-----------------\\; _LIST_VISUUPDATE >;=================/; Dessine ou met  jour le contenu.; in	D2.L	#VISU_UPDATE + mode (BLIVUxxx);	D6.L	canal;	D3.L	position relative -FACPOSR..0..+FACPOSR (y;x);	A0.L	^descripteur de la fentre; out	D7.W	erreur; mod	D7.W_LIST_VISUUPDATE:	PUSH.L	A6	LOAD.W	D7,#ERILCH	TEST.L	D6	JUMP',EQ 80$	LOAD.L	A6,D6		; A6 <-- ^variables	TEST.L	D2:#BLIVUNPOS	JUMP',BS 10$	LOAD.L	(A6)+OHVPOR,D3	; OHVPOR <-- position relative10$:	LOAD.L	(A6)+OHVMOU,D2	; OHVMOU <-- mode	TEST.W	(A6)+OHVERR	; y a-t-il eu une erreur ?	JUMP',NE 60$		; oui => 60$	COMP.W	(A6)+OHVTYP,#TYPIMAGE	JUMP',EQ 41$	COMP.W	(A6)+OHVTYP,#TYPPLAN	JUMP',EQ 42$	COMP.W	(A6)+OHVTYP,#TYPGENCAR	JUMP',EQ 43$	COMP.W	(A6)+OHVTYP,#TYPCOLOR	JUMP',EQ 44$	CALL	ASCIIUPDATE	JUMP'	80$41$:	CALL	IMAGEUPDATE	JUMP'	80$42$:	CALL	PLANUPDATE	JUMP'	80$43$:	CALL	GENCARUPDATE	JUMP'	80$44$:	CALL	COLORUPDATE	JUMP'	80$60$:	CALL	VISUERR		; affiche l'erreur80$:	POP.L	A6	TEST.W	D7		; retour EQ/NE	RET;---------------\\; _LIST_VISUMOVE >;===============/; Dplace le contenu, avec la souris.; in	D2.L	#VISU_MOVE;	D6.L	canal;	D4.L	position de la souris (y;x);	A0.L	^descripteur de la fentre; out	D3.L	position relative -FACPOSR..0..+FACPOSR (y;x);	D7.W	erreur; mod	D3.L, D7.W_LIST_VISUMOVE:	PUSH.L	A6	LOAD.W	D7,#ERILCH	TEST.L	D6	JUMP',EQ 80$	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.W	D7,#ERDIOUT	TEST.W	(A6)+OHVERR	; y a-t-il eu une erreur ?	JUMP',NE 80$		; oui => 80$	COMP.W	(A6)+OHVTYP,#TYPIMAGE	JUMP',EQ 41$	COMP.W	(A6)+OHVTYP,#TYPPLAN	JUMP',EQ 42$	COMP.W	(A6)+OHVTYP,#TYPGENCAR	JUMP',EQ 43$	COMP.W	(A6)+OHVTYP,#TYPCOLOR	JUMP',EQ 44$	CALL	ASCIIMOVE	JUMP'	70$41$:	CALL	IMAGEMOVE	JUMP'	70$42$:	CALL	PLANMOVE	JUMP'	70$43$:	CALL	GENCARMOVE	JUMP'	70$44$:	CALL	COLORMOVE;	JUMP'	70$70$:	LOAD.L	D3,(A6)+OHVPOR	; D3 <-- position relative80$:	POP.L	A6	TEST.W	D7		; retour EQ/NE	RET;---------------\\; _LIST_VISUINFO >;===============/; Dessine ou met  jour les informations.; in	D2.L	#VISU_INFO + mode (BLIVIxxx);	D6.L	canal;	A0.L	^descripteur de la fentre; out	D7.W	erreur; mod	D7.W_LIST_VISUINFO:	PUSHM.L	D3,D4,A6	LOAD.W	D7,#ERILCH	TEST.L	D6	JUMP,EQ 90$	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	(A6)+OHVMOI,D2	; OHVMOI <-- mode	TEST.W	(A6)+OHVERR	; y a-t-il eu une erreur ?	JUMP,NE 90$		; oui => 90$	TEST.B	(A6)+OHVMOD+2:#BLIVDINFO-8 ; affiche les informations ?	JUMP,BC 90$		; non => 90$	LOAD.L	D3,(A6)+OHVPOS	; D3 <-- position	LOAD.L	D4,(A6)+OHVDIM	; D4 <-- dimensions	CALL	WDOOPEN		; ouvre sous-fentre	LIB	?AFTIM	.B	NOCURS		; plus de curseur	.B	NOEFLI		; pas de EFLI automatique	.B	TRUNC		; tronque les lignes trop longues	.B	0	.EVEN	LOAD.W	D3,#MARIFY	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	CLR.W	D3	LIB	?SETCURS	; positionne le curseur	COMP.W	(A6)+OHVTYP,#TYPIMAGE	JUMP',EQ 41$	COMP.W	(A6)+OHVTYP,#TYPPLAN	JUMP',EQ 42$	COMP.W	(A6)+OHVTYP,#TYPGENCAR	JUMP',EQ 43$	COMP.W	(A6)+OHVTYP,#TYPCOLOR	JUMP',EQ 44$	CALL	ASCIIINFO	JUMP'	80$41$:	CALL	IMAGEINFO	JUMP'	80$42$:	CALL	PLANINFO	JUMP'	80$43$:	CALL	GENCARINFO	JUMP'	80$44$:	CALL	COLORINFO;	JUMP'	80$80$:	PUSH.W	D7	CALL	WDOCLOSE	; ferme sous-fentre	POP.W	D790$:	POPM.L	D3,D4,A6	TEST.W	D7		; retour EQ/NE	RET;----------------\\; _LIST_VISUCLOSE >;================/; Libre la mmoire utilise par un fichier.; in	D2.L	#VISU_CLOSE;	D6.L	canal;	A0.L	^descripteur de la fentre; out	D7.W	erreur; mod	D7.W_LIST_VISUCLOSE:	PUSHM.L	D1,A4,A6	LOAD.W	D7,#ERILCH	TEST.L	D6	JUMP',EQ 90$	LOAD.L	A6,D6		; A6 <-- ^variables	COMP.W	(A6)+OHVTYP,#TYPIMAGE	JUMP',EQ 41$	COMP.W	(A6)+OHVTYP,#TYPPLAN	JUMP',EQ 42$	COMP.W	(A6)+OHVTYP,#TYPGENCAR	JUMP',EQ 43$	COMP.W	(A6)+OHVTYP,#TYPCOLOR	JUMP',EQ 44$	CALL	ASCIICLOSE	JUMP'	80$41$:	CALL	IMAGECLOSE	JUMP'	80$42$:	CALL	PLANCLOSE	JUMP'	80$43$:	CALL	GENCARCLOSE	JUMP'	80$44$:	CALL	COLORCLOSE;	JUMP'	80$80$:	CALL	IMAGECLMOD	; ferme le module STRETCH	CALL	PLANCLMOD	; ferme le module PLANA	LOAD.L	A4,A6		; A4 <-- ^variables	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire des variables90$:	POPM.L	D1,A4,A6	TEST.W	D7		; D7 <-- retour EQ/NE	RET;---------------\\; _LIST_VISUTYPE >;===============/; Cherche le type d'un fichier selon son extension.; Toutes les extensions qui ne sont pas des images, des plans; ou des gencars sont considres comme du texte !; in	A3.L	^nom de fichier; out	D3.W	type (0=text, 1=image, 2=plan, 3=genc, 4=color); mod	D3.L, D7.W_LIST_VISUTYPE:	PUSHM.L	A2..A4	LOAD.L	A4,A3	LOAD.L	A2,#R16"TERM$	LOAD.W	D3,#TYPIMAGE	LOAD.L	A3,#R16"IMAGE$	LIB	?CPSTRING	JUMP',NC 90$	LOAD.W	D3,#TYPPLAN	LOAD.L	A3,#R16"PLAN$	LIB	?CPSTRING	JUMP',NC 90$	LOAD.W	D3,#TYPGENCAR	LOAD.L	A3,#R16"GENC$	LIB	?CPSTRING	JUMP',NC 90$	LOAD.W	D3,#TYPCOLOR	LOAD.L	A3,#R16"COLOR$	LIB	?CPSTRING	JUMP',NC 90$	CLR.W	D390$:	POPM.L	A2..A4	RETIMAGE$:	.ASCIZ	"*.IMAGE"PLAN$:	.ASCIZ	"*.PLAN"GENC$:	.ASCIZ	"*.GENC"COLOR$:	.ASCIZ	"*.COLOR"TERM$:	.B	0,'|,-1	.EVEN;---------\\; VISUERR  >;---------/; Affiche un message d'erreur au milieu de la fentre.; in	-; out	-; mod	D7.WVISUERR:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,#R16"SYNT$	LOAD.W	D7,(A6)+OHVERR	; D7 <-- erreur rencontre	COMP.W	D7,#ERSYNT	JUMP',EQ 30$	LOAD.L	A4,#(A6)+OHVBUF	; A4 <-- ^buffer	CLR.W	D2		; D2 <-- mode	LOAD.W	D3,#26		; D3 <-- nb max de caractres	LOAD.W	D4,#1		; D4 <-- nb max de lignes	FOS	?XERROR		; OHVBUF <-- message d'erreur30$:	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.L	A3,A4	CALL	VISUTEXT	; affiche le message	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	POPM.L	D2..D4,A3,A4	RETSYNT$:	.ASCIZ	"Affichage impossible"	.EVEN;---------\\; VISUWAIT >;---------/; Affiche "Attendez ..." au milieu de la fentre.; in	-; out	-; mod	D7.WVISUWAIT:	PUSH.L	A3	LOAD.L	A3,#R16"TEXT$	CALL	VISUTEXT	POP.L	A3	RETTEXT$:	.ASCIZ	" Attendez un instant ..."	.EVEN;---------\\; VISUTEXT >;---------/; Affiche un texte (termin par zro) au milieu de la fentre.; in	A3.L	^texte (.ASCIZ); out	-; mod	D7.WVISUTEXT:	PUSHM.L	D2..D4,A3,A4	CALL	WAITMOUSE	; souris: met le sablier	TEST.B	(A6)+OHVMOD+1:#BLIVDMSET-16 ; mode SETDOT ?	JUMP',BS 90$	TEST.B	(A6)+OHVMOD+1:#BLIVDMCLR-16 ; mode CLRDOT ?	JUMP',BS 90$	TEST.B	(A6)+OHVMOD+1:#BLIVDMINV-16 ; mode INVDOT ?	JUMP',BS 90$	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfinit trame pour effacer	LOAD.L	D3,(A6)+OHVPOF	; D3 <-- position	LOAD.L	D4,(A6)+OHVDIF	; D4 <-- dimensions	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface tout	LOAD.L	A4,A3	LOAD.W	D2,#-120$:	INC.W	D2		; D2 <-- nb de caractre du texte	TEST.B	(A4+)	JUMP,NE 20$	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	LOAD.W	D4,D2	MUL.WU	D4,(A0)+ODFCX	SR.W	D4,#1	SUB.W	D3,D4	COMP.W	D3,(A6)+OHVPOF+2	JUMP',LO 90$	LIB	?SETCURS	LOAD.W	D3,D2	LIB	?STRING		; affiche le texte90$:	POPM.L	D2..D4,A3,A4	RET; Gestion des images; ------------------;----------\\; IMAGEOPEN >;----------/; Lit une image sur disque, sans l'afficher.; in	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WIMAGEOPEN:	PUSHM.L	D0..D4,D6,A1..A4	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE 90$	LOAD.L	A4,#(A6)+OHVHD	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; OHVHD <-- lit l'en-tte	JUMP,NE 82$	COMP.B	(A6)+OHVHD+OIMTYP,#H'82 ; image du LAMI ?	JUMP',NE 20$		; non => 20$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute la stupide en-tte de 256 bytes !	JUMP,NE 82$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$20$:	CLR.B	(A6)+OHVHD+OIMINV ; image positive	LOAD.W	D0,(A6)+OHVHD+OIMDLX ; D0 <-- largeur de l'image	LOAD.W	D1,(A6)+OHVHD+OIMDLY ; D1 <-- hauteur de l'image	LOAD.W	D4,D0	ADD.W	D4,#8-1	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF+4	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE 82$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	(A6)+OHVPT,A1	; OHVPT <-- ^data de l'image	LOAD.L	D4,(A6)+OHVHD+OIMNBB ; D4 <-- longueur  lire	TEST.B	(A6)+OHVHD+OIMCOD ; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP',NE 80$	JUMP'	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 80$	LOAD.L	A3,A1	LOAD.L	A2,#(A6)+OHVHD	; A2 <-- ^en-tte image	PUSH.B	(A2)+OIMCOD	PUSH.L	(A2)+OIMNBB	GRA_	DECOIMA		; dcode l'image ...	POP.L	(A2)+OIMNBB	POP.B	(A2)+OIMCOD	TEST.W	D7	JUMP',NE 80$35$:	FOS	?CLOSE		; ferme l'image	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	CLR.L	(A6)+OHVPT	; OHVPT <-- pas de data	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D790$:	POPM.L	D0..D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IMAGEPARAM >;-----------/; Donne quelques paramtres.; in	-; out	D3.L	position relative par dfaut;	D4.L	fanions par dfaut (BLIVUxxxx);	A4.L	^textes des options (tout<0>ngatif<0>divers<0>);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A4.LIMAGEPARAM:	CLR.L	D3	CLR.L	D4	TEST.B	(A0)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP',BS 20$		; oui => 20$	TSET.L	D4:#BLIVUOPT2	; D4 <-- ngatif20$:	LOAD.L	A4,#R16"OP$	CLR.W	D7		; D7 <-- ok	RETOP$:	.ASCIZ	"tout    "	.ASCIZ	"ngatif "	.ASCIZ	"          "	.B	0	.EVEN;------------\\; IMAGEUPDATE >;------------/; Met  jour l'affichage de l'image, des ascenseurs, etc.; Les informations ne sont pas mises  jour !; in	-; out	D7.W	erreur; mod	D7.WIMAGEUPDATE:	PUSHM.L	D2..D4,A5	CALL	IMAGESHOW	; affiche l'image	TEST.B	(A6)+OHVMOD+2:#BLIVDASC-8 ; utilise les ascenseurs ?	JUMP,BC 90$		; non => 90$	LOAD.L	A5,#(A6)+OHVASV	; A5 <-- ^variables ascenseur vertical	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche toute l'image ?	JUMP',BS 20$	LOAD.W	D4,(A6)+OHVHD+OIMDLY ; D4 <-- hauteur de l'image	COMP.W	D4,(A6)+OHVDIF+0	JUMP',LS 20$	LOAD.W	(A5)+OSCHTV,#FACPOSR*2	LOAD.W	(A5)+OSCINC,#(FACPOSR*2)/50	CALL	PUTPOSV		; OSCPOSV <-- OHVPOR	SCROLL_	UPDATE		; dessine l'ascenseur vertical plein	JUMP'	40$20$:	TEST.W	(A5)+OSCHTV	; ascenseur dj vide ?	JUMP',EQ 40$		; oui => 40$	CLR.W	(A5)+OSCHTV	SCROLL_	DRAW		; dessine l'ascenseur vertical vide40$:	LOAD.L	A5,#(A6)+OHVASH	; A5 <-- ^variables ascenseur horizontal	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche toute l'image ?	JUMP',BS 60$	LOAD.W	D4,(A6)+OHVHD+OIMDLX ; D4 <-- largeur de l'image	COMP.W	D4,(A6)+OHVDIF+2	JUMP',LS 60$	LOAD.W	(A5)+OSCHTV,#FACPOSR*2	LOAD.W	(A5)+OSCINC,#(FACPOSR*2)/50	CALL	PUTPOSV		; OSCPOSV <-- OHVPOR	SCROLL_	UPDATE		; dessine l'ascenseur horizontal plein	JUMP'	90$60$:	TEST.W	(A5)+OSCHTV	; ascenseur dj vide ?	JUMP',EQ 90$		; oui => 90$	CLR.W	(A5)+OSCHTV	SCROLL_	DRAW		; dessine l'ascenseur horizontal vide90$:	POPM.L	D2..D4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGEMOVE >;----------/; Dplace ventuellement l'image.; in	D4.L	position de la souris (y;x); out	D7.W	erreur (trop petit); mod	D7.WIMAGEMOVE:	PUSH.L	A2	LOAD.L	A2,#R16"IMAGESHOW	CALL	BASEMOVEA	; dplace les ascenseurs ...	JUMP',EQ 90$	LOAD.L	A2,#R16"IMAGEUPDATE	CALL	BASEMOVEM	; dplace le contenu ...90$:	POP.L	A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGESHOW >;----------/; Affiche une image dans la fentre.; in	-; out	D7.W	erreur; mod	D7.WIMAGESHOW:	PUSHM.L	D0..D4,A3,A4	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT2-8 ; affiche en ngatif ?	JUMP',BS 10$				; positif =>	TEST.B	(A6)+OHVHD+OIMINV ; image ngative ?	JUMP',F 15$		; non => 15$	CALL	IMAGEINV	; remet l'image en positif	JUMP'	15$10$:				; ngatif =>	TEST.B	(A6)+OHVHD+OIMINV ; image ngative ?	JUMP',T 15$		; oui => 15$	CALL	IMAGEINV	; met l'image en ngatif15$:	LOAD.L	A4,(A6)+OHVPT	; A4 <-- ^image	LOAD.W	D0,(A6)+OHVHD+OIMDLX ; D0 <-- largeur de l'image	LOAD.W	D1,(A6)+OHVHD+OIMDLY ; D1 <-- hauteur de l'image	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche toute l'image ?	JUMP',BC 20$		; non => 20$				; oui =>	CALL	VISUWAIT	; affiche "attendez ..."	CALL	IMAGEOPMOD	; ouvre le module "stretch"	JUMP',NE 90$	CALL	IMAGESTR	; A4/D0/D1 <-- ^image/dx/dy "stretch"	JUMP',NE 90$20$:	CALL	BASECLEAR	; efface v. le dessous	CALL	IMAGEAFF	; affiche l'image	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche toute l'image ?	JUMP',BC 80$	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire de l'image "stretche"80$:	CLR.W	D7		; D7 <-- ok90$:	PUSH.W	D7	CALL	NORMMOUSE	; souris: enlve le sablier	POP.W	D7	POPM.L	D0..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; IMAGEINV >;---------/; Inverse toute la matrice d'une image.; in	-; out	-; mod	D7.WIMAGEINV:	PUSHM.L	D0,D1,A1	LOAD.L	A1,(A6)+OHVPT	; A1 <-- ^data de l'image	LOAD.W	D1,(A6)+OHVHD+OIMDLX ; D1 <-- largeur de l'image	MUL.WU	D1,(A6)+OHVHD+OIMDLY ; D1 <-- nb de points de l'image	SR.L	D1,#3		; D1 <-- /8 car en bytes	LOAD.W	D0,D1	AND.W	D0,#B'11111	SR.L	D1,#5		; D1 <-- /32 car par 8x.L	DEC.W	D1	JUMP',NS 22$20$:	NOT.L	(A1+)		; inverse 32 bytes	NOT.L	(A1+)	NOT.L	(A1+)	NOT.L	(A1+)	NOT.L	(A1+)	NOT.L	(A1+)	NOT.L	(A1+)	NOT.L	(A1+)	DECJ.W,NMO D1,20$22$:	DEC.W	D0	JUMP',NS 32$30$:	NOT.B	(A1+)	DECJ.W,NMO D0,30$32$:	NOT.B	(A6)+OHVHD+OIMINV ; inverse la positivit de l'image	POPM.L	D0,D1,A1	RET;---------\\; IMAGESTR >;---------/; Dforme l'image pour quelle entre dans la fentre d'affichage.; in	-; out	D0.W	largeur de l'image;	D1.W	hauteur de l'image;	A4.L	^image;	D7.W	erreur; mod	D0.L, D1.L, D7.W, A4.LIMAGESTR:	PUSHM.L	D4,A0	LOAD.W	D0,(A6)+OHVDIF+2 ; D0 <-- largeur	LOAD.W	D1,(A6)+OHVDIF+0 ; D1 <-- hauteur	LOAD.W	D4,D1	MUL.WU	D4,(A6)+OHVHD+OIMDLX	DIV.WU	D4,(A6)+OHVHD+OIMDLY	COMP.W	D4,D0	JUMP',HI 12$	LOAD.W	D0,D4		; D0 <-- conserve les proportions	JUMP'	14$12$:	LOAD.W	D1,D0	MUL.WU	D1,(A6)+OHVHD+OIMDLY	DIV.WU	D1,(A6)+OHVHD+OIMDLX ; D1 <-- conserve les proportions14$:	ADD.W	D0,#8-1	AND.B	D0,#B'11111000	; D0 <-- largeur modulo 8	LOAD.W	D4,D0	MUL.WU	D4,D1		; D4 <-- taille en points	SR.L	D4,#3		; D4 <-- taille en bytes	ADD.L	D4,#4		; D4 <-- rserve psychologique (bof)	PUSH.L	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour image "stretche"	POPM.L	D1	JUMP,NE 90$	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A0,A4	SR.L	D4,#2		; D4 <-- /4 car par .L30$:	CLR.L	(A0+)		; efface toute la mmoire	DEC.L	D4	JUMP,NE 30$	LOAD.L	A0,#(A6)+OHVBUF	; A0 <-- ^variables pour le module stretch	CLR.W	(A0)+OSTRTYP	CLR.W	(A0)+OSTROP	LOAD.L	(A0)+OSTRSPT,(A6)+OHVPT ; ^source	LOAD.W	D4,(A6)+OHVHD+OIMDLX	SR.W	D4,#3	LOAD.W	(A0)+OSTRSDX,D4	CLR.L	(A0)+OSTRS0	LOAD.W	(A0)+OSTRS2+2,(A6)+OHVHD+OIMDLX	LOAD.W	(A0)+OSTRS2+0,(A6)+OHVHD+OIMDLY	LOAD.L	(A0)+OSTRDPT,A4	; ^destination	LOAD.W	D4,D0	SR.W	D4,#3	LOAD.W	(A0)+OSTRDDX,D4	CLR.L	(A0)+OSTRD0	LOAD.W	(A0)+OSTRD1+2,D0	CLR.W	(A0)+OSTRD1+0	LOAD.W	(A0)+OSTRD2+2,D0	LOAD.W	(A0)+OSTRD2+0,D1	CLR.W	(A0)+OSTRD3+2	LOAD.W	(A0)+OSTRD3+0,D1	ST_	RECT		; paf, on dforme ...	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A0	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IMAGEOPMOD >;-----------/; Ouvre le module "stretch".; in	-; out	D7.W	erreur; mod	D7.WIMAGEOPMOD:	PUSHM.L	D1,D3,A3	CLR.W	D7		; D7 <-- ok	COMP.W	(A6)+OHVCHS,#-1	JUMP',NE 90$	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#R16"NMSTRET	LOAD.W	D3,#ST_FIRST	LIB_	OPEN	JUMP',NE 90$	LOAD.W	(A6)+OHVCHS,D190$:	POPM.L	D1,D3,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IMAGECLMOD >;-----------/; Ferme le module "stretch".; in	-; out	-; mod	D7.WIMAGECLMOD:	PUSH.W	D1	COMP.W	(A6)+OHVCHS,#-1	JUMP',EQ 90$	LOAD.W	D1,(A6)+OHVCHS	LIB_	CLOSE	LOAD.W	(A6)+OHVCHS,#-190$:	POP.W	D1	RET;---------\\; IMAGEAFF >;---------/; Affiche une image quelconque.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie centrale.; in	D0.W	largeur de l'image;	D1.W	hauteur de l'image;	A4.L	^image; out	-; mod	D7.WIMAGEAFF:	PUSHM.L	D0..D4,A3	LOAD.L	A3,#(A6)+OHVBUF+1 ; A3 <-- ^buffer pour DRAWRASTER	LOAD.W	D3,D0	SR.W	D3,#3	LOAD.W	(A3)+9,D3	; source: <ii>	CLR.W	(A3)+19		; destination: <ii>	LOAD.L	D4,(A6)+OHVPOF	SWAP.W	D4	LOAD.L	(A3)+11,D4	; destination: <xx> et <yy>	LOAD.L	D4,(A6)+OHVDIF	; D4 <-- dimensions	COMP.W	D0,D4		; image trop large ?	JUMP',HI 50$		; oui => 50$	CLR.W	(A3)+1		; source: <xx>	LOAD.W	(A3)+21,D0	; image: <dxx>	SUB.W	D4,D0	SR.W	D4,#1	ADD.W	(A3)+11,D4	; destination: <xx>	JUMP'	55$50$:	LOAD.W	(A3)+21,D4	; image: <dxx>	SUB.W	D0,D4	SR.W	D0,#1	LOAD.W	D3,(A6)+OHVPOR+2	MUL.WA	D3,D0	DIV.WA	D3,#FACPOSR	ADD.W	D3,D0	JUMP',NC 52$	CLR.W	D352$:	SL.W	D0,#1	COMP.W	D3,D0	JUMP',LS 53$	LOAD.W	D3,D053$:	LOAD.W	(A3)+1,D3	; source: <xx>55$:	SWAP.W	D4	COMP.W	D1,D4		; image trop haute ?	JUMP',HI 60$		; oui => 60$	CLR.W	(A3)+3		; source: <yy>	LOAD.W	(A3)+23,D1	; image: <dyy>	SUB.W	D4,D1	SR.W	D4,#1	ADD.W	(A3)+13,D4	; destination: <yy>	JUMP'	65$60$:	LOAD.W	(A3)+23,D4	; image: <dyy>	SUB.W	D1,D4	SR.W	D1,#1	LOAD.W	D3,(A6)+OHVPOR+0	MUL.WA	D3,D1	DIV.WA	D3,#FACPOSR	ADD.W	D3,D1	JUMP',NC 62$	CLR.W	D362$:	SL.W	D1,#1	COMP.W	D3,D1	JUMP',LS 63$	LOAD.W	D3,D163$:	LOAD.W	(A3)+3,D3	; source: <yy>65$:	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+5,A4	; source: <pppp>	CLR.L	(A3)+15		; destination: <pppp>	LOAD.B	D2,#SETDOT	TEST.B	(A6)+OHVMOD+1:#BLIVDMSET-16 ; mode SETDOT ?	JUMP',BS 70$	LOAD.B	D2,#CLRDOT	TEST.B	(A6)+OHVMOD+1:#BLIVDMCLR-16 ; mode CLRDOT ?	JUMP',BS 70$	LOAD.B	D2,#INVDOT	TEST.B	(A6)+OHVMOD+1:#BLIVDMINV-16 ; mode INVDOT ?	JUMP',BS 70$	LOAD.B	D2,#LOADDOT70$:	LOAD.B	(A3)+25,D2	; image: <mode>	LOAD.W	D3,#26		; D3 <-- longueur	LIB	?STRING		; affiche l'image	POPM.L	D0..D4,A3	RET;----------\\; IMAGEINFO >;----------/; Met  jour quelques informations sur une image.; in	-; out	-; mod	D7.WIMAGEINFO:	PUSHM.L	D0..D4,A3	LIB	?AFTIM	.ASCIZ	"  Nom de l'image: "	.EVEN	TEST.B	(A6)+OHVMOI+2:#BLIVIINV-8 ; nom en inverse ?	JUMP',BC 10$		; non => 10$	LOAD.B	D3,#AFINV	; oui =>	LIB	?AFCAR		; affiche en vido-inverse10$:	LOAD.L	A3,#(A6)+OHVNAM	LIB	?AFFILE		; affiche le nom de l'image	LIB	?AFTIM	.ASCIZ	"<AFDIR><CR>  Dimensions: "	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OHVHD+OIMDLX	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"x"	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OHVHD+OIMDLY	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"      Image "	.EVEN	CLR.L	D4	LOAD.B	D4,(A6)+OHVHD+OIMCOD	JUMP',NE 50$	LIB	?AFTIM	.ASCIZ	"pas code<CR>"	.EVEN	JUMP	90$50$:	LIB	?AFTIM	.ASCIZ	"code (#"	.EVEN	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	")    Gain de place: "	.EVEN	LOAD.L	D0,(A6)+OHVHD+OIMNBB ; D0 <-- longueur avec codage	LOAD.W	D1,(A6)+OHVHD+OIMDLX	MUL.WU	D1,(A6)+OHVHD+OIMDLY	SR.L	D1,#3		; D1 <-- longueur sans codage	SUB.L	D1,D0		; D1 <-- longueur gagne par le codage	CALL	CALCPOURCENT	; D4 <-- 0..100	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"%<CR>"	.EVEN90$:	POPM.L	D0..D4,A3	RET;-----------\\; IMAGECLOSE >;-----------/; Libre la mmoire utilise par une image.; in	-; out	-; mod	D7.WIMAGECLOSE:	PUSHM.L	D1,A4	TEST.L	(A6)+OHVPT	JUMP',EQ 90$	LOAD.L	A4,(A6)+OHVPT	LOAD.L	A4,#(A4)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	CLR.L	(A6)+OHVPT	; OHVPT <-- pas de data90$:	POPM.L	D1,A4	RET; Gestion des images couleurs; ---------------------------;----------\\; COLOROPEN >;----------/; Lit une image sur disque, sans l'afficher.; in	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WCOLOROPEN:	PUSHM.L	D0..D6,A1..A4	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE 90$	LOAD.L	A4,#(A6)+OHVHD	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; OHVHD <-- lit l'en-tte	JUMP,NE 82$	LOAD.W	D0,(A6)+OHVHD+OIMDLX ; D0 <-- largeur de l'image	LOAD.W	D1,(A6)+OHVHD+OIMDLY ; D1 <-- hauteur de l'image	LOAD.W	D4,D0	ADD.W	D4,#8-1	SR.W	D4,#3	CLR.W	D5	LOAD.B	D5,(A6)+OHVHD+OIMBIP ; D5 <-- nb de bits/pixel	MUL.WU	D4,D5	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,(A6)+OHVHD+OIMLGC ; D4 <-- rserve pour la CLUT	ADD.L	D4,#IMLBUF+4	; D4 <-- rserve pour codage	PUSH.L	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.L	D1	JUMP,NE 82$	LOAD.L	A1,A4	ADD.L	A1,(A6)+OHVHD+OIMLGC	LOAD.L	A1,#(A1)+IMLBUF	; A1 <-- ^image	LOAD.L	(A6)+OHVPT,A1	; OHVPT <-- ^data de l'image	LOAD.L	D4,(A6)+OHVHD+OIMLGC ; D4 <-- lg de la CLUT	JUMP',EQ 20$	FOS	?RDBYTE		; lit la CLUT	JUMP,NE 80$20$:	LOAD.L	D4,(A6)+OHVHD+OIMNBB ; D4 <-- longueur  lire	TEST.B	(A6)+OHVHD+OIMCOD ; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP,NE 80$	JUMP'	35$30$:	LOAD.L	A4,#(A1)-IMLBUF	; A4 <-- ^o lire l'image	FOS	?RDBYTE		; lit toute l'image code	JUMP,NE 80$	LOAD.L	A3,A1	LOAD.L	A2,#(A6)+OHVHD	; A2 <-- ^en-tte image	PUSH.B	(A2)+OIMCOD	PUSH.B	(A2)+OIMBIP	PUSH.W	(A2)+OIMDLX	PUSH.L	(A2)+OIMNBB	LOAD.W	D4,(A2)+OIMDLX	MUL.WU	D4,D5		; OIMDLX <-- * nb bits/pixels	LOAD.W	(A2)+OIMDLX,D4	LOAD.B	(A2)+OIMBIP,#1	GRA_	DECOIMA		; dcode l'image couleur ...	POP.L	(A2)+OIMNBB	POP.W	(A2)+OIMDLX	POP.B	(A2)+OIMBIP	POP.B	(A2)+OIMCOD	TEST.W	D7	JUMP',NE 80$35$:	FOS	?CLOSE		; ferme l'image	TEST.L	(A6)+OHVHD+OIMLGC ; CLUT existe ?	JUMP',EQ 60$		; non => 60$	LOAD.W	D6,D5		; D6 <-- nb de bits/pixels	LOAD.W	D5,D0	ADD.W	D5,#8-1	SR.W	D5,#3	MUL.WU	D5,D6		; D5 <-- Iy image	CLR.L	D2		; D2 <-- mode	CLR.L	D3		; D3 <-- origine	LOAD.W	D4,D1		; D4 <-- hauteur de l'image	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- largeur de l'image	LOAD.L	A4,A1		; A4 <-- ^image couleur	LOAD.L	A3,#(A4)-IMLBUF	SUB.L	A3,(A6)+OHVHD+OIMLGC ; A3 <-- ^CLUT de l'image	ICOL_	CONVC		; conversion selon la CLUT active ...60$:	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	SUB.L	A4,(A6)+OHVHD+OIMLGC	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	CLR.L	(A6)+OHVPT	; OHVPT <-- pas de data	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D790$:	POPM.L	D0..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; COLORPARAM >;-----------/; Donne quelques paramtres.; in	-; out	D3.L	position relative par dfaut;	D4.L	fanions par dfaut (BLIVUxxxx);	A4.L	^textes des options (tout<0>ngatif<0>divers<0>);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A4.LCOLORPARAM:	CLR.L	D3	CLR.L	D4	LOAD.L	A4,#R16"OP$	CLR.W	D7		; D7 <-- ok	RETOP$:	.ASCIZ	"        "	.ASCIZ	"        "	.ASCIZ	"          "	.B	0	.EVEN;------------\\; COLORUPDATE >;------------/; Met  jour l'affichage de l'image, des ascenseurs, etc.; Les informations ne sont pas mises  jour !; in	-; out	D7.W	erreur; mod	D7.WCOLORUPDATE:	PUSHM.L	D2..D4,A5	CALL	COLORSHOW	; affiche l'image	TEST.B	(A6)+OHVMOD+2:#BLIVDASC-8 ; utilise les ascenseurs ?	JUMP,BC 90$		; non => 90$	LOAD.L	A5,#(A6)+OHVASV	; A5 <-- ^variables ascenseur vertical	LOAD.W	D4,(A6)+OHVHD+OIMDLY ; D4 <-- hauteur de l'image	COMP.W	D4,(A6)+OHVDIF+0	JUMP',LS 20$	LOAD.W	(A5)+OSCHTV,#FACPOSR*2	LOAD.W	(A5)+OSCINC,#(FACPOSR*2)/50	CALL	PUTPOSV		; OSCPOSV <-- OHVPOR	SCROLL_	UPDATE		; dessine l'ascenseur vertical plein	JUMP'	40$20$:	TEST.W	(A5)+OSCHTV	; ascenseur dj vide ?	JUMP',EQ 40$		; oui => 40$	CLR.W	(A5)+OSCHTV	SCROLL_	DRAW		; dessine l'ascenseur vertical vide40$:	LOAD.L	A5,#(A6)+OHVASH	; A5 <-- ^variables ascenseur horizontal	LOAD.W	D4,(A6)+OHVHD+OIMDLX ; D4 <-- largeur de l'image	COMP.W	D4,(A6)+OHVDIF+2	JUMP',LS 60$	LOAD.W	(A5)+OSCHTV,#FACPOSR*2	LOAD.W	(A5)+OSCINC,#(FACPOSR*2)/50	CALL	PUTPOSV		; OSCPOSV <-- OHVPOR	SCROLL_	UPDATE		; dessine l'ascenseur horizontal plein	JUMP'	90$60$:	TEST.W	(A5)+OSCHTV	; ascenseur dj vide ?	JUMP',EQ 90$		; oui => 90$	CLR.W	(A5)+OSCHTV	SCROLL_	DRAW		; dessine l'ascenseur horizontal vide90$:	POPM.L	D2..D4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; COLORMOVE >;----------/; Dplace ventuellement l'image.; in	D4.L	position de la souris (y;x); out	D7.W	erreur (trop petit); mod	D7.WCOLORMOVE:	PUSH.L	A2	LOAD.L	A2,#R16"COLORSHOW	CALL	BASEMOVEA	; dplace les ascenseurs ...	JUMP',EQ 90$	LOAD.L	A2,#R16"COLORUPDATE	CALL	BASEMOVEM	; dplace le contenu ...90$:	POP.L	A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; COLORSHOW >;----------/; Affiche une image couleur dans la fentre.; in	-; out	D7.W	erreur; mod	D7.WCOLORSHOW:	PUSHM.L	D0..D6,A2..A4	CALL	BASECLEAR	; efface v. le dessous	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,EQ NB$		; non => NB$	CALL	CCMO		; enlve la souris	LOAD.W	D0,(A6)+OHVHD+OIMDLX ; D0 <-- largeur de l'image	LOAD.W	D1,(A6)+OHVHD+OIMDLY ; D1 <-- hauteur de l'image	LOAD.W	D5,D0	ADD.W	D5,#8-1	SR.W	D5,#3	CLR.W	D6	LOAD.B	D6,(A6)+OHVHD+OIMBIP ; D6 <-- nb de bits/pixel	MUL.WU	D5,D6		; D5 <-- Iy source	LOAD.L	A3,(A6)+OHVPT	; A3 <-- ^source (image couleur)	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	LOAD.W	D4,(A6)+OHVDIF+0 ; D4 <-- hauteur	COMP.W	D1,D4		; image trop haute ?	JUMP',HI YLARG$		; oui => YLARG$	CLR.W	D3		; D3 <-- origine source	LOAD.W	D2,D1		; D2 <-- hauteur	SUB.W	D4,D1	SR.W	D4,#1	ADD.W	D4,(A6)+OHVPOF+0 ; D4 <-- origine destination	JUMP'	YEND$YLARG$:	LOAD.W	D2,D4		; D2 <-- hauteur	SUB.W	D1,D4	SR.W	D1,#1	LOAD.W	D6,(A6)+OHVPOR+0	MUL.WA	D6,D1	DIV.WA	D6,#FACPOSR	ADD.W	D6,D1	JUMP',NC YMIN$	CLR.W	D6YMIN$:	SL.W	D1,#1	COMP.W	D6,D1	JUMP',LS YMAX$	LOAD.W	D6,D1YMAX$:	LOAD.W	D3,D6		; D3 <-- origine source	LOAD.W	D4,(A6)+OHVPOF+0 ; D4 <-- origine destinationYEND$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,(A6)+OHVDIF+2 ; D4 <-- largeur	COMP.W	D0,D4		; image trop large ?	JUMP',HI XLARG$		; oui => XLARG$	CLR.W	D3		; D3 <-- origine source	LOAD.W	D2,D0		; D2 <-- largeur	SUB.W	D4,D0	SR.W	D4,#1	ADD.W	D4,(A6)+OHVPOF+2 ; D4 <-- origine destination	JUMP'	XEND$XLARG$:	LOAD.W	D2,D4		; D2 <-- largeur	SUB.W	D0,D4	SR.W	D0,#1	LOAD.W	D6,(A6)+OHVPOR+2	MUL.WA	D6,D0	DIV.WA	D6,#FACPOSR	ADD.W	D6,D0	JUMP',NC XMIN$	CLR.W	D6XMIN$:	SL.W	D0,#1	COMP.W	D6,D0	JUMP',LS XMAX$	LOAD.W	D6,D0XMAX$:	LOAD.W	D3,D6		; D3 <-- origine source	LOAD.W	D4,(A6)+OHVPOF+2 ; D4 <-- origine destinationXEND$:	LOAD.W	D1,#SETDOT!2^BSRCCOUL!2^BDSTCOUL	TEST.B	(A6)+OHVMOD+1:#BLIVDMSET-16 ; mode SETDOT ?	JUMP',BS MODE$	LOAD.W	D1,#CLRDOT!2^BSRCCOUL!2^BDSTCOUL	TEST.B	(A6)+OHVMOD+1:#BLIVDMCLR-16 ; mode CLRDOT ?	JUMP',BS MODE$	LOAD.W	D1,#INVDOT!2^BSRCCOUL!2^BDSTCOUL	TEST.B	(A6)+OHVMOD+1:#BLIVDMINV-16 ; mode INVDOT ?	JUMP',BS MODE$	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOULMODE$:	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	GRA_	CRASTER		; affiche l'image en couleurs	CALL	SCMO		; remet la souris	JUMP'	EXIT$NB$:	LOAD.L	A3,#R16"TEXT$	CALL	VISUTEXTEXIT$:	POPM.L	D0..D6,A2..A4	RETTEXT$:	.ASCIZ	"(image couleur)"	.EVEN;----------\\; COLORINFO >;----------/; Met  jour quelques informations sur une image.; in	-; out	-; mod	D7.WCOLORINFO:	PUSHM.L	D0..D4,A3	LIB	?AFTIM	.ASCIZ	"  Nom de l'image couleur : "	.EVEN	TEST.B	(A6)+OHVMOI+2:#BLIVIINV-8 ; nom en inverse ?	JUMP',BC 10$		; non => 10$	LOAD.B	D3,#AFINV	; oui =>	LIB	?AFCAR		; affiche en vido-inverse10$:	LOAD.L	A3,#(A6)+OHVNAM	LIB	?AFFILE		; affiche le nom de l'image	LIB	?AFTIM	.ASCIZ	"<AFDIR><CR>  Dimensions: "	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OHVHD+OIMDLX	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"x"	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OHVHD+OIMDLY	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"   "	.EVEN	CLR.W	D4	LOAD.B	D4,(A6)+OHVHD+OIMBIP	MUL.WU	D4,D4	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" couleurs    Image "	.EVEN	CLR.L	D4	LOAD.B	D4,(A6)+OHVHD+OIMCOD	JUMP',NE 50$	LIB	?AFTIM	.ASCIZ	"pas code<CR>"	.EVEN	JUMP	90$50$:	LIB	?AFTIM	.ASCIZ	"code (#"	.EVEN	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	")   Gain de place: "	.EVEN	LOAD.L	D0,(A6)+OHVHD+OIMNBB ; D0 <-- longueur avec codage	CLR.W	D1	LOAD.B	D1,(A6)+OHVHD+OIMBIP	MUL.WU	D1,(A6)+OHVHD+OIMDLX	SR.L	D1,#3	MUL.WU	D1,(A6)+OHVHD+OIMDLY ; D1 <-- longueur sans codage	SUB.L	D1,D0		; D1 <-- longueur gagne par le codage	CALL	CALCPOURCENT	; D4 <-- 0..100	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"%<CR>"	.EVEN90$:	POPM.L	D0..D4,A3	RET;-----------\\; COLORCLOSE >;-----------/; Libre la mmoire utilise par une image.; in	-; out	-; mod	D7.WCOLORCLOSE:	PUSHM.L	D1,A4	TEST.L	(A6)+OHVPT	JUMP',EQ 90$	LOAD.L	A4,(A6)+OHVPT	LOAD.L	A4,#(A4)-IMLBUF	SUB.L	A4,(A6)+OHVHD+OIMLGC	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	CLR.L	(A6)+OHVPT	; OHVPT <-- pas de data90$:	POPM.L	D1,A4	RET; Gestion des plans; -----------------;---------\\; PLANOPEN >;---------/; Lit un fichier sur disque, sans l'afficher.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WPLANOPEN:GENCAROPEN:	PUSHM.L	D1,D3,D4,D6,A4	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre le fichier	JUMP,NE 90$	LOAD.W	D3,#-1	LOAD.L	D4,#-1	FOS	?SPOS		; va tout  la fin	LOAD.L	D1,D4		; D1 <-- longueur du fichier	CLR.W	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP,NE 82$	LOAD.L	(A6)+OHVLG,D1	; OHVLG <-- longueur du fichier	LOAD.L	D4,D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour fichier complet	JUMP,NE 82$	LOAD.L	(A6)+OHVPT,A4	; OHVPT <-- ^data du fichier	FOS	?RDBYTE		; lit le fichier	JUMP',NE 80$	FOS	?CLOSE		; ferme le fichier	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	A4,(A6)+OHVPT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire du fichier	CLR.L	(A6)+OHVPT	; OHVPT <-- pas de data	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; PLANPARAM >;----------/; Donne quelques paramtres.; in	-; out	D3.L	position relative par dfaut;	D4.L	fanions par dfaut (BLIVUxxxx);	A4.L	^textes des options (tout<0>ngatif<0>divers<0>);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A4.LPLANPARAM:	CLR.L	D3	LOAD.L	D4,#2^BLIVUOPT1	; D4 <-- tout	LOAD.L	A4,#R16"OP$	CLR.W	D7		; D7 <-- ok	RETOP$:	.ASCIZ	"tout    "	.ASCIZ	"        "	.ASCIZ	"caractres"	.B	0	.EVEN;-----------\\; PLANUPDATE >;-----------/; Met  jour l'affichage du plan, des ascenseurs, etc.; Les informations ne sont pas mises  jour !; in	-; out	D7.W	erreur; mod	D7.WPLANUPDATE:	JUMP	PLANSHOW	; affiche le plan;---------\\; PLANMOVE >;---------/; Dplace ventuellement le plan.; in	D4.L	position de la souris (y;x); out	D7.W	erreur (trop petit); mod	D7.WPLANMOVE:	LOAD.W	D7,#ERDIOUT	TEST.W	D7		; retour EQ/NE	RET;---------\\; PLANSHOW >;---------/; Affiche un plan dans la fentre.; in	-; out	D7.W	erreur; mod	D7.WPLANSHOW:	PUSHM.L	D0..D6,A3,A4	CALL	WAITMOUSE	; souris: met le sablier	CALL	PLANOPMOD	; ouvre le module "plana"	JUMP,NE 90$	CALL	BASECLEAR	; efface v. le dessous	LIB	?GETWDO		; D5 <-- swdo actuelle	LOAD.L	A4,(A6)+OHVPT	; A4 <-- ^contenu du fichier .PLAN	LOAD.L	D0,(A6)+OHVLG	; D0 <-- longueur du fichier .PLAN	LOAD.L	D2,#2^BPLANCENV!2^BPLANCENH ; D2 <-- mode	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche toute l'image ?	JUMP',BC 30$	TSET.L	D2:#BPLANTOUT30$:	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT3-8 ; gencars rels ?	JUMP',BC 31$	TSET.L	D2:#BPLANLCAR31$:	COMP.W	(A6)+OHVPOR+0,#-FACPOSR/2	JUMP',GT 40$	TCLR.L	D2:#BPLANCENV	TSET.L	D2:#BPLANHAUT40$:	COMP.W	(A6)+OHVPOR+0,#+FACPOSR/2	JUMP',LT 41$	TCLR.L	D2:#BPLANCENV	TSET.L	D2:#BPLANBAS41$:	COMP.W	(A6)+OHVPOR+2,#-FACPOSR/2	JUMP',GT 42$	TCLR.L	D2:#BPLANCENH	TSET.L	D2:#BPLANGAUCHE42$:	COMP.W	(A6)+OHVPOR+2,#+FACPOSR/2	JUMP',LT 43$	TCLR.L	D2:#BPLANCENH	TSET.L	D2:#BPLANDROITE43$:	LOAD.L	D3,(A6)+OHVPOF	; D3 <-- position	LOAD.L	D4,(A6)+OHVDIF	; D4 <-- dimensions	ADD.W	D3,(A0)+ODFFX	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,(A0)+ODFFY	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	A3,#0		; A3 <-- pas d'informations	.W	PLAN_AFF	; affiche le plan ...	LIB	?USEWDO		; remet la swdo initiale	CLR.W	D7		; D7 <-- ok90$:	PUSH.W	D7	CALL	NORMMOUSE	; souris: enlve le sablier	POP.W	D7	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; PLANOPMOD >;----------/; Ouvre le module "plana".; in	-; out	D7.W	erreur; mod	D7.WPLANOPMOD:	PUSHM.L	D1,D3,A3	CLR.W	D7		; D7 <-- ok	COMP.W	(A6)+OHVCHP,#-1	JUMP',NE 90$	CALL	VISUWAIT	; affiche "attendez ..."	LOAD.L	A3,#R16"NMPLAN	LOAD.W	D3,#PLAN_FIRST	LIB_	OPEN	JUMP',NE 90$	LOAD.W	(A6)+OHVCHP,D190$:	POPM.L	D1,D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; PLANCLMOD >;----------/; Ferme le module "plana".; in	-; out	-; mod	D7.WPLANCLMOD:	PUSH.W	D1	COMP.W	(A6)+OHVCHP,#-1	JUMP',EQ 90$	LOAD.W	D1,(A6)+OHVCHP	LIB_	CLOSE	LOAD.W	(A6)+OHVCHP,#-190$:	POP.W	D1	RET;---------\\; PLANINFO >;---------/; Met  jour quelques informations sur un plan.; in	-; out	-; mod	D7.WPLANINFO:	PUSHM.L	D0..D4,A3	LIB	?AFTIM	.ASCIZ	"  Nom du plan: "	.EVEN	TEST.B	(A6)+OHVMOI+2:#BLIVIINV-8 ; nom en inverse ?	JUMP',BC 10$		; non => 10$	LOAD.B	D3,#AFINV	; oui =>	LIB	?AFCAR		; affiche en vido-inverse10$:	LOAD.L	A3,#(A6)+OHVNAM	LIB	?AFFILE		; affiche le nom du plan	LOAD.B	D3,#AFDIR	LIB	?AFCAR	POPM.L	D0..D4,A3	RET;----------\\; PLANCLOSE >;----------/;------------\\; GENCARCLOSE >;------------/;-----------\\; ASCIICLOSE >;-----------/; Libre la mmoire utilise par un fichier.; in	-; out	-; mod	D7.WPLANCLOSE:GENCARCLOSE:ASCIICLOSE:	PUSHM.L	D1,A4	TEST.L	(A6)+OHVPT	JUMP',EQ 90$	LOAD.L	A4,(A6)+OHVPT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire du fichier	CLR.L	(A6)+OHVPT	; OHVPT <-- pas de data90$:	POPM.L	D1,A4	RET; Gestion des gencars; -------------------;------------\\; GENCARPARAM >;------------/; Donne quelques paramtres.; in	-; out	D3.L	position relative par dfaut;	D4.L	fanions par dfaut (BLIVUxxxx);	A4.L	^textes des options (tout<0>ngatif<0>divers<0>);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A4.LGENCARPARAM:	CLR.L	D3	CLR.L	D4	LOAD.L	A4,#R16"OP$	CLR.W	D7		; D7 <-- ok	RETOP$:	.ASCIZ	"        "	.ASCIZ	"        "	.ASCIZ	"          "	.B	0	.EVEN;-------------\\; GENCARUPDATE >;-------------/; Met  jour l'affichage du gencar, des ascenseurs, etc.; Les informations ne sont pas mises  jour !; in	-; out	D7.W	erreur; mod	D7.WGENCARUPDATE:	JUMP	GENCARSHOW	; affiche le gencar;-----------\\; GENCARMOVE >;-----------/; Dplace ventuellement le gencar.; in	D4.L	position de la souris (y;x); out	D7.W	erreur (trop petit); mod	D7.WGENCARMOVE:	LOAD.W	D7,#ERDIOUT	RET;-----------\\; GENCARSHOW >;-----------/; Affiche un gencar dans la (sous-)fentre.; in	-; out	D7.W	erreur; mod	D7.WGENCARSHOW:	PUSHM.L	D0..D4,A1,A4	CALL	BASECLEAR	; efface v. le dessous	LOAD.L	D3,(A6)+OHVPOF	; D3 <-- position	LOAD.L	D4,(A6)+OHVDIF	; D4 <-- dimensions	CALL	WDOOPEN		; ouvre la sous-fentre	LOAD.L	A1,(A6)+OHVPT	LOAD.L	A1,#(A1)+256	; A1 <-- ^en-tte du gencar	TEST.W	(A1)+oxcIDENT	; gencar "bitmap" ?	JUMP',NE 50$		; non => 50$	LOAD.L	D3,#H'10000*1	; D3 <-- position initiale en Y	CLR.B	D4		; D4 <-- code initial	LOAD.W	D0,#(256/16)-120$:	LOAD.W	D3,(A6)+OHVPOF+2	LOAD.W	D3,#1		; D3 <-- position initiale en X	LOAD.W	D1,#16-130$:	CALL	GENCARONE	; affiche un caractre	ADD.W	D3,(A1)+OGCMWI	; D3 <-- position suivante en X	ADD.W	D3,#4	INC.B	D4		; D4 <-- code suivant	DECJ.W,NMO D1,30$	SWAP.W	D3	ADD.W	D3,(A1)+OGCMHD	; D3 <-- position suivante en Y	ADD.W	D3,#4	SWAP.W	D3	DECJ.W,NMO D0,20$	JUMP'	80$50$:	COMP.W	(A1)+oxcIDENT,#xcIDENT ; gencar analytique ?	JUMP',NE 80$		; non => 80$				; oui =>	LOAD.L	A4,A1		; A4 <-- ^contenu du gencar	CLR.L	D3		; D3 <-- coin sup/gauche (y;x)	LOAD.L	D4,(A0)+ODFFDY	; D4 <-- dimensions (dy;dx)	LOAD.W	D1,D4	SR.W	D1		; D1 <-- demi-largeur	LOAD.L	D2,D4	SWAP.W	D2		; D2 <-- hauteur	COMP.W	D2,D1	JUMP',LS 54$	LOAD.W	D2,D154$:	SUB.W	D2,#20		; D2 <-- taille	XCAR_	SHOWF		; affiche "Abc"80$:	CALL	WDOCLOSE	; ferme la sous-fentre	POPM.L	D0..D4,A1,A4	RET;----------\\; GENCARONE >;----------/; Affiche juste un caractre.; in	D3.L	position coin sup/gauche (y;x);	D4.B	caractre (0..127);	A1.L	^gencar; out	-; mod	D7.WGENCARONE:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A3,#(A6)+OHVBUF+1	LOAD.B	(A3+),#DRAWRASTER	CLR.L	(A3+)		; source: <xx> et <yy>	LOAD.L	A4,#(A1)+256	; A4 <-- saute l'en-tte	COMP.B	D4,(A1)+OGCLCA	JUMP,HI 90$	SUB.B	D4,(A1)+OGCFCA	JUMP,LO 90$	CLR.W	D2	LOAD.B	D2,(A1)+OGCLCA	SUB.B	D2,(A1)+OGCFCA	INC.B	D2	ADD.W	A4,D2		; A4 <-- saute la table width	ADD.W	A4,D2		; A4 <-- saute la table h1	ADD.W	A4,D2		; A4 <-- saute la table h2	AND.W	D4,#H'FF	MUL.WU	D4,(A1)+OGCMSB	ADD.L	A4,D4	LOAD.L	(A3+),A4	; source: <pppp>	CLR.W	D2	LOAD.B	D2,(A1)+OGCMWB	LOAD.W	(A3+),D2	; source: <ii>	SWAP.W	D3	LOAD.L	(A3+),D3	; destination: <xx> et <yy>	CLR.L	(A3+)		; destination: <pppp>	CLR.W	(A3+)		; destination: <ii>	CLR.W	D3	LOAD.B	D3,(A1)+OGCMWB	SL.W	D3,#3	LOAD.W	(A3+),D3	; <dxx>	LOAD.W	(A3+),(A1)+OGCMHD ; <dyy>	LOAD.B	(A3+),#SETDOT	; <mode>	LOAD.L	A3,#(A6)+OHVBUF+1	LOAD.W	D3,#26	LIB	?STRING		; affiche le caractre90$:	POPM.L	D2..D4,A3,A4	RET;-----------\\; GENCARINFO >;-----------/; Met  jour quelques informations sur un gencar.; in	-; out	-; mod	D7.WGENCARINFO:	PUSHM.L	D2..D4,A1,A3	LOAD.L	A1,(A6)+OHVPT	LOAD.L	A1,#(A1)+256	; A1 <-- ^en-tte du gencar	LIB	?AFTIM	.ASCIZ	"  Nom du gnrateur: "	.EVEN	TEST.B	(A6)+OHVMOI+2:#BLIVIINV-8 ; nom en inverse ?	JUMP',BC 10$		; non => 10$	LOAD.B	D3,#AFINV	; oui =>	LIB	?AFCAR		; affiche en vido-inverse10$:	LOAD.L	A3,#(A6)+OHVNAM	; A3 <-- ^nom du gencar	LIB	?AFFILE	LIB	?AFTIM	.ASCIZ	"<AFDIR><CR>  Gnrateur contenant "	.EVEN	TEST.W	(A1)+oxcIDENT	; gencar "bitmap" ?	JUMP',NE 40$		; non => 40$	CLR.L	D4	LOAD.B	D4,(A1)+OGCLCA	SUB.B	D4,(A1)+OGCFCA	INC.B	D4	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" caractres "	.EVEN	CLR.L	D4	LOAD.W	D4,(A1)+OGCMWI	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"x"	.EVEN	CLR.L	D4	LOAD.W	D4,(A1)+OGCMHD	LIB	?AFDEC	JUMP'	45$40$:	LIB	?AFTIM	.ASCIZ	/256 caractres "XCAR"/	.EVEN45$:	LIB	?AFCR	LIB	?AFTIM	.ASCIZ	"  Nom complet: "	.EVEN	LOAD.L	A3,#(A1)+OGCCNM	LOAD.W	D3,#-150$:	INC.W	D3	COMP.B	(A3+),#CR	JUMP',EQ 52$	TEST.B	(A3)-1	JUMP,NE 50$52$:	TEST.W	D3	JUMP',EQ 56$	LOAD.L	A3,#(A1)+OGCCNM	LIB	?STRING	JUMP'	58$56$:	LIB	?AFTIM	.ASCIZ	"<'<>inconnu<'>>"	.EVEN58$:	LIB	?AFCR	POPM.L	D2..D4,A1,A3	RET; Gestion des textes; ------------------;----------\\; ASCIIOPEN >;----------/; Lit un fichier ASCII sur disque, sans l'afficher.; in	A3.L	^nom du fichier ASCII; out	D7.W	erreur; mod	D7.WASCIIOPEN:	PUSHM.L	D1,D3,D4,D6,A1,A3,A4	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre le fichier ASCII	JUMP,NE 90$	LOAD.W	D3,#-1	LOAD.L	D4,#-1	FOS	?SPOS		; va tout  la fin	LOAD.L	D1,D4		; D1 <-- longueur du fichier	CLR.W	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP,NE 82$	LOAD.L	(A6)+OHVHD+OTXLGT,D1 ; OTXLGT <-- longueur du fichier ASCII	LOAD.L	D4,D1	INC.L	D4		; D4 <-- place pour <0> terminateur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour fichier ASCII complet	JUMP,NE 82$	LOAD.L	A1,A4		; A1 <-- ^buffer pour fichier ASCII	LOAD.L	(A6)+OHVPT,A1	; OHVPT <-- ^data du fichier	DEC.L	D4	FOS	?RDBYTE		; lit le fichier ASCII	JUMP,NE 80$	CLR.B	(A4)+(D4.L)	; met le <0> terminateur	FOS	?CLOSE		; ferme le fichier ASCII	CALL	ASCIICHECK	; est-ce bien un fichier ASCII ?	JUMP',NE 60$		; non => 60$	CLR.B	(A6)+OHVHD+OTXBIN	LOAD.L	A3,A1		; A3 <-- ^source	LOAD.L	A4,A1		; A4 <-- ^destination	CLR.B	(A6)+OHVDCR	; enable <cr>40$:	CALL	ASCIICAR	; D3 <-- caractre suivant	LOAD.B	(A4+),D3	; destination <-- caractre	JUMP,NE 40$	LOAD.L	D3,A4	SUB.L	D3,A1	DEC.L	D3	LOAD.L	(A6)+OHVHD+OTXLGB,D3 ; OTXLGB <-- longueur du fichier sans les BOAs	LOAD.L	A3,A1		; A3 <-- ^texte	CLR.W	D4		; D4 <-- nb de lignes50$:	LOAD.B	D3,(A3+)	JUMP',EQ 52$	COMP.B	D3,#CR	JUMP,NE 50$	INC.W	D4		; D4 <-- une ligne de plus	JUMP	50$52$:	INC.W	D4	LOAD.W	(A6)+OHVHD+OTXNBL,D4 ; OTXNBL <-- nb de lignes	CLR.W	D7		; D7 <-- ok	JUMP'	90$60$:				; fichier binaire =>	SET.B	(A6)+OHVHD+OTXBIN	LOAD.L	(A6)+OHVHD+OTXLGB,D4	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	A4,A1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire du fichier ASCII	CLR.L	(A6)+OHVPT	; OHVPT <-- pas de data	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier ASCII	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ASCIICHECK >;-----------/; Vrifie si le fichier lu est bien de l'ASCII.; in	A4.L	^data;	D4.L	lg data; out	D7.W	erreur; mod	D7.WASCIICHECK:	PUSHM.L	D4,A4	LOAD.W	D7,#ERSYNT	; D7 <-- erreur10$:	LOAD.B	D3,(A4+)	JUMP',NS 90$	JUMP',EQ 90$	DEC.L	D4	JUMP,NE 10$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; ASCIICAR >;---------/; Lit un caractre, en ignorant les commandes "boa".; in	A3.L	^texte source; out	A3.L	^plus loin;	D3.B	caractre lu; mod	D3.L, D7.W, A3.LASCIICAR:	PUSHM.L	D4,A410$:	LOAD.B	D3,(A3+)	; D3 <-- lit un caractre	JUMP,EQ 90$	TEST.L	D3:#7	JUMP,BS 10$	COMP.B	D3,#CR	JUMP',NE 12$	TEST.B	(A6)+OHVDCR	; disable <cr> ?	JUMP,T	10$		; oui => 10$12$:	LOAD.B	D4,D3	LOAD.B	D3,#CR	COMP.B	D4,#H'0A	; pseudo-CR ?	JUMP,EQ 90$	COMP.B	D4,#H'06	; pseudo-FF ?	JUMP,EQ 90$	COMP.B	D4,#H'0C	; FF ?	JUMP,EQ 90$	LOAD.B	D3,#'-	COMP.B	D4,#H'0B	; pseudo-tiret ?	JUMP,EQ 90$	LOAD.B	D3,#SPACE	COMP.B	D4,#H'02	; cadratin ?	JUMP,EQ 90$	LOAD.B	D3,D4	COMP.B	D3,#'\	JUMP,NE 90$; Lit toute une commande "boa".	LOAD.L	A4,#(A6)+OHVBUF	LOAD.W	D4,#LHVBUF-2	LOAD.B	D3,(A3+)	; D3 <-- lit 1er caractre d'une "boa"	JUMP,EQ 90$	LOAD.B	(A4+),D3	; OHVBUF <-- commande "boa"	DEC.W	D4	CALL	MINMAJ	COMP.B	D3,#'\		; double "boa" ?	JUMP,EQ 90$		; oui => 90$	COMP.B	D3,#'A		; commence par une lettre ?	JUMP,LO 10$		; non => 10$	COMP.B	D3,#'Z	JUMP,HI 10$20$:	LOAD.B	D3,(A3+)	; D3 <-- lit une "boa"	JUMP,EQ 90$	TEST.W	D4	JUMP',EQ 22$	LOAD.B	(A4+),D3	; OHVBUF <-- commande "boa"	DEC.W	D422$:	COMP.B	D3,#';		; fin de la "boa" ?	JUMP',EQ 24$	COMP.B	D3,#':	JUMP,NE 20$24$:	CLR.B	(A4)		; OHVBUF <-- terminateur	LOAD.L	A4,#(A6)+OHVBUF	CALL	ASCIIBOA	; D3 <-- no commande "boa"	TEST.B	D3	JUMP,EQ 10$	COMP.B	D3,#1	JUMP',EQ 30$	COMP.B	D3,#2	JUMP',EQ 31$	COMP.B	D3,#3	JUMP',EQ 35$	JUMP	10$30$:				; disable <cr> =>	SET.B	(A6)+OHVDCR	JUMP	10$31$:				; enable <cr> =>	CLR.B	(A6)+OHVDCR	JUMP	10$35$:				; define =>	LOAD.B	D3,(A3+)	JUMP',EQ 90$	COMP.B	D3,#CR	JUMP,NE 35$	JUMP	10$90$:	POPM.L	D4,A4	RET;---------\\; ASCIIBOA >;---------/; Cherche s'il s'agit d'une commande "boa" spciale.; in	A4.L	^commande "boa"; out	D3.B	no commande (zro si pas trouv); mod	D3.L, D7.WASCIIBOA:	PUSHM.L	A2..A4	LOAD.L	A3,#R16"00$10$:	LOAD.B	D3,(A3+)	; D3 <-- no commande	JUMP,EQ 90$	LOAD.L	A2,A420$:	TEST.B	(A3)	JUMP,EQ 90$	COMP.B	(A3+),(A2+)	JUMP,EQ 20$30$:	TEST.B	(A3+)	JUMP,NE 30$	JUMP	10$90$:	POPM.L	A2..A4	RET00$:	.B	1	.ASCIZ	"disable <'<>cr<'>>"	.B	2	.ASCIZ	"enable <'<>cr<'>>"	.B	3	.ASCIZ	"define "	.B	0	.EVEN;-----------\\; ASCIIPARAM >;-----------/; Donne quelques paramtres.; in	-; out	D3.L	position relative par dfaut;	D4.L	fanions par dfaut (BLIVUxxxx);	A4.L	^textes des options (tout<0>ngatif<0>divers<0>);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A4.LASCIIPARAM:	LOAD.W	D3,#-FACPOSR	SWAP.W	D3	LOAD.W	D3,#-FACPOSR	CLR.L	D4	LOAD.L	A4,#R16"OPTEXT$	TEST.B	(A6)+OHVHD+OTXBIN ; fichier binaire ?	JUMP',F 90$	LOAD.L	A4,#R16"OPBIN$90$:	CLR.W	D7		; D7 <-- ok	RETOPTEXT$:	.ASCIZ	"petit   "	.ASCIZ	"        "	.ASCIZ	"          "	.B	0OPBIN$:	.ASCIZ	"dtail  "	.ASCIZ	"        "	.ASCIZ	"          "	.B	0	.EVEN;------------\\; ASCIIUPDATE >;------------/; Met  jour l'affichage du texte, des ascenseurs, etc.; Les informations ne sont pas mises  jour !; in	-; out	D7.W	erreur; mod	D7.WASCIIUPDATE:	PUSHM.L	D2..D4,A5	CALL	ASCIISHOW	; affiche le texte	TEST.B	(A6)+OHVMOD+2:#BLIVDASC-8 ; utilise les ascenseurs ?	JUMP,BC 90$		; non => 90$	LOAD.L	A5,#(A6)+OHVASV	; A5 <-- ^variables ascenseur vertical	CLR.L	D3	LOAD.W	D3,(A6)+OHVDIF+0	DIV.WU	D3,(A6)+OHVHD+OTXCY ; D3 <-- nb de lignes visibles	LOAD.W	D4,(A6)+OHVHD+OTXNBL ; D4 <-- nb de lignes	SUB.W	D4,D3	JUMP',LE 20$	LOAD.W	(A5)+OSCHTV,D4	LOAD.W	(A5)+OSCINC,#+2	CALL	PUTPOSV		; OSCPOSV <-- OHVPOR	SCROLL_	UPDATE		; dessine l'ascenseur vertical plein	JUMP'	90$20$:	TEST.W	(A5)+OSCHTV	; ascenseur dj vide ?	JUMP',EQ 90$		; oui => 90$	CLR.W	(A5)+OSCHTV	SCROLL_	DRAW		; dessine l'ascenseur vertical vide90$:	POPM.L	D2..D4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; ASCIIMOVE >;----------/; Dplace ventuellement le texte.; in	D4.L	position de la souris (y;x); out	D7.W	erreur (trop petit); mod	D7.WASCIIMOVE:	PUSH.L	A2	LOAD.L	A2,#R16"ASCIISHOW	CALL	BASEMOVEA	; dplace les ascenseurs ...	JUMP',EQ 90$	LOAD.L	A2,#R16"ASCIIUPDATE	CALL	BASEMOVEM	; dplace le contenu ...90$:	POP.L	A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; ASCIISHOW >;----------/; Affiche un fichier ASCII quelconque.; in	-; out	-; mod	D7.WASCIISHOW:	PUSHM.L	D1..D4,A3	CALL	BASECLEAR	; efface v. le dessous	LOAD.L	D3,(A6)+OHVPOF	; D3 <-- position	LOAD.L	D4,(A6)+OHVDIF	; D4 <-- dimensions	CALL	WDOOPEN		; ouvre la sous-fentre	TEST.B	(A6)+OHVHD+OTXBIN ; fichier binaire ?	JUMP',T 10$		; oui => 10$	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche tout ?	JUMP',BS 15$		; oui => 15$10$:	LOAD.L	D4,(A0)+ODFGCF	LOAD.B	D4,#USEGC	RR.L	D4,#8	PUSH.L	D4		; stack <-- <USEGC><F><S><T> initial	LIB	?AFTIM	.B	LOADGC,'N,'E!2^7,07	.B	USEGC,'N,'E!2^7,07 ; utilise le gencar NEF07	.B	0	.EVEN	LOAD.W	D4,(A0)+ODFC1Y	LOAD.W	(A6)+OHVHD+OTXC1Y,D4	ADD.W	D4,(A0)+ODFC2Y	LOAD.W	(A6)+OHVHD+OTXCY,D4	LOAD.W	(A6)+OHVHD+OTXCX,(A0)+ODFCX	LOAD.W	(A6)+OHVHD+OTXC1X,(A0)+ODFC1X	JUMP'	20$15$:	LOAD.W	(A6)+OHVHD+OTXCY,#2	LOAD.W	(A6)+OHVHD+OTXCX,#2	CLR.W	(A6)+OHVHD+OTXC1Y	CLR.W	(A6)+OHVHD+OTXC1X	CALL	CCMO		; enlve la souris20$:	CALL	ASCIINBL	; calcule nb lignes et nb caractres	LOAD.W	D3,(A6)+OHVASV+OSCPOSV ; D3 <-- position virtuelle	CLR.L	D4	LOAD.W	D4,(A6)+OHVDIF+0	DIV.WU	D4,(A6)+OHVHD+OTXCY ; D4 <-- nb de lignes	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche tout ?	JUMP',BC 22$		; non => 22$	TEST.B	(A6)+OHVHD+OTXBIN ; fichier binaire ?	JUMP',T 22$		; oui => 22$	DEC.W	D4		; D4 <-- une ligne de moins22$:	CLR.W	D2		; D2 <-- affiche depuis tout en haut	LOAD.W	D1,(A6)+OHVHD+OTXLFL	LOAD.W	(A6)+OHVHD+OTXLFL,D3	TEST.B	(A6)+OHVMOU+1:#BLIVUNCLR-16 ; n'efface pas le dessous ?	JUMP',BC 50$		; non => 50$				; oui =>	SUB.W	D1,D3	JUMP',EQ 60$	JUMP',HI 40$				; descend =>	NEG.W	D1	COMP.W	D1,D4		; y a-t-il qq chose d'utile  scroller ?	JUMP',HS 50$		; non => 50$	CALL	ASCIIROLL	; scroll contre en haut	SUB.W	D1,D4	NEG.W	D1	LOAD.W	D2,D1		; D2 <-- premire ligne o affichier	ADD.W	D3,D1		; D3 <-- premire ligne  affichier	SUB.W	D4,D1		; D4 <-- nb de lignes	JUMP'	50$40$:				; monte =>	COMP.W	D1,D4		; y a-t-il qq chose d'utile  scroller ?	JUMP',HS 50$		; non => 50$	NEG.W	D1	CALL	ASCIIROLL	; scroll contre en bas	LOAD.W	D4,D1	NEG.W	D4		; D4 <-- nb de lignes	DEC.W	D450$:	INC.W	D4	CALL	ASCIIPAVE	; affiche le pav60$:	TEST.B	(A6)+OHVHD+OTXBIN ; fichier binaire ?	JUMP',T 62$		; oui => 62$	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche tout ?	JUMP',BS 80$		; oui => 80$62$:				; non =>	LOAD.L	A3,SP		; A3 <-- ^<USEGC><F><S><T>	LOAD.W	D3,#4	LIB	?STRING		; remet le gencar initial	POP.L	D4		; ajuste le stack80$:	CALL	SCMO		; remet la souris	CALL	WDOCLOSE	; ferme la sous-fentre	POPM.L	D1..D4,A3	RET;----------\\; ASCIIROLL >;----------/; Scroll quelques lignes contre en haut (+) ou contre en bas (-).; in	D1.W	nb de lignes  scroller (+/-); out	-; mod	D7.WASCIIROLL:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OHVBUF+1	LOAD.B	(A3)+0,#ROLLUP	LOAD.W	D3,D1	JUMP',NC 20$	LOAD.B	(A3)+0,#ROLLDOWN	NEG.W	D320$:	MUL.WU	D3,(A6)+OHVHD+OTXCY	LOAD.W	(A3)+1,D3	LOAD.W	D3,#3	LIB	?STRING		; scroll up/down	POPM.L	D3,A3	RET;---------\\; ASCIINBL >;---------/; Calcule le nombre de lignes et le nombre de caractres.; in	-; out	-; mod	D7.WASCIINBL:	PUSHM.L	D0,D1	TEST.B	(A6)+OHVHD+OTXBIN ; fichier binaire ?	JUMP,F	80$		; non => 80$	CLR.L	D0	LOAD.W	D0,(A0)+ODFFDX	DIV.WU	D0,(A0)+ODFCX	; D0 <-- nb caractres/ligne dans swdo	LOAD.W	D1,D0	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche dtails ?	JUMP',BC 30$		; non => 30$	LOAD.W	D1,#64	COMP.W	D0,#10+64+(1+8)*(64/4)	JUMP',HS 30$	LOAD.W	D1,#32	COMP.W	D0,#10+32+(1+8)*(32/4)	JUMP',HS 30$	LOAD.W	D1,#16	COMP.W	D0,#10+16+(1+8)*(16/4)	JUMP',HS 30$	LOAD.W	D1,#8	COMP.W	D0,#10+8+(1+8)*(8/4)	JUMP',HS 30$	LOAD.W	D1,#4		; D1 <-- nb caractres/ligne30$:	LOAD.W	(A6)+OHVHD+OTXNBC,D1	LOAD.L	D0,(A6)+OHVHD+OTXLGT	DIV.WU	D0,D1	ADD.W	D0,#2	LOAD.W	(A6)+OHVHD+OTXNBL,D0	PUSH.W	(A6)+OHVASV+OSCHTV	CLR.W	(A6)+OHVASV+OSCHTV	CLR.L	D0	LOAD.W	D0,(A6)+OHVDIF+0	DIV.WU	D0,(A6)+OHVHD+OTXCY ; D0 <-- nb de lignes visibles	LOAD.W	D1,(A6)+OHVHD+OTXNBL ; D1 <-- nb de lignes	SUB.W	D1,D0	JUMP',NS 40$	LOAD.W	(A6)+OHVASV+OSCHTV,D140$:	CALL	PUTPOSV		; OSCPOSV <-- OHVPOR	POP.W	(A6)+OHVASV+OSCHTV	JUMP'	90$80$:	CALL	PUTPOSV		; OSCPOSV <-- OHVPOR90$:	POPM.L	D0,D1	RET;----------\\; ASCIIPAVE >;----------/; Affiche un pav de texte dans la swdo.; in	D2.W	ligne o afficher (0..n);	D3.W	premire ligne (0..n);	D4.W	nb de lignes (1..n); out	-; mod	D7.WASCIIPAVE:	PUSHM.L	D0..D5,A3	PUSH.B	(A0)+ODFMGR	LOAD.B	(A0)+ODFMGR,#GRACLIP2	TEST.B	(A6)+OHVHD+OTXBIN ; fichier binaire ?	JUMP,T	60$		; oui => 60$	TEST.B	(A6)+OHVMOU+1:#BLIVUNCLR-16 ; n'efface pas le dessous ?	JUMP,BC 40$		; non => 40$				; oui =>	TEST.L	(A6)+OHVHD+OTXLPL	JUMP,EQ 40$	LOAD.L	A3,(A6)+OHVHD+OTXLPL	LOAD.W	D0,(A6)+OHVHD+OTXLNL	SUB.W	D0,D3	JUMP,EQ 50$	JUMP',HI 30$				; descend =>	NEG.W	D022$:	DEC.W	D0	JUMP',NS 27$24$:	LOAD.B	D1,(A3+)	JUMP',EQ 26$	COMP.B	D1,#CR	JUMP,NE 24$	JUMP	22$26$:	DEC.L	A327$:	LOAD.W	(A6)+OHVHD+OTXLNL,D3	LOAD.L	(A6)+OHVHD+OTXLPL,A3	JUMP	50$30$:				; remonte =>	LOAD.L	D5,A3	SUB.L	D5,(A6)+OHVPT32$:	DEC.W	D0	JUMP',NS 37$	DEC.L	D5	JUMP',NS 37$	DEC.L	A334$:	DEC.L	D5	JUMP',NS 37$	COMP.B	(-A3),#CR	JUMP,NE 34$	INC.L	D5	INC.L	A3	JUMP	32$37$:	LOAD.W	(A6)+OHVHD+OTXLNL,D3	LOAD.L	(A6)+OHVHD+OTXLPL,A3	JUMP'	50$; Cherche la premire ligne  afficher depuis le dbut du texte.40$:	LOAD.L	A3,(A6)+OHVPT	; A3 <-- ^dbut du texte	LOAD.W	(A6)+OHVHD+OTXLNL,D342$:	DEC.W	D3	JUMP',NS 47$44$:	LOAD.B	D1,(A3+)	JUMP',EQ 46$	COMP.B	D1,#CR	JUMP,NE 44$	JUMP	42$46$:	DEC.L	A347$:	LOAD.L	(A6)+OHVHD+OTXLPL,A3; Affiche quelques lignes conscutives.50$:	LOAD.W	D3,D2	MUL.WU	D3,(A6)+OHVHD+OTXCY	ADD.W	D3,(A6)+OHVHD+OTXC1Y	SWAP.W	D3	LOAD.W	D3,(A6)+OHVHD+OTXC1X52$:	CALL	ASCIILINE	; affiche une ligne	SWAP.W	D3	ADD.W	D3,(A6)+OHVHD+OTXCY ; D3 <-- position suivante	SWAP.W	D3	DEC.W	D4		; encore une ligne ?	JUMP,NE 52$		; oui => 52$	JUMP	80$; Affiche un fichier binaire.60$:	LOAD.W	D0,D3		; D0 <-- premire ligne	LOAD.W	D1,(A6)+OHVHD+OTXNBC ; D1 <-- nb caractres/ligne	LOAD.W	D3,D2	MUL.WU	D3,(A6)+OHVHD+OTXCY	ADD.W	D3,(A6)+OHVHD+OTXC1Y	SWAP.W	D3	LOAD.W	D3,(A6)+OHVHD+OTXC1X64$:	CALL	ASCIIBIN	; affiche une ligne de binaire	INC.W	D0		; D0 <-- ligne suivante	SWAP.W	D3	ADD.W	D3,(A6)+OHVHD+OTXCY ; D3 <-- position suivante	SWAP.W	D3	DEC.W	D4		; encore une ligne ?	JUMP,NE 64$		; oui => 64$80$:	POP.B	(A0)+ODFMGR	POPM.L	D0..D5,A3	RET;----------\\; ASCIILINE >;----------/; Affiche une ligne de texte dans la swdo.; in	D3.L	position (y;x);	A3.L	^ligne; out	A3.L	^plus loin; mod	D7.W, A3.LASCIILINE:	PUSHM.L	D1..D4,A4	LOAD.L	D1,D3		; D1 <-- position	LOAD.L	A4,#(A6)+OHVBUF	CLR.L	D4	LOAD.W	D4,(A6)+OHVDIF+2	DIV.WU	D4,(A6)+OHVHD+OTXCX ; D4 <-- nb max de caractres	CLR.W	D2		; D2 <-- position dans la ligne10$:	LOAD.B	D3,(A3)		; D3 <-- caractre suivant	JUMP,EQ 20$	COMP.B	D3,#CR	JUMP,EQ 20$	INC.L	A3	COMP.B	D3,#TAB	JUMP',EQ 15$	LOAD.B	(A4+),D3	; OHVBUF <-- un caractre	INC.W	D2		; D2 <-- position suivante	DEC.W	D4	JUMP,NE 10$	JUMP	20$15$:				; tabulateur =>	LOAD.W	D3,D2	ADD.W	D2,#8	AND.B	D2,#B'11111000	; D2 <-- position suivante	SUB.W	D3,D2	NEG.W	D3		; D3 <-- nb d'espaces  mettre16$:	LOAD.B	(A4+),#SPACE	; OHVBUF <-- un espace	DEC.W	D4	JUMP',EQ 20$	DEC.W	D3	JUMP,NE 16$	JUMP	10$20$:	TEST.W	D4	JUMP',EQ 22$	LOAD.B	(A4+),#EFLI	; OHVBUF <-- efface la fin de la ligne22$:	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche tout ?	JUMP',BS 50$		; oui => 50$				; non =>	LOAD.L	D3,D1	LIB	?SETCURS	; positionne au dbut de la ligne	PUSH.L	A3	LOAD.L	A3,#(A6)+OHVBUF	LOAD.L	D3,A4	SUB.L	D3,A3	LIB	?STRING		; affiche toute le ligne	POP.L	A3	JUMP	80$50$:	PUSHM.L	A2,A3	LOAD.L	D4,D1		; D4 <-- position	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.L	A3,#(A6)+OHVBUF	LOAD.L	D2,A4	SUB.L	D2,A3		; D2 <-- nb de caractres	LOAD.L	A4,A3		; A4 <-- ^caractres	LOAD.W	D3,#GRA_DOT	LIB_	GETAD		; A3 <-- ^routine GRA_DOT	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre60$:	DEC.W	D2	JUMP,NS 68$	LOAD.W	D1,#SETDOT	; D1 <-- mode de dessin	LOAD.B	D3,(A4+)	COMP.B	D3,#EFLI	JUMP',EQ 64$	COMP.B	D3,#SPACE	JUMP',NE 62$	LOAD.W	D1,#CLRDOT	; D1 <-- mode de dessin62$:	CALL	(A3)		; appel de GRA_DOT	ADD.W	D4,#2		; D4 <-- position suivante	JUMP	60$64$:	LOAD.L	D3,D4	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,D3	DEC.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRSEG		; efface la fin de la ligne68$:	POPM.L	A2,A380$:	LOAD.B	D3,(A3)	JUMP',EQ 90$	INC.L	A3		; A3 <-- ^dbut de la ligne suiante	COMP.B	D3,#CR	JUMP,NE 80$90$:	POPM.L	D1..D4,A4	RET;---------\\; ASCIIBIN >;---------/; Affiche une ligne de binaire dans la swdo.; in	D3.L	position (y;x);	A3.L	^ligne;	D0.W	no de la ligne  afficher;	D1.W	nb caractres/ligne; out	-; mod	D7.WASCIIBIN:	PUSHM.L	D0..D4,A1..A4	LIB	?SETCURS	; positionne au dbut de la ligne	LOAD.W	D4,D0	MUL.WU	D4,D1		; D4 <-- offset dbut	LOAD.L	A3,(A6)+OHVPT	; A3 <-- ^dbut du texte	LOAD.L	A1,A3	ADD.L	A3,D4		; A3 <-- ^dbut  afficher	ADD.L	A1,(A6)+OHVHD+OTXLGT	COMP.L	A3,A1	JUMP,HS 80$	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche dtails ?	JUMP,BC 50$		; non => 50$	LIB	?AFX8		; affiche l'adresse de la ligne	LIB	?AFTIM	.ASCIZ	": "	.EVEN	LOAD.L	A4,#(A6)+OHVBUF	LOAD.L	A2,A3	LOAD.B	(A4+),#AFTOUT	LOAD.W	D4,D1	LOAD.B	D0,#AFDIR20$:	LOAD.B	D3,(A2+)	COMP.L	A2,A1	JUMP',LO 21$	LOAD.B	D3,#SPACE21$:	LOAD.B	D2,#AFDIR	TCLR.L	D3:#7	JUMP',BC 22$	LOAD.B	D2,#AFINV22$:	COMP.B	D2,D0	JUMP',EQ 24$	LOAD.B	(A4+),D2	LOAD.B	D0,D224$:	LOAD.B	(A4+),D3	DEC.W	D4	JUMP,NE 20$	LOAD.B	(A4+),#AFDIR	LOAD.B	(A4+),#AFNORM	LOAD.B	(A4+),#SPACE	LOAD.L	A2,A3	LOAD.L	A3,#(A6)+OHVBUF	LOAD.L	D3,A4	SUB.L	D3,A3	LIB	?STRING		; affiche la ligne en "ASCII"	LOAD.L	A3,A2	SR.W	D1,#240$:	COMP.L	A3,A1	JUMP',HS 80$	LIB	?AFSPACE	LOAD.L	D4,(A3+)	LIB	?AFX8		; affiche la ligne en hexa	DEC.W	D1	JUMP,NE 40$	JUMP'	80$50$:	LOAD.L	A4,#(A6)+OHVBUF	LOAD.B	(A4+),#AFTOUT	LOAD.W	D2,D152$:	LOAD.B	D3,(A3+)	COMP.L	A3,A1	JUMP',HS 58$	COMP.B	D3,#'	JUMP',LO 54$	COMP.B	D3,#'~	JUMP',LS 56$54$:	CLR.B	D3		; D3 <-- caractre ".."56$:	LOAD.B	(A4+),D3	DEC.W	D2	JUMP,NE 52$58$:	LOAD.B	(A4+),#AFNORM	LOAD.L	A3,#(A6)+OHVBUF	LOAD.L	D3,A4	SUB.L	D3,A3	LIB	?STRING		; affiche la ligne en "ASCII";	JUMP'	80$80$:	LOAD.B	D3,#EFLI	LIB	?AFCAR		; efface la fin de la ligne	POPM.L	D0..D4,A1..A4	RET;----------\\; ASCIIINFO >;----------/; Met  jour quelques informations sur un fichier ASCII.; in	-; out	-; mod	D7.WASCIIINFO:	PUSHM.L	D2..D4,A3	LIB	?AFTIM	.ASCIZ	"  Nom du fichier: "	.EVEN	TEST.B	(A6)+OHVMOI+2:#BLIVIINV-8 ; nom en inverse ?	JUMP',BC 10$		; non => 10$	LOAD.B	D3,#AFINV	; oui =>	LIB	?AFCAR		; affiche en vido-inverse10$:	LOAD.L	A3,#(A6)+OHVNAM	; A3 <-- ^nom du fichier ASCII	LIB	?AFFILE	LIB	?AFTIM	.ASCIZ	"<AFDIR>    Taille: "	.EVEN	LOAD.L	D4,(A6)+OHVHD+OTXLGB	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	COMP.L	D4,(A6)+OHVHD+OTXLGT	JUMP',EQ 30$	LIB	?AFTIM	.ASCIZ	"/"	.EVEN	LOAD.L	D4,(A6)+OHVHD+OTXLGT;	LOAD.W	D3,#8;	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC30$:	LIB	?AFTIM	.ASCIZ	" caractres<CR>"	.EVEN	POPM.L	D2..D4,A3	RET; Routines communes; -----------------;---------\\; BASEDRAW >;---------/; Dessine le cadre, les ascenseurs vides, etc.; in	D1.W	nb de lignes pour les informations;		 :#16=1  -->  ascenseur vertical;		 :#17=1  -->  ascenseur horizontal; out	D7.W	erreur (trop petit); mod	D7.WBASEDRAW:	PUSHM.L	D2..D4,A5	TEST.B	(A6)+OHVMOD+1:#BLIVDMSET-16 ; mode SETDOT ?	JUMP',BS 10$	TEST.B	(A6)+OHVMOD+1:#BLIVDMCLR-16 ; mode CLRDOT ?	JUMP',BS 10$	TEST.B	(A6)+OHVMOD+1:#BLIVDMINV-16 ; mode INVDOT ?	JUMP',BS 10$	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfinit trame pour effacer	LOAD.L	D3,(A6)+OHVPOS	; D3 <-- position	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.L	D4,(A6)+OHVDIM	; D4 <-- dimensions	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface tout10$:	TEST.B	(A6)+OHVMOD+2:#BLIVDRECT-8 ; rectangle englobant ?	JUMP',BC 20$		; non => 20$	PUSHM.L	D3,D4	LOAD.L	D3,(A6)+OHVPOS	; D3 <-- position	LOAD.L	D4,(A6)+OHVDIM	; D4 <-- dimensions	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; trace le rectangle englobant	POPM.L	D3,D420$:	TEST.B	(A6)+OHVMOD+2:#BLIVDINFO-8 ; affiche les informations ?	JUMP',BC 30$		; non => 30$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A0)+ODFCY	MUL.WU	D2,D1	ADD.W	D2,#MARIFY*2	; D2 <-- hauteur pour les infos	ADD.W	D3,D2	SUB.W	D4,D2	SWAP.W	D4	SWAP.W	D330$:	TEST.B	(A6)+OHVMOD+2:#BLIVDASC-8 ; utilise les ascenseurs ?	JUMP',BC 40$		; non => 40$	TEST.L	D1:#16		; ascenseur vertical ?	JUMP',BC 35$		; non => 35$	ADD.W	D3,#LGSCROLL-1	SUB.W	D4,#LGSCROLL-135$:	TEST.L	D1:#17		; ascenseur horizontal ?	JUMP',BC 40$		; non => 40$	SWAP.W	D4	SUB.W	D4,#LGSCROLL-1	SWAP.W	D440$:	LOAD.W	D7,#ERDIOUT	; D7 <-- impossible	COMP.W	D4,#MINWDOX	JUMP,LT 90$	SWAP.W	D4	COMP.W	D4,#MINWDOY	JUMP,LT 90$	SWAP.W	D4	LOAD.L	(A6)+OHVPOF,D3	; OHVPOF <-- position pour afficher le fichier	LOAD.L	(A6)+OHVDIF,D4	; OHVDIF <-- dimensions pour afficher le fichier	TEST.B	(A6)+OHVMOD+2:#BLIVDINFO-8 ; affiche les informations ?	JUMP',BC 50$		; non => 50$	LOAD.L	D3,(A6)+OHVPOF	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A6)+OHVDIF+2	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; trait horizontal de sparation50$:	TEST.B	(A6)+OHVMOD+2:#BLIVDASC-8 ; utilise les ascenseurs ?	JUMP,BC 80$		; non => 80$	LOAD.L	A5,#(A6)+OHVASV	; A5 <-- ^variables ascenseur vertical	CLR.L	(A5)+OSCDEB	TEST.L	D1:#16		; ascenseur vertical ?	JUMP',BC 55$		; non => 55$	LOAD.W	D4,(A6)+OHVPOF+0	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OHVPOF+2	SUB.W	D4,#LGSCROLL	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OHVDIF+0	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4;	CLR.B	(A5)+OSCHOR	SCROLL_	DRAW		; dessine l'ascenseur vertical55$:	LOAD.L	A5,#(A6)+OHVASH	; A5 <-- ^variables ascenseur horizontal	CLR.L	(A5)+OSCDEB	TEST.L	D1:#17		; ascenseur horizontal ?	JUMP',BC 80$		; non => 80$	LOAD.W	D4,(A6)+OHVPOF+2	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OHVPOF+0	ADD.W	D4,(A6)+OHVDIF+0	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OHVDIF+2	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCHOR	SCROLL_	DRAW		; dessine l'ascenseur horizontal80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; BASEMOVEA >;----------/; Dplace ventuellement les ascenseurs.; in	D4.L	position de la souris (y;x);	A2.L	^routine "xxxxSHOW"; out	D7.W	erreur (trop petit); mod	D7.WBASEMOVEA:	PUSHM.L	D2..D5,A5	LOAD.L	D5,D4		; D5 <-- position de la souris	LOAD.W	D7,#ERDIOUT	TEST.B	(A6)+OHVMOD+2:#BLIVDASC-8 ; utilise les ascenseurs ?	JUMP,BC 90$		; non => 90$	CALL	PUTPOSV		; OSCPOSV <-- OHVPOR;	LOAD.W	D7,#ERDIOUT	LOAD.L	A5,#(A6)+OHVASV	; A5 <-- ^variables ascenseur vertical	TEST.L	(A5)+OSCDEB	JUMP',EQ 40$	TEST.W	(A5)+OSCHTV	JUMP',EQ 40$	LOAD.L	D4,D5		; D4 <-- position de la souris	LOAD.W	D2,(A5)+OSCINC	CLR.W	(A5)+OSCINC	INC.W	(A5)+OSCHTV	SCROLL_	MOVE		; dplace l'ascenseur ...	DEC.W	(A5)+OSCHTV	LOAD.W	(A5)+OSCINC,D2	TEST.W	D7	JUMP',EQ 60$40$:	LOAD.W	D7,#ERDIOUT	LOAD.L	A5,#(A6)+OHVASH	; A5 <-- ^variables ascenseur horizontal	TEST.L	(A5)+OSCDEB	JUMP,EQ 90$	TEST.W	(A5)+OSCHTV	JUMP,EQ 90$	LOAD.L	D4,D5		; D4 <-- position de la souris	LOAD.W	D2,(A5)+OSCINC	CLR.W	(A5)+OSCINC	INC.W	(A5)+OSCHTV	SCROLL_	MOVE		; dplace l'ascenseur ...	DEC.W	(A5)+OSCHTV	LOAD.W	(A5)+OSCINC,D2	TEST.W	D7	JUMP,NE 90$60$:	CALL	CCMO		; enlve la flche de la souris	SCROLL_	PRESS		; presse la petite flche62$:	LOAD.W	D3,D2		; D3 <-- avance	COMP.W	D4,#SCROLLFDOWN	JUMP',EQ 64$	NEG.W	D3		; D3 <-- recule	COMP.W	D4,#SCROLLFUP	JUMP',NE 68$64$:	ADD.W	D3,(A5)+OSCPOSV	; D3 <-- nouvelle position	JUMP',NC 65$	CLR.W	D365$:	COMP.W	D3,(A5)+OSCHTV	JUMP',LS 66$	LOAD.W	D3,(A5)+OSCHTV66$:	COMP.W	D3,(A5)+OSCPOSV	; position change ?	JUMP',EQ 74$		; non => 74$67$:				; oui =>	LOAD.W	(A5)+OSCPOSV,D368$:	CALL	GETPOSV		; OSCPOSV --> OHVPOR	PUSH.L	(A6)+OHVMOU	TSET.B	(A6)+OHVMOU+1:#BLIVUNCLR-16 ; n'efface pas le dessous	CALL	(A2)		; CALL xxxxSHOW	POP.L	(A6)+OHVMOU	COMP.W	D4,#SCROLLFDOWN	JUMP',EQ 72$	COMP.W	D4,#SCROLLFUP	JUMP',NE 76$72$:	SCROLL_	UPDATE		; bouge aussi l'ascenseur74$:	LIB	?IFCAR		; bouton relch ?	JUMP,NE 62$		; non => 62$76$:	SCROLL_	PRESS		; relche la petite flche	CALL	SCMO		; remet la flche de la souris	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D5,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; BASEMOVEM >;----------/; Dplace ventuellement le contenu avec la "main".; in	D4.L	position de la souris (y;x);	A2.L	^routine "xxxxUPDATE"; out	D7.W	erreur; mod	D7.WBASEMOVEM:	PUSHM.L	D2..D5,A3	TEST.B	(A6)+OHVHD+OTXBIN ; fichier binaire ?	JUMP',T 10$		; oui => 10$	TEST.B	(A6)+OHVMOU+2:#BLIVUOPT1-8 ; affiche toute l'image ?	JUMP,BS 90$		; oui => 90$10$:	CALL	BASEPOSM	; souris dans le rectangle ?	JUMP,NE 90$		; non => 90$	CALL	MAINMOUSE	; lutin souris = main	LOAD.L	D5,D4		; D5 <-- position relative20$:	CALL	IFMOUSE		; D4 <-- position de la souris	ADD.W	D4,D5	SWAP.W	D4	SWAP.W	D5	ADD.W	D4,D5		; D4 <-- centre de l'icne spciale	SWAP.W	D4	SWAP.W	D5	CALL	BASEPOSM	; D4 <-- position dans le rectangle	LOAD.W	D3,D4		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	LOAD.W	D2,(A6)+OHVASH+OSCHTV	INC.W	D2	MUL.WU	D3,D2	DIV.WU	D3,(A6)+OHVDIF+2	COMP.W	D3,D2	JUMP',LO 30$	LOAD.W	D3,D2	DEC.W	D330$:	SUB.W	D3,D2	INC.W	D3	NEG.W	D3	LOAD.W	(A6)+OHVASH+OSCPOSV,D3	LOAD.W	D2,(A6)+OHVASV+OSCHTV	INC.W	D2	MUL.WU	D4,D2	DIV.WU	D4,(A6)+OHVDIF+0	COMP.W	D4,D2	JUMP',LO 32$	LOAD.W	D4,D2	DEC.W	D432$:	SUB.W	D4,D2	INC.W	D4	NEG.W	D4	LOAD.W	(A6)+OHVASV+OSCPOSV,D4	LOAD.L	D4,(A6)+OHVPOR	; D4 <-- ancienne valeur	CALL	GETPOSV		; OSCPOSV --> OHVPOR	COMP.L	D4,(A6)+OHVPOR	; position relative change ?	JUMP',EQ 50$		; non => 50$				; oui =>	PUSH.L	(A6)+OHVMOU	TSET.B	(A6)+OHVMOU+1:#BLIVUNCLR-16 ; n'efface pas le dessous	CALL	(A2)		; CALL xxxxUPDATE	POP.L	(A6)+OHVMOU50$:	LIB	?IFCAR		; bouton relch ?	JUMP,NE 20$		; non => 20$	TCLR.B	(A6)+OHVFLG:#BHVMAIN	CALL	FLECMOUSE	; lutin souris = flche	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D5,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; BASELUTIN >;----------/; Modifie v. le lutin de la souris selon la position.; in	-; out	-; mod	D7.WBASELUTIN:	PUSH.L	D4	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE 90$	CALL	BASEPOSM	; souris dans le rectangle ?	JUMP',EQ 40$		; oui => 40$	TCLR.B	(A6)+OHVFLG:#BHVMAIN	JUMP',BC 90$	CALL	FLECMOUSE	; lutin souris = flche	JUMP'	90$40$:	TSET.B	(A6)+OHVFLG:#BHVMAIN	JUMP',BS 90$	CALL	MAINMOUSE	; lutin souris = main90$:	POP.L	D4	RET;---------\\; BASEPOSM >;---------/; Donne la position relative dans le rectangle o agit la main.; in	D4.L	position de la souris (y;x); out	D4.L	position pour la main (y;x);	D7.W	erreur; mod	D4.L, D7.WBASEPOSM:	CLR.W	D7		; D7 <-- ok	SUB.W	D4,(A6)+OHVPOF+2 ; souris trop  gauche ?	JUMP',HS 10$	CLR.W	D4	LOAD.W	D7,#ERDIOUT10$:	COMP.W	D4,(A6)+OHVDIF+2 ; souris trop  droite ?	JUMP',LO 12$	LOAD.W	D4,(A6)+OHVDIF+2	DEC.W	D4	LOAD.W	D7,#ERDIOUT12$:	SWAP.W	D4	SUB.W	D4,(A6)+OHVPOF+0 ; souris trop en haut ?	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	COMP.W	D4,(A6)+OHVDIF+0 ; souris trop en bas ?	JUMP',LO 22$	LOAD.W	D4,(A6)+OHVDIF+0	DEC.W	D4	LOAD.W	D7,#ERDIOUT22$:	SWAP.W	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; BASECLEAR >;----------/; Efface la partie o dessiner.; in	-; out	-; mod	D7.WBASECLEAR:	PUSHM.L	D2..D4	TEST.B	(A6)+OHVMOD+1:#BLIVDMSET-16 ; mode SETDOT ?	JUMP',BS 90$	TEST.B	(A6)+OHVMOD+1:#BLIVDMCLR-16 ; mode CLRDOT ?	JUMP',BS 90$	TEST.B	(A6)+OHVMOD+1:#BLIVDMINV-16 ; mode INVDOT ?	JUMP',BS 90$	TEST.B	(A6)+OHVMOU+1:#BLIVUNCLR-16 ; n'efface pas le dessous ?	JUMP',BS 90$	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfinit trame pour effacer	LOAD.L	D3,(A6)+OHVPOF	; D3 <-- position	LOAD.L	D4,(A6)+OHVDIF	; D4 <-- dimensions	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface tout90$:	POPM.L	D2..D4	RET;--------\\; PUTPOSV >;--------/; OHVPOR --> OSCPOSV; in	-; out	-; mod	D7.WPUTPOSV:	PUSHM.L	D3,D4	LOAD.W	D4,(A6)+OHVASV+OSCHTV	LOAD.W	D3,(A6)+OHVPOR+0	ADD.W	D3,#FACPOSR	MUL.WU	D3,D4	DIV.WU	D3,#FACPOSR*2	TEST.W	D3	JUMP',NC 20$	CLR.W	D320$:	COMP.W	D3,D4	JUMP',LO 22$	LOAD.W	D3,D4	JUMP',EQ 22$	DEC.W	D322$:	LOAD.W	(A6)+OHVASV+OSCPOSV,D3	LOAD.W	D4,(A6)+OHVASH+OSCHTV	LOAD.W	D3,(A6)+OHVPOR+2	ADD.W	D3,#FACPOSR	MUL.WU	D3,D4	DIV.WU	D3,#FACPOSR*2	TEST.W	D3	JUMP',NC 30$	CLR.W	D330$:	COMP.W	D3,D4	JUMP',LO 32$	LOAD.W	D3,D4	JUMP',EQ 32$	DEC.W	D332$:	LOAD.W	(A6)+OHVASH+OSCPOSV,D3	POPM.L	D3,D4	RET;--------\\; GETPOSV >;--------/; OHVPOR <-- OSCPOSV; in	-; out	-; mod	D7.WGETPOSV:	PUSH.L	D3	TEST.W	(A6)+OHVASV+OSCHTV	JUMP',EQ 40$	LOAD.W	D3,(A6)+OHVASV+OSCPOSV	MUL.WU	D3,#FACPOSR*2	DIV.WU	D3,(A6)+OHVASV+OSCHTV	SUB.W	D3,#FACPOSR	LOAD.W	(A6)+OHVPOR+0,D340$:	TEST.W	(A6)+OHVASH+OSCHTV	JUMP',EQ 90$	LOAD.W	D3,(A6)+OHVASH+OSCPOSV	MUL.WU	D3,#FACPOSR*2	DIV.WU	D3,(A6)+OHVASH+OSCHTV	SUB.W	D3,#FACPOSR	LOAD.W	(A6)+OHVPOR+2,D390$:	POP.L	D3	RET;---------\\; WDOOPEN  >;---------/; On travaille dans une sous-fentre quelconque.; in	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WWDOOPEN:	PUSHM.L	D3..D5,A3	TEST.W	(A6)+OHVWDJ	; sous-fentre dj cre ?	JUMP',NE 90$		; oui => 90$	PUSHM.L	D3,D4	LOAD.L	A3,#R16"FREE$	LOAD.W	D3,#2	LIB	?STRING		; y'a plus de modulos	LIB	?GETWDO	LOAD.W	(A6)+OHVWDI,D5	POPM.L	D3,D4	ADD.W	D3,(A0)+ODFFX	INC.W	D3	SWAP.W	D3	ADD.W	D3,(A0)+ODFFY	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LIB	?CREWDO	LOAD.W	(A6)+OHVWDJ,D5	LIB	?USEWDO	LOAD.L	A3,#R16"INIT$	LOAD.W	D3,#2	LIB	?STRING		; remet les modulos90$:	POPM.L	D3..D5,A3	RETFREE$:	.B	MMODULO,1INIT$:	.B	MMODULO,0	.EVEN;---------\\; WDOCLOSE >;---------/; Fin du travail dans une sous-fentre.; in	-; out	-; mod	D7.WWDOCLOSE:	PUSH.L	D5	TEST.W	(A6)+OHVWDJ	; sous-fentre existe ?	JUMP',EQ 90$		; non => 90$	LOAD.W	D5,(A6)+OHVWDI	LIB	?USEWDO	LOAD.W	D5,(A6)+OHVWDJ	LIB	?KILWDO	CLR.W	(A6)+OHVWDJ90$:	POP.L	D5	RET;--------\\; CCMO    >;--------/; Enlve la flche de la souris.; in	-; out	-; mod	D7.WCCMO:	PUSH.W	D3	TEST.W	(A6)+OHVNCM	JUMP',NE 80$	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la flche de la souris80$:	INC.W	(A6)+OHVNCM	POP.W	D3	RET;--------\\; SCMO    >;--------/; Remet la flche de la souris.; in	-; out	-; mod	D7.WSCMO:	PUSH.W	D3	DEC.W	(A6)+OHVNCM	JUMP',NE 80$	LOAD.B	D3,#AFSCMO	LIB	?AFCAR		; remet la flche de la souris80$:	POP.W	D3	RET; Textes fixes; ------------NMSTRET:.ASCIZ	"STRETCH"NMPLAN:	.ASCIZ	"PLANA"	.EVEN	.END