	.SBTTL	LIBDIS; Routines utilitaires pour l'cran; ---------------------------------;-----------\\; _OPEBITMAP >;===========/; Dessine dans un bitmap.; ATTENTION:	dx	doit tre modulo 8;		dy	doit tre modulo 2;		^bitmap	doit tre modulo 2 (adresse pair);; Avec le module GRA.LIB rev 1.11, les primitives suivantes peuvent; tre utilises en mmoire :;	GRA_RASTER	(raster-op);	GRA_DOT;	GRA_LINE	(avec trait ou pinceau);	GRA_CIRCLE	(avec trait ou pinceau);	GRA_ELLIPSE	(avec trait ou pinceau);	GRA_TRAME	(trames rectangulaires);	GRA_MATRIX	(caractres);	GRA_FILLO	(remplissage quelconque); in	D4.L	dimensions (dy;dx);	A4.L	^dbut du bitmap; out	-; mod	D7.W_OPEBITMAP:	PUSHM.L	D4,A0	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur rel	LOAD.L	(A6)+OSDFABS,(A0)+ODFABS	LOAD.W	(A6)+OSDFIIX,(A0)+ODFIIX	LOAD.W	(A6)+OSDFIIY,(A0)+ODFIIY	LOAD.L	(A6)+OSDFY,(A0)+ODFY	LOAD.L	(A6)+OSDFDY,(A0)+ODFDY	LOAD.L	(A6)+OSDFFY,(A0)+ODFFY	LOAD.L	(A6)+OSDFFDY,(A0)+ODFFDY	LOAD.L	(A6)+OSDFWBY,(A0)+ODFWBY	LOAD.L	(A6)+OSDFWEY,(A0)+ODFWEY	LOAD.W	(A6)+OSDFTTC,(A0)+ODFTTC	LOAD.L	(A0)+ODFABS,A4	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	LOAD.W	(A0)+ODFIIX,#1	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.W	(A0)+ODFIIY,D4	POPM.L	D4,A0	CLR.W	D7		; retour EQ	RET;-----------\\; _CLOBITMAP >;===========/; Dessine dans l'cran.; in	-; out	-; mod	D7.W_CLOBITMAP:	PUSH.L	A0	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur rel	LOAD.L	(A0)+ODFABS,(A6)+OSDFABS	LOAD.W	(A0)+ODFIIX,(A6)+OSDFIIX	LOAD.W	(A0)+ODFIIY,(A6)+OSDFIIY	LOAD.L	(A0)+ODFY,(A6)+OSDFY	LOAD.L	(A0)+ODFDY,(A6)+OSDFDY	LOAD.L	(A0)+ODFFY,(A6)+OSDFFY	LOAD.L	(A0)+ODFFDY,(A6)+OSDFFDY	LOAD.L	(A0)+ODFWBY,(A6)+OSDFWBY	LOAD.L	(A0)+ODFWEY,(A6)+OSDFWEY	LOAD.W	(A0)+ODFTTC,(A6)+OSDFTTC	POP.L	A0	CLR.W	D7		; retour EQ	RET;---------\\; _GETPDIS >;=========/; Donne le pointeur au descripteur rel de la fentre.; in	-; out	A4.L	^descripteur rel;	D7.W	erreur; mod	D7.W, A4.L_GETPDIS:	LOAD.W	D7,#ERDIOUT	LOAD.L	A4,#0	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP',NE 90$		; non => 90$	LOAD.L	A4,(A6)+OPDDIS	; A4 <-- ^descripteur de la fentre	CLR.W	D7		; D7 <-- ok90$:	TEST.W	D7		; retour EQ/NE	RET;--------\; _GETDIM >;========/; in	-; out	D3.L	dimensions (y;x) d'un caractre;	D4.L	dimensions (y;x) de la fentre;	D7.W	erreur; mod	D3.L, D4.L, D7.W_GETDIM:	PUSH.L	A4	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP',NE 50$		; non => 50$	LOAD.L	A4,(A6)+OPDDIS	; A4 <-- ^descripteur de la fentre	LOAD.W	D3,(A4)+ODFCY	; D3 <-- interligne	SWAP.W	D3	LOAD.W	D3,(A4)+ODFCX	; D3 <-- intercaractre	LOAD.W	D4,(A4)+ODFDY	; D4 <-- dimension en Y	SWAP.W	D4	LOAD.W	D4,(A4)+ODFDX	; D4 <-- dimension en X	JUMP'	90$50$:	LOAD.W	D4,#-1		; dim. fentre Y par dfaut	SWAP.W	D4	LOAD.W	D4,#500		; dim. fentre X par dfaut	LOAD.W	D3,#16		; dim. caractre Y par dfaut	SWAP.W	D3	LOAD.W	D3,#8		; dim. caractre X par dfaut90$:	POP.L	A4	RET;--------\; _LGXCAR >;========/; Donne la largeur (x) d'un caractre en fonction du; gnrateur de caractres utilis.; in	D3.B	caractre; out	D4.W	largeur en points;	D7.W	erreur; mod	D4.W, D7.W_LGXCAR:	PUSHM.L	D0,D3,A4	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP',NE 50$		; non => 50$	CLR.W	D0	LOAD.B	D0,D3		; D0 <-- caractre	LOAD.L	A4,(A6)+OPDDIS	; A4 <-- ^descripteur de la fentre	LOAD.L	A4,(A4)+ODFPGC	; A4 <-- ^dbut GENCAR	SUB.B	D0,(A4)+OGCFCA	ADD.L	A4,#OGCWID	CLR.W	D4	LOAD.B	D4,(A4)+(D0.W)	; D4 <-- largeur	JUMP'	90$50$:	LOAD.W	D4,#8		; dim. caractre X par dfaut90$:	POPM.L	D0,D3,A4	RET;--------\; _AFDEC  >;========/; Affiche un nombre en dcimal, avec la possibilit d'afficher; ou pas les zros non significatifs.; in	D4.L	nombre binaire;	D3.B	nombre de digits  afficher (1..10);	D2.W	mode d'affichage (BAFDxxx); out	D7.W	erreur; mod	D0..A0, D7.W_AFDEC:	PUSH.L	A4	LOAD.L	A4,#(A6)+OBUWRI	; A4 <-- ^buffer	CALL	_PUTDEC		; OBUWRI <-- nombre	LOAD.L	A0,A4	CALL	WRBUF	POP.L	A4	RET;--------\; _PUTDEC >;========/; Met dans un buffer un nombre en dcimal, avec la possibilit; de reprsenter ou non les zros non significatifs.; in	D4.L	nombre binaire;	D3.B	nombre de digits  afficher (1..10);	D2.W	mode d'affichage (BAFDxxx);	A4.L	^buffer; out	A4.L	^buffer;	D7.W	erreur; mod	D0..A0, D7.W, A4.L_PUTDEC:	PUSHM.L	D2..D5,A3	LOAD.L	A3,#R16"TABLE$	; A3 <-- ^table	LOAD.B	D5,#10		; D5 <-- compteur pour '	LOAD.B	D1,D5	COMP.B	D3,D5	JUMP',LS 05$	LOAD.B	D3,D105$:	SUB.B	D1,D3		; D1 <-- nb digits  sauter	JUMP',EQ 15$	PUSH.W	D310$:	CALL	NEXT$		; D4 <-- saute un digit	DEC.B	D1	JUMP,NE 10$	POP.W	D315$:	LOAD.B	D1,D320$:	DEC.B	D1	JUMP',EQ 30$	CALL	NEXT$		; D3 <-- digit suivant	CALL	PUT$		; affiche (ou pas) un digit	JUMP	20$30$:	TSET.L	D2:#BAFDALL	CALL	NEXT$		; D3 <-- dernier digit	CALL	PUT$		; affiche le dernier digit	CLR.B	(A4)		; met un terminateur	POPM.L	D2..D5,A3	CLR.W	D7		; D7 <-- ok	RET; in	D4.L	nombre;	A3.L	^table;	D5.B	compteur pour '; out	D4.L	reste nombre;	A3.L	^suivant;	D5.B	compteur pour ';	D3.B	digit 0..9NEXT$:	PUSHM.L	D1,D2	LOAD.L	D3,(A3+)	LOAD.L	D2,(A3+)	LOAD.L	D1,(A3+)NEXT2$:	COMP.L	D4,D2	JUMP',HS NEXT4$	SUB.L	D2,D1	DEC.W	D3	JUMP	NEXT2$NEXT4$:	SUB.L	D4,D2	DEC.B	D5		; D5 <-- mj compteur '	POPM.L	D1,D2	RET; in	D2.B	mode;	D3.B	digit 0..9;	D5.B	compteur pour '; out	D2.B	nouveau modePUT$:	TEST.L	D2:#BAFDALL	; faut-il tout afficher ?	JUMP',BS PUT5$		; oui => PUT5$	TEST.B	D3		; "0" ?	JUMP',NE PUT5$		; non => PUT5$	TEST.L	D2:#BAFDCM	; affichage "compact" ?	JUMP',BS PUT9$		; oui => PUT9$	LOAD.B	D3,#SPACE	LOAD.B	(A4+),D3	; met un blanc	JUMP'	PUT6$PUT5$:	TSET.L	D2:#BAFDALL	; maintenant faut tout afficher	ADD.W	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	; affiche un digit dcimal	LOAD.B	D3,#''		; D3 <-- sparateur 'PUT6$:	TEST.L	D2:#BAFDSP	; faut-il afficher ' ?	JUMP',BC PUT9$		; non => PUT9$	COMP.B	D5,#3	JUMP',EQ PUT7$	COMP.B	D5,#6	JUMP',EQ PUT7$	COMP.B	D5,#9	JUMP',NE PUT9$PUT7$:	LOAD.B	(A4+),D3	; met '/SPACE aprs digitPUT9$:	RETTABLE$:	.L	4,4000000000,1000000000	.L	9,900000000,100000000	.L	9,90000000,10000000	.L	9,9000000,1000000	.L	9,900000,100000	.L	9,90000,10000	.L	9,9000,1000	.L	9,900,100	.L	9,90,10	.L	9,9,1;--------\; _AFX8   >;========/; Affiche un nombre de huit digits hexadcimal.; in	D4.L	valeur  afficher; out	D7.W	erreur; mod	D0..A0, D7.W_AFX8:	LOAD.L	A0,#(A6)+OBUWRI	CALL	AFX8	JUMP	WRBUF;--------\; _AFX4   >;========/; Affiche un nombre de quatre digits hexadcimal.; in	D4.W	valeur  afficher; out	D7.W	erreur; mod	D0..A0, D7.W_AFX4:	LOAD.L	A0,#(A6)+OBUWRI	CALL	AFX4	JUMP	WRBUF;--------\; _AFX2   >;========/; Affiche un nombre de deux digits hexadcimal.; in	D4.B	valeur  afficher; out	D7.W	erreur; mod	D0..A0, D7.W_AFX2:	LOAD.L	A0,#(A6)+OBUWRI	CALL	AFX2	JUMP	WRBUF;--------\; AFX8    >;--------/; Affiche un nombre de huit digits hexadcimal.; in	D4.L	valeur  afficher;	A0.L	^dans buffer; out	A0.L	^plus loin; mod	A0.LAFX8:	SWAP.W	D4	CALL	AFX4		; affiche quatre 1er digits	SWAP.W	D4;--------\; AFX4    >;--------/; Affiche un nombre de quatre digits hexadcimal.; in	D4.W	valeur  afficher;	A0.L	^dans buffer; out	A0.L	^plus loin; mod	A0.LAFX4:	PUSH.W	D4	SR.W	D4,#8	CALL	AFX2		; affiche deux 1er digits	POP.W	D4;--------\; AFX2    >;--------/; Affiche un nombre de deux digits hexadcimal.; in	D4.B	valeur  afficher;	A0.L	^dans buffer; out	A0.L	^plus loin; mod	A0.LAFX2:	PUSHM.L	D3,D4	LOAD.B	D3,D4	SR.B	D3,#4	CALL	AFDIGIT		; affiche premier digit	LOAD.B	D3,D4	CALL	AFDIGIT		; affiche deuxime digit	POPM.L	D3,D4	RET;--------\; AFDIGIT >;--------/; Affiche un digit hexadcimal.; in	D3.B	affiche les 4 bits 0..3;	A0.L	^dans buffer; out	A0.L	^plus loin; mod	A0.LAFDIGIT:	PUSH.W	D3	AND.B	D3,#H'F	ADD.B	D3,#'0	COMP.B	D3,#'9		; '0..'9  ?	JUMP',LS 50$		; oui => 50$	ADD.B	D3,#'A-'9-1	; D3 <-- 'A..'F50$:	LOAD.B	(A0+),D3	; affiche '0..'9 ou 'A..'F90$:	POP.W	D3	RET;--------\; _AFB8   >;========/; in	D4.B	valeur  afficher en binaire; out	D7.W	erreur; mod	D0..A0, D7.W_AFB8:	PUSHM.L	D2,D3,D4	LOAD.L	A0,#(A6)+OBUWRI	LOAD.B	D2,#8.10$:	LOAD.B	D3,#'0	SL.B	D4,#1	JUMP,CC 20$	INC.B	D320$:	LOAD.B	(A0+),D3	; affiche "0" ou "1"	DEC.B	D2	JUMP,NE 10$	CALL	WRBUF	POPM.L	D2,D3,D4	RET;---------\; _AFERROR >;=========/; Affiche sur l'cran une erreur en clair.; in	D7.W	numro d'erreur  afficher; out	D7.W	erreur; mod	D7.W_AFERROR:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBULINE ; A4 <-- ^buffer de ligne	FOS	?ERROR	LOAD.L	A3,A4		; A3 <-- ^erreur en clair	CALL	_AFTEXT		; affiche l'erreur	POPM.L	A3,A4	RET;---------\; _SMAFTIM >;=========/; Affiche un texte dans une langue quelconque.; Voir remarque importante sous _SAFTIM !; in	-; out	D7.W	erreur; mod	D7.W_SMAFTIM:	PUSH.L	A3	LOAD.L	A3,(SP)+7*4+2	; A3 <-- ^textes .ASCIZ /<'c> /	CALL	_MAFTEXT	; affiche un texte	LOAD.L	(SP)+7*4+2,A3	; corrige l'adresse de retour	POP.L	A3	RET;--------\; _MAFTIM >;========/; Affiche un texte dans une langue quelconque.; in	-; out	D7.W	erreur; mod	D7.W_MAFTIM:	PUSH.L	A3	LOAD.L	A3,(SP)+4	; A3 <-- ^textes .ASCIZ /<'c> /	CALL	_MAFTEXT	; affiche un texte	LOAD.L	(SP)+4,A3	; corrige l'adresse de retour	POP.L	A3	RET;---------\; _MAFTEXT >;=========/; Affiche un texte dans la langue choisie.; in	A3.L	^texte en plusieurs langues; out	A3.L	^plus loin (align);	D7.W	erreur; mod	D7.W, A3.L_MAFTEXT:	PUSHM.L	D3,D4,A4	FOS	?OPINFO		; A4 <-- ^contenu SYSTEM.INFO	LOAD.B	D3,(A4)+OINLAN	; D3 <-- langue	CLR.W	D4		; pas de mise  jour	FOS	?CLINFO		; "rend" SYSTEM.INFO	LOAD.L	A4,A3		; A4 <-- ^texte par dfaut10$:	COMP.B	D3,(A3)		; texte de la bonne langue ?	JUMP',EQ 50$		; oui => 50$20$:				; non =>	TEST.B	(A3+)		; saute un .ASCIZ	JUMP,NE 20$	TEST.B	(A3)		; fin des .ASCIZ ?	JUMP,NE 10$		; non => 10$				; oui =>	LOAD.L	A3,A4		; A3 <-- ^premier texte50$:	INC.L	A3		; saute lettre pour la langue	PUSH.L	A3	CALL	_AFTEXT		; affiche le texte	POP.L	A355$:	TEST.B	(A3+)		; saute un .ASCIZ	JUMP,NE 55$60$:	TEST.B	(A3+)		; fin de tous les .ASCIZ ?	JUMP,NE 55$		; non => 55$				; oui =>	LOAD.L	D3,A3	TEST.L	D3:#0		; adresse paire ?	JUMP',EQ 90$		; oui => 90$	INC.L	A3		; non => align sur un word90$:	POPM.L	D3,D4,A4	RET;--------\; _SAFTIM >;========/; Cette routine ne peut tre appele que depuis la routine; d'appel systme. En effet, l'adresse sur le stack n'est pas; la mme qu'avec un CALL direct !; Pour un CALL direct, il faut utiliser _AFTIM.; in	-; out	D7.W	erreur; mod	D7.W_SAFTIM:	PUSH.L	A3	LOAD.L	A3,(SP)+7*4+2	; A3 <-- ^texte	CALL	_AFTEXT		; affiche un texte	EX.L	D3,A3	TEST.L	D3:#0		; est-ce que A3 est pair ?	EX.L	A3,D3	JUMP',EQ 50$		; oui => 50$	INC.L	A3		; non => aligne sur un word50$:	LOAD.L	(SP)+7*4+2,A3	; corrige l'adresse de retour	POP.L	A3	RET;--------\; _AFTIM  >;========/; in	-; out	D7.W	erreur; mod	D7.W_AFTIM:	PUSH.L	A3	LOAD.L	A3,(SP)+4	; A3 <-- ^texte	CALL	_AFTEXT		; affiche un texte	EX.L	D3,A3	TEST.L	D3:#0		; est-ce que A3 est pair ?	EX.L	A3,D3	JUMP',EQ 50$		; oui => 50$	INC.L	A3		; non => aligne sur un word50$:	LOAD.L	(SP)+4,A3	; corrige l'adresse de retour	POP.L	A3	RET;--------\; _AFTEXT >;========/; Affiche un texte termin par un zro.; in	A3.L	^texte  afficher .ASCIZ; out	A3.L	^plus loin;	D7.W	erreur; mod	D7.W, A3.L_AFTEXT:	PUSHM.L	D4,D6,A4	LOAD.L	A4,A3		; A4 <-- ^texte  afficher	CLR.L	D4		; D4 <-- future longueur texte	DEC.L	D410$:	INC.L	D4		; D4 <-- un caractre de plus	TEST.B	(A3+)		; fin du texte ?	JUMP,NE 10$	TEST.L	D4		; texte de longueur nulle ?	JUMP',EQ 90$		; oui => 90$				; non =>	CALL	WRMULC		; crit tout le texte90$:	POPM.L	D4,D6,A4	RET;--------\; _STRING >;========/; Affiche un nombre quelconque de caractres.; in	A3.L	^texte quelconque;	D3.W	longueur du texte; out	D7.W	erreur; mod	D7.W_STRING:	PUSHM.L	D4,A4	CLR.L	D4	LOAD.W	D4,D3		; D4 <-- longueur	JUMP',EQ 90$		; si lg nulle => 90$	LOAD.L	A4,A3		; A4 <-- ^caractres	CALL	WRMULC		; crit plusieurs caractres90$:	POPM.L	D4,A4	RET;---------\; _AFSPACE >;=========/; in	-; out	D7.W	erreur; mod	D7.W_AFSPACE:	PUSH.W	D3	LOAD.B	D3,#SPACE	CALL	_AFCAR	POP.W	D3	RET;--------\; _AFCR   >;========/; in	-; out	D7.W	erreur; mod	D7.W_AFCR:	PUSH.W	D3	LOAD.B	D3,#CR	CALL	_AFCAR	POP.W	D3	RET;--------\; _AFTAB  >;========/; in	-; out	D7.W	erreur; mod	D7.W_AFTAB:	PUSH.W	D3	LOAD.B	D3,#TAB	CALL	_AFCAR	POP.W	D3	RET;--------\; _AFBS   >;========/; in	-; out	D7.W	erreur; mod	D7.W_AFBS:	PUSH.W	D3	LOAD.B	D3,#BS	CALL	_AFCAR	POP.W	D3	RET;--------\; _AFCODE >;========/; in	D3.B	code  afficher; out	D7.W	erreur; mod	D7.W_AFCODE:	PUSHM.L	D3,A0	COMP.B	D3,#SPACE	; caractre H'20..H'7F ?	JUMP',LO 20$		; non => 20$	COMP.B	D3,#H'7F	JUMP',HS 20$		; oui =>10$:	CALL	_AFCAR		; affiche normalement	JUMP'	90$20$:	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP,NE	10$		; non => 10$	LOAD.L	A0,#(A6)+OBUWRI	; A0 <-- ^petit buffer	TCLR.L	D3:#7		; caractre invers ?	JUMP',NE 50$		; oui => 50$				; non =>	LOAD.B	(A0+),#AFTOUT	LOAD.B	(A0+),D3	LOAD.B	(A0+),#AFNORM	JUMP'	80$50$:	LOAD.B	(A0+),#AFINV	; vido inverse	LOAD.B	(A0+),#AFTOUT	LOAD.B	(A0+),D3	LOAD.B	(A0+),#AFNORM	LOAD.B	(A0+),#AFDIR	; vido normale80$:	CALL	WRBUF90$:	POPM.L	D3,A0	RET;--------\; _AFCAR  >;========/; in	D3.B	caractre  afficher; out	D7.W	erreur; mod	D7.W_AFCAR:	JUMP	WRONEC		; crit un caractre;---------\; _GETCURS >;=========/; in	-; out	D3.L	position (y;x);	D7.W	erreur; mod	D3.L, D7.W_GETCURS:	PUSH.L	A4	CALL	_FLUSH		; vide buffer pour que la posi-				; tion soit correcte !	CLR.L	D3		; rend position zro si erreur	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP',NE 90$		; non => 90$	LOAD.L	A4,(A6)+OPDDIS	; A4 <-- ^descripteur de la fentre	LOAD.L	D3,(A4)+ODFPY	; D3 <-- position en (Y;X)90$:	POP.L	A4	RET;---------\; _SETCURS >;=========/; in	D3.L	position (y;x); out	D7.W	erreur; mod	D7.W_SETCURS:	PUSH.L	A0	LOAD.L	A0,#(A6)+OBUWRI	LOAD.B	(A0+),#NUL	LOAD.B	(A0+),#TYPOAX	LOAD.W	(A0+),D3	; <xx>	SWAP.W	D3	LOAD.B	(A0+),#NUL	LOAD.B	(A0+),#TYPOAY	LOAD.W	(A0+),D3	; <yy>	SWAP.W	D3	CALL	WRBUF	POP.L	A0	RET;--------\; WRBUF   >;========/; Ecrit dans l'cran le contenu du buffer OBUWRI.; in	A0.L	^dans OBUWRI;	A6.L	^variables user; out	D7.W	erreur; mod	D7.WWRBUF:	PUSHM.L	D4,A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,#(A6)+OBUWRI	; A4 <-- ^caractres  crire	LOAD.L	D4,A0	SUB.L	D4,A4		; D4 <-- longueur dans buffer	JUMP',EQ 90$	CALL	WRMULC		; crit plusieurs caractres90$:	POPM.L	D4,A4	RET;--------\; _BUCAR  >;========/; Passe dans un mode o tous les caractres sont mis dans; un buffer pour tre crits  la fin de la ligne.; in	-; out	D7.W	erreur; mod	D7.W_BUCAR:	CALL	_FLUSH		; vide le buffer	TSET.B	(A6)+OFLAGS:#BMBUFF	RET;---------\; _NOBUCAR >;=========/; Passe dans un mode o tous les caractres sont directement; crits dans l'cran.; in	-; out	D7.W	erreur; mod	D7.W_NOBUCAR:	CALL	_FLUSH		; vide le buffer	TCLR.B	(A6)+OFLAGS:#BMBUFF	RET;--------\; WRMULC  >;========/; Ecrit plusieurs caractres directement ou dans un buffer.; in	A4.L	^caractres;	D4.L	nombre de caractres; out	D7.W	erreur; mod	D7.WWRMULC:	PUSHM.L	D0,D4,D6,A0,A4	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLAGS:#BMBUFF ; mode bufferis ?	JUMP',EQ 50$		; non => 50$10$:				; oui =>;;?	COMP.B	(A4),#CR	; fin de ligne ?;;?	JUMP',EQ 15$		; oui => 15$	COMP.W	(A6)+OPTBUF,#LGBUFF ; buffer plein ?	JUMP',LO 20$		; non => 20$15$:	CALL	_FLUSH		; oui => vide le buffer20$:	LOAD.W	D0,(A6)+OPTBUF	LOAD.B	(A6)+(D0.W)+OBUFFER,(A4+) ; buffer <-- car	INC.W	(A6)+OPTBUF	DEC.L	D4	JUMP,NE 10$	JUMP'	90$50$:	LOAD.W	D6,(A6)+OCHDIS	; D6 <-- canal pour l'cran	CALL	WRBWDO		; FOS,?WRBYTE90$:	POPM.L	D0,D4,D6,A0,A4	RET;--------\; WRONEC  >;========/; Ecrit un caractre directement ou dans un buffer.; in	D3.B	caractre; out	D7.W	erreur; mod	D7.WWRONEC:	PUSHM.L	D4,D6,A4	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFLAGS:#BMBUFF ; mode bufferis ?	JUMP',EQ 50$		; non => 50$				; oui =>	COMP.W	(A6)+OPTBUF,#LGBUFF ; buffer plein ?	JUMP',LO 10$		; non => 10$	CALL	_FLUSH		; oui => vide le buffer10$:	LOAD.W	D4,(A6)+OPTBUF	LOAD.B	(A6)+(D4.W)+OBUFFER,D3 ; buffer <-- caractre	INC.W	(A6)+OPTBUF	COMP.B	D3,#CR		; fin de ligne ?	JUMP',NE 90$		; non => 90$	CALL	_FLUSH		; oui => vide le buffer	JUMP'	90$50$:	LOAD.W	D6,(A6)+OCHDIS	; D6 <-- canal pour l'cran	LOAD.L	A4,#(A6)+OBUWRI	; A4 <-- ^caractre  crire	LOAD.L	D4,#1		; D4 <-- un caractre  crire	LOAD.B	(A4),D3		; met le caractre en (A4)	CALL	WRBWDO		; FOS,?WRBYTE90$:	POPM.L	D4,D6,A4	RET;--------\; _FLUSH  >;========/; Ecrit le contenu du buffer OBUFFER dans l'cran, puis vide; le buffer.; in	-; out	D7.W	erreur; mod	D7.W_FLUSH:	PUSHM.L	D4,D6,A4	LOAD.W	D6,(A6)+OCHDIS	; D6 <-- canal pour l'cran	LOAD.L	A4,#(A6)+OBUFFER ; A4 <-- ^caractres  crire	CLR.L	D4	LOAD.W	D4,(A6)+OPTBUF	; D4 <-- nb de caractres	JUMP',EQ 90$		; si rien  crire => 90$	CALL	WRBWDO		; FOS,?WRBYTE	CLR.W	(A6)+OPTBUF	; clear le "pointeur"90$:	POPM.L	D4,D6,A4	RET;--------\; WRBWDO  >;========/; Routine exactement quivalente  FOS,?WRBYTE, avec en plus; un compteur du nombre de CR pour pouvoir stopper lorsque; la page est pleine.; Revient avec l'erreur EROUTF si la touche (END) est appuye.; in	A4.L	^caractres  crire;	D4.L	nombre de caractres  crire;	D6.W	canal; out	D4.L	nombre de caractres effectivement crits;	D7.W	erreur; mod	D7.WWRBWDO:	PUSHM.L	D0,D1,D2,D3,A2,A3,A4	TEST.B	(A6)+OFLAGS:#BWDKEY ; attend touche si plein ?	JUMP,EQ 85$		; non => 85$	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP,NE	85$		; non => 85$	CLR.W	D7		; D7 <-- ok	LOAD.L	D3,D4		; D3 <-- nb bytes  crire	LOAD.L	A3,A4		; A3 <-- ^caractres	LOAD.W	D0,(A6)+OMAXLI	; D0 <-- nb lignes dans fentre	CLR.B	D2		; D2 <-- nb param. si commande10$:	TEST.L	D3		; reste qq chose ?	JUMP,EQ 80$		; non => 80$	LOAD.B	D1,(A3+)	; D1 <-- un caractre	DEC.L	D3		; D3 <-- dcompte	TEST.B	D2		; attend param. commande ?	JUMP',EQ 20$		; non => 20$	DEC.B	D2		; D2 <-- un param. de moins	JUMP	10$20$:	COMP.B	D1,#SPACE	JUMP',LO 50$		; test rapide s'il s'agit d'un	COMP.B	D1,#H'80	; caractre "normal" ?	JUMP',LO 10$		; oui => 10$				; non =>	COMP.B	D1,#AFTOUT	JUMP',EQ 40$	COMP.B	D1,#AFNORM	JUMP',EQ 45$	LOAD.L	A2,#R16"01$-230$:	ADD.L	A2,#2		; A2 <-- ^suivant dans 01$	TEST.B	(A2)+0		; fin de la table ?	JUMP,EQ	10$		; oui => 10$	COMP.B	D1,(A2)+0	; car. trouv dans table ?	JUMP,NE	30$		; non => 30$	LOAD.B	D2,(A2)+1	; D2 <-- nb param. attendus	JUMP	10$40$:	TSET.B	(A6)+OFLAGS:#BAFTOUT	JUMP	10$45$:	TCLR.B	(A6)+OFLAGS:#BAFTOUT	JUMP	10$50$:	TEST.B	(A6)+OFLAGS:#BAFTOUT	JUMP,BS 10$	COMP.B	D1,#CR	JUMP',EQ 70$	COMP.B	D1,#LF		; ajout le 30.1.85 pour FJ !	JUMP',EQ 70$	COMP.B	D1,#EOP	JUMP,NE 10$	CLR.W	(A6)+OCNTLI	; clear compteur de lignes	JUMP	10$70$:	INC.W	(A6)+OCNTLI	; une ligne de plus	COMP.W	D0,(A6)+OCNTLI	; fentre pleine ?	JUMP,HI 10$		; non => 10$				; oui =>	LOAD.L	D4,A3	SUB.L	D4,A4		; D4 <-- lg  crire	FOS	?WRBYTE		; crit un "bout"	JUMP,NS 90$		; si erreur grve => 90$	LOAD.L	A4,A3		; A4 <-- ^nouveau dbut	TEST.W	(A6)+OCHKEY	; clavier existe ?	JUMP,EQ 10$		; non => 10$				; oui =>	PUSHM.L	D2,D3,A3	LOAD.B	D2,(A6)+OFLAGS	; D2 <-- mm. flags	TCLR.B	(A6)+OFLAGS:#BMBUFF ; mode non bufferis	TCLR.B	(A6)+OFLAGS:#BWDKEY ; n'attend pas si plein	LIB	?MAFTIM	.ASCIZ	/<'F><AFINV>Appuyez sur une touche ...<AFDIR>/	.ASCIZ	/<'E><AFINV>Strike any key ...<AFDIR>/	.B	0	.EVEN	LIB	?GETCAR		; attend une touche ...	LOAD.B	D1,D3		; D1 <-- touche appuye	LOAD.L	A3,#R16"00$	LOAD.W	D3,#3+1	LIB	?STRING		; efface "strike any key"	LOAD.B	(A6)+OFLAGS,D2	; remet les flags corrects	POPM.L	D2,D3,A3	COMP.B	D1,#END		; touche (END) ?	JUMP,NE 10$		; non => 10$	LOAD.W	D7,#EROUTF	; oui => rend une erreur	JUMP'	90$80$:	LOAD.L	D4,A3	SUB.L	D4,A4		; D4 <-- lg  crire	JUMP',EQ 90$		; si reste rien => 90$85$:	FOS	?WRBYTE		; crit dernier "bout"90$:	POPM.L	D0,D1,D2,D3,A2,A3,A4	RET00$:	.B	TYPOAX,0,0	; revient au dbut de la ligne	.B	EFLI		; efface "strike any key"	.EVEN; Cette table donne le nombre de paramtres attendus pour; tous les caractres spciaux du driver cran.01$:	.B	CARXY		2	.B	GRAXY		4	.B	MSPACE		1	.B	ROLLUP		2	.B	ROLLDOWN	2	.B	TRAME		8	.B	PEN		8	.B	MAPTT		2	.B	PROCURS		1	.B	USEGC		3	.B	LOADGC		3	.B	KILLGC		3	.B	MODCAR		1	.B	DIMWDO		8	.B	MODGRA		1	.B	TYPOAX		2	.B	TYPOAY		2	.B	TYPORX		1	.B	TYPORY		1	.B	HSPACE		1	.B	VSPACE		1	.B	COLORSA		6	.B	COLORCA		6	.B	COLORSR		4	.B	COLORCR		4	.B	DRAWDOT		5	.B	DRAWLINE	5	.B	DRAWSEG		9	.B	DRAWCERCLE	3	.B	DRAWTRAME	9	.B	DRAWMATRIX	9	.B	DRAWARC		9	.B	DRAWFILLO	4	.B	DRAWRASTER	25	.B	DRAWMOUSE	13	.B	DRAWOSPRITE	17	.B	DRAWMSPRITE	5	.B	DRAWESPRITE	1	.B	DRAWCSPRITE	1	.B	DRAWELLIPSE	11	.B	0	.EVEN;---------\; _DISWKEY >;=========/; in	D3.B	zro  => n'attend pas si fentre pleine;		autre => attend une touche si fentre pleine; out	D7.W	erreur; mod	D7.W_DISWKEY:	PUSHM.L	D4,A4	TCLR.B	(A6)+OFLAGS:#BWDKEY	TEST.B	D3		; D3 = zro ?	JUMP',EQ 90$		; oui => 90$	COMP.B	(A6)+OTYPDIS,#TYPWDO ; type fentre ?	JUMP',NE 90$		; non => 90$	LOAD.L	A4,(A6)+OPDDIS	; A4 <-- ^descripteur de la fentre	CLR.L	D4	LOAD.W	D4,(A4)+ODFFDY	; D4 <-- hauteur swdo	DIV.WU	D4,(A4)+ODFCY	; D4 <-- Hswdo / Hcar	DEC.W	D4		; D4 <-- une de moins	LOAD.W	(A6)+OMAXLI,D4	; mm. nb max de lignes	TSET.B	(A6)+OFLAGS:#BWDKEY	CLR.W	(A6)+OCNTLI	; clear compteur de lignes90$:	POPM.L	D4,A4	RET	.END