	.SBTTL	LIBCOM;--------\; _GTCOMM >;========/; Donne le type correspondant  un caractre.; in	D3.B	caractre (si zro => rend zro); out	D3.W	type correspondant; mod	D3.W_GTCOMM:	PUSH.L	A3	LIB	?MINMAJ		; D3 <-- lettre majuscule	LOAD.L	A3,#R16"00$-210$:	ADD.L	A3,#2		; A3 <-- ^suivant	TEST.B	(A3)		; fin de la table ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,(A3)		; trouv ?	JUMP,NE 10$		; non => 10$50$:	CLR.W	D3	LOAD.B	D3,(A3)+1	; D3 <-- type BIOS (TYP...)	CLR.W	D7		; D7 <-- toujours ok	POP.L	A3	RET00$:	.B	'M,TYPMM	.B	'K,TYPKEY	.B	'D,TYPDIS	.B	'W,TYPWDO	.B	'I,TYPIO	.B	'P,TYPPRI	.B	'N,TYPNETW	.B	0,0		; type par dfaut (inconnu)	.EVEN;--------\; _TRCOMM >;========/; Transforme les paramtres d'une commande pour pouvoir tre; traits par l'appel ?COMMAND.; Exemples corrects:;	F;	B9600;	V[12];	FW,PSos,[500.L];	XYZ[-12.w]ABC[+98.W]; La commande peut tre termine par NUL, CR ou SPACE.; in	A3.L	^commande en ASCII;	A4.L	^buffer;	D4.W	longueur du buffer; out	D7.W	ok (zro);	 A3.L	 ^plus loin;	D7.W	erreur;	 A3.L	 ^sur l'erreur; mod	D7.W, A3.L_TRCOMM:	PUSHM.L	D0,D1,D3,D4,A4	CLR.L	D1	LOAD.W	D1,D4		; D1 <-- longueur du buffer	ADD.L	A4,D1		; A4 <-- ^fin du buffer10$:	LOAD.B	(-A4),#H'FF	; rempli le buffer de -1	DEC.W	D1	JUMP,NE 10$	LOAD.W	D7,#ERLSYN	; D7 <-- erreur de syntaxe30$:	LOAD.B	D3,(A3)		; D3 <-- un car. de la commande	JUMP,EQ	70$	COMP.B	D3,#CR		; fin des commandes ?	JUMP,EQ 70$ 		; oui => 70$	INC.L	A3		; A3 <-- ^car. suivant	COMP.B	D3,#SPACE	JUMP,EQ	70$	COMP.B	D3,#'[		; dbut d'un nombre +/- ?	JUMP',EQ 50$		; oui => 50$	LIB	?MINMAJ		; D3 <-- lettre MAJUSCULE	LOAD.B	D1,D340$:				; met un .B en (A4) :	LOAD.B	(A4+),D1	; stocke une commande	DEC.W	D4		; D4 <-- un byte de plus	JUMP,NE	30$	LOAD.W	D7,#ERLBFU	JUMP	90$50$:	CLR.B	D0		; D0 <-- signe positif	CLR.L	D1		; D1 <-- nombre de dpart	COMP.B	(A3),#'+	; nombre positif ?	JUMP',EQ 51$		; oui => 51$	COMP.B	(A3),#'-	; nombre ngatif ?	JUMP',NE 52$		; non => 52$ (positif sans "+")	INC.B	D0		; D0 <-- signe ngatif51$:	INC.L	A3		; A3 <-- saute le signe +/-52$:	LOAD.B	D3,(A3+)	; D3 <-- caractre suivant	JUMP,EQ	80$	COMP.B	D3,#CR		; nombre termin sans "]" ?	JUMP,EQ 80$ 		; oui => 80$	COMP.B	D3,#']		; fin du nombre ?	JUMP,EQ 60$		; oui => 60$	COMP.B	D3,#'.		; type spcifi ?	JUMP',EQ 55$		; oui => 55$	COMP.B	D3,#'0	JUMP,LO 80$	COMP.B	D3,#'9		; caractre 0..9 ?	JUMP,HI 80$		; non => 80$	SL.L	D1,#1	PUSH.L	D1	SL.L	D1,#2	ADD.L	D1,(SP+)	; D1 <-- D1 * 10	SUB.B	D3,#'0		; D3 <-- 0..9	AND.L	D3,#H'FF	ADD.L	D1,D3		; D1 <-- un digit de plus	JUMP	52$55$:	LOAD.B	D3,(A3+)	; D3 <-- B,W,L	LIB	?MINMAJ	COMP.B	(A3+),#']	JUMP,NE 80$	COMP.B	D3,#'L	JUMP,EQ 65$	COMP.B	D3,#'W	JUMP',EQ 62$	COMP.B	D3,#'B	JUMP,NE 80$60$:	COMP.L	D1,#2^8		; nb plus grand qu'un byte ?	JUMP,HS	80$		; oui => 80$	TEST.B	D0		; nombre positif ?	JUMP,EQ 40$		; oui => 40$	NEG.B	D1		; D1 <-- nombre ngatif	JUMP	40$62$:				; met un .W en (A4) :	COMP.L	D1,#2^16	; nb plus grand qu'un word ?	JUMP,HS	80$		; oui => 80$	TEST.B	D0		; nombre positif ?	JUMP',EQ 63$		; oui => 63$	NEG.W	D1		; D1 <-- nombre ngatif63$:	LOAD.B	(A4)+1,D1	SR.W	D1,#8.	LOAD.B	(A4)+0,D1	ADD.L	A4,#2		; A4 <-- saute .W	SUB.W	D4,#2		; D4 <-- deux bytes de plus	JUMP,HI	30$	LOAD.W	D7,#ERLBFU	JUMP	90$65$:				; met un .L en (A4) :	TEST.B	D0		; nombre positif ?	JUMP',EQ 66$		; oui => 66$	NEG.L	D1		; D1 <-- nombre ngatif66$:	LOAD.B	(A4)+3,D1	SR.L	D1,#8.	LOAD.B	(A4)+2,D1	SR.L	D1,#8.	LOAD.B	(A4)+1,D1	SR.W	D1,#8.	LOAD.B	(A4)+0,D1	ADD.L	A4,#4		; A4 <-- saute .L	SUB.W	D4,#4		; D4 <-- quatre bytes de plus	JUMP,HI	30$	LOAD.W	D7,#ERLBFU	JUMP'	90$70$:	CLR.B	(A4)		; termine les commandes	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	DEC.L	A3		; A3 <-- ^SUR l'erreur90$:	POPM.L	D0,D1,D3,D4,A4	RET;--------\; _SNCOMM >;========/; Envoie une commande  un driver mme si celui-ci n'est; pas ouvert. Si le type n'est pas connu (D1.W=zro), le; type correct est automatiquement cherch.; (*)	paramtre plus utilis !; in	D2.W	numro du driver (*);	D1.W	type du driver (*, sauf :#15);		0	=> si pas connu;		:#15=1	=> pas de question;	A3.L	^unit physique;	A4.L	^commandes termines par zro; out	D7.W	erreur; mod	D7.W_SNCOMM:	PUSHM.L	D3,D4,D6,A2..A4	LOAD.L	A2,A4		; A2 <-- ^commande	CALL	_GETUPH		; A4 <-- ^nom physique	TEST.W	D7	JUMP,NE EXIT$	LOAD.L	A3,A4		; A3 <-- ^nom physique	FOS	?TYPEUNIT	; D3/D4 <-- type/attributs	JUMP,NE EXIT$	LOAD.L	D4,#2^BOPEXTEND!2^BOPRSTATUS	COMP.B	D3,#TYPMM	; type "mmoire de masse" ?	JUMP',NE COMM$		; non => COMM$	TSET.L	D4:#BOPMMUNIT	TEST.L	D1:#15		; pose la question ?	JUMP',BS COMM$		; non => COMM$				; oui =>	LOAD.B	D3,(A2)		; D3 <-- 1re lettre commande	LIB	?MINMAJ		; D3 <-- lettre MAJUSCULE	COMP.B	D3,#'F		; commande "F..." ?	JUMP',NE COMM$		; non => COMM$	LIB	?MAFTIM	.ASCIZ	/<'F>Formatage physique de /	.ASCIZ	/<'E>Physical format of /	.B	0	.EVEN	PUSH.L	A3	LIB	?AFFILE		; affiche le nom physique	POP.L	A3	LIB	?AFTIM	.ASCIZ	/ ? /	.EVEN	LIB	?YESNO		; attend oui/non ...	JUMP',NE EXIT$		; non => EXIT$COMM$:	LOAD.L	D3,D4		; D3 <-- mode d'ouverture	FOS	?ARGSOPEN	JUMP',NE EXIT$		; non => EXIT$	LOAD.L	A4,A2		; A4 <-- ^commande	FOS	?COMMAND	; fait la commande	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	POPM.L	D3,D4,D6,A2..A4	RET.IF 0	PUSHM.L	D0,D1,D4,A2,A3,A4	LOAD.L	A2,A3		; A2 <-- ^unit physique	LOAD.L	A3,A4		; A3 <-- ^commande(s)	LOAD.W	D4,#50.		; D4 <-- une seconde	NTREL	?SETTIM		; init timeout pas infini	FOS	?UOPEN		; essaye d'ouvrir le driver !	LOAD.W	D0,D7		; D0 <-- ok/erreur	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	TEST.W	D0		; ouverture ok ?	JUMP',EQ 20$		; oui => 20$				; non =>	LOAD.W	D7,#ERALOP	; D7 <-- "driver dj ouvert"	COMP.W	D0,#ERTIMO	; timeout ?	JUMP,EQ	90$		; oui => 90$	LOAD.W	D7,D0		; D7 <-- autre erreur	COMP.W	D0,#ERALOP	; driver dj ouvert ?	JUMP,NE	90$		; non => 90$ (autre erreur)20$:	TEST.B	D1		; type dj connu ?	JUMP',NE 50$		; oui => 50$	BIOS	?SEADRIV	; A4 <-- ^base du driver	JUMP,NE	70$	LOAD.B	D1,(A4)+ODHTYPE	; D1 <-- type du driver50$:	LOAD.L	A4,A3		; A4 <-- ^commande(s)	COMP.B	D1,#TYPMM	; type mmoire de masse ?	JUMP',NE 60$		; non => 60$	TEST.L	D1:#15		; pose la question ?	JUMP',BS 60$		; non => 60$				; oui =>	LOAD.B	D3,(A4)		; D3 <-- 1re lettre commande	LIB	?MINMAJ		; D3 <-- lettre MAJUSCULE	COMP.B	D3,#'F		; commande "F..." ?	JUMP',NE 60$		; non => 60$	LIB	?MAFTIM	.ASCIZ	/<'F>Formatage physique de /	.ASCIZ	/<'E>Physical format of /	.B	0	.EVEN	LOAD.L	A3,A2		; A3 <-- ^unit physique	LIB	?AFFILE		; affiche le nom physique	LIB	?AFTIM	.ASCIZ	/ ? /	.EVEN	LIB	?YESNO		; attend oui/non ...	JUMP',NE 70$		; non => 70$60$:	AND.W	D1,#H'FF	; D1 <-- type du driver	BIOS	?DCOMMAND	; envoie commande(s)70$:	TEST.W	D0		; ouverture ok ?	JUMP',NE 90$		; non => 90$	PUSH.W	D7		; oui =>	FOS	?UCLOSE		; ferme sans tester si erreur	POP.W	D790$:	POPM.L	D0,D1,D4,A2,A3,A4	RET.ENDIF;--------\; _GTRSMM >;========/; Cherche dans une ligne de commande une rservation pour; le gestionnaire de mmoire.;;  ligne de commande	| demande mmoire effectue; ----------------------|-----------------------------------;  EPRO<CR>		| getpmem selon D3 donn en entre;  EPRO ABC XY/R<CR>	| getpmem selon D3 donn en entre;  EPRO 1000/M<CR>	| getmem de 1000 bytes;  EPRO ABC 1000/M<CR>	| getmem de 1000 bytes;  EPRO 1000/M ABC<CR>	| getmem de 1000 bytes;  EPRO 100%/M<CR>	| getpmem de 100% (D3=16);  EPRO 50%/M<CR>	| getpmem de 50% (D3=8);  EPRO 20%/M<CR>	| getpmem de 20% (D3=3);  EPRO 2x3/M<CR>	| retour avec D7=ERSYNT; in	A3.L	^dbut ligne de commande;	D3.W	pour seize par dfaut;	D4.L	longueur minimum;	D5.L	longueur maximum;	D1.W	type du compte mmoire;	A1.L	^descripteur (si D1.W<>MTYPCP); out	A4.L	^zone mmoire;	D4.L	longueur;	D7.W	erreur (ERSYNT ou selon GESMEM); mod	D4.L, D7.W, A4.L_GTRSMM:	PUSHM.L	D0,D2,D3,D6,A3	LOAD.W	D2,D3		; D2 <-- pour seize par dfaut10$:	LOAD.B	D3,#'M	LIB	?IFSWITCH	; .../M trouv ?	JUMP',EQ 40$		; oui => 40$20$:	LOAD.B	D3,(A3+)	JUMP,EQ	80$	COMP.B	D3,#CR		; fin de la ligne ?	JUMP,EQ	80$		; oui => 80$	COMP.B	D3,#SPACE	JUMP,NE	20$25$:	COMP.B	(A3+),#SPACE	; saute si plusieurs SPACE(s)	JUMP,EQ	25$	DEC.L	A3		; A3 <-- ^dbut paramtre	JUMP	10$40$:	LOAD.W	D7,#ERLSYN	; D7 <-- erreur de syntaxe	CLR.L	D0		; D0 <-- futur nombre	CLR.B	D6		; D6 <-- demande positive	COMP.B	(A3),#'-	JUMP',NE 50$	INC.L	A3		; A3 <-- saute "-"	INC.B	D6		; D6 <-- demande ngative50$:	CLR.L	D3	LOAD.B	D3,(A3+)	COMP.B	D3,#'/		; fin reservation absolue ?	JUMP',EQ 60$		; oui => 60$	COMP.B	D3,#'%		; fin reservation relative ?	JUMP,EQ	70$		; oui => 70$	COMP.B	D3,#'0	JUMP,LO	90$	COMP.B	D3,#'9		; chiffre ?	JUMP,HI	90$		; non => 90$ (erreur)	SUB.B	D3,#'0		; D3 <-- 0..9	PUSH.L	D1	SL.L	D0,#1	LOAD.L	D1,D0	SL.L	D0,#2	ADD.L	D0,D1		; D0 <-- dcale d'un digit (*10)	POP.L	D1;	MUL.WU	D0,#10		; D0 <-- dcale d'un digit	ADD.L	D0,D3		; D0 <-- ajoute nouveau digit	JUMP	50$60$:	EX.L	D4,D0		; D4 <-- lg demande, D0 <-- min	TEST.B	D6		; demande positive ?	JUMP',EQ 62$		; oui => 62$				; non =>	PUSHM.L	D4,D5	GESMEM	?ARGMEM		; D4 <-- total, D5 <-- plus grand trou	LOAD.L	D3,D5		; D3 <-- plus grand trou	POPM.L	D4,D5	SUB.L	D4,D3	NEG.L	D4		; D4 <-- reste - demande62$:	COMP.L	D4,D5		; lg demande trop grande ?	JUMP',LS 65$		; non => 65$	LOAD.L	D4,D5		; oui => prend le maximum65$:	GESMEM	?GETMEM		; demande mmoire absolue	JUMP,NE	90$		; si erreur => 90$	COMP.L	D4,D0		; lg attribue suffisante ?	JUMP,HS	90$		; oui => 90$	GESMEM	?GIVMEM		; non => rend le tout	LOAD.W	D7,#ERNEMEM	; D7 <-- "pas assez de mmoire"	JUMP	90$70$:	TEST.B	D6		; demande positive ?	JUMP',EQ 72$		; oui => 72$				; non =>	SUB.W	D0,#100	NEG.W	D0		; D0 <-- 100 - demande72$:	MUL.WU	D0,#MPDIV	DIV.WU	D0,#100		; D0 <-- (n*16)/100	LOAD.W	D2,D0		; D2 <-- pour seize choisi80$:	LOAD.W	D3,D2		; D3 <-- pour seize dsir	GESMEM	?GETPMEM	; demande mmoire relative;	JUMP',EQ 90$		; ok => 90$;	COMP.W	D7,#ERNEMEM	; demande trop gourmande ?;	JUMP',NE 90$		; non => 90$;	LOAD.B	D0,#10		; D0 <-- compteur pour qq essai;85$:;	.W	GESMEM,?GETMEM	; demande max. selon last appel;	JUMP',EQ 90$		; ok => 90$;	DEC.B	D0		; encore un essai ?;	JUMP,NE	85$		; oui => 85$90$:	POPM.L	D0,D2,D3,D6,A3	RET	.END