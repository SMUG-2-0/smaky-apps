	.TITLE	TCOLOR	.PROC	M680002	.REF	SM8	.REF	LIB	.REF	DRIVERS	.REF	FOS	.REF	BIOSDIS0	=	0		; 1 => travaille dans $DIS_20	.LOC	0OPDDIS:	.BLKB	4OBUFF:	.BLKB	100OCNDIS:	.BLKB	2		; canal de la fentre $DIS_nOC0DIS:	.BLKB	2		; canal de la fentre $DIS_0LGVAR:	.LOC	0START:	LIB	?OPELIB	LOAD.L	A6,#R16"VAR	LIB	?GCHDIS	LOAD.W	(A6)+OCNDIS,D6	LOAD.L	A3,#R16"NPDIS	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre $DIS_0	LOAD.W	(A6)+OC0DIS,D6	.IF	DIS0	LOAD.W	D3,#TYPDIS	; D3 <-- type fentre cran	.ELSE	LOAD.W	D6,(A6)+OCNDIS	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	.ENDIF	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERROR	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>.IF 0LOAD.L D4,(A0)+ODFABS.W H'A032,H'A024LOAD.L D4,(A0)+ODFCAB.W H'A032,H'A024LOAD.L D4,(A0)+ODFCLG.W H'A032,H'A024LOAD.W D4,(A0)+ODFCNB.W H'A036,H'A024LOAD.B D4,(A0)+ODFCNP.W H'A038,H'A024LOAD.B D4,(A0)+ODFCMD.W H'A038,H'A024LOAD.W D4,(A0)+ODFCMR.W H'A036,H'A024.ENDIF	LIB	?AFTIM	.B	EOP	.B	0	.EVENLOOP:	CALL	AFFICHE	LIB	?AFTIM	.ASCIZ	"<CR>(A)bsolu, (R)elatif, (L)ink, (U)nlink, (P)ush, p(O)p, (F)aux, (T)able ? "	.EVEN	LIB	?GETCAR	LIB	?MINMAJ	LIB	?AFCR	COMP.W	D3,#'A	JUMP,EQ DOABS	COMP.W	D3,#'R	JUMP,EQ DOREL	COMP.W	D3,#'L	JUMP,EQ DOLINK	COMP.W	D3,#'U	JUMP,EQ DOUNLINK	COMP.W	D3,#'P	JUMP,EQ DOPUSH	COMP.W	D3,#'O	JUMP,EQ DOPOP	COMP.W	D3,#'F	JUMP,EQ DOFAUX	COMP.W	D3,#'T	JUMP,EQ DOTABLE	COMP.W	D3,#END	JUMP,EQ EXIT	JUMP	LOOPDOABS:	LOAD.L	A3,#(A6)+OBUFF+1	LOAD.B	(A3)+0,#COLORSA	LIB	?AFTIM	.ASCIZ	"Rouge : "	.EVEN	LIB	?GETHEX	LOAD.W	(A3)+1,D4	LIB	?AFTIM	.ASCIZ	"Vert  : "	.EVEN	LIB	?GETHEX	LOAD.W	(A3)+3,D4	LIB	?AFTIM	.ASCIZ	"Bleu  : "	.EVEN	LIB	?GETHEX	LOAD.W	(A3)+5,D4	LOAD.W	D3,#7	CALL	SEND	JUMP	LOOPDOREL:	LOAD.L	A3,#(A6)+OBUFF+1	LOAD.B	(A3)+0,#COLORSR	LIB	?AFTIM	.ASCIZ	"Numro : "	.EVEN	LIB	?GETHEX	LOAD.L	(A3)+1,D4	LOAD.W	D3,#5	CALL	SEND	JUMP	LOOPDOLINK:	LOAD.L	A3,#(A6)+OBUFF+1	LOAD.B	(A3)+0,#COLORLINK	LIB	?AFTIM	.ASCIZ	"Numro : "	.EVEN	LIB	?GETHEX	LOAD.L	(A3)+1,D4	LIB	?AFTIM	.ASCIZ	"Rouge : "	.EVEN	LIB	?GETHEX	LOAD.W	(A3)+5,D4	LIB	?AFTIM	.ASCIZ	"Vert  : "	.EVEN	LIB	?GETHEX	LOAD.W	(A3)+7,D4	LIB	?AFTIM	.ASCIZ	"Bleu  : "	.EVEN	LIB	?GETHEX	LOAD.W	(A3)+9,D4	LOAD.W	D3,#11	CALL	SEND	JUMP	LOOPDOUNLINK:	LOAD.L	A3,#(A6)+OBUFF+1	LOAD.B	(A3)+0,#COLORUNLINK	LIB	?AFTIM	.ASCIZ	"Numro : "	.EVEN	LIB	?GETHEX	LOAD.L	(A3)+1,D4	LOAD.W	D3,#5	CALL	SEND	JUMP	LOOPDOPUSH:	LIB	?AFTIM	.B	COLOROP,COLOROPPUSH,0	.EVEN	JUMP	LOOPDOPOP:	LIB	?AFTIM	.B	COLOROP,COLOROPPOP,0	.EVEN	JUMP	LOOPDOFAUX:	LOAD.L	A3,#(A6)+OBUFF+1	LOAD.B	(A3)+0,#COLORFALSE	LIB	?AFTIM	.ASCIZ	"Faux  : "	.EVEN	LIB	?GETHEX	LOAD.L	(A3)+1,D4	LIB	?AFTIM	.ASCIZ	"Rouge : "	.EVEN	LIB	?GETHEX	LOAD.W	(A3)+5,D4	LIB	?AFTIM	.ASCIZ	"Vert  : "	.EVEN	LIB	?GETHEX	LOAD.W	(A3)+7,D4	LIB	?AFTIM	.ASCIZ	"Bleu  : "	.EVEN	LIB	?GETHEX	LOAD.W	(A3)+9,D4	LOAD.W	D3,#11	CALL	SEND	JUMP	LOOPDOTABLE:	LIB	?AFCR	LOAD.L	A4,(A0)+ODFCPF	LOAD.L	D4,A4	LIB	?AFX8	LIB	?AFCR	LOAD.W	D2,#256/1010$:	LOAD.W	D3,#1020$:	LOAD.B	D4,(A4+)	LIB	?AFX2	LIB	?AFSPACE	LOAD.B	D4,(A4+)	LIB	?AFX2	LIB	?AFSPACE	LOAD.B	D4,(A4+)	LIB	?AFX2	LIB	?AFSPACE	LIB	?AFSPACE	DEC.W	D3	JUMP,NE 20$	LIB	?AFCR	DEC.W	D2	JUMP,NE 10$	JUMP	LOOPERROR:	LIB	?AFERROR	LIB	?GETCAREXIT:	LOAD.W	D6,(A6)+OC0DIS	FOS	?CLOSE		; ferme $DIS_0	LIB	?CLOLIB	FOS	?STOP;--------\\; SEND    >;========/; ; in	A3.L	^data;	D3.W	lg data; out	-; mod	D7.WSEND:	PUSHM.L	D6	.IF	DIS0	LOAD.W	D6,(A6)+OC0DIS	.ELSE	LOAD.W	D6,(A6)+OCNDIS	.ENDIF	LIB	?PCHDIS		; donne canal  la librairie	LIB	?STRING	LOAD.W	D6,(A6)+OCNDIS	LIB	?PCHDIS	POPM.L	D6	RET;--------\\; AFFICHE >;========/; ; in	; out	; mod	AFFICHE:	PUSHM.L	D4	LIB	?AFTIM	.ASCIZ	"<CR>SA="	.EVEN	LOAD.W	D4,(A0)+ODFCSA+0	LIB	?AFX4	LIB	?AFTIM	.ASCIZ	","	.EVEN	LOAD.W	D4,(A0)+ODFCSA+2	LIB	?AFX4	LIB	?AFTIM	.ASCIZ	","	.EVEN	LOAD.W	D4,(A0)+ODFCSA+4	LIB	?AFX4	LIB	?AFTIM	.ASCIZ	" CA="	.EVEN	LOAD.W	D4,(A0)+ODFCCA+0	LIB	?AFX4	LIB	?AFTIM	.ASCIZ	","	.EVEN	LOAD.W	D4,(A0)+ODFCCA+2	LIB	?AFX4	LIB	?AFTIM	.ASCIZ	","	.EVEN	LOAD.W	D4,(A0)+ODFCCA+4	LIB	?AFX4	LIB	?AFTIM	.ASCIZ	" SR="	.EVEN	LOAD.L	D4,(A0)+ODFCSR	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	" CR="	.EVEN	LOAD.L	D4,(A0)+ODFCCR	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	" SF="	.EVEN	LOAD.L	D4,(A0)+ODFCSF	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	" CF="	.EVEN	LOAD.L	D4,(A0)+ODFCCF	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	"  NR="	.EVEN	LOAD.W	D4,(A0)+ODFCNR	LIB	?AFX4	LIB	?AFTIM	.ASCIZ	" NS="	.EVEN	LOAD.W	D4,(A0)+ODFCNS	LIB	?AFX4	POPM.L	D4	RETNPDIS:	.ASCIZ	"$DIS_20"VAR:	.FILLB	LGVAR,0	.END	START