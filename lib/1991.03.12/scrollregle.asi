	.SBTTL	SCROLLREGLE; Constantes; ----------LXCAR	=	4		; largeur caractreLYCAR	=	7		; hauteur caractreLXLUTIN	=	15		; largeur lutin (si horizontal)LYLUTIN	=	15		; hauteur lutin (si horizontal)NHLUTIN	=	14		; numro du lutin horizontalNVLUTIN	=	15		; numro du lutin vertical;---------------\\; _SCROLL_RMOUSE >;===============/; Dessine la position de la souris dans les rgles horizontales; et verticales, sous la forme de deux petites flches.; Avant d'effacer la fentre, ne pas oublier d'effacer les; flches (avec D4.L=0) !; Les flches utilisent les lutins numros 14 et 15, qui ne; peuvent donc pas tre utiliss dans le programme appelant.; in	D4.L		position de la souris (y;x);			(zro efface les flches);	A5.L		^variables;	(A5)+ORGPOS.L	ancienne position de la souris;			rgle horizontale :;	(A5)+ORGHPO.L	position coin sup/gauche (y;x);	(A5)+ORGHLG.W	largeur (dx), zro = pas de rgle;	(A5)+ORGHMI.B	1 => rgle en bas;			rgle verticale :;	(A5)+ORGVPO.L	position coin sup/gauche (y;x);	(A5)+ORGVLG.W	hauteur (dy), zro = pas de rgle;	(A5)+ORGVMI.B	1 => rgle  gauche;	A0.L		^descripteur de la fentre; out	(A5)+ORGPOS.L	nouvelle position de la souris;	D7.W		erreur; mod	D7.W_SCROLL_RMOUSE:	PUSHM.L	D4,D5	TEST.L	D4	JUMP,EQ 50$	CALL	OPELUTIN	; cre les lutins si ncessaire	LOAD.L	D5,D4		; D5 <-- nouvelle position	LOAD.L	D4,(A5)+ORGPOS	; D4 <-- ancienne position	COMP.W	D4,D5		; position change ?	JUMP',EQ 20$		; non => 20$				; oui =>	CALL	XPOSREGLE	; dessine la nouvelle20$:	SWAP.W	D4	SWAP.W	D5	COMP.W	D4,D5		; position change ?	JUMP',EQ 30$		; non => 30$				; oui =>	CALL	YPOSREGLE	; dessine la nouvelle30$:	SWAP.W	D5	LOAD.L	(A5)+ORGPOS,D5	JUMP'	90$50$:	CALL	CLOLUTIN	; supprime les lutins	LOAD.L	(A5)+ORGPOS,D490$:	POPM.L	D4,D5	CLR.W	D7		; retour EQ	RET;-----------\\; XPOSREGLE  >;-----------/; Inverse la position de la souris dans la rgle horizontale.; in	D5.W	position (absolue) de la souris en X; out	-; mod	D7.WXPOSREGLE:	PUSHM.L	D3,D4,A3	TEST.W	(A5)+ORGHLG	JUMP',EQ 90$	TEST.W	D5	JUMP',EQ 90$	LOAD.W	D4,(A5)+ORGHPO+2	COMP.W	D5,D4		; trop  gauche ?	JUMP',LO 90$	ADD.W	D4,(A5)+ORGHLG	COMP.W	D5,D4		; trop  droite ?	JUMP',HS 90$	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_RUCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_RUMARK	LIB	?COLORSR	; donne la couleur des marques	LOAD.L	A3,#(A5)+ORGBUF+1	LOAD.B	(A3)+0,#DRAWMSPRITE	LOAD.W	D4,D5	SUB.W	D4,#LXLUTIN/2	LOAD.W	(A3)+1,D4	LOAD.W	(A3)+3,(A5)+ORGHPO+0	LOAD.B	(A3)+5,#NHLUTIN	LOAD.W	D3,#6	LIB	?STRING		; dplace le lutin	LIB	?COLORPOP	; restitue les couleurs90$:	POPM.L	D3,D4,A3	RET;-----------\\; YPOSREGLE  >;-----------/; Inverse la position de la souris dans la rgle verticale.; in	D5.W	position (absolue) de la souris en Y; out	-; mod	D7.WYPOSREGLE:	PUSHM.L	D3,D4,A3	TEST.W	(A5)+ORGVLG	JUMP',EQ 90$	TEST.W	D5	JUMP',EQ 90$	LOAD.W	D4,(A5)+ORGVPO+0	COMP.W	D5,D4		; trop en haut ?	JUMP',LO 90$	ADD.W	D4,(A5)+ORGVLG	COMP.W	D5,D4		; trop en bas ?	JUMP',HS 90$	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_RUCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_RUMARK	LIB	?COLORSR	; donne la couleur des marques	LOAD.L	A3,#(A5)+ORGBUF+1	LOAD.B	(A3)+0,#DRAWMSPRITE	LOAD.W	(A3)+1,(A5)+ORGVPO+2	LOAD.W	D4,D5	SUB.W	D4,#LXLUTIN/2	LOAD.W	(A3)+3,D4	LOAD.B	(A3)+5,#NVLUTIN	LOAD.W	D3,#6	LIB	?STRING		; dplace le lutin	LIB	?COLORPOP	; restitue les couleurs90$:	POPM.L	D3,D4,A3	RET;----------------\\; _SCROLL_RUPDATE >;================/; Dessine les rgles horizontales et verticales, gradues; en centimtres.; Un rectangle est dessin autour de chaque rgle.; Utilise le gencar NEF07 pour les graduations, qui doit ; exister sur disque. Le gencar courant n'est pas chang.; La rgle horizontale doit tre distante d'au moins huit; points des bords gauche et droite de la (sous-)fentre.; La rgle verticale doit tre distante d'au moins huit; points des bords suprieur et infrieur de la (sous-)fentre.; Le "pas" correspond  la distance (en points) entre deux; graduations millimtriques, multipli par 64 pour viter les; erreurs cumules d'arrondis.; L'"origine" (en points) dtermine o dbute la graduation.; L'"chelle" influence le "pas". Par exemple, -2 correspond;  une rduction de deux (les graduations seront donc deux fois; plus serres). +1 ou 0 correspond  l'chelle 1:1.; in	A5.L		^variables;	(A5)+ORGPOS.L	ancienne position de la souris;			rgle horizontale :;	(A5)+ORGHPO.L	position coin sup/gauche (y;x);	(A5)+ORGHLG.W	largeur (dx), zro = pas de rgle;	(A5)+ORGHPA.W	pas (nb points par mm)*64;	(A5)+ORGHOR.W	origine (points);	(A5)+ORGHSC.W	chelle (-rduction et +agrandissement);	(A5)+ORGHMI.B	1 => rgle en bas;			rgle verticale :;	(A5)+ORGVPO.L	position coin sup/gauche (y;x);	(A5)+ORGVLG.W	hauteur (dy), zro = pas de rgle;	(A5)+ORGVPA.W	pas (nb points par mm)*64;	(A5)+ORGVOR.W	origine (points);	(A5)+ORGVSC.W	chelle (-rduction et +agrandissement);	(A5)+ORGVMI.B	1 => rgle  gauche;	(A5)+ORGVHB.B	1 => graduation de haut en bas;	A0.L		^descripteur de la fentre; out	D7.W		erreur; mod	D7.W_SCROLL_RUPDATE:	PUSHM.L	D3,D4,A3	CLR.L	D4	CALL	_SCROLL_RMOUSE	; efface l'ancienne position souris	LIB	?BUCAR		; mode rapide !	TEST.W	(A5)+ORGHLG	JUMP',EQ 40$	CALL	XREGLE		; dessine la rgle horizontale40$:	TEST.W	(A5)+ORGVLG	JUMP',EQ 50$	CALL	YREGLE		; dessine la rgle verticale50$:	LIB	?NOBUCAR	; remet mode normal	CLR.L	(A5)+ORGPOS	; position souris pas dessine	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; XREGLE  >;--------/; Dessine une jolie rgle horizontale.; in	-; out	-; mod	D7.WXREGLE:	PUSHM.L	D0..D5	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_RUCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_RUSET	LIB	?COLORSR	; donne la couleur du dessin	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfini trame pour effacer	LOAD.L	D3,(A5)+ORGHPO	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	LOAD.W	D4,#LGREGLE	SWAP.W	D4	LOAD.W	D4,(A5)+ORGHLG	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; met le rectangle autour	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface toute la rgle	LOAD.W	D0,(A5)+ORGHPA	; D0 <-- pas *64	CLR.L	D5	LOAD.W	D5,(A5)+ORGHOR	; D5 <-- origine	SL.L	D5,#6	DIV.WU	D5,D0	AND.L	D5,#H'FFFF	LOAD.W	D1,(A5)+ORGHSC	CALL	D0SCALE		; D0 <-- pas selon chelle	TEST.W	D0	JUMP,EQ 90$	LOAD.W	D1,D3	ADD.W	D1,D4		; D1 <-- position X maximale	SL.W	D1,#6	SWAP.W	D3	TEST.B	(A5)+ORGHMI	; rgle en bas ?	JUMP',T 20$		; oui => 20$	ADD.W	D3,#LGREGLE-220$:	SWAP.W	D3	SL.W	D3,#6		; D3 <-- OCX*64	LOAD.W	D2,#SETDOT	; D2 <-- mode30$:	CALL	XLINEREGLE	; dessine une ligne	CALL	XGRADREGLE	; dessine un chiffre	INC.W	D5		; D5 <-- rang suivant	ADD.W	D3,D0		; D3 <-- barrette suivante	COMP.W	D3,D1		; fin de la rgle ?	JUMP,LO	30$		; non => 30$90$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D0..D5	RET;-----------\\; XLINEREGLE >;-----------/; Dessine une ligne pour indiquer un milimtre.; in	D3.L	position (y;x);	D5.W	rang;	D0.W	pas;	D1.W	maximum; out	-; mod	D7.WXLINEREGLE:	PUSHM.L	D3..D5	PUSH.L	D3	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_RULINE	LIB	?COLORSR	; donne la couleur des lignes	POP.L	D3	SR.W	D3,#6		; D3 <-- origine X /64	LOAD.W	D4,#-(LGREGLE-1); D4 <-- toute la hauteur	COMP.W	D0,#2*64	; pas trs petit ?	JUMP',HS 30$		; non => 30$				; oui =>	DIV.WU	D5,#10		; D5 <-- reste/10	SWAP.W	D5	TEST.W	D5		; reste qq chose ?	JUMP',NE 90$		; oui => 90$	SWAP.W	D5	DIV.WU	D5,#5	SWAP.W	D5		; D5 <-- reste de la division	TEST.W	D5	JUMP',EQ 40$	LOAD.W	D4,#-3		; D4 <-- juste trois points	JUMP'	40$30$:	DIV.WU	D5,#10		; D5 <-- rang/10	SWAP.W	D5		; D5 <-- reste de la division	TEST.W	D5	JUMP',EQ 40$	LOAD.W	D4,#-(LGREGLE/2); D4 <-- 1/2 de la hauteur	COMP.W	D5,#5	JUMP',EQ 40$	LOAD.W	D4,#-3		; D4 <-- juste trois points40$:	TEST.B	(A5)+ORGHMI	; rgle en bas ?	JUMP',F 50$		; non => 50$	NEG.W	D4		; oui => inverse la longueur50$:	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; dessine une barrette verticale90$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D3..D5	RET;-----------\\; XGRADREGLE >;-----------/; Dessine un chiffre dans la graduation.; in	D3.L	position (y;x);	D5.W	rang;	D0.W	pas;	D1.W	maximum; out	-; mod	D7.WXGRADREGLE:	PUSHM.L	D1..D5	COMP.W	D5,#2000	; plus de 2 mtres ?	JUMP,HS 90$		; oui => 90$	COMP.W	D0,#2*64	; pas trs petit ?	JUMP',HS 20$		; non => 20$				; oui =>	DIV.WU	D5,#10*5	SWAP.W	D5	TEST.W	D5		; est-ce une dizaine (0,5,10,15...) ?	JUMP,NE 90$		; non => 90$	SWAP.W	D5	MUL.WU	D5,#5	JUMP'	25$20$:	DIV.WU	D5,#10	SWAP.W	D5	TEST.W	D5		; est-ce une dizaine (0,1,2,3...) ?	JUMP,NE 90$		; non => 90$	SWAP.W	D525$:	DIV.WU	D5,#10	SR.W	D3,#6		; D3 <-- origine X /64	SWAP.W	D3	TEST.B	(A5)+ORGHMI	; rgle en bas ?	JUMP',T 30$	SUB.W	D3,#LGREGLE-1-LYCAR-2	JUMP'	35$30$:	ADD.W	D3,#LGREGLE-1-235$:	SWAP.W	D3	SR.W	D1,#6		; D1 <-- maximum /64	DEC.W	D1	SUB.W	D1,#LXCAR+1	; D1 <-- maximum pour les chiffres	COMP.W	D3,D1		; chiffre trop  droite ?	JUMP,HS 90$		; oui => 90$	SUB.W	D3,#LXCAR+1	LOAD.L	D1,D5	SWAP.W	D1		; D1 <-- zro si dizaine	TEST.W	D5	JUMP',EQ 60$	COMP.W	D3,(A5)+ORGHPO+2 ; chiffre trop  gauche ?	JUMP,LO 90$		; oui => 90$	PUSHM.L	D3,D4	LOAD.L	D4,D3	EX.L	D3,D5	CALL	REGLECAR	; affiche les dizaines	TEST.W	D1	JUMP',NE 55$	DEC.W	D4	CALL	REGLECAR	; affiche les dizaines en gras55$:	EX.L	D5,D3	POPM.L	D3,D460$:	ADD.W	D3,#LXCAR+1+2	LOAD.L	D4,D3	SWAP.W	D5	LOAD.B	D3,D5	CALL	REGLECAR	; affiche les units	TEST.W	D1	JUMP',NE 90$	INC.W	D4	CALL	REGLECAR	; affiche les units en gras90$:	POPM.L	D1..D5	RET;--------\\; YREGLE  >;--------/; Dessine une jolie rgle verticale.; in	-; out	-; mod	D7.WYREGLE:	PUSHM.L	D0..D5	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_RUCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_RUSET	LIB	?COLORSR	; donne la couleur du dessin	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfini trame pour effacer	LOAD.L	D3,(A5)+ORGVPO	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	LOAD.W	D4,(A5)+ORGVLG	SWAP.W	D4	LOAD.W	D4,#LGREGLE	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine le rectangle autour	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface toute la rgle	LOAD.W	D0,(A5)+ORGVPA	; D0 <-- pas *64	CLR.L	D5	LOAD.W	D5,(A5)+ORGVOR	; D5 <-- origine	SL.L	D5,#6	DIV.WU	D5,D0	AND.L	D5,#H'FFFF	LOAD.W	D1,(A5)+ORGVSC	CALL	D0SCALE		; D0 <-- pas selon chelle	TEST.W	D0	JUMP,EQ 90$	TEST.B	(A5)+ORGVMI	; rgle  gauche ?	JUMP',F 20$		; non => 20$	ADD.W	D3,#LGREGLE-220$:	SWAP.W	D3	SWAP.W	D4	TEST.B	(A5)+ORGVHB	; rgle de haut en bas ?	JUMP',T 22$		; oui => 22$	ADD.W	D3,D4	DEC.W	D322$:	SL.W	D3,#6		; D3 <-- OCX*64	SWAP.W	D4	SWAP.W	D3	LOAD.W	D1,(A5)+ORGVPO+0 ; D1 <-- position Y minimale	TEST.B	(A5)+ORGVHB	; rgle de haut en bas ?	JUMP',F 24$		; non => 24$	ADD.W	D1,(A5)+ORGVLG	; D1 <-- position Y maximale24$:	SL.W	D1,#6	LOAD.W	D2,#SETDOT	; D2 <-- mode	SWAP.W	D330$:	SWAP.W	D3	CALL	YLINEREGLE	; dessine une ligne	CALL	YGRADREGLE	; dessine un chiffre	SWAP.W	D3	INC.W	D5		; D5 <-- rang suivant	TEST.B	(A5)+ORGVHB	; rgle de haut en bas ?	JUMP',T 75$	TEST.W	D3	JUMP',NS 70$	SUB.W	D3,D0		; D3 <-- barrette suivante	COMP.W	D3,D1		; fin de la rgle ?	JUMP,GT	30$		; non => 30$;;?	JUMP,HI	30$		; non => 30$	JUMP'	90$70$:	SUB.W	D3,D0		; D3 <-- barrette suivante	JUMP	30$75$:	ADD.W	D3,D0		; D3 <-- barrette suivante	COMP.W	D3,D1		; fin de la rgle ?	JUMP,LO	30$		; non => 30$90$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D0..D5	RET;-----------\\; YLINEREGLE >;-----------/; Dessine une ligne pour indiquer un milimtre.; in	D3.L	position (y;x);	D5.W	rang;	D0.W	pas;	D1.W	maximum; out	-; mod	D7.WYLINEREGLE:	PUSHM.L	D3..D5	PUSH.L	D3	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_RULINE	LIB	?COLORSR	; donne la couleur des lignes	POP.L	D3	SWAP.W	D3	SR.W	D3,#6		; D3 <-- origine Y /64	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,#LGREGLE-1	; D4 <-- toute la hauteur	COMP.W	D0,#2*64	; pas trs petit ?	JUMP',HS 30$		; non => 30$				; oui =>	DIV.WU	D5,#10		; D5 <-- reste/10	SWAP.W	D5	TEST.W	D5		; reste qq chose ?	JUMP',NE 90$		; oui => 90$	SWAP.W	D5	DIV.WU	D5,#5	SWAP.W	D5		; D5 <-- reste de la division	TEST.W	D5	JUMP',EQ 40$	LOAD.W	D4,#3		; D4 <-- juste trois points	JUMP'	40$30$:	DIV.WU	D5,#10		; D5 <-- rang/10	SWAP.W	D5		; D5 <-- reste de la division	TEST.W	D5	JUMP',EQ 40$	LOAD.W	D4,#LGREGLE/2	; D4 <-- 1/2 de la hauteur	COMP.W	D5,#5	JUMP',EQ 40$	LOAD.W	D4,#3		; D4 <-- juste trois points40$:	TEST.B	(A5)+ORGVMI	; rgle  gauche ?	JUMP',F 50$		; non => 50$	NEG.W	D4		; oui => inverse le sens50$:	LIB	?DRSEG		; dessine une barrette horizontale90$:	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D3..D5	RET;-----------\\; YGRADREGLE >;-----------/; Dessine un chiffre dans la graduation.; in	D3.L	position (y;x);	D5.W	rang;	D0.W	pas;	D1.W	maximum; out	-; mod	D7.WYGRADREGLE:	PUSHM.L	D1..D5	COMP.W	D5,#2000	; plus de 2 mtres ?	JUMP,HS 90$		; oui => 90$	COMP.W	D0,#2*64	; pas trs petit ?	JUMP',HS 20$		; non => 20$				; oui =>	DIV.WU	D5,#10*5	SWAP.W	D5	TEST.W	D5		; est-ce une dizaine (0,5,10,15...) ?	JUMP,NE 90$		; non => 90$	SWAP.W	D5	MUL.WU	D5,#5	JUMP'	25$20$:	DIV.WU	D5,#10	SWAP.W	D5	TEST.W	D5		; est-ce une dizaine (0,1,2,3...) ?	JUMP,NE 90$		; non => 90$	SWAP.W	D525$:	DIV.WU	D5,#10	SWAP.W	D3	SR.W	D3,#6		; D3 <-- origine Y /64	TEST.B	(A5)+ORGVHB	; rgle de haut en bas ?	JUMP',T 30$	DEC.W	D3	SR.W	D1,#6		; D1 <-- minimum /64	ADD.W	D1,#LYCAR	; D1 <-- minimum pour les chiffres	COMP.W	D3,D1		; chiffre trop haut ?	JUMP',LO 90$		; oui => 90$	JUMP'	35$30$:	ADD.W	D3,#2+LYCAR	SR.W	D1,#6		; D1 <-- maximum /64	COMP.W	D3,D1		; chiffre trop bas ?	JUMP',HS 90$		; oui => 90$35$:	SWAP.W	D3	TEST.B	(A5)+ORGVMI	; rgle  gauche ?	JUMP',T 40$		; oui => 40$	ADD.W	D3,#5	JUMP'	45$40$:	SUB.W	D3,#LGREGLE-445$:	LOAD.L	D1,D5	SWAP.W	D1		; D1 <-- zro si dizaine	TEST.W	D5	JUMP',EQ 60$	PUSHM.L	D3,D4	LOAD.L	D4,D3	LOAD.B	D3,D5	CALL	REGLECAR	; affiche les dizaines	TEST.W	D1	JUMP',NE 55$	DEC.W	D4	CALL	REGLECAR	; affiche les dizaines en gras55$:	POPM.L	D3,D460$:	ADD.W	D3,#LXCAR+1	LOAD.L	D4,D3	SWAP.W	D5	LOAD.B	D3,D5	CALL	REGLECAR	; affiche les units	TEST.W	D1	JUMP',NE 90$	DEC.W	D4	CALL	REGLECAR	; affiche les units en gras90$:	POPM.L	D1..D5	RET;---------\\; REGLECAR >;---------/; Affiche un chiffre (graduation) dans une rgle.; in	D3.B	chiffre (0..19);	D4.L	position (y;x); out	-; mod	D7.WREGLECAR:	PUSHM.L	D3,D4,A3,A4	PUSH.L	D3	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_RUCAR	LIB	?COLORSR	; donne la couleur des caractres	POP.L	D3	LOAD.L	A4,#R16"TCHIFFRES	AND.W	D3,#H'00FF	MUL.WU	D3,#2+7	ADD.L	A4,D3	LOAD.L	A3,#(A5)+ORGBUF+1	LOAD.B	(A3)+0,#DRAWMATRIX	CLR.W	D3	LOAD.B	D3,(A4)+0	; D3 <-- largeur	SUB.W	D4,D3	ADD.W	D4,#LXCAR	SWAP.W	D4	SUB.W	D4,#LYCAR	LOAD.L	(A3)+1,D4	; <xx> et <yy>	LOAD.L	(A3)+5,A4	; <pppp>	LOAD.B	(A3)+9,#SETDOT!PENDOT ; <m>	LOAD.W	D3,#10	LIB	?STRING		; affiche un chiffre	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D3,D4,A3,A4	RET;--------\\; D0SCALE >;--------/; Tient compte de l'chelle.; in	D1.W	+/- chelle;	D0.W	valeur; out	D0.L	valeur selon chelle; mod	D0.LD0SCALE:	PUSH.W	D1	TEST.W	D1	JUMP',EQ 90$	JUMP',NS 50$				; agrandissement =>	MUL.WU	D0,D1	JUMP'	90$50$:				; rduction =>	AND.L	D0,#H'FFFF	NEG.W	D1	DIV.WU	D0,D1	AND.L	D0,#H'FFFF90$:	POP.W	D1	RET;---------\\; OPELUTIN >;---------/; Cre si ncessaire les deux lutins.; in	D4.L	position de la souris (y;x); out	-; mod	D7.WOPELUTIN:	PUSHM.L	D3,D4,A1..A3	TEST.B	(A5)+ORGFLE	; flches prsentes ?	JUMP,T	90$		; oui => 90$				; non =>	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_RUCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_RUMARK	LIB	?COLORSR	; donne la couleur des marques	LOAD.W	D3,(A5)+ORGHPO+2	COMP.W	D4,D3		; trop  gauche ?	JUMP',HS 10$	LOAD.W	D4,D310$:	ADD.W	D3,(A5)+ORGHLG	COMP.W	D4,D3		; trop  droite ?	JUMP',LO 12$	LOAD.W	D4,D3	DEC.W	D412$:	LOAD.L	A3,#(A5)+ORGBUF+1	LOAD.B	(A3)+0,#DRAWOSPRITE	LOAD.W	D3,D4	SUB.W	D3,#LXLUTIN/2	LOAD.W	(A3)+1,D3	LOAD.W	(A3)+3,(A5)+ORGHPO+0	LOAD.W	(A3)+5,#LXLUTIN	LOAD.W	(A3)+7,#LYLUTIN	LOAD.L	A1,#R16"TAHHSLUTIN	LOAD.L	A2,#R16"TAHHCLUTIN	TEST.B	(A5)+ORGHMI	; rgle en bas ?	JUMP',F 20$	LOAD.L	A1,#R16"TAHBSLUTIN	LOAD.L	A2,#R16"TAHBCLUTIN20$:	LOAD.L	(A3)+9,A1	LOAD.L	(A3)+13,A2	LOAD.B	(A3)+17,#NHLUTIN	LOAD.W	D3,#18	LIB	?STRING		; dessine le premier lutin	SWAP.W	D4	LOAD.W	D3,(A5)+ORGVPO+0	COMP.W	D4,D3		; trop en haut ?	JUMP',HS 30$	LOAD.W	D4,D330$:	ADD.W	D3,(A5)+ORGHLG	COMP.W	D4,D3		; trop en bas ?	JUMP',LO 32$	LOAD.W	D4,D3	DEC.W	D432$:	LOAD.L	A3,#(A5)+ORGBUF+1	LOAD.B	(A3)+0,#DRAWOSPRITE	LOAD.W	(A3)+1,(A5)+ORGVPO+2	LOAD.W	D3,D4	SUB.W	D3,#LXLUTIN/2	LOAD.W	(A3)+3,D3	LOAD.W	(A3)+5,#LYLUTIN	LOAD.W	(A3)+7,#LXLUTIN	LOAD.L	A1,#R16"TAVDSLUTIN	LOAD.L	A2,#R16"TAVDCLUTIN	TEST.B	(A5)+ORGVMI	; rgle  gauche ?	JUMP',F 40$	LOAD.L	A1,#R16"TAVGSLUTIN	LOAD.L	A2,#R16"TAVGCLUTIN40$:	LOAD.L	(A3)+9,A1	LOAD.L	(A3)+13,A2	LOAD.B	(A3)+17,#NVLUTIN	LOAD.W	D3,#18	LIB	?STRING		; dessine le premier lutin	SET.B	(A5)+ORGFLE	LIB	?COLORPOP	; restitue les couleurs90$:	POPM.L	D3,D4,A1..A3	RET;---------\\; CLOLUTIN >;---------/; Supprime si ncessaire les deux lutins.; in	-; out	-; mod	D7.WCLOLUTIN:	PUSHM.L	D3,A3	TEST.B	(A5)+ORGFLE	; flches prsentes ?	JUMP',F 90$		; non => 90$				; oui =>	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLOR_RUCLEAR	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLOR_RUMARK	LIB	?COLORSR	; donne la couleur des marques	LOAD.L	A3,#(A5)+ORGBUF+1	LOAD.B	(A3)+0,#DRAWCSPRITE	LOAD.B	(A3)+1,#NHLUTIN	LOAD.B	(A3)+2,#DRAWCSPRITE	LOAD.B	(A3)+3,#NVLUTIN	LOAD.W	D3,#2+2	LIB	?STRING		; efface les deux lutins	CLR.B	(A5)+ORGFLE	LIB	?COLORPOP	; restitue les couleurs90$:	POPM.L	D3,A3	RETTAHHSLUTIN:	.B	B'01111111,B'11111100	.B	B'01111111,B'11111100	.B	B'00111111,B'11111000	.B	B'00111111,B'11111000	.B	B'00011111,B'11110000	.B	B'00011111,B'11110000	.B	B'00001111,B'11100000	.B	B'00001111,B'11100000	.B	B'00000111,B'11000000	.B	B'00000111,B'11000000	.B	B'00000011,B'10000000	.B	B'00000011,B'10000000	.B	B'00000001,B'00000000	.B	B'00000001,B'00000000	.B	B'00000000,B'00000000TAHHCLUTIN:	.B	B'11111111,B'11111110	.B	B'11111111,B'11111110	.B	B'11111111,B'11111110	.B	B'01111111,B'11111100	.B	B'01111111,B'11111100	.B	B'00111111,B'11111000	.B	B'00111111,B'11111000	.B	B'00011111,B'11110000	.B	B'00011111,B'11110000	.B	B'00001111,B'11100000	.B	B'00001111,B'11100000	.B	B'00000111,B'11000000	.B	B'00000111,B'11000000	.B	B'00000011,B'10000000	.B	B'00000000,B'00000000TAHBSLUTIN:	.B	B'00000000,B'00000000	.B	B'00000001,B'00000000	.B	B'00000001,B'00000000	.B	B'00000011,B'10000000	.B	B'00000011,B'10000000	.B	B'00000111,B'11000000	.B	B'00000111,B'11000000	.B	B'00001111,B'11100000	.B	B'00001111,B'11100000	.B	B'00011111,B'11110000	.B	B'00011111,B'11110000	.B	B'00111111,B'11111000	.B	B'00111111,B'11111000	.B	B'01111111,B'11111100	.B	B'01111111,B'11111100TAHBCLUTIN:	.B	B'00000000,B'00000000	.B	B'00000011,B'10000000	.B	B'00000111,B'11000000	.B	B'00000111,B'11000000	.B	B'00001111,B'11100000	.B	B'00001111,B'11100000	.B	B'00011111,B'11110000	.B	B'00011111,B'11110000	.B	B'00111111,B'11111000	.B	B'00111111,B'11111000	.B	B'01111111,B'11111100	.B	B'01111111,B'11111100	.B	B'11111111,B'11111110	.B	B'11111111,B'11111110	.B	B'11111111,B'11111110TAVDSLUTIN:	.B	B'00000000,B'00000000	.B	B'00000000,B'00000110	.B	B'00000000,B'00011110	.B	B'00000000,B'01111110	.B	B'00000001,B'11111110	.B	B'00000111,B'11111110	.B	B'00011111,B'11111110	.B	B'01111111,B'11111110	.B	B'00011111,B'11111110	.B	B'00000111,B'11111110	.B	B'00000001,B'11111110	.B	B'00000000,B'01111110	.B	B'00000000,B'00011110	.B	B'00000000,B'00000110	.B	B'00000000,B'00000000TAVDCLUTIN:	.B	B'00000000,B'00001110	.B	B'00000000,B'00111110	.B	B'00000000,B'11111110	.B	B'00000011,B'11111110	.B	B'00001111,B'11111110	.B	B'00111111,B'11111110	.B	B'01111111,B'11111110	.B	B'01111111,B'11111110	.B	B'01111111,B'11111110	.B	B'00111111,B'11111110	.B	B'00001111,B'11111110	.B	B'00000011,B'11111110	.B	B'00000000,B'11111110	.B	B'00000000,B'00111110	.B	B'00000000,B'00001110TAVGSLUTIN:	.B	B'00000000,B'00000000	.B	B'11000000,B'00000000	.B	B'11110000,B'00000000	.B	B'11111100,B'00000000	.B	B'11111111,B'00000000	.B	B'11111111,B'11000000	.B	B'11111111,B'11110000	.B	B'11111111,B'11111100	.B	B'11111111,B'11110000	.B	B'11111111,B'11000000	.B	B'11111111,B'00000000	.B	B'11111100,B'00000000	.B	B'11110000,B'00000000	.B	B'11000000,B'00000000	.B	B'00000000,B'00000000TAVGCLUTIN:	.B	B'11100000,B'00000000	.B	B'11111000,B'00000000	.B	B'11111110,B'00000000	.B	B'11111111,B'10000000	.B	B'11111111,B'11100000	.B	B'11111111,B'11111000	.B	B'11111111,B'11111100	.B	B'11111111,B'11111100	.B	B'11111111,B'11111100	.B	B'11111111,B'11111000	.B	B'11111111,B'11100000	.B	B'11111111,B'10000000	.B	B'11111110,B'00000000	.B	B'11111000,B'00000000	.B	B'11100000,B'00000000	.EVEN	.END