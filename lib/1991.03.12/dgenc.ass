	.TITLE	DGENC.ASS	.PROC	M68000			; mnmonics CALM	.BASE	10'10			; base 10 par dfaut;	.LAYOUT	HEX			; listing en hexadcima; Numros des appels; ------------------	.SYSCALL.16	DGENC_DGENC_MODIF	=	16'A8D0		; modifie un ou plusieurs gencarsDGENC_LIST	=	16'A8D1		; donne la liste des gencarsDGENC_DISGC	=	16'A8D3		; libre tous les gencarsDGENC_ENAGC	=	16'A8D4		; recharge tous les gencarsDGENC_SEARCH	=	16'A8D5		; cherche d'aprs le titreDGENC_FREE	=	16'A8D6		; cherche une place videDGENC_NEW	=	16'A8D7		; charge un nouveau gencarDGENC_KILL	=	16'A8D8		; libre un gencarDGENC_PUT	=	16'A8D9		; construit un nom en asciiDGENC_GET	=	16'A8DA		; construit les 3 bytes codsDGENC_MENU	=	16'A8DB		; construit le m-menuDGENC_FIRST	=	DGENC_MODIFDGENC_LAST	=	DGENC_MENU; Tables des gnrateurs de caractres; ------------------------------------MAXGC	=	10			; nb max de gencar simultansLGNGC	=	12+2			; lg d'un nom de gencarLGTGC	=	10+2			; lg d'un titre de gencarLUSGC	=	10			; lg variables utilisateur	.LOC	0OGCFLG:		.BLK.8		1		; 1 => gencar utilis BGCUSE		=  0				;  gencar utilis BGCPROT	=  1				;  gencar indestructibleOGCVAR:		.BLK.8		1		; 0 => chasse fixe, 1 => chasse proportionnelleOGCCOD:		.BLK.8		1		; place pour LOADGC/USEGC/KILLGC (*)OGCF:		.BLK.8		1		; fonte (*)OGCS:		.BLK.8		1		; style/chasse (*)OGCT:		.BLK.8		1		; taille (*)OGCNAM:		.BLK.8		LGNGC		; nom du gencarOGCTIT:		.BLK.8		LGTGC		; titre du gencarOGCITL:		.BLK.16		1		; interligneOGC1Y:		.BLK.16		1		; hauteur dessus la ligne de baseOGC2Y:		.BLK.16		1		; hauteur dessous la ligne de baseOGCX:		.BLK.16		1		; largeur si chasse fixeOGC1X:		.BLK.16		1		; largeur  gaucheOGC2X:		.BLK.16		1		; largeur  droite (maximum)OGCPT:		.BLK.32		1		; ^dbut		.BLK.8		10		; rserve (faut pas modifier LGGC !)OGCUSER:	.BLK.8		LUSGC		; variables utilisateurLGGC:; (*)	dans cet ordre !;-------------\\; DGENC_MODIF  >;=============/; Dialogue pour la DBOX des gencars.; in	D2.W	mode d'ouverture;	D3.L	v. coordonne (selon D2.W);	D4.L	fanions;	A4.L	^buffer des gencars;	A5.L	^liste des gencars (si liste vide, -1 au dbut);	D5.W	^longueur buffer si A5=^nil;	D1.L	gencar  ne jamais dtruire "-fst"";	A2.L	^descripteur de la fentre; out	D3.W	dernire touche (F1/F4/END);		 F1  => modifie (et pas cre);		 F4  => supprime;		 END => termine;	D4.L	fanions;	A4.L	^gencar modifi/supprim (utile si D3=F1/F4);	D2.L	ancien gencar "-fst" (utile si D3=F1);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A4.L;-------------\\; DGENC_DISGC  >;=============/; Libre provisoirement tous les gencars.; in	A4.L	^buffer des gencars;	A2.L	^description de la fentre; out	-; mod	D7.W;-------------\\; DGENC_ENAGC  >;=============/; Reprend tous les gencars librs provisoirement.; in	A4.L	^buffer des gencars;	A2.L	^description de la fentre; out	-; mod	D7.W;--------------\\; DGENC_SEARCH  >;==============/; Cherche un gencar d'aprs son titre.; Si le gencar cherch est dans le buffer des gencars,; il ne se trouve pas lui-mme !; in	A3.L	^nom d'un titre de gencar;	A4.L	^buffer des gencars; out	A4.L	^dans le buffer des gencars;	D4.W	no du gencar;	D7.W	erreur; mod	D4.W, D7.W, A4.L;------------\\; DGENC_FREE  >;============/; Cherche un gencar libre.; in	A4.L	^buffer des gencars; out	A4.L	^dans le buffer des gencars;	D4.W	no du gencar;	D7.W	erreur; mod	D4.W, D7.W, A4.L;-----------\\; DGENC_NEW  >;===========/; Si ncessaire, charge un nouveau gnrateur de caractre.; Il est interdit de librer le gencar, car il peut tre utilis; dans un buffer de texte !; in	A4.L	^lment dans le buffer des gencars;	A3.L	^buffer des gencars;	D4.L	gencar  ne pas dtruire;	A2.L	^description de la fentre; out	D7.W	erreur; mod	D7.W;-----------\\; DGENC_PUT  >;===========/; Construit le nom du gencar en fonction des 3 bytes compactifis.; in	D4.L	"-fst";	A3.L	^buffer o mettre le nom en clair; out	-; mod	D7.W;------------\\; DGENC_KILL  >;============/; Libre un gencar "hard" ou "soft".; Attention: accepte de librer le gencar du Fond, indestructible !; in	A4.L	^dans le buffer des gencars;	A3.L	^buffer des gencars;	D4.L	gencar  ne pas dtruire; out	D7.W	erreur; mod	D7.W;-----------\\; DGENC_GET  >;===========/; Vrifie la syntaxe d'un nom de gencar "fsctt".; in	A3.L	^fsctt; out	A3.L	^plus loin;	D5.L	"fst" compactifi :	| - | f | s | t |;	D7.W	erreur; mod	D5.L, D7.W, A3.L;------------\; DGENC_MENU  >;============/; Construit le menu pour choisir le gencar.; in	A4.L	^buffer des gencars;	A3.L	^buffer pour le menu;		 lg min = ((15+LGTGC)*MAXGC)+10 = 280 !;	A2.L	^descripteur de la fentre; out	A3.L	^fin du menu (sur le zro terminateur); mod	D7.W, A3.L;------------\\; DGENC_LIST  >;============/; Fait la liste de tous les gencar disponibles.; Pour vider ou initialiser la liste, il faut la mettre; dans l'un des tats suivants :;	a)	<-1>;	b)	<-2> nom <0> <-1>	(nom de l'imprimante);; La liste peut avoir les tats suivants :;;	             |-------|  |-------|  |-------|  |-------|;	OMDPLN --|-->|  -1   |  |   0   |  |  -2   |  |  -2   |    ^;	OMDPLF --|   |-------|  |-------|  |-------|  |-------|    |;	             |       |  |       |  |       |  |       |    |;	             |       |  |       |  |  nom  |  |  nom  |    |;	             |       |  |       |  |       |  |       |    |;	             |       |  |       |  |-------|  |-------|    | LGMN;	             |       |  |       |  |   0   |  |   0   |    |;	             |       |  |       |  |-------|  |-------|    |;	OMDPLF --------------------------->|  -1   |  |   0   |    |;	             |       |  |       |  |-------|  |-------|    |;	             |       |  |       |  |       |  |       |    v;	             |-------|  |-------|  |-------|  |-------|;	OMDPLV ----->|       |  |       |  |       |  |       |    ^;	             |       |  |       |  |       |  |       |    |;	             |  var  |  |  var  |  |  var  |  |  var  |    | LGMV;	             |       |  |       |  |       |  |       |    |;	             |       |  |       |  |       |  |       |    v;	             |-------|  |-------|  |-------|  |-------|;	OMDPLI ----->|       |  | gencar|  |       |  | gencar|;	             |       |  |       |  |       |  |       |;	             |       |  |-------|  |       |  |-------|;	             |       |  | gencar|  |       |  | gencar|;	             |       |  |       |  |       |  |       |;	             |       |  |-------|  |       |  |-------|;	             |       |  | gencar|  |       |  | gencar|;	             |       |  |       |  |       |  |       |;	             |       |  |-------|  |       |  |-------|;	             |       |  |   0   |  |       |  |   0   |;	             |       |  |-------|  |       |  |-------|;	             |       |  |       |  |       |  |       |;	             |       |  |       |  |       |  |       |;;	nom:       nom de l'imprimante (OKI, LQ, etc.);	var:       qq variables permanantes concerves chez l'utilisateur;	gencar:    3 bytes pour coder un gencar; in	A4.L	^buffer;	D4.W	longueur du buffer (3 bytes par gencar); out	D7.W	erreur; mod	D7.W	.END