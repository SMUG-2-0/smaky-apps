	.SBTTL	DGENCMOD;-------------\\; _DGENC_MODIF >;=============/; Dialogue pour la DBOX des gencars.; in	D2.W	mode d'ouverture;	D3.L	v. coordonne (selon D2.W);	D4.L	fanions;	A4.L	^buffer des gencars;	A5.L	^liste des gencars (si liste vide, -1 au dbut);	D5.W	^longueur buffer si A5=^nil;	D1.L	gencar  ne jamais dtruire "-fst"";	A2.L	^descripteur de la fentre; out	D3.W	dernire touche (F1/F4/END);		 F1  => modifie (et pas cre);		 F4  => supprime;		 END => termine;	D4.L	fanions;	A4.L	^gencar modifi/supprim (utile si D3=F1/F4);	D2.L	ancien gencar "-fst" (utile si D3=F1);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A4.L_DGENC_MODIF:	PUSHM.L	D0,D1,D5,A0..A3,A5,A6	LOAD.L	D0,D4	LOAD.L	A0,A4	PUSH.L	D1	LOAD.L	D4,#LGMD	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	POPM.L	D1	JUMP,NE ERFAT$	GESMEM	?CLEARMEM	; met TOUTES les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.W	(A6)+OMDMOD,D2	; mm. mode d'ouverture	LOAD.L	(A6)+OMDPOS,D3	; mm. position	LOAD.L	(A6)+OMDPGC,A0	; mm. ^buffer des gencars	LOAD.L	(A6)+OMDNOK,D1	; mm. gencar  ne jamais dtruire	LOAD.L	(A6)+OMDPDD,A2	; mm. ^descripteur de la fentre	LOAD.L	(A6)+OMDPLN,A5	LOAD.L	A5,#(A5)+LGMN	LOAD.L	(A6)+OMDPLV,A5	; mm. ^qq variables permanantes	LOAD.L	A5,#(A5)+LGMV	LOAD.L	(A6)+OMDPLI,A5	; mm. ^liste des gencars	LOAD.W	(A6)+OMDLLI,D5	; mm. lg liste des gencars	LOAD.L	A5,(A6)+OMDPLN	COMP.B	(A5),#-2	; nom de l'imprimante dans la liste ?	JUMP',NE NAM4$		; non => NAM4$NAM3$:	TEST.B	(A5+)		; A5 <-- saute le nom de l'imprimante	JUMP,NE NAM3$NAM4$:	LOAD.L	(A6)+OMDPLF,A5	; mm. ^flag (-1 si vide, autre si plein)	LOAD.L	D4,D0		; D4 <-- fanions existent ?	JUMP',NE REFAIT$	; oui => REFAIT$	LOAD.L	D4,#1		; non => met le fanion "Fond" par dfautREFAIT$:	LOAD.L	A3,(A6)+OMDPLV	; A3 <-- ^variables permanantes	TEST.L	(A3)+OMVPFI	; mise  jour aprs PREND en cours ?	JUMP,NE PRENDL$		; oui => PRENDL$	LOAD.W	D2,(A6)+OMDMOD	; D2 <-- mode d'ouverture	LOAD.L	D3,(A6)+OMDPOS	; D3 <-- position	LOAD.L	A2,#R16"TDBOX_GENCAR	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	CLR.W	D2AFF$:	CALL	DBGCAFN		; affiche un nom	INC.W	D2		; D2 <-- no nom suivant	COMP.W	D2,#MAXGC	JUMP,LO	AFF$	JUMP	AFCREMOD$	; mj la touche Cre/ModifieLOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEYOKAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#CR		; cre/modifie ?	JUMP,EQ CREE$	COMP.W	D3,#F4		; supprime ?	JUMP,EQ SUPP$	COMP.W	D3,#END		; termine ?	JUMP,EQ TERM$	COMP.W	D3,#DEFINE	; clic dans "circle" ?	JUMP,EQ AFCREMOD$	COMP.W	D3,#F7		; prend ?	JUMP,EQ PREND$	COMP.W	D3,#F9		; sauve ?	JUMP,EQ SAUVE$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$PREND$:				; PREND =>	DBOX_	CLOSE		; ferme la DBOX	CALL	PREND		; prend une liste de caractres ...	JUMP,NE ERROR$	LOAD.L	A3,(A6)+OMDPLV	; A3 <-- ^variables permanantes	LOAD.L	(A3)+OMVPFI,A4	CLR.B	(A3)+OMVNOGPRENDL$:	CALL	PRENDMAJ	; met  jour un gencar	JUMP,NE REFAIT$		; si fini => REFAIT$	TEST.W	D3	JUMP,EQ REFAIT$	JUMP	EXIT$SAUVE$:				; SAUVE =>	DBOX_	CLOSE		; ferme la DBOX	CALL	SAUVE		; sauve la liste de caractres ...	JUMP,NE ERROR$	JUMP	REFAIT$AFCREMOD$:			; CIRCLE =>	CALL	DBGCGPT		; A4 <-- ^dans le buffer des gencars	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	; positionne au dbut de la touche	POP.L	D4	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP',BC AFCRE$	LIB	?AFTIM	.ASCIZ	" MODIFIE "	.EVEN	JUMP'	AFSUPP$AFCRE$:	LIB	?AFTIM	.ASCIZ	"  CREE   "	.EVENAFSUPP$:	PUSH.L	D4	LOAD.W	D2,#2!2^BDBGCLABEL!2^BDBGCGREY	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP',BC AFSUPG$	TEST.B	(A4)+OGCFLG:#BGCPROT	JUMP',BS AFSUPG$	LOAD.W	D2,#2!2^BDBGCLABEL!2^BDBGCFULLAFSUPG$:	DBOX_	GETCO		; grise/dgrise la touche	POP.L	D4	JUMP	LOOP$CREE$:				; CREE/MODIFIE =>	DBOX_	CLOSE		; ferme la DBOX	CALL	DBGCGPT		; A4 <-- ^dans le buffer des gencars	CLR.L	D1	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP',BC CREE2$	LOAD.L	D1,(A4)+OGCCOD	; D1 <-- gencar actuel	AND.L	D1,#H'FFFFFFCREE2$:	CALL	DBOXCARAC	; modifie le caractre	JUMP',NE ERROR$		; si erreur => ERROR$	CLR.L	D2	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP',BC CREE4$	LOAD.L	D2,(A4)+OGCCOD	; D2 <-- gencar v. modifi	AND.L	D2,#H'FFFFFFCREE4$:	TEST.L	D1		; cration d'un nouveau gencar ?	JUMP,EQ	REFAIT$		; oui => REFAIT$	COMP.L	D1,D2		; gencar modifi ?	JUMP,EQ	REFAIT$		; non => REFAIT$	LOAD.L	D2,D1		; D2 <-- ancien gencar	LOAD.W	D3,#F1	JUMP'	EXIT$ERROR$:	COMP.W	D7,#ERKSTO	JUMP,EQ REFAIT$	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP	POP.W	D7	LOAD.W	D2,(A6)+OMDMOD	; D2 <-- mode d'ouverture	LOAD.L	D3,(A6)+OMDPOS	; D3 <-- position	DBOX_	MERROR		; affiche l'erreur	JUMP	REFAIT$SUPP$:				; SUPPRIME =>	CALL	DBGCGPT		; A4 <-- ^dans le buffer des gencars	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP,BC BIP$	TEST.B	(A4)+OGCFLG:#BGCPROT	JUMP,BS BIP$TERM$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	PUSHM.L	D7,A4	TEST.L	(A6)+OMDPGR	JUMP',EQ NOGR$	LOAD.L	A4,(A6)+OMDPGR	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le gencar rduitNOGR$:	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire	POPM.L	D7,A4ERFAT$:	POPM.L	D0,D1,D5,A0..A3,A5,A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBGCGPT >;--------/; Donne le pointeur dans le buffer des gencars en fonction des fanions.; in	D4.L	fanions; out	A4.L	^dans le buffer des gencars; mod	D7.W, A4.LDBGCGPT:	PUSHM.L	D2,D4	CLR.W	D210$:	SR.L	D4,#1	JUMP',CS 20$	INC.W	D2	JUMP	10$20$:	LOAD.L	A4,(A6)+OMDPGC	; A4 <-- ^buffer des gencars	MUL.WU	D2,#LGGC	ADD.L	A4,D2		; A4 <-- ^dans le buffer des gencars	POPM.L	D2,D4	RET;--------\\; DBGCAFN >;--------/; Affiche un nom dans la dbox.; in	D2.W	rang du nom (0..n);	D5.L	"canal" de la dbox; out	-; mod	D7.WDBGCAFN:	PUSHM.L	D2..D4,A1..A4	LOAD.L	A2,(A6)+OMDPDD	; A2 <-- ^descripteur de la fentre	LOAD.L	A4,(A6)+OMDPGC	; A4 <-- ^buffer des gencars	LOAD.W	D4,D2	MUL.WU	D4,#LGGC	ADD.L	A4,D4		; A4 <-- ^dans le buffer des gencars	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP,BC 90$	SL.W	D2,#1		; D2 <-- premire colonne (0,2,4,6,8)	COMP.W	D2,#MAXGC	JUMP',LO 20$	SUB.W	D2,#MAXGC-1	; D2 <-- deuxime colonne (1,3,5,7,9)20$:	DBOX_	GETCO		; D3/D4 <-- position dbut/fin	LOAD.W	D4,(A2)+ODFCX	MUL.WU	D4,#3	ADD.W	D3,D4		; D3 <-- saute le cercle	LIB	?SETCURS	; positionne au dbut	LOAD.L	D4,D3	LOAD.L	A3,#(A6)+OMDDIS	LOAD.L	A1,A3	LOAD.B	(A1+),#USEGC	LOAD.B	(A1+),(A4)+OGCF	LOAD.B	(A1+),(A4)+OGCS	LOAD.B	(A1+),(A4)+OGCT	LOAD.B	(A1+),#MODCAR	LOAD.B	(A1+),#SETDOT!PENDOT	LOAD.B	(A1+),#'A	; dessine le motif "Abc"	LOAD.B	(A1+),#'b	LOAD.B	(A1+),#'c	LOAD.B	(A1+),#MODCAR	LOAD.B	(A1+),#LOADDOT!PENDOT	LOAD.B	(A1+),#USEGC	LOAD.B	(A1+),(A2)+ODFGCF	LOAD.B	(A1+),(A2)+ODFGCS	LOAD.B	(A1+),(A2)+ODFGCT	LOAD.L	D3,A1	SUB.L	D3,A3		; D3 <-- lg	LIB	?STRING	LOAD.L	D3,D4	ADD.W	D3,#8+(2*32)	; <-- trop serr, mais + fait vilain !	LIB	?SETCURS	LOAD.L	A3,#(A4)+OGCTIT	LIB	?AFTEXT		; affiche le nom90$:	POPM.L	D2..D4,A1..A4	RET;-------------\\; _DGENC_DISGC >;=============/; Libre provisoirement tous les gencars.; in	A4.L	^buffer des gencars;	A2.L	^description de la fentre; out	-; mod	D7.W_DGENC_DISGC:	PUSHM.L	D3,D4,A3,A4	LOAD.W	D4,#MAXGC-110$:	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar occup ?	JUMP',BC 50$		; non => 50$				; oui =>	LOAD.L	A3,#(A4)+OGCCOD	; A3 <-- ^trou, fonte, style/chasse et taille	LOAD.B	(A3)+0,#KILLGC	; trou <-- <killgc>	LOAD.W	D3,#4	LIB	?STRING		; libre gencar50$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^gencar suivant	DECJ.W,NMO D4,10$	POPM.L	D3,D4,A3,A4	RET;-------------\\; _DGENC_ENAGC >;=============/; Reprend tous les gencars librs provisoirement.; in	A4.L	^buffer des gencars;	A2.L	^description de la fentre; out	-; mod	D7.W_DGENC_ENAGC:	PUSHM.L	D3,D4,A3,A4	LOAD.W	D4,#MAXGC-110$:	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar tait occup ?	JUMP',BC 50$		; non => 50$				; oui =>	LOAD.L	A3,#(A4)+OGCCOD	; A3 <-- ^trou, fonte, style/chasse et taille	LOAD.B	(A3)+0,#LOADGC	; trou <-- <loadgc>	LOAD.W	D3,#4	LIB	?STRING		; charge gencar	JUMP',NE 40$	LOAD.B	(A3)+0,#USEGC	; trou <-- <usegc>	LIB	?STRING		; utilise gencar	JUMP',NE 40$	LOAD.L	A3,(A2)+ODFPGC	; A3 <-- ^gencar	LOAD.L	(A4)+OGCPT,A3	; re-init juste le pointeur !	JUMP'	50$40$:	TCLR.B	(A4)+OGCFLG:#BGCUSE ; gencar libre !!!50$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^gencar suivant	DECJ.W,NMO D4,10$	POPM.L	D3,D4,A3,A4	RET;--------------\\; _DGENC_SEARCH >;==============/; Cherche un gencar d'aprs son titre.; Si le gencar cherch est dans le buffer des gencars,; il ne se trouve pas lui-mme !; in	A3.L	^nom d'un titre de gencar;	A4.L	^buffer des gencars; out	A4.L	^dans le buffer des gencars;	D4.W	no du gencar;	D7.W	erreur; mod	D4.W, D7.W, A4.L_DGENC_SEARCH:	PUSHM.L	D3,A1,A2	LOAD.W	D7,#ERDIGC	; D7 <-- pas trouv	LOAD.W	D4,#MAXGC10$:	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BC 30$		; non => 30$	LOAD.L	A1,A3		; A1 <-- ^titre cherch	LOAD.L	A2,#(A4)+OGCTIT	; A2 <-- ^titre dans le buffer des gencars	COMP.L	A1,A2		; est-ce lui-mme ?	JUMP',EQ 30$		; oui => 30$ (ne le trouve pas)20$:	TEST.B	(A2)	JUMP',EQ 50$	COMP.B	(A2+),(A1+)	JUMP,EQ	20$30$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^suivant	DEC.W	D4	JUMP,NE	10$	JUMP'	90$50$:	LOAD.B	D3,(A1)	JUMP',EQ 80$	COMP.B	D3,#';	JUMP',EQ 80$	COMP.B	D3,#':	JUMP,NE	30$80$:	SUB.W	D4,#MAXGC	NEG.W	D4		; D4 <-- no du gencar	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,A1,A2	TEST.W	D7		; retour EQ/NE	RET;------------\\; _DGENC_FREE >;============/; Cherche un gencar libre.; in	A4.L	^buffer des gencars; out	A4.L	^dans le buffer des gencars;	D4.W	no du gencar;	D7.W	erreur; mod	D4.W, D7.W, A4.L_DGENC_FREE:	LOAD.W	D4,#MAXGC10$:	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar libre ?	JUMP',BC 80$		; oui => 80$	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^suivant	DEC.W	D4	JUMP,NE	10$	LOAD.W	D7,#ERDIGC	; D7 <-- pas trouv	JUMP'	90$80$:	SUB.W	D4,#MAXGC	NEG.W	D4		; D4 <-- no du gencar	CLR.W	D7		; D7 <-- trouv90$:	TEST.W	D7		; retour EQ/NE	RET;-----------\\; _DGENC_NEW >;===========/; Si ncessaire, charge un nouveau gnrateur de caractre.; Il est interdit de librer le gencar, car il peut tre utilis; dans un buffer de texte !; in	A4.L	^lment dans le buffer des gencars;	A3.L	^buffer des gencars;	D4.L	gencar  ne pas dtruire;	A2.L	^description de la fentre; out	D7.W	erreur; mod	D7.W_DGENC_NEW:	PUSHM.L	D3..D5,A3..A5	LOAD.L	A5,A3		; A5 <-- ^buffer des gencars	LOAD.L	D3,(A2)+ODFGCF	SR.L	D3,#8		; D3 <-- "-fst" actuellement utilis	PUSH.L	D3		; hop, sur le stack; Essaye de charger le gencar tel qu'il a t demand.	LOAD.L	A3,#(A4)+OGCCOD	; A3 <-- ^trou, fonte, style/chasse et taille	LOAD.B	(A3)+0,#LOADGC	; trou <-- <loadgc>	LOAD.W	D3,#4	LIB	?STRING		; charge gencar	JUMP,NE 60$	LOAD.B	(A3)+0,#USEGC	; trou <-- <usegc>	LIB	?STRING		; utilise gencar	JUMP,NE 60$	LOAD.L	A3,A5		; A3 <-- ^buffer des gencars	CALL	_DGENC_KILL	; si ncessaire, libre l'ancien gencar	TSET.B	(A4)+OGCFLG:#BGCUSE ; signal gencar occup	LOAD.L	A3,(A2)+ODFPGC	; A3 <-- ^gencar	LOAD.L	(A4)+OGCPT,A3	LOAD.W	(A4)+OGCITL,(A3)+OGCISP	LOAD.W	(A4)+OGC1Y,(A3)+OGCMH1	LOAD.W	(A4)+OGC2Y,(A3)+OGCMH2	LOAD.W	(A4)+OGCX,(A3)+OGCMWI	LOAD.W	(A4)+OGC1X,(A3)+OGCLMA	LOAD.W	D3,(A3)+OGCMWI	SUB.W	D3,(A3)+OGCLMA	LOAD.W	(A4)+OGC2X,D3; S'il s'agit d'un caractre fait par l'imprimante en mode "texte" (D ou Q),; initialise la chasse fixe ou proportionnelle selon l'en-tte du gencar.; Autrement, met toujours la chasse proportionnelle, car l'imprimante le fait; en mode graphique.;;?	LOAD.B	(A4)+OGCVAR,(A3)+OGCVSP;;?	LOAD.B	D3,(A4)+OGCF;;?	TCLR.L	D3:#7		; D3 <-- fonte;;?	COMP.B	D3,#'D;;?	JUMP',EQ 50$;;?	COMP.B	D3,#'Q;;?	JUMP',EQ 50$;;?	SET.B	(A4)+OGCVAR;;?50$:	SET.B	(A4)+OGCVAR	; chasse proportionnelle	LOAD.B	D3,(A4)+OGCF	TCLR.L	D3:#7		; D3 <-- fonte	COMP.B	D3,#'D	JUMP',EQ 50$	COMP.B	D3,#'Q	JUMP',NE 52$50$:	TEST.B	(A4)+OGCS:#7	; DRF ou QRF ?	JUMP',BC 52$		; non => 52$	CLR.B	(A4)+OGCVAR	; oui => chasse fixe52$:	LOAD.L	A3,#(A4)+OGCNAM	LOAD.L	D4,(A4)+OGCCOD	; D4 <-- "-fst"	CALL	_DGENC_PUT	; construit le nom du gencar	CLR.W	D7	JUMP'	90$; En cas d'erreur, reprend le nom du gencar (qui n'a pas encore; t modifi) et re-calcul OGCF, OGCS et OGCT pour reprendre; les valeurs initiales.60$:				; erreur =>	PUSH.W	D7	LOAD.L	A3,#(A4)+OGCNAM	; A3 <-- ^nom du gencar	CALL	_DGENC_GET	; D5 <-- "fst" compactifi	LOAD.L	(A4)+OGCCOD,D5	; buffer des gencars <-- "fst" compactifi	POP.W	D790$:	LOAD.W	D5,D7	LOAD.L	A3,SP		; A3 <-- ^dbut "-fst" sur le stack	LOAD.B	(A3)+0,#USEGC	LOAD.W	D3,#4	LIB	?STRING		; r-utilise le gencar initial	POP.L	D3		; compense le PUSH.L D3	LOAD.W	D7,D5	POPM.L	D3..D5,A3..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; _DGENC_PUT >;===========/; Construit le nom du gencar en fonction des 3 bytes compactifis.; in	D4.L	"-fst";	A3.L	^buffer o mettre le nom en clair; out	-; mod	D7.W_DGENC_PUT:	PUSHM.L	D3..D5,A3	LOAD.L	D5,D4		; D5 <-- "-fst"	RL.L	D5,#8	RL.L	D5,#8		; D5 <-- "st-f"	LOAD.B	D3,D5		; D3 <-- fonte	AND.B	D3,#H'7F	CALL	MAJMIN	LOAD.B	(A3+),D3	; nom <-- fonte	TEST.L	D5:#7	JUMP',BS 30$	RL.L	D5,#8		; D5 <-- "t-fs"	LOAD.B	D3,D5		; D3 <-- style	LOAD.B	D4,#'p	TCLR.L	D3:#7	JUMP',BC 20$	LOAD.B	D4,#'f20$:	CALL	MAJMIN	LOAD.B	(A3+),D3	; nom <-- style	LOAD.B	(A3+),D4	; nom <-- chasse (p/f)	JUMP'	50$30$:	RL.L	D5,#8		; D5 <-- "t-fs"	LOAD.B	D3,D5		; D3 <-- style	LOAD.B	(A3+),#'(	TEST.L	D3:#BGCBOLD	JUMP',BC 31$	LOAD.B	(A3+),#'b31$:	TEST.L	D3:#BGCITAL	JUMP',BC 32$	LOAD.B	(A3+),#'i32$:	TEST.L	D3:#BGCOUTL	JUMP',BC 33$	LOAD.B	(A3+),#'o33$:	TEST.L	D3:#BGCSHAD	JUMP',BC 34$	LOAD.B	(A3+),#'s34$:	TEST.L	D3:#BGCLARG	JUMP',BC 35$	LOAD.B	(A3+),#'l35$:	TEST.L	D3:#BGCFIX	JUMP',BC 36$	LOAD.B	(A3+),#'f36$:	LOAD.B	(A3+),#')50$:	RL.L	D5,#8		; D5 <-- "-fst"	CLR.L	D3	LOAD.B	D3,D5		; D3 <-- taille	DIV.WU	D3,#10		; D3 <-- units/dizaines	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; nom <-- dizaines taille	SWAP.W	D3	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; nom <-- units taille	CLR.B	(A3)		; nom <-- terminateur	POPM.L	D3..D5,A3	RET;------------\\; _DGENC_KILL >;============/; Libre un gencar "hard" ou "soft".; Attention: accepte de librer le gencar du Fond, indestructible !; in	A4.L	^dans le buffer des gencars;	A3.L	^buffer des gencars;	D4.L	gencar  ne pas dtruire; out	D7.W	erreur; mod	D7.W_DGENC_KILL:	PUSHM.L	D3..D5,A3,A4	LOAD.W	D7,#ERDIGC	; D7 <-- destruction impossible	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar occup ?	JUMP,BC 90$		; non => 90$				; oui =>	PUSH.L	A3	LOAD.L	A3,#(A4)+OGCNAM	; A3 <-- ^nom du gencar	CALL	_DGENC_GET	; D5 <-- "-fst" gencar  dtruire	POP.L	A3; Vrifie si le gencar  dtruire est encore utilis par un; autre gencar. Si oui, ne le dtruit pas !	LOAD.W	D3,#MAXGC10$:	COMP.L	A3,A4		; celui  dtruire ?	JUMP',EQ 30$		; oui => 30$	TEST.B	(A3)+OGCFLG:#BGCUSE ; gencar utilis ?	JUMP',BC 30$		; non => 30$	CLR.B	(A3)+OGCCOD	COMP.L	D5,(A3)+OGCCOD	; mme gencar utilis ?	JUMP',EQ 80$		; oui => 80$30$:	LOAD.L	A3,#(A3)+LGGC	; A3 <-- ^suivant	DEC.W	D3	JUMP,NE	10$	LOAD.W	D7,#ERDIGC	; D7 <-- destruction impossible	COMP.L	D5,D4		; gencar  ne pas dtruire ?	JUMP',EQ 80$		; oui => 80$				; non =>	PUSH.L	D5	LOAD.L	A3,SP		; A3 <-- ^dbut D5.L sur le stack (rigolo)	LOAD.B	(A3)+0,#KILLGC	LOAD.W	D3,#4	LIB	?STRING		; libre le gencar	POP.L	D580$:	TCLR.B	(A4)+OGCFLG:#BGCUSE ; libre le gencar90$:	POPM.L	D3..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; _DGENC_GET >;===========/; Vrifie la syntaxe d'un nom de gencar "fsctt".; in	A3.L	^fsctt; out	A3.L	^plus loin;	D5.L	"fst" compactifi :	| - | f | s | t |;	D7.W	erreur; mod	D5.L, D7.W, A3.L_DGENC_GET:	PUSHM.L	D3,D4	LOAD.W	D7,#ERSYNT	CLR.L	D5	LOAD.B	D3,(A3+)	; D3 <-- fonte	CALL	MINMAJ		; D3 <-- fonte MAJUSCULE	COMP.B	D3,#'A	JUMP,LO 90$	COMP.B	D3,#'Z		; lettre ?	JUMP,HI	90$		; non => 90$	LOAD.B	D5,D3		; D5 <-- fonte	SL.W	D5,#8	LOAD.B	D3,(A3+)	; D3 <-- style	COMP.B	D3,#'(	JUMP',NE 40$	TSET.L	D5:#8+7		; D5 <-- fonte "soft"30$:	LOAD.B	D3,(A3+)	; D3 <-- style "soft"	CALL	MINMAJ		; D3 <-- style MAJUSCULE	COMP.B	D3,#'B		; bold ?	JUMP',EQ 32$	COMP.B	D3,#'I		; italique ?	JUMP',EQ 33$	COMP.B	D3,#'O		; outline ?	JUMP',EQ 34$	COMP.B	D3,#'S		; shadow ?	JUMP',EQ 35$	COMP.B	D3,#'L		; large ?	JUMP',EQ 36$	COMP.B	D3,#'F		; fix ?	JUMP',EQ 37$	COMP.B	D3,#'P		; proportionnel ?	JUMP,EQ 30$	COMP.B	D3,#')	JUMP,NE	90$	JUMP	60$32$:	TSET.L	D5:#BGCBOLD	JUMP	30$33$:	TSET.L	D5:#BGCITAL	JUMP	30$34$:	TSET.L	D5:#BGCOUTL	JUMP	30$35$:	TSET.L	D5:#BGCSHAD	JUMP	30$36$:	TSET.L	D5:#BGCLARG	JUMP	30$37$:	TSET.L	D5:#BGCFIX	JUMP	30$40$:	CALL	MINMAJ		; D3 <-- style MAJUSCULE	COMP.B	D3,#'A	JUMP,LO	90$	COMP.B	D3,#'Z		; lettre ?	JUMP,HI	90$		; non => 90$	LOAD.B	D5,D3		; D5 <-- style	LOAD.B	D3,(A3+)	; D3 <-- chasse	CALL	MINMAJ		; D3 <-- chasse MAJUSCULE	COMP.B	D3,#'P	JUMP',EQ 60$	COMP.B	D3,#'F		; prop/fix ?	JUMP,NE	90$		; non => 90$	TSET.L	D5:#BGCFIX	; D5 <-- style fixe60$:	SL.L	D5,#8	LOAD.B	D3,(A3+)	; D3 <-- dizaines	SUB.B	D3,#'0	JUMP',LO 90$	COMP.B	D3,#10	JUMP',HS 90$	LOAD.B	D4,D3	LOAD.B	D3,(A3)		; D3 <-- units	SUB.B	D3,#'0	JUMP',LO 70$	COMP.B	D3,#10	JUMP',HS 70$	INC.L	A3	MUL.WU	D4,#10	ADD.B	D4,D370$:	LOAD.B	D5,D4		; D5 <-- taille	LOAD.B	D3,(A3)	CALL	MINMAJ	COMP.B	D3,#'P	JUMP',NE 80$	INC.L	A3	LOAD.B	D3,(A3)	CALL	MINMAJ	COMP.B	D3,#'G		; si "nrf12PG", saute l'unit "PG"	JUMP',NE 80$	INC.L	A380$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;------------\; _DGENC_MENU >;============/; Construit le menu pour choisir le gencar.; in	A4.L	^buffer des gencars;	A3.L	^buffer pour le menu;		 lg min = ((15+LGTGC)*MAXGC)+10 = 280 !;	A2.L	^descripteur de la fentre; out	A3.L	^fin du menu (sur le zro terminateur); mod	D7.W, A3.L_DGENC_MENU:	PUSHM.L	D3,A1,A2,A4	LOAD.B	(A3+),#SPACE	; buffer <-- premire case vide	CLR.B	(A3+)	LOAD.L	A1,#(A4)+LGGC*MAXGC ; A1 <-- ^fin du buffer	LOAD.W	D3,#MAXGC10$:	LOAD.L	A1,#(A1)-LGGC	; A1 <-- ^prcdent	TEST.B	(A1)+OGCFLG:#BGCUSE ; gencar occup ?	JUMP',BS 20$		; oui => 20$	DEC.W	D3	JUMP,NE	10$	JUMP	80$20$:	LOAD.B	(A3+),#-1	; buffer <-- ligne horizontale30$:	TEST.B	(A4)+OGCFLG:#BGCUSE ; gencar occup ?	JUMP',BC 50$		; non => 50$				; oui =>	LOAD.B	(A3+),#SPACE	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),(A4)+OGCF	LOAD.B	(A3+),(A4)+OGCS	LOAD.B	(A3+),(A4)+OGCT	LOAD.B	(A3+),#'A	; dessine le motif "Abc"	LOAD.B	(A3+),#'b	LOAD.B	(A3+),#'c	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),(A2)+ODFGCF	LOAD.B	(A3+),(A2)+ODFGCS	LOAD.B	(A3+),(A2)+ODFGCT	LOAD.B	(A3+),#TYPOAX	LOAD.B	(A3+),#0	LOAD.B	(A3+),#8+(3*32)	LOAD.L	A1,#(A4)+OGCTIT	; A1 <-- ^nom du titre40$:	LOAD.B	(A3+),(A1+)	; buffer <-- un titre	JUMP,NE	40$	JUMP'	60$50$:				; case vide =>	LOAD.B	(A3+),#SPACE	; met juste un espace	CLR.B	(A3+)60$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^suivant	DEC.W	D3	JUMP,NE	30$80$:	CLR.B	(A3)		; buffer <-- terminateur	POPM.L	D3,A1,A2,A4	RETTDBOX_GENCAR:	.W	10$-TDBOX_GENCAR	.W	20$-TDBOX_GENCAR	.W	0,010$:	.B	ODBCIRCLE,0!2^7,0,DEFINE	.ASCIZ	"                     "	.B	ODBTABX,30	.B	ODBCIRCLE,5!2^7,0,DEFINE	.ASCIZ	"                     "	.B	ODBTABX,30+30	.B	ODBCR,ODBCR	.B	ODBCIRCLE,1!2^7,0,DEFINE	.ASCIZ	"                     "	.B	ODBTABX,30	.B	ODBCIRCLE,6!2^7,0,DEFINE	.ASCIZ	"                     "	.B	ODBCR,ODBCR	.B	ODBCIRCLE,2!2^7,0,DEFINE	.ASCIZ	"                     "	.B	ODBTABX,30	.B	ODBCIRCLE,7!2^7,0,DEFINE	.ASCIZ	"                     "	.B	ODBCR,ODBCR	.B	ODBCIRCLE,3!2^7,0,DEFINE	.ASCIZ	"                     "	.B	ODBTABX,30	.B	ODBCIRCLE,8!2^7,0,DEFINE	.ASCIZ	"                     "	.B	ODBCR,ODBCR	.B	ODBCIRCLE,4!2^7,0,DEFINE	.ASCIZ	"                     "	.B	ODBTABX,30	.B	ODBCIRCLE,9!2^7,0,DEFINE	.ASCIZ	"                     "	.B	ODBCR,ODBCR,ODBCR	.B	ODBLABEL,1	.B	ODBBOX,0,CR,TDBNORM	.ASCIZ	" MODIFIE "	.B	ODBLABEL,2	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	" SUPPRIME "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" PREND "	.B	ODBBOX,0,F9,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,END,TDBMEV	.ASCIZ	" TERMINE "	.B	0	.EVEN20$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Cre/Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Supprime"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Termine"	.EVENTKEYOKAN:	.W	CR,F1,F2,F3,0		DOOK-TKEYOKAN	.W	END,F13,F14,F15,0	DOAN-TKEYOKAN	.W	KEYMGP,KEYMMP,KEYMDP,0	DOMP-TKEYOKAN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOMR-TKEYOKAN	.W	0	.END