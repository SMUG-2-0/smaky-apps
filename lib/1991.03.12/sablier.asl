	.TITLE	SABLIER	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcima	.REF	SM8		; df diverses	.REF	NTREL		; df noyau temps rel	.REF	GESMEM		; df gestionnaire de mmoire	.REF	FOS		; df file operating system	.REF	LIB		; df librairie	.REF	DRIVERS		; df drivers	.REF	DOLIB		; df restart LIB	.REF	SABLIER		; df sablier	.REV	1,0; Constantes; ----------TRAMNEW	=	H'88882222	; trame claireTRAMOLD	=	H'7777DDDD	; trame plus fonce; Variables; ---------	.LOC	0OCOIN:				; position coin sup/gauche de la boteOCOINY:	.BLKB	2OCOINX:	.BLKB	2ODIM:				; dimensions totales de la boteODIMY:	.BLKB	2ODIMX:	.BLKB	2OLGTRAN:.BLKB	2		; largeur en X d'une trancheOPOSAV:	.BLKB	2		; ancienne de l'avance en XONBTRAN:.BLKB	2		; compteur nb de tranchesLGVAR:; En-tte du module LIB; ---------------------	.LOC	0	.W	SABLIER_OPEN	; code du premier appel	.W	SABLIER_MAJ	; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	1,0		; rvision.version	.W	0,END_SABLIER	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"SABLIER"	; nom du module	.FILLB	(LGHLIB-.),0	.W	_SABLIER_OPEN	.W	_SABLIER_NEXT	.W	_SABLIER_CLOSE	.W	_SABLIER_MAJ; Codes des appels; ----------------;--------------\; _SABLIER_OPEN >;==============/; Dessine un sablier.; in	D4.W	nombre de tranches (1..100); out	D6.L	canal;	D7.W	erreur; mod	D6.L, D7.W_SABLIER_OPEN:	PUSHM.L	D0,D1,D2,D3,D4,D5,A4,A6	LOAD.W	D0,D4		; D0 <-- nb de tranches	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	.W	GESMEM,?GETMEM	; demande mmoire pour variables	JUMP,NE	90$	LOAD.L	A6,A4		; A6 <-- ^variables	.W	LIB,?AFTIM	.B	CR,CR,CR,CR,CR,0	.EVEN	LOAD.W	(A6)+ONBTRAN,D0	.W	LIB,?GETCURS	LOAD.L	D2,D3		; D2 <-- position curseur	.W	LIB,?GETWDO	; D4 <-- dim fentre (swdo)	LOAD.L	D5,D4		; D5 <-- dim fentre (swdo)	.W	LIB,?GETDIM	; D3 <-- dim caractres	EX.L	D3,D2		; D2 <-- dim caractres, D3 <-- pos	LOAD.L	D4,D5		; D4 <-- dim fentre (swdo)	SL.W	D2,#1		; D2 <-- largeur de 2 caractres	LOAD.W	D3,D2		; D3 <-- marge  gauche	SUB.W	D4,D2	SUB.W	D4,D2		; D4 <-- largeur avec marges gauche/droite	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D2	SL.W	D2,#1		; D2 <-- hauteur de 2 lignes	SUB.W	D3,D2		; D3 <-- remonte de 3 lignes	LOAD.W	D4,D2		; D4 <-- hauteur de 2 lignes	SWAP.W	D4	SWAP.W	D3	CLR.L	D2	LOAD.W	D2,D4		; D2 <-- largeur	DIV.WU	D2,D0	LOAD.W	(A6)+OLGTRAN,D2	MUL.WU	D2,D0	LOAD.W	D4,D2		; D4 <-- largeur arrondie	LOAD.L	(A6)+OCOIN,D3	LOAD.L	(A6)+ODIM,D4	LOAD.W	(A6)+OPOSAV,(A6)+OCOINX	LOAD.L	D6,A6		; D6 <-- canal	CALL	_SABLIER_MAJ	; dessine le sablier	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1,D2,D3,D4,D5,A4,A6	RET;--------------\; _SABLIER_NEXT >;==============/; Avance le sablier.; in	D6.L	canal; out	D7.W	erreur; mod	D7.W_SABLIER_NEXT:	PUSHM.L	D0,D1,D2,D3,D4,A6	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.W	D7,#EROUTF	; D7 <-- fin du fichier !	TEST.W	(A6)+ONBTRAN	JUMP,EQ	90$	DEC.W	(A6)+ONBTRAN	LOAD.W	D0,(A6)+OPOSAV	; D0 <-- ancienne position	ADD.W	D0,(A6)+OLGTRAN	; D0 <-- avance d'un incrment	CLR.L	D3	CLR.L	D4	.W	LIB,?DRMDEF	; dfinit une trame vide	LOAD.L	D3,(A6)+OCOIN	LOAD.L	D4,(A6)+ODIM	LOAD.W	D3,D0	LOAD.W	D4,D0	SUB.W	D4,(A6)+OPOSAV	TEST.W	(A6)+ONBTRAN	JUMP,EQ	30$	LOAD.W	D2,#CLRDOT	.W	LIB,?DRMATRIX	; efface30$:	PUSHM.L	D3,D4	LOAD.L	D3,#TRAMOLD	LOAD.L	D4,D3	.W	LIB,?DRMDEF	; dfinit une trame pleine	POPM.L	D3,D4	SUB.W	D3,(A6)+OLGTRAN	LOAD.W	D2,#SETDOT	.W	LIB,?DRMATRIX	; dessine	LOAD.W	(A6)+OPOSAV,D090$:	POPM.L	D0,D1,D2,D3,D4,A6	TEST.W	D7		; retour EQ/NE	RET;---------------\; _SABLIER_CLOSE >;===============/; Efface le sablier.; in	D6.L	canal; out	-; mod	-_SABLIER_CLOSE:	PUSHM.L	D1,D7,A4,A6	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	.W	GESMEM,?GIVMEM	; rend les variables	POPM.L	D1,D7,A4,A6	RET;-------------\\; _SABLIER_MAJ >;=============/; Raffiche le sablier.; in	D6.L	canal; out	-; mod	D7.W_SABLIER_MAJ:	PUSHM.L	D1,D2,D3,D4,A6	LOAD.L	A6,D6		; A6 <-- ^variables	LOAD.L	D3,#TRAMOLD	LOAD.L	D4,D3	.W	LIB,?DRMDEF	; dfini la trame de gauche	LOAD.L	D3,(A6)+OCOIN	LOAD.L	D4,(A6)+ODIM	LOAD.W	D4,(A6)+OPOSAV	SUB.W	D4,D3	JUMP,EQ	20$	LOAD.W	D2,#SETDOT	.W	LIB,?DRMATRIX	; rempli le tout (les 1)	LOAD.W	D2,#CLRDOT	.W	LIB,?DRMATRIX	; rempli le tout (les 0)20$:	CLR.L	D3	CLR.L	D4	.W	LIB,?DRMDEF	; dfini la trame du milieu	LOAD.L	D3,(A6)+OCOIN	LOAD.L	D4,(A6)+ODIM	LOAD.W	D3,(A6)+OPOSAV	LOAD.W	D4,(A6)+OLGTRAN	LOAD.W	D2,#CLRDOT	.W	LIB,?DRMATRIX	; efface	LOAD.L	D3,#TRAMNEW	LOAD.L	D4,D3	.W	LIB,?DRMDEF	; dfini la trame de droite	LOAD.L	D3,(A6)+OCOIN	LOAD.L	D4,(A6)+ODIM	LOAD.W	D3,(A6)+OPOSAV	ADD.W	D3,(A6)+OLGTRAN	LOAD.W	D4,(A6)+ODIMX	ADD.W	D4,(A6)+OCOINX	SUB.W	D4,D3	JUMP,EQ	40$	LOAD.W	D2,#SETDOT	.W	LIB,?DRMATRIX	; rempli le tout (les 1)	LOAD.W	D2,#CLRDOT	.W	LIB,?DRMATRIX	; rempli le tout (les 0)40$:	LOAD.L	D3,(A6)+OCOIN	LOAD.L	D4,(A6)+ODIM	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D1,#2		; D1 <-- double paisseur60$:	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LOAD.W	D2,#SETDOT	; D2 <-- mode	.W	LIB,?DRRECT	; dessine rectangle extrieur	DEC.W	D1	JUMP,NE	60$	POPM.L	D1,D2,D3,D4,A6	RETEND_SABLIER:	.END