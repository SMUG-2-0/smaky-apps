	.TITLE	SMA_LDIMA.ASC;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------;	Source du programme SMA_LDIMA.CODE;	Date		Amliorations; --------------------------------------------------------------------------; 2.3	21.02.91	affiche .COLOR si existe;			accepte "SMA_LDIMA image" dans la macro de dmarrage; 2.2	14.12.87	affiche l'image si REP:DESSIN.CODE;			arrondi les coins si la fentre est plus grande; 2.1			tient compte des crans  fond blanc; 2.0			version utilise trs longtemps	.PROC	M680002	.REF	SMAKY	.REF	MODULES	.REF	TCOLOR;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;GRA_CRASTER = H'A899		; raster-op couleurGRA_GDOT = H'A89A		; get-dotBSRCCOUL = 11BDSTCOUL = 12;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;MAJREV	=	2		; rvisionMINREV	=	3		; version	.REV	MAJREV,MINREV; Constantes; ----------TRAGRIS	=	H'11441144	; trame grise; En-tte d'un fichier .IMAGE/.COLOR; ----------------------------------	.LOC	0	.BLKB	1		; OIMTYP: H'82	.BLKB	1		; OIMCOD: 0 ou 4	.BLKB	1		; OIMBIP: 4 bits/pixel	.BLKB	1		; OIMDIR: 2	.BLKB	2		; OIMDLX: largeur (multiple de 16)	.BLKB	2		; OIMDLY: hauteur	.BLKB	4		; OIMNBB: longueur du dataOIMSIZ:	.BLKB	2		; taille d'un pixel (4)OIMCNT:	.BLKB	2		; nb de pixels (1)OIMLGC:	.BLKB	4		; longueur de la CLUT	.BLKB	12		; rserve				; LGHIMA: longueur de l'en-tte; Dbut du code; -------------	.LOC	0START:	LIB	?OPELIB	PUSH.L	A0	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,SP		; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	POPM.L	A0		; A0 <-- ^status rel	JUMP',NE EXEC$	CLR.W	D5		; D5 <-- pas de "LDIMA" dans la ligne de commande	LOAD.L	A4,A3	LOAD.L	A3,#R16"NMLDIMA	LOAD.L	A2,#R16"LTLDIMA	LIB	?CPSTRING	; ligne de commande commence par "LDIMA" ?	LOAD.L	A3,A4	JUMP',NS DRAW$		; non => DRAW$	INC.W	D5		; D5 <-- "LDIMA" dans la ligne de commande	LIB	?SKPNAM		; A3 <-- saute "LDIMA"	JUMP',NE EXEC$DRAW$:	CALL	AFCLEAR		; efface la fentre	CALL	AFCOLOR		; affiche l'image couleur	JUMP',EQ EXEC$	CALL	AFIMAGE		; affiche l'image noir/blancEXEC$:	TEST.W	D5		; "LDIMA" dans la ligne de commande ?	JUMP,NE STOP$		; oui => STOP$	TSET.B	(A3):#7		; pour ne pas afficher l'image !	LIB	?OEXECUTE	; excute et attend ...	JUMP',EQ END$		; ok => END$				; erreur =>	LOAD.W	D0,D7		; D0 <-- erreur	LOAD.L	A0,A3		; A0 <-- ^nom	LOAD.W	D3,#BIPERR	LIB	?BEEP		; crac boum patatra	LOAD.W	D3,#3	LIB	?MOUSE		; souris par le clavier	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN		; ouvre le module DBOX	JUMP',NE END$	LOAD.W	D7,D0		; D7 <-- erreur	LOAD.L	A3,A0		; A3 <-- ^nom	CLR.W	D2		; D2 <-- mode sans sauver le fond !	DBOX_	MERROR		; affiche l'erreur ...	LIB_	CLOSE		; ferme le module DBOXEND$:	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface la fentre	JUMP'	QUIT$STOP$:	CLR.L	D3	CLR.L	D4	LIB	?CREWDO		; cre une swdo nulle (pour ne pas effacer)	LIB	?USEWDOQUIT$:	LIB	?CLOLIB	FOS	?STOP;--------\\; AFCLEAR >;========/; Efface toute la fentre.; in	-; out	-; mod	D7.WAFCLEAR:	PUSHM.L	D2..D4	LOAD.B	D3,#NOCURS	LIB	?AFCAR	TEST.B	(A0)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP',BS WHITE$		; oui => WHITE$				; non =>	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface tout	JUMP'	EXIT$WHITE$:	LOAD.L	D3,#TRAGRIS	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LOAD.W	D2,#LOADDOT	LIB	?DRMATRIX	; trame toute la fentreEXIT$:	POPM.L	D2..D4	RET;--------\\; AFCOLOR >;========/; Affiche une image dans la fentre.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie suprieure gauche.; in	A3.L	^nom de l'image;	A0.L	^descripteur de la fentre; out	D7.W	erreur; mod	D7.WAFCOLOR:	PUSHM.L	D0..D6,A1..A5	LOAD.W	D7,#1	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^en-tteNLOOP$:	LOAD.B	D3,(A3+)	JUMP',EQ NEND$	COMP.B	D3,#CR	JUMP',EQ NEND$	COMP.B	D3,#SPACE	JUMP',EQ NEND$	COMP.B	D3,#'/	JUMP',EQ NEND$	LOAD.B	(A4+),D3	; buffer en-tte <-- nom de l'image	JUMP	NLOOP$NEND$:	CLR.B	(A4)	LOAD.L	A3,A2	CALL	SKIPREP		; A3 <-- ^aprs rep:rep:	LOAD.L	A4,#R16"TEXCOL	LOAD.W	D3,#1		; D3 <-- force si dj	LIB	?ADDEXT		; ajoute l'extension ".COLOR"	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE GIVHEAD$	LOAD.L	A4,A2	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE CLOSE$	LOAD.L	A5,#0	LOAD.L	D4,(A2)+OIMLGC	; CLUT existe ?	JUMP',EQ CEND$		; non => CEND$	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour la CLUT	JUMP,NE CLOSE$	LOAD.L	A5,A4		; A5 <-- ^buffer pour la CLUT	FOS	?RDBYTE		; lit la CLUT	JUMP,NE GIVCLUT$CEND$:	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	CLR.W	D2	LOAD.B	D2,(A2)+OIMBIP	; D2 <-- nb de bits/pixels	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D2	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF+10	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE GIVCLUT$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE DECO$		; oui => DECO$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP,NE GIVDATA$	LOAD.L	A3,A4	JUMP'	DRAW$DECO$:	FOS	?RDBYTE		; lit toute l'image code	JUMP,NE GIVDATA$	LOAD.L	A3,A1	PUSH.W	(A2)+OIMDLX	PUSH.B	(A2)+OIMBIP	LOAD.W	D4,(A2)+OIMDLX	MUL.WU	D4,D2	LOAD.W	(A2)+OIMDLX,D4	LOAD.B	(A2)+OIMBIP,#1	GRA_	DECOIMA		; dcode l'image couleur ...	POP.B	(A2)+OIMBIP	POP.W	(A2)+OIMDLX	TEST.W	D7	JUMP,NE GIVDATA$DRAW$:	COMP.L	A5,#0		; CLUT existe ?	JUMP',EQ CLUT$		; non => CLUT$	PUSHM.L	D6,A3	LOAD.L	A3,A5		; A3 <-- ^CLUT lue	LOAD.L	D3,#2^BTCTABLE	; D3 <-- mode	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal pour TCOLOR	TCOL_	LOADCLUT	; change la CLUT de la fentre	POPM.L	D6,A3CLUT$:	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la souris	LOAD.W	D5,D0	ADD.W	D5,#8-1	SR.W	D5,#3	MUL.WU	D5,D2		; D5 <-- Iy source	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	LOAD.W	D4,(A0)+ODFDY	; D4 <-- hauteur	COMP.W	D1,D4		; image trop haute ?	JUMP',HI YLARG$		; oui => YLARG$	CLR.W	D3		; D3 <-- origine source	LOAD.W	D2,D1		; D2 <-- hauteur	SUB.W	D4,D1	SR.W	D4,#1		; D4 <-- origine destination	JUMP'	YEND$YLARG$:	LOAD.W	D2,D4		; D2 <-- hauteur	LOAD.W	D3,D1	SUB.W	D3,D4	SR.W	D3,#1		; D3 <-- origine source	CLR.W	D4		; D4 <-- origine destinationYEND$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,(A0)+ODFDX	; D4 <-- largeur	COMP.W	D0,D4		; image trop large ?	JUMP',HI XLARG$		; oui => XLARG$	CLR.W	D3		; D3 <-- origine source	LOAD.W	D2,D0		; D2 <-- largeur	SUB.W	D4,D0	SR.W	D4,#1		; D4 <-- origine destination	JUMP'	XEND$XLARG$:	LOAD.W	D2,D4		; D2 <-- largeur	LOAD.W	D3,D0	SUB.W	D3,D4	SR.W	D3,#1		; D3 <-- origine source	CLR.W	D4		; D4 <-- origine destinationXEND$:	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	GRA_	CRASTER		; affiche l'image en couleurs	LOAD.B	D3,#AFSCMO	LIB	?AFCAR		; remet la souris	CLR.W	D7		; D7 <-- okGIVDATA$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D7GIVCLUT$:	COMP.L	A5,#0	JUMP',EQ CLOSE$	PUSH.W	D7	LOAD.L	A4,A5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de la CLUT	POP.W	D7CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7GIVHEAD$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POP.W	D7EXIT$:	POPM.L	D0..D6,A1..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; AFIMAGE >;========/; Affiche une image dans la fentre.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie suprieure gauche.; in	A3.L	^nom de l'image;	A0.L	^descripteur de la fentre; out	D7.W	erreur; mod	D7.WAFIMAGE:	PUSHM.L	D0..D4,D6,A1..A4	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^en-tteNLOOP$:	LOAD.B	D3,(A3+)	JUMP',EQ NEND$	COMP.B	D3,#CR	JUMP',EQ NEND$	COMP.B	D3,#SPACE	JUMP',EQ NEND$	COMP.B	D3,#'/	JUMP',EQ NEND$	LOAD.B	(A4+),D3	; buffer en-tte <-- nom de l'image	JUMP	NLOOP$NEND$:	CLR.B	(A4)	LOAD.L	A3,A2	CALL	SKIPREP		; A3 <-- ^aprs rep:rep:	LOAD.L	A4,#R16"TEXIMA	LOAD.W	D3,#1		; D3 <-- force si dj	LIB	?ADDEXT		; ajoute l'extension ".IMAGE"	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE GIVHEAD$	LOAD.L	A4,A2	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE CLOSE$	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF+10	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE CLOSE$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP,NE GIVDATA$	JUMP'	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP,NE GIVDATA$	LOAD.L	A3,A1	GRA_	DECOIMA		; dcode l'image ...	JUMP,NE GIVDATA$35$:	TEST.B	(A0)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP',BS 45$		; oui => 45$				; non =>	LOAD.L	A3,A1		; A3 <-- ^image	LOAD.W	D3,D0	MUL.WU	D3,D1		; D3 <-- taille de l'image en points	SR.L	D3,#3+2		; D3 <-- /8 pour bytes et /4 pour .L;	ADD.W	D3,#1-1		; D3 <-- -1  cause NMO40$:	NOT.L	(A3+)		; inverse toute l'image	DECJ.W,NMO D3,40$45$:	LOAD.L	A3,#(A2)+1	; A3 <-- prend buffer en-tte pour STRING	LOAD.W	D3,D0	SR.W	D3,#3	LOAD.W	(A3)+9,D3	; source: <ii>	CLR.W	(A3)+19		; destination: <ii>	LOAD.L	D4,(A0)+ODFDY	; D4 <-- dimensions de la fentre	COMP.W	D0,D4		; image trop large ?	JUMP',HI 50$		; oui => 50$	CLR.W	(A3)+1		; source: <xx>	LOAD.W	(A3)+21,D0	; image: <dxx>	SUB.W	D4,D0	SR.W	D4,#1	LOAD.W	(A3)+11,D4	; destination: <xx>	JUMP'	55$50$:	CLR.W	(A3)+1		; source: <xx>	CLR.W	(A3)+11		; destination: <xx>	LOAD.W	(A3)+21,D4	; image: <dxx>55$:	SWAP.W	D4	COMP.W	D1,D4		; image trop haute ?	JUMP',HI 60$		; oui => 60$	CLR.W	(A3)+3		; source: <yy>	LOAD.W	(A3)+23,D1	; image: <dyy>	SUB.W	D4,D1	SR.W	D4,#1	LOAD.W	(A3)+13,D4	; destination: <yy>	JUMP'	65$60$:	CLR.W	(A3)+3		; source: <yy>	CLR.W	(A3)+13		; destination: <yy>	LOAD.W	(A3)+23,D4	; image: <dyy>65$:	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+5,A1	; source: <pppp>	CLR.L	(A3)+15		; destination: <pppp>	LOAD.B	(A3)+25,#LOADDOT; image: <mode>	LOAD.W	D3,#26		; D3 <-- longueur	CALL	RASTER		; affiche l'image	CLR.W	D7		; D7 <-- okGIVDATA$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D7CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7GIVHEAD$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POP.W	D7EXIT$:	POPM.L	D0..D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RASTER  >;--------/; Dessine l'image, ventuellement avec les coins arrondis !; in	A3.L	^paramtres pour DRAWRASTER;	D3.W	longueur;	D0.W	largeur de l'image;	D1.W	hauteur de l'image; out	-; mod	D7.WRASTER:	PUSHM.L	D2,D4,A4	PUSH.L	A3	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	POP.L	A3	COMP.B	D4,#SMAKY8	JUMP',EQ 10$	COMP.W	D0,(A0)+ODFDX	JUMP',HS 10$	COMP.W	D1,(A0)+ODFDY	JUMP',LO 20$10$:	LIB	?STRING		; affiche sans arrondir les coins	JUMP	EXIT$20$:	LOAD.L	A4,#R16"00$	CLR.W	D2		; D2 <-- <yy> initial30$:	TEST.W	(A4)	JUMP,NS 40$	PUSH.L	(A3)+1	PUSH.L	(A3)+11	PUSH.L	(A3)+21	ADD.W	(A3)+3,D2	; source: <yy>	ADD.W	(A3)+13,D2	; destination: <yy>	LOAD.W	D4,(A4)+2	ADD.W	(A3)+1,D4	; source: <xx>	ADD.W	(A3)+11,D4	; destination: <xx>	SL.W	D4,#1	SUB.W	(A3)+21,D4	; <dxx>	LOAD.W	(A3)+23,(A4)+0	; <dyy>	LIB	?STRING	POP.L	(A3)+21	POP.L	(A3)+11	POP.L	(A3)+1	PUSH.L	(A3)+1	PUSH.L	(A3)+11	PUSH.L	(A3)+21	LOAD.W	D4,(A3)+23	SUB.W	D4,D2	SUB.W	D4,(A4)+0	ADD.W	(A3)+3,D4	; source: <yy>	ADD.W	(A3)+13,D4	; destination: <yy>	LOAD.W	D4,(A4)+2	ADD.W	(A3)+1,D4	; source: <xx>	ADD.W	(A3)+11,D4	; destination: <xx>	SL.W	D4,#1	SUB.W	(A3)+21,D4	; <dxx>	LOAD.W	(A3)+23,(A4)+0	; <dyy>	LIB	?STRING	POP.L	(A3)+21	POP.L	(A3)+11	POP.L	(A3)+1	ADD.W	D2,(A4)+0	; D2 <-- <yy> suivant	ADD.L	A4,#4	JUMP	30$40$:;	PUSH.L	(A3)+1;	PUSH.L	(A3)+11;	PUSH.L	(A3)+21	ADD.W	(A3)+3,D2	; source: <yy>	ADD.W	(A3)+13,D2	; destination: <yy>	SL.W	D2,#1	SUB.W	(A3)+23,D2	; <dyy>	LIB	?STRING;	POP.L	(A3)+21;	POP.L	(A3)+11;	POP.L	(A3)+1EXIT$:	POPM.L	D2,D4,A4	RET;	o o o o o o o o o o o o o;	o o o o o o o o o o;	o o o o o o o o;	o o o o o o;	o o o o o;	o o o o;	o o o;	o o o;	o o;	o o;	o;	o;	o00$:	;	dy,dx	.W	1,13	.W	1,10	.W	1,8	.W	1,6	.W	1,5	.W	1,4	.W	2,3	.W	2,2	.W	3,1	.W	-1.IF 0;	o o o o o o o;	o o o o o;	o o o;	o o;	o o;	o;	o00$:	;	dy,dx	.W	1,7	.W	1,5	.W	1,3	.W	2,2	.W	2,1	.W	-1.ENDIF;--------\\; SKIPREP >;--------/; Saute tous les noms d'units et de rpertoires devant; un nom de fichier.; in	A3.L	^unit:rp:rp:nom.ext; out	A3.L	^nom.ext; mod	A3.LSKIPREP:	PUSH.W	D3	CLR.W	D310$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE 10$20$:	DEC.W	D3	JUMP',NS EXIT$	COMP.B	(-A3),#':	JUMP,NE 20$	INC.L	A3EXIT$:	POP.W	D3	RET; Textes; ------TEXCOL:	.ASCIZ	".COLOR"	; extension pour les imagesTEXIMA:	.ASCIZ	".IMAGE"	; extension pour les imagesNMDBOX:	.ASCIZ	"DBOX"		; nom du module dboxNMLDIMA:.ASCIZ	"SMA_LDIMA"	; nom du logiciel LDIMALTLDIMA:.B	0,CR,SPACE,TAB,'.,'/,-1	.EVEN	.END	START