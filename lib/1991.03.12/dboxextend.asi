	.SBTTL	DBOXEXTEND;-------------\\; _DBOX_EXTEND >;=============/; Appel d'extension des appels du module DBOX.; in	D1.W	numro de l'appel;	D2.W	= 2^BDBEXTEND (ou A2.L = 0);	+ selon l'appel; out	+ selon l'appel; mod	+ selon l'appel_DBOX_EXTEND:	COMP.W	D1,#DBOX_ERCALL	JUMP,EQ _DBOX_ERCALL	COMP.W	D1,#DBOX_OPWAIT	JUMP,EQ _DBOX_OPWAIT	COMP.W	D1,#DBOX_CLWAIT	JUMP,EQ _DBOX_CLWAIT	COMP.W	D1,#DBOX_NAMDISK	JUMP,EQ _DBOX_NAMDISK	COMP.W	D1,#DBOX_PREND	JUMP,EQ _DBOX_IOEDIT	COMP.W	D1,#DBOX_AJOUTE	JUMP,EQ _DBOX_IOEDIT	COMP.W	D1,#DBOX_SAUVE	JUMP,EQ _DBOX_IOEDIT	COMP.W	D1,#DBOX_MAJ	JUMP,EQ _DBOX_MAJ	COMP.W	D1,#DBOX_QUITTE	JUMP,EQ _DBOX_QUITTE	COMP.W	D1,#DBOX_DETRUIT	JUMP,EQ _DBOX_DETRUIT	COMP.W	D1,#DBOX_EFFACE	JUMP,EQ _DBOX_EFFACE	COMP.W	D1,#DBOX_EXTRAIT	JUMP,EQ _DBOX_IOEDIT	RET;-------------\\; _DBOX_ERCALL >;=============/; Excute un appel et essaye de rsoudre un problme suite  une erreur.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.W_DBOX_ERCALL:LOOP$:	FOS	?FOS		; excute un appel FOS ...	JUMP,EQ QUIT$	PUSHM.L	D0..D5,A1..A6	LOAD.W	D0,D7		; D0 <-- erreur	COMP.W	D7,#ERMRDY	JUMP',EQ ERCLOSE$	COMP.W	D7,#ERMWPR	JUMP',EQ ERPROTECT$	COMP.W	D7,#ERMOUT	JUMP',EQ ERFORMAT$	LOAD.W	D4,D7	AND.W	D4,#H'FFF0	COMP.W	D4,#ERMREAD	JUMP',EQ ERFORMAT$	COMP.W	D4,#ERMWRITE	JUMP',EQ ERFORMAT$	JUMP'	EXIT$ERCLOSE$:	CALL	ERRCLOSE	JUMP'	EXIT$ERFORMAT$:	CALL	ERRFORMAT	JUMP'	EXIT$ERPROTECT$:	CALL	ERRPROTECT;	JUMP'	EXIT$EXIT$:	LOAD.W	D7,D0		; D7 <-- ok/erreur	POPM.L	D0..D5,A1..A6	TEST.W	D7	JUMP,EQ LOOP$QUIT$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; ERRCLOSE >;---------/; Propose de mettre une disquette et de fermer la porte.; in	D0.W	code de l'erreur;	D2.W	mode d'ouverture;	D3.L	position centre (si BDBPOS); out	D0.W	erreur (ERKSTO si annule); mod	D0..D5,D7,A1..A6ERRCLOSE:	SUB.W	SP,#12		; rserve 12 bytes sur le stack (PUSH)	LOAD.L	A5,SP		; A5 <-- ^buffer sur le stack	CALL	ERFLOPPY	; est-ce un floppy ?	JUMP,NE 95$		; non => 95$	CALL	ECOPVAR		; A6 <-- ^variables	JUMP,NE 95$	LOAD.W	D3,#BIPERR	LIB	?BEEP	LOAD.L	A2,#R16"TDBOX_CLOSE	LOAD.W	D2,#2^BDBSAV	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la swdo	JUMP,NE	90$	CALL	DRATTENTION	; dessine le signe "attention"	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS;	LOAD.L	A3,#(A6)+OECNAM	; A3 <-- ^nom de l'unit	CALL	_DBOX_NAMDISK	; A3 <-- ^nom plus clair	LIB	?AFTEXT		; affiche le nom de l'unit (1re partie)	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le nom de l'unit (2me partie)	CALL	GETPSW		; A1 <-- ^descripteur de la fentre	LOAD.W	D1,#B'11	; D1 <-- inverse et ombre	CALL	CADRE		; dessine le cadre	CALL	INVWDO		; inverse toute la dbox20$:	DBOX_	EDIT		; attend touche/souris ...	LOAD.L	A1,#R16"TKEY_CLOSE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC		; touche admise ?	COMP.W	D3,#KEYMGR	JUMP,EQ 20$	COMP.W	D3,#F1	JUMP',EQ 70$	COMP.W	D3,#F0	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:	CLR.W	D0		; D0 <-- c'est rsolu	JUMP'	85$80$:	LOAD.W	D0,#ERKSTO	; D0 <-- annule85$:	DBOX_	CLOSE		; ferme la swdo90$:	CALL	ECCLVAR		; rend les variables95$:	ADD.W	SP,#12		; reprend le buffer sur le stack (POP)	RETTDBOX_CLOSE:	.W	10$-TDBOX_CLOSE	.W	20$-TDBOX_CLOSE	.W	0,010$:	.B	ODBLABEL,10	; label pour le signe ATTENTION	.B	ODBTEXT,0	.B	ODBTABX,10	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBTABX,11	.B	ODBTEXT	.ASCIZ	"Veuillez mettre une disquette  "	.B	ODBCR	.B	ODBTABX,11	.B	ODBTEXT	.ASCIZ	"dans "	.B	ODBLABEL,1	.B	ODBTEXT	;	"le lecteur de droite "	.ASCIZ	"                     "	.B	ODBCR	.B	ODBTABX,11	.B	ODBTEXT	.ASCIZ	"et actionner le dispositif de"	.B	ODBCR	.B	ODBTABX,11	.B	ODBTEXT	.ASCIZ	"fermeture de la porte.        "	.B	ODBLABEL,21	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" C'EST FAIT "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"C'est fait"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CLOSE:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_CLOSE	.W	F1,F2,F3,CR,0		DOKF1-TKEY_CLOSE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CLOSE	.W	0;----------\\; ERRFORMAT >;----------/; Propose de formater une disquette.; in	D0.W	code de l'erreur;	D2.W	mode d'ouverture;	D3.L	position centre (si BDBPOS); out	D0.W	erreur (ERKSTO si annule); mod	D0..D5,D7,A1..A6ERRFORMAT:	SUB.W	SP,#12		; rserve 12 bytes sur le stack (PUSH)	LOAD.L	A5,SP		; A5 <-- ^buffer sur le stack	CALL	ERFLOPPY	; est-ce un floppy ?	JUMP,NE 95$		; non => 95$	CALL	ECOPVAR		; A6 <-- ^variables	JUMP,NE 95$	LOAD.W	D3,#BIPERR	LIB	?BEEP	LOAD.L	A2,#R16"TDBOX_FORMAT	LOAD.W	D2,#2^BDBSAV	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la swdo	JUMP,NE	90$	CALL	DRATTENTION	; dessine le signe "attention"	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A4,#(A6)+OECTXT	; A4 <-- ^buffer	LOAD.W	D2,#2^BERSNAM	; D2 <-- mode "nom court"	LOAD.W	D3,#50-2	; D3 <-- nb cars/ligne	LOAD.W	D4,#1		; D4 <-- nb lignes	LOAD.W	D7,D0		; D7 <-- numro de l'erreur	FOS	?XERROR		; buffer <-- message d'erreur	LOAD.B	D3,#AFINV	LIB	?AFCAR	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le message d'erreur	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OECNAM	; A3 <-- ^nom de l'unit	CALL	_DBOX_NAMDISK	; A3 <-- ^nom plus clair	LIB	?AFTEXT		; affiche le nom de l'unit (1re partie)	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le nom de l'unit (2me partie)	LIB	?AFTIM	.ASCIZ	"?"	.EVEN	CALL	GETPSW		; A1 <-- ^descripteur de la fentre	LOAD.W	D1,#B'11	; D1 <-- inverse et ombre	CALL	CADRE		; dessine le cadre	CALL	INVWDO		; inverse toute la dbox20$:	DBOX_	EDIT		; attend touche/souris ...	LOAD.L	A1,#R16"TKEY_FORMAT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC		; touche admise ?	COMP.W	D3,#KEYMGR	JUMP,EQ 20$	COMP.W	D3,#F1	JUMP',EQ 50$	COMP.W	D3,#F0	JUMP,EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:	DBOX_	CLOSE		; ferme la swdo	CALL	_DBOX_OPWAIT	; ouvre la dbox "attendez un instant ..."	COMP.W	D0,#ERMOUT	; formatage physique ncessaire ?	JUMP,EQ 60$		; non => 60$				; oui =>	LOAD.L	A3,#(A6)+OECNAM	; A3 <-- ^nom de l'unit	FOS	?RELEASE	; essaye un RELEASE sans tester l'erreur !	CLR.W	D3		; D3 <-- global	FOS	?VASSIGN	; A4 <-- ^nom physique	JUMP,NE 70$	LOAD.L	A3,#(A4)+1	; A3 <-- ^nom physique aprs le "$"	FOS	?UNAMDRIV	; D2 <-- no driver	JUMP,NE 70$	LOAD.W	D4,#50	NTREL	?SETTIM		; stoppe aprs une seconde	FOS	?UOPEN		; tente une ouverture	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	JUMP,NE 70$	LOAD.L	A4,#R16"01$	LOAD.W	D1,#TYPMM	; D1 <-- type mmoire de masse	BIOS	?DCOMMAND	; formatage physique ...	PUSH.W	D7	FOS	?UCLOSE		; ferme	POP.W	D7	JUMP,NE 70$60$:	LOAD.L	A3,#(A6)+OECNAM	; A3 <-- ^nom de l'unit	LOAD.W	D4,#31	FOS	?FORMAT		; formatage logique ...	JUMP,NE 70$62$:	TEST.B	(A3+)	JUMP,NE 62$	DEC.L	A3	LOAD.L	A4,#R16"02$63$:	LOAD.B	(A3+),(A4+)	; buffer <-- unit:DOSSIER:	JUMP,NE 63$	LOAD.L	A4,#(A3)-2	LOAD.L	A3,#(A6)+OECNAM	; A3 <-- ^nom de l'unit	LOAD.W	D3,#1		; D3 <-- valeur de hachage minimale	CLR.L	D4		; D4 <-- lg max	FOS	?CDIR		; crer le dossier vide "DOSSIER:"	JUMP',NE 70$	LOAD.B	(A4+),#'.	LOAD.B	(A4+),#'D	LOAD.B	(A4+),#'I	LOAD.B	(A4+),#'R	CLR.B	(A4)	LOAD.L	D3,#2^BATTM!2^BATTS!2^BATTG!2^BATTA!2^BATTZ!2^BATTP!2^BATTL	FOS	?CHATR		; enlve les attributs "R", "W" et "C"70$:	LOAD.W	D0,D7		; D0 <-- ok/erreur	CALL	_DBOX_CLWAIT	; ferme la dbox "attendez un instant ..."	CALL	ECCLVAR		; rend les variables	JUMP'	95$80$:	LOAD.W	D0,#ERKSTO	; D0 <-- annule85$:	DBOX_	CLOSE		; ferme la swdo90$:	CALL	ECCLVAR		; rend les variables95$:	ADD.W	SP,#12		; reprend le buffer sur le stack (POP)	RET01$:	.ASCIZ	"F"		; commande de formatage02$:	.ASCIZ	"DOSSIER:"	.EVENTDBOX_FORMAT:	.W	10$-TDBOX_FORMAT	.W	20$-TDBOX_FORMAT	.W	0,010$:	.B	ODBLABEL,10	; label pour le signe ATTENTION	.B	ODBTEXT,0	.B	ODBTABX,10	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBTABX,11	.B	ODBLABEL,1	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR	.B	ODBTABX,11	.B	ODBTEXT	.ASCIZ	"Voulez-vous formater la disquette"	.B	ODBCR	.B	ODBTABX,11	.B	ODBTEXT	.ASCIZ	"dans "	.B	ODBLABEL,2	.B	ODBTEXT	;	"le lecteur de droite ?"	.ASCIZ	"                                  "	.B	ODBLABEL,21	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	" FORMATE "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBMEV	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Formate"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_FORMAT:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_FORMAT	.W	F1,F2,F3,0		DOKF1-TKEY_FORMAT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_FORMAT	.W	0;-----------\\; ERRPROTECT >;-----------/; Propose de formater une disquette.; in	D0.W	code de l'erreur;	D2.W	mode d'ouverture;	D3.L	position centre (si BDBPOS); out	D0.W	erreur (ERKSTO si annule); mod	D0..D5,D7,A1..A6ERRPROTECT:	SUB.W	SP,#12		; rserve 12 bytes sur le stack (PUSH)	LOAD.L	A5,SP		; A5 <-- ^buffer sur le stack	CALL	ERFLOPPY	; est-ce un floppy ?	JUMP,NE 95$		; non => 95$	CALL	ECOPVAR		; A6 <-- ^variables	JUMP,NE 95$	FOS	?RELEASE	; tente un release	JUMP,NE 91$		; si impossible => 91$	LOAD.W	D3,#BIPERR	LIB	?BEEP	LOAD.L	A2,#R16"TDBOX_PROTECT	LOAD.W	D2,#2^BDBSAV	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la swdo	JUMP,NE	90$	CALL	DRATTENTION	; dessine le signe "attention"	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"La disquette dans "	.EVEN;	LOAD.L	A3,#(A6)+OECNAM	; A3 <-- ^nom de l'unit	CALL	_DBOX_NAMDISK	; A3 <-- ^nom plus clair	LIB	?AFTEXT		; affiche le nom de l'unit (1re partie)	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le nom de l'unit (2me partie)	LIB	?AFTIM	.ASCIZ	"est protge !"	.EVEN	CALL	GETPSW		; A1 <-- ^descripteur de la fentre	LOAD.W	D1,#B'11	; D1 <-- inverse et ombre	CALL	CADRE		; dessine le cadre	CALL	INVWDO		; inverse toute la dbox20$:	DBOX_	EDIT		; attend touche/souris ...	LOAD.L	A1,#R16"TKEY_PROTECT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC		; touche admise ?	COMP.W	D3,#KEYMGR	JUMP,EQ 20$	COMP.W	D3,#F1	JUMP',EQ 70$	COMP.W	D3,#F0	JUMP,EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:	CLR.W	D0		; D0 <-- c'est resolu	JUMP'	85$80$:	LOAD.W	D0,#ERKSTO	; D0 <-- annule85$:	DBOX_	CLOSE		; ferme la swdo90$:	LOAD.L	A3,#(A6)+OECNAM	; A3 <-- ^nom de l'unit	FOS	?ENTER		; refait l'enter !91$:	CALL	ECCLVAR		; rend les variables95$:	ADD.W	SP,#12		; reprend le buffer sur le stack (POP)	RETTDBOX_PROTECT:	.W	10$-TDBOX_PROTECT	.W	20$-TDBOX_PROTECT	.W	0,010$:	.B	ODBLABEL,1	.B	ODBTEXT	;	"La disquette dans le lecteur de gauche est protge !"	.ASCIZ	"                                                     "	.B	ODBCR,ODBCR	.B	ODBLABEL,10	; label pour le signe ATTENTION	.B	ODBTEXT,0	.B	ODBTABX,10	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBTABX,11	.B	ODBTEXT	.ASCIZ	"Pour la modifier, procdez comme suit :"	.B	ODBCR	.B	ODBTABX,11	.B	ODBTEXT	.ASCIZ	"1)  sortez la disquette"	.B	ODBCR	.B	ODBTABX,11	.B	ODBTEXT	.ASCIZ	"2)  dcollez l'tiquette sur le ct"	.B	ODBCR	.B	ODBTABX,11	.B	ODBTEXT	.ASCIZ	"3)  remettez la disquette                  "	.B	ODBLABEL,21	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	" C'EST FAIT "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBMEV	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"C'est fait"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_PROTECT:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_PROTECT	.W	F1,F2,F3,0		DOKF1-TKEY_PROTECT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_PROTECT	.W	0;------------\\; DRATTENTION >;------------/; Dessine le signal "attention" dans une dbox.; in	D5.L	canal dbox; out	-; mod	D7.WDRATTENTION:	PUSHM.L	D2..D4,A3,A4	SUB.W	SP,#12		; rserve 12 bytes sur le stack (PUSH)	LOAD.L	A3,#(SP)+1	; A3 <-- ^buffer sur le stack	LOAD.B	(A3)+0,#DRAWMATRIX	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,#8	SWAP.W	D3	ADD.W	D3,#-2	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.L	A4,#R16"ATTENTION	LOAD.L	(A3)+5,A4	; <pppp>	LOAD.B	(A3)+9,#INVDOT	; <m>	LOAD.W	D3,#10	LIB	?STRING		; dessine le signe "attention"	ADD.W	SP,#12		; reprend le buffer sur le stack (POP)	POPM.L	D2..D4,A3,A4	RET;--------\\; GETPSW  >;--------/; Demande le status de la fentre pour connatre les dimensions; des caractres affichs.; in	-; out	A1.L	^descripteur de la fentre; mod	D7.W, A1.LGETPSW:	PUSHM.L	D3,D4,D6,A4	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	PUSH.L	A4	LOAD.L	A4,SP		; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	POP.L	A1		; A1 <-- ^status rel	POPM.L	D3,D4,D6,A4	RET;--------\\; CADRE   >;--------/; Dessine un cadre autour du texte.; in	D1.W	mode (:#0 si inversion, :#1 si ombre);	A1.L	^descripteur de la fentre; out	D3/D4	position/dimension rectangle; mod	D3.L, D4.L, D7.WCADRE:	PUSHM.L	D1,D2	LOAD.W	D2,#21!2^BDBGCLABEL	DBOX_	GETCO		; D3 <-- fin du texte	ADD.W	D3,#MTERRX	; D3 <-- x	SWAP.W	D3	ADD.W	D3,(A1)+ODFC2Y	ADD.W	D3,#MTERRY	; D3 <-- y	SWAP.W	D3	PUSH.L	D3	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO		; D3 <-- dbut du texte	SUB.W	D3,#MTERRX	; D3 <-- x	SWAP.W	D3	SUB.W	D3,(A1)+ODFC1Y	SUB.W	D3,#MTERRY	; D3 <-- y	SWAP.W	D3	POP.L	D4	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	; D2 <-- mode de dessin	TEST.L	D1:#0		; faut-il ne pas inverser le texte ?	JUMP',BC 30$		; non => 30$				; oui =>	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit une trame pleine	POPM.L	D3,D4	LIB	?DRMATRIX	; inverse tout le texte30$:	PUSHM.L	D3,D4	LOAD.L	D3,#H'55AA55AA	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit une trame grise (pour l'ombre)	POPM.L	D3,D4	SUB.W	D3,#2	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	ADD.W	D4,#4-1	SWAP.W	D4	ADD.W	D4,#4-1	SWAP.W	D4	TEST.L	D1:#1		; dessine une ombre ?	JUMP',BS 50$		; oui => 50$				; non =>	LIB	?DRRECT		; juste encore un rectangle autour	JUMP'	90$50$:	LOAD.W	D1,#3		; D1 <-- paisseur de l'ombre	LIB	?DRRECTO	; juste encore un rectangle ombr autour90$:	POPM.L	D1,D2	RET;--------\\; INVWDO  >;--------/; Inverse toute la dbox.; in	A1.L	^descripteur de la fentre; out	-; mod	D7.WINVWDO:	PUSHM.L	D2..D5	TEST.B	(A1)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP',BS 90$		; oui => 90$				; non =>	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LIB	?GETWDO	CLR.L	D3	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	; inverse toute la dbox90$:	POPM.L	D2..D5	RET;--------------\\; _DBOX_NAMDISK >;==============/; Donne le nom d'un lecteur de disquette.; Par exemple :;	"le lecteur de droite ";	"le lecteur ";	"le lecteur $FLO_2: ";	"l'unit $WIN_0: "; in	A3.L	^nom d'unit; out	A3.L	^1re partie du nom plus clair (le lecteur/l'unit/etc.);	A4.L	^2me partie du nom plus clair (de droite/$FLO_1/etc.); mod	D7.W, A3.L, A4.L_DBOX_NAMDISK:	PUSH.L	D3	CLR.W	D3		; D3 <-- global	FOS	?VASSIGN	; A4 <-- ^nom physique	JUMP,NE 80$	LOAD.L	A3,A4		; A3 <-- ^nom physique	CALL	IFFLOPPY	; est-ce un floppy ?	JUMP,NE 80$		; non => 80$				; oui =>	PUSH.L	A3	LOAD.L	A3,#R16"FLO1$	CLR.W	D3		; D3 <-- global	FOS	?VASSIGN	; est-ce qu'il existe deux lecteurs ?	POPM.L	A3	JUMP',EQ 40$		; oui => 40$				; non =>	LOAD.L	A4,#R16"ONE$	JUMP'	50$40$:	LOAD.L	A4,#R16"LEFT$	COMP.B	(A3)+5,#'0	; $FLO_0 ?	JUMP',EQ 50$	LOAD.L	A4,#R16"RIGHT$	COMP.B	(A3)+5,#'1	; $FLO_1 ?	JUMP',EQ 50$	LOAD.L	A4,A350$:	LOAD.L	A3,#R16"FLOP$	; A3 <-- "le lecteur"	JUMP'	90$80$:	LOAD.L	A4,A3	LOAD.L	A3,#R16"UNIT$	; A3 <-- "l'unit"90$:	POP.L	D3	CLR.W	D7		; D7 <-- retour EQ	RETUNIT$:	.ASCIZ	"l'unit "FLOP$:	.ASCIZ	"le lecteur "LEFT$:	.ASCIZ	"de gauche "RIGHT$:	.ASCIZ	"de droite "ONE$:	.ASCIZ	""FLO1$:	.ASCIZ	"$FLO_1:"	.EVEN;---------\\; ERFLOPPY >;---------/; Vrifie si une erreur est survenue avec le floppy.; in	D7.W	erreur;	A5.L	^buffer de 12 bytes; out	A3.L	^nom du fichier ayant caus l'erreur;	D7.W	EQ si floppy;		NE autrement; mod	D7.W, A3.LERFLOPPY:	PUSHM.L	D2..D4,A4	LOAD.L	A3,#R16"NIL$	; A3 <-- ^nom inconnu	LOAD.L	A4,A5		; A4 <-- ^buffer sur le stack	LOAD.W	D2,#2^BERUNAM!2^BERPHYS!2^BERNOTXT	LOAD.W	D3,#12-2	; D3 <-- nb max de car/ligne	LOAD.W	D4,#1		; D4 <-- nb max de lignes	FOS	?XERROR		; buffer <-- nom ayant caus l'erreur	JUMP',NE 90$	LOAD.L	A3,A4		; A3 <-- ^nom trouv	CALL	IFFLOPPY	; est-ce un floppy ?90$:	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RETNIL$:	.ASCIZ	""	.EVEN;---------\\; IFFLOPPY >;---------/; Vrifie si un nom d'unit est de type "floppy".; in	A3.L	^nom d'unit; out	D7.W	EQ si floppy;		NE autrement; mod	D7.WIFFLOPPY:	LOAD.W	D7,#1		; D7 <-- pas floppy	COMP.B	(A3)+0,#'$	JUMP',NE 90$	COMP.B	(A3)+1,#'F	JUMP',NE 90$	COMP.B	(A3)+2,#'L	JUMP',NE 90$	COMP.B	(A3)+3,#'O	JUMP',NE 90$	COMP.B	(A3)+4,#'_	JUMP',NE 90$	CLR.W	D7		; D7 <-- c'est un floppy90$:	TEST.W	D7		; retour EQ/NE	RET;-------------\\; _DBOX_OPWAIT >;=============/; Met la dbox "Attendez un instant ..."; in	-; out	D5.L	canal spcial;	D7.W	erreur; mod	D5.L, D7.W_DBOX_OPWAIT:	PUSHM.L	D2..D4,A2,A3,A6	LOAD.L	A3,#R16"NIL$	CALL	ECOPVAR		; A6 <-- ^variables	JUMP',NE 85$	LOAD.L	A2,#R16"TDBOX_WAIT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE 80$	LOAD.L	(A6)+OECCDB,D5	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	D5,A6		; D5 <-- canal	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	CALL	ECCLVAR85$:	CLR.L	D5		; D5 <-- pas de canal90$:	POPM.L	D2..D4,A2,A3,A6	TEST.W	D7		; retour EQ/NE	RETNIL$:	.ASCIZ	""	.EVEN;-------------\\; _DBOX_CLWAIT >;=============/; Enlve la dbox "Attendez un instant ..."; in	D5.L	canal spcial; out	-; mod	D7.W_DBOX_CLWAIT:	PUSHM.L	D4,D5,A6	TEST.L	D5		; canal existe ?	JUMP',EQ 90$		; non => 90$				; oui =>	LOAD.L	A6,D5		; A6 <-- ^variables	LOAD.L	D5,(A6)+OECCDB	; D5 <-- canal dbox	DBOX_	CLOSE		; ferme la DBOX	CALL	ECCLVAR		; rend les variables	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier90$:	POPM.L	D4,D5,A6	RETTDBOX_WAIT:	.W	10$-TDBOX_WAIT	.W	20$-TDBOX_WAIT	.W	0,010$:	.B	ODBCR,ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"       Attendez un instant ...      "	.B	ODBCR,ODBCR,ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN;--------\\; ECOPVAR >;--------/; Demande des variables pour ERCALL.; in	A3.L	^nom du fichier ayant caus l'erreur; out	A3.L	^nom du fichier mmoris;	A6.L	^variables;	D7.W	erreur; mod	D7.W, A6.LECOPVAR:	PUSHM.L	D1..D5,A4	LOAD.L	D4,#LGVAREC	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande de la mmoire	JUMP,NE 90$	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LIB	?PUSHMENU	; sauve les soft-keys	JUMP,NE 80$	LOAD.L	(A6)+OECPPM,D5	LOAD.L	A4,#(A6)+OECNAM	LOAD.W	D3,#50-230$:	DEC.W	D3	JUMP',EQ 32$	LOAD.B	(A4+),(A3+)	; OECNAM <-- nom	JUMP,NE 30$32$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OECNAM	; A3 <-- ^nom dans OECNAM	NTREL	?GETTIM	LOAD.W	(A6)+OECTIM,D4	LOAD.W	D4,#-1	NTREL	?SETTIM		; met un timeout infini	LIB	?GETWDO	LOAD.W	(A6)+OECWDO,D5	CLR.W	D5	LIB	?USEWDO		; utilise la wdo principale	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend les variables	POP.W	D790$:	POPM.L	D1..D5,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ECCLVAR >;--------/; Rend la mmoire pour les variables.; in	A6.L	^variables; out	-; mod	-ECCLVAR:	PUSHM.L	D1,D4,D5,D7,A4	LOAD.W	D5,(A6)+OECWDO	LIB	?USEWDO		; utilise la swdo initiale	LOAD.W	D4,(A6)+OECTIM	NTREL	?SETTIM		; remet le timeout initial	LOAD.L	D5,(A6)+OECPPM	LIB	?POPMENU	; restitue les soft-keys	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend les variables	POPM.L	D1,D4,D5,D7,A4	RET	.END