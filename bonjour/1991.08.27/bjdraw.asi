	.SBTTL	BJDRAW.ASI;---------\\; DRFONDDA >;=========/; Dessine un fond dgrad anim.; in	D4.W	mode (FGA*); out	-; mod	D7.WDRFONDDA:	PUSHM.L	D3,D4,A4	LOAD.L	A4,#R16"FGACOPEN$	COMP.W	D4,#FGACOPEN	JUMP',EQ DEL$	LOAD.L	A4,#R16"FGACCLOSE$	COMP.W	D4,#FGACCLOSE	JUMP',EQ DEL$	LOAD.L	A4,#R16"FGASOPEN$	COMP.W	D4,#FGASOPEN	JUMP',EQ DEL$	LOAD.L	A4,#R16"FGASCLOSE$;	COMP.W	D4,#FGASCLOSE;	JUMP',EQ DEL$DEL$:	CLR.L	D3	LOAD.W	D3,(A4+)	; D3 <-- attente	COMP.B	(A6)+OMACHINE,#SMAKY100	JUMP',NE LOOP$	DIV.WU	D3,#5		; D3 <-- SMAKY100 5 x plus lent que les autres machines !LOOP$:	LOAD.L	D4,(A4+)	JUMP',EQ EXIT$	CALL	DRAWOPEN	; dessine en mmoire	CALL	DRFONDD	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,D3	JUMP,EQ LOOP$	NTREL	?DELMS		; attend un p'tit peu ...	JUMP	LOOP$EXIT$:	POPM.L	D3,D4,A4	RETFGACOPEN$:	.W	4	.L	FGCIRCLE+H'0F;	.L	FGCIRCLE+H'0E	.L	FGCIRCLE+H'0D;	.L	FGCIRCLE+H'0C	.L	FGCIRCLE+H'0B;	.L	FGCIRCLE+H'0A	.L	FGCIRCLE+H'09;	.L	FGCIRCLE+H'08	.L	FGCIRCLE+H'07;	.L	FGCIRCLE+H'06	.L	FGCIRCLE+H'05;	.L	FGCIRCLE+H'04	.L	FGCIRCLE+H'03;	.L	FGCIRCLE+H'02	.L	FGCIRCLE+H'01;	.L	FGCIRCLE+H'00	.L	FGCIRCLE+H'FF;	.L	FGCIRCLE+H'FE	.L	FGCIRCLE+H'FD;	.L	FGCIRCLE+H'FC	.L	FGCIRCLE+H'FB;	.L	FGCIRCLE+H'FA	.L	FGCIRCLE+H'F9;	.L	FGCIRCLE+H'F8	.L	FGCIRCLE+H'F7;	.L	FGCIRCLE+H'F6	.L	FGCIRCLE+H'F5;	.L	FGCIRCLE+H'F4	.L	FGCIRCLE+H'F3;	.L	FGCIRCLE+H'F2	.L	FGCIRCLE+H'F1	.L	0FGACCLOSE$:	.W	4	.L	FGCIRCLE+H'F1;	.L	FGCIRCLE+H'F2	.L	FGCIRCLE+H'F3;	.L	FGCIRCLE+H'F4	.L	FGCIRCLE+H'F5;	.L	FGCIRCLE+H'F6	.L	FGCIRCLE+H'F7;	.L	FGCIRCLE+H'F8	.L	FGCIRCLE+H'F9;	.L	FGCIRCLE+H'FA	.L	FGCIRCLE+H'FB;	.L	FGCIRCLE+H'FC	.L	FGCIRCLE+H'FD;	.L	FGCIRCLE+H'FE	.L	FGCIRCLE+H'FF;	.L	FGCIRCLE+H'00	.L	FGCIRCLE+H'01;	.L	FGCIRCLE+H'02	.L	FGCIRCLE+H'03;	.L	FGCIRCLE+H'04	.L	FGCIRCLE+H'05;	.L	FGCIRCLE+H'06	.L	FGCIRCLE+H'07;	.L	FGCIRCLE+H'08	.L	FGCIRCLE+H'09;	.L	FGCIRCLE+H'0A	.L	FGCIRCLE+H'0B;	.L	FGCIRCLE+H'0C	.L	FGCIRCLE+H'0D;	.L	FGCIRCLE+H'0E	.L	FGCIRCLE+H'0F	.L	0FGASOPEN$:	.W	4	.L	FGSQUARE+H'00;	.L	FGSQUARE+H'01	.L	FGSQUARE+H'02;	.L	FGSQUARE+H'03	.L	FGSQUARE+H'04;	.L	FGSQUARE+H'05	.L	FGSQUARE+H'06;	.L	FGSQUARE+H'07	.L	FGSQUARE+H'08;	.L	FGSQUARE+H'09	.L	FGSQUARE+H'0A;	.L	FGSQUARE+H'0B	.L	FGSQUARE+H'0C;	.L	FGSQUARE+H'0D	.L	FGSQUARE+H'0E	.L	FGSQUARE+H'0F	.L	0FGASCLOSE$:	.W	4	.L	FGSQUARE+H'0F;	.L	FGSQUARE+H'0E	.L	FGSQUARE+H'0D;	.L	FGSQUARE+H'0C	.L	FGSQUARE+H'0B;	.L	FGSQUARE+H'0A	.L	FGSQUARE+H'09;	.L	FGSQUARE+H'08	.L	FGSQUARE+H'07;	.L	FGSQUARE+H'06	.L	FGSQUARE+H'05;	.L	FGSQUARE+H'04	.L	FGSQUARE+H'03;	.L	FGSQUARE+H'02	.L	FGSQUARE+H'01	.L	FGSQUARE+H'00	.L	0;--------\\; DRFONDD >;========/; Dessine un fond dgrad.; in	D4.L	mode |bits|type|-|add|; out	-; mod	D7.WDRFONDD:	PUSHM.L	D0..D6,A0..A4	CALL	CCMO		; enlve la souris	LIB	?COLORPUSH	LOAD.L	A0,(A6)+OPDDIS	LOAD.L	D3,D4	SWAP.W	D3	LOAD.L	A3,#R16"MIDDLEH$	COMP.B	D3,#FGMIDDLEH/H'10000	JUMP',EQ TABLE$	LOAD.L	A3,#R16"MIDDLEV$	COMP.B	D3,#FGMIDDLEV/H'10000	JUMP',EQ TABLE$	LOAD.L	A3,#R16"DIAG$	COMP.B	D3,#FGDIAG/H'10000	JUMP',EQ TABLE$	LOAD.L	A3,#R16"CIRCLE$	COMP.B	D3,#FGCIRCLE/H'10000	JUMP',EQ TABLE$	LOAD.L	A3,#R16"SQUARE$	COMP.B	D3,#FGSQUARE/H'10000	JUMP',EQ TABLE$	LOAD.L	A3,#R16"VERTI$	COMP.B	D3,#FGVERTI/H'10000	JUMP',EQ TABLE$	LOAD.L	A3,#R16"HORIZ$TABLE$:	LOAD.L	D0,D4		; D0 <-- |bits|-|-|add|	CLR.W	D6LOOPY$:	CLR.W	D5	LOAD.B	(A6)+OFGLTR,#-1LOOPX$:	LOAD.W	D3,D6	TEST.L	D0:#BFGINVY	JUMP',BC INVY$	SUB.W	D3,#16-1	NEG.W	D3INVY$:	SL.W	D3,#4	LOAD.W	D4,D5	TEST.L	D0:#BFGINVX	JUMP',BC INVX$	SUB.W	D4,#16-1	NEG.W	D4INVX$:	ADD.W	D3,D4	SR.W	D3,#1	LOAD.B	D2,(A3)+(D3.W)	; D2 <-- valeur de la trame	TEST.L	D4:#0	JUMP',BS RIGHT$	SR.B	D2,#4	JUMP'	TRAME$RIGHT$:	AND.B	D2,#B'00001111;	JUMP'	TRAME$TRAME$:	ADD.B	D2,D0		; D2 <-- correction selon "add"	JUMP',NC ADD2$	CLR.B	D2ADD2$:	COMP.B	D2,#16	JUMP',LS ADD3$	LOAD.B	D2,#16ADD3$:	TEST.L	D0:#BFGINVI	JUMP',BC DEF$	SUB.B	D2,#16-1	NEG.B	D2DEF$:	PUSH.W	D2	LOAD.W	D3,D6	MUL.WU	D3,#LYWDO	SR.L	D3,#4	LOAD.W	D4,D6	INC.W	D4	MUL.WU	D4,#LYWDO	SR.L	D4,#4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D5	MUL.WU	D1,#LXWDO	SR.L	D1,#4	LOAD.W	D2,D5	INC.W	D2	MUL.WU	D2,#LXWDO	SR.L	D2,#4	SUB.W	D2,D1	LOAD.W	D3,D1	LOAD.W	D4,D2	POP.W	D2	CALL	DRFONDT		; dessine le rectangle suivant	INC.W	D5	COMP.W	D5,#16	JUMP,LO LOOPX$	LOAD.B	D2,#-1	CALL	DRFONDT		; dessine le dernier rectangle	INC.W	D6	COMP.W	D6,#16	JUMP,LO LOOPY$	LIB	?COLORPOP	POPM.L	D0..D6,A0..A4	RETHORIZ$:	.L	H'00000000,H'00000000	.L	H'11111111,H'11111111	.L	H'22222222,H'22222222	.L	H'33333333,H'33333333	.L	H'44444444,H'44444444	.L	H'55555555,H'55555555	.L	H'66666666,H'66666666	.L	H'77777777,H'77777777	.L	H'88888888,H'88888888	.L	H'99999999,H'99999999	.L	H'AAAAAAAA,H'AAAAAAAA	.L	H'BBBBBBBB,H'BBBBBBBB	.L	H'CCCCCCCC,H'CCCCCCCC	.L	H'DDDDDDDD,H'DDDDDDDD	.L	H'EEEEEEEE,H'EEEEEEEE	.L	H'FFFFFFFF,H'FFFFFFFFVERTI$:	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210	.L	H'FEDCBA98,H'76543210MIDDLEH$:	.L	H'00000000,H'00000000	.L	H'11111111,H'11111111	.L	H'22222222,H'22222222	.L	H'33333333,H'33333333	.L	H'44444444,H'44444444	.L	H'55555555,H'55555555	.L	H'66666666,H'66666666	.L	H'77777777,H'77777777	.L	H'77777777,H'77777777	.L	H'66666666,H'66666666	.L	H'55555555,H'55555555	.L	H'44444444,H'44444444	.L	H'33333333,H'33333333	.L	H'22222222,H'22222222	.L	H'11111111,H'11111111	.L	H'00000000,H'00000000MIDDLEV$:	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210	.L	H'01234567,H'76543210DIAG$:	.L	H'77665544,H'33221100	.L	H'87766554,H'43322110	.L	H'88776655,H'44332211	.L	H'98877665,H'54433221	.L	H'99887766,H'55443322	.L	H'A9988776,H'65544332	.L	H'AA998877,H'66554433	.L	H'BAA99887,H'76655443	.L	H'BBAA9988,H'77665544	.L	H'CBBAA998,H'87766554	.L	H'CCBBAA99,H'88776655	.L	H'DCCBBAA9,H'98877665	.L	H'DDCCBBAA,H'99887766	.L	H'EDDCCBBA,H'A9988776	.L	H'EEDDCCBB,H'AA998877	.L	H'FEEDDCCB,H'BAA99887CIRCLE$:	.L	H'BA988777,H'777889AB	.L	H'A9887766,H'6677889A	.L	H'98776655,H'55667789	.L	H'87765544,H'44556778	.L	H'87655433,H'33455678	.L	H'77654332,H'23345677	.L	H'76543321,H'12334567	.L	H'76543210,H'01234567	.L	H'76543210,H'01234567	.L	H'76543321,H'12334567	.L	H'77654332,H'23345677	.L	H'87655433,H'33455678	.L	H'87765544,H'44556778	.L	H'98776655,H'55667789	.L	H'A9887766,H'6677889A	.L	H'BA988777,H'777889ABSQUARE$:	.L	H'FFFFFFFF,H'FFFFFFFF	.L	H'FCCCCCCC,H'CCCCCCCF	.L	H'FC888888,H'888888CF	.L	H'FC844444,H'444448CF	.L	H'FC843333,H'333348CF	.L	H'FC843222,H'222348CF	.L	H'FC843211,H'112348CF	.L	H'FC843210,H'012348CF	.L	H'FC843210,H'012348CF	.L	H'FC843211,H'112348CF	.L	H'FC843222,H'222348CF	.L	H'FC843333,H'333348CF	.L	H'FC844444,H'444448CF	.L	H'FC888888,H'888888CF	.L	H'FCCCCCCC,H'CCCCCCCF	.L	H'FFFFFFFF,H'FFFFFFFF;--------\\; DRFONDT >;--------/; Dessine le rectangle suivant.; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D2.B	trame (0..16); out	-; mod	D1.L, D3.L, D4.L, D7.W, A1.L, A2.L, A4.LDRFONDT:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COUL$		; oui => COUL$	COMP.B	D2,(A6)+OFGLTR	JUMP',EQ SUITE$	COMP.B	(A6)+OFGLTR,#-1	JUMP',EQ FIRST$	PUSHM.L	D3,D4	LOAD.B	D3,(A6)+OFGLTR	CALL	DEFTRAD		; dfini une trame	LOAD.W	D3,(A6)+OFGLPX	LOAD.W	D4,(A6)+OFGLDX	EX.L	D3,D4	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	LOAD.L	A4,#(A2)+ODFTRA	LOAD.L	A1,(A6)+OADTRAME	CALL	(A1)		; GRA_TRAME, dessine un rectangle	POPM.L	D3,D4FIRST$:	LOAD.W	(A6)+OFGLPX,D3	LOAD.W	(A6)+OFGLDX,D4	LOAD.B	(A6)+OFGLTR,D2	JUMP'	EXIT$SUITE$:	ADD.W	(A6)+OFGLDX,D4	JUMP'	EXIT$COUL$:	COMP.B	D2,#-1	JUMP',EQ EXIT$	PUSHM.L	D3,D4	EX.L	D2,D3	CALL	DEFTRAD		; dfini une trame	EX.L	D3,D2	EX.L	D3,D4	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	LOAD.L	A4,#(A2)+ODFTRA	LOAD.L	A1,(A6)+OADTRAME	CALL	(A1)		; GRA_TRAME, dessine un rectangle	POPM.L	D3,D4EXIT$:	RET;--------\\; DEFTRAD >;========/; Dfinition d'une trame dgrade.; in	D3.B	rang de la trame (0..16); out	-; mod	D7.WDEFTRAD:	PUSHM.L	D3,D4,A3	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COUL$		; oui => COUL$	LOAD.L	A3,#R16"TRAMES$	AND.W	D3,#H'00FF	SL.W	D3,#3	ADD.W	A3,D3	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3)	CALL	INVTRAME	LOAD.L	(A0)+ODFTRA+0,D3	LOAD.L	(A0)+ODFTRA+4,D4	JUMP'	EXIT$COUL$:	LOAD.L	A3,#R16"TRAME50$	SR.B	D3,#1	JUMP',CS CTRAME$	LOAD.L	A3,#R16"TRAME100$CTRAME$:	LOAD.L	(A0)+ODFTRA+0,(A3+)	LOAD.L	(A0)+ODFTRA+4,(A3)	LOAD.B	D4,D3	CALL	CREL$		; D3 <-- couleur relative;	LIB	?COLORSR	LOAD.W	(A0)+ODFCSF+2,D3	INC.B	D4	CALL	CREL$		; D3 <-- couleur relative;	LIB	?COLORCR	LOAD.W	(A0)+ODFCCF+2,D3EXIT$:	POPM.L	D3,D4,A3	RET; in	D4.B	numro (0..8); out	D3.L	couleur relative; mod	D3.LCREL$:;	LOAD.L	D3,#COLORBLANC	CLR.W	D3		; D3 <-- fausse couleur blanche (BJBLANC)	TEST.B	D4	JUMP',EQ CREXIT$;	LOAD.L	D3,#COLORNOIR	LOAD.W	D3,#15		; D3 <-- fausse couleur noire (BJNOIR)	COMP.B	D4,#8	JUMP',HS CREXIT$;	LOAD.L	D3,#COLORDEG1-1	LOAD.W	D3,#8-1		; D3 <-- fausse couleur violette (BJDEG1-1)	ADD.B	D3,D4CREXIT$:	RETTRAMES$:			; 0	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000				; 1	.B	B'10000000	.B	B'00000000	.B	B'00001000	.B	B'00000000	.B	B'10000000	.B	B'00000000	.B	B'00001000	.B	B'00000000				; 2	.B	B'10001000	.B	B'00000000	.B	B'00100010	.B	B'00000000	.B	B'10001000	.B	B'00000000	.B	B'00100010	.B	B'00000000				; 3	.B	B'10001000	.B	B'00100000	.B	B'10001000	.B	B'00000010	.B	B'10001000	.B	B'00100000	.B	B'10001000	.B	B'00000010				; 4	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010	.B	B'10001000	.B	B'00100010				; 5	.B	B'11001000	.B	B'00100010	.B	B'10001100	.B	B'00100010	.B	B'11001000	.B	B'00100010	.B	B'10001100	.B	B'00100010				; 6	.B	B'11001100	.B	B'00100010	.B	B'10001000	.B	B'00110011	.B	B'11001100	.B	B'00100010	.B	B'10001000	.B	B'00110011				; 7	.B	B'11001100	.B	B'00110011	.B	B'10001000	.B	B'00110011	.B	B'11001100	.B	B'00110011	.B	B'10001000	.B	B'00110011				; 8	.B	B'11001100	.B	B'00110011	.B	B'11001100	.B	B'00110011	.B	B'11001100	.B	B'00110011	.B	B'11001100	.B	B'00110011				; 9	.B	B'11001100	.B	B'00110011	.B	B'11001100	.B	B'01110111	.B	B'11001100	.B	B'00110011	.B	B'11001100	.B	B'01110111				; 10	.B	B'11001100	.B	B'00110011	.B	B'11011101	.B	B'01110111	.B	B'11001100	.B	B'00110011	.B	B'11011101	.B	B'01110111				; 11	.B	B'11011101	.B	B'00110111	.B	B'11011101	.B	B'01110011	.B	B'11011101	.B	B'00110111	.B	B'11011101	.B	B'01110011				; 12	.B	B'11011101	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101	.B	B'01110111	.B	B'11011101	.B	B'01110111				; 13	.B	B'11111111	.B	B'01110111	.B	B'11111111	.B	B'01010101	.B	B'11111111	.B	B'01110111	.B	B'11111111	.B	B'01010101				; 14	.B	B'11111111	.B	B'01110111	.B	B'11111111	.B	B'11011101	.B	B'11111111	.B	B'01110111	.B	B'11111111	.B	B'11011101				; 15	.B	B'11111111	.B	B'01111111	.B	B'11111111	.B	B'11110111	.B	B'11111111	.B	B'01111111	.B	B'11111111	.B	B'11110111				; 16	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111TRAME50$:	.B	B'01010101	.B	B'10101010	.B	B'01010101	.B	B'10101010	.B	B'01010101	.B	B'10101010	.B	B'01010101	.B	B'10101010TRAME100$:	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.EVEN;-------------\\; DRAWOPENCOPY >;=============/; Dbut du dessin cach en mmoire.; On peut continuer le dessin commenc sur l'cran !; in	-; out	D7.W	erreur; mod	D7.WDRAWOPENCOPY:	PUSHM.L	D1..D6,A3,A4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE OK$		; oui => OK$	LOAD.L	D4,#LXWDO*LYWDO/8	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire o dessiner	JUMP',NE EXIT$	CALL	CCMO		; enlve la souris	LOAD.L	A3,#0	CLR.L	D3	CLR.L	D4	LOAD.W	D6,#LXWDO/8	LOAD.L	D1,#H'10000*LYWDO+LXWDO	LOAD.W	D2,#LOADDOT	CALL	DRRASTER	; mmoire <-- copie de l'cran	LOAD.L	D4,#H'10000*LYWDO+LXWDO	CALL	OPEDISMATOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DRAWOPEN >;=========/; Dbut du dessin cach en mmoire.; Il faut commencer par tout effacer !; in	-; out	D7.W	erreur; mod	D7.WDRAWOPEN:	PUSHM.L	D1,D4,A4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE OK$		; oui => OK$	LOAD.L	D4,#LXWDO*LYWDO/8	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire o dessiner	JUMP',NE EXIT$	LOAD.L	D4,#H'10000*LYWDO+LXWDO	CALL	OPEDISMATOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DRAWCLOSE >;==========/; Fin du dessin cach en mmoire.; in	-; out	-; mod	D7.WDRAWCLOSE:	PUSHM.L	D1..D5,A3,A4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.L	A3,(A0)+ODFABS	; A3 <-- ^mmoire bitmap	CALL	CLODISMAT	; fin du dessin en mmoire	LOAD.L	A4,#0	CLR.L	D3	CLR.L	D4	LOAD.W	D5,#LXWDO/8	LOAD.L	D1,#H'10000*LYWDO+LXWDO	LOAD.W	D2,#LOADDOT	CALL	DRRASTER	; cran <-- mmoire	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEMEXIT$:	POPM.L	D1..D5,A3,A4	RET;----------\\; OPEDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement en mmoire.; in	A4.L	^matrice o dessiner;	D4.L	^dimensions (dy;dx); out	-; mod	D7.WOPEDISMAT:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBSSTK	LOAD.W	D3,(A6)+OBSSTP	MUL.WU	D3,#LBS	ADD.L	A3,D3		; A3 <-- ^dans OBSSTK	LOAD.L	(A3)+OBSABS,(A0)+ODFABS	LOAD.W	(A3)+OBSIIX,(A0)+ODFIIX	LOAD.W	(A3)+OBSIIY,(A0)+ODFIIY	LOAD.L	(A3)+OBSY,(A0)+ODFY	LOAD.L	(A3)+OBSDY,(A0)+ODFDY	LOAD.L	(A3)+OBSFY,(A0)+ODFFY	LOAD.L	(A3)+OBSFDY,(A0)+ODFFDY	LOAD.L	(A3)+OBSWBY,(A0)+ODFWBY	LOAD.L	(A3)+OBSWEY,(A0)+ODFWEY	LOAD.L	(A0)+ODFABS,A4	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	LOAD.W	(A0)+ODFIIX,#1	SR.W	D4,#3	LOAD.W	(A0)+ODFIIY,D4	INC.W	(A6)+OBSSTP	POPM.L	D3,D4,A3	RET;----------\\; CLODISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.WCLODISMAT:	PUSHM.L	D3,A3	DEC.W	(A6)+OBSSTP	LOAD.L	A3,#(A6)+OBSSTK	LOAD.W	D3,(A6)+OBSSTP	MUL.WU	D3,#LBS	ADD.L	A3,D3		; A3 <-- ^dans OBSSTK	LOAD.L	(A0)+ODFABS,(A3)+OBSABS	LOAD.W	(A0)+ODFIIX,(A3)+OBSIIX	LOAD.W	(A0)+ODFIIY,(A3)+OBSIIY	LOAD.L	(A0)+ODFY,(A3)+OBSY	LOAD.L	(A0)+ODFDY,(A3)+OBSDY	LOAD.L	(A0)+ODFFY,(A3)+OBSFY	LOAD.L	(A0)+ODFFDY,(A3)+OBSFDY	LOAD.L	(A0)+ODFWBY,(A3)+OBSWBY	LOAD.L	(A0)+ODFWEY,(A3)+OBSWEY	POPM.L	D3,A3	RET;---------\\; DRINV    >;=========/; Inverse une surface rectangulaire.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRINV:	PUSHM.L	D1..D4,A1,A2	TEST.W	D4		; dx <= 0 ?	JUMP',LE EXIT$	SWAP.W	D4	TEST.W	D4		; dy <= 0 ?	JUMP',LE EXIT$	SWAP.W	D4	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADINV	CALL	(A1)		; appel de GRA_INVEXIT$:	POPM.L	D1..D4,A1,A2	RET;--------\\; DRFILL  >;========/; Rempli une surface quelconque.; in	D3.L	point de remplissage (y;x); out	D7.W	erreur; mod	D7.WDRFILL:	PUSHM.L	D1..D4,A1,A2	LOAD.L	D4,D3		; D4 <-- y;x	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADFILLO	CALL	(A1)		; appel de GRA_FILLO	PUSH.W	D7	LOAD.L	A1,(A6)+OADFILLC	CALL	(A1)		; appel de GRA_FILLC	POP.W	D7	POPM.L	D1..D4,A1,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; DRRASTER >;=========/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D1.L	hauteur/largeur (y;x);	D2.B	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT); out	-; mod	D7.WDRRASTER:	PUSHM.L	D0..D6,A1,A2	TEST.W	D1		; dx <= 0 ?	JUMP',LE EXIT$	SWAP.W	D1	TEST.W	D1		; dy <= 0 ?	JUMP',LE EXIT$	SWAP.W	D1	EX.L	D1,D2		; D2/D1 <-- mode/dimensions	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	CLR.W	D0	LOAD.B	D0,(A0)+ODFCNP	; D0 <-- nb de bits/pixel (1,4)	COMP.W	D0,#1	JUMP',NE COUL$	LOAD.L	A1,(A6)+OADRASTER	CALL	(A1)		; appel de GRA_RASTER	JUMP'	EXIT$COUL$:	TEST.L	D1:#BSRCCOUL	JUMP',BC CSRC$	MUL.WU	D5,D0		; D5 <-- Iy sourceCSRC$:	TEST.L	D1:#BDSTCOUL	JUMP',BC CDST$	MUL.WU	D6,D0		; D6 <-- Iy destinationCDST$:	LOAD.L	A1,(A6)+OADCRASTER	CALL	(A1)		; appel de GRA_CRASTEREXIT$:	POPM.L	D0..D6,A1,A2	RET;--------\\; DRRECT  >;========/; Dessine un rectangle.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	-; mod	D7.WDRRECT:	PUSHM.L	D3..D5	LOAD.L	D5,D4		; D5 <-- dimensions (dy;dx)	AND.L	D4,#H'FFFF	CALL	DRLINE		; trace ligne suprieure	LOAD.L	D4,D5	CLR.W	D4	CALL	DRLINE		; trace ligne de droite	LOAD.L	D4,D5	AND.L	D4,#H'FFFF	NEG.W	D4	CALL	DRLINE		; trace ligne infrieure	LOAD.L	D4,D5	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DRLINE		; trace ligne de gauche	POPM.L	D3..D5	RET;--------\\; DRLINE  >;========/; Dessine un segment de droite.; in	D3.L	coordonne origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode; out	D3.L	coordonne d'arrive (y;x); mod	D3.L, D7.WDRLINE:	PUSHM.L	D1,D2,D4,A1,A2	LOAD.W	D1,D2		; D1 <-- mode	EX.L	D3,D4		; D4/D3 <-- y;x/dy;dx	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OADLINE	CALL	(A1)		; appel de GRA_LINE	EX.L	D3,D4	ADD.W	D3,D4		; D3 <-- arrive en X	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- arrive en Y	SWAP.W	D3;	SWAP.W	D4	POPM.L	D1,D2,D4,A1,A2	RET;---------\\; DRTRADEF >;=========/; Dfinit une trame.; ATTENTION: les bits sont retourns par-rapport  LIB,?DRMDEF !; in	D3.L	trame;	D4.L	trame; out	-; mod	D7.WDRTRADEF:	LOAD.L	(A0)+ODFTRA+0,D3	LOAD.L	(A0)+ODFTRA+4,D4	RET	.END