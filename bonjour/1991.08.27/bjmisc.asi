	.SBTTL	BJMISC.ASI; Tirage de nombres alatoires; ----------------------------;--------\\; COUPSAC >;========/; Coup de sac pour le gnrateur alatoire.; in	-; out	-; mod	D7.WCOUPSAC:	PUSHM.L	D3,D4	LIB	?RDCLOCK	; D3/D4 <-- date et heure	RR.L	D3,#3	RL.L	D4,#7		; savante cuisine	NOT.L	D3	XOR.L	D4,D3	LOAD.L	(A6)+OHAZA+0,D3	LOAD.L	(A6)+OHAZA+4,D4	LOAD.W	D3,#10-120$:	CALL	HAZARD		; tire qq nombres	DECJ.W,NMO D3,20$	POPM.L	D3,D4	RET;---------\\; RZHAZARD >;=========/; Remet  zro le gnrateur alatoire exclusif.; in	D3.W	+/- borne infrieure (min);	D4.W	+/- borne suprieure (max+1);	A4.L	^table d'exclusion; out	-; mod	D7.WRZHAZARD:	PUSHM.L	D4,A4	SUB.W	D4,D3	ADD.W	D4,#8-1	SR.W	D4,#340$:	CLR.B	(A4+)		; recommence le tirage exclusif	DEC.W	D4	JUMP,NE 40$	POPM.L	D4,A4	RET;---------\\; EXHAZARD >;=========/; Tire un nombre alatoire exclusif.; in	D3.W	+/- borne infrieure (min);	D4.W	+/- borne suprieure (max+1);	A4.L	^table d'exclusion; out	D4.W	+/- nombre alatoire: D3 <= n < D4; mod	D4.L, D7.WEXHAZARD:	PUSHM.L	D0..D3,A3	LOAD.W	D2,D410$:	LOAD.W	D1,D2	SUB.W	D1,D3	MUL.WU	D1,#10		; D1 <-- nb max d'essais20$:	LOAD.W	D4,D2		; D4 <-- borne suprieure	CALL	MMHAZARD	; D4 <-- nombre alatoire	LOAD.W	D0,D4	SUB.W	D0,D3	SR.W	D0,#3	TSET.B	(A4)+(D0.W):D4	; nombre dj sorti ?	JUMP',BC 80$		; non => 80$				; oui =>	DEC.W	D1		; encore un essai ?	JUMP,NE 20$		; oui => 20$	LOAD.W	D1,D2	SUB.W	D1,D3	LOAD.W	D4,D340$:	LOAD.W	D0,D4	SUB.W	D0,D3	SR.W	D0,#3	TSET.B	(A4)+(D0.W):D4	; nombre dj sorti ?	JUMP',BC 80$		; non => 80$	INC.W	D4	DEC.W	D1	JUMP,NE 40$	LOAD.L	A3,A4	LOAD.W	D1,D2	SUB.W	D1,D3	ADD.W	D1,#8-1	SR.W	D1,#350$:	CLR.B	(A3+)		; recommence le tirage exclusif	DEC.W	D1	JUMP,NE 50$	JUMP	10$80$:	POPM.L	D0..D3,A3	RET;---------\\; MMHAZARD >;=========/; Tire un nombre alatoire (16 bits) compris entre deux bornes.; in	D3.W	+/- borne infrieure (min);	D4.W	+/- borne suprieure (max+1); out	D4.W	+/- nombre alatoire: D3 <= n < D4; mod	D4.L, D7.WMMHAZARD:	PUSH.W	D2	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- sup - inf	CALL	HAZARD	AND.L	D4,#H'FFFF	DIV.WU	D4,D2	SWAP.W	D4		; D4 <-- reste de la division	ADD.W	D4,D3	POP.W	D2	RET;--------\\; HAZARD  >;========/; Tire un nombre alatoire de 32 bits.; On utilise un registre  dcalage de 63 bits, avec un XNOR entre; les bits 0 et 60 pour calculer le nouveau bit inject.; in	-; out	D4.L	nombre; mod	D4.LHAZARD:	PUSHM.L	D2,D3	LOAD.W	D2,#32-1	LOAD.L	D3,(A6)+OHAZA+0	LOAD.L	D4,(A6)+OHAZA+410$:	TEST.L	D4:#1	JUMP,BC 20$	TEST.L	D3:#30	JUMP,BC 35$	JUMP	30$20$:	TEST.L	D3:#30	JUMP,BS 35$30$:	CLRX	RRX.L	D3,#1	RRX.L	D4,#1	JUMP	40$35$:	SETX	RRX.L	D3,#1	RRX.L	D4,#140$:	LOAD.L	(A6)+OHAZA+0,D3	LOAD.L	(A6)+OHAZA+4,D4	DECJ.W,NMO D2,10$	POPM.L	D2,D3	RET;---------\\; DESRECTM >;=========/; Dessine un joli rectangle multiple.; in	D1.W	map (0..7 pour SETDOT, 7..15 pour CLRDOT);	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDESRECTM:	PUSHM.L	D0..D5	LOAD.W	D0,D1		; D1 <-- map pour SETDOT	SR.W	D0,#8		; D0 <-- map pour CLRDOT	LOAD.W	D5,#8-1LOOP$:	RR.B	D0,#1		; C <-- cadre ou pas	JUMP',CC NOCLR$	LOAD.W	D2,#CLRDOT	CALL	INVMODE	LIB	?DRRECT		; dessine un rectangleNOCLR$:	RR.B	D1,#1		; C <-- cadre ou pas	JUMP',CC NOSET$	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRRECT		; dessine un rectangleNOSET$:	DEC.W	D3		; X <-- X-1	SWAP.W	D3	DEC.W	D3		; Y <-- Y-1	SWAP.W	D3	ADD.W	D4,#2		; dX <-- dX+2	SWAP.W	D4	ADD.W	D4,#2		; dY <-- dY+2	SWAP.W	D4	DECJ.W,NMO D5,LOOP$	POPM.L	D0..D5	RET;---------\\; INVTRAME >;=========/; in	D3/D4	trame; out	D3/D4	trame inverse; mod	D3/D4INVTRAME:	TEST.B	(A6)+OINV	JUMP',F EXIT$	NOT.L	D3	NOT.L	D4EXIT$:	RET;--------\\; INVMODE >;========/; in	D2.W	mode de dessin; out	D2.W	mode inverse; mod	D2.WINVMODE:	PUSH.W	D1	TEST.B	(A6)+OINV	JUMP',F EXIT$	LOAD.B	D1,D2	AND.B	D1,#B'11111100	AND.B	D2,#B'00000011	COMP.B	D2,#SETDOT	JUMP',EQ SET$	COMP.B	D2,#CLRDOT	JUMP',NE END$CLR$:	LOAD.B	D2,#SETDOT	JUMP'	END$SET$:	LOAD.B	D2,#CLRDOT;	JUMP'	END$END$:	OR.B	D2,D1EXIT$:	POP.W	D1	RET;--------\\; CLRFIFO >;========/; Vide le fifo du clavier.; in	-; out	-; mod	D7.WCLRFIFO:	PUSH.L	D3LOOP$:	LIB	?IFCAR	JUMP,EQ LOOP$	POP.L	D3	RET; Gestion de la souris; --------------------;------------\\; MODEMOSTART >;============/; Dbut d'une dmonstration automatique avec la souris.; in	A4.L	^table des dplacements; out	D7.W	erreur; mod	D7.WMODEMOSTART:	PUSHM.L	D3..D5,A1..A5	LOAD.L	A1,A4		; A1 <-- ^table (pass dans A3 du fils)	LOAD.L	D4,(A4)		; D4 <-- position initiale	CALL	PMOUSE	CLR.B	(A6)+OABORT3	NTREL	?GETPRIO	; D4 <-- priorit de BONJOUR	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS4	LOAD.L	A3,#R16"NFILS4	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP',NE EXIT$	CALL	CLRFIFO		; vide le fifo du clavier	CALL	SCMO		; remet la sourisEXIT$:	POPM.L	D3..D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; MODEMSTOP >;==========/; Fin d'une dmonstration automatique avec la souris.; in	-; out	-; mod	D7.WMODEMOSTOP:	PUSHM.L	D4	CALL	CCMO		; enlve la souris	SET.B	(A6)+OABORT3	LOAD.W	D4,#10	NTREL	?DELMS		; attend la fin du processus fils	POPM.L	D4	TEST.W	D7		; retour EQ/NE	RET; Processus de dplacement de la souris; -------------------------------------NFILS4:	.ASCIZ	"BONJOUR_MOUSE"	.EVENPFILS4:	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	D3,(A3+)	; D3 <-- position initiale	ADD.W	D3,(A0)+ODFFX	SWAP.W	D3	ADD.W	D3,(A0)+ODFFY	SWAP.W	D3		; D3 <-- position de dpartLOOP$:	CALL	SCMO		; remet la souris !	LOAD.W	D1,(A3+)	JUMP,EQ END$	JUMP',NS SPEC$	LOAD.L	D2,(A3+)MOVE$:	TEST.B	(A6)+OABORT3	JUMP',T	END$	SWAP.W	D2	SWAP.W	D3	ADD.W	D3,D2		; D3 <-- nouvelle position	SWAP.W	D2	SWAP.W	D3	ADD.W	D3,D2	LOAD.L	D4,D3	LIB	?PMOUSE		; positionne la souris	PUSH.L	D3	LOAD.L	D3,#KEYMPO	LIB	?WRKEY		; signal un dplacement	POP.L	D3	LOAD.W	D4,#2	NTREL	?DELMS	DEC.W	D1	JUMP,NE MOVE$	JUMP	LOOP$SPEC$:	COMP.W	D1,#-1	JUMP',EQ KEY$	JUMP	LOOP$KEY$:	PUSH.L	D3	CLR.L	D3	LOAD.W	D3,(A3+)	LIB	?WRKEY		; "presse" une touche	LOAD.W	D4,#TMUSTIC	COMP.W	D3,#KEYMGP	JUMP',EQ KEYMUS$	COMP.W	D3,#KEYMMP	JUMP',EQ KEYMUS$	COMP.W	D3,#KEYMDP	JUMP',EQ KEYMUS$	LOAD.W	D4,#TMUSTAC	COMP.W	D3,#KEYMGR	JUMP',EQ KEYMUS$	COMP.W	D3,#KEYMMR	JUMP',EQ KEYMUS$	COMP.W	D3,#KEYMDR	JUMP',NE KEYEND$KEYMUS$:	LOAD.W	(A6)+OSOUND,D4KEYEND$:	POP.L	D3	JUMP	LOOP$END$:	NTREL	?ABORTWAIT$:	LOAD.W	D1,D4	SR.W	D1,#1WLOOP$:	LOAD.L	D4,D3	LIB	?PMOUSE		; positionne la souris	LOAD.W	D4,#2	NTREL	?DELMS	DEC.W	D1	JUMP,NE WLOOP$	RET;--------\\; CCMO    >;========/; Enlve la flche de la souris.; in	-; out	-; mod	-CCMO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	SET.B	(A6)+OCCMO	POPM.L	D3,D7	RET;--------\\; SCMO    >;========/; Remet la flche de la souris.; in	-; out	-; mod	-SCMO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	CLR.B	(A6)+OCCMO	POPM.L	D3,D7	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMOUSE  >;========/; Met la souris dans la fentre.; in	D4.L	position (y;x); out	-; mod	D7.WPMOUSE:	PUSH.L	D4	ADD.W	D4,(A0)+ODFFX	SWAP.W	D4	ADD.W	D4,(A0)+ODFFY	SWAP.W	D4	LIB	?PMOUSE	POP.L	D4	RET;----------\\; AFMENUNIL >;==========/; Affiche les soft-keys.; in	-; out	-; mod	-AFMENUNIL:	PUSHM.L	D7,A3	LOAD.L	A3,#R16"TXMENU$	LIB	?AFMENU	POPM.L	D7,A3	RETTXMENU$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN;-----------\\; AFMENUCTRL >;===========/; Affiche les soft-keys.; in	-; out	-; mod	-AFMENUCTRL:	PUSHM.L	D7,A3	LOAD.L	A3,#R16"TXMENU$	LIB	?AFMENU	POPM.L	D7,A3	RETTXMENU$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	"Revient  l'exer-"	.ASCIZ	" cice prcdent  "		;     ;     ;     ;	.ASCIZ	"Rpte le dernier"	.ASCIZ	"    exercice     "		;     ;     ;     ;	.ASCIZ	"Termine la srie "	.ASCIZ	"   d'exercices   "		;     ;     ;     ;	.ASCIZ	" Passe  l'exer- "	.ASCIZ	"  cice suivant   "		;     ;     ;     ;	.EVEN;------------\\; AFMENUBASEC >;============/; Affiche les soft-keys.; in	-; out	-; mod	-AFMENUBASEC:	PUSHM.L	D7,A3	LOAD.L	A3,#R16"TXMENU$	LIB	?AFMENU	POPM.L	D7,A3	RETTXMENU$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	"         Couleurs"	.ASCIZ	""		;     ;     ;     ;	.EVEN;-----------\\; AFMENUBASE >;===========/; Affiche les soft-keys.; in	-; out	-; mod	-AFMENUBASE:	PUSHM.L	D7,A3	LOAD.L	A3,#R16"TXMENU$	LIB	?AFMENU	POPM.L	D7,A3	RETTXMENU$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN	.END