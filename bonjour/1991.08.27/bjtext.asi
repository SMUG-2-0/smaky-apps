	.SBTTL	BJTEXT.ASI;--------\\; TXBULLE >;========/; Affiche un texte dans une bulle normale (pour toto).; in	A3.L	^texte; out	-; mod	D7.WTXBULLE:	PUSHM.L	D1..D4	CALL	TXOPEN		; utilise les grands caractres	LOAD.W	D1,#IMABULLE	LOAD.L	D2,#H'10000*(LYWDO-312)+234	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; affiche la bulle	CALL	TXGETDIM	; D4 <-- dimensions	LOAD.W	D3,#310	SUB.W	D3,D4	ASR.W	D3,#1	ADD.W	D3,D2	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,#182	SUB.W	D3,D4	ASR.W	D3,#1	ADD.W	D3,D2;	SWAP.W	D2	SWAP.W	D3;	SWAP.W	D4	CALL	TXDRAW		; affiche le texte	CALL	TXCLOSE		; utilise les petits caractres	POPM.L	D1..D4	RET;---------\\; TXBULLEL >;=========/; Affiche un texte dans une bulle large (pour toto).; in	A3.L	^texte; out	-; mod	D7.WTXBULLEL:	PUSHM.L	D1..D4	CALL	TXOPEN		; utilise les grands caractres	LOAD.W	D1,#IMABULLEL	LOAD.L	D2,#H'10000*4+0	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; affiche la bulle	CALL	TXGETDIM	; D4 <-- dimensions	LOAD.W	D3,#630	SUB.W	D3,D4	ASR.W	D3,#1	ADD.W	D3,D2	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,#80	SUB.W	D3,D4	ASR.W	D3,#1	ADD.W	D3,D2;	SWAP.W	D2	SWAP.W	D3;	SWAP.W	D4	CALL	TXDRAW		; affiche le texte	CALL	TXCLOSE		; utilise les petits caractres	POPM.L	D1..D4	RET;---------\\; TXBULLEH >;=========/; Affiche un texte dans une bulle horizontale (sans toto).; in	A3.L	^texte; out	-; mod	D7.WTXBULLEH:	PUSHM.L	D1..D4	CALL	TXOPEN		; utilise les grands caractres	LOAD.W	D1,#IMABULLEH	LOAD.L	D2,#H'10000*8+0	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; affiche la bulle	CALL	TXGETDIM	; D4 <-- dimensions	LOAD.W	D3,#630	SUB.W	D3,D4	ASR.W	D3,#1	ADD.W	D3,D2	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,#56	SUB.W	D3,D4	ASR.W	D3,#1	ADD.W	D3,D2;	SWAP.W	D2	SWAP.W	D3;	SWAP.W	D4	CALL	TXDRAW		; affiche le texte	CALL	TXCLOSE		; utilise les petits caractres	POPM.L	D1..D4	RET;--------\\; TXDRAW  >;========/; Affiche un texte.; in	A3.L	^texte;	D3.L	coin sup/gauche (y;x); out	-; mod	D7.WTXDRAW:	PUSHM.L	D0..D5,A3	CLR.B	D5		; D5 <-- roman	LOAD.L	D2,D3	SWAP.W	D2	ADD.W	D2,(A0)+ODFC1Y	SWAP.W	D2LOOPY$:	LOAD.L	D1,D2	LOAD.L	D3,D2	LIB	?SETCURS	LOAD.W	D3,(A0)+ODFCY	COMP.B	(A3),#CR	JUMP',NE NEXTY$	SR.W	D3,#1NEXTY$:	SWAP.W	D2	ADD.W	D2,D3	SWAP.W	D2LOOPX$:	LOAD.B	D3,(A3+)	JUMP,EQ EXIT$	JUMP',NS SPEC$	COMP.B	D3,#CR	JUMP,EQ LOOPY$	LIB	?AFCAR		; affiche un caractre	LIB	?LGXCAR	TEST.B	D5	JUMP',EQ AFROMAN$	PUSH.L	D3	LOAD.L	D3,D1	INC.W	D3	LIB	?SETCURS	POP.L	D3	LIB	?AFCAR	PUSH.L	D3	LOAD.L	D3,D1	ADD.W	D3,D4	LIB	?SETCURS	POP.L	D3AFROMAN$:	ADD.W	D1,D4	LOAD.W	D4,(A6)+OTXDEL	JUMP,EQ LOOPX$	COMP.B	D3,#SPACE	JUMP',EQ TIC$	LOAD.W	(A6)+OSOUND,#TMUSTAC	JUMP'	DEL$TIC$:	LOAD.W	(A6)+OSOUND,#TMUSTICDEL$:	LOAD.W	D3,D4	SR.W	D3,#1	CALL	MMHAZARD	NTREL	?DELMS		; attend un p'tit peu ...	JUMP	LOOPX$SPEC$:	COMP.B	D3,#AFDRECT	JUMP',EQ DRECT$	COMP.B	D3,#AFFRECT	JUMP',EQ FRECT$	COMP.B	D3,#AFBOLD	JUMP',EQ BOLD$	COMP.B	D3,#AFROMAN	JUMP',EQ ROMAN$	COMP.B	D3,#AFTRAIT	JUMP,EQ TRAIT$	LIB	?AFCAR	JUMP	LOOPX$DRECT$:	LOAD.L	D0,D1	JUMP	LOOPX$FRECT$:	LOAD.L	D3,D0	LOAD.L	D4,D1	SUB.W	D3,#3	ADD.W	D4,#3	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,#2	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	INC.W	D4	SWAP.W	D3	SWAP.W	D4	PUSHM.L	D1,D2	LOAD.W	D1,#3	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRRECTA	POPM.L	D1,D2	JUMP	LOOPX$BOLD$:	INC.B	D5	JUMP	LOOPX$ROMAN$:	DEC.B	D5	JUMP	LOOPX$TRAIT$:	LOAD.L	D3,D1	CLR.W	D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A0)+ODFC1Y	DEC.W	D3	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	INC.W	D4	SWAP.W	D3	SWAP.W	D4	PUSH.W	D2	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRSEG	POP.W	D2	JUMP	LOOPX$EXIT$:	POPM.L	D0..D5,A3	RET;---------\\; TXGETDIM >;=========/; Cherche les dimensions d'un texte quelconque.; in	A3.L	^texte; out	D4.L	dimensions (dy;dx); mod	D4.L, D7.WTXGETDIM:	PUSHM.L	D1..D3,D5,A3	CLR.W	D1		; D1 <-- hauteur	CLR.W	D2		; D2 <-- largeurLINE$:	CLR.W	D5		; D5 <-- largeur de la ligne	TEST.B	(A3)	JUMP',EQ END$	LOAD.W	D3,(A0)+ODFCY	COMP.B	(A3),#CR	JUMP',NE NEXTY$	SR.W	D3,#1NEXTY$:	ADD.W	D1,D3LLOOP$:	LOAD.B	D3,(A3+)	JUMP,NS LLOOP$	JUMP',EQ LEND$	COMP.B	D3,#CR	JUMP',EQ LEND$	LIB	?LGXCAR		; D4 <-- largeur d'un caractrea	ADD.W	D5,D4	JUMP	LLOOP$LEND$:	COMP.W	D2,D5	JUMP',HS LNEXT$	LOAD.W	D2,D5		; D2 <-- largeur la plus grandeLNEXT$:	TEST.B	D3	JUMP,NE LINE$END$:	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D2	POPM.L	D1..D3,D5,A3	RET;--------\\; TXOPEN  >;========/; Utilise les grands caractres.; in	-; out	-; mod	D7.WTXOPEN:	LIB	?AFTIM	.B	USEGC		; utilise les grands caractres	.B	GCTGF	.B	GCTGS	.B	GCTGT	.B	0	.EVEN	JUMP'	TXPOPEN;---------\\; TXPPOPEN >;=========/; Utilise les grands caractres.; in	-; out	-; mod	D7.WTXPPOPEN:	LIB	?AFTIM	.B	USEGC		; utilise les petits caractres	.B	GCTPF	.B	GCTPS	.B	GCTPT	.B	0	.EVEN;	JUMP'	TXPOPEN;--------\\; TXPOPEN >;========/; Utilise les petits caractres.; in	-; out	-; mod	D7.WTXPOPEN:	TEST.B	(A6)+OINV	JUMP',T INV$	LIB	?AFTIM	.B	MODCAR,SETDOT!PENDOT,0	.EVEN	JUMP'	EXIT$INV$:	LIB	?AFTIM	.B	MODCAR,CLRDOT!PENDOT,0	.EVENEXIT$:	RET;----------\\; TXPPCLOSE >;==========/;--------\\; TXCLOSE >;========/; Utilise les petits caractres.; in	-; out	-; mod	D7.WTXPPCLOSE:TXCLOSE:	LIB	?AFTIM	.B	USEGC		; utilise les petits caractres	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	MODCAR,SETDOT,0	.B	0	.EVEN	RET;---------\\; TXPCLOSE >;=========/; Utilise les petits caractres.; in	-; out	-; mod	D7.WTXPCLOSE:	LIB	?AFTIM	.B	MODCAR,SETDOT,0	.B	0	.EVEN	RET	.END