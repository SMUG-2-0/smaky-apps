	.SBTTL	BJSOURIS.ASI;--------\\; DEBUT   >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDEBUT:	PUSHM.L	D1,D2,D4,A3,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGMIDDLEH+H'04	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLE	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*5	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	_CTRLEVENT	; attend un vnement ...	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"<AFINV> BONJOUR ! <AFDIR><CR>"	.ASCII	"<CR>"	.ASCII	"Nous allons ensemble<CR>"	.ASCII	"faire connaissance<CR>"	.ASCII	"avec le SMAKY ...<CR>"	.B	0	.EVEN;--------\\; SOURIS1 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS1:	PUSHM.L	D1,D2,D4,A3,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLE	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*2	CALL	_CTRLWAIT	; attend ...	JUMP,EQ END$		; si arrt d'urgence => END$	LOAD.L	A4,#R16"TAMSOURIS	CALL	_MOVEALL	; animation ...	COMP.W	D3,#END		; arrt d'urgence ?	JUMP,EQ END$		; oui => END$	LOAD.W	D1,#IMABLUPQ2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D4,#50*2	CALL	_CTRLWAIT	; attend ...	JUMP,EQ END$		; si arrt d'urgence => END$	CALL	_DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT2$	CALL	_TXBULLE	; dessine le texte	LOAD.W	D1,#IMASOURIS	LOAD.L	D2,(A6)+OOBJ1+OOLPOS	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; redessine la souris	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	_CTRLEVENT	; attend un vnement ...END$:	LOAD.W	D1,#IMASOURIS	CALL	_IMAGECODE	; libre l'image de la souris	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"Commenons par<CR>"	.ASCII	"tudier la <AFBOLD>souris<AFROMAN>.<CR>"	.B	0TEXT2$:	.ASCII	"Non, la souris du SMAKY<CR>"	.ASCII	"n'est pas un animal,<CR>"	.ASCII	"mais un petit dispositif<CR>"	.ASCII	"avec trois boutons ...<CR>"	.B	0	.EVEN;--------\\; SOURIS2 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS2:	PUSHM.L	D1,D2,D4,A3,A4	LOAD.L	A3,#R16"PEN$	LOAD.W	D3,#1+8	LIB	?STRING	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLE	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*4	CALL	_CTRLWAIT	; attend ...	JUMP,EQ END$		; si arrt d'urgence => END$	LOAD.L	A4,#R16"TAMMOUSEF1	CALL	_MOVEALL	; animation ...	COMP.W	D3,#END		; arrt d'urgence ?	JUMP,EQ END$		; oui => END$	CALL	_DRAWOPENCOPY	; dessine en mmoire	LOAD.W	D1,#IMABLUPP2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT2$	CALL	_TXBULLE	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A4,#R16"TAMMOUSEF2	CALL	_MOVEALL	; animation ...	COMP.W	D3,#END		; arrt d'urgence ?	JUMP,EQ END$		; oui => END$	LIB	?COLORPUSH	LOAD.L	D3,#COLORROUGE	LIB	?COLORSR	LOAD.L	D3,#H'10000*222+346	LOAD.L	D4,#H'10000*80+80	LOAD.W	D2,#SETDOT!PENDOT	PUSH.L	D3	LIB	?DRSEG		; biffe le mauvais exemple	POP.L	D3	ADD.W	D3,D4	NEG.W	D4	LIB	?DRSEG	LIB	?COLORPOP	LOAD.W	D4,#50*5	CLR.B	(A6)+OCTRLG	CALL	_CTRLEVENT	; attend un vnement ...END$:	LOAD.W	D1,#IMAMOUSE1	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAMOUSE2	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAMOUSE3	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAMOUSE4	CALL	_IMAGECODE	; libre l'image 	POPM.L	D1,D2,D4,A3,A4	RETPEN$:	.B	PEN	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'01111110	.B	B'00111100;	.EVENTEXT1$:	.ASCII	"La souris se dplace<CR>"	.ASCII	" la main, ce qui se<CR>"	.ASCII	"traduit sur l'cran<CR>"	.ASCII	"par le dplacement<CR>"	.ASCII	"d'une petite flche !<CR>"	.B	0TEXT2$:	.ASCII	"<AFBOLD>Ce dplacement n'est<AFROMAN><CR>"	.ASCII	"<AFBOLD>pas correct !<AFROMAN><CR>"	.ASCII	"Il faut maintenir la<CR>"	.ASCII	"souris bien droite,<CR>"	.ASCII	"avec les trois bou-<CR>"	.ASCII	"tons en avant ...<CR>"	.B	0	.EVEN;--------\\; SOURIS3 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS3:	PUSHM.L	D1,D2,D4,A3,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLE	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A4,#R16"TAMMOUSEJ	CALL	_MOVEALL	; animation ...	COMP.W	D3,#END		; arrt d'urgence ?	JUMP',EQ END$		; oui => END$	LOAD.W	D4,#50*3	CLR.B	(A6)+OCTRLG	CALL	_CTRLEVENT	; attend un vnement ...END$:	LOAD.W	D1,#IMAMOUSE1	CALL	_IMAGECODE	; libre l'image 	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"Observez un<CR>"	.ASCII	"dplacement<CR>"	.ASCII	"correct :<CR>"	.B	0	.EVEN;---------\\; SOURIS3B >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS3B:	PUSHM.L	D1,D2,D4,A3,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGVERTI	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D1,#IMAVISER	LOAD.L	D2,#H'10000*150+280	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine l'explication	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*7	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	_CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMAVISER	CALL	_IMAGECODE	; libre l'image 	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"La flche de la souris pointe sur<CR>"	.ASCII	"l'cran avec son extrmit :<CR>"	.B	0	.EVEN;--------\\; SOURIS4 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS4:	PUSHM.L	D0,D1,D2,D4,A3,A4	LOAD.L	A3,#R16"TEXT1$	LOAD.W	D0,#2ENCORE$:	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMASM324V	LOAD.L	D2,#H'10000*(LYWDO-306)+10	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	CALL	_TXBULLE	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	CALL	SOURIS4PTS	; attend les points 1  7 ...	COMP.L	D4,#50*5	; plus de 5 secondes ?	JUMP',LO SUITE$		; non => SUITE$	LOAD.W	(A6)+OSOUND,#TMUSFAUX	LOAD.L	A3,#R16"TEXT2$	DEC.W	D0	JUMP,NE ENCORE$SUITE$:	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMASM324	LOAD.L	D2,#H'10000*(LYWDO-306)+10	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT3$	CALL	_TXBULLE	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*4	CLR.B	(A6)+OCTRLG	CALL	_CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMASM324V	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMASM324	CALL	_IMAGECODE	; libre l'image 	POPM.L	D0,D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"Maintenant, c'est <CR>"	.ASCII	"vous de jouer !<CR>"	.ASCII	"<CR>"	.ASCII	"Dplacez la souris sur<CR>"	.ASCII	"les points <AFDRECT>1<AFFRECT>  <AFDRECT>7<AFFRECT> ...<CR>"	.B	0TEXT2$:	.ASCII	"C'est juste, mais pas<CR>"	.ASCII	"assez rapide !<CR>"	.ASCII	"<CR>"	.ASCII	"Essayez encore une fois<CR>"	.ASCII	"de dplacez la souris <CR>"	.ASCII	"sur les points <AFDRECT>1<AFFRECT>  <AFDRECT>7<AFFRECT> ...<CR>"	.B	0TEXT3$:	.ASCII	"Trs bien !<CR>"	.B	0	.EVEN;-----------\\; SOURIS4PTS >;-----------/; Attend que la souris aie pass par tous les points de l'image.; in	D2.L	position de l'image (y;x); out	D4.L	temps utilis; mod	D4.L, D7.WSOURIS4PTS:	PUSHM.L	D0..D3,D5,A3,A4	LIB	?BUZZ	LOAD.L	D0,D2	LOAD.L	A3,#R16"PEN$	LOAD.W	D3,#1+8	LIB	?STRING	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	_CLRFIFO	; vide le fifo du clavier	CALL	_SCMO		; remet la souris	LOAD.L	A4,#R16"TABLE$	; A4 <-- ^table des points	CLR.L	D5LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',EQ MOVE$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	CLR.L	D4	COMP.W	D3,#CR	JUMP,EQ EXIT$	COMP.W	D3,#SPACE	JUMP,EQ EXIT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$MOVE$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	LOAD.W	D3,(A4)+0	ADD.W	D3,D0	SUB.W	D3,#5	COMP.W	D4,D3	JUMP,LO LOOP$	ADD.W	D3,#5+5	COMP.W	D4,D3	JUMP,HS LOOP$	SWAP.W	D4	LOAD.W	D3,#306	SUB.W	D3,(A4)+2	SWAP.W	D0	ADD.W	D3,D0	SWAP.W	D0	SUB.W	D3,#5	COMP.W	D4,D3	JUMP,LO LOOP$	ADD.W	D3,#5+5	COMP.W	D4,D3	JUMP,HS LOOP$	TEST.L	D5	JUMP',NE JUSTE$	LOAD.L	D5,(A6)+OTIME	; D5 <-- temps du premier point visJUSTE$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	LOAD.W	D3,#306	SUB.W	D3,(A4)+2	SWAP.W	D0	ADD.W	D3,D0	SWAP.W	D0	SUB.W	D3,#10	SWAP.W	D3	LOAD.W	D3,(A4)+0	ADD.W	D3,D0	SUB.W	D3,#10	LOAD.L	D4,#H'10000*20+20	LOAD.W	D2,#INVDOT	LOAD.W	D1,#6-1INV$:	LIB	?DRTRAME	; inverse le point	PUSH.W	D4	LOAD.W	D4,#50/10	NTREL	?DELMS	POP.W	D4	DECJ.W,NMO D1,INV$	TEST.L	(A4)-4	JUMP',EQ NEXT$	LOAD.W	D3,#306	SUB.W	D3,(A4)-2	SWAP.W	D0	ADD.W	D3,D0	SWAP.W	D0	SWAP.W	D3	LOAD.W	D3,(A4)-4	ADD.W	D3,D0	LOAD.W	D4,(A4)-2	SUB.W	D4,(A4)+2	SWAP.W	D4	LOAD.W	D4,(A4)+0	SUB.W	D4,(A4)-4	LIB	?COLORPUSH	PUSH.L	D3	LOAD.L	D3,#COLORJAUNE	LIB	?COLORSR	POP.L	D3	LOAD.W	D2,#SETDOT!PENDOT	CALL	_INVMODE	LIB	?DRSEG	LIB	?COLORPOPNEXT$:	ADD.L	A4,#4		; A4 <-- ^point suivant	TEST.L	(A4)	JUMP,NE LOOP$	LOAD.L	D4,(A6)+OTIME	SUB.L	D4,D5		; D4 <-- temps utilisEXIT$:	CALL	_CCMO		; enlve la souris	POPM.L	D0..D3,D5,A3,A4	RETPEN$:	.B	PEN	.B	B'00000000	.B	B'00111100	.B	B'01111110	.B	B'01111110	.B	B'01111110	.B	B'01111110	.B	B'00111100	.B	B'00000000	.EVEN	.W	0,0TABLE$:	;	X= Y=		(selon DESSIN4)	.W	73,289	.W	185,298	.W	188,151	.W	74,140	.W	12,174	.W	9,263	.W	35,267	.W	0,0;---------\\; SOURIS4B >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS4B:	PUSHM.L	D1,D2,D4,A3,A4	.IF	~NOLABY	CALL	_LAMOUSE	; labyrinthe ...	.ENDIF	LOAD.W	D4,#50*3	CLR.B	(A6)+OCTRLG	CALL	_CTRLEVENT	; attend un vnement ...	POPM.L	D1,D2,D4,A3,A4	RET;--------\\; SOURIS5 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS5:	PUSHM.L	D1,D2,D4,A3,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGCIRCLE	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*8	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	_CTRLEVENT	; attend un vnement ...	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"L'action qui consiste  presser l'un des trois<CR>"	.ASCII	"boutons de la souris, puis  le relcher imm-<CR>"	.ASCII	/diatement, est dsigne par le verbe <AFBOLD>"cliquer"<AFROMAN>.<CR>/	.B	0	.EVEN;--------\\; SOURIS6 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS6:	PUSHM.L	D0,D1,D2,D4,A3,A4	LOAD.L	A3,#R16"TEXT1$	LOAD.W	D1,#IMABLUPF1	LOAD.W	D0,#2ENCORE$:	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGCIRCLE	CALL	_DRFONDD	; dessine le fond	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	CALL	_TXBULLEL	; dessine le texte	LOAD.L	A3,#R16"SOURIS6POS	LOAD.L	(A6)+OBSQAD,A3	LOAD.L	A3,#R16"TEXTB$	LOAD.L	A4,#0	CALL	BSQDRAW		; dessine les 3 carrs	CALL	_DRAWCLOSE	; montre le dessin en mmoire	CALL	SOURIS6ACTION	; action ...	COMP.L	D4,#50*3	; plus de 3 secondes ?	JUMP',LO SUITE$		; non => SUITE$	LOAD.L	A3,#R16"TEXT2$	LOAD.W	D1,#IMABLUPF2	DEC.W	D0	JUMP,NE ENCORE$SUITE$:	CALL	_DRAWOPENCOPY	; dessine en mmoire	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT3$	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*2	CLR.B	(A6)+OCTRLG	CALL	_CTRLEVENT	; attend un vnement ...	POPM.L	D0,D1,D2,D4,A3,A4	RETTEXTB$:	.ASCIZ	"bouton de gauche"	.ASCIZ	"bouton du milieu"	.ASCIZ	"bouton de droite"TEXT1$:	.ASCII	"<AFBOLD>Cliquez<AFROMAN> dans les trois carrs ci-dessous,<CR>"	.ASCII	"en utilisant les boutons demands ...<CR>"	.B	0TEXT2$:	.ASCII	"C'est juste, mais pas assez rapide !<CR>"	.ASCII	"Recommencez ...<CR>"	.B	0TEXT3$:	.ASCII	"Bravo !<CR>"	.B	0	.EVEN;--------------\\; SOURIS6ACTION >;==============/; Action dans les 3 boutons.; in	-; out	D4.L	temps utilis; mod	D4.L, D7.WSOURIS6ACTION:	PUSHM.L	D0..D3,D5	CALL	_CLRFIFO	; vide le fifo du clavier	CALL	_SCMO		; remet la souris	CLR.B	D0		; D0 <-- boutons cliqus	CLR.L	D5LOOP$:	LIB	?GETCAR		; attend souris/clavier ...	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	CLR.L	D4	COMP.W	D3,#CR	JUMP,EQ EXIT$	COMP.W	D3,#SPACE	JUMP,EQ EXIT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	TEST.L	D5	JUMP',NE NOFIRST$	LOAD.L	D5,(A6)+OTIME	; D5 <-- temps du premier point visNOFIRST$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	CALL	BSQMOVE		; D1 <-- rang (0..2)	JUMP,NE BIP$	LOAD.W	D2,#KEYMGP	TEST.W	D1	JUMP',EQ BUTTON$	LOAD.W	D2,#KEYMMP	COMP.W	D1,#1	JUMP',EQ BUTTON$	LOAD.W	D2,#KEYMDPBUTTON$:	COMP.W	D3,D2		; avec le bon bouton ?	JUMP,NE FAUX$	TSET.L	D0:D1	JUMP,BS BIP$	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	CALL	BSQBIF		; biffe le carr	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	COMP.B	D0,#B'111	; tous les carrs biffs ?	JUMP,NE LOOP$		; non => LOOP$	LOAD.L	D4,(A6)+OTIME	SUB.L	D4,D5		; D4 <-- temps utilis	JUMP'	EXIT$FAUX$:	LOAD.W	(A6)+OSOUND,#TMUSFAUX	LOAD.W	D1,#IMABLUPF2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	JUMP	LOOP$EXIT$:	CALL	_CCMO		; enlve la souris	POPM.L	D0..D3,D5	RET;-----------\\; SOURIS6POS >;-----------/; Donne la position d'un carr.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WSOURIS6POS:	PUSH.L	D1	LOAD.W	D7,#1	COMP.W	D1,#3	JUMP',HS EXIT$	LOAD.L	D3,#H'10000*150+310	LOAD.L	D4,#H'10000*24+24	MUL.WU	D1,#24+10	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D3	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;--------\\; SOURIS7 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS7:	PUSHM.L	D1,D2,D4,A3,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGMIDDLEV+H'04	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLE	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*8	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	_CTRLEVENT	; attend un vnement ...	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"L'action qui consiste <CR>"	.ASCII	"presser un bouton, puis<CR>"	.ASCII	" dplacer la souris tout<CR>"	.ASCII	"en le maintenant press,<CR>"	.ASCII	"est dsigne par le verbe<CR>"	.ASCII	/<AFBOLD>"tirer"<AFROMAN>.<CR>/	.B	0	.EVEN;--------\\; SOURIS8 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS8:	PUSHM.L	D0,D1,D2,D4,A3,A4	LOAD.L	A3,#R16"TEXT1$	LOAD.W	D0,#2ENCORE$:	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGMIDDLEV+H'04	CALL	_DRFONDD	; dessine le fond	CALL	SOURIS8DRAW	; dessine le puzzle initial	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#70	NTREL	?DELMS	LOAD.L	A2,(A6)+OPZCHA+(4*0)	LOAD.W	D2,#-3	SWAP.W	D2	LOAD.W	D2,#-9	LOAD.W	D1,#20	CALL	SOURIS8MEL	; mlange le puzzle ...	LOAD.L	A2,(A6)+OPZCHA+(4*1)	LOAD.W	D2,#-4	SWAP.W	D2	LOAD.W	D2,#+9	LOAD.W	D1,#12	CALL	SOURIS8MEL	; mlange le puzzle ...	LOAD.L	A2,(A6)+OPZCHA+(4*2)	LOAD.W	D2,#+3	SWAP.W	D2	LOAD.W	D2,#-8	LOAD.W	D1,#15	CALL	SOURIS8MEL	; mlange le puzzle ...	LOAD.L	A2,(A6)+OPZCHA+(4*3)	LOAD.W	D2,#+4	SWAP.W	D2	LOAD.W	D2,#+9	LOAD.W	D1,#17	CALL	SOURIS8MEL	; mlange le puzzle ...	CALL	_DRAWOPENCOPY	; dessine en mmoire	CALL	_TXBULLEH	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	CALL	SOURIS8ACTION	; action ...	COMP.L	D4,#50*8	JUMP',LO SUITE$	LOAD.L	A3,#R16"TEXT2$	DEC.W	D0	JUMP,NE ENCORE$SUITE$:	CALL	_DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT3$	CALL	_TXBULLEH	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*2	CLR.B	(A6)+OCTRLG	CALL	_CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMAPUZZLE1	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAPUZZLE2	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAPUZZLE3	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAPUZZLE4	CALL	_IMAGECODE	; libre l'image 	POPM.L	D0,D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"<AFBOLD>Tirez<AFROMAN> les pices pour les remettre en place ...<CR>"	.B	0TEXT2$:	.ASCII	"Juste, mais trop lent: recommencez ...<CR>"	.B	0TEXT3$:	.ASCII	"Voil, c'est trs bien !<CR>"	.B	0	.EVEN;------------\\; SOURIS8DRAW >;============/; Dessine le puzzle initial.; in	-; out	-; mod	D7.WSOURIS8DRAW:	PUSHM.L	D2..D4,A2	CLR.L	D3	CLR.L	D4	CALL	_INVTRAME	LIB	?DRMDEF	LOAD.L	D3,#H'10000*(136)+(192)	LOAD.L	D4,#H'10000*64+128	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	LOAD.W	D2,#SETDOT	CALL	_INVMODE	LIB	?DRRECT	LOAD.L	D3,#H'10000*(136)+(192+128)	LOAD.L	D4,#H'10000*64+128	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	LOAD.W	D2,#SETDOT	CALL	_INVMODE	LIB	?DRRECT	LOAD.L	D3,#H'10000*(136+64)+(192)	LOAD.L	D4,#H'10000*64+128	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	LOAD.W	D2,#SETDOT	CALL	_INVMODE	LIB	?DRRECT	LOAD.L	D3,#H'10000*(136+64)+(192+128)	LOAD.L	D4,#H'10000*64+128	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	LOAD.W	D2,#SETDOT	CALL	_INVMODE	LIB	?DRRECT	LOAD.L	D4,#H'10000*(136)+(192)	LOAD.W	D3,#IMAPUZZLE1	CALL	_MOVEOPEN	CALL	_MOVEDRAW	LOAD.L	(A6)+OPZCHA+(4*0),A2	LOAD.L	D4,#H'10000*(136)+(192+128)	LOAD.W	D3,#IMAPUZZLE2	CALL	_MOVEOPEN	CALL	_MOVEDRAW	LOAD.L	(A6)+OPZCHA+(4*1),A2	LOAD.L	D4,#H'10000*(136+64)+(192)	LOAD.W	D3,#IMAPUZZLE3	CALL	_MOVEOPEN	CALL	_MOVEDRAW	LOAD.L	(A6)+OPZCHA+(4*2),A2	LOAD.L	D4,#H'10000*(136+64)+(192+128)	LOAD.W	D3,#IMAPUZZLE4	CALL	_MOVEOPEN	CALL	_MOVEDRAW	LOAD.L	(A6)+OPZCHA+(4*3),A2	POPM.L	D2..D4,A2	RET;-----------\\; SOURIS8MEL >;===========/; Mlange une pice.; in	A2.L	canal de la pice;	D2.L	dplacement (dy;dx);	D1.W	nb de pas (1..n); out	-; mod	D7.WSOURIS8MEL:	PUSHM.L	D1..D4LOOP$:	LOAD.L	D4,(A2)+OMIPOS	ADD.W	D4,D2	SWAP.W	D2	SWAP.W	D4	ADD.W	D4,D2	SWAP.W	D2	SWAP.W	D4	LOAD.W	D3,#-1	CALL	_MOVEDRAW	LOAD.W	D4,#1	NTREL	?DELMS	DEC.W	D1	JUMP,NE LOOP$	POPM.L	D1..D4	RET;--------------\\; SOURIS8ACTION >;==============/; Action dans le puzzle.; in	-; out	D4.L	temps utilis; mod	D4.L, D7.WSOURIS8ACTION:	PUSHM.L	D0..D3,D5,A2	CALL	_CLRFIFO	; vide le fifo du clavier	CALL	_SCMO		; remet la souris	CLR.L	D5LOOP$:	LOAD.L	A2,(A6)+OPZCHA+(4*0)	CALL	SOURIS8TERM	; pice bien place ?	JUMP',NE WAIT$	LOAD.L	A2,(A6)+OPZCHA+(4*1)	CALL	SOURIS8TERM	; pice bien place ?	JUMP',NE WAIT$	LOAD.L	A2,(A6)+OPZCHA+(4*2)	CALL	SOURIS8TERM	; pice bien place ?	JUMP',NE WAIT$	LOAD.L	A2,(A6)+OPZCHA+(4*3)	CALL	SOURIS8TERM	; pice bien place ?	JUMP,EQ END$WAIT$:	LIB	?GETCAR		; attend souris/clavier ...	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	CLR.L	D4	COMP.W	D3,#CR	JUMP,EQ EXIT$	COMP.W	D3,#SPACE	JUMP,EQ EXIT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	TEST.L	D5	JUMP',NE NOFIRST$	LOAD.L	D5,(A6)+OTIME	; D5 <-- temps du premier point visNOFIRST$:	LOAD.L	A2,(A6)+OPZCHA+(4*0)	LOAD.L	D0,#H'10000*(0)+(0)	LOAD.L	D1,#H'10000*(136)+(192)	CALL	SOURIS8MOVE	; dplace une pice ...	JUMP',EQ MOVE$	LOAD.L	A2,(A6)+OPZCHA+(4*1)	LOAD.L	D0,#H'10000*(0)+(192+128)	LOAD.L	D1,#H'10000*(136)+(LXWDO-128)	CALL	SOURIS8MOVE	; dplace une pice ...	JUMP',EQ MOVE$	LOAD.L	A2,(A6)+OPZCHA+(4*2)	LOAD.L	D0,#H'10000*(136+64)+(0)	LOAD.L	D1,#H'10000*(LYWDO-64)+(192)	CALL	SOURIS8MOVE	; dplace une pice ...	JUMP',EQ MOVE$	LOAD.L	A2,(A6)+OPZCHA+(4*3)	LOAD.L	D0,#H'10000*(136+64)+(192+128)	LOAD.L	D1,#H'10000*(LYWDO-64)+(LXWDO-128)	CALL	SOURIS8MOVE	; dplace une pice ...	JUMP,NE BIP$MOVE$:	CALL	SOURIS8TERM	; pice bien place ?	JUMP',NE FAUX$	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	CALL	SOURIS8END	; place parfaitement la pice	JUMP	LOOP$FAUX$:	LOAD.W	(A6)+OSOUND,#TMUSFAUX	JUMP	LOOP$END$:	LOAD.L	D4,(A6)+OTIME	SUB.L	D4,D5		; D4 <-- temps utilisEXIT$:	CALL	_CCMO		; enlve la souris	LOAD.L	A2,(A6)+OPZCHA+(4*0)	CALL	_MOVECLOSE	LOAD.L	A2,(A6)+OPZCHA+(4*1)	CALL	_MOVECLOSE	LOAD.L	A2,(A6)+OPZCHA+(4*2)	CALL	_MOVECLOSE	LOAD.L	A2,(A6)+OPZCHA+(4*3)	CALL	_MOVECLOSE	POPM.L	D0..D3,D5,A2	RET;------------\\; SOURIS8MOVE >;============/; Dplace une pice.; in	A2.L	canal de la pice;	D0.L	minimum (y;x);	D1.L	maximum (y;x); out	D7.W	erreur; mod	D7.WSOURIS8MOVE:	PUSHM.L	D2..D4	CALL	_IFMOUSE	JUMP,NE EXIT$	LOAD.W	D7,#1	SUB.W	D4,(A2)+OMIPOS+2	JUMP',LO EXIT$	COMP.W	D4,#128	JUMP',HS EXIT$	SWAP.W	D4	SUB.W	D4,(A2)+OMIPOS+0	JUMP',LO EXIT$	COMP.W	D4,#64	JUMP',HS EXIT$	SWAP.W	D4	LOAD.L	D2,D4LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP,NE END$	CALL	_IFMOUSE	JUMP,NE LOOP$	SUB.W	D4,D2	SWAP.W	D2	SWAP.W	D4	SUB.W	D4,D2	SWAP.W	D2	SWAP.W	D4	COMP.W	D4,D0	JUMP',GE MINX$	LOAD.W	D4,D0MINX$:	COMP.W	D4,D1	JUMP',LE MAXX$	LOAD.W	D4,D1MAXX$:	SWAP.W	D0	SWAP.W	D1	SWAP.W	D4	COMP.W	D4,D0	JUMP',GE MINY$	LOAD.W	D4,D0MINY$:	COMP.W	D4,D1	JUMP',LE MAXY$	LOAD.W	D4,D1MAXY$:	SWAP.W	D0	SWAP.W	D1	SWAP.W	D4	CALL	_CCMO		; enlve la souris	LOAD.W	D3,#-1	CALL	_MOVEDRAW	; dplace la pice	CALL	_SCMO		; remet la souris	JUMP	LOOP$END$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; SOURIS8TERM >;============/; Regarde si une pice est bien place.; in	A2.L	canal de la pice; out	D7.W	erreur; mod	D7.WSOURIS8TERM:	PUSH.L	D4	LOAD.L	D4,#H'10000*(136)+(192)	COMP.W	(A2)+OMIIMA,#IMAPUZZLE1	JUMP',EQ COMP$	LOAD.L	D4,#H'10000*(136)+(192+128)	COMP.W	(A2)+OMIIMA,#IMAPUZZLE2	JUMP',EQ COMP$	LOAD.L	D4,#H'10000*(136+64)+(192)	COMP.W	(A2)+OMIIMA,#IMAPUZZLE3	JUMP',EQ COMP$	LOAD.L	D4,#H'10000*(136+64)+(192+128)COMP$:	LOAD.W	D7,#1	SUB.W	D4,#5	COMP.W	D4,(A2)+OMIPOS+2	JUMP',HS EXIT$	ADD.W	D4,#5+5	COMP.W	D4,(A2)+OMIPOS+2	JUMP',LO EXIT$	SWAP.W	D4	SUB.W	D4,#5	COMP.W	D4,(A2)+OMIPOS+0	JUMP',HS EXIT$	ADD.W	D4,#5+5	COMP.W	D4,(A2)+OMIPOS+0	JUMP',LO EXIT$	CLR.W	D7EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; SOURIS8END >;===========/; Place parfaitement une pice.; in	A2.L	canal de la pice; out	D7.W	erreur; mod	D7.WSOURIS8END:	PUSHM.L	D3,D4	LOAD.L	D4,#H'10000*(136)+(192)	COMP.W	(A2)+OMIIMA,#IMAPUZZLE1	JUMP',EQ MOVE$	LOAD.L	D4,#H'10000*(136)+(192+128)	COMP.W	(A2)+OMIIMA,#IMAPUZZLE2	JUMP',EQ MOVE$	LOAD.L	D4,#H'10000*(136+64)+(192)	COMP.W	(A2)+OMIIMA,#IMAPUZZLE3	JUMP',EQ MOVE$	LOAD.L	D4,#H'10000*(136+64)+(192+128)MOVE$:	CALL	_CCMO		; enlve la souris	LOAD.W	D3,#-1	CALL	_MOVEDRAW	; met la pice en place	CALL	_SCMO		; remet la souris	POPM.L	D3,D4	RET;--------\\; SOURIS9 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS9:	PUSHM.L	D1,D2,D4,A3,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGVERTI	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLEL	; dessine le texte	CALL	_CTRLDRAW	; dessine le contrle	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A4,#R16"TAMFLDOWN	CALL	_MOVEALL	; animation ...	COMP.W	D3,#END		; arrt d'urgence ?	JUMP,EQ END$		; oui => END$	CALL	_DRAWOPENCOPY	; dessine en mmoire	LOAD.W	D1,#IMAICONE4	LOAD.L	D2,#H'10000*130+227	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine la signification	CALL	_DRAWCLOSE	; montre le dessin en mmoireWAIT$:	LOAD.W	D4,#-(50*10)	CLR.B	(A6)+OBEGIN	; permet le contrle	CLR.B	(A6)+OCTRLG	CALL	_CTRLEVENT	; attend un vnement ...	COMP.W	D3,#CR	JUMP',EQ END$	LOAD.W	(A6)+OSOUND,#TMUSFAUX	JUMP	WAIT$END$:	LOAD.W	D1,#IMAFLDOWN	CALL	_IMAGECODE	; libre l'image 	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"Les <AFBOLD>quatre icnes<AFROMAN> en bas  droite vous<CR>"	.ASCII	"permettent d'agir sur le droulement des<CR>"	.ASCII	"exercices, avec des clics de la souris ...<CR>"	.B	0	.EVEN;---------\\; SOURIS10 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS10:	PUSHM.L	D1,D2,D4,A3,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGVERTI	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPP3	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D1,#IMAFLDOWN	LOAD.L	D2,#H'10000*206+549	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLE	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoireWAIT$:	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^0!2^1!2^2	CALL	_CTRLEVENT	; attend un vnement ...	COMP.W	D3,#CR	JUMP',EQ END$	LOAD.W	(A6)+OSOUND,#TMUSFAUX	JUMP	WAIT$END$:	LOAD.W	D1,#IMAFLDOWN	CALL	_IMAGECODE	; libre l'image 	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"A partir de maintenant,<CR>"	.ASCII	"vous devrez <AFBOLD>cliquer<CR>"	.ASCII	"l'icne de droite<AFROMAN> pour<CR>"	.ASCII	"passer  l'exercice<CR>"	.ASCII	"suivant ...<CR>"	.B	0	.EVEN;---------\\; SOURIS11 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS11:	PUSHM.L	D0,D1,D2,D4,A3,A4	CALL	SOURIS11DEMO	; dmo automatique ...	LOAD.L	A3,#R16"TEXT1$	LOAD.W	D1,#IMABLUPQ1	LOAD.W	D0,#2ENCORE$:	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY+H'FC	CALL	_DRFONDD	; dessine le fond	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D1,#IMAVOUS1	LOAD.L	D2,#H'10000*100+24	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine vous/smaky	CALL	_TXBULLEL	; dessine le texte	LOAD.L	A4,#R16"TAPOAOBJ$:	LOAD.W	D1,#IMAOBJET2	LOAD.L	D2,(A4+)	CLR.L	D3	LOAD.W	D3,(A4+)	LOAD.L	D4,#H'10000*28+32	CALL	_IMAGEAFFF	; dessine oiseau/araigne	TEST.L	(A4)	JUMP,NE OBJ$	CALL	_DRAWCLOSE	; montre le dessin en mmoire	CALL	SOURIS11ACTION	; action ...	COMP.L	D4,#50*6	JUMP',LO SUITE$	LOAD.L	A3,#R16"TEXT2$	LOAD.W	D1,#IMABLUPQ2	DEC.W	D0	JUMP,NE ENCORE$SUITE$:	CALL	_DRAWOPENCOPY	; dessine en mmoire	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT3$	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*4	CLR.B	(A6)+OCTRLG	CALL	_CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMAVOUS0	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAVOUS1	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAOBJET2	CALL	_IMAGECODE	; libre l'image 	POPM.L	D0,D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/A vous maintenant de <AFBOLD>"tirez" un rectangle<AFROMAN> avec<CR>/	.ASCII	/le bouton de <AFBOLD>droite<AFROMAN>, qui englobe tous les oiseaux,<CR>/	.ASCII	/sans toucher aux araignes ...<CR>/	.B	0TEXT2$:	.ASCII	/Juste mais trop lent ! Recommencez de "tirer" un rec-<CR>/	.ASCII	/tangle avec le bouton de droite, qui englobe tous<CR>/	.ASCII	/les oiseaux, sans toucher aux araignes ...<CR>/	.B	0TEXT3$:	.ASCII	/Bravo, vous avez correctement<CR>/	.ASCII	/<AFBOLD>"slectionn"<AFROMAN> tous les oiseaux !<CR>/	.B	0	.EVEN;-------------\\; SOURIS11DEMO >;=============/; Dmonstration automatique.; in	-; out	-; mod	D7.WSOURIS11DEMO:	PUSHM.L	D1..D4,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY+H'FC	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D1,#IMAVOUS0	LOAD.L	D2,#H'10000*100+24	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine vous/smaky	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLEL	; dessine le texte	LOAD.L	A4,#R16"TAPOAOBJ$:	LOAD.W	D1,#IMAOBJET2	LOAD.L	D2,(A4+)	CLR.L	D3	LOAD.W	D3,(A4+)	LOAD.L	D4,#H'10000*28+32	CALL	_IMAGEAFFF	; dessine oiseau/araigne	TEST.L	(A4)	JUMP,NE OBJ$	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*2	NTREL	?DELMS	LOAD.L	A4,#R16"TADEMO$	CALL	_MODEMOSTART	CALL	SOURIS11ACTION	; action ...	CALL	_MODEMOSTOP	LOAD.W	D4,#50*2	NTREL	?DELMS	LOAD.L	D4,#H'10000*236+438	CALL	_PMOUSE		; met la souris au milieu !	LIB	?BUZZ	POPM.L	D1..D4,A4	RETTADEMO$:	.W	176,308-(60*4)	.W	60	0,+4	.W	5	0,0	.W	-1	KEYMDP	.W	15	0,0	.W	60	+2,+4	.W	4	0,+5	.W	5	0,0	.W	-1	KEYMDR	.W	5	0,0	.W	0TEXT1$:	.ASCII	/Pour <AFBOLD>"slectionner"<AFROMAN> les oiseaux, il faut les entourer<CR>/	.ASCII	/d'un rectangle. <AFBOLD>Observez<AFROMAN> la manoeuvre :<CR>/	.B	0	.EVENTAPOA:	.W	176,249,32	; araignes	.W	133,319,32	.W	144,425,32	.W	118,515,32	.W	164,594,32	.W	258,580,32	.W	268,268,32	.W	303,357,32	.W	227,316,0	; oiseaux	.W	184,385,0	.W	199,467,0	.W	213,530,0	.W	262,417,0	.L	0;---------------\\; SOURIS11ACTION >;===============/; Entoure les oiseaux.; in	-; out	D4.L	temps utilis; mod	D4.L, D7.WSOURIS11ACTION:	PUSHM.L	D0..D3,D5	CALL	_CLRFIFO	; vide le fifo du clavier	CALL	_SCMO		; remet la souris	CLR.L	D5LOOP$:	LIB	?GETCAR		; attend souris/clavier ...	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$;;?	COMP.W	D3,#KEYMGP;;?	JUMP',EQ CLIC$;;?	COMP.W	D3,#KEYMMP;;?	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	CLR.L	D4	COMP.W	D3,#CR	JUMP,EQ EXIT$	COMP.W	D3,#SPACE	JUMP,EQ EXIT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	TEST.L	D5	JUMP',NE NOFIRST$	LOAD.L	D5,(A6)+OTIME	; D5 <-- temps du premier point visNOFIRST$:	CALL	_IFMOUSE	JUMP,NE BIP$	LOAD.L	D0,D4		; D0 <-- dpart	LOAD.L	D1,D4		; D1 <-- arriveMLOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE MEND$	CALL	_IFMOUSE	JUMP,NE MLOOP$	PUSH.L	D4	LOAD.L	D3,D0	LOAD.L	D4,D1	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRRECT		; efface l'ancien	POP.L	D4	LOAD.L	D1,D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRRECT		; dessine le nouveau	JUMP	MLOOP$MEND$:	LOAD.W	D3,D0	LOAD.W	D4,D1	COMP.W	D3,D4	JUMP',LS OKX$	EX.L	D3,D4OKX$:	COMP.W	D3,#301	JUMP',LO FAUX$	COMP.W	D3,#317	JUMP',HS FAUX$	COMP.W	D4,#560	JUMP',LO FAUX$	COMP.W	D4,#579	JUMP',HS FAUX$	LOAD.L	D3,D0	LOAD.L	D4,D1	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',LS OKY$	EX.L	D3,D4OKY$:	COMP.W	D3,#170	JUMP',LO FAUX$	COMP.W	D3,#186	JUMP',HS FAUX$	COMP.W	D4,#289	JUMP',LO FAUX$	COMP.W	D4,#307	JUMP',HS FAUX$	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	JUMP'	END$FAUX$:	LOAD.W	(A6)+OSOUND,#TMUSFAUX	LOAD.L	D3,D0	LOAD.L	D4,D1	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRRECT		; efface le rectangle faux	LOAD.W	D1,#IMABLUPQ2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	JUMP	LOOP$END$:	LOAD.L	D4,(A6)+OTIME	SUB.L	D4,D5		; D4 <-- temps utilisEXIT$:	CALL	_CCMO		; enlve la souris	POPM.L	D0..D3,D5	RET;---------\\; SOURIS12 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS12:	PUSHM.L	D1,D2,D4,A3,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGMIDDLEH+H'03	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D1,#IMASCROLL	LOAD.L	D2,#H'10000*142+277	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine un ascenseur	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*8	LOAD.B	(A6)+OCTRLG,#2^1	CALL	_CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMASCROLL	CALL	_IMAGECODE	; libre l'image 	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Les <AFBOLD>"ascenseurs"<AFROMAN> permettent de choisir la partie<CR>/	.ASCII	/visible d'un texte ou d'une image, lorsque l'cran<CR>/	.ASCII	/est trop petit.<CR>/	.B	0	.EVEN;---------\\; SOURIS13 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS13:	PUSHM.L	D1,D2,D4,A3,A4	CALL	SOURIS13DEMO	; dmo automatique ...	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGMIDDLEH+H'03	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D1,#IMAVOUS1	LOAD.L	D2,#H'10000*100+24	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine vous/smaky	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLEL	; dessine le texte	CALL	SOURIS13DRAW	; dessine l'ascenseur avec le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#42	CALL	SOURIS13MOVE	; dplace l'ascenseur ...	TEST.L	D4	JUMP',EQ END$	CALL	_DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT2$	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#2	CALL	SOURIS13MOVE	; dplace l'ascenseur ...	TEST.L	D4	JUMP',EQ END$	CALL	_DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT3$	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#18	CALL	SOURIS13MOVE	; dplace l'ascenseur ...END$:	CALL	_DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT4$	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LIB	?AFTIM	.B	MMODULO,1	; plus de modulos ( cause de SCROLL_LMOVE !)	.B	0	.EVEN	LOAD.W	D4,#50*8	CLR.B	(A6)+OCTRLG	CALL	_CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMAVOUS0	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAVOUS1	CALL	_IMAGECODE	; libre l'image 	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/A vous maintenant :<CR>/	.ASCII	/Dplacez l'ascenseur, pour atteindre les mots<CR>/	.ASCII	/<AFINV>"elle agit sur nous"<AFDIR>, situs  la fin du texte ...<CR>/	.B	0TEXT2$:	.ASCII	/Juste ! Dplacez maintenant l'ascenseur sur les<CR>/	.ASCII	/mots <AFINV>"Communiquer, voil un des"<AFDIR>, presque tout<CR>/	.ASCII	/au dbut du texte ...<CR>/	.B	0TEXT3$:	.ASCII	/Trs bien. Cherchez maintenant les mots<CR>/	.ASCII	/<AFINV>"Dans le langage parl ou"<AFDIR>, au dbut du<CR>/	.ASCII	/troisime paragraphe ...<CR>/	.B	0TEXT4$:	.ASCII	"Bravo, vous avez bien compris le<CR>"	.ASCII	"fonctionnement des ascenseurs !<CR>"	.B	0	.EVEN;-------------\\; SOURIS13DEMO >;=============/; Dmonstration automatique.; in	-; out	-; mod	D7.WSOURIS13DEMO:	PUSHM.L	D1..D4,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGMIDDLEH+H'03	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D1,#IMAVOUS0	LOAD.L	D2,#H'10000*100+24	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine vous/smaky	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLEL	; dessine le texte	CALL	SOURIS13DRAW	; dessine l'ascenseur avec le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*2	NTREL	?DELMS	LOAD.L	A4,#R16"TADEMO$	CALL	_MODEMOSTART	LOAD.W	D4,#42	CALL	SOURIS13MOVE	; dplace l'ascenseur ...	CALL	_MODEMOSTOP	LOAD.W	D4,#50*2	NTREL	?DELMS	LOAD.L	D4,#H'10000*(263-50)+(277-50)	CALL	_PMOUSE		; met la souris au milieu !	LIB	?BUZZ	POPM.L	D1..D4,A4	RETTADEMO$:	.W	263-(30*4),277-(30*4)	.W	30	+4,+4	; va dans la flche en bas	.W	30	0,0	.W	-1	KEYMGP	.W	40	0,0	.W	-1	KEYMGR	.W	30	0,0	.W	38	-3,0	; remonte dans la flche en haut	.W	30	0,0	.W	-1	KEYMGP	.W	40+2	0,0	.W	-1	KEYMGR	.W	30	0,0	.W	16	+2,+5	.W	20	0,0	.W	-1	KEYMGP	.W	20	0,0	.W	24	+2,0	.W	10	0,0	.W	-1	KEYMGR	.W	30	0,0	.W	16	-4,-5	; remonte sous la flche en haut	.W	30	0,0	.W	-1	KEYMGP	.W	20	0,0	.W	16	+2,0	.W	20	0,0	.W	-1	KEYMGR	.W	30	0,0	.W	-1	KEYMGP	.W	30	0,0	.W	25	+2,0	.W	20	0,0	.W	-1	KEYMGR	.W	30	0,0	.W	0TEXT1$:	.ASCII	/<AFBOLD>Observer<AFROMAN> l'utilisation de l'ascenseur ci-dessous :<CR>/	.B	0	.EVEN;-------------\\; SOURIS13DRAW >;=============/; Dessine l'ascenseur.; in	-; out	-; mod	D7.WSOURIS13DRAW:	PUSHM.L	A4,A5	LOAD.L	A5,#(A6)+OSLVAR	LOAD.L	(A5)+OSLPOS,#H'10000*142+272	LOAD.L	(A5)+OSLDIM,#H'10000*((16*8)+1)+((31*8)+1)	SCROLL_	LDRAW	LOAD.L	A4,#R16"SOURIS13GETTX	LOAD.L	(A5)+OSLADL,A4	LOAD.W	(A5)+OSLCYN,#43	CLR.W	(A5)+OSLCYS	SCROLL_	LUPDATE	POPM.L	A4,A5	RET;-------------\\; SOURIS13MOVE >;=============/; Dplace l'ascenseur.; in	D4.W	case  slectionner (0..n); out	D4.L	temps utilis; mod	D4.L, D7.WSOURIS13MOVE:	PUSHM.L	D2,D3,D5,A5	LOAD.W	D2,D4	CALL	_CLRFIFO	; vide le fifo du clavier	CALL	_SCMO		; remet la souris	CLR.L	D5LOOP$:	LIB	?GETCAR		; attend souris/clavier ...	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	CLR.L	D4	COMP.W	D3,#CR	JUMP,EQ EXIT$	COMP.W	D3,#SPACE	JUMP,EQ EXIT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	TEST.L	D5	JUMP',NE NOFIRST$	LOAD.L	D5,(A6)+OTIME	; D5 <-- temps du premier point visNOFIRST$:	CALL	_IFMOUSE	JUMP,NE BIP$	LOAD.L	A5,#(A6)+OSLVAR	SCROLL_	LMOVE	JUMP,NE BIP$	COMP.W	D2,(A5)+OSLCYS	JUMP,NE LOOP$	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	LOAD.L	D4,(A6)+OTIME	SUB.L	D4,D5		; D4 <-- temps utilisEXIT$:	CALL	_CCMO		; enlve la souris	POPM.L	D2,D3,D5,A5	RET;--------------\\; SOURIS13GETTX >;--------------/; Routine appele par SCROLL_LUPDATE.; in	D3.W	rang ligne; out	A3.L	^ligne;	D3.W	zro; mod	D3.L, D7.W, A3.LSOURIS13GETTX:	PUSHM.L	D4,A5	COMP.B	(A6)+OMACHINE,#SMAKY100	JUMP',EQ QUICK$	LOAD.L	A5,#(A6)+OSLVAR	LOAD.W	D4,(A5)+OSLCYA	COMP.W	D3,D4		; premire ligne affiche ?	JUMP',EQ DEL$	ADD.W	D4,(A5)+OSLNBY	DEC.W	D4	COMP.W	D3,D4		; dernire ligne affiche ?	JUMP',NE QUICK$		; non => QUICK$DEL$:	LOAD.W	D4,#4	NTREL	?DELMS		; freine l'ascenseur ...QUICK$:	LOAD.L	A3,#R16"TEXT$	MUL.WU	D3,#28	ADD.L	A3,D3	POPM.L	D4,A5	CLR.W	D3	CLR.W	D7	RETTEXT$:	.ASCIZ	/Le langage musical         /	.ASCIZ	/                           /	.ASCIZ	/Communiquer, voil un des  /	.ASCIZ	/besoins les plus profonds  /	.ASCIZ	/de l'homme.                /	.ASCIZ	/Le mouvement du danseur,   /	.ASCIZ	/le babil ou le chant de    /	.ASCIZ	/l'enfant, les paroles de la/	.ASCIZ	/mre, une page de Bach, le /	.ASCIZ	/geste du chef d'orchestre, /	.ASCIZ	/un pome de Victor Hugo,   /	.ASCIZ	/l'improvisation d'un trom- /	.ASCIZ	/pettiste noir, toujours    /	.ASCIZ	/l'intention de reste la    /	.ASCIZ	/mme: communiquer, dire   /	.ASCIZ	/autrui ce que l'on ressent,/	.ASCIZ	/ce que l'on croit, ce que  /	.ASCIZ	/l'on veut.                 /	.ASCIZ	/Dans le langage parl ou   /	.ASCIZ	/crit, - notre principal   /	.ASCIZ	/moyen de communication -   /	.ASCIZ	/les mots ont un sens fix  /	.ASCIZ	/par l'usage, et la cons-   /	.ASCIZ	/truction des phrases obit /	.ASCIZ	/ certaines rgles. Si je  /	.ASCIZ	/dis "comme le ciel est bleu/	.ASCIZ	/aujourd'hui" ou "Je t'offre/	.ASCIZ	/ce livre", ces phrases ont /	.ASCIZ	/un sens prcis pour mon    /	.ASCIZ	/interlocuteur.             /	.ASCIZ	/La musique ne peut tre    /	.ASCIZ	/traduite par des paroles;  /	.ASCIZ	/elle n'voque pas un lieu  /	.ASCIZ	/prcis, ni une action par- /	.ASCIZ	/ticulire, ni un personnage/	.ASCIZ	/connu. Si l'on nous posait /	.ASCIZ	/une question  propos d'une/	.ASCIZ	/pice musicale, chacun     /	.ASCIZ	/donnerait une rponse dif- /	.ASCIZ	/frente. Et pourtant - nous/	.ASCIZ	/le ressentons -, la musique/	.ASCIZ	/nous dit quelque chose,    /	.ASCIZ	/elle agit sur nous.        /	.EVEN;---------\\; SOURIS14 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS14:	PUSHM.L	D0,D1,D2,D4,A3,A4	LOAD.L	A3,#R16"TEXT1$	LOAD.W	D1,#IMABLUPQ1	LOAD.W	D0,#2ENCORE$:	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ!2^BFGINVY	CALL	_DRFONDD	; dessine le fond	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D1,#IMAVOUS1	LOAD.L	D2,#H'10000*100+24	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine vous/smaky	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A3,#R16"TMENU1	CALL	SOURIS14ACTION	; choix selon mmenu ...	TEST.L	D4	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TEXT3$	TEST.W	(A4)+(LMM*0)+OMMSEL	JUMP',EQ FAUX$	LOAD.L	A3,#R16"TEXT2$	COMP.W	(A4)+(LMM*0)+OMMSEL,#7	JUMP',NE FAUX$	COMP.L	D4,#50*2	JUMP',LO JUSTE$	LOAD.L	A3,#R16"TEXT4$FAUX$:	LOAD.W	(A6)+OSOUND,#TMUSFAUX	LOAD.W	D1,#IMABLUPQ2	DEC.W	D0	JUMP,NE ENCORE$JUSTE$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D4,#50/2	NTREL	?DELMSEXIT$:	LOAD.W	D3,#CR	LOAD.W	D1,#IMAVOUS0	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAVOUS1	CALL	_IMAGECODE	; libre l'image 	POPM.L	D0,D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/En appuyant sur le bouton de droite, un <AFBOLD>"menu"<AFROMAN><CR>/	.ASCII	/apparatra. Descendez alors tout en bas, dans la<CR>/	.ASCII	/case <AFINV>"suite"<AFDIR>, puis relchez le bouton ...<CR>/	.B	0TEXT2$:	.ASCII	/Vous avez relch le bouton de droite alors<CR>/	.ASCII	/que la souris n'tait pas dans la case <AFINV>"suite"<AFDIR> !<CR>/	.ASCII	/Essayez encore ...<CR>/	.B	0TEXT3$:	.ASCII	/Il faut <AFBOLD>maintenir press<AFROMAN> le bouton de la souris !<CR>/	.ASCII	/Essayez encore d'atteindre <AFINV>"suite"<AFDIR>, en maintenant<CR>/	.ASCII	/press le bouton de droite ...<CR>/	.B	0TEXT4$:	.ASCII	/C'est juste, mais vous n'avez pas excut le<CR>/	.ASCII	/mouvement suffisamment vite !<CR>/	.ASCII	/Recommencez ...<CR>/	.B	0	.EVEN;---------------\\; SOURIS14ACTION >;===============/; Choix dans un mmenus.; in	A3.L	^mmenu; out	A4.L	^paramtres;	D4.L	temps utilis; mod	D4.L, D7.W, A4.LSOURIS14ACTION:	PUSHM.L	D2,D3,D5	CALL	_CLRFIFO	; vide le fifo du clavier	CALL	_SCMO		; remet la souris	CLR.L	D5	LOAD.L	A4,#(A6)+OMMPAR	CLR.W	(A4)+(LMM*0)+OMMSELLOOP$:	LIB	?GETCAR		; attend souris/clavier ...	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$;	COMP.W	D3,#KEYMGP;	JUMP',EQ CLIC$;	COMP.W	D3,#KEYMMP;	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	CLR.L	D4	COMP.W	D3,#CR	JUMP,EQ EXIT$	COMP.W	D3,#SPACE	JUMP,EQ EXIT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	TEST.L	D5	JUMP',NE NOFIRST$	LOAD.L	D5,(A6)+OTIME	; D5 <-- temps du premier point visNOFIRST$:	CALL	_IFMOUSE	JUMP,NE BIP$	PUSH.L	D5	CLR.L	D5	LIB	?MMENUS		; choix selon mmenu ...	POP.L	D5	LOAD.L	D4,(A6)+OTIME	SUB.L	D4,D5		; D4 <-- temps utilis	JUMP',NE EXIT$	INC.L	D4		; D4 <-- jamais zro !EXIT$:	CALL	_CCMO		; enlve la souris	POPM.L	D2,D3,D5	RET;---------\\; SOURIS15 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS15:	PUSHM.L	D0,D1,D2,D4,A3,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ!2^BFGINVY	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D1,#IMAVOUS0	LOAD.L	D2,#H'10000*100+24	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine vous/smaky	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*3	NTREL	?DELMS	CALL	SOURIS15EX	; montre un exemple ...	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ!2^BFGINVY	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D1,#IMAVOUS1	LOAD.L	D2,#H'10000*100+24	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine vous/smaky	LOAD.L	A3,#R16"TEXT2$	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoireENCORE$:	LOAD.L	D4,#H'10000*(95+11)+(274+76)	CALL	_PMOUSE	LOAD.L	A3,#R16"TMENU2	CALL	SOURIS14ACTION	; choix selon mmenu ...	TEST.L	D4	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TEXT4$	TEST.W	(A4)+(LMM*0)+OMMSEL	JUMP',EQ FAUX$	LOAD.L	A3,#R16"TEXT3$	COMP.W	(A4)+(LMM*0)+OMMSEL,#4	JUMP',NE FAUX$	COMP.W	(A4)+(LMM*1)+OMMSEL,#4	JUMP',NE FAUX$	COMP.L	D4,#50*4	JUMP',LO JUSTE$	LOAD.L	A3,#R16"TEXT5$FAUX$:	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	_DRAWOPENCOPY	; dessine en mmoire	LOAD.W	D1,#IMABLUPP2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	JUMP	ENCORE$JUSTE$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D4,#50/2	NTREL	?DELMSEXIT$:	LOAD.W	D3,#CR	LOAD.W	D1,#IMAMMENUH1	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAMMENUH2	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAVOUS0	CALL	_IMAGECODE	; libre l'image 	LOAD.W	D1,#IMAVOUS1	CALL	_IMAGECODE	; libre l'image 	POPM.L	D0,D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Certains <AFBOLD>"menu"<AFROMAN> proposent des <AFBOLD>"sous-menus"<AFROMAN>.<CR>/	.ASCII	/Observez le mouvement de la souris dans<CR>/	.ASCII	/cet exemple :<CR>/	.B	0TEXT2$:	.ASCII	/A vous maintenant :<CR>/	.ASCII	/En appuyant sur le bouton de droite,<CR>/	.ASCII	/slectionnez <AFINV>"opration"<AFDIR> puis <AFINV>"contour"<AFDIR> ...<CR>/	.B	0TEXT3$:	.ASCII	/Vous n'avez pas slectionn <AFINV>"opration"<AFDIR> puis /	.ASCII	/<AFINV>"contour"<AFDIR> !<CR>/	.ASCII	/<CR>/	.ASCII	/Essayez encore avec le bouton de droite ...<CR>/	.B	0TEXT4$:	.ASCII	/Il faut maintenir press le bouton de la souris !<CR>/	.ASCII	/Essayez encore d'atteindre <AFINV>"opration"<AFDIR> puis /	.ASCII	/<AFINV>"contour"<AFDIR>,<CR>/	.ASCII	/en maintenant press le bouton de droite ...<CR>/	.B	0TEXT5$:	.ASCII	/C'est juste, mais vous n'avez pas slectionn<CR>/	.ASCII	/<AFINV>"opration"<AFDIR> puis <AFINV>"contour"<AFDIR> suffisamment vite !<CR>/	.ASCII	/Recommencez avec le bouton de droite ...<CR>/	.B	0	.EVEN;-----------\\; SOURIS15EX >;===========/; Montre un exemple de mmenu hirarchique.; in	-; out	A4.L	^paramtres; mod	D7.W, A4.LSOURIS15EX:	PUSHM.L	D0..D4,A2	LOAD.W	D1,#IMAMMENUH1	LOAD.L	D2,#H'10000*95+274	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine le mmenu principal	CLR.W	D2	CALL	SOURIS15INV1	; allume la premire case	LOAD.L	D3,#H'10000*(95+11)+(274+76)	CALL	SOURIS15OS	; ouvre le lutin	LOAD.W	D4,#50	NTREL	?DELMS	LOAD.W	D0,#4-1DOWN1$:	LOAD.W	D1,#13-1DOWN2$:	ADD.L	D3,#H'10000*1	CALL	SOURIS15MS	; dplace le lutin	LOAD.W	D4,#2	NTREL	?DELMS	DECJ.W,NMO D1,DOWN2$	CALL	SOURIS15CS	; ferme le lutin	CALL	SOURIS15INV1	; teint la dernire case	INC.W	D2		; D2 <-- case suivante	CALL	SOURIS15INV1	; allume la case suivante	CALL	SOURIS15OS	; ouvre le lutin	LOAD.W	D1,#10-1DOWN3$:	ADD.L	D3,#H'10000*1	CALL	SOURIS15MS	; dplace le lutin	LOAD.W	D4,#2	NTREL	?DELMS	DECJ.W,NMO D1,DOWN3$	DECJ.W,NMO D0,DOWN1$	PUSH.L	D3	LOAD.W	D1,#IMAMMENUH2	LOAD.L	D2,#H'10000*(95+(4*23))+(274+155)	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine le mmenu secondaire	POP.L	D3	LOAD.W	D4,#50/2	NTREL	?DELMS	LOAD.W	D1,#77-1RIGHT2$:	INC.W	D3	CALL	SOURIS15MS	; dplace le lutin	LOAD.W	D4,#2	NTREL	?DELMS	DECJ.W,NMO D1,RIGHT2$	CALL	SOURIS15CS	; ferme le lutin	CLR.W	D2	CALL	SOURIS15INV2	; allume la premire case	CALL	SOURIS15OS	; ouvre le lutin	LOAD.W	D1,#65-1RIGHT3$:	INC.W	D3	CALL	SOURIS15MS	; dplace le lutin	LOAD.W	D4,#2	NTREL	?DELMS	DECJ.W,NMO D1,RIGHT3$	LOAD.W	D0,#4-1DOWN6$:	LOAD.W	D1,#13-1DOWN7$:	ADD.L	D3,#H'10000*1	CALL	SOURIS15MS	; dplace le lutin	LOAD.W	D4,#2	NTREL	?DELMS	DECJ.W,NMO D1,DOWN7$	CALL	SOURIS15CS	; ferme le lutin	CALL	SOURIS15INV2	; teint la dernire case	INC.W	D2		; D2 <-- case suivante	CALL	SOURIS15INV2	; allume la case suivante	CALL	SOURIS15OS	; ouvre le lutin	LOAD.W	D1,#10-1DOWN8$:	ADD.L	D3,#H'10000*1	CALL	SOURIS15MS	; dplace le lutin	LOAD.W	D4,#2	NTREL	?DELMS	DECJ.W,NMO D1,DOWN8$	DECJ.W,NMO D0,DOWN6$	LOAD.W	D4,#20	NTREL	?DELMS	CALL	SOURIS15CS	; ferme le lutin	LOAD.W	D1,#12-1CLIGN1$:	CALL	SOURIS15INV2	; teint la dernire case	LOAD.W	D4,#6	NTREL	?DELMS	CALL	SOURIS15INV2	; allume la dernire case	LOAD.W	D4,#8	NTREL	?DELMS	DECJ.W,NMO D1,CLIGN1$	LOAD.W	D4,#50	NTREL	?DELMS	POPM.L	D0..D4,A2	RET;-------------\\; SOURIS15INV1 >;-------------/; Inverse une case.; in	D2.W	rang (0..n); out	-; mod	D7.WSOURIS15INV1:	PUSHM.L	D2..D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.W	D3,D2	MUL.WU	D3,#23	ADD.W	D3,#95+3	SWAP.W	D3	LOAD.W	D3,#274+3	LOAD.L	D4,#H'10000*22+153	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	POPM.L	D2..D4	RET;-------------\\; SOURIS15INV2 >;-------------/; Inverse une case.; in	D2.W	rang (0..n); out	-; mod	D7.WSOURIS15INV2:	PUSHM.L	D2..D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.W	D3,D2	MUL.WU	D3,#23	ADD.W	D3,#95+(4*23)+3	SWAP.W	D3	LOAD.W	D3,#274+155+3	LOAD.L	D4,#H'10000*22+132	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	POPM.L	D2..D4	RET;-----------\\; SOURIS15OS >;-----------/; Ouverture du lutin.; in	D3.L	position (y;x); out	A2.L	canal; mod	D7.WSOURIS15OS:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,#(A6)+OBKTAB+(LBK*(MAXIMA-1))	LOAD.L	A3,#R16"CODE$	LOAD.L	(A4)+OBKPIC,A3	LOAD.L	A3,#R16"LUTINC$	LOAD.L	(A4)+OBKPID,A3	LOAD.L	A3,#R16"LUTINF$	LOAD.L	(A4)+OBKPIF,A3	LOAD.L	D4,D3	LOAD.W	D3,#MAXIMA-1	CALL	MOVEOPEN	; dbut d'un dplacement	CALL	MOVEDRAW	; dessine le premier	POPM.L	D3,D4,A3,A4	RETCODE$:	.L	H'81040102	; en-tte	.W	16,20		; dx,dyLUTINC$:	.W	B'0000000000000000	.W	B'0100000000000000	.W	B'0110000000000000	.W	B'0111000000000000	.W	B'0111100000000000	.W	B'0111110000000000	.W	B'0111111000000000	.W	B'0111111100000000	.W	B'0111111110000000	.W	B'0111111111000000	.W	B'0111111111100000	.W	B'0111111111110000	.W	B'0111111111111000	.W	B'0111111110000000	.W	B'0111011110000000	.W	B'0110001111000000	.W	B'0100001111000000	.W	B'0000000111100000	.W	B'0000000111000000	.W	B'0000000000000000LUTINF$:	.W	B'1110000000000000	.W	B'1111000000000000	.W	B'1111100000000000	.W	B'1111110000000000	.W	B'1111111000000000	.W	B'1111111100000000	.W	B'1111111110000000	.W	B'1111111111000000	.W	B'1111111111100000	.W	B'1111111111110000	.W	B'1111111111111000	.W	B'1111111111111100	.W	B'1111111111111100	.W	B'1111111111111100	.W	B'1111111111100000	.W	B'1111111111100000	.W	B'1111011111110000	.W	B'1110011111110000	.W	B'0000001111110000	.W	B'0000001111100000;-----------\\; SOURIS15MS >;-----------/; Dplacement du lutin.; in	D3.L	position (y;x);	A2.L	canal; out	-; mod	D7.WSOURIS15MS:	PUSHM.L	D3,D4	LOAD.L	D4,D3	LOAD.W	D3,#MAXIMA-1	CALL	MOVEDRAW	; dplace l'image	POPM.L	D3,D4	RET;-----------\\; SOURIS15CS >;-----------/; Fermeture du lutin.; in	A2.L	canal; out	-; mod	D7.WSOURIS15CS:	CALL	MOVECLEAR	JUMP	MOVECLOSETMENU1:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODETRUIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEPLACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  dplace  "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMOVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODUPLIQUE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  duplique "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMOVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODIVERS	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  opration.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICONEGATIF	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  ngatif"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLOUPE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  loupe"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSUITE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  suite.."	.B	0TMENU2:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODETRUIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEPLACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  dplace  "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMOVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODUPLIQUE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  duplique "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMOVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	-1	.BW	-2,TMENUOP$-TMENU2	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODIVERS	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  opration"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICONEGATIF	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  ngatif"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLOUPE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  loupe"	.B	0TMENUOP$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOZOOM	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  zoom.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOTOURNE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  tourne.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMIROIR	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  miroir.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEFORME	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dforme.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICORELIEF	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  contour.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOTRAME	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  trame.."	.B	0	.EVEN;---------\\; SOURIS16 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS16:	PUSHM.L	D1,D2,D4,A3,A4	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGMIDDLEH	CALL	_DRFONDD	; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.W	D1,#IMASABLIER	LOAD.L	D2,#H'10000*140+280	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine l'explication	LOAD.L	A3,#R16"TEXT1$	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*7	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	_CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMASABLIER	CALL	_IMAGECODE	; libre l'image 	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Lorsque la flche de la souris se transforme<CR>/	.ASCII	/en <AFBOLD>"sablier"<AFROMAN>, il faut attendre ...<CR>/	.B	0	.EVEN;---------\\; SOURIS17 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSOURIS17:	PUSHM.L	D0,D1,D2,D4,A3,A4	LOAD.L	A3,#R16"TEXT1$	LOAD.W	D1,#IMABLUPQ1	LOAD.W	D0,#2ENCORE$:	CALL	_DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGMIDDLEH	CALL	_DRFONDD	; dessine le fond	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	CALL	_TXBULLEL	; dessine le texte	LOAD.L	A3,#R16"SOURIS17POS	LOAD.L	(A6)+OBSQAD,A3	LOAD.L	A3,#R16"TEXTB$	LOAD.L	A4,#0	CALL	BSQDRAW		; dessine les 3 carrs	CALL	_DRAWCLOSE	; montre le dessin en mmoire	CALL	SOURIS17ACTION	; action ...	COMP.L	D4,#50*20	; plus de 20 secondes ?	JUMP',LO SUITE$		; non => SUITE$	LOAD.L	A3,#R16"TEXT2$	LOAD.W	D1,#IMABLUPQ2	DEC.W	D0	JUMP,NE ENCORE$SUITE$:	CALL	_DRAWOPENCOPY	; dessine en mmoire	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT3$	CALL	_TXBULLEL	; dessine le texte	CALL	_DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*2	CLR.B	(A6)+OCTRLG	CALL	_CTRLEVENT	; attend un vnement ...	POPM.L	D0,D1,D2,D4,A3,A4	RETTEXTB$:	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""	.ASCIZ	""TEXT1$:	.ASCII	"Cliquez dans les carrs ci-dessous, sans oublier<CR>"	.ASCII	"d'attendre lorsque le sablier est prsent ...<CR>"	.B	0TEXT2$:	.ASCII	"C'est bien, mais pas assez rapide !<CR>"	.ASCII	"Recommencez encore une fois ...<CR>"	.B	0TEXT3$:	.ASCII	"Oui, c'est termin !<CR>"	.B	0	.EVEN;---------------\\; SOURIS17ACTION >;===============/; Action dans les boutons.; in	-; out	D4.L	temps utilis; mod	D4.L, D7.WSOURIS17ACTION:	PUSHM.L	D0..D3,D5,D6	CALL	_CLRFIFO	; vide le fifo du clavier	CALL	_SCMO		; remet la souris	CLR.W	D0		; D0 <-- boutons cliqus	CLR.L	D5	LOAD.W	D2,#1		; D2 <-- pas de sablier	LOAD.L	D6,(A6)+OTIME	ADD.L	D6,#50*1	; D6 <-- "t" jusqu'o attendreLOOP$:	LIB	?IFCAR		; attend souris/clavier ...	JUMP',NE TIMO$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	CLR.L	D4	COMP.W	D3,#CR	JUMP,EQ EXIT$	COMP.W	D3,#SPACE	JUMP,EQ EXIT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$TIMO$:	COMP.L	D6,(A6)+OTIME	; est-on arriv au temps "t" ?	JUMP,HI LOOP$		; non => LOOP$	TNOT.L	D2:#0		; D2 <-- inverse flche/sablier	LOAD.W	D4,D2	LIB	?WAITMOUSE	; met/enlve le sablier	LOAD.W	D3,#50*1	; D3 <-- 1 secondes minimum	LOAD.W	D4,#50*4	; D4 <-- 4 secondes maximum	CALL	MMHAZARD	CLR.L	D6	LOAD.W	D6,D4	ADD.L	D6,(A6)+OTIME	; D6 <-- nouveau "t" jusqu'o attendre	JUMP	LOOP$CLIC$:	TEST.L	D5	JUMP',NE NOFIRST$	LOAD.L	D5,(A6)+OTIME	; D5 <-- temps du premier point visNOFIRST$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	TEST.L	D2:#0		; sablier prsent ?	JUMP',BC FAUX$		; oui => FAUX$	CALL	BSQMOVE		; D1 <-- rang (0..n)	JUMP,NE BIP$	TSET.L	D0:D1	JUMP,BS BIP$	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	CALL	BSQBIF		; biffe le carr	PUSH.L	D2	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	POP.L	D2	COMP.W	D0,#-1		; tous les carrs biffs ?	JUMP,NE LOOP$		; non => LOOP$	LOAD.L	D4,(A6)+OTIME	SUB.L	D4,D5		; D4 <-- temps utilis	JUMP'	EXIT$FAUX$:	LOAD.W	(A6)+OSOUND,#TMUSFAUX	PUSH.L	D2	LOAD.W	D1,#IMABLUPQ2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+78	CLR.L	D3	CLR.L	D4	CALL	_IMAGEAFFF	; dessine toto	POP.L	D2	JUMP	LOOP$EXIT$:	CALL	_CCMO		; enlve la souris	POPM.L	D0..D3,D5,D6	RET;------------\\; SOURIS17POS >;------------/; Donne la position d'un carr.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WSOURIS17POS:	PUSH.L	A4	LOAD.W	D7,#1	COMP.W	D1,#16	JUMP',HS EXIT$	LOAD.W	D3,D1	SL.W	D3,#2	LOAD.L	A4,#R16"TABLE$	LOAD.L	D3,(A4)+(D3.W)	LOAD.L	D4,#H'10000*24+24	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	111,258	.W	208,238	.W	293,255	.W	172,286	.W	126,363	.W	191,351	.W	248,338	.W	287,391	.W	232,422	.W	170,440	.W	103,450	.W	130,527	.W	164,594	.W	198,530	.W	256,487	.W	246,587	.END