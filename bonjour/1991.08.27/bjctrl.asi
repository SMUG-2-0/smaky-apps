	.SBTTL	BJCTRL.ASI;---------\\; CTRLSTOP >;=========/; Regarde s'il faut stopper d'urgence une action.; in	-; out	D3.W	touche presse (SHIFT-CR/TAB/END/CR);	D7.W	erreur; mod	D3.L, D7.WCTRLSTOP:	LIB	?IFCAR		; une touche presse ?	JUMP',NE CONT$	COMP.W	D3,#END	JUMP',EQ BEGIN$	COMP.W	D3,#F0	JUMP',EQ BEGIN$	COMP.W	D3,#F0+SHIFT	JUMP',EQ BEGIN$CONT$:	CLR.W	D3	LOAD.W	D7,#1		; D7 <-- on continue	JUMP'	EXIT$BEGIN$:	LOAD.W	D3,#END		; D3 <-- retourne au menu du dbut	CLR.W	D7;	JUMP'	EXIT$EXIT$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; CTRLWAIT >;=========/; Attend, en regarde s'il faut stopper d'urgence.; in	D4.W	dlai [ms]; out	D3.W	touche presse (SHIFT-CR/TAB/END/CR);	D7.W	erreur; mod	D3.L, D7.WCTRLWAIT:	NTREL	?SETTIM	LIB	?GETCAR		; une touche presse ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP',NE CONT$	COMP.W	D3,#END	JUMP',EQ BEGIN$	COMP.W	D3,#F0	JUMP',EQ BEGIN$	COMP.W	D3,#F0+SHIFT	JUMP',EQ BEGIN$CONT$:	CLR.W	D3	LOAD.W	D7,#1		; D7 <-- on continue	JUMP'	EXIT$BEGIN$:	LOAD.W	D3,#END		; D3 <-- retourne au menu du dbut	CLR.W	D7;	JUMP'	EXIT$EXIT$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; CTRLEVENT >;==========/; Attend un vnement.; in	D4.W	attente maximale; out	D3.W	touche presse (SHIFT-CR/TAB/END/CR); mod	D3.L, D7.WCTRLEVENT:	PUSHM.L	D1,D2,D4	LOAD.W	D2,D4		; D2 <-- attente maximale	CALL	CLRFIFO		; vide le fifo du clavier	TEST.B	(A6)+OBEGIN	; permet le contrle ?	JUMP',F CTRL$		; oui => CTRL$				; non =>	LOAD.W	D4,D2	JUMP',NC TIMOS$	NEG.W	D4TIMOS$:	NTREL	?SETTIM	LIB	?GETCAR		; attend souris/clavier ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE NEXT$	COMP.W	D3,#SHIFT!CR	JUMP,EQ PREV$	COMP.W	D3,#TAB	JUMP,EQ SAME$	COMP.W	D3,#UNDO	JUMP,EQ SAME$	COMP.W	D3,#END	JUMP,EQ BEGIN$	COMP.W	D3,#F0	JUMP,EQ BEGIN$	COMP.W	D3,#F0+SHIFT	JUMP,EQ BEGIN$	JUMP	NEXT$CTRL$:	CALL	CTRLDRAW	; dessine le contrle	CALL	AFMENUCTRL	; dessine les soft-keys	CALL	SCMO		; remet la sourisLOOP$:	LOAD.W	D4,D2	JUMP',NC WAIT$	NEG.W	D4	NTREL	?SETTIMWAIT$:	LIB	?GETCAR		; attend souris/clavier ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE NEXT$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#F4	JUMP,EQ PREV$	COMP.W	D3,#F5	JUMP,EQ PREV$	COMP.W	D3,#F6	JUMP,EQ PREV$	COMP.W	D3,#SHIFT!CR	JUMP,EQ PREV$	COMP.W	D3,#F7	JUMP,EQ SAME$	COMP.W	D3,#F8	JUMP,EQ SAME$	COMP.W	D3,#F9	JUMP,EQ SAME$	COMP.W	D3,#TAB	JUMP,EQ SAME$	COMP.W	D3,#UNDO	JUMP,EQ SAME$	COMP.W	D3,#F10	JUMP,EQ BEGIN$	COMP.W	D3,#F11	JUMP,EQ BEGIN$	COMP.W	D3,#F12	JUMP,EQ BEGIN$	COMP.W	D3,#END	JUMP,EQ BEGIN$	COMP.W	D3,#F0	JUMP,EQ BEGIN$	COMP.W	D3,#F0+SHIFT	JUMP,EQ BEGIN$	COMP.W	D3,#F13	JUMP,EQ NEXT$	COMP.W	D3,#F14	JUMP,EQ NEXT$	COMP.W	D3,#F15	JUMP,EQ NEXT$	COMP.W	D3,#CR	JUMP,EQ NEXT$	COMP.W	D3,#SPACE	JUMP,EQ NEXT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	CALL	CTRLMOVE	; action dans un contrle ...	JUMP,NE BIP$	DEC.W	D1	JUMP',NS PREV$	DEC.W	D1	JUMP',NS SAME$	DEC.W	D1	JUMP',NS BEGIN$	DEC.W	D1	JUMP',NS NEXT$	JUMP	BIP$NEXT$:	LOAD.W	D3,#CR	JUMP'	EXIT$PREV$:	LOAD.W	D3,#SHIFT!CR	JUMP'	EXIT$SAME$:	LOAD.W	D3,#TAB	JUMP'	EXIT$BEGIN$:	LOAD.W	D3,#END;	JUMP'	EXIT$EXIT$:	CALL	CCMO		; enlve la souris	CALL	AFMENUNIL	; dessine les soft-keys	POPM.L	D1,D2,D4	RET;---------\\; CTRLDRAW >;=========/; Dessine le contrle.; in	-; out	-; mod	D7.WCTRLDRAW:	PUSHM.L	D1..D4	LOAD.W	D1,#IMACONTROL	LOAD.L	D2,(A6)+OCTRLP	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine le controle	CLR.W	D1GREY$:	TEST.B	(A6)+OCTRLG:D1	; icne grise ?	JUMP',BC NEXT$		; non => NEXT$	CALL	CTRLGREY	; grise une icneNEXT$:	INC.W	D1	COMP.W	D1,#4	JUMP,LO GREY$	POPM.L	D1..D4	RET;---------\\; CTRLGREY >;=========/; Grise une icne du contrle.; in	D1.W	rang (0..3); out	-; mod	D7.WCTRLGREY:	PUSHM.L	D1..D4	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	CALL	CTRLPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; supprime l'icne "same"EXIT$:	POPM.L	D1..D4	RET;---------\\; CTRLMOVE >;=========/; Action dans un contrle.; in	D4.L	position de la souris (y;x); out	D1.W	rang (0..3);	D7.W	erreur; mod	D1.L, D7.WCTRLMOVE:	PUSHM.L	D2..D4	CALL	CTRLDET		; D1 <-- contrle o est la souris	JUMP',NE EXIT$	CALL	CTRLINV		; allume le premier	LOAD.W	D2,D1LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	CTRLDET		; D1 <-- contrle o est la souris	COMP.W	D1,D2	JUMP,EQ LOOP$	EX.L	D1,D2	CALL	CTRLINV		; teint l'ancien	LOAD.W	D1,D2	CALL	CTRLINV		; allume le nouveau	JUMP	LOOP$END$:	LOAD.W	D1,D2	CALL	CTRLINV		; teint le dernier	CALL	CTRLPOS		; D3/D4 <-- position/dimensionsEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CTRLDET >;--------/; Dtecte dans quel contrle est la souris.; in	D4.L	position de la souris (y;x); out	D1.W	rang (0..3);	D7.W	erreur; mod	D1.L, D7.WCTRLDET:	PUSHM.L	D0,D2..D4	LOAD.W	D0,D4		; D0 <-- position en X	LOAD.L	D2,D4	SWAP.W	D2		; D2 <-- position en Y	LOAD.W	D1,#-1LOOP$:	INC.W	D1	CALL	CTRLPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	COMP.W	D0,D3	JUMP,LO LOOP$	ADD.W	D3,D4	COMP.W	D0,D3	JUMP,HS LOOP$	SWAP.W	D3	SWAP.W	D4	COMP.W	D2,D3	JUMP,LO LOOP$	ADD.W	D3,D4	COMP.W	D2,D3	JUMP,HS LOOP$	TEST.B	(A6)+OCTRLG:D1	; icne grise ?	JUMP,BS LOOP$		; oui => LOOPEXIT$:	POPM.L	D0,D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CTRLINV >;--------/; Inverse un contrle.; in	D1.W	rang (0..3); out	-; mod	D7.WCTRLINV:	PUSHM.L	D2..D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	CTRLPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#2+1	SWAP.W	D4	SUB.W	D4,#2+1	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse le contrleEXIT$:	POPM.L	D2..D4	RET;--------\\; CTRLPOS >;--------/; Donne la position d'un contrle.; in	D1.W	rang (0..3); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WCTRLPOS:	PUSH.L	D1	LOAD.W	D7,#1	COMP.W	D1,#4	JUMP',HS EXIT$	LOAD.L	D3,(A6)+OCTRLP	ADD.W	D3,#6	SWAP.W	D3	ADD.W	D3,#3	SWAP.W	D3	LOAD.L	D4,#H'10000*24+32	MUL.WU	D1,D4	ADD.W	D3,D1	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET	.END