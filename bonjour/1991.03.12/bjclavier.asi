	.SBTTL	BJCLAVIER.ASI;---------\\; CLAVIER1 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER1:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMANOCAPS	LOAD.L	D2,#H'10000*130+280	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMANOCAPS	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"Nous allons tudier le clavier. Avant de commencer,<CR>"	.ASCII	"<AFBOLD>assurez-vous que le mot CAPS n'apparat pas en haut<CR>"	.ASCII	"de l'cran<AFROMAN>, en appuyant sur la touche du mme nom !<CR>"	.B	0	.EVEN;---------\\; CLAVIER2 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER2:	PUSHM.L	D0,D1,D2,D4,A3,A4	LOAD.L	A3,#R16"TEXT1$	LOAD.W	D1,#IMABLUPP1	LOAD.W	D0,#2	LOAD.W	(A6)+OTXDEL,#20ENCORE$:	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGVERTI	CALL	DRFONDD		; dessine le fond	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	TXBULLEL	; dessine le texte	CLR.W	(A6)+OTXDEL	LOAD.L	A3,#R16"MODELE$	CALL	TXPOPEN		; utilise les petits caractres	CALL	CLAFRAP		; frappe ...	CALL	TXPCLOSE	; utilise les caractres normaux	COMP.L	D4,#50*25	JUMP',LO SUITE$	LOAD.L	A3,#R16"TEXT2$	LOAD.W	D1,#IMABLUPP2	DEC.W	D0	JUMP,NE ENCORE$SUITE$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT3$	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	POPM.L	D0,D1,D2,D4,A3,A4	RETMODELE$:	.ASCIZ	"apportez ce vieux whisky au juge blond qui fume"TEXT1$:	.ASCII	"Pour vous familiariser avec le clavier,<CR>"	.ASCII	"copiez la phrase ci-dessous :<CR>"	.B	0TEXT2$:	.ASCII	"C'est juste, mais pas assez rapide !<CR>"	.ASCII	"<CR>"	.ASCII	"Essayez encore une fois ...<CR>"	.B	0TEXT3$:	.ASCII	"                    Trs bien !<CR>"	.ASCII	"<CR>"	.ASCII	"Cliquez l'icne en bas  droite pour passer plus loin ...<CR>"	.B	0	.EVEN;---------\\; CLAVIER3 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER3:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGMIDDLEH	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMASHIFT	LOAD.L	D2,#H'10000*150+280	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMASHIFT	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"Les deux touches <AFDRECT>SHIFT<AFFRECT> permettent d'atteindre les<CR>"	.ASCII	"lettres majuscules et les signes placs sur la <AFBOLD>partie<CR>"	.ASCII	"suprieure<AFROMAN> de certaines touches :<CR>"	.B	0	.EVEN;---------\\; CLAVIER4 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER4:	PUSHM.L	D0,D1,D2,D4,A3,A4	LOAD.L	A3,#R16"TEXT1$	LOAD.W	D1,#IMABLUPP1	LOAD.W	D0,#2ENCORE$:	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGMIDDLEH	CALL	DRFONDD		; dessine le fond	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A3,#R16"MODELE$	CALL	TXOPEN		; utilise les grands caractres	CALL	CLAFRAP		; frappe ...	CALL	TXCLOSE		; utilise les petits caractres	COMP.L	D4,#50*25	JUMP',LO SUITE$	LOAD.L	A3,#R16"TEXT2$	LOAD.W	D1,#IMABLUPP2	DEC.W	D0	JUMP,NE ENCORE$SUITE$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT3$	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	POPM.L	D0,D1,D2,D4,A3,A4	RETMODELE$:	.ASCIZ	/aA bB 1+ 2"   [{ ,;/TEXT1$:	.ASCII	"Copiez les caractres ci-dessous,<CR>"	.ASCII	"en utilisant la touche <AFDRECT>SHIFT<AFFRECT> si ncessaire :<CR>"	.B	0TEXT2$:	.ASCII	"C'est bien, mais vous devez recommencer plus rapidement !<CR>"	.B	0TEXT3$:	.ASCII	"Oui, bravo !<CR>"	.B	0	.EVEN;---------\\; CLAVIER5 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER5:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGMIDDLEV	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMACTRL	LOAD.L	D2,#H'10000*150+280	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMACTRL	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"La touche <AFDRECT>CTRL<AFFRECT> permet d'atteindre les signes<CR>"	.ASCII	"placs sur la <AFBOLD>droite<AFROMAN> des touches :<CR>"	.B	0	.EVEN;---------\\; CLAVIER6 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER6:	PUSHM.L	D0,D1,D2,D4,A3,A4	LOAD.L	A3,#R16"TEXT1$	LOAD.W	D1,#IMABLUPP1	LOAD.W	D0,#2ENCORE$:	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGMIDDLEV	CALL	DRFONDD		; dessine le fond	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A3,#R16"MODELE$	CALL	TXOPEN		; utilise les grands caractres	CALL	CLAFRAP		; frappe ...	CALL	TXCLOSE		; utilise les petits caractres	COMP.L	D4,#50*25	JUMP',LO SUITE$	LOAD.L	A3,#R16"TEXT2$	LOAD.W	D1,#IMABLUPP2	DEC.W	D0	JUMP,NE ENCORE$SUITE$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT3$	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	POPM.L	D0,D1,D2,D4,A3,A4	RETMODELE$:	.ASCIZ	/ ~ @ ,<'<> .<'>>/TEXT1$:	.ASCII	"Copiez les caractres ci-dessous,<CR>"	.ASCII	"en utilisant la touche <AFDRECT>CTRL<AFFRECT> si ncessaire :<CR>"	.B	0TEXT2$:	.ASCII	"C'est juste, mais vous devez recommencer plus vite !<CR>"	.B	0TEXT3$:	.ASCII	"Parfait !<CR>"	.B	0	.EVEN;---------\\; CLAVIER7 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER7:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMACAPS	LOAD.L	D2,#H'10000*130+250	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMACAPS	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"Lorsque CAPS est visible en haut de l'cran,<CR>"	.ASCII	"toutes les <AFBOLD>lettres sont majuscules<AFROMAN>;<CR>"	.ASCII	"les autres signes restent inchangs.<CR>"	.B	0	.EVEN;---------\\; CLAVIER8 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER8:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGCIRCLE!2^BFGINVI+H'FD	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMASUPER	LOAD.L	D2,#H'10000*140+250	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMASUPER	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Les 7 touches rouges <AFBOLD>"super-shift"<AFROMAN> sont toujours<CR>/	.ASCII	/actionnes <AFBOLD>simultanment<AFROMAN> avec une autre touche.<CR>/	.B	0	.EVEN;---------\\; CLAVIER9 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER9:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVX!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMACURSOR	LOAD.L	D2,#H'10000*140+250	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMACURSOR	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"La touche super-shift <AFDRECT>CURSOR<AFFRECT> s'utilise beaucoup<CR>"	.ASCII	"avec les quatre touches grises <AFDRECT>R<AFFRECT> "	.ASCII	"<AFDRECT>D<AFFRECT> <AFDRECT>F<AFFRECT> <AFDRECT>C<AFFRECT> pour<CR>"	.ASCII	"effectuer des <AFBOLD>dplacements<AFROMAN>.<CR>"	.B	0	.EVEN;----------\\; CLAVIER10 >;==========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER10:	PUSHM.L	D1,D2,D4,A3,A4	.IF	~NOLABY	CALL	LAKEY		; labyrinthe ...	.ENDIF	LOAD.W	D4,#50*3	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	POPM.L	D1,D2,D4,A3,A4	RET;----------\\; CLAVIER11 >;==========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER11:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMACURSEUR	LOAD.L	D2,#H'10000*140+240	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMACURSEUR	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Le <AFBOLD>"curseur"<AFROMAN> indique o apparaissent les caractres<CR>/	.ASCII	/frapps au clavier.<CR>/	.ASCII	/Il prend diffrentes formes selon le logiciel utilis :<CR>/	.B	0	.EVEN;----------\\; CLAVIER12 >;==========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER12:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMACURSOR2	LOAD.L	D2,#H'10000*140+250	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMACURSOR2	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	"D'autres touches situes autour de "	.ASCII	"<AFDRECT>R<AFFRECT> <AFDRECT>D<AFFRECT> "	.ASCII	"<AFDRECT>F<AFFRECT> <AFDRECT>C<AFFRECT><CR>"	.ASCII	"permettent de dplacer le curseur d'un <AFBOLD>mot<AFROMAN>,<CR>"	.ASCII	"d'une <AFBOLD>ligne<AFROMAN> ou plus, avec la touche <AFDRECT>CURSOR<AFFRECT> .<CR>"	.B	0	.EVEN;----------\\; CLAVIER13 >;==========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER13:	PUSHM.L	D0,D1,D2,D4,A3,A4	LOAD.L	A3,#R16"TEXT1$	LOAD.W	D0,#2ENCORE$:	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A3,#R16"TJUSTE$	LOAD.L	A4,#R16"TFAUX$	CALL	CLAEDITI	; corrige le texte ...	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	COMP.L	D4,#50*30	JUMP',LO SUITE$	LOAD.L	A3,#R16"TEXT2$	DEC.W	D0	JUMP,NE ENCORE$SUITE$:	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT3$	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	POPM.L	D0,D1,D2,D4,A3,A4	RETTJUSTE$:	.ASCII	/La mus<AFINV>i<AFDIR>que ne peut<AFINV> <AFDIR>tre tr<AFINV>a<AFDIR>duite /	.ASCII	/par des<CR>/	.ASCII	/parole<AFINV>s<AFDIR>; elle n<AFINV>'<AFDIR>voque pas un lieu /	.ASCII	/prci<AFINV>s<AFDIR>,<CR>/	.ASCII	/ni un<AFINV>e<AFDIR> action particu<AFINV>l<AFDIR>ire./	.B	0TFAUX$:	.ASCII	/La musque ne peuttre trduite par des<CR>/	.ASCII	/parole; elle nvoque pas un lieu prci,<CR>/	.ASCII	/ni un action particuire./	.B	0TEXT1$:	.ASCII	/Corrigez la phrase ci-dessous, en <AFBOLD>dplaant le curseur<AFROMAN><CR>/	.ASCII	/avec la touche <AFDRECT>CURSOR<AFFRECT> associe  /	.ASCII	/<AFDRECT>R<AFFRECT> <AFDRECT>D<AFFRECT> /	.ASCII	/<AFDRECT>F<AFFRECT> <AFDRECT>C<AFFRECT> ...<CR>/	.B	0TEXT2$:	.ASCII	/C'est tout  fait juste, mais pas assez rapide !<CR>/	.ASCII	/Essayez encore une dernire fois ...<CR>/	.B	0TEXT3$:	.ASCII	/Trs bien !<CR>/	.B	0	.EVEN;----------\\; CLAVIER14 >;==========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER14:	PUSHM.L	D0,D1,D2,D4,A3,A4	LOAD.L	A3,#R16"TEXT1$	LOAD.W	D0,#2ENCORE$:	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A3,#R16"TJUSTE$	LOAD.L	A4,#R16"TFAUX$	CALL	CLAEDIT		; corrige le texte ...	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	COMP.L	D4,#50*30	JUMP',LO SUITE$	LOAD.L	A3,#R16"TEXT2$	DEC.W	D0	JUMP,NE ENCORE$SUITE$:	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT3$	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	POPM.L	D0,D1,D2,D4,A3,A4	RETTJUSTE$:	.ASCII	/Dans le lang<AFTRAIT>age parl ou crit<AFTRAIT> les mots ont<CR>/	.ASCII	/un sens fix par l'us<AFTRAIT>age, et la construction<CR>/	.ASCII	/des phrases obit<AFTRAIT>  certain<AFTRAIT>es rgles./	.B	0TFAUX$:	.ASCII	/Dans le langgage parl ou crits les mots ont<CR>/	.ASCII	/un sens fix par l'uskage, et la construction<CR>/	.ASCII	/des phrases obitte  certainnes rgles./	.B	0TEXT1$:	.ASCII	/La touche <AFDRECT>DEL<AFFRECT> supprime le caractre  /	.ASCII	/<AFBOLD>gauche<AFROMAN> du<CR>/	.ASCII	/curseur. Utilisez cette touche pour supprimer les<CR>/	.ASCII	/caractres inutiles ci-dessous :<CR>/	.B	0TEXT2$:	.ASCII	/C'est bien, mais trop lent !<CR>/	.ASCII	/Essayez encore une fois ...<CR>/	.B	0TEXT3$:	.ASCII	/Oui, c'est juste !<CR>/	.B	0	.EVEN;----------\\; CLAVIER15 >;==========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WCLAVIER15:	PUSHM.L	D1,D2,D4,A2..A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGCIRCLE	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMASOFTKEY	LOAD.L	D2,#H'10000*140+250	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A2,#R16"TEXT10$	LOAD.L	A3,#R16"TEXT1$	LOAD.L	A4,#R16"MENU1$	LOAD.W	D3,#F15	CALL	CLAVIER14ACTION	COMP.W	D3,#END	JUMP',EQ END$	LOAD.L	A2,#R16"TEXT20$	LOAD.L	A3,#R16"TEXT2$	LOAD.L	A4,#R16"MENU2$	LOAD.W	D3,#F8	CALL	CLAVIER14ACTION	COMP.W	D3,#END	JUMP',EQ END$	LOAD.L	A2,#R16"TEXT30$	LOAD.L	A3,#R16"TEXT3$	LOAD.L	A4,#R16"MENU3$	LOAD.W	D3,#F1	CALL	CLAVIER14ACTION	COMP.W	D3,#END	JUMP',EQ END$	LOAD.L	A2,#R16"TEXT40$	LOAD.L	A3,#R16"TEXT4$	LOAD.L	A4,#R16"MENU4$	LOAD.W	D3,#F11	CALL	CLAVIER14ACTION	COMP.W	D3,#END	JUMP',EQ END$	LOAD.L	A2,#R16"TEXT50$	LOAD.L	A3,#R16"TEXT5$	LOAD.L	A4,#R16"MENU5$	LOAD.W	D3,#F6	CALL	CLAVIER14ACTIONEND$:	CALL	AFMENUNIL	LOAD.W	D3,#CR	LOAD.W	D1,#IMASOFTKEY	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A2..A4	RETTEXT1$:	.ASCII	/Les <AFBOLD>16 touches fonctions<AFROMAN> s'adaptent au logiciel utilis.<CR>/	.ASCII	/Les cases en bas de l'cran donnent leurs significations<CR>/	.ASCII	/ un instant donn. Appuyez sur <AFDRECT>F15<AFFRECT> = "Suite" ...<CR>/	.B	0TEXT2$:	.ASCII	/Appuyez sur la touche <AFDRECT>F8<AFFRECT> = "Suite" ...<CR>/	.B	0TEXT3$:TEXT4$:TEXT5$:	.ASCII	/Appuyez sur la touche "Suite" ...<CR>/	.B	0TEXT10$:	.ASCII	/Vous devez appuyer sur la touche <AFDRECT>F15<AFFRECT> /	.ASCII	/du <AFBOLD>clavier<AFROMAN>,<CR>/	.ASCII	/sans utiliser la <AFBOLD>souris<AFROMAN> !<CR>/	.B	0TEXT20$:	.ASCII	/Vous devez appuyer sur la touche <AFDRECT>F8<AFFRECT> /	.ASCII	/du <AFBOLD>clavier<AFROMAN>,<CR>/	.ASCII	/sans utiliser la <AFBOLD>souris<AFROMAN> !<CR>/	.B	0TEXT30$:	.ASCII	/Vous devez appuyer sur la touche <AFDRECT>F1<AFFRECT> /	.ASCII	/du <AFBOLD>clavier<AFROMAN>,<CR>/	.ASCII	/sans utiliser la <AFBOLD>souris<AFROMAN> !<CR>/	.B	0TEXT40$:	.ASCII	/Vous devez appuyer sur la touche <AFDRECT>F11<AFFRECT> /	.ASCII	/du <AFBOLD>clavier<AFROMAN>,<CR>/	.ASCII	/sans utiliser la <AFBOLD>souris<AFROMAN> !<CR>/	.B	0TEXT50$:	.ASCII	/Vous devez appuyer sur la touche <AFDRECT>F6<AFFRECT> /	.ASCII	/du <AFBOLD>clavier<AFROMAN>,<CR>/	.ASCII	/sans utiliser la <AFBOLD>souris<AFROMAN> !<CR>/	.B	0	.EVENMENU1$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"            Suite"		;     ;     ;     ;MENU2$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"      Suite      "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;MENU3$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Suite            "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;MENU4$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"      Suite      "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;MENU5$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"            Suite"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN;----------------\\; CLAVIER14ACTION >;================/; in	A2.L	^texte si souris;	A3.L	^texte pour bulle;	A4.L	^table pour soft-keys;	D3.W	touche attendue; out	D3.W	touche presse; mod	D3.L, D7.WCLAVIER14ACTION:	PUSHM.L	D0..D2,D4,A3	CALL	DRAWOPENCOPY	; dessine en mmoire	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A3,A4	LIB	?AFMENU		; affiche les soft-keys	LOAD.W	D0,D3	CALL	CLRFIFO		; vide le fifo du clavierLOOP$:	LIB	?GETCAR		; attend touche ...	COMP.W	D3,#END	JUMP',EQ END$	COMP.W	D3,D0	JUMP',EQ OK$FAUX$:	LOAD.W	(A6)+OSOUND,#TMUSFAUX	LOAD.W	D1,#IMABLUPQ2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	JUMP	LOOP$OK$:	LOAD.L	D2,D3	SWAP.W	D2		; D2 <-- pseudo-code	LOAD.W	D1,D0	AND.B	D1,#B'1111	; D1 <-- 0..15	COMP.B	D2,D1		; pseudo-code ok ?	JUMP',EQ EXIT$	LOAD.L	A3,A2	CALL	DRAWOPENCOPY	; dessine en mmoire	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	JUMP	FAUX$END$:	LOAD.W	D3,#ENDEXIT$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	PUSH.L	D3	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	POP.L	D3	POPM.L	D0..D2,D4,A3	RET;--------\\; CLAFRAP >;========/; Demande de copier dans l'ordre un texte modle.; in	A3.L	^texte modle; out	D4.L	temps utilis; mod	D4.L, D7.WCLAFRAP:	PUSHM.L	D0..D3,D5,A3	CALL	CLRFIFO		; vide le fifo du clavier	LOAD.L	D3,#H'10000*124+237	LOAD.L	D4,#H'10000*(80+1)+(384+1)	CALL	CLARECT	LOAD.L	D3,#H'10000*204+237;	LOAD.L	D4,#H'10000*(80+1)+(384+1)	CALL	CLARECT	LOAD.W	D1,(A0)+ODFC1Y	ADD.W	D1,(A0)+ODFC2Y	SR.W	D1,#1	LOAD.L	D3,#H'10000*(124+40)+(237+4)	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	CALL	TXDRAW		; affiche le texte modle	LOAD.L	D2,#H'10000*(204+40)+(237+4)	SWAP.W	D2	SUB.W	D2,D1	ADD.W	D2,(A0)+ODFC1Y	; D2 <-- position pour les caractres	SWAP.W	D2	CLR.W	D0		; D0 <-- dernier toto affich	CLR.L	D5LOOP$:	TEST.B	(A3)		; fin du texte modle ?	JUMP,EQ FINI$	CALL	CLACURS		; met le curseur	LIB	?GETCAR		; attend une touche ...	CALL	CLACURS		; enlve le curseur	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	CLR.L	D4	COMP.W	D3,#END	JUMP,EQ EXIT$	COMP.W	D3,#F0	JUMP,EQ EXIT$	COMP.B	D3,(A3)		; frapp le bon caractre ?	JUMP',NE FAUX$		; non => FAUX$JUSTE$:	TEST.L	D5	JUMP',NE NOFIRST$	LOAD.L	D5,(A6)+OTIME	; D5 <-- temps du premier point visNOFIRST$:	COMP.W	D0,#IMABLUPP1	JUMP',EQ JUSTE2$	PUSH.L	D2	LOAD.W	D1,#IMABLUPP1	LOAD.W	D0,D1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	POP.L	D2JUSTE2$:	LOAD.L	D3,D2	LIB	?SETCURS	LOAD.B	D3,(A3+)	LIB	?AFCODE		; affiche le caractre	LIB	?LGXCAR		; D4 <-- largeur du caractre	ADD.W	D2,D4		; D2 <-- position suivante	JUMP	LOOP$FAUX$:	LOAD.W	(A6)+OSOUND,#TMUSFAUX	COMP.W	D0,#IMABLUPP2	JUMP,EQ LOOP$	PUSH.L	D2	LOAD.W	D1,#IMABLUPP2	LOAD.W	D0,D1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	POP.L	D2	JUMP	LOOP$FINI$:	LOAD.L	D4,(A6)+OTIME	SUB.L	D4,D5		; D4 <-- temps utilisEXIT$:	POPM.L	D0..D3,D5,A3	RET;--------\\; CLACURS >;--------/; Inverse le curseur.; in	D2.L	position (y;x);	A3.L	^caractre; out	-; mod	D7.WCLACURS:	PUSHM.L	D2..D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.B	D3,(A3)	LIB	?LGXCAR		; D4 <-- largeur du caractre	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LOAD.L	D3,D2	SUB.W	D3,(A0)+ODFC1X	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse le curseur	SWAP.W	D3	SUB.W	D3,#204-124	SWAP.W	D3;	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse le curseur	POPM.L	D2..D4	RET;--------\\; CLAEDIT >;========/; Demande de copier librement un texte modle.; in	A3.L	^texte modle;	A4.L	^texte  diter; out	D4.L	temps utilis; mod	D4.L, D7.WCLAEDIT:	PUSHM.L	D2,D3,D5,D6,A2..A4	LOAD.L	D2,(A6)+OTIME	; D2 <-- temps du dpart	CALL	CLRFIFO		; vide le fifo du clavier	LOAD.L	D3,#H'10000*124+237	LOAD.L	D4,#H'10000*(80+1)+(384+1)	CALL	CLARECT	LOAD.L	D3,#H'10000*204+237;	LOAD.L	D4,#H'10000*(80+1)+(384+1)	CALL	CLARECTE	LOAD.L	D3,#H'10000*(124+1+16)+(237+1+8)	CALL	TXPOPEN	CALL	TXDRAW		; affiche le texte modle	CALL	TXPCLOSE	LIB	?GETWDO	PUSH.W	D5	LOAD.L	D3,#H'10000*(204+1+16)+(237+1)	LOAD.L	D4,#H'10000*(16*4)+(384)	ADD.W	D3,(A0)+ODFFX	SWAP.W	D3	ADD.W	D3,(A0)+ODFFY	SWAP.W	D3	LIB	?CREWDO	LIB	?USEWDO	LOAD.L	A2,A3		; A2 <-- ^texte modle	LOAD.L	A3,#(A6)+OBUDISXFER$:	LOAD.B	(A3+),(A4+)	JUMP,NE XFER$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	LOAD.L	D3,#500	LOAD.W	D4,#2^BEPRONI!2^BEPRONEOT!2^BEPROQUITTE!2^BEPROAFCR!2^BEPROAFLF!2^BEPROAFTAB	EPRO_	OPEN	JUMP,NE END$LOOP$:	LOAD.L	A4,#R16"TERM$	EPRO_	MAIN	COMP.W	D3,#END	JUMP',EQ CLOSE$	COMP.W	D3,#F0	JUMP',EQ CLOSE$	CALL	CLACOMP		; texte correct ?	JUMP,NE LOOP$CLOSE$:	EPRO_	CLOSEEND$:	LIB	?GETWDO	LOAD.W	D6,D5	POP.W	D5	LIB	?USEWDO	LOAD.W	D5,D6	LIB	?KILWDOEXIT$:	LOAD.L	D3,#H'10000*204+237	LOAD.L	D4,#H'10000*(80+1)+(384+1)	CALL	CLARECT	LOAD.L	A3,A2	LOAD.L	D3,#H'10000*(204+1+16)+(237+1+8)	CALL	TXPOPEN	CALL	TXDRAW		; affiche le texte modle	CALL	TXPCLOSE	LOAD.L	D4,(A6)+OTIME	SUB.L	D4,D2		; D4 <-- temps utilis	POPM.L	D2,D3,D5,D6,A2..A4	RETTERM$:	.W	0;---------\\; CLAEDITI >;=========/; Demande de copier librement un texte modle.; in	A3.L	^texte modle;	A4.L	^texte  diter; out	D4.L	temps utilis; mod	D4.L, D7.WCLAEDITI:	PUSHM.L	D2,D3,D5,D6,A2..A4	LOAD.L	D2,(A6)+OTIME	; D2 <-- temps du dpart	CALL	CLRFIFO		; vide le fifo du clavier	LOAD.L	D3,#H'10000*124+237	LOAD.L	D4,#H'10000*(80+1)+(384+1)	CALL	CLARECT	LOAD.L	D3,#H'10000*204+237;	LOAD.L	D4,#H'10000*(80+1)+(384+1)	CALL	CLARECTE	LOAD.L	D3,#H'10000*(124+1+16)+(237+1+8)	CALL	TXPOPEN	CALL	TXDRAW		; affiche le texte modle	CALL	TXPCLOSE	LIB	?GETWDO	PUSH.W	D5	LOAD.L	D3,#H'10000*(204+1+16)+(237+1)	LOAD.L	D4,#H'10000*(16*4)+(384)	ADD.W	D3,(A0)+ODFFX	SWAP.W	D3	ADD.W	D3,(A0)+ODFFY	SWAP.W	D3	LIB	?CREWDO	LIB	?USEWDO	LOAD.L	A2,A3		; A2 <-- ^texte modle	LOAD.L	A3,#(A6)+OBUDISXFER$:	LOAD.B	(A3+),(A4+)	JUMP,NE XFER$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	LOAD.L	D3,#500	LOAD.W	D4,#2^BEPRONI!2^BEPRONEOT!2^BEPROQUITTE!2^BEPROAFCR!2^BEPROAFLF!2^BEPROAFTAB	EPRO_	OPEN	JUMP,NE END$LOOP$:	CALL	CLANBCAR	; D4 <-- nb de caractres	LOAD.L	A4,#R16"TERM$	EPRO_	MAIN	COMP.W	D3,#END	JUMP',EQ CLOSE$	COMP.W	D3,#F0	JUMP',EQ CLOSE$	CALL	CLAINSOK	; insr correctement ?	CALL	CLACOMP		; texte correct ?	JUMP,NE LOOP$CLOSE$:	EPRO_	CLOSEEND$:	LIB	?GETWDO	LOAD.W	D6,D5	POP.W	D5	LIB	?USEWDO	LOAD.W	D5,D6	LIB	?KILWDOEXIT$:	LOAD.L	D3,#H'10000*204+237	LOAD.L	D4,#H'10000*(80+1)+(384+1)	CALL	CLARECT	LOAD.L	A3,A2	LOAD.L	D3,#H'10000*(204+1+16)+(237+1+8)	CALL	TXPOPEN	CALL	TXDRAW		; affiche le texte modle	CALL	TXPCLOSE	LOAD.L	D4,(A6)+OTIME	SUB.L	D4,D2		; D4 <-- temps utilis	POPM.L	D2,D3,D5,D6,A2..A4	RETTERM$:	.B	2^BCURSOR!2^BKILL,'W	.B	2^BCURSOR!2^BKILL,'E	.B	2^BCURSOR!2^BKILL,'R	.B	2^BCURSOR!2^BKILL,'T	.B	2^BCURSOR!2^BKILL,'S	.B	2^BCURSOR!2^BKILL,'D	.B	2^BCURSOR!2^BKILL,'F	.B	2^BCURSOR!2^BKILL,'G	.B	2^BCURSOR!2^BKILL,'Y	.B	2^BCURSOR!2^BKILL,'X	.B	2^BCURSOR!2^BKILL,'C	.B	2^BCURSOR!2^BKILL,'V	.B	2^BCURSOR!2^BKILL,'w	.B	2^BCURSOR!2^BKILL,'e	.B	2^BCURSOR!2^BKILL,'r	.B	2^BCURSOR!2^BKILL,'t	.B	2^BCURSOR!2^BKILL,'s	.B	2^BCURSOR!2^BKILL,'d	.B	2^BCURSOR!2^BKILL,'f	.B	2^BCURSOR!2^BKILL,'g	.B	2^BCURSOR!2^BKILL,'y	.B	2^BCURSOR!2^BKILL,'x	.B	2^BCURSOR!2^BKILL,'c	.B	2^BCURSOR!2^BKILL,'v	.B	0,DEL	.B	0,BS	.B	0,DELETE	.B	0,CLEAR	.B	0,TRIZERO	.B	0,'		; touche accent ^	.B	0,'		; touche accent "	.W	0;---------\\; CLAINSOK >;---------/; Vrifie si l'insertion est correcte.; in	D3.W	touche frappe;	D4.L	nb de caractres prcdent;	D6.L	canal EPRO; out	-; mod	D7.WCLAINSOK:	PUSHM.L	D0..D3,A3,A4	SR.W	D3,#8	COMP.B	D3,#2^BCURSOR	JUMP,EQ EXIT$	LOAD.L	D3,D4		; D3 <-- nb de caractres prcdent	CALL	CLANBCAR	; D4 <-- nb de caractres actuel	COMP.L	D3,D4	JUMP,HS BIP$	EPRO_	GETPTC		; D3/A4 <-- caractre/pointeur	JUMP,NE ERROR$	EPRO_	PVISU	LOAD.B	D2,D3		; D2 <-- caractre suivant	EPRO_	PVISU	LOAD.B	D1,D3		; D1 <-- caractre frapp	EPRO_	PVISU	LOAD.B	D0,D3		; D0 <-- caractre prcdent	LOAD.L	A3,#R16"TABLE$-3SRC$:	ADD.L	A3,#3		; A3 <-- ^suivant	TEST.B	(A3)		; fin de la table ?	JUMP',EQ ERROR$		; oui => ERROR$	COMP.B	D0,(A3)+0	JUMP,NE SRC$	COMP.B	D1,(A3)+1	JUMP,NE SRC$	COMP.B	D2,(A3)+2	JUMP,NE SRC$	JUMP'	EXIT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP'	EXIT$ERROR$:	LOAD.W	(A6)+OSOUND,#TMUSFAUX	EPRO_	DRECULE		; supprime le caractre insrEXIT$:	POPM.L	D0..D3,A3,A4	RETTABLE$:	.ASCII	"siq"		; musIque	.ASCII	"t "		; peut tre	.ASCII	"rad"		; trAduite	.ASCII	"es;"		; paroleS;	.ASCII	"n'"		; n'voque	.ASCII	"is,"		; prciS,	.ASCII	"ne "		; unE action	.ASCII	"uli"		; particuLirement	.B	0	.EVEN;---------\\; CLANBCAR >;---------/; Donne le nombre de caractres dits.; in	D6.L	canal EPRO; out	D4.L	nb de caractres contenus; mod	D4.L, D7.WCLANBCAR:	PUSHM.L	D1,A5	LOAD.W	D1,#EPRO_GETPDBUFF	EPRO_	EXTEND		; A5 <-- ^descripteur buffer	LOAD.L	D4,(A5)+OEPROPFB	SUB.L	D4,(A5)+OEPROPFT	ADD.L	D4,(A5)+OEPROPDT	SUB.L	D4,(A5)+OEPROPDB	POPM.L	D1,A5	RET;--------\\; CLACOMP >;--------/; Regarde si le texte frapp est comme le modle.; in	D6.L	canal EPRO;	A2.L	^texte modle; out	D7.W	ok/erreur; mod	D7.WCLACOMP:	PUSHM.L	D1,A2..A5	LOAD.W	D1,#EPRO_GETPDBUFF	EPRO_	EXTEND		; A5 <-- ^descripteur buffer	LOAD.L	A3,(A5)+OEPROPDB	LOAD.L	A4,(A5)+OEPROPDTLOOP1$:	COMP.L	A3,A4	JUMP',EQ HOLE$	TEST.B	(A2)	JUMP',NC SPEC1$	INC.L	A2	TEST.B	(A2)SPEC1$:	JUMP',EQ DIFF$	COMP.B	(A3+),(A2+)	JUMP,EQ LOOP1$	JUMP'	DIFF$HOLE$:	LOAD.L	A3,(A5)+OEPROPFT	LOAD.L	A4,(A5)+OEPROPFBLOOP2$:	COMP.L	A3,A4	JUMP',EQ EOB$	TEST.B	(A2)	JUMP',NC SPEC2$	INC.L	A2	TEST.B	(A2)SPEC2$:	JUMP',EQ DIFF$	COMP.B	(A3+),(A2+)	JUMP,EQ LOOP2$	JUMP'	DIFF$EOB$:	TEST.B	(A2)	JUMP',EQ SAME$DIFF$:	LOAD.W	D7,#1	JUMP'	EXIT$SAME$:	CLR.W	D7EXIT$:	POPM.L	D1,A2..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLARECT >;--------/; Dessine un rectangle ombr.; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WCLARECT:	PUSHM.L	D2..D4	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,#12+1	SWAP.W	D3	ADD.W	D3,#4+1	SWAP.W	D3	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; dessine l'ombre	POPM.L	D3,D4	PUSHM.L	D3,D4	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'intrieur	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRRECT		; dessine le tour	POPM.L	D2..D4	RET;---------\\; CLARECTE >;---------/; Dessine un rectangle ombr pour diter avec EPRO.; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WCLARECTE:	PUSHM.L	D2..D4	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,#12+1	SWAP.W	D3	ADD.W	D3,#4+1	SWAP.W	D3	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; dessine l'ombre	POPM.L	D3,D4	PUSHM.L	D3,D4	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'intrieur	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRRECT		; dessine le tour	POPM.L	D2..D4	RET	.END