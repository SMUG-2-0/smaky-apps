	.TITLE	BJDATA.ASC; Cre le fichier BONJOUR.DATA pour BONJOUR.CODE	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULESLBUBIG	=	100000; Variables; ---------	.LOC	0OBUBIG:	.BLKB	LBUBIGLGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LIB	?AFTIM	.B	EOP,NOCURS	.ASCIZE	"<CR>Cration de BONJOUR.DATA ...<CR>"	LIB	?AFTIM	.ASCIZE	"<CR>Destruction de l'ancien"	LOAD.L	A3,#R16"NMFILE	FOS	?DELETE	LIB	?AFTIM	.ASCIZE	"<CR>Cration du nouveau"	LOAD.L	D3,#DEFATT-2^BATTL-2^BATTC	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP,NE ERROR	LIB	?AFTIM	.ASCIZE	"<CR>Ouverture"	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE ERROR	LOAD.L	A3,#R16"TANAMELOOP$:	LIB	?AFTIM	.ASCIZE	"<CR>Transfert de "	PUSH.L	A3	LIB	?AFTEXT	POP.L	A3	CALL	READFILE	JUMP,NE ERROR	FOS	?WRBYTE	JUMP,NE ERROR	TEST.L	D4:#0	JUMP,BC NEXT$	LOAD.L	A4,#SAJEX	LOAD.L	D4,#1	FOS	?WRBYTE	JUMP,NE ERRORNEXT$:	TEST.B	(A3+)	JUMP,NE NEXT$	TEST.B	(A3)	JUMP,NE LOOP$	LIB	?AFTIM	.ASCIZE	"<CR>Fermeture"	FOS	?CLOSE	JUMP,NE ERROR	JUMP	FINIERROR:	LIB	?AFERROR	LIB	?GETCARFINI:ERFAT:	LIB	?CLOLIB	FOS	?STOP;---------\\; READFILE >;=========/; ; in	A3.L	^nom; out	A4/D4	^data/lg;	D7.W	erreur; mod	D4.L, D7.W, A4.LREADFILE:	PUSHM.L	D3,D6	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE EXIT$	LOAD.L	A4,#(A6)+OBUBIG	LOAD.L	D4,#LBUBIG	FOS	?RDBYTE	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	COMP.W	D7,#EROUTF	JUMP,NE EXIT$	CLR.W	D7EXIT$:	POPM.L	D3,D6	TEST.W	D7		; retour EQ/NE	RETNMFILE:	.ASCIZ	"#:BONJOUR.DATA"SAJEX:	.B	0TANAME:	.ASCIZ	"CONTROL.IMAGE"	.ASCIZ	"BLUPF1.IMAGE"	.ASCIZ	"BLUPF2.IMAGE"	.ASCIZ	"BLUPQ1.IMAGE"	.ASCIZ	"BLUPQ2.IMAGE"	.ASCIZ	"BLUPP1.IMAGE"	.ASCIZ	"BLUPP2.IMAGE"	.ASCIZ	"BLUPP3.IMAGE"	.ASCIZ	"BULLE.IMAGE"	.ASCIZ	"BULLEL.IMAGE"	.ASCIZ	"BULLEH.IMAGE"	.ASCIZ	"SOURIS.IMAGE"	.ASCIZ	"MOUSE1.IMAGE"	.ASCIZ	"MOUSE2.IMAGE"	.ASCIZ	"MOUSE3.IMAGE"	.ASCIZ	"MOUSE4.IMAGE"	.ASCIZ	"VISER.IMAGE"	.ASCIZ	"SM324V.IMAGE"	.ASCIZ	"SM324.IMAGE"	.ASCIZ	"PUZZLE1.IMAGE"	.ASCIZ	"PUZZLE2.IMAGE"	.ASCIZ	"PUZZLE3.IMAGE"	.ASCIZ	"PUZZLE4.IMAGE"	.ASCIZ	"ICONE4.IMAGE"	.ASCIZ	"FLDOWN.IMAGE"	.ASCIZ	"OBJET2.IMAGE"	.ASCIZ	"SCROLL.IMAGE"	.ASCIZ	"SABLIER.IMAGE"	.ASCIZ	"NOCAPS.IMAGE"	.ASCIZ	"SHIFT.IMAGE"	.ASCIZ	"CTRL.IMAGE"	.ASCIZ	"CAPS.IMAGE"	.ASCIZ	"SUPER.IMAGE"	.ASCIZ	"CURSOR.IMAGE"	.ASCIZ	"CURSOR2.IMAGE"	.ASCIZ	"CURSEUR.IMAGE"	.ASCIZ	"SOFTKEY.IMAGE"	.ASCIZ	"START1.IMAGE"	.ASCIZ	"START2.IMAGE"	.ASCIZ	"START3.IMAGE"	.ASCIZ	"START4.IMAGE"	.ASCIZ	"STARTVISU.IMAGE"	.ASCIZ	"DESSIN0.IMAGE"	.ASCIZ	"DESSIN1.IMAGE"	.ASCIZ	"FLOPPY.IMAGE"	.ASCIZ	"DESDETR.IMAGE"	.ASCIZ	"PAQUETS.IMAGE"	.ASCIZ	"VOUS0.IMAGE"	.ASCIZ	"VOUS1.IMAGE"	.ASCIZ	"MMENUH1.IMAGE"	.ASCIZ	"MMENUH2.IMAGE"	.B	0	.EVEN	.END	START