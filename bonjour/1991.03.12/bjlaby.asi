	.SBTTL	BJLABY.ASILALMAR	=	14		; marges autour du labyrinthe;--------\\; LAKEY   >;========/; Labyrinthe avec le clavier.; in	-; out	-; mod	D7.WLAKEY:	PUSHM.L	D0..D4,A4	LOAD.L	D4,#H'10000*((6*2)+1)+((15*2)+1)	CALL	LAINIT		; prpare un labyrinthe	JUMP,NE EXIT$	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE EXIT$	CALL	LACADRE		; affiche le cadre	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	LAHAZARD	; construit un labyrinthe	CALL	LASHOW		; affiche le labyrinthe	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEH	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	CLRFIFO		; vide le fifo du clavier	CLR.L	(A6)+OLACHI	LOAD.L	A4,(A6)+OLAPRE	; A4 <-- ^rponse	LOAD.L	D1,#H'10000*1+1	; D1 <-- premire case	CALL	LACHEMIN	; avance ou reculeLOOP$:	LIB	?GETCAR		; attend clavier ...	COMP.W	D3,#SPACE	JUMP,EQ END$	COMP.W	D3,#END	JUMP,EQ END$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	LIB	?MINMAJ	COMP.W	D3,#H'100*(2^BCURSOR)+'R	JUMP',EQ UP$	COMP.W	D3,#H'100*(2^BCURSOR)+'D	JUMP',EQ LEFT$	COMP.W	D3,#H'100*(2^BCURSOR)+'F	JUMP',EQ RIGHT$	COMP.W	D3,#H'100*(2^BCURSOR)+'C	JUMP',EQ DOWN$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$UP$:	LOAD.W	D3,#-2	SWAP.W	D3	LOAD.W	D3,#0	JUMP'	MOVE$LEFT$:	LOAD.W	D3,#0	SWAP.W	D3	LOAD.W	D3,#-2	JUMP'	MOVE$RIGHT$:	LOAD.W	D3,#0	SWAP.W	D3	LOAD.W	D3,#+2	JUMP'	MOVE$DOWN$:	LOAD.W	D3,#+2	SWAP.W	D3	LOAD.W	D3,#0;	JUMP'	MOVE$MOVE$:	LOAD.L	D2,D1		; D2 <-- ancienne position	ADD.W	D1,D3	SWAP.W	D1	SWAP.W	D3	ADD.W	D1,D3		; D1 <-- nouvelle position	SWAP.W	D1	SWAP.W	D3	CALL	LACHEMIN	; avance ou recule	JUMP',NE FAUX$	COMP.L	D1,(A6)+OLAARR	; est-on arriv ?	JUMP',EQ GAGNE$		; oui => GAGNE$	JUMP	LOOP$FAUX$:	LOAD.L	D1,D2		; D1 <-- ancienne position	JUMP	BIP$GAGNE$:	LOAD.W	(A6)+OSOUND,#TMUSGAGNE	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT2$	CALL	TXBULLEH	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoireEND$:	CALL	LAKILL		; libre le labyrintheEXIT$:	POPM.L	D0..D4,A4	TEST.W	D7		; retour EQ/NE	RETTEXT1$:	.ASCII	"Trouvez le <AFBOLD>disque rond<AFROMAN>, "	.ASCII	"en utilisant la touche <AFDRECT>CURSOR<AFFRECT><CR>"	.ASCII	"associe aux quatre touches grises <AFDRECT>R<AFFRECT> <AFDRECT>D<AFFRECT> "	.ASCII	"<AFDRECT>F<AFFRECT> <AFDRECT>C<AFFRECT> ...<CR>"	.B	0TEXT2$:	.ASCII	"Bravo, c'est bien !<CR>"	.B	0	.EVEN;--------\\; LAMOUSE >;========/; Labyrinthe avec la souris.; in	; out	; mod	LAMOUSE:	PUSHM.L	D0..D4,A4	LOAD.L	D4,#H'10000*((8*2)+1)+((20*2)+1)	CALL	LAINIT		; prpare un labyrinthe	JUMP,NE EXIT$	CALL	DRAWOPEN	; dessine en mmoire	JUMP,NE EXIT$	CALL	LACADRE		; affiche le cadre	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	LAHAZARD	; construit un labyrinthe	CALL	LASHOW		; affiche le labyrinthe	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEH	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	CLRFIFO		; vide le fifo du clavier	CALL	SCMO		; remet la souris	LOAD.L	A4,(A6)+OLAPRE	; A4 <-- ^rponse	CLR.L	D2		; D2 <-- dernire case	LOAD.L	(A6)+OLACHI,D2LOOP$:	LIB	?GETKEY		; attend clavier/souris ...	COMP.W	D3,#KEYMPO	JUMP',EQ MOVE$	COMP.W	D3,#SPACE	JUMP,EQ END$	COMP.W	D3,#END	JUMP,EQ END$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMP	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDP	JUMP,EQ LOOP$BIP$:	LOAD.W	(A6)+OSOUND,#TMUSLIT	JUMP	LOOP$MOVE$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	LADETECT	; D1 <-- coordonne	JUMP,NE LOOP$	COMP.L	D1,D2		; est-on toujours dans la mme case ?	JUMP,EQ LOOP$		; oui => LOOP$	EX.L	D1,D2	CALL	LAHILIE		; teint l'ancienne	EX.L	D1,D2	CALL	LAHILIE		; allume la nouvelle	LOAD.L	D2,D1		; D2 <-- dernire case	LOAD.L	(A6)+OLACHI,D2	CALL	LACHEMIN	; avance ou recule	JUMP,NE BIP$	COMP.L	D1,(A6)+OLAARR	; est-on arriv ?	JUMP,NE LOOP$		; non => LOOP$GAGNE$:	LOAD.W	(A6)+OSOUND,#TMUSGAGNE	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT2$	CALL	TXBULLEH	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	D1,(A4)-4	CALL	LAHILII		; teint le dernier	LOAD.L	D1,(A6)+OLACHI	CALL	LAHILIE		; teint le dernier	CLR.L	(A6)+OLACHIEND$:	CALL	CCMO		; enlve la souris	CALL	LAKILL		; libre le labyrintheEXIT$:	POPM.L	D0..D4,A4	RETTEXT1$:	.ASCII	"Parcourez le chemin menant de la <AFBOLD>flche<AFROMAN> au<CR>"	.ASCII	"<AFBOLD>disque rond<AFROMAN>, en dplaant la souris ...<CR>"	.B	0TEXT2$:	.ASCII	"Oui, c'est juste !<CR>"	.B	0	.EVEN.IF 0;-----------\\; LASOLUTION >;===========/; Montre la solution.; in	A4.L	^bout du chemin actuel; out	-; mod	D7.WLASOLUTION:	PUSHM.L	D1..D4,A3,A4	CLR.L	(A4)	LOAD.L	D1,(A4)-4	CALL	LAHILII		; teint le dernier	LOAD.L	D1,(A6)+OLACHI	CALL	LAHILIE		; teint le dernier	CLR.L	(A6)+OLACHI	LOAD.W	D4,#50	NTREL	?DELMS	CALL	LARSOLUTION	; cherche le chemin de la solution	LOAD.L	A3,(A6)+OLAPRE	LOAD.L	A4,(A6)+OLAPSOCOMP$:	COMP.L	(A3+),(A4+)	JUMP,EQ COMP$	SUB.L	A3,#4	SUB.L	A4,#4	TEST.L	(A3)	JUMP',EQ SET1$	LOAD.W	D1,#-1CLR1$:	INC.W	D1	TEST.L	(A3+)	JUMP,NE CLR1$	SUB.L	A3,#4CLR2$:	SUB.L	A3,#4	LOAD.W	D3,#1	LOAD.W	D2,#CLRDOT	CALL	LACHEMINV	; efface le bout faux	LOAD.W	(A6)+OSOUND,#TMUSTAC	LOAD.W	D4,#10	NTREL	?DELMS	DEC.W	D1	JUMP,NE CLR2$	LOAD.W	(A6)+OSOUND,#TMUSFAUX	LOAD.W	D4,#50	NTREL	?DELMSSET1$:	LOAD.L	A3,A4SET2$:	TEST.L	(A3)	JUMP',EQ END$	LOAD.W	D3,#1	LOAD.W	D2,#SETDOT	CALL	LACHEMINV	; allume le bout juste	ADD.L	A3,#4	LOAD.W	(A6)+OSOUND,#TMUSTIC	LOAD.W	D4,#10	NTREL	?DELMS	JUMP	SET2$END$:	LOAD.W	D4,#50*3	NTREL	?DELMS	POPM.L	D1..D4,A3,A4	RET.ENDIF;---------\\; LACHEMIN >;=========/; Modifie le chemin (avance ou recule).; in	D1.L	nouvelle coordonne (y;x);	A4.L	^bout du chemin actuel; out	A4.L	^bout du chemin nouveau;	D7.W	erreur; mod	D7.W, A4.LLACHEMIN:	PUSH.L	D1	LOAD.L	D1,(A4)-4	CALL	LAHILII		; teint l'ancien	POP.L	D1	CALL	LACHEMAR	; tente de reculer	JUMP',EQ EXIT$	CALL	LACHEMAV	; tente d'avancerEXIT$:	PUSHM.L	D1,D7	LOAD.L	D1,(A4)-4	CALL	LAHILII		; allume le nouveau	POPM.L	D1,D7	TEST.W	D7		; retour EQ/NE	RET;---------\\; LACHEMAR >;---------/; Essaye de raccourcir le chemin (recule).; in	D1.L	nouvelle coordonne (y;x);	A4.L	^bout du chemin actuel; out	A4.L	^bout du chemin nouveau;	D7.W	erreur; mod	D7.W, A4.LLACHEMAR:	PUSHM.L	D2,D3,A2,A3	LOAD.L	A2,(A6)+OLAPRE	; A2 <-- ^dbut du chemin	LOAD.L	A3,A4		; A3 <-- ^fin du chemin	COMP.L	A3,A2	JUMP,EQ ERROR$	ADD.L	A2,#4	LOAD.W	D3,#10-1RECULE$:	COMP.L	A3,A2	JUMP,EQ ERROR$	LOAD.L	D2,(-A3)	; D2 <-- recule d'une case	COMP.L	D2,D1	JUMP',EQ SUPP$	DECJ.W,NMO D3,RECULE$	JUMP	ERROR$SUPP$:	ADD.L	A3,#4	LOAD.L	D3,A4	SUB.L	D3,A3	JUMP',EQ ERROR$	SR.L	D3,#2	LOAD.W	D2,#CLRDOT	CALL	LACHEMINV	LOAD.L	A4,A3		; A4 <-- ^chemin plus court	CLR.W	D7	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1EXIT$:	POPM.L	D2,D3,A2,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; LACHEMAV >;---------/; Essaye d'allonger le chemin (avance).; in	D1.L	nouvelle coordonne (y;x);	A4.L	^bout du chemin actuel; out	A4.L	^bout du chemin nouveau;	D7.W	erreur; mod	D7.W, A4.LLACHEMAV:	PUSHM.L	D0..D4,A1..A3	LOAD.L	A2,(A6)+OLAPRE	; A2 <-- ^dbut du chemin	LOAD.L	A3,A4		; A3 <-- ^fin du chemin	COMP.L	A3,A2	JUMP,EQ BEGIN$	LOAD.L	D2,(-A3)	; D2 <-- dernire case	COMP.L	D2,D1	JUMP,EQ ERROR$	COMP.W	D2,D1	JUMP,EQ VERTI$	SWAP.W	D1	SWAP.W	D2	COMP.W	D2,D1	JUMP,EQ HORIZ$	LOAD.W	D3,D2	SUB.W	D3,D1	JUMP',NC BIAIY$	NEG.W	D3		; D3 <-- |dy|BIAIY$:	COMP.W	D3,#2	JUMP,NE ERROR$	SWAP.W	D2	SWAP.W	D1	LOAD.W	D3,D2	SUB.W	D3,D1	JUMP',NC BIAIX$	NEG.W	D3		; D3 <-- |dx|BIAIX$:	COMP.W	D3,#2	JUMP,NE ERROR$	LOAD.L	D3,D1	LOAD.L	D1,D3	LOAD.W	D1,D2	COMP.L	D1,(A3)-4	JUMP',EQ BIAII$	LOAD.L	D1,D3	ADD.W	D1,D2	SR.W	D1,#1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC BIAII$	LOAD.L	D1,D2	SWAP.W	D1	SWAP.W	D3	ADD.W	D1,D3	SR.W	D1,#1	SWAP.W	D3	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC BIAII$	LOAD.L	A3,A4	LOAD.L	D1,D3	LOAD.W	D1,D2	LOAD.L	(A4+),D1	LOAD.L	(A4+),D3	LOAD.W	D3,#2	LOAD.W	D2,#SETDOT	CALL	LACHEMINV	; inverse un nouveau bout de chemin	JUMP	OK$BIAII$:	LOAD.L	D1,D2	LOAD.W	D1,D3	COMP.L	D1,(A3)-4	JUMP,EQ ERROR$	LOAD.L	D1,D2	ADD.W	D1,D3	SR.W	D1,#1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP,BC ERROR$	LOAD.L	D1,D3	SWAP.W	D1	SWAP.W	D2	ADD.W	D1,D2	SR.W	D1,#1	SWAP.W	D2	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP,BC ERROR$	LOAD.L	A3,A4	LOAD.L	D1,D2	LOAD.W	D1,D3	LOAD.L	(A4+),D1	LOAD.L	(A4+),D3	LOAD.W	D3,#2	LOAD.W	D2,#SETDOT	CALL	LACHEMINV	; inverse un nouveau bout de chemin	JUMP	OK$HORIZ$:	SWAP.W	D2	SWAP.W	D1	CLR.W	D3	LOAD.W	D4,#-1	COMP.W	D1,D2	JUMP',HS HSENS$	NEG.W	D4HSENS$:	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP,BC ERROR$	INC.W	D3	ADD.W	D1,D4	COMP.W	D1,D2	JUMP,NE HSENS$	LOAD.L	A3,A4	SR.W	D3,#1	LOAD.W	D2,D3HPUT$:	SUB.W	D1,D4	SUB.W	D1,D4	LOAD.L	(A4+),D1	DEC.W	D2	JUMP,NE HPUT$	LOAD.W	D2,#SETDOT	CALL	LACHEMINV	; inverse un nouveau bout de chemin	JUMP	OK$VERTI$:	SWAP.W	D2	SWAP.W	D1	CLR.W	D3	LOAD.W	D4,#-1	COMP.W	D1,D2	JUMP',HS VSENS$	NEG.W	D4VSENS$:	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	SWAP.W	D1	TEST.B	(A1):D0	JUMP,BC ERROR$	INC.W	D3	ADD.W	D1,D4	COMP.W	D1,D2	JUMP,NE VSENS$	LOAD.L	A3,A4	SR.W	D3,#1	LOAD.W	D2,D3VPUT$:	SUB.W	D1,D4	SUB.W	D1,D4	SWAP.W	D1	LOAD.L	(A4+),D1	SWAP.W	D1	DEC.W	D2	JUMP,NE VPUT$	LOAD.W	D2,#SETDOT	CALL	LACHEMINV	; inverse un nouveau bout de chemin;	JUMP'	OK$OK$:	CLR.W	D7	JUMP'	EXIT$BEGIN$:	COMP.L	D1,#H'10000*1+1	JUMP',NE ERROR$	LOAD.L	A3,A4	LOAD.L	(A4+),D1	LOAD.W	D3,#1	LOAD.W	D2,#SETDOT	CALL	LACHEMINV	; inverse la premire case	JUMP	OK$ERROR$:	LOAD.W	D7,#1EXIT$:	POPM.L	D0..D4,A1..A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; LACHEMINV >;----------/; Inverse une partie de chemin.; in	A3.L	^coordonne premire case;	D3.W	nb de cases;	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WLACHEMINV:	PUSHM.L	D1,D3,A3,A4	LOAD.L	D1,(A6)+OLACHI	CALL	LAHILIE		; teint	LOAD.L	A4,(A6)+OLAPRELOOP$:	COMP.L	A3,A4	JUMP',EQ INT$	LOAD.L	D1,(A3)	ADD.W	D1,(A3)-4+2	SR.W	D1,#1	SWAP.W	D1	ADD.W	D1,(A3)-4+0	SR.W	D1,#1	SWAP.W	D1	CALL	LAINVINT$:	LOAD.L	D1,(A3+)	CALL	LAINV	DEC.W	D3	JUMP,NE LOOP$	LOAD.L	D1,(A6)+OLACHI	CALL	LAHILIE		; rallume	POPM.L	D1,D3,A3,A4	RET;---------\\; LADETECT >;=========/; Dtecte dans quelle case est la souris.; in	D4.L	position de la souris (y;x); out	D1.L	position dans le bitmap (y;x);	D7.W	erreur; mod	D1.L, D7.WLADETECT:	PUSHM.L	D3,D4	LOAD.W	D7,#1	LOAD.W	D3,(A6)+OLADIM	SR.W	D3,#1	CLR.L	D1	LOAD.W	D1,D4	SUB.W	D1,D3	SUB.W	D1,(A6)+OLAPOX	JUMP',LO EXIT$	DIV.WU	D1,(A6)+OLADIX	SL.W	D1,#1	INC.W	D1	COMP.W	D1,(A6)+OLANBX	JUMP',HS EXIT$	CLR.W	D4	SWAP.W	D4	SUB.W	D4,D3	SUB.W	D4,(A6)+OLAPOY	JUMP',LO EXIT$	DIV.WU	D4,(A6)+OLADIY	SL.W	D4,#1	INC.W	D4	COMP.W	D4,(A6)+OLANBY	JUMP',HS EXIT$	SWAP.W	D1	LOAD.W	D1,D4	SWAP.W	D1	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; LAINV   >;========/; Inverse une case du labyrinthe.; in	D1.L	coordonne (y;x);	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WLAINV:	PUSHM.L	D2..D4	LIB	?COLORPUSH	LOAD.L	D3,#COLORROUGE	LIB	?COLORSR	LOAD.L	D3,#-1	COMP.W	D2,#SETDOT	JUMP',EQ MDEF$	LOAD.L	D3,#H'11004400	COMP.L	D1,#H'10000*1+1	; teint le dpart ?	JUMP,EQ EXIT$		; oui => EXIT$	COMP.L	D1,#H'10000*1+2	JUMP,EQ EXIT$	COMP.L	D1,#H'10000*2+1	JUMP,EQ EXIT$MDEF$:	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	CALL	LAPOSDIM	; D3/D4 <-- position/dimensions	LOAD.W	D2,#LOADDOT	TEST.L	D1:#0	JUMP',BC LEFT$	TEST.L	D1:#16+0	JUMP',BC UP$	ADD.W	D3,#4	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	SUB.W	D4,#8	SWAP.W	D4	SUB.W	D4,#8	SWAP.W	D4	LIB	?DRTRAME	; inverse une case	JUMP	EXIT$LEFT$:	TEST.L	D1:#16+0	JUMP,BC EXIT$	SUB.W	D3,#4	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	ADD.W	D4,#8	SWAP.W	D4	SUB.W	D4,#8	SWAP.W	D4	LIB	?DRTRAME	; inverse une case	JUMP'	EXIT$UP$:	ADD.W	D3,#4	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	SUB.W	D4,#8	SWAP.W	D4	ADD.W	D4,#8	SWAP.W	D4	LIB	?DRTRAME	; inverse une case;	JUMP	EXIT$EXIT$:	LIB	?COLORPOP	POPM.L	D2..D4	RET;--------\\; LACADRE >;========/; Affiche le cadre.; in	-; out	-; mod	D7.WLACADRE:	PUSHM.L	D1..D4	LIB	?COLORPUSH	LOAD.L	D3,#COLORDEG2	LIB	?COLORSR	LOAD.L	D3,#COLORDEG3	LIB	?COLORCR	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame toute la fentre	LOAD.L	D3,#COLORBLEU	LIB	?COLORSR	LOAD.L	D3,#COLORBLEU	LIB	?COLORCR	LOAD.L	D3,#H'55AA55AA	LOAD.L	D4,D3	CALL	INVTRAME	LIB	?DRMDEF	LOAD.W	D4,(A6)+OLADIY	LOAD.W	D2,(A6)+OLANBY	DEC.W	D2	SR.W	D2,#1	MUL.WU	D4,D2	ADD.W	D4,(A6)+OLADIM	SWAP.W	D4	LOAD.W	D3,(A6)+OLADIX	LOAD.W	D2,(A6)+OLANBX	DEC.W	D2	SR.W	D2,#1	MUL.WU	D3,D2	ADD.W	D3,(A6)+OLADIM	LOAD.W	D4,D3	LOAD.L	D3,(A6)+OLAPOY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; grise le labyrinthe	PUSH.L	D3	LOAD.L	D3,#COLORNOIR	LIB	?COLORSR	LOAD.L	D3,#COLORBLANC	LIB	?COLORCR	POP.L	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D1,#B'0000110000110010	CALL	DESRECTM	; cadre	LIB	?COLORPOP	POPM.L	D1..D4	RET;--------\\; LASHOW  >;========/; Dessine tout le labyrinthe.; in	-; out	-; mod	D7.WLASHOW:	PUSHM.L	D0..D4,A1	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF		; trame pour les passages	LOAD.L	D1,#H'10000*1+1	LOAD.L	D4,(A6)+OLAPOYLOOPY$:	LOAD.W	D1,#1	LOAD.W	D4,(A6)+OLAPOXLOOPX$:	CALL	LASHOWCASE	; dessine une case	ADD.W	D4,(A6)+OLADIX	ADD.W	D1,#2	COMP.W	D1,(A6)+OLANBX	JUMP,LO LOOPX$	SWAP.W	D4	ADD.W	D4,(A6)+OLADIY	SWAP.W	D4	SWAP.W	D1	ADD.W	D1,#2	LOAD.W	D0,D1	SWAP.W	D1	COMP.W	D0,(A6)+OLANBY	JUMP,LO LOOPY$	LOAD.W	D2,#SETDOT	CALL	INVMODE	LOAD.L	D1,(A6)+OLAARR	; D1 <-- coordonne de l'arrive	CALL	LAPOSDIM	; D3/D4 <-- position/dimensions	SR.W	D4,#1	ADD.W	D3,D4	SUB.W	D4,#2	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SUB.W	D4,#2	SWAP.W	D3	SWAP.W	D4	CALL	LACERCLE	; dessine l'arrive	LOAD.L	D1,#H'10000*1+1	CALL	LAPOSDIM	; D3/D4 <-- position/dimensions	INC.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0		; labyrinthe part  droite ?	JUMP',BC DOWN$		; non => DOWN$RIGHT$:	ADD.W	D3,#4	SUB.W	D4,#8	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	CLR.W	D4	SWAP.W	D4	SWAP.W	D3	CALL	LAFLECHE	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	CALL	LAFLECHE	JUMP'	EXIT$DOWN$:	SR.W	D4,#1	ADD.W	D3,D4	CLR.W	D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#4	SUB.W	D4,#8	SWAP.W	D4	SWAP.W	D3	CALL	LAFLECHE	DEC.W	D3	CALL	LAFLECHE;	JUMP'	EXIT$EXIT$:	POPM.L	D0..D4,A1	RET;-----------\\; LASHOWCASE >;-----------/; Dessine une case du labyrinthe.; in	D1.L	coordonne dans le bitmap (y;x);	D4.L	coin sup/gauche (y;x); out	-; mod	D7.WLASHOWCASE:	PUSHM.L	D0..D6,A1	LOAD.L	D6,D1	LOAD.L	D5,D4	LOAD.W	D2,#LOADDOT	LOAD.L	D1,D6;	ADD.W	D1,#0	SWAP.W	D1	ADD.W	D1,#-1	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC NOHD$	LOAD.L	D3,D5	ADD.W	D3,(A6)+OLADIM;	SWAP.W	D3;	ADD.W	D3,#0;	SWAP.W	D3	LOAD.W	D4,(A6)+OLADIM	SWAP.W	D4	LOAD.W	D4,(A6)+OLADIX	SUB.W	D4,(A6)+OLADIM	LIB	?DRTRAMENOHD$:	LOAD.L	D1,D6	ADD.W	D1,#-1;	SWAP.W	D1;	ADD.W	D1,#0;	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC NOBG$	LOAD.L	D3,D5;	ADD.W	D3,#0	SWAP.W	D3	ADD.W	D3,(A6)+OLADIM	SWAP.W	D3	LOAD.W	D4,(A6)+OLADIY	SUB.W	D4,(A6)+OLADIM	SWAP.W	D4	LOAD.W	D4,(A6)+OLADIM	LIB	?DRTRAMENOBG$:	LOAD.L	D1,D6	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC NOBD$	LOAD.L	D3,D5	ADD.W	D3,(A6)+OLADIM	SWAP.W	D3	ADD.W	D3,(A6)+OLADIM	SWAP.W	D3	LOAD.W	D4,(A6)+OLADIY	SUB.W	D4,(A6)+OLADIM	SWAP.W	D4	LOAD.W	D4,(A6)+OLADIX	SUB.W	D4,(A6)+OLADIM	LIB	?DRTRAMENOBD$:	LOAD.W	D2,#SETDOT	CALL	INVMODE	LOAD.L	D1,D6;	ADD.W	D1,#0	SWAP.W	D1	ADD.W	D1,#-1	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC NOA$	LOAD.L	D3,D5	ADD.W	D3,(A6)+OLADIM;	SWAP.W	D3;	ADD.W	D3,#0;	SWAP.W	D3	LOAD.W	D4,(A6)+OLADIM	INC.W	D4	SWAP.W	D4	CLR.W	D4	CALL	DRLINE	LOAD.L	D3,D5	ADD.W	D3,(A6)+OLADIX	DEC.W	D3;	SWAP.W	D3;	ADD.W	D3,#0;	SWAP.W	D3	CALL	DRLINENOA$:	LOAD.L	D1,D6	ADD.W	D1,#-1;	SWAP.W	D1;	ADD.W	D1,#0;	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC NOB$	LOAD.L	D3,D5;	ADD.W	D3,#0	SWAP.W	D3	ADD.W	D3,(A6)+OLADIM	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A6)+OLADIM	INC.W	D4	CALL	DRLINE	LOAD.L	D3,D5;	ADD.W	D3,#0	SWAP.W	D3	ADD.W	D3,(A6)+OLADIY	DEC.W	D3	SWAP.W	D3	CALL	DRLINENOB$:	LOAD.L	D1,D6	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP,BC EXIT$	LOAD.L	D1,D6;	ADD.W	D1,#0	SWAP.W	D1	ADD.W	D1,#-1	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BS NOC$	LOAD.L	D3,D5	ADD.W	D3,(A6)+OLADIM	SWAP.W	D3	ADD.W	D3,(A6)+OLADIM	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A6)+OLADIX	SUB.W	D4,(A6)+OLADIM	CALL	DRLINENOC$:	LOAD.L	D1,D6	ADD.W	D1,#-1;	SWAP.W	D1;	ADD.W	D1,#0;	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BS NOD$	LOAD.L	D3,D5	ADD.W	D3,(A6)+OLADIM	SWAP.W	D3	ADD.W	D3,(A6)+OLADIM	SWAP.W	D3	LOAD.W	D4,(A6)+OLADIY	SUB.W	D4,(A6)+OLADIM	SWAP.W	D4	CLR.W	D4	CALL	DRLINENOD$:	LOAD.L	D1,D6;	ADD.W	D1,#0	SWAP.W	D1	ADD.W	D1,#+1	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BS NOE$	LOAD.L	D3,D5	ADD.W	D3,(A6)+OLADIM	SWAP.W	D3	ADD.W	D3,(A6)+OLADIY	DEC.W	D3	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A6)+OLADIX	SUB.W	D4,(A6)+OLADIM	CALL	DRLINENOE$:	LOAD.L	D1,D6	ADD.W	D1,#+1;	SWAP.W	D1;	ADD.W	D1,#0;	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BS NOF$	LOAD.L	D3,D5	ADD.W	D3,(A6)+OLADIX	DEC.W	D3	SWAP.W	D3	ADD.W	D3,(A6)+OLADIM	SWAP.W	D3	LOAD.W	D4,(A6)+OLADIY	SUB.W	D4,(A6)+OLADIM	SWAP.W	D4	CLR.W	D4	CALL	DRLINENOF$:	LOAD.L	D3,D5	ADD.W	D3,(A6)+OLADIX	DEC.W	D3	SWAP.W	D3	ADD.W	D3,(A6)+OLADIY	DEC.W	D3	SWAP.W	D3	LOAD.L	D4,#H'10000*0+1	CALL	DRLINEEXIT$:	POPM.L	D0..D6,A1	RET;---------\\; LACERCLE >;---------/; Dessine un cercle rempli.; in	D3.L	centre (y;x);	D4.L	rayons (ry;rx);	D2.W	mode de dessin; out	-; mod	D7.WLACERCLE:	PUSHM.L	D1..D4	LIB	?COLORPUSH	PUSH.L	D3	LOAD.L	D3,#COLORROUGE	LIB	?COLORSR	POP.L	D3	LOAD.L	D1,D4	SWAP.W	D1	COMP.W	D4,D1	JUMP',LS LOOP$	LOAD.W	D4,D1		; D4 <-- rayon le plus petitLOOP$:	LIB	?DRCERCLE	DEC.W	D4	COMP.W	D4,#3	JUMP,HS LOOP$	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	LOAD.L	D4,#H'10000*3+0	PUSH.L	D3	LIB	?DRSEG		; rempli l'intrieur !	POP.L	D3	INC.W	D3	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	INC.W	D3	LIB	?DRSEG	LIB	?COLORPOP	POPM.L	D1..D4	RET;---------\\; LAFLECHE >;---------/; Dessine une flche.; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode de dessin; out	-; mod	D7.WLAFLECHE:	PUSHM.L	D1..D4	LIB	?DRSEG	TEST.W	D4	JUMP',EQ VERTI$HORIZ$:	ASR.W	D4,#1	INC.W	D4	NEG.W	D4	LOAD.W	D1,D4	ASR.W	D4,#1	SWAP.W	D4	LOAD.W	D4,D1	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	LIB	?DRSEG	JUMP'	EXIT$VERTI$:	SWAP.W	D4	ASR.W	D4,#1	INC.W	D4	NEG.W	D4	LOAD.W	D1,D4	SWAP.W	D4	LOAD.W	D4,D1	ASR.W	D4,#1	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	NEG.W	D4	LIB	?DRSEG;	JUMP'	EXIT$EXIT$:	POPM.L	D1..D4	RET;--------\\; LAHILIE >;--------/; Met en vidence l'extrieur.; in	D1.L	coordonne (y;x); out	-; mod	D7.WLAHILIE:	PUSHM.L	D2..D4	TEST.L	D1:#0	JUMP',BC EXIT$	TEST.L	D1:#16+0	JUMP',BC EXIT$	CALL	LAPOSDIM	; D3/D4 <-- position/dimensions	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#4+1	SWAP.W	D4	SUB.W	D4,#4+1	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRRECTEXIT$:	POPM.L	D2..D4	RET;--------\\; LAHILII >;--------/; Met en vidence l'intrieur.; in	D1.L	coordonne (y;x); out	-; mod	D7.WLAHILII:	PUSHM.L	D2..D4	TEST.L	D1:#0	JUMP',BC EXIT$	TEST.L	D1:#16+0	JUMP',BC EXIT$	CALL	LAPOSDIM	; D3/D4 <-- position/dimensions	ADD.W	D3,#5	SWAP.W	D3	ADD.W	D3,#5	SWAP.W	D3	SUB.W	D4,#10+1	SWAP.W	D4	SUB.W	D4,#10+1	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRRECTEXIT$:	POPM.L	D2..D4	RET;---------\\; LAPOSDIM >;---------/; Trouve la position d'une case.; in	D1.L	coordonne dans le bitmap (y;x); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WLAPOSDIM:	PUSH.L	D2	LOAD.L	D3,D1	SWAP.W	D3	SR.W	D3,#1	MUL.WU	D3,(A6)+OLADIY	ADD.W	D3,(A6)+OLAPOY	LOAD.W	D4,(A6)+OLADIM	TEST.L	D1:#16+0	JUMP',BC POSY$	ADD.W	D3,D4	SUB.W	D4,(A6)+OLADIY	NEG.W	D4POSY$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,D1	SR.W	D2,#1	MUL.WU	D2,(A6)+OLADIX	ADD.W	D2,(A6)+OLAPOX	LOAD.W	D3,D2	LOAD.W	D4,(A6)+OLADIM	TEST.L	D1:#0	JUMP',BC POSX$	ADD.W	D3,D4	SUB.W	D4,(A6)+OLADIX	NEG.W	D4POSX$:	POP.L	D2	RET;--------\\; LAINIT  >;========/; Initialise un nouveau labyrinthe.; in	D4.L	nb de cases (ny;nx); out	D7.W	erreur; mod	D7.WLAINIT:	PUSHM.L	D1..D4,A4	LOAD.L	(A6)+OLANBY,D4	LOAD.W	(A6)+OLADIM,#4	LOAD.W	D1,#4/2	LOAD.L	D4,#LXWDO-LALMAR-LALMAR	LOAD.W	D3,(A6)+OLANBX	DEC.W	D3	SR.W	D3,#1	DIV.WU	D4,D3	LOAD.W	(A6)+OLADIX,D4	MUL.WU	D4,D3	SUB.L	D4,#LXWDO-LALMAR-LALMAR	NEG.W	D4	SR.W	D4,#1	ADD.W	D4,#LALMAR	SUB.W	D4,D1	LOAD.W	(A6)+OLAPOX,D4	LOAD.L	D4,#LYWDO-70-LALMAR-LALMAR	LOAD.W	D3,(A6)+OLANBY	DEC.W	D3	SR.W	D3,#1	DIV.WU	D4,D3	LOAD.W	(A6)+OLADIY,D4	MUL.WU	D4,D3	SUB.L	D4,#LYWDO-70-LALMAR-LALMAR	NEG.W	D4	SR.W	D4,#1	ADD.W	D4,#70-5+LALMAR	SUB.W	D4,D1	LOAD.W	(A6)+OLAPOY,D4	LOAD.W	D4,(A6)+OLANBX	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.W	(A6)+OLAIIY,D4	MUL.WU	D4,(A6)+OLANBY	ADD.L	D4,#1000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP',NE ERROR$	GESMEM	?CLEARMEM	LOAD.L	(A6)+OLAPBM,A4	LOAD.W	D4,(A6)+OLANBX	MUL.WU	D4,(A6)+OLANBY;	SR.L	D4,#2		; D4 <-- /4 car une case sur 2 (=4 en surface);	SL.L	D4,#2		; D4 <-- *4 car .L	ADD.L	D4,#1000	; D4 <-- ajoute p'tite rserve;	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP',NE ERROR$	GESMEM	?CLEARMEM	LOAD.L	(A6)+OLAPSO,A4	GESMEM	?GETMEM	JUMP',NE ERROR$	GESMEM	?CLEARMEM	LOAD.L	(A6)+OLAPRE,A4	JUMP'	EXIT$ERROR$:	PUSH.W	D7	CALL	LAKILL	POP.W	D7EXIT$:	POPM.L	D1..D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; LAHAZARD >;=========/; Construit un nouveau labyrinthe.; Cette opration peut prendre plusieurs secondes !; in	-; out	-; mod	D7.WLAHAZARD:	PUSHM.L	D0..D4,A1,A4	LOAD.L	A4,(A6)+OLAPSO	; A4 <-- ^solution	CLR.W	D4		; D4 <-- rang solution	LOAD.L	D1,#H'10000*1+1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TSET.B	(A1):D0	LOAD.L	(A4+),D1	; solution <-- position de dpart	INC.W	D4LOOP$:	LOAD.W	D2,#30	CALL	LAICHEMIN	; fait un bout de chemin	JUMP',NE RESTE$	PUSHM.L	D1,D4,A4	PUSH.L	D4	LOAD.W	D3,#20	LOAD.W	D4,#50	CALL	MMHAZARD	LOAD.W	D2,D4	POP.L	D4	CALL	LAICHEMIN	; fait un bout de fausse piste	POPM.L	D1,D4,A4	JUMP	LOOP$RESTE$:	LOAD.L	D1,#H'10000*1RESTY$:	LOAD.W	D1,#1RESTX$:	CALL	LAIIFPASS	; passage possible ?	JUMP',NE RESTN$		; non => RESTN$	PUSH.L	D1RESTA$:	CALL	LAIAVANCE	; D1 <-- avance	JUMP,EQ RESTA$	POP.L	D1RESTN$:	ADD.W	D1,#2	COMP.W	D1,(A6)+OLANBX	JUMP,LO RESTX$	SWAP.W	D1	ADD.W	D1,#2	LOAD.W	D0,D1	SWAP.W	D1	COMP.W	D0,(A6)+OLANBY	JUMP,LO RESTY$	CALL	LARARRIVEE	; OLAARR <-- coordonne de l'arrive	POPM.L	D0..D4,A1,A4	RET;----------\\; LAICHEMIN >;----------/; Avance un bout de chemin dans le labyrinthe.; in	D2.W	nb max de cases (1..n);	D1.L	coordonne (y;x);	A4.L	^dans solution;	D4.W	rang dans solution; out	D2.W	lg du chemin fait (0..n);	D1.L	coordonne (y;x);	A4.L	^dans solution;	D4.W	rang dans solution;	D7.W	erreur (si fini); mod	D1.L, D2.L, D4.L, D7.W, A4.LLAICHEMIN:	PUSH.L	D5	LOAD.L	D5,A4LOOP$:	CLR.W	D7	DEC.W	D2	JUMP',EQ EXIT$	CALL	LAIAVANCE	; D1 <-- avance	JUMP',NE CULSAC$	LOAD.L	(A4+),D1	; solution <-- position suivante	INC.W	D4	JUMP	LOOP$CULSAC$:	LOAD.W	D7,#1	COMP.W	D4,#2	JUMP',LS EXIT$	SUB.L	A4,#4	LOAD.L	D1,(A4)-4	; D1 <-- recule	DEC.W	D4	JUMP	LOOP$EXIT$:	LOAD.L	D2,A4	SUB.L	D2,D5	SR.L	D2,#2		; D2 <-- lg du chemin fait	POP.L	D5	TEST.W	D7		; retour EQ/NE	RET;----------\\; LAIIFPASS >;----------/; Regarde dans les quatre directions s'il est possible de crer; un nouveau passage.; in	D1.L	coordonne (y;x); out	D7.W	erreur si passage impossible; mod	D7.WLAIIFPASS:	PUSHM.L	D0..D2,A1	CLR.W	D7	LOAD.L	D2,D1	SUB.W	D1,#2	JUMP',NS OUEST$	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC EXIT$OUEST$:	LOAD.L	D1,D2	ADD.W	D1,#2	COMP.W	D1,(A6)+OLANBX	JUMP',HS EST$	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC EXIT$EST$:	LOAD.L	D1,D2	SWAP.W	D1	SUB.W	D1,#2	JUMP',NS NORD$	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC EXIT$NORD$:	LOAD.L	D1,D2	SWAP.W	D1	ADD.W	D1,#2	COMP.W	D1,(A6)+OLANBY	JUMP',HS SUD$	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC EXIT$SUD$:	LOAD.W	D7,#1EXIT$:	POPM.L	D0..D2,A1	TEST.W	D7		; retour EQ/NE	RET;----------\\; LAIAVANCE >;----------/; Avance dans le labyrinthe.; in	D1.L	coordonne (y;x); out	D1.L	coordonne suivante (y;x);	D7.W	erreur; mod	D1.L, D7.WLAIAVANCE:	PUSHM.L	D0,D2..D5,A1	LOAD.L	D2,D1		; D2 <-- position originale	LOAD.W	D5,#(4*3)-1	; D5 <-- nb max d'essaisOTHER$:	CLR.W	D3	LOAD.W	D4,#4	CALL	MMHAZARD	; D4 <-- direction (0..3)	CLR.L	D3	DEC.W	D4	JUMP',NS EST$	DEC.W	D4	JUMP',NS SUD$	DEC.W	D4	JUMP',NS OUEST$NORD$:	LOAD.W	D3,#+1	SWAP.W	D3	JUMP'	IFOK$OUEST$:	LOAD.W	D3,#-1	JUMP'	IFOK$SUD$:	LOAD.W	D3,#-1	SWAP.W	D3	JUMP'	IFOK$EST$:	LOAD.W	D3,#+1;	JUMP'	IFOK$IFOK$:	ADD.W	D1,D3	ADD.W	D1,D3	SWAP.W	D1	SWAP.W	D3	ADD.W	D1,D3	ADD.W	D1,D3	SWAP.W	D1	SWAP.W	D3	TEST.W	D1	JUMP',NS ERROR$	COMP.W	D1,(A6)+OLANBX	JUMP',HS ERROR$	SWAP.W	D1	TEST.W	D1	JUMP',NS ERROR$	COMP.W	D1,(A6)+OLANBY	JUMP',HS ERROR$	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TSET.B	(A1):D0	JUMP',BS ERROR$	LOAD.L	D1,D2	ADD.W	D1,D3	SWAP.W	D1	SWAP.W	D3	ADD.W	D1,D3	SWAP.W	D1	SWAP.W	D3	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TSET.B	(A1):D0	ADD.W	D1,D3	SWAP.W	D1	SWAP.W	D3	ADD.W	D1,D3	SWAP.W	D1;	SWAP.W	D3	CLR.W	D7	JUMP'	EXIT$ERROR$:	LOAD.L	D1,D2		; D1 <-- position originale	DECJ.W,NMO D5,OTHER$	LOAD.W	D7,#1EXIT$:	POPM.L	D0,D2..D5,A1	TEST.W	D7		; retour EQ/NE	RET;-----------\\; LARARRIVEE >;-----------/; Cherche rcursivement l'arrive, qui doit tre au bout de la branche; la plus longue de tout le labyrinthe !; in	-; out	-; mod	D7.WLARARRIVEE:	PUSHM.L	D0..D6,A5	LOAD.L	A5,#(A6)+OBUDIS	; A5 <-- ^stack spcial	CLR.W	D5		; D5 <-- rang dans le stack	CLR.L	D0	LOAD.L	D1,#H'10000*1+1	CLR.L	D6		; D6 <-- maximum/longueur du cheminLOOP$:	CALL	LARAVANCE	; D2/D3/D4 <-- nouvelles positions	TEST.L	D2		; cul de sac ?	JUMP',EQ POP$		; oui => POP$	TEST.L	D3		; plusieurs possibilits ?	JUMP',NE PUSH$		; oui => PUSH$NEXT$:	LOAD.L	D0,D1	LOAD.L	D1,D2	INC.W	D6		; D6 <-- longueur du chemin	LOAD.W	D2,D6		; D2 <-- longueur actuelle	SWAP.W	D6		; D6 <-- maximum	COMP.W	D6,D2	JUMP',HS NOARR$	LOAD.W	D6,D2	LOAD.L	(A6)+OLAARR,D1	; OLAARR <-- arriveNOARR$:	SWAP.W	D6	JUMP	LOOP$PUSH$:	COMP.W	D5,#(LBUDIS/(4+4+2))-2	JUMP',HS EXIT$	LOAD.L	(A5+),D1	; stack <-- ancien	LOAD.L	(A5+),D3	; stack <-- nouveau	LOAD.W	(A5+),D6	; stack <-- longueur	INC.W	D5	TEST.L	D4	JUMP,EQ NEXT$	LOAD.L	(A5+),D1	; stack <-- ancien	LOAD.L	(A5+),D4	; stack <-- nouveau	LOAD.W	(A5+),D6	; stack <-- longueur	INC.W	D5	JUMP	NEXT$POP$:	DEC.W	D5	JUMP',NS EXIT$	LOAD.W	D6,(-A5)	; D6 <-- longueur	LOAD.L	D1,(-A5)	; D1 <-- nouveau	LOAD.L	D0,(-A5)	; D0 <-- ancien	JUMP	LOOP$EXIT$:	POPM.L	D0..D6,A5	RET.IF 0;------------\\; LARSOLUTION >;------------/; Cherche rcursivement le chemin de la solution.; in	-; out	-; mod	D7.WLARSOLUTION:	PUSHM.L	D0..D5,A4,A5	LOAD.L	A5,#(A6)+OBUDIS	; A5 <-- ^stack spcial	CLR.W	D5		; D5 <-- rang dans le stack	CLR.L	D0	LOAD.L	D1,#H'10000*1+1	LOAD.L	A4,(A6)+OLAPSO	; A4 <-- ^solutionLOOP$:	LOAD.L	(A4+),D1	COMP.L	D1,(A6)+OLAARR	; a-t-on trouv l'arrive ?	JUMP,EQ EXIT$	CALL	LARAVANCE	; D2/D3/D4 <-- nouvelles positions	TEST.L	D2		; cul de sac ?	JUMP',EQ POP$		; oui => POP$	TEST.L	D3		; plusieurs possibilits ?	JUMP',NE PUSH$		; oui => PUSH$NEXT$:	LOAD.L	D0,D1	LOAD.L	D1,D2	JUMP	LOOP$PUSH$:	COMP.W	D5,#(LBUDIS/(4+4+4))-2	JUMP',HS EXIT$	LOAD.L	(A5+),D1	; stack <-- ancien	LOAD.L	(A5+),D3	; stack <-- nouveau	LOAD.L	(A5+),A4	; stack <-- ^solution	INC.W	D5	TEST.L	D4	JUMP,EQ NEXT$	LOAD.L	(A5+),D1	; stack <-- ancien	LOAD.L	(A5+),D4	; stack <-- nouveau	LOAD.L	(A5+),A4	; stack <-- ^solution	INC.W	D5	JUMP	NEXT$POP$:	DEC.W	D5	JUMP',NS EXIT$	LOAD.L	A4,(-A5)	; A4 <-- ^solution	LOAD.L	D1,(-A5)	; D1 <-- nouveau	LOAD.L	D0,(-A5)	; D0 <-- ancien	JUMP	LOOP$EXIT$:	CLR.L	(A4)	POPM.L	D0..D5,A4,A5	RET.ENDIF;----------\\; LARAVANCE >;----------/; Cherche les trois directions (au maximum) dans lesquelles il est possible d'aller.; in	D1.L	position actuelle;	D0.L	ancienne position (l d'o on vient); out	D2.L	nouvelle position (zro si rien);	D3.L	nouvelle position (zro si rien);	D4.L	nouvelle position (zro si rien); mod	D2.L, D3.L, D4.L, D7.WLARAVANCE:	PUSHM.L	D0,D1,D5,D6,A1	LOAD.L	D6,D0	PUSH.L	D1	CLR.L	D2	DEC.W	D1	JUMP',EQ OUEST$	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC OUEST$	DEC.W	D1	COMP.L	D1,D6	JUMP',EQ OUEST$	LOAD.L	D2,D1		; D2 <-- case  l'ouestOUEST$:	POP.L	D1	PUSH.L	D1	CLR.L	D3	INC.W	D1	LOAD.W	D0,(A6)+OLANBX	DEC.W	D0	COMP.W	D1,D0	JUMP',HS EST$	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC EST$	INC.W	D1	COMP.L	D1,D6	JUMP',EQ EST$	LOAD.L	D3,D1		; D3 <-- case  l'estEST$:	POP.L	D1	PUSH.L	D1	CLR.L	D4	SWAP.W	D1	DEC.W	D1	JUMP',EQ NORD$	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC NORD$	SWAP.W	D1	DEC.W	D1	SWAP.W	D1	COMP.L	D1,D6	JUMP',EQ NORD$	LOAD.L	D4,D1		; D4 <-- case au nordNORD$:	POP.L	D1	PUSH.L	D1	CLR.L	D5	SWAP.W	D1	INC.W	D1	LOAD.W	D0,(A6)+OLANBY	DEC.W	D0	COMP.W	D1,D0	JUMP',HS SUD$	SWAP.W	D1	CALL	LAGETBIT	; A1/D0 <-- ^byte/bit	TEST.B	(A1):D0	JUMP',BC SUD$	SWAP.W	D1	INC.W	D1	SWAP.W	D1	COMP.L	D1,D6	JUMP',EQ SUD$	LOAD.L	D5,D1		; D5 <-- case au sudSUD$:	POP.L	D1	TEST.L	D4	JUMP',NE D4$	LOAD.L	D4,D5	CLR.L	D5D4$:	TEST.L	D3	JUMP',NE D3$	LOAD.L	D3,D4	LOAD.L	D4,D5	CLR.L	D5D3$:	TEST.L	D2	JUMP',NE D2$	LOAD.L	D2,D3	LOAD.L	D3,D4	LOAD.L	D4,D5;	CLR.L	D5D2$:	POPM.L	D0,D1,D5,D6,A1	RET;---------\\; LAGETBIT >;---------/; in	D1.L	coordonne (y;x); out	A1/D0	pour instruction du genre: TEST.B (A1):D0; mod	D0.L, A1.LLAGETBIT:	PUSH.L	D1	LOAD.L	A1,(A6)+OLAPBM	; A1 <-- ^bitmap	LOAD.W	D0,D1	AND.W	D0,#B'111	; D0 <-- bit	SR.W	D1,#3	ADD.W	A1,D1		; A1 <-- ^selon X	SWAP.W	D1	MUL.WU	D1,(A6)+OLAIIY	ADD.L	A1,D1		; A1 <-- ^selon Y	POP.L	D1	RET;--------\\; LAKILL  >;========/; Libre le labyrinthe.; in	-; out	-; mod	D7.WLAKILL:	PUSHM.L	D1,A4	TEST.L	(A6)+OLAPBM	JUMP',EQ PBM$	LOAD.L	A4,(A6)+OLAPBM	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OLAPBMPBM$:	TEST.L	(A6)+OLAPSO	JUMP',EQ PSO$	LOAD.L	A4,(A6)+OLAPSO	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OLAPSOPSO$:	TEST.L	(A6)+OLAPRE	JUMP',EQ PRE$	LOAD.L	A4,(A6)+OLAPRE	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OLAPREPRE$:	POPM.L	D1,A4	RET	.END