	.SBTTL	BJSTART.ASI;--------\\; START1  >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART1:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMASTART1	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMASTART1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Le logiciel <AFBOLD>START<AFROMAN> supervise l'utilisation du SMAKY.<CR>/	.ASCII	/Ici, la fentre ouverte prsente les deux units de<CR>/	.ASCII	/disquettes, appeles #MM0: (gauche) et #MM1: (droite).<CR>/	.B	0	.EVEN;--------\\; START2  >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART2:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMASTART1	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoireLOOP$:	LOAD.L	A4,#R16"STICPOS1	CALL	STICACTION	; action ...	COMP.W	D3,#END	JUMP',EQ END$	LOAD.L	A3,#R16"TEXT3$	COMP.W	D3,#KEYMGP	JUMP',NE FAUX$	LOAD.L	A3,#R16"TEXT2$	TEST.W	D1	JUMP',EQ JUSTE$FAUX$:	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMABLUPQ2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	DRAWCLOSE	; montre le dessin en mmoire	JUMP	LOOP$JUSTE$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.W	D3,#CR		; D3 <-- exercice suivantEND$:	LOAD.W	D1,#IMASTART1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Aprs avoir mis une disquette dans le lecteur de gauche<CR>/	.ASCII	/(ne le faites pas rellement), il faut <AFBOLD>cliquer avec<CR>/	.ASCII	/le bouton de gauche<AFROMAN> sur #MM0: pour l'<AFBOLD>ouvrir<AFROMAN> :<CR>/	.B	0TEXT2$:	.ASCII	/Vous n'avez pas ouvert l'unit #MM0: !<CR>/	.ASCII	/<CR>/	.ASCII	/Cherchez mieux ...<CR>/	.B	0TEXT3$:	.ASCII	/Non, il faut utiliser le <AFBOLD>bouton de gauche<AFROMAN> !<CR>/	.ASCII	/<CR>/	.ASCII	/Ouvrez l'unit #MM0: ...<CR>/	.B	0	.EVEN;--------\\; START3  >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART3:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMASTART2	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*2	NTREL	?DELMS		; attend ...	LOAD.L	A4,#R16"STICPOS2	LOAD.W	D2,#10-1LOOPG$:	LOAD.W	D1,#4LOOPS$:	CALL	STICINV	INC.W	D1	COMP.W	D1,#4+3	JUMP,LO LOOPS$	LOAD.W	D4,#10	NTREL	?DELMS	LOAD.W	D1,#4LOOPC$:	CALL	STICINV	INC.W	D1	COMP.W	D1,#4+3	JUMP,LO LOOPC$	LOAD.W	D4,#6	NTREL	?DELMS	DECJ.W,NMO D2,LOOPG$	LOAD.W	D4,#50*1	NTREL	?DELMS		; attend ...	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMASTART2	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/La <AFBOLD>nouvelle fentre<AFROMAN> ouverte montre le contenu de la<CR>/	.ASCII	/disquette. Les logiciels sont reprsents par des<CR>/	.ASCII	/<AFBOLD>hexagones<AFROMAN>, avec au-dessous le nom termin par .CODE :<CR>/	.B	0	.EVEN;--------\\; START4  >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART4:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMASTART2	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoireLOOP$:	LOAD.L	A4,#R16"STICPOS2	CALL	STICACTION	; action ...	COMP.W	D3,#END	JUMP',EQ END$	LOAD.L	A3,#R16"TEXT3$	COMP.W	D3,#KEYMGP	JUMP',NE FAUX$	LOAD.L	A3,#R16"TEXT2$	COMP.W	D1,#5	JUMP',EQ JUSTE$FAUX$:	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMABLUPP2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	DRAWCLOSE	; montre le dessin en mmoire	JUMP	LOOP$JUSTE$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.W	D3,#CR		; D3 <-- exercice suivantEND$:	LOAD.W	D1,#IMASTART2	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Pour <AFBOLD>excuter<AFROMAN> un logiciel, il suffit de le cliquer<CR>/	.ASCII	/avec le <AFBOLD>bouton de gauche<AFROMAN> de la souris.<CR>/	.ASCII	/<AFINV> Excutez le logiciel DESSIN4.CODE ... <AFDIR><CR>/	.B	0TEXT2$:	.ASCII	/Vous n'avez pas excut le logiciel DESSIN4.CODE !<CR>/	.ASCII	/<CR>/	.ASCII	/Cherchez mieux ...<CR>/	.B	0TEXT3$:	.ASCII	/Non, il faut utiliser le <AFBOLD>bouton de gauche<AFROMAN> !<CR>/	.ASCII	/<CR>/	.ASCII	/Excutez le logiciel DESSIN4.CODE ...<CR>/	.B	0	.EVEN;--------\\; START5  >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART5:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMADESSIN0	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	SCMO		; remet la souris	CALL	WAITMOUSE	; met le sablier	LOAD.W	D4,#50*5	NTREL	?DELMS		; attend ...	CALL	NORMMOUSE	; enlve le sablier	CALL	CCMO		; enlve la souris	LOAD.W	D3,#CR		; D3 <-- exercice suivant	LOAD.W	D1,#IMADESSIN0	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Dans quelques secondes,<CR>/	.ASCII	/le logiciel DESSIN4 sera charg ...<CR>/	.B	0	.EVEN;--------\\; START6  >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART6:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	D5,#-1-(2^BODCTRL) ; D5 <-- permet tout, sauf le contrle	CLR.W	(A6)+ODESOUT	; crayon	CLR.W	(A6)+ODESMOD	; noir	CLR.W	(A6)+ODESOBJ	; trait  main leve	CALL	DESFREE		; dessine librement ...	CALL	DESMAJ		; mise  jour ...	LOAD.W	D3,#CR		; D3 <-- exercice suivant	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Voil, vous pouvez <AFBOLD>effectuer un petit dessin<AFROMAN> en maintenant<CR>/	.ASCII	/press le bouton de gauche, tout en dplaant la souris.<CR>/	.ASCII	/Appuyez sur <AFDRECT>F0<AFFRECT> = <AFDRECT>Fin<AFFRECT> lorsque /	.ASCII	/avez termin ...<CR>/	.B	0	.EVEN;--------\\; START7  >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART7:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMASTART3	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	START7AFF	; affiche le nom du document	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A4,#R16"TAMST7DOWN	CALL	MOVEALL	LOAD.L	A4,#R16"STICPOS3	LOAD.W	D2,#10-1LOOPG$:	LOAD.W	D1,#7	CALL	STICINV	LOAD.W	D4,#10	NTREL	?DELMS;	LOAD.W	D1,#7	CALL	STICINV	LOAD.W	D4,#8	NTREL	?DELMS	DECJ.W,NMO D2,LOOPG$	LOAD.L	A4,#R16"TAMST7UP	CALL	MOVEALL	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMAFLDOWN	CALL	IMAGECODE	; libre l'image 	LOAD.W	D1,#IMASTART3	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Le <AFBOLD>document image<AFROMAN> que vous venez de crer est<CR>/	.ASCII	/maintenant contenu sur la disquette #MM0: ,<CR>/	.ASCII	/et son <AFBOLD>icne<AFROMAN> apparat en bas  droite :<CR>/	.B	0	.EVEN;----------\\; START7AFF >;----------/; Affiche le nom du document image.; in	-; out	-; mod	D7.WSTART7AFF:	PUSHM.L	D3,A3,A4	CALL	TXPPOPEN	CALL	START7PNI	; A3 <-- ^nom de l'image	LOAD.L	A4,A3	LOAD.W	D3,#-1CNT$:	INC.W	D3	TEST.B	(A4+)	JUMP,NE CNT$	MUL.WU	D3,(A0)+ODFCX	SR.W	D3,#1	SUB.W	D3,#313+ECRPX	NEG.W	D3	SWAP.W	D3	LOAD.W	D3,#ECRDY-1-13+ECRPY	SWAP.W	D3	LIB	?SETCURSAFF$:	LOAD.B	D3,(A3+)	JUMP',EQ EXIT$	LIB	?MINMAJ	LIB	?AFCAR	JUMP	AFF$EXIT$:	CALL	TXPPCLOSE	POPM.L	D3,A3,A4	RET;----------\\; START7PNI >;----------/; Donne le pointeur au nom du document image.; in	-; out	A3.L	^nom; mod	D7.W, A3.LSTART7PNI:	LOAD.L	A3,#(A6)+OSIMNM	TEST.B	(A3)	JUMP',NE FOUND$	LOAD.L	A3,#R16"NAME$FOUND$:	RETNAME$:	.ASCIZ	"EXEMPLE.IMAGE"	.EVEN;--------\\; START8  >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART8:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMASTART3	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	START7AFF	; affiche le nom du document	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*2	NTREL	?DELMS	LOAD.L	A4,#R16"STICPOS3	LOAD.W	D2,#10-1LOOPG$:	LOAD.W	D1,#2	CALL	STICINV	LOAD.W	D4,#10	NTREL	?DELMS;	LOAD.W	D1,#2	CALL	STICINV	LOAD.W	D4,#8	NTREL	?DELMS	DECJ.W,NMO D2,LOOPG$	LOAD.W	D4,#50*1	NTREL	?DELMS	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMASTART3	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Un <AFBOLD>dossier<AFROMAN> est une sorte de bote pouvant <AFBOLD>contenir<CR>/	.ASCII	/des documents<AFROMAN>. Dans l'exemple ci-dessous, le dossier<CR>/	.ASCII	/COURRIER: correspond  une telle bote :<CR>/	.B	0	.EVEN;--------\\; START9  >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART9:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	START9AFB	; dessine le texte	LOAD.W	D1,#IMASTART3	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	START7AFF	; affiche le nom du document	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	START9ACTION	; action ...	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMASTART2	CALL	IMAGECODE	; libre l'image	LOAD.W	D1,#IMASTART3	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/<AFBOLD>Dplaons<AFROMAN> * dans le dossier COURRIER:.<CR>/	.ASCII	/Pour cela, cliquez *, choisissez <AFINV>"dplace"<AFDIR><CR>/	.ASCII	/dans le menu, puis amenez la souris sur COURRIER: ...<CR>/	.B	0	.EVEN;-------------\\; START9ACTION >;=============/; Dplace *.IMAGE dans COURRIER:.; in	-; out	-; mod	D7.WSTART9ACTION:	PUSHM.L	D0..D6,A4SELECT$:	LOAD.L	A4,#R16"STICPOS3	CALL	STICACTION	; action ...	COMP.W	D3,#END	JUMP,EQ EXIT$	LOAD.L	A3,#R16"TEXT1$	COMP.W	D3,#KEYMDP	JUMP',NE FAUX$	LOAD.L	A3,#R16"TEXT2$	COMP.W	D1,#7	JUMP',EQ MENU$FAUX$:	CALL	CCMO		; enlve la souris	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	START9AFB	; dessine le texte	LOAD.W	D1,#IMABLUPP2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	DRAWCLOSE	; montre le dessin en mmoire	JUMP	SELECT$MENU$:	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	SCMO		; remet la souris	CALL	IFMOUSE	LOAD.L	D0,D4	LOAD.L	A3,#R16"TXMENUS	CLR.W	D3	LOAD.L	D4,#2^5		; D4 <-- "dite" gris	LIB	?MMENU		; choix selon mmenu ...	LOAD.L	D4,D0	CALL	PMOUSE	COMP.W	D3,#2	JUMP',EQ DEPL$	LOAD.L	A3,#R16"TEXT3$	JUMP	FAUX$DEPL$:	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	LOAD.W	D1,#7	CALL	STICPOS3	; D3/D4 <-- r1 et D5/D6 <-- r2	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	EX.L	D3,D5	EX.L	D4,D6	LIB	?DRTRAME	; efface l'icne du document image	SUB.W	D0,D5	SWAP.W	D0	SWAP.W	D5	SUB.W	D0,D5	SWAP.W	D0	SWAP.W	D5	LOAD.L	D4,D5	CALL	START9ITT	; allume le premier traitill	LOAD.W	D2,#-1DLOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE DEND$	CALL	IFMOUSE	JUMP,NE DLOOP$	LOAD.L	D3,D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	EX.L	D4,D5	CALL	START9ITT	; teint le traitill	LOAD.L	D4,D5	CALL	START9ITT	; allume le traitill	LOAD.L	D4,D3	LOAD.L	A4,#R16"STICPOS3	CALL	STICDET		; D1 <-- icne o est la souris	COMP.W	D1,D2	JUMP,EQ DLOOP$	EX.L	D1,D2	CALL	START9IRE	; teint l'ancien	LOAD.W	D1,D2	CALL	START9IRE	; allume le nouveau	JUMP	DLOOP$DEND$:	LOAD.L	D4,D5	CALL	START9ITT	; teint le dernier traitill	COMP.W	D2,#2		; est-on arriv dans "COURRIER:" ?	JUMP',EQ DOK$	CALL	CCMO		; enlve la souris	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	D1,#IMASTART3	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	START7AFF	; affiche le nom du document	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A3,#R16"TEXT4$	JUMP	FAUX$DOK$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	CALL	CCMO		; enlve la souris	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT5$	CALL	START9AFB	; dessine le texte	LOAD.W	D1,#IMASTART2	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D3,#CR		; D3 <-- exercice suivantEXIT$:	CALL	CCMO		; enlve la souris	POPM.L	D0..D6,A4	RETTEXT1$:	.ASCII	/Vous devez slectionner <AFBOLD>*<AFROMAN> avec<CR>/	.ASCII	/le <AFBOLD>bouton de droite<AFROMAN> de la souris !<CR>/	.ASCII	/Recommencez ...<CR>/	.B	0TEXT2$:	.ASCII	/Vous n'avez pas slectionn <AFBOLD>*<AFROMAN> !<CR>/	.ASCII	/Essayez encore ...<CR>/	.B	0TEXT3$:	.ASCII	/Vous avez bien slectionn *,<CR>/	.ASCII	/mais vous n'avez pas choisi <AFINV>"dplace"<AFDIR> dans le menu !<CR>/	.ASCII	/Recommencez ...<CR>/	.B	0TEXT4$:	.ASCII	/Lors du choix de <AFINV>"dplace"<AFDIR> dans le menu, il faut<CR>/	.ASCII	/<AFBOLD>maintenir le bouton press<AFROMAN>, et amener la souris<CR>/	.ASCII	/jusque dans le dossier <AFBOLD>COURRIER:<AFROMAN> !  Recommencez ...<CR>/	.B	0TEXT5$:	.ASCII	/Oui, c'est juste !<CR>/	.ASCII	/Le document * n'est plus visible,<CR>/	.ASCII	/mais il est bien <AFBOLD>contenu dans le dossier COURRIER:<AFROMAN> !<CR>/	.B	0	.EVEN;----------\\; START9AFB >;==========/; Affiche un texte dans une bulle (BULLEL).; Les "*" sont remplaces par le nom de l'image !; in	A3.L	^texte; out	-; mod	D7.WSTART9AFB:	PUSHM.L	D3,A2..A4	LOAD.L	A2,A3	LOAD.L	A4,#(A6)+OBUDISXFER$:	LOAD.B	D2,(A2+)	JUMP',EQ AFF$	COMP.B	D2,#'*	JUMP',EQ NAME$	LOAD.B	(A4+),D2	JUMP	XFER$NAME$:	CALL	START7PNI	; A3 <-- ^nom de l'imageNXFER$:	LOAD.B	D3,(A3+)	JUMP,EQ XFER$	LIB	?MINMAJ	LOAD.B	(A4+),D3	JUMP	NXFER$AFF$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUDIS	CALL	TXBULLEL	; dessine le texte	POPM.L	D3,A2..A4	RET;----------\\; START9IRE >;----------/; Inverse ou efface tout le cadre d'une icne.;	                (1);	            |----|----|;	            |         |;	        (8)-|         |-(2);	        (7) |         | (3);	      |--|--|         |--|--|;	  (6)-|                     |-(4);	      |----------|----------|;	                (5); in	D1.W	rang (0..n); out	-; mod	D7.WSTART9IRE:	PUSHM.L	D0..D6	COMP.W	D1,#4	JUMP,HS EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.W	D2,#INVDOT	CALL	STICPOS3	; D3/D4 <-- r1 et D5/D6 <-- r2	JUMP,NE EXIT$	LOAD.L	D0,D3	LOAD.L	D1,D4	TEST.L	D6	JUMP,EQ RECT$; Corrige D0/D1 et D5/D6 pour laisser un petit filet blanc.	INC.W	D5	SUB.W	D6,#2	SWAP.W	D6	DEC.W	D6	SWAP.W	D6; Dessine les 8 surfaces tout autour (voir dessin ci-dessus).	LOAD.L	D3,D0	SUB.W	D3,#EPCADIC	SWAP.W	D3	SUB.W	D3,#EPCADIC	SWAP.W	D3	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D1	ADD.W	D4,#EPCADIC*2	LIB	?DRMATRIX	; surface (1)	LOAD.L	D3,D0	ADD.W	D3,D1	LOAD.L	D4,D1	LOAD.W	D4,#EPCADIC	LIB	?DRMATRIX	; surface (2)	LOAD.L	D3,D5	SWAP.W	D3	SUB.W	D3,#EPCADIC	SWAP.W	D3	LOAD.W	D3,D0	ADD.W	D3,D1	ADD.W	D3,#EPCADIC	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D5	ADD.W	D4,D6	SUB.W	D4,D0	SUB.W	D4,D1	LIB	?DRMATRIX	; surface (3)	LOAD.L	D3,D5	ADD.W	D3,D6	LOAD.L	D4,D6	LOAD.W	D4,#EPCADIC	LIB	?DRMATRIX	; surface (4)	LOAD.L	D3,D5	SWAP.W	D3	SWAP.W	D6	ADD.W	D3,D6	SWAP.W	D6	SWAP.W	D3	SUB.W	D3,#EPCADIC	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D6	ADD.W	D4,#EPCADIC*2	LIB	?DRMATRIX	; surface (5)	LOAD.L	D3,D5	SUB.W	D3,#EPCADIC	LOAD.L	D4,D6	LOAD.W	D4,#EPCADIC	LIB	?DRMATRIX	; surface (6)	LOAD.L	D3,D5	SUB.W	D3,#EPCADIC	SWAP.W	D3	SUB.W	D3,#EPCADIC	SWAP.W	D3	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D0	SUB.W	D4,D5	LIB	?DRMATRIX	; surface (7)	LOAD.L	D3,D0	SUB.W	D3,#EPCADIC	LOAD.L	D4,D1	LOAD.W	D4,#EPCADIC	LIB	?DRMATRIX	; surface (8)	JUMP	EXIT$RECT$:	INC.W	D0	SWAP.W	D0	INC.W	D0	SWAP.W	D0	SUB.W	D1,#4	SWAP.W	D1	SUB.W	D1,#3	SWAP.W	D1	LOAD.L	D3,D0	SUB.W	D3,#EPCADIC	SWAP.W	D3	SUB.W	D3,#EPCADIC	SWAP.W	D3	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D1	ADD.W	D4,#EPCADIC*2	LIB	?DRMATRIX	; surface (1)	LOAD.L	D3,D0	ADD.W	D3,D1	LOAD.L	D4,D1	LOAD.W	D4,#EPCADIC	LIB	?DRMATRIX	; surface (2)	LOAD.L	D3,D0	SWAP.W	D3	SWAP.W	D1	ADD.W	D3,D1	SWAP.W	D1	SWAP.W	D3	SUB.W	D3,#EPCADIC	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D1	ADD.W	D4,#EPCADIC*2	LIB	?DRMATRIX	; surface (3)	LOAD.L	D3,D0	SUB.W	D3,#EPCADIC	LOAD.L	D4,D1	LOAD.W	D4,#EPCADIC	LIB	?DRMATRIX	; surface (4)EXIT$:	POPM.L	D0..D6	RET;----------\\; START9ITT >;----------/; Met en pointill une icne, n'importe o dans l'cran !;	                (1);	            |----|----|;	            |         |;	        (8)-|         |-(2);	        (7) |         | (3);	      |--|--|         |--|--|;	  (6)-|                     |-(4);	      |----------|----------|;	                (5); in	D4.L	coordonne coin sup/gauche icne; out	-; mod	D7.WSTART9ITT:	PUSHM.L	D2..D4	LIB	?AFTIM	.B	MAPTT	.B	B'01010101	; <map>	.B	1		; <chelle>	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT	LOAD.L	D3,D4	ADD.W	D3,#-2	SWAP.W	D3	ADD.W	D3,#-2	SWAP.W	D3	LOAD.L	D4,#+51	LIB	?DRSEG		; (1) horizontale dessus	OR.W	D2,#NCTDOT	; D2 <-- plus de rz du traitill	LOAD.W	D4,#+30	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; (2)	LOAD.L	D4,#+35	LIB	?DRSEG		; (3)	LOAD.W	D4,#14	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; (4)	CLR.L	D4	LOAD.W	D4,#-121	LIB	?DRSEG		; (5) horizontale dessous	LOAD.W	D4,#-14	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; (6)	LOAD.L	D4,#+35	LIB	?DRSEG		; (7)	LOAD.W	D4,#-30	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; (8)	POPM.L	D2..D4	RET;--------\\; START10 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART10:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMASTART2	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoireLOOP$:	LOAD.L	A4,#R16"STICPOS2	CALL	STICACTION	; action ...	COMP.W	D3,#END	JUMP',EQ END$	LOAD.L	A3,#R16"TEXT3$	COMP.W	D3,#KEYMGP	JUMP',NE FAUX$	LOAD.L	A3,#R16"TEXT2$	COMP.W	D1,#2	JUMP',EQ JUSTE$FAUX$:	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMABLUPQ2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	DRAWCLOSE	; montre le dessin en mmoire	JUMP	LOOP$JUSTE$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.W	D3,#CR		; D3 <-- exercice suivantEND$:	LOAD.W	D1,#IMASTART2	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/<AFBOLD>Ouvrons<AFROMAN> le dossier COURRIER:, pour voir son contenu.<CR>/	.ASCII	/Pour cela, il suffit de cliquer son icne avec le<CR>/	.ASCII	/<AFBOLD>bouton de gauche<AFROMAN> de la souris ...<CR>/	.B	0TEXT2$:	.ASCII	/Vous n'avez pas ouvert le dossier COURRIER: !<CR>/	.ASCII	/<CR>/	.ASCII	/Cherchez mieux ...<CR>/	.B	0TEXT3$:	.ASCII	/Non, il faut utiliser le <AFBOLD>bouton de gauche<AFROMAN> !<CR>/	.ASCII	/<CR>/	.ASCII	/Ouvrez le dossier COURRIER: ...<CR>/	.B	0	.EVEN;--------\\; START11 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART11:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	START9AFB	; dessine le texte	LOAD.W	D1,#IMASTART4	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	START11AFF	; affiche le nom du document	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*2	NTREL	?DELMS		; attend ...	LOAD.L	A4,#R16"STICPOS4	LOAD.W	D2,#10-1LOOPG$:	LOAD.W	D1,#1	CALL	STICINV	LOAD.W	D4,#10	NTREL	?DELMS;	LOAD.W	D1,#1	CALL	STICINV	LOAD.W	D4,#8	NTREL	?DELMS	DECJ.W,NMO D2,LOOPG$	LOAD.W	D4,#50*1	NTREL	?DELMS		; attend ...	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMASTART4	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Une <AFBOLD>nouvelle fentre<AFROMAN> s'ouvre, qui donne le contenu<CR>/	.ASCII	/du dossier COURRIER:. On constate que le document<CR>/	.ASCII	/* y est bien contenu :<CR>/	.B	0	.EVEN;-----------\\; START11AFF >;-----------/; Affiche le nom du document image.; in	-; out	-; mod	D7.WSTART11AFF:	PUSHM.L	D3,A3,A4	CALL	TXPPOPEN	CALL	START7PNI	; A3 <-- ^nom de l'image	LOAD.L	A4,A3	LOAD.W	D3,#-1CNT$:	INC.W	D3	TEST.B	(A4+)	JUMP,NE CNT$	MUL.WU	D3,(A0)+ODFCX	SR.W	D3,#1	SUB.W	D3,#69+ECRPX	NEG.W	D3	SWAP.W	D3	LOAD.W	D3,#ECRDY-1-8+ECRPY	SWAP.W	D3	LIB	?SETCURSAFF$:	LOAD.B	D3,(A3+)	JUMP',EQ EXIT$	LIB	?MINMAJ	LIB	?AFCAR	JUMP	AFF$EXIT$:	CALL	TXPPCLOSE	POPM.L	D3,A3,A4	RET;--------\\; START12 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART12:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	START9AFB	; dessine le texte	LOAD.W	D1,#IMASTART4	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	START11AFF	; affiche le nom du document	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	START12ACTION	; action ...	LOAD.W	D3,#CR		; D3 <-- exercice suivant	LOAD.W	D1,#IMASTARTVISU	CALL	IMAGECODE	; libre l'image	LOAD.W	D1,#IMASTART4	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/<AFBOLD>Visualisons<AFROMAN> le document *.<CR>/	.ASCII	/Pour cela, cliquez * avec le bouton<CR>/	.ASCII	/de droite, puis choisissez <AFINV>"visualise"<AFDIR>.<CR>/	.B	0	.EVEN;--------------\\; START12ACTION >;==============/; Visualise le document image.; in	-; out	-; mod	D7.WSTART12ACTION:	PUSHM.L	D0..D4,A4SELECT$:	LOAD.L	A4,#R16"STICPOS4	CALL	STICACTION	; action ...	COMP.W	D3,#END	JUMP,EQ EXIT$	LOAD.L	A3,#R16"TEXT1$	COMP.W	D3,#KEYMDP	JUMP',NE FAUX$	LOAD.L	A3,#R16"TEXT2$	COMP.W	D1,#1	JUMP',EQ MENU$FAUX$:	CALL	CCMO		; enlve la souris	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	START9AFB	; dessine le texte	LOAD.W	D1,#IMABLUPP2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	DRAWCLOSE	; montre le dessin en mmoire	JUMP	SELECT$MENU$:	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	SCMO		; remet la souris	CALL	IFMOUSE	LOAD.L	D0,D4	LOAD.L	A3,#R16"TXMENUS	CLR.W	D3	LOAD.L	D4,#2^5		; D4 <-- "dite" gris	LIB	?MMENU		; choix selon mmenu ...	LOAD.L	D4,D0	CALL	PMOUSE	COMP.W	D3,#6	JUMP',EQ VISU$	LOAD.L	A3,#R16"TEXT3$	JUMP	FAUX$VISU$:	CALL	CCMO		; enlve la souris	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT4$	CALL	START9AFB	; dessine le texte	CALL	START12VISU	; affiche l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A3,#R16"TXMENU$	LIB	?AFMENU	CALL	SCMO		; remet la sourisVLOOP$:	LIB	?GETCAR		; attend souris/clavier ...	COMP.W	D3,#KEYMGR	JUMP,EQ VLOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ VLOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ VLOOP$	COMP.W	D3,#F0	JUMP',EQ VEND$VBIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	VLOOP$VEND$:	CALL	AFMENUNILEXIT$:	CALL	CCMO		; enlve la souris	POPM.L	D0..D4,A4	RETTEXT1$:	.ASCII	/Vous devez slectionner <AFBOLD>*<AFROMAN> avec<CR>/	.ASCII	/le <AFBOLD>bouton de droite<AFROMAN> de la souris !<CR>/	.ASCII	/Recommencez ...<CR>/	.B	0TEXT2$:	.ASCII	/Vous n'avez pas slectionn <AFBOLD>*<AFROMAN> !<CR>/	.ASCII	/Essayez encore ...<CR>/	.B	0TEXT3$:	.ASCII	/Vous avez bien slectionn *,<CR>/	.ASCII	/mais vous n'avez pas choisi <AFINV>"visualise"<AFDIR> dans le menu !<CR>/	.ASCII	/Recommencez ...<CR>/	.B	0TEXT4$:	.ASCII	/Appuyez sur <AFDRECT>F0<AFFRECT> = <AFDRECT>Fin<AFFRECT> lorsque<CR>/	.ASCII	/vous avez vu le document ...<CR>/	.B	0TXMENU$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"<'>><'>><'>>"	.ASCIZ	"Suivant"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Slectionne"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Tout Ngatif     "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN;------------\\; START12VISU >;------------/; Affiche le document image.; in	-; out	-; mod	D7.WSTART12VISU:	PUSHM.L	D1..D5,A3,A4	LOAD.W	D1,#IMASTARTVISU	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	START12AFF	; affiche le nom du document	TEST.L	(A6)+OSIMPT	JUMP',EQ EXIT$	CLR.L	D3	CLR.L	D4	CALL	INVTRAME	LIB	?DRMDEF	LOAD.L	D3,#H'10000*(ECRDY-1-173+ECRPY)+(21+ECRPX)	LOAD.L	D4,#H'10000*153+371	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'emplacement	LOAD.L	D3,#H'10000*((175-153)/2)+0	LOAD.L	A3,(A6)+OSIMPT	LOAD.W	D5,#(282/8)+1	LOAD.L	D4,#H'10000*(ECRDY-1-173+ECRPY)+(21+((371-282)/2)+ECRPX)	LOAD.L	A4,#0	LOAD.L	D1,#H'10000*153+282	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	; met le documentEXIT$:	POPM.L	D1..D5,A3,A4	RET;-----------\\; START12AFF >;-----------/; Affiche le nom du document image.; in	-; out	-; mod	D7.WSTART12AFF:	PUSHM.L	D3,A3	CALL	TXPPOPEN	LOAD.L	D3,#H'10000*(ECRDY-1-196+ECRPY)+(191+ECRPX)	LIB	?SETCURS	CALL	START7PNI	; A3 <-- ^nom de l'imageAFF$:	LOAD.B	D3,(A3+)	JUMP',EQ EXIT$	LIB	?MINMAJ	LIB	?AFCAR	JUMP	AFF$EXIT$:	CALL	TXPPCLOSE	POPM.L	D3,A3	RET;--------\\; START13 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART13:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	START9AFB	; dessine le texte	LOAD.W	D1,#IMASTART4	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	START11AFF	; affiche le nom du document	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	D3,#H'10000*(ECRPY+158)+(ECRPX-7)	CALL	START13FAR	; flche clignottanteLOOP$:	LOAD.L	A4,#R16"STICPOS4	CALL	STICACTION	; action ...	COMP.W	D3,#END	JUMP',EQ END$	LOAD.L	A3,#R16"TEXT2$	TEST.W	D1	JUMP',EQ JUSTE$FAUX$:	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMABLUPQ2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	DRAWCLOSE	; montre le dessin en mmoire	JUMP	LOOP$JUSTE$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.W	D3,#CR		; D3 <-- exercice suivantEND$:	LOAD.W	D1,#IMASTART4	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Pour <AFBOLD>fermer<AFROMAN> le dossier COURRIER:, il faut cliquer<CR>/	.ASCII	/dans sa case de fermeture, en haut  gauche de<CR>/	.ASCII	/sa fentre ...<CR>/	.B	0TEXT2$:	.ASCII	/Vous n'avez pas cliqu dans la case de fermeture !<CR>/	.ASCII	/Cette case est situe en haut  gauche de la fentre<CR>/	.ASCII	/du dossier COURRIER:. Cherchez mieux ...<CR>/	.B	0	.EVEN;-----------\\; START13FAR >;===========/; Flash arrow.; in	D3.L	extrmit (y;x); out	-; mod	D7.WSTART13FAR:	PUSHM.L	D1..D4	LIB	?COLORPUSH	PUSH.L	D3	LOAD.L	D3,#COLORROUGE	LIB	?COLORSR	LOAD.L	D3,#COLORJAUNE	LIB	?COLORCR	POP.L	D3	LIB	?AFTIM	.B	PEN	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'01111110	.B	B'00111100	.B	0	.EVEN	LOAD.W	D1,#12+1-1	LOAD.W	D2,#SETDOT	CALL	INVMODE	OR.W	D2,#PENDOTLOOP$:	PUSH.L	D3	CLR.L	D4	LOAD.W	D4,#-40	LIB	?DRSEG	POP.L	D3	PUSH.L	D3	LOAD.W	D4,#-10	SWAP.W	D4	LOAD.W	D4,#-10	LIB	?DRSEG	POP.L	D3	PUSH.L	D3	LOAD.W	D4,#+10	SWAP.W	D4	LOAD.W	D4,#-10	LIB	?DRSEG	POP.L	D3	LOAD.W	D4,#10	NTREL	?DELMS	TNOT.L	D2:#0		; D2 <-- SETDOT/CLRDOT	DECJ.W,NMO D1,LOOP$	LIB	?COLORPOP	POPM.L	D1..D4	RET;--------\\; START14 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART14:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	START9AFB	; dessine le texte	LOAD.W	D1,#IMASTART2	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	D3,#H'10000*(ECRPY+99)+(ECRPX-7)	CALL	START13FAR	; flche clignottanteLOOP$:	LOAD.L	A4,#R16"STICPOS5	CALL	STICACTION	; action ...	COMP.W	D3,#END	JUMP',EQ END$	LOAD.L	A3,#R16"TEXT2$	TEST.W	D1	JUMP',EQ JUSTE$FAUX$:	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMABLUPF2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	DRAWCLOSE	; montre le dessin en mmoire	JUMP	LOOP$JUSTE$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.W	D3,#CR		; D3 <-- exercice suivantEND$:	LOAD.W	D1,#IMASTART2	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Pour <AFBOLD>fermer<AFROMAN> la disquette #MM0:, il faut cliquer<CR>/	.ASCII	/dans sa case de fermeture, en haut  gauche de<CR>/	.ASCII	/sa fentre ...<CR>/	.B	0TEXT2$:	.ASCII	/Vous n'avez pas cliqu dans la case de fermeture !<CR>/	.ASCII	/Cette case est situe en haut  gauche de la fentre<CR>/	.ASCII	/de #MM0:. Cherchez mieux ...<CR>/	.B	0	.EVEN;--------\\; START15 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART15:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMASTART1	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMASTART1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/La disquette #MM0: est <AFBOLD>ferme<AFROMAN>.<CR>/	.ASCII	/C'est seulement maintenant qu'il est possible<CR>/	.ASCII	/de la <AFBOLD>sortir<AFROMAN> du lecteur de disquettes ...<CR>/	.B	0	.EVEN;--------\\; START16 >;========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WSTART16:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGDIAG!2^BFGINVY	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMAFLOPPY	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMAFLOPPY	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/<AFBOLD>Une disquette ne peut pas tre enleve n'importe<CR>/	.ASCII	/quand<AFROMAN>. Deux icnes en haut de l'cran indiquent<CR>/	.ASCII	/l'tat des lecteurs de disquettes ...<CR>/	.B	0	.EVENTXMENUS:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSDETRUIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSDEPLACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  dplace  "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMOVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSDUPLIQUE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  duplique "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMOVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSMODIF	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  modifie.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSEDIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dite.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSVISU	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  visualise.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSPRINT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  imprime.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSLOCK	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  verrouille.."	.B	0	.EVEN;-----------\\; STICACTION >;===========/; Attente et action dans une icne.; in	A4.L	^routine STICPOSx; out	D3.W	touche presse;	D1.W	rang icne clique (0..n); mod	D1.L, D3.L, D7.WSTICACTION:	PUSHM.L	D2,D4	CALL	CLRFIFO		; vide le fifo du clavier	CALL	SCMO		; remet la sourisLOOP$:	LIB	?GETCAR		; attend souris/clavier ...	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	COMP.W	D3,#END	JUMP',EQ END$	COMP.W	D3,#F0	JUMP',EQ END$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	CALL	STICMOVE	; D1 <-- rang (0..n)	JUMP,NE BIP$	JUMP'	EXIT$END$:	LOAD.W	D3,#ENDEXIT$:	CALL	CCMO		; enlve la souris	POPM.L	D2,D4	RET;---------\\; STICMOVE >;=========/; Action dans une icne.; in	D4.L	position de la souris (y;x);	A4.L	^routine STICPOSx; out	D1.W	rang (0..n);	D7.W	erreur; mod	D1.L, D7.WSTICMOVE:	PUSHM.L	D2..D4	CALL	STICDET		; D1 <-- icne o est la souris	JUMP',NE EXIT$	CALL	STICINV		; allume le premier	LOAD.W	D2,D1LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	STICDET		; D1 <-- icne o est la souris	COMP.W	D1,D2	JUMP,EQ LOOP$	EX.L	D1,D2	CALL	STICINV		; teint l'ancien	LOAD.W	D1,D2	CALL	STICINV		; allume le nouveau	JUMP	LOOP$END$:	LOAD.W	D1,D2	CALL	STICINV		; teint le dernier	CALL	(A4)		; D3/D4 <-- position/dimensionsEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; STICDET >;--------/; Dtecte dans quelle icne est la souris.; in	D4.L	position de la souris (y;x);	A4.L	^routine STICPOSx; out	D1.W	rang (0..n);	D7.W	erreur; mod	D1.L, D7.WSTICDET:	PUSHM.L	D0,D2..D6	LOAD.W	D0,D4		; D0 <-- position en X	LOAD.L	D2,D4	SWAP.W	D2		; D2 <-- position en Y	LOAD.W	D1,#-1LOOP$:	INC.W	D1	CALL	(A4)		; D3/D4 <-- position/dimensions	JUMP,NE EXIT$	COMP.W	D0,D3	JUMP',LO SECOND$	ADD.W	D3,D4	COMP.W	D0,D3	JUMP',HS SECOND$	SWAP.W	D3	SWAP.W	D4	COMP.W	D2,D3	JUMP',LO SECOND$	ADD.W	D3,D4	COMP.W	D2,D3	JUMP',LO EXIT$SECOND$:	TEST.L	D6	JUMP,EQ LOOP$	COMP.W	D0,D5	JUMP,LO LOOP$	ADD.W	D5,D6	COMP.W	D0,D5	JUMP,HS LOOP$	SWAP.W	D5	SWAP.W	D6	COMP.W	D2,D5	JUMP,LO LOOP$	ADD.W	D5,D6	COMP.W	D2,D5	JUMP,HS LOOP$EXIT$:	POPM.L	D0,D2..D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; STICINV >;--------/; Inverse une icne.; in	D1.W	rang (0..n);	A4.L	^routine STICPOSx; out	-; mod	D7.WSTICINV:	PUSHM.L	D2..D6	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_PPHILI	LIB	?COLORSR	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	(A4)		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	LOAD.L	D3,D5	LOAD.L	D4,D6	JUMP',EQ EXIT$	LIB	?DRTRAMEEXIT$:	LIB	?COLORPOP	POPM.L	D2..D6	RET;---------\\; STICPOS1 >;---------/; Donne la position d'une icne dans l'image START1.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D5.L	position (y;x);	D6.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D5.L, D6.L, D7.WSTICPOS1:	PUSH.L	D1	COMP.W	D1,#2	JUMP',LO PHYS$	LOAD.W	D7,#1	JUMP	EXIT$PHYS$:	AND.L	D1,#H'FFFF	DIV.WU	D1,#5	LOAD.W	D3,D1	MUL.WU	D3,#51	ADD.W	D3,#ECRDY-1-178	SWAP.W	D3	SWAP.W	D1	MUL.WU	D1,#122	ADD.W	D1,#44	LOAD.W	D3,D1;	JUMP'	CHAP$CHAP$:	LOAD.L	D5,D3	ADD.W	D5,#-35	SWAP.W	D5	ADD.W	D5,#+30	SWAP.W	D5	LOAD.L	D4,#H'10000*30+51	LOAD.L	D6,#H'10000*14+121OK$:	ADD.W	D3,#ECRPX	SWAP.W	D3	ADD.W	D3,#ECRPY	SWAP.W	D3	ADD.W	D5,#ECRPX	SWAP.W	D5	ADD.W	D5,#ECRPY	SWAP.W	D5	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;---------\\; STICPOS2 >;---------/; Donne la position d'une icne dans l'image START2.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D5.L	position (y;x);	D6.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D5.L, D6.L, D7.WSTICPOS2:	PUSH.L	D1	COMP.W	D1,#2	JUMP',LO PHYS$	COMP.W	D1,#2+5	JUMP',LO MM0$	LOAD.W	D7,#1	JUMP	EXIT$PHYS$:	AND.L	D1,#H'FFFF	DIV.WU	D1,#5	LOAD.W	D3,D1	MUL.WU	D3,#51	ADD.W	D3,#ECRDY-1-178	SWAP.W	D3	SWAP.W	D1	MUL.WU	D1,#122	ADD.W	D1,#44	LOAD.W	D3,D1	JUMP'	CHAP$MM0$:	SUB.W	D1,#2	AND.L	D1,#H'FFFF	DIV.WU	D1,#3	LOAD.W	D3,D1	MUL.WU	D3,#51	ADD.W	D3,#ECRDY-1-105	SWAP.W	D3	SWAP.W	D1	MUL.WU	D1,#122	ADD.W	D1,#44	LOAD.W	D3,D1;	JUMP'	CHAP$CHAP$:	LOAD.L	D5,D3	ADD.W	D5,#-35	SWAP.W	D5	ADD.W	D5,#+30	SWAP.W	D5	LOAD.L	D4,#H'10000*30+51	LOAD.L	D6,#H'10000*14+121OK$:	ADD.W	D3,#ECRPX	SWAP.W	D3	ADD.W	D3,#ECRPY	SWAP.W	D3	ADD.W	D5,#ECRPX	SWAP.W	D5	ADD.W	D5,#ECRPY	SWAP.W	D5	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;---------\\; STICPOS3 >;---------/; Donne la position d'une icne dans l'image START3.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D5.L	position (y;x);	D6.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D5.L, D6.L, D7.WSTICPOS3:	PUSH.L	D1	COMP.W	D1,#2	JUMP',LO PHYS$	COMP.W	D1,#2+6	JUMP',LO MM0$	LOAD.W	D7,#1	JUMP	EXIT$PHYS$:	AND.L	D1,#H'FFFF	DIV.WU	D1,#5	LOAD.W	D3,D1	MUL.WU	D3,#51	ADD.W	D3,#ECRDY-1-178	SWAP.W	D3	SWAP.W	D1	MUL.WU	D1,#122	ADD.W	D1,#44	LOAD.W	D3,D1	JUMP'	CHAP$MM0$:	SUB.W	D1,#2	AND.L	D1,#H'FFFF	DIV.WU	D1,#3	LOAD.W	D3,D1	MUL.WU	D3,#51	ADD.W	D3,#ECRDY-1-105	SWAP.W	D3	SWAP.W	D1	MUL.WU	D1,#122	ADD.W	D1,#44	LOAD.W	D3,D1;	JUMP'	CHAP$CHAP$:	LOAD.L	D5,D3	ADD.W	D5,#-35	SWAP.W	D5	ADD.W	D5,#+30	SWAP.W	D5	LOAD.L	D4,#H'10000*30+51	LOAD.L	D6,#H'10000*14+121OK$:	ADD.W	D3,#ECRPX	SWAP.W	D3	ADD.W	D3,#ECRPY	SWAP.W	D3	ADD.W	D5,#ECRPX	SWAP.W	D5	ADD.W	D5,#ECRPY	SWAP.W	D5	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;---------\\; STICPOS4 >;---------/; Donne la position d'une icne dans l'image START4.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D5.L	position (y;x);	D6.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D5.L, D6.L, D7.WSTICPOS4:	PUSH.L	D1	TEST.W	D1	JUMP',EQ CLOSE$	COMP.W	D1,#1+2	JUMP',LO MM0$	LOAD.W	D7,#1	JUMP	EXIT$CLOSE$:	LOAD.L	D3,#H'10000*(ECRDY-1-64)+7	LOAD.L	D4,#H'10000*14+14	CLR.L	D5	CLR.L	D6	JUMP	OK$MM0$:	SUB.W	D1,#1	AND.L	D1,#H'FFFF	DIV.WU	D1,#3	LOAD.W	D3,D1	MUL.WU	D3,#51	ADD.W	D3,#ECRDY-1-48	SWAP.W	D3	SWAP.W	D1	MUL.WU	D1,#122	ADD.W	D1,#44	LOAD.W	D3,D1;	JUMP'	CHAP$CHAP$:	LOAD.L	D5,D3	ADD.W	D5,#-35	SWAP.W	D5	ADD.W	D5,#+30	SWAP.W	D5	LOAD.L	D4,#H'10000*30+51	LOAD.L	D6,#H'10000*12+121OK$:	ADD.W	D3,#ECRPX	SWAP.W	D3	ADD.W	D3,#ECRPY	SWAP.W	D3	ADD.W	D5,#ECRPX	SWAP.W	D5	ADD.W	D5,#ECRPY	SWAP.W	D5	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;---------\\; STICPOS5 >;---------/; Donne la position d'une icne dans l'image START5.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D5.L	position (y;x);	D6.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D5.L, D6.L, D7.WSTICPOS5:	PUSH.L	D1	TEST.W	D1	JUMP',EQ CLOSE$	LOAD.W	D7,#1	JUMP	EXIT$CLOSE$:	LOAD.L	D3,#H'10000*(ECRDY-1-123)+7	LOAD.L	D4,#H'10000*14+14	CLR.L	D5	CLR.L	D6;	JUMP'	OK$OK$:	ADD.W	D3,#ECRPX	SWAP.W	D3	ADD.W	D3,#ECRPY	SWAP.W	D3	ADD.W	D5,#ECRPX	SWAP.W	D5	ADD.W	D5,#ECRPY	SWAP.W	D5	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET	.END