	.SBTTL	BJIMAGE.ASI;----------\\; IMAGEAFFF >;==========/; Affiche une partie d'image, avec le fond.; in	D1.W	numro de l'image (0..n);	D2.L	position dans l'cran (y;x);	D3.L	position dans l'image (y;x);	D4.L	dimensions (dy;dx)  (si zro => tout); out	-; mod	D7.WIMAGEAFFF:	PUSHM.L	D1..D5,A1..A4	CALL	IMAGECALCFOND	; calcule le fond	JUMP,NE EXIT$	CALL	MOVECOLOR	; choix des couleurs pour l'image	LOAD.L	A1,#(A6)+OBKTAB	MUL.WU	D1,#LBK	ADD.L	A1,D1		; A1 <-- ^dans OBKTAB	LOAD.L	A2,(A1)+OBKPIC	LOAD.L	D1,D4	JUMP',NE DIMOK$	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	SWAP.W	D1	LOAD.W	D1,(A2)+OIMDLX	; D1 <-- largeur de l'imageDIMOK$:	COMP.W	D1,(A2)+OIMDLX	JUMP',LS DIMX$	LOAD.W	D1,(A2)+OIMDLXDIMX$:	SWAP.W	D1	COMP.W	D1,(A2)+OIMDLY	JUMP',LS DIMY$	LOAD.W	D1,(A2)+OIMDLYDIMY$:	SWAP.W	D1	LOAD.L	A3,(A1)+OBKPIF	; A3 <-- ^source	LOAD.W	D5,(A2)+OIMDLX	SR.W	D5,#3		; D5 <-- Iy source	LOAD.L	A4,#0		; A4 <-- ^destination (dans l'cran)	LOAD.L	D4,D2		; D4 <-- position destination	LOAD.W	D2,#CLRDOT!2^BDSTCOUL	TEST.B	(A6)+OINV	; affichage invers ?	JUMP',F FOND$	LOAD.W	D2,#SETDOT!2^BDSTCOULFOND$:	CALL	DRRASTER	; efface le fond	LOAD.L	A3,(A1)+OBKPID	; A3 <-- ^source	LOAD.W	D2,#SETDOT!2^BDSTCOUL	TEST.B	(A6)+OINV	; affichage invers ?	JUMP',F CHAIR$	LOAD.W	D2,#CLRDOT!2^BDSTCOULCHAIR$:	CALL	DRRASTER	; allume la chair	LIB	?COLORPOP	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; IMAGEAFF >;=========/; Affiche une partie d'image.; in	D1.W	numro de l'image (0..n);	D2.L	position dans l'cran (y;x);	D3.L	position dans l'image (y;x);	D4.L	dimensions (dy;dx)  (si zro => tout); out	-; mod	D7.WIMAGEAFF:	PUSHM.L	D1..D5,A1..A4	CALL	IMAGEDECO	; dcode l'image	JUMP,NE EXIT$	CALL	MOVECOLOR	; choix des couleurs pour l'image	LOAD.L	A1,#(A6)+OBKTAB	MUL.WU	D1,#LBK	ADD.L	A1,D1		; A1 <-- ^dans OBKTAB	LOAD.L	A2,(A1)+OBKPIC	LOAD.L	D1,D4	JUMP',NE DIMOK$	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	SWAP.W	D1	LOAD.W	D1,(A2)+OIMDLX	; D1 <-- largeur de l'imageDIMOK$:	COMP.W	D1,(A2)+OIMDLX	JUMP',LS DIMX$	LOAD.W	D1,(A2)+OIMDLXDIMX$:	SWAP.W	D1	COMP.W	D1,(A2)+OIMDLY	JUMP',LS DIMY$	LOAD.W	D1,(A2)+OIMDLYDIMY$:	SWAP.W	D1	LOAD.L	A3,(A1)+OBKPID	; A3 <-- ^source	LOAD.W	D5,(A2)+OIMDLX	SR.W	D5,#3		; D5 <-- Iy source	LOAD.L	A4,#0		; A4 <-- ^destination (dans l'cran)	LOAD.L	D4,D2		; D4 <-- position destination	LOAD.W	D2,#LOADDOT	TEST.B	(A6)+OINV	; affichage invers ?	JUMP',F DRAW$	LOAD.W	D2,#LOADDOT!CPLDOTDRAW$:	CALL	DRRASTER	; affiche l'image	LIB	?COLORPOP	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------------\\; IMAGECALCFOND >;--------------/; Calcule le fond d'une image.; in	D1.W	numro de l'image (0..n); out	D7.W	erreur; mod	D7.WIMAGECALCFOND:	PUSHM.L	D1..D4,A1..A4	CALL	IMAGEDECO	; dcode l'image	JUMP,NE EXIT$	LOAD.L	A1,#(A6)+OBKTAB	MUL.WU	D1,#LBK	ADD.L	A1,D1		; A1 <-- ^dans OBKTAB	CLR.W	D7		; D7 <-- ok	TEST.L	(A1)+OBKPIF	; image fond existe dj ?	JUMP,NE EXIT$		; oui => EXIT$	LOAD.L	A2,(A1)+OBKPIC	; A2 <-- ^en-tte	LOAD.W	D4,(A2)+OIMDLX	SR.W	D4,#3	MUL.WU	D4,(A2)+OIMDLY	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour le fond	JUMP,NE EXIT$	LOAD.L	(A1)+OBKPIF,A4	LOAD.L	A3,(A1)+OBKPIDXFER$:	LOAD.B	(A4+),(A3+)	; OBKPIF <-- OBKPID	DEC.L	D4	JUMP,NE XFER$	LOAD.L	A4,(A1)+OBKPIF	LOAD.W	D4,(A2)+OIMDLY	SWAP.W	D4	LOAD.W	D4,(A2)+OIMDLX	CALL	OPEDISMAT	LOAD.L	(A0)+ODFTRA+0,#-1	LOAD.L	(A0)+ODFTRA+4,#-1	CLR.L	D3	CALL	DRFILL		; rempli le tour	CALL	DRINV		; inverse tout	CALL	CLODISMAT	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGEDECO >;----------/; Dcode une l'image.; in	D1.W	numro de l'image (0..n); out	D7.W	erreur; mod	D7.WIMAGEDECO:	PUSHM.L	D1,D4,A1..A4	LOAD.L	A1,#(A6)+OBKTAB	MUL.WU	D1,#LBK	ADD.L	A1,D1		; A1 <-- ^dans OBKTAB	CLR.W	D7		; D7 <-- ok	TEST.L	(A1)+OBKPID	; image dj dcode ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.L	A4,(A1)+OBKPIC	; A4 <-- ^image code	LOAD.L	A3,#(A4)+LGHIMA	; A3 <-- ^data de l'image	TEST.B	(A4)+OIMCOD	; image code ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A2,A4		; A2 <-- ^image code	LOAD.W	D4,(A2)+OIMDLX	SR.W	D4,#3	MUL.WU	D4,(A2)+OIMDLY	; D4 <-- largeur*hauteur/8	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	JUMP',NE EXIT$	EX.L	A3,A4	PUSH.B	(A2)+OIMCOD	PUSH.L	(A2)+OIMNBB	GRA_	DECOIMA		; dcode l'image ...	POP.L	(A2)+OIMNBB	POP.B	(A2)+OIMCOD	TEST.W	D7	JUMP',NE ERROR$	LOAD.L	(A1)+OBKPID,A3	JUMP'	EXIT$ERROR$:	PUSH.W	D7	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'image	POP.W	D7EXIT$:	POPM.L	D1,D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGECODE >;----------/; Libre l'image dcode.; in	D1.W	numro de l'image (0..n); out	-; mod	D7.WIMAGECODE:	PUSHM.L	D1,A1,A4	LOAD.L	A1,#(A6)+OBKTAB	MUL.WU	D1,#LBK	ADD.L	A1,D1		; A1 <-- ^dans OBKTAB	TEST.L	(A1)+OBKPIF	; image de fond existe ?	JUMP',EQ PIF$		; non => PIF$	LOAD.L	A4,(A1)+OBKPIF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'image de fond	CLR.L	(A1)+OBKPIFPIF$:	TEST.L	(A1)+OBKPID	; image dcode existe ?	JUMP',EQ PID$		; non => PID$	LOAD.L	A4,(A1)+OBKPID	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'image dcode	CLR.L	(A1)+OBKPIDPID$:	POPM.L	D1,A1,A4	RET;--------\\; BKREAD  >;========/; Lit le fichier gnral.; in	D6.W	canal FOS; out	D7.W	erreur; mod	D7.WBKREAD:	PUSHM.L	D1..D5,A3,A4	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; D4 <-- longueur du fichier	LOAD.L	D2,D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP',NE ERROR$	GESMEM	?ARGMEM		; D4/D5 <-- libre/plus grand trou	LOAD.W	D7,#ERNEMEM	ADD.L	D2,#100000	; D2 <-- rserve de 100 k	COMP.L	D2,D4		; reste assez de mmoire ?	JUMP',HS ERROR$		; non => ERROR$	LOAD.L	D4,D2	SUB.L	D4,#100000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour tout le fichier	JUMP',NE ERROR$	FOS	?RDBYTE		; lit tout le fichier	JUMP',NE ERROR$	LOAD.L	A3,#(A6)+OBKTAB	CLR.W	D1LOOP$:	TEST.L	D4		; reste une(des) image(s) ?	JUMP',LE ERROR$		; non => ERROR$	LOAD.L	(A3)+OBKPIC,A4	LOAD.L	D3,(A4)+OIMNBB	ADD.L	D3,#LGHIMA+1	TCLR.L	D3:#0		; D3 <-- longueur paire	ADD.L	A4,D3		; A4 <-- ^image suivante	SUB.L	D4,D3		; D4 <-- lg restante	INC.W	D1		; D1 <-- nombre d'images	LOAD.L	A3,#(A3)+LBK	JUMP	LOOP$ERROR$:	TEST.W	D7	JUMP',NE CLOSE$	COMP.W	D1,#IMANB	; y a-t-il le bon nombre d'images ?	JUMP',EQ CLOSE$	LOAD.W	D7,#ERFOS	; D7 <-- problme avec un fichierCLOSE$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	COMP.W	D7,#EROUTF	JUMP',NE EXIT$	CLR.W	D7EXIT$:	POPM.L	D1..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET	.END