	.TITLE	BONJOUR.ASC;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du programme BONJOUR.CODE;	Date		Amliorations; -----------------------------------------------------------------------------------; 0.4	23.11.90	utilise ICOLOR; 0.3	23.10.90	couleur pour SMAKY-300; 0.2	23.03.90	BONJOUR/M -> choix tout de suite;			souris: rectangle araignes/oiseaux plus facile;			laby: indique "oui, c'est juste"  la fin;			laby: plus facile avec (CURSOR), 15x6 au lieu de 20x8;			fondus enchans: + rapides;			dessin: lutin souris = crayon/pinceau/gomme ...;			clavier: F0..F15 -> clic souris impossible;			souris: exemple sous-menus sans utiliser LIB,?MMENUS !;			souris: indications "smaky/vous"; 0.1	12.03.90	dbut des travaux ...	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	ICOLOR	.REF	COLORS;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;BEPROTXT = 3BEPROQUITTE = 4BEPROMOUSE = 5BEPROAFCR = 7BEPROAFLF = 8BEPROAFTAB = 9EPRO_EXTEND = 16'A84FEPRO_GETPDBUFF = 1OEPROPDB = 0OEPROPDT = 4OEPROPFT = 8OEPROPFB = 12OEPROSTATUS = H'1BBEPROFILMOD = 0GRA_CRASTER = H'A899		; raster-op couleurBSRCCOUL = 11BDSTCOUL = 12;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; Constantes; ----------ASSMILE	=	0		; 1 => test avec SMILE2NOSOURIS=	0NOCLAVIER=	0NOSTART	=	0NODESSIN=	0NOLABY	=	0MAJREV	=	0		; rvisionMINREV	=	4		; version	.REV	MAJREV,MINREV	.CODE	800,11,B'1111,640,2000,340,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"LXWDO	=	640		; largeur de l'cranLYWDO	=	340		; hauteur de l'cranMAXIMA	=	100		; nb max d'imagesKEYDBOX	=	H'7E00		; "touche" trs spciale !PRIOTIME=	3		; priorit du processus de mesure du tempsEPCADIC	=	3		; paisseur du cadre autour d'une icneECRPX	=	232		; cran: position en XECRPY	=	116		; cran: position en YECRDX	=	400		; cran: largeurECRDY	=	216		; cran: hauteur; Gnrateurs de caractres; -------------------------GCTXF	=	'NGCTXS	=	'E!2^7		; NEF11GCTXT	=	11GCTPF	=	'NGCTPS	=	'R!2^7		; NRF09GCTPT	=	09GCTGF	=	'IGCTGS	=	'B		; IBP14GCTGT	=	14GCICF	=	'I		; IBP20GCICS	=	'BGCICT	=	20ICODETRUIT=	1		; dtruitICODEPLACE=	2		; dplaceICODUPLIQUE=	3		; dupliqueICODIVERS=	4		; diversICONEGATIF=	5		; ngatifICOLOUPE=	6		; loupeICOZOOM=	7		; zoomICOTOURNE=	8		; tourneICOMIROIR=	9		; miroirICODEFORME=	10		; dformeICORELIEF=	11		; reliefICOTRAME=	12		; trameICOMOVE	=	13		; dplace/dupliqueICOSUITE=	14		; exercice suivantICOSDETRUIT=	17		; start: ICOSDEPLACE=	18		; start: ICOSDUPLIQUE=	19		; start: ICOSMODIF=	20		; start: ICOSEDIT=	21		; start: ICOSVISU=	22		; start: ICOSPRINT=	23		; start: ICOSLOCK=	24		; start: ; Rangs des images; ----------------		.LOC	0IMACONTROL:	.BLKB	1IMABLUPF1:	.BLKB	1IMABLUPF2:	.BLKB	1IMABLUPQ1:	.BLKB	1IMABLUPQ2:	.BLKB	1IMABLUPP1:	.BLKB	1IMABLUPP2:	.BLKB	1IMABLUPP3:	.BLKB	1IMABULLE:	.BLKB	1IMABULLEL:	.BLKB	1IMABULLEH:	.BLKB	1IMASOURIS:	.BLKB	1IMAMOUSE1:	.BLKB	1IMAMOUSE2:	.BLKB	1IMAMOUSE3:	.BLKB	1IMAMOUSE4:	.BLKB	1IMAVISER:	.BLKB	1IMASM324V:	.BLKB	1IMASM324:	.BLKB	1IMAPUZZLE1:	.BLKB	1IMAPUZZLE2:	.BLKB	1IMAPUZZLE3:	.BLKB	1IMAPUZZLE4:	.BLKB	1IMAICONE4:	.BLKB	1IMAFLDOWN:	.BLKB	1IMAOBJET2:	.BLKB	1IMASCROLL:	.BLKB	1IMASABLIER:	.BLKB	1IMANOCAPS:	.BLKB	1IMASHIFT:	.BLKB	1IMACTRL:	.BLKB	1IMACAPS:	.BLKB	1IMASUPER:	.BLKB	1IMACURSOR:	.BLKB	1IMACURSOR2:	.BLKB	1IMACURSEUR:	.BLKB	1IMASOFTKEY:	.BLKB	1IMASTART1:	.BLKB	1IMASTART2:	.BLKB	1IMASTART3:	.BLKB	1IMASTART4:	.BLKB	1IMASTARTVISU:	.BLKB	1IMADESSIN0:	.BLKB	1IMADESSIN1:	.BLKB	1IMAFLOPPY:	.BLKB	1IMADESDETR:	.BLKB	1IMAPAQUETS:	.BLKB	1IMAVOUS0:	.BLKB	1IMAVOUS1:	.BLKB	1IMAMMENUH1:	.BLKB	1IMAMMENUH2:	.BLKB	1IMANB:; Oprations de dessin; --------------------BODOUT	=	0		; changement d'outilBODMOD	=	1		; changement de modeBODOBJ	=	2		; changement d'objetBODDRAW	=	3		; dessin avec le bouton de gaucheBODSELECT=	4		; slection avec le bouton de droiteBODUNDO	=	5		; annulation avec UNDOBODCTRL	=	6		; contrle prsent; Couleurs; --------COLORBASE	= H'8000COLORTOTO	= COLORBASE+0	; totoCOLORICONE	= COLORBASE+1	; icnesCOLOREXPLI	= COLORBASE+2	; explicationsCOLORBULLE	= COLORBASE+3	; bullesCOLORBLANC	= COLORBASE+10	; blancCOLORNOIR	= COLORBASE+11	; noirCOLORJAUNE	= COLORBASE+12	; jauneCOLORORANGE	= COLORBASE+13	; orangeCOLORROUGE	= COLORBASE+14	; rougeCOLORCYAN	= COLORBASE+15	; cyanCOLORBLEU	= COLORBASE+16	; bleuCOLORVERT	= COLORBASE+17	; vertCOLORBRUN	= COLORBASE+18	; brunCOLORDEG1	= COLORBASE+20	; fond 1COLORDEG2	= COLORBASE+21	; fond 2COLORDEG3	= COLORBASE+22	; fond 3COLORDEG4	= COLORBASE+23	; fond 4COLORDEG5	= COLORBASE+24	; fond 5COLORDEG6	= COLORBASE+25	; fond 6COLORDEG7	= COLORBASE+26	; fond 7; Caractres spciaux dans les textes; -----------------------------------AFDRECT	=	H'80		; dbut rectangleAFFRECT	=	H'81		; fin rectangleAFBOLD	=	H'82		; affiche en grasAFROMAN	=	H'83		; affiche en normalAFTRAIT	=	H'84		; affiche un trait vertical;AFINV	=	H'91		; affiche en inverse;AFDIR	=	H'90		; affiche en normal; Modes pour les fonds anims; ---------------------------FGACOPEN=	0		; ouverture en cercleFGACCLOSE=	1		; fermeture en cercleFGASOPEN=	2		; ouverture en carrFGASCLOSE=	3		; fermeture en carr; Modes pour les fonds gris; -------------------------BFGINVX	=	31		; inversion gauche/droiteBFGINVY	=	30		; inversion haut/basBFGINVI	=	29		; inversion intensitFGHORIZ	=	H'10000*1	; horizontalFGVERTI	=	H'10000*2	; verticalFGMIDDLEH=	H'10000*3	; milieu horizontalFGMIDDLEV=	H'10000*4	; milieu verticalFGDIAG	=	H'10000*5	; diagonaleFGCIRCLE=	H'10000*6	; cercleFGSQUARE=	H'10000*7	; carr; Modes dans les tables; ---------------------TMOPEN	=	-1		; dbut             [y,x,ima]TMCLEAR	=	-2		; efface            []TMCLOSE	=	-3		; fin               []TMDEL	=	-4		; nouveaux dlais   [dlai]TMSOUND	=	-5		; bruitage          [TMUSxxxx]TMSKIPNE=	-6		; saut cond. si NE  [var,inf,sup,ad]TMSKIPEQ=	-7		; saut cond. si EQ  [var,inf,sup,ad]; Descripteur d'un objet anim; ----------------------------	.LOC	0OORIMA:	.BLKB	2		; rang de l'image (0..n)OOLPOS:	.BLKB	4		; dernire positionOONPOS:	.BLKB	4		; nouvelle positionOOMPTA:	.BLKB	4		; ^lment suivantOOMPTB:	.BLKB	4		; ^lment prcdentOOMCTN:	.BLKB	2		; compteur nb de dlacementsOOMCTI:	.BLKB	2		; compteur nb d'icneOOMNBI:	.BLKB	2		; nb max d'icnesOOMDEL:	.BLKB	2		; dlai (vitesse)OOCHIM:	.BLKB	4		; canal icne en mouvementLOBJ:; Descripteur d'une icne en mouvement; ------------------------------------	.LOC	0OMIIMA:	.BLKB	2		; rang de l'image (0..n)OMIDIM:	.BLKB	4		; dimensionsOMIIIY:	.BLKB	2		; IyOMIPOS:	.BLKB	4		; position originaleOMIMAT:	.BLKB	4		; ^bitmap originalLMI:; Descripteur d'une image dans la banque; --------------------------------------	.LOC	0OBKPIC:	.BLKB	4		; ^image codeOBKPID:	.BLKB	4		; ^image dcodeOBKPIF:	.BLKB	4		; ^image fondLBK:; Descripteur d'un bitmap sauv; -----------------------------OBSABS:	.BLKB	4OBSIIX:	.BLKB	2OBSIIY:	.BLKB	2OBSY:	.BLKB	4OBSDY:	.BLKB	4OBSFY:	.BLKB	4OBSFDY:	.BLKB	4OBSWBY:	.BLKB	4OBSWEY:	.BLKB	4LBS:; Variables; ---------LBUDIS	=	((200*200)/8)*4*4 ; *4 si couleur !!!	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHEPRO:.BLKB	2		; canal module EPROOCHICOLOR:.BLKB	2		; canal module ICOLOROMACHINE:.BLKB	1		; machineOABORT:	.BLKB	1		; 1 => fin du processus filsOABORT3:.BLKB	1		; 1 => fin du processus fils 3OINV:	.BLKB	1		; 1 => cran inversOBEGIN:	.BLKB	1		; 1 => dbut (pas de contrle)	.EVENOTIME:	.BLKB	4		; temps absolu (1=20ms)OSOUND:	.BLKB	2		; son  effectuer par le processus filsOPLCOM:	.BLKB	4		; ^ligne de commandeOPDDIS:	.BLKB	4		; ^descripteur de la fentreOSDDIS:	.BLKB	LGDIS6		; copie du descripteur de la fentreONOWDO:	.BLKB	2		; swdo de travail (640 x 340)OIDCRET:.BLKB	4		; identificateur CRETOCCMO:	.BLKB	1		; 1 => souris enleveONOCO:	.BLKB	1		; 1 => pas de couleurs	.EVENOADRASTER:	.BLKB	4	;  adresse de GRA_RASTEROADCRASTER:	.BLKB	4	;  adresse de GRA_CRASTEROADMATRIX:	.BLKB	4	;  adresse de GRA_MATRIXOADDOT:		.BLKB	4	;  adresse de GRA_DOTOADTRAME:	.BLKB	4	;  adresse de GRA_TRAMEOADLINE:	.BLKB	4	;  adresse de GRA_LINEOADELLIPSE:	.BLKB	4	;  adresse de GRA_ELLIPSEOADFILLO:	.BLKB	4	;  adresse de GRA_FILLOOADFILLC:	.BLKB	4	;  adresse de GRA_FILLCOADCLEAR:	.BLKB	4	;  adresse de GRA_CLEAROADSET:		.BLKB	4	;  adresse de GRA_SETOADINV:		.BLKB	4	;  adresse de GRA_INVOADQXDOT:	.BLKB	4	;  adresse de GRA_QXDOTOBSSTK:	.BLKB	LBS*10		; bitmap sauv: stackOBSSTP:	.BLKB	2		; bitmap sauv: rang dans stackOFGLPX:	.BLKB	2		; fond gris: dernire position XOFGLDX:	.BLKB	2		; fond gris: dernire largeurOFGLTR:	.BLKB	1		; fond gris: dernire trame	.EVENOBSQAD:	.BLKB	4		; boutons carrs: ^routine "getpos"OEXM:	.BLKB	20		; exercices faits : sourisOEXK:	.BLKB	20		; exercices faits : clavierOEXS:	.BLKB	20		; exercices faits : startOEXD:	.BLKB	20		; exercices faits : dessinOCTRLP:	.BLKB	4		; contrle: positionOCTRLG:	.BLKB	1		; contrle: icnes grises	.EVENOBKTAB:	.BLKB	LBK*MAXIMA	; banque: table des imagesOOBJ1:	.BLKB	LOBJ		; objet anim numro 1OOBJ2:	.BLKB	LOBJ		; objet anim numro 2OPZCHA:	.BLKB	4*4		; puzzle: canauxOLANBY:	.BLKB	2		; labyrinthe: nb de cases verticalementOLANBX:	.BLKB	2		; labyrinthe: nb de cases horizontalementOLAIIY:	.BLKB	2		; labyrinthe: nb de bytesOLAPOY:	.BLKB	2		; labyrinthe: positionOLAPOX:	.BLKB	2		; labyrinthe: OLADIY:	.BLKB	2		; labyrinthe: dimensions d'une caseOLADIX:	.BLKB	2		; labyrinthe: OLADIM:	.BLKB	2		; labyrinthe: paisseur d'un murOLAARR:	.BLKB	4		; labyrinthe: arriveOLACHI:	.BLKB	4		; labyrinthe: hilightOLAPBM:	.BLKB	4		; labyrinthe: ^bitmapOLAPSO:	.BLKB	4		; labyrinthe: ^solutionOLAPRE:	.BLKB	4		; labyrinthe: ^rponseOTXDEL:	.BLKB	2		; texte: vitesse de frappeODESOUT:.BLKB	2		; dessin: outilODESMOD:.BLKB	2		; dessin: modeODESOBJ:.BLKB	2		; dessin: objetODESOP1:.BLKB	4		; dessin: opration P1(y;x)ODESOP2:.BLKB	4		; dessin: opration P2(y;x)OLUPX:	.BLKB	2		; centre du lutin en XOLUPY:	.BLKB	2		; centre du lutin en YOLUTIN:	.BLKB	2		; no lutin de la sourisOSIMNM:	.BLKB	50		; start-image: nomOSIMPT:	.BLKB	4		; start-image: ^bitmapOHABKI:	.BLKB	(MAXIMA/8)+1	; hazard: banque d'images	.EVENOHAZA:	.BLKB	8		; registre 63 bits pour gnrateur alatoireOSLVAR:	.BLKB	LSLVAR		; variables pour scroll-listeOMMPAR:	.BLKB	LMM*4		; paramtres pour mmenusOBUDIS:	.BLKB	LBUDIS		; buffer pour "write-display"LGVAR:; Programme; ---------	.LOC	0ADCODE:	JUMP	START; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMEPRO:		.ASCIZ	"EPRO"NMICOLOR:	.ASCIZ	"ICOLOR"NMBONJOUR:	.ASCIZ	"BONJOUR"NMDEF:		.ASCIZ	"(:,#:)BONJOUR.DATA"		.EVENSTART:	.IF	~ASSMILE	LIB	?OPELIB	.ENDIF	LOAD.W	D3,#2	LIB	?MOUSE	LIB	?AFTIM	.B	NOCURS	.B	0	.EVEN	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	CALL	_CCMO		; enlve la souris	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LIB	?GETPDIS	LOAD.L	(A6)+OPDDIS,A4	LOAD.L	A0,A4	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMEPRO	LOAD.W	D3,#EPRO_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHEPRO,D1	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	LOAD.L	A3,#R16"NMICOLOR	LOAD.W	D3,#ICOL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHICOLOR,D1	LOAD.L	A3,#R16"NMBONJOUR	LOAD.L	A5,#R16"TCOUL	LOAD.L	D3,#2^BICCRET	ICOL_	INIT		; charge BONJOUR.CRET	LOAD.L	(A6)+OIDCRET,D5NOCOUL$:	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADRASTER,A3	LOAD.W	D3,#GRA_CRASTER	LIB_	GETAD	LOAD.L	(A6)+OADCRASTER,A3	LOAD.W	D3,#GRA_MATRIX	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADMATRIX,A3	LOAD.W	D3,#GRA_DOT	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADDOT,A3	LOAD.W	D3,#GRA_TRAME	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADTRAME,A3	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADLINE,A3	LOAD.W	D3,#GRA_ELLIPSE	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADELLIPSE,A3	LOAD.W	D3,#GRA_FILLO	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADFILLO,A3	LOAD.W	D3,#GRA_FILLC	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADFILLC,A3	LOAD.W	D3,#GRA_CLEAR	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADCLEAR,A3	LOAD.W	D3,#GRA_SET	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADSET,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADINV,A3	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE ERFAT	LOAD.L	(A6)+OADQXDOT,A3	CALL	_COUPSAC	; hazard: coup de sac	LIB	?AFTIM	.B	NOCURS		; pas de curseur !	.B	NOEFLI		; pas de EFLI automatique	.B	TRUNC		; tronque les lignes trop longues	.B	AFFILLA		; pas de test lors des remplissages	.B	MMODULO,1	; plus de modulos	.B	LOADGC		; charge les caractres standards	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	LOADGC		; charge les grands caractres	.B	GCTGF	.B	GCTGS	.B	GCTGT	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	LOADGC		; charge les petits caractres	.B	GCTPF	.B	GCTPS	.B	GCTPT	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	LOADGC		; charge les icnes	.B	GCICF	.B	GCICS	.B	GCICT	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	USEGC		; utilise les caractres standard	.B	GCTXF	.B	GCTXS	.B	GCTXT	.B	0	.EVEN	LOAD.W	D4,#PRIOTIME	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#200		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils de mesure du temps	JUMP,NE ERFAT2	NTREL	?GETPRIO	; D4 <-- priorit de BONJOUR	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS2	LOAD.L	A3,#R16"NFILS2	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils des bruitages	JUMP,NE ERFAT2	LOAD.W	D4,#LYWDO	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,D4	SR.W	D3,#1	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,#LXWDO	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,D4	SR.W	D3,#1	AND.B	D3,#B'11110000	; D3 <-- utile pour SMAKY8 !	LIB	?CREWDO		; cre swdo (utile si grand cran)	LIB	?USEWDO	LOAD.W	(A6)+ONOWDO,D5	LOAD.L	A3,(A6)+OPLCOM	LIB	?SKPNAM	JUMP',EQ READ$	LOAD.L	A3,#R16"NMDEFREAD$:	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE RERR$	CALL	_BKREAD		; charge toute la banque d'images	JUMP,NE ERFAT2RERR$:	TEST.B	(A0)+ODFMOD:#BFBLANC	JUMP',BS REFAIT	SET.B	(A6)+OINV	; OINV <-- cran  fond noirREFAIT:	LIB	?GETWDO	LOAD.W	D6,D5	CLR.W	D5	LIB	?USEWDO	LOAD.L	D3,#-1	TEST.B	(A6)+OINV	JUMP,F	20$	CLR.L	D320$:	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface toute la fentre	LOAD.W	D5,D6	LIB	?USEWDO	JUMP	MAINFINI:ERFAT:	SET.B	(A6)+OABORT	; signal la fin aux fils	.IF	~ASSMILE	NTREL	?WFABDESC	; attend la fin des fils ...	.ELSE	PUSH.L	D4	LOAD.W	D4,#50	NTREL	?DELMS	POP.L	D4	.ENDIF	CLR.W	D5	LIB	?USEWDO		; utilise la swdo principale	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface la fentre	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHEPRO	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHICOLOR	LIB_	CLOSE	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend les variablesERFAT1:	.IF	~ASSMILE	LIB	?CLOLIB	FOS	?STOP	.ELSE	EXIT	.ENDIFERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT; Processus de mesure du temps; ----------------------------NFILS1:	.ASCIZ	"BONJOUR_TIME"	.EVENPFILS1:	LOAD.L	A0,(A6)+OPDDIS	CLR.L	(A6)+OTIME	; OTIME <-- rz la mesure du tempsLOOP$:	TEST.B	(A6)+OABORT	; fin des fils ?	JUMP',T END$		; oui => END$	LOAD.W	D4,#50/5	NTREL	?DELMS	ADD.L	(A6)+OTIME,#5	; OTIME <-- inc la mesure du temps;;?	TEST.B	(A6)+OCCMO	; souris cache ?;;?	JUMP,F	LOOP$		; non => LOOP$;;?	CALL	MMOUSE		; remet la souris au milieu	JUMP	LOOP$END$:	NTREL	?ABORT; Processus de gnration des bruitages; -------------------------------------NFILS2:	.ASCIZ	"BONJOUR_SOUND"	.EVENPFILS2:LOOP$:	TEST.B	(A6)+OABORT	; fin ?	JUMP',T	END$		; oui => END$				; non =>	LOAD.W	D3,(A6)+OSOUND	JUMP',EQ WAIT$	CLR.W	(A6)+OSOUND	CALL	PATATRA		; fait le bruit	JUMP	LOOP$WAIT$:	LOAD.W	D4,#50/10	NTREL	?DELMS		; attend un peu	JUMP	LOOP$END$:	NTREL	?ABORT;--------\\; PATATRA >;========/; Fait un bruit rigolo !; in	D3.W	#TMUSxxx; out	-; mod	D7.WPATATRA:	PUSHM.L	D3,A4;;?	TEST.B	(A6)+OFLAGS:#BFSON;;?	JUMP',BC EXIT$	LOAD.L	A4,#R16"ADCODE	AND.L	D3,#H'FFFF	; ADD.W A4,D3 impossible si D3.W ngatif !	ADD.L	D3,A4	LOAD.L	A4,D3	TEST.W	(A4)	JUMP',EQ EXIT$	LIB	?PLAYEXIT$:	POPM.L	D3,A4	RET	.INS	BJMAIN.ASI	.IF	~NOSOURIS	.INS	BJSOURIS.ASI	.ENDIF	.IF	~NOCLAVIER	.INS	BJCLAVIER.ASI	.ENDIF	.IF	~NOSTART	.INS	BJSTART.ASI	.ENDIF_CCMO:		JUMP	CCMO_SCMO:		JUMP	SCMO_COUPSAC:	JUMP	COUPSAC_BKREAD:	JUMP	BKREAD_INVTRAME:	JUMP	INVTRAME_INVMODE:	JUMP	INVMODE_CLRFIFO:	JUMP	CLRFIFO_IFMOUSE:	JUMP	IFMOUSE_AFMENUBASE:	JUMP	AFMENUBASE_AFMENUBASEC:	JUMP	AFMENUBASEC_AFMENUNIL:	JUMP	AFMENUNIL_IMAGEAFFF:	JUMP	IMAGEAFFF_IMAGECODE:	JUMP	IMAGECODE	.IF	~NOLABY_LAMOUSE:	JUMP	LAMOUSE	.ENDIF_DRAWOPENCOPY:	JUMP	DRAWOPENCOPY_DRAWOPEN:	JUMP	DRAWOPEN_DRAWCLOSE:	JUMP	DRAWCLOSE_DRFONDD:	JUMP	DRFONDD_DRFONDDA:	JUMP	DRFONDDA_TXBULLE:	JUMP	TXBULLE_TXBULLEL:	JUMP	TXBULLEL_TXBULLEH:	JUMP	TXBULLEH_CTRLEVENT:	JUMP	CTRLEVENT_MOVEALL:	JUMP	MOVEALL_MOVEOPEN:	JUMP	MOVEOPEN_MOVEDRAW:	JUMP	MOVEDRAW_MOVECLOSE:	JUMP	MOVECLOSE_TXOPEN:	JUMP	TXOPEN_TXCLOSE:	JUMP	TXCLOSE_TXPOPEN:	JUMP	TXPOPEN_TXPCLOSE:	JUMP	TXPCLOSE_MODEMOSTART:	JUMP	MODEMOSTART_MODEMOSTOP:	JUMP	MODEMOSTOP_PMOUSE:	JUMP	PMOUSE_CTRLDRAW:	JUMP	CTRLDRAW_ADCODE: 	LOAD.L	A3,#R16"ADCODE	RET_BSQINV:	JUMP	BSQINV_BSQMOVE:	JUMP	BSQMOVE	.INS	BJTABLE.ASI	.IF	~NODESSIN	.INS	BJDESSIN.ASI	.INS	BJOUTIL.ASI	.ENDIF	.INS	BJCTRL.ASI	.INS	BJTEXT.ASI	.INS	BJMOVE.ASI	.INS	BJDRAW.ASI	.INS	BJIMAGE.ASI	.INS	BJMISC.ASI	.IF	~NOLABY	.INS	BJLABY.ASI	.ENDIF	.END	START