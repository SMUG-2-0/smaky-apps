	.SBTTL	BJDESSIN.ASI;---------\\; DESSIN1  >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN1:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPF1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLE		; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLEVENT	; attend un vnement ...	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Nous allons tudier<CR>/	.ASCII	/le logiciel de dessin,<CR>/	.ASCII	/appel DESSIN4.CODE !<CR>/	.B	0	.EVEN;---------\\; DESSIN2  >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN2:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPQ1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMADESSIN0	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	SCMO		; remet la souris	CALL	WAITMOUSE	; met le sablier	LOAD.W	D4,#50*5	NTREL	?DELMS		; attend ...	CALL	NORMMOUSE	; enlve le sablier	CALL	CCMO		; enlve la souris	LOAD.W	D3,#CR		; D3 <-- exercice suivant	LOAD.W	D1,#IMADESSIN0	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Dans quelques secondes,<CR>/	.ASCII	/le logiciel DESSIN4 sera charg ...<CR>/	.B	0	.EVEN;---------\\; DESSIN3  >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN3:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	DESSIN3ACTION	; action ...	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Tout en <AFBOLD>maintenant press le bouton de gauche<AFROMAN>,<CR>/	.ASCII	/vous pouvez <AFBOLD>dplacer la souris<AFROMAN> pour dessiner<CR>/	.ASCII	/un <AFBOLD>trait  main leve<AFROMAN> ...<CR>/	.B	0	.EVEN;--------------\\; DESSIN3ACTION >;==============/; Dessine.; in	-; out	-; mod	D7.WDESSIN3ACTION:	PUSHM.L	D0..D4,A3	CLR.W	(A6)+ODESOUT	; crayon	CLR.W	(A6)+ODESMOD	; noir	CLR.W	(A6)+ODESOBJ	; trait  main leve	CALL	DESINIT		; met les soft-keys de DESSIN4 !	CALL	CLRFIFO		; vide le fifo du clavierLOOPM$:	CALL	SCMO		; remet la sourisLOOP$:	LIB	?GETKEY		; attend souris/clavier ...	TEST.L	D3:#BKPSEUDO	JUMP,BS LOOP$	COMP.W	D3,#KEYMPO	JUMP',EQ MOVE$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	COMP.W	D3,#END	JUMP,EQ EXIT$	COMP.W	D3,#F0	JUMP,EQ EXIT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$MOVE$:	CALL	DESSELMO	; utilise le bon lutin	JUMP	LOOP$CLIC$:	CALL	DESIFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A3,#R16"TEXT1$	COMP.W	D3,#KEYMGP	JUMP,NE FAUX$	LOAD.L	A3,#R16"TEXT2$	CALL	DESIFD		; dans la surface de dessin ?	JUMP,NE FAUX$	CLR.W	D0	LOAD.L	D1,D4		; D1 <-- dpart	LOAD.L	D2,D4		; D2 <-- ancienne positionDRAW$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE DEND$	CALL	DESIFMOUSE	; D4 <-- position de la souris	JUMP,NE DRAW$	CALL	DESIFD		; dans la surface de dessin ?	JUMP,NE DRAW$	CALL	DESOBJM		; dessine l'objet	LOAD.L	D2,D4		; D2 <-- ancienne position	INC.W	D0	JUMP	DRAW$DEND$:	LOAD.L	A3,#R16"TEXT3$	COMP.W	D0,#2	JUMP',LS FAUX$	COMP.W	D0,#10	JUMP,LS LOOP$	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	JUMP'	END$FAUX$:	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMABLUPP2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	DRAWCLOSE	; montre le dessin en mmoire	JUMP	LOOPM$END$:	LOAD.W	(A6)+OSOUND,#TMUSJUSTE	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT4$	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoireEXIT$:	LOAD.W	(A6)+ODESOUT,#-1	CALL	DESSELMO	; utilise la flche	CALL	CCMO		; enlve la souris	CALL	AFMENUNIL	; enlve les soft-keys	POPM.L	D0..D4,A3	RETTEXT1$:	.ASCII	/Vous devez dessiner avec le <AFBOLD>bouton de gauche<AFROMAN> !<CR>/	.B	0TEXT2$:	.ASCII	/Vous ne pouvez dessiner que dans la grande<CR>/	.ASCII	/surface,  ct des deux ascenseurs !<CR>/	.B	0TEXT3$:	.ASCII	/Vous devez <AFBOLD>maintenir le bouton de gauche press<AFROMAN>,<CR>/	.ASCII	/tout en dplaant la souris !<CR>/	.B	0TEXT4$:	.ASCII	/Oui, c'est trs beau (hum) !<CR>/	.B	0	.EVEN;---------\\; DESSIN4  >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN4:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A4,#R16"DESPOSOBJ	LOAD.L	(A6)+OBSQAD,A4	CLR.W	D1	CALL	_BSQINV	INC.W	D1	CALL	_BSQINV	INC.W	D1	CALL	_BSQINV	INC.W	D1	CALL	_BSQINV	LOAD.W	D4,#50*2	NTREL	?DELMS	LOAD.L	D3,#H'10000*(ECRPY+171)+(ECRPX-7)	CALL	START13FAR	; flche clignottante	CLR.W	D1	CALL	_BSQINV	INC.W	D1	CALL	_BSQINV	INC.W	D1	CALL	_BSQINV	INC.W	D1	CALL	_BSQINV	LOAD.W	D2,#(4*5)-1	CLR.W	D1LOOP$:	CALL	_BSQINV		; allume	LOAD.W	D4,#10	NTREL	?DELMS	CALL	_BSQINV		; teint	INC.W	D1	COMP.W	D1,#4	JUMP',LO NEXT$	CLR.W	D1NEXT$:	DECJ.W,NMO D2,LOOP$	LOAD.W	D4,#50*1	NTREL	?DELMS	LOAD.W	D4,#50*6	CLR.B	(A6)+OCTRLG	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Le groupe d'icne en bas  gauche permet de choisir<CR>/	.ASCII	/l'<AFBOLD>objet<AFROMAN> dessin (trait  main leve, droite, rectangle<CR>/	.ASCII	/ou cercle) :<CR>/	.B	0	.EVEN;---------\\; DESSIN5  >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN5:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	D5,#2^BODDRAW!2^BODCTRL	CLR.W	(A6)+ODESOUT	; crayon	CLR.W	(A6)+ODESMOD	; noir	CLR.W	(A6)+ODESOBJ	; trait  main leve	CALL	DESINIT		; met les soft-keys de DESSIN4 !	CALL	CLRFIFO		; vide le fifo du clavier	CALL	SCMO		; remet la souris	CALL	DESSIN5SEL	; action ...	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT2$	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	DESINIT		; teint les icnes !	CALL	DESFREE		; dessine librement ...	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Slectionnez l'<AFBOLD>objet<AFROMAN> <AFINV>droite<AFDIR> ...<CR>/	.B	0TEXT2$:	.ASCII	/Dessinez quelques lignes droites, comme suit :<CR>/	.ASCII	/<AFINV>1<AFDIR> = placer la souris au dpart<CR>/	.ASCII	/<AFINV>2<AFDIR> = <AFBOLD>tirer<AFROMAN> jusqu' l'arrive  /	.ASCII	/<AFINV>3<AFDIR> = relcher le bouton<CR>/	.B	0	.EVEN;-----------\\; DESSIN5SEL >;===========/; Dessine.; in	-; out	-; mod	D7.WDESSIN5SEL:	PUSHM.L	D0..D4,A3LOOP$:	LIB	?GETKEY		; attend souris/clavier ...	TEST.L	D3:#BKPSEUDO	JUMP,BS LOOP$	COMP.W	D3,#KEYMPO	JUMP',EQ MOVE$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	COMP.W	D3,#END	JUMP,EQ EXIT$	COMP.W	D3,#F0	JUMP,EQ EXIT$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$MOVE$:	CALL	DESSELMO	; utilise le bon lutin	JUMP	LOOP$CLIC$:	CALL	DESIFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A3,#R16"DESPOSOBJ	LOAD.L	(A6)+OBSQAD,A3	CALL	_BSQMOVE	; D1 <-- rang (0..n)	JUMP,NE BIP$	CALL	DESNEWOBJ	COMP.W	(A6)+ODESOBJ,#1	JUMP',EQ END$	LOAD.L	A3,#R16"TEXT1$FAUX$:	LOAD.W	(A6)+OSOUND,#TMUSFAUX	LOAD.W	D1,#IMABLUPP2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	JUMP	LOOP$END$:	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine totoEXIT$:	PUSH.W	(A6)+ODESOUT	LOAD.W	(A6)+ODESOUT,#-1	CALL	DESSELMO	; utilise la flche	POP.W	(A6)+ODESOUT	POPM.L	D0..D4,A3	RETTEXT1$:	.ASCII	/Vous n'avez pas slectionn l'<AFBOLD>objet<AFROMAN> <AFINV>droite<AFDIR> !<CR>/	.B	0	.EVEN;---------\\; DESSIN6  >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN6:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	D5,#2^BODDRAW!2^BODOBJ!2^BODCTRL	CLR.W	(A6)+ODESOUT	; crayon	CLR.W	(A6)+ODESMOD	; noir	CLR.W	(A6)+ODESOBJ	; trait  main leve	CALL	DESFREE		; dessine librement ...	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Essayez maintenant de dessiner divers objets<CR>/	.ASCII	/(droites, rectangles, cercles, etc.)<CR>/	.B	0	.EVEN;---------\\; DESSIN7  >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN7:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A4,#R16"DESPOSOUT	LOAD.L	(A6)+OBSQAD,A4	LOAD.W	D1,#1	CALL	_BSQINV	LOAD.L	D3,#H'10000*(ECRPY+58)+(ECRPX-7)	CALL	START13FAR	; flche clignottante	CALL	_BSQINV	LOAD.L	D5,#2^BODDRAW!2^BODOBJ!2^BODCTRL	LOAD.W	(A6)+ODESOUT,#1	; pinceau	CLR.W	(A6)+ODESMOD	; noir	CLR.W	(A6)+ODESOBJ	; trait  main leve	CALL	DESFREE		; dessine librement ...	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Le <AFBOLD>pinceau<AFROMAN> permet de dessiner avec des traits pais,<CR>/	.ASCII	/alors que le <AFBOLD>crayon<AFROMAN> dessine toujours des traits fins.<CR>/	.ASCII	/Dessinez quelques objets ...<CR>/	.B	0	.EVEN;---------\\; DESSIN8  >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN8:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	LOAD.W	(A6)+ODESOUT,#1	; pinceau	CALL	DESPENI		; initialise le pinceau	LOAD.W	D2,#SETDOT;;?	CALL	INVMODE	OR.W	D2,#PENDOT	LOAD.L	D3,#H'10000*(ECRPY+20+43)+(ECRPX+112+70)	LOAD.L	D4,#H'10000*87+140	LIB	?DRRECT	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	ADD.W	D3,D4	DEC.W	D3	NEG.W	D4	LIB	?DRSEG	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A4,#R16"DESPOSMOD	LOAD.L	(A6)+OBSQAD,A4	LOAD.W	D1,#1	CALL	_BSQINV	LOAD.L	D3,#H'10000*(ECRPY+115)+(ECRPX+26)	CALL	START13FAR	; flche clignottante	CALL	_BSQINV	LOAD.L	D5,#2^BODDRAW!2^BODCTRL	LOAD.W	(A6)+ODESOUT,#1	; pinceau	LOAD.W	(A6)+ODESMOD,#1	; gomme	CLR.W	(A6)+ODESOBJ	; trait  main leve	CALL	DESFREE		; dessine librement ...	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/La <AFBOLD>gomme<AFROMAN>, avec le pinceau et le trait  main leve,<CR>/	.ASCII	/efface tant que le bouton de gauche est enfonc.<CR>/	.ASCII	/Effacez le dessin ci-dessous ...<CR>/	.B	0	.EVEN;---------\\; DESSIN9  >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN9:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.W	D2,#INVDOT	LOAD.L	D3,#H'10000*(ECRPY+20+21)+(ECRPX+112+35)	LOAD.L	D4,#H'10000*87+140	LIB	?DRTRAME	LOAD.L	D3,#H'10000*(ECRPY+20+66)+(ECRPX+112+106)	LOAD.L	D4,#H'10000*87+140	LIB	?DRTRAME	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	D5,#2^BODDRAW!2^BODOBJ!2^BODCTRL	LOAD.W	(A6)+ODESOUT,#1	; pinceau	LOAD.W	(A6)+ODESMOD,#1	; gomme	LOAD.W	(A6)+ODESOBJ,#1	; droite	CALL	DESFREE		; dessine librement ...	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/La <AFBOLD>gomme<AFROMAN> s'utilise aussi pour dessiner des droites,<CR>/	.ASCII	/des rectangles ou des cercles, par-dessus un<CR>/	.ASCII	/dessin existant !  Essayez ...<CR>/	.B	0	.EVEN;---------\\; DESSIN10 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN10:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	CALL	DESINVALL	; inverse la surface	LOAD.W	D1,#IMASOURIS	LOAD.L	D2,#H'10000*(ECRPY+42)+(ECRPX+177)	CLR.L	D3	CLR.L	D4	SET.B	(A6)+ONOCO	; dessine sans couleurs !	CALL	IMAGEAFFF	; dessine la souris	CLR.B	(A6)+ONOCO	CALL	DESINVALL	; inverse la surface	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	A4,#R16"DESPOSOUT	LOAD.L	(A6)+OBSQAD,A4	LOAD.W	D1,#2	CALL	_BSQINV	LOAD.L	D3,#H'10000*(ECRPY+84)+(ECRPX+26)	CALL	START13FAR	; flche clignottante	CALL	_BSQINV	LOAD.L	D5,#2^BODDRAW!2^BODCTRL	LOAD.W	(A6)+ODESOUT,#2	; bidon	CLR.W	(A6)+ODESMOD	; noir	LOAD.W	(A6)+ODESOBJ,#-1	CALL	DESFREE		; dessine librement ...	LOAD.W	D1,#IMASOURIS	CALL	IMAGECODE	; libre l'image	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Le <AFBOLD>bidon<AFROMAN> permet de remplir de peinture<CR>/	.ASCII	/des surfaces fermes.<CR>/	.ASCII	/Remplissez diffrentes parties de la souris ...<CR>/	.B	0	.EVEN;---------\\; DESSIN11 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN11:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMADESDETR	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*6	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLEVENT	; attend un vnement ...	LOAD.W	D1,#IMADESDETR	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Pour <AFBOLD>effacer<AFROMAN> une zone rectangulaire, il faut l'entourer<CR>/	.ASCII	/d'un rectangle avec le <AFBOLD>bouton de droite<AFROMAN>, puis choisir<CR>/	.ASCII	/<AFINV>"dtruit"<AFDIR> dans le menu :<CR>/	.B	0	.EVEN;---------\\; DESSIN12 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN12:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	CALL	DESINVALL	; inverse la surface	LOAD.L	A4,#R16"TABLE$OBJ$:	LOAD.W	D1,#IMAOBJET2	LOAD.L	D2,(A4+)	CLR.L	D3	LOAD.W	D3,(A4+)	LOAD.L	D4,#H'10000*28+32	CALL	IMAGEAFFF	; dessine oiseau/araigne	TEST.L	(A4)	JUMP,NE OBJ$	CALL	DESINVALL	; inverse la surface	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	D5,#2^BODSELECT!2^BODCTRL	CLR.W	(A6)+ODESOUT	; crayon	CLR.W	(A6)+ODESMOD	; noir	CLR.W	(A6)+ODESOBJ	; trait  main leve	CALL	DESFREE		; dessine librement ...	LOAD.W	D1,#IMAOBJET2	CALL	IMAGECODE	; libre l'image 	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTABLE$:	.W	ECRPY+40,ECRPX+115,32	.W	ECRPY+132,ECRPX+138,32	.W	ECRPY+75,ECRPX+213,32	.W	ECRPY+157,ECRPX+237,32	.W	ECRPY+54,ECRPX+300,32	.W	ECRPY+163,ECRPX+348,32	.W	ECRPY+86,ECRPX+154,0	.W	ECRPY+161,ECRPX+180,0	.W	ECRPY+24,ECRPX+192,0	.W	ECRPY+29,ECRPX+347,0	.W	ECRPY+122,ECRPX+293,0	.L	0TEXT1$:	.ASCII	/En les entourant d'un rectangle avec le bouton de <AFBOLD>droite<AFROMAN>,<CR>/	.ASCII	/enlevez toutes les araignes ci-dessous :<CR>/	.B	0	.EVEN;---------\\; DESSIN13 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN13:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	CALL	DESINVALL	; inverse la surface	LOAD.L	A4,#R16"TABLE$OBJ$:	LOAD.W	D1,#IMAOBJET2	LOAD.L	D2,(A4+)	CLR.L	D3	LOAD.W	D3,(A4+)	LOAD.L	D4,#H'10000*28+32	CALL	IMAGEAFFF	; dessine oiseau/araigne	TEST.L	(A4)	JUMP,NE OBJ$	CALL	DESINVALL	; inverse la surface	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	D5,#2^BODSELECT!2^BODCTRL	CLR.W	(A6)+ODESOUT	; crayon	CLR.W	(A6)+ODESMOD	; noir	CLR.W	(A6)+ODESOBJ	; trait  main leve	CALL	DESFREE		; dessine librement ...	LOAD.W	D1,#IMAOBJET2	CALL	IMAGECODE	; libre l'image 	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTABLE$:	.W	ECRPY+40,ECRPX+115,32	.W	ECRPY+132,ECRPX+138,32	.W	ECRPY+75,ECRPX+213,32	.W	ECRPY+157,ECRPX+237,32	.W	ECRPY+54,ECRPX+300,32	.W	ECRPY+163,ECRPX+348,32	.W	ECRPY+86,ECRPX+154,0	.W	ECRPY+161,ECRPX+180,0	.W	ECRPY+24,ECRPX+192,0	.W	ECRPY+29,ECRPX+347,0	.W	ECRPY+122,ECRPX+293,0	.L	0TEXT1$:	.ASCII	/Toujours en entourant avec le bouton de droite,<CR>/	.ASCII	/<AFBOLD>dplacez<AFROMAN> quelques oiseaux ci-dessous :<CR>/	.B	0	.EVEN;---------\\; DESSIN14 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN14:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	CALL	DESINVALL	; inverse la surface	LOAD.W	D1,#IMAPAQUETS	LOAD.L	D2,#H'10000*(75+ECRPY)+(170+ECRPX)	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine des paquets	CALL	DESINVALL	; inverse la surface	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	D5,#2^BODSELECT!2^BODCTRL	CLR.W	(A6)+ODESOUT	; crayon	CLR.W	(A6)+ODESMOD	; noir	CLR.W	(A6)+ODESOBJ	; trait  main leve	CALL	DESFREE		; dessine librement ...	LOAD.W	D1,#IMAPAQUETS	CALL	IMAGECODE	; libre l'image 	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/Toujours en entourant avec le bouton de droite,<CR>/	.ASCII	/<AFBOLD>dupliquez<AFROMAN> quelques cadeaux :<CR>/	.B	0	.EVEN;---------\\; DESSIN15 >;=========/; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESSIN15:	PUSHM.L	D1,D2,D4,A3,A4	CALL	DRAWOPEN	; dessine en mmoire	LOAD.L	D4,#FGHORIZ	CALL	DRFONDD		; dessine le fond	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	LOAD.L	A3,#R16"TEXT1$	CALL	TXBULLEL	; dessine le texte	CALL	DESBASE		; affiche l'image de base	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.L	D5,#-1	CLR.W	(A6)+ODESOUT	; crayon	CLR.W	(A6)+ODESMOD	; noir	CLR.W	(A6)+ODESOBJ	; trait  main leve	CALL	DESFREE		; dessine librement ...	LOAD.W	D1,#IMADESSIN1	CALL	IMAGECODE	; libre l'image	POPM.L	D1,D2,D4,A3,A4	RETTEXT1$:	.ASCII	/La touche <AFDRECT>UNDO<AFFRECT> <AFBOLD>annule<AFROMAN> la dernire /	.ASCII	/opration effectue,<CR>/	.ASCII	/qu'il s'agisse d'un dessin avec le bouton de gauche,<CR>/	.ASCII	/ou d'une modification avec le bouton de droite. Essayez :<CR>/	.B	0	.EVEN;--------\\; DESFREE >;========/; Dessine plus ou moins librement.; in	D5.L	opration autorises (BOD*);	A3.L	^texte de la bulle; out	D3.W	dernire touche; mod	D3.L, D7.WDESFREE:	PUSHM.L	D0..D2,D4,D6,A2,A3	LOAD.L	A2,A3		; A2 <-- ^texte initial	CALL	DESINIT		; met les soft-keys de DESSIN4 !	CALL	CLRFIFO		; vide le fifo du clavier	CLR.L	D0		; D0 <-- nb d'objets dessinsLOOPM$:	CALL	SCMO		; remet la sourisLOOP$:	LIB	?GETKEY		; attend souris/clavier ...	TEST.L	D3:#BKPSEUDO	JUMP,BS LOOP$	COMP.W	D3,#KEYMPO	JUMP',EQ MOVE$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#F0	JUMP,EQ NEXT$	COMP.W	D3,#F0	JUMP',LO BIP$	COMP.W	D3,#F15	JUMP,LS NODESS4$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$MOVE$:	CALL	DESSELMO	; utilise le bon lutin	JUMP	LOOP$UNDO$:	TEST.L	D5:#BODUNDO	JUMP,BC BIP$	CALL	DESUNDO		; revient en arrire	JUMP	DOK$CLIC$:	CALL	DESIFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A3,#R16"DESPOSOUT	LOAD.L	(A6)+OBSQAD,A3	CALL	_BSQMOVE	; D1 <-- rang (0..n)	JUMP,EQ OUTIL$	LOAD.L	A3,#R16"DESPOSMOD	LOAD.L	(A6)+OBSQAD,A3	CALL	_BSQMOVE	; D1 <-- rang (0..n)	JUMP,EQ MODE$	LOAD.L	A3,#R16"DESPOSOBJ	LOAD.L	(A6)+OBSQAD,A3	CALL	_BSQMOVE	; D1 <-- rang (0..n)	JUMP,EQ OBJET$	TEST.W	D0		; fait qq chose ?	JUMP',EQ CCTRL$		; non => CCTRL$	TEST.L	D5:#BODCTRL	JUMP',BC CCTRL$	CALL	CTRLMOVE	; action dans un contrle ...	JUMP,EQ CTRL$CCTRL$:	COMP.W	D3,#KEYMGP	JUMP,EQ DRAW$	COMP.W	D3,#KEYMDP	JUMP,EQ SELECT$	JUMP	BIP$OUTIL$:	TEST.L	D5:#BODOUT	JUMP,BC BIP$	COMP.W	D1,#3	JUMP,HS NODESS4$	CALL	DESNEWOUT	JUMP	LOOP$MODE$:	TEST.L	D5:#BODMOD	JUMP,BC BIP$	COMP.W	D1,#2	JUMP,HS NODESS4$	CALL	DESNEWMOD	JUMP	LOOP$OBJET$:	TEST.L	D5:#BODOBJ	JUMP,BC BIP$	COMP.W	D1,#4	JUMP,HS NODESS4$	CALL	DESNEWOBJ	JUMP	LOOP$DRAW$:	TEST.L	D5:#BODDRAW	JUMP',BS DGO$	TEST.L	D5:#BODSELECT	JUMP,BC NODESS4$	LOAD.L	A3,#R16"TEXT1B$	JUMP	FAUX$DGO$:	CALL	DESIFD		; dans la surface de dessin ?	JUMP,NE BIP$	CALL	DESSAVE		; sauve le dessin dans l'cran (pour UNDO)	COMP.W	(A6)+ODESOUT,#2	; bidon ?	JUMP,EQ FILL$	LOAD.L	D1,D4		; D1 <-- dpart	LOAD.L	D2,D4		; D2 <-- ancienne position	CALL	DESPENI		; initialise le pinceau	CLR.W	D6DLOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE DEND$	CALL	DESIFMOUSE	; D4 <-- position de la souris	JUMP,NE DLOOP$	CALL	DESIFD		; dans la surface de dessin ?	JUMP,NE DLOOP$	CALL	DESOBJM		; dessine l'objet	LOAD.L	D2,D4		; D2 <-- ancienne position	INC.W	D6	JUMP	DLOOP$DEND$:	LOAD.L	D3,D1	LOAD.L	D4,D2	LOAD.W	D2,#SETDOT	CALL	DESOBJ1		; dessine l'objet dfinitif	LOAD.L	A3,#R16"TEXT5$	COMP.W	D6,#1	JUMP,LS FAUX$DOK$:	TEST.W	D0		; fait qq chose ?	JUMP',NE DCTRL$		; oui => DCTRL$	TEST.L	D5:#BODCTRL	JUMP',BC DCTRL$	LOAD.B	(A6)+OCTRLG,#2^1 ; grise "same"	CALL	CTRLDRAW	; dessine le contrleDCTRL$:	INC.W	D0		; D0 <-- un trait de plus	TCLR.L	D0:#16		; D0 <-- texte "faux" affich ?	JUMP,BC LOOP$		; non => LOOP$	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,A2	CALL	TXBULLEL	; dessine le texte initial	LOAD.W	D1,#IMABLUPP1	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	DRAWCLOSE	; montre le dessin en mmoire	JUMP	LOOPM$FILL$:	CALL	DESFILL		; coule la peinture ...	JUMP,NE LOOP$	JUMP	DOK$SELECT$:	TEST.L	D5:#BODSELECT	JUMP',BS SGO$	TEST.L	D5:#BODDRAW	JUMP,BC NODESS4$	LOAD.L	A3,#R16"TEXT1A$	JUMP	FAUX$SGO$:	CALL	DESIFD		; dans la surface de dessin ?	JUMP,NE BIP$	CALL	DESSAVE		; sauve le dessin dans l'cran (pour UNDO)	LOAD.L	D1,D4		; D1 <-- dpart	LOAD.L	D2,D4		; D2 <-- dpart	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	.B	1	.B	0	.EVEN	CLR.W	D6	PUSH.W	(A6)+ODESOUT	LOAD.W	(A6)+ODESOUT,#-1	CALL	DESSELMO	; utilise la flche	POP.W	(A6)+ODESOUTSLOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE SEND$	CALL	DESIFMOUSE	; D4 <-- position de la souris	JUMP,NE SLOOP$	CALL	DESIFD		; dans la surface de dessin ?	JUMP,NE SLOOP$	CALL	DESOBJS		; efface l'ancien	LOAD.L	D2,D4	CALL	DESOBJS		; allume le nouveau	INC.W	D6	JUMP	SLOOP$SEND$:	COMP.W	D6,#2	JUMP',HI SOK$	CALL	DESOBJS		; efface le rectangle	LOAD.L	A3,#R16"TEXT6$	JUMP	FAUX$SOK$:	LOAD.L	A3,#R16"TXMENU$	LOAD.W	D3,#2^15	LOAD.L	D4,#2^4!2^6	; D4 <-- grise "opration" et "loupe"	LIB	?MMENU		; choix selon mmenu	LOAD.L	D4,D2	CALL	PMOUSE		; remet la souris o elle tait	LOAD.L	D6,D2	CALL	DESOBJS		; efface le rectangle	COMP.W	D1,D2	JUMP',LS SOKX$	LOAD.W	D4,D1	LOAD.W	D1,D2	LOAD.W	D2,D4SOKX$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,D2	JUMP',LS SOKY$	LOAD.W	D4,D1	LOAD.W	D1,D2	LOAD.W	D2,D4SOKY$:	SWAP.W	D1	SWAP.W	D2	LOAD.L	(A6)+ODESOP1,D1	LOAD.L	(A6)+ODESOP2,D2	COMP.W	D3,#1	JUMP',EQ SDETR$	COMP.W	D3,#2	JUMP',EQ SDETR$	COMP.W	D3,#3	JUMP',EQ SDUPL$	COMP.W	D3,#5	JUMP,EQ SNEG$	JUMP	LOOP$SDETR$:	PUSH.W	D3	CLR.L	D3	CLR.L	D4;;?	CALL	INVTRAME	LIB	?DRMDEF	LOAD.L	D3,D1	LOAD.L	D4,D2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	POP.W	D3	COMP.W	D3,#1	JUMP,EQ DOK$SDUPL$:	LOAD.L	D1,(A6)+ODESOP1	SUB.W	D6,D1	SWAP.W	D1	SWAP.W	D6	SUB.W	D6,D1	SWAP.W	D1	SWAP.W	D6	LOAD.L	D3,D1	LOAD.W	D2,#INVDOT	CALL	DESDDD		; dessine le premier	CLR.W	D2SDLOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE SDEND$	CALL	DESIFMOUSE	JUMP,NE SDLOOP$	SUB.W	D4,D6	SWAP.W	D4	SWAP.W	D6	SUB.W	D4,D6	SWAP.W	D4	SWAP.W	D6	CALL	DESIFD		; dans la surface de dessin ?	JUMP,NE SDLOOP$	LOAD.L	D3,D4	ADD.W	D4,(A6)+ODESOP2+2	SUB.W	D4,(A6)+ODESOP1+2	SWAP.W	D4	ADD.W	D4,(A6)+ODESOP2+0	SUB.W	D4,(A6)+ODESOP1+0	SWAP.W	D4	CALL	DESIFD		; dans la surface de dessin ?	JUMP,NE SDLOOP$	LOAD.L	D4,D3	PUSH.W	D2	LOAD.L	D3,D1	LOAD.W	D2,#INVDOT	CALL	DESDDD		; efface l'ancien	LOAD.L	D3,D4	CALL	DESDDD		; dessine le nouveau	LOAD.L	D1,D4	POP.W	D2	INC.W	D2	JUMP	SDLOOP$SDEND$:	PUSH.W	D2	LOAD.L	D3,D1	LOAD.W	D2,#INVDOT	CALL	DESDDD		; efface le dernier	LOAD.W	D2,#SETDOT;;?	CALL	INVMODE	CALL	DESDDD		; dessine dfinitivement	POP.W	D2	LOAD.L	A3,#R16"TEXT4$	COMP.W	D2,#2	JUMP,LS FAUX$	JUMP	DOK$SNEG$:	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D3,D1	LOAD.L	D4,D2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	JUMP	DOK$NODESS4$:	LOAD.L	A3,#R16"TEXT3$FAUX$:	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	TXBULLEL	; dessine le texte	LOAD.W	D1,#IMABLUPP2	LOAD.L	D2,#H'10000*(LYWDO-148-10)+40	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine toto	CALL	DRAWCLOSE	; montre le dessin en mmoire	TSET.L	D0:#16		; D0 <-- texte "faux" affich	JUMP	LOOPM$CTRL$:	LOAD.W	D3,#SHIFT!CR	; D3 <-- prcdent	DEC.W	D1	JUMP',NS END$	LOAD.W	D3,#TAB		; D3 <-- rpte	DEC.W	D1	JUMP',NS END$	LOAD.W	D3,#END		; D3 <-- fin	DEC.W	D1	JUMP',NS END$NEXT$:	LOAD.W	D3,#CR		; D3 <-- suivantEND$:	LOAD.L	A3,#R16"TEXT2$	TEST.W	D0		; qq chose de dessin ?	JUMP,EQ FAUX$		; non => FAUX$	CALL	DESSAVE		; sauve le dessin dans l'cran	LOAD.W	(A6)+ODESOUT,#-1	CALL	DESSELMO	; utilise la flche	CALL	CCMO		; enlve la souris	CALL	AFMENUNIL	; enlve les soft-keys	POPM.L	D0..D2,D4,D6,A2,A3	RETTEXT1A$:	.ASCII	/Vous devez dessiner avec le <AFBOLD>bouton de gauche<AFROMAN> !<CR>/	.B	0TEXT1B$:	.ASCII	/Vous devez slectionner avec le <AFBOLD>bouton de droite<AFROMAN> !<CR>/	.B	0TEXT2$:	.ASCII	/Essayez de raliser un dessin, avant de terminer en<CR>/	.ASCII	/appuyant sur <AFDRECT>F0<AFFRECT> = <AFDRECT>Fin<AFFRECT> ...<CR>/	.B	0TEXT3$:	.ASCII	/Hlas, toutes les fonctions de DESSIN4 ne sont pas<CR>/	.ASCII	/disponibles ici !!!<CR>/	.B	0TEXT4$:	.ASCII	/En choisissant <AFINV>"dplace"<AFDIR> ou <AFINV>"duplique"<AFDIR> dans le menu,<CR>/	.ASCII	/il faut <AFBOLD>maintenir press<AFROMAN> le bouton de la souris !<CR>/	.B	0TEXT5$:	.ASCII	/Pour dessiner, il faut <AFBOLD>maintenir press<AFROMAN><CR>/	.ASCII	/le bouton de gauche !<CR>/	.B	0TEXT6$:	.ASCII	/Pour slectionner, il faut <AFBOLD>maintenir press<AFROMAN><CR>/	.ASCII	/le bouton de droite !<CR>/	.B	0TXMENU$:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODETRUIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEPLACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  dplace  "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMOVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODUPLIQUE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  duplique "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMOVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODIVERS	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  opration.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICONEGATIF	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  ngatif"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOLOUPE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  loupe"	.B	0	.EVEN;---------\\; DESSELMO >;---------/; Slectionne un nouveau lutin pour la souris.; in	-; out	-; mod	D7.WDESSELMO:	PUSHM.L	D1..D5,A3..A5	LOAD.W	D2,(A6)+ODESOUT	COMP.W	(A6)+ODESMOD,#1	; gomme ?	JUMP',NE 04$		; non => 04$	TSET.L	D2:#7		; D2 <-- utilise la gome04$:	LOAD.W	D3,#-1		; D3 <-- pas d'outil; Vrifie si la souris est dans la zone de dessin.; Si non, n'utilise pas l'outil slectionn.	LOAD.L	D1,#-1		; D1 <-- hors de la fentre	CALL	DESIFMOUSE	; D4 <-- position de la souris	JUMP',NE 10$	LOAD.L	D1,D4	CALL	DESIFD		; dans la surface de dessin ?	JUMP',NE 10$		; non => 10$	LOAD.W	D3,D2		; D3 <-- outil slectionn10$:	COMP.W	D3,(A6)+OLUTIN	; toujours le mme outil ?	JUMP,EQ 90$		; oui => 90$	LOAD.W	(A6)+OLUTIN,D3	LOAD.L	A4,#R16"ONCCRAYON	LOAD.L	A5,#R16"ONFCRAYON	COMP.W	D3,#0	JUMP',EQ 20$	LOAD.L	A4,#R16"OGCCRAYON	LOAD.L	A5,#R16"OGFCRAYON	COMP.W	D3,#0!2^7	JUMP',EQ 20$	LOAD.L	A4,#R16"ONCPINCEAU	LOAD.L	A5,#R16"ONFPINCEAU	COMP.W	D3,#1	JUMP',EQ 20$	LOAD.L	A4,#R16"OGCPINCEAU	LOAD.L	A5,#R16"OGFPINCEAU	COMP.W	D3,#1!2^7	JUMP',EQ 20$	LOAD.L	A4,#R16"ONCBIDON	LOAD.L	A5,#R16"ONFBIDON	COMP.W	D3,#2	JUMP',EQ 20$	LOAD.L	A4,#0		; A4 <-- utilise la flche normale	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	CLR.W	(A6)+OLUPX	CLR.W	(A6)+OLUPY	JUMP'	50$20$:	LOAD.B	(A6)+OLUPX+1,(A4)-2	LOAD.B	(A6)+OLUPY+1,(A4)-150$:	NTREL	?GETPRIO	LOAD.W	D5,D4		; D5 <-- priorit actuelle	LOAD.W	D4,#1	NTREL	?SETPRIO	; met une trs forte priorit	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	LOAD.L	(A3)+1,A4	; <ssss> matrice chair	LOAD.L	(A3)+5,A5	; <cccc> matrice fond	LOAD.W	D3,#9	LIB	?STRING	COMP.L	D1,#-1		; hors de la fentre ?	JUMP,EQ 70$		; oui => 70$				; non =>	CALL	DESIFMOUSE	; D4 <-- position de la souris	JUMP,NE 70$	SUB.W	D4,D1	JUMP',NC 60$	NEG.W	D4		; D4 <-- |dplacement horizontal|60$:	COMP.W	D4,#30		; souris beaucoup bouge "entre temps" ?	JUMP',HS 70$		; oui => 70$ (crac, pas de positionnement !!!)	LOAD.L	D4,D1	SUB.W	D4,(A6)+OLUPX	SWAP.W	D4	SUB.W	D4,(A6)+OLUPY	SWAP.W	D4	CALL	PMOUSE		; positionne pour ne pas bouger la "pointe"70$:	LOAD.W	D4,D5	NTREL	?SETPRIO	; remet la priorit initiale90$:	POPM.L	D1..D5,A3..A5	RET;-----------\\; DESIFMOUSE >;===========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WDESIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	ADD.W	D4,(A6)+OLUPX	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	ADD.W	D4,(A6)+OLUPY	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;-------\\; DESMAJ >;=======/; Met  jour le dessin.; in	-; out	-; mod	D7.WDESMAJ:	PUSHM.L	D0..D4,A3	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT4$	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	CALL	CLRFIFO		; vide le fifo du clavierMAJ$:	CALL	SCMO		; remet la souris	CALL	DESDBMAJ	; mise  jour ...	COMP.W	D3,#F1	JUMP',EQ SAVE$	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT5$	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*1	NTREL	?DELMS	JUMP	MAJ$SAVE$:	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT6$	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoireSAVE2$:	CALL	SCMO		; remet la souris	CALL	DESDBSAV	; demande le nom ...	COMP.W	D3,#F1	JUMP',EQ EXIT$	LOAD.W	(A6)+OSOUND,#TMUSFAUX	CALL	DRAWOPENCOPY	; dessine en mmoire	LOAD.L	A3,#R16"TEXT7$	CALL	TXBULLEL	; dessine le texte	CALL	DRAWCLOSE	; montre le dessin en mmoire	LOAD.W	D4,#50*1	NTREL	?DELMS	JUMP	SAVE2$EXIT$:	CALL	CCMO		; enlve la souris	CALL	AFMENUNIL	; enlve les soft-keys	POPM.L	D0..D4,A3	RETTEXT4$:	.ASCII	/DESSIN4 vous demande s'il faut <AFBOLD>conserver<AFROMAN> votre dessin<CR>/	.ASCII	/dans un document sur la disquette #MM0.<CR>/	.ASCII	/Cliquez dans la case <AFDRECT> OUI <AFFRECT> ...<CR>/	.B	0TEXT5$:	.ASCII	/Vous n'avez pas cliqu dans la case <AFDRECT> OUI <AFFRECT><CR>/	.ASCII	/pour conserver votre chef-d'oeuvre !<CR>/	.ASCII	/Recommencez ...<CR>/	.B	0TEXT6$:	.ASCII	/Donnez <AFBOLD>le nom du document<AFROMAN> image  sauver. Si vous frap-<CR>/	.ASCII	/pez plus de 9 lettres, <AFDRECT>SAUVE<AFFRECT> devient gris (donc inactif).<CR>/	.ASCII	/Lorsque le nom est donn, cliquez dans <AFDRECT>SAUVE<AFFRECT> ...<CR>/	.B	0TEXT7$:	.ASCII	/Il ne faut pas cliquer dans <AFDRECT>ANNULE<AFFRECT> , /	.ASCII	/mais dans <AFDRECT>SAUVE<AFFRECT> ,<CR>/	.ASCII	/aprs avoir donn un nom de 9 lettres ou chiffres<CR>/	.ASCII	/au maximum. Essayez encore ...<CR>/	.B	0	.EVEN;--------\\; DESBASE >;========/; Affiche l'image de base.; in	-; out	-; mod	D7.WDESBASE:	PUSHM.L	D1..D4	LOAD.W	D1,#IMADESSIN1	LOAD.L	D2,#H'10000*ECRPY+ECRPX	CLR.L	D3	CLR.L	D4	CALL	IMAGEAFFF	; dessine l'image	CALL	DESINVALL	; inverse la surface	POPM.L	D1..D4	RET;--------\\; DESINIT >;========/; Initialise pour pouvoir dessiner.; in	-; out	-; mod	D7.WDESINIT:	PUSHM.L	D1,A3	LOAD.L	A3,#R16"DESPOSOUT	LOAD.L	(A6)+OBSQAD,A3	LOAD.W	D1,(A6)+ODESOUT	CALL	_BSQINV		; allume l'outil	LOAD.L	A3,#R16"DESPOSMOD	LOAD.L	(A6)+OBSQAD,A3	LOAD.W	D1,(A6)+ODESMOD	CALL	_BSQINV		; allume le mode	LOAD.L	A3,#R16"DESPOSOBJ	LOAD.L	(A6)+OBSQAD,A3	LOAD.W	D1,(A6)+ODESOBJ	CALL	_BSQINV		; allume l'objet	LOAD.L	A3,#R16"TXMENU$	LIB	?AFMENU		; met les soft-keys de DESSIN4 !	LOAD.W	(A6)+OLUTIN,#-1	POPM.L	D1,A3	RETTXMENU$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"      Ajoute     "	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" Df. Zoom Scanne"		;     ;     ;     ;	.ASCIZ	"Echelle"	.ASCIZ	"  -    1:1    +  "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Rgle     Ngatif"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Tout  Efface Imp."		;     ;     ;     ;	.EVEN;----------\\; DESNEWOUT >;==========/; Slectionne un nouvel outil.; in	D1.W	nouvel outil; out	-; mod	D7.WDESNEWOUT:	PUSHM.L	D1,D2,A3	LOAD.W	D2,D1	LOAD.W	D1,(A6)+ODESOUT	CALL	_BSQINV		; teint l'ancien	LOAD.W	D1,D2	CALL	_BSQINV		; allume le nouveau	LOAD.W	(A6)+ODESOUT,D1;;?	COMP.W	D1,#2		; spray ?;;?	JUMP',EQ OBJETNIL$	COMP.W	D1,#2		; bidon ?	JUMP',EQ MODESET$	TEST.W	(A6)+ODESOBJ	JUMP',NC EXIT$OBJETTML$:	LOAD.L	A3,#R16"DESPOSOBJ	LOAD.L	(A6)+OBSQAD,A3	LOAD.W	D1,(A6)+ODESOBJ	JUMP,EQ EXIT$	CALL	_BSQINV		; teint l'ancien	CLR.W	D1	CALL	_BSQINV		; allume le nouveau	LOAD.W	(A6)+ODESOBJ,D1	JUMP'	EXIT$MODESET$:	LOAD.L	A3,#R16"DESPOSMOD	LOAD.L	(A6)+OBSQAD,A3	LOAD.W	D1,(A6)+ODESMOD	JUMP',EQ OBJETNIL$	CALL	_BSQINV		; teint l'ancien	CLR.W	D1	CALL	_BSQINV		; allume le nouveau	LOAD.W	(A6)+ODESMOD,D1OBJETNIL$:	LOAD.L	A3,#R16"DESPOSOBJ	LOAD.L	(A6)+OBSQAD,A3	LOAD.W	D1,(A6)+ODESOBJ	JUMP,NS EXIT$	CALL	_BSQINV		; teint l'ancien	LOAD.W	D1,#-1	CALL	_BSQINV		; allume le nouveau	LOAD.W	(A6)+ODESOBJ,D1EXIT$:	POPM.L	D1,D2,A3	RET;----------\\; DESNEWMOD >;==========/; Slectionne un nouveau mode.; in	D1.W	nouvel outil; out	-; mod	D7.WDESNEWMOD:	PUSHM.L	D1,D2,A3	COMP.W	(A6)+ODESOUT,#2	; bidon ?	JUMP',EQ EXIT$	LOAD.W	D2,D1	LOAD.W	D1,(A6)+ODESMOD	CALL	_BSQINV		; teint l'ancien	LOAD.W	D1,D2	CALL	_BSQINV		; allume le nouveau	LOAD.W	(A6)+ODESMOD,D1EXIT$:	POPM.L	D1,D2,A3	RET;----------\\; DESNEWOBJ >;==========/; Slectionne un nouvel objet.; in	D1.W	nouvel outil; out	-; mod	D7.WDESNEWOBJ:	PUSHM.L	D1,D2,A3	LOAD.W	D2,D1	LOAD.W	D1,(A6)+ODESOBJ	CALL	_BSQINV		; teint l'ancien	LOAD.W	D1,D2	CALL	_BSQINV		; allume le nouveau	LOAD.W	(A6)+ODESOBJ,D1;;?	COMP.W	(A6)+ODESOUT,#2	; spray ?;;?	JUMP',EQ OUTILCR$	COMP.W	(A6)+ODESOUT,#2	; bidon ?	JUMP',NE EXIT$OUTILCR$:	LOAD.L	A3,#R16"DESPOSOUT	LOAD.L	(A6)+OBSQAD,A3	LOAD.W	D1,(A6)+ODESOUT	JUMP',EQ EXIT$	CALL	_BSQINV		; teint l'ancien	CLR.W	D1	CALL	_BSQINV		; allume le nouveau	LOAD.W	(A6)+ODESOUT,D1EXIT$:	POPM.L	D1,D2,A3	RET;-------\\; DESIFD >;=======/; Regarde si la souris est dans la surface de dessin.; in	D4.L	position (y;x); out	D7.W	ok/erreur; mod	D7.WDESIFD:	PUSH.L	D4	LOAD.W	D7,#1	SUB.W	D4,#112+ECRPX	JUMP',LT EXIT$	COMP.W	D4,#282	JUMP',GE EXIT$	SWAP.W	D4	SUB.W	D4,#20+ECRPY	JUMP',LT EXIT$	COMP.W	D4,#175	JUMP',GE EXIT$	CLR.W	D7EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DESOBJM >;========/; Dessine un objet pendant un mouvement lors de la cration.; in	D1.L	dpart (y;x);	D2.L	dernire position (y;x);	D4.L	nouvelle position (y;x); out	-; mod	D7.WDESOBJM:	PUSHM.L	D2..D4	TEST.W	(A6)+ODESOBJ	JUMP',NE LINE$TML$:	LOAD.L	D3,D2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	COMP.W	(A6)+ODESMOD,#1	JUMP',NE TML3$	LOAD.W	D2,#CLRDOTTML3$:	COMP.W	(A6)+ODESOUT,#1	JUMP',NE TML4$	OR.W	D2,#PENDOTTML4$:;;?	CALL	INVMODE	LIB	?DRSEG	JUMP'	EXIT$LINE$:	PUSH.L	D4	LOAD.L	D3,D1	LOAD.L	D4,D2	LOAD.W	D2,#INVDOT	CALL	DESOBJ1		; efface l'ancien	POP.L	D4;	LOAD.L	D3,D1;	LOAD.L	D4,D4;	LOAD.W	D2,#INVDOT	CALL	DESOBJ1		; allume le nouveau;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4	RET;--------\\; DESOBJ1 >;========/; Dessine un objet juste une fois.; in	D2.W	mode de dessin;	D3.L	dpart (y;x);	D4.L	arrive (y;x); out	-; mod	D7.WDESOBJ1:	PUSHM.L	D1..D4	COMP.W	D2,#INVDOT	JUMP',EQ MODE$	COMP.W	D2,#INVDOT!TTTDOT	JUMP',EQ MODE$	COMP.W	(A6)+ODESMOD,#1	JUMP',NE SET$	LOAD.W	D2,#CLRDOTSET$:	COMP.W	(A6)+ODESOUT,#1	JUMP',NE MODE$	OR.W	D2,#PENDOTMODE$:;;?	CALL	INVMODE	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,(A6)+ODESOBJ	COMP.W	D1,#1	JUMP',EQ LINE$	COMP.W	D1,#2	JUMP',EQ RECT$	COMP.W	D1,#3	JUMP',EQ CIRC$TML$:	JUMP	EXIT$LINE$:	LIB	?DRSEG	JUMP	EXIT$RECT$:	LIB	?DRRECT	JUMP	EXIT$CIRC$:	TEST.W	D4	JUMP',NC CIRC2$	NEG.W	D4CIRC2$:	LOAD.L	D1,D4	SWAP.W	D1	TEST.W	D1	JUMP',NC CIRC3$	NEG.W	D1CIRC3$:	COMP.W	D4,D1	JUMP',HS CIRC4$	LOAD.W	D4,D1CIRC4$:	COMP.W	D4,#3	JUMP',LO EXIT$	LOAD.W	D1,D4	LOAD.L	D4,D3	SUB.W	D4,D1	SWAP.W	D4	SUB.W	D4,D1	SWAP.W	D4	CALL	DESIFD	JUMP',NE EXIT$	LOAD.L	D4,D3	ADD.W	D4,D1	SWAP.W	D4	ADD.W	D4,D1	SWAP.W	D4	CALL	DESIFD	JUMP',NE EXIT$	LOAD.W	D4,D1	LIB	?DRCERCLE;	JUMP'	EXIT$EXIT$:	POPM.L	D1..D4	RET;--------\\; DESOBJS >;========/; Dessine un rectangle de slection.; in	D1.L	dpart (y;x);	D2.L	arrive (y;x); out	-; mod	D7.WDESOBJS:	PUSHM.L	D2..D4	LOAD.L	D3,D1	LOAD.L	D4,D2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT	POPM.L	D2..D4	RET;--------\\; DESPENI >;========/; Initialise le pinceau.; in	-; out	-; mod	D7.WDESPENI:	PUSHM.L	D3,A3	COMP.W	(A6)+ODESOUT,#1	JUMP',NE EXIT$	LOAD.L	A3,#R16"PEN$	LOAD.W	D3,#9	LIB	?STRINGEXIT$:	POPM.L	D3,A3	RETPEN$:	.B	PEN	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00111100	.B	B'00111100	.B	B'00011000	.B	B'00000000	.B	B'00000000	.EVEN;--------\\; DESFILL >;========/; Remplissage avec le bidon.; in	D4.L	coordonne (y;x); out	D7.W	erreur; mod	D7.WDESFILL:	PUSHM.L	D1..D5,A3	LOAD.L	D1,D4	LIB	?GETWDO	LOAD.W	D2,D5		; D2 <-- swdo actuelle	LOAD.L	D3,#H'10000*(20+ECRPY)+(112+ECRPX)	LOAD.L	D4,#H'10000*175+282	SUB.W	D1,D3	ADD.W	D3,(A0)+ODFFX	SWAP.W	D1	SWAP.W	D3	SUB.W	D1,D3	ADD.W	D3,(A0)+ODFFY	SWAP.W	D1	SWAP.W	D3	LIB	?CREWDO	LIB	?USEWDO	PUSH.L	D4	LOAD.L	D3,#H'55AA55AA	LOAD.L	D4,D3	LIB	?DRMDEF	POP.L	D4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3)+0,#AFFILLT	LOAD.B	(A3)+1,#DRAWFILLO	SWAP.W	D1	LOAD.L	(A3)+2,D1	LOAD.B	(A3)+6,#DRAWFILLC	LOAD.B	(A3)+7,#AFFILLA	LOAD.W	D3,#8	LIB	?STRING		; rempli dans la swdo	PUSH.W	D7	JUMP',EQ OK$	LOAD.W	D3,#BIPERR	LIB	?BEEPOK$:	EX.L	D5,D2	LIB	?USEWDO		; remet la swdo initiale	LOAD.W	D5,D2	LIB	?KILWDO	POP.W	D7	POPM.L	D1..D5,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; DESINVALL >;----------/; Inverse toute la fentre, si l'on est en mode inverse.; in	-; out	-; mod	D7.WDESINVALL:	PUSHM.L	D2..D4	TEST.B	(A6)+OINV	JUMP',F EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D3,#H'10000*(20+ECRPY)+(112+ECRPX)	LOAD.L	D4,#H'10000*175+282	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse toutEXIT$:	POPM.L	D2..D4	RET;--------\\; DESDDD  >;========/; Affiche une partie du dessin sauv.; in	D2.W	mode de dessin;	D3.L	position dans l'cran (y;x); out	-; mod	D7.WDESDDD:	PUSHM.L	D1..D6,A3,A4	TEST.L	(A6)+OSIMPT	JUMP,EQ EXIT$	CALL	CCMO		; enlve la souris	LOAD.L	D4,D3	LOAD.L	A4,#0	LOAD.L	D3,(A6)+ODESOP1	LOAD.W	D5,#(282/8)+1	LOAD.L	A3,(A6)+OSIMPT	LOAD.L	D1,(A6)+ODESOP2	SUB.W	D1,D3	SUB.W	D3,#112+ECRPX	SWAP.W	D1	SWAP.W	D3	SUB.W	D1,D3	SUB.W	D3,#20+ECRPY	SWAP.W	D1	SWAP.W	D3	TSET.L	D2:#BSRCCOUL	TSET.L	D2:#BDSTCOUL	CALL	DRRASTER	; affiche une partie du dessin	COMP.B	D2,#INVDOT	JUMP',NE END$	LOAD.L	D2,D1	LOAD.L	D1,D4	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	CALL	DESOBJS		; inverse le rectangleEND$:	CALL	SCMO		; remet la sourisEXIT$:	POPM.L	D1..D6,A3,A4	RET;----------\\; DESPOSOUT >;==========/; Donne la position d'un outil.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WDESPOSOUT:	PUSH.L	D1	LOAD.W	D7,#1	COMP.W	D1,#7	JUMP',HS EXIT$	LOAD.L	D3,#H'10000*(ECRDY-1-196)+5	; crayon	LOAD.L	D4,#H'10000*25+55	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-170)+5	; pinceau;	LOAD.L	D4,#H'10000*25+55	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-144)+33	; bidon	LOAD.L	D4,#H'10000*25+27	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-196)+61	; main;	LOAD.L	D4,#H'10000*25+27	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-170)+61	; df. pinceau;	LOAD.L	D4,#H'10000*25+27	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-144)+5	; vaporisateur;	LOAD.L	D4,#H'10000*25+27	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-144)+61	; df. trame;	LOAD.L	D4,#H'10000*25+27;	DEC.W	D1;	JUMP',NS OK$OK$:	ADD.W	D3,#ECRPX	SWAP.W	D3	ADD.W	D3,#ECRPY	SWAP.W	D3	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;----------\\; DESPOSMOD >;==========/; Donne la position d'un mode.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WDESPOSMOD:	PUSH.L	D1	LOAD.W	D7,#1	COMP.W	D1,#3	JUMP',HS EXIT$	LOAD.L	D3,#H'10000*(ECRDY-1-113)+5	; noir	LOAD.L	D4,#H'10000*25+27	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-113)+33	; gomme;	LOAD.L	D4,#H'10000*25+27	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-113)+61	; pas;	LOAD.L	D4,#H'10000*25+27;	DEC.W	D1;	JUMP',NS OK$OK$:	ADD.W	D3,#ECRPX	SWAP.W	D3	ADD.W	D3,#ECRPY	SWAP.W	D3	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;----------\\; DESPOSOBJ >;==========/; Donne la position d'un objet.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WDESPOSOBJ:	PUSH.L	D1	LOAD.W	D7,#1	COMP.W	D1,#6	JUMP',HS EXIT$	LOAD.L	D3,#H'10000*(ECRDY-1-82)+5	; trait  main leve	LOAD.L	D4,#H'10000*25+27	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-82)+33	; droite;	LOAD.L	D4,#H'10000*25+27	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-56)+5	; rectangle	LOAD.L	D4,#H'10000*25+55	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-30)+5	; cercle;	LOAD.L	D4,#H'10000*25+55	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-82)+61	; courbe	LOAD.L	D4,#H'10000*25+27	DEC.W	D1	JUMP',NS OK$	LOAD.L	D3,#H'10000*(ECRDY-1-56)+61	; df. rectangle;	LOAD.L	D4,#H'10000*25+27;	DEC.W	D1;	JUMP',NS OK$OK$:	ADD.W	D3,#ECRPX	SWAP.W	D3	ADD.W	D3,#ECRPY	SWAP.W	D3	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;--------\\; DESUNDO >;========/; Restitue le dessin dans l'cran.; in	-; out	-; mod	D7.WDESUNDO:	PUSHM.L	D1..D6,A3,A4	TEST.L	(A6)+OSIMPT	JUMP',EQ EXIT$	CALL	CCMO		; enlve la souris	CLR.L	D3	LOAD.W	D5,#(282/8)+1	LOAD.L	A3,(A6)+OSIMPT	LOAD.L	D4,#H'10000*(ECRDY-1-195+ECRPY)+(112+ECRPX)	LOAD.L	A4,#0	LOAD.L	D1,#H'10000*175+282	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	; restitue le dessinEXIT$:	CALL	SCMO		; remet la souris	POPM.L	D1..D6,A3,A4	RET;--------\\; DESSAVE >;========/; Sauve le dessin dans l'cran.; in	-; out	-; mod	D7.WDESSAVE:	PUSHM.L	D1..D6,A3,A4	TEST.L	(A6)+OSIMPT	JUMP',NE XFER$	CLR.W	D4	LOAD.B	D4,(A0)+ODFCNP	; D4 <-- nb de bits/pixel (1,4)	MUL.WU	D4,#((282/8)+1)*175	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP',NE EXIT$	LOAD.L	(A6)+OSIMPT,A4XFER$:	CALL	CCMO		; enlve la souris	LOAD.L	D3,#H'10000*(20+ECRPY)+(112+ECRPX)	LOAD.L	A3,#0	CLR.L	D4	LOAD.W	D6,#(282/8)+1	LOAD.L	A4,(A6)+OSIMPT	LOAD.L	D1,#H'10000*175+282	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	; mmorise le dessinEXIT$:	CALL	SCMO		; remet la souris	POPM.L	D1..D6,A3,A4	RET;---------\\; DESDBSAV >;=========/; Demande le nom  sauver.; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESDBSAV:	PUSHM.L	D1,D2,D4,D5,A3..A5	LOAD.L	A5,#(A6)+OSIMNM	LOAD.L	A4,#R16"EXT$	LOAD.L	A3,#R16"TDBOX_IOIM	LOAD.L	D5,#H'10000*226+440	ADD.W	D5,(A0)+ODFFX	SWAP.W	D5	ADD.W	D5,(A0)+ODFFY	SWAP.W	D5	CLR.L	D4	LOAD.L	D3,#2^BDBIONMAJ!2^BDBIOEXT1!50	LOAD.W	D2,#2^BDBSAV!2^BDBPOS!2^BDBEXTEND	LOAD.W	D1,#DBOX_SAUVE	DBOX_	EXTEND		; mise  jour ...	POPM.L	D1,D2,D4,D5,A3..A5	TEST.W	D7		; retour EQ/NE	RETEXT$:	.ASCIZ	".IMAGE"	.EVEN;---------\\; DESDBMAJ >;=========/; Mise  jour ?; in	-; out	D3.W	dernire touche; mod	D3.L, D7.WDESDBMAJ:	PUSHM.L	D1,D2,D4,D5,A3,A5	LOAD.L	A5,#(A6)+OSIMNM	CLR.B	(A5)	LOAD.L	A3,#R16"TDBOX_IOIM	LOAD.L	D5,#H'10000*226+440	ADD.W	D5,(A0)+ODFFX	SWAP.W	D5	ADD.W	D5,(A0)+ODFFY	SWAP.W	D5	CLR.L	D4	LOAD.L	D3,#2^BDBIOQUIT!1	LOAD.W	D2,#2^BDBSAV!2^BDBPOS!2^BDBEXTEND	LOAD.W	D1,#DBOX_MAJ	DBOX_	EXTEND		; mise  jour ...	POPM.L	D1,D2,D4,D5,A3,A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_IOIM:	.ASCIZ	"DESSIN"	; nom du logiciel	.ASCIZ	"Fimage"	; [M,F] nom des lments manipuls	.ASCIZ	"Fpage"		; [M,F] nom du contenant	.B	0	.EVEN	.END