	.SBTTL	BJMOVE.ASI;-----------\\; MOVEENLEVE >;===========/; Enlve toto lorsque l'cran changera.; in	-; out	-; mod	D7.WMOVEENLEVE:	PUSHM.L	A2,A5	LOAD.L	A5,#(A6)+OOBJ1	LOAD.L	A2,(A5)+OOCHIM	; A2 <-- canal	CALL	MOVECLEAR	; enlve toto	CALL	MOVECLOSE	CLR.L	(A5)+OOCHIM	POPM.L	A2,A5	RET;----------\\; MOVEREMET >;==========/; Remet toto si l'cran a chang.; in	-; out	-; mod	D7.WMOVEREMET:	PUSHM.L	D3,D4,A2,A5	LOAD.L	A5,#(A6)+OOBJ1	LOAD.L	D4,(A5)+OOLPOS	; D4 <-- dernire position	LOAD.W	D3,(A5)+OORIMA	; D3 <-- dernire image	CALL	MOVEOPEN	LOAD.L	(A5)+OOCHIM,A2	LOAD.W	D3,(A5)+OORIMA	; D3 <-- dernire image	CALL	MOVEDRAW	; remet totoEXIT$:	POPM.L	D3,D4,A2,A5	RET;--------\\; MOVEALL >;========/; Mouvement complet pour l'objet 1.; in	A4.L	^table des mouvements; out	-; mod	D7.WMOVEALL:	PUSH.L	A5	LOAD.L	A5,#(A6)+OOBJ1	CALL	MOVEBEGINLOOP$:	CALL	MOVENEXT	JUMP,EQ LOOP$	POP.L	A5	RET;----------\\; MOVEBEGIN >;==========/; Dbut d'un mouvement d'objet anim.; in	A5.L	^descripteur objet anim;	A4.L	^table des mouvements; out	-; mod	D7.WMOVEBEGIN:	LOAD.L	(A5)+OOMPTA,A4	CLR.W	(A5)+OOMCTN	RET;---------\\; MOVENEXT >;=========/; Dplace un objet anim.; in	A5.L	^descripteur objet anim; out	D7.W	erreur si mouvement fini; mod	D7.WMOVENEXT:	PUSHM.L	D3,D4,A2,A4	TEST.W	(A5)+OOMCTN	JUMP,NE POS$; Cherche l'lment suivant dans la table.NEXT$:	LOAD.L	A4,(A5)+OOMPTA	LOAD.W	D7,#EROUTF	TEST.W	(A4)		; fin de la table ?	JUMP,EQ EXIT$		; oui => EXIT$	CALL	MOVESPEC	; objet spcial TMxxxx ?	JUMP',NE NSPEC$		; non => NSPEC$	LOAD.L	(A5)+OOMPTA,A4	JUMP	NEXT$NSPEC$:	LOAD.L	(A5)+OOMPTB,A4	LOAD.W	(A5)+OOMCTN,(A4+)	ADD.L	A4,#4	LOAD.W	(A5)+OOMNBI,#-1NBI$:	INC.W	(A5)+OOMNBI	TEST.W	(A4+)	JUMP,NE NBI$	CLR.W	(A5)+OOMCTI	LOAD.L	(A5)+OOMPTA,A4; Cherche la nouvelle position et la nouvelle icne.POS$:	LOAD.L	A4,(A5)+OOMPTB	; A4 <-- ^lment prcdent	DEC.W	(A5)+OOMCTN	LOAD.W	D4,(A5)+OOLPOS+0	ADD.W	D4,(A4)+2	LOAD.W	(A5)+OONPOS+0,D4	LOAD.W	D4,(A5)+OOLPOS+2	ADD.W	D4,(A4)+4	LOAD.W	(A5)+OONPOS+2,D4	TEST.W	(A5)+OOMNBI	JUMP,EQ END$	LOAD.W	D3,(A5)+OOMCTI	SL.W	D3,#1	LOAD.W	(A5)+OORIMA,(A4)+(D3.W)+6	SR.W	D3,#1	INC.W	D3	COMP.W	D3,(A5)+OOMNBI	JUMP',LO NLI$	CLR.W	D3NLI$:	LOAD.W	(A5)+OOMCTI,D3; Bouge l'objet sur l'cran.	LOAD.W	D3,(A5)+OORIMA	LOAD.L	D4,(A5)+OONPOS	LOAD.L	A2,(A5)+OOCHIM	; A2 <-- canal	CALL	MOVEDRAW	; dplace l'icne	LOAD.W	D4,(A5)+OOMDEL	JUMP',EQ END$	NTREL	?DELMS		; attend un peuEND$:	LOAD.L	(A5)+OOLPOS,(A5)+OONPOS	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MOVESPEC >;---------/; Traite les objet spciaux TMxxx contenus dans la table.; in	A4.L	^dans table; out	A4.L	^plus loin;	D7.W	erreur; mod	D7.W, A4.LMOVESPEC:	PUSHM.L	D2..D4,A2,A3	LOAD.W	D7,#1		; D7 <-- pas un objet TMxxxx	TEST.W	(A4)	JUMP,NC EXIT$	LOAD.W	D4,(A4+)	; D4 <-- objet TMxxxx	COMP.W	D4,#TMOPEN	JUMP,EQ OPEN$	COMP.W	D4,#TMCLEAR	JUMP,EQ CLEAR$	COMP.W	D4,#TMCLOSE	JUMP,EQ CLOSE$	COMP.W	D4,#TMDEL	JUMP,EQ DEL$	COMP.W	D4,#TMSOUND	JUMP,EQ SOUND$	COMP.W	D4,#TMSKIPNE	JUMP,EQ SKIPNE$	COMP.W	D4,#TMSKIPEQ	JUMP,EQ SKIPEQ$	JUMP	EXIT$OPEN$:	LOAD.L	(A5)+OOLPOS,(A4+)	LOAD.W	(A5)+OORIMA,(A4+)	LOAD.L	(A5)+OOMPTA,A4	CLR.W	(A5)+OOMCTN	LOAD.L	D4,(A5)+OOLPOS	; D4 <-- position initiale	LOAD.W	D3,(A5)+OORIMA	; D3 <-- dernire image	CALL	MOVEOPEN	; A2 <-- canal	LOAD.L	(A5)+OOCHIM,A2	JUMP	OK$CLEAR$:	LOAD.L	A2,(A5)+OOCHIM	CALL	MOVECLEAR	; enlve l'icne	CLR.L	(A5)+OOCHIM	JUMP	OK$CLOSE$:	LOAD.L	A2,(A5)+OOCHIM	CALL	MOVECLOSE	; termine le dplacement	CLR.L	(A5)+OOCHIM	JUMP	OK$DEL$:	LOAD.W	(A5)+OOMDEL,(A4+)	JUMP	OK$SOUND$:	LOAD.W	(A6)+OSOUND,(A4+)	JUMP	OK$SKIPNE$:	ADD.L	A4,#+8		; A4 <-- saute SKIPNE et paramtres	LOAD.L	A3,A6	ADD.W	A3,(A4)-8+0	; A3 <-- ^variable	LOAD.W	D3,(A3)		; D3 <-- valeur variable	COMP.W	D3,(A4)-8+2	; effectue le test	JUMP',LO SKIP$	COMP.W	D3,(A4)-8+4	; effectue le test	JUMP',HI SKIP$	JUMP'	OK$SKIPEQ$:	ADD.L	A4,#+8		; A4 <-- saute SKIPEQ et paramtres	LOAD.L	A3,A6	ADD.W	A3,(A4)-8+0	; A3 <-- ^variable	LOAD.W	D3,(A3)		; D3 <-- valeur variable	COMP.W	D3,(A4)-8+2	; effectue le test	JUMP',LO OK$	COMP.W	D3,(A4)-8+4	; effectue le test	JUMP',HI OK$SKIP$:	CALL	_ADCODE		; LOAD.L A3,#R16"ADCODE	CLR.L	D3	LOAD.W	D3,(A4)-8+6	ADD.L	A3,D3		; A4 <-- adresse absolue si NE	LOAD.L	A4,A3;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; MOVEOPEN >;=========/; Dbut d'un dplacement d'image.; in	D4.L	position initiale (y;x);	D3.W	rang de l'image (0..n); out	A2.L	canal;	D7.W	erreur; mod	D7.W, A2.LMOVEOPEN:	PUSHM.L	D1..D6,A1,A3,A4	LOAD.L	A2,#0	LOAD.W	D2,D3	LOAD.L	D3,D4; Demande de la mmoire pour le canal.	LOAD.L	D4,#LMI	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP',NE EXIT$	LOAD.L	A2,A4		; A2 <-- "canal"	LOAD.W	(A2)+OMIIMA,D2	LOAD.L	A1,#(A6)+OBKTAB	MUL.WU	D2,#LBK	ADD.L	A1,D2		; A1 <-- ^dans OBKTAB	LOAD.L	A4,(A1)+OBKPIC	; A4 <-- ^en-tte image	LOAD.W	(A2)+OMIDIM+2,(A4)+OIMDLX	LOAD.W	(A2)+OMIDIM+0,(A4)+OIMDLY	LOAD.W	D4,(A2)+OMIDIM+2	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.W	(A2)+OMIIIY,D4	CLR.W	D1	LOAD.B	D1,(A0)+ODFCNP	; D1 <-- nb de bits/pixel (1,4)	MUL.WU	D4,D1	MUL.WU	D4,(A2)+OMIDIM+0	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP',NE EXIT$	LOAD.L	(A2)+OMIMAT,A4; Transfert l'cran dans le bitmap original.	LOAD.L	A3,#0	LOAD.L	A4,(A2)+OMIMAT	CLR.L	D4	LOAD.W	D6,(A2)+OMIIIY	LOAD.L	D1,(A2)+OMIDIM	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	LOAD.L	(A2)+OMIPOS,D3	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D6,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MOVEDRAW >;=========/; Dplace une image.; in	D4.L	position sup/gauche (y;x);	D3.W	rang de l'image (0..n,-1);	A2.L	canal; out	-; mod	D7.WMOVEDRAW:	PUSHM.L	D0..D6,A1,A3,A4	SUB.L	SP,#4		; SP <-- ^variables	COMP.L	A2,#0	JUMP,EQ EXIT$	COMP.W	D3,#-1	JUMP',NE IMA$	LOAD.W	D3,(A2)+OMIIMAIMA$:	LOAD.W	(A2)+OMIIMA,D3	LOAD.L	A1,#(A6)+OBKTAB	MUL.WU	D3,#LBK	ADD.L	A1,D3		; A1 <-- ^dans OBKTAB	TEST.L	(A1)+OBKPIF	; image fond existe dj ?	JUMP',NE FOND$		; oui => FOND$	LOAD.W	D1,(A2)+OMIIMA	CALL	IMAGECALCFOND	; calcule le fond	JUMP,NE EXIT$FOND$:	LOAD.L	D0,D4		; D0 <-- nouvelle position	LOAD.L	D1,D4	SUB.W	D1,(A2)+OMIPOS+2	JUMP',NC DIMX$	NEG.W	D1DIMX$:	COMP.W	D1,(A2)+OMIDIM+2	JUMP,HS EXIT$		; <<<<<<< PROVISOIRE <<<<<<<<<	ADD.W	D1,(A2)+OMIDIM+2 ; D1 <-- largeur totale	SWAP.W	D1	SUB.W	D1,(A2)+OMIPOS+0	JUMP',NC DIMY$	NEG.W	D1DIMY$:	COMP.W	D1,(A2)+OMIDIM+0	JUMP,HS EXIT$		; <<<<<<< PROVISOIRE <<<<<<<<<	ADD.W	D1,(A2)+OMIDIM+0 ; D1 <-- hauteur totale	SWAP.W	D1	LOAD.L	(SP)+0,D1	; stack <-- dimensions totales; Transfert le bitmap original dans le bitmap temporaire.	LOAD.L	A3,(A2)+OMIMAT	CLR.L	D3	LOAD.W	D5,(A2)+OMIIIY	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,(A2)+OMIPOS+2	SUB.W	D4,D0	JUMP',NC P0DX$	CLR.W	D4P0DX$:	SWAP.W	D0	SWAP.W	D4	LOAD.W	D4,(A2)+OMIPOS+0	SUB.W	D4,D0	JUMP',NC P0DY$	CLR.W	D4P0DY$:	SWAP.W	D0	SWAP.W	D4	LOAD.W	D6,(A2)+OMIIIY	SL.W	D6,#1	LOAD.L	D1,(A2)+OMIDIM	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER; Transfert l'image (1) dans le bitmap temporaire.	LOAD.L	A3,#0	LOAD.W	D3,(A2)+OMIPOS+2	COMP.W	D3,D0	JUMP',LE P1SX$	LOAD.W	D3,D0P1SX$:	SWAP.W	D0	SWAP.W	D3	LOAD.W	D3,D0	SWAP.W	D0	SWAP.W	D3;	LOAD.L	A4,#(A6)+OBUDIS	CLR.L	D4;	LOAD.W	D6,(A2)+OMIIIY;	SL.W	D6,#1	LOAD.W	D1,(SP)+2	SWAP.W	D0	SWAP.W	D1	LOAD.W	D1,(A2)+OMIPOS+0	SUB.W	D1,D0	SWAP.W	D1	SWAP.W	D0;	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER; Transfert l'image (2) dans le bitmap temporaire.;	LOAD.L	A3,#0	LOAD.W	D3,D0	SWAP.W	D3	LOAD.W	D3,(A2)+OMIPOS+0	SWAP.W	D3;	LOAD.L	A4,#(A6)+OBUDIS	CLR.W	D4	SWAP.W	D0	SWAP.W	D4	LOAD.W	D4,(A2)+OMIPOS+0	SUB.W	D4,D0	JUMP',NC P2DY$	CLR.W	D4P2DY$:	SWAP.W	D0	SWAP.W	D4;	LOAD.W	D6,(A2)+OMIIIY;	SL.W	D6,#1	LOAD.W	D1,(A2)+OMIPOS+2	SUB.W	D1,D0	SWAP.W	D1	LOAD.W	D1,(A2)+OMIDIM+0	SWAP.W	D1;	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER; Transfert l'image (3) dans le bitmap temporaire.;	LOAD.L	A3,#0	LOAD.W	D3,(A2)+OMIPOS+2	ADD.W	D3,(A2)+OMIDIM+2	SWAP.W	D3	LOAD.W	D3,(A2)+OMIPOS+0	SWAP.W	D3;	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,(A2)+OMIDIM+2	SWAP.W	D0	SWAP.W	D4	LOAD.W	D4,(A2)+OMIPOS+0	SUB.W	D4,D0	JUMP',NC P3DY$	CLR.W	D4P3DY$:	SWAP.W	D0	SWAP.W	D4;	LOAD.W	D6,(A2)+OMIIIY;	SL.W	D6,#1	LOAD.W	D1,D0	SUB.W	D1,(A2)+OMIPOS+2	SWAP.W	D1	LOAD.W	D1,(A2)+OMIDIM+0	SWAP.W	D1;	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER; Transfert l'image (4) dans le bitmap temporaire.;	LOAD.L	A3,#0	LOAD.W	D3,(A2)+OMIPOS+2	COMP.W	D3,D0	JUMP',LE P4SX$	LOAD.W	D3,D0P4SX$:	SWAP.W	D3	LOAD.W	D3,(A2)+OMIPOS+0	ADD.W	D3,(A2)+OMIDIM+0	SWAP.W	D3;	LOAD.L	A4,#(A6)+OBUDIS	CLR.W	D4	SWAP.W	D4	LOAD.W	D4,(A2)+OMIDIM+0	SWAP.W	D4;	LOAD.W	D6,(A2)+OMIIIY;	SL.W	D6,#1	LOAD.W	D1,(SP)+2	SWAP.W	D0	SWAP.W	D1	LOAD.W	D1,D0	SUB.W	D1,(A2)+OMIPOS+0	SWAP.W	D1	SWAP.W	D0;	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER; Transfert le bitmap temporaire dans le bitmap original.	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D3,D0	SUB.W	D3,(A2)+OMIPOS+2	JUMP',NC POSX$	CLR.W	D3POSX$:	SWAP.W	D0	SWAP.W	D3	LOAD.W	D3,D0	SUB.W	D3,(A2)+OMIPOS+0	JUMP',NC POSY$	CLR.W	D3POSY$:	SWAP.W	D0	SWAP.W	D3	LOAD.W	D5,(A2)+OMIIIY	SL.W	D5,#1	LOAD.L	A4,(A2)+OMIMAT	CLR.L	D4	LOAD.W	D6,(A2)+OMIIIY	LOAD.L	D1,(A2)+OMIDIM;	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER; Transfert l'image de fond dans le bitmap temporaire.	LOAD.W	D1,(A2)+OMIIMA	CALL	MOVECOLOR	; choix des couleurs pour l'image	LOAD.L	A3,(A1)+OBKPIF	; A3 <-- ^image fond	CLR.L	D3		; D3 <-- position dans l'image	LOAD.W	D5,(A2)+OMIIIY	; D5 <-- Iy image	LOAD.L	D1,(A2)+OMIDIM	; D1 <-- dimensions images	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,D0	SUB.W	D4,(A2)+OMIPOS+2	JUMP',NC PFDX$	CLR.W	D4PFDX$:	SWAP.W	D0	SWAP.W	D4	LOAD.W	D4,D0	SUB.W	D4,(A2)+OMIPOS+0	JUMP',NC PFDY$	CLR.W	D4PFDY$:	SWAP.W	D0	SWAP.W	D4	LOAD.W	D6,(A2)+OMIIIY	SL.W	D6,#1	LOAD.W	D2,#CLRDOT!2^BDSTCOUL	CALL	INVMODE	CALL	DRRASTER; Transfert l'image de chair dans le bitmap temporaire.	LOAD.L	A3,(A1)+OBKPID	; A3 <-- ^image chair;	CLR.L	D3		; D3 <-- position dans l'image;	LOAD.W	D5,(A2)+OMIIIY	; D5 <-- Iy image;	LOAD.L	D1,(A2)+OMIDIM	; D1 <-- dimensions images;	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D2,#SETDOT!2^BDSTCOUL	CALL	INVMODE	CALL	DRRASTER	LIB	?COLORPOP; Transfert le bitmap temporaire dans l'cran.	LOAD.L	A3,#(A6)+OBUDIS	CLR.L	D3	LOAD.W	D5,(A2)+OMIIIY	SL.W	D5,#1	LOAD.L	A4,#0	LOAD.W	D4,(A2)+OMIPOS+2	COMP.W	D4,D0	JUMP',LE PEDX$	LOAD.W	D4,D0PEDX$:	SWAP.W	D0	SWAP.W	D4	LOAD.W	D4,(A2)+OMIPOS+0	COMP.W	D4,D0	JUMP',LE PEDY$	LOAD.W	D4,D0PEDY$:	SWAP.W	D0	SWAP.W	D4	LOAD.L	D1,(SP)+0	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTER	LOAD.L	(A2)+OMIPOS,D0EXIT$:	ADD.L	SP,#4		; ajuste le stack	POPM.L	D0..D6,A1,A3,A4	RET;----------\\; MOVECOLOR >;----------/; Choix des couleurs selon une image.; in	D1.W	numro de l'image (0..n); out	-; mod	D7.WMOVECOLOR:	PUSHM.L	D3,A3	LIB	?COLORPUSH	TEST.B	(A6)+ONOCO	; dessin sans couleurs ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.L	A3,#R16"TABLE$	LOAD.W	D3,D1	SL.W	D3,#2		; D3 <-- *4 (car 2 x .W)	ADD.W	A3,D3	CLR.L	D3	LOAD.W	D3,(A3+)	LIB	?COLORSR	CLR.L	D3	LOAD.W	D3,(A3+)	LIB	?COLORCREXIT$:	POPM.L	D3,A3	RETTABLE$:	.W	COLORNOIR,COLORICONE	; CONTROL	.W	COLORNOIR,COLORTOTO	; BLUPF1	.W	COLORNOIR,COLORTOTO	; BLUPF2	.W	COLORNOIR,COLORTOTO	; BLUPQ1	.W	COLORNOIR,COLORTOTO	; BLUPQ2	.W	COLORNOIR,COLORTOTO	; BLUPP1	.W	COLORNOIR,COLORTOTO	; BLUPP2	.W	COLORNOIR,COLORTOTO	; BLUPP3	.W	COLORNOIR,COLORBULLE	; BULLE	.W	COLORNOIR,COLORBULLE	; BULLEL	.W	COLORNOIR,COLORBULLE	; BULLEH	.W	COLORNOIR,COLORBRUN	; SOURIS	.W	COLORNOIR,COLORORANGE	; MOUSE1	.W	COLORNOIR,COLORORANGE	; MOUSE2	.W	COLORNOIR,COLORORANGE	; MOUSE3	.W	COLORNOIR,COLORORANGE	; MOUSE4	.W	COLORNOIR,COLOREXPLI	; VISER	.W	COLORNOIR,COLORBLEU	; SM324V	.W	COLORNOIR,COLORBLEU	; SM324	.W	COLORNOIR,COLORVERT	; PUZZLE1	.W	COLORNOIR,COLORVERT	; PUZZLE2	.W	COLORNOIR,COLORVERT	; PUZZLE3	.W	COLORNOIR,COLORVERT	; PUZZLE4	.W	COLORNOIR,COLORJAUNE	; ICONE4	.W	COLORROUGE,COLORJAUNE	; FLDOWN	.W	COLORNOIR,COLOREXPLI	; OBJET2	.W	COLORNOIR,COLOREXPLI	; SCROLL	.W	COLORNOIR,COLOREXPLI	; SABLIER	.W	COLORNOIR,COLOREXPLI	; NOCAPS	.W	COLORNOIR,COLOREXPLI	; SHIFT	.W	COLORNOIR,COLOREXPLI	; CTRL	.W	COLORNOIR,COLOREXPLI	; CAPS	.W	COLORNOIR,COLOREXPLI	; SUPER	.W	COLORNOIR,COLOREXPLI	; CURSOR	.W	COLORNOIR,COLOREXPLI	; CURSOR2	.W	COLORNOIR,COLOREXPLI	; CURSEUR	.W	COLORNOIR,COLOREXPLI	; SOFTKEY	.W	COLORNOIR,COLORBLANC	; START1	.W	COLORNOIR,COLORBLANC	; START2	.W	COLORNOIR,COLORBLANC	; START3	.W	COLORNOIR,COLORBLANC	; START4	.W	COLORNOIR,COLORBLANC	; STARTVISU	.W	COLORNOIR,COLORBLANC	; DESSIN0	.W	COLORNOIR,COLORBLANC	; DESSIN1	.W	COLORNOIR,COLOREXPLI	; FLOPPY	.W	COLORNOIR,COLOREXPLI	; DESDETR	.W	COLORNOIR,COLORROUGE	; PAQUETS	.W	COLORNOIR,COLORROUGE	; VOUS0	.W	COLORNOIR,COLORVERT	; VOUS1	.W	COLORNOIR,COLORBLANC	; MMENUH1	.W	COLORNOIR,COLORBLANC	; MMENUH2;----------\\; MOVECLEAR >;==========/; Enlve provisoirement l'image.; in	A2.L	canal; out	-; mod	D7.WMOVECLEAR:	PUSHM.L	D1..D6,A3,A4	COMP.L	A2,#0	JUMP',EQ EXIT$; Transfert le bitmap orginal dans l'cran.	LOAD.L	A3,(A2)+OMIMAT	CLR.L	D3	LOAD.W	D5,(A2)+OMIIIY	LOAD.L	A4,#0	LOAD.L	D4,(A2)+OMIPOS	LOAD.L	D1,(A2)+OMIDIM	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DRRASTEREXIT$:	POPM.L	D1..D6,A3,A4	RET;----------\\; MOVECLOSE >;==========/; Termine un dplacement.; in	A2.L	canal; out	-; mod	D7.WMOVECLOSE:	PUSHM.L	D1,A4	COMP.L	A2,#0	JUMP',EQ EXIT$	LOAD.L	A4,(A2)+OMIMAT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	LOAD.L	A4,A2;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoireEXIT$:	POPM.L	D1,A4	RET	.END