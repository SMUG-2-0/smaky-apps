	.TITLE	FICHEPSION.ASC;	----------------------------------------;		(C) 1989 - Pierre Arnaud;	----------------------------------------	.PROC	M68000	.REF	SMILE	.LOC	0	.START	DEBUTREVMAJ	= 0REVMIN	= 1VERSINT	= "b"	.REV	REVMAJ,REVMIN	.IDENT	"Transfert .FICHE -> .PSION - (C) 1989 - P.Arnaud"	.CODE	800,20,2'001111,20,2000,20,2000,2,"N","E","F",11LBUFILE	= 64LBUFOS	= 1000LBUTRI	= 64; Variables gnrales :; ---------------------ONOMFOS:	.BLK.8	LBUFILE		; buffer pour le nom de fichierONOMTRI:	.BLK.8	LBUTRI		; nom de slection pour TRIOBUFOS:		.BLK.8	LBUFOS		; buffer pour les op. FOSOBUWR:		.BLK.8	LBUFOS		; buffer pour le WRITEODBFLAG:	.BLK.32	1		; mmoire pour fanionsONBTRI:		.BLK.16	1		; nombre de trisOCANAL:		.BLK.16	1		; canal du fichierOCHFICHE:	.BLK.32	1		; canal FICHEOCHDBOX:	.BLK.32	1		; canal DBOXOCHLIST:	.BLK.32	1		; canal LISTOCHSCROLL:	.BLK.32	1		; canal SCROLLOVARLIST:	.BLK.8	LSLVAR		; variable d'une listeLGVAR:; Programme principal :; ---------------------	.LOC	0NAMFICHE:	.ASCIZ	"FICHE"NAMDBOX:	.ASCIZ	"DBOX"NAMLIST:	.ASCIZ	"LIST"NAMSCROLL:	.ASCIZ	"SCROLL"EXTPSION:	.ASCIZ	".PSION"	.EVENDEBUT:	LIB	?OPELIB	CALL	PROGRAMME	LIB	?CLOLIB	FOS	?STOP	EXITPROGRAMME:	MOVE.32	#LGVAR,D4	MOVE.16	#MTYPCP,D1	GESMEM	?GETMEM	JUMP,NE	NOMEM$	MOVE.32	A4,A6	GESMEM	?CLEAR	MOVE.32	#R16^NAMFICHE,A3	MOVE.32	#FICHE_FIRST,D3	LIB_	OPEN	JUMP,NE	NOMOD$	MOVE.32	D1,{A6}+OCHFICHE	MOVE.32	#R16^NAMDBOX,A3	MOVE.32	#DBOX_FIRST,D3	LIB_	OPEN	JUMP,NE	NOMOD$	MOVE.32	D1,{A6}+OCHDBOX	MOVE.32	#R16^NAMLIST,A3	MOVE.32	#LIST_FIRST,D3	LIB_	OPEN	JUMP,NE	NOMOD$	MOVE.32	D1,{A6}+OCHLIST	MOVE.32	#R16^NAMSCROLL,A3	MOVE.32	#SCROLL_FIRST,D3	LIB_	OPEN	JUMP,NE	NOMOD$	MOVE.32	D1,{A6}+OCHSCROLL	CALL	FONDGRIS		; affiche une trame grise	CALL	WORK			; fait le boulot principalEND$:	MOVE.32	{A6}+OCHSCROLL,D1	LIB_	CLOSE	MOVE.32	{A6}+OCHLIST,D1	LIB_	CLOSE	MOVE.32	{A6}+OCHDBOX,D1	LIB_	CLOSE	MOVE.32	{A6}+OCHFICHE,D1	LIB_	CLOSE	MOVE.16	#MTYPCP,D1	MOVE.32	A6,A4	GESMEM	?GIVMEM	RETNOMEM$:	LIB	?AFTIM	.ASCIZE	"<EOP><CR><CR>Erreur fatale : mmoire pleine.<CR><NOCURS>"	LIB	?GETCAR	RETNOMOD$:	PUSH.16	D7	LIB	?AFTIM	.ASCIZE	"<EOP><CR><CR>Erreur fatale : librairie absente.<CR><NOCURS><CR><AFINV>"	POP.16	D7	LIB	?AFERROR ?AFCR	LIB	?GETCAR	RET;-------------\\;   FondGris   >;=============/; Affiche le fond gris et la barre en vido inverse en haut de l'cran en fonction de; la dimension de la fentre de travail. Affiche aussi le nom du programme + rvision; in	-; out	-; mod	-FondGris:	PUSHM.32 D3|D4|A4	LIB	?AFTIM	.ASCIZE	"<AFDIR><AFFULL><LOADGC>N<"E".OR.128><11><USEGC>N<"E".OR.128><11>"	JUMP,NE	ERR$	LIB	?GETDIM	COMP.16	#600,D4			; recherche la dimension de la fentre	JUMP,GT	OK$	LIB	?AFTIM	.ASCIZE	"<LOADGC>N<"E".OR.128><7><USEGC>N<"E".OR.128><7>"	JUMP,NE	ERR$OK$:	MOVE.32	#H'22882288,D3	MOVE.32	#H'22882288,D4	LIB	?DRMDEF			; matrice grise comme START	LIB	?GETDIM	CLR.32	D3	LIB	?DRMATRIX		; remplit toute la surface	MOVE.32	#H'FFFFFFFF,D3	MOVE.32	#H'FFFFFFFF,D4	LIB	?DRMDEF			; matrice pleine (pour l'en-tte)	LIB	?GETDIM	LIB	?GETPDIS	MOVE.16	{A4}+ODFC1Y,D3		; cherche hauteur de la barre	ADD.16	{A4}+ODFC2Y,D3	SWAP.32	D3	AND.32	#H'FFFF0000,D3	AND.32	#H'0000FFFF,D4		; combine hauteur / largeur	OR.32	D3,D4	CLR.32	D3	LIB	?DRMATRIX		; dessine la barre en vido-inverse	LIB	?SETCURS	LIB	?AFTIM			; affiche le nom du programme	.ASCII	"<AFINV> FICHEPSION "	.IF	REVMAJ<10		.8	REVMAJ+"0"	.ELSE		.8	REVMAJ/10+"0"		.8	REVMAJ-(REVMAJ/10)*10+"0"	.ENDIF	.8	"."	.IF	REVMIN<10		.8	REVMIN+"0"	.ELSE		.8	REVMIN/10+"0"		.8	REVMIN-(REVMIN/10)*10+"0"	.ENDIF	.8	VERSINT	.ASCIZE	"<AFDIR><NOEFLI><CR><NOCURS>"ERR$:	POPM.32	D3|D4|A4	TEST.16	D7			; test pour EQ/NE	RET;-------\\;  WORK  >;=======/; Effectue tout le travail productif !; in	-; out	-; mod	...WORK:	CALL	DBPREND	JUMP,NE	ERR$	COMP.16	#F1,D3	JUMP,NE	OK$			; termin si pas "prend"	CLR.16	D3	FICHE_	OUVRE			; ouvre le fichier...	JUMP,NE	ERR$	MOVE.16	D6,{A6}+OCANAL		; sauve le canal du fichier	FICHE_	NBTRI			; nombre de tris	MOVE.16	D1,{A6}+ONBTRI	CALL	DBCHOIX			; choix dans DBOX	JUMP,NE	CLOSE$	COMP.16	#F1,D3	JUMP,NE	FERME$			; pas de sauvegarde -> fin	CALL	SAVEPSION	JUMP,NE	CLOSE$FERME$:	FICHE_	FERME	JUMP	WORKCLOSE$:	PUSH.16	D7	FICHE_	FERME			; ferme le fichier...	POP.16	D7	JUMP,NE	ERR$OK$:	RETERR$:	PUSH.16	D7	MOVE.16	#BIPFAT,D3	LIB	?BEEP	POP.16	D7	MOVE.16	#2**BDBSAV,D2	DBOX_	MERROR	RET;----------\\;  DBPREND  >;==========/; Demande le nom du fichier .FICHE  prendre; in	-; out	D3.16	dernire touche F1/F4/F0;	A3.32	^nom de fichier;	D7.16	erreur (DBOX); mod	D3.32, D7.16DBPREND:	PUSHM.32 D1|D2|D4|D5|A4|A5	LIB	?PUSHMENU		; sauve le menu des touches	MOVE.32	#{A6}+ONOMFOS,A5	; nom de fichier	CLR.8	{A5}	MOVE.16	#2,D3	LIB	?MOUSE	MOVE.16	#DBOX_PREND,D1	MOVE.16	#2**BDBEXTEND+2**BDBSAV,D2	MOVE.32	#2**BDBIOEXT1+32,D3	MOVE.32	#0,D4	MOVE.32	#R16^DESCRIPTION,A3	MOVE.32	#R16^EXTENSION$,A4	; extension '.FICHE'	DBOX_	EXTEND	PUSH.16	D7	LIB	?POPMENU	MOVE.32	A5,A3	POP.16	D7	POPM.32	D1|D2|D4|D5|A4|A5	TEST.16	D7			; y a-t-il eu une erreur DBOX ?	RETEXTENSION$:	.ASCIZ	".FICHE"		.EVENDESCRIPTION:	.ASCIZ	"FICHEPSION"		.ASCIZ	"Mfichier"		.ASCIZ	"Fslection"		.8	0		.EVEN;----------\\;  DBCHOIX  >;==========/; Affiche une DBOX permettant de choisir le tri et de sauver.; in	-; out	D3.16	dernire touche F0/F1;	D7.16	ok/erreur; mod	D3.16, D7.16DBCHOIX:	PUSHM.32 D0..D2|D4..D6|A0..A5	LIB	?PUSHMENU	PUSH.32	D5	MOVE.32	#R16^TABLEDB$,A2	MOVE.16	#2**BDBSAV,D2	CLR.32	D4		DBOX_	OPEN	JUMP,NE	ERR$	CLR.16	D1			; numro de la rubrique	MOVE.16	#1,D2			; commence au second objet	MOVE.16	#6,D0			; 14 rubriques au total !	MOVE.16	{A6}+OCANAL,D6		; canal FICHEWRITE$:	DBOX_	GETCO			; coordonnes de l'objet D2	MOVE.32	D4,D3			; fin = position curseur	LIB	?SETCURS	LIB	?AFTIM	.FILL.8	14,BS	.8	0			; recule de 10 caractres	.EVEN	MOVE.32	#{A6}+OBUFOS,A3		; buffer	PUSHM.32 D3	MOVE.16	#LBUFOS,D3		; taille	FICHE_	LITDEF			; lit une rubrique	POPM.32 D3	JUMP,NE	ENDRU$SK1$:	COMP.8	#SPACE,{A3+}	JUMP,NE	SK1$	MOVE.32	A3,A4DEL1$:	COMP.8	#SPACE,{A4+}	JUMP,NE	DEL1$	CLR.8	{A4}-1	LIB	?AFTEXT			; affiche le nom de rubrique	LIB	?SETCURS		; repositionne le curseur	LIB	?AFTIM			; avance dans la ligne	.FILL.8	6,RIGHT	.8	0	.EVEN	INC.16	D1			; rubrique suivante	MOVE.32	#{A6}+OBUFOS,A3		; buffer	MOVE.16	#LBUFOS,D3		; taille	FICHE_	LITDEF			; lit une rubrique	JUMP,NE	ENDRU$SK2$:	COMP.8	#SPACE,{A3+}	JUMP,NE	SK2$	MOVE.32	A3,A4DEL2$:	COMP.8	#SPACE,{A4+}	JUMP,NE	DEL2$	CLR.8	{A4}-1	LIB	?AFTEXT	ADD.16	#2,D2			; passe  la ligne suivante	INC.16	D1			; rubrique suivante	DECJ.16,NMO D0,WRITE$		; passe tous en revueENDRU$:	MOVE.32	#H'00300010,D3	MOVE.32	#H'00800080,D4	CALL	CHOIXLISTE	CLR.32	D4EDIT$:	DBOX_	EDIT	MOVE.16	#2**BDBCCMM+2**BDBCCFF,D1	MOVE.32	#R16^TABLE$,A1	DBOX_	CALLC	TEST.16	D3	JUMP,EQ	EDIT$	COMP.16	#F1,D3	JUMP,EQ	OK$	COMP.16	#F0,D3	JUMP,EQ	OK$	MOVE.8	#BIPLIT,D3	LIB	?BEEP	JUMP	EDIT$OK$:	DBOX_	CLOSEERR$:	POP.32	D5	PUSH.16	D7	LIB	?POPMENU	MOVE.32	D4,{A6}+ODBFLAG	POP.16	D7	POPM.32	D0..D2|D4..D6|A0..A5	RETTABLEDB$:	.16	DB$-TABLEDB$	.16	SK$-TABLEDB$	.16	0,0DB$:	.ASCIZ	"<ODBTEXT>Choisissez la slection pour la sauvegarde."	.8	ODBCR,ODBCR,ODBTABX,20,ODBSQUARE,0	.ASCIZ	"               "	.8	ODBTABX,40,ODBSQUARE,1	.ASCIZ	"               "	.8	ODBCR,ODBTABX,20,ODBSQUARE,2	.ASCIZ	"               "	.8	ODBTABX,40,ODBSQUARE,3	.ASCIZ	"               "	.8	ODBCR,ODBTABX,20,ODBSQUARE,4	.ASCIZ	"               "	.8	ODBTABX,40,ODBSQUARE,5	.ASCIZ	"               "	.8	ODBCR,ODBTABX,20,ODBSQUARE,6	.ASCIZ	"               "	.8	ODBTABX,40,ODBSQUARE,7	.ASCIZ	"               "	.8	ODBCR,ODBTABX,20,ODBSQUARE,8	.ASCIZ	"               "	.8	ODBTABX,40,ODBSQUARE,9	.ASCIZ	"               "	.8	ODBCR,ODBTABX,20,ODBSQUARE,10	.ASCIZ	"               "	.8	ODBTABX,40,ODBSQUARE,11	.ASCIZ	"               "	.8	ODBCR,ODBTABX,20,ODBSQUARE,12	.ASCIZ	"               "	.8	ODBTABX,40,ODBSQUARE,13	.ASCIZ	"               "	.8	ODBCR,ODBCR,ODBCR	.ASCIZ	"<ODBBOX><0><CR><TDBMEV> SAUVE .PSION "	.ASCIZ	"<ODBTEXT>     "	.ASCIZ	"<ODBBOX><0><F0><TDBNORM>    ANNULE    "	.8	0	.EVENSK$:	.8	0,0,0	.ASCIZ	"Sauve en .PSION"	.8	0,0,0,0,0,0,0	.ASCIZ	"Annule"	.EVENTABLE$:	.16	F0,END,F13,F14,F15,UNDO,CLEAR,0,	F0$-TABLE$	.16	F1,F2,F3,CR,ENTER,DEFINE,0,		F1$-TABLE$	.16	KEYMGP,KEYMMP,KEYMDP,0,			PRESS$-TABLE$	.16	KEYMGR,KEYMMR,KEYMDR,0,			LACHE$-TABLE$	.16	0,0F0$:	MOVE.16	#F0,D3	RETF1$:	MOVE.16	#F1,D3	RETPRESS$:	PUSHM.32 D0..D2|D4|D5|A0..A5	LIB	?GETPDIS	MOVE.32	A4,A0	MOVE.32	#{A6}+OVARLIST,A5	LIB	?GETWDO			; position de la fentre	LIB	?IFMOUSE		; position dans la fentre	JUMP,NE	FINPR$	SUB.32	D3,D4	SUB.16	#H'0038,D4	SCROLL_	LMOVE			; action sur la liste	JUMP,NE	FINPR$	CLR.16	D3FINPR$:	POPM.32	D0..D2|D4|D5|A0..A5	RETLACHE$:	CLR.16	D3	RET;-------------\\;  CHOIXLISTE  >;=============/; Affiche une liste avec les choix possibles de tri.; in	D3.32	[y;x] de dbut de liste;	D4.32	[dy;dx] de la liste;	D6.16	canal fiche; out	D7.16; mod	D7.16CHOIXLISTE:	PUSHM.32 D0..D6|A0..A5	LIB	?GETPDIS	MOVE.32	A4,A0			; ^descripteur cran	MOVE.32	#{A6}+OVARLIST,A5	; ^variables	CLR.8	{A5}+OSLVID	CLR.8	{A5}+OSLHOR	MOVE.32	D3,{A5}+OSLPOS	MOVE.32	D4,{A5}+OSLDIM	SCROLL_	LDIM			; arrondi des dimensions	JUMP,NE	ERR$	SCROLL_	LDRAW			; dessine rectangle + cage	JUMP,NE	ERR$	MOVE.32	#R16^GETEXT,A4	MOVE.32	A4,{A5}+OSLADL		; routine pour liste de tris	MOVE.32	#R16^AFTEXT,A4	MOVE.32	A4,{A5}+OSLADA		; routine pour affichage des tris	MOVE.16	{A6}+ONBTRI,{A5}+OSLCYN	; nombre de cases verticales	CLR.16	{A5}+OSLCXN	CLR.16	{A5}+OSLCYS		; case slectionne	SCROLL_	LUPDATEERR$:	POPM.32	D0..D6|A0..A5	TEST.16	D7			; erreur ?	RET; Cherche le numro de tri; ------------------------GETEXT:		PUSHM.32 D1|D6	MOVE.16	{A6}+OCANAL,D6	MOVE.16	D3,D1	MOVE.16	LBUTRI,D3	MOVE.32	#{A6}+ONOMTRI,A3	FICHE_	LITTRI	PUSH.32	A3DO$:	COMP.8	#SPACE,{A3+}	JUMP,NE	DO$	CLR.8	{A3}	POP.32	A3	CLR.16	D3	POPM.32 D1|D6	RETAFTEXT:	MOVE.16	#ERLSYN,D7		; problme !	RET;------------\\;  SAVEPSION  >;============/; Sauve le fichier en .PSION !; in	D6.16	canal FICHE; out	D7.16	ok/erreur; mod	D7.16SAVEPSION:	PUSHM.32 D0..D6|A0..A5	MOVE.16	#DBOX_OPWAIT,D1	MOVE.16	#2**BDBSAV+2**BDBEXTEND,D2	DBOX_	EXTEND			; DBOX pour "Attendez un instant"	MOVE.16	D6,D2	MOVE.32	#{A6}+ONOMFOS,A3	MOVE.32	#R16^EXTPSION,A4	; cre fichier xxx.PSION (criture)	MOVE.16	#1,D3	LIB	?ADDEXT	MOVE.32	#2**BOPWR+2**BOPEXCL+2**BOPCREATE,D3	MOVE.32	#FOS?ARGSOPEN,D0	CALL	ERCALL	JUMP,NE	END$	MOVE.32	#{A6}+OBUFOS,A4		; ^buffer FOS	MOVE.16	#LBUFOS,D4		; longueur	MOVE.16	{A6}+OVARLIST+OSLCYS,D3	; cherche numro du TRI	RR.32	#8,D3			; numro du critre de TRI	AND.32	#H'FF000000,D3DO$:	EX.32	D6,D2			; numro du canal FICHE dans D6.16	FICHE_	LIT			; lit la fiche	EX.32	D2,D6			; canal FOS dans D6.16	TEST.16	D7	JUMP,NE	CLOSE$			; fin atteinte	CALL	WRBUF			; sauve le contenu du buffer	JUMP,NE	CLOSE$			; erreur -> termin	INC.16	D3	JUMP	DO$CLOSE$:	FOS	?TRUNC	FOS	?CLOSE			; ferme fichier FOSEND$:	PUSH.16	D7	MOVE.16	#DBOX_CLWAIT,D1	MOVE.16	#2**BDBEXTEND,D2	; ferme DBOX "Attendez un instant"	DBOX_	EXTEND	POP.16	D7	POPM.32	D0..D6|A0..A5	RET;---------\\;  ERCALL  >;=========/; Gestion des erreurs avec interaction par DBOX; in	D0.32	commande FOS?...;	+ selon appel FOS; out	+ selon appel FOS;	D7.16	erreur (ERKSTO si annule); mod	D7.16ERCALL:	PUSHM.32 D1|D2	MOVE.16	#DBOX_ERCALL,D1		; gestion d'erreurs	MOVE.16	#2**BDBEXTEND,D2	; mode 'EXTENSION'	DBOX_	EXTEND			; excute appel FOS	POPM.32	D1|D2	TEST.16	D7			; test pour EQ/NE	RET;--------\\;  WRBUF  >;========/; Ecrit le contenu du buffer dans le fichier FOS; in	A4.32	^buffer;	D6.16	canal FOS; out	D7.16	ok/erreur; mod	D7.16WRBUF:	PUSHM.32 D0..D4|A2..A4	MOVE.32	A4,A3	MOVE.32	#{A6}+OBUWR,A4		; ^buffer write	CLR.32	D4			; taille du buffer  disposition	CLR.16	D2			; passe en revue les rubriques	MOVE.32	{A6}+ODBFLAG,D0		; flags (bits de 0  13)TEST$:	TEST.32	D0:D2			; faut-il prendre la rubrique ?	JUMP,BC	NEXT$			; non -> passe  la suite	CALL	SIRUBRIQUE		; trouve la rubrique dans le tas ?	JUMP,NE	NXTWR$			; non -> suite (+ TAB); La rubrique dsire est ^en A2.32NSP$:	MOVE.8	{A2+},D3	COMP.8	#SPACE,D3	JUMP,NE	NSP$			; saute le premier espaceDOCOP$:	MOVE.8	{A2+},D3		; cherche premier caractre	JUMP,EQ	NXTWR$			; suite (+ TAB)	COMP.8	#CR,D3	JUMP,EQ	NXTWR$			; RETURN = fin de donne;	COMP.8	#TAB,D3;	JUMP,EQ	NXTWR$			; TAB    = fin de donne;	COMP.8	#SPACE,D3;	JUMP,EQ	NXTWR$			; ESPACE = fin de donne	MOVE.8	D3,{A4}+A16^{D4}	INC.16	D4	JUMP	DOCOP$			; copie la suite dans bufferNXTWR$:	MOVE.8	#TAB,{A4}+A16^{D4}	; place un TAB aprs	INC.16	D4NEXT$:	INC.16	D2			; rubrique suivante	COMP.8	#14,D2	JUMP,LT	TEST$			; copie rubriques suivantes	MOVE.8	#CR,{A4}+A16^{D4}-1	FOS	?WRBYTE			; crit le buffer	POPM.32 D0..D4|A2..A4	RET;-------------\\;  SIRUBRIQUE  >;=============/; Cherche le ^dans le buffer correspondant  la rubrique numro D2.16; in	D2.16	numro de rubrique  chercher;	A3.32	^fiche  analyser; out	D7.16	ok/erreur;	A2.32	^dans la fiche sur initiales de la rubrique; mod	D7.16, A2.32SIRUBRIQUE:	PUSHM.32 D1|D3|D6|A3	MOVE.16	{A6}+OCANAL,D6		; canal FICHELOOP$:	FICHE_	CHEDEF			; regarde si initiales connues	JUMP,NE	ERR$			; non -> erreur	COMP.16	D1,D2			; rang de la rubrique trouv ?	JUMP,EQ	END$			; oui -> terminSKIP$:	MOVE.8	{A3+},D3	JUMP,EQ	NIL$			; fin atteinte	COMP.8	#CR,D3	JUMP,NE	SKIP$			; saute la ligne courante	JUMP	LOOP$			; analyse ligne suivanteNIL$:	MOVE.16	#ERFRNF,D7	JUMP	ERR$			; rubrique pas trouve !END$:	CLR.16	D7	MOVE.32	A3,A2			; rend A2.32 ^ligne correcteERR$:	POPM.32	D1|D3|D6|A3	TEST.16	D7			; test pour EQ/NE	RET