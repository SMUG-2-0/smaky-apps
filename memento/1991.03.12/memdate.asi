	.SBTTL	MEMDATE;--------\\; DATENOW >;========/; Donne la date actuelle.; in	-; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.L, D7.WDATENOW:	PUSH.L	D3	LIB	?RDCLOCK	; D4 <-- |-|J|M|A|	JUMP',NE 90$	RR.W	D4,#8		; D4 <-- |-|J|A|M|	SWAP.W	D4		; D4 <-- |A|M|-|J|	RR.W	D4,#8		; D4 <-- |A|M|J|-|	CLR.B	D4		; D4 <-- |A|M|J|H|90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;------------\\; DATERNDWEEK >;============/; Arrondi une date  la semaine prcdente,; c'est--dire au lundi.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.L, D7.WDATERNDWEEK:	PUSH.L	D3	CALL	CALCNJ		; D4 <-- nb de jours	LOAD.L	D3,D4	CALL	CALCJS		; D4 <-- jour semaine (1..7)	DEC.L	D4		; D4 <-- nb de jours  reculer (0..6)	SUB.L	D3,D4	LOAD.L	D4,D3	CALL	CALCJN	POP.L	D3	RET;------------\\; DATERNDYEAR >;============/; Arrondi une date  la demi-anne prcdente,; c'est--dire au 1.1.xx ou au 1.7.xx.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.L, D7.WDATERNDYEAR:	PUSH.L	D3	SWAP.W	D4	LOAD.B	D3,#H'01	COMP.B	D4,#H'07	JUMP',LO 50$	LOAD.B	D3,#H'0750$:	LOAD.B	D4,D3	SWAP.W	D4	AND.W	D4,#H'00FF	OR.W	D4,#H'0100	; D4 <-- jour = 1	POP.L	D3	RET;-------------\\; DATEQNEXTDAY >;=============/; Cherche le jour suivant (sans changer de mois).; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.L, D7.WDATEQNEXTDAY:	RR.W	D4,#8	CALL	CONVAB		; D4 <-- jour en binaire	INC.B	D4	CALL	CONVBA	RR.W	D4,#8	RET;------------\\; DATENEXTDAY >;============/; Cherche le jour suivant.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.L, D7.WDATENEXTDAY:	CALL	CALCNJ		; D4 <-- nombre de jours	INC.L	D4	CALL	CALCJN	RET;------------\\; DATEPREVDAY >;============/; Cherche le jour prcdent.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.L, D7.WDATEPREVDAY:	CALL	CALCNJ		; D4 <-- nombre de jours	DEC.L	D4	CALL	CALCJN	RET;--------------\\; DATENEXTMONTH >;==============/; Cherche le mois suivant.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.L, D7.WDATENEXTMONTH:	SWAP.W	D4	CALL	CONVAB		; D4 <-- mois en binaire	INC.B	D4		; D4 <-- mois suivant	COMP.B	D4,#12	JUMP',LS 50$	LOAD.B	D4,#1		; D4 <-- revient en janvier	RR.W	D4,#8	CALL	CONVAB		; D4 <-- anne en binaire	INC.B	D4		; D4 <-- anne suivante	CALL	CONVBA	RR.W	D4,#850$:	CALL	CONVBA	SWAP.W	D4	RET;--------------\\; DATEPREVMONTH >;==============/; Cherche le mois prcdent.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.L, D7.WDATEPREVMONTH:	SWAP.W	D4	CALL	CONVAB		; D4 <-- mois en binaire	DEC.B	D4		; D4 <-- mois prcdent	JUMP',NE 50$	LOAD.B	D4,#12		; D4 <-- revient en dcembre	RR.W	D4,#8	CALL	CONVAB		; D4 <-- anne en binaire	DEC.B	D4		; D4 <-- anne prcdente	CALL	CONVBA	RR.W	D4,#850$:	CALL	CONVBA	SWAP.W	D4	RET;--------------\\; DATEIFWEMONTH >;==============/; Vrifie si tous les jours d'une semaines sont dans le mme mois.; in	D4.L	anne-mois-jour-heure en BCD; out	D7.W	EQ => mme mois;		NE =>  cheval sur deux mois; mod	D7.WDATEIFWEMONTH:	PUSHM.L	D3,D4	LOAD.L	D3,D4		; D3 <-- date du lundi	CALL	CALCNJ		; D4 <-- nombre de jours	ADD.L	D4,#7-1	CALL	CALCJN		; D4 <-- date du dimanche	CLR.W	D7		; D7 <-- mme mois	AND.L	D3,#H'00FF0000	AND.L	D4,#H'00FF0000	COMP.L	D3,D4	JUMP',EQ 90$	INC.W	D7		; D7 <--  chaval90$:	POPM.L	D3,D4	RET;----------\\; DATEMTIME >;==========/; Transforme une date BCD --> nom d'heure en ASCII, sans les minutes.; in	D4.L	anne-mois-jour-heure en BCD;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LDATEMTIME:	PUSHM.L	D2..D4,A4	LOAD.L	A4,A3	AND.W	D4,#H'00FF	; D4 <-- temps (unit = 10 minutes)	MUL.WU	D4,#10		; D4 <-- temps (unit = 1 minute)	DIV.WU	D4,#60	PUSH.L	D4	AND.L	D4,#H'FFFF	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDCM	LIB	?PUTDEC		; buffer <-- heure	POP.L	D4	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'h	LOAD.B	(A4+),#'e	LOAD.B	(A4+),#'u	LOAD.B	(A4+),#'r	LOAD.B	(A4+),#'e	COMP.W	D4,#1	JUMP',LS 40$	LOAD.B	(A4+),#'s40$:	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'e	LOAD.B	(A4+),#'t	CLR.B	(A4)	LOAD.L	A3,A4	POPM.L	D2..D4,A4	RET;----------\\; DATEQTIME >;==========/; Transforme une date BCD --> nom d'heure en ASCII, " 9 1/2".; in	D4.L	anne-mois-jour-heure en BCD;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LDATEQTIME:	PUSHM.L	D2..D4,A4	LOAD.L	A4,A3	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCT0F	LOAD.B	(A4+),#GCT0S	LOAD.B	(A4+),#GCT0T	AND.W	D4,#H'00FF	; D4 <-- temps (unit = 10 minutes)	MUL.WU	D4,#10		; D4 <-- temps (unit = 1 minute)	DIV.WU	D4,#60	SWAP.W	D4	TEST.W	D4	JUMP',NE 80$	CLR.W	D4	SWAP.W	D4	LOAD.W	D3,#2	CLR.W	D2	LIB	?PUTDEC		; buffer <-- heure	LOAD.B	(A4+),#ICOH	; buffer <-- "h" spcial80$:	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCT1F	LOAD.B	(A4+),#GCT1S	LOAD.B	(A4+),#GCT1T	CLR.B	(A4)	LOAD.L	A3,A4	POPM.L	D2..D4,A4	RET;----------\\; DATEHTIME >;==========/; Transforme une date BCD --> nom d'heure en ASCII, " 9h15".; in	D4.L	minutes/heures;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LDATEHTIME:	PUSHM.L	D2..D4,A4	LOAD.L	A4,A3	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCT0F	LOAD.B	(A4+),#GCT0S	LOAD.B	(A4+),#GCT0T	PUSH.L	D4	AND.L	D4,#H'FFFF	LOAD.W	D3,#2	CLR.W	D2	LIB	?PUTDEC		; buffer <-- heure	POP.L	D4	LOAD.B	(A4+),#ICOH	; buffer <-- "h" spcial	CLR.W	D4	SWAP.W	D4	TEST.W	D4	JUMP',EQ 80$	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDALL	LIB	?PUTDEC		; buffer <-- minutes80$:	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCT1F	LOAD.B	(A4+),#GCT1S	LOAD.B	(A4+),#GCT1T	CLR.B	(A4)	LOAD.L	A3,A4	POPM.L	D2..D4,A4	RET;---------\\; DATEJDLS >;=========/; Transforme une date BCD --> nom de jour de la semaine en ASCII.; in	D4.L	anne-mois-jour-heure en BCD;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LDATEJDLS:	PUSHM.L	D4,A4	LOAD.L	A4,#R16"NIL$	CALL	CALCNJ		; D4 <-- nb de jours	JUMP',NE 20$	CALL	CALCJS		; D4 <-- jour semaine (1..7)	LOAD.L	A4,#R16"TABLE$10$:	DEC.B	D4	JUMP',EQ 20$12$:	TEST.B	(A4+)	JUMP,NE 12$	JUMP	10$20$:	LOAD.B	(A3+),(A4+)	JUMP,NE 20$	DEC.L	A3	POPM.L	D4,A4	RETNIL$:	.B	0TABLE$:	.ASCIZ	"Lundi"	.ASCIZ	"Mardi"	.ASCIZ	"Mercredi"	.ASCIZ	"Jeudi"	.ASCIZ	"Vendredi"	.ASCIZ	"Samedi"	.ASCIZ	"Dimanche"	.EVEN;--------\\; DATEDAY >;========/; Transforme une date BCD --> nom de jour en ASCII.; in	D4.L	anne-mois-jour-heure en BCD;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LDATEDAY:	PUSH.L	D3	LOAD.W	D3,D4	SR.W	D3,#8	SR.B	D3,#4	JUMP',EQ 20$	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- dizaines20$:	LOAD.W	D3,D4	SR.W	D3,#8	AND.B	D3,#H'0F	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- units	CLR.B	(A3)	POP.L	D3	RET;----------\\; DATEMONTH >;==========/; Transforme une date BCD --> nom de mois en ASCII.; in	D4.L	anne-mois-jour-heure en BCD;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LDATEMONTH:	PUSHM.L	D4,A4	LOAD.L	A4,#R16"TABLE$	SWAP.W	D4	CALL	CONVAB		; D4 <-- mois en binaire10$:	DEC.B	D4	JUMP',EQ 20$12$:	TEST.B	(A4+)	JUMP,NE 12$	JUMP	10$20$:	LOAD.B	(A3+),(A4+)	JUMP,NE 20$	DEC.L	A3	POPM.L	D4,A4	RETTABLE$:	.ASCIZ	"Janvier"	.ASCIZ	"Fvrier"	.ASCIZ	"Mars"	.ASCIZ	"Avril"	.ASCIZ	"Mai"	.ASCIZ	"Juin"	.ASCIZ	"Juillet"	.ASCIZ	"Aot"	.ASCIZ	"Septembre"	.ASCIZ	"Octobre"	.ASCIZ	"Novembre"	.ASCIZ	"Dcembre"	.EVEN;---------\\; DATEYEAR >;=========/; Transforme une date BCD --> nom d'anne en ASCII.; in	D4.L	anne-mois-jour-heure en BCD;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LDATEYEAR:	PUSH.L	D3	LOAD.B	(A3+),#'1	LOAD.B	(A3+),#'9	LOAD.L	D3,D4	RL.L	D3,#8	SR.B	D3,#4	COMP.B	D3,#10	JUMP',LO 20$	LOAD.B	(A3)-2,#'2	LOAD.B	(A3)-1,#'0	SUB.B	D3,#1020$:	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- dizaines	LOAD.L	D3,D4	RL.L	D3,#8	AND.B	D3,#H'0F	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- units	CLR.B	(A3)	POP.L	D3	RET;-----------\\; DATEBCDASC >;===========/; Transforme une date BCD --> ASCII.; in	D4.L	anne-mois-jour-heure en BCD;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LDATEBCDASC:	PUSHM.L	D2..D4	LOAD.W	D2,#2-1		; D2 <-- -1  cause NMO20$:	RR.L	D4,#8	LOAD.B	D3,D4	SR.B	D3,#4	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- dizaines	LOAD.B	D3,D4	AND.B	D3,#H'0F	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- units	LOAD.B	(A3+),#'/	; buffer <-- sparateur	DECJ.W,NMO D2,20$	SWAP.W	D4	CALL	DATEYEAR	; buffer <-- anne	POPM.L	D2..D4	RET;-----------\\; TIMEBCDASC >;===========/; Transforme une heure BCD --> ASCII.; in	D4.W	heure-minute en BCD;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LTIMEBCDASC:	PUSHM.L	D2..D4	LOAD.W	D2,#2-1		; D2 <-- -1  cause NMO	JUMP'	22$20$:	LOAD.B	(A3+),#':	; buffer <-- sparateur22$:	RR.W	D4,#8	LOAD.B	D3,D4	SR.B	D3,#4	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- dizaines	LOAD.B	D3,D4	AND.B	D3,#H'0F	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- units	DECJ.W,NMO D2,20$	POPM.L	D2..D4	RET;-------\\; BCDASC >;=======/; Transforme une valeur BCD --> ASCII.; in	D4.B	valeur en BCD;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LBCDASC:	PUSH.W	D3	LOAD.B	D3,D4	SR.B	D3,#4	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- dizaines	LOAD.B	D3,D4	AND.B	D3,#H'0F	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- units	POP.W	D3	RET;-------\\; ASCBCD >;=======/; Transforme une valeur ASCII --> BCD.; in	A3.L	^buffer; out	A3.L	^plus loin;	D4.W	valeur en BCD;	D7.W	erreur; mod	D4.L, D7.W, A3.LASCBCD:	PUSH.W	D3	LOAD.W	D7,#ERPREP	CLR.W	D4	LOAD.B	D3,(A3+)	; D3 <-- dizaines	SUB.B	D3,#'0	JUMP',LO EXIT$	COMP.B	D3,#9	JUMP',HI EXIT$	SL.B	D3,#4	LOAD.B	D4,D3	LOAD.B	D3,(A3+)	; D3 <-- units	SUB.B	D3,#'0	JUMP',LO EXIT$	COMP.B	D3,#9	JUMP',HI EXIT$	OR.B	D4,D3	CLR.W	D7		; D7 <-- okEXIT$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; CALCJN  >;========/; Calcul une date d'aprs un nombre de jours fixe depuis le 01/01/1900,; voir (*).; in	D4.L	nombre de jours; out	D4.L	anne-mois-jour-heure en BCD;	D7.W	erreur; mod	D4.L, D7.WCALCJN:	PUSHM.L	D0..D3,D5,A0	LOAD.L	D5,D4		; D5 <-- nb de jours	CLR.L	D4	DIV.WU	D5,#(365*4)+1	LOAD.L	D3,D5	SWAP.W	D3	CLR.W	D2		; D2 <-- anne zro (bissextile)	COMP.W	D3,#365+1	JUMP',LO 20$	SUB.W	D3,#365+1	INC.W	D2		; D2 <-- anne un	COMP.W	D3,#365	JUMP',LO 20$	SUB.W	D3,#365	INC.W	D2		; D2 <-- anne deux	COMP.W	D3,#365	JUMP',LO 20$	SUB.W	D3,#365	INC.W	D2		; D2 <-- anne trois20$:	SL.W	D5,#2	ADD.W	D5,D2	LOAD.B	D4,D5		; D4 <-- anne	CALL	CONVBA		; D4 <-- anne en BCD	RR.L	D4,#8	LOAD.L	A0,#R16"TAMOIS+1	LOAD.W	D0,#1		; D0 <-- compte les mois40$:	CLR.W	D1	LOAD.B	D1,(A0+)	; D1 <-- nb de jours du mois	COMP.B	D1,#28		; mois de fvrier ?	JUMP',NE 45$		; non => 45$	TEST.W	D2		; anne bissextile ?	JUMP',NE 45$		; non => 45$	INC.W	D1		; oui => un jour de plus45$:	COMP.W	D3,D1		; est-on dans ce mois ?	JUMP',LO 50$		; oui => 50$	SUB.W	D3,D1	INC.W	D0		; D0 <-- mois suivant	JUMP	40$50$:	SWAP.W	D4	LOAD.B	D4,D0		; D4 <-- mois	CALL	CONVBA		; D4 <-- mois en BCD	SWAP.W	D4	INC.W	D3	RR.W	D4,#8	LOAD.B	D4,D3		; D4 <-- jour	CALL	CONVBA		; D4 <-- jour en BCD	RR.W	D4,#8	CLR.B	D4		; D4 <-- heure	POPM.L	D0..D3,D5,A0	CLR.W	D7		; D7 <-- ok	RET;---------\\; CALCWEEK >;=========/; Calcul le numro de la semaine.; in	D4.L	anne-mois-jour-heure en BCD; out	D3.W	numro de la semaine (0..52); mod	D3.L, D7.WCALCWEEK:	PUSHM.L	D1,D2,D4	LOAD.L	D3,D4	AND.L	D4,#H'FF000000	OR.L	D4,#H'00010100	; D4 <-- 1.1.xx	CALL	CALCNJ		; D4 <-- nb de jours	LOAD.L	D1,D4	CALL	CALCJS		; D4 <-- jour semaine (1..7)	COMP.W	D4,#5		; vendredi..dimanche ?	JUMP',HS 20$		; oui => 20$	ADD.W	D4,#720$:	DEC.W	D4	CLR.L	D2	LOAD.W	D2,D4		; D2 <-- correction	LOAD.L	D4,D3	CALL	CALCNJ	SUB.L	D4,D1		; D4 <-- nb de jours depuis le 1.1.xx	ADD.L	D4,D2	DIV.WU	D4,#7	LOAD.W	D3,D490$:	POPM.L	D1,D2,D4	RET;--------\\; CALCJS  >;========/; Calcul le jour de la semaine en fonction d'une date; quelconque comprise dans le 20me sicle.; Pour cela, calcul le nombre de jour depuis une date de; rfrence fixe le 01/01/1900 (c'tait un dimanche),; voir (*).; in	D4.L	nombre de jours; out	D4.L	jour de la semaine 1..7 (lundi..dimanche);	D7.W	erreur; mod	D4.L, D7.WCALCJS:	DIV.WU	D4,#7		; divise par nb jour/semaine	SWAP.W	D4		; D4 <-- reste de la division	TEST.B	D4		; dimanche ?	JUMP',NE 80$		; non => 80$	LOAD.B	D4,#7		; oui => 780$:	AND.L	D4,#H'FF90$:	CLR.W	D7		; retour EQ	RET;--------\\; CALCNJ  >;========/; Calcul le nombre de jours depuis une date de rfrence; fixe le 01/01/1900, voir (*).; (*)	ATTENTION: dans tous les calculs de MEMENTO, on considre l'anne 1900;	comme bissextile, ce qui est faux (mais qui donc verra que les dates;	comprises entre le 1.1.1900 et le 29.2.1900 sont fausses) !; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	nombre de jours;	D7.W	erreur; mod	D4.L, D7.WCALCNJ:	PUSHM.L	D0..D3,D5,A0	LOAD.L	D5,D4		; D5 <-- anne-mois-jour-heure en BCD	LOAD.L	D0,#-1		; D0 <-- signal date fausse	CALL	CALCJX		; D3 <-- 28..31 (0 si erreur)	JUMP,NE 90$	LOAD.W	D7,#ERMMDAT	; D7 <-- date incorrecte	LOAD.W	D4,D5	RR.W	D4,#8		; D4 <-- jour (BCD)	CALL	CONVAB		; D4 <-- jour (binaire)	TEST.B	D4	JUMP,EQ	90$	COMP.B	D4,D3		; date correcte ?	JUMP,HI	90$		; non => 90$				; oui =>	DEC.B	D4		; D4 <-- 0..n	CLR.L	D0	LOAD.B	D0,D4		; D0 <-- nb jour depuis rf.	LOAD.L	D4,D5	RL.L	D4,#8		; D4 <-- anne (BCD)	CALL	CONVAB		; D4 <-- anne (binaire)	LOAD.B	D3,#00		; D3 <-- anne de rfrence	LOAD.B	D2,#-1		; D2 <-- compteur bissextile10$:	INC.B	D2	COMP.B	D3,D4	JUMP',HS 20$	ADD.L	D0,#365		; D0 <-- ajoute une anne	INC.B	D3		; D3 <-- anne suivante	AND.B	D2,#B'11	; anne bissextile ?	JUMP,NE	10$		; non => 10$	INC.L	D0		; oui => un jour de plus	JUMP	10$20$:	LOAD.L	D4,D5	SWAP.W	D4		; D4 <-- mois (BCD)	CALL	CONVAB		; D4 <-- mois (binaire)	LOAD.B	D3,#01		; D3 <-- mois de rfrence	LOAD.L	A0,#R16"TAMOIS+130$:	COMP.B	D3,D4	JUMP',HS 80$	INC.B	D3		; D3 <-- mois suivant	CLR.L	D1	LOAD.B	D1,(A0+)	; D1 <-- nb jours ce mois	COMP.B	D1,#28		; fvrier ?	JUMP',NE 35$		; non => 35$	AND.B	D2,#B'11	; anne bissextile ?	JUMP',NE 35$		; non => 35$	INC.B	D1		; D1 <-- 29 jours35$:	ADD.L	D0,D1		; D0 <-- ajoute un mois	JUMP	30$80$:	LOAD.L	D4,D0		; D4 <-- nb jours ou -1	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D3,D5,A0	TEST.W	D7		; retour EQ/NE	RET;--------\\; CALCJX  >;--------/; Calcul le nombre de jours dans un mois en tenant compte des; mois  28, 29, 30 et 31 jours.; in	D5.L	anne-mois-jour-heure en BCD; out	D3.B	jour max 28..31;	D7.W	erreur; mod	D3.B, D7.WCALCJX:	PUSHM.L	D4,A0	LOAD.W	D7,#ERMMDAT	; D7 <-- date incorrecte	LOAD.L	D4,D5	SWAP.W	D4		; D4 <-- mois (BCD)	CALL	CONVAB		; D4 <-- mois (binaire)	TEST.B	D4	JUMP',EQ 90$	COMP.B	D4,#12		; mois 1..12 ?	JUMP',HI 90$		; non => 90$	LOAD.L	A0,#R16"TAMOIS	; A0 <-- ^table	AND.W	D4,#H'00FF	LOAD.B	D3,(A0)+(D4.W)	; D3 <-- 28, 30 ou 31	COMP.B	D3,#28		; fvrier ?	JUMP',NE 80$		; non => 80$				; oui =>	LOAD.L	D4,D5	RL.L	D4,#8		; D4 <-- anne (BCD)	CALL	CONVAB		; D4 <-- anne (binaire)	AND.L	D4,#H'000000FF	DIV.WU	D4,#4	SWAP.W	D4		; D4 <-- reste	TEST.W	D4		; anne bissextile ?	JUMP',NE 80$		; non => 80$	INC.B	D3		; oui => 29 jours80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A0	TEST.W	D7		; retour EQ/NE	RETTAMOIS:	.B	0		;  0 = rien du tout	.B	31		;  1 = janvier	.B	28		;  2 = fvrier	.B	31		;  3 = mars	.B	30		;  4 = avril	.B	31		;  5 = mai	.B	30		;  6 = juin	.B	31		;  7 = juillet	.B	31		;  8 = aot	.B	30		;  9 = septembre	.B	31		; 10 = octobre	.B	30		; 11 = novembre	.B	31		; 12 = dcembre	.EVEN;--------\\; CALCNM  >;========/; Calcul le nombre de minutes depuis une heure de rfrence; fixe  00:00.; in	D4.W	heure-minute en BCD; out	D4.L	nombre de minutes;	D7.W	erreur; mod	D4.L, D7.WCALCNM:	PUSH.L	D3	CLR.L	D3	CALL	CONVAB		; D4 <-- nombre de minutes	LOAD.B	D3,D4	RR.W	D4,#8	CALL	CONVAB		; D4 <-- nombre d'heures	AND.W	D4,#H'00FF	MUL.WU	D4,#60	ADD.W	D3,D4	LOAD.L	D4,D3	POP.L	D3	CLR.W	D7		; retour EQ	RET;--------\\; CALCMN  >;========/; Calcul une heure d'aprs un nombre de minutes fixe depuis 00:00.; in	D4.W	nombre de minutes; out	D4.W	heure-minute en BCD;	D7.W	erreur; mod	D4.L, D7.WCALCMN:	PUSH.L	D3	AND.L	D4,#H'FFFF	DIV.WU	D4,#60	CALL	CONVBA		; D4 <-- heure en BCD	LOAD.B	D3,D4	RL.W	D3,#8	SWAP.W	D4	CALL	CONVBA		; D4 <-- minute en BCD	LOAD.B	D3,D4	LOAD.W	D4,D3	POP.L	D3	CLR.W	D7		; retour EQ	RET;--------\\; CONVAB  >;--------/; Converti BCD --> binaire.; in	D4.B	byte en BCD; out	D4.B	idem en binaire; mod	D4.BCONVAB:	PUSH.L	D3	CLR.W	D3	LOAD.B	D3,D4	SR.B	D3,#4		; D3 <-- dizaines	MUL.WU	D3,#10	AND.B	D4,#H'0F	; D4 <-- units	ADD.B	D4,D3		; D4 <-- units + dizaines	POP.L	D3	RET;--------\\; CONVBA  >;--------/; Converti binaire --> BCD.; in	D4.B	byte en binaire; out	D4.B	idem en BCD; mod	D4.BCONVBA:	PUSH.L	D3	CLR.L	D3	LOAD.B	D3,D4	DIV.WU	D3,#10		; D3 <-- |  | u|  | d|	SWAP.W	D3		; D3 <-- |  | d|  | u|	SL.W	D3,#8		; D3 <-- |  | d| u|  |	SL.W	D3,#4		; D3 <-- |  | d|u |  |	SL.L	D3,#4		; D3 <-- |  |du|  |  |	SWAP.W	D3		; D3 <-- |  |  |  |du|	LOAD.B	D4,D3	POP.L	D3	RET	.END