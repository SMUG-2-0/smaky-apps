   10 Rem PHASES DE LA LUNE   20 Dim L$(4)   30 Input "ANNEE ";AX   40 L$(1)="    NOUVELLE LUNE":L$(2)="PREMIER QUARTIER":L$(3)="      PLEINE LUNE":L$(4)="DERNIER QUARTIER"   50 FA=3.14159/180   60 Rem BOUCLE SUR LES MOIS   70 For MO=1 To 13:A=AX+(MO-1)/12   80 K=(A-1900)*12.3685   90 K1=Int(K)  100 If K-K1 > .5 Then Let K1=K1+1  110 If K1-K > .5 Then Let K1=K1-1  130 For IP=1 To 4:K=K1+.25*(IP-1)  140 T=K/1236.85  160 JD=2415020.75933+29.53058868*K+.0001178*T*T-.000000155*T*T*T+.00033*Sin(FA*(166.56+132.87*T-.009173*T*T))  170 M=FA*(359.2242+29.10535608*K-.0000333*T*T-.00000347*T*T*T)  180 MP=FA*(306.0253+385.8169180*K+.0107306*T*T+.00001236*T*T*T)  190 F=FA*(21.2964+390.670506*K-.0016528*T*T-.00000239*T*T*T)  200 If IP=1 Or IP=3 Then Goto 280  210 Rem PQ ET DQ  220 JC=(.1721-.0004*T)*Sin(M)+.0021*Sin(2*M)-.628*Sin(MP)+.0089*Sin(2*MP)-.0004*Sin(3*MP)+.0079*Sin(2*F)  230 JC=JC-.0119*Sin(M+MP)-.0047*Sin(M-MP)+.0003*Sin(2*F+M)-.0004*Sin(2*F-M)  240 JC=JC-.0006*Sin(2*F+MP)+.0021*Sin(2*F-MP)+.0003*Sin(M+2*MP)+.0004*Sin(M-2*MP)-.0003*Sin(2*M+MP)  250 If IP=4 Then Let JC=JC-.0028+.0004*Cos(M)-.0003*Cos(MP)  260 If IP=2 Then Let JC=JC+.0028-.0004*Cos(M)+.0003*Cos(MP)  270 Goto 300  280 JC=(.1734-.000393*T)*Sin(M)+.0021*Sin(2*M)-.4068*Sin(MP)+.0161*Sin(2*MP)-.0004*Sin(3*MP)+.0104*Sin(2*F)-.0051*Sin(M+MP)-.0047*Sin(M-MP)+.0004*Sin(2*F+M)-.0004*Sin(2*F-M)  290 JC=JC-.0006*Sin(2*F+MP)+.001*Sin(2*F-MP)+.0005*Sin(M+2*MP)  300 Rem JOUR JULIEN --> DATE  310 JD=JD+JC  320 J1=JD+.5:Z=Int(J1):F=J1-Z  330 If Z<2299161 Then Let AA=Z:Goto 360  340 AL=Int((Z-1867216.25)/36524.25)  350 AA=Z+1+AL-Int(AL/4)  360 B=AA+1524:C=Int((B-122.1)/365.25):D=Int(365.25*C):E=Int((B-D)/30.6001)  370 DM=B-D-Int(30.6001*E)+F  380 If E<13.5 Then Let M=E-1  390 If E>13.5 Then Let M=E-13  400 If M>2.5 Then Let AN=C-4716  410 If M<2.5 Then Let AN=C-4715  420 H=Int(24*(DM-Int(DM)))  430 Print L$(IP),Int(DM);"/";M;"/";AN,H;" H."  440 Next IP  450 Next MO