	.TITLE	CHECK	.PROC	M680002	.REF	SMAKYSTART:	LOAD.W	D0,#16	LOAD.W	D1,#010$:	CALL	ESSAI	INC.W	D1	DEC.W	D0	JUMP,NE 10$	EXITESSAI:	LOAD.L	A4,#R16"DATA1	CALL	CHECK	CALL	AFF	LOAD.L	A4,#R16"DATA2	CALL	CHECK	CALL	AFF	LOAD.L	A4,#R16"DATA3	CALL	CHECK	CALL	AFF	LOAD.L	A4,#R16"DATA4	CALL	CHECK	CALL	AFF	LOAD.L	A4,#R16"DATA5	CALL	CHECK	CALL	AFF	LOAD.L	A4,#R16"DATA6	CALL	CHECK	CALL	AFF	LOAD.L	A4,#R16"DATA7	CALL	CHECK	CALL	AFF	LOAD.L	A4,#R16"DATA8	CALL	CHECK	CALL	AFF	LIB	?AFCR	RETAFF:	COMP.W	D3,D4	JUMP',NE 10$	LIB	?AFTIM	.ASCIZ	"<AFINV>"	.EVEN10$:	LIB	?AFX4	LIB	?AFSPACE	EX.L	D4,D3	LIB	?AFX4	LIB	?AFSPACE	LIB	?AFTIM	.ASCIZ	"<AFDIR>"	.EVEN	LIB	?AFSPACE	RET;--------\\; CHECK   >;========/; ; in	A4.L	^data; out	D4.W	check calcul;	D3.W	check rel; mod	CHECK:	PUSHM.L	D0,D2,A4	LOAD.B	D3,(A4+)	SUB.B	D3,#2	CLR.W	D410$:	CLR.W	D2	LOAD.B	D2,(A4+)	ADD.W	D4,D2	NOT.W	D4	RL.W	D4,D1	DEC.B	D3	JUMP,NE 10$	LOAD.B	D3,(A4+)	RL.W	D3,#8	LOAD.B	D3,(A4+)	POPM.L	D0,D2,A4	RETDATA1:	.B	4+1+4	.B	H'16	.B	H'10	.B	H'02	.B	H'01	.B	H'00	.B	H'10	.B	H'03	.B	H'01	.B	H'90DATA2:	.B	4+1+4	.B	H'16	.B	H'10	.B	H'02	.B	H'01	.B	H'01	.B	H'10	.B	H'03	.B	H'C0	.B	H'50DATA3:	.B	4+1+4	.B	H'16	.B	H'10	.B	H'02	.B	H'01	.B	H'02	.B	H'10	.B	H'03	.B	H'80	.B	H'51DATA4:	.B	4+1+4	.B	H'16	.B	H'10	.B	H'02	.B	H'01	.B	H'03	.B	H'10	.B	H'03	.B	H'41	.B	H'91DATA5:	.B	4+1+4	.B	H'16	.B	H'10	.B	H'02	.B	H'01	.B	H'04	.B	H'10	.B	H'03	.B	H'00	.B	H'53DATA6:	.B	4+1+4	.B	H'16	.B	H'10	.B	H'02	.B	H'01	.B	H'05	.B	H'10	.B	H'03	.B	H'C1	.B	H'93DATA7:	.B	4+2+4	.B	H'16	.B	H'10	.B	H'02	.B	H'01	.B	H'10	.B	H'10	.B	H'10	.B	H'03	.B	H'00	.B	H'5CDATA8:	.B	4+6+4	.B	H'16	.B	H'10	.B	H'02	.B	H'01	.B	H'19	.B	H'46	.B	H'54	.B	H'56	.B	H'41	.B	H'4E	.B	H'10	.B	H'03	.B	H'9A	.B	H'83	.END	START