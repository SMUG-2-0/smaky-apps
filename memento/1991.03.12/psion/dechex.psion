DECHEX:(CH$)LOCAL NB%,I%,C%,T%NB%=0I%=1DO C%=ASC(MID$(CH$,I%,1)) IF C%>=%A AND C%<=%F  T%=C%-%A+10  NB%=NB%*16+T% ELSEIF C%>=%a AND C%<=%f  T%=C%-%a+10  NB%=NB%*16+T% ELSEIF C%>=%0 AND C%<=%9  T%=C%-%0  NB%=NB%*16+T% ELSEIF C%=%<  NB%=NB%*16+10 ELSEIF C%=%>  NB%=NB%*16+11 ELSEIF C%=%(  NB%=NB%*16+12 ELSEIF C%=%)  NB%=NB%*16+13 ELSEIF C%=%%  NB%=NB%*16+14 ELSEIF C%=%/  NB%=NB%*16+15 ELSE  T%=-1 ENDIF I%=I%+1UNTIL T%=-1RETURN NB%