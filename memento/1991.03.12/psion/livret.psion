LIVRET:LOCAL OP1%,OP2%,NB%,REP%,JUSTE%,FAUX%LOCAL MAX,T1%PRINT"LIVRET"PRINT"Valeur max = ";TRAP INPUT MAX :IF ERR=206 :STOP :ENDIFNB%=0JUSTE%=0 :FAUX%=0T1%=MINUTE*60+SECONDDO OP1%=2+INT(RND*(MAX-1)) OP2%=2+INT(RND*(MAX-1)) CLS PRINT OP1%;" x ";OP2%;" = "; TRAP INPUT REP% :IF ERR=206 :STOP :ENDIF IF REP%=OP1%*OP2%  PRINT"Juste"  JUSTE%=JUSTE%+1  PAUSE 40 ELSE  PRINT"Faux, = ";OP1%*OP2%  FAUX%=FAUX%+1  PAUSE 80 ENDIF NB%=NB%+1UNTIL NB%=10T1%=(MINUTE*60+SECOND)-T1%CLSPRINT"JUSTE: ";JUSTE%PRINT" FAUX: ";FAUX%;"    ";T1%;""""GET :STOP