HP45HD$:(P1)LOCAL CH$(10),NOMBRE,DIGIT%CH$=""NOMBRE=ABS(P1)IF P1<0 NOMBRE=-P1 CH$="-"ENDIFDIGIT%=0IF NOMBRE>=16777216 DIGIT%=NOMBRE/16777216 NOMBRE=NOMBRE-(16777216*FLT(DIGIT%))ENDIFIF DIGIT%=0 CH$=CH$+"00"ELSEIF DIGIT%<16 CH$=CH$+"0"+HEX$(DIGIT%)ELSE CH$=CH$+HEX$(DIGIT%)ENDIFDIGIT%=0IF NOMBRE>=65536 DIGIT%=NOMBRE/65536 NOMBRE=NOMBRE-(65536*FLT(DIGIT%))ENDIFIF DIGIT%=0 CH$=CH$+"00"ELSEIF DIGIT%<16 CH$=CH$+"0"+HEX$(DIGIT%)ELSE CH$=CH$+HEX$(DIGIT%)ENDIFDIGIT%=0IF NOMBRE>=256 DIGIT%=NOMBRE/256 NOMBRE=NOMBRE-(256*FLT(DIGIT%))ENDIFIF DIGIT%=0 CH$=CH$+"00"ELSEIF DIGIT%<16 CH$=CH$+"0"+HEX$(DIGIT%)ELSE CH$=CH$+HEX$(DIGIT%)ENDIFDIGIT%=NOMBREIF DIGIT%=0 CH$=CH$+"00"ELSEIF DIGIT%<16 CH$=CH$+"0"+HEX$(DIGIT%)ELSE CH$=CH$+HEX$(DIGIT%)ENDIFRETURN CH$