VISU:LOCAL M%,R%BEGIN::ONERR ERROR::M%=MENU("VISU,MAX,QUITTER")IF M%=1 CLS :PRINT"Rang: "; :INPUT R% OPEN "MAIN",A,CH1$,CH2$ POSITION R% CLS :PRINT LEFT$(A.CH1$,15) GET CLOSEENDIFIF M%=2 OPEN"MAIN",A,CH1$ PRINT"MAX=";COUNT GET CLOSEENDIFIF M%=3 OR M%=0 STOPENDIFGOTO BEGIN::ERROR::PRINT"ERR=";ERRGETGOTO BEGIN::