	.TITLE	PLUME.ASC;	--------------------------------------;		(C) 1988 - Daniel Roux;	--------------------------------------;	Source du programme PLUME;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 1.0a	15.08.88	Dbut des travaux ...	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULESMAJREV	=	1		; rvisionMINREV	=	0		; versionPROREV	=	'a		; rvision.version provisoire;PROREV	=	SPACE		; rvision.version dfinitive	.REV	MAJREV,MINREV	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LBUNAM	=	50LBUFIO	=	100000CARSEOL	=	H'100		; SMAKY: fin de ligneCARSEOF	=	H'101		; SMAKY: fin du fichierCARPEOF	=	H'1A		; PSION: fin de transfert 26=<SUB>NBFIFO	=	100		; lg max du fifoLGFIFO	=	2		; taille d'un lment dans le fifo (.W); Erreurs; -------ERSMAKY	=	H'AA00		; erreur SMAKYERPSION	=	H'AB00		; erreur PSIONERPREP	=	ERSMAKY+1	; contenu rponse incorrectERPCHK	=	ERSMAKY+2	; checksum incorrectERPDIG	=	ERSMAKY+3	; ce n'est pas un digitERPTIM	=	ERSMAKY+4	; timeout; Variables; ---------LBUDIS	=	100	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOPLCOM:	.BLKB	4		; ^ligne de commandeOPDDIS:	.BLKB	4		; ^descripteur de la fentreOPSEM:	.BLKB	4OHEAD:	.BLKB	2		; fifo: ^tteOTAIL:	.BLKB	2		; fifo: ^queueOFIFO:	.BLKB	LGFIFO*NBFIFO	; fifo: contenuOCHIN1:	.BLKB	2OCHOUT1:.BLKB	2OCHIN2:	.BLKB	2OCHOUT2:.BLKB	2OBUDIS:	.BLKB	LBUDIS		; buffer write-displayOBUNAM:	.BLKB	LBUNAMOBURD1:	.BLKB	2OBURD2:	.BLKB	2OPBUF:	.BLKB	4OLBUF:	.BLKB	4OBUFI:	.BLKB	200OBUFO:	.BLKB	200OBUFIO:	.BLKB	LBUFIOLGVAR:; Programme; ---------	.LOC	0ADCODE:	JUMP	START; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"	.EVEN; Erreurs fatales; ---------------TXERFATREV:	.ASCIZ	"La rvision du systme est incompatible"TXERFATDIS:	.ASCIZ	"Driver d'cran incompatible"TXERFATGRA:	.ASCIZ	"Module GRA incompatible"TXERFATTXT:	.ASCIZ	"Erreur avec le gencar NEF11"TXERFATICO:	.ASCIZ	"Erreur avec le gencar IPP15"	.EVENSTART:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*5+6	; est-ce au moins 5.6 ?	JUMP,LO ERFAT2		; non => ERFAT2	LOAD.L	A3,#R16"TXERFATDIS	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT2	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	COMP.W	(A0)+ODFIIX,#1	; cran de type SMAKY100/324 ?	JUMP,NE ERFAT2		; non => patatras ...	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	D4,#1	NTREL	?CRESEM	JUMP,NE ERFAT	LOAD.L	(A6)+OPSEM,A5	LOAD.B	D3,#EOP	LIB	?AFCAR	CALL	USARTOPEN	JUMP,NE ERRORLOOP:	LIB	?AFTIM	.ASCIZ	"<CR>(T)ransmet, (R)eoit, (E)spion, (A)nalyse, (1)transmet (2)reoit (3)stoppe agenda, (END) ? "	.EVEN	LIB	?GETCAR	LIB	?MINMAJ	LIB	?AFCODE	COMP.W	D3,#'T	JUMP,EQ TRANSMIT	COMP.W	D3,#'R	JUMP,EQ RECEIVE	COMP.W	D3,#'E	JUMP,EQ ESPION	COMP.W	D3,#'A	JUMP,EQ ANALYSE	COMP.W	D3,#'1	JUMP,EQ SDIARY	COMP.W	D3,#'2	JUMP,EQ RDIARY	COMP.W	D3,#'3	JUMP,EQ ADIARY	COMP.W	D3,#END	JUMP,EQ FINIBIP:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOPTRANSMIT:	CALL	FILENAME	JUMP,NE LOOP	CALL	FILEREAD	JUMP,NE ERROR	CALL	USARTWRITE	JUMP,NE ERROR	LOAD.L	A4,#(A6)+OBUFIO	LOAD.B	(A4),#CARPEOF	LOAD.L	D4,#1	CALL	USARTWRITE	JUMP,NE ERROR	JUMP	LOOPRECEIVE:	CALL	FILENAME	JUMP,NE LOOP	CALL	USARTREAD	JUMP,NE ERROR	CALL	FILEWRITE	JUMP,NE ERROR	JUMP	LOOPESPION:	LOAD.L	A4,#(A6)+OBUFIO	LOAD.L	(A6)+OPBUF,A4	CLR.L	(A6)+OLBUF	NTREL	?GETPRIO	; D4 <-- priorit de START	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP,NE ERROR	NTREL	?GETPRIO	; D4 <-- priorit de START	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS2	LOAD.L	A3,#R16"NFILS2	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP,NE ERROR	LIB	?AFTIM	.ASCIZ	"<CR>(A)vort ? "	.EVEN20$:	LOAD.W	D4,#50*1	NTREL	?SETTIM	LIB	?GETCAR	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE 20$	LIB	?MINMAJ	COMP.W	D3,#'A	JUMP,NE 20$	LOAD.W	D6,(A6)+OCHIN1	FOS	?AVORT	LOAD.W	D6,(A6)+OCHIN2	FOS	?AVORT	NTREL	?WFABDESC	CALL	FILENAME	JUMP,NE LOOP	LOAD.L	A4,#(A6)+OBUFIO	LOAD.L	D4,(A6)+OLBUF	CALL	FILEWRITE	JUMP,NE ERROR	JUMP	LOOPANALYSE:	CALL	FILENAME	JUMP,NE LOOP	CALL	FILEREAD	JUMP,NE ERROR	LIB	?AFCR	LOAD.W	D2,#-120$:	TEST.L	D4	JUMP,EQ LOOP	LOAD.W	D3,(A4+)	SUB.L	D4,#2	LOAD.W	D1,D3	SR.W	D1,#8	COMP.W	D1,D2	JUMP,EQ 30$	LOAD.W	D2,D1	LIB	?AFCR	PUSH.W	D3	LOAD.B	D3,D2	LIB	?AFCODE	LIB	?AFSPACE	POP.W	D330$:	LIB	?AFCODE	JUMP	20$SDIARY:	CALL	USARTCLOSE	CALL	USARTOPEN	CALL	FILENAME	JUMP,NE LOOP	CALL	FILEREAD	JUMP,NE ERROR	LOAD.L	D0,D4	LOAD.L	A0,A4	CLR.W	(A6)+OHEAD	; vide le fifo	CLR.W	(A6)+OTAIL	NTREL	?GETPRIO	; D4 <-- priorit de START	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS3	LOAD.L	A3,#R16"NFILS3	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP,NE ERROR	LOAD.L	D3,D0	LOAD.L	A3,A020$:	LIB	?AFTIM	.ASCIZ	"."	.EVEN	CALL	USARTDIAL	JUMP,NE 80$	CLR.L	D4	LOAD.B	D4,(A3)	INC.L	D4	ADD.L	A3,D4		; A3 <-- ^lment suivant	SUB.L	D3,D4	JUMP,NE 20$80$:	PUSH.W	D7	LOAD.W	D6,(A6)+OCHIN1	FOS	?AVORT	NTREL	?WFABDESC	POP.W	D7	JUMP,NE ERROR	JUMP	LOOP;	.B	1+2	H'01,0,(7+5)+(7+3);	.B	1+7+5	H'02,5,88,9-1,16-1,12,0,0,'E,'s,'s,'a,'i;	.B	1+7+3	H'02,3,88,9-1,16-1,13,0,0,'A,'b,'cRDIARY:	CLR.W	(A6)+OHEAD	; vide le fifo	CLR.W	(A6)+OTAIL	NTREL	?GETPRIO	; D4 <-- priorit de START	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS3	LOAD.L	A3,#R16"NFILS3	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP,NE ERROR	LOAD.L	A4,#(A6)+OBUFIO	LOAD.L	A3,#R16"COM$	CALL	USARTSEND	JUMP,NE 50$	LOAD.L	A3,#(A6)+OBUFI	CALL	USARTRECV	JUMP,NE 50$	LOAD.W	D7,#ERPREP	COMP.B	(A3)+0,#3	; lg correcte ?	JUMP,NE 50$	COMP.B	(A3)+1,#H'01	JUMP,NE 50$	LOAD.W	D4,(A3)+2	; D4 <-- lg attendue	ADD.W	D4,#230$:	LIB	?AFTIM	.ASCIZ	"."	.EVEN	CLR.W	D2	LOAD.B	D2,(A3)	DEC.W	D2	SUB.W	D4,D2	ADD.W	D2,#232$:	LOAD.B	(A4+),(A3+)	; buffer <-- un lment	DEC.B	D2	JUMP,NE 32$	CLR.W	D7	TEST.W	D4	JUMP,EQ 50$	LOAD.L	A3,#(A6)+OBUFI	CALL	USARTRECV	JUMP,NE 50$	LOAD.W	D7,#ERPREP	COMP.B	(A3)+1,#H'02	JUMP,NE 50$	JUMP	30$50$:	PUSH.W	D7	LOAD.W	D6,(A6)+OCHIN1	FOS	?AVORT	NTREL	?WFABDESC	POP.W	D7	JUMP,NE ERROR	LOAD.L	A3,#(A6)+OBUFIO	LOAD.L	D4,A4	SUB.L	D4,A3	LOAD.L	A4,A3	CALL	FILENAME	JUMP,NE LOOP	CALL	FILEWRITE	JUMP,NE ERROR	JUMP	LOOPCOM$:	.B	1	H'03	; demande les donnes	.EVENADIARY:	LOAD.L	A3,#R16"COM$	CALL	USARTSEND	JUMP,NE ERROR	JUMP	LOOPCOM$:	.B	1	H'FE	; demande de quitter	.EVENERROR:	LIB	?AFERROR	JUMP	LOOPFINI:	CALL	USARTCLOSEERFAT:	LOAD.L	A5,(A6)+OPSEM	NTREL	?KILLSEM	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSEERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFATNFILS1:	.ASCIZ	"PSION_READ1"	.EVENPFILS1:	LIB	?AFTIM	.ASCIZ	"<CR>Dbut du processus fils 1 "	.EVEN10$:	LOAD.L	A4,#(A6)+OBURD1	LOAD.L	D4,#1	LOAD.W	D6,(A6)+OCHIN1	FOS	?RDBYTE	JUMP,NE 90$	LOAD.W	D3,#H'100*'1	LOAD.B	D3,(A4)	CALL	PUTBUF	JUMP,EQ	10$90$:	LIB	?AFTIM	.ASCIZ	"<CR>Fin du processus fils 1 "	.EVEN	NTREL	?ABORTNFILS2:	.ASCIZ	"PSION_READ2"	.EVENPFILS2:	LIB	?AFTIM	.ASCIZ	"<CR>Dbut du processus fils 2 "	.EVEN10$:	LOAD.L	A4,#(A6)+OBURD2	LOAD.L	D4,#1	LOAD.W	D6,(A6)+OCHIN2	FOS	?RDBYTE	JUMP,NE 90$	LOAD.W	D3,#H'100*'2	LOAD.B	D3,(A4)	CALL	PUTBUF	JUMP,EQ	10$90$:	LIB	?AFTIM	.ASCIZ	"<CR>Fin du processus fils 2 "	.EVEN	NTREL	?ABORTNFILS3:	.ASCIZ	"PSION_READ3"	.EVENPFILS3:10$:	LOAD.L	A4,#(A6)+OBURD1	LOAD.L	D4,#1	LOAD.W	D6,(A6)+OCHIN1	FOS	?RDBYTE		; lit un byte ...	JUMP,NE 80$	CLR.W	D3	LOAD.B	D3,(A4)	CALL	PUTFIFO		; fifo <-- caractre	JUMP	10$80$:	LOAD.W	D3,#CARSEOF	CALL	PUTFIFO		; fifo <-- c'est fini	NTREL	?ABORTPUTBUF:	LOAD.W	D7,#1	COMP.L	(A6)+OLBUF,#LBUFIO	JUMP,HS 90$	LOAD.L	A5,(A6)+OPSEM	NTREL	?LOCK	LOAD.L	A4,(A6)+OPBUF	LOAD.W	(A4+),D3	LOAD.L	(A6)+OPBUF,A4	ADD.L	(A6)+OLBUF,#2	NTREL	?UNLOCK	CLR.W	D790$:	TEST.W	D7	RET;----------\\; USARTDIAL >;==========/; ; in	A3.L	^<lg>data; out	D7.W	erreur; mod	D7.WUSARTDIAL:	PUSHM.L	D4,A3	LOAD.W	D4,#20	NTREL	?DELMS		; attend que le PSION soit prt ...	CALL	USARTSEND	JUMP,NE 90$	LOAD.L	A3,#(A6)+OBUFI	CALL	USARTRECV	JUMP,NE 90$	LOAD.W	D7,#ERPREP	COMP.B	(A3)+0,#2	; lg correcte ?	JUMP,NE 90$	COMP.B	(A3)+1,#H'FF	JUMP,NE 90$	LOAD.W	D7,#ERPSION	LOAD.B	D7,(A3)+2	; D7 <-- ok/erreur PSION	JUMP,NE 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTSEND >;==========/; Envoie une ligne du type :;;	head      check;	>--<      >--<;	 %$41424344F6<CR>;	   <------>;	     data; in	A3.L	^<lg>data; out	D7.W	erreur; mod	D7.WUSARTSEND:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,#(A6)+OBUFO	LOAD.B	(A4+),#'%	LOAD.B	(A4+),#'$	LOAD.B	D2,(A3+)	; D2 <-- lg	CLR.B	D4		; D4 <-- check20$:	LOAD.B	D3,(A3+)	CALL	USARTSPUT	ADD.B	D4,D3	DEC.B	D2	JUMP,NE 20$	LOAD.B	D3,D4	NEG.B	D3	CALL	USARTSPUT	LOAD.B	(A4+),#CR	LOAD.L	A3,#(A6)+OBUFO	LOAD.L	D4,A4	SUB.L	D4,A3	LOAD.L	A4,A3	CALL	USARTWRITE	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTSPUT >;----------/; Met deux digits hexadcimaux pour un byte.; in	D3.B	byte;	A4.L	^buffer; out	A4.L	^plus loin; mod	A4.LUSARTSPUT:	PUSH.W	D4	LOAD.B	D4,D3	SR.B	D4,#4	ADD.B	D4,#'0	COMP.B	D4,#'9	JUMP,LS 20$	ADD.B	D4,#'A-'9-120$:	LOAD.B	(A4+),D4	LOAD.B	D4,D3	AND.B	D4,#H'0F	ADD.B	D4,#'0	COMP.B	D4,#'9	JUMP,LS 30$	ADD.B	D4,#'A-'9-130$:	LOAD.B	(A4+),D4	POP.W	D4	RET;----------\\; USARTRECV >;==========/; Reoit une ligne.; in	A3.L	^buffer; out	(A3)	^<lg>data;	D7.W	erreur; mod	D7.WUSARTRECV:	PUSHM.L	D2..D4,A3,A410$:	CALL	USARTRWCA	; D3 <-- un caractre	JUMP,NE 90$	COMP.W	D3,#'%	JUMP,NE 10$	CALL	USARTRWCA	; D3 <-- un caractre	JUMP,NE 90$	COMP.W	D3,#'#	JUMP,NE 10$	LOAD.L	A4,#(A3)+1	CLR.B	D2		; D2 <-- lg	CLR.B	D4		; D4 <-- check30$:	CALL	USARTRGET	; D3 <-- un caractre	JUMP,NE 90$	COMP.W	D3,#CARSEOL	JUMP,EQ 40$	LOAD.B	(A4+),D3	; buffer <-- un caractre	ADD.B	D4,D3		; D4 <-- check	INC.B	D2	JUMP	30$40$:	DEC.B	D2	LOAD.B	(A3),D2		; buffer <-- <lg>	LOAD.W	D7,#ERPCHK	TEST.B	D4		; check correct ?	JUMP,NE 90$		; non => 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTRGET >;----------/; ; in	-; out	D3.W	byte lu;	D7.W	erreur; mod	D3.L, D7.WUSARTRGET:	PUSH.L	D4	CALL	USARTRWCA	; D3 <-- un caractre	JUMP,NE 90$	COMP.W	D3,#CARSEOL	JUMP,EQ 90$	COMP.B	D3,#'0	JUMP,LO 80$	COMP.B	D3,#'9	JUMP,LS 20$	COMP.B	D3,#'A	JUMP,LO 80$	COMP.B	D3,#'F	JUMP,HI 80$	SUB.B	D3,#'A-'9-120$:	SUB.B	D3,#'0	LOAD.B	D4,D3	SL.B	D4,#4	CALL	USARTRWCA	; D3 <-- un caractre	JUMP,NE 90$	COMP.W	D3,#CARSEOL	JUMP,EQ 90$	COMP.B	D3,#'0	JUMP,LO 80$	COMP.B	D3,#'9	JUMP,LS 40$	COMP.B	D3,#'A	JUMP,LO 80$	COMP.B	D3,#'F	JUMP,HI 80$	SUB.B	D3,#'A-'9-140$:	SUB.B	D3,#'0	OR.B	D3,D4	JUMP	90$80$:	LOAD.W	D7,#ERPDIG90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTRWCA >;----------/; ; in	-; out	D3.W	caractre lu;	D7.W	erreur; mod	D3.L, D7.WUSARTRWCA:	PUSHM.L	D0,D4,A020$:	CALL	GETFIFO		; D3 <-- lit le fifo	JUMP,EQ 80$	LOAD.W	D4,#50/4	NTREL	?SETTIM	LIB	?GETCAR		; une touche presse ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE 20$		; non => 20$	COMP.W	D3,#END	JUMP,NE 20$	LOAD.W	D7,#ERPTIM	JUMP	90$80$:	LOAD.W	D7,#ERPTIM	COMP.W	D3,#CARSEOF	JUMP,EQ 90$	COMP.B	D3,#CR	JUMP,NE 85$	LOAD.W	D3,#CARSEOL85$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D4,A0	TEST.W	D7		; retour EQ/NE	RET;---------\\; FILENAME >;=========/; ; in	-; out	A3.L	^nom du fichier;	D7.W	erreur; mod	D7.W, A3.LFILENAME:	PUSHM.L	D3	LIB	?AFTIM	.ASCIZ	"<CR>Nom du fichier : "	.EVEN	LOAD.L	A3,#(A6)+OBUNAM	LOAD.W	D3,#LBUNAM	LIB	?GETLINE	COMP.W	D3,#CR	JUMP,EQ 90$	LOAD.W	D7,#ERKSTO90$:	POPM.L	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; FILEREAD >;=========/; ; in	A3.L	^nom; out	A4.L	^data;	D4.L	longueur;	D7.W	erreur; mod	D4.L, D7.W, A4.LFILEREAD:	PUSHM.L	D3,D6	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUFIO	LOAD.L	D4,#LBUFIO	FOS	?RDBYTE	COMP.W	D7,#EROUTF	JUMP,NE 80$	FOS	?CLOSE	JUMP	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; FILEWRITE >;==========/; ; in	A3.L	^nom;	A4.L	^data;	D4.L	longueur; out	D7.W	erreur; mod	D7.WFILEWRITE:	PUSHM.L	D3,D4,D620$:	PUSH.L	D4	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	POPM.L	D4	JUMP,EQ 30$	COMP.W	D7,#ERFAEX	JUMP,NE 90$	LIB	?AFTIM	.ASCIZ	"<CR>Dtruit l'ancien ? "	.EVEN	LIB	?YESNO	COMP.W	D7,#ERKYES	JUMP,NE 90$	FOS	?DELETE	JUMP,NE 90$	JUMP	20$30$:	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE 90$	FOS	?WRBYTE80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTREAD >;==========/; ; in	-; out	A4.L	^data;	D4.L	longueur;	D7.W	erreur; mod	D4.L, D7.W, A4.LUSARTREAD:	PUSHM.L	D3,D6	LOAD.L	A4,#(A6)+OBUFIO	LOAD.L	D4,#LBUFIO	LOAD.W	D6,(A6)+OCHIN1	FOS	?RDBYTE	COMP.W	D7,#EROUTF	JUMP,NE 90$	TEST.L	D4	JUMP,EQ 90$	CLR.W	D790$:	POPM.L	D3,D6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; USARTWRITE >;===========/; ; in	A4.L	^data;	D4.L	longueur; out	D7.W	erreur; mod	D7.WUSARTWRITE:	PUSHM.L	D3,D4,D6	LOAD.W	D6,(A6)+OCHOUT1	FOS	?WRBYTE90$:	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTOPEN >;==========/; ; in	-; out	D7.W	erreur; mod	D7.WUSARTOPEN:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,#R16"TUSIN1	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE 90$	LOAD.W	(A6)+OCHIN1,D6	LOAD.L	A3,#R16"TUSOUT1	LOAD.W	D3,#2^BOPWR	FOS	?OPEN	JUMP,NE 90$	LOAD.W	(A6)+OCHOUT1,D6	LOAD.L	A4,#R16"TCMIN	LOAD.W	D3,#TYPIO	LOAD.W	D6,(A6)+OCHIN1	FOS	?COMMAND;	JUMP,NE 90$	LOAD.L	A4,#R16"TCMOUT	LOAD.W	D3,#TYPIO	LOAD.W	D6,(A6)+OCHOUT1	FOS	?COMMAND;	JUMP,NE 90$	LOAD.L	A3,#R16"TUSIN2	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE 90$	LOAD.W	(A6)+OCHIN2,D6	LOAD.L	A3,#R16"TUSOUT2	LOAD.W	D3,#2^BOPWR	FOS	?OPEN	JUMP,NE 90$	LOAD.W	(A6)+OCHOUT2,D6	LOAD.L	A4,#R16"TCMIN	LOAD.W	D3,#TYPIO	LOAD.W	D6,(A6)+OCHIN2	FOS	?COMMAND;	JUMP,NE 90$	LOAD.L	A4,#R16"TCMOUT	LOAD.W	D3,#TYPIO	LOAD.W	D6,(A6)+OCHOUT2	FOS	?COMMAND;	JUMP,NE 90$90$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; USARTCLOSE >;===========/; ; in	-; out	-; mod	D7.WUSARTCLOSE:	PUSHM.L	D6	LOAD.W	D6,(A6)+OCHIN1	FOS	?CLOSE	LOAD.W	D6,(A6)+OCHOUT1	FOS	?CLOSE	LOAD.W	D6,(A6)+OCHIN2	FOS	?CLOSE	LOAD.W	D6,(A6)+OCHOUT2	FOS	?CLOSE	CLR.W	(A6)+OCHIN1	CLR.W	(A6)+OCHOUT1	CLR.W	(A6)+OCHIN2	CLR.W	(A6)+OCHOUT2	POPM.L	D6	RET;--------\\; PUTFIFO >;========/; Met un caractre dans le fifo.; in	D3.W	caractre; out	D7.W	erreur; mod	D7.WPUTFIFO:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OFIFO	LOAD.W	D4,(A6)+OHEAD	ADD.W	A4,D4	LOAD.W	(A4+),D3	ADD.W	D4,#LGFIFO	COMP.W	D4,#LGFIFO*NBFIFO	JUMP',LO 30$	CLR.W	D430$:	LOAD.W	D7,#1		; D7 <-- fifo plein	COMP.W	D4,(A6)+OTAIL	JUMP',EQ 90$	LOAD.W	(A6)+OHEAD,D4	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETFIFO >;========/; Prend un caractre dans le fifo.; in	-; out	D3.W	canal;	D7.W	erreur; mod	D3.L, D7.WGETFIFO:	PUSHM.L	D4,A4	LOAD.W	D7,#1		; D7 <-- fifo vide	LOAD.W	D4,(A6)+OTAIL	COMP.W	D4,(A6)+OHEAD	JUMP',EQ 90$	LOAD.L	A4,#(A6)+OFIFO	ADD.W	A4,D4	LOAD.W	D3,(A4+)	ADD.W	D4,#LGFIFO	COMP.W	D4,#LGFIFO*NBFIFO	JUMP',LO 30$	CLR.W	D430$:	LOAD.W	(A6)+OTAIL,D4	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RETTUSIN1:	.ASCIZ	"#PR"TUSOUT1:.ASCIZ	"#PP"TUSIN2:	.ASCIZ	"#MI"TUSOUT2:.ASCIZ	"#MO"TCMIN:;;?	.B	'N;;?	.BW	'V,300;;?	.BB	'F,'E;;?	.BB	'Y,'D;;?	.B	0	.B	'N		; mode standard	.BW	'V,9600		; baud-rate	.BB	'Y,'E		; timeout par commande	.BW	'W,50*4		; timeout de 4 secondes	.BB	'F,'E		; fifo enable	.BB	'X,'E		; xon-xoff enable	.B	0TCMOUT:;;?	.BW	'V,300;;?	.BB	'F,'E;;?	.BB	'Y,'D;;?	.B	0	.BW	'V,9600		; baud-rate	.BB	'Y,'E		; timeout par commande	.BW	'W,50*4		; timeout de 4 secondes	.BB	'F,'E		; fifo enable	.BB	'X,'E		; xon-xoff enable	.B	0	.EVEN	.END	START