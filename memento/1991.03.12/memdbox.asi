	.SBTTL	MEMDBOX;--------\\; DBOXRDV >;========/; Edition d'un rendez-vous ...; in	D4.L	date; out	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXRDV:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	D0,D4		; D0 <-- date	LOAD.L	A2,#R16"TDBOX_RDV	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D1,(A0)+ODFC1Y	ADD.W	D1,(A0)+ODFC2Y	; D1 <-- interligne	LOAD.W	D2,#201!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A0)+ODFCX	SWAP.W	D3	SUB.W	D3,D1	SUB.W	D3,#2	SWAP.W	D3	LOAD.W	D4,D1	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#4	SWAP.W	D4	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#10	LOAD.W	D4,D2	LOAD.W	D2,#SETDOT	LIB	?DRRECT	LOAD.W	D2,#202!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A0)+ODFCX	SWAP.W	D3	SUB.W	D3,D1	SUB.W	D3,#2	SWAP.W	D3	LOAD.W	D4,D1	MUL.WU	D4,#8	ADD.W	D4,#2	SWAP.W	D4	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#34	LOAD.W	D4,D2	LOAD.W	D2,#SETDOT	LIB	?DRRECT	LOAD.W	D2,#203!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A0)+ODFCX	SWAP.W	D3	SUB.W	D3,D1	SUB.W	D3,#2	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#39	SUB.W	D4,#4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	LOAD.W	D4,D1	MUL.WU	D4,#11	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRSEG	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#39-6	SUB.W	D4,#4	NEG.W	D4	LIB	?DRSEG	LOAD.W	D4,D1	MUL.WU	D4,#3	NEG.W	D4	SWAP.W	D4	LIB	?DRSEG	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#6	NEG.W	D4	LIB	?DRSEG	LOAD.W	D4,D1	MUL.WU	D4,#11-3	ADD.W	D4,#2	NEG.W	D4	SWAP.W	D4	LIB	?DRSEG	LOAD.W	D2,#204!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A0)+ODFCX	SWAP.W	D3	SUB.W	D3,D1	SUB.W	D3,#8	SWAP.W	D3	LOAD.W	D4,D1	MUL.WU	D4,#2	ADD.W	D4,#8	SWAP.W	D4	LOAD.W	D2,(A0)+ODFCX	MUL.WU	D2,#40	LOAD.W	D4,D2	LOAD.W	D2,#SETDOT	LIB	?DRRECT	LIB	?AFTIM	.B	USEGC,GCT2F,GCT2S,GCT2T,0	.EVEN	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	D4,D0		; D4 <-- date	CALL	DATEJDLS	LOAD.B	(A3+),#SPACE	CALL	DATEDAY	LOAD.B	(A3+),#SPACE	LOAD.L	A4,A3	CALL	DATEMONTH	ADD.B	(A4),#'a-'A	; 1re lettre du mois = minuscule !	LOAD.B	(A3+),#SPACE	CALL	DATEYEAR	LOAD.B	(A3+),#SPACE	LOAD.B	(A3+),#'	LOAD.B	(A3+),#SPACE	CALL	DATEMTIME	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D2,#104!2^BDBGCLABEL	DBOX_	GETCO	LOAD.W	D1,D4	LOAD.W	D4,D3	SUB.W	D4,#10	CLR.W	D3	LOAD.W	D2,#2^BAFFRIGHT	CALL	AFFTEXT		; affiche la date et l'heure	LOAD.L	A3,#R16"MIN$	LOAD.W	D3,D1	ADD.W	D3,#8+12	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,D3	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFTEXT		; affiche les minutes	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0	.EVEN	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	LOAD.W	D2,#SETDOT	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SWAP.W	D3	SUB.W	D3,#8	LOAD.W	D4,#+5	SWAP.W	D4	LOAD.W	D4,#-5	LIB	?DRSEG		; "/" en haut	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	MUL.WU	D4,#3	SUB.W	D4,#2	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; "|" suprieure	LOAD.W	D4,#+5	SWAP.W	D4	LOAD.W	D4,#-10	LIB	?DRSEG		; "/" pointe	LOAD.W	D4,#+5	SWAP.W	D4	LOAD.W	D4,#+10	LIB	?DRSEG		; "\" pointe	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	MUL.WU	D4,#3	SUB.W	D4,#4	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; "|" infrieure	LOAD.W	D4,#+5	SWAP.W	D4	LOAD.W	D4,#+5	LIB	?DRSEG		; "\" en bas	LOAD.L	D4,D0		; D4 <-- date	CALL	RDVSEARCH	; A4 <-- ^rendez-vous	JUMP',NE NEW$	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	" MODIFIE "	.EVEN	LOAD.L	A3,#(A6)+ORDV	LOAD.W	D4,(A4)+ORMLG	DEC.W	D4TAKE$:	LOAD.B	(A3+),(A4+)	; ORDV <-- rendez-vous	DECJ.W,NMO D4,TAKE$	JUMP'	TEXT$NEW$:	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"  CREE   "	.EVEN	LOAD.W	D2,#2!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	CLR.B	(A6)+ORDV+ORMTXT	LOAD.L	(A6)+ORDV+ORMFAN,#2^BRDVT3!2^BRDVUM!2^BRDVRN	LOAD.W	(A6)+ORDV+ORMNBR,#1	CLR.W	(A6)+ORDV+ORMDUR	LOAD.W	(A6)+ORDV+ORMSON,#15	CLR.W	(A6)+ORDV+ORMMIN	LOAD.L	D4,D0		; D4 <-- date	AND.W	D4,#H'00FF	; D4 <-- temps (unit = 10 minutes)	MUL.WU	D4,#10		; D4 <-- temps (unit = 1 minute)	DIV.WU	D4,#60	SWAP.W	D4	TEST.W	D4	JUMP',EQ TEXT$	LOAD.W	(A6)+ORDV+ORMMIN,#30TEXT$:	LOAD.L	A4,#(A6)+OBUDIS+10	CLR.L	D4	LOAD.W	D4,(A6)+ORDV+ORMNBR	CALL	PUTANUM		; OBUDIS+10 <-- nb de fois	CLR.B	(A4)	LOAD.L	A4,#(A6)+OBUDIS+20	CLR.L	D4	LOAD.W	D4,(A6)+ORDV+ORMSON	CALL	PUTANUM		; OBUDIS+20 <-- nb de minutes avant	CLR.B	(A4)	LOAD.L	A4,#(A6)+OBUDIS+30	LOAD.W	D4,(A6)+ORDV+ORMDUR	TEST.B	(A6)+ORDV+ORMFAN+3:#BRDVUH-0	JUMP',BC TEXT1$	DIV.WU	D4,#60TEXT1$:	AND.L	D4,#H'FFFF	JUMP',EQ TEXT2$	CALL	PUTANUM		; OBUDIS+30 <-- dure en ASCIITEXT2$:	CLR.B	(A4)	LOAD.L	A4,#(A6)+OBUDIS+40	CLR.L	D4	LOAD.W	D4,(A6)+ORDV+ORMMIN	CALL	PUTANUM		; OBUDIS+40 <-- minutes	CLR.B	(A4)	LOAD.W	D2,#101!2^BDBGCLABEL	LOAD.L	A3,#(A6)+OBUDIS+10	CALL	DBOXAFTEXT	; affiche le nb de fois	LOAD.W	D2,#102!2^BDBGCLABEL	LOAD.L	A3,#(A6)+OBUDIS+20	CALL	DBOXAFTEXT	; affiche le nb de minutes avant	LOAD.W	D2,#103!2^BDBGCLABEL	LOAD.L	A3,#(A6)+OBUDIS+30	CALL	DBOXAFTEXT	; affiche la dure	LOAD.W	D2,#104!2^BDBGCLABEL	LOAD.L	A3,#(A6)+OBUDIS+40	CALL	DBOXAFTEXT	; affiche les minutes	LOAD.L	D4,(A6)+ORDV+ORMFAN ; D4 <-- fanions	CLR.W	D2		; D2 <-- dite le texteCHANGE$:	LOAD.L	A3,#(A6)+ORDV+ORMTXT	LOAD.W	D3,#1	TEST.W	D2	JUMP',EQ CHANGE1$	LOAD.L	A3,#(A6)+OBUDIS+10	LOAD.W	D3,#2	COMP.W	D2,#1	JUMP',EQ CHANGE1$	LOAD.L	A3,#(A6)+OBUDIS+20	LOAD.W	D3,#3	COMP.W	D2,#2	JUMP',EQ CHANGE1$	LOAD.L	A3,#(A6)+OBUDIS+30	LOAD.W	D3,#4	COMP.W	D2,#3	JUMP',EQ CHANGE1$	LOAD.L	A3,#(A6)+OBUDIS+40	CLR.W	D3CHANGE1$:	LOAD.L	A4,A3CHANGE2$:	TEST.B	(A4+)	JUMP,NE CHANGE2$	DEC.L	A4	DBOX_	MEDITDUREE$:	CALL	DBRDDUR		; affiche la dure selon  la rptitionLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_RDV	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	TEST.W	D3	JUMP,EQ DUREE$	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ MODIF$	COMP.W	D3,#F4	JUMP,EQ SUPP$	COMP.W	D3,#F0	JUMP,EQ CLOSE$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#DEFINE	JUMP',EQ DEFINE$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ CLIC$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	CHANGE$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	INC.W	D2	COMP.W	D2,#5	JUMP,LO CHANGE$	CLR.W	D2	JUMP	CHANGE$DEFINE$:	CALL	DBRDPREC	; reprend le rendez-vous prcdent	JUMP,NE BIP$	JUMP	TEXT$CLIC$:	COMP.B	D3,#100	JUMP,HS CLIC9$	COMP.B	D3,#BRDVUM	JUMP,EQ UNITM$	COMP.B	D3,#BRDVUH	JUMP,EQ UNITH$	LOAD.L	D1,#H'FFFFFFE0	COMP.B	D3,#BRDVT4	JUMP',LS CLIC2$	LOAD.L	D1,#H'FFFF00FF	COMP.B	D3,#BRDVRA	JUMP,LS CLIC2$	COMP.B	D3,#BRDVRX7	JUMP',LS CLIC4$	JUMP	LOOP$CLIC2$:	AND.L	D4,D1	TSET.L	D4:D3	COMP.B	D3,#BRDVRJ	JUMP',EQ CLIC3$	TEST.L	D4:#BRDVRJ	JUMP,BS DUREE$	AND.L	D4,#-1-(2^BRDVRX1!2^BRDVRX2!2^BRDVRX3!2^BRDVRX4!2^BRDVRX5!2^BRDVRX6!2^BRDVRX7)	JUMP	DUREE$CLIC3$:	OR.L	D4,#2^BRDVRX1!2^BRDVRX2!2^BRDVRX3!2^BRDVRX4!2^BRDVRX5!2^BRDVRX6!2^BRDVRX7	JUMP	DUREE$CLIC4$:	LOAD.L	D1,D4	AND.L	D1,#H'00FF0000	JUMP',EQ CLIC5$	AND.L	D4,#H'FFFF00FF	TSET.L	D4:#BRDVRJ	JUMP	DUREE$CLIC5$:	TEST.L	D4:#BRDVRJ	JUMP,BC DUREE$	AND.L	D4,#H'FFFF00FF	TSET.L	D4:#BRDVRN	JUMP	DUREE$CLIC9$:	SUB.B	D3,#100	LOAD.B	D2,D3	JUMP	CHANGE$UNITM$:	TSET.L	D4:#BRDVUM	TCLR.L	D4:#BRDVUH	JUMP,BC BIP$	PUSH.L	D4	LOAD.L	A4,#(A6)+OBUDIS+30	CALL	GETANUM		; D4 <-- dure	MUL.WU	D4,#60	LOAD.L	A4,#(A6)+OBUDIS+30	CALL	PUTANUM	CLR.B	(A4)	POP.L	D4	JUMP'	UNIT$UNITH$:	TSET.L	D4:#BRDVUH	TCLR.L	D4:#BRDVUM	JUMP,BC BIP$	PUSH.L	D4	LOAD.L	A4,#(A6)+OBUDIS+30	CALL	GETANUM		; D4 <-- dure	DIV.WU	D4,#60	AND.L	D4,#H'FFFF	LOAD.L	A4,#(A6)+OBUDIS+30	CALL	PUTANUM	CLR.B	(A4)	POP.L	D4UNIT$:	LOAD.W	D2,#103!2^BDBGCLABEL	LOAD.L	A3,#(A6)+OBUDIS+30	CALL	DBOXAFTEXT	; affiche la dure	LOAD.W	D2,#3		; D2 <-- dite la dure	JUMP	CHANGE$MODIF$:				; MODIFIE/CREE =>	TCLR.L	D4:#BRDVQS	; D4 <-- sonne  nouveau si ncessaire !	LOAD.L	(A6)+ORDV+ORMFAN,D4	LOAD.L	A4,#(A6)+OBUDIS+10	CALL	GETANUM		; D4 <-- nombre de rptitions	LOAD.W	(A6)+ORDV+ORMNBR,D4	LOAD.L	A4,#(A6)+OBUDIS+20	CALL	GETANUM		; D4 <-- nombre de minutes avant	LOAD.W	(A6)+ORDV+ORMSON,D4	LOAD.L	A4,#(A6)+OBUDIS+30	CALL	GETANUM		; D4 <-- dure	TEST.B	(A6)+ORDV+ORMFAN+3:#BRDVUH-0	JUMP',BC MODIF2$	MUL.WU	D4,#60		; D4 <-- dure toujours en minutesMODIF2$:	LOAD.W	(A6)+ORDV+ORMDUR,D4	LOAD.L	A4,#(A6)+OBUDIS+40	CALL	GETANUM		; D4 <-- minutes	LOAD.W	(A6)+ORDV+ORMMIN,D4	CLR.W	D2	LOAD.L	D4,(A6)+ORDV+ORMFAN	TEST.B	(A6)+ORDV+ORMTXT	JUMP,EQ BIP$	LOAD.W	D2,#4	COMP.W	(A6)+ORDV+ORMMIN,#60	JUMP,HS BIP$	CALL	DBRDSAVE	; sauve le rendez-vous dit	LOAD.L	D4,D0		; D4 <-- date	CALL	RDVDELETE	; supprime le(s) rendez-vous ..	CALL	RDVINSERT	; .. puis recre-le(s)	JUMP'	CLOSE$SUPP$:				; SUPPRIME =>	LOAD.L	(A6)+ORDV+ORMFAN,D4	CALL	DBRDSAVE	; sauve le rendez-vous dit	LOAD.L	D4,D0		; D4 <-- date	CALL	RDVDELETE	; supprime le(s) rendez-vous	CLR.W	D7		; D7 <-- toujours ok;	JUMP'	CLOSE$CLOSE$:	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETMIN$:	.ASCIZ	"minutes"	.EVEN;--------\\; DBRDDUR >;--------/; Affiche la dure d'une rptition.; in	D0.L	date;	D4.L	fanions; out	-; mod	D7.WDBRDDUR:	PUSHM.L	D2..D4,A3,A4	PUSH.L	(A6)+ORDV+ORMFAN	LOAD.L	(A6)+ORDV+ORMFAN,D4	LOAD.L	A3,#R16"NIL$	TEST.L	D4:#BRDVRN	; y a-t-il une rptition ?	JUMP',BS 50$		; non => 50$	LOAD.L	A4,#(A6)+OBUDIS+10	CALL	GETANUM		; D4 <-- nombre de rptitions	LOAD.W	D3,D4	JUMP',EQ 50$	LOAD.L	D4,D0		; D4 <-- date initiale20$:	CALL	RDVNEXTREP	; D4 <-- date suivante	DEC.W	D3	JUMP,NE 20$	LOAD.L	A3,#(A6)+OBUDIS+100	LOAD.L	A4,#R16"BEGIN$30$:	LOAD.B	(A3+),(A4+)	JUMP,NE 30$	DEC.L	A3	CALL	DATEDAY	LOAD.B	(A3+),#SPACE	LOAD.L	A4,A3	CALL	DATEMONTH	ADD.B	(A4),#'a-'A	; 1re lettre du mois = minuscule !	LOAD.B	(A3+),#SPACE	CALL	DATEYEAR	LOAD.B	(A3+),#')	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBUDIS+10050$:	LOAD.W	D2,#222!2^BDBGCLABEL	CALL	DBOXAFTEXT	; affiche "jusqu' ..."	POP.L	(A6)+ORDV+ORMFAN	POPM.L	D2..D4,A3,A4	RETNIL$:	.B	0BEGIN$:	.ASCIZ	"(jusqu'au "	.EVEN;---------\\; DBRDSAVE >;---------/; Sauve le rendez-vous dit.; in	-; out	-; mod	D7.WDBRDSAVE:	PUSHM.L	D3,A3,A4	LOAD.L	A3,#(A6)+ORDV	LOAD.L	A4,#(A6)+ORDVLS	LOAD.W	D3,#((ORMTXT+LMTRDV)/2)-120$:	LOAD.W	(A4+),(A3+)	; ORDVLS <-- ORDV	DECJ.W,NMO D3,20$	POPM.L	D3,A3,A4	RET;---------\\; DBRDPREC >;---------/; Reprend le rendez-vous dit prcdemment.; in	-; out	D7.W	erreur; mod	D7.WDBRDPREC:	PUSHM.L	D3,A3,A4	LOAD.W	D7,#1		; D7 <-- impossible	LOAD.L	A3,#(A6)+ORDV	LOAD.L	A4,#(A6)+ORDVLS	TEST.B	(A4)+ORMTXT	; texte existe ?	JUMP',EQ 90$		; non => 90$	LOAD.W	D3,#((ORMTXT+LMTRDV)/2)-120$:	LOAD.W	(A3+),(A4+)	; ORDV <-- ORDVLS	DECJ.W,NMO D3,20$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_RDV:	.W	10$-TDBOX_RDV	.W	20$-TDBOX_RDV	.W	0,010$:	.B	ODBTABX,35+14	.B	ODBLABEL,104	.B	ODBCLINE,(2+2)!2^7,KEYDBOX/H'100,104,TDBOMBRE	.B	ODBCR,ODBCR	.B	ODBLABEL,201	.B	ODBTEXT	.ASCIZ	"Texte :  "	.B	ODBLABEL,100	.B	ODBLINE,LMTRDV!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBCR,ODBCR	.B	ODBLABEL,202	.B	ODBTEXT	.ASCIZ	"   Type :"	.B	ODBTABX,35	.B	ODBLABEL,203	.B	ODBTEXT	.ASCIZ	"   Rptition :"	.B	ODBCR	.B	ODBLCIRCLE,BRDVT1!2^7!2^6,KEYDBOX/H'100,BRDVT1	.ASCIZ	" commentaire"	.B	ODBTABX,20	.B	ODBSQUARE,BRDVEX	.ASCIZ	" excute"	.B	ODBTABX,35	.B	ODBLCIRCLE,BRDVRN!2^7!2^6,KEYDBOX/H'100,BRDVRN	.ASCIZ	" aucune"	.B	ODBTABX,35+28	.B	ODBLABEL,101	.B	ODBXLINE,4,4,2^5,KEYDBOX/H'100,101,TDBOMBRE	.B	ODBTEXT	.ASCIZ	" x"	.B	ODBCR	.B	ODBLCIRCLE,BRDVT2!2^7!2^6,KEYDBOX/H'100,BRDVT2	.ASCIZ	" peu important"	.B	ODBTABX,35	.B	ODBLCIRCLE,BRDVRA!2^7!2^6,KEYDBOX/H'100,BRDVRA	.ASCIZ	" annuelle"	.B	ODBTABX,35+18	.B	ODBLABEL,10	.B	ODBSQUARE,BRDVRX1!2^7,KEYDBOX/H'100,BRDVRX1	.ASCIZ	" lundi"	.B	ODBCR	.B	ODBLCIRCLE,BRDVT3!2^7!2^6,KEYDBOX/H'100,BRDVT3	.ASCIZ	" normal"	.B	ODBTABX,35	.B	ODBLCIRCLE,BRDVRM!2^7!2^6,KEYDBOX/H'100,BRDVRM	.ASCIZ	" mensuelle"	.B	ODBTABX,35+18	.B	ODBSQUARE,BRDVRX2!2^7,KEYDBOX/H'100,BRDVRX2	.ASCIZ	" mardi"	.B	ODBCR	.B	ODBLCIRCLE,BRDVT4!2^7!2^6,KEYDBOX/H'100,BRDVT4	.ASCIZ	" trs important"	.B	ODBTABX,35	.B	ODBLCIRCLE,BRDVRH!2^7!2^6,KEYDBOX/H'100,BRDVRH	.ASCIZ	" hebdomadaire"	.B	ODBTABX,35+18	.B	ODBSQUARE,BRDVRX3!2^7,KEYDBOX/H'100,BRDVRX3	.ASCIZ	" mercredi"	.B	ODBCR	.B	ODBTABX,35	.B	ODBLCIRCLE,BRDVRJ!2^7!2^6,KEYDBOX/H'100,BRDVRJ	.ASCIZ	" journalire"	.B	ODBTABX,35+18	.B	ODBSQUARE,BRDVRX4!2^7,KEYDBOX/H'100,BRDVRX4	.ASCIZ	" jeudi"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"   Sonne "	.B	ODBLABEL,102	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,102,TDBOMBRE	.B	ODBTEXT	.ASCIZ	" minutes avant"	.B	ODBTABX,35+18	.B	ODBSQUARE,BRDVRX5!2^7,KEYDBOX/H'100,BRDVRX5	.ASCIZ	" vendredi"	.B	ODBCR	.B	ODBTABX,35+18	.B	ODBSQUARE,BRDVRX6!2^7,KEYDBOX/H'100,BRDVRX6	.ASCIZ	" samedi"	.B	ODBCR	.B	ODBTABX,35+18	.B	ODBSQUARE,BRDVRX7!2^7,KEYDBOX/H'100,BRDVRX7	.ASCIZ	" dimanche"	.B	ODBCR	.B	ODBLABEL,204	.B	ODBTEXT	.ASCIZ	"Dure :  "	.B	ODBLABEL,103	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,103,TDBOMBRE	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCIRCLE,BRDVUM!2^7!2^6,KEYDBOX/H'100,BRDVUM	.ASCIZ	" minutes"	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCIRCLE,BRDVUH!2^7!2^6,KEYDBOX/H'100,BRDVUH	.ASCIZ	" heures"	.B	ODBTABX,35+8	.B	ODBLABEL,222	.B	ODBTEXT	.ASCIZ	"                            "	.B	ODBCR,ODBCR,ODBCR	.B	ODBLABEL,1	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"         "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBLABEL,2	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	" SUPPRIME "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,DEFINE,TDBNORM	.ASCIZ	" PRECEDENT "	.B	ODBTABX,62	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Cre/Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Supprime"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_RDV:	.W	F1,F2,F3,0		DOKF1-TKEY_RDV	.W	F4,F5,F6,0		DOKF4-TKEY_RDV	.W	END,F0,F13,F14,F15,0	DOKF0-TKEY_RDV	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_RDV	.W	0;---------\\; DBOXLIST >;=========/; Affiche la liste des rendez-vous.; in	-; out	D3.W	dernire touche (F1/F10/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXLIST:	PUSHM.L	D1,D2,D4,D5,A1..A5	LOAD.L	A2,#R16"TDBOX_LIST	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	LOAD.L	A5,#(A6)+OLISLV	; A5 <-- ^variables scroll-list	CLR.W	(A5)+OSLCYSREFAIT$:	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	LOAD.L	D1,D3	LOAD.W	D2,#11!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,D1	SWAP.W	D1	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D1	SWAP.W	D3	LOAD.L	(A5)+OSLDIM,D3	SCROLL_	LDRAW		; dessine la scroll-list vide	LOAD.L	A3,#R16"DBLITXT	LOAD.L	(A5)+OSLADL,A3	LOAD.W	(A5)+OSLCYN,(A6)+ORDVNB	SCROLL_	LUPDATE		; dessine le contenu de la scroll-listLOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_LIST	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ SHOW$	COMP.W	D3,#F4	JUMP,EQ DEL$	COMP.W	D3,#F7	JUMP,EQ OLD$	COMP.W	D3,#F10	JUMP,EQ SAVE$	COMP.W	D3,#F0	JUMP,EQ ANNULE$	LOAD.B	D3,#BIPLITBIP$:	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	SCROLL_	LMOVE		; dplace scroll-list ...	JUMP,NE BIP$	JUMP	LOOP$DEL$:	TEST.W	(A5)+OSLCYN	JUMP,EQ BIP$	LOAD.L	A3,#(A6)+ORDVDP	LOAD.W	D3,(A5)+OSLCYS	MUL.WU	D3,#8	ADD.L	A3,D3	LOAD.L	D4,(A3)		; D4 <-- date du rendez-vous slectionn	CALL	RDVKILL		; supprime le rendez-vous	LOAD.W	D3,(A5)+OSLCYS	INC.W	D3	COMP.W	D3,(A5)+OSLCYN	JUMP,LO REFAIT$	DEC.W	(A5)+OSLCYS	JUMP	REFAIT$OLD$:	TEST.W	(A5)+OSLCYN	JUMP,EQ BIP$	LOAD.L	A3,#(A6)+ORDVDP	LOAD.W	D3,(A5)+OSLCYS	; D3 <-- nb de rendez-vous  supprimer	JUMP,EQ BIP$	CLR.W	(A5)+OSLCYSOLD2$:	LOAD.L	D4,(A3)		; D4 <-- date du premier rendez-vous	ADD.L	A3,#8	INC.W	(A5)+OSLCYS	COMP.B	D4,#HIMAY	JUMP',EQ OLD4$	COMP.B	D4,#HIMAW	JUMP',EQ OLD4$	COMP.B	D4,#HIMAD	JUMP',EQ OLD4$	SUB.L	A3,#8	DEC.W	(A5)+OSLCYS	CALL	RDVKILL		; supprime le rendez-vousOLD4$:	DEC.W	D3	JUMP,NE OLD2$	JUMP	REFAIT$SHOW$:	LOAD.L	A3,#(A6)+ORDVDP	LOAD.W	D3,(A5)+OSLCYS	MUL.WU	D3,#8	ADD.L	A3,D3	LOAD.L	D4,(A3)		; D4 <-- date du rendez-vous slectionn	LOAD.W	(A6)+OTYPE,#ICOYEAR	COMP.B	D4,#HIMAY	JUMP',EQ SHOW2$	LOAD.W	(A6)+OTYPE,#ICOWEEK	COMP.B	D4,#HIMAW	JUMP',EQ SHOW2$	LOAD.W	(A6)+OTYPE,#ICODAYSHOW2$:	LOAD.L	(A6)+ODATE,D4	LOAD.L	(A6)+OHERE,D4	LOAD.W	D3,#F1;	JUMP'	ANNULE$SAVE$:ANNULE$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBLITXT >;--------/; Donne le texte contenu dans la scroll-list.; in	D3.W	rang; out	A3.L	^texte;	D3.W	0=rien, 1=ligne;	D7.W	erreur; mod	D3.L, D7.W, A3.LDBLITXT:	PUSHM.L	D2,D4,A2,A4	LOAD.W	D2,D3	LOAD.L	A3,#(A6)+ORDVDP	MUL.WU	D3,#8	ADD.L	A3,D3	LOAD.L	D4,(A3)		; D4 <-- date	LOAD.L	A4,(A3)+4	; A4 <-- ^rendez-vous	LOAD.L	A2,A3	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D2,#2^BMADUR	CALL	PUTTXTRDV	; OBUDIS <-- date, heure et texte	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^texte	CLR.W	D3		; D3 <-- rien	INC.W	D2	COMP.W	D2,(A6)+ORDVNB	JUMP',HS 90$	LOAD.L	D2,(A2)+8	; D2 <-- date du rendez-vous suivant	CLR.W	D2	CLR.W	D4	COMP.L	D2,D4		; mme mois ?	JUMP',EQ 90$		; oui => 90$	INC.W	D3		; D3 <-- traitill90$:	POPM.L	D2,D4,A2,A4	CLR.W	D7		; D7 <-- ok	RETTDBOX_LIST:	.W	10$-TDBOX_LIST	.W	20$-TDBOX_LIST	.W	0,010$:	.B	ODBLABEL,10	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,72	.B	ODBLABEL,11	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" MONTRE "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	" SUPPRIME UN "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" SUPPRIME ANCIENS "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,F10,TDBMEV	.ASCIZ	" SAUVE "	.B	ODBTABX,62	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Montre"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Supprime un"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Supprime anciens"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_LIST:	.W	CR,F1,F2,F3,0		DOKF1-TKEY_LIST	.W	F4,F5,F6,0		DOKF4-TKEY_LIST	.W	F7,F8,F9,0		DOKF7-TKEY_LIST	.W	F10,F11,F12,0		DOKF10-TKEY_LIST	.W	END,F0,F13,F14,F15,0	DOKF0-TKEY_LIST	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_LIST	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_LIST	.W	0;---------\\; DBOXGOTO >;=========/; Demande o aller.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXGOTO:	PUSHM.L	D0,D1,D2,D4,D5,A1..A4	LOAD.L	D0,(A6)+OHERE	LOAD.L	D4,#B'001	COMP.W	(A6)+OTYPE,#ICOYEAR	JUMP',EQ INIT$	SL.B	D4,#1	COMP.W	(A6)+OTYPE,#ICOWEEK	JUMP',EQ INIT$	SL.B	D4,#1INIT$:	LOAD.L	A2,#R16"TDBOX_GOTO	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$REFAIT$:	CALL	DBGTINV		; inverse la date initiale	CALL	DBGTDAY		; affiche le jour de la semaine	EX.L	D0,D4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	CALL	DATEYEAR	; OBUDIS <-- anne ditable	EX.L	A3,A4		; A3/A4 <-- ^dbut/^fin anne ditable	EX.L	D4,D0LOOP$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_GOTO	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	TEST.W	D3	JUMP,EQ EDIT$	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ GOTO$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#DEFINE	JUMP,EQ TODAY$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ DAY$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX-H'100	JUMP,EQ MONTH$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX-H'200	JUMP,EQ YEAR$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$EDIT$:	PUSHM.L	D4,A4	LOAD.L	A4,A3	CALL	GETANUM	TEST.B	(A4)	JUMP',NE EDIT8$	COMP.W	D4,#1901	JUMP',LO EDIT7$	COMP.W	D4,#2059	JUMP',HS EDIT7$	SUB.W	D4,#1900EDIT3$:	CALL	CONVBA	LOAD.B	D3,D4		; D3 <-- anne en BCD	POPM.L	D4,A4	CALL	DBGTINV		; efface la dernire date	RL.L	D0,#8	LOAD.B	D0,D3	RR.L	D0,#8	CALL	DBGTINV		; allume la nouvelle date	JUMP	LOOP$EDIT7$:	POPM.L	D4,A4	JUMP	LOOP$EDIT8$:	POPM.L	D4,A4	JUMP	BIP$TODAY$:	CALL	DBGTINV		; efface la dernire date	PUSH.L	D4	CALL	DATENOW	LOAD.L	D0,D4		; D0 <-- date du jour	POP.L	D4	JUMP	REFAIT$DAY$:				; jour =>	CALL	DBGTINV		; efface la dernire date	PUSH.L	D4	LOAD.B	D4,D3	CALL	CONVBA	RR.W	D0,#8	LOAD.B	D0,D4	RR.W	D0,#8	POP.L	D4	JUMP'	CHANGE$MONTH$:				; mois =>	CALL	DBGTINV		; efface la dernire date	PUSH.L	D4	LOAD.B	D4,D3	CALL	CONVBA	SWAP.W	D0	LOAD.B	D0,D4	SWAP.W	D0	POP.L	D4	JUMP'	CHANGE$YEAR$:				; anne =>	CALL	DBGTINV		; efface la dernire date	PUSH.L	D4	LOAD.B	D4,D3	ADD.B	D4,#88	CALL	CONVBA	RL.L	D0,#8	LOAD.B	D0,D4	RR.L	D0,#8	POP.L	D4;	JUMP'	CHANGE$CHANGE$:	PUSH.L	D4	LOAD.L	D4,D0	LOAD.W	D2,#F1!2^BDBGCLABEL!2^BDBGCFULL	CALL	CALCNJ	JUMP',EQ CHANGE2$	LOAD.W	D2,#F1!2^BDBGCLABEL!2^BDBGCGREYCHANGE2$:	DBOX_	GETCO		; grise/dgrise la touche (VA)	POP.L	D4	JUMP	REFAIT$GOTO$:				; VA =>	PUSH.L	D4	LOAD.L	D4,D0	CALL	CALCNJ		; date valide ?	POPM.L	D4	JUMP,NE BIP$		; non => BIP$	LOAD.W	(A6)+OTYPE,#ICOYEAR	TEST.L	D4:#0	JUMP',BS TYPE$	LOAD.W	(A6)+OTYPE,#ICOWEEK	TEST.L	D4:#1	JUMP',BS TYPE$	LOAD.W	(A6)+OTYPE,#ICODAYTYPE$:	LOAD.L	(A6)+OHERE,D0	LOAD.L	(A6)+ODATE,D0CANCEL$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0,D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBGTINV >;--------/; Inverse une date.; in	D0.L	date  inverser; out	-; mod	D7.WDBGTINV:	PUSHM.L	D2,D4	LOAD.L	D4,D0	RR.W	D4,#8	CALL	CONVAB	DEC.B	D4	AND.L	D4,#H'FF	DIV.WU	D4,#6	LOAD.L	D2,D4	SWAP.W	D2	MUL.WU	D2,#6+2+2	ADD.W	D2,D4	ADD.W	D2,#4	CALL	DBOXINV		; inverse le jour	LOAD.L	D4,D0	SWAP.W	D4	CALL	CONVAB	DEC.B	D4	AND.L	D4,#H'FF	DIV.WU	D4,#6	LOAD.L	D2,D4	SWAP.W	D2	MUL.WU	D2,#6+2+2	ADD.W	D2,D4	ADD.W	D2,#4+6	CALL	DBOXINV		; inverse le mois	LOAD.L	D4,D0	RL.L	D4,#8	CALL	CONVAB	SUB.B	D4,#88	JUMP',LO 90$	COMP.B	D4,#4+4	JUMP',HS 90$	AND.L	D4,#H'FF	DIV.WU	D4,#4	LOAD.L	D2,D4	SWAP.W	D2	MUL.WU	D2,#6+2+2	ADD.W	D2,D4	ADD.W	D2,#4+6+2	CALL	DBOXINV		; inverse l'anne90$:	POPM.L	D2,D4	RET;--------\\; DBGTDAY >;--------/; Affiche le jour de la semaine.; in	D0.L	date; out	-; mod	D7.WDBGTDAY:	PUSHM.L	D2..D4,A3	LOAD.L	D4,D0	LOAD.L	A3,#(A6)+OBUDIS	CALL	DATEJDLS	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	TEST.B	(A3)	JUMP',EQ 50$	LOAD.B	D3,#'(	LIB	?AFCAR	ADD.B	(A3),#'a-'A	; premire lettre = minuscule !	LIB	?AFTEXT	LIB	?AFTIM	.B	')	.B	MSPACE,3	.B	0	.EVEN	JUMP'	90$50$:	LIB	?AFTIM	.B	MSPACE,1+8+1	.B	0	.EVEN90$:	POPM.L	D2..D4,A3	RETTDBOX_GOTO:	.W	10$-TDBOX_GOTO	.W	20$-TDBOX_GOTO	.W	0,010$:	.B	ODBTEXT	.ASCIZ	" Jour :"	.B	ODBTABX,14	.B	ODBLABEL,1	.B	ODBTEXT,0	.B	ODBTABX,32	.B	ODBTEXT	.ASCIZ	" Mois :"	.B	ODBTABX,32+27	.B	ODBTEXT	.ASCIZ	" Anne :"	.B	ODBCR,ODBCR	.B	ODBBOX,KEYDBOX/H'100,1,TDBNORM	.ASCIZ	" 1"	.B	ODBBOX,KEYDBOX/H'100,7,TDBNORM	.ASCIZ	" 7"	.B	ODBBOX,KEYDBOX/H'100,13,TDBNORM	.ASCIZ	"13"	.B	ODBBOX,KEYDBOX/H'100,19,TDBNORM	.ASCIZ	"19"	.B	ODBBOX,KEYDBOX/H'100,25,TDBNORM	.ASCIZ	"25"	.B	ODBBOX,KEYDBOX/H'100,31,TDBNORM	.ASCIZ	"31"	.B	ODBTABX,32	.B	ODBBOX,(KEYDBOX-H'100)/H'100,1,TDBNORM	.ASCIZ	" JANVIER "	.B	ODBBOX,(KEYDBOX-H'100)/H'100,7,TDBNORM	.ASCIZ	" JUILLET "	.B	ODBTABX,32+27	.B	ODBBOX,(KEYDBOX-H'200)/H'100,0,TDBNORM	.ASCIZ	"1988"	.B	ODBBOX,(KEYDBOX-H'200)/H'100,4,TDBNORM	.ASCIZ	"1992"	.B	ODBCR,ODBCR	.B	ODBBOX,KEYDBOX/H'100,2,TDBNORM	.ASCIZ	" 2"	.B	ODBBOX,KEYDBOX/H'100,8,TDBNORM	.ASCIZ	" 8"	.B	ODBBOX,KEYDBOX/H'100,14,TDBNORM	.ASCIZ	"14"	.B	ODBBOX,KEYDBOX/H'100,20,TDBNORM	.ASCIZ	"20"	.B	ODBBOX,KEYDBOX/H'100,26,TDBNORM	.ASCIZ	"26"	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,32	.B	ODBBOX,(KEYDBOX-H'100)/H'100,2,TDBNORM	.ASCIZ	" FEVRIER "	.B	ODBBOX,(KEYDBOX-H'100)/H'100,8,TDBNORM	.ASCIZ	"  AOUT   "	.B	ODBTABX,32+27	.B	ODBBOX,(KEYDBOX-H'200)/H'100,1,TDBNORM	.ASCIZ	"1989"	.B	ODBBOX,(KEYDBOX-H'200)/H'100,5,TDBNORM	.ASCIZ	"1993"	.B	ODBCR,ODBCR	.B	ODBBOX,KEYDBOX/H'100,3,TDBNORM	.ASCIZ	" 3"	.B	ODBBOX,KEYDBOX/H'100,9,TDBNORM	.ASCIZ	" 9"	.B	ODBBOX,KEYDBOX/H'100,15,TDBNORM	.ASCIZ	"15"	.B	ODBBOX,KEYDBOX/H'100,21,TDBNORM	.ASCIZ	"21"	.B	ODBBOX,KEYDBOX/H'100,27,TDBNORM	.ASCIZ	"27"	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,32	.B	ODBBOX,(KEYDBOX-H'100)/H'100,3,TDBNORM	.ASCIZ	"  MARS   "	.B	ODBBOX,(KEYDBOX-H'100)/H'100,9,TDBNORM	.ASCIZ	"SEPTEMBRE"	.B	ODBTABX,32+27	.B	ODBBOX,(KEYDBOX-H'200)/H'100,2,TDBNORM	.ASCIZ	"1990"	.B	ODBBOX,(KEYDBOX-H'200)/H'100,6,TDBNORM	.ASCIZ	"1994"	.B	ODBCR,ODBCR	.B	ODBBOX,KEYDBOX/H'100,4,TDBNORM	.ASCIZ	" 4"	.B	ODBBOX,KEYDBOX/H'100,10,TDBNORM	.ASCIZ	"10"	.B	ODBBOX,KEYDBOX/H'100,16,TDBNORM	.ASCIZ	"16"	.B	ODBBOX,KEYDBOX/H'100,22,TDBNORM	.ASCIZ	"22"	.B	ODBBOX,KEYDBOX/H'100,28,TDBNORM	.ASCIZ	"28"	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,32	.B	ODBBOX,(KEYDBOX-H'100)/H'100,4,TDBNORM	.ASCIZ	"  AVRIL  "	.B	ODBBOX,(KEYDBOX-H'100)/H'100,10,TDBNORM	.ASCIZ	" OCTOBRE "	.B	ODBTABX,32+27	.B	ODBBOX,(KEYDBOX-H'200)/H'100,3,TDBNORM	.ASCIZ	"1991"	.B	ODBBOX,(KEYDBOX-H'200)/H'100,7,TDBNORM	.ASCIZ	"1995"	.B	ODBCR,ODBCR	.B	ODBBOX,KEYDBOX/H'100,5,TDBNORM	.ASCIZ	" 5"	.B	ODBBOX,KEYDBOX/H'100,11,TDBNORM	.ASCIZ	"11"	.B	ODBBOX,KEYDBOX/H'100,17,TDBNORM	.ASCIZ	"17"	.B	ODBBOX,KEYDBOX/H'100,23,TDBNORM	.ASCIZ	"23"	.B	ODBBOX,KEYDBOX/H'100,29,TDBNORM	.ASCIZ	"29"	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,32	.B	ODBBOX,(KEYDBOX-H'100)/H'100,5,TDBNORM	.ASCIZ	"   MAI   "	.B	ODBBOX,(KEYDBOX-H'100)/H'100,11,TDBNORM	.ASCIZ	"NOVEMBRE "	.B	ODBTABX,32+27+1	.B	ODBTEXT	.ASCIZ	"Autre:"	.B	ODBCR,ODBCR2	.B	ODBTABX,32+27	.B	ODBXLINE,11,4+2,2^(13-8),0,0,TDBNORM	.B	ODBCR2	.B	ODBBOX,KEYDBOX/H'100,6,TDBNORM	.ASCIZ	" 6"	.B	ODBBOX,KEYDBOX/H'100,12,TDBNORM	.ASCIZ	"12"	.B	ODBBOX,KEYDBOX/H'100,18,TDBNORM	.ASCIZ	"18"	.B	ODBBOX,KEYDBOX/H'100,24,TDBNORM	.ASCIZ	"24"	.B	ODBBOX,KEYDBOX/H'100,30,TDBNORM	.ASCIZ	"30"	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,32	.B	ODBBOX,(KEYDBOX-H'100)/H'100,6,TDBNORM	.ASCIZ	"  JUIN   "	.B	ODBBOX,(KEYDBOX-H'100)/H'100,12,TDBNORM	.ASCIZ	"DECEMBRE "	.B	ODBCR,ODBCR	.B	ODBTABX,32+27	.B	ODBBOX,0,DEFINE,TDBOMBRE	.ASCIZ	"AUJOURD'HUI"	.B	ODBCR2	.B	ODBTABX,32	.B	ODBTEXT	.ASCIZ	"Montre une :"	.B	ODBCR2,ODBCR	.B	ODBLABEL,F1	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"   VA   "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,32	.B	ODBLCIRCLE,0	.ASCIZ	" demi-anne"	.B	ODBTABX,32+15	.B	ODBLCIRCLE,1	.ASCIZ	" semaine"	.B	ODBTABX,32+15+12	.B	ODBLCIRCLE,2	.ASCIZ	" journe"	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Va"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_GOTO:	.W	CR,F1,F2,F3,0		DOKF1-TKEY_GOTO	.W	END,F0,F13,F14,F15,0	DOKF0-TKEY_GOTO	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_GOTO	.W	0;---------\\; DBOXINFO >;=========/; Donne quelques informations.; in	-; out	D3.W	dernire touche (F1/F0);	D2.W	nb de couleurs modofies;	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXINFO:	PUSHM.L	D1,D4,D5,A1..A4	LOAD.L	D4,(A6)+OINFO	LOAD.L	D3,D4	AND.L	D3,#H'FFFF0000	JUMP',NE 10$	TSET.L	D4:#BINFCXX10$:	LOAD.L	A2,#R16"TDBOX_INFO	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.B	MAJREV+'0,'.	.IF	MINREV<10	.B	MINREV+'0	.ELSE	.B	(MINREV/10)+'0,(MINREV-((MINREV/10)*10))+'0	.ENDIF	.B	PROREV	.B	0	.EVEN	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Contient "	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+ORDVNB	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" rendez-vous."	.EVEN	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Fichier: "	.EVEN	LOAD.L	A3,#(A6)+OFILNAM	LOAD.W	D2,#2^BAFXMA	; D2 <-- en majuscules	LOAD.W	D3,#35-11	; D3 <-- lg max	LIB	?AFXFILE	LOAD.W	D2,#12!2^BDBGCLABEL	DBOX_	GETCO	PUSH.W	D3	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	CLR.W	D3	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	CLR.L	D4	POP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	LOAD.W	D2,#11!2^BDBGCLABEL	DBOX_	GETCO	CLR.W	D3	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG	CLR.W	D3	PUSH.L	D3	LOAD.W	D2,#12!2^BDBGCLABEL	DBOX_	GETCO	AND.L	D3,#H'FFFF	POP.L	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE EXCOUL$	; oui => EXCOUL$	LOAD.W	D2,#F7!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCOEXCOUL$:	POP.L	D4	CLR.W	D2		; D2 <-- aucune couleur modifie50$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_INFO	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	50$		; oui => 50$	COMP.W	D3,#F1	JUMP,EQ 70$	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#F7	JUMP',EQ COUL$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	50$COUL$:	PUSHM.L	D4,D5,A3,A5	LOAD.L	A3,#R16"NMMEMENTO	LOAD.L	A5,#R16"TCOUL	LOAD.L	D5,(A6)+OIDCRET	LOAD.L	D4,#2^BICMPAL	; D4 <-- mode local	ICOL_	MODCRET		; modifie la CRET ...;	LOAD.L	A2,#R16"TDBOX_INFO	CALL	DBOXRSK		; refait les soft-keys	TEST.W	D7	JUMP',NE COUL8$	LOAD.L	(A6)+OIDCRET,D5	INC.W	D2		; D2 <-- une couleur modifieCOUL8$:	POPM.L	D4,D5,A3,A5	JUMP	50$70$:	LOAD.L	(A6)+OINFO,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_INFO:	.W	10$-TDBOX_INFO	.W	20$-TDBOX_INFO	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"MEMENTO "	.B	ODBLABEL,1	.B	ODBTEXT,0	.B	ODBTABX,35-2	.B	ODBLABEL,12	.B	ODBTEXT,0	.B	ODBTABX,35+3	.B	ODBTEXT	.ASCIZ	"Canton:"	.B	ODBCR	.B	ODBLABEL,2	.B	ODBTEXT,0	.B	ODBTABX,35	.B	ODBLCIRCLE,BINFCBE	.ASCIZ	" Berne"	.B	ODBCR	.B	ODBLABEL,3	.B	ODBTEXT,0	.B	ODBTABX,35	.B	ODBLCIRCLE,BINFCFR	.ASCIZ	" Fribourg"	.B	ODBCR	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBTABX,35	.B	ODBLCIRCLE,BINFCGE	.ASCIZ	" Genve"	.B	ODBCR	.B	ODBSQUARE,BINFQPA	.ASCIZ	" tourne les pages rapidement"	.B	ODBTABX,35	.B	ODBLCIRCLE,BINFCJU	.ASCIZ	" Jura"	.B	ODBCR	.B	ODBSQUARE,BINFMEM	.ASCIZ	" mmorise la dernire case"	.B	ODBTABX,35	.B	ODBLCIRCLE,BINFCNE	.ASCIZ	" Neuchtel"	.B	ODBCR	.B	ODBSQUARE,BINFINV	.ASCIZ	" affichage invers"	.B	ODBTABX,35	.B	ODBLCIRCLE,BINFCVD	.ASCIZ	" Vaud"	.B	ODBCR	.B	ODBTABX,35	.B	ODBLCIRCLE,BINFCVS	.ASCIZ	" Valais"	.B	ODBCR	.B	ODBLABEL,F7	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" COULEURS "	.B	ODBTABX,35	.B	ODBLCIRCLE,BINFCXX	.ASCIZ	" autre ..."	.B	ODBCR	.B	ODBLABEL,11	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Couleurs"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_INFO:	.W	CR,F1,F2,F3,0		DOKF1-TKEY_INFO	.W	F7,F8,F9,0		DOKF7-TKEY_INFO	.W	END,F0,F13,F14,F15,0	DOKF0-TKEY_INFO	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_INFO	.W	0;----------\\; DBOXPSION >;==========/; Echanges avec le PSION.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPSION:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	D4,(A6)+OPSION	LOAD.L	A2,#R16"TDBOX_PSION	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#1!2^BDBGCLABEL	CALL	DBOXLINELOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_PSION	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ OK$	COMP.W	D3,#F0	JUMP',EQ CANCEL$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$KEYDBOX$:	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO MASK$	LOAD.L	D1,#H'FFFF00FFMASK$:	AND.L	D4,D1	TSET.L	D4:D3	JUMP	LOOP$OK$:	LOAD.L	(A6)+OPSION,D4CANCEL$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_PSION:	.W	10$-TDBOX_PSION	.W	20$-TDBOX_PSION	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Echange d'information avec le PSION ORGANISEUR II."	.B	ODBCR	.B	ODBLABEL,1	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBTABX,40	.B	ODBTEXT	.ASCIZ	"Modle :"	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,BPSMEM!2^7!2^6,KEYDBOX/H'100,BPSMEM	.ASCIZ	" mmento en mmoire"	.B	ODBTABX,40	.B	ODBLCIRCLE,BPSXP!2^7!2^6,KEYDBOX/H'100,BPSXP	.ASCIZ	" CM ou XP"	.B	ODBCR	.B	ODBLCIRCLE,BPSFIL!2^7!2^6,KEYDBOX/H'100,BPSFIL	.ASCIZ	" fichier ou procdure sur disque"	.B	ODBTABX,40	.B	ODBLCIRCLE,BPSLZ!2^7!2^6,KEYDBOX/H'100,BPSLZ	.ASCIZ	" LZ ou LZ64"	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" ECHANGE "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Echange"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_PSION:	.W	CR,F1,F2,F3,0		DOKF1-TKEY_PSION	.W	END,F0,F13,F14,F15,0	DOKF0-TKEY_PSION	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_PSION	.W	0;------------\\; DBOXPSIONMM >;============/; Echanges de mmento (agenda) avec le PSION.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPSIONMM:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	D4,(A6)+OPSION	LOAD.L	A2,#R16"TDBOX_PSIONMM	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	LOAD.W	D2,#1!2^BDBGCLABEL	CALL	DBOXLINE	LOAD.W	D2,#2!2^BDBGCLABEL	CALL	DBOXLINE40$:	CALL	DBPSENRE	; affiche ENVOIE/RECOIT50$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_PSIONMM	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	50$		; oui => 50$	COMP.W	D3,#F1	JUMP',EQ 70$	COMP.W	D3,#F0	JUMP',EQ 80$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ 40$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	50$70$:	LOAD.L	(A6)+OPSION,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_PSIONMM:	.W	10$-TDBOX_PSIONMM	.W	20$-TDBOX_PSIONMM	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Echange de mmento avec le PSION ORGANISEUR II."	.B	ODBCR	.B	ODBLABEL,1	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Dmarrez tout d'abord le programme SMAKY sur l'ORGANISEUR,"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	/qui doit alors afficher "Attend SMAKY..."/	.B	ODBCR	.B	ODBLABEL,2	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLCIRCLE,BPSSND!2^7,KEYDBOX/H'100,BPSSND	.ASCIZ	" SMAKY --<'>> ORGANISEUR"	.B	ODBCR	.B	ODBLCIRCLE,BPSRCV!2^7,KEYDBOX/H'100,BPSRCV	.ASCIZ	" SMAKY <'<>-- ORGANISEUR"	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBLABEL,11	.B	ODBSQUARE,BPSFUS	.ASCIZ	" fusionne"	.B	ODBCR,ODBCR,ODBCR	.B	ODBLABEL,F1	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"        "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Envoie/Reoit"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_PSIONMM:	.W	CR,F1,F2,F3,0		DOKF1-TKEY_PSIONMM	.W	END,F0,F13,F14,F15,0	DOKF0-TKEY_PSIONMM	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_PSIONMM	.W	0;------------\\; DBOXPSIONFP >;============/; Echanges de fichier ou de procdures avec le PSION.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPSIONFP:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	D4,(A6)+OPSION	LOAD.L	A2,#R16"TDBOX_PSIONFP	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE 90$	LOAD.W	D2,#1!2^BDBGCLABEL	CALL	DBOXLINE	LOAD.W	D2,#2!2^BDBGCLABEL	CALL	DBOXLINE	LOAD.L	A3,#(A6)+OFILPSI	LOAD.L	A4,A320$:	TEST.B	(A4+)	JUMP,NE 20$	DEC.L	A440$:	CALL	DBPSENRE	; affiche ENVOIE/RECOIT50$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_PSIONFP	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	50$		; oui => 50$	COMP.W	D3,#F1	JUMP',EQ 70$	COMP.W	D3,#F0	JUMP',EQ 80$	COMP.W	D3,#UNDO	JUMP',EQ 60$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ 40$55$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	50$60$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	50$70$:	TEST.B	(A3)		; nom existe ?	JUMP,EQ 55$		; non => 55$	LOAD.L	(A6)+OPSION,D4	LOAD.L	A4,#R16"EXT$	LOAD.W	D3,#1	LIB	?ADDEXT		; force l'extension .PSION	LOAD.W	D3,#F180$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETEXT$:	.ASCIZ	".PSION"	.EVENTDBOX_PSIONFP:	.W	10$-TDBOX_PSIONFP	.W	20$-TDBOX_PSIONFP	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Echange de fichiers ou de procdures avec le PSION ORGANISEUR II."	.B	ODBCR	.B	ODBLABEL,1	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Dmarrez tout d'abord le programme COMMS sur l'ORGANISEUR, puis"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"choisissez TRANSMIT ou RECEIVE, et finalement FILE ou PROCEDURE."	.B	ODBCR	.B	ODBLABEL,2	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLCIRCLE,BPSSND!2^7,KEYDBOX/H'100,BPSSND	.ASCIZ	" SMAKY --<'>> ORGANISEUR  (choisissez RECEIVE sur l'ORGANISEUR)"	.B	ODBCR	.B	ODBLCIRCLE,BPSRCV!2^7,KEYDBOX/H'100,BPSRCV	.ASCIZ	" SMAKY <'<>-- ORGANISEUR  (choisissez TRANSMIT sur l'ORGANISEUR)"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Nom du fichier SMAKY :  "	.B	ODBFILE,32	.B	ODBTEXT	.ASCIZ	" .PSION"	.B	ODBCR,ODBCR,ODBCR	.B	ODBLABEL,F1	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"        "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Envoie/Reoit"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_PSIONFP:	.W	CR,F1,F2,F3,0		DOKF1-TKEY_PSIONFP	.W	END,F0,F13,F14,F15,0	DOKF0-TKEY_PSIONFP	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_PSIONFP	.W	0;---------\\; DBPSENRE >;---------/; Affiche ENVOIE/RECOIT dans le bouton principal.; in	D4.L	fanions; out	-; mod	D7.WDBPSENRE:	PUSHM.L	D1..D4,A3	LOAD.L	A3,#R16"SND$	LOAD.W	D1,#11!2^BDBGCLABEL!2^BDBGCGREY	TEST.L	D4:#BPSSND	JUMP',BS 20$	LOAD.L	A3,#R16"RCV$	LOAD.W	D1,#11!2^BDBGCLABEL!2^BDBGCFULL20$:	LOAD.W	D2,#F1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT	LOAD.W	D2,D1	DBOX_	GETCO		; grise/dgrise "fusionne"	POPM.L	D1..D4,A3	RETSND$:	.ASCIZ	" ENVOIE "RCV$:	.ASCIZ	" RECOIT "	.EVEN;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer le texte.; in	-; out	D7.W	erreur (reste dans edit); mod	D7.WDBOXEFFACE:	PUSHM.L	D1..D4,A2..A5	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	LOAD.L	A5,#(A6)+OFILNAM ; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	CALL	DBOXPREF	; dbox: attend la rponse ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',EQ 90$	LOAD.W	D7,#ERKNO	; D7 <-- rponse "non"90$:	POPM.L	D1..D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande s'il faut quitter.; in	-; out	D4.L	fanions;	D7.W	rponse; mod	D4.L, D7.WDBOXQUITTE:	PUSHM.L	D1..D3,A2..A5	LOAD.L	D4,#B'10	; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A2,#R16"TDBOX_QUITTE	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.L	D3,#2^BDBIOOBJ	CALL	DBOXPREF	; dbox: attend la rponse ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',EQ 90$	LOAD.W	D7,#ERKNO	; D7 <-- rponse "non"90$:	POPM.L	D1..D3,A2..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_QUITTE:	.B	LDBOX_QUITTE	.B	ODBLCIRCLE,0	.ASCIZ	" quitte compltement"	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" quitte en librant la fentre, mais en laissant"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"   une veilleuse pour signaler les rendez-vous"	.B	ODBCRLDBOX_QUITTE	=	.-TDBOX_QUITTE-1	.EVEN;---------\\; DBOXSAVE >;=========/; Sauve le texte d'une zone selon le choix de l'utilisateur.; in	-;	D0.W	mode (0=quitte, 1=nouveau texte); out	D7.W	erreur (reste dans edit); mod	D7.WDBOXSAVE:	PUSHM.L	D1..D4,A2..A5	TEST.B	(A6)+ORDVMJ	; rendez-vous  jour ?	JUMP,EQ	80$		; oui => 80$ (quitte, snif)				; non =>	TEST.W	(A6)+ORDVNB	; y a-t-il des rendez-vous ?	JUMP,EQ 80$		; non => 80$	LOAD.L	D4,(A6)+OFILFAN	; D4 <-- fanions	CLR.L	D3	TEST.B	D0	JUMP',NE 25$	TSET.L	D3:#BDBIOQUIT	; D3 <-- texte "avant de quitter"25$:	LOAD.L	A5,#(A6)+OFILNAM ; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_MAJ	; D1 <-- code du sous-appel	CALL	DBOXPREF	; dbox: attend la rponse ...	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 85$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$	LOAD.L	(A6)+OFILFAN,D4	TSET.B	(A6)+OFILFAN+0:#BDBAUTO-24	CALL	DBOXCREATE	; cre le fichier ...	TCLR.B	(A6)+OFILFAN+0:#BDBAUTO-24	TEST.W	D7	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 85$	LOAD.L	A3,#(A6)+OFILNAM ; A3 <-- ^nom du fichier	CALL	WRMEMENTO	; sauve tout sur disque	JUMP',NE 90$	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente80$:	CLR.W	D7		; D7 <-- quitte EDIT	JUMP'	90$85$:	LOAD.W	D7,#ERKSTO	; D7 <-- reste dans EDIT90$:	POPM.L	D1..D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCREATE >;===========/; Cre un fichier quelconque.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCREATE:	PUSHM.L	D0..D2,D4,D5,A2..A4	TCLR.B	(A6)+OFILFAN+0:#BDBNMAJ-24 ; touche (MET A JOUR) normale	TEST.B	(A6)+ORDVMJ	; rendez-vous  jour ?	JUMP',NE 10$		; non => 10$	TSET.B	(A6)+OFILFAN+0:#BDBNMAJ-24 ; touche (MET A JOUR) grise10$:	CALL	DBOXSAUVE	; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F0	JUMP,EQ	90$	LOAD.W	D1,D3		; D1 <-- F1/F4	LOAD.L	D2,#DEFATT	; D2 <-- attributs par dfaut20$:	LOAD.L	A3,#(A6)+OFILNAM ; A3 <-- ^nom du fichier	LOAD.L	D3,D2		; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP,EQ	70$		; ok => 70$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	TEST.B	(A6)+OFILFAN+0:#BDBAUTO-24 ; mode automatique ?	JUMP',BS 45$		; oui => 45$	COMP.W	D1,#F4		; touche (MET A JOUR) ?	JUMP',EQ 45$		; oui => 45$	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	JUMP',NE 90$	CALL	DBOXCLOSE1	; remet les soft-keys	COMP.W	D3,#'O	JUMP,NE 10$45$:	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D0,#FOS?ARGS	CALL	ERCALL		; demande les arguments du fichier	JUMP',NE 90$	LOAD.L	D2,(A4)+OBAATT	; D2 <-- arguments du fichier	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP',NE 90$	JUMP	20$70$:	LOAD.W	D3,#F1		; D3 <-- (RETURN)	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2,D4,D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCRTEXT >;===========/; Cre un fichier de texte.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCRTEXT:	PUSHM.L	D0..D2,D4,D5,A2..A410$:	CALL	DBOXSVTEXT	; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F0	JUMP,EQ	90$	LOAD.W	D1,D3		; D1 <-- F1/F4	LOAD.L	D2,#DEFATT	; D2 <-- attributs par dfaut20$:	LOAD.L	A3,#(A6)+OFILTXT ; A3 <-- ^nom du fichier	LOAD.L	D3,D2		; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP,EQ	70$		; ok => 70$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	JUMP',NE 90$	CALL	DBOXCLOSE1	; remet les soft-keys	COMP.W	D3,#'O	JUMP,NE 10$	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D0,#FOS?ARGS	CALL	ERCALL		; demande les arguments du fichier	JUMP',NE 90$	LOAD.L	D2,(A4)+OBAATT	; D2 <-- arguments du fichier	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP',NE 90$	JUMP	20$70$:	LOAD.W	D3,#F1		; D3 <-- (RETURN)	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2,D4,D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXPREND >;==========/; Edite un nom de fichier en entre.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPREND:	PUSHM.L	D1,D2,D4,A2..A5	LOAD.L	D4,(A6)+OFILFAN	; D4 <-- fanions	LOAD.L	A5,#(A6)+OFILNAM ; A5 <-- ^nom du fichier	LOAD.L	A4,#R16"TDBOX_EXT	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1	CALL	DBOXPREF	; dbox: attend la rponse ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	LOAD.L	(A6)+OFILFAN,D490$:	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXSAUVE >;==========/; Edite un nom de fichier en sortie.; in	-; out	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXSAUVE:	PUSHM.L	D1,D2,D4,A2..A5	LOAD.L	D4,(A6)+OFILFAN	; D4 <-- fanions	LOAD.L	A5,#(A6)+OFILNAM ; A5 <-- ^nom du fichier	TEST.B	(A5)		; nom existe ?	JUMP',EQ 20$		; non => 20$				; oui =>	CLR.W	D7	LOAD.W	D3,#F1		; D3 <-- comme si (SAUVE)	TEST.L	D4:#BDBAUTO	; mode automatique ?	JUMP',BS 90$		; oui => 90$20$:	LOAD.L	A4,#R16"TDBOX_EXT	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1	TEST.L	D4:#BDBNMAJ	JUMP',BC 40$	TSET.L	D3:#BDBIONMAJ	; D3 <-- touche (MET A JOUR) grise40$:	CALL	DBOXPREF	; dbox: attend la rponse ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',EQ 80$	COMP.W	D3,#F4	JUMP',NE 90$80$:	LOAD.L	(A6)+OFILFAN,D490$:	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXIMAGE >;==========/; Edite un nom d'image en entre.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXIMAGE:	PUSHM.L	D1,D2,D4,A2..A5	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,#(A6)+OFILIMA ; A5 <-- ^nom de l'image	LOAD.L	A4,#R16"TDBOX_EXTIM	LOAD.L	A3,#R16"TDBOX_IOIM	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1	CALL	DBOXPREF	; dbox: attend la rponse ...	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXSVTEXT >;===========/; Edite un nom de texte en sortie.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXSVTEXT:	PUSHM.L	D1,D2,D4,A2..A5	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,#(A6)+OFILTXT ; A5 <-- ^nom du texte	LOAD.L	A4,#R16"TDBOX_EXTTX	LOAD.L	A3,#R16"TDBOX_IOTX	LOAD.W	D1,#DBOX_EXTRAIT ; D1 <-- code du sous-appel	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1!2^BDBIOFULL	CALL	DBOXPREF	; dbox: attend la rponse ...	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXERROR >;==========/; Affiche une erreur.; in	D7.W	erreur; out	D7.W	erreur; mod	D7.WDBOXERROR:	PUSHM.L	D2..D4,A3	LOAD.W	D4,D7	JUMP',EQ 20$	COMP.W	D7,#ERKNO	JUMP',EQ 20$	COMP.W	D7,#ERKSTO	JUMP',NE 30$20$:	CLR.W	D7		; D7 <-- ok	JUMP'	90$30$:	CALL	DBOXOPEN1	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	CALL	DBERTEXT	; A3 <-- ^message interne  PLUME	JUMP',EQ 50$	LOAD.W	D7,D4		; D7 <-- code de l'erreur	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur "externe" ...	JUMP'	80$50$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur "interne" ...80$:	CALL	DBOXCLOSE1	; remet les soft-keys90$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBERTEXT >;---------/; Donne le texte d'une erreur interne  PLUME.; in	D4.W	erreur; out	A3.L	^message d'erreur;	D7.W	erreur; mod	D7.W, A3.LDBERTEXT:	PUSH.L	D3	LOAD.W	D7,#1		; D7 <-- pas trouv	LOAD.W	D3,D4	SR.W	D3,#8	COMP.B	D3,#ERMEMENTO/H'100 ; erreur interne  MEMENTO ?	JUMP',EQ 10$	COMP.B	D3,#ERSMAKY/H'100	JUMP',EQ 10$	COMP.B	D3,#ERPSION/H'100	JUMP',NE 90$		; non => 90$10$:	LOAD.L	A3,#R16"TABLE$20$:	TEST.W	(A3+)		; fin de la table ?	JUMP',EQ 80$		; oui => 80$	COMP.W	D4,(A3)-2	; erreur trouve ?	JUMP',EQ 80$		; oui => 80$30$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE	30$	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- saute comme .EVEN	LOAD.L	A3,D3	JUMP	20$80$:	CLR.W	D7		; D7 <-- trouv90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	ERMMDAT	.ASCIZ	"Date incorrecte !"	.EVEN	.W	ERMMRPL	.ASCIZ	"Trop de rendez-vous !"	.EVEN	.W	ERMMRPT	.ASCII	"Il n'y a plus de rendez-vous<CR>"	.ASCIZ	"dans cette direction !"	.EVEN	.W	ERMMREX	.ASCII	"La rptition ne s'est pas effectue cor-<CR>"	.ASCII	"rectement jusqu'au bout, car il y a eu une<CR>"	.ASCIZ	"collision avec un rendez-vous existant !"	.EVEN	.W	ERMMREV	.ASCIZ	"Rvision incompatible !"	.EVEN	.W	ERMMIMG	.ASCIZ	"Image trop grande !"	.EVEN	.W	ERPREP	.ASCII	"Problme avec l'ORGANISEUR :<CR>"	.ASCIZ	"contenu de la rponse incorrect !"	.EVEN	.W	ERPCHK	.ASCII	"Problme avec l'ORGANISEUR :<CR>"	.ASCIZ	"somme de contrle incorrecte !"	.EVEN	.W	ERPDIG	.ASCII	"Problme avec l'ORGANISEUR :<CR>"	.ASCIZ	"digit incorrect !"	.EVEN	.W	ERPTIM	.ASCII	"L'ORGANISEUR n'est pas<CR>"	.ASCIZ	"connect correctement !"	.EVEN	.W	ERPMEM	.ASCII	"Il ne reste pas assez de mmoire<CR>"	.ASCIZ	"libre dans l'ORGANISEUR !"	.EVEN	.W	ERPOPI	.ASCIZ	"Ordre inconnu reu par l'ORGANISEUR !<CR>"	.EVEN	.W	0	.ASCIZ	"Erreur avec le logiciel MEMENTO !"	.EVEN;---------\\; DBOXPREF >;---------/; Travaille dans une DBOX prfabrique.; in	voir DBOX_EXTEND; out	idem; mod	idemDBOXPREF:	PUSH.W	D2	CALL	DBOXOPEN1	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	DBOX_	EXTEND		; travaille dans la DBOX ...	CALL	DBOXCLOSE1	POP.W	D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXOPEN >;---------/; Ouvre une DBOX.; in	voir DBOX_OPEN; out	idem; mod	idemDBOXOPEN:	CALL	DBOXOPEN1	DBOX_	OPEN		; ouvre la DBOX	TEST.W	D7		; retour EQ/NE	RETDBOXOPEN1:	PUSH.W	D3	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	NORMMOUSE	; souris: plus de sablier	CLR.W	D3	CALL	SELMO		; souris: met une flche	POP.W	D3	RET;----------\\; DBOXCLOSE >;----------/; Ferme une DBOX.; in	voir DBOX_CLOSE; out	idem; mod	idemDBOXCLOSE:	DBOX_	CLOSE		; ferme la DBOXDBOXCLOSE1:	PUSH.W	D7	CALL	AFMENU		; remet les soft-keys	POP.W	D7	RET;--------\\; DBOXRSK >;========/; Refait les soft-keys.; in	A2.L	^table DBOX; out	-; mod	-DBOXRSK:	PUSHM.L	D3,D7,A3	LOAD.W	D3,(A2)+2	LOAD.L	A3,#(A2)+(D3.W)	LIB	?AFMENU		; refait les soft-keys	POPM.L	D3,D7,A3	RET;-----------\\; DBOXAFTEXT >;===========/; Affiche un texte dans une dbox (dans un ODBBOX).; in	D2.W	rang;	A3.L	^texte; out	-; mod	D7.WDBOXAFTEXT:	PUSHM.L	D2..D4,A3,A4	DBOX_	GETCO	LIB	?SETCURS	; positionne le curseur au dbut	SUB.W	D4,D3	AND.L	D4,#H'FFFF	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb de caractres  afficher	LOAD.L	A4,A3	LOAD.W	D3,#-120$:	INC.W	D3		; D3 <-- nb de caractres du nom	TEST.B	(A4+)	JUMP,NE 20$	COMP.W	D3,D4		; place pour tout afficher ?	JUMP',LS 50$		; oui => 50$				; non =>	LIB	?AFTIM		; affiche flche "<-" inverse	.B	AFINV,AFTOUT,5,AFNORM,AFDIR,0	.EVEN	DEC.W	D4	SUB.W	D3,D4	ADD.W	A3,D3	LOAD.W	D3,D4	LIB	?STRING		; affiche la fin du nom	LIB	?AFSPACE	JUMP'	90$50$:	LIB	?STRING		; affiche le nom	SUB.W	D4,D3	JUMP',EQ 90$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin90$:	POPM.L	D2..D4,A3,A4	RET;---------\\; DBOXLINE >;=========/; Trace une ligne horizontale  travers toute la dbox.; in	D2.W	rang; out	-; mod	D7.WDBOXLINE:	PUSHM.L	D2..D4	DBOX_	GETCO	CLR.W	D3	SWAP.W	D3	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2..D4	RET;--------\\; DBOXINV >;========/; Inverse un objet ODBBOX.; in	D2.W	rang; out	-; mod	D7.WDBOXINV:	PUSHM.L	D2..D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	DBOX_	GETCO	JUMP',NE 90$	LOAD.W	D2,(A0)+ODFCX	SR.W	D2,#1	SUB.W	D4,D3	ADD.W	D4,D2	ADD.W	D4,D2	ADD.W	D4,#3	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC2Y	ADD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#7	SWAP.W	D4	SUB.W	D3,D2	DEC.W	D3	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#3	SWAP.W	D3	LOAD.W	D2,#INVDOT	LIB	?DRTRAME90$:	POPM.L	D2..D4	RET;-----------\\; DBOXOPWAIT >;===========/; Met la dbox d'attente.; in	-; out	D7.W	erreur; mod	D7.WDBOXOPWAIT:	PUSHM.L	D1,D2,D5	CALL	WAITMOUSE	; souris: met le sablier	CLR.W	D7		; D7 <-- ok	TEST.L	(A6)+OWAITCH	; dbox dj l ?	JUMP',NE 90$		; oui => 90$	LOAD.W	D1,#DBOX_OPWAIT	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_OPWAIT	JUMP',NE 90$	LOAD.L	(A6)+OWAITCH,D590$:	POPM.L	D1,D2,D5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCLWAIT >;===========/; Enlve la dbox d'attente.; in	-; out	-; mod	-DBOXCLWAIT:	PUSHM.L	D1,D2,D5,D7	LOAD.L	D5,(A6)+OWAITCH	JUMP',EQ 90$	LOAD.W	D1,#DBOX_CLWAIT	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_CLWAIT	CALL	AFMENU		; remet les soft-keys	CLR.L	(A6)+OWAITCH90$:	POPM.L	D1,D2,D5,D7	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs LIB,?EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>90$:	POP.L	A3	RET;--------\\; DOK...  >;========/DOKOUI:	LOAD.W	D3,#'O	RETDOKNON:	LOAD.W	D3,#'N	RETDOKOK:	LOAD.W	D3,#CR	RETDOKDEF:	LOAD.W	D3,#DEFINE	RETDOKANNULE:	LOAD.W	D3,#END	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RETTDBOX_EXT:	.ASCIZ	".MEMENTO"	; extension des fichiersTDBOX_EXTIM:	.ASCIZ	".IMAGE"	; extension des fichiersTDBOX_EXTTX:	.ASCIZ	".TEXT"		; extension des fichiersTDBOX_IO:	.ASCIZ	"MEMENTO"	; nom du logiciel	.ASCIZ	"Mmmento"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0TDBOX_IOIM:	.ASCIZ	"MEMENTO"	; nom du logiciel	.ASCIZ	"Fimage"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0TDBOX_IOTX:	.ASCIZ	"MEMENTO"	; nom du logiciel	.ASCIZ	"Mtexte"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN	.END