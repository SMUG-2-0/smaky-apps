	.SBTTL	MEMFETE; Le calcul des phases de la lune tient compte d'une premire pleine lune; le 14.1.1900  20h49 (*), puis d'une priode constante de 29 jours 12 heures; et 44 minutes. On ne tient pas compte des anomalies du soleil et de la lune,; ce qui induit une erreur de +/- un jour !; (*)	ATTENTION: dans tous les calculs de MEMENTO, on considre l'anne 1900;	comme bissextile, ce qui est faux (mais qui donc verra que les dates;	comprises entre le 1.1.1900 et le 29.2.1900 sont fausses) !LUNEM	= 60				; nb de minutes / heureLUNEJ	= 24*LUNEM			; nb de minutes / jourLUNEPH	= (29*LUNEJ)+(12*LUNEM)+44	; dure d'une phase complte (29j 12h 44m)LUNE1	= (14*LUNEJ)+(20*LUNEM)+49	; premire pleine lune (14.1.1900  20h49);---------\\; FETELUNE >;=========/; Cherche si une lunaison correspond  la date spcifie.; in	D4.L	anne-mois-jour-heure en BCD; out	D3.B	icne de lune  afficher;	D7.W	erreur; mod	D3.L, D7.WFETELUNE:	PUSH.L	D4	CALL	CALCNJ		; D4 <-- nombre de jours depuis 1.1.1900	MUL.WU	D4,#LUNEJ	; D4 <-- nombre de minutes depuis 1.1.1900	SUB.L	D4,#LUNE1	; D4 <-- idem depuis premire nouvelle lune	DIV.WU	D4,#LUNEPH	SWAP.W	D4	CLR.W	D7	LOAD.B	D3,#ICOPL	; D3 <-- pleine lune	COMP.W	D4,#LUNEJ	JUMP',LO 90$	LOAD.B	D3,#ICODQ	; D3 <-- dernier quartier	COMP.W	D4,#LUNEPH/4	JUMP',LO 80$	COMP.W	D4,#LUNEPH/4+LUNEJ	JUMP',LO 90$	LOAD.B	D3,#ICONL	; D3 <-- nouvelle lune	COMP.W	D4,#LUNEPH/2	JUMP',LO 80$	COMP.W	D4,#LUNEPH/2+LUNEJ	JUMP',LO 90$	LOAD.B	D3,#ICOPQ	; D3 <-- premier quartier	COMP.W	D4,#LUNEPH/4*3	JUMP',LO 80$	COMP.W	D4,#LUNEPH/4*3+LUNEJ	JUMP',LO 90$80$:	LOAD.W	D7,#190$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; FETETEXT >;=========/; Cherche si une fte correspond  la date spcifie.; in	D4.L	anne-mois-jour-heure en BCD; out	A3.L	^nom de la fte (ou des ftes !);	D3.W	nombre de caractres;	D7.W	erreur; mod	D3.L, D7.W, A3.LFETETEXT:	PUSHM.L	D1,D2,D4,D5,A4,A5	LOAD.L	D5,D4		; D5 <-- anne-mois-jour-heure en BCD	LOAD.L	D3,(A6)+OINFO	; D3 <-- informations	LOAD.L	A5,#R16"TBE$-6	TEST.L	D3:#BINFCBE	JUMP',BS 10$	LOAD.L	A5,#R16"TFR$-6	TEST.L	D3:#BINFCFR	JUMP',BS 10$	LOAD.L	A5,#R16"TGE$-6	TEST.L	D3:#BINFCGE	JUMP',BS 10$	LOAD.L	A5,#R16"TJU$-6	TEST.L	D3:#BINFCJU	JUMP',BS 10$	LOAD.L	A5,#R16"TNE$-6	TEST.L	D3:#BINFCNE	JUMP',BS 10$	LOAD.L	A5,#R16"TVD$-6	TEST.L	D3:#BINFCVD	JUMP',BS 10$	LOAD.L	A5,#R16"TVS$-6	TEST.L	D3:#BINFCVS	JUMP',BS 10$	LOAD.L	A5,#R16"TXX$-610$:	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^buffer	LOAD.L	D4,D5	CALL	CALCNJ		; D4 <-- date actuelle (en jours)	LOAD.L	D2,D4		; D2 <-- date actuelle (en jours)	LOAD.L	D4,D5	CALL	FETEPAQUES	; D4 <-- date de Pques	CALL	CALCNJ		; D4 <-- date de Pques (en jours)	LOAD.L	D1,D4		; D1 <-- date de Pques (en jours)20$:	ADD.L	A5,#6		; A5 <-- ^fte suivante	LOAD.W	D3,(A5)		; fin de la table ?	JUMP,NS 70$		; oui => 70$	COMP.W	D3,#1	JUMP,EQ 40$	COMP.W	D3,#2	JUMP,EQ 50$				; date fixe =>	LOAD.L	D4,D5	SR.L	D4,#8		; D4 <-- mois-jour	COMP.W	D4,(A5)+2	JUMP,NE 20$	JUMP	60$40$:				; date spciale =>	LOAD.W	D3,(A5)+4	COMP.W	D3,#FMERE$	JUMP',EQ 42$	COMP.W	D3,#JEUNE$	JUMP',EQ 43$	COMP.W	D3,#JLUND$	JUMP',EQ 44$	COMP.W	D3,#JEUNG$	JUMP',EQ 45$	JUMP	20$42$:	LOAD.L	D4,D5	CALL	FETEMERE	; D4 <-- date de la Fte des mres	COMP.L	D4,D5	JUMP,NE 20$	JUMP'	60$43$:	LOAD.L	D4,D5	CALL	FETEJEUNE	; D4 <-- date du Jene fdral	COMP.L	D4,D5	JUMP,NE 20$	JUMP'	60$44$:	LOAD.L	D4,D5	CALL	FETEJEUNE	; D4 <-- date du Jene fdral	CALL	DATENEXTDAY	; D4 <-- idem, mais +1 jour	COMP.L	D4,D5	JUMP,NE 20$	JUMP'	60$45$:	LOAD.L	D4,D5	CALL	FETEJEUNG	; D4 <-- date du Jene genevois	COMP.L	D4,D5	JUMP,NE 20$	JUMP'	60$50$:				; date selon Pques =>	LOAD.W	D3,(A5)+2	; D3 <-- +/- nb de jour par rapport  Pques	CONV.LA.WA D3	ADD.L	D3,D1	COMP.L	D3,D2	JUMP,NE 20$;	JUMP'	60$60$:	LOAD.L	A3,#R16"ADCODE	CLR.L	D3	LOAD.W	D3,(A5)+4	ADD.L	A3,D3	CALL	FETEPUTT	; buffer <-- texte de la fte	JUMP	20$70$:	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	D3,A4	SUB.L	D3,A3		; D3 <-- nb de caractres	LOAD.W	D7,#1		; D7 <-- ce n'est pas une fte !	TEST.W	D3	JUMP',EQ 90$	CLR.W	D7		; D7 <-- youpie, c'est la fte90$:	POPM.L	D1,D2,D4,D5,A4,A5	TEST.W	D7		; retour EQ/NE	RETTBE$:	.W	0,H'0101,D0101$	.W	0,H'0102,D0102$	.W	0,H'0801,D0801$	.W	0,H'1225,D1225$	.W	0,H'1226,D1226$	.W	1,0,FMERE$	.W	1,0,JEUNE$	.W	2,-7,RAMEA$	.W	2,-2,VENDR$	.W	2,+0,PAQUE$	.W	2,+1,LUNDI$	.W	2,+39,ASCEN$	.W	2,+49,PENTE$	.W	2,+50,PLUND$	.W	-1TFR$:	.W	0,H'0101,D0101$	.W	0,H'0102,D0102$	.W	0,H'0801,D0801$	.W	0,H'0815,D0815$	.W	0,H'1101,D1101$	.W	0,H'1208,D1208$	.W	0,H'1225,D1225$	.W	1,0,FMERE$	.W	1,0,JEUNE$	.W	2,-7,RAMEA$	.W	2,-2,VENDR$	.W	2,+0,PAQUE$	.W	2,+1,LUNDI$	.W	2,+39,ASCEN$	.W	2,+49,PENTE$	.W	2,+50,PLUND$	.W	2,+60,FDIEU$	.W	-1TGE$:	.W	0,H'0101,D0101$	.W	0,H'0801,D0801$	.W	0,H'1225,D1225$	.W	0,H'1226,D1226$	.W	0,H'1231,E1231$	.W	1,0,FMERE$	.W	1,0,JEUNE$	.W	1,0,JEUNG$	.W	2,-7,RAMEA$	.W	2,-2,VENDR$	.W	2,+0,PAQUE$	.W	2,+1,LUNDI$	.W	2,+39,ASCEN$	.W	2,+49,PENTE$	.W	2,+50,PLUND$	.W	-1TJU$:	.W	0,H'0101,D0101$	.W	0,H'0102,D0102$	.W	0,H'0501,E0501$	.W	0,H'0623,D0623$	.W	0,H'0801,D0801$	.W	0,H'0815,D0815$	.W	0,H'1101,D1101$	.W	0,H'1225,D1225$	.W	0,H'1226,D1226$	.W	1,0,FMERE$	.W	1,0,JEUNE$	.W	2,-7,RAMEA$	.W	2,-2,VENDR$	.W	2,+0,PAQUE$	.W	2,+1,LUNDI$	.W	2,+39,ASCEN$	.W	2,+49,PENTE$	.W	2,+50,PLUND$	.W	2,+60,FDIEU$	.W	-1TNE$:	.W	0,H'0101,D0101$	.W	0,H'0102,D0102$	.W	0,H'0301,D0301$	.W	0,H'0801,D0801$	.W	0,H'1225,D1225$	.W	0,H'1226,D1226$	.W	1,0,FMERE$	.W	1,0,JEUNE$	.W	1,0,JLUND$	.W	2,-7,RAMEA$	.W	2,-2,VENDR$	.W	2,+0,PAQUE$	.W	2,+1,LUNDI$	.W	2,+39,ASCEN$	.W	2,+49,PENTE$	.W	2,+50,PLUND$	.W	-1TVD$:	.W	0,H'0101,D0101$	.W	0,H'0102,D0102$	.W	0,H'0801,D0801$	.W	0,H'1225,D1225$	.W	1,0,FMERE$	.W	1,0,JEUNE$	.W	1,0,JLUND$	.W	2,-7,RAMEA$	.W	2,-2,VENDR$	.W	2,+0,PAQUE$	.W	2,+1,LUNDI$	.W	2,+39,ASCEN$	.W	2,+49,PENTE$	.W	2,+50,PLUND$	.W	-1TVS$:	.W	0,H'0101,D0101$	.W	0,H'0319,D0319$	.W	0,H'0801,D0801$	.W	0,H'0815,D0815$	.W	0,H'1101,D1101$	.W	0,H'1208,D1208$	.W	0,H'1225,D1225$	.W	1,0,FMERE$	.W	1,0,JEUNE$	.W	2,-7,RAMEA$	.W	2,+0,PAQUE$	.W	2,+1,LUNDI$	.W	2,+39,ASCEN$	.W	2,+49,PENTE$	.W	2,+50,PLUND$	.W	2,+60,FDIEU$	.W	-1TXX$:	.W	0,H'0101,D0101$	.W	0,H'0801,D0801$	.W	0,H'1225,D1225$	.W	1,0,FMERE$	.W	1,0,JEUNE$	.W	2,-7,RAMEA$	.W	2,-2,VENDR$	.W	2,+0,PAQUE$	.W	2,+1,LUNDI$	.W	2,+39,ASCEN$	.W	2,+49,PENTE$	.W	2,+50,PLUND$	.W	-1D0101$:	.ASCIZ	"Nouvel an"D0102$:	.ASCIZ	"Fri"D0301$:	.ASCIZ	"Fte de la Rpublique"D0319$:	.ASCIZ	"Saint Joseph"E0501$:	.ASCIZ	"Fte du 1er mai"D0623$:	.ASCIZ	"Fte de l'Indpendance"D0801$:	.ASCIZ	"Fte nationale"D0815$:	.ASCIZ	"Assomption"D1101$:	.ASCIZ	"Toussaint"D1208$:	.ASCIZ	"Immacule Conception"D1225$:	.ASCIZ	"Nol"D1226$:	.ASCIZ	"Saint Etienne"E1231$:	.ASCIZ	"Anniversaire Restauration"FMERE$:	.ASCIZ	"Fte des mres"JEUNE$:	.ASCIZ	"Jene fdral"JLUND$:	.ASCIZ	"Lundi du jene"JEUNG$:	.ASCIZ	"Jene genevois"RAMEA$:	.ASCIZ	"Rameaux"VENDR$:	.ASCIZ	"Vendredi saint"PAQUE$:	.ASCIZ	"Pques"LUNDI$:	.ASCIZ	"Lundi de Pques"ASCEN$:	.ASCIZ	"Ascension"PENTE$:	.ASCIZ	"Pentecte"PLUND$:	.ASCIZ	"Lundi de Pentecte"FDIEU$:	.ASCIZ	"Fte-Dieu"	.EVEN;---------\\; FETEPUTT >;---------/; Met un nom de fte dans le buffer.; in	A3.L	^texte;	A4.L	^buffer; out	A4.L	^plus loin; mod	D7.W, A4.LFETEPUTT:	PUSHM.L	A2,A3	LOAD.L	A2,#(A6)+OBUDIS	COMP.L	A4,A2		; est-on au dbut du buffer ?	JUMP',EQ 20$		; oui => 20$	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'/	LOAD.B	(A4+),#SPACE20$:	LOAD.B	(A4+),(A3+)	JUMP,NE 20$	DEC.L	A4	POPM.L	A2,A3	RET;---------\\; FETEMERE >;---------/; Cherche la date de la "fte des mres" pour une anne donne.; Rgle :; Deuxime dimanche de mai.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.LFETEMERE:	PUSH.L	D3	AND.L	D4,#H'FF000000	; D4 <-- conserve l'anne	OR.L	D4,#H'00050100	; D4 <-- force le 1.5.xx	CALL	CALCNJ		; D4 <-- nb de jours	LOAD.L	D3,D4	CALL	CALCJS		; D4 <-- jour de la semaine (1..7)	ADD.L	D3,#7*2	SUB.L	D3,D4	LOAD.L	D4,D3	CALL	CALCJN		; D4 <-- date en BCD	POP.L	D3	RET;----------\\; FETEJEUNE >;----------/; Cherche la date du "Jene fdral" pour une anne donne.; Rgle :; Troisime dimanche de septembre.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.LFETEJEUNE:	PUSH.L	D3	AND.L	D4,#H'FF000000	; D4 <-- conserve l'anne	OR.L	D4,#H'00090100	; D4 <-- force le 1.9.xx	CALL	CALCNJ		; D4 <-- nb de jours	LOAD.L	D3,D4	CALL	CALCJS		; D4 <-- jour de la semaine (1..7)	ADD.L	D3,#7*3	SUB.L	D3,D4	LOAD.L	D4,D3	CALL	CALCJN		; D4 <-- date en BCD	POP.L	D3	RET;----------\\; FETEJEUNG >;----------/; Cherche la date du "Jene genevois" pour une anne donne.; Rgle :; Premier jeudi de septembre.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.LFETEJEUNG:	PUSH.L	D3	AND.L	D4,#H'FF000000	; D4 <-- conserve l'anne	OR.L	D4,#H'00090100	; D4 <-- force le 1.9.xx	CALL	CALCNJ		; D4 <-- nb de jours	LOAD.L	D3,D4	CALL	CALCJS		; D4 <-- jour de la semaine (1..7)	ADD.L	D3,#4	COMP.W	D4,#4	JUMP',LS 50$	ADD.L	D3,#750$:	SUB.L	D3,D4	LOAD.L	D4,D3	CALL	CALCJN		; D4 <-- date en BCD	POP.L	D3	RET;-----------\\; FETEPAQUES >;-----------/; Cherche la date de "Pques" pour une anne donne.; Rgle :; Premier dimanche aprs la pleine lune qui a lieu soit; le jour de l'quinoxe de printemps (21 mars), soit; aussitt aprs cette date. Si la pleine lune tombe le; 20 mars, la suivante sera le 18 avril (29 jours aprs).; Si ce jour est un dimanche, Pques sera le 25 avril.; Ainsi, la fte de Pques oscille entre le 22 mars et; le 25 avril, et de sa date dpendent celles des autres; ftes mobiles :; Les Rameaux   -->  7 jours avant Pques; L'Ascension   -->  40 jours aprs Pques; La Pentecte  -->  10 jours aprs l'Ascension; Algorithme utilis :;;	J = anne (1988, 2003, etc.);	A = J MOD 19;	B = J MOD 4;	C = J MOD 7;	T = (19*A)+24;	D = T MOD 30;	T = (2*B)+(4*C)+(6*D)+5;	E = T MOD 7; 	F = D+E-9;	SI F<=0 THEN --> F+31 MARS;	SI F=26 THEN --> 19 AVRIL;	SI F=25 ET D=28 THEN --> 18 AVRIL;	SINON --> F AVRIL;; Avec :;;	D0.W	<-->	J;	D1.W	<-->	A;	D2.W	<-->	B;	D3.W	<-->	C;	D4.W	<-->	D;	D5.W	<-->	E;	D6.W	<-->	F;	D7.W	<-->	T; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.LFETEPAQUES:	PUSHM.L	D0..D3,D5..D7	PUSH.L	D4	RL.L	D4,#8	CALL	CONVAB		; A4 <-- anne en binaire (0..n)	AND.W	D4,#H'00FF	ADD.W	D4,#1900	LOAD.W	D0,D4		; J <-- anne	CLR.L	D1	LOAD.W	D1,D0	DIV.WU	D1,#19	SWAP.W	D1		; A <-- J MOD 19	CLR.L	D2	LOAD.W	D2,D0	DIV.WU	D2,#4	SWAP.W	D2		; B <-- J MOD 4	CLR.L	D3	LOAD.W	D3,D0	DIV.WU	D3,#7	SWAP.W	D3		; C <-- J MOD 7	LOAD.W	D7,D1	MUL.WU	D7,#19	ADD.W	D7,#24		; T <-- (A*19)+24	CLR.L	D4	LOAD.W	D4,D7	DIV.WU	D4,#30	SWAP.W	D4		; D <-- T MOD 30	LOAD.W	D7,#5	LOAD.W	D5,D2	MUL.WU	D5,#2	ADD.W	D7,D5	LOAD.W	D5,D3	MUL.WU	D5,#4	ADD.W	D7,D5	LOAD.W	D5,D4	MUL.WU	D5,#6	ADD.W	D7,D5		; T <-- 5+(2*B)+(4*C)+(6*D)	CLR.L	D5	LOAD.W	D5,D7	DIV.WU	D5,#7	SWAP.W	D5		; E <-- T MOD 7	LOAD.W	D6,D4	ADD.W	D6,D5	SUB.W	D6,#9		; F <-- D+E-9	JUMP',GT 30$	ADD.W	D6,#31		; D6 <-- jour	LOAD.B	D7,#H'03	; D7 <-- mois (mars)	JUMP'	50$30$:	COMP.W	D6,#26	JUMP',NE 32$	LOAD.W	D6,#19		; D6 <-- jour (19)	LOAD.B	D7,#H'04	; D7 <-- mois (avril)	JUMP'	50$32$:	COMP.W	D6,#25	JUMP',NE 34$	COMP.W	D4,#28	JUMP',NE 34$	LOAD.W	D6,#18		; D6 <-- jour (18)	LOAD.B	D7,#H'04	; D7 <-- mois (avril)	JUMP'	50$34$:	LOAD.B	D7,#H'04	; D7 <-- mois (avril)50$:	POP.L	D4	SWAP.W	D4	LOAD.B	D4,D7		; D4 <-- mois (mars ou avril)	SWAP.W	D4	RR.W	D4,#8	LOAD.B	D4,D6		; D4 <-- jour	CALL	CONVBA	RR.W	D4,#8	POPM.L	D0..D3,D5..D7	RET	.END