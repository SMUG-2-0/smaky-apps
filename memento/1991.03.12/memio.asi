	.SBTTL	MEMIO;----------\\; RDMEMENTO >;==========/; Lit un memento complet.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WRDMEMENTO:	PUSHM.L	D2..D4,D6,A2..A4	CALL	DBOXOPWAIT	; met la dbox d'attente	CALL	IMAXFDEL	; dtruit toutes les images temporaires	CALL	RDVFLUSH	; poutz tous les rendez-vous	LOAD.L	A2,A3		; A2 <-- ^nom du fichier	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE 90$	CALL	LOCK		; dbut de zone critique	CALL	RDENTETE	; lit l'en-tte	JUMP,NE 80$	CALL	RDOPEN20$:	LOAD.L	A4,#(A6)+ORDV-4	LOAD.W	D4,#4+2		; D4 <-- date + longueur22$:	CALL	RDONE		; lit la date et la longueur	JUMP,NE 60$	LOAD.B	(A4+),D3	DEC.W	D4	JUMP,NE 22$	LOAD.L	D2,(A4)-6	; D2 <-- date	LOAD.W	D4,(A4)-2	; D4 <-- longueur	SUB.W	D4,#230$:	CALL	RDONE		; lit le reste du rendez-vous	JUMP',NE 80$	LOAD.B	(A4+),D3	DEC.W	D4	JUMP,NE 30$	LOAD.L	A4,#(A6)+ORDV	; A4 <-- ^rendez-vous lu	LOAD.L	D4,D2		; D4 <-- date	CALL	RDVCREATE	; cre le rendez-vous	JUMP',NE 80$	JUMP	20$60$:	COMP.W	D7,#EROUTF	JUMP',NE 80$	LOAD.L	A4,#(A6)+OFILORI70$:	LOAD.B	(A4+),(A2+)	; OFILORI <-- nom d'origine	JUMP,NE 70$	CLR.B	(A6)+ORDVMJ	; rendez-vous  jour	CLR.W	D7		; D7 <-- ok80$:	CALL	UNLOCK		; fin de zone critique	PUSH.W	D7	CALL	RDCLOSE	POP.W	D790$:	POPM.L	D2..D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; RDENTETE >;---------/; Lit l'en-tte.; in	D6.W	canal; out	D7.W	erreur; mod	D7.WRDENTETE:	PUSHM.L	D4,A3,A4	LOAD.L	A4,#(A6)+OTMIO	LOAD.L	D4,#LHEAD	FOS	?RDBYTE	JUMP',NE 90$	LOAD.W	D7,#ERMMREV	COMP.W	(A4)+OHREV,#H'100*MAJREV+MINREV	JUMP',HI 90$	LOAD.L	(A6)+OINFO,(A4)+OHINFO	LOAD.L	(A6)+OPSION,(A4)+OHPSION	JUMP',NE 80$	LOAD.L	(A6)+OPSION,#2^BPSMEM!2^BPSSND!2^BPSXP80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; WRMEMENTO >;==========/; Ecrit le memento complet.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WWRMEMENTO:	PUSHM.L	D3,D4,D6,A2..A4	CALL	DBOXOPWAIT	; met la dbox d'attente	LOAD.L	A2,A3		; A2 <-- ^nom du fichier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE 90$	CALL	LOCK		; dbut de zone critique	CALL	WRENTETE	; crit l'en-tte	JUMP,NE 80$	CALL	WROPEN	LOAD.L	A3,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D320$:	ADD.L	A3,#8	DEC.W	D3	JUMP',EQ 50$	LOAD.L	A4,#(A6)+ORDV-4	; A4 <-- ^buffer pour date	LOAD.L	(A4),(A3)	; buffer <-- date	LOAD.W	D4,#4		; D4 <-- lg de la date	CALL	WRMANY		; crit la date	JUMP',NE 80$	LOAD.L	A4,(A3)+4	; A4 <-- ^rendez-vous	LOAD.W	D4,(A4)+ORMLG	; D4 <-- lg du rendez-vous	CALL	WRMANY		; crit le rendez-vous	JUMP',NE 80$	JUMP	20$50$:	CALL	IMAXF		; transfert les images	LOAD.L	A4,#(A6)+OFILORI	LOAD.L	A3,A270$:	LOAD.B	(A4+),(A3+)	; OFILORI <-- nom d'origine	JUMP,NE 70$	CLR.B	(A6)+ORDVMJ	; rendez-vous  jour	CLR.W	D7		; D7 <-- ok80$:	CALL	UNLOCK		; fin de zone critique	CALL	WRCLOSE	JUMP',NE 90$	LOAD.L	A3,A2	CALL	WRLIST		; crit le fichier "!"90$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; WRENTETE >;---------/; Ecrit l'en-tte.; in	D6.W	canal; out	D7.W	erreur; mod	D7.WWRENTETE:	PUSHM.L	D4,A3,A4	LOAD.L	A4,#(A6)+OTMIO+LHEAD	LOAD.W	D4,#(LHEAD/4)-110$:	CLR.L	(-A4)	DECJ.W,NMO D4,10$	LOAD.W	(A4)+OHREV,#H'100*MAJREV+MINREV	LOAD.L	(A4)+OHINFO,(A6)+OINFO	LOAD.L	(A4)+OHPSION,(A6)+OPSION	LOAD.L	D4,#LHEAD	FOS	?WRBYTE90$:	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRLIST  >;--------/; Ecrit le fichier "!" avec la liste des images spciales.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WWRLIST:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A4,#(A6)+OBUDIS10$:	LOAD.B	(A4+),(A3+)	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBUDIS	CALL	SKIPREP12$:	COMP.B	(A3+),#'.	JUMP,NE 12$	LOAD.B	(A3)-1,#'!	LOAD.L	A3,#(A6)+OBUDIS	FOS	?DELETE	LOAD.L	D3,#DEFATT-(2^BATTL)	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP,NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE 90$	CALL	WROPEN	LOAD.L	A3,#(A6)+OBUDIS	CALL	SKIPREP	CALL	WRTEXT		; fichier <-- nom "!"	JUMP,NE 80$	LOAD.L	A3,#R16"CACHE$	CALL	WRTEXT	JUMP,NE 80$	LOAD.L	A3,#(A6)+OBUDIS	CALL	SKIPREP30$:	COMP.B	(A3+),#'!	JUMP,NE 30$	LOAD.B	(A3)-1,#'.	LOAD.L	A3,#(A6)+OBUDIS	CALL	SKIPREP	CALL	WRTEXT		; fichier <-- nom "."	JUMP,NE 80$	LOAD.L	A3,#R16"VISU$	CALL	WRTEXT	JUMP,NE 80$	LOAD.L	A4,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D340$:	ADD.L	A4,#8		; A4 <-- ^date/rdv suivant	DEC.W	D3	JUMP',EQ 80$	LOAD.L	D4,(A4)	COMP.B	D4,#HIMAY	JUMP',EQ 42$	COMP.B	D4,#HIMAW	JUMP',EQ 42$	COMP.B	D4,#HIMAD	JUMP,NE 40$42$:	CALL	IMARNAME	; A3 <-- ^nom de fichier	CALL	SKIPREP	CALL	WRTEXT		; fichier <-- nom d'image	JUMP',NE 80$	LOAD.L	A3,#R16"CACHE$	CALL	WRTEXT	JUMP',NE 80$	JUMP	40$80$:	CALL	WRCLOSE90$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RETCACHE$:	.ASCIZ	"/D -CL<CR>"VISU$:	.ASCIZ	"/D -C+L<CR>"	.EVEN;--------\\; IMAXF   >;========/; Transfert les images.; in	-; out	-; mod	D7.WIMAXF:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D320$:	ADD.L	A3,#8		; A3 <-- ^date/rdv suivant	DEC.W	D3	JUMP',EQ 40$	LOAD.L	D4,(A3)	COMP.B	D4,#HIMAY	JUMP',EQ 24$	COMP.B	D4,#HIMAW	JUMP',EQ 24$	COMP.B	D4,#HIMAD	JUMP,NE 20$24$:	LOAD.L	A4,(A3)+4	; A4 <-- ^rendez-vous spcial	CLR.W	(A4)+ORMNBR	; image pas encore transfre	JUMP	20$40$:	CALL	IMAXFNEW	; transfert les nouvelles images	CALL	IMAXFOLD	; transfert les anciennes images	POPM.L	D3,D4,A3,A4	RET;---------\\; IMAXFNEW >;=========/; Transfert toutes les nouvelles images cres dans les noms dfinitifs.; in	-; out	-; mod	D7.WIMAXFNEW:	PUSHM.L	D2..D6,A2..A4	LOAD.L	A3,#(A6)+OFILORI	LOAD.L	A4,#(A6)+OBUDIS10$:	LOAD.B	(A4+),(A3+)	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBUDIS	CALL	SKIPREP	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^dossier	LOAD.L	A4,#R16"CRIT$	; A4 <-- ^critre	LOAD.L	D3,#2^BOPRD	FOS	?LISTOPEN	; ouvre la liste	JUMP,NE 90$20$:	FOS	?LISTNXT	; A3/A4 <-- ^nom/^arguments	JUMP,NE 80$	CALL	IMAOKNMW	; est-ce bien un nom correct ?	JUMP,NE 20$		; non => 20$	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OFILORI	CALL	IMACNMS		; construit nom source	CALL	IMACNMD		; construit nom destination	LOAD.L	A3,#(A6)+OFILNMS	LOAD.L	A4,#(A6)+OFILNMD	CALL	IMAMOVE		; dplace le fichier	JUMP,NE 20$	CALL	IMAIFEXNM	; image existe ?	JUMP,NE 20$		; non => 20$	INC.W	(A2)+ORMNBR	; signal image transfre	JUMP	20$80$:	FOS	?LISTCLOSE	; ferme la liste90$:	POPM.L	D2..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETCRIT$:	.ASCIZ	"M??????.M??????"	.EVEN;---------\\; IMAXFOLD >;=========/; Transfert toutes les anciennes images dans les noms dfinitifs.; in	-; out	-; mod	D7.WIMAXFOLD:	PUSHM.L	D2..D6,A2..A4	LOAD.L	A3,#(A6)+OFILORI	LOAD.L	A4,#(A6)+OBUDIS10$:	LOAD.B	(A4+),(A3+)	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBUDIS	CALL	SKIPREP	CLR.B	(A3)	LOAD.L	A4,#(A6)+OBUDIS+50	LOAD.L	A3,#(A6)+OFILORI	CALL	SKIPREP12$:	LOAD.B	D3,(A3+)	JUMP,EQ 90$	COMP.B	D3,#'.	JUMP',EQ 13$	LOAD.B	(A4+),D3	JUMP	12$13$:	LOAD.L	A3,#R16"CRIT$	; A3 <-- ^critre14$:	LOAD.B	(A4+),(A3+)	JUMP,NE 14$	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^dossier	LOAD.L	A4,#(A6)+OBUDIS+50 ; A4 <-- ^critre	LOAD.L	D3,#2^BOPRD	FOS	?LISTOPEN	; ouvre la liste	JUMP,NE 90$20$:	FOS	?LISTNXT	; A3/A4 <-- ^nom/^arguments	JUMP,NE 80$	CALL	IMAOKNMR	; est-ce bien un nom correct ?	JUMP,NE 20$		; non => 20$	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OFILORI	CALL	IMACNMS		; construit nom source	CALL	IMACNMD		; construit nom destination	LOAD.L	A3,#(A6)+OFILNMS	LOAD.L	A4,#(A6)+OFILNMD	CALL	IMAIFEXNM	; image existe ?	JUMP',NE 40$		; non => 40$	TEST.W	(A2)+ORMNBR	; dj transfr ?	JUMP,NE 20$		; oui => 20$	CALL	IMAXFER		; duplique le fichier	JUMP	20$40$:	LOAD.L	A3,A4	FOS	?DELETE	JUMP	20$80$:	FOS	?LISTCLOSE	; ferme la liste90$:	POPM.L	D2..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETCRIT$:	.ASCIZ	".M??????"	.EVEN;---------\\; IMAXFDEL >;=========/; Dtruit toutes les images temporaires.; in	-; out	-; mod	D7.WIMAXFDEL:	PUSHM.L	D2..D6,A2..A4	LOAD.L	A3,#(A6)+OFILORI	LOAD.L	A4,#(A6)+OBUDIS10$:	LOAD.B	(A4+),(A3+)	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBUDIS	CALL	SKIPREP	CLR.B	(A3)	LOAD.L	A4,#R16"CRIT$	; A4 <-- ^critre	LOAD.L	D3,#2^BOPRD	FOS	?LISTOPEN	; ouvre la liste	JUMP',NE 90$20$:	FOS	?LISTNXT	; A3/A4 <-- ^nom/^arguments	JUMP',NE 80$	CALL	IMAOKNMW	; est-ce bien un nom correct ?	JUMP,NE 20$		; non => 20$	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OFILORI	CALL	IMACNMS		; A3 <-- ^nom source	LOAD.L	A3,#(A6)+OFILNMS	FOS	?DELETE	JUMP	20$80$:	FOS	?LISTCLOSE	; ferme la liste90$:	POPM.L	D2..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETCRIT$:	.ASCIZ	"M??????.M??????"	.EVEN;---------\\; IMAOKNMR >;---------/; Vrifie si un nom est bien un nom d'image en lecture.; in	A3.L	^nom; out	D7.W	erreur; mod	D7.WIMAOKNMR:	PUSHM.L	D3,D4,A3	CALL	IMAOKNMW	; nom d'image en criture ?	JUMP',NE 10$	LOAD.W	D7,#1		; D7 <-- autre nom	JUMP	90$10$:	CALL	SKIPREP		; A3 <-- ^aprs rep:	LOAD.W	D7,#1		; D7 <-- autre nom30$:	COMP.B	(A3+),#'.	JUMP,NE 30$	LOAD.B	D3,(A3+)	COMP.B	D3,#'M	JUMP',NE 90$	LOAD.W	D4,#6-150$:	LOAD.B	D3,(A3+)	COMP.B	D3,#'0	JUMP',LO 90$	COMP.B	D3,#'9	JUMP',HI 90$	DECJ.W,NMO D4,50$	TEST.B	(A3)	JUMP',NE 90$	CLR.W	D7		; D7 <-- nom ok90$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; IMAOKNMW >;---------/; Vrifie si un nom est bien un nom d'image en criture.; in	A3.L	^nom; out	D7.W	erreur; mod	D7.WIMAOKNMW:	PUSHM.L	D3,D4,A3	CALL	SKIPREP		; A3 <-- ^aprs rep:	LOAD.W	D7,#1		; D7 <-- autre nom	LOAD.B	D3,(A3+)	COMP.B	D3,#'M	JUMP,NE 90$	LOAD.W	D4,#6-130$:	LOAD.B	D3,(A3+)	COMP.B	D3,#'0	JUMP',LO 90$	COMP.B	D3,#'9	JUMP',HI 90$	DECJ.W,NMO D4,30$	LOAD.B	D3,(A3+)	COMP.B	D3,#'.	JUMP',NE 90$	LOAD.B	D3,(A3+)	COMP.B	D3,#'M	JUMP',NE 90$	LOAD.W	D4,#6-150$:	LOAD.B	D3,(A3+)	COMP.B	D3,#'0	JUMP',LO 90$	COMP.B	D3,#'9	JUMP',HI 90$	DECJ.W,NMO D4,50$	TEST.B	(A3)	JUMP',NE 90$	CLR.W	D7		; D7 <-- nom ok90$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAIFEXNM >;----------/; Vrifie si l'image associe  un nom existe toujours.; in	A3.L	^nom de fichier; out	A2.L	^rendez-vous spcial;	D7.W	erreur; mod	D7.W, A2.LIMAIFEXNM:	PUSHM.L	D2..D4,A3,A4	CALL	SKIPREP20$:	COMP.B	(A3+),#'.	JUMP,NE 20$	LOAD.W	D7,#1	COMP.B	(A3+),#'M	JUMP,NE 90$	LOAD.B	D3,(A3+)	LOAD.B	D2,#HIMAY	COMP.B	D3,#'1	JUMP',EQ 40$	LOAD.B	D2,#HIMAW	COMP.B	D3,#'2	JUMP',EQ 40$	LOAD.B	D2,#HIMAD	COMP.B	D3,#'3	JUMP',NE 90$40$:	LOAD.L	A4,A3	CALL	GETANUM	CALL	CALCJN		; D4 <-- date en BCD	LOAD.B	D4,D2	CALL	RDVSEARCH	; image existe ?	JUMP',NE 90$	LOAD.L	A2,A4		; A2 <-- ^rendez-vous spcial90$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IMACNMS >;--------/; Construit le nom source.; in	A3.L	^nom de rpertoire(s);	A4.L	^nom de fichier; out	-; mod	D7.WIMACNMS:	PUSHM.L	A2..A4	LOAD.L	A2,#(A6)+OFILNMS20$:	LOAD.B	(A2+),(A3+)	JUMP,NE 20$	LOAD.L	A3,#(A6)+OFILNMS	CALL	SKIPREP	LOAD.L	A2,A3	LOAD.L	A3,A4	CALL	SKIPREP40$:	LOAD.B	(A2+),(A3+)	JUMP,NE 40$	POPM.L	A2..A4	RET;--------\\; IMACNMD >;--------/; Construit le nom destination.; in	-; out	-; mod	D7.WIMACNMD:	PUSHM.L	A2..A4	LOAD.L	A3,#(A6)+OFILNAM	LOAD.L	A4,#(A6)+OFILNMD30$:	LOAD.B	(A4+),(A3+)	JUMP,NE 30$	LOAD.L	A3,#(A6)+OFILNMD	CALL	SKIPREP32$:	COMP.B	(A3+),#'.	JUMP,NE 32$	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OFILNMS	CALL	SKIPREP34$:	COMP.B	(A3+),#'.	JUMP,NE 34$36$:	LOAD.B	(A4+),(A3+)	JUMP,NE 36$	POPM.L	A2..A4	RET;--------\\; IMAMOVE >;--------/; Dplace un fichier dans un autre.; in	A3.L	^nom source;	A4.L	^nom destination; out	D7.W	erreur; mod	D7.WIMAMOVE:	PUSHM.L	D4,A2..A4	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; noms identiques ?	JUMP',EQ 90$		; oui => 90$	EX.L	A3,A4	FOS	?DELETE		; dtruit le fichier destination	EX.L	A4,A3	JUMP',EQ 20$	COMP.W	D7,#ERFDNE	JUMP',NE 90$20$:	CLR.L	D4	FOS	?MOVE		; dplace rapidement	JUMP',EQ 90$	COMP.W	D7,#ERNSUNI	JUMP',NE 90$	CALL	IMAXFER		; duplique le fichier	JUMP',NE 90$	FOS	?DELETE		; dtruit le fichier source90$:	POPM.L	D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETTERM$:	.B	0,-1	.EVEN;--------\\; IMAXFER >;--------/; Duplique un fichier dans un autre.; in	A3.L	^nom source;	A4.L	^nom destination; out	D7.W	erreur; mod	D7.WIMAXFER:	PUSHM.L	D1..D6,A2..A4	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; noms identiques ?	JUMP,EQ 90$		; oui => 90$	EX.L	A3,A4	FOS	?DELETE		; dtruit le fichier destination	EX.L	A4,A3	JUMP',EQ 20$	COMP.W	D7,#ERFDNE	JUMP,NE 90$20$:	LOAD.L	A2,A4		; A2 <-- ^nom destination	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier source	JUMP,NE 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; D4 <-- longueur du fichier source	LOAD.L	D2,D4		; D2 <-- longueur du fichier source	CLR.L	D3	CLR.L	D4	FOS	?SPOS	LOAD.L	D4,D2	COMP.L	D4,#LGARGS	JUMP',HS 30$	LOAD.L	D4,#LGARGS30$:	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande de la mmoire	JUMP,NE 88$	FOS	?ARGS		; demande les arguments du fichier source	JUMP',NE 86$	EX.L	A3,A2	LOAD.L	D3,(A4)+OBAATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier destination	JUMP',NE 86$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	EX.L	D5,D6	FOS	?OPEN		; ouvre le fichier destination	EX.L	D5,D6	JUMP',NE 86$	LOAD.L	D4,D2	FOS	?RDBYTE		; lit le fichier source	JUMP',NE 84$	EX.L	D5,D6	FOS	?WRBYTE		; crit le fichier destination	EX.L	D5,D6	JUMP',NE 84$	EX.L	D5,D6	FOS	?CLOSE		; ferme le fichier destination	EX.L	D5,D6	JUMP'	86$84$:	PUSH.W	D7	EX.L	D5,D6	FOS	?CLOSE		; ferme le fichier destination	EX.L	D5,D6	POP.W	D786$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D788$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier source	POP.W	D790$:	POPM.L	D1..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETTERM$:	.B	0,-1	.EVEN;----------\\; WRRDVTEXT >;==========/; Sauve tous les rendez-vous dans un fichier de texte.; in	A3.L	^nom du texte; out	D7.W	erreur; mod	D7.WWRRDVTEXT:	PUSHM.L	D2..D4,D6,A2..A4	CALL	DBOXOPWAIT	; met la dbox d'attente	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE 90$	CALL	LOCK		; dbut de zone critique	CALL	WROPEN	LOAD.L	A2,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D320$:	ADD.L	A2,#8	DEC.W	D3	JUMP',EQ 80$	LOAD.L	D4,(A2)		; D4 <-- date	LOAD.L	A4,(A2)+4	; A4 <-- ^rendez-vous	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D2,#2^BMADUR!2^BMATAB	CALL	PUTTXTRDV	; OBUDIS <-- date, heure et texte	LOAD.B	(A3+),#CR	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^texte	CALL	WRTEXT	JUMP,EQ 20$80$:	CALL	UNLOCK		; fin de zone critique	CALL	WRCLOSE90$:	POPM.L	D2..D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\; RDOPEN  >;========/; Ouvre le fichier en entre.; in	D6.W	canal; out	-; mod	-RDOPEN:	LOAD.W	(A6)+OCHIO,D6	; mm. canal	LOAD.W	(A6)+OPTIO,#LTMIO	RET;--------\; RDONE   >;========/; Lit un byte dans le fichier d'entre.; in	-; out	D3.B	byte lu;	D7.W	erreur; mod	D3.L, D7.WRDONE:	PUSHM.L	D4,D6,A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^buffer tampon	COMP.W	(A6)+OPTIO,#LTMIO ; reste qq chose ?	JUMP',LO 50$		; oui => 50$				; non =>	LOAD.L	D4,#LTMIO	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?RDBYTE		; lit tout le buffer	LOAD.W	(A6)+ONBIO,#-1	CLR.W	(A6)+OPTIO	; buffer vide	TEST.W	D7		; lecture ok ?	JUMP',EQ 50$		; oui => 50$	COMP.W	D7,#EROUTF	; fin du fichier ?	JUMP,NE 90$		; non => 90$	CLR.W	D7		; D7 <-- ok pour l'instant	LOAD.W	(A6)+ONBIO,D4	; mm. lg dernire tranche50$:	TEST.W	(A6)+ONBIO	; reste qq chose ?	JUMP',NE 60$		; oui => 60$	LOAD.W	D7,#EROUTF	; D7 <-- fin du fichier	JUMP'	90$60$:	LOAD.W	D4,(A6)+OPTIO	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- un byte du buffer	INC.W	(A6)+OPTIO	; avance "pointeur"	DEC.W	(A6)+ONBIO	; diminue reste90$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; RDCLOSE >;========/; Ferme le fichier en entre.; in	-; out	D7.W	erreur; mod	D7.WRDCLOSE:	PUSH.L	D6	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?CLOSE		; ferme le fichier	POP.L	D6	TEST.W	D7		; retour EQ/NE	RET;--------\; WROPEN  >;========/; Ouvre le fichier en sortie.; in	D6.W	canal; out	-; mod	-WROPEN:	LOAD.W	(A6)+OCHIO,D6	; mm. canal	CLR.W	(A6)+OPTIO	; buffer vide	RET;--------\\; WRTEXT  >;========/; Ecrit un texte .ASCIZ dans le fichier de sortie.; in	A3.L	^texte <0>; out	D7.W	erreur; mod	D7.WWRTEXT:	PUSHM.L	D4,A3,A4	LOAD.L	A4,A3	CLR.L	D410$:	INC.W	D4		; D4 <-- lg du texte	TEST.B	(A3+)	JUMP,NE 10$	DEC.W	D4		; D4 <-- lg sans le <0>	CALL	WRMANY		; crit tout le texte	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; WRMANY  >;========/; Ecrit plusieurs bytes dans le fichier de sortie.; in	A4.L	^bytes  crire;	D4.W	nombre de bytes  crire; out	D7.W	erreur; mod	D7.WWRMANY:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,A4		; A3 <-- ^bytes  crire	LOAD.W	D3,D4		; D3 <-- nombre10$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OPTIO	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer20$:	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4+),(A3+)	; buffer <-- un byte	INC.W	D4		; D4 <-- un byte de plus	DEC.W	D3	JUMP,NE	20$	LOAD.W	(A6)+OPTIO,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OPTIO	; signal buffer vide	JUMP	10$90$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; WRONE   >;========/; Ecrit un byte dans le fichier de sortie.; in	D3.B	byte  crire; out	D7.W	erreur; mod	D7.WWRONE:	PUSHM.L	D4,D6,A410$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OPTIO	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4),D3		; buffer <-- le byte	INC.W	D4		; D4 <-- un byte de plus	LOAD.W	(A6)+OPTIO,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OPTIO	; signal buffer vide	JUMP	10$90$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; WRCLOSE >;========/; Ecrit le reste du fichier de sortie, puis ferme.; in	D7.W	ok/erreur; out	D7.W	erreur; mod	D7.WWRCLOSE:	PUSHM.L	D4..D6,A4	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	LOAD.W	D5,D7		; D5 <-- ok/erreur	JUMP',NE 50$		; erreur => 50$				; ok =>	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^buffer tampon	CLR.L	D4	LOAD.W	D4,(A6)+OPTIO	; D4 <-- nb bytes dans buffer	JUMP',EQ 50$		; si vide => 50$				; si reste qq chose =>	FOS	?WRBYTE		; crit tout le buffer	LOAD.W	D5,D750$:	FOS	?CLOSE		; ferme le fichier	COMP.W	D7,D5	JUMP',HS 90$	LOAD.W	D7,D5		; D7 <-- erreur la plus grve !90$:	POPM.L	D4..D6,A4	TEST.W	D7		; retour EQ/NE	RET	.END