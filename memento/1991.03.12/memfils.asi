	.SBTTL	MEMFILS; Processus fils pour signaler les rendez-vous; --------------------------------------------NFILS1:	.ASCIZ	"MEMENTO_SCAN"	.EVENPFILS1:10$:	CALL	CLOCKREAD	; D3/D4 <-- heure/date	LOAD.B	D4,D3	CALL	CONVAB		; D4 <-- secondes	LOAD.B	D3,D420$:	TEST.B	(A6)+OABORT	; fin du processus ?	JUMP,NE 90$		; oui => 90$	LOAD.W	D4,#50*2	NTREL	?DELMS		; attend deux secondes ...	ADD.B	D3,#2	COMP.B	D3,#60-2	; une minute de passe ?	JUMP,LO 20$		; non => 20$; Balaye tous les rendez-vous pour voir ceux qui doivent sonner.	CALL	CLOCKTIME	; D3/D4 <-- temps actuel	JUMP,NE 10$	LOAD.W	D6,D3		; D6 <-- heure	LOAD.L	D5,D4		; D5 <-- date40$:	CALL	LOCK		; dbut de zone critique	LOAD.L	A3,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D342$:	ADD.L	A3,#8		; A3 <-- ^date/rdv suivant	DEC.W	D3	JUMP,EQ 60$	LOAD.L	D4,(A3)		; D4 <-- date du rendez-vous	COMP.B	D4,#HIMAY	JUMP,EQ 42$	COMP.B	D4,#HIMAW	JUMP,EQ 42$	COMP.B	D4,#HIMAD	JUMP,EQ 42$	LOAD.L	A4,(A3)+4	; A4 <-- ^rendez-vous	TEST.B	(A4)+ORMFAN+0:#BRDVQS-24 ; rendez-vous dj sonn ?	JUMP,BS 42$		; oui => 42$	TEST.B	(A4)+ORMFAN+3:#BRDVT1-0 ; commentaire ?	JUMP,BS 42$		; oui => 42$	CLR.B	D4	COMP.L	D4,D5		; rendez-vous aprs cette date ?	JUMP,HI 42$		; oui => 42$	JUMP',LO 50$	LOAD.L	D4,(A3)	AND.L	D4,#H'FF	DIV.WU	D4,#6	MUL.WU	D4,#60		; D4 <-- heure du rendez-vous	ADD.W	D4,(A4)+ORMMIN	SUB.W	D4,(A4)+ORMSON	COMP.W	D4,D6		; rendez-vous aprs cette heure ?	JUMP,HI 42$		; oui => 42$	JUMP',EQ 52$50$:	TEST.B	(A4)+ORMFAN+3:#BRDVT2-0 ; peu important ?	JUMP,BS 42$		; oui => 42$52$:	TSET.B	(A4)+ORMFAN+0:#BRDVQS-24 ; signal rendez-vous dj sonn	SET.B	(A6)+ORDVMJ	; mise  jour ncessaire	LOAD.L	D4,(A3)		; D4 <-- date du rendez-vous	CALL	UNLOCK		; fin de zone critique	CALL	CLOCKCOMMAND	; envoie commande  l'horloge	JUMP	40$60$:	CALL	UNLOCK		; fin de zone critique	JUMP	10$90$:	NTREL	?ABORT;----------\\; CLOCKTIME >;==========/; Donne la date actuelle.; in	-; out	D3.W	heure (en nombre de minutes);	D4.L	anne-mois-jour-heure en BCD;	D7.W	erreur; mod	D3.L, D4.L, D7.WCLOCKTIME:	CALL	CLOCKREAD	; D4 <-- |-|J|M|A| et D3 <-- |-|H|M|S|	JUMP',NE 90$	RR.W	D4,#8		; D4 <-- |-|J|A|M|	SWAP.W	D4		; D4 <-- |A|M|-|J|	RR.W	D4,#8		; D4 <-- |A|M|J|-|	CLR.B	D4		; D4 <-- |A|M|J|H|	PUSH.L	D4	LOAD.L	D4,D3	RR.L	D4,#8	CALL	CONVAB		; D4 <-- minutes	CLR.W	D3	LOAD.B	D3,D4	RR.L	D4,#8	CALL	CONVAB		; D4 <-- heures	AND.W	D4,#H'00FF	MUL.WU	D4,#60	ADD.W	D3,D4	POP.L	D490$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; CLOCKREAD >;==========/; Lit la date et l'heure d'aprs le driver horloge du systme.; ATTENTION:	On ne peut pas utiliser LIB,?RDCLOCK, car;		lorsque MEMENTO est en veilleuse, la librairie;		est ferme (LIB,?CLOLIB effectu) !!!; in	-; out	D3.L	heure en BCD	!   ! h ! m ! s !;	D4.L	date en BCD	! w ! j ! m ! a !;	D7.W	erreur; mod	D3.L, D4.L, D7.WCLOCKREAD:	PUSHM.L	D6,A3,A4	LOAD.L	A3,#R16"NMLCLK	LOAD.B	D3,#2^BOPRD	FOS	?OPEN		; ouvre l'horloge	JUMP,NE 80$	LOAD.L	A4,#(A6)+OBUCOM	LOAD.L	D4,#3+3+1	FOS	?RDBYTE		; lit la date et l'heure	JUMP',NE 70$	FOS	?CLOSE		; ferme l'horloge	JUMP',NE 80$	CLR.W	D3	LOAD.B	D3,(A6)+OBUCOM+2 ; heures	SL.L	D3,#8	LOAD.B	D3,(A6)+OBUCOM+1 ; minutes	SL.L	D3,#8	LOAD.B	D3,(A6)+OBUCOM+0 ; secondes	LOAD.B	D4,(A6)+OBUCOM+6 ; jour de la semaine	SL.L	D4,#8	LOAD.B	D4,(A6)+OBUCOM+3 ; jour	SL.L	D4,#8	LOAD.B	D4,(A6)+OBUCOM+4 ; mois	SL.L	D4,#8	LOAD.B	D4,(A6)+OBUCOM+5 ; anne	JUMP'	90$70$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'horloge	POP.W	D780$:	CLR.L	D3		; rend zro en cas d'erreur	CLR.L	D490$:	POPM.L	D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; CLOCKCOMMAND >;=============/; Envoie une commande  l'horloge.; in	D4.L	date  |A|M|J|-|;	A4.L	^rendez-vous; out	-; mod	D7.WCLOCKCOMMAND:	PUSHM.L	D1..D4,D6,A3,A4	TEST.B	(A4)+ORMFAN+3:#BRDVEX-0 ; excute ?	JUMP',BC 20$		; non => 20$				; oui =>	LOAD.L	A3,#(A4)+ORMTXT	FOS	?EXECUTE	; excute un logiciel	JUMP,EQ 90$20$:	LOAD.L	A3,#R16"NMLCLK	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE 90$	LOAD.L	A3,#(A6)+OBUCOM	LOAD.B	(A3+),#'A	LOAD.B	D3,#4		; D3 <-- nb de dfilement	LOAD.B	D2,#2		; D2 <-- nb de sonneries	TEST.B	(A4)+ORMFAN+3:#BRDVT2-0 ; peu important ?	JUMP',BS 30$		; oui => 30$	LOAD.B	D3,#5		; D3 <-- nb de dfilement	LOAD.B	D2,#10		; D2 <-- nb de sonneries	TEST.B	(A4)+ORMFAN+3:#BRDVT3-0 ; normal ?	JUMP',BS 30$		; oui => 30$	LOAD.B	D3,#0		; D3 <-- nb de dfilement	LOAD.B	D2,#20		; D2 <-- nb de sonneries30$:	LOAD.B	(A3+),D3	LOAD.B	(A3+),D2	CLR.B	(A3+)	LOAD.B	(A3+),#24	; icnes 24,25,26 dans SNF07 et SNF11 !	CLR.W	D2		; D2 <-- mode	CALL	PUTTXTRDV	; commande <-- date, heure et texte	LOAD.L	A4,#(A6)+OBUCOM	LOAD.W	D3,#TYPIO	FOS	?COMMAND80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D1..D4,D6,A3,A4	RETNMLCLK:	.ASCIZ	"#CLOCK"	.EVEN;----------\\; PUTTXTRDV >;==========/; Prpare le texte pour un rendez-vous.; in	D2.W	mode (BMAxxx);	D4.L	date;	A4.L	^rendez-vous;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LPUTTXTRDV:	PUSHM.L	D0..D4,A2,A4	LOAD.B	D0,#SPACE	TEST.L	D2:#BMATAB	JUMP',BC 10$	LOAD.B	D0,#TAB10$:	LOAD.L	D1,D4	AND.L	D4,#H'FF	DIV.WU	D4,#6		; D4 <-- heure du rendez-vous	CALL	CONVBA	LOAD.B	D3,D4	SL.W	D3,#8	LOAD.W	D4,(A4)+ORMMIN	CALL	CONVBA	LOAD.B	D3,D4		; D3 <-- heure du rendez-vous	LOAD.L	D4,D1		; D4 <-- date du rendez-vous	CALL	DATEBCDASC	; buffer <-- date	LOAD.B	(A3+),D0	LOAD.L	A2,#R16"TIME$	COMP.B	D1,#HIMAY	JUMP',EQ 20$	COMP.B	D1,#HIMAW	JUMP',EQ 20$	COMP.B	D1,#HIMAD	JUMP',EQ 20$	LOAD.W	D4,D3	CALL	TIMEBCDASC	; buffer <-- heure de dbut	JUMP'	25$20$:	LOAD.B	(A3+),(A2+)	JUMP,NE 20$	DEC.L	A325$:	TEST.L	D2:#BMADUR	; met la dure ?	JUMP',BC 40$		; non => 40$	LOAD.W	D3,(A4)+ORMDUR	; D3 <-- dure	JUMP',EQ 30$	CALL	CALCNM		; D4 <-- nombre de minutes	ADD.W	D4,D3	CALL	CALCMN		; D4 <-- heure en BCD	LOAD.B	(A3+),#'-	CALL	TIMEBCDASC	; buffer <-- heure de fin	JUMP'	40$30$:	COMP.B	D0,#TAB	JUMP',EQ 40$	LOAD.W	D3,#6-132$:	LOAD.B	(A3+),D0	DECJ.W,NMO D3,32$40$:	LOAD.B	(A3+),D0	LOAD.L	A2,#R16"YEAR$	COMP.B	D1,#HIMAY	JUMP',EQ 50$	LOAD.L	A2,#R16"WEEK$	COMP.B	D1,#HIMAW	JUMP',EQ 50$	LOAD.L	A2,#R16"DAY$	COMP.B	D1,#HIMAD	JUMP',EQ 50$	LOAD.L	A2,#(A4)+ORMTXT50$:	LOAD.B	(A3+),(A2+)	; buffer <-- texte	JUMP,NE 50$	DEC.L	A3	POPM.L	D0..D4,A2,A4	RETTIME$:	.ASCIZ	"  :  "YEAR$:	.ASCIZ	"Dessin pour une anne"WEEK$:	.ASCIZ	"Dessin pour une semaine"DAY$:	.ASCIZ	"Dessin pour une journe"	.EVEN;--------\\; LOCK    >;========/; Dbut de zone critique.; in	-; out	-; mod	-LOCK:	PUSHM.L	D7,A5	LOAD.L	A5,(A6)+OPSEM	NTREL	?LOCK	POPM.L	D7,A5	RET;--------\\; UNLOCK  >;========/; Fin de zone critique.; in	-; out	-; mod	-UNLOCK:	PUSHM.L	D7,A5	LOAD.L	A5,(A6)+OPSEM	NTREL	?UNLOCK	POPM.L	D7,A5	RET;--------\\; RACUNIT >;========/; Installe toutes les units.; RAPPEL:	La ligne de commande rendue par le FOS;		a le format suivant :;;		MEMENTO {12} TOTO<CR>;;		devient :;;		MEMENTO TOTO<CR><0>12<0>;		<-------------->  >--<;		  partie utile    partie qui tait entre les { }; in	A3.L	^ligne de commande; out	D7.W	erreur; mod	D7.WRACUNIT:	PUSHM.L	D3,D4,A2..A4	SUB.L	SP,#20		; prend buffer sur le stack	LOAD.L	A4,SP		; A4 <-- ^buffer	LOAD.L	A2,#R16"NMPDIS20$:	LOAD.B	(A4+),(A2+)	; buffer <-- nom physique "$DIS"	JUMP,NE 20$	DEC.L	A422$:	TEST.B	(A3+)		; A3 <-- saute 1re partie ligne de commande	JUMP,NE 22$	TEST.B	(A3)		; {n} dans ligne de commande ?	JUMP',EQ 30$		; non => 30$	LOAD.B	(A4+),#'_24$:	LOAD.B	(A4+),(A3+)	; buffer <-- numro "_nn"	JUMP,NE 24$30$:	NTREL	?GTPNUM		; D4 <-- no processus courant	LOAD.L	A3,#R16"NMLDIS	LOAD.L	A4,SP	LOAD.L	A2,#R16"ADCODE-256+OBXDIS	LOAD.W	D3,D4	FOS	?INSTALL	; essaye d'installer "$DIS_n"	JUMP',EQ 50$;	LOAD.L	A3,#R16"NMLDIS	LOAD.L	A4,#R16"NMPDIS;	LOAD.L	A2,#R16"ADCODE-256+OBXDIS	LOAD.W	D3,D4	FOS	?INSTALL	; essaye d'installer n'importe quel "$DIS"	JUMP',NE 90$50$:	LOAD.L	A3,#R16"NMLKEY	LOAD.L	A4,#R16"NMPKEY	LOAD.L	A2,#0	LOAD.W	D3,D4	FOS	?INSTALL	JUMP',NE 90$	LOAD.L	A3,#R16"NMLSYN	LOAD.L	A4,#R16"NMPSYN	LOAD.L	A2,#0	LOAD.W	D3,D4	FOS	?INSTALL	JUMP',NE 90$	CLR.L	D7	LIB	?OPELIB		; ouvre la librairie	CLR.W	D7		; D7 <-- ok90$:	ADD.L	SP,#20		; rend buffer sur le stack	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RLAUNIT >;========/; Dinstalle toutes les units.; in	-; out	-; mod	D7.WRLAUNIT:	PUSHM.L	D3,D4,A2..A4	LIB	?CLOLIB		; ferme la librairie	NTREL	?GTPNUM		; D4 <-- no processus courant	LOAD.W	D3,D4	FOS	?RINSTALL	POPM.L	D3,D4,A2..A4	RETNMLDIS:	.ASCIZ	"#DISPLAY"NMPDIS:	.ASCIZ	"$DIS"NMLKEY:	.ASCIZ	"#KEYBOARD"NMPKEY:	.ASCIZ	"$KEY"NMLSYN:	.ASCIZ	"#SYNTHESIZER"NMPSYN:	.ASCIZ	"$SYNT"	.EVEN	.END