	.SBTTL	MEMMISC.ASI;--------\\; MMEMUS  >;========/; Choix selon un mmenu hirarchique.; in	A3.L	^mmenus;	A4.L	^paramtres; out	D7.W	erreur; mod	D7.WMMENUS:	PUSHM.L	D3..D5	CLR.W	D3	CALL	SELMO		; utilise la flche	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE 90$	TEST.B	(A6)+OINFO+3:#BINFMEM-0	JUMP',BS 30$	CLR.W	(A4)+(LMM*0)+OMMSEL30$:	CLR.L	D5		; D5 <-- flags	LIB	?MMENUS		; choix selon souris ...	PUSH.W	D7	CALL	PMOUSE		; remet la souris o elle tait	POP.W	D790$:	POPM.L	D3..D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	ADD.W	D4,(A6)+OLUPX	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	COMP.W	D4,(A0)+ODFFDX	JUMP',LO 22$	LOAD.W	D4,(A0)+ODFFDX	DEC.W	D4	LOAD.W	D7,#ERDIOUT22$:	SWAP.W	D4	ADD.W	D4,(A6)+OLUPY	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	COMP.W	D4,(A0)+ODFFDY	JUMP',LO 32$	LOAD.W	D4,(A0)+ODFFDY	DEC.W	D4	LOAD.W	D7,#ERDIOUT32$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMOUSE  >;========/; Positionne la souris.; in	D4.L	position (y;x); out	-; mod	D7.WPMOUSE:	PUSH.L	D4	ADD.W	D4,(A0)+ODFFX	SWAP.W	D4	ADD.W	D4,(A0)+ODFFY	SWAP.W	D4	LIB	?PMOUSE		; remet la souris o elle tait	POP.L	D4	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; CCMO    >;========/; Enlve la souris.; in	-; out	-; mod	-CCMO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	POPM.L	D3,D7	RET;--------\\; SCMO    >;========/; Remet la souris.; in	-; out	-; mod	-SCMO:	PUSHM.L	D3,D7	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	POPM.L	D3,D7	RET;----------\\; SELDESSIN >;==========/; Slectionne le bon lutin pour la souris.; in	-; out	-; mod	D7.WSELDESSIN:	PUSHM.L	D3,D4	TEST.B	(A6)+ODESS+3:#BDESFL-0	JUMP',BS 50$	LOAD.W	D3,#ICOCRAYON	TEST.B	(A6)+ODESS+3:#BDESCR-0	JUMP',BS 40$	LOAD.W	D3,#ICOPINCEAU	TEST.B	(A6)+ODESS+3:#BDESPI-0	JUMP',BS 40$	LOAD.W	D3,#ICOGOMME	TEST.B	(A6)+ODESS+3:#BDESGO-0	JUMP',BC 50$40$:	CALL	IFMOUSE	JUMP',NE 50$	PUSH.L	D3	CALL	AFFDETICONE	; souris dans une icne ?	POPM.L	D3	JUMP',NE 60$		; non => 60$50$:	CLR.W	D3		; D3 <-- flche normale60$:	CALL	SELMO	POPM.L	D3,D4	RET;--------\\; SELMO   >;========/; Slectionne un nouveau lutin pour la souris.; in	D3.B	outil en fonction; out	-; mod	D7.WSELMO:	PUSHM.L	D2..D5,A2..A5	LOAD.L	D2,#-1		; D2 <-- hors de la fentre	PUSH.L	D3	LIB	?IFMOUSE	POPM.L	D3	JUMP',NE 05$	ADD.W	D4,(A6)+OLUPX	SWAP.W	D4	ADD.W	D4,(A6)+OLUPY	SWAP.W	D4	LOAD.L	D2,D405$:	LOAD.L	A3,#R16"TABLE$-510$:	ADD.L	A3,#5		; A3 <-- ^suivant dans table	TEST.B	(A3)+0		; fin de la table ?	JUMP',EQ 12$	COMP.B	D3,(A3)+0	; outil trouv ?	JUMP,NE 10$12$:	CLR.W	D3	LOAD.B	D3,(A3)+1	; D3 <-- code de l'icne	LOAD.B	(A6)+OLUPX+1,(A3)+3	LOAD.B	(A6)+OLUPY+1,(A3)+4	COMP.B	D3,(A6)+OLUTIN	; toujours le mme outil ?	JUMP,EQ 90$		; oui => 90$	LOAD.B	(A6)+OLUTIN,D3	LOAD.L	A2,#(A6)+OLUMAM	LOAD.L	A4,#0		; A4 <-- utilise la flche normale	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	TEST.B	D3	JUMP',EQ 50$	TEST.B	(A3)+2	JUMP',NE 30$20$:	CALL	CMOUTIL		; A4/A5 <-- ^dx,dy,matrice de l'outil	JUMP'	50$30$:	CALL	CMOUTILFOND	; A4/A5 <-- ^dx,dy,matrice chair/fond50$:	NTREL	?GETPRIO	LOAD.W	D5,D4		; D5 <-- priorit actuelle	LOAD.W	D4,#1	NTREL	?SETPRIO	; met une trs forte priorit	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	LOAD.L	(A3)+1,A4	; <ssss> matrice chair	LOAD.L	(A3)+5,A5	; <cccc> matrice fond	LOAD.W	D3,#9	LIB	?STRING	COMP.L	D2,#-1		; hors de la fentre ?	JUMP,EQ 70$		; oui => 70$				; non =>	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 70$	SUB.W	D4,D2	JUMP',NC 60$	NEG.W	D4		; D4 <-- |dplacement horizontal|60$:	COMP.W	D4,#30		; souris beaucoup bouge "entre temps" ?	JUMP',HS 70$		; oui => 70$ (crac, pas de positionnement !!!)	LOAD.L	D3,D2	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',NC 62$	NEG.W	D4		; D4 <-- |dplacement vertical|62$:	COMP.W	D4,#30		; souris beaucoup bouge "entre temps" ?	JUMP',HS 70$		; oui => 70$ (crac, pas de positionnement !!!)	LOAD.L	D4,D2	SUB.W	D4,(A6)+OLUPX	SWAP.W	D4	SUB.W	D4,(A6)+OLUPY	SWAP.W	D4	LIB	?PMOUSE		; positionne pour ne pas bouger la "pointe"70$:	LOAD.W	D4,D5	NTREL	?SETPRIO	; remet la priorit initiale90$:	POPM.L	D2..D5,A2..A5	RETTABLE$:	.B	ICOCRAYON,ICOOUTC,0		0,20	.B	ICOPINCEAU,ICOOUTP,0		0,16	.B	ICOGOMME,ICOOUTGC,ICOOUTGF	5,8	.B	0,0,0				0,0	.EVEN;--------\\; CMOUTIL >;--------/; Construit la matrice d'un outil quelconque d'aprs; une icne contenue dans IMP12.; La matrice construite possde un point de plus de tous; les cts, pour permettre un calcul correct de la matrice; automatique de fond.; in	D3.W	code de l'icne;	A2.L	^buffer pour matrice; out	A4.L	^dx,dy,matrice chair;	A5.L	^dx,dy,matrice fond; mod	D7.W, A4.L, A5.LCMOUTIL:	PUSHM.L	D1..D4,A3	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	A4,(A6)+OPGC4	; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D3	CLR.W	D1	LOAD.B	D1,(A4)+OGCLCA	SUB.B	D1,(A4)+OGCFCA	INC.B	D1	MUL.WU	D1,#3	ADD.L	D4,D1	ADD.L	D4,#OGCWID	ADD.L	A4,D4		; A4 <-- ^bonne matrice	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#GCT4X/8 ; source: <ii>	LOAD.L	A4,(A6)+OPGC4	; A4 <-- ^gencar des icnes	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D2,#1+GCT4Y+1	; D2 <-- hauteur	SWAP.W	D2	CLR.W	D2	LOAD.B	D2,(A4)+(D3.W)	ADD.W	D2,#2		; D2 <-- largeur	LOAD.W	D1,D2	ADD.W	D1,#8-1	SR.W	D1,#3		; D1 <-- largeur en bytes	LOAD.W	(A3)+12,#1	; destination: <xx>	LOAD.W	(A3)+14,#1	; destination: <yy>	LOAD.L	A4,A2		; A4 <-- ^buffer pour matrice	LOAD.B	(A4+),D2	; OLUMAM <-- dx	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM <-- dy	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,D1	; destination: <ii>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D440$:	CLR.B	(A4+)		; OLUMAM <-- efface tout	DECJ.W,NMO D4,40$	SUB.W	D2,#2	LOAD.W	(A3)+22,D2	; <dxx>	SWAP.W	D2	SUB.W	D2,#2	LOAD.W	(A3)+24,D2	; <dyy>	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM <-- icne	LOAD.L	A4,A2		; A4 <-- ^dx,dy,matrice	POPM.L	D1..D4,A3	RET;------------\\; CMOUTILFOND >;------------/; Construit les matrices chair et fond d'un outil quelconque d'aprs; une icne et la suivante contenue dans IDP20.; in	D3.W	code de l'icne;	A2.L	^buffer pour matrice; out	A4.L	^dx,dy,matrice chair;	A5.L	^dx,dy,matrice fond; mod	D7.W, A4.L, A5.LCMOUTILFOND:	PUSHM.L	D0..D4,A3	LOAD.W	D0,D3		; D0 <-- code de l'icne	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	A4,(A6)+OPGC4	; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D0	CLR.W	D1	LOAD.B	D1,(A4)+OGCLCA	SUB.B	D1,(A4)+OGCFCA	INC.B	D1	MUL.WU	D1,#3	ADD.L	D4,D1	ADD.L	D4,#OGCWID	ADD.L	A4,D4		; A4 <-- ^matrice chair	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#GCT4X/8 ; source: <ii>	LOAD.L	A4,(A6)+OPGC4	; A4 <-- ^gencar des icnes	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D2,#GCT4Y	; D2 <-- hauteur	SWAP.W	D2	CLR.W	D2	LOAD.B	D2,(A4)+(D0.W)	; D2 <-- largeur	LOAD.W	D1,D2	ADD.W	D1,#8-1	SR.W	D1,#3		; D1 <-- largeur en bytes	CLR.L	(A3)+12		; destination: <xx> et <yy>	LOAD.L	A4,A2		; A4 <-- ^buffer pour matrice	LOAD.B	(A4+),D2	; OLUMAM <-- dx chair	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM <-- dy chair	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,D1	; destination: <ii>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D440$:	CLR.B	(A4+)		; OLUMAM <-- efface tout	DECJ.W,NMO D4,40$	SWAP.W	D2	LOAD.L	(A3)+22,D2	; <dxx> et <dyy>	SWAP.W	D2	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM <-- icne chair	LOAD.L	A5,A4		; A5 <-- ^futur dx,dy,matrice fond	LOAD.L	A4,(A6)+OPGC4	; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	LOAD.W	D3,D0	INC.W	D3	MUL.WU	D4,D3	CLR.W	D0	LOAD.B	D0,(A4)+OGCLCA	SUB.B	D0,(A4)+OGCFCA	INC.B	D0	MUL.WU	D0,#3	ADD.L	D4,D0	ADD.L	D4,#OGCWID	ADD.L	A4,D4		; A4 <-- ^matrice suivante (fond)	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.L	A4,A5	LOAD.B	(A4+),D2	; OLUMAM <-- dx fond	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM <-- dy fond	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D460$:	CLR.B	(A4+)		; OLUMAM <-- efface tout	DECJ.W,NMO D4,60$	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM <-- icne fond	LOAD.L	A4,A2		; A4 <-- ^dx,dy,matrice chair	POPM.L	D0..D4,A3	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	-; out	-; mod	D7.WAFMENU:	PUSHM.L	D3,A3	LOAD.L	A3,#R16"TXMENU	LIB	?AFMENU	POPM.L	D3,A3	RETTXMENU:	.ASCIZ	""	.ASCIZ	" Fin "		;     ;     ;     ;	.ASCIZ	"      Ajoute     "	.ASCIZ	"Prend image Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	"     Semaine     "	.ASCIZ	"Anne       Jour "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"      Efface Imp."		;     ;     ;     ;	.EVEN;--------\\; SKIPREP >;========/; Saute tous les noms d'units et de rpertoires devant; un nom de fichier.; in	A3.L	^unit:rp:rp:nom.ext; out	A3.L	^nom.ext; mod	A3.LSKIPREP:	PUSH.W	D3	CLR.W	D310$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE 10$20$:	DEC.W	D3	JUMP',NS 90$	COMP.B	(-A3),#':	JUMP,NE 20$	INC.L	A390$:	POP.W	D3	RET;--------\\; PUTANUM >;--------/; Met un nombre dcimal dans un buffer.; in	D4.L	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;--------/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSHM.L	D2,D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	SL.L	D4,#1	LOAD.L	D2,D4	SL.L	D4,#2	ADD.L	D4,D2		; D4 <-- pousse d'un digit (*10)	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POPM.L	D2,D3	RET;---------\\; IFSWITCH >;=========/; Vrifie si un nom de fichier est termin par un switch; donn.; in	A3.L	^nom de fichier;	D3.B	switch cherch (lettre maj. ou min.); out	EQ	switch existe		(D7=zro);	NE	switch n'existe pas	(D7=un); mod	D7.WIFSWITCH:	PUSHM.L	D0,D3,A3	CALL	MINMAJ		; D3 <-- switch MAJUSCULE	LOAD.B	D0,D3		; D0 <-- switch cherch10$:	LOAD.B	D3,(A3+)	; D3 <-- caractre suivant	JUMP',EQ 80$	COMP.B	D3,#CR		; fin du nom ?	JUMP',EQ 80$		; oui => 80$	COMP.B	D3,#SPACE	JUMP',EQ 80$	COMP.B	D3,#'/		; switch ?	JUMP,NE 10$		; non => 10$				; oui =>	LOAD.B	D3,(A3)		; D3 <-- lettre aprs switch	CALL	MINMAJ		; D3 <-- lettre MAJUSCULE	COMP.B	D0,D3		; switch trouv ?	JUMP,NE 10$		; non => 10$				; oui =>	CLR.W	D7		; D7 <-- zro pour retour EQ	JUMP'	90$80$:	LOAD.W	D7,#1		; D7 <-- valeur pour retour NE90$:	POPM.L	D0,D3,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; NOACCENT >;=========/; in	D3.B	caractre; out	D3.B	caractre non accentu; mod	D3.BNOACCENT:	COMP.B	D3,#'	JUMP',LO 90$	COMP.B	D3,#'	JUMP',HI 90$	CALL	MINMAJ	ADD.B	D3,#'a-'A90$:	RET;--------\\; MINMAJ  >;========/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMINMAJ:	TEST.L	D3:#7		; code "supplmentaire" ?	JUMP',NE 20$		; oui => 20$	COMP.B	D3,#SPACE-2	; lettre accentue ?	JUMP',LO 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+TABLE$ ; D3 <-- lettre majuscule	POP.W	D0	RETTABLE$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN	.END