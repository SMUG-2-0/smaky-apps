	.SBTTL	MEMPSION;----------\\; PSDSENDXP >;==========/; Envoie les rendez-vous dans le PSION-XP.; Voici un exemple du format  utiliser pour envoyer; deux rendez-vous :;;	.B	1+2	H'01,0,(7+5)+(7+3);	.B	1+7+5	H'02,5,88,9-1,16-1,12,0,0,'E,'s,'s,'a,'i;	.B	1+7+3	H'02,3,88,9-1,16-1,13,0,0,'A,'b,'c;			     <--------------------------------->;			           donnes dans le PSION; in	-; out	D7.W	erreur; mod	D7.WPSDSENDXP:	PUSHM.L	D0..D6,A0..A5	CALL	DBOXOPWAIT	; met la dbox d'attente;;?	CALL	USARTOPEN	CALL	USARTCLOSE	CALL	USARTOPEN	LOAD.L	D4,#10000+100	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande buffer temporaire	JUMP,NE 90$	LOAD.L	A0,A4		; A0 <-- ^dbut du buffer	LOAD.L	D0,A4	ADD.L	D0,D4	SUB.L	D0,#100		; D0 <-- max  ne pas dpasser; Met tous les rendez-vous  envoyer dans un grand buffer.	CALL	LOCK		; dbut de zone critique	LOAD.B	(A4+),#1+2	LOAD.B	(A4+),#H'01	CLR.W	(A4+)	CLR.W	D5	LOAD.L	A3,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D320$:	ADD.L	A3,#8		; A3 <-- ^date/rdv suivant	DEC.W	D3	JUMP,EQ 40$	LOAD.L	D4,(A3)		; D4 <-- date	COMP.B	D4,#HIMAY	JUMP,EQ 20$	COMP.B	D4,#HIMAW	JUMP,EQ 20$	COMP.B	D4,#HIMAD	JUMP,EQ 20$	LOAD.L	A2,(A3)+4	; A2 <-- ^rendez-vous	LOAD.L	A1,#(A2)+ORMTXT	LOAD.W	D2,#-130$:	INC.W	D2		; D2 <-- longueur du texte	TEST.B	(A1+)	JUMP,NE 30$	TEST.W	D2	JUMP,EQ 20$	LOAD.W	D1,D2	ADD.W	D1,#1+7	ADD.W	D5,D1	DEC.W	D5	LOAD.B	(A4+),D1	LOAD.B	(A4+),#H'02	LOAD.B	(A4+),D2	RL.L	D4,#8	CALL	CONVAB		; D4 <-- anne	LOAD.B	(A4+),D4	RL.L	D4,#8	CALL	CONVAB		; D4 <-- mois	DEC.B	D4	LOAD.B	(A4+),D4	RL.L	D4,#8	CALL	CONVAB		; D4 <-- jour	DEC.B	D4	LOAD.B	(A4+),D4	RL.L	D4,#8	AND.L	D4,#H'FF	DIV.WU	D4,#6		; D4 <-- heure	LOAD.B	(A4+),D4	SWAP.W	D4	TEST.W	D4	JUMP',EQ 34$	LOAD.W	D4,#3034$:	LOAD.B	(A4+),D4	CLR.B	D1	TEST.B	(A2)+ORMFAN+3:#BRDVT1-0	JUMP',BS 37$	TEST.B	(A2)+ORMFAN+0:#BRDVQS-24	JUMP',BS 37$	LOAD.W	D1,(A2)+ORMSON	SUB.W	D1,(A2)+ORMMIN	ADD.W	D1,D4	JUMP',NC 35$	CLR.W	D135$:	COMP.W	D1,#59	JUMP',LS 36$	LOAD.W	D1,#5936$:	INC.B	D137$:	LOAD.B	(A4+),D1	PUSH.W	D3	LOAD.L	A1,#(A2)+ORMTXT38$:	LOAD.B	D3,(A1+)	CALL	NOACCENT	; D3 <-- caractre sans accent	LOAD.B	(A4+),D3	DEC.W	D2	JUMP,NE 38$	POP.W	D3	LOAD.W	D7,#ERMMRPL	COMP.L	A4,D0		; buffer trop plein ?	JUMP,LO 20$		; non => 20$	CALL	UNLOCK		; fin de zone critique	JUMP	80$40$:	LOAD.W	(A0)+2,D5	LOAD.L	D0,A4	SUB.L	D0,A0	CALL	UNLOCK		; fin de zone critique; Envois tous les rendez-vous contenus dans le buffer.	CLR.W	(A6)+OHEAD	; vide le fifo	CLR.W	(A6)+OTAIL	NTREL	?GETPRIO	; D4 <-- priorit de START	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS2	LOAD.L	A3,#R16"NFILS2	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP',NE 80$	LOAD.L	D3,D0	LOAD.L	A3,A050$:	CALL	USARTDIAL	JUMP',NE 60$	CLR.L	D4	LOAD.B	D4,(A3)	INC.L	D4	ADD.L	A3,D4		; A3 <-- ^lment suivant	SUB.L	D3,D4	JUMP,NE 50$	CLR.W	D7		; D7 <-- ok60$:	PUSH.W	D7	LOAD.W	D6,(A6)+OPSCHI	FOS	?AVORT	POP.W	D780$:	PUSH.W	D7	LOAD.L	A4,A0	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D790$:	PUSH.W	D7;;?	CALL	USARTCLOSE	POP.W	D7	POPM.L	D0..D6,A0..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; PSDSENDLZ >;==========/; Envoie les rendez-vous dans le PSION-LZ.; Voici un exemple du format  utiliser pour envoyer; un rendez-vous :;;	1989101120150716<TAB>texte<CR>;	aaaammjjhhmmddss; in	-; out	D7.W	erreur; mod	D7.WPSDSENDLZ:	PUSHM.L	D0..D4,A0..A4	CALL	DBOXOPWAIT	; met la dbox d'attente;;?	CALL	USARTOPEN	CALL	USARTCLOSE	CALL	USARTOPEN	LOAD.L	D4,#50000+100	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande buffer temporaire	JUMP,NE 90$	LOAD.L	A0,A4		; A0 <-- ^dbut du buffer	LOAD.L	D0,A4	ADD.L	D0,D4	SUB.L	D0,#100		; D0 <-- max  ne pas dpasser; Met tous les rendez-vous  envoyer dans un grand buffer.	CALL	LOCK		; dbut de zone critique	LOAD.L	A3,A4		; A3 <-- ^buffer	LOAD.L	A4,#(A6)+ORDVDP-8	LOAD.W	D2,(A6)+ORDVNB	INC.W	D220$:	ADD.L	A4,#8		; A4 <-- ^date/rdv suivant	DEC.W	D2	JUMP,EQ 40$	LOAD.L	D4,(A4)		; D4 <-- anne-mois-jour-heure en BCD	COMP.B	D4,#HIMAY	JUMP,EQ 20$	COMP.B	D4,#HIMAW	JUMP,EQ 20$	COMP.B	D4,#HIMAD	JUMP,EQ 20$	LOAD.L	A1,#(A2)+ORMTXT	TEST.B	(A1)		; texte existe ?	JUMP,EQ 20$		; non => 20$	CALL	DATEYEAR	; buffer <-- anne	SWAP.W	D4	CALL	BCDASC		; buffer <-- mois	SWAP.W	D4	RR.W	D4,#8	CALL	BCDASC		; buffer <-- jour	RL.W	D4,#8	LOAD.L	A2,(A4)+4	; A2 <-- ^rendez-vous	AND.L	D4,#H'FF	DIV.WU	D4,#6		; D4 <-- heure du rendez-vous	LOAD.W	D1,D4	MUL.WU	D1,#4		; D1 <-- heure *4	CALL	CONVBA	CALL	BCDASC		; buffer <-- heure	CLR.L	D4	LOAD.W	D4,(A2)+ORMMIN	DIV.WU	D4,#15	ADD.W	D1,D4	MUL.WU	D4,#15	LOAD.W	D3,D4	CALL	CONVBA	CALL	BCDASC		; buffer <-- minutes	CLR.L	D4	LOAD.W	D4,(A2)+ORMDUR	DIV.WU	D4,#15	TEST.W	D4	JUMP',NE 33$	INC.W	D4		; D4 <-- la dure ne peut pas tre nulle !33$:	SUB.W	D1,#24*4	NEG.W	D1		; D1 <-- dure maximale	COMP.W	D4,D1	JUMP',LO 34$	LOAD.W	D4,D1	DEC.W	D434$:	CALL	CONVBA	CALL	BCDASC		; buffer <-- dure	CLR.B	D4	TEST.B	(A2)+ORMFAN+3:#BRDVT1-0	JUMP',BS 37$	TEST.B	(A2)+ORMFAN+0:#BRDVQS-24	JUMP',BS 37$	LOAD.W	D4,(A2)+ORMSON	SUB.W	D4,(A2)+ORMMIN	ADD.W	D4,D3	JUMP',NC 35$	CLR.W	D435$:	COMP.W	D4,#59	JUMP',LS 36$	LOAD.W	D4,#5936$:	INC.B	D437$:	CALL	CONVBA	CALL	BCDASC		; buffer <-- sonnerie	LOAD.B	(A3+),#TAB	LOAD.L	A1,#(A2)+ORMTXT38$:	LOAD.B	D3,(A1+)	JUMP',EQ 39$	CALL	NOACCENT	; D3 <-- caractre sans accent	LOAD.B	(A3+),D3	JUMP	38$39$:	LOAD.B	(A3+),#CR	LOAD.W	D7,#ERMMRPL	COMP.L	A3,D0		; buffer trop plein ?	JUMP,LO 20$		; non => 20$	CALL	UNLOCK		; fin de zone critique	JUMP'	80$40$:	CALL	UNLOCK		; fin de zone critique	LOAD.L	A4,A0	LOAD.L	D4,A3	SUB.L	D4,A4	CALL	USARTWRITE	; crit tout le fichier	JUMP',NE 80$	LOAD.B	(A4),#CARPEOF	LOAD.L	D4,#1	CALL	USARTWRITE	; crit le caractre de fin80$:	PUSH.W	D7	LOAD.L	A4,A0	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D790$:	PUSH.W	D7;;?	CALL	USARTCLOSE	POP.W	D7	POPM.L	D0..D4,A0..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; PSDRECVXP >;==========/; Lit tous les rendez-vous contenus dans le PSION-XP.; in	-; out	D7.W	erreur; mod	D7.WPSDRECVXP:	PUSHM.L	D0..D6,A0..A5	CALL	DBOXOPWAIT	; met la dbox d'attente;;?	CALL	USARTOPEN	CALL	USARTCLOSE	CALL	USARTOPEN	LOAD.L	D4,#10000+100	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande buffer temporaire	JUMP,NE 90$	LOAD.L	A0,A4		; A0 <-- ^dbut du buffer	LOAD.L	D0,D4; Reoit tous les rendez-vous du PSION.	CLR.W	(A6)+OHEAD	; vide le fifo	CLR.W	(A6)+OTAIL	NTREL	?GETPRIO	; D4 <-- priorit de START	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS2	LOAD.L	A3,#R16"NFILS2	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP,NE 80$	LOAD.L	A4,A0	LOAD.L	A3,#R16"COM$	CALL	USARTSEND	JUMP,NE 40$	LOAD.L	A3,#(A6)+OPSBUI	CALL	USARTRECV	JUMP,NE 40$	LOAD.W	D7,#ERPREP	COMP.B	(A3)+0,#3	; lg correcte ?	JUMP,NE 40$	COMP.B	(A3)+1,#H'01	JUMP,NE 40$	LOAD.W	D4,(A3)+2	; D4 <-- lg attendue	ADD.W	D4,#230$:	CLR.W	D2	LOAD.B	D2,(A3)	DEC.W	D2	SUB.W	D4,D2	ADD.W	D2,#232$:	LOAD.B	(A4+),(A3+)	; buffer <-- un lment	DEC.B	D2	JUMP,NE 32$	CLR.W	D7	TEST.W	D4	JUMP',EQ 40$	LOAD.L	A3,#(A6)+OPSBUI	CALL	USARTRECV	JUMP',NE 40$	LOAD.W	D7,#ERPREP	COMP.B	(A3)+1,#H'02	JUMP,EQ 30$40$:	PUSH.W	D7	LOAD.W	D6,(A6)+OPSCHI	FOS	?AVORT	POP.W	D7	JUMP,NE 80$; Cre tous les rendez-vous correspondant.	CALL	LOCK		; dbut de zone critique	LOAD.L	A3,A0	LOAD.W	D3,(A0)+2	ADD.W	D3,#250$:	CLR.W	D2	LOAD.B	D2,(A3+)	ADD.W	A3,D2		; A3 <-- ^rendez-vous suivant	DEC.W	D2	SUB.W	D3,D2	JUMP,LE 70$	LOAD.L	A4,#(A6)+ORDV	CLR.L	D4	LOAD.B	D4,(A3)+3	CALL	CONVBA		; D4 <-- anne	RL.L	D4,#8	LOAD.B	D4,(A3)+4	INC.B	D4	CALL	CONVBA		; D4 <-- mois	RL.L	D4,#8	LOAD.B	D4,(A3)+5	INC.B	D4	CALL	CONVBA		; D4 <-- jour	RL.L	D4,#8	CLR.W	D2	LOAD.B	D2,(A3)+6	CLR.W	(A4)+ORMMIN	MUL.WU	D2,#6	TEST.B	(A3)+7	JUMP',EQ 54$	ADD.B	D2,#30/10	LOAD.W	(A4)+ORMMIN,#3054$:	LOAD.B	D4,D2		; D4 <-- date |A|M|J|H|	CLR.W	(A4)+ORMSON	LOAD.L	(A4)+ORMFAN,#2^BRDVT1!2^BRDVUM!2^BRDVRN	CLR.W	D2	LOAD.B	D2,(A3)+8	JUMP',EQ 56$	DEC.W	D2	LOAD.W	(A4)+ORMSON,D2	TCLR.B	(A4)+ORMFAN+3:#BRDVT1-0	TSET.B	(A4)+ORMFAN+3:#BRDVT3-056$:	CLR.W	(A4)+ORMNBR	CLR.W	(A4)+ORMDUR	LOAD.L	A1,#(A4)+ORMTXT	LOAD.L	A2,#(A3)+9	LOAD.B	D2,(A3)+2	JUMP,EQ 50$58$:	LOAD.B	(A1+),(A2+)	DEC.B	D2	JUMP,NE 58$	CLR.B	(A1)	TEST.B	(A6)+OPSION+3:#BPSFUS-0	JUMP',BS 60$	CALL	RDVKILL		; supprime si existe dj	CALL	RDVCREATE	; cre un rendez-vous	JUMP,EQ 50$	JUMP'	70$60$:	CALL	RDVCREATEEV	; cre un rendez-vous si diffrent	JUMP,EQ 50$70$:	CALL	UNLOCK		; fin de zone critique80$:	PUSH.W	D7	LOAD.L	A4,A0	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D790$:	PUSH.W	D7;;?	CALL	USARTCLOSE	POP.W	D7	POPM.L	D0..D6,A0..A5	TEST.W	D7		; retour EQ/NE	RETCOM$:	.B	1	H'03	; demande les donnes	.EVEN;----------\\; PSDRECVLZ >;==========/; Lit tous les rendez-vous contenus dans le PSION-LZ.; in	-; out	D7.W	erreur; mod	D7.WPSDRECVLZ:	PUSHM.L	D0..D4,A0..A4	CALL	DBOXOPWAIT	; met la dbox d'attente;;?	CALL	USARTOPEN	CALL	USARTCLOSE	CALL	USARTOPEN	LOAD.L	D4,#50000+100	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande buffer temporaire	JUMP,NE 90$	LOAD.L	A0,A4		; A0 <-- ^dbut du buffer	LOAD.L	D0,D4; Lit tous les rendez-vous du PSION.	CALL	USARTREAD	; lit depuis l'usart	JUMP,NE 80$	CLR.B	(A4)+(D4.L)	LOAD.L	A3,A4		; A3 <-- ^rendez-vous lus; Cre tous les rendez-vous.	CALL	LOCK		; dbut de zone critique20$:	CLR.W	D7		; D7 <-- ok	COMP.B	(A3),#CARPEOF	; encore un rendez-vous ?	JUMP,EQ	70$		; non => 70$	TEST.B	(A3)	JUMP,EQ	70$	LOAD.L	A4,#(A6)+ORDV	CALL	ASCBCD		; D4 <-- anne (19..20)	JUMP,NE 70$	CALL	CONVAB	LOAD.B	D3,D4	CALL	ASCBCD		; D4 <-- anne (00..99)	JUMP,NE 70$	CALL	CONVAB	LOAD.W	D7,#ERPREP	COMP.B	D3,#19	JUMP',EQ 30$	COMP.B	D3,#20	JUMP,NE 70$	ADD.B	D4,#100	COMP.B	D4,#159		; anne > 2059 ?	JUMP,HS 70$30$:	CALL	CONVBA	LOAD.B	D3,D4	SL.L	D3,#8	CALL	ASCBCD		; D4 <-- mois	JUMP,NE 70$	LOAD.W	D7,#ERPREP	COMP.B	D4,#H'01	JUMP,LO 70$	COMP.B	D4,#H'12	JUMP,HI 70$	LOAD.B	D3,D4	SL.L	D3,#8	CALL	ASCBCD		; D4 <-- jour	JUMP,NE 70$	LOAD.W	D7,#ERPREP	COMP.B	D4,#H'01	JUMP,LO 70$	COMP.B	D4,#H'31	JUMP,HI 70$	LOAD.B	D3,D4	SL.L	D3,#8		; D3 <-- |A|M|J|-|	CALL	ASCBCD		; D4 <-- heure	JUMP,NE 70$	CALL	CONVAB	LOAD.W	D7,#ERPREP	COMP.B	D4,#23	JUMP,HI 70$	MUL.WU	D4,#6	LOAD.B	D3,D4	CALL	ASCBCD		; D4 <-- minutes	JUMP,NE 70$	CALL	CONVAB	LOAD.W	D7,#ERPREP	COMP.B	D4,#59	JUMP,HI 70$	LOAD.W	(A4)+ORMMIN,D4	COMP.B	D4,#30	JUMP',LO 32$	ADD.B	D3,#30/1032$:	CALL	ASCBCD		; D4 <-- dure	JUMP,NE 70$	CALL	CONVAB	COMP.W	D4,#1		; dure presque nulle (15 minutes) ?	JUMP',NE 33$		; non => 33$	DEC.W	D4		; D4 <-- met tout  fait zro !33$:	MUL.WU	D4,#15	LOAD.W	(A4)+ORMDUR,D4	CALL	ASCBCD		; D4 <-- sonnerie	JUMP,NE 70$	CALL	CONVAB	CLR.W	(A4)+ORMSON	LOAD.L	(A4)+ORMFAN,#2^BRDVT1!2^BRDVUM!2^BRDVRN	TEST.W	D4	JUMP',EQ 36$	DEC.W	D4	LOAD.W	(A4)+ORMSON,D4	TCLR.B	(A4)+ORMFAN+3:#BRDVT1-0	TSET.B	(A4)+ORMFAN+3:#BRDVT3-036$:	CLR.W	(A4)+ORMNBR	LOAD.L	D4,D3		; D4 <-- |A|M|J|H|	LOAD.W	D7,#ERPREP	COMP.B	(A3+),#TAB	JUMP',NE 70$	LOAD.L	A1,#(A4)+ORMTXT38$:	LOAD.B	D3,(A3+)	JUMP',EQ 70$	COMP.B	D3,#CR	JUMP',EQ 39$	LOAD.B	(A1+),D3	JUMP	38$39$:	CLR.B	(A1)	TEST.B	(A6)+OPSION+3:#BPSFUS-0	JUMP',BS 60$	CALL	RDVKILL		; supprime si existe dj	CALL	RDVCREATE	; cre un rendez-vous	JUMP,EQ 20$	JUMP'	70$60$:	CALL	RDVCREATEEV	; cre un rendez-vous si diffrent	JUMP,EQ 20$70$:	CALL	UNLOCK		; fin de zone critique80$:	PUSH.W	D7	LOAD.L	A4,A0	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D790$:	PUSH.W	D7;;?	CALL	USARTCLOSE	POP.W	D7	POPM.L	D0..D4,A0..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PSFSEND >;========/; Envoie un fichier sur le PSION.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WPSFSEND:	PUSHM.L	D1..D6,A3,A4	CALL	DBOXOPWAIT	; met la dbox d'attente;;?	CALL	USARTOPEN	CALL	USARTCLOSE	CALL	USARTOPEN	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; D4 <-- longueur du fichier source	LOAD.L	D2,D4		; D2 <-- longueur du fichier source	CLR.L	D3	CLR.L	D4	FOS	?SPOS	LOAD.L	D4,D2	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande de la mmoire	JUMP,NE 88$	FOS	?RDBYTE		; lit tout le fichier	JUMP',NE 86$	LOAD.L	A3,A4	LOAD.L	D2,D430$:	DEC.L	D2	JUMP',NS 35$	LOAD.B	D3,(A3)	CALL	NOACCENT	; enlve tous les accents !	LOAD.B	(A3+),D3	JUMP	30$35$:	CALL	USARTWRITE	; crit tout le fichier	JUMP',NE 86$	LOAD.B	(A4),#CARPEOF	LOAD.L	D4,#1	CALL	USARTWRITE	; crit le caractre de fin86$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D788$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	PUSH.W	D7;;?	CALL	USARTCLOSE	POP.W	D7	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PSFRECV >;========/; Reoit un fichier depuis le PSION.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WPSFRECV:	PUSHM.L	D1..D6,A3,A4	CALL	DBOXOPWAIT	; met la dbox d'attente;;?	CALL	USARTOPEN	CALL	USARTCLOSE	CALL	USARTOPEN	LOAD.L	D4,#50000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande de la mmoire	JUMP,NE 90$	CALL	USARTREAD	; lit depuis l'usart	JUMP,NE 88$20$:	CALL	DBOXOPWAIT	; met la dbox d'attente	PUSH.L	D4	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	POPM.L	D4	JUMP',EQ 30$	CALL	DBOXOPEN1	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	JUMP',NE 88$	CALL	DBOXCLOSE1	; remet les soft-keys	COMP.W	D3,#'O	JUMP',NE 88$	FOS	?DELETE	JUMP',NE 88$	JUMP	20$30$:	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE 88$	FOS	?WRBYTE		; crit tout le fichier	JUMP',NE 86$	FOS	?CLOSE	JUMP'	88$86$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D788$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D790$:	PUSH.W	D7;;?	CALL	USARTCLOSE	POP.W	D7	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; PSQUITTE >;=========/; Indique au PSION qu'il doit quitter le mode serveur.; in	-; out	D7.W	erreur; mod	D7.WPSQUITTE:	PUSHM.L	D4,A3;;?	CALL	USARTOPEN	LOAD.W	D4,#50/2	NTREL	?DELMS		; attend 1/2 seconde ...	LOAD.L	A3,#R16"COM$	CALL	USARTSEND	PUSH.W	D7;;?	CALL	USARTCLOSE	POP.W	D7	POPM.L	D4,A3	RETCOM$:	.B	1	H'FE	; demande de quitter	.EVEN; Processus de rception de l'usart; ---------------------------------NFILS2:	.ASCIZ	"PSION_READ"	.EVENPFILS2:	PUSH.W	D4		; place pour p'tit buffer10$:	LOAD.L	A4,SP		; A4 <-- ^p'tit buffer sur le stack	LOAD.L	D4,#1	LOAD.W	D6,(A6)+OPSCHI	FOS	?RDBYTE		; lit un byte ...	JUMP',NE 80$	CLR.W	D3	LOAD.B	D3,(A4)	CALL	PUTFIFO		; fifo <-- caractre	JUMP	10$80$:	LOAD.W	D3,#CARSEOF	CALL	PUTFIFO		; fifo <-- c'est fini	POP.W	D4		; ajuste le stack	NTREL	?ABORT;----------\\; USARTDIAL >;==========/; ; in	A3.L	^<lg>data; out	D7.W	erreur; mod	D7.WUSARTDIAL:	PUSHM.L	D4,A3	LOAD.W	D4,#20	NTREL	?DELMS		; attend que le PSION soit prt ...	CALL	USARTSEND	JUMP',NE 90$	LOAD.L	A3,#(A6)+OPSBUI	CALL	USARTRECV	JUMP',NE 90$	LOAD.W	D7,#ERPREP	COMP.B	(A3)+0,#2	; lg correcte ?	JUMP',NE 90$	COMP.B	(A3)+1,#H'FF	JUMP',NE 90$	LOAD.W	D7,#ERPSION	LOAD.B	D7,(A3)+2	; D7 <-- ok/erreur PSION	JUMP',NE 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTSEND >;==========/; Envoie une ligne du type :;;	head      check;	>--<      >--<;	 %$41424344F6<CR>;	   <------>;	     data; in	A3.L	^<lg>data; out	D7.W	erreur; mod	D7.WUSARTSEND:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,#(A6)+OPSBUO	LOAD.B	(A4+),#'%	LOAD.B	(A4+),#'$	LOAD.B	D2,(A3+)	; D2 <-- lg	CLR.B	D4		; D4 <-- check20$:	LOAD.B	D3,(A3+)	CALL	USARTSPUT	ADD.B	D4,D3	DEC.B	D2	JUMP,NE 20$	LOAD.B	D3,D4	NEG.B	D3	CALL	USARTSPUT	LOAD.B	(A4+),#CR	LOAD.L	A3,#(A6)+OPSBUO	LOAD.L	D4,A4	SUB.L	D4,A3	LOAD.L	A4,A3	CALL	USARTWRITE	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTSPUT >;----------/; Met deux digits hexadcimaux pour un byte.; in	D3.B	byte;	A4.L	^buffer; out	A4.L	^plus loin; mod	A4.LUSARTSPUT:	PUSH.W	D4	LOAD.B	D4,D3	SR.B	D4,#4	ADD.B	D4,#'0	COMP.B	D4,#'9	JUMP',LS 20$	ADD.B	D4,#'A-'9-120$:	LOAD.B	(A4+),D4	LOAD.B	D4,D3	AND.B	D4,#H'0F	ADD.B	D4,#'0	COMP.B	D4,#'9	JUMP',LS 30$	ADD.B	D4,#'A-'9-130$:	LOAD.B	(A4+),D4	POP.W	D4	RET;----------\\; USARTRECV >;==========/; Reoit une ligne.; in	A3.L	^buffer; out	(A3)	^<lg>data;	D7.W	erreur; mod	D7.WUSARTRECV:	PUSHM.L	D2..D4,A3,A410$:	CALL	USARTRWCA	; D3 <-- un caractre	JUMP,NE 90$	COMP.W	D3,#'%	JUMP,NE 10$	CALL	USARTRWCA	; D3 <-- un caractre	JUMP,NE 90$	COMP.W	D3,#'#	JUMP,NE 10$	LOAD.L	A4,#(A3)+1	CLR.B	D2		; D2 <-- lg	CLR.B	D4		; D4 <-- check30$:	CALL	USARTRGET	; D3 <-- un caractre	JUMP',NE 90$	COMP.W	D3,#CARSEOL	JUMP',EQ 40$	LOAD.B	(A4+),D3	; buffer <-- un caractre	ADD.B	D4,D3		; D4 <-- check	INC.B	D2	JUMP	30$40$:	DEC.B	D2	LOAD.B	(A3),D2		; buffer <-- <lg>	LOAD.W	D7,#ERPCHK	TEST.B	D4		; check correct ?	JUMP',NE 90$		; non => 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTRGET >;----------/; ; in	-; out	D3.W	byte lu;	D7.W	erreur; mod	D3.L, D7.WUSARTRGET:	PUSH.L	D4	CALL	USARTRWCA	; D3 <-- un caractre	JUMP',NE 90$	COMP.W	D3,#CARSEOL	JUMP',EQ 90$	COMP.B	D3,#'0	JUMP',LO 80$	COMP.B	D3,#'9	JUMP',LS 20$	COMP.B	D3,#'A	JUMP',LO 80$	COMP.B	D3,#'F	JUMP',HI 80$	SUB.B	D3,#'A-'9-120$:	SUB.B	D3,#'0	LOAD.B	D4,D3	SL.B	D4,#4	CALL	USARTRWCA	; D3 <-- un caractre	JUMP',NE 90$	COMP.W	D3,#CARSEOL	JUMP',EQ 90$	COMP.B	D3,#'0	JUMP',LO 80$	COMP.B	D3,#'9	JUMP',LS 40$	COMP.B	D3,#'A	JUMP',LO 80$	COMP.B	D3,#'F	JUMP',HI 80$	SUB.B	D3,#'A-'9-140$:	SUB.B	D3,#'0	OR.B	D3,D4	JUMP'	90$80$:	LOAD.W	D7,#ERPDIG90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTRWCA >;----------/; ; in	-; out	D3.W	caractre lu;	D7.W	erreur; mod	D3.L, D7.WUSARTRWCA:	PUSHM.L	D0,D4,A020$:	CALL	GETFIFO		; D3 <-- lit le fifo	JUMP',EQ 80$	LOAD.W	D4,#50/4	NTREL	?SETTIM	LIB	?GETCAR		; une touche presse ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE 20$		; non => 20$	COMP.W	D3,#END	JUMP,NE 20$	LOAD.W	D7,#ERPTIM	JUMP'	90$80$:	LOAD.W	D7,#ERPTIM	COMP.W	D3,#CARSEOF	JUMP',EQ 90$	COMP.B	D3,#CR	JUMP',NE 85$	LOAD.W	D3,#CARSEOL85$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D4,A0	TEST.W	D7		; retour EQ/NE	RET;-----------\\; USARTWRITE >;===========/; Ecrit dans l'usart.; in	A4.L	^data;	D4.L	longueur; out	D7.W	erreur; mod	D7.WUSARTWRITE:	PUSHM.L	D3,D4,D6	LOAD.W	D6,(A6)+OPSCHO	FOS	?WRBYTE	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTREAD >;==========/; Lit depuis l'usart.; in	A4.L	^buffer;	D4.L	lg max; out	D4.L	longueur lue;	D7.W	erreur; mod	D4.L, D7.W, A4.LUSARTREAD:	PUSHM.L	D3,D6	LOAD.W	D6,(A6)+OPSCHI	FOS	?RDBYTE	COMP.W	D7,#EROUTF	JUMP',NE 90$	TEST.L	D4	JUMP',EQ 90$	CLR.W	D790$:	POPM.L	D3,D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTOPEN >;==========/; Ouvre l'usart.; in	-; out	D7.W	erreur; mod	D7.WUSARTOPEN:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,#R16"TUSIN1	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE 90$	LOAD.W	(A6)+OPSCHI,D6	LOAD.L	A3,#R16"TUSOUT1	LOAD.W	D3,#2^BOPWR	FOS	?OPEN	JUMP',NE 90$	LOAD.W	(A6)+OPSCHO,D6	LOAD.L	A4,#R16"TCMIN	LOAD.W	D3,#TYPIO	LOAD.W	D6,(A6)+OPSCHI	FOS	?COMMAND;	JUMP',NE 90$	LOAD.L	A4,#R16"TCMOUT	LOAD.W	D3,#TYPIO	LOAD.W	D6,(A6)+OPSCHO	FOS	?COMMAND;	JUMP',NE 90$90$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; USARTCLOSE >;===========/; Ferme l'usart.; in	-; out	-; mod	-USARTCLOSE:	PUSHM.L	D6,D7	LOAD.W	D6,(A6)+OPSCHI	FOS	?CLOSE	LOAD.W	D6,(A6)+OPSCHO	FOS	?CLOSE	CLR.W	(A6)+OPSCHI	CLR.W	(A6)+OPSCHO	POPM.L	D6,D7	RET;--------\\; PUTFIFO >;========/; Met un caractre dans le fifo.; in	D3.W	caractre; out	D7.W	erreur; mod	D7.WPUTFIFO:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OFIFO	LOAD.W	D4,(A6)+OHEAD	ADD.W	A4,D4	LOAD.W	(A4+),D3	ADD.W	D4,#LGFIFO	COMP.W	D4,#LGFIFO*NBFIFO	JUMP',LO 30$	CLR.W	D430$:	LOAD.W	D7,#1		; D7 <-- fifo plein	COMP.W	D4,(A6)+OTAIL	JUMP',EQ 90$	LOAD.W	(A6)+OHEAD,D4	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETFIFO >;========/; Prend un caractre dans le fifo.; in	-; out	D3.W	canal;	D7.W	erreur; mod	D3.L, D7.WGETFIFO:	PUSHM.L	D4,A4	LOAD.W	D7,#1		; D7 <-- fifo vide	LOAD.W	D4,(A6)+OTAIL	COMP.W	D4,(A6)+OHEAD	JUMP',EQ 90$	LOAD.L	A4,#(A6)+OFIFO	ADD.W	A4,D4	LOAD.W	D3,(A4+)	ADD.W	D4,#LGFIFO	COMP.W	D4,#LGFIFO*NBFIFO	JUMP',LO 30$	CLR.W	D430$:	LOAD.W	(A6)+OTAIL,D4	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RETTUSIN1:	.ASCIZ	"#PR"TUSOUT1:.ASCIZ	"#PP"TCMIN:	.B	'N		; mode standard	.BW	'V,9600		; baud-rate	.BB	'Y,'E		; timeout par commande	.BW	'W,50*4		; timeout de 4 secondes	.BB	'F,'E		; fifo enable	.BB	'X,'E		; xon-xoff enable	.B	0TCMOUT:	.BW	'V,9600		; baud-rate	.BB	'Y,'E		; timeout par commande	.BW	'W,50*4		; timeout de 4 secondes;;?	.BB	'F,'E		; fifo enable	.BB	'X,'E		; xon-xoff enable	.B	0	.EVEN	.END