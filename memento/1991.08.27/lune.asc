	.TITLE	LUNE.ASC	.PROC	M680002	.REF	SMAKYERMMDAT	=	H'1111	.LOC	0OBUFF:	.BLKB	100LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.L	D4,#H'88010100	; 1.1.88	LOAD.W	D0,#3010$:	CALL	FETELUNE	JUMP,NE 50$	CALL	AFDATE	LIB	?AFSPACE	PUSH.L	D4	LOAD.B	D4,D3	LIB	?AFX2	POP.L	D4	LIB	?AFCR	DEC.W	D0	JUMP,EQ 90$50$:	CALL	CALCNJ	INC.L	D4	CALL	CALCJN	JUMP	10$90$:	EXITFETELUNE:	PUSHM.L	D4	CALL	CALCNJ	MUL.WU	D4,#60*24	SUB.L	D4,#21409	DIV.WU	D4,#29*60*24+12*60+44	SWAP.W	D4	CLR.W	D7	LOAD.B	D3,#1	COMP.W	D4,#60*24	JUMP',LO 90$	LOAD.B	D3,#2	COMP.W	D4,#(29*60*24+12*60+44)/4	JUMP',LO 80$	COMP.W	D4,#(29*60*24+12*60+44)/4+(60*24)	JUMP',LO 90$	LOAD.B	D3,#3	COMP.W	D4,#(29*60*24+12*60+44)/2	JUMP',LO 80$	COMP.W	D4,#(29*60*24+12*60+44)/2+(60*24)	JUMP',LO 90$	LOAD.B	D3,#4	COMP.W	D4,#(29*60*24+12*60+44)/4*3	JUMP',LO 80$	COMP.W	D4,#(29*60*24+12*60+44)/4*3+(60*24)	JUMP',LO 90$80$:	LOAD.W	D7,#190$:	POPM.L	D4	TEST.W	D7	RETAFDATE:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBUFF	CALL	DATEBCDASC	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBUFF	LIB	?AFTEXT	POPM.L	D3,D4,A3	RET;-----------\\; DATEBCDASC >;===========/; Transforme une date BCD --> ASCII.; in	D4.L	anne-mois-jour-heure en BCD;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LDATEBCDASC:	PUSHM.L	D2..D4	LOAD.W	D2,#3-1		; D2 <-- -1  cause NMO	JUMP'	22$20$:	LOAD.B	(A3+),#'/	; buffer <-- sparateur22$:	RR.L	D4,#8	LOAD.B	D3,D4	SR.B	D3,#4	ADD.B	D3,#'0	COMP.B	D3,#'9	JUMP',LS 40$	LOAD.B	(A3+),#'2	LOAD.B	(A3+),#'0	SUB.B	D3,#'9+140$:	LOAD.B	(A3+),D3	; buffer <-- dizaines	LOAD.B	D3,D4	AND.B	D3,#H'0F	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- units	DECJ.W,NMO D2,20$	POPM.L	D2..D4	RET;-----------\\; TIMEBCDASC >;===========/; Transforme une heure BCD --> ASCII.; in	D4.W	heure-minute en BCD;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LTIMEBCDASC:	PUSHM.L	D2..D4	LOAD.W	D2,#2-1		; D2 <-- -1  cause NMO	JUMP'	22$20$:	LOAD.B	(A3+),#':	; buffer <-- sparateur22$:	RR.W	D4,#8	LOAD.B	D3,D4	SR.B	D3,#4	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- dizaines	LOAD.B	D3,D4	AND.B	D3,#H'0F	ADD.B	D3,#'0	LOAD.B	(A3+),D3	; buffer <-- units	DECJ.W,NMO D2,20$	POPM.L	D2..D4	RET;--------\\; CALCJN  >;========/; Calcul une date d'aprs un nombre de jours fixe depuis le 01/01/1900.; in	D4.L	nombre de jours; out	D4.L	anne-mois-jour-heure en BCD;	D7.W	erreur; mod	D4.L, D7.WCALCJN:	PUSHM.L	D0..D3,D5,A0	LOAD.L	D5,D4		; D5 <-- nb de jours	CLR.L	D4	DIV.WU	D5,#(365*4)+1	LOAD.L	D3,D5	SWAP.W	D3	CLR.W	D2		; D2 <-- anne zro (bissextile)	COMP.W	D3,#365+1	JUMP',LO 20$	SUB.W	D3,#365+1	INC.W	D2		; D2 <-- anne un	COMP.W	D3,#365	JUMP',LO 20$	SUB.W	D3,#365	INC.W	D2		; D2 <-- anne deux	COMP.W	D3,#365	JUMP',LO 20$	SUB.W	D3,#365	INC.W	D2		; D2 <-- anne trois20$:	SL.W	D5,#2	ADD.W	D5,D2	LOAD.B	D4,D5		; D4 <-- anne	CALL	CONVBA		; D4 <-- anne en BCD	RR.L	D4,#8	LOAD.L	A0,#R16"TAMOIS+1	LOAD.W	D0,#1		; D0 <-- compte les mois40$:	CLR.W	D1	LOAD.B	D1,(A0+)	; D1 <-- nb de jours du mois	COMP.B	D1,#28		; mois de fvrier ?	JUMP',NE 45$		; non => 45$	TEST.W	D2		; anne bissextile ?	JUMP',NE 45$		; non => 45$	INC.W	D1		; oui => un jour de plus45$:	COMP.W	D3,D1		; est-on dans ce mois ?	JUMP',LO 50$		; oui => 50$	SUB.W	D3,D1	INC.W	D0		; D0 <-- mois suivant	JUMP	40$50$:	SWAP.W	D4	LOAD.B	D4,D0		; D4 <-- mois	CALL	CONVBA		; D4 <-- mois en BCD	SWAP.W	D4	INC.W	D3	RR.W	D4,#8	LOAD.B	D4,D3		; D4 <-- jour	CALL	CONVBA		; D4 <-- jour en BCD	RR.W	D4,#8	CLR.B	D4		; D4 <-- heure	POPM.L	D0..D3,D5,A0	CLR.W	D7		; D7 <-- ok	RET;--------\\; CALCJS  >;========/; Calcul le jour de la semaine en fonction d'une date; quelconque comprise dans le 20me sicle.; Pour cela, calcul le nombre de jour depuis une date de; rfrence fixe le 01/01/1900 (c'tait un dimanche).; in	D4.L	nombre de jours; out	D4.L	jour de la semaine 1..7 (lundi..dimanche);	D7.W	erreur; mod	D4.L, D7.WCALCJS:	DIV.WU	D4,#7		; divise par nb jour/semaine	SWAP.W	D4		; D4 <-- reste de la division	TEST.B	D4		; dimanche ?	JUMP',NE 80$		; non => 80$	LOAD.B	D4,#7		; oui => 780$:	AND.L	D4,#H'FF90$:	CLR.W	D7		; retour EQ	RET;--------\\; CALCNJ  >;========/; Calcul le nombre de jours depuis une date de rfrence; fixe le 01/01/1900.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	nombre de jours;	D7.W	erreur; mod	D4.L, D7.WCALCNJ:	PUSHM.L	D0..D3,D5,A0	LOAD.L	D5,D4		; D5 <-- anne-mois-jour-heure en BCD	LOAD.L	D0,#-1		; D0 <-- signal date fausse	CALL	CALCJX		; D3 <-- 28..31 (0 si erreur)	JUMP,NE 90$	LOAD.W	D7,#ERMMDAT	; D7 <-- date incorrecte	LOAD.W	D4,D5	RR.W	D4,#8		; D4 <-- jour (BCD)	CALL	CONVAB		; D4 <-- jour (binaire)	TEST.B	D4	JUMP,EQ	90$	COMP.B	D4,D3		; date correcte ?	JUMP,HI	90$		; non => 90$				; oui =>	DEC.B	D4		; D4 <-- 0..n	CLR.L	D0	LOAD.B	D0,D4		; D0 <-- nb jour depuis rf.	LOAD.L	D4,D5	RL.L	D4,#8		; D4 <-- anne (BCD)	CALL	CONVAB		; D4 <-- anne (binaire)	LOAD.B	D3,#00		; D3 <-- anne de rfrence	LOAD.B	D2,#-1		; D2 <-- compteur bissextile10$:	INC.B	D2	COMP.B	D3,D4	JUMP',HS 20$	ADD.L	D0,#365		; D0 <-- ajoute une anne	INC.B	D3		; D3 <-- anne suivante	AND.B	D2,#B'11	; anne bissextile ?	JUMP,NE	10$		; non => 10$	INC.L	D0		; oui => un jour de plus	JUMP	10$20$:	LOAD.L	D4,D5	SWAP.W	D4		; D4 <-- mois (BCD)	CALL	CONVAB		; D4 <-- mois (binaire)	LOAD.B	D3,#01		; D3 <-- mois de rfrence	LOAD.L	A0,#R16"TAMOIS+130$:	COMP.B	D3,D4	JUMP',HS 80$	INC.B	D3		; D3 <-- mois suivant	CLR.L	D1	LOAD.B	D1,(A0+)	; D1 <-- nb jours ce mois	COMP.B	D1,#28		; fvrier ?	JUMP',NE 35$		; non => 35$	AND.B	D2,#B'11	; anne bissextile ?	JUMP',NE 35$		; non => 35$	INC.B	D1		; D1 <-- 29 jours35$:	ADD.L	D0,D1		; D0 <-- ajoute un mois	JUMP	30$80$:	LOAD.L	D4,D0		; D4 <-- nb jours ou -1	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D3,D5,A0	TEST.W	D7		; retour EQ/NE	RET;--------\\; CALCJX  >;--------/; Calcul le nombre de jours dans un mois en tenant compte des; mois  28, 29, 30 et 31 jours.; in	D5.L	anne-mois-jour-heure en BCD; out	D3.B	jour max 28..31;	D7.W	erreur; mod	D3.B, D7.WCALCJX:	PUSHM.L	D4,A0	LOAD.W	D7,#ERMMDAT	; D7 <-- date incorrecte	LOAD.L	D4,D5	SWAP.W	D4		; D4 <-- mois (BCD)	CALL	CONVAB		; D4 <-- mois (binaire)	TEST.B	D4	JUMP',EQ 90$	COMP.B	D4,#12		; mois 1..12 ?	JUMP',HI 90$		; non => 90$	LOAD.L	A0,#R16"TAMOIS	; A0 <-- ^table	AND.W	D4,#H'00FF	LOAD.B	D3,(A0)+(D4.W)	; D3 <-- 28, 30 ou 31	COMP.B	D3,#28		; fvrier ?	JUMP',NE 80$		; non => 80$				; oui =>	LOAD.L	D4,D5	RL.L	D4,#8		; D4 <-- anne (BCD)	CALL	CONVAB		; D4 <-- anne (binaire)	AND.L	D4,#H'000000FF	DIV.WU	D4,#4	SWAP.W	D4		; D4 <-- reste	TEST.W	D4		; anne bissextile ?	JUMP',NE 80$		; non => 80$	INC.B	D3		; oui => 29 jours80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A0	TEST.W	D7		; retour EQ/NE	RETTAMOIS:	.B	0		;  0 = rien du tout	.B	31		;  1 = janvier	.B	28		;  2 = fvrier	.B	31		;  3 = mars	.B	30		;  4 = avril	.B	31		;  5 = mai	.B	30		;  6 = juin	.B	31		;  7 = juillet	.B	31		;  8 = aot	.B	30		;  9 = septembre	.B	31		; 10 = octobre	.B	30		; 11 = novembre	.B	31		; 12 = dcembre	.EVEN;--------\\; CALCNM  >;========/; Calcul le nombre de minutes depuis une heure de rfrence; fixe  00:00.; in	D4.W	heure-minute en BCD; out	D4.L	nombre de minutes;	D7.W	erreur; mod	D4.L, D7.WCALCNM:	PUSH.L	D3	CLR.L	D3	CALL	CONVAB		; D4 <-- nombre de minutes	LOAD.B	D3,D4	RR.W	D4,#8	CALL	CONVAB		; D4 <-- nombre d'heures	AND.W	D4,#H'00FF	MUL.WU	D4,#60	ADD.W	D3,D4	LOAD.L	D4,D3	POP.L	D3	CLR.W	D7		; retour EQ	RET;--------\\; CALCMN  >;========/; Calcul une heure d'aprs un nombre de minutes fixe depuis 00:00.; in	D4.W	nombre de minutes; out	D4.W	heure-minute en BCD;	D7.W	erreur; mod	D4.L, D7.WCALCMN:	PUSH.L	D3	AND.L	D4,#H'FFFF	DIV.WU	D4,#60	CALL	CONVBA		; D4 <-- heure en BCD	LOAD.B	D3,D4	RL.W	D3,#8	SWAP.W	D4	CALL	CONVBA		; D4 <-- minute en BCD	LOAD.B	D3,D4	LOAD.W	D4,D3	POP.L	D3	CLR.W	D7		; retour EQ	RET;--------\\; CONVAB  >;--------/; Converti BCD --> binaire.; in	D4.B	byte en BCD; out	D4.B	idem en binaire; mod	D4.BCONVAB:	PUSH.L	D3	CLR.W	D3	LOAD.B	D3,D4	SR.B	D3,#4		; D3 <-- dizaines	MUL.WU	D3,#10	AND.B	D4,#H'0F	; D4 <-- units	ADD.B	D4,D3		; D4 <-- units + dizaines	POP.L	D3	RET;--------\\; CONVBA  >;--------/; Converti binaire --> BCD.; in	D4.B	byte en binaire; out	D4.B	idem en BCD; mod	D4.BCONVBA:	PUSH.L	D3	CLR.L	D3	LOAD.B	D3,D4	DIV.WU	D3,#10		; D3 <-- |  | u|  | d|	SWAP.W	D3		; D3 <-- |  | d|  | u|	SL.W	D3,#8		; D3 <-- |  | d| u|  |	SL.W	D3,#4		; D3 <-- |  | d|u |  |	SL.L	D3,#4		; D3 <-- |  |du|  |  |	SWAP.W	D3		; D3 <-- |  |  |  |du|	LOAD.B	D4,D3	POP.L	D3	RETTABLE:	.L	H'88010400	.L	H'88011900	.L	H'88020200	.L	H'88021700	.L	H'88030300	.L	H'88031800	.L	H'88040200	.L	H'88041600	.L	H'88050100	.L	H'88051500	.L	H'88053100	.L	H'88061400	.L	H'88062900	.L	H'88071300	.L	H'88072900	.L	H'88081200	.L	H'88082700	.L	H'88091100	.L	H'88092500	.L	H'88101000	.L	H'88102500	.L	H'88110900	.L	H'88112300	.L	H'88120900	.L	H'88122300	.L	H'89010700	.L	H'89012100	.L	H'89020600	.L	H'89022000	.L	H'89030700	.L	H'89032200	.L	H'89040600	.L	H'89042100	.L	H'89050500	.L	H'89052000	.L	H'89060300	.L	H'89061900	.L	H'89070300	.L	H'89071800	.L	H'89080100	.L	H'89081700	.L	H'89083100	.L	H'89091500	.L	H'89092900	.L	H'89101400	.L	H'89102900	.L	H'89111300	.L	H'89112800	.L	H'89121200	.L	H'89122800	.L	H'90011100	.L	H'90012600	.L	0VAR:	.FILLB	LGVAR,0	.END	START