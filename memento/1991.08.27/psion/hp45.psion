HP45:LOCAL REG1,REG2,REG3,REG4,TEMPLOCAL K%,KEY%,I%,E%,HEX%,NBD%,MD%LOCAL VAL$(15),INPUT$(15)NBD%=2MD%=1UDG 0,$18,$18,$1E,$1B,$1B,$1B,$00,$00 :REM "h"UDG 1,$00,$00,$1E,$1B,$1B,$1E,$18,$18 :REM "p"UDG 2,$00,$08,$08,$0A,$0F,$02,$00,$00 :REM "4"UDG 3,$00,$1E,$10,$1C,$02,$1C,$00,$00 :REM "5"UDG 4,$00,$00,$15,$00,$00,$00,$00,$00 :REM "..."DO AT 1,4 IF MD%=0  PRINT "X: "; ENDIF IF I%=1  PRINT INPUT$;CHR$(26); ELSE  IF HEX%=0   VAL$=FIX$(REG1,NBD%,15)   IF ASC(VAL$)=%*    VAL$=GEN$(REG1,15)   ENDIF  ELSE   VAL$=HP45HD$:(REG1)  ENDIF  PRINT VAL$;CHR$(26); ENDIF IF MD%=0  AT 1,3 :PRINT "Y: ";  IF HEX%=0   VAL$=FIX$(REG2,NBD%,15)   IF ASC(VAL$)=%*    VAL$=GEN$(REG2,15)   ENDIF  ELSE   VAL$=HP45HD$:(REG2)  ENDIF  PRINT VAL$;CHR$(26);  AT 1,2 :PRINT "Z: ";  IF HEX%=0   VAL$=FIX$(REG3,NBD%,15)   IF ASC(VAL$)=%*    VAL$=GEN$(REG3,15)   ENDIF  ELSE   VAL$=HP45HD$:(REG3)  ENDIF  PRINT VAL$;CHR$(26);  AT 1,1 :PRINT "T: ";  IF HEX%=0   VAL$=FIX$(REG4,NBD%,15)   IF ASC(VAL$)=%*    VAL$=GEN$(REG4,15)   ENDIF  ELSE   VAL$=HP45HD$:(REG4)  ENDIF  PRINT VAL$;CHR$(26); ELSE  AT 1,1 :PRINT CHR$(0);CHR$(1);" ";CHR$(2);CHR$(3);CHR$(26);  AT 1,2 :PRINT REPT$(CHR$(4),20);  AT 1,3 :PRINT CHR$(26); ENDIF IF HEX%=1  AT 20,1 :PRINT "H"; ENDIF KSTAT 3 K%=GET IF HEX%=1  IF K%=%<   KEY%=%A  ELSEIF K%=%>   KEY%=%B  ELSEIF K%=%(   KEY%=%C  ELSEIF K%=%)   KEY%=%D  ELSEIF K%=%%   KEY%=%E  ELSEIF K%=%/   KEY%=%F  ELSEIF K%=%F   KEY%=%/  ELSE   KEY%=K%  ENDIF ELSE  KEY%=K% ENDIF IF (KEY%>=%0 AND KEY%<=%9) OR (KEY%>=%A AND KEY%<=%F) OR KEY%=%. OR KEY%=8  IF I%=0   IF E%=0    REG4=REG3    REG3=REG2    REG2=REG1   ENDIF   INPUT$=""   I%=1  ENDIF  IF KEY%=8   IF LEN(INPUT$)<>0    INPUT$=LEFT$(INPUT$,LEN(INPUT$)-1)   ENDIF  ELSE   INPUT$=INPUT$+CHR$(KEY%)  ENDIF  KEY%=0 ELSE  IF I%=1   IF HEX%=0    REG1=VAL(INPUT$)   ELSE    REG1=HP45DH:(INPUT$)   ENDIF   I%=0  ENDIF ENDIF E%=0 IF KEY%=13 :REM touche (EXE)  REG4=REG3  REG3=REG2  REG2=REG1  E%=1 ELSEIF KEY%=32 :REM touche (SPACE)  REG1=0  E%=1 ELSEIF KEY%=%+  REG1=REG2+REG1  REG2=REG3  REG3=REG4 ELSEIF KEY%=%-  REG1=REG2-REG1  REG2=REG3  REG3=REG4 ELSEIF KEY%=%*  REG1=REG2*REG1  REG2=REG3  REG3=REG4 ELSEIF KEY%=%/  IF REG1<>0   REG1=REG2/REG1   REG2=REG3   REG3=REG4  ELSE   AT 1,4 :PRINT "   error";CHR$(26);   BEEP 10,100 :K%=GET   E%=1  ENDIF ELSEIF KEY%=3 :REM touche (UP)  TEMP=REG4  REG4=REG3  REG3=REG2  REG2=REG1  REG1=TEMP ELSEIF KEY%=4 :REM touche (DOWN)  TEMP=REG1  REG1=REG2  REG2=REG3  REG3=REG4  REG4=TEMP ELSEIF KEY%=%= :REM touche (G)  IF MD%=0   MD%=1  ELSE   MD%=0  ENDIF ELSEIF KEY%=%" :REM touche (H)  IF HEX%=0   HEX%=1  ELSE   HEX%=0  ENDIF ELSEIF KEY%=%$ :REM touche (N)  NBD%=INT(REG1)  REG1=REG2  REG2=REG3  REG3=REG4 ELSEIF KEY%=%; :REM touche (S)  IF MD%=0   CLS  ENDIF  AT 1,3 :PRINT "Met dans la";CHR$(26);  AT 1,4 :PRINT "m";CHR$(130);"moire (0..9) :";CHR$(26);  KSTAT 3  K%=GET  IF     K%=%0 :M0=REG1  ELSEIF K%=%1 :M1=REG1  ELSEIF K%=%2 :M2=REG1  ELSEIF K%=%3 :M3=REG1  ELSEIF K%=%4 :M4=REG1  ELSEIF K%=%5 :M5=REG1  ELSEIF K%=%6 :M6=REG1  ELSEIF K%=%7 :M7=REG1  ELSEIF K%=%8 :M8=REG1  ELSEIF K%=%9 :M9=REG1  ENDIF ELSEIF KEY%=%: :REM touche (T)  IF MD%=0   CLS  ENDIF  AT 1,3 :PRINT "Reprend la";CHR$(26);  AT 1,4 :PRINT "m";CHR$(130);"moire (0..9) :";CHR$(26);  KSTAT 3  K%=GET  REG4=REG3  REG3=REG2  REG2=REG1  REG1=0  IF     K%=%0 :REG1=M0  ELSEIF K%=%1 :REG1=M1  ELSEIF K%=%2 :REG1=M2  ELSEIF K%=%3 :REG1=M3  ELSEIF K%=%4 :REG1=M4  ELSEIF K%=%5 :REG1=M5  ELSEIF K%=%6 :REG1=M6  ELSEIF K%=%7 :REG1=M7  ELSEIF K%=%8 :REG1=M8  ELSEIF K%=%9 :REG1=M9  ENDIF ELSEIF KEY%=2 :REM touche (MODE)  CLS  K%=MENUN(2,"1/X,SQR,X-Y,CHS,ABS,Y^X,DEG,RAD, ,LN,LOG,E^X,SIN,COS,TAN,ASIN,ACOS,ATAN")   IF K%=1    IF REG1<>0     REG1=1/REG1    ELSE     AT 1,4 :PRINT "   error";CHR$(26);     BEEP 10,100 :K%=GET    ENDIF   ELSEIF K%=2    REG1=SQR(REG1)   ELSEIF K%=3    TEMP=REG1    REG1=REG2    REG2=TEMP   ELSEIF K%=4    REG1=-REG1   ELSEIF K%=5    REG1=ABS(REG1)   ELSEIF K%=6    REG1=REG2**REG1    REG2=REG3    REG3=REG4   ELSEIF K%=7    REG1=DEG(REG1)   ELSEIF K%=8    REG1=RAD(REG1)   ELSEIF K%=9   ELSEIF K%=10    REG1=LN(REG1)   ELSEIF K%=11    REG1=LOG(REG1)   ELSEIF K%=12    REG1=EXP(REG1)   ELSEIF K%=13    REG1=SIN(REG1)   ELSEIF K%=14    REG1=COS(REG1)   ELSEIF K%=15    REG1=TAN(REG1)   ELSEIF K%=16    REG1=ASIN(REG1)   ELSEIF K%=17    REG1=ACOS(REG1)   ELSEIF K%=18    REG1=ATAN(REG1)   ENDIF   ELSEIF KEY%=1 :REM touche (ON)  STOP ELSE  IF KEY%<>0   BEEP 10,100  ENDIF ENDIFUNTIL 1=2