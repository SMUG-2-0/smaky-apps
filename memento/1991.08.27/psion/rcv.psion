RCV:LOCAL LINE$(250)LOCAL I%,L%,H%,C%,D%,Ps%,Pd%,CHK%ONERR ERROR::LINE$=LINPUT$:(250)ONERR OFFI%=LOC(LINE$,"%$")IF I%=0 CODr$=CHR$($FF)+CHR$(4)ELSE Ps%=ADDR(LINE$)+I%+2 Pd%=ADDR(CODr$)+1 C%=(LEN(LINE$)-I%-1)/2 IF C%<2  CODr$=CHR$($FF)+CHR$(3) ELSE  POKEB Pd%-1,C%-1  CHK%=0  DO   H%=PEEKB(Ps%): Ps%=Ps%+1   H%=H%-48 :IF H%>9 :H%=H%-7 :ENDIF   L%=PEEKB(Ps%): Ps%=Ps%+1   L%=L%-48 :IF L%>9 :L%=L%-7 :ENDIF   D%=16*H%+L%   POKEB Pd%,D% :Pd%=Pd%+1   CHK%=(CHK%+D%) AND $FF   C%=C%-1  UNTIL C%=0  IF CHK%<>0   CODr$=CHR$($FF)+CHR$(2)  ENDIF ENDIFENDIFRETURNERROR::CODr$=CHR$($FF)+CHR$(1)RETURN