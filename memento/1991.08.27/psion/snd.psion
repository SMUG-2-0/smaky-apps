SND:LOCAL LINE$(250)LOCAL L%,H%,C%,D%,Ps%,Pd%,CHK%Ps%=ADDR(CODs$)+1Pd%=ADDR(LINE$)+1C%=LEN(CODs$)POKEB Pd%-1,(C%*2)+4POKEB Pd%,%% :Pd%=Pd%+1POKEB Pd%,%# :Pd%=Pd%+1CHK%=0DO D%=PEEKB(Ps%): Ps%=Ps%+1 H%=(D%/16)+%0 :IF H%>%9 :H%=H%+7 :ENDIF L%=(D% AND $F)+%0 :IF L%>%9 :L%=L%+7 :ENDIF POKEB Pd%,H% :Pd%=Pd%+1 POKEB Pd%,L% :Pd%=Pd%+1 CHK%=(CHK%+D%) AND $FF C%=C%-1UNTIL C%=0CHK%=$100-CHK%H%=(CHK%/16)+%0 :IF H%>%9 :H%=H%+7 :ENDIFL%=(CHK% AND $F)+%0 :IF L%>%9 :L%=L%+7 :ENDIFPOKEB Pd%,H% :Pd%=Pd%+1POKEB Pd%,L% :Pd%=Pd%+1LPRINT LINE$