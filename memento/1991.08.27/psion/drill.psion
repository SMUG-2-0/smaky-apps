DRILL:LOCAL M%,OP1%,OP2%,NB%,REP%,SOL%,JUSTE%,FAUX%LOCAL VMAX%,T1%,MUS%UDG 0,$0E,$15,$1F,$11,$1F,$0E,$00,$1FUDG 1,$11,$0A,$04,$0A,$11,$00,$00,$1FUDG 2,$00,$00,$00,$00,$00,$00,$00,$1FCLS :PRINT CHR$(0);REPT$(CHR$(2),14)CLOCK(1)M%=MENUN(2,"Addition,Soustraction,Multiplication,Division     ,Quitte")IF M%=0 OR M%=5 RETURNELSE POKEB $77,$FF :REM plus de repeat CLS :PRINT REPT$(CHR$(2),15) CLOCK(1) AT 1,3 :PRINT "Valeur max = "; TRAP INPUT VMAX% :IF ERR=206 :GOTO QUITTE:: :ENDIF AT 1,4 :PRINT "Musiques? O/N"; MUS%=GET NB%=0 JUSTE%=0 :FAUX%=0 T1%=MINUTE*60+SECOND DO  OP1%=2+INT(RND*(VMAX%-1))  OP2%=2+INT(RND*(VMAX%-1))  IF M%=1   SOL%=OP1%+OP2%  ELSEIF M%=2   SOL%=OP1%  ELSEIF M%=3   SOL%=OP1%*OP2%  ELSEIF M%=4   SOL%=OP1%  ENDIF  PRINT CHR$(15);CHR$(22);CHR$(23); :AT 1,3  IF M%=1   PRINT OP1%;" + ";OP2%;" = ";  ELSEIF M%=2   PRINT OP1%+OP2%;" - ";OP2%;" = ";  ELSEIF M%=3   PRINT OP1%;" x ";OP2%;" = ";  ELSEIF M%=4   PRINT OP1%*OP2%;" ";CHR$(253);" ";OP2%;" = ";  ENDIF  TRAP INPUT REP% :IF ERR=206 :GOTO QUITTE:: :ENDIF  IF REP%=SOL%   PRINT "Juste";   JUSTE%=JUSTE%+1   AT NB%+1,1 :PRINT CHR$(0);   IF MUS%=%O    BEEP 100,200 :BEEP 100,160 :BEEP 100,120 :BEEP 200,80   ENDIF   PAUSE 40  ELSE   IF MUS%=%O    BEEP 400,1000   ENDIF   AT 1,2 :PRINT "Essaye encore ..."   PRINT CHR$(22);CHR$(23); :AT 1,3   IF M%=1    PRINT OP1%;" + ";OP2%;" = ";   ELSEIF M%=2    PRINT OP1%+OP2%;" - ";OP2%;" = ";   ELSEIF M%=3    PRINT OP1%;" x ";OP2%;" = ";   ELSEIF M%=4    PRINT OP1%*OP2%;" ";CHR$(253);" ";OP2%;" = ";   ENDIF   TRAP INPUT REP% :IF ERR=206 :GOTO QUITTE:: :ENDIF   PRINT CHR$(15); :AT 1,4   IF REP%=SOL%    PRINT "Juste";    JUSTE%=JUSTE%+1    AT NB%+1,1 :PRINT CHR$(0);    IF MUS%=%O     BEEP 100,200 :BEEP 100,160 :BEEP 100,120 :BEEP 200,80    ENDIF    PAUSE 40   ELSE    IF REP%=SOL%+1 OR REP%=SOL%-1     PRINT "Presque, = ";SOL%;    ELSE     PRINT "Faux, = ";SOL%;    ENDIF    FAUX%=FAUX%+1    AT NB%+1,1 :PRINT CHR$(1);    IF MUS%=%O     BEEP 200,700 :BEEP 200,800 :BEEP 200,900 :BEEP 400,1000    ENDIF    PAUSE 80   ENDIF  ENDIF  NB%=NB%+1 UNTIL NB%=10 T1%=(MINUTE*60+SECOND)-T1% PRINT CHR$(15);CHR$(22);CHR$(23); :AT 1,3 PRINT "JUSTE: ";JUSTE% PRINT " FAUX: ";FAUX%;"    ";T1%;"""" IF MUS%=%O  IF FAUX%=0   BEEP 100,200 :BEEP 100,160 :BEEP 100,120 :BEEP 200,80   BEEP 100,200 :BEEP 100,160 :BEEP 100,120 :BEEP 200,80   BEEP 100,200 :BEEP 100,160 :BEEP 100,120 :BEEP 200,80  ELSE   BEEP 200,700 :BEEP 200,800 :BEEP 200,900 :BEEP 400,1000   BEEP 200,700 :BEEP 200,800 :BEEP 200,900 :BEEP 400,1000   BEEP 200,700 :BEEP 200,800 :BEEP 200,900 :BEEP 400,1000  ENDIF ENDIFGETENDIFQUITTE::POKEB $77,$0E :REM remet le repeat