MON:LOCAL OP1%,OP2%,OP3%,ADR$(4),ADR%,DATA%,DEL%,I%DEL%=PEEKW($6B) :POKEW $6B,1OP3%=1DO OP1%=MENU("READ,WRITE,QUIT") IF OP1%=1  PRINT "ADDR = "; :KSTAT 3 :INPUT ADR$ :ADR%=DECHEX:(ADR$)  DO   PRINT "(";HEX$(ADR%);")=";   IF OP3%=1    DATA%=PEEKB(ADR%)    PRINT FIX$(DATA%,0,-3);" ";    IF DATA%<16 :PRINT "0"; :ENDIF    PRINT HEX$(DATA%);" ";    IF DATA%>31 AND DATA%<127     PRINT CHR$(DATA%)    ELSE     PRINT CHR$($FF)    ENDIF    I%=1   ELSE    PRINT " ";    I%=0    DO     DATA%=PEEKB(ADR%+I%)     IF DATA%>31 AND DATA%<127      PRINT CHR$(DATA%);     ELSE      PRINT CHR$($FF);     ENDIF     I%=I%+1    UNTIL I%=8    PRINT   ENDIF   OP2%=GET   IF OP2%=3 :ADR%=ADR%-I% :ENDIF   IF OP2%=4 :ADR%=ADR%+I% :ENDIF   IF OP2%=2 :IF OP3%=1 :OP3%=2 :ELSE :OP3%=1 :ENDIF :ENDIF  UNTIL OP2%=1 ELSEIF OP1%=2  PRINT "DATA = "; :INPUT DATA%  POKEB ADR%,DATA% ENDIFUNTIL OP1%=0 OR OP1%=3POKEW $6B,DEL%