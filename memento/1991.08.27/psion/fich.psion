FICH:LOCAL F$(10),N$(8),OPT%,G%,L%L%=1OPT::OPT%=MENU("RENOMME,DETRUIT,CATALOGUE,LIBRE")IF OPT%=1 RMORE:: CLS :PRINT "NOM A CHANGER:" TRAP INPUT F$ IF ERR=206 :GOTO RRET:: :ENDIF N$=UPPER$(LEFT$(F$,1)) IF F$=""  GOTO RRET:: ELSEIF (N$<"A") OR (N$>"C") OR (MID$(F$,2,1)<>":")  BEEP 200,100 :PRINT "NOM FICH ILLEGAL" :GET :GOTO RMORE:: ELSEIF EXIST(F$)  RNEW::  CLS :PRINT "NOUVEAU NOM:"  TRAP INPUT N$  IF ERR=206 :GOTO RRET:: :ENDIF  TRAP RENAME F$,N$  IF ERR   BEEP 200,100 :PRINT ERR$(ERR) :GET :GOTO RNEW::  ENDIF ELSE  BEEP 200,100 :PRINT "FICH PAS TROUVE" :GET :GOTO RMORE:: ENDIF RRET::ELSEIF OPT%=2 DMORE:: CLS :PRINT "FICH A DETRUIRE:"; TRAP INPUT F$ IF ERR=206 :GOTO DRET:: :ENDIF N$=UPPER$(LEFT$(F$,1)) IF F$=""  GOTO DRET:: ELSEIF (N$<"A") OR (N$>"C") OR (MID$(F$,2,1)<>":")  BEEP 200,100 :PRINT "NOM FICH ILLEGAL" :GET :GOTO DMORE:: ELSEIF EXIST(F$)  DELETE F$ :PRINT "DETRUIT" :GET ELSE  BEEP 200,100 :PRINT "FICH PAS TROUVE" :GET :GOTO DMORE:: ENDIF DRET::ELSEIF OPT%=3 ONERR CMORE:: L%=L%-1 CLOC:: L%=L%+1 :IF L%>3 :L%=1 :ENDIF CMORE:: N$=CHR$(64+L%)+":" CLS :CURSOR OFF :PRINT "CATALOGUE",N$; G%=GET IF G%=2  GOTO CLOC:: ELSEIF G%=1  GOTO CRET:: ELSEIF G%=13  CLS  DO   F$=DIR$(N$)   PRINT F$   IF F$=""    CLS :PRINT "******************FIN DU PACK***"    GET :GOTO CRET::   ENDIF   N$=""   G%=GET  UNTIL G%=1 OR F$="" ELSE  GOTO CMORE:: ENDIF CRET:: CURSOR ON :ONERR OFFELSEIF OPT%=4 ONERR LMORE:: L%=L%-1 LLOC:: L%=L%+1 :IF L%>3 :L%=1 :ENDIF LMORE:: N$=CHR$(64+L%)+":" CLS :CURSOR OFF :PRINT "LIBRE",N$; G%=GET IF G%=2  GOTO LLOC:: ELSEIF G%=1  GOTO LRET:: ELSEIF G%=13  CLS  OPEN N$+"MAIN",A,T$  PRINT "LIBRE =",SPACE :GET  CLOSE ELSE  GOTO LMORE:: ENDIF LRET:: CURSOR ON :ONERR OFFELSE RETURNENDIFGOTO OPT::