SMAKY:GLOBAL CODr$(128),CODs$(128)LOCAL OP1%,OP2%,SINT%,ADR%,LG%,KO%,NB%,ER%,I%,P%LSET:(9600,0,8,2,1,1,0,CHR$(13),CHR$(26),"",CHR$(13),"","",0)DO CLS :PRINT "Attend SMAKY..." RCV: OP1%=ASC(MID$(CODr$,1,1)) IF OP1%=$FF  ER%=ASC(MID$(CODr$,2,1))  IF ER%=1   STOP  ELSE   AT 1,2 :PRINT "Erreur ";ER%   SND:  ENDIF ELSEIF OP1%=$01  CLS :PRINT "Reception AGENDA"  LG%=256*ASC(MID$(CODr$,2,1))+ASC(MID$(CODr$,3,1))  KO%=0 :NB%=0  SINT%=ASS:(0,"B6233518070F7F23357F234A0639") :REM IntDisable  I%=ASS:(0,"CE20043F05CE0000DF411809182705CE20043F0439") :REM ClrMem  ADR%=ASS:(LG%,"CE0000DF41CE20043F022506CE2004EE0039CE000039") :REM NewMem  IF ADR%=0   AT 1,2 :PRINT "Memoire pleine"   CODs$=CHR$($FF)+CHR$(5) :SND:  ELSE   CODs$=CHR$($FF)+CHR$(0) :SND:   DO    RCV:    OP2%=ASC(MID$(CODr$,1,1))    IF OP2%=$02     I%=2     DO      POKEB ADR%,ASC(MID$(CODr$,I%,1))      ADR%=ADR%+1      I%=I%+1     UNTIL I%>LEN(CODr$)     LG%=LG%-I%+2     NB%=NB%+1 :AT 1,2 :PRINT NB%     CODs$=CHR$($FF)+CHR$(0) :SND:    ELSE     AT 1,2: PRINT "Op=";OP2%;" inconnu"     CODs$=CHR$($FF)+CHR$(6) :SND:     KO%=1    ENDIF   UNTIL LG%<=0 OR KO%=1  ENDIF  IF KO%=0   AT 1,2: PRINT "OK   "  ELSE   I%=ASS:(0,"CE20043F05CE0000DF411809182705CE20043F0439") :REM ClrMem  ENDIF  I%=ASS:(SINT%,"7F23357F234AB7233539") :REM IntEnable ELSEIF OP1%=$03  CLS :PRINT "Envoi AGENDA"  SINT%=ASS:(0,"B6233518070F7F23357F234A0639") :REM IntDisable  LG%=ASS:(0,"CE20043F05180939") :REM GetMem  CODs$=CHR$($01)+CHR$(LG%/256)+CHR$(LG% AND $FF) :SND:  NB%=0  ADR%=PEEKW($2004)  I%=7+PEEKB(ADR%)  WHILE I%>7   P%=ADDR(CODs$)+2   POKEB P%-2,I%+1   POKEB P%-1,$02   DO    POKEB P%,PEEKB(ADR%) :P%=P%+1 :ADR%=ADR%+1    I%=I%-1   UNTIL I%=0   I%=7+PEEKB(ADR%)   NB%=NB%+1 :AT 1,2 :PRINT NB%   SND:  ENDWH  I%=ASS:(SINT%,"7F23357F234AB7233539") :REM IntEnable ELSEIF OP1%=$FE  STOP ELSE  AT 1,2: PRINT "Op=";OP1%;" inconnu"  CODs$=CHR$($FF)+CHR$(6) :SND: ENDIFUNTIL 0