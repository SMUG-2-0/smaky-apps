bulateurs; En-tte d'un fichier .MEMENTO; -----------------------------	.LOC	0OHREV:	.BLKB	2		; rvision et versionOHINFO:	.BLKB	4		; informationsOHPSION:.BLKB	4		; fanions PSION	.BLKB	246		; rserveLHEAD:; Description d'un rendez-vous; ----------------------------MAXRDV	=	2000		; nb max de rendez-vousLMTRDV	=	62		; lg max d'un texte de rendez-vousBRDVT1	=	0		; type: commentaireBRDVT2	=	1		; type: peu importantBRDVT3	=	2		; type: normalBRDVT4	=	3		; type: trs importantBRDVEX	=	5		; type: excuteBRDVUM	=	6		; unit: minutesBRDVUH	=	7		; unit: heuresBRDVRN	=	8		; rptition: ancuneBRDVRJ	=	9		; rptition: journalireBRDVRH	=	10		; rptition: hebdomadaireBRDVRM	=	11		; rptition: mensuelleBRDVRA	=	12		; rptition: annuelleBRDVRX1	=	16		; rptition: lundiBRDVRX2	=	17		; rptition: mardiBRDVRX3	=	18		; rptition: mercrediBRDVRX4	=	19		; rptition: jeudiBRDVRX5	=	20		; rptition: vendrediBRDVRX6	=	21		; rptition: samediBRDVRX7	=	22		; rptition: dimancheBRDVQS	=	31		; quittance sonnerie	.LOC	0ORMLG:	.BLKB	2		; longueur totaleORMFAN:	.BLKB	4		; fanionsORMNBR:	.BLKB	2		; nb de rptitionsORMDUR:	.BLKB	2		; dure en minutesORMSON:	.BLKB	2		; nombre de minutes avantORMMIN:	.BLKB	2		; minutes	.BLKB	14		; rserve	.BLKB	2		; place juste avant ORMTXT !ORMTXT:				; texte <0>; Couleurs; --------COLORBASE	= H'8000COLORFLIVRE	= COLORBASE+1	; fond  livreCOLORCLIVRE	= COLORBASE+2	; chair livreCOLORCONTENU	= COLORBASE+3	; contenuCOLORRDV	= COLORBASE+4	; rendez-vousCOLORDESSIN	= COLORBASE+5	; dessinCOLORICONES	= COLORBASE+6	; icnesCOLORSAMEDI	= COLORBASE+7	; samedisCOLORDIMANCHE	= COLORBASE+8	; dimanchesCOLORFETE	= COLORBASE+9	; ftesCOLORLUNE	= COLORBASE+10	; lune; Variables communes  tous les MEMENTO.CODE en excution; -------------------------------------------------------STFIRST	=	1		; premier dmarrage normalSTSLEEP	=	2		; premier dmarrage en veilleuse (MEMENTO/V)STWORK	=	3		; passe de veilleuse  normal	.LOC	0OCNBEX:	.BLKB	2		; nb d'excutions (0..n)OCSLP:	.BLKB	1		; 1 => MEMENTO endormi	.EVENOCPSEM:	.BLKB	4		; ^smaphoreLGCVAR:; Variables; ---------LBUDIS	=	200	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHICOLOR:.BLKB	2		; canal module ICOLOROPLCOM:	.BLKB	4		; ^ligne de commandeOPDDIS:	.BLKB	4		; ^descripteur de la fentreOSDDIS:	.BLKB	LGDIS6		; copie du descripteur de la fentreONOWDO:	.BLKB	2		; no swdoOWAITCH:.BLKB	4		; canal dbox-waitOIDCRET:.BLKB	4		; identificateur CRETOBUDIS:	.BLKB	LBUDIS		; buffer write-displayOTAICO:	.BLKB	20*10		; table des icnesOLUMAM:	.BLKB	250		; matrice(s) du lutin de la sourisOLUPX:	.BLKB	2		; centre du lutin en XOLUPY:	.BLKB	2		; centre du lutin en YOLUTIN:	.BLKB	1		; no lutin de la souris	.EVENOPARMM:	.BLKB	LMM*5		; paramtres mmenus du milieuOPARMD:	.BLKB	LMM*1		; paramtres mmenus de droiteOPSEM:	.BLKB	4		; ^smaphoreOBUCOM:	.BLKB	LMTRDV+30	; buffer command-clockOABORT:	.BLKB	1		; 1 => fin du processus fils	.EVENOPIMF:	.BLKB	4		; ^image de fond (nb)OPIMO:	.BLKB	4		; ^image original (c)OPIMU:	.BLKB	4		; ^image d'annulation (nb)OPIMD:	.BLKB	4		; ^image de dessin (nb)ODIMD:	.BLKB	4		; date de l'image de dessinOMIMD:	.BLKB	1		; 0 => image de dessin  jour	.EVENOPGCX:	.BLKB	4		; ^gencar par dfautOPGC0:	.BLKB	4		; ^gencar 0OPGC1:	.BLKB	4		; ^gencar 1OPGC2:	.BLKB	4		; ^gencar 2OPGC3:	.BLKB	4		; ^gencar 3OPGC4:	.BLKB	4		; ^gencar 4OMCY:	.BLKB	2OMCX:	.BLKB	2OAPOS:	.BLKB	4		; affiche: position de la sourisOALGY:	.BLKB	2		; affiche: hauteur suppl. a dtecterOADET:	.BLKB	4		; affiche: date dtecteOADATA:	.BLKB	4		; affiche: data pour dtectionOINFO:	.BLKB	4		; informationsODESS:	.BLKB	4		; mode de dessinOOPER:	.BLKB	2		; oprationOTYPE:	.BLKB	2		; type de reprsentationOHERE:	.BLKB	4		; date couranteODATE:	.BLKB	4		; date de dbut d'affichageORDVDP:	.BLKB	MAXRDV*8	; rendez-vous: table des date/^rdvORDVNB:	.BLKB	2		; rendez-vous: nombreORDVMP:	.BLKB	4		; rendez-vous: ^table pour NEXTORDVMN:	.BLKB	2		; rendez-vous: nombre pour NEXT	.BLKB	4		; rendez-vous: place pour date (i/o)ORDV:	.BLKB	ORMTXT+LMTRDV	; rendez-vous: en ditionORDVLS:	.BLKB	ORMTXT+LMTRDV	; rendez-vous: dernier ditORDVMJ:	.BLKB	1		; rendez-vous: 1 => mj. ncessaire	.EVENOLISLV:	.BLKB	LSLVAR		; list: variables de la scroll-listOFILNAM:.BLKB	LBUNAM		; nom du fichierOFILIMA:.BLKB	LBUNAM		; nom de l'image  ajouterOFILTXT:.BLKB	LBUNAM		; nom du texte  sauverOFILPSI:.BLKB	LBUNAM		; nom du fichier PSIONOFILORI:.BLKB	LBUNAM		; nom du fichier d'origineOFILNMS:.BLKB	LBUNAM		; nom du fichier sourceOFILNMD:.BLKB	LBUNAM		; nom du fichier destinationOFILFAN:.BLKB	4		; fanionsOCHIO:	.BLKB	2		; canal pour entre/sortieOTMIO:	.BLKB	LTMIO		; buffer tamponOPTIO:	.BLKB	2		; ^relatif dans OTMIOONBIO:	.BLKB	2		; reste dans OTMIOOPSION:	.BLKB	4		; PSION: fanionsOPSCHI:	.BLKB	2		; PSION: canal usart "in"OPSCHO:	.BLKB	2		; PSION: canal usart "out"OPSBUI:	.BLKB	200		; PSION: buffer "in"OPSBUO:	.BLKB	200		; PSION: buffer "out"OHEAD:	.BLKB	2		; fifo: ^tteOTAIL:	.BLKB	2		; fifo: ^queueOFIFO:	.BLKB	LGFIFO*NBFIFO	; fifo: contenuLGVAR:; Programme; ---------	.LOC	0ADCODE:	JUMP	START; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMICOLOR:	.ASCIZ	"ICOLOR"NMMEMENTO:	.ASCIZ	"MEMENTO"; Noms des fichiers; -----------------NMIMA:		.ASCIZ	"#:MEMENTO.IMAGE"NMIMA1:		.ASCIZ	"#:MEMENTO1.IMAGE"NMIMA2S:	.ASCII	"#:"NMIMA2:		.ASCIZ	"MEMENTO2.IMAGE"NMIMA3:		.ASCIZ	"#:MEMENTO3.IMAGE"; Erreurs fatales; ---------------TXERFATREV:	.ASCIZ	"La rvision du systme est incompatible"TXERFATDIS:	.ASCIZ	"Driver d'cran incompatible"TXERFATGRA:	.ASCIZ	"Module GRA incompatible"TXERFATTX0:	.ASCIZ	"Erreur avec le gencar IMP08"TXERFATTX1:	.ASCIZ	"Erreur avec le gencar IMP10"TXERFATTX2:	.ASCIZ	"Erreur avec le gencar IMP12"TXERFATTX3:	.ASCIZ	"Erreur avec le gencar IMP17"TXERFATTX4:	.ASCIZ	"Erreur avec le gencar IMP24"	.EVEN; Couleurs relatives; ------------------TCOUL:	.L	COLORFLIVRE	.W	-1,-1,-1	.ASCIZE	"fond des pages"	.L	COLORCLIVRE	.W	0,0,0	.ASCIZE	"cadre du livre"	.L	COLORCONTENU	.W	0,0,0	.ASCIZE	"inscriptions fixes"	.L	COLORRDV	.W	0,0,0	.ASCIZE	"inscriptions des rendez-vous"	.L	COLORDESSIN	.W	0,0,0	.ASCIZE	"dessin  main leve"	.L	COLORICONES	.W	0,0,0	.B	1	.ASCIZE	"icnes (en haut de la page de droite)"	.L	COLORSAMEDI	.W	-1,-1,-1	.ASCIZE	"samedis"	.L	COLORDIMANCHE	.W	-1,-1,-1	.ASCIZE	"dimanches"	.L	COLORFETE	.W	0,0,0	.ASCIZE	"ftes"	.L	COLORLUNE	.W	0,0,0	.ASCIZE	"phases de la lune"	.L	0; Programme; ---------START:	LOAD.L	A4,#R16"ADCODE	LOAD.L	D4,#LGCVAR	FOS	?GETCOMMEM	; A4 <-- ^variables communes	JUMP',NE 15$	TEST.W	(A4)+OCNBEX	; est-ce la premire excution ?	JUMP',EQ 20$		; oui => 20$				; non =>	TEST.B	(A4)+OCSLP	; y a-t-il un MEMENTO endormi ?	JUMP',EQ 15$		; non => 15$	LOAD.L	A5,(A4)+OCPSEM	NTREL	?SIGNEV		; rveille le MEMENTO qui dormait ..15$:	FOS	?STOP20$:	CLR.W	D4	NTREL	?CRESEM	JUMP,NE 15$	LOAD.L	(A4)+OCPSEM,A5	INC.W	(A4)+OCNBEX	; une excution de plus	LOAD.W	D0,#STFIRST	; D0 <-- premire excution normale	LOAD.B	D3,#'V	CALL	_IFSWITCH	; MEMENTO/V ? (LIB,?IFSWITCH pas utilisable, voir (*))	JUMP',NE REEXEC	LOAD.W	D0,#STSLEEP	; D0 <-- excution directement en veilleuseREEXEC:	COMP.W	D0,#STSLEEP	; excution directement en veilleuse ?	JUMP',EQ 10$		; oui => 10$	CALL	RACUNIT		; fait le LIB,?OPELIB	JUMP,NE ERFAT1	LOAD.W	D3,#2	LIB	?MOUSE10$:	COMP.W	D0,#STWORK	; rveil ?	JUMP',EQ 12$		; oui => 12$	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour les variables	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	; met TOUTES les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	LOAD.L	(A6)+OPSION,#2^BPSMEM!2^BPSSND!2^BPSXP12$:	COMP.W	D0,#STFIRST	; premire excution ?	JUMP',NE 14$		; non => 14$	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*5+5	; est-ce au moins 5.5 ?	JUMP,LO ERFAT2		; non => ERFAT214$:	COMP.W	D0,#STSLEEP	; excution directement en veilleuse ?	JUMP,EQ 60$		; oui => 60$	LOAD.L	A3,#R16"TXERFATDIS	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT2	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	COMP.W	(A0)+ODFIIX,#1	; cran de type SMAKY100/324 ?	JUMP,NE ERFAT2		; non => patatras ...	COMP.W	D0,#STFIRST	; premire excution ?	JUMP',NE 16$		; non => 16$	LOAD.L	A3,#R16"NMIMA	CALL	IMAOPEN		; charge l'image gnrique	JUMP',NE 16$	LIB	?COLORPUSH	LOAD.L	D3,#COLORFLIVRE	LIB	?COLORCR	LOAD.L	D3,#COLORCLIVRE	LIB	?COLORSR	LOAD.W	D2,#LOADDOT!2^BDSTCOUL	CALL	IMADRAW		; affiche l'image gnrique	LIB	?COLORPOP	CALL	IMACLOSE	; libre l'image gnrique16$:	LOAD.L	A3,#R16"TXERFATTX0	LIB	?AFTIM	.B	LOADGC,GCT0F,GCT0S,GCT0T,0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCT0F,GCT0S,GCT0T,0	.EVEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OPGC0,(A0)+ODFPGC	LOAD.L	A3,#R16"TXERFATTX1	LIB	?AFTIM	.B	LOADGC,GCT1F,GCT1S,GCT1T,0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCT1F,GCT1S,GCT1T,0	.EVEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OPGC1,(A0)+ODFPGC	LOAD.L	A3,#R16"TXERFATTX2	LIB	?AFTIM	.B	LOADGC,GCT2F,GCT2S,GCT2T,0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCT2F,GCT2S,GCT2T,0	.EVEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OPGC2,(A0)+ODFPGC	LOAD.L	A3,#R16"TXERFATTX3	LIB	?AFTIM	.B	LOADGC,GCT3F,GCT3S,GCT3T,0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCT3F,GCT3S,GCT3T,0	.EVEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OPGC3,(A0)+ODFPGC	LOAD.L	A3,#R16"TXERFATTX4	LIB	?AFTIM	.B	LOADGC,GCT4F,GCT4S,GCT4T,0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCT4F,GCT4S,GCT4T,0	.EVEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OPGC4,(A0)+ODFPGC	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0	.EVEN	LOAD.L	(A6)+OPGCX,(A0)+ODFPGC	COMP.W	D0,#STFIRST	; premire excution ?	JUMP',NE 40$		; non => 40$	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ 40$		; non => 40$	LOAD.L	A3,#R16"NMICOLOR	LOAD.W	D3,#ICOL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHICOLOR,D1	LOAD.L	A3,#R16"NMMEMENTO	LOAD.L	A5,#R16"TCOUL	LOAD.L	D3,#2^BICCRET	ICOL_	INIT		; charge MEMENTO.CRET	LOAD.L	(A6)+OIDCRET,D540$:	TEST.B	(A0)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP',BS 50$		; oui => 50$	TSET.B	(A6)+OINFO+3:#BINFINV-050$:	LIB	?AFTIM	.B	NOCURS	.B	TRUNC	.B	MODGRA,GRACLIP	.B	0	.EVEN	LOAD.L	A3,#R16"NMIMA1	CALL	IMAOPEN		; ouvre l'image de fond	JUMP,NE ERFAT2	LOAD.L	(A6)+OPIMF,A4	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,#LYIMA	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,#LXIMA	SR.W	D3,#1	LOAD.L	D4,#H'10000*LYIMA+LXIMA	LIB	?CREWDO	LOAD.W	(A6)+ONOWDO,D5	LIB	?USEWDO		; utilise une swdo de 640x340 !	CALL	DESWDO		; affiche la fentre de base	CALL	_AFMENU		; affiche les soft-keys	LOAD.L	(A6)+ODESS,#2^BDESFL	LOAD.W	(A6)+OOPER,#OPAFF	LOAD.W	(A6)+OTYPE,#ICOYEAR	LOAD.W	(A6)+OMCX,#24	LOAD.W	(A6)+OMCY,#13	CALL	DATENOW	LOAD.L	(A6)+OHERE,D4	CALL	USARTOPEN	COMP.W	D0,#STFIRST	; premire excution ?	JUMP,NE NEWTYPE		; non => NEWTYPE60$:	LOAD.W	D4,#1	NTREL	?CRESEM	JUMP,NE ERFAT2	LOAD.L	(A6)+OPSEM,A5	NTREL	?GETPRIO	; D4 <-- priorit de START	INC.B	D4		; fils moins prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP,NE ERFAT2	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SKPNAM		; voir (*)	JUMP,NE NEWTYPE	LOAD.L	A4,#(A6)+OFILNAM70$:	LOAD.B	D3,(A3+)	JUMP',EQ 72$	COMP.B	D3,#CR	JUMP',EQ 72$	COMP.B	D3,#SPACE	JUMP',EQ 72$	COMP.B	D3,#TAB	JUMP',EQ 72$	COMP.B	D3,#'/	JUMP',EQ 72$	LOAD.B	(A4+),D3	JUMP	70$72$:	LOAD.L	A3,#(A6)+OFILNAM	LOAD.L	A4,#R16"TDBOX_EXT	LOAD.W	D3,#1		; D3 <-- force	LIB	?ADDEXT		; force l'extension .MEMENTO, voir (*)	CALL	RDMEMENTO	; lit un fichier	JUMP',EQ 74$	COMP.W	D0,#STSLEEP	; excution directement en veilleuse ?	JUMP,EQ ERFAT1		; oui => ERFAT1	CALL	DBOXERROR	; affiche l'erreur74$:	COMP.W	D0,#STSLEEP	; excution directement en veilleuse ?	JUMP,EQ VEILLE		; oui => VEILLE;	JUMP	NEWTYPE; (*)	Tous ces appels sont possibles mme si la librairie;	n'est pas ouverte (cas lors d'un MEMENTO/V) !!!NEWTYPE:	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	AFFRNDTYPE	; ODATE <-- arrondi selon le typeREFAIT:	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	AFFDRAWTYPE	; affiche selon le typeLOOP:	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	_SELDESSIN	; slectionne le bon lutin-souris20$:	LIB	?GETKEY		; attend clavier/souris ...	TEST.L	D3:#BKPSEUDO	JUMP,BS 20$	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP	COMP.W	D3,#KEYMGP	JUMP,EQ GAUCHE	COMP.W	D3,#KEYMMP	JUMP,EQ MILIEU	COMP.W	D3,#KEYMDP	JUMP,EQ DROITE	COMP.B	D3,#F0+SHIFT	JUMP',LO 40$	COMP.B	D3,#F15+SHIFT	JUMP',HI 40$	SUB.B	D3,#SHIFT40$:	COMP.W	D3,#UNDO	JUMP,EQ ANNULE	COMP.W	D3,#HELP	JUMP,EQ AIDE	COMP.W	D3,#F0	JUMP,EQ FINI	COMP.W	D3,#END	JUMP,EQ FINI	COMP.W	D3,#F1	JUMP,EQ PREND	COMP.W	D3,#F2	JUMP,EQ AJIMAGE	COMP.W	D3,#F3	JUMP,EQ SAUVE	COMP.W	D3,#F7	JUMP,EQ TYPEY	COMP.W	D3,#F8	JUMP,EQ TYPEW	COMP.W	D3,#F9	JUMP,EQ TYPED	COMP.W	D3,#F14	JUMP,EQ EFFACEBIP:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOPERROR:	CALL	DBOXERROR	; affiche l'erreur ...	JUMP,NE BIP	JUMP	LOOPGAUCHE:	CALL	AFFMOVEICONE	; D3 <-- icne o est la souris	JUMP,EQ ICONE$	TEST.B	(A6)+ODESS+3:#BDESFL-0	JUMP,BC DESSIN	CALL	AFFDETTYPE	; D4 <-- date o est la souris	JUMP,NE BIP	CALL	AFFMODTYPE	; ODATE <-- nouvelle date	JUMP,EQ NEWTYPE	COMP.W	D7,#ERMMREX	JUMP,NE ERROR	PUSH.W	D7	CALL	AFFRNDTYPE	; ODATE <-- arrondi selon le type	CALL	AFFDRAWTYPE	; affiche selon le type	POP.W	D7	JUMP	ERRORICONE$:	COMP.W	D3,#ICONEXT	JUMP,EQ NEXT	COMP.W	D3,#ICOPREV	JUMP,EQ PREV	COMP.W	D3,#ICOCHAV	JUMP,EQ CHAV	COMP.W	D3,#ICOCHAR	JUMP,EQ CHAR	COMP.W	D3,#ICODAY	JUMP,EQ TYPED	COMP.W	D3,#ICOWEEK	JUMP,EQ TYPEW	COMP.W	D3,#ICOYEAR	JUMP,EQ TYPEY	COMP.W	D3,#ICOLIST	JUMP,EQ LIST	COMP.W	D3,#ICOGOTO	JUMP,EQ GOTO	COMP.W	D3,#ICOINFO	JUMP,EQ INFO	COMP.W	D3,#ICOPSION	JUMP,EQ PSION	COMP.W	D3,#ICOFLECHE	JUMP,EQ FLECHE	COMP.W	D3,#ICOCRAYON	JUMP,EQ CRAYON	COMP.W	D3,#ICOPINCEAU	JUMP,EQ PINCEAU	COMP.W	D3,#ICOGOMME	JUMP,EQ GOMME	COMP.W	D3,#ICOTRAIT	JUMP,EQ TRAIT	COMP.W	D3,#ICODROITE	JUMP,EQ LDROITE	COMP.W	D3,#ICOTRAME	JUMP,EQ RTRAME	COMP.W	D3,#ICORECTANGLE	JUMP,EQ RECT	COMP.W	D3,#ICOLIB	JUMP,EQ LIBRARY	COMP.W	D3,#ICOAJIMAGE	JUMP,EQ AJIMAGE	COMP.W	D3,#ICOAJOUTE	JUMP,EQ AJIMAGE	JUMP	BIPNEXT:	CALL	AFFNEXTTYPE	; ODATE <-- suivant selon le type	JUMP,NE BIP	CALL	AFFNEXT		; tourne la page en avant	LOAD.L	(A6)+OHERE,(A6)+ODATE	JUMP	REFAITPREV:	CALL	AFFPREVTYPE	; ODATE <-- prcdent selon le type	JUMP,NE BIP	CALL	AFFPREV		; tourne la page en arrire	LOAD.L	(A6)+OHERE,(A6)+ODATE	JUMP	REFAITTYPEY:	LOAD.W	(A6)+OTYPE,#ICOYEAR	JUMP	NEWTYPETYPEW:	LOAD.W	(A6)+OTYPE,#ICOWEEK	JUMP	NEWTYPETYPED:	LOAD.W	(A6)+OTYPE,#ICODAY	JUMP	NEWTYPECHAV:	CALL	AFFCHAVTYPE	JUMP,NE ERROR	JUMP	REFAITCHAR:	CALL	AFFCHARTYPE	JUMP,NE ERROR	JUMP	REFAITLIST:	TEST.W	(A6)+ORDVNB	JUMP,EQ BIP	CALL	DBOXLIST	; affiche la liste ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,EQ NEWTYPE	COMP.W	D3,#F10	JUMP,NE REFAIT	CALL	DBOXCRTEXT	; demande le nom du fichier texte ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.L	A3,#(A6)+OFILTXT	CALL	WRRDVTEXT	; sauve les rendez-vous dans un texte	JUMP,NE ERROR	JUMP	LOOPGOTO:	CALL	DBOXGOTO	; demande o aller ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	JUMP	NEWTYPEINFO:	LOAD.L	D4,(A6)+OINFO	CALL	DBOXINFO	; donne quelques informations ...	JUMP,NE ERROR	TEST.W	D2		; y a-t-il des couleurs modifies ?	JUMP',NE REFAIT$	; oui => REFAIT$	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.L	D3,(A6)+OINFO	XOR.L	D4,D3		; D4 <-- fanions changs	AND.L	D4,#2^BINFINV!H'FFFF0000	JUMP,NE REFAIT	JUMP	LOOPREFAIT$:	CALL	DESWDO		; affiche la fentre de base	JUMP	REFAITFLECHE:	TSET.B	(A6)+ODESS+3:#BDESFL-0	TCLR.B	(A6)+ODESS+3:#BDESCR-0	TCLR.B	(A6)+ODESS+3:#BDESPI-0	TCLR.B	(A6)+ODESS+3:#BDESGO-0	TCLR.B	(A6)+ODESS+3:#BDESTM-0	TCLR.B	(A6)+ODESS+3:#BDESDR-0	TCLR.B	(A6)+ODESS+3:#BDESTR-0	TCLR.B	(A6)+ODESS+3:#BDESRE-0	CALL	AFFCLRICONE	; efface les anciennes icnes	CALL	AFFDRAWICONE	; redessine les nouvelles	JUMP	LOOPCRAYON:	TCLR.B	(A6)+ODESS+3:#BDESFL-0	JUMP',BC CRAYON2	TSET.B	(A6)+ODESS+3:#BDESCR-0	TSET.B	(A6)+ODESS+3:#BDESTM-0	CALL	AFFCLRICONE	; efface les anciennes icnes	CALL	AFFDRAWICONE	; redessine les nouvelles	JUMP	LOOPCRAYON2:	LOAD.W	D3,#BDESCR-0	JUMP'	OUTILPINCEAU:	LOAD.W	D3,#BDESPI-0;	JUMP'	OUTILOUTIL:	CALL	AFFINVOUTIL	; efface l'ancien outil	TCLR.B	(A6)+ODESS+3:#BDESCR-0	TCLR.B	(A6)+ODESS+3:#BDESPI-0	TCLR.B	(A6)+ODESS+3:#BDESGO-0	TSET.B	(A6)+ODESS+3:D3	CALL	AFFINVOUTIL	; allume le nouvel outil	TEST.B	(A6)+ODESS+3:#BDESTM-0	JUMP,BS LOOP	TEST.B	(A6)+ODESS+3:#BDESDR-0	JUMP,BS LOOP	TEST.B	(A6)+ODESS+3:#BDESTR-0	JUMP,BS LOOP	TEST.B	(A6)+ODESS+3:#BDESRE-0	JUMP,BS LOOP	JUMP'	TRAITGOMME:	CALL	AFFINVOUTIL	; efface l'ancien outil	TCLR.B	(A6)+ODESS+3:#BDESCR-0	TCLR.B	(A6)+ODESS+3:#BDESPI-0	TSET.B	(A6)+ODESS+3:#BDESGO-0	CALL	AFFINVOUTIL	; allume le nouvel outil	CALL	AFFINVOBJET	; efface l'ancien objet	TCLR.B	(A6)+ODESS+3:#BDESTM-0	TCLR.B	(A6)+ODESS+3:#BDESDR-0	TCLR.B	(A6)+ODESS+3:#BDESTR-0	TCLR.B	(A6)+ODESS+3:#BDESRE-0	JUMP	LOOPTRAIT:	LOAD.W	D3,#BDESTM-0	JUMP'	OBJETLDROITE:	LOAD.W	D3,#BDESDR-0	JUMP'	OBJETRTRAME:	LOAD.W	D3,#BDESTR-0	JUMP'	OBJETRECT:	LOAD.W	D3,#BDESRE-0;	JUMP'	OBJETOBJET:	CALL	AFFINVOBJET	; efface l'ancien objet	TCLR.B	(A6)+ODESS+3:#BDESTM-0	TCLR.B	(A6)+ODESS+3:#BDESDR-0	TCLR.B	(A6)+ODESS+3:#BDESTR-0	TCLR.B	(A6)+ODESS+3:#BDESRE-0	TSET.B	(A6)+ODESS+3:D3	CALL	AFFINVOBJET	; allume le nouvel objet	TEST.B	(A6)+ODESS+3:#BDESGO-0	JUMP,BS CRAYON2	JUMP	LOOPDESSIN:	TEST.L	(A6)+OPIMD	; image de dessin existe ?	JUMP,EQ BIP		; non => BIP	CALL	_IFMOUSE	JUMP,NE BIP	CALL	DESSAVE		; sauvetage pour (UNDO) v.	LOAD.L	D5,D4	LOAD.L	D6,D4	TEST.B	(A6)+ODESS+3:#BDESDR-0	JUMP',BS OBJET$	TEST.B	(A6)+ODESS+3:#BDESTR-0	JUMP',BS OBJET$	TEST.B	(A6)+ODESS+3:#BDESRE-0	JUMP',BS OBJET$TRAIT$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP,NE LOOP	CALL	_IFMOUSE	JUMP,NE TRAIT$	LOAD.L	D3,D5	CALL	DESTDRAW	; hop, dessine	LOAD.L	D5,D4	JUMP	TRAIT$OBJET$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	_IFMOUSE	JUMP,NE OBJET$	LOAD.L	D3,D5	LOAD.W	D2,#INVDOT	EX.L	D4,D6	CALL	DESODRAW	; efface l'ancien	LOAD.L	D4,D6	CALL	DESODRAW	; dessine le nouveau	JUMP	OBJET$END$:	LOAD.L	D3,D5	LOAD.L	D4,D6	LOAD.W	D2,#SETDOT	CALL	DESODRAW	; dessine de dfinitif	JUMP	LOOPDROITE:	TEST.B	(A6)+ODESS+3:#BDESFL-0	JUMP,BS BIP	TEST.L	(A6)+OPIMD	; image de dessin existe ?	JUMP,EQ BIP		; non => BIP	CALL	_IFMOUSE	JUMP,NE BIP	LOAD.L	D5,D4	LOAD.L	D6,D4	CLR.W	D3	CALL	_SELMO		; utilise la flcheLOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	_IFMOUSE	JUMP,NE LOOP$	LOAD.L	D3,D5	EX.L	D4,D6	CALL	DESSELECT	; efface l'ancien	LOAD.L	D4,D6	CALL	DESSELECT	; dessine le nouveau	JUMP	LOOP$END$:	COMP.W	D5,D6	JUMP',EQ EXIT$	LOAD.L	D3,D5	LOAD.L	D4,D6	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',EQ EXIT$	LOAD.L	A3,#R16"MENU$	LOAD.L	A4,#(A6)+OPARMD	CALL	_MMENUS		; choix selon mmenus ...	JUMP',NE EXIT$	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	COMP.W	D3,#1	JUMP,EQ DDD$	COMP.W	D3,#2	JUMP,EQ DDD$	COMP.W	D3,#3	JUMP,EQ DDD$EXIT$:	LOAD.L	D3,D5	LOAD.L	D4,D6	CALL	DESSELECT	; efface le dernier	JUMP	LOOPDDD$:	CALL	DESSAVE		; sauvetage pour (UNDO) v.	LOAD.W	D2,D3		; D2 <-- opration	CALL	DESDDDSEL	; dtruit/dplace/duplique ...	JUMP	LOOPMENU$:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICODETR	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit "	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICODEPL	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  dplace  "	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOPRESS	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICODUPL	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  duplique "	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOPRESS	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	0	.EVENMILIEU:	LOAD.L	A3,#R16"MENU$	LOAD.L	A4,#(A6)+OPARMM	CLR.L	(A4)+(LMM*1)+OMMINA	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA	TSET.B	(A4)+(LMM*2)+OMMINA+3:#2 ; case "dessine" grise	TEST.B	(A6)+ODESS+3:#BDESFL-0	JUMP',BC 10$	TCLR.B	(A4)+(LMM*2)+OMMINA+3:#2	TSET.B	(A4)+(LMM*2)+OMMINA+3:#1 ; case "dite" grise	TSET.B	(A4)+(LMM*2)+OMMINA+3:#0 ; case "annule" grise10$:	TEST.W	(A6)+ORDVNB	JUMP',NE 12$	TSET.B	(A4)+(LMM*2)+OMMINA+3:#4 ; case "efface" grise	TSET.B	(A4)+(LMM*1)+OMMINA+3:#1 ; case "sauve" grise	TSET.B	(A4)+(LMM*1)+OMMINA+3:#3 ; case "imprime" grise	TSET.B	(A4)+(LMM*3)+OMMINA+3:#3 ; case "liste" grise12$:	CLR.B	D3	COMP.W	(A6)+OTYPE,#ICOYEAR	JUMP',EQ 20$	INC.B	D3	COMP.W	(A6)+OTYPE,#ICOWEEK	JUMP',EQ 20$	INC.B	D320$:	TSET.B	(A4)+(LMM*3)+OMMINA+3:D3	CALL	_MMENUS		; choix selon mmenus ...	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	COMP.W	D3,#1	JUMP,EQ FILE$	COMP.W	D3,#2	JUMP,EQ EDIT$	COMP.W	D3,#3	JUMP,EQ SHOW$	JUMP	LOOPFILE$:	LOAD.W	D3,(A4)+(LMM*1)+OMMSEL	COMP.W	D3,#0	JUMP,EQ PREND	COMP.W	D3,#1	JUMP,EQ SAUVE	COMP.W	D3,#2	JUMP,EQ AJIMAGE	COMP.W	D3,#3	JUMP,EQ BIP	COMP.W	D3,#4	JUMP,EQ PSION	COMP.W	D3,#5	JUMP,EQ FINI	JUMP	LOOPEDIT$:	LOAD.W	D3,(A4)+(LMM*2)+OMMSEL	COMP.W	D3,#0	JUMP,EQ ANNULE	COMP.W	D3,#1	JUMP,EQ FLECHE	COMP.W	D3,#2	JUMP,EQ CRAYON	COMP.W	D3,#3	JUMP,EQ INFO	COMP.W	D3,#4	JUMP,EQ EFFACE	COMP.W	D3,#5	JUMP,EQ AIDE	JUMP	LOOPSHOW$:	LOAD.W	D3,(A4)+(LMM*3)+OMMSEL	COMP.W	D3,#0	JUMP,EQ TYPEY	COMP.W	D3,#1	JUMP,EQ TYPEW	COMP.W	D3,#2	JUMP,EQ TYPED	COMP.W	D3,#3	JUMP,EQ LIST	COMP.W	D3,#4	JUMP,EQ GOTO	JUMP	LOOPMENU$:	.ASCIZ	" "	.B	-1	.BW	-2,MFILE$-MENU$	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOFILE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  fichier "	.BW	-2,MEDIT$-MENU$	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOEDIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dition "	.BW	-2,MSHOW$-MENU$	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOSHOW	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  vue "	.B	0MFILE$:	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOPREND	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  prend.."	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOSAUVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  sauve.."	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOAJOUTE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  ajoute image.."	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOPRINT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  imprime.."	.B	-1	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOPSION	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  ORGANISEUR.."	.B	-1	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOSTOP	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  quitte.."	.B	0MEDIT$:	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOANNULE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  annule"	.B	-1	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOFLECHE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dite"	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOCRAYON	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dessine"	.B	-1	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOINFO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  informations.."	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOEFFACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  efface.."	.B	-1	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOHELP	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  aide.."	.B	0MSHOW$:	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOYEAR	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  anne"	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOWEEK	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  semaine "	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICODAY	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  jour"	.B	-1	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOLIST	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  liste.."	.B	SPACE	.B	USEGC,GCT4F,GCT4S,GCT4T	.B	ICOGOTO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  va .."	.B	0	.EVENAIDE:	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#R16"NMIMA3	CALL	IMAOPEN		; A4 <-- ouvre l'image d'aide	JUMP,NE ERROR	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve le contenu de la fentre	JUMP',NE 80$	LIB	?COLORPUSH	LOAD.L	D3,#COLORFLIVRE	LIB	?COLORCR	LOAD.L	D3,#COLORCLIVRE	LIB	?COLORSR	LOAD.W	D2,#LOADDOT!2^BDSTCOUL	CALL	IMADRAW		; affiche l'image d'aide	LIB	?COLORPOP	CLR.W	D3	CALL	_SELMO		; utilise la flche	CALL	_NORMMOUSE	; souris: remet la flche	LIB	?GETCAR	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue le contenu de la fentre80$:	CALL	IMACLOSE	; ferme l'image lue	JUMP	LOOPANNULE:	CALL	DESUNDO		; annule le dessin	JUMP,NE BIP	JUMP	LOOPPREND:	CALL	IMAMAJ		; met  jour l'image actuelle	LOAD.W	D0,#1		; D0 <-- avant de reprendre	CALL	DBOXSAVE	; mise  jour ...	JUMP',NE 80$	CLR.B	(A6)+OFILNAM20$:	CALL	DBOXPREND	; demande le nom ...	JUMP',NE 80$	COMP.W	D3,#F1	JUMP,NE REFAIT	LOAD.L	A3,#(A6)+OFILNAM	CALL	RDMEMENTO	; lit un fichier	JUMP',EQ 60$	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	20$60$:	LOAD.W	(A6)+OTYPE,#ICOYEAR	CALL	DATENOW	LOAD.L	(A6)+OHERE,D4	JUMP	NEWTYPE80$:	PUSH.W	D7	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	AFFDRAWTYPE	; affiche selon le type	POP.W	D7	JUMP	ERRORSAUVE:	CALL	IMAMAJ		; met  jour l'image actuelle	CALL	DBOXCREATE	; demande le nom ...	JUMP',NE 80$	COMP.W	D3,#F1	JUMP,NE REFAIT	LOAD.L	A3,#(A6)+OFILNAM	CALL	WRMEMENTO	; crit un fichier	JUMP,EQ NEWTYPE	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	SAUVE80$:	PUSH.W	D7	CALL	DBOXCLWAIT	; enlve v. la dbox d'attente	CALL	AFFDRAWTYPE	; affiche selon le type	POP.W	D7	JUMP	ERRORAJIMAGE:	TEST.L	(A6)+OPIMD	; image de dessin existe ?	JUMP,EQ BIP		; non => BIP	CALL	DBOXIMAGE	; demande le nom de l'image ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.L	A3,#(A6)+OFILIMA	CALL	DESAJIMAGE	; ajoute l'image ...	JUMP,NE ERROR	JUMP	LOOPLIBRARY:	CALL	DESLIB		; choisi un symbole ...	JUMP,NE ERROR	JUMP	LOOPPSION:	CALL	DBOXPSION	; demande comment transfrer ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	TEST.B	(A6)+OPSION+3:#BPSMEM-0	JUMP',BS MEMENTO$	TEST.B	(A6)+OPSION+3:#BPSFIL-0	JUMP,BS FILE$	JUMP	LOOPMEMENTO$:	CALL	DBOXPSIONMM	; demande comment transfrer ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	TEST.B	(A6)+OPSION+3:#BPSSND-0	JUMP',BS MSEND$	TEST.B	(A6)+OPSION+3:#BPSRCV-0	JUMP',BS MRECV$	JUMP	BIPMSEND$:	TEST.B	(A6)+OPSION+2:#BPSLZ-8	JUMP',BS MSENDLZ$	CALL	PSDSENDXP	; envoie dans le PSION-XP ...	JUMP,NE ERROR	CALL	PSQUITTE	JUMP	LOOPMSENDLZ$:	CALL	PSDSENDLZ	; envoie dans le PSION-LZ ...	JUMP,NE ERROR	JUMP	LOOPMRECV$:	TEST.B	(A6)+OPSION+2:#BPSLZ-8	JUMP',BS MRECVLZ$	CALL	PSDRECVXP	; reoit depuis le PSION-XP ...	JUMP,NE ERROR	CALL	PSQUITTE	JUMP	REFAITMRECVLZ$:	CALL	PSDRECVLZ	; reoit depuis le PSION-LZ ...	JUMP,NE ERROR	JUMP	REFAITFILE$:	CALL	DBOXPSIONFP	; demande comment transfrer ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	TEST.B	(A6)+OPSION+3:#BPSSND-0	JUMP',BS FSEND$	TEST.B	(A6)+OPSION+3:#BPSRCV-0	JUMP',BS FRECV$	JUMP	BIPFSEND$:	LOAD.L	A3,#(A6)+OFILPSI	CALL	PSFSEND		; envoie dans le PSION ...	JUMP,NE ERROR	JUMP	LOOPFRECV$:	LOAD.L	A3,#(A6)+OFILPSI	CALL	PSFRECV		; reoit depuis le PSION ...	JUMP,NE ERROR	JUMP	LOOPEFFACE:	TEST.W	(A6)+ORDVNB	JUMP,EQ BIP	CALL	DBOXEFFACE	; demande s'il faut effacer ...	JUMP,NE LOOP	CALL	IMAMAJ		; met  jour l'image actuelle	CALL	IMAXFDEL	; dtruit toutes les images temporaires	CALL	RDVFLUSH	; libre tous les rendez-vous	CLR.B	(A6)+OFILNAM	JUMP	REFAITFINI:	CLR.W	D0		; D0 <-- avant de quitter	CALL	DBOXSAVE	; mise  jour ...	JUMP,NE ERROR	CALL	DBOXQUITTE	; demande s'il faut quitter ?	JUMP,NE LOOP	TEST.L	D4:#1		; reste en veilleuse ?	JUMP,BC ARRET		; non => ARRET				; oui =>	LOAD.L	A4,(A6)+OPIMF	CALL	IMACLOSE	; libre l'image de fond	CLR.L	(A6)+OPIMF	LOAD.L	A4,(A6)+OPIMO	CALL	IMACLOSE	; libre l'image originale	CLR.L	(A6)+OPIMO	LOAD.L	A4,(A6)+OPIMU	CALL	IMACLOSE	; libre l'image d'annulation	CLR.L	(A6)+OPIMU	LOAD.L	A4,(A6)+OPIMD	CALL	IMACLOSE	; libre l'image de dessin	CLR.L	(A6)+OPIMD	CALL	USARTCLOSE	CALL	RLAUNIT		; fait le LIB,?CLOLIBVEILLE:	LOAD.L	A4,#R16"ADCODE	LOAD.L	D4,#LGCVAR	FOS	?GETCOMMEM	; A4 <-- ^variables communes	JUMP',NE ARRET	SET.B	(A4)+OCSLP	LOAD.L	A5,(A4)+OCPSEM	NTREL	?WAITEV		; attend le rveil ...	CLR.B	(A4)+OCSLP	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LOAD.W	D0,#STWORK	; D0 <-- nouvelle excution !	JUMP	REEXECARRET:	CALL	_WAITMOUSE	; souris: met le sablier	SET.B	(A6)+OABORT	; hello du bateau, c'est l'heure	NTREL	?WFABDESC	; attend la fin du processus fils	CALL	_NORMMOUSE	; souris: remet la flche	LOAD.L	A5,(A6)+OPSEM	NTREL	?KILLSEM	CLR.W	D5	LIB	?USEWDO	LOAD.W	D5,(A6)+ONOWDO	LIB	?KILWDO	CALL	USARTCLOSEERFAT:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHICOLOR	LIB_	CLOSEERFAT1:	LOAD.L	A4,#R16"ADCODE	LOAD.L	D4,#LGCVAR	FOS	?GETCOMMEM	; A4 <-- ^variables communes	JUMP',NE 50$	LOAD.L	A5,(A4)+OCPSEM	NTREL	?KILLSEM50$:	CALL	RLAUNIT		; fait le LIB,?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	MEMPSION.ASI	.INS	MEMFILS.ASI	.INS	MEMAFF.ASI	.INS	MEMIMAGE.ASI	.INS	MEMDBOX.ASI_IFSWITCH:	JUMP	IFSWITCH_MMENUS:	JUMP	MMENUS_IFMOUSE:	JUMP	IFMOUSE_WAITMOUSE:	JUMP	WAITMOUSE_NORMMOUSE:	JUMP	NORMMOUSE_SELDESSIN:	JUMP	SELDESSIN_SELMO:		JUMP	SELMO_AFMENU:	JUMP	AFMENU	.INS	MEMIO.ASI	.INS	MEMFETE.ASI	.INS	MEMDATE.ASI	.INS	MEMRDV.ASI	.INS	MEMMISC.ASI	.END	START