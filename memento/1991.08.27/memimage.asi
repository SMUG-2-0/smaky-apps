	.SBTTL	MEMIMAGE;--------\\; DESWDO  >;========/; Affiche la fentre de base (trame de fond + image de base).; in	-; out	-; mod	D7.WDESWDO:	PUSHM.L	D2..D5,A4	CLR.W	D5	LIB	?USEWDO		; utilise toute la fentre	LOAD.L	D3,#COLORFLIVRE	LIB	?COLORCR	LOAD.L	D3,#COLORCLIVRE	LIB	?COLORSR	LOAD.L	D3,#H'AA55AA55	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; grise toute la fentre	LOAD.W	D5,(A6)+ONOWDO	LIB	?USEWDO		; utilise la swdo de 640x340	LOAD.L	A4,(A6)+OPIMF	LIB	?COLORPUSH	LOAD.L	D3,#COLORFLIVRE	LIB	?COLORCR	LOAD.L	D3,#COLORCLIVRE	LIB	?COLORSR	LOAD.W	D2,#LOADDOT!2^BDSTCOUL	CALL	IMADRAW		; affiche l'image de fond	LIB	?COLORPOP	POPM.L	D2..D5,A4	RET;--------\\; DESLIB  >;========/; Ajoute un symbole de la librairie.; in	-; out	D7.W	erreur; mod	D7.WDESLIB:	PUSHM.L	D1..D6,A3,A4	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#R16"NMIMA2	CALL	IMAOPEN		; A4 <-- ouvre l'image dans le dossier courant	JUMP',EQ 10$	LOAD.L	A3,#R16"NMIMA2S	CALL	IMAOPEN		; A4 <-- ouvre l'image dans le dossier systme	JUMP,NE EXIT$10$:	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve le contenu de la fentre	JUMP,NE 80$	LIB	?COLORPUSH	LOAD.L	D3,#COLORFLIVRE	LIB	?COLORCR	LOAD.L	D3,#COLORDESSIN	LIB	?COLORSR	LOAD.W	D2,#LOADDOT!2^BDSTCOUL	CALL	IMADRAW		; affiche l'image	LIB	?COLORPOP	CLR.W	D3	CALL	SELMO		; utilise la flche	CALL	NORMMOUSE	; souris: remet la flche	LOAD.W	D1,#-120$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMGR	JUMP',EQ 30$	COMP.W	D3,#KEYMMR	JUMP',EQ 30$	COMP.W	D3,#KEYMDR	JUMP',EQ 30$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 20$	CALL	DESLIBDET	; D2 <-- objet o est la souris	COMP.W	D2,D1		; toujours sur le mme ?	JUMP,EQ 20$		; oui => 20$				; non =>	EX.L	D2,D1	CALL	DESLIBINV	; teint l'ancien	LOAD.W	D2,D1	CALL	DESLIBINV	; allume le nouveau	JUMP	20$30$:	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue le contenu de la fentre	COMP.W	D1,#-1	JUMP,EQ 80$	LOAD.W	D2,D1	CALL	DESLIBPOS	; D3/D4 <-- position/dimensions	JUMP,NE 80$	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	DESSAVE		; sauvetage pour (UNDO) v.	CALL	PMOUSE		; positionne la souris	PUSH.L	(A6)+OPIMU	LOAD.L	(A6)+OPIMU,A4	LOAD.L	D5,D3		; D5 <-- origine	LOAD.L	D6,D4		; D6 <-- arrive	LOAD.W	D2,#4		; D2 <-- opration	CALL	DESDDDSEL	; positionne ...	POP.L	(A6)+OPIMU	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	CALL	IMACLOSE	; ferme l'image lue	POP.W	D7EXIT$:	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DESLIBDET >;----------/; Dtecte dans quel objet est la souris.; in	D4.L	position de la souris; out	D2.W	numro de l'objet;	D7.W	erreur; mod	D2.L, D7.WDESLIBDET:	PUSHM.L	D3..D6	LOAD.W	D5,D4		; D5 <-- position en X	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- position en Y	LOAD.W	D2,#-120$:	INC.W	D2		; D2 <-- objet suivant	CALL	DESLIBPOS	; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	COMP.W	D5,D3		; trop  gauche ?	JUMP,LO 20$	ADD.W	D3,D4	COMP.W	D5,D3		; trop  droite ?	JUMP,HS 20$	SWAP.W	D3	SWAP.W	D4	COMP.W	D6,D3		; trop en haut ?	JUMP,LO 20$	ADD.W	D3,D4	COMP.W	D6,D3		; trop en bas ?	JUMP,HS 20$EXIT$:	POPM.L	D3..D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; DESLIBINV >;----------/; Inverse un objet.; in	D2.W	numro de l'objet; out	-; mod	D7.WDESLIBINV:	PUSHM.L	D2..D4	COMP.W	D2,#-1	JUMP',EQ EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	DESLIBPOS	; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse l'objetEXIT$:	POPM.L	D2..D4	RET;----------\\; DESLIBPOS >;----------/; Donne la position et les dimensions d'un objet de librairie.; in	D2.W	numro de l'objet; out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WDESLIBPOS:	PUSH.L	D2	LOAD.W	D7,#1	CLR.L	D4	COMP.W	D2,#13*6	JUMP',HS EXIT$	AND.L	D2,#H'FFFF	DIV.WU	D2,#13	LOAD.W	D3,D2	MUL.WU	D3,#48	ADD.W	D3,#49	SWAP.W	D3	SWAP.W	D2	MUL.WU	D2,#48	ADD.W	D2,#9	LOAD.W	D3,D2	LOAD.L	D4,#H'10000*39+39	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DESAJIMAGE >;===========/; Lit un fichier image, puis ajoute-la dans l'image de dessin.; in	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WDESAJIMAGE:	PUSHM.L	D2..D6,A4	CALL	IMAOPEN		; A4 <-- ^image	JUMP,NE EXIT$	LOAD.W	D7,#ERMMIMG	; D7 <-- image trop grande	COMP.W	(A4)+OIMDLX,#LXIMA	JUMP',HS 80$	COMP.W	(A4)+OIMDLY,#LYIMA	JUMP',HS 80$	CALL	DESSAVE		; sauvetage pour (UNDO) v.	CLR.W	D3	CALL	SELMO		; utilise la flche	LOAD.W	D4,(A4)+OIMDLY	SWAP.W	D4	LOAD.W	D4,(A4)+OIMDLX	CALL	PMOUSE		; positionne la souris	PUSH.L	(A6)+OPIMU	LOAD.L	(A6)+OPIMU,A4	CLR.L	D5		; D5 <-- origine	LOAD.L	D6,D4		; D6 <-- arrive	LOAD.W	D2,#4		; D2 <-- opration	CALL	DESDDDSEL	; positionne ...	POP.L	(A6)+OPIMU	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	CALL	IMACLOSE	; ferme l'image lue	POP.W	D7EXIT$:	POPM.L	D2..D6,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DESDDDSEL >;==========/; Dtruit, dplace ou duplique.; in	D2.W	1= dtruit, 2=dplace, 3=duplique, 4=image;	D5.L	origine (y;x);	D6.L	arrive (y;x); out	-; mod	D7.WDESDDDSEL:	PUSHM.L	D0..D6,A3,A4	LOAD.L	D0,D5		; D0 <-- origine	COMP.W	D0,D6	JUMP',LO 10$	LOAD.W	D0,D610$:	SWAP.W	D0	SWAP.W	D6	COMP.W	D0,D6	JUMP',LO 12$	LOAD.W	D0,D612$:	SWAP.W	D0	SWAP.W	D6	COMP.W	D2,#1		; dtruit ?	JUMP,EQ 50$		; oui => 50$	COMP.W	D2,#2		; dplace ?	JUMP',EQ 20$		; oui => 20$	LOAD.L	D3,D5	LOAD.L	D4,D6	CALL	DESINVSEL	; efface le premier	COMP.W	D2,#4		; image ?	JUMP',NE 20$		; non => 20$	CALL	DESSELECT	; dessine la premire slection20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP,NE 50$	CALL	IFMOUSE	JUMP,NE 20$	LOAD.W	D3,D4	ADD.W	D3,D5	SUB.W	D3,D6	JUMP',NC 30$	SUB.W	D4,D3	CLR.W	D330$:	LOAD.W	D1,(A0)+ODFFDX	COMP.W	D3,D1	JUMP',LO 32$	SUB.W	D3,D1	SUB.W	D4,D3	LOAD.W	D3,D132$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	LOAD.W	D3,D4	ADD.W	D3,D5	SUB.W	D3,D6	JUMP',NC 34$	SUB.W	D4,D3	CLR.W	D334$:	LOAD.W	D1,(A0)+ODFFDY	COMP.W	D3,D1	JUMP',LO 36$	SUB.W	D3,D1	SUB.W	D4,D3	LOAD.W	D3,D136$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	CALL	DESINVSEL	; dessine le nouveau	CALL	DESSELECT	; dessine le nouveau	EX.L	D3,D5	EX.L	D4,D6	CALL	DESINVSEL	; efface l'ancien	CALL	DESSELECT	; efface l'ancien	JUMP	20$50$:	SUB.W	D6,D5	JUMP',NC 52$	NEG.W	D6	SUB.W	D5,D652$:	SWAP.W	D5	SWAP.W	D6	SUB.W	D6,D5	JUMP',NC 54$	NEG.W	D6	SUB.W	D5,D654$:	SWAP.W	D5	SWAP.W	D6	COMP.W	D2,#3		; duplique ?	JUMP',EQ 60$		; oui => 60$	COMP.W	D2,#4		; image ?	JUMP',EQ 60$		; oui => 60$	PUSHM.L	D2,D5,D6	LOAD.L	D2,D6		; D2 <-- dimensions	LOAD.L	D3,D0		; D3 <-- origine source	LOAD.L	A3,(A6)+OPIMU	LOAD.W	D5,(A3)+OIMDLX	SR.W	D5,#3		; D5 <-- Iy source	LOAD.L	A3,(A3)+LGHIMA	; A3 <-- ^source	LOAD.L	D4,D0		; D4 <-- origine destination	LOAD.L	A4,(A6)+OPIMD	LOAD.W	D6,(A4)+OIMDLX	SR.W	D6,#3		; D6 <-- Iy destination	LOAD.L	A4,(A4)+LGHIMA	; A4 <-- ^destination	LOAD.W	D1,#CLRDOT	CALL	DRRASTER	; efface l'origine	POPM.L	D2,D5,D660$:	COMP.W	D2,#1		; dtruit ?	JUMP',EQ 70$		; oui => 70$	LOAD.L	D2,D6		; D2 <-- dimensions	LOAD.L	D4,D5		; D4 <-- origine destination	LOAD.L	D3,D0		; D3 <-- origine source	LOAD.L	A3,(A6)+OPIMU	LOAD.W	D5,(A3)+OIMDLX	SR.W	D5,#3		; D5 <-- Iy source	LOAD.L	A3,(A3)+LGHIMA	; A3 <-- ^source	LOAD.L	A4,(A6)+OPIMD	LOAD.W	D6,(A4)+OIMDLX	SR.W	D6,#3		; D6 <-- Iy destination	LOAD.L	A4,(A4)+LGHIMA	; A4 <-- ^destination	LOAD.W	D1,#SETDOT	CALL	DRRASTER	; dplace rellement70$:	SET.B	(A6)+OMIMD	; image de dessin plus  jour	SET.B	(A6)+ORDVMJ	; mise  jour ncessaire	LOAD.L	A4,(A6)+OPIMO	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	IMADRAW		; affiche l'image originale	CALL	AFFCLRICONE	; efface les anciennes icnes	CALL	AFFDRAWICONE	; redessine les nouvelles	LIB	?COLORPUSH	LOAD.L	D3,#COLORDESSIN	LIB	?COLORSR	LOAD.L	A4,(A6)+OPIMD	LOAD.W	D2,#SETDOT!2^BDSTCOUL	CALL	IMADRAW		; supperpose l'image de dessin	LIB	?COLORPOP	POPM.L	D0..D6,A3,A4	RET;----------\\; DESINVSEL >;----------/; Inverse la partie du dessin dplace.; in	D3.L	origine (y;x);	D4.L	arrive (y;x);	D0.L	point initial (y;x); out	-; mod	D7.WDESINVSEL:	PUSHM.L	D1..D5,A3,A4	SUB.W	D4,D3	JUMP',NC 20$	NEG.W	D4	SUB.W	D3,D420$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',NC 22$	NEG.W	D4	SUB.W	D3,D422$:	SWAP.W	D3	SWAP.W	D4	CALL	CCMO		; enlve la souris	LIB	?COLORPUSH	PUSH.L	D3	LOAD.L	D3,#COLORDESSIN	LIB	?COLORSR	POP.L	D3	LOAD.L	D2,D4		; D2 <-- dimensions	LOAD.L	D4,D3		; D4 <-- origine destination	LOAD.L	D3,D0		; D3 <-- origine source	LOAD.L	A3,(A6)+OPIMU	LOAD.W	D5,(A3)+OIMDLX	SR.W	D5,#3		; D5 <-- Iy source	LOAD.L	A3,(A3)+LGHIMA	; A3 <-- ^source	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	LOAD.W	D1,#INVDOT!2^BDSTCOUL	CALL	DRRASTER	; inverse la partie dplace	LIB	?COLORPOP	CALL	SCMO		; remet la souris	POPM.L	D1..D5,A3,A4	RET;---------\\; DESTDRAW >;=========/; Dessine un trait  main leve dans la matrice de dessin et dans l'cran.; in	D3.L	origine (y;x);	D4.L	arrive (y;x); out	-; mod	D7.WDESTDRAW:	PUSHM.L	D2..D4,A3,A4	TEST.L	(A6)+OPIMD	; image de dessin existe ?	JUMP,EQ EXIT$		; non => EXIT$	SET.B	(A6)+OMIMD	; image de dessin plus  jour	SET.B	(A6)+ORDVMJ	; mise  jour ncessaire	SUB.W	D4,D3		; D4 <-- largeur	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur	SWAP.W	D3	SWAP.W	D4	TEST.L	D4	JUMP,EQ EXIT$	TEST.B	(A6)+ODESS+3:#BDESGO-0	JUMP',BS 40$	LOAD.W	D2,#SETDOT	TEST.B	(A6)+ODESS+3:#BDESPI-0	JUMP',BC 20$	PUSH.L	D3	LOAD.L	A3,#R16"TDPEN	LOAD.W	D3,#1+8	LIB	?STRING	POP.L	D3	LOAD.W	D2,#SETDOT!PENDOT20$:	CALL	OPEDISMAT	CALL	DESDROITE	; dessine un trait  main leve	CALL	CLODISMAT	LOAD.L	A4,(A6)+OPIMD	; A4 <-- ^image de dessin	LOAD.W	D2,#SETDOT	CALL	DESMATRIX	JUMP'	EXIT$40$:				; gomme =>	PUSH.L	D3	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	POP.L	D3	SUB.W	D3,#6-1	SWAP.W	D3	SUB.W	D3,#6-1	SWAP.W	D3	LOAD.L	D4,#H'10000*12+12	CALL	OPEDISMAT	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface dans l'image dessin	CALL	CLODISMAT	LOAD.L	A4,(A6)+OPIMO	; A4 <-- ^image d'origine	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	DESMATRIXEXIT$:	POPM.L	D2..D4,A3,A4	RET;---------\\; DESODRAW >;=========/; Dessine un objet dans la matrice de dessin et dans l'cran.; in	D3.L	origine (y;x);	D4.L	arrive (y;x);	D2.W	mode (INVDOT/SETDOT); out	-; mod	D7.WDESODRAW:	PUSHM.L	D1..D4,A3,A4	TEST.L	(A6)+OPIMD	; image de dessin existe ?	JUMP,EQ EXIT$		; non => EXIT$	SET.B	(A6)+OMIMD	; image de dessin plus  jour	SET.B	(A6)+ORDVMJ	; mise  jour ncessaire	SUB.W	D4,D3		; D4 <-- largeur	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur	SWAP.W	D3	SWAP.W	D4	TEST.L	D4	JUMP,EQ EXIT$	LOAD.W	D1,D2	COMP.W	D2,#SETDOT	JUMP',NE 20$	TEST.B	(A6)+ODESS+3:#BDESPI-0	JUMP',BC 20$	PUSH.L	D3	LOAD.L	A3,#R16"TDPEN	LOAD.W	D3,#1+8	LIB	?STRING	POP.L	D3	TSET.L	D2:#BPENDOT20$:	COMP.W	D1,#SETDOT	JUMP',NE 22$	CALL	OPEDISMAT22$:	TEST.B	(A6)+ODESS+3:#BDESRE-0	JUMP',BS 40$	TEST.B	(A6)+ODESS+3:#BDESTR-0	JUMP',BS 50$	CALL	DESDROITE	JUMP'	60$40$:	CALL	DESRECT	JUMP'	60$50$:	CALL	DESTRAME;	JUMP'	60$60$:	COMP.W	D1,#SETDOT	JUMP',NE EXIT$	CALL	CLODISMAT	LOAD.L	A4,(A6)+OPIMD	; A4 <-- ^image de dessin	LOAD.W	D2,#SETDOT	CALL	DESMATRIXEXIT$:	POPM.L	D1..D4,A3,A4	RETTDPEN:	.B	PEN	.B	B'00000000	.B	B'00000000	.B	B'00011000	.B	B'00111100	.B	B'00111100	.B	B'00011000	.B	B'00000000	.B	B'00000000	.EVEN;----------\\; DESSELECT >;==========/; Dessine le rectangle de slection.; in	D3.L	origine (y;x);	D4.L	arrive (y;x); out	-; mod	D7.WDESSELECT:	PUSHM.L	D2..D4	TEST.L	(A6)+OPIMD	; image de dessin existe ?	JUMP',EQ EXIT$		; non => EXIT$	SUB.W	D4,D3		; D4 <-- largeur	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- hauteur	SWAP.W	D3	SWAP.W	D4	TEST.L	D4	JUMP',EQ EXIT$	LIB	?AFTIM	.B	MAPTT	.B	B'01010101	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT	CALL	DESRECT		; inverse la slectionEXIT$:	POPM.L	D2..D4	RET;----------\\; DESDROITE >;----------/; Dessine une droite.; in	D2.W	mode;	D3.L	origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDESDROITE:	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	RET;--------\\; DESRECT >;--------/; Dessine un rectangle.; in	D2.W	mode;	D3.L	origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDESRECT:	LIB	?DRRECT	RET;---------\\; DESTRAME >;---------/; Dessine une trame rectangulaire.; in	D2.W	mode;	D3.L	origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDESTRAME:	PUSHM.L	D3,D4	PUSHM.L	D3,D4	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	LIB	?DRMDEF	POPM.L	D3,D4	TEST.W	D4	JUMP',EQ EXIT$	JUMP',NC 20$	NEG.W	D4	SUB.W	D3,D420$:	SWAP.W	D3	SWAP.W	D4	TEST.W	D4	JUMP',EQ EXIT$	JUMP',NC 22$	NEG.W	D4	SUB.W	D3,D422$:	SWAP.W	D3	SWAP.W	D4	LIB	?DRTRAMEEXIT$:	POPM.L	D3,D4	RET;----------\\; DESMATRIX >;----------/; Met  jour l'cran en fonction d'une image en mmoire.; in	D3.L	origine (y;x);	D4.L	+/- dimensions (dy;dx);	A4.L	^image;	D2.W	mode; out	-; mod	D7.WDESMATRIX:	PUSHM.L	D1..D5,A3,A4	TEST.W	D4	JUMP',NC 20$	NEG.W	D4	SUB.W	D3,D420$:	SWAP.W	D3	SWAP.W	D4	TEST.W	D4	JUMP',NC 22$	NEG.W	D4	SUB.W	D3,D422$:	SWAP.W	D3	SWAP.W	D4	TEST.B	(A6)+ODESS+3:#BDESCR-0	JUMP',BC 30$	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D430$:	TEST.B	(A6)+ODESS+3:#BDESPI-0	JUMP',BC 40$	SUB.W	D3,#4	ADD.W	D4,#4+4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#4	ADD.W	D4,#4+4	SWAP.W	D3	SWAP.W	D440$:	LOAD.W	D1,D2	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	COMP.W	D1,D2	JUMP',NE 70$	CALL	AFFIFINV	; affichage invers ?	JUMP',NE 70$		; non => 70$	TSET.L	D2:#BCPLDOT70$:	CALL	CCMO		; enlve la souris	LIB	?COLORPUSH	PUSH.L	D3	LOAD.L	D3,#COLORDESSIN	LIB	?COLORSR	POP.L	D3	LOAD.W	D1,D2		; D1 <-- mode	TSET.L	D1:#BDSTCOUL	LOAD.L	D2,D4		; D2 <-- dimensions	LOAD.L	D4,D3		; D4 <-- origine destination	LOAD.W	D5,#LXIMA/8	; D5 <-- Iy source	LOAD.L	A3,(A4)+LGHIMA	; A3 <-- ^source	LOAD.L	A4,#0		; A4 <-- ^destination	CALL	DRRASTER	; dessine dans l'cran	LIB	?COLORPOP	CALL	SCMO		; remet la souris	POPM.L	D1..D5,A3,A4	RET;--------\\; DESSAVE >;========/; Effectue un sauvetage un vue d'un ventuel (UNDO).; in	-; out	-; mod	D7.WDESSAVE:	PUSHM.L	D3,A3,A4	TEST.L	(A6)+OPIMU	JUMP',NE 10$	CALL	IMAEMPTY	; A4 <-- ^image vide	JUMP',NE EXIT$	LOAD.L	(A6)+OPIMU,A410$:	LOAD.L	A4,(A6)+OPIMU	LOAD.L	A4,(A4)+LGHIMA	; A4 <-- ^data image UNDO	LOAD.W	D7,#1	TEST.L	(A6)+OPIMD	JUMP',EQ EXIT$	LOAD.L	A3,(A6)+OPIMD	LOAD.L	A3,(A3)+LGHIMA	; A3 <-- ^data image de dessin	LOAD.W	D3,#(LXIMA*LYIMA/8/4/8)-120$:	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	DECJ.W,NMO D3,20$EXIT$:	POPM.L	D3,A3,A4	RET;--------\\; DESUNDO >;========/; Effectue un (UNDO) au niveau de l'image de dessin.; in	-; out	D7.W	erreur; mod	D7.WDESUNDO:	PUSHM.L	D2..D4,A3,A4	TEST.L	(A6)+OPIMU	JUMP',NE 10$	CALL	IMAEMPTY	; A4 <-- ^image vide	JUMP',NE EXIT$	LOAD.L	(A6)+OPIMU,A410$:	LOAD.L	A4,(A6)+OPIMU	LOAD.L	A4,(A4)+LGHIMA	; A4 <-- ^data image UNDO	LOAD.W	D7,#1	TEST.L	(A6)+OPIMD	JUMP',EQ EXIT$	LOAD.L	A3,(A6)+OPIMD	LOAD.L	A3,(A3)+LGHIMA	; A3 <-- ^data image de dessin	LOAD.W	D3,#(LXIMA*LYIMA/8/4)-120$:	LOAD.L	D4,(A4)	LOAD.L	(A4+),(A3)	; EX.L (A4+),(A3+)	LOAD.L	(A3+),D4	DECJ.W,NMO D3,20$	SET.B	(A6)+OMIMD	; image de dessin plus  jour	SET.B	(A6)+ORDVMJ	; mise  jour ncessaire	LOAD.L	A4,(A6)+OPIMO	LOAD.W	D2,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	IMADRAW		; affiche l'image originale	CALL	AFFCLRICONE	; efface les anciennes icnes	CALL	AFFDRAWICONE	; redessine les nouvelles	LIB	?COLORPUSH	LOAD.L	D3,#COLORDESSIN	LIB	?COLORSR	LOAD.L	A4,(A6)+OPIMD	LOAD.W	D2,#SETDOT!2^BDSTCOUL	CALL	IMADRAW		; supperpose l'image de dessin	LIB	?COLORPOP	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; OPEDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans l'image de dessin.; in	-; out	-; mod	D7.WOPEDISMAT:	PUSHM.L	D4,A1,A2,A4	LOAD.L	(A6)+OSDDIS+ODFABS,(A0)+ODFABS	LOAD.W	(A6)+OSDDIS+ODFIIX,(A0)+ODFIIX	LOAD.W	(A6)+OSDDIS+ODFIIY,(A0)+ODFIIY	LOAD.L	(A6)+OSDDIS+ODFY,(A0)+ODFY	LOAD.L	(A6)+OSDDIS+ODFDY,(A0)+ODFDY	LOAD.L	(A6)+OSDDIS+ODFFY,(A0)+ODFFY	LOAD.L	(A6)+OSDDIS+ODFFDY,(A0)+ODFFDY	LOAD.L	(A6)+OSDDIS+ODFWBY,(A0)+ODFWBY	LOAD.L	(A6)+OSDDIS+ODFWEY,(A0)+ODFWEY	LOAD.L	A4,(A6)+OPIMD	; A4 <-- ^image de dessin	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.L	A1,(A4)+LGHIMA	; A1 <-- ^data	LOAD.L	(A0)+ODFABS,A1	LOAD.W	(A0)+ODFIIX,#1	LOAD.W	D4,(A2)+OIMDLX	SR.W	D4,#3	LOAD.W	(A0)+ODFIIY,D4	LOAD.W	D4,(A2)+OIMDLY	SWAP.W	D4	LOAD.W	D4,(A2)+OIMDLX	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	POPM.L	D4,A1,A2,A4	RET;----------\\; CLODISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.WCLODISMAT:	LOAD.L	(A0)+ODFABS,(A6)+OSDDIS+ODFABS	LOAD.W	(A0)+ODFIIX,(A6)+OSDDIS+ODFIIX	LOAD.W	(A0)+ODFIIY,(A6)+OSDDIS+ODFIIY	LOAD.L	(A0)+ODFY,(A6)+OSDDIS+ODFY	LOAD.L	(A0)+ODFDY,(A6)+OSDDIS+ODFDY	LOAD.L	(A0)+ODFFY,(A6)+OSDDIS+ODFFY	LOAD.L	(A0)+ODFFDY,(A6)+OSDDIS+ODFFDY	LOAD.L	(A0)+ODFWBY,(A6)+OSDDIS+ODFWBY	LOAD.L	(A0)+ODFWEY,(A6)+OSDDIS+ODFWEY	RET;----------\\; IMADESSIN >;==========/; Sauve l'ancienne image et charge la nouvelle.; in	-; out	-; mod	D7.WIMADESSIN:	PUSHM.L	D1..D6,A3,A4; Sauve l'image actuellement visible.	TEST.L	(A6)+OPIMO	JUMP',NE 10$	CALL	IMAEMPTYC	; A4 <-- ^image vide	JUMP,NE EXIT$	LOAD.L	(A6)+OPIMO,A410$:	LOAD.L	A4,(A6)+OPIMO	CALL	CCMO		; enlve la souris	CLR.L	D3		; D3 <-- origine source	LOAD.L	A3,#0		; A3 <-- ^source (cran)	CLR.L	D4		; D4 <-- origine destination	LOAD.L	A4,(A4)+LGHIMA	; A4 <-- ^destination	LOAD.W	D6,#LXIMA/8	LOAD.L	D2,#H'10000*LYIMA+LXIMA	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	CALL	AFFIFINV	; affichage invers ?	JUMP',NE 12$		; non => 12$	TSET.L	D1:#BCPLDOT12$:	CALL	DRRASTER	; image originale <-- contenu de l'cran	CALL	SCMO		; remet la souris; Met ventuellement  jour l'ancienne image de dessin.	LOAD.L	D4,(A6)+ODATE	; D4 <-- date initiale	LOAD.B	D4,#HIMAY	COMP.W	(A6)+OTYPE,#ICOYEAR	JUMP',EQ 20$	LOAD.B	D4,#HIMAW	COMP.W	(A6)+OTYPE,#ICOWEEK	JUMP',EQ 20$	LOAD.B	D4,#HIMAD20$:	TEST.L	(A6)+OPIMD	; image de dessin existe ?	JUMP',EQ 30$		; non => 30$	COMP.L	D4,(A6)+ODIMD	; change d'image ?	JUMP,EQ 60$		; non => 60$	CALL	IMAMAJ		; met  jour l'image actuelle; Lit et affiche la nouvelle image de dessin.30$:	PUSH.L	D4	CALL	RDVSEARCH	; image existe ?	POPM.L	D4	JUMP',NE 40$		; non => 40$	CALL	WAITMOUSE	; souris: met le sablier	CALL	IMAWNAME	; A3 <-- ^nom de l'image  crire	CALL	IMAOPEN		; A4 <-- ouvre l'image dj modifie	JUMP',EQ 35$	CALL	IMARNAME	; A3 <-- ^nom de l'image  lire	CALL	IMAOPEN		; A4 <-- ouvre l'image originale	JUMP',NE 40$35$:	LIB	?COLORPUSH	LOAD.L	D3,#COLORDESSIN	LIB	?COLORSR	LOAD.W	D2,#SETDOT!2^BDSTCOUL	CALL	IMADRAW		; supperpose l'image de dessin	LIB	?COLORPOP	JUMP'	50$40$:	CALL	IMAEMPTY	; A4 <-- ^image vide	JUMP',NE EXIT$50$:	LOAD.L	(A6)+OPIMD,A4	; OPIMD <-- ^image de dessin	LOAD.L	(A6)+ODIMD,D4	; ODIMD <-- date de l'image de dessin	CLR.B	(A6)+OMIMD	; OMIMD <-- image  jour	JUMP'	EXIT$; Raffiche simplement l'image de dessin, sans qu'elle aie t; remise  jour.60$:	TEST.L	(A6)+OPIMD	; image de dessin existe ?	JUMP',EQ EXIT$		; non => EXIT$	LIB	?COLORPUSH	LOAD.L	D3,#COLORDESSIN	LIB	?COLORSR	LOAD.L	A4,(A6)+OPIMD	; A4 <-- ^image de dessin	LOAD.W	D2,#SETDOT!2^BDSTCOUL	CALL	IMADRAW		; supperpose l'image de dessin	LIB	?COLORPOPEXIT$:	CALL	NORMMOUSE	; souris: remet la flche	POPM.L	D1..D6,A3,A4	RET;-------\\; IMAMAJ >;=======/; Met  jour l'image actuelle, si ncessaire.; in	-; out	-; mod	D7.WIMAMAJ:	PUSHM.L	D4,A3,A4	TEST.L	(A6)+OPIMD	; image de dessin existe ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A4,(A6)+OPIMD	; A4 <-- ^image de dessin	TEST.B	(A6)+OMIMD	; image  jour ?	JUMP',EQ 50$		; oui => 50$	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	D4,(A6)+ODIMD	CALL	RDVKILL		; supprime l'ancienne date-image	CALL	IMAWNAME	; A3 <-- ^nom de l'image  crire	FOS	?DELETE		; dtruit le fichier image	CALL	IMAIFEMPTY	; image entirement vide ?	JUMP',EQ 50$		; oui => 50$	CALL	IMAWRITE	; cre le fichier image	JUMP',NE 50$	LOAD.L	A4,#(A6)+ORDV	LOAD.L	(A4)+ORMFAN,#2^BRDVT1 ; met type commentaire !	CLR.W	(A4)+ORMNBR	CLR.W	(A4)+ORMDUR	CLR.W	(A4)+ORMSON	CLR.W	(A4)+ORMMIN	CLR.B	(A4)+ORMTXT	; pas de texte	CALL	RDVCREATE	; cre la nouvelle date-image50$:	CALL	IMACLOSE	; libre l'image de dessin	CLR.L	(A6)+OPIMD	; plus d'image de dessinEXIT$:	POPM.L	D4,A3,A4	RET;-----------\\; IMAIFEMPTY >;===========/; Vrifie si une image est vide.; in	A4.L	^image; out	D7.W	EQ => vide;		NE => contient qq chose; mod	D7.WIMAIFEMPTY:	PUSHM.L	D4,A1,A2	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.L	A1,(A4)+LGHIMA	; A1 <-- ^data	LOAD.W	D4,(A2)+OIMDLX	MUL.WU	D4,(A2)+OIMDLY	SR.L	D4,#3+2		; D4 <-- /8 (byte) et /4 (.L)	DEC.W	D4	LOAD.W	D7,#1		; D7 <-- contient qq close20$:	TEST.L	(A1+)	JUMP',NE EXIT$	DECJ.W,NMO D4,20$	CLR.W	D7		; D7 <-- videEXIT$:	POPM.L	D4,A1,A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAEMPTYC >;==========/; Rserve de la mmoire pour une image vide couleur (inexistante).; in	-; out	A4.L	^image vide;	D7.W	erreur; mod	D7.W, A4.LIMAEMPTYC:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,EQ IMAEMPTY	; non => IMAEMPTY	PUSHM.L	D1,D4,A1,A2	LOAD.L	D4,#LGHIMA+4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP',NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.B	(A2)+OIMTYP,#H'81 ; indique type image	LOAD.B	(A2)+OIMBIP,#H'01 ; 1 bit par point	LOAD.B	(A2)+OIMDIR,#H'02 ; coord. X-Y comme cran	LOAD.W	(A2)+OIMDLX,#LXIMA	LOAD.W	(A2)+OIMDLY,#LYIMA	LOAD.L	(A2)+OIMNBB,#(LXIMA*LYIMA)/8	CLR.W	D4	LOAD.B	D4,(A0)+ODFCNP	; D4 <-- nb de bits/pixel (1,4)	MUL.WU	D4,#(LXIMA*LYIMA)/8	ADD.L	D4,#IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	JUMP',NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	(A2)+LGHIMA,A1	LOAD.L	A4,A2		; A4 <-- ^imageEXIT$:	POPM.L	D1,D4,A1,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; IMAEMPTY >;=========/; Rserve de la mmoire pour une image vide noir/blanc (inexistante).; in	-; out	A4.L	^image vide;	D7.W	erreur; mod	D7.W, A4.LIMAEMPTY:	PUSHM.L	D1,D4,A1,A2	LOAD.L	D4,#LGHIMA+4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP',NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.B	(A2)+OIMTYP,#H'81 ; indique type image	LOAD.B	(A2)+OIMBIP,#H'01 ; 1 bit par point	LOAD.B	(A2)+OIMDIR,#H'02 ; coord. X-Y comme cran	LOAD.W	(A2)+OIMDLX,#LXIMA	LOAD.W	(A2)+OIMDLY,#LYIMA	LOAD.L	(A2)+OIMNBB,#(LXIMA*LYIMA)/8	LOAD.L	D4,#(LXIMA*LYIMA)/8+IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	JUMP',NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	(A2)+LGHIMA,A1	LOAD.L	A4,A2		; A4 <-- ^imageEXIT$:	POPM.L	D1,D4,A1,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; IMAOPEN >;========/; Ouvre une image.; in	A3.L	^nom de l'image; out	A4.L	^image;	D7.W	erreur; mod	D7.W, A4.LIMAOPEN:	PUSHM.L	D0..D4,D6,A1..A3	LOAD.L	D4,#LGHIMA+4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE 84$	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$	COMP.B	(A2)+OIMTYP,#H'82 ; image du LAMI ?	JUMP',NE 20$		; non => 20$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute la stupide en-tte de 256 bytes !	JUMP,NE 82$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$20$:	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE 82$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP,NE 80$	JUMP'	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP,NE 80$	LOAD.L	A3,A1	GRA_	DECOIMA		; dcode l'image ...	JUMP,NE 80$35$:	LOAD.L	(A2)+LGHIMA,A1	LOAD.L	A4,A2		; A4 <-- ^image	FOS	?CLOSE		; ferme l'image	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D784$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POP.W	D7EXIT$:	POPM.L	D0..D4,D6,A1..A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; IMAWRITE >;=========/; Ecrit une image.; in	A3.L	^nom de l'image;	A4.L	^image; out	D7.W	erreur; mod	D7.WIMAWRITE:	PUSHM.L	D3,D4,D6,A1..A4	LOAD.L	D3,#DEFATT-(2^BATTL)	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP,NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.L	A1,(A4)+LGHIMA	; A1 <-- ^data	LOAD.L	A3,A1		; A3 <-- ^image dcode	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^pour image code	GRA_	CODEIMA		; code l'image ...	JUMP,NE 50$; Ecrit une image code.	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE 40$	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^image code	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- nb total de bytes	FOS	?WRBYTE		; crit l'image code	JUMP',NE 40$	FOS	?CLOSE		; ferme l'image40$:	PUSH.W	D7	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^image code	GRA_	DECOIMA		; re-dcode l'image !	POP.W	D7	JUMP',NE 80$	JUMP'	EXIT$; Ecrit une image telle quelle, c'est--dire dcode.50$:	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE 80$	LOAD.L	A4,A3		; A4 <-- ^matrice principale	LOAD.L	D4,D3		; D4 <-- nb total de bytes	FOS	?WRBYTE		; crit le data de l'image	JUMP',NE 80$	FOS	?CLOSE		; ferme l'image	JUMP'	EXIT$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	POPM.L	D3,D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IMADRAW >;========/; Affiche une image dans la fentre.; in	A4.L	^image;	D2.W	mode d'affichage; out	-; mod	D7.WIMADRAW:	PUSHM.L	D1..D5,A2..A4	CALL	CCMO		; enlve la souris	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.W	D1,D2	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	COMP.W	D1,D2	JUMP',NE MODE$	CALL	AFFIFINV	; affichage invers ?	JUMP',NE MODE$		; non => MODE$	TSET.L	D2:#BCPLDOTMODE$:	LOAD.W	D1,D2	CLR.L	D3		; D3 <-- origine source	LOAD.W	D5,(A2)+OIMDLX	SR.W	D5,#3		; D5 <-- Iy source	LOAD.L	A3,(A4)+LGHIMA	; A3 <-- ^source	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	LOAD.W	D4,(A0)+ODFFDY	SUB.W	D4,(A2)+OIMDLY	SR.W	D4,#1	SWAP.W	D4	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,(A2)+OIMDLX	SR.W	D4,#1	LOAD.W	D2,(A2)+OIMDLY	SWAP.W	D2	LOAD.W	D2,(A2)+OIMDLX	CALL	DRRASTER	; affiche l'image	CALL	SCMO		; remet la souris	POPM.L	D1..D5,A2..A4	RET;---------\\; IMACLOSE >;=========/; Ferme une image.; in	A4.L	^image; out	-; mod	D7.WIMACLOSE:	PUSHM.L	D1,A1,A2,A4	COMP.L	A4,#0	JUMP',EQ EXIT$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.L	A1,(A4)+LGHIMA	; A1 <-- ^data	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-teteEXIT$:	POPM.L	D1,A1,A2,A4	RET;---------\\; IMARNAME >;---------/; Construit le nom d'une image  lire d'aprs une date.;;	rep:nnnnnnn.Mtddddd;	-------------------;	rep:	-->  nom du fichier .MEMENTO;	nnnnnnn	-->  nom du fichier .MEMENTO;	t	-->  type (1=anne, 2=semaine, 3=journe);	ddddd	-->  date (nombre de jours depuis 1.1.1900); in	D4.L	date; out	A3.L	^nom du fichier; mod	D7.W, A3.LIMARNAME:	PUSHM.L	D2..D4,A4	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^buffer pour nom	LOAD.L	A3,#(A6)+OFILORI20$:	LOAD.B	D3,(A3+)	JUMP',EQ 22$	COMP.B	D3,#'.	JUMP',EQ 22$	LOAD.B	(A4+),D3	JUMP	20$22$:	LOAD.B	(A4+),#'.	LOAD.B	(A4+),#'M	LOAD.B	D3,#'1	COMP.B	D4,#HIMAY	JUMP',EQ 30$	LOAD.B	D3,#'2	COMP.B	D4,#HIMAW	JUMP',EQ 30$	LOAD.B	D3,#'330$:	LOAD.B	(A4+),D3	CALL	CALCNJ		; D4 <-- nombre de jours	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDALL	LIB	?PUTDEC	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^nom	POPM.L	D2..D4,A4	RET;---------\\; IMAWNAME >;---------/; Construit le nom d'une image  crire d'aprs une date.;;	rep:Mssssss.Mtddddd;	-------------------;	rep:	-->  nom du fichier .MEMENTO;	ssssss	-->  numro du SMAKY;	t	-->  type (1=anne, 2=semaine, 3=journe);	ddddd	-->  date (nombre de jours depuis 1.1.1900); in	D4.L	date; out	A3.L	^nom du fichier; mod	D7.W, A3.LIMAWNAME:	PUSHM.L	D2..D4,A4	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^buffer pour nom	LOAD.L	A3,#(A6)+OFILORI20$:	LOAD.B	(A4+),(A3+)	JUMP,NE 20$	LOAD.L	A3,#(A6)+OBUDIS	CALL	SKIPREP	LOAD.L	A4,A3	LOAD.B	(A4+),#'M	PUSH.L	D4	NTREL	?GETMACHINE	; D4/A3 <-- informations	AND.L	D4,#H'FFFF	LOAD.W	D3,#6	LOAD.W	D2,#2^BAFDALL	LIB	?PUTDEC	POP.L	D4	LOAD.B	(A4+),#'.	LOAD.B	(A4+),#'M	LOAD.B	D3,#'1	COMP.B	D4,#HIMAY	JUMP',EQ 30$	LOAD.B	D3,#'2	COMP.B	D4,#HIMAW	JUMP',EQ 30$	LOAD.B	D3,#'330$:	LOAD.B	(A4+),D3	CALL	CALCNJ		; D4 <-- nombre de jours	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDALL	LIB	?PUTDEC	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^nom	POPM.L	D2..D4,A4	RET;---------\\; DRRASTER >;=========/; Dplace une surface rectangulaire mmoire/cran --> mmoire/cran.; in	D3.L	coordonne source (y;x);	A3.L	^mmoire source/^nil si cran;	D5.W	Iy source (si mmoire);	----;	D4.L	coordonne destination (y;x);	A4.L	^mmoire destination/^nil si cran;	D6.W	Iy destination (si mmoire);	----;	D2.L	hauteur/largeur (y;x);	D1.W	opration (INVDOT, SETDOT, CLRDOT ou LOADDOT); out	-; mod	D7.WDRRASTER:	PUSHM.L	D0,D5,D6,A2	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	CLR.W	D0	LOAD.B	D0,(A0)+ODFCNP	; D0 <-- nb de bits/pixel (1,4)	COMP.W	D0,#1	JUMP',NE COUL$	GRA_	RASTER	JUMP'	EXIT$COUL$:	TEST.L	D1:#BSRCCOUL	JUMP',BC CSRC$	MUL.WU	D5,D0		; D5 <-- Iy sourceCSRC$:	TEST.L	D1:#BDSTCOUL	JUMP',BC CDST$	MUL.WU	D6,D0		; D6 <-- Iy destinationCDST$:	GRA_	CRASTEREXIT$:	POPM.L	D0,D5,D6,A2	RET	.END