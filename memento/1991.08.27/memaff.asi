	.SBTTL	MEMAFFLGXTIME	=	30		; largeur pour afficher l'heure;-------------\\; AFFMOVEICONE >;=============/; Inverse une icne tant que la souris est maintenue presse.; in	-; out	D3.W	icne o est la souris (ICOxxxx);	D7.W	erreur; mod	D3.L, D7.WAFFMOVEICONE:	PUSHM.L	D2,D4	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE EXIT$	CALL	AFFDETICONE	; D3 <-- icne o est la souris	JUMP,NE EXIT$	LOAD.W	D2,#-1	JUMP'	30$20$:	LIB	?GETKEY	COMP.W	D3,#KEYMPO	JUMP',NE 50$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 20$	CALL	AFFDETICONE	; D3 <-- icne o est la souris	COMP.W	D3,D2		; toujours sur la mme ?	JUMP,EQ 20$		; oui => 20$30$:				; non =>	EX.L	D2,D3	CALL	AFFINVICONE	; teint l'ancienne	LOAD.W	D3,D2	CALL	AFFINVICONE	; allume la nouvelle	JUMP	20$50$:	LOAD.W	D3,D2	CALL	AFFINVICONE	; teint la dernire	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; AFFINVOUTIL >;============/; Inverse l'outil de dessin slectionn.; in	-; out	-; mod	D7.WAFFINVOUTIL:	PUSH.W	D3	TEST.B	(A6)+ODESS+3:#BDESFL-0	JUMP',BS EXIT$	LOAD.W	D3,#ICOCRAYON	TEST.B	(A6)+ODESS+3:#BDESCR-0	JUMP',BS 50$	LOAD.W	D3,#ICOPINCEAU	TEST.B	(A6)+ODESS+3:#BDESPI-0	JUMP',BS 50$	LOAD.W	D3,#ICOGOMME	TEST.B	(A6)+ODESS+3:#BDESGO-0	JUMP',BC EXIT$50$:	CALL	AFFINVICONEEXIT$:	POP.W	D3	RET;------------\\; AFFINVOBJET >;============/; Inverse l'objet de dessin slectionn.; in	-; out	-; mod	D7.WAFFINVOBJET:	PUSH.W	D3	TEST.B	(A6)+ODESS+3:#BDESFL-0	JUMP',BS EXIT$	LOAD.W	D3,#ICOTRAIT	TEST.B	(A6)+ODESS+3:#BDESTM-0	JUMP',BS 50$	LOAD.W	D3,#ICODROITE	TEST.B	(A6)+ODESS+3:#BDESDR-0	JUMP',BS 50$	LOAD.W	D3,#ICOTRAME	TEST.B	(A6)+ODESS+3:#BDESTR-0	JUMP',BS 50$	LOAD.W	D3,#ICORECTANGLE	TEST.B	(A6)+ODESS+3:#BDESRE-0	JUMP',BC EXIT$50$:	CALL	AFFINVICONEEXIT$:	POP.W	D3	RET;------------\\; AFFINVICONE >;============/; Inverse une icne.; in	D3.W	icne o est la souris (ICOxxxx); out	-; mod	D7.WAFFINVICONE:	PUSHM.L	D2..D4,A4	COMP.W	D3,#-1	JUMP',EQ EXIT$	LOAD.L	A4,#(A6)+OTAICO-1020$:	LOAD.L	A4,#(A4)+10	LOAD.W	D4,(A4)	JUMP',EQ EXIT$	COMP.W	D3,D4	JUMP,NE 20$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_PPHILI	LIB	?COLORSR	LOAD.L	D3,(A4)+2	LOAD.L	D4,(A4)+6	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse l'icne	LIB	?COLORPOPEXIT$:	POPM.L	D2..D4,A4	RET;------------\\; AFFDETICONE >;============/; Dtecte dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D3.W	icne o est la souris (ICOxxxx);	D7.W	erreur; mod	D3.L, D7.WAFFDETICONE:	PUSHM.L	D2,D4,D5,A4	LOAD.L	D5,D4		; D4 <-- position en X	SWAP.W	D5		; D5 <-- position en Y	LOAD.W	D7,#1		; D7 <-- pas trouv	COMP.W	D4,#332	JUMP',LO 10$	COMP.W	D4,#332+286	JUMP',HS 10$	COMP.W	D5,#17	JUMP',LO 10$	COMP.W	D5,#17+28	JUMP',HS 10$	CLR.W	D7		; D7 <-- trouv10$:	LOAD.L	A4,#(A6)+OTAICO-10	LOAD.W	D3,#-120$:	LOAD.L	A4,#(A4)+10	TEST.W	(A4)	JUMP',EQ EXIT$	LOAD.W	D2,(A4)+4	COMP.W	D4,D2		; trop  gauche ?	JUMP,LO 20$	ADD.W	D2,(A4)+8	COMP.W	D4,D2		; trop  droite ?	JUMP,HS 20$	LOAD.W	D2,(A4)+2	COMP.W	D5,D2		; trop en haut ?	JUMP,LO 20$	ADD.W	D2,(A4)+6	COMP.W	D5,D2		; trop en bas ?	JUMP,HS 20$	LOAD.W	D3,(A4)		; D3 <-- icne	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D4,D5,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; AFFCLRICONE >;============/; Efface les anciennes icnes.; in	-; out	-; mod	D7.WAFFCLRICONE:	PUSHM.L	D2..D4	LOAD.W	D2,#CLRDOT	CLR.L	D3	CLR.L	D4	CALL	AFFINVTRAME	; D2/D3D4 <-- inverse v. mode/trame	LIB	?DRMDEF	LOAD.L	D3,#H'10000*17+332	LOAD.L	D4,#H'10000*28+286	LIB	?DRTRAME	; efface	POPM.L	D2..D4	RET;-------------\\; AFFDRAWICONE >;=============/; Affiche toutes les icnes.; in	-; out	-; mod	D7.WAFFDRAWICONE:	PUSHM.L	D3,D4,A4	LIB	?COLORPUSH	LOAD.L	D3,#COLORICONES	LIB	?COLORSR	CALL	AFFTAICONE	; OTAICO <-- icnes actuelles	LIB	?AFTIM	.B	USEGC,GCT4F,GCT4S,GCT4T,0	.EVEN	CALL	AFFIFINV	; affichage invers ?	JUMP',NE 10$		; non => 10$	LOAD.B	D3,#AFINV	LIB	?AFCAR10$:	LOAD.L	A4,#(A6)+OTAICO-1020$:	LOAD.L	A4,#(A4)+10	LOAD.W	D4,(A4)	JUMP',EQ 80$	COMP.W	D4,#128	JUMP,HS 20$	LOAD.L	D3,(A4)+2	ADD.W	D3,(A0)+ODFC1X	SWAP.W	D3	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LIB	?SETCURS	COMP.W	D4,(A6)+OTYPE	JUMP',NE 30$	LOAD.B	D3,#AFGREY	LIB	?AFCAR30$:	COMP.W	D4,#ICOLIST	JUMP',NE 32$	TEST.W	(A6)+ORDVNB	JUMP',NE 32$	LOAD.B	D3,#AFGREY	LIB	?AFCAR32$:	LOAD.W	D3,D4	LIB	?AFCODE		; affiche une icne	LOAD.B	D3,#AFFULL	LIB	?AFCAR	JUMP	20$80$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	AFDIR	.B	0	.EVEN	CALL	AFFINVOUTIL	; allume l'outil	CALL	AFFINVOBJET	; allume l'objet	LIB	?COLORPOP	POPM.L	D3,D4,A4	RET;-----------\\; AFFTAICONE >;-----------/; Construit la table des icnes.; in	-; out	-; mod	D7.WAFFTAICONE:	PUSHM.L	D3,A3,A4	LOAD.L	A4,#(A6)+OTAICO	LOAD.L	A3,#R16"TABLE1$	TEST.B	(A6)+ODESS+3:#BDESFL-0	JUMP',BS 20$	LOAD.L	A3,#R16"TABLE2$20$:	LOAD.W	D3,(A3+)	JUMP',EQ 50$	LOAD.W	(A4+),D3	LOAD.L	(A4+),(A3+)	LOAD.L	(A4+),(A3+)	JUMP	20$50$:	CLR.W	(A4)	POPM.L	D3,A3,A4	RETTABLE1$:	.W	ICOPREV	.W	299,17,30,33	.W	ICONEXT	.W	299,589,30,33	.W	ICOCHAR	.W	299-24,17,22,33	.W	ICOCHAV	.W	299-24,589,22,33	.W	ICOCRAYON	.W	19,344,24,24	.W	ICOYEAR	.W	19,344+36,24,24	.W	ICOWEEK	.W	19,344+36+30,24,24	.W	ICODAY	.W	19,344+36+30+30,24,24	.W	ICOLIST	.W	19,344+36+30+30+36,24,24	.W	ICOGOTO	.W	19,344+36+30+30+36+48,24,24	.W	ICOINFO	.W	19,344+36+30+30+36+48+30,24,24	.W	ICOPSION	.W	19,344+36+30+30+36+48+30+30,24,24	.W	0TABLE2$:	.W	ICOPREV	.W	299,17,30,33	.W	ICONEXT	.W	299,589,30,33	.W	ICOCHAR	.W	299-24,17,22,33	.W	ICOCHAV	.W	299-24,589,22,33	.W	ICOFLECHE	.W	19,344,24,24	.W	ICOCRAYON	.W	19,344+36,24,24	.W	ICOPINCEAU	.W	19,344+36+23,24,24	.W	ICOGOMME	.W	19,344+36+23+23,24,24	.W	ICOTRAIT	.W	19,344+36+23+23+32,24,24	.W	ICODROITE	.W	19,344+36+23+23+32+23,24,24	.W	ICORECTANGLE	.W	19,344+36+23+23+32+23+23,24,24	.W	ICOTRAME	.W	19,344+36+23+23+32+23+23+23,24,24	.W	ICOLIB	.W	19,344+36+23+23+32+23+23+23+32,24,24	.W	ICOAJIMAGE	.W	19,344+36+23+23+32+23+23+23+32+28,24,24	.W	0;-----------\\; AFFMODTYPE >;===========/; Modifie la date courante en fonction du type.; in	D4.L	nouvelle date; out	D7.W	erreur; mod	D7.WAFFMODTYPE:	PUSHM.L	D3,D4	CLR.W	D7		; D7 <-- ok	COMP.W	(A6)+OTYPE,#ICODAY	JUMP',EQ DAY$	COMP.W	(A6)+OTYPE,#ICOWEEK	JUMP',EQ WEEK$	COMP.W	(A6)+OTYPE,#ICOYEAR	JUMP',EQ YEAR$	JUMP'	EXIT$DAY$:	CALL	DBOXRDV		; dite un rendez-vous ...	JUMP',NE EXIT$	LOAD.W	D7,#ERKSTO	COMP.W	D3,#F0		; (ANNULE) ?	JUMP',EQ EXIT$		; oui => EXIT$	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$WEEK$:	LOAD.W	(A6)+OTYPE,#ICODAY	LOAD.L	(A6)+OHERE,D4	CALL	AFFRNDTYPE	; ODATE <-- arrondi selon le type	JUMP'	EXIT$YEAR$:	LOAD.W	(A6)+OTYPE,#ICOWEEK	LOAD.L	(A6)+OHERE,D4	CALL	AFFRNDTYPE	; ODATE <-- arrondi selon le type;	JUMP'	EXIT$EXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; AFFDETTYPE >;===========/; Dtecte selon le type.; in	-; out	D4.L	date o est la souris;	D7.W	erreur; mod	D4.L, D7.WAFFDETTYPE:	LOAD.W	(A6)+OOPER,#OPDET	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE 80$	LOAD.L	(A6)+OAPOS,D4	LOAD.L	(A6)+OADET,#-1	CALL	AFFDRAWTYPE	; dtecte	LOAD.W	D7,#1	LOAD.L	D4,(A6)+OADET	; D4 <-- date dtecte	COMP.L	D4,#-1	JUMP',EQ 80$	CLR.W	D780$:	LOAD.W	(A6)+OOPER,#OPAFF	TEST.W	D7		; retour EQ/NE	RET;------------\\; AFFDRAWTYPE >;============/; Affiche selon le type.; in	-; out	-; mod	D7.WAFFDRAWTYPE:	COMP.W	(A6)+OTYPE,#ICODAY	JUMP,EQ AFFDAY	COMP.W	(A6)+OTYPE,#ICOWEEK	JUMP,EQ AFFWEEK	COMP.W	(A6)+OTYPE,#ICOYEAR	JUMP,EQ AFFYEAR	RET;-----------\\; AFFRNDTYPE >;===========/; Arrondi selon le type.; in	-; out	-; mod	D7.WAFFRNDTYPE:	PUSH.L	D4	LOAD.L	D4,(A6)+OHERE	COMP.W	(A6)+OTYPE,#ICODAY	JUMP',EQ DAY$	COMP.W	(A6)+OTYPE,#ICOWEEK	JUMP',EQ WEEK$	COMP.W	(A6)+OTYPE,#ICOYEAR	JUMP',EQ YEAR$	JUMP'	EXIT$DAY$:;	CALL	DATERNDDAY	; D4 <-- arrondi au jour (!)	JUMP'	EXIT$WEEK$:	CALL	DATERNDWEEK	; D4 <-- arrondi  la semaine	JUMP'	EXIT$YEAR$:	CALL	DATERNDYEAR	; D4 <-- arrondi  la demi-anne;	JUMP'	EXIT$EXIT$:	LOAD.L	(A6)+ODATE,D4	POP.L	D4	RET;------------\\; AFFNEXTTYPE >;============/; Suivant selon le type.; in	-; out	D7.W	erreur; mod	D7.WAFFNEXTTYPE:	PUSHM.L	D3,D4,	LOAD.W	D7,#ERMMDAT	; D7 <-- date incorrecte	LOAD.L	D4,(A6)+ODATE	COMP.W	(A6)+OTYPE,#ICODAY	JUMP',EQ DAY$	COMP.W	(A6)+OTYPE,#ICOWEEK	JUMP',EQ WEEK$	COMP.W	(A6)+OTYPE,#ICOYEAR	JUMP',EQ YEAR$	JUMP'	EXIT$WEEK$:	COMP.L	D4,#H'F8122900	JUMP',HS EXIT$	CALL	DATENEXTDAY	; D4 <-- jour suivant	CALL	DATENEXTDAY	; D4 <-- jour suivant	CALL	DATENEXTDAY	; D4 <-- jour suivant	CALL	DATENEXTDAY	; D4 <-- jour suivant	CALL	DATENEXTDAY	; D4 <-- jour suivant	CALL	DATENEXTDAY	; D4 <-- jour suivant	CALL	DATENEXTDAY	; D4 <-- jour suivant	JUMP'	OK$DAY$:	COMP.L	D4,#H'F8123100	JUMP',HS EXIT$	CALL	DATENEXTDAY	; D4 <-- jour suivant	JUMP'	OK$YEAR$:	COMP.L	D4,#H'F8070000	JUMP',HS EXIT$	CALL	DATENEXTMONTH	; D4 <-- mois suivant	CALL	DATENEXTMONTH	; D4 <-- mois suivant	CALL	DATENEXTMONTH	; D4 <-- mois suivant	CALL	DATENEXTMONTH	; D4 <-- mois suivant	CALL	DATENEXTMONTH	; D4 <-- mois suivant	CALL	DATENEXTMONTH	; D4 <-- mois suivant;	JUMP'	OK$OK$:	LOAD.L	(A6)+ODATE,D4	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; AFFPREVTYPE >;============/; Prcdent selon le type.; in	-; out	D7.W	erreur; mod	D7.WAFFPREVTYPE:	PUSHM.L	D3,D4	LOAD.W	D7,#ERMMDAT	; D7 <-- date incorrecte	LOAD.L	D4,(A6)+ODATE	COMP.W	(A6)+OTYPE,#ICODAY	JUMP',EQ DAY$	COMP.W	(A6)+OTYPE,#ICOWEEK	JUMP',EQ WEEK$	COMP.W	(A6)+OTYPE,#ICOYEAR	JUMP',EQ YEAR$	JUMP'	EXIT$WEEK$:	COMP.L	D4,#H'01010700	JUMP',LO EXIT$	CALL	DATEPREVDAY	; D4 <-- jour prcdent	CALL	DATEPREVDAY	; D4 <-- jour prcdent	CALL	DATEPREVDAY	; D4 <-- jour prcdent	CALL	DATEPREVDAY	; D4 <-- jour prcdent	CALL	DATEPREVDAY	; D4 <-- jour prcdent	CALL	DATEPREVDAY	; D4 <-- jour prcdent	CALL	DATEPREVDAY	; D4 <-- jour prcdent	JUMP'	OK$DAY$:	COMP.L	D4,#H'01010200	JUMP',LO EXIT$	CALL	DATEPREVDAY	; D4 <-- jour prcdent	JUMP'	OK$YEAR$:	COMP.L	D4,#H'01070000	JUMP',LO EXIT$	CALL	DATEPREVMONTH	; D4 <-- mois prcdent	CALL	DATEPREVMONTH	; D4 <-- mois prcdent	CALL	DATEPREVMONTH	; D4 <-- mois prcdent	CALL	DATEPREVMONTH	; D4 <-- mois prcdent	CALL	DATEPREVMONTH	; D4 <-- mois prcdent	CALL	DATEPREVMONTH	; D4 <-- mois prcdent;	JUMP'	OK$OK$:	LOAD.L	(A6)+ODATE,D4	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; AFFCHAVTYPE >;============/; Cherche en avant, selon le type.; in	-; out	D7.W	erreur; mod	D7.WAFFCHAVTYPE:	PUSHM.L	D3,D4,A4	CALL	LOCK		; dbut de zone critique	LOAD.L	D4,(A6)+ODATE	LOAD.L	D3,D4	COMP.W	(A6)+OTYPE,#ICODAY	JUMP',EQ DAY$	COMP.W	(A6)+OTYPE,#ICOWEEK	JUMP',EQ WEEK$	COMP.W	(A6)+OTYPE,#ICOYEAR	JUMP',EQ YEAR$	JUMP	EXIT$WEEK$:	CALL	DATENEXTDAY	; D4 <-- jour suivant	CALL	DATENEXTDAY	; D4 <-- jour suivant	CALL	DATENEXTDAY	; D4 <-- jour suivant	CALL	DATENEXTDAY	; D4 <-- jour suivant	CALL	DATENEXTDAY	; D4 <-- jour suivant	CALL	DATENEXTDAY	; D4 <-- jour suivantDAY$:	CALL	DATENEXTDAY	; D4 <-- jour suivant	JUMP'	SEARCH$YEAR$:	CALL	DATENEXTMONTH	; D4 <-- mois suivant	CALL	DATENEXTMONTH	; D4 <-- mois suivant	CALL	DATENEXTMONTH	; D4 <-- mois suivant	CALL	DATENEXTMONTH	; D4 <-- mois suivant	CALL	DATENEXTMONTH	; D4 <-- mois suivant	CALL	DATENEXTMONTH	; D4 <-- mois suivant;	JUMP'	SEARCH$SEARCH$:	EX.L	D3,D4	CLR.B	D3LOOP$:	CALL	RDVCHAV		; D4 <-- rendez-vous suivant	JUMP,NE EXIT$	CLR.B	D4	COMP.L	D4,D3	JUMP,LO LOOP$	LOAD.L	(A6)+OHERE,D4	CALL	AFFRNDTYPE	; ODATE <-- arrondi selon le type	CLR.W	D7		; D7 <-- okEXIT$:	CALL	UNLOCK		; fin de zone critique	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; AFFCHARTYPE >;============/; Cherche en arrire, selon le type.; in	-; out	D7.W	erreur; mod	D7.WAFFCHARTYPE:	PUSHM.L	D3,D4,A4	CALL	LOCK		; dbut de zone critique	LOAD.L	D4,(A6)+ODATE	LOAD.L	D3,D4	CLR.B	D3LOOP$:	CALL	RDVCHAR		; D4 <-- rendez-vous prcdent	JUMP,NE EXIT$	CLR.B	D4	COMP.L	D4,D3	JUMP,HS LOOP$	LOAD.L	(A6)+OHERE,D4	CALL	AFFRNDTYPE	; ODATE <-- arrondi selon le type	CLR.W	D7		; D7 <-- okEXIT$:	CALL	UNLOCK		; fin de zone critique	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; AFFDAY  >;========/; Affiche toute une journe.; in	-; out	-; mod	D7.WAFFDAY:	PUSHM.L	D1..D5,A3,A4	CALL	LOCK		; dbut de zone critique	LIB	?COLORPUSH	LOAD.L	D3,#COLORCONTENU	LIB	?COLORSR	LOAD.L	D4,(A6)+ODATE	; D4 <-- date initiale	LOAD.L	A4,#R16"NIL$	COMP.W	(A6)+OOPER,#OPAFF	JUMP,NE 24$	CALL	AFFCLRDATA	; efface le data prcdent	LOAD.B	D3,#MODCAR	LIB	?AFCAR	LOAD.B	D2,#SETDOT!PENDOT	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	LOAD.B	D3,D2	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC,GCT3F,GCT3S,GCT3T,0	.EVEN	PUSH.L	D4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCT3F	LOAD.B	(A3+),#GCT3S	LOAD.B	(A3+),#GCT3T	CALL	DATEJDLS	LOAD.B	(A3+),#SPACE	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCT2F	LOAD.B	(A3+),#GCT2S	LOAD.B	(A3+),#GCT2T	CALL	DATEDAY	LOAD.B	(A3+),#SPACE	LOAD.L	A4,A3	CALL	DATEMONTH	ADD.B	(A4),#'a-'A	; 1re lettre du mois = minuscule !	LOAD.B	(A3+),#SPACE	CALL	DATEYEAR	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	D3,#H'10000*40+24	LOAD.W	D4,#280	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFTEXT		; affiche le mois et l'anne	POP.L	D4	PUSH.L	D4	CALL	FETELUNE	; D3 <-- phase de la lune	JUMP',NE 20$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCT1F	LOAD.B	(A3+),#GCT1S	LOAD.B	(A3+),#GCT1T	LOAD.B	(A3+),D3	CLR.B	(A3)	LIB	?COLORPUSH	LOAD.L	D3,#COLORLUNE	LIB	?COLORSR	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D4,#20	LOAD.L	D3,#H'10000*(80-10)+60-30	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFTEXT		; affiche la phase de la lune	LIB	?COLORPOP20$:	POP.L	D4	LOAD.L	A4,#R16"MATIN$	CALL	FETETEXT	; A3 <-- ^nom de la fte	JUMP',NE 24$	LIB	?AFTIM	.B	USEGC,GCT3F,GCT3S,GCT3T,0	.EVEN	COMP.W	D3,#20		; y a-t-il beaucoup de caractres ?	JUMP',LO 22$		; non => 22$	LIB	?AFTIM	.B	USEGC,GCT2F,GCT2S,GCT2T,0	.EVEN22$:	PUSH.L	D4	LOAD.W	D4,#233	LOAD.L	D3,#H'10000*(80+85*0-6)+60	LOAD.W	D2,#2^BAFFCENTER!2^BAFFRECT!2^BAFFFGRF!2^BAFFBOLD	CALL	AFFTEXT		; affiche la fte	POP.L	D4	LOAD.L	A4,#R16"NIL$24$:	LOAD.L	D3,#H'10000*(80+85*0)+60	LOAD.W	D5,#233	LOAD.W	D2,#2^BAFFLEFT	LOAD.L	A3,A4	LOAD.L	A4,#R16"HOUR1$	CALL	AFFDHOUR	LOAD.L	D3,#H'10000*(80+85*0)+320+26	LOAD.W	D5,#233	LOAD.W	D2,#2^BAFFRIGHT	LOAD.L	A3,#R16"APRES$	LOAD.L	A4,#R16"HOUR2$	CALL	AFFDHOUR	COMP.W	(A6)+OOPER,#OPAFF	JUMP',NE EXIT$	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	MODCAR,SETDOT	.B	0	.EVEN	CALL	IMADESSIN	; affiche l'image de dessinEXIT$:	LIB	?COLORPOP	CALL	UNLOCK		; fin de zone critique	POPM.L	D1..D5,A3,A4	RETNIL$:	.B	0MATIN$:	.ASCIZ	"Matin"APRES$:	.ASCIZ	"Aprs-midi et soir"HOUR1$:	.B	(00*6)+(00/10),0	.B	(01*6)+(00/10),0	.B	(02*6)+(00/10),0	.B	(03*6)+(00/10),0	.B	(04*6)+(00/10),0	.B	(05*6)+(00/10),1	.B	(06*6)+(00/10),0	.B	(06*6)+(30/10),0	.B	(07*6)+(00/10),0	.B	(07*6)+(30/10),0	.B	(08*6)+(00/10),0	.B	(08*6)+(30/10),0	.B	(09*6)+(00/10),0	.B	(09*6)+(30/10),0	.B	(10*6)+(00/10),0	.B	(10*6)+(30/10),0	.B	(11*6)+(00/10),0	.B	(11*6)+(30/10),0HOUR2$:	.B	(12*6)+(00/10),0	.B	(12*6)+(30/10),0	.B	(13*6)+(00/10),0	.B	(13*6)+(30/10),0	.B	(14*6)+(00/10),0	.B	(14*6)+(30/10),0	.B	(15*6)+(00/10),0	.B	(15*6)+(30/10),0	.B	(16*6)+(00/10),0	.B	(16*6)+(30/10),0	.B	(17*6)+(00/10),0	.B	(17*6)+(30/10),1	.B	(18*6)+(00/10),0	.B	(19*6)+(00/10),0	.B	(20*6)+(00/10),0	.B	(21*6)+(00/10),0	.B	(22*6)+(00/10),0	.B	(23*6)+(00/10),0	.EVEN;---------\\; AFFDHOUR >;---------/; Affiche quelques heures.; in	D3.L	coordonne initiale;	D4.L	date initiale (BCD);	D5.W	largeur;	D2.W	mode pour afficher la priode;	A3.L	^texte;	A4.L	^table des heures; out	-; mod	D7.WAFFDHOUR:	PUSHM.L	D1..D5,A3,A4	LOAD.L	(A6)+OADATA,D4	; OADATA <-- date pour dtection	COMP.W	(A6)+OOPER,#OPAFF	JUMP',NE 30$	LIB	?AFTIM	.B	MAPTT	.B	B'00010001	; map	.B	1		; chelle	.B	USEGC,GCT2F,GCT2S,GCT2T	.B	0	.EVEN	TEST.B	(A3)	JUMP',EQ 20$	PUSHM.L	D3,D4	LOAD.W	D4,D5	SWAP.W	D3	SUB.W	D3,#8	SWAP.W	D3	CALL	AFFTEXT		; affiche la priode	POPM.L	D3,D420$:	LOAD.W	D2,#SETDOT	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	LIB	?BUCAR30$:	CLR.L	D4	LOAD.W	D4,D5	LOAD.W	D1,#18-140$:	SWAP.W	D3	ADD.W	D3,(A6)+OMCY	SWAP.W	D3	PUSHM.L	D2,D4	PUSH.W	D4	LOAD.L	D4,(A6)+OADATA	LOAD.B	D4,(A4)+0	; D4 <-- heure suivante	LOAD.L	(A6)+OADATA,D4	; OADATA <-- pour dtection	LOAD.L	A3,#(A6)+OBUDIS	CALL	DATEQTIME	LOAD.L	A3,#(A6)+OBUDIS	POP.W	D4	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFTEXT		; affiche l'heure	POPM.L	D2,D4	COMP.W	(A6)+OOPER,#OPAFF	JUMP',NE 70$	PUSHM.L	D3,D4	ADD.W	D3,#LGXTIME+16	SUB.W	D4,#LGXTIME+16	TSET.L	D2:#BTTTDOT	TEST.B	(A4)+1	JUMP',EQ 50$	TCLR.L	D2:#BTTTDOT50$:	LIB	?DRSEG		; trace une ligne pointille horizontale	POPM.L	D3,D4	PUSHM.L	D0,D4,A4	PUSH.L	D4	LOAD.L	D4,(A6)+OADATA	LOAD.L	D0,D4	CALL	RDVSEARCH	; A4 <-- ^rendez-vous	POPM.L	D4	JUMP',NE 68$	PUSH.W	D2	LOAD.W	D2,#1		; D2 <-- affiche la flche	CALL	AFFRDV		; affiche le rendez-vous	CALL	AFFDDUR		; affiche la dure ventuelle	POP.W	D268$:	POPM.L	D0,D4,A470$:	ADD.L	A4,#2	DECJ.W,NMO D1,40$	LIB	?NOBUCAR	POPM.L	D1..D5,A3,A4	RET;--------\\; AFFDDUR >;--------/; Affiche la dure d'un rendez-vous.; in	A4.L	^rendez-vous;	D0.L	date; out	-; mod	D7.WAFFDDUR:	PUSHM.L	D0..D4,A3	LOAD.W	D4,(A4)+ORMDUR	COMP.W	D4,#60	JUMP,LO EXIT$	LOAD.L	A3,#R16"PEN$	LOAD.W	D3,#1+8	LIB	?STRING	AND.L	D0,#H'FF	DIV.WU	D0,#6	MUL.WU	D0,#60	ADD.W	D0,(A4)+ORMMIN	; D0 <-- heure de dbut	LOAD.W	D1,D0	ADD.W	D1,D4		; D1 <-- heure de fin	LOAD.L	A3,#R16"TABLE$-620$:	ADD.L	A3,#6		; A3 <-- ^suivant	COMP.W	(A3)+6,#-1	; fin de la table ?	JUMP,EQ EXIT$		; oui => EXIT$	COMP.W	(A3)+6,#-2	JUMP,EQ 20$	COMP.W	(A3),#-2	JUMP,EQ 20$	COMP.W	D0,(A3)		; dbut dans cette tranche de temps ?	JUMP,LO 20$		; non => 20$	COMP.W	D0,(A3)+6	JUMP,HS 20$	LOAD.W	D3,(A3)+2	; D3 <-- origine (y)	LOAD.W	D4,D0	SUB.W	D4,(A3)	LOAD.W	D2,(A3)+6+2	SUB.W	D2,(A3)+2	MUL.WU	D4,D2	DIV.WU	D4,#60	ADD.W	D3,D4	SWAP.W	D3	LOAD.W	D3,(A3)+4	; D3 <-- origine (x)	LOAD.W	D4,D1	SUB.W	D4,(A3)		; D4 <-- dure restante	COMP.W	D4,#60	JUMP',LO 30$	LOAD.W	D4,#6030$:	LOAD.W	D2,(A3)+6+2	SUB.W	D2,(A3)+2	MUL.WU	D4,D2	DIV.WU	D4,#60		; D4 <-- hauteur	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT!PENDOT	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	LIB	?DRSEG		; trace une droite verticale	LOAD.W	D0,(A3)+6	COMP.W	D1,(A3)		; fin dans cette tranche de temps ?	JUMP,LO 20$		; non => 20$	COMP.W	D1,(A3)+6	JUMP,HS 20$	LOAD.W	D4,#-7	SWAP.W	D4	LOAD.W	D4,#-3	LOAD.W	D2,#SETDOT!PENDOT	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	PUSH.L	D3	LIB	?DRSEG		; trace une flche	POP.L	D3	LOAD.W	D4,#+3	LIB	?DRSEGEXIT$:	POPM.L	D0..D4,A3	RETPEN$:	.B	PEN	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00111000	.B	B'00010000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.EVENTABLE$:	.W	00*60	80+1+13*01,60+LGXTIME-6	.W	01*60	80+1+13*02,60+LGXTIME-6	.W	02*60	80+1+13*03,60+LGXTIME-6	.W	03*60	80+1+13*04,60+LGXTIME-6	.W	04*60	80+1+13*05,60+LGXTIME-6	.W	05*60	80+1+13*06,60+LGXTIME-6	.W	06*60	80+1+13*07,60+LGXTIME-6	.W	07*60	80+1+13*09,60+LGXTIME-6	.W	08*60	80+1+13*11,60+LGXTIME-6	.W	09*60	80+1+13*13,60+LGXTIME-6	.W	10*60	80+1+13*15,60+LGXTIME-6	.W	11*60	80+1+13*17,60+LGXTIME-6	.W	12*60	80+1+13*19,60+LGXTIME-6	.W	-2,0,0	.W	12*60	80+1+13*01,320+26+LGXTIME-6	.W	13*60	80+1+13*03,320+26+LGXTIME-6	.W	14*60	80+1+13*05,320+26+LGXTIME-6	.W	15*60	80+1+13*07,320+26+LGXTIME-6	.W	16*60	80+1+13*09,320+26+LGXTIME-6	.W	17*60	80+1+13*11,320+26+LGXTIME-6	.W	18*60	80+1+13*13,320+26+LGXTIME-6	.W	19*60	80+1+13*14,320+26+LGXTIME-6	.W	20*60	80+1+13*15,320+26+LGXTIME-6	.W	21*60	80+1+13*16,320+26+LGXTIME-6	.W	22*60	80+1+13*17,320+26+LGXTIME-6	.W	23*60	80+1+13*18,320+26+LGXTIME-6	.W	24*60	80+1+13*18,320+26+LGXTIME-6	.W	-1;--------\\; AFFWEEK >;========/; Affiche tous les jours d'une semaine.; in	-; out	-; mod	D7.WAFFWEEK:	PUSHM.L	D2..D5,A3,A4	CALL	LOCK		; dbut de zone critique	LIB	?COLORPUSH	LOAD.L	D3,#COLORCONTENU	LIB	?COLORSR	LOAD.L	D4,(A6)+ODATE	; D4 <-- date initiale	COMP.W	(A6)+OOPER,#OPAFF	JUMP,NE 20$	CALL	AFFCLRDATA	; efface le data prcdent	LOAD.B	D3,#MODCAR	LIB	?AFCAR	LOAD.B	D2,#SETDOT!PENDOT	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	LOAD.B	D3,D2	LIB	?AFCAR	PUSH.L	D4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCT3F	LOAD.B	(A3+),#GCT3S	LOAD.B	(A3+),#GCT3T	CALL	DATEMONTH	CALL	DATEIFWEMONTH	;  chaval sur deux mois ?	JUMP',EQ 15$		; non => 15$	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCT2F	LOAD.B	(A4+),#GCT2S	LOAD.B	(A4+),#GCT2T	LOAD.B	(A3+),#'-	CALL	DATENEXTMONTH	CALL	DATEMONTH	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCT3F	LOAD.B	(A3+),#GCT3S	LOAD.B	(A3+),#GCT3T15$:	LOAD.B	(A3+),#SPACE	CALL	DATEYEAR	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	D3,#H'10000*40+24	LOAD.W	D4,#272	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFTEXT		; affiche le mois et l'anne	POP.L	D4	PUSH.L	D4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	A3,#R16"WEEK$17$:	LOAD.B	(A4+),(A3+)	JUMP,NE 17$	DEC.L	A4	CALL	CALCWEEK	; D3 <-- numro de la semaine	CLR.L	D4	LOAD.W	D4,D3	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDCM	LIB	?PUTDEC	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	D3,#H'10000*64+320+26	LOAD.W	D4,#232+37	LOAD.W	D2,#2^BAFFRIGHT	CALL	AFFTEXT		; affiche le numro de la semaine	POP.L	D4	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	USEGC,GCT1F,GCT1S,GCT1T	.B	0	.EVEN20$:	LOAD.L	D3,#H'10000*(80+85*0)+60	LOAD.W	D5,#232	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFWDAY	CALL	DATENEXTDAY	; D4 <-- jour suivant	LOAD.L	D3,#H'10000*(80+85*1)+60	LOAD.W	D5,#232	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFWDAY	CALL	DATENEXTDAY	; D4 <-- jour suivant	LOAD.L	D3,#H'10000*(80+85*2)+60	LOAD.W	D5,#232	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFWDAY	CALL	DATENEXTDAY	; D4 <-- jour suivant	LOAD.L	D3,#H'10000*(80+85*0)+320+26	LOAD.W	D5,#232	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFWDAY	CALL	DATENEXTDAY	; D4 <-- jour suivant	LOAD.L	D3,#H'10000*(80+85*1)+320+26	LOAD.W	D5,#232	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFWDAY	CALL	DATENEXTDAY	; D4 <-- jour suivant	LOAD.L	D3,#H'10000*(80+85*2)+320+26	LOAD.W	D5,#110	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFWDAY	CALL	DATENEXTDAY	; D4 <-- jour suivant	LOAD.L	D3,#H'10000*(80+85*2)+320+26+(232-110)	LOAD.W	D5,#110	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFWDAY	CALL	DATENEXTDAY	; D4 <-- jour suivant	COMP.W	(A6)+OOPER,#OPAFF	JUMP',NE EXIT$	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	MODCAR,SETDOT	.B	0	.EVEN	CALL	IMADESSIN	; affiche l'image de dessinEXIT$:	LIB	?COLORPOP	CALL	UNLOCK		; fin de zone critique	POPM.L	D2..D5,A3,A4	RETWEEK$:	.B	USEGC,GCT0F,GCT0S,GCT0T	.ASCII	"Semaine "	.B	USEGC,GCT1F,GCT1S,GCT1T	.B	0	.EVEN;--------\\; AFFWDAY >;--------/; Affiche un jour.; in	D3.L	coordonne initiale;	D4.L	date initiale (BCD);	D2.W	mode pour afficher le jour de la semaine;	D5.W	largeur; out	-; mod	D7.WAFFWDAY:	PUSHM.L	D0..D6,A3,A4	LOAD.L	(A6)+OADATA,D4	; OADATA <-- date pour dtection	LOAD.W	D1,(A6)+OMCY	MUL.WU	D1,#4	ADD.W	D1,#6	LOAD.W	(A6)+OALGY,D1	; OALGY <-- hauteur suppl. pour dtection	PUSHM.L	D2..D4	CLR.W	D0	LOAD.L	D1,D3	CALL	FETELUNE	; D3 <-- phase de la lune	JUMP',NE 20$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCT1F	LOAD.B	(A3+),#GCT1S	LOAD.B	(A3+),#GCT1T	LOAD.B	(A3+),D3	CLR.B	(A3)	LIB	?COLORPUSH	LOAD.L	D3,#COLORLUNE	LIB	?COLORSR	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	D3,D1	LOAD.W	D4,D5	LOAD.W	D0,#18	COMP.W	D3,#320+26+(232-110) ; dimanche ?	JUMP',NE 15$		; non => 15$	ADD.W	D4,#19	CLR.W	D015$:	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	LOAD.W	D2,#2^BAFFRIGHT	CALL	AFFTEXT		; affiche la phase de la lune	LIB	?COLORPOP20$:	POPM.L	D2..D4	PUSHM.L	D3,D4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCT2F	LOAD.B	(A3+),#GCT2S	LOAD.B	(A3+),#GCT2T	CALL	DATEJDLS	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCT1F	LOAD.B	(A3+),#GCT1S	LOAD.B	(A3+),#GCT1T	LOAD.B	(A3+),#SPACE	CALL	DATEDAY	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D4,D5	SUB.W	D4,D0	CALL	AFFHERE		; D2 <-- inverse si "ici"	CALL	AFFTEXT		; affiche le jour de la semaine	POPM.L	D3,D4	CLR.W	(A6)+OALGY	COMP.W	(A6)+OOPER,#OPAFF	JUMP,NE EXIT$;	LOAD.L	D4,(A6)+OADATA	LOAD.B	D4,#-1		; D4 <-- n'importe quelle heure	CALL	RDVSEARCH	; D4/A4 <-- date/^rendez-vous	LOAD.L	D0,D4	LOAD.W	D2,#SETDOT!TTTDOT	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	LOAD.W	D1,#4-130$:	SWAP.W	D3	ADD.W	D3,(A6)+OMCY	SWAP.W	D3	COMP.W	D1,#4-1		; est-on sur la premire ligne ?	JUMP',NE 40$		; non => 40$	LOAD.L	D4,(A6)+OADATA	PUSH.L	D3	CALL	FETETEXT	; A3 <-- ^nom de la fte	POPM.L	D3	JUMP',NE 40$	PUSHM.L	D2..D4,A3	LOAD.L	A3,#(A6)+OBUDIS+LBUDIS-4	LOAD.B	(A3),#ICOT3	; flche grise	CLR.B	(A3)+1	ADD.W	D3,#2	LOAD.W	D4,#LGXTIME-2	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFTEXT		; affiche la flche	POPM.L	D2..D4,A3	PUSHM.L	D2..D4	LOAD.W	D4,D5	ADD.W	D3,#LGXTIME	SUB.W	D4,#LGXTIME	LOAD.W	D2,#2^BAFFLEFT!2^BAFFRECT!2^BAFFFGRF	CALL	AFFTEXT		; affiche la fte	POPM.L	D2..D4	JUMP	60$40$:	PUSH.L	D3	CLR.L	D4	LOAD.W	D4,D5	ADD.W	D3,#LGXTIME	SUB.W	D4,#LGXTIME	LIB	?DRSEG		; trace une ligne pointille horizontale	POP.L	D342$:	COMP.L	D0,#-1		; encore un rendez-vous ?	JUMP',EQ 60$		; non => 60$	COMP.B	D0,#HIMAY	JUMP',EQ 44$	COMP.B	D0,#HIMAW	JUMP',EQ 44$	COMP.B	D0,#HIMAD	JUMP',NE 45$44$:	CALL	RDVGET		; D4/A4 <-- date/^rendez-vous	JUMP',NE 50$	LOAD.L	D6,D4	CLR.B	D6	CLR.B	D0	COMP.L	D0,D6		; est-on toujours dans le mme jour ?	JUMP',NE 50$		; non => 50$	LOAD.L	D0,D4	CALL	RDVNEXT		; passe au rendez-vous suivant	JUMP	42$45$:	LOAD.W	D4,D5	PUSH.W	D2	CLR.W	D2		; D2 <-- pas de flche	CALL	AFFRDV		; affiche le rendez-vous	POP.W	D2	CALL	RDVGET		; D4/A4 <-- date/^rendez-vous	JUMP',NE 50$	LOAD.L	D6,D4	CLR.B	D6	CLR.B	D0	COMP.L	D0,D6		; est-on toujours dans le mme jour ?	JUMP',NE 50$		; non => 50$	LOAD.L	D0,D4	CALL	RDVNEXT		; passe au rendez-vous suivant	JUMP'	60$50$:	LOAD.L	D0,#-160$:	DECJ.W,NMO D1,30$	COMP.L	D0,#-1		; encore un rendez-vous ?	JUMP',EQ EXIT$		; non => EXIT$				; oui =>	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3),#ICOOVER	CLR.B	(A3)+1	LOAD.W	D4,D5	ADD.W	D3,#4	SWAP.W	D3	ADD.W	D3,(A6)+OMCY	SWAP.W	D3	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFTEXT		; affiche la flche de dbordementEXIT$:	POPM.L	D0..D6,A3,A4	RET;--------\\; AFFYEAR >;========/; Affiche tous les jours pour une demi-anne.; in	-; out	-; mod	D7.WAFFYEAR:	PUSHM.L	D2..D4,A3	CALL	LOCK		; dbut de zone critique	LIB	?COLORPUSH	LOAD.L	D3,#COLORCONTENU	LIB	?COLORSR	LOAD.L	D4,(A6)+ODATE	; D4 <-- date initiale	COMP.W	(A6)+OOPER,#OPAFF	JUMP,NE 20$	CALL	AFFCLRDATA	; efface le data prcdent	LOAD.B	D3,#MODCAR	LIB	?AFCAR	LOAD.B	D2,#SETDOT!PENDOT	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	LOAD.B	D3,D2	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC,GCT3F,GCT3S,GCT3T,0	.EVEN	PUSH.L	D4	LOAD.L	A3,#(A6)+OBUDIS	CALL	DATEYEAR	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	D3,#H'10000*40+24	LOAD.W	D4,#272	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFTEXT		; affiche l'anne	POP.L	D4	LIB	?AFTIM	.B	USEGC,GCT1F,GCT1S,GCT1T,0	.EVEN20$:	LIB	?BUCAR	LOAD.L	D3,#H'10000*(68)+110	CALL	AFFYJDLS	LOAD.L	D3,#H'10000*(88+85*0)+110	LOAD.W	D2,#2^BAFFRIGHT	CALL	AFFYLINE	CALL	AFFYMONTH	CALL	DATENEXTMONTH	; D4 <-- mois suivant	LOAD.L	D3,#H'10000*(88+85*1)+110	LOAD.W	D2,#2^BAFFRIGHT	CALL	AFFYLINE	CALL	AFFYMONTH	CALL	DATENEXTMONTH	; D4 <-- mois suivant	LOAD.L	D3,#H'10000*(88+85*2)+110	LOAD.W	D2,#2^BAFFRIGHT	CALL	AFFYLINE	CALL	AFFYMONTH	CALL	DATENEXTMONTH	; D4 <-- mois suivant	LOAD.L	D3,#H'10000*(68)+320+34	CALL	AFFYJDLS	LOAD.L	D3,#H'10000*(88+85*0)+320+34	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFYLINE	CALL	AFFYMONTH	CALL	DATENEXTMONTH	; D4 <-- mois suivant	LOAD.L	D3,#H'10000*(88+85*1)+320+34	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFYLINE	CALL	AFFYMONTH	CALL	DATENEXTMONTH	; D4 <-- mois suivant	LOAD.L	D3,#H'10000*(88+85*2)+320+34	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFYLINE	CALL	AFFYMONTH;	CALL	DATENEXTMONTH	; D4 <-- mois suivant	LIB	?NOBUCAR	COMP.W	(A6)+OOPER,#OPAFF	JUMP',NE EXIT$	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	MODCAR,SETDOT	.B	0	.EVEN	CALL	IMADESSIN	; affiche l'image de dessinEXIT$:	LIB	?COLORPOP	CALL	UNLOCK		; fin de zone critique	POPM.L	D2..D4,A3	RET;----------\\; AFFYMONTH >;----------/; Affiche tous les jours d'un mois.; in	D3.L	coordonne initiale;	D4.L	date initiale (BCD);	D2.W	mode pour afficher le mois; out	-; mod	D7.WAFFYMONTH:	PUSHM.L	D0..D5,A3	COMP.W	(A6)+OOPER,#OPAFF	JUMP',NE 15$	PUSHM.L	D3,D4	LOAD.L	A3,#(A6)+OBUDIS	CALL	DATEMONTH	LOAD.L	A3,#(A6)+OBUDIS	SWAP.W	D3	ADD.W	D3,#5	SWAP.W	D3	LOAD.W	D4,#100		; D4 <-- largeur	SUB.W	D3,D4		; D3 <-- position	SUB.W	D3,#8	TEST.L	D2:#BAFFLEFT	JUMP',BC 10$	ADD.W	D3,D4	ADD.W	D3,#8	LOAD.W	D4,(A6)+OMCX	MUL.WU	D4,#7	ADD.W	D3,D4	ADD.W	D3,#1010$:	TSET.L	D2:#BAFFBOLD	CALL	AFFTEXT		; affiche le mois	POPM.L	D3,D415$:	LOAD.L	(A6)+OADATA,D4	; OADATA <-- date pour dtection	LOAD.L	D2,D3	LOAD.L	D5,D4	CALL	CALCJX		; D3 <-- nb de jours (28..31)	JUMP,NE EXIT$	LOAD.B	D0,D3		; D0 <-- nb de jours (28..31)	LOAD.L	D4,D5	CALL	CALCNJ		; D4 <-- nb de jours	CALL	CALCJS		; D4 <-- jour semaine (1..7)	LOAD.W	D1,D4		; D1 <-- jour semaine (1..7)	LOAD.L	D3,D2		; D3 <-- coordonne initiale	DEC.W	D4	MUL.WU	D4,(A6)+OMCX	ADD.W	D3,D4	COMP.W	(A6)+OOPER,#OPAFF	JUMP',NE 18$	LOAD.L	D4,(A6)+OADATA	CALL	RDVFINC		; initialise pour recherche incrmentale18$:	LOAD.W	D4,#120$:	CALL	AFFYDAY		; affiche un jour	ADD.W	D3,(A6)+OMCX	; D3 <-- plus loin ( droite)	PUSH.L	D4	LOAD.L	D4,(A6)+OADATA	CALL	DATEQNEXTDAY	; D4 <-- jour suivant (dans le mme mois)	LOAD.L	(A6)+OADATA,D4	; OADATA <-- date pour dtection	POP.L	D4	INC.W	D1		; D1 <-- jour suivant	COMP.W	D1,#7	JUMP',LS 30$	LOAD.W	D1,#1		; D1 <-- lundi	LOAD.W	D3,D2		; D3 <-- revient  gauche	SWAP.W	D3	ADD.W	D3,(A6)+OMCY	; D3 <-- plus loin (en bas)	SWAP.W	D330$:	INC.W	D4		; D4 <-- jour suivant	DEC.B	D0	JUMP,NE 20$EXIT$:	POPM.L	D0..D5,A3	RET;--------\\; AFFYDAY >;--------/; Affiche un jour.; in	D3.L	position (y;x);	D4.W	numro (1..31);	D1.W	jour semaine (1..7); out	-; mod	D7.WAFFYDAY:	PUSHM.L	D0..D4,A3,A4	LIB	?COLORPUSH	LOAD.L	D0,D3	LOAD.L	A3,#(A6)+OBUDIS	CLR.B	(A3)	COMP.W	(A6)+OOPER,#OPAFF	JUMP',NE 34$	LOAD.L	A4,A3	AND.L	D4,#H'FFFF	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDCM	LIB	?PUTDEC	CLR.B	(A4)	LOAD.W	D2,#2^BAFFRIGHT	; D2 <-- cal  droite	COMP.W	D1,#6		; samedi ?	JUMP',NE 30$	TSET.L	D2:#BAFFFGRS30$:	COMP.W	D1,#7		; dimanche ?	JUMP',NE 32$	TSET.L	D2:#BAFFFGRD32$:	LOAD.L	D4,(A6)+OADATA	CALL	RDVNINC		; rendez-vous existe ?	JUMP',NE 34$		; non => 34$	TSET.L	D2:#BAFFBOLD	TSET.L	D2:#BAFFRECT	TCLR.L	D2:#BAFFFGRS	TCLR.L	D2:#BAFFFGRD	LOAD.L	D3,#COLORRDV	LIB	?COLORSR34$:	LOAD.L	D3,D0		; D3 <-- position	LOAD.W	D4,(A6)+OMCX	; D4 <-- largeur	ADD.W	D3,#4	SUB.W	D4,#4+4	CALL	AFFHERE		; D2 <-- inverse si "ici"	CALL	AFFTEXT		; affiche le jour	LIB	?COLORPOP	POPM.L	D0..D4,A3,A4	RET;---------\\; AFFYJDLS >;---------/; Affiche les jours de la semaine.; in	D3.L	position (y;x); out	-; mod	D7.WAFFYJDLS:	PUSHM.L	D2..D4,A3	COMP.W	(A6)+OOPER,#OPAFF	JUMP',NE EXIT$	ADD.W	D3,#2	LOAD.W	D4,(A6)+OMCX	; D4 <-- largeur	LOAD.W	D2,#2^BAFFCENTER	LOAD.L	A3,#R16"LUN$	CALL	AFFTEXT	ADD.W	D3,D4	LOAD.L	A3,#R16"MAR$	CALL	AFFTEXT	ADD.W	D3,D4	LOAD.L	A3,#R16"MER$	CALL	AFFTEXT	ADD.W	D3,D4	LOAD.L	A3,#R16"JEU$	CALL	AFFTEXT	ADD.W	D3,D4	LOAD.L	A3,#R16"VEN$	CALL	AFFTEXT	ADD.W	D3,D4	LOAD.L	A3,#R16"SAM$	CALL	AFFTEXT	ADD.W	D3,D4	LOAD.L	A3,#R16"DIM$	CALL	AFFTEXT;	ADD.W	D3,D4EXIT$:	POPM.L	D2..D4,A3	RETLUN$:	.ASCIZ	"L"MAR$:	.ASCIZ	"M"MER$:	.ASCIZ	"M"JEU$:	.ASCIZ	"J"VEN$:	.ASCIZ	"V"SAM$:	.ASCIZ	"S"DIM$:	.ASCIZ	"D"	.EVEN;---------\\; AFFYLINE >;---------/; Affiche une ligne horizontale en dessus d'un mois.; in	D3.L	position (y;x); out	-; mod	D7.WAFFYLINE:	PUSHM.L	D2..D4	COMP.W	(A6)+OOPER,#OPAFF	JUMP',NE EXIT$	ADD.W	D3,#4	SWAP.W	D3	SUB.W	D3,#16	SWAP.W	D3	LOAD.W	D4,(A6)+OMCX	MUL.WU	D4,#7	SUB.W	D4,#4	LOAD.W	D2,#SETDOT	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	ADD.L	D3,#H'10000*1	LIB	?DRSEGEXIT$:	POPM.L	D2..D4	RET;--------\\; AFFRDV  >;========/; Affiche un rendez-vous.; in	A4.L	^rendez-vous;	D2.W	0 => pas de flche;	D3.L	position (y;x);	D4.W	largeur (dx);	D0.L	date; out	-; mod	D7.WAFFRDV:	PUSHM.L	D2..D4,A3	PUSH.W	D2	PUSH.W	D4	LOAD.L	D4,D0	AND.L	D4,#H'00FF	; D4 <-- temps (unit = 10 minutes)	DIV.WU	D4,#6		; D4 <-- temps (unit = 1 heure)	SWAP.W	D4	LOAD.W	D4,(A4)+ORMMIN	; D4 <-- minutes relles	SWAP.W	D4	LOAD.L	A3,#(A6)+OBUDIS	CALL	DATEHTIME	POP.W	D4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D2,#2^BAFFLEFT	CALL	AFFTEXT		; affiche l'heure	POP.W	D2	LIB	?FLUSH		;  cause du changement de gencar !	LOAD.L	A3,#(A4)+ORMTXT	; A3 <-- ^texte du rendez-vous	TEST.W	D2	JUMP',EQ 30$	DEC.L	A3		; A3 <-- place pour flche	LOAD.B	D2,#ICOEX	TEST.B	(A4)+ORMFAN+3:#BRDVEX-0	JUMP',BS 20$	LOAD.B	D2,#ICOT1	TEST.B	(A4)+ORMFAN+3:#BRDVT1-0	JUMP',BS 20$	INC.B	D2	TEST.B	(A4)+ORMFAN+3:#BRDVT2-0	JUMP',BS 20$	INC.B	D2	TEST.B	(A4)+ORMFAN+3:#BRDVT3-0	JUMP',BS 20$	INC.B	D220$:	LOAD.B	(A3),D2		; texte <-- flche au dbut !30$:	ADD.W	D3,#LGXTIME	SUB.W	D4,#LGXTIME	LOAD.W	D2,#2^BAFFLEFT	TEST.B	(A4)+ORMFAN+3:#BRDVT4-0	JUMP',BC 50$	TSET.L	D2:#BAFFBOLD50$:	LIB	?COLORPUSH	PUSH.L	D3	LOAD.L	D3,#COLORRDV	LIB	?COLORSR	POP.L	D3	CALL	AFFTEXT		; affiche le rendez-vous	LIB	?COLORPOP	POPM.L	D2..D4,A3	RET;--------\\; AFFHERE >;========/; Si on affiche le jour courant, met le mode inverse.; in	D2.W	mode (BAFFxxxx); out	D2.W	mode (BAFFxxxx); mod	D2.LAFFHERE:	PUSHM.L	D3,D4	LOAD.L	D3,(A6)+OHERE	CLR.B	D3		; D3 <-- igonre l'heure	LOAD.L	D4,(A6)+OADATA	CLR.B	D4		; D4 <-- ignore l'heure	COMP.L	D3,D4	JUMP',NE EXIT$	TCLR.L	D2:#BAFFFGRS	TCLR.L	D2:#BAFFFGRD	TCLR.L	D2:#BAFFFGRF	TSET.L	D2:#BAFFINVEXIT$:	POPM.L	D3,D4	RET;--------\\; AFFTEXT >;========/; Affiche un texte.; in	A3.L	^texte <0>;	D2.W	mode (BAFFxxxx);	D3.L	position (y;x);	D4.W	largeur (dx); out	-; mod	D7.WAFFTEXT:	PUSHM.L	D0..D6,A1..A5	COMP.W	(A6)+OOPER,#OPAFF	JUMP,NE DETECT$	LOAD.L	A1,(A0)+ODFPGC	; A1 <-- ^dbut gencar	LOAD.L	A5,A1		; A5 <-- ^gencar le plus haut	LOAD.L	A4,A3		; A4 <-- ^texte	CLR.W	D0		; D0 <-- largeur du texte	CLR.W	D6		; D6 <-- nb de caractresCLOOP$:	CLR.W	D1	LOAD.B	D1,(A4+)	; D1 <-- caractre	JUMP,EQ CEND$	COMP.B	D1,#USEGC	JUMP',EQ CGENC$	SUB.B	D1,(A1)+OGCFCA	LOAD.L	A2,#(A1)+OGCWID	LOAD.B	D1,(A2)+(D1.W)	; D1 <-- largeur	ADD.W	D0,D1		; D0 <-- largeur totale	INC.W	D6		; D6 <-- un caractre de plus	COMP.W	D0,D4		; dpasse la largeur  disposition ?	JUMP,LS CLOOP$		; non => CLOOP$				; oui =>	SUB.W	D0,D1		; D0 <-- largeur	DEC.W	D6		; D6 <-- un caractre de moins	JUMP'	CEND$CGENC$:	ADD.W	D6,#4		; D6 <-- quatre caractres de plus	LOAD.W	D1,(A1)+OGCMHD	; D1 <-- hauteur du gencar	CALL	AFFTEXTGC	; A1 <-- ^nouveau gencar	ADD.L	A4,#3		; A4 <-- saute <f><s><t>	COMP.W	D1,(A1)+OGCMHD	; nouveau gencar plus haut ?	JUMP,HS CLOOP$		; non => CLOOP$	LOAD.L	A5,A1		; A5 <-- ^gencar le plus haut	JUMP	CLOOP$CEND$:	LOAD.W	D1,D4		; D1 <-- largeur (dx)	LOAD.L	D5,D3		; D5 <-- position (y;x)	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ AFF$		; non => AFF$	CALL	AFFTEXTTRAME	; dessine une trame	CALL	AFFTEXTRECT	; dessine un rectangleAFF$:	TEST.W	D6	JUMP,EQ END$	SUB.W	D4,D0		; D4 <-- largeur restante	JUMP,LO END$	TEST.L	D2:#BAFFLEFT	JUMP',BS POSX$	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- au centre	TEST.L	D2:#BAFFCENTER	JUMP',BS POSX$	ADD.W	D3,D4		; D3 <--  droitePOSX$:	LIB	?SETCURS	PUSH.W	D3	LOAD.B	D3,#AFTOUT	LIB	?AFCAR	LOAD.W	D3,D6		; D3 <-- nb de caractres	LIB	?STRING		; affiche normalement	LOAD.B	D3,#AFNORM	LIB	?AFCAR	POP.W	D3	TEST.L	D2:#BAFFBOLD	JUMP',BC END$	INC.W	D3	LIB	?SETCURS	LOAD.B	D3,#AFTOUT	LIB	?AFCAR	LOAD.W	D3,D6		; D3 <-- nb de caractres	LIB	?STRING		; affiche en gras (2x)	LOAD.B	D3,#AFNORM	LIB	?AFCAREND$:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE EXIT$		; oui => EXIT$	CALL	AFFTEXTTRAME	; dessine une trame	CALL	AFFTEXTRECT	; dessine un rectangle	JUMP'	EXIT$DETECT$:			; dtection =>	LOAD.L	D2,(A6)+OAPOS	SUB.W	D2,D3		; trop  gauche ?	JUMP',LO EXIT$	COMP.W	D2,D4		; trop  droite ?	JUMP',HS EXIT$	SWAP.W	D2	SWAP.W	D3	SUB.W	D3,(A6)+OMCY	ADD.W	D3,#2	COMP.W	D2,D3		; trop en haut ?	JUMP',LO EXIT$	ADD.W	D3,(A6)+OMCY	ADD.W	D3,(A6)+OALGY	COMP.W	D2,D3		; trop en bas ?	JUMP',HS EXIT$	LOAD.L	(A6)+OADET,(A6)+OADATAEXIT$:	POPM.L	D0..D6,A1..A5	RET;-------------\\; AFFTEXTTRAME >;-------------/; Affiche une trame autour d'un texte.; in	D5.L	position (y;x);	D1.W	largeur;	D2.W	mode (BAFFxxxx);	A5.L	^gencar; out	-; mod	D7.WAFFTEXTTRAME:	PUSHM.L	D0..D4	LOAD.W	D0,#INVDOT	LOAD.L	D3,#COLOR_PPHILI	LOAD.L	D4,#-1	TEST.L	D2:#BAFFINV	JUMP',BS DRAW$	LOAD.W	D0,#SETDOT	LOAD.L	D3,#COLORDIMANCHE	LOAD.L	D4,#H'AA55AA55	TEST.L	D2:#BAFFFGRD	JUMP',BS DRAW$	LOAD.L	D3,#COLORSAMEDI	LOAD.L	D4,#H'11441144	TEST.L	D2:#BAFFFGRS	JUMP',BS DRAW$	LOAD.L	D3,#COLORFETE;	LOAD.L	D4,#H'11441144	TEST.L	D2:#BAFFFGRF	JUMP',BC EXIT$DRAW$:	LIB	?COLORPUSH	LIB	?COLORSR	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	LOAD.W	D0,#SETDOT	LOAD.L	D4,#-1NOCOUL$:	LOAD.L	D3,D4	LOAD.W	D2,D0	CALL	AFFINVTRAME	; D2/D3D4 <-- inverse v. mode/trame	LIB	?DRMDEF	LOAD.L	D3,D5	SWAP.W	D3	LOAD.W	D4,(A5)+OGCMHD	SUB.W	D4,(A5)+OGCBLI	; D4 <-- hauteur dessus ligne de base	SUB.W	D3,D4	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	LOAD.W	D4,D1	SUB.W	D3,#4	ADD.W	D4,#4+4	LIB	?DRTRAME	LIB	?COLORPOPEXIT$:	POPM.L	D0..D4	RET;------------\\; AFFTEXTRECT >;------------/; Affiche un rectangle autour d'un texte.; in	D5.L	position (y;x);	D1.W	largeur;	D2.W	mode (BAFFxxxx);	A5.L	^gencar; out	-; mod	D7.WAFFTEXTRECT:	PUSHM.L	D2..D4	TEST.L	D2:#BAFFRECT	JUMP',BC EXIT$	LOAD.W	D2,#SETDOT	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	LOAD.L	D3,D5	SWAP.W	D3	LOAD.W	D4,(A5)+OGCMHD	SUB.W	D4,(A5)+OGCBLI	; D4 <-- hauteur dessus ligne de base	SUB.W	D3,D4	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	LOAD.W	D4,D1	SUB.W	D3,#4	ADD.W	D4,#4+4	LIB	?DRRECTEXIT$:	POPM.L	D2..D4	RET;----------\\; AFFTEXTGC >;----------/; Cherche le gencar correspondant.; in	A4.L	^<f><s><t>; out	A1.L	^gencar; mod	A1.LAFFTEXTGC:	LOAD.L	A1,(A6)+OPGC0	COMP.B	(A4)+2,#GCT0T	JUMP',EQ EXIT$	LOAD.L	A1,(A6)+OPGC1	COMP.B	(A4)+2,#GCT1T	JUMP',EQ EXIT$	LOAD.L	A1,(A6)+OPGC2	COMP.B	(A4)+2,#GCT2T	JUMP',EQ EXIT$	LOAD.L	A1,(A6)+OPGC3	COMP.B	(A4)+2,#GCT3T	JUMP',EQ EXIT$	LOAD.L	A1,(A6)+OPGC4	COMP.B	(A4)+2,#GCT4T	JUMP',EQ EXIT$	LOAD.L	A1,(A6)+OPGCXEXIT$:	RET;--------\\; AFFNEXT >;========/; Tourne la page en avant.; in	-; out	-; mod	D7.WAFFNEXT:	PUSHM.L	D0..D4,A4	TEST.B	(A6)+OINFO+3:#BINFQPA-0	JUMP,BS EXIT$	LOAD.W	D2,#LOADDOT	LOAD.L	D3,#H'11004400	LOAD.L	D4,D3	CALL	AFFINVTRAME	; D2/D3D4 <-- inverse v. mode/trame	LIB	?DRMDEF	LOAD.W	D1,D2	LOAD.W	D2,#SETDOT	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	LOAD.W	D0,D2	LOAD.L	A4,#R16"TAFNEXT20$:	SUB.L	A4,#8	TEST.W	(A4)+6	JUMP',EQ EXIT$	LOAD.L	D3,(A4)+0	LOAD.L	D4,(A4)+4	LOAD.W	D2,D1	LIB	?DRTRAME	DEC.W	D3	CLR.W	D4	LOAD.W	D2,D0	LIB	?DRSEG;;?	LOAD.W	D4,#1;;?	NTREL	?DELMS	JUMP	20$EXIT$:	POPM.L	D0..D4,A4	RET;--------\\; AFFPREV >;========/; Tourne la page en arrire.; in	-; out	-; mod	D7.WAFFPREV:	PUSHM.L	D0..D4,A4	TEST.B	(A6)+OINFO+3:#BINFQPA-0	JUMP,BS EXIT$	LOAD.W	D2,#LOADDOT	LOAD.L	D3,#H'11004400	LOAD.L	D4,D3	CALL	AFFINVTRAME	; D2/D3D4 <-- inverse v. mode/trame	LIB	?DRMDEF	LOAD.W	D1,D2	LOAD.W	D2,#SETDOT	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	LOAD.W	D0,D2	LOAD.L	A4,#R16"TAFPREV-820$:	ADD.L	A4,#8	TEST.W	(A4)	JUMP',EQ EXIT$	LOAD.L	D3,(A4)+0	LOAD.L	D4,(A4)+4	LOAD.W	D2,D1	LIB	?DRTRAME	ADD.W	D3,D4	CLR.W	D4	LOAD.W	D2,D0	LIB	?DRSEG;;?	LOAD.W	D4,#1;;?	NTREL	?DELMS	JUMP	20$EXIT$:	POPM.L	D0..D4,A4	RET	.W	0TAFPREV:	.W	16,21+(15*0),282,15	.W	16,21+(15*1),282,15	.W	16,21+(15*2),312,15	.W	16,21+(15*3),312,15	.W	16,21+(15*4),312,15	.W	16,21+(15*5),312,15	.W	16,21+(15*6),312,15	.W	16,21+(15*7),312,15	.W	16,21+(15*8),312,15	.W	16,21+(15*9),312,15	.W	16,21+(15*10),312,15	.W	16,21+(15*11),312,15	.W	16,21+(15*12),312,15	.W	16,21+(15*13),312,15	.W	16,21+(15*14),312,15	.W	16,21+(15*15),312,15	.W	16,21+(15*16),312,15	.W	16,21+(15*17),312,15	.W	16,21+(15*18),312,13	.W	16,332+(15*0),312,15	.W	16,332+(15*1),312,15	.W	16,332+(15*2),312,15	.W	16,332+(15*3),312,15	.W	16,332+(15*4),312,15	.W	16,332+(15*5),312,15	.W	16,332+(15*6),312,15	.W	16,332+(15*7),312,15	.W	16,332+(15*8),312,15	.W	16,332+(15*9),312,15	.W	16,332+(15*10),312,15	.W	16,332+(15*11),312,15	.W	16,332+(15*12),312,15	.W	16,332+(15*13),312,15	.W	16,332+(15*14),312,15	.W	16,332+(15*15),312,15	.W	16,332+(15*16),312,15	.W	16,332+(15*17),282,15	.W	16,332+(15*18),282,13TAFNEXT:	.W	0;-----------\\; AFFCLRDATA >;===========/; Efface le data prcdent dans la page.; in	-; out	-; mod	D7.WAFFCLRDATA:	PUSHM.L	D2..D4,A4	COMP.W	(A6)+OOPER,#OPAFF	JUMP,NE EXIT$	LIB	?COLORPUSH	LOAD.L	D3,#COLORFLIVRE	LIB	?COLORCR	LOAD.L	D3,#COLORCLIVRE	LIB	?COLORSR	LOAD.L	A4,(A6)+OPIMF	; A4 <-- ^image	LOAD.W	D2,#LOADDOT!2^BDSTCOUL	CALL	IMADRAW		; affiche l'image de fond	LOAD.W	D2,#SETDOT	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	LOAD.L	D4,#272	LOAD.L	D3,#H'10000*50+24	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	ADD.L	D3,#H'10000*1	LIB	?DRSEG	LOAD.L	D3,#H'10000*50+342	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	ADD.L	D3,#H'10000*1	LIB	?DRSEG	LIB	?COLORPOP	CALL	AFFDRAWICONE	; remet les icnesEXIT$:	POPM.L	D2..D4,A4	RET;------------\\; AFFINVTRAME >;------------/; Si l'cran n'a pas un fond blanc, inverse la trame.; in	D2.W	mode;	D3D4	trame; out	D2.W	mode (v. invers);	D3D4	trame (v. inverse); mod	D2.W, D3.L, D4.LAFFINVTRAME:	CALL	AFFINVMODE	; D2 <-- inverse v. le mode	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE EXIT$		; oui => EXIT$	TEST.B	(A6)+OINFO+3:#BINFINV-0 ; affichage invers ?	JUMP',BC EXIT$		; non => EXIT$	COMP.B	D2,#INVDOT	JUMP',EQ EXIT$	NOT.L	D3	NOT.L	D4EXIT$:	RET;-----------\\; AFFINVMODE >;-----------/; Si l'cran n'a pas un fond blanc, inverse le mode.; in	D2.W	mode; out	D2.W	mode (v. inverse); mod	D2.WAFFINVMODE:	PUSHM.L	D0,D1	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE EXIT$		; oui => EXIT$	TEST.B	(A6)+OINFO+3:#BINFINV-0 ; affichage invers ?	JUMP',BC EXIT$		; non => EXIT$	LOAD.B	D1,D2	AND.B	D1,#B'11	LOAD.B	D0,#CLRDOT	COMP.B	D1,#SETDOT	JUMP',EQ 50$	LOAD.B	D0,#SETDOT	COMP.B	D1,#CLRDOT	JUMP',NE EXIT$50$:	AND.B	D2,#B'11111100	OR.B	D2,D0EXIT$:	POPM.L	D0,D1	RET;---------\\; AFFIFINV >;=========/; Teste si l'cran est invers.; in	-; out	EQ	cran invers; mod	FAFFIFINV:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE EXIT$		; oui => EXIT$	TEST.B	(A6)+OINFO+3:#BINFINV-0 ; affichage invers ?	NOTZEXIT$:	RET	.END