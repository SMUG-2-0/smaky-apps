	.SBTTL	MEMRDV;----------\\; RDVINSERT >;==========/; Insre plusieurs rendez-vous identiques,; selon la rptition choisie.; in	D4.L	anne-mois-jour-heure en BCD;	D3.W	nombre de rptitions; out	D7.W	erreur; mod	D7.WRDVINSERT:	PUSHM.L	D4,A420$:	PUSH.L	D4	CALL	RDVSEARCH	; y a-t-il dj un rendez-vous ici ?	POPM.L	D4	JUMP',EQ 80$		; oui => 80$				; non =>	LOAD.L	A4,#(A6)+ORDV	CALL	RDVCREATE	; cre un rendez-vous	JUMP',NE 90$	TEST.B	(A6)+ORDV+ORMFAN+2:#BRDVRN-8	JUMP',BS 90$	DEC.W	(A6)+ORDV+ORMNBR ; encore un ?	JUMP',NS 90$		; non => 90$	CALL	RDVNEXTREP	; D4 <-- date suivante	JUMP	20$80$:	LOAD.L	(A6)+ODATE,D4	LOAD.L	(A6)+OHERE,D4	; va sur la journe litigieuse	LOAD.W	(A6)+OTYPE,#ICODAY	LOAD.W	D7,#ERMMREX90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; RDVDELETE >;==========/; Dtruit tous les rendez-vous identiques au premier rencontr,; selon la rptition choisie.; in	D4.L	anne-mois-jour-heure en BCD; out	-; mod	D7.WRDVDELETE:	PUSHM.L	D4,A2..A4	CALL	RDVSEARCH	; A4 <-- ^premier rendez-vous	JUMP',NE 90$	LOAD.L	A3,#(A4)+ORMTXT	LOAD.L	A2,#(A6)+OBUDIS20$:	LOAD.B	(A2+),(A3+)	; OBUDIS <-- texte du premier rendez-vous	JUMP,NE  20$30$:	CALL	RDVKILL		; dtruit un rendez-vous	TEST.B	(A6)+ORDV+ORMFAN+2:#BRDVRN-8	JUMP',BS 90$	CALL	RDVNEXTREP	; D4 <-- date suivante	CALL	RDVSEARCH	; A4 <-- ^rendez-vous	JUMP',NE 90$	LOAD.L	A3,#(A4)+ORMTXT	LOAD.L	A2,#(A6)+OBUDIS50$:	TEST.B	(A2)	JUMP',EQ 52$	COMP.B	(A2+),(A3+)	; textes identiques ?	JUMP,EQ 50$	JUMP'	90$		; non => 90$52$:	TEST.B	(A3)	JUMP,EQ 30$		; oui => 30$90$:	POPM.L	D4,A2..A4	RET;-----------\\; RDVNEXTREP >;-----------/; Cherche la date suivante selon les rptitions.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD; mod	D4.L, D7.WRDVNEXTREP:	PUSHM.L	D0..D3	LOAD.B	D0,D4		; D0 <-- heure initiale	LOAD.L	D3,(A6)+ORDV+ORMFAN	LOAD.W	D2,#1-1	TEST.L	D3:#BRDVRJ	JUMP',BS SPEC$	LOAD.W	D2,#7-1	TEST.L	D3:#BRDVRH	JUMP',BS DAY$	TEST.L	D3:#BRDVRM	JUMP',BS MONTH$	TEST.L	D3:#BRDVRA	JUMP',BS YEAR$	JUMP	EXIT$DAY$:	CALL	DATENEXTDAY	; D4 <-- jour suivant	DECJ.W,NMO D2,DAY$	JUMP	EXIT$MONTH$:	CALL	DATENEXTMONTH	; D4 <-- mois suivant	PUSH.L	D4	CALL	CALCNJ		; date plausible ?	POPM.L	D4	JUMP,NE MONTH$		; non => MONTH$	JUMP	EXIT$YEAR$:	LOAD.W	D2,#12-1YEAR2$:	CALL	DATENEXTMONTH	; D4 <-- mois suivant	DECJ.W,NMO D2,YEAR2$	JUMP	EXIT$SPEC$:	CLR.W	D2	SWAP.W	D3	TEST.B	D3	JUMP,EQ DAY$	LOAD.L	D1,D4	CALL	CALCNJ		; D4 <-- nb de jours	CALL	CALCJS		; D4 <-- jour semaine (1..7)	DEC.W	D4		; D4 <-- 0..6SPEC2$:	INC.W	D2	RR.B	D3,#1	JUMP',CS SPEC3$	TCLR.L	D3:#6	JUMP'	SPEC4$SPEC3$:	TSET.L	D3:#6SPEC4$:	TEST.L	D3:D4	JUMP,BC SPEC2$	LOAD.L	D4,D1	DEC.W	D2		; D2 <-- -1  cause NMO	JUMP	DAY$EXIT$:	LOAD.B	D4,D0		; D4 <-- remet l'heure initiale	POPM.L	D0..D3	RET;------------\\; RDVCREATEEV >;============/; Cre ventuellement un rendez-vous reu depuis l'ORGANISEUR.; Cre un nouveau rendez-vous, seulement s'il est diffrent; du rendez-vous existant.; in	D4.L	anne-mois-jour-heure en BCD;	A4.L	^rendez-vous  crer; out	D7.W	erreur; mod	D7.WRDVCREATEEV:	PUSHM.L	A2,A3	PUSHM.L	D4,A4	CALL	RDVSEARCH	; A4 <-- ^rendez-vous	LOAD.L	A3,A4		; A3 <-- ^rendez-vous ancien	POPM.L	D4,A4	TEST.W	D7	JUMP',NE 50$	PUSHM.L	A3,A4	LOAD.L	A3,#(A3)+ORMTXT	LOAD.L	A4,#(A4)+ORMTXT	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; texte semblable ?	POPM.L	A3,A4	JUMP',NS 40$	CLR.W	D7	JUMP'	90$40$:	CALL	RDVKILL		; supprime le rdv existant50$:	CALL	RDVCREATE	; cre le nouveau rdv90$:	POPM.L	A2,A3	TEST.W	D7		; retour EQ/NE	RETTERM$:	.B	0,-1	.EVEN;----------\\; RDVCREATE >;==========/; Cre un nouveau rendez-vous.; in	D4.L	anne-mois-jour-heure en BCD;	A4.L	^rendez-vous  crer; out	D7.W	erreur; mod	D7.WRDVCREATE:	PUSHM.L	D1,D3,D4,A2..A4	LOAD.W	D7,#ERMMRPL	; D7 <-- trop de rendez-vous	COMP.W	(A6)+ORDVNB,#MAXRDV	JUMP,HS 90$	LOAD.L	A3,#(A4)+ORMTXT	CLR.W	D305$:	INC.W	D3		; D3 <-- lg du texte	TEST.B	(A3+)	JUMP,NE 05$	ADD.W	D3,#ORMTXT	LOAD.W	(A4)+ORMLG,D3	PUSHM.L	D4,A4	CLR.L	D4	LOAD.W	D4,(A4)+ORMLG	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour rendez-vous	LOAD.L	A2,A4		; A2 <-- ^mmoire	POPM.L	D4,A4	TEST.W	D7	JUMP,NE 90$	LOAD.L	A3,A2	LOAD.W	D3,(A4)+ORMLG	DEC.W	D3		; D3 <-- -1  cause NMO10$:	LOAD.B	(A3+),(A4+)	; mmoire <-- rendez-vous	DECJ.W,NMO D3,10$	LOAD.L	A3,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D320$:	ADD.L	A3,#8		; A3 <-- ^date/rdv suivant	DEC.W	D3	JUMP',EQ 30$	COMP.L	D4,(A3)	JUMP,HI 20$30$:	LOAD.W	D1,D3	JUMP',EQ 45$	SL.W	D1,#3		; D1 <-- *8	ADD.W	A3,D1	LOAD.L	A4,#(A3)+8	DEC.W	D3		; D3 <-- -1  cause NMO40$:	LOAD.L	(-A4),(-A3)	LOAD.L	(-A4),(-A3)	DECJ.W,NMO D3,40$45$:	LOAD.L	(A3+),D4	; ORDVDP <-- date	LOAD.L	(A3),A2		; ORDVDP <-- ^rdv	INC.W	(A6)+ORDVNB	; un rendez-vous de plus	SET.B	(A6)+ORDVMJ	; mise  jour ncessaire	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDVFINC >;========/; Initialisation pour une recherche incrmentale journalire.; in	D4.L	anne-mois-jour-heure en BCD initial; out	-; mod	D7.WRDVFINC:	PUSHM.L	D3,D4,A3	CLR.B	D4	LOAD.L	A3,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D320$:	ADD.L	A3,#8		; A3 <-- ^date/rdv suivant	DEC.W	D3	JUMP',EQ 80$	COMP.L	D4,(A3)	JUMP,HI 20$80$:	LOAD.L	(A6)+ORDVMP,A3	LOAD.W	(A6)+ORDVMN,D3	POPM.L	D3,D4,A3	RET;--------\\; RDVNINC >;========/; Recherche incrmentalement le rendez-vous du jour suivant.; in	D4.L	anne-mois-jour-heure en BCD cherch; out	D7.W	erreur; mod	D7.WRDVNINC:	PUSHM.L	D2..D4,A3,A4	LOAD.W	D7,#ERMMRPT	; D7 <-- rendez-vous pas trouv	CLR.B	D4	LOAD.L	A3,(A6)+ORDVMP	LOAD.W	D3,(A6)+ORDVMN	JUMP',EQ 90$20$:	LOAD.L	D2,(A3)	CLR.B	D2	COMP.L	D4,D2		; rendez-vous trouv ?	JUMP',NE 90$		; non => 90$	LOAD.L	A4,(A3)+4	; A4 <-- ^rendez-vous	TEST.B	(A4)+ORMFAN+3:#BRDVT1-0	JUMP',BS 40$	TEST.B	(A4)+ORMFAN+3:#BRDVT2-0	JUMP',BS 40$	CLR.W	D7		; D7 <-- ok, trouv40$:	ADD.L	A3,#8	LOAD.L	(A6)+ORDVMP,A3	DEC.W	D3	LOAD.W	(A6)+ORDVMN,D3	JUMP,NE 20$90$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; RDVSEARCH >;==========/; Cherche un rendez-vous.; in	D4.L	anne-mois-jour-heure en BCD;		 si heure = -1 --> cherche n'importe quelle heure; out	D4.L	anne-mois-jour-heure en BCD trouve (-1 si erreur);	A4.L	^rendez-vous trouv;	D7.W	erreur; mod	D4.L, D7.W, A4.LRDVSEARCH:	PUSHM.L	D2,D3,A3	COMP.B	D4,#-1		; cherche n'importe quelle heure ?	JUMP',EQ 50$		; oui => 50$	LOAD.L	A3,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D320$:	ADD.L	A3,#8		; A3 <-- ^date/rdv suivant	DEC.W	D3	JUMP',EQ 85$	COMP.L	D4,(A3)	JUMP,NE 20$	JUMP'	80$50$:	CLR.B	D4	LOAD.L	A3,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D360$:	ADD.L	A3,#8		; A3 <-- ^date/rdv suivant	DEC.W	D3	JUMP',EQ 85$	LOAD.L	D2,(A3)	CLR.B	D2	COMP.L	D4,D2	JUMP,NE 60$80$:	LOAD.L	D4,(A3)		; D4 <-- date exacte	LOAD.L	A4,(A3)+4	; A4 <-- ^rendez-vous	ADD.L	A3,#8	LOAD.L	(A6)+ORDVMP,A3	DEC.W	D3	LOAD.W	(A6)+ORDVMN,D3	CLR.W	D7		; D7 <-- youpie, trouv	JUMP'	90$85$:	LOAD.L	D4,#-1	CLR.W	(A6)+ORDVMN	LOAD.W	D7,#ERMMRPT	; D7 <-- rendez-vous pas trouv90$:	POPM.L	D2,D3,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDVCHAV >;========/; Cherche le prochain rendez-vous en avant.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD trouve;	A4.L	^rendez-vous trouv;	D7.W	erreur; mod	D4.L, D7.W, A4.LRDVCHAV:	PUSHM.L	D0..D3,A3	LOAD.W	D7,#ERMMRPT	; D7 <-- rendez-vous pas trouv	LOAD.B	D0,#HIMAW	LOAD.B	D1,#HIMAD	COMP.W	(A6)+OTYPE,#ICOYEAR	JUMP',EQ 10$	LOAD.B	D0,#HIMAY;	LOAD.B	D1,#HIMAD	COMP.W	(A6)+OTYPE,#ICOWEEK	JUMP',EQ 10$;	LOAD.B	D0,#HIMAY	LOAD.B	D1,#HIMAW10$:	CLR.B	D4	LOAD.L	A3,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D320$:	ADD.L	A3,#8		; A3 <-- ^date/rdv suivant	DEC.W	D3	JUMP',EQ 90$	LOAD.L	D2,(A3)	CLR.B	D2	COMP.L	D4,D2	JUMP,HS 20$	LOAD.L	D2,(A3)	COMP.B	D2,D0	JUMP,EQ 20$	COMP.B	D2,D1	JUMP,EQ 20$	LOAD.L	D4,(A3)		; D4 <-- date exacte	LOAD.L	A4,(A3)+4	; A4 <-- ^rendez-vous	CLR.W	D7		; D7 <-- youpie, trouv90$:	POPM.L	D0..D3,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDVCHAR >;========/; Cherche le prochain rendez-vous en arrire.; in	D4.L	anne-mois-jour-heure en BCD; out	D4.L	anne-mois-jour-heure en BCD trouve;	A4.L	^rendez-vous trouv;	D7.W	erreur; mod	D4.L, D7.W, A4.LRDVCHAR:	PUSHM.L	D0..D3,A3	LOAD.W	D7,#ERMMRPT	; D7 <-- rendez-vous pas trouv	LOAD.B	D0,#HIMAW	LOAD.B	D1,#HIMAD	COMP.W	(A6)+OTYPE,#ICOYEAR	JUMP',EQ 10$	LOAD.B	D0,#HIMAY;	LOAD.B	D1,#HIMAD	COMP.W	(A6)+OTYPE,#ICOWEEK	JUMP',EQ 10$;	LOAD.B	D0,#HIMAY	LOAD.B	D1,#HIMAW10$:	CLR.B	D4	LOAD.L	A3,#(A6)+ORDVDP	LOAD.W	D3,(A6)+ORDVNB	LOAD.W	D2,D3	MUL.WU	D2,#8	ADD.L	A3,D2	INC.W	D320$:	SUB.L	A3,#8		; A3 <-- ^date/rdv prcdent	DEC.W	D3	JUMP',EQ 90$	LOAD.L	D2,(A3)	CLR.B	D2	COMP.L	D4,D2	JUMP,LS 20$	LOAD.L	D2,(A3)	COMP.B	D2,D0	JUMP,EQ 20$	COMP.B	D2,D1	JUMP,EQ 20$	LOAD.L	D4,(A3)		; D4 <-- date exacte	LOAD.L	A4,(A3)+4	; A4 <-- ^rendez-vous	CLR.W	D7		; D7 <-- youpie, trouv90$:	POPM.L	D0..D3,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDVGET  >;========/; Donne le rendez-vous suivant.; in	-; out	D4.L	anne-mois-jour-heure en BCD trouve (-1 si erreur);	A4.L	^rendez-vous suivant;	D7.W	erreur; mod	D4.L, D7.W, A4.LRDVGET:	PUSHM.L	D3,A3	LOAD.W	D7,#ERMMRPT	; D7 <-- rendez-vous pas trouv	LOAD.L	D4,#-1	LOAD.W	D3,(A6)+ORDVMN	JUMP',EQ 90$	LOAD.L	A3,(A6)+ORDVMP	LOAD.L	D4,(A3)		; D4 <-- date	LOAD.L	A4,(A3)+4	; A4 <-- ^rendez-vous	CLR.W	D7		; D7 <-- youpie, trouv90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDVNEXT >;========/; Passe au rendez-vous suivant.; L'erreur ventuelle est rendue lors du RDVGET !; in	-; out	-; mod	D7.WRDVNEXT:	TEST.W	(A6)+ORDVMN	JUMP',EQ 90$	DEC.W	(A6)+ORDVMN	ADD.L	(A6)+ORDVMP,#890$:	RET;--------\\; RDVKILL >;========/; Supprime un rendez-vous.; in	D4.L	anne-mois-jour-heure en BCD; out	D7.W	erreur; mod	D7.WRDVKILL:	PUSHM.L	D1,D3,D4,A3,A4	LOAD.W	D7,#ERMMRPT	; D7 <-- rendez-vous pas trouv	LOAD.L	A3,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D320$:	ADD.L	A3,#8		; A3 <-- ^date/rdv suivant	DEC.W	D3	JUMP',EQ 90$	COMP.L	D4,(A3)	JUMP,NE 20$	LOAD.L	A4,(A3)+4	; A4 <-- ^rendez-vous	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	DEC.W	D3	JUMP',EQ 45$	LOAD.L	A4,#(A3)+8	DEC.W	D3		; D3 <-- -1  cause NMO40$:	LOAD.L	(A3+),(A4+)	LOAD.L	(A3+),(A4+)	DECJ.W,NMO D3,40$45$:	DEC.W	(A6)+ORDVNB	; un rendez-vous de moins	SET.B	(A6)+ORDVMJ	; mise  jour ncessaire	CLR.W	D7		; D7 <-- ok, dtruit90$:	POPM.L	D1,D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; RDVFLUSH >;=========/; Libre tous les rendez-vous.; in	-; out	-; mod	D7.WRDVFLUSH:	PUSHM.L	D1,D3,D4,A3,A4	CALL	LOCK		; dbut de zone critique	LOAD.L	A3,#(A6)+ORDVDP-8	LOAD.W	D3,(A6)+ORDVNB	INC.W	D320$:	ADD.L	A3,#8		; A3 <-- ^date/rdv suivant	DEC.W	D3	JUMP',EQ 80$	LOAD.L	A4,(A3)+4	; A4 <-- ^rendez-vous	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	JUMP	20$80$:	CLR.W	(A6)+ORDVNB	; y'a plus rien !	CALL	UNLOCK		; fin de zone critique	POPM.L	D1,D3,D4,A3,A4	RET	.END