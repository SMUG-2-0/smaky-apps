	.TITLE	INDEX;	--------------------------------------;		(C) 1987 - Daniel Roux;	--------------------------------------	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REV	1,0	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'R,'F,09	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"LBUNAME	=	30LTMIO	=	256*16; Variables; ---------	.LOC	0OBUNAME:.BLKB	LBUNAMEOBUOUT:	.BLKB	LBUNAMEOPDATA:	.BLKB	4OPTEXT:	.BLKB	4*50OCHIO:	.BLKB	2		; canal pour entre/sortieOTMIO:	.BLKB	LTMIO		; buffer tampon/recupOPTIO:	.BLKB	2		; ^relatif dans OTMIOONBIO:	.BLKB	2		; reste dans OTMIOLGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	LOAD.W	D3,#3	LIB	?MOUSE	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^zone des variables <<PERMANANT>>05$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.W	D4	JUMP,NE 05$	LIB	?AFTIM	.B	AUTOCR	.B	CR	.ASCII	"Programme de gnration automatique d'index.<CR>"	.B	CR	.ASCIZ	"Donnez le nom du fichier .DATA : "	.EVEN	LOAD.L	A3,#(A6)+OBUNAME	LOAD.W	D3,#LBUNAME	LIB	?GETLINE	COMP.W	D3,#CR	JUMP,NE FINI	CALL	RDFILE	JUMP,NE ERROR	LOAD.L	(A6)+OPDATA,A4	LIB	?AFTIM	.ASCIZ	"<CR>Donnez le nom du fichier  gnrer : "	.EVEN	LOAD.L	A3,#(A6)+OBUOUT	LOAD.W	D3,#LBUNAME	LIB	?GETLINE	COMP.W	D3,#CR	JUMP,NE FINI	LOAD.L	D3,#DEFATT	LIB	?FCREATE	JUMP,NE ERROR	CALL	WROPEN	LOAD.L	A3,#R16"TXFILES	LOAD.L	A4,(A6)+OPDATA	CALL	SEARCHNAME	; cherche .FILES	JUMP,NE ERROR	COMP.B	(A4),#TAB	JUMP,NE 20$	INC.L	A420$:	LOAD.L	A3,A4		; A3 <-- ^noms de fichiers	LOAD.L	A1,A4	LOAD.L	A2,#(A6)+OPTEXT25$:	LIB	?AFTIM	.ASCIZ	"<CR>Lit le fichier "	.EVEN	LIB	?AFFILE	CALL	RDFILE		; lit un fichier .TEXT	JUMP,NE ERROR	LOAD.L	(A2+),A4	LIB	?SKPNAM	JUMP,EQ 25$	LOAD.L	A3,A130$:	LOAD.B	D3,(A3+)	; A3 <-- ^mot avec () suivant	JUMP,EQ 80$	COMP.B	D3,#CR	JUMP,NE 30$	TEST.B	(A3)	JUMP,EQ 80$	COMP.B	(A3),#CR	JUMP,NE 33$	LIB	?AFCR	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE ERROR	JUMP	30$33$:	LIB	?IFCAR	JUMP,NE 35$	COMP.W	D3,#END	JUMP,EQ FINI35$:	LIB	?AFTIM	.ASCIZ	"<CR>Cherche le mot "	.EVEN	CALL	AFMOT	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE ERROR	LOAD.L	A4,A3	CALL	WRTEXT	JUMP,NE ERROR	LOAD.B	D3,#TAB	CALL	WRONE	JUMP,NE ERROR	LOAD.L	A2,#(A6)+OPTEXT	LOAD.W	D4,#3		; D4 <-- numro de la 1re page	DEC.W	D440$:	TEST.L	(A2)	JUMP,EQ 30$	LOAD.L	A4,(A2+)	LOAD.W	D2,#-150$:	CALL	SEARCHNAME	JUMP,NE 40$	COMP.W	D4,D2		; dj trouv dans cette page ?	JUMP,EQ 50$		; oui => 50$	LOAD.W	D2,D4	PUSHM.L	D2..D4	LIB	?AFSPACE	AND.L	D4,#H'FFFF	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	POPM.L	D2..D4	CALL	WRNUM	JUMP,NE ERROR	LOAD.B	D3,#SPACE	CALL	WRONE	JUMP,NE ERROR	JUMP	50$80$:	JUMP	FINIERROR:	PUSH.W	D7	LIB	?AFTIM	.B	CR,CR,0	.EVEN	LOAD.B	D3,#BIPERR	LIB	?BEEP	POP.W	D7	LIB	?AFERRORFINI:	TEST.W	(A6)+OCHIO	JUMP,EQ 20$	CLR.W	D7	CALL	WRCLOSE20$:	LIB	?AFTIM	.ASCIZ	"<CR>Appuyez sur une touche ... "	.EVEN	LIB	?GETCARERFAT1:	LIB	?CLOLIB	FOS	?STOP;--------\\; AFMOT   >;========/; Affiche un mot.; in	A3.L	^mot; out	-; mod	D7.WAFMOT:	PUSHM.L	D3,A310$:	LOAD.B	D3,(A3+)	JUMP,EQ 90$	COMP.B	D3,#CR	JUMP,EQ 90$	LIB	?AFCAR	JUMP	10$90$:	POPM.L	D3,A3	RET;-----------\\; SEARCHNAME >;===========/; Cherche un nom dans un fichier.; in	A3.L	^nom cherch avec des ();	A4.L	^data;	D4.W	numro page; out	A4.L	^plus loin;	D4.W	numro page suivant;	D7.W	EQ/NE; mod	D4.L, D7.W, A4.LSEARCHNAME:	PUSHM.L	D310$:	CALL	COMPNAME	; nom trouv ?	JUMP,EQ 90$20$:	LOAD.B	D3,(A4+)	JUMP,EQ 80$	COMP.B	D3,#EOP	JUMP,NE 25$	INC.W	D4		; D4 <-- page suivante	JUMP	20$25$:	CALL	IFEDIT	JUMP,EQ 20$30$:	LOAD.B	D3,(A4+)	JUMP,EQ 80$	COMP.B	D3,#EOP	JUMP,NE 35$	INC.W	D4		; D4 <-- page suivante	JUMP	30$35$:	COMP.B	D3,#'.	JUMP,EQ 40$	CALL	IFEDIT	JUMP,NE 30$40$:	DEC.L	A4	JUMP	10$80$:	LOAD.W	D7,#190$:	POPM.L	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; COMPNAME >;---------/; Compare deux chanes de caractres.; in	A3.L	^nom cherch avec des ();	A4.L	^data; out	A4.L	^plus loin;	D7.W	EQ/NE; mod	D7.W, A4.LCOMPNAME:	PUSHM.L	D3,D4,A1..A3	LOAD.L	A1,A410$:	LOAD.B	D3,(A3+)	JUMP,EQ 50$	COMP.B	D3,#CR	JUMP,EQ 50$	COMP.B	D3,#TAB	JUMP,EQ 50$	COMP.B	D3,#'(	JUMP,EQ 30$15$:	LOAD.B	D4,(A4+)	COMP.B	D4,#LF	JUMP,EQ 15$	CALL	COMPCAR	JUMP,EQ 10$	JUMP	80$30$:				; parenthse ouverte =>	LOAD.L	A2,A432$:	LOAD.B	D3,(A3+)	JUMP,EQ 50$	COMP.B	D3,#CR	JUMP,EQ 50$	COMP.B	D3,#TAB	JUMP,EQ 50$	COMP.B	D3,#')	JUMP,EQ 38$35$:	LOAD.B	D4,(A2+)	COMP.B	D4,#LF	JUMP,EQ 35$	CALL	COMPCAR	JUMP,EQ 32$	LOAD.B	D3,#')	CALL	SKIPCAR		; A3 <-- ^aprs ")"	JUMP	10$38$:	LOAD.L	A4,A2	JUMP	10$50$:	LOAD.B	D3,(A4)	CALL	IFEDIT	JUMP,EQ 80$	CLR.W	D7		; D7 <-- EQ	JUMP	90$80$:	LOAD.L	A4,A1		; A4 <-- idem	LOAD.W	D7,#1		; D7 <-- NE90$:	POPM.L	D3,D4,A1..A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; COMPCAR >;--------/; Compare deux caractres.; in	D3.B	caractre;	D4.B	caractre; out	F	EQ/NE; mod	D3.B, D4.B, D7.WCOMPCAR:	COMP.B	D3,#'A	JUMP,LO 50$	COMP.B	D3,#'Z	JUMP,HI 50$	COMP.B	D3,D4	RET50$:	CALL	MINMAJ	EX.L	D3,D4	CALL	MINMAJ	EX.L	D3,D4	COMP.B	D3,D4	RET;--------\\; SKIPCAR >;--------/; Saute jusqu'aprs un caractre donn.; in	D3.B	caractre;	A3.L	^texte; out	A3.L	^plus loin; mod	A3.LSKIPCAR:	PUSHM.L	D3,D4	LOAD.B	D4,D310$:	LOAD.B	D3,(A3)	JUMP,EQ 90$	COMP.B	D3,#CR	JUMP,EQ 90$	INC.L	A3	COMP.B	D3,D4	JUMP,NE 10$90$:	POPM.L	D3,D4	RET;--------\\; RDFILE  >;========/; Lit un fichier ASCII en mmoire, et met un <0> terminateur;  la fin.; in	A3.L	^nom du fichier; out	A4.L	^data;	D7.W	erreur; mod	D7.W, A4.LRDFILE:	PUSHM.L	D1,D3,D4,D6	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE 90$	LOAD.L	D4,#-1	LOAD.B	D3,#-1	FOS	?SPOS		; D4 <-- lg du fichier	PUSH.L	D4	CLR.L	D4	CLR.B	D3	FOS	?SPOS	POPM.L	D4	JUMP,NE 85$	INC.L	D4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE 85$	DEC.L	D4	FOS	?RDBYTE	JUMP,NE 80$	CLR.B	(A4)+(D4.L)	; met <0> terminateur	JUMP	85$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	POP.W	D785$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D1,D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFEDIT  >;========/; Regarde si un caractre est ditable.; in	D3.B	; out	D7.W	EQ/NE; mod	D3.B, D7.WIFEDIT:	CALL	MINMAJ	COMP.B	D3,#'0	JUMP,LO NE$	COMP.B	D3,#'9	JUMP,LS EQ$	COMP.B	D3,#'A	JUMP,LO NE$	COMP.B	D3,#'Z	JUMP,LS EQ$NE$:	LOAD.W	D7,#1	RETEQ$:	CLR.W	D7	RET;--------\\; MINMAJ  >;========/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMINMAJ:	TEST.L	D3:#7		; code "supplmentaire" ?	JUMP',NE 20$		; oui => 20$	COMP.B	D3,#SPACE-2	; lettre accentue ?	JUMP',LO 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+70$  ; D3 <-- lettre majuscule	POP.W	D0	RET70$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN;--------\; WROPEN  >;========/; Ouvre le fichier en sortie.; in	D6.W	canal; out	-; mod	-WROPEN:	LOAD.W	(A6)+OCHIO,D6	; mm. canal	CLR.W	(A6)+OPTIO	; buffer vide	RET;--------\\; WRNUM   >;========/; Ecrit un nombre dcimal dans le fichier en sortie.; in	D4.W	nombre (+/-); out	D7.W	erreur; mod	D7.WWRNUM:	PUSHM.L	D2..D4	TEST.W	D4		; nombre positif ?	JUMP',NC 05$		; oui => 05$	NEG.W	D4		; non =>	LOAD.B	D3,#'-	CALL	WRONE		; met un signe moins	JUMP',NE 90$05$:	AND.L	D4,#H'FFFF	LIB	?BINBCD		; D4 <-- nombre en BCD	LOAD.L	D2,#8-1		; D2 <-- nb max de digits10$:	RL.L	D4,#4	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- digit 0..9	JUMP',NE 20$	TEST.W	D2		; dernier digit ?	JUMP',EQ 20$		; oui => 20$	TEST.L	D2:#16	JUMP',BC 30$20$:	ADD.B	D3,#'0	CALL	WRONE		; crit un digit	JUMP',NE 90$	TSET.L	D2:#1630$:	DECJ.W,NMO D2,10$90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRTEXT  >;========/; Ecrit un texte termin par un zro dans le fichier en sortie.; in	A4.L	^texte<0> ou <CR>; out	D7.W	erreur; mod	D4.L, D7.W, A4.LWRTEXT:	LOAD.L	D4,A410$:	TEST.B	(A4+)	JUMP',EQ 20$	COMP.B	(A4)-1,#CR	JUMP,NE	10$20$:	DEC.L	A4	EX.L	D4,A4		; A4 <-- ^dbut	SUB.L	D4,A4		; D4 <-- longueur;	CALL	WRMANY;	RET;--------\; WRMANY  >;========/; Ecrit plusieurs bytes dans le fichier de sortie.; in	A4.L	^bytes  crire;	D4.L	nombre de bytes  crire; out	D7.W	erreur; mod	D7.WWRMANY:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,A4		; A3 <-- ^bytes  crire	LOAD.W	D3,D4		; D3 <-- nombre10$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OPTIO	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer20$:	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4+),(A3+)	; buffer <-- un byte	INC.W	D4		; D4 <-- un byte de plus	DEC.W	D3	JUMP,NE	20$	LOAD.W	(A6)+OPTIO,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OPTIO	; signal buffer vide	JUMP	10$90$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; WRONE   >;========/; Ecrit un byte dans le fichier de sortie.; in	D3.B	byte  crire; out	D7.W	erreur; mod	D7.WWRONE:	PUSHM.L	D4,D6,A410$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OPTIO	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4),D3		; buffer <-- le byte	INC.W	D4		; D4 <-- un byte de plus	LOAD.W	(A6)+OPTIO,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OPTIO	; signal buffer vide	JUMP	10$90$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; WRCLOSE >;========/; Ecrit le reste du fichier de sortie, puis ferme.; in	D7.W	ok/erreur; out	D7.W	erreur; mod	D7.WWRCLOSE:	PUSHM.L	D4..D6,A4	LOAD.W	D6,(A6)+OCHIO	; D6 <-- canal	LOAD.W	D5,D7		; D5 <-- ok/erreur	JUMP',NE 50$		; erreur => 50$				; ok =>	LOAD.L	A4,#(A6)+OTMIO	; A4 <-- ^buffer tampon	CLR.L	D4	LOAD.W	D4,(A6)+OPTIO	; D4 <-- nb bytes dans buffer	JUMP',EQ 50$		; si vide => 50$				; si reste qq chose =>	FOS	?WRBYTE		; crit tout le buffer	LOAD.W	D5,D750$:	FOS	?CLOSE		; ferme le fichier	COMP.W	D7,D5	JUMP',HS 90$	LOAD.W	D7,D5		; D7 <-- erreur la plus grve !90$:	POPM.L	D4..D6,A4	TEST.W	D7		; retour EQ/NE	RETTXFILES:.ASCIZ	".FILES"	.EVEN	.END	START