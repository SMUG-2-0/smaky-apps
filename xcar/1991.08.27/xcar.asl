	.TITLE	XCAR.ASL	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal; Date		Rev	Amliorations; --------------------------------------------------------------------------------; 03.05.91	1.18	XCAR_CREATE/BMMATRIX: lg containte jamais nulle !; 15.01.91	1.17	XCAR_SHOW/SHOWF: ok si cran couleur (SMAKY300); 25.09.90	1.16	XCAR_BMOPEN: gnre un interligne correct (pour PAGE);			XCAR_BMOPEN: sablier pendant chargement; 04.05.90	1.15	XCAR_CREATE: largeur matrices: tient compte de la chasse; 23.03.90	1.14	XCAR_SHOWF: ok avec trs gros pinceaux;			XCAR_SHOW/SHOWF: clipping si pinceau dborde;			gre oxcPMN/PNG (si gencar trs petit);			XCAR_SHOW: loupe si gencar trs petit;			bzier: routine d'exception si outline et <4x4; 12.03.90	1.13	gre OGCBRI (roman/bold/italic);			xcOPPEN dans les *00.GENC (pinceaux); 27.02.90	1.12	version distribue par erreur, plante sur SMAKY100 !; 13.12.89	1.11	XCAR_FRAGMENT: nouvel appel pour PAGE; 21.11.89	1.10	pour nouveau GRAMISC en A440 !; 10.11.89	1.9	XCAR_BMMATRIX: rend les largeurs correctes; 08.11.89	1.8	utilise TGRAMIS --> GRAMISC; 17.10.89	1.7	XCAR_LIST: nouvel appel de liste; 19.09.89	1.6	XCAR_BMxxx: nouveaux appels pour PAGE; 11.08.89	1.5	utilise GRA2_RLINE si contour; 11.07.89	1.4	XCAR_SHOW: ok si taille > hauteur rectangle; 05.07.89	1.3	ne charge plus l'en-tte avec FOS,?CLOAD;			XCAR_SHOWF: nouvel appel pour LIST_VISU; 15.06.89	1.2	XCAR_SHOW: nouvel appel pour DGENC; 14.06.89	1.1	XCAR_HEADER: ok; 13.04.89	1.0	premiers essais avec STRETCH	.REF	SMAKY	.REF	GRA	.REF	GENCAR	.REF	XCAR	.REF	GRAMISC	.REF	GRA2	.REF	DOLIB;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;XPEN	=	H'D5		; trame quelconqueXTRAME	=	H'D6		; pinceau quelconqueXMAPTT	=	H'D7		; traitill quelconque	.LOC	LGDIS7ODFPPM:	.BLKL	1		; pinceau: ^matriceODFPPO:	.BLKW	2		; pinceau: position (y;x)ODFPDI:	.BLKW	2		; pinceau: dimensions (dy;dx)ODFPII:	.BLKW	1		; pinceau: incrment ligneODFPTO:	.BLKW	1		; pinceau: origine traitillODFPT1:	.BLKW	1		; pinceau: trait 1ODFPT2:	.BLKW	1		; pinceau: trou  1ODFPT3:	.BLKW	1		; pinceau: trait 2ODFPT4:	.BLKW	1		; pinceau: trou  2ODFPT5:	.BLKW	1		; pinceau: trait 3ODFPT6:	.BLKW	1		; pinceau: trou  3ODFPT7:	.BLKW	1		; pinceau: trait 4ODFPT8:	.BLKW	1		; pinceau: trou  4	.BLKB	8		; pinceau: rserveODFTPM:	.BLKL	1		; trame: ^matriceODFTPO:	.BLKW	2		; trame: position (y;x)ODFTDI:	.BLKW	2		; trame: dimensions (dy;dx)ODFTII:	.BLKW	1		; trame: incrment ligneODFTOR:	.BLKW	2		; trame: origine motif	.BLKB	4		; trame: rserve;LGDIS8:;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.REV	1,18	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------CHOUIA05	=	H'8000		; p'tit chouia = 0.5; Dfinition de l'entte d'un gnrateur de caractres; ----------------------------------------------------OGCRBI		=	H'7C		; 4 caractres pour "normal,gras,ital,gras-ital"OGCH1		=	H'180		; h1OGCH2		=	H'200		; h2OGCMAT		=	H'280		; matrix; Variables pour courbe de bezier; -------------------------------;	C1                      C2;	 o----------------------o;	 |                       \;	 |          .     .       \;	 |      .              .   \;	 |   .                     .\;	 | .                         o;	 |.                            P2;	 o  P1	.LOC	0OBZP1Y:	.BLKB	4		; P1[y]OBZP1X:	.BLKB	4		; P1[x]OBZC1Y:	.BLKB	4		; C1[y]OBZC1X:	.BLKB	4		; C1[x]OBZC2Y:	.BLKB	4		; C2[y]OBZC2X:	.BLKB	4		; C2[x]OBZP2Y:	.BLKB	4		; P2[y]OBZP2X:	.BLKB	4		; P2[x]LBZ:; Variables locales de XCAR_CREATE; --------------------------------	.LOC	0OXCF:	.BLKB	1		; fonte	.EVENOXCS:	.BLKB	4		; styleOXCT:	.BLKB	2		; tailleOXCFILN:.BLKB	16		; nom du fichier normalOXCFILJ:.BLKB	16		; nom du fichier si trs petitOXCPI:	.BLKB	4		; ^gencar en entreOXCPJ:	.BLKB	4		; ^gencar en entre si trs petitOXCPO:	.BLKB	4		; ^gencar en sortieOXCPM:	.BLKB	4		; ^descripteur pour transformation mathmatiqueOXCLO:	.BLKB	4		; lg gencar en sortieOXCDF:	.BLKB	LGDIS8+4	; descripteur de fentreOXCPB:	.BLKB	4		; ^bitmap si cran couleurOXCPOS:	.BLKB	4		; position o dessiner (y;x)OXCIRG:	.BLKB	4		; rgion: identificateurOXCBRG:	.BLKB	LGGBMAP		; rgion: descripteur bitmapOXCIX1:	.BLKB	2		; l1 (gauche)	[po]OXCIX2:	.BLKB	2		; l2 (droite)	[po]OXCIXB:	.BLKB	2		; l1+l2		[bytes]OXCIY1:	.BLKB	2		; h1 (haut)	[po]OXCIY2:	.BLKB	2		; h2 (bas)	[po]OXCIYE:	.BLKB	2		; taille du "E"	[pi]OXCIYEJ:.BLKB	2		; taille du "E"	[pi] si trs petitOXCJMY:	.BLKB	2		; trs petit: facteur pour *YOXCJDY:	.BLKB	2		; trs petit: facteur pour /YOXCJMX:	.BLKB	2		; trs petit: facteur pour *XOXCJDX:	.BLKB	2		; trs petit: facteur pour /XOXCMOD:	.BLKB	2		; mode XCMODFILL =	1		;  mode remplissage XCMODOUTL =	2		;  mode outline XCMODFRAG =	3		;  mode fragmenteOPPEN:	.BLKB	4		; ^matrice pinceauOLPEN:	.BLKB	2		; dernier pinceauOUPEN:	.BLKB	2		; pinceau en cours d'utilisationOLPOS:	.BLKB	4		; dernire position [pg]OIPOS:	.BLKB	4		; dernire position [pi]ORPOS:	.BLKB	4OWCAR:	.BLKB	2OAGMNR:	.BLKB	4		; adresse de GMI_NEWRGNOAGMDR:	.BLKB	4		; adresse de GMI_DISPOSERGNOAGMOR:	.BLKB	4		; adresse de GMI_OPENRGNOAGMCR:	.BLKB	4		; adresse de GMI_CLOSERGNOAGMRB:	.BLKB	4		; adresse de GMI_RGNTOBITMAPOAGMPL:	.BLKB	4		; adresse de GMI_PUTRLINEOFRAPV:	.BLKB	4		; fragment: ^variables de l'utilisateurOFRAPR:	.BLKB	4		; fragment: ^routine de l'utilisateurLGVAR:; Contenu de la liste des noms; ----------------------------	.LOC	0OLNNAM:	.BLKB	32		; nomOLNFON:	.BLKB	1		; fonteOLNSTY:	.BLKB	1		; style/chasse	.BLKB	6		; rserveLLN:; Variables globales de XCAR_Lxxx; -------------------------------	.LOC	0OVLCTM:	.BLKB	4		; compte mmoireOVLPLI:	.BLKB	4		; ^listeOVLNLI:	.BLKB	2		; nb de noms contenusOVLBUF:	.BLKB	32		; buffer pour un nomLVL:; En-tte du module LIB; ---------------------	.LOC	0	XCAR_	FIRST		; code du premier appel	XCAR_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	1,18		; rvision.version	.W	0,END_XCAR	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"XCAR"		; nom du module	.FILLB	(LGHLIB-.),0	.W	_XCAR_OPEN	.W	_XCAR_CREATE	.W	_XCAR_HEADER	.W	_XCAR_SHOW	.W	_XCAR_SHOWF	.W	_XCAR_BMOPEN	.W	_XCAR_BMMATRIX	.W	_XCAR_BMCLOSE	.W	_XCAR_LIST	.W	_XCAR_FRAGMENT;-----------\\; _XCAR_OPEN >;===========/; Charge les modules utilise par XCAR.; in	-; out	-; mod	D7.W_XCAR_OPEN:	PUSHM.L	D1,D3,A3	LOAD.L	A3,#R16"NMGMI$	LOAD.W	D3,#GMI_FIRST	LIB_	OPEN	LOAD.L	A3,#R16"NMGRA$	LOAD.W	D3,#GRA2_FIRST	LIB_	OPEN	POPM.L	D1,D3,A3	CLR.W	D7		; retour EQ	RETNMGMI$:	.ASCIZ	"GRAMISC"NMGRA$:	.ASCIZ	"GRA2"	.EVEN;-------------\\; _XCAR_CREATE >;=============/; Cre un gencar "bitmap" complet (128 caractres)  partir d'un gencar analytique.; in	D0.B	fonte;	D1.L	style/chasse;	D2.B	taille; out	A4.L	^gencar (GETMEM sur le compte MTYPCP);	D7.W	erreur; mod	D7.W, A4.L_XCAR_CREATE:	PUSHM.L	D0..D4,A1,A3,A6	LOAD.L	D3,D1	CALL	OPEVAR		; A6 <-- ^variables locales	JUMP,NE 95$	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	#(A6)+OXCIRG	; stack <-- ^VAR identificateur rgion	LOAD.L	A1,(A6)+OAGMNR	CALL	(A1)		; GMI_NEWRGN, cre une nouvelle rgion	POP.W	D7	JUMP,NE 90$	LOAD.L	D1,D3	LOAD.B	(A6)+OXCF,D0	LOAD.L	(A6)+OXCS,D1	LOAD.B	(A6)+OXCT+1,D2	CALL	NAMEGC		; A3 <-- ^nom du fichier	LOAD.L	D3,#2^BEXNHEAD	; D3 <-- ne charge pas l'en-tte	FOS	?CLOAD	JUMP,NE 90$	LOAD.L	(A6)+OXCPI,A4	LOAD.W	D7,#ERDIGC	COMP.W	(A4)+oxcIDENT,#xcIDENT	JUMP,NE 80$	CALL	NAMEGCJ		; A3 <-- ^nom du fichier trs petit	JUMP',NE DIM$	LOAD.L	D3,#2^BEXNHEAD	; D3 <-- ne charge pas l'en-tte	FOS	?CLOAD	JUMP',NE DIM$	LOAD.L	(A6)+OXCPJ,A4DIM$:	LOAD.L	A4,(A6)+OXCPI	CALL	DIMGC		; calcule les dimensions	LOAD.W	D4,(A6)+OXCIY1	ADD.W	D4,(A6)+OXCIY2	MUL.WU	D4,(A6)+OXCIXB	MUL.WU	D4,#128	ADD.L	D4,#OGCMAT	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour gencar en sortie	JUMP',NE 80$	LOAD.L	(A6)+OXCPO,A4	LOAD.L	(A6)+OXCLO,D4	LOAD.L	A3,A4		; A3 <-- ^gencar en sortie	LOAD.L	D3,D4		; D3 <-- gnre tout	LOAD.L	A4,(A6)+OXCPI	; A4 <-- ^gencar en entre	CALL	CONVHEAD	; gnre l'en-tte	CALL	CONVGC		; gnre les matrices	LOAD.L	A4,(A6)+OXCPO	; A4 <-- ^gencar en sortie	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	TEST.L	(A6)+OXCPJ	JUMP',EQ 84$	LOAD.L	A3,#(A6)+OXCFILJ	FOS	?CUNLOAD84$:	LOAD.L	A3,#(A6)+OXCFILN	FOS	?CUNLOAD	POP.W	D790$:	PUSHM.L	D7,A4	TEST.L	(A6)+OXCIRG	JUMP',EQ 92$	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	LOAD.L	A1,(A6)+OAGMDR	CALL	(A1)		; GMI_DISPOSERGN, rend la rgion	POP.W	D792$:	CALL	CLOVAR		; rend les variables	POPM.L	D7,A495$:	POPM.L	D0..D4,A1,A3,A6	TEST.W	D7		; retour EQ/NE	RET;-------------\\; _XCAR_HEADER >;=============/; Cre l'en-tte d'un gencar "bitmap"  partir d'un gencar analytique.; in	D0.B	fonte;	D1.L	style/chasse;	D2.B	taille;	A4.L	^buffer pour recevoir l'en-tte;	D4.W	lg du buffer; out	D7.W	erreur; mod	D7.W_XCAR_HEADER:	PUSHM.L	D0..D5,A3,A4,A6	LOAD.L	A3,A4	CLR.L	D5	LOAD.W	D5,D4	LOAD.L	D3,D1	CALL	OPEVAR		; A6 <-- ^variables locales	JUMP,NE 95$	LOAD.L	D1,D3	LOAD.B	(A6)+OXCF,D0	LOAD.L	(A6)+OXCS,D1	LOAD.B	(A6)+OXCT+1,D2	LOAD.L	(A6)+OXCPO,A3	LOAD.L	(A6)+OXCLO,D5	CALL	NAMEGC		; A3 <-- ^nom du fichier	LOAD.L	D3,#2^BEXNHEAD	; D3 <-- ne charge pas l'en-tte	FOS	?CLOAD	JUMP',NE 90$	LOAD.L	(A6)+OXCPI,A4	LOAD.W	D7,#ERDIGC	COMP.W	(A4)+oxcIDENT,#xcIDENT	JUMP',NE 80$	CALL	DIMGC		; calcule les dimensions	LOAD.L	A3,(A6)+OXCPO	; A3 <-- ^gencar en sortie	LOAD.L	D3,(A6)+OXCLO	; D3 <-- lg  gnrer;	LOAD.L	A4,(A6)+OXCPI	; A4 <-- ^gencar en entre	CALL	CONVHEAD	; gnre l'en-tte	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	LOAD.L	A3,#(A6)+OXCFILN	FOS	?CUNLOAD	POP.W	D790$:	CALL	CLOVAR		; rend les variables95$:	POPM.L	D0..D5,A3,A4,A6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; _XCAR_SHOW >;===========/; Affiche les caractres "Abc" d'un gencar analytique rapidement,; sans construire tous les autres caractres.; in	D0.B	fonte;	D1.L	style/chasse;	D2.B	taille;	D3.L	coin sup/gauche fentre o afficher (y;x);	D4.L	dimensions fentre o afficher (dy;dx);	A0.L	^descripteur fentre; out	D7.W	erreur; mod	D7.W_XCAR_SHOW:	PUSHM.L	D0..D6,A1,A3,A4,A6	LOAD.L	D5,D3		; D5 <-- pos	LOAD.L	D6,D4		; D6 <-- dim	CALL	OPEVAR		; A6 <-- ^variables locales	JUMP,NE 95$	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	#(A6)+OXCIRG	; stack <-- ^VAR identificateur rgion	LOAD.L	A1,(A6)+OAGMNR	CALL	(A1)		; GMI_NEWRGN, cre une nouvelle rgion	POP.W	D7	JUMP,NE 90$	LOAD.B	(A6)+OXCF,D0	LOAD.L	(A6)+OXCS,D1	LOAD.B	(A6)+OXCT+1,D2	CALL	NAMEGC		; A3 <-- ^nom du fichier	LOAD.L	D3,#2^BEXNHEAD	; D3 <-- ne charge pas l'en-tte	FOS	?CLOAD	JUMP,NE 90$	LOAD.L	(A6)+OXCPI,A4	LOAD.W	D7,#ERDIGC	COMP.W	(A4)+oxcIDENT,#xcIDENT	JUMP,NE 80$	CALL	DIMGC		; calcule les dimensions	LOAD.L	D4,#OGCH1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour en-tte + chasse	JUMP,NE 80$	LOAD.L	(A6)+OXCPO,A4	LOAD.L	(A6)+OXCLO,D4	LOAD.L	A3,A4		; A3 <-- ^gencar en sortie	LOAD.L	D3,D4		; D3 <-- gnre tout	LOAD.L	A4,(A6)+OXCPI	; A4 <-- ^gencar en entre	CALL	CONVHEAD	; gnre l'en-tte + chasse	CALL	WDOOPEN		; prpare la sous-fentre	JUMP,NE 70$	LOAD.L	A4,(A6)+OXCPI	; A4 <-- ^gencar en entre	LOAD.L	A4,#(A4)+oxcLENGTH ; A4 <-- ^table de chasse	CLR.W	(A6)+OXCPOS+0	LOAD.L	D4,(A3)+ODFFDY	SWAP.W	D4	SUB.W	D4,(A6)+OXCT	JUMP',NS 36$	SR.W	D4,#1	ADD.W	D4,(A6)+OXCT	SUB.W	D4,(A6)+OXCIY1	; D4 <-- position en Y	LOAD.W	(A6)+OXCPOS+0,D436$:	LOAD.W	D4,(A4)+(2*'A)	ADD.W	D4,(A4)+(2*'b)	ADD.W	D4,(A4)+(2*'c)	CALL	CONVIO		; D4 <-- largeur pour "Abc"	SUB.W	D4,(A3)+ODFFDX	NEG.W	D4	ASR.W	D4,#1	JUMP',NC 40$	CLR.W	D440$:	LOAD.W	(A6)+OXCPOS+2,D4	LOAD.W	D3,#'A	CALL	CONVCARSCR	; affiche "A"	LOAD.W	D4,(A4)+(2*'A)	CALL	CONVIO	ADD.W	(A6)+OXCPOS+2,D4	LOAD.W	D3,#'b	CALL	CONVCARSCR	; affiche "b"	LOAD.W	D4,(A4)+(2*'b)	CALL	CONVIO	ADD.W	(A6)+OXCPOS+2,D4	LOAD.W	D3,#'c	CALL	CONVCARSCR	; affiche "c"	CALL	SHOWLOUPE	; met v. une loupe	CALL	WDOCLOSE	; termine la sous-fentre	CLR.W	D7		; D7 <-- ok70$:	PUSH.W	D7	LOAD.L	A4,(A6)+OXCPO	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend l'en-tte + chasse	POP.W	D780$:	PUSH.W	D7	LOAD.L	A3,#(A6)+OXCFILN	FOS	?CUNLOAD	POP.W	D790$:	PUSH.W	D7	TEST.L	(A6)+OXCIRG	JUMP',EQ 92$	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	LOAD.L	A1,(A6)+OAGMDR	CALL	(A1)		; GMI_DISPOSERGN, rend la rgion	POP.W	D792$:	CALL	CLOVAR		; rend les variables	POP.W	D795$:	POPM.L	D0..D6,A1,A3,A4,A6	TEST.W	D7		; retour EQ/NE	RET;----------\\; SHOWLOUPE >;----------/; Met une loupe dans le coin inf/droite, si le gencar est trs petit.; in	A3.L	^descripteur; out	-; mod	D7.WSHOWLOUPE:	PUSHM.L	D1..D5,A2..A4	LOAD.L	A4,(A6)+OXCPI	; A4 <-- ^gencar en entre	LOAD.W	D4,(A6)+OXCT	; D4 <-- taille demande	COMP.W	D4,(A4)+oxcPMN	; taille trs petite ?	JUMP',HS EXIT$		; non => EXIT$	TEST.B	(A4)+oxcPNG	; nom existe ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A2,A3		; A2 <-- ^descripteur fentre	LOAD.L	A3,#R16"LOUPE$	; A3 <-- ^source	CLR.L	D3		; D3 <-- position dans source	LOAD.W	D5,#2		; D5 <-- Iy source	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.W	D4,(A2)+ODFFDY	SUB.W	D4,#32+2	SWAP.W	D4	LOAD.W	D4,(A2)+ODFFDX	SUB.W	D4,#16+3	; D4 <-- position dans destination	LOAD.L	D2,#H'10000*32+16 ; D2 <-- dimensions	LOAD.W	D1,#LOADDOT	; D1 <-- mode	GRA_	RASTER		; met la loupe dans la fentreEXIT$:	POPM.L	D1..D5,A2..A4	RETLOUPE$:	.W	B'0000011111100000	.W	B'0001100000011000	.W	B'0010001111000100	.W	B'0100110101110010	.W	B'0101101010111010	.W	B'1001010101011001	.W	B'1010100010101101	.W	B'1011010101010101	.W	B'1010101010101101	.W	B'1011010101010101	.W	B'1001101010101001	.W	B'0101110101011010	.W	B'0100111010110010	.W	B'0010001111000100	.W	B'0001100000011000	.W	B'0000011111100000	.W	B'0000000110000000	.W	B'0000000110000000	.W	B'0000001111000000	.W	B'0000010001100000	.W	B'0000010001100000	.W	B'0000010001100000	.W	B'0000010001100000	.W	B'0000010001100000	.W	B'0000010001100000	.W	B'0000010001100000	.W	B'0000010001100000	.W	B'0000010001100000	.W	B'0000010001100000	.W	B'0000010001100000	.W	B'0000010001100000	.W	B'0000001111000000;------------\\; _XCAR_SHOWF >;============/; Affiche les caractres "Abc" d'un gencar analytique rapidement,; sans construire tous les autres caractres.; in	D2.W	taille;	D3.L	coin sup/gauche fentre o afficher (y;x);	D4.L	dimensions fentre o afficher (dy;dx);	A4.L	^contenu du fichier *00.GENC (sans l'en-tte binaire);	A0.L	^descripteur fentre; out	D7.W	erreur; mod	D7.W_XCAR_SHOWF:	PUSHM.L	D0..D6,A1,A3,A4,A6	LOAD.L	D6,D4		; D6 <-- dimensions fentre	LOAD.L	D5,A4	CALL	OPEVAR		; A6 <-- ^variables locales	JUMP,NE 95$	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	#(A6)+OXCIRG	; stack <-- ^VAR identificateur rgion	LOAD.L	A1,(A6)+OAGMNR	CALL	(A1)		; GMI_NEWRGN, cre une nouvelle rgion	POP.W	D7	JUMP,NE 90$	LOAD.L	A4,D5		; A4 <-- ^gencar	LOAD.L	D5,D3		; D5 <-- position fentre	LOAD.W	(A6)+OXCT,D2	LOAD.L	(A6)+OXCPI,A4	LOAD.W	D7,#ERDIGC	COMP.W	(A4)+oxcIDENT,#xcIDENT	JUMP,NE 90$	CALL	DIMGC		; calcule les dimensions	LOAD.L	D4,#OGCH1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour en-tte + chasse	JUMP,NE 90$	LOAD.L	(A6)+OXCPO,A4	LOAD.L	(A6)+OXCLO,D4	LOAD.L	A3,A4		; A3 <-- ^gencar en sortie	LOAD.L	D3,D4		; D3 <-- gnre tout	LOAD.L	A4,(A6)+OXCPI	; A4 <-- ^gencar en entre	CALL	CONVHEAD	; gnre l'en-tte + chasse	CALL	WDOOPEN		; prpare la sous-fentre	JUMP,NE 80$	LOAD.L	A4,(A6)+OXCPI	; A4 <-- ^gencar en entre	LOAD.L	A4,#(A4)+oxcLENGTH ; A4 <-- ^table de chasse	LOAD.L	D4,D6	SWAP.W	D4	SUB.W	D4,(A6)+OXCT	SR.W	D4,#1	ADD.W	D4,(A6)+OXCT	SUB.W	D4,(A6)+OXCIY1	; D4 <-- position en Y	LOAD.W	(A6)+OXCPOS+0,D4	LOAD.W	D4,(A4)+(2*'A)	ADD.W	D4,(A4)+(2*'b)	ADD.W	D4,(A4)+(2*'c)	CALL	CONVIO		; D4 <-- largeur pour "Abc"	SUB.W	D4,D6	NEG.W	D4	ASR.W	D4,#1	JUMP',NC 40$	CLR.W	D440$:	LOAD.W	(A6)+OXCPOS+2,D4	LOAD.W	D3,#'A	CALL	CONVCARSCR	; affiche "A"	LOAD.W	D4,(A4)+(2*'A)	CALL	CONVIO	ADD.W	(A6)+OXCPOS+2,D4	LOAD.W	D3,#'b	CALL	CONVCARSCR	; affiche "b"	LOAD.W	D4,(A4)+(2*'b)	CALL	CONVIO	ADD.W	(A6)+OXCPOS+2,D4	LOAD.W	D3,#'c	CALL	CONVCARSCR	; affiche "c"	CALL	WDOCLOSE	; termine la sous-fentre	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	LOAD.L	A4,(A6)+OXCPO	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend l'en-tte + chasse	POP.W	D790$:	PUSH.W	D7	TEST.L	(A6)+OXCIRG	JUMP',EQ 92$	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	LOAD.L	A1,(A6)+OAGMDR	CALL	(A1)		; GMI_DISPOSERGN, rend la rgion	POP.W	D792$:	CALL	CLOVAR		; rend les variables	POP.W	D795$:	POPM.L	D0..D6,A1,A3,A4,A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; WDOOPEN >;--------/; Prpare la sous-fentre o afficher.; in	D5.L	coin sup/gauche fentre o afficher (y;x);	D6.L	dimensions fentre o afficher (dy;dx); out	A3.L	^descripteur;	D7.W	erreur; mod	D7.W, A3.LWDOOPEN:	PUSHM.L	D1..D5,A4	LOAD.L	A3,A0	LOAD.L	A4,#(A6)+OXCDF	; A4 <-- ^copie descripteur fentre	LOAD.W	D4,#(LGDIS8/4)+1-1CLOOP$:	LOAD.L	(A4+),(A3+)	; OXCDF <-- copie descripteur dentre	DECJ.W,NMO D4,CLOOP$	LOAD.L	A3,#(A6)+OXCDF	; A3 <-- ^copie descripteur fentre	TEST.B	(A3)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	CLR.B	(A3)+ODFCMD	; le bitmap sera noir/blanc	LOAD.L	D4,D6	ADD.W	D4,#16-1	AND.B	D4,#B'11110000	LOAD.W	D3,D4	MUL.WU	D4,D6	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour bitmap	JUMP,NE EXIT$	GESMEM	?CLEARMEM	; efface le bitmap	LOAD.L	(A6)+OXCPB,A4	; OXCPB <-- ^bitmap	LOAD.L	(A3)+ODFABS,A4	SR.W	D3,#3	LOAD.W	(A3)+ODFIIY,D3	CLR.L	D5	LOAD.L	(A3)+ODFY,D5	LOAD.L	(A3)+ODFFY,D5NOCOUL$:	ADD.W	(A3)+ODFFX,D5	SWAP.W	D5	ADD.W	(A3)+ODFFY,D5	LOAD.L	(A3)+ODFFDY,D6	LOAD.W	D4,(A3)+ODFX	ADD.W	D4,(A3)+ODFFX	LOAD.W	(A3)+ODFWBX,D4	; init min X	ADD.W	D4,(A3)+ODFFDX	LOAD.W	(A3)+ODFWEX,D4	; init max X	LOAD.W	D4,(A3)+ODFY	ADD.W	D4,(A3)+ODFFY	LOAD.W	(A3)+ODFWBY,D4	; init min Y	ADD.W	D4,(A3)+ODFFDY	LOAD.W	(A3)+ODFWEY,D4	; init max Y	LOAD.B	(A3)+ODFMGR,#GRACLIP	LOAD.L	A4,(A3)+ODFABS	LOAD.L	D2,(A3)+ODFFDY	LOAD.W	D4,(A3)+ODFWBX	LOAD.W	D3,D4	AND.W	D3,#B'1111	JUMP',EQ MODX$	NEG.W	D3	ADD.W	D3,#16	SUB.W	D2,D3	SUB.W	(A3)+ODFFDX,D3	SUB.W	(A3)+ODFWEX,D3MODX$:	ADD.W	D4,#16-1	AND.B	D4,#B'11110000	LOAD.W	(A3)+ODFWBX,D4	SR.W	D4,#3	ADD.W	A4,D4	LOAD.W	D4,(A3)+ODFWBY	MUL.WU	D4,(A3)+ODFIIY	ADD.L	A4,D4	LOAD.L	(A6)+OXCBRG+OGBMAPPT,A4	LOAD.W	(A6)+OXCBRG+OGBMAPWIDTH,(A3)+ODFIIY	CLR.L	(A6)+OXCBRG+OGBMAPRECT+OGRECTTL	LOAD.L	(A6)+OXCBRG+OGBMAPRECT+OGRECTBR,D2	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la souris	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D5,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; WDOCLOSE >;---------/; Termine la sous-fentre.; in	D5.L	coin sup/gauche fentre o afficher (y;x);	D6.L	dimensions fentre o afficher (dy;dx); out	-; mod	D7.WWDOCLOSE:	PUSHM.L	D1..D5,A2..A4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ EXIT$		; non => EXIT$	TEST.L	(A6)+OXCPB	JUMP',EQ EXIT$	LOAD.L	A2,#(A6)+OXCDF	; A2 <-- ^copie descripteur fentre	LOAD.L	D2,D6		; D2 <-- dimensions	LOAD.L	D4,D5		; D4 <-- origine destination	CLR.L	D3		; D3 <-- origine source	LOAD.W	D5,(A2)+ODFIIY	LOAD.L	A3,(A2)+ODFABS	; A3 <-- ^source	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	LOAD.L	A2,A0		; A2 <-- ^descripteur	LOAD.W	D1,#LOADDOT	; D1 <-- mode	GRA_	RASTER		; met le bitmap dans la fentre	LOAD.L	A4,(A6)+OXCPB	; A4 <-- ^bitmap	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire pour bitmapEXIT$:	LOAD.B	D3,#AFSCMO	LIB	?AFCAR		; remet la souris	POPM.L	D1..D5,A2..A4	RET;--------\\; NAMEGC  >;========/; Construit le nom du fichier  charger.; in	D0.B	fonte;	D1.L	style/chasse; out	A3.L	^nom du fichier; mod	D7.W, A3.LNAMEGC:	PUSH.L	D1	LOAD.L	A3,#(A6)+OXCFILN	LOAD.B	(A3+),#'S	LOAD.B	(A3+),#'M	LOAD.B	(A3+),#'A	LOAD.B	(A3+),#'_	LOAD.B	(A3+),D0	LOAD.B	(A3+),D1	LOAD.B	(A3+),#'P	TEST.L	D1:#BGCFIX	JUMP',BC 40$	LOAD.B	(A3)-1,#'F	TCLR.B	(A3)-2:#BGCFIX40$:	LOAD.B	(A3+),#'0	LOAD.B	(A3+),#'0	LOAD.B	(A3+),#'.	LOAD.B	(A3+),#'G	LOAD.B	(A3+),#'E	LOAD.B	(A3+),#'N	LOAD.B	(A3+),#'C	CLR.B	(A3)	LOAD.L	A3,#(A6)+OXCFILN	POP.L	D1	RET;--------\\; NAMEGCJ >;========/; Construit le nom du fichier trs petit  charger.; in	A4.L	^gencar en entre; out	A3.L	^nom du fichier;	D7.W	erreur; mod	D7.WNAMEGCJ:	PUSHM.L	D4,A2	LOAD.W	D7,#1	LOAD.W	D4,(A6)+OXCT	; D4 <-- taille demande	COMP.W	D4,(A4)+oxcPMN	; taille trs petite ?	JUMP',HS EXIT$		; non => EXIT$	TEST.B	(A4)+oxcPNG	; nom existe ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A2,#(A6)+OXCFILN	LOAD.L	A3,#(A6)+OXCFILJXFER$:	LOAD.B	(A3+),(A2+)	; OXCFILJ <-- OXCFILN	JUMP,NE XFER$	LOAD.L	A3,#(A6)+OXCFILJ	LOAD.W	(A3)+4,(A4)+oxcPNG	LOAD.B	(A3)+6,#'P	TCLR.B	(A3)+4+1:#BGCFIX	JUMP',BC OK$	LOAD.B	(A3)+6,#'FOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; DIMGC   >;========/; Calcule les dimensions maximales d'un caractres.; in	A4.L	^gencar en entre; out	-; mod	D7.WDIMGC:	PUSHM.L	D1..D4,A2,A3	CALL	CALCHTE		; D4 <-- hauteur du "E"	LOAD.W	(A6)+OXCIYE,D4	TEST.L	(A6)+OXCPJ	JUMP',EQ 10$	PUSH.L	A4	LOAD.L	A4,(A6)+OXCPJ	CALL	CALCHTE		; D4 <-- hauteur du "E" si trs petit	LOAD.W	(A6)+OXCIYEJ,D4	POP.L	A410$:	LOAD.L	A3,#(A4)+oxcXMINS	LOAD.W	D3,#128-1	CLR.W	D420$:	LOAD.W	D2,(A3+)	NEG.W	D2	COMP.W	D4,D2	JUMP',GE 22$	LOAD.W	D4,D222$:	DECJ.W,NMO D3,20$	CALL	CONVIO	TEST.B	(A4)+oxcMODE+2:#bxcMODELIMIT-8	JUMP',BC 24$	CLR.W	D424$:	LOAD.W	(A6)+OXCIX1,D4	LOAD.L	A3,#(A4)+oxcYMINS	LOAD.W	D3,#128-1	CLR.W	D430$:	LOAD.W	D2,(A3+)	NEG.W	D2	COMP.W	D4,D2	JUMP',GE 32$	LOAD.W	D4,D232$:	DECJ.W,NMO D3,30$	CALL	CONVIO	LOAD.W	(A6)+OXCIY1,D4	LOAD.L	A3,#(A4)+oxcXMAXS	LOAD.L	A2,#(A4)+oxcLENGTH	LOAD.W	D3,#128-1	CLR.W	D440$:	LOAD.W	D2,(A2+)	TEST.B	(A4)+oxcMODE+2:#bxcMODELINK-8	JUMP',BS 44$	TEST.B	(A6)+OXCS+3:#BGCFIX-0	JUMP',BS 44$	LOAD.W	D1,(A3+)	; D1 <-- chasse minimale (recouvrement impossible !)	COMP.W	D2,D1	JUMP',HS 44$	LOAD.W	D2,D144$:	COMP.W	D4,D2	JUMP',GE 48$	LOAD.W	D4,D248$:	DECJ.W,NMO D3,40$	CALL	CONVIO	LOAD.W	(A6)+OXCIX2,D4	LOAD.L	A3,#(A4)+oxcYMAXS	LOAD.W	D3,#128-1	CLR.W	D450$:	LOAD.W	D2,(A3+)	COMP.W	D4,D2	JUMP',GE 52$	LOAD.W	D4,D252$:	DECJ.W,NMO D3,50$	CALL	CONVIO	INC.W	D4	LOAD.W	(A6)+OXCIY2,D4	TEST.B	(A6)+OXCS+3:#BGCFIX-0	JUMP',BC 60$	LOAD.W	D4,(A4)+oxcLENGTH+(2*'E)	CALL	CONVIO		; D4 <-- largeur du "E"	LOAD.W	(A6)+OXCIX2,D460$:	LOAD.W	D4,(A6)+OXCIX1	ADD.W	D4,(A6)+OXCIX2	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	LOAD.W	(A6)+OXCIXB,D4	POPM.L	D1..D4,A2,A3	RET;---------\\; CONVHEAD >;=========/; Gnre l'en-tte du gnrateur.; in	A3	^gencar en sortie;	D3.L	lg  gnrer en sortie;	A4	^gencar en entre; out	(A3)++	gencar en sortie; mod	D7.WCONVHEAD:	PUSHM.L	D1..D4,A1,A2,A5	PUSH.L	A4	LOAD.L	A4,A3	LOAD.L	D4,D3	GESMEM	?CLEARMEM	; efface tout en sortie	POP.L	A4; Gnre l'en-tte du gencar.	LOAD.W	D4,(A6)+OXCIY1	ADD.W	D4,(A6)+OXCIY2	LOAD.W	(A3)+OGCMHD,D4	LOAD.W	D4,(A6)+OXCIXB	LOAD.B	(A3)+OGCMWB,D4	MUL.WU	D4,(A3)+OGCMHD	LOAD.W	(A3)+OGCMSB,D4;	LOAD.B	(A3)+OGCFCA,#0	LOAD.B	(A3)+OGCLCA,#128-1	LOAD.W	(A3)+OGCLMA,(A6)+OXCIX1	LOAD.W	(A3)+OGCBLI,(A6)+OXCIY2	LOAD.W	(A3)+OGCMH1,(A6)+OXCIY1	LOAD.W	(A3)+OGCMH2,(A6)+OXCIY2	LOAD.W	D4,(A6)+OXCIX1	ADD.W	D4,(A6)+OXCIX2	LOAD.W	(A3)+OGCMWI,D4	LOAD.W	D4,(A6)+OXCIYE	; D4 <-- hauteur du "E"	MUL.WU	D4,(A4)+oxcITL	DIV.WU	D4,#1000	CALL	CONVIO		; D4 <-- hauteur du "E"	LOAD.W	D2,(A6)+OXCIY1	ADD.W	D2,(A6)+OXCIY2	; D2 <-- minimum autoris	COMP.W	D4,D2	JUMP',HS 15$	LOAD.W	D4,D215$:	LOAD.W	(A3)+OGCISP,D4	LOAD.B	(A3)+OGCVSP,#1;	LOAD.W	(A3)+OGCPWI,#H'0000	LOAD.W	(A3)+OGCPH1,#H'0080	LOAD.W	(A3)+OGCPH2,#H'0100	LOAD.W	(A3)+OGCPMX,#H'0180	LOAD.L	(A3)+OGCRBI,(A4)+oxcRBI	LOAD.L	A1,#(A3)+OGCIDE	LOAD.L	A2,#(A4)+oxcIDE20$:	LOAD.B	(A1+),(A2+)	JUMP,NE 20$	LOAD.L	A1,#(A3)+OGCTXT	LOAD.L	A2,#(A4)+oxcTEXT22$:	LOAD.B	(A1+),(A2+)	JUMP,NE 22$	LOAD.L	A1,#(A3)+OGCCNM	LOAD.L	A2,#(A4)+oxcNAME24$:	LOAD.B	(A1+),(A2+)	JUMP,NE 24$; Gnre la table de chasse.	COMP.L	D3,#OGCWID	JUMP,LS 90$	LOAD.L	A1,#(A3)+OGCWID	LOAD.L	A2,#(A4)+oxcLENGTH	LOAD.L	A5,#(A4)+oxcXMAXS	LOAD.W	D1,#128-140$:	LOAD.W	D4,(A2+)	TEST.B	(A4)+oxcMODE+2:#bxcMODELINK-8	JUMP',BS 45$	TEST.B	(A6)+OXCS+3:#BGCFIX-0	JUMP',BS 45$	LOAD.W	D2,(A5+)	; D2 <-- chasse minimale (recouvrement impossible !)	COMP.W	D4,D2	JUMP',HS 45$	LOAD.W	D4,D245$:	CALL	CONVIO	ADD.W	D4,(A6)+OXCIX1	LOAD.B	(A1+),D4	DECJ.W,NMO D1,40$; Gnre la table h1.	COMP.L	D3,#OGCH1	JUMP',LS 90$	LOAD.L	A1,#(A3)+OGCH1	LOAD.L	A2,#(A4)+oxcYMINS	LOAD.W	D1,#128-150$:	LOAD.W	D4,(A2+)	NEG.W	D4	CALL	CONVIO	LOAD.B	(A1+),D4	DECJ.W,NMO D1,50$; Gnre la table h2.	COMP.L	D3,#OGCH2	JUMP',LS 90$	LOAD.L	A1,#(A3)+OGCH2	LOAD.L	A2,#(A4)+oxcYMAXS	LOAD.W	D1,#128-160$:	LOAD.W	D4,(A2+)	CALL	CONVIO	LOAD.B	(A1+),D4	DECJ.W,NMO D1,60$90$:	POPM.L	D1..D4,A1,A2,A5	RET;--------\\; CALCHTE >;========/; Cherche la hauteur du "E", sans tenir compte des pinceaux.; in	A4.L	^gencar en entre; out	D4.W	hauteur du "E"; mod	D4.L, D7.WCALCHTE:	LOAD.W	D4,(A4)+oxcHTE	JUMP',NE EXIT$	LOAD.W	D4,(A4)+oxcYMINS+(2*'E)	NEG.W	D4EXIT$:	RET;--------\\; CONVGC  >;========/; Gnre toutes les matrices des caractres.; in	A3	^gencar en sortie;	A4	^gencar en entre; out	(A3)++	gencar en sortie; mod	D7.WCONVGC:	PUSHM.L	D3,A2; Prpare le descripteur de fentre.	LOAD.L	A2,#(A6)+OXCDF	; A2 <-- ^descripteur fentre spcial	CLR.W	D3	LOAD.B	D3,(A3)+OGCMWB	LOAD.W	(A2)+ODFIIY,D3	SL.W	D3,#3	LOAD.W	(A2)+ODFDX,D3	LOAD.W	(A2)+ODFFDX,D3	LOAD.W	(A2)+ODFWEX,D3	LOAD.W	D3,(A3)+OGCMHD	LOAD.W	(A2)+ODFDY,D3	LOAD.W	(A2)+ODFFDY,D3	LOAD.W	(A2)+ODFWEY,D3	LOAD.W	(A2)+ODFIIX,#1	LOAD.B	(A2)+ODFMGR,#GRACLIP	LOAD.B	(A2)+ODFNOW,#-1; Gnre tous les caractres.	CLR.W	D340$:	CALL	CONVCAR		; gnre un caractre	INC.W	D3	COMP.W	D3,#128	JUMP,LO 40$	POPM.L	D3,A2	RET;--------\\; CONVCAR >;--------/; Gnre la matrice d'un caractre.; in	D3.W	code d'un caractre;	A3	^gencar en sortie; out	(A3)++	nouvelle matrice; mod	D7.WCONVCAR:	PUSHM.L	D1..D4,A1..A5	LOAD.W	D1,D3		; D1 <-- caractre	MUL.WU	D3,(A3)+OGCMSB	LOAD.L	A1,#(A3)+OGCMAT	ADD.L	A1,D3		; A1 <-- ^matrice  crer	LOAD.L	A2,#(A6)+OXCBRG	; A2 <-- ^descripteur bitmap	LOAD.L	(A2)+OGBMAPPT,A1	CLR.W	D4	LOAD.B	D4,(A3)+OGCMWB	; D4 <-- largeur matrice en bytes	LOAD.W	(A2)+OGBMAPWIDTH,D4	CLR.L	(A2)+OGBMAPRECT+OGRECTTL	LOAD.W	D4,(A3)+OGCMHD	; D4 <-- hauteur matrice	SWAP.W	D4	CLR.W	D4	LOAD.B	D4,(A3)+OGCMWB	SL.W	D4,#3		; D4 <-- largeur matrice	LOAD.L	(A2)+OGBMAPRECT+OGRECTBR,D4	LOAD.W	D3,D1		; D3 <-- caractre	CALL	IFFILL		; remplissage ?	JUMP,NE 50$		; non => 50$	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	PUSH.W	#GFILLXOR+GFILLINTERIOR ; stack <-- mode	PUSH.L	#(A6)+OXCBRG+OGBMAPRECT ; stack <-- ^cliprect	LOAD.L	A1,(A6)+OAGMOR	CALL	(A1)		; GMI_OPENRGN, dbut de dfinition de rgion	POP.W	D7	JUMP',NE 50$	LOAD.W	D3,D1		; D3 <-- caractre	LOAD.W	(A6)+OXCMOD,#XCMODFILL	CALL	DECODE		; dfinition de la rgion	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	LOAD.L	A1,(A6)+OAGMCR	CALL	(A1)		; GMI_CLOSERGN, termine la dfinition de rgion	POP.W	D7	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	PUSH.L	#(A6)+OXCBRG	; stack <-- ^descripteur bitmap	PUSH.B	#GMOR		; stack <-- mode de transfert	LOAD.L	A1,(A6)+OAGMRB	CALL	(A1)		; GMI_RGNTOBITMAP, bitmap <-- rgion	POP.W	D750$:	LOAD.W	D3,D1		; D3 <-- caractre	CALL	IFOUTL		; outline ?	JUMP',NE 90$		; non => 90$	LOAD.L	A2,#(A6)+OXCBRG	; A2 <-- ^descripteur bitmap	LOAD.L	(A6)+OXCDF+ODFABS,(A2)+OGBMAPPT	LOAD.W	(A6)+OXCMOD,#XCMODOUTL	CALL	DECODE		; dfinition de la rgion90$:	POPM.L	D1..D4,A1..A5	RET;-----------\\; CONVCARSCR >;-----------/; Dessine la matrice d'un caractre directement dans l'cran.; in	D3.W	code d'un caractre;	A3.L	^descripteur; out	-; mod	D7.WCONVCARSCR:	PUSHM.L	D1..D4,A1..A5	LOAD.W	D1,D3		; D1 <-- caractre	CALL	IFFILL		; remplissage ?	JUMP',NE 50$		; non => 50$	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	PUSH.W	#GFILLXOR+GFILLINTERIOR ; stack <-- mode	PUSH.L	#(A6)+OXCBRG+OGBMAPRECT ; stack <-- ^cliprect	LOAD.L	A1,(A6)+OAGMOR	CALL	(A1)		; GMI_OPENRGN, dbut de dfinition de rgion	POP.W	D7	JUMP',NE 50$	LOAD.W	D3,D1		; D3 <-- caractre	LOAD.W	(A6)+OXCMOD,#XCMODFILL	CALL	DECODE		; dfinition de la rgion	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	LOAD.L	A1,(A6)+OAGMCR	CALL	(A1)		; GMI_CLOSERGN, termine la dfinition de rgion	POP.W	D7	LOAD.L	A2,#(A6)+OXCBRG	; A2 <-- ^descripteur bitmap	LOAD.W	D2,#GMOR	; D2 <-- mode de transfert	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	PUSH.L	#(A6)+OXCBRG	; stack <-- ^descripteur bitmap	PUSH.B	#GMOR		; stack <-- mode de transfert	LOAD.L	A1,(A6)+OAGMRB	CALL	(A1)		; GMI_RGNTOBITMAP, bitmap <-- rgion	POP.W	D750$:	LOAD.W	D3,D1		; D3 <-- caractre	CALL	IFOUTL		; outline ?	JUMP',NE 90$		; non => 90$	LOAD.W	(A6)+OXCMOD,#XCMODOUTL	CALL	DECODE		; dfinition de la rgion90$:	POPM.L	D1..D4,A1..A5	RET;--------\\; CONVIO  >;========/; ; in	D4.W	longueur dans le gencar en entre [pi]; out	D4.W	idem, dans le gencar en sortie [po]; mod	D4.L, D7.WCONVIO:	PUSH.L	D3	MUL.WA	D4,(A6)+OXCT	CLR.L	D3	LOAD.W	D3,(A6)+OXCIYE	SR.W	D3,#1	ADD.L	D4,D3	DIV.WA	D4,(A6)+OXCIYE	POP.L	D3	RET;--------\\; CONVIOJ >;========/; ; in	D4.W	longueur dans le gencar en entre [pi]; out	D4.W	idem, dans le gencar en sortie [po]; mod	D4.L, D7.WCONVIOJ:	PUSH.L	D3	MUL.WA	D4,(A6)+OXCT	CLR.L	D3	LOAD.W	D3,(A6)+OXCIYEJ	SR.W	D3,#1	ADD.L	D4,D3	DIV.WA	D4,(A6)+OXCIYEJ	POP.L	D3	RET;--------\\; OPEVAR  >;--------/; Ouvre les variables locales.; ATTENTION:	Il faut absolument excuter un appel  GMI par un CALL (An);		et non par un appel normal GMI_xxx, car le passage des;		paramtres par le stack n'est pas compatible entre GMI et;		les modules .LIB en mode superviseur !!!; in	-; out	A6.L	^variables locales;	D7.W	erreur; mod	D7.W, A6.LOPEVAR:	PUSHM.L	D1,D3,D4,A3,A4	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour les variables	JUMP,NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables locales	LOAD.W	D3,#GMI_NEWRGN	LIB_	GETAD	LOAD.L	(A6)+OAGMNR,A3	LOAD.W	D3,#GMI_DISPOSERGN	LIB_	GETAD	LOAD.L	(A6)+OAGMDR,A3	LOAD.W	D3,#GMI_OPENRGN	LIB_	GETAD	LOAD.L	(A6)+OAGMOR,A3	LOAD.W	D3,#GMI_CLOSERGN	LIB_	GETAD	LOAD.L	(A6)+OAGMCR,A3	LOAD.W	D3,#GMI_RGNTOBITMAP	LIB_	GETAD	LOAD.L	(A6)+OAGMRB,A3	LOAD.W	D3,#GMI_PUTRLINE	LIB_	GETAD	LOAD.L	(A6)+OAGMPL,A3	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOVAR  >;--------/; Ferme les variables locales.; in	A6.L	^variables locales; out	-; mod	-CLOVAR:	PUSHM.L	D1,D7,A4	TEST.L	(A6)+OPPEN	JUMP',EQ GIVE$	LOAD.L	A4,(A6)+OPPEN	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancien pinceauGIVE$:	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend les variables	POPM.L	D1,D7,A4	RET	.INS	XCARBITMAP.ASI	.INS	XCARFRAG.ASI	.INS	XCARLSTGC.ASI	.INS	XCARDRAW.ASIEND_XCAR:	.END