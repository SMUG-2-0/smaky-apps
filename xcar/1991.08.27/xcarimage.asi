	.SBTTL	XCARIMAGE.ASI;--------\\; IFSHOW  >;========/; Affiche l'image de fond.; in	-; out	-; mod	D7.WIFSHOW:	PUSHM.L	D1,D3,D4,A0,A3,A4	TEST.B	(A6)+OFADEFI+3:#0 ; affiche l'image de fond ?	JUMP,BC 80$		; non => 80$	TEST.L	(A6)+OIFPT	; image de fond existe ?	JUMP,EQ 80$		; non => 80$	COMP.L	(A6)+OIFSLP,#POSNIL	JUMP',EQ 20$	LOAD.L	D3,(A6)+OIFSPO	COMP.L	D3,#POSNIL	JUMP',NE 10$	LOAD.L	D3,(A6)+OIFDIM	SR.W	D3,#1	SWAP.W	D3	SR.W	D3,#1	SWAP.W	D310$:	CALL	CONVPFPG	COMP.L	D3,(A6)+OIFSLP	; position change ?	JUMP',NE 20$	LOAD.W	D4,(A6)+OIZOOM	CALL	D4SCALE	COMP.W	D4,(A6)+OIFSLZ	; zoom chang ?	JUMP,EQ 50$20$:	TEST.L	(A6)+OIFSPT	JUMP',EQ 22$	LOAD.L	A4,(A6)+OIFSPT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OIFSPT22$:	LOAD.W	D4,(A6)+OWDODX	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	MUL.WU	D4,(A6)+OWDODY	ADD.L	D4,#10000	; <<<<< A VERIFIER !!!!!	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande de la mmoire	JUMP,NE 80$	LOAD.L	(A6)+OIFSPT,A4	GESMEM	?CLEARMEM	; efface tout	LOAD.L	D3,(A6)+OIFSPO	COMP.L	D3,#POSNIL	JUMP',NE 30$	LOAD.L	D3,(A6)+OIFDIM	SR.W	D3,#1	SWAP.W	D3	SR.W	D3,#1	SWAP.W	D330$:	CALL	CONVPFPG	LOAD.L	(A6)+OIFSLP,D3	LOAD.W	D4,(A6)+OIZOOM	CALL	D4SCALE	LOAD.W	(A6)+OIFSLZ,D4	LOAD.L	A0,#(A6)+OSTVAR	LOAD.L	(A0)+OSTRSPT,(A6)+OIFPT	LOAD.W	D4,(A6)+OIFDIM+2	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.W	(A0)+OSTRSDX,D4	CLR.L	D3	CALL	CONVPGPF	LOAD.L	(A0)+OSTRS0,D3	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OWDODY	CALL	CONVPGPF	LOAD.L	(A0)+OSTRS2,D3	COMP.L	D3,D4	JUMP',EQ 50$	LOAD.L	(A0)+OSTRDPT,(A6)+OIFSPT	LOAD.W	D4,(A6)+OWDODX	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	LOAD.W	(A0)+OSTRDDX,D4	LOAD.L	D3,(A0)+OSTRS2	CALL	CONVPFPG	LOAD.L	D4,D3	LOAD.L	D3,(A0)+OSTRS0	CALL	CONVPFPG	COMP.L	D3,D4	JUMP',EQ 50$	LOAD.L	(A0)+OSTRD0,D3	LOAD.L	(A0)+OSTRD2,D4	LOAD.W	(A0)+OSTRD1+2,D4	LOAD.W	(A0)+OSTRD3+2,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	(A0)+OSTRD1+0,D3	LOAD.W	(A0)+OSTRD3+0,D4	ST_	RECT		; hop, stretch ...50$:	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	CLR.L	(A3)+1	LOAD.L	(A3)+5,(A6)+OIFSPT	LOAD.W	D4,(A6)+OWDODX	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	LOAD.W	(A3)+9,D4	CLR.L	(A3)+11	CLR.L	(A3)+15	CLR.W	(A3)+19	LOAD.L	D4,(A6)+OWDODY	SWAP.W	D4	LOAD.L	(A3)+21,D4	LOAD.B	(A3)+25,#LOADDOT	LOAD.W	D3,#26	LIB	?STRING		; affiche l'image de fond	JUMP'	90$80$:	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface la swdo90$:	POPM.L	D1,D3,D4,A0,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; CONVPFPG >;=========/; Conversion d'un point image-fond en point graphique.; in	D3.L	point (y;x) fond; out	D3.L	point (y;x) dans l'cran; mod	D3.L, D7.WCONVPFPG:	PUSH.L	D4	LOAD.L	D4,(A6)+OIFSPO	COMP.L	D4,#POSNIL	JUMP',NE 20$	LOAD.L	D4,(A6)+OIFDIM	SR.W	D4,#1	SWAP.W	D4	SR.W	D4,#1	SWAP.W	D420$:	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LOAD.W	D4,D3	MUL.WA	D4,(A6)+OIZOOM	DIV.WA	D4,#1000	LOAD.W	D3,D4	SWAP.W	D3	LOAD.W	D4,D3	MUL.WA	D4,(A6)+OIZOOM	DIV.WA	D4,#1000	LOAD.W	D3,D4	SWAP.W	D3	CALL	CONVPIPG	POP.L	D4	RET;---------\\; CONVPGPF >;=========/; Conversion d'un point graphique en point image-fond.; in	D3.L	point (y;x) dans l'cran; out	D3.L	point (y;x) fond; mod	D3.L, D7.WCONVPGPF:	PUSH.L	D4	CALL	CONVPGPI	LOAD.W	D4,D3	MUL.WA	D4,#1000	DIV.WA	D4,(A6)+OIZOOM	LOAD.W	D3,D4	SWAP.W	D3	LOAD.W	D4,D3	MUL.WA	D4,#1000	DIV.WA	D4,(A6)+OIZOOM	LOAD.W	D3,D4	SWAP.W	D3	LOAD.L	D4,(A6)+OIFSPO	COMP.L	D4,#POSNIL	JUMP',NE 20$	LOAD.L	D4,(A6)+OIFDIM	SR.W	D4,#1	SWAP.W	D4	SR.W	D4,#1	SWAP.W	D420$:	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	TEST.W	D3	JUMP',NC 30$	CLR.W	D330$:	COMP.W	D3,(A6)+OIFDIM+2	JUMP',LS 32$	LOAD.W	D3,(A6)+OIFDIM+232$:	SWAP.W	D3	TEST.W	D3	JUMP',NC 40$	CLR.W	D340$:	COMP.W	D3,(A6)+OIFDIM+0	JUMP',LS 42$	LOAD.W	D3,(A6)+OIFDIM+042$:	SWAP.W	D3	POP.L	D4	RET;--------\\; AFIMAGE >;========/; Affiche une image, sans la conserver en mmoire.; in	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WAFIMAGE:	PUSH.L	A4	CALL	LOADIMAGE	; charge l'image en mmoire	JUMP',NE 90$	CALL	SHOWIMAGE	; affiche l'image	CALL	KILLIMAGE	; libre la mmoire	CLR.W	D7		; D7 <-- ok90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; LOADIMAGE >;==========/; Charge une image en mmoire.; in	A3.L	^nom de l'image; out	A4.L	^image;	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	A4.L, D7.W, A4.LLOADIMAGE:	PUSHM.L	D0,D1,D3,D6,A1..A3,A5	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A5,A3		; A5 <-- ^nom de l'image	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE 90$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE 84$	LOAD.L	A4,A2	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$	COMP.B	(A2)+OIMTYP,#H'82 ; image du LAMI ?	JUMP',NE 20$		; non => 20$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute la stupide en-tte de 256 bytes !	JUMP,NE 82$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$20$:	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE 82$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP,NE 80$	JUMP'	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 80$	LOAD.L	A3,A1	GRA_	DECOIMA		; dcode l'image ...	JUMP',NE 80$35$:	LOAD.L	A4,A1		; A4 <-- ^image	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions de l'image	CLR.W	D7		; D7 <-- ok	JUMP'	82$80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D784$:	PUSHM.L	D7,A4	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POPM.L	D7,A490$:	POPM.L	D0,D1,D3,D6,A1..A3,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; SHOWIMAGE >;==========/; Affiche une image dans la (sous-)fentre.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie centrale.; in	A4.L	^image;	D4.L	dimensions (dy;dx);	D3.L	coin sup/gauche (y;x); out	-; mod	D7.WSHOWIMAGE:	PUSHM.L	D0,D1,D3,D4,A3	LOAD.W	D0,D4		; D0 <-- largeur de l'image	SWAP.W	D4	LOAD.W	D1,D4		; D1 <-- hauteur de l'image	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^buffer pour DRAWRASTER	LOAD.W	(A3)+12,D3	; destination: <xx>	SWAP.W	D3	LOAD.W	(A3)+14,D3	; destination: <yy>	LOAD.W	D3,D0	SR.W	D3,#3	LOAD.W	(A3)+10,D3	; source: <ii>	CLR.W	(A3)+20		; destination: <ii>	CLR.W	(A3)+2		; source: <xx>	LOAD.W	(A3)+22,D0	; image: <dxx>	CLR.W	(A3)+4		; source: <yy>	LOAD.W	(A3)+24,D1	; image: <dyy>	LOAD.W	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+6,A4	; source: <pppp>	CLR.L	(A3)+16		; destination: <pppp>	LOAD.B	(A3)+26,#SETDOT	; image: <mode>	LOAD.W	D3,#1+26	; D3 <-- longueur	LIB	?STRING		; affiche l'image	POPM.L	D0,D1,D3,D4,A3	RET;----------\\; KILLIMAGE >;==========/; Libre la mmoire d'une image.; in	A4.L	^image; out	-; mod	-KILLIMAGE:	PUSHM.L	D1,D7,A4	LOAD.L	A4,#(A4)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POPM.L	D1,D7,A4	RET	.END