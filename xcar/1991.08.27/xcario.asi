	.SBTTL	XCARIO.ASIDOPREND:	CLR.B	(A6)+OBUFINDOPRENDL:	LOAD.L	A3,#(A6)+OBUFIN	CALL	DBOXEDITI	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ _LOOP	LOAD.W	D0,#1		; D0 <-- avant de reprendre	CALL	DBOXSAVE	; sauve si ncessaire le dessin actuel	JUMP',EQ DOPRENDF	; ok => DOPRENDF	COMP.W	D7,#1		; (ANNULE) ?	JUMP,EQ _LOOP		; oui => _LOOP	JUMP	ERROR		; non => ERRORDOPRENDF:	CALL	PRENDTOUT	; A4 <-- ^gencar lu	JUMP',EQ 50$	COMP.W	D7,#ERKSTO	JUMP,EQ _LOOP	PUSH.W	D7	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	DOPRENDL50$:	LOAD.L	A3,A4	TEST.L	(A6)+OXCPGC	JUMP',EQ 52$	LOAD.L	A4,(A6)+OXCPGC	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'ancien gencar52$:	LOAD.L	(A6)+OXCPGC,A3	LOAD.L	A3,#(A6)+OBUFIN	CALL	SAVFILE		; OBUNAME <-- nom	CALL	DESINFFILE	; affiche le nom dans les infos	CLR.B	(A6)+OMAJ	; le dessin est  jour	LOAD.W	(A6)+OXCCAA,#-1	CALL	NEWCAR		; dessine le nouveau caractre	JUMP	_LOOP;----------\\; PRENDTOUT >;==========/; Lit tout un gencar.; in	A3.L	^nom; out	A4.L	^gencar;	D7.W	erreur; mod	D7.W, A4.LPRENDTOUT:	PUSHM.L	D1..D4,D6,A2,A3	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .GENC	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le gencar	JUMP,NE 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; va  la fin	LOAD.L	D1,D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	LOAD.L	D4,D1		; D4 <-- longueur du gencar	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour le gencar	JUMP,NE 42$	FOS	?RDBYTE		; lit tout le gencar	JUMP',NE 40$	LOAD.W	D7,#ERFOS	; D7 <-- problme avec un fichier	COMP.W	(A4)+256+oxcIDENT,#xcIDENT	JUMP',NE 40$	LOAD.L	A3,#(A4)+256+oxcIDE	TEST.B	(A3)	JUMP',NE 32$	LOAD.L	A2,#R16"IDE$30$:	LOAD.B	(A3+),(A2+)	JUMP,NE 30$32$:	LOAD.L	A3,#(A4)+256+oxcTEXT	LOAD.L	A2,#R16"TEXT1$34$:	LOAD.B	(A3+),(A2+)	JUMP,NE 34$	DEC.L	A3	LOAD.B	(A3+),#XCARREV+'0	LOAD.B	(A3+),#'.	.IF	XCARVERS<10	LOAD.B	(A3+),#XCARVERS+'0	.ELSE	LOAD.B	(A3+),#(XCARVERS/10)+'0	LOAD.B	(A3+),#(XCARVERS-((XCARVERS/10)*10))+'0	.ENDIF	.IF	XCARPROV>SPACE	LOAD.B	(A3+),#XCARPROV	.ENDIF	LOAD.L	A2,#R16"TEXT2$36$:	LOAD.B	(A3+),(A2+)	JUMP,NE 36$	CLR.W	D7	JUMP'	42$40$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend mmoire pour le gencar	POP.W	D742$:	PUSH.W	D7	FOS	?CLOSE		; ferme le gencar	POP.W	D790$:	POPM.L	D1..D4,D6,A2,A3	TEST.W	D7		; retour EQ/NE	RETIDE$:	.ASCIZ	"XCAR"TEXT1$:	.ASCIZ	"XCAR "TEXT2$:	.ASCIZ	" -- (C) 1989, D.ROUX et EPSITEC-system sa"	.EVENDOSAUVE:	TEST.L	(A6)+OXCPGC	; gencar existe ?	JUMP,EQ BIP		; non => BIP	CALL	NEWCAR		; sauve le caractre en dition	CLR.W	D2		; D2 <-- mode manuel	CALL	SAUVETOUT	; sauve tout le gencar	JUMP,NE ERROR	JUMP	_LOOP;----------\\; SAUVETOUT >;==========/; Sauve tout le gencar.; in	D2.W	mode; out	D7.W	erreur; mod	D7.WSAUVETOUT:	PUSHM.L	D0..D6,A3,A4	TEST.L	(A6)+OXCPGC	; gencar existe ?	JUMP,EQ 90$		; non => 90$	LOAD.L	A3,#(A6)+OBUFOUT	CALL	GETFILE		; OBUFOUT <-- OBUNAME	CLR.L	D5	TEST.B	(A6)+OMAJ	; mise  jour ncessaire ?	JUMP',T 10$		; oui => 10$	TSET.L	D2:#BDBNMAJ	; D2 <-- touche (MET A JOUR) grise10$:	LOAD.L	A3,#(A6)+OBUFOUT	LOAD.L	D4,D5		; D4 <-- fanions	CALL	DBOXEDITO	JUMP,NE 95$	COMP.W	D3,#F0	JUMP,EQ 95$	LOAD.W	D1,D3		; D1 <-- F1/F4	LOAD.L	D5,D4		; D5 <-- fanions	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier avec extension20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP,EQ 50$		; ok => 50$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	TEST.L	D2:#BDBAUTO	; sauvetage automatique ?	JUMP',BS 40$		; oui => 40$	COMP.W	D1,#F4		; touche (MET A JOUR) ?	JUMP',EQ 40$		; oui => 40$	CALL	NORMMOUSE	; remet la flche	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE 90$	COMP.W	D3,#'O	JUMP,NE 10$40$:	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE 90$	JUMP	20$50$:	CALL	WAITMOUSE	; met le sablier	CALL	MINMAXALL	; recalcule la "bounding box" globale	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE 90$	LOAD.L	A4,(A6)+OXCPGC	LOAD.L	D4,(A4)+OBXLG	ADD.L	D4,#256	FOS	?WRBYTE		; crit tout le gencar	JUMP',NE 80$	FOS	?CLOSE	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	TEST.W	D7		; ok =	JUMP',NE 95$		; non => 90$	LOAD.L	A3,#(A6)+OBUFOUT	CALL	SAVFILE		; OBUNAME <-- nom	CALL	DESINFFILE	; affiche le nom dans les infos	CLR.B	(A6)+OMAJ	; le dessin est  jour	CLR.W	D7		; D7 <-- ok95$:	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RETDOSAUVEBMF:	TSET.B	(A6)+OSWCOM+0:#31-24 ; il faudra quitter XCAR aprs cela	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SKPNAM	JUMP,NE BIP	LIB	?SKPNAM	JUMP,NE BIP	LOAD.L	A4,A3	CALL	GETANUM	LOAD.W	(A6)+OTSVBM,D4	JUMP'	DOSAUVEBMLDOSAUVEBM:	LOAD.W	D0,#1		; D0 <-- avant de reprendre	CALL	DBOXSAVE	; sauve si ncessaire le dessin actuel	JUMP',EQ SAUVE$		; ok => SAUVE$	COMP.W	D7,#1		; (ANNULE) ?	JUMP,EQ _LOOP		; oui => _LOOP	JUMP	ERROR		; non => ERRORSAUVE$:	CALL	DBOXSAUVEBM	; demande la taille ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE _LOOPDOSAUVEBML:	LOAD.L	A3,#(A6)+OBUFOUT	CALL	GETFILE		; OBUFOUT <-- OBUNAME	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .GENC	LOAD.L	A2,A3		; A2 <-- ^nom du fichier	CALL	SKIPREP	LOAD.W	D7,#ERSYNT	COMP.B	(A3+),#'S	JUMP,NE ERROR	COMP.B	(A3+),#'M	JUMP,NE ERROR	COMP.B	(A3+),#'A	JUMP,NE ERROR	COMP.B	(A3+),#'_	JUMP,NE ERROR	CLR.L	D4	LOAD.W	D4,(A6)+OTSVBM	DIV.WU	D4,#10	ADD.B	D4,#'0	LOAD.B	(A3)+3,D4	SWAP.W	D4	ADD.B	D4,#'0	LOAD.B	(A3)+4,D4	LIB	?SYNGC		; D3/D4/D5 <-- FST	JUMP,NE ERROR	LOAD.B	D0,D3	LOAD.B	D1,D4	LOAD.B	D2,D5	CALL	CONVNEWGC	CALL	WAITMOUSE	; met le sablier	XCAR_	CREATE		; A4 <-- ^gencar	JUMP,NE ERROR	LOAD.L	A5,A4CREATE$:	CALL	WAITMOUSE	; met le sablier	LOAD.L	A3,A2	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP',EQ OPEN$		; ok => OPEN$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	EXIT$		; non => EXIT$				; oui =>	LOAD.L	D3,(A6)+OSWCOM	TEST.L	D3:#'B-'A	; XCAR/B ?	JUMP',BS DELETE$	; oui => DELETE$	CALL	NORMMOUSE	; remet la flche	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE EXIT$	COMP.W	D3,#'O	JUMP,NE EXIT$DELETE$:	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE EXIT$	JUMP	CREATE$OPEN$:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE EXIT$	LOAD.L	A4,A5	LOAD.W	D5,(A4)+OGCMSB	MUL.WU	D5,#128	ADD.L	D5,#OGCWID+(128*3) ; D5 <-- lg du gencar (sans l'en-tte binaire)	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.B	(A4)+OBXTYP,#2	LOAD.L	(A4)+OBXLG,D5	LOAD.L	D4,#256	FOS	?WRBYTE		; crit l'en-tte binaire	JUMP',NE ERR$	LOAD.L	A4,A5	LOAD.L	D4,D5	FOS	?WRBYTE		; crit le gencar	JUMP',NE ERR$	FOS	?CLOSE	JUMP'	EXIT$ERR$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	PUSH.W	D7	LOAD.L	A4,A5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire du gnrateur bitmap	POP.W	D7	JUMP,NE ERROR	JUMP	_LOOP;----------\\; CONVNEWGC >;----------/; Converti "fst" pour les "vieux" appels LOADGC/USEGC/KILLGC.; in	D0.B	fonte;	D1.B	style/chasse;	D2.B	taille; out	D0.B	fonte;	D1.L	style/chasse;	D2.B	taille; mod	D0.B, D1.L, D2.B, D7.WCONVNEWGC:	AND.L	D1,#H'000000FF	TEST.L	D0:#7		; gencar construit ?	JUMP',BC 90$		; non => 90$				; oui =>	SL.L	D1,#8	LOAD.B	D1,#'R		; D1 <-- style "Roman"	TEST.L	D1:#8+7	JUMP',BC 90$	TSET.L	D1:#7		; D1 <-- chasse "Fixe"90$:	RETDOIMAGE:	CLR.W	D0		; D0 <-- lecture nouvelle image	LOAD.L	A3,#(A6)+OBUFIM	CALL	DBOXEDITIM	; demande le nom ...	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ _LOOPDOIMAGEF:	CALL	LOADIMAGE	; A4/D4 <-- ^image/dimensions	JUMP',EQ 30$	PUSH.W	D7	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	DOIMAGE30$:	TEST.L	(A6)+OIFPT	JUMP',EQ 35$	PUSH.L	A4	LOAD.L	A4,(A6)+OIFPT	CALL	KILLIMAGE	; libre l'ancienne image	POP.L	A435$:	LOAD.L	(A6)+OIFPT,A4	LOAD.L	(A6)+OIFDIM,D4	TSET.B	(A6)+OFADEFI+3:#0 ; image visible !	LOAD.L	(A6)+OIFSLP,#POSNIL	LOAD.L	A3,#(A6)+OIFTAP	LOAD.W	D3,(A6)+OXCCAR	; D3 <-- caractre	SL.W	D3,#2	LOAD.L	(A6)+OIFSPO,(A3)+(D3.W)	TEST.W	D0		; lecture nouvelle image ?	JUMP',NE 50$		; non => 50$	SR.W	D4,#1	SWAP.W	D4	SR.W	D4,#1	SWAP.W	D4	LOAD.L	(A6)+OIFSPO,D4	LOAD.L	A4,#(A6)+OIFTAP	LOAD.W	D4,#xcNBCAR-140$:	LOAD.L	(A4+),#POSNIL	DECJ.W,NMO D4,40$50$:	CALL	DESCAR		; redessine le caractre	JUMP	_LOOPDOPRENDDF:	LOAD.L	A3,#(A6)+OBUFDF	CALL	DBOXEDITIDF	; demande le nom ...	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ _LOOP	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',EQ 30$20$:	PUSH.W	D7	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	DOPRENDDF30$:	LOAD.L	A4,#(A6)+OIODDF	LOAD.L	D4,#OIOFDF-OIODDF	FOS	?RDBYTE		; lit les dfinitions	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	JUMP,NE 20$	LOAD.W	D0,#1		; D0 <-- lecture image connue	LOAD.L	A3,#(A6)+OBUFIM	TEST.B	(A3)		; nom de l'image existe ?	JUMP,NE DOIMAGEF	; oui => DOIMAGEF	LOAD.L	(A6)+OIFSLP,#POSNIL	LOAD.L	(A6)+OIFSPO,#POSNIL	CALL	DESCAR		; redessine le caractre	JUMP	_LOOPDOSAUVEDF:	LOAD.L	A3,#(A6)+OBUFDF	CALL	DBOXEDITODF	; demande le nom ...	JUMP,NE ERROR	COMP.W	D3,#F0	JUMP,EQ _LOOP	CALL	WAITMOUSE	; met le sablier20$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP,EQ 50$		; ok => 50$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	45$		; non => 45$				; oui =>	CALL	NORMMOUSE	; remet la flche	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE 45$	COMP.W	D3,#'O	JUMP,NE DOSAUVEDF40$:	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,EQ 20$45$:	PUSH.W	D7	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	DOSAUVEDF50$:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE 45$	LOAD.L	A4,#(A6)+OIODDF	LOAD.L	D4,#OIOFDF-OIODDF	FOS	?WRBYTE		; crit toutes les dfinitions	JUMP',NE 60$	FOS	?CLOSE	JUMP'	65$60$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D765$:	TEST.W	D7	JUMP,NE 45$	JUMP	_LOOP;--------\\; SAVFILE >;========/; Sauve un nom de fichier dans OBUNAME.; in	A3.L	^nom; out	-; mod	D7.WSAVFILE:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBUNAME10$:	LOAD.B	(A4+),(A3+)	; OBUNAME <-- nom	JUMP',EQ 90$	COMP.B	(A4)-1,#CR	JUMP,NE 10$	CLR.B	(A4)-190$:	POPM.L	A3,A4	RET;--------\\; GETFILE >;========/; Prend le nom de fichier dans OBUNAME.; in	A3.L	^buffer; out	-; mod	D7.WGETFILE:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBUNAME10$:	LOAD.B	(A3+),(A4+)	; buffer <-- OBUNAME	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 10$	CLR.B	(A3)-190$:	POPM.L	A3,A4	RET;--------\\; AFFFILE >;========/; Affiche un nom de fichier en minuscules et entre guillemets.; in	A3.L	^nom; out	-; mod	D7.WAFFFILE:	PUSHM.L	D2,D3,A3	LOAD.B	D3,#'"	LIB	?AFCAR	LOAD.W	D2,#2^BAFXMI	; D2 <-- en minuscules	LOAD.W	D3,#-1		; D3 <-- pas de maximum	LIB	?AFXFILE	LOAD.B	D3,#'"	LIB	?AFCAR	POPM.L	D2,D3,A3	RET;--------\\; ADDEXT  >;========/; Transfert le nom de fichier dans OBXFILE et force une extension.; in	A3.L	^nom sans extension;	A4.L	^extension  ajouter; out	A3.L	^nom avec extension (dans OBXFILE); mod	D7.W, A3.LADDEXT:	PUSHM.L	D3,A1,A2	LOAD.L	A2,A3	CALL	SKIPREP		; A3 <-- saute rep(s):	LOAD.L	A1,#(A6)+OBXFILE20$:	COMP.L	A2,A3	JUMP',EQ 22$	LOAD.B	(A1+),(A2+)	; OBXFILE <-- "rep(s):"	JUMP	20$22$:	LOAD.B	D3,(A3)+0	LIB	?MINMAJ	COMP.B	D3,#'A	JUMP,LO 50$	COMP.B	D3,#'Z	JUMP,HI 50$	LOAD.B	D3,(A3)+1	LIB	?MINMAJ	COMP.B	D3,#'A	JUMP,LO 50$	COMP.B	D3,#'Z	JUMP,HI 50$	LOAD.B	D3,(A3)+2	JUMP',EQ 32$	COMP.B	D3,#'.	JUMP',EQ 32$	LIB	?MINMAJ	COMP.B	D3,#'P	JUMP',EQ 30$	COMP.B	D3,#'F	JUMP,NE 50$30$:	LOAD.B	D3,(A3)+3	JUMP',EQ 32$	COMP.B	D3,#'.	JUMP',EQ 32$	COMP.B	D3,#'0	JUMP,NE 50$	COMP.B	(A3)+4,#'0	JUMP,NE 50$	LOAD.B	D3,(A3)+5	JUMP',EQ 32$	COMP.B	D3,#'.	JUMP,NE 50$32$:	LOAD.B	(A1+),#'S	LOAD.B	(A1+),#'M	LOAD.B	(A1+),#'A	LOAD.B	(A1+),#'_	; OBXFILE <-- "SMA_"	LOAD.B	(A1+),(A3+)	; OBXFILE <-- fonte	LOAD.B	(A1+),(A3+)	; OBXFILE <-- style	LOAD.B	(A1+),(A3+)	; OBXFILE <-- chasse	LOAD.B	D3,(A1)-1	JUMP',EQ 34$	COMP.B	D3,#'.	JUMP',NE 35$34$:	LOAD.B	(A1)-1,#'P35$:	LOAD.B	(A1+),#'0	LOAD.B	(A1+),#'0	CLR.B	(A1)	JUMP'	80$50$:	LOAD.B	(A1+),(A3+)	; OBXFILE <-- nom tel quel	JUMP,NE 50$80$:	LOAD.L	A3,#(A6)+OBXFILE	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	POPM.L	D3,A1,A2	RET;--------\\; SKIPREP >;========/; Saute tous les noms d'units et de rpertoires devant; un nom de fichier.; in	A3.L	^unit:rp:rp:nom.ext; out	A3.L	^nom.ext; mod	A3.LSKIPREP:	PUSH.W	D3	CLR.W	D310$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE 10$20$:	DEC.W	D3	JUMP',NS 90$	COMP.B	(-A3),#':	JUMP,NE 20$	INC.L	A390$:	POP.W	D3	RET	.END