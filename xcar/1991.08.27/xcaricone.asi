	.SBTTL	XCARICONE.ASI;---------\\; MAJICONE >;=========/; Met  jour les icnes variables.; in	-; out	-; mod	D7.WMAJICONE:	PUSHM.L	D3	COMP.W	(A6)+OXICO,#NIVMOVE	JUMP',EQ MOVE$	COMP.W	(A6)+OXICO,#NIVPOLY	JUMP',EQ POLY$	CALL	MAJCODE		; montre le caractre en dition	LOAD.B	D3,(A6)+OOUTIL	CALL	INVICONE	; allume l'icne de mode	LOAD.B	D3,(A6)+ODEPL	CALL	INVICONE	; allume l'icne de dplacement	LOAD.B	D3,(A6)+OVISU	CALL	INVICONE	; allume l'icne de visualisation	JUMP'	EXIT$MOVE$:	LOAD.B	D3,(A6)+ODEPL	CALL	INVICONE	; allume l'icne de dplacement	LOAD.B	D3,(A6)+ODEPLP	CALL	INVICONE	; allume l'icne de dplacement	JUMP'	EXIT$POLY$:	LOAD.B	D3,(A6)+ODEPL	CALL	INVICONE	; allume l'icne de dplacement	LOAD.B	D3,(A6)+OPOLY	CALL	INVICONE	; allume l'icne de cration	LOAD.B	D3,#ICOOPEN	TEST.B	(A6)+OPOOPE	JUMP',NE POLY2$	LOAD.B	D3,#ICOCLOSEPOLY2$:	CALL	INVICONE	; allume l'icne ouvert/ferm;	JUMP'	EXIT$EXIT$:	POPM.L	D3	RET;--------\\; MAJCODE >;--------/; Montre le caractre en dition.; in	-; out	-; mod	D7.WMAJCODE:	PUSHM.L	D2..D4,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.W	D2,(A6)+OXCCAR	CALL	IPPOS		; D3/D4 <-- position/dimensions	INC.W	D3	SWAP.W	D3	INC.W	D3;	SWAP.W	D3	LOAD.L	(A3)+1,D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4;	SWAP.W	D4	LOAD.L	(A3)+21,D4	LOAD.L	(A3)+5,(A6)+OIPPT	LOAD.W	D3,(A6)+OIPDIM+2	SR.W	D3,#3	LOAD.W	(A3)+9,D3	LOAD.B	D3,#ICOCSHOW	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP',NE 90$	ADD.W	D4,#7	SWAP.W	D4	ADD.W	D4,#4;	SWAP.W	D4	LOAD.L	(A3)+11,D4	CLR.L	(A3)+15	CLR.W	(A3)+19	LOAD.B	(A3)+25,#LOADDOT	LOAD.W	D3,#26	LIB	?STRING		; affiche le caractre90$:	POPM.L	D2..D4,A3	RET;---------\\; DPLICONE >;=========/; Dplace ventuellement toutes les icnes de gauche.; in	D4.L	position de la souris (y;x); out	D7.W	ok/erreur; mod	D7.WDPLICONE:	PUSHM.L	D2..D4	LOAD.W	D7,#1	COMP.W	D4,#MARGX+ICOLX	; trop  droite ?	JUMP,HS 90$	CLR.W	D2		; D2 <-- nb de dplacements10$:	SWAP.W	D4	SUB.W	D4,#ICOLY/2	; D4 <-- la souris montre le milieu	LOAD.W	D3,#340-ICOLY	; D3 <-- minimum (340 = hauteur wdo SM100)	COMP.W	D4,D3		; trop haut ?	JUMP',GE 20$	LOAD.W	D4,D320$:	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,#ICOLY	; D3 <-- maximum	COMP.W	D4,D3		; trop bas ?	JUMP',LE 22$	LOAD.W	D4,D322$:	AND.B	D4,#B'11111110	; D4 <-- doit tre pair	COMP.W	D4,(A6)+ODICO+0	; nouvelle position ?	JUMP',EQ 40$		; non => 40$				; oui =>	JUMP',HI 30$	PUSH.W	D4	LOAD.W	D3,D4	ADD.W	D3,#ICOLY	SUB.W	D4,(A6)+ODICO+0	NEG.W	D4	CALL	CLRICONE	; efface la partie dcouverte en bas	POP.W	D4	JUMP'	35$30$:	PUSH.W	D4	LOAD.W	D3,(A6)+ODICO+0	SUB.W	D4,(A6)+ODICO+0	CALL	CLRICONE	; efface la partie dcouverte en haut	POP.W	D435$:	LOAD.W	(A6)+ODICO+0,D4	CALL	REQICONE	; remet rapidement les icnes	INC.W	D2		; D2 <-- un dplacement de plus40$:	CALL	WAITMOVE	; attend dplacement souris ...	JUMP',NE 50$		; fin du dplacement => 50$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 40$	JUMP	10$50$:	TEST.W	D2		; y a-t-il eu des dplacements	JUMP',EQ 80$		; non => 80$	CALL	MAJICONE	; mj. les icnes variables80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MEMICONE >;=========/; Mmorise toutes les icnes dessines  gauche.; in	-; out	D7.W	erreur; mod	D7.WMEMICONE:	PUSHM.L	D1..D6,A1..A4	CLR.W	D7	TEST.L	(A6)+OPICO	; icnes dj mmorises ?	JUMP,NE 90$		; oui => 90$	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE 90$		; oui => 90$ (ne mmorise jamais)	LOAD.L	D4,#ICOLY*(ICOLX/8)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour icnes	JUMP,NE 90$	LOAD.L	(A6)+OPICO,A4	LOAD.L	A3,#0		; A3 <-- ^source (dans l'cran)	LOAD.L	D3,(A6)+ODICO	SUB.W	D3,#GCIMX+6	SWAP.W	D3	SUB.W	D3,#GCIMY+5	SWAP.W	D3;	LOAD.L	A4,A4		; A4 <-- ^destination	CLR.L	D4	LOAD.W	D6,#ICOLX/8	LOAD.L	D2,#H'10000*ICOLY+ICOLX	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0		; A2 <-- ^descripteur WDO	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; appel GRA_RASTER	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; REMICONE >;=========/; Remet toutes les icnes dessines  gauche.; in	-; out	-; mod	D7.WREMICONE:	CALL	REQICONE	; remet toutes les icnes	CALL	MAJICONE	; mj. les icnes variables	RET;---------\\; REQICONE >;=========/; Remet toutes les icnes dessines  gauche, rapidement,; c'est--dire sans mettre  jour les icnes.; in	-; out	-; mod	D7.WREQICONE:	PUSHM.L	D1..D6,A1..A4	TEST.L	(A6)+OPICO	; icnes mmorises ?	JUMP,EQ 60$		; non => 60$	CALL	CCMO		; enlve la souris	LOAD.L	A3,(A6)+OPICO	; A3 <-- ^source	CLR.L	D3	LOAD.W	D5,#ICOLX/8	LOAD.L	A4,#0		; A4 <-- ^destination (dans cran)	LOAD.L	D4,(A6)+ODICO	SUB.W	D4,#GCIMX+6	SWAP.W	D4	SUB.W	D4,#GCIMY+5	SWAP.W	D4	LOAD.L	D2,#H'10000*ICOLY+ICOLX	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0		; A2 <-- ^descripteur WDO	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; appel GRA_RASTER	CALL	SCMO		; remet la souris	LOAD.L	A4,#(A6)+OTICO	LOAD.W	D4,#(256/8/4)-140$:	CLR.L	(A4+)		; OTICO <-- plus d'icnes grises	DECJ.W,NMO D4,40$	JUMP'	90$60$:	CALL	DESICONE	; dessine normalement90$:	POPM.L	D1..D6,A1..A4	RET;---------\\; DESICONE >;=========/; Dessine une liste d'icnes en colonne.; in	-; out	-; mod	D7.WDESICONE:	PUSHM.L	D0..D4,A3	LOAD.W	D3,(A6)+ODICO+0	LOAD.W	D4,#ICOLY	CALL	CLRICONE	; efface toutes les icnes	LOAD.W	D0,#OPICODES	; D0 <-- dessine	LIB	?BUCAR	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE	LIB	?NOBUCAR90$:	POPM.L	D0..D4,A3	RET;---------\\; CLRICONE >;---------/; Efface toutes les icnes de gauche.; in	D3.W	origine (y);	D4.W	hauteur (dy); out	-; mod	D7.WCLRICONE:	PUSHM.L	D2..D4	LOAD.W	D2,D4	LOAD.L	D4,#H'88228822	; D4 <-- trame pour joli cran	CALL	DRMDEF	LOAD.W	D4,D2	SUB.W	D3,#GCIMY+5	SWAP.W	D3	LOAD.W	D3,(A6)+ODICO+2	SUB.W	D3,#GCIMX+6	SWAP.W	D4	LOAD.W	D4,#ICOLX	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise toutes les icnes ..	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; .. grise toutes les icnes	POPM.L	D2..D4	RET;---------\\; MOVICONE >;=========/; Dplace une icne tant que le bouton est press.; in	D4.L	position de la souris (y;x); out	D3.B	icne o est la souris;	D7.W	ok/erreur; mod	D3.L, D7.WMOVICONE:	PUSHM.L	D4,D5	CALL	DETICONE	; souris dans une icne ?	JUMP,NE 90$		; non => 90$	LOAD.B	D5,D3	JUMP'	30$20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 50$		; non => 50$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 20$	CALL	DETICONE	; D3 <-- icne o est la souris	JUMP,NE 20$	COMP.B	D3,D5	JUMP,EQ 20$	EX.L	D3,D5	CALL	INVALLICONE	; teint l'ancienne icne30$:	LOAD.B	D3,D5	CALL	INVALLICONE	; allume la nouvelle icne	JUMP	20$50$:	LOAD.B	D3,D5	CALL	INVALLICONE	; teint l'ancienne icne	CALL	XXXONETEST	; icne grise ?	JUMP',BC 80$		; non => 80$	CLR.B	D380$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DETICONE >;=========/; Dtecte dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D3.B	icne o est la souris;	D7.W	ok/erreur; mod	D3.L, D7.WDETICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICODET	; D0 <-- dtecte	LOAD.L	D5,D4		; D5 <-- position de la souris (y;x)	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE	JUMP',NE 90$	LOAD.B	D3,D5		; D3 <-- code de l'icne90$:	POPM.L	D0,D5,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; INVICONE >;=========/; Inverse une icne.; in	D3.B	icne  inverser; out	-; mod	D7.WINVICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICOINV	; D0 <-- inverse	LOAD.B	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE90$:	POPM.L	D0,D5,A3	RET;------------\\; INVALLICONE >;============/; Inverse toute une icne.; in	D3.B	icne  inverser; out	-; mod	D7.WINVALLICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICOINVALL	; D0 <-- inverse	LOAD.B	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE90$:	POPM.L	D0,D5,A3	RET;---------\\; POSICONE >;=========/; Donne la position d'une icne.; in	D3.B	icne; out	D4.L	position coin sup/gauche (y;x);	D7.W	erreur; mod	D7.WPOSICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICOPOS	; D0 <-- position	LOAD.B	D5,D3		; D5 <-- code de l'icne	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE	JUMP',NE 90$50$:	LOAD.L	D4,D5		; D4 <-- position90$:	POPM.L	D0,D5,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; GREYICONE >;==========/; Grise ou dgrise une icne.; in	D3.B	icne  (d)griser;	D7.W	EQ => dgrise;		NE => grise; out	-; mod	-GREYICONE:	PUSHM.L	D0,D5,D7,A3	LOAD.B	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	TEST.W	D7	JUMP',NE 20$	CALL	XXXONETEST	; est-ce dj plein ?	JUMP',BC 90$		; oui => 90$	LOAD.W	D0,#OPICOFULL	; D0 <-- dgrise	JUMP'	30$20$:	CALL	XXXONETEST	; est-ce dj gris ?	JUMP',BS 90$		; oui => 90$	LOAD.W	D0,#OPICOGREY	; D0 <-- grise30$:	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE90$:	POPM.L	D0,D5,D7,A3	RET;---------\\; PTGICONE >;---------/; Donne le pointeur aux icnes de gauche.; in	-; out	A3.L	^icnes de gauche; mod	A3.LPTGICONE:	LOAD.L	A3,#R16"TICOMOVE	COMP.W	(A6)+OXICO,#NIVMOVE	JUMP',EQ 90$	LOAD.L	A3,#R16"TICOPOLY	COMP.W	(A6)+OXICO,#NIVPOLY	JUMP',EQ 90$	LOAD.L	A3,#R16"TICOGAUCHE90$:	RET;---------\\; XXXICONE >;---------/; Dessine une liste d'icnes en colonne.; in	A3.L	^liste;	D0.W	opration (OPICOxxx);	D5.L	position de la souris (si dtecte);	D5.B	code de l'icne (si inverse/position); out	D5.B	icne o est la souris (si dtecte);	D5.L	coordonne (si position);	D7.W	ok/erreur (si dtecte ou inverse); mod	D5.L, D7.WXXXICONE:	PUSHM.L	D1..D4,A3	LOAD.L	D4,(A6)+ODICO	LOAD.L	D3,D4	CLR.W	D2		; D2 <-- gencar du texte20$:	COMP.B	(A3),#IF	; fin de la table ?	JUMP,EQ 80$	COMP.B	(A3),#IL	; va  la ligne suivante ?	JUMP',EQ 40$	COMP.B	(A3),#IC	; va  la ligne suivante ?	JUMP',EQ 45$	COMP.W	D0,#OPICODET	JUMP',EQ 30$	COMP.W	D0,#OPICOINV	JUMP',EQ 35$	COMP.W	D0,#OPICOINVALL	JUMP',EQ 35$	COMP.W	D0,#OPICOPOS	JUMP',EQ 35$	COMP.W	D0,#OPICOGREY	JUMP',EQ 35$				; dessine/dgrise =>	LOAD.B	D1,#GCICT	TEST.B	(A3)+1	JUMP',NC 22$	INC.B	D122$:	COMP.B	D2,D1		; utilise toujours le mme gencar ?	JUMP',EQ 24$		; oui => 24$	LOAD.B	D2,D1	COMP.B	D2,#GCICT+1	JUMP',EQ 23$	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP'	24$23$:	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT+1	.B	0	.EVEN24$:	CALL	XXXONEICONE	; dessine une icne25$:	ADD.L	A3,#3	JUMP	20$30$:				; dtecte =>	CALL	XXXONEICONE	; dtecte si dans cette icne ?	JUMP,NE 25$		; non => 25$	LOAD.B	D5,(A3)+1	; D5 <-- code de l'icne	JUMP'	80$35$:				; inverse/position =>	CALL	XXXONEICONE	; inverse cette icne ?	JUMP,NE 25$		; non => 25$	JUMP'	80$40$:				; grand interligne =>	SWAP.W	D3	ADD.W	D3,#GCICY+GCIMY*2	SWAP.W	D3	LOAD.L	D4,D3	INC.L	A3	JUMP	20$45$:				; petit interligne =>	SWAP.W	D3	ADD.W	D3,#5		; aligne en bas sur Smaky 100 !	SWAP.W	D3	LOAD.L	D4,D3	INC.L	A3	JUMP	20$80$:	COMP.W	D0,#OPICODES	; dessine ?	JUMP',EQ 85$		; oui => 85$	COMP.W	D0,#OPICOFULL	; dgrise ?	JUMP',NE 90$		; non => 90$85$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN90$:	POPM.L	D1..D4,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; XXXONEICONE >;------------/; Dessine/dtecte/inverse une icne.; in	A3.L	^lment dans table;	D4.L	coordonne coin sup/gauche;	D0.W	opration (OPICOxxx);	D5.L	position de la souris (si dtecte);	D5.B	code de l'icne (si inverse/position/grise/dgrise); out	D4.L	coordonne suivante;	D5.L	coordonne coin (si position);	D7.W	ok/erreur (si dtecte ou inverse); mod	D4.L, D5.L, D7.WXXXONEICONE:	PUSHM.L	D1..D3	LOAD.L	D1,D4		; D1 <-- coin	LOAD.L	D3,D4	SUB.W	D3,#GCIMX	SWAP.W	D3	SUB.W	D3,#GCIMY	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SWAP.W	D4	LOAD.W	D4,#GCICX/2+GCIMX*2	COMP.B	(A3)+0,#ID	JUMP',NE 20$	ADD.W	D4,#GCICX/2+GCIMX*220$:	COMP.W	D0,#OPICODET	JUMP,EQ 40$	COMP.W	D0,#OPICOINV	JUMP,EQ 50$	COMP.W	D0,#OPICOINVALL	JUMP,EQ 50$	COMP.W	D0,#OPICOPOS	JUMP,EQ 60$	COMP.W	D0,#OPICOGREY	JUMP,EQ 70$	COMP.W	D0,#OPICOFULL	JUMP,EQ 75$22$:				; dessine =>	COMP.B	(A3)+1,#ICOVIDE	JUMP,EQ 80$	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	PUSH.L	D4	CLR.L	D4	CALL	DRMDEF	POP.L	D4	PUSHM.L	D3,D4	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour icne	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	LOAD.L	D3,D1		; D3 <-- coin	SUB.W	D3,#2	COMP.B	(A3)+0,#ID	JUMP',NE 30$	ADD.W	D3,#2+GCIMX30$:	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,(A3)+1	; D3 <-- code	AND.B	D3,#H'7F	LIB	?AFCODE	POPM.L	D3,D4	CALL	DESACTION	; dessine ventuellement une action	LOAD.B	D3,(A3)+1	; D3 <-- code de l'icne	CALL	XXXONEFULL	; signal icne pleine	JUMP	80$40$:				; dtecte =>	LOAD.W	D7,#ERDIOUT	LOAD.W	D2,D5	SUB.W	D2,D3		; souris trop  gauche ?	JUMP,LO 80$	COMP.W	D2,D4		; souris trop  droite ?	JUMP,HS 80$	SET.B	(A6)+OGICO	; on est  gauche	SR.W	D4,#1	COMP.W	D2,D4	JUMP',LO 42$	CLR.B	(A6)+OGICO	; on est  droite42$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	D2,D5	SWAP.W	D2	SUB.W	D2,D3		; souris trop en haut ?	JUMP,LO 80$	COMP.W	D2,D4		; souris trop en bas ?	JUMP,HS 80$	CLR.B	(A6)+OBICO	; on est en haut	SR.W	D4,#1	COMP.W	D2,D4	JUMP',LO 44$	SET.B	(A6)+OBICO	; on est en bas44$:	CLR.W	D7		; D7 <-- dans l'icone	JUMP	80$50$:				; inverse =>	LOAD.W	D7,#ERDIOUT	COMP.B	D5,(A3)+1	JUMP,NE 80$	PUSHM.L	D3,D4	LOAD.L	D4,#-1	LOAD.B	D3,(A3)+1	; D3 <-- code de l'icne	CALL	XXXONETEST	; icne grise ?	JUMP',BC 52$		; non => 52$;	LOAD.L	D4,#H'55AA55AA	; D4 <-- trame si gris	LOAD.L	D4,#H'00550055	; D4 <-- trame pour inverser52$:	CALL	DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#1	COMP.W	D0,#OPICOINVALL	JUMP',EQ 53$	INC.W	D253$:	ADD.W	D3,D2	SWAP.W	D3	ADD.W	D3,D2	SWAP.W	D3	SUB.W	D4,D2	SUB.W	D4,D2	SWAP.W	D4	SUB.W	D4,D2	SUB.W	D4,D2	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	CLR.W	D7	JUMP	80$60$:				; position =>	LOAD.W	D7,#ERDIOUT	COMP.B	D5,(A3)+1	JUMP,NE 80$	LOAD.L	D5,D3		; D5 <-- position	CLR.W	D7	JUMP	80$70$:				; grise =>	LOAD.W	D7,#ERDIOUT	COMP.B	D5,(A3)+1	JUMP,NE 80$	PUSH.L	D4	LOAD.L	D4,#H'55AA55AA	CALL	DRMDEF	POP.L	D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; grise toute l'icne	LOAD.B	D3,(A3)+1	; D3 <-- code de l'icne	CALL	XXXONEGREY	; signal icne grise	CLR.W	D7	JUMP	80$75$:				; dgrise =>	LOAD.W	D7,#ERDIOUT	COMP.B	D5,(A3)+1	JUMP,EQ 22$;	JUMP	80$80$:	LOAD.L	D4,D1	ADD.W	D4,#GCICX/2+GCIMX*2	COMP.B	(A3)+0,#ID	JUMP',NE 90$	ADD.W	D4,#GCICX/2+GCIMX*290$:	POPM.L	D1..D3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; XXXONETEST >;-----------/; Regarde si une icne est pleine ou grise.; in	D3.B	code de l'icne; out	BC	plein;	BS	gris; mod	D7.WXXXONETEST:	PUSHM.L	D4,A4	CLR.W	D4	LOAD.B	D4,D3	LOAD.L	A4,#(A6)+OTICO	SR.W	D4,#3	TEST.B	(A4)+(D4.W):D3	POPM.L	D4,A4	RET;-----------\\; XXXONEFULL >;-----------/; Indique qu'une icne est pleine (non grise).; in	D3.B	code de l'icne; out	-; mod	D7.WXXXONEFULL:	PUSHM.L	D4,A4	CLR.W	D4	LOAD.B	D4,D3	LOAD.L	A4,#(A6)+OTICO	SR.W	D4,#3	TCLR.B	(A4)+(D4.W):D3	POPM.L	D4,A4	RET;-----------\\; XXXONEGREY >;-----------/; Indique qu'une icne est grise.; in	D3.B	code de l'icne; out	-; mod	D7.WXXXONEGREY:	PUSHM.L	D4,A4	CLR.W	D4	LOAD.B	D4,D3	LOAD.L	A4,#(A6)+OTICO	SR.W	D4,#3	TSET.B	(A4)+(D4.W):D3	POPM.L	D4,A4	RET;----------\\; DESACTION >;----------/; Dessine ventuellement une action.; in	A3.L	^ID/IS et code;	D3.L	origine rectangle;	D4.L	dimensions rectangle; out	-; mod	D7.WDESACTION:	PUSHM.L	D2..D4,A3,A4	LOAD.B	D2,(A3)+2	AND.B	D2,#H'F0	; D2 <-- type de l'icne	JUMP,EQ 90$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	A4,#R16"DIAL$	COMP.B	D2,#TDIAL	JUMP',EQ 20$	LOAD.L	A4,#R16"DOWN$	COMP.B	D2,#TDOWN	JUMP',EQ 20$	LOAD.L	A4,#R16"EFFET$;	COMP.B	D2,#TEFFET;	JUMP',EQ 20$20$:	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	ADD.W	D3,D4	SUB.W	D3,#8	LOAD.W	(A3)+1,D3	; <xx>	SWAP.W	D3	LOAD.W	(A3)+3,D3	; <yy>	LOAD.L	(A3)+5,A4	; <pppp>	LOAD.B	(A3)+9,#INVDOT	; <m>	LOAD.W	D3,#10	LIB	?STRING		; dessine le motif90$:	POPM.L	D2..D4,A3,A4	RETDIAL$:	.B	8,24	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00110110	.B	B'00110110	.B	B'00000000DOWN$:	.B	8,24	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00001000	.B	B'00001000	.B	B'00111110	.B	B'00011100	.B	B'00001000	.B	B'00000000EFFET$:	.B	8,24	.B	B'00111111	.B	B'00011111	.B	B'00011111	.B	B'00001111	.B	B'00001111	.B	B'00000111	.B	B'00000111	.B	B'00000011	.B	B'00000011	.B	B'00000001	.B	B'00000001	.B	B'00000000	.B	B'00000000	.B	B'00000001	.B	B'00000001	.B	B'00000011	.B	B'00000011	.B	B'00000111	.B	B'00000111	.B	B'00001111	.B	B'00001111	.B	B'00011111	.B	B'00011111	.B	B'00111111	.EVEN	.END