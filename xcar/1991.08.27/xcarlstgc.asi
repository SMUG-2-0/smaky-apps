	.SBTTL	XCARLSTGC.ASI;-----------\\; _XCAR_LIST >;===========/; Gestion de la liste des noms.; in	D7.W	sous-appel (xcLISTxxx);	?	selon sous-appel; out	?	selon sous-appel;	D7.W	erreur; mod	D7.W + ?_XCAR_LIST:	PUSH.L	A6	PUSH.W	D7	CALL	GETCOMMEM	; A6 <-- ^variables globales	POP.W	D7	COMP.W	D7,#xcLISTSRCNC	JUMP',EQ SRCNC$	COMP.W	D7,#xcLISTGETNB	JUMP',EQ GETNB$	COMP.W	D7,#xcLISTGETNL	JUMP',EQ GETNL$	COMP.W	D7,#xcLISTADD	JUMP',EQ ADD$	COMP.W	D7,#xcLISTREFAIT	JUMP',EQ REFAIT$	LOAD.W	D7,#1	JUMP'	EXIT$SRCNC$:	CALL	LISTSRCNC	JUMP'	EXIT$GETNB$:	CALL	LISTGETNB	JUMP'	EXIT$GETNL$:	CALL	LISTGETNL	JUMP'	EXIT$ADD$:	CALL	LISTADD	JUMP'	EXIT$REFAIT$:	CALL	LISTREFAIT;	JUMP'	EXIT$EXIT$:	POP.L	A6	TEST.W	D7		; retour EQ/NE	RET;----------\\; LISTSRCNC >;==========/; Cherche le nom compact d'aprs le nom complet.; in	A3.L	^nom complet; out	D4.L	"-fst" correspondant;	D3.W	rang (0..n);	D7.W	erreur; mod	D3.L, D4.L, D7.WLISTSRCNC:	PUSH.L	A4	CALL	LSTREAD		; lit le fichier si ncessaire	JUMP',NE EXIT$	LOAD.L	A4,(A6)+OVLPLI	; A4 <-- ^liste	LOAD.W	D4,(A6)+OVLNLI	; D4 <-- nb de noms contenus	JUMP',EQ ERROR$LOOP$:	CALL	LSTCOMP		; nom trouv ?	TEST.W	D7	JUMP',NE NEXT$		; non => NEXT$	LOAD.W	D3,(A6)+OVLNLI	SUB.W	D3,D4		; D3 <-- rang (0..n)	CLR.L	D4	LOAD.B	D4,(A4)+OLNFON	SL.L	D4,#8	LOAD.B	D4,(A4)+OLNSTY	SL.L	D4,#8		; D4 <-- "-fs-"	JUMP'	EXIT$NEXT$:	LOAD.L	A4,#(A4)+LLN	; A4 <-- ^suivant	DEC.W	D4	JUMP,NE LOOP$ERROR$:	LOAD.W	D7,#1		; D7 <-- pas trouvEXIT$:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: remet la flche	POPM.L	D4,D7	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; LISTGETNB >;==========/; Donne le nombre de noms connus dans la liste.; in	-; out	D3.W	nb de noms connus; mod	D3.L, D7.WLISTGETNB:	PUSH.L	D4	CALL	LSTREAD		; lit le fichier si ncessaire	JUMP',NE EXIT$	LOAD.W	D3,(A6)+OVLNLI	; D3 <-- nb de noms contenusEXIT$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: remet la flche	POP.W	D7	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; LISTGETNL >;==========/; Donne le nom complet d'aprs un rang.; in	D3.W	rang (0..n); out	A3.L	^nom complet correspondant;	D7.W	erreur; mod	D7.W, A3.LLISTGETNL:	PUSHM.L	D3,D4	CALL	LSTREAD		; lit le fichier si ncessaire	JUMP',NE EXIT$	LOAD.W	D7,#1	COMP.W	D3,(A6)+OVLNLI	JUMP',HS EXIT$	LOAD.L	A3,(A6)+OVLPLI	; A3 <-- ^liste	MUL.WU	D3,#LLN	ADD.L	A3,D3		; A3 <-- ^nom correspondant	CLR.W	D7		; D7 <-- okEXIT$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: remet la flche	POP.W	D7	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; LISTREFAIT >;===========/; Refait compltement la liste d'aprs le contenu du disque.; in	-; out	D7.W	erreur; mod	D7.WLISTREFAIT:	PUSHM.L	D1,D3..D6,A1,A3,A4	TEST.L	(A6)+OVLPLI	JUMP',EQ FREE$	LOAD.L	A4,(A6)+OVLPLI	; A4 <-- ^liste	LOAD.L	A1,(A6)+OVLCTM	LOAD.W	D1,#MTYPUSER	GESMEM	?GIVMEM		; libre l'ancienne liste	CLR.L	(A6)+OVLPLIFREE$:	LOAD.L	D4,#LLN		; D4 <-- longueur du texte	LOAD.L	A1,(A6)+OVLCTM	LOAD.W	D1,#MTYPUSER	GESMEM	?GETMEM		; demande mmoire pour fichier .INFO	JUMP',NE EXIT$	LOAD.L	(A6)+OVLPLI,A4	CLR.W	(A6)+OVLNLI	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#R16"DIR$	LOAD.L	A4,#R16"CRIT$	LOAD.L	D3,#2^BOPSYS	FOS	?LISTOPEN	JUMP',NE EXIT$LOOP$:	FOS	?LISTNXT	; A3/A4 <-- ^nom/^arguments	JUMP',NE END$	ADD.L	A3,#4		; A3 <-- saute "SMA_"	LIB	?SYNGC		; D3/D4/D5 <-- f/s/t	AND.L	D3,#H'FF	SL.L	D3,#8	LOAD.B	D3,D4	SL.L	D3,#8	LOAD.B	D3,D5		; D3 <-- "-fst"	CALL	LSTADD		; liste <-- un nouveau nom	JUMP,EQ LOOP$END$:	PUSH.W	D7	FOS	?LISTCLOSE	POP.W	D7	COMP.W	D7,#EROUTF	JUMP',NE EXIT$	CALL	LSTWRITE	; crit le fichier .INFO sur disqueEXIT$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: remet la flche	POP.W	D7	POPM.L	D1,D3..D6,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RETDIR$:	.ASCIZ	"#:"CRIT$:	.ASCIZ	"SMA_???00.GENC"	.EVEN;--------\\; LISTADD >;========/; Ajoute si ncessaire un nom dans la liste.; in	D3.L	gencar  ajouter "-fst"; out	D7.W	erreur; mod	D7.WLISTADD:	PUSH.L	D4	CALL	LSTREAD		; lit le fichier si ncessaire	JUMP',NE EXIT$	CALL	LSTADD		; ajoute dans la liste	JUMP',NE EXIT$	CALL	LSTWRITE	; crit le fichier .INFO sur disqueEXIT$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: remet la flche	POP.W	D7	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; LSTADD >;-------/; Ajoute si ncessaire un nom dans la liste.; in	D3.L	gencar  ajouter "-fst"; out	D7.W	erreur; mod	D7.WLSTADD:	PUSHM.L	D1..D4,A1..A5	LOAD.L	A4,#(A6)+OVLBUF	CALL	LSTRDNAME	; lit le nom complet	LOAD.L	A3,A4		; A3 <-- ^nom complet	LOAD.W	D4,(A6)+OVLNLI	; D4 <-- nb de noms contenus	INC.W	D4	MUL.WU	D4,#LLN	LOAD.L	A1,(A6)+OVLCTM	LOAD.W	D1,#MTYPUSER	GESMEM	?GETMEM		; demande mmoire pour nouvelle liste	JUMP,NE EXIT$	LOAD.L	A5,A4	LOAD.L	A2,A4	LOAD.L	A4,(A6)+OVLPLI	; A4 <-- ^liste	LOAD.W	D4,(A6)+OVLNLI	; D4 <-- nb de noms contenus	JUMP',EQ ADD$SRC$:	CALL	LSTCOMP		; faut-il insrer ici ?	TEST.W	D7	JUMP,EQ EXIT$	COMP.W	D7,#1	JUMP',EQ ADD$	LOAD.W	D2,#(LLN/2)-1XFER2$:	LOAD.W	(A2+),(A4+)	; nouvelle liste <-- un nom de l'ancienne	DECJ.W,NMO D2,XFER2$	DEC.W	D4	JUMP,NE SRC$ADD$:	LOAD.L	A1,A2	LOAD.W	D2,#(LLN/2)-1ADD1$:	CLR.W	(A1+)	DECJ.W,NMO D2,ADD1$	LOAD.L	A1,A2ADD2$:	LOAD.B	(A1+),(A3+)	; nouvelle liste <-- nouveau nom	JUMP,NE ADD2$	SWAP.W	D3	LOAD.B	(A2)+OLNFON,D3	; nouvelle liste <-- fonte	RL.L	D3,#8	LOAD.B	(A2)+OLNSTY,D3	; nouvelle liste <-- style	LOAD.L	A2,#(A2)+LLN	INC.W	(A6)+OVLNLI	; OVLNLI <-- un nom de plusEND$:	DEC.W	D4	JUMP',NS END4$	LOAD.W	D2,#(LLN/2)-1XFER4$:	LOAD.W	(A2+),(A4+)	; nouvelle liste <-- un nom de l'ancienne	DECJ.W,NMO D2,XFER4$	JUMP	END$END4$:	LOAD.L	A4,(A6)+OVLPLI	; A4 <-- ^liste	LOAD.L	A1,(A6)+OVLCTM	LOAD.W	D1,#MTYPUSER	GESMEM	?GIVMEM		; libre l'ancienne liste	LOAD.L	(A6)+OVLPLI,A5	; remplace par la nouvelleEXIT$:	POPM.L	D1..D4,A1..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; LSTRDNAME >;----------/; Cherche le nom d'un gencar en lisant son en-tte sur disque.; in	D3.L	gencar (-fst);	A4.L	^buffer pour nom; out	(A4)++	nom complet; mod	D7.WLSTRDNAME:	PUSHM.L	D2..D4,D6,A3,A4	SUB.L	SP,#16	LOAD.L	D2,D3		; D2 <-- gencar (-fst)	LOAD.L	A3,SP		; A3 <-- ^buffer sur le stack	LOAD.B	(A3+),#'S	LOAD.B	(A3+),#'M	LOAD.B	(A3+),#'A	LOAD.B	(A3+),#'_	LOAD.L	D4,D3	SWAP.W	D4	AND.B	D4,#H'7F	LOAD.B	(A3+),D4	; buffer <-- fonte	LOAD.W	D4,D3	SR.W	D4,#8	AND.B	D4,#H'7F	LOAD.B	(A3+),D4	; buffer <-- style	LOAD.B	(A3+),#'P	; buffer <-- chasse	TEST.L	D3:#8+7	JUMP',BC PROP$	LOAD.B	(A3)-1,#'FPROP$:	CLR.L	D4	LOAD.B	D4,D3	DIV.WU	D4,#10	ADD.B	D4,#'0	LOAD.B	(A3+),D4	; buffer <-- dizaine taille	SWAP.W	D4	ADD.B	D4,#'0	LOAD.B	(A3+),D4	; buffer <-- unit taille	LOAD.B	(A3+),#'.	LOAD.B	(A3+),#'G	LOAD.B	(A3+),#'E	LOAD.B	(A3+),#'N	LOAD.B	(A3+),#'C	CLR.B	(A3)	LOAD.L	A3,SP	LOAD.W	D3,#2^BOPRD!2^BOPSYS	FOS	?OPEN		; ouvre le fichier gencar	JUMP',NE READ4$	CLR.W	D3	LOAD.L	D4,#256+OGCCNM	FOS	?SPOS		; va au dbut du nom	JUMP',NE READ3$	LOAD.L	D4,#32	FOS	?RDBYTE		; lit le nom du gencarREAD3$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier gencar	POP.W	D7READ4$:	TEST.W	D7		; lecture du gencar ok ?	JUMP',NE FS$		; non => FS$	TEST.B	(A4)		; nom existe ?	JUMP',EQ FS$		; non => FS$	COMP.B	(A3)+6,#'F	; chasse fixe ?	JUMP',NE EXIT$		; non => EXIT$	CLR.B	D4FIX2$:	LOAD.B	D3,(A4+)	JUMP',EQ FIX3$	COMP.B	D3,#'_	JUMP,NE FIX2$	INC.B	D4	JUMP	FIX2$FIX3$:	DEC.L	A4	TEST.B	D4	JUMP',NE FIX4$	LOAD.B	(A4+),#'_	; nom <-- ajoute "_"FIX4$:	LOAD.B	(A4+),#'F	; nom <-- ajoute "F"	CLR.B	(A4)	JUMP'	EXIT$FS$:	LOAD.B	(A4+),(A3)+4	; nom <-- fonte	LOAD.B	(A4+),(A3)+5	; nom <-- style	LOAD.B	(A4+),(A3)+6	; nom <-- chasse	CLR.B	(A4)EXIT$:	ADD.L	SP,#16	POPM.L	D2..D4,D6,A3,A4	RET;--------\\; LSTCOMP >;--------/; Compare deux noms de fichiers.; in	A3.L	^premier nom;	A4.L	^deuxime nom; out	D7.W	1 => LO;		0 => EQ;		2 => HI; mod	D7.WLSTCOMP:	PUSHM.L	D3,A3,A4LOOP$:	LOAD.B	D3,(A3+)	COMP.B	D3,(A4+)	JUMP',LO LO$	JUMP',HI HI$	TEST.B	D3	JUMP',NE LOOP$EQ$:	CLR.W	D7		; D7 <-- EQ	JUMP'	EXIT$LO$:	LOAD.W	D7,#1		; D7 <-- LO	JUMP'	EXIT$HI$:	LOAD.W	D7,#2		; D7 <-- HI;	JUMP'	EXIT$EXIT$:	POPM.L	D3,A3,A4	RET;--------\\; LSTREAD >;========/; Lit sur disque le fichier .INFO.; in	-; out	D7.W	erreur; mod	D7.WLSTREAD:	PUSHM.L	D1,D3,D4,D6,A1,A3,A4	CLR.W	D7	TEST.L	(A6)+OVLPLI	; fichier dj lu ?	JUMP,NE EXIT$		; oui => EXIT$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#R16"FLNAME	LOAD.W	D3,#2^BOPRD!2^BOPSYS	FOS	?OPEN		; ouvre le fichier .INFO	JUMP',EQ EXIST$	COMP.W	D7,#ERFDNE	JUMP',NE EXIT$	CALL	LISTREFAIT	; tente de refaire la liste	JUMP'	EXIT$EXIST$:	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; va  la fin	LOAD.L	D1,D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	LOAD.L	D4,D1		; D4 <-- longueur du texte	LOAD.L	A1,(A6)+OVLCTM	LOAD.W	D1,#MTYPUSER	GESMEM	?GETMEM		; demande mmoire pour fichier .INFO	JUMP',NE CLOSE$	LOAD.L	(A6)+OVLPLI,A4	LOAD.L	D3,D4	DIV.WU	D3,#LLN	LOAD.W	(A6)+OVLNLI,D3	FOS	?RDBYTE		; lit le fichier .INFOCLOSE$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	POPM.L	D1,D3,D4,D6,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; LSTWRITE >;=========/; Ecrit sur disque le fichier .INFO.; in	-; out	D7.W	erreur; mod	D7.WLSTWRITE:	PUSHM.L	D3,D4,D6,A3,A4	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#R16"FLNAME	FOS	?DELETE		; dtruit le fichier .INFO	LOAD.L	D3,#DEFATT-2^BATTL	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier .INFO	JUMP',NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL!2^BOPSYS	FOS	?OPEN		; ouvre le fichier .INFO	JUMP',NE EXIT$	LOAD.L	A4,(A6)+OVLPLI	LOAD.W	D4,(A6)+OVLNLI	MUL.WU	D4,#LLN	FOS	?WRBYTE		; crit le fichier .INFO	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	COMP.W	D7,#ERMWPR	; disquette protge en criture ?	JUMP',NE QUIT$		; non => QUIT$	CLR.W	D7		; D7 <-- okQUIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; GETCOMMEM >;----------/; Donne les variables globales.; in	-; out	A6.L	^mmoire commune; mod	D7.W, A6.LGETCOMMEM:	LOAD.L	A6,#R16"VL	; A6 <-- ^variables globales	TEST.L	(A6)+OVLCTM	; compte mmoire existe ?	JUMP',NE EXIT$		; oui => EXIT$	PUSHM.L	D1,A2,A3	LOAD.L	A3,#R16"NAME$	LOAD.W	D1,#MTYPSYS	GESMEM	?CREMCPT	; cre un nouveau compte mmoire	LOAD.L	(A6)+OVLCTM,A2	POPM.L	D1,A2,A3EXIT$:	CLR.W	D7		; retour EQ	RETNAME$:	.ASCIZ	"XCAR"	.EVENVL:	.FILLB	LVL,0		; variables globales dans le code !!!FLNAME:	.ASCIZ	"#:SMA_XCAR.INFO"	.EVEN	.END