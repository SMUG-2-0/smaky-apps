	.SBTTL	XCARMISC.ASI;-------\\; FIXMUL >;=======/; Multiplication de deux nombres rels (16 bits entier et 16 bits fraction).; in	D1.L	premier nombre rel;	D2.L	deuxime nombre rel; out	D0.L	rsultat rel;	VS	si dpassement de capacit (dans ce cas D0=max ou min selon signes); mod	D0.LFIXMUL:	PUSHM.L	D1,D2,D4,D5,D6	CALL	TOPOSITIF	LOAD.L	D4,#H'00010000	COMP.L	D1,D4		; D1 = 1.0 ?	JUMP',NE DIFF0$		; non => D2 = 1.0 ?	LOAD.L	D1,D2	JUMP'	MUL10$DIFF0$:	COMP.L	D2,D4		; D2 = 1.0 ?	JUMP',NE DIFFZERO$MUL10$:	CLR.L	D0	CLR.L	D4	LOAD.W	D4,D1	SWAP.W	D4	SWAP.W	D1	LOAD.W	D0,D1		; (D0;D4) = rsultat	JUMP'	LONGTOFIX$DIFFZERO$:	LOAD.W	D4,D2	MUL.WU	D4,D1		; D4: D1.fract * D2.fract	SWAP.W	D2	LOAD.W	D5,D2	MUL.WU	D5,D1		; D5: D1.fract * D2.int	SWAP.W	D1	LOAD.W	D0,D2	MUL.WU	D0,D1		; D0: D1.int * D2.int	SWAP.W	D2	MUL.WU	D2,D1		; D2: D1.int * D2.fract	ADD.L	D2,D5		; mid	CLR.L	D5	LOAD.W	D5,D2	SWAP.W	D5		; mid * 2**16	LOAD.W	D2,D5		; #0	SWAP.W	D2	ADD.L	D4,D5		; + low	ADDX.L	D0,D2		; mid.31..W + high + carry				; (D0;D4): rsultatLONGTOFIX$:	SWAP.W	D0	TEST.W	D0		; high word <> 0 ?	JUMP',NE SETMAX$	; oui => met la val. maximum	SWAP.W	D4	LOAD.W	D0,D4		; low res. word	TEST.L	D4		; high bit reste = 0 ?	JUMP',PL NOTROUND$	INC.L	D0		; inc res.fract	JUMP',CS SETMAX$NOTROUND$:	TEST.L	D0		; bit de signe dj mis ?	JUMP',MI SETMAX$	; ==> dbordement !	TEST.B	D6		; (VC)	JUMP',EQ EXIT$	NEG.L	D0		; met rsultat ngatif selon D1 et D2.in (VC)	JUMP'	EXIT$SETMAX$:	LOAD.L	D0,#H'00000001	RR.L	D0,#1	TEST.B	D6	JUMP',NE OVER$	DEC.L	D0OVER$:	SETV			; met le bit overflowEXIT$:	POPM.L	D1,D2,D4,D5,D6	RET;----------\\; TOPOSITIF >;----------/; ; in	D1.L	nombre rel;	D2.L	nombre rel; out	D1.L	nombre rel positif;	D2.L	nombre rel positif;	D6.B	0 si rsultat positif; mod	D1.L, D2.L, D6.BTOPOSITIF:	CLR.B	D6	TEST.L	D1	JUMP',NC POS1$	NEG.L	D1	SET.B	D6POS1$:	TEST.L	D2	JUMP',NC POS2$	NEG.L	D2	NOT.B	D6POS2$:	RET;-----------\\; CALIFLECHE >;-----------/; Calcul les coordonnes des trois points D5-D6-D7; pour une flche intrieure.;	               D5;	               |\;	               | \;	               |  \;	D4 +-----------+---> D3;	             D7|  //;	               | //;	               |//;	               D6; in	D3.L	point o mettre la flche (y;x);	D4.L	autre extrmit (y;x); out	D5.L	une extrmit;	D6.L	l'autre extrmit;	D7.L	point intermdiaire; mod	D5.L, D6.L, D7.LCALIFLECHE:	PUSHM.L	D0..D4	LOAD.W	D1,D4	SUB.W	D1,D3		; D1 <-- dx	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- dy	SWAP.W	D3	LOAD.W	D0,#10		; D0 <-- longueur de la flche	CALL	PYTHAGORE	LOAD.L	D7,D3	ADD.W	D7,D1	SWAP.W	D7	ADD.W	D7,D2	SWAP.W	D7		; D7 <-- P7(y;x)	LOAD.W	D0,#1		; D0 <-- angle de la flche (27 degrs)	ASR.W	D1,D0	ASR.W	D2,D0	LOAD.L	D5,D7	SUB.W	D5,D2	SWAP.W	D5	ADD.W	D5,D1	SWAP.W	D5	LOAD.L	D6,D7	ADD.W	D6,D2	SWAP.W	D6	SUB.W	D6,D1	SWAP.W	D6	POPM.L	D0..D4	RET;----------\\; PYTHAGORE >;----------/; Calcul les coordonnes du point P7(x;y) en fonction du point P4(x;y); et de la longueur l sur l'hypotnuse.;		         o P4(x;y);		        /|;		       / |;		      /  |;		     /   |;		    o P7(x;y);		   /|    |;		l / |    |;		 /  |    |;		o---------;	     P3(x;y)  l'origine, donc (0;0); in	D0.W	+   l;	D1.W	+/- P4(x);	D2.W	+/- P4(y); out	D1.W	+/- P7(x);	D2.W	+/- P7(y); mod	D1.L, D2.LPYTHAGORE:	PUSHM.L	D0,D3..D7	CLR.W	D7		; D7 <-- clear flags	TEST.W	D1	JUMP',NC 10$	NEG.W	D1		; D1 <-- |P4(x)|	TSET.L	D7:#110$:	TEST.W	D2	JUMP',NC 15$	NEG.W	D2		; D2 <-- |P4(y)|	TSET.L	D7:#215$:	TEST.W	D1	JUMP',EQ 50$	TEST.W	D2	JUMP',EQ 55$	LOAD.W	D5,D0		; D5 <-- P7(x) suppos (trop grand)	MUL.WA	D0,D0		; D0 <-- l^2	COMP.W	D1,D2	JUMP',HS 20$	EX.L	D1,D2		; D1 > D2	TSET.L	D7:#020$:	LOAD.W	D6,D5	MUL.WU	D6,D2	DIV.WU	D6,D1		; D6 <-- P7(y) selon P4	LOAD.W	D3,D5	MUL.WU	D3,D3		; D3 <-- P7(x)^2	LOAD.W	D4,D6	MUL.WU	D4,D4		; D4 <-- P7(y)^2	ADD.W	D3,D4		; D3 <-- P7(x)^2 + P7(y)^2	COMP.W	D3,D0		; mme carr que le carr de "l" ?	JUMP',LS 30$		; oui => 30$				; encore trop grand =>	DEC.W	D5		; diminue P7(x) suppos	JUMP,NE	20$		; et recommence si non nul30$:	TEST.L	D7:#0	JUMP',BC 60$	EX.L	D5,D6	JUMP'	60$50$:				; "l" vertical =>	CLR.W	D5		; D5 <-- P7(x)	LOAD.W	D6,D0		; D6 <-- P7(y)	JUMP'	60$55$:				; "l" horizontal =>	LOAD.W	D5,D0		; D5 <-- P7(x)	CLR.W	D6		; D6 <-- P7(y)60$:	LOAD.W	D1,D5	LOAD.W	D2,D6	TEST.L	D7:#1	JUMP',BC 80$	NEG.W	D180$:	TEST.L	D7:#2	JUMP',BC 85$	NEG.W	D285$:	POPM.L	D0,D3..D7	RET;------------\\; CALCPMILIEU >;============/; Calcule le point milieu d'un segment.; in	D3.L	P1 (y;x);	D4.L	P2 (y;x); out	D4.L	M (y;x); mod	D4.L, D7.WCALCPMILIEU:	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	RET;---------\\; CALCPSYM >;=========/; Calcule une symtrie centrale pour un point.; in	D3.L	centre (y;x);	D4.L	point (y;x); out	D4.L	symtrique (y;x); mod	D4.L, D7.WCALCPSYM:	SUB.W	D4,D3	NEG.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	NEG.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	RET;-----------\\; CALCSYTOUR >;===========/; Calcule le point P2' en fonction de P1, P2 et C.; Les distances P2-C et P2'-C doivent rester identiques.;	         P2' o;	            /;	           /;	        C /      P2;	         o-------o;	        /;	       /;	      /;	     /;	 P1 o; in	D3.L	C   (y;x);	D4.L	P1  (y;x);	D5.L	P2  (y;x);	D6.W	lg  (-1 si inconnue); out	D5.L	P2' (y;x);	D6.W	lg; mod	D5.L, D6.L, D7.WCALCSYTOUR:	PUSHM.L	D1..D4	SUB.W	D4,D3	SUB.W	D5,D3	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D3	SUB.W	D5,D3	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	COMP.W	D6,#-1		; longueur initiale connue ?	JUMP',NE 20$		; oui => 20$	PUSHM.L	D3,D4	LOAD.L	D3,D5	LIB	?CALCHYPO	LOAD.W	D6,D4		; D6 <-- longueur initiale	POPM.L	D3,D420$:	LOAD.W	D1,D4	NEG.W	D1		; D1 <-- symtrique de P1 selon C en X	LOAD.L	D2,D4	SWAP.W	D2	NEG.W	D2		; D2 <-- symtrique de P1 selon C en Y	PUSH.L	D3	LOAD.L	D3,D4	LIB	?CALCHYPO	; D4 <-- nouvelle longueur	POP.L	D3	TEST.W	D4	JUMP',EQ 50$	MUL.WA	D1,D6	DIV.WA	D1,D4	MUL.WA	D2,D6	DIV.WA	D2,D450$:	LOAD.W	D5,D2	SWAP.W	D5	LOAD.W	D5,D1	ADD.W	D5,D3	SWAP.W	D3	SWAP.W	D5	ADD.W	D5,D3;	SWAP.W	D3	SWAP.W	D590$:	POPM.L	D1..D4	RET;--------\\; PUTVNUM >;========/; Met un nombre  trois dcimales (*1000) dans un buffer.; in	D4.W	nombre (+/-);	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTVNUM:	PUSHM.L	D1..D4	TEST.W	D4	JUMP',NC 20$	NEG.W	D4	LOAD.B	(A4+),#'-20$:	AND.L	D4,#H'FFFF	DIV.WU	D4,#1000	LOAD.L	D1,D4	AND.L	D4,#H'FFFF	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDCM	LIB	?PUTDEC	LOAD.B	(A4+),#'.	LOAD.L	D4,D1	CLR.W	D4	SWAP.W	D4	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDALL	LIB	?PUTDEC	POPM.L	D1..D4	RET;--------\\; GETVNUM >;========/; Lit un nombre  trois dcimales, rendu 1000 fois plus grand.; S'il n'y a pas de nombre, rend 1 pour ne rien zoomer !; in	A4.L	^nombre prsum; out	A4.L	^plus loin;	D4.W	nombre (+/-);	D7.W	erreur; mod	D4.L, D7.W, A4.LGETVNUM:	PUSHM.L	D1..D3,A3	CLR.W	D1		; D1 <-- nb de dcimales	CLR.W	D2		; D2 <-- positif	COMP.B	(A4),#'-	; signe moins ?	JUMP',NE 05$		; non => 05$	INC.L	A4		; oui =>	INC.W	D2		; D2 <-- ngatif05$:	LOAD.W	D7,#ERSYNT	LOAD.L	A3,A4		; A3 <-- ^dbut du nombre	CLR.W	D4		; D4 <-- futur nombre10$:	CLR.W	D3	LOAD.B	D3,(A4+)	; D3 <-- caractre	COMP.B	D3,#'.	JUMP',EQ 30$	COMP.B	D3,#'0		; est un digit ?	JUMP',LO 40$		; non => 40$	COMP.B	D3,#'9	JUMP',HI 40$	TEST.L	D1:#15		; est-on dans les dcimales ?	JUMP',BC 20$		; non => 20$				; oui =>	COMP.B	D1,#3		; plus de 3 dcimales ?	JUMP,HS 10$		; oui => 10$ (ignore)	INC.B	D1		; non => une dcimale de plus20$:	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.W	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$30$:	TSET.L	D1:#15		; D1 <-- partie dcimale existe	JUMP,BS 90$		; si 2me point => 90$ (erreur)	JUMP	10$40$:	TEST.W	D2		; nombre positif ?	JUMP',EQ 45$		; oui => 45$	NEG.L	D4		; non => prend le complment45$:	TEST.B	D3		; nombre termin ?	JUMP',NE 90$		; non => 90$				; oui =>	DEC.L	A4	LOAD.W	D2,#1000	; D2 <-- aucune dcimale	TEST.B	D1	JUMP',EQ 60$	LOAD.W	D2,#100		; D2 <-- une dcimale	DEC.B	D1	JUMP',EQ 60$	LOAD.W	D2,#10		; D2 <-- deux dcimales	DEC.B	D1	JUMP',EQ 60$	LOAD.W	D2,#1		; D2 <-- trois dcimales60$:	MUL.WU	D4,D2		; D4 <-- simule les dcimales manquantes	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D3,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PUTANUM >;========/; Met un nombre dcimal dans un buffer.; in	D4.W	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	AND.L	D4,#H'FFFF	; D4 <-- nombre binaire	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	CLR.B	(A4)	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;========/; Donne un nombre dcimal.; OK jusqu' 32 bits !; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSHM.L	D2,D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	SL.L	D4,#1	LOAD.L	D2,D4	SL.L	D4,#2	ADD.L	D4,D2		; D4 <-- pousse d'un digit (*10)	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POPM.L	D2,D3	RET;--------\\; MMENUS  >;========/; Attend un choix selon un mmenu hirarchique.; in	A3.L	^mmenu;	A4.L	^paramtres; out	D7.W	erreur; mod	D7.WMMENUS:	PUSHM.L	D3..D5	CALL	SCMO		; remet la souris	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	IFMOUSE		; D4 <-- position de la souris;;?	TEST.B	(A6)+ODEF+3:#BDEFMDC;;?	JUMP',BS 50$;;?	CLR.W	(A4)+OMMSEL	; slectionne la premire case50$:	CLR.L	D5		; D5 <-- flags	LIB	?MMENUS		; choix selon mmenu hirarchique ...	PUSH.W	D7	CALL	PMOUSE		; remet la souris o elle tait	LOAD.W	D4,#2	NTREL	?DELMS		; attend le positionnement	POP.W	D7	POPM.L	D3..D5	TEST.W	D7		; retour EQ/NE	RET;----------\\; WAITPRESS >;----------/; Attend une pression d'une touche ou d'un bouton.; in	-; out	D3.L	touche presse; mod	D3.L, D7.WWAITPRESS:	PUSH.L	D410$:	LIB	?GETKEY		; attend souris ...	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP,BS 10$		; non => 10$	COMP.W	D3,#KEYMPO	; dplacement ?	JUMP,EQ 10$		; oui => 10$	POP.L	D4	RET;----------\\; WAITMOVES >;----------/; Attend les dplacements de la souris, mme si elle ne bouge pas.; in	-; out	D3.L	touche presse;	D7.W	EQ si souris dplace; mod	D3.L, D7.WWAITMOVES:	PUSH.L	D4	CLR.W	D4	NTREL	?SETTIM		; met timeout nul (trs trs court)	CALL	WAITMOVE	; attend dplacement souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; WAITMOVE >;---------/; Attend un dplacement de la souris.; in	-; out	D3.L	touche presse;	D7.W	EQ si souris dplace; mod	D3.L, D7.WWAITMOVE:10$:	LIB	?GETKEY		; attend souris ...	JUMP',NE 20$		; si timeout => 20$	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP',BC 30$		; oui => 30$	JUMP	10$20$:	LOAD.W	D3,#KEYMPO	; D3 <-- dplacement	CLR.W	D7		; D7 <-- souris bouge	JUMP'	90$30$:	LOAD.W	D7,#1		; D7 <-- fin du dplacement	COMP.W	D3,#KEYMGP	JUMP',EQ 90$	COMP.W	D3,#KEYMMP	JUMP',EQ 90$	COMP.W	D3,#KEYMDP	JUMP',EQ 90$	COMP.W	D3,#KEYMGR	JUMP',EQ 90$	COMP.W	D3,#KEYMMR	JUMP',EQ 90$	COMP.W	D3,#KEYMDR	JUMP',EQ 90$	CLR.W	D7		; D7 <-- souris bouge90$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; IFMOUSEW >;=========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSEW:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE 90$	SUB.W	D4,(A6)+OWDOPX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	COMP.W	D4,(A6)+OWDODX	JUMP',LO 22$	LOAD.W	D4,(A6)+OWDODX	DEC.W	D4	LOAD.W	D7,#ERDIOUT22$:	SWAP.W	D4	SUB.W	D4,(A6)+OWDOPY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	COMP.W	D4,(A6)+OWDODY	JUMP',LO 32$	LOAD.W	D4,(A6)+OWDODY	DEC.W	D4	LOAD.W	D7,#ERDIOUT32$:	SWAP.W	D490$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la wdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	ADD.W	D4,(A6)+OLUPX	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	ADD.W	D4,(A6)+OLUPY	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMOUSE  >;========/; Positionne la souris en (y;x).; in	D4.L	nouvelle position y;x; out	-; mod	D7.WPMOUSE:	LIB	?PMOUSE		; positionne la souris	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; ATTENTION:	Le fait d'crire directement dans le descripteur;		de la fentre fait que la trame est inverse;		entre le Smaky 8 et 100 (gauche <--> droite) !;		Il ne faut donc utiliser que des trames simples;		(pas de hachures par exemple).; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	RET;--------\\; CCMO    >;========/; Enlve la souris.; in	-; out	-; mod	D7.WCCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',T 90$	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	SET.B	(A6)+OCCMO90$:	POP.W	D3	RET;--------\\; SCMO    >;========/; Remet la souris.; in	-; out	-; mod	D7.WSCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',F 90$	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	CLR.B	(A6)+OCCMO90$:	POP.W	D3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; SELMO   >;--------/; Slectionne un nouveau lutin pour la souris.; in	D3.B	outil en fonction; out	-; mod	D7.WSELMO:	PUSHM.L	D1..D5,A2..A5	LOAD.L	A3,#R16"TABLE$	LOAD.B	D2,D3	CLR.B	D3		; D3 <-- pas d'outil; Vrifie si la souris est dans la zone de dessin.; Si non, n'utilise pas l'outil slectionn.	LOAD.L	D1,#-1		; D1 <-- hors de la fentre	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE 10$	LOAD.L	D1,D4	SUB.W	D4,(A6)+OWDOPX	JUMP',LO 10$	COMP.W	D4,(A6)+OWDODX	JUMP',HS 10$	SWAP.W	D4	SUB.W	D4,(A6)+OWDOPY	JUMP',LO 10$	COMP.W	D4,(A6)+OWDODY	JUMP',HS 10$	LOAD.B	D3,D2		; D3 <-- outil slectionn10$:	TEST.B	(A3)+0		; fin de la table ?	JUMP',EQ 15$	COMP.B	D3,(A3)+0	; outil trouv ?	JUMP',EQ 15$	ADD.L	A3,#5		; A3 <-- ^suivant dans table	JUMP	10$15$:	CLR.W	D3	LOAD.B	D3,(A3)+1	; D3 <-- code de l'icne	LOAD.B	(A6)+OLUPX+1,(A3)+3	LOAD.B	(A6)+OLUPY+1,(A3)+4	COMP.B	D3,(A6)+OLUTIN	; toujours le mme outil ?	JUMP,EQ 90$		; oui => 90$	LOAD.B	(A6)+OLUTIN,D3	LOAD.L	A2,#(A6)+OLUMAM	TNOT.B	(A6)+OLUFLG:#BLUMAN	JUMP',BC 17$	LOAD.L	A2,#(A6)+OLUMAN17$:	LOAD.L	A4,#0		; A4 <-- utilise la flche normale	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	TEST.B	D3	JUMP',EQ 50$	TEST.B	(A3)+2	JUMP',NE 30$20$:	CALL	CMOUTIL		; A4/A5 <-- ^dx,dy,matrice de l'outil	JUMP'	50$30$:	CALL	CMOUTILFOND	; A4/A5 <-- ^dx,dy,matrice chair/fond;	JUMP'	50$50$:	NTREL	?GETPRIO	LOAD.W	D5,D4		; D5 <-- priorit actuelle	LOAD.W	D4,#1	NTREL	?SETPRIO	; met une trs forte priorit	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	LOAD.L	(A3)+1,A4	; <ssss> matrice chair	LOAD.L	(A3)+5,A5	; <cccc> matrice fond	LOAD.W	D3,#9	LIB	?STRING	COMP.L	D1,#-1		; hors de la fentre ?	JUMP,EQ 70$		; oui => 70$				; non =>	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 70$	SUB.W	D4,D1	JUMP',NC 60$	NEG.W	D4		; D4 <-- |dplacement horizontal|60$:	COMP.W	D4,#30		; souris beaucoup bouge "entre temps" ?	JUMP',HS 70$		; oui => 70$ (crac, pas de positionnement !!!)	LOAD.L	D4,D1	SUB.W	D4,(A6)+OLUPX	SWAP.W	D4	SUB.W	D4,(A6)+OLUPY	SWAP.W	D4	CALL	PMOUSE		; positionne pour ne pas bouger la "pointe"70$:	LOAD.W	D4,D5	NTREL	?SETPRIO	; remet la priorit initiale	LOAD.W	D4,#2	NTREL	?DELMS		; attend le changement/positionnement !90$:	POPM.L	D1..D5,A2..A5	RETTABLE$:	.B	ICOMOVE,ICOMOVE,0			0,20	.B	ICOOBJET,ICOOBJET,0			15,14	.B	ICOLOUPEP,ICOLOUPEP,0			9,7	.B	ICOLOUPEM,ICOLOUPEM,0			9,7	.B	ICOPOLYL,ICOMPOLYL,0			0,0	.B	ICOPOLYC,ICOMPOLYC,0			0,0	.B	ICOCIRCLE,ICOMCIRCLE,0			0,0	.B	ICOLINE,ICOMLINE,0			0,0	.B	ICORECT,ICOMRECT,0			0,0	.B	ICOELLIPSE,ICOMELLIPSE,0		0,0	.B	ICOZONE,ICOMZONE,0			10,10	.B	ICOREGLE,ICOMREGLE,0			0,0	.B	ICOPOSIMA,ICOPOSIMA,0			4,16	.B	ICORELATIF,ICORELATIF,0			1,1	.B	0,0,0					0,0	.EVEN;--------\\; CMOUTIL >;--------/; Construit la matrice d'un outil quelconque d'aprs; une icne contenue dans IXP20.; La matrice construite possde un point de plus de tous; les cts, pour permettre un calcul correct de la matrice; automatique de fond.; in	D3.W	code de l'icne;	A2.L	^buffer pour matrice; out	A4.L	^dx,dy,matrice chair;	A5.L	^dx,dy,matrice fond; mod	D7.W, A4.L, A5.LCMOUTIL:	PUSHM.L	D1..D4,A1,A3	LOAD.L	A1,(A6)+OPGICO	; A1 <-- ^gencar des icnes IXP20;;?	TCLR.L	D3:#7;;?	JUMP',BC 20$;;?	LOAD.L	A1,(A6)+OPHICO	; A1 <-- ^gencar des icnes IXP21;;?20$:	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D3	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^bonne matrice	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#GCICX/8 ; source: <ii>	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D2,#1+GCICY+1	; D2 <-- hauteur	SWAP.W	D2	CLR.W	D2	LOAD.B	D2,(A4)+(D3.W)	ADD.W	D2,#2		; D2 <-- largeur	LOAD.W	D1,D2	ADD.W	D1,#8-1	SR.W	D1,#3		; D1 <-- largeur en bytes	LOAD.W	(A3)+12,#1	; destination: <xx>	LOAD.W	(A3)+14,#1	; destination: <yy>	LOAD.L	A4,A2		; A4 <-- ^buffer pour matrice	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,D1	; destination: <ii>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D440$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,40$	SUB.W	D2,#2	LOAD.W	(A3)+22,D2	; <dxx>	SWAP.W	D2	SUB.W	D2,#2	LOAD.W	(A3)+24,D2	; <dyy>	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne	LOAD.L	A4,A2		; A4 <-- ^dx,dy,matrice	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	POPM.L	D1..D4,A1,A3	RET;------------\\; CMOUTILFOND >;------------/; Construit les matrices chair et fond d'un outil quelconque d'aprs; une icne et la suivante contenue dans IXP20.; in	D3.W	code de l'icne;	A2.L	^buffer pour matrice; out	A4.L	^dx,dy,matrice chair;	A5.L	^dx,dy,matrice fond; mod	D7.W, A4.L, A5.LCMOUTILFOND:	PUSHM.L	D0..D4,A1,A3	LOAD.L	A1,(A6)+OPGICO	; A1 <-- ^gencar des icnes IXP20;;?	TCLR.L	D3:#7;;?	JUMP',BC 20$;;?	LOAD.L	A1,(A6)+OPHICO	; A1 <-- ^gencar des icnes IXP21;;?20$:	LOAD.W	D0,D3		; D0 <-- code de l'icne	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D0	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^matrice chair	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#GCICX/8 ; source: <ii>	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D2,#GCICY	; D2 <-- hauteur	SWAP.W	D2	CLR.W	D2	LOAD.B	D2,(A4)+(D0.W)	; D2 <-- largeur	LOAD.W	D1,D2	ADD.W	D1,#8-1	SR.W	D1,#3		; D1 <-- largeur en bytes	CLR.L	(A3)+12		; destination: <xx> et <yy>	LOAD.L	A4,A2		; A4 <-- ^buffer pour matrice	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx chair	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy chair	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,D1	; destination: <ii>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D440$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,40$	SWAP.W	D2	LOAD.L	(A3)+22,D2	; <dxx> et <dyy>	SWAP.W	D2	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne chair	LOAD.L	A5,A4		; A5 <-- ^futur dx,dy,matrice fond	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	LOAD.W	D3,D0	INC.W	D3	MUL.WU	D4,D3	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^matrice suivante (fond)	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.L	A4,A5	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx fond	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy fond	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D460$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,60$	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne fond	LOAD.L	A4,A2		; A4 <-- ^dx,dy,matrice chair	POPM.L	D0..D4,A1,A3	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	-; out	-; mod	D7.WAFMENU:	PUSH.L	A3	LOAD.L	A3,#R16"TXMOVE$	COMP.W	(A6)+OXICO,#NIVMOVE	JUMP',EQ MENU$	LOAD.L	A3,#R16"TXPOLY$	COMP.W	(A6)+OXICO,#NIVPOLY	JUMP',EQ MENU$	LOAD.L	A3,#R16"TXMENU$MENU$:	LIB	?AFMENU	POP.L	A3	RETTXMOVE$:TXPOLY$:	.ASCIZ	"Ter- "	.ASCIZ	"mine "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	"Echelle"	.ASCIZ	"  -    1:1    +  "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TXMENU$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" Df.            "		;     ;     ;     ;	.ASCIZ	"Echelle"	.ASCIZ	"  -    1:1    +  "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"     Efface      "		;     ;     ;     ;	.EVEN	.END