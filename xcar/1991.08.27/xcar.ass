 Cre un gencar "bitmap" complet (128 caractres)  partir d'un gencar analytique.; in	D0.B	fonte;	D1.L	style/chasse, voir (*);	D2.B	taille; out	A4.L	^gencar (GETMEM sur le compte MTYPCP);	D7.W	erreur; mod	D7.W, A4.L;-------------\\; _XCAR_HEADER >;=============/; Cre l'en-tte d'un gencar "bitmap"  partir d'un gencar analytique.; in	D0.B	fonte;	D1.L	style/chasse, voir (*);	D2.B	taille;	A4.L	^buffer pour recevoir l'en-tte;	D4.W	lg du buffer (par exemple 256 ou 256+128); out	D7.W	erreur; mod	D7.W; (*)	Le style doit tre donn sur 32 bits !;	La routine ci-dessous converti un style 8 bits;	en un style 32 bits ...;----------\\; CONVNEWGC >;----------/;; Converti "fst" pour les "vieux" appels LOADGC/USEGC/KILLGC.;; in	D0.B	fonte;	D1.B	style/chasse;	D2.B	taille; out	D0.B	fonte;	D1.L	style/chasse;	D2.B	taille; mod	D0.B, D1.L, D2.B, D7.W;;CONVNEWGC:;	AND.L	D1,#H'000000FF	; D1 <-- style sur 32 bits;	TEST.L	D0:#7		; gencar construit ?;	JUMP,BC	90$		; non => 90$;				; oui =>;	SL.L	D1,#8;	LOAD.B	D1,#'R		; D1 <-- style "Roman";	TEST.L	D1:#8+BGCFIX;	JUMP,BC	90$;	TSET.L	D1:#BGCFIX	; D1 <-- chasse "Fixe";90$:;	RET;-----------\\; _XCAR_SHOW >;===========/; Affiche les caractres "Abc" d'un gencar analytique rapidement,; sans construire tous les autres caractres.; in	D0.B	fonte;	D1.L	style/chasse;	D2.B	taille;	D3.L	coin sup/gauche fentre o afficher (y;x);	D4.L	dimensions fentre o afficher (dy;dx);	A0.L	^descripteur fentre; out	D7.W	erreur; mod	D7.W;------------\\; _XCAR_SHOWF >;============/; Affiche les caractres "Abc" d'un gencar analytique rapidement,; sans construire tous les autres caractres.; in	D2.W	taille;	D3.L	coin sup/gauche fentre o afficher (y;x);	D4.L	dimensions fentre o afficher (dy;dx);	A4.L	^contenu du fichier *00.GENC (sans l'en-tte binaire);	A0.L	^descripteur fentre; out	D7.W	erreur; mod	D7.W;-------------\\; _XCAR_BMOPEN >;=============/; Ouvre un gencar bi