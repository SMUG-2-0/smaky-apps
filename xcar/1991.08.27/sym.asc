	.TITLE	SYM.ASC	.PROC	M680002	.REF	SMAKYPC	=	H'10000*500+500PP1	=	H'10000*500+300PP2	=	H'10000*500+600	.LOC	0OC:	.BLKB	4OP1:	.BLKB	4OP2:	.BLKB	4LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.L	(A6)+OC,#PC	LOAD.L	(A6)+OP1,#PP1	LOAD.L	(A6)+OP2,#PP2	LOAD.L	D3,(A6)+OC	CALL	CROIX	LOAD.L	D3,(A6)+OP1	CALL	CROIX	LOAD.L	D3,(A6)+OP2	CALL	CROIXLOOP:	LIB	?GETKEY	COMP.W	D3,#END	JUMP,EQ FIN	LIB	?IFMOUSE	LOAD.L	D5,D4	CALL	LINES	LOAD.L	D3,(A6)+OC	LOAD.L	D4,D5	LOAD.L	D5,#PP2	CALL	CALCSYTOUR	LOAD.L	(A6)+OP2,D5	LOAD.L	(A6)+OP1,D4	CALL	LINES	JUMP	LOOPFIN:	EXITLINES:	LOAD.L	D3,(A6)+OP1	LOAD.L	D4,(A6)+OC	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRSEG	LOAD.L	D3,(A6)+OP2	LOAD.L	D4,(A6)+OC	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRSEG	RETCROIX:	SUB.W	D3,#10	LOAD.L	D4,#H'10000*0+20	LOAD.W	D2,#INVDOT	LIB	?DRSEG	SUB.W	D3,#10	SWAP.W	D3	SUB.W	D3,#10	SWAP.W	D3	LOAD.L	D4,#H'10000*20+0	LOAD.W	D2,#INVDOT	LIB	?DRSEG	RET;-----------\\; CALCSYTOUR >;===========/; Calcule le point P2' en fonction de P1, P2 et C.; Les distances P2-C et P2'-C doivent rester identiques.;	         P2' o;	            /;	           /;	        C /      P2;	         o-------o;	        /;	       /;	      /;	     /;	 P1 o; in	D3.L	C   (y;x);	D4.L	P1' (y;x);	D5.L	P2  (y;x); out	D5.L	P2' (y;x); mod	D5.L, D7.WCALCSYTOUR:	PUSHM.L	D0..D4,D6	LOAD.L	D6,D3		; D6 <-- centre	SUB.W	D4,D6	SUB.W	D5,D6	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	SUB.W	D4,D6	SUB.W	D5,D6	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	PUSH.L	D4	LOAD.L	D3,D5	LIB	?CALCHYPO	LOAD.W	D0,D4		; D0 <-- longueur initiale	POP.L	D4	LOAD.W	D1,D4	NEG.W	D1	LOAD.L	D2,D4	SWAP.W	D2	NEG.W	D2	LOAD.W	D3,D2	SWAP.W	D3	LOAD.W	D3,D1	LIB	?CALCHYPO	; D4 <-- nouvelle longueur	TEST.W	D4	JUMP',EQ 50$	MUL.WA	D1,D0	DIV.WA	D1,D4	MUL.WA	D2,D0	DIV.WA	D2,D450$:	LOAD.W	D5,D2	SWAP.W	D5	LOAD.W	D5,D1	ADD.W	D5,D6	SWAP.W	D5	SWAP.W	D6	ADD.W	D5,D6	SWAP.W	D5;	SWAP.W	D690$:	POPM.L	D0..D4,D6	RET;---------\\; CALCPSYM >;=========/; Calcule une symtrie centrale pour un point.; in	D3.L	centre (y;x);	D4.L	point (y;x); out	D4.L	symtrique (y;x); mod	D4.L, D7.WCALCPSYM:	SUB.W	D4,D3	NEG.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	NEG.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	RETVAR:	.FILLB	LGVAR,0	.END	START