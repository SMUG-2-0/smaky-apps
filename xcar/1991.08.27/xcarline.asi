	.SBTTL	XCARLINE.ASI;--------\\; NEWCARQ >;========/; Dessine un nouveau caractrre, rapidement (sans dessiner !).; in	-; out	-; mod	D7.WNEWCARQ:	PUSHM.L	D3,A3	TEST.L	(A6)+OXCPGC	JUMP,EQ EXIT$	COMP.W	(A6)+OXCCAA,#-1	JUMP',EQ DECODE$	COMP.L	(A6)+OIFSPO,#POSNIL	JUMP',EQ NOSPOS$	LOAD.L	A3,#(A6)+OIFTAP	LOAD.W	D3,(A6)+OXCCAA	; D3 <-- caractre	SL.W	D3,#2	LOAD.L	(A3)+(D3.W),(A6)+OIFSPONOSPOS$:	TEST.B	(A6)+OMAJC	JUMP',F DECODE$	CALL	RECODE		; recode le caractre en dition	JUMP',NE EXIT$DECODE$:	CLR.B	(A6)+OMAJC	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D3,(A6)+OXCCAR	; D3 <-- caractre	CALL	DECODE		; cre la liste	JUMP',NE EXIT$	LOAD.L	A3,#(A6)+OIFTAP	LOAD.W	D3,(A6)+OXCCAR	; D3 <-- caractre	SL.W	D3,#2	LOAD.L	D3,(A3)+(D3.W)	COMP.L	D3,#POSNIL	JUMP',EQ NOGPOS$	LOAD.L	(A6)+OIFSPO,D3	LOAD.L	(A6)+OIFSLP,#POSNILNOGPOS$:	LOAD.W	(A6)+OXCCAA,(A6)+OXCCAR	CLR.L	(A6)+OPSLST	; plus de poignes slectionnes	LOAD.W	(A6)+OLSTOP,#OPNILEXIT$:	POPM.L	D3,A3	RET;--------\\; NEWCAR  >;========/; Dessine un nouveau caractrre.; in	-; out	-; mod	D7.WNEWCAR:	PUSHM.L	D3,A3	TEST.L	(A6)+OXCPGC	JUMP,EQ EXIT$	COMP.W	(A6)+OXCCAA,#-1	JUMP',EQ DECODE$	COMP.L	(A6)+OIFSPO,#POSNIL	JUMP',EQ NOSPOS$	LOAD.L	A3,#(A6)+OIFTAP	LOAD.W	D3,(A6)+OXCCAA	; D3 <-- caractre	SL.W	D3,#2	LOAD.L	(A3)+(D3.W),(A6)+OIFSPONOSPOS$:	TEST.B	(A6)+OMAJC	JUMP',F DECODE$	CALL	RECODE		; recode le caractre en dition	JUMP',NE EXIT$DECODE$:	CLR.B	(A6)+OMAJC	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D3,(A6)+OXCCAR	; D3 <-- caractre	CALL	DECODE		; cre la liste	JUMP',NE EXIT$	LOAD.L	A3,#(A6)+OIFTAP	LOAD.W	D3,(A6)+OXCCAR	; D3 <-- caractre	SL.W	D3,#2	LOAD.L	D3,(A3)+(D3.W)	COMP.L	D3,#POSNIL	JUMP',EQ NOGPOS$	LOAD.L	(A6)+OIFSPO,D3	LOAD.L	(A6)+OIFSLP,#POSNILNOGPOS$:	LOAD.W	(A6)+OXCCAA,(A6)+OXCCAR	CLR.L	(A6)+OPSLST	; plus de poignes slectionnes	CALL	DESCAR		; dessine un caractre	LOAD.W	(A6)+OLSTOP,#OPNILEXIT$:	POPM.L	D3,A3	RET;--------\\; DESCAR  >;========/; Dessine un caractrre.; in	-; out	-; mod	D7.WDESCAR:	PUSHM.L	D3	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	CALL	IFSHOW		; affiche l'image de fond	COMP.B	(A6)+OVISU,#ICOVCAR	JUMP,EQ CAR$	COMP.B	(A6)+OVISU,#ICOVCONS	JUMP,EQ CONS$	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ CHAS$	JUMP	EXIT$CAR$:	COMP.B	(A6)+OOUTIL,#ICORELATIF	JUMP',EQ REL$	CALL	DESAXES		; dessine les axes	CALL	DESCHASSETT	; dessine la chasse en traitill	CALL	DESOUTLINE	; dessine l'outline du caractre	CALL	DESPOIGNEES	; dessine les poignes du caractre	PUSH.W	(A6)+ODMODE	LOAD.W	(A6)+ODMODE,#INVDOT!TTTDOT	PUSH.L	(A6)+OLSTCH	LOAD.L	(A6)+OLSTCH,(A6)+OLSTC2	CALL	DESOUTLINE	; dessine l'outline des constructions	POP.L	(A6)+OLSTCH	POP.W	(A6)+ODMODE	JUMP	EXIT$REL$:	CALL	DESAXES		; dessine les axes	CALL	DESCHASSETT	; dessine la chasse en traitill	PUSH.W	(A6)+ODMODE	LOAD.W	(A6)+ODMODE,#INVDOT!TTTDOT	CALL	DESOUTLINE	; dessine l'outline du caractre	POP.W	(A6)+ODMODE	CALL	DESPOIGNEES	; dessine les poignes du caractre	JUMP	EXIT$CONS$:	CALL	DESAXES		; dessine les axes	CALL	DESCHASSETT	; dessine la chasse en traitill	CALL	DESOUTLINE	; dessine l'outline des constructions	CALL	DESPOIGNEES	; dessine les poignes des constructions	PUSH.W	(A6)+ODMODE	LOAD.W	(A6)+ODMODE,#INVDOT!TTTDOT	PUSH.L	(A6)+OLSTCH	LOAD.L	(A6)+OLSTCH,(A6)+OLSTC1	CALL	DESOUTLINE	; dessine l'outline du caractre	POP.L	(A6)+OLSTCH	POP.W	(A6)+ODMODE	JUMP	EXIT$CHAS$:	CALL	DESAXES		; dessine les axes	CALL	DESCHASSE	; dessine la chasse	PUSH.L	(A6)+OLSTCH	LOAD.L	(A6)+OLSTCH,(A6)+OLSTC1	CALL	DESOUTLINE	; dessine l'outline du caractre	POP.L	(A6)+OLSTCH	PUSH.W	(A6)+ODMODE	LOAD.W	(A6)+ODMODE,#INVDOT!TTTDOT	PUSH.L	(A6)+OLSTCH	LOAD.L	(A6)+OLSTCH,(A6)+OLSTC2	CALL	DESOUTLINE	; dessine l'outline des constructions	POP.L	(A6)+OLSTCH	POP.W	(A6)+ODMODE;	JUMP	EXIT$EXIT$:	CALL	CLOWDO		; dessine normalement	CALL	PETAFF		; dessine le petit caractre rel	POPM.L	D3	RET;-----------\\; DESOUTLINE >;===========/; Dessine la "outline" d'un caractre.; in	-; out	-; mod	D7.WDESOUTLINE:	PUSHM.L	D6,A4	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP',EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	CALL	DESOBJET	; dessine un objet	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	POPM.L	D6,A4	RET;------------\\; DESPOIGNEES >;============/; Dessine toutes les poignes d'un caractrre.; in	-; out	-; mod	D7.WDESPOIGNEES:	PUSHM.L	D1..D4,D6,A3,A4	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE END$	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D4,#POSNIL	LOAD.L	A3,#(A6)+OPSLST	TEST.L	(A3)	JUMP',EQ LOOP$	LOAD.W	D4,(A3)+4	; D4 <-- offset	LOAD.L	A3,(A3)		; A3 <-- ^objet	LOAD.L	D4,(A3)+(D4.W)	; D4 <-- position poigne slectionneLOOP$:	LOAD.W	D1,(A4)+OOBTYP	COMP.W	D1,#xcOPLINE	JUMP',EQ OBJ$	COMP.W	D1,#xcOPCURVE	JUMP',EQ OBJ$	COMP.W	D1,#xcOPADDCHAR	JUMP',NE NEXT$OBJ$:	LOAD.L	D3,(A4)+OOBPP1	COMP.L	D3,D4		; est-ce la poigne slectionne ?	JUMP',EQ SEL$		; oui => SEL$	LOAD.W	D2,#TPTROND	CALL	IPTQQ		; inverse une poigne	COMP.B	(A6)+OOUTIL,#ICOREGLE	JUMP',NE NEXT$	COMP.W	D1,#xcOPCURVE	JUMP',NE NEXT$	LOAD.L	D3,(A4)+OOBPS1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ		; inverse une poigne	LOAD.L	D3,(A4)+OOBPS2;	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ		; inverse une poigne	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBPS1	LOAD.W	D2,#INVDOT!TTTDOT	CALL	LINE	LOAD.L	D3,(A4)+OOBPP2	LOAD.L	D4,(A4)+OOBPS2;	LOAD.W	D2,#INVDOT!TTTDOT	CALL	LINE	JUMP'	NEXT$SEL$:	CALL	PSINV		; inverse la poigne slectionne;	JUMP'	NEXT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	POPM.L	D1..D4,D6,A3,A4	RET;--------\\; DESAXES >;========/; Dessines les axes.; in	-; out	-; mod	D7.WDESAXES:	PUSHM.L	D2..D4	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	3		; chelle	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT	CLR.L	D3	LOAD.W	D3,(A6)+ODESDX	SR.W	D3,#1	NEG.W	D3	CLR.L	D4	LOAD.W	D4,(A6)+ODESDX	SR.W	D4,#1	CALL	LINE		; dessine le repre horizontal	LOAD.W	D3,(A6)+ODESDY	SR.W	D3,#1	NEG.W	D3	SWAP.W	D3	CLR.W	D3	LOAD.W	D4,(A6)+ODESDY	SR.W	D4,#1	SWAP.W	D4	CLR.W	D4	CALL	LINE		; dessine le repre vertical	POPM.L	D2..D4	RET;----------\\; DESCHASSE >;==========/; Dessine la chasse.; in	-; out	-; mod	D7.WDESCHASSE:	PUSHM.L	D1..D4,A3	TEST.L	(A6)+OXCPGC	JUMP,EQ EXIT$	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D1,(A6)+OXCCAR	; D1 <-- caractre	SL.W	D1,#1	LOAD.L	A3,#(A3)+oxcLENGTH	LOAD.W	D1,(A3)+(D1.W)	LOAD.W	D3,(A6)+ODESDY	SR.W	D3,#1	NEG.W	D3	SWAP.W	D3	LOAD.W	D3,D1	LOAD.W	D4,(A6)+ODESDY	SR.W	D4,#1	SWAP.W	D4	LOAD.W	D4,D1	CALL	LINE	AND.L	D3,#H'FFFF	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ	CALL	CLOWDO		; dessine normalementEXIT$:	POPM.L	D1..D4,A3	RET;------------\\; DESCHASSETT >;============/; Dessine la chasse en traitills.; in	-; out	-; mod	D7.WDESCHASSETT:	PUSHM.L	D1..D4,A3	TEST.L	(A6)+OXCPGC	JUMP,EQ EXIT$	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	LIB	?AFTIM	.B	MAPTT	.B	B'10000000	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D1,(A6)+OXCCAR	; D1 <-- caractre	SL.W	D1,#1	LOAD.L	A3,#(A3)+oxcLENGTH	LOAD.W	D1,(A3)+(D1.W)	LOAD.W	D3,(A6)+ODESDY	SR.W	D3,#1	NEG.W	D3	SWAP.W	D3	LOAD.W	D3,D1	LOAD.W	D4,(A6)+ODESDY	SR.W	D4,#1	SWAP.W	D4	LOAD.W	D4,D1	CALL	LINE	CALL	CLOWDO		; dessine normalementEXIT$:	POPM.L	D1..D4,A3	RET.IF 0;--------\\; DESBBOX >;========/; Dessine la "bounding box".; in	-; out	-; mod	D7.WDESBBOX:	PUSHM.L	D1..D4,A3	TEST.L	(A6)+OXCPGC	JUMP,EQ EXIT$	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D1,(A6)+OXCCAR	; D1 <-- caractre	SL.W	D1,#1	LOAD.L	A3,#(A3)+oxcXMINS	LOAD.W	D1,(A3)+(D1.W)	LOAD.W	D3,(A6)+ODESDY	SR.W	D3,#1	NEG.W	D3	SWAP.W	D3	LOAD.W	D3,D1	LOAD.W	D4,(A6)+ODESDY	SR.W	D4,#1	SWAP.W	D4	LOAD.W	D4,D1	CALL	LINE	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D1,(A6)+OXCCAR	; D1 <-- caractre	SL.W	D1,#1	LOAD.L	A3,#(A3)+oxcYMINS	LOAD.W	D1,(A3)+(D1.W)	LOAD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,(A6)+ODESDX	SR.W	D3,#1	NEG.W	D3	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,(A6)+ODESDX	SR.W	D4,#1	CALL	LINE	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D1,(A6)+OXCCAR	; D1 <-- caractre	SL.W	D1,#1	LOAD.L	A3,#(A3)+oxcXMAXS	LOAD.W	D1,(A3)+(D1.W)	LOAD.W	D3,(A6)+ODESDY	SR.W	D3,#1	NEG.W	D3	SWAP.W	D3	LOAD.W	D3,D1	LOAD.W	D4,(A6)+ODESDY	SR.W	D4,#1	SWAP.W	D4	LOAD.W	D4,D1	CALL	LINE	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D1,(A6)+OXCCAR	; D1 <-- caractre	SL.W	D1,#1	LOAD.L	A3,#(A3)+oxcYMAXS	LOAD.W	D1,(A3)+(D1.W)	LOAD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,(A6)+ODESDX	SR.W	D3,#1	NEG.W	D3	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,(A6)+ODESDX	SR.W	D4,#1	CALL	LINE	CALL	CLOWDO		; dessine normalementEXIT$:	POPM.L	D1..D4,A3	RET.ENDIF;---------\\; DESOBJET >;---------/; Dessine un objet.; in	A4.L	^objet; out	-; mod	D7.WDESOBJET:	PUSHM.L	D2..D6	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	LOAD.W	D2,(A6)+ODMODE	COMP.W	D2,#INVDOT!TTTDOT	JUMP',NE CONT$	COMP.B	(A6)+OOUTIL,#ICORELATIF	JUMP',EQ REL$	LIB	?AFTIM	.B	MAPTT	.B	B'11001100	; map	.B	1		; chelle	.B	0	.EVEN	JUMP'	CONT$REL$:	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	; map	.B	1		; chelle	.B	0	.EVENCONT$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	COMP.W	D3,#xcOPADDCHAR	JUMP',EQ ADDCHAR$	JUMP'	EXIT$LINE$:	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBPP2	CALL	LINE	CALL	DESREL		; dessine les points relatifs	JUMP'	EXIT$CURVE$:	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBPS1	LOAD.L	D5,(A4)+OOBPS2	LOAD.L	D6,(A4)+OOBPP2	CALL	CURVE	CALL	DESREL		; dessine les points relatifs	JUMP'	EXIT$ADDCHAR$:	LOAD.L	D4,(A4)+OOBPP1	; D4 <-- dplacement	LOAD.B	D3,(A4)+OOBPP2	; D3 <-- caractre	CALL	DESADDCHAR;	JUMP'	EXIT$EXIT$:	CALL	CLOWDO		; dessine normalement	POPM.L	D2..D6	RET;--------\\; DESREL  >;--------/; Dessine les points relatifs d'un objet.; in	A4.L	^objet; out	-; mod	D7.WDESREL:	COMP.B	(A6)+OOUTIL,#ICORELATIF	JUMP',EQ REL$	RETREL$:	PUSHM.L	D3,D4	LOAD.L	D3,(A4)+OOBRP1	JUMP',EQ P2$	LOAD.L	D4,(A4)+OOBPP1	CALL	DESRELONEP2$:;;?	LOAD.L	D3,(A4)+OOBRP2;;?	JUMP',EQ EXIT$;;?	LOAD.L	D4,(A4)+OOBPP2;;?	CALL	DESRELONEEXIT$:	POPM.L	D3,D4	RET;----------\\; DESRELONE >;----------/; Dessine juste une flche XY, X ou Y.; in	D3.L	dpart "relatif";	D4.L	arrive; out	-; mod	D7.WDESRELONE:	PUSHM.L	D2..D4	LOAD.W	D2,#INVDOT	TEST.L	D3:#15	JUMP',BC Y$	TEST.L	D3:#31	JUMP',BC X$	CALL	RELABS		; D3 <-- coordonne absolue	CALL	FLECHE2	JUMP	EXIT$X$:	CALL	RELABS		; D3 <-- coordonne absolue	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,D4	SWAP.W	D4	SWAP.W	D3	CALL	FLECHE1	JUMP'	EXIT$Y$:	CALL	RELABS		; D3 <-- coordonne absolue	LOAD.W	D3,D4	CALL	FLECHE1;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4	RET;---------\\; DESDEBUG >;---------/; Dessine un objet.; in	A4.L	^objet; out	-; mod	D7.WDESDEBUG:	PUSHM.L	D2..D6	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP,EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP,EQ CURVE$	COMP.W	D3,#xcOPADDCHAR	JUMP,EQ ADDCHAR$	JUMP	EXIT$LINE$:	LIB	?AFTIM	.ASCIZ	"	LINE:	"	.EVEN	LOAD.L	D4,(A4)+OOBPP1	LIB	?AFX8	LIB	?AFSPACE	LOAD.L	D4,(A4)+OOBPP2	LIB	?AFX8	LIB	?AFSPACE	LIB	?AFCR	JUMP	EXIT$CURVE$:	LIB	?AFTIM	.ASCIZ	"	CURVE:	"	.EVEN	LOAD.L	D4,(A4)+OOBPP1	LIB	?AFX8	LIB	?AFSPACE	LOAD.L	D4,(A4)+OOBPS1	LIB	?AFX8	LIB	?AFSPACE	LOAD.L	D4,(A4)+OOBPS2	LIB	?AFX8	LIB	?AFSPACE	LOAD.L	D4,(A4)+OOBPP2	LIB	?AFX8	LIB	?AFSPACE	LIB	?AFCR	JUMP	EXIT$ADDCHAR$:	LIB	?AFTIM	.ASCIZ	"	ADD:	"	.EVEN	LOAD.L	D4,(A4)+OOBPP1	LIB	?AFX8	LIB	?AFSPACE	LOAD.B	D4,(A4)+OOBPP2	LIB	?AFX2	LIB	?AFSPACE	LIB	?AFCR;	JUMP	EXIT$EXIT$:	POPM.L	D2..D6	RET;-----------\\; DESADDCHAR >;-----------/; Dessine un caractre non dcod.; in	D3.B	code du caractre;	D4.L	+/- dplacement (dy;dx); out	-; mod	D7.WDESADDCHAR:	PUSHM.L	D0..D6,A3,A4	LOAD.L	D0,D4		; D0 <-- dplacement	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	CLR.W	D4	LOAD.B	D4,D3	SL.W	D4,#2	LOAD.L	A4,#(A3)+oxcPCHAR	LOAD.L	D4,(A4)+(D4.W)	LOAD.L	A4,#(A3)+(D4.L)	; A4 <-- ^description du caractre	LOAD.W	D2,#INVDOT!TTTDOTLOOP$:	LOAD.B	D3,(A4+)	INC.L	A4	COMP.B	D3,#xcOPBEGIN	JUMP,EQ BEGIN$	COMP.B	D3,#xcOPLINE	JUMP,EQ LINE$	COMP.B	D3,#xcOPCURVE	JUMP,EQ CURVE$	COMP.B	D3,#xcOPADDCHAR	JUMP,EQ ADDCHAR$	COMP.B	D3,#xcOPFILLI	JUMP,EQ LOOP$	COMP.B	D3,#xcOPFILLA	JUMP,EQ LOOP$	COMP.B	D3,#xcOPPEN	JUMP,EQ PEN$	JUMP	END$BEGIN$:	CALL	DESADDCHARGET	LOAD.L	D1,D3	JUMP	LOOP$LINE$:	CALL	DESADDCHARGET	LOAD.L	D4,D3	LOAD.L	D3,D1	LOAD.L	D1,D4	ADD.W	D3,D0	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D0	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	CALL	LINE	LOAD.W	D2,#INVDOT!TTTDOT!NCTDOT	JUMP	LOOP$CURVE$:	CALL	DESADDCHARGET	LOAD.L	D4,D3	CALL	DESADDCHARGET	LOAD.L	D5,D3	CALL	DESADDCHARGET	LOAD.L	D6,D3	LOAD.L	D3,D1	LOAD.L	D1,D6	ADD.W	D3,D0	ADD.W	D4,D0	ADD.W	D5,D0	ADD.W	D6,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	ADD.W	D3,D0	ADD.W	D4,D0	ADD.W	D5,D0	ADD.W	D6,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	CALL	CURVE	LOAD.W	D2,#INVDOT!TTTDOT!NCTDOT	JUMP	LOOP$ADDCHAR$:	ADD.L	A4,#4+2		; pas de rcursion possible !	JUMP	LOOP$PEN$:	ADD.L	A4,#2	JUMP	LOOP$END$:	POPM.L	D0..D6,A3,A4	RET;--------------\\; DESADDCHARGET >;--------------/; Donne les coordonnes d'un point.; in	A4.L	^buffer; out	A4.L	^plus loin;	D3.L	point (y;x); mod	D3.L, D7.W, A4.LDESADDCHARGET:	PUSH.L	D4	EX.L	A4,A5	CALL	DECOGETPR	; D3/D4 <-- PP/RP (y;x)	EX.L	A5,A4	POP.L	D4	RET;--------\\; CIRCLE  >;--------/; Dessine un cercle.; in	D2.W	mode de dessin;	D3.L	centre (y;x) [pi];	D4.W	rayon (r)    [pi]; out	-; mod	D7.WCIRCLE:	PUSHM.L	D1..D6,A2	CALL	CONVPIPG	; D3 <-- centre [pg]	CALL	D4SCALE		; D4 <-- rayon [pg]	INC.W	D4	COMP.W	D4,#2	JUMP',LO 90$	PUSHM.L	D3,D4	LOAD.W	D1,D4	LOAD.L	D4,D3	SUB.W	D3,D1	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	ADD.W	D4,D1	SWAP.W	D4	ADD.W	D4,D1	SWAP.W	D4	LOAD.L	D5,D3	LOAD.L	D6,D4	CALL	CLIP4PTS	; qq chose  dessiner ?	POPM.L	D3,D4	JUMP',NE 90$		; non => 90$	EX.L	D3,D4	LOAD.W	D1,D2	LOAD.W	D2,#-1	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	GRA_	CIRCLE90$:	POPM.L	D1..D6,A2	RET;--------\\; ELLIPSE >;--------/; Dessine une ellipse.; in	D2.W	mode de dessin;	D3.L	centre (y;x) [pi];	D4.L	rayons (y;x) [pi]; out	-; mod	D7.WELLIPSE:	PUSHM.L	D0..D6,A2	TEST.L	D4	JUMP,EQ 90$	TEST.W	D4	JUMP',NC 20$	NEG.W	D420$:	SWAP.W	D4	TEST.W	D4	JUMP',NC 22$	NEG.W	D422$:	SWAP.W	D4	CALL	CONVPIPG	; D3 <-- centre [pg]	CALL	D4SCALE		; D4 <-- rayons [pg]	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	PUSHM.L	D3,D4	LOAD.W	D0,D4	LOAD.L	D1,D4	SWAP.W	D1	LOAD.L	D4,D3	SUB.W	D3,D0	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	ADD.W	D4,D0	SWAP.W	D4	ADD.W	D4,D1	SWAP.W	D4	LOAD.L	D5,D3	LOAD.L	D6,D4	CALL	CLIP4PTS	; qq chose  dessiner ?	POPM.L	D3,D4	JUMP',NE 90$		; non => 90$	EX.L	D3,D4	LOAD.W	D1,D2	LOAD.W	D2,#-1	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	GRA_	ELLIPSE90$:	POPM.L	D0..D6,A2	RET;--------\\; RECT    >;--------/; Dessine un rectangle.; in	D2.W	mode de dessin;	D3.L	dpart (y;x)  [pi];	D4.L	arrive (y;x) [pi]; out	-; mod	D7.WRECT:	PUSHM.L	D0,D1,D3,D4	LOAD.L	D0,D3	LOAD.L	D1,D4;	LOAD.L	D3,D0	LOAD.L	D4,D0	LOAD.W	D4,D1	CALL	LINE	LOAD.L	D3,D0	LOAD.W	D3,D1	LOAD.L	D4,D1	CALL	LINE	LOAD.L	D3,D1	LOAD.L	D4,D1	LOAD.W	D4,D0	CALL	LINE	LOAD.L	D3,D1	LOAD.W	D3,D0	LOAD.L	D4,D0	CALL	LINE	POPM.L	D0,D1,D3,D4	RET;--------\\; FLECHE2 >;--------/; Dessine une flche allant du dpart  l'arrive.; in	D2.W	mode de dessin;	D3.L	dpart (y;x)  [pi];	D4.L	arrive (y;x) [pi]; out	-; mod	D7.WFLECHE2:	PUSHM.L	D1..D6,A2	CALL	CONVPIPG	; D3 <-- point [pg]	EX.L	D3,D4	CALL	CONVPIPG	; D4 <-- point [pg]	EX.L	D3,D4	EX.L	D3,D4	CALL	CALIFLECHE	; D5/D6 <-- points spciaux	CALL	CLIP4PTS	; qq chose  dessiner ?	JUMP,NE 90$		; non => 90$	LOAD.W	D1,D2	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	LOAD.L	D2,D3	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	GRA_	LINE	LOAD.L	D4,D2	LOAD.L	D3,D5	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	GRA_	LINE;	LOAD.L	D4,D2	LOAD.L	D3,D6	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	GRA_	LINE90$:	POPM.L	D1..D6,A2	RET;--------\\; FLECHE1 >;--------/; Dessine une flche allant du dpart  l'arrive.; in	D2.W	mode de dessin;	D3.L	dpart (y;x)  [pi];	D4.L	arrive (y;x) [pi]; out	-; mod	D7.WFLECHE1:	PUSHM.L	D1..D6,A2	CALL	CONVPIPG	; D3 <-- point [pg]	EX.L	D3,D4	CALL	CONVPIPG	; D4 <-- point [pg]	EX.L	D3,D4	EX.L	D3,D4	CALL	CALIFLECHE	; D5/D6 <-- points spciaux	CALL	CLIP4PTS	; qq chose  dessiner ?	JUMP,NE 90$		; non => 90$	LOAD.W	D1,D2	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	LOAD.L	D2,D3	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	GRA_	LINE	LOAD.L	D4,D2	LOAD.L	D3,D5	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	GRA_	LINE90$:	POPM.L	D1..D6,A2	RET;--------\\; LINE    >;--------/; Dessine une ligne droite.; in	D2.W	mode de dessin;	D3.L	dpart (y;x)  [pi];	D4.L	arrive (y;x) [pi]; out	-; mod	D7.WLINE:	PUSHM.L	D1..D6,A2	CALL	CONVPIPG	; D3 <-- point [pg]	EX.L	D3,D4	CALL	CONVPIPG	; D4 <-- point [pg]	EX.L	D3,D4	LOAD.L	D5,D3	LOAD.L	D6,D4	CALL	CLIP4PTS	; qq chose  dessiner ?	JUMP',NE 90$		; non => 90$	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	EX.L	D3,D4	LOAD.W	D1,D2	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	GRA_	LINE90$:	POPM.L	D1..D6,A2	RET;--------\\; CURVE   >;--------/; Dessine une courbe de bzier.; in	D2.W	mode de dessin;	D3.L	P1 (y;x) [pi];	D4.L	P2 (y;x) [pi];	D5.L	P3 (y;x) [pi];	D6.L	P4 (y;x) [pi]; out	-; mod	D7.WCURVE:	PUSHM.L	D3..D6,A4	CALL	CONVPIPG	; D3 <-- point [pg]	EX.L	D3,D4	CALL	CONVPIPG	; D4 <-- point [pg]	EX.L	D3,D4	EX.L	D3,D5	CALL	CONVPIPG	; D5 <-- point [pg]	EX.L	D3,D5	EX.L	D3,D6	CALL	CONVPIPG	; D6 <-- point [pg]	EX.L	D3,D6	CALL	CLIP4PTS	; qq chose  dessiner ?	JUMP',NE 90$		; non => 90$	SUB.L	SP,#LBZ	LOAD.L	A4,SP		; A4 <-- ^variables sur le stack	LOAD.W	(A4)+OBZMOD,D2	LOAD.W	(A4)+OBZP1X+0,D3	SWAP.W	D3	LOAD.W	(A4)+OBZP1Y+0,D3	LOAD.W	(A4)+OBZC1X+0,D4	SWAP.W	D4	LOAD.W	(A4)+OBZC1Y+0,D4	LOAD.W	(A4)+OBZC2X+0,D5	SWAP.W	D5	LOAD.W	(A4)+OBZC2Y+0,D5	LOAD.W	(A4)+OBZP2X+0,D6	SWAP.W	D6	LOAD.W	(A4)+OBZP2Y+0,D6;;?	LOAD.W	D3,#CHOUIA05	; D3 <-- p'tit chouia (0.5)CLR.W D3	LOAD.W	(A4)+OBZP1X+2,D3	LOAD.W	(A4)+OBZP1Y+2,D3	LOAD.W	(A4)+OBZC1X+2,D3	LOAD.W	(A4)+OBZC1Y+2,D3	LOAD.W	(A4)+OBZC2X+2,D3	LOAD.W	(A4)+OBZC2Y+2,D3	LOAD.W	(A4)+OBZP2X+2,D3	LOAD.W	(A4)+OBZP2Y+2,D3	CALL	BZDRAW	ADD.L	SP,#LBZ90$:	POPM.L	D3..D6,A4	RET;---------\\; CLIP4PTS >;---------/; Regarde si le plus petit rectangle englobant quatre points; est visible, mme partiellement.; in	D3.L	P1 (y;x);	D4.L	P2 (y;x);	D5.L	P3 (y;x);	D6.L	P4 (y;x); out	D7.W	erreur si rien  dessiner; mod	D7.WCLIP4PTS:	PUSHM.L	D1,D2	LOAD.L	D1,#H'7FFF7FFF	; D1 <-- +infini	LOAD.L	D2,#H'80008000	; D2 <-- -infini	COMP.W	D1,D3	JUMP',LE 20$	LOAD.W	D1,D320$:	COMP.W	D2,D3	JUMP',GE 21$	LOAD.W	D2,D321$:	COMP.W	D1,D4	JUMP',LE 22$	LOAD.W	D1,D422$:	COMP.W	D2,D4	JUMP',GE 23$	LOAD.W	D2,D423$:	COMP.W	D1,D5	JUMP',LE 24$	LOAD.W	D1,D524$:	COMP.W	D2,D5	JUMP',GE 25$	LOAD.W	D2,D525$:	COMP.W	D1,D6	JUMP',LE 26$	LOAD.W	D1,D626$:	COMP.W	D2,D6	JUMP',GE 27$	LOAD.W	D2,D627$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	COMP.W	D1,D3	JUMP',LE 30$	LOAD.W	D1,D330$:	COMP.W	D2,D3	JUMP',GE 31$	LOAD.W	D2,D331$:	COMP.W	D1,D4	JUMP',LE 32$	LOAD.W	D1,D432$:	COMP.W	D2,D4	JUMP',GE 33$	LOAD.W	D2,D433$:	COMP.W	D1,D5	JUMP',LE 34$	LOAD.W	D1,D534$:	COMP.W	D2,D5	JUMP',GE 35$	LOAD.W	D2,D535$:	COMP.W	D1,D6	JUMP',LE 36$	LOAD.W	D1,D636$:	COMP.W	D2,D6	JUMP',GE 37$	LOAD.W	D2,D637$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	LOAD.W	D7,#ERDIOUT	TEST.W	D2	JUMP',NS 90$	COMP.W	D1,(A6)+OWDODX	JUMP',GE 90$	SWAP.W	D1	SWAP.W	D2	TEST.W	D2	JUMP',NS 90$	COMP.W	D1,(A6)+OWDODY	JUMP',GE 90$	CLR.W	D790$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; BZMINMAX >;=========/; Cherche le rectangle englobant une courbe de bzier.; in	D3.L	P0 (y;x);	D4.L	P1 (y;x);	D5.L	P2 (y;x);	D6.L	P3 (y;x); out	D1.L	min (y;x);	D2.L	max (y;x); mod	D1.L, D2.L, D7.WBZMINMAX:	PUSHM.L	D3..D6,A4	SUB.L	SP,#LBZI	LOAD.L	A4,SP		; A4 <-- ^variables sur le stack	LOAD.L	(A4)+OBZP1I,D3	LOAD.L	(A4)+OBZC1I,D4	LOAD.L	(A4)+OBZC2I,D5	LOAD.L	(A4)+OBZP2I,D6	LOAD.W	D1,#H'7FFF	; D1 <-- X min	LOAD.W	D2,#H'7FFF	; D2 <-- Y min	LOAD.W	D5,#H'8000	; D5 <-- X max 	LOAD.W	D6,#H'8000	; D6 <-- Y max	CLR.W	D4LOOP$:	CALL	BZPOINTI	; D3 <-- point (y;x)	COMP.W	D1,D3	JUMP',LE XMIN$	LOAD.W	D1,D3		; D1 <-- X minXMIN$:	COMP.W	D5,D3	JUMP',GE XMAX$	LOAD.W	D5,D3		; D5 <-- X maxXMAX$:	SWAP.W	D3	COMP.W	D2,D3	JUMP',LE YMIN$	LOAD.W	D2,D3		; D2 <-- Y minYMIN$:	COMP.W	D6,D3	JUMP',GE YMAX$	LOAD.W	D6,D3		; D6 <-- Y maxYMAX$:	INC.W	D4	COMP.W	D4,#256	JUMP,LS LOOP$	SWAP.W	D1	LOAD.W	D1,D2	SWAP.W	D1	LOAD.W	D2,D6	SWAP.W	D2	LOAD.W	D2,D5	ADD.L	SP,#LBZI	POPM.L	D3..D6,A4	RET;--------\\; BZDRAW  >;========/; Dessine une courbe de bezier.; in	A4.L	^OBZxxx; out	-; mod	D7.WBZDRAW:	PUSH.L	A1	LOAD.L	A1,#R16"BZLINE	; A1 <-- ^routine "line"	CALL	BZDRAWQQ	; trace une courbe de bzier	POP.L	A1	RET;---------\\; BZDRAWQQ >;=========/; Dessine une courbe de bezier.; in	A4.L	^OBZxxx;	A1.L	^routine "line"; out	-; mod	D7.WBZDRAWQQ:	PUSHM.L	D0..D5; Calcule une valeur approximative correspondant ; la distance P1C1 + C1C2 + C2P2.	LOAD.L	D3,(A4)+OBZP1X	SUB.L	D3,(A4)+OBZC1X	JUMP',NC POS1$	NEG.L	D3POS1$:	LOAD.L	D2,D3	LOAD.L	D3,(A4)+OBZP1Y	SUB.L	D3,(A4)+OBZC1Y	JUMP',NC POS2$	NEG.L	D3POS2$:	ADD.L	D2,D3	LOAD.L	D3,(A4)+OBZC1X	SUB.L	D3,(A4)+OBZC2X	JUMP',NC POS3$	NEG.L	D3POS3$:	ADD.L	D2,D3	LOAD.L	D3,(A4)+OBZC1Y	SUB.L	D3,(A4)+OBZC2Y	JUMP',NC POS4$	NEG.L	D3POS4$:	ADD.L	D2,D3	LOAD.L	D3,(A4)+OBZC2X	SUB.L	D3,(A4)+OBZP2X	JUMP',NC POS5$	NEG.L	D3POS5$:	ADD.L	D2,D3	LOAD.L	D3,(A4)+OBZC2Y	SUB.L	D3,(A4)+OBZP2Y	JUMP',NC POS6$	NEG.L	D3POS6$:	ADD.L	D2,D3		; D2 <-- distance approximative; Calcule l'incrment en fonction de la distance; approximative (totalement empyrique) !	LOAD.W	D5,#1	COMP.L	D2,#H'10000*640	JUMP',HS STEP$	LOAD.W	D5,#2	COMP.L	D2,#H'10000*320	JUMP',HS STEP$	LOAD.W	D5,#4	COMP.L	D2,#H'10000*160	JUMP',HS STEP$	LOAD.W	D5,#8	COMP.L	D2,#H'10000*80	JUMP',HS STEP$	LOAD.W	D5,#16	COMP.L	D2,#H'10000*40	JUMP',HS STEP$	LOAD.W	D5,#32	COMP.L	D2,#H'10000*20	JUMP',HS STEP$	LOAD.W	D5,#64STEP$:; Calcule tous les points de la courbe de bzier.	CLR.W	D4		; D4 <-- rang initial	LOAD.L	D0,(A4)+OBZP1X	LOAD.L	D1,(A4)+OBZP1Y	; D0/D1 <-- dpartLOOP$:	CALL	BZPOINT		; D2/D3 <-- point	CALL	(A1)		; trace un segment de droite	LOAD.L	D0,D2	LOAD.L	D1,D3	ADD.W	D4,D5		; D4 <-- rang suivant	COMP.W	D4,#256		; a-t-on fini ?	JUMP,LS LOOP$		; non => LOOP$	POPM.L	D0..D5	RET;---------\\; BZPOINTI >;---------/; Calcule un point entier quelconque situ sur une courbe de bzier.; Cette routine est essentiellement plus rapide que BZPOINT !; in	A4.L	^OBZxxI;	D4.W	rang (0..256); out	D3.L	point (y;x); mod	D3.L, D7.WBZPOINTI:	PUSHM.L	D2,D4,A2,A3	LOAD.L	A3,#R16"BZTABLE	LOAD.L	A2,A3	LOAD.W	D3,#256	SUB.W	D3,D4	SL.W	D4,#2	SL.W	D3,#2	ADD.W	A3,D4	ADD.W	A2,D3	LOAD.W	D4,(A4)+OBZP1I+0	MUL.WA	D4,(A3)+0	LOAD.L	D3,D4	LOAD.W	D4,(A4)+OBZC1I+0	MUL.WA	D4,(A3)+2	ADD.L	D3,D4	LOAD.W	D4,(A4)+OBZC2I+0	MUL.WA	D4,(A2)+2	ADD.L	D3,D4	LOAD.W	D4,(A4)+OBZP2I+0	MUL.WA	D4,(A2)+0	ADD.L	D3,D4	RL.L	D3,#1	COMP.W	D3,#H'8000	JUMP',LO 20$	ADD.L	D3,#H'1000020$:	LOAD.W	D4,(A4)+OBZP1I+2	MUL.WA	D4,(A3)+0	LOAD.L	D2,D4	LOAD.W	D4,(A4)+OBZC1I+2	MUL.WA	D4,(A3)+2	ADD.L	D2,D4	LOAD.W	D4,(A4)+OBZC2I+2	MUL.WA	D4,(A2)+2	ADD.L	D2,D4	LOAD.W	D4,(A4)+OBZP2I+2	MUL.WA	D4,(A2)+0	ADD.L	D2,D4	RL.L	D2,#1	COMP.W	D2,#H'8000	JUMP',LO 40$	ADD.L	D2,#H'1000040$:	SWAP.W	D2	LOAD.W	D3,D2	POPM.L	D2,D4,A2,A3	RET;--------\\; BZPOINT >;--------/; Calcule un point quelconque situ sur une courbe de bzier.; in	A4.L	^OBZxxx;	D4.W	rang (0..256); out	D2/D3	point (x;y); mod	D2.L, D3.L, D7.WBZPOINT:	PUSHM.L	D0,D1,D4,A2,A3	LOAD.L	A3,#R16"BZTABLE	LOAD.L	A2,A3	LOAD.W	D3,#256	SUB.W	D3,D4	SL.W	D4,#2	SL.W	D3,#2	ADD.W	A3,D4		; A3 <-- ^table, depuis le dbut	ADD.W	A2,D3		; A2 <-- ^table, depuis la fin	LOAD.L	D1,(A4)+OBZP1Y	CLR.L	D2	LOAD.W	D2,(A3)+0	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	LOAD.L	D3,D0	LOAD.L	D1,(A4)+OBZC1Y	CLR.L	D2	LOAD.W	D2,(A3)+2	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	ADD.L	D3,D0	LOAD.L	D1,(A4)+OBZC2Y	CLR.L	D2	LOAD.W	D2,(A2)+2	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	ADD.L	D3,D0	LOAD.L	D1,(A4)+OBZP2Y	CLR.L	D2	LOAD.W	D2,(A2)+0	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	ADD.L	D3,D0	LOAD.L	D1,(A4)+OBZP1X	CLR.L	D2	LOAD.W	D2,(A3)+0	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	LOAD.L	D4,D0	LOAD.L	D1,(A4)+OBZC1X	CLR.L	D2	LOAD.W	D2,(A3)+2	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	ADD.L	D4,D0	LOAD.L	D1,(A4)+OBZC2X	CLR.L	D2	LOAD.W	D2,(A2)+2	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	ADD.L	D4,D0	LOAD.L	D1,(A4)+OBZP2X	CLR.L	D2	LOAD.W	D2,(A2)+0	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	ADD.L	D4,D0	LOAD.L	D2,D4	POPM.L	D0,D1,D4,A2,A3	RET;	1re colonne:	((1-t)^3)*m;	2me colonne:	(3t*(1-t)^2)*m;	avec:		0 < t < 1;			m = (2^15)-1 = 32767BZTABLE:	.W	32767	0	; t=0/256	.W	32385	381	; t=1/256	.W	32005	756	; t=2/256	.W	31628	1125	; ...	.W	31255	1488	.W	30884	1846	.W	30517	2197	.W	30152	2543	.W	29790	2883	.W	29431	3217	.W	29075	3546	.W	28722	3869	.W	28372	4186	.W	28024	4498	.W	27680	4804	.W	27338	5105	.W	26999	5400	.W	26663	5690	.W	26330	5974	.W	25999	6253	.W	25672	6527	.W	25347	6795	.W	25024	7058	.W	24705	7316	.W	24388	7569	.W	24074	7816	.W	23763	8059	.W	23454	8296	.W	23148	8528	.W	22845	8756	.W	22545	8978	.W	22247	9195	.W	21951	9408	.W	21659	9615	.W	21369	9818	.W	21081	10016	.W	20796	10209	.W	20514	10397	.W	20234	10581	.W	19957	10760	.W	19682	10935	.W	19410	11104	.W	19141	11270	.W	18874	11431	.W	18609	11587	.W	18347	11739	.W	18087	11886	.W	17830	12029	.W	17575	12168	.W	17323	12302	.W	17073	12432	.W	16826	12558	.W	16581	12679	.W	16338	12797	.W	16098	12910	.W	15860	13019	.W	15625	13125	.W	15391	13226	.W	15160	13323	.W	14932	13416	.W	14706	13505	.W	14482	13591	.W	14260	13672	.W	14041	13750	.W	13824	13824	.W	13609	13894	.W	13396	13960	.W	13186	14023	.W	12977	14082	.W	12771	14137	.W	12568	14189	.W	12366	14238	.W	12167	14283	.W	11969	14324	.W	11774	14362	.W	11581	14396	.W	11390	14428	.W	11201	14456	.W	11015	14480	.W	10830	14501	.W	10648	14520	.W	10467	14534	.W	10289	14546	.W	10112	14555	.W	9938	14560	.W	9766	14563	.W	9595	14562	.W	9427	14559	.W	9261	14553	.W	9096	14543	.W	8934	14531	.W	8773	14516	.W	8615	14498	.W	8458	14478	.W	8304	14454	.W	8151	14428	.W	8000	14400	.W	7851	14368	.W	7703	14334	.W	7558	14298	.W	7415	14259	.W	7273	14217	.W	7133	14174	.W	6995	14127	.W	6859	14079	.W	6724	14028	.W	6592	13974	.W	6461	13919	.W	6331	13861	.W	6204	13801	.W	6078	13738	.W	5954	13674	.W	5832	13608	.W	5711	13539	.W	5592	13469	.W	5475	13396	.W	5359	13321	.W	5245	13245	.W	5133	13167	.W	5022	13087	.W	4913	13005	.W	4805	12921	.W	4699	12835	.W	4595	12748	.W	4492	12659	.W	4391	12569	.W	4291	12477	.W	4193	12383	.W	4096	12288	.W	4001	12191	.W	3907	12093	.W	3815	11993	.W	3724	11892	.W	3634	11790	.W	3546	11686	.W	3460	11581	.W	3375	11475	.W	3291	11367	.W	3209	11259	.W	3128	11149	.W	3049	11038	.W	2970	10926	.W	2894	10813	.W	2818	10699	.W	2744	10584	.W	2671	10468	.W	2600	10351	.W	2529	10233	.W	2460	10115	.W	2393	9995	.W	2326	9875	.W	2261	9754	.W	2197	9633	.W	2134	9511	.W	2073	9388	.W	2012	9264	.W	1953	9140	.W	1895	9016	.W	1838	8891	.W	1783	8766	.W	1728	8640	.W	1675	8514	.W	1622	8387	.W	1571	8260	.W	1521	8133	.W	1472	8006	.W	1424	7878	.W	1377	7751	.W	1331	7623	.W	1286	7495	.W	1242	7367	.W	1199	7239	.W	1158	7111	.W	1117	6983	.W	1077	6855	.W	1038	6727	.W	1000	6600	.W	963	6472	.W	927	6345	.W	892	6218	.W	857	6092	.W	824	5965	.W	791	5839	.W	760	5714	.W	729	5589	.W	699	5464	.W	670	5340	.W	642	5216	.W	614	5093	.W	587	4971	.W	561	4849	.W	536	4728	.W	512	4608	.W	488	4488	.W	465	4369	.W	443	4251	.W	422	4134	.W	401	4018	.W	381	3903	.W	362	3788	.W	343	3675	.W	325	3563	.W	308	3451	.W	291	3341	.W	275	3232	.W	259	3124	.W	244	3017	.W	230	2912	.W	216	2808	.W	203	2705	.W	190	2604	.W	178	2503	.W	166	2405	.W	155	2308	.W	145	2212	.W	135	2118	.W	125	2025	.W	116	1934	.W	107	1844	.W	99	1757	.W	91	1671	.W	84	1586	.W	77	1504	.W	70	1423	.W	64	1344	.W	58	1267	.W	53	1192	.W	48	1119	.W	43	1047	.W	38	978	.W	34	911	.W	31	846	.W	27	783	.W	24	722	.W	21	664	.W	18	607	.W	16	553	.W	13	501	.W	11	452	.W	10	405	.W	8	360	.W	7	318	.W	5	278	.W	4	241	.W	3	206	.W	3	174	.W	2	144	.W	1	117	.W	1	93	.W	1	71	.W	0	53	.W	0	37	.W	0	24	.W	0	13	; ...	.W	0	6	; t=254/256	.W	0	1	; t=255/256	.W	0	0	; t=256/256;--------\\; BZLINE  >;--------/; Trace une droite, avec les coordonnes donnes en rels.; in	D0/D1	dpart  (x;y);	D2/D3	arrive (x;y);	A4.L	^OBZxxx; out	-; mod	D7.WBZLINE:	PUSHM.L	D0..D4,A2	LOAD.L	D4,#CHOUIA05	ADD.L	D0,D4	ADD.L	D1,D4	ADD.L	D2,D4	ADD.L	D3,D4	SWAP.W	D0	LOAD.W	D1,D0		; D1 <-- dpart (y;x)	SWAP.W	D2	LOAD.W	D3,D2		; D3 <-- arrive (y;x)	LOAD.L	D4,D3	LOAD.L	D3,D1	COMP.L	D3,D4	JUMP',EQ EXIT$	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	EX.L	D3,D4	LOAD.W	D1,(A4)+OBZMOD	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	GRA_	LINE	TEST.L	D1:#BTTTDOT	JUMP',BC EXIT$	TSET.L	D1:#BNCTDOT	LOAD.W	(A4)+OBZMOD,D1EXIT$:	POPM.L	D0..D4,A2	RET;--------\\; IPTQQ   >;========/; Inverse un point quelconque.; in	D3.L	point (y;x);	D2.W	type de la poigne (TPTxxxx); out	-; mod	D7.WIPTQQ:	COMP.W	D2,#TPTNIL	JUMP,EQ EXIT$	COMP.L	D3,#POSNIL	JUMP,EQ EXIT$	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	COMP.W	D2,#TPTROND	JUMP',EQ ROND$	COMP.W	D2,#TPTRONDHILI	JUMP',EQ RONDHILI$	COMP.W	D2,#TPTRONDTJ	JUMP',EQ RONDTJ$	COMP.W	D2,#TPTCARRE	JUMP',EQ CARRE$	COMP.W	D2,#TPTCROIX	JUMP',EQ CROIX$	JUMP'	END$ROND$:	CALL	IPTROND	JUMP'	END$RONDHILI$:	CALL	IPTRONDHILI	JUMP'	END$RONDTJ$:	CALL	IPTRONDTJ	JUMP'	END$CARRE$:	CALL	IPTCARRE	JUMP'	END$CROIX$:	CALL	IPTCROIX;	JUMP'	END$END$:	CALL	CLOWDO		; dessine normalementEXIT$:	RET;--------\\; IPTROND >;--------/; Inverse un point rond, seulement en cas de jointure !; in	D3.L	point (y;x); out	-; mod	D7.WIPTROND:	PUSH.L	D4	CALL	PTCOUNT		; D4 <-- nb d'occurrences	COMP.W	D4,#2	JUMP',LO 90$	CALL	IPTRONDTJ90$:	POP.L	D4	RET;----------\\; IPTRONDTJ >;----------/; Inverse un point rond.; in	D3.L	point (y;x); out	-; mod	D7.WIPTRONDTJ:	PUSHM.L	D1..D4,A2	CALL	CONVPIPG	; D3 <-- point [pg]	LOAD.W	D4,#4		; D4 <-- rayon	EX.L	D3,D4	LOAD.W	D1,#INVDOT	LOAD.W	D2,#-1		; D2 <-- tous les octants	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	GRA_	CIRCLE	POPM.L	D1..D4,A2	RET;------------\\; IPTRONDHILI >;------------/; Inverse un point rond.; in	D3.L	point (y;x); out	-; mod	D7.WIPTRONDHILI:	PUSHM.L	D1..D4,A2	CALL	CONVPIPG	; D3 <-- point [pg]	LOAD.L	D4,D3	LOAD.W	D1,#INVDOT	LOAD.W	D2,#-1		; D2 <-- tous les octants	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	LOAD.W	D3,#3		; D3 <-- rayon	GRA_	CIRCLE	LOAD.W	D3,#6		; D3 <-- rayon	GRA_	CIRCLE	LOAD.W	D3,#7		; D3 <-- rayon	GRA_	CIRCLE	POPM.L	D1..D4,A2	RET;---------\\; IPTCARRE >;---------/; Inverse un point carr.; in	D3.L	point (y;x); out	-; mod	D7.WIPTCARRE:	PUSHM.L	D1..D4,A2,A4	CALL	CONVPIPG	; D3 <-- point [pg]	SUB.W	D3,#3	SWAP.W	D3	SUB.W	D3,#3	SWAP.W	D3	LOAD.L	D4,#H'10000*7+7	EX.L	D3,D4	LOAD.W	D1,#INVDOT	LOAD.L	A4,#R16"TRAME$	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	GRA_	TRAME	POPM.L	D1..D4,A2,A4	RETTRAME$:	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.EVEN;---------\\; IPTCROIX >;---------/; Inverse un point en croix.; in	D3.L	point (y;x); out	-; mod	D7.WIPTCROIX:	PUSHM.L	D1..D4,A2	CALL	CONVPIPG	; D3 <-- point [pg]	SUB.W	D3,#2	LOAD.L	D4,#H'10000*0+5	EX.L	D3,D4	LOAD.W	D1,#INVDOT	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	GRA_	LINE	ADD.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LOAD.L	D3,#H'10000*5+0	GRA_	LINE	POPM.L	D1..D4,A2	RET;--------\\; PTCOUNT >;========/; Compte le nombre d'occurrences d'un point donn.; in	D3.L	point (y;x); out	D4.W	nb d'occurrences (0..n); mod	D4.L, D7.WPTCOUNT:	PUSHM.L	D6,A4	CLR.W	D4	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP',EQ EXIT$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	COMP.L	D3,(A4)+OOBPP1	JUMP',EQ INC$	COMP.L	D3,(A4)+OOBPP2	JUMP',NE NEXT$INC$:	INC.W	D4	COMP.W	(A4)+OOBTYP,#xcOPADDCHAR	JUMP',NE NEXT$	LOAD.W	D4,#2		; D4 <-- si ADDCHAR, toujours visible !	JUMP'	EXIT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D6,A4	RET;--------\\; OPEWDO  >;--------/; Utilise la swdo de dessin, si ncessaire.; in	-; out	-; mod	D7.WOPEWDO:	TEST.W	(A6)+OWUSE	JUMP',NE 20$	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	LOAD.W	(A3)+1,(A6)+OWDOPX	LOAD.W	(A3)+3,(A6)+OWDOPY	LOAD.W	(A3)+5,(A6)+OWDODX	LOAD.W	(A3)+7,(A6)+OWDODY	LOAD.W	D3,#9	LIB	?STRING	POPM.L	D3,A320$:	INC.W	(A6)+OWUSE	RET;--------\\; CLOWDO  >;--------/; Ferme la swdo de dessin, si ncessaire.; in	-; out	-; mod	D7.WCLOWDO:	DEC.W	(A6)+OWUSE	JUMP',NE 90$	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	CLR.L	(A3)+1	LOAD.W	(A3)+5,(A0)+ODFDX	LOAD.W	(A3)+7,(A0)+ODFDY	LOAD.W	D3,#9	LIB	?STRING	POPM.L	D3,A390$:	RET;---------\\; CONVPIPG >;=========/; Conversion d'un point interne en point graphique.; in	D3.L	point (y;x) interne; out	D3.L	point (y;x) dans l'cran;	D7.W	erreur si hors de la fentre de dessin; mod	D3.L, D7.WCONVPIPG:	PUSH.L	D4	LOAD.W	D4,(A6)+ODESDX	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	LOAD.W	D4,(A6)+ODESDY	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	D4,D3	CALL	D4SCALE	LOAD.L	D3,D4	SUB.W	D3,(A6)+ODESPX	SWAP.W	D3	SUB.W	D3,(A6)+ODESPY	SWAP.W	D3	CLR.W	D7	TEST.W	D3	JUMP',NC 30$	LOAD.W	D7,#ERDIOUT30$:	COMP.W	D3,(A6)+OWDODX	JUMP',LT 32$	LOAD.W	D7,#ERDIOUT32$:	SWAP.W	D3	TEST.W	D3	JUMP',NC 40$	LOAD.W	D7,#ERDIOUT40$:	COMP.W	D3,(A6)+OWDODY	JUMP',LT 42$	LOAD.W	D7,#ERDIOUT42$:	SWAP.W	D390$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; CONVPGPI >;=========/; Conversion d'un point graphique en point interne.; in	D3.L	point (y;x) dans l'cran; out	D3.L	point (y;x) interne; mod	D3.L, D7.WCONVPGPI:	PUSH.L	D4	ADD.W	D3,(A6)+ODESPX	SWAP.W	D3	ADD.W	D3,(A6)+ODESPY	SWAP.W	D3	LOAD.L	D4,D3	NEG.W	(A6)+OSCALE	CALL	D4SCALE	NEG.W	(A6)+OSCALE	LOAD.L	D3,D4	LOAD.W	D4,(A6)+ODESDX	SR.W	D4,#1	SUB.W	D3,D4	SWAP.W	D3	LOAD.W	D4,(A6)+ODESDY	SR.W	D4,#1	SUB.W	D3,D4	SWAP.W	D3	POP.L	D4	RET	.END