	.SBTTL	XCARDET.ASI;--------\\; PENGET  >;========/; Donne le pinceau utilis par un caractre.; in	-; out	D2.W	pinceau (-1 si diffrentes sortes); mod	D2.L, D7.WPENGET:	PUSHM.L	D1,D3,D6,A4	LOAD.W	D2,#-1	LOAD.W	D1,#-1	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP',EQ EXIT$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ PEN$	COMP.W	D3,#xcOPCURVE	JUMP',NE NEXT$PEN$:	COMP.W	D1,#-1	JUMP',EQ FIRST$	COMP.W	D1,(A4)+OOBPEN	; toujours le mme pinceau ?	JUMP',NE EXIT$		; non => EXIT$	JUMP'	NEXT$FIRST$:	LOAD.W	D1,(A4)+OOBPEN	; D1 <-- premier pinceau;	JUMP'	NEXT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$	LOAD.W	D2,D1		; D2 <-- pinceau utilis partoutEXIT$:	POPM.L	D1,D3,D6,A4	RET;--------\\; PENPUT  >;========/; Utilise un pinceau par tous les objets d'un caractre.; in	D2.W	pinceau; out	-; mod	D7.WPENPUT:	PUSHM.L	D3,D6,A4	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP',EQ EXIT$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ PEN$	COMP.W	D3,#xcOPCURVE	JUMP',NE NEXT$PEN$:	LOAD.W	(A4)+OOBPEN,D2NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D3,D6,A4	RET;----------\\; TRITALCAR >;----------/; Transforme un caractre en italique.; in	-; out	-; mod	D7.WTRITALCAR:	PUSH.L	A1	LOAD.L	A1,#R16"TRITALONE	CALL'	TRXXXXCAR	POP.L	A1	RET;----------\\; TRLARGCAR >;----------/; Transforme la largeur du caractre.; in	-; out	-; mod	D7.WTRLARGCAR:	PUSHM.L	D1,A1	LOAD.L	A1,#R16"TRLARGONE	CALL'	TRXXXXCAR	LOAD.L	A1,(A6)+OXCPGC	; A1 <-- ^en-tte gencar	ADD.L	A1,#256		; A1 <-- ^gencar	LOAD.W	D1,(A6)+OXCCAR	; D1 <-- caractre	SL.W	D1,#1	LOAD.L	A1,#(A1)+oxcLENGTH	LOAD.W	D3,(A1)+(D1.W)	; D3 <-- chasse caractre actuelle	CALL	TRLARGONE	LOAD.W	(A1)+(D1.W),D3	POPM.L	D1,A1	RET;----------\\; TRDEPLCAR >;----------/; Dplace un caractre.; in	D0.L	+/- dplacement (dy;dx); out	-; mod	D7.WTRDEPLCAR:	PUSH.L	A1	LOAD.L	A1,#R16"TRDEPLONE	CALL'	TRXXXXCAR	POP.L	A1	RETTRXXXXCAR:	PUSHM.L	D3,D6,A4	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE END$LOOP$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	COMP.W	D3,#xcOPADDCHAR	JUMP,EQ ADDCHAR$	JUMP	NEXT$LINE$:CURVE$:	LOAD.L	D3,(A4)+OOBPP1	CALL	(A1)	LOAD.L	(A4)+OOBPP1,D3	LOAD.L	D3,(A4)+OOBPS1	CALL	(A1)	LOAD.L	(A4)+OOBPS1,D3	LOAD.L	D3,(A4)+OOBPS2	CALL	(A1)	LOAD.L	(A4)+OOBPS2,D3	LOAD.L	D3,(A4)+OOBPP2	CALL	(A1)	LOAD.L	(A4)+OOBPP2,D3	LOAD.L	D3,(A4)+OOBRP1	JUMP',EQ NORP1$	TEST.L	D3:#15	JUMP',BC YRP1$	TEST.L	D3:#31	JUMP',BC XRP1$	CALL	RELABS	CALL	(A1)	TSET.L	D3:#15	TSET.L	D3:#31	LOAD.L	(A4)+OOBRP1,D3	JUMP'	NORP1$XRP1$:	CALL	RELABS	SWAP.W	D3	LOAD.W	D3,(A4)+OOBPP1+0	SWAP.W	D3	CALL	(A1)	TSET.L	D3:#15	AND.L	D3,#H'FFFF	LOAD.L	(A4)+OOBRP1,D3	JUMP'	NORP1$YRP1$:	CALL	RELABS	LOAD.W	D3,(A4)+OOBPP1+2	CALL	(A1)	TSET.L	D3:#31	CLR.W	D3	LOAD.L	(A4)+OOBRP1,D3NORP1$:	LOAD.L	D3,(A4)+OOBRP2	JUMP',EQ NORP2$	TEST.L	D3:#15	JUMP',BC YRP2$	TEST.L	D3:#31	JUMP',BC XRP2$	CALL	RELABS	CALL	(A1)	TSET.L	D3:#15	TSET.L	D3:#31	LOAD.L	(A4)+OOBRP2,D3	JUMP'	NORP2$XRP2$:	CALL	RELABS	SWAP.W	D3	LOAD.W	D3,(A4)+OOBPP2+0	SWAP.W	D3	CALL	(A1)	TSET.L	D3:#15	AND.L	D3,#H'FFFF	LOAD.L	(A4)+OOBRP2,D3	JUMP'	NORP2$YRP2$:	CALL	RELABS	LOAD.W	D3,(A4)+OOBPP2+2	CALL	(A1)	TSET.L	D3:#31	CLR.W	D3	LOAD.L	(A4)+OOBRP2,D3NORP2$:	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	JUMP	NEXT$ADDCHAR$:	LOAD.L	D3,(A4)+OOBPP1	CALL	(A1)	LOAD.L	(A4)+OOBPP1,D3	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	JUMP	NEXT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	POPM.L	D3,D6,A4	RET;----------\\; TRITALONE >;----------/; Transforme une coordonne pour gnrer de l'italique.; in	D3.L	p (y;x); out	D3.L	p (y;x); mod	D3.L, D7.WTRITALONE:	PUSHM.L	D2,D4	LOAD.W	D2,D3		; D2 <-- x	SWAP.W	D3		; D3 <-- y	LOAD.W	D4,(A6)+OIPTRAN	MUL.WA	D4,D3	DIV.WA	D4,#100	SUB.W	D2,D4	SWAP.W	D3	LOAD.W	D3,D2		; D3 <-- (y;x)	POPM.L	D2,D4	RET;----------\\; TRLARGONE >;----------/; Transforme une coordonne pour modifier la largeur.; in	D3.L	p (y;x); out	D3.L	p (y;x); mod	D3.L, D7.WTRLARGONE:	PUSH.L	D2	LOAD.W	D2,D3		; D2 <-- x	MUL.WA	D2,(A6)+OLPTRAN	DIV.WA	D2,#100	LOAD.W	D3,D2		; D3 <-- (y;x)	POP.L	D2	RET;----------\\; TRDEPLONE >;----------/; Transforme une coordonne pour la dplacer.; in	D3.L	p (y;x); out	D3.L	p (y;x); mod	D3.L, D7.WTRDEPLONE:	ADD.W	D3,D0	SWAP.W	D3	SWAP.W	D0	ADD.W	D3,D0	SWAP.W	D3	SWAP.W	D0	RET;---------\\; TRPENCAR >;---------/; Transforme le pinceau de tous les objets du caractre.; in	-; out	-; mod	D7.WTRPENCAR:	PUSHM.L	D3,D6,A4	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP',EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	JUMP'	NEXT$LINE$:CURVE$:	LOAD.W	D3,(A6)+OPEN	COMP.W	D3,(A4)+OOBPEN	JUMP',EQ NEXT$	LOAD.W	(A4)+OOBPEN,D3	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC;	JUMP'	NEXT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	POPM.L	D3,D6,A4	RET;--------\\; RGAJUST >;========/; Dplace un point selon la rgle.; in	D3.W	opration (1..5);	D4.L	+/- dplacement (dy;dx);	D5.L	dpart (y;x);	D6.L	arrive (y;x); out	-; mod	D7.WRGAJUST:	PUSHM.L	D0..D6,A4	LOAD.L	D1,D6		; D1 <-- point initial	CALL	RGAJUSTONE	; D6 <-- point modifi	COMP.L	D1,D6	JUMP,EQ EXIT$	LOAD.L	D0,D6		; D0 <-- point modifi	SUB.W	D0,D1	SWAP.W	D0	SWAP.W	D1	SUB.W	D0,D1	SWAP.W	D0	SWAP.W	D1	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ EXIT$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE EXIT$LOOP$:	LOAD.W	D2,(A4)+OOBTYP	COMP.W	D2,#xcOPLINE	JUMP',EQ OBJ$	COMP.W	D2,#xcOPCURVE	JUMP,NE NEXT$OBJ$:	LOAD.W	D2,#OOBPP1	COMP.L	D1,(A4)+(D2.W)	JUMP',EQ DEPL$	LOAD.W	D2,#OOBPP2	COMP.L	D1,(A4)+(D2.W)	JUMP',EQ DEPL$	LOAD.W	D2,#OOBPS1	COMP.L	D1,(A4)+(D2.W)	JUMP',EQ DEPL$	LOAD.W	D2,#OOBPS2	COMP.L	D1,(A4)+(D2.W)	JUMP',NE NEXT$DEPL$:	ADD.W	(A4)+(D2.W)+2,D0	SWAP.W	D0	ADD.W	(A4)+(D2.W)+0,D0	SWAP.W	D0	COMP.W	D2,#OOBPS1	JUMP',EQ NEXT$	COMP.W	D2,#OOBPS2	JUMP',EQ NEXT$	ADD.W	(A4)+(D2.W)+(OOBPS1-OOBPP1)+2,D0	SWAP.W	D0	ADD.W	(A4)+(D2.W)+(OOBPS1-OOBPP1)+0,D0	SWAP.W	D0NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$	CALL	DESCAR		; redessine le caractre	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPMOVEEXIT$:	POPM.L	D0..D6,A4	RET;-----------\\; RGAJUSTONE >;-----------/; ; in	D3.W	opration (1..5);	D4.L	+/- dplacement (dy;dx);	D5.L	dpart (y;x);	D6.L	point initial (y;x); out	D6.L	point modifi (y;x); mod	D6.L, D7.WRGAJUSTONE:	PUSHM.L	D0..D5	COMP.W	D3,#1	JUMP',EQ XY$	COMP.W	D3,#2	JUMP',EQ XY$	COMP.W	D3,#3	JUMP',EQ XY$	COMP.W	D3,#4	JUMP,EQ LG$	COMP.W	D3,#5	JUMP,EQ ANG$	JUMP	EXIT$XY$:	TEST.W	D4	JUMP',NC XY21$	NEG.W	D4XY21$:	COMP.W	D6,D5	JUMP',GE XY22$	NEG.W	D4XY22$:	ADD.W	D5,D4	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	TEST.W	D4	JUMP',NC XY31$	NEG.W	D4XY31$:	COMP.W	D6,D5	JUMP',GE XY32$	NEG.W	D4XY32$:	ADD.W	D5,D4	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	COMP.W	D3,#1	JUMP',EQ XY41$	COMP.W	D3,#2	JUMP',NE XY42$XY41$:	LOAD.W	D6,D5XY42$:	COMP.W	D3,#1	JUMP',EQ XY43$	COMP.W	D3,#3	JUMP',NE XY44$XY43$:	SWAP.W	D5	SWAP.W	D6	LOAD.W	D6,D5	SWAP.W	D6	SWAP.W	D5XY44$:	JUMP	EXIT$LG$:	CALL	RGAJUSTLG	LOAD.W	D0,D4		; D0 <-- longueur  obtenir	SUB.W	D6,D5	SWAP.W	D5	SWAP.W	D6	SUB.W	D6,D5	SWAP.W	D5	SWAP.W	D6	LOAD.L	D4,D6	CALL	RGAJUSTLG	LOAD.W	D1,D4		; D1 <-- longueur actuelle	JUMP,EQ EXIT$	LOAD.W	D3,D6	MUL.WA	D3,D0	DIV.WA	D3,D1	LOAD.W	D6,D3	SWAP.W	D6	LOAD.W	D3,D6	MUL.WA	D3,D0	DIV.WA	D3,D1	LOAD.W	D6,D3	SWAP.W	D6	ADD.W	D6,D5	SWAP.W	D5	SWAP.W	D6	ADD.W	D6,D5	SWAP.W	D5	SWAP.W	D6	JUMP	EXIT$ANG$:	ADD.W	D4,D5	SWAP.W	D4	SWAP.W	D5	ADD.W	D4,D5	SWAP.W	D4	SWAP.W	D5	LOAD.L	D3,D5	LOAD.L	D5,D6	LOAD.W	D6,#-1	CALL	CALCSYTOUR	LOAD.L	D4,D5	CALL	CALCPSYM	LOAD.L	D6,D4;	JUMP	EXIT$EXIT$:	POPM.L	D0..D5	RET;----------\\; RGAJUSTLG >;----------/; Donne la longueur d'une droite dy;dx, en optimisant (+ de prcision); si elle est horizontale ou verticale.; in	D4.L	+/- dplacement (dy;dx); out	D4.W	+ longueur; mod	D4.L, D7.WRGAJUSTLG:	PUSH.L	D3	LOAD.L	D3,D4	AND.L	D3,#H'FFFF0000	; dy nul ?	JUMP',EQ 50$		; oui => 50$	LOAD.W	D3,D4	SWAP.W	D4	TEST.W	D3		; dx nul ?	JUMP',EQ 50$		; oui => 50$	LOAD.L	D3,D4	LIB	?CALCHYPO	; D4 <-- longueur50$:	TEST.W	D4	JUMP',NC 90$	NEG.W	D4		; D4 <-- |longueur|90$:	POP.L	D3	RET;--------\\; RGINVL  >;========/; Inverse la ligne pointille de la rgle de mesure.; in	D5.L	dpart (y;x);	D3.L	arrive (y;x); out	-; mod	D7.WRGINVL:	PUSHM.L	D2..D4	COMP.L	D3,D5	JUMP',EQ 90$	CALL	OPEWDO	CALL	CCMO	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT	LOAD.L	D4,D3	LOAD.L	D3,D5	CALL	FLECHE2		; inverse la ligne	CALL	CLOWDO90$:	POPM.L	D2..D4	RET;-----------\\; OBFRAGMENT >;===========/; Fragmente un objet.; in	A4.L	^objet;	D2.W	opration (0..1); out	D7.W	erreur; mod	D7.WOBFRAGMENT:	PUSHM.L	D0..D6,A3,A4	LOAD.W	D7,#1	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ EXIT$	TEST.W	D2	JUMP,EQ LINE$	COMP.W	D2,#1	JUMP,EQ CURVE$	JUMP	EXIT$LINE$:	LOAD.L	A3,A4	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	_OBJ_LINSERT	; insre un nouvel objet	JUMP,NE EXIT$	LOAD.W	(A3)+OOBTYP,#xcOPLINE	LOAD.W	(A4)+OOBTYP,#xcOPLINE	LOAD.L	(A4)+OOBPP2,(A3)+OOBPP2	LOAD.L	D3,(A3)+OOBPP1	LOAD.L	D4,(A3)+OOBPP2	CALL	CALCPMILIEU	LOAD.L	(A3)+OOBPP2,D4	LOAD.L	(A4)+OOBPP1,D4;	LOAD.L	(A3)+OOBPS1,(A3)+OOBPP1	LOAD.L	(A3)+OOBPS2,(A3)+OOBPP2	LOAD.L	(A4)+OOBPS1,(A4)+OOBPP1	LOAD.L	(A4)+OOBPS2,(A4)+OOBPP2	JUMP	EXIT$CURVE$:	LOAD.L	A3,A4	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	_OBJ_LINSERT	; insre un nouvel objet	JUMP,NE EXIT$	LOAD.W	(A3)+OOBTYP,#xcOPCURVE	LOAD.W	(A4)+OOBTYP,#xcOPCURVE	LOAD.L	(A4)+OOBPP2,(A3)+OOBPP2	LOAD.L	D3,(A3)+OOBPS1	LOAD.L	D4,(A3)+OOBPS2	CALL	CALCPMILIEU	LOAD.L	D0,D4	LOAD.L	D3,(A3)+OOBPP1	LOAD.L	D4,(A3)+OOBPS1	CALL	CALCPMILIEU	LOAD.L	D1,D4	LOAD.L	D3,(A3)+OOBPP2	LOAD.L	D4,(A3)+OOBPS2	CALL	CALCPMILIEU	LOAD.L	D2,D4	LOAD.L	D3,D0	LOAD.L	D4,D1	CALL	CALCPMILIEU	LOAD.L	D5,D4	LOAD.L	D3,D0	LOAD.L	D4,D2	CALL	CALCPMILIEU	LOAD.L	D6,D4	LOAD.L	D3,D5	LOAD.L	D4,D6	CALL	CALCPMILIEU	LOAD.L	(A3)+OOBPS1,D1	LOAD.L	(A3)+OOBPS2,D5	LOAD.L	(A3)+OOBPP2,D4	LOAD.L	(A4)+OOBPP1,D4	LOAD.L	(A4)+OOBPS1,D6	LOAD.L	(A4)+OOBPS2,D2;	JUMP	EXIT$EXIT$:	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; OBTRANS >;========/; Transforme un objet.; in	A4.L	^objet;	D2.W	opration (0..3); out	D7.W	erreur; mod	D7.WOBTRANS:	PUSHM.L	D2..D4,A2..A4	TEST.W	D2	JUMP,EQ LINE$	COMP.W	D2,#1	JUMP,EQ CURVE1$	COMP.W	D2,#2	JUMP,EQ CURVE2$	COMP.W	D2,#3	JUMP,EQ CURVE2$	LOAD.W	D7,#1	JUMP	EXIT$LINE$:	LOAD.W	(A4)+OOBTYP,#xcOPLINE	LOAD.L	(A4)+OOBPS1,(A4)+OOBPP1	LOAD.L	(A4)+OOBPS2,(A4)+OOBPP2	JUMP	EXIT$CURVE1$:	LOAD.W	(A4)+OOBTYP,#xcOPCURVE	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBPP2	CALL	CALCPMILIEU	LOAD.L	(A4)+OOBPS1,D4	LOAD.L	(A4)+OOBPS2,(A4)+OOBPP2	CLR.W	D7		; D7 <-- ok	JUMP	EXIT$CURVE2$:	LOAD.L	A3,A4	LOAD.W	D3,#OOBPP1	CALL	SRCJOINT	; A4 <-- ^objet jointif prcdent	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^objet jointif prcdent	LOAD.W	D3,#OOBPP2	CALL	SRCJOINT	; A4 <-- ^objet jointif suivant	JUMP,NE EXIT$	LOAD.W	(A3)+OOBTYP,#xcOPCURVE	LOAD.L	D3,(A2)+OOBPP2	LOAD.L	D4,(A2)+OOBPP1	COMP.W	(A2)+OOBTYP,#xcOPCURVE	JUMP',NE CURVE21$	LOAD.L	D4,(A2)+OOBPS2CURVE21$:	CALL	CALCPSYM	LOAD.L	(A3)+OOBPS1,D4	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBPP2	COMP.W	(A4)+OOBTYP,#xcOPCURVE	JUMP',NE CURVE22$	LOAD.L	D4,(A4)+OOBPS1CURVE22$:	CALL	CALCPSYM	LOAD.L	(A3)+OOBPS2,D4	CLR.W	D7		; D7 <-- ok;	JUMP	EXIT$EXIT$:	POPM.L	D2..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; OBINV  >;=======/; Inverse l'objet montr par la souris.; in	A4.L	^objet/nil; out	-; mod	D7.WOBINV:	PUSHM.L	D2..D6	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	COMP.L	A4,#0	JUMP,EQ EXIT$	LIB	?AFTIM	.B	MAPTT	.B	B'11001100	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	JUMP'	EXIT$LINE$:	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBPP2	CALL	LINE	JUMP'	EXIT$CURVE$:	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBPS1	LOAD.L	D5,(A4)+OOBPS2	LOAD.L	D6,(A4)+OOBPP2	CALL	CURVE;	JUMP'	EXIT$EXIT$:	CALL	CLOWDO		; dessine normalement	POPM.L	D2..D6	RET;-------\\; OBDET  >;=======/; Cherche quel est l'objet montr par la souris.; in	D4.L	position de la souris (y;x); out	A4.L	^objet montr/nil;	D7.W	erreur; mod	D7.W, A4.LOBDET:	PUSHM.L	D6	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP',EQ ERROR$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE ERROR$LOOP$:	CALL	OBDETONE	; souris dans cet objet ?	JUMP',EQ EXIT$		; oui => EXIT$	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$ERROR$:	LOAD.L	A4,#0		; A4 <-- nil	LOAD.W	D7,#1		; D7 <-- pas trouvEXIT$:	POPM.L	D6	TEST.W	D7		; retour EQ/NE	RET;---------\\; OBDETONE >;---------/; Regarde si la souris est dans un objet.; in	A4.L	^objet;	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WOBDETONE:	PUSHM.L	D3..D5	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	LOAD.W	D7,#1		; D7 <-- pas trouv	JUMP'	EXIT$LINE$:	LOAD.L	D5,D4	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBPP2	CALL	DETSEGMENT	; souris dans le segment ?	JUMP'	EXIT$CURVE$:	CALL	OBDETCURVE	; souris dans la courbe ?;	JUMP'	EXIT$EXIT$:	POPM.L	D3..D5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; OBDETCURVE >;-----------/; Regarde si la souris dans dans une courbe de bezier.; in	A4.L	^objet courbe de bzier;	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WOBDETCURVE:	PUSHM.L	D2..D5,A3,A4	LOAD.L	A3,A4		; A3 <-- ^objet	LOAD.L	D5,D4		; D5 <-- position de la souris	SUB.L	SP,#LBZI	LOAD.L	A4,SP		; A4 <-- ^variables sur le stack	LOAD.L	(A4)+OBZP1I,(A3)+OOBPP1	LOAD.L	(A4)+OBZC1I,(A3)+OOBPS1	LOAD.L	(A4)+OBZC2I,(A3)+OOBPS2	LOAD.L	(A4)+OBZP2I,(A3)+OOBPP2	CLR.W	D4	LOAD.L	D2,(A3)+OOBPP1LOOP$:	CALL	BZPOINTI	; D3 <-- point (y;x)	EX.L	D2,D4	CALL	DETSEGMENT	EX.L	D4,D2	JUMP',EQ EXIT$	LOAD.L	D2,D3	ADD.W	D4,#8	COMP.W	D4,#256	JUMP,LS LOOP$	LOAD.W	D7,#1		; D7 <-- ailleurEXIT$:	ADD.L	SP,#LBZI	POPM.L	D2..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZOZOOM  >;========/; Zoom tous les points slectionns.; in	D0.L	dpart (y;x);	D1.L	arrive (y;x);	D2.W	opration (0..6); out	D7.W	erreur; mod	D7.WZOZOOM:	PUSHM.L	D0,D1,D3,D6,A4	COMP.W	D2,#6		; autre.. ?	JUMP',NE NORM$		; non => NORM$	CALL	DBOXZOOM	; demande le zoom spcial ...	JUMP,NE EXIT$	LOAD.W	D7,#ERKSTO	COMP.W	D3,#F1	JUMP,NE EXIT$NORM$:	SUB.W	D1,D0	ASR.W	D1,#1	ADD.W	D0,D1		; D0 <-- centre en X	SWAP.W	D0	SWAP.W	D1	SUB.W	D1,D0	ASR.W	D1,#1	ADD.W	D0,D1		; D0 <-- centre en Y	SWAP.W	D0	SWAP.W	D1	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE END$LOOP$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	JUMP'	NEXT$LINE$:CURVE$:	TEST.B	(A4)+OOBPP1+4	JUMP',EQ PP2$	LOAD.W	D3,#OOBPP1	CALL	ZOZOOMONE	LOAD.W	D3,#OOBPS1	CALL	ZOZOOMONEPP2$:	TEST.B	(A4)+OOBPP2+4	JUMP',EQ NEXT$	LOAD.W	D3,#OOBPP2	CALL	ZOZOOMONE	LOAD.W	D3,#OOBPS2	CALL	ZOZOOMONE;	JUMP'	NEXT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0,D1,D3,D6,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; ZOZOOMONE >;----------/; Effectue un zoom sur un point.; in	A4.L	^objet;	D3.W	offset;	D2.W	opration (0..6);	D0.L	centre (y;x); out	-; mod	D7.WZOZOOMONE:	PUSHM.L	D0,D4	COMP.W	D2,#6		; autre.. ?	JUMP,EQ 50$		; oui => 50$	LOAD.L	D4,(A4)+(D3.W)	COMP.W	D2,#0	JUMP',EQ 20$	COMP.W	D2,#1	JUMP',NE 22$20$:				; *2 en X =>	SUB.W	D4,D0	ASL.W	D4,#1	ADD.W	D4,D022$:	COMP.W	D2,#3	JUMP',EQ 24$	COMP.W	D2,#4	JUMP',NE 26$24$:				; */ en X =>	SUB.W	D4,D0	ASR.W	D4,#1	ADD.W	D4,D026$:	SWAP.W	D0	SWAP.W	D4	COMP.W	D2,#0	JUMP',EQ 30$	COMP.W	D2,#2	JUMP',NE 32$30$:				; *2 en Y =>	SUB.W	D4,D0	ASL.W	D4,#1	ADD.W	D4,D032$:	COMP.W	D2,#3	JUMP',EQ 34$	COMP.W	D2,#5	JUMP',NE 36$34$:				; */ en Y =>	SUB.W	D4,D0	ASR.W	D4,#1	ADD.W	D4,D036$:	SWAP.W	D0	SWAP.W	D4	LOAD.L	(A4)+(D3.W),D4	JUMP'	90$50$:				; autre =>	TEST.B	(A6)+OFAZOOM+3:#1	JUMP',BC 52$	CLR.L	D0		; D0 <-- centre selon origine52$:	LOAD.W	D4,(A4)+(D3.W)+2	SUB.W	D4,D0	MUL.WA	D4,(A6)+OXZOOM	DIV.WA	D4,#1000	ADD.W	D4,D0	LOAD.W	(A4)+(D3.W)+2,D4	SWAP.W	D0	LOAD.W	D4,(A4)+(D3.W)+0	SUB.W	D4,D0	MUL.WA	D4,(A6)+OYZOOM	DIV.WA	D4,#1000	ADD.W	D4,D0	LOAD.W	(A4)+(D3.W)+0,D4;	JUMP'	90$90$:	POPM.L	D0,D4	RET;---------\\; ZOTOURNE >;=========/; Tourne tous les points slectionns.; in	D0.L	dpart (y;x);	D1.L	arrive (y;x);	D2.W	opration (0..2); out	-; mod	D7.WZOTOURNE:	PUSHM.L	D0,D1,D3,D6,A4	SUB.W	D1,D0	ASR.W	D1,#1	ADD.W	D0,D1		; D0 <-- centre en X	SWAP.W	D0	SWAP.W	D1	SUB.W	D1,D0	ASR.W	D1,#1	ADD.W	D0,D1		; D0 <-- centre en Y	SWAP.W	D0	SWAP.W	D1	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE END$LOOP$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	JUMP'	NEXT$LINE$:CURVE$:	TEST.B	(A4)+OOBPP1+4	JUMP',EQ PP2$	LOAD.W	D3,#OOBPP1	CALL	ZOTOURNEONE	LOAD.W	D3,#OOBPS1	CALL	ZOTOURNEONEPP2$:	TEST.B	(A4)+OOBPP2+4	JUMP',EQ NEXT$	LOAD.W	D3,#OOBPP2	CALL	ZOTOURNEONE	LOAD.W	D3,#OOBPS2	CALL	ZOTOURNEONE;	JUMP'	NEXT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	POPM.L	D0,D1,D3,D6,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; ZOTOURNEONE >;------------/; Effectue une rotation sur un point.; in	A4.L	^objet;	D3.W	offset;	D2.W	opration (0..2);	D0.L	centre (y;x); out	-; mod	D7.WZOTOURNEONE:	PUSHM.L	D2,D4	LOAD.L	D4,(A4)+(D3.W)20$:	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D4	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D4	DEC.W	D2	JUMP,NC 20$	LOAD.L	(A4)+(D3.W),D4	POPM.L	D2,D4	RET;---------\\; ZOMIROIR >;=========/; Symtrise tous les points slectionns.; in	D0.L	dpart (y;x);	D1.L	arrive (y;x);	D2.W	opration (0..1); out	-; mod	D7.WZOMIROIR:	PUSHM.L	D0,D1,D3,D6,A4	SUB.W	D1,D0	ASR.W	D1,#1	ADD.W	D0,D1		; D0 <-- centre en X	SWAP.W	D0	SWAP.W	D1	SUB.W	D1,D0	ASR.W	D1,#1	ADD.W	D0,D1		; D0 <-- centre en Y	SWAP.W	D0	SWAP.W	D1	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE END$LOOP$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	JUMP'	NEXT$LINE$:CURVE$:	TEST.B	(A4)+OOBPP1+4	JUMP',EQ PP2$	LOAD.W	D3,#OOBPP1	CALL	ZOMIROIRONE	LOAD.W	D3,#OOBPS1	CALL	ZOMIROIRONEPP2$:	TEST.B	(A4)+OOBPP2+4	JUMP',EQ NEXT$	LOAD.W	D3,#OOBPP2	CALL	ZOMIROIRONE	LOAD.W	D3,#OOBPS2	CALL	ZOMIROIRONE;	JUMP'	NEXT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	POPM.L	D0,D1,D3,D6,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; ZOMIROIRONE >;------------/; Effectue une symtrie sur un point.; in	A4.L	^objet;	D3.W	offset;	D2.W	opration (0..1);	D0.L	centre (y;x); out	-; mod	D7.WZOMIROIRONE:	PUSH.L	D4	LOAD.L	D4,(A4)+(D3.W)	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	NEG.W	D4	TEST.W	D2	JUMP',NE 30$	NEG.W	D4	SWAP.W	D4	NEG.W	D4	SWAP.W	D430$:	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D4	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.L	(A4)+(D3.W),D4	POP.L	D4	RET;-------------\\; ZOIFDUPLIQUE >;=============/; Vrifie s'il est possible de dupliquer les points slectionns.; in	-; out	D7.W	erreur; mod	D7.WZOIFDUPLIQUE:	PUSHM.L	D3,D6,A4	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ ERROR$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE ERROR$LOOP$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	JUMP	NEXT$LINE$:CURVE$:	TEST.B	(A4)+OOBPP1+4	JUMP',NE VERIF$	TEST.B	(A4)+OOBPP2+4	JUMP',NE VERIF$	JUMP	NEXT$VERIF$:	TEST.B	(A4)+OOBPP1+4	JUMP',EQ ERROR$	TEST.B	(A4)+OOBPP2+4	JUMP',EQ ERROR$	LOAD.W	D3,#OOBPP1	CALL	ZOIFDUPLONE	JUMP',NE ERROR$	LOAD.W	D3,#OOBPP2	CALL	ZOIFDUPLONE	JUMP',NE ERROR$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$OK$:	CLR.W	D7	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1EXIT$:	POPM.L	D3,D6,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; ZOIFDUPLONE >;------------/; Regarde si l'objet jointif est slectionn.; in	A4.L	^objet;	D3.W	offset; out	D7.W	erreur; mod	D7.WZOIFDUPLONE:	PUSHM.L	A3,A4	LOAD.L	A3,A4	CALL	SRCJOINT	; A4 <-- ^objet jointif	JUMP',NE ERROR$	TEST.B	(A4)+OOBPP1+4	JUMP',EQ ERROR$	TEST.B	(A4)+OOBPP2+4	JUMP',EQ ERROR$OK$:	CLR.W	D7	JUMP'	END$ERROR$:	LOAD.W	D7,#1END$:	POPM.L	A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ZODUPLIQUE >;===========/; Duplique tous les objets ayant un point slectionn.; in	-; out	D2.W	nb d'objets dupliqus; mod	D2.L, D7.WZODUPLIQUE:	PUSHM.L	D1,D3,D4,D6,A3,A4	CLR.W	D1		; D1 <-- nb d'objets dupliqus	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE END$LOOP$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	COMP.W	D3,#xcOPADDCHAR	JUMP',EQ ADDCHAR$	JUMP	NEXT$LINE$:CURVE$:	TEST.B	(A4)+OOBPP1+4	JUMP',NE DUPL$	TEST.B	(A4)+OOBPP2+4	JUMP',NE DUPL$	JUMP	NEXT$ADDCHAR$:	TEST.B	(A4)+OOBPP1+4	JUMP',NE DUPL$	JUMP	NEXT$DUPL$:	LOAD.L	A3,A4	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	_OBJ_LINSERT	; insre un nouvel objet	EX.L	A3,A4	JUMP',NE NEXT$	PUSHM.L	A3,A4	SR.W	D4,#1	DEC.W	D4DUPL3$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,DUPL3$	POPM.L	A3,A4	CLR.B	(A3)+OOBPP1+4	CLR.B	(A3)+OOBPP2+4	CALL	DESOBJET	; efface l'objet double	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTROND	CALL	IPTQQ		; efface la poigne	INC.W	D1		; D1 <-- un objet dupliqu de plusNEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	LOAD.W	D2,D1		; D2 <-- nb d'objets dupliqus	POPM.L	D1,D3,D4,D6,A3,A4	RET;----------\\; ZODEPLACE >;==========/; Dplace tous les objets ayant un point slectionn.; in	D4.L	+/- dplacement (dy;dx); out	-; mod	D7.WZODEPLACE:	PUSHM.L	D2,D3,D6,A4	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE END$LOOP$:	CLR.W	D2	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	COMP.W	D3,#xcOPADDCHAR	JUMP',EQ ADDCHAR$	JUMP'	NEXT$LINE$:CURVE$:	LOAD.W	D3,#OOBPP1	CALL	ZODEPLACEONE	LOAD.W	D3,#OOBPP2	CALL	ZODEPLACEONE	JUMP'	DRAW$ADDCHAR$:	LOAD.W	D3,#OOBPP1	CALL	ZODEPLACEONE;	JUMP'	DRAW$DRAW$:	TEST.W	D2	JUMP',EQ NEXT$	CALL	DESOBJET	; dessine le nouvel objetNEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	CALL	CLOWDO		; dessine normalement	POPM.L	D2,D3,D6,A4	RET;-------------\\; ZODEPLACEONE >;-------------/; Dplace un point s'il est slectionn.; in	A4.L	^objet;	D3.W	offset;	D4.L	+/- dplacement (dy;dx);	D2.W	nb de points dplacs; out	D2.W	v. +1; mod	D2.L, D7.WZODEPLACEONE:	TEST.B	(A4)+(D3.W)+4	; point slectionn ?	JUMP',EQ 90$		; non => 90$	TEST.W	D2	JUMP',NE 20$	CALL	DESOBJET	; efface l'ancien objet20$:	ADD.W	(A4)+(D3.W)+2,D4	SWAP.W	D4	ADD.W	(A4)+(D3.W)+0,D4	SWAP.W	D4	ADD.W	(A4)+(D3.W)+(OOBPS1-OOBPP1)+2,D4	SWAP.W	D4	ADD.W	(A4)+(D3.W)+(OOBPS1-OOBPP1)+0,D4	SWAP.W	D4	INC.W	D290$:	RET;----------\\; ZODETRUIT >;==========/; Dtruit tous les objets ayant un point slectionn.; in	-; out	-; mod	D7.WZODETRUIT:	PUSHM.L	D3,D6,A4BEGIN$:	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE END$LOOP$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	COMP.W	D3,#xcOPADDCHAR	JUMP',EQ ADDCHAR$	JUMP'	NEXT$LINE$:CURVE$:	TEST.B	(A4)+OOBPP1+4	JUMP',NE DEL$	TEST.B	(A4)+OOBPP2+4	JUMP',NE DEL$	JUMP'	NEXT$ADDCHAR$:	TEST.B	(A4)+OOBPP1+4	JUMP',NE DEL$;	JUMP'	NEXT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$	JUMP	END$DEL$:	CALL	ZODETRUITONE	JUMP	BEGIN$END$:	POPM.L	D3,D6,A4	RET;-------------\\; ZODETRUITONE >;-------------/; Dtruit un objet en ajustant au mieux les objets jointifs prcdent; et suivant.; in	A4.L	^objet  dtruire; out	-; mod	D7.WZODETRUITONE:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A3,A4		; A3 <-- ^objet milieu	LOAD.W	D3,#OOBPP1	CALL	SRCJOINT	; A4 <-- ^objet jointif prcdent	JUMP,NE SINGLE$	LOAD.L	A2,A4		; A2 <-- ^objet jointif prcdent	COMP.W	(A2)+OOBTYP,#xcOPLINE	JUMP',EQ PREV$	COMP.W	(A2)+OOBTYP,#xcOPCURVE	JUMP,NE SINGLE$PREV$:	LOAD.W	D3,#OOBPP2	CALL	SRCJOINT	; A4 <-- ^objet jointif suivant	JUMP,NE SINGLE$	COMP.W	(A4)+OOBTYP,#xcOPLINE	JUMP',EQ NEXT$	COMP.W	(A4)+OOBTYP,#xcOPCURVE	JUMP,NE SINGLE$NEXT$:	COMP.L	A2,A4		; objet suivant = prcdent ?	JUMP,EQ TWO$	TEST.B	(A3)+OOBPP1+4	JUMP',NE APP2$APP1$:	CLR.B	(A4)+OOBPP1+4	; dslectionne le point	CLR.B	(A4)+OOBPP2+4	; dslectionne le point	LOAD.L	(A4)+OOBPP1,(A2)+OOBPP2	COMP.W	(A2)+OOBTYP,#xcOPLINE	JUMP',NE APP1C$	COMP.W	(A4)+OOBTYP,#xcOPLINE	JUMP',NE APP1LC$APP1LL$:			; A2(line) - A4(line) =>	LOAD.L	(A4)+OOBPS1,(A2)+OOBPP2	JUMP	ONE$APP1LC$:			; A2(line) - A4(curve) =>	LOAD.L	D3,(A2)+OOBPP2	LOAD.L	D4,(A2)+OOBPP1	CALL	CALCPSYM	LOAD.L	(A4)+OOBPS1,D4	JUMP	ONE$APP1C$:	COMP.W	(A4)+OOBTYP,#xcOPLINE	JUMP',NE APP1CC$APP1CL$:			; A2(curve) - A4(line) =>	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBPP2	CALL	CALCPSYM	LOAD.L	(A2)+OOBPS2,D4	JUMP	ONE$APP1CC$:			; A2(curve) - A4(curve) =>	LOAD.L	D3,(A2)+OOBPP2	LOAD.L	D4,(A2)+OOBPS2	CALL	CALCPSYM	LOAD.L	(A4)+OOBPS1,D4	JUMP	ONE$APP2$:	CLR.B	(A2)+OOBPP1+4	; dslectionne le point	CLR.B	(A2)+OOBPP2+4	; dslectionne le point	LOAD.L	(A2)+OOBPP2,(A4)+OOBPP1	COMP.W	(A2)+OOBTYP,#xcOPLINE	JUMP',NE APP2C$	COMP.W	(A4)+OOBTYP,#xcOPLINE	JUMP',NE APP2LC$APP2LL$:			; A2(line) - A4(line) =>	LOAD.L	(A2)+OOBPS2,(A4)+OOBPP1	JUMP	ONE$APP2LC$:			; A2(line) - A4(curve) =>	LOAD.L	D3,(A2)+OOBPP2	LOAD.L	D4,(A2)+OOBPP1	CALL	CALCPSYM	LOAD.L	(A4)+OOBPS1,D4	JUMP	ONE$APP2C$:	COMP.W	(A4)+OOBTYP,#xcOPLINE	JUMP',NE APP2CC$APP2CL$:			; A2(curve) - A4(line) =>	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBPP2	CALL	CALCPSYM	LOAD.L	(A2)+OOBPS2,D4	JUMP	ONE$APP2CC$:			; A2(curve) - A4(curve) =>	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBPS1	CALL	CALCPSYM	LOAD.L	(A2)+OOBPS2,D4	JUMP	ONE$ONE$:	EX.L	A4,A3	CALL	_OBJ_LREMOVE	; supprime l'objet milieu	LOAD.L	A4,A3	LOAD.L	D3,(A2)+OOBPP1	COMP.L	D3,(A4)+OOBPP2	JUMP',NE EXIT$	COMP.W	(A2)+OOBTYP,#xcOPLINE	JUMP',NE EXIT$	COMP.W	(A4)+OOBTYP,#xcOPLINE	JUMP',NE EXIT$				; reste deux droites identiques =>	CALL	_OBJ_LREMOVE	; supprime l'objet suivant	LOAD.L	A4,A2	CALL	_OBJ_LREMOVE	; supprime l'objet prcdent	JUMP'	EXIT$TWO$:	CALL	_OBJ_LREMOVE	; supprime l'objet suivant-prcdentSINGLE$:	LOAD.L	A4,A3	CALL	_OBJ_LREMOVE	; supprime l'objet milieuEXIT$:	POPM.L	D3,D4,A2..A4	RET;-----------\\; ZOUNSELECT >;===========/; Dslectionne tous les points slectionns.; in	D0.L	dpart (y;x);	D1.L	arrive (y;x); out	D7.W	erreur; mod	D7.WZOUNSELECT:	PUSHM.L	D3,D6,A4	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE END$LOOP$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	COMP.W	D3,#xcOPADDCHAR	JUMP',EQ ADDCHAR$	JUMP'	NEXT$LINE$:CURVE$:	CLR.B	(A4)+OOBPP1+4	; dslectionne le point	CLR.B	(A4)+OOBPP2+4	; dslectionne le point	JUMP'	NEXT$ADDCHAR$:	CLR.B	(A4)+OOBPP1+4	; dslectionne le point;	JUMP'	NEXT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	POPM.L	D3,D6,A4	RET;---------\\; ZOSELECT >;=========/; Slectionne tous les points qui sont dans la zone de slection.; in	D0.L	dpart (y;x);	D1.L	arrive (y;x); out	D7.W	erreur; mod	D7.WZOSELECT:	PUSHM.L	D0..D3,D6,A4	COMP.W	D0,D1	JUMP',LE OKX$	LOAD.W	D4,D0	LOAD.W	D0,D1		; EX.W D0,D1	LOAD.W	D1,D4OKX$:	SWAP.W	D0	SWAP.W	D1	COMP.W	D0,D1	JUMP',LE OKY$	LOAD.W	D4,D0	LOAD.W	D0,D1		; EX.W D0,D1	LOAD.W	D1,D4OKY$:	SWAP.W	D0	SWAP.W	D1	CLR.W	D2		; D2 <-- nb de points slectionns	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE END$LOOP$:	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	COMP.W	D3,#xcOPADDCHAR	JUMP',EQ ADDCHAR$	JUMP'	NEXT$LINE$:CURVE$:	LOAD.W	D3,#OOBPP1	CALL	ZOSELPOINT	LOAD.W	D3,#OOBPP2	CALL	ZOSELPOINT	JUMP'	NEXT$ADDCHAR$:	LOAD.W	D3,#OOBPP1	CALL	ZOSELPOINT;	JUMP'	NEXT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	LOAD.W	D7,#1		; D7 <-- rien	TEST.W	D2		; y a-t-il des points slectionns ?	JUMP',EQ EXIT$		; non => exit$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D3,D6,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ZOSELPOINT >;-----------/; Slectionne ventuellement un point.; in	A4.L	^objet;	D3.W	offset;	D0.L	dpart (y;x);	D1.L	arrive (y;x);	D2.W	nb de points slectionns; out	D2.W	v. +1; mod	D2.L, D7.WZOSELPOINT:	PUSH.L	D4	LOAD.L	D4,(A4)+(D3.W)	CALL	ZODET	JUMP',NE 90$	SET.B	(A4)+(D3.W)+4	; slectionne le point	INC.W	D2		; D2 <-- un point slectionn de plus90$:	POP.L	D4	RET;--------\\; ZODET   >;--------/; Regarde si un point est dans la zone rectangulaire de slection.; in	D0.L	dpart (y;x);	D1.L	arrive (y;x);	D4.L	point (y;x); out	D7.W	erreur; mod	D7.WZODET:	PUSHM.L	D0,D1,D4	LOAD.W	D7,#1		; D7 <-- ailleur	COMP.W	D4,D0	JUMP',LT 90$	COMP.W	D4,D1	JUMP',GE 90$	SWAP.W	D0	SWAP.W	D1	SWAP.W	D4	COMP.W	D4,D0	JUMP',LT 90$	COMP.W	D4,D1	JUMP',GE 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZOINV   >;========/; Inverse la zone de slection rectangulaire.; in	D0.L	dpart (y;x);	D1.L	arrive (y;x); out	-; mod	D7.WZOINV:	PUSHM.L	D2..D4	COMP.L	D0,D1		; dpart = arrive ?	JUMP,EQ EXIT$		; oui => EXIT$	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	LIB	?AFTIM	.B	MAPTT	.B	B'11110000	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D3,D1	CALL	CONVPIPG	LOAD.L	D4,D3		; D4 <-- arrive [pg]	LOAD.L	D3,D0	CALL	CONVPIPG	; D3 <-- dpart [pg]	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT	CALL	CLOWDO		; dessine normalementEXIT$:	POPM.L	D2..D4	RET;--------\\; POINV   >;========/; Inverse les poignes slectionnes.; in	D3.L	centre (y;x);	D4.L	point (y;x); out	-; mod	D7.WPOINV:	PUSHM.L	D2..D5	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D5,D4	CALL	CALCPSYM	LOAD.W	D2,#INVDOT!TTTDOT	CALL	LINE	EX.L	D4,D5	CALL	LINE	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ	LOAD.L	D3,D4	CALL	IPTQQ	LOAD.L	D3,D5	CALL	IPTQQ	CALL	CLOWDO		; dessine normalement	POPM.L	D2..D5	RET;--------\\; PSSLECT >;========/; Slectionne un point.; in	-; out	D7.W	erreur; mod	D7.WPSSELECT:	PUSHM.L	D2..D5,A2..A4	LOAD.L	D5,#POSNIL	JUMP'	POS$LOOP$:	CALL	SCMO		; remet la souris	CALL	WAITMOVE	; attend dplacement ...	JUMP',NE END$POS$:	CALL	IFMOUSEW	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	DETPOINTS	; D3 <-- position exacte	COMP.L	D3,D5		; est-on toujours dans la mme poigne ?	JUMP,EQ LOOP$		; oui => LOOP$	EX.L	D3,D5	LOAD.W	D2,#TPTRONDHILI	CALL	IPTQQ		; efface l'ancienne poigne	LOAD.L	D3,D5	LOAD.W	D2,#TPTRONDHILI	CALL	IPTQQ		; allume la nouvelle poigne	JUMP	LOOP$END$:	LOAD.L	D3,D5	LOAD.W	D2,#TPTRONDHILI	CALL	IPTQQ		; efface la dernire poigne	LOAD.W	D7,#1		; D7 <-- pas trouv	COMP.L	D3,#POSNIL	JUMP,EQ EXIT$	LOAD.L	D3,D5	LOAD.W	D2,#TPTROND	CALL	IPTQQ		; efface la poigne ronde	LOAD.L	A3,#(A6)+OPSLST	LOAD.L	A2,A3SEL2$:	TEST.L	(A2)	JUMP',EQ SEL3$	ADD.L	A2,#4+2	JUMP	SEL2$SEL3$:	TEST.L	(A3)	JUMP',EQ SEL6$	LOAD.L	A4,(A3+)	; A4 <-- ^objet	LOAD.W	D4,(A3+)	; D4 <-- offset	COMP.W	(A4)+OOBTYP,#xcOPCURVE	JUMP,NE SEL3$	COMP.W	D4,#OOBPP1	JUMP',EQ SEL51$	COMP.W	D4,#OOBPP2	JUMP',EQ SEL52$	JUMP	SEL3$SEL51$:	LOAD.L	(A2+),A4	; OPSLST <-- ^objet	LOAD.W	(A2+),#OOBPS1	; OPSLST <-- offset	JUMP	SEL3$SEL52$:	LOAD.L	(A2+),A4	; OPSLST <-- ^objet	LOAD.W	(A2+),#OOBPS2	; OPSLST <-- offset	JUMP	SEL3$SEL6$:	CLR.L	(A2)		; OPSLST <-- terminateur	CALL	PSINV		; allume la nouvelle poigne slectionne	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; PSCANCEL >;=========/; Annule tous les objets slectionns.; in	-; out	-; mod	D7.WPSCANCEL:	PUSHM.L	D2,D3,A3,A4	LOAD.L	A3,#(A6)+OPSLST	TEST.L	(A3)	JUMP',EQ 90$	CALL	PSINV		; efface l'ancienne poigne slectionne	LOAD.L	A4,(A3+)	; A4 <-- ^objet	LOAD.W	D3,(A3+)	; D3 <-- offset	LOAD.L	D3,(A4)+(D3.W)	LOAD.W	D2,#TPTROND	CALL	IPTQQ		; allume la poigne ronde	LOAD.L	A3,#(A6)+OPSLST	CLR.L	(A3)		; y'a plus rien de slectionn90$:	POPM.L	D2,D3,A3,A4	RET;-------\\; PSDES  >;=======/; Dessine tous les objets slectionns.; in	-; out	-; mod	D7.WPSDES:	PUSHM.L	D2,D3,A3,A4	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	LOAD.L	A3,#(A6)+OPSLSTLOOP$:	TEST.L	(A3)	JUMP',EQ EXIT$	LOAD.L	A4,(A3+)	; A4 <-- ^objet	LOAD.W	D3,(A3+)	; D3 <-- offset	COMP.W	D3,#OOBPP1	JUMP',EQ DES$	COMP.W	D3,#OOBPP2	JUMP,NE LOOP$DES$:	LOAD.W	D2,#TPTNIL	CALL	DESOBJET	JUMP	LOOP$EXIT$:	CALL	CLOWDO		; dessine normalement	POPM.L	D2,D3,A3,A4	RET;---------\\; PSMOVEP  >;=========/; Dplace OOBPxx de tous les objets slectionns.; in	D4.L	+/- dplacement (dy;dx);	D2.W	offset (OOBPxx);	D6.W	longueur (-1 si inconnue); out	D6.W	longueur; mod	D6.L, D7.WPSMOVEP:	PUSHM.L	D2..D5,A1..A4	LOAD.L	A3,#(A6)+OPSLST	LOAD.L	A2,#0	COMP.W	D2,#OOBPS1	JUMP,EQ PS1$	COMP.W	D2,#OOBPS2	JUMP,EQ PS2$LOOP$:	TEST.L	(A3)	JUMP,EQ EXIT$	LOAD.L	A4,(A3+)	; A4 <-- ^objet	LOAD.W	D3,(A3+)	; D3 <-- offset	ADD.W	(A4)+(D3.W)+2,D4	SWAP.W	D4	ADD.W	(A4)+(D3.W)+0,D4	SWAP.W	D4	JUMP	LOOP$PS1$:	TEST.L	(A3)	JUMP',EQ PS14$	LOAD.L	A4,(A3+)	; A4 <-- ^objet	LOAD.W	D3,(A3+)	; D3 <-- offset	COMP.W	D3,#OOBPS1	JUMP',EQ PS12$	COMP.W	D3,#OOBPS2	JUMP,NE PS1$	LOAD.L	A2,A4		; A2 <-- ^objet symtrique	JUMP	PS1$PS12$:	LOAD.L	A1,A4		; A1 <-- ^objet principal	ADD.W	(A4)+OOBPS1+2,D4	SWAP.W	D4	ADD.W	(A4)+OOBPS1+0,D4	SWAP.W	D4	JUMP	PS1$PS14$:	COMP.L	A2,#0		; objet symtrique existe ?	JUMP,EQ EXIT$		; non => EXIT$	COMP.B	(A6)+ODEPLP,#ICODEPLP1	JUMP',EQ PS15$	COMP.B	(A6)+ODEPLP,#ICODEPLP3	JUMP,EQ EXIT$	LOAD.L	D3,(A1)+OOBPP1	LOAD.L	D4,(A1)+OOBPS1	LOAD.L	D5,(A2)+OOBPS2	CALL	CALCSYTOUR	LOAD.L	(A2)+OOBPS2,D5	JUMP	EXIT$PS15$:	LOAD.L	D3,(A1)+OOBPP1	LOAD.L	D4,(A1)+OOBPS1	CALL	CALCPSYM	LOAD.L	(A2)+OOBPS2,D4	JUMP	EXIT$PS2$:	TEST.L	(A3)	JUMP',EQ PS24$	LOAD.L	A4,(A3+)	; A4 <-- ^objet	LOAD.W	D3,(A3+)	; D3 <-- offset	COMP.W	D3,#OOBPS2	JUMP',EQ PS22$	COMP.W	D3,#OOBPS1	JUMP,NE PS2$	LOAD.L	A2,A4		; A2 <-- ^objet symtrique	JUMP	PS2$PS22$:	LOAD.L	A1,A4		; A1 <-- ^objet principal	ADD.W	(A4)+OOBPS2+2,D4	SWAP.W	D4	ADD.W	(A4)+OOBPS2+0,D4	SWAP.W	D4	JUMP	PS2$PS24$:	COMP.L	A2,#0		; objet symtrique existe ?	JUMP,EQ EXIT$		; non => EXIT$	COMP.B	(A6)+ODEPLP,#ICODEPLP1	JUMP',EQ PS25$	COMP.B	(A6)+ODEPLP,#ICODEPLP3	JUMP,EQ EXIT$	LOAD.L	D3,(A1)+OOBPP2	LOAD.L	D4,(A1)+OOBPS2	LOAD.L	D5,(A2)+OOBPS1	CALL	CALCSYTOUR	LOAD.L	(A2)+OOBPS1,D5	JUMP	EXIT$PS25$:	LOAD.L	D3,(A1)+OOBPP2	LOAD.L	D4,(A1)+OOBPS2	CALL	CALCPSYM	LOAD.L	(A2)+OOBPS1,D4	JUMP	EXIT$EXIT$:	POPM.L	D2..D5,A1..A4	RET;---------\\; PSCOPYPT >;=========/; Copie OOBPxx --> OOBTxx de tous les objets.; in	-; out	-; mod	D7.WPSCOPYPT:	PUSHM.L	D6,A4	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP',EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	LOAD.L	(A4)+OOBTP1,(A4)+OOBPP1	LOAD.L	(A4)+OOBTP2,(A4)+OOBPP2	LOAD.L	(A4)+OOBTS1,(A4)+OOBPS1	LOAD.L	(A4)+OOBTS2,(A4)+OOBPS2	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	POPM.L	D6,A4	RET;---------\\; PSCOPYTP >;=========/; Copie OOBTxx --> OOBPxx de tous les objets.; in	-; out	-; mod	D7.WPSCOPYTP:	PUSHM.L	D6,A4	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP',EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	LOAD.L	(A4)+OOBPP1,(A4)+OOBTP1	LOAD.L	(A4)+OOBPP2,(A4)+OOBTP2	LOAD.L	(A4)+OOBPS1,(A4)+OOBTS1	LOAD.L	(A4)+OOBPS2,(A4)+OOBTS2	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	POPM.L	D6,A4	RET;---------\\; PSEXCHPT >;=========/; Echange OOBPxx <--> OOBTxx de tous les objets.; in	-; out	-; mod	D7.WPSEXCHPT:	PUSHM.L	D4,D6,A4	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP',EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	LOAD.L	D4,(A4)+OOBTP1	LOAD.L	(A4)+OOBTP1,(A4)+OOBPP1	LOAD.L	(A4)+OOBPP1,D4	LOAD.L	D4,(A4)+OOBTP2	LOAD.L	(A4)+OOBTP2,(A4)+OOBPP2	LOAD.L	(A4)+OOBPP2,D4	LOAD.L	D4,(A4)+OOBTS1	LOAD.L	(A4)+OOBTS1,(A4)+OOBPS1	LOAD.L	(A4)+OOBPS1,D4	LOAD.L	D4,(A4)+OOBTS2	LOAD.L	(A4)+OOBTS2,(A4)+OOBPS2	LOAD.L	(A4)+OOBPS2,D4	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	POPM.L	D4,D6,A4	RET;--------\\; PSINV   >;========/; Inverse les poignes slectionnes.; in	-; out	-; mod	D7.WPSINV:	PUSHM.L	D2..D5,A3,A4	LOAD.L	A3,#(A6)+OPSLST	TEST.L	(A3)	JUMP,EQ 90$	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D5,#POSNIL20$:	TEST.L	(A3)	JUMP,EQ 80$	LOAD.L	A4,(A3+)	; A4 <-- ^objet	LOAD.W	D4,(A3+)	; D4 <-- offset	LOAD.L	D3,(A4)+(D4.W)	; D3 <-- position	COMP.L	D3,D5	JUMP,EQ 20$	COMP.L	D5,#POSNIL	JUMP',NE 30$	LOAD.L	D5,D330$:	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; inverse la poigne carre	COMP.W	D4,#OOBPS1	JUMP',EQ 40$	COMP.W	D4,#OOBPS2	JUMP,NE 20$40$:	LOAD.L	D4,D5	LOAD.W	D2,#INVDOT!TTTDOT	CALL	LINE	JUMP	20$80$:	CALL	CLOWDO		; dessine normalement90$:	POPM.L	D2..D5,A3,A4	RET;----------\\; DETPOINTS >;==========/; Dtecte tous les objets o est la souris.; in	D4.L	point o est la souris (y;x) [pg]; out	D3.L	point exact [pi];	D7.W	erreur; mod	D3.L, D7.WDETPOINTS:	PUSHM.L	D1,D2,D6,A3,A4	LOAD.L	A3,#(A6)+OPSLST	LOAD.L	D2,#POSNIL	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE END$LOOP$:	LOAD.W	D1,#OOBPP1	LOAD.L	D3,(A4)+(D1.W)	CALL	DETPOINT	JUMP',EQ POINT$	LOAD.W	D1,#OOBPP2	LOAD.L	D3,(A4)+(D1.W)	CALL	DETPOINT	JUMP',EQ POINT$	COMP.B	(A6)+OOUTIL,#ICOREGLE	JUMP',NE NEXT$	COMP.W	(A4)+OOBTYP,#xcOPCURVE	JUMP',NE NEXT$	LOAD.W	D1,#OOBPS1	LOAD.L	D3,(A4)+(D1.W)	CALL	DETPOINT	JUMP',EQ POINT$	LOAD.W	D1,#OOBPS2	LOAD.L	D3,(A4)+(D1.W)	CALL	DETPOINT	JUMP',NE NEXT$POINT$:	COMP.L	D2,#POSNIL	; premier point ?	JUMP',EQ PUT$		; oui => PUT$	COMP.L	D2,D3		; exactement la mme coordonne ?	JUMP',NE NEXT$		; non => NEXT$PUT$:	LOAD.L	(A3+),A4	; OPSLST <-- ^objet	LOAD.W	(A3+),D1	; OPSLST <-- offset	LOAD.L	D2,D3	COMP.W	(A4)+OOBTYP,#xcOPADDCHAR	JUMP',EQ END$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	CLR.L	(A3)		; OPSLST <-- terminateur	CLR.W	D7	LOAD.L	D3,D2		; D3 <-- point exact	COMP.L	D3,#POSNIL	JUMP',NE EXIT$	LOAD.W	D7,#1EXIT$:	POPM.L	D1,D2,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DETCHASSE >;==========/; Regarde si la souris est sur la poigne de modification de chasse.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WDETCHASSE:	PUSHM.L	D3,A3	LOAD.W	D7,#1	TEST.L	(A6)+OXCPGC	JUMP',EQ 90$	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D3,(A6)+OXCCAR	; D3 <-- caractre	SL.W	D3,#1	LOAD.L	A3,#(A3)+oxcLENGTH	LOAD.W	D3,(A3)+(D3.W)	AND.L	D3,#H'FFFF	CALL	DETPOINT90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; NEWCHASSE >;==========/; Modifie la chasse du caractre en dition.; in	D4.L	position de la souris (y;x); out	-; mod	D7.WNEWCHASSE:	PUSHM.L	D3,D4,A3	LOAD.L	D3,D4	CALL	CONVPGPI	LOAD.W	D4,D3		; D4 <-- chasse [pi]	TEST.L	(A6)+OXCPGC	JUMP',EQ 90$	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D3,(A6)+OXCCAR	; D3 <-- caractre	SL.W	D3,#1	LOAD.L	A3,#(A3)+oxcLENGTH	LOAD.W	(A3)+(D3.W),D4	SET.B	(A6)+OMAJ90$:	POPM.L	D3,D4,A3	RET;---------\\; SRCJOINT >;=========/; Cherche un objet jointif  un autre objet.; in	A3.L	^objet;	D3.W	offset point cherch; out	A4.L	^objet jointif;	D7.W	erreur; mod	D7.W, A4.LSRCJOINT:	PUSHM.L	D3,D4,D6	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP',EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE END$	LOAD.L	D3,(A3)+(D3.W)	; D3 <-- point cherchLOOP$:	COMP.L	A4,A3	JUMP',EQ NEXT$	LOAD.W	D4,(A4)+OOBTYP	COMP.W	D4,#xcOPADDCHAR	JUMP',EQ NEXT$	COMP.L	D3,(A4)+OOBPP1	JUMP',EQ EXIT$	COMP.L	D3,(A4)+OOBPP2	JUMP',EQ EXIT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	LOAD.W	D7,#1EXIT$:	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;---------\\; DETPOINT >;---------/; Regarde si la souris est sur un point.; in	D4.L	point o est la souris (y;x)	[pg];	D3.L	point cherch (y;x)		[pi]; out	D7.W	erreur; mod	D7.WDETPOINT:	PUSHM.L	D3,D4	LOAD.W	D7,#1		; D7 <-- ailleur	COMP.L	D3,#POSNIL	JUMP',EQ 90$	CALL	CONVPIPG	; D3 <-- point dans l'cran	LOAD.W	D7,#1		; D7 <-- ailleur	SUB.W	D3,#LDET	COMP.W	D4,D3	JUMP',LT 90$	ADD.W	D3,#LDET*2	COMP.W	D4,D3	JUMP',GE 90$	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#LDET	COMP.W	D4,D3	JUMP',LT 90$	ADD.W	D3,#LDET*2	COMP.W	D4,D3	JUMP',GE 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DETSEGMENT >;-----------/; Regarde si un point P5 est sur un segment de droite P3-P4.; in	D3.L	origine droite (y;x);	D4.L	arrive droite (y;x);	D5.L	point de dtection (y;x); out	D7.W	erreur; mod	D7.WDETSEGMENT:	PUSHM.L	D1..D6	CLR.W	D7		; D7 <-- dans la droite	LOAD.L	D6,D5		; D5 <-- Dx	SWAP.W	D6		; D6 <-- Dy; Regarde si le point D(y;x) est dans le rectangle englobant; la droite.	LOAD.L	D1,D3	LOAD.L	D2,D4	COMP.W	D1,D2	JUMP',LE 10$	EX.L	D1,D210$:	SUB.W	D1,#LDET	ADD.W	D2,#LDET	COMP.W	D5,D1		; trop  gauche ?	JUMP,LT 80$	COMP.W	D5,D2		; trop  droite ?	JUMP,GE 80$	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,D2	JUMP',LE 12$	EX.L	D1,D212$:	SUB.W	D1,#LDET	ADD.W	D2,#LDET	COMP.W	D6,D1		; trop haut ?	JUMP,LT 80$	COMP.W	D6,D2		; trop bas ?	JUMP,GE 80$; Regarde si le point D(y;x) est sur la droite.	SUB.W	D4,D3		; D4 <-- dX	LOAD.W	D1,D4	JUMP,EQ 90$	JUMP',NC 20$	NEG.W	D1		; D1 <-- |dX|20$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dY	LOAD.W	D2,D4	JUMP,EQ 90$	JUMP',NC 22$	NEG.W	D2		; D2 <-- |dY|22$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,D2	JUMP',LO 50$				; droite plutt horizontale =>	LOAD.W	D2,D5	SUB.W	D2,D3	SWAP.W	D4	MUL.WA	D2,D4	SWAP.W	D4	DIV.WA	D2,D4	SUB.W	D2,D6	NEG.W	D2	SWAP.W	D3	SUB.W	D2,D3	SWAP.W	D3	TEST.W	D2	JUMP',NC 30$	NEG.W	D230$:	COMP.W	D2,#LDET	JUMP',LS 90$	JUMP'	80$50$:				; droite plutt verticale =>	LOAD.W	D2,D6	SWAP.W	D3	SUB.W	D2,D3	SWAP.W	D3	MUL.WA	D2,D4	SWAP.W	D4	DIV.WA	D2,D4	SWAP.W	D4	SUB.W	D2,D5	NEG.W	D2	SUB.W	D2,D3	JUMP',NC 60$	NEG.W	D260$:	COMP.W	D2,#LDET	JUMP',LS 90$80$:	LOAD.W	D7,#1		; D7 <-- en dehors de la droite90$:	POPM.L	D1..D6	TEST.W	D7		; retour EQ/NE	RET	.END