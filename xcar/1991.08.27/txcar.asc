	.TITLE	TXCAR.ASC	.PROC	M680002	.REF	SMAKY	.REF	XCAR	.LOC	0ODESC:	.BLKB	ldgbmOPGC:	.BLKB	4OBUDIS:	.BLKB	100LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.L	A4,#(A6)+ODESC	LOAD.L	A3,#(A4)+odgbmNAME	LOAD.L	A2,#R16"GCNAMENAME$:	LOAD.B	(A3+),(A2+)	JUMP,NE NAME$	LOAD.W	(A4)+odgbmCORPS,#40	XCAR_	BMOPEN	JUMP,NE ERROR	LOAD.L	(A6)+OPGC,A3	LOAD.L	D4,#H'10000*100+100	LOAD.W	D3,#'A	CALL	AFCAR	LOAD.W	D3,#'b	CALL	AFCAR	LOAD.W	D3,#'c	CALL	AFCAR	LOAD.L	D4,#H'10000*200+100	LOAD.W	D3,#'A	CALL	AFCAR	LOAD.W	D3,#'b	CALL	AFCAR	LOAD.W	D3,#'c	CALL	AFCAR	LOAD.L	D4,#H'10000*300+100	LOAD.W	D3,#'A	CALL	AFCAR	LOAD.W	D3,#'b	CALL	AFCAR	LOAD.W	D3,#'c	CALL	AFCAR	LIB	?GETCAR	LOAD.L	A3,(A6)+OPGC	XCAR_	BMCLOSEERROR:	LIB	?AFERRORFINI:	EXIT;--------\\; AFCAR   >;========/; ; in	D3.W	caractre;	D4.L	position; out	D4.L	position suivante; mod	AFCAR:	PUSHM.L	D1..D3,D5,A3,A4	LOAD.L	D2,D4	LOAD.L	A3,(A6)+OPGC	XCAR_	BMMATRIX	JUMP,NE EXIT$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	CLR.L	(A3)+1	LOAD.L	(A3)+5,A4	LOAD.W	D1,D4	ADD.W	D1,#16-1	SR.W	D1,#4	SL.W	D1,#1	LOAD.W	(A3)+9,D1	LOAD.L	D1,D2	SUB.W	D1,D3	SWAP.W	D1	SWAP.W	D3	SUB.W	D1,D3	LOAD.L	(A3)+11,D1	CLR.L	(A3)+15	SWAP.W	D4	LOAD.L	(A3)+21,D4	LOAD.B	(A3)+25,#SETDOT	LOAD.W	D3,#26	LIB	?STRING	LOAD.L	D4,D2	ADD.W	D4,D5	CLR.W	D7EXIT$:	POPM.L	D1..D3,D5,A3,A4	TEST.W	D7		; retour EQ/NE	RETGCNAME:	.ASCIZ	"Swiss"	.EVENVAR:	.FILLB	LGVAR,0	.END	START