WAP.W	D0	LOAD.W	D4,D0	SWAP.W	D2	LOAD.W	D3,D2	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	LOAD.L	A2,#(A6)+OXCDF	; A2 <-- ^descripteur fentre spcial	LOAD.W	D1,#SETDOT	CALL	DRPEN		; choix du pinceau	GRA_	LINE		; trace une ligne droite	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3;	SWAP.W	D3	SWAP.W	D4	GRA_	DOT		; met le point d'arrive !EXIT$:	POPM.L	D0..D4,A2	RET;;?.IF 0	PUSHM.L	D1..D3,A2,A4	SUB.L	SP,#4*4	LOAD.L	A4,SP		; A4 <-- ^paramtres sur le stack	LOAD.L	(A4)+4*0,D1	LOAD.L	(A4)+4*1,D0	SUB.L	D2,D0	SUB.L	D3,D1	LOAD.L	(A4)+4*2,D3	LOAD.L	(A4)+4*3,D2	LOAD.L	A2,#(A6)+OXCDF	; A2 <-- ^descripteur fentre spcial	LOAD.W	D1,#SETDOT	; D1 <-- mode de dessin	CALL	DRPEN		; choix du pinceau	GRA2_	RLINE	ADD.L	SP,#4*4	POPM.L	D1..D3,A2,A4	RET.ENDIF;--------\\; DRODOT  >;========/; Trace un seul point.; in	D0.L	point (y;x); out	-; mod	D7.WDRODOT:	PUSHM.L	D1,D4,A2	LOAD.L	D4,D0	LOAD.L	A2,#(A6)+OXCDF	; A2 <-- ^descripteur fentre spcial	LOAD.W	D1,#SETDOT	GRA_	DOT		; trace un point isol	POPM.L	D1,D4,A2	RET;--------\\; DRPEN   >;--------/; Utilise le bon pinceau.; in	A2.L	^descripteur;	D1.W	mode de dessin; out	D1.W	mode de dessin; mod	D1.L, D7.WDRPEN:	PUSHM.L	D4,A4	CALL	DRPENDIM	; D4 <-- diamtre du pinceau	COMP.W	D4,(A6)+OUPEN	; utilise dj le bon pinceau ?	JUMP,EQ OK$		; oui => OK$	LOAD.W	(A6)+OUPEN,D4	COMP.W	D4,#1		; simple trait ?	JUMP,EQ OK$		; oui => OK$	COMP.W	D4,#16		; petit pinceau ?	JUMP',LS LITTLE$	; oui => LITTLE$	CALL	DRPENCALC	; construit un grand pinceau	JUMP	OK$LITTLE$:	LOAD.L	A4,#R16"PEN2$	SUB.W	D4,#2	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN3$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN4$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN5$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN6$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN7$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN8$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN9$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN10$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN11$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN12$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN13$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN14$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN15$	DEC.W	D4	JUMP',EQ DEF$	LOAD.L	A4,#R16"PEN16$DEF$:	CLR.L	(A2)+ODFPPO	LOAD.W	(A2)+ODFPDI+2,(A4+)	LOAD.W	(A2)+ODFPDI+0,(A4+)	LOAD.W	(A2)+ODFPII,(A4+)	LOAD.L	(A2)+ODFPPM,A4OK$:	COMP.W	(A6)+OUPEN,#1	JUMP',LS EXIT$	TSET.L	D1:#BPENDOT	; D1 <-- utilise un pinceauEXIT$:	POPM.L	D4,A4	RETPEN2$:	.W	2,2	.W	1	.B	B'11000000	.B	B'11000000	.EVENPEN3$:	.W	3,3	.W	1	.B	B'11100000	.B	B'11100000	.B	B'11100000	.EVENPEN4$:	.W	4,4	.W	1	.B	B'01100000	.B	B'11110000	.B	B'11110000	.B	B'01100000	.EVENPEN5$:	.W	5,5	.W	1	.B	B'01110000	.B	B'11111000	.B	B'11111000	.B	B'11111000	.B	B'01110000	.EVENPEN6$:	.W	6,6	.W	1	.B	B'00110000	.B	B'01111000	.B	B'11111100	.B	B'11111100	.B	B'01111000	.B	B'00110000	.EVENPEN7$:	.W	7,7	.W	1	.B	B'00111000	.B	B'01111100	.B	B'11111110	.B	B'11111110	.B	B'11111110	.B	B'01111100	.B	B'00111000	.EVENPEN8$:	.W	8,8	.W	1	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'01111110	.B	B'00111100	.EVENPEN9$:	.W	9,9	.W	2	.W	B'0001110000000000	.W	B'0111111100000000	.W	B'0111111100000000	.W	B'1111111110000000	.W	B'1111111110000000	.W	B'1111111110000000	.W	B'0111111100000000	.W	B'0111111100000000	.W	B'0001110000000000	.EVENPEN10$:	.W	10,10	.W	2	.W	B'0001111000000000	.W	B'0111111110000000	.W	B'0111111110000000	.W	B'1111111111000000	.W	B'1111111111000000	.W	B'1111111111000000	.W	B'1111111111000000	.W	B'0111111110000000	.W	B'0111111110000000	.W	B'0001111000000000	.EVENPEN11$:	.W	11,11	.W	2	.W	B'0000111000000000	.W	B'0011111110000000	.W	B'0111111111000000	.W	B'0111111111000000	.W	B'1111111111100000	.W	B'1111111111100000	.W	B'1111111111100000	.W	B'0111111111000000	.W	B'0111111111000000	.W	B'0011111110000000	.W	B'0000111000000000	.EVENPEN12$:	.W	12,12	.W	2	.W	B'0000111100000000	.W	B'0011111111000000	.W	B'0111111111100000	.W	B'0111111111100000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'1111111111110000	.W	B'0111111111100000	.W	B'0111111111100000	.W	B'0011111111000000	.W	B'0000111100000000	.EVENPEN13$:	.W	13,13	.W	2	.W	B'0000111110000000	.W	B'0011111111100000	.W	B'0111111111110000	.W	B'0111111111110000	.W	B'1111111111111000	.W	B'1111111111111000	.W	B'1111111111111000	.W	B'1111111111111000	.W	B'1111111111111000	.W	B'0111111111110000	.W	B'0111111111110000	.W	B'0011111111100000	.W	B'0000111110000000	.EVENPEN14$:	.W	14,14	.W	2	.W	B'0000111111000000	.W	B'0011111111110000	.W	B'0111111111111000	.W	B'0111111111111000	.W	B'1111111111111100	.W	B'1111111111111100	.W	B'1111111111111100	.W	B'1111111111111100	.W	B'1111111111111100	.W	B'1111111111111100	.W	B'0111111111111000	.W	B'0111111111111000	.W	B'0011111111110000	.W	B'0000111111000000	.EVENPEN15$:	.W	15,15	.W	2	.W	B'0000011111000000	.W	B'0001111111110000	.W	B'0011111111111000	.W	B'0111111111111100	.W	B'0111111111111100	.W	B'1111111111111110	.W	B'1111111111111110	.W	B'1111111111111110	.W	B'1111111111111110	.W	B'1111111111111110	.W	B'0111111111111100	.W	B'0111111111111100	.W	B'0011111111111000	.W	B'0001111111110000	.W	B'0000011111000000	.EVENPEN16$:	.W	16,16	.W	2	.W	B'0000011111100000	.W	B'0001111111111000	.W	B'0011111111111100	.W	B'0111111111111110	.W	B'0111111111111110	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'0111111111111110	.W	B'0111111111111110	.W	B'0011111111111100	.W	B'0001111111111000	.W	B'0000011111100000	.EVEN;----------\\; DRPENCALC >;----------/; Construit un grand pinceau quelconque.; in	A2.L	^descripteur;	D4.W	diamtre; out	D7.W	erreur; mod	D7.WDRPENCALC:	PUSHM.L	D0..D4,A4	PUSH.L	(A2)+ODFABS	PUSH.L	(A2)+ODFY	PUSH.L	(A2)+ODFDY	PUSH.L	(A2)+ODFFY	PUSH.L	(A2)+ODFFDY	PUSH.L	(A2)+ODFWBY	PUSH.L	(A2)+ODFWEY	PUSH.W	(A2)+ODFIIY	PUSH.L	(A2)+ODFBAS	LIB	?GETPDIS	LOAD.L	(A2)+ODFBAS,(A4)+ODFBAS ; ncessaire pour FILLO/FILLC	TEST.L	(A6)+OPPEN	JUMP',EQ GIVE$	LOAD.L	A4,(A6)+OPPEN	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancien	CLR.L	(A6)+OPPENGIVE$:	LOAD.W	D0,D4		; D0 <-- diamtre	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	LOAD.W	(A2)+ODFIIY,D4	MUL.WU	D4,D0	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouveau bitmap	JUMP,NE EXIT$	GESMEM	?CLEARMEM	; efface tout	LOAD.L	(A6)+OPPEN,A4	LOAD.L	(A2)+ODFABS,A4	CLR.L	(A2)+ODFY	CLR.L	(A2)+ODFFY	CLR.L	(A2)+ODFWBY	LOAD.W	(A2)+ODFDX,D0	LOAD.W	(A2)+ODFFDX,D0	LOAD.W	(A2)+ODFWEX,D0	LOAD.W	(A2)+ODFDY,D0	LOAD.W	(A2)+ODFFDY,D0	LOAD.W	(A2)+ODFWEY,D0	LOAD.W	D4,D0	SR.W	D4,#1	LOAD.W	D3,D4	SWAP.W	D4	SWAP.W	D3	LOAD.W	D4,D0	SR.W	D4,#1	LOAD.W	D3,D4	LOAD.W	D2,#-1	LOAD.W	D1,#SETDOT	GRA_	CIRCLE		; trace un cercle	LOAD.L	(A2)+ODFTRA+0,#-1	LOAD.L	(A2)+ODFTRA+4,#-1	GRA_	FILLO		; rempli-le	GRA_	FILLC	LOAD.W	D1,(A2)+ODFIIY	POP.L	(A2)+ODFBAS	POP.W	(A2)+ODFIIY	POP.L	(A2)+ODFWEY	POP.L	(A2)+ODFWBY	POP.L	(A2)+ODFFDY	POP.L	(A2)+ODFFY	POP.L	(A2)+ODFDY	POP.L	(A2)+ODFY	POP.L	(A2)+ODFABS	CLR.L	(A2)+ODFPPO	LOAD.W	(A2)+ODFPDI+2,D0	LOAD.W	(A2)+ODFPDI+0,D0	LOAD.W	(A2)+ODFPII,D1	LOAD.L	(A2)+ODFPPM,(A6)+OPPEN	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DRPENDIM >;---------/; Calcule le diamtre du pinceau.; in	-; out	D4.W	diamtre du pinceau; mod	D4.L, D7.WDRPENDIM:	LOAD.W	D4,(A6)+OLPEN	JUMP',EQ NUL$	CALL	SCALEY		; D4 <-- diamtre du pinceau	TEST.W	D4	JUMP',NE EXIT$NUL$:	INC.W	D4		; D4 <-- jamais zro !EXIT$:	RET;-------\\; FIXMUL >;=======/; Multiplication de deux nombres rels (16 bits entier et 16 bits fraction).; in	D1.L	premier nombre rel;	D2.L	deuxime nombre rel; out	D0.L	rsultat rel;	VS	si dpassement de capacit (dans ce cas D0=max ou min selon signes); mod	D0.LFIXMUL:	PUSHM.L	D1,D2,D4,D5,D6	CALL	TOPOSITIF	LOAD.L	D4,#H'00010000	COMP.L	D1,D4		; D1 = 1.0 ?	JUMP',NE DIFF0$		; non => D2 = 1.0 ?	LOAD.L	D1,D2	JUMP'	MUL10$DIFF0$:	COMP.L	D2,D4		; D2 = 1.0 ?	JUMP',NE DIFFZERO$MUL10$:	CLR.L	D0	CLR.L	D4	LOAD.W	D4,D1	SWAP.W	D4	SWAP.W	D1	LOAD.W	D0,D1		; (D0;D4) = rsultat	JUMP'	LONGTOFIX$DIFFZERO$:	LOAD.W	D4,D2	MUL.WU	D4,D1		; D4: D1.fract * D2.fract	SWAP.W	D2	LOAD.W	D5,D2	MUL.WU	D5,D1		; D5: D1.fract * D2.int	SWAP.W	D1	LOAD.W	D0,D2	MUL.WU	D0,D1		; D0: D1.int * D2.int	SWAP.W	D2	MUL.WU	D2,D1		; D2: D1.int * D2.fract	ADD.L	D2,D5		; mid	CLR.L	D5	LOAD.W	D5,D2	SWAP.W	D5		; mid * 2**16	LOAD.W	D2,D5		; #0	SWAP.W	D2	ADD.L	D4,D5		; + low	ADDX.L	D0,D2		; mid.31..W + high + carry				; (D0;D4): rsultatLONGTOFIX$:	SWAP.W	D0	TEST.W	D0		; high word <> 0 ?	JUMP',NE SETMAX$	; oui => met la val. maximum	SWAP.W	D4	LOAD.W	D0,D4		; low res. word	TEST.L	D4		; high bit reste = 0 ?	JUMP',PL NOTROUND$	INC.L	D0		; inc res.fract	JUMP',CS SETMAX$NOTROUND$:	TEST.L	D0		; bit de signe dj mis ?	JUMP',MI SETMAX$	; ==> dbordement !	TEST.B	D6		; (VC)	JUMP',EQ EXIT$	NEG.L	D0		; met rsultat ngatif selon D1 et D2.in (VC)	JUMP'	EXIT$SETMAX$:	LOAD.L	D0,#H'00000001	RR.L	D0,#1	TEST.B	D6	JUMP',NE OVER$	DEC.L	D0OVER$:	SETV			; met le bit overflowEXIT$:	POPM.L	D1,D2,D4,D5,D6	RET;----------\\; TOPOSITIF >;----------/; ; in	D1.L	nombre rel;	D2.L	nombre rel; out	D1.L	nombre rel positif;	D2.L	nombre rel positif;	D6.B	0 si rsultat positif; mod	D1.L, D2.L, D6.BTOPOSITIF:	CLR.B	D6	TEST.L	D1	JUMP',NC POS1$	NEG.L	D1	SET.B	D6POS1$:	TEST.L	D2	JUMP',NC POS2$	NEG.L	D2	NOT.B	D6POS2$:	RET	.END