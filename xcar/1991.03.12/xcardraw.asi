	.SBTTL	XCARDRAW.ASI;--------\\; IFFILL  >;========/; Faut-il remplir un caractre.; in	D3.W	code du caractre; out	D7.W	erreur si pas de remplissage; mod	D7.WIFFILL:	PUSHM.L	D3,A3,A4	LOAD.L	A3,(A6)+OXCPI	; A3 <-- ^gencar en entre	TEST.L	(A6)+OXCPJ	; gencar trs petit en entre ?	JUMP',EQ PI$	LOAD.L	A3,(A6)+OXCPJ	; A3 <-- ^gencar trs petitPI$:	LOAD.W	D7,#1		; D7 <-- pas de remplissage	TEST.B	(A3)+oxcMODE+3:#bxcMODEFILL-0	JUMP',BC EXIT$	SL.W	D3,#2	LOAD.L	A4,#(A3)+oxcPCHAR	LOAD.L	D3,(A4)+(D3.W)	LOAD.L	A4,#(A3)+(D3.L)	; A4 <-- ^description du caractre	CLR.W	D7		; D7 <-- remplissage	LOAD.B	D3,(A4)		; D3 <-- premier objet	COMP.B	D3,#xcOPFILLI	JUMP',EQ EXIT$	COMP.B	D3,#xcOPFILLA	JUMP',EQ EXIT$	LOAD.W	D7,#1		; D7 <-- pas de remplissageEXIT$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFOUTL  >;========/; Faut-il tracer le outline d'un caractre.; in	D3.W	code du caractre; out	D7.W	erreur si pas de outline; mod	D7.WIFOUTL:	PUSHM.L	D3,A3,A4	LOAD.L	A3,(A6)+OXCPI	; A3 <-- ^gencar en entre	TEST.L	(A6)+OXCPJ	; gencar trs petit en entre ?	JUMP',EQ PI$	LOAD.L	A3,(A6)+OXCPJ	; A3 <-- ^gencar trs petitPI$:	CLR.W	D7		; D7 <-- outline	TEST.B	(A3)+oxcMODE+3:#bxcMODEOUTL-0	JUMP',BS EXIT$	SL.W	D3,#2	LOAD.L	A4,#(A3)+oxcPCHAR	LOAD.L	D3,(A4)+(D3.W)	LOAD.L	A4,#(A3)+(D3.L)	; A4 <-- ^description du caractre	LOAD.W	D7,#1		; D7 <-- pas de outline	LOAD.B	D3,(A4)		; D3 <-- premier objet	COMP.B	D3,#xcOPFILLI	JUMP',EQ EXIT$	COMP.B	D3,#xcOPFILLA	JUMP',EQ EXIT$	CLR.W	D7		; D7 <-- outlineEXIT$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DECODE  >;========/; Dcode tout un caractre.; in	D3.W	code du caractre; out	-; mod	D7.WDECODE:	CLR.L	(A6)+ORPOS	TEST.L	(A6)+OXCPJ	; gencar trs petit en entre ?	JUMP,EQ DECODER		; non => DECODER	PUSHM.L	D3,D4,A3,A4	LOAD.W	(A6)+OXCJMY,(A6)+OXCIYE	LOAD.W	(A6)+OXCJDY,(A6)+OXCIYEJ	JUMP',EQ JEND$	SL.W	D3,#1	LOAD.L	A4,(A6)+OXCPJ	LOAD.L	A3,#(A4)+oxcLENGTH	LOAD.W	D4,(A3)+(D3.W)	; D4 <-- largeur caractre de OXCPJ	JUMP',EQ JEND$	LOAD.W	(A6)+OXCJDX,D4	LOAD.L	A4,(A6)+OXCPI	LOAD.L	A3,#(A4)+oxcLENGTH	LOAD.W	D4,(A3)+(D3.W)	; D4 <-- largeur caractre de OXCPI	LOAD.W	(A6)+OXCJMX,D4.IF 0	LOAD.L	A3,#(A4)+oxcXMINS	LOAD.W	D4,(A3)+(D3.W)	NEG.W	D4	LOAD.L	A3,#(A4)+oxcXMAXS	ADD.W	D4,(A3)+(D3.W)	; D4 <-- largeur caractre de OXCPJ	JUMP',EQ JEND$	LOAD.W	(A6)+OXCJDX,D4	LOAD.L	A4,(A6)+OXCPI	LOAD.L	A3,#(A4)+oxcXMINS	LOAD.W	D4,(A3)+(D3.W)	NEG.W	D4	LOAD.L	A3,#(A4)+oxcXMAXS	ADD.W	D4,(A3)+(D3.W)	; D4 <-- largeur caractre de OXCPI	LOAD.W	(A6)+OXCJMX,D4.ENDIF	CLR.W	D7JEND$:	POPM.L	D3,D4,A3,A4	TEST.W	D7	JUMP',EQ DECODER	RETDECODER:	PUSHM.L	D0..D6,A3,A4	LOAD.W	D0,D3	LOAD.L	A3,(A6)+OXCPI	TEST.L	(A6)+OXCPJ	; gencar trs petit en entre ?	JUMP',EQ PI$	LOAD.L	A3,(A6)+OXCPJ	; A3 <-- ^gencar trs petitPI$:	LOAD.W	D4,D0	SL.W	D4,#2	LOAD.L	A4,#(A3)+oxcPCHAR	LOAD.L	D4,(A4)+(D4.W)	LOAD.L	A4,#(A3)+(D4.L)	; A4 <-- ^description du caractre	CLR.W	(A6)+OLPENLOOP$:	LOAD.B	D3,(A4+)	INC.L	A4	COMP.B	D3,#xcOPBEGIN	JUMP,EQ BEGIN$	COMP.B	D3,#xcOPLINE	JUMP,EQ LINE$	COMP.B	D3,#xcOPCURVE	JUMP,EQ CURVE$	COMP.B	D3,#xcOPADDCHAR	JUMP,EQ ADDCHAR$	COMP.B	D3,#xcOPFILLI	JUMP,EQ FILLI$	COMP.B	D3,#xcOPFILLA	JUMP,EQ FILLA$	COMP.B	D3,#xcOPPEN	JUMP,EQ PEN$	JUMP	END$BEGIN$:	CALL	DECOGETPR	; D3 <-- p (y;x) de dpart	LOAD.L	(A6)+OLPOS,D3	LOAD.L	(A6)+OIPOS,D4	JUMP	LOOP$LINE$:	CALL	DECOGETPR	LOAD.L	(A6)+OIPOS,D4	LOAD.L	D4,D3		; D4 <-- p2 (y;x)	LOAD.L	D3,(A6)+OLPOS	; D3 <-- p1 (y;x)	CALL	LINE	LOAD.L	(A6)+OLPOS,D4	JUMP	LOOP$CURVE$:	LOAD.L	D2,(A4+)	LOAD.L	D3,(A6)+OLPOS	LOAD.L	D4,(A6)+OIPOS	CALL	DECOGETPS	LOAD.L	D1,D3		; D1 <-- s1 (y;x)	LOAD.L	D2,(A4+)	CALL	DECOGETPR	LOAD.L	(A6)+OIPOS,D4	LOAD.L	D6,D3		; D6 <-- p2 (y;x)	CALL	DECOGETPS	LOAD.L	D5,D3		; D5 <-- s2 (y;x)	LOAD.L	D3,(A6)+OLPOS	; D3 <-- p1 (y;x)	LOAD.L	D4,D1		; D4 <-- s1 (y;x)	CALL	CURVE	LOAD.L	(A6)+OLPOS,D6	JUMP	LOOP$ADDCHAR$:	PUSH.L	(A6)+ORPOS	PUSH.W	(A6)+OLPEN	LOAD.L	(A6)+ORPOS,(A4+)	CLR.W	D3	LOAD.B	D3,(A4+)	INC.L	A4	CALL	DECODER		; hop, rcursif ...	POP.W	(A6)+OLPEN	POP.L	(A6)+ORPOS	JUMP	LOOP$FILLI$:	JUMP	LOOP$FILLA$:	JUMP	LOOP$PEN$:	LOAD.W	(A6)+OLPEN,(A4+)	JUMP	LOOP$END$:	LOAD.W	D4,D0	SL.W	D4,#1	LOAD.L	A4,#(A3)+oxcLENGTH	LOAD.W	D4,(A4)+(D4.W)	CALL	SCALEX	LOAD.W	(A6)+OWCAR,D4	POPM.L	D0..D6,A3,A4	RET;----------\\; DECOGETPS >;----------/; Cherche une coordonne secondaire (point de contrle d'une courbe; de bzier), qui est toujours relative au point principal.; in	D2.L	ps (y;x) [pi];	D3.L	pp (y;x) [pg];	D4.L	pp (y;x) [pi]; out	D3.L	point (y;x) [pg]; mod	D3.L, D7.WDECOGETPS:	PUSHM.L	D2,D4	SUB.W	D2,D4	SWAP.W	D2	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D2;	SWAP.W	D4	LOAD.L	D4,D3	LOAD.L	D3,D2	CALL	CONVL3X	SWAP.W	D3	CALL	CONVL3Y	SWAP.W	D3	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	POPM.L	D2,D4	RET;----------\\; DECOGETPR >;----------/; Cherche une coordonne absolue avec sa coordonne relative.; Nombre dans le buffer cod :;	00xxx	-->	+ position;	11xxx	-->	- position;	10xxx	-->	+ distance;	01xxx	-->	- distance; in	A4.L	^buffer; out	A4.L	^plus loin;	D3.L	point (y;x) [pg];	D4.L	point (y;x) [pi]; mod	D3.L, D4.L, D7.W, A4.LDECOGETPR:	CALL'	DECOGETPRY	; D3/D4 <-- y [pg]/[pi]	SWAP.W	D3	SWAP.W	D4;	CALL'	DECOGETPRX	; D3/D4 <-- x [pg]/[pi];	RET;-----------\\; DECOGETPRX >;-----------/; in	A4.L	^buffer; out	A4.L	^plus loin;	D3.W	point (x) [pg];	D4.W	point (x) [pi]; mod	D3.W, D4.W, D7.W, A4.LDECOGETPRX:	PUSHM.L	D1,D2	LOAD.W	D3,(A4+)	LOAD.W	D1,D3	RL.W	D1,#1	XOR.W	D1,D3		; nombre relatif ?	JUMP',NS 20$		; oui => 20$	LOAD.W	D4,D3	CALL	CONVP3X	JUMP'	90$20$:	TNOT.L	D3:#15	LOAD.W	D4,D3	CALL	CONVL3X	LOAD.W	D2,D330$:	LOAD.W	D3,(A4+)	LOAD.W	D1,D3	RL.W	D1,#1	XOR.W	D1,D3		; nombre relatif ?	JUMP',NC 40$		; non => 40$	TNOT.L	D3:#15	ADD.W	D4,D3	CALL	CONVL3X	ADD.W	D2,D3		; D2 <-- somme des deltas	JUMP	30$40$:	ADD.W	D4,D3	CALL	CONVP3X	ADD.W	D3,D2		; D3 <-- somme des deltas90$:	POPM.L	D1,D2	RET;-----------\\; DECOGETPRY >;-----------/; in	A4.L	^buffer; out	A4.L	^plus loin;	D3.W	point (y) [pg];	D4.W	point (y) [pi]; mod	D3.W, D4.W, D7.W, A4.LDECOGETPRY:	PUSHM.L	D1,D2	LOAD.W	D3,(A4+)	LOAD.W	D1,D3	RL.W	D1,#1	XOR.W	D1,D3		; nombre relatif ?	JUMP',NS 20$		; oui => 20$	LOAD.W	D4,D3	CALL	CONVP3Y	JUMP'	90$20$:	TNOT.L	D3:#15	LOAD.W	D4,D3	CALL	CONVL3Y	LOAD.W	D2,D330$:	LOAD.W	D3,(A4+)	LOAD.W	D1,D3	RL.W	D1,#1	XOR.W	D1,D3		; nombre relatif ?	JUMP',NC 40$		; non => 40$	TNOT.L	D3:#15	ADD.W	D4,D3	CALL	CONVL3Y	ADD.W	D2,D3		; D2 <-- somme des deltas	JUMP	30$40$:	ADD.W	D4,D3	CALL	CONVP3Y	ADD.W	D3,D2		; D3 <-- somme des deltas90$:	POPM.L	D1,D2	RET;--------\\; LINE    >;========/; ; in	D3.L	P1 (y;x);	D4.L	P2 (y;x); out	-; mod	D7.WLINE:	PUSHM.L	D0..D4	TEST.L	(A6)+OXCPM	; descripteur pour transformation existe ?	JUMP',EQ NOMATH$	; non => NOMATH$	EX.L	D4,D3	CALL	CONVMATH	; D3 <-- P1'	EX.L	D3,D4;	EX.L	D4,D4	CALL	CONVMATH	; D4 <-- P2';	EX.L	D4,D4NOMATH$:	COMP.W	(A6)+OXCMOD,#XCMODFRAG	JUMP',EQ FRAG$	LOAD.W	D0,D3	SWAP.W	D0	LOAD.L	D1,D3	LOAD.W	D2,D4	SWAP.W	D2	LOAD.L	D3,D4	LOAD.W	D4,#CHOUIA05	LOAD.W	D0,D4	LOAD.W	D1,D4	LOAD.W	D2,D4	LOAD.W	D3,D4	COMP.W	(A6)+OXCMOD,#XCMODOUTL	JUMP',EQ OUTL$FILL$:	CALL	DRFLINE	JUMP'	EXIT$OUTL$:	CALL	DROLINE	JUMP'	EXIT$FRAG$:	PUSHM.L	A4,A6	LOAD.L	D6,D4	LOAD.L	D5,D4	LOAD.L	D4,D3	LOAD.L	A4,(A6)+OFRAPR	; A4 <-- ^routine	LOAD.L	A6,(A6)+OFRAPV	; A6 <-- ^variables utilisateur	CALL	(A4)	POPM.L	A4,A6;	JUMP'	EXIT$EXIT$:	POPM.L	D0..D4	RET;--------\\; CURVE   >;========/; ; in	D3.L	P1 (y;x);	D4.L	P2 (y;x);	D5.L	P3 (y;x);	D6.L	P4 (y;x); out	-; mod	D7.WCURVE:	PUSHM.L	D3..D6,A4	TEST.L	(A6)+OXCPM	; descripteur pour transformation existe ?	JUMP',EQ NOMATH$	; non => NOMATH$	EX.L	D4,D3	CALL	CONVMATH	; D3 <-- P1'	EX.L	D3,D4;	EX.L	D4,D4	CALL	CONVMATH	; D4 <-- P2';	EX.L	D4,D4	EX.L	D4,D5	CALL	CONVMATH	; D5 <-- P3'	EX.L	D5,D4	EX.L	D4,D6	CALL	CONVMATH	; D6 <-- P4'	EX.L	D6,D4NOMATH$:	COMP.W	(A6)+OXCMOD,#XCMODFRAG	JUMP,EQ FRAG$	SUB.L	SP,#LBZ	LOAD.L	A4,SP		; A4 <-- ^variables sur le stack	LOAD.W	(A4)+OBZP1X+0,D3	SWAP.W	D3	LOAD.W	(A4)+OBZP1Y+0,D3	LOAD.W	(A4)+OBZC1X+0,D4	SWAP.W	D4	LOAD.W	(A4)+OBZC1Y+0,D4	LOAD.W	(A4)+OBZC2X+0,D5	SWAP.W	D5	LOAD.W	(A4)+OBZC2Y+0,D5	LOAD.W	(A4)+OBZP2X+0,D6	SWAP.W	D6	LOAD.W	(A4)+OBZP2Y+0,D6	LOAD.W	D3,#CHOUIA05	; D3 <-- p'tit chouia (0.5)	LOAD.W	(A4)+OBZP1X+2,D3	LOAD.W	(A4)+OBZP1Y+2,D3	LOAD.W	(A4)+OBZC1X+2,D3	LOAD.W	(A4)+OBZC1Y+2,D3	LOAD.W	(A4)+OBZC2X+2,D3	LOAD.W	(A4)+OBZC2Y+2,D3	LOAD.W	(A4)+OBZP2X+2,D3	LOAD.W	(A4)+OBZP2Y+2,D3	CALL	BZRDRAW	ADD.L	SP,#LBZ	JUMP'	EXIT$FRAG$:	PUSH.L	A6	LOAD.L	A4,(A6)+OFRAPR	; A4 <-- ^routine	LOAD.L	A6,(A6)+OFRAPV	; A6 <-- ^variables utilisateur	CALL	(A4)	POP.L	A6;	JUMP'	EXIT$EXIT$:	POPM.L	D3..D6,A4	RET;---------\\; CONVMATH >;=========/; ; in	D4.L	P (y;x); out	D4.L	P (y;x); mod	D4.L, D7.WCONVMATH:	SUB.W	D4,(A6)+OXCPOS+2	SWAP.W	D4	SUB.W	D4,(A6)+OXCPOS+0	SWAP.W	D4	CALL	MATHPOINT	; D4 <-- P'	ADD.W	D4,(A6)+OXCPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OXCPOS+0	SWAP.W	D4	RET;--------\\; CONVP3X >;========/; ; in	D3.W	position (x); out	D3.W	position (x); mod	D3.W, D7.WCONVP3X:	PUSHM.L	D4,A4	ADD.W	D3,(A6)+ORPOS+2	LOAD.W	D4,D3	CALL	SCALEX	LOAD.W	D3,D4	TEST.L	(A6)+OXCPO	JUMP',EQ 50$	LOAD.L	A4,(A6)+OXCPO	ADD.W	D3,(A4)+OGCLMA50$:	ADD.W	D3,(A6)+OXCPOS+2	POPM.L	D4,A4	RET;--------\\; CONVP3Y >;========/; ; in	D3.W	position (y); out	D3.W	position (y); mod	D3.W, D7.WCONVP3Y:	PUSHM.L	D4,A4	ADD.W	D3,(A6)+ORPOS+0	LOAD.L	D4,D3	CALL	SCALEY	LOAD.L	D3,D4	TEST.L	(A6)+OXCPO	JUMP',EQ 50$	LOAD.L	A4,(A6)+OXCPO	ADD.W	D3,(A4)+OGCMH150$:	ADD.W	D3,(A6)+OXCPOS+0	POPM.L	D4,A4	RET;---------\\; CONVL3XY >;=========/; ; in	D3.W	distance (y ou x); out	D3.W	distance (y ou x); mod	D3.W, D7.WCONVL3X:	EX.L	D4,D3	CALL	SCALEX	EX.L	D3,D4	RETCONVL3Y:	EX.L	D4,D3	CALL	SCALEY	EX.L	D3,D4	RET;--------\\; SCALEXY >;========/; ; in	D4.W	valeur [pi]; out	D4.W	valeur [po]; mod	D4.W, D7.WSCALEX:	TEST.L	(A6)+OXCPJ	; gencar trs petit en entre ?	JUMP',EQ SCALEXY	PUSH.L	D3	LOAD.W	D3,D4	MUL.WA	D3,(A6)+OXCJMX	DIV.WA	D3,(A6)+OXCJDX	LOAD.W	D4,D3	POP.L	D3	JUMP'	SCALEXYSCALEY:	TEST.L	(A6)+OXCPJ	; gencar trs petit en entre ?	JUMP',EQ SCALEXY	PUSH.L	D3	LOAD.W	D3,D4	MUL.WA	D3,(A6)+OXCJMY	DIV.WA	D3,(A6)+OXCJDY	LOAD.W	D4,D3	POP.L	D3;	JUMP'	SCALEXYSCALEXY:	PUSHM.L	D2,D3	LOAD.W	D3,D4		; D4 <-- X	MUL.WA	D3,(A6)+OXCT	CLR.L	D2	LOAD.W	D2,(A6)+OXCIYE	SR.W	D2,#1	TEST.L	D3	JUMP',NC 20$	NEG.L	D220$:	ADD.L	D3,D2	DIV.WA	D3,(A6)+OXCIYE	LOAD.W	D4,D3	POPM.L	D2,D3	RET;--------\\; BZRDRAW >;========/; Dessine une courbe de bezier avec des nombres rels.; in	A4.L	^OBZxxx; out	-; mod	D7.WBZRDRAW:	PUSHM.L	D0..D5	COMP.W	(A6)+OXCMOD,#XCMODOUTL	JUMP',NE NORM$	CALL	DRPENDIM	; D4 <-- diamtre du pinceau	COMP.W	D4,#1		; pinceau tout fin ?	JUMP',HI NORM$		; non => NORM$	CALL	BZOUTL		; essaye de tracer une courbe trs petite	JUMP,EQ EXIT$; Calcule une valeur approximative correspondant ; la distance P1C1 + C1C2 + C2P2.NORM$:	LOAD.L	D3,(A4)+OBZP1X	SUB.L	D3,(A4)+OBZC1X	JUMP',NC POS1$	NEG.L	D3POS1$:	LOAD.L	D2,D3	LOAD.L	D3,(A4)+OBZP1Y	SUB.L	D3,(A4)+OBZC1Y	JUMP',NC POS2$	NEG.L	D3POS2$:	ADD.L	D2,D3	LOAD.L	D3,(A4)+OBZC1X	SUB.L	D3,(A4)+OBZC2X	JUMP',NC POS3$	NEG.L	D3POS3$:	ADD.L	D2,D3	LOAD.L	D3,(A4)+OBZC1Y	SUB.L	D3,(A4)+OBZC2Y	JUMP',NC POS4$	NEG.L	D3POS4$:	ADD.L	D2,D3	LOAD.L	D3,(A4)+OBZC2X	SUB.L	D3,(A4)+OBZP2X	JUMP',NC POS5$	NEG.L	D3POS5$:	ADD.L	D2,D3	LOAD.L	D3,(A4)+OBZC2Y	SUB.L	D3,(A4)+OBZP2Y	JUMP',NC POS6$	NEG.L	D3POS6$:	ADD.L	D2,D3		; D2 <-- distance approximative; Calcule l'incrment en fonction de la distance; approximative (totalement empyrique) !	LOAD.W	D5,#1	COMP.L	D2,#H'10000*640	JUMP',HS STEP$	LOAD.W	D5,#2	COMP.L	D2,#H'10000*320	JUMP',HS STEP$	LOAD.W	D5,#4	COMP.L	D2,#H'10000*160	JUMP',HS STEP$	LOAD.W	D5,#8	COMP.L	D2,#H'10000*80	JUMP',HS STEP$	LOAD.W	D5,#16	COMP.L	D2,#H'10000*40	JUMP',HS STEP$	LOAD.W	D5,#32	COMP.L	D2,#H'10000*20	JUMP',HS STEP$	LOAD.W	D5,#64STEP$:; Calcule tous les points de la courbe de bzier.	CLR.W	D4		; D4 <-- rang initial	LOAD.L	D0,(A4)+OBZP1X	LOAD.L	D1,(A4)+OBZP1Y	; D0/D1 <-- dpartLOOP$:	CALL	BZRPOINT	; D2/D3 <-- point	COMP.W	(A6)+OXCMOD,#XCMODOUTL	JUMP',EQ OUTL$	CALL	DRFLINE		; trace un segment de droite	JUMP'	NEXT$OUTL$:	CALL	DROLINE		; trace un segment de droite;	JUMP'	NEXT$NEXT$:	LOAD.L	D0,D2	LOAD.L	D1,D3	ADD.W	D4,D5		; D4 <-- rang suivant	COMP.W	D4,#256		; a-t-on fini ?	JUMP,LS LOOP$		; non => LOOP$EXIT$:	POPM.L	D0..D5	RET;--------\\; BZOUTL  >;========/; Trace une courbe de bzier trs petite; in	A4.L	^points; out	D7.W	erreur; mod	D7.WBZOUTL:	PUSHM.L	D0..D2	PUSH.W	(A4)+OBZP1X	PUSH.W	(A4)+OBZP1Y	PUSH.W	(A4)+OBZC1X	PUSH.W	(A4)+OBZC1Y	PUSH.W	(A4)+OBZC2X	PUSH.W	(A4)+OBZC2Y	PUSH.W	(A4)+OBZP2X	PUSH.W	(A4)+OBZP2Y	LOAD.W	D7,#1		; D7 <-- impossible	LOAD.W	D0,(A4)+OBZP1X	COMP.W	D0,(A4)+OBZC1X	JUMP',EQ P1X$	LOAD.W	D0,(A4)+OBZP1Y	COMP.W	D0,(A4)+OBZC1Y	JUMP,NE EXIT$	LOAD.W	D0,(A4)+OBZP2X	COMP.W	D0,(A4)+OBZC2X	JUMP,NE EXIT$	LOAD.W	D0,(A4)+OBZP1X	LOAD.W	(A4)+OBZP1X,(A4)+OBZP2X	LOAD.W	(A4)+OBZP2X,D0	LOAD.W	D0,(A4)+OBZP1Y	LOAD.W	(A4)+OBZP1Y,(A4)+OBZP2Y	LOAD.W	(A4)+OBZP2Y,D0	LOAD.W	D0,(A4)+OBZC1X	LOAD.W	(A4)+OBZC1X,(A4)+OBZC2X	LOAD.W	(A4)+OBZC2X,D0	LOAD.W	D0,(A4)+OBZC1Y	LOAD.W	(A4)+OBZC1Y,(A4)+OBZC2Y	LOAD.W	(A4)+OBZC2Y,D0	JUMP'	DIR$P1X$:	LOAD.W	D0,(A4)+OBZP2Y	COMP.W	D0,(A4)+OBZC2Y	JUMP,NE EXIT$DIR$:	CLR.B	D2		; D2 <-- flags	LOAD.W	D0,(A4)+OBZP1X	SUB.W	(A4)+OBZC1X,D0	SUB.W	(A4)+OBZC2X,D0	SUB.W	(A4)+OBZP2X,D0	LOAD.W	D0,(A4)+OBZP1Y	SUB.W	(A4)+OBZC1Y,D0	SUB.W	(A4)+OBZC2Y,D0	SUB.W	(A4)+OBZP2Y,D0	TEST.W	(A4)+OBZP2X	JUMP',NC RIGHT$	NEG.W	(A4)+OBZC1X	NEG.W	(A4)+OBZC2X	NEG.W	(A4)+OBZP2X	TSET.L	D2:#0		; D2 <-- X inversRIGHT$:	TEST.W	(A4)+OBZC1X	JUMP,NS EXIT$	TEST.W	(A4)+OBZC2X	JUMP,NS EXIT$	TEST.W	(A4)+OBZP2X	JUMP,NS EXIT$	LOAD.W	D0,(A4)+OBZP2X	COMP.W	D0,(A4)+OBZC2X	JUMP,LO EXIT$	TEST.W	(A4)+OBZP2Y	JUMP',NC DOWN$	NEG.W	(A4)+OBZC1Y	NEG.W	(A4)+OBZC2Y	NEG.W	(A4)+OBZP2Y	TSET.L	D2:#1		; D2 <-- Y inversDOWN$:	TEST.W	(A4)+OBZC1Y	JUMP,NS EXIT$	TEST.W	(A4)+OBZC2Y	JUMP,NS EXIT$	TEST.W	(A4)+OBZP2Y	JUMP,NS EXIT$	LOAD.L	A3,#R16"TABLE$	LOAD.W	D0,(A4)+OBZP2Y	SWAP.W	D0	LOAD.W	D0,(A4)+OBZP2XSEARCH$:	LOAD.L	D1,(A3)		; lment trouv ?	JUMP',EQ EXIT$		; non => EXIT$	COMP.L	D1,D0	JUMP',EQ FOUND$NEXT$:	TEST.L	(A3+)		; A3 <-- ^lment suivant	JUMP,NE NEXT$	JUMP	SEARCH$FOUND$:	LOAD.L	D0,(A3)		; D0 <-- point relatif (y;x)	TEST.L	D2:#0	JUMP',BC DOTX$	NEG.W	D0DOTX$:	ADD.W	D0,(A4)+OBZP1X	SWAP.W	D0	TEST.L	D2:#1	JUMP',BC DOTY$	NEG.W	D0DOTY$:	ADD.W	D0,(A4)+OBZP1Y	SWAP.W	D0	CALL	DRODOT		; trace un point isol	TEST.L	(A3+)	JUMP,NE FOUND$	CLR.W	D7		; D7 <-- okEXIT$:	POP.W	(A4)+OBZP2Y	POP.W	(A4)+OBZP2X	POP.W	(A4)+OBZC2Y	POP.W	(A4)+OBZC2X	POP.W	(A4)+OBZC1Y	POP.W	(A4)+OBZC1X	POP.W	(A4)+OBZP1Y	POP.W	(A4)+OBZP1X	POPM.L	D0..D2	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	1,0	.W	0,0	.W	0,1	.W	0,0	.W	1,1	.W	0,0	.W	2,1	.W	1,0	.W	0,0	.W	1,2	.W	1,1	.W	0,0	.W	2,2	.W	2,1	.W	1,0	.W	0,0	.W	3,1	.W	2,0	.W	1,0	.W	0,0	.W	3,2	.W	3,1	.W	2,0	.W	1,0	.W	0,0	.W	1,3	.W	1,2	.W	1,1	.W	0,0	.W	2,3	.W	2,2	.W	2,1	.W	1,0	.W	0,0	.W	3,3	.W	3,2	.W	2,1	.W	1,0	.W	0,0	.W	4,1	.W	3,0	.W	2,0	.W	1,0	.W	0,0	.W	4,2	.W	3,1	.W	2,0	.W	1,0	.W	0,0	.W	4,3	.W	4,2	.W	3,1	.W	2,0	.W	1,0	.W	0,0	.W	1,4	.W	1,3	.W	1,2	.W	1,0	.W	0,0	.W	2,4	.W	2,3	.W	2,2	.W	1,1	.W	0,0	.W	3,4	.W	3,3	.W	3,2	.W	2,1	.W	1,0	.W	0,0	.W	4,4	.W	4,3	.W	4,2	.W	3,1	.W	2,0	.W	1,0	.W	0,0	.W	0,0;---------\\; BZRPOINT >;---------/; Calcule un point rel quelconque situ sur une courbe de bzier.; in	A4.L	^OBZxxx;	D4.W	rang (0..256); out	D2/D3	point (x;y); mod	D2.L, D3.L, D7.WBZRPOINT:	PUSHM.L	D0,D1,D4,A2,A3	LOAD.L	A3,#R16"BZTABLE	LOAD.L	A2,A3	LOAD.W	D3,#256	SUB.W	D3,D4	SL.W	D4,#2	SL.W	D3,#2	ADD.W	A3,D4		; A3 <-- ^table, depuis le dbut	ADD.W	A2,D3		; A2 <-- ^table, depuis la fin	LOAD.L	D1,(A4)+OBZP1Y	CLR.L	D2	LOAD.W	D2,(A3)+0	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	LOAD.L	D3,D0	LOAD.L	D1,(A4)+OBZC1Y	CLR.L	D2	LOAD.W	D2,(A3)+2	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	ADD.L	D3,D0	LOAD.L	D1,(A4)+OBZC2Y	CLR.L	D2	LOAD.W	D2,(A2)+2	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	ADD.L	D3,D0	LOAD.L	D1,(A4)+OBZP2Y	CLR.L	D2	LOAD.W	D2,(A2)+0	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	ADD.L	D3,D0	LOAD.L	D1,(A4)+OBZP1X	CLR.L	D2	LOAD.W	D2,(A3)+0	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	LOAD.L	D4,D0	LOAD.L	D1,(A4)+OBZC1X	CLR.L	D2	LOAD.W	D2,(A3)+2	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	ADD.L	D4,D0	LOAD.L	D1,(A4)+OBZC2X	CLR.L	D2	LOAD.W	D2,(A2)+2	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	ADD.L	D4,D0	LOAD.L	D1,(A4)+OBZP2X	CLR.L	D2	LOAD.W	D2,(A2)+0	SL.L	D2,#1	CALL	FIXMUL		; D0 <-- D1*D2	ADD.L	D4,D0	LOAD.L	D2,D4	POPM.L	D0,D1,D4,A2,A3	RET;	1re colonne:	((1-t)^3)*m;	2me colonne:	(3t*(1-t)^2)*m;	avec:		0 < t < 1;			m = (2^15)-1 = 32767BZTABLE:	.W	32767	0	; t=0/256	.W	32385	381	; t=1/256	.W	32005	756	; t=2/256	.W	31628	1125	; ...	.W	31255	1488	.W	30884	1846	.W	30517	2197	.W	30152	2543	.W	29790	2883	.W	29431	3217	.W	29075	3546	.W	28722	3869	.W	28372	4186	.W	28024	4498	.W	27680	4804	.W	27338	5105	.W	26999	5400	.W	26663	5690	.W	26330	5974	.W	25999	6253	.W	25672	6527	.W	25347	6795	.W	25024	7058	.W	24705	7316	.W	24388	7569	.W	24074	7816	.W	23763	8059	.W	23454	8296	.W	23148	8528	.W	22845	8756	.W	22545	8978	.W	22247	9195	.W	21951	9408	.W	21659	9615	.W	21369	9818	.W	21081	10016	.W	20796	10209	.W	20514	10397	.W	20234	10581	.W	19957	10760	.W	19682	10935	.W	19410	11104	.W	19141	11270	.W	18874	11431	.W	18609	11587	.W	18347	11739	.W	18087	11886	.W	17830	12029	.W	17575	12168	.W	17323	12302	.W	17073	12432	.W	16826	12558	.W	16581	12679	.W	16338	12797	.W	16098	12910	.W	15860	13019	.W	15625	13125	.W	15391	13226	.W	15160	13323	.W	14932	13416	.W	14706	13505	.W	14482	13591	.W	14260	13672	.W	14041	13750	.W	13824	13824	.W	13609	13894	.W	13396	13960	.W	13186	14023	.W	12977	14082	.W	12771	14137	.W	12568	14189	.W	12366	14238	.W	12167	14283	.W	11969	14324	.W	11774	14362	.W	11581	14396	.W	11390	14428	.W	11201	14456	.W	11015	14480	.W	10830	14501	.W	10648	14520	.W	10467	14534	.W	10289	14546	.W	10112	14555	.W	9938	14560	.W	9766	14563	.W	9595	14562	.W	9427	14559	.W	9261	14553	.W	9096	14543	.W	8934	14531	.W	8773	14516	.W	8615	14498	.W	8458	14478	.W	8304	14454	.W	8151	14428	.W	8000	14400	.W	7851	14368	.W	7703	14334	.W	7558	14298	.W	7415	14259	.W	7273	14217	.W	7133	14174	.W	6995	14127	.W	6859	14079	.W	6724	14028	.W	6592	13974	.W	6461	13919	.W	6331	13861	.W	6204	13801	.W	6078	13738	.W	5954	13674	.W	5832	13608	.W	5711	13539	.W	5592	13469	.W	5475	13396	.W	5359	13321	.W	5245	13245	.W	5133	13167	.W	5022	13087	.W	4913	13005	.W	4805	12921	.W	4699	12835	.W	4595	12748	.W	4492	12659	.W	4391	12569	.W	4291	12477	.W	4193	12383	.W	4096	12288	.W	4001	12191	.W	3907	12093	.W	3815	11993	.W	3724	11892	.W	3634	11790	.W	3546	11686	.W	3460	11581	.W	3375	11475	.W	3291	11367	.W	3209	11259	.W	3128	11149	.W	3049	11038	.W	2970	10926	.W	2894	10813	.W	2818	10699	.W	2744	10584	.W	2671	10468	.W	2600	10351	.W	2529	10233	.W	2460	10115	.W	2393	9995	.W	2326	9875	.W	2261	9754	.W	2197	9633	.W	2134	9511	.W	2073	9388	.W	2012	9264	.W	1953	9140	.W	1895	9016	.W	1838	8891	.W	1783	8766	.W	1728	8640	.W	1675	