	.TITLE	S.ASC	.PROC	M680002	.REF	SMAKY	.REF	MODULES	.LOC	0OBZP1Y:	.BLKB	4		; P1[y]OBZP1X:	.BLKB	4		; P1[x]OBZC1Y:	.BLKB	4		; C1[y]OBZC1X:	.BLKB	4		; C1[x]OBZC2Y:	.BLKB	4		; C2[y]OBZC2X:	.BLKB	4		; C2[x]OBZP2Y:	.BLKB	4		; P2[y]OBZP2X:	.BLKB	4		; P2[x]LBZ:	.LOC	0OBUF:	.BLKB	LBZLGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LIB	?GETPDIS	LOAD.L	A0,A4	LOAD.L	A4,#(A6)+OBUF	LOAD.W	(A4)+OBZP1X,#100	LOAD.W	(A4)+OBZP1Y,#104	LOAD.W	(A4)+OBZC1X,#100	LOAD.W	(A4)+OBZC1Y,#100	LOAD.W	(A4)+OBZC2X,#100	LOAD.W	(A4)+OBZC2Y,#100	LOAD.W	(A4)+OBZP2X,#104	LOAD.W	(A4)+OBZP2Y,#100CALL TOTO	CALL	BZOUTL	LOAD.W	(A4)+OBZP1X,#204	LOAD.W	(A4)+OBZP1Y,#104	LOAD.W	(A4)+OBZC1X,#204	LOAD.W	(A4)+OBZC1Y,#100	LOAD.W	(A4)+OBZC2X,#204	LOAD.W	(A4)+OBZC2Y,#100	LOAD.W	(A4)+OBZP2X,#200	LOAD.W	(A4)+OBZP2Y,#100CALL TOTO	CALL	BZOUTL	LOAD.W	(A4)+OBZP1X,#204	LOAD.W	(A4)+OBZP1Y,#200	LOAD.W	(A4)+OBZC1X,#204	LOAD.W	(A4)+OBZC1Y,#204	LOAD.W	(A4)+OBZC2X,#204	LOAD.W	(A4)+OBZC2Y,#204	LOAD.W	(A4)+OBZP2X,#200	LOAD.W	(A4)+OBZP2Y,#204CALL TOTO	CALL	BZOUTL	LOAD.W	(A4)+OBZP1X,#100	LOAD.W	(A4)+OBZP1Y,#200	LOAD.W	(A4)+OBZC1X,#100	LOAD.W	(A4)+OBZC1Y,#204	LOAD.W	(A4)+OBZC2X,#100	LOAD.W	(A4)+OBZC2Y,#204	LOAD.W	(A4)+OBZP2X,#104	LOAD.W	(A4)+OBZP2Y,#204CALL TOTO	CALL	BZOUTL	EXITTOTO:	LOAD.W	D0,(A4)+OBZP1X	LOAD.W	(A4)+OBZP1X,(A4)+OBZP2X	LOAD.W	(A4)+OBZP2X,D0	LOAD.W	D0,(A4)+OBZP1Y	LOAD.W	(A4)+OBZP1Y,(A4)+OBZP2Y	LOAD.W	(A4)+OBZP2Y,D0	LOAD.W	D0,(A4)+OBZC1X	LOAD.W	(A4)+OBZC1X,(A4)+OBZC2X	LOAD.W	(A4)+OBZC2X,D0	LOAD.W	D0,(A4)+OBZC1Y	LOAD.W	(A4)+OBZC1Y,(A4)+OBZC2Y	LOAD.W	(A4)+OBZC2Y,D0	RET;--------\\; BZOUTL  >;========/; Trace une courbe de bzier trs petite; in	A4.L	^points; out	D7.W	erreur; mod	D7.WBZOUTL:	PUSHM.L	D0..D2	PUSH.W	(A4)+OBZP1X	PUSH.W	(A4)+OBZP1Y	PUSH.W	(A4)+OBZC1X	PUSH.W	(A4)+OBZC1Y	PUSH.W	(A4)+OBZC2X	PUSH.W	(A4)+OBZC2Y	PUSH.W	(A4)+OBZP2X	PUSH.W	(A4)+OBZP2Y	LOAD.W	D7,#1		; D7 <-- impossible	LOAD.W	D0,(A4)+OBZP1X	COMP.W	D0,(A4)+OBZC1X	JUMP',EQ P1X$	LOAD.W	D0,(A4)+OBZP1Y	COMP.W	D0,(A4)+OBZC1Y	JUMP,NE EXIT$	LOAD.W	D0,(A4)+OBZP2X	COMP.W	D0,(A4)+OBZC2X	JUMP,NE EXIT$	LOAD.W	D0,(A4)+OBZP1X	LOAD.W	(A4)+OBZP1X,(A4)+OBZP2X	LOAD.W	(A4)+OBZP2X,D0	LOAD.W	D0,(A4)+OBZP1Y	LOAD.W	(A4)+OBZP1Y,(A4)+OBZP2Y	LOAD.W	(A4)+OBZP2Y,D0	LOAD.W	D0,(A4)+OBZC1X	LOAD.W	(A4)+OBZC1X,(A4)+OBZC2X	LOAD.W	(A4)+OBZC2X,D0	LOAD.W	D0,(A4)+OBZC1Y	LOAD.W	(A4)+OBZC1Y,(A4)+OBZC2Y	LOAD.W	(A4)+OBZC2Y,D0	JUMP'	DIR$P1X$:	LOAD.W	D0,(A4)+OBZP2Y	COMP.W	D0,(A4)+OBZC2Y	JUMP,NE EXIT$DIR$:	CLR.B	D2		; D2 <-- flags	LOAD.W	D0,(A4)+OBZP1X	SUB.W	(A4)+OBZC1X,D0	SUB.W	(A4)+OBZC2X,D0	SUB.W	(A4)+OBZP2X,D0	LOAD.W	D0,(A4)+OBZP1Y	SUB.W	(A4)+OBZC1Y,D0	SUB.W	(A4)+OBZC2Y,D0	SUB.W	(A4)+OBZP2Y,D0	TEST.W	(A4)+OBZP2X	JUMP',NC RIGHT$	NEG.W	(A4)+OBZC1X	NEG.W	(A4)+OBZC2X	NEG.W	(A4)+OBZP2X	TSET.L	D2:#0		; D2 <-- X inversRIGHT$:	TEST.W	(A4)+OBZC1X	JUMP,NS EXIT$	TEST.W	(A4)+OBZC2X	JUMP,NS EXIT$	TEST.W	(A4)+OBZP2X	JUMP,NS EXIT$	LOAD.W	D0,(A4)+OBZP2X	COMP.W	D0,(A4)+OBZC2X	JUMP,LO EXIT$	TEST.W	(A4)+OBZP2Y	JUMP',NC DOWN$	NEG.W	(A4)+OBZC1Y	NEG.W	(A4)+OBZC2Y	NEG.W	(A4)+OBZP2Y	TSET.L	D2:#1		; D2 <-- Y inversDOWN$:	TEST.W	(A4)+OBZC1Y	JUMP,NS EXIT$	TEST.W	(A4)+OBZC2Y	JUMP,NS EXIT$	TEST.W	(A4)+OBZP2Y	JUMP,NS EXIT$	LOAD.L	A3,#R16"TABLE$	LOAD.W	D0,(A4)+OBZP2Y	SWAP.W	D0	LOAD.W	D0,(A4)+OBZP2XSEARCH$:	LOAD.L	D1,(A3)		; lment trouv ?	JUMP',EQ EXIT$		; non => EXIT$	COMP.L	D1,D0	JUMP',EQ FOUND$NEXT$:	TEST.L	(A3+)		; A3 <-- ^lment suivant	JUMP,NE NEXT$	JUMP	SEARCH$FOUND$:	LOAD.L	D0,(A3)		; D0 <-- point relatif (y;x)	TEST.L	D2:#0	JUMP',BC DOTX$	NEG.W	D0DOTX$:	ADD.W	D0,(A4)+OBZP1X	SWAP.W	D0	TEST.L	D2:#1	JUMP',BC DOTY$	NEG.W	D0DOTY$:	ADD.W	D0,(A4)+OBZP1Y	SWAP.W	D0	CALL	DRODOT		; trace un point isol	TEST.L	(A3+)	JUMP,NE FOUND$	CLR.W	D7		; D7 <-- okEXIT$:	POP.W	(A4)+OBZP2Y	POP.W	(A4)+OBZP2X	POP.W	(A4)+OBZC2Y	POP.W	(A4)+OBZC2X	POP.W	(A4)+OBZC1Y	POP.W	(A4)+OBZC1X	POP.W	(A4)+OBZP1Y	POP.W	(A4)+OBZP1X	POPM.L	D0..D2	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	1,0	.W	0,0	.W	0,1	.W	0,0	.W	1,1	.W	0,0	.W	2,1	.W	1,0	.W	0,0	.W	1,2	.W	1,1	.W	0,0	.W	2,2	.W	2,1	.W	1,0	.W	0,0	.W	3,2	.W	3,1	.W	2,0	.W	1,0	.W	0,0	.W	2,3	.W	2,2	.W	2,1	.W	1,0	.W	0,0	.W	3,3	.W	3,2	.W	2,1	.W	1,0	.W	0,0	.W	4,3	.W	4,2	.W	3,1	.W	2,0	.W	1,0	.W	0,0	.W	3,4	.W	3,3	.W	3,2	.W	2,1	.W	1,0	.W	0,0	.W	4,4	.W	4,3	.W	4,2	.W	3,1	.W	2,0	.W	1,0	.W	0,0	.W	0,0;--------\\; DRODOT  >;========/; Trace un seul point.; in	D0.L	point (y;x); out	-; mod	D7.WDRODOT:	PUSHM.L	D1,D4,A2	LOAD.L	D4,D0;;?	LOAD.L	A2,#(A6)+OXCDF	; A2 <-- ^descripteur fentre spcial	LOAD.L	A2,A0	LOAD.W	D1,#SETDOT	GRA_	DOT		; trace un point isol	POPM.L	D1,D4,A2	RETVAR:	.FILLB	LGVAR,0	.END	START