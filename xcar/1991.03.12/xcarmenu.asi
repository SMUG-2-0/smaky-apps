	.SBTTL	XCARMENU.ASI;----------\\; MENUREGLE >;==========/; ; in	-; out	A3.L	^table du mmenu;	A4.L	^paramtres; mod	D7.W, A3.L, A4.LMENUREGLE:	PUSHM.L	D3..D5	CLR.L	(A6)+OMPARG+(LMM*0)+OMMINA	LOAD.L	A3,#(A6)+OBUBIG	LOAD.L	A4,#R16"TMENUREGLE	LOAD.W	D3,#LMENUREGLE-120$:	LOAD.B	(A3+),(A4+)	; OBUBIG <-- menu principal	DECJ.W,NMO D3,20$	LOAD.L	A3,#(A6)+OBUBIG+(250*1)	LOAD.L	A4,#(A6)+OMPARG+(LMM*1)+OMMINA	LOAD.W	D5,#130$:	CALL	MENUREGLEAH	ADD.L	A3,#250	ADD.L	A4,#LMM	INC.W	D5	COMP.W	D5,#6	JUMP,LS 30$	LOAD.L	A3,#(A6)+OBUBIG	; A3 <-- ^mmenu	LOAD.L	A4,#(A6)+OMPARG	; A4 <-- ^paramtres	POPM.L	D3..D5	RET;------------\\; MENUREGLEAH >;------------/; ; in	A3.L	^buffer;	A4.L	^paramtres;	D5.W	opration (1..5); out	-; mod	D7.WMENUREGLEAH:	PUSHM.L	D0..D5,A2..A4	EX.L	A3,A4	CLR.L	(A3)		; pas de cases grises	LOAD.L	A2,#(A6)+ORGDIM	LOAD.B	D1,#ICOREGLEA	CLR.W	D0LOOP$:	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCICF	LOAD.B	(A4+),#GCICS	LOAD.B	(A4+),#GCICT	LOAD.B	(A4+),D1	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCTXF	LOAD.B	(A4+),#GCTXS	LOAD.B	(A4+),#GCTXT	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	COMP.W	D5,#6		; enregistre ?	JUMP',EQ FULL$		; oui => FULL$	LOAD.L	D3,(A3)	TSET.L	D3:D0		; grise la case	LOAD.L	(A3),D3	LOAD.L	D4,(A2)	COMP.W	D5,#2		; dplace X ?	JUMP',NE NOX$	AND.L	D4,#H'FFFFNOX$:	COMP.W	D5,#3		; dplace Y ?	JUMP',NE NOY$	CLR.W	D4NOY$:	TEST.L	D4	JUMP,EQ NEXT$	LOAD.L	D3,(A3)	TCLR.L	D3:D0		; dgrise la case	LOAD.L	(A3),D3FULL$:	TEST.L	(A2)	JUMP,EQ NEXT$	COMP.W	D5,#4		; dplace // ?	JUMP,EQ PUTD$	COMP.W	D5,#5		; dplace R ?	JUMP,EQ PUTA$	COMP.W	D5,#3		; dplace Y ?	JUMP,EQ PUTY$PUTX$:	LOAD.B	(A4+),#'X	LOAD.B	(A4+),#'=	CLR.L	D4	LOAD.W	D4,(A2)+2	JUMP',NC PUTXN$	NEG.W	D4PUTXN$:	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDALL	LIB	?PUTDEC	LOAD.B	(A4+),#SPACE	COMP.W	D5,#2		; dplace X ?	JUMP,EQ NEXT$PUTY$:	LOAD.B	(A4+),#'Y	LOAD.B	(A4+),#'=	CLR.L	D4	LOAD.W	D4,(A2)+0	JUMP',NC PUTYN$	NEG.W	D4PUTYN$:	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDALL	LIB	?PUTDEC	LOAD.B	(A4+),#SPACE	JUMP	NEXT$PUTD$:	LOAD.B	(A4+),#'d	LOAD.B	(A4+),#'=	LOAD.L	D3,(A2)	LIB	?CALCHYPO	AND.L	D4,#H'FFFF	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDALL	LIB	?PUTDEC	LOAD.B	(A4+),#SPACE	JUMP	NEXT$PUTA$:	PUSH.W	D5	LOAD.L	D3,(A2)	LIB	?CALCHYPO	CLR.L	D5	LOAD.W	D5,D4	LOAD.L	D4,D3	CLR.L	D3	LIB	?CALCANGLE	CLR.L	D4	LOAD.W	D4,D2	LOAD.W	D3,#3	CLR.W	D2	LIB	?PUTDEC	POP.W	D5	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'d	LOAD.B	(A4+),#'e	LOAD.B	(A4+),#'g	LOAD.B	(A4+),#'r	LOAD.B	(A4+),#'	LOAD.B	(A4+),#'s	LOAD.B	(A4+),#SPACE;	JUMP	NEXT$NEXT$:	CLR.B	(A4+)	ADD.L	A2,#4		; A2 <-- ^dplacement suivant	INC.B	D1		; D1 <-- icne suivante	INC.W	D0	COMP.W	D0,#8	JUMP,LO LOOP$	CLR.B	(A4+)	COMP.B	(A3)+3,#-1	; toutes les cases grises ?	JUMP',NE EXIT$		; non => EXIT$	TSET.B	(A6)+OMPARG+(LMM*0)+OMMINA+3:D5EXIT$:	POPM.L	D0..D5,A2..A4	RET	.END