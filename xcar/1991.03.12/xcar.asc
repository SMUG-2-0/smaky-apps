	.TITLE	XCAR.ASC;	--------------------------------------;		(C) 1989 - Daniel Roux;	--------------------------------------;	Source du programme XCAR.CODE;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 0.7	14.06.90	pinceau: calcul bbox du "E" ok !; 0.6	27.03.90	df: choix pour gencars trs petits (oxcPMN/PNG); 0.5	27.02.90	df: dition de OGCRBI;			xcOPPEN dans les *00.GENC;			menu du bouton du milieu transform (3 -> 4 sous-menus);			transforme largeur;			transforme pinceau;			transforme remplissage;			si zone entoure avec CURSOR => duplique, tourne, etc. possible; 0.4	11.12.89	adaptation  GRAMISC; 0.2	15.06.89	efface: fonctionne;			XCAR/B SW 50 => gnre un SMA_SWP50.GENC;			plusieurs raccourcis clavier; 0.1	24.04.89	dbut des travaux ...	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	XCAR	.REF	GRAMISCXCARREV	=	0		; rvisionXCARVERS=	7		; version;XCARPROV=	'a		; rvision.version provisoireXCARPROV=	SPACE		; rvision.version dfinitive	.REV	XCARREV,XCARVERS	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"PCVAR	=	1PCCODE	=	2; Constantes; ----------CHOUIA05	=	H'8000		; p'tit chouia = 0.5TPTNIL		=	0		; pas de pointTPTROND		=	1		; point rondTPTRONDHILI	=	1!2^15		; point rond (high light)TPTRONDTJ	=	1!2^14		; point rond (toujours)TPTCARRE	=	2		; point carrTPTCROIX	=	3		; point en croixPOSNIL		=	H'7FFF7FFF	; position jamais utiliseACAIGU		=	H'D1ACGRAVE		=	H'D2ACCIRC		=	H'D3ACTREMA		=	H'D4ACTILDA		=	H'D5ACANGS		=	H'D6ACVE		=	H'DA; Palette; -------IPPOSX	=	8			; position premire icne sup/gaucheIPPOSY	=	8IPDIMX	=	16			; dimensions d'une icneIPDIMY	=	20IPWDOX	=	12			; position image dans dboxIPWDOY	=	40; Dfinition de l'entte d'un gnrateur de caractres; ----------------------------------------------------OGCRBI	=	H'7C		; 4 caractres pour "norm