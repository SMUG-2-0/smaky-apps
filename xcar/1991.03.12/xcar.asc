PEN:	.BLKB	2		; diamtre du pinceauOOBPP1:	.BLKB	4		; Pp1 (y;x)	.BLKB	2OOBPP2:	.BLKB	4		; Pp2 (y;x)	.BLKB	2OOBPS1:	.BLKB	4		; Ps1 (y;x)	.BLKB	2OOBPS2:	.BLKB	4		; Ps2 (y;x)	.BLKB	2OOBTP1:	.BLKB	4		; Tp1 (y;x)OOBTP2:	.BLKB	4		; Tp2 (y;x)OOBTS1:	.BLKB	4		; Ts1 (y;x)OOBTS2:	.BLKB	4		; Ts2 (y;x)OOBRP1:	.BLKB	4		; Rp1 (y;x)OOBRP2:	.BLKB	4		; Rp2 (y;x)OOBRS1:	.BLKB	4		; Rs1 (y;x)OOBRS2:	.BLKB	4		; Rs2 (y;x)LOB:; Variables pour courbe de bezier; -------------------------------;	C1                      C2;	 o----------------------o;	 |                       \;	 |          .     .       \;	 |      .              .   \;	 |   .                     .\;	 | .                         o;	 |.                            P2;	 o  P1	.PC	PCVAR	.LOC	0OBZMOD:	.BLKB	2		; modeOBZP1Y:	.BLKB	4		; P1[y]OBZP1X:	.BLKB	4		; P1[x]OBZC1Y:	.BLKB	4		; C1[y]OBZC1X:	.BLKB	4		; C1[x]OBZC2Y:	.BLKB	4		; C2[y]OBZC2X:	.BLKB	4		; C2[x]OBZP2Y:	.BLKB	4		; P2[y]OBZP2X:	.BLKB	4		; P2[x]LBZ:	.PC	PCVAR	.LOC	0OBZP1I:	.BLKB	4		; P1OBZC1I:	.BLKB	4		; C1OBZC2I:	.BLKB	4		; C2OBZP2I:	.BLKB	4		; P2LBZI:; Variables; ---------	.PC	PCVAR	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHSTRETCH:.BLKB 2		; canal module STRETCHOCHGMI:	.BLKB	2		; canal module GRAMISCOPLCOM:	.BLKB	4		; ^ligne de commandeOSWCOM:	.BLKB	4		; bits switchs aprs XCAROPDDIS:	.BLKB	4		; ^descripteur de la fentreORASTER:.BLKB	4		; adresse de GRA_RASTEROBUDIS:	.BLKB	LBUDIS		; buffer write-displayOWUSE:	.BLKB	2		; compteur utilisation swdoOCCMO:	.BLKB	1		; 1 => souris enleve	.EVENOPGICO:	.BLKB	4		; ^gencar IXP20OLUPX:	.BLKB	2		; centre du lutin en XOLUPY:	.BLKB	2		; centre du lutin en YOLUMAM:	.BLKB	200		; matrice(s) du lutin de la sourisOLUMAN:	.BLKB	200		; matrice(s) du lutin de la sourisOLUTIN:	.BLKB	1		; no lutin de la sourisOLUFLG:	.BLKB	1		; flags pour le lutin BLUMAN	=  0			;  0 => OLUMAM, 1 => OLUMAN	.EVENOOUTIL:	.BLKB	1		; outil selon les icnesODEPL:	.BLKB	1		; dplacementODEPLP:	.BLKB	1		; dplacementOVISU:	.BLKB	1		; visualisationOPOLY:	.BLKB	1		; cration polygoneOBZTYP:	.BLKB	1		; type de courbe de bzier	.EVENOXICO:	.BLKB	2		; niveau des icnes de gaucheOPICO:	.BLKB	4		; ^matrice des icnes de gaucheODICO:	.BLKB	4		; position des icnes de gaucheOTICO:	.BLKB	256/8		; tables des icnes grises (bits)OBICO:	.BLKB	1		; indique si clic haut/bas dans icneOGICO:	.BLKB	1		; indique si clic gauche/droite dans icne	.EVENOLSTOP:	.BLKB	2		; dernire oprationOLSTNB:	.BLKB	2		; dernire valeurOWDOPY:	.BLKB	2		; fentre: coin sup/gauche en YOWDOPX:	.BLKB	2		; fentre: coin sup/gauche en XOWDODY:	.BLKB	2		; fentre: hauteurOWDODX:	.BLKB	2		; fentre: largeurOPETPY:	.BLKB	2		; petit: coin sup/gauche en YOPETPX:	.BLKB	2		; petit: coin sup/gauche en XOPETDY:	.BLKB	2		; petit: hauteurOPETDX:	.BLKB	2		; petit: largeurOPETPM:	.BLKB	4		; petit: ^matriceOPETLM:	.BLKB	4		; petit: lg matriceOPETIR:	.BLKB	1		; petit: 1 => "dessine" dans rgion	.EVENODESPY:	.BLKB	2		; dessin: position en YODESPX:	.BLKB	2		; dessin: position en XODESDY:	.BLKB	2		; dessin: hauteurODESDX:	.BLKB	2		; dessin: largeurOSCALE:	.BLKB	2		; chelle (+/- 1..n)ODMODE:	.BLKB	2		; mode de dessinOASVER:	.BLKB	LSCVAR		; variables de l'ascenseur verticalOASHOR:	.BLKB	LSCVAR		; variables de l'ascenseur horizontalOLSTCH:	.BLKB	4		; canal liste utiliseOLSTC1:	.BLKB	4		; canal liste caractresOLSTC2:	.BLKB	4		; canal liste constructionsORGNPT:	.BLKB	4		; rgion: ^identificateur rgionORGNDB:	.BLKB	LGGBMAP		; rgion: descripteur bitmapOXCPGC:	.BLKB	4		; ^gencarOXCCAR:	.BLKB	2		; caractre visibleOXCCAA:	.BLKB	2		; caractre actuelOMAJ:	.BLKB	1		; 1 => mise  jour ncessaireOMAJC:	.BLKB	1		; 1 => mise  jour caractre ncessaire	.EVENOINFO:	.BLKB	4		; informationsOPEN:	.BLKB	2		; pinceau pour la crationOLPEN:	.BLKB	2		; dernier pinceauOLPOS:	.BLKB	4		; dernire positionORPOS:	.BLKB	4		; dernire position relativeOPSLST:	.BLKB	6*10		; liste des poignes [^objet/offset]OMPAZO:	.BLKB	LMM*6		; paramtres pour "zone"OMPAOB:	.BLKB	LMM*6		; paramtres pour "objet"OMPARG:	.BLKB	LMM*10		; paramtres pour "rgle"OMPARE:	.BLKB	LMM*1		; paramtres pour "relatif"OMPAMI:	.BLKB	LMM*6		; paramtres pour "milieu"OPODEP:	.BLKB	4		; polygone: dpartOPOARR:	.BLKB	4		; polygone: arriveOPOAR1:	.BLKB	4		; polygone: arrive 1OPOAR2:	.BLKB	4		; polygone: arrive 2OPOPOI:	.BLKB	4		; polygone: position poigne carreOPONBO:	.BLKB	2		; polygone: nb d'objets crsOPOOPE:	.BLKB	1		; polygone: 1 => ouvert	.EVENOIPPT:	.BLKB	4		; image palette: ^dataOIPDIM:	.BLKB	4		; image palette: dimensions (dy;dx)OIFPT:	.BLKB	4		; image fond: ^dataOIFDIM:	.BLKB	4		; image fond: dimensions (dy;dx)OIFSPO:	.BLKB	4		; image fond: position origine [pf]OIFSPT:	.BLKB	4		; image fond: ^image stretcheOIFSLP:	.BLKB	4		; image fond: dernire position [pi]OIFSLZ:	.BLKB	2		; image fond: dernier zoomOIODDF:				; ----------- dbut df.	.BLKB	4		; rserveOBUFIM:	.BLKB	LBUFILE		; nom du fichier en entre (image)OIZOOM:	.BLKB	2		; facteur de zoom spcial pour image (*1000)OBIZOOM:.BLKB	10		; buffer pour valeur de zoom pour imageOFADEFI:.BLKB	4		; fanions dfinitions image	.BLKB	44		; rserveOIFTAP:	.BLKB	4*xcNBCAR	; image fond: table des positionsORGDIM:	.BLKB	4*8		; rgle: dimensions enregistres	.BLKB	96		; rserveOIOFDF:				; ----------- fin df.OFAADD:	.BLKB	4		; fanions add BFAADDLINK	=  0 BFAADDREEL	=  1 BFAADDOTHER	=  2 BFAADDCAR	=  8 BFAADDCHAS	=  9OXZOOM:	.BLKB	2		; facteur de zoom spcial en X (*1000)OYZOOM:	.BLKB	2		; facteur de zoom spcial en Y (*1000)OBXZOOM:.BLKB	10		; buffer pour valeur de zoom en XOBYZOOM:.BLKB	10		; buffer pour valeur de zoom en YOFAZOOM:.BLKB	4		; fanions zoomOFATRAN:.BLKB	4		; fanions transformationOIPTRAN:.BLKB	2		; inclinaison en %OBITRAN:.BLKB	10		; buffer pour inclinaisonOLPTRAN:.BLKB	2		; largeur en %OBLTRAN:.BLKB	10		; buffer pour largeurOFFTRAN:.BLKB	4		; fanions transformation remplissageOFAACCE:.BLKB	4		; fanions accentsOTSVBM:.BLKB	2		; taille pour sauve bitmapOBTSVBM:.BLKB	10		; buffer pour sauve bitmapOSTVAR:	.BLKB	ST_LGTRECT	; variables pour le module STRETCHOBUNAME:.BLKB	LBUFILE		; nom du dessin en mmoireOBUFIN:	.BLKB	LBUFILE		; nom du fichier en entre (prend)OBUFAJ:	.BLKB	LBUFILE		; nom du fichier en entre (ajoute)OBUFDF:	.BLKB	LBUFILE		; nom du fichier des dfinitionsOBUFOUT:.BLKB	LBUFILE		; nom du fichier en sortieOBXFILE:.BLKB	LBUFILE		; nom du fichier avec extensionOBUHEAD:.BLKB	256		; buffer en-tteOBUBIG:	.BLKB	2000		; big bufferLGVAR:; Programme; ---------	.PC	PCCODE	.LOC	0	JUMP	START; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMSTRETCH:	.ASCIZ	"STRETCH"NMGMI:		.ASCIZ	"TGRAMIS"NMIMAP:		.ASCIZ	"XCAR_P.IMAGE"	; image de la palette des caractres; Erreurs fatales; ---------------TXERFATREV:	.ASCIZ	"La rvision du systme est incompatible"TXERFATDIS:	.ASCIZ	"Driver d'cran incompatible"TXERFATTXT:	.ASCIZ	"Erreur avec le gencar NEF11"TXERFATICO:	.ASCIZ	"Erreur avec le gencar IXP20"	.EVENSTART:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CALL	_WAITMOUSE	; met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*6+0	; est-ce au moins 6.0 ?	JUMP,LO ERFAT2		; non => ERFAT2	LIB	?GETPDIS	LOAD.L	(A6)+OPDDIS,A4	LOAD.L	A0,A4		; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	LOAD.L	A3,#R16"TXERFATICO	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN	LOAD.L	(A6)+OPGICO,(A0)+ODFPGC	LOAD.L	A3,#R16"TXERFATTXT	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	LOAD.L	(A6)+ORASTER,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMSTRETCH	LOAD.W	D3,#ST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSTRETCH,D1	LOAD.L	A3,#R16"NMGMI	LOAD.W	D3,#GMI_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHGMI,D1	LOAD.L	A3,#R16"NMIMAP	CALL	_LOADIMAGE	; charge l'image "XCAR_P.IMAGE"	JUMP,NE ERFAT2	LOAD.L	(A6)+OIPPT,A4	LOAD.L	(A6)+OIPDIM,D4	CLR.L	D3		; D3 <-- mode	CLR.W	D4		; D4 <-- lg standard	CALL	__OBJ_LOPEN	; ouvre une nouvelle liste	JUMP,NE ERFAT2	LOAD.L	(A6)+OLSTC2,D6	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	#(A6)+ORGNPT	; stack <-- ^VAR identificateur rgion	GMI_	NEWRGN		; A4 <-- ^rgion	POP.W	D7	JUMP,NE ERFAT2	LOAD.B	(A6)+OOUTIL,#ICOMOVE	LOAD.B	(A6)+ODEPL,#ICODEPLXY	LOAD.B	(A6)+ODEPLP,#ICODEPLP2	LOAD.B	(A6)+OVISU,#ICOVCAR	LOAD.B	(A6)+OPOLY,#ICOPLINE	LOAD.W	(A6)+ODESDX,#1500*2	LOAD.W	(A6)+ODESDY,#1500*2;	LOAD.W	(A6)+ODESPX,#1500-200;	LOAD.W	(A6)+ODESPY,#1500-500	LOAD.W	(A6)+OXCCAR,#'A	LOAD.W	(A6)+OSCALE,#-6	LOAD.W	(A6)+ODMODE,#INVDOT	LOAD.L	(A6)+OFAADD,#2^BFAADDREEL!2^BFAADDCAR	LOAD.L	(A6)+OFAZOOM,#2^0	LOAD.W	(A6)+OIZOOM,#1000*1	LOAD.B	(A6)+OBIZOOM,#'1	LOAD.L	(A6)+OFATRAN,#2^0	LOAD.L	(A6)+OFAACCE,#2^0!2^1	CALL	_CCMO		; enlve la souris	CALL	CALCADRE	; calcul pos/dim de la fentre de dessin	CALL	DESWDO	CALL	DESCADRE	CALL	_AFMENU		; affiche les soft-keys	LIB	?BUZZ		; signal: c'est prt !	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SWITCH		; D3 <-- bits switch aprs XCAR	LOAD.L	(A6)+OSWCOM,D3	LIB	?SKPNAM	JUMP,NE LOOP	LOAD.L	A4,#(A6)+OBUFIN70$:	LOAD.B	D3,(A3+)	JUMP',EQ 75$	COMP.B	D3,#CR	JUMP',EQ 75$	COMP.B	D3,#SPACE	JUMP',EQ 75$	COMP.B	D3,#TAB	JUMP',EQ 75$	COMP.B	D3,#'/	JUMP',EQ 75$	LOAD.B	(A4+),D3	; OBUFIN <-- nom ligne de commande	JUMP	70$75$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUFIN	; A3 <-- ^nom	JUMP	_DOPRENDF	; essaye de prendre ce fichier ...LOOP:	LOAD.L	D3,(A6)+OSWCOM	TEST.L	D3:#31		; quitte XCAR ?	JUMP,BS DOFINI		; oui => DOFINI	TEST.L	D3:#'B-'A	; XCAR/B ?	JUMP,BS _DOSAUVEBMF	; oui => DOSAUVEBMF	CALL	_SCMO		; remet la souris	CALL	_NORMMOUSE	; enlve le sablier20$:	LOAD.B	D3,(A6)+OOUTIL	CALL	_SELMO		; utilise le bon lutin	CALL	DESINFXY	; affiche X= et Y= dans les informations70$:	LIB	?GETKEY		; attend clavier/souris ...	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP,BS 70$		; non => 70$				; oui =>	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ 20$		; oui => 20$EXECUTE:	COMP.W	D3,#F0+SHIFT	JUMP',LO 10$	COMP.W	D3,#F15+SHIFT	JUMP',HI 10$	SUB.W	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)10$:	LOAD.W	D2,D3	LIB	?MINMAJ	EX.L	D2,D3	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC	COMP.W	D3,#F0	JUMP,EQ DOFINI	COMP.W	D3,#END	JUMP,EQ DOFINI	COMP.W	D3,#F1	JUMP,EQ _DOPREND	COMP.W	D3,#H'100*(2^BSHOW)+DEFINE	JUMP,EQ _DOPREND	COMP.W	D3,#F3	JUMP,EQ _DOSAUVE	COMP.W	D3,#H'100*(2^BCOPY)+DEFINE	JUMP,EQ _DOSAUVE	COMP.W	D3,#F4	JUMP,EQ DODEFGC	COMP.W	D3,#F7	JUMP,EQ SCALEM	COMP.W	D3,#F8	JUMP,EQ SCALE1	COMP.W	D3,#F9	JUMP,EQ SCALEP	COMP.W	D3,#F14	JUMP,EQ DOEFFACE	COMP.W	D3,#CR	JUMP,EQ CNEXT	COMP.W	D3,#SCR	JUMP,EQ CPREV	COMP.W	D3,#UNDO	JUMP,EQ DOUNDO	COMP.W	D3,#UNDO+SHIFT	JUMP,EQ DOSUNDO	COMP.W	D2,#H'100*(2^BCURSOR)+'D	JUMP,EQ DODEPLG	COMP.W	D2,#H'100*(2^BCURSOR)+'F	JUMP,EQ DODEPLD	COMP.W	D2,#H'100*(2^BCURSOR)+'R	JUMP,EQ DODEPLH	COMP.W	D2,#H'100*(2^BCURSOR)+'C	JUMP,EQ DODEPLB	COMP.W	D2,#H'100*(2^BCURSOR)+'S	JUMP,EQ DODEPLG10	COMP.W	D2,#H'100*(2^BCURSOR)+'G	JUMP,EQ DODEPLD10	COMP.W	D2,#H'100*(2^BCURSOR)+'E	JUMP,EQ DODEPLH10	COMP.W	D2,#H'100*(2^BCURSOR)+'X	JUMP,EQ DODEPLB10	COMP.W	D2,#H'100*(2^BSHOW)+'G	JUMP,EQ _DOPREND	COMP.W	D2,#H'100*(2^BCOPY)+'G	JUMP,EQ _DOSAUVE	COMP.W	D2,#H'100*(2^BCOPY)+'B	JUMP,EQ _DOSAUVEBM	COMP.W	D2,#H'100*(2^BSHOW)+'D	JUMP,EQ _DOPRENDDF	COMP.W	D2,#H'100*(2^BCOPY)+'D	JUMP,EQ _DOSAUVEDF	COMP.W	D2,#H'100*(2^BSHOW)+'I	JUMP,EQ _DOIMAGE	COMP.W	D2,#H'100*(2^BPROGRA)+'I	JUMP,EQ DODEFIM	COMP.W	D2,#H'100*(2^BPROGRA)+'A	JUMP,EQ DOADD	COMP.W	D2,#H'100*(2^BKILL)+'C	JUMP,EQ DORELDEL	COMP.W	D2,#H'100*(2^BPROGRA)+'F	JUMP,EQ DOCFIX	COMP.W	D3,#H'100*(2^BPROGRA)+'	JUMP,EQ DOACCENT	COMP.W	D2,#H'100*(2^BSHOW)+SPACE	JUMP,EQ DOPOSIMA	COMP.W	D2,#H'100*(2^BPROGRA)+'D	JUMP,EQ DODEBUG	COMP.W	D2,#H'100*(2^BPROGRA)+'M	JUMP,EQ DOMINMAX	COMP.W	D3,#H'100*(2^BPROGRA)+'1	JUMP,EQ DOBEZIER1	COMP.W	D3,#H'100*(2^BPROGRA)+'2	JUMP,EQ DOBEZIER2	COMP.W	D3,#128	JUMP,HS BIP	COMP.W	D3,(A6)+OXCCAR	JUMP,EQ BIP	LOAD.W	(A6)+OXCCAR,D3	CALL	NEWCAR		; dessine le nouveau caractre	CALL	MAJCODE		; montre le caractre en dition	JUMP	LOOPDODEFGC:	CALL	DBOXDEF		; dfinitions gnrales ...	JUMP,NE ERROR	CALL	PETAFF		; dessine le petit caractre rel	JUMP	LOOPDODEFIM:	CALL	DBOXDEFIM	; dfinitions image de fond ...	JUMP,NE ERROR	CALL	DESCAR		; redessine le caractre	JUMP	LOOPSCALEM:	LOAD.W	D3,#-1	CALL	NEXTSCALE	JUMP,NE BIP	JUMP'	SCALEXSCALEP:	LOAD.W	D3,#+1	CALL	NEXTSCALE	JUMP,NE BIP	JUMP'	SCALEXSCALE1:	CLR.W	D4;	JUMP'	SCALEXSCALEX:	COMP.W	D4,(A6)+OSCALE	; chelle change ?	JUMP,EQ BIP		; non => BIP	LOAD.W	D3,(A6)+OWDODY	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,(A6)+OWDODX	SR.W	D3,#1	CALL	CONVPGPI	; D3 <-- centre partie visible [pi]	CALL	NEWSCALE	; change l'chelle	JUMP	LOOPDOUNDO:	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ BIP	LOAD.W	D3,(A6)+OLSTOP	COMP.W	D3,#OPMOVE	JUMP',EQ DEPLACE$	COMP.W	D3,#OPZODEPLACE	JUMP',EQ DEPLACE$	COMP.W	D3,#OPZOZOOM	JUMP',EQ DEPLACE$	COMP.W	D3,#OPZOTOURNE	JUMP',EQ DEPLACE$	COMP.W	D3,#OPZOMIROIR	JUMP',EQ DEPLACE$	COMP.W	D3,#OPOBDEPLACE	JUMP',EQ DEPLACE$	COMP.W	D3,#OPCRPOLY	JUMP',EQ CREATE$	COMP.W	D3,#OPCRCIRCLE	JUMP',EQ CREATE$	COMP.W	D3,#OPCRLINE	JUMP',EQ CREATE$	COMP.W	D3,#OPCRRECT	JUMP',EQ CREATE$	COMP.W	D3,#OPCRELLIPSE	JUMP',EQ CREATE$	COMP.W	D3,#OPCRADDCHAR	JUMP',EQ CREATE$	JUMP	BIPDEPLACE$:	CALL	PSEXCHPT	; OOBTxx <--> OOBPxx	CALL	DESCAR		; redessine le caractre	JUMP	LOOPCREATE$:	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ BIP	LOAD.W	D3,(A6)+OLSTNBCREATE2$:	CALL	__OBJ_LLAST	; A4 <-- ^dernier objet	JUMP',NE CREATE4$	CALL	__OBJ_LREMOVE	; dtruit le dernier objet cr	DEC.W	D3	JUMP,NE CREATE2$CREATE4$:	CALL	DESCAR		; redessine le caractre	LOAD.W	(A6)+OLSTOP,#OPNIL	JUMP	LOOPDOSUNDO:	LOAD.W	(A6)+OXCCAA,#-1	CALL	NEWCAR		; redessine le caractre initial	JUMP	LOOPDOEFFACE:	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ BIP20$:	CALL	__OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE 30$	CALL	__OBJ_LREMOVE	; dtruit l'objet	JUMP	20$30$:	CALL	DESCAR		; redessine le caractre	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPNIL	JUMP	LOOPDODEPLD:	LOAD.W	D0,#0	SWAP.W	D0	LOAD.W	D0,#+1	JUMP'	DODEPLXDODEPLD10:	LOAD.W	D0,#0	SWAP.W	D0	LOAD.W	D0,#+10	JUMP'	DODEPLXDODEPLG:	LOAD.W	D0,#0	SWAP.W	D0	LOAD.W	D0,#-1	JUMP'	DODEPLXDODEPLG10:	LOAD.W	D0,#0	SWAP.W	D0	LOAD.W	D0,#-10	JUMP'	DODEPLXDODEPLH:	LOAD.W	D0,#-1	SWAP.W	D0	LOAD.W	D0,#0	JUMP'	DODEPLXDODEPLH10:	LOAD.W	D0,#-10	SWAP.W	D0	LOAD.W	D0,#0	JUMP'	DODEPLXDODEPLB:	LOAD.W	D0,#+1	SWAP.W	D0	LOAD.W	D0,#0	JUMP'	DODEPLXDODEPLB10:	LOAD.W	D0,#+10	SWAP.W	D0	LOAD.W	D0,#0;	JUMP'	DODEPLXDODEPLX:	LOAD.L	D4,D0	NEG.W	(A6)+OSCALE	CALL	D4SCALE	NEG.W	(A6)+OSCALE	LOAD.L	D0,D4	CALL	TRDEPLCAR	; dplace le caractre	CALL	DESCAR	JUMP	LOOPDOADD:	CALL	DBOXADD		; choix du caractre ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	TEST.L	D4:#BFAADDLINK	JUMP,BS DOADDLINK	TEST.L	D4:#BFAADDREEL	JUMP,BS DOADDREEL	TEST.L	D4:#BFAADDOTHER	JUMP,BS DOADDOTHER	JUMP	LOOPDOADDLINK:	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ BIP	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	JUMP,NE ERROR	LOAD.W	(A4)+OOBTYP,#xcOPADDCHAR;	CLR.L	(A4)+OOBPP1	LOAD.B	(A4)+OOBPP2,D2	CALL	DESOBJET	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPCRADDCHAR	LOAD.W	(A6)+OLSTNB,#1	JUMP	LOOPDOADDREEL:	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D3,D2		; D3 <-- caractre	LOAD.W	D2,#1		; D2 <-- pas les "FILLx"	TEST.L	D4:#BFAADDCAR	JUMP',BC 20$	CALL	_DECODEADD	; liste <-- ajoute tous les objets20$:	TEST.L	D4:#BFAADDCHAS	JUMP',BC 30$	CALL	_DECODEADDCHAS	; chasse <-- chasse de l'autre30$:	CALL	DESCAR		; redessine le caractre	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPCRADDCHAR	LOAD.W	(A6)+OLSTNB,D1	JUMP	LOOPDOADDOTHER:	CALL	PRENDTOUT	; A4 <-- ^gencar lu	JUMP,NE ERROR	LOAD.L	A3,#(A4)+256	LOAD.W	D3,D2		; D3 <-- caractre	LOAD.W	D2,#1		; D2 <-- pas les "FILLx"	TEST.L	D4:#BFAADDCAR	JUMP',BC 20$	CALL	_DECODEADD	; liste <-- ajoute tous les objets20$:	TEST.L	D4:#BFAADDCHAS	JUMP',BC 30$	CALL	_DECODEADDCHAS	; chasse <-- chasse de l'autre30$:	LOAD.W	D2,D1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le gencar lu	CALL	DESCAR		; redessine le caractre	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPCRADDCHAR	LOAD.W	(A6)+OLSTNB,D2	JUMP	LOOPDORELDEL:	CALL	RELDEL		; enlve tous les relatifs	CALL	DESCAR		; redessine le caractre	JUMP	LOOPDOCFIX:	CALL	DBOXCFIX	; demande oui/non ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D3,(A6)+OXCCAR	; D3 <-- caractre	SL.W	D3,#1	LOAD.L	A3,#(A3)+oxcLENGTH	LOAD.W	D4,(A3)+(D3.W)	; D4 <-- chasse caractre actuelle	LOAD.W	D3,#xcNBCAR-120$:	LOAD.W	(A3+),D4	DECJ.W,NMO D3,20$	SET.B	(A6)+OMAJ	JUMP	LOOPDOITAL:	CALL	DBOXITAL	; demande quelle transformation ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	TEST.B	(A6)+OFATRAN+3:#1-0	JUMP',BS ALL$ONE$:	CALL	TRITALCAR	; transforme le caractre	CALL	DESCAR	JUMP	LOOPALL$:	CALL	_WAITMOUSE	PUSH.W	(A6)+OXCCAR	PUSH.L	(A6)+OPETDY	CLR.W	(A6)+OXCCAR	CLR.L	(A6)+OPETDYLOOP$:	CALL	NEWCARQ		; dessine le nouveau caractre	CALL	TRITALCAR	; transforme le caractre	INC.W	(A6)+OXCCAR	COMP.W	(A6)+OXCCAR,#xcNBCAR	JUMP,LO LOOP$	POP.L	(A6)+OPETDY	POP.W	(A6)+OXCCAR	CALL	NEWCAR		; dessine le caractre initial	JUMP	LOOPDOLARG:	CALL	DBOXLARG	; demande quelle transformation ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	TEST.B	(A6)+OFATRAN+3:#1-0	JUMP',BS ALL$ONE$:	CALL	TRLARGCAR	; transforme le caractre	CALL	DESCAR	JUMP	LOOPALL$:	CALL	_WAITMOUSE	PUSH.W	(A6)+OXCCAR	PUSH.L	(A6)+OPETDY	CLR.W	(A6)+OXCCAR	CLR.L	(A6)+OPETDYLOOP$:	CALL	NEWCARQ		; dessine le nouveau caractre	CALL	TRLARGCAR	; transforme le caractre	INC.W	(A6)+OXCCAR	COMP.W	(A6)+OXCCAR,#xcNBCAR	JUMP,LO LOOP$	POP.L	(A6)+OPETDY	POP.W	(A6)+OXCCAR	CALL	NEWCAR		; dessine le caractre initial	JUMP	LOOPDOPEN:	CALL	DBOXPEN		; demande quelle transformation ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	_WAITMOUSE	PUSH.W	(A6)+OXCCAR	PUSH.L	(A6)+OPETDY	CLR.W	(A6)+OXCCAR	CLR.L	(A6)+OPETDYLOOP$:	CALL	NEWCARQ		; dessine le nouveau caractre	CALL	TRPENCAR	; transforme le caractre	INC.W	(A6)+OXCCAR	COMP.W	(A6)+OXCCAR,#xcNBCAR	JUMP,LO LOOP$	POP.L	(A6)+OPETDY	POP.W	(A6)+OXCCAR	CALL	NEWCAR		; dessine le caractre initial	JUMP	LOOPDOFILL:	CALL	DBOXFILL	; demande quelle transformation ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	_WAITMOUSE	PUSH.W	(A6)+OXCCAR	PUSH.L	(A6)+OPETDY	CLR.W	(A6)+OXCCAR	CLR.L	(A6)+OPETDYLOOP$:	CALL	NEWCARQ		; dessine le nouveau caractre	LOAD.L	D4,(A6)+OFFTRAN	COMP.L	D4,(A6)+OINFO	JUMP',EQ NEXT$	LOAD.L	(A6)+OINFO,D4	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJCNEXT$:	INC.W	(A6)+OXCCAR	COMP.W	(A6)+OXCCAR,#xcNBCAR	JUMP,LO LOOP$	POP.L	(A6)+OPETDY	POP.W	(A6)+OXCCAR	CALL	NEWCAR		; dessine le caractre initial	JUMP	LOOPDOACCENT:	CALL	DBOXACCENT	; demande ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	PUSH.W	(A6)+OXCCAR	PUSH.L	(A6)+OPETDY	CLR.L	(A6)+OPETDY	LOAD.L	A2,#R16"TABLE$-320$:	ADD.L	A2,#3		; A2 <-- ^suivant	CLR.W	D3	LOAD.B	D3,(A2)+0	; D3 <-- code du caractre	JUMP,EQ 50$	TEST.B	(A6)+OFAACCE+3:#0	JUMP',BS 30$	COMP.W	D3,#H'80	JUMP,LO 20$30$:	TEST.B	(A6)+OFAACCE+3:#1	JUMP',BS 31$	COMP.W	D3,#H'80	JUMP,HS 20$31$:	LOAD.W	(A6)+OXCCAR,D3	CALL	NEWCARQ	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ 20$32$:	CALL	__OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE 34$	CALL	__OBJ_LREMOVE	; dtruit l'objet	JUMP	32$34$:	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	JUMP,NE ERROR	LOAD.W	(A4)+OOBTYP,#xcOPADDCHAR;	CLR.L	(A4)+OOBPP1	LOAD.B	(A4)+OOBPP2,(A2)+2	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	JUMP,NE ERROR	LOAD.W	(A4)+OOBTYP,#xcOPADDCHAR;	CLR.L	(A4)+OOBPP1	LOAD.B	(A4)+OOBPP2,(A2)+1	CLR.W	D3	LOAD.B	D3,(A2)+1	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	CALL	_DECODEADDCHAS	; chasse <-- chasse de l'autre	SET.B	(A6)+OMAJC	JUMP	20$50$:	POP.L	(A6)+OPETDY	POP.W	(A6)+OXCCAR	SET.B	(A6)+OMAJ	CALL	NEWCAR		; dessine le caractre initial	JUMP	LOOPTABLE$:	.B	H'0F,'u,ACTREMA	.B	H'10,'a,ACGRAVE	.B	H'11,'a,ACCIRC	.B	H'12,'e,ACAIGU	.B	H'13,'e,ACGRAVE	.B	H'14,'e,ACTREMA	.B	H'15,'e,ACCIRC	.B	H'16,H'B0,ACTREMA	.B	H'17,H'B0,ACCIRC	.B	H'18,'o,ACCIRC	.B	H'19,'u,ACGRAVE	.B	H'1A,'u,ACCIRC	.B	H'1B,'a,ACTREMA	.B	H'1C,'o,ACTREMA	.B	H'81,'A,ACAIGU	.B	H'82,'A,ACGRAVE	.B	H'83,'A,ACCIRC	.B	H'84,'A,ACTREMA	.B	H'85,'A,ACTILDA	.B	H'86,'A,ACANGS	.B	H'88,'E,ACAIGU	.B	H'89,'E,ACGRAVE	.B	H'8A,'E,ACCIRC	.B	H'8B,'E,ACTREMA	.B	H'8C,'I,ACAIGU	.B	H'8D,'I,ACGRAVE	.B	H'8E,'I,ACCIRC	.B	H'8F,'I,ACTREMA	.B	H'91,'N,ACTILDA	.B	H'92,'O,ACAIGU	.B	H'93,'O,ACGRAVE	.B	H'94,'O,ACCIRC	.B	H'95,'O,ACTREMA	.B	H'96,'O,ACTILDA	.B	H'97,'O,'/	.B	H'98,'U,ACAIGU	.B	H'99,'U,ACGRAVE	.B	H'9A,'U,ACCIRC	.B	H'9B,'U,ACTREMA	.B	H'9C,'Y,ACTREMA	.B	H'A1,'a,ACAIGU	.B	H'A2,'c,ACAIGU	.B	H'A3,'c,ACVE	.B	H'A4,'s,ACVE	.B	H'A5,'a,ACTILDA	.B	H'A6,'a,ACANGS	.B	H'A7,'z,ACVE	.B	H'A8,'C,ACAIGU	.B	H'A9,'C,ACVE	.B	H'AA,'S,ACVE	.B	H'AB,'Z,ACVE	.B	H'AC,H'B0,ACAIGU	.B	H'AD,H'B0,ACGRAVE	.B	H'B1,'n,ACTILDA	.B	H'B2,'o,ACAIGU	.B	H'B3,'o,ACGRAVE	.B	H'B6,'o,ACTILDA	.B	H'B7,'o,'/	.B	H'B8,'u,ACAIGU	.B	H'BC,'y,ACTREMA	.B	0	.EVENDOPOSIMA:	TEST.L	(A6)+OIFPT	; image de fond existe ?	JUMP,EQ BIP		; non => BIP				; oui =>	TNOT.B	(A6)+OFADEFI+3:#0	LOAD.L	(A6)+OIFSLP,#POSNIL	CALL	DESCAR		; redessine le caractre	JUMP	LOOPDOMINMAX:	CALL	_WAITMOUSE	; souris: met le sablier	CALL	_MINMAXREFAIT	; recalcule toutes les "bounding box"	LIB	?BUZZ		; boiiiiiiing, c'est fini !	JUMP	LOOPDOBEZIER1:	LOAD.B	(A6)+OBZTYP,#1	CALL	DESCAR	JUMP	LOOPDOBEZIER2:	LOAD.B	(A6)+OBZTYP,#2	CALL	DESCAR	JUMP	LOOPDODEBUG:	CALL	OPEWDO		; dessine dans la swdo	LOAD.W	D3,#1	LIB	?DISWKEY	; attend si fentre pleine	LIB	?AFTIM	.B	EOP,CR,0	.EVEN	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP',EQ END$	CALL	__OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	CALL	DESDEBUG	; dessine un objet	CALL	__OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	LIB	?AFTIM	.ASCIZ	"<CR>	Appuyez sur une touche ..."	.EVEN	LIB	?GETCAR	CLR.W	D3	LIB	?DISWKEY	; n'attend plus si fentre pleine	CALL	CLOWDO		; dessine normalement	CALL	DESCAR	JUMP	LOOPBIP:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPBIGBIP:				; erreur =>	LOAD.B	D3,#BIPERR	LIB	?BEEP		; grand bruit	JUMP	LOOPERROR:	PUSH.W	D7	CALL	_SCMO		; remet la flche	CALL	_NORMMOUSE	; remet la flche	POP.W	D7	TEST.W	D7	JUMP,EQ LOOP	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	_AFMENU		; refait les soft-keys	JUMP	LOOPDOFINI:	CLR.W	D0		; D0 <-- avant de quitter	CALL	DBOXSAVE	; sauve si ncessaire le gencar actuel	JUMP',EQ 20$		; ok => 20$	COMP.W	D7,#1		; (ANNULE) ?	JUMP,EQ LOOP		; oui => LOOP	JUMP	ERROR		; non => ERROR20$:	TEST.L	(A6)+OSWCOM	JUMP',NE ERFAT	CALL	DBOXQUITTE	; demande s'il faut quitter ...	COMP.W	D3,#F1	JUMP,NE LOOPERFAT:	TEST.L	(A6)+ORGNPT	JUMP',EQ 20$	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+ORGNPT	; stack <-- ^identificateur rgion	GMI_	DISPOSERGN	; libre la rgion	POP.W	D720$:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSTRETCH	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHGMI	LIB_	CLOSEERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	XCARCLIC.ASI	.INS	XCARMENU.ASI	.INS	XCARDET.ASI	.INS	XCARREL.ASI	.INS	XCARLINE.ASI	.INS	XCARPETIT.ASI	.INS	XCARDBOX.ASI	.INS	XCARDBOXT.ASI_AFMENU:	JUMP	AFMENU_CCMO:		JUMP	CCMO_SCMO:		JUMP	SCMO_SELMO:		JUMP	SELMO_NORMMOUSE:	JUMP	NORMMOUSE_WAITMOUSE:	JUMP	WAITMOUSE_LOADIMAGE:	JUMP	LOADIMAGE_IFMOUSE:	JUMP	IFMOUSE_IFMOUSEW:	JUMP	IFMOUSEW_MMENUS:	JUMP	MMENUS_WAITMOVE:	JUMP	WAITMOVE_MINMAXREFAIT:	JUMP	MINMAXREFAIT_DOPRENDF:	JUMP	DOPRENDF_DOSAUVEBMF:	JUMP	DOSAUVEBMF_DOSAUVEBM:	JUMP	DOSAUVEBM_DOSAUVEDF:	JUMP	DOSAUVEDF_DOPRENDDF:	JUMP	DOPRENDDF_DOPREND:	JUMP	DOPREND_DOSAUVE:	JUMP	DOSAUVE_DOIMAGE:	JUMP	DOIMAGE_DECODEADD:	JUMP	DECODEADD_DECODEADDCHAS:	JUMP	DECODEADDCHAS_CALCPSYM:	JUMP	CALCPSYM__OBJ_LOPEN:	JUMP	_OBJ_LOPEN__OBJ_LFIRST:	JUMP	_OBJ_LFIRST__OBJ_LLAST:	JUMP	_OBJ_LLAST__OBJ_LNEXT:	JUMP	_OBJ_LNEXT__OBJ_LPREV:	JUMP	_OBJ_LPREV__OBJ_LREMOVE:	JUMP	_OBJ_LREMOVE__OBJ_LINSERT:	JUMP	_OBJ_LINSERT_LOOP:		JUMP	LOOP	.INS	XCARTABLE.ASI	.INS	XCARCADRE.ASI	.INS	XCARICONE.ASI	.INS	XCARIO.ASI	.INS	XCARCONV.ASI	.INS	XCARMINMAX.ASI	.INS	XCARLIST.ASI	.INS	XCARIMAGE.ASI	.INS	XCARMISC.ASI	.END	START