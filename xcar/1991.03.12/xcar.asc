seICOVCONS	=	21	; visualise: constructionICOREGLE	=	22	; rgleICOPOSIMA	=	23	; position de l'imageICODEPLP1	=	24	; dplacement li type 1ICODEPLP2	=	25	; dplacement li type 2ICODEPLP3	=	26	; dplacement li type 3ICODEPLXY	=	27	; dplacement libreICODEPLX	=	28	; dplacement selon XICODEPLY	=	29	; dplacement selon YICODACCORD	=	30	; d'accordICOANNULE	=	31	; annuleICOTRANSFORME	=	32	; transformeICOACCENT	=	33	; accentsICOADD		=	34	; addICOUNDO1	=	35	; undo 1ICOUNDOT	=	36	; undo toutICOUNDOT2	=	37	; undo tout (double largeur)ICOOPEN		=	38	; courbe ouverteICOCLOSE	=	39	; courbe fermeICOINFO		=	40	; informationsICOTITAL	=	44	; transforme: italiqueICOTLARG	=	45	; transforme: largeurICOTPEN		=	46	; transforme: pinceauICOTFILL	=	47	; transforme: remplissageICOPRESS	=	48	; bouton souris pressICODETRUIT	=	49	; dtruitICODEPLACE	=	50	; dplaceICODUPLIQUE	=	51	; dupliqueICODIVERS	=	52	; diversICOZOOM		=	53	; zoomICOTOURNE	=	54	; tourneICOMIROIR	=	55	; miroirICOZOOMPXY	=	56	; zoom +xyICOZOOMPX	=	57	; zoom +xICOZOOMPY	=	58	; zoom +yICOZOOMMXY	=	59	; zoom -xyICOZOOMMX	=	60	; zoom -xICOZOOMMY	=	61	; zoom -yICOTOURNE90	=	62	; tourne 90 degrsICOTOURNE180	=	63	; tourne 180 degrsICOTOURNE270	=	64	; tourne 270 degrsICOMIROIRH	=	65	; miroir horizontalICOMIROIRV	=	66	; miroir verticalICOFRAGMENT	=	67	; fragmenteICOTRANS	=	68	; transformeICOFRAGD	=	69	; fragmente droitesICOFRAGC	=	70	; fragmente courbesICOTRANSD	=	71	; transforme droiteICOTRANSC1	=	72	; transforme courbe 1ICOTRANSC2	=	73	; transforme courbe 2ICOTRANSPENTE	=	74	; transforme penteICOZOOMMQQ	=	75	; zoom quelconqueICORELXY	=	76	; relatif XYICORELX		=	77	; relatif XICORELY		=	78	; relatif YICORELDEL 	=	79	; relatif enlveICOFILE		=	80ICOEDIT		=	81ICOSHOW		=	82ICOSTOP		=	84ICORDGC		=	85ICOWRGC		=	86ICORDDF		=	87ICOWRDF		=	88ICORDIM		=	89ICODFIM		=	90ICOWRBM		=	91ICOCFIX		=	93	; chasse fixeICOEFFACE	=	94ICODEF		=	95ICOREGLEXY	=	96	; rgle: dplace