	.TITLE	BEZIER.ASC	.PROC	M680002	.REF	SMAKY	.LOC	0OBZP0:	.BLKB	4		; P0OBZP1:	.BLKB	4		; P1OBZP2:	.BLKB	4		; P2OBZP3:	.BLKB	4		; P3LBZ:	.LOC	0OBZ:	.BLKB	LBZOMODE:	.BLKB	2LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.L	A4,#(A6)+OBZ	LOAD.L	(A4)+OBZP0,#H'10000*100+100	LOAD.L	(A4)+OBZP1,#H'10000*300+600	LOAD.L	(A4)+OBZP2,#H'10000*600+700	LOAD.L	(A4)+OBZP3,#H'10000*800+100	LOAD.B	D3,#NOCURS	LIB	?AFCAR	LOAD.W	(A6)+OMODE,#INVDOT	CALL	BZDRAW20$:	LIB	?GETCAR	COMP.W	D3,#KEYMGP	JUMP,EQ 30$	COMP.W	D3,#END	JUMP,EQ 90$	COMP.W	D3,#SPACE	JUMP,EQ 50$25$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	20$30$:	LIB	?IFMOUSE	CALL	DETECT	JUMP,NE 25$32$:	LIB	?GETKEY	COMP.W	D3,#KEYMPO	JUMP,NE 20$	LIB	?IFMOUSE	CALL	BZDRAW	LOAD.L	(A3),D4	CALL	BZDRAW	JUMP	32$50$:	LOAD.W	(A6)+OMODE,#SETDOT	CALL	BZDRAW	LIB	?GETCAR	LOAD.B	D3,#EOP	LIB	?AFCAR	LOAD.W	(A6)+OMODE,#INVDOT	CALL	BZDRAW	JUMP	20$90$:	EXIT;--------\\; DETECT  >;========/; ; in	A4.L	^OBZPn;	D4.L	position de la souris; out	A3.L	^point;	D7.W; mod	D7.W, A3.LDETECT:	PUSHM.L	D1..D4	CLR.W	D7	LOAD.W	D3,D4		; D3 <-- X	SWAP.W	D4		; D4 <-- Y	LOAD.L	A3,A4	LOAD.W	D2,#420$:	LOAD.W	D1,(A3)+2	SUB.W	D1,#10	COMP.W	D3,D1	JUMP,LO 50$	ADD.W	D1,#10+10	COMP.W	D3,D1	JUMP,HS 50$	LOAD.W	D1,(A3)+0	SUB.W	D1,#10	COMP.W	D4,D1	JUMP,LO 50$	ADD.W	D1,#10+10	COMP.W	D4,D1	JUMP,LO 90$50$:	ADD.L	A3,#4	DEC.W	D2	JUMP,NE 20$	LOAD.W	D7,#190$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; BZDRAW  >;========/; ; in	A4.L	^OBZPn; out	; mod	BZDRAW:	PUSHM.L	D0..D6	LIB	?BUCAR	LOAD.L	D3,(A4)+OBZP0	CALL	BZSHOW	LOAD.L	D3,(A4)+OBZP1	CALL	BZSHOW	LOAD.L	D3,(A4)+OBZP2	CALL	BZSHOW	LOAD.L	D3,(A4)+OBZP3	CALL	BZSHOW	LOAD.W	D3,(A4)+OBZP0+2	SUB.W	D3,(A4)+OBZP1+2	JUMP',NC POS1$	NEG.W	D3POS1$:	LOAD.W	D2,D3	LOAD.W	D3,(A4)+OBZP0+0	SUB.W	D3,(A4)+OBZP1+0	JUMP',NC POS2$	NEG.W	D3POS2$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP1+2	SUB.W	D3,(A4)+OBZP2+2	JUMP',NC POS3$	NEG.W	D3POS3$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP1+0	SUB.W	D3,(A4)+OBZP2+0	JUMP',NC POS4$	NEG.W	D3POS4$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP2+2	SUB.W	D3,(A4)+OBZP3+2	JUMP',NC POS5$	NEG.W	D3POS5$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP2+0	SUB.W	D3,(A4)+OBZP3+0	JUMP',NC POS6$	NEG.W	D3POS6$:	ADD.W	D2,D3	LOAD.W	D1,#1	COMP.W	D2,#1280	JUMP',HS STEP$	LOAD.W	D1,#2	COMP.W	D2,#640	JUMP',HS STEP$	LOAD.W	D1,#4	COMP.W	D2,#320	JUMP',HS STEP$	LOAD.W	D1,#8	COMP.W	D2,#160	JUMP',HS STEP$	LOAD.W	D1,#16	COMP.W	D2,#80	JUMP',HS STEP$	LOAD.W	D1,#32	COMP.W	D2,#40	JUMP',HS STEP$	LOAD.W	D1,#64STEP$:	LOAD.W	D0,#6	COMP.W	D2,#640	JUMP',HS PROX$	LOAD.W	D0,#5	COMP.W	D2,#320	JUMP',HS PROX$	LOAD.W	D0,#4	COMP.W	D2,#160	JUMP',HS PROX$	LOAD.W	D0,#3	COMP.W	D2,#80	JUMP',HS PROX$	LOAD.W	D0,#2	COMP.W	D2,#40	JUMP',HS PROX$	LOAD.W	D0,#1PROX$:	CLR.W	D4	LOAD.L	D2,(A4)+OBZP0load.w d0,#0;;?load.w d1,#1LOOP$:	CALL	BZPOINT		; D3 <-- point;;?jump okline$	LOAD.W	D5,D4	ADD.W	D5,D1	COMP.W	D5,#256	JUMP,HI OKLINE$	LOAD.W	D5,D2	SUB.W	D5,D3	JUMP',NC PLUSX$	NEG.W	D5		; D5 <-- |dx|PLUSX$:	SWAP.W	D2	SWAP.W	D3	LOAD.W	D6,D2	SUB.W	D6,D3	JUMP',NC PLUSY$	NEG.W	D6		; D6 <-- |dy|PLUSY$:	SWAP.W	D2	SWAP.W	D3	COMP.W	D5,D0	JUMP,HS OKLINE$	COMP.W	D6,D0	JUMP,LO NOLINE$OKLINE$:	CALL	BZLINE	LOAD.L	D2,D3NOLINE$:	ADD.W	D4,D1	COMP.W	D4,#256	JUMP,LS LOOP$	LIB	?NOBUCAR	POPM.L	D0..D6	RET;--------\\; BZSHOW  >;========/; ; in	D3.L	; out	-; mod	D7.WBZSHOW:	PUSHM.L	D2..D4	LOAD.W	D2,(A6)+OMODE	SUB.W	D3,#2	LOAD.L	D4,#H'10000*0+5	LIB	?DRSEG	SUB.W	D3,#3	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LOAD.L	D4,#H'10000*5+0	LIB	?DRSEG	POPM.L	D2..D4	RET;--------\\; BZLINE  >;========/; ; in	D2.L	dpart  (y;x);	D3.L	arrive (y;x); out	-; mod	D7.WBZLINE:	PUSHM.L	D2..D4	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	LOAD.L	D4,D3;;?load.l d4,#H'10000*1+1	LOAD.L	D3,D2	LOAD.W	D2,(A6)+OMODE	LIB	?DRSEG	POPM.L	D2..D4	RET;--------\\; BZPOINT >;========/; ; in	A4.L	^OBZPn;	D4.W	position (0..256); out	D3.L	point (y;x); mod	D3.LBZPOINT:	PUSHM.L	D2,D4,A2,A3	LOAD.L	A3,#R16"TABLE$	LOAD.L	A2,A3	LOAD.W	D3,#256	SUB.W	D3,D4	SL.W	D4,#2	SL.W	D3,#2	ADD.W	A3,D4	ADD.W	A2,D3	LOAD.W	D4,(A4)+OBZP0+0	MUL.WA	D4,(A3)+0	LOAD.L	D3,D4	LOAD.W	D4,(A4)+OBZP1+0	MUL.WA	D4,(A3)+2	ADD.L	D3,D4	LOAD.W	D4,(A4)+OBZP2+0	MUL.WA	D4,(A2)+2	ADD.L	D3,D4	LOAD.W	D4,(A4)+OBZP3+0	MUL.WA	D4,(A2)+0	ADD.L	D3,D4	RL.L	D3,#1	COMP.W	D3,#H'8000	JUMP',LO 20$	ADD.L	D3,#H'1000020$:	LOAD.W	D4,(A4)+OBZP0+2	MUL.WA	D4,(A3)+0	LOAD.L	D2,D4	LOAD.W	D4,(A4)+OBZP1+2	MUL.WA	D4,(A3)+2	ADD.L	D2,D4	LOAD.W	D4,(A4)+OBZP2+2	MUL.WA	D4,(A2)+2	ADD.L	D2,D4	LOAD.W	D4,(A4)+OBZP3+2	MUL.WA	D4,(A2)+0	ADD.L	D2,D4	RL.L	D2,#1	COMP.W	D2,#H'8000	JUMP',LO 40$	ADD.L	D2,#H'1000040$:	SWAP.W	D2	LOAD.W	D3,D2	POPM.L	D2,D4,A2,A3	RETTABLE$:	.W	32767	0	.W	32384	380	.W	32005	756	.W	31628	1125	.W	31254	1488	.W	30884	1845	.W	30516	2197	.W	30151	2542	.W	29790	2882	.W	29431	3217	.W	29075	3545	.W	28722	3868	.W	28371	4186	.W	28024	4497	.W	27679	4803	.W	27338	5104	.W	26999	5399	.W	26663	5689	.W	26329	5973	.W	25999	6253	.W	25671	6526	.W	25346	6795	.W	25024	7058	.W	24704	7316	.W	24388	7568	.W	24074	7816	.W	23762	8058	.W	23454	8296	.W	23148	8528	.W	22845	8755	.W	22544	8977	.W	22246	9195	.W	21951	9407	.W	21658	9615	.W	21368	9818	.W	21081	10015	.W	20796	10209	.W	20513	10397	.W	20234	10581	.W	19957	10760	.W	19682	10934	.W	19410	11104	.W	19140	11269	.W	18873	11430	.W	18609	11586	.W	18346	11738	.W	18087	11885	.W	17830	12028	.W	17575	12167	.W	17323	12301	.W	17073	12432	.W	16825	12557	.W	16580	12679	.W	16338	12796	.W	16097	12910	.W	15860	13019	.W	15624	13124	.W	15391	13225	.W	15160	13322	.W	14931	13415	.W	14705	13505	.W	14481	13590	.W	14260	13672	.W	14040	13749	.W	13823	13823	.W	13608	13893	.W	13396	13960	.W	13185	14022	.W	12977	14081	.W	12771	14137	.W	12567	14189	.W	12366	14237	.W	12166	14282	.W	11969	14323	.W	11774	14361	.W	11581	14396	.W	11390	14427	.W	11201	14455	.W	11014	14480	.W	10830	14501	.W	10647	14519	.W	10467	14534	.W	10288	14546	.W	10112	14554	.W	9938	14560	.W	9765	14562	.W	9595	14562	.W	9427	14558	.W	9260	14552	.W	9096	14543	.W	8933	14531	.W	8773	14516	.W	8614	14498	.W	8458	14477	.W	8303	14454	.W	8150	14428	.W	7999	14399	.W	7850	14368	.W	7703	14334	.W	7558	14297	.W	7414	14258	.W	7272	14217	.W	7133	14173	.W	6995	14127	.W	6858	14078	.W	6724	14027	.W	6591	13974	.W	6460	13918	.W	6331	13860	.W	6203	13800	.W	6078	13738	.W	5954	13674	.W	5831	13607	.W	5711	13539	.W	5592	13468	.W	5474	13395	.W	5359	13321	.W	5245	13245	.W	5132	13166	.W	5022	13086	.W	4912	13004	.W	4805	12920	.W	4699	12835	.W	4594	12748	.W	4491	12659	.W	4390	12568	.W	4290	12476	.W	4192	12382	.W	4095	12287	.W	4000	12190	.W	3906	12092	.W	3814	11993	.W	3723	11892	.W	3634	11789	.W	3546	11685	.W	3459	11580	.W	3374	11474	.W	3291	11367	.W	3208	11258	.W	3128	11148	.W	3048	11037	.W	2970	10925	.W	2893	10812	.W	2818	10698	.W	2743	10583	.W	2671	10467	.W	2599	10350	.W	2529	10233	.W	2460	10114	.W	2392	9995	.W	2326	9875	.W	2260	9754	.W	2196	9632	.W	2134	9510	.W	2072	9387	.W	2012	9264	.W	1953	9140	.W	1895	9015	.W	1838	8890	.W	1782	8765	.W	1727	8639	.W	1674	8513	.W	1622	8387	.W	1570	8260	.W	1520	8133	.W	1471	8005	.W	1423	7878	.W	1376	7750	.W	1330	7622	.W	1286	7494	.W	1242	7366	.W	1199	7238	.W	1157	7110	.W	1116	6982	.W	1076	6855	.W	1037	6727	.W	999	6599	.W	962	6472	.W	926	6345	.W	891	6218	.W	857	6091	.W	823	5965	.W	791	5839	.W	759	5713	.W	728	5588	.W	699	5464	.W	669	5340	.W	641	5216	.W	614	5093	.W	587	4971	.W	561	4849	.W	536	4728	.W	511	4607	.W	488	4488	.W	465	4369	.W	443	4251	.W	421	4134	.W	401	4017	.W	381	3902	.W	361	3788	.W	342	3674	.W	324	3562	.W	307	3451	.W	290	3341	.W	274	3232	.W	259	3124	.W	244	3017	.W	229	2912	.W	215	2807	.W	202	2705	.W	190	2603	.W	177	2503	.W	166	2404	.W	155	2307	.W	144	2211	.W	134	2117	.W	125	2024	.W	115	1933	.W	107	1844	.W	98	1756	.W	91	1670	.W	83	1586	.W	76	1503	.W	70	1422	.W	64	1343	.W	58	1266	.W	52	1191	.W	47	1118	.W	42	1047	.W	38	978	.W	34	910	.W	30	845	.W	27	782	.W	23	722	.W	20	663	.W	18	607	.W	15	553	.W	13	501	.W	11	451	.W	9	404	.W	8	359	.W	6	317	.W	5	277	.W	4	240	.W	3	205	.W	2	173	.W	1	144	.W	1	117	.W	1	93	.W	0	71	.W	0	52	.W	0	36	.W	0	23	.W	0	13	.W	0	5	.W	0	1	.W	0	0;------\\; MUL32 >;======/; Module de multiplication 32*32 --> 64 bits (non-sign).;	-------------------;	 D1&D0 <-- D2 * D3;	-------------------; in	D2.L	multiplicande (32 bits non-sign);	D3.L	multiplicateur (32 bits non-sign); out	D1&D0.L	rsultat (64 bits non-sign); mod	D0.L, D1.LMUL32:	PUSHM.L D4,D5	LOAD.W	D0,D3	MUL.WU	D0,D2		; D0 low longword <-- low word * low word	SWAP.W	D2	LOAD.W	D5,D3		; D5 mid longword <-- high word * low word	MUL.WU	D5,D2	SWAP.W	D3	LOAD.W	D1,D3		; D1 high long <-- high word * high word	MUL.WU	D1,D2	SWAP.W	D2	LOAD.W	D4,D3		; D4 mid long <-- high word * low word	MUL.WU	D4,D2	SWAP.W	D3	SWAP.W	D1	ADD.L	D4,D5		; ADD.L D4,D5 avec report sur D1 si ncessessaire	CLR.W	D5	ADDX.W	D1,D5	SWAP.W	D1	ADDX.W	D1,D5	LOAD.W	D5,D1		; ADD.64 D1&D0,D4*(2^16)	SWAP.W	D5	SWAP.W	D0	LOAD.W	D5,D0	ADD.L	D5,D4	LOAD.W	D0,D5	SWAP.W	D0	SWAP.W	D5	LOAD.W	D1,D5	SWAP.W	D1	CLR.L	D5	ADDX.L	D1,D5	SWAP.W	D1	POPM.L	D4,D5	RET;------\\; DIV32 >;======/; Module de division 64/32 --> 32 bits (non-sign).;	-------------------;	 D3 <-- D1&D0 / D2;	 D4 <-- reste;	-------------------; ATTENTION: pas de test de division par zro !; in	D1&D0.L	numrateur (64 bits non-sign);	D2.L	dnominateur (32 bits non-sign); out	D3.L	rsultat (32 bits non-sign);	D4.L	reste (32 bits non-sign);	VS	overflow; mod	D3.L, D4.LDIV32:	PUSHM.L D0,D1	LOAD.W	D4,#32-1	; D4 <-- dcompteur de bouclesLOOP$:	SETX	RLX.L	D0	RLX.L	D1	JUMP',CS ERROR$	SUB.L	D1,D2	JUMP',HS NEXT$	ADD.L	D1,D2	TCLR.L	D0:#0		; bit 0 si rtablissementNEXT$:	DECJ.W,NMO D4,LOOP$	COMP.L	D1,D2		; reste >= diviseur ?	JUMP',HS ERROR$	LOAD.L	D3,D0		; D3 <-- quotient	LOAD.L	D4,D1		; D4 <-- reste,	 F <-- V=0	JUMP'	EXIT$ERROR$:	SETV			; F <-- V=1EXIT$:	POPM.L	D0,D1	RETVAR:	.FILLB	LGVAR,0	.END	START