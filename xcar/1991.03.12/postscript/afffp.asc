	.TITLE	AFFFP.ASC	.PROC	M680002	.REF	SMAKY; En-tte d'un gencar analytique; ------------------------------LBX		=	256		; lg de l'en-tte binaireNBCAR		=	128		; nb de caractresgcaIDENT	=	H'FFFF		; identificateur		.LOC	0ogcaIDENT:	.BLKB	2		; identificateur		.BLKB	2		; rserveogcaUNIT:	.BLKB	2		; rsolution		.BLKB	2		; rserveogcaXMIN:	.BLKB	2		; X minogcaYMIN:	.BLKB	2		; Y minogcaXMAX:	.BLKB	2		; X maxogcaYMAX:	.BLKB	2		; Y max		.LOC	192ogcaNAME:	.BLKB	32		; nom		.LOC	256ogcaLENGTH:	.BLKB	2*NBCAR		; chassesogcaXMINS:	.BLKB	2*NBCAR		; X minogcaYMINS:	.BLKB	2*NBCAR		; Y minogcaXMAXS:	.BLKB	2*NBCAR		; X maxogcaYMAXS:	.BLKB	2*NBCAR		; Y maxogcaPCHAR:	.BLKB	4*NBCAR		; ^s descriptions des caractresogcaDCHAR:				; descriptions des caractresOPEND		=	0		; terminateurOPBEGIN		=	1		; dbut <p1>OPLINE		=	2		; ligne <p1>OPCURVE		=	3		; courbe <p1> <p2> <p3>	.LOC	0ONMIN:	.BLKB	100OBUDIS:	.BLKB	100OPFILE:	.BLKB	4ODPOS:	.BLKB	4OLPOS:	.BLKB	4OWCAR:	.BLKB	2OCODE:	.BLKB	2OSCALE:	.BLKB	2OFREV:	.BLKB	2OPOINT:	.BLKB	1OSTEP:	.BLKB	1	.EVENOBZP0:	.BLKB	4		; P0OBZP1:	.BLKB	4		; P1OBZP2:	.BLKB	4		; P2OBZP3:	.BLKB	4		; P3LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LIB	?AFTIM	.B	MODGRA,GRACLIP	.B	NOCURS	.B	NOEFLI	.B	0	.EVEN	LOAD.L	A3,#R16"TXMENU	LIB	?AFMENU	LIB	?AFTIM	.ASCIZ	"<CR>Nom du fichier .GENC : "	.EVEN	LOAD.L	A3,#(A6)+ONMIN	LOAD.W	D3,#100	LIB	?GETLINE	COMP.W	D3,#CR	JUMP,NE FINI	CLR.L	D3	FOS	?CLOAD	JUMP,NE ERROR	LOAD.L	(A6)+OPFILE,A4REFAIT:	LOAD.W	(A6)+ODPOS+2,#50	LOAD.W	(A6)+ODPOS+0,#100	LOAD.W	(A6)+OSCALE,#1	LOAD.W	(A6)+OCODE,#'A	JUMP	40$20$:	TEST.B	(A6)+OSTEP	JUMP,F	22$	LIB	?BUZZ22$:	LIB	?AFTIM	.ASCIZ	"Caractre = "	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OCODE	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFSPACE	LOAD.B	D3,D4	LIB	?AFCODE	LIB	?AFTIM	.ASCIZ	"    Echelle = "	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OSCALE	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"<CR>Caractre : "	.EVEN	LIB	?GETCAR	COMP.W	D3,#F0	JUMP,EQ FINI	COMP.W	D3,#F1	JUMP,EQ 60$	COMP.W	D3,#F3	JUMP,EQ 62$	COMP.W	D3,#F4	JUMP,EQ 70$	COMP.W	D3,#F6	JUMP,EQ 72$	COMP.W	D3,#F7	JUMP,EQ 50$	COMP.W	D3,#F8	JUMP,EQ 52$	COMP.W	D3,#F9	JUMP,EQ 54$	COMP.W	D3,#F7+SHIFT	JUMP,EQ 56$	COMP.W	D3,#F9+SHIFT	JUMP,EQ 58$	COMP.W	D3,#F13	JUMP,EQ FRAPPE	AND.W	D3,#H'FF	LOAD.W	(A6)+OCODE,D340$:	LIB	?AFTIM	.B	EOP,0	.EVEN	LOAD.W	D3,(A6)+OCODE	CALL	DECODE	CALL	AFBBOXCAR	JUMP	20$50$:	LOAD.W	D4,(A6)+OSCALE	SL.W	D4,#1	LOAD.W	(A6)+OSCALE,D4	JUMP	40$52$:	LOAD.W	(A6)+OSCALE,#1	JUMP	40$54$:	LOAD.W	D4,(A6)+OSCALE	COMP.W	D4,#1	JUMP,EQ 40$	SR.W	D4,#1	LOAD.W	(A6)+OSCALE,D4	JUMP	40$56$:	LOAD.W	D4,(A6)+OSCALE	INC.W	D4	LOAD.W	(A6)+OSCALE,D4	JUMP	40$58$:	LOAD.W	D4,(A6)+OSCALE	COMP.W	D4,#1	JUMP,EQ 40$	DEC.W	D4	LOAD.W	(A6)+OSCALE,D4	JUMP	40$60$:	DEC.W	(A6)+OCODE	JUMP	40$62$:	INC.W	(A6)+OCODE	JUMP	40$70$:	NOT.B	(A6)+OPOINT	JUMP	40$72$:	NOT.B	(A6)+OSTEP	JUMP	40$FRAPPE:	LOAD.B	D3,#EOP	LIB	?AFCAR	LOAD.W	(A6)+ODPOS+2,#50	LOAD.W	(A6)+ODPOS+0,#100-50020$:	LIB	?GETCAR	COMP.W	D3,#F0	JUMP,EQ REFAIT	COMP.W	D3,#CR	JUMP,EQ 30$	CALL	AFCAR	JUMP	20$30$:	LOAD.W	(A6)+ODPOS+2,#50	LOAD.W	D4,#1000	CALL	SCALE	ADD.W	(A6)+ODPOS+0,D4	JUMP	20$ERROR:	LIB	?AFERRORFINI:	LOAD.L	A3,#(A6)+ONMIN	FOS	?CUNLOADRETOUR:	EXIT;--------\\; AFBBOX  >;========/; ; in	-; out	-; mod	D7.WAFBBOX:	PUSHM.L	D3,D4,A4	LOAD.L	A4,(A6)+OPFILE	LOAD.W	D3,(A4)+ogcaYMIN	SWAP.W	D3	LOAD.W	D3,(A4)+ogcaXMIN	LOAD.W	D4,(A4)+ogcaYMIN	SWAP.W	D4	LOAD.W	D4,(A4)+ogcaXMAX	CALL	LINE	LOAD.W	D3,(A4)+ogcaYMIN	SWAP.W	D3	LOAD.W	D3,(A4)+ogcaXMAX	LOAD.W	D4,(A4)+ogcaYMAX	SWAP.W	D4	LOAD.W	D4,(A4)+ogcaXMAX	CALL	LINE	LOAD.W	D3,(A4)+ogcaYMAX	SWAP.W	D3	LOAD.W	D3,(A4)+ogcaXMAX	LOAD.W	D4,(A4)+ogcaYMAX	SWAP.W	D4	LOAD.W	D4,(A4)+ogcaXMIN	CALL	LINE	LOAD.W	D3,(A4)+ogcaYMAX	SWAP.W	D3	LOAD.W	D3,(A4)+ogcaXMIN	LOAD.W	D4,(A4)+ogcaYMIN	SWAP.W	D4	LOAD.W	D4,(A4)+ogcaXMIN	CALL	LINE	POPM.L	D3,D4,A4	RET;----------\\; AFBBOXCAR >;==========/; ; in	D3.W	code du caractre; out	-; mod	D7.WAFBBOXCAR:	PUSHM.L	D3,D4,A0..A4	LOAD.L	A0,(A6)+OPFILE	SL.W	D3,#1	LOAD.L	A1,#(A0)+ogcaXMINS	ADD.W	A1,D3	LOAD.L	A2,#(A0)+ogcaYMINS	ADD.W	A2,D3	LOAD.L	A3,#(A0)+ogcaXMAXS	ADD.W	A3,D3	LOAD.L	A4,#(A0)+ogcaYMAXS	ADD.W	A4,D3	LOAD.W	D3,(A2)	SWAP.W	D3	LOAD.W	D3,(A1)	LOAD.W	D4,(A2)	SWAP.W	D4	LOAD.W	D4,(A3)	CALL	LINE	LOAD.W	D3,(A2)	SWAP.W	D3	LOAD.W	D3,(A3)	LOAD.W	D4,(A4)	SWAP.W	D4	LOAD.W	D4,(A3)	CALL	LINE	LOAD.W	D3,(A4)	SWAP.W	D3	LOAD.W	D3,(A3)	LOAD.W	D4,(A4)	SWAP.W	D4	LOAD.W	D4,(A1)	CALL	LINE	LOAD.W	D3,(A4)	SWAP.W	D3	LOAD.W	D3,(A1)	LOAD.W	D4,(A2)	SWAP.W	D4	LOAD.W	D4,(A1)	CALL	LINE	POPM.L	D3,D4,A0..A4	RET;--------\\; AFCAR   >;========/; ; in	D3.B	caractre  afficher; out	-; mod	D7.WAFCAR:	PUSHM.L	D3	AND.W	D3,#H'FF	LOAD.W	(A6)+OCODE,D3	CALL	DECODE	LOAD.W	D3,(A6)+OWCAR	ADD.W	(A6)+ODPOS+2,D390$:	POPM.L	D3	RET;--------\\; DECODE  >;========/; ; in	D3.W	code du caractre; out	-; mod	D7.WDECODE:	PUSHM.L	D3..D6,A3,A4	LOAD.L	A3,(A6)+OPFILE	LOAD.W	D4,D3	SL.W	D4,#1	LOAD.L	A4,#(A3)+ogcaLENGTH	LOAD.W	D4,(A4)+(D4.W)	CALL	SCALE	LOAD.W	(A6)+OWCAR,D4	LOAD.W	D4,D3	SL.W	D4,#2	LOAD.L	A4,#(A3)+ogcaPCHAR	LOAD.L	D4,(A4)+(D4.W)	LOAD.L	A4,#(A3)+(D4.L)	; A4 <-- ^description du caractreLOOP$:	LOAD.W	D3,(A4+)	COMP.W	D3,#OPBEGIN	JUMP,EQ BEGIN$	COMP.W	D3,#OPLINE	JUMP,EQ LINE$	COMP.W	D3,#OPCURVE	JUMP,EQ CURVE$	JUMP	END$BEGIN$:	LOAD.L	(A6)+OLPOS,(A4+)	JUMP	LOOP$LINE$:	LOAD.L	D3,(A6)+OLPOS	LOAD.L	D4,(A4+)	CALL	LINE	LOAD.L	(A6)+OLPOS,D4	JUMP	LOOP$CURVE$:	LOAD.L	D3,(A6)+OLPOS	LOAD.L	D4,(A4+)	LOAD.L	D5,(A4+)	LOAD.L	D6,(A4+)	CALL	CURVE	LOAD.L	(A6)+OLPOS,D6	JUMP	LOOP$END$:EXIT$:	POPM.L	D3..D6,A3,A4	RET;--------\\; LINE    >;========/; ; in	; out	; mod	LINE:	PUSHM.L	D2..D4	CALL	CONVD3	EX.L	D3,D4	CALL	CONVD3	EX.L	D3,D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2..D4	RET;--------\\; CURVE   >;========/; ; in	; out	; mod	CURVE:	PUSHM.L	D3..D6,A4	CALL	CONVD3	EX.L	D3,D4	CALL	CONVD3	EX.L	D3,D4	EX.L	D3,D5	CALL	CONVD3	EX.L	D3,D5	EX.L	D3,D6	CALL	CONVD3	EX.L	D3,D6	LOAD.L	A4,A6	LOAD.L	(A4)+OBZP0,D3	LOAD.L	(A4)+OBZP1,D4	LOAD.L	(A4)+OBZP2,D5	LOAD.L	(A4)+OBZP3,D6	CALL	BZDRAW	POPM.L	D3..D6,A4	RET;--------\\; CONVD3  >;========/; ; in	; out	; mod	CONVD3:	EX.L	D3,D4	CALL	SCALE	EX.L	D4,D3	ADD.W	D3,(A6)+ODPOS+2	SWAP.W	D3	ADD.W	D3,#700	ADD.W	D3,(A6)+ODPOS+0	SWAP.W	D3	RET;--------\\; SCALE   >;========/; ; in	D4.L	valeur; out	D4.L	valeur; mod	SCALE:	PUSHM.L	D1..D3	LOAD.W	D2,(A6)+OSCALE	COMP.W	D2,#1	JUMP,EQ 90$	LOAD.W	D3,D4	JUMP,NS 20$	CALL	DIVD3D2	JUMP	30$20$:	NEG.W	D3	CALL	DIVD3D2	NEG.W	D330$:	LOAD.W	D4,D3	SWAP.W	D4	LOAD.W	D3,D4	JUMP,NS 40$	CALL	DIVD3D2	JUMP	50$40$:	NEG.W	D3	CALL	DIVD3D2	NEG.W	D350$:	LOAD.W	D4,D3	SWAP.W	D490$:	POPM.L	D1..D3	RET;--------\\; DIVD3D2 >;========/; ; in	D3.W	munrateur;	D2.W	dnominateur; out	D3.W	= D3/D2; mod	D3.LDIVD3D2:	PUSHM.L	D1,D2	AND.L	D3,#H'FFFF	DIV.WU	D3,D2	SR.W	D2,#1	LOAD.L	D1,D3	SWAP.W	D1	COMP.W	D1,D2	JUMP,LO 90$	INC.W	D390$:	POPM.L	D1,D2	RET;----------\\; DRAWPOINT >;==========/; ; in	D4.L	point (y;x); out	; mod	DRAWPOINT:	PUSHM.L	D2..D4	TEST.B	(A6)+OPOINT	JUMP,F	90$	LOAD.L	D3,D4	LOAD.W	D4,#4	LOAD.W	D2,#SETDOT	LIB	?DRCERCLE90$:	POPM.L	D2..D4	RET;-----------\\; DRAWPOINTC >;===========/; ; in	D4.L	point (y;x); out	; mod	DRAWPOINTC:	PUSHM.L	D2..D4	TEST.B	(A6)+OPOINT	JUMP,F	90$	LOAD.L	D3,D4	LOAD.W	D2,#SETDOT	SUB.W	D3,#2	LOAD.L	D4,#H'10000*0+5	LIB	?DRSEG	SUB.W	D3,#3	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LOAD.L	D4,#H'10000*5+0	LIB	?DRSEG90$:	POPM.L	D2..D4	RET;--------\\; BZDRAW  >;========/; ; in	A4.L	^OBZPn; out	; mod	BZDRAW:	PUSHM.L	D0..D6	LIB	?BUCAR	LOAD.L	D2,(A4)+OBZP0	LOAD.L	D3,(A4)+OBZP1;;?	CALL	BZLINE	LOAD.L	D2,(A4)+OBZP1	LOAD.L	D3,(A4)+OBZP2;;?	CALL	BZLINE	LOAD.L	D2,(A4)+OBZP2	LOAD.L	D3,(A4)+OBZP3;;?	CALL	BZLINE	LOAD.W	D3,(A4)+OBZP0+2	SUB.W	D3,(A4)+OBZP1+2	JUMP',NC POS1$	NEG.W	D3POS1$:	LOAD.W	D2,D3	LOAD.W	D3,(A4)+OBZP0+0	SUB.W	D3,(A4)+OBZP1+0	JUMP',NC POS2$	NEG.W	D3POS2$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP1+2	SUB.W	D3,(A4)+OBZP2+2	JUMP',NC POS3$	NEG.W	D3POS3$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP1+0	SUB.W	D3,(A4)+OBZP2+0	JUMP',NC POS4$	NEG.W	D3POS4$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP2+2	SUB.W	D3,(A4)+OBZP3+2	JUMP',NC POS5$	NEG.W	D3POS5$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP2+0	SUB.W	D3,(A4)+OBZP3+0	JUMP',NC POS6$	NEG.W	D3POS6$:	ADD.W	D2,D3	LOAD.W	D1,#1	COMP.W	D2,#160	JUMP',HS STEP$	LOAD.W	D1,#2	COMP.W	D2,#80	JUMP',HS STEP$	LOAD.W	D1,#4	COMP.W	D2,#40	JUMP',HS STEP$	LOAD.W	D1,#8	COMP.W	D2,#20	JUMP',HS STEP$	LOAD.W	D1,#16	COMP.W	D2,#10	JUMP',HS STEP$	LOAD.W	D1,#32	COMP.W	D2,#5	JUMP',HS STEP$	LOAD.W	D1,#64STEP$:	LOAD.W	D0,#6	COMP.W	D2,#640	JUMP',HS PROX$	LOAD.W	D0,#5	COMP.W	D2,#320	JUMP',HS PROX$	LOAD.W	D0,#4	COMP.W	D2,#160	JUMP',HS PROX$	LOAD.W	D0,#3	COMP.W	D2,#80	JUMP',HS PROX$	LOAD.W	D0,#2	COMP.W	D2,#40	JUMP',HS PROX$	LOAD.W	D0,#1PROX$:	CLR.W	D4	LOAD.L	D2,(A4)+OBZP0LOOP$:	CALL	BZPOINT		; D3 <-- point;;?jump okline$	LOAD.W	D5,D4	ADD.W	D5,D1	COMP.W	D5,#256	JUMP,HI OKLINE$	LOAD.W	D5,D2	SUB.W	D5,D3	JUMP',NC PLUSX$	NEG.W	D5		; D5 <-- |dx|PLUSX$:	SWAP.W	D2	SWAP.W	D3	LOAD.W	D6,D2	SUB.W	D6,D3	JUMP',NC PLUSY$	NEG.W	D6		; D6 <-- |dy|PLUSY$:	SWAP.W	D2	SWAP.W	D3	COMP.W	D5,D0	JUMP,HS OKLINE$	COMP.W	D6,D0	JUMP,LO NOLINE$OKLINE$:	CALL	BZLINE	LOAD.L	D2,D3NOLINE$:	ADD.W	D4,D1	COMP.W	D4,#256	JUMP,LS LOOP$	LIB	?NOBUCAR	POPM.L	D0..D6	RET;--------\\; BZLINE  >;========/; ; in	D2.L	dpart  (y;x);	D3.L	arrive (y;x); out	-; mod	D7.WBZLINE:	PUSHM.L	D2..D4	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	LOAD.L	D4,D3;;?load.l d4,#H'10000*1+1	LOAD.L	D3,D2	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2..D4	RET;--------\\; BZPOINT >;========/; ; in	A4.L	^OBZPn;	D4.W	position (0..256); out	D3.L	point (y;x); mod	D3.LBZPOINT:	PUSHM.L	D2,D4,A2,A3	LOAD.L	A3,#R16"TABLE$	LOAD.L	A2,A3	LOAD.W	D3,#256	SUB.W	D3,D4	SL.W	D4,#2	SL.W	D3,#2	ADD.W	A3,D4	ADD.W	A2,D3	LOAD.W	D4,(A4)+OBZP0+0	MUL.WA	D4,(A3)+0	LOAD.L	D3,D4	LOAD.W	D4,(A4)+OBZP1+0	MUL.WA	D4,(A3)+2	ADD.L	D3,D4	LOAD.W	D4,(A4)+OBZP2+0	MUL.WA	D4,(A2)+2	ADD.L	D3,D4	LOAD.W	D4,(A4)+OBZP3+0	MUL.WA	D4,(A2)+0	ADD.L	D3,D4	RL.L	D3,#1	COMP.W	D3,#H'8000	JUMP',LO 20$	ADD.L	D3,#H'1000020$:	LOAD.W	D4,(A4)+OBZP0+2	MUL.WA	D4,(A3)+0	LOAD.L	D2,D4	LOAD.W	D4,(A4)+OBZP1+2	MUL.WA	D4,(A3)+2	ADD.L	D2,D4	LOAD.W	D4,(A4)+OBZP2+2	MUL.WA	D4,(A2)+2	ADD.L	D2,D4	LOAD.W	D4,(A4)+OBZP3+2	MUL.WA	D4,(A2)+0	ADD.L	D2,D4	RL.L	D2,#1	COMP.W	D2,#H'8000	JUMP',LO 40$	ADD.L	D2,#H'1000040$:	SWAP.W	D2	LOAD.W	D3,D2	POPM.L	D2,D4,A2,A3	RETTABLE$:	.W	32767	0	.W	32385	381	.W	32005	756	.W	31628	1125	.W	31255	1488	.W	30884	1846	.W	30517	2197	.W	30152	2543	.W	29790	2883	.W	29431	3217	.W	29075	3546	.W	28722	3869	.W	28372	4186	.W	28024	4498	.W	27680	4804	.W	27338	5105	.W	26999	5400	.W	26663	5690	.W	26330	5974	.W	25999	6253	.W	25672	6527	.W	25347	6795	.W	25024	7058	.W	24705	7316	.W	24388	7569	.W	24074	7816	.W	23763	8059	.W	23454	8296	.W	23148	8528	.W	22845	8756	.W	22545	8978	.W	22247	9195	.W	21951	9408	.W	21659	9615	.W	21369	9818	.W	21081	10016	.W	20796	10209	.W	20514	10397	.W	20234	10581	.W	19957	10760	.W	19682	10935	.W	19410	11104	.W	19141	11270	.W	18874	11431	.W	18609	11587	.W	18347	11739	.W	18087	11886	.W	17830	12029	.W	17575	12168	.W	17323	12302	.W	17073	12432	.W	16826	12558	.W	16581	12679	.W	16338	12797	.W	16098	12910	.W	15860	13019	.W	15625	1