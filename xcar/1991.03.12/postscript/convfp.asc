	.TITLE	CONVFP.ASC	.PROC	M680002	.REF	SMAKY	.REF	XCARASSMILE	=	0DEBUG	=	0LBX	=	256		; lg en-tte binaire; Variables; ---------LNM	=	100		; lg max d'un nom de fichier	.LOC	0ONMIN:	.BLKB	LNM		; nom du fichier .PS en entreONMOUT:	.BLKB	LNM		; nom du fichier .GENC en sortieOPFIN:	.BLKB	4		; ^fichier en entreOPFOUT:	.BLKB	4		; ^fichier en sortieOPPOUT:	.BLKB	4		; ^points dans fichier en sortieOPPOUF:	.BLKB	4		; ^fill dans fichier en sortieOPLICO:	.BLKB	4		; ^ligne de commandeOBUPAR:	.BLKB	100OPPOS:	.BLKB	4		; premire position (y;x)OLPOS:	.BLKB	4		; dernire position (y;x)ORPOS:	.BLKB	4		; position relative de l'origine (y;x)OWCAR:	.BLKB	2		; largeur d'un caractreOFREV:	.BLKB	2		; rvision du fichier en entreLGVAR:; Programme; ---------	.LOC	0START:	.IF	~ASSMILE	LIB	?OPELIB	.ENDIF	LOAD.L	A6,#R16"VAR	.IF	~ASSMILE	LOAD.L	(A6)+OPLICO,A3	.ENDIF	LIB	?AFTIM	.B	MODGRA,GRACLIP	.B	NOEFLI	.B	0	.EVEN	LOAD.L	A3,#R16"TXMENU	LIB	?AFMENU	LIB	?AFTIM	.B	EOP,CR	.ASCII	"    ---------------------------------------------------------<CR>"	.ASCII	"	Conversion d'un gnrateur de caractres PostScript<CR>"	.ASCII	"	cr avec Fontographer (FS.ps) en un gnrateur<CR>"	.ASCII	"	analytique pour le SMAKY (sma_FSp00.genc).<CR>"	.ASCII	"    ---------------------------------------------------------<CR>"	.B	CR,0	.EVEN	.IF	~ASSMILE	LOAD.L	A3,(A6)+OPLICO	LIB	?SKPNAM	JUMP,NE EDIT$	LOAD.B	(A6)+ONMIN+0,(A3+)	LOAD.B	(A6)+ONMIN+1,(A3+)	JUMP	NAME$	.ENDIFEDIT$:	LIB	?AFTIM	.ASCIZ	"<CR>Nom de la fonte (FS) : "	.EVEN	LOAD.L	A3,#(A6)+ONMIN	LOAD.W	D3,#LNM	LIB	?GETLINE	COMP.W	D3,#CR	JUMP,NE FININAME$:	LOAD.B	(A6)+ONMIN+2,#'.	LOAD.B	(A6)+ONMIN+3,#'P	LOAD.B	(A6)+ONMIN+4,#'S	CLR.B	(A6)+ONMIN+5	LOAD.B	(A6)+ONMOUT+0,#'S	LOAD.B	(A6)+ONMOUT+1,#'M	LOAD.B	(A6)+ONMOUT+2,#'A	LOAD.B	(A6)+ONMOUT+3,#'_	LOAD.B	(A6)+ONMOUT+4,(A6)+ONMIN+0	LOAD.B	(A6)+ONMOUT+5,(A6)+ONMIN+1	LOAD.B	(A6)+ONMOUT+6,#'P	LOAD.B	(A6)+ONMOUT+7,#'0	LOAD.B	(A6)+ONMOUT+8,#'0	LOAD.B	(A6)+ONMOUT+9,#'.	LOAD.B	(A6)+ONMOUT+10,#'G	LOAD.B	(A6)+ONMOUT+11,#'E	LOAD.B	(A6)+ONMOUT+12,#'N	LOAD.B	(A6)+ONMOUT+13,#'C	CLR.B	(A6)+ONMOUT+14	LOAD.L	A3,#(A6)+ONMIN	CALL	RDFILE		; lit le fichier .PS	JUMP,NE ERROR	LOAD.L	(A6)+OPFIN,A4	LOAD.L	D4,#100000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE ERROR	GESMEM	?CLEARMEM	LOAD.L	(A6)+OPFOUT,A4	CALL	DECODEALL	; dcode tous les caractres	LOAD.L	A3,#(A6)+ONMOUT	LOAD.L	A4,(A6)+OPFOUT	LOAD.L	D4,(A6)+OPPOUT	SUB.L	D4,A4	CALL	WRFILE		; crit le fichier .GENC	JUMP,NE ERROR	JUMP	FINIERROR:	LIB	?AFERRORFINI:	TEST.L	(A6)+OPFIN	JUMP,EQ 20$	LOAD.L	A4,(A6)+OPFIN	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPFIN20$:	TEST.L	(A6)+OPFOUT	JUMP,EQ 30$	LOAD.L	A4,(A6)+OPFOUT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPFOUT30$:RETOUR:	.IF	ASSMILE	EXIT	.ELSE	LIB	?CLOLIB	FOS	?STOP	.ENDIF;----------\\; DECODEALL >;==========/; Dcode tous les caractres.; in	-; out	-; mod	D7.WDECODEALL:	PUSHM.L	D1..D5,A1..A4	CALL	DECODEINIT	LOAD.L	A1,(A6)+OPFOUT	ADD.L	A1,#LBX	LOAD.L	A2,#(A1)+oxcPCHAR	LOAD.L	A3,#(A1)+oxcLENGTH	LOAD.L	A4,#(A1)+oxcDCHAR	LOAD.L	(A6)+OPPOUT,A4	LIB	?AFTIM	.ASCIZ	"<CR>Caractres: "	.EVEN	LOAD.L	A4,#R16"TACAR	CLR.W	D420$:	LOAD.B	D3,D4	LIB	?AFCODE	LOAD.W	D3,(A4+)	COMP.W	D3,#-1		; fin de la table ?	JUMP,EQ 40$	LOAD.L	D2,(A6)+OPPOUT	SUB.L	D2,A1	LOAD.L	(A2+),D2	; oxcPCHAR <-- ^description du caractre	CALL	DECODEONE	; dcode un caractre	LOAD.W	(A3+),(A6)+OWCAR ; oxcLENGTH <-- largeur du caractre	INC.W	D4	JUMP	20$40$:	LOAD.L	A4,(A6)+OPFOUT	LOAD.B	(A4)+OBXTYP,#2^BBXREL	LOAD.L	D4,(A6)+OPPOUT	SUB.L	D4,(A6)+OPFOUT	SUB.L	D4,#LBX	LOAD.L	(A4)+OBXLG,D4	LOAD.W	(A1)+oxcIDENT,#xcIDENT	LOAD.L	A4,(A6)+OPFIN	LOAD.L	A3,#R16"CH1$	CALL	SEARCH		; cherche ".00"	JUMP,NE 50$	CALL	GETANUM	TEST.W	D4	JUMP,EQ 50$	LOAD.L	D3,#1000000	DIV.WU	D3,D4	LOAD.W	(A1)+oxcUNIT,D3 ; oxcUNIT <-- unit de rsolution50$:	LOAD.L	A4,(A6)+OPFIN	LOAD.L	A3,#R16"CH3$	CALL	SEARCH		; cherche "font: "	JUMP,NE 80$	LOAD.L	A3,#(A1)+oxcNAME72$:	LOAD.B	D3,(A4+)	COMP.B	D3,#CR	JUMP,EQ 80$	LOAD.B	(A3+),D3	; oxcNAME <-- nom de la police	JUMP	72$80$:	LIB	?AFCR	LIB	?AFCR	POPM.L	D1..D5,A1..A4	RETCH1$:	.ASCIZ	".00"CH3$:	.ASCIZ	"font: "	.EVENTACAR:	.W	H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'A4,H'A6,H'00,H'9F	.W	H'88,H'89,H'8E,H'8F,H'91,H'90,H'95,H'94,H'99,H'9D,H'9E,H'8A,H'9A,H'8D,H'C7,H'C8	.W	H'20,H'21,H'22,H'23,H'24,H'25,H'26,H'27,H'28,H'29,H'2A,H'2B,H'2C,H'2D,H'2E,H'2F	.W	H'30,H'31,H'32,H'33,H'34,H'35,H'36,H'37,H'38,H'39,H'3A,H'3B,H'3C,H'3D,H'3E,H'3F	.W	H'40,H'41,H'42,H'43,H'44,H'45,H'46,H'47,H'48,H'49,H'4A,H'4B,H'4C,H'4D,H'4E,H'4F	.W	H'50,H'51,H'52,H'53,H'54,H'55,H'56,H'57,H'58,H'59,H'5A,H'5B,H'5C,H'5D,H'5E,H'5F	.W	H'60,H'61,H'62,H'63,H'64,H'65,H'66,H'67,H'68,H'69,H'6A,H'6B,H'6C,H'6D,H'6E,H'6F	.W	H'70,H'71,H'72,H'73,H'74,H'75,H'76,H'77,H'78,H'79,H'7A,H'7B,H'7C,H'7D,H'7E,H'7F	.W	H'00,H'E7,H'CB,H'E5,H'80,H'CC,H'81,H'82,H'83,H'E9,H'E6,H'E8,H'EA,H'ED,H'EB,H'EC	.W	H'00,H'84,H'EE,H'F1,H'EF,H'85,H'CD,H'AF,H'F2,H'F4,H'F3,H'86,H'D9,H'AE,H'CE,H'A7	.W	H'00,H'87,H'00,H'00,H'00,H'8B,H'8C,H'00,H'00,H'00,H'00,H'00,H'92,H'93,H'00,H'00	.W	H'F5,H'96,H'97,H'98,H'00,H'00,H'9B,H'BF,H'9C,H'00,H'00,H'00,H'D8,H'BE,H'CF,H'00	.W	H'C0,H'C1,H'C9,H'D2,H'D3,H'D4,H'D5,H'E4,H'BA,H'C4,H'A5,H'E1,H'D7,H'C3,H'D0,H'D1	.W	H'2A,H'AB,H'60,H'F6,H'AC,H'F7,H'FB,H'FC,H'FE,H'F8,H'F9,H'FA,H'00,H'A8,H'A9,H'AA	.W	H'B1,H'B2,H'B3,H'AD,H'D6,H'A1,H'30,H'31,H'32,H'33,H'34,H'35,H'36,H'37,H'38,H'39	.W	H'A2,H'A3,H'B4,H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00	.W	-1;-----------\\; DECODEINIT >;===========/; Cherche le numro de rvision du logiciel "Fontographer" qui; a gnr le fichier .PS; in	-; out	-; mod	D7.WDECODEINIT:	PUSHM.L	D2..D4,A3,A4	LIB	?AFTIM	.ASCIZ	"<CR>Rvision: "	.EVEN	CLR.W	(A6)+OFREV	LOAD.L	A4,(A6)+OPFIN	LOAD.L	A3,#R16"CH2$	CALL	SEARCH		; cherche "Metamorphosis "	JUMP,EQ META$	LOAD.L	A4,(A6)+OPFIN	LOAD.L	A3,#R16"CH1$	CALL	SEARCH		; cherche "Fontographer "	JUMP,EQ FONT$	JUMP	EXIT$FONT$:	LIB	?AFTEXT	CALL	GETANUM	LOAD.W	(A6)+OFREV,D4	JUMP	EXIT$META$:	LIB	?AFTEXT	CALL	GETANUM	ADD.W	D4,#100	LOAD.W	(A6)+OFREV,D4	JUMP	EXIT$EXIT$:	CLR.L	D4	LOAD.W	D4,(A6)+OFREV	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	POPM.L	D2..D4,A3,A4	RETCH1$:	.ASCIZ	"Fontographer "CH2$:	.ASCIZ	"Metamorphosis "	.EVEN;----------\\; DECODEONE >;==========/; Dcode un caractre.; in	D3.W	code du caractre; out	-; mod	D7.WDECODEONE:	PUSHM.L	D1..D4,A2..A4	LOAD.L	A2,#(A6)+OBUPAR	CLR.L	(A6)+ORPOS	LOAD.L	A3,(A6)+OPPOUT	LOAD.L	(A6)+OPPOUF,A3	LOAD.B	(A3+),#xcOPFILLI	CLR.B	(A3+)	LOAD.L	(A6)+OPPOUT,A3	LOAD.L	A3,#R16"TACODE$20$:	TEST.B	(A3)		; fin de la table ?	JUMP,EQ 90$		; oui => 90$	DEC.W	D3	JUMP',NS 24$22$:	TEST.B	(A3+)		; A3 <-- ^nom de caractre suivant	JUMP,NE 22$	JUMP	20$24$:	LOAD.L	A4,(A6)+OPFIN30$:	CALL	SEARCH		; cherche le nom du caractre (ex. "/A")	JUMP,NE 90$32$:	COMP.B	(A4+),#SPACE	; "/A {<1234.."	JUMP,EQ 32$	DEC.L	A4	COMP.B	(A4),#'{	JUMP',NE 36$	INC.L	A436$:	COMP.B	(A4),#'<	JUMP,NE 30$	INC.L	A4	CLR.L	(A6)+OLPOS	TCLR.L	D1:#1640$:	COMP.B	(A4+),#CR	JUMP,EQ 40$	DEC.L	A4	CALL	GETHNUM	JUMP,NE 90$	COMP.W	D4,#200	JUMP,LO 60$	COMP.W	D4,#233	JUMP,LO 50$				; 233..255 =>	CALL	PUTNUM	SUB.W	D4,#233	CALL	PUTOP	LOAD.L	A2,#(A6)+OBUPAR	JUMP	40$50$:				; 200..232 =>	SUB.W	D4,#216	MUL.WA	D4,#100	ADD.W	D1,D4	TSET.L	D1:#16	JUMP	40$60$:				; 000..199 =>	CALL	PUTNUM	SUB.W	D4,#100	LOAD.W	D1,D4	TSET.L	D1:#16	JUMP	40$90$:	LOAD.L	A3,(A6)+OPPOUT	LOAD.B	(A3+),#xcOPEND	CLR.B	(A3+)	LOAD.L	(A6)+OPPOUT,A3	POPM.L	D1..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETTACODE$:	.ASCIZ	"/"			; 00	.ASCIZ	"/"			; 01	.ASCIZ	"/"			; 02	.ASCIZ	"/"			; 03	.ASCIZ	"/"			; 04	.ASCIZ	"/"			; 05	.ASCIZ	"/"			; 06	.ASCIZ	"/"			; 07	.ASCIZ	"/"			; 08	.ASCIZ	"/"			; 09	.ASCIZ	"/"			; 0A	.ASCIZ	"/"			; 0B	.ASCIZ	"/"			; 0C	.ASCIZ	"/"			; 0D	.ASCIZ	"/"			; 0E	.ASCIZ	"/"			; 0F	.ASCIZ	"/"			; 10	.ASCIZ	"/"			; 11	.ASCIZ	"/"			; 12	.ASCIZ	"/"			; 13	.ASCIZ	"/"			; 14	.ASCIZ	"/"			; 15	.ASCIZ	"/"			; 16	.ASCIZ	"/"			; 17	.ASCIZ	"/"			; 18	.ASCIZ	"/"			; 19	.ASCIZ	"/"			; 1A	.ASCIZ	"/"			; 1B	.ASCIZ	"/"			; 1C	.ASCIZ	"/"			; 1D	.ASCIZ	"/"			; 1E	.ASCIZ	"/"			; 1F	.ASCIZ	"/space"		; 20	.ASCIZ	"/exclam"		; 21	.ASCIZ	"/quotedbl"		; 22	.ASCIZ	"/numbersign"		; 23	.ASCIZ	"/dollar"		; 24	.ASCIZ	"/percent"		; 25	.ASCIZ	"/ampersand"		; 26	.ASCIZ	"/quotesingle"		; 27	.ASCIZ	"/parenleft"		; 28	.ASCIZ	"/parenright"		; 29	.ASCIZ	"/asterisk"		; 2A	.ASCIZ	"/plus"			; 2B	.ASCIZ	"/comma"		; 2C	.ASCIZ	"/hyphen"		; 2D	.ASCIZ	"/period"		; 2E	.ASCIZ	"/slash"		; 2F	.ASCIZ	"/zero"			; 30	.ASCIZ	"/one"			; 31	.ASCIZ	"/two"			; 32	.ASCIZ	"/three"		; 33	.ASCIZ	"/four"			; 34	.ASCIZ	"/five"			; 35	.ASCIZ	"/six"			; 36	.ASCIZ	"/seven"		; 37	.ASCIZ	"/eight"		; 38	.ASCIZ	"/nine"			; 39	.ASCIZ	"/colon"		; 3A	.ASCIZ	"/semicolon"		; 3B	.ASCIZ	"/less"			; 3C	.ASCIZ	"/equal"		; 3D	.ASCIZ	"/greater"		; 3E	.ASCIZ	"/question"		; 3F	.ASCIZ	"/at"			; 40	.ASCIZ	"/A"			; 41	.ASCIZ	"/B"			; 42	.ASCIZ	"/C"			; 43	.ASCIZ	"/D"			; 44	.ASCIZ	"/E"			; 45	.ASCIZ	"/F"			; 46	.ASCIZ	"/G"			; 47	.ASCIZ	"/H"			; 48	.ASCIZ	"/I"			; 49	.ASCIZ	"/J"			; 4A	.ASCIZ	"/K"			; 4B	.ASCIZ	"/L"			; 4C	.ASCIZ	"/M"			; 4D	.ASCIZ	"/N"			; 4E	.ASCIZ	"/O"			; 4F	.ASCIZ	"/P"			; 50	.ASCIZ	"/Q"			; 51	.ASCIZ	"/R"			; 52	.ASCIZ	"/S"			; 53	.ASCIZ	"/T"			; 54	.ASCIZ	"/U"			; 55	.ASCIZ	"/V"			; 56	.ASCIZ	"/W"			; 57	.ASCIZ	"/X"			; 58	.ASCIZ	"/Y"			; 59	.ASCIZ	"/Z"			; 5A	.ASCIZ	"/bracketleft"		; 5B	.ASCIZ	"/backslash"		; 5C	.ASCIZ	"/bracketright"		; 5D	.ASCIZ	"/asciicircum"		; 5E	.ASCIZ	"/underscore"		; 5F	.ASCIZ	"/grave"		; 60	.ASCIZ	"/a"			; 61	.ASCIZ	"/b"			; 62	.ASCIZ	"/c"			; 63	.ASCIZ	"/d"			; 64	.ASCIZ	"/e"			; 65	.ASCIZ	"/f"			; 66	.ASCIZ	"/g"			; 67	.ASCIZ	"/h"			; 68	.ASCIZ	"/i"			; 69	.ASCIZ	"/j"			; 6A	.ASCIZ	"/k"			; 6B	.ASCIZ	"/l"			; 6C	.ASCIZ	"/m"			; 6D	.ASCIZ	"/n"			; 6E	.ASCIZ	"/o"			; 6F	.ASCIZ	"/p"			; 70	.ASCIZ	"/q"			; 71	.ASCIZ	"/r"			; 72	.ASCIZ	"/s"			; 73	.ASCIZ	"/t"			; 74	.ASCIZ	"/u"			; 75	.ASCIZ	"/v"			; 76	.ASCIZ	"/w"			; 77	.ASCIZ	"/x"			; 78	.ASCIZ	"/y"			; 79	.ASCIZ	"/z"			; 7A	.ASCIZ	"/braceleft"		; 7B	.ASCIZ	"/bar"			; 7C	.ASCIZ	"/braceright"		; 7D	.ASCIZ	"/asciitilde"		; 7E	.ASCIZ	"/"			; 7F	.ASCIZ	"/Adieresis"		; 80	.ASCIZ	"/Aring"		; 81	.ASCIZ	"/Ccedilla"		; 82	.ASCIZ	"/Eacute"		; 83	.ASCIZ	"/Ntilde"		; 84	.ASCIZ	"/Odieresis"		; 85	.ASCIZ	"/Udieresis"		; 86	.ASCIZ	"/aacute"		; 87	.ASCIZ	"/agrave"		; 88	.ASCIZ	"/acircumflex"		; 89	.ASCIZ	"/adieresis"		; 8A	.ASCIZ	"/atilde"		; 8B	.ASCIZ	"/aring"		; 8C	.ASCIZ	"/ccedilla"		; 8D	.ASCIZ	"/eacute"		; 8E	.ASCIZ	"/egrave"		; 8F	.ASCIZ	"/ecircumflex"		; 90	.ASCIZ	"/edieresis"		; 91	.ASCIZ	"/iacute"		; 92	.ASCIZ	"/igrave"		; 93	.ASCIZ	"/icircumflex"		; 94	.ASCIZ	"/idieresis"		; 95	.ASCIZ	"/ntilde"		; 96	.ASCIZ	"/oacute"		; 97	.ASCIZ	"/ograve"		; 98	.ASCIZ	"/ocircumflex"		; 99	.ASCIZ	"/odieresis"		; 9A	.ASCIZ	"/otilde"		; 9B	.ASCIZ	"/uacute"		; 9C	.ASCIZ	"/ugrave"		; 9D	.ASCIZ	"/ucircumflex"		; 9E	.ASCIZ	"/udieresis"		; 9F	.ASCIZ	"/dagger"		; A0	.ASCIZ	"/degree"		; A1	.ASCIZ	"/cent"			; A2	.ASCIZ	"/sterling"		; A3	.ASCIZ	"/section"		; A4	.ASCIZ	"/bullet"		; A5	.ASCIZ	"/paragraph"		; A6	.ASCIZ	"/germandbls"		; A7	.ASCIZ	"/registersans"		; A8	.ASCIZ	"/copyrightsans"	; A9	.ASCIZ	"/trademarksans"	; AA	.ASCIZ	"/acute"		; AB	.ASCIZ	"/dieresis"		; AC	.ASCIZ	"/notequal"		; AD	.ASCIZ	"/AE"			; AE	.ASCIZ	"/Oslash"		; AF	.ASCIZ	"/infinity"		; B0	.ASCIZ	"/plusminus"		; B1	.ASCIZ	"/lessequal"		; B2	.ASCIZ	"/greaterequal"		; B3	.ASCIZ	"/yen"			; B4	.ASCIZ	"/mu"			; B5	.ASCIZ	"/partialdiff"		; B6	.ASCIZ	"/summation"		; B7	.ASCIZ	"/product"		; B8	.ASCIZ	"/pi"			; B9	.ASCIZ	"/integral"		; BA	.ASCIZ	"/ordfeminine"		; BB	.ASCIZ	"/ordmasculine"		; BC	.ASCIZ	"/Omega"		; BD	.ASCIZ	"/ae"			; BE	.ASCIZ	"/oslash"		; BF	.ASCIZ	"/questiondown"		; C0	.ASCIZ	"/exclamdown"		; C1	.ASCIZ	"/logicalnot"		; C2	.ASCIZ	"/radical"		; C3	.ASCIZ	"/florin"		; C4	.ASCIZ	"/approxequal"		; C5	.ASCIZ	"/Delta"		; C6	.ASCIZ	"/guillemotleft"	; C7	.ASCIZ	"/guillemotright"	; C8	.ASCIZ	"/ellipsis"		; C9	.ASCIZ	"/nbspace"		; CA	.ASCIZ	"/Agrave"		; CB	.ASCIZ	"/Atilde"		; CC	.ASCIZ	"/Otilde"		; CD	.ASCIZ	"/OE"			; CE	.ASCIZ	"/oe"			; CF	.ASCIZ	"/endash"		; D0	.ASCIZ	"/emdash"		; D1	.ASCIZ	"/quotedblleft"		; D2	.ASCIZ	"/quotedblright"	; D3	.ASCIZ	"/quoteleft"		; D4	.ASCIZ	"/quoteright"		; D5	.ASCIZ	"/divide"		; D6	.ASCIZ	"/lozenge"		; D7	.ASCIZ	"/ydieresis"		; D8	.ASCIZ	"/Ydieresis"		; D9	.ASCIZ	"/fraction"		; DA	.ASCIZ	"/currency"		; DB	.ASCIZ	"/guilsinglleft"	; DC	.ASCIZ	"/guilsinglright"	; DD	.ASCIZ	"/fi"			; DE	.ASCIZ	"/fl"			; DF	.ASCIZ	"/daggerdbl"		; E0	.ASCIZ	"/periodcentered"	; E1	.ASCIZ	"/quotesinglbase"	; E2	.ASCIZ	"/quotedblbase"		; E3	.ASCIZ	"/perthousand"		; E4	.ASCIZ	"/Acircumflex"		; E5	.ASCIZ	"/Ecircumflex"		; E6	.ASCIZ	"/Aacute"		; E7	.ASCIZ	"/Edieresis"		; E8	.ASCIZ	"/Egrave"		; E9	.ASCIZ	"/Iacute"		; EA	.ASCIZ	"/Icircumflex"		; EB	.ASCIZ	"/Idieresis"		; EC	.ASCIZ	"/Igrave"		; ED	.ASCIZ	"/Oacute"		; EE	.ASCIZ	"/Ocircumflex"		; EF	.ASCIZ	"/apple"		; F0	.ASCIZ	"/Ograve"		; F1	.ASCIZ	"/Uacute"		; F2	.ASCIZ	"/Ucircumflex"		; F3	.ASCIZ	"/Ugrave"		; F4	.ASCIZ	"/dotlessi"		; F5	.ASCIZ	"/circumflex"		; F6	.ASCIZ	"/tilde"		; F7	.ASCIZ	"/macron"		; F8	.ASCIZ	"/breve"		; F9	.ASCIZ	"/dotaccent"		; FA	.ASCIZ	"/ring"			; FB	.ASCIZ	"/cedilla"		; FC	.ASCIZ	"/hungarumlaut"		; FD	.ASCIZ	"/ogonek"		; FE	.ASCIZ	"/caron"		; FF	.B	0	.EVEN;--------\\; PUTOP   >;--------/; ; in	D4.W	opration;	A2.L	^fin des valeurs; out	-; mod	D7.WPUTOP:	PUSHM.L	D2..D4,A3	.IF	DEBUG	PUSH.W	D4	LOAD.L	A3,#(A6)+OBUPAR20$:	COMP.L	A3,A2	JUMP,EQ 24$	CLR.L	D4	LOAD.W	D4,(A3+)	JUMP,NC 22$	NEG.W	D4	LOAD.B	D3,#'-	LIB	?AFCAR22$:	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFSPACE	JUMP	20$24$:	POP.W	D4	LIB	?AFTIM	.ASCIZ	" op="	.EVEN	AND.L	D4,#H'FFFF	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFCR	.ENDIF	COMP.W	(A6)+OFREV,#100	JUMP,HS REVM$	COMP.W	(A6)+OFREV,#2	JUMP,HS REV2$	COMP.W	D4,#0	JUMP,EQ POS$	COMP.W	D4,#1	JUMP,EQ LINE$	COMP.W	D4,#2	JUMP,EQ CURVE$	COMP.W	D4,#5	JUMP,EQ DIM$	COMP.W	D4,#17	JUMP,EQ FILL$	COMP.W	D4,#18	JUMP,EQ EOFILL$	JUMP	OTHER$REV2$:	COMP.W	D4,#0	JUMP,EQ POS2$	COMP.W	D4,#1	JUMP,EQ LINE$	COMP.W	D4,#2	JUMP,EQ CURVE$	COMP.W	D4,#4	JUMP,EQ REL$	COMP.W	D4,#5	JUMP,EQ DIM$	COMP.W	D4,#7	JUMP,EQ ADD$	COMP.W	D4,#10	JUMP,EQ EXIT$	COMP.W	D4,#11	JUMP,EQ EXIT$	COMP.W	D4,#12	JUMP,EQ FILL$	COMP.W	D4,#13	JUMP,EQ EOFILL$	COMP.W	D4,#16	JUMP,EQ EXIT$	COMP.W	D4,#18	JUMP,EQ EXIT$	COMP.W	D4,#19	JUMP,EQ CLOSE$	JUMP	OTHER$REVM$:	COMP.W	D4,#0	JUMP,EQ POS2$	COMP.W	D4,#1	JUMP,EQ LINE$	COMP.W	D4,#2	JUMP,EQ CURVE$	COMP.W	D4,#4	JUMP,EQ REL$	COMP.W	D4,#5	JUMP,EQ DIM$	COMP.W	D4,#7	JUMP,EQ ADD$	COMP.W	D4,#10	JUMP,EQ EXIT$	COMP.W	D4,#11	JUMP,EQ EXIT$	COMP.W	D4,#12	JUMP,EQ FILL$	COMP.W	D4,#13	JUMP,EQ EOFILL$	COMP.W	D4,#16	JUMP,EQ EXIT$	COMP.W	D4,#18	JUMP,EQ EXIT$	COMP.W	D4,#19	JUMP,EQ CLOSE$	JUMP	OTHER$OTHER$:	.IF	~DEBUG	LIB	?AFTIM	.ASCIZ	" op="	.EVEN	AND.L	D4,#H'FFFF	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFCR	.ENDIF	JUMP	EXIT$POS$:	LOAD.L	D3,(A6)+OLPOS	LOAD.L	D4,(A2)-4	CALL	CONVIN	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OLPOS,D4	LOAD.L	(A6)+OPPOS,D4POS1$:	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	LOAD.L	A3,(A6)+OPPOUT	LOAD.B	(A3+),#xcOPBEGIN	CLR.B	(A3+)	CALL	CONVOUT	LOAD.L	(A3+),D4	LOAD.L	D3,(A3)-4	CALL	FILTREP	JUMP,NE EXIT$	LOAD.L	(A6)+OPPOUT,A3	JUMP	EXIT$POS2$:	LOAD.L	D4,(A2)-4	CALL	CONVIN	LOAD.L	(A6)+OLPOS,D4	LOAD.L	(A6)+OPPOS,D4	JUMP	POS1$LINE$:	LOAD.L	D4,(A2)-4	CALL	CONVIN	LOAD.L	D3,(A6)+OLPOS	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OLPOS,D4LINE1$:	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	LOAD.L	A3,(A6)+OPPOUT	LOAD.B	(A3+),#xcOPLINE	CLR.B	(A3+)	CALL	CONVOUT	LOAD.L	(A3+),D4	LOAD.L	D3,(A3)-4	CALL	FILTREP	JUMP,NE EXIT$	LOAD.L	(A6)+OPPOUT,A3	JUMP	EXIT$CLOSE$:	LOAD.L	D4,(A6)+OPPOS	JUMP	LINE1$CURVE$:	LOAD.L	A3,(A6)+OPPOUT	LOAD.B	(A3+),#xcOPCURVE	CLR.B	(A3+)	LOAD.L	D3,(A6)+OLPOS	LOAD.L	D4,(A2)-12	CALL	CONVIN	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	NEG.W	D4	SWAP.W	D3	SWAP.W	D4	CALL	CONVOUT	LOAD.L	(A3+),D4	LOAD.L	D4,(A2)-8	CALL	CONVIN	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	NEG.W	D4	SWAP.W	D3	SWAP.W	D4	CALL	CONVOUT	LOAD.L	(A3+),D4	LOAD.L	D4,(A2)-4	CALL	CONVIN	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	NEG.W	D4	SWAP.W	D3	SWAP.W	D4	PUSH.L	D4	CALL	CONVOUT	LOAD.L	(A3+),D4	POP.L	D4	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	LOAD.L	(A6)+OLPOS,D4	LOAD.L	D3,(A3)-4	CALL	FILTREP	JUMP,NE EXIT$	LOAD.L	D3,(A3)-8	CALL	FILTREP	JUMP,NE EXIT$	LOAD.L	D3,(A3)-12	CALL	FILTREP	JUMP,NE EXIT$	LOAD.L	(A6)+OPPOUT,A3	JUMP	EXIT$DIM$:	LOAD.W	D4,(A2)-12	LOAD.W	(A6)+OWCAR,D4	JUMP	EXIT$FILL$:	LOAD.L	A3,(A6)+OPPOUF	LOAD.B	(A3+),#xcOPFILLA	JUMP	EXIT$EOFILL$:	LOAD.L	A3,(A6)+OPPOUF	LOAD.B	(A3+),#xcOPFILLI	JUMP	EXIT$REL$:	LOAD.L	D4,(A2)-4	CALL	CONVIN	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	LOAD.L	(A6)+ORPOS,D4	JUMP	EXIT$ADD$:	LOAD.L	D3,(A6)+ORPOS	CALL	FILTREP	JUMP,NE EXIT$	LOAD.W	D3,(A2)-2	CALL	CARMS	JUMP,NE EXIT$	LOAD.L	A3,(A6)+OPPOUT	LOAD.B	(A3+),#xcOPADDCHAR	CLR.B	(A3+)	LOAD.L	(A3+),(A6)+ORPOS	LOAD.B	(A3+),D3	CLR.B	(A3+)	LOAD.L	(A6)+OPPOUT,A3	JUMP	EXIT$EXIT$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; FILTREP >;--------/; in	D3.L	point (y;x); out	D7.W	erreur; mod	D7.WFILTREP:	PUSH.L	D3	LOAD.W	D7,#1	COMP.W	D3,#-1500	JUMP',LT 90$	COMP.W	D3,#+1500	JUMP',GE 90$	SWAP.W	D3	COMP.W	D3,#-1500	JUMP',LT 90$	COMP.W	D3,#+1500	JUMP',GE 90$	CLR.W	D790$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; CARMS   >;--------/; Conversion d'un caractre MAC --> SMAKY.; in	D3.B	caractre MAC; out	D3.B	caractre SMAKY;	D7.W	erreur; mod	D3.L, D7.WCARMS:	PUSHM.L	D2,D4,A4	LOAD.W	D7,#1	LOAD.L	A4,#R16"TACAR	LOAD.W	D2,#-120$:	INC.W	D2	LOAD.W	D4,(A4+)	COMP.W	D4,#-1	JUMP',EQ 90$	COMP.B	D4,D3	JUMP,NE 20$	LOAD.W	D3,D2	CLR.W	D790$:	POPM.L	D2,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CONVIN  >;--------/; ; in	; out	; mod	CONVIN:	SWAP.W	D4	RET;--------\\; CONVOUT >;--------/; ; in	; out	; mod	CONVOUT:	RET;--------\\; PUTNUM  >;--------/; Met un nombre dans un buffer.; in	D1.L	nombre et flag;	A2.L	^buffer; out	D1.L	nombre suivant;	A2.L	^plus loin; mod	D1.L, A2.LPUTNUM:	PUSHM.L	D2..D4	TCLR.L	D1:#16	JUMP,BC 90$	LOAD.W	(A2+),D1	; OBUPAR <-- valeur	CLR.W	D190$:	POPM.L	D2..D4	RET;--------\\; SEARCH  >;========/; Cherche une chane de caractre.; in	A3.L	^texte cherch;	A4.L	^o chercher; out	A4.L	^aprs le texte trouv;	D7.W	erreur; mod	D7.W, A4.LSEARCH:	PUSHM.L	A1..A3	LOAD.W	D7,#120$:	TEST.B	(A4)	JUMP,EQ 90$	LOAD.L	A1,A3	LOAD.L	A2,A422$:	TEST.B	(A1)	JUMP,EQ 26$	COMP.B	(A1+),(A2+)	JUMP,EQ 22$24$:	INC.L	A4	JUMP	20$26$:	LOAD.L	A4,A2	CLR.W	D790$:	POPM.L	A1..A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETBNUM >;--------/; Donne un nombre dcimal +/-.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre +/-; mod	D4.L, A4.LGETBNUM:20$:	COMP.B	(A4+),#SPACE	JUMP,EQ 20$	DEC.L	A4	COMP.B	(A4+),#'+	JUMP,EQ GETANUM	COMP.B	(-A4),#'-	JUMP,NE GETANUM	INC.L	A4	CALL	GETANUM	NEG.L	D4	RET;--------\\; GETANUM >;--------/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSH.L	D320$:	COMP.B	(A4+),#SPACE	JUMP,EQ 20$	DEC.L	A4	CLR.L	D4		; D4 <-- futur nombre30$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	30$50$:	DEC.L	A4		; D4 <-- ^terminateur	POP.L	D3	RET;--------\\; GETHNUM >;--------/; ; Donne un nombre hexadcimal  deux digits.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre;	D7.W	erreur; mod	D4.L, D7.W, A4.LGETHNUM:	PUSHM.L	D2,D3	LOAD.W	D7,#1	LOAD.W	D2,#2	CLR.L	D420$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP,LO 90$	COMP.B	D3,#'9	JUMP,LS 40$	COMP.B	D3,#'A	JUMP,LO 90$	COMP.B	D3,#'F	JUMP,HI 90$	SUB.B	D3,#'A-'9-140$:	SUB.B	D3,#'0		; D3 <-- 0..15	SL.L	D4,#4		; fait place pour 4 bits	OR.B	D4,D3		; ajoute nouveaux 4 bits	DEC.W	D2	JUMP,NE 20$	CLR.W	D790$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDFILE  >;========/; Lit entirement un fichier en mmoire.; in	A3.L	^nom du fichier; out	A4.L	^data;	D7.W	erreur; mod	D7.W, A4.LRDFILE:	PUSHM.L	D1..D6	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS	LOAD.L	D2,D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS	LOAD.L	D4,D2	INC.L	D4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE 85$	DEC.L	D4	FOS	?RDBYTE	JUMP,NE 80$	CLR.B	(A4)+(D4.L)	JUMP	85$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	POP.W	D785$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D1..D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRFILE  >;========/; Ecrit sur disque un fichier entirement en mmoire.; in	A3.L	^nom du fichier;	A4.L	^data;	D4.L	lg data; out	D7.W	erreur; mod	D7.WWRFILE:	PUSHM.L	D3,D4,D6	.IF	~ASSMILE	FOS	?DELETE	.ENDIF	LOAD.L	D3,#DEFATT	LIB	?FCREATE	JUMP,NE 90$	FOS	?WRBYTE	JUMP,NE 80$	FOS	?CLOSE	JUMP	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RETTXMENU:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVENVAR:	.FILLB	LGVAR,0	.END	START