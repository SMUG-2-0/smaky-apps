	.TITLE	FP.ASC	.PROC	M680002	.REF	SMAKYDEBUG	=	0	.LOC	0OBUDIS:	.BLKB	100OPFILE:	.BLKB	4OBUFF:	.BLKB	100ODPOS:	.BLKB	4OPPOS:	.BLKB	4OLPOS:	.BLKB	4ORPOS:	.BLKB	4OWCAR:	.BLKB	2OCODE:	.BLKB	2OSCALE:	.BLKB	2OFREV:	.BLKB	2OPOINT:	.BLKB	1OSTEP:	.BLKB	1	.EVENOBZP0:	.BLKB	4		; P0OBZP1:	.BLKB	4		; P1OBZP2:	.BLKB	4		; P2OBZP3:	.BLKB	4		; P3LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LIB	?AFTIM	.B	MODGRA,GRACLIP	.B	NOCURS	.B	NOEFLI	.B	0	.EVEN	LOAD.L	A3,#R16"TXMENU	LIB	?AFMENU	LIB	?AFTIM	.ASCIZ	"<CR>Nom du fichier .PS : "	.EVEN	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D3,#50	LIB	?GETLINE	COMP.W	D3,#CR	JUMP,NE FINI	CALL	RDFILE	JUMP,NE ERROR	LOAD.L	(A6)+OPFILE,A4	CALL	INIDECODEREFAIT:	LOAD.W	(A6)+ODPOS+2,#50	LOAD.W	(A6)+ODPOS+0,#100	LOAD.W	(A6)+OSCALE,#1	LOAD.W	(A6)+OCODE,#'A	JUMP	40$20$:	TEST.B	(A6)+OSTEP	JUMP,F	22$	LIB	?BUZZ22$:	LIB	?AFTIM	.ASCIZ	"Caractre = "	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OCODE	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFSPACE	LIB	?AFX2	LIB	?AFSPACE	LOAD.B	D3,D4	LIB	?AFCODE	LIB	?AFTIM	.ASCIZ	"    Echelle = "	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OSCALE	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"<CR>Caractre : "	.EVEN	LIB	?GETCAR	COMP.W	D3,#F0	JUMP,EQ FINI	COMP.W	D3,#F1	JUMP,EQ 60$	COMP.W	D3,#F3	JUMP,EQ 62$	COMP.W	D3,#F4	JUMP,EQ 70$	COMP.W	D3,#F6	JUMP,EQ 72$	COMP.W	D3,#F7	JUMP,EQ 50$	COMP.W	D3,#F8	JUMP,EQ 52$	COMP.W	D3,#F9	JUMP,EQ 54$	COMP.W	D3,#F7+SHIFT	JUMP,EQ 56$	COMP.W	D3,#F9+SHIFT	JUMP,EQ 58$	COMP.W	D3,#F13	JUMP,EQ FRAPPE	AND.W	D3,#H'FF	LOAD.W	(A6)+OCODE,D340$:	LIB	?AFTIM	.B	EOP,0	.EVEN	LOAD.W	D3,(A6)+OCODE	CALL	DECODE	JUMP	20$50$:	LOAD.W	D4,(A6)+OSCALE	SL.W	D4,#1	LOAD.W	(A6)+OSCALE,D4	JUMP	40$52$:	LOAD.W	(A6)+OSCALE,#1	JUMP	40$54$:	LOAD.W	D4,(A6)+OSCALE	COMP.W	D4,#1	JUMP,EQ 40$	SR.W	D4,#1	LOAD.W	(A6)+OSCALE,D4	JUMP	40$56$:	LOAD.W	D4,(A6)+OSCALE	INC.W	D4	LOAD.W	(A6)+OSCALE,D4	JUMP	40$58$:	LOAD.W	D4,(A6)+OSCALE	COMP.W	D4,#1	JUMP,EQ 40$	DEC.W	D4	LOAD.W	(A6)+OSCALE,D4	JUMP	40$60$:	DEC.W	(A6)+OCODE	JUMP	40$62$:	INC.W	(A6)+OCODE	JUMP	40$70$:	NOT.B	(A6)+OPOINT	JUMP	40$72$:	NOT.B	(A6)+OSTEP	JUMP	40$FRAPPE:	LOAD.B	D3,#EOP	LIB	?AFCAR	LOAD.W	(A6)+ODPOS+2,#50	LOAD.W	(A6)+ODPOS+0,#100-50020$:	LIB	?GETCAR	COMP.W	D3,#F0	JUMP,EQ REFAIT	COMP.W	D3,#CR	JUMP,EQ 30$	CALL	AFCAR	JUMP	20$30$:	LOAD.W	(A6)+ODPOS+2,#50	LOAD.W	D4,#1000	CALL	SCALE	ADD.W	(A6)+ODPOS+0,D4	JUMP	20$ERROR:	LIB	?AFERRORFINI:	TEST.L	(A6)+OPFILE	JUMP,EQ RETOUR	LOAD.L	A4,(A6)+OPFILE	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPFILERETOUR:	EXIT;----------\\; INIDECODE >;==========/; Cherche le numro de rvision du logiciel "Fontographer" qui; a gnr le fichier .PS; in	-; out	-; mod	D7.WINIDECODE:	PUSHM.L	D4,A3,A4	CLR.W	(A6)+OFREV	LOAD.L	A4,(A6)+OPFILE	LOAD.L	A3,#R16"CH1$	CALL	SEARCH		; cherche "Fontographer "	JUMP,NE 90$	CALL	GETANUM	LOAD.W	(A6)+OFREV,D490$:	POPM.L	D4,A3,A4	RETCH1$:	.ASCIZ	"Fontographer "	.EVEN;--------\\; AFCAR   >;========/; ; in	D3.B	caractre  afficher; out	-; mod	D7.WAFCAR:	PUSHM.L	D3	AND.W	D3,#H'FF	LOAD.W	(A6)+OCODE,D3	CALL	DECODE	LOAD.W	D3,(A6)+OWCAR	ADD.W	(A6)+ODPOS+2,D390$:	POPM.L	D3	RET;--------\\; DECODE  >;========/; ; in	D3.W	code du caractre; out	; mod	DECODE:	CLR.L	(A6)+ORPOSDECODE2:	PUSHM.L	D1..D4,A2..A4	LOAD.L	A2,#(A6)+OBUFF	LOAD.L	A3,#R16"TACODE$20$:	TEST.B	(A3)		; fin de la table ?	JUMP,EQ 90$		; oui => 90$	DEC.W	D3	JUMP',NS 24$22$:	TEST.B	(A3+)		; A3 <-- ^nom de caractre suivant	JUMP,NE 22$	JUMP	20$24$:	LOAD.L	A4,(A6)+OPFILE30$:	CALL	SEARCH		; cherche le nom du caractre (ex. "/A")	JUMP,NE 90$32$:	COMP.B	(A4+),#SPACE	; "/A {<1234.."	JUMP,EQ 32$	DEC.L	A4	COMP.B	(A4),#'{	JUMP',NE 36$	INC.L	A436$:	COMP.B	(A4),#'<	JUMP,NE 30$	INC.L	A4	CLR.L	(A6)+OLPOS	TCLR.L	D1:#1640$:	COMP.B	(A4+),#CR	JUMP,EQ 40$	DEC.L	A4	CALL	GETHNUM	JUMP,NE 90$	COMP.W	D4,#200	JUMP,LO 60$	COMP.W	D4,#233	JUMP,LO 50$				; 233..255 =>	CALL	PUTNUM	SUB.W	D4,#233	CALL	PUTOP	LOAD.L	A2,#(A6)+OBUFF	JUMP	40$50$:				; 200..232 =>	SUB.W	D4,#216	MUL.WA	D4,#100	ADD.W	D1,D4	TSET.L	D1:#16	JUMP	40$60$:				; 000..199 =>	CALL	PUTNUM	SUB.W	D4,#100	LOAD.W	D1,D4	TSET.L	D1:#16	JUMP	40$90$:	POPM.L	D1..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETTACODE$:	.ASCIZ	"/"			; 00	.ASCIZ	"/"			; 01	.ASCIZ	"/"			; 02	.ASCIZ	"/"			; 03	.ASCIZ	"/"			; 04	.ASCIZ	"/"			; 05	.ASCIZ	"/"			; 06	.ASCIZ	"/"			; 07	.ASCIZ	"/"			; 08	.ASCIZ	"/"			; 09	.ASCIZ	"/"			; 0A	.ASCIZ	"/"			; 0B	.ASCIZ	"/"			; 0C	.ASCIZ	"/"			; 0D	.ASCIZ	"/"			; 0E	.ASCIZ	"/"			; 0F	.ASCIZ	"/"			; 10	.ASCIZ	"/"			; 11	.ASCIZ	"/"			; 12	.ASCIZ	"/"			; 13	.ASCIZ	"/"			; 14	.ASCIZ	"/"			; 15	.ASCIZ	"/"			; 16	.ASCIZ	"/"			; 17	.ASCIZ	"/"			; 18	.ASCIZ	"/"			; 19	.ASCIZ	"/"			; 1A	.ASCIZ	"/"			; 1B	.ASCIZ	"/"			; 1C	.ASCIZ	"/"			; 1D	.ASCIZ	"/"			; 1E	.ASCIZ	"/"			; 1F	.ASCIZ	"/space"		; 20	.ASCIZ	"/exclam"		; 21	.ASCIZ	"/quotedbl"		; 22	.ASCIZ	"/numbersign"		; 23	.ASCIZ	"/dollar"		; 24	.ASCIZ	"/percent"		; 25	.ASCIZ	"/ampersand"		; 26	.ASCIZ	"/quotesingle"		; 27	.ASCIZ	"/parenleft"		; 28	.ASCIZ	"/parenright"		; 29	.ASCIZ	"/asterisk"		; 2A	.ASCIZ	"/plus"			; 2B	.ASCIZ	"/comma"		; 2C	.ASCIZ	"/hyphen"		; 2D	.ASCIZ	"/period"		; 2E	.ASCIZ	"/slash"		; 2F	.ASCIZ	"/zero"			; 30	.ASCIZ	"/one"			; 31	.ASCIZ	"/two"			; 32	.ASCIZ	"/three"		; 33	.ASCIZ	"/four"			; 34	.ASCIZ	"/five"			; 35	.ASCIZ	"/six"			; 36	.ASCIZ	"/seven"		; 37	.ASCIZ	"/eight"		; 38	.ASCIZ	"/nine"			; 39	.ASCIZ	"/colon"		; 3A	.ASCIZ	"/semicolon"		; 3B	.ASCIZ	"/less"			; 3C	.ASCIZ	"/equal"		; 3D	.ASCIZ	"/greater"		; 3E	.ASCIZ	"/question"		; 3F	.ASCIZ	"/at"			; 40	.ASCIZ	"/A"			; 41	.ASCIZ	"/B"			; 42	.ASCIZ	"/C"			; 43	.ASCIZ	"/D"			; 44	.ASCIZ	"/E"			; 45	.ASCIZ	"/F"			; 46	.ASCIZ	"/G"			; 47	.ASCIZ	"/H"			; 48	.ASCIZ	"/I"			; 49	.ASCIZ	"/J"			; 4A	.ASCIZ	"/K"			; 4B	.ASCIZ	"/L"			; 4C	.ASCIZ	"/M"			; 4D	.ASCIZ	"/N"			; 4E	.ASCIZ	"/O"			; 4F	.ASCIZ	"/P"			; 50	.ASCIZ	"/Q"			; 51	.ASCIZ	"/R"			; 52	.ASCIZ	"/S"			; 53	.ASCIZ	"/T"			; 54	.ASCIZ	"/U"			; 55	.ASCIZ	"/V"			; 56	.ASCIZ	"/W"			; 57	.ASCIZ	"/X"			; 58	.ASCIZ	"/Y"			; 59	.ASCIZ	"/Z"			; 5A	.ASCIZ	"/bracketleft"		; 5B	.ASCIZ	"/backslash"		; 5C	.ASCIZ	"/bracketright"		; 5D	.ASCIZ	"/asciicircum"		; 5E	.ASCIZ	"/underscore"		; 5F	.ASCIZ	"/grave"		; 60	.ASCIZ	"/a"			; 61	.ASCIZ	"/b"			; 62	.ASCIZ	"/c"			; 63	.ASCIZ	"/d"			; 64	.ASCIZ	"/e"			; 65	.ASCIZ	"/f"			; 66	.ASCIZ	"/g"			; 67	.ASCIZ	"/h"			; 68	.ASCIZ	"/i"			; 69	.ASCIZ	"/j"			; 6A	.ASCIZ	"/k"			; 6B	.ASCIZ	"/l"			; 6C	.ASCIZ	"/m"			; 6D	.ASCIZ	"/n"			; 6E	.ASCIZ	"/o"			; 6F	.ASCIZ	"/p"			; 70	.ASCIZ	"/q"			; 71	.ASCIZ	"/r"			; 72	.ASCIZ	"/s"			; 73	.ASCIZ	"/t"			; 74	.ASCIZ	"/u"			; 75	.ASCIZ	"/v"			; 76	.ASCIZ	"/w"			; 77	.ASCIZ	"/x"			; 78	.ASCIZ	"/y"			; 79	.ASCIZ	"/z"			; 7A	.ASCIZ	"/braceleft"		; 7B	.ASCIZ	"/bar"			; 7C	.ASCIZ	"/braceright"		; 7D	.ASCIZ	"/asciitilde"		; 7E	.ASCIZ	"/"			; 7F	.ASCIZ	"/Adieresis"		; 80	.ASCIZ	"/Aring"		; 81	.ASCIZ	"/Ccedilla"		; 82	.ASCIZ	"/Eacute"		; 83	.ASCIZ	"/Ntilde"		; 84	.ASCIZ	"/Odieresis"		; 85	.ASCIZ	"/Udieresis"		; 86	.ASCIZ	"/aacute"		; 87	.ASCIZ	"/agrave"		; 88	.ASCIZ	"/acircumflex"		; 89	.ASCIZ	"/adieresis"		; 8A	.ASCIZ	"/atilde"		; 8B	.ASCIZ	"/aring"		; 8C	.ASCIZ	"/ccedilla"		; 8D	.ASCIZ	"/eacute"		; 8E	.ASCIZ	"/egrave"		; 8F	.ASCIZ	"/ecircumflex"		; 90	.ASCIZ	"/edieresis"		; 91	.ASCIZ	"/iacute"		; 92	.ASCIZ	"/igrave"		; 93	.ASCIZ	"/icircumflex"		; 94	.ASCIZ	"/idieresis"		; 95	.ASCIZ	"/ntilde"		; 96	.ASCIZ	"/oacute"		; 97	.ASCIZ	"/ograve"		; 98	.ASCIZ	"/ocircumflex"		; 99	.ASCIZ	"/odieresis"		; 9A	.ASCIZ	"/otilde"		; 9B	.ASCIZ	"/uacute"		; 9C	.ASCIZ	"/ugrave"		; 9D	.ASCIZ	"/ucircumflex"		; 9E	.ASCIZ	"/udieresis"		; 9F	.ASCIZ	"/dagger"		; A0	.ASCIZ	"/degree"		; A1	.ASCIZ	"/cent"			; A2	.ASCIZ	"/sterling"		; A3	.ASCIZ	"/section"		; A4	.ASCIZ	"/bullet"		; A5	.ASCIZ	"/paragraph"		; A6	.ASCIZ	"/germandbls"		; A7	.ASCIZ	"/registersans"		; A8	.ASCIZ	"/copyrightsans"	; A9	.ASCIZ	"/trademarksans"	; AA	.ASCIZ	"/acute"		; AB	.ASCIZ	"/dieresis"		; AC	.ASCIZ	"/notequal"		; AD	.ASCIZ	"/AE"			; AE	.ASCIZ	"/Oslash"		; AF	.ASCIZ	"/infinity"		; B0	.ASCIZ	"/plusminus"		; B1	.ASCIZ	"/lessequal"		; B2	.ASCIZ	"/greaterequal"		; B3	.ASCIZ	"/yen"			; B4	.ASCIZ	"/mu"			; B5	.ASCIZ	"/partialdiff"		; B6	.ASCIZ	"/summation"		; B7	.ASCIZ	"/product"		; B8	.ASCIZ	"/pi"			; B9	.ASCIZ	"/integral"		; BA	.ASCIZ	"/ordfeminine"		; BB	.ASCIZ	"/ordmasculine"		; BC	.ASCIZ	"/Omega"		; BD	.ASCIZ	"/ae"			; BE	.ASCIZ	"/oslash"		; BF	.ASCIZ	"/questiondown"		; C0	.ASCIZ	"/exclamdown"		; C1	.ASCIZ	"/logicalnot"		; C2	.ASCIZ	"/radical"		; C3	.ASCIZ	"/florin"		; C4	.ASCIZ	"/approxequal"		; C5	.ASCIZ	"/Delta"		; C6	.ASCIZ	"/guillemotleft"	; C7	.ASCIZ	"/guillemotright"	; C8	.ASCIZ	"/ellipsis"		; C9	.ASCIZ	"/nbspace"		; CA	.ASCIZ	"/Agrave"		; CB	.ASCIZ	"/Atilde"		; CC	.ASCIZ	"/Otilde"		; CD	.ASCIZ	"/OE"			; CE	.ASCIZ	"/oe"			; CF	.ASCIZ	"/endash"		; D0	.ASCIZ	"/emdash"		; D1	.ASCIZ	"/quotedblleft"		; D2	.ASCIZ	"/quotedblright"	; D3	.ASCIZ	"/quoteleft"		; D4	.ASCIZ	"/quoteright"		; D5	.ASCIZ	"/divide"		; D6	.ASCIZ	"/lozenge"		; D7	.ASCIZ	"/ydieresis"		; D8	.ASCIZ	"/Ydieresis"		; D9	.ASCIZ	"/fraction"		; DA	.ASCIZ	"/currency"		; DB	.ASCIZ	"/guilsinglleft"	; DC	.ASCIZ	"/guilsinglright"	; DD	.ASCIZ	"/fi"			; DE	.ASCIZ	"/fl"			; DF	.ASCIZ	"/daggerdbl"		; E0	.ASCIZ	"/periodcentered"	; E1	.ASCIZ	"/quotesinglbase"	; E2	.ASCIZ	"/quotedblbase"		; E3	.ASCIZ	"/perthousand"		; E4	.ASCIZ	"/Acircumflex"		; E5	.ASCIZ	"/Ecircumflex"		; E6	.ASCIZ	"/Aacute"		; E7	.ASCIZ	"/Edieresis"		; E8	.ASCIZ	"/Egrave"		; E9	.ASCIZ	"/Iacute"		; EA	.ASCIZ	"/Icircumflex"		; EB	.ASCIZ	"/Idieresis"		; EC	.ASCIZ	"/Igrave"		; ED	.ASCIZ	"/Oacute"		; EE	.ASCIZ	"/Ocircumflex"		; EF	.ASCIZ	"/apple"		; F0	.ASCIZ	"/Ograve"		; F1	.ASCIZ	"/Uacute"		; F2	.ASCIZ	"/Ucircumflex"		; F3	.ASCIZ	"/Ugrave"		; F4	.ASCIZ	"/dotlessi"		; F5	.ASCIZ	"/circumflex"		; F6	.ASCIZ	"/tilde"		; F7	.ASCIZ	"/macron"		; F8	.ASCIZ	"/breve"		; F9	.ASCIZ	"/dotaccent"		; FA	.ASCIZ	"/ring"			; FB	.ASCIZ	"/cedilla"		; FC	.ASCIZ	"/hungarumlaut"		; FD	.ASCIZ	"/ogonek"		; FE	.ASCIZ	"/caron"		; FF	.B	0	.EVEN;--------\\; PUTOP   >;========/; ; in	D4.W	opration;	A2.L	^fin des valeurs; out	-; mod	D7.WPUTOP:	PUSHM.L	D2..D4,A3,A4	.IF	DEBUG	PUSH.W	D4	LOAD.L	A3,#(A6)+OBUFF20$:	COMP.L	A3,A2	JUMP,EQ 24$	CLR.L	D4	LOAD.W	D4,(A3+)	JUMP,NC 22$	NEG.W	D4	LOAD.B	D3,#'-	LIB	?AFCAR22$:	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFSPACE	JUMP	20$24$:	POP.W	D4	LIB	?AFTIM	.ASCIZ	" op="	.EVEN	AND.L	D4,#H'FFFF	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFCR	.ENDIF	TEST.B	(A6)+OSTEP	JUMP,F	GO$	LIB	?GETCARGO$:	COMP.W	(A6)+OFREV,#2	JUMP,HS REV2$	COMP.W	D4,#0	JUMP,EQ POS$	COMP.W	D4,#1	JUMP,EQ LINE$	COMP.W	D4,#2	JUMP,EQ CURVE$	COMP.W	D4,#5	JUMP,EQ DIM$	COMP.W	D4,#17	JUMP,EQ FILL$	COMP.W	D4,#18	JUMP,EQ EOFILL$	JUMP	OTHER$REV2$:	COMP.W	D4,#0	JUMP,EQ POS2$	COMP.W	D4,#1	JUMP,EQ LINE$	COMP.W	D4,#2	JUMP,EQ CURVE$	COMP.W	D4,#4	JUMP,EQ REL$	COMP.W	D4,#5	JUMP,EQ DIM$	COMP.W	D4,#7	JUMP,EQ ADD$	COMP.W	D4,#12	JUMP,EQ FILL$	COMP.W	D4,#13	JUMP,EQ EOFILL$	COMP.W	D4,#19	JUMP,EQ CLOSE$	JUMP	OTHER$OTHER$:	.IF	~DEBUG	LIB	?AFTIM	.ASCIZ	" op="	.EVEN	AND.L	D4,#H'FFFF	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFCR	.ENDIF	JUMP	EXIT$POS$:	LOAD.L	D3,(A6)+OLPOS	LOAD.L	D4,(A2)-4	CALL	CONVRNUM	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OLPOS,D4	LOAD.L	(A6)+OPPOS,D4	JUMP	EXIT$POS2$:	LOAD.L	D4,(A2)-4	CALL	CONVRNUM	LOAD.L	(A6)+OLPOS,D4	LOAD.L	(A6)+OPPOS,D4	JUMP	EXIT$LINE$:	LOAD.L	D4,(A2)-4	CALL	CONVRNUM	LOAD.L	D3,(A6)+OLPOS	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OLPOS,D4LINE1$:	EX.L	D3,D4	CALL	CONVGNUM	CALL	DRAWPOINT	EX.L	D4,D3	CALL	CONVGNUM	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	TEST.L	D4	JUMP,EQ LINE4$	LOAD.W	D2,#SETDOT	LIB	?DRSEG	JUMP	EXIT$LINE4$:	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWDOT	SWAP.W	D3	LOAD.L	(A3)+1,D3	LOAD.B	(A3)+5,#SETDOT	LOAD.W	D3,#6	LIB	?STRING	JUMP	EXIT$CLOSE$:	LOAD.L	D4,(A6)+OPPOS	LOAD.L	D3,(A6)+OLPOS	JUMP	LINE1$CURVE$:	LOAD.L	A4,A6	LOAD.L	D3,(A6)+OLPOS	LOAD.L	D4,D3	CALL	CONVGNUM	CALL	DRAWPOINT	LOAD.L	(A4)+OBZP0,D4	LOAD.L	D4,(A2)-12	CALL	CONVRNUM	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	CONVGNUM	CALL	DRAWPOINTC	LOAD.L	(A4)+OBZP1,D4	LOAD.L	D4,(A2)-8	CALL	CONVRNUM	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	CONVGNUM	CALL	DRAWPOINTC	LOAD.L	(A4)+OBZP2,D4	LOAD.L	D4,(A2)-4	CALL	CONVRNUM	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OLPOS,D4	CALL	CONVGNUM	CALL	DRAWPOINT	LOAD.L	(A4)+OBZP3,D4	CALL	BZDRAW	JUMP	EXIT$DIM$:	LOAD.W	D4,(A2)-12	CALL	SCALE	LOAD.W	(A6)+OWCAR,D4	JUMP	EXIT$FILL$:	JUMP	EXIT$EOFILL$:	JUMP	EXIT$REL$:	LOAD.L	D4,(A2)-4	CALL	CONVRNUM	LOAD.L	(A6)+ORPOS,D4	JUMP	EXIT$ADD$:	LOAD.W	D3,(A2)-2	CALL	DECODE2		; hop, rcursif ...	JUMP	EXIT$EXIT$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; CONVANUM >;=========/; ; in	D4.L	valeur brutte; out	D4.L	valeur utilisable; mod	D4.LCONVANUM:	SWAP.W	D4	RET;---------\\; CONVRNUM >;=========/; ; in	D4.L	valeur brutte; out	D4.L	valeur utilisable; mod	D4.LCONVRNUM:	SWAP.W	D4	RET;---------\\; CONVGNUM >;=========/; ; in	D4.L	valeur brutte; out	D4.L	valeur utilisable; mod	D4.LCONVGNUM:	ADD.W	D4,(A6)+ORPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+ORPOS+0	SWAP.W	D4	CALL	SCALE	ADD.W	D4,(A6)+ODPOS+2	SWAP.W	D4	NEG.W	D4	ADD.W	D4,#700	ADD.W	D4,(A6)+ODPOS+0	SWAP.W	D4	RET;--------\\; SCALE   >;========/; ; in	D4.L	valeur; out	D4.L	valeur; mod	SCALE:	PUSHM.L	D1..D3	LOAD.W	D2,(A6)+OSCALE	COMP.W	D2,#1	JUMP,EQ 90$	LOAD.W	D3,D4	JUMP,NS 20$	CALL	DIVD3D2	JUMP	30$20$:	NEG.W	D3	CALL	DIVD3D2	NEG.W	D330$:	LOAD.W	D4,D3	SWAP.W	D4	LOAD.W	D3,D4	JUMP,NS 40$	CALL	DIVD3D2	JUMP	50$40$:	NEG.W	D3	CALL	DIVD3D2	NEG.W	D350$:	LOAD.W	D4,D3	SWAP.W	D490$:	POPM.L	D1..D3	RET;--------\\; DIVD3D2 >;========/; ; in	D3.W	munrateur;	D2.W	dnominateur; out	D3.W	= D3/D2; mod	D3.LDIVD3D2:	PUSHM.L	D1,D2	AND.L	D3,#H'FFFF	DIV.WU	D3,D2	SR.W	D2,#1	LOAD.L	D1,D3	SWAP.W	D1	COMP.W	D1,D2	JUMP,LO 90$	INC.W	D390$:	POPM.L	D1,D2	RET;----------\\; DRAWPOINT >;==========/; ; in	D4.L	point (y;x); out	; mod	DRAWPOINT:	PUSHM.L	D2..D4	TEST.B	(A6)+OPOINT	JUMP,F	90$	LOAD.L	D3,D4	LOAD.W	D4,#4	LOAD.W	D2,#SETDOT	LIB	?DRCERCLE90$:	POPM.L	D2..D4	RET;-----------\\; DRAWPOINTC >;===========/; ; in	D4.L	point (y;x); out	; mod	DRAWPOINTC:	PUSHM.L	D2..D4	TEST.B	(A6)+OPOINT	JUMP,F	90$	LOAD.L	D3,D4	LOAD.W	D2,#SETDOT	SUB.W	D3,#2	LOAD.L	D4,#H'10000*0+5	LIB	?DRSEG	SUB.W	D3,#3	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LOAD.L	D4,#H'10000*5+0	LIB	?DRSEG90$:	POPM.L	D2..D4	RET;--------\\; PUTNUM  >;========/; ; in	; out	; mod	PUTNUM:	PUSHM.L	D2..D4	TCLR.L	D1:#16	JUMP,BC 90$	LOAD.W	(A2+),D1	; OBUFF <-- valeur	CLR.W	D190$:	POPM.L	D2..D4	RET;--------\\; SEARCH  >;========/; Cherche une chane de caractre.; in	A3.L	^texte cherch;	A4.L	^o chercher; out	A4.L	^aprs le texte trouv;	D7.W	erreur; mod	D7.W, A4.LSEARCH:	PUSHM.L	A1..A3	LOAD.W	D7,#120$:	TEST.B	(A4)	JUMP,EQ 90$	LOAD.L	A1,A3	LOAD.L	A2,A422$:	TEST.B	(A1)	JUMP,EQ 26$	COMP.B	(A1+),(A2+)	JUMP,EQ 22$24$:	INC.L	A4	JUMP	20$26$:	LOAD.L	A4,A2	CLR.W	D790$:	POPM.L	A1..A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETANUM >;--------/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSH.L	D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POP.L	D3	RET;--------\\; GETHNUM >;========/; ; Donne un nombre hexadcimal  deux digits.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre;	D7.W	erreur; mod	D4.L, D7.W, A4.LGETHNUM:	PUSHM.L	D2,D3	LOAD.W	D7,#1	LOAD.W	D2,#2	CLR.L	D420$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP,LO 90$	COMP.B	D3,#'9	JUMP,LS 40$	COMP.B	D3,#'A	JUMP,LO 90$	COMP.B	D3,#'F	JUMP,HI 90$	SUB.B	D3,#'A-'9-140$:	SUB.B	D3,#'0		; D3 <-- 0..15	SL.L	D4,#4		; fait place pour 4 bits	OR.B	D4,D3		; ajoute nouveaux 4 bits	DEC.W	D2	JUMP,NE 20$	CLR.W	D790$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDFILE  >;========/; ; in	A3.L	^nom du fichier; out	A4.L	^data;	D7.W	erreur; mod	D7.W, A4.LRDFILE:	PUSHM.L	D1..D6	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS	LOAD.L	D2,D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS	LOAD.L	D4,D2	INC.L	D4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE 85$	DEC.L	D4	FOS	?RDBYTE	JUMP,NE 80$	CLR.B	(A4)+(D4.L)	JUMP	85$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	POP.W	D785$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D1..D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; BZDRAW  >;========/; ; in	A4.L	^OBZPn; out	; mod	BZDRAW:	PUSHM.L	D0..D6	LIB	?BUCAR	LOAD.L	D2,(A4)+OBZP0	LOAD.L	D3,(A4)+OBZP1;;?	CALL	BZLINE	LOAD.L	D2,(A4)+OBZP1	LOAD.L	D3,(A4)+OBZP2;;?	CALL	BZLINE	LOAD.L	D2,(A4)+OBZP2	LOAD.L	D3,(A4)+OBZP3;;?	CALL	BZLINE	LOAD.W	D3,(A4)+OBZP0+2	SUB.W	D3,(A4)+OBZP1+2	JUMP',NC POS1$	NEG.W	D3POS1$:	LOAD.W	D2,D3	LOAD.W	D3,(A4)+OBZP0+0	SUB.W	D3,(A4)+OBZP1+0	JUMP',NC POS2$	NEG.W	D3POS2$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP1+2	SUB.W	D3,(A4)+OBZP2+2	JUMP',NC POS3$	NEG.W	D3POS3$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP1+0	SUB.W	D3,(A4)+OBZP2+0	JUMP',NC POS4$	NEG.W	D3POS4$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP2+2	SUB.W	D3,(A4)+OBZP3+2	JUMP',NC POS5$	NEG.W	D3POS5$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP2+0	SUB.W	D3,(A4)+OBZP3+0	JUMP',NC POS6$	NEG.W	D3POS6$:	ADD.W	D2,D3	LOAD.W	D1,#1	COMP.W	D2,#160	JUMP',HS STEP$	LOAD.W	D1,#2	COMP.W	D2,#80	JUMP',HS STEP$	LOAD.W	D1,#4	COMP.W	D2,#40	JUMP',HS STEP$	LOAD.W	D1,#8	COMP.W	D2,#20	JUMP',HS STEP$	LOAD.W	D1,#16	COMP.W	D2,#10	JUMP',HS STEP$	LOAD.W	D1,#32	COMP.W	D2,#5	JUMP',HS STEP$	LOAD.W	D1,#64STEP$:	LOAD.W	D0,#6	COMP.W	D2,#640	JUMP',HS PROX$	LOAD.W	D0,#5	COMP.W	D2,#320	JUMP',HS PROX$	LOAD.W	D0,#4	COMP.W	D2,#160	JUMP',HS PROX$	LOAD.W	D0,#3	COMP.W	D2,#80	JUMP',HS PROX$	LOAD.W	D0,#2	COMP.W	D2,#40	JUMP',HS PROX$	LOAD.W	D0,#1PROX$:	CLR.W	D4	LOAD.L	D2,(A4)+OBZP0LOOP$:	CALL	BZPOINT		; D3 <-- point;;?jump okline$	LOAD.W	D5,D4	ADD.W	D5,D1	COMP.W	D5,#256	JUMP,HI OKLINE$	LOAD.W	D5,D2	SUB.W	D5,D3	JUMP',NC PLUSX$	NEG.W	D5		; D5 <-- |dx|PLUSX$:	SWAP.W	D2	SWAP.W	D3	LOAD.W	D6,D2	SUB.W	D6,D3	JUMP',NC PLUSY$	NEG.W	D6		; D6 <-- |dy|PLUSY$:	SWAP.W	D2	SWAP.W	D3	COMP.W	D5,D0	JUMP,HS OKLINE$	COMP.W	D6,D0	JUMP,LO NOLINE$OKLINE$:	CALL	BZLINE	LOAD.L	D2,D3NOLINE$:	ADD.W	D4,D1	COMP.W	D4,#256	JUMP,LS LOOP$	LIB	?NOBUCAR	POPM.L	D0..D6	RET;--------\\; BZLINE  >;========/; ; in	D2.L	dpart  (y;x);	D3.L	arrive (y;x); out	-; mod	D7.WBZLINE:	PUSHM.L	D2..D4	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	LOAD.L	D4,D3;;?load.l d4,#H'10000*1+1	LOAD.L	D3,D2	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2..D4	RET;--------\\; BZPOINT >;========/; ; in	A4.L	^OBZPn;	D4.W	position (0..256); out	D3.L	point (y;x); mod	D3.LBZPOINT:	PUSHM.L	D2,D4,A2,A3	LOAD.L	A3,#R16"TABLE$	LOAD.L	A2,A3	LOAD.W	D3,#256	SUB.W	D3,D4	SL.W	D4,#2	SL.W	D3,#2	ADD.W	A3,D4	ADD.W	A2,D3	LOAD.W	D4,(A4)+OBZP0+0	MUL.WA	D4,(A3)+0	LOAD.L	D3,D4	LOAD.W	D4,(A4)+OBZP1+0	MUL.WA	D4,(A3)+2	ADD.L	D3,D4	LOAD.W	D4,(A4)+OBZP2+0	MUL.WA	D4,(A2)+2	ADD.L	D3,D4	LOAD.W	D4,(A4)+OBZP3+0	MUL.WA	D4,(A2)+0	ADD.L	D3,D4	RL.L	D3,#1	COMP.W	D3,#H'8000	JUMP',LO 20$	ADD.L	D3,#H'1000020$:	LOAD.W	D4,(A4)+OBZP0+2	MUL.WA	D4,(A3)+0	LOAD.L	D2,D4	LOAD.W	D4,(A4)+OBZP1+2	MUL.WA	D4,(A3)+2	ADD.L	D2,D4	LOAD.W	D4,(A4)+OBZP2+2	MUL.WA	D4,(A2)+2	ADD.L	D2,D4	LOAD.W	D4,(A4)+OBZP3+2	MUL.WA	D4,(A2)+0	ADD.L	D2,D4	RL.L	D2,#1	COMP.W	D2,#H'8000	JUMP',LO 40$	ADD.L	D2,#H'1000040$:	SWAP.W	D2	LOAD.W	D3,D2	POPM.L	D2,D4,A2,A3	RETTABLE$:	.W	32767	0	.W	32385	381	.W	32005	756	.W	31628	1125	.W	31255	1488	.W	30884	1846	.W	30517	2197	.W	30152	2543	.W	29790	2883	.W	29431	3217	.W	29075	3546	.W	28722	3869	.W	28372	4186	.W	28024	4498	.W	27680	4804	.W	27338	5105	.W	26999	5400	.W	26663	5690	.W	26330	5974	.W	25999	6253	.W	25672	6527	.W	25347	6795	.W	25024	7058	.W	24705	7316	.W	24388	7569	.W	24074	7816	.W	23763	8059	.W	23454	8296	.W	23148	8528	.W	22845	8756	.W	22545	8978	.W	22247	9195	.W	21951	9408	.W	21659	9615	.W	21369	9818	.W	21081	10016	.W	20796	10209	.W	20514	10397	.W	20234	10581	.W	19957	10760	.W	19682	10935	.W	19410	11104	.W	19141	11270	.W	18874	11431	.W	18609	11587	.W	18347	11739	.W	18087	11886	.W	17830	12029	.W	17575	12168	.W	17323	12302	.W	17073	12432	.W	16826	12558	.W	16581	12679	.W	16338	12797	.W	16098	12910	.W	15860	13019	.W	15625	13125	.W	15391	13226	.W	15160	13323	.W	14932	13416	.W	14706	13505	.W	14482	13591	.W	14260	13672	.W	14041	13750	.W	13824	13824	.W	13609	13894	.W	13396	13960	.W	13186	14023	.W	12977	14082	.W	12771	14137	.W	12568	14189	.W	12366	14238	.W	12167	14283	.W	11969	14324	.W	11774	14362	.W	11581	14396	.W	1