	.TITLE	BEZIER2.ASC	.PROC	M680002	.REF	SMAKYBZECARTMIN =	H'10000*2	; cart minimal en Y	.LOC	0OBZP0:	.BLKB	4		; P0OBZP1:	.BLKB	4		; P1OBZP2:	.BLKB	4		; P2OBZP3:	.BLKB	4		; P3LBZ:	.LOC	0OSPP1Y:	.BLKB	4OSPP1X:	.BLKB	4OSPS1Y:	.BLKB	4OSPS1X:	.BLKB	4OSPS2Y:	.BLKB	4OSPS2X:	.BLKB	4OSPP2Y:	.BLKB	4OSPP2X:	.BLKB	4LSP:	.LOC	0OBZ:	.BLKB	LBZOCNT:	.BLKB	2LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.L	A4,#(A6)+OBZ	LOAD.L	(A4)+OBZP0,#H'10000*300+300	LOAD.L	(A4)+OBZP1,#H'10000*310+390	LOAD.L	(A4)+OBZP2,#H'10000*370+380	LOAD.L	(A4)+OBZP3,#H'10000*390+310	LOAD.B	D3,#NOCURS	LIB	?AFCAR	CALL	BZDRAW20$:	LIB	?GETCAR	COMP.W	D3,#KEYMGP	JUMP,EQ 30$	COMP.W	D3,#END	JUMP,EQ 90$25$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	20$30$:	LIB	?IFMOUSE	CALL	DETECT	JUMP,NE 25$32$:	LIB	?GETKEY	COMP.W	D3,#KEYMPO	JUMP,NE 20$	LIB	?IFMOUSE	CALL	BZDRAW	LOAD.L	(A3),D4	CALL	BZDRAW	JUMP	32$90$:	EXIT;--------\\; DETECT  >;========/; ; in	A4.L	^OBZPn;	D4.L	position de la souris; out	A3.L	^point;	D7.W; mod	D7.W, A3.LDETECT:	PUSHM.L	D1..D4	CLR.W	D7	LOAD.W	D3,D4		; D3 <-- X	SWAP.W	D4		; D4 <-- Y	LOAD.L	A3,A4	LOAD.W	D2,#420$:	LOAD.W	D1,(A3)+2	SUB.W	D1,#10	COMP.W	D3,D1	JUMP,LO 50$	ADD.W	D1,#10+10	COMP.W	D3,D1	JUMP,HS 50$	LOAD.W	D1,(A3)+0	SUB.W	D1,#10	COMP.W	D4,D1	JUMP,LO 50$	ADD.W	D1,#10+10	COMP.W	D4,D1	JUMP,LO 90$50$:	ADD.L	A3,#4	DEC.W	D2	JUMP,NE 20$	LOAD.W	D7,#190$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; BZDRAW  >;========/; ; in	A4.L	^points; out	; mod	BZDRAW:	PUSHM.L	D0..D6,A2	CLR.W	(A6)+OCNT	LOAD.L	D3,(A4)+OBZP0	CALL	BZSHOW	LOAD.L	D3,(A4)+OBZP1	CALL	BZSHOW	LOAD.L	D3,(A4)+OBZP2	CALL	BZSHOW	LOAD.L	D3,(A4)+OBZP3	CALL	BZSHOW	SUB.L	SP,#LSP	LOAD.W	D0,(A4)+OBZP0+2	SWAP.W	D0	LOAD.W	D0,#H'7FFF	LOAD.L	(SP)+OSPP1X,D0	LOAD.W	D0,(A4)+OBZP0+0	SWAP.W	D0	LOAD.W	D0,#H'7FFF	LOAD.L	(SP)+OSPP1Y,D0	LOAD.W	D0,(A4)+OBZP1+2	SWAP.W	D0	LOAD.W	D0,#H'7FFF	LOAD.L	(SP)+OSPS1X,D0	LOAD.W	D0,(A4)+OBZP1+0	SWAP.W	D0	LOAD.W	D0,#H'7FFF	LOAD.L	(SP)+OSPS1Y,D0	LOAD.W	D0,(A4)+OBZP2+2	SWAP.W	D0	LOAD.W	D0,#H'7FFF	LOAD.L	(SP)+OSPS2X,D0	LOAD.W	D0,(A4)+OBZP2+0	SWAP.W	D0	LOAD.W	D0,#H'7FFF	LOAD.L	(SP)+OSPS2Y,D0	LOAD.W	D0,(A4)+OBZP3+2	SWAP.W	D0	LOAD.W	D0,#H'7FFF	LOAD.L	(SP)+OSPP2X,D0	LOAD.W	D0,(A4)+OBZP3+0	SWAP.W	D0	LOAD.W	D0,#H'7FFF	LOAD.L	(SP)+OSPP2Y,D0	CALL	BZDEMI	POPM.L	D0..D6,A2	RET;--------\\; BZDEMI  >;--------/; ; in	(SP)++	^retour, puis P2-S2-S1-P1; out	-; mod	D0..D7,A2BZDEMI:	LOAD.L	A2,#(SP)+4	INC.W	(A6)+OCNT	COMP.W	(A6)+OCNT,#6;;?	JUMP,HS DRAW$	LOAD.L	D0,(A2)+OSPP1Y	SUB.L	D0,(A2)+OSPS1Y	JUMP',NC STOP2$	NEG.L	D0STOP2$:	COMP.L	D0,#BZECARTMIN	JUMP,HI GO$	LOAD.L	D0,(A2)+OSPS1Y	SUB.L	D0,(A2)+OSPS2Y	JUMP',NC STOP3$	NEG.L	D0STOP3$:	COMP.L	D0,#BZECARTMIN	JUMP,HI GO$	LOAD.L	D0,(A2)+OSPS2Y	SUB.L	D0,(A2)+OSPP2Y	JUMP',NC STOP4$	NEG.L	D0STOP4$:	COMP.L	D0,#BZECARTMIN	JUMP,LS DRAW$GO$:; Met sur le stack P1-S1-S2-P2 pour la premire moiti.	LOAD.L	A2,#(SP)+4	SUB.L	SP,#LSP	LOAD.L	(SP)+OSPP1Y,(A2)+OSPP1Y	LOAD.L	(SP)+OSPP1X,(A2)+OSPP1X	LOAD.L	D0,(A2)+OSPS2Y	SUB.L	D0,(A2)+OSPS1Y	ASR.L	D0,#1	ADD.L	D0,(A2)+OSPS1Y	LOAD.L	D1,(A2)+OSPS2X	SUB.L	D1,(A2)+OSPS1X	ASR.L	D1,#1	ADD.L	D1,(A2)+OSPS1X	LOAD.L	D2,(A2)+OSPS1Y	SUB.L	D2,(A2)+OSPP1Y	ASR.L	D2,#1	ADD.L	D2,(A2)+OSPP1Y	LOAD.L	D3,(A2)+OSPS1X	SUB.L	D3,(A2)+OSPP1X	ASR.L	D3,#1	ADD.L	D3,(A2)+OSPP1X	LOAD.L	(SP)+OSPS1Y,D2	LOAD.L	(SP)+OSPS1X,D3	SUB.L	D2,D0	ASR.L	D2,#1	ADD.L	D2,D0	SUB.L	D3,D1	ASR.L	D3,#1	ADD.L	D3,D1	LOAD.L	(SP)+OSPS2Y,D2	LOAD.L	(SP)+OSPS2X,D3	LOAD.L	D4,(A2)+OSPS2Y	SUB.L	D4,(A2)+OSPP2Y	ASR.L	D4,#1	ADD.L	D4,(A2)+OSPP2Y	LOAD.L	D5,(A2)+OSPS2X	SUB.L	D5,(A2)+OSPP2X	ASR.L	D5,#1	ADD.L	D5,(A2)+OSPP2X	SUB.L	D4,D0	ASR.L	D4,#1	ADD.L	D4,D0	SUB.L	D5,D1	ASR.L	D5,#1	ADD.L	D5,D1	SUB.L	D2,D4	ASR.L	D2,#1	ADD.L	D2,D4	SUB.L	D3,D5	ASR.L	D3,#1	ADD.L	D3,D5	LOAD.L	(SP)+OSPP2Y,D2	LOAD.L	(SP)+OSPP2X,D3	CALL	BZDEMI; Met sur le stack P1-S1-S2-P2 pour la deuxime moiti.	LOAD.L	A2,#(SP)+4	SUB.L	SP,#LSP	LOAD.L	(SP)+OSPP2Y,(A2)+OSPP2Y	LOAD.L	(SP)+OSPP2X,(A2)+OSPP2X	LOAD.L	D0,(A2)+OSPS1Y	SUB.L	D0,(A2)+OSPS2Y	ASR.L	D0,#1	ADD.L	D0,(A2)+OSPS2Y	LOAD.L	D1,(A2)+OSPS1X	SUB.L	D1,(A2)+OSPS2X	ASR.L	D1,#1	ADD.L	D1,(A2)+OSPS2X	LOAD.L	D2,(A2)+OSPS2Y	SUB.L	D2,(A2)+OSPP2Y	ASR.L	D2,#1	ADD.L	D2,(A2)+OSPP2Y	LOAD.L	D3,(A2)+OSPS2X	SUB.L	D3,(A2)+OSPP2X	ASR.L	D3,#1	ADD.L	D3,(A2)+OSPP2X	LOAD.L	(SP)+OSPS2Y,D2	LOAD.L	(SP)+OSPS2X,D3	SUB.L	D2,D0	ASR.L	D2,#1	ADD.L	D2,D0	SUB.L	D3,D1	ASR.L	D3,#1	ADD.L	D3,D1	LOAD.L	(SP)+OSPS1Y,D2	LOAD.L	(SP)+OSPS1X,D3	LOAD.L	D4,(A2)+OSPS1Y	SUB.L	D4,(A2)+OSPP1Y	ASR.L	D4,#1	ADD.L	D4,(A2)+OSPP1Y	LOAD.L	D5,(A2)+OSPS1X	SUB.L	D5,(A2)+OSPP1X	ASR.L	D5,#1	ADD.L	D5,(A2)+OSPP1X	SUB.L	D4,D0	ASR.L	D4,#1	ADD.L	D4,D0	SUB.L	D5,D1	ASR.L	D5,#1	ADD.L	D5,D1	SUB.L	D2,D4	ASR.L	D2,#1	ADD.L	D2,D4	SUB.L	D3,D5	ASR.L	D3,#1	ADD.L	D3,D5	LOAD.L	(SP)+OSPP1Y,D2	LOAD.L	(SP)+OSPP1X,D3	CALL	BZDEMI	DEC.W	(A6)+OCNT	POP.L	A2	ADD.L	SP,#LSP	JUMP	(A2)DRAW$:	LOAD.W	D2,(A2)+OSPP1Y+0	COMP.W	(A2)+OSPP1Y+2,#H'7FFF	JUMP',LS DRAW2$	INC.W	D2DRAW2$:	SWAP.W	D2	LOAD.W	D2,(A2)+OSPP1X+0	COMP.W	(A2)+OSPP1X+2,#H'7FFF	JUMP',LS DRAW3$	INC.W	D2DRAW3$:	LOAD.W	D3,(A2)+OSPP2Y+0	COMP.W	(A2)+OSPP2Y+2,#H'7FFF	JUMP',LS DRAW4$	INC.W	D3DRAW4$:	SWAP.W	D3	LOAD.W	D3,(A2)+OSPP2X+0	COMP.W	(A2)+OSPP2X+2,#H'7FFF	JUMP',LS DRAW5$	INC.W	D3DRAW5$:	CALL	BZLINE	DEC.W	(A6)+OCNT	POP.L	A2	ADD.L	SP,#LSP	JUMP	(A2);--------\\; BZDOT   >;--------/; ; in	D4.L	P' (y;x); out	-; mod	D7.WBZDOT:	PUSHM.L	D2..D4	LOAD.L	D3,D4	LOAD.L	D4,#H'10000*1+1	LOAD.W	D2,#INVDOT	LIB	?DRSEG	POPM.L	D2..D4	RET;--------\\; BZSHOW  >;========/; ; in	D3.L	; out	-; mod	D7.WBZSHOW:	PUSHM.L	D2..D4	LOAD.W	D2,#INVDOT	SUB.W	D3,#2	LOAD.L	D4,#H'10000*0+5	LIB	?DRSEG	SUB.W	D3,#3	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LOAD.L	D4,#H'10000*5+0	LIB	?DRSEG	POPM.L	D2..D4	RET;--------\\; BZLINE  >;========/; ; in	D2.L	;	D3.L	; out	-; mod	D7.WBZLINE:	PUSHM.L	D2..D4	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	LOAD.L	D4,D3	LOAD.L	D3,D2;;?LOAD.L D4,#H'10000*1+1	LOAD.W	D2,#INVDOT;;?LOAD.W D2,#SETDOT	LIB	?DRSEG	POPM.L	D2..D4	RETVAR:	.FILLB	LGVAR,0	.END	START