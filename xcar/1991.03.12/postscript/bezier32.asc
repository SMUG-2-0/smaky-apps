	.TITLE	BEZIER32.ASC	.PROC	M680002	.REF	SMAKY	.LOC	0OBZP0:	.BLKB	4		; P0OBZP1:	.BLKB	4		; P1OBZP2:	.BLKB	4		; P2OBZP3:	.BLKB	4		; P3LBZ:	.LOC	0OBZ:	.BLKB	LBZOMODE:	.BLKB	2LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.L	A4,#(A6)+OBZ	LOAD.L	(A4)+OBZP0,#H'10000*100+100	LOAD.L	(A4)+OBZP1,#H'10000*300+600	LOAD.L	(A4)+OBZP2,#H'10000*600+700	LOAD.L	(A4)+OBZP3,#H'10000*800+100	LOAD.B	D3,#NOCURS	LIB	?AFCAR	LOAD.W	(A6)+OMODE,#INVDOT	CALL	BZDRAW20$:	LIB	?GETCAR	COMP.W	D3,#KEYMGP	JUMP,EQ 30$	COMP.W	D3,#END	JUMP,EQ 90$	COMP.W	D3,#SPACE	JUMP,EQ 50$25$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	20$30$:	LIB	?IFMOUSE	CALL	DETECT	JUMP,NE 25$32$:	LIB	?GETKEY	COMP.W	D3,#KEYMPO	JUMP,NE 20$	LIB	?IFMOUSE	CALL	BZDRAW	LOAD.L	(A3),D4	CALL	BZDRAW	JUMP	32$50$:	LOAD.W	(A6)+OMODE,#SETDOT	CALL	BZDRAW	LIB	?GETCAR	LOAD.B	D3,#EOP	LIB	?AFCAR	LOAD.W	(A6)+OMODE,#INVDOT	CALL	BZDRAW	JUMP	20$90$:	EXIT;--------\\; DETECT  >;========/; ; in	A4.L	^OBZPn;	D4.L	position de la souris; out	A3.L	^point;	D7.W; mod	D7.W, A3.LDETECT:	PUSHM.L	D1..D4	CLR.W	D7	LOAD.W	D3,D4		; D3 <-- X	SWAP.W	D4		; D4 <-- Y	LOAD.L	A3,A4	LOAD.W	D2,#420$:	LOAD.W	D1,(A3)+2	SUB.W	D1,#10	COMP.W	D3,D1	JUMP,LO 50$	ADD.W	D1,#10+10	COMP.W	D3,D1	JUMP,HS 50$	LOAD.W	D1,(A3)+0	SUB.W	D1,#10	COMP.W	D4,D1	JUMP,LO 50$	ADD.W	D1,#10+10	COMP.W	D4,D1	JUMP,LO 90$50$:	ADD.L	A3,#4	DEC.W	D2	JUMP,NE 20$	LOAD.W	D7,#190$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; BZDRAW  >;========/; ; in	A4.L	^OBZPn; out	; mod	BZDRAW:	PUSHM.L	D0..D6	LIB	?BUCAR	LOAD.L	D3,(A4)+OBZP0	CALL	BZSHOW	LOAD.L	D3,(A4)+OBZP1	CALL	BZSHOW	LOAD.L	D3,(A4)+OBZP2	CALL	BZSHOW	LOAD.L	D3,(A4)+OBZP3	CALL	BZSHOW	LOAD.W	D3,(A4)+OBZP0+2	SUB.W	D3,(A4)+OBZP1+2	JUMP',NC POS1$	NEG.W	D3POS1$:	LOAD.W	D2,D3	LOAD.W	D3,(A4)+OBZP0+0	SUB.W	D3,(A4)+OBZP1+0	JUMP',NC POS2$	NEG.W	D3POS2$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP1+2	SUB.W	D3,(A4)+OBZP2+2	JUMP',NC POS3$	NEG.W	D3POS3$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP1+0	SUB.W	D3,(A4)+OBZP2+0	JUMP',NC POS4$	NEG.W	D3POS4$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP2+2	SUB.W	D3,(A4)+OBZP3+2	JUMP',NC POS5$	NEG.W	D3POS5$:	ADD.W	D2,D3	LOAD.W	D3,(A4)+OBZP2+0	SUB.W	D3,(A4)+OBZP3+0	JUMP',NC POS6$	NEG.W	D3POS6$:	ADD.W	D2,D3	LOAD.W	D1,#1	COMP.W	D2,#160	JUMP',HS STEP$	LOAD.W	D1,#2	COMP.W	D2,#80	JUMP',HS STEP$	LOAD.W	D1,#4	COMP.W	D2,#40	JUMP',HS STEP$	LOAD.W	D1,#8	COMP.W	D2,#20	JUMP',HS STEP$	LOAD.W	D1,#16	COMP.W	D2,#10	JUMP',HS STEP$	LOAD.W	D1,#32	COMP.W	D2,#5	JUMP',HS STEP$	LOAD.W	D1,#64STEP$:	LOAD.W	D0,#6	COMP.W	D2,#640	JUMP',HS PROX$	LOAD.W	D0,#5	COMP.W	D2,#320	JUMP',HS PROX$	LOAD.W	D0,#4	COMP.W	D2,#160	JUMP',HS PROX$	LOAD.W	D0,#3	COMP.W	D2,#80	JUMP',HS PROX$	LOAD.W	D0,#2	COMP.W	D2,#40	JUMP',HS PROX$	LOAD.W	D0,#1PROX$:	CLR.W	D4	LOAD.L	D2,(A4)+OBZP0load.w d0,#0load.w d1,#1LOOP$:	CALL	BZPOINT		; D3 <-- point;;?jump okline$	LOAD.W	D5,D4	ADD.W	D5,D1	COMP.W	D5,#256	JUMP,HI OKLINE$	LOAD.W	D5,D2	SUB.W	D5,D3	JUMP',NC PLUSX$	NEG.W	D5		; D5 <-- |dx|PLUSX$:	SWAP.W	D2	SWAP.W	D3	LOAD.W	D6,D2	SUB.W	D6,D3	JUMP',NC PLUSY$	NEG.W	D6		; D6 <-- |dy|PLUSY$:	SWAP.W	D2	SWAP.W	D3	COMP.W	D5,D0	JUMP,HS OKLINE$	COMP.W	D6,D0	JUMP,LO NOLINE$OKLINE$:	CALL	BZLINE	LOAD.L	D2,D3NOLINE$:	ADD.W	D4,D1	COMP.W	D4,#256	JUMP,LS LOOP$	LIB	?NOBUCAR	POPM.L	D0..D6	RET;--------\\; BZSHOW  >;========/; ; in	D3.L	; out	-; mod	D7.WBZSHOW:	PUSHM.L	D2..D4	LOAD.W	D2,(A6)+OMODE	SUB.W	D3,#2	LOAD.L	D4,#H'10000*0+5	LIB	?DRSEG	SUB.W	D3,#3	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LOAD.L	D4,#H'10000*5+0	LIB	?DRSEG	POPM.L	D2..D4	RET;--------\\; BZLINE  >;========/; ; in	D2.L	dpart  (y;x);	D3.L	arrive (y;x); out	-; mod	D7.WBZLINE:	PUSHM.L	D2..D4	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	LOAD.L	D4,D3;;?  load.l d4,#H'10000*1+1	LOAD.L	D3,D2	LOAD.W	D2,(A6)+OMODE	LIB	?DRSEG	POPM.L	D2..D4	RET;--------\\; BZPOINT >;========/; ; in	A4.L	^OBZPn;	D4.W	position (0..256); out	D3.L	point (y;x); mod	D3.LBZPOINT:	PUSHM.L	D0..D2,D4..D6,A2,A3	LOAD.L	A3,#R16"TABLE$	LOAD.L	A2,A3	LOAD.W	D3,#256	SUB.W	D3,D4	SL.W	D4,#3	SL.W	D3,#3	ADD.W	A3,D4	ADD.W	A2,D3	CLR.L	D2	LOAD.W	D2,(A4)+OBZP0+0	SL.L	D2,#8	LOAD.B	D2,#H'80	LOAD.L	D3,(A3)+0	CALL	MUL32	LOAD.L	D4,D0	LOAD.L	D5,D1	CLR.L	D2	LOAD.W	D2,(A4)+OBZP1+0	SL.L	D2,#8	LOAD.B	D2,#H'80	LOAD.L	D3,(A3)+4	CALL	MUL32	ADD.L	D4,D0	ADDX.L	D5,D1	CLR.L	D2	LOAD.W	D2,(A4)+OBZP2+0	SL.L	D2,#8	LOAD.B	D2,#H'80	LOAD.L	D3,(A2)+4	CALL	MUL32	ADD.L	D4,D0	ADDX.L	D5,D1	CLR.L	D2	LOAD.W	D2,(A4)+OBZP3+0	SL.L	D2,#8	LOAD.B	D2,#H'80	LOAD.L	D3,(A2)+0	CALL	MUL32	ADD.L	D4,D0	ADDX.L	D5,D1	COMP.L	D4,#H'80000000	JUMP',LO 20$	INC.W	D520$:	LOAD.W	D6,D5	CLR.L	D2	LOAD.W	D2,(A4)+OBZP0+2	SL.L	D2,#8	LOAD.B	D2,#H'80	LOAD.L	D3,(A3)+0	CALL	MUL32	LOAD.L	D4,D0	LOAD.L	D5,D1	CLR.L	D2	LOAD.W	D2,(A4)+OBZP1+2	SL.L	D2,#8	LOAD.B	D2,#H'80	LOAD.L	D3,(A3)+4	CALL	MUL32	ADD.L	D4,D0	ADDX.L	D5,D1	CLR.L	D2	LOAD.W	D2,(A4)+OBZP2+2	SL.L	D2,#8	LOAD.B	D2,#H'80	LOAD.L	D3,(A2)+4	CALL	MUL32	ADD.L	D4,D0	ADDX.L	D5,D1	CLR.L	D2	LOAD.W	D2,(A4)+OBZP3+2	SL.L	D2,#8	LOAD.B	D2,#H'80	LOAD.L	D3,(A2)+0	CALL	MUL32	ADD.L	D4,D0	ADDX.L	D5,D1	COMP.L	D4,#H'80000000	JUMP',LO 40$	INC.W	D540$:	LOAD.W	D3,D6	SWAP.W	D3	LOAD.W	D3,D5	POPM.L	D0..D2,D4..D6,A2,A3	RETTABLE$:	.L	16777215,0	.L	16581374,195075	.L	16387063,387096	.L	16194276,576081	.L	16003007,762048	.L	15813250,945015	.L	15624999,1125000	.L	15438248,1302021	.L	15252991,1476096	.L	15069222,1647243	.L	14886935,1815480	.L	14706124,1980825	.L	14526783,2143296	.L	14348906,2302911	.L	14172487,2459688	.L	13997520,2613645	.L	13823999,2764800	.L	13651918,2913171	.L	13481271,3058776	.L	13312052,3201633	.L	13144255,3341760	.L	12977874,3479175	.L	12812903,3613896	.L	12649336,3745941	.L	12487167,3875328	.L	12326390,4002075	.L	12166999,4126200	.L	12008988,4247721	.L	11852351,4366656	.L	11697082,4483023	.L	11543175,4596840	.L	11390624,4708125	.L	11239423,4816896	.L	11089566,4923171	.L	10941047,5026968	.L	10793860,5128305	.L	10647999,5227200	.L	10503458,5323671	.L	10360231,5417736	.L	10218312,5509413	.L	10077695,5598720	.L	9938374,5685675	.L	9800343,5770296	.L	9663596,5852601	.L	9528127,5932608	.L	9393930,6010335	.L	9260999,6085800	.L	9129328,6159021	.L	8998911,6230016	.L	8869742,6298803	.L	8741815,6365400	.L	8615124,6429825	.L	8489663,6492096	.L	8365427,6552231	.L	8242408,6610248	.L	8120601,6666165	.L	8000000,6720000	.L	7880599,6771771	.L	7762392,6821496	.L	7645373,6869193	.L	7529536,6914880	.L	7414875,6958575	.L	7301384,7000296	.L	7189057,7040061	.L	7077888,7077888	.L	6967871,7113795	.L	6859000,7147800	.L	6751269,7179921	.L	6644672,7210176	.L	6539203,7238583	.L	6434856,7265160	.L	6331625,7289925	.L	6229504,7312896	.L	6128487,7334091	.L	6028568,7353528	.L	5929741,7371225	.L	5832000,7387200	.L	5735339,7401471	.L	5639752,7414056	.L	5545233,7424973	.L	5451776,7434240	.L	5359375,7441875	.L	5268024,7447896	.L	5177717,7452321	.L	5088448,7455168	.L	5000211,7456455	.L	4913000,7456200	.L	4826809,7454421	.L	4741632,7451136	.L	4657463,7446363	.L	4574296,7440120	.L	4492125,7432425	.L	4410944,7423296	.L	4330747,7412751	.L	4251528,7400808	.L	4173281,7387485	.L	4096000,7372800	.L	4019679,7356771	.L	3944312,7339416	.L	3869893,7320753	.L	3796416,7300800	.L	3723875,7279575	.L	3652264,7257096	.L	3581577,7233381	.L	3511808,7208448	.L	3442951,7182315	.L	3375000,7155000	.L	3307949,7126521	.L	3241792,7096896	.L	3176523,7066143	.L	3112136,7034280	.L	3048625,7001325	.L	2985984,6967296	.L	2924207,6932211	.L	2863288,6896088	.L	2803221,6858945	.L	2744000,6820800	.L	2685619,6781671	.L	2628072,6741576	.L	2571353,6700533	.L	2515456,6658560	.L	2460375,6615675	.L	2406104,6571896	.L	2352637,6527241	.L	2299968,6481728	.L	2248091,6435375	.L	2197000,6388200	.L	2146689,6340221	.L	2097152,6291456	.L	2048383,6241923	.L	2000376,6191640	.L	1953125,6140625	.L	1906624,6088896	.L	1860867,6036471	.L	1815848,5983368	.L	1771561,5929605	.L	1728000,5875200	.L	1685159,5820171	.L	1643032,5764536	.L	1601613,5708313	.L	1560896,5651520	.L	1520875,5594175	.L	1481544,5536296	.L	1442897,5477901	.L	1404928,5419008	.L	1367631,5359635	.L	1331000,5299800	.L	1295029,5239521	.L	1259712,5178816	.L	1225043,5117703	.L	1191016,5056200	.L	1157625,4994325	.L	1124864,4932096	.L	1092727,4869531	.L	1061208,4806648	.L	1030301,4743465	.L	1000000,4680000	.L	970299,4616271	.L	941192,4552296	.L	912673,4488093	.L	884736,4423680	.L	857375,4359075	.L	830584,4294296	.L	804357,4229361	.L	778688,4164288	.L	753571,4099095	.L	729000,4033800	.L	704969,3968421	.L	681472,3902976	.L	658503,3837483	.L	636056,3771960	.L	614125,3706425	.L	592704,3640896	.L	571787,3575391	.L	551368,3509928	.L	531441,3444525	.L	512000,3379200	.L	493039,3313971	.L	474552,3248856	.L	456533,3183873	.L	438976,3119040	.L	421875,3054375	.L	405224,2989896	.L	389017,2925621	.L	373248,2861568	.L	357911,2797755	.L	343000,2734200	.L	328509,2670921	.L	314432,2607936	.L	300763,2545263	.L	287496,2482920	.L	274625,2420925	.L	262144,2359296	.L	250047,2298051	.L	238328,2237208	.L	226981,2176785	.L	216000,2116800	.L	205379,2057271	.L	195112,1998216	.L	185193,1939653	.L	175616,1881600	.L	166375,1824075	.L	157464,1767096	.L	148877,1710681	.L	140608,1654848	.L	132651,1599615	.L	125000,1545000	.L	117649,1491021	.L	110592,1437696	.L	103823,1385043	.L	97336,1333080	.L	91125,1281825	.L	85184,1231296	.L	79507,1181511	.L	74088,1132488	.L	68921,1084245	.L	64000,1036800	.L	59319,990171	.L	54872,944376	.L	50653,899433	.L	46656,855360	.L	42875,812175	.L	39304,769896	.L	35937,728541	.L	32768,688128	.L	29791,648675	.L	27000,610200	.L	24389,572721	.L	21952,536256	.L	19683,500823	.L	17576,466440	.L	15625,433125	.L	13824,400896	.L	12167,369771	.L	10648,339768	.L	9261,310905	.L	8000,283200	.L	6859,256671	.L	5832,231336	.L	4913,207213	.L	4096,184320	.L	3375,162675	.L	2744,142296	.L	2197,123201	.L	1728,105408	.L	1331,88935	.L	1000,73800	.L	729,60021	.L	512,47616	.L	343,36603	.L	216,27000	.L	125,18825	.L	64,12096	.L	27,6831	.L	8,3048	.L	1,765	.L	0,0;------\\; MUL32 >;======/; Module de multiplication 32*32 --> 64 bits (non-sign).;	-------------------;	 D1&D0 <-- D2 * D3;	-------------------; in	D2.L	multiplicande (32 bits non-sign);	D3.L	multiplicateur (32 bits non-sign); out	D1&D0.L	rsultat (64 bits non-sign); mod	D0.L, D1.LMUL32:	PUSHM.L D4,D5	LOAD.W	D0,D3	MUL.WU	D0,D2		; D0 low longword <-- low word * low word	SWAP.W	D2	LOAD.W	D5,D3		; D5 mid longword <-- high word * low word	MUL.WU	D5,D2	SWAP.W	D3	LOAD.W	D1,D3		; D1 high long <-- high word * high word	MUL.WU	D1,D2	SWAP.W	D2	LOAD.W	D4,D3		; D4 mid long <-- high word * low word	MUL.WU	D4,D2	SWAP.W	D3	SWAP.W	D1	ADD.L	D4,D5		; ADD.L D4,D5 avec report sur D1 si ncessessaire	CLR.W	D5	ADDX.W	D1,D5	SWAP.W	D1	ADDX.W	D1,D5	LOAD.W	D5,D1		; ADD.64 D1&D0,D4*(2^16)	SWAP.W	D5	SWAP.W	D0	LOAD.W	D5,D0	ADD.L	D5,D4	LOAD.W	D0,D5	SWAP.W	D0	SWAP.W	D5	LOAD.W	D1,D5	SWAP.W	D1	CLR.L	D5	ADDX.L	D1,D5	SWAP.W	D1	POPM.L	D4,D5	RET;------\\; DIV32 >;======/; Module de division 64/32 --> 32 bits (non-sign).;	-------------------;	 D3 <-- D1&D0 / D2;	 D4 <-- reste;	-------------------; ATTENTION: pas de test de division par zro !; in	D1&D0.L	numrateur (64 bits non-sign);	D2.L	dnominateur (32 bits non-sign); out	D3.L	rsultat (32 bits non-sign);	D4.L	reste (32 bits non-sign);	VS	overflow; mod	D3.L, D4.LDIV32:	PUSHM.L D0,D1	LOAD.W	D4,#32-1	; D4 <-- dcompteur de bouclesLOOP$:	SETX	RLX.L	D0	RLX.L	D1	JUMP',CS ERROR$	SUB.L	D1,D2	JUMP',HS NEXT$	ADD.L	D1,D2	TCLR.L	D0:#0		; bit 0 si rtablissementNEXT$:	DECJ.W,NMO D4,LOOP$	COMP.L	D1,D2		; reste >= diviseur ?	JUMP',HS ERROR$	LOAD.L	D3,D0		; D3 <-- quotient	LOAD.L	D4,D1		; D4 <-- reste,	 F <-- V=0	JUMP'	EXIT$ERROR$:	SETV			; F <-- V=1EXIT$:	POPM.L	D0,D1	RETVAR:	.FILLB	LGVAR,0	.END	START