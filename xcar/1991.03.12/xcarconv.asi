	.SBTTL	XCARCONV.ASI;--------\\; DECODE  >;========/; Cre une nouvelle liste avec les objets d'un caractre.; in	D3.W	code du caractre;	A3.L	^gencar; out	D7.W	erreur; mod	D7.WDECODE:	PUSHM.L	D1..D6	TEST.L	(A6)+OLSTC1	JUMP',EQ FREE$	LOAD.L	D6,(A6)+OLSTC1	CALL	_OBJ_LCLOSE	; ferme la vieille liste	CLR.L	(A6)+OLSTC1FREE$:	PUSH.L	D3	CLR.L	D3		; D3 <-- mode	CLR.W	D4		; D4 <-- lg standard	CALL	_OBJ_LOPEN	; ouvre une nouvelle liste	POPM.L	D3	JUMP',NE EXIT$	LOAD.L	(A6)+OLSTC1,D6	COMP.B	(A6)+OVISU,#ICOVCONS	JUMP',EQ NOCAR$	LOAD.L	(A6)+OLSTCH,D6NOCAR$:	PUSH.L	(A6)+OLSTCH	LOAD.L	(A6)+OLSTCH,(A6)+OLSTC1	CLR.W	D2		; D2 <-- tous les objets	CALL	DECODEADD	; liste <-- tous les objets	POP.L	(A6)+OLSTCHEXIT$:	POPM.L	D1..D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; DECODEADD >;==========/; Ajoute tous les objets d'un caractre  la liste courante.; in	D2.W	mode (1 => ignore les FILLx);	D3.W	code du caractre;	A3.L	^gencar; out	D1.W	nb d'objets crs;	D7.W	erreur; mod	D1.L, D7.WDECODEADD:	PUSHM.L	D3..D6,A3..A5	CLR.W	D1		; D1 <-- nb d'objets crs	TEST.L	(A6)+OLSTCH	JUMP,EQ END$	LOAD.L	D6,(A6)+OLSTCH	LOAD.W	D4,D3	SL.W	D4,#2	LOAD.L	A5,#(A3)+oxcPCHAR	LOAD.L	D4,(A5)+(D4.W)	LOAD.L	A5,#(A3)+(D4.L)	; A5 <-- ^description du caractre	CLR.W	(A6)+OLPEN	COMP.W	D2,#1	JUMP',EQ LOOP$	CLR.L	(A6)+OINFOLOOP$:	LOAD.B	D3,(A5+)	INC.L	A5	COMP.B	D3,#xcOPBEGIN	JUMP,EQ BEGIN$	COMP.B	D3,#xcOPLINE	JUMP,EQ LINE$	COMP.B	D3,#xcOPCURVE	JUMP,EQ CURVE$	COMP.B	D3,#xcOPADDCHAR	JUMP,EQ ADDCHAR$	COMP.B	D3,#xcOPFILLI	JUMP,EQ FILLI$	COMP.B	D3,#xcOPFILLA	JUMP,EQ FILLA$	COMP.B	D3,#xcOPPEN	JUMP,EQ PEN$	JUMP	END$BEGIN$:	CALL	DECOGETPR	; D3/D4 <-- PP/RP (y;x)	LOAD.L	(A6)+OLPOS,D3	LOAD.L	(A6)+ORPOS,D4	JUMP	LOOP$LINE$:	CALL	DECOGETPR	; D3/D4 <-- PP/RP (y;x)	COMP.L	D3,(A6)+OLPOS	; droite de longueur nulle ?	JUMP,EQ LOOP$		; oui => LOOP$	PUSH.L	D4	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	_OBJ_LINSERT	; cre un nouvel objet	POPM.L	D4	JUMP,NE EXIT$	LOAD.W	(A4)+OOBTYP,#xcOPLINE	LOAD.W	(A4)+OOBPEN,(A6)+OLPEN	LOAD.L	(A4)+OOBPP1,(A6)+OLPOS	LOAD.L	(A4)+OOBRP1,(A6)+ORPOS	LOAD.L	(A4)+OOBPP2,D3	LOAD.L	(A4)+OOBRP2,D4	LOAD.L	(A4)+OOBPS1,D3	LOAD.L	(A4)+OOBRS1,D4	LOAD.L	(A4)+OOBPS2,D3	LOAD.L	(A4)+OOBRS2,D4	LOAD.L	(A6)+OLPOS,D3	LOAD.L	(A6)+ORPOS,D4	INC.W	D1		; D1 <-- un objet cr de plus	JUMP	LOOP$CURVE$:	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	_OBJ_LINSERT	; cre un nouvel objet	JUMP,NE EXIT$	LOAD.W	(A4)+OOBTYP,#xcOPCURVE	LOAD.W	(A4)+OOBPEN,(A6)+OLPEN	LOAD.L	(A4)+OOBPP1,(A6)+OLPOS	LOAD.L	(A4)+OOBRP1,(A6)+ORPOS	CALL	DECOGETPR	; D3/D4 <-- PP/RP (y;x)	LOAD.L	(A4)+OOBPS1,D3	LOAD.L	(A4)+OOBRS1,D4	CALL	DECOGETPR	; D3/D4 <-- PP/RP (y;x)	LOAD.L	(A4)+OOBPS2,D3	LOAD.L	(A4)+OOBRS2,D4	CALL	DECOGETPR	; D3/D4 <-- PP/RP (y;x)	LOAD.L	(A4)+OOBPP2,D3	LOAD.L	(A4)+OOBRP2,D4	LOAD.L	(A6)+OLPOS,(A4)+OOBPP2	LOAD.L	(A6)+ORPOS,(A4)+OOBRP2	INC.W	D1		; D1 <-- un objet cr de plus	JUMP	LOOP$ADDCHAR$:	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	_OBJ_LINSERT	; cre un nouvel objet	JUMP,NE EXIT$	LOAD.W	(A4)+OOBTYP,#xcOPADDCHAR	LOAD.L	(A4)+OOBPP1,(A5+) ; OOBPP1.L <-- dplacement	LOAD.B	(A4)+OOBPP2,(A5+) ; OOBPP2.B <-- caractre	INC.L	A5	INC.W	D1		; D1 <-- un objet cr de plus	JUMP	LOOP$FILLI$:	COMP.W	D2,#1	JUMP,EQ LOOP$	TSET.B	(A6)+OINFO+3:#BINFILLI-0	JUMP	LOOP$FILLA$:	COMP.W	D2,#1	JUMP,EQ LOOP$	TSET.B	(A6)+OINFO+3:#BINFILLA-0	JUMP	LOOP$PEN$:	LOAD.W	(A6)+OLPEN,(A5+) ; OLPEN <-- diamtre du pinceau	JUMP	LOOP$END$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3..D6,A3..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DECOGETPR >;----------/; Cherche une coordonne absolue avec sa coordonne relative.; in	A5.L	^buffer; out	A5.L	^plus loin;	D3.L	PP (y;x);	D4.L	RP (y;x); mod	D3.L, D4.L, D7.W, A5.LDECOGETPR:	CALL'	DECOGETPRONE	; D3/D4 <-- y	SWAP.W	D3	SWAP.W	D4;	CALL'	DECOGETPRONE	; D3/D4 <-- x;	RET;-------------\\; DECOGETPRONE >;-------------/; Nombre dans le buffer cod :;	00xxx	-->	+ position;	11xxx	-->	- position;	10xxx	-->	+ distance;	01xxx	-->	- distance; in	A5.L	^buffer; out	A5.L	^plus loin;	D3.W	PP (y ou x);	D4.W	RP (y ou x); mod	D3.W, D4.W, D7.W, A5.LDECOGETPRONE:	PUSHM.L	D1,D2	CLR.W	D4		; D4 <-- RP inexistant	LOAD.W	D3,(A5+)	LOAD.W	D1,D3	RL.W	D1,#1	XOR.W	D1,D3		; nombre relatif ?	JUMP',NC 90$		; non => 90$	TNOT.L	D3:#15	LOAD.W	D4,D3		; D4 <-- delta initial30$:	LOAD.W	D2,(A5+)	LOAD.W	D1,D2	RL.W	D1,#1	XOR.W	D1,D2		; nombre relatif ?	JUMP',NC 40$		; non => 40$	TNOT.L	D2:#15	ADD.W	D3,D2		; D3 <-- somme des deltas	JUMP	30$40$:	ADD.W	D3,D2		; D3 <-- somme des deltas	SUB.W	D4,D3	NEG.W	D4		; D4 <-- somme des deltas sans le premier	TSET.L	D4:#15		; D4 <-- RP toujours "relatif"90$:	POPM.L	D1,D2	RET;--------------\\; DECODEADDCHAS >;==============/; Met la chasse d'un autre caractre.; in	D3.W	code du caractre;	A3.L	^gencar; out	-; mod	D7.WDECODEADDCHAS:	PUSHM.L	D3,D4,A3	SL.W	D3,#1	LOAD.L	A3,#(A3)+oxcLENGTH	LOAD.W	D4,(A3)+(D3.W)	; D4 <-- chasse source	TEST.L	(A6)+OXCPGC	JUMP',EQ 90$	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D3,(A6)+OXCCAR	; D3 <-- caractre	SL.W	D3,#1	LOAD.L	A3,#(A3)+oxcLENGTH	LOAD.W	(A3)+(D3.W),D490$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; RECODE  >;========/; Recode le caractre en dition.; in	-; out	D7.W	erreur; mod	D7.WRECODE:	PUSHM.L	D1..D5,A3..A5	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D3,(A6)+OXCCAA	; D3 <-- caractre	CALL	RELGOLD		; D4 <-- longueur actuellement utilise	LOAD.L	D5,D4		; D5 <-- ancienne longueur	LOAD.L	A3,#(A6)+OBUBIG	CALL	REPUTOBS	; D4 <-- nouvelle longueur	CALL	REAJDIM		; ajuste les dimensions	JUMP',NE 90$	LOAD.L	A4,(A6)+OXCPGC	; A4 <-- ^en-tte gencar	ADD.L	A4,#256		; A4 <-- ^gencar	LOAD.W	D5,D3	SL.W	D5,#2	LOAD.L	A5,#(A4)+oxcPCHAR	LOAD.L	D5,(A5)+(D5.W)	LOAD.L	A5,#(A4)+(D5.L)	; A5 <-- ^description du caractre	SR.L	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMO40$:	LOAD.W	(A5+),(A3+)	DECJ.W,NMO D4,40$	LOAD.W	D3,(A6)+OXCCAA	; D3 <-- caractre	CALL	MINMAXONE	; initialise la "bounding box"	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D5,A3..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; REAJDIM >;--------/; ; in	D3.W	code du caractre;	D4.L	nouvelle lg;	D5.L	ancienne lg; out	D7.W	erreur; mod	D7.WREAJDIM:	PUSHM.L	D0..D4,A2..A4	LOAD.W	D2,D3	LOAD.L	A3,(A6)+OXCPGC	LOAD.L	D3,(A3)+OBXLG	ADD.L	D3,#256	ADD.L	D3,D4	SUB.L	D3,D5		; D3 <-- nouvelle longueur	EX.L	D3,D4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour nouveau gencar	JUMP,NE 90$	EX.L	D4,D3	ADD.L	A3,#256	LOAD.W	D1,D2	SL.W	D1,#2	LOAD.L	A2,#(A3)+oxcPCHAR	LOAD.L	D1,(A2)+(D1.W)	LOAD.L	A2,#(A3)+(D1.L)	; A2 <-- ^description du caractre	SUB.L	A3,#256	PUSHM.L	A3,A4	LOAD.L	D1,A2	SUB.L	D1,A3	LOAD.L	D0,D3	SUB.L	D0,D1	SUB.L	D0,D4	SR.L	D1,#1		; D1 <-- /2 car .W	DEC.W	D1		; D1 <-- -1 car NMO	JUMP',NS 31$30$:	LOAD.W	(A4+),(A3+)	DECJ.W,NMO D1,30$31$:	ADD.W	A3,D5	ADD.W	A4,D4	SR.L	D0,#1		; D0 <-- /2 car .W	DEC.W	D0		; D0 <-- -1 car NMO	JUMP',NS 36$35$:	LOAD.W	(A4+),(A3+)	DECJ.W,NMO D0,35$36$:	POPM.L	A3,A4	LOAD.W	D1,D2	INC.W	D1	SL.W	D1,#2	LOAD.L	A2,#(A4)+256+oxcPCHAR	ADD.W	A2,D1	LOAD.W	D1,#xcNBCAR-1-1	SUB.W	D1,D2	JUMP',NS 42$	LOAD.L	D0,D4	SUB.L	D0,D540$:	ADD.L	(A2+),D0	; ajuste les ^aux caractres suivants	DECJ.W,NMO D1,40$42$:	SUB.L	D3,#256	LOAD.L	(A4)+OBXLG,D3	LOAD.L	(A6)+OXCPGC,A4	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancien gencar	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RELGOLD >;--------/; Cherche la longueur utilise pour un caractre.; in	D3.W	code du caractre;	A3.L	^gencar; out	D4.L	lg; mod	D4.L, D7.WRELGOLD:	PUSHM.L	D2,D3,A4,A5	LOAD.W	D4,D3	SL.W	D4,#2	LOAD.L	A5,#(A3)+oxcPCHAR	LOAD.L	D4,(A5)+(D4.W)	LOAD.L	A5,#(A3)+(D4.L)	; A5 <-- ^description du caractre	LOAD.L	A4,A5LOOP$:	LOAD.B	D3,(A5+)	INC.L	A5	LOAD.W	D4,#2*1	COMP.B	D3,#xcOPBEGIN	JUMP',EQ REL$;	LOAD.W	D4,#2*1	COMP.B	D3,#xcOPLINE	JUMP',EQ REL$	LOAD.W	D4,#2*3	COMP.B	D3,#xcOPCURVE	JUMP',EQ REL$	LOAD.W	D4,#4+2	COMP.B	D3,#xcOPADDCHAR	JUMP',EQ NEXT$	COMP.B	D3,#xcOPFILLI	JUMP',EQ LOOP$	COMP.B	D3,#xcOPFILLA	JUMP',EQ LOOP$	LOAD.W	D4,#2	COMP.B	D3,#xcOPPEN	JUMP',EQ NEXT$	JUMP'	END$REL$:	LOAD.W	D3,(A5+)	LOAD.W	D2,D3	RL.W	D2,#1	XOR.W	D2,D3		; nombre relatif ?	JUMP,NS REL$		; oui => REL$	DEC.W	D4	JUMP,NE REL$	JUMP	LOOP$NEXT$:	ADD.W	A5,D4	JUMP	LOOP$END$:	LOAD.L	D4,A5	SUB.L	D4,A4		; D4 <-- lg	POPM.L	D2,D3,A4,A5	RET;---------\\; REPUTOBS >;---------/; Recode tous les objets du caractre en dition.; Nombre dans le buffer cod :;	00xxx	-->	+ position;	11xxx	-->	- position;	10xxx	-->	+ distance;	01xxx	-->	- distance; in	A3.L	^buffer pour objets compresss; out	D4.L	lg ncessaire; mod	D4.L, D7.WREPUTOBS:	PUSHM.L	D3,D6,A2..A4	LOAD.L	A2,A3	LOAD.L	D6,(A6)+OLSTC1	; D6 <-- canal de la liste	JUMP,EQ END$	TEST.B	(A6)+OINFO+3:#BINFILLI-0	JUMP',BC FILLI$	LOAD.B	(A3+),#xcOPFILLI	CLR.B	(A3+)FILLI$:	TEST.B	(A6)+OINFO+3:#BINFILLA-0	JUMP',BC FILLA$	LOAD.B	(A3+),#xcOPFILLA	CLR.B	(A3+)FILLA$:	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE END$SPEC$:	CALL	REPUTOBX	; buffer <-- objet spcial	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ SPEC$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE END$	CLR.W	(A6)+OLPENLOOP$:	COMP.W	(A4)+OOBTYP,#-1	JUMP',EQ NEXT$	COMP.W	(A4)+OOBTYP,#-2	JUMP',EQ NEXT$	PUSH.L	A4	LOAD.B	(A3+),#xcOPBEGIN	CLR.B	(A3+)	CALL	REPUTPP1	LOAD.L	D3,(A4)+OOBPP1	; D3 <-- point initialCONT$:	COMP.L	D3,(A4)+OOBPP1	JUMP',EQ CONT2$	CALL	REPUTOB21	; buffer <-- objet (2-1)	LOAD.L	D3,(A4)+OOBPP1	; D3 <-- point suivant	JUMP'	CONT3$CONT2$:	CALL	REPUTOB12	; buffer <-- objet (1-2)	LOAD.L	D3,(A4)+OOBPP2	; D3 <-- point suivantCONT3$:	CALL	RESEARCH	; A4 <-- ^objet jointif	JUMP,EQ CONT$	POP.L	A4NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	LOAD.B	(A3+),#xcOPEND	CLR.B	(A3+)	LOAD.L	D4,A3	SUB.L	D4,A2		; D4 <-- lg ncessaire	POPM.L	D3,D6,A2..A4	RET;---------\\; REPUTOBX >;---------/; in	A4.L	^objet;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LREPUTOBX:	COMP.W	(A4)+OOBTYP,#xcOPADDCHAR	JUMP',EQ ADDCHAR$	JUMP'	EXIT$ADDCHAR$:	LOAD.B	(A3+),#xcOPADDCHAR	CLR.B	(A3+)	LOAD.L	(A3+),(A4)+OOBPP1	LOAD.B	(A3+),(A4)+OOBPP2	CLR.B	(A3+);	JUMP'	OK$OK$:	LOAD.W	(A4)+OOBTYP,#-1EXIT$:	RET;----------\\; REPUTOB12 >;----------/; in	A4.L	^objet;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LREPUTOB12:	COMP.W	(A4)+OOBTYP,#xcOPLINE	JUMP',EQ LINE$	COMP.W	(A4)+OOBTYP,#xcOPCURVE	JUMP',EQ CURVE$	JUMP'	EXIT$LINE$:	CALL	REPUTPEN	LOAD.B	(A3+),#xcOPLINE	CLR.B	(A3+)	CALL	REPUTPP2	JUMP'	OK$CURVE$:	CALL	REPUTPEN	LOAD.B	(A3+),#xcOPCURVE	CLR.B	(A3+)	CALL	REPUTPS1	CALL	REPUTPS2	CALL	REPUTPP2;	JUMP'	OK$OK$:	LOAD.W	(A4)+OOBTYP,#-2EXIT$:	RET;----------\\; REPUTOB21 >;----------/; in	A4.L	^objet;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LREPUTOB21:	COMP.W	(A4)+OOBTYP,#xcOPLINE	JUMP',EQ LINE$	COMP.W	(A4)+OOBTYP,#xcOPCURVE	JUMP',EQ CURVE$	JUMP'	EXIT$LINE$:	CALL	REPUTPEN	LOAD.B	(A3+),#xcOPLINE	CLR.B	(A3+)	CALL	REPUTPP1	JUMP'	OK$CURVE$:	CALL	REPUTPEN	LOAD.B	(A3+),#xcOPCURVE	CLR.B	(A3+)	CALL	REPUTPS2	CALL	REPUTPS1	CALL	REPUTPP1;	JUMP'	OK$OK$:	LOAD.W	(A4)+OOBTYP,#-2EXIT$:	RET;---------\\; REPUTPP1 >;---------/; Met le point PP1 d'un objet dans le buffer cod.; in	A4.L	^objet;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LREPUTPP1:	PUSHM.L	D3,D4	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBRP1	CALL	REPUTPP	POPM.L	D3,D4	RET;---------\\; REPUTPP2 >;---------/; Met le point PP2 d'un objet dans le buffer cod.; in	A4.L	^objet;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LREPUTPP2:	PUSHM.L	D3,D4	LOAD.L	D3,(A4)+OOBPP2	LOAD.L	D4,(A4)+OOBRP2	CALL	REPUTPP	POPM.L	D3,D4	RET;--------\\; REPUTPP >;--------/; Met un point PP d'un objet dans le buffer cod.; in	D3.L	P (y;x)  [pi];	D4.L	R (y;x)  [pi];	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LREPUTPP:	PUSHM.L	D2..D4,A2,A4	TEST.L	D4	JUMP,EQ 80$	LOAD.L	A2,#(A6)+OBUDIS	LOAD.L	(A2+),D3	; OBUDIS <-- point final	LOAD.W	D2,#20		; D2 <-- lg max chane de flches relatives20$:	DEC.W	D2		; on tourne en rond ?	JUMP',NS 35$		; oui => 35$	LOAD.L	D3,D4	LOAD.L	(A2+),D3	; OBUDIS <-- point initiateur	CALL	RELABS		; D3 <-- point standard	CALL	RESEARCH2	; A4 <-- ^objet jointif	JUMP',NE 35$	LOAD.L	D4,(A4)+OOBRP1	COMP.L	D3,(A4)+OOBPP1	JUMP',EQ 30$	LOAD.L	D4,(A4)+OOBRP230$:	TEST.L	D4	JUMP,NE 20$35$:	CLR.L	(A2)	LOAD.L	A2,#(A6)+OBUDIS40$:	LOAD.L	D3,(A2+)	LOAD.L	D4,(A2)	SWAP.W	D3	SWAP.W	D4	TEST.W	D4	JUMP',NC 44$	CALL	RELABS	EX.L	D3,D4	CALL	RELABS	EX.L	D4,D3	SUB.W	D3,D4	TNOT.L	D3:#15	LOAD.W	(A3+),D3	; buffer <-- dy	JUMP	40$44$:	CALL	RELABS	LOAD.W	(A3+),D3	; buffer <-- y	LOAD.L	A2,#(A6)+OBUDIS50$:	LOAD.L	D3,(A2+)	LOAD.L	D4,(A2)	TEST.W	D4	JUMP',NC 54$	CALL	RELABS	EX.L	D3,D4	CALL	RELABS	EX.L	D4,D3	SUB.W	D3,D4	TNOT.L	D3:#15	LOAD.W	(A3+),D3	; buffer <-- dx	JUMP	50$54$:	CALL	RELABS	LOAD.W	(A3+),D3	; buffer <-- x	JUMP'	90$80$:	LOAD.L	(A3+),D390$:	POPM.L	D2..D4,A2,A4	RET;---------\\; REPUTPS1 >;---------/; Met le point PS1 d'un objet dans le buffer cod.; in	A4.L	^objet;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LREPUTPS1:	LOAD.L	(A3+),(A4)+OOBPS1	RET;---------\\; REPUTPS2 >;---------/; Met le point PS2 d'un objet dans le buffer cod.; in	A4.L	^objet;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LREPUTPS2:	LOAD.L	(A3+),(A4)+OOBPS2	RET;---------\\; REPUTPEN >;---------/; Met le pinceau d'un objet dans le buffer cod.; in	A4.L	^objet;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LREPUTPEN:	PUSH.W	D3	LOAD.W	D3,(A4)+OOBPEN	COMP.W	D3,(A6)+OLPEN	; est-ce toujours le mme pinceau ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.B	(A3+),#xcOPPEN	CLR.B	(A3+)	LOAD.W	(A3+),D3	LOAD.W	(A6)+OLPEN,D3EXIT$:	POP.W	D3	RET;---------\\; RESEARCH >;---------/; Cherche un objet partant ou arrivant  une position donne.; in	D3.L	point (y;x); out	A4.L	^objet;	D7.W	erreur; mod	D7.W, A4.LRESEARCH:	PUSHM.L	D4,D6	LOAD.L	D6,(A6)+OLSTC1	; D6 <-- canal de la liste	JUMP',EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	LOAD.W	D4,(A4)+OOBTYP	COMP.W	D4,#-1	JUMP',EQ NEXT$	COMP.W	D4,#-2	JUMP',EQ NEXT$	COMP.W	D4,#xcOPADDCHAR	JUMP',EQ NEXT$	COMP.L	D3,(A4)+OOBPP1	JUMP',EQ EXIT$	COMP.L	D3,(A4)+OOBPP2	JUMP',EQ EXIT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	LOAD.W	D7,#1EXIT$:	POPM.L	D4,D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; RESEARCH2 >;----------/; Cherche un objet partant ou arrivant  une position donne.; in	D3.L	point (y;x); out	A4.L	^objet;	D7.W	erreur; mod	D7.W, A4.LRESEARCH2:	PUSHM.L	D4,D6	LOAD.L	D6,(A6)+OLSTC1	; D6 <-- canal de la liste	JUMP',EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	LOAD.W	D4,(A4)+OOBTYP	COMP.W	D4,#-1	JUMP',EQ NEXT$	COMP.W	D4,#xcOPADDCHAR	JUMP',EQ NEXT$	COMP.L	D3,(A4)+OOBPP1	JUMP',EQ EXIT$	COMP.L	D3,(A4)+OOBPP2	JUMP',EQ EXIT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	LOAD.W	D7,#1EXIT$:	POPM.L	D4,D6	TEST.W	D7		; retour EQ/NE	RET	.END