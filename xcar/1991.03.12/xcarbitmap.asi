	.SBTTL	XCARBITMAP.ASI;-------------\\; _XCAR_BMOPEN >;=============/; Ouvre un gencar bitmap.; in	A4.L	^descripteur (odgbm*); out	A3.L	^gencar bitmap;	D7.W	erreur; mod	D7.W, A3.L_XCAR_BMOPEN:	PUSHM.L	D1..D4,A0..A2,A4,A6	LOAD.L	A2,A4		; A2 <-- ^descripteur; Demande de la mmoire pour les variables locales.	CALL	OPEVAR		; A6 <-- ^variables locales	JUMP,NE EXIT9$	LOAD.W	(A6)+OXCT,(A2)+odgbmCORPS; Charge le fichier du gencar analytique.	LOAD.L	A4,#(A2)+odgbmNAME ; A4 <-- ^nom complet	CALL	BMNAMEGC	; A3 <-- ^nom du fichier	JUMP,NE EXIT4$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	D3,#2^BEXNHEAD	; D3 <-- ne charge pas l'en-tte	FOS	?CLOAD		; A4 <-- ^gencar analytique	JUMP,NE EXIT4$	LOAD.L	(A6)+OXCPI,A4	LOAD.W	D7,#ERDIGC	COMP.W	(A4)+oxcIDENT,#xcIDENT	JUMP,NE EXIT3$	CALL	CALCHTE		; D4 <-- hauteur du "E"	LOAD.W	(A6)+OXCIYE,D4	LOAD.W	D4,(A6)+OXCT	; D4 <-- taille demande	COMP.W	D4,(A4)+oxcPMN	; taille trs petite ?	JUMP',HS BMEM$		; non => BMEM$	TEST.B	(A4)+oxcPNG	; nom existe ?	JUMP',EQ BMEM$		; non => BMEM$	CALL	BMNAMEGCJ	; A3 <-- ^nom du fichier trs petit	LOAD.L	D3,#2^BEXNHEAD	; D3 <-- ne charge pas l'en-tte	FOS	?CLOAD		; A4 <-- ^gencar analytique trs petit	JUMP',NE BMEM$	LOAD.L	(A6)+OXCPJ,A4	CALL	CALCHTE		; D4 <-- hauteur du "E" trs petit	LOAD.W	(A6)+OXCIYEJ,D4; Demande de la mmoire pour le gencar bitmap.BMEM$:	LOAD.L	D4,#oxcbmLG	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour gencar bitmap	JUMP,NE EXIT3$	GESMEM	?CLEARMEM	LOAD.L	A3,A4		; A3 <-- ^gencar bitmap	LOAD.L	A4,(A6)+OXCPI	; A4 <-- ^gencar analytique; Gnre l'en-tte du gencar bitmap.	LOAD.L	(A6)+OXCPM,A2	LOAD.L	(A3)+oxcbmPDESC,A2	LOAD.L	(A3)+oxcbmPGCA,A4	LOAD.L	(A3)+oxcbmPGCAP,(A6)+OXCPJ	LOAD.W	D2,(A2)+odgbmZOOMX	LOAD.L	A2,#(A4)+oxcLENGTH	LOAD.L	A1,#(A3)+oxcbmLENGTH	LOAD.W	D3,#xcNBCAR-1LENGTH$:	LOAD.W	D4,(A2+)	CALL	CONVIO	TEST.W	D2	JUMP',EQ LENGTH2$	MUL.WA	D4,D2	DIV.WA	D4,#100		; D4 <-- Px(zoom)LENGTH2$:	LOAD.W	(A1+),D4	DECJ.W,NMO D3,LENGTH$	TEST.L	(A6)+OXCPJ	; gencar petit existe ?	JUMP,NE BBOXJ$		; oui => BBOXJ$	LOAD.L	A2,A4	LOAD.L	A1,A3	LOAD.W	D1,#xcNBCAR-1BBOXL$:	LOAD.W	D4,(A2)+oxcYMINS	CALL	CONVIO	LOAD.W	D3,D4	SWAP.W	D3	LOAD.W	D4,(A2)+oxcXMINS	CALL	CONVIO	LOAD.W	D3,D4	LOAD.W	D4,(A2)+oxcYMAXS	CALL	CONVIO	LOAD.W	D2,D4	SWAP.W	D2	LOAD.W	D4,(A2)+oxcXMAXS	CALL	CONVIO	LOAD.W	D2,D4	LOAD.L	D4,D2	CALL	MATHRECT	; D3/D4 <-- rectangle englobant	NEG.W	D3	INC.W	D3	LOAD.W	(A1)+oxcbmXMINS,D3	SWAP.W	D3	NEG.W	D3	INC.W	D3	LOAD.W	(A1)+oxcbmYMINS,D3	INC.W	D4	LOAD.W	(A1)+oxcbmXMAXS,D4	SWAP.W	D4	INC.W	D4	LOAD.W	(A1)+oxcbmYMAXS,D4	ADD.L	A2,#2	ADD.L	A1,#2	DECJ.W,NMO D1,BBOXL$	JUMP	BBOXEND$BBOXJ$:	LOAD.L	A2,A4	LOAD.L	A1,A3	LOAD.L	A0,(A6)+OXCPJ	LOAD.W	D1,#xcNBCAR-1BBOXJL$:	LOAD.W	D4,(A0)+oxcYMINS	CALL	CONVIOJ	LOAD.W	D3,D4	SWAP.W	D3	LOAD.W	D4,(A2)+oxcXMINS	CALL	CONVIO	LOAD.W	D3,D4	LOAD.W	D4,(A0)+oxcYMAXS	CALL	CONVIOJ	LOAD.W	D2,D4	SWAP.W	D2	LOAD.W	D4,(A2)+oxcXMAXS	CALL	CONVIO	LOAD.W	D2,D4	LOAD.L	D4,D2	CALL	MATHRECT	; D3/D4 <-- rectangle englobant	NEG.W	D3	INC.W	D3	LOAD.W	(A1)+oxcbmXMINS,D3	SWAP.W	D3	NEG.W	D3	INC.W	D3	LOAD.W	(A1)+oxcbmYMINS,D3	INC.W	D4	LOAD.W	(A1)+oxcbmXMAXS,D4	SWAP.W	D4	INC.W	D4	LOAD.W	(A1)+oxcbmYMAXS,D4	ADD.L	A2,#2	ADD.L	A1,#2	ADD.L	A0,#2	DECJ.W,NMO D1,BBOXJL$BBOXEND$:	LOAD.L	A1,#(A3)+oxcbmXMINS	CLR.W	D4	LOAD.W	D3,#xcNBCAR-1XMIN1$:	COMP.W	D4,(A1+)	JUMP',GE XMIN2$	LOAD.W	D4,(A1)-2XMIN2$:	DECJ.W,NMO D3,XMIN1$	LOAD.W	(A3)+oxcbmXMIN,D4	LOAD.L	A1,#(A3)+oxcbmXMAXS	CLR.W	D4	LOAD.W	D3,#xcNBCAR-1XMAX1$:	COMP.W	D4,(A1+)	JUMP',GE XMAX2$	LOAD.W	D4,(A1)-2XMAX2$:	DECJ.W,NMO D3,XMAX1$	LOAD.W	(A3)+oxcbmXMAX,D4	LOAD.L	A1,#(A3)+oxcbmYMINS	CLR.W	D4	LOAD.W	D3,#xcNBCAR-1YMIN1$:	COMP.W	D4,(A1+)	JUMP',GE YMIN2$	LOAD.W	D4,(A1)-2YMIN2$:	DECJ.W,NMO D3,YMIN1$	LOAD.W	(A3)+oxcbmYMIN,D4	LOAD.L	A1,#(A3)+oxcbmYMAXS	CLR.W	D4	LOAD.W	D3,#xcNBCAR-1YMAX1$:	COMP.W	D4,(A1+)	JUMP',GE YMAX2$	LOAD.W	D4,(A1)-2YMAX2$:	DECJ.W,NMO D3,YMAX1$	LOAD.W	(A3)+oxcbmYMAX,D4	CALL	CALCHTE		; D4 <-- hauteur du "E"	MUL.WU	D4,(A4)+oxcITL	DIV.WU	D4,#1000	CALL	CONVIO	LOAD.W	(A3)+oxcbmITL,D4	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT4$EXIT2$:	PUSH.W	D7	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le gencar bitmap	POP.W	D7EXIT3$:	PUSH.W	D7	TEST.L	(A6)+OXCPJ	JUMP',EQ EXIT32$	CALL	BMNAMEGCJ	; A3 <-- ^nom du fichier	FOS	?CUNLOAD	; libre le gencar analytique trs petitEXIT32$:	LOAD.L	A4,#(A2)+odgbmNAME ; A4 <-- ^nom complet	CALL	BMNAMEGC	; A3 <-- ^nom du fichier	JUMP',NE EXIT33$	FOS	?CUNLOAD	; libre le gencar analytiqueEXIT33$:	POP.W	D7EXIT4$:	CALL	CLOVAR		; rend les variablesEXIT9$:	PUSH.W	D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: remet la flche	POP.W	D7	POPM.L	D1..D4,A0..A2,A4,A6	TEST.W	D7		; retour EQ/NE	RET;--------------\\; _XCAR_BMCLOSE >;==============/; Ferme un gencar bitmap.; in	A3.L	^gencar bitmap; out	-; mod	D7.W_XCAR_BMCLOSE:	PUSHM.L	D1,D3,D4,A2..A4,A6	LOAD.L	A2,A3		; A2 <-- ^gencar bitmap; Libre les matrices construites.	LOAD.L	A3,#(A2)+oxcbmPMAT	LOAD.W	D3,#xcNBCAR-1MLOOP$:	LOAD.L	D4,(A3)	JUMP',EQ MNEXT$	LOAD.L	A4,D4	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre une matriceMNEXT$:	CLR.L	(A3+)	DECJ.W,NMO D3,MLOOP$; Demande de la mmoire pour les variables locales.	CALL	OPEVAR		; A6 <-- ^variables locales	JUMP',NE EXIT9$	LOAD.L	(A6)+OXCPI,(A2)+oxcbmPGCA; Libre le gencar analytique.	TEST.L	(A2)+oxcbmPGCAP	JUMP',EQ NOLIT$	CALL	BMNAMEGCJ	; A3 <-- ^nom du fichier	FOS	?CUNLOAD	; libre le gencar analytique trs petitNOLIT$:	LOAD.L	A4,(A2)+oxcbmPDESC ; A4 <-- ^descripteur;	LOAD.L	A4,#(A4)+odgbmNAME ; A4 <-- ^nom complet	CALL	BMNAMEGC	; A3 <-- ^nom du fichier	JUMP',NE EXIT2$	FOS	?CUNLOAD	; libre le gencar analytique; Libre le gencar bitmap.EXIT2$:	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le gencar bitmapEXIT4$:	CALL	CLOVAR		; rend les variablesEXIT9$:	POPM.L	D1,D3,D4,A2..A4,A6	CLR.W	D7		; retour EQ	RET;---------------\\; _XCAR_BMMATRIX >;===============/; Donne la matrice d'un caractre bitmap.; Lors de la premire utilisation d'un caractre donn, la matrice est calcule.; in	A3.L	^gencar bitmap;	D3.W	code du caractre; out	A4.L	^matrice;	D3.L	coin sup/gauche matrice (y;x);	D4.L	dimensions matrice (dy;dx);	D5.L	Iy;chasse (dx);	D7.W	erreur; mod	D3.L, D4.L, D5.L, D7.W, A4.L_XCAR_BMMATRIX:	PUSHM.L	D0,D2,A2	; PUSH minimal	LOAD.W	D0,D3		; D0 <-- code du caractre	LOAD.W	D2,D0	SL.W	D2,#1		; D2 <-- dcalage pour .W	LOAD.L	A2,#(A3)+oxcbmLENGTH	LOAD.W	D5,(A2)+(D2.W)	; D5 <-- chasse	LOAD.L	A2,#(A3)+oxcbmYMINS	LOAD.W	D3,(A2)+(D2.W)	; D3 <-- coin	LOAD.L	A2,#(A3)+oxcbmYMAXS	LOAD.W	D4,(A2)+(D2.W)	ADD.W	D4,D3		; D4 <-- hauteur	JUMP',NE LYOK$	INC.W	D4		; D4 <-- hauteur d'au moins une ligne !LYOK$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	A2,#(A3)+oxcbmXMINS	LOAD.W	D3,(A2)+(D2.W)	; D3 <-- coin	LOAD.L	A2,#(A3)+oxcbmXMAXS	LOAD.W	D4,(A2)+(D2.W)	ADD.W	D4,D3		; D4 <-- largeur	JUMP',NE LXOK$	INC.W	D4		; D4 <-- largeur d'au moins un point !LXOK$:	SWAP.W	D5	LOAD.W	D5,D4	COMP.W	D5,#16+1	; largeur < 4 bytes (RGNTOBITMAP plante) ?	JUMP',HS IXOK$		; non => IXOK$	LOAD.W	D5,#16+1	; D5 <-- largeur de 4 bytesIXOK$:	ADD.W	D5,#16-1	SR.W	D5,#4	SL.W	D5,#1		; D5 <-- largeur en bytes (multiple de words)	SWAP.W	D5	LOAD.L	A2,#(A3)+oxcbmPMAT	SL.W	D2,#1		; D2 <-- dcalage pour .L	TEST.L	(A2)+(D2.W)	; matrice dj calcule ?	JUMP',EQ CREATE$	; non => CREATE$	LOAD.L	A4,(A2)+(D2.W)	; A4 <-- ^matrice	CLR.W	D7		; D7 <-- ok	JUMP	EXIT9$CREATE$:	PUSHM.L	D1,D4,D6,A0,A1,A5,A6 ; PUSH le reste	COMP.W	D4,#16+1	; largeur < 4 bytes (RGNTOBITMAP plante) ?	JUMP',HS CXOK$		; non => CXOK$	LOAD.W	D4,#16+1	; D4 <-- largeur de 4 bytesCXOK$:	LOAD.L	D2,D3		; D2 <-- coin sup/gauche	LOAD.L	D6,D4		; D6 <-- dimensions; Ouvre les variables et la rgion.	CALL	OPEVAR		; A6 <-- ^variables locales	JUMP,NE EXIT8$	LOAD.L	A4,(A3)+oxcbmPGCAP	LOAD.L	(A6)+OXCPJ,A4	CALL	CALCHTE		; D4 <-- hauteur du "E" si trs petit	LOAD.W	(A6)+OXCIYEJ,D4	LOAD.L	A4,(A3)+oxcbmPGCA	LOAD.L	(A6)+OXCPI,A4	CALL	CALCHTE		; D4 <-- hauteur du "E"	LOAD.W	(A6)+OXCIYE,D4	LOAD.L	A2,(A3)+oxcbmPDESC	LOAD.W	(A6)+OXCT,(A2)+odgbmCORPS	LOAD.L	(A6)+OXCPM,A2	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	#(A6)+OXCIRG	; stack <-- ^VAR identificateur rgion	LOAD.L	A1,(A6)+OAGMNR	CALL	(A1)		; GMI_NEWRGN, cre une nouvelle rgion	POP.W	D7	JUMP,NE EXIT6$; Rserve la mmoire pour la matrice du caractre.;	CLR.L	(A6)+OXCBRG+OGBMAPRECT+OGRECTTL	LOAD.L	(A6)+OXCBRG+OGBMAPRECT+OGRECTBR,D6	LOAD.W	D4,D6	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1		; D4 <-- largeur en bytes (multiple de words)	LOAD.W	(A6)+OXCBRG+OGBMAPWIDTH,D4	SWAP.W	D6	MUL.WU	D4,D6		; D4 <-- taille ncessaire	SWAP.W	D6	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- demande mmoire pour matrice	JUMP,NE EXIT4$	GESMEM	?CLEARMEM	LOAD.L	A0,A4		; A0 <-- ^matrice vide (pleine de zros)	LOAD.L	A2,#(A3)+oxcbmPMAT	LOAD.W	D1,D0	SL.W	D1,#2	LOAD.L	(A2)+(D1.W),A0	; oxcbmPMAT <-- ^nouvelle matrice	LOAD.L	(A6)+OXCBRG+OGBMAPPT,A0; Prpare le descripteur de fentre.	LOAD.L	A2,#(A6)+OXCDF	; A2 <-- ^descripteur fentre spcial	LOAD.W	D4,D6	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1		; D4 <-- largeur en bytes (multiple de words)	LOAD.W	(A2)+ODFIIY,D4	SL.W	D4,#3	LOAD.W	(A2)+ODFDX,D4	LOAD.W	(A2)+ODFFDX,D4	LOAD.W	(A2)+ODFWEX,D4	LOAD.L	D4,D6	SWAP.W	D4		; D4 <-- hauteur	LOAD.W	(A2)+ODFDY,D4	LOAD.W	(A2)+ODFFDY,D4	LOAD.W	(A2)+ODFWEY,D4	LOAD.W	(A2)+ODFIIX,#1	LOAD.B	(A2)+ODFMGR,#GRACLIP	LOAD.B	(A2)+ODFNOW,#-1; Gnre la matrice du caractre.	LOAD.L	(A6)+OXCPOS,D2	LOAD.W	D3,D0		; D3 <-- caractre	CALL	IFFILL		; remplissage ?	JUMP',NE OUTL$		; non => OUTL$	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	PUSH.W	#GFILLXOR+GFILLINTERIOR ; stack <-- mode	PUSH.L	#(A6)+OXCBRG+OGBMAPRECT ; stack <-- ^cliprect	LOAD.L	A1,(A6)+OAGMOR	CALL	(A1)		; GMI_OPENRGN, dbut de dfinition de rgion	POP.W	D7	JUMP,NE EXIT2$;	LOAD.W	D3,D0		; D3 <-- caractre	LOAD.W	(A6)+OXCMOD,#XCMODFILL	CALL	DECODE		; dfinition de la rgion	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	LOAD.L	A1,(A6)+OAGMCR	CALL	(A1)		; GMI_CLOSERGN, termine la dfinition de rgion	POP.W	D7	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	PUSH.L	#(A6)+OXCBRG	; stack <-- ^descripteur bitmap	PUSH.B	#GMOR		; stack <-- mode de transfert	LOAD.L	A1,(A6)+OAGMRB	CALL	(A1)		; GMI_RGNTOBITMAP, bitmap <-- rgion	POP.W	D7OUTL$:;	LOAD.W	D3,D0		; D3 <-- caractre	CALL	IFOUTL		; outline ?	JUMP',NE END$		; non => END$	LOAD.L	(A6)+OXCDF+ODFABS,A0	LOAD.W	(A6)+OXCMOD,#XCMODOUTL	CALL	DECODE		; dfinition de la rgionEND$:	LOAD.L	D3,D2		; D3 <-- coin sup/gauche	LOAD.L	A4,A0		; A4 <-- ^matrice	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT4$; Libre la rgion et les variables.EXIT2$:	PUSH.W	D7	LOAD.L	A4,A0	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la matrice	POP.W	D7EXIT4$:	PUSH.L	D7	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+OXCIRG	; stack <-- ^identificateur rgion	LOAD.L	A1,(A6)+OAGMDR	CALL	(A1)		; GMI_DISPOSERGN, rend la rgion	POP.W	D7	POP.L	D7EXIT6$:	CALL	CLOVAR		; rend les variablesEXIT8$:	POPM.L	D1,D4,D6,A0,A1,A5,A6 ; POP le resteEXIT9$:	POPM.L	D0,D2,A2	; POP minimal	TEST.W	D7		; retour EQ/NE	RET;---------\\; BMNAMEGC >;---------/; Cherche le nom du fichier d'aprs le nom complet.; in	A4.L	^nom complet; out	A3.L	^nom du fichier;	D7.W	erreur; mod	D7.W, A3.LBMNAMEGC:	PUSHM.L	D3,D4,A4..A6	LOAD.L	A5,A6		; A5 <-- ^variables	CALL	GETCOMMEM	; A6 <-- ^variables globales	LOAD.L	A3,A4	CALL	LISTSRCNC	; D3/D4 <-- rang/"-fst"	JUMP,NE EXIT$	LOAD.L	A3,#(A5)+OXCFILN	LOAD.B	(A3+),#'S	LOAD.B	(A3+),#'M	LOAD.B	(A3+),#'A	LOAD.B	(A3+),#'_	LOAD.L	D3,D4	SWAP.W	D3	LOAD.B	(A3+),D3	LOAD.W	D3,D4	RR.W	D3,#8	TCLR.L	D3:#7	LOAD.B	(A3+),D3	LOAD.B	(A3+),#'P	TEST.L	D4:#8+7	JUMP',BC PROP$	LOAD.B	(A3)-1,#'FPROP$:	LOAD.B	(A3+),#'0	LOAD.B	(A3+),#'0	LOAD.B	(A3+),#'.	LOAD.B	(A3+),#'G	LOAD.B	(A3+),#'E	LOAD.B	(A3+),#'N	LOAD.B	(A3+),#'C	CLR.B	(A3)	LOAD.L	A3,#(A5)+OXCFILN	CLR.W	D7		; D7 <-- trouvEXIT$:	POPM.L	D3,D4,A4..A6	TEST.W	D7		; retour EQ/NE	RET;----------\\; BMNAMEGCJ >;----------/; Cherche le nom du fichier trs petit.; in	-; out	A3.L	^nom du fichier; mod	D7.W, A3.LBMNAMEGCJ:	PUSHM.L	D3,D4,A4	LOAD.L	A4,(A6)+OXCPI	; A4 <-- ^gencar en entre	LOAD.L	A3,#(A6)+OXCFILN	LOAD.B	(A3+),#'S	LOAD.B	(A3+),#'M	LOAD.B	(A3+),#'A	LOAD.B	(A3+),#'_	LOAD.W	(A3+),(A4)+oxcPNG	LOAD.B	(A3+),#'P	TCLR.B	(A3)-2:#BGCFIX	JUMP',BC PROP$	LOAD.B	(A3)-1,#'FPROP$:	LOAD.B	(A3+),#'0	LOAD.B	(A3+),#'0	LOAD.B	(A3+),#'.	LOAD.B	(A3+),#'G	LOAD.B	(A3+),#'E	LOAD.B	(A3+),#'N	LOAD.B	(A3+),#'C	CLR.B	(A3)	LOAD.L	A3,#(A6)+OXCFILN	POPM.L	D3,D4,A4	RET;---------\\; MATHRECT >;=========/; Transforme tous les points d'un rectangle, puis dtermine; le rectangle englobant.; in	D3.L	coin sup/gauche (y;x);	D4.L	coin inf/droite (y;x); out	D3.L	coin sup/gauche (y;x);	D4.L	coin inf/droite (y;x); mod	D3.L, D4.L, D7.WMATHRECT:	PUSHM.L	D0..D2	LOAD.L	D1,D3	LOAD.W	D1,D4		; D1 <-- coin sup/droite (y;x)	LOAD.L	D2,D4	LOAD.W	D2,D3		; D2 <-- coin inf/gauche (y;x)	EX.L	D4,D1	CALL	MATHPOINT	; D1 <-- P1'	EX.L	D1,D4	EX.L	D4,D2	CALL	MATHPOINT	; D2 <-- P2'	EX.L	D2,D4	EX.L	D4,D3	CALL	MATHPOINT	; D3 <-- P3'	EX.L	D3,D4;	EX.L	D4,D4	CALL	MATHPOINT	; D4 <-- P4';	EX.L	D4,D4	LOAD.W	D0,D1	COMP.W	D0,D2	JUMP',LE MINX1$	LOAD.W	D0,D2MINX1$:	COMP.W	D0,D3	JUMP',LE MINX2$	LOAD.W	D0,D3MINX2$:	COMP.W	D0,D4	JUMP',LE MINX3$	LOAD.W	D0,D4MINX3$:	TEST.W	D0	JUMP',LE MINX4$	CLR.W	D0		; D0 <-- XminMINX4$:	COMP.W	D4,D3	JUMP',GE MAXX1$	LOAD.W	D4,D3MAXX1$:	COMP.W	D4,D2	JUMP',GE MAXX2$	LOAD.W	D4,D2MAXX2$:	COMP.W	D4,D1	JUMP',GE MAXX3$	LOAD.W	D4,D1MAXX3$:	TEST.W	D4	JUMP',GE MAXX4$	CLR.W	D4		; D4 <-- XmaxMAXX4$:	LOAD.W	D3,D0		; D3 <-- Xmin	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,D1	COMP.W	D0,D2	JUMP',LE MINY1$	LOAD.W	D0,D2MINY1$:	COMP.W	D0,D3	JUMP',LE MINY2$	LOAD.W	D0,D3MINY2$:	COMP.W	D0,D4	JUMP',LE MINY3$	LOAD.W	D0,D4MINY3$:	TEST.W	D0	JUMP',LE MINY4$	CLR.W	D0		; D0 <-- YminMINY4$:	COMP.W	D4,D3	JUMP',GE MAXY1$	LOAD.W	D4,D3MAXY1$:	COMP.W	D4,D2	JUMP',GE MAXY2$	LOAD.W	D4,D2MAXY2$:	COMP.W	D4,D1	JUMP',GE MAXY3$	LOAD.W	D4,D1MAXY3$:	TEST.W	D4	JUMP',GE MAXY4$	CLR.W	D4		; D4 <-- YmaxMAXY4$:	LOAD.W	D3,D0		; D3 <-- Ymin;	SWAP.W	D1;	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	POPM.L	D0..D2	RET;----------\\; MATHPOINT >;==========/; Effectue les oprations "zoom", "shift" et "rotate" sur un point.; in	D4.L	point (y;x); out	D4.L	point (y;x); mod	D4.L, D7.WMATHPOINT:	TEST.L	(A6)+OXCPM	; descripteur pour transformation existe ?	JUMP',NE MATH$		; oui => MATH$	RETMATH$:	PUSHM.L	D1..D3,A4	LOAD.L	A4,(A6)+OXCPM	; A4 <-- ^descripteur	LOAD.L	D1,D4		; D4 <-- Px	SWAP.W	D1		; D1 <-- Py; Effectue les oprations "zoom" en X et Y.	LOAD.W	D3,(A4)+odgbmZOOMX	JUMP',EQ ZOOMX$	MUL.WA	D4,D3	DIV.WA	D4,#100		; D4 <-- Px(zoom)ZOOMX$:	LOAD.W	D3,(A4)+odgbmZOOMY	JUMP',EQ ZOOMY$	MUL.WA	D1,D3	DIV.WA	D1,#100		; D1 <-- Py(zoom)ZOOMY$:; Effectue les oprations "shift" en X et Y.	LOAD.W	D2,D4	LOAD.W	D3,(A4)+odgbmSHIFTX	JUMP',EQ SHIFTX$	MUL.WA	D3,D1	DIV.WA	D3,#100	SUB.W	D4,D3		; D4 <-- Px(shift)SHIFTX$:	LOAD.W	D3,(A4)+odgbmSHIFTY	JUMP',EQ SHIFTY$	MUL.WA	D3,D2	DIV.WA	D3,#100	SUB.W	D1,D3		; D1 <-- Py(shift)SHIFTY$:; Effectue l'opration "rotate".	SWAP.W	D4	LOAD.W	D4,D1		; D4 <-- P(y;x)	SWAP.W	D4	LOAD.W	D1,(A4)+odgbmROTATE+0	JUMP',EQ ROTATE$	CLR.L	D3	LIB	?CALCPSYM	; D4 <-- P(rotate)ROTATE$:	POPM.L	D1..D3,A4	RET	.END