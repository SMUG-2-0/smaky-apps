	.SBTTL	XCARCADRE.ASI;--------\\; DESWDO  >;========/; Grise toute la fentre et place les icnes.; in	-; out	-; mod	D7.WDESWDO:	PUSHM.L	D2..D4	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface toute la fentre	LOAD.L	D4,#H'88228822	; D4 <-- trame pour joli cran	CALL	DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise toute la fentre	PUSH.L	D4	LOAD.L	D4,#-1	CALL	DRMDEF	POP.L	D4	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LIB	?DRMATRIX	; dessine une bande blanche en haut	CALL	DESINFO		; affiche les informations	CALL	DESINFSC	; affiche l'chelle	CALL	DESINFFILE	; affiche le nom du dessin	CLR.L	D4	CALL	DRMDEF	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,#ICOLY	SWAP.W	D4	LOAD.W	D4,#MARGX+GCIMX	LOAD.L	(A6)+ODICO,D4	; ODICO <-- position pour icnes  gauche	CALL	DESICONE	; dessine toutes les icnes	CALL	MEMICONE	; mmorise les icnes de gauche	CALL	MAJICONE	POPM.L	D2..D4	RET;--------\\; DESINFO >;========/; Dessine les informations tout en haut.; in	-; out	-; mod	D7.WDESINFO:	PUSH.L	D3	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	AFINV		; vido inverse	.ASCII	" XCAR "	.B	XCARREV+'0,'.	.IF	XCARVERS<10	.B	XCARVERS+'0	.ELSE	.B	(XCARVERS/10)+'0,(XCARVERS-((XCARVERS/10)*10))+'0	.ENDIF	.B	XCARPROV	.B	AFDIR	.B	0	.EVEN	POP.L	D3	RET;---------\\; DESINFXY >;=========/; Affiche la position x,y de la souris dans les informations.; in	-; out	-; mod	D7.WDESINFXY:	PUSHM.L	D2..D4	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSXY	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	CALL	IFMOUSEW	; D4 <-- position de la souris	JUMP,NE 50$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- position [pi]	LOAD.L	D4,D3	LIB	?AFTIM	.ASCIZ	"X="	.EVEN	PUSH.L	D4	LOAD.B	D3,#'+	TEST.W	D4	JUMP',NC 30$	NEG.W	D4	LOAD.B	D3,#'-30$:	LIB	?AFCAR	CONV.LA.WA D4	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode	LOAD.W	D3,#4		; D3 <-- nb digits pour 0..9999	LIB	?AFDEC	POP.L	D4	LIB	?AFTIM	.ASCIZ	" Y="	.EVEN	SWAP.W	D4	LOAD.B	D3,#'-	TEST.W	D4	JUMP',NC 40$	NEG.W	D4	LOAD.B	D3,#'+40$:	LIB	?AFCAR	CONV.LA.WA D4;	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode	LOAD.W	D3,#4		; D3 <-- nb digits pour 0..9999	LIB	?AFDEC	JUMP'	80$50$:	LIB	?AFTIM	.B	MSPACE,15,0	; efface tout	.EVEN80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	POPM.L	D2..D4	RET;---------\\; DESINFSC >;=========/; Affiche l'chelle dans les informations.;	OSCALE positif	-->	n:1;	OSCALE ngatif	-->	1:n; in	(A6)+OSCALE.W; out	-; mod	D7.WDESINFSC:	PUSHM.L	D2..D4	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSSCALE	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LOAD.W	D3,#2		; D3 <-- 2 digits au maximum	CLR.L	D4	LOAD.W	D4,(A6)+OSCALE	; D4 <-- +/- chelle	JUMP',EQ 55$	JUMP',NS 50$				; chelle n:1 =>	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	":1"	.EVEN	JUMP'	60$50$:				; chelle 1:n =>	NEG.W	D4	LIB	?AFTIM	.ASCIZ	"1:"	.EVEN	LIB	?AFDEC	JUMP'	60$55$:	LIB	?AFTIM	.ASCIZ	"1:1"	.EVEN60$:	COMP.W	D4,#10		; deux digits affichs ?	JUMP',HS 80$		; oui => 80$	LIB	?AFSPACE	; non => affiche encore un espace80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	POPM.L	D2..D4	RET;-----------\\; DESINFFILE >;===========/; Affiche le nom du fichier dans les informations.; in	-; out	-; mod	D7.WDESINFFILE:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A3,#(A6)+OBUNAME	LIB	?BUCAR		; mode rapide	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSFILE	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A0)+ODFDX	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb car dans toute la largeur	SUB.W	D4,#POSFILE	TEST.B	(A3)	JUMP',EQ 50$	COMP.B	(A3),#CR	JUMP',EQ 50$	LIB	?AFTIM	.B	'"		; guillemet au dbut	.B	AFTOUT	.B	0	.EVEN	SUB.W	D4,#2	LOAD.L	A4,#(A6)+OBUDIS	CALL	PUTINFFILE	; OBUDIS <-- nom du fichier	COMP.W	D3,D4	JUMP',LS 30$	ADD.W	A4,D3	SUB.W	A4,D4		; A4 <-- saute le dbut du nom	LOAD.B	(A4),#5		; dbut de nom <-- triangle "<"	LOAD.W	D3,D430$:	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le nom, ou seulement la fin	SUB.W	D4,D3		; D4 <-- lg restante	LIB	?AFTIM	.B	AFNORM	.B	'"		; guillemet  la fin	.B	0	.EVEN50$:	TEST.W	D4	JUMP',EQ 80$	LOAD.B	D3,#MSPACE	LIB	?AFCAR		; efface la fin	LOAD.B	D3,D4	LIB	?AFCAR80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?NOBUCAR	; mode normal	POPM.L	D2..D4,A3,A4	RET;-----------\\; PUTINFFILE >;-----------/; Prpare le nom du fichier  afficher.; in	A3.L	^nom;	A4.L	^buffer; out	D3.W	nb de caractres; mod	D3.L, D7.WPUTINFFILE:	PUSHM.L	D1,D2,A4	LOAD.W	D2,#2^BAFXMI	; D2 <-- affiche en minuscules	LOAD.W	D3,#100		; D3 <-- lg max	LOAD.L	D1,A4	LIB	?PUTXFILE	; OBUDIS <-- nom du fichier20$:	COMP.L	A4,D1	JUMP',EQ 30$	LOAD.B	D3,(-A4)	COMP.B	D3,#':	JUMP',EQ 30$	COMP.B	D3,#'.	JUMP,NE 20$	CLR.B	(A4)		; enlve l'extension30$:	LOAD.L	A4,D1	LOAD.W	D3,#-140$:	INC.W	D3	TEST.B	(A4+)	JUMP,NE 40$	POPM.L	D1,D2,A4	RET;---------\\; DESCADRE >;=========/; Dessine le cadre de la grande matrice, avec les ascenseurs; et la grille. Dessine aussi le "L" pour dlimiter le; petit rectangle.; in	-; out	-; mod	D7.WDESCADRE:	PUSHM.L	D2..D5,A5	CLR.L	D4	CALL	DRMDEF	LOAD.L	D3,(A6)+OWDOPY	LOAD.L	D4,(A6)+OWDODY	SUB.W	D3,#LGSCROLL-1	ADD.W	D4,#LGSCROLL-1	SWAP.W	D4	ADD.W	D4,#LGSCROLL-1	SWAP.W	D4	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface toute la grande matrice	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour grande matrice	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	LOAD.L	A5,#(A6)+OASVER	LOAD.W	D4,(A6)+OWDOPY	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OWDOPX	SUB.W	D4,#LGSCROLL	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OWDODY	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	CLR.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	LOAD.L	A5,#(A6)+OASHOR	LOAD.W	D4,(A6)+OWDOPX	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OWDOPY	ADD.W	D4,(A6)+OWDODY	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OWDODX	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	CALL	MAJCADRE	POPM.L	D2..D5,A5	RET;---------\\; MAJCADRE >;=========/; Met  jour le cadre (ascenseurs et rgles).; in	-; out	-; mod	D7.WMAJCADRE:	PUSHM.L	D3,D4,A5	LOAD.L	A5,#(A6)+OASVER	SCROLL_	DRAW		; dessine la cage verticale	CLR.W	(A5)+OSCHTV	CLR.W	(A5)+OSCPOSV	LOAD.W	D4,(A6)+ODESDY	CALL	D4SCALE	SUB.W	D4,(A6)+OWDODY	JUMP',LS 40$	LOAD.W	(A5)+OSCHTV,D4	LOAD.W	(A5)+OSCPOSV,(A6)+ODESPY	SCROLL_	UPDATE		; dessine la cabine verticale40$:	LOAD.L	A5,#(A6)+OASHOR	SCROLL_	DRAW		; dessine la cage horizontale	CLR.W	(A5)+OSCHTV	CLR.W	(A5)+OSCPOSV	LOAD.W	D4,(A6)+ODESDX	CALL	D4SCALE	SUB.W	D4,(A6)+OWDODX	JUMP',LS 60$	LOAD.W	(A5)+OSCHTV,D4	LOAD.W	(A5)+OSCPOSV,(A6)+ODESPX	SCROLL_	UPDATE		; dessine la cabine horizontale60$:	POPM.L	D3,D4,A5	RET;-------------\\; DOMASCENSEUR >;=============/; Agit dans les ascenseurs en fonction de la souris.; in	D4.L	position de la souris (y;x);	A1.L	^routine d'inversion/nil; out	D7.W	erreur; mod	D7.WDOMASCENSEUR:	PUSHM.L	D1,D4,A5	LOAD.L	D1,D4		; D1 <-- position de la souris	LOAD.L	A5,#(A6)+OASVER	TEST.W	(A5)+OSCHTV	JUMP',EQ 20$	LOAD.W	(A5)+OSCPOSV,(A6)+ODESPY	SCROLL_	MOVE		; dans ascenseur vertical ?	JUMP',NE 20$	TCLR.L	D4:#16		; D4 <-- avec rptition	CALL	ASCMOVEV	; dplace l'ascenseur vertical ...	CLR.W	D7		; D7 <-- ok	JUMP'	90$20$:	LOAD.L	D4,D1		; D4 <-- position de la souris	LOAD.L	A5,#(A6)+OASHOR	TEST.W	(A5)+OSCHTV	JUMP',EQ 80$	LOAD.W	(A5)+OSCPOSV,(A6)+ODESPX	SCROLL_	MOVE		; dans ascenseur horizontal ?	JUMP',NE 80$	TCLR.L	D4:#16		; D4 <-- avec rptition	CALL	ASCMOVEH	; dplace l'ascenseur horizontal ...	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	LOAD.W	D7,#190$:	POPM.L	D1,D4,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; ASCMOVEH >;=========/; Dplace l'ascenseur horizontal.; in	A5.L	^description ascenseur;	D4.L	SCROLL(F/P)(UP/DOWN);	A1.L	^routine d'inversion/nil; out	-; mod	D7.WASCMOVEH:	PUSHM.L	D2..D4	SCROLL_	PRESS		; allume le "bouton"	COMP.L	A1,#0	JUMP',EQ 06$	CALL	(A1)		; teint qq chose !06$:	LOAD.L	D2,D4		; D2 <-- "bouton" de l'ascenseur10$:	LOAD.W	D3,#+10		; D3 <-- +10 point	COMP.W	D2,#SCROLLFDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -10 point	COMP.W	D2,#SCROLLFUP	JUMP',EQ 50$	LOAD.W	D3,(A6)+OWDODX	DEC.W	D3		; D3 <-- +1 cran	COMP.W	D2,#SCROLLPDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -1 cran	COMP.W	D2,#SCROLLPUP	JUMP',EQ 50$; Dplacement absolu selon l'ascenseur.	LOAD.L	D4,(A6)+ODESPY	LOAD.W	D4,(A5)+OSCPOSV	CALL	ASCMOVE		; dplace la partie visible	JUMP'	80$; Dplacement selon la quantit dans D3.50$:	LOAD.L	D4,(A6)+ODESPY	ADD.W	D4,D3	CALL	ASCMOVE		; dplace la partie visible	TEST.L	D2:#16		; juste une fois ?	JUMP',BS 80$		; oui => 80$				; non =>	LIB	?IFCAR		; bouton relach ?	JUMP,NE 10$		; non => 10$80$:	LOAD.W	D4,D2	SCROLL_	PRESS		; teint le "bouton"	COMP.L	A1,#0	JUMP',EQ 86$	CALL	(A1)		; allume qq chose !86$:	POPM.L	D2..D4	RET;---------\\; ASCMOVEV >;=========/; Dplace l'ascenseur vertical.; in	A5.L	^description ascenseur;	D4.L	SCROLL(F/P)(UP/DOWN);	A1.L	^routine d'inversion/nil; out	-; mod	D7.WASCMOVEV:	PUSHM.L	D2..D4	SCROLL_	PRESS		; allume le "bouton"	COMP.L	A1,#0	JUMP',EQ 06$	CALL	(A1)		; teint qq chose !06$:	LOAD.L	D2,D4		; D2 <-- "bouton" de l'ascenseur10$:	LOAD.W	D3,#+10		; D3 <-- +10 point	COMP.W	D2,#SCROLLFDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -10 point	COMP.W	D2,#SCROLLFUP	JUMP',EQ 50$	LOAD.W	D3,(A6)+OWDODY	DEC.W	D3		; D3 <-- +1 cran	COMP.W	D2,#SCROLLPDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -1 cran	COMP.W	D2,#SCROLLPUP	JUMP',EQ 50$; Dplacement absolu selon l'ascenseur.	LOAD.L	D4,(A6)+ODESPY	SWAP.W	D4	LOAD.W	D4,(A5)+OSCPOSV	SWAP.W	D4	CALL	ASCMOVE		; dplace la partie visible	JUMP'	80$; Dplacement selon la quantit dans D3.50$:	LOAD.L	D4,(A6)+ODESPY	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D4	CALL	ASCMOVE		; dplace la partie visible	TEST.L	D2:#16		; juste une fois ?	JUMP',BS 80$		; oui => 80$				; non =>	LIB	?IFCAR		; bouton relach ?	JUMP,NE 10$		; non => 10$80$:	LOAD.W	D4,D2	SCROLL_	PRESS		; teint le "bouton"	COMP.L	A1,#0	JUMP',EQ 86$	CALL	(A1)		; allume qq chose !86$:	POPM.L	D2..D4	RET;--------\\; ASCMOVE >;--------/; Dplace la partie visible horizontalement ou verticalement.; in	A5.L	^description ascenseur;	D4.L	nouvelle position (y;x); out	-; mod	D7.WASCMOVE:	PUSHM.L	D3,D4	TEST.W	D4	JUMP',NC 20$	CLR.W	D420$:	COMP.W	D4,(A6)+OASHOR+OSCHTV	JUMP',LO 22$	LOAD.W	D4,(A6)+OASHOR+OSCHTV	JUMP',EQ 22$	DEC.W	D422$:	SWAP.W	D4	TEST.W	D4	JUMP',NC 30$	CLR.W	D430$:	COMP.W	D4,(A6)+OASVER+OSCHTV	JUMP',LO 32$	LOAD.W	D4,(A6)+OASVER+OSCHTV	JUMP',EQ 32$	DEC.W	D432$:	SWAP.W	D4	LOAD.L	(A6)+ODESPY,D4	LOAD.W	(A6)+OASHOR+OSCPOSV,D4	SWAP.W	D4	LOAD.W	(A6)+OASVER+OSCPOSV,D4	SCROLL_	UPDATE		; dplace l'ascenseur	CALL	DESCAR		; dessine le caractre	POPM.L	D3,D4	RET;---------\\; CALCADRE >;=========/; Calcul la position et les dimensions de la fentre principale.; in	-; out	(A6)+OWDOP?.W	fentre: coin sup/gauche;	(A6)+OWDOD?.W	fentre: dimensions; out	(A6)+OPETP?.W	petit: coin sup/gauche;	(A6)+OPETD?.W	petit: dimensions; mod	D7.WCALCADRE:	PUSH.L	D3	LOAD.W	D3,(A0)+ODFFDX	SUB.W	D3,#8+8	LOAD.W	D3,(A0)+ODFFDX	SUB.W	D3,#MARGX+(GCIMX+GCICX/2+GCIMX)*3+MARGX+LGSCROLL	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X	LOAD.W	(A6)+OWDODX,D3	LOAD.W	D3,(A0)+ODFFDY	SUB.W	D3,#MARGY+MARGY+LGSCROLL	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	AND.B	D3,#B'11111110	; D3 <-- modulo 2 en Y	LOAD.W	(A6)+OWDODY,D3	LOAD.W	D3,#8	LOAD.W	D3,#MARGX+(GCIMX+GCICX/2+GCIMX)*3+MARGX+LGSCROLL	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X	LOAD.W	(A6)+OWDOPX,D3	LOAD.W	D3,#MARGY	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	AND.B	D3,#B'11111110	; D3 <-- modulo 2 en Y	LOAD.W	(A6)+OWDOPY,D3	LOAD.W	(A6)+OPETDX,#100	LOAD.W	(A6)+OPETDY,#100	LOAD.W	D3,(A6)+OWDOPX	ADD.W	D3,(A6)+OWDODX	SUB.W	D3,(A6)+OPETDX	LOAD.W	(A6)+OPETPX,D3	LOAD.W	(A6)+OPETPY,(A6)+OWDOPY	POP.L	D3	RET;----------\\; NEXTSCALE >;==========/; Cherche l'chelle suivante ou prcdente.; in	D3.W	+1 si suivante, -1 si prcdente; out	D4.W	nouvelle chelle; mod	D4.L, D7.WNEXTSCALE:	PUSHM.L	D3,A4	LOAD.L	A4,#R16"TABLE$-2	LOAD.W	D4,(A6)+OSCALE	LOAD.W	D7,#120$:	ADD.L	A4,#2		; A4 <-- ^suivant	COMP.W	(A4),#-1	JUMP',EQ 90$	COMP.W	D4,(A4)	JUMP,NE 20$	ASL.W	D3,#1	LOAD.W	D4,(A4)+(D3.W)	COMP.W	D4,#-1	JUMP',EQ 90$	CLR.W	D790$:	POPM.L	D3,A4	TEST.W	D7		; retour EQ/NE	RET	.W	-1TABLE$:;;?	.W	-32;;?	.W	-24	.W	-16	.W	-12	.W	-8	.W	-6	.W	-4	.W	-3	.W	-2	.W	0	.W	+2	.W	+3	.W	+4	.W	+6	.W	+8	.W	+12	.W	+16;;?	.W	+24;;?	.W	+32	.W	-1;---------\\; NEWSCALE >;=========/; Change l'chelle.; in	D4.W	nouvelle chelle;	D3.L	centre partie visible (y;x) [pi]; out	-; mod	D7.WNEWSCALE:	PUSHM.L	D3,D4	LOAD.W	(A6)+OSCALE,D4	CLR.L	(A6)+ODESPY	CALL	CONVPIPG	; D3 <-- centre partie visible [pg]	LOAD.W	D4,(A6)+OWDODX	SR.W	D4,#1	SUB.W	D3,D4	JUMP',HS 30$	CLR.W	D330$:	LOAD.W	(A6)+ODESPX,D3	SWAP.W	D3	LOAD.W	D4,(A6)+OWDODY	SR.W	D4,#1	SUB.W	D3,D4	JUMP',HS 32$	CLR.W	D332$:	LOAD.W	(A6)+ODESPY,D3	CALL	MAJCADRE	; met  jour les ascenseurs	TEST.W	(A6)+OASVER+OSCHTV	JUMP',NE 40$	CLR.W	(A6)+ODESPY40$:	TEST.W	(A6)+OASHOR+OSCHTV	JUMP',NE 42$	CLR.W	(A6)+ODESPX42$:	CALL	DESCAR		; redessine le caractre	CALL	DESINFSC	; affiche l'chelle dans les informations	POPM.L	D3,D4	RET;--------\\; D4SCALE >;--------/; Tient compte de l'chelle.; in	D4.L	(y;x); out	D4.L	(y;x) plus petit si 1:n (vue d'ensemble);		(y;x) plus grand si n:1 (loupe); mod	D4.LD4SCALE:	PUSHM.L	D2,D3	LOAD.W	D2,(A6)+OSCALE	; chelle ngative (vue d'ensemble) ?	JUMP',EQ 90$	JUMP',NC 50$		; non => 50$				; oui =>	NEG.W	D2		; D2 <-- |chelle|	CLR.L	D3	LOAD.W	D3,D4	DIV.WU	D3,D2	LOAD.W	D4,D3		; D4 <-- x	SWAP.W	D4	CLR.L	D3	LOAD.W	D3,D4	DIV.WU	D3,D2	LOAD.W	D4,D3		; D4 <-- y	SWAP.W	D4	JUMP'	90$50$:	LOAD.W	D3,D4	MUL.WU	D3,D2	LOAD.W	D4,D3		; D4 <-- x	SWAP.W	D4	LOAD.W	D3,D4	MUL.WU	D3,D2	LOAD.W	D4,D3		; D4 <-- y	SWAP.W	D490$:	POPM.L	D2,D3	RET	.END