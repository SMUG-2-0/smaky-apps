	.SBTTL	XCARPETIT.ASI;--------\\; PETMOVE >;========/; Dplace la petite fentre.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WPETMOVE:	PUSHM.L	D2..D4	CALL	PETDET		; souris dans la petite fentre ?	JUMP',NE 90$		; non => 90$	COMP.B	(A6)+OOUTIL,#ICOMOVE	JUMP',NE 90$	JUMP'	30$20$:	CALL	WAITMOVE	; attend dplacement ...	JUMP',NE 80$	CALL	IFMOUSE	JUMP,NE 20$30$:	LOAD.W	D2,#INVDOT	CALL	PETCADRE	; efface l'ancien cadre	CALL	PETMOD	CALL	PETCADRE	; dessine le nouveau cadre	JUMP	20$80$:	CALL	DESCAR		; redessine le caractre	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PETDET  >;--------/; Regarde si la souris est dans la petite fentre.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WPETDET:	PUSHM.L	D3,D4	LOAD.W	D7,#1	LOAD.W	D3,(A6)+OPETPX	COMP.W	D4,D3	JUMP',LO 90$	ADD.W	D3,(A6)+OPETDX	COMP.W	D4,D3	JUMP',HS 90$	SWAP.W	D4	LOAD.W	D3,(A6)+OPETPY	COMP.W	D4,D3	JUMP',LO 90$	ADD.W	D3,(A6)+OPETDY	COMP.W	D4,D3	JUMP',HS 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PETMOD  >;--------/; Modifie la position et les dimensions de la petite fentre.; in	D4.L	position de la souris (y;x); out	-; mod	D7.WPETMOD:	PUSHM.L	D3,D4	LOAD.W	D3,(A6)+OWDOPX	ADD.W	D3,(A6)+OWDODX	SUB.W	D3,#10	COMP.W	D4,D3	JUMP',LS 20$	LOAD.W	D4,D320$:	LOAD.W	(A6)+OPETPX,D4	ADD.W	D3,#10	SUB.W	D3,D4	LOAD.W	(A6)+OPETDX,D3	SWAP.W	D4	LOAD.W	D3,(A6)+OWDOPY	ADD.W	D3,#10	COMP.W	D4,D3	JUMP',HS 30$	LOAD.W	D4,D330$:	SUB.W	D3,#10	SUB.W	D4,D3	LOAD.W	(A6)+OPETDY,D4	POPM.L	D3,D4	RET;--------\\; PETAFF  >;========/; Affiche le caractre rel en petit.; in	-; out	-; mod	D7.WPETAFF:	PUSHM.L	D1..D4,A1..A5	TEST.L	(A6)+OLSTC1	JUMP,EQ CADRE$	COMP.W	(A6)+OPETDX,#10	JUMP,LS CADRE$	COMP.W	(A6)+OPETDY,#10	JUMP,LS CADRE$	TEST.L	(A6)+OXCPGC	JUMP,EQ CADRE$	LOAD.L	A1,(A6)+OXCPGC	; A1 <-- ^en-tte gencar	ADD.L	A1,#256		; A1 <-- ^gencar	LOAD.L	D4,(A1)+oxcMODE	; D4 <-- fanions	TEST.L	D4:#bxcMODEFILL	JUMP,BC OUTL$	TEST.B	(A6)+OINFO+3:#BINFILLI-0	JUMP',BS FILL$	TEST.B	(A6)+OINFO+3:#BINFILLA-0	JUMP,BC OUTL$FILL$:	LOAD.W	D4,(A6)+OPETDX	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	MUL.WU	D4,(A6)+OPETDY	ADD.L	D4,#100	COMP.L	D4,(A6)+OPETLM	; matrice actuelle assez grande ?	JUMP',LS 22$		; oui => 22$	TEST.L	(A6)+OPETPM	JUMP',EQ 20$	LOAD.L	A4,(A6)+OPETPM	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancienne matrice	CLR.L	(A6)+OPETPM	CLR.L	(A6)+OPETLM20$:	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour nouvelle matrice	JUMP,NE CADRE$	LOAD.L	(A6)+OPETPM,A4	LOAD.L	(A6)+OPETLM,D422$:	LOAD.L	A2,#(A6)+ORGNDB	; A2 <-- ^descripteur bitmap	LOAD.L	(A2)+OGBMAPPT,(A6)+OPETPM	LOAD.W	D4,(A6)+OPETDX	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	LOAD.W	(A2)+OGBMAPWIDTH,D4	CLR.L	(A2)+OGBMAPRECT+OGRECTTL	LOAD.L	(A2)+OGBMAPRECT+OGRECTBR,(A6)+OPETDY	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+ORGNPT	; stack <-- ^identificateur rgion	PUSH.W	#GFILLXOR+GFILLINTERIOR ; stack <-- mode	PUSH.L	#(A6)+ORGNDB+OGBMAPRECT ; stack <-- ^cliprect	GMI_	OPENRGN		; A5 <-- ^dfinition rgion	POP.W	D7	JUMP,NE CADRE$	SET.B	(A6)+OPETIR	CALL	PETOUTLINE	; rgion <-- contour du caractre	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+ORGNPT	; stack <-- ^identificateur rgion	GMI_	CLOSERGN	POP.W	D7	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+ORGNPT	; stack <-- ^identificateur rgion	PUSH.L	#(A6)+ORGNDB	; stack <-- ^descripteur bitmap	PUSH.B	#GMCOPY		; stack <-- mode de transfert	GMI_	RGNTOBITMAP	POP.W	D7	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	CLR.L	(A3)+1	LOAD.L	(A3)+5,(A6)+OPETPM	LOAD.W	D4,(A6)+OPETDX	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	LOAD.W	(A3)+9,D4	LOAD.L	D3,(A6)+OPETPY	SWAP.W	D3	LOAD.L	(A3)+11,D3	CLR.L	(A3)+15	CLR.W	(A3)+19	LOAD.L	D3,(A6)+OPETDY	SWAP.W	D3	LOAD.L	(A3)+21,D3	LOAD.B	(A3)+25,#LOADDOT	LOAD.W	D3,#26	LIB	?STRING	LOAD.L	D4,(A1)+oxcMODE	; D4 <-- fanions	TEST.L	D4:#bxcMODEOUTL	JUMP',BC CADRE$	JUMP'	OUTL2$OUTL$:	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A6)+OPETPY	LOAD.L	D4,(A6)+OPETDY	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface le caractre prcdentOUTL2$:	CLR.B	(A6)+OPETIR	CALL	PETOUTLINE	; rgion <-- contour du caractreCADRE$:	LOAD.W	D2,#SETDOT	CALL	PETCADRE	; dessine le cadre	POPM.L	D1..D4,A1..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; PETCADRE >;=========/; Dessine le cadre de la petite fentre.; in	D2.W	mode; out	-; mod	D7.WPETCADRE:	PUSHM.L	D3,D4	LOAD.L	D3,(A6)+OPETPY	DEC.W	D3	LOAD.W	D4,(A6)+OPETDY	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	CLR.L	D4	LOAD.W	D4,(A6)+OPETDX	INC.W	D4	LIB	?DRSEG	POPM.L	D3,D4	RET;-----------\\; PETOUTLINE >;===========/; Dessine la "outline" d'un caractre.; in	-; out	-; mod	D7.WPETOUTLINE:	PUSHM.L	D6,A4	LOAD.L	D6,(A6)+OLSTC1	; D6 <-- canal de la liste	JUMP',EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	CALL	PETOBJET	; dessine un objet	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	POPM.L	D6,A4	RET;---------\\; PETOBJET >;---------/; Dessine un objet.; in	A4.L	^objet; out	-; mod	D7.WPETOBJET:	PUSHM.L	D3..D6	LOAD.W	D3,(A4)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.W	D3,#xcOPCURVE	JUMP',EQ CURVE$	COMP.W	D3,#xcOPADDCHAR	JUMP',EQ ADDCHAR$	JUMP'	EXIT$LINE$:	CALL	PETGETP2	; D3/D4 <-- Pp2/Ps2	LOAD.L	D5,D3	CALL	PETGETP1	; D3/D4 <-- Pp1/Ps1	LOAD.L	D4,D5	CALL	PETLINEG	JUMP'	EXIT$CURVE$:	CALL	PETGETP2	; D3/D4 <-- Pp2/Ps2	LOAD.L	D6,D3	LOAD.L	D5,D4	CALL	PETGETP1	; D3/D4 <-- Pp1/Ps1	CALL	PETCURVEG	JUMP'	EXIT$ADDCHAR$:	LOAD.L	D4,(A4)+OOBPP1	; D4 <-- dplacement	LOAD.B	D3,(A4)+OOBPP2	; D3 <-- caractre	CALL	PETADDCHAR;	JUMP'	EXIT$EXIT$:	POPM.L	D3..D6	RET;---------\\; PETGETP1 >;---------/; in	A4.L	^objet; out	D3.L	P1 (y;x)  [pg];	D4.L	S1 (y;x)  [pg]; mod	D3.L, D4.L, D7.WPETGETP1:	PUSHM.L	D1,D2	LOAD.L	D3,(A4)+OOBPS1	CALL	PETCONVP	LOAD.L	D4,D3		; D4 <-- Ps [pg]	TEST.L	(A4)+OOBRP1	JUMP',EQ ABS$	LOAD.L	D1,D4		; D1 <-- Ps brut [pg]	LOAD.L	D3,(A4)+OOBPP1	CALL	PETCONVP	LOAD.L	D2,D3		; D2 <-- Pp brut [pg]	LOAD.L	D3,(A4)+OOBPP1	LOAD.L	D4,(A4)+OOBRP1	CALL	RELCALCP	; D3 <-- Pp ajust [pg]	LOAD.L	D4,D1		; D4 <-- Ps brut [pg]	ADD.W	D4,D3	SUB.W	D4,D2	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SUB.W	D4,D2		; D4 <-- Ps ajust [pg]	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	JUMP'	EXIT$ABS$:	LOAD.L	D3,(A4)+OOBPP1	CALL	PETCONVP	; D3 <-- Pp [pg]EXIT$:	POPM.L	D1,D2	RET;---------\\; PETGETP2 >;---------/; in	A4.L	^objet; out	D3.L	P2 (y;x)  [pg];	D4.L	S2 (y;x)  [pg]; mod	D3.L, D4.L, D7.WPETGETP2:	PUSHM.L	D1,D2	LOAD.L	D3,(A4)+OOBPS2	CALL	PETCONVP	LOAD.L	D4,D3		; D4 <-- Ps [pg]	TEST.L	(A4)+OOBRP2	JUMP',EQ ABS$	LOAD.L	D1,D4		; D1 <-- Ps brut [pg]	LOAD.L	D3,(A4)+OOBPP2	CALL	PETCONVP	LOAD.L	D2,D3		; D2 <-- Pp brut [pg]	LOAD.L	D3,(A4)+OOBPP2	LOAD.L	D4,(A4)+OOBRP2	CALL	RELCALCP	; D3 <-- Pp ajust [pg]	LOAD.L	D4,D1		; D4 <-- Ps brut [pg]	ADD.W	D4,D3	SUB.W	D4,D2	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SUB.W	D4,D2		; D4 <-- Ps ajust [pg]	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	JUMP'	EXIT$ABS$:	LOAD.L	D3,(A4)+OOBPP2	CALL	PETCONVP	; D3 <-- Pp [pg]EXIT$:	POPM.L	D1,D2	RET;-----------\\; PETADDCHAR >;-----------/; Dessine un caractre non dcod.; in	D3.B	code du caractre;	D4.L	+/- dplacement (dy;dx); out	-; mod	D7.WPETADDCHAR:	PUSHM.L	D0..D6,A3,A4	LOAD.L	D0,D4		; D0 <-- dplacement	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	CLR.W	D4	LOAD.B	D4,D3	SL.W	D4,#2	LOAD.L	A4,#(A3)+oxcPCHAR	LOAD.L	D4,(A4)+(D4.W)	LOAD.L	A4,#(A3)+(D4.L)	; A4 <-- ^description du caractreLOOP$:	LOAD.B	D3,(A4+)	INC.L	A4	COMP.B	D3,#xcOPBEGIN	JUMP,EQ BEGIN$	COMP.B	D3,#xcOPLINE	JUMP,EQ LINE$	COMP.B	D3,#xcOPCURVE	JUMP,EQ CURVE$	COMP.B	D3,#xcOPADDCHAR	JUMP,EQ ADDCHAR$	COMP.B	D3,#xcOPFILLI	JUMP,EQ LOOP$	COMP.B	D3,#xcOPFILLA	JUMP,EQ LOOP$	COMP.B	D3,#xcOPPEN	JUMP,EQ PEN$	JUMP	END$BEGIN$:	CALL	PETADDCHARGET	LOAD.L	D1,D3	JUMP	LOOP$LINE$:	CALL	PETADDCHARGET	LOAD.L	D4,D3	LOAD.L	D3,D1	LOAD.L	D1,D4	ADD.W	D3,D0	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D0	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	CALL	PETLINE	JUMP	LOOP$CURVE$:	CALL	PETADDCHARGET	LOAD.L	D4,D3	CALL	PETADDCHARGET	LOAD.L	D5,D3	CALL	PETADDCHARGET	LOAD.L	D6,D3	LOAD.L	D3,D1	LOAD.L	D1,D6	ADD.W	D3,D0	ADD.W	D4,D0	ADD.W	D5,D0	ADD.W	D6,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	ADD.W	D3,D0	ADD.W	D4,D0	ADD.W	D5,D0	ADD.W	D6,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	CALL	PETCURVE	JUMP	LOOP$ADDCHAR$:	ADD.L	A4,#4+2		; pas de rcursion possible !	JUMP	LOOP$PEN$:	LOAD.W	D3,(A4+)	JUMP	LOOP$END$:	POPM.L	D0..D6,A3,A4	RET;--------------\\; PETADDCHARGET >;--------------/; Donne les coordonnes d'un point.; in	A4.L	^buffer; out	A4.L	^plus loin;	D3.L	point (y;x); mod	D3.L, D7.W, A4.LPETADDCHARGET:	PUSH.L	D4	EX.L	A4,A5	CALL	DECOGETPR	; D3/D4 <-- PP/RP (y;x)	EX.L	A5,A4	POP.L	D4	RET;--------\\; PETLINE >;--------/; Dessine une ligne droite.; in	D3.L	dpart (y;x)  [pi];	D4.L	arrive (y;x) [pi]; out	-; mod	D7.WPETLINE:	PUSHM.L	D3,D4	CALL	PETCONVP	; D3 <-- point [pg]	EX.L	D3,D4	CALL	PETCONVP	; D4 <-- point [pg]	EX.L	D3,D4	CALL	PETLINEG	POPM.L	D3,D4	RET;---------\\; PETLINEG >;---------/; Dessine une ligne droite.; in	D3.L	dpart (y;x)  [pg];	D4.L	arrive (y;x) [pg]; out	-; mod	D7.WPETLINEG:	PUSHM.L	D0..D4	LOAD.W	D0,D3	SWAP.W	D0	LOAD.L	D1,D3	LOAD.W	D2,D4	SWAP.W	D2	LOAD.L	D3,D4	LOAD.W	D4,#CHOUIA05	LOAD.W	D0,D4	LOAD.W	D1,D4	LOAD.W	D2,D4	LOAD.W	D3,D4	CALL	PETSEG	POPM.L	D0..D4	RET;---------\\; PETCURVE >;---------/; Dessine une courbe de bzier.; in	D3.L	P1 (y;x) [pi];	D4.L	P2 (y;x) [pi];	D5.L	P3 (y;x) [pi];	D6.L	P4 (y;x) [pi]; out	-; mod	D7.WPETCURVE:	PUSHM.L	D3..D6	CALL	PETCONVP	; D3 <-- point [pg]	EX.L	D3,D4	CALL	PETCONVP	; D4 <-- point [pg]	EX.L	D3,D4	EX.L	D3,D5	CALL	PETCONVP	; D5 <-- point [pg]	EX.L	D3,D5	EX.L	D3,D6	CALL	PETCONVP	; D6 <-- point [pg]	EX.L	D3,D6	CALL	PETCURVEG	POPM.L	D3..D6	RET;----------\\; PETCURVEG >;----------/; Dessine une courbe de bzier.; in	D3.L	P1 (y;x) [pg];	D4.L	P2 (y;x) [pg];	D5.L	P3 (y;x) [pg];	D6.L	P4 (y;x) [pg]; out	-; mod	D7.WPETCURVEG:	PUSHM.L	D3..D6,A1,A4	SUB.L	SP,#LBZ	LOAD.L	A4,SP		; A4 <-- ^variables sur le stack	LOAD.W	(A4)+OBZP1X+0,D3	SWAP.W	D3	LOAD.W	(A4)+OBZP1Y+0,D3	LOAD.W	(A4)+OBZC1X+0,D4	SWAP.W	D4	LOAD.W	(A4)+OBZC1Y+0,D4	LOAD.W	(A4)+OBZC2X+0,D5	SWAP.W	D5	LOAD.W	(A4)+OBZC2Y+0,D5	LOAD.W	(A4)+OBZP2X+0,D6	SWAP.W	D6	LOAD.W	(A4)+OBZP2Y+0,D6	LOAD.W	D3,#CHOUIA05	; D3 <-- p'tit chouia (0.5)	LOAD.W	(A4)+OBZP1X+2,D3	LOAD.W	(A4)+OBZP1Y+2,D3	LOAD.W	(A4)+OBZC1X+2,D3	LOAD.W	(A4)+OBZC1Y+2,D3	LOAD.W	(A4)+OBZC2X+2,D3	LOAD.W	(A4)+OBZC2Y+2,D3	LOAD.W	(A4)+OBZP2X+2,D3	LOAD.W	(A4)+OBZP2Y+2,D3	LOAD.L	A1,#R16"PETSEG	; A1 <-- ^routine "line"	CALL	BZDRAWQQ	; trace une courbe de bzier dans la rgion	ADD.L	SP,#LBZ	POPM.L	D3..D6,A1,A4	RET;--------\\; PETSEG  >;--------/; Trace une droite, avec les coordonnes donnes en rels.; in	D0/D1	dpart  (x;y);	D2/D3	arrive (x;y); out	-; mod	D7.WPETSEG:	TEST.B	(A6)+OPETIR	JUMP',EQ LINE$	PUSH.L	D0		; stack <-- dpart x	PUSH.L	D1		; stack <-- dpart y	PUSH.L	D2		; stack <-- arrive x	PUSH.L	D3		; stack <-- arrive y	SUB.L	SP,#2		; stack <-- rserve place pour erreur	PUSH.L	(A6)+ORGNPT	; stack <-- ^identificateur rgion	PUSH.L	#(SP)+4+2+8	; stack <-- ^dpart	PUSH.L	#(SP)+4+4+2+0	; stack <-- ^arrive	GMI_	PUTRLINE	POP.W	D7	ADD.L	SP,#4*4	JUMP'	EXIT$LINE$:	PUSHM.L	D0..D4	LOAD.L	D4,D3	SWAP.W	D2	LOAD.W	D4,D2	LOAD.L	D3,D1	SWAP.W	D0	LOAD.W	D3,D0	SUB.W	D4,D3	ADD.W	D3,(A6)+OPETPX	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ADD.W	D3,(A6)+OPETPY	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D0..D4EXIT$:	RET;---------\\; PETCONVP >;---------/; ; in	D3.L	point (y;x) [pi]; out	D3.L	point (y;x) [pg]; mod	D3.L, D7.WPETCONVP:	PUSHM.L	D2,D4,A3	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D2,D3		; D2 <-- x	SWAP.W	D3		; D3 <-- y	LOAD.W	D4,(A3)+oxcXMIN	NEG.W	D4	ADD.W	D2,D4		; D2 <-- x positif	LOAD.W	D4,(A3)+oxcYMIN	NEG.W	D4	ADD.W	D3,D4		; D3 <-- y positif;	LOAD.W	D4,(A3)+oxcYMIN;	NEG.W	D4	ADD.W	D4,(A3)+oxcYMAX	; D4 <-- largeur maximale [pi]	MUL.WA	D2,(A6)+OPETDY	DIV.WA	D2,D4	MUL.WA	D3,(A6)+OPETDY	DIV.WA	D3,D4	SWAP.W	D3	LOAD.W	D3,D2		; D3 <-- (y;x)	POPM.L	D2,D4,A3	RET;---------\\; PETCONVD >;---------/; ; in	D3.L	distance (dy;dx) [pi]; out	D3.L	distance (dy;dx) [pg]; mod	D3.L, D7.WPETCONVD:	PUSHM.L	D2,D4,A3	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	LOAD.W	D2,D3		; D2 <-- x	SWAP.W	D3		; D3 <-- y	LOAD.W	D4,(A3)+oxcYMIN	NEG.W	D4	ADD.W	D4,(A3)+oxcYMAX	; D4 <-- largeur maximale [pi]	MUL.WA	D2,(A6)+OPETDY	DIV.WA	D2,D4	MUL.WA	D3,(A6)+OPETDY	DIV.WA	D3,D4	SWAP.W	D3	LOAD.W	D3,D2		; D3 <-- (y;x)	POPM.L	D2,D4,A3	RET	.END