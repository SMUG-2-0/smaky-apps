	.SBTTL	XCARFRAG.ASI;---------------\\; _XCAR_FRAGMENT >;===============/; Fragmente un caractre.; in	A3.L	^gencar bitmap;	D3.W	code du caractre;	D4.L	position du centre (y;x);	A4.L	^routine (*);	A6.L	^variables de l'utilisateur; out	-; mod	D7.W; Description de la routine (*) :;; in	A6.L	^variables de l'utilisateur;	D3.L	P1 (y;x);	D4.L	P2 (y;x);	D5.L	P3 (y;x);	D6.L	P4 (y;x); out	-; mod	D7.W_XCAR_FRAGMENT:	PUSHM.L	D1,D3,D4,A2..A4,A6	LOAD.L	D1,A6	CALL	OPEVAR		; A6 <-- ^variables locales	JUMP,NE EXIT8$	LOAD.L	(A6)+OFRAPV,D1	; OFRAPV <-- ^variables utilisateur	LOAD.L	(A6)+OFRAPR,A4	; OFRAPR <-- ^routine utilisateur	LOAD.L	(A6)+OXCPOS,D4	LOAD.L	A4,(A3)+oxcbmPGCA	LOAD.L	(A6)+OXCPI,A4	CALL	CALCHTE		; D4 <-- hauteur du "E"	LOAD.W	(A6)+OXCIYE,D4	LOAD.L	A2,(A3)+oxcbmPDESC	LOAD.W	(A6)+OXCT,(A2)+odgbmCORPS	LOAD.L	(A6)+OXCPM,A2	LOAD.W	(A6)+OXCMOD,#XCMODFRAG	CALL	DECODE		; fragmente le caractre	CALL	CLOVAR		; rend les variablesEXIT8$:	POPM.L	D1,D3,D4,A2..A4,A6	TEST.W	D7		; retour EQ/NE	RET	.END