	.SBTTL	XCARDBOXT.ASI;---------\\; DBOXOPEN >;---------/; Ouvre une dbox.; in	A2.L	table;	D2.W	mode; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WDBOXOPEN:	PUSH.L	D3	CALL	DBOXOPEN1	CALL	DBOXPOS3	; D3 <-- centre de la dbox	DBOX_	OPEN		; ouvre la dbox	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETDBOXOPEN1:	PUSH.W	D3	CALL	SCMO		; remet la flche	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	NORMMOUSE	; remet la flche	POP.W	D3	RET;----------\\; DBOXCLOSE >;----------/; Ferme une dbox.; in	D5.L	canal; out	D7.W	erreur; mod	D7.WDBOXCLOSE:	DBOX_	CLOSE		; ferme la dboxDBOXCLOSE1:	CALL	AFMENU		; refait les soft-keys	RET;---------\\; DBOXPOS5 >;---------/; Centre ventuellement les dbox selon les icnes de gauche.; in	D2.W	mode d'ouverture; out	D2.W	mode d'ouverture;	D5.L	position (y;x); mod	D2.L, D5.L, D7.WDBOXPOS5:	PUSH.L	D3	CALL	DBOXPOS3	LOAD.L	D5,D3	POP.L	D3	RET;---------\\; DBOXPOS3 >;---------/; Centre ventuellement les dbox selon les icnes de gauche.; in	D2.W	mode d'ouverture; out	D2.W	mode d'ouverture;	D3.L	position (y;x); mod	D2.L, D3.L, D7.WDBOXPOS3:	LOAD.W	D3,(A6)+ODICO+0	ADD.W	D3,#ICOLY/2	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#1	TSET.L	D2:#BDBPOS	; D2 <-- centre selon D3.L	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs DBOX_EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>90$:	POP.L	A3	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET; Tables; ------TDBOX_DEF:	.W	10$-TDBOX_DEF	.W	20$-TDBOX_DEF	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Nom complet :    "	.B	ODBLABEL,0	.B	ODBLINE,(26)!2^7,KEYDBOX/H'100,0,TDBNORM	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Auteur :         "	.B	ODBLABEL,1	.B	ODBLINE,(26)!2^7,KEYDBOX/H'100,1,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Interligne :     "	.B	ODBLABEL,2	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,2,TDBNORM	.B	ODBTEXT	.ASCIZ	/  h = h("E")*i/	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Styles drivs : "	.B	ODBLABEL,3	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,3,TDBNORM	.B	ODBTEXT	.ASCIZ	" (normal,gras,ital,gras-ital)"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Taille min :     "	.B	ODBLABEL,4	.B	ODBCLINE,(2+2)!2^7,KEYDBOX/H'100,4,TDBNORM	.B	ODBTEXT	.ASCIZ	"  Gencar si <'<> min : "	.B	ODBLABEL,5	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,5,TDBNORM	.B	ODBTEXT	.ASCIZ	" (fsc)"	.B	ODBCR,ODBCR	.B	ODBSQUARE,bxcMODEFILL	.ASCIZ	" remplissage intrieur"	.B	ODBTABX,30	.B	ODBSQUARE,bxcMODELINK	.ASCIZ	" caractres lis"	.B	ODBCR	.B	ODBSQUARE,bxcMODEOUTL	.ASCIZ	" contour extrieur"	.B	ODBTABX,30	.B	ODBSQUARE,bxcMODELIMIT	.ASCIZ	" limite la largeur"	.B	ODBCR,ODBCR	.B	ODBLABEL,10	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,51	.B	ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEF:	.W	F1,F2,F3,0		DOKF1-TKEY_DEF	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DEF	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEF	.W	0TDBOX_INFO:	.W	10$-TDBOX_INFO	.W	20$-TDBOX_INFO	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Diamtre du pinceau :  "	.B	ODBCLINE,(4+2)!2^7,0,0,TDBNO