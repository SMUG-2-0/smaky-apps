	.SBTTL	XCARLIST.ASI;	--------------------------------------;		(C) 1989 - Daniel Roux;	--------------------------------------; Module de gestion de listes d'lments avec les proprits suivantes :;;  1)	Une liste peut contenir un nombre quelconque d'lments,;	limit seulement par la taille mmoire du SMAKY.;;  2)	Chaque lment peut avoir une longueur diffrente, comprise;	entre 1 et 65'000 bytes.;;  3)	Un lment peut contenir des pointeurs, car il n'est jamais;	dplac. Il est ainsi ais de raliser des listes de listes !;;  4)	La liste est ordonne, avec une tte et une queue. Par dfaut,;	un lment est insr  la tte. Un lment peut tre rapidement;	plac en tte ou en queue de liste.;;  5)	La mmoire est rserve et libre automatiquement, non pas;	pour chaque lment, mais pour un ensemble d'lments. On;	spcifie la longueur d'un bloc mmoire lors de l'ouverture.;	Toutefois, un lment peut trs bien tre plus grand que la;	longueur d'un bloc mmoire.;;  6)	En plus de la taille d'un lment, les listes utilisent 12 bytes;	pour chaque lment.; Une liste est matrialise par deux chanes :;;	OlistUSE	chane des lments utiliss;	OlistFREE	chane des lments libres;; Un lment est chan soit dans la chane des libres, soit dans la; chane des utiliss. Jamais dans les deux, et jamais dans aucune.; Les lments libres sont tris en fonction de leurs adresses; (queue -> adresses basses et tte -> adresses hautes). Ceci permet; de garantir que, quelque soit l'ordre, deux lments contigus librs; pourront toujours fusionner en un seul lment, afin d'viter le; morcellement de la mmoire. En effet, il n'est prvu aucun "ramasse; miettes" visant  compacter les lments utiliss pour n'avoir plus; qu'un seul grand trou. De toute faon, ceci n'est pas souhaitable,; car les lments peuvent contenir des pointeurs  d'autres lments.;;;	      descripteur d'une chane vide;	   +---------------+;	   |               |;	   |   +-------+   |;	   +-->|     o-|---+     NEXT;	       +-------+;	   +---|-o     |<--+     PREV;	   |   +-------+   |;	   |               |;	   +---------------+;;;	      descripteur       lment         lment;	   +-----------------------------------------------+;	   |                                               |;	   |   +-------+       +-------+       +-------+   |;	   +-->|     o-|------>|     o-|------>|     o-|---+     OlichNEXT;	       +-------+       +-------+       +-------+;	   +---|-o     |<------|-o     |<------|-o     |<--+     OlichPREV;	   |   +-------+       +-------+       +-------+   |;	   |                   |       |       |       |   |     OlichLGDATA;	   |                   +-------+       +-------+   |;	   |                   |       |       |       |   |     OlichLGBMEM;	   |                   +-------+       +-------+   |;	   |              A4-->|       |       |       |   |;	   |                   |  ...  |       |  ...  |   |     donnes de l'lment;	   |                   |       |       |       |   |;	   |                   |       |       +-------+   |;	   |                   +-------+                   |;	   |                                               |;	   +-----------------------------------------------+; Descripteur d'une chane; ------------------------		.PC	PCVARLlich		=	4+4+2+2		.LOC	-LlichOlichNEXT:	.BLKB	4		; ^suivantOlichPREV:	.BLKB	4		; ^prcdentOlichLGDATA:	.BLKB	2		; longueur lmentOlichLGBMEM:	.BLKB	2		; longueur bloc mmoire; Descripteur d'une liste; -----------------------		.PC	PCVARLlist		=	2+4+Llich+Llich		.LOC	-LlistOlistLGBMEM:	.BLKB	2		; longueur pour bloc mmoireOlistMODE:	.BLKB	4		; mode de la liste		.BLKB	Llich		; chane des libresOlistFREE:		.BLKB	Llich		; chane des utiliss (doit tre en dernier)OlistUSE:		.PC	PCCODE;-----------\\; _OBJ_LOPEN >;===========/; Ouvre une nouvelle liste vide.; in	D3.L	mode (zro par dfaut);	D4.W	longueur d'un bloc mmoire;		 0 => longueur standard (1000 bytes);		-1 => maximum possible (65522 bytes); out	D6.L	canal de la liste;	D7.W	erreur; mod	D6.L, D7.W_OBJ_LOPEN:	PUSHM.L	D1..D4,A4,A6	TEST.W	D4	JUMP',NE 20$	LOAD.W	D4,#1000		; D4 <-- longueur par dfaut20$:	COMP.W	D4,#(2^16)-Llich-2	JUMP',LS 22$	LOAD.W	D4,#(2^16)-Llich-222$:	INC.W	D4	TCLR.L	D4:#0			; D4 <-- arrondi au multiple de 2 suprieur	ADD.W	D4,#Llich	LOAD.W	D2,D4	LOAD.L	D4,#Llist		; D4 <-- lg pour descripteur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM			; A4 <-- mmoire pour descripteur liste	JUMP',NE 90$	LOAD.L	A6,#(A4)+Llist		; A6 <-- ^descripteur	LOAD.L	(A6)+OlistMODE,D3	; OlistMODE <-- mode (inutilis)	LOAD.W	(A6)+OlistLGBMEM,D2	; OlistLGBMEM <-- lg d'un bloc mmoire	LOAD.L	A4,#(A6)+OlistFREE	LOAD.L	(A4)+OlichNEXT,A4	; chane des libres vide	LOAD.L	(A4)+OlichPREV,A4	LOAD.L	(A6)+OlichNEXT,A6	; chane des utiliss vide	LOAD.L	(A6)+OlichPREV,A6	LOAD.L	D6,A6			; D6 <-- canal90$:	POPM.L	D1..D4,A4,A6	TEST.W	D7			; retour EQ/NE	RET;------------\\; _OBJ_LCLOSE >;============/; Termine l'utilisation d'une liste.; Si la liste contient encore des lments, ils sont supprims,; et les blocs mmoires correspondants sont librs.; in	D6.L	canal de la liste; out	-; mod	D7.W_OBJ_LCLOSE:	PUSHM.L	D1,A3,A4,A6	LOAD.L	A6,D6			; A6 <-- ^descripteur liste20$:	LOAD.L	A4,(A6)+OlichPREV	COMP.L	A4,A6			; dbut de la liste ?	JUMP',EQ 50$			; oui => 50$					; non =>	CALL	_OBJ_LREMOVE		; libre un lment	JUMP	20$50$:	LOAD.L	A4,#(A6)-Llist	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM			; libre mmoire pour descripteur liste	POPM.L	D1,A3,A4,A6	RET;-------------\\; _OBJ_LINSERT >;=============/; Ajoute un lment n'importe o dans la liste.; Si cela est ncessaire, un nouveau bloc mmoire est allou.; in	D4.W	longueur de l'lment;	A4.L	^lment avant lequel insrer (si zro =>  la tte);	D6.L	canal de la liste; out	A4.L	^lment initialis avec des zro;	D7.W	erreur; mod	D7.W, A4.L_OBJ_LINSERT:	PUSHM.L	D1..D4,A0..A3,A6	LOAD.L	A6,D6			; A6 <-- ^descripteur liste	INC.W	D4	TCLR.L	D4:#0			; D4 <-- arrondi au multiple de 2 suprieur	ADD.W	D4,#Llich		; D4 <-- lg pour l'lment	LOAD.W	D2,D4	LOAD.L	A0,A4; Cherche un trou ayant exactement la bonne longueur en parcourant; la chane des lments libres.20$:	LOAD.W	D4,D2	LOAD.L	A3,#(A6)+OlistFREE	LOAD.L	A4,(A3)+OlichPREV22$:	COMP.L	A4,A3			; fin de la chane ?	JUMP',EQ 30$			; oui => 30$	COMP.W	D4,(A4)+OlichLGDATA	; juste la bonne place ici ?	JUMP',EQ 40$			; oui => 40$	LOAD.L	A4,(A4)+OlichPREV	; A4 <-- ^suivant	JUMP	22$; Cherche un trou pouvant se transformer en deux (un lment suivi d'un trou); en parcourant la chane des lments libres.30$:	ADD.W	D4,#Llich		; D4 <-- lg minimale pour ddoubler un lment;	LOAD.L	A3,#(A6)+OlistFREE	LOAD.L	A4,(A3)+OlichPREV32$:	COMP.L	A4,A3			; fin de la chane ?	JUMP',EQ 36$			; oui => 36$	COMP.W	D4,(A4)+OlichLGDATA	; assez (mais trop) de place ici ?	JUMP',LS 50$			; oui => 50$	LOAD.L	A4,(A4)+OlichPREV	; A4 <-- ^suivant	JUMP	32$36$:	CLR.L	D4	LOAD.W	D4,(A6)+OlistLGBMEM	; D4 <-- longueur d'un bloc	COMP.W	D4,D2			; lment  ajouter plus grand ?	JUMP',HS 37$			; non => 37$	LOAD.W	D4,D2			; D4 <-- longueur ncessaire pour l'lment37$:	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM			; demande mmoire pour nouveau bloc	JUMP,NE 90$	LOAD.L	A4,#(A4)+Llich	LOAD.W	(A4)+OlichLGDATA,D4	LOAD.W	(A4)+OlichLGBMEM,D4	CALL	ADDFREE			; ajoute  la chane des libres	JUMP	20$; Remplace le trou par un lment ayant exactement la mme longueur.40$:					; juste la place =>	CALL	SUBLINK			; enlve de la chane des libres	JUMP'	55$; Remplace le trou par un lment suivit d'un trou plus petit.50$:					; trop de place =>	SUB.W	D4,#Llich		; D4 <-- lg pour l'lment	LOAD.L	A3,(A4)+OlichNEXT	LOAD.L	A2,(A4)+OlichPREV	LOAD.L	A1,#(A4)+(D4.W)	LOAD.W	D3,(A4)+OlichLGDATA	SUB.W	D3,D4	LOAD.W	(A1)+OlichLGDATA,D3	CLR.W	(A1)+OlichLGBMEM	LOAD.L	(A1)+OlichPREV,A2	LOAD.L	(A1)+OlichNEXT,A3	LOAD.L	(A3)+OlichPREV,A1	LOAD.L	(A2)+OlichNEXT,A1	LOAD.W	(A4)+OlichLGDATA,D455$:	LOAD.L	A3,A6			; A3 <-- ajoute  la fin de la chane (devant)	COMP.L	A0,#0	JUMP',EQ 56$	LOAD.L	A3,A0			; A3 <-- ajoute n'importe o56$:	CALL	ADDLINK			; ajoute  la chane des utiliss; Rempli l'lment avec des zros.	LOAD.L	A3,A4			; A3 <-- ^dbut du data	LOAD.W	D4,(A4)+OlichLGDATA	; D4 <-- lg de l'lment	SUB.W	D4,#Llich		; D4 <-- n'efface pas le dbut	SR.W	D4,#1			; D4 <-- /2 car .W	DEC.W	D4			; D4 <-- -1 car NMO	CLR.W	D3			; D3 <-- pour effacer plus vite que CLR.W (A3+) !60$:	LOAD.W	(A3+),D3		; efface le data	DECJ.W,NMO D4,60$	CLR.W	D7			; D7 <-- ok90$:	POPM.L	D1..D4,A0..A3,A6	TEST.W	D7			; retour EQ/NE	RET;-------------\\; _OBJ_LREMOVE >;=============/; Supprime un lment dans la liste.; S'il existe un bloc mmoire ne contenant plus aucun lment,; il est libr.; in	A4.L	^lment;	D6.L	canal de la liste; out	D7.W	erreur; mod	D7.W_OBJ_LREMOVE:	PUSHM.L	D1,A4,A6	LOAD.L	A6,D6			; A6 <-- ^descripteur liste	CALL	SUBLINK			; enlve de la chane des utiliss	CALL	ADDFREE			; ajoute  la chane des libres; Essaye plusieurs fois d'appondre le trou au suivant et/ou; au prcdent.40$:	CALL	APPEND			; essaye d'appondre deux trous	JUMP,NE 40$			; si fait qq chose => essaye encore; Regarde s'il faut rendre une tranche mmoire.	LOAD.W	D1,(A4)+OlichLGDATA	COMP.W	D1,(A4)+OlichLGBMEM	JUMP',NE 90$	CALL	SUBLINK			; supprime de la chane des libres	LOAD.L	A4,#(A4)-Llich	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM			; rend la tranche mmoire90$:	POPM.L	D1,A4,A6	CLR.W	D7			; retour EQ	RET;--------\\; ADDFREE >;--------/; Ajoute un lment dans la liste des libres.; Cherche l'endroit o ajouter dans la chane des libres, pour; que cette chane soit trie en fonction des adresses.; in	A4.L	^lment; out	-; mod	-ADDFREE:	PUSHM.L	A2,A3	LOAD.L	A2,#(A6)+OlistFREE	LOAD.L	A3,(A2)+OlichPREV20$:	COMP.L	A3,A2			; dbut de la chane ?	JUMP',EQ 30$			; oui => 30$	COMP.L	A4,A3	JUMP',HI 30$	LOAD.L	A3,(A3)+OlichPREV	; A3 <-- ^prcdent	JUMP	20$30$:	LOAD.L	A3,(A3)+OlichNEXT	; A3 <-- ^suivant	CALL	ADDLINK			; ajoute  la chane des libres	POPM.L	A2,A3	RET;--------\\; APPEND  >;--------/; Tente d'appondre un trou au suivant et/ou au prcdent.; in	A4.L	^trou; out	A4.L	^trou appondu avec un autre;	D7.W	EQ => rien n'a t appondu; mod	D7.W, A4.LAPPEND:	PUSHM.L	D3,A2,A3	CLR.W	D7			; D7 <-- rien fait; Si l'lment devenu trou est suivi d'un autre trou, fusionne les deux; trous en un seul.	LOAD.L	A3,A4	ADD.W	A3,(A4)+OlichLGDATA	COMP.L	A3,(A4)+OlichPREV	; trou juste aprs ?	JUMP',NE 20$			; non => 20$					; oui =>	LOAD.W	D3,(A3)+OlichLGDATA	ADD.W	(A4)+OlichLGDATA,D3	LOAD.L	A2,(A3)+OlichPREV	LOAD.L	(A4)+OlichPREV,A2	LOAD.L	(A2)+OlichNEXT,A4	INC.W	D7			; D7 <-- deux trous appondus	JUMP'	30$20$:	LOAD.L	A3,A4	ADD.W	A3,(A4)+OlichLGDATA	COMP.L	A3,(A4)+OlichNEXT	; trou juste aprs ?	JUMP',NE 30$			; non => 30$					; oui =>	LOAD.W	D3,(A3)+OlichLGDATA	ADD.W	(A4)+OlichLGDATA,D3	LOAD.L	A2,(A3)+OlichNEXT	LOAD.L	(A4)+OlichNEXT,A2	LOAD.L	(A2)+OlichPREV,A4	INC.W	D7			; D7 <-- deux trous appondus; Si l'lment devenu trou est prcd d'un autre trou, fusionne les deux; trous en un seul.30$:	LOAD.L	A3,(A4)+OlichPREV	ADD.W	A3,(A3)+OlichLGDATA	COMP.L	A3,A4			; trou juste avant ?	JUMP',NE 40$			; non => 40$					; oui =>	LOAD.L	A3,(A4)+OlichPREV	LOAD.W	D3,(A4)+OlichLGDATA	ADD.W	(A3)+OlichLGDATA,D3	LOAD.L	A2,(A4)+OlichNEXT	LOAD.L	(A3)+OlichNEXT,A2	LOAD.L	(A2)+OlichPREV,A3	LOAD.L	A4,A3	INC.W	D7			; D7 <-- deux trous appondus	JUMP'	90$40$:	LOAD.L	A3,(A4)+OlichNEXT	ADD.W	A3,(A3)+OlichLGDATA	COMP.L	A3,A4			; trou juste avant ?	JUMP',NE 90$			; non => 90$					; oui =>	LOAD.L	A3,(A4)+OlichNEXT	LOAD.W	D3,(A4)+OlichLGDATA	ADD.W	(A3)+OlichLGDATA,D3	LOAD.L	A2,(A4)+OlichPREV	LOAD.L	(A3)+OlichPREV,A2	LOAD.L	(A2)+OlichNEXT,A3	LOAD.L	A4,A3	INC.W	D7			; D7 <-- deux trous appondus90$:	POPM.L	D3,A2,A3	TEST.W	D7			; retour EQ/NE	RET;-----------\\; _OBJ_LHEAD >;===========/; Place un lment en tte de liste.; in	A4.L	^lment;	D6.L	canal de la liste; out	D7.W	erreur; mod	D7.W_OBJ_LHEAD:	PUSHM.L	A3,A4,A6	LOAD.L	A6,D6			; A6 <-- ^descripteur liste	CALL	SUBLINK			; supprime de la chane	LOAD.L	A3,(A6)+OlichNEXT	CALL	ADDLINK			; remet au dbut de la chane	POPM.L	A3,A4,A6	CLR.W	D7			; D7 <-- ok	RET;-----------\\; _OBJ_LTAIL >;===========/; Place un lment en queue de liste.; in	A4.L	^lment;	D6.L	canal de la liste; out	D7.W	erreur; mod	D7.W_OBJ_LTAIL:	PUSHM.L	A3,A4,A6	LOAD.L	A6,D6			; A6 <-- ^descripteur liste	CALL	SUBLINK			; supprime de la chane	LOAD.L	A3,A6			; A3 <-- ajoute  la fin de la chane	CALL	ADDLINK			; remet  la fin de la chane	POPM.L	A3,A4,A6	CLR.W	D7			; D7 <-- ok	RET;------------\\; _OBJ_LFIRST >;============/; Cherche le premier lment (celui  la queue de la liste).; in	D6.L	canal de la liste; out	A4.L	^premier lment;	D7.W	erreur; mod	D7.W, A4.L_OBJ_LFIRST:	LOAD.L	A4,D6			; A4 <-- ^descripteur liste	COMP.L	A4,(A4)+OlichNEXT	; premier lment existe ?	JUMP',EQ 80$			; non => 80$	LOAD.L	A4,(A4)+OlichNEXT	; A4 <-- ^lment	CLR.W	D7			; D7 <-- ok	RET80$:	LOAD.W	D7,#1			; D7 <-- erreur	RET;-----------\\; _OBJ_LLAST >;===========/; Cherche le dernier lment (celui  la tte de la liste).; in	D6.L	canal de la liste; out	A4.L	^dernier lment;	D7.W	erreur; mod	D7.W, A4.L_OBJ_LLAST:	LOAD.L	A4,D6			; A4 <-- ^descripteur liste	COMP.L	A4,(A4)+OlichPREV	; dernier lment existe ?	JUMP',EQ 80$			; non => 80$	LOAD.L	A4,(A4)+OlichPREV	CLR.W	D7			; D7 <-- ok	RET80$:	LOAD.W	D7,#1			; D7 <-- erreur	RET;-----------\\; _OBJ_LNEXT >;===========/; Cherche l'lment suivant, en allant de la queue  la tte de la liste.; in	A4.L	^lment;	D6.L	canal de la liste; out	A4.L	^lment suivant;	D7.W	erreur; mod	D7.W, A4.L_OBJ_LNEXT:	COMP.L	D6,(A4)+OlichNEXT	; est-on  la fin ?	JUMP',EQ 80$			; oui => 80$					; non =>	LOAD.L	A4,(A4)+OlichNEXT	; A4 <-- ^lment suivant	CLR.W	D7			; D7 <-- ok	RET80$:	LOAD.W	D7,#1			; D7 <-- erreur	RET;-----------\\; _OBJ_LPREV >;===========/; Cherche l'lment prcdent, en allant de la tte  la queue de la liste.; in	A4.L	^lment;	D6.L	canal de la liste; out	A4.L	^lment prcdent;	D7.W	erreur; mod	D7.W, A4.L_OBJ_LPREV:	COMP.L	D6,(A4)+OlichPREV	; est-on au dbut ?	JUMP',EQ 80$			; oui => 80$					; non =>	LOAD.L	A4,(A4)+OlichPREV	; A4 <-- ^lment prcdent	CLR.W	D7			; D7 <-- ok	RET80$:	LOAD.W	D7,#1			; D7 <-- erreur	RET;--------\\; ADDLINK >;--------/; Ajoute un lment dans une chane.; in	A3.L	^lment de base (ou n'importe lequel);	A4.L	^lment  ajouter; out	-; mod	-ADDLINK:	PUSH.L	A2	LOAD.L	A2,(A3)+OlichPREV	LOAD.L	(A3)+OlichPREV,A4	LOAD.L	(A2)+OlichNEXT,A4	LOAD.L	(A4)+OlichPREV,A2	LOAD.L	(A4)+OlichNEXT,A3	POP.L	A2	RET;--------\\; SUBLINK >;--------/; Supprime un lment dans une chane.; in	A4.L	^lment  supprimer; out	-; mod	-SUBLINK:	PUSHM.L	A2,A3	LOAD.L	A2,(A4)+OlichNEXT	; A2 <-- ^lment suivant	LOAD.L	A3,(A4)+OlichPREV	; A3 <-- ^lment prcdent	LOAD.L	(A2)+OlichPREV,A3	LOAD.L	(A3)+OlichNEXT,A2	POPM.L	A2,A3	RET	.END