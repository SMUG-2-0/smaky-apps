	.TITLE	NAMEGENC.ASC;	--------------------------------------;		(C) 1989 - Daniel Roux;	--------------------------------------;	Source du programme NAMEGENC.CODE;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 1.2	05.07.89	cre SMA_GENC.INFO avec LIB ?ADDNGC; 1.1	14.06.89	rgnre les en-ttes si ncessaire; 1.0	20.04.89	premire (et dernire ?) version	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	GENCAR;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;LIB?FLUSHNGC = LIB_BASE+147LIB?ADDNGC = LIB_BASE+148LIB?SUBNGC = LIB_BASE+149LIB?MAJNGC = LIB_BASE+150LIB?GETREVL = LIB_BASE+59;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;MAJREV	=	1		; rvisionMINREV	=	2		; version	.REV	MAJREV,MINREV	.CODE	800,11,B'1111,20,2000,20,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"	.LOC	0OBUFF:	.BLKB	256LGVAR:	.LOC	0START:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CLR.W	D4	LIB	?WAITMOUSE	; met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LIB	?AFTIM	.B	EOP,NOCURS	.B	0	.EVEN	LOAD.W	D4,#H'AAAA	LIB	?GETREVL	; D4 <-- rvision de la librairue	COMP.W	D4,#H'AAAA	JUMP,EQ REVKO	COMP.W	D4,#H'100*5+15	; au moins 5.15	JUMP,LO REVKO		; non => REVKO	LIB	?AFTIM	.ASCIZ	"<CR>Effectue la liste de tous les gnrateurs de caractres ...<CR>"	.EVEN	LIB	?FLUSHNGC	; poutz tout	LOAD.L	A3,#R16"TXDIR	LOAD.L	A4,#R16"TXCRIT	LOAD.L	D3,#2^BOPSYS	FOS	?LISTOPEN	JUMP,NE ERROR40$:	FOS	?LISTNXT	; A3/A4 <-- ^nom/^arguments	JUMP,NE 60$	CALL	HEADGENC	CALL	NAMEGENC	JUMP	40$60$:	FOS	?LISTCLOSE	LIB	?AFTIM	.ASCIZ	"<CR><CR>Travail effectu correctement."	.EVEN	LOAD.W	D4,#50*2	NTREL	?DELMS	JUMP	ERFAT1REVKO:	LIB	?AFTIM	.ASCII	"<CR><CR>Le systme n'est pas  jour !!!<CR>"	.ASCII	"<CR>"	.ASCII	"Dupliquez un systme contenant une librairie 5.15 ou suprieure,<CR>"	.ASCII	"puis redmarrez avant d'excuter NAMEGENC.<CR>"	.ASCII	"<CR>"	.ASCIZ	"Appuyez sur une touche ...<CR>"	.EVEN	LIB	?GETCAR	JUMP	ERFAT1ERROR:	PUSH.W	D7	LIB	?AFTIM	.ASCIZ	"<CR><CR>Erreur rencontre: <AFINV>"	.EVEN	POP.W	D7	LIB	?AFERROR	LIB	?AFTIM	.ASCIZ	"<AFDIR><CR>Appuyez sur une touche ..."	.EVEN	LIB	?GETCARERFAT1:	LIB	?CLOLIB	FOS	?STOP;---------\\; HEADGENC >;=========/; ; in	A3.L	^nom du fichier gencar; out	-; mod	D7.WHEADGENC:	PUSHM.L	D2,D3,D4,D6,A3,A4	LOAD.W	D3,#2^BOPWR!2^BOPRD!2^BOPEXCL!2^BOPSYS	FOS	?OPEN	JUMP,NE 90$	CLR.W	D3	LOAD.L	D4,#256	FOS	?SPOS	JUMP,NE 80$	LOAD.L	A4,#(A6)+OBUFF	LOAD.L	D4,#256	FOS	?RDBYTE	JUMP,NE 80$	CLR.W	D2	LOAD.L	A4,A320$:	LOAD.B	D3,(A4+)	JUMP,EQ 30$	COMP.B	D3,#'_	JUMP,NE 20$	COMP.B	(A4)+3,#'0	JUMP,NE 25$	COMP.B	(A4)+4,#'0	JUMP,EQ 30$25$:	LOAD.L	A4,#(A6)+OBUFF	TEST.L	(A4)		; oxcIDENT nul ?	JUMP,EQ 30$	CLR.L	(A4)	INC.W	D230$:	LOAD.L	A4,#(A6)+OBUFF	LOAD.W	D3,#OGCIDE	LOAD.W	D4,#OGCTXT	CALL	TEXTOK	ADD.W	D2,D7	LOAD.W	D3,#OGCTXT	LOAD.W	D4,#OGCCNM	CALL	TEXTOK	ADD.W	D2,D7	LOAD.W	D3,#OGCCNM	LOAD.W	D4,#OGCWID	CALL	TEXTOK	ADD.W	D2,D7	JUMP,EQ 80$	CLR.W	D3	LOAD.L	D4,#256	FOS	?SPOS	JUMP,NE 80$	LOAD.L	A4,#(A6)+OBUFF	LOAD.L	D4,#256	FOS	?WRBYTE	JUMP,NE 80$	FOS	?CLOSE	JUMP,NE 85$	LOAD.B	D3,#CR	LIB	?AFCAR	PUSH.L	A3	LIB	?AFTEXT		; affiche le nom du gencar	POP.L	A3	LIB	?AFTIM	.ASCIZ	" --<'>> en-tte rgnre"	.EVEN	JUMP	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D785$:	LOAD.W	D4,D7	JUMP,EQ 90$	LOAD.B	D3,#CR	LIB	?AFCAR	PUSH.L	A3	LIB	?AFTEXT		; affiche le nom du gencar	POP.L	A3	LIB	?AFTIM	.ASCIZ	" --<'>> impossible de rgnrer l'en-tte <AFINV>"	.EVEN	LOAD.W	D7,D4	LIB	?AFERROR	LOAD.B	D3,#AFDIR	LIB	?AFCAR90$:	POPM.L	D2,D3,D4,D6,A3,A4	RET;--------\\; TEXTOK  >;--------/; ; in	A4.L	^en-tte;	D3.W	offset dbut;	D4.W	offset fin; out	D7.W	nb de fautes; mod	D7.WTEXTOK:	PUSHM.L	D3,D4,A4	ADD.W	A4,D3		; A4 <-- ^dbut du texte	SUB.W	D4,D3		; D4 <-- lg	CLR.W	D7		; D7 <-- ok20$:	DEC.W	D4	JUMP,NS 90$	LOAD.B	D3,(A4+)	JUMP,EQ 40$	COMP.B	D3,#CR	JUMP,NE 20$	CLR.B	(A4)-1	INC.W	D7		; D7 <-- pas correct40$:	DEC.W	D4	JUMP,NS 90$	LOAD.B	D3,(A4+)	JUMP,EQ 40$	CLR.B	(A4)-1	INC.W	D7		; D7 <-- pas correct	JUMP	40$90$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; NAMEGENC >;=========/; ; in	A3.L	^nom du fichier gencar; out	-; mod	D7.WNAMEGENC:	PUSHM.L	D3..D5,A2..A4	LOAD.B	D3,#CR	LIB	?AFCAR	PUSH.L	A3	LIB	?AFTEXT		; affiche le nom du gencar	POP.L	A3	LIB	?AFTIM	.ASCIZ	" --<'>> "	.EVEN	LOAD.L	A2,#R16"ERR1$	LOAD.L	A4,A315$:	LOAD.B	D3,(A4+)	JUMP,EQ 80$	COMP.B	D3,#'_	JUMP,NE 15$	LOAD.B	D3,(A4+)	; D3 <-- fonte	LOAD.B	D4,(A4+)	; D4 <-- style	LOAD.L	A4,#R16"TABLE20$:	TEST.B	(A4)		; fin de la table ?	JUMP,EQ 60$	COMP.B	D3,(A4+)	JUMP,NE 30$	COMP.B	D4,(A4+)	JUMP,EQ 40$30$:	TEST.B	(A4+)	JUMP,NE 30$	JUMP	20$40$:	CALL	WRNAME	JUMP,EQ 50$	LOAD.L	A2,#R16"ERR2$	COMP.W	D7,#1	JUMP,EQ 80$	PUSH.W	D7	LOAD.B	D3,#AFINV	LIB	?AFCAR	POP.W	D7	LIB	?AFERROR	LOAD.B	D3,#AFDIR	LIB	?AFCAR	JUMP	90$50$:	SWAP.W	D3	LOAD.B	D3,D4	SL.W	D3,#8		; D3 <-- "-fs-"	LIB	?ADDNGC	LIB	?AFTIM	.ASCIZ	/met le nom "/	.EVEN	LOAD.L	A3,A4	LIB	?AFTEXT	LIB	?AFTIM	.ASCIZ	/"/	.EVEN	JUMP	90$60$:	COMP.B	(A3+),#'_	JUMP,NE 60$	LIB	?SYNGC		; D3/D4/D5 <-- f/s/t	JUMP,NE 80$	SL.L	D3,#8	LOAD.B	D3,D4	SL.L	D3,#8	LOAD.B	D3,D5		; D3 <-- "-fst"	LOAD.W	D2,#2^0	LOAD.L	A4,#(A6)+OBUFF	LOAD.W	D4,#20	LIB	?TEXTGC		; ajoute le nom dans SMA_GENC.INFO80$:	LOAD.L	A3,A2	LIB	?AFTEXT90$:	POPM.L	D3..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RETERR1$:	.ASCIZ	"nom pas trouv !"ERR2$:	.ASCIZ	"nom dj mis !"	.EVEN;--------\\; WRNAME  >;--------/; ; in	A3.L	^nom du fichier gencar;	A4.L	^nom complet; out	D7.W	erreur; mod	D7.WWRNAME:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.W	D3,#2^BOPWR!2^BOPRD!2^BOPEXCL!2^BOPSYS	FOS	?OPEN	JUMP,NE 90$.IF 0	CLR.W	D3	LOAD.L	D4,#256+OGCCNM	FOS	?SPOS	JUMP,NE 80$	LOAD.L	A3,A4	LOAD.L	A4,#(A6)+OBUFF	LOAD.L	D4,#32	FOS	?RDBYTE	JUMP,NE 80$	LOAD.W	D7,#1	TEST.B	(A4)	JUMP,NE 80$	LOAD.L	A4,A3.ENDIF	CLR.W	D3	LOAD.L	D4,#256+OGCCNM	FOS	?SPOS	JUMP,NE 80$	LOAD.L	A3,A4	CLR.L	D430$:	INC.L	D4	TEST.B	(A3+)	JUMP,NE 30$	FOS	?WRBYTE	JUMP,NE 80$	FOS	?CLOSE	JUMP	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RETTABLE:	.ASCIZ	"AGAvantGarde"	.ASCIZ	"ATAthens"	.ASCIZ	"BBBubble"	.ASCIZ	"BMBookman"	.ASCIZ	"BNBrush"	.ASCIZ	"BRBrocklin"	.ASCIZ	"BWBroadway"	.ASCIZ	"CACarroll"	.ASCIZ	"CHChicago"	.ASCIZ	"COCourrier"	.ASCIZ	"CRComputer"	.ASCIZ	"DRStandard"	.ASCIZ	"ERElegant"	.ASCIZ	"GEGeneva"	.ASCIZ	"GRGrec"	.ASCIZ	"HBHelvetica_B"	.ASCIZ	"HEHelvetica_C"	.ASCIZ	"HIHelvetica_I"	.ASCIZ	"HJHelvetica_BI"	.ASCIZ	"HRHelvetica"	.ASCIZ	"KRKeyboard"	.ASCIZ	"LALosAngeles"	.ASCIZ	"LBLucida_B"	.ASCIZ	"LILucida_I"	.ASCIZ	"LRLucida"	.ASCIZ	"MRMessenger"	.ASCIZ	"NBNormal_B"	.ASCIZ	"NCNewCentury"	.ASCIZ	"NENormal_C"	.ASCIZ	"NINormal_I"	.ASCIZ	"NRNormal"	.ASCIZ	"NYNewYork"	.ASCIZ	"ONOldEnglish"	.ASCIZ	"OROldEnglish_R"	.ASCIZ	"PAPalatino"	.ASCIZ	"POPolka"	.ASCIZ	"QRQualit"	.ASCIZ	"RBRomande_B"	.ASCIZ	"RERomande_C"	.ASCIZ	"RIRomande_I"	.ASCIZ	"RRRomande"	.ASCIZ	"SCScan"	.ASCIZ	"SESegment"	.ASCIZ	"SFSanFransisco"	.ASCIZ	"SNSemiGraphic"	.ASCIZ	"SVSunnyvale"	.ASCIZ	"THThames"	.ASCIZ	"TBTimes_B"	.ASCIZ	"TITimes_I"	.ASCIZ	"TRTimes"	.ASCIZ	"UBUnivers_B"	.ASCIZ	"UEUnivers_C"	.ASCIZ	"UIUnivers_I"	.ASCIZ	"ULUnivers_List"	.ASCIZ	"URUnivers"	.ASCIZ	"VBVolta_B"	.ASCIZ	"VEVenice"	.ASCIZ	"VIVolta_I"	.ASCIZ	"VJVolta_BI"	.ASCIZ	"VRVolta"	.ASCIZ	"ZCZapfChancery"	.B	0	.EVENTXDIR:	.ASCIZ	"#:"TXCRIT:	.ASCIZ	"*.GENC"	.EVEN	.END	START