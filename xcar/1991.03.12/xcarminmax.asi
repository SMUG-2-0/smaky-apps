	.SBTTL	XCARMINMAX.ASI;-------------\\; MINMAXREFAIT >;=============/; Initialise toutes les "bounding box" des caractres.; Initialise galement la "bounding box" gnrale englobant; tous les caractres.; Cette routine n'est en principe jamais ncessaire, puisque; les "bounding box" sont refaites avec chaque modification; d'un caractre !; in	-; out	-; mod	D7.WMINMAXREFAIT:	PUSHM.L	D1..D5,A3	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	CLR.L	D1		; D1 <-- min	CLR.L	D2		; D2 <-- max	CLR.W	D3LOOP$:	PUSHM.L	D1,D2	CALL	MINMAXONE	; initialise la "bounding box"	LOAD.L	D4,D1	LOAD.L	D5,D2	POPM.L	D1,D2	PUSH.L	D3	LOAD.L	D3,D4	CALL	MINMAXPOINT	LOAD.L	D3,D5	CALL	MINMAXPOINT	POP.L	D3	INC.W	D3	COMP.W	D3,#xcNBCAR	JUMP,LO LOOP$	LOAD.W	(A3)+oxcXMIN,D1	SWAP.W	D1	LOAD.W	(A3)+oxcYMIN,D1	LOAD.W	(A3)+oxcXMAX,D2	SWAP.W	D2	LOAD.W	(A3)+oxcYMAX,D2	POPM.L	D1..D5,A3	RET;----------\\; MINMAXALL >;==========/; Initialise la "bounding box" gnrale englobant tous les caractres.; in	-; out	-; mod	D7.WMINMAXALL:	PUSHM.L	D0..D5,A3,A4	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	CLR.L	D1		; D1 <-- min	CLR.L	D2		; D2 <-- max	CLR.W	D3LOOP$:	LOAD.W	D0,D3	SL.W	D0,#1	LOAD.L	A4,#(A3)+oxcYMINS	LOAD.W	D4,(A4)+(D0.W)	SWAP.W	D4	LOAD.L	A4,#(A3)+oxcXMINS	LOAD.W	D4,(A4)+(D0.W)	; D4 <-- min (y;x)	LOAD.L	A4,#(A3)+oxcYMAXS	LOAD.W	D5,(A4)+(D0.W)	SWAP.W	D5	LOAD.L	A4,#(A3)+oxcXMAXS	LOAD.W	D5,(A4)+(D0.W)	; D5 <-- max (y;x)	PUSH.L	D3	LOAD.L	D3,D4	CALL	MINMAXPOINT	LOAD.L	D3,D5	CALL	MINMAXPOINT	POP.L	D3	INC.W	D3	COMP.W	D3,#xcNBCAR	JUMP,LO LOOP$	LOAD.W	(A3)+oxcXMIN,D1	SWAP.W	D1	LOAD.W	(A3)+oxcYMIN,D1	LOAD.W	(A3)+oxcXMAX,D2	SWAP.W	D2	LOAD.W	(A3)+oxcYMAX,D2	LOAD.W	D3,#'E!2^15	CALL	MINMAXONE	; calcule la hauteur du "E" sans les pinceaux	SWAP.W	D1	NEG.W	D1	LOAD.W	(A3)+oxcHTE,D1	; oxcHTE <-- hauteur du "E"	POPM.L	D0..D5,A3,A4	RET;----------\\; MINMAXONE >;----------/; Initialise la "bounding box" d'un caractre.; in	D3.W	code du caractre;		 si D3:#15 -> ne tient pas compte des pinceaux; out	D1.L	min (y;x);	D2.L	max (y;x); mod	D1.L, D2.L, D7.WMINMAXONE:	PUSHM.L	D0,D3..D6,A3,A4	LOAD.W	D0,D3	LOAD.L	A3,(A6)+OXCPGC	; A3 <-- ^en-tte gencar	ADD.L	A3,#256		; A3 <-- ^gencar	SL.W	D3,#2	LOAD.L	A4,#(A3)+oxcPCHAR	LOAD.L	D3,(A4)+(D3.W)	LOAD.L	A4,#(A3)+(D3.L)	; A4 <-- ^description du caractre	CLR.L	D1		; D1 <-- min	CLR.L	D2		; D2 <-- max	CLR.W	(A6)+OLPENLOOP$:	LOAD.B	D3,(A4+)	INC.L	A4	COMP.B	D3,#xcOPBEGIN	JUMP',EQ BEGIN$	COMP.B	D3,#xcOPLINE	JUMP',EQ LINE$	COMP.B	D3,#xcOPCURVE	JUMP',EQ CURVE$	COMP.B	D3,#xcOPADDCHAR	JUMP,EQ ADDCHAR$	COMP.B	D3,#xcOPFILLI	JUMP,EQ LOOP$	COMP.B	D3,#xcOPFILLA	JUMP,EQ LOOP$	COMP.B	D3,#xcOPPEN	JUMP,EQ PEN$	JUMP	END$BEGIN$:	CALL	MINMAXONEGET	LOAD.L	(A6)+OLPOS,D3	JUMP	LOOP$LINE$:	CALL	MINMAXONEGET	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OLPOS	CALL	MINMAXLINE	LOAD.L	(A6)+OLPOS,D4	JUMP	LOOP$CURVE$:	CALL	MINMAXONEGET	LOAD.L	D4,D3	CALL	MINMAXONEGET	LOAD.L	D5,D3	CALL	MINMAXONEGET	LOAD.L	D6,D3	LOAD.L	D3,(A6)+OLPOS	CALL	MINMAXCURVE	LOAD.L	(A6)+OLPOS,D6	JUMP	LOOP$ADDCHAR$:	LOAD.L	D5,(A4+)	; D5 <-- position	LOAD.W	D3,D0	LOAD.B	D3,(A4+)	; D3 <-- caractre	INC.L	A4	PUSHM.L	D1,D2	PUSH.W	(A6)+OLPEN	CALL	MINMAXONE	; hop, rcursif ...	POP.W	(A6)+OLPEN	LOAD.L	D3,D1	LOAD.L	D4,D2	POPM.L	D1,D2	ADD.W	D3,D5	SWAP.W	D3	SWAP.W	D5	ADD.W	D3,D5	SWAP.W	D3	SWAP.W	D5	CALL	MINMAXPOINT	LOAD.L	D3,D4	ADD.W	D3,D5	SWAP.W	D3	SWAP.W	D5	ADD.W	D3,D5	SWAP.W	D3	SWAP.W	D5	CALL	MINMAXPOINT	JUMP	LOOP$PEN$:	LOAD.W	D3,(A4+)	; D3 <-- diamtre du pinceau	TEST.L	D0:#15		; tient compte des pinceaux ?	JUMP,BS LOOP$		; non => LOOP$	INC.W	D3	SR.W	D3,#1		; D3 <-- rayon du pinceau	LOAD.W	(A6)+OLPEN,D3	; OLPEN <-- rayon du pinceau	JUMP	LOOP$END$:	TEST.L	D0:#15		; tient compte des pinceaux ?	JUMP',BS EXIT$		; non => EXIT$	SL.W	D0,#1	LOAD.L	A4,#(A3)+oxcXMINS	LOAD.W	(A4)+(D0.W),D1	SWAP.W	D1	LOAD.L	A4,#(A3)+oxcYMINS	LOAD.W	(A4)+(D0.W),D1	SWAP.W	D1	LOAD.L	A4,#(A3)+oxcXMAXS	LOAD.W	(A4)+(D0.W),D2	SWAP.W	D2	LOAD.L	A4,#(A3)+oxcYMAXS	LOAD.W	(A4)+(D0.W),D2	SWAP.W	D2EXIT$:	POPM.L	D0,D3..D6,A3,A4	RET;-------------\\; MINMAXONEGET >;-------------/; Donne les coordonnes d'un point.; in	A4.L	^buffer; out	A4.L	^plus loin;	D3.L	point (y;x); mod	D3.L, D7.W, A4.LMINMAXONEGET:	PUSH.L	D4	EX.L	A4,A5	CALL	DECOGETPR	; D3/D4 <-- PP/RP (y;x)	EX.L	A5,A4	POP.L	D4	RET;-----------\\; MINMAXLINE >;-----------/; ; in	D3.L	P1 (y;x);	D4.L	P2 (y;x);	D1.L	min (y;x);	D2.L	max (y;x); out	D1.L	min (y;x);	D2.L	max (y;x); mod	D1.L, D2.L, D7.WMINMAXLINE:	PUSHM.L	D3..D5	COMP.W	D3,D4	JUMP',LE OKX$	LOAD.W	D5,D3	LOAD.W	D3,D4	LOAD.W	D4,D5OKX$:	SUB.W	D3,(A6)+OLPEN	ADD.W	D4,(A6)+OLPEN	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',LE OKY$	LOAD.W	D5,D3	LOAD.W	D3,D4	LOAD.W	D4,D5OKY$:	SUB.W	D3,(A6)+OLPEN	ADD.W	D4,(A6)+OLPEN	SWAP.W	D3	SWAP.W	D4	CALL	MINMAXPOINT	EX.L	D3,D4	CALL	MINMAXPOINT;	EX.L	D3,D4	POPM.L	D3..D5	RET;------------\\; MINMAXCURVE >;------------/; ; in	D3.L	P0 (y;x);	D4.L	P1 (y;x);	D5.L	P2 (y;x);	D6.L	P3 (y;x);	D1.L	min (y;x);	D2.L	max (y;x); out	D1.L	min (y;x);	D2.L	max (y;x); mod	D1.L, D2.L, D7.WMINMAXCURVE:	PUSHM.L	D3,D4	PUSHM.L	D1,D2	CALL	BZMINMAX	; D1 <-- min, D2 <-- max	SUB.W	D1,(A6)+OLPEN	SWAP.W	D1	SUB.W	D1,(A6)+OLPEN	SWAP.W	D1	ADD.W	D2,(A6)+OLPEN	SWAP.W	D2	ADD.W	D2,(A6)+OLPEN	SWAP.W	D2	LOAD.L	D3,D1	LOAD.L	D4,D2	POPM.L	D1,D2	CALL	MINMAXPOINT	LOAD.L	D3,D4	CALL	MINMAXPOINT	POPM.L	D3,D4	RET;------------\\; MINMAXPOINT >;------------/; ; in	D3.L	P (y;x);	D1.L	min (y;x);	D2.L	max (y;x); out	D1.L	min (y;x);	D2.L	max (y;x); mod	D1.L, D2.L, D7.WMINMAXPOINT:	COMP.W	D1,D3	JUMP',LE 20$	LOAD.W	D1,D320$:	COMP.W	D2,D3	JUMP',GE 22$	LOAD.W	D2,D322$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	COMP.W	D1,D3	JUMP',LE 40$	LOAD.W	D1,D340$:	COMP.W	D2,D3	JUMP',GE 42$	LOAD.W	D2,D342$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	RET	.END