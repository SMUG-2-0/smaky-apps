	.SBTTL	XCARDBOX.ASI;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut;	D2.W	mode; out	D2.W	mode;	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXEDITO:	PUSHM.L	D1,D4,D5,A2..A5	TEST.B	(A3)		; nom du fichier existe ?	JUMP',EQ 10$		; non => 10$				; oui =>	CLR.W	D7		; D7 <-- ok	LOAD.W	D3,#F1		; D3 <-- comme si (SAUVE)	TEST.L	D2:#BDBAUTO	; mode automatique ?	JUMP,BS	90$		; oui => 90$10$:	CALL	DBOXOPEN1	LOAD.W	D4,D2		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	TSET.L	D2:#BDBEXTEND	; D2 <-- sous-appel d'extension	TSET.L	D2:#BDBSAV	; D2 <-- sauve le fond	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	TEST.L	D2:#BDBNMAJ	JUMP',BC 30$	TSET.L	D3:#BDBIONMAJ	; D3 <-- touche (MET A JOUR) grise30$:	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITE >;==========/; Edite un nom de fichier en sortie (extraction).; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXEDITE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_EXTRAIT; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre (prend).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITA >;==========/; Edite un nom de fichier en entre (ajoute).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITA:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXGC	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEDITIM >;===========/; Edite un nom de fichier en entre (image).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITIM:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOIM	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXEDITIDF >;============/; Edite un nom de fichier en entre (df).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITIDF:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IODF	LOAD.L	A4,#R16"TEXDF	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXEDITODF >;============/; Edite un nom de fichier en sortie (df).; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXEDITODF:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IODF	LOAD.L	A4,#R16"TEXDF	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_EXTRAIT; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXSAVE >;=========/; Sauve le gencar selon le choix de l'utilisateur.; in	D0.W	mode (0=quitte, 1=nouveau texte); out	D7.W	0	=> ok, on peut quitter;		1	=> (ANNULE), donc on reste;		autre	=> erreur grve; mod	D7.WDBOXSAVE:	PUSHM.L	D1..D5,A2..A5	TEST.B	(A6)+OMAJ	; mise  jour ncessaire ?	JUMP,F	80$		; non => 80$ (quitte, snif)				; oui =>	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	CLR.L	D3		; D3 <-- numro de la zone	TEST.B	D0	JUMP',NE 25$	TSET.L	D3:#BDBIOQUIT	; D3 <-- texte "avant de quitter"25$:	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_MAJ	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 85$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$	OR.W	D2,D4		; D2 <-- met aussi les fanions (pour BDBDEF)	CALL	SAUVETOUT	; sauve tout sur disque (in D2.W !)	JUMP'	90$80$:	CLR.W	D7		; D7 <-- quitte	JUMP'	90$85$:	LOAD.W	D7,#1		; D7 <-- reste90$:	POPM.L	D1..D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande si l'on veut quitter DESSIN.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXQUITTE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D790$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer le gencar.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXEFFACE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	CLR.L	D3		; D3 <-- numro de la zone	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXDEF >;========/; Dfinitions du gencar.; in	-; out	D7.W	erreur; mod	D7.WDBOXDEF:	PUSHM.L	D1..D5,A1..A4	TEST.L	(A6)+OXCPGC	JUMP,EQ EXIT$	LOAD.L	A2,#R16"TDBOX_DEF	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	A2,(A6)+OXCPGC	; A2 <-- ^en-tte gencar	ADD.L	A2,#256		; A2 <-- ^gencar	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A2)+oxcIDE	LIB	?AFTEXT	LOAD.L	A4,#(A6)+OBUDIS+0	LOAD.W	D4,(A2)+oxcITL	CALL	PUTVNUM		; OBUDIS+0 <-- interligne	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS+0	LIB	?AFTEXT	LOAD.L	(A6)+OBUDIS+20,(A2)+oxcRBI	CLR.B	(A6)+OBUDIS+20+4	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS+20	LIB	?AFTEXT	LOAD.L	A4,#(A6)+OBUDIS+40	LOAD.W	D4,(A2)+oxcPMN	CALL	PUTANUM		; OBUDIS+40 <-- taille minimale	LOAD.W	D2,#4!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS+40	LIB	?AFTEXT	LOAD.W	(A6)+OBUDIS+60,(A2)+oxcPNG	LOAD.B	(A6)+OBUDIS+60+2,#'P	TCLR.B	(A6)+OBUDIS+60+1:#BGCFIX	JUMP',BC INIT4$	LOAD.B	(A6)+OBUDIS+60+2,#'FINIT4$:	CLR.B	(A6)+OBUDIS+60+3	LOAD.W	D2,#5!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS+60	LIB	?AFTEXT	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A2)+oxcTEXT	LIB	?AFTEXT	LOAD.L	D4,(A2)+oxcMODE	; D4 <-- fanions	CLR.W	D2EDIT$:	LOAD.L	A3,#(A2)+oxcNAME	TEST.W	D2	JUMP',EQ EDIT2$	LOAD.L	A3,#(A2)+oxcIDE	COMP.W	D2,#1	JUMP',EQ EDIT2$	LOAD.L	A3,#(A6)+OBUDIS+0	COMP.W	D2,#2	JUMP',EQ EDIT2$	LOAD.L	A3,#(A6)+OBUDIS+20	COMP.W	D2,#3	JUMP',EQ EDIT2$	LOAD.L	A3,#(A6)+OBUDIS+40	COMP.W	D2,#4	JUMP',EQ EDIT2$	LOAD.L	A3,#(A6)+OBUDIS+60EDIT2$:	LOAD.L	A4,A3EDIT3$:	TEST.B	(A4+)	JUMP,NE EDIT3$	DEC.L	A4LOOP$:	LOAD.W	D3,D2	DBOX_	MEDIT		; indique le texte  diter	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_DEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ NEXT$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#KEYDBOX+0	JUMP',LO BIP$	COMP.W	D3,#KEYDBOX+6	JUMP',LO NEW$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	LOOP$NEXT$:	INC.W	D2	COMP.W	D2,#6	JUMP,LO EDIT$	CLR.W	D2	JUMP	EDIT$NEW$:				; change =>	SUB.W	D3,#KEYDBOX	LOAD.W	D2,D3		; D2 <-- 0..5	JUMP	EDIT$OK$:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OBUDIS+0	CALL	GETVNUM	LOAD.W	D1,D4	POPM.L	D4,A4	TEST.W	D7	JUMP,NE BIP$	LOAD.W	(A2)+oxcITL,D1	PUSHM.L	D4,A3,A4	LOAD.L	A4,#(A6)+OBUDIS+20	LOAD.L	A3,#(A2)+oxcRBI	CLR.L	(A3)	LOAD.W	D4,#4RBI2$:	DEC.W	D4	JUMP',NS RBI4$	LOAD.B	(A3+),(A4+)	; oxcRBI <-- 4 caractres	JUMP,NE RBI2$RBI4$:	POPM.L	D4,A3,A4	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OBUDIS+40	CALL	GETANUM	LOAD.W	D1,D4	POPM.L	D4,A4	TEST.W	D7	JUMP,NE BIP$	LOAD.W	(A2)+oxcPMN,D1	LOAD.W	(A2)+oxcPNG,(A6)+OBUDIS+60	COMP.B	(A6)+OBUDIS+60+2,#'F	JUMP',EQ PNG2$	COMP.B	(A6)+OBUDIS+60+2,#'f	JUMP',NE PNG4$PNG2$:	TSET.B	(A2)+oxcPNG+1:#BGCFIXPNG4$:	LOAD.L	(A2)+oxcMODE,D4	SET.B	(A6)+OMAJCANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXINFO >;=========/; Choix du diamtre du pinceau.; in	D2.W	diamtre initial;	D4.L	informations; out	D2.W	nouveau diamtre;	D4.L	informations;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.WDBOXINFO:	PUSHM.L	D1,D5,A1..A4	LOAD.W	D1,D2	LOAD.L	A2,#R16"TDBOX_INFO	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	A4,#(A6)+OBUDIS+0	LOAD.L	A3,A4	CLR.B	(A3)	COMP.W	D1,#-1	JUMP',EQ LOOP$	PUSH.L	D4	LOAD.W	D4,D1	CALL	PUTANUM		; OBUDIS+0 <-- diamtre	POP.L	D4LOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_INFO	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#F1	JUMP',EQ OK$	COMP.W	D3,#F0	JUMP',EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	LOOP$OK$:	LOAD.W	D2,#-1	TEST.B	(A3)	JUMP',EQ CANCEL$	LOAD.L	A4,A3	PUSH.L	D4	CALL	GETANUM	LOAD.W	D2,D4	POP.L	D4	TEST.B	(A4)	JUMP,NE BIP$CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXCAR >;========/; Choix du caractre  visualiser.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCAR:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_CAR	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	A4,(A6)+OIPPT	LOAD.L	D4,(A6)+OIPDIM	LOAD.L	D3,#H'10000*IPWDOY+IPWDOX	CALL	SHOWIMAGE	; affiche l'image de la palette	LOAD.W	D0,(A6)+OXCCAR	LOAD.W	D2,D0	CALL	IPINV		; allume le caractre actuelLOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_CAR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	CALL	IPMOVE		; slectionne un caractre ...	JUMP,NE LOOP$	LOAD.W	D3,#F1OK$:	CLR.W	D7		; D7 <-- ok	COMP.W	D0,#-1	JUMP',EQ CANCEL$	LOAD.W	(A6)+OXCCAR,D0CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXADD >;========/; Choix du caractre  ajouter.; in	-; out	D3.W	dernire touche (F1/F0);	D4.L	fanions;	D2.W	caractre choisi (0..255);	A3.L	^nom du gencar;	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.W, A3.LDBOXADD:	PUSHM.L	D0,D1,D5,A1,A2,A4	LOAD.L	A2,#R16"TDBOX_ADD	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFAADD	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.L	A4,(A6)+OIPPT	LOAD.L	D4,(A6)+OIPDIM	LOAD.L	D3,#H'10000*IPWDOY+IPWDOX	CALL	SHOWIMAGE	; affiche l'image de la palette	POP.L	D4	LOAD.W	D0,(A6)+OXCCAR	LOAD.W	D2,D0	CALL	IPINV		; allume le caractre actuel	LOAD.L	A3,#(A6)+OBUFAJ	LOAD.L	A4,A3EDIT$:	TEST.B	(A4+)	JUMP,NE EDIT$	DEC.L	A4LOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_ADD	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	LOOP$CLIC$:	CALL	IPMOVE		; slectionne un caractre ...	JUMP,NE LOOP$OK$:	TEST.L	D4:#BFAADDREEL	JUMP',BC OK1$	COMP.W	D0,(A6)+OXCCAR	; ajoute lui-mme ?	JUMP,EQ BIP$		; oui => BIP$OK1$:	TEST.L	D4:#BFAADDOTHER	JUMP',BC OK2$	TEST.B	(A3)		; nom de gencar existe ?	JUMP,EQ BIP$		; non => BIP$OK2$:	CLR.W	D7		; D7 <-- ok	LOAD.W	D3,#F0	COMP.W	D0,#-1	JUMP',EQ CANCEL$	LOAD.W	D2,D0		; D2 <-- caractre choisi	LOAD.L	(A6)+OFAADD,D4	LOAD.W	D3,#F1CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0,D1,D5,A1,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IPMOVE  >;--------/; Change de caractre slectionn.; in	D0.W	caractre slectionn; out	D0.W	nouveau caractre;	D7.W	0 => double clic; mod	D0.L, D7.WIPMOVE:	PUSHM.L	D1..D4	LOAD.W	D1,D0	JUMP'	CPOS$CLOOP$:	CALL	WAITMOVE	; attend dplacement ...	JUMP',NE CEND$CPOS$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE CLOOP$	CALL	IPDET		; D2 <-- caractre o est la souris	COMP.W	D2,D0		; toujours dans le mme ?	JUMP,EQ CLOOP$		; oui => CLOOP$				; non =>	EX.L	D0,D2	CALL	IPINV		; efface l'ancien	LOAD.W	D2,D0	CALL	IPINV		; allume le nouveau	JUMP	CLOOP$CEND$:	LOAD.W	D7,#1		; D7 <-- simple clic	COMP.W	D0,D1	JUMP',NE EXIT$	COMP.W	D0,#-1	JUMP',EQ EXIT$	CLR.W	D7		; D7 <-- double clicEXIT$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IPDET   >;--------/; Dtecte dans quel caractre est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	caractre (0..255,-1);	D7.W	erreur; mod	D2.L, D7.WIPDET:	PUSHM.L	D0,D1,D3,D4	LOAD.W	D0,D4	LOAD.L	D1,D4	SWAP.W	D1	CLR.W	D7	CLR.W	D220$:	CALL	IPPOS		; D3/D4 <-- position/dimensions	ADD.W	D3,#IPWDOX	SWAP.W	D3	ADD.W	D3,#IPWDOY	SWAP.W	D3	COMP.W	D0,D3	JUMP',LO 40$	ADD.W	D3,D4	COMP.W	D0,D3	JUMP',HS 40$	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,D3	JUMP',LO 40$	ADD.W	D3,D4	COMP.W	D1,D3	JUMP',LO 90$40$:	INC.W	D2	COMP.W	D2,#256	JUMP,LO 20$	LOAD.W	D2,#-1	LOAD.W	D7,#190$:	POPM.L	D0,D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IPINV   >;--------/; Inverse un caractre.; in	D2.W	caractre (0..255,-1); out	-; mod	D7.WIPINV:	PUSHM.L	D2..D4	COMP.W	D2,#-1	JUMP',EQ 90$	LOAD.L	D4,#-1	CALL	DRMDEF	CALL	IPPOS		; D3/D4 <-- position/dimensions	ADD.W	D3,#IPWDOX+1	SWAP.W	D3	ADD.W	D3,#IPWDOY+1	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME90$:	POPM.L	D2..D4	RET;--------\\; IPPOS   >;--------/; Donne la position et les dimensions d'un caractre.; in	D2.W	caractre (0..255); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WIPPOS:	PUSHM.L	D1,D2	LOAD.L	D3,#H'10000*IPPOSY+(IPPOSX+(IPDIMX*(16+1)))	SUB.W	D2,#128	JUMP',NC 20$	ADD.W	D2,#128	LOAD.L	D3,#H'10000*IPPOSY+IPPOSX20$:	LOAD.W	D1,D2	AND.W	D1,#B'1111	MUL.WU	D1,#IPDIMX	ADD.W	D3,D1	LOAD.W	D1,D2	SR.W	D1,#4	MUL.WU	D1,#IPDIMY	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D3	LOAD.L	D4,#H'10000*IPDIMY+IPDIMX	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXZOOM  >;==========/; Demande deux facteurs de zoom spciaux.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXZOOM:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_ZOOM	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFAZOOM	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBYZOOM	LIB	?AFTEXT		; affiche le facteur vertical	POP.L	D4	CLR.W	D2		; D2 <-- dans facteur en XEDIT$:	LOAD.L	A3,#(A6)+OBXZOOM	TEST.W	D2	JUMP',EQ EDIT2$	LOAD.L	A3,#(A6)+OBYZOOMEDIT2$:	LOAD.L	A4,A3EDIT3$:	TEST.B	(A4+)	JUMP,NE EDIT3$	DEC.L	A4		; A4 <-- ^fin du dernier nombreLOOP$:	LOAD.W	D3,D2	DBOX_	MEDIT		; indique le facteur  diter	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_ZOOM	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#KEYDBOX+0	JUMP',EQ NEW$	COMP.W	D3,#KEYDBOX+1	JUMP',EQ NEW$	COMP.W	D3,#CR	JUMP',EQ NEXT$	COMP.W	D3,#F1		; (ZOOM) ?	JUMP',EQ ZOOM$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP,EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$NEW$:				; change =>	SUB.W	D3,#KEYDBOX	LOAD.W	D2,D3		; D2 <-- 0..1	JUMP	EDIT$NEXT$:				; suivant =>	INC.W	D2	COMP.W	D2,#2	JUMP,LO EDIT$	CLR.W	D2	JUMP	EDIT$ZOOM$:				; ZOOM =>	LOAD.L	A3,#(A6)+OBXZOOM	LOAD.L	A4,A3		; A4 <-- ^nombre prsum	CALL	ZRDNUM		; D1 <-- nombre *1000	JUMP,NE BIP$	LOAD.W	(A6)+OXZOOM,D1	LOAD.L	A3,#(A6)+OBYZOOM	LOAD.L	A4,A3		; A4 <-- ^nombre prsum	CALL	ZRDNUM		; D1 <-- nombre *1000	JUMP,NE BIP$	LOAD.W	(A6)+OYZOOM,D1	LOAD.L	(A6)+OFAZOOM,D4CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZRDNUM  >;--------/; in	A4.L	^nombre prsum; out	A4.L	^plus loin;	D1.W	nombre (+/-);	D7.W	erreur; mod	D1.L, D7.W, A4.LZRDNUM:	PUSH.L	D4	LOAD.W	D1,#1000	TEST.B	(A4)	JUMP',EQ 90$	CALL	GETVNUM	LOAD.W	D1,D490$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXDEFIM >;==========/; Demande un facteur de zoom pour l'image de fond.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDEFIM:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_DEFIM	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFADEFI	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$EDIT$:	LOAD.L	A3,#(A6)+OBIZOOM	LOAD.L	A4,A3EDIT3$:	TEST.B	(A4+)	JUMP,NE EDIT3$	DEC.L	A4		; A4 <-- ^fin du dernier nombreLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_DEFIM	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#F1		; (ZOOM) ?	JUMP',EQ ZOOM$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP,EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$ZOOM$:				; ZOOM =>	LOAD.L	A3,#(A6)+OBIZOOM	LOAD.L	A4,A3		; A4 <-- ^nombre prsum	CALL	ZRDNUM		; D1 <-- nombre *1000	JUMP,NE BIP$	LOAD.W	(A6)+OIZOOM,D1	LOAD.L	(A6)+OFADEFI,D4CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXCFIX >;=========/; Demande oui/non.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCFIX:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_CFIX	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFADEFI	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_CFIX	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ END$	COMP.W	D3,#F0	JUMP',EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$END$:	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXITAL >;=========/; Demande la transformation pour l'italique.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXITAL:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_ITAL	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFATRAN	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$EDIT$:	LOAD.L	A3,#(A6)+OBITRAN	LOAD.L	A4,A3EDIT3$:	TEST.B	(A4+)	JUMP,NE EDIT3$	DEC.L	A4		; A4 <-- ^fin du dernier nombreLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_ITAL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#F1		; (TRANSFORME) ?	JUMP',EQ TRANS$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP',EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$TRANS$:				; TRANSFORME =>	LOAD.L	(A6)+OFATRAN,D4	LOAD.B	D2,(A3+)	COMP.B	D2,#'+	JUMP',EQ SIGN$	COMP.B	D2,#'-	JUMP',EQ SIGN$	DEC.L	A3SIGN$:	LOAD.L	A4,A3	CALL	GETANUM	COMP.B	D2,#'-	JUMP',NE POS$	NEG.W	D4POS$:	LOAD.W	(A6)+OIPTRAN,D4CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXLARG >;=========/; Demande la transformation pour l'troitisation.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXLARG:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_LARG	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFATRAN	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$EDIT$:	LOAD.L	A3,#(A6)+OBLTRAN	LOAD.L	A4,A3EDIT3$:	TEST.B	(A4+)	JUMP,NE EDIT3$	DEC.L	A4		; A4 <-- ^fin du dernier nombreLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_LARG	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#F1		; (TRANSFORME) ?	JUMP',EQ TRANS$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP',EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$TRANS$:				; TRANSFORME =>	LOAD.L	(A6)+OFATRAN,D4	LOAD.L	A4,A3	CALL	GETANUM	LOAD.W	(A6)+OLPTRAN,D4CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXPEN  >;=========/; Demande la transformation pour le pinceau.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPEN:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_PEN	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,(A6)+OPEN	CALL	PUTANUMEDIT$:	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3EDIT3$:	TEST.B	(A4+)	JUMP,NE EDIT3$	DEC.L	A4		; A4 <-- ^fin du dernier nombreLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_PEN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#F1		; (TRANSFORME) ?	JUMP',EQ TRANS$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP',EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$TRANS$:				; TRANSFORME =>	LOAD.L	A4,A3	CALL	GETANUM	LOAD.W	(A6)+OPEN,D4CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXFILL >;=========/; Demande la transformation pour le remplissage.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXFILL:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_FILL	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OINFO	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_FILL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1		; (TRANSFORME) ?	JUMP',EQ TRANS$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP',EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$TRANS$:				; TRANSFORME =>	LOAD.L	(A6)+OFFTRAN,D4CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXACCENT >;===========/; Demande commet crer les accents.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXACCENT:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_ACCENT	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFAACCE	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_ACCENT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1		; (CREE) ?	JUMP',EQ CREE$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP',EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CREE$:				; CREE =>	LOAD.L	(A6)+OFAACCE,D4CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXSAUVEBM >;============/; Demande la taille des caractres bitmap.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXSAUVEBM:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_SAUVEBM	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$EDIT$:	LOAD.L	A3,#(A6)+OBTSVBM	LOAD.L	A4,A3EDIT3$:	TEST.B	(A4+)	JUMP,NE EDIT3$	DEC.L	A4		; A4 <-- ^fin du dernier nombreLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_SAUVEBM	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#F1		; (SAUVE) ?	JUMP',EQ SAUVE$	COMP.W	D3,#F0		; (ANNULE) ?	JUMP,EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$SAUVE$:				; SAUVE =>	LOAD.L	A4,A3	CALL	GETANUM	LOAD.W	(A6)+OTSVBM,D4CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.END