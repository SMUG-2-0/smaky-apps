	.SBTTL	XCARREL.ASI;---------\\; RELCALCP >;=========/; Calcule un point relatif, en effectuant une somme de vecteurs relatifs.; in	D3.L	P (y;x)  [pi];	D4.L	R (y;x)  [pi]; out	D3.L	P (y;x)  [pg]; mod	D3.L, D7.WRELCALCP:	PUSHM.L	D0..D2,D4,A2..A4	LOAD.L	A3,#(A6)+OBUBIG	LOAD.L	A2,A3	LOAD.L	(A3+),D3	; OBUBIG <-- point final	LOAD.W	D2,#20		; D2 <-- lg max chane de flches relatives20$:	DEC.W	D2		; on tourne en rond ?	JUMP',NS 35$		; oui => 35$	LOAD.L	D3,D4	LOAD.L	(A3+),D3	; OBUBIG <-- point initiateur	CALL	RELABS		; D3 <-- point standard	CALL	RESEARCH	; A4 <-- ^objet jointif	JUMP',NE 35$	LOAD.L	D4,(A4)+OOBRP1	COMP.L	D3,(A4)+OOBPP1	JUMP',EQ 30$	LOAD.L	D4,(A4)+OOBRP230$:	TEST.L	D4	JUMP,NE 20$35$:	LOAD.L	D3,(-A3)	CALL	RELABS	CALL	PETCONVP	LOAD.L	D0,D3		; D0 <-- point initial [pg]40$:	LOAD.L	D3,(A3)	LOAD.L	D1,D3		; D1 <-- point "relatif"	CALL	RELABS		; D3 <-- point standard	LOAD.L	D4,D3	LOAD.L	D3,(-A3)	CALL	RELABS		; D3 <-- point standard	LOAD.L	D2,D3	CALL	PETCONVP	; D2 <-- point [pg]	EX.L	D2,D3	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	CALL	PETCONVD	; D3 <-- distance [pg]	ADD.W	D0,D3	TEST.L	D1:#15		; relatif en X ?	JUMP',BS 60$	LOAD.W	D0,D260$:	SWAP.W	D0	SWAP.W	D2	SWAP.W	D3	ADD.W	D0,D3	TEST.L	D1:#31		; relatif en Y ?	JUMP',BS 62$	LOAD.W	D0,D262$:	SWAP.W	D0;	SWAP.W	D2;	SWAP.W	D3	COMP.L	A3,A2		; est-on au dbut de la table ?	JUMP,NE 40$		; non => 40$	LOAD.L	D3,D0		; D3 <-- point en [pg]	POPM.L	D0..D2,D4,A2..A4	RET;---------\\; RELAJUST >;=========/; Met ou enlve une contrainte.; in	D3.W	opration (1..4);	D5.L	dpart (y;x);	D6.L	arrive (y;x); out	-; mod	D7.WRELAJUST:	PUSHM.L	D2..D6,A4	LOAD.L	D4,D6		; D4 <-- arrive	TSET.L	D5:#31	COMP.W	D3,#2		; rgulier X ?	JUMP',NE NOX$	AND.L	D5,#H'FFFFNOX$:	TSET.L	D5:#15	COMP.W	D3,#3		; rgulier Y ?	JUMP',NE NOY$	CLR.W	D5NOY$:	COMP.W	D3,#4		; normal ?	JUMP',NE NODEL$	CLR.L	D5NODEL$:	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ EXIT$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP,NE EXIT$LOOP$:	LOAD.W	D2,(A4)+OOBTYP	COMP.W	D2,#xcOPLINE	JUMP',EQ OBJ$	COMP.W	D2,#xcOPCURVE	JUMP',NE NEXT$OBJ$:	COMP.L	D4,(A4)+OOBPP1	JUMP',EQ PP1$	COMP.L	D4,(A4)+OOBPP2	JUMP',EQ PP2$	JUMP'	NEXT$PP1$:	LOAD.L	(A4)+OOBRP1,D5	JUMP'	NEXT$PP2$:	LOAD.L	(A4)+OOBRP2,D5;	JUMP'	NEXT$NEXT$:	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPMOVEEXIT$:	POPM.L	D2..D6,A4	RET;--------\\; RELDEL  >;========/; Enlve toutes les contraintes.; in	-; out	-; mod	D7.WRELDEL:	PUSHM.L	D6,A4	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP',EQ END$	CALL	_OBJ_LFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	CLR.L	(A4)+OOBRP1	CLR.L	(A4)+OOBRP2	CLR.L	(A4)+OOBRS1	CLR.L	(A4)+OOBRS2	CALL	_OBJ_LNEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPMOVEEND$:	POPM.L	D6,A4	RET;--------\\; RELABS  >;========/; Transforme une coordonne "relative" (bits 15 et 31 toujours  1) ou; "normale" (bits 15 et 31 toujours  0) en une coordonne standard; positive ou ngative.; in	00xxx	-->	+ normal;	01xxx	-->	- normal;	10xxx	-->	+ relatif;	11xxx	-->	- relatif; out	00xxx	-->	+ valeur;	11xxx	-->	- valeur; in	D3.L	point "relatif" (y;x); out	D3.L	point (y;x); mod	D3.LRELABS:	TCLR.L	D3:#15		; D3 <-- enlve le bit "relatif"	TEST.L	D3:#14	JUMP',BC 20$	TSET.L	D3:#15		; D3 <-- remet le bit de signe20$:	TCLR.L	D3:#31		; D3 <-- enlve le bit "relatif"	TEST.L	D3:#30	JUMP',BC 40$	TSET.L	D3:#31		; D3 <-- remet le bit de signe40$:	RET	.END