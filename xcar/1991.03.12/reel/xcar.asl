	.TITLE	XCAR.ASL	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal	.REF	SMAKY	.REF	GRA	.REF	XCAR	.REF	GRAMISC	.REF	DOLIB; Date		Rev	Amliorations; ------------------------------------------------------------------------------; 13.04.89	1.0	premiers essais avec STRETCH	.REV	1,0	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------CHOUIA05	=	H'8000		; p'tit chouia = 0.5; Dfinition de l'entte d'un gnrateur de caractres; ----------------------------------------------------OGCNBR		=	H'00		; total number of recordsOGCFSN		=	H'02		; font set numberOGCFN		=	H'03		; font numberOGCMSB		=	H'04		; matrix size in bytesOGCMHD		=	H'06		; matrix height in dotsOGCMWB		=	H'08		; matrix width in bytesOGCPSI		=	H'09		; point sizeOGCFCA		=	H'0A		; ASCII code of first characterOGCLCA		=	H'0B		; ASCII code of last characterOGCLMA		=	H'0C		; left margin of matrixOGCBLI		=	H'0E		; bottom of matrix to baselineOGCMH1		=	H'10		; max heigth above baselineOGCMH2		=	H'12		; max extension under baselineOGCMWI		=	H'14		; max width (for fixed spacing)OGCISP		=	H'16		; interline space in dotsOGCVSP		=	H'18		; variable spacedOGCDAT		=	H'1A		; date en BCD jjmmyyyyOGCPWI		=	H'1E		; ^widthOGCPH1		=	H'20		; ^h1OGCPH2		=	H'22		; ^h2OGCPMX		=	H'24		; ^matrixOGCIDE		=	H'26		; text identifierOGCTXT		=	H'80		; textOGCWID		=	H'100		; widthOGCH1		=	H'180		; h1OGCH2		=	H'200		; h2OGCMAT		=	H'280		; matrix; Variables pour courbe de bezier; -------------------------------;	C1                      C2;	 o----------------------o;	 |                       \;	 |          .     .       \;	 |      .              .   \;	 |   .                     .\;	 | .                         o;	 |.                            P2;	 o  P1	.LOC	0OBZP1Y:	.BLKB	4		; P1[y]OBZP1X:	.BLKB	4		; P1[x]OBZC1Y:	.BLKB	4		; C1[y]OBZC1X:	.BLKB	4		; C1[x]OBZC2Y:	.BLKB	4		; C2[y]OBZC2X:	.BLKB	4		; C2[x]OBZP2Y:	.BLKB	4		; P2[y]OBZP2X:	.BLKB	4		; P2[x]LBZ:; Variables locales de XCAR_CREATE; --------------------------------	.LOC	0OXCF:	.BLKB	1		; fonte	.EVENOXCS:	.BLKB	4		; styleOXCT:	.BLKB	2		; tailleOXCFILN:.BLKB	16		; nom du fichierOXCPI:	.BLKB	4		; ^gencar en entreOXCPO:	.BLKB	4		; ^gencar en sortieOXCDF:	.BLKB	LGDIS7		; descripteur de fentreOXCIRG:	.BLKB	4		; rgion: identificateurOXCDRG:	.BLKB	4		; rgion: dfinitionOXCMOD:	.BLKB	2		; mode MXCFILL =  1			;  rempli MXCOUTL =  2			;  contour	.EVENOXCIXG:	.BLKB	2		; l1 (gauche)	[pi]OXCIX1:	.BLKB	2		; l1 (gauche)	[po]OXCIX2:	.BLKB	2		; l2 (droite)	[po]OXCIXB:	.BLKB	2		; l1+l2		[bytes]OXCIY1:	.BLKB	2		; h1 (haut)	[po]OXCIY2:	.BLKB	2		; h2 (bas)	[po]OXCIYE:	.BLKB	2		; taille du "E"	[pi]OLPOS:	.BLKB	4ORPOS:	.BLKB	4OWCAR:	.BLKB	2OBZP0:	.BLKB	4		; P0OBZP1:	.BLKB	4		; P1OBZP2:	.BLKB	4		; P2OBZP3:	.BLKB	4		; P3LGVAR:; En-tte du module LIB; ---------------------	.LOC	0	XCAR_	FIRST		; code du premier appel	XCAR_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	1,0		; rvision.version	.W	0,END_XCAR	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"XCAR"		; nom du module	.FILLB	(LGHLIB-.),0	.W	_XCAR_OPEN	.W	_XCAR_CREATE;-----------\\; _XCAR_OPEN >;===========/; ; in	-; out	-; mod	D7.W_XCAR_OPEN:	PUSHM.L	D1,D3,A3	LOAD.L	A3,#R16"NMGMI$	LOAD.W	D3,#GMI_FIRST	LIB_	OPEN	POPM.L	D1,D3,A3	CLR.W	D7		; retour EQ	RETNMGMI$:	.ASCIZ	"GRAMISC"	.EVEN;-------------\\; _XCAR_CREATE >;=============/; Cre un gencar "bitmap" complet (128 caractres)  partir d'un gencar analytique.; in	D0.B	fonte;	D1.L	style/chasse;	D2.B	taille; out	A4.L	^gencar;	D7.W	erreur; mod	D7.W, A4.L_XCAR_CREATE:	PUSHM.L	D0..D4,A3,A6	LOAD.L	D3,D1	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour les variables	JUMP,NE 95$	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables localesPUSHM.L D0..D6,A0..A3,A5,A6	GMI_	NEWRGN		; cre une nouvelle rgionPOPM.L D0..D6,A0..A3,A5,A6;;?	JUMP,NE 90$	LOAD.L	(A6)+OXCIRG,A4	LOAD.B	(A6)+OXCF,D0	LOAD.L	(A6)+OXCS,D3	LOAD.B	(A6)+OXCT+1,D2	LOAD.L	A3,#(A6)+OXCFILN	LOAD.B	(A3+),#'S	LOAD.B	(A3+),#'M	LOAD.B	(A3+),#'A	LOAD.B	(A3+),#'_	LOAD.B	(A3+),D0	LOAD.B	(A3+),D3	LOAD.B	(A3+),#'P	LOAD.B	(A3+),#'0	LOAD.B	(A3+),#'0	LOAD.B	(A3+),#'.	LOAD.B	(A3+),#'G	LOAD.B	(A3+),#'E	LOAD.B	(A3+),#'N	LOAD.B	(A3+),#'C	CLR.B	(A3)	LOAD.L	A3,#(A6)+OXCFILN	CLR.L	D3	FOS	?CLOAD	JUMP,NE 90$	LOAD.L	(A6)+OXCPI,A4	CALL	DIMGC		; calcule les dimensions	LOAD.W	D4,(A6)+OXCIY1	ADD.W	D4,(A6)+OXCIY2	MUL.WU	D4,(A6)+OXCIXB	MUL.WU	D4,#128	ADD.L	D4,#OGCMAT	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour gencar en sortie	JUMP,NE 90$	GESMEM	?CLEARMEM	LOAD.L	(A6)+OXCPO,A4	LOAD.L	A3,A4		; A3 <-- ^gencar en sortie	LOAD.L	A4,(A6)+OXCPI	; A4 <-- ^gencar en entre	CALL	CONVGC	LOAD.L	A3,#(A6)+OXCFILN	FOS	?CUNLOAD	LOAD.L	A4,(A6)+OXCPO	; A4 <-- ^gencar en sortie90$:	PUSHM.L	D7,A4	TEST.L	(A6)+OXCIRG	JUMP',EQ 92$	LOAD.L	A4,(A6)+OXCIRGPUSHM.L D0..D6,A0..A6	GMI_	DISPOSERGN	; rend la rgionPOPM.L D0..D6,A0..A692$:	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend les variables	POPM.L	D7,A495$:	POPM.L	D0..D4,A3,A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; DIMGC   >;========/; Calcule les dimensions maximales d'un caractres.; in	A4.L	^gencar en entre; out	-; mod	D7.WDIMGC:	PUSHM.L	D2..D4,A3	LOAD.W	D4,(A4)+oxcYMINS+(2*'E)	NEG.W	D4	LOAD.W	(A6)+OXCIYE,D4	LOAD.L	A3,#(A4)+oxcXMINS	LOAD.W	D3,#128-1	CLR.W	D420$:	LOAD.W	D2,(A3+)	NEG.W	D2	COMP.W	D4,D2	JUMP',GE 22$	LOAD.W	D4,D222$:	DECJ.W,NMO D3,20$	LOAD.W	(A6)+OXCIXG,D4	CALL	CONVIO	LOAD.W	(A6)+OXCIX1,D4	LOAD.L	A3,#(A4)+oxcYMINS	LOAD.W	D3,#128-1	CLR.W	D430$:	LOAD.W	D2,(A3+)	NEG.W	D2	COMP.W	D4,D2	JUMP',GE 32$	LOAD.W	D4,D232$:	DECJ.W,NMO D3,30$	CALL	CONVIO	LOAD.W	(A6)+OXCIY1,D4	LOAD.L	A3,#(A4)+oxcXMAXS	LOAD.W	D3,#128-1	CLR.W	D440$:	LOAD.W	D2,(A3+)	COMP.W	D4,D2	JUMP',GE 42$	LOAD.W	D4,D242$:	DECJ.W,NMO D3,40$	CALL	CONVIO	LOAD.W	(A6)+OXCIX2,D4	LOAD.L	A3,#(A4)+oxcYMAXS	LOAD.W	D3,#128-1	CLR.W	D450$:	LOAD.W	D2,(A3+)	COMP.W	D4,D2	JUMP',GE 52$	LOAD.W	D4,D252$:	DECJ.W,NMO D3,50$	CALL	CONVIO	LOAD.W	(A6)+OXCIY2,D4	LOAD.W	D4,(A6)+OXCIX1	ADD.W	D4,(A6)+OXCIX2	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	LOAD.W	(A6)+OXCIXB,D4	POPM.L	D2..D4,A3	RET;--------\\; CONVGC  >;========/; ; in	A3	^gencar en sortie;	A4	^gencar en entre; out	(A3)++	gencar en sortie; mod	D7.WCONVGC:	PUSHM.L	D2..D4,A1,A2,A5; Gnre l'en-tte du gencar.	LOAD.W	D4,(A6)+OXCIY1	ADD.W	D4,(A6)+OXCIY2	LOAD.W	(A3)+OGCMHD,D4	LOAD.W	D4,(A6)+OXCIXB	LOAD.B	(A3)+OGCMWB,D4	MUL.WU	D4,(A3)+OGCMHD	LOAD.W	(A3)+OGCMSB,D4;	LOAD.B	(A3)+OGCFCA,#0	LOAD.B	(A3)+OGCLCA,#128-1	LOAD.W	(A3)+OGCLMA,(A6)+OXCIX1	LOAD.W	(A3)+OGCBLI,(A6)+OXCIY2	LOAD.W	(A3)+OGCMH1,(A6)+OXCIY1	LOAD.W	(A3)+OGCMH2,(A6)+OXCIY2	LOAD.W	D4,(A6)+OXCIX1	ADD.W	D4,(A6)+OXCIX2	LOAD.W	(A3)+OGCMWI,D4	LOAD.W	D4,(A6)+OXCIY1	ADD.W	D4,(A6)+OXCIY2	LOAD.W	(A3)+OGCISP,D4	LOAD.B	(A3)+OGCVSP,#1;	LOAD.W	(A3)+OGCPWI,#H'0000	LOAD.W	(A3)+OGCPH1,#H'0080	LOAD.W	(A3)+OGCPH2,#H'0100	LOAD.W	(A3)+OGCPMX,#H'0180; Gnre la table de chasse.	LOAD.L	A1,#(A3)+OGCWID	LOAD.L	A2,#(A4)+oxcLENGTH	LOAD.L	A5,#(A4)+oxcXMAXS	LOAD.W	D3,#128-130$:	LOAD.W	D2,(A6)+OXCIXG	ADD.W	D2,(A5+)	; D2 <-- chasse minimale (recouvrement impossible !)	LOAD.W	D4,(A2+)	COMP.W	D4,D2	JUMP',HS 31$	LOAD.W	D4,D231$:	CALL	CONVIO	LOAD.B	(A1+),D4	DECJ.W,NMO D3,30$; Gnre la table h1.	LOAD.L	A1,#(A3)+OGCH1	LOAD.L	A2,#(A4)+oxcYMINS	LOAD.W	D3,#128-132$:	LOAD.W	D4,(A2+)	NEG.W	D4	CALL	CONVIO	LOAD.B	(A1+),D4	DECJ.W,NMO D3,32$; Gnre la table h2.	LOAD.L	A1,#(A3)+OGCH2	LOAD.L	A2,#(A4)+oxcYMAXS	LOAD.W	D3,#128-134$:	LOAD.W	D4,(A2+)	CALL	CONVIO	LOAD.B	(A1+),D4	DECJ.W,NMO D3,34$; Prpare le descripteur de fentre.	LOAD.L	A2,#(A6)+OXCDF	; A2 <-- ^descripteur fentre spcial	CLR.W	D4	LOAD.B	D4,(A3)+OGCMWB	LOAD.W	(A2)+ODFIIY,D4	SL.W	D4,#3	LOAD.W	(A2)+ODFDX,D4	LOAD.W	(A2)+ODFFDX,D4	LOAD.W	(A2)+ODFWEX,D4	LOAD.W	D4,(A3)+OGCMHD	LOAD.W	(A2)+ODFDY,D4	LOAD.W	(A2)+ODFFDY,D4	LOAD.W	(A2)+ODFWEY,D4	LOAD.W	(A2)+ODFIIX,#1	LOAD.B	(A2)+ODFMGR,#GRACLIP	LOAD.B	(A2)+ODFNOW,#-1; Gnre tous les caractres.	CLR.W	D340$:	CALL	CONVCAR		; gnre un caractre	INC.W	D3	COMP.W	D3,#128	JUMP,LO 40$	POPM.L	D2..D4,A1,A2,A5	RET;--------\\; CONVCAR >;========/; ; in	D3.W	code d'un caractre;	A3	^gencar en sortie; out	(A3)++	nouvelle matrice; mod	D7.WCONVCAR:	PUSHM.L	D2..D6,A2..A5	LOAD.W	D2,D3		; D2 <-- caractre	LOAD.L	A2,A3		; A2 <-- ^gencar en sortie	LOAD.L	A4,(A6)+OXCIRGPUSHM.L D0..D6,A0..A4,A6	GMI_	OPENRGN		; dbut de dfinition de rgionPOPM.L D0..D6,A0..A4,A6;;?	JUMP,NE 50$	LOAD.L	(A6)+OXCDRG,A5	LOAD.W	(A6)+OXCMOD,#MXCFILL	CALL	DECODE		; dfinition de la rgion	LOAD.L	A4,(A6)+OXCIRG	LOAD.L	A5,(A6)+OXCDRGPUSHM.L D0..D6,A0..A6	GMI_	CLOSERGN	; termine la dfinition de rgionPOPM.L D0..D6,A0..A6	MUL.WU	D3,(A2)+OGCMSB	LOAD.L	A3,#(A2)+OGCMAT	ADD.L	A3,D3		; A3 <-- ^matrice	CLR.L	D3		; D3 <-- limite gauche	LOAD.W	D4,(A2)+OGCMHD	; D4 <-- hauteur matrice	SWAP.W	D4	CLR.W	D4	LOAD.B	D4,(A2)+OGCMWB	SL.W	D4,#3		; D4 <-- largeur matrice	CLR.W	D5	CLR.W	D6	LOAD.B	D6,(A2)+OGCMWB	; D6 <-- largeur matrice en bytesPUSHM.L D0..D6,A0..A6	GMI_	RGNTOBITMAP	; bitmap <-- rgionPOPM.L D0..D6,A0..A650$:	LOAD.L	(A6)+OXCDF+ODFABS,A3 ; met le ^matrice dans le descripteur de fentre	LOAD.W	D3,D2		; D3 <-- caractre	LOAD.W	(A6)+OXCMOD,#MXCOUTL	CALL	DECODE		; bitmap <-- outline90$:	POPM.L	D2..D6,A2..A5	RET;--------\\; CONVIO  >;========/; ; in	D4.W	longueur dans le gencar en entre [pi]; out	D4.W	idem, dans le gencar en sortie [po]; mod	D4.L, D7.WCONVIO:	MUL.WA	D4,(A6)+OXCT	DIV.WA	D4,(A6)+OXCIYE	RET	.INS	XCARDRAW.ASIEND_XCAR:	.END