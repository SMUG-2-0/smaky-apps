	.SBTTL	XCARDRAW.ASI;--------\\; DECODE  >;========/; ; in	D3.W	code du caractre; out	-; mod	D7.WDECODE:	CLR.L	(A6)+ORPOSDECODER:	PUSHM.L	D2..D6,A3,A4	LOAD.W	D2,D3	LOAD.L	A3,(A6)+OXCPI	LOAD.W	D4,D3	SL.W	D4,#2	LOAD.L	A4,#(A3)+oxcPCHAR	LOAD.L	D4,(A4)+(D4.W)	LOAD.L	A4,#(A3)+(D4.L)	; A4 <-- ^description du caractreLOOP$:	LOAD.B	D3,(A4+)	INC.L	A4	COMP.B	D3,#xcOPBEGIN	JUMP,EQ BEGIN$	COMP.B	D3,#xcOPLINE	JUMP,EQ LINE$	COMP.B	D3,#xcOPCURVE	JUMP,EQ CURVE$	COMP.B	D3,#xcOPADDCHAR	JUMP,EQ ADDCHAR$	COMP.B	D3,#xcOPFILLI	JUMP,EQ FILLI$	COMP.B	D3,#xcOPFILLA	JUMP,EQ FILLA$	JUMP	END$BEGIN$:	LOAD.L	(A6)+OLPOS,(A4+)	JUMP	LOOP$LINE$:	LOAD.L	D3,(A6)+OLPOS	LOAD.L	D4,(A4+)	CALL	LINE	LOAD.L	(A6)+OLPOS,D4	JUMP	LOOP$CURVE$:	LOAD.L	D3,(A6)+OLPOS	LOAD.L	D4,(A4+)	LOAD.L	D5,(A4+)	LOAD.L	D6,(A4+)	CALL	CURVE	LOAD.L	(A6)+OLPOS,D6	JUMP	LOOP$ADDCHAR$:	LOAD.L	(A6)+ORPOS,(A4+)	CLR.W	D3	LOAD.B	D3,(A4+)	INC.L	A4	CALL	DECODER		; hop, rcursif ...	JUMP	LOOP$FILLI$:	JUMP	LOOP$FILLA$:	JUMP	LOOP$END$:	LOAD.W	D4,D2	SL.W	D4,#1	LOAD.L	A4,#(A3)+oxcLENGTH	LOAD.W	D4,(A4)+(D4.W)	CALL	SCALE	LOAD.W	(A6)+OWCAR,D4	POPM.L	D2..D6,A3,A4	RET;--------\\; LINE    >;========/; ; in	D3.L	P1 (y;x);	D4.L	P2 (y;x); out	-; mod	D7.WLINE:	PUSHM.L	D0..D4	CALL	CONVD3	EX.L	D3,D4	CALL	CONVD3	EX.L	D3,D4	LOAD.W	D0,D3		; D0 <-- P1[x]	SWAP.W	D0	LOAD.L	D1,D3		; D1 <-- P1[y]	LOAD.W	D2,D4		; D2 <-- P2[x]	SWAP.W	D2	LOAD.L	D3,D4		; D3 <-- P2[y]	LOAD.W	D0,#CHOUIA05	LOAD.W	D1,#CHOUIA05	LOAD.W	D2,#CHOUIA05	LOAD.W	D3,#CHOUIA05	CALL	DRLINE	POPM.L	D0..D4	RET;--------\\; CURVE   >;========/; ; in	D3.L	P1 (y;x);	D4.L	C1 (y;x);	D5.L	C2 (y;x);	D6.L	P2 (y;x); out	-; mod	D7.WCURVE:	PUSHM.L	D3..D6,A4	CALL	CONVD3	EX.L	D3,D4	CALL	CONVD3	EX.L	D3,D4	EX.L	D3,D5	CALL	CONVD3	EX.L	D3,D5	EX.L	D3,D6	CALL	CONVD3	EX.L	D3,D6	SUB.L	SP,#LBZ	LOAD.L	A4,SP		; A4 <-- ^paramtres sur le stack	LOAD.W	(A4)+OBZP1X+0,D3	SWAP.W	D3	LOAD.W	(A4)+OBZP1Y+0,D3	LOAD.W	(A4)+OBZC1X+0,D4	SWAP.W	D3	LOAD.W	(A4)+OBZC1Y+0,D4	LOAD.W	(A4)+OBZC2X+0,D5	SWAP.W	D3	LOAD.W	(A4)+OBZC2Y+0,D5	LOAD.W	(A4)+OBZP2X+0,D6	SWAP.W	D3	LOAD.W	(A4)+OBZP2Y+0,D6	LOAD.W	D3,#CHOUIA05	; D3 <-- p'tit chouia (0.5)	LOAD.W	(A4)+OBZP1X+2,D3	LOAD.W	(A4)+OBZP1Y+2,D3	LOAD.W	(A4)+OBZC1X+2,D3	LOAD.W	(A4)+OBZC1Y+2,D3	LOAD.W	(A4)+OBZC2X+2,D3	LOAD.W	(A4)+OBZC2Y+2,D3	LOAD.W	(A4)+OBZP2X+2,D3	LOAD.W	(A4)+OBZP2Y+2,D3	CALL	BZDRAW	ADD.L	SP,#LBZ	POPM.L	D3..D6,A4	RET;--------\\; CONVD3  >;========/; ; in	D3.L	valeur (y;x); out	D3.L	valeur (y;x); mod	D3.L, D7.WCONVD3:	PUSHM.L	D4,A4	ADD.W	D3,(A6)+ORPOS+2	SWAP.W	D3	ADD.W	D3,(A6)+ORPOS+0	SWAP.W	D3	LOAD.L	D4,D3	CALL	SCALE	LOAD.L	D3,D4	LOAD.L	A4,(A6)+OXCPO	ADD.W	D3,(A4)+OGCLMA	SWAP.W	D3	ADD.W	D3,(A4)+OGCMH1	SWAP.W	D3	POPM.L	D4,A4	RET;--------\\; SCALE   >;========/; ; in	D4.L	valeur [pi]; out	D4.L	valeur [po]; mod	D4.L, D7.WSCALE:	PUSH.L	D3	LOAD.L	D3,D4		; D4 <-- X	SWAP.W	D3		; D3 <-- Y	MUL.WA	D4,(A6)+OXCT	DIV.WA	D4,(A6)+OXCIYE	MUL.WA	D3,(A6)+OXCT	DIV.WA	D3,(A6)+OXCIYE	SWAP.W	D3	LOAD.W	D3,D4	LOAD.L	D4,D3		; D4 <-- Y;X	POP.L	D3	RET;--------\\; BZDRAW  >;========/; Dessine une courbe de bezier.; in	A4.L	^OBZxxx; out	-; mod	D7.WBZDRAW:	PUSHM.L	D0..D5; Calcule une valeur approximative correspondant ; la distance P1C1 + C1C2 + C2P2.	LOAD.L	D3,(A4)+OBZP1X	SUB.L	D3,(A4)+OBZC1X	JUMP',NC POS1$	NEG.L	D3POS1$:	LOAD.L	D2,D3	LOAD.L	D3,(A4)+OBZP1Y	SUB.L	D3,(A4)+OBZC1Y	JUMP',NC POS2$	NEG.L	D3POS2$:	ADD.L	D2,D3	LOAD.L	D3,(A4)+OBZC1X	SUB.L	D3,(A4)+OBZC2X	JUMP',NC POS3$	NEG.L	D3POS3$:	ADD.L	D2,D3	LOAD.L	D3,(A4)+OBZC1Y	SUB.L	D3,(A4)+OBZC2Y	JUMP',NC POS4$	NEG.L	D3POS4$:	ADD.L	D2,D3	LOAD.L	D3,(A4)+OBZC2X	SUB.L	D3,(A4)+OBZP2X	JUMP',NC POS5$	NEG.L	D3POS5$:	ADD.L	D2,D3	LOAD.L	D3,(A4)+OBZC2Y	SUB.L	D3,(A4)+OBZP2Y	JUMP',NC POS6$	NEG.L	D3POS6$:	ADD.L	D2,D3		; D2 <-- distance approximative; Calcule l'incrment en fonction de la distance; approximative (totalement empyrique) !	LOAD.W	D5,#1	COMP.L	D2,#H'10000*320	JUMP',HS STEP$	LOAD.W	D5,#2	COMP.L	D2,#H'10000*160	JUMP',HS STEP$	LOAD.W	D5,#4	COMP.L	D2,#H'10000*80	JUMP',HS STEP$	LOAD.W	D5,#8	COMP.L	D2,#H'10000*40	JUMP',HS STEP$	LOAD.W	D5,#16	COMP.L	D2,#H'10000*20	JUMP',HS STEP$	LOAD.W	D5,#32	COMP.L	D2,#H'10000*10	JUMP',HS STEP$	LOAD.W	D5,#64STEP$:; Calcule tous les points de la courbe de bzier.	CLR.W	D4		; D4 <-- rang initial	LOAD.L	D0,(A4)+OBZP1X	LOAD.L	D1,(A4)+OBZP1Y	; D0/D1 <-- dpartLOOP$:	CALL	BZPOINT		; D2/D3 <-- point	CALL	DRLINE		; trace un segment de droite	LOAD.L	D0,D2	LOAD.L	D1,D3	ADD.W	D4,D5		; D4 <-- rang suivant	COMP.W	D4,#256		; a-t-on fini ?	JUMP,LS LOOP$		; non => LOOP$	POPM.L	D0..D5	RET;--------\\; BZPOINT >;--------/; Calcule un point quelconque situ sur une courbe de bzier.; in	A4.L	^OBZxxx;	D4.W	rang (0..256); out	D2/D3	point (x;y); mod	D2.L, D3.LBZPOINT:	PUSHM.L	D1,D4,A2,A3	LOAD.L	A3,#R16"TABLE$	LOAD.L	A2,A3	LOAD.W	D3,#256	SUB.W	D3,D4	SL.W	D4,#2	SL.W	D3,#2	ADD.W	A3,D4		; A3 <-- ^table, depuis le dbut	ADD.W	A2,D3		; A2 <-- ^table, depuis la fin	LOAD.L	D1,#CHOUIA05	; D1 <-- pour arrondir	LOAD.L	D4,(A4)+OBZP1Y	ADD.L	D4,D1	SWAP.W	D4	MUL.WA	D4,(A3)+0	LOAD.L	D3,D4	LOAD.L	D4,(A4)+OBZC1Y	ADD.L	D4,D1	SWAP.W	D4	MUL.WA	D4,(A3)+2	ADD.L	D3,D4	LOAD.L	D4,(A4)+OBZC2Y	ADD.L	D4,D1	SWAP.W	D4	MUL.WA	D4,(A2)+2	ADD.L	D3,D4	LOAD.L	D4,(A4)+OBZP2Y	ADD.L	D4,D1	SWAP.W	D4	MUL.WA	D4,(A2)+0	ADD.L	D3,D4	ASL.L	D3,#1		; D3 <-- point (y)	LOAD.L	D4,(A4)+OBZP1X	ADD.L	D4,D1	SWAP.W	D4	MUL.WA	D4,(A3)+0	LOAD.L	D2,D4	LOAD.L	D4,(A4)+OBZC1X	ADD.L	D4,D1	SWAP.W	D4	MUL.WA	D4,(A3)+2	ADD.L	D2,D4	LOAD.L	D4,(A4)+OBZC2X	ADD.L	D4,D1	SWAP.W	D4	MUL.WA	D4,(A2)+2	ADD.L	D2,D4	LOAD.L	D4,(A4)+OBZP2X	ADD.L	D4,D1	SWAP.W	D4	MUL.WA	D4,(A2)+0	ADD.L	D2,D4	ASL.L	D2,#1		; D2 <-- point (x)	POPM.L	D1,D4,A2,A3	RET;	1re colonne:	((1-t)^3)*m;	2me colonne:	(3t*(1-t)^2)*m;	avec:		0 < t < 1;			m = (2^15)-1 = 32767TABLE$:	.W	32767	0	; t=0/256	.W	32385	381	; t=1/256	.W	32005	756	; t=2/256	.W	31628	1125	; ...	.W	31255	1488	.W	30884	1846	.W	30517	2197	.W	30152	2543	.W	29790	2883	.W	29431	3217	.W	29075	3546	.W	28722	3869	.W	28372	4186	.W	28024	4498	.W	27680	4804	.W	27338	5105	.W	26999	5400	.W	26663	5690	.W	26330	5974	.W	25999	6253	.W	25672	6527	.W	25347	6795	.W	25024	7058	.W	24705	7316	.W	24388	7569	.W	24074	7816	.W	23763	8059	.W	23454	8296	.W	23148	8528	.W	22845	8756	.W	22545	8978	.W	22247	9195	.W	21951	9408	.W	21659	9615	.W	21369	9818	.W	21081	10016	.W	20796	10209	.W	20514	10397	.W	20234	10581	.W	19957	10760	.W	19682	10935	.W	19410	11104	.W	19141	11270	.W	18874	11431	.W	18609	11587	.W	18347	11739	.W	18087	11886	.W	17830	12029	.W	17575	12168	.W	17323	12302	.W	17073	12432	.W	16826	12558	.W	16581	12679	.W	16338	12797	.W	16098	12910	.W	15860	13019	.W	15625	13125	.W	15391	13226	.W	15160	13323	.W	14932	13416	.W	14706	13505	.W	14482	13591	.W	14260	13672	.W	14041	13750	.W	13824	13824	.W	13609	13894	.W	13396	13960	.W	13186	14023	.W	12977	14082	.W	12771	14137	.W	12568	14189	.W	12366	14238	.W	12167	14283	.W	11969	14324	.W	11774	14362	.W	11581	14396	.W	11390	14428	.W	11201	14456	.W	11015	14480	.W	10830	14501	.W	10648	14520	.W	10467	14534	.W	10289	14546	.W	10112	14555	.W	9938	14560	.W	9766	14563	.W	9595	14562	.W	9427	14559	.W	9261	14553	.W	9096	14543	.W	8934	14531	.W	8773	14516	.W	8615	14498	.W	8458	14478	.W	8304	14454	.W	8151	14428	.W	8000	14400	.W	7851	14368	.W	7703	14334	.W	7558	14298	.W	7415	14259	.W	7273	14217	.W	7133	14174	.W	6995	14127	.W	6859	14079	.W	6724	14028	.W	6592	13974	.W	6461	13919	.W	6331	13861	.W	6204	13801	.W	6078	13738	.W	5954	13674	.W	5832	13608	.W	5711	13539	.W	5592	13469	.W	5475	13396	.W	5359	13321	.W	5245	13245	.W	5133	13167	.W	5022	13087	.W	4913	13005	.W	4805	12921	.W	4699	12835	.W	4595	12748	.W	4492	12659	.W	4391	12569	.W	4291	12477	.W	4193	12383	.W	4096	12288	.W	4001	12191	.W	3907	12093	.W	3815	11993	.W	3724	11892	.W	3634	11790	.W	3546	11686	.W	3460	11581	.W	3375	11475	.W	3291	11367	.W	3209	11259	.W	3128	11149	.W	3049	11038	.W	2970	10926	.W	2894	10813	.W	2818	10699	.W	2744	10584	.W	2671	10468	.W	2600	10351	.W	2529	10233	.W	2460	10115	.W	2393	9995	.W	2326	9875	.W	2261	9754	.W	2197	9633	.W	2134	9511	.W	2073	9388	.W	2012	9264	.W	1953	9140	.W	1895	9016	.W	1838	8891	.W	1783	8766	.W	1728	8640	.W	1675	8514	.W	1622	8387	.W	1571	8260	.W	1521	8133	.W	1472	8006	.W	1424	7878	.W	1377	7751	.W	1331	7623	.W	1286	7495	.W	1242	7367	.W	1199	7239	.W	1158	7111	.W	1117	6983	.W	1077	6855	.W	1038	6727	.W	1000	6600	.W	963	6472	.W	927	6345	.W	892	6218	.W	857	6092	.W	824	5965	.W	791	5839	.W	760	5714	.W	729	5589	.W	699	5464	.W	670	5340	.W	642	5216	.W	614	5093	.W	587	4971	.W	561	4849	.W	536	4728	.W	512	4608	.W	488	4488	.W	465	4369	.W	443	4251	.W	422	4134	.W	401	4018	.W	381	3903	.W	362	3788	.W	343	3675	.W	325	3563	.W	308	3451	.W	291	3341	.W	275	3232	.W	259	3124	.W	244	3017	.W	230	2912	.W	216	2808	.W	203	2705	.W	190	2604	.W	178	2503	.W	166	2405	.W	155	2308	.W	145	2212	.W	135	2118	.W	125	2025	.W	116	1934	.W	107	1844	.W	99	1757	.W	91	1671	.W	84	1586	.W	77	1504	.W	70	1423	.W	64	1344	.W	58	1267	.W	53	1192	.W	48	1119	.W	43	1047	.W	38	978	.W	34	911	.W	31	846	.W	27	783	.W	24	722	.W	21	664	.W	18	607	.W	16	553	.W	13	501	.W	11	452	.W	10	405	.W	8	360	.W	7	318	.W	5	278	.W	4	241	.W	3	206	.W	3	174	.W	2	144	.W	1	117	.W	1	93	.W	1	71	.W	0	53	.W	0	37	.W	0	24	.W	0	13	; ...	.W	0	6	; t=254/256	.W	0	1	; t=255/256	.W	0	0	; t=256/256;--------\\; DRLINE  >;========/; Trace une droite, avec les coordonnes donnes en rels.; in	D0/D1	dpart  (x;y);	D2/D3	arrive (x;y); out	-; mod	D7.WDRLINE:	PUSHM.L	D0..D4,A2..A5	COMP.W	(A6)+OXCMOD,#MXCOUTL	JUMP',EQ OUTL$				; dessine dans la rgion =>	SUB.L	SP,#4*4	LOAD.L	A3,SP		; A3 <-- ^paramtres sur le stack	LOAD.L	(A3)+4*0,D1	LOAD.L	(A3)+4*1,D0	LOAD.L	(A3)+4*2,D3	LOAD.L	(A3)+4*3,D2	LOAD.L	A4,(A6)+OXCIRG	LOAD.L	A5,(A6)+OXCDRGPUSHM.L D0..D6,A0..A6	GMI_	PUTLINE		; rgion <-- une lignePOPM.L D0..D6,A0..A6	ADD.L	SP,#4*4	JUMP'	EXIT$OUTL$:				; dessine dans le bitmap =>	LOAD.L	D4,#CHOUIA05	ADD.L	D0,D4	ADD.L	D1,D4	ADD.L	D2,D4	ADD.L	D3,D4	SWAP.W	D0	LOAD.W	D1,D0		; D1 <-- dpart (y;x)	SWAP.W	D2	LOAD.W	D3,D2		; D3 <-- arrive (y;x)	LOAD.L	D4,D3	LOAD.L	D3,D1	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	EX.L	D3,D4	LOAD.W	D1,#SETDOT	LOAD.L	A2,#(A6)+OXCDF	; A2 <-- ^descripteur fentre spcial	GRA_	LINEEXIT$:	POPM.L	D0..D4,A2..A5	RET	.END