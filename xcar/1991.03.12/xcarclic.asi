	.SBTTL	XCARCLIC.ASI;******;; CLIC ;;******;CLIC:	COMP.W	D3,#KEYMMP	JUMP,EQ CLICM	LOAD.W	D2,D3		; D2 <-- bouton press	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP; Traite le cas o la souris est dans un ascenseur.	LOAD.L	A1,#0	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP; Traite le cas o la souris est dans une icne.	CALL	MOVICONE	; souris dans une icne ?	JUMP,EQ CLICICONE	; oui => CLICICONE				; non =>	CALL	DPLICONE	; dplace toutes les icnes ?	JUMP,EQ LOOP		; oui => LOOP	CALL	PETMOVE		; dplace la petite fentre ?	JUMP,EQ LOOP		; oui => LOOP	LOAD.W	D3,D2		; D3 <-- bouton press	COMP.W	D3,#KEYMGP	JUMP,EQ CLICG	COMP.W	D3,#KEYMDP	JUMP,EQ CLICD	JUMP	BIP;*******;; CLICM ;;*******;CLICM:	LOAD.L	A3,#R16"TMENUMILIEU	LOAD.L	A4,#(A6)+OMPAMI	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	CLR.L	(A4)+(LMM*1)+OMMINA	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA	CLR.L	(A4)+(LMM*4)+OMMINA	CALL	_MMENUS		; choix selon mmenus ...	JUMP,NE BIP	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	DEC.W	D3	JUMP,EQ FILE$	DEC.W	D3	JUMP,EQ EDIT$	DEC.W	D3	JUMP,EQ SHOW$	DEC.W	D3	JUMP,EQ TRANS$	JUMP	LOOPFILE$:	LOAD.W	D3,(A4)+(LMM*1)+OMMSEL	DEC.W	D3	JUMP,NS DOPREND	DEC.W	D3	JUMP,NS DOSAUVE	DEC.W	D3	JUMP,NS DOSAUVEBM	DEC.W	D3	JUMP,NS DOPRENDDF	DEC.W	D3	JUMP,NS DOSAUVEDF	DEC.W	D3	JUMP,NS DOIMAGE	DEC.W	D3	JUMP,NS DODEFIM	DEC.W	D3	JUMP,NS DOFINI	JUMP	LOOPEDIT$:	LOAD.W	D3,(A4)+(LMM*2)+OMMSEL	DEC.W	D3	JUMP,NS DOUNDO	DEC.W	D3	JUMP,NS DOSUNDO	DEC.W	D3	JUMP,NS DOADD	DEC.W	D3	JUMP,NS DODEFGC	DEC.W	D3	JUMP,NS DORELDEL	JUMP	LOOPSHOW$:	LOAD.W	D3,(A4)+(LMM*3)+OMMSEL	SL.W	D3,#1	LOAD.L	A3,#R16"TABLE$	LOAD.W	D4,(A3)+(D3.W)	JUMP	SCALEXTRANS$:	LOAD.W	D3,(A4)+(LMM*4)+OMMSEL	DEC.W	D3	JUMP,NS DOITAL	DEC.W	D3	JUMP,NS DOLARG	DEC.W	D3	JUMP,NS DOPEN	DEC.W	D3	JUMP,NS DOFILL	DEC.W	D3	JUMP,NS DOCFIX	DEC.W	D3	JUMP,NS DOACCENT	JUMP	LOOPTABLE$:	.W	-16	.W	-12	.W	-8	.W	-6	.W	-4	.W	-3	.W	-2	.W	0	.W	+2	.W	+3	.W	+4	.W	+6	.W	+8	.W	+12	.W	+16;***********;; CLICICONE ;;***********;CLICICONE:	COMP.B	D3,#ICOCNEXT	JUMP,EQ CNEXT	COMP.B	D3,#ICOCSHOW	JUMP,EQ CSHOW	COMP.B	D3,#ICOCPREV	JUMP,EQ CPREV	COMP.B	D3,#ICOMOVE	JUMP,EQ OUTIL$	COMP.B	D3,#ICOOBJET	JUMP,EQ OUTIL$	COMP.B	D3,#ICOZONE	JUMP,EQ OUTIL$	COMP.B	D3,#ICOLOUPEP	JUMP,EQ OUTIL$	COMP.B	D3,#ICOLOUPEM	JUMP,EQ OUTIL$	COMP.B	D3,#ICOPOLYL	JUMP,EQ OUTIL$	COMP.B	D3,#ICOPOLYC	JUMP,EQ OUTIL$	COMP.B	D3,#ICOCIRCLE	JUMP,EQ OUTIL$	COMP.B	D3,#ICOLINE	JUMP,EQ OUTIL$	COMP.B	D3,#ICORECT	JUMP,EQ OUTIL$	COMP.B	D3,#ICOELLIPSE	JUMP,EQ OUTIL$	COMP.B	D3,#ICOREGLE	JUMP,EQ OUTIL$	COMP.B	D3,#ICOPOSIMA	JUMP,EQ OUTIL$	COMP.B	D3,#ICORELATIF	JUMP,EQ OUTIL$	COMP.B	D3,#ICOINFO	JUMP,EQ INFO$	COMP.B	D3,#ICODEPLXY	JUMP,EQ DEPL$	COMP.B	D3,#ICODEPLX	JUMP,EQ DEPL$	COMP.B	D3,#ICODEPLY	JUMP,EQ DEPL$	COMP.B	D3,#ICODEPLP1	JUMP,EQ DEPLP$	COMP.B	D3,#ICODEPLP2	JUMP,EQ DEPLP$	COMP.B	D3,#ICODEPLP3	JUMP,EQ DEPLP$	COMP.B	D3,#ICOVCAR	JUMP,EQ VISU$	COMP.B	D3,#ICOVCHAS	JUMP,EQ VISU$	COMP.B	D3,#ICOVCONS	JUMP,EQ VISU$	COMP.B	D3,#ICOUNDO1	JUMP,EQ DOUNDO	COMP.B	D3,#ICOUNDOT	JUMP,EQ DOSUNDO	COMP.B	D3,#ICOADD	JUMP,EQ DOADD	JUMP	BIPOUTIL$:	COMP.B	D3,#ICOPOSIMA	JUMP',NE OUTIL2$	TEST.B	(A6)+OFADEFI+3:#0	JUMP,BC BIPOUTIL2$:	COMP.B	D3,(A6)+OOUTIL	JUMP,EQ BIP	PUSH.W	D3	LOAD.B	D3,(A6)+OOUTIL	CALL	INVICONE	; efface l'ancienne icne	LOAD.B	D4,D3	POP.W	D3	CALL	INVICONE	; allume la nouvelle icne	LOAD.B	(A6)+OOUTIL,D3	COMP.B	D3,#ICORELATIF	JUMP',EQ OUTIL8$	COMP.B	D4,#ICORELATIF	JUMP',EQ OUTIL8$	COMP.B	D3,#ICOREGLE	JUMP',EQ OUTIL8$	COMP.B	D4,#ICOREGLE	JUMP,NE LOOPOUTIL8$:	CALL	DESCAR		; redessine le caractre	JUMP	LOOPINFO$:	CALL	PENGET		; D2 <-- pinceau du caractre	LOAD.L	D4,(A6)+OINFO	CALL	DBOXINFO	; choix des informations ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.L	(A6)+OINFO,D4	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPINFO	COMP.W	D2,#-1	JUMP',EQ INFO8$	LOAD.W	(A6)+OPEN,D2	CALL	PENPUT		; caractre <-- pinceauINFO8$:	CALL	PETAFF		; dessine le petit caractre rel	JUMP	LOOPDEPL$:	COMP.B	D3,(A6)+ODEPL	JUMP,EQ BIP	PUSH.W	D3	LOAD.B	D3,(A6)+ODEPL	CALL	INVICONE	; efface l'ancienne icne	POP.W	D3	CALL	INVICONE	; allume la nouvelle icne	LOAD.B	(A6)+ODEPL,D3	JUMP	LOOPDEPLP$:	COMP.B	D3,(A6)+ODEPLP	JUMP,EQ BIP	PUSH.W	D3	LOAD.B	D3,(A6)+ODEPLP	CALL	INVICONE	; efface l'ancienne icne	POP.W	D3	CALL	INVICONE	; allume la nouvelle icne	LOAD.B	(A6)+ODEPLP,D3	JUMP	LOOPVISU$:	COMP.B	D3,(A6)+OVISU	JUMP,EQ BIP	PUSH.W	D3	LOAD.B	D3,(A6)+OVISU	CALL	INVICONE	; efface l'ancienne icne	POP.W	D3	CALL	INVICONE	; allume la nouvelle icne	LOAD.B	(A6)+OVISU,D3	COMP.B	D3,#ICOVCAR	JUMP',NE VISU4$	LOAD.L	(A6)+OLSTCH,(A6)+OLSTC1VISU4$:	COMP.B	D3,#ICOVCONS	JUMP',NE VISU5$	LOAD.L	(A6)+OLSTCH,(A6)+OLSTC2VISU5$:	CALL	DESCAR		; redessine le caractre	COMP.B	D3,#ICOVCHAS	JUMP,NE LOOP	LOAD.B	D3,#ICOMOVE	COMP.B	D3,(A6)+OOUTIL	JUMP,NE OUTIL$	JUMP	LOOPCNEXT:	COMP.W	(A6)+OXCCAR,#xcNBCAR-1	JUMP,EQ BIP	INC.W	(A6)+OXCCAR	CALL	NEWCAR		; dessine le nouveau caractre	CALL	MAJCODE		; montre le caractre en dition	JUMP	LOOPCPREV:	TEST.W	(A6)+OXCCAR	JUMP,EQ BIP	DEC.W	(A6)+OXCCAR	CALL	NEWCAR		; dessine le nouveau caractre	CALL	MAJCODE		; montre le caractre en dition	JUMP	LOOPCSHOW:	CALL	DBOXCAR		; choix du caractre ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	NEWCAR		; dessine le nouveau caractre	CALL	MAJCODE		; montre le caractre en dition	JUMP	LOOP;*******;; CLICx ;;*******;CLICG:CLICD:	COMP.B	(A6)+OOUTIL,#ICOMOVE	JUMP,EQ CLICMOVE	COMP.B	(A6)+OOUTIL,#ICOOBJET	JUMP,EQ CLICOBJET	COMP.B	(A6)+OOUTIL,#ICOZONE	JUMP,EQ CLICZONE	COMP.B	(A6)+OOUTIL,#ICOLOUPEP	JUMP,EQ CLICLOUPEP	COMP.B	(A6)+OOUTIL,#ICOLOUPEM	JUMP,EQ CLICLOUPEM	COMP.B	(A6)+OOUTIL,#ICOPOLYL	JUMP,EQ CLICPOLYL	COMP.B	(A6)+OOUTIL,#ICOPOLYC	JUMP,EQ CLICPOLYC	COMP.B	(A6)+OOUTIL,#ICOCIRCLE	JUMP,EQ CLICCIRCLE	COMP.B	(A6)+OOUTIL,#ICOLINE	JUMP,EQ CLICLINE	COMP.B	(A6)+OOUTIL,#ICORECT	JUMP,EQ CLICRECT	COMP.B	(A6)+OOUTIL,#ICOELLIPSE	JUMP,EQ CLICELLIPSE	COMP.B	(A6)+OOUTIL,#ICOREGLE	JUMP,EQ CLICREGLE	COMP.B	(A6)+OOUTIL,#ICOPOSIMA	JUMP,EQ CLICPOSIMA	COMP.B	(A6)+OOUTIL,#ICORELATIF	JUMP,EQ CLICRELATIF	JUMP	BIP;**********;; CLICMOVE ;;**********;CLICMOVE:	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ CLICCHAS	CALL	PSSELECT	; slectionne une poigne ...	JUMP,NE BIP	CALL	PSCOPYPT	; OOBTxx <-- OOBPxx	LOAD.W	(A6)+OXICO,#NIVMOVE	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keysLOOP$:	CALL	_SCMO		; remet la sourisSELMO$:	LOAD.B	D3,(A6)+OOUTIL	CALL	_SELMO		; utilise le bon lutin	CALL	DESINFXY	; affiche X= et Y= dans les informationsWAIT$:	LIB	?GETKEY		; attend souris ...	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP,BS WAIT$		; non => WAIT$				; oui =>	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ SELMO$		; oui => SELMO$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	; bouton press ?	JUMP,EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ DACCORD$	COMP.W	D3,#END	JUMP,EQ ANNULE$	COMP.W	D3,#F7	JUMP,EQ SCALEM$	COMP.W	D3,#F8	JUMP,EQ SCALE1$	COMP.W	D3,#F9	JUMP,EQ SCALEP$	COMP.W	D3,#UNDO	JUMP,EQ INIT$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$SCALEM$:	LOAD.W	D3,#-1	CALL	NEXTSCALE	JUMP,NE BIP$	JUMP'	SCALEX$SCALEP$:	LOAD.W	D3,#+1	CALL	NEXTSCALE	JUMP,NE BIP$	JUMP'	SCALEX$SCALE1$:	CLR.W	D4;	JUMP'	SCALEX$SCALEX$:	COMP.W	D4,(A6)+OSCALE	; chelle change ?	JUMP,EQ BIP$		; non => BIP$	LOAD.L	A3,#(A6)+OPSLST	LOAD.L	A4,(A3+)	; A4 <-- ^objet	LOAD.W	D3,(A3+)	; D3 <-- offset	LOAD.L	D3,(A4)+(D3.W)	; D3 <-- position poigne slectionne	CALL	NEWSCALE	; change l'chelle	JUMP	LOOP$CLIC$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#0	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	CALL	MOVICONE	; souris dans une icne ?	JUMP,NE MOVE$	COMP.B	D3,#ICOINFO	JUMP,EQ INFO$	COMP.B	D3,#ICODEPLXY	JUMP,EQ DEPL$	COMP.B	D3,#ICODEPLX	JUMP,EQ DEPL$	COMP.B	D3,#ICODEPLY	JUMP,EQ DEPL$	COMP.B	D3,#ICODEPLP1	JUMP,EQ DEPLP$	COMP.B	D3,#ICODEPLP2	JUMP,EQ DEPLP$	COMP.B	D3,#ICODEPLP3	JUMP,EQ DEPLP$	COMP.B	D3,#ICOINIT	JUMP,EQ INIT$	COMP.B	D3,#ICODACCORD	JUMP,EQ DACCORD$	COMP.B	D3,#ICOANNULE	JUMP,EQ ANNULE$	JUMP	BIP$INFO$:	LOAD.W	D2,#-1	LOAD.L	A3,#(A6)+OPSLST	TEST.L	(A3)		; fin de la table ?	JUMP',EQ INFO29$	; oui => INFO29$	LOAD.L	A4,(A3+)	; A4 <-- ^objet	ADD.L	A3,#2		; A3 <-- saute offset	LOAD.W	D3,(A4)+OOBPEN	; D3 <-- premier diamtreINFO22$:	TEST.L	(A3)		; fin de la table ?	JUMP',EQ INFO26$	; oui => INFO26$	LOAD.L	A4,(A3+)	; A4 <-- ^objet	ADD.L	A3,#2		; A3 <-- saute offset	COMP.W	D3,(A4)+OOBPEN	; partout le mme diamtre ?	JUMP,EQ INFO22$		; oui => INFO22$	JUMP'	INFO29$		; non => INFO29$INFO26$:	LOAD.W	D2,D3INFO29$:	LOAD.L	D4,(A6)+OINFO	; D4 <-- informations	CALL	DBOXINFO	; choix des informations ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.L	(A6)+OINFO,D4	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPINFO	COMP.W	D2,#-1	JUMP,EQ MEND$	LOAD.L	A3,#(A6)+OPSLSTINFO42$:	TEST.L	(A3)		; fin de la table ?	JUMP,EQ MEND$		; oui => MEND$	LOAD.L	A4,(A3+)	; A4 <-- ^objet	ADD.L	A3,#2		; A3 <-- saute offset	LOAD.W	(A4)+OOBPEN,D2	; objet <-- nouveau diamtre	JUMP	INFO42$DEPL$:	COMP.B	D3,(A6)+ODEPL	JUMP,EQ BIP$	PUSH.W	D3	LOAD.B	D3,(A6)+ODEPL	CALL	INVICONE	; efface l'ancienne icne	POP.W	D3	CALL	INVICONE	; allume la nouvelle icne	LOAD.B	(A6)+ODEPL,D3	JUMP	LOOP$DEPLP$:	COMP.B	D3,(A6)+ODEPLP	JUMP,EQ BIP$	PUSH.W	D3	LOAD.B	D3,(A6)+ODEPLP	CALL	INVICONE	; efface l'ancienne icne	POP.W	D3	CALL	INVICONE	; allume la nouvelle icne	LOAD.B	(A6)+ODEPLP,D3	JUMP	LOOP$INIT$:	CALL	PSCOPYTP	; OOBPxx <-- OOBTxx	CALL	DESCAR		; redessine le caractre	JUMP	LOOP$MOVE$:	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A3,#(A6)+OPSLSTMOVE2$:	TEST.L	(A3)		; fin de la table ?	JUMP,EQ OTHER$		; oui => OTHER$	LOAD.L	A4,(A3+)	; A4 <-- ^objet	LOAD.W	D2,(A3+)	; D2 <-- offset	LOAD.L	D3,(A4)+(D2.W)	CALL	DETPOINT	; souris dans le point slectionn ?	JUMP,NE MOVE2$		; non => MOVE2$	LOAD.L	D5,D3	LOAD.W	D6,#-1		; D6 <-- longueur inconnueMLOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP',NE MEND$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE MLOOP$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- position [pi]	COMP.B	(A6)+ODEPL,#ICODEPLX	JUMP',NE OKX$	SWAP.W	D3	SWAP.W	D5	LOAD.W	D3,D5	SWAP.W	D5	SWAP.W	D3OKX$:	COMP.B	(A6)+ODEPL,#ICODEPLY	JUMP',NE OKY$	LOAD.W	D3,D5OKY$:	LOAD.L	D4,D3	SUB.W	D4,D5	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D5	SWAP.W	D4	SWAP.W	D5	LOAD.L	D5,D3	CALL	PSINV		; efface les poignes	CALL	PSDES		; efface les objets	CALL	PSMOVEP		; dplace les objets	CALL	PSINV		; allume les poignes	CALL	PSDES		; allume les objets	JUMP	MLOOP$MEND$:	CALL	PETAFF		; dessine le petit caractre rel	JUMP	LOOP$OTHER$:	CALL	PSCANCEL	; annule le point slectionn	CALL	PSSELECT	; slectionne une autre poigne ...	JUMP,NE DACCORD$	JUMP	LOOP$DACCORD$:	CALL	PSCANCEL	; annule le point slectionn	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPMOVE	JUMP	EXIT$ANNULE$:	CALL	PSCANCEL	; annule le point slectionn	CALL	PSEXCHPT	; OOBTxx <--> OOBPxx	CALL	DESCAR		; redessine le caractre;	JUMP'	EXIT$EXIT$:	CLR.W	(A6)+OXICO	CALL	REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	JUMP	LOOP;**********;; CLICCHAS ;;**********;CLICCHAS:	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP	CALL	DETCHASSE	; dans la poigne de chasse ?	JUMP,NE BIP		; non => BIPLOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP',NE END$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	DESCHASSE	; efface la chasse	CALL	NEWCHASSE	CALL	DESCHASSE	; allume la chasse	JUMP	LOOP$END$:	JUMP	LOOP;************;; CLICLOUPEx ;;************;CLICLOUPEP:	LOAD.W	D3,#+1	JUMP'	CLICLOUPEXCLICLOUPEM:	LOAD.W	D3,#-1;	JUMP'	CLICLOUPEXCLICLOUPEX:	CALL	NEXTSCALE	JUMP,NE BIP	COMP.W	D4,(A6)+OSCALE	; chelle change ?	JUMP,EQ BIP		; non => BIP	LOAD.W	D5,D4	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- centre partie visible [pi]	LOAD.W	D4,D5	CALL	NEWSCALE	; change l'chelle	JUMP	LOOP;***********;; CLICPOLYx ;;***********;CLICPOLYL:	LOAD.B	(A6)+OPOLY,#ICOPLINE	JUMP'	CLICPOLYCLICPOLYC:	LOAD.B	(A6)+OPOLY,#ICOPCURVE;	JUMP'	CLICPOLYCLICPOLY:	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ BIP	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- origine [pi]	LOAD.L	(A6)+OPODEP,D3	; OPODEP <-- position de dpart	LOAD.L	(A6)+OPOARR,D3	; OPOARR <-- position d'arrive	LOAD.L	(A6)+OPOAR1,D3	; OPOARR <-- position d'arrive 1	LOAD.L	(A6)+OPOAR2,D3	; OPOARR <-- position d'arrive 2	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ BIP	CLR.W	(A6)+OPONBO	; OPONBO <-- nb d'objets crs	LOAD.L	(A6)+OPOPOI,#POSNIL	LOAD.W	(A6)+OXICO,#NIVPOLY	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	JUMP	DRAW$LOOP$:	CALL	_SCMO		; remet la sourisSELMO$:	LOAD.B	D3,(A6)+OOUTIL	CALL	_SELMO		; utilise le bon lutin	CALL	DESINFXY	; affiche X= et Y= dans les informationsWAIT$:	LIB	?GETKEY		; attend souris ...	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP,BS WAIT$		; non => WAIT$				; oui =>	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ SELMO$		; oui => SELMO$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	; bouton press ?	JUMP,EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ DACCORD$	COMP.W	D3,#END	JUMP,EQ ANNULE$	COMP.W	D3,#F7	JUMP,EQ SCALEM$	COMP.W	D3,#F8	JUMP,EQ SCALE1$	COMP.W	D3,#F9	JUMP,EQ SCALEP$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$BIPPOI$:	LOAD.L	D3,(A6)+OPOPOI	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; allume la poigne carre	JUMP	BIP$SCALEM$:	LOAD.W	D3,#-1	CALL	NEXTSCALE	JUMP,NE BIP$	JUMP'	SCALEX$SCALEP$:	LOAD.W	D3,#+1	CALL	NEXTSCALE	JUMP,NE BIP$	JUMP'	SCALEX$SCALE1$:	CLR.W	D4;	JUMP'	SCALEX$SCALEX$:	COMP.W	D4,(A6)+OSCALE	; chelle change ?	JUMP,EQ BIP$		; non => BIP$	LOAD.L	D3,(A6)+OPOPOI	CALL	NEWSCALE	; change l'chelle	CALL	IASC$		; allume la poigne carre	JUMP	LOOP$CLIC$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"IASC$	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	CALL	MOVICONE	; souris dans une icne ?	JUMP,NE DRAW$	COMP.B	D3,#ICOOPEN	JUMP,EQ OPEN$	COMP.B	D3,#ICOCLOSE	JUMP,EQ CLOSE$	COMP.B	D3,#ICOPLINE	JUMP,EQ MODE$	COMP.B	D3,#ICOPCURVE	JUMP,EQ MODE$	COMP.B	D3,#ICODEPLXY	JUMP,EQ DEPL$	COMP.B	D3,#ICODEPLX	JUMP,EQ DEPL$	COMP.B	D3,#ICODEPLY	JUMP,EQ DEPL$	COMP.B	D3,#ICODACCORD	JUMP,EQ DACCORD$	COMP.B	D3,#ICOANNULE	JUMP,EQ ANNULE$	JUMP	BIP$OPEN$:	TEST.B	(A6)+OPOOPE	JUMP,NE BIP$	SET.B	(A6)+OPOOPE	JUMP'	OPECLO$CLOSE$:	TEST.B	(A6)+OPOOPE	JUMP,EQ BIP$	CLR.B	(A6)+OPOOPEOPECLO$:	LOAD.B	D3,#ICOOPEN	CALL	INVICONE	; efface l'ancienne icne	LOAD.B	D3,#ICOCLOSE	CALL	INVICONE	; allume la nouvelle icne	JUMP	LOOP$MODE$:	COMP.B	D3,(A6)+OPOLY	JUMP,EQ BIP$	PUSH.W	D3	LOAD.B	D3,(A6)+OPOLY	CALL	INVICONE	; efface l'ancienne icne	POP.W	D3	CALL	INVICONE	; allume la nouvelle icne	LOAD.B	(A6)+OPOLY,D3	JUMP	LOOP$DEPL$:	COMP.B	D3,(A6)+ODEPL	JUMP,EQ BIP$	PUSH.W	D3	LOAD.B	D3,(A6)+ODEPL	CALL	INVICONE	; efface l'ancienne icne	POP.W	D3	CALL	INVICONE	; allume la nouvelle icne	LOAD.B	(A6)+ODEPL,D3	JUMP	LOOP$DRAW$:	LOAD.L	D3,(A6)+OPOPOI	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; efface la poigne carre	COMP.B	(A6)+OPOLY,#ICOPCURVE	JUMP,EQ CURVE$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIPPOI$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- arrive [pi]	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	JUMP,NE ERROR$	LOAD.W	(A4)+OOBTYP,#xcOPLINE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	(A4)+OOBPP1,(A6)+OPOARR	LOAD.L	(A4)+OOBPS1,(A6)+OPOARR	LOAD.L	(A4)+OOBPP2,D3	LOAD.L	(A4)+OOBPS2,D3	CALL	DESOBJET	; allume le premier objetLLOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP',NE LEND$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE LLOOP$	CALL	DESOBJET	; efface l'ancien objet	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- arrive [pi]	COMP.B	(A6)+ODEPL,#ICODEPLY	JUMP',NE LNOY$	LOAD.W	D3,(A6)+OPOARR+2LNOY$:	COMP.B	(A6)+ODEPL,#ICODEPLX	JUMP',NE LNOX$	SWAP.W	D3	LOAD.W	D3,(A6)+OPOARR+0	SWAP.W	D3LNOX$:	LOAD.L	(A4)+OOBPP2,D3	LOAD.L	(A4)+OOBPS2,D3	CALL	DESOBJET	; allume le nouvel objet	JUMP	LLOOP$LEND$:	LOAD.L	D3,(A4)+OOBPP2	COMP.L	D3,(A4)+OOBPP1	JUMP',NE LOK$	CALL	__OBJ_LREMOVE	; ne cre pas un objet nul	LOAD.L	(A6)+OPOPOI,D3	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; allume la poigne carre	JUMP	LOOP$LOK$:	LOAD.L	(A6)+OPOARR,D3	LOAD.L	(A6)+OPOAR1,D3	LOAD.L	D4,(A4)+OOBPP1	CALL	_CALCPSYM	LOAD.L	(A6)+OPOAR2,D4	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ		; allume la poigne ronde	LOAD.L	D3,(A4)+OOBPP2	LOAD.L	(A6)+OPOPOI,D3	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; allume la poigne carre	INC.W	(A6)+OPONBO	; OPONBO <-- un objet de plus	JUMP	LOOP$CURVE$:	COMP.L	(A6)+OPOPOI,#POSNIL	JUMP,EQ FCURVE$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIPPOI$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- arrive [pi]	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	JUMP,NE ERROR$	LOAD.W	(A4)+OOBTYP,#xcOPCURVE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	(A4)+OOBPP1,(A6)+OPOAR1	LOAD.L	(A4)+OOBPS1,(A6)+OPOAR2	LOAD.L	(A4)+OOBPP2,D3	LOAD.L	(A4)+OOBPS2,D3	CALL	DESOBJET	; allume le premier objet	LOAD.L	(A6)+OPOAR1,D3	LOAD.L	(A6)+OPOARR,D3	LOAD.L	D3,(A4)+OOBPP2	LOAD.L	D4,(A4)+OOBPS2	CALL	POINV		; allume la premire poigneCLOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP,NE CEND$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE CLOOP$	PUSH.L	D4	LOAD.L	D3,(A4)+OOBPP2	LOAD.L	D4,(A4)+OOBPS2	CALL	POINV		; efface l'ancienne poigne	POP.L	D4	CALL	DESOBJET	; efface l'ancien objet	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- arrive [pi]	LOAD.L	D4,D3	LOAD.L	D3,(A4)+OOBPP2	CALL	_CALCPSYM	COMP.B	(A6)+ODEPL,#ICODEPLY	JUMP',NE CNOY$	LOAD.W	D4,(A4)+OOBPP2+2CNOY$:	COMP.B	(A6)+ODEPL,#ICODEPLX	JUMP',NE CNOX$	SWAP.W	D4	LOAD.W	D4,(A4)+OOBPP2+0	SWAP.W	D4CNOX$:	LOAD.L	(A4)+OOBPS2,D4	CALL	DESOBJET	; allume le nouvel objet	LOAD.L	D3,(A4)+OOBPP2;	LOAD.L	D4,(A4)+OOBPS2	CALL	POINV		; allume la nouvelle poigne	JUMP	CLOOP$CEND$:	LOAD.L	D3,(A4)+OOBPP2	LOAD.L	D4,(A4)+OOBPS2	CALL	POINV		; teint la dernire poigne;	LOAD.L	D3,(A4)+OOBPP2;	LOAD.L	D4,(A4)+OOBPS2	CALL	_CALCPSYM	LOAD.L	(A6)+OPOAR2,D4	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ		; allume la poigne ronde	LOAD.L	D3,(A4)+OOBPP2	LOAD.L	(A6)+OPOPOI,D3	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; allume la poigne carre	INC.W	(A6)+OPONBO	; OPONBO <-- un objet de plus	JUMP	LOOP$FCURVE$:	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIPPOI$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- arrive [pi]	LOAD.L	(A6)+OPOAR1,D3	LOAD.L	(A6)+OPOAR2,D3	LOAD.L	(A6)+OPOARR,D3	LOAD.L	D4,D3	CALL	POINV		; allume la premire poigneFLOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP',NE FEND$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE FLOOP$	PUSH.L	D4	LOAD.L	D3,(A6)+OPOAR1	LOAD.L	D4,(A6)+OPOAR2	CALL	POINV		; efface l'ancienne poigne	POP.L	D3	CALL	CONVPGPI	; D3 <-- arrive [pi]	COMP.B	(A6)+ODEPL,#ICODEPLY	JUMP',EQ FNOY$	LOAD.W	(A6)+OPOAR2+2,D3FNOY$:	COMP.B	(A6)+ODEPL,#ICODEPLX	JUMP',EQ FNOX$	SWAP.W	D3	LOAD.W	(A6)+OPOAR2+0,D3FNOX$:	LOAD.L	D3,(A6)+OPOAR1	LOAD.L	D4,(A6)+OPOAR2	CALL	POINV		; allume la nouvelle poigne	JUMP	FLOOP$FEND$:	LOAD.L	D3,(A6)+OPOAR1	LOAD.L	D4,(A6)+OPOAR2	CALL	POINV		; teint la dernire poigne	LOAD.L	(A6)+OPOPOI,D3	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; allume la poigne carre	JUMP	LOOP$DACCORD$:	LOAD.W	D3,#1	COMP.B	(A6)+OPOLY,#ICOPCURVE	JUMP',EQ DACC2$	LOAD.W	D3,#2DACC2$:	COMP.W	D3,(A6)+OPONBO	JUMP,HI BIP$	LOAD.L	D3,(A6)+OPOPOI	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; teint la poigne carre	LOAD.L	D3,(A6)+OPOARR	COMP.L	D3,(A6)+OPODEP	JUMP,EQ MAJ$	TEST.B	(A6)+OPOOPE	; mode "ouvert" ?	JUMP,NE MAJ$		; oui => MAJ$	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre le dernier objet	JUMP,NE ERROR$	COMP.B	(A6)+OPOLY,#ICOPCURVE	JUMP',EQ DCURVE$	LOAD.W	(A4)+OOBTYP,#xcOPLINE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	(A4)+OOBPP1,(A6)+OPOARR	LOAD.L	(A4)+OOBPS1,(A6)+OPOARR	LOAD.L	(A4)+OOBPP2,(A6)+OPODEP	LOAD.L	(A4)+OOBPS2,(A6)+OPODEP	CALL	DESOBJET	; allume le dernier objet	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ		; allume la poigne	JUMP	MAJ$DCURVE$:	LOAD.L	A3,A4	CALL	__OBJ_LLAST	; A4 <-- ^dernier objet	LOAD.W	D3,(A6)+OPONBODCURVE2$:	CALL	__OBJ_LPREV	; A4 <-- ^objet prcdent	DEC.W	D3	JUMP',NE DCURVE2$	EX.L	A3,A4		; A3 <-- ^premier objet cr	LOAD.W	(A4)+OOBTYP,#xcOPCURVE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	(A4)+OOBPP1,(A6)+OPOAR1	LOAD.L	(A4)+OOBPS1,(A6)+OPOAR2	LOAD.L	D3,(A3)+OOBPP1	LOAD.L	D4,(A3)+OOBPS1	CALL	_CALCPSYM	LOAD.L	(A4)+OOBPP2,D3	LOAD.L	(A4)+OOBPS2,D4	COMP.W	(A3)+OOBTYP,#xcOPCURVE	JUMP',EQ DCURVE6$	LOAD.L	D3,(A3)+OOBPP1	LOAD.L	D4,(A3)+OOBPP2	CALL	_CALCPSYM	LOAD.L	(A4)+OOBPS2,D4DCURVE6$:	CALL	DESOBJET	; allume le dernier objet	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ		; allume la poigneMAJ$:	CALL	PETAFF		; dessine le petit caractre rel	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPCRPOLY	LOAD.W	D3,(A6)+OPONBO	INC.W	D3	LOAD.W	(A6)+OLSTNB,D3	JUMP	EXIT$ANNULE$:	LOAD.L	D3,(A6)+OPOPOI	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; teint la poigne carre	LOAD.W	D4,(A6)+OPONBO	; D4 <-- nb d'objets crs	JUMP',EQ EXIT$ALOOP$:	CALL	__OBJ_LLAST	; A4 <-- ^dernier objet	JUMP,NE EXIT$	CALL	DESOBJET	; teint l'objet	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ		; teint la poigne	CALL	__OBJ_LREMOVE	; dtruit un objet	DEC.W	D4	JUMP,NE ALOOP$;	JUMP'	EXIT$EXIT$:	CLR.W	(A6)+OXICO	CALL	REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	JUMP	LOOPERROR$:	PUSH.W	D7	CLR.W	(A6)+OXICO	CALL	REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	POP.W	D7	JUMP	ERRORIASC$:	PUSHM.L	D2,D3	LOAD.L	D3,(A6)+OPOPOI	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; inverse la poigne carre	POPM.L	D2,D3	RET;************;; CLICCIRCLE ;;************;CLICCIRCLE:	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ BIP	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- centre [pi]	LOAD.L	D0,D3	CLR.W	D1LOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP,NE END$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE LOOP$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- arrive [pi]	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	LOAD.L	D6,D3	LIB	?CALCHYPO	; D4 <-- rayon	COMP.W	D4,D1	JUMP,EQ LOOP$	LOAD.L	D3,D0	EX.L	D1,D4	CALL	OPEWDO	CALL	_CCMO	LOAD.W	D2,#INVDOT	CALL	CIRCLE		; efface l'ancien cercle	LOAD.W	D4,D1	CALL	CIRCLE		; allume le nouveau cercle	CALL	CLOWDO	JUMP	LOOP$END$:	LOAD.L	D3,D0	LOAD.W	D4,D1	CALL	OPEWDO	CALL	_CCMO	LOAD.W	D2,#INVDOT	CALL	CIRCLE		; efface l'ancien cercle	CALL	CLOWDO	LOAD.W	D3,D1	SWAP.W	D1	LOAD.W	D1,D3;	JUMP	CRELLIPSE; in	D0.L	centre (y;x);	D1.L	rayons (ry;dx); 	D6.L	dplacement (dy;dx)CRELLIPSE:	TEST.L	D1	JUMP,EQ BIP	TEST.W	D6	JUMP',NC INCLX$	NEG.W	D6		; D6 <-- |dx|INCLX$:	LOAD.L	D4,D6	SWAP.W	D4	TEST.W	D4	JUMP',NC INCLY$	NEG.W	D4		; D4 <-- |dy|INCLY$:	COMP.W	D6,D4	JUMP,LO HORIZ$VERT$:	LOAD.L	D5,D1	SWAP.W	D5	MUL.WA	D5,#4	DIV.WA	D5,#3		; D5 <-- r' (pour distance PPx-PSx)	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ BIP	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	JUMP,NE ERROR	LOAD.W	(A4)+OOBTYP,#xcOPCURVE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	D3,D0	SUB.W	D3,D1	LOAD.L	(A4)+OOBPP1,D3	LOAD.L	D3,D0	SUB.W	D3,D1	SWAP.W	D3	ADD.W	D3,D5	SWAP.W	D3	LOAD.L	(A4)+OOBPS1,D3	LOAD.L	D3,D0	ADD.W	D3,D1	LOAD.L	(A4)+OOBPP2,D3	LOAD.L	D3,D0	ADD.W	D3,D1	SWAP.W	D3	ADD.W	D3,D5	SWAP.W	D3	LOAD.L	(A4)+OOBPS2,D3	CALL	DESOBJET	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	JUMP,NE ERROR	LOAD.W	(A4)+OOBTYP,#xcOPCURVE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	D3,D0	ADD.W	D3,D1	LOAD.L	(A4)+OOBPP1,D3	LOAD.L	D3,D0	ADD.W	D3,D1	SWAP.W	D3	SUB.W	D3,D5	SWAP.W	D3	LOAD.L	(A4)+OOBPS1,D3	LOAD.L	D3,D0	SUB.W	D3,D1	LOAD.L	(A4)+OOBPP2,D3	LOAD.L	D3,D0	SUB.W	D3,D1	SWAP.W	D3	SUB.W	D3,D5	SWAP.W	D3	LOAD.L	(A4)+OOBPS2,D3	CALL	DESOBJET	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ	JUMP	MAJ$HORIZ$:	LOAD.W	D5,D1	MUL.WA	D5,#4	DIV.WA	D5,#3		; D5 <-- r' (pour distance PPx-PSx)	SWAP.W	D1	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ BIP	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	JUMP,NE ERROR	LOAD.W	(A4)+OOBTYP,#xcOPCURVE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	D3,D0	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	LOAD.L	(A4)+OOBPP1,D3	LOAD.L	D3,D0	ADD.W	D3,D5	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	LOAD.L	(A4)+OOBPS1,D3	LOAD.L	D3,D0	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D3	LOAD.L	(A4)+OOBPP2,D3	LOAD.L	D3,D0	ADD.W	D3,D5	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D3	LOAD.L	(A4)+OOBPS2,D3	CALL	DESOBJET	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	JUMP,NE ERROR	LOAD.W	(A4)+OOBTYP,#xcOPCURVE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	D3,D0	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D3	LOAD.L	(A4)+OOBPP1,D3	LOAD.L	D3,D0	SUB.W	D3,D5	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D3	LOAD.L	(A4)+OOBPS1,D3	LOAD.L	D3,D0	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	LOAD.L	(A4)+OOBPP2,D3	LOAD.L	D3,D0	SUB.W	D3,D5	SWAP.W	D3	SUB.W	D3,D1	SWAP.W	D3	LOAD.L	(A4)+OOBPS2,D3	CALL	DESOBJET	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQMAJ$:	CALL	PETAFF		; dessine le petit caractre rel	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPCRCIRCLE	LOAD.W	(A6)+OLSTNB,#2	JUMP	LOOP;*************;; CLICELLIPSE ;;*************;CLICELLIPSE:	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ BIP	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- centre [pi]	LOAD.L	D0,D3	CLR.L	D1LOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP,NE END$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE LOOP$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- arrive [pi]	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	LOAD.L	D6,D3	LOAD.L	D4,D3	LOAD.L	D3,D0	EX.L	D1,D4	CALL	OPEWDO	CALL	_CCMO	LOAD.W	D2,#INVDOT	CALL	ELLIPSE		; efface l'ancienne ellipse	LOAD.L	D4,D1	CALL	ELLIPSE		; allume la nouvelle ellipse	CALL	CLOWDO	JUMP	LOOP$END$:	LOAD.L	D3,D0	LOAD.L	D4,D1	CALL	OPEWDO	CALL	_CCMO	LOAD.W	D2,#INVDOT	CALL	ELLIPSE		; efface l'ancienne ellipse	CALL	CLOWDO	SWAP.W	D6		; <<<<<  choix !!!	JUMP	CRELLIPSE;**********;; CLICLINE ;;**********;CLICLINE:	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ BIP	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- dpart [pi]	LOAD.L	D0,D3	LOAD.L	D1,D3LOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP,NE END$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE LOOP$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- arrive [pi]	LOAD.L	D5,D3	COMP.B	(A6)+ODEPL,#ICODEPLX	JUMP',NE OKX$	SWAP.W	D5	SWAP.W	D0	LOAD.W	D5,D0	SWAP.W	D0	SWAP.W	D5OKX$:	COMP.B	(A6)+ODEPL,#ICODEPLY	JUMP',NE OKY$	LOAD.W	D5,D0OKY$:	CALL	OPEWDO	CALL	_CCMO	LOAD.W	D2,#INVDOT	LOAD.L	D3,D0	LOAD.L	D4,D1	CALL	LINE		; efface l'ancienne ligne	LOAD.L	D4,D5	CALL	LINE		; allume la nouvelle ligne	LOAD.L	D1,D5	CALL	CLOWDO	JUMP	LOOP$END$:	COMP.L	D0,D1		; dpart = arrive ?	JUMP,EQ BIP		; oui => BIP	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ BIP	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	LOAD.W	(A4)+OOBTYP,#xcOPLINE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	(A4)+OOBPP1,D0	LOAD.L	(A4)+OOBPS1,D0	LOAD.L	(A4)+OOBPP2,D1	LOAD.L	(A4)+OOBPS2,D1	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTROND	CALL	IPTQQ	CALL	PETAFF		; dessine le petit caractre rel	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPCRLINE	LOAD.W	(A6)+OLSTNB,#1	JUMP	LOOP;**********;; CLICRECT ;;**********;CLICRECT:	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ BIP	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- dpart [pi]	LOAD.L	D0,D3	LOAD.L	D1,D3LOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP,NE END$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE LOOP$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- arrive [pi]	LOAD.L	D5,D3	CALL	OPEWDO	CALL	_CCMO	LOAD.W	D2,#INVDOT	LOAD.L	D3,D0	LOAD.L	D4,D1	CALL	RECT		; efface l'ancien rectangle	LOAD.L	D4,D5	CALL	RECT		; allume le nouveau rectangle	LOAD.L	D1,D5	CALL	CLOWDO	JUMP	LOOP$END$:	COMP.L	D0,D1		; dpart = arrive ?	JUMP,EQ BIP		; oui => BIP	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ BIP	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	LOAD.W	(A4)+OOBTYP,#xcOPLINE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	D3,D0	LOAD.L	D4,D0	LOAD.W	D4,D1	LOAD.L	(A4)+OOBPP1,D3	LOAD.L	(A4)+OOBPS1,D3	LOAD.L	(A4)+OOBPP2,D4	LOAD.L	(A4)+OOBPS2,D4	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	LOAD.W	(A4)+OOBTYP,#xcOPLINE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	D3,D0	LOAD.W	D3,D1	LOAD.L	D4,D1	LOAD.L	(A4)+OOBPP1,D3	LOAD.L	(A4)+OOBPS1,D3	LOAD.L	(A4)+OOBPP2,D4	LOAD.L	(A4)+OOBPS2,D4	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	LOAD.W	(A4)+OOBTYP,#xcOPLINE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	D3,D1	LOAD.L	D4,D1	LOAD.W	D4,D0	LOAD.L	(A4)+OOBPP1,D3	LOAD.L	(A4)+OOBPS1,D3	LOAD.L	(A4)+OOBPP2,D4	LOAD.L	(A4)+OOBPS2,D4	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ	LOAD.W	D4,#LOB	LOAD.L	A4,#0	CALL	__OBJ_LINSERT	; cre un nouvel objet	LOAD.W	(A4)+OOBTYP,#xcOPLINE	LOAD.W	(A4)+OOBPEN,(A6)+OPEN	LOAD.L	D3,D1	LOAD.W	D3,D0	LOAD.L	D4,D0	LOAD.L	(A4)+OOBPP1,D3	LOAD.L	(A4)+OOBPS1,D3	LOAD.L	(A4)+OOBPP2,D4	LOAD.L	(A4)+OOBPS2,D4	LOAD.L	D3,(A4)+OOBPP1	LOAD.W	D2,#TPTRONDTJ	CALL	IPTQQ	CALL	PETAFF		; dessine le petit caractre rel	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPCRRECT	LOAD.W	(A6)+OLSTNB,#4	JUMP	LOOP;***********;; CLICOBJET ;;***********;CLICOBJET:	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ BIP	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	A3,#0	JUMP'	POS$LOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP',NE END$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE LOOP$POS$:	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- position [pi]	LOAD.L	D4,D3	CALL	OBDET		; A4 <-- ^objet montr	COMP.L	A4,A3		; est-ce toujours le mme objet ?	JUMP,EQ LOOP$		; oui => LOOP$	EX.L	A3,A4	CALL	OBINV		; efface l'ancien objet	LOAD.L	A4,A3	CALL	OBINV		; allume le nouvel objet	JUMP	LOOP$END$:	COMP.L	A3,#0	JUMP,EQ BIP	LOAD.L	A2,A3	LOAD.L	A3,#R16"TMENUOBJET	LOAD.L	A4,#(A6)+OMPAOB	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	CLR.L	(A4)+(LMM*1)+OMMINA	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA	CLR.L	(A4)+(LMM*4)+OMMINA	TSET.B	(A4)+(LMM*0)+3:#3 ; grise la case "duplique"	LOAD.W	D3,(A2)+OOBTYP	COMP.W	D3,#xcOPLINE	JUMP',NE OK2$	TSET.B	(A4)+(LMM*2)+3:#3 ; grise la case "pente"OK2$:	CALL	_MMENUS		; choix selon mmenus ...	JUMP',NE BIP$	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	DEC.W	D3	JUMP,EQ OBJETDETRUIT	DEC.W	D3	JUMP,EQ OBJETDEPLACE	DEC.W	D3	JUMP,EQ BIP$	DEC.W	D3	JUMP,EQ OBJETFRAGMENT	DEC.W	D3	JUMP,EQ OBJETTRANS	LOAD.L	A4,A2	CALL	OBINV		; efface l'objet	JUMP	LOOPBIP$:	LOAD.L	A4,A2	CALL	OBINV		; efface l'objet	JUMP	BIPOBJETDETRUIT:	LOAD.L	A4,A2	SET.B	(A4)+OOBPP1+4	SET.B	(A4)+OOBPP2+4	CALL	ZODETRUIT	; dtruit cet objet	CALL	DESCAR		; redessine le caractre	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPOBDETRUIT	JUMP	LOOPOBJETDEPLACE:	LOAD.L	A4,A2	CALL	OBINV		; efface l'objet	SET.B	(A4)+OOBPP1+4	SET.B	(A4)+OOBPP2+4	LOAD.L	A3,A4	LOAD.W	D3,#OOBPP1	CALL	SRCJOINT	; A4 <-- ^objet jointif suivant	JUMP,NE BIP$	SET.B	(A4)+OOBPP2+4	LOAD.W	D3,#OOBPP2	CALL	SRCJOINT	; A4 <-- ^objet jointif prcdent	JUMP,NE BIP$	SET.B	(A4)+OOBPP1+4	LOAD.L	D0,(A3)+OOBPP1	LOAD.L	D1,(A3)+OOBPP2	LOAD.W	D4,#10	NEG.W	(A6)+OSCALE	CALL	D4SCALE	NEG.W	(A6)+OSCALE	COMP.W	D0,D1	JUMP',LE OKX$	LOAD.W	D2,D0	LOAD.W	D0,D1	LOAD.W	D1,D2OKX$:	SUB.W	D0,D4	ADD.W	D1,D4	SWAP.W	D0	SWAP.W	D1	COMP.W	D0,D1	JUMP',LE OKY$	LOAD.W	D2,D0	LOAD.W	D0,D1	LOAD.W	D1,D2OKY$:	SUB.W	D0,D4	ADD.W	D1,D4	SWAP.W	D0	SWAP.W	D1	CALL	ZOINV		; allume la zone	LOAD.L	D3,D1	CALL	CONVPIPG	LOAD.L	D4,D3	ADD.W	D4,(A6)+OWDOPX	SWAP.W	D4	ADD.W	D4,(A6)+OWDOPY	SWAP.W	D4	CALL	PMOUSE		; met la souris dans le coin	LOAD.W	D4,#2	NTREL	?DELMS	CLR.W	D2		; D2 <-- rien de dupliqu	LOAD.W	(A6)+OLSTOP,#OPOBDEPLACE	JUMP	ZONEDEPDUPBIP$:	CALL	ZOUNSELECT	; dslectionne tous les points	JUMP	BIP$OBJETFRAGMENT:	LOAD.W	D2,(A4)+(LMM*1)+OMMSEL	LOAD.L	A4,A2	CALL	OBINV		; efface l'objet	CALL	OBFRAGMENT	; hop, fragmente	JUMP,NE BIP	CALL	DESCAR		; redessine le caractre	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPOBFRAG	JUMP	LOOPOBJETTRANS:	LOAD.W	D2,(A4)+(LMM*2)+OMMSEL	LOAD.L	A4,A2	CALL	OBINV		; efface l'objet	CALL	OBTRANS		; hop, transforme	JUMP,NE BIP	CALL	DESCAR		; redessine le caractre	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPOBTRANS	JUMP	LOOP;**********;; CLICZONE ;;**********;CLICZONE:	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ BIP	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- dpart [pi]	LOAD.L	D0,D3		; D0 <-- dpart [pi]	LOAD.L	D1,D3		; D1 <-- arrive [pi]LOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP',NE END$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE LOOP$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- arrive [pi]	COMP.L	D3,D1	JUMP,EQ LOOP$	CALL	ZOINV		; efface l'ancienne zone	LOAD.L	D1,D3	CALL	ZOINV		; allume la nouvelle zone	JUMP	LOOP$END$:	COMP.L	D0,D1		; dpart = arrive ?	JUMP,EQ BIP		; oui => BIP	CALL	ZOSELECT	; slectionne les points entours	JUMP,NE BIP$	LOAD.L	A3,#R16"TMENUENTOURE	LOAD.L	A4,#(A6)+OMPAZO	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	CLR.L	(A4)+(LMM*1)+OMMINA	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA	CLR.L	(A4)+(LMM*4)+OMMINA	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCURSOR	JUMP',BS OK2$	CALL	ZOIFDUPLIQUE	; duplique possible ?	JUMP',EQ OK2$	TSET.B	(A4)+(LMM*0)+3:#3 ; grise la case "duplique"	TSET.B	(A4)+(LMM*0)+3:#4 ; grise la case "zoom"	TSET.B	(A4)+(LMM*0)+3:#5 ; grise la case "tourne"	TSET.B	(A4)+(LMM*0)+3:#6 ; grise la case "miroir"OK2$:	CALL	_MMENUS		; choix selon mmenus ...	JUMP',NE BIP$	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	DEC.W	D3	JUMP,EQ ZONEDETRUIT	DEC.W	D3	JUMP,EQ ZONEDEPLACE	DEC.W	D3	JUMP,EQ ZONEDUPLIQUE	DEC.W	D3	JUMP,EQ ZONEZOOM	DEC.W	D3	JUMP,EQ ZONETOURNE	DEC.W	D3	JUMP,EQ ZONEMIROIR	CALL	ZOUNSELECT	; dslectionne tous les points	CALL	ZOINV		; efface la dernire zone	JUMP	LOOPBIP$:	CALL	ZOUNSELECT	; dslectionne tous les points	CALL	ZOINV		; efface la dernire zone	JUMP	BIPZONEDETRUIT:	CALL	ZODETRUIT	; dtruit qq objets	CALL	ZOUNSELECT	; dslectionne tous les points	CALL	ZOINV		; efface la dernire zone	CALL	DESCAR		; redessine le caractre	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPZODETRUIT	JUMP	LOOPZONEDEPLACE:	CLR.W	D2		; D2 <-- rien de dupliqu	LOAD.W	(A6)+OLSTOP,#OPZODEPLACEZONEDEPDUP:	CALL	PSCOPYPT	; OOBTxx <-- OOBPxx	LOAD.L	D6,D1	LOAD.L	D5,D1	LOAD.B	D3,(A6)+OOUTIL	CALL	_SELMO		; utilise le bon lutinLOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP,NE END$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE LOOP$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- position [pi]	COMP.B	(A6)+ODEPL,#ICODEPLX	JUMP',NE OKX$	SWAP.W	D3	SWAP.W	D5	LOAD.W	D3,D5	SWAP.W	D5	SWAP.W	D3OKX$:	COMP.B	(A6)+ODEPL,#ICODEPLY	JUMP',NE OKY$	LOAD.W	D3,D5OKY$:	LOAD.L	D4,D3	SUB.W	D4,D5	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D5	SWAP.W	D4	SWAP.W	D5	LOAD.L	D5,D3	CALL	ZOINV		; efface l'ancienne zone	CALL	ZODEPLACE	; dplace les points slectionns	ADD.W	D0,D4	ADD.W	D1,D4	SWAP.W	D0	SWAP.W	D1	SWAP.W	D4	ADD.W	D0,D4	ADD.W	D1,D4	SWAP.W	D0	SWAP.W	D1	SWAP.W	D4	CALL	ZOINV		; allume la nouvelle zone	JUMP	LOOP$END$:	COMP.L	D1,D6		; dplacement effectu ?	JUMP',EQ ERROR$		; non => ERROR$	CALL	PETAFF		; dessine le petit caractre rel	CALL	PSEXCHPT	; OOBTxx <--> OOBPxx	CALL	DESPOIGNEES	; efface toutes les poignes	CALL	PSEXCHPT	; OOBTxx <--> OOBPxx	CALL	DESPOIGNEES	; allume toutes les poignes	CALL	ZOUNSELECT	; dslectionne tous les points	CALL	ZOINV		; efface la dernire zone	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	JUMP	LOOPERROR$:	CALL	ZOUNSELECT	; dslectionne tous les points	CALL	ZOINV		; efface la dernire zone	TEST.W	D2	JUMP,EQ BIP	LOAD.L	D6,(A6)+OLSTCH	; D6 <-- canal de la liste	JUMP,EQ BIPERROR2$:	CALL	__OBJ_LLAST	; A4 <-- ^dernier objet	JUMP,NE BIP	CALL	__OBJ_LREMOVE	; supprime le dernier objet cr	DEC.W	D2	JUMP,NE ERROR2$	CALL	DESCAR		; redessine le caractre	JUMP	BIPZONEDUPLIQUE:	CALL	ZODUPLIQUE	; duplique tous les objets	LOAD.W	(A6)+OLSTOP,#OPZODUPLIQUE	JUMP	ZONEDEPDUPZONEZOOM:	CALL	PSCOPYPT	; OOBTxx <-- OOBPxx	LOAD.W	D2,(A4)+(LMM*1)+OMMSEL	CALL	ZOZOOM	JUMP',NE 50$	CALL	ZOUNSELECT	; dslectionne tous les points	CALL	ZOINV		; efface la dernire zone	CALL	DESCAR		; redessine le caractre	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPZOZOOM	JUMP	LOOP50$:	PUSH.W	D7	CALL	ZOUNSELECT	; dslectionne tous les points	CALL	ZOINV		; efface la dernire zone	POP.W	D7	JUMP	ERRORZONETOURNE:	CALL	PSCOPYPT	; OOBTxx <-- OOBPxx	LOAD.W	D2,(A4)+(LMM*2)+OMMSEL	CALL	ZOTOURNE	CALL	ZOUNSELECT	; dslectionne tous les points	CALL	ZOINV		; efface la dernire zone	CALL	DESCAR		; redessine le caractre	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPZOTOURNE	JUMP	LOOPZONEMIROIR:	CALL	PSCOPYPT	; OOBTxx <-- OOBPxx	LOAD.W	D2,(A4)+(LMM*3)+OMMSEL	CALL	ZOMIROIR	CALL	ZOUNSELECT	; dslectionne tous les points	CALL	ZOINV		; efface la dernire zone	CALL	DESCAR		; redessine le caractre	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPZOMIROIR	JUMP	LOOP;***********;; CLICREGLE ;;***********;CLICREGLE:	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ BIP	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP	CALL	DETPOINTS	; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.L	D5,D3		; D5 <-- dpart (y;x)	LOAD.W	D2,#TPTROND	CALL	IPTQQ		; efface le point rond	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; allume le point carr de dpart	LOAD.L	D6,#POSNIL	; D6 <-- arrive point	LOAD.L	D0,D5		; D0 <-- arrive ligneALOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP,NE AEND$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE ALOOP$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- arrive [pi]	LOAD.L	D1,D3	LOAD.L	D3,D0	CALL	RGINVL		; efface l'ancienne ligne	LOAD.L	D3,D1	CALL	RGINVL		; allume la nouvelle ligne	LOAD.L	D0,D1	CALL	DETPOINTS	; D3 <-- point o est la souris	COMP.L	D3,D6		; est-on toujours sur le mme point ?	JUMP,EQ ALOOP$		; oui => ALOOP$	COMP.L	D3,D5		; est-on sur le point de dpart ?	JUMP,EQ ALOOP$		; oui => ALOOP$	LOAD.W	D2,#TPTRONDHILI	EX.L	D3,D6	CALL	IPTQQ		; efface l'ancien point	LOAD.L	D3,D6	CALL	IPTQQ		; allume le nouveau point	JUMP	ALOOP$AEND$:	CLR.L	(A6)+OPSLST	; annule le point slectionn avec DETPOINTS !	COMP.L	D6,#POSNIL	JUMP',NE MENU$	LOAD.L	D3,D5	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; efface le point de dpart	LOAD.W	D2,#TPTROND	CALL	IPTQQ		; rallume le point rond	LOAD.L	D3,D0	CALL	RGINVL		; efface la dernire ligne	JUMP	BIPMENU$:	CALL	MENUREGLE	; A3 <-- ^mmenu et A4 <-- ^paramtres	CALL	_MMENUS		; choix selon mmenus ...	PUSHM.L	D3,D7	LOAD.L	D3,D5	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; efface le point de dpart	LOAD.W	D2,#TPTROND	CALL	IPTQQ		; rallume le point rond	LOAD.L	D3,D6	LOAD.W	D2,#TPTRONDHILI	CALL	IPTQQ		; efface le point d'arrive	LOAD.L	D3,D0	CALL	RGINVL		; efface la dernire ligne	POPM.L	D3,D7	TEST.W	D7	JUMP,NE BIP	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	JUMP,EQ LOOP	COMP.W	D3,#5	JUMP,LS REGLEPLAY	COMP.W	D3,#6	JUMP,EQ REGLEREC	COMP.W	D3,#7	JUMP,EQ REGLEVIDE	JUMP	LOOPREGLEPLAY:	CALL	PSCOPYPT	; OOBTxx <-- OOBPxx	LOAD.W	D2,D3	MUL.WU	D2,#LMM	LOAD.W	D2,(A4)+(D2.W)+OMMSEL	MUL.WU	D2,#4	LOAD.L	A4,#(A6)+ORGDIM	LOAD.L	D4,(A4)+(D2.W)	CALL	RGAJUST		; dplace un point	JUMP	LOOPREGLEREC:	SUB.W	D6,D5	SWAP.W	D5	SWAP.W	D6	SUB.W	D6,D5	SWAP.W	D5	SWAP.W	D6	LOAD.W	D3,(A4)+(LMM*6)+OMMSEL	MUL.WU	D3,#4	LOAD.L	A4,#(A6)+ORGDIM	LOAD.L	(A4)+(D3.W),D6	JUMP	LOOPREGLEVIDE:	LOAD.L	A4,#(A6)+ORGDIM	LOAD.W	D4,#8-120$:	CLR.L	(A4+)	DECJ.W,NMO D4,20$	JUMP	LOOP;************;; CLICPOSIMA ;;************;CLICPOSIMA:	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ BIP	TEST.B	(A6)+OFADEFI+3:#0	JUMP,BC BIP	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D3,D4	CALL	CONVPGPF	LOAD.L	(A6)+OIFSPO,D3	; redessine le caractre	LOAD.L	(A6)+OIFSLP,#POSNIL	CALL	DESCAR	JUMP	LOOP;*************;; CLICRELATIF ;;*************;CLICRELATIF:	COMP.B	(A6)+OVISU,#ICOVCHAS	JUMP,EQ BIP	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE BIP	CALL	DETPOINTS	; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.L	D5,D3		; D5 <-- dpart (y;x)	LOAD.W	D2,#TPTROND	CALL	IPTQQ		; efface le point rond	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; allume le point carr de dpart	LOAD.L	D6,#POSNIL	; D6 <-- arrive point	LOAD.L	D0,D5		; D0 <-- arrive ligneALOOP$:	CALL	_SCMO		; remet la souris	CALL	DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement ...	JUMP,NE AEND$	CALL	_IFMOUSEW	; D4 <-- position de la souris	JUMP,NE ALOOP$	LOAD.L	D3,D4	CALL	CONVPGPI	; D3 <-- arrive [pi]	LOAD.L	D1,D3	LOAD.L	D3,D0	CALL	RGINVL		; efface l'ancienne ligne	LOAD.L	D3,D1	CALL	RGINVL		; allume la nouvelle ligne	LOAD.L	D0,D1	CALL	DETPOINTS	; D3 <-- point o est la souris	COMP.L	D3,D6		; est-on toujours sur le mme point ?	JUMP,EQ ALOOP$		; oui => ALOOP$	COMP.L	D3,D5		; est-on sur le point de dpart ?	JUMP,EQ ALOOP$		; oui => ALOOP$	LOAD.W	D2,#TPTRONDHILI	EX.L	D3,D6	CALL	IPTQQ		; efface l'ancien point	LOAD.L	D3,D6	CALL	IPTQQ		; allume le nouveau point	JUMP	ALOOP$AEND$:	CLR.L	(A6)+OPSLST	; annule le point slectionn avec DETPOINTS !	COMP.L	D6,#POSNIL	JUMP',NE MENU$	LOAD.L	D3,D5	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; efface le point de dpart	LOAD.W	D2,#TPTROND	CALL	IPTQQ		; rallume le point rond	LOAD.L	D3,D0	CALL	RGINVL		; efface la dernire ligne	JUMP	BIPMENU$:	LOAD.L	A3,#R16"TMENUREL	LOAD.L	A4,#(A6)+OMPARE	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	CALL	_MMENUS		; choix selon mmenus ...	PUSHM.L	D3,D7	LOAD.L	D3,D5	LOAD.W	D2,#TPTCARRE	CALL	IPTQQ		; efface le point de dpart	LOAD.W	D2,#TPTROND	CALL	IPTQQ		; rallume le point rond	LOAD.L	D3,D6	LOAD.W	D2,#TPTRONDHILI	CALL	IPTQQ		; efface le point d'arrive	LOAD.L	D3,D0	CALL	RGINVL		; efface la dernire ligne	POPM.L	D3,D7	TEST.W	D7	JUMP,NE BIP	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	JUMP,EQ LOOP	CALL	RELAJUST	; met/enlve une contrainte	SET.B	(A6)+OMAJ	SET.B	(A6)+OMAJC	LOAD.W	(A6)+OLSTOP,#OPREL	CALL	DESCAR	JUMP	LOOP	.END