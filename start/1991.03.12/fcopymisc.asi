	.SBTTL	FCOPYMISC.ASI;--------\\; SKIPREP >;========/; Saute tous les noms d'units et de rpertoires devant; un nom de fichier.; in	A3.L	^unit:rp:rp:nom.ext; out	A3.L	^nom.ext; mod	A3.LSKIPREP:	PUSH.W	D3	CLR.W	D310$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE 10$20$:	DEC.W	D3	JUMP',NS 90$	COMP.B	(-A3),#':	JUMP,NE 20$	INC.L	A390$:	POP.W	D3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la wdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; WAITMOVE >;---------/; Attend un dplacement de la souris.; in	-; out	D3.L	touche presse;	D7.W	EQ si souris dplace; mod	D3.L, D7.WWAITMOVE:10$:	LIB	?GETKEY		; attend souris ...	JUMP',NE 20$		; si timeout => 20$	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP',BC 30$		; oui => 30$	JUMP	10$20$:	LOAD.W	D3,#KEYMPO	; D3 <-- dplacement	CLR.W	D7		; D7 <-- souris bouge	JUMP'	90$30$:	LOAD.W	D7,#1		; D7 <-- fin du dplacement	COMP.W	D3,#KEYMGP	JUMP',EQ 90$	COMP.W	D3,#KEYMMP	JUMP',EQ 90$	COMP.W	D3,#KEYMDP	JUMP',EQ 90$	COMP.W	D3,#KEYMGR	JUMP',EQ 90$	COMP.W	D3,#KEYMMR	JUMP',EQ 90$	COMP.W	D3,#KEYMDR	JUMP',EQ 90$	CLR.W	D7		; D7 <-- souris bouge90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLRFIFO >;========/; Vide le fifo du clavier.; in	-; out	-; mod	D7.WCLRFIFO:	PUSH.L	D310$:	LIB	?IFCAR		; une touche presse ?	JUMP,EQ 10$		; oui => 10$	POP.L	D3	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	-; out	-; mod	D7.WAFMENU:	PUSH.L	A3	LOAD.L	A3,#R16"TXMENU$	LIB	?AFMENU	POP.L	A3	RETTXMENU$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN	.END