	.SBTTL	STARTDBOXT;---------\\; DBOXOPEN >;---------/; Ouvre une dbox.; in	A2.L	table;	D2.W	mode; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WDBOXOPEN:	CALL	NORMMOUSE	; remet la flche	DBOX_	OPEN		; ouvre la dbox	RET;---------\\; DBOXEDIT >;---------/; Edite une dbox.; in	A3.L	^dbut ligne;	A4.L	^dans la ligne;	D4.L	fanions;	D5.L	canal; out	D3.W	dernire touche;	D4.L	fanions;	A4.L	^dans la ligne; mod	D3.L, D4.L, D7.W, A4.LDBOXEDIT:	PUSH.W	D210$:	DBOX_	EDIT		; dite ...	COMP.W	D3,#KEYMGR	JUMP,EQ 10$	COMP.W	D3,#KEYMMR	; bouton de souris relch ?	JUMP,EQ 10$		; oui => 10$	COMP.W	D3,#KEYMDR	JUMP,EQ 10$	COMP.W	D3,#KEYSLEEP	; ordre d'endormir le SMAKY ?	JUMP',NE 90$		; non => 90$				; oui =>	CALL	SLEEP		; endort le SMAKY ...	JUMP	10$90$:	POP.W	D2	RET;----------\\; DBOXCLOSE >;----------/; Ferme une dbox.; in	D5.L	canal; out	D7.W	erreur; mod	D7.WDBOXCLOSE:	DBOX_	CLOSE		; ferme la dbox	CALL	AFMENU		; refait les soft-keys	RET;--------\\; DBOXRSK >;--------/; Refait les soft-keys.; in	A2.L	^table DBOX; out	-; mod	-DBOXRSK:	PUSHM.L	D3,D7,A3	LOAD.W	D3,(A2)+2	LOAD.L	A3,#(A2)+(D3.W)	LIB	?AFMENU		; refait les soft-keys	POPM.L	D3,D7,A3	RET;----------\\; DBINVRECT >;----------/; Inverse le rectangle autour d'un objet ODBBOX, ODBFILE ou ODBLINE.; in	D3.L	coordonne dbut;	D4.L	coordonne fin; out	-; mod	D7.W; in	D4.L	position;	D3.W	longueur du rectangle; out	D4.L	position suivante; mod	D4.LDBINVRECT:	PUSHM.L	D2..D4	LOAD.W	D2,(A0)+ODFCX	ADD.W	D4,D2	SR.W	D2,#1		; D2 <-- largeur 1/2 caractre	SUB.W	D3,D2		; D3 <-- dbut en X	ADD.W	D4,D2		; D4 <-- fin en X	SUB.W	D4,D3		; D4 <-- largeur	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#2		; D3 <-- dbut en Y	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#2+2		; D4 <-- hauteur	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRRECT	POPM.L	D2..D4	RETTD