	.SBTTL	STARTFILE;---------\\; DDDEXMUL >;=========/; Dtruit, dplace ou duplique (DDD) tous les fichiers slectionns; sur le disque et dans les diffrentes fentres.; in	A5.L		^description unit source;	A4.L		^nom unit destination;	(A6)+ODDDOP.W	opration (dtruit/dplace/duplique/accs/modifie);	(A6)+OSELNB.W	nb de fichiers slectionns (0..n); out	D7.W		erreur;	A3.L		^nom du fichier ayant caus l'erreur; mod	D7.W, A3.LDDDEXMUL:	PUSHM.L	D3,D4,A1,A2	LOAD.L	A1,#(A5)+OUNNAM	; A1 <-- ^nom source	LOAD.L	A2,A4		; A2 <-- ^nom destination	CALL	DDDOPDBOX	; ouvre la dbox d'affichage	JUMP,NE 90$10$:	CLR.W	D420$:	CALL	GETPFILE	; A3 <-- ^nom du fichier	TCLR.B	(A3)+OFLATT+0:#BATTSEL-24 ; icne slectionne ?	JUMP',BS 30$		; oui => 30$				; non =>	INC.W	D4	COMP.W	D4,(A5)+OUNNBL	JUMP,LO 20$	JUMP'	80$30$:	LOAD.W	(A3)+OFLRAF,#-1	; signal icne  redessiner	LOAD.B	(A5)+OUNMOD,#2^BMAJICO	CALL	DDDEX		; dtruit/dplace/duplique	CALL	DDDERROR	; affiche v. l'erreur	CALL	DDDIFSTOP	; faut-il stopper ?	JUMP',EQ 80$		; oui => 80$	CALL	DDDKYSTOP	; touche "stoppe" presse ?	JUMP,EQ 10$		; non => 10$80$:	CALL	DDDCLDBOX	; ferme la dbox d'affichage	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A1,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; DDDEXALL >;=========/; Dtruit, dplace ou duplique (DDD) tous les fichiers sur le disque; et dans les diffrentes fentres.; in	A5.L		^description unit source;	A4.L		^nom unit destination;	(A6)+ODDDOP.W	opration (dtruit/dplace/duplique/accs/modifie);	(A6)+OSELNB.W	nb de fichiers slectionns (0..n); out	D7.W		erreur;	A3.L		^nom du fichier ayant caus l'erreur; mod	D7.W, A3.LDDDEXALL:	PUSHM.L	D3,D4,A1..A4	PUSH.L	(A5)+OUNFALI	; stack <-- fanions initiaux	LOAD.L	(A5)+OUNFALI,#2^BFLC1E!2^BFLC2A!2^BFLCAC!2^BFLSYS	LOAD.L	A3,#(A5)+OUNNAM	CALL	SKIPREP	PUSH.B	(A3)+0	PUSH.B	(A3)+1		; stack <-- critre initial	PUSH.L	A3	LOAD.B	(A3)+0,#'*	CLR.B	(A3)+1		; met le critre "*"	CALL	SORTALL		; trie tout	CALL	SELECTALL	; slectionne tout	LOAD.L	A1,#(A5)+OUNNAM	; A1 <-- ^nom source	LOAD.L	A2,A4		; A2 <-- ^nom destination	CALL	DDDOPDBOX	; ouvre la dbox d'affichage	JUMP,NE 90$10$:	CLR.W	D420$:	CALL	GETPFILE	; A3 <-- ^nom du fichier	TCLR.B	(A3)+OFLATT+0:#BATTSEL-24 ; icne slectionne ?	JUMP',BS 30$		; oui => 30$				; non =>	INC.W	D4	COMP.W	D4,(A5)+OUNNBL	JUMP,LO 20$	JUMP'	80$30$:	LOAD.W	(A3)+OFLRAF,#-1	; signal icne  redessiner	LOAD.B	(A5)+OUNMOD,#2^BMAJICO	PUSH.L	A4	LOAD.L	A4,A3	LOAD.L	A3,#R16"02$	LOAD.L	A2,#R16"01$	LIB	?CPSTRING	POPM.L	A4	JUMP',NS 40$	LOAD.L	A1,#R16"03$	CALL	DDDAFFILE	; affiche le nom de la commande	LOAD.L	A3,A4		; A3 <-- ^nom destination	CALL	GENBOOT		; gnre le bootstrap	CALL	DDDERROR	; affiche v. l'erreur40$:	LOAD.W	(A6)+ODDDXF,#XFALL ; transfert tous les fichiers	CALL	DDDEX1		; dtruit/dplace/duplique	CALL	DDDERROR	; affiche v. l'erreur	CALL	DDDIFSTOP	; faut-il stopper ?	JUMP',EQ 80$		; oui => 80$	CALL	DDDKYSTOP	; touche "stoppe" presse ?	JUMP,EQ 10$		; non => 10$80$:	CALL	DDDCLDBOX	; ferme la dbox d'affichage	CLR.W	D7		; D7 <-- ok90$:	POP.L	A3	POP.B	(A3)+1		; remet le critre initial	POP.B	(A3)+0	POP.L	(A5)+OUNFALI	; remet les fanions initiaux	PUSH.W	D7	CALL	SELECTUNDO	; annule la slection	CALL	SORTALL		; retrie tout comme avant	POP.W	D7	POPM.L	D3,D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.B	0,CR,-102$:	.ASCIZ	"SYSTEM!CODE"03$:	.ASCIZ	".GENBOOT"	.EVEN;--------\\; DDDEX   >;========/; Dtruit, dplace ou duplique (DDD) un fichier sur le disque; et dans les diffrentes fentres.; in	A5.L		^description unit source;	D4.W		rang (0..n);	A4.L		^nom unit destination;	(A6)+ODDDOP.W	opration (dtruit/dplace/duplique/accs/modifie);	(A6)+OSELNB.W	nb de fichiers slectionns (0..n); out	D7.W		erreur;	A3.L		^nom du fichier ayant caus l'erreur; mod	D7.W, A3.LDDDEX:	CLR.W	(A6)+ODDDXF	; transfert normalDDDEX1:	COMP.W	(A6)+ODDDOP,#5	; modifie ?	JUMP,EQ MODIF$		; oui => MODIF$	CLR.L	(A6)+ODDDAP	; pas d'attributs  ajouter	CLR.L	(A6)+ODDDAM	; pas d'attributs  enlever	PUSHM.L	A1,A2	CALL	_WAITMOUSE	; souris: met le sablier	CALL	PREPFIS	LOAD.L	A1,A3		; A1 <-- ^nom fichier source	CALL	GETTYPE		; D3 <-- type du fichier source	LOAD.W	(A6)+ODDDTY,D3	; ODDDTY <-- type du fichier source	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 06$		; oui => 06$	CALL	PREPFID	LOAD.L	A2,A3		; A2 <-- ^nom fichier destination06$:	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP',EQ 10$		; non => 10$	CALL	DDDAFFILE	; oui => affiche le nom du fichier10$:	COMP.W	D3,#TYPDIR	JUMP',EQ 30$	COMP.W	D3,#TYPDOSSIER	JUMP',EQ 40$;;?	LOAD.L	A3,A1;;?	CALL	SKIPREP		; A3 <-- saute unit:rep:rep:;;?	TEST.B	(A3)		; dossier ?;;?	JUMP',EQ 30$		; oui => 30$				; document =>	COMP.W	(A6)+ODDDOP,#4	; accs ?	JUMP',EQ 20$	CALL	DDDFILES	; effectue un transfert v. selon fichier "!"	JUMP'	90$20$:	CALL	DDDACCES	; cre un accs	JUMP'	90$30$:				; dossier quelconque =>	CALL	DDDDIR		; effectue le transfert d'un dossier	JUMP'	90$40$:				; dossier DOSSIER: =>	CALL	DDDDOSSIER	; duplique DOSSIER:;	JUMP'	90$90$:	POPM.L	A1,A2	TEST.W	D7		; retour EQ/NE	RETMODIF$:	PUSHM.L	D2,D3,A1..A3	CALL	PREPFIS		; A3 <-- ^nom	LOAD.L	A1,A3		; A1 <-- ^nom fichier	CALL	DDDAFFILE	; affiche le nom du fichier	CALL	GETPFILE	; A3 <-- ^nom du fichier	LOAD.L	D3,(A3)+OFLATT	; D3 <-- attributs actuels	LOAD.L	D2,D3	OR.L	D3,(A6)+ODDDAP	; D3 <-- ajoute qq attributs	NOT.L	D3	OR.L	D3,(A6)+ODDDAM	; D3 <-- enlve qq attributs	NOT.L	D3	LOAD.W	D7,#ERSDAEQ	; D7 <-- "... pas ncessaire"	COMP.L	D3,D2		; faut-il changer les attributs ?	JUMP',EQ 80$		; non => 80$				; oui =>	CALL	CHATREX		; change les attributs80$:;;?	CALL	DDDERROR	; affiche v. l'erreur	POPM.L	D2,D3,A1..A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DDDRELEASE >;===========/; Release l'unit destination.; in	A4.L	^nom unit destination; out	-; mod	-DDDRELEASE:	PUSHM.L	D7,A3	LOAD.L	A3,A4		; A3 <-- ^nom unit:rps:*	CALL	SKIPREP	PUSH.B	(A3)	PUSH.L	A3	CLR.B	(A3)	LOAD.L	A3,A4		; A3 <-- ^nom unit:rps:	FOS	?RELEASE	; release l'unit destination	POP.L	A3	POP.B	(A3)		; restitue le nom initial	POPM.L	D7,A3	RET;---------\\; DDDFILES >;=========/; Dtruit, dplace ou duplique un programme, avec les fichiers; indiqus dans le fichier "!".; in	A1.L	^nom fichier source;	A2.L	^nom fichier destination; out	D7.W	erreur;	A3.L	^fichier ayant caus l'erreur; mod	D7.W, A3.LDDDFILES:	PUSHM.L	D1..D6,A3..A5	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP',NE 10$		; oui => 10$	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',NE 10$		; non => 10$	LOAD.L	A3,A1		; A3 <-- ^nom fichier source	CALL	DBOXDELETE	; demande confirmation ...	JUMP,NE 90$		; si rponse "non" => 90$10$:	CALL	_WAITMOUSE	; souris: met le sablier	COMP.W	(A6)+ODDDXF,#XFALL ; transfert tous les fichiers ?	JUMP',EQ 11$		; oui => 11$				; non =>	LOAD.L	A3,A1		; A3 <-- ^nom fichier source	CALL	RDFILES		; A4 <-- ^contenu du fichier "!"	JUMP',EQ 12$		; ok => 12$	COMP.W	D7,#1		; fichier "!" n'existe pas ?	JUMP',EQ 11$		; oui => 11$	COMP.W	D7,#ERFDNE	; fichier "!" n'existe pas ?	JUMP,NE 90$		; non => 90$11$:	CALL	DDDDISK		; effectue un transfert tout bte	JUMP	90$12$:	LOAD.L	A5,A4		; A5 <-- ^contenu du fichier "!"	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',NE 15$		; non => 15$				; oui =>	LOAD.L	A3,A1		; A3 <-- ^nom fichier source	LOAD.L	A4,#(A6)+OBUARGS	CALL	DDDARGS		; demande les arguments du fichier source	JUMP,NE 85$	LOAD.L	D4,(A4)+OFLATT	; D4 <-- attributs source	TEST.L	D4:#BATTD	; attribut "D" prsent ?	JUMP,BS 18$		; oui => 18$14$:				; non =>	LOAD.W	D7,#ERATTD	; D7 <-- fichier indestructible	PUSH.W	D7	FOS	?NAMERROR	; donne le nom du fichier au FOS	POP.W	D7	JUMP	85$15$:				; dplace ou duplique =>	CALL	PREPFIDIFSD	; unit source = destination ?	JUMP',NE 16$		; non => 16$	LOAD.W	D7,#ERSDUPF	; oui => erreur	JUMP	85$16$:	LOAD.L	A3,A2		; A3 <-- ^nom fichier destination	LOAD.L	A4,#(A6)+OBUARGS	CALL	DDDARGS		; demande les arguments du fichier destination	COMP.W	D7,#ERFDNE	JUMP',EQ 18$	TEST.W	D7	JUMP,NE 85$	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP',NE 17$		; oui => 17$	CALL	DBOXDELETE	; demande confirmation ...	JUMP,NE 85$		; si rponse "non" => 85$	CALL	_WAITMOUSE	; souris: met le sablier17$:	LOAD.L	D4,(A4)+OFLATT	; D4 <-- attributs destination	TEST.L	D4:#BATTD	; attribut "D" prsent ?	JUMP,BC 14$		; non => 14$18$:	LOAD.L	A4,A5		; A4 <-- ^contenu du fichier "!"	CALL	DBOXXFFILES	; A4 <-- ^plus loin, et demande comment transfrer ...	JUMP,NE 85$	COMP.W	D3,#F1		; d'accord ?	JUMP,NE 85$		; non => 85$	CALL	DBOXDUPSYSC	; demande quelle(s) imprimante(s) ...	JUMP,NE 85$	CALL	_WAITMOUSE	; souris: met le sablier	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP',NE 20$		; oui => 20$	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 20$		; oui => 20$	CALL	LGFILES		; y a-t-il la place ncessaire ?	JUMP,NE 85$		; non => 85$20$:				; oui =>	CALL	DDDOPDBOX	; ouvre la dbox d'affichage	JUMP,NE 85$	LOAD.W	(A6)+ODDDXF,#XFFILES ; transfert selon fichier "!"	CLR.W	(A6)+ODDDIN	; condition positive	CLR.W	(A6)+ONBSYSC	LOAD.B	(A6)+OBUDSS,#-1	; dossier systme pas encore connu	PUSH.L	A1	PUSH.L	A230$:	CALL	DDDKYSTOP	; touche "stoppe" presse ?	JUMP,NE 80$		; oui => 80$	LOAD.L	A1,(SP)+4	; A1 <-- ^nom dossier source	LOAD.L	A2,(SP)		; A2 <-- ^nom dossier destination	CALL	MAJFILES	; A1/A2 <-- prpare les noms	JUMP',NE 40$	CALL	MAJIFEQ		; condition ngative ?	JUMP',NE 40$		; oui => 40$	LOAD.L	D3,(A6)+ODDDSN	AND.L	D3,D4	COMP.L	D3,(A6)+ODDDSN	; correspond aux switchs numriques ?	JUMP',NE 40$		; non => 40$	TEST.B	(A6)+ODDDSW:#BSWWIN ; switch /W prsent ?	JUMP',BC 36$		; non => 36$	CALL	IFPASSWORD	; y a-t-il un mot de passe ?	JUMP',EQ 40$		; oui => 40$36$:	TEST.B	(A6)+ODDDSW:#BSWSUP ; switch /X prsent ?	JUMP',BS 38$		; oui => 38$	CALL	DDDAFFILE	; affiche le nom du fichier	CALL	DDDLIST		; dtruit, dplace ou duplique sur disque	CALL	DDDERROR	; affiche v. l'erreur	CALL	DDDIFSTOP	; faut-il stopper ?	JUMP',EQ 80$		; oui => 80$	JUMP'	40$38$:	LOAD.L	A3,A2		; A3 <-- ^nom destination	CALL	MAJ2DFILES	; supprime le fichier destination40$:	TEST.B	(A4)		; encore un nom ?	JUMP,NE 30$		; oui => 30$				; non =>	CLR.W	D7		; D7 <-- ok80$:	POP.L	A2	POP.L	A1	PUSH.W	D7	CALL	DDDCLDBOX	; ferme la dbox d'affichage	POP.W	D785$:	PUSH.W	D7	LOAD.L	A4,A5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire du fichier "!"	POP.W	D790$:	POPM.L	D1..D6,A3..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDFILES >;--------/; Lit le fichier "!" associ  un programme.;	TOTO		-->	erreur;	TOTO!TEXT	-->	erreur;	TOTO.TEXT	-->	lit TOTO!TEXT; in	A3.L	^nom fichier source; out	A4.L	^contenu;	D7.W	erreur; mod	D7.W, A4.LRDFILES:	PUSHM.L	D1,D3,D4,D6,A2,A3	LOAD.L	A4,#(A6)+OBUFIT	LOAD.W	D7,#1		; D7 <-- fichier "!" n'existe pas10$:	LOAD.B	D3,(A3+)	JUMP,EQ 90$	COMP.B	D3,#'!	JUMP,EQ 90$	LOAD.B	(A4+),D3	; OBUFIT <-- partie avant l'extension	COMP.B	D3,#'.	JUMP,NE 10$	LOAD.B	(A4)-1,#'!	; OBUFIT <-- remplace "." par "!"12$:	LOAD.B	(A4+),(A3+)	; OBUFIT <-- extension	JUMP,NE 12$	LOAD.L	A3,#(A6)+OBUFIT	LOAD.W	D3,#2^BOPRD	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	_ERCALL		; ouvre le fichier "!"	POPM.L	D0	JUMP,NE 90$	LOAD.B	D3,#-1	LOAD.L	D4,#-1	FOS	?SPOS		; D4 <-- longueur du fichier "!"	PUSH.L	D4	CLR.B	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	POP.L	D4	LOAD.W	D7,#1	TEST.L	D4		; longueur nulle ?	JUMP,EQ 85$		; oui => 85$	INC.L	D4		; D4 <-- +1 pour <0> terminateur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande de la mmoire	JUMP,NE 85$	DEC.L	D4	FOS	?RDBYTE		; buffer <-- fichier "!"	JUMP',NE 80$	CLR.B	(A4)+(D4.L)	; buffer <-- met <0> terminateur	FOS	?CLOSE		; ferme le fichier "!"	JUMP',NE 80$	LOAD.L	A3,#(A6)+OBUFIT	CALL	SKIPREP	LOAD.L	A2,#(A6)+OBUFIB50$:	LOAD.B	D3,(A3+)	JUMP',EQ 52$	COMP.B	D3,#'!	JUMP',EQ 52$	LOAD.B	(A2+),D3	; OBUFIB <-- nom de base du fichier "!"	JUMP	50$52$:	CLR.B	(A2)	JUMP'	90$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire	POP.W	D785$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier "!"	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A2,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; LGFILES >;--------/; Regarde s'il y a assez de place sur l'unit destination en fonction; de la place ncessaire pour tous les fichiers contenus dans le; fichier "!".; in	A1.L	^nom fichier source;	A2.L	^nom fichier destination;	A4.L	^contenu du fichier "!";	D4.L	fanions; out	D7.W	erreur; mod	D7.WLGFILES:	PUSHM.L	D0..D4,A0..A5; Dans le cas d'un dplacement, regarde si les deux premiers; noms d'unit sont identique. Si oui, il y aura forcment assez; de place (par exemple si #MM1:TOTO: et #MM1:TITI:).	COMP.W	(A6)+ODDDOP,#2	; dplace ?	JUMP',NE 06$		; non => 06$				; oui =>	CLR.W	D7		; D7 <-- ok, assez de place	LOAD.L	A3,A1	LOAD.L	A5,A202$:	LOAD.B	D3,(A3+)	COMP.B	D3,#':	JUMP',EQ 04$	COMP.B	D3,(A5+)	; mmes noms d'unit ?	JUMP,EQ 02$	JUMP'	06$		; non => 06$04$:	COMP.B	(A5),#':	JUMP,EQ 99$		; oui => 99$06$:	PUSH.W	(A6)+ODDDOP	PUSH.L	A1	PUSH.L	A2	LOAD.W	(A6)+ODDDOP,#-1	; ce n'est pas une opration !	LOAD.L	A0,A4		; A0 <-- ^contenu	LOAD.L	D0,D4		; D0 <-- fanions	LOAD.L	A3,A1		; A3 <-- ^nom fichier source	CALL	SEARCHUNIT	; A3 <-- ^juste le nom, A5 <-- ^unit	JUMP,NE 80$; Parcourt une premire fois le fichier "!", et effectue la somme; de la taille de tous les fichiers contenus.	CLR.L	D1		; D1 <-- place ncessaire	CLR.W	(A6)+ODDDIN	; condition positive	CLR.W	(A6)+ONBSYSC10$:	COMP.B	(A4),#'"	JUMP,EQ 50$	LOAD.L	A1,(SP)+4	; A1 <-- ^nom dossier source	LOAD.L	A2,(SP)		; A2 <-- ^nom dossier destination	CALL	MAJFILESLG	; A1/A2 <-- prpare les noms	JUMP,NE 50$; Cherche le fichier dans la liste des noms.	PUSHM.L	A1,A2,A4	LOAD.L	A3,A1		; A3 <-- ^nom fichier source	CALL	SKIPREP		; A3 <-- ^nom fichier source (sans unit:rep:)	LOAD.L	A4,(A5)+OUNPLI	; A4 <-- ^liste des noms	CLR.W	D2		; D2 <-- rang initial20$:	TEST.B	(A4)		; nom existe ?	JUMP',EQ 28$		; non => 28$				; oui =>	LOAD.L	A2,A4	LOAD.L	A1,A322$:	LOAD.B	D3,(A1+)	JUMP',EQ 24$	COMP.B	D3,#CR	JUMP',EQ 24$	COMP.B	D3,#SPACE	JUMP',EQ 24$	COMP.B	D3,#'/	JUMP',EQ 24$	CALL	_MINMAJ	COMP.B	D3,(A2+)	; nom trouv ?	JUMP,EQ 22$	JUMP'	28$24$:	TEST.B	(A2)	JUMP',EQ 30$28$:	LOAD.L	A4,#(A4)+LFL	; A4 <-- ^fichier suivant	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,(A5)+OUNNBM	JUMP,LO 20$	JUMP'	38$30$:	LOAD.L	D2,(A4)+OFLLG	; D2 <-- taille du fichier	ADD.L	D2,#256-1	CLR.B	D2		; D2 <-- arrondi au multiple de 256 suprieur	ADD.L	D2,#256+256/4	; D2 <-- place pour BD + petite rserve !	ADD.L	D1,D2		; D1 <-- place ncessaire38$:	POPM.L	A1,A2,A4; Avance sur la ligne suivante du fichier "!".50$:	TEST.B	(A4)		; encore un nom ?	JUMP,NE 10$		; oui => 10$; Regarde s'il reste assez de place sur l'unit destination.	LOAD.L	A3,A2		; A3 <-- ^nom fichier destination	LOAD.L	A4,A255$:	COMP.B	(A4+),#':	JUMP,NE 55$	PUSH.B	(A4)	CLR.B	(A4)	PUSH.L	D0	LOAD.L	D0,#FOS?DISK	CALL	_ERCALL		; D3/D4 <-- place restante/utilise	POPM.L	D0	POP.B	(A4)	TEST.W	D7	JUMP,NE 80$	SL.L	D3,#8		; D3 <-- place restante en bytes	COMP.L	D1,D3		; reste assez de place ?	JUMP,LO 80$		; oui => 80$; Soustrait ( la place ncessaire) la taille de tous les fichiers; destination qui existent dj.	LOAD.L	D2,D3		; D2 <-- place restante	LOAD.L	A4,A0		; A4 <-- ^contenu	LOAD.L	D4,D0		; D4 <-- fanions	CLR.W	(A6)+ODDDIN	; condition positive	CLR.W	(A6)+ONBSYSC60$:	COMP.B	(A4),#'"	JUMP,EQ 65$	LOAD.L	A1,(SP)+4	; A1 <-- ^nom dossier source	LOAD.L	A2,(SP)		; A2 <-- ^nom dossier destination	CALL	MAJFILESLG	; A1/A2 <-- prpare les noms	JUMP',NE 65$	PUSH.L	A4	LOAD.L	A3,A2		; A3 <-- ^fichier destination	LOAD.L	A4,#(A6)+OBUARGD	CALL	DDDARGS		; lit arguments fichier destination	JUMP',NE 64$	LOAD.L	D3,(A4)+OFLLG	; D3 <-- taille du fichier	ADD.L	D3,#256-1	CLR.B	D3		; D3 <-- arrondi au multiple de 256 suprieur	ADD.L	D3,#256+256/4	; D3 <-- place pour BD + petite rserve !	SUB.L	D1,D3		; D1 <-- place ncessaire64$:	POP.L	A4	TEST.L	D1	JUMP',NS 80$	COMP.L	D1,D2		; reste assez de place ?	JUMP',LO 80$		; oui => 80$65$:	TEST.B	(A4)		; encore un nom ?	JUMP,NE 60$		; oui => 60$	LOAD.W	D7,#ERSFULL	; D7 <-- disque plein	JUMP'	90$80$:	CLR.W	D7		; D7 <-- ok90$:	POP.L	A2	POP.L	A1	POP.W	(A6)+ODDDOP99$:	POPM.L	D0..D4,A0..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MAJFILESLG >;-----------/; Prpare les noms des fichiers source et destination.; in	comme MAJFILES;	D4.L	fanions; out	comme MAJFILES;	D7.W	erreur si  ignorer pour la place restante; mod	comme MAJFILESMAJFILESLG:	PUSH.L	D3	CALL	MAJFILES	; prpare les noms	JUMP',NE 80$	TEST.B	(A6)+ODDDDS	; dans dossiers systmes ?	JUMP',T	80$		; oui => 80$	TEST.B	(A6)+ODDDSW:#BSWSUP ; switch /X prsent ?	JUMP',BS 80$		; oui => 80$	CALL	MAJIFEQ		; condition ngative ?	JUMP',NE 80$		; oui => 80$	LOAD.L	D3,(A6)+ODDDSN	AND.L	D3,D4	COMP.L	D3,(A6)+ODDDSN	; correspond aux switchs numriques ?	JUMP',NE 80$		; non => 80$	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	LOAD.W	D7,#1		; D7 <--  ignorer90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; MAJFILES >;---------/; Prpare les noms des fichiers source et destination.; in	A1.L		^nom dossier source;	A2.L		^nom dossier destination;	A4.L		^nom contenu dans fichier "!"; out	A1.L		^nom fichier source;	A2.L		^nom fichier destination;	A4.L		^nom suivant dans fichier "!";	(A6)+ODDDSW.B	switchs trouvs;	(A6)+ODDDSN.L	bits switchs numriques;	(A6)+ODDDAP.L	attributs  ajouter (+);	(A6)+ODDDAM.L	attributs  enlever (-);	(A6)+ODDDI?.B	condition selon .IFEQ;	(A6)+ODDDDS.B	si dans dossiers systmes;	D7.W		erreur; mod	D7.W, A1.L, A2.L, A4.LMAJFILES:	PUSHM.L	D0..D3,A3,A5	PUSH.L	A4	LOAD.L	A5,A1		; A5 <-- ^nom dossier source	CALL	MAJPFILES	; A4 <-- ^nom sans les paramtres "%?"	JUMP,NE IGNORE$	COMP.B	(A4),#'.	; commande ?	JUMP,EQ COMM$		; oui => COMM$				; non =>	CLR.B	(A6)+ODDDSW	LOAD.L	A3,A4	LOAD.B	D3,#'D	LIB	?IFSWITCH	; switch /D ?	JUMP',NE NOSWD$	TSET.B	(A6)+ODDDSW:#BSWDELNOSWD$:	LOAD.B	D3,#'N	LIB	?IFSWITCH	; switch /N ?	JUMP',NE NOSWN$	TSET.B	(A6)+ODDDSW:#BSWNOTNOSWN$:	LOAD.B	D3,#'A	LIB	?IFSWITCH	; switch /A ?	JUMP',NE NOSWA$	TSET.B	(A6)+ODDDSW:#BSWALWNOSWA$:	LOAD.B	D3,#'W	LIB	?IFSWITCH	; switch /W ?	JUMP',NE NOSWW$	TSET.B	(A6)+ODDDSW:#BSWWINNOSWW$:	LOAD.B	D3,#'X	LIB	?IFSWITCH	; switch /X ?	JUMP',NE NOSWX$	TSET.B	(A6)+ODDDSW:#BSWSUPNOSWX$:	LOAD.B	D3,#'G	LIB	?IFSWITCH	; switch /G ?	JUMP',NE NOSWG$	TSET.B	(A6)+ODDDSW:#BSWGRENOSWG$:	CALL	MAJSNFILE	; D3 <-- switchs numriques trouvs	LOAD.L	(A6)+ODDDSN,D3	CALL	MAJ1FILES	; A1 <-- ^nom fichier source dans OBUFJS	CALL	MAJ1FILED	; A2 <-- ^nom fichier destination dans OBUFJS	CALL	MAJ2FILES	; gre les "SMA_", "100_" et "SYS_"; Cherche les ventuels attributs  ajouter ou  enlever; spcifis aprs le nom.	CLR.L	D0		; D0 <-- pas d'attributs  ajouter	CLR.L	D1		; D1 <-- pas d'attributs  enlever	LOAD.B	D2,#'+		; D2 <-- mode ajoute par dfautASKIP$:	LOAD.B	D3,(A4+)	JUMP,EQ AEND$	COMP.B	D3,#CR	JUMP,EQ AEND$	COMP.B	D3,#SPACE	JUMP',EQ ALOOP$	COMP.B	D3,#TAB	JUMP,NE ASKIP$ALOOP$:	LOAD.B	D3,(A4+)	; D3 <-- +/- ou attribut	JUMP,EQ AEND$	COMP.B	D3,#CR	JUMP,EQ AEND$	CALL	_MINMAJ	COMP.B	D3,#'+		; ajoute ?	JUMP',EQ ACHG$	COMP.B	D3,#'-		; enlve ?	JUMP',EQ ACHG$	LOAD.L	A3,#R16"TATTR$-2ASRC$:	ADD.L	A3,#2		; A3 <-- ^suivant	TEST.B	(A3)	JUMP,EQ ALOOP$	COMP.B	D3,(A3)		; attribut trouv ?	JUMP,NE ASRC$		; non => ASRC$				; oui =>	LOAD.B	D3,(A3)+1	; D3 <-- bit correspondant  l'attribut	COMP.B	D2,#'-	JUMP',EQ ASUB$AADD$:	TSET.L	D0:D3		; D0 <-- nouvel attribut  ajouter	JUMP	ALOOP$ASUB$:	TSET.L	D1:D3		; D1 <-- nouvel attribut  enlever	JUMP	ALOOP$ACHG$:				; change de mode =>	LOAD.B	D2,D3		; D2 <-- nouveau mode (+/-)	JUMP	ALOOP$AEND$:	LOAD.L	(A6)+ODDDAP,D0	; mj les attributs  ajouter	LOAD.L	(A6)+ODDDAM,D1	; mj les attributs  enlever	CLR.W	D7		; D7 <-- ok	JUMP	END$COMM$:				; commande =>	LOAD.L	A3,#R16"TCOMM$CLOOP$:	TEST.B	(A3)		; fin de la table ?	JUMP,EQ IGNORE$		; oui => IGNORE$	PUSH.L	A2	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; commande trouve ?	POPM.L	A2	JUMP',NC CFOUND$	; oui => CFOUND$CNEXT$:	TEST.B	(A3+)		; A3 <-- saute le .ASCIZ	JUMP,NE CNEXT$	INC.L	A3		; A3 <-- saute le .B	JUMP	CLOOP$CFOUND$:	TEST.B	(A3+)		; A3 <-- saute le .ASCIZ	JUMP,NE CFOUND$	LOAD.B	D3,(A3)		; D3 <-- .B juste aprs	COMP.B	D3,#5	JUMP,EQ APPEND$	COMP.B	D3,#4	JUMP,EQ GENBOOT$	COMP.B	D3,#3	JUMP,EQ ENDIF$	COMP.B	D3,#2	JUMP,EQ ELSE$	COMP.B	D3,#1	JUMP,NE IGNORE$IFEQ$:				; .IFEQ =>	LOAD.L	A5,#(A6)+ODDDIC	; A5 <-- ^pile des conditions	LOAD.W	D3,(A6)+ODDDIN	INC.W	(A6)+ODDDIN	CLR.B	(A5)+(D3.W)	; condition positive	LOAD.L	A3,A4	LIB	?SKPNAM	LOAD.L	A4,A3	LIB	?SKPNAM	EX.L	A3,A4		; A3 <-- ^1re chane, A4 <-- ^2me chane	CALL	MAJCOMP		; compare les deux chanes	JUMP,NC IGNORE$		; oui => IGNORE$	SET.B	(A5)+(D3.W)	; condition ngative	JUMP	IGNORE$ELSE$:				; .ELSE =>	LOAD.L	A5,#(A6)+ODDDIC	; A5 <-- ^pile des conditions	LOAD.W	D3,(A6)+ODDDIN	JUMP,EQ IGNORE$	DEC.W	D3	NOT.B	(A5)+(D3.W)	; inverse la condition	JUMP	IGNORE$ENDIF$:				; .ENDIF =>	TEST.W	(A6)+ODDDIN	JUMP,EQ IGNORE$	DEC.W	(A6)+ODDDIN	JUMP	IGNORE$GENBOOT$:			; .GENBOOT =>	CALL	MAJIFEQ		; condition ngative ?	JUMP',NE IGNORE$	; oui => IGNORE$	COMP.W	(A6)+ODDDOP,#-1	; est-ce une opration ?	JUMP',EQ IGNORE$	; non => IGNORE$	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ IGNORE$	; oui => IGNORE$	PUSH.L	A1	LOAD.L	A1,A4	CALL	DDDAFFILE	; affiche le nom de la commande	POP.L	A1	LOAD.L	A3,A2		; A3 <-- ^nom destination	CALL	GENBOOT		; gnre le bootstrap	CALL	DDDERROR	; affiche v. l'erreur	JUMP'	IGNORE$APPEND$:			; .APPENDIC =>	CALL	MAJIFEQ		; condition ngative ?	JUMP',NE IGNORE$	; oui => IGNORE$	COMP.W	(A6)+ODDDOP,#-1	; est-ce une opration ?	JUMP',EQ IGNORE$	; non => IGNORE$	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ IGNORE$	; oui => IGNORE$	PUSH.L	A1	LOAD.L	A1,A4	CALL	DDDAFFILE	; affiche le nom de la commande	POP.L	A1	CALL	_APPENDIC	; fusionne START_USER.INFO et SMA_JIP24.GENC	CALL	DDDERROR	; affiche v. l'erreur;	JUMP'	IGNORE$IGNORE$:	LOAD.W	D7,#1		; D7 <-- ignore cette ligne; Regarde s'il faut avance le pointeur (A4) dans le fichier "!".END$:	POP.L	A4		; A4 <-- ^nom contenu dans le fichier "!"	TEST.L	(A6)+OFASYSC	; duplique plusieurs imprimantes ?	JUMP',EQ NEXT$		; non => NEXT$	TEST.W	(A6)+ONBSYSC	JUMP',EQ NEXT$		; ligne normale => NEXT$	JUMP',NC EXIT$		; une autre imprimante => EXIT$	CLR.W	(A6)+ONBSYSC	; y'en a plus =>	LOAD.W	D7,#1		; D7 <-- ignore cette ligneNEXT$:	TEST.B	(A4)	JUMP',EQ EXIT$	COMP.B	(A4+),#CR	; A4 <-- ^nom suivant (ligne suivante)	JUMP,NE NEXT$EXIT$:	POPM.L	D0..D3,A3,A5	TEST.W	D7		; retour EQ/NE	RETTATTR$:	.B	'E,BATTE	.B	'M,BATTM	.B	'R,BATTR	.B	'W,BATTW	.B	'S,BATTS	.B	'G,BATTG	.B	'Y,BATTY	.B	'D,BATTD	.B	'C,BATTC	.B	'A,BATTA	.B	'Z,BATTZ	.B	'X,BATTX	.B	'P,BATTP	.B	'L,BATTL	.B	'U,BATTU	.B	'N,BATTN	.B	'B,BATTB	.B	0TCOMM$:	.ASCIZ	".IFEQ"	.B	1	.ASCIZ	".ELSE"	.B	2	.ASCIZ	".ENDIF"	.B	3	.ASCIZ	".GENBOOT"	.B	4	.ASCIZ	".APPENDIC"	.B	5	.B	0TERM$:	.B	SPACE,TAB,'/,0,-1	.EVEN;--------\\; MAJCOMP >;--------/; Compare deux chanes, l'une pouvant contenir :;	{ch1,ch2,ch3}; in	A3.L	^chane 1;	A4.L	^chane 2; out	D7.W	EQ/NE; mod	D7.WMAJCOMP:	PUSHM.L	D3,A2..A4	LOAD.L	A2,#R16"TERM$	COMP.B	(A3),#'{	JUMP',EQ OR$	COMP.B	(A4),#'{	JUMP',EQ OREX$	LIB	?CPSTRING	JUMP'	EXIT$OREX$:	EX.L	A3,A4		; A3 <-- ^chane avec {,,}OR$:	INC.L	A3		; A3 <-- saute "{"OLOOP$:	LIB	?CPSTRING	JUMP',NC EXIT$ONEXT$:	LOAD.B	D3,(A3+)	JUMP',EQ EXIT$	COMP.B	D3,#'}	JUMP',EQ EXIT$	COMP.B	D3,#',	JUMP,EQ OLOOP$	JUMP	ONEXT$EXIT$:	POPM.L	D3,A2..A4	TEST.W	D7		; retour EQ/NE	RETTERM$:	.B	SPACE,TAB,'/,',,'},0,-1	.EVEN;----------\\; MAJSNFILE >;----------/; Cherche un switch /0../31 derrire un nom.; in	A3.L	^nom de fichier; out	D3.L	bits pour les switchs trouvs; mod	D3.L, D7.WMAJSNFILE:	PUSHM.L	D2,D4,A3	CLR.L	D3		; D3 <-- aucun switch trouv10$:	LOAD.B	D4,(A3+)	JUMP,EQ 90$	COMP.B	D4,#CR	JUMP,EQ 90$	COMP.B	D4,#'/	JUMP,NE 10$	CLR.W	D4	LOAD.B	D4,(A3)	COMP.B	D4,#'0	JUMP,LO 10$	COMP.B	D4,#'9	JUMP,HI 10$	SUB.B	D4,#'0		; D4 <-- 0..9	INC.L	A3	LOAD.B	D2,(A3)	COMP.B	D2,#'0	JUMP',LO 40$	COMP.B	D2,#'9	JUMP',HI 40$	SUB.B	D2,#'0		; D2 <-- 0..9	INC.L	A3	MUL.WU	D4,#10	ADD.W	D4,D240$:	TSET.L	D3:D4		; D3 <-- ajoute le switch trouv	JUMP	10$90$:	POPM.L	D2,D4,A3	RET;----------\\; MAJPFILES >;----------/; Copie la ligne contenue dans le fichier "!" et met  jour les paramtres.; Si le nom contient un paramtre (%?), effectue le remplacement.;	%M	-->	nom de la machine		(ex: 100 ou SYS);	%P	-->	nom de l'imprimante complet	(ex: LQ800);	%Q	-->	nom de l'imprimante sans numro (ex: LQ);	%*	-->	nom de base du fichier "!"	(ex: TOTO); in	A1.L	^nom dossier source;	A2.L	^nom dossier destination;	A4.L	^nom contenu dans le fichier "!"; out	A1.L	^nom dossier source;	A2.L	^nom dossier destination;	A4.L	^nom dans buffer intermdiaire;	D7.W	erreur si rien  faire; mod	D7.W, A1.L, A2.L, A4.LMAJPFILES:	PUSHM.L	D1..D4,A3,A5SKIP$:	LOAD.B	D1,(A4+)	; D1 <-- premier caractre valide	COMP.B	D1,#SPACE	; saute les espaces en dbut de ligne	JUMP,EQ SKIP$	COMP.B	D1,#TAB	JUMP,EQ SKIP$	DEC.L	A4	LOAD.W	D7,#1		; D7 <-- rien  faire	COMP.B	(A4),#CR	; ligne vide ?	JUMP,EQ EXIT$		; oui => EXIT$	CLR.B	(A6)+ODDDDS	; pas dans dossiers systmes	COMP.B	(A4),#'#	JUMP',NE GO$	COMP.B	(A4)+1,#':	; fichier commence par "#:" ?	JUMP',NE GO$		; non => GO$				; oui =>	ADD.L	A4,#2		; A4 <-- saute "#:"	SET.B	(A6)+ODDDDS	; dans dossiers systmes	COMP.B	(A6)+OBUDSS,#-1	; dossier systme dj connu ?	JUMP',NE SYS$		; oui => SYS$	CALL	PREPDSSD	; cherche les dossiers systmes source et destination	JUMP,NE EXIT$SYS$:	LOAD.W	D7,#1		; D7 <-- rien  faire	TEST.B	(A6)+OBUDSS	JUMP,EQ EXIT$	LOAD.L	A1,#(A6)+OBUDSS	; A1 <-- ^dossier systme source	LOAD.L	A2,#(A6)+OBUDSD	; A2 <-- ^dossier systme destinationGO$:	LOAD.L	A3,#(A6)+ODDDLILOOP$:	LOAD.B	D3,(A4+)	JUMP,EQ END$	COMP.B	D3,#CR	JUMP,EQ END$	COMP.B	D3,#'%		; paramtre ?	JUMP',EQ PARAM$		; oui => PARAM$	CALL	_MINMAJ	LOAD.B	(A3+),D3	; nom <-- nom dans fichier "!"	JUMP	LOOP$PARAM$:				; paramtre =>	LOAD.B	D3,(A4+)	JUMP,EQ END$	COMP.B	D3,#CR	JUMP,EQ END$	CALL	_MINMAJ		; D3 <-- caractre aprs le "%"	COMP.B	D3,#'M	JUMP',EQ MACHINE$	COMP.B	D3,#'P	JUMP',EQ PRINT$	COMP.B	D3,#'Q	JUMP',EQ PRINT$	COMP.B	D3,#'*	JUMP,EQ STAR$	LOAD.B	(A3+),#'%	LOAD.B	(A3+),D3	LOAD.B	(A3+),#'.	; met "%X..." si paramtre inconnu !	LOAD.B	(A3+),#'.	LOAD.B	(A3+),#'.	JUMP	LOOP$MACHINE$:			; paramtre %M =>	LOAD.B	(A3+),(A6)+OMANAME+0	LOAD.B	(A3+),(A6)+OMANAME+1	LOAD.B	(A3+),(A6)+OMANAME+2	JUMP	LOOP$PRINT$:				; paramtre %P ou %Q =>	LOAD.L	D2,(A6)+OFASYSC	; duplique plusieurs imprimantes ?	JUMP,EQ LOOP$		; non => LOOP$	COMP.B	D3,#'Q		; %Q ?	JUMP',NE PGO$		; non => PGO$	LOAD.L	D2,(A6)+OFBSYSC	; D2 <-- fanions pour %QPGO$:	COMP.B	D1,#'.		; %P dans une commande (.IFEQ) ?	JUMP',EQ PCOMM$		; oui => PCOMM$	LOAD.W	D4,(A6)+ONBSYSCPLOOP$:	TEST.L	D2:D4		; imprimante  dupliquer ?	JUMP',BS PPUT$		; oui => PPUT$				; non =>	INC.W	D4		; D4 <-- no imprimante suivante	COMP.W	D4,#24	JUMP,LO PLOOP$	LOAD.W	(A6)+ONBSYSC,#-1 ; passe  la ligne "!" suivante	JUMP	LOOP$PPUT$:	CALL	MAJPPRINT	; (A3+) <-- nom de l'imprimante	INC.W	D4		; D4 <-- no imprimante suivante	LOAD.W	(A6)+ONBSYSC,D4	JUMP	LOOP$PCOMM$:				; paramtre %P dans une commande =>	LOAD.B	(A3+),#'{	CLR.W	D4PCLOOP$:	TEST.L	D2:D4		; imprimante  dupliquer ?	JUMP',BC PCNEXT$	; non => PCNEXT$	CALL	MAJPPRINT	; (A3+) <-- nom de l'imprimante	LOAD.B	(A3+),#',PCNEXT$:	INC.W	D4	COMP.W	D4,#24	JUMP,LO PCLOOP$	LOAD.B	(A3)-1,#'}	JUMP	LOOP$STAR$:				; paramtre %* =>	LOAD.L	A5,#(A6)+OBUFIBSLOOP$:	LOAD.B	(A3+),(A5+)	; nom <-- nom de base du fichier "!"	JUMP,NE SLOOP$	DEC.L	A3	JUMP	LOOP$END$:	CLR.B	(A3)	LOAD.L	A4,#(A6)+ODDDLI	; A4 <-- ^ligne sans paramtres %	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,A3,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; MAJPPRINT >;----------/; Met un nom d'imprimante dans le buffer.; in	D4.W	rang de l'imprimante (0..n);	D3.B	"P"/"Q";	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LMAJPPRINT:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+ONMSYSC	MUL.WU	D4,#8	ADD.L	A4,D4		; A4 <-- ^nom de l'imprimanteLOOP$:	LOAD.B	D4,(A4+)	JUMP',EQ EXIT$	COMP.B	D3,#'Q		; %Q ?	JUMP',NE NEXT$		; non => NEXT$	COMP.B	D4,#'0	JUMP',LO NEXT$	COMP.B	D4,#'9		; chiffre ?	JUMP,LS LOOP$		; oui => LOOP$NEXT$:	LOAD.B	(A3+),D4	; nom <-- nom de l'imprimante	JUMP	LOOP$EXIT$:	POPM.L	D4,A4	RET;----------\\; MAJ1FILES >;----------/; Construit un nom source d'aprs le fichier "!".; Si le nom dans le fichier "!" commence par "SYS_*" ou "100_*",; cette chane est remplace par le nom "SMA_".; in	A1.L	^nom dossier source systme;	A5.L	^nom dossier source normal;	A4.L	^nom dans fichier "!"; out	A1.L	^nom fichier source; mod	D7.W, A1.LMAJ1FILES:	PUSHM.L	D2..D4,A2..A5	LOAD.L	A3,A1	CALL	SKIPREP	LOAD.L	D4,A3	SUB.L	D4,A1		; D4 <-- lg du dossier systme	LOAD.L	A3,A5	CALL	SKIPREP	LOAD.L	D3,A3	SUB.L	D3,A5		; D3 <-- lg du dossier normal	COMP.W	D3,D4		; lg identiques ?	JUMP',NE 40$		; non => 40$				; oui =>	LOAD.L	A2,A1	LOAD.L	A3,A5	LOAD.W	D2,D320$:	COMP.B	(A2+),(A3+)	; dossier systme = dossier normal ?	JUMP',NE 40$		; non => 40$	DEC.W	D2		; oui => 30$	JUMP,NE 20$; Met seulement le nom du dossier normal.30$:	LOAD.L	A2,#(A6)+OBUFJS	; A2 <-- ^buffer pour nom source32$:	LOAD.B	(A2+),(A5+)	; buffer <-- dossier unique	DEC.W	D3	JUMP,NE 32$	JUMP'	50$; Met le nom du dossier systme, puis celui du dossier normal.40$:	LOAD.L	A2,#(A6)+OBUFJS	; A2 <-- ^buffer pour nom source	LOAD.B	(A2+),#'(	DEC.W	D442$:	LOAD.B	(A2+),(A1+)	; buffer <-- dossier systme	DEC.W	D4	JUMP,NE 42$	LOAD.B	(A2+),#',	DEC.W	D344$:	LOAD.B	(A2+),(A5+)	; buffer <-- dossier normal	DEC.W	D3	JUMP,NE 44$	LOAD.B	(A2+),#')	LOAD.B	(A2+),#':; Met ensuite le nom du fichier.50$:	LOAD.L	A5,A2	CALL	MAJ1FILE	; buffer <-- nom	LOAD.L	A1,#(A6)+OBUFJS	; A1 <-- ^nom du fichier source	POPM.L	D2..D4,A2..A5	RET;----------\\; MAJ1FILED >;----------/; Construit un nom destination d'aprs le fichier "!".; Si le nom dans le fichier "!" commence par "SYS_*" ou "100_*",; cette chane est remplace par le nom "SMA_".; in	A2.L	^nom dossier destination;	A4.L	^nom dans fichier "!"; out	A2.L	^nom fichier destination; mod	D7.W, A2.LMAJ1FILED:	PUSHM.L	D3,A1,A3..A5	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	A1,#(A6)+OBUFJD	; A1 <-- ^buffer pour nom destination	LOAD.L	A3,A2	CALL	SKIPREP	LOAD.L	D3,A3	SUB.L	D3,A210$:	LOAD.B	(A1+),(A2+)	; buffer <-- dossier destination	DEC.W	D3	JUMP,NE 10$	LOAD.L	A5,A1	CALL	MAJ1FILE	; buffer <-- nom	LOAD.L	A2,#(A6)+OBUFJD	; A2 <-- ^nom du fichier destination90$:	POPM.L	D3,A1,A3..A5	RET;---------\\; MAJ1FILE >;---------/; Construit un nom d'aprs le fichier "!".; Si le nom dans le fichier "!" commence par "SYS_*" ou "100_*",; cette chane est remplace par le nom "SMA_".; in	A4.L	^nom dans fichier "!";	A5.L	^buffer; out	-; mod	D7.WMAJ1FILE:	PUSHM.L	D3,A3..A5	TEST.B	(A6)+ODDDSW:#BSWSUP ; switch /X prsent ?	JUMP',BS 40$		; oui => 40$				; non =>	LOAD.L	A3,A4	CALL	IF100_		; fichier dit "systme" ?	JUMP',NE 40$		; non => 40$				; oui =>	LOAD.B	(A5+),#'S	LOAD.B	(A5+),#'M	LOAD.B	(A5+),#'A	; met SMA_	LOAD.B	(A5+),#'_	ADD.L	A4,#4		; A4 <-- saute "SYS_" ou "100_"40$:	LOAD.B	D3,(A4+)	JUMP',EQ 80$	COMP.B	D3,#CR	JUMP',EQ 80$	COMP.B	D3,#SPACE	JUMP',EQ 80$	COMP.B	D3,#TAB	JUMP',EQ 80$	COMP.B	D3,#'/	JUMP',EQ 80$	CALL	_MINMAJ	LOAD.B	(A5+),D3	; nom <-- nom dans fichier "!"	JUMP	40$80$:	CLR.B	(A5)	POPM.L	D3,A3..A5	RET;----------\\; MAJ2FILES >;----------/; Cette routine s'occupe des problmes 100_ ou SMA_ comme suit:;   1)	regarde si le fichier source SMA_ existe;   2)	si oui, dtruit les ventuels 100_ et SYS_ (destination);   3)	si non, transforme le SMA_ en 100_ ou SYS_ (source et destination); in	A1.L		^nom fichier source;	A2.L		^nom fichier destination; out	-; mod	D7.WMAJ2FILES:	PUSHM.L	D3,D4,A3..A5	CALL	MAJIFEQ		; condition ngative ?	JUMP,NE 90$		; oui => 90$	TEST.B	(A6)+ODDDSW:#BSWSUP ; switch /X prsent ?	JUMP,BS 90$		; oui => 90$	LOAD.L	A3,A1	CALL	SKIPREP	COMP.B	(A3+),#'S	; fichier source systme ?	JUMP,NE 90$		; non => 90$	COMP.B	(A3+),#'M	JUMP,NE 90$	COMP.B	(A3+),#'A	JUMP,NE 90$	COMP.B	(A3+),#'_	JUMP,NE 90$	LOAD.L	A3,A1	CALL	IFGENC		; fichier .GENC ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A3,A1	CALL	SEARCHFILE	; fichier source SMA_ existe ?	JUMP,NE 50$		; non =>				; oui =>	LOAD.L	A5,A4		; A5 <-- ^description source SMA_	LOAD.L	A3,A1	CALL	SKIPREP	LOAD.B	(A3+),(A6)+OMANAME+0	LOAD.B	(A3+),(A6)+OMANAME+1	LOAD.B	(A3+),(A6)+OMANAME+2	LOAD.L	A3,A1	CALL	SEARCHFILE	; fichier source 100_ ou SYS_ existe ?	JUMP',NE 30$		; non =>				; oui =>	LOAD.L	A3,#(A5)+OFLCD	LOAD.L	A4,#(A4)+OFLCD	CALL	COMPDATE	; compare les dates de crations	JUMP,LO 60$30$:	LOAD.L	A3,A1	CALL	SKIPREP	LOAD.B	(A3+),#'S	LOAD.B	(A3+),#'M	LOAD.B	(A3+),#'A	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A5,#(A6)+OMALIST-432$:	ADD.L	A5,#4		; A5 <-- ^nom de machine suivant	TEST.B	(A5)		; nom existe ?	JUMP',EQ 35$		; non => 35$				; oui =>	LOAD.L	A3,A2	CALL	SKIPREP	LOAD.B	(A3+),(A5)+0	LOAD.B	(A3+),(A5)+1	LOAD.B	(A3+),(A5)+2	LOAD.L	A3,A2	CALL	MAJ2DFILES	; supprime le fichier destination "xxx_"	JUMP	32$35$:	LOAD.L	A3,A2	CALL	SKIPREP	LOAD.B	(A3+),#'S	LOAD.B	(A3+),#'M	LOAD.B	(A3+),#'A	JUMP	90$50$:	LOAD.L	A3,A1	CALL	SKIPREP	LOAD.B	(A3+),(A6)+OMANAME+0	LOAD.B	(A3+),(A6)+OMANAME+1	LOAD.B	(A3+),(A6)+OMANAME+2	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	A3,A1	CALL	SEARCHFILE	; fichier source 100_ ou SYS_ existe ?	JUMP',NE 90$		; non =>60$:				; oui =>	LOAD.L	A3,A2;	CALL	SKIPREP;	LOAD.B	(A3+),#'S;	LOAD.B	(A3+),#'M;	LOAD.B	(A3+),#'A;	LOAD.L	A3,A2	CALL	MAJ2DFILES	; supprime le fichier destination "SMA_"	LOAD.L	A3,A2	CALL	SKIPREP	LOAD.B	(A3+),(A6)+OMANAME+0	LOAD.B	(A3+),(A6)+OMANAME+1	LOAD.B	(A3+),(A6)+OMANAME+290$:	POPM.L	D3,D4,A3..A5	RET;-----------\\; MAJ2DFILES >;-----------/; Dtruit un fichier "100_" ou "SYS_" inutile.; in	A3.L	^nom du fichier; out	-; mod	D7.WMAJ2DFILES:	PUSH.L	D0	COMP.W	(A6)+ODDDOP,#-1	; est-ce une opration ?	JUMP',EQ 90$		; non => 90$				; oui =>	LOAD.L	D0,#FOS?DELETE	CALL	_ERCALL		; dtruit le fichier "100_" ou "SYS_"	COMP.W	D7,#ERFDNE	JUMP',EQ 90$	LOAD.W	D0,D7		; D0 <-- ok/erreur	CALL	DDDAFIMB	; affiche <CR> puis qq espaces	LIB	?AFTIM	.ASCIZ	"Dtruit "	.EVEN	PUSH.L	A3	LIB	?AFTEXT		; affiche le nom du fichier source	POP.L	A3	LIB	?AFSPACE	LOAD.W	D7,D0		; D7 <-- ok/erreur	CALL	DDDERROR	; affiche v. l'erreur90$:	POP.L	D0	RET;--------\\; MAJIFEQ >;--------/; Teste si les conditions (imbriques) sont remplies.;;	.ifeq c1;	  .ifeq c2;	    .ifeq c3;	      .. les 3 conditions doivent tre remplies !;	    .endif;	  .endif;	.endif; in	-; out	D7.W	EQ -> condition(s) remplie(s); mod	D7.WMAJIFEQ:	PUSHM.L	D4,A4	LOAD.W	D4,(A6)+ODDDIN	JUMP',EQ OK$	LOAD.L	A4,#(A6)+ODDDIC	; A4 <-- ^pile des conditionsLOOP$:	TEST.B	(A4+)		; condition remplie ?	JUMP',NE NO$		; non => NO$	DEC.W	D4	JUMP,NE LOOP$OK$:	CLR.W	D7		; D7 <-- conditions remplies	JUMP'	EXIT$NO$:	LOAD.W	D7,#1		; D7 <-- conditions pas rempliesEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GENBOOT >;--------/; Gnre le bootstrap sur une unit physique.; in	A3.L	^nom "unit:rep:rep:fichier"; out	D7.W	erreur; mod	D7.WGENBOOT:	PUSHM.L	D2..D4,A2,A3	CLR.W	D7		; D7 <-- ok;;?	TEST.W	(A6)+OSELNB	; slection multiple ?;;?	JUMP',NE 90$		; oui => 90$	COMP.B	(A3),#'#	; unit #... ?	JUMP',NE 90$		; non => 90$	LOAD.L	A2,A320$:	COMP.B	(A2+),#':	JUMP,NE 20$	LOAD.B	D2,(A2)	CLR.B	(A2)	LIB	?AFSPACE	PUSH.L	A3	LIB	?AFTEXT		; affiche ".GENBOOT #MM1:"	POP.L	A3	LOAD.W	D4,#HACHE	; D4 <-- h	LOAD.W	D3,#2^BFRBOOT	; D3 <-- fait juste un "genfboot"	PUSH.L	D0	LOAD.L	D0,#FOS?NFORMAT	CALL	_ERCALL		; moteur ...	POPM.L	D0	LOAD.B	(A2),D290$:	POPM.L	D2..D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IFPASSWORD >;-----------/; Regarde si le serveur a dmarrr avec un mot de passe.; in	-; out	D7.W	EQ => il y a un mot de passe; mod	D7.WIFPASSWORD:	PUSHM.L	D3,D4,D6,A3,A4	CLR.W	D4		; D4 <-- demande le dossier systme	FOS	?GSDIR		; A3 <-- ^dossier systme	JUMP,NE 80$	COMP.B	(A3),#'@	JUMP,NE 80$	CLR.W	D3	FOS	?VASSIGN	; A4 <-- ^nom d'arrive	JUMP',EQ 20$	LOAD.L	A4,A320$:	LOAD.B	D3,(A4+)	JUMP',EQ 80$	COMP.B	D3,#CR	JUMP',EQ 80$	COMP.B	D3,#':	JUMP',EQ 80$	COMP.B	D3,#'.		; accepte @Z.1234:	JUMP',EQ 25$	COMP.B	D3,#'-		; accepte @Z-1234:	JUMP,NE 20$25$:	CALL	_GETANUM	; D4 <-- numro du serveur	CALL	NAMEPASS0	; A3 <-- ^nom du fichier mot de passe	LOAD.W	D3,#2^BOPRD	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	_ERCALL		; fichier mot de passe existe ?	POPM.L	D0	JUMP',NE 80$		; non => 80$	FOS	?CLOSE	CLR.W	D7	JUMP'	90$80$:	LOAD.W	D7,#1		; D7 <-- y'a pas de mot de passe90$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DDDACCES >;=========/; Cre un chemin d'accs  un programme.; in	A1.L	^nom fichier source;	A2.L	^nom fichier destination; out	D7.W	erreur;	A3.L	^fichier ayant caus l'erreur; mod	D7.W, A3.LDDDACCES:	PUSHM.L	D3,D4,D6	LOAD.L	A3,A2	LOAD.L	D3,#DEFATT	; D3 <-- attributs	LOAD.W	D4,#TYPRAND	; D4 <-- type	PUSH.L	D0	LOAD.L	D0,#FOS?CREATE	CALL	_ERCALL		; cre le programme vide	POPM.L	D0	JUMP',NE 90$; Met une date et une heure nulle pour viter de prendre ce fichier; lors des transferts du type "le plus rcent" !	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	_ERCALL	POPM.L	D0	JUMP',NE 90$	CLR.L	D3		; D3 <-- heure 00:00:00	LOAD.L	D4,#H'010180	; D4 <-- date  01/01/80;;?	CLR.L	D4		; D4 <-- date  00/00/00;;?	TSET.L	D4:#31		; D4 <-- astuce pour tromper le FOS !	FOS	?CLOMDC		; met une date nulle90$:	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; DDDDIR  >;========/; Dtruit, dplace ou duplique un dossier, avec tous les fichiers; inclus, les sous-dossiers et leurs fichiers, sous-sous-dossiers, etc.; P.S.	C'est vraiment pas de la tarte !!!; in	A1.L	^nom fichier source;	A2.L	^nom fichier destination; out	D7.W	erreur;	A3.L	^fichier ayant caus l'erreur; mod	D7.W, A3.LDDDDIR:	PUSHM.L	D1..D6,A4	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP',NE 10$		; oui => 10$	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',NE 10$		; non => 10$	LOAD.L	A3,A1		; A3 <-- ^nom dossier source	CALL	DBOXDELETE	; demande confirmation ...	JUMP,NE 90$		; si rponse "non" => 90$10$:	COMP.W	(A6)+ODDDOP,#2	; dplace ?	JUMP',NE 12$		; non => 12$				; oui =>	CALL	DDDQDIRDEPL	; dplace super-rapidement ?	JUMP,EQ	90$		; ok => 90$	COMP.W	D7,#ERNSUNI	; changement d'units physiques ?	JUMP',EQ 12$		; oui => 12$	COMP.W	D7,#ERFAEX	; dossier existe dj ?	JUMP,NE 90$		; non => 90$12$:	CALL	_WAITMOUSE	; souris: met le sablier; Cre une dbox pour afficher les fichiers transfrs.	COMP.W	(A6)+ODDDOP,#3	; duplique ?	JUMP',EQ 15$		; oui => 15$	LOAD.L	A3,A1	CALL	IFUUSE		; dossier ouvert ?	JUMP,NE 90$		; oui => 90$	CALL	IFDREP		; destruction dossier source possible ?	JUMP,NE 90$		; non => 90$15$:	CALL	DDDOPDBOX	; ouvre la dbox d'affichage	JUMP,NE 90$; Transfert tous les fichiers du rpertoire, avec une rcursivit; pour les rpertoires imbriqus.	LOAD.W	(A6)+ODDDXF,#XFDIR ; transfert tout le dossier	LOAD.L	A4,#(A6)+ODDDSTK ; A4 <-- ^stack spcial	CLR.W	D1		; D1 <-- niveau d'imbrication20$:	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 25$		; oui => 25$				; non =>	LOAD.L	A3,A1		; A3 <-- ^nom dossier source	FOS	?GETHACH	; D4 <-- valeur "h" du dossier source	JUMP',EQ 23$	LOAD.W	D4,#HACHE	; D4 <-- h=31 par dfaut23$:	LOAD.W	D2,D4		; D2 <-- valeur "h"	CALL	CREREP		; cre le rpertoire destination	CALL	DDDERROR	; affiche v. l'erreur25$:	CALL	OPEREP		; prpare les noms de rpertoires	PUSH.L	A4	LOAD.L	A3,A1	LOAD.L	A4,A127$:	COMP.B	(A4+),#'*	JUMP,NE 27$	CLR.B	(A4)-1		; A3 <-- ^rpertoires "unit:rep:rep:<0>"	LOAD.B	(A4)+0,#'*	; A4 <-- ^critre "*<0>"	CLR.B	(A4)+1	CLR.W	D3		; D3 <-- mode d'ouverture	FOS	?LISTOP		; D6 <-- canal	LOAD.B	(A4)-1,#'*	CLR.B	(A4)+0	POP.L	A4	CALL	DDDERROR	; affiche v. l'erreur	TEST.W	D7	JUMP,NE 45$30$:	CALL	DDDKYSTOP	; touche "stoppe" presse ?	JUMP,NE 60$		; oui => 60$	PUSH.L	A4	FOS	?LISTNXT	; A3 <-- ^nom, A4 <-- ^arguments	POPM.L	A4	JUMP,NE 40$	CALL	IFSYSTEM	; fichier du genre SYS_LIST ?	JUMP,EQ 30$		; oui => 30$	CALL	MAJREP		; prpare les noms de fichiers	LOAD.L	A3,A1	CALL	IFDIR		; rpertoire imbriqu ?	JUMP,NE 35$		; non => 35$				; oui =>	INC.W	D1		; D1 <-- une imbrication de plus	LOAD.L	(A4+),D6	; PUSH D6	JUMP	20$35$:	CALL	DDDAFFILE	; affiche le nom du fichier	CALL	DDDDISK		; dtruit, dplace ou duplique sur disque	CALL	DDDERROR	; affiche v. l'erreur	CALL	DDDIFSTOP	; faut-il stopper ?	JUMP,EQ 60$		; oui => 60$	JUMP	30$40$:	PUSH.W	D7	FOS	?LISTCLO	; ferme la liste	POP.W	D7	COMP.W	D7,#EROUTF	; fin normale ?	JUMP',EQ 42$		; oui => 42$	CALL	DDDERROR	; affiche v. l'erreur42$:	COMP.W	(A6)+ODDDOP,#3	; duplique ?	JUMP',EQ 45$		; oui => 45$				; non =>	TEST.W	(A6)+ODDDER	; une ou plusieurs erreurs ?	JUMP',NE 45$		; oui => 45$	CALL	KILREP		; supprime le rpertoire source	CALL	DDDERROR	; affiche v. l'erreur45$:	TEST.W	D1		; est-on dans une imbrication ?	JUMP',EQ 50$		; non => 50$	DEC.W	D1		; D1 <-- une imbrication de moins	LOAD.L	D6,(-A4)	; POP D6	CALL	CLOREP		; prpare les noms de rpertoires	JUMP	30$50$:	CLR.W	D7		; D7 <-- ok	JUMP	70$; En cas d'erreur, ferme toutes les listes ouvertes sur le stack.60$:	PUSH.W	D7	FOS	?LISTCLO	; ferme la liste courante62$:	TEST.W	D1	JUMP',EQ 66$	DEC.W	D1	LOAD.L	D6,(-A4)	; POP D6	FOS	?LISTCLO	; ferme les listes pres	JUMP	62$66$:	POP.W	D7; Ferme la dbox utilise pour afficher les fichiers transfrs.70$:	PUSH.W	D7	CALL	DDDCLDBOX	; ferme la dbox d'affichage	POP.W	D790$:	POPM.L	D1..D6,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DDDQDIRDEPL >;------------/; Dplace super-rapidement un dossier, en utilisant l'appel FOS,?MOVE.; in	A1.L		^nom dossier source;	A2.L		^nom dossier destination; out	D7.W		erreur;	A3.L		^fichier ayant caus l'erreur; mod	D7.W, A3.LDDDQDIRDEPL:	PUSHM.L	D4,A4	LOAD.L	A3,A1		; A3 <-- ^dossier source	FOS	?RELEASE	; release si ouvert	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,A130$:	LOAD.B	(A3+),(A4+)	; OBUFIT <-- dossier source	JUMP,NE 30$	LOAD.B	(A3)-2,#'.	LOAD.B	(A3)-1,#'D	LOAD.B	(A3)+0,#'I	LOAD.B	(A3)+1,#'R	CLR.B	(A3)+2	LOAD.L	A3,#(A6)+OBUFIU	LOAD.L	A4,A235$:	LOAD.B	(A3+),(A4+)	; OBUFIU <-- dossier destination	JUMP,NE 35$	LOAD.B	(A3)-2,#'.	LOAD.B	(A3)-1,#'D	LOAD.B	(A3)+0,#'I	LOAD.B	(A3)+1,#'R	CLR.B	(A3)+2	LOAD.L	A3,#(A6)+OBUFIT	; A3 <-- ^nom source	LOAD.L	A4,#(A6)+OBUFIU	; A4 <-- ^nom destination	CLR.L	D4		; D4 <-- mode	PUSH.L	D0	LOAD.L	D0,#FOS?MOVE	CALL	_ERCALL		; dplace super-rapidement	POPM.L	D090$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DDDDOSSIER >;===========/; Duplique le dossier systme DOSSIER:.; in	A1.L	^nom fichier source;	A2.L	^nom fichier destination; out	D7.W	erreur;	A3.L	^fichier ayant caus l'erreur; mod	D7.W, A3.LDDDDOSSIER:	PUSHM.L	D2..D4	CLR.W	D7		; D7 <-- ok	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP',NE 90$		; oui => 90$				; non =>	LOAD.W	D7,#ERSDOSS	; D7 <-- dossier pas ouvrable !	COMP.W	(A6)+ODDDOP,#3	; duplique ?	JUMP',NE 90$		; non => 90$				; oui =>	CALL	DBOXCREEDIR	; demande comment crer ...	JUMP',NE 90$	COMP.W	D3,#F1		; D'ACCORD ?	JUMP',NE 90$		; non => 90$	LOAD.L	A3,A2		; A3 <-- ^nom destination	CLR.L	D4		; <<<<< petite boulette de FOS 4.28 <<<<<	LOAD.W	D4,D2		; D4 <-- nb max de fichiers	JUMP',EQ 50$	FOS	?CALHACH	; D4 <-- valeur "h"	JUMP',EQ 52$50$:	LOAD.W	D4,#HACHE	; D4 <-- h=31 par dfaut52$:	LOAD.W	D2,D4		; D2 <-- valeur "h"	CALL	_WAITMOUSE	; souris: met le sablier	CALL	CREREP		; cre le rpertoire destination90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DDDOPDBOX >;----------/; Cre une dbox pour afficher les fichiers transfrs.; in	A1.L	^nom source;	A2.L	^nom destination; out	D7.W	erreur; mod	D7.WDDDOPDBOX:	PUSHM.L	D2..D5,A2..A4	TEST.W	(A6)+ODDDND	; dj une dbox ouverte ?	JUMP,NE 80$		; oui => 80$				; non =>	PUSH.L	A2	LOAD.L	A2,#R16"TDBOX_CADRE	LOAD.W	D2,#2^BDBSAV!2^BDBMAX	DBOX_	OPEN		; D5 <-- canal dbox	POPM.L	A2	JUMP,NE 90$	LOAD.L	(A6)+ODDDCD,D5	; mm. canal dbox	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#MAXER	INC.W	D3	SWAP.W	D3	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; dessine un trait horizontal	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D2,(A6)+ODDDOP	LOAD.L	A3,#R16"DETR$	COMP.W	D2,#1	JUMP',EQ 20$	LOAD.L	A3,#R16"DEPL$	COMP.W	D2,#2	JUMP',EQ 20$	LOAD.L	A3,#R16"DUPL$	COMP.W	D2,#3	JUMP',EQ 20$	LOAD.L	A3,#R16"ACCE$	COMP.W	D2,#4	JUMP',EQ 20$	LOAD.L	A3,#R16"MODI$	COMP.W	D2,#5	JUMP',EQ 20$	LOAD.L	A3,#R16"CLEA$	COMP.W	D2,#7	JUMP',NE 28$20$:	LIB	?AFTEXT		; affiche l'opration	LOAD.L	A4,A1	CALL	_AFFREP		; affiche la source	COMP.W	D2,#1		; dtruit ?	JUMP',EQ 28$	COMP.W	D2,#5		; modifie ?	JUMP',EQ 28$	COMP.W	D2,#7		; libre ?	JUMP',EQ 28$	LIB	?AFTIM	.ASCIZ	" dans "	.EVEN	LOAD.L	A4,A2	CALL	_AFFREP		; affiche la destination28$:	LIB	?GETWDO	LOAD.W	(A6)+ODDDVD,D5	LOAD.W	D2,(A0)+ODFCY	MUL.WU	D2,#MAXER	SWAP.W	D4	LOAD.W	D4,D2	SWAP.W	D4	LIB	?CREWDO		; cre swdo spciale	LOAD.W	(A6)+ODDDWD,D5	LIB	?USEWDO		; utilise swdo spciale	LIB	?AFTIM	.B	ROLL,TRUNC,0	.EVEN	CLR.L	D3	LIB	?SETCURS	CLR.W	(A6)+ODDDER	; pas (encore) d'erreur	CLR.W	(A6)+ODDDNB	; rang initial80$:	INC.W	(A6)+ODDDND	; une dbox "imbrique" de plus	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RETDETR$:	.ASCIZ	"Dtruit dans "DEPL$:	.ASCIZ	"Dplace de "DUPL$:	.ASCIZ	"Duplique de "ACCE$:	.ASCIZ	"Accs de "MODI$:	.ASCIZ	"Modifie dans "CLEA$:	.ASCIZ	"Libre dans "	.EVENTDBOX_CADRE:	.W	10$-TDBOX_CADRE	.W	20$-TDBOX_CADRE	.W	0,010$:	.B	ODBTABX,77	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	; MAXER=15 x ODBCR	;	--------------------------------	.B	ODBCR,ODBCR2	.B	ODBTABX,4	.B	ODBLABEL,1	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	" STOPPE "	.B	ODBTABX,18	.B	ODBLABEL,2	.B	ODBTEXT,0	.B	ODBCR2	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN;----------\\; DDDAFFILE >;----------/; Affiche le nom du fichier.; in	A1.L	^fichier source; out	-; mod	D7.WDDDAFFILE:	PUSH.L	A3	CALL	DDDAFIMB	; affiche <CR> puis qq espaces	LOAD.L	A3,#R16"00$	COMP.B	(A1),#'.	; affiche une commande (.GENBOOT) ?	JUMP',EQ 20$		; oui => 20$				; non =>	LOAD.L	A3,#R16"01$	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 20$	LOAD.L	A3,#R16"02$	COMP.W	(A6)+ODDDOP,#2	; dplace ?	JUMP',EQ 20$	LOAD.L	A3,#R16"03$	COMP.W	(A6)+ODDDOP,#3	; duplique ?	JUMP',EQ 20$	LOAD.L	A3,#R16"04$	COMP.W	(A6)+ODDDOP,#4	; accs ?	JUMP',EQ 20$	LOAD.L	A3,#R16"05$20$:	LIB	?AFTEXT		; affiche dtruit, dplace ou duplique	LOAD.L	A3,A1	LIB	?AFTEXT		; affiche le nom du fichier source	LIB	?AFSPACE	POP.L	A3	RET00$:	.ASCIZ	"Commande "01$:	.ASCIZ	"Dtruit "02$:	.ASCIZ	"Dplace "03$:	.ASCIZ	"Duplique "04$:	.ASCIZ	"Cre l'accs  "05$:	.ASCIZ	"Modifie "	.EVEN;---------\\; DDDAFIMB >;---------/; Affiche <CR> puis qq espaces selon l'imbrication.; in	-; out	-; mod	D7.WDDDAFIMB:	PUSH.L	D3	LIB	?AFTIM	.B	CR,MSPACE,0	.EVEN	LOAD.W	D3,(A6)+ODDDND	; D3 <-- niveau d'imbrication	MUL.WU	D3,#2	DEC.W	D3	LIB	?AFCAR	INC.W	(A6)+ODDDNB	; ODDDNB <-- rang suivant	POP.L	D3	RET;---------\\; DDDERROR >;---------/; Affiche une eventuelle erreur.; in	D7.W	ok/erreur;	A3.L	^nom du fichier; out	-; mod	-DDDERROR:	PUSHM.L	D3,D4,D7,A3,A4	LOAD.W	D4,D7		; D4 <-- erreur	JUMP,EQ 90$	COMP.W	D4,#ERKSTO	JUMP,EQ 90$	COMP.W	D4,#ERANNULE	JUMP,EQ 90$	COMP.W	D4,#ERFDNE	; fichier n'existe pas ?	JUMP',NE 20$		; non => 20$	TEST.B	(A6)+ODDDSW:#BSWNOT ; switch /N prsent ?	JUMP,BS 90$		; oui => pas d'erreur20$:	LIB	?AFTIM	.B	AFINV,0	.EVEN	LOAD.W	D7,D4		; D7 <-- erreur	CALL	_AFERROR	; affiche l'erreur	LOAD.B	D3,#AFDIR	LIB	?AFCAR	COMP.W	D4,#ERSDATE	; ... pas ncessaire (plus ancien) ?	JUMP',EQ 90$		; oui => 90$	COMP.W	D4,#ERSDAEQ	; ... pas ncessaire (identique) ?	JUMP',EQ 90$		; oui => 90$	COMP.W	D4,#ERSDOPN	; ... pas ncessaire (existe dj) ?	JUMP',EQ 90$		; oui => 90$				; non =>	INC.W	(A6)+ODDDER	; y'a eu une erreur !	LOAD.L	A4,#(A6)+ODDDBE	LOAD.W	D3,(A6)+ODDDER	DEC.W	D3	COMP.W	D3,#MAXER	JUMP',HS 90$	MUL.WU	D3,#LER	ADD.L	A4,D3		; A4 <-- ^dans la table d'erreur	LOAD.W	(A4)+OERCOD,D4	; OERCOD <-- code de l'erreur	LOAD.W	(A4)+OERRAN,(A6)+ODDDNB ; OERRAN <-- rang	LOAD.L	A4,#(A4)+OERNAM	LOAD.W	D3,#50-150$:	DEC.W	D3	JUMP',EQ 60$	LOAD.B	(A4+),(A3+)	; OERNAM <-- nom du fichier	JUMP,NE 50$60$:	CLR.B	(A4)90$:	POPM.L	D3,D4,D7,A3,A4	RET;----------\\; DDDKYSTOP >;----------/; Regarde si une touche "stoppe" est presse.; in	-; out	D7.W	erreur si stoppe; mod	D7.WDDDKYSTOP:	PUSHM.L	D3,D410$:	LIB	?IFCAR		; touche presse ?	JUMP',NE 70$		; non => 70$	COMP.W	D3,#KEYMGP	JUMP',EQ 40$	COMP.W	D3,#KEYMMP	JUMP',EQ 40$	COMP.W	D3,#KEYMDP	JUMP',EQ 40$	COMP.W	D3,#END	JUMP',EQ 80$	JUMP	10$40$:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 70$	SUB.W	D4,(A0)+ODFFX	JUMP',LO 70$	COMP.W	D4,(A0)+ODFFDX	JUMP',HS 70$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',LO 70$	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#3		; D3 <-- la touche (STOPPE) est 3 lignes plus bas !	ADD.W	D3,(A0)+ODFFDY	COMP.W	D4,D3	JUMP',LO 80$70$:	CLR.W	D7		; D7 <-- on continue	JUMP'	90$80$:	LOAD.W	D7,#ERSSTOP	; D7 <-- transfert stopp90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DDDIFSTOP >;----------/; Vrifie si l'erreur rendue par un transfert ncessite; de stopper tout.; in	D7.W	erreur; out	EQ	=> il faut stopper;	NE	=> on continue; mod	-DDDIFSTOP:	PUSH.W	D4	LOAD.W	D4,D7		; D4 <-- code de l'erreur	AND.W	D4,#H'FFF0	COMP.W	D4,#ERFULL	; qq chose de plein dans le FOS ?	JUMP',EQ 80$		; oui => 80$	COMP.W	D7,#ERSSTOP	; transfert stopp ?	JUMP',EQ 80$		; oui => 80$	COMP.W	D7,#ERANNULE	JUMP',EQ 80$				; continue =>	POP.W	D4	CLRZ			; met NE	RET80$:				; stop =>	POP.W	D4	SETZ			; met EQ	RET;----------\\; DDDCLDBOX >;----------/; Ferme une dbox pour afficher les fichiers transfrs.; in	-; out	-; mod	D7.WDDDCLDBOX:	PUSHM.L	D2..D5,A3,A4	DEC.W	(A6)+ODDDND	; une dbox "imbrique" de moins	JUMP,NE 90$	TEST.W	(A6)+ODDDER	; une ou plusieurs erreurs ?	JUMP,EQ 80$		; non => 80$				; oui =>	LIB	?BUZZ		; grand bruit !	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface toute la swdo	LOAD.L	A4,#(A6)+ODDDBE	LOAD.W	D4,(A6)+ODDDER	COMP.W	D4,#MAXER	JUMP',LS 22$	LOAD.W	D4,#MAXER	; D4 <-- nb d'erreurs  afficher	JUMP'	22$20$:	LIB	?AFCR22$:	LOAD.W	D7,(A4)+OERCOD	; D7 <-- code de l'erreur	LOAD.L	A3,#(A4)+OERNAM	; A3 <-- ^nom du fichier	FOS	?NAMERROR	PUSHM.L	D2,D4	CLR.L	D4	LOAD.W	D4,(A4)+OERRAN	; D4 <-- rang de l'erreur	LOAD.W	D3,#4		; D3 <-- nb max de digits	CLR.W	D2		; D2 <-- mode	LIB	?AFDEC		; affiche le rang de l'erreur	POPM.L	D2,D4	LIB	?AFTIM	.ASCIZ	": "	.EVEN	LIB	?AFTEXT		; affiche le nom du fichier	LIB	?AFTIM	.B	SPACE,AFINV,0	.EVEN	LOAD.L	A3,#(A4)+OERNAM	; A3 <-- ^nom du fichier	LOAD.W	D7,(A4)+OERCOD	; D7 <-- erreur	CALL	_AFERROR	; affiche l'erreur	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LOAD.L	A4,#(A4)+LER	; A4 <-- ^erreur suivante	DEC.W	D4	JUMP,NE 20$70$:	LIB	?IFCAR		; vide le fifo du clavier	JUMP,EQ 70$	LOAD.W	D5,(A6)+ODDDVD	LIB	?USEWDO		; utilise swdo initiale	LOAD.L	D5,(A6)+ODDDCD	; D5 <-- canal de la dbox	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#R16"VU$	LIB	?AFTEXT		; met une touche ( VU )72$:	CALL	DBOXEDIT	; attend clic ...	COMP.W	D3,#F0	JUMP',EQ 80$	COMP.W	D3,#END	JUMP',EQ 80$	COMP.W	D3,#SPACE	JUMP',EQ 80$	COMP.W	D3,#CR	JUMP',EQ 80$	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	72$80$:	LOAD.W	D5,(A6)+ODDDVD	LIB	?USEWDO		; utilise swdo initiale	LOAD.W	D5,(A6)+ODDDWD	LIB	?KILWDO		; dtruit swdo spciale	LOAD.L	D5,(A6)+ODDDCD	; D5 <-- canal de la dbox	DBOX_	CLOSE		; ferme la dbox	CLR.L	(A6)+ODDDCD	; plus de canal90$:	POPM.L	D2..D5,A3,A4	RET		; STOPPE ;VU$:	.ASCIZ	"   VU   "	.EVEN;--------\\; IFDREP  >;--------/; Vrifie si l'on peut dtruire le rpertoire source.; in	A1.L	^rpertoire source; out	D7.W	erreur;	A3.L	^nom du rpertoire; mod	D7.W, A3.LIFDREP:	PUSHM.L	D3,D4,A4	LOAD.L	A3,A1	LOAD.L	A4,#(A6)+OBUFIT10$:	LOAD.B	(A4+),(A3+)	; OBUFIT <-- rpertoire source	JUMP,NE 10$	LOAD.B	(A4)-2,#'.	LOAD.B	(A4)-1,#'D	LOAD.B	(A4)+0,#'I	LOAD.B	(A4)+1,#'R	CLR.B	(A4)+2	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,#(A6)+OBUARGS	CALL	DDDARGS		; demande les arguments du fichier .DIR	JUMP',NE 90$	LOAD.L	D4,(A4)+OFLATT	; D4 <-- attributs source	TEST.L	D4:#BATTD	; attribut "D" prsent ?	JUMP',BS 90$		; oui => 90$				; non =>	LOAD.W	D7,#ERATTD	; D7 <-- destruction impossible	PUSH.W	D7	FOS	?NAMERROR	; donne le nom du fichier au FOS	POP.W	D790$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CREREP  >;--------/; Cre le rpertoire destination.; in	A2.L	^rpertoire destination;	D2.W	valeur "h"; out	D7.W	erreur;	A3.L	^nom du rpertoire; mod	D7.W, A3.LCREREP:	PUSHM.L	D3,D4,A4,A5; Met le nom du rpertoire  crer dans OBUFIT, car il faudra; le triturer.	LOAD.L	A3,A2	LOAD.L	A4,#(A6)+OBUFIT10$:	LOAD.B	(A4+),(A3+)	; OBUFIT <-- rpertoire destination	JUMP,NE 10$; Transforme le nom comme suit :;	#MM1:TOTO:TITI:		-->	idem;	#MM1:TOTO:TITI.DIR	-->	#MM1:TOTO:TITI:	LOAD.L	A3,#(A6)+OBUFIT	CALL	SKIPREP	TEST.B	(A3)	JUMP',EQ 25$20$:	COMP.B	(A3+),#'.	JUMP,NE 20$	LOAD.B	(A3)-1,#':	CLR.B	(A3); Compte de nombre de ":" dans le nom.; S'il n'y en a qu'un, il s'agit d'un nom logique d'unit; qu'il ne faut pas crer !25$:	LOAD.L	A3,#(A6)+OBUFIT	CLR.W	D330$:	TEST.B	(A3+)	JUMP',EQ 35$	COMP.B	(A3)-1,#':	JUMP,NE 30$	INC.W	D3		; D3 <-- un ":" de plus	JUMP	30$35$:	CLR.W	D7	COMP.W	D3,#1		; juste un nom logique (#MM1:) ?	JUMP,LE 90$		; oui => 90$	TEST.L	(A6)+ODDDCD	; dbox existe ?	JUMP',EQ 40$		; non => 40$	CALL	DDDAFIMB	; affiche <CR> puis qq espaces	LIB	?AFTIM	.ASCIZ	"Cre le dossier "	.EVEN	LOAD.L	A3,#(A6)+OBUFIT	LIB	?AFTEXT		; affiche le nom du dossier	LIB	?AFSPACE; Effectue un ENTER, car le FOS ne le fait pas automatiquement; avec l'appel ?CDIR !;	#MM1:TOTO:TITI:		-->	ENTER #MM1:TOTO:40$:	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,A3	DEC.W	D3		; D3 <-- tous les noms, sauf le dernier45$:	COMP.B	(A4+),#':	JUMP,NE 45$	DEC.W	D3	JUMP,NE 45$	LOAD.B	D3,(A4)	CLR.B	(A4)		; annule provisoirement le dernier nom	PUSH.L	D0	LOAD.L	D0,#FOS?ENTER	CALL	_ERCALL	POPM.L	D0	LOAD.B	(A4),D3		; restitue le dernier nom; Cre enfin le (sous-)rpertoire demand.	LOAD.L	A3,#(A6)+OBUFIT	LOAD.W	D3,D2		; D3 <-- valeur de hachage	CLR.L	D4		; D4 <-- lg max	PUSH.L	D0	LOAD.L	D0,#FOS?CDIR	CALL	_ERCALL		; cre le rpertoire destination	POPM.L	D0	JUMP',EQ 60$		; ok => 60$				; erreur =>	COMP.W	D7,#ERFAEX	JUMP,NE 90$	LOAD.W	D7,#ERSDOPN	; D7 <-- pas ncessaire (existe dj)	JUMP	90$; Cre le rpertoire dans la list.60$:	LOAD.L	A4,A362$:	TEST.B	(A4+)	JUMP,NE 62$	LOAD.B	(A4)-2,#'.	LOAD.B	(A4)-1,#'D	LOAD.B	(A4)+0,#'I	LOAD.B	(A4)+1,#'R	CLR.B	(A4)+2	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; KILREP  >;--------/; Supprime le rpertoire source.; in	A1.L	^rpertoire source; out	D7.W	erreur;	A3.L	^nom du rpertoire; mod	D7.W, A3.LKILREP:	PUSHM.L	D3,D4,A4,A5	LOAD.L	A3,A1	LOAD.L	A4,#(A6)+OBUFIT10$:	LOAD.B	(A4+),(A3+)	; OBUFIT <-- rpertoire source	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBUFIT	CALL	SKIPREP	CLR.B	(A3)	TEST.L	(A6)+ODDDCD	; dbox existe ?	JUMP',EQ 20$		; non => 20$	CALL	DDDAFIMB	; affiche <CR> puis qq espaces	LIB	?AFTIM	.ASCIZ	"Supprime le dossier "	.EVEN	LOAD.L	A3,#(A6)+OBUFIT	LIB	?AFTEXT20$:	LOAD.L	A3,#(A6)+OBUFIT	FOS	?RELEASE	; ferme le rpertoire;;?	JUMP,NE 90$		; voir (*)	LOAD.L	A4,A340$:	TEST.B	(A4+)	JUMP,NE 40$	LOAD.B	(A4)-2,#'.	LOAD.B	(A4)-1,#'D	LOAD.B	(A4)+0,#'I	LOAD.B	(A4)+1,#'R	CLR.B	(A4)+2	FOS	?CLEAR		; rz le compteur d'ouvertures	LOAD.L	D3,#2^BATTM!2^BATTR!2^BATTW!2^BATTS!2^BATTG	OR.L	D3,#2^BATTD!2^BATTC!2^BATTA!2^BATTZ!2^BATTP!2^BATTL	FOS	?CHATR		; met l'attribut "D"	JUMP',NE 90$	FOS	?DELETE		; dtruit le rpertoire90$:	POPM.L	D3,D4,A4,A5	TEST.W	D7		; retour EQ/NE	RET; (*)	L'appel RELEASE rend une erreur car il ne peut pas;	releaser toute la chane ( cause des SYS_LIST ouverts),;	mais seulement le dernier, ce qui correspond justement;	pile  ce qu'il faut !;--------\\; OPEREP  >;--------/; Construit les noms des rpertoires.; in	(A1) --> #mm1:courrier:aa.dir; out	(A1) --> #mm1:courrier:aa:*; in	A1.L	^rpertoire source;	A2.L	^rpertoire destination; out	-; mod	D7.WOPEREP:	PUSHM.L	A3,A4	LOAD.L	A3,A1	CALL	SKIPREP	TEST.B	(A3)	JUMP',EQ 15$10$:	COMP.B	(A3+),#'.	JUMP,NE 10$	LOAD.B	(A3)-1,#':15$:	LOAD.B	(A3)+0,#'*	CLR.B	(A3)+1	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 90$	LOAD.L	A3,A2	CALL	SKIPREP	TEST.B	(A3)	JUMP',EQ 25$20$:	COMP.B	(A3+),#'.	JUMP,NE 20$	LOAD.B	(A3)-1,#':25$:	LOAD.B	(A3)+0,#'*	CLR.B	(A3)+190$:	POPM.L	A3,A4	RET;--------\\; MAJREP  >;--------/; Construit les noms des fichiers  tranfrer.; in	(A3) --> toto.text;	(A1) --> #mm1:courrier:aa:xyz; out	(A1) --> #mm1:courrier:aa:toto.text; in	A1.L	^rpertoire source;	A2.L	^rpertoire destination;	A3.L	^nom (sans rpertoires); out	-; mod	D7.WMAJREP:	PUSHM.L	A3,A4	LOAD.L	A4,A3	PUSH.L	A4	LOAD.L	A3,A1	CALL	SKIPREP10$:	LOAD.B	(A3+),(A4+)	; construit le nom source	JUMP,NE 10$	POP.L	A4	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 90$	PUSH.L	A4	LOAD.L	A3,A2	CALL	SKIPREP20$:	LOAD.B	(A3+),(A4+)	; construit le nom destination	JUMP,NE 20$	POP.L	A490$:	POPM.L	A3,A4	RET;--------\\; CLOREP  >;--------/; Construit les noms des rpertoires.; in	(A1) --> #mm1:courrier:aa:xyz; out	(A1) --> #mm1:courrier:; in	A1.L	^rpertoire source;	A2.L	^rpertoire destination; out	-; mod	D7.WCLOREP:	PUSH.L	A3	LOAD.L	A3,A1	CALL	SKIPREP	DEC.L	A310$:	COMP.B	(-A3),#':	JUMP,NE 10$	CLR.B	(A3)+1	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 90$	LOAD.L	A3,A2	CALL	SKIPREP	DEC.L	A320$:	COMP.B	(-A3),#':	JUMP,NE 20$	CLR.B	(A3)+190$:	POP.L	A3	RET;--------\\; DDDLIST >;========/; Effectue une opration dtruit, dplace ou duplique sur le disque,; sur un fichier unique.; Rsoud le cas d'un fichier "SMA_fsctt.GENC" qui n'existe pas en; essayant une deuxime fois avec "SMA_fst00.GENC".; in	A1.L		^nom fichier source;	A2.L		^nom fichier destination;	(A6)+ODDDOP.W	opration (dtruit/dplace/duplique);	(A6)+ODDDXF.W	mode de transfert (XF...);	(A6)+ODDDSW.B	switchs trouvs si fichier "!";	(A6)+ODDDAP.L	attributs  ajouter (+);	(A6)+ODDDAM.L	attributs  enlever (-); out	D7.W		erreur;	A3.L		^fichier ayant caus l'erreur; mod	D7.W, A3.LDDDLIST:	PUSHM.L	D4,A4	CALL	DDDDISK		; essaye une premire fois ...	JUMP,EQ 90$		; ok => 90$	COMP.W	D7,#ERFDNE	; fichier n'existe pas ?	JUMP,NE 90$		; non => 90$	COMP.W	(A6)+ODDDOP,#2	; dplace ?	JUMP',EQ 20$		; oui => 20$	COMP.W	(A6)+ODDDOP,#3	; duplique ?	JUMP,NE 90$		; non => 90$20$:	PUSHM.L	D7,A3	LOAD.L	A3,A1	CALL	IFGENC		; fichier .GENC ?	POPM.L	D7,A3	JUMP,NE 90$		; non => 90$	LOAD.L	A4,A1	EX.L	A3,A4	CALL	SKIPREP		; A4 <-- ^aprs rep: fichier source	EX.L	A4,A3	COMP.B	(A4+),#'S	JUMP',NE 90$	COMP.B	(A4+),#'M	JUMP',NE 90$	COMP.B	(A4+),#'A	JUMP',NE 90$	COMP.B	(A4+),#'_	JUMP',NE 90$	LOAD.W	D4,#5-130$:	COMP.B	(A4+),#'.	JUMP',EQ 90$	DECJ.W,NMO D4,30$	COMP.B	(A4),#'.	JUMP',NE 90$	COMP.B	(A4)-1,#'0	JUMP',NE 50$	COMP.B	(A4)-2,#'0	JUMP',EQ 90$50$:	LOAD.B	(A4)-1,#'0	LOAD.B	(A4)-2,#'0	LOAD.L	A4,A2	EX.L	A3,A4	CALL	SKIPREP		; A4 <-- ^aprs rep: fichier destination	EX.L	A4,A3	LOAD.B	(A4)+7,#'0	LOAD.B	(A4)+8,#'0	CALL	DDDDISK		; essaye encore une fois avec "*00.GENC"90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DDDDISK >;========/; Effectue une opration dtruit, dplace ou duplique sur le disque,; sur un fichier unique.; in	A1.L		^nom fichier source;	A2.L		^nom fichier destination;	(A6)+ODDDOP.W	opration (dtruit/dplace/duplique);	(A6)+ODDDXF.W	mode de transfert (XF...);	(A6)+ODDDSW.B	switchs trouvs si fichier "!";	(A6)+ODDDAP.L	attributs  ajouter (+);	(A6)+ODDDAM.L	attributs  enlever (-); out	D7.W		erreur;	A3.L		^fichier ayant caus l'erreur; mod	D7.W, A3.LDDDDISK:	PUSHM.L	D0..D6,A4,A5	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',NE 10$		; non => 10$				; oui =>	CALL	DDDSDEL		; dtruit le fichier source	JUMP	95$10$:	CALL	_APPENDIF	; fusionne v. START_USER.INFO et SMA_JIP24.GENC	JUMP,NE 95$	TEST.W	D3		; fait qq chose ?	JUMP,NE 95$		; oui => 95$11$:	COMP.W	(A6)+ODDDOP,#2	; dplace ?	JUMP',NE 12$		; non => 12$	COMP.W	(A6)+ODDDXF,#XFLOCK ; transfert en (d)verrouillant ?	JUMP',EQ 12$		; oui =>	COMP.W	(A6)+ODDDXF,#XFPRINT ; imprime ?	JUMP',EQ 12$		; oui =>				; non =>	CALL	DDDQDISKDEPL	; dplace super-rapidement ?	JUMP,EQ	95$		; ok => 95$	COMP.W	D7,#ERNSUNI	; changement d'units phsiques ?	JUMP,NE 95$		; non => 95$12$:	LOAD.L	A5,#0		; A5 <-- pas encore de grand buffer	CLR.W	(A6)+ORDCH	; canal de lecture pas valide	CLR.W	(A6)+OWRCH	; canal d'criture pas valide; Demande les arguments des fichiers source/destination.	LOAD.L	A3,A1		; A3 <-- ^fichier source	LOAD.L	A4,#(A6)+OBUARGS	CALL	DDDARGS		; lit arguments fichier source	JUMP,NE 80$	COMP.W	(A6)+ODDDXF,#XFPRINT ; imprime ?	JUMP',EQ 22$		; oui => 22$	LOAD.L	A3,A2		; A3 <-- ^fichier destination	LOAD.L	A4,#(A6)+OBUARGD	CALL	DDDARGS		; lit arguments fichier destination	JUMP',EQ 20$		; si fichier destination existe => 20$	COMP.W	D7,#ERFDNE	; fichier destination n'existe pas ?	JUMP',EQ 22$		; oui => 22$	JUMP	80$		; non => 80$ (autre erreur)20$:	CALL	DDDIFDEL	; demande s'il faut dtruire ...	JUMP,NE 80$		; non => 80$; Ouvre le fichier source.22$:	LOAD.L	A3,A1		; A3 <-- ^fichier source	LOAD.W	D3,#2^BOPRD	COMP.W	(A6)+ODDDXF,#XFLOCK ; (d-)verrouille ?	JUMP',EQ 23$		; oui => 23$	COMP.W	(A6)+ODDDXF,#XFPRINT ; imprime ?	JUMP',EQ 23$		; oui => 23$	LOAD.W	D3,#2^BOPRD!2^BOPCODE23$:	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	_ERCALL		; ouvre le fichier source	POPM.L	D0	JUMP,NE 90$	LOAD.W	(A6)+ORDCH,D6	; mm. canal de lecture	LOAD.W	D1,D3		; D1 <-- valeur de codage; Cre et ouvre le fichier destination.	COMP.W	(A6)+ODDDXF,#XFPRINT ; imprime ?	JUMP,EQ 27$		; oui => 27$	LOAD.L	D0,(A6)+OBUARGS+OFLATT ; D0 <-- attributs source	CLR.L	D3		; D3 <-- attributs par dfaut	TEST.L	D0:#BATTU	; unit (fichier streamer) ?	JUMP',BS 26$		; oui => 26$	LOAD.L	D3,D0		; D3 <-- attributs source	OR.L	D3,#2^BATTE!2^BATTM!2^BATTW	TCLR.L	D3:#BATTN26$:	OR.L	D3,(A6)+ODDDAP	; D3 <-- ajoute qq attributs	NOT.L	D3	OR.L	D3,(A6)+ODDDAM	; D3 <-- enlve qq attributs	NOT.L	D3	TCLR.L	D3:#BATTWPR	; D3 <-- enlve  cause boulette dans FOS en EPROM !	LOAD.L	A3,A2		; A2 <-- ^fichier destination	LOAD.B	D4,#TYPRAND	; D4 <-- type random	PUSH.L	D5	LOAD.W	D5,D1		; D5 <-- valeur de codage	PUSH.L	D0	LOAD.L	D0,#FOS?CREATE	CALL	_ERCALL		; cre le fichier destination	POPM.L	D0	POPM.L	D5	JUMP,NE 80$27$:	LOAD.L	A3,A2		; A2 <-- ^fichier destination	LOAD.W	D3,#2^BOPWR!2^BOPEXCL!2^BOPPRE	COMP.W	(A6)+ODDDXF,#XFLOCK ; (d-)verrouille ?	JUMP',EQ 28$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL!2^BOPPRE!2^BOPCODE28$:	PUSHM.L	D0,D5	LOAD.L	D5,(A6)+OBUARGS+OFLLG ; D5 <-- taille du fichier source	LOAD.L	D0,#FOS?ARGSOPEN	CALL	_ERCALL		; ouvre le fichier destination	POPM.L	D0,D5	JUMP,NE 80$	LOAD.W	(A6)+OWRCH,D6	; mm. canal d'criture; Demande la mmoire temporaire pour effectuer le transfert.	LOAD.W	D3,#16/2	; D3 <-- la moiti	LOAD.L	D4,#256*1	; D4 <-- mimimum	LOAD.L	D5,#256*256	; D5 <-- maximum	LOAD.W	D1,#MTYPCP	GESMEM	?GETPMEM	; demande grand buffer	JUMP,NE 80$	LOAD.L	A5,A4		; A5 <-- ^grand buffer	LOAD.L	D5,D4		; D5 <-- lg grand buffer; Effectue le transfert par tranches.50$:	LOAD.L	A3,A1		; A3 <-- ^source (si erreur)	LOAD.W	D6,(A6)+ORDCH	LOAD.L	A4,A5		; A4 <-- ^trs grand buffer	LOAD.L	D4,D5		; D4 <-- longueur buffer	FOS	?RDBYTE		; lit une grande tranche ...	LOAD.W	D0,D7	JUMP',NC 52$		; ok ou erreur mineure => 52$	COMP.W	D7,#EROUTF	JUMP,NE 80$52$:	LOAD.L	A3,A2		; A3 <-- ^destination (si erreur)	LOAD.W	D6,(A6)+OWRCH	FOS	?WRBYTE		; crit une grande tranche ...	JUMP,NS 80$		; erreur majeure => 80$	TEST.W	D0		; EOF rencontr en lecture ?	JUMP,NC 50$		; non => 50$; Ferme les fichiers source et destination.	LOAD.L	A3,A2		; A3 <-- ^destination (si erreur)	CLR.L	D3	LOAD.B	D3,(A6)+OBUARGS+OFLCH+0	; D3 <-- heure fichier source	SL.L	D3,#8	LOAD.B	D3,(A6)+OBUARGS+OFLCH+1	; D3 <-- minute fichier source	SL.L	D3,#8	LOAD.B	D3,(A6)+OBUARGS+OFLCH+2	; D3 <-- seconde fichier source	CLR.L	D4	LOAD.B	D4,(A6)+OBUARGS+OFLCD+0	; D4 <-- jour fichier source	SL.L	D4,#8	LOAD.B	D4,(A6)+OBUARGS+OFLCD+1	; D4 <-- mois fichier source	SL.L	D4,#8	LOAD.B	D4,(A6)+OBUARGS+OFLCD+2	; D4 <-- anne fichier source	LOAD.W	D6,(A6)+OWRCH	JUMP',EQ 75$	FOS	?CLOMDC		; ferme le fichier destination	JUMP,NE 80$		; + modifie la date de cration	CLR.W	(A6)+OWRCH	; canal d'criture plus valide75$:	LOAD.L	A3,A1		; A3 <-- ^source (si erreur)	LOAD.W	D6,(A6)+ORDCH	JUMP',EQ 84$	FOS	?CLOSE		; ferme le fichier source	JUMP',NE 80$	CLR.W	(A6)+ORDCH	; canal de lecture plus valide	JUMP'	84$; En cas d'erreur, ferme les fichiers ouverts.80$:	LOAD.W	D6,(A6)+OWRCH	; canal d'criture valide ?	JUMP',EQ 82$		; non => 82$	PUSHM.L	D7,A3	FOS	?CLOSE		; oui => ferme fichier destination	LOAD.L	A3,A2		; A2 <-- ^fichier destination	FOS	?DELETE		; puis dtruit (puisque pas complet) !	POPM.L	D7,A382$:	LOAD.W	D6,(A6)+ORDCH	; canal de lecture valide ?	JUMP',EQ 84$		; non => 84$	PUSH.W	D7	FOS	?CLOSE		; oui => ferme fichier source	POP.W	D7; Dtruit le fichier source pour l'opration dplace.84$:	COMP.W	(A6)+ODDDOP,#2	; dplace ?	JUMP',NE 90$		; non => 90$				; oui =>	COMP.W	D7,#ERSDATE	; transfert pas ncessaire (plus ancien) ?	JUMP',EQ 85$		; oui => 85$	COMP.W	D7,#ERSDAEQ	; transfert pas ncessaire (identique) ?	JUMP',EQ 85$		; oui => 85$	TEST.W	D7		; transfert ok ?	JUMP',NE 90$		; non => 90$85$:	LOAD.W	D6,D7	LOAD.L	A4,A3	CALL	DDDSDEL		; dtruit encore le fichier source	EX.L	D6,D7		; D6 <-- ok/erreur de DDDSDEL	EX.L	A3,A4	TEST.W	D7		; transfert excut correctement ?	JUMP',NE 90$	LOAD.W	D7,D6		; D7 <-- ok/erreur de DDDSDEL	LOAD.L	A3,A4; Libre la mmoire temporaire.90$:	COMP.L	A5,#0		; grand buffer existe ?	JUMP',EQ 95$		; non => 95$	PUSH.W	D7	LOAD.L	A4,A5		; A4 <-- ^zone mmoire	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le grand buffer	POP.W	D795$:	PUSH.W	D7	CALL	BALWAIT		; traite les messages du FOS ...	POP.W	D7	POPM.L	D0..D6,A4,A5	TEST.W	D7		; retour EQ/NE	RETBOURRE$:	.B	0,0,0,0	.EVEN;-------------\\; DDDQDISKDEPL >;-------------/; Dplace super-rapidement un fichier, en utilisant l'appel FOS,?MOVE.; in	A1.L		^nom fichier source;	A2.L		^nom fichier destination;	(A6)+ODDDXF.W	mode de transfert (XF...);	(A6)+ODDDSW.B	switchs trouvs si fichier "!";	(A6)+ODDDAP.L	attributs  ajouter (+);	(A6)+ODDDAM.L	attributs  enlever (-); out	D7.W		erreur;	A3.L		^fichier ayant caus l'erreur; mod	D7.W, A3.LDDDQDISKDEPL:	PUSHM.L	D4,A4	LOAD.W	D7,#ERNSUNI	; D7 <-- changement d'units physiques	COMP.W	(A6)+ODDDXF,#XFFILES ; selon fichier "!" ?	JUMP',NE 20$		; non => 20$	TEST.B	(A6)+ODDDSW:#BSWDEL ; switch /D prsent ?	JUMP,BC 90$		; non => 90$20$:	LOAD.L	A3,A1		; A3 <-- ^nom source	LOAD.L	A4,A2		; A4 <-- ^nom destination	CLR.L	D4		; D4 <-- mode	PUSH.L	D0	LOAD.L	D0,#FOS?MOVE	CALL	_ERCALL		; dplace super-rapidement	POPM.L	D0	JUMP,EQ 90$		; ok => 90$	COMP.W	D7,#ERNSUNI	; changement d'units physiques ?	JUMP,EQ 90$		; oui => 90$	COMP.W	D7,#ERFAEX	; fichier destination existe dj ?	JUMP,NE 90$		; non => 90$				; oui =>	LOAD.L	A3,A1		; A3 <-- ^fichier source	LOAD.L	A4,#(A6)+OBUARGS	CALL	DDDARGS		; lit arguments fichier source	JUMP,NE 90$	LOAD.L	A3,A2		; A3 <-- ^fichier destination	LOAD.L	A4,#(A6)+OBUARGD	CALL	DDDARGS		; lit arguments fichier destination	JUMP,NE 90$	CALL	DDDIFDEL	; demande s'il faut dtruire ...	JUMP,EQ 20$		; oui => 20$	COMP.W	D7,#ERSDATE	; transfert pas ncessaire (plus ancien) ?	JUMP',EQ 50$		; oui => 50$	COMP.W	D7,#ERSDAEQ	; transfert pas ncessaire (identique) ?	JUMP',EQ 50$		; oui => 50$	JUMP'	90$50$:	PUSHM.L	D7,A3	CALL	DDDSDEL		; dtruit encore le fichier source	POPM.L	D7,A390$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DDDIFDEL >;---------/; Demande s'il faut dtruire le fichier destination.; in	A3.L		^nom du fichier  dtruire (destination);	(A6)+ODDDXF.W	mode de transfert (XF...); out	D7.W		erreur (ERANNULE si rponse "non"); mod	D7.WDDDIFDEL:	PUSH.L	D3	COMP.W	(A6)+ODDDXF,#XFFILES ; selon fichier "!" ?	JUMP',EQ 30$		; oui => 30$	COMP.W	(A6)+ODDDXF,#XFALL ; transfert tous les fichiers ?	JUMP',EQ 30$		; oui => 30$	COMP.W	(A6)+ODDDXF,#XFDIR ; transfert tout le dossier ?	JUMP',EQ 30$		; oui => 30$	COMP.W	(A6)+ODDDXF,#XFLOCK ; (d-)verrouille ?	JUMP',EQ 20$		; oui => 20$	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP',NE 30$		; oui => 30$				; non =>	CALL	DDDCOMPDATE	; compare les dates	JUMP',EQ 15$	COMP.W	D7,#ERSDATE	JUMP',EQ 15$	COMP.W	D7,#ERSDAEQ	JUMP',NE 90$15$:	LOAD.W	D3,D7		; D3 <-- mode	CALL	DBOXMDELETE	; demande s'il faut supprimer ... ?	JUMP',NE 90$		; si rponse "non" => 90$	CALL	_WAITMOUSE	; souris: met le sablier20$:	PUSH.L	D0	LOAD.L	D0,#FOS?DELETE	CALL	_ERCALL		; supprime l'ancien fichier destination	POP.L	D0	JUMP'	90$30$:				; transfert seulement si plus rcent =>	TEST.B	(A6)+ODDDSW:#BSWALW ; fichier /A ?	JUMP,BS 20$		; oui => 20$				; non =>	CALL	DDDCOMPDATE	; compare les dates	JUMP,EQ 20$90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;------------\\; DDDCOMPDATE >;------------/; Compare les dates des fichiers source/destination.; in	-; out	D7.W	erreur (mode); mod	D7.WDDDCOMPDATE:	PUSHM.L	D3,A3,A4	LOAD.L	A3,#(A6)+OBUARGS+OFLCD	CALL	CHECKDATE	; date source ok ?	JUMP,NE	90$		; non => 90$;	LOAD.L	A3,#(A6)+OBUARGS+OFLCD	LOAD.L	A4,#(A6)+OBUARGD+OFLCD	CALL	COMPDATE	; compare les dates de crations	JUMP',HI 80$	JUMP',EQ 60$	LOAD.W	D7,#ERSDATE	; D7 <-- transfert pas ncessaire (plus ancien)	JUMP'	90$60$:	LOAD.L	D3,(A6)+OBUARGS+OFLLG	COMP.L	D3,(A6)+OBUARGD+OFLLG ; voir note (*)	JUMP',NE 80$	LOAD.W	D7,#ERSDAEQ	; D7 <-- transfert pas ncessaire (identique)	JUMP'	90$80$:	CLR.W	D7		; D7 <-- transfert ncessaire (plus rcent)90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET; (*)	Si les dates/heures sont exactement identiques, regarde si les;	longueurs sont galement identiques. Si non, il s'agit vraissemblablement;	d'une erreur au niveau de l'horloge (par exemple: bloque ?), et;	il faut dtruire la destination !!!;--------\\; DDDSDEL >;--------/; Dtruit le fichier source, pour l'opration dtruit, ou aprs; l'opration dplace.; in	A1.L	^fichier source; out	D7.W	erreur;	A3.L	^fichier ayant caus l'erreur; mod	D7.W, A3.LDDDSDEL:	PUSH.L	D3	COMP.W	(A6)+ODDDXF,#XFFILES ; selon fichier "!" ?	JUMP',NE 10$		; non => 10$	TEST.B	(A6)+ODDDSW:#BSWDEL ; switch /D prsent ?	JUMP',BS 10$		; oui => 10$	COMP.W	(A6)+ODDDTY,#TYPSYSC ; fichier SYSTEM.CODE ?	JUMP',EQ 10$	CLR.W	D7	JUMP	90$10$:	LOAD.L	A3,A1		; A3 <-- ^source	PUSH.L	D0	LOAD.L	D0,#FOS?DELETE	CALL	_ERCALL		; dtruit le fichier source	POPM.L	D0	JUMP,EQ 90$		; ok => 90$				; erreur =>	COMP.W	(A6)+ODDDXF,#XFDIR ; transfert tout le dossier ?	JUMP,NE 90$		; non => 90$				; oui =>	COMP.W	D7,#ERFUSE	JUMP',EQ 40$	COMP.W	D7,#ERATTD	JUMP',NE 90$				; destruction impossible =>	LOAD.L	D3,#DEFATT	FOS	?CHATR	JUMP',NE 90$	FOS	?DELETE	JUMP'	90$40$:				; fichier utilis =>	FOS	?CLEAR	JUMP',NE 90$	FOS	?DELETE90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; DDDARGS >;--------/; Appel quivalent  FOS,?ARGS mais utilisant si possible; les listes en mmoire (donc beaucoup plus rapide).; in	A3.L	^nom du fichier;	A4.L	^buffer pour arguments; out	D7.W	erreur; mod	D7.WDDDARGS:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A2,A4		; A2 <-- ^buffer	CALL	SEARCHFILE	; A4 <-- ^description (OFL...)	JUMP',NE 50$	LOAD.W	D3,#(LFL/2)-1	; D3 <-- /2 car LOAD.W et -1  cause NMO20$:	LOAD.W	(A2+),(A4+)	; buffer <-- arguments	DECJ.W,NMO D3,20$	JUMP'	90$50$:	COMP.W	D7,#ERFDNE	; fichier n'existe pas ?	JUMP',NE 60$		; non => 60$				; oui =>	PUSH.W	D7	FOS	?NAMERROR	; donne le nom du fichier au FOS	POP.W	D7	JUMP'	90$60$:	LOAD.L	A4,#(A6)+OBUARGT ; A4 <-- ^buffer temporaire	PUSH.L	D0	LOAD.L	D0,#FOS?ARGS	CALL	_ERCALL		; fait un vrai appel (mod D4.L)	POPM.L	D0	JUMP',NE 90$	CALL	PUTFILIST	; buffer <-- arguments	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; COMPDATE >;---------/; Compare deux comples dates/heures.; in	A3.L	^date/heure source;	A4.L	^date/heure destination; out	HI	(A3) > (A4);	EQ	(A3) = (A4);	LO	(A3) < (A4); mod	D7.WCOMPDATE:	PUSH.L	D3	EX.L	A4,A3	CALL	CHECKDATE	; date destination ok ?	EX.L	A3,A4	JUMP',EQ 20$		; oui => 20$				; non =>	CLRZ	CLRC			; retour HI	JUMP'	90$20$:	LOAD.B	D3,(A3)+2	COMP.B	D3,(A4)+2	; compare les annes	JUMP',NE 90$	LOAD.B	D3,(A3)+1	COMP.B	D3,(A4)+1	; compare les mois	JUMP',NE 90$	LOAD.B	D3,(A3)+0	COMP.B	D3,(A4)+0	; compare les jours	JUMP',NE 90$	LOAD.B	D3,(A3)+3	COMP.B	D3,(A4)+3	; compare les heures	JUMP',NE 90$	LOAD.B	D3,(A3)+4	COMP.B	D3,(A4)+4	; compare les minutes	JUMP',NE 90$	LOAD.B	D3,(A3)+5	COMP.B	D3,(A4)+5	; compare les secondes90$:	POPM.L	D3	RET;----------\\; CHECKDATE >;----------/; Vrifie si une date/heure est plausible.; in	A3.L	^date/heure; out	D7.W	ok/erreur; mod	D7.WCHECKDATE:	PUSHM.L	D3,D4	LOAD.B	D3,(A3)+2	; D3 <-- annes	CALL	CHECKBCD	JUMP,NE 80$	LOAD.B	D3,(A3)+1	; D3 <-- mois	CALL	CHECKBCD	JUMP,NE 80$	COMP.B	D3,#H'01	JUMP,LO 80$	COMP.B	D3,#H'12	JUMP,HI 80$	LOAD.B	D3,(A3)+0	; D3 <-- jours	CALL	CHECKBCD	JUMP,NE 80$	COMP.B	D3,#H'01	JUMP,LO 80$	COMP.B	D3,#H'31	JUMP,HI 80$	LOAD.B	D3,(A3)+3	; D3 <-- heures	CALL	CHECKBCD	JUMP,NE 80$	COMP.B	D3,#H'24	JUMP,HI 80$	LOAD.B	D3,(A3)+4	; D3 <-- minutes	CALL	CHECKBCD	JUMP,NE 80$	COMP.B	D3,#H'60	JUMP,HI 80$	LOAD.B	D3,(A3)+5	; D3 <-- secondes	CALL	CHECKBCD	JUMP,NE 80$	COMP.B	D3,#H'60	JUMP,HI 80$; Vrifie si la date est suprieure  la date du jour.;;?	CLR.W	D4	CALL	MAJDATE		; OTIME <-- date du jour40$:	LOAD.B	D3,(A3)+2	; D3 <-- annes	COMP.B	D3,(A6)+OTIME+3	JUMP',HI 50$	JUMP',LO 45$	LOAD.B	D3,(A3)+1	; D3 <-- mois	COMP.B	D3,(A6)+OTIME+2	JUMP',HI 50$	JUMP',LO 45$	LOAD.B	D3,(A3)+0	; D3 <-- jours	COMP.B	D3,(A6)+OTIME+1	JUMP',HI 50$45$:	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:;;?	CALL	MAJDATE		; OTIME <-- date du jour;;?	INC.W	D4;;?	COMP.W	D4,#2;;?	JUMP,LO 40$80$:	LOAD.W	D7,#ERSDAIL	; D7 <-- date/heure illgale90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; CHECKBCD >;---------/; Vrifie si un byte BCD contient une valeur dcimale.; in	D3.B	valeur BCD; out	D7.W	ok/erreur; mod	D7.WCHECKBCD:	PUSH.W	D4	LOAD.W	D7,#ERSDAIL	; D7 <-- date/heure illgale	LOAD.B	D4,D3	SR.B	D4,#4		; D4 <-- dizaines	COMP.B	D4,#9	JUMP',HI 90$	LOAD.B	D4,D3	AND.B	D4,#H'0F	; D4 <-- units	COMP.B	D4,#9	JUMP',HI 90$	CLR.W	D7		; D7 <-- ok90$:	POP.W	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; MAJDATE >;--------/; Met  jour la date du jour.; in	-; out	-; mod	D7.WMAJDATE:	PUSHM.L	D3,D4	LIB	?RDCLOCK	; D3/D4 <-- heure/date	JUMP',NE 90$	LOAD.L	(A6)+OTIME,D490$:	POPM.L	D3,D4	RET;------------\\; CLEARNBFILE >;============/; Donne le nombre de fichiers ouverts.; in	A5.L	^description unit; out	D4.W	nb de fichiers  clearer; mod	D4.L, D7.WCLEARNBFILE:	PUSHM.L	D3,A3	LOAD.L	A3,(A5)+OUNPLI	; A3 <-- ^table des fichiers	LOAD.W	D3,(A5)+OUNNBT	; D3 <-- nb total de fichiers	CLR.W	D420$:	TEST.B	(A3)+OFLOPE	; fichier ouvert en exclusif ?	JUMP',NC 50$		; non => 50$	INC.W	D4		; D4 <-- un fichier ouvert de plus50$:	LOAD.L	A3,#(A3)+LFL	; A3 <-- ^fichier suivant	DEC.W	D3	JUMP,NE 20$	POPM.L	D3,A3	RET;---------\\; CLEARALL >;=========/; Libre tous les fichiers ouverts.; in	A5.L	^description unit; out	-; mod	D7.WCLEARALL:	PUSHM.L	D3,A2..A4	LOAD.L	A1,#(A5)+OUNNAM	; A1 <-- ^nom source	CALL	DDDOPDBOX	; ouvre la dbox d'affichage	JUMP,NE 90$	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.L	A4,#(A6)+OBUFIS	; A4 <-- ^buffer o mettre le nom	LOAD.L	A3,#(A5)+OUNNAM10$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- unit et/ou rpertoires	JUMP,NE 10$	LOAD.L	A2,(A5)+OUNPLI	; A2 <-- ^table des fichiers	LOAD.W	D3,(A5)+OUNNBT	; D3 <-- nb total de fichiers20$:	TEST.B	(A2)+OFLOPE	; fichier ouvert en exclusif ?	JUMP',NC 50$		; non => 50$	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^buffer o mettre le nom	CALL	SKIPREP	LOAD.L	A4,#(A2)+OFLNAM30$:	LOAD.B	(A3+),(A4+)	; OBUFIS <-- nom du fichier	JUMP,NE 30$	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^fichier source	FOS	?CLEAR	CALL	DDDERROR	; affiche v. l'erreur50$:	LOAD.L	A2,#(A2)+LFL	; A2 <-- ^fichier suivant	DEC.W	D3	JUMP,NE 20$	CALL	DDDCLDBOX	; ferme la dbox d'affichage	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,A2..A4	RET	.END