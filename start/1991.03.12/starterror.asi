	.SBTTL	STARTERROR;----------\\; DBOXERROR >;==========/; Affiche une erreur quelconque dans une DBOX.; in	D7.W	erreur;	A3.L	^nom du fichier (facultatif); out	-; mod	-DBOXERROR:	PUSHM.L	D2..D4,D7,A3	LOAD.W	D4,D7		; D4 <-- code de l'erreur	JUMP,EQ 90$		; non => 90$				; oui =>	COMP.W	D4,#ERANNULE	JUMP,EQ 90$	COMP.W	D4,#ERBIP	JUMP',NE 10$	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; juste un p'tit bip	JUMP	90$10$:	CALL	NORMMOUSE	; remet la flche	LOAD.B	D3,#BIPERR	LIB	?BEEP		; fait un "mauvais" bruit	LOAD.W	D3,D4	SR.W	D3,#8	COMP.B	D3,#ERSTART/H'100 ; erreur interne  START ?	JUMP,NE	50$		; non => 50$				; oui =>	LOAD.L	A3,#R16"TAERR20$:	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- saute comme .EVEN	LOAD.L	A3,D3	TEST.W	(A3+)		; fin de la table ?	JUMP',EQ 40$		; oui => 40$	COMP.W	D4,(A3)-2	; erreur trouve ?	JUMP',EQ 40$		; oui => 40$30$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE	30$	JUMP	20$40$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur	JUMP',EQ 80$	TCLR.L	D2:#BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur	JUMP'	80$50$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,D4		; D7 <-- no de l'erreur	DBOX_	MERROR		; affiche l'erreur PSos	JUMP',EQ 80$	TCLR.L	D2:#BDBSAV	; D2 <-- mode	LOAD.W	D7,D4		; D7 <-- no de l'erreur	DBOX_	MERROR		; affiche l'erreur PSos80$:	CALL	AFMENU		; remet les soft-keys90$:	POPM.L	D2..D4,D7,A3	RET;--------\\; AFERROR >;========/; Affiche une erreur quelconque sans DBOX, d'une faon; similaire  LIB,?AFERROR.; in	D7.W	erreur;	A3.L	^nom du fichier (facultatif); out	-; mod	-AFERROR:	PUSHM.L	D3,D4,D7,A3	LOAD.W	D4,D7		; D4 <-- code de l'erreur	LOAD.W	D3,D4	SR.W	D3,#8	COMP.B	D3,#ERSTART/H'100 ; erreur interne  START ?	JUMP,NE	50$		; non => 50$				; oui =>	LOAD.L	A3,#R16"TAERR20$:	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- saute comme .EVEN	LOAD.L	A3,D3	TEST.W	(A3+)		; fin de la table ?	JUMP',EQ 40$		; oui => 40$	COMP.W	D4,(A3)-2	; erreur trouve ?	JUMP',EQ 40$		; oui => 40$30$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE	30$	JUMP	20$40$:	LIB	?AFTEXT		; affiche le texte de l'erreur	JUMP'	90$50$:	LIB	?AFERROR	; affiche l'erreur PSos90$:	POPM.L	D3,D4,D7,A3	RETTAERR:	.W	ERSFUSE	.ASCII	"Cette unit ou ce dossier<CR>"	.ASCIZ	"est dj ouvert !"	.EVEN	.W	ERSTWDO	.ASCIZ	"Trop d'units ou de dossiers ouverts !"	.EVEN	.W	ERSDOSS	.ASCII	"Il est impossible d'ouvrir ce dossier !<CR>"	.ASCII	"<CR>"	.ASCII	"RAPPEL: L'icne DOSSIER: sert uniquement<CR>"	.ASCIZ	"         crer de nouveaux dossiers."	.EVEN	.W	ERSDOSL	.ASCII	"Il est impossible d'ouvrir ce dossier,<CR>"	.ASCII	/car l'opration "lecture" n'est pas<CR>/	.ASCIZ	"autorise !"	.EVEN	.W	ERSDOIL	.ASCII	"Le nom DOSSIER: ne peut pas<CR>"	.ASCIZ	"tre utilis !"	.EVEN	.W	ERSDOPN	.ASCIZ	"<AFDIR>... pas ncessaire (existe dj)"	.EVEN	.W	ERSDATE	.ASCIZ	"<AFDIR>... pas ncessaire (plus ancien)"	.EVEN	.W	ERSDAEQ	.ASCIZ	"<AFDIR>... pas ncessaire (identique)"	.EVEN	.W	ERSDAIL	.ASCIZ	"Date ou heure incorrecte !"	.EVEN	.W	ERSPROG	.ASCII	"Pas de programme associ<CR>"	.ASCIZ	" ce type de document !"	.EVEN	.W	ERSSYST	.ASCIZ	"SYSTEM.CODE est dj en excution !"	.EVEN	.W	ERSFORM	.ASCII	"Le formatage n'est possible<CR>"	.ASCIZ	"qu'avec une disquette !"	.EVEN	.W	ERSSTOP	.ASCIZ	"Opration stoppe ..."	.EVEN	.W	ERSPRIN	.ASCII	"Rseau: changement d'imprimante<CR>"	.ASCIZ	"        impossible !"	.EVEN	.W	ERSEDIT	.ASCII	"L'dition de ce document<CR>"	.ASCIZ	"n'est pas possible !"	.EVEN	.W	ERSCOPY	.ASCII	"Les mmoires de masse ont<CR>"	.ASCIZ	"des capacits diffrentes !"	.EVEN	.W	ERSFULL	.ASCII	"L'espace disque est insuffisant<CR>"	.ASCIZ	"pour cette opration !"	.EVEN	.W	ERSDUPF	.ASCII	"Ce fichier ne peut pas tre dupliqu<CR>"	.ASCIZ	" cette destination, car il y est dj !"	.EVEN	.W	ERSGJIP	.ASCIZ	"Problme avec JIP24"	.EVEN	.W	ERSCLEF	.ASCIZ	"Les deux clefs ne sont pas identiques !"	.EVEN	.W	0				; <-- terminateur	.ASCIZ	"Erreur avec START !"	.EVEN	.END