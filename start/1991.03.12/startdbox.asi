	.SBTTL	STARTDBOX;----------\\; DBOXLISTE >;==========/; Choix pour les listes.; in	A5.L	^description unit; out	D3.W	dernire touche (F0/F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXLISTE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_LISTE	LOAD.L	D4,(A5)+OUNFALI	; D4 <-- fanions	TNOT.L	D4:#BFLNCOD	TNOT.L	D4:#BFLNDIR	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	A3,#(A5)+OUNNAM	; A3 <-- ^dbut du nom	CALL	SKIPREP		; A3 <-- ^aprs rep:	LOAD.L	A4,A310$:	TEST.B	(A4+)		; A4 <-- ^fin du nom	JUMP,NE 10$	DEC.L	A420$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,A322$:	COMP.B	(A1+),#CR	JUMP,NE 22$	CLR.B	(A1)-1		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_LISTE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ 70$	COMP.W	D3,#F4	JUMP,EQ 70$	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP',EQ 40$	COMP.W	D3,#SPACE	JUMP,EQ 20$	LOAD.W	D1,D3	CLR.B	D1	COMP.W	D1,#KEYDBOX	JUMP',EQ 50$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$50$:				; KEYDBOX =>	COMP.B	D3,#8*1	JUMP',LO 54$	COMP.B	D3,#8*2	JUMP',LO 52$	COMP.B	D3,#8*3	JUMP,HS 30$				; range affichage =>	AND.L	D4,#H'FF00FFFF	TSET.L	D4:D3	JUMP	20$52$:				; range classement 2 =>	AND.L	D4,#H'FFFF00FF	TSET.L	D4:D3	SUB.B	D3,#8	TEST.L	D4:D3		; idem allum dans classement 1 ?	JUMP,BC 20$		; non => 20$	AND.L	D4,#H'FFFFFF00	TSET.L	D4:#BFLC1A	TEST.L	D4:#BFLC2A	JUMP,BC 20$	TCLR.L	D4:#BFLC1A	TSET.L	D4:#BFLC1E	JUMP	20$54$:				; range classement 1 =>	AND.L	D4,#H'FFFFFF00	TSET.L	D4:D3	ADD.B	D3,#8	TEST.L	D4:D3		; idem allum dans classement 2 ?	JUMP,BC 20$		; non => 20$	AND.L	D4,#H'FFFF00FF	TSET.L	D4:#BFLC2A	TEST.L	D4:#BFLC1A	JUMP,BC 20$	TCLR.L	D4:#BFLC2A	TSET.L	D4:#BFLC2E	JUMP	20$70$:				; D'ACCORD =>;;?	TEST.B	(A3)		; nom critre existe ?;;?	JUMP,EQ 30$		; non => 30$	TNOT.L	D4:#BFLNCOD	TNOT.L	D4:#BFLNDIR	LOAD.L	(A5)+OUNFALI,D480$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX	TEST.B	(A3)		; nom critre existe ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.B	(A3+),#'*	; non => met "*" par dfaut !	CLR.B	(A3)EXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXMODIF >;==========/; Modifie un fichier.; in	A5.L	^description unit;	D4.W	rang du fichier; out	D3.W	dernire touche (F0/F1);	D7.W	erreur;	A3.L	^nom de fichier ayant caus l'erreur; mod	D3.L, D7.W, A3.LDBOXMODIF:	PUSHM.L	D0..D2,D4,D5,A1,A2,A4	CALL	PREPFIS		; OBUFIS <-- nom du fichier  modifier	CLR.L	D0	LOAD.W	D0,D4		; D0 <-- rang du fichier	CALL	GETPFILE	; A3 <-- ^nom du fichier	LOAD.L	A1,A3	LOAD.L	A2,#R16"TDBOX_MODIF	LOAD.L	D4,(A3)+OFLATT	; D4 <-- attributs	TNOT.L	D4:#BATTN	TNOT.L	D4:#BATTB	TCLR.L	D4:#BATTWPR	; D4 <-- enlve  cause boulette dans FOS en EPROM !	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LIB	?GETSHIFT	; D3 <-- touches super-shift	LOAD.B	(A6)+OSHIFT,D3	TEST.L	D3:#BCHANGE	; touche (CHANGE) enfonce ?	JUMP',BC NOEXT$	TSET.L	D0:#17		; D0 <-- dition extension autoriseNOEXT$:	LOAD.L	A4,#(A6)+OBUFITNAME2$:	LOAD.B	D3,(A3+)	JUMP',EQ NAME4$	COMP.B	D3,#'.	JUMP',EQ NAME4$	COMP.B	D3,#'!	JUMP',EQ NAME4$	COMP.B	D3,#':	JUMP',EQ NAME4$	LOAD.B	(A4+),D3	; OBUFIT <-- nom sans extension	JUMP	NAME2$NAME4$:	CLR.B	(A4)		; A4 <-- ^fin du nom	PUSHM.L	D4,A3	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUFIT	LIB	?AFTEXT		; affiche le nom sans extension	POPM.L	D4,A3	DEC.L	A3	LOAD.L	A2,#(A6)+OBUFIDEXT2$:	LOAD.B	(A2+),(A3+)	; OBUFID <-- .extension	JUMP,NE EXT2$	COMP.B	(A6)+OBUFID,#':	JUMP',NE EXT3$	TCLR.L	D0:#17		; D0 <-- dition extension interditeEXT3$:	PUSH.L	D4	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	TEST.L	D0:#17		; dition extension autorise ?	JUMP',BS EXT6$		; oui => EXT6$	LOAD.B	D3,#AFGREY	LIB	?AFCAREXT6$:	LOAD.L	A3,#(A6)+OBUFID	LIB	?AFTEXT		; affiche l'extension (en gris)	LOAD.B	D3,#AFFULL	LIB	?AFCAR	POP.L	D4	LOAD.L	A3,#(A1)+OFLCD	CALL	CHECKDATE	; date/heure de cration correcte ?	JUMP',EQ DATE3$		; oui => DATE3$	TSET.L	D0:#18		; D0 <-- dition date autoriseDATE3$:	CLR.L	D3	LOAD.B	D3,(A1)+OFLCD+0	; D3 <-- jour	SL.L	D3,#8	LOAD.B	D3,(A1)+OFLCD+1	; D3 <-- mois	SL.L	D3,#8	LOAD.B	D3,(A1)+OFLCD+2	; D3 <-- anne	LOAD.L	A3,#(A6)+OBUDAT	CALL	PUTDATE		; OBUDAT <-- date en ASCIZ	PUSH.L	D4	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	TEST.L	D0:#18		; dition date autorise ?	JUMP',BC DATE5$		; non => DATE5$	CALL	DBINVRECT	; oui => dessine le rectangleDATE5$:	LIB	?SETCURS	LIB	?AFTEXT		; affiche la date de cration	POP.L	D4	PUSH.L	D4	LOAD.W	D2,#4!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,(A1)+OFLLG	; D4 <-- taille	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDCM!2^BAFDSP	LIB	?AFDEC		; affiche la taille	POP.L	D4	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nom (#MM0:TOTO.TEXT)	CALL	SKIPREPSRC2$:	LOAD.B	D3,(A3+)	JUMP',EQ SRC6$	COMP.B	D3,#'.	JUMP',NE SRC2$	LOAD.B	(A3)-1,#'!	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nom (#MM0:TOTO!TEXT)	CALL	SEARCHFILE	; fichier "!" existe ?	JUMP',NE SRC2$		; non => SRC2$				; oui =>	TCLR.L	D0:#17		; dition extension impossible	TCLR.L	D4:#BATTC	; D4 <-- enlve l'attribut "C"	PUSH.L	D4	LOAD.W	D2,#5!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO		; grise le bouton "changement de nom"	POP.L	D4SRC6$:	TCLR.L	D0:#16		; D0 <-- dition nom impossible	TEST.L	D4:#BATTC	JUMP',BC SRC8$	TSET.L	D0:#16		; D0 <-- dition nom possibleSRC8$:	CLR.W	D2		; D2 <-- dite le nomCHEDIT$:	LOAD.W	D3,#-1		; D3 <-- le nom n'est pas ditable !	COMP.W	D2,#2	JUMP',EQ CHEDIT2$	COMP.W	D2,#1	JUMP',EQ CHEDIT1$CHEDIT0$:	TEST.L	D0:#16	JUMP',BC CHEDIT8$	LOAD.L	A3,#(A6)+OBUFIT	; A3 <-- ^dbut du nom	JUMP'	CHEDIT4$CHEDIT1$:	TEST.L	D0:#17	JUMP',BC CHEDIT8$	LOAD.L	A3,#(A6)+OBUFID	; A3 <-- ^dbut de l'extension	JUMP'	CHEDIT4$CHEDIT2$:	TEST.L	D0:#18	JUMP',BC CHEDIT8$	LOAD.L	A3,#(A6)+OBUDAT	; A3 <-- ^dbut de la date;	JUMP'	CHEDIT4$CHEDIT4$:	LOAD.W	D3,D2	LOAD.L	A4,A3CHEDIT5$:	TEST.B	(A4+)	JUMP,NE CHEDIT5$	DEC.L	A4		; A4 <-- ^fin du nom/extension/dateCHEDIT8$:	DBOX_	MEDITLOOP$:	CALL	DBMDSYN		; grise v. (MODIFIE)	JUMP',EQ LOOP1$		; ok => LOOP$1				; "." frapp =>	TEST.L	D0:#17		; dition extension possible ?	JUMP,BC BIP$		; non => BIP$				; oui =>	LOAD.B	(A6)+OBUFID+0,#'.	CLR.B	(A6)+OBUFID+1	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUFIT	LIB	?AFTEXT		; affiche le nom sans le "."	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	".       "	; affiche l'extension en effaant l'ancienne	.EVEN	POP.L	D4	LOAD.W	D2,#1		; D2 <-- dite l'extension	JUMP	CHEDIT$LOOP1$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,A3LOOP2$:	TEST.B	(A1)	JUMP',EQ LOOP3$	COMP.B	(A1+),#CR	JUMP,NE LOOP2$	CLR.B	(A1)-1		; remplace le <CR> par <0>LOOP3$:	LOAD.L	A1,#R16"TKEY_MODIF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	TEST.W	D3	JUMP,EQ LOOP$	COMP.W	D3,#SPACE	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ CR$	COMP.W	D3,#KEYDBOX+0	JUMP,EQ EDITN$	COMP.W	D3,#KEYDBOX+1	JUMP,EQ EDITE$	COMP.W	D3,#KEYDBOX+2	JUMP,EQ EDITD$	COMP.W	D3,#KEYDBOX+BATTC	JUMP,EQ BATTC$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	LOOP$CR$:				; RETURN =>	TEST.L	D4:#BATTC	JUMP',BS CR2$	TEST.L	D0:#17	JUMP',BS CR2$	TEST.L	D0:#18		; qq chose d'ditable ?	JUMP,BC BIP$		; non => BIP$CR2$:	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,#3	JUMP',LO CR3$	CLR.W	D2	TEST.L	D0:#16		; dition nom possible ?	JUMP,BC CR2$		; non => CR2$	JUMP	CHEDIT$CR3$:	COMP.W	D2,#2	JUMP',EQ CR4$	TEST.L	D0:#17		; dition extension possible ?	JUMP,BC CR2$		; non => CR2$	JUMP	CHEDIT$CR4$:	TEST.L	D0:#18		; dition date possible ?	JUMP,BC CR2$		; non => CR2$	JUMP	CHEDIT$EDITN$:	TEST.L	D0:#16		; dition nom possible ?	JUMP,BC BIP$		; non => BIP$	CLR.W	D2		; D2 <-- dite le nom	JUMP	CHEDIT$EDITE$:	TEST.L	D0:#17		; dition extension possible ?	JUMP,BC BIP$		; non => BIP$	LOAD.W	D2,#1		; D2 <-- dite l'extension	JUMP	CHEDIT$EDITD$:	TEST.L	D0:#18		; dition date possible ?	JUMP,BC BIP$		; non => BIP$	LOAD.W	D2,#2		; D2 <-- dite la date	JUMP	CHEDIT$BATTC$:	TCLR.L	D0:#16		; D0 <-- dition nom impossible	TCLR.L	D0:#17		; D0 <-- dition extension impossible	TEST.L	D4:#BATTC	JUMP,BC CHEDIT$	TSET.L	D0:#16		; D0 <-- dition nom possible	TEST.B	(A6)+OSHIFT:#BCHANGE ; touche (CHANGE) enfonce ?	JUMP,BC CHEDIT$	COMP.B	(A6)+OBUFID,#':	JUMP,EQ CHEDIT$	TSET.L	D0:#17		; D0 <-- dition extension possible	JUMP	CHEDIT$OK$:				; D'ACCORD =>	TEST.L	D0:#20		; touche grise ?	JUMP,BS BIP$		; oui => BIP$	TEST.B	(A6)+OBUFIT	; nom existe ?	JUMP,EQ BIP$		; non => BIP$;;?	TEST.B	(A6)+OBUFID	; extension existe ?;;?	JUMP,EQ BIP$		; non => BIP$	TEST.B	(A6)+OBUDAT	; date existe ?	JUMP,EQ BIP$		; non => BIP$				; oui =>	LOAD.L	A1,#(A6)+OBUFITOK2$:	COMP.B	(A1),#':	; y a-t-il un ":" dans le nom ?	JUMP,EQ BIP$		; oui => BIP$	TEST.B	(A1+)	JUMP,NE OK2$	CALL	DBOXCLOSE	; ferme la DBOX	LOAD.L	A3,#(A6)+OBUFITOK3$:	LOAD.B	D3,(A3)	LIB	?MINMAJ	LOAD.B	(A3+),D3	JUMP,NE OK3$	DEC.L	A3	LOAD.L	A4,#(A6)+OBUFIDOK4$:	LOAD.B	(A3+),(A4+)	; OBUFIT <-- remet l'extension	JUMP,NE OK4$	EX.L	D4,D0		; D4 <-- rang, D0 <-- attributs	CALL	GETPFILE	; A3 <-- ^nom du fichier original	LOAD.L	A4,#(A6)+OBUFIT	; A4 <-- ^nom du fichier dit	LOAD.L	A2,#R16"TERM$	; A2 <-- ^terminateurs	LIB	?CPSTRING	; nom chang ?	JUMP,EQ OK62$		; non => OK62$				; oui =>	CALL	SEARCHNAME	; A4/D4 <-- ^descripteur/rang	JUMP,NE EXIT$	LOAD.L	D3,(A4)+OFLATT	TEST.L	D3:#BATTC	; attribut "C" prsent ?	JUMP',BS OK6$		; oui => OK6$	LOAD.L	D3,D0		; D3 <-- nouveaux attributs	TSET.L	D3:#BATTC	; D3 <-- met de toute faon l'attribut "C" !	TNOT.L	D3:#BATTN	TNOT.L	D3:#BATTB	COMP.L	D3,(A4)+OFLATT	; attributs changs ?	JUMP',EQ OK6$		; non => OK6$				; oui =>	CALL	CHATREX		; change les attributs (met l'attribut "C")	JUMP,NE EXIT$	CALL	BALWAIT		; traite les messages du FOS ...OK6$:	LOAD.L	A3,#(A6)+OBUFIT	; A3 <-- ^nouveau nom	CALL	RENAMEEX	; renomme le fichier	JUMP,NE EXIT$	CALL	BALWAIT		; traite les messages du FOS ...	LOAD.L	A3,#(A6)+OBUFIT	; A3 <-- ^nouveau nomOK62$:	CALL	SEARCHNAME	; A4/D4 <-- ^descripteur/rang	JUMP,NE EXIT$OK63$:	LOAD.L	D3,D0		; D3 <-- nouveaux attributs	TNOT.L	D3:#BATTN	TNOT.L	D3:#BATTB	COMP.L	D3,(A4)+OFLATT	; attributs changs ?	JUMP',EQ OK65$		; non => OK65$				; oui =>	CALL	CHATREX		; change les attributs	JUMP,NE EXIT$	CALL	BALWAIT		; traite les messages du FOS ...OK65$:	LOAD.L	A3,#(A6)+OBUDAT	CALL	GETDATE		; D3 <-- nouvelle date en BCD	CALL	DBMDCHK		; date plausible ?	JUMP,NE EXIT$		; non => EXIT$	CLR.L	D2	LOAD.B	D2,(A4)+OFLCD+0	; D2 <-- jour	SL.L	D2,#8	LOAD.B	D2,(A4)+OFLCD+1	; D2 <-- mois	SL.L	D2,#8	LOAD.B	D2,(A4)+OFLCD+2	; D2 <-- anne	COMP.L	D3,D2		; date change ?	JUMP',EQ OK70$		; non => OK70$				; oui =>	CALL	CHDATEEX	; change la date de cration	JUMP',NE EXIT$	CALL	BALWAIT		; traite les messages du FOS ...OK70$:	LOAD.W	D3,#F1		; D3 <-- (D'ACCORD)	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1,A2,A4	TEST.W	D7		; retour EQ/NE	RETTERM$:	.B	0,-1		; terminateurs	.EVEN;--------\\; DBMDSYN >;--------/; Grise le bouton (MODIFIE) si la syntaxe n'est pas correcte.; in	D0.L	flags;	D2.W	rang (0,1); out	D0.L	flags;	D7.W	NE => "." frapp dans le nom; mod	D0.L, D7.WDBMDSYN:	PUSHM.L	D2..D4,A3	TEST.W	D2		; dite le nom ?	JUMP',EQ 10$		; oui => 10$	COMP.W	D2,#1		; dite l'extension ?	JUMP,NE EXIT$		; non => EXIT$10$:				; oui =>	LOAD.L	A3,#(A6)+OBUFIT	; A3 <-- ^nom (sans extension)	TEST.B	(A3)	JUMP,EQ GREY$	CLR.W	D4		; D4 <-- nb de caractres20$:	LOAD.B	D3,(A3+)	JUMP',EQ 30$	INC.W	D4	COMP.B	D3,#SPACE	JUMP',NE 22$	LOAD.B	(A3)-1,#'_	; remplace espace par soulign !	JUMP	20$22$:	COMP.B	D3,#'_	JUMP,EQ 20$	COMP.B	D3,#'.	JUMP',EQ 26$	COMP.B	D3,#'0	JUMP',LO GREY$	COMP.B	D3,#'9	JUMP,LS 20$	COMP.B	D3,#'A	JUMP',LO GREY$	COMP.B	D3,#'Z	JUMP,LS 20$	COMP.B	D3,#'a	JUMP',LO GREY$	COMP.B	D3,#'z	JUMP',HI GREY$	JUMP	20$26$:				; "." dans le nom =>	LOAD.L	A4,#(A3)-1	CLR.B	(A4)		; tronque depuis le "." jusqu' la fin	LOAD.W	D7,#1		; D7 <-- "." frapp dans le nom	JUMP	ERROR$30$:	LOAD.L	A3,#(A6)+OBUFID	; A3 <-- ^extension	ADD.W	D4,#4		; D4 <-- +4 pour ".DIR"	COMP.B	(A3),#':	JUMP',EQ 40$	TEST.B	(A3)	JUMP',EQ 35$	COMP.B	(A3),#'.	JUMP',EQ 34$	COMP.B	(A3),#'!	JUMP',NE GREY$34$:	TEST.B	(A3)+1	JUMP',EQ GREY$35$:	SUB.W	D4,#4+136$:	INC.W	D4	TEST.B	(A3+)	JUMP,NE 36$40$:	COMP.W	D4,#15		; nom trop long ?	JUMP',LS FULL$GREY$:	TSET.L	D0:#20	JUMP',BS EXIT$	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	JUMP'	EXIT$FULL$:	TCLR.L	D0:#20	JUMP',BC EXIT$	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCOEXIT$:	CLR.W	D7		; D7 <-- pas de "." frappERROR$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBMDCHK >;--------/; Vrifie si une date dans un registre est plausible.; in	D3.L	date en BCD: | |j|m|a|; out	D7.W	ok/erreur; mod	D7.WDBMDCHK:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUFID	LOAD.B	(A3)+2,D3	SR.L	D3,#8	LOAD.B	(A3)+1,D3	SR.L	D3,#8	LOAD.B	(A3)+0,D3	LOAD.B	(A3)+3,#H'12	LOAD.B	(A3)+4,#H'00	LOAD.B	(A3)+5,#H'00	CALL	CHECKDATE	; nouvelle date plausible ?	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCOLOR1 >;===========/; Modifie la couleur d'un fichier.; in	A5.L	^description unit;	D4.W	rang du fichier; out	D7.W	erreur;	A3.L	^nom de fichier ayant caus l'erreur; mod	D3.L, D7.W, A3.LDBOXCOLOR1:	PUSHM.L	D2..D4	CALL	PREPFIS		; OBUFIS <-- nom du fichier  modifier	CALL	GETPFILE	; A3 <-- ^nom du fichier	LOAD.L	D2,(A3)+OFLATT	; D2 <-- attributs	SWAP.W	D2	SR.W	D2,#4	AND.W	D2,#B'111	; D2 <-- couleur (0..7)	CALL	DBOXCOLOR	; choix de la couleur ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	SL.W	D2,#4	SWAP.W	D2	AND.L	D2,#H'00700000	LOAD.L	D3,(A3)+OFLATT	; D3 <-- attributs	AND.L	D3,#H'FF8FFFFF	OR.L	D3,D2	COMP.L	D3,(A3)+OFLATT	; attributs changs ?	JUMP',EQ EXIT$		; non => EXIT$	CALL	CHATREX		; change les attributs (met l'attribut "C")	JUMP',NE EXIT$	CALL	BALWAIT		; traite les messages du FOS ...	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXCOLOR >;==========/; Choix d'une couleur.; in	D2.W	couleur initiale (0..n); out	D2.W	couleur choisie (0..n);	D3.W	dernire touche (F0/F1);	D7.W	erreur; mod	D2.L, D3.L, D7.W, A3.LDBOXCOLOR:	PUSHM.L	D0,D1,D4,D5,A1..A4	LOAD.W	D0,D2		; D0 <-- couleur initiale	LOAD.L	A2,#R16"TDBOX_COLOR	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	LOAD.L	(A6)+OCOPOS,D3	LOAD.W	D1,#-1DRAW$:	INC.W	D1	CALL	DBCODRAW	; dessine un rectangle	JUMP,EQ DRAW$	LOAD.W	D1,D0	CALL	DBCOINV		; allume la couleur actuelleLOOP$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_COLOR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#F1	JUMP',EQ OK$	COMP.W	D3,#F0	JUMP',EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	LOAD.W	D1,D0	CALL	DBCOMOVE	; choix d'une couleur ...	JUMP,NE BIP$	COMP.W	D1,D0		; double-clic ?	JUMP',EQ OK$		; oui => OK$	LOAD.W	D0,D1	JUMP	LOOP$OK$:				; D'ACCORD =>	LOAD.W	D3,#F0	COMP.W	D0,#-1	JUMP',EQ CANCEL$	LOAD.W	D2,D0		; D2 <-- couleur choisie	LOAD.W	D3,#F1CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0,D1,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBCOMOVE >;---------/; Action dans un rectangle.; in	D1.W	rang (0..n); out	D1.W	rang (0..n);	D7.W	erreur; mod	D1.L, D7.WDBCOMOVE:	PUSHM.L	D2..D4	LOAD.W	D2,D1	JUMP'	FIRST$LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE END$FIRST$:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	SUB.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SWAP.W	D4	CALL	DBCODET		; D1 <-- carr o est la souris	COMP.W	D1,D2	JUMP,EQ LOOP$	EX.L	D1,D2	CALL	DBCOINV		; teint l'ancien	LOAD.W	D1,D2	CALL	DBCOINV		; allume le nouveau	JUMP	LOOP$END$:	LOAD.W	D1,D2	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBCODET >;--------/; Dtecte dans quel rectangle est la souris.; in	D4.L	position de la souris (y;x); out	D1.W	rang (0..n);	D7.W	erreur; mod	D1.L, D7.WDBCODET:	PUSHM.L	D0,D2..D4	LOAD.W	D0,D4		; D0 <-- position en X	LOAD.L	D2,D4	SWAP.W	D2		; D2 <-- position en Y	LOAD.W	D1,#-1LOOP$:	INC.W	D1	CALL	DBCOPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	COMP.W	D0,D3	JUMP,LO LOOP$	ADD.W	D3,D4	COMP.W	D0,D3	JUMP,HS LOOP$	SWAP.W	D3	SWAP.W	D4	COMP.W	D2,D3	JUMP,LO LOOP$	ADD.W	D3,D4	COMP.W	D2,D3	JUMP,HS LOOP$EXIT$:	POPM.L	D0,D2..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBCODRAW >;---------/; Dessine un rectangle.; in	D1.W	rang (0..n); out	D7.W	erreur; mod	D7.WDBCODRAW:	PUSHM.L	D2..D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	DBCOPOS		; D3/D4 <-- position/dimensions	JUMP,NE EXIT$	LOAD.W	D2,#SETDOT	LIB	?DRRECT	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COUL$	SR.W	D4,#1	ADD.W	D3,D4	SUB.W	D3,#4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	ADD.W	D3,#5	SWAP.W	D3;	SWAP.W	D4	LIB	?SETCURS	LOAD.B	D3,D1	ADD.B	D3,#'1	LIB	?AFCAR		; affiche un numro 1..8	JUMP'	OK$COUL$:	LIB	?COLORPUSH	PUSH.L	D3	LOAD.L	D3,#COLOR_STCOL1	ADD.W	D3,D1	LIB	?COLORSR	POP.L	D3	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	LIB	?COLORPOPOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBCOINV >;--------/; Inverse un rectangle.; in	D1.W	rang (0..n); out	-; mod	D7.WDBCOINV:	PUSHM.L	D1..D4	CALL	DBCOPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	LOAD.W	D2,#INVDOT	LOAD.W	D1,#4-1LOOP$:	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	COMP.W	D1,#4-1	JUMP',EQ NEXT$	LIB	?DRRECTNEXT$:	DECJ.W,NMO D1,LOOP$EXIT$:	POPM.L	D1..D4	RET;--------\\; DBCOPOS >;--------/; Donne la position et les dimensions d'un rectangle.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBCOPOS:	PUSH.L	D1	LOAD.W	D7,#1	COMP.W	D1,#-1	JUMP',EQ EXIT$	AND.L	D1,#H'FFFF	DIV.WU	D1,#4		; D1 <-- rang (x;y)	LOAD.L	D3,(A6)+OCOPOS	LOAD.W	D4,D1	COMP.W	D4,#2	JUMP',HS EXIT$	MUL.WU	D4,#50	SWAP.W	D3	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	D4,D1	SWAP.W	D4	MUL.WU	D4,#60	ADD.W	D3,D4	LOAD.L	D4,#H'10000*(50-10)+(60-10)	CLR.W	D7EXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXCHATR >;==========/; Change les attributs d'un groupe de fichiers.; in	-; out	D3.W		dernire touche (F0/F1);	(A6)+ODDDAP.L	attributs  ajouter (+);	(A6)+ODDDAM.L	attributs  enlever (-);	D7.W		erreur; mod	D3.L, D7.WDBOXCHATR:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_CHATR	CLR.L	D4		; D4 <-- attributs	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Modifie "	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OSELNB	; D4 <-- nb de fichiers	LOAD.W	D3,#4		; D3 <-- nb max de digits	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" fichier"	.EVEN	COMP.W	D4,#1	JUMP',LS 10$	LIB	?AFTIM	.ASCIZ	"s"	.EVEN10$:	LIB	?AFTIM	.ASCIZ	" comme suit :"	.EVEN	LOAD.W	D2,#101!2^BDBGCLABEL	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO		; D3 <-- coin sup/gauche	POP.L	D4		; D4 <-- coin inf/droite	SUB.W	D3,(A0)+ODFCX	SUB.W	D3,#4	ADD.W	D4,(A0)+ODFCX	ADD.W	D4,#4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,#4	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#4-1	SUB.W	D4,D3	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour des exemples	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,#3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"-  +"	.EVEN	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,#3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"-  +"	.EVEN	POP.L	D420$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_CHATR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ 70$	COMP.W	D3,#F0	JUMP,EQ 80$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ 40$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; clic =>	TEST.L	D4:D3		; fanion allum ?	JUMP,BC 20$		; non => 20$	SUB.B	D3,#16	JUMP',NC 42$	ADD.B	D3,#16+1642$:	TCLR.L	D4:D3		; D4 <-- teint le fanion "dakt"	JUMP	20$70$:				; D'ACCORD =>	TEST.L	D4	JUMP,EQ 30$	PUSH.L	D4	AND.L	D4,#H'0000FFFF	TCLR.L	D4:#BATTB-16	JUMP',BC 72$	TSET.L	D4:#BATTB72$:	LOAD.L	(A6)+ODDDAM,D4	; ODDDAM <-- attributs  enlever	POP.L	D4	CLR.W	D4	SWAP.W	D4	TCLR.L	D4:#BATTB-16	JUMP',BC 74$	TSET.L	D4:#BATTB74$:	LOAD.L	(A6)+ODDDAP,D4	; ODDDAM <-- attributs  ajouter80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXCLEAR >;==========/; Libre tous les fichiers d'un groupe.; in	A5.L	^description unit; out	D3.W	dernire touche ('O/'N);	D7.W	erreur; mod	D3.L, D7.WDBOXCLEAR:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ		; signal qq chose de spcial	LOAD.L	A2,#R16"TDBOX_CLEAR	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	CALL	CLEARNBFILE	; D4 <-- nb de fichiers  clearer	CLR.L	D1	LOAD.W	D1,D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	COMP.W	D1,#1	JUMP',HI 15$	LIB	?AFTIM	.ASCIZ	"le fichier ouvert"	.EVEN	JUMP'	20$15$:	LIB	?AFTIM	.ASCIZ	"les "	.EVEN	LOAD.L	D4,D1	LOAD.W	D3,#4		; D3 <-- nb max de digits	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" fichiers ouverts"	.EVEN20$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_CLEAR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#'O	JUMP',EQ 80$	COMP.W	D3,#'N	JUMP',EQ 80$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXHEADER >;===========/; Modifie l'en-tte binaire d'un programme.; in	A3.L	^nom du programme; out	D3.W	dernire touche (F0/F1);	D7.W	erreur; mod	D3.L, D7.WDBOXHEADER:	PUSHM.L	D0..D2,D4,D5,D6,A1..A5	LOAD.L	A5,A3		; A5 <-- ^nom du programme	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL	JUMP,NE EXIT$	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D4,#256	FOS	?RDBYTE		; OBUHEAD <-- en-tte	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	JUMP,NE EXIT$	LOAD.L	A2,#R16"TDBOX_HEADER	LOAD.L	D4,(A6)+OBUHEAD+OBXUNIT ; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	CLR.W	D210$:	CALL	DBHDGET		; A3 <-- ^contenu	CALL	DBHDAFF		; affiche le contenu	INC.W	D2	COMP.W	D2,#9	JUMP,LO 10$	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	CLR.L	D4	LOAD.B	D4,(A6)+OBUHEAD+OBXREV	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le numro de rvision	LIB	?AFTIM	.ASCIZ	"."	.EVEN	CLR.L	D4	LOAD.B	D4,(A6)+OBUHEAD+OBXVER;	LOAD.W	D3,#3;	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le numro de version	LOAD.L	D4,(A6)+OBUHEAD+OBXUNIT ; D4 <-- fanions	CLR.W	D220$:	CALL	DBHDGET		; A3/A4 <-- ^dbut/fin ligne  diter22$:	LOAD.W	D3,D2	DBOX_	MEDIT	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,A326$:	COMP.B	(A1+),#CR	JUMP,NE 26$	CLR.B	(A1)-1		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_HEADER	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ 70$	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP,EQ 40$	COMP.W	D3,#CR	JUMP,EQ 60$	LOAD.W	D1,D3	CLR.B	D1	COMP.W	D1,#KEYDBOX	JUMP,EQ 50$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	22$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	22$50$:				; KEYDBOX =>	CALL	DBHDPUT	JUMP,NE 30$	LOAD.W	D2,D3	AND.W	D2,#H'FF	JUMP	20$60$:				; RETURN =>	CALL	DBHDPUT	JUMP,NE 30$	INC.W	D2	COMP.W	D2,#9	JUMP,LO 20$	CLR.W	D2	JUMP	20$70$:				; D'ACCORD =>	CALL	DBHDPUT	JUMP,NE 30$	LOAD.L	(A6)+OBUHEAD+OBXUNIT,D4 ; mj. selon les fanions	CALL	WAITMOUSE	; souris: met le sablier	CALL	DBOXCLOSE	; ferme la DBOX	LOAD.L	A3,A5		; A3 <-- ^nom du programme	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D4,#256	FOS	?WRBYTE		; en-tte <-- OBUHEAD	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	JUMP',NE EXIT$	LOAD.W	D3,#F1	JUMP'	EXIT$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,D6,A1..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBHDGET >;--------/; Prend un nouveau paramtre pour l'diter.; in	D2.W	rang (0..n);	D5.L	canal DBOX; out	A3.L	^dbut ligne  diter;	A4.L	^fin ligne  diter; mod	D7.W, A3.L, A4.LDBHDGET:	PUSHM.L	D2..D4,A2	LOAD.L	A4,#R16"TDBHEAD	MUL.WU	D2,#12	ADD.L	A4,D2		; A4 <-- ^dans TDBHEAD	LOAD.L	A2,#(A6)+OBUHEAD	LOAD.W	D2,(A4)+2	; D2 <-- OBX...	CLR.L	D4	COMP.W	(A4)+10,#1	JUMP,EQ 50$	COMP.W	(A4)+10,#2	JUMP,EQ 70$	COMP.W	(A4)+4,#4	JUMP',EQ 16$	COMP.W	(A4)+4,#2	JUMP',EQ 14$	LOAD.B	D4,(A2)+(D2.W)	; D4 <-- valeur .B	JUMP'	20$14$:	LOAD.W	D4,(A2)+(D2.W)	; D4 <-- valeur .W	JUMP'	20$16$:	LOAD.L	D4,(A2)+(D2.W)	; D4 <-- valeur .L;	JUMP'	20$20$:	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,A3	CALL	PUTANUM		; OBUFIT <-- nombre	CLR.B	(A4)	JUMP	EXIT$50$:				; gencar =>	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,A3	LOAD.B	D3,(A2)+(D2.W)+0 ; D3 <-- fonte	COMP.B	D3,#'*	JUMP,EQ 60$	LOAD.B	(A4+),D3	LOAD.B	D3,(A2)+(D2.W)+1 ; D3 <-- style	LOAD.B	D4,#'P	TCLR.L	D3:#7	JUMP',BC 54$	LOAD.B	D4,#'F54$:	LOAD.B	(A4+),D3	LOAD.B	(A4+),D4	CLR.L	D4	LOAD.B	D4,(A2)+(D2.W)+2 ; D4 <-- taille	DIV.WU	D4,#10	ADD.B	D4,#'0	LOAD.B	(A4+),D4	SWAP.W	D4	ADD.B	D4,#'0	LOAD.B	(A4+),D4	CLR.B	(A4)	JUMP	EXIT$60$:	LOAD.B	(A4+),#'*	CLR.B	(A4)	JUMP	EXIT$70$:				; texte =>	LOAD.W	D4,(A4)+4	SUB.W	D4,#2		; D4 <-- lg max	ADD.W	A2,D2	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,A372$:	DEC.W	D4	JUMP',NS 74$	LOAD.B	(A4+),(A2+)	; OBUFIT <-- texte	JUMP,NE 72$	DEC.L	A474$:	CLR.B	(A4)EXIT$:	POPM.L	D2..D4,A2	RET;--------\\; DBHDPUT >;--------/; Met  jour un paramtre dit.; in	D2.W	rang (0..n);	A3.L	^ligne;	D5.L	canal DBOX; out	D7.W	erreur; mod	D7.WDBHDPUT:	PUSHM.L	D2..D5,A2..A4	LOAD.L	A4,#R16"TDBHEAD	MUL.WU	D2,#12	ADD.L	A4,D2		; A4 <-- ^dans TDBHEAD	LOAD.L	A2,#(A6)+OBUHEAD	LOAD.W	D2,(A4)+2	; D2 <-- OBX...	CLR.L	D4	COMP.W	(A4)+10,#1	JUMP,EQ 50$	COMP.W	(A4)+10,#2	JUMP,EQ 70$	EX.L	A4,A3	CALL	GETANUM		; D4 <-- nombre	EX.L	A3,A4	LOAD.W	D7,#ERSYNT	; D7 <-- valeur hors limites	CLR.L	D3	LOAD.W	D3,(A4)+6	; D3 <-- valeur minimale	COMP.L	D4,D3	JUMP,LO EXIT$	LOAD.W	D3,(A4)+8	; D3 <-- valeur maximale	COMP.L	D4,D3	JUMP,HI EXIT$	CLR.W	D7		; D7 <-- ok	COMP.W	(A4)+4,#4	JUMP',EQ 16$	COMP.W	(A4)+4,#2	JUMP',EQ 14$	LOAD.B	(A2)+(D2.W),D4	; mj. valeur .B	JUMP'	EXIT$14$:	LOAD.W	(A2)+(D2.W),D4	; mj. valeur .W	JUMP'	EXIT$16$:	LOAD.L	(A2)+(D2.W),D4	; mj. valeur .L	JUMP'	EXIT$50$:				; gencar =>	COMP.B	(A3)+0,#'*	JUMP',EQ 60$	LIB	?SYNGC		; D3/D4/D5 <-- fonte/style/chasse	JUMP',NE EXIT$	LOAD.B	(A2)+(D2.W)+0,D3	LOAD.B	(A2)+(D2.W)+1,D4	LOAD.B	(A2)+(D2.W)+2,D5	JUMP'	EXIT$60$:	LOAD.B	(A2)+(D2.W)+0,#'*	CLR.B	(A2)+(D2.W)+1	CLR.B	(A2)+(D2.W)+2	CLR.W	D7	JUMP'	EXIT$70$:				; texte =>	ADD.W	A2,D272$:	LOAD.B	(A2+),(A3+)	; mj. texte	JUMP,NE 72$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBHDAFF >;--------/; Affiche le contenu d'une case.; in	D2.W	rang (0..n);	A3.L	^ligne;	D5.L	canal DBOX; out	-; mod	D7.WDBHDAFF:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,#R16"TDBHEAD	MUL.WU	D2,#12	ADD.L	A4,D2		; A4 <-- ^dans TDBHEAD	LOAD.W	D2,(A4)+0	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D4,#5+2		; D4 <-- longueur standard	COMP.W	(A4)+10,#2	JUMP',NE 20$	LOAD.W	D4,(A4)+4	; D4 <-- longueur du texte20$:	LOAD.L	A4,A330$:	DEC.W	D4	TEST.B	(A4+)	JUMP,NE 30$	LIB	?AFTEXT		; affiche le contenu	TEST.W	D4	JUMP',EQ EXIT$	LOAD.B	D3,#MSPACE	LIB	?AFCAR		; efface la fin	LOAD.B	D3,D4	LIB	?AFCAREXIT$:	POPM.L	D2..D4,A3,A4	RETTDBHEAD:;	.W	rang,head,B/W/L,min,max,type	.W	1!2^BDBGCLABEL,OBXSYN,2,0,3,0	.W	2!2^BDBGCLABEL,OBXPRIO,1,8,29,0	.W	3!2^BDBGCLABEL,OBXGC,4,0,0,1	.W	4!2^BDBGCLABEL,OBXSTK,4,200,1000,0	.W	5!2^BDBGCLABEL,OBXIDE,43+2,0,0,2	.W	6!2^BDBGCLABEL,OBXDIS+0,2,10,5000,0	.W	7!2^BDBGCLABEL,OBXDIS+4,2,10,5000,0	.W	8!2^BDBGCLABEL,OBXDIS+2,2,10,5000,0	.W	9!2^BDBGCLABEL,OBXDIS+6,2,10,5000,0;------------\\; DBOXINSTALL >;============/; Effectue une installation.; in	A5.L	^description unit; out	D3.W	dernire touche (F0/F1);	D7.W	erreur;	A3.L	^fichier ayant caus l'erreur; mod	D3.L, D7.W, A3.LDBOXINSTALL:	PUSHM.L	D0..D2,D4,D5,A1,A2,A4	LOAD.L	A2,#R16"TDBOX_INSTALL	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#SETDOT	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#3	SUB.W	D3,#4	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#2+17-1	LOAD.W	D3,D4	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#7	SUB.W	D4,#8	SWAP.W	D4	LIB	?DRSEG	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	LOAD.L	D0,#2^BINNLOG	LOAD.L	D1,D0	LOAD.L	A3,#R16"NLQUICK	LOAD.W	D2,#4!2^BDBGCLABEL!2^BDBGCGREY	CALL	UNITUSE	JUMP',EQ 10$	LOAD.W	D2,#4!2^BDBGCLABEL!2^BDBGCFULL	TSET.L	D0:#BINQUICK	LOAD.B	D1,#2^BINQUICK10$:	DBOX_	GETCO	LOAD.L	A3,#R16"NLMM2	LOAD.W	D2,#3!2^BDBGCLABEL!2^BDBGCGREY	CALL	UNITUSE	JUMP',EQ 11$	LOAD.W	D2,#3!2^BDBGCLABEL!2^BDBGCFULL	TSET.L	D0:#BINMM2	LOAD.B	D1,#2^BINMM211$:	DBOX_	GETCO	LOAD.L	A3,#R16"NLMM1	LOAD.W	D2,#2!2^BDBGCLABEL!2^BDBGCGREY	CALL	UNITUSE	JUMP',EQ 12$	LOAD.W	D2,#2!2^BDBGCLABEL!2^BDBGCFULL	TSET.L	D0:#BINMM1	LOAD.B	D1,#2^BINMM112$:	DBOX_	GETCO	LOAD.L	A3,#R16"NLMM0	LOAD.W	D2,#1!2^BDBGCLABEL!2^BDBGCGREY	CALL	UNITUSE	JUMP',EQ 13$	LOAD.W	D2,#1!2^BDBGCLABEL!2^BDBGCFULL	TSET.L	D0:#BINMM0	LOAD.B	D1,#2^BINMM013$:	DBOX_	GETCO	TSET.L	D1:#BINMEM	LOAD.L	D4,D1		; D4 <-- fanions	LOAD.L	A3,#(A6)+OBULOG	LOAD.B	(A3+),#'@	; propose le nom logique @...	CLR.B	(A3)	CLR.W	D220$:	LOAD.L	A3,#(A6)+OBULOG	; A3 <-- ^nom logique	TEST.W	D2	JUMP',EQ 21$	LOAD.L	A3,#(A6)+OBUNOS	; A3 <-- ^numro serveur21$:	LOAD.L	A4,A322$:	TEST.B	(A4+)	JUMP,NE 22$	DEC.L	A4		; A4 <-- ^fin de la chane	LOAD.W	D3,D2	DBOX_	MEDIT	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,A326$:	COMP.B	(A1+),#CR	JUMP,NE 26$	CLR.B	(A1)-1		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_INSTALL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ 60$	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#CR	JUMP',EQ 35$	COMP.W	D3,#UNDO	JUMP',EQ 40$	LOAD.W	D1,D3	CLR.B	D1	COMP.W	D1,#KEYDBOX	JUMP',EQ 50$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$35$:				; RETURN =>	INC.W	D2	COMP.W	D2,#2	JUMP,LO 20$	CLR.W	D2	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$50$:				; KEYDBOX =>	COMP.B	D3,#8*1	JUMP',HS 51$	TEST.L	D0:D3		; unit logique possible ?	JUMP',BS 51$		; oui => 51$	TCLR.L	D4:D3	JUMP	30$51$:	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO 52$	LOAD.L	D1,#H'000000FF52$:	AND.L	D4,D1		; D4 <-- efface les fanions de la colonne	TSET.L	D4:D3		; D4 <-- allume juste un fanion	COMP.B	D3,#BINNET	JUMP',EQ 54$	COMP.B	D3,#BINNLOG	JUMP,NE 20$	CLR.W	D2		; D2 <-- dite le nom logique	JUMP	20$54$:	LOAD.W	D2,#1		; D2 <-- dite le numro de serveur	JUMP	20$60$:				; INSTALLE =>	CALL	WAITMOUSE	; souris: met le sablier	CALL	DBOXCLOSE	; ferme la DBOX	CALL	DBINSTALL	JUMP',NE EXIT$	LOAD.W	D3,#F1		; D3 <-- touche (INSTALL)	JUMP'	EXIT$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; UNITUSE >;--------/; Vrifie si une unit logique est utilise.; in	A3.L	^nom logique; out	D7.W	EQ => utilis;		NE => pas utilis; mod	D7.WUNITUSE:	PUSHM.L	D3,D4,A1..A5	LOAD.L	A5,#(A6)+OUNIT	LOAD.L	A4,(A5)+OUNPLI	LOAD.W	D4,(A5)+OUNNBM	DEC.W	D4		; D4 <-- -1  cause du test NMO !10$:	TEST.B	(A4)		; nom utilis ?	JUMP,EQ 60$		; non => 60$				; oui =>	LOAD.W	D3,#LGNAME+1	LOAD.L	A2,A420$:	LOAD.L	A1,A322$:	DEC.W	D3	JUMP',EQ 60$	TEST.B	(A2)	JUMP',EQ 30$	COMP.B	(A2+),(A1+)	JUMP,EQ 22$25$:	DEC.W	D3	JUMP',EQ 60$	TEST.B	(A2+)		; A2 <-- cherche le nom suivant	JUMP,NE 25$	JUMP	20$30$:	TEST.B	(A1)	JUMP,NE 25$	CLR.W	D7		; D7 <-- utilis	JUMP'	EXIT$60$:	LOAD.L	A4,#(A4)+LFL	; A4 <-- ^nom suivant	DECJ.W,NMO D4,10$	LOAD.W	D7,#1		; D7 <-- pas utilisEXIT$:	POPM.L	D3,D4,A1..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBINSTALL >;----------/; Effectue une installation.; in	D4.L	fanions;	D5.L	canal DBOX; out	D7.W	erreur;	A3.L	^fichier ayant caus l'erreur; mod	D7.W, A3.LDBINSTALL:	PUSHM.L	D0,D3,D4,A2,A4	LOAD.L	A3,#R16"NLMM0	; A3 <-- ^nom logique	TEST.L	D4:#BINMM0	JUMP',BS 10$	LOAD.L	A3,#R16"NLMM1	TEST.L	D4:#BINMM1	JUMP',BS 10$	LOAD.L	A3,#R16"NLMM2	TEST.L	D4:#BINMM2	JUMP',BS 10$	LOAD.L	A3,#R16"NLQUICK	TEST.L	D4:#BINQUICK	JUMP',BS 10$	LOAD.L	A3,#(A6)+OBULOG10$:	TEST.L	D4:#BINNET	JUMP,BS 50$; Effectue une installation d'une unit de type mmoire de masse.	LOAD.L	A4,#R16"NPFLO0	; A4 <-- nom physique	TEST.L	D4:#BINFLO0	JUMP',BS 30$	LOAD.L	A4,#R16"NPFLO1	TEST.L	D4:#BINFLO1	JUMP',BS 30$	LOAD.L	A4,#R16"NPSCSI0	TEST.L	D4:#BINSCSI0	JUMP',BS 30$	LOAD.L	A4,#R16"NPSCSI1	TEST.L	D4:#BINSCSI1	JUMP',BS 30$	LOAD.L	A4,#R16"NPSCSI2	TEST.L	D4:#BINSCSI2	JUMP',BS 30$	LOAD.L	A4,#R16"NPSCSI3	TEST.L	D4:#BINSCSI3	JUMP',BS 30$	LOAD.L	A4,#R16"NPWIN	TEST.L	D4:#BINWIN	JUMP',BS 30$	LOAD.L	A4,#R16"NPMEM30$:	LOAD.L	A2,#0		; A2 <-- pas de paramtres	CLR.W	D3		; D3 <-- global	LOAD.L	D0,#FOS?INSTALL	CALL	ERCALL2		; installe le driver	JUMP,NE EXIT$	TEST.L	D4:#BINMEM	; installe $MEM ?	JUMP,BC EXIT$		; non => EXIT$				; oui =>	LOAD.W	D4,#1		; D4 <-- h=1	FOS	?FORMAT		; format encore la mmoire virtuelle !	JUMP	EXIT$; Effectue une assignation pour le rseau.50$:	LOAD.L	A4,#R16"NPZ	; A4 <-- nom physique	PUSH.L	A3	LOAD.L	A3,#0		; A3 <-- pas de nom logique	LOAD.L	A2,A3		; A2 <-- pas de paramtres	CLR.W	D3		; D3 <-- global	LOAD.L	D0,#FOS?INSTALL	CALL	ERCALL		; installe ventuellement le driver rseau	POP.L	A3	JUMP',EQ 60$	COMP.W	D7,#ERUUSE	; driver dj install ?	JUMP',EQ 60$		; oui => 60$	COMP.W	D7,#ERNDEV	JUMP',EQ 60$	LOAD.L	A3,A4		; A3 <-- ^nom physique ($NANET, etc.)	JUMP	EXIT$60$:	LOAD.L	A2,#(A6)+OBUDIS	LOAD.B	(A2+),#'@	; OBUDIS <-- @	INC.L	A4		; A4 <-- saute le $62$:	LOAD.B	(A2+),(A4+)	; OBUDIS <-- NANET	JUMP,NE 62$	LOAD.B	(A2)-1,#'-	; OBUDIS <-- -	LOAD.L	A4,#(A6)+OBUNOS64$:	LOAD.B	(A2+),(A4+)	; OBUDIS <-- 123	JUMP,NE 64$	LOAD.B	(A2)-1,#':	; OBUDIS <-- :	CLR.B	(A2)	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^nom physique @NANET-123:	CLR.W	D3		; D3 <-- global	FOS	?ASSIGN		; assigneEXIT$:	POPM.L	D0,D3,D4,A2,A4	TEST.W	D7		; retour EQ/NE	RETNLMM0:	.ASCIZ	"#MM0:"		; noms logiquesNLMM1:	.ASCIZ	"#MM1:"NLMM2:	.ASCIZ	"#MM2:"NLQUICK:.ASCIZ	"#QUICK:"NPFLO0:	.ASCIZ	"$FLO_0"	; noms physiquesNPFLO1:	.ASCIZ	"$FLO_1"NPSCSI0:.ASCIZ	"$SCSI_0"NPSCSI1:.ASCIZ	"$SCSI_1"NPSCSI2:.ASCIZ	"$SCSI_2"NPSCSI3:.ASCIZ	"$SCSI_3"NPWIN:	.ASCIZ	"$WIN_0"NPMEM:	.ASCIZ	"$MEM"NPZ:	.ASCIZ	"$Z"	.EVEN;-----------\\; DBOXFORMAT >;===========/; Demande s'il faut formater l'unit.; in	A3.L	^nom de l'unit; out	D3.W	dernire touche (F0/F1);	D7.W	erreur; mod	D3.L, D7.WDBOXFORMAT:	PUSHM.L	D0..D2,D4,D5,A1..A5	LOAD.L	A4,#(A6)+OBUFIS10$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- nom de l'unit	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBUFIS	CLR.W	D3		; D3 <-- global	FOS	?VASSIGN	; A4 <-- ^nom physique	JUMP,NE EXIT$	LOAD.W	D7,#ERSFORM	; D7 <-- type de driver incorrect	COMP.B	(A4)+0,#'$	JUMP,NE EXIT$	COMP.B	(A4)+1,#'F	; $FLO ?	JUMP,NE EXIT$	LOAD.L	A2,#R16"TDBOX_FORMAT	LOAD.L	D4,#B'11	; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,A3	CLR.B	(A3)		; donne toujours un nom vide !20$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,A324$:	COMP.B	(A1+),#CR	JUMP,NE 24$	CLR.B	(A1)-1		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_FORMAT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ 60$	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP,EQ 40$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$60$:				; D'ACCORD =>	TEST.L	D4		; qq chose  faire ?	JUMP,EQ 30$		; non => 30$;;?	TEST.L	D4:#1		; formatage software ?;;?	JUMP',BC 62$		; non => 62$;;?	TEST.B	(A3)		; nom de la disquette existe ?;;?	JUMP,EQ 30$		; non => 30$62$:				; oui =>	CALL	WAITMOUSE	; souris: met le sablier	CALL	DBOXCLOSE	; ferme la DBOX	LOAD.W	D1,#DBOX_OPWAIT	LOAD.W	D2,#2^BDBEXTEND	DBOX_	EXTEND		; affiche "attendez un instant ..."	JUMP,NE EXIT$	LOAD.L	A3,#(A6)+OBUFIS	TEST.L	D4:#0		; formatage physique ?	JUMP',BC 70$		; non => 70$				; oui =>	CALL	PFORMAT		; format physique de l'unit ...	JUMP,NE 79$70$:	TEST.L	D4:#1		; formatage software ?	JUMP,BC 79$		; non => 79$				; oui =>	LOAD.L	A2,#(A6)+OBUFIT	; A2 <-- ^nom de la disquette	LOAD.W	D4,#HACHE	; D4 <-- valeur de hachage standard	LOAD.L	A5,#R16"00$	; A5 <-- ^nom du dossier systme	LOAD.L	D3,#2^BFRLIST!2^BFRNAME!2^BFRSYS	LOAD.L	D0,#FOS?NFORMAT	CALL	ERCALL2		; format software de l'unit ...	JUMP,NE 79$	LOAD.L	A4,A372$:	TEST.B	(A4+)	JUMP,NE 72$	DEC.L	A4	LOAD.L	A2,#R16"NDVIDE73$:	LOAD.B	(A4+),(A2+)	JUMP,NE 73$	LOAD.W	D3,#1		; D3 <-- valeur de hachage minimale	CLR.L	D4		; D4 <-- lg max	FOS	?CDIR		; crer le dossier vide "DOSSIER:"	JUMP,NE 79$	LOAD.L	A4,A375$:	TEST.B	(A4+)	JUMP,NE 75$	LOAD.B	(A4)-2,#'.	LOAD.B	(A4)-1,#'D	LOAD.B	(A4)+0,#'I	LOAD.B	(A4)+1,#'R	CLR.B	(A4)+2	LOAD.L	D3,#2^BATTM!2^BATTS!2^BATTG!2^BATTA!2^BATTZ!2^BATTP!2^BATTL	FOS	?CHATR		; enlve les attributs "R", "W" et "C"79$:	PUSH.W	D7	LOAD.W	D1,#DBOX_CLWAIT	LOAD.W	D2,#2^BDBEXTEND	DBOX_	EXTEND		; enlve "attendez un instant ..."	POP.W	D7	JUMP'	EXIT$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET00$:	.ASCIZ	""		; dossier systme	.EVEN;---------\\; DBOXNAME >;=========/; Demande le nom d'un disque.; in	A3.L	^nom de l'unit; out	D3.W	dernire touche (F0/F1);	D7.W	erreur; mod	D3.L, D7.WDBOXNAME:	PUSHM.L	D0..D2,D4,D5,A1..A5	LOAD.L	A4,#(A6)+OBUFIS05$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- nom de l'unit	JUMP,NE 05$	LOAD.L	A3,#(A6)+OBUFIS	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D0,#FOS?INFODISK	CALL	ERCALL		; OBUHEAD <-- informations du disque	JUMP,NE EXIT$	LOAD.L	A2,#R16"TDBOX_NAME	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUHEAD+OBK0SYS	LIB	?AFTEXT		; affiche le dossier systme	POP.L	D4	CLR.W	D2		; D2 <-- rang initial20$:	LOAD.L	A3,#(A6)+OBUHEAD+OBK0NLO	TEST.W	D2	JUMP',EQ 21$	LOAD.L	A3,#(A6)+OBUHEAD+OBK0SYS21$:	LOAD.L	A4,A322$:	TEST.B	(A4+)	JUMP,NE 22$	DEC.L	A4		; A4 <-- ^fin du nom25$:	LOAD.W	D3,D2	DBOX_	MEDIT	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,A327$:	COMP.B	(A1+),#CR	JUMP,NE 27$	CLR.B	(A1)-1		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_NAME	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ 60$	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP',EQ 40$	COMP.W	D3,#CR	JUMP',EQ 55$	COMP.W	D3,#KEYDBOX+0	JUMP',EQ 50$	COMP.W	D3,#KEYDBOX+1	JUMP',EQ 50$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	25$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	25$50$:				; KEYDBOX =>	LOAD.W	D2,D3	AND.W	D2,#H'FF	; D2 <-- nouveau rang	JUMP	20$55$:				; RETURN =>	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,#2	JUMP,LO 20$	CLR.W	D2	JUMP	20$60$:				; D'ACCORD =>;;?	TEST.B	(A6)+OBUHEAD+OBK0NLO ; nom de la disquette existe ?;;?	JUMP,EQ 30$		; non => 30$				; oui =>	CALL	WAITMOUSE	; souris: met le sablier	CALL	DBOXCLOSE	; ferme la DBOX	LOAD.L	A3,#(A6)+OBUHEAD+OBK0SYS	TEST.B	(A3)	JUMP',EQ 64$63$:	TEST.B	(A3+)	JUMP,NE 63$	COMP.B	(A3)-2,#':	; nom du dossier termin par ":" ?	JUMP',EQ 64$		; oui => 64$	LOAD.B	(A3)-1,#':	CLR.B	(A3)64$:	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nom de l'unit	LOAD.L	A5,#(A6)+OBUHEAD+OBK0SYS	LOAD.L	A2,#(A6)+OBUHEAD+OBK0NLO	LOAD.L	D3,#2^BFRSYS!2^BFRNAME	LOAD.L	D0,#FOS?NFORMAT	CALL	ERCALL2		; met  jour le disque	JUMP'	EXIT$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXDISK >;=========/; Donne quelques informations sur une unit physique.; in	A3.L	^nom de l'unit; out	D7.W	erreur; mod	D7.WDBOXDISK:	PUSHM.L	D0..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_DISK	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	CALL	WAITMOUSE	; souris: met le sablier	CLR.W	D3		; D3 <-- global	FOS	?VASSIGN	; A4 <-- ^nom phsique	JUMP,NE 80$	PUSHM.L	A3,A4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche le nom logique	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le nom physique	POPM.L	A3,A4	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D0,#FOS?INFODISK	CALL	ERCALL		; OBUHEAD <-- informations du disque	JUMP',NE 11$	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A4)+OBK0NLO	LIB	?AFTEXT		; affiche le nom du disque	LOAD.W	D2,#4!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A4)+OBK0SYS	LIB	?AFTEXT		; affiche le dossier systme11$:	POPM.L	A3,A4	COMP.B	(A4),#'@	; nom physique rseau ?	JUMP',EQ 15$		; oui => 15$				; non =>	PUSH.L	A4	LOAD.L	D0,#FOS?GETUNIT	CALL	ERCALL		; D4 <-- info et A4 <-- ^bitmap	POP.L	A4	JUMP,NE 80$	LOAD.L	D0,D4	LOAD.W	D2,#5!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	TEST.L	D0:#0	JUMP',BS 13$	LIB	?AFTIM	.ASCIZ	"lecture et criture"	.EVEN	JUMP'	18$13$:	LIB	?AFTIM	.ASCIZ	"<AFINV> lecture seulement <AFDIR>"	.EVEN	JUMP'	18$15$:	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO		; grise la ligne "Mode:"18$:	LOAD.L	D0,#FOS?DISK	CALL	ERCALL	JUMP,NE 80$	LOAD.L	D0,D3		; D0 <-- reste	LOAD.L	D1,D4		; D1 <-- utilis	LOAD.W	D2,#6!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,D0		; D4 <-- reste en blocs	SL.L	D4,#8		; D4 <-- reste en bytes	LOAD.B	D3,#10		; D3 <-- 10 digits au maximum	LOAD.B	D2,#2^BAFDSP	; D2 <-- compact + '	LIB	?AFDEC		; affiche en dcimal	LOAD.W	D2,#7!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,D1		; D4 <-- utilis en blocs	SL.L	D4,#8		; D4 <-- utilis en bytes	LOAD.B	D3,#10		; D3 <-- 10 digits au maximum	LOAD.B	D2,#2^BAFDSP	; D2 <-- compact + '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	" ou "	.EVEN	CALL	CALCPOURCENT	; D4 <-- 0..100	LOAD.B	D3,#3		; D3 <-- 3 digits au maximum	LOAD.B	D2,#2^BAFDCM	; D2 <-- compact sans '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	"%"	.EVEN	CALL	NORMMOUSE	; souris: enlve le sablier20$:	CLR.L	D4		; D4 <-- fanions	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_DISK	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP',EQ 80$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:				; VU =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D0..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXSTATUS >;===========/; Modifie quelques informations gnrales sur la machine.; in	-; out	D7.W	erreur; mod	D7.WDBOXSTATUS:	PUSHM.L	D0..D5,A1..A5	FOS	?OPINFO		; A4 <-- ^contenu de SYS_INFO	LOAD.L	D3,(A4)+OINSTA	; D3 <-- informations pour START	LOAD.B	D2,(A4)+OINVOL	; D2 <-- volume h-p	CLR.W	D4		; D4 <-- pas de mise  jour	FOS	?CLINFO	TEST.L	D3	JUMP',NE INIT2$	LOAD.L	D3,#2^BINFK12!2^BINFK23INIT2$:	TEST.L	D3:#BINFS0	JUMP',BS INIT4$;	TEST.L	D3:#BINFS5;	JUMP',BS INIT4$	TEST.L	D3:#BINFS15	JUMP',BS INIT4$	TEST.L	D3:#BINFS60	JUMP',BS INIT4$	TSET.L	D3:#BINFS5INIT4$:	TEST.L	D3:#BINFMD0	JUMP',BS INIT6$;	TEST.L	D3:#BINFMD1;	JUMP',BS INIT6$	TEST.L	D3:#BINFMD2	JUMP',BS INIT6$	TSET.L	D3:#BINFMD1INIT6$:	TEST.L	D3:#BINFMA0	JUMP',BS INIT7$;	TEST.L	D3:#BINFMA1;	JUMP',BS INIT7$	TEST.L	D3:#BINFMA2	JUMP',BS INIT7$	TSET.L	D3:#BINFMA1INIT7$:	PUSH.L	D2	LOAD.L	A2,#R16"TDBOX_STATUS	LOAD.L	D4,D3		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	POPM.L	D2	JUMP,NE	EXIT$	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COUL$		; oui => COUL$	PUSHM.L	D2,D4	LOAD.W	D2,#F2!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	POPM.L	D2,D4COUL$:	COMP.B	(A6)+OMACHINE,#SMAKY300	JUMP',EQ LOOP$	PUSHM.L	D2,D4	LOAD.W	D2,#F5!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	POPM.L	D2,D4LOOP$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_STATUS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP',EQ ECR$	COMP.W	D3,#F2	JUMP',EQ COL$	COMP.W	D3,#F3	JUMP',EQ CLA$	COMP.W	D3,#F4	JUMP',EQ SOU$	COMP.W	D3,#F5	JUMP',EQ HP$	COMP.W	D3,#F0	JUMP,EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ECR$:	CALL	DBOXCLOSE	; ferme la DBOX	CALL	DBOXSTATEC	; choix pour l'cran ...	JUMP'	MAJ0$COL$:	CALL	DBOXCLOSE	; ferme la DBOX	CALL	DBOXSTATCO	; modifie les couleurs ...	JUMP	EXIT$CLA$:	CALL	DBOXCLOSE	; ferme la DBOX	CALL	DBOXSTATCL	; choix pour le clavier ...	JUMP'	MAJ0$SOU$:	CALL	DBOXCLOSE	; ferme la DBOX	CALL	DBOXSTATSO	; choix pour la souris ...	JUMP'	MAJ0$HP$:	COMP.B	(A6)+OMACHINE,#SMAKY300	JUMP,NE BIP$	CALL	DBOXCLOSE	; ferme la DBOX	CALL	DBOXSTATHP	; choix pour le haut-parleur ...;	JUMP'	MAJ0$MAJ0$:	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE MAJ2$MAJ$:	CALL	WAITMOUSE	; souris: met le sablier	FOS	?OPINFO		; A4 <-- ^contenu de SYS_INFO	LOAD.L	(A4)+OINSTA,D4	LOAD.B	(A4)+OINVOL,D2	LOAD.W	D4,#1		; D4 <-- mise  jour	LOAD.L	D0,#FOS?CLINFO	CALL	ERCALLMAJ2$:	CALL	MAJSTATUS	; met  jour les informations	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D0..D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; MAJSTATUS >;==========/; Met  jour diffrents priphriques en fonction des informations; de START dans 100_INFO.; in	-; out	-; mod	D7.WMAJSTATUS:	PUSHM.L	D0..D4,A4	FOS	?OPINFO		; A4 <-- ^contenu de SYS_INFO	LOAD.L	D0,(A4)+OINSTA	; D0 <-- informations pour START	LOAD.B	D2,(A4)+OINVOL	; D2 <-- volume	LOAD.L	D1,D0	TCLR.L	D1:#BINFLRD	; D1 <-- explore partout	LOAD.L	D3,(A6)+OSWITCH	TEST.L	D3:#('D-'A)	; START/D ?	JUMP',BC LIST$		; non => LIST$	TSET.L	D1:#BINFLRD	; D1 <-- exploration rduiteLIST$:	CLR.W	D4		; D4 <-- pas de mise  jour	COMP.L	D1,D0		; informations pour START changes ?	JUMP',EQ MAJ$		; non => MAJ$	INC.W	D4		; D4 <-- mise  jour	LOAD.L	(A4)+OINSTA,D1MAJ$:	LOAD.L	D0,#FOS?CLINFO	CALL	ERCALL	LOAD.W	(A6)+OSLDU,#60*5	TCLR.L	D1:#BINFLRD	TEST.L	D1	JUMP',EQ EXIT$	LOAD.L	D4,D1	CALL	DBSTECMAJ	; met  jour l'cran	CALL	DBSTCLMAJ	; met  jour le clavier	CALL	DBSTSOMAJ	; met  jour la souris	CALL	DBSTHPMAJ1	; met  jour le haut-parleur	CALL	DBSTHPMAJ2	; met  jour le haut-parleurEXIT$:	POPM.L	D0..D4,A4	RET;-----------\\; DBOXSTATEC >;===========/; Modifie quelques informations gnrales sur l'cran.; in	D4.L	fanions; out	D4.L	fanions;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXSTATEC:	PUSHM.L	D1,D2,D5,A1..A5	LOAD.L	A2,#R16"TDBOX_STATEC	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$LOOP$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_STATEC	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ MODIF$	COMP.W	D3,#F0	JUMP,EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$MODIF$:				; MODIFIE =>CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBSTECMAJ >;----------/; Met  jour l'cran en fonction des fanions.; in	D4.L	fanions; out	-; mod	D7.WDBSTECMAJ:	PUSH.W	D3	CLR.W	D3	TEST.L	D4:#BINFS0	JUMP',BS SLEEP$	LOAD.W	D3,#60*15	TEST.L	D4:#BINFS15	JUMP',BS SLEEP$	LOAD.W	D3,#60*60	TEST.L	D4:#BINFS60	JUMP',BS SLEEP$	LOAD.W	D3,#60*5SLEEP$:	LOAD.W	(A6)+OSLDU,D3	POP.W	D3	RET;-----------\\; DBOXSTATCO >;===========/; Modifie quelques couleurs.; in	-; out	D7.W	erreur; mod	D7.WDBOXSTATCO:	PUSHM.L	D3..D5,A3..A5	CALL	DBSTECPD0	; A1 <-- ^descripteur de $DIS_0	LOAD.L	A3,#R16"NMSYS$	LOAD.L	A5,#R16"TCOUL$	LOAD.L	D5,(A1)+ODFCPR	; D5 <-- id. CRET globale	LOAD.L	D4,#2^BICMPAL!2^BTCGLOB	ICOL_	MODCRET		; modifie la CRET ...	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP',NE EXIT$	LOAD.L	(A1)+ODFCPR,D5	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-1LOOP$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP',F	OK$		; non => OK$	CALL	_ALLREFAIT	; oui => redessine toute la fentre	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3..D5,A3..A5	TEST.W	D7		; retour EQ/NE	RETNMSYS$:	.ASCIZ	"%M_%N"		; 300_6152 (par exemple)	.EVENTCOUL$:	.L	COLOR_PPCLEAR	.W	-1,-1,-1	.ASCIZE	"Gnral:    fond"	.L	COLOR_PPSET	.W	0,0,0	.B	1	.ASCIZE	"Gnral:    dessin"	.L	COLOR_PPHILI	.W	-1,-1,0	.B	1	.ASCIZE	"Gnral:    mises en vidence"	.L	COLOR_PPCMOUSE	.W	-1,-1,-1	.ASCIZE	"Gnral:    pourtour de la souris"	.L	COLOR_PPSMOUSE	.W	-1,0,0	.B	2	.ASCIZE	"Gnral:    intrieur de la souris"	.L	COLOR_MMCLEAR	.W	-1,-1,-1	.ASCIZE	"Menu:       fond"	.L	COLOR_MMSET	.W	0,0,0	.ASCIZE	"Menu:       contenu"	.L	COLOR_MMCADRE	.W	0,0,0	.ASCIZE	"Menu:       cadre"	.L	COLOR_MMSEP	.W	0,0,0	.B	2	.ASCIZE	"Menu:       sparations"	.L	COLOR_DBCLEAR	.W	-1,-1,-1	.ASCIZE	"Dialogue:   fond"	.L	COLOR_DBSET	.W	0,0,0	.ASCIZE	"Dialogue:   contenu"	.L	COLOR_DBCADRE	.W	0,0,0	.ASCIZE	"Dialogue:   cadre"	.L	COLOR_DBTITLE	.W	0,0,0	.ASCIZE	"Dialogue:   titre en haut"	.L	COLOR_DBTRAME	.W	0,0,0	.ASCIZE	"Dialogue:   trame de fond"	.L	COLOR_DBSEL	.W	-1,0,0	.ASCIZE	"Dialogue:   boutons slectionns"	.L	COLOR_DBERROR	.W	0,0,0	.ASCIZE	"Dialogue:   erreurs"	.L	COLOR_DBICOCADRE	.W	0,0,0	.ASCIZE	"Dialogue:   cadre des icnes"	.L	COLOR_DBICODESS	.W	-1,-1,-1	.B	2	.ASCIZE	"Dialogue:   dessin des icnes"	.L	COLOR_SCCLEAR	.W	-1,-1,-1	.ASCIZE	"Ascenseur:  fond"	.L	COLOR_SCSET	.W	0,0,0	.ASCIZE	"Ascenseur:  cadre et contenu"	.L	COLOR_SCOBJ	.W	0,0,0	.ASCIZE	"Ascenseur:  flches"	.L	COLOR_SCPOS	.W	-1,-1,-1	.ASCIZE	"Ascenseur:  fond de la cabine"	.L	COLOR_SCSCALE	.W	0,0,0	.B	2	.ASCIZE	"Ascenseur:  chelles"	.L	COLOR_RUCLEAR	.W	-1,-1,-1	.ASCIZE	"Rgle:      fond"	.L	COLOR_RUSET	.W	0,0,0	.ASCIZE	"Rgle:      contenu"	.L	COLOR_RULINE	.W	0,0,0	.ASCIZE	"Rgle:      graduations"	.L	COLOR_RUCAR	.W	0,0,0	.ASCIZE	"Rgle:      caractres"	.L	COLOR_RUMARK	.W	0,0,0	.B	2	.ASCIZE	"Rgle:      marques"	.L	COLOR_STEXEC	.W	-1,0,0	.B	1	.ASCIZE	"START:      slection pour excuter";;?	.L	COLOR_STSLEEP;;?	.W	-1,-1,-1;;?	.B	1;;?	.ASCIZE	"START:      si endormi (horloge)"	.L	COLOR_STCOL1	.W	0,0,0	.ASCIZE	"START:      couleur 1 (noir)"	.L	COLOR_STCOL2	.W	0,0,0	.ASCIZE	"START:      couleur 2"	.L	COLOR_STCOL3	.W	0,0,0	.ASCIZE	"START:      couleur 3"	.L	COLOR_STCOL4	.W	0,0,0	.ASCIZE	"START:      couleur 4"	.L	COLOR_STCOL5	.W	0,0,0	.ASCIZE	"START:      couleur 5"	.L	COLOR_STCOL6	.W	0,0,0	.ASCIZE	"START:      couleur 6"	.L	COLOR_STCOL7	.W	0,0,0	.ASCIZE	"START:      couleur 7"	.L	COLOR_STCOL8	.W	0,0,0	.ASCIZE	"START:      couleur 8"	.L	0;----------\\; DBSTECPD0 >;----------/; Cherche le descripteur de $DIS_0.; in	-; out	A1.L	^descripteur $DIS_0;	D7.W	erreur; mod	D7.W, A1.LDBSTECPD0:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,#R16"NPDIS$	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre $DIS_0	JUMP',NE EXIT$	LOAD.W	D3,#TYPDIS	; D3 <-- type spcial pour $DIS_0 !	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP',NE CLOSE$	LOAD.L	A1,(A4)		; A1 <-- ^descripteur de $DIS_0CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme $DIS_0	POP.W	D7EXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RETNPDIS$:	.ASCIZ	"$DIS_0"	.EVEN;-----------\\; DBOXSTATCL >;===========/; Modifie quelques informations gnrales sur le clavier.; in	D4.L	fanions; out	D4.L	fanions;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXSTATCL:	PUSHM.L	D0..D2,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_STATCL	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	CLR.B	(A4)LOOP$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_STATCL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP',EQ MODIF$	COMP.W	D3,#F0	JUMP',EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#KEYDBOX+BINFK10	JUMP',LO BIP$	COMP.W	D3,#KEYDBOX+BINFK13	JUMP',LS PREM$	COMP.W	D3,#KEYDBOX+BINFK20	JUMP',LO BIP$	COMP.W	D3,#KEYDBOX+BINFK23	JUMP',LS SUITE$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$PREM$:	AND.W	D4,#-1-(2^BINFK10!2^BINFK11!2^BINFK12!2^BINFK13)	JUMP'	MAJ$SUITE$:	AND.W	D4,#-1-(2^BINFK20!2^BINFK21!2^BINFK22!2^BINFK23)MAJ$:	TSET.L	D4:D3	CALL	DBSTCLMAJ	; met  jour le clavier	JUMP	UNDO$MODIF$:				; MODIFIE =>CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D0..D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBSTCLMAJ >;----------/; Met  jour le clavier en fonction des fanions.; in	D4.L	fanions; out	-; mod	D7.WDBSTCLMAJ:	PUSHM.L	D2..D4	LOAD.L	D2,D4	LOAD.W	D3,#20	TEST.L	D2:#BINFK13	JUMP',BS KEY1$	LOAD.W	D3,#40	TEST.L	D2:#BINFK12	JUMP',BS KEY1$	LOAD.W	D3,#80	TEST.L	D2:#BINFK11	JUMP',BS KEY1$	LOAD.W	D3,#-1KEY1$:	LOAD.W	D4,#2!2^15	TEST.L	D2:#BINFK23	JUMP',BS KEY2$	LOAD.W	D4,#6!2^15	TEST.L	D2:#BINFK22	JUMP',BS KEY2$	LOAD.W	D4,#16!2^15	TEST.L	D2:#BINFK21	JUMP',BS KEY2$	LOAD.W	D4,#255!2^15KEY2$:	LIB	?REPKEY	POPM.L	D2..D4	RET;-----------\\; DBOXSTATSO >;===========/; Modifie quelques informations gnrales sur la souris.; in	D4.L	fanions; out	D4.L	fanions;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXSTATSO:	PUSHM.L	D0..D2,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_STATSO	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$LOOP$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_STATSO	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP',EQ MODIF$	COMP.W	D3,#F0	JUMP',EQ CANCEL$	COMP.W	D3,#KEYDBOX+BINFMD0	JUMP',LO BIP$	COMP.W	D3,#KEYDBOX+BINFMD2	JUMP',LS DEPL$	COMP.W	D3,#KEYDBOX+BINFMA0	JUMP',LO BIP$	COMP.W	D3,#KEYDBOX+BINFMA2	JUMP',LS ACC$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$DEPL$:	AND.L	D4,#-1-(2^BINFMD0!2^BINFMD1!2^BINFMD2)	JUMP'	MAJ$ACC$:	AND.L	D4,#-1-(2^BINFMA0!2^BINFMA1!2^BINFMA2)MAJ$:	TSET.L	D4:D3	CALL	DBSTSOMAJ	; change la souris	JUMP	LOOP$MODIF$:				; MODIFIE =>CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D0..D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBSTSOMAJ >;----------/; Met  jour la souris en fonction des fanions.; in	D4.L	fanions; out	-; mod	D7.WDBSTSOMAJ:	PUSHM.L	D2..D4,D6,A4	LOAD.L	D2,D4	CLR.W	D3	TEST.L	D2:#BINFMD0	JUMP',BS MOUSD$	LOAD.W	D3,#2	TEST.L	D2:#BINFMD2	JUMP',BS MOUSD$	LOAD.W	D3,#1MOUSD$:	LOAD.W	D4,#H'100*10+10	TEST.L	D2:#BINFMA0	JUMP',BS MOUSA$	LOAD.W	D4,#H'100*2+4	TEST.L	D2:#BINFMA2	JUMP',BS MOUSA$	LOAD.W	D4,#H'100*5+5MOUSA$:	LIB	?GCHMOU		; D6 <-- canal de la souris 	LOAD.L	A4,#(A6)+OBUDIS+1	LOAD.B	(A4)+0,#'S	; <S>	LOAD.B	(A4)+1,D3	LOAD.B	(A4)+2,#'A	; <A>	LOAD.W	(A4)+3,D4	CLR.B	(A4)+5	LOAD.W	D3,#TYPIO	; D3 <-- type du driver souris	FOS	?COMMAND	; change la vitesse de la souris	POPM.L	D2..D4,D6,A4	RET;-----------\\; DBOXSTATHP >;===========/; Modifie quelques informations gnrales sur la souris.; in	D2.B	volume;	D4.L	fanions; out	D2.B	volume;	D4.L	fanions;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXSTATHP:	PUSHM.L	D0,D1,D5,A1..A4	LOAD.L	D0,D4		; D0 <-- fanions originaux	LOAD.W	D4,#2^0	TEST.B	D2	JUMP',EQ INIT$	SL.W	D4,#1	COMP.B	D2,#64	JUMP',LO INIT$	SL.W	D4,#1	COMP.B	D2,#128	JUMP',LO INIT$	SL.W	D4,#1	COMP.B	D2,#192	JUMP',LO INIT$	SL.W	D4,#1		; D4 <-- fanionsINIT$:	PUSH.L	D2	LOAD.L	A2,#R16"TDBOX_STATHP	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	POPM.L	D2	JUMP,NE	EXIT$LOOP$:	CALL	NORMMOUSE	; souris: enlve le sablier	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_STATHP	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP',EQ MODIF$	COMP.W	D3,#F0	JUMP',EQ CANCEL$	COMP.W	D3,#KEYDBOX+BINFBSA	JUMP',EQ TESTF$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ TESTV$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$TESTV$:	CALL	DBSTHPPUT	; D2 <-- volume	CALL	DBSTHPMAJ1	; modifie le volume	LIB	?BUZZ		; p'tite exprience !	JUMP	LOOP$TESTF$:	CALL	WAITMOUSE	; souris: met le sablier	CALL	DBSTHPMAJ2	; modifie selon les fanions	LIB	?BUZZ		; p'tite exprience !	JUMP	LOOP$MODIF$:				; MODIFIE =>	CALL	DBSTHPPUT	; D2 <-- volume	LOAD.W	D4,D0		; D4 <-- fanionsCANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D0,D1,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBSTHPPUT >;----------/; in	D2.B	volume; out	D2.B	volume; mod	D2.L, D7.WDBSTHPPUT:	PUSH.W	D4	CLR.B	D2	RR.W	D4,#1	JUMP',CS EXIT$	LOAD.B	D2,#32	RR.W	D4,#1	JUMP',CS EXIT$	LOAD.B	D2,#96	RR.W	D4,#1	JUMP',CS EXIT$	LOAD.B	D2,#160	RR.W	D4,#1	JUMP',CS EXIT$	LOAD.B	D2,#224EXIT$:	POP.W	D4	RET;-----------\\; DBSTHPMAJ1 >;-----------/; Met  jour le haut-parleur en fonction du volume.; in	D2.B	volume; out	-; mod	D7.WDBSTHPMAJ1:	PUSHM.L	D3,D6,A3,A4	LOAD.L	A3,#R16"NAUDIO$	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre #AUDIO:	JUMP',NE EXIT$ 	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#'L	LOAD.B	(A4)+1,D2	CLR.B	(A4)+2	LOAD.W	D3,#TYPIO	; D3 <-- type du driver	FOS	?COMMAND	; change le volume	FOS	?CLOSE		; ferme #AUDIO:EXIT$:	POPM.L	D3,D6,A3,A4	RETNAUDIO$:.ASCIZ	"#AUDIO:"	.EVEN;-----------\\; DBSTHPMAJ2 >;-----------/; Met  jour le haut-parleur en fonction des fanions.; in	D4.L	fanions; out	-; mod	D7.WDBSTHPMAJ2:	PUSHM.L	D3,D6,A3,A4	COMP.B	(A6)+OMACHINE,#SMAKY300	JUMP',NE EXIT$	LOAD.L	A3,#R16"NSYNT$	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre #SYNTHESIZER:	JUMP',NE EXIT$ 	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#'F	LOAD.B	(A4)+1,#'+	TEST.L	D4:#BINFBSA	JUMP',BS AUDIO$	LOAD.B	(A4)+1,#'-AUDIO$:	CLR.B	(A4)+2	LOAD.W	D3,#TYPIO	; D3 <-- type du driver	FOS	?COMMAND	; utilise ou pas 300_SYNT.AUDIO	FOS	?CLOSE		; ferme #SYNTHESIZER:EXIT$:	POPM.L	D3,D6,A3,A4	RETNSYNT$:	.ASCIZ	"#SYNTHESIZER:"	.EVEN;---------\\; DBOXINFO >;=========/; Donne quelques informations gnrales sur la machine.; in	-; out	D7.W	erreur; mod	D7.WDBOXINFO:	PUSHM.L	D1..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_INFO	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	PUSH.W	D4	SR.W	D4,#8	AND.L	D4,#H'FF	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche la rvision	LOAD.B	D3,#'.	LIB	?AFCAR	POP.W	D4	AND.L	D4,#H'FF	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche la version	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	NTREL	?GETMACHINE10$:	TEST.B	(A3+)	JUMP,NE 10$	LIB	?AFTEXT		; affiche "Smaky 100"	LIB	?AFTIM	.ASCIZ	" numro "	.EVEN	AND.L	D4,#H'FFFFFF	LOAD.B	D3,#5		; D3 <-- 5 digits au maximum	LOAD.B	D2,#2^BAFDCM!2^BAFDSP ; D2 <-- compact + '	LIB	?AFDEC		; affiche en dcimal	LOAD.W	D2,#4!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	PUSH.L	D5	GESMEM	?ARGLGM		; D4 <-- total  D5 <-- user	POP.L	D5	LOAD.B	D3,#8	LOAD.B	D2,#2^BAFDSP	; D2 <-- '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	" octets"	.EVEN	LOAD.W	D2,#5!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	PUSH.L	D5	GESMEM	?ARGMEM		; D4 <-- total  D5 <-- user	LOAD.L	D1,D5	POP.L	D5	LOAD.B	D3,#8	LOAD.B	D2,#2^BAFDSP	; D2 <-- '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	" octets"	.EVEN	LOAD.W	D2,#6!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,D1	LOAD.B	D3,#8	LOAD.B	D2,#2^BAFDSP	; D2 <-- '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	" octets"	.EVEN	POP.L	D420$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_INFO	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP',EQ 80$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:				; VU =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCOMPTE >;===========/; Donne quelques informations gnrales sur une unit/dossier.; in	A5.L	^description unit; out	D7.W	erreur; mod	D7.WDBOXCOMPTE:	PUSHM.L	D0..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_COMPTE	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	A3,(A5)+OUNPLI	CLR.L	D0	CLR.L	D1	LOAD.W	D4,(A5)+OUNNBT	JUMP',EQ 12$10$:	LOAD.L	D2,(A3)+OFLLG	; D2 <-- longueur du fichier	ADD.L	D0,D2	ADD.L	D2,#256-1	CLR.B	D2		; D2 <-- arrondi au multiple de 256 suprieur	ADD.L	D2,#256		; D2 <-- compte au moins le BD !	ADD.L	D1,D2	LOAD.L	A3,#(A3)+LFL	; A3 <-- ^fichier suivant	DEC.W	D4	JUMP,NE 10$12$:	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,D0	LOAD.B	D3,#10		; D3 <-- 10 digits au maximum	LOAD.B	D2,#2^BAFDSP	; D2 <-- compact + '	LIB	?AFDEC		; affiche en dcimal	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,D1	LOAD.B	D3,#10		; D3 <-- 10 digits au maximum	LOAD.B	D2,#2^BAFDSP	; D2 <-- compact + '	LIB	?AFDEC		; affiche en dcimal20$:	CLR.L	D4		; D4 <-- fanions	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_COMPTE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ 80$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:				; VU =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D0..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXXFFILES >;============/; Demande comment transfrer un programme avec un fichier "!".; in	A1.L	^nom fichier source;	A4.L	^contenu du fichier "!"; out	A4.L	^plus loin;	D3.W	dernire touche (F0/F1);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A4.LDBOXXFFILES:	PUSHM.L	D0..D2,D5,A1..A3,A5	LOAD.L	A3,A4	LOAD.L	A5,A4	CLR.W	D7		; D7 <-- ok	LOAD.W	D3,#F1		; D3 <-- (D'ACCORD)	LOAD.L	D4,#-1		; D4 <-- tous les fanions	COMP.B	(A5),#'"	; fichier commence par "blabla"/1 ?	JUMP,NE EXIT$		; non => EXIT$	CALL	DBXFMASEL	; D4 <-- slectionne la machine courante	CALL	DBXFMAUSE	; utilise la machine selon D4.L	CALL	DBXFCONST	; construit la dbox	CLR.W	D7		; D7 <-- ok	LOAD.W	D3,#F1		; D3 <-- (D'ACCORD)	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP,NE EXIT$		; oui => EXIT$	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',NE 20$	LOAD.L	D4,#-1		; D4 <-- tous les fanions	JUMP	EXIT$20$:	COMP.W	(A6)+ODDDOP,#3	; duplique ?	JUMP,NE EXIT$		; non => EXIT$	LIB	?BUZZ		; signal qq chose de spcial	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	CALL	DBXFMAGREY	; D1 <-- boutons des machines gris	LOAD.W	D2,#2422$:	RR.L	D1,#1	JUMP',CC 24$	PUSHM.L	D2,D4	TSET.L	D2:#BDBGCLABEL	TSET.L	D2:#BDBGCGREY	DBOX_	GETCO		; grise un bouton	POPM.L	D2,D424$:	INC.W	D2	COMP.W	D2,#32	JUMP,LO 22$30$:	CLR.W	D232$:	PUSHM.L	D2,D4	TSET.L	D2:#BDBGCLABEL	TSET.L	D2:#BDBGCGREY	RR.L	D0,#1	JUMP',CS 34$	TCLR.L	D2:#BDBGCGREY	TSET.L	D2:#BDBGCFULL34$:	DBOX_	GETCO		; grise/dgrise un bouton	POPM.L	D2,D4	INC.W	D2	COMP.W	D2,#24	JUMP,LO 32$40$:	CALL	NORMMOUSE	; souris: enlve le sablier	CALL	DBOXEDIT	; attend action ...	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_XFFILES	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#F1	JUMP',EQ 70$	COMP.W	D3,#F0	JUMP',EQ 80$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ 50$45$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	40$50$:	COMP.B	D3,#24		; changement de machine ?	JUMP,LO 40$		; non => 40$				; oui =>	CALL	DBXFMAUSE	; utilise la machine selon D4.L	PUSHM.L	D4,A5	LOAD.L	A5,A3		; A5 <-- ^dbut du fichier "!"	CALL	DBXFCONST	; D0 <-- boutons  griser	POPM.L	D4,A5	LOAD.L	D3,D0	NOT.L	D3	OR.L	D3,#H'FF000000	AND.L	D4,D3		; D4 <-- relche les boutons gris	JUMP	30$70$:				; D'ACCORD =>	CALL	DBXFMAUSE	; utilise la machine selon D4.L80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	LOAD.L	A4,A5	POPM.L	D0..D2,D5,A1..A3,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBXFCONST >;----------/; Construit la dbox en fonction du fichier "!".; in	A1.L	^nom fichier source;	A5.L	^contenu du fichier "!";	D4.L	fanions pour la machine (bits 24..31); out	A5.L	^plus loin;	D4.L	fanions;	D0.L	boutons  griser (1=gris);	A2.L	^table construite; mod	D0.L, D4.L, D7.W, A2.L, A5.LDBXFCONST:	PUSHM.L	D2,D3,A3,A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	(A4+),#4*2	; buffer <-- .W  10$-TDBOX_XFFILES	CLR.W	(A4+)		; buffer <-- .W  20$-TDBOX_XFFILES	CLR.W	(A4+)		; buffer <-- .W  0	CLR.W	(A4+)		; buffer <-- .W  0	CLR.L	D0		; D0 <-- boutons  griser	OR.L	D4,#H'00FFFFFF	; D4 <-- allume tous les fanions	LOAD.L	A3,#R16"TDBOX_XFFIL1	LOAD.W	D3,#LDBOX_XFFIL1-110$:	LOAD.B	(A4+),(A3+)	; buffer <-- table 1	DECJ.W,NMO D3,10$20$:	LOAD.L	A3,A5	CALL	MAJSNFILE	; D3 <-- bits des switchs trouvs	TEST.L	D3		; switch trouv ?	JUMP,EQ 40$	LOAD.B	D2,#-122$:	INC.B	D2		; D2 <-- numro du switch	RR.L	D3,#1	JUMP,CC 22$	LOAD.B	(A4+),#ODBLABEL	LOAD.B	(A4+),D2	LOAD.L	A2,A4	LOAD.B	(A4+),#ODBSQUARE	LOAD.B	(A4+),D2	TSET.B	(A4)-1:#7	LOAD.B	(A4+),#KEYDBOX/H'100	LOAD.B	(A4+),D2	LOAD.B	(A4+),#SPACE	CALL	DBXFASCIZ	; buffer <-- texte	CALL	DBXFEXIST	; fichier existe ?	JUMP',EQ 28$		; oui => 28$	TSET.L	D0:D2		; D0 <-- bouton  griser	TCLR.L	D4:D228$:	LOAD.L	A3,A5	LOAD.B	D3,#'O	LIB	?IFSWITCH	; /O pour bouton rond ?	JUMP',NE 29$		; non => 29$	LOAD.B	(A2),#ODBLCIRCLE29$:	LOAD.L	A3,A5	LOAD.B	D3,#'E	LIB	?IFSWITCH	; /E pour teindre le switch ?	JUMP',NE 50$		; non => 50$	TCLR.L	D4:D2		; oui => clear le fanion	JUMP'	50$40$:				; texte =>	LOAD.B	(A4+),#ODBTEXT	CALL	DBXFASCIZ	; buffer <-- texte50$:				; ligne suivante =>	LOAD.B	D3,(A5)	JUMP',EQ 52$	INC.L	A5		; A5 <-- ^ligne suivante	COMP.B	D3,#CR	JUMP,NE 50$	COMP.B	(A5),#'"	; encore une option ?	JUMP,EQ 20$		; oui => 20$52$:	LOAD.L	A3,#R16"TDBOX_XFFIL2	LOAD.W	D3,#LDBOX_XFFIL2-170$:	LOAD.B	(A4+),(A3+)	; buffer <-- table 2	DECJ.W,NMO D3,70$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	D3,A4	SUB.L	D3,A3	LOAD.W	(A3)+2,D3	; buffer <-- .W  20$-TDBOX_XFFILES	LOAD.L	A3,#R16"TDBOX_XFFIL3	LOAD.W	D3,#LDBOX_XFFIL3-172$:	LOAD.B	(A4+),(A3+)	; buffer <-- table 3	DECJ.W,NMO D3,72$	LOAD.L	A2,#(A6)+OBUDIS	; A2 <-- ^table dbox construite (pfff..)	POPM.L	D2,D3,A3,A4	RET;----------\\; DBXFASCIZ >;----------/; Met un texte entre guillemets dans la dbox.; in	A5.L	^texte entre guillemets;	A4.L	^buffer; out	A5.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A4.L, A5.LDBXFASCIZ:	PUSHM.L	D3,D4,A3	INC.L	A5		; A5 <-- saute le "20$:	LOAD.B	D3,(A5+)	JUMP',EQ 50$	COMP.B	D3,#CR	JUMP',EQ 50$	COMP.B	D3,#'"	JUMP',EQ 50$	COMP.B	D3,#'<	JUMP',EQ 30$	LOAD.B	(A4+),D3	; buffer <-- texte	JUMP	20$30$:	LOAD.B	D3,(A5+)	JUMP',EQ 50$	COMP.B	D3,#CR	JUMP',EQ 50$	COMP.B	D3,#'"	JUMP',EQ 50$	COMP.B	D3,#'>	JUMP,NE 30$	JUMP	20$50$:	CLR.B	(A4+)	LOAD.B	(A4+),#ODBCR	LOAD.L	A3,A560$:	LOAD.B	D3,(A3+)	JUMP',EQ EXIT$	COMP.B	D3,#CR	JUMP,NE 60$	COMP.B	(A3+),#'"	JUMP',NE EXIT$	COMP.B	(A3+),#'<	JUMP',NE EXIT$	COMP.B	(A3+),#'T	JUMP',NE EXIT$	COMP.B	(A3+),#'A	JUMP',NE EXIT$	COMP.B	(A3+),#'B	JUMP',NE EXIT$	COMP.B	(A3+),#SPACE	JUMP',NE EXIT$	EX.L	A4,A3	CALL	GETANUM		; D4 <-- nombre	EX.L	A3,A4	LOAD.B	(A4)-1,#ODBTABX	LOAD.B	(A4+),D4EXIT$:	POPM.L	D3,D4,A3	RET;----------\\; DBXFEXIST >;----------/; Regarde si tous les fichiers existent dans la liste "!".; in	D2.B	numro du switch;	A1.L	^nom fichier source;	A5.L	^contenu du fichier "!"; out	D7.W	EQ --> fichier existe;		NE --> fichier n'existe pas; mod	D7.WDBXFEXIST:	PUSHM.L	D3,A2..A5	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,A110$:	LOAD.B	(A3+),(A4+)	; OBUFIT <-- nom "REP:SYSTEM.CODE"	JUMP,NE 10$20$:	CLR.W	D7		; D7 <-- fichier existe	LOAD.B	D3,(A5+)	; A5 <-- ^ligne suivante	JUMP,EQ EXIT$	COMP.B	D3,#CR	JUMP,NE 20$	COMP.B	(A5),#'"	; encore des questions ?	JUMP,EQ 20$		; oui => 20$	LOAD.L	A3,A5	CALL	MAJSNFILE	; D3 <-- switchs trouvs	TCLR.L	D3:D2	JUMP,BC 20$	TEST.L	D3		; d'autres switchs ?	JUMP,NE 20$		; oui => 20$	LOAD.B	D3,#'N	LIB	?IFSWITCH	; switch /N ?	JUMP,EQ 20$		; oui => 20$	LOAD.B	D3,#'G	LIB	?IFSWITCH	; switch /G ?	JUMP,EQ 20$		; oui => 20$	LOAD.L	A4,A552$:	COMP.B	(A4+),#SPACE	JUMP,EQ 52$	DEC.L	A4	COMP.B	(A4),#'#	JUMP',NE 53$	COMP.B	(A4)+1,#':	; fichier "#:" dans dossier systme ?	JUMP,EQ 20$		; oui => 20$53$:	LOAD.L	A3,#(A6)+OBUFIT	CALL	SKIPREP		; A3 <-- saute unit:rps:	LOAD.L	A2,A354$:	LOAD.B	D3,(A4+)	JUMP',EQ 56$	COMP.B	D3,#CR	JUMP',EQ 56$	COMP.B	D3,#SPACE	JUMP',EQ 56$	COMP.B	D3,#'/	JUMP',EQ 56$	COMP.B	D3,#'%		; "%p" ou "%q" dans le nom ?	JUMP,EQ 20$		; oui => 20$	LOAD.B	(A3+),D3	; OBUFIT <-- nom du fichier	JUMP	54$56$:	CLR.B	(A3)	LOAD.L	A3,A2	CALL	IF100_		; fichier dit "systme" ?	JUMP',NE 70$		; non => 70$				; oui =>	COMP.B	(A3)+0,#'S	; "SMA_*" ?	JUMP',NE 60$	COMP.B	(A3)+1,#'M	JUMP',NE 60$	COMP.B	(A3)+2,#'A	JUMP',EQ 70$60$:	LOAD.B	(A3+),(A6)+OMANAME+0	LOAD.B	(A3+),(A6)+OMANAME+1	LOAD.B	(A3+),(A6)+OMANAME+270$:	LOAD.L	A3,#(A6)+OBUFIT	CALL	SEARCHFILE	; fichier existe ?	JUMP,EQ 20$		; oui => 20$EXIT$:	POPM.L	D3,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBXFMASEL >;----------/; Slectionne dans les fanions le type de la machine.; in	D4.L	fanions; out	D4.L	fanions; mod	D4.L, D7.WDBXFMASEL:	PUSHM.L	D2,D3,A3,A4	PUSH.L	D4	NTREL	?GETMACHINE	LOAD.B	(A6)+OMANAME+0,(A3+) ; OMANAME <-- nom de la machine (SYS,100,324,etc.)	LOAD.B	(A6)+OMANAME+1,(A3+)	LOAD.B	(A6)+OMANAME+2,(A3+)	POP.L	D4	LOAD.L	A4,#(A6)+OMALIST-4	LOAD.W	D2,#24	AND.L	D4,#H'00FFFFFF	; D4 <-- fanions10$:	ADD.L	A4,#4		; A4 <-- ^nom de machine suivant	TEST.B	(A4)		; machine existe ?	JUMP',EQ 50$		; non => 50$				; oui =>	LOAD.L	D3,(A4)		; D3 <-- nom de la machine	COMP.L	D3,(A6)+OMANAME	JUMP',NE 50$	TSET.L	D4:D2		; D4 <-- presse le bouton rond50$:	INC.W	D2	COMP.W	D2,#32	JUMP,LO 10$	POPM.L	D2,D3,A3,A4	RET;-----------\\; DBXFMAGREY >;-----------/; Regarde quels sont les boutons gris.; in	A1.L	^nom fichier source; out	D1.L	boutons gris (1=gris); mod	D1.L, D7.WDBXFMAGREY:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,A110$:	LOAD.B	(A3+),(A4+)	; OBUFIT <-- nom "REP:SYSTEM.CODE"	JUMP,NE 10$	LOAD.L	A4,#(A6)+OMALIST-4	CLR.L	D1		; D1 <-- pas de boutons gris	CLR.W	D220$:	ADD.L	A4,#4		; A4 <-- ^nom de machine suivant	TEST.B	(A4)		; machine existe ?	JUMP',EQ EXIT$		; non => EXIT$				; oui =>	LOAD.L	A3,#R16"FILE1$	CALL	DBXFMAFILE	; fichier "xxx_SHI.BIN" existe ?	JUMP',EQ 50$		; oui => 50$				; non =>	LOAD.L	A3,#R16"FILE2$	CALL	DBXFMAFILE	; fichier "xxx_SYSTEM.BIN" existe ?	JUMP',EQ 50$		; oui => 50$				; non =>	LOAD.L	A3,#R16"FILE3$	CALL	DBXFMAFILE	; fichier "xxx_BOOT.CLE" existe ?	JUMP',EQ 50$		; oui => 50$				; non =>	TSET.L	D1:D2		; D1 <-- un bouton gris50$:	INC.W	D2	JUMP	20$EXIT$:	POPM.L	D3,D4,A3,A4	RETFILE1$:	.ASCIZ	"_SHI.BIN"FILE2$:	.ASCIZ	"_SYSTEM.BIN"FILE3$:	.ASCIZ	"_BOOT.CLE"	.EVEN;-----------\\; DBXFMAFILE >;-----------/; Cherche si un fichier existe pour une machine donne.; in	A3.L	^nom de fichier;	A4.L	^nom de machine; out	D7.W	erreur; mod	D7.WDBXFMAFILE:	PUSHM.L	A2..A4	LOAD.L	A2,A3	LOAD.L	A3,#(A6)+OBUFIT	CALL	SKIPREP		; A3 <-- saute unit:rps:	LOAD.B	(A3+),(A4+)	LOAD.B	(A3+),(A4+)	LOAD.B	(A3+),(A4+)20$:	LOAD.B	(A3+),(A2+)	JUMP,NE 20$	LOAD.L	A3,#(A6)+OBUFIT	CALL	SEARCHFILE	; fichier "xxx_file" existe ?	POPM.L	A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBXFMAUSE >;----------/; Utilise la machine choisie par les fanions.; in	D4.L	fanions; out	-; mod	D7.WDBXFMAUSE:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OMALIST-4	RL.L	D4,#8		; quivalent  RR.L D4,#24 !	TEST.B	D4	JUMP',EQ 90$20$:	ADD.L	A4,#4		; A4 <-- ^nom de machine suivant	RR.L	D4,#1	JUMP,CC 20$	LOAD.L	(A6)+OMANAME,(A4) ; OMANAME <-- nom de la machine90$:	POPM.L	D4,A4	RET	.IF	~MPRINT;------------\\; IFDBOXPRINT >;============/; Vrifie s'il est possible de modifier les paramtres de l'imprimante.; in	-; out	EQ	possible;	NE	impossible; mod	D7.WIFDBOXPRINT:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A3,#R16"NPRINT	; A3 <-- ^nom logique	CLR.W	D3		; D3 <-- pour tous	FOS	?VASSIGN	; D4/A4 <-- type/^nom d'arrive	JUMP',NE 80$	COMP.B	(A4),#'$	; nom physique ?	JUMP',NE 80$		; non => 80$	LOAD.L	A3,#R16"00$	LOAD.L	A2,#R16"01$	LIB	?CPSTRING	; $print ?	JUMP',NC 80$		; oui => 80$	CLR.W	D7		; D7 <-- possible	JUMP'	EXIT$80$:	LOAD.W	D7,#1		; D7 <-- impossibleEXIT$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.ASCIZ	"$PRINT*"	; nom pour "$print_0"01$:	.B	0,CR,SPACE,-1	.EVEN	.ENDIF	.IF	~MPRINT;----------\\; DBOXPRINT >;==========/; Choix de l'imprimante  utiliser.; in	-; out	D7.W	erreur;	A3.L	^nom de fichier ayant caus l'erreur; mod	D7.W, A3.LDBOXPRINT:	PUSHM.L	D0..D6,A1,A2,A4	CALL	WAITMOUSE	; souris: met le sablier	CLR.L	D0		; D0 <-- tous les fanions teints	LOAD.L	A3,#R16"NPRINT	; A3 <-- ^nom logique	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre l'imprimante	JUMP',NE 05$	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^buffer (!)	LOAD.L	D4,#LGPRI0	LOAD.W	D3,#TYPPRI	; D3 <-- type de l'imprimante	FOS	?RSTATUS	; lit le status	PUSH.W	D7	FOS	?CLOSE		; ferme l'imprimante	POP.W	D7	JUMP',NE 05$	LOAD.W	D4,(A4)+OPRHTP	MUL.WU	D4,(A4)+OPRUMY+2 ; D4 <-- hauteur du papier	LOAD.B	D0,#B'010	; D0 <-- fanion "papier continu"	TEST.L	D4	JUMP',EQ 05$	LOAD.B	D0,#B'001	; D0 <-- fanion "papier accordon"	COMP.L	D4,#300*10000	; hauteur papier suprieure  300mm ?	JUMP',HS 05$		; oui => 05$	LOAD.B	D0,#B'100	; D0 <-- fanion "feuille  feuille"05$:	LOAD.L	A2,#R16"TDBOX_PRINT	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	FOS	?OPINFO		; A4 <-- ^contenu de SYS_INFO	JUMP,NE EXIT$	CLR.W	D4		; D4 <-- pas de mise  jour	FOS	?CLINFO	LOAD.L	A4,#(A4)+OINNAP	; A4 <-- ^nom imprimante dans SYS_INFO	LOAD.L	A3,#(A6)+OBUFIT+110$:	LOAD.B	(A3+),(A4+)	; OBUFIT <-- nom imprimante	JUMP,NE 10$	LOAD.L	A4,#(A3)-1	; A4 <-- ^fin du nom	LOAD.L	A3,#(A6)+OBUFIT+1 ; A3 <-- ^dbut du nom	LOAD.L	D4,D0		; D4 <-- fanions20$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,A322$:	COMP.B	(A1+),#CR	JUMP,NE 22$	CLR.B	(A1)-1		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_PRINT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP',EQ 50$	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP',EQ 40$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$50$:				; D'ACCORD =>	TEST.B	(A3)		; nom existe ?	JUMP,EQ 30$		; non => 30$				; oui =>	LOAD.L	D0,D4		; D0 <-- fanions; Vrifie si le nom de l'imprimante est bien constitu uniquement; de lettres et de chiffres.	LOAD.L	A2,A352$:	LOAD.B	D3,(A2+)	JUMP',EQ 53$	LIB	?MINMAJ	COMP.B	D3,#'0		; chiffre ?	JUMP,LO 30$		; non => 30$	COMP.B	D3,#'9	JUMP,LS 52$	COMP.B	D3,#'A		; lettre ?	JUMP,LO 30$		; non => 30$	COMP.B	D3,#'Z	JUMP,HI 30$	JUMP	52$53$:	CALL	WAITMOUSE	; souris: met le sablier	CALL	DBOXCLOSE	; ferme la DBOX; Regarde si l'on a chang le nom de l'imprimante.	FOS	?OPINFO		; A4 <-- ^contenu de SYS_INFO	JUMP,NE EXIT$	CLR.W	D4		; D4 <-- pas de mise  jour	FOS	?CLINFO	LOAD.L	A4,#(A4)+OINNAP	; A4 <-- ^nom imprimante dans SYS_INFO	LOAD.L	A3,#(A6)+OBUFIT+1	LOAD.L	A2,#R16"00$	LIB	?CPSTRING	; nouveau nom ?	JUMP,EQ 70$		; non => 70$; Dinstalle l'imprimante actuellement utilise.	LOAD.L	A3,#R16"NPRINT	; A3 <-- ^nom "#printer"	CLR.W	D3		; D3 <-- global	FOS	?VASSIGN	; A4 <-- ^nom physique	JUMP',NE 55$	LOAD.W	D7,#ERSPRIN	COMP.B	(A4),#'$	; nom physique "direct" ?	JUMP,NE EXIT$		; non => EXIT$	FOS	?DEINSTALL	; dinstalle l'imprimante actuelle; Installe la nouvelle imprimante.55$:	LOAD.L	A3,#R16"NPRINT	; A3 <-- ^nom logique	LOAD.L	A4,#(A6)+OBUFIT	; A4 <-- ^nom physique	LOAD.B	(A4),#'$	LOAD.L	A2,#0		; A2 <-- pas de paramtres	CLR.W	D3		; D3 <-- global	FOS	?INSTALL	; installe la nouvelle imprimante	JUMP,EQ 60$; En cas d'erreur d'installation, remet l'imprimante initiale.	PUSH.W	D7	FOS	?OPINFO		; A4 <-- ^contenu de SYS_INFO	JUMP,NE 59$	CLR.W	D4		; D4 <-- pas de mise  jour	FOS	?CLINFO	LOAD.L	A4,#(A4)+OINNAP	; A4 <-- ^nom imprimante dans SYS_INFO	LOAD.L	A3,#(A6)+OBUFIU+157$:	LOAD.B	(A3+),(A4+)	; OBUFIU <-- nom imprimante initiale	JUMP,NE 57$	LOAD.L	A3,#R16"NPRINT	; A3 <-- ^nom logique	LOAD.L	A4,#(A6)+OBUFIU	; A4 <-- ^nom physique	LOAD.B	(A4),#'$	LOAD.L	A2,#0		; A2 <-- pas de paramtres	CLR.W	D3		; D3 <-- global	FOS	?INSTALL	; r-installe l'imprimante initiale !	LOAD.L	A3,#0		; A3 <-- pas de nom logique	LOAD.L	A4,#(A6)+OBUFIT	; A4 <-- ^nom physique (ayant caus une erreur);	LOAD.B	(A4),#'$	LOAD.L	A2,#0		; A2 <-- pas de paramtres	CLR.W	D3		; D3 <-- global	FOS	?INSTALL	; pour afficher l'erreur correctement !!!59$:	POP.W	D7	JUMP	EXIT$; Met  jour le nouveau nom dans SYS_INFO.60$:	FOS	?OPINFO		; A4 <-- ^contenu de SYS_INFO	LOAD.L	A4,#(A4)+OINNAP	; A4 <-- ^nom imprimante dans SYS_INFO	LOAD.L	A3,#(A6)+OBUFIT+1 ; A3 <-- ^nouveau nom63$:	LOAD.B	D3,(A3+)	JUMP',EQ 65$	LIB	?MINMAJ	LOAD.B	(A4+),D3	; SYS_INFO <-- nom de l'imprimante	JUMP	63$65$:	CLR.B	(A4)		; SYS_INFO <-- terminateur	LOAD.W	D4,#1		; D4 <-- mise  jour	FOS	?CLINFO	JUMP,NE EXIT$; Envoie la commande pour le choix du papier.70$:	LOAD.L	A3,#R16"NPRINT	; A3 <-- ^nom logique	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre l'imprimante	JUMP,NE EXIT$	LOAD.L	A4,#R16"01$	TEST.L	D0:#0		; fanion "papier accordon" allum ?	JUMP',BS 73$		; oui => 73$	LOAD.L	A4,#R16"02$	TEST.L	D0:#1		; fanion "papier continu" allum ?	JUMP',BS 73$		; oui => 73$	LOAD.L	A4,#R16"03$73$:	LOAD.W	D3,#TYPPRI	; D3 <-- type de l'imprimante	FOS	?COMMAND	; choix du papier	PUSH.W	D7	FOS	?CLOSE		; ferme l'imprimante	POP.W	D7	JUMP'	EXIT$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D6,A1,A2,A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0,CR,-101$:	.ASCIZ	"*"		; papier accordon (US)02$:	.ASCIZ	"*,h=0"		; papier continu (tiquettes)03$:	.ASCIZ	"*,f=1,h=296mm"	; introducteur feuille  feuille (A4)	.EVEN	.ENDIF;----------\\; DBOXHEURE >;==========/; Modifie la date et/ou l'heure.; in	-; out	D3.W	dernire touche (F0/F1);	D7.W	erreur;	A3.L	^nom de fichier ayant caus l'erreur; mod	D3.L, D7.W, A3.LDBOXHEURE:	PUSHM.L	D0..D2,D4,D5,A1,A2,A4	LOAD.L	A2,#R16"TDBOX_HEURE	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	CALL	RDCLOCK		; lit la date et l'heure	JUMP,NE EXIT$	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUTIM	LIB	?AFTEXT		; affiche l'heure	CLR.L	D4		; D4 <-- fanions	CLR.W	D2		; D2 <-- on commence par la date20$:	LOAD.L	A3,#(A6)+OBUDAT	; A3 <-- ^heure	TEST.W	D2	JUMP',EQ 21$	LOAD.L	A3,#(A6)+OBUTIM	; A3 <-- ^date21$:	LOAD.L	A4,A322$:	TEST.B	(A4+)	JUMP,NE 22$	DEC.L	A4		; A4 <-- ^fin du texte25$:	LOAD.W	D3,D2	DBOX_	MEDIT	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,A327$:	COMP.B	(A1+),#CR	JUMP,NE 27$	CLR.B	(A1)-1		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_HEURE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ 60$	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP,EQ 40$	COMP.W	D3,#CR	JUMP,EQ 50$	COMP.W	D3,#KEYDBOX+0	JUMP,EQ 52$	COMP.W	D3,#KEYDBOX+1	JUMP,EQ 54$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	25$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	25$50$:				; RETURN =>	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,#2	JUMP,LO 20$	CLR.W	D2	JUMP	20$52$:	CLR.W	D2		; D2 <-- dite la date	JUMP	20$54$:	LOAD.W	D2,#1		; D2 <-- dite l'heure	JUMP	20$60$:				; D'ACCORD =>	TEST.B	(A6)+OBUDAT	; date existe ?	JUMP,EQ 30$		; non => 30$	TEST.B	(A6)+OBUTIM	; heure existe ?	JUMP,EQ 30$		; non => 30$	CALL	WRCLOCK		; met  jour la date et l'heure	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7	JUMP	EXIT$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDCLOCK >;--------/; Prpare la date et l'heure dans les buffers d'dition.; in	-; out	(A6)+OBUDAT	jj/mm/aa;	(A6)+OBUTIM	hh/mm/ss;	D7.W		erreur; mod	D7.WRDCLOCK:	PUSHM.L	D3,D4,A3	LIB	?RDCLOCK	; D3 <-- heure, D4 <-- date	JUMP',NE EXIT$;	LOAD.L	D3,D3		; D3 <-- heure	LOAD.L	A3,#(A6)+OBUTIM	CALL	PUTTIME		; OBUTIM <-- heure en ASCIZ	LOAD.L	D3,D4		; D3 <-- date	LOAD.L	A3,#(A6)+OBUDAT	CALL	PUTDATE		; OBUDAT <-- date en ASCIZEXIT$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRCLOCK >;--------/; Ecrit la date et l'heure prpare dans les buffers d'ditions.; in	(A6)+OBUDAT	jj/mm/aa;	(A6)+OBUTIM	hh/mm/ss; out	D7.W		erreur; mod	D7.WWRCLOCK:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,#R16"NCLOCK	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre l'horloge	JUMP,NE EXIT$	LOAD.L	A3,#(A6)+OBUDAT	CALL	GETDATE		; D3 <-- date en BCD	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#SCDATE	LOAD.B	(A4)+3,D3	; buffer <-- anne	RR.L	D3,#8	LOAD.B	(A4)+2,D3	; buffer <-- mois	RR.L	D3,#8	LOAD.B	(A4)+1,D3	; buffer <-- jour	LOAD.L	D4,#4	FOS	?WRBYTE	JUMP',NE 80$	LOAD.L	A3,#(A6)+OBUTIM	CALL	GETTIME		; D3 <-- heure en BCD	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#SCTIME	LOAD.B	(A4)+1,D3	; buffer <-- secondes	RR.L	D3,#8	LOAD.B	(A4)+2,D3	; buffer <-- minutes	RR.L	D3,#8	LOAD.B	(A4)+3,D3	; buffer <-- heures	LOAD.L	D4,#4	FOS	?WRBYTE80$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'horloge	POP.W	D7EXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXSAVE >;=========/; Demande s'il faut sauver le document dit.; in	-; out	D3.W	rponse ('O,'N,END);	D7.W	erreur; mod	D3.L, D7.WDBOXSAVE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ		; signal qq chose de spcial	LOAD.L	A2,#R16"TDBOX_SAVE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$20$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_SAVE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#'O	JUMP,EQ 80$	COMP.W	D3,#'N	JUMP,EQ 80$	COMP.W	D3,#END	JUMP,EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXDELETE >;===========/; Demande  l'utilisateur s'il faut dtruit ou non un fichier.; Ne fait pas l'appel FOS,?DELETE !; in	A3.L	^nom du fichier; out	D7.W	erreur (ERANNULE si rponse "non"); mod	D7.WDBOXDELETE:	PUSH.W	D3	CLR.W	D3	CALL	DBOXMDELETE	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXMDELETE >;============/; Demande  l'utilisateur s'il faut dtruit ou non un fichier.; Ne fait pas l'appel FOS,?DELETE !; in	A3.L	^nom du fichier;	D3.W	mode (zro/ERSDATE/ERSDAEQ); out	D7.W	erreur (ERANNULE si rponse "non"); mod	D7.WDBOXMDELETE:	PUSHM.L	D1..D4,A2..A5	LOAD.W	D2,D3		; D2 <-- mode	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"01$	; A3 <-- ^textes de description	CLR.L	D4		; D4 <-- fanions	CLR.L	D3		; D3 <-- flags	TEST.W	D2	JUMP',EQ 30$	TSET.L	D3:#BDBIOOBJ	LOAD.L	A2,#R16"TDBDELETELO	COMP.W	D2,#ERSDATE	JUMP',EQ 30$	LOAD.L	A2,#R16"TDBDELETEEQ30$:	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_DETRUIT	DBOX_	EXTEND		; dialogue ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',EQ EXIT$	LOAD.W	D7,#ERANNULE	; D7 <-- rponse "non"EXIT$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	POPM.L	D1..D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	""		; nom du logiciel	.ASCIZ	"Mfichier"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN;----------\\; DBOXARRET >;==========/; Demande comment arrter le Smaky.; in	D0.W	1 => appel depuis "mot de passe"; out	D3.W	dernire touche (F0/F1/F4);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXARRET:	PUSHM.L	D1,D2,D5,A1..A4	LIB	?BUZZ		; signal qq chose de spcial	TEST.W	D0		; appel depuis "mot de passe" ?	JUMP',EQ 10$		; non => 10$	CALL	KEYLOCK		; bloque les assignations de clavier10$:	LOAD.L	A2,#R16"TDBOX_ARRET	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	SUB.W	D3,#20	ADD.W	D4,#20+20	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,#10	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#10+10	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,#B'1111110011001	LOAD.W	D2,#16-115$:	RR.W	D1,#1	JUMP',CC 16$	PUSH.W	D2	LOAD.W	D2,#SETDOT	LIB	?DRRECT	POP.W	D216$:	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	DECJ.W,NMO D2,15$20$:	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_ARRET	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F0	JUMP',EQ 80$	COMP.W	D3,#F1	JUMP',EQ 80$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:				; REDEMARRE/ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	TEST.W	D0		; appel depuis "mot de passe" ?	JUMP',EQ 95$		; non => 95$	PUSH.W	D7	CALL	KEYUNLOCK	; dbloque les assignations de clavier	POP.W	D795$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXIFARRET >;============/; Demande s'il vraiment arrter le SMAKY.; in	D7.W	erreur; out	D3.W	rponse ('O,'N);	D7.W	erreur; mod	D3.L, D7.WDBOXIFARRET:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.W	D1,D7		; D1 <-- erreur	LIB	?BUZZ		; signal qq chose de spcial	LOAD.L	A2,#R16"TDBOX_IFARRET	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"<AFINV> "	.EVEN	LOAD.W	D7,D1	LIB	?AFERROR	; affiche l'erreur	LIB	?AFTIM	.ASCIZ	" <AFDIR>"	.EVEN20$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_IFARRET	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#'O	JUMP,EQ 80$	COMP.W	D3,#'N	JUMP,EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXEXMULTI >;============/; Demande s'il faut excuter un programme dans une nouvelle fentre.; in	A3.L	^ligne de commande;	D4.W	compteur d'excutions; out	D3.W	rponse ('O,'N);	D7.W	erreur; mod	D3.L, D7.WDBOXEXMULTI:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.W	D1,D4	LIB	?BUZZ		; signal qq chose de spcial	LOAD.L	A2,#R16"TDBOX_EXMULTI	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	CALL	SKIPREP		; A3 <-- ^aprs unit:rep:10$:	LOAD.B	D3,(A3+)	JUMP',EQ 15$	COMP.B	D3,#SPACE	JUMP',EQ 15$	COMP.B	D3,#'/	JUMP',EQ 15$	LIB	?AFCAR		; affiche le nom du programme	JUMP	10$15$:	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D4,D1	INC.W	D4	CALL	DBEMAFFN	; affiche "premire", etc.	LIB	?AFTIM	.ASCIZ	" fois"	.EVEN20$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_EXMULTI	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#'O	JUMP,EQ 80$	COMP.W	D3,#'N	JUMP,EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBEMAFFN >;---------/; Affiche un nombre de fois.; in	D4.W	nombre de fois; out	-; mod	D7.WDBEMAFFN:	PUSHM.L	D2..D4,A3	LOAD.L	A3,#R16"00$	LOAD.W	D3,D410$:	TEST.B	(A3)	JUMP',EQ 40$	DEC.W	D3	JUMP',EQ 20$12$:	TEST.B	(A3+)	JUMP,NE 12$	JUMP	10$20$:	LIB	?AFTEXT	JUMP'	EXIT$40$:	LOAD.W	D2,#2^BAFDCM	LOAD.W	D3,#5	AND.L	D4,#H'FFFF	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	"me"	.EVENEXIT$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET00$:	.ASCIZ	"premire"	.ASCIZ	"deuxime"	.ASCIZ	"troisime"	.ASCIZ	"quatrime"	.ASCIZ	"cinquime"	.ASCIZ	"sixime"	.ASCIZ	"septime"	.ASCIZ	"huitime"	.ASCIZ	"neuvime"	.ASCIZ	"dixime"	.B	0	.EVEN;-----------\\; DBOXMULDDD >;===========/; Confirmation pour une slection multiple.; in	A4.L	^nom unit destination; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXMULDDD:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_MULDDD	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4		; stack <-- fanions	LOAD.W	D3,(A6)+ODDDOP	LOAD.L	A3,#R16"01$	DEC.W	D3	JUMP',EQ 10$	LOAD.L	A3,#R16"02$	DEC.W	D3	JUMP',EQ 10$	LOAD.L	A3,#R16"03$	DEC.W	D3	JUMP',EQ 10$	LOAD.L	A3,#R16"04$10$:	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT	CLR.L	D4	LOAD.W	D4,(A6)+OSELNB	; D4 <-- nb de fichiers	LOAD.W	D3,#4		; D3 <-- nb max de digits	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" fichiers"	.EVEN	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 14$	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	" dans "	.EVEN	CALL	AFFREP		; affiche le dossier destination14$:	LIB	?AFTIM	.ASCIZ	" ?"	.EVEN	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT	POP.L	D4		; D4 <-- fanions20$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_MULDDD	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; D'ACCORD ?	JUMP',EQ 80$	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	" Dtruit "	.ASCIZ	" DETRUIT  "02$:	.ASCIZ	" Dplace "	.ASCIZ	" DEPLACE  "03$:	.ASCIZ	" Duplique "	.ASCIZ	" DUPLIQUE "04$:	.ASCIZ	" Accs pour "	.ASCIZ	"  ACCES   "	.EVEN;-----------\\; DBOXALLDDD >;===========/; Confirmation pour une slection multiple.; in	A4.L	^nom unit destination;	A5.L	^description unit source; out	D3.W	dernire touche (F1/F0);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXALLDDD:	PUSHM.L	D1,D2,D5,A1..A4	LIB	?BUZZ	LOAD.L	D4,#B'01	; D4 <-- fanions	LOAD.L	A3,#(A5)+OUNNAM	CALL	SKIPREP	COMP.B	(A3)+0,#'*	; critre = "*" ?	JUMP',NE 10$		; non => 10$	TEST.B	(A3)+1	JUMP',NE 10$	LOAD.B	D4,#B'10	; D4 <-- fanions10$:	LOAD.L	A2,#R16"TDBOX_ALLDDD	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4		; stack <-- fanions	LOAD.W	D3,(A6)+ODDDOP	LOAD.L	A3,#R16"01$	DEC.W	D3	JUMP',EQ 12$	LOAD.L	A3,#R16"02$	DEC.W	D3	JUMP',EQ 12$	LOAD.L	A3,#R16"03$12$:	PUSH.L	A3	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	LIB	?SETCURS	LIB	?AFTEXT	CLR.L	D4	LOAD.W	D4,(A6)+OSELNB	; D4 <-- nb de fichiers	LOAD.W	D3,#4		; D3 <-- nb max de digits	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" fichiers"	.EVEN	POP.L	A3	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	LIB	?SETCURS	LIB	?AFTEXT	LIB	?AFTIM	.ASCIZ	"tous les fichiers"	.EVEN	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 14$	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	" dans "	.EVEN	CALL	AFFREP		; affiche le dossier destination	LIB	?AFTIM	.ASCIZ	" ?"	.EVEN14$:	LOAD.W	D2,#4!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT	POP.L	D4		; D4 <-- fanions20$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_ALLDDD	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; D'ACCORD ?	JUMP',EQ 80$	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	"dtruit "	.ASCIZ	" DETRUIT  "02$:	.ASCIZ	"dplace "	.ASCIZ	" DEPLACE  "03$:	.ASCIZ	"duplique "	.ASCIZ	" DUPLIQUE "	.EVEN;------------\\; DBOXDUPSYSC >;============/; Demande quelle(s) imprimante(s) dupliquer avec SYSTEM.CODE; in	A1.L		^nom fichier source;	D4.L		fanions de DBOXXFFILES; out	D4.L		fanions de DBOXXFFILES;	(A6)+ONMSYSC	noms des imprimantes;	(A6)+OFASYSC.L	fanions;	(A6)+ONBSYSC.W	rang initial;	D7.W		erreur; mod	D4.L, D7.WDBOXDUPSYSC:	PUSHM.L	D0..D3,D5,D6,A1..A4	LOAD.L	D6,D4		; D6 <-- fanions de DBOXXFFILES	CLR.L	(A6)+OFASYSC	; pas de fanions	CLR.W	(A6)+ONBSYSC	CLR.W	D7		; D7 <-- ok	COMP.W	(A6)+ODDDTY,#TYPSYSC ; fichier SYSTEM.CODE ?	JUMP,NE EXIT$		; non => EXIT$	COMP.W	(A6)+ODDDOP,#3	; duplique ?	JUMP,NE EXIT$		; non => EXIT$	TEST.L	D6:#1		; transfert les imprimantes (../1) ?	JUMP,BC EXIT$		; non => EXIT$10$:	LOAD.L	A2,#R16"TDBOX_DUPSYSC	LOAD.W	D2,#2^BDBSAV	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	CALL	DBDUPSYSCAFF	; affiche les noms d'imprimantes20$:	LOAD.L	D0,D4		; D0 <-- anciens fanions	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,#R16"TKEY_DUPSYSC	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1	JUMP,EQ 70$	COMP.W	D3,#F0	JUMP,EQ 80$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ 40$	JUMP'	32$30$:				; erreur =>	LOAD.L	D4,D0		; D4 <-- reprend les anciens fanions32$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; KEYDBOX =>	AND.W	D3,#H'00FF	LOAD.L	A1,#(A6)+ONMSYSC	LOAD.W	D2,D3	MUL.WU	D2,#8	ADD.L	A1,D2	TEST.B	(A1)		; nom d'imprimante existe ?	JUMP,EQ 30$		; non => 30$	JUMP	20$70$:				; D'ACCORD =>	TEST.L	D4		; au moins un bouton carr allum ?	JUMP',NE 72$		; oui => 72$	TCLR.L	D6:#1		; ne transfert pas les imprimantes (../1) ?72$:	LOAD.L	(A6)+OFASYSC,D4	CALL	DBDUPSYSCFAN	; D4 <-- fanions pour %Q	LOAD.L	(A6)+OFBSYSC,D4	CALL	DBOXCLOSE	; ferme la DBOX	CLR.W	D7	JUMP'	EXIT$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX	LOAD.W	D7,#ERANNULEEXIT$:	LOAD.L	D4,D6		; D4 <-- fanions de DBOXXFFILES	POPM.L	D0..D3,D5,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DBDUPSYSCAFF >;-------------/; Affiche tous les noms d'imprimantes.; in	A1.L	^nom fichier source;	D5.L	canal DBOX; out	-; mod	D7.WDBDUPSYSCAFF:	PUSHM.L	D0..D4,A2..A4	LOAD.L	A4,#(A6)+ONMSYSC	CLR.W	D2		; D2 <-- rang dans DBOX	PUSH.L	A4	LOAD.L	A2,(A6)+OCAPRINT	PRINTAX_ LISTPIL	; A4 <-- ^liste des pilotes	LOAD.L	A3,A4		; A3 <-- ^liste des pilotes	POP.L	A4	TEST.W	D7	JUMP,NE 80$10$:	TEST.B	(A3)		; encore un nom d'imprimante ?	JUMP,EQ 80$		; non => 80$; Regarde si le nom de driver d'imprimante en (A3) existe sur disque.	PUSHM.L	A1..A4	LOAD.L	A2,A3	LOAD.L	A3,#(A6)+OBUFIT30$:	LOAD.B	(A3+),(A1+)	; OBUFIT <-- nom du fichier source	JUMP,NE 30$	LOAD.L	A3,#(A6)+OBUFIT	CALL	SKIPREP	LOAD.B	(A3+),#'S	LOAD.B	(A3+),#'M	LOAD.B	(A3+),#'A	LOAD.B	(A3+),#'_32$:	LOAD.B	(A3+),(A2+)	JUMP,NE 32$	DEC.L	A3	LOAD.B	(A3+),#'.	LOAD.B	(A3+),#'D	LOAD.B	(A3+),#'R	LOAD.B	(A3+),#'I	LOAD.B	(A3+),#'V	CLR.B	(A3)	LOAD.B	D0,#AFFULL	LOAD.L	A3,#(A6)+OBUFIT	CALL	SEARCHFILE	; A4 <-- ^description (OFL...)	JUMP',EQ 35$	LOAD.B	D0,#AFGREY35$:	POPM.L	A1..A4; Grise le bouton carr.	COMP.B	D0,#AFGREY	JUMP',NE 40$	PUSH.L	D2	TSET.L	D2:#BDBGCLABEL	TSET.L	D2:#BDBGCGREY	DBOX_	GETCO		; grise le bouton carr	POP.L	D2; Affiche le nom de l'imprimante dans la dbox.40$:	PUSHM.L	D2,A3	TSET.L	D2:#BDBGCLABEL	DBOX_	GETCO	LOAD.L	D3,D4	LIB	?SETCURS	LOAD.B	D3,D0	LIB	?AFCAR		; AFFULL/AFGREY	LIB	?AFTEXT		; affiche le nom de l'imprimante	LOAD.B	D3,#AFFULL	LIB	?AFCAR	POPM.L	D2,A3; Met le nom de l'imprimante dans le buffer ONMSYSC.	PUSHM.L	A3,A4	CLR.B	(A4)	COMP.B	D0,#AFGREY	; affich en gris ?	JUMP',EQ 52$		; oui => 52$ (pas de nom)50$:	LOAD.B	(A4+),(A3+)	; ONMSYSC <-- nom de l'imprimante	JUMP,NE 50$52$:	POPM.L	A3,A4	ADD.L	A4,#8		; A4 <-- ^suivant dans ONMSYSC	INC.W	D2		; D2 <-- rang suivant dans DBOX	COMP.W	D2,#24	JUMP',HS EXIT$62$:	TEST.B	(A3+)		; A3 <-- ^nom de l'imprimante suivant	JUMP,NE 62$	JUMP	10$; Efface tout le reste du buffer ONMSYSC.80$:	COMP.W	D2,#24	JUMP',HS EXIT$	CLR.B	(A4)		; ONMSYSC <-- pas de nom	ADD.L	A4,#8		; A4 <-- ^suivant dans ONMSYSC	INC.W	D2		; D2 <-- rang suivant dans DBOX	JUMP	80$EXIT$:	POPM.L	D0..D4,A2..A4	RET;-------------\\; DBDUPSYSCFAN >;-------------/; Supprime tous les fanions qui correspondent au mme nom d'imprimante; sans le numro (par exemple: LQ800 et LQ2500).; in	D4.L	fanions pour %P; out	D4.L	fanions pour %Q; mod	D4.LDBDUPSYSCFAN:	PUSHM.L	D1..D3,A2..A4	CLR.W	D210$:	TEST.L	D4:D2	JUMP,BC 80$	LOAD.L	A4,#(A6)+ONMSYSC	LOAD.W	D3,D2	MUL.WU	D3,#8	ADD.L	A4,D3		; A4 <-- ^nom cherch	CLR.W	D120$:	TEST.L	D4:D1	JUMP,BC 70$	COMP.W	D1,D2	JUMP,EQ 70$	LOAD.L	A3,#(A6)+ONMSYSC	LOAD.W	D3,D1	MUL.WU	D3,#8	ADD.L	A3,D3		; A3 <-- ^nom  comparer	LOAD.L	A2,A430$:	LOAD.B	D3,(A3+)	JUMP',EQ 34$	COMP.B	D3,#'0	JUMP',LO 32$	COMP.B	D3,#'9	JUMP',LS 34$32$:	COMP.B	D3,(A2+)	; compare les noms	JUMP,EQ 30$	JUMP'	70$34$:	LOAD.B	D3,(A2)	JUMP',EQ 36$	COMP.B	D3,#'0	JUMP',LO 70$	COMP.B	D3,#'9	JUMP',HI 70$36$:	TCLR.L	D4:D1		; D4 <-- supprime cette option70$:	INC.W	D1	COMP.W	D1,#24	JUMP,LO 20$80$:	INC.W	D2	COMP.W	D2,#24	JUMP,LO 10$	POPM.L	D1..D3,A2..A4	RET;------------\\; DBOXCREEDIR >;============/; Pose qq questions pour crer un nouveau dossier.; in	A2.L	^rpertoire destination; out	(A2)++	nom rpertoire destination;	D2.W	nb max de fichiers;	D3.W	dernire touche (F0/F1);	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXCREEDIR:	PUSHM.L	D0,D1,D4,D5,A1..A4	CLR.B	(A6)+OBUFIT	; pas de nom	LOAD.B	(A6)+OBUFIU+0,#'5	LOAD.B	(A6)+OBUFIU+1,#'0	CLR.B	(A6)+OBUFIU+2	; nombre 50 par dfaut	PUSH.L	A2	LOAD.L	A2,#R16"TDBOX_CREEDIR	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	POPM.L	A2	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUFIU	LIB	?AFTEXT		; affiche le nombre par dfaut	POP.L	D4	CLR.W	D2		; D2 <-- dite le nom20$:	LOAD.L	A3,#(A6)+OBUFIT	; A3 <-- ^dbut du nom	TEST.W	D2	JUMP',EQ 21$	LOAD.L	A3,#(A6)+OBUFIU	; A3 <-- ^dbut du nb21$:	LOAD.L	A4,A322$:	TEST.B	(A4+)	JUMP,NE 22$	DEC.L	A4		; A4 <-- ^fin du nom/nb	LOAD.W	D3,D2	DBOX_	MEDIT25$:	CALL	DBCDSYN		; grise v. (CREE)	CALL	DBOXEDIT	; attend action ...	LOAD.L	A1,A327$:	COMP.B	(A1+),#CR	JUMP,NE 27$	CLR.B	(A1)-1		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_CREEDIR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	TEST.W	D3	JUMP,EQ 25$	COMP.W	D3,#SPACE	JUMP,EQ 25$	COMP.W	D3,#F1	JUMP,EQ 50$	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP,EQ 40$	COMP.W	D3,#CR	JUMP,EQ 44$	COMP.W	D3,#KEYDBOX+0	JUMP,EQ 46$	COMP.W	D3,#KEYDBOX+1	JUMP,EQ 47$30$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	25$44$:				; RETURN =>	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,#2	JUMP,LO 20$	CLR.W	D2	JUMP	20$46$:	CLR.W	D2		; D2 <-- dite le nom	JUMP	20$47$:	LOAD.W	D2,#1		; D2 <-- dite le nb	JUMP	20$50$:				; D'ACCORD =>	CLR.W	D2		; D2 <-- dite le nom	CALL	DBCDSYN		; vrifie syntaxe du nom	TEST.L	D0:#17		; touche grise ?	JUMP,BS 30$		; oui => 30$	INC.W	D2		; D2 <-- dite le nb	TEST.B	(A6)+OBUFIU	JUMP,EQ 30$; Remplace le dernier nom de dossier en (A2) par le nom dit ici.60$:	TEST.B	(A2+)	JUMP,NE 60$	SUB.L	A2,#262$:	COMP.B	(-A2),#':	JUMP,NE 62$	INC.L	A2	LOAD.L	A3,#(A6)+OBUFIT64$:	LOAD.B	D3,(A3+)	JUMP',EQ 65$	COMP.B	D3,#':	JUMP',EQ 65$	CALL	MINMAJ	LOAD.B	(A2+),D3	JUMP	64$65$:	LOAD.B	(A2+),#':	CLR.B	(A2); Cherche le nombre maximal de fichiers.	LOAD.L	A4,#(A6)+OBUFIU	; A4 <-- ^nb	CALL	GETANUM		; D4 <-- nb	LOAD.W	D2,D4		; D2 <-- nb max de fichiers	LOAD.W	D3,#F1		; D3 <-- (D'ACCORD)	CLR.W	D7		; D7 <-- ok80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0,D1,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBCDSYN >;--------/; Grise le bouton (CREE) si la syntaxe n'est pas correcte.; in	D0.L	flags;	D2.W	rang (0,1); out	D0.L	flags; mod	D0.L, D7.WDBCDSYN:	PUSHM.L	D2..D4,A3	TEST.W	D2		; dite le nom ?	JUMP,NE EXIT$		; non => EXIT$				; oui =>	LOAD.L	A3,#(A6)+OBUFIT	; A3 <-- ^nom	TEST.B	(A3)	JUMP,EQ GREY$NOM$:	LOAD.B	D3,(A3+)	JUMP,EQ FULL$	COMP.B	D3,#SPACE	JUMP',NE NOM2$	LOAD.B	(A3)-1,#'_	; remplace espace par soulign !	JUMP	NOM$NOM2$:	COMP.B	D3,#'_	JUMP,EQ NOM$	COMP.B	D3,#':	JUMP',EQ NOM5$	COMP.B	D3,#'0	JUMP',LO GREY$	COMP.B	D3,#'9	JUMP,LS NOM$	COMP.B	D3,#'A	JUMP',LO GREY$	COMP.B	D3,#'Z	JUMP,LS NOM$	COMP.B	D3,#'a	JUMP',LO GREY$	COMP.B	D3,#'z	JUMP',HI GREY$	JUMP	NOM$NOM5$:	TEST.B	(A3)	JUMP',EQ FULL$;	JUMP'	GREY$GREY$:	TSET.L	D0:#17	JUMP',BS EXIT$	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	JUMP'	EXIT$FULL$:	TCLR.L	D0:#17	JUMP',BC EXIT$	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCOEXIT$:	POPM.L	D2..D4,A3	RET;-----------\\; IFDBOXCLEF >;===========/; Demande une clef secrte seulement si on est en mode manuel.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WIFDBOXCLEF:	LOAD.L	D3,(A6)+OFACLE	TEST.L	D3:#1		; clef permanente ?	JUMP',BC 50$		; non => 50$				; oui =>	LOAD.W	D3,#F1		; D3 <-- D'ACCORD	CLR.W	D7		; D7 <-- ok	RET50$:;	CALL	DBOXCLEF	; demande la clef ...;	RET;---------\\; DBOXCLEF >;=========/; Demande une clef secrte.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCLEF:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_CLEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OFACLE	; D4 <-- fanions	JUMP',NE 10$	LOAD.L	D4,#B'01	; D4 <-- fanions par dfaut10$:	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$15$:	LOAD.L	A3,#(A6)+OBUCLE	; A3 <-- ^dbut ligne	LOAD.L	A4,A3		; A4 <-- ^curseur (toujours  la fin)20$:	CALL	DBCLAFF		; affiche la clef	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_CLEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ 70$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP,EQ 15$	COMP.W	D3,#BS	JUMP,EQ 50$	COMP.W	D3,#DEL	JUMP,EQ 50$	LIB	?MINMAJ		; D3 <-- majuscule	COMP.W	D3,#'_	JUMP',EQ 40$	COMP.W	D3,#'0	JUMP',LO 30$	COMP.W	D3,#'9	JUMP',LS 40$	COMP.W	D3,#'A	JUMP',LO 30$	COMP.W	D3,#'Z	JUMP',LS 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; insre un caractre =>	LOAD.L	D1,A4	SUB.L	D1,A3	COMP.W	D1,#15		; ligne pleine ?	JUMP,HS 30$		; oui => 30$	LOAD.B	(A4+),D3	; OBUCLE <-- un caractre	JUMP	20$50$:				; supprime un caractre =>	COMP.L	A4,A3		; ligne vide ?	JUMP,EQ 30$		; oui => 30$	DEC.L	A4	JUMP	20$70$:				; D'ACCORD =>	TEST.L	D4:#1		; permanent ?	JUMP',BC 72$		; non => 72$	COMP.L	A4,A3		; ligne vide ?	JUMP,EQ 30$		; oui => 30$72$:	CLR.B	(A4)	LOAD.L	(A6)+OFACLE,D4	; mm. les fanions	CLR.W	(A6)+ONBCLE	; clef jamais encore utilise80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DBOXCONFCLEF >;=============/; Demande une confirmation de clef secrte.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCONFCLEF:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_CONFCLEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$15$:	LOAD.L	A3,#(A6)+OB2CLE	; A3 <-- ^dbut ligne	LOAD.L	A4,A3		; A4 <-- ^curseur (toujours  la fin)20$:	CALL	DBCLAFF		; affiche la clef	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_CONFCLEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ 70$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP,EQ 15$	COMP.W	D3,#BS	JUMP,EQ 50$	COMP.W	D3,#DEL	JUMP,EQ 50$	LIB	?MINMAJ		; D3 <-- majuscule	COMP.W	D3,#'_	JUMP',EQ 40$	COMP.W	D3,#'0	JUMP',LO 30$	COMP.W	D3,#'9	JUMP',LS 40$	COMP.W	D3,#'A	JUMP',LO 30$	COMP.W	D3,#'Z	JUMP',LS 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; insre un caractre =>	LOAD.L	D1,A4	SUB.L	D1,A3	COMP.W	D1,#15		; ligne pleine ?	JUMP,HS 30$		; oui => 30$	LOAD.B	(A4+),D3	; OB2CLE <-- un caractre	JUMP	20$50$:				; supprime un caractre =>	COMP.L	A4,A3		; ligne vide ?	JUMP,EQ 30$		; oui => 30$	DEC.L	A4	JUMP	20$70$:				; D'ACCORD =>	CLR.B	(A4)	CALL	DBOXCLOSE	; ferme la DBOX	LOAD.L	A3,#(A6)+OBUCLE	LOAD.L	A4,#(A6)+OB2CLE	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; deux clefs identiques ?	JUMP',NE 72$	INC.W	(A6)+ONBCLE	; utilise la clef	JUMP'	EXIT$72$:	LOAD.W	D7,#ERSCLEF	JUMP'	EXIT$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTERM$:	.B	0,-1	.EVEN;--------\\; DBCLAFF >;--------/; Affiche la clef, sous forme de "XXXXX" (chut, c'est secret).; in	A3.L	^dbut nom;	A4.L	^fin nom; out	-; mod	D7.WDBCLAFF:	PUSHM.L	D2..D4,A3	LOAD.B	D3,#NOCURS	LIB	?AFCAR		; enlve le curseur	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO		; D3 <-- position	ADD.W	D3,(A0)+ODFCX	LIB	?SETCURS	; met le curseur au dbut	LOAD.W	D4,#1620$:	COMP.L	A3,A4	JUMP',EQ 30$	LOAD.B	D3,(A3+);;?	COMP.L	A3,A4		; dernier caractre frapp ?;;?	JUMP',EQ 25$		; oui => 25$	LOAD.B	D3,#'X		; non => affiche un "X"25$:	LIB	?AFCAR		; affiche un caractre	DEC.W	D4	JUMP	20$30$:	LIB	?GETCURS	; D3 <-- position du curseur	LOAD.L	D2,D340$:	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin de la ligne	LOAD.L	D3,D2	LIB	?SETCURS	; met le curseur aprs le dernier caractre	LOAD.B	D3,#CURS	LIB	?AFCAR		; remet le curseur	POPM.L	D2..D4,A3	RET;---------\\; DBOXPASS >;=========/; Demande un mot de passe.; in	-; out	D3.W	dernire touche (F1/F0);	D4.L	fanions;	D7.W	erreur; mod	D4.L, D7.WDBOXPASS:	PUSHM.L	D0..D2,D5,D6,A1..A4	CALL	WAITMOUSE	; souris: met le sablier	CALL	NAMEPASS	; A3 <-- ^nom du fichier	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier du mot de passe	JUMP',NE 10$	LOAD.L	A4,#(A6)+OBUFIU	LOAD.L	D4,#16	FOS	?RDBYTE		; OBUFIU <-- mot de passe	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier mot de passe	POP.W	D7	JUMP',NE 10$	LOAD.L	D4,#B'010	; D4 <-- fanion "avec mot de passe"	JUMP'	12$10$:	LOAD.L	D4,#B'001	; D4 <-- fanion "sans mot de passe"	CLR.B	(A6)+OBUFIU	; pas de mot de passe connu12$:	LOAD.L	A2,#R16"TDBOX_PASS	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$15$:	LOAD.L	A3,#(A6)+OBUFIU	; A3 <-- ^dbut ligne	LOAD.L	A4,A316$:	TEST.B	(A4+)	JUMP,NE 16$	DEC.L	A4		; A4 <-- ^fin ligne20$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,A327$:	TEST.B	(A1)	JUMP',EQ 28$	COMP.B	(A1+),#CR	JUMP,NE 27$	CLR.B	(A1)-1		; remplace le <CR> par <0>28$:	LOAD.L	A1,#R16"TKEY_PASS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,EQ 50$	COMP.W	D3,#F0		; ANNULE ?	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP',EQ 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	20$50$:				; D'ACCORD =>	TEST.L	D4:#0	JUMP,BS 60$				; avec mot de passe =>	TEST.B	(A3)	JUMP,EQ 30$	CALL	DBOXCLOSE	; ferme la DBOX	CALL	WAITMOUSE	; souris: met le sablier	CALL	NAMEPASS	; A3 <-- ^nom du fichier	FOS	?DELETE		; dtruit le fichier	PUSHM.L	D3,D4	LOAD.L	D3,#DEFATT-2^BATTL	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier	JUMP',NE 58$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP',NE 58$	LOAD.L	A4,#(A6)+OBUFIU	LOAD.L	D4,#16	FOS	?WRBYTE		; crit le fichier	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D758$:	POPM.L	D3,D4	JUMP'	EXIT$60$:				; sans mot de passe =>	CALL	DBOXCLOSE	; ferme la DBOX	CALL	WAITMOUSE	; souris: met le sablier	CALL	NAMEPASS	; A3 <-- ^nom du fichier	FOS	?DELETE		; dtruit le fichier mot de passe	CLR.W	D7	JUMP'	EXIT$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXOKPASS >;===========/; Refuse de dmarrer si le mot de passe n'est pas correct.; in	-; out	D3.W	dernire touche (F1/F13); mod	D3.L, D7.WDBOXOKPASS:	PUSHM.L	D0..D2,D4..D6,A1..A4	CALL	NAMEPASS	; A3 <-- ^nom du fichier	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier du mot de passe	JUMP,NE 95$	LOAD.L	A4,#(A6)+OBUFIU+20	LOAD.L	D4,#16	FOS	?RDBYTE		; OBUFIU+20 <-- mot de passe	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier mot de passe	POP.W	D7	JUMP,NE 95$	CALL	KEYLOCK		; bloque les assignations de clavier	CLR.W	D0		; D0 <-- premire tentative10$:	LIB	?IFCAR		; vide le fifo du clavier	JUMP,EQ 10$	LIB	?BUZZ		; grand bruit	LOAD.L	A2,#R16"TDBOX_OKPASS	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	D3,#H'55AA55AA	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.W	D3,#GCIIY-GCIIB+20	SWAP.W	D3	LOAD.W	D3,(A0)+ODFFDX	SR.W	D3,#1	SUB.W	D3,#GCIIX/2	LIB	?SETCURS	SUB.W	D3,#10	SWAP.W	D3	SUB.W	D3,#GCIIY-GCIIB+5	SWAP.W	D3	LOAD.L	D4,#H'10000*(5+GCIIY+5)+(10+GCIIX+10)	LOAD.W	D2,#SETDOT	LOAD.W	D1,#3	LIB	?DRRECTO	LIB	?AFTIM	.B	USEGC,GCIIF,GCIIS,GCIIT	.B	ICOPASS		; affiche la jolie (mais oui) petite main	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN15$:	LOAD.L	A3,#(A6)+OBUFIU+0 ; A3 <-- ^dbut ligne	LOAD.L	A4,A3		; A4 <-- ^curseur (toujours  la fin)20$:	CALL	DBCLAFF		; affiche la clef	LOAD.W	D4,#50*30	; D4 <-- 30 secondes	NTREL	?SETTIM	CALL	DBOXEDIT	; attend une action ...	LOAD.W	D4,#-1	NTREL	?SETTIM	TEST.W	D3		; timeout ?	JUMP',NE 22$		; non => 22$	CLR.W	D0		; D0 <-- comme si premire tentative	JUMP	20$22$:	LOAD.L	A1,#R16"TKEY_OKPASS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; ENTRE ?	JUMP,EQ 60$	COMP.W	D3,#F13		; ARRET ?	JUMP,EQ 80$	COMP.W	D3,#UNDO	JUMP,EQ 15$	COMP.W	D3,#UNDO	JUMP,EQ 15$	COMP.W	D3,#BS	JUMP,EQ 50$	COMP.W	D3,#DEL	JUMP,EQ 50$	COMP.W	D3,#H'0F	JUMP',LO 30$	COMP.W	D3,#H'7F	JUMP',LO 40$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$40$:				; insre un caractre =>	LOAD.L	D1,A4	SUB.L	D1,A3	COMP.W	D1,#16		; ligne pleine ?	JUMP,HS 30$		; oui => 30$	LOAD.B	(A4+),D3	; OBUCLE <-- un caractre	JUMP	20$50$:				; supprime un caractre =>	COMP.L	A4,A3		; ligne vide ?	JUMP,EQ 30$		; oui => 30$	DEC.L	A4	JUMP	20$60$:				; ENTRE =>	COMP.L	A4,A3		; ligne vide ?	JUMP,EQ 30$		; oui => 30$	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUFIU+20	LOAD.L	A4,#(A6)+OBUFIU+0	LOAD.L	A2,#R16"00$	LIB	?CPSTRING	; mot de passe correct ?	JUMP',NC 70$		; oui => 70$				; non =>	INC.W	D0		; D0 <-- une tentative de plus	LOAD.W	D3,#BIPFAT	LIB	?BEEP		; mchant bruit (si, si)	LIB	?AFTIM	.B	PEN	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'01111110	.B	B'00111100	.B	0	.EVEN	LOAD.L	D3,#H'10000*4+4	LOAD.W	D4,(A0)+ODFFDY	SUB.W	D4,#4+4	SWAP.W	D4	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,#4+4	LOAD.W	D2,#SETDOT!PENDOT	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	ADD.W	D3,D4	NEG.W	D4	LIB	?DRSEG		; dessine une grande croix "X"	CALL	WAITMOUSE	; souris: met le sablier	LOAD.W	D4,D0	COMP.W	D4,#6	JUMP',LS 65$	LOAD.W	D4,#665$:	MUL.WU	D4,#50*2	NTREL	?DELMS		; attend 2*n secondes ...	CALL	DBOXCLOSE	; ferme la DBOX	JUMP	10$		; puis hop, redemmande70$:	LOAD.W	D3,#F180$:	CALL	DBOXCLOSE	; ferme la DBOX	CLR.W	D7		; D7 <-- okEXIT$:	PUSH.W	D7	CALL	KEYUNLOCK	; dbloque les assignations de clavier	POP.W	D795$:	POPM.L	D0..D2,D4..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0,CR,-1	.EVEN;---------\\; NAMEPASS >;---------/; Construit le nom du fichier mot de passe.; in	-; out	A3.L	^nom du fichier; mod	D7.W, A3.LNAMEPASS:	PUSH.L	D4	NTREL	?GETMACHINE	; D4/A3 <-- informations	AND.L	D4,#H'00FFFFFF	; D4 <-- numro du SMAKY	CALL	NAMEPASS0	; A3 <-- ^nom du fichier	POP.L	D4	RET;----------\\; NAMEPASS0 >;----------/; Construit le nom du fichier mot de passe.; in	D4.L	numro du SMAKY; out	A3.L	^nom du fichier; mod	D7.W, A3.LNAMEPASS0:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OBUFIT	LOAD.L	A3,#R16"01$10$:	LOAD.B	(A4+),(A3+)	; OBUFIT <-- XXXX`START_	JUMP,NE 10$	DEC.L	A4	DIV.WU	D4,#10000	SWAP.W	D4		; D4 <-- numro  4 digits (0..9999)	CALL	PUTANUM		; OBUFIT <-- numro du SMAKY	LOAD.L	A3,#R16"02$30$:	LOAD.B	(A4+),(A3+)	; OBUFIT <-- .INFO	JUMP,NE 30$	LOAD.L	A3,#(A6)+OBUFIT	; A3 <-- ^nom du fichier	POPM.L	D4,A4	RET01$:	.ASCIZ	"#:HFGDNVBCZRTJM`START_"02$:	.ASCIZ	".INFO"	.EVEN;--------\\; KEYLOCK >;========/; Bloque les assignations de clavier.; in	-; out	-; mod	D7.WKEYLOCK:	PUSH.L	D3	CLR.W	D3	LIB	?ASSKEY		; assigne le clavier  START !	LOAD.W	D3,#1	LIB	?BASSKEY	; bloque tout les ASSKEY ...	POP.L	D3	RET;----------\\; KEYUNLOCK >;==========/; Dbloque les assignations de clavier.; in	-; out	-; mod	D7.WKEYUNLOCK:	PUSH.L	D3	CLR.W	D3	LIB	?BASSKEY	; dbloque tout les ASSKEY ...	POP.L	D3	RET;-----------\\; DBOXCOPYSI >;===========/; Demande confirmation pour une copie avec un seul floppy.; in	A1.L	^nom unit source = nom unit destination; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCOPYSI:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_COPYSI	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OCPFFF	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"<AFINV> Copie intgralement "	.EVEN	LOAD.L	A3,A1	LIB	?AFTEXT		; affiche l'unit	LIB	?AFTIM	.ASCIZ	" avec un seul lecteur ? <AFDIR>"	.EVEN	POP.L	D420$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_COPYSI	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; COPIE ?	JUMP',EQ 70$	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:				; COPIE =>	LOAD.L	(A6)+OCPFFF,D480$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCOPYSX >;===========/; Demande de changer de disquette pour une copie avec un seul floppy.; in	A1.L	^nom unit source = nom unit destination;	D6.W	flags; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCOPYSX:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_COPYSX	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OCPFFF	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	TEST.L	D6:#0	JUMP',BS 10$	LIB	?AFTIM	.ASCIZ	"Mettez la disquette source (l'original)"	.EVEN	JUMP'	12$10$:	LIB	?AFTIM	.ASCIZ	"Mettez la disquette rceptrice (destination)"	.EVEN12$:	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"dans le lecteur "	.EVEN	LOAD.L	A3,A1	LIB	?AFTEXT		; affiche l'unit	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"(Il reste "	.EVEN	LOAD.W	D2,#2^BAFDCM	LOAD.W	D3,#4	LOAD.L	D4,D6	CLR.W	D4	SWAP.W	D4	LIB	?AFDEC		; affiche le nb de tranches	LIB	?AFTIM	.ASCIZ	" tranche"	.EVEN	COMP.W	D4,#1	JUMP',LS 16$	LOAD.B	D3,#'s	LIB	?AFCAR16$:	LIB	?AFTIM	.ASCIZ	"  copier ...)"	.EVEN20$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_COPYSX	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; COPIE ?	JUMP',EQ 70$	COMP.W	D3,#F0		; STOPPE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:				; COPIE =>80$:				; STOPPE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCOPYSE >;===========/; Demande de remettre la disquette originale pour une copie avec un seul floppy.; in	A1.L	^nom unit source = nom unit destination; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCOPYSE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_COPYSE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OCPFFF	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"dans le lecteur "	.EVEN	LOAD.L	A3,A1	LIB	?AFTEXT		; affiche l'unit20$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_COPYSE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; COPIE ?	JUMP',EQ 70$	COMP.W	D3,#F0		; STOPPE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:				; COPIE =>80$:				; STOPPE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCOPYFF >;===========/; Demande confirmation pour une copie floppy --> autre floppy.; in	A1.L	^nom unit source;	A2.L	^nom unit destination; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCOPYFF:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A3,A2	LOAD.L	A2,#R16"TDBOX_COPYFF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OCPFFF	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	A2,A3	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"<AFINV> Copie intgralement "	.EVEN	LOAD.L	A3,A1	CALL	SKIPREP	TEST.B	(A3)		; nom de fichier existe ?	JUMP',NE 10$		; oui => 10$	LOAD.L	A3,A1		; non => affiche tout10$:	LIB	?AFTEXT		; affiche l'unit source	LIB	?AFTIM	.ASCIZ	" sur "	.EVEN	LOAD.L	A3,A2	LIB	?AFTEXT		; affiche l'unit destination	LIB	?AFTIM	.ASCIZ	" ? <AFDIR>"	.EVEN	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,A2	LIB	?AFTEXT		; affiche l'unit destination	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,A2	LIB	?AFTEXT		; affiche l'unit destination	LIB	?AFTIM	.ASCIZ	"  formater (neuve)"	.EVEN	POP.L	D420$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_COPYFF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; COPIE ?	JUMP',EQ 70$	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:				; COPIE =>	LOAD.L	(A6)+OCPFFF,D480$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCOPYFW >;===========/; Demande confirmation pour une copie floppy --> winch.; in	A1.L	^nom unit source;	A2.L	^nom unit destination; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCOPYFW:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A3,A2	LOAD.L	A2,#(A6)+OCPNAM02$:	LOAD.B	(A2+),(A3+)	; OCPNAM <-- unit:rps:	JUMP,NE 02$	DEC.L	A2	LOAD.L	A3,A1		; A3 <-- ^nom unit source	LOAD.L	D0,#FOS?ENTER	CALL	ERCALL		; init l'unit	COMP.W	D7,#ERKSTO	JUMP,EQ EXIT$	LOAD.W	D2,D7		; D2 <-- ok/erreur	FOS	?NAMEDISK	; A4 <-- ^nom de la disquette	JUMP',NE 06$		; si nom inconnu => 06$				; nom existe =>	COMP.B	(A4),#'#	JUMP',NE 04$	INC.L	A4		; A4 <-- saute le "#"04$:	LOAD.B	D3,(A4+)	JUMP',EQ 06$	COMP.B	D3,#':	JUMP',EQ 06$	LOAD.B	(A2+),D3	JUMP	04$06$:	TEST.W	D2		; init ok ?	JUMP',NE 07$		; non => 07$	FOS	?RELEASE	; oui => libre l'unit07$:	CLR.B	(A2)	LOAD.L	A3,#(A6)+OCPNAM	; A3 <-- ^dbut du nom	LOAD.L	A4,A2		; A4 <-- ^fin du nom	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_COPYFW	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$20$:	CALL	DBFWSYN		; grise v. (COPIE)	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,A322$:	COMP.B	(A1+),#CR	JUMP,NE 22$	CLR.B	(A1)-1		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_COPYFW	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	TEST.W	D3	JUMP,EQ 20$	COMP.W	D3,#SPACE	JUMP,EQ 20$	COMP.W	D3,#UNDO	JUMP',EQ 50$	COMP.W	D3,#F1		; COPIE ?	JUMP',EQ 70$	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	20$70$:				; COPIE =>	LOAD.L	A4,#R16"TXDI	; A4 <-- ^extension .DI	LOAD.W	D3,#1		; D3 <-- force	LIB	?ADDEXT		; ajoute .DI72$:	LOAD.B	D3,(A3)	JUMP',EQ 74$	LIB	?MINMAJ		; OCPNAM <-- nom en majuscules	LOAD.B	(A3+),D3	JUMP	72$74$:	LOAD.W	D3,#F1		; D3 <-- (D'ACCORD)80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBFWSYN >;--------/; Grise le bouton (COPIE) si la syntaxe n'est pas correcte.; in	A3.L	^nom;	D0.L	flags; out	D0.L	flags; mod	D0.L, D7.WDBFWSYN:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,#(A6)+OBUFIT20$:	LOAD.B	(A4+),(A3+)	JUMP',EQ 22$	COMP.B	(A3)-1,#SPACE	JUMP,NE 20$	LOAD.B	(A3)-1,#'_	; remplace espace par soulign !	JUMP	20$22$:	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,#R16"TXDI	; A4 <-- ^extension .DI	LOAD.W	D3,#1		; D3 <-- force	LIB	?ADDEXT		; ajoute .DI	CALL	SKIPREP	TEST.B	(A3)	JUMP',EQ GREY$	COMP.B	(A3),#'.	JUMP',EQ GREY$	LOAD.L	A3,#(A6)+OBUFIT	FOS	?WHAT		; D3 <-- bits	JUMP',NE GREY$;;?	TEST.L	D3:#BWHNETW;;?	JUMP',BS GREY$	TEST.L	D3:#BWHUNIT	JUMP',BS GREY$	TEST.L	D3:#BWHREP	JUMP',BC FULL$GREY$:	TSET.L	D0:#17	JUMP',BS EXIT$	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	JUMP'	EXIT$FULL$:	TCLR.L	D0:#17	JUMP',BC EXIT$	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCOEXIT$:	POPM.L	D2..D4,A3,A4	RET;---------\\; WAITDBOX >;=========/; Met la dbox d'attente.; in	-; out	D7.W	erreur; mod	D7.WWAITDBOX:	PUSHM.L	D2..D5,A2	CALL	WAITMOUSE	; souris: met le sablier	CALL	NORMDBOX	; enlve si dj l	LOAD.L	A2,#R16"TDBOX_WAIT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE EXIT$	LOAD.L	(A6)+OCPCDB,D5	CLR.W	(A6)+OCPASC+OSCHTV ; ascenseur pas dessinEXIT$:	POPM.L	D2..D5,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; AFFTDBOX >;=========/; Affiche un texte dans la dbox d'attente.; in	A3.L	^texte <0>; out	-; mod	D7.WAFFTDBOX:	PUSHM.L	D2..D5,A3	LOAD.L	D5,(A6)+OCPCDB	; D5 <-- canal dbox	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche le texte	LOAD.B	D3,#EFLI	LIB	?AFCAR		; efface la fin de la ligne	POPM.L	D2..D5,A3	RET;---------\\; AFFNDBOX >;=========/; Affiche le nb de blocs restant dans la dbox d'attente.; in	D1.L	nb de blocs restant; out	-; mod	D7.WAFFNDBOX:	PUSHM.L	D2..D5,A3,A5	LOAD.L	A5,#(A6)+OCPASC	; A5 <-- ^variables de l'ascenseur	TEST.W	(A5)+OSCHTV	; ascenseur dj dessin ?	JUMP',NE 20$		; oui => 20$				; non => 	LOAD.L	D5,(A6)+OCPCDB	; D5 <-- canal dbox	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFCY	LOAD.W	(A5)+OSCDEBL,D3	SWAP.W	D3	LOAD.W	(A5)+OSCDEBO,D3	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,D3	SUB.W	D4,D3	LOAD.W	(A5)+OSCHTR,D4	LOAD.W	(A5)+OSCHTV,D1	SET.B	(A5)+OSCHOR	SCROLL_	DRAW		; dessine l'ascenseur20$:	LOAD.W	D3,(A5)+OSCHTV	SUB.W	D3,D1	LOAD.W	(A5)+OSCPOSV,D3	SCROLL_	UPDATE		; dplace l'ascenseur	LOAD.L	D5,(A6)+OCPCDB	; D5 <-- canal dbox	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"  Il reste "	.EVEN	LOAD.W	D2,#2^BAFDCM	LOAD.W	D3,#6	LOAD.L	D4,D1	LIB	?AFDEC		; affiche le nombre de blocs	LIB	?AFTIM	.ASCIZ	" blocs  copier ...<EFLI>"	.EVEN	POPM.L	D2..D5,A3,A5	RET;---------\\; AFFCDBOX >;=========/; Affiche un caractre dans la cabine de l'ascenseur.; in	D3.B	caractre; out	-; mod	D7.WAFFCDBOX:	PUSHM.L	D1..D4,A5	LOAD.L	A5,#(A6)+OCPASC	; A5 <-- ^variables de l'ascenseur	TEST.W	(A5)+OSCHTV	; ascenseur dj dessin ?	JUMP,EQ EXIT$		; non => EXIT$				; oui =>	LOAD.B	D1,D3	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfini une trame pour effacer	LOAD.W	D3,(A5)+OSCDEBL	ADD.W	D3,#2	SWAP.W	D3	LOAD.W	D3,(A5)+OSCDEBO	ADD.W	D3,(A5)+OSCPOSR	ADD.W	D3,#LGSCROLL+1	LOAD.W	D4,#LGSCROLL-4	SWAP.W	D4	LOAD.W	D4,#LGSCROLL-1	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface dans la cabine	SR.W	D4,#1	ADD.W	D3,D4	LOAD.W	D4,(A0)+ODFCX	SR.W	D4,#1	SUB.W	D3,D4	ADD.W	D3,(A0)+ODFC1X	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	LOAD.W	D4,(A0)+ODFC1Y	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LIB	?SETCURS	; positionne le curseur	LIB	?AFTIM	.B	AFTOUT	.B	MODCAR,INVDOT	.B	0	.EVEN	LOAD.B	D3,D1	LIB	?AFCAR		; affiche le caractre	LIB	?AFTIM	.B	MODCAR,SETDOT	.B	AFNORM	.B	0	.EVENEXIT$:	POPM.L	D1..D4,A5	RET;---------\\; NORMDBOX >;=========/; Enlve la dbox d'attente.; in	-; out	-; mod	-NORMDBOX:	PUSHM.L	D5,D7	TEST.L	(A6)+OCPCDB	JUMP',EQ EXIT$	LOAD.L	D5,(A6)+OCPCDB	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys	CLR.L	(A6)+OCPCDBEXIT$:	POPM.L	D5,D7	RET;--------\\; ERCALL  >;========/; Essaye de rsoudre une erreur.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,A2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.L	A2,#0		; A2 <-- mode "tendu";;?	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,A2	TEST.W	D7		; retour EQ/NE	RETERCALL2:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel;;?	LOAD.L	A2,#0		; A2 <-- mode "tendu"	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET	.END