	.SBTTL	STARTAFF;----------\\; IFRELEASE >;==========/; Release une unit s'il n'y a plus de dossiers fils ouverts.; in	A5.L	description unit; out	-; mod	D7.WIFRELEASE:	PUSHM.L	D3,A3..A5	LOAD.L	A3,#(A5)+OUNNAM	COMP.B	(A3)+OFLTYP,#'@	JUMP,EQ EXIT$.IF 0	LOAD.L	A4,#(A6)+OBUFIS10$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- nom de l'unit physique	COMP.B	(A3)-1,#':	JUMP,NE 10$	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUFIS	PUSH.B	(A5)+OUNNAM	CLR.B	(A5)+OUNNAM	; pour qu'il ne se trouve pas lui-mme !	CALL	IFUUSE		; unit utilise ?	POP.B	(A5)+OUNNAM	TEST.W	D7	JUMP',NE EXIT$		; oui => EXIT$	CALL	_WAITMOUSE	; souris: met le sablier	FOS	?RELEASE	; ferme l'unit (sans tester l'erreur).ELSE	LOAD.L	A4,#(A6)+OBUFIS10$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- nom de l'unit physique	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBUFIS	CALL	SKIPREP	CLR.B	(A3)20$:	LOAD.L	A3,#(A6)+OBUFIS	PUSH.B	(A5)+OUNNAM	CLR.B	(A5)+OUNNAM	; pour qu'il ne se trouve pas lui-mme !	CALL	IFUUSE		; unit utilise ?	POP.B	(A5)+OUNNAM	TEST.W	D7	JUMP',NE EXIT$		; oui => EXIT$	CALL	_WAITMOUSE	; souris: met le sablier	FOS	?RELEASE	; ferme l'unit (sans tester l'erreur)	JUMP',NE EXIT$	LOAD.L	A4,A340$:	TEST.B	(A4+)	JUMP,NE 40$	SUB.L	A4,#242$:	COMP.L	A4,A3	JUMP',EQ EXIT$	COMP.B	(-A4),#':	JUMP,NE 42$	CLR.B	(A4)+1	JUMP	20$.ENDIFEXIT$:	POPM.L	D3,A3..A5	RET;--------\\; IFUUSE  >;========/; Vrifie si une unit est utilise par une fentre active.;	A3	-->	#MM1:;	s'il existe #MM1:ESSAI:*	-->	retour ERUUSE; in	A3.L	^nom unit:rep:rep:; out	D7.W	erreur (ERUUSE si utilis); mod	D7.WIFUUSE:	PUSHM.L	D5,A1..A5	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-120$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP',F	80$		; non => 80$				; oui =>	LOAD.L	A1,#(A5)+OUNNAM	LOAD.L	A2,A330$:	TEST.B	(A2)	JUMP',EQ 60$	COMP.B	(A2+),(A1+)	JUMP,EQ 30$	JUMP'	70$60$:	LOAD.W	D7,#ERSFUSE	; D7 <-- unit utilise	JUMP'	EXIT$70$:	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,20$80$:	CLR.W	D7		; D7 <-- pas utiliseEXIT$:	POPM.L	D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; IFEQUUSE >;=========/; Vrifie si une unit est utilise par une fentre active.; in	A3.L	^nom unit:rep:rep:; out	D7.W	erreur (ERUUSE si utilis); mod	D7.WIFEQUUSE:	PUSHM.L	D3..D5,A1..A5	LOAD.L	A2,A3	CALL	SKIPREP	LOAD.L	D3,A3	SUB.L	D3,A2		; D3 <-- longueur rep: cherch	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-120$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP,F	80$		; non => 80$				; oui =>	LOAD.L	A1,#(A5)+OUNNAM	LOAD.L	A3,A1	CALL	SKIPREP	LOAD.L	D4,A3	SUB.L	D4,A1		; D4 <-- longueur rep: dans table	COMP.L	D4,D3		; mme longueurs ?	JUMP',NE 70$		; non => 70$	LOAD.L	A3,A230$:	DEC.L	D4	JUMP',NS 60$	COMP.B	(A3+),(A1+)	JUMP,EQ 30$	JUMP'	70$60$:	LOAD.W	D7,#ERSFUSE	; D7 <-- unit utilise	JUMP'	EXIT$70$:	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,20$80$:	CLR.W	D7		; D7 <-- pas utiliseEXIT$:	POPM.L	D3..D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFPRINT >;========/; Regarde si un fichier est imprimable.; in	A3.L	^nom de fichier; out	D7.W	EQ si imprimable; mod	D7.WIFPRINT:	PUSHM.L	D3,D4,A1..A4	LOAD.L	A1,A3		; A1 <-- ^nom de fichier	LOAD.L	A3,(A6)+OPINFO	; A3 <-- ^contenu de START.INFO	CLR.W	D4		; D4 <-- premire passe10$:	LOAD.L	A4,A3	LOAD.L	A3,#R16"00$	CALL	SRCPSEUDO	; A4 <-- ^dbut ligne avec .PRINTEXT	JUMP,NE 60$	LOAD.L	A3,A420$:	LIB	?SKPNAM		; A3 <-- ^mot suivant	JUMP,NE 10$	LOAD.L	A4,A1	LOAD.L	A2,#R16"01$	; A2 <-- ^terminateurs	LIB	?CPSTRING	; extension reconnue ?	JUMP,NS	20$		; non => 20$				; oui =>	CLR.W	D7		; D7 <-- c'est imprimable, si si	JUMP'	EXIT$60$:	LOAD.W	D7,#1		; D7 <-- pas imprimable	TEST.W	D4	JUMP',NE EXIT$	INC.W	D4		; D4 <-- deuxime passe	LOAD.L	A3,(A6)+OPUSER	; A3 <-- ^contenu de START_USER.INFO	JUMP	10$EXIT$:	POPM.L	D3,D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.ASCIZ	".PRINTEXT"01$:	.B	0,CR,SPACE,TAB,-1	.EVEN;----------\\; MOVECADRE >;==========/; Dtecte dans quelle case est la souris, ; dans n'importe quelle fentre d'unit,; et bouge tant que le bouton est maintenu press.; La case slectionne reste allume (utiliser INVCADRE) !; in	D4.L	position de la souris (y:x); out	D2.W	case o est la souris;	A5.L	^description unit;	D7.W	erreur; mod	D2.L, D7.W, A5.LMOVECADRE:	PUSHM.L	D1,D3,D4	CALL	DEXCADRE	; D2 <-- rang o est la souris	JUMP,NE EXIT$	CALL	INVCADRE	; allume la case	LOAD.W	D1,D2		; D1 <-- case allume20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 40$		; non => 40$				; oui =>	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	DETCADRE	; D2 <-- rang o est la souris	COMP.W	D2,D1		; toujours dans la mme case ?	JUMP,EQ 20$		; oui => 20$				; non =>	EX.L	D1,D2	CALL	INVCADRE	; teint l'ancienne case	LOAD.W	D2,D1	CALL	INVCADRE	; allume la nouvelle case	JUMP	20$40$:	LOAD.W	D2,D1		; D2 <-- case o est la souris	CLR.W	D7		; D7 <-- ok, clic dans caseEXIT$:	POPM.L	D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DEXCADRE >;=========/; Dtecte dans quelle case est la souris, ; dans n'importe quelle fentre d'unit.; in	D4.L	position de la souris (y:x); out	D7.W	ok;	 A5.L	 ^description unit;	 D2.W	 rang (0..n);	D7.W	erreur;	 D2.W	 -1; mod	D2.L ,D7.W, A5.LDEXCADRE:	PUSH.L	D5	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-120$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP',F	80$		; non => 80$				; oui =>	CALL	DETCADRE	; souris dans une case ?	JUMP',EQ EXIT$		; oui => EXIT$				; non =>	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,20$80$:	LOAD.W	D2,#-1	LOAD.W	D7,#ERDIOUT	; D7 <-- pas dans une icneEXIT$:	POP.L	D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DETCADRE >;=========/; Dtecte dans quelle case est la souris.; in	A5.L	^description unit;	D4.L	position de la souris (y;x); out	D2.W	rang de la case (0..n/-1);	D7.W	erreur; mod	D2.L, D7.WDETCADRE:	PUSHM.L	D0,D1,D3,D4	LOAD.L	D1,D4		; D1 <-- position de la souris	CLR.W	D210$:	CALL	POSCADRE	; D3/D4 <-- position/dimensions	LOAD.W	D0,D1	SUB.W	D0,D3		; trop  gauche ?	JUMP',LO 50$	COMP.W	D0,D4		; trop  droite ?	JUMP',HS 50$	SWAP.W	D3	SWAP.W	D4	LOAD.L	D0,D1	SWAP.W	D0	SUB.W	D0,D3		; trop en haut ?	JUMP',LO 50$	COMP.W	D0,D4		; trop en bas ?	JUMP',HS 50$	CLR.W	D7		; D7 <-- chic, on est dans une case	JUMP'	EXIT$50$:	INC.W	D2	COMP.W	D2,#NBNOC	JUMP,LO 10$	LOAD.W	D2,#-1	LOAD.W	D7,#ERDIOUT	; D7 <-- pas dans une caseEXIT$:	POPM.L	D0,D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; INVCADRE >;=========/; Inverse une case en haut d'une fentre.; in	A5.L	^description unit;	D2.W	rang (0..n/-1); out	-; mod	D7.WINVCADRE:	PUSHM.L	D2..D4	COMP.W	D2,#-1	JUMP',EQ EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_PPHILI	LIB	?COLORSR	CALL	POSCADRE	; D3/D4 <-- position/dimensions	COMP.W	D2,#NOCFERME	JUMP',EQ TRAME$	INC.W	D3	DEC.W	D4TRAME$:	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse la case	LIB	?COLORPOPEXIT$:	POPM.L	D2..D4	RET;---------\\; POSCADRE >;---------/; Donne la position et les dimensions d'une case en haut; d'une fentre.; in	A5.L	^description unit;	D2.W	rang (0..n); out	D3.L	origine (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WPOSCADRE:	PUSH.L	D2	LOAD.L	D3,(A5)+OUNPOS	LOAD.W	D4,(A6)+ODCASY	SWAP.W	D4	COMP.W	D2,#NOCLISTE	JUMP,EQ LISTE$	COMP.W	D2,#NOCREFAIT	JUMP,EQ REFAIT$	COMP.W	D2,#NOCCOMPTE	JUMP',EQ INFO$	COMP.W	D2,#NOCNOM	JUMP',EQ NOM$	COMP.W	D2,#NOCTOUT	JUMP',EQ TOUT$				; case de fermeture =>	LOAD.W	D4,(A6)+ODCASY	JUMP	EXIT$TOUT$:				; case TOUT =>	ADD.W	D3,(A6)+ODCASY	LOAD.W	D4,(A6)+ODCASY	INC.W	D4	JUMP	EXIT$NOM$:				; nom d'unit/rpertoire =>	ADD.W	D3,(A6)+ODCASY	ADD.W	D3,(A6)+ODCASY	INC.W	D3	LOAD.W	D2,(A6)+ODCARX	MUL.WU	D2,#30	LOAD.W	D4,D2	ADD.W	D4,#2	JUMP	EXIT$INFO$:				; informations diverses =>	LOAD.W	D4,D3	ADD.W	D3,(A6)+ODCASY	ADD.W	D3,(A6)+ODCASY	INC.W	D3	LOAD.W	D2,(A6)+ODCARX	MUL.WU	D2,#30	ADD.W	D3,D2	ADD.W	D3,#2	ADD.W	D4,(A5)+OUNDIM+2	SUB.W	D4,#LGSCROLL-1	LOAD.W	D2,(A6)+ODCARX	MUL.WU	D2,#8+7	SUB.W	D4,D2	SUB.W	D4,D3	JUMP	EXIT$REFAIT$:			; case REFAIT =>	LOAD.W	D2,(A6)+ODCARX	MUL.WU	D2,#8+7	ADD.W	D3,(A5)+OUNDIM+2	SUB.W	D3,#LGSCROLL-1	SUB.W	D3,D2	LOAD.W	D2,(A6)+ODCARX	MUL.WU	D2,#8	LOAD.W	D4,D2	JUMP'	EXIT$LISTE$:				; case LISTE =>	LOAD.W	D2,(A6)+ODCARX	MUL.WU	D2,#7	ADD.W	D3,(A5)+OUNDIM+2	SUB.W	D3,#LGSCROLL-1	SUB.W	D3,D2	LOAD.W	D4,D2;	JUMP'	EXIT$EXIT$:	POP.L	D2	RET;--------\\; OPEWDO  >;========/; Ouvre une nouvelle fentre.; in	A5.L	^description du pre / ^nil; out	A5.L	^description nouvelle fentre;	D7.W	erreur; mod	D7.W, A5.LOPEWDO:	CALL	OPEWDOS		; ouvre la fentre (brrr...)	CALL	MAJWDO		; redessine les fentre modifies	TEST.W	D7		; retour EQ/NE	RET;--------\\; OPEWDOS >;========/; Ouvre une nouvelle fentre, sans faire MAJWDO.; in	A5.L	^description du pre / ^nil; out	A5.L	^description nouvelle fentre;	D7.W	erreur; mod	D7.W, A5.LOPEWDOS:	PUSHM.L	D2..D5,A3,A4	LOAD.L	A3,A5		; A3 <-- ^description pre	LOAD.W	D7,#ERSTWDO	; D7 <-- y'en a trop; Compresse toutes les fentres existantes pour les caler; contre en haut, afin de laisser le maximum de place en bas; pour la nouvelle fentre.	LOAD.L	A5,#(A6)+OUNIT	LOAD.W	D3,(A6)+OPBIG+0	; D3 <-- position initiale en Y	LOAD.W	D5,#MAXUNIT-110$:	TEST.B	(A5)+OUNUSE	; fentre utilise ?	JUMP,F	30$		; non => 30$				; oui =>	CALL	MINHWDO		; D2/D4 <-- nb/hauteur minimale	COMP.W	D3,(A5)+OUNPOS+0	JUMP',NE 15$	COMP.W	D4,(A5)+OUNDIM+0	JUMP,EQ 20$15$:	LOAD.W	(A5)+OUNPOS+0,D3	LOAD.W	(A5)+OUNDIM+0,D4	LOAD.W	(A5)+OUNNBY,D2	; nb d'icnes en hauteur	SET.B	(A5)+OUNMOD	; signal fentre modifie20$:	ADD.W	D3,D4	ADD.W	D3,#MARGEY	; D3 <-- position suivante en Y	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,10$	JUMP	80$; Prend le maximum de place en bas pour la nouvelle fentre.30$:	LOAD.L	A4,A5	LOAD.W	D5,#LUN-140$:	CLR.B	(A4+)		; met toute l'unit  zro	DECJ.W,NMO D5,40$	LOAD.L	(A5)+OUNFALI,#2^BFLC1A!2^BFLC2E!2^BFLAI	SET.B	(A5)+OUNPHY	COMP.L	A3,#0	JUMP',EQ 45$	LOAD.L	(A5)+OUNFALI,(A3)+OUNFALI	CLR.B	(A5)+OUNPHY45$:	LOAD.W	(A5)+OUNPOS+2,(A6)+OPBIG+2	LOAD.W	(A5)+OUNDIM+2,(A6)+ODBIG+2	CALL	DIMICOXY	; calcul les dimensions d'une icne	LOAD.W	(A5)+OUNPOS+0,D3	CLR.L	D4	LOAD.W	D4,(A6)+OPBIG+0	ADD.W	D4,(A6)+ODBIG+0	SUB.W	D4,D3		; D4 <-- hauteur maximale possible	SUB.W	D4,(A6)+ODCASY	JUMP',LE 80$	DIV.WU	D4,(A5)+OUNLGY	LOAD.W	(A5)+OUNNBY,D4	JUMP',EQ 80$	MUL.WU	D4,(A5)+OUNLGY	ADD.W	D4,(A6)+ODCASY	LOAD.W	(A5)+OUNDIM+0,D4	CLR.L	D4	LOAD.W	D4,(A5)+OUNDIM+2	SUB.W	D4,#LGSCROLL-1	DIV.WU	D4,(A5)+OUNLGX	LOAD.W	(A5)+OUNNBX,D4	SET.B	(A5)+OUNUSE	; utilise nouvelle fentre	SET.B	(A5)+OUNMOD	; faudra la dessiner	CLR.W	D7		; D7 <-- ok80$:	POPM.L	D2..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOWDO  >;========/; Ferme une fentre existante.; in	A5.L	^description fentre  fermer; out	-; mod	D7.WCLOWDO:	CALL	CLOWDOS		; ferme la fentre	CALL	MAJWDO		; redessine les fentre modifies	RET;--------\\; CLOWDOS >;========/; Ferme une fentre existante, sans faire MAJWDO.; in	A5.L	^description fentre  fermer; out	-; mod	D7.WCLOWDOS:	PUSHM.L	D1..D4,A4,A5	TEST.L	(A5)+OUNPIN	JUMP',EQ 12$	LOAD.L	A4,(A5)+OUNPIN	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire de l'index12$:	TEST.L	(A5)+OUNPLI	JUMP',EQ 14$	LOAD.L	A4,(A5)+OUNPLI	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire de la liste14$:	CLR.L	D3	LOAD.W	D3,(A6)+OPBIG+0	ADD.W	D3,(A6)+ODBIG+0	TEST.B	(A5)+LUN+OUNUSE	; fentre suivante existe ?	JUMP',F	20$		; non => 20$	LOAD.W	D3,(A5)+LUN+OUNPOS+020$:	LOAD.L	A4,#(A5)-LUN	; A4 <-- ^fentre prcdente	SUB.W	D3,(A4)+OUNPOS+0	SUB.W	D3,(A6)+ODCASY	DIV.WU	D3,(A4)+OUNLGY	LOAD.W	(A4)+OUNNBY,D3	MUL.WU	D3,(A4)+OUNLGY	ADD.W	D3,(A6)+ODCASY	LOAD.W	(A4)+OUNDIM+0,D3	SET.B	(A4)+OUNMOD	; fentre modifie	LOAD.W	D3,(A4)+OUNPOS+0	ADD.W	D3,(A4)+OUNDIM+0	ADD.W	D3,#MARGEY	; D3 <--position pour fentre suivante40$:	TEST.B	(A5)+LUN+OUNUSE	JUMP',F	50$	LOAD.W	D4,#LUN-142$:	LOAD.B	(A5),(A5)+LUN	INC.L	A5	DECJ.W,NMO D4,42$	LOAD.W	(A5)-LUN+OUNPOS+0,D3	ADD.W	D3,(A5)-LUN+OUNDIM+0	ADD.W	D3,#MARGEY	; D3 <--position pour fentre suivante	SET.B	(A5)-LUN+OUNMOD	; fentre modifie	JUMP	40$50$:	CLR.B	(A5)+OUNUSE	CALL	COMPACTWDO	; compresse toutes les fentres	POPM.L	D1..D4,A4,A5	RET;--------\\; ENDWDO  >;========/; Place une unit tout  la fin (tout en bas).; in	A5.L	^descripteur unit; out	-; mod	D7.WENDWDO:	PUSHM.L	D3,D4,A4,A510$:	LOAD.L	A4,#(A5)+LUN	; A4 <-- ^unit suivante	TEST.B	(A4)+OUNUSE	; unit utilise ?	JUMP',F	50$		; non => 50$				; oui =>	LOAD.W	D3,#(LUN/2)-1	; D3 <-- /2 car .W et -1  cause NMO20$:	LOAD.W	D4,(A5)	LOAD.W	(A5+),(A4)	; EX.W (A5+),(A4+)	LOAD.W	(A4+),D4	DECJ.W,NMO D3,20$	JUMP	10$50$:	CALL	COMPACTWDO	; compresse toutes les fentres	CALL	MAJWDO		; redessine les fentre modifies (toutes)	POPM.L	D3,D4,A4,A5	RET;-----------\\; TOOMUCHWDO >;===========/; Regarde s'il existe trop de swdo en fonction de l'chelle.; in	-; out	D7.W	ok/erreur; mod	D7.WTOOMUCHWDO:	PUSHM.L	D3..D5,A5	LOAD.L	A5,#(A6)+OUNIT	LOAD.W	D3,(A6)+OPBIG+0	; D3 <-- position initiale en Y	LOAD.W	D5,#MAXUNIT-110$:	TEST.B	(A5)+OUNUSE	; fentre utilise ?	JUMP',F	30$		; non => 30$				; oui =>	ADD.W	D3,(A6)+ODCASY	CALL	DIMWMINY	; D4 <-- hauteur minimale	ADD.W	D3,D4	ADD.W	D3,#MARGEY	; D3 <-- position suivante en Y	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,10$30$:	CLR.W	D7		; D7 <-- ok	COMP.W	D3,(A0)+ODFDY	; arrive-t-on trop bas ?	JUMP',LO EXIT$		; non => EXIT$	LOAD.W	D7,#ERSTWDO	; D7 <-- trop de swdoEXIT$:	POPM.L	D3..D5,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; SCALEWDO >;=========/; Modifie les dimensions et le nombre d'icnes dans une fentre; en fonction d'une nouvelle chelle.; in	-; out	-; mod	D7.WSCALEWDO:	PUSHM.L	D5,A5	LOAD.L	A5,#(A6)+OUNIT	LOAD.W	D5,#MAXUNIT-110$:	TEST.B	(A5)+OUNUSE	; fentre utilise ?	JUMP',F	20$		; non => 20$				; oui =>	CALL	DIMICO		; recalcul les dimensions d'une icne	SET.B	(A5)+OUNMOD	; signal fentre modifie	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,10$20$:	CALL	COMPACTWDO	; compresse toutes les fentres	CALL	MAJWDO		; redessine les fentre modifies (toutes)	POPM.L	D5,A5	RET;-----------\\; COMPACTWDO >;===========/; Compresse toutes les fentres pour laisser un maximum de place;  la dernire tout en bas.; in	-; out	-; mod	D7.WCOMPACTWDO:	PUSHM.L	D2..D4,A4,A5; Compresse toutes les fentres existantes pour les caler; contre en haut, afin de laisser le maximum de place en bas; pour la nouvelle fentre.	LOAD.L	A5,#(A6)+OUNIT	LOAD.W	D3,(A6)+OPBIG+0	; D3 <-- position initiale en Y	LOAD.W	D5,#MAXUNIT-110$:	TEST.B	(A5)+OUNUSE	; fentre utilise ?	JUMP,F	30$		; non => 30$				; oui =>	CALL	MINHWDO		; D2/D4 <-- nb/hauteur minimale	COMP.W	D3,(A5)+OUNPOS+0	JUMP',NE 15$	COMP.W	D4,(A5)+OUNDIM+0	JUMP',EQ 20$15$:	LOAD.W	(A5)+OUNPOS+0,D3	LOAD.W	(A5)+OUNDIM+0,D4	LOAD.W	(A5)+OUNNBY,D2	; nb d'icnes en hauteur	SET.B	(A5)+OUNMOD	; signal fentre modifie20$:	ADD.W	D3,D4	ADD.W	D3,#MARGEY	; D3 <-- position suivante en Y	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,10$; Prend le maximum de place en bas pour la dernire fentre.30$:	LOAD.L	A5,#(A5)-LUN	; A5 <-- ^dernire unit	CLR.L	D4	LOAD.W	D4,(A6)+OPBIG+0	ADD.W	D4,(A6)+ODBIG+0	SUB.W	D4,(A5)+OUNPOS+0 ; D4 <-- hauteur maximale possible	SUB.W	D4,(A6)+ODCASY	DIV.WU	D4,(A5)+OUNLGY	MUL.WU	D4,(A5)+OUNLGY	ADD.W	D4,(A6)+ODCASY	LOAD.W	(A5)+OUNDIM+0,D4	CLR.L	D4	LOAD.W	D4,(A5)+OUNDIM+0	SUB.W	D4,(A6)+ODCASY	DIV.WU	D4,(A5)+OUNLGY	LOAD.W	(A5)+OUNNBY,D4	POPM.L	D2..D4,A4,A5	RET;--------\\; MINHWDO >;--------/; Donne la hauteur minimale pour une fentre.; in	A5.L	^description unit; out	D4.W	hauteur minimale;	D2.W	nb d'icne en hauteur; mod	D2.L, D4.L, D7.WMINHWDO:	LOAD.W	D2,#1		; D2 <-- une seule icne	TEST.B	(A5)+OUNFAAF:#BFLAI-16	JUMP',BS 10$	LOAD.W	D2,#NLITIC	; D2 <-- 3 lignes de noms10$:	COMP.W	(A0)+ODFDY,#512	; fentre trs haute ?	JUMP',LS 20$		; non => 20$	LOAD.W	D4,(A5)+OUNNBL	COMP.W	D4,(A5)+OUNNBX	; beaucoup d'icnes visibles ?	JUMP',LS 20$		; non => 20$	SL.W	D2,#1		; D2 <-- deux icnes ou 6 lignes20$:	LOAD.W	D4,(A5)+OUNLGY	; D4 <-- hauteur minimale	MUL.WU	D4,D2	ADD.W	D4,(A6)+ODCASY	RET;--------\\; DIMICO  >;========/; Calcule toutes les dimensions pour une icne.; in	A5.L	^description unit; out	-; mod	-DIMICO:	PUSH.L	D4	CALL	DIMICOXY	; calcul les dimensions d'une icne	CLR.L	D4	LOAD.W	D4,(A5)+OUNDIM+0	SUB.W	D4,(A6)+ODCASY	DIV.WU	D4,(A5)+OUNLGY	LOAD.W	(A5)+OUNNBY,D4	CLR.L	D4	LOAD.W	D4,(A5)+OUNDIM+2	SUB.W	D4,#LGSCROLL-1	DIV.WU	D4,(A5)+OUNLGX	LOAD.W	(A5)+OUNNBX,D4	POP.L	D4	RET;---------\\; DIMICOXY >;---------/; Calcule juste les dimensions d'une icne.; in	A5.L	^description unit; out	-; mod	-DIMICOXY:	PUSH.L	D4	CALL	DIMWMINY	; D4 <-- hauteur minimale	LOAD.W	(A5)+OUNLGY,D4	TEST.B	(A5)+OUNFAAF:#BFLAI-16	JUMP',BC 50$30$:	LOAD.W	D4,(A6)+OTDFCX	MUL.WU	D4,#15	ADD.W	D4,#2		; D4 <-- largeur pour une icne	TEST.B	(A6)+ODEMIX	JUMP',F 35$	DEC.W	D4		; D4 <-- serre les p'tites icnes35$:	LOAD.W	(A5)+OUNLGX,D4	JUMP'	EXIT$50$:;	CLR.L	D4;	LOAD.W	D4,(A5)+OUNLGY	DIV.WU	D4,#NLITIC	LOAD.W	(A5)+OUNLGY,D4	TEST.B	(A5)+OUNFAAF:#BFLAT-16	JUMP,BC 30$	LOAD.W	D4,(A5)+OUNDIM+2	SUB.W	D4,#LGSCROLL-1+2	LOAD.W	(A5)+OUNLGX,D4EXIT$:	POP.L	D4	RET;---------\\; DIMWMINY >;---------/; Donne la hauteur minimale pour une fentre.; in	-; out	D4.W	hauteur minimale; mod	D4.L, D7.WDIMWMINY:	CLR.L	D4	LOAD.W	D4,(A6)+OGCIIMY	ADD.W	D4,(A6)+OGCIIY	ADD.W	D4,(A6)+OGCIIMY	ADD.W	D4,(A6)+OGCIIMT	ADD.W	D4,(A6)+OTDFCY	ADD.W	D4,#8	TEST.B	(A6)+ODEMIY	JUMP',F 20$	SUB.W	D4,#420$:	ADD.W	D4,#NLITIC-1	DIV.WU	D4,#NLITIC	MUL.WU	D4,#NLITIC	; D4 <-- arrondi au multiple de 3 suprieur	RET;--------\\; MRKWDO  >;--------/; Signal que toutes les fentres sont modifies.; in	-; out	-; mod	-MRKWDO:	PUSHM.L	D5,A5	LOAD.L	A5,#(A6)+OUNIT	LOAD.W	D5,#MAXUNIT-110$:	TEST.B	(A5)+OUNUSE	; fentre utilise ?	JUMP',F	EXIT$		; non => EXIT$				; oui =>	SET.B	(A5)+OUNMOD	; signal fentre modifie	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,10$EXIT$:	POPM.L	D5,A5	RET;--------\\; MAJWDO  >;--------/; Redessine toutes les fentres modifies.; in	-; out	-; mod	-MAJWDO:	PUSHM.L	D2..D5,D7,A5; Redessine toutes les fentres modifies.	LOAD.L	A5,#(A6)+OUNIT	LOAD.W	D5,#MAXUNIT-110$:	TEST.B	(A5)+OUNUSE	; fentre utilise ?	JUMP',F	30$		; non => 30$	TEST.B	(A5)+OUNMOD	; fentre modifie ?	JUMP',F	20$		; non => 20$				; oui =>	CALL	DESWDO		; redessine la fentre	CALL	MAJASCENSEUR	; redessine l'ascenseur	CALL	ALLICONE	; redessine les icnes	CLR.B	(A5)+OUNMOD	; fentre maintenant  jour20$:	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,10$30$:	LOAD.L	A5,#(A5)-LUN	; A5 <-- ^dernire unit tout en bas; Redessine le fond de l'cran tout en bas.	LOAD.L	D3,#TRAGRIS	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D3,(A5)+OUNPOS	SUB.W	D3,#2	LOAD.L	D4,(A5)+OUNDIM	ADD.W	D4,#6	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,(A5)+OUNDIM+0	ADD.W	D3,#MARGEY-3	LOAD.W	D4,(A6)+OPBIG+0	ADD.W	D4,(A6)+ODBIG+0	ADD.W	D4,#4	SUB.W	D4,D3	JUMP',LE EXIT$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAMEEXIT$:	POPM.L	D2..D5,D7,A5	RET;--------\\; DESWDO  >;========/; Dessine le cadre d'une fentre correspondant  une unit.; in	A5.L	^description unit; out	-; mod	D7.WDESWDO:	PUSHM.L	D0..D4,A4,A5; Redessine le fond de l'cran sous la fentre.	LOAD.L	D3,#TRAGRIS	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D3,(A5)+OUNPOS	SUB.W	D3,#2	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LOAD.L	D4,(A5)+OUNDIM	ADD.W	D4,#6	SWAP.W	D4	ADD.W	D4,#MARGEY	SWAP.W	D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME; Efface toute la surface.	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A5)+OUNPOS	LOAD.L	D4,(A5)+OUNDIM	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME; Dessine le cadre en double paisseur et ombr.	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D3,(A5)+OUNPOS	LOAD.L	D4,(A5)+OUNDIM	SUB.W	D3,#2	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	ADD.W	D4,#3	SWAP.W	D4	ADD.W	D4,#3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LOAD.W	D1,#2	LIB	?DRRECTO	; rectangle extrieur ombr	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; rectangle intrieur; Dessine quelques lignes de sparations.	LOAD.L	D3,(A5)+OUNPOS	SWAP.W	D3	ADD.W	D3,(A6)+ODCASY	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A5)+OUNDIM+2	SUB.W	D4,#LGSCROLL-1	LIB	?DRSEG		; grand trait horizontal	LOAD.W	D2,#NOCFERME	CALL	POSCADRE	LOAD.W	D2,#SETDOT	TEST.B	(A5)+OUNPHY	; fentre des units physiques ?	JUMP',T	40$		; oui => 40$	PUSH.L	D3	LIB	?DRSEG		; croix dans case de gauche	POP.L	D3	ADD.W	D3,D4	DEC.W	D3	NEG.W	D4	LIB	?DRSEG		; croix dans case de gauche	TEST.B	(A5)+LUN+OUNUSE	; unit suivante utilise ?	JUMP',F	45$		; non => 45$	LOAD.W	D2,#NOCTOUT	CALL	POSCADRE	LOAD.W	D2,#SETDOT	LOAD.L	A4,#R16"00$	CALL	DESMOTIF	; motif dans la case TOUT	JUMP'	45$40$:	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#5	SWAP.W	D4	SUB.W	D4,#5	SWAP.W	D4	LIB	?DRRECT		; petit carr inclu45$:	LOAD.W	D1,#146$:	LOAD.W	D2,D1	CALL	POSCADRE	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; dessine une sparation entre deux cases	INC.W	D1	COMP.W	D1,#NBNOC	JUMP,LO 46$; Dessine le texte dans la case REFAIT.	COMP.B	(A5)+OUNNAM,#'@	JUMP',NE 50$	LOAD.W	D2,#NOCREFAIT	CALL	POSCADRE	ADD.W	D3,(A0)+ODFCX	SWAP.W	D3	INC.W	D3	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"REFAIT"	.EVEN; Dessine le texte dans la case LISTE.50$:	LOAD.W	D2,#NOCLISTE	CALL	POSCADRE	ADD.W	D3,(A0)+ODFCX	SWAP.W	D3	INC.W	D3	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LIB	?SETCURS	TEST.B	(A5)+OUNPHY	; fentre des units physiques ?	JUMP',T	53$		; oui => 53$	LIB	?AFTIM	.ASCIZ	"LISTE"	.EVEN	JUMP'	55$53$:	LOAD.L	D3,(A6)+OSWITCH	TEST.L	D3:#('A-'A)	; START/A ?	JUMP',BS 55$		; oui => 55$	LIB	?AFTIM	.ASCIZ	"AUTRE"	.EVEN; Dessine l'ascenseur vertical tout  droite.55$:	CALL	DESASCENSEUR	; dessine l'ascenseurEXIT$:	POPM.L	D0..D4,A4,A5	RET00$:	.W	6,6	.W	-4,0	.W	0,1	.W	4,0	.W	0,1	.W	-4,0	.W	0,1	.W	5,0	.W	0,3	.W	0,-9	.W	1,1	.W	0,7	.W	1,-1	.W	0,-5	.W	1,1	.W	0,3	.W	1,-1	.W	0,-2	.W	0,0;--------\\; CALCUL  >;========/; Effectue tous les calculs fixes de dimensionnement.; in	-; out	-; mod	D7.WCALCUL:	PUSHM.L	D3,D4	LOAD.W	(A6)+ODCARX,(A0)+ODFCX	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	LOAD.W	(A6)+ODCARY,D4	COMP.W	D4,#LGSCROLL-2	JUMP',HS 20$	LOAD.W	D4,#LGSCROLL-220$:	LOAD.W	(A6)+ODCASY,D4; Calcul la surface utilisable pour les grandes fentres.	LOAD.W	(A6)+OPBIG+2,#MARGEX	LOAD.W	D4,(A0)+ODFDX	SUB.W	D4,#MARGEX*2	LOAD.W	(A6)+ODBIG+2,D4	LOAD.W	D4,(A6)+ODCARY	ADD.W	D4,#MARGEY/2	LOAD.W	(A6)+OPBIG+0,D4	ADD.W	D4,#MARGEY/2	SUB.W	D4,(A0)+ODFDY	NEG.W	D4	LOAD.W	(A6)+ODBIG+0,D4	CLR.L	D4	LOAD.W	D4,(A6)+ODBIG+2	SUB.W	D4,#LGSCROLL-1	LOAD.W	D3,(A6)+OTDFCX	MUL.WU	D3,#15	ADD.W	D3,#2		; D3 <-- largeur pour une icne	DIV.WU	D4,D3	MUL.WU	D4,D3	SUB.W	D4,(A6)+ODBIG+2	ADD.W	D4,#LGSCROLL-1	NEG.W	D4	DEC.W	D4	JUMP',NS EXIT$	SUB.W	(A6)+ODBIG+2,D4	SR.W	D4,#1	ADD.W	(A6)+OPBIG+2,D4	COMP.W	(A6)+ODBIG+0,#600 ; fentre trs haute ?	JUMP',LO EXIT$		  ; non => EXIT$	SUB.W	(A6)+ODBIG+0,D4	SR.W	D4,#1	ADD.W	(A6)+OPBIG+0,D4EXIT$:	POPM.L	D3,D4	RET;--------\\; CADRE   >;========/; Dessine le cadre complet.; in	-; out	-; mod	D7.WCADRE:	PUSHM.L	D2..D4	CALL	FOND		; trame tout le fond	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LOAD.W	D4,(A0)+ODFDX	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	; inverse la bande suprieure	CALL	INFO		; affiche "START ..."	POPM.L	D2..D4	RET;--------\\; FOND    >;========/; Dessine juste le fond de l'cran.; in	-; out	-; mod	D7.WFOND:	PUSHM.L	D2..D4	LOAD.L	D3,#TRAGRIS	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	POPM.L	D2..D4	RET;--------\\; INFO    >;========/; Affiche les informations tout en haut.; in	-; out	-; mod	D7.WINFO:	PUSHM.L	D3,D4,A3	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	AFINV	.ASCII	" START "	.B	STARTREV+'0	.B	'.	.IF	STARTVERS<10	.B	STARTVERS+'0	.ASCII	"     "	.ELSE	.B	(STARTVERS/10)+'0,(STARTVERS-((STARTVERS/10)*10))+'0	.ASCII	"    "	.ENDIF	.B	0	.EVEN	LOAD.L	D4,(A6)+OSWITCH	TEST.L	D4:#('S-'A)	; START/S ?	JUMP',BS 50$		; oui => 50$	LIB	?AFTIM	.ASCIZ	"Systme en "	.EVEN	CLR.W	D4	FOS	?GSDIR		; A3 <-- ^rpertoire systme	JUMP',NE 40$	LIB	?AFTEXT		; affiche le rpertoire systme	JUMP'	50$40$:	LIB	?AFTIM	.ASCIZ	"?"	.EVEN50$:	LIB	?AFTIM	.B	MSPACE,100	; efface la fin de la ligne	.B	AFDIR	.B	0	.EVEN	LOAD.L	A3,#R16"TIHELP	CALL	INFO3B		; affiche les 3 boutons de la souris	POPM.L	D3,D4,A3	RET;---------\\; INFO3B   >;---------/; Affiche les fonctions des trois boutons de la souris.; in	A3.L	^texte; out	-; mod	D7.WINFO3B:	PUSHM.L	D3,A3	LOAD.B	D3,#AFINV	LIB	?AFCAR	LOAD.W	D3,#LIHELP	MUL.WU	D3,(A0)+ODFCX	SUB.W	D3,(A0)+ODFDX	NEG.W	D3	AND.L	D3,#H'FFFF	LIB	?SETCURS	LIB	?AFTEXT		; affiche les 3 boutons de la souris	LOAD.B	D3,#AFDIR	LIB	?AFCAR	POPM.L	D3,A3	RET	.END