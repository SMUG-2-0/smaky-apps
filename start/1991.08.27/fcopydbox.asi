	.SBTTL	FCOPYDBOX.ASI;----------\\; DBOXCHOIX >;==========/; Choix de la copie  effectuer.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCHOIX:	PUSHM.L	D0..D2,D4,D5,A1..A4	CALL	COPYGREY	; OGREY <-- options impossibles	LOAD.L	A2,#R16"TDBOX_CHOIX	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	A4,(A6)+OIPPT	LOAD.L	D4,(A6)+OIPDIM	LOAD.L	D3,#H'10000*IPWDOY+IPWDOX	CALL	SHOWIMAGE	; affiche l'image de la palette	CLR.W	D2	LOAD.B	D3,(A6)+OGREYGREY$:	TEST.L	D3:D2		; option impossible ?	JUMP',BC FULL$		; non => FULL$	CALL	IPGREY		; oui => met-la en grisFULL$:	INC.W	D2		; D2 <-- option suivante	COMP.W	D2,#5	JUMP,LO GREY$	LOAD.W	D0,(A6)+OCHOIX	LOAD.W	D2,D0	CALL	IPINV		; allume l'option actuelleLOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_CHOIX	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	LOAD.W	D1,#-1	COMP.B	D3,#'R	JUMP,EQ MOVE$	COMP.B	D3,#'r	JUMP,EQ MOVE$	LOAD.W	D1,#+1	COMP.B	D3,#'C	JUMP,EQ MOVE$	COMP.B	D3,#'c	JUMP,EQ MOVE$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$MOVE$:	LOAD.W	D3,D0MOVE2$:	ADD.W	D3,D1		; D3 <-- option suivante	JUMP,NS BIP$	COMP.W	D3,#5	JUMP,HS BIP$	LOAD.B	D2,(A6)+OGREY	TEST.L	D2:D3		; option impossible ?	JUMP,BS MOVE2$		; oui => MOVE2$	LOAD.W	D2,D0	CALL	IPINV		; efface l'ancien	LOAD.W	D0,D3	LOAD.W	D2,D0	CALL	IPINV		; allume le nouveau	JUMP	LOOP$CLIC$:	CALL	IPMOVE		; slectionne une option ...	JUMP	LOOP$OK$:	COMP.W	D0,#-1	JUMP,EQ BIP$	LOAD.W	(A6)+OCHOIX,D0CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CHOIX:	.W	10$-TDBOX_CHOIX	.W	20$-TDBOX_CHOIX	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix de la copie  affectuer :"	.B	ODBTABX,57	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  COPIE  "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  FIN  "	.B	020$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Copie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_CHOIX:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_CHOIX	.W	F0,END,0		DOKF0-TKEY_CHOIX	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_CHOIX	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CHOIX	.W	0;--------\\; IPMOVE  >;--------/; Change d'option slectionne.; in	D0.W	option slectionne; out	D0.W	nouvelle option;	D7.W	0 => double clic; mod	D0.L, D7.WIPMOVE:	PUSHM.L	D1..D4	LOAD.W	D1,D0	JUMP'	CPOS$CLOOP$:	CALL	WAITMOVE	; attend dplacement ...	JUMP',NE CEND$CPOS$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE CLOOP$	CALL	IPDET		; D2 <-- option o est la souris	COMP.W	D2,D0		; toujours dans le mme ?	JUMP,EQ CLOOP$		; oui => CLOOP$				; non =>	EX.L	D0,D2	CALL	IPINV		; efface l'ancien	LOAD.W	D2,D0	CALL	IPINV		; allume le nouveau	JUMP	CLOOP$CEND$:	LOAD.W	D7,#1		; D7 <-- simple clic	COMP.W	D0,D1	JUMP',NE EXIT$	COMP.W	D0,#-1	JUMP',EQ EXIT$	CLR.W	D7		; D7 <-- double clicEXIT$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IPDET   >;--------/; Dtecte dans quelle option est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	option (0..4,-1);	D7.W	erreur; mod	D2.L, D7.WIPDET:	PUSHM.L	D0,D1,D3,D4	LOAD.W	D0,D4	LOAD.L	D1,D4	SWAP.W	D1	CLR.W	D7	CLR.W	D220$:	CALL	IPPOS		; D3/D4 <-- position/dimensions	ADD.W	D3,#IPWDOX	SWAP.W	D3	ADD.W	D3,#IPWDOY	SWAP.W	D3	COMP.W	D0,D3	JUMP',LO 40$	ADD.W	D3,D4	COMP.W	D0,D3	JUMP',HS 40$	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,D3	JUMP',LO 40$	ADD.W	D3,D4	COMP.W	D1,D3	JUMP',HS 40$	LOAD.B	D4,(A6)+OGREY	TEST.L	D4:D2		; option possible ?	JUMP',BC 90$		; oui => 90$40$:	INC.W	D2	COMP.W	D2,#5	JUMP,LO 20$	LOAD.W	D2,#-1	LOAD.W	D7,#190$:	POPM.L	D0,D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IPGREY  >;--------/; Grise une option.; in	D2.W	option (0..4,-1); out	-; mod	D7.WIPGREY:	PUSHM.L	D2..D4	COMP.W	D2,#-1	JUMP',EQ 90$	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	CALL	IPPOS		; D3/D4 <-- position/dimensions	ADD.W	D3,#IPWDOX+1	SWAP.W	D3	ADD.W	D3,#IPWDOY+1	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	PUSHM.L	D3,D4	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	LIB	?DRMDEF	POPM.L	D3,D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRTRAME90$:	POPM.L	D2..D4	RET;--------\\; IPINV   >;--------/; Inverse une option.; in	D2.W	option (0..4,-1); out	-; mod	D7.WIPINV:	PUSHM.L	D2..D4	COMP.W	D2,#-1	JUMP',EQ 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	IPPOS		; D3/D4 <-- position/dimensions	ADD.W	D3,#IPWDOX+1	SWAP.W	D3	ADD.W	D3,#IPWDOY+1	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME90$:	POPM.L	D2..D4	RET;--------\\; IPPOS   >;--------/; Donne la position et les dimensions d'une option.; in	D2.W	option (0..4); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WIPPOS:	PUSH.L	D2	LOAD.L	D3,#H'10000*IPPOSY+IPPOSX	MUL.WU	D2,#IPDIMY	SWAP.W	D3	ADD.W	D3,D2	SWAP.W	D3	LOAD.L	D4,#H'10000*IPDIMY+IPDIMX	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCOPYSI >;===========/; Demande confirmation pour une copie avec un seul floppy.; in	A1.L	^nom unit source = nom unit destination; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCOPYSI:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_COPYSI	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OCPFFF	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"<AFINV> Copie intgralement "	.EVEN	LOAD.L	A3,A1	LIB	?AFTEXT		; affiche l'unit	LIB	?AFTIM	.ASCIZ	" avec un seul lecteur ? <AFDIR>"	.EVEN	POP.L	D420$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_COPYSI	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; COPIE ?	JUMP',EQ 70$	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:				; COPIE =>	LOAD.L	(A6)+OCPFFF,D480$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_COPYSI:	.W	10$-TDBOX_COPYSI	.W	20$-TDBOX_COPYSI	.W	0	.W	010$:	.B	ODBLABEL,1	.B	ODBTEXT	;	" Copie intgralement #MM0: avec un seul lecteur ? "	.ASCIZ	""	.B	ODBTABX,51	.B	ODBCR,ODBCR,ODBCR	.B	ODBSQUARE,0	.ASCIZ	" disquette rceptrice  formater (neuve)"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	"  COPIE  "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBMEV	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Copie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_COPYSI:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_COPYSI	.W	F1,F2,F3,CR,0		DOKF1-TKEY_COPYSI	.W	0;-----------\\; DBOXCOPYSX >;===========/; Demande de changer de disquette pour une copie avec un seul floppy.; in	A1.L	^nom unit source = nom unit destination;	D6.W	flags; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCOPYSX:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_COPYSX	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OCPFFF	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	TEST.L	D6:#0	JUMP',BS 10$	LIB	?AFTIM	.ASCIZ	"Mettez la disquette source (l'original)"	.EVEN	JUMP'	12$10$:	LIB	?AFTIM	.ASCIZ	"Mettez la disquette rceptrice (destination)"	.EVEN12$:	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"dans le lecteur "	.EVEN	LOAD.L	A3,A1	LIB	?AFTEXT		; affiche l'unit	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"(Il reste "	.EVEN	LOAD.W	D2,#2^BAFDCM	LOAD.W	D3,#4	LOAD.L	D4,D6	CLR.W	D4	SWAP.W	D4	LIB	?AFDEC		; affiche le nb de tranches	LIB	?AFTIM	.ASCIZ	" tranche"	.EVEN	COMP.W	D4,#1	JUMP',LS 16$	LOAD.B	D3,#'s	LIB	?AFCAR16$:	LIB	?AFTIM	.ASCIZ	"  copier ...)"	.EVEN20$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_COPYSX	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; COPIE ?	JUMP',EQ 70$	COMP.W	D3,#F0		; STOPPE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:				; COPIE =>80$:				; STOPPE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_COPYSX:	.W	10$-TDBOX_COPYSX	.W	20$-TDBOX_COPYSX	.W	0	.W	010$:	.B	ODBLABEL,1	.B	ODBTEXT	;	"Mettez la disquette source (l'original)"	;	"Mettez la disquette rceptrice (destination)"	.ASCIZ	""	.B	ODBTABX,44	.B	ODBCR	.B	ODBLABEL,2	.B	ODBTEXT	;	"dans le lecteur #MM1:"	.ASCIZ	""	.B	ODBCR,ODBCR	.B	ODBLABEL,3	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" C'EST FAIT "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  STOPPE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"C'est fait"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_COPYSX:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_COPYSX	.W	F1,F2,F3,CR,0		DOKF1-TKEY_COPYSX	.W	0;-----------\\; DBOXCOPYSE >;===========/; Demande de remettre la disquette originale pour une copie avec un seul floppy.; in	A1.L	^nom unit source = nom unit destination; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCOPYSE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_COPYSE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OCPFFF	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"dans le lecteur "	.EVEN	LOAD.L	A3,A1	LIB	?AFTEXT		; affiche l'unit20$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_COPYSE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; COPIE ?	JUMP',EQ 70$	COMP.W	D3,#F0		; STOPPE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:				; COPIE =>80$:				; STOPPE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_COPYSE:	.W	10$-TDBOX_COPYSE	.W	20$-TDBOX_COPYSE	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"Remettez la disquette source (l'original)"	.B	ODBCR	.B	ODBLABEL,1	.B	ODBTEXT	;	"dans le lecteur #MM1:"	.ASCIZ	""	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"(C'est fini !)"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" C'EST FAIT "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"C'est fait"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_COPYSE:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_COPYSE	.W	0;-----------\\; DBOXCOPYFF >;===========/; Demande confirmation pour une copie floppy --> autre floppy.; in	A1.L	^nom unit source;	A2.L	^nom unit destination; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCOPYFF:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A3,A2	LOAD.L	A2,#R16"TDBOX_COPYFF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OCPFFF	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A2,A3	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"<AFINV> Copie intgralement "	.EVEN	LOAD.L	A3,A1	CALL	SKIPREP	TEST.B	(A3)		; nom de fichier existe ?	JUMP',NE 10$		; oui => 10$	LOAD.L	A3,A1		; non => affiche tout10$:	LIB	?AFTEXT		; affiche l'unit source	LIB	?AFTIM	.ASCIZ	" sur "	.EVEN	LOAD.L	A3,A2	LIB	?AFTEXT		; affiche l'unit destination	LIB	?AFTIM	.ASCIZ	" ? <AFDIR>"	.EVEN	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,A2	LIB	?AFTEXT		; affiche l'unit destination	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,A2	LIB	?AFTEXT		; affiche l'unit destination	LIB	?AFTIM	.ASCIZ	"  formater (neuve)"	.EVEN	POP.L	D420$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_COPYFF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; COPIE ?	JUMP',EQ 70$	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:				; COPIE =>	LOAD.L	(A6)+OCPFFF,D480$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_COPYFF:	.W	10$-TDBOX_COPYFF	.W	20$-TDBOX_COPYFF	.W	0	.W	010$:	.B	ODBLABEL,1	.B	ODBTEXT	;	" Copie intgralement #MM0: sur #MM1: ? "	;	" Copie intgralement xxxxxxxxxxxx.DI sur #MM1: ? "	.ASCIZ	""	.B	ODBTABX,48	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"ATTENTION: Le contenu ventuel de "	.B	ODBLABEL,2	.B	ODBTEXT	;	"#MM1:"	.ASCIZ	""	.B	ODBCR	.B	ODBTABX,11	.B	ODBTEXT	.ASCIZ	"sera perdu !"	.B	ODBCR,ODBCR	.B	ODBSQUARE,0	.ASCIZ	" disquette en "	.B	ODBLABEL,3	.B	ODBTEXT	;	"#MM1:  formater (neuve)"	.ASCIZ	""	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	"  COPIE  "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBMEV	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Copie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_COPYFF:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_COPYFF	.W	F1,F2,F3,CR,0		DOKF1-TKEY_COPYFF	.W	0;-----------\\; DBOXCOPYFW >;===========/; Demande confirmation pour une copie floppy --> winch.; in	A1.L	^nom unit source;	A2.L	^nom unit destination; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCOPYFW:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A3,A2	LOAD.L	A2,#R16"TDBOX_COPYFW	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OCPFFF	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	LOAD.L	A2,A3	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"<AFINV> Copie intgralement "	.EVEN	LOAD.L	A3,A1	CALL	SKIPREP	TEST.B	(A3)		; nom de fichier existe ?	JUMP',NE 10$		; oui => 10$	LOAD.L	A3,A1		; non => affiche tout10$:	LIB	?AFTEXT		; affiche l'unit source	LIB	?AFTIM	.ASCIZ	" sur "	.EVEN	LOAD.L	A3,A2	LIB	?AFTEXT		; affiche l'unit destination	LIB	?AFTIM	.ASCIZ	" ? <AFDIR>"	.EVEN	POP.L	D420$:	CALL	DBOXEDIT	; attend une action ...	LOAD.L	A1,#R16"TKEY_COPYFW	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#F1		; COPIE ?	JUMP',EQ 70$	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:				; COPIE =>80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_COPYFW:	.W	10$-TDBOX_COPYFW	.W	20$-TDBOX_COPYFW	.W	0	.W	010$:	.B	ODBLABEL,1	.B	ODBTEXT	;	" Copie intgralement #MM0: sur #MM1: ? "	;	" Copie intgralement xxxxxxxxxxxx.DI sur #MM1: ? "	.ASCIZ	""	.B	ODBTABX,48	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	"  COPIE  "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F0,TDBMEV	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Copie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_COPYFW:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_COPYFW	.W	F1,F2,F3,CR,0		DOKF1-TKEY_COPYFW	.W	0;----------\\; DBOXPREND >;==========/; Demande le nom du fichier .DI  sauver.; in	A3.L	^nom; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPREND:	PUSHM.L	D1,D2,D4,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3		; A5 <-- ^nom	LOAD.L	A4,#R16"TXDI	; A4 <-- ^extension	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A2,#R16"TDBOX_PREND	CLR.L	D4		; D4 <-- fanions	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1!2^BDBIOOBJ	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_PREND	DBOX_	EXTEND		; dialogue ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_PREND:	.B	LDBOX_PREND	.B	ODBTEXT	.ASCIZ	" Lit un fichier .DI sur disque dur"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	" contenant une copie d'une disquette. "	.B	ODBCRLDBOX_PREND =	.-TDBOX_PREND-1	.EVEN;----------\\; DBOXSAUVE >;==========/; Demande le nom du fichier .DI  sauver.; in	A3.L	^nom; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXSAUVE:	PUSHM.L	D1,D2,D4,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3		; A5 <-- ^nom	LOAD.L	A4,#R16"TXDI	; A4 <-- ^extension	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A2,#R16"TDBOX_SAUVE	CLR.L	D4		; D4 <-- fanions	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1!2^BDBIOOBJ	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_EXTRAIT	DBOX_	EXTEND		; dialogue ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_SAUVE:	.B	LDBOX_SAUVE	.B	ODBTEXT	.ASCIZ	" Cre un fichier .DI sur disque dur"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	" contenant une copie de la disquette. "	.B	ODBCRLDBOX_SAUVE =	.-TDBOX_SAUVE-1	.EVEN;-----------\\; DBOXDELETE >;===========/; Demande  l'utilisateur s'il faut dtruit ou non un fichier.; Ne fait pas l'appel FOS,?DELETE !; in	A3.L	^nom du fichier; out	D7.W	erreur (ERKSTO si rponse "non"); mod	D7.WDBOXDELETE:	PUSHM.L	D1..D4,A3,A5	CALL	DBOXOPEN1	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	CLR.L	D3		; D3 <-- flags	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_DETRUIT	DBOX_	EXTEND		; dialogue ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',EQ 90$	LOAD.W	D7,#ERKSTO	; D7 <-- rponse "non"90$:	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	POPM.L	D1..D4,A3,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande si l'on veut quitter FCOPY.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXQUITTE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_IO:	.ASCIZ	"FCOPY"		; nom du logiciel	.ASCIZ	"Mfichier"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN;---------\\; WAITDBOX >;=========/; Met la dbox d'attente.; in	-; out	D7.W	erreur; mod	D7.WWAITDBOX:	PUSHM.L	D2..D5,A2	CALL	WAITMOUSE	; souris: met le sablier	CALL	NORMDBOX	; enlve si dj l	LOAD.L	A2,#R16"TDBOX_WAIT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE 90$	LOAD.L	(A6)+OCPCDB,D5	CLR.W	(A6)+OCPASC+OSCHTV ; ascenseur pas dessin90$:	POPM.L	D2..D5,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; AFFTDBOX >;=========/; Affiche un texte dans la dbox d'attente.; in	A3.L	^texte <0>; out	-; mod	D7.WAFFTDBOX:	PUSHM.L	D2..D5,A3	LOAD.L	D5,(A6)+OCPCDB	; D5 <-- canal dbox	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche le texte	LOAD.B	D3,#EFLI	LIB	?AFCAR		; efface la fin de la ligne	POPM.L	D2..D5,A3	RET;---------\\; AFFNDBOX >;=========/; Affiche le nb de blocs restant dans la dbox d'attente.; in	D1.L	nb de blocs restant; out	-; mod	D7.WAFFNDBOX:	PUSHM.L	D2..D5,A3,A5	LOAD.L	A5,#(A6)+OCPASC	; A5 <-- ^variables de l'ascenseur	TEST.W	(A5)+OSCHTV	; ascenseur dj dessin ?	JUMP',NE 20$		; oui => 20$				; non => 	LOAD.L	D5,(A6)+OCPCDB	; D5 <-- canal dbox	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFCY	LOAD.W	(A5)+OSCDEBL,D3	SWAP.W	D3	LOAD.W	(A5)+OSCDEBO,D3	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,D3	SUB.W	D4,D3	LOAD.W	(A5)+OSCHTR,D4	LOAD.W	(A5)+OSCHTV,D1	SET.B	(A5)+OSCHOR	SCROLL_	DRAW		; dessine l'ascenseur20$:	LOAD.W	D3,(A5)+OSCHTV	SUB.W	D3,D1	LOAD.W	(A5)+OSCPOSV,D3	SCROLL_	UPDATE		; dplace l'ascenseur	LOAD.L	D5,(A6)+OCPCDB	; D5 <-- canal dbox	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"  Il reste "	.EVEN	LOAD.W	D2,#2^BAFDCM	LOAD.W	D3,#6	LOAD.L	D4,D1	LIB	?AFDEC		; affiche le nombre de blocs	LIB	?AFTIM	.ASCIZ	" blocs  copier ...<EFLI>"	.EVEN	POPM.L	D2..D5,A3,A5	RET;---------\\; AFFCDBOX >;=========/; Affiche un caractre dans la cabine de l'ascenseur.; in	D3.B	caractre; out	-; mod	D7.WAFFCDBOX:	PUSHM.L	D1..D4,A5	LOAD.L	A5,#(A6)+OCPASC	; A5 <-- ^variables de l'ascenseur	TEST.W	(A5)+OSCHTV	; ascenseur dj dessin ?	JUMP,EQ 90$		; non => 90$				; oui =>	LOAD.B	D1,D3	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfini une trame pour effacer	LOAD.W	D3,(A5)+OSCDEBL	ADD.W	D3,#2	SWAP.W	D3	LOAD.W	D3,(A5)+OSCDEBO	ADD.W	D3,(A5)+OSCPOSR	ADD.W	D3,#LGSCROLL+1	LOAD.W	D4,#LGSCROLL-4	SWAP.W	D4	LOAD.W	D4,#LGSCROLL-1	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface dans la cabine	SR.W	D4,#1	ADD.W	D3,D4	LOAD.W	D4,(A0)+ODFCX	SR.W	D4,#1	SUB.W	D3,D4	ADD.W	D3,(A0)+ODFC1X	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	LOAD.W	D4,(A0)+ODFC1Y	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LIB	?SETCURS	; positionne le curseur	LIB	?AFTIM	.B	AFTOUT	.B	MODCAR,INVDOT	.B	0	.EVEN	LOAD.B	D3,D1	LIB	?AFCAR		; affiche le caractre	LIB	?AFTIM	.B	MODCAR,SETDOT	.B	AFNORM	.B	0	.EVEN90$:	POPM.L	D1..D4,A5	RET;---------\\; NORMDBOX >;=========/; Enlve la dbox d'attente.; in	-; out	-; mod	-NORMDBOX:	PUSHM.L	D5,D7	TEST.L	(A6)+OCPCDB	JUMP',EQ 90$	LOAD.L	D5,(A6)+OCPCDB	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys	CLR.L	(A6)+OCPCDB90$:	POPM.L	D5,D7	RETTDBOX_WAIT:	.W	10$-TDBOX_WAIT	.W	20$-TDBOX_WAIT	.W	0,010$:	.B	ODBCR,ODBCR,ODBCR	.B	ODBLABEL,1	.B	ODBTEXT	;	"       Attendez un instant ...      "	.ASCIZ	"                                    "	.B	ODBCR,ODBCR,ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN;--------\\; ERCALL  >;========/; Essaye de rsoudre une erreur.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,A2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.L	A2,#0		; A2 <-- mode "tendu";;?	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,A2	TEST.W	D7		; retour EQ/NE	RETERCALL2:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel;;?	LOAD.L	A2,#0		; A2 <-- mode "tendu"	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXOPEN >;---------/; Ouvre une dbox.; in	A2.L	table;	D2.W	mode; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WDBOXOPEN:	CALL	NORMMOUSE	; remet la flche	DBOX_	OPEN		; ouvre la dbox	RETDBOXOPEN1:	CALL	NORMMOUSE	; remet la flche	RET;---------\\; DBOXEDIT >;---------/; Edite une dbox.; in	A3.L	^dbut ligne;	A4.L	^dans la ligne;	D4.L	fanions;	D5.L	canal; out	D3.W	dernire touche;	D4.L	fanions;	A4.L	^dans la ligne; mod	D3.L, D4.L, D7.W, A4.LDBOXEDIT:	PUSH.W	D210$:	DBOX_	EDIT		; dite ...	COMP.W	D3,#KEYMGR	JUMP,EQ 10$	COMP.W	D3,#KEYMMR	; bouton de souris relch ?	JUMP,EQ 10$		; oui => 10$	COMP.W	D3,#KEYMDR	JUMP,EQ 10$	POP.W	D2	RET;----------\\; DBOXCLOSE >;----------/; Ferme une dbox.; in	D5.L	canal; out	D7.W	erreur; mod	D7.WDBOXCLOSE:	DBOX_	CLOSE		; ferme la dboxDBOXCLOSE1:	CALL	AFMENU		; refait les soft-keys	RETDOKCR:	LOAD.W	D3,#CR	RETDOKEND:	LOAD.W	D3,#END	RETDOKOUI:	LOAD.W	D3,#'O	RETDOKNON:	LOAD.W	D3,#'N	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RET	.END