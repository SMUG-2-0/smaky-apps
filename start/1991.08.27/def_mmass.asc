	.TITLE	DEF_MMASS.ASC;	--------------------------------------;		(C) 1991 - Daniel Roux;	--------------------------------------;	Source du programme DEF_MMASS.CODE	.PROC	M680002	.RADIX	10.	.HEXDEFREV	=	1		; rvisionDEFVERS	=	2		; version;	Date		Amliorations; --------------------------------------------------------------------------------------------------; 1.2	03.07.91	retourne "U" pour que START redessine les units physiques; 1.1	24.05.91	priorit plus leve (23 -> 11);			pilote $HFLEX accessible avec un bouton;			4 icnes pour le type grises si "rien"; 1.0	16.05.91	premire version	.REF	SMAKY	.REF	MODULES	.REF	COLORS;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;SMAKY300 = 7OINVOL = OINSTA+4		; volume du h-p dans 100_INFOFOS?MMAssign	=	FOS_BASE+108	; dfini la mmoire de masse pour touches de contrleFOS?MMDeassign	=	FOS_BASE+109	; supprime l'assignation de mmFOS?MMVassign	=	FOS_BASE+110	; donne le nom de la mmoire de masse selon contrle;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.REV	DEFREV,DEFVERS;;?	.HEADER	OBXSOVER.L OVERLAY	; faire "HEADER DEF_MMASS.CODE 16/O" !!!	.CODE	800,11,B'100111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LBUDIS	=	20LBULINE	=	10KEYDBOX	=	H'7E00		; "touche" pour dbox; Fanions; -------BM0	=	0		; M0BM1	=	1		; M1BM2	=	2		; SHIFT-M0BM3	=	3		; SHIFT-M1BRIEN	=	8		; rienBFLO0	=	9		; $FLO_0BFLO1	=	10		; $FLO_1BTEAC0	=	11		; $FTEAC_0BTEAC1	=	12		; $FTEAC_1BFLEX0	=	13		; $HFLEX_0BOTHER	=	15		; autre..BTYPE0	=	16		; type 0BTYPE1	=	17		; type 1BTYPE2	=	18		; type 2BTYPE3	=	19		; type 3; Variables; ---------	.LOC	0OPLCOM:	.BLKB	4		; ^ligne de commandeOBUDIS:	.BLKB	LBUDIS		; buffer temporaireOMOUSE:	.BLKB	1		; mode souris initialOMACHINE:.BLKB	1		; type de la machine (SMAKY*)	.EVENOCHMENU:.BLKB	4		; canal des soft-keysOBULINE:.BLKB	LBULINE		; ligne en ditionLGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	CALL	OVERLAY	LIB	?CLOLIB	FOS	?STOPOVERLAY:	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE EXIT$	GESMEM	?CLEARMEM	; met TOUTES les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; OPLCOM <-- ^ligne de commande	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	NTREL	?GETMACHINE	RL.L	D4,#8	LOAD.B	(A6)+OMACHINE,D4	LOAD.L	A3,(A6)+OPLCOM	LOAD.B	D3,#'I	LIB	?IFSWITCH	; excut avec /i ?	JUMP',EQ INIT$		; oui => INIT$	CALL	DBOXMAIN	; appel dbox principale ...	JUMP',EQ END$	JUMP'	NOOVER$INIT$:;	...	JUMP'	END$NOOVER$:	LOAD.W	D7,#-1		; D7 <-- demande une excution normaleEND$:	PUSH.W	D7	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre les variables	POP.W	D7EXIT$:	RET;---------\\; DBOXMAIN >;=========/; Modifie quelques informations gnrales sur la machine.; in	-; out	D7.W	erreur; mod	D7.WDBOXMAIN:	PUSHM.L	D0..D6,A1..A5	LIB	?PUSHMENU	; sauve les soft-keys	LOAD.L	(A6)+OCHMENU,D5	LIB	?GMOUSE	LOAD.B	(A6)+OMOUSE,D3	LOAD.W	D3,#2	LIB	?MOUSE		; souris par le clavier	CALL	NORMMOUSE	; souris: enlve le sablier	LOAD.L	D4,#2^BM0	CALL	FANGET	LOAD.L	A2,#R16"TDBOX_MAIN	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#100!2^BDBGCLABEL	CALL	DBOXHLINE	LOAD.W	D2,#101!2^BDBGCLABEL	CALL	DBOXHLINE	CALL	DRAWTYPE	; dessine les types	CALL	DRAWARROW	; dessine la flche	CLR.W	D0		; D0 <-- nb de modificationsNLINE$:	LOAD.L	A3,#(A6)+OBULINE	LOAD.L	A4,A3NLINE2$:	TEST.B	(A4+)	JUMP,NE NLINE2$	DEC.L	A4LOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_MAIN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP,EQ DACCORD$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A3)	JUMP	LOOP$KEYDBOX$:	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO PUT$	LOAD.L	D1,#H'FFFF00FF	COMP.B	D3,#16	JUMP',LO MASK$	LOAD.L	D1,#H'FF00FFFF	COMP.B	D3,#24	JUMP',LO MASK$	JUMP	LOOP$PUT$:	CALL	FANPUT		; mj. selon les fanions	AND.L	D4,D1		; D4 <-- teint toute une range	TSET.L	D4:D3		; D4 <-- allume juste un bouton	CALL	FANGET		; D4 <-- selon nouvelle touche	CALL	DRAWARROW	; dessine la flche	CALL	DRAWTYPE	; dessine les types	JUMP	NLINE$MASK$:	AND.L	D4,D1		; D4 <-- teint toute une range	TSET.L	D4:D3		; D4 <-- allume juste un bouton	CALL	DRAWTYPE	; dessine les types	INC.W	D0		; D0 <-- une modification de plus	JUMP	LOOP$DACCORD$:			; D'ACCORD =>	CALL	FANPUT		; mj. selon les fanions	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D7	TEST.W	D0		; y'a-t-il eu des modifications ?	JUMP',EQ EXIT$		; non => EXIT$	CALL	WAITMOUSE	; souris: met le sablier	FOS	?OPINFO	LOAD.W	D4,#1	FOS	?CLINFO		; met  jour 100_INFO sur le disque	LOAD.B	D3,#'U	CALL	RETURN		; indique qu'il faudra redessiner les units physiques	CLR.W	D7		; D7 <-- okEXIT$:	PUSH.W	D7	LOAD.B	D3,(A6)+OMOUSE	LIB	?MOUSE		; remet le mode souris initial	LOAD.L	D5,(A6)+OCHMENU	LIB	?POPMENU	; restitue les soft-keys	CALL	NORMMOUSE	; souris: enlve le sablier	POP.W	D7	POPM.L	D0..D6,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_MAIN:	.W	10$-TDBOX_MAIN	.W	20$-TDBOX_MAIN	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"Choix des mmoires de masse action-"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"nes par les touches (M0) et (M1) :"	.B	ODBCR,ODBCR	.B	ODBBOX,KEYDBOX/H'100,BM0,TDBOMBRE	.ASCIZ	" M0 "	.B	ODBBOX,KEYDBOX/H'100,BM1,TDBOMBRE	.ASCIZ	" M1 "	.B	ODBBOX,KEYDBOX/H'100,BM2,TDBOMBRE	.ASCIZ	"SHIFT-M0"	.B	ODBBOX,KEYDBOX/H'100,BM3,TDBOMBRE	.ASCIZ	"SHIFT-M1"	.B	ODBCR,ODBCR2	.B	ODBTABX,2	.B	ODBLABEL,BM0	.B	ODBTEXT,0	.B	ODBTABX,2+7	.B	ODBLABEL,BM1	.B	ODBTEXT,0	.B	ODBTABX,2+7+9	.B	ODBLABEL,BM2	.B	ODBTEXT,0	.B	ODBTABX,2+7+9+11	.B	ODBLABEL,BM3	.B	ODBTEXT,0	.B	ODBCR2	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLCIRCLE,BRIEN!2^7!2^6,KEYDBOX/H'100,BRIEN	.ASCIZ	"   rien"	.B	ODBTABX,30-7	.B	ODBLABEL,50	.B	ODBTEXT	.ASCIZ	"icne"	.B	ODBTABX,30	.B	ODBLABEL,BTYPE0	.B	ODBLCIRCLE,BTYPE0!2^7!2^6,KEYDBOX/H'100,BTYPE0	.ASCIZ	" "	.B	ODBCR	.B	ODBLCIRCLE,BFLO0!2^7!2^6,KEYDBOX/H'100,BFLO0	.ASCIZ	""	.B	ODBLCIRCLE,BFLO1!2^7!2^6,KEYDBOX/H'100,BFLO1	.ASCIZ	""	.B	ODBTEXT	.ASCIZ	" $FLO   0 ou 1"	.B	ODBTABX,30	.B	ODBLABEL,BTYPE1	.B	ODBLCIRCLE,BTYPE1!2^7!2^6,KEYDBOX/H'100,BTYPE1	.ASCIZ	" "	.B	ODBCR	.B	ODBLCIRCLE,BTEAC0!2^7!2^6,KEYDBOX/H'100,BTEAC0	.ASCIZ	""	.B	ODBLCIRCLE,BTEAC1!2^7!2^6,KEYDBOX/H'100,BTEAC1	.ASCIZ	""	.B	ODBTEXT	.ASCIZ	" $FTEAC 0 ou 1"	.B	ODBTABX,30	.B	ODBLABEL,BTYPE2	.B	ODBLCIRCLE,BTYPE2!2^7!2^6,KEYDBOX/H'100,BTYPE2	.ASCIZ	" "	.B	ODBCR	.B	ODBLCIRCLE,BFLEX0!2^7!2^6,KEYDBOX/H'100,BFLEX0	.ASCIZ	""	.B	ODBTEXT	.ASCIZ	"   $HFLEX"	.B	ODBTABX,30	.B	ODBLABEL,BTYPE3	.B	ODBLCIRCLE,BTYPE3!2^7!2^6,KEYDBOX/H'100,BTYPE3	.ASCIZ	" "	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,BOTHER!2^7!2^6,KEYDBOX/H'100,BOTHER	.ASCIZ	"  "	.B	ODBCLINE,8+2	.B	ODBCR,ODBCR2	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" TERMINE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Termine"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_MAIN:	.W	F1,F2,F3,0		DOKF1-TKEY_MAIN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MAIN	.W	0;---------\\; DRAWTYPE >;=========/; Dessine les types.; in	D4.L	fanions; out	D4.L	fanions ajusts; mod	D4.L, D7.WDRAWTYPE:	PUSHM.L	D2,D3,A4	TEST.L	D4:#BRIEN	JUMP,BS GREY$	PUSH.L	D4	LOAD.W	D2,#50!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#BTYPE0!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#BTYPE1!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#BTYPE2!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#BTYPE3!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	POP.L	D4	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_DBSET	LIB	?COLORSR	LOAD.L	D3,#COLOR_DBCLEAR	LIB	?COLORCR	LOAD.L	A4,#R16"TICO0	LOAD.W	D3,#-11	SWAP.W	D3	CLR.W	D3	LOAD.W	D2,#BTYPE0!2^BDBGCLABEL	CALL	DRAWICO	LOAD.L	A4,#R16"TICO1	LOAD.W	D2,#BTYPE1!2^BDBGCLABEL	CALL	DRAWICO	LOAD.L	A4,#R16"TICO2	LOAD.W	D2,#BTYPE2!2^BDBGCLABEL	CALL	DRAWICO	LOAD.L	A4,#R16"TICO3	LOAD.W	D2,#BTYPE3!2^BDBGCLABEL	CALL	DRAWICO	LIB	?COLORPOP;	TEST.L	D4:#BTYPE0;	JUMP,BS EXIT$	TEST.L	D4:#BTYPE1	JUMP,BS EXIT$	TEST.L	D4:#BTYPE2	JUMP,BS EXIT$	TEST.L	D4:#BTYPE3	JUMP,BS EXIT$	TSET.L	D4:#BTYPE0	; D4 <-- au moins un type allum !	JUMP	EXIT$GREY$:	PUSH.L	D4	LOAD.W	D2,#50!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BTYPE0!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BTYPE1!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BTYPE2!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BTYPE3!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	POP.L	D4	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_DBSET	LIB	?COLORSR	LOAD.L	D3,#COLOR_DBCLEAR	LIB	?COLORCR	LOAD.L	A4,#R16"TICOV	LOAD.W	D3,#-11	SWAP.W	D3	CLR.W	D3	LOAD.W	D2,#BTYPE0!2^BDBGCLABEL	CALL	DRAWICO	LOAD.W	D2,#BTYPE1!2^BDBGCLABEL	CALL	DRAWICO	LOAD.W	D2,#BTYPE2!2^BDBGCLABEL	CALL	DRAWICO	LOAD.W	D2,#BTYPE3!2^BDBGCLABEL	CALL	DRAWICO	LIB	?COLORPOP	AND.L	D4,#H'FF00FFFF	; D4 <-- teint tous les typesEXIT$:	POPM.L	D2,D3,A4	RET;----------\\; DRAWARROW >;==========/; Dessine la bonne flche.; in	D4.L	fanions; out	-; mod	D7.WDRAWARROW:	PUSHM.L	D2,D3,A4	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_DBSEL	LIB	?COLORSR	LOAD.L	D3,#COLOR_DBCLEAR	LIB	?COLORCR	LOAD.W	D3,#-14	SWAP.W	D3	CLR.W	D3	LOAD.L	A4,#R16"TICOV	LOAD.W	D2,#BM0!2^BDBGCLABEL	CALL	DRAWICO	LOAD.L	A4,#R16"TICOV	LOAD.W	D2,#BM1!2^BDBGCLABEL	CALL	DRAWICO	LOAD.L	A4,#R16"TICOV	LOAD.W	D2,#BM2!2^BDBGCLABEL	CALL	DRAWICO	LOAD.L	A4,#R16"TICOV	LOAD.W	D2,#BM3!2^BDBGCLABEL	CALL	DRAWICO	LOAD.L	A4,#R16"TICOF	LOAD.W	D2,#BM0!2^BDBGCLABEL	TEST.L	D4:#BM0	JUMP',BS DRAW$	LOAD.W	D2,#BM1!2^BDBGCLABEL	TEST.L	D4:#BM1	JUMP',BS DRAW$	LOAD.W	D2,#BM2!2^BDBGCLABEL	TEST.L	D4:#BM2	JUMP',BS DRAW$	LOAD.W	D2,#BM3!2^BDBGCLABELDRAW$:	CALL	DRAWICO	LIB	?COLORPOP	POPM.L	D2,D3,A4	RET;--------\\; FANGET  >;========/; Cherche les fanions pour une touche donne.; in	D4.L	fanions (BM0..3); out	D4.L	fanions; mod	D4.L, D7.WFANGET:	PUSHM.L	D0..D3,A2..A4	LOAD.L	D0,D4	AND.L	D0,#H'FF0000FF	CLR.B	(A6)+OBULINE	CLR.W	D4	TEST.L	D0:#BM0	JUMP',BS VASS$	INC.W	D4	TEST.L	D0:#BM1	JUMP',BS VASS$	INC.W	D4	TEST.L	D0:#BM2	JUMP',BS VASS$	INC.W	D4VASS$:	FOS	?MMVASSIGN	; A3/D3 <-- ^nom/type	JUMP,NE RIEN$	TEST.B	(A3)	JUMP,EQ RIEN$	ADD.W	D3,#BTYPE0	TSET.L	D0:D3		; D0 <-- bouton type 0..3	LOAD.L	A4,A3	LOAD.L	A2,#R16"TERM$	LOAD.W	D3,#BFLO0	LOAD.L	A3,#R16"NFLO0$	LIB	?CPSTRING	JUMP',NC FOUND$	LOAD.W	D3,#BFLO1	LOAD.L	A3,#R16"NFLO1$	LIB	?CPSTRING	JUMP',NC FOUND$	LOAD.W	D3,#BTEAC0	LOAD.L	A3,#R16"NTEAC0$	LIB	?CPSTRING	JUMP',NC FOUND$	LOAD.W	D3,#BTEAC1	LOAD.L	A3,#R16"NTEAC1$	LIB	?CPSTRING	JUMP',NC FOUND$	LOAD.W	D3,#BFLEX0	LOAD.L	A3,#R16"NFLEX0$	LIB	?CPSTRING	JUMP',NC FOUND$	LOAD.L	A3,#(A6)+OBULINEXFER$:	LOAD.B	(A3+),(A4+)	; OBULINE <-- nom physique	JUMP,NE XFER$	LOAD.W	D3,#BOTHERFOUND$:	TSET.L	D0:D3		; D0 <-- bouton nom	JUMP'	END$RIEN$:	OR.L	D0,#2^BRIEN!2^BTYPE0END$:	LOAD.L	D4,D0	POPM.L	D0..D3,A2..A4	RETNFLO0$:	.ASCIZ	"$FLO_0*"NFLO1$:	.ASCIZ	"$FLO_1*"NTEAC0$:.ASCIZ	"$FTEAC_0*"NTEAC1$:.ASCIZ	"$FTEAC_1*"NFLEX0$:.ASCIZ	"$HFLEX_0*"TERM$:	.B	0,CR,-1	.EVEN;--------\\; FANPUT  >;========/; Met  jour en fonction des fanions d'une touche donne.; in	D4.L	fanions; out	-; mod	D7.WFANPUT:	PUSHM.L	D0..D4,A3,A4	LOAD.L	D0,D4	CLR.W	D4	TEST.L	D0:#BM0	JUMP',BS VASS$	INC.W	D4	TEST.L	D0:#BM1	JUMP',BS VASS$	INC.W	D4	TEST.L	D0:#BM2	JUMP',BS VASS$	INC.W	D4VASS$:	TEST.L	D0:#BRIEN	JUMP,BS DEASS$	LOAD.L	A3,#R16"NFLO0$	TEST.L	D0:#BFLO0	JUMP',BS NAME$	LOAD.L	A3,#R16"NFLO1$	TEST.L	D0:#BFLO1	JUMP',BS NAME$	LOAD.L	A3,#R16"NTEAC0$	TEST.L	D0:#BTEAC0	JUMP',BS NAME$	LOAD.L	A3,#R16"NTEAC1$	TEST.L	D0:#BTEAC1	JUMP',BS NAME$	LOAD.L	A3,#R16"NFLEX0$	TEST.L	D0:#BFLEX0	JUMP',BS NAME$	LOAD.L	A3,#(A6)+OBULINENAME$:	CLR.W	D3	TEST.L	D0:#BTYPE0	JUMP',BS ASS$	INC.W	D3	TEST.L	D0:#BTYPE1	JUMP',BS ASS$	INC.W	D3	TEST.L	D0:#BTYPE2	JUMP',BS ASS$	INC.W	D3	TEST.L	D0:#BTYPE3	JUMP',BS ASS$	CLR.W	D3ASS$:	FOS	?MMASSIGN	JUMP'	EXIT$DEASS$:	FOS	?MMDEASSIGNEXIT$:	POPM.L	D0..D4,A3,A4	RETNFLO0$:	.ASCIZ	"$FLO_0"NFLO1$:	.ASCIZ	"$FLO_1"NTEAC0$:.ASCIZ	"$FTEAC_0"NTEAC1$:.ASCIZ	"$FTEAC_1"NFLEX0$:.ASCIZ	"$HFLEX_0"	.EVEN;----------\; DBOXHLINE >;==========/; Trace une ligne horizontale dans une dbox.; in	D2.W	rang de l'objet; out	D3.L	position d'arrive; mod	D3.L, D7.WDBOXHLINE:	PUSHM.L	D2,D4,A4	DBOX_	GETCO	CLR.W	D3	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2,D4,A4	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs DBOX_EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A3LOOP$:	TEST.B	(A3+)	JUMP',EQ EXIT$	COMP.B	(A3)-1,#CR	JUMP,NE LOOP$	CLR.B	(A3)-1		; remplace le <CR> par <0>EXIT$:	POP.L	A3	RET;--------\\; DRAWICO >;========/; Affiche une icne dans une dbox.; in	A4.L	^dx,dy,matrice icne;	D2.W	rang dans dbox;	D3.L	+/- dplacement (dy;dx);	D5.L	canal dbox; out	-; mod	D7.WDRAWICO:	PUSHM.L	D3,D4,A3	PUSH.L	D3	DBOX_	GETCO	POP.L	D3	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3;	SWAP.W	D3;	SWAP.W	D4	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	LOAD.L	(A3)+1,D4	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#LOADDOT	LOAD.W	D3,#10	LIB	?STRING	POPM.L	D3,D4,A3	RET;--------\\; RETURN  >;========/; Retourne un paramtre au programme appelant.; Le programme appelant doit excuter une ligne de commande;	DEF_XXX.CODE ^ad/Z; o "ad" est l'adresse (hexadcimale) o mettre le paramtre; en retour.; START ne gnre le "^ad/Z" que si le fichier START.INFO; contient un /R (par exemple "DEF_COLOR"/R) !; Actuellement, START accepte les paramtres suivants :;	"R"	redessine toute la fentre; in	D3.B	paramtre  retourner; out	-; mod	D7.WRETURN:	PUSHM.L	D2..D4,A3,A4	LOAD.B	D2,D3		; D2 <-- paramtre	LOAD.L	A3,(A6)+OPLCOMLOOP$:	LOAD.B	D3,#'Z	LIB	?IFSWITCH	; "^12345678/Z" trouv ?	JUMP',EQ FOUND$		; oui => FOUND$	LIB	?SKPNAM	JUMP,EQ LOOP$	JUMP'	EXIT$FOUND$:	COMP.B	(A3+),#'^	; commence par "^" ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.L	A4,A3	CALL	GETHNUM		; D4 <-- adresse o mettre la rponse	LOAD.L	A4,D4	LOAD.B	(A4),D2		; zone rponse <-- paramtreEXIT$:	POPM.L	D2..D4,A3,A4	RET;--------\\; GETHNUM >;========/; Lit un nombre hexadcimal.; in	A4.L	^nombre hexa; out	D4.L	nombre hexa; mod	D4.L, D7.WGETHNUM:	PUSH.W	D3	CLR.L	D4LOOP$:	LOAD.B	D3,(A4)	SUB.B	D3,#'0	JUMP',LO EXIT$	COMP.B	D3,#9	JUMP',LS PUT$	SUB.B	D3,#'A-'9-1	JUMP',LO EXIT$	COMP.B	D3,#15	JUMP',HI EXIT$PUT$:	SL.L	D4,#4	OR.B	D4,D3		; D4 <-- nouveau digit	INC.L	A4	JUMP	LOOP$EXIT$:	POP.W	D3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETTICO0:	.B	16,14	.W	B'1111111111111100	.W	B'1101011111111100	.W	B'1010101111111100	.W	B'1101011111111000	.W	B'1111111111111000	.W	B'1111110011111100	.W	B'1111100001111100	.W	B'1111100001011100	.W	B'1111110011111100	.W	B'1111111111111100	.W	B'1111110011111100	.W	B'1111110011111100	.W	B'1111110011111100	.W	B'1111111111111100TICO1:	.B	16,14	.W	B'1111111111110000	.W	B'1010100000101000	.W	B'1110100000110100	.W	B'1010100000101100	.W	B'1101111111010100	.W	B'1010101010101100	.W	B'1101111111110100	.W	B'1010000000011100	.W	B'1110000000010100	.W	B'1010000000011100	.W	B'1110000000010100	.W	B'1010000000011100	.W	B'1110000000010100	.W	B'1111111111111100TICO2:	.B	16,14	.W	B'0111111111111000	.W	B'1010110010101100	.W	B'1101010011010100	.W	B'1010110010101100	.W	B'1101011111010100	.W	B'1010101010101100	.W	B'1111111111110100	.W	B'1010000000011100	.W	B'1110000000010100	.W	B'1010000000011100	.W	B'1110000000010100	.W	B'1011111111111100	.W	B'1101010101010100	.W	B'0111111111111000TICO3:	.B	16,14	.W	B'1111111111111100	.W	B'1010101010101100	.W	B'1101010101010100	.W	B'1010101010101100	.W	B'1101010101010100	.W	B'1010101010101100	.W	B'1101010101010100	.W	B'1010101010101100	.W	B'1101010101010100	.W	B'1010101010101100	.W	B'1101010101010100	.W	B'1010101010101100	.W	B'1101010101010100	.W	B'1111111111111100TICOV:	.B	16,14	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000TICOF:	.B	16,14	.W	B'0000111111110000	.W	B'0000111111110000	.W	B'0000111111110000	.W	B'0000111111110000	.W	B'0000111111110000	.W	B'0000111111110000	.W	B'1111111111111111	.W	B'0111111111111110	.W	B'0011111111111100	.W	B'0001111111111000	.W	B'0000111111110000	.W	B'0000011111100000	.W	B'0000001111000000	.W	B'0000000110000000	.EVEN	.END	START