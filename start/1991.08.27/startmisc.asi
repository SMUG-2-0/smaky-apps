	.SBTTL	STARTMISC;--------\\; AFFREP  >;========/; Affiche un nom de dossier.; in	A4.L	^nom de dossier(s); out	-; mod	D7.WAFFREP:	PUSHM.L	D3,A3	LOAD.L	A3,A4	CALL	SKIPREP		; A3 <-- ^fin du nom	LOAD.L	D3,A3	SUB.L	D3,A4		; D3 <-- lg	LOAD.L	A3,A4		; A3 <-- ^dbut du nom	LIB	?STRING		; affiche	POPM.L	D3,A3	RET;--------\\; PUTDATE >;========/; Prpare une date en ASCIZ.; in	D3.L	date en BCD: | |j|m|a|;	A3.L	^buffer pour; out	(A3+)	date en ASCIZ; mod	D7.WPUTDATE:	PUSHM.L	D3,A3	RL.L	D3,#8	RL.L	D3,#8	CALL	PUTBCD		; buffer <-- jour	LOAD.B	(A3+),#'/	RL.L	D3,#8	CALL	PUTBCD		; buffer <-- mois	LOAD.B	(A3+),#'/	RL.L	D3,#8	CALL	PUTBCD		; buffer <-- anne	CLR.B	(A3)	POPM.L	D3,A3	RET;--------\\; PUTTIME >;========/; Prpare une heure en ASCIZ.; in	D3.L	heure en BCD: | |h|m|s|;	A3.L	^buffer pour; out	(A3+)	date en ASCIZ; mod	D7.WPUTTIME:	PUSHM.L	D3,A3	RL.L	D3,#8	RL.L	D3,#8	CALL	PUTBCD		; buffer <-- heure	LOAD.B	(A3+),#':	RL.L	D3,#8	CALL	PUTBCD		; buffer <-- minutes	LOAD.B	(A3+),#':	RL.L	D3,#8	CALL	PUTBCD		; buffer <-- secondes	CLR.B	(A3)	POPM.L	D3,A3	RET;--------\\; PUTBCD  >;--------/; in	D3.B	byte en BCD;	A3.L	^dans buffer; out	A3.L	^plus loin; mod	A3.LPUTBCD:	PUSH.W	D4	LOAD.B	D4,D3	SR.B	D4,#4	ADD.B	D4,#'0	LOAD.B	(A3+),D4	; buffer <-- dizaines	LOAD.B	D4,D3	AND.B	D4,#H'0F	ADD.B	D4,#'0	LOAD.B	(A3+),D4	; buffer <-- units	POP.W	D4	RET;--------\\; GETDATE >;========/; Donne une date en BCD.; in	A3.L	^date en ASCIZ; out	D3.L	date en BCD: | |j|m|a|; mod	D7.W;--------\\; GETTIME >;========/; Donne une heure en BCD.; in	A3.L	^heure en ASCIZ; out	D3.L	heure en BCD: | |h|m|s|; mod	D7.WGETDATE:GETTIME:	PUSHM.L	D4,A3	CLR.L	D3	CALL	GETBCD		; D4 <-- jour/heures	LOAD.B	D3,D4	SL.L	D3,#8	CALL	GETBCD		; D4 <-- mois/minutes	LOAD.B	D3,D4	SL.L	D3,#8	CALL	GETBCD		; D4 <-- anne/secondes	LOAD.B	D3,D4	POPM.L	D4,A3	RET;--------\\; GETBCD  >;--------/; in	A3.L	^dans buffer; out	A3.L	^plus loin;	D4.B	byte en BCD; mod	D4.L, A3.LGETBCD:	PUSH.W	D3	CLR.W	D410$:	CLR.W	D3	LOAD.B	D3,(A3)	JUMP',EQ 90$	INC.L	A3	COMP.B	D3,#'0	JUMP',LO 90$	COMP.B	D3,#'9	JUMP',HI 90$	SUB.B	D3,#'0	SL.W	D4,#4	ADD.W	D4,D3	JUMP	10$90$:	POP.W	D3	RET;---------\\; IFSWITCH >;=========/; Regarde si un nom est suivi d'un switch.;	TOTO/X;	"TOTO"/X;	"TOTO PARAM"/X; in	A3.L	^nom;	D3.B	switch cherch; out	D7.W	ok/erreur; mod	D7.WIFSWITCH:	PUSHM.L	D3,D4,A3	COMP.B	(A3),#'"	JUMP,NE NORM$	INC.L	A3	LOAD.B	D4,D3LOOP$:	LOAD.B	D3,(A3+)	JUMP',EQ ERROR$	COMP.B	D3,#CR	JUMP',EQ ERROR$	COMP.B	D3,#'"	JUMP,NE LOOP$SWI$:	COMP.B	(A3+),#'/	JUMP',NE ERROR$	LOAD.B	D3,(A3+)	CALL	MINMAJ	COMP.B	D3,D4	JUMP,NE SWI$	CLR.W	D7	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1	JUMP'	EXIT$NORM$:	LIB	?IFSWITCHEXIT$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; EXMMENU >;========/; Construit le m-menu lorsqu'il est possible d'excuter; plusieurs programmes pour une extension donne.; in	A3.L	^nom de l'extension (par exemple: "asm"); out	A3.L	^mmenu; mod	D7.W, A3.LEXMMENU:	PUSHM.L	D2..D4,A1,A2,A4	LOAD.L	A1,#(A6)+OBUDIS	; A1 <-- ^buffer pour LOADGC	LOAD.L	A2,#(A6)+OBUDIS+100 ; A2 <-- ^buffer pour MMENU	CLR.W	D2	LOAD.B	(A2+),#SPACE	CLR.B	(A2+)		; buffer <-- case blanche	LOAD.B	(A2+),#-1	; buffer <-- ligne horizontale	ADD.W	D2,#3	LOAD.L	A4,(A6)+OPUSER	; A4 <-- ^fichier START_USER.INFO	CALL	SRCEINFO	; A4 <-- ^ligne suivante	JUMP',EQ 12$	LOAD.L	A4,(A6)+OPINFO	; A4 <-- ^fichier START.INFO10$:	CALL	SRCEINFO	; A4 <-- ^ligne suivante	JUMP,NE 80$12$:	COMP.W	D2,#LBUDIS-30	; encore assez de place pour une case ?	JUMP,HS 80$		; non => 80$	LOAD.B	D4,#GCIIF	; D4 <-- fonte par dfaut	LOAD.B	D3,(A4)	CALL	MINMAJ		; D3 <-- premier caractre du "nombre"	COMP.B	D3,#'A	JUMP',LO 14$	COMP.B	D3,#'Z		; est-ce une lettre ?	JUMP',HI 14$		; non => 10$	LOAD.B	D4,D3		; D4 <-- fonte spciale	INC.L	A4		; A4 <-- saute la lettre14$:	LOAD.B	(A2+),#SPACE	LOAD.B	(A2+),#USEGC	LOAD.B	(A2+),D4	LOAD.B	(A2+),#GCIIS	LOAD.B	(A2+),#GCIIT	ADD.W	D2,#5	COMP.B	D4,#GCIIF	JUMP',EQ 20$	LOAD.B	(A1+),#LOADGC	LOAD.B	(A1+),D4	LOAD.B	(A1+),#GCIIS	LOAD.B	(A1+),#GCIIT20$:	CLR.W	D3		; D3 <-- code de l'icne21$:	CLR.W	D4	LOAD.B	D4,(A4)	SUB.B	D4,#'0	JUMP',LO 25$	COMP.B	D4,#10	JUMP',HS 25$	INC.L	A4	MUL.WU	D3,#10		; D3 <-- pousse d'un digit	ADD.W	D3,D4		; D3 <-- ajoute nouveau digit	JUMP	21$25$:	LOAD.B	(A2+),D3	INC.W	D2	COMP.B	(A2)-4,#GCIIF	JUMP',EQ 26$	LOAD.B	(A2+),#USEGC	LOAD.B	(A2+),#GCIIF	LOAD.B	(A2+),#GCIIS	LOAD.B	(A2+),#GCIIT	ADD.W	D2,#426$:	LOAD.B	(A2+),#ICOSPACE	LOAD.B	(A2+),#USEGC	LOAD.B	(A2+),#GCTXF	LOAD.B	(A2+),#GCTXS	LOAD.B	(A2+),#GCTXT	ADD.W	D2,#5; Met dans le mmenu le dernier nom (entre guillemets) qui ne contient; pas de "/". Par exemple :;	TOTO			-->	TOTO;	"EDIT"			-->	EDIT;	"EDIT 100/M"		-->	EDIT;	"CLE ASLIB"		-->	ASLIB;	"BASIC TOTO.CBAS 10/M"	-->	TOTO.CBAS30$:	LOAD.B	D3,(A4+)	COMP.B	D3,#SPACE	JUMP,EQ 30$	COMP.B	D3,#TAB	JUMP,EQ 30$	DEC.L	A4	COMP.B	D3,#'"	JUMP,NE 50$	INC.L	A440$:				; nom entre guillements =>	LOAD.B	D3,(A4)	JUMP',EQ 42$	COMP.B	D3,#CR	JUMP',EQ 42$	COMP.B	D3,#'"	JUMP',EQ 42$	INC.L	A4	JUMP	40$42$:	CLR.B	D4		; D4 <-- pas de "/" trouv43$:	LOAD.B	D3,(-A4)	COMP.B	D3,#'"	JUMP',EQ 48$	COMP.B	D3,#SPACE	JUMP',EQ 45$	COMP.B	D3,#TAB	JUMP',EQ 45$	COMP.B	D3,#'/	JUMP,NE 43$	INC.B	D4		; D4 <-- un "/" trouv	JUMP	43$45$:	TEST.B	D4		; un "/" trouv ?	JUMP,NE 42$		; oui => 42$48$:	INC.L	A450$:				; nom sans guillemets =>	LOAD.B	D3,(A4+)	JUMP',EQ 60$	COMP.B	D3,#SPACE	JUMP',EQ 60$	COMP.B	D3,#TAB	JUMP',EQ 60$	COMP.B	D3,#CR	JUMP',EQ 60$	COMP.B	D3,#'"	JUMP',EQ 60$	CALL	MINMAJ	LOAD.B	(A2+),D3	; buffer <-- nom du programme	INC.W	D2	JUMP	50$60$:	LOAD.B	(A2+),#SPACE	CLR.B	(A2+)	ADD.W	D2,#2	DEC.L	A4	CALL	NEXTINFO	; A4 <-- ^ligne suivante	JUMP	10$80$:	CLR.B	(A2)	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	D3,A1	SUB.L	D3,A3	JUMP',EQ 85$	LIB	?STRING		; effectue un LOADGC de tous les gencars utiliss !85$:	LOAD.L	A3,#(A6)+OBUDIS+100 ; A3 <-- ^m-menu	POPM.L	D2..D4,A1,A2,A4	RET;----------\\; WAITMMENU >;==========/; Comme LIB,?MMENU et remet en plus la souris o elle tait.; Le mmenu est construit selon une table d'instructions.; in	A5.L	^description unit;	D4.W	rang;	D2.W	type (TYP...);	A3.L	^table de construction du mmenu;	D3.W	case initiale; out	D3.W	case choisie;	D7.W	erreur; mod	D3.L, D7.WWAITMMENU:	PUSHM.L	D0,D1,D4,A2..A4	PUSH.L	D3	LIB	?GETSHIFT	; D3 <-- touches super-shift	LOAD.B	(A6)+OSHIFT,D3	POP.L	D3	CLR.L	D0		; D0 <-- pas de cases "blanches"	CLR.W	D1		; D1 <-- pas de cases "options"	LOAD.L	A4,A3		; A4 <-- ^table de construction	COMP.W	D2,#TYPSELECT	JUMP,EQ SEL$	COMP.W	D2,#TYPALLWDO	JUMP,EQ WDO$	COMP.W	D2,#TYPMILIEU	JUMP,EQ MILIEU$	COMP.W	D2,#TYPPRINT	JUMP,EQ MENU$	CALL	__GETPFILE	; A3 <-- ^OFL...	JUMP,NE MENU$	LOAD.L	D4,(A3)+OFLATT	; D4 <-- attributs	COMP.W	D2,#TYPUNIT	JUMP,EQ UNIT$	COMP.W	D2,#TYPDIR	JUMP,EQ DIR$	COMP.W	D2,#TYPDOSSIER	JUMP,EQ DIR$	COMP.W	D2,#TYPCODE	JUMP,EQ CODE$	COMP.W	D2,#TYPSYSC	JUMP,EQ SYSC$DOC$:				; autre =>	TEST.L	D4:#BATTD	JUMP',BS DOC1$	TSET.L	D0:#1		; D0 <-- plus de case "dtruit"	TSET.L	D0:#2		; D0 <-- plus de case "dplace"	TSET.L	D0:#9		; D0 <-- plus de case "(d-)verrouille"DOC1$:	TEST.L	D4:#BATTR	JUMP',BS DOC2$	TSET.L	D0:#2		; D0 <-- plus de case "dplace"	TSET.L	D0:#3		; D0 <-- plus de case "duplique"	TSET.L	D0:#6		; D0 <-- plus de case "dite"	TSET.L	D0:#7		; D0 <-- plus de case "visualise"	TSET.L	D0:#8		; D0 <-- plus de case "imprime"	TSET.L	D0:#9		; D0 <-- plus de case "(d-)verrouille"DOC2$:	CALL	__IF100_	; fichier dit "systme" ?	JUMP',NE DOC3$		; non => DOC3$	TSET.L	D0:#9		; D0 <-- plus de case "(d-)verrouille"DOC3$:	TEST.L	D4:#BATTW	JUMP',BS DOC4$	TSET.L	D0:#9		; D0 <-- plus de case "(d-)verrouille"	TSET.L	D0:#6		; D0 <-- plus de case "dite"DOC4$:	TEST.L	D4:#BATTQ	JUMP',BC DOC5$	TSET.L	D1:#9		; D1 <-- option "dverrouille"DOC5$:	CALL	__IFPRINT	; document imprimable ?	JUMP',EQ DOC6$		; oui => DOC6$;;?	TSET.L	D0:#6		; D0 <-- plus de case "dite";;?	TSET.L	D0:#7		; D0 <-- plus de case "visualise"	TSET.L	D0:#8		; D0 <-- plus de case "imprime"DOC6$:	COMP.W	D2,#TYPIMAGE	JUMP',EQ DOC7$	COMP.W	D2,#TYPCOLOR	JUMP',EQ DOC7$	COMP.W	D2,#TYPPLAN	JUMP',NE DOC8$DOC7$:	TSET.L	D0:#6		; D0 <-- plus de case "dite"DOC8$:;;?	COMP.W	D2,#TYPPLAN;;?	JUMP',EQ DOC9$;;?	COMP.W	D2,#TYPGENCAR;;?	JUMP',NE DOC10$;;?DOC9$:;;?	TCLR.L	D0:#7		; D0 <-- remet la case "visualise";;?DOC10$:	.IF	MPRINT	TEST.L	(A6)+OCAPRINT	; module PRINTA charg ?	JUMP,NE MENU$		; oui => MENU$	TSET.L	D0:#8		; D0 <-- plus de case "imprime"	.ENDIF	JUMP	MENU$CODE$:				; programme =>	TEST.L	D4:#BATTD	JUMP',BS CODE1$	TSET.L	D0:#1		; D0 <-- plus de case "dtruit"	TSET.L	D0:#2		; D0 <-- plus de case "dplace"CODE1$:	TEST.L	D4:#BATTR	JUMP',BS CODE2$	TSET.L	D0:#2		; D0 <-- plus de case "dplace"	TSET.L	D0:#3		; D0 <-- plus de case "duplique"	TSET.L	D0:#7		; D0 <-- plus de case "paramtres"CODE2$:	TEST.L	D4:#BATTW	JUMP',BS CODE3$	TSET.L	D0:#7		; D0 <-- plus de case "paramtres"CODE3$:	TEST.L	(A3)+OFLLG	; longueur nulle (accs) ?	JUMP',NE CODE4$		; non => CODE4$	TSET.L	D0:#2		; D0 <-- plus de case "dplace"	TSET.L	D0:#3		; D0 <-- plus de case "duplique"	TSET.L	D0:#7		; D0 <-- plus de case "paramtres"CODE4$:	LOAD.L	D4,(A6)+OSWITCH	TEST.L	D4:#('P-'A)	; START/P ?	JUMP,BC MENU$		; non => MENU$	TSET.L	D0:#7		; D0 <-- plus de case "paramtres"	JUMP	MENU$SYSC$:				; SYSTEM.CODE =>	TEST.B	(A6)+OSHIFT:#BKILL ; touche (KILL) enfonce ?	JUMP',BS SYSC1$		; oui => SYSC1$	TSET.L	D0:#1		; D0 <-- plus de case "dtruit"	TSET.L	D0:#2		; D0 <-- plus de case "dplace"SYSC1$:	TSET.L	D0:#4		; D0 <-- plus de case "accs"	TSET.L	D0:#5		; D0 <-- plus de case "modifie"	TSET.L	D0:#7		; D0 <-- plus de case "paramtres"	JUMP	MENU$DIR$:				; dossier =>	TEST.L	D4:#BATTD	JUMP',BS DIR1$	TSET.L	D0:#1		; D0 <-- plus de case "dtruit"	TSET.L	D0:#2		; D0 <-- plus de case "dplace"DIR1$:	TEST.L	D4:#BATTR	JUMP',BS DIR2$	TSET.L	D0:#1		; D0 <-- plus de case "dtruit"	TSET.L	D0:#2		; D0 <-- plus de case "dplace"	TSET.L	D0:#3		; D0 <-- plus de case "duplique"DIR2$:	TEST.L	D4:#BATTW	JUMP',BS DIR3$	TSET.L	D0:#1		; D0 <-- plus de case "dtruit"	TSET.L	D0:#2		; D0 <-- plus de case "dplace"DIR3$:	COMP.W	D2,#TYPDOSSIER	; DOSSIER: ?	JUMP,NE MENU$		; non => MENU$	TCLR.L	D0:#3		; D0 <-- toujours la case "duplique"	TSET.L	D0:#4		; D0 <-- plus de case "modifie"	JUMP	MENU$UNIT$:				; unit physique =>	COMP.B	(A3)+OFLTYP,#'@	JUMP',NE UNIT1$	TSET.L	D0:#2		; D0 <-- plus de case "nom du disque"	TSET.L	D0:#3		; D0 <-- plus de case "format du disque"	TSET.L	D0:#4		; D0 <-- plus de case "formate"	TSET.L	D0:#5		; D0 <-- plus de case "copie"UNIT1$:	CALL	__IFUUSE	; unit utilise ?	JUMP',EQ UNIT3$		; non => UNIT3$	TSET.L	D0:#3		; D0 <-- plus de case "format du disque"	TSET.L	D0:#4		; D0 <-- plus de case "formate"	TSET.L	D0:#7		; D0 <-- plus de case "deinstalle"UNIT3$:	LOAD.L	D4,(A6)+OSWITCH	TEST.L	D4:#('S-'A)	; START/S ?	JUMP',BC UNIT4$		; non => UNIT4$	TSET.L	D0:#6		; D0 <-- plus de case "systme"UNIT4$:	COMP.B	(A3)+OFLTYP,#'@	JUMP',EQ UNIT6$	PUSH.L	A4	CALL	MINSTATUS	; A4 <-- ^status minimal	LOAD.L	A2,A4		; A2 <-- ^status minimal	POP.L	A4	TEST.W	D7	JUMP',NE UNIT59$	COMP.B	(A2)+OMTYPE,#MTFLO ; disque amovible ?	JUMP',EQ UNIT52$	; oui => UNIT52$	TSET.L	D0:#4		; D0 <-- plus de case "formate"	TSET.L	D0:#5		; D0 <-- plus de case "copie"UNIT52$:	TEST.W	(A2)+OMNBFMTREC	; au moins un format FMT ?	JUMP',NE UNIT53$	; oui => UNIT53$	TSET.L	D0:#3		; D0 <-- plus de case "format du disque"UNIT53$:	JUMP'	UNIT6$UNIT59$:	TSET.L	D0:#1		; D0 <-- plus de case "informations"	TSET.L	D0:#2		; D0 <-- plus de case "nom du disque"	TSET.L	D0:#3		; D0 <-- plus de case "format du disque"	TSET.L	D0:#4		; D0 <-- plus de case "formate"	TSET.L	D0:#5		; D0 <-- plus de case "copie"UNIT6$:	LOAD.L	D4,(A6)+OSWITCH	TEST.L	D4:#('A-'A)	; START/A ?	JUMP,BC MENU$		; non => MENU$	TSET.L	D0:#7		; D0 <-- plus de case "deinstalle"	JUMP	MENU$SEL$:				; slection multiple =>	TSET.L	D0:#4		; D0 <-- plus de case "accs"	PUSH.L	D3	CALL	__SELECTTYPE	LOAD.W	D4,D3		; D4 <-- type de la slection	POP.L	D3	TEST.W	D7		; que des types identiques ?	JUMP,NE MENU$		; non => MENU$	COMP.W	D4,#TYPCODE	JUMP,NE MENU$	TCLR.L	D0:#4		; D0 <-- met la case "accs"	JUMP	MENU$WDO$:				; slection fentre =>	CALL	__CLEARNBFILE	; D4 <-- nb de fichiers  clearer	TEST.W	D4	JUMP,NE MENU$	TSET.L	D0:#7		; D0 <-- plus de case "libre"	JUMP	MENU$MILIEU$:			; bouton du milieu =>	.IF	MPRINT	TEST.L	(A6)+OCAPRINT	JUMP',NE MILIEU1$	TSET.L	D0:#1		; D0 <-- plus de case "imprimante"	.ELSE	CALL	IFDBOXPRINT	JUMP',EQ MILIEU1$	TSET.L	D0:#2		; D0 <-- plus de case "imprimante"	.ENDIFMILIEU1$:	.IF	MPRINT	TSET.L	D0:#6		; D0 <-- plus de case "petit"	.ELSE	TSET.L	D0:#5		; D0 <-- plus de case "petit"	.ENDIF	TEST.B	(A6)+ODEMIX	JUMP',T MILIEU2$	.IF	MPRINT	TCLR.L	D0:#6	TSET.L	D0:#5		; D0 <-- plus de case "plat"	.ELSE	TCLR.L	D0:#5	TSET.L	D0:#4		; D0 <-- plus de case "plat"	.ENDIF	TEST.B	(A6)+ODEMIY	JUMP',T MILIEU2$	.IF	MPRINT	TCLR.L	D0:#5	TSET.L	D0:#4		; D0 <-- plus de case "normal"	.ELSE	TCLR.L	D0:#4	TSET.L	D0:#3		; D0 <-- plus de case "normal"	.ENDIFMILIEU2$:	LOAD.L	D4,(A6)+OSWITCH	TEST.L	D4:#('N-'A)	; START/N ?	JUMP',BS MENU$		; oui => MENU$	.IF	MPRINT	TSET.L	D0:#7		; D0 <-- plus de case "mot de passe"	.ELSE	TSET.L	D0:#6		; D0 <-- plus de case "mot de passe"	.ENDIF;	JUMP'	MENU$MENU$:	LOAD.L	A3,A4		; A3 <-- ^table de construction	CALL	CONSMMENU	; A3 <-- ^mmenu construit	LOAD.L	D4,D0		; D4 <-- cases inactives	TSET.L	D3:#15		; D3 <-- signal D4 donn en entre !	CALL	MMENU		; agit selon mmenu ...	JUMP',NE EXIT$	TEST.L	D0:D3		; case "blanche" slectionne ?	JUMP',BC EXIT$		; non => EXIT$	LOAD.W	D7,#ERBIP	; D7 <-- bip (case "blanche")EXIT$:	POPM.L	D0,D1,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; CONSMMENU >;----------/; Gnre un mmenu d'aprs une table de construction.; in	A3.L	^table de construction;	D1.W	cases "options"; out	A3.L	^mmenu construit; mod	D7.W, A3.LCONSMMENU:	PUSHM.L	D0,D1,D3,A2,A4	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^buffer	LOAD.B	(A4+),#SPACE	CLR.B	(A4+)		; buffer <-- case blanche	LOAD.B	(A4+),#-1LOOP$:	RR.W	D1,#1		; D1 <-- case "option" suivanteLOOP2$:	LOAD.W	D3,(A3+)	; D3 <-- instruction de construction	JUMP,EQ END$	COMP.W	D3,#-1		; ligne de sparation ?	JUMP,EQ HLINE$	COMP.W	D3,#-3		; option ?	JUMP,EQ OPT$CASE$:				; gnre une case =>	LOAD.L	A2,#R16"TMN	ADD.W	A2,D3		; A2 <-- ^texte de construction	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCIIF	LOAD.B	(A4+),#GCIIS	LOAD.B	(A4+),#GCIIT	LOAD.B	(A4+),(A2+)	; buffer <-- ICO..	LOAD.B	(A4+),#ICOSPACE	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCTXF	LOAD.B	(A4+),#GCTXS	LOAD.B	(A4+),#GCTXTTEXT$:	LOAD.B	(A4+),(A2+)	; buffer <-- texte	JUMP,NE TEXT$	LOAD.B	(A4)-1,#SPACE	; buffer <-- espace  la fin du texte	CLR.B	(A4+)	JUMP	LOOP$OPT$:				; option =>	ADD.L	A3,#4	LOAD.W	D3,(A3)-4	; D3 <-- premire option	TEST.L	D1:#0	JUMP,BC CASE$	LOAD.W	D3,(A3)-2	; D3 <-- deuxime option	JUMP	CASE$HLINE$:				; ligne de sparation =>	LOAD.B	(A4+),D3	; buffer <-- ligne -------	JUMP	LOOP2$END$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^menu construit	POPM.L	D0,D1,D3,A2,A4	RET;--------\\; MMENU   >;========/; Comme LIB,?MMENU et remet en plus la souris o elle tait.; in	A3.L	^mmenu;	D3.W	case initiale;	D4.L	cases inactives (si D3:#15=1); out	D3.W	case choisie;	D7.W	erreur; mod	D3.L, D7.WMMENU:	PUSHM.L	D0..D2,D4	LOAD.W	D0,D3		; D0 <-- case initiale	LOAD.L	D1,D4		; D1 <-- cases inactives	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 90$	LOAD.L	D2,D4	LOAD.W	D3,D0		; D3 <-- case initiale	LOAD.L	D4,D1		; D4 <-- cases inactives	LIB	?MMENU		; attend selon mmenu ...	JUMP',NE 90$	LOAD.L	D4,D2		; D4 <-- position de la souris	CALL	PMOUSE		; remet la souris o elle tait	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMOUSE  >;========/; Positionne la souris en (y;x).; in	D4.L	nouvelle position y;x; out	-; mod	D7.WPMOUSE:	PUSHM.L	D3,D4,D6,A4; Ramne la position dans la fentre si elle en sort.	TEST.W	D4		; trop  gauche ?	JUMP',NC 10$	CLR.W	D410$:	COMP.W	D4,(A0)+ODFDX	; trop  droite ?	JUMP',LT 15$	LOAD.W	D4,(A0)+ODFDX	DEC.W	D415$:	SWAP.W	D4	TEST.W	D4		; trop en haut ?	JUMP',NC 20$	CLR.W	D420$:	COMP.W	D4,(A0)+ODFDY	; trop en bas ?	JUMP',LT 25$	LOAD.W	D4,(A0)+ODFDY	DEC.W	D425$:	SWAP.W	D4; Calcul la position absolue dans le grand bitmap $DIS_0.	ADD.W	D4,(A0)+ODFX	SWAP.W	D4	ADD.W	D4,(A0)+ODFY	SWAP.W	D4		; D4 <-- position dans $DIS_0 !; Envoie la commande secrte et mystrieuse de positionnement. 	LOAD.L	A4,#(A6)+OBUDIS+1	LOAD.B	(A4)+0,#'P	; <P>	LOAD.L	(A4)+1,D4	; <yy> <xx>	CLR.B	(A4)+5	LOAD.W	D3,#TYPIO	; D3 <-- type du driver souris	LIB	?GCHMOU		; D6 <-- canal souris	FOS	?COMMAND	LOAD.W	D4,#2	NTREL	?DELMS		; attend que le positionnement se fasse !	POPM.L	D3,D4,D6,A4	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;---------\\; CLRKFIFO >;=========/; Vide le fifo du clavier.; in	-; out	-; mod	D7.WCLRKFIFO:	PUSH.L	D310$:	LIB	?IFCAR		; une touche presse ?	JUMP,EQ 10$		; oui => 10$	POP.L	D3	RET;--------\\; BUCAR   >;========/; Met le mode rapide bufferis.; in	-; out	-; mod	D7.WBUCAR:	TEST.B	(A6)+OBUCAR	JUMP',T 90$	SET.B	(A6)+OBUCAR	LIB	?BUCAR90$:	RET;--------\\; NOBUCAR >;========/; Enlve le mode rapide bufferis.; in	-; out	-; mod	D7.WNOBUCAR:	TEST.B	(A6)+OBUCAR	JUMP',F 90$	CLR.B	(A6)+OBUCAR	LIB	?NOBUCAR90$:	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	-; out	-; mod	D7.WAFMENU:	PUSH.L	A3	LOAD.L	A3,#R16"TXMENU	LIB	?AFMENU	POP.L	A3	RET;--------\\; CLRMEM  >;========/; Efface une zone mmoire quelconque.; Super-rapide, si si !;;	LOOP:;		CLR.L	(An+);		DECJ.W,NMO Dn,LOOP; in	A4.L	^zone mmoire;	D4.L	lg zone; out	-; mod	-CLRMEM:	PUSHM.L	D3,D4,A4	SR.L	D4,#2		; D4 <-- nb de .L  effacer	JUMP',CC 10$	CLR.W	(A4+)		; si multiple de .W, efface le premier .W10$:	LOAD.L	D3,D4	COMP.L	D3,#30000	; tranche compatible avec DECJ.W,NMO ?	JUMP',LO 20$		; oui => 20$	LOAD.L	D3,#30000	; non => met (presque) le maximum20$:	SUB.L	D4,D3		; D4 <-- reste pour tranche suivante	DEC.W	D3		; D3 <-- -1  cause du test NMO !30$:	CLR.L	(A4+)		; efface super-rapidement une tranche	DECJ.W,NMO D3,30$	TEST.L	D4		; encore qq chose  effacer ?	JUMP,NE 10$		; oui => 10$	POPM.L	D3,D4,A4	RET;--------\\; PUTHNUM >;========/; Met un nombre hexadcimal dans un buffer.; in	D4.L	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTHNUM:	PUSHM.L	D2..D4	LOAD.W	D2,#8-1LOOP$:	RL.L	D4,#4	LOAD.B	D3,D4	AND.B	D3,#B'1111	ADD.B	D3,#'0	COMP.B	D3,#'9	JUMP',LS PUT$	ADD.B	D3,#'A-'9-1PUT$:	LOAD.B	(A4+),D3	DECJ.W,NMO D2,LOOP$	POPM.L	D2..D4	RET;--------\\; PUTANUM >;--------/; Met un nombre dcimal dans un buffer.; in	D4.W	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	AND.L	D4,#H'FFFF	; D4 <-- nombre binaire	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;--------/; Donne un nombre dcimal.; OK jusqu' 32 bits !; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSHM.L	D2,D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	SL.L	D4,#1	LOAD.L	D2,D4	SL.L	D4,#2	ADD.L	D4,D2		; D4 <-- pousse d'un digit (*10)	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POPM.L	D2,D3	RET;----------\\; MINSTATUS >;==========/; Lit le status minimum d'un disque (pas d'accs).; in	A3.L	^nom du disque; out	A4.L	^status minimal;	D7.W	erreur; mod	D7.W, A4.LMINSTATUS:	PUSHM.L	D0,D3,D4,D6	LOAD.L	D3,#2^BOPEXTEND!2^BOPMMUNIT!2^BOPRSTATUS	LOAD.L	D0,#FOS?ARGSOPEN ; ouvre le disque	CALL	ERCALL	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OBUHEAD ; A4 <-- ^buffer	LOAD.L	D4,#LGMAM3	LOAD.W	D3,#TYPMM	FOS	?RSTATUS	; lit le status sans les records FMT	JUMP',EQ CLOSE$	GESMEM	?CLEARMEM	LOAD.L	D4,#LGMAM0;	LOAD.W	D3,#TYPMM	FOS	?RSTATUS	; lit le status le plus simple !CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le disque	POP.W	D7EXIT$:	POPM.L	D0,D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;--------\; MINMAJ  >;========/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMINMAJ:	TEST.L	D3:#7		; code "supplmentaire" ?	JUMP',NE 20$		; oui => 20$	COMP.B	D3,#SPACE-2	; lettre accentue ?	JUMP',LO 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+70$  ; D3 <-- lettre majuscule	POP.W	D0	RET70$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVENTXMENU:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN	.END