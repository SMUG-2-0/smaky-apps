	.SBTTL	STARTLIST;---------\\; RENAMEEX >;=========/; Renomme un fichier sur disque et dans la fentre.; in	A5.L		^description unit;	D4.W		rang (0..n);	A3.L		^nouveau nom; out	D7.W		erreur;	A3.L		^nom du fichier ayant caus l'erreur; mod	D7.W, A3.LRENAMEEX:	PUSHM.L	D3,A2,A4	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.L	A2,A3		; A2 <-- ^nouveau nom	CALL	PREPFIS		; A3 <-- ^nom fichier original	CALL	SKIPREP	TEST.B	(A3)		; dossier ?	JUMP',EQ 30$		; oui => 30$				; non =>	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nom fichier original	LOAD.L	A4,A2		; A4 <-- ^nouveau nom	PUSH.L	D0	LOAD.L	D0,#FOS?RENAME	CALL	ERCALL		; change le nom	POPM.L	D0	JUMP,EQ 90$		; ok => 90$20$:				; erreur =>	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE 90$		; non => 90$	LOAD.L	A3,A4		; oui => rend le bon nom de fichier	JUMP	90$; Renomme un fichier dossier.30$:	EX.L	A3,A2	CALL	GETTYPE	EX.L	A2,A3		; D3 <-- type du nouveau nom	LOAD.W	D7,#ERSDOIL	; D7 <-- ce nom ne peut pas tre utilis	COMP.W	D3,#TYPDOSSIER	; nouveau nom = DOSSIER: ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nom fichier original	CALL	IFEQUUSE	; unit dj utilise ?	JUMP,NE 90$	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nom fichier original	FOS	?RELEASE	; ferme le rpertoire	LOAD.B	(A4)-1,#'.	LOAD.B	(A4)+0,#'D	LOAD.B	(A4)+1,#'I	LOAD.B	(A4)+2,#'R	CLR.B	(A4)+3	LOAD.L	A3,A2	CALL	SKIPREP	TEST.B	(A3)		; dossier ?	JUMP',NE 50$		; non => 50$	LOAD.B	(A3)-1,#'.	LOAD.B	(A3)+0,#'D	LOAD.B	(A3)+1,#'I	LOAD.B	(A3)+2,#'R	CLR.B	(A3)+3	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nom fichier .DIR	LOAD.L	A4,A2		; A4 <-- ^nouveau nom .DIR	PUSH.L	D4	FOS	?CLEAR		; rz le compteur d'ouvertures !	POP.L	D4	FOS	?RENAME		; change le nom	JUMP,NE 20$		; erreur => 20$40$:	TEST.B	(A4+)	JUMP,NE 40$	LOAD.B	(A4)-5,#':	CLR.B	(A4)-4	JUMP'	90$50$:	LOAD.L	A3,A2	LOAD.W	D7,#ERSYNT	; D7 <-- erreur de syntaxe	PUSH.W	D7	FOS	?NAMERROR	; donne le nom du fichier au FOS	POP.W	D790$:	POPM.L	D3,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CHATREX >;========/; Change les attributs d'un fichier sur disque et dans la fentre.; in	A5.L		^description unit;	D4.W		rang (0..n);	D3.L		nouveaux attributs; out	D7.W		erreur;	A3.L		^nom du fichier ayant caus l'erreur; mod	D7.W, A3.LCHATREX:	PUSHM.L	D3,A4	CALL	_WAITMOUSE	; souris: met le sablier	CALL	PREPFIS		; A3 <-- ^nom	CALL	SKIPREP	TEST.B	(A3)		; dossier ?	JUMP',EQ 30$		; oui => 30$				; non =>	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nom fichier	PUSH.L	D0	LOAD.L	D0,#FOS?CHATR	CALL	ERCALL		; change les attributs	POPM.L	D0	JUMP	90$; Change les attributs d'un fichier dossier.30$:	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nom fichier original	FOS	?RELEASE	; ferme le rpertoire	LOAD.B	(A4)-1,#'.	LOAD.B	(A4)+0,#'D	LOAD.B	(A4)+1,#'I	LOAD.B	(A4)+2,#'R	CLR.B	(A4)+3	PUSH.L	D4	FOS	?CLEAR		; rz le compteur d'ouvertures !	POP.L	D4	FOS	?CHATR		; change les attributs90$:	POPM.L	D3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; CHDATEEX >;=========/; Change la date de cration d'un fichier sur disque et dans la fentre.; in	A5.L		^description unit;	D4.W		rang (0..n);	D3.L		nouvelle date en BCD; out	D7.W		erreur;	A3.L		^nom du fichier ayant caus l'erreur; mod	D7.W, A3.LCHDATEEX:	PUSHM.L	D2,D3,D6	LOAD.L	D2,D3		; D2 <-- nouvelle date	CALL	_WAITMOUSE	; souris: met le sablier	CALL	PREPFIS		; A3 <-- ^nom	CALL	SKIPREP	TEST.B	(A3)		; dossier ?	JUMP',EQ 30$		; oui => 30$				; non =>	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nom fichier	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL	POPM.L	D0	JUMP,NE 90$	PUSH.L	D4	LOAD.L	D4,D2		; D4 <-- met la nouvelle date	LOAD.L	D3,#H'120000	; D3 <-- met l'heure 12:00:00	FOS	?CLOMDC	POPM.L	D4	JUMP	90$; Change la date d'un fichier dossier.30$:	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nom fichier original	FOS	?RELEASE	; ferme le rpertoire	LOAD.B	(A4)-1,#'.	LOAD.B	(A4)+0,#'D	LOAD.B	(A4)+1,#'I	LOAD.B	(A4)+2,#'R	CLR.B	(A4)+3	PUSH.L	D4	FOS	?CLEAR		; rz le compteur d'ouvertures !	POP.L	D4	LOAD.L	D3,#2^BOPWR!2^BOPNETW!2^BOPEXTEND!2^BOPDIR	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL	POPM.L	D0	JUMP,NE 90$	PUSH.L	D4	LOAD.L	D4,D2		; D4 <-- met la nouvelle date	LOAD.L	D3,#H'120000	; D3 <-- met l'heure 12:00:00	FOS	?CLOMDC	POPM.L	D490$:	POPM.L	D2,D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; LOCKEX  >;========/; Verrouille un fichier.; in	A5.L		^description unit;	D4.W		rang (0..n); out	D7.W		erreur;	A3.L		^nom du fichier ayant caus l'erreur; mod	D7.W, A3.LLOCKEX:	PUSHM.L	D3,A1,A2,A4	CALL	_WAITMOUSE	; souris: met le sablier; Construit le nom du fichier source dverrouill.	CALL	PREPFIS		; A3 <-- ^nom fichier dverrouill	LOAD.L	A1,A3		; A1 <-- ^nom source; Construit le nom du fichier destination verrouill.	LOAD.L	A4,A3	CALL	SKIPREP	LOAD.L	A2,#(A6)+OBUFID20$:	COMP.L	A4,A3	JUMP',EQ 22$	LOAD.B	(A2+),(A4+)	; OBUFID <-- unit:rep: du fichier source	JUMP	20$22$:	LOAD.L	A4,#(A6)+OBUCLE24$:	LOAD.B	(A2+),(A4+)	; OBUFID <-- clef`	JUMP,NE 24$	LOAD.B	(A2)-1,#'`26$:	LOAD.B	D3,(A3+)	JUMP',EQ 28$	COMP.B	D3,#'.	JUMP',EQ 28$	COMP.B	D3,#'!	JUMP',EQ 28$	LOAD.B	(A2+),D3	; OBUFID <-- nom sans extension	JUMP	26$28$:	LOAD.B	(A2+),#'.	LOAD.B	(A2+),#'T	LOAD.B	(A2+),#'E	LOAD.B	(A2+),#'M	LOAD.B	(A2+),#'P	; OBUFID <-- extension .TEMP	CLR.B	(A2)	LOAD.L	A2,#(A6)+OBUFID	; A2 <-- ^nom destination; Cre le fichier verrouill en dplaant dans le fichier .TEMP.	LOAD.W	(A6)+ODDDOP,#2	; opration dplace	LOAD.W	(A6)+ODDDXF,#XFLOCK ; transfert en verrouillant	CLR.L	(A6)+ODDDAP	; pas d'attributs  ajouter	CLR.L	(A6)+ODDDAM	; pas d'attributs  enlever	CALL	DDDDISK		; dplace source dans destination	JUMP,NE 90$	LOAD.L	A3,A2		; A3 <-- ^nom actuel (.TEMP)	LOAD.L	A4,A1		; A4 <-- ^nouveau nom	FOS	?RENAME		; renomme le .TEMP	JUMP,EQ 90$	COMP.W	D7,#ERATTC	JUMP,NE 90$	CALL	GETPFILE	; A3 <-- ^nom	LOAD.L	D3,(A3)+OFLATT	TSET.L	D3:#BATTC	; D3 <-- ajoute l'attribut "C"	LOAD.L	A3,A2		; A3 <-- ^nom actuel (.TEMP)	FOS	?CHATR		; CHATR fichier.TEMP +C	JUMP,NE 90$	LOAD.L	A3,A2		; A3 <-- ^nom actuel (.TEMP)	LOAD.L	A4,A1		; A4 <-- ^nouveau nom	FOS	?RENAME		; renomme le .TEMP	PUSH.W	D7	TCLR.L	D3:#BATTC	; D3 <-- enlve l'attribut "C"	TSET.L	D3:#BATTQ	; D3 <-- ajoute l'attribut "V"	LOAD.L	A3,A1		; A3 <-- ^nouveau nom	FOS	?CHATR		; CHATR fichier.new -C	POP.W	D790$:	POPM.L	D3,A1,A2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; UNLOCKEX >;=========/; Dverrouille un fichier.; in	A5.L		^description unit;	D4.W		rang (0..n); out	D7.W		erreur;	A3.L		^nom du fichier ayant caus l'erreur; mod	D7.W, A3.LUNLOCKEX:	PUSHM.L	D3,A1,A2,A4	CALL	_WAITMOUSE	; souris: met le sablier; Construit le nom du fichier source verrouill.	LOAD.L	A4,#(A6)+OBUFIS	; A4 <-- ^buffer o mettre le nom	LOAD.L	A3,#(A5)+OUNNAM	PUSH.L	A410$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- unit et/ou rpertoires	JUMP,NE 10$	POP.L	A3	CALL	SKIPREP	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OBUCLE12$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- clef`	JUMP,NE 12$	LOAD.B	(A4)-1,#'`	CALL	GETPFILE	; A3 <-- ^nom	JUMP,NE 90$14$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- nom du fichier	JUMP,NE 14$	LOAD.L	A1,#(A6)+OBUFIS	; A1 <-- ^nom source; Construit le nom du fichier destination deverrouill.	LOAD.L	A2,#(A6)+OBUFID	LOAD.L	A3,A1	LOAD.L	A4,A1	CALL	SKIPREP20$:	COMP.L	A4,A3		; OBUFID <-- unit:rep: du nom source	JUMP',EQ 22$	LOAD.B	(A2+),(A4+)	JUMP	20$22$:	COMP.B	(A4+),#'`	JUMP,NE 22$24$:	LOAD.B	D3,(A4+)	JUMP',EQ 26$	COMP.B	D3,#'.	JUMP',EQ 26$	COMP.B	D3,#'!	JUMP',EQ 26$	LOAD.B	(A2+),D3	; OBUFID <-- nom sans extension	JUMP	24$26$:	LOAD.B	(A2+),#'.	LOAD.B	(A2+),#'T	LOAD.B	(A2+),#'E	LOAD.B	(A2+),#'M	LOAD.B	(A2+),#'P	; OBUFID <-- .TEMP	CLR.B	(A2)	LOAD.L	A2,#(A6)+OBUFID	; A2 <-- ^nom destination; Cre le fichier dverrouill en dplaant dans le fichier .TEMP.	LOAD.W	(A6)+ODDDOP,#2	; opration dplace	LOAD.W	(A6)+ODDDXF,#XFLOCK ; transfert en dverrouillant	CLR.L	(A6)+ODDDAP	; pas d'attributs  ajouter	LOAD.L	(A6)+ODDDAM,#2^BATTQ ; enlve l'attribut "Q"	CALL	DDDDISK		; dplace source dans destination	JUMP',NE 90$	LOAD.L	A3,A2		; A3 <-- ^nom actuel (.TEMP)	LOAD.L	A4,A1		; A4 <-- ^nouveau nom	FOS	?RENAME		; renomme le .TEMP	JUMP,EQ 90$	COMP.W	D7,#ERATTC	JUMP,NE 90$	CALL	GETPFILE	; A3 <-- ^nom	LOAD.L	D3,(A3)+OFLATT	TSET.L	D3:#BATTC	; D3 <-- ajoute l'attribut "C"	LOAD.L	A3,A2		; A3 <-- ^nom actuel (.TEMP)	FOS	?CHATR		; CHATR fichier.TEMP +C	JUMP,NE 90$	LOAD.L	A3,A2		; A3 <-- ^nom actuel (.TEMP)	LOAD.L	A4,A1		; A4 <-- ^nouveau nom	FOS	?RENAME		; renomme le .TEMP	PUSH.W	D7	TCLR.L	D3:#BATTC	; D3 <-- enlve l'attribut "C"	TCLR.L	D3:#BATTQ	; D3 <-- enlve l'attribut "V"	LOAD.L	A3,A1		; A3 <-- ^nouveau nom	FOS	?CHATR		; CHATR fichier.new -C	POP.W	D790$:	POPM.L	D3,A1,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; BALWAIT >;========/; Regarde s'il y a un message du FOS dans la bal.; L'affichage sera fait par BALAFF.; in	-; out	D7.W	EQ si aucun message reu; mod	D7.WBALWAIT:	PUSHM.L	D2..D5,A4,A5	CLR.W	D5		; D5 <-- nb de messages	CLR.W	D2		; D2 <-- nb de assign/deassign20$:	LOAD.W	D4,#2	NTREL	?SETTIM		; met timeout presque nul	LOAD.L	A5,(A6)+OBALPT	; A5 <-- ^bal	LOAD.L	A4,#(A6)+OBALMS	; A4 <-- ^buffer	LOAD.L	D4,#64		; D4 <-- lg attendue	LOAD.W	D3,#2^BMSCOPY	; D3 <-- mode	NTREL	?GETMS		; OBALMS <-- attend un message du FOS	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	JUMP',NE 50$		; pas de message => 50$				; message reu =>	CALL	BALMAJ		; met  jour selon le message	INC.W	D5		; D5 <-- un message de plus trait	JUMP	20$50$:	CALL	BALMAJASS	; refait liste des units si assign/deassign	LOAD.W	D7,D5		; D7 <-- nb de messages traits	POPM.L	D2..D5,A4,A5	RET;--------\\; BALAFF  >;========/; Affiche les modifications apportes par BALWAIT.; in	D2.W	mode (1 si annule slection); out	-; mod	D7.WBALAFF:	PUSHM.L	D3..D5,A3,A5; Cherche s'il existe au moins une fentre qui possde le; bit BMAJWDO. Si oui, il faut repeindre toutes les fentres,; avec leurs cadres, car elles ont peut-tre t dplaces; (ENTER ou RELEASE d'units).	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-1WLOOP$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP,F	MIN$		; non => MIN$	TEST.B	(A5)+OUNMOD:#BMAJWDO	JUMP',BS ALL$	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,WLOOP$	JUMP	MIN$ALL$:	TEST.W	D2	JUMP',EQ ADRAW$	TEST.W	(A6)+OSELNB	; slection en cours ?	JUMP',EQ ADRAW$		; non => ADRAW$	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-1ALOOP$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP',F	ADRAW$		; non => ADRAW$	COMP.L	A5,(A6)+OSELPU	; est-ce la bonne unit ?	JUMP',NE ANEXT$		; non => ANEXT$	CALL	SELECTUNDO	; annule toute la slectionANEXT$:	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,ALOOP$ADRAW$:	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^units physiques	CALL	SORTALL		; trie toutes les units physiques	CALL	MAJWDO		; redessine toutes les fentres	LOAD.W	D4,#-1	JUMP	KFIFO$; Passe en revue toutes les fentres, pour ne repeindre que le; stricte minimum.MIN$:	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-1	CLR.W	D4		; D4 <-- nb de fentres repeintesMLOOP$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP,F	KFIFO$		; non => KFIFO$	TEST.B	(A5)+OUNMOD	; fentre modifie ?	JUMP,F	MIFSEL$		; non => MIFSEL$				; oui =>	COMP.W	(A5)+OUNNAM,#H'100*'$ ; units physiques ?	JUMP',NE MFILE$		; non => MFILE$	CALL	ALLREFAIT	; oui => refait tout (y compris le tri)	JUMP'	MOK$MFILE$:	TEST.B	(A5)+OUNMOD:#BMAJNBF	JUMP',BC MNBF$	CALL	WDONBF		; redessine le nombre de fichiers	CALL	MAJASCENSEUR	; redessine l'ascenseur  droiteMNBF$:	TEST.W	D2	JUMP',EQ MSEL$	TEST.W	(A6)+OSELNB	; slection en cours ?	JUMP',EQ MSEL$		; non => MSEL$	COMP.L	A5,(A6)+OSELPU	; est-ce la bonne unit ?	JUMP',NE MSEL$		; non => MSEL$	CALL	SELECTUNDO	; annule toute la slectionMSEL$:	TEST.B	(A5)+OUNMOD:#BMAJICO	JUMP',BC MOK$	CALL	WDOICONE	; redessine les icnesMOK$:	CLR.B	(A5)+OUNMOD	; fentre maintenant  jour	INC.W	D4		; D4 <-- une fentre repreinte de plus	JUMP'	MNEXT$MIFSEL$:	TEST.W	D2	JUMP',EQ MNEXT$	TEST.W	(A6)+OSELNB	; slection en cours ?	JUMP',EQ MNEXT$		; non => MNEXT$	COMP.L	A5,(A6)+OSELPU	; est-ce la bonne unit ?	JUMP',NE MNEXT$		; non => MNEXT$	CALL	SELECTUNDOAFF	; annule toute la slectionMNEXT$:	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,MLOOP$; S'il y a eu au moins une fentre de repeinte, il faut vider; le fifo du clavier !KFIFO$:	TEST.W	D4		; au moins une fentre repeinte ?	JUMP',EQ EXIT$		; non => EXIT$KFLOOP$:	LIB	?IFCAR		; vide le fifo du clavier	JUMP,EQ KFLOOP$EXIT$:	POPM.L	D3..D5,A3,A5	RET;--------\\; BALMAJ  >;--------/; Met  jour les listes en fonction d'un message reu du FOS.; in	D2.W	nb de assign/deassign; out	D2.W	nb de assign/deassign; mod	D2.W, D7.WBALMAJ:	PUSHM.L	D3..D5,A2..A5	LOAD.L	A4,#(A6)+OBALMS	; A4 <-- ^message	LOAD.L	A3,A4		; A3 <-- ^nom du fichier	LOAD.B	D3,(A3)		; assign/deassign/enter/release ?	JUMP,NS 40$		; oui => 40$	JUMP',NE 10$	INC.L	A3		; A3 <-- ^nom du fichier10$:	CALL	IFSYSTEM	; fichier du genre SYS_LIST ?	JUMP,EQ 90$		; oui => 90$	PUSH.B	(A3)+LGNAME-1	CLR.B	(A3)+LGNAME-1	CALL	IFDIR		; fichier .DIR ?	POP.B	(A3)+LGNAME-1	TEST.W	D7	JUMP',NE 15$		; non => 15$12$:	COMP.B	(A3+),#'.	JUMP,NE 12$	LOAD.B	(A3)-1,#':	; remplace "TOTO.DIR" par "TOTO:"	CLR.B	(A3)15$:	LOAD.L	A3,A4		; A3 <-- ^message	LOAD.L	D4,(A3)+LGBL	; D4 <-- indentificateur du message; Cherche l'unit en fonction de l'identificateur.	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-120$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP,F	90$		; non => 90$				; oui =>	COMP.W	(A5)+OUNNAM,#H'100*'$ ; units physiques ?	JUMP',EQ 25$		; oui => 25$	COMP.L	D4,(A5)+OUNIDE	; est-ce le bon identificateur ?	JUMP',EQ 30$25$:	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,20$	JUMP	90$; Cherche le nom du fichier dans l'unit.30$:	TEST.B	(A3)		; fichier  dtruire ?	JUMP',EQ 35$		; oui => 35$				; non =>	CALL	BALADD		; ajoute ou met  jour dans la liste	JUMP	90$35$:	CALL	BALSUB		; enlve de la liste	JUMP	90$; Traite le cas des units physiques.40$:	COMP.B	D3,#-1	JUMP',EQ 45$	COMP.B	D3,#-2	JUMP',EQ 45$	COMP.B	D3,#-3	JUMP',EQ 50$	COMP.B	D3,#-4	JUMP,EQ 60$	COMP.B	D3,#-7	JUMP,EQ 70$	JUMP	90$45$:	INC.W	D2		; D2 <-- un assign/deassign de plus	JUMP	90$50$:				; ENTER =>	TEST.W	(A3)+1+LGNAME+1	; y a-t-il une erreur ?	JUMP,NE 90$		; oui => 90$	LOAD.L	A3,#(A3)+1	; A3 <-- ^nom physique ($FLO_0)	CALL	GETNAP		; A4 <-- ^nom de l'unit	JUMP,NE 90$	LOAD.L	A3,A4	CALL	IFEQUUSE	; unit dj utilise ?	JUMP,NE 90$		; oui => 90$				; non =>	FOS	?GETUNIT	; A4/D4 <-- ^map/mode	JUMP,NE 90$	LOAD.L	A5,#(A6)+OUNIT	LOAD.W	D5,#MAXUNIT-151$:	TEST.B	(A5)+OUNUSE	; fentre utilise ?	JUMP',F	52$		; non => 52$				; oui =>	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,51$52$:	LOAD.L	A5,#(A5)-LUN	; A5 <-- ^dernire unit (pre)	CALL	OPEWDOS		; A5 <-- ^nouvelle unit	JUMP,NE 90$	LOAD.L	A4,#(A5)+OUNNAM53$:	LOAD.B	(A4+),(A3+)	; OUNNAM <-- nom de l'unit physique	JUMP,NE 53$	LOAD.B	(A4)-1,#'*	; OUNNAM <-- tous les fichiers	CLR.B	(A4)	CALL	RDDIRINFO	; lit START_DIR.INFO s'il existe;;?	LOAD.W	D3,#3		; D3 <-- essaye pendant 3 secondes max !;;?54$:	CALL	_RDLIST		; lit la liste des noms de fichiersJUMP,NE 90$;;?	JUMP',EQ 56$		; ok => 56$;;?	DEC.W	D3;;?	JUMP,NS 90$;;?	LOAD.W	D4,#50;;?	NTREL	?DELMS		; attend une seconde ...;;?	JUMP	54$;;?56$:	CALL	SORTALL		; trie toute la liste	JUMP	90$60$:				; RELEASE =>	TEST.W	(A3)+1+LGNAME+1	; y a-t-il une erreur ?	JUMP,NE 90$		; oui => 90$	LOAD.L	A3,#(A3)+1	; A3 <-- ^nom physique ($FLO_0)	CALL	GETNAP		; A4 <-- ^nom de l'unit	JUMP,NE 90$62$:	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-163$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP,F	90$		; non => 90$				; oui =>	LOAD.L	A3,#(A5)+OUNNAM	LOAD.L	A2,A464$:	TEST.B	(A2)	JUMP',EQ 65$	COMP.B	(A2+),(A3+)	JUMP,EQ 64$	JUMP'	67$65$:	CALL	CLOWDOS		; ferme cette fentre, sans rafficher	JUMP	62$67$:	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,63$	JUMP'	90$70$:				; SDIR =>	CALL	INFO		; raffiche les informations tout en haut;	JUMP'	90$90$:	POPM.L	D3..D5,A2..A5	RET;----------\\; BALMAJASS >;----------/; Refait la liste des units physiques si un assign/deassign a t fait.; in	D2.W	nb de assign/deassign; out	D2.W	nb de assign/deassign; mod	D2.W, D7.WBALMAJASS:	PUSH.L	A5	TEST.W	D2		; y a-t-il eu des assign/deassign ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- descripteur units physiques	CALL	RDLIST		; relit la liste des units physiques	TSET.B	(A5)+OUNMOD:#BMAJICO	TSET.B	(A5)+OUNMOD:#BMAJNBF	CLR.W	D290$:	POP.L	A5	RET;--------\\; BALADD  >;--------/; Ajoute ou met  jour un fichier dans la liste.; in	A5.L	^description unit;	A3.L	^message; out	-; mod	D7.WBALADD:	PUSHM.L	D0..D4,A0..A4; Vrifie si le nom  ajouter existe dj.; Si oui, il faudra uniquement le mettre  jour.; Si non, il faudra l'ajouter dans la liste.	LOAD.L	A2,(A5)+OUNPLI	; A2 <-- ^premier nom	CLR.W	D210$:	TEST.B	(A2)		; emplacement libre ?	JUMP',EQ 20$		; oui => 20$				; non =>	LOAD.L	A1,A2	LOAD.L	A0,A314$:	TEST.B	(A1)	JUMP',EQ 16$	COMP.B	(A1+),(A0+)	; noms identiques ?	JUMP,EQ 14$		; oui => 14$	JUMP	20$		; non => 20$16$:	TEST.B	(A0)		; vraiment identiques ?	JUMP,EQ 50$		; oui => 50$20$:	LOAD.L	A2,#(A2)+LFL	; A2 <-- ^fichier suivant	INC.W	D2	COMP.W	D2,(A5)+OUNNBM	JUMP,LO 10$; Cherche un emplacement vide dans la liste.	LOAD.L	A2,(A5)+OUNPLI	; A2 <-- ^premier nom	CLR.W	D230$:	TEST.B	(A2)		; emplacement libre ?	JUMP',EQ 40$		; oui => 40$				; non =>	LOAD.L	A2,#(A2)+LFL	; A2 <-- ^fichier suivant	INC.W	D2	COMP.W	D2,(A5)+OUNNBM	JUMP,LO 30$; Si la liste est toute pleine, il faut la refaire, ce qui; a pour consquence d'ajouter de nouveau 100 places libres.	CALL	RDLIST		; relit toute la liste	JUMP,NE 90$	CALL	SORTALL		; trie tout	TSET.B	(A5)+OUNMOD:#BMAJICO	TSET.B	(A5)+OUNMOD:#BMAJNBF	JUMP	90$; Lit les arguments du fichier et ajoute dans la liste.40$:	LOAD.L	A4,#(A3)+LGNAME	; A4 <-- ^arguments	CALL	PUTFILIST	; liste <-- nom et arguments	INC.W	(A5)+OUNNBT	CALL	SORTONE		; ajoute dans liste/index	TSET.B	(A5)+OUNMOD:#BMAJICO	TSET.B	(A5)+OUNMOD:#BMAJNBF	JUMP	90$; Lit les arguments du fichier et met  jour la liste.50$:	LOAD.B	D0,(A2)+OFLOPE	; D0 <-- compteur d'ouvertures	LOAD.L	D1,(A2)+OFLLG	; D1 <-- longueur	LOAD.L	D2,(A2)+OFLATT	; D2 <-- attributs	LOAD.L	A4,#(A3)+LGNAME	; A4 <-- ^arguments	PUSH.W	(A2)+OFLRAF	CALL	PUTFILIST	; liste <-- nom et arguments	POP.W	(A2)+OFLRAF	TEST.L	D2:#BATTSEL	; l'icne tait-elle slectionne ?	JUMP',BC 60$		; non => 60$	TSET.B	(A2)+OFLATT+0:#BATTSEL-24 ; slectionne l'icne60$:	TEST.B	(A5)+OUNFAAF:#BFLAT-16 ; affiche noms, tailles et dates ?	JUMP,BS 75$		; oui => 75$; Vrifie si la longueur a chang (dans le sens 0 --> x ou x --> 0),; car l'icne .CODE est pointille (accs) si la longueur est nulle !	TEST.B	(A5)+OUNFAAF:#BFLAI-16 ; affiche les icnes ?	JUMP',BC 65$		; non => 65$	COMP.L	D1,(A2)+OFLLG	; mme longueur ?	JUMP',EQ 65$		; oui => 65$	TEST.L	D1	JUMP',EQ 63$	TEST.L	(A2)+OFLLG	JUMP',NE 65$63$:				; longueur tait/devient nulle =>	CALL	GETTYPE		; D3 <-- type du fichier	COMP.W	D3,#TYPCODE	JUMP',EQ 75$	COMP.W	D3,#TYPSYSC	JUMP',EQ 75$65$:	LOAD.B	D1,(A2)+OFLOPE	AND.B	D1,#H'80	AND.B	D0,#H'80	COMP.B	D0,D1		; mme compteur d'ouvertures ?	JUMP',EQ 90$		; oui => 90$75$:	LOAD.W	(A2)+OFLRAF,#-1	; signal icne  repeindre	TSET.B	(A5)+OUNMOD:#BMAJICO90$:	POPM.L	D0..D4,A0..A4	RET;--------\\; BALSUB  >;--------/; Supprime un fichier dans une liste.; in	A5.L	^description unit;	A3.L	^message; out	-; mod	D7.WBALSUB:	PUSHM.L	D2..D4,A1..A4; Cherche le fichier  supprimer dans la liste des noms.	LOAD.L	A4,(A5)+OUNPLI	; A4 <-- ^liste des noms	CLR.W	D4		; D4 <-- rang initial10$:	TEST.B	(A4)		; nom existe ?	JUMP',EQ 18$		; non => 18$				; oui =>	LOAD.L	A2,A4	LOAD.L	A1,#(A3)+1	LOAD.W	D3,#16		; D3 <-- lg max du nom12$:	DEC.W	D3	JUMP',EQ 14$	TEST.B	(A1)	JUMP',EQ 14$	COMP.B	(A1+),(A2+)	; nom trouv ?	JUMP,EQ 12$	JUMP'	18$14$:	TEST.B	(A2)	JUMP',EQ 20$18$:	LOAD.L	A4,#(A4)+LFL	; A4 <-- ^fichier suivant	INC.W	D4		; D4 <-- rang suivant	COMP.W	D4,(A5)+OUNNBM	JUMP,LO 10$	JUMP	90$20$:	CLR.B	(A4)		; supprime le fichier dans la liste	TEST.B	(A4)+OFLATT+0:#BATTSEL-24 ; icne slectionne ?	JUMP',BC 25$		; non => 25$	TEST.W	(A6)+OSELNB	; slection en cours ?	JUMP',EQ 25$		; non => 25$	DEC.W	(A6)+OSELNB	; un fichier slectionn de moins !25$:	DEC.W	(A5)+OUNNBT	; un fichier en moins; Cherche o est plac le rang dans l'index pour le supprimer.; S'il n'y est pas, ce n'est pas grave. Cela signifie simplement; que le fichier existait, mais qu'il n'tait pas visible !	TEST.W	(A5)+OUNNBL	; index vide ?	JUMP,EQ 85$		; oui => 85$	LOAD.L	A4,(A5)+OUNPIN	; A4 <-- ^index	LOAD.W	D3,(A5)+OUNNBL30$:	COMP.W	D4,(A4+)	; trouv dans l'index ?	JUMP',EQ 40$		; oui => 40$	DEC.W	D3	JUMP,NE 30$	JUMP'	85$; Supprime le fichier dans l'index.40$:	DEC.W	D3	JUMP',EQ 60$	LOAD.L	A3,#(A4)-250$:	LOAD.W	(A3+),(A4+)	; bouche le trou dans l'index	DEC.W	D3	JUMP,NE 50$60$:	DEC.W	(A5)+OUNNBL	; un fichier en moins	TSET.B	(A5)+OUNMOD:#BMAJICO85$:	TSET.B	(A5)+OUNMOD:#BMAJNBF90$:	POPM.L	D2..D4,A1..A4	RET;-----------\\; SEARCHFILE >;===========/; Cherche la mini-description d'un fichier.; Peut remplacer FOS,?ARGS si le fichier est list.; in	A3.L	^nom du fichier; out	A4.L	^description (OFL...);	D7.W	erreur (ERUNNI/ERFDNE); mod	D7.W, A4.LSEARCHFILE:	PUSHM.L	D4,A3,A5	CALL	SEARCHUNIT	; A3 <-- ^juste le nom, A5 <-- ^unit	JUMP',NE 90$; Si la clef existe, saute-la avant de chercher dans la liste.	LOAD.L	A4,A310$:	LOAD.B	D4,(A4+)	JUMP',EQ 20$	COMP.B	D4,#'`		; clef ?	JUMP,NE 10$		; non => 10$	LOAD.L	A3,A4		; oui => pointe juste aprs; Cherche le fichier dans la liste des noms.20$:	CALL	SEARCHNAME	; A4/D4 <-- ^descripteur/rang90$:	POPM.L	D4,A3,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; SEARCHUNIT >;-----------/; Prpare un nom pour l'ajouter ou l'enlever d'une liste.;	#MM1:TOTO:TITI.TEXT  -->    TITI.TEXT;	#MM1:TOTO:TITI.DIR   -->    TITI:;	#MM1:TOTO:TITI:      -->    TITI:; in	A3.L	^nom complet; out	A3.L	^nom prpar dans OBUFIL;	A5.L	^description unit;	D7.W	erreur (ERUNNI); mod	D7.W, A3.L, A5.LSEARCHUNIT:	PUSHM.L	D3..D5,A2,A4; Construit le nom du fichier pour la liste.	LOAD.L	A4,#(A6)+OBUFIL	LOAD.L	A2,A3	CALL	SKIPREP		; A3 <-- ^juste le nom	TEST.B	(A3)	JUMP,EQ 30$	CALL	IFDIR		; fichier .DIR ?	JUMP,EQ 20$10$:	LOAD.L	D4,A3	SUB.L	D4,A2		; D4 <-- longueur prfixe15$:	LOAD.B	(A4+),(A3+)	; OBUFIL <-- juste le nom	JUMP,NE 15$	JUMP	50$20$:	LOAD.L	D4,A3	SUB.L	D4,A2		; D4 <-- longueur prfixe22$:	LOAD.B	D3,(A3+)	JUMP',EQ 25$	COMP.B	D3,#'.	JUMP',EQ 25$	LOAD.B	(A4+),D3	; OBUFIL <-- nom sans l'extension .DIR	JUMP	22$25$:	LOAD.B	(A4+),#':	CLR.B	(A4)	JUMP	50$30$:	DEC.L	A335$:	COMP.L	A3,A2	JUMP,EQ 10$	COMP.B	(-A3),#':	JUMP,NE 35$	INC.L	A3	JUMP	10$; Cherche dans quelle unit est le fichier.50$:	LOAD.W	D7,#ERUNNI		; D7 <-- unit pas trouve	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-160$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP,F	90$		; non => 90$				; oui =>	LOAD.L	A4,#(A5)+OUNNAM	; A4 <-- ^nom de l'unit	LOAD.L	A3,A4	CALL	SKIPREP	LOAD.L	D3,A3	SUB.L	D3,A4		; D3 <-- lg du nom de l'unit	COMP.W	D3,D4		; lg identiques ?	JUMP',NE 70$		; non => 70$	LOAD.L	A3,A2		; A3 <-- ^prfixe du fichier	LOAD.W	D3,D4		; D3 <-- lg  comparer65$:	TEST.W	D3	JUMP',EQ 80$	DEC.W	D3	COMP.B	(A3+),(A4+)	JUMP,EQ 65$70$:	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,60$	JUMP'	90$80$:	LOAD.L	A3,#(A6)+OBUFIL	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3..D5,A2,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; SEARCHNAME >;-----------/; Cherche le rang (absolu) d'un fichier d'aprs son nom.; in	A3.L	^nom de fichier (sans rep:); out	A4.L	^description (OFL...);	D4.W	rang;	D7.W	erreur; mod	D4.L, D7.W, A4.LSEARCHNAME:	PUSHM.L	A1,A2	LOAD.L	A4,(A5)+OUNPLI	; A4 <-- ^liste des noms	CLR.W	D4		; D4 <-- rang initial20$:	TEST.B	(A4)		; nom existe ?	JUMP',EQ 28$		; non => 28$				; oui =>	LOAD.L	A2,A4	LOAD.L	A1,A322$:	TEST.B	(A1)	JUMP',EQ 24$	COMP.B	(A1+),(A2+)	; nom trouv ?	JUMP,EQ 22$	JUMP'	28$24$:	TEST.B	(A2)	JUMP',EQ 40$28$:	LOAD.L	A4,#(A4)+LFL	; A4 <-- ^fichier suivant	INC.W	D4		; D4 <-- rang suivant	COMP.W	D4,(A5)+OUNNBM	JUMP,LO 20$	LOAD.W	D7,#ERFDNE	; D7 <-- pas trouv !	JUMP'	90$40$:	TSET.L	D4:#15		; D4 <-- rang absolu	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	A1,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; PREPFIC >;========/; Prpare le nom du fichier source avec le verrou.; in	A5.L	^description unit;	D4.W	rang (0..n); out	A3.L	^nom du fichier source;	D7.W	erreur; mod	D7.W, A3.LPREPFIC:	PUSHM.L	D3,A4	CALL	GETPFILE	; A3 <-- ^nom	LOAD.L	D3,(A3)+OFLATT	; D3 <-- attributs	TEST.L	D3:#BATTQ	; fichier verrouill ?	JUMP',BS 20$		; oui => 20$				; non =>	CALL	PREPFIS	CLR.W	D7		; D7 <-- ok	JUMP	90$20$:				; verrouill =>	CALL	IFDBOXCLEF	; demande la clef ...	JUMP,NE 90$	LOAD.W	D7,#ERANNULE	COMP.W	D3,#F1		; D'ACCORD ?	JUMP,NE 90$		; non => 90$				; oui =>	LOAD.L	A4,#(A6)+OBUFIS	; A4 <-- ^buffer o mettre le nom	LOAD.L	A3,#(A5)+OUNNAM	PUSH.L	A430$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- unit et/ou rpertoires	JUMP,NE 30$	POP.L	A3	CALL	SKIPREP	LOAD.L	A4,A3	LOAD.L	A3,#(A6)+OBUCLE35$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- clef`	JUMP,NE 35$	LOAD.B	(A4)-1,#'`	CALL	GETPFILE	; A3 <-- ^nom40$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- nom du fichier	JUMP,NE 40$	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^fichier source	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PREPFIS >;========/; Prpare le nom du fichier source.; in	A5.L	^description unit;	D4.W	rang (0..n); out	A3.L	^nom du fichier source; mod	D7.W, A3.LPREPFIS:	PUSH.L	A4	LOAD.L	A4,#(A6)+OBUFIS	; A4 <-- ^buffer o mettre le nom	LOAD.L	A3,#(A5)+OUNNAM	COMP.W	(A3),#H'100*'$	JUMP',EQ 15$	PUSH.L	A410$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- unit et/ou rpertoires	JUMP,NE 10$	POP.L	A3	CALL	SKIPREP	LOAD.L	A4,A315$:	CLR.B	(A4)	CALL	GETPFILE	; A3 <-- ^nom	JUMP',NE 80$40$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- nom du fichier	JUMP,NE 40$80$:	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^fichier source	POP.L	A4	RET;--------\\; PREPFID >;========/; Prpare le nom du fichier destination.; in	A4.L	^nom unit destination;	A5.L	^description unit source;	D3.W	type du fichier source; out	A3.L	^nom du fichier destination; mod	D7.W, A3.LPREPFID:	PUSHM.L	D2..D4,A1,A2	LOAD.W	D4,D3		; D4 <-- type du fichier source	LOAD.L	A1,#(A6)+OBUFID	; A1 <-- ^buffer o mettre le nom	PUSH.L	A1	LOAD.L	A3,A4		; A3 <-- ^nom unit destination10$:	LOAD.B	(A1+),(A3+)	; OBUFID <-- unit et/ou rpertoires	JUMP,NE 10$	POP.L	A3	CALL	SKIPREP	LOAD.L	A1,A3	CLR.B	(A1); Compte le nombre de ":" dans le nom du fichier source.; S'il n'y en a qu'un, ne transfert pas le nom du fichier; source dans le fichier destination.; source: #MM1:			ne transfert rien	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^fichier source	CALL	SKIPREP	TEST.B	(A3)	JUMP,NE 30$	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^fichier source	CLR.W	D214$:	TEST.B	(A3+)	JUMP',EQ 16$	COMP.B	(A3)-1,#':	JUMP,NE 14$	INC.W	D2		; D2 <-- un ":" de plus	JUMP	14$16$:	COMP.W	D2,#1	JUMP,LE 80$; Transfert le nom du fichier source dans le nom du fichier; destination.; source: #MM1:REP:TOTO.PLAN	transfert TOTO.PLAN; source: #MM1:REP:TRAVAIL:	transfert TRAVAIL:	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^fichier source	CALL	SKIPREP	TEST.B	(A3)	JUMP',NE 30$	DEC.L	A320$:	COMP.B	(-A3),#':	JUMP,NE 20$	INC.L	A330$:	LOAD.L	A2,A3	LOAD.W	D2,#-140$:	INC.W	D2		; D2 <-- nb de caractres sans l'extension	LOAD.B	D3,(A2+)	JUMP',EQ 42$	COMP.B	D3,#'.	JUMP',EQ 42$	COMP.B	D3,#'!	JUMP',EQ 42$	COMP.B	D3,#':	JUMP,NE 40$42$:	LOAD.W	D3,D2	JUMP',EQ 44$43$:	LOAD.B	(A1+),(A3+)	; OBUFID <-- nom sans extension	DEC.W	D3	JUMP,NE 43$	CLR.B	(A1)	COMP.W	D4,#TYPDIR	; dossier ?	JUMP',NE 44$		; non => 44$	LOAD.B	(A1)+0,#':	; OBUFID <-- termine le nom par ":"	CLR.B	(A1)+144$:	COMP.W	D4,#TYPDOSSIER	; transforme toujours DOSSIER: en DOSSIER1: !	JUMP',EQ 45$	CALL	PREPFIDIFSD	; unit source = destination ?	JUMP,NE 60$		; non => 60$45$:	LOAD.B	D3,(A1)-1	; D3 <-- dernier caractre du nom	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9		; dj termin par un chiffre ?	JUMP',HI 50$		; non => 50$				; oui =>	INC.B	D3		; D3 <-- chiffre suivant	COMP.B	D3,#'9	JUMP',LS 47$	LOAD.B	D3,#'0		; D3 <-- boucle !47$:	LOAD.B	(A1)-1,D3	JUMP'	60$50$:	COMP.B	D2,#8		; peut-on ajouter un chiffre au nom ?	JUMP',LS 52$		; oui => 52$	DEC.L	A1		; non => supprime l'actuel dernier caractre52$:	LOAD.B	(A1+),#'160$:	LOAD.B	(A1+),(A3+)	; OBUFID <-- extension	JUMP,NE 60$80$:	LOAD.L	A3,#(A6)+OBUFID	; A3 <-- ^fichier destination	POPM.L	D2..D4,A1,A2	RET;---------\\; PREPDSSD >;=========/; Prpare les dossiers systmes source et destination.; in	A1.L	^nom unit source;	A2.L	^nom unit destination; out	D7.W	erreur; mod	D7.WPREPDSSD:	PUSHM.L	D0,D3,A1..A4	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 46$		; oui => 46$	LOAD.L	A3,#(A6)+OBUDSS20$:	LOAD.B	D3,(A1+)	JUMP',EQ 22$	LOAD.B	(A3+),D3	; OBUDSS <-- nom unit source	COMP.B	D3,#':	JUMP,NE 20$22$:	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBUDSD30$:	LOAD.B	D3,(A2+)	JUMP',EQ 32$	LOAD.B	(A3+),D3	; OBUDSD <-- nom unit destination	COMP.B	D3,#':	JUMP,NE 30$32$:	CLR.B	(A3); Regarde si l'unit source est la mme que l'unit destination.	LOAD.L	A1,#(A6)+OBUDSS	LOAD.L	A2,#(A6)+OBUDSD40$:	TEST.B	(A1)	JUMP',EQ 42$	COMP.B	(A1+),(A2+)	JUMP,EQ 40$	JUMP'	50$42$:	TEST.B	(A2)	JUMP',NE 50$46$:	CLR.B	(A6)+OBUDSS	; pas de dossier systme source	CLR.B	(A6)+OBUDSD	; pas de dossier systme destination	CLR.W	D7		; D7 <-- ok	JUMP'	90$; Lit les blocs d'informations source et destination.50$:	LOAD.L	A3,#(A6)+OBUDSS	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D0,#FOS?INFODISK	CALL	ERCALL		; OBUHEAD <-- bloc d'informations source	JUMP',NE 90$	LOAD.L	A4,#(A4)+OBK0SYS	CALL	SKIPREP52$:	LOAD.B	(A3+),(A4+)	JUMP,NE 52$	LOAD.L	A3,#(A6)+OBUDSD	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D0,#FOS?INFODISK	CALL	ERCALL		; OBUHEAD <-- bloc d'informations destination	JUMP',NE 90$	LOAD.L	A4,#(A4)+OBK0SYS	CALL	SKIPREP54$:	LOAD.B	(A3+),(A4+)	JUMP,NE 54$90$:	POPM.L	D0,D3,A1..A4	RET;------------\\; PREPFIDIFSD >;------------/; Regarde si le rpertoire source est le mme que le rpertoire destination.; in	-; out	D7.W	EQ si rep source = destination; mod	D7.WPREPFIDIFSD:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,#(A6)+OBUFIS	LOAD.L	A3,A4	CALL	SKIPREP	LOAD.L	D3,A3	SUB.L	D3,A4		; D3 <-- lg rp source	LOAD.L	A4,#(A6)+OBUFID	LOAD.L	A3,A4	CALL	SKIPREP	LOAD.L	D4,A3	SUB.L	D4,A4		; D4 <-- lg rp destination	LOAD.W	D7,#1		; D7 <-- diffrents	COMP.W	D3,D4		; compare les longueurs ?	JUMP',NE 90$	LOAD.L	A3,#(A6)+OBUFIS	LOAD.L	A4,#(A6)+OBUFID30$:	COMP.B	(A3+),(A4+)	; compare les noms ?	JUMP',NE 90$	DEC.W	D3	JUMP,NE 30$	CLR.W	D7		; D7 <-- identiques90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PREPDDU >;========/; Prpare le nom du dossier destination.; in	A5.L	^description unit;	D4.W	rang (0..n); out	A4.L	^nom du dossier destination; mod	D7.W, A4.LPREPDDU:	PUSHM.L	D3,A3	LOAD.L	A4,#(A6)+OBUFIE	; A4 <-- ^buffer o mettre le nom	LOAD.L	A3,#(A5)+OUNNAM	COMP.W	(A3),#H'100*'$	JUMP',EQ 15$	PUSH.L	A410$:	LOAD.B	(A4+),(A3+)	; OBUFIE <-- unit et/ou rpertoires	JUMP,NE 10$	POP.L	A3	CALL	SKIPREP	LOAD.L	A4,A315$:	CLR.B	(A4)	CALL	GETPFILE	; A3 <-- ^nom	JUMP',NE 80$40$:	LOAD.B	(A4+),(A3+)	; OBUFIE <-- nom du dossier	JUMP,NE 40$80$:	LOAD.L	A4,#(A6)+OBUFIE	; A4 <-- ^dossier destination	POPM.L	D3,A3	RET;--------\\; PREPFIX >;========/; Prpare la ligne de commande pour excuter un programme; et charger un fichier.; in	A5.L	^description unit;	D4.W	rang (0..n); out	A3.L	^ligne de commande;	D7.W	erreur; mod	D7.W, A3.LPREPFIX:	PUSHM.L	D2,D3,D6,A1,A2,A4	PUSH.L	D3		; stack <-- une variable .L temporaire	CALL	GETPFILE	; A3 <-- ^nom	JUMP,NE 90$10$:	COMP.B	(A3+),#'.	; A3 <-- ^extension	JUMP',EQ 15$	TEST.B	(A3)-1		; nom sans extension ?	JUMP,NE 10$		; non => 10$12$:	LOAD.W	D7,#ERSPROG	; oui => erreur	JUMP	90$15$:	LOAD.L	A2,A3	LOAD.L	A4,(A6)+OPUSER	; A4 <-- ^fichier START_USER.INFO	CALL	SKIPINFO	; A4 <-- ^aprs les pseudo-instructions	LOAD.L	(SP)+0,A4	CALL	SRCEINFO	; A4 <- ^ligne dans START_USER.INFO	JUMP',EQ 16$	LOAD.L	A4,(A6)+OPINFO	; A4 <-- ^fichier START.INFO	CALL	SKIPINFO	; A4 <-- ^aprs les pseudo-instructions	LOAD.L	(SP)+0,A4	CALL	SRCEINFO	; A4 <- ^ligne dans START.INFO	JUMP,NE 12$16$:	PUSH.L	A4	CALL	NEXTINFO	; A4 <-- ^suite	CALL	SRCEINFO	; extension rfrence plusieurs fois ?	POP.L	A4	JUMP,NE 20$		; non => 20$				; oui =>	CALL	_EXMMENU	; A3 <-- ^mmenu	CLR.W	D3		; D3 <-- case initiale	CALL	_MMENU		; attend choix ...	JUMP,NE 90$	LOAD.W	D7,#ERANNULE	; D7 <-- erreur "case vide"	TEST.W	D3		; "clic" dans la case vide ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A3,A2		; A3 <-- ^extension	LOAD.L	A4,(SP)+0	; A4 <-- ^fichier START[_USER].INFO17$:	CALL	SRCEINFO	; A4 <-- ^ligne dans START[_USER].INFO	DEC.W	D3	JUMP',EQ 20$	CALL	NEXTINFO	; A4 <-- suite	JUMP	17$20$:	LOAD.W	D7,#ERSPROG	; oui => erreur	LOAD.L	A2,#(A6)+OBUFIT30$:	LOAD.B	D3,(A4+)	JUMP,EQ 90$	COMP.B	D3,#CR	JUMP,EQ 90$	COMP.B	D3,#SPACE	JUMP',EQ 32$	COMP.B	D3,#TAB	JUMP,NE 30$32$:	LOAD.B	D3,(A4+)	JUMP,EQ 90$	COMP.B	D3,#CR	JUMP,EQ 90$	COMP.B	D3,#SPACE	JUMP,EQ 32$	COMP.B	D3,#TAB	JUMP,EQ 32$	DEC.L	A4	COMP.B	(A4),#'.	JUMP,EQ 90$	CLR.L	D2		; D2 <-- .CODE pas encore mis	LOAD.B	D2,(A4+)	COMP.B	D2,#'"	JUMP',EQ 40$	DEC.L	A4	LOAD.B	D2,#SPACE40$:	LOAD.B	D3,(A4+)	JUMP',EQ 45$	COMP.B	D3,#CR	JUMP',EQ 45$	COMP.B	D3,D2	JUMP',EQ 45$	COMP.B	D3,#TAB	JUMP',EQ 45$	COMP.B	D3,#SPACE	JUMP',EQ 43$	COMP.B	D3,#'/	JUMP',EQ 43$42$:	LOAD.B	(A2+),D3	; OBUFIT <-- nom du programme	JUMP	40$43$:	TSET.L	D2:#16		; .CODE dj mis ?	JUMP,BS 42$		; oui => 42$	LOAD.B	(A2+),#'.	LOAD.B	(A2+),#'C	LOAD.B	(A2+),#'O	LOAD.B	(A2+),#'D	LOAD.B	(A2+),#'E	JUMP	42$45$:	TSET.L	D2:#16		; .CODE dj mis ?	JUMP',BS 46$		; oui => 46$	LOAD.B	(A2+),#'.	LOAD.B	(A2+),#'C	LOAD.B	(A2+),#'O	LOAD.B	(A2+),#'D	LOAD.B	(A2+),#'E46$:	LOAD.B	(A2+),#SPACE	CALL	GETPFILE	; A3 <-- ^nom	LOAD.L	A1,#0	LOAD.L	D3,(A3)+OFLATT	; D3 <-- attributs	TEST.L	D3:#BATTQ	; fichier cod ?	JUMP',BC 60$		; non => 60$				; oui =>	CALL	IFDBOXCLEF	; non => demande la clef ...	JUMP',NE 90$	LOAD.W	D7,#ERANNULE	COMP.W	D3,#F1		; D'ACCORD ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A1,A2	LOAD.L	A4,#(A6)+OBUCLE50$:	LOAD.B	(A2+),(A4+)	; OBUFIT <-- clef`	JUMP,NE 50$	LOAD.B	(A2)-1,#'`60$:	LOAD.B	(A2+),(A3+)	; OBUFIT <-- nom du fichier	JUMP,NE 60$	COMP.L	A1,#0	JUMP',EQ 70$	LOAD.L	A3,A1		; A3 <-- ^clef`nom	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; vrifie si la clef est correcte ?	JUMP',NE 90$	FOS	?CLOSE70$:	LOAD.L	A3,#(A6)+OBUFIT	CLR.W	D7		; D7 <-- ok90$:	POP.L	D3	POPM.L	D2,D3,D6,A1,A2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; PREPFIXW >;=========/; Ajoute ventuellement un numro de fentre entre { } dans la; ligne de commande ( la fin).; in	A3.L	^ligne de commande; out	(A3)+	ligne de commande modifie;	D7.W	erreur; mod	D7.WPREPFIXW:	PUSHM.L	D0..D4,A1..A4	LIB	?GETSHIFT	; D3 <-- touches super-shift	CLR.W	D7		; D7 <-- ok	TEST.L	D3:#BPROGRA	; touche (PROGRA) enfonce ?	JUMP,BC 90$		; non => 90$				; oui =>	LOAD.L	A1,A3		; A1 <-- ^ligne de commande	LOAD.L	A2,(A0)+ODFPSK	; A2 <-- ^table des soft-keys	ADD.W	A2,(A2)+4	; A2 <-- ^table des fentres (16 x .B)	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^buffer	LOAD.B	(A4+),#SPACE	CLR.B	(A4+)		; buffer <-- case blanche	CLR.B	D0	LOAD.W	D1,#1	LOAD.W	D2,#16	CLR.L	D4		; D4 <-- cases grises20$:	CLR.W	D3	LOAD.B	D3,(A2)+1	; D3 <-- numro fentre	JUMP,EQ 40$	PUSHM.L	D4,D6,A4	LIB	?SRCWDO		; fentre utilise ?	POPM.L	D4,D6,A4	JUMP',NE 22$	TSET.L	D4:D1		; D4 <-- une case grise22$:	COMP.B	D0,(A2)+0	JUMP',EQ 26$	LOAD.B	D0,(A2)+0	LOAD.B	(A4+),#-1	; buffer <-- ligne horizontale	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'[	PUSHM.L	D2..D4	CLR.L	D4	LOAD.B	D4,D0		; D4 <-- numro	LOAD.W	D3,#1		; D3 <-- nb de digits	CLR.W	D2		; D2 <-- mode	LIB	?PUTDEC		; buffer <-- numro	POPM.L	D2..D4	LOAD.B	(A4+),#']	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'-	LOAD.B	(A4+),#'>	JUMP'	30$26$:	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	; [	LOAD.B	(A4+),#'"	; n	LOAD.B	(A4+),#SPACE	; ]	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	; -	LOAD.B	(A4+),#SPACE	; >30$:	LOAD.L	A3,#R16"01$32$:	LOAD.B	(A4+),(A3+)	; buffer <-- "fentre"	JUMP,NE 32$	DEC.L	A4	PUSHM.L	D2,D4	CLR.L	D4	LOAD.W	D4,D3		; D4 <-- numro	LOAD.W	D3,#2		; D3 <-- nb de digits	CLR.W	D2		; D2 <-- mode	LIB	?PUTDEC		; buffer <-- numro	POPM.L	D2,D4	LOAD.B	(A4+),#SPACE	CLR.B	(A4+)	INC.W	D1		; D1 <-- no case suivante40$:	ADD.L	A2,#2		; A2 <-- ^fentre suivante	DEC.W	D2	JUMP,NE 20$	CLR.B	(A4+)	CALL	_NORMMOUSE	; souris: enlve le sablier	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^mmenu	LOAD.W	D3,#2^15	; D3 <-- cases grises dans D4.L	CALL	_MMENU		; attend choix ...	JUMP,NE 90$	LOAD.W	D7,#ERANNULE	; D7 <-- erreur "case vide"	TEST.W	D3		; "clic" dans la case vide ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A2,(A0)+ODFPSK	; A2 <-- ^table des soft-keys	ADD.W	A2,(A2)+4	; A2 <-- ^table des fentres (16 x .B)50$:	ADD.L	A2,#2	CLR.L	D4	LOAD.B	D4,(A2)-2+1	JUMP,EQ 50$	DEC.W	D3	JUMP,NE 50$	LOAD.L	A4,A1		; A4 <-- ^ligne de commande55$:	TEST.B	(A4+)	JUMP,NE 55$	LOAD.B	(A4)-1,#SPACE	LOAD.B	(A4+),#'{	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDCM	LIB	?PUTDEC		; commande <-- {numro}	LOAD.B	(A4+),#'}	CLR.B	(A4)	CLR.W	D7		; D7 <-- ok90$:	PUSH.W	D7	CALL	_WAITMOUSE	; souris: met le sablier	POP.W	D7	POPM.L	D0..D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	"  fentre "	.EVEN;---------\\; PREPFIXM >;=========/; Vrifie si un programme est dj en excution,; et ajoute le complment de START.INFO :;	"TEXT 25000/M"  -->  ajoute "25000/M"; in	A3.L	^ligne de commande; out	D7.W	erreur; mod	D7.WPREPFIXM:	PUSHM.L	D2..D5,A2..A4	CALL	SKIPREP		; A3 <-- saute unit:rep:	LOAD.L	A4,(A6)+OPUSER	; A4 <-- ^fichier START_USER.INFO	CALL	SKIPINFO	; A4 <-- ^aprs les pseudo-instructions	CALL	SRCFINFO	; A4 <- ^ligne dans START_USER.INFO	JUMP',EQ 10$	LOAD.L	A4,(A6)+OPINFO	; A4 <-- ^fichier START.INFO	CALL	SKIPINFO	; A4 <-- ^aprs les pseudo-instructions	CALL	SRCFINFO	; A4 <- ^ligne dans START.INFO	JUMP',NE 30$10$:	LOAD.B	D3,(A4+)	JUMP',EQ 30$	COMP.B	D3,#CR	JUMP',EQ 30$	COMP.B	D3,#'"	JUMP,NE 10$12$:	LOAD.B	D3,(A4+)	JUMP',EQ 30$	COMP.B	D3,#CR	JUMP',EQ 30$	COMP.B	D3,#SPACE	; "TEXT 25000/M" dans START.INFO ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D3,#'"	JUMP,NE 12$14$:	COMP.B	(A4+),#'/	JUMP',NE 30$	COMP.B	(A4+),#'N	JUMP',NE 30$	JUMP	80$20$:	LOAD.L	A2,A322$:	TEST.B	(A2+)		; A2 <-- ^fin ligne de commande	JUMP,NE 22$	LOAD.B	(A2)-1,#SPACE24$:	LOAD.B	D3,(A4+)	JUMP',EQ 26$	COMP.B	D3,#CR	JUMP',EQ 26$	COMP.B	D3,#'"	JUMP',EQ 26$	LOAD.B	(A2+),D3	; ligne de commande <-- ajoute "25000/M"	JUMP	24$26$:	CLR.B	(A2)	COMP.B	D3,#'"	JUMP,EQ 14$30$:	CLR.W	D2		; D2 <-- rang40$:	FOS	?VISUCACHE	; D3/D4/D5/A2/A4 <-- paramtres du FOS	JUMP',NE 80$	TEST.W	D4		; excut au moins une fois ?	JUMP',EQ 50$		; non => 50$	LOAD.L	A4,A2		; A4 <-- ^nom du fichier cach	LOAD.L	A2,#R16"02$	LIB	?CPSTRING	; dj en excution ?	JUMP',EQ 70$		; oui => 70$50$:				; non =>	INC.W	D2		; D2 <-- rang suivant	JUMP	40$70$:	CALL	DBOXEXMULTI	; pose la question ...	COMP.W	D3,#'O	JUMP',EQ 80$	LOAD.W	D7,#ERANNULE	JUMP'	90$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET02$:	.B	0,SPACE,'/,-1	.EVEN;--------\\; DIRDOC  >;========/; Effectue un DIR pour les documents avant un EXECUTE.; in	A5.L	^description unit; out	D7.W	erreur; mod	D7.WDIRDOC:	PUSHM.L	D3,A2..A4	CALL	RELDOC		; REL si oubli	LOAD.L	A2,#(A6)+OBUFIT	LOAD.L	A3,#(A5)+OUNNAM;;?	CALL	UNITSRC		; A4 <-- ^autre nom logique;;?	JUMP',NE 40$;;?20$:;;?	LOAD.B	(A2+),(A4+)	; OBUFIT <-- autre nom logique;;?	JUMP,NE 20$;;?	DEC.L	A2;;?25$:;;?	COMP.B	(A3+),#':;;?	JUMP,NE 25$40$:	LOAD.B	(A2+),(A3+)	; OBUFIT <-- unit:rep:*	JUMP,NE 40$	LOAD.L	A3,#(A6)+OBUFIT	CALL	SKIPREP	LOAD.B	(A3+),#',	; OBUFIT <-- unit:rep:,	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBUFIT	PUSH.L	D0	LOAD.L	D0,#FOS?DIR	CALL	ERCALL		; DIR o est le document	POPM.L	D0	POPM.L	D3,A2..A4	TEST.W	D7		; retour EQ/NE	RET.IF	0;--------\\; UNITSRC >;--------/; Cherche l'autre nom logique d'un nom logique.; Par exemple, #TOTO: trouvera #MM1: !; in	A3.L	^nom logique (#TOTO:#REP:...); out	A4.L	^autre nom logique (#MM1:);	D7.W	erreur; mod	D7.W, A4.LUNITSRC:	PUSHM.L	D3,D4,A1..A3,A5	LOAD.L	A5,#(A6)+OUNIT	LOAD.L	A4,(A5)+OUNPLI	LOAD.W	D4,(A5)+OUNNBM	DEC.W	D4		; D4 <-- -1  cause du test NMO !10$:	TEST.B	(A4)		; nom utilis ?	JUMP,EQ 60$		; non => 60$				; oui =>	LOAD.W	D3,#LGNAME+1	LOAD.L	A2,A4	LOAD.L	A1,A320$:	DEC.W	D3	JUMP,EQ 60$	COMP.B	(A2),#':	JUMP',EQ 30$	COMP.B	(A2+),(A1+)	JUMP,EQ 20$	JUMP	60$30$:	COMP.B	(A1),#':	JUMP',NE 60$	COMP.W	D3,#2	JUMP',LO 60$40$:	TEST.B	(A2+)		; A2 <-- ^autre nom logique	JUMP,NE 40$	TEST.B	(A2)		; 2me nom existe ?	JUMP',EQ 60$		; non => 60$	LOAD.L	A4,A2		; A4 <-- ^autre nom logique	CLR.W	D7		; D7 <-- trouv	JUMP'	90$60$:	LOAD.L	A4,#(A4)+LFL	; A4 <-- ^nom suivant	DECJ.W,NMO D4,10$	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POPM.L	D3,D4,A1..A3,A5	TEST.W	D7		; retour EQ/NE	RET.ENDIF;--------\\; RELDOC  >;========/; Effectue un REL global pour les documents.; in	-; out	-; mod	D7.WRELDOC:	PUSHM.L	D4,A3	LOAD.L	A3,#R16"00$	FOS	?REL		; supprime les DIRs prcdents	CLR.W	D4	FOS	?GSDIR		; A3 <-- ^dossier systme	FOS	?DIR		; dossier courant = dossier systme !	POPM.L	D4,A3	RET00$:	.B	0		; nom de rpertoire nul	.EVEN;----------\\; NEWOPNAME >;==========/; Met dans le nouveau OUNNAM le contenu du OUNNAM du pre.;	in^A2	in^A3		out^A3 (nom construit);	----------------------------------------------;	$	#MM0:		#MM0:;	#MM0:*	REP:		#MM0:REP:; in	A2.L	^contenu de OUNNAM du "pre";	A3.L	^nom du dossier  ouvrir; out	A3.L	^nom complet  ouvrir; mod	D7.W, A3.LNEWOPNAME:	PUSHM.L	D3,A1,A2,A4	LOAD.L	A4,#(A6)+OBUFIS	; A4 <-- ^buffer	COMP.W	(A2),#H'100*'$	JUMP,EQ 40$; Ouverture d'un nouveau dossier.; Met dans le buffer les noms du pre.	LOAD.L	A1,A210$:	TEST.B	(A1+)		; A1 <-- ^fin du nom	JUMP,NE 10$15$:	COMP.L	A1,A2	JUMP,EQ 60$	COMP.B	(-A1),#':	JUMP,NE 15$	INC.L	A1	LOAD.L	D3,A1	SUB.L	D3,A220$:	LOAD.B	(A4+),(A2+)	; buffer <-- noms du pre	DEC.W	D3	JUMP,NE 20$;;?	JUMP'	60$; Ouverture d'une nouvelle unit physique.; Met dans le buffer le nom du disque s'il existe.40$:;;?	PUSH.L	A4;;?	FOS	?NAMEDISK	; A4 <-- ^nom du disque;;?	LOAD.L	A2,A4;;?	POP.L	A4;;?	JUMP',NE 60$;;?	TEST.B	(A2);;?	JUMP',EQ 60$;;?	COMP.B	(A2),#CR;;?	JUMP',EQ 60$;;?	COMP.B	(A2),#':;;?	JUMP',EQ 60$;;?	LOAD.L	A3,A2; Met dans le buffer le nouveau nom  ouvrir.60$:	LOAD.B	D3,(A3+)	JUMP',EQ 65$	COMP.B	D3,#':	JUMP',EQ 65$	CALL	_MINMAJ	LOAD.B	(A4+),D3	; buffer <-- nouveau nom  ouvrir	JUMP	60$65$:	LOAD.B	(A4+),#':	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nouveau nom	POPM.L	D3,A1,A2,A4	RET;--------\\; GETNAP  >;========/; Donne le nom de l'unit physique d'aprs un nom physique; (rendu par la messagerie du FOS).; in	A3.L	^nom physique (par exemple: $FLO_0); out	A4.L	^nom de l'unit physique;	D7.W	erreur; mod	D7.W, A4.LGETNAP:	PUSHM.L	D3..D5,A2,A3,A5	LOAD.L	A2,A3		; A2 <-- ^nom cherch	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^descripteur des units	LOAD.W	D5,(A5)+OUNNBM	; D5 <-- nb max de noms d'units	LOAD.L	A5,(A5)+OUNPLI	; A5 <-- ^liste des noms d'units10$:	TEST.B	(A5)		; nom d'unit existe ?	JUMP',EQ 50$		; non => 50$	LOAD.L	A3,A5	CLR.W	D3		; D3 <-- pour tous	FOS	?VASSIGN	; A4/D4 <-- ^nom physique/type	JUMP',NE 50$	LOAD.L	A3,A220$:	LOAD.B	D3,(A3+)	JUMP',EQ 22$	COMP.B	D3,#':	JUMP',EQ 22$	COMP.B	D3,(A4+)	; noms identiques ?	JUMP,EQ 20$		; oui => 30$	JUMP'	50$		; non => 50$22$:	LOAD.B	D3,(A4)	JUMP',EQ 30$	COMP.B	D3,#':	JUMP',NE 50$30$:	LOAD.L	A4,A5		; A4 <-- ^unit physique;	CLR.W	D7		; D7 <-- trouv	JUMP'	90$50$:	LOAD.L	A5,#(A5)+LFL	; A5 <-- ^nom d'unit suivant	DEC.W	D5	JUMP,NE 10$	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POPM.L	D3..D5,A2,A3,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; GETPFILE >;=========/; Donne le pointeur  un fichier d'aprs son rang,; en utilisant l'index de classement.; in	A5.L	^description unit;	D4.W	rang (0..n) (:#15 si rang absolu); out	A3.L	^fichier;	D7.W	erreur; mod	D7.W, A3.LGETPFILE:	PUSH.L	D4	LOAD.W	D7,#EROUTF	TCLR.L	D4:#15		; rang absolu ?	JUMP',BS 40$		; oui => 40$	COMP.W	D4,(A5)+OUNNBL	; fichier existant ?	JUMP',HS 90$	LOAD.L	A3,(A5)+OUNPIN	; A3 <-- ^table des index	SL.W	D4,#1	ADD.W	A3,D4	LOAD.W	D4,(A3)	JUMP'	50$40$:	COMP.W	D4,(A5)+OUNNBM	; fichier existant ?	JUMP',HS 90$50$:	LOAD.L	A3,(A5)+OUNPLI	; A3 <-- ^table des fichiers	MUL.WU	D4,#LFL	ADD.L	A3,D4		; A3 <-- ^nom de fichier	CLR.W	D7		; D7 <-- ok90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SKIPREP >;========/; Saute tous les noms d'units et de rpertoires devant; un nom de fichier.; in	A3.L	^unit:rp:rp:nom.ext; out	A3.L	^nom.ext; mod	A3.LSKIPREP:	PUSH.W	D3	CLR.W	D310$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE 10$20$:	DEC.W	D3	JUMP',NS 90$	COMP.B	(-A3),#':	JUMP,NE 20$	INC.L	A390$:	POP.W	D3	RET;--------\\; IFDIR   >;========/; Vrifie si un fichier est un rpertoire (fichier .DIR).; in	A3.L	^nom de fichier; out	D7.W	EQ => c'est un rpertoire;		NE => autrement; mod	D7.WIFDIR:	PUSH.L	A3	LOAD.W	D7,#1		; D7 <-- c'est pas un .DIR10$:	TEST.B	(A3+)		; A3 <-- ^fin du nom	JUMP,NE 10$	DEC.L	A3	COMP.B	(-A3),#'R	JUMP',NE 90$	COMP.B	(-A3),#'I	JUMP',NE 90$	COMP.B	(-A3),#'D	JUMP',NE 90$	COMP.B	(-A3),#'.	JUMP',NE 90$	CLR.W	D7		; D7 <-- y'en  trouv .DIR90$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFGENC  >;========/; Vrifie si un fichier est un gencar (fichier .GENC).; in	A3.L	^nom de fichier; out	D7.W	EQ => c'est un gencar;		NE => autrement; mod	D7.WIFGENC:	PUSH.L	A3	LOAD.W	D7,#1		; D7 <-- c'est pas un .GENC10$:	TEST.B	(A3+)		; A3 <-- ^fin du nom	JUMP,NE 10$	DEC.L	A3	COMP.B	(-A3),#'C	JUMP',NE 90$	COMP.B	(-A3),#'N	JUMP',NE 90$	COMP.B	(-A3),#'E	JUMP',NE 90$	COMP.B	(-A3),#'G	JUMP',NE 90$	COMP.B	(-A3),#'.	JUMP',NE 90$	CLR.W	D7		; D7 <-- y'en  trouv .GENC90$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; IF100_  >;========/; Vrifie si un fichier est dit "systme", c'est--dire s'il; commence par "SMA_", "100_", "SYS_" ou "324_".; in	A3.L	^nom de fichier; out	D7.W	EQ => c'est un fichier systme;		NE => autrement; mod	D7.WIF100_:	PUSHM.L	A1,A2,A4	COMP.B	(A3)+0,#'S	; "SMA_*" ?	JUMP',NE 10$	COMP.B	(A3)+1,#'M	JUMP',NE 10$	COMP.B	(A3)+2,#'A	JUMP',NE 10$	COMP.B	(A3)+3,#'_	JUMP',EQ 80$10$:	LOAD.W	D7,#1		; D7 <-- c'est pas	LOAD.L	A4,#(A6)+OMALIST-420$:	ADD.L	A4,#4		; A4 <-- ^nom de machine suivant	TEST.B	(A4)		; nom existe ?	JUMP',EQ 90$		; non => 90$	LOAD.L	A1,A3	LOAD.L	A2,A4	COMP.B	(A1+),(A2+)	JUMP,NE 20$	COMP.B	(A1+),(A2+)	JUMP,NE 20$	COMP.B	(A1+),(A2+)	JUMP,NE 20$	COMP.B	(A1),#'_	JUMP,NE 20$80$:	CLR.W	D7		; D7 <-- c'en est un !90$:	POPM.L	A1,A2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; IFSYSTEM >;=========/; Vrifie si un fichier est SYS_LIST ou SYS_FREE,; c'est--dire  cacher dfinitivement.; in	A3.L	^nom de fichier; out	D7.W	EQ => c'est un fichier systme;		NE => autrement; mod	D7.WIFSYSTEM:	PUSH.L	A3	LOAD.W	D7,#1		; D7 <-- c'est pas	COMP.B	(A3+),#'S	JUMP',NE 90$	COMP.B	(A3+),#'Y	JUMP',NE 90$	COMP.B	(A3+),#'S	JUMP',NE 90$	COMP.B	(A3+),#'_	JUMP',NE 90$	COMP.B	(A3)+0,#'L	JUMP',NE 50$	COMP.B	(A3)+1,#'I	JUMP',NE 50$	COMP.B	(A3)+2,#'S	JUMP',NE 50$	COMP.B	(A3)+3,#'T	JUMP',NE 50$	TEST.B	(A3)+4	JUMP',EQ 80$50$:	COMP.B	(A3)+0,#'F	JUMP',NE 90$	COMP.B	(A3)+1,#'R	JUMP',NE 90$	COMP.B	(A3)+2,#'E	JUMP',NE 90$	COMP.B	(A3)+3,#'E	JUMP',NE 90$	TEST.B	(A3)+4	JUMP',NE 90$80$:	CLR.W	D7		; D7 <-- c'en est un !90$:	POP.L	A3	RET	.END