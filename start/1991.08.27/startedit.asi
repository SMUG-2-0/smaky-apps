	.SBTTL	STARTEDITMARIFY	=	8		; marge pour les infos en YBVIFALL	=	0		; toutBVIFNEG	=	1		; ngatifBVIFLEFT=	4		; gaucheBVIFRIGHT=	5		; droiteBVIFUP	=	6		; hautBVIFDOWN=	7		; bas;--------\\; EDITE   >;========/; Edite un fichier avec le module EPRO.; in	A3.L	^nom du fichier  diter; out	D7.W	erreur; mod	D7.WEDITE:	PUSHM.L	D1..D6,A1..A5	LOAD.L	A2,A3		; A2 <-- ^nom du fichier	CALL	RDEDIT		; A1/D1 <-- ^contenu du fichier	JUMP,NE 90$; Prpare une swdo avec un cadre dans l'cran.	CALL	EDOPEWDO	; ouvre le sous-fentre	JUMP,NE 90$	LOAD.L	A3,A1		; A3 <-- ^dbut texte  diter	LOAD.L	A4,A1		; A4 <-- curseur au dbut	LOAD.L	D3,D1		; D3 <-- longueur buffer	LOAD.W	D4,#2^BEPROMOUSE!2^BEPROAFCR!2^BEPROAFLF!2^BEPROAFTAB	EPRO_	OPEN		; D6 <-- canal de l'dition	JUMP,NE 70$40$:	LOAD.L	A3,#R16"TXMENE	LIB	?AFMENU41$:	LOAD.L	A4,#R16"00$	; A4 <-- ^touches terminatrices	EPRO_	MAIN		; dite ...	JUMP,NE	45$	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ 41$		; oui => 41$	COMP.W	D3,#KEYMMR	JUMP,EQ 41$	COMP.W	D3,#KEYMDR	JUMP,EQ 41$	COMP.W	D3,#END	JUMP,EQ	60$	COMP.W	D3,#F0	JUMP,EQ	60$	COMP.W	D3,#F0+SHIFT	JUMP,EQ	60$	LOAD.L	A4,#R16"TEDIT1	COMP.W	D3,#F1	JUMP',EQ 50$	LOAD.L	A4,#R16"TEDIT2	COMP.W	D3,#F2	JUMP',EQ 50$	LOAD.L	A4,#R16"TEDIT3	COMP.W	D3,#F3	JUMP',EQ 50$	LOAD.L	A4,#R16"TEDIT4	COMP.W	D3,#F4	JUMP',EQ 50$	LOAD.L	A4,#R16"TEDIT10	COMP.W	D3,#F10	JUMP',EQ 50$	LOAD.L	A4,#R16"TEDIT11	COMP.W	D3,#F11	JUMP',EQ 50$	LOAD.L	A4,#R16"TEDIT12	COMP.W	D3,#F12	JUMP',EQ 50$	LOAD.L	A4,#R16"TEDIT13	COMP.W	D3,#F13	JUMP',EQ 50$	LOAD.L	A4,#R16"TEDIT14	COMP.W	D3,#F14	JUMP',EQ 50$	LOAD.L	A4,#R16"TEDIT15	COMP.W	D3,#F15	JUMP',EQ 50$45$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	41$50$:				; insre "#mm?:" =>	LOAD.B	D3,(A4+)	JUMP,EQ	41$	EPRO_	INSERT		; insre un caractre	JUMP	50$60$:	LOAD.W	D1,#EPRO_GETPDBUFF	EPRO_	EXTEND		; A5 <-- ^descripteur du texte	TEST.B	(A5)+OEPROSTATUS:#BEPROFILMOD	JUMP',BC 68$	CALL	_DBOXSAVE	; sauve le document dit ?	JUMP',NE 68$	COMP.W	D3,#'N	JUMP',EQ 68$	COMP.W	D3,#'O	JUMP,NE 40$; Met  jour le document sur le disque.	EPRO_	CLOSE	LOAD.L	A3,A2		; A3 <-- ^nom du fichier	CALL	WREDIT		; met  jour le fichier	JUMP'	70$68$:	PUSH.W	D7	EPRO_	CLOSE	POP.W	D770$:	CALL	EDCLOWDO	; ferme la sous-fentre	PUSH.W	D7	LOAD.L	A4,A1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire	POP.W	D790$:	PUSH.W	D7	CALL	_AFMENU		; remet les soft-keys	POP.W	D7	POPM.L	D1..D6,A1..A5	TEST.W	D7		; retour EQ/NE	RET00$:;	.BB	0,END	.W	0;----------\\; VISUALISE >;==========/; Visualise un fichier de type image, gencar ou ascii.; in	A3.L	^nom du fichier  visualiser;	A5.L	^description unit;	D4.W	rang (0..n); out	D7.W	erreur; mod	D7.WVISUALISE:	PUSHM.L	D1..D5,A1..A5	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve l'tat de l'cran	JUMP,NE ERFAT$	CALL	FOND		; trame tout le fond	LOAD.L	(A6)+OVIFPU,A5	LOAD.W	(A6)+OVIFRA,D4	CLR.B	(A6)+OVIFABO	SET.B	(A6)+OVIFNET	; OVIFNET <-- "banque"  travers le rseau	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BKILL	; touche (KILL) enfonce ?	JUMP',BS NET$		; oui => NET$	COMP.B	(A3),#'@	JUMP',EQ NET$	CLR.B	(A6)+OVIFNETNET$:	CALL	SKIPREP		; A3 <-- saute unit:rps:	CALL	GETTYPE		; D3 <-- type image/gencar/autre	LOAD.W	(A6)+OVIFTYP,D3	; OVIFTYP <-- type des fichiers visualiss	LOAD.L	A4,#(A6)+OVIFEXT	CLR.B	(A4)EXT2$:	LOAD.B	D3,(A3+)	JUMP',EQ EXT5$	COMP.B	D3,#'.	JUMP',EQ EXT3$	COMP.B	D3,#'!	JUMP,NE EXT2$EXT3$:	DEC.L	A3EXT4$:	LOAD.B	(A4+),(A3+)	; OVIFEXT <-- extension (avec "." ou "!")	JUMP,NE EXT4$EXT5$:	CLR.W	(A6)+OHEAD	; vide le fifo	CLR.W	(A6)+OTAIL	GESMEM	?ARGMEM		; D4/D5 <-- total/continu libre	LOAD.W	D7,#ERNEMEM	COMP.L	D4,#150000	; reste au moins 150 Kbytes ?	JUMP,LO EXIT$		; non => EXIT$	NTREL	?GETPRIO	; D4 <-- priorit de START	INC.B	D4		; fils moins prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS2	LOAD.L	A3,#R16"NFILS2	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP,NE EXIT$	LOAD.L	A3,#R16"TXMENI	COMP.W	(A6)+OVIFTYP,#TYPIMAGE	JUMP',EQ 04$	LOAD.L	A3,#R16"TXMENC	COMP.W	(A6)+OVIFTYP,#TYPCOLOR	JUMP',EQ 04$	LOAD.L	A3,#R16"TXMENP	COMP.W	(A6)+OVIFTYP,#TYPPLAN	JUMP',EQ 04$	LOAD.L	A3,#R16"TXMENG	COMP.W	(A6)+OVIFTYP,#TYPGENCAR	JUMP',EQ 04$	LOAD.L	A3,#R16"TXMENA04$:	TEST.B	(A6)+OVIFNET	; "banque"  travers le rseau ?	JUMP',F	05$		; non => 05$				; oui =>	LOAD.L	A3,#R16"TXMENI0	COMP.W	(A6)+OVIFTYP,#TYPIMAGE	JUMP',EQ 05$	LOAD.L	A3,#R16"TXMENC0	COMP.W	(A6)+OVIFTYP,#TYPCOLOR	JUMP',EQ 05$	LOAD.L	A3,#R16"TXMENP0	COMP.W	(A6)+OVIFTYP,#TYPPLAN	JUMP',EQ 05$	LOAD.L	A3,#R16"TXMENG0	COMP.W	(A6)+OVIFTYP,#TYPGENCAR	JUMP',EQ 05$	LOAD.L	A3,#R16"TXMENA005$:	LIB	?AFMENU		; affiche les soft-keys	CLR.L	D1		; D1 <-- flags	CLR.L	D6		; D6 <-- pas de canal	JUMP	NEXT2$		; commence par attendre un fichierREFAIT$:	LOAD.L	D3,#H'10000*(8-1)+(8-1)	LOAD.L	D4,(A0)+ODFDY	SUB.W	D4,#8+8-1	SWAP.W	D4	SUB.W	D4,#8+8-1	SWAP.W	D4	LOAD.L	D2,#VISU_DRAW!2^BLIVDRECT!2^BLIVDINFO!2^BLIVDASC	LIST_	VISU		; affiche le canevas	LOAD.L	D2,#VISU_PARAM	LIST_	VISU		; D2/D3/D4/A4 <-- paramtres	LOAD.L	D1,D4		; D1 <-- flags	LOAD.L	D2,#VISU_UPDATE	OR.L	D2,D4	LIST_	VISU		; affiche le contenuINFO$:	LOAD.L	D2,#VISU_USER	LIST_	VISU		; A4 <-- ^variables libres	JUMP,NE LOOP$	LOAD.L	A3,(A4)+0	; A3 <-- ^fichier (OFL..)	TEST.B	(A3)+OFLATT+0:#BATTSEL-24 ; icne slectionne ?	JUMP',BS INFO3$		; oui => INFO3$	LOAD.B	D3,#4	LIB	?CLRBARRE	INC.B	D3	LIB	?CLRBARRE	INC.B	D3	LIB	?CLRBARRE	JUMP'	INFO4$INFO3$:	LOAD.B	D3,#4	LIB	?SETBARRE	INC.B	D3	LIB	?SETBARRE	INC.B	D3	LIB	?SETBARREINFO4$:	LOAD.L	D2,#VISU_INFO	TEST.B	(A3)+OFLATT+0:#BATTSEL-24 ; icne slectionne ?	JUMP',BC INFO5$		; non => INFO5$	TSET.L	D2:#BLIVIINV	; oui => affiche nom en inverseINFO5$:	LIST_	VISU		; affiche les informationsF789$:	LOAD.W	D3,#7	TEST.L	D1:#BLIVUOPT1	JUMP',BS F7SET$F7CLR$:	LIB	?CLRBARRE	JUMP'	F8$F7SET$:	LIB	?SETBARREF8$:	INC.W	D3	TEST.L	D1:#BLIVUOPT2	JUMP',BS F8SET$F8CLR$:	LIB	?CLRBARRE	JUMP'	F9$F8SET$:	LIB	?SETBARREF9$:	INC.W	D3	TEST.L	D1:#BLIVUOPT3	JUMP',BS F9SET$F9CLR$:	LIB	?CLRBARRE	JUMP'	LOOP$F9SET$:	LIB	?SETBARRELOOP$:	CALL	_NORMMOUSE	; souris: enlve le sablier	LIB	?GETCAR		; attend une touche ...	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	; bouton souris relch ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC1$	COMP.W	D3,#KEYMMP	; bouton souris press ?	JUMP,EQ CLIC2$		; oui => CLICn$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC2$	COMP.W	D3,#F0+SHIFT	JUMP',LO SHIFT$	COMP.W	D3,#F15+SHIFT	JUMP',HI SHIFT$	SUB.W	D3,#SHIFTSHIFT$:	CALL	_MINMAJ	COMP.W	D3,#F1	JUMP,EQ NEXT$	COMP.W	D3,#F2	JUMP,EQ NEXT$	COMP.W	D3,#F3	JUMP,EQ NEXT$	COMP.W	D3,#SPACE	JUMP,EQ NEXT$	COMP.W	D3,#F4	JUMP,EQ SELECT$	COMP.W	D3,#F5	JUMP,EQ SELECT$	COMP.W	D3,#F6	JUMP,EQ SELECT$	COMP.W	D3,#F7	JUMP,EQ DOF7$	COMP.W	D3,#F8	JUMP,EQ DOF8$	COMP.W	D3,#F9	JUMP,EQ DOF9$	COMP.W	D3,#END	JUMP,EQ END$	COMP.W	D3,#F0		; fin ?	JUMP,EQ END$		; oui => END$BIP$:				; touche incorrecte =>	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; fait un p'tit bruit	JUMP	LOOP$CLIC1$:				; clic =>	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$;;?	SUB.W	D4,(A0)+ODFFX;;?	JUMP,LO BIP$;;?	SWAP.W	D4;;?	SUB.W	D4,(A0)+ODFFY;;?	JUMP,LO BIP$;;?	SWAP.W	D4	LOAD.L	D2,#VISU_MOVE	LIST_	VISU		; dplace selon souris ...	JUMP,EQ LOOP$CLIC2$:	LOAD.L	A3,#R16"TXVMENI	COMP.W	(A6)+OVIFTYP,#TYPIMAGE	JUMP',EQ CLIC4$	LOAD.L	A3,#R16"TXVMENC	COMP.W	(A6)+OVIFTYP,#TYPCOLOR	JUMP',EQ CLIC4$	LOAD.L	A3,#R16"TXVMENP	COMP.W	(A6)+OVIFTYP,#TYPPLAN	JUMP',EQ CLIC4$	LOAD.L	A3,#R16"TXVMENG	COMP.W	(A6)+OVIFTYP,#TYPGENCAR	JUMP',EQ CLIC4$	LOAD.L	A3,#R16"TXVMENACLIC4$:	CLR.L	D4	TEST.B	(A6)+OVIFNET	; "banque"  travers le rseau ?	JUMP',F CLIC5$		; non => CLIC5$	LOAD.B	D4,#B'110	; oui => suivant/slectionne en grisCLIC5$:	LOAD.W	D3,#2^15	LIB	?MMENU		; attend selon mmenu ...	JUMP,NE BIP$	COMP.W	D3,#1	JUMP,EQ NEXT$	COMP.W	D3,#2	JUMP,EQ SELECT$	LOAD.W	D4,#F7	COMP.W	D3,#3	JUMP',EQ CLICW$	LOAD.W	D4,#F8	COMP.W	D3,#4	JUMP,NE	LOOP$CLICW$:	LOAD.W	D3,D4	LIB	?WRKEY	JUMP	LOOP$NEXT$:				; fichier suivant =>	TEST.B	(A6)+OVIFNET	; "banque"  travers le rseau ?	JUMP,T	BIP$		; oui => BIP$NEXT2$:				; non =>	LOAD.L	D2,#VISU_CLOSE	LIST_	VISU		; libre le fichier prcdent	CLR.L	D6	CALL	GETFIFO		; D6 <-- canal	JUMP,EQ REFAIT$	CALL	_WAITMOUSE	; souris: met le sablier	CALL	VISUWAIT	; affiche "attendez ..."NEXT4$:	CALL	GETFIFO		; D6 <-- canal	JUMP,EQ REFAIT$	LOAD.W	D4,#50/4	NTREL	?DELMS		; attend 1/4 de seconde ...	LIB	?IFCAR		; une touche presse ?	JUMP,NE NEXT4$		; non => NEXT4$	COMP.W	D3,#END	JUMP,EQ END$	COMP.W	D3,#F0		; fin ?	JUMP,EQ END$		; oui => END$	COMP.W	D3,#F0+SHIFT	JUMP,EQ END$	JUMP	NEXT4$SELECT$:			; slectionne =>	TEST.B	(A6)+OVIFNET	; "banque"  travers le rseau ?	JUMP,T	BIP$		; oui => BIP$				; non =>	LOAD.L	D2,#VISU_USER	LIST_	VISU		; A4 <-- ^variables libres	JUMP,NE BIP$	LOAD.L	A3,(A4)+0	; A3 <-- ^fichier (OFL..)	TNOT.B	(A3)+OFLATT+0:#BATTSEL-24 ; slectionne l'icne	JUMP',BS DESEL$				; slectionne =>	INC.W	(A6)+OSELNB	LOAD.L	(A6)+OSELPU,(A6)+OVIFPU	JUMP	INFO$DESEL$:				; d-slectionne =>	DEC.W	(A6)+OSELNB	JUMP	INFO$DOF7$:	TNOT.L	D1:#BLIVUOPT1	JUMP'	UPDATE$DOF8$:	TNOT.L	D1:#BLIVUOPT2	JUMP'	UPDATE$DOF9$:	TNOT.L	D1:#BLIVUOPT3;	JUMP'	UPDATE$UPDATE$:	LOAD.L	D2,#VISU_UPDATE	OR.L	D2,D1	TSET.L	D2:#BLIVUNPOS	LIST_	VISU		; affiche le contenu	JUMP	F789$END$:	SET.B	(A6)+OVIFABO	; signal la fin du processus fils	LOAD.L	D2,#VISU_CLOSE	LIST_	VISU		; ferme le dernier fichier	CALL	_AFMENU		; remet les soft-keys	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface la swdo	LOAD.W	D4,#50	NTREL	?DELMS		; attend une seconde ...	CLR.W	D7		; D7 <-- okEXIT$:	PUSH.W	D7	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue l'tat de l'cran	POP.W	D7ERFAT$:	POPM.L	D1..D5,A1..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; EDOPEWDO >;---------/; Ouvre la sous-fentre d'dition.; in	-; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WEDOPEWDO:	PUSHM.L	D2..D4	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve l'tat de l'cran	JUMP,NE 90$	CALL	FOND		; trame tout le fond	LOAD.W	D3,(A0)+ODFDY	SR.W	D3,#1		; D3 <-- centre en Y	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#1		; D3 <-- centre en X	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,#8*2		; D4 <-- hauteur	SWAP.W	D4	LOAD.W	D4,(A0)+ODFDX	SUB.W	D4,#8*2		; D4 <-- largeur	LOAD.W	D2,#2^BDBPOS	; D2 <-- centre selon D3.L	DBOX_	CADRE		; D5 <-- canal du cadre	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EDCLOWDO >;---------/; Ferme la sous-fentre d'dition.; in	D5.L	canal; out	-; mod	-EDCLOWDO:	PUSHM.L	D3,D7	DBOX_	CLOSE		; ferme le cadre	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue l'tat de l'cran	POPM.L	D3,D7	RET;--------\\; RDEDIT  >;--------/; Ouvre le fichier et rserve de la mmoire pour le lire.; in	A3.L	^nom du fichier; out	A1.L	^buffer;	D1.L	longueur;	D7.W	erreur; mod	D1.L, D7.W, A1.LRDEDIT:	PUSHM.L	D2..D4,A4	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouve le fichier	JUMP,NE 90$	LOAD.L	D4,#-1	LOAD.B	D3,#-1	FOS	?SPOS		; va tout  la fin	LOAD.L	D2,D4		; D2 <-- longueur du fichier	CLR.L	D4	CLR.B	D3	FOS	?SPOS		; revient au dbut	JUMP,NE 85$	LOAD.L	D4,D2		; D4 <-- longueur du fichier	ADD.L	D4,#1000	; D4 <-- rserve pour diter	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer o lire le fichier	JUMP,NE 85$	LOAD.L	D1,D4	LOAD.L	A1,A4	LOAD.L	D4,D2	FOS	?RDBYTE		; lit tout le fichier  diter	JUMP,NE 80$	CLR.B	(A4)+(D4.L)	; met un <0> terminateur  la fin; Vrifie si le fichier lu semble contenir un texte ASCII.	LOAD.W	D7,#ERSEDIT	; D7 <-- fichier pas ditable40$:	TEST.B	(A4+)		; caractre ditable ?	JUMP',NS 80$		; non => 80$	DEC.L	D4	JUMP,NE 40$	CLR.W	D7		; D7 <-- ok	JUMP'	85$80$:	PUSH.W	D7	LOAD.L	A4,A1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire	POP.W	D785$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D790$:	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WREDIT  >;--------/; Met  jour le fichier dit sur disque.; in	A3.L	^nom du fichier;	A1.L	^buffer; out	D7.W	erreur; mod	D7.WWREDIT:	PUSHM.L	D3,D4,A4	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.L	A4,A1	CLR.L	D410$:	INC.L	D4	TEST.B	(A4+)	JUMP,NE 10$	DEC.L	D4		; D4 <-- nouvelle longueur	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP',NE 90$	LOAD.L	A4,A1	FOS	?WRBYTE		; crit le fichier	JUMP',NE 85$	FOS	?TRUNC		; tronque si nouveau plus court	JUMP',NE 85$	LIB	?RDCLOCK	; D3/D4 <-- heure/date	JUMP',NE 70$	FOS	?CLOMDC		; ferme, et change la date de cration !	JUMP'	90$70$:	FOS	?CLOSE		; ferme le fichier	JUMP'	90$85$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; VISUWAIT >;=========/; Affiche "Attendez ..." au milieu de la dbox.; in	-; out	-; mod	D7.WVISUWAIT:	PUSHM.L	D2..D4	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF		; dfinit trame pour effacer	LOAD.L	D3,#H'10000*(8-1)+(8-1)	LOAD.L	D4,(A0)+ODFDY	SUB.W	D4,#8+8-1	SWAP.W	D4	SUB.W	D4,#8+8-1	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface tout	LOAD.W	D3,(A0)+ODFDY	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#1	LOAD.W	D4,#LGVIFW	MUL.WU	D4,(A0)+ODFCX	SR.W	D4,#1	SUB.W	D3,D4	LIB	?SETCURS	LOAD.L	A3,#R16"TXVIFW	LOAD.W	D3,#LGVIFW	LIB	?STRING		; affiche le texte	POPM.L	D2..D4	RETTXVIFW:	.ASCII	" Attendez un instant ..."LGVIFW	=  .-TXVIFW	.EVEN; Processus fils de START; -----------------------NFILS2:	.ASCIZ	"READ_FILE"	.EVENPFILS2:	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	PUSH.L	(A6)+OFACLE	TSET.B	(A6)+OFACLE+3:#1 ; met une clef permanente	CLR.L	D0		; D0 <-- c'est le premier fichier10$:	TEST.B	(A6)+OVIFABO	; fin du processus fils ?	JUMP,T	90$		; oui => 90$; Lit un fichier sur disque, pour le mettre dans le fifo.	LOAD.L	A5,(A6)+OVIFPU	; A5 <-- ^description unit	LOAD.W	D4,(A6)+OVIFRA	; D4 <-- rang	CALL	GETPFILE	; A3 <-- ^nom	LOAD.L	D3,(A3)+OFLATT	; D3 <-- attributs	TEST.L	D0		; est-ce le premier fichier ?	JUMP',NE 12$		; non => 12$				; oui =>	LOAD.L	D0,D3		; D0 <-- attributs du premier fichier	JUMP'	14$12$:	XOR.L	D3,D0		; D3 <-- attributs changs	TEST.L	D3:#BATTQ	; attribut verrouill chang ?	JUMP,BS 70$		; oui => 70$14$:	LOAD.L	A4,A3		; A4 <-- ^fichier (OFL..)	CALL	PREPFIC		; A3 <-- ^nom du fichier (v. avec clef)	PUSH.L	A3	CALL	SKIPREP		; A3 <-- saute unit:rps:16$:	LOAD.B	D3,(A3+)	NOTZ	JUMP',NE 18$	COMP.B	D3,#'.	JUMP',EQ 17$	COMP.B	D3,#'!	JUMP,NE 16$17$:	DEC.L	A3	LOAD.L	A2,#(A6)+OVIFEXT	CALL	COMPEXT		; mme extension ?18$:	POPM.L	A3	JUMP,NE 70$		; non => 70$20$:	GESMEM	?ARGMEM		; D4/D5 <-- total/continu libre	COMP.L	D4,#100000	; reste au moins 100 Kbytes ?	JUMP',LO 22$		; non => 22$				; oui =>	LOAD.L	D2,#VISU_OPEN	LIST_	VISU		; D6 <-- ouvre le fichier	JUMP',NE 21$	LOAD.L	A3,A4	LOAD.L	D2,#VISU_USER	LIST_	VISU		; A4 <-- ^variables libres	JUMP',NE 21$	LOAD.L	(A4)+0,A3	; mm. ^fichier (OFL...)	JUMP'	30$21$:	COMP.W	D7,#ERNEMEM	JUMP,NE 70$22$:				; pas assez de mmoire =>	LOAD.W	D3,#4		; D3 <-- 4 secondes avant de r-essayer23$:	TEST.B	(A6)+OVIFABO	; fin du processus fils ?	JUMP,T	90$		; oui => 90$	LOAD.W	D4,#50	NTREL	?DELMS		; attend une seconde ...	DEC.W	D3	JUMP,NE 23$	JUMP	20$; Met le fichier lu dans le fifo. Si le fifo est plein, attend; une seconde, puis essaye de nouveau.30$:	CALL	PUTFIFO		; fifo <-- D6.L (canal)	JUMP',EQ 50$		; ok => 50$				; fifo plein =>	TEST.B	(A6)+OVIFABO	; fin du processus fils ?	JUMP',T	35$		; oui => 35$	LOAD.W	D4,#50	NTREL	?DELMS		; attend une seconde ...	JUMP	30$35$:	LOAD.L	D2,#VISU_CLOSE	LIST_	VISU		; libre le fichier	JUMP	90$50$:	TEST.B	(A6)+OVIFNET	; "banque"  travers le rseau ?	JUMP',F 70$		; non => 70$55$:				; oui =>	TEST.B	(A6)+OVIFABO	; fin du processus fils ?	JUMP,T	90$		; oui => 90$	LOAD.W	D4,#50	NTREL	?DELMS		; attend une seconde ...	JUMP	55$; Cherche le nom du fichier suivant  lire.70$:	LOAD.L	A5,(A6)+OVIFPU	; A5 <-- ^description unit	LOAD.W	D4,(A6)+OVIFRA	; D4 <-- rang	INC.W	D4		; D4 <-- rang suivant	COMP.W	D4,(A5)+OUNNBL	; dernier fichier ?	JUMP',LO 72$		; non => 72$	CLR.W	D4		; oui => repart au premier72$:	LOAD.W	(A6)+OVIFRA,D4	JUMP	10$; Fin du processus fils. Vide toutes les fichiers contenus dans; le fifo, pour les librer.90$:	CALL	GETFIFO		; D6 <-- canal	JUMP',NE 95$	LOAD.L	D2,#VISU_CLOSE	LIST_	VISU		; libre le fichier	JUMP	90$95$:	POP.L	(A6)+OFACLE	; remet le mode de clef initial	NTREL	?ABORT;--------\\; PUTFIFO >;========/; Met un fichier dans le fifo.; in	D6.L	canal; out	D7.W	erreur; mod	D7.WPUTFIFO:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OFIFO	LOAD.W	D4,(A6)+OHEAD	ADD.W	A4,D4	LOAD.L	(A4+),D6	ADD.W	D4,#LGFIFO	COMP.W	D4,#LGFIFO*NBFIFO	JUMP',LO 30$	CLR.W	D430$:	LOAD.W	D7,#1		; D7 <-- fifo plein	COMP.W	D4,(A6)+OTAIL	JUMP',EQ 90$	LOAD.W	(A6)+OHEAD,D4	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETFIFO >;========/; Prend un fichier dans le fifo.; in	-; out	D6.L	canal;	D7.W	erreur; mod	D6.L, D7.WGETFIFO:	PUSHM.L	D4,A4	LOAD.W	D7,#1		; D7 <-- fifo vide	LOAD.W	D4,(A6)+OTAIL	COMP.W	D4,(A6)+OHEAD	JUMP',EQ 90$	LOAD.L	A4,#(A6)+OFIFO	ADD.W	A4,D4	LOAD.L	D6,(A4+)	ADD.W	D4,#LGFIFO	COMP.W	D4,#LGFIFO*NBFIFO	JUMP',LO 30$	CLR.W	D430$:	LOAD.W	(A6)+OTAIL,D4	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RETTXMENE:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"#mm0: #mm1: #mm2:"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"#printer         "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	".text .bas  .asm "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	".code .image.plan"		;     ;     ;     ;TXMENI:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"       <'>><'>><'>>       "	.ASCIZ	"     Suivant     "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"   Slectionne   "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Tout Ngatif     "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TXMENI0:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"     <AFGREY>Suivant<AFFULL>     "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"   <AFGREY>Slectionne<AFFULL>   "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Tout Ngatif     "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TXMENP:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"       <'>><'>><'>>       "	.ASCIZ	"     Suivant     "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"   Slectionne   "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Tout       Carac."		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TXMENP0:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"     <AFGREY>Suivant<AFFULL>     "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"   <AFGREY>Slectionne<AFFULL>   "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Tout       Carac."		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TXMENC:TXMENG:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"       <'>><'>><'>>       "	.ASCIZ	"     Suivant     "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"   Slectionne   "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TXMENC0:TXMENG0:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"     <AFGREY>Suivant<AFFULL>     "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"   <AFGREY>Slectionne<AFFULL>   "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TXMENA:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"       <'>><'>><'>>       "	.ASCIZ	"     Suivant     "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"   Slectionne   "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Petit            "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TXMENA0:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"     <AFGREY>Suivant<AFFULL>     "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"   <AFGREY>Slectionne<AFFULL>   "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Petit            "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TEDIT1:	.ASCIZ	"#mm0:"TEDIT2:	.ASCIZ	"#mm1:"TEDIT3:	.ASCIZ	"#mm2:"TEDIT4:	.ASCIZ	"#printer"TEDIT10:.ASCIZ	".text"TEDIT11:.ASCIZ	".bas"TEDIT12:.ASCIZ	".asm"TEDIT13:.ASCIZ	".code"TEDIT14:.ASCIZ	".image"TEDIT15:.ASCIZ	".plan"TXVMENI:	.ASCIZ	" "	.B	-1	.B	SPACE,USEGC,GCIIF,GCIIS,GCIIT	.B	ICONEXT,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"suivant "	.B	SPACE,USEGC,GCIIF,GCIIS,GCIIT	.B	ICOSELECT,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"slectionne "	.B	-1	.B	SPACE,USEGC,GCIIF,GCIIS,GCIIT	.B	ICOALL,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"tout "	.B	SPACE,USEGC,GCIIF,GCIIS,GCIIT	.B	ICONEGATIF,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"ngatif "	.B	0TXVMENP:	.ASCIZ	" "	.B	-1	.B	SPACE,USEGC,GCIIF,GCIIS,GCIIT	.B	ICONEXT,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"suivant "	.B	SPACE,USEGC,GCIIF,GCIIS,GCIIT	.B	ICOSELECT,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"slectionne "	.B	-1	.B	SPACE,USEGC,GCIIF,GCIIS,GCIIT	.B	ICOALL,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"tout "	.B	0TXVMENC:TXVMENG:TXVMENA:	.ASCIZ	" "	.B	-1	.B	SPACE,USEGC,GCIIF,GCIIS,GCIIT	.B	ICONEXT,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"suivant "	.B	SPACE,USEGC,GCIIF,GCIIS,GCIIT	.B	ICOSELECT,ICOSPACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"slectionne "	.B	0	.EVEN	.END