	.TITLE	SFLO.ASC	.PROC	M680002	.REF	SMAKY	.LOC	0OBUHEAD:.BLKB	LGMAM3LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.L	A3,#R16"NAME	CALL	MINSTATUS	JUMP,NE FINI	LIB	?AFTIM	.ASCIZE	"nombre de blocs (partition) = "	LOAD.L	D4,(A4)+OMNBLK	; .BLK.32	LIB	?AFX8	LIB	?AFCR	LIB	?AFTIM	.ASCIZE	"bloc le plus rapide = "	LOAD.L	D4,(A4)+OMRBLK	; .BLK.32	LIB	?AFX8	LIB	?AFCR	LIB	?AFTIM	.ASCIZE	"nombre de blocs rservs boot = "	LOAD.W	D4,(A4)+OMNBBO	; .BLK.16	LIB	?AFX4	LIB	?AFCR	LIB	?AFTIM	.ASCIZE	"taille d'un bloc disque = "	LOAD.W	D4,(A4)+OMLGBLK	; .BLK.16	LIB	?AFX4	LIB	?AFCR	LIB	?AFTIM	.ASCIZE	"nombre total de blocs = "	LOAD.L	D4,(A4)+OMTBLK	; .BLK.32	LIB	?AFX8	LIB	?AFCRFINI:	EXITNAME:	.ASCIZ	"#MM1:"	.EVEN;----------\\; MINSTATUS >;==========/; Lit le status minimum d'un disque (pas d'accs).; in	A3.L	^nom du disque; out	A4.L	^status minimal;	D7.W	erreur; mod	D7.W, A4.LMINSTATUS:	PUSHM.L	D0,D3,D4,D6	LOAD.L	D3,#2^BOPEXTEND!2^BOPMMUNIT!2^BOPRSTATUS	FOS	?ARGSOPEN	 ; ouvre le disque	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OBUHEAD ; A4 <-- ^buffer	LOAD.L	D4,#LGMAM3	LOAD.W	D3,#TYPMM	FOS	?RSTATUS	; lit le status sans les records FMTCLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le disque	POP.W	D7EXIT$:	POPM.L	D0,D3,D4,D6	TEST.W	D7		; retour EQ/NE	RETVAR:	.FILLB	LGVAR,0	.END	START