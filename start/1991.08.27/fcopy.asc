 	.TITLE	FCOPY;	--------------------------------------;		(C) 1985 - Daniel Roux;	--------------------------------------;	Source du programme START.CODE;	Date		Amliorations; --------------------------------------------------------------------------------------------------; 4.1	05.07.89	clear OBK0CHANGE  la lecture (dans .DI); 4.0	30.06.89	version compltement r-crite !;			appels BIOS --> appels FOS; 3.7			version longuement utilise; 1.0			premire version	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;BOPMMUNIT = 20OBK0CHANGE = H'EC;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;FCOPYREV=	4FCOPYVERS=	1	.REV	FCOPYREV,FCOPYVERS	.CODE	800,23,B'1111,600,2000,300,2000,2,'N,'R,'F,09; Constantes; ----------LBUNAM	=	50		; lg max d'un nom de fichier; Palette; -------IPPOSX	=	4		; position premire icne sup/gaucheIPPOSY	=	8IPDIMX	=	174		; dimensions d'une icneIPDIMY	=	32IPWDOX	=	12		; position image dans dboxIPWDOY	=	40; En-tte d'un fichier .IMAGE; ---------------------------	.LOC	0OIMTYP:	.BLKB	1		; H'01 = indique type imageOIMCOD:	.BLKB	1		; H'00 = indique pas de codageOIMBIP:	.BLKB	1		; H'01 = 1 bit par pointOIMDIR:	.BLKB	1		; H'02 = coord. X-Y comme cranOIMDLX:	.BLKB	2		; largeur image en pointsOIMDLY:	.BLKB	2		; hauteur image en pointsOIMNBB:	.BLKB	4		; nb de byte pour l'image	.BLKB	20		; rserveLGHIMA:; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHSCROLL:.BLKB	2		; canal module SCROLLOCHLIST:.BLKB	2		; canal module LISTOPLCOM:	.BLKB	4		; ^ligne de commandeOBUDIS:	.BLKB	100		; buffer pour write-displayOIPPT:	.BLKB	4		; image palette: ^dataOIPDIM:	.BLKB	4		; image palette: dimensions (dy;dx)OCHOIX:	.BLKB	2		; choix du type de copie (0..4)OGREY:	.BLKB	1		; options impossibles	.EVENOCPFFF:	.BLKB	4		; copie: fanions floppy-floppyOCPCDB:	.BLKB	4		; copie: canal dbox waitOCPNAM:	.BLKB	LBUNAM		; copie: nom du fichier .DIOCPCHR:	.BLKB	2		; copie: canal driver source (read)OCPCHW:	.BLKB	2		; copie: canal driver destination (write)OCPERR:	.BLKB	2		; copie: ok/erreur lors d'ouvertureOCPASC:	.BLKB	LSCVAR		; copie: ascenseurLGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.W	D1,#MTYPCP	LOAD.L	D4,#LGVAR	GESMEM	?GETMEM		; demande mm pour variables	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	LIB	?GETPDIS	JUMP,NE ERFAT2	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMIMAP	CALL	LOADIMAGE	; charge l'image "XCAR_P.IMAGE"	JUMP,NE ERFAT2	LOAD.L	(A6)+OIPPT,A4	LOAD.L	(A6)+OIPDIM,D4	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame toute la fentre	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle tout autour	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LOAD.W	D4,(A0)+ODFDX	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; inverse la bande suprieure	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	AFINV	.ASCII	" FCOPY "	.B	FCOPYREV+'0	.B	'.	.IF	FCOPYVERS<10	.B	FCOPYVERS+'0	.ASCII	"     "	.ELSE	.B	(FCOPYVERS/10)+'0,(FCOPYVERS-((FCOPYVERS/10)*10))+'0	.ASCII	"    "	.ENDIF	.B	AFDIR	.B	0	.EVEN	CALL	AFMENU		; dessine les soft-keys	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SKPNAM	JUMP,NE LOOP	LOAD.L	A4,#(A6)+OCPNAM50$:	LOAD.B	D3,(A3+)	JUMP,EQ 52$	COMP.B	D3,#CR	JUMP,EQ 52$	LOAD.B	(A4+),D3	; OCPNAM <-- nom de la ligne de commande	JUMP	50$52$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OCPNAM	LOAD.L	A4,#R16"TXDI	LOAD.W	D3,#1	LIB	?ADDEXT		; force l'extension .DI	LOAD.W	(A6)+OCHOIX,#4	; floppy <-- winch	JUMP	DOQQLOOP:	CALL	DBOXCHOIX	; attend choix ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE FINIDOQQ:	LOAD.L	A1,#R16"UFLO0	LOAD.L	A2,#R16"UFLO0	COMP.W	(A6)+OCHOIX,#0	JUMP,EQ COPY$	LOAD.L	A1,#R16"UFLO0	LOAD.L	A2,#R16"UFLO1	COMP.W	(A6)+OCHOIX,#1	JUMP,EQ COPY$	LOAD.L	A1,#R16"UFLO1	LOAD.L	A2,#R16"UFLO0	COMP.W	(A6)+OCHOIX,#2	JUMP,EQ COPY$	LOAD.L	A1,#R16"UFLO0	LOAD.L	A2,#R16"UWIN	COMP.W	(A6)+OCHOIX,#3	JUMP,EQ COPY$	LOAD.L	A1,#R16"UWIN	LOAD.L	A2,#R16"UFLO0	COMP.W	(A6)+OCHOIX,#4	JUMP,NE LOOPCOPY$:	CALL	COPYEX		; effectue une copie ...	JUMP,NE ERROR	JUMP	LOOPERROR:	PUSH.W	D7	CALL	NORMMOUSE	; remet la flche	POP.W	D7	TEST.W	D7	JUMP,EQ LOOP	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	AFMENU		; refait les soft-keys	JUMP	LOOPFINI:	CALL	DBOXQUITTE	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOPERFAT2:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSEERFAT1:	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface toute la fentre	LIB	?CLOLIB	FOS	?STOP	.INS	FCOPYDBOX.ASI	.INS	FCOPYIMAGE.ASI	.INS	FCOPYIO.ASI	.INS	FCOPYMISC.ASI; Noms des units; ---------------UFLO0:	.ASCIZ	"$FLO_0:"UFLO1:	.ASCIZ	"$FLO_1:"UWIN:	.ASCIZ	""; Noms des modules; ----------------NMDBOX:	.ASCIZ	"DBOX"NMSCROLL:.ASCIZ	"SCROLL"NMLIST:	.ASCIZ	"LIST"NMIMAP:	.ASCIZ	"FCOPY_C.IMAGE"	.EVEN	.END	START