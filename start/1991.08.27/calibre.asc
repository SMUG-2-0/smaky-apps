	.PROC	M680002	.REF	SMAKYKEYDBOX	=	H'7E00		; "touche" pour dboxKEYENTER=	H'7D00		; "touche" pour disquette miseKEYRELEASE=	H'7C00		; "touche" pour disquette enleveKEYSLEEP=	H'7B00		; "touche" pour s'endormir	.LOC	0OABORT:	.BLKB	1		; 1 => abort des processus fils	.EVENOSLK1:	.BLKB	2OSLK2:	.BLKB	2OCHDIS:	.BLKB	2OPDIS0:	.BLKB	4OBUDIS:	.BLKB	20LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	CLR.B	(A6)+OABORT	LIB	?VASSKEY	LOAD.W	(A6)+OSLK1,D3	LIB	?AFTIM	.B	CR,CR,CR	.ASCIZ	"Programme de test pour SLEEP ..."	.EVEN	NTREL	?GETPRIO	; D4 <-- priorit de START	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP,NE ERFATLOOP:	LIB	?GETCAR	COMP.W	D3,#END	JUMP,EQ FINI	COMP.W	D3,#KEYSLEEP	JUMP,NE LOOP;;?	CALL	SLEEP	JUMP	LOOPFINI:	SET.B	(A6)+OABORT	; signal la fin au processus fils;;?	NTREL	?WFABDESC	; attend leurs fins ...	LOAD.W	D4,#50*2	NTREL	?DELMSERFAT:	EXIT; Processus fils de START; -----------------------NFILS1:	.ASCIZ /WAIT_CHANGE/	.EVENPFILS1:	LOAD.W	D4,#50	NTREL	?DELMS	LOAD.L	D6,#-110$:	CLR.W	D112$:	TEST.B	(A6)+OABORT	; fin ?	JUMP,T	90$		; oui => 90$				; non =>	NTREL	?GETSYTIME	LOAD.L	D0,D2		; D0 <-- temps processeur inutilis	LOAD.W	D4,#50	NTREL	?SETTIM		; met timeout d'une seconde	LOAD.L	D4,#2^BWTRELEASE!2^BWTENTER ; D4 <-- attend RELEASE/ENTER	FOS	?WCHANGE	; attend release ou enter ...	JUMP,EQ 20$	NTREL	?GETSYTIME	SUB.L	D2,D0		; D2 <-- dure d'excution de IDLELOAD.L D4,D2CLR.L H'900.W H'A032COMP.L D6,D4JUMP',LS 15$LOAD.L D6,D415$:.W H'A024LOAD.L D4,D6.W H'A032	COMP.L	D2,#H'1400	; IDLE beaucoup excut ?	JUMP,LO	10$		; non => 10$				; oui =>	INC.W	D1		; D1 <-- une seconde d'inactivit de plus	COMP.W	D1,#10	JUMP,LO 12$	LOAD.L	D3,#KEYSLEEP	LIB	?WRKEY		; envoie l'vnement au pre !	JUMP	10$20$:	TEST.W	D4		; erreur ?	JUMP,NE 10$		; oui => 10$	TEST.L	D4:#BWTENTER	JUMP',BS 50$				; RELEASE =>	SWAP.W	D4		; D4 <-- no du driver	AND.L	D4,#H'FF	OR.W	D4,#KEYRELEASE	LOAD.L	D3,D4	LIB	?WRKEY		; envoie l'vnement au pre !	JUMP	10$50$:				; ENTER =>	SWAP.W	D4		; D4 <-- no du driver	AND.L	D4,#H'FF	OR.W	D4,#KEYENTER	LOAD.L	D3,D4	LIB	?WRKEY		; envoie l'vnement au pre !	JUMP	10$90$:	NTREL	?ABORTSLEEP:	PUSHM.L	D3,D4,D6,A0,A4	LIB	?VASSKEY	LOAD.W	(A6)+OSLK2,D3	LOAD.W	D3,(A6)+OSLK1	LIB	?ASSKEY	LIB	?GCHDIS	LOAD.W	(A6)+OCHDIS,D6	LOAD.L	A3,#R16"NDIS0	LOAD.W	D3,#2^BOPWR!2^BOPRD	FOS	?OPEN		; ouvre le bitmap complet $DIS_0	JUMP,NE EXIT$	LOAD.W	D3,#TYPDIS	; D3 <-- type bitmap complet	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDIS0	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERROR$	LOAD.L	A0,(A6)+OPDIS0	; A0 <-- ^descripteur de $DIS_0	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la flche de la souris	LIB	?PCHDIS		; utilise maintenant $DIS_0	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve tout le bitmap	LOAD.L	A4,#R16"CLKIN	CALL	CLKCOMM		; stoppe l'horloge	LOAD.L	A4,#R16"KEYIN	CALL	KEYCOMM		; bloque le clavier	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface tout le bitmap	LIB	?GETCAR	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue tout le bitmap	LOAD.L	A4,#R16"CLKOUT	CALL	CLKCOMM		; affiche de nouveau l'horloge	LOAD.L	A4,#R16"KEYOUT	CALL	KEYCOMM		; dbloque le clavier	FOS	?CLOSE		; ferme le bitmap complet $DIS_0	LOAD.W	D6,(A6)+OCHDIS	LIB	?PCHDIS		; r-utilise la fentre normale	LOAD.B	D3,#AFSCMO	LIB	?AFCAR		; remet la flche de la souris	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	FOS	?CLOSEEXIT$:	PUSH.W	D7	LOAD.W	D3,(A6)+OSLK2	LIB	?ASSKEY	POP.W	D7	POPM.L	D3,D4,D6,A0,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLKCOMM >;========/; Envoie une commande  l'horloge.; in	A4.L	^commande; out	-; mod	D7.WCLKCOMM:	PUSHM.L	D3,D6,A3	LOAD.L	A3,#R16"NCLK	LOAD.W	D3,#2^BOPRD!2^BOPWR	FOS	?OPEN		; ouvre l'horloge	JUMP',NE 90$	LOAD.W	D3,#TYPIO	FOS	?COMMAND	; envoie la commande	FOS	?CLOSE		; ferme l'horloge90$:	POPM.L	D3,D6,A3	RET;--------\\; KEYCOMM >;========/; Envoie une commande au clavier.; in	A4.L	^commande; out	-; mod	D7.WKEYCOMM:	PUSHM.L	D3,D6,A3	LIB	?GCHKEY	LOAD.W	D3,#TYPKEY	FOS	?COMMAND	; envoie la commande	POPM.L	D3,D6,A3	RETNDIS0:	.ASCIZ	"$DIS_0"NCLK:	.ASCIZ	"#CLOCK"CLKIN:	.ASCIZ	"M"		; clock: n'affiche plus rienCLKOUT:	.ASCIZ	"R"		; clock: affiche de nouveau normalementKEYIN:	.ASCIZ	"<KEYACT> "KEYOUT:	.ASCIZ	"<KEYACT>"	.EVENVAR:	.FILLB	LGVAR,0	.END	START