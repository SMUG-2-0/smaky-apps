	.SBTTL	DISKNAME.ASI;-----------\\; _DISK_NAME >;===========/; Demande le nom d'un disque.; in	A3.L	^nom du disque; out	D3.W	dernire touche (F0/F1);	D7.W	erreur; mod	D3.L, D7.W_DISK_NAME:	PUSHM.L	D0..D2,D4,D5,A1..A6	CALL	OPEVAR		; A6 <-- ^variables globales	JUMP,NE QUIT$	LOAD.L	A3,#(A6)+OBUNAM	; A3 <-- ^nom du disque	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D0,#FOS?INFODISK	CALL	ERCALL		; OBUHEAD <-- informations du disque	JUMP,NE EXIT$	LOAD.L	A2,#R16"TDBOX_NAME	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUHEAD+OBK0SYS	LIB	?AFTEXT		; affiche le dossier systme	POP.L	D4	CLR.W	D2		; D2 <-- rang initialNLINE$:	LOAD.L	A3,#(A6)+OBUHEAD+OBK0NLO	TEST.W	D2	JUMP',EQ NLINE2$	LOAD.L	A3,#(A6)+OBUHEAD+OBK0SYSNLINE2$:	LOAD.L	A4,A3NLINE4$:	TEST.B	(A4+)	JUMP,NE NLINE4$	DEC.L	A4		; A4 <-- ^fin du nom	CALL	NORMMOUSE	; souris: enlve le sablierLOOP$:	LOAD.W	D3,D2	DBOX_	MEDIT	DBOX_	EDIT		; attend action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_NAME	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP,EQ NAME$	COMP.W	D3,#F0	JUMP,EQ CLOSE$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#KEYDBOX+0	JUMP',EQ KEYDBOX$	COMP.W	D3,#KEYDBOX+1	JUMP',EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	LOOP$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D2,D3	AND.W	D2,#H'FF	; D2 <-- nouveau rang	JUMP	NLINE$RETURN$:			; RETURN =>	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$NAME$:				; D'ACCORD =>;;?	TEST.B	(A6)+OBUHEAD+OBK0NLO ; nom de la disquette existe ?;;?	JUMP,EQ BIP$		; non => BIP$				; oui =>	CALL	WAITMOUSE	; souris: met le sablier	DBOX_	CLOSE		; ferme la DBOX	LOAD.L	A3,#(A6)+OBUHEAD+OBK0SYS	TEST.B	(A3)	JUMP',EQ 64$63$:	TEST.B	(A3+)	JUMP,NE 63$	COMP.B	(A3)-2,#':	; nom du dossier termin par ":" ?	JUMP',EQ 64$		; oui => 64$	LOAD.B	(A3)-1,#':	CLR.B	(A3)64$:	LOAD.L	A3,#(A6)+OBUNAM	; A3 <-- ^nom du disque	LOAD.L	A5,#(A6)+OBUHEAD+OBK0SYS	LOAD.L	A2,#(A6)+OBUHEAD+OBK0NLO	LOAD.L	D3,#2^BFRSYS!2^BFRNAME	LOAD.L	D0,#FOS?NFORMAT	CALL	ERCALL2		; met  jour le disque	JUMP'	EXIT$CLOSE$:				; ANNULE =>	DBOX_	CLOSE		; ferme la DBOXEXIT$:	CALL	CLOVAR		; rend les variables globalesQUIT$:	POPM.L	D0..D2,D4,D5,A1..A6	TEST.W	D7		; retour EQ/NE	RETTDBOX_NAME:	.W	10$-TDBOX_NAME	.W	20$-TDBOX_NAME	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"Nom du disque:   "	.B	ODBLINE,(14+2)!2^7,KEYDBOX/H'100,0,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Dossier systme: "	.B	ODBLABEL,1	.B	ODBLINE,(14+2)!2^7,KEYDBOX/H'100,1,TDBNORM	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" RENOMME "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Renomme"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_NAME:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_NAME	.W	F1,F2,F3,0		DOKF1-TKEY_NAME	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_NAME	.W	0	.END