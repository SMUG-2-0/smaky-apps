	.TITLE	DEF_CLOCK.ASC;	--------------------------------------;		(C) 1991 - Daniel Roux;	--------------------------------------;	Source du programme DEF_CLOCK.CODE	.PROC	M680002	.RADIX	10.	.HEXDEFREV	=	1		; rvisionDEFVERS	=	1		; version;	Date		Amliorations; --------------------------------------------------------------------------------------------------; 1.1	23.05.91	priorit plus leve (23 -> 11); 1.0	16.05.91	premire version	.REF	SMAKY	.REF	MODULES;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;SMAKY300 = 7OINVOL = OINSTA+4		; volume du h-p dans 100_INFO;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.REV	DEFREV,DEFVERS;;?	.HEADER	OBXSOVER.L OVERLAY	; faire "HEADER DEF_CLOCK.CODE 16/O" !!!	.CODE	800,11,B'100111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LBUDIS	=	20KEYDBOX	=	H'7E00		; "touche" pour dbox; Variables; ---------	.LOC	0OPLCOM:	.BLKB	4		; ^ligne de commandeOBUDIS:	.BLKB	LBUDIS		; buffer temporaireOMOUSE:	.BLKB	1		; mode souris initialOMACHINE:.BLKB	1		; type de la machine (SMAKY*)	.EVENOCHMENU:.BLKB	4		; canal des soft-keysOBUDAT:	.BLKB	16		; date en clairOBUTIM:	.BLKB	16		; heure en clairLGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	CALL	OVERLAY	LIB	?CLOLIB	FOS	?STOPOVERLAY:	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE EXIT$	GESMEM	?CLEARMEM	; met TOUTES les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; OPLCOM <-- ^ligne de commande	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	NTREL	?GETMACHINE	RL.L	D4,#8	LOAD.B	(A6)+OMACHINE,D4	LOAD.L	A3,(A6)+OPLCOM	LOAD.B	D3,#'I	LIB	?IFSWITCH	; excut avec /i ?	JUMP',EQ INIT$		; oui => INIT$	CALL	DBOXMAIN	; appel dbox principale ...	JUMP',EQ END$	JUMP'	NOOVER$INIT$:;	...	JUMP'	END$NOOVER$:	LOAD.W	D7,#-1		; D7 <-- demande une excution normaleEND$:	PUSH.W	D7	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre les variables	POP.W	D7EXIT$:	RET;---------\\; DBOXMAIN >;=========/; Modifie quelques informations gnrales sur la machine.; in	-; out	D7.W	erreur; mod	D7.WDBOXMAIN:	PUSHM.L	D0..D6,A1..A5	LIB	?PUSHMENU	; sauve les soft-keys	LOAD.L	(A6)+OCHMENU,D5	LIB	?GMOUSE	LOAD.B	(A6)+OMOUSE,D3	LOAD.W	D3,#2	LIB	?MOUSE		; souris par le clavier	CALL	NORMMOUSE	; souris: enlve le sablier	LOAD.L	A2,#R16"TDBOX_MAIN	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	CALL	RDCLOCK		; lit la date et l'heure	JUMP,NE EXIT$	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUTIM	LIB	?AFTEXT		; affiche l'heure	CLR.L	D4		; D4 <-- fanions	CLR.W	D2		; D2 <-- on commence par la dateNLINE$:	LOAD.L	A3,#(A6)+OBUDAT	; A3 <-- ^heure	TEST.W	D2	JUMP',EQ 21$	LOAD.L	A3,#(A6)+OBUTIM	; A3 <-- ^date21$:	LOAD.L	A4,A322$:	TEST.B	(A4+)	JUMP,NE 22$	DEC.L	A4		; A4 <-- ^fin du texteLOOP$:	LOAD.W	D3,D2	DBOX_	MEDIT	DBOX_	EDIT		; attend action ...	LOAD.L	A1,A327$:	COMP.B	(A1+),#CR	JUMP,NE 27$	CLR.B	(A1)-1		; remplace le <CR> par <0>	LOAD.L	A1,#R16"TKEY_MAIN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP,EQ MODIF$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ NEXT$	COMP.W	D3,#KEYDBOX+0	JUMP',EQ KDATE$	COMP.W	D3,#KEYDBOX+1	JUMP',EQ KTIME$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	LOOP$NEXT$:				; RETURN =>	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KDATE$:	CLR.W	D2		; D2 <-- dite la date	JUMP	NLINE$KTIME$:	LOAD.W	D2,#1		; D2 <-- dite l'heure	JUMP	NLINE$MODIF$:				; D'ACCORD =>	TEST.B	(A6)+OBUDAT	; date existe ?	JUMP,EQ BIP$		; non => BIP$	TEST.B	(A6)+OBUTIM	; heure existe ?	JUMP,EQ BIP$		; non => BIP$	CALL	WRCLOCK		; met  jour la date et l'heure	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D7	JUMP'	EXIT$CANCEL$:			; ANNULE =>	DBOX_	CLOSE		; ferme la DBOXEXIT$:	PUSH.W	D7	LOAD.B	D3,(A6)+OMOUSE	LIB	?MOUSE		; remet le mode souris initial	LOAD.L	D5,(A6)+OCHMENU	LIB	?POPMENU	; restitue les soft-keys	CALL	NORMMOUSE	; souris: enlve le sablier	POP.W	D7	POPM.L	D0..D6,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_MAIN:	.W	10$-TDBOX_MAIN	.W	20$-TDBOX_MAIN	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"Date:  "	.B	ODBLABEL,1	.B	ODBLINE,(8+2)!2^7,KEYDBOX/H'100,0,TDBNORM	.B	ODBTEXT	.ASCIZ	"  (jour/mois/anne)"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Heure: "	.B	ODBLABEL,2	.B	ODBLINE,(8+2)!2^7,KEYDBOX/H'100,1,TDBNORM	.B	ODBTEXT	.ASCIZ	"  (heure:minute:seconde)"	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBMEV	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_MAIN:	.W	F1,F2,F3,0		DOKF1-TKEY_MAIN	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_MAIN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MAIN	.W	0;--------\\; RDCLOCK >;--------/; Prpare la date et l'heure dans les buffers d'dition.; in	-; out	(A6)+OBUDAT	jj/mm/aa;	(A6)+OBUTIM	hh/mm/ss;	D7.W		erreur; mod	D7.WRDCLOCK:	PUSHM.L	D3,D4,A3	LIB	?RDCLOCK	; D3 <-- heure, D4 <-- date	JUMP',NE EXIT$;	LOAD.L	D3,D3		; D3 <-- heure	LOAD.L	A3,#(A6)+OBUTIM	CALL	PUTTIME		; OBUTIM <-- heure en ASCIZ	LOAD.L	D3,D4		; D3 <-- date	LOAD.L	A3,#(A6)+OBUDAT	CALL	PUTDATE		; OBUDAT <-- date en ASCIZEXIT$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRCLOCK >;--------/; Ecrit la date et l'heure prpare dans les buffers d'ditions.; in	(A6)+OBUDAT	jj/mm/aa;	(A6)+OBUTIM	hh/mm/ss; out	D7.W		erreur; mod	D7.WWRCLOCK:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,#R16"NCLOCK	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre l'horloge	JUMP,NE EXIT$	LOAD.L	A3,#(A6)+OBUDAT	CALL	GETDATE		; D3 <-- date en BCD	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#SCDATE	LOAD.B	(A4)+3,D3	; buffer <-- anne	RR.L	D3,#8	LOAD.B	(A4)+2,D3	; buffer <-- mois	RR.L	D3,#8	LOAD.B	(A4)+1,D3	; buffer <-- jour	LOAD.L	D4,#4	FOS	?WRBYTE	JUMP',NE 80$	LOAD.L	A3,#(A6)+OBUTIM	CALL	GETTIME		; D3 <-- heure en BCD	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#SCTIME	LOAD.B	(A4)+1,D3	; buffer <-- secondes	RR.L	D3,#8	LOAD.B	(A4)+2,D3	; buffer <-- minutes	RR.L	D3,#8	LOAD.B	(A4)+3,D3	; buffer <-- heures	LOAD.L	D4,#4	FOS	?WRBYTE80$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'horloge	POP.W	D7EXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PUTDATE >;========/; Prpare une date en ASCIZ.; in	D3.L	date en BCD: | |j|m|a|;	A3.L	^buffer pour; out	(A3+)	date en ASCIZ; mod	D7.WPUTDATE:	PUSHM.L	D3,A3	RL.L	D3,#8	RL.L	D3,#8	CALL	PUTBCD		; buffer <-- jour	LOAD.B	(A3+),#'/	RL.L	D3,#8	CALL	PUTBCD		; buffer <-- mois	LOAD.B	(A3+),#'/	RL.L	D3,#8	CALL	PUTBCD		; buffer <-- anne	CLR.B	(A3)	POPM.L	D3,A3	RET;--------\\; PUTTIME >;========/; Prpare une heure en ASCIZ.; in	D3.L	heure en BCD: | |h|m|s|;	A3.L	^buffer pour; out	(A3+)	date en ASCIZ; mod	D7.WPUTTIME:	PUSHM.L	D3,A3	RL.L	D3,#8	RL.L	D3,#8	CALL	PUTBCD		; buffer <-- heure	LOAD.B	(A3+),#':	RL.L	D3,#8	CALL	PUTBCD		; buffer <-- minutes	LOAD.B	(A3+),#':	RL.L	D3,#8	CALL	PUTBCD		; buffer <-- secondes	CLR.B	(A3)	POPM.L	D3,A3	RET;--------\\; PUTBCD  >;--------/; in	D3.B	byte en BCD;	A3.L	^dans buffer; out	A3.L	^plus loin; mod	A3.LPUTBCD:	PUSH.W	D4	LOAD.B	D4,D3	SR.B	D4,#4	ADD.B	D4,#'0	LOAD.B	(A3+),D4	; buffer <-- dizaines	LOAD.B	D4,D3	AND.B	D4,#H'0F	ADD.B	D4,#'0	LOAD.B	(A3+),D4	; buffer <-- units	POP.W	D4	RET;--------\\; GETDATE >;========/; Donne une date en BCD.; in	A3.L	^date en ASCIZ; out	D3.L	date en BCD: | |j|m|a|; mod	D7.W;--------\\; GETTIME >;========/; Donne une heure en BCD.; in	A3.L	^heure en ASCIZ; out	D3.L	heure en BCD: | |h|m|s|; mod	D7.WGETDATE:GETTIME:	PUSHM.L	D4,A3	CLR.L	D3	CALL	GETBCD		; D4 <-- jour/heures	LOAD.B	D3,D4	SL.L	D3,#8	CALL	GETBCD		; D4 <-- mois/minutes	LOAD.B	D3,D4	SL.L	D3,#8	CALL	GETBCD		; D4 <-- anne/secondes	LOAD.B	D3,D4	POPM.L	D4,A3	RET;--------\\; GETBCD  >;--------/; in	A3.L	^dans buffer; out	A3.L	^plus loin;	D4.B	byte en BCD; mod	D4.L, A3.LGETBCD:	PUSH.W	D3	CLR.W	D410$:	CLR.W	D3	LOAD.B	D3,(A3)	JUMP',EQ 90$	INC.L	A3	COMP.B	D3,#'0	JUMP',LO 90$	COMP.B	D3,#'9	JUMP',HI 90$	SUB.B	D3,#'0	SL.W	D4,#4	ADD.W	D4,D3	JUMP	10$90$:	POP.W	D3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETNCLOCK:	.ASCIZ	"#CLOCK"	.EVEN	.END	START