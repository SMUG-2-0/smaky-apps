	.SBTTL	STARTAPP;---------\\; APPENDIF >;=========/; Cette routine est appele lorsque n'importe quels fichiers sont; dplacs ou dupliqus.; Si le fichier s'appelle START_USER.INFO, fusionne intgralement; START_USER.INFO et SMA_JIP24.GENC.; Si le fichier s'appelle SMA_JIP24.GENC, ne fait rien.; in	A1.L	^nom fichier source;	A2.L	^nom fichier destination; out	D3.W	0 => si rien fait;	D7.W	erreur; mod	D3.L, D7.WAPPENDIF:	PUSHM.L	A3,A4	LOAD.L	A3,A1	CALL	__SKIPREP	LOAD.L	A4,#R16"APPNIC	CALL	APPCPSTR	; fichier source = SMA_JIP24.GENC ?	JUMP',EQ 20$	LOAD.L	A4,#R16"APPNTX	CALL	APPCPSTR	; fichier source = START_USER.INFO ?	JUMP',NE 80$	LOAD.L	A3,A2	CALL	__SKIPREP	CALL	APPCPSTR	; fichier destination = START_USER.INFO ?	JUMP',NE 80$	JUMP'	40$20$:	LOAD.L	A3,A2	CALL	__SKIPREP	CALL	APPCPSTR	; fichier destination = SMA_JIP24.GENC ?	JUMP',NE 80$	LOAD.W	D3,#1		; D3 <-- comme si fait qq chose	CLR.W	D7		; D7 <-- ok	JUMP'	90$40$:	LOAD.L	A4,#R16"TOUT$	; A4 <-- pour tout fusionner	CALL	APPENDIC	; fusionne START_USER.INFO et SMA_JIP24.GENC	LOAD.W	D3,#1		; D3 <-- fait qq chose	JUMP'	90$80$:	CLR.W	D3		; D3 <-- rien fait	CLR.W	D7		; D7 <-- ok90$:	POPM.L	A3,A4	TEST.W	D7		; retour EQ/NE	RETTOUT$:	.B	0	.EVEN;---------\\; APPCPSTR >;---------/; Compare deux chanes de caractres.; in	A3.L	^chane <0>;	A4.L	^chane <0>; out	EQ,NE; mod	-APPCPSTR:	PUSHM.L	A3,A410$:	TEST.B	(A3)	JUMP',EQ 30$	COMP.B	(A3+),(A4+)	JUMP,EQ 10$	JUMP'	90$30$:	TEST.B	(A4)90$:	POPM.L	A3,A4	RET;---------\\; APPENDIC >;=========/; Fusionne START_USER.INFO et SMA_JIP24.GENC trouvs dans l'unit; source avec ceux trouvs dans l'unit destination.; in	A1.L	^nom fichier source;	A2.L	^nom fichier destination;	A4.L	^commande .APPENDIC avec paramtres; out	D7.W	erreur; mod	D7.WAPPENDIC:	PUSHM.L	D3,D4,A3..A5	LOAD.L	A5,A4		; A5 <-- ^commande avec paramtre(s)	CALL	APPSRDTX	; lit le texte source	JUMP',NE 80$	CALL	APPDRDTX	; lit le texte destination	JUMP',NE 80$	CALL	APPSRDIC	; lit les icnes source	JUMP',NE 80$	CALL	APPDRDIC	; lit les icnes destination	JUMP',NE 80$	CALL	APPPOUTZ	; fait l'mnage dans destination; Balaye toutes les lignes du texte source, et fusionne celles qui; doivent l'tre.	LOAD.L	A4,(A6)+OAPST	; A4 <-- ^texte source20$:	CLR.W	D7		; D7 <-- ok	TEST.B	(A4)		; fin du texte source ?	JUMP',EQ 50$		; oui => 50$	CALL	APPFILTRE	; ligne  fusionner ?	JUMP',NE 30$		; non => 30$	CALL	APPLINE		; A3 <-- ^ligne v. adapte	JUMP',NE 80$	CALL	APPINSERT	; insre v. dans destination30$:	CALL	__NEXTINFO	; A4 <-- ^ligne source suivante	JUMP	20$50$:	CALL	APPDWRIC	; mj. les icnes destination	JUMP',NE 80$	CALL	APPDWRTX	; mj. le texte destination80$:	PUSH.W	D7	CALL	APPSCLIC	; ferme les icnes source	CALL	APPSCLTX	; ferme le texte source	CALL	APPDCLIC	; ferme les icnes destination	CALL	APPDCLTX	; ferme le texte destination	POP.W	D790$:	POPM.L	D3,D4,A3..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; APPPOUTZ >;---------/; Fait d'la poutz dans le texte destination pour supprimer toutes; les lignes qui correspondent.; Efface aussi toutes les matrices inutiles (non rfrences).; in	A5.L	^commande avec paramtre(s); out	-; mod	D7.WAPPPOUTZ:	PUSHM.L	D3,A4	TEST.B	(A5)		; fusionne tout ?	JUMP',EQ 50$		; oui => 50$	LOAD.L	A4,(A6)+OAPDT	; A4 <-- ^texte destination20$:	CLR.W	D7		; D7 <-- ok	TEST.B	(A4)		; fin du texte destination ?	JUMP',EQ 50$		; oui => 50$	CALL	APPFILTRE	; ligne  fusionner ?	JUMP',NE 30$		; non => 30$	CALL	APPKLINE	; oui => supprime la ligne	JUMP	20$30$:	CALL	__NEXTINFO	; A4 <-- ^ligne source suivante	JUMP	20$; Efface toutes les matrices qui ne sont pas utilises par; le texte de destination.50$:	CLR.B	D352$:	CALL	APPIFUSE	; icne utilise dans texte destination ?	JUMP',NE 54$		; oui => 54$	CALL	APPCLEAR	; non => efface la matrice54$:	INC.B	D3	COMP.B	D3,#128	JUMP,LO 52$	POPM.L	D3,A4	RET;---------\\; APPKLINE >;---------/; Supprime une ligne.; in	A4.L	^ligne  supprimer; out	-; mod	D7.WAPPKLINE:	PUSHM.L	A3,A4	LOAD.L	A3,A4	CALL	__NEXTINFO	; A4 <-- ^ligne source suivante20$:	LOAD.B	(A3+),(A4+)	JUMP,NE 20$	POPM.L	A3,A4	RET;---------\\; APPIFUSE >;---------/; Cherche si une icne est utilise dans le texte de destination.; in	D3.B	icne; out	D7.W	EQ => pas utilise;		NE => utilise; mod	D7.WAPPIFUSE:	PUSHM.L	D2..D4,A4	LOAD.L	A4,(A6)+OAPDT	; A4 <-- ^texte destination	LOAD.B	D2,D320$:	CLR.W	D7		; D7 <-- pas utilis	TEST.B	(A4)		; fin du texte source ?	JUMP',EQ 90$		; oui => 90$	LOAD.B	D3,(A4)	CALL	MINMAJ	COMP.B	D3,#'J	JUMP',NE 50$	INC.L	A4		; A4 <-- saute le "j"	CALL	GETANUM		; D4 <-- code de l'icne JIP24	LOAD.W	D7,#ERSGJIP	; D7 <-- utilis	COMP.B	D4,D2	JUMP',EQ 90$50$:	CALL	__NEXTINFO	; A4 <-- ^ligne source suivante	JUMP	20$90$:	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; APPCLEAR >;---------/; Efface compltement une matrice d'une icne destination.; in	D3.B	icne; out	-; mod	D7.WAPPCLEAR:	PUSHM.L	D4,A4	CALL	APPDPTIC	; A4 <-- ^matrice destination	LOAD.W	D4,#((GCIIX*GCIIY/8)/4)-120$:	CLR.L	(A4+)		; efface toute la matrice	DECJ.W,NMO D4,20$	POPM.L	D4,A4	RET;----------\\; APPFILTRE >;----------/; Regarde si la ligne doit tre fusionne en fonction des; paramtres de la commande.;;	A4^	-->	32 "TOTO 2000/M" .ASM;	A5^	-->	AppendIc TOTO .ASM		=>  EQ;;	A4^	-->	32    .ASM;	A5^	-->	AppendIc TOTO .ASM		=>  EQ;;	A4^	-->	32 "TOTO 2000/M" .ASM;	A5^	-->	AppendIc TOTO			=>  NE;;	A4^	-->	32 "TOTO 2000/M" .ASM .ASI;	A5^	-->	AppendIc TOTO .ASM		=>  NE; in	A4.L	^ligne source;	A5.L	^commande avec paramtre(s); out	D7.W	EQ => ligne  appondre;		NE => ligne  ignorer; mod	D7.WAPPFILTRE:	PUSHM.L	D3,A1..A5	LOAD.W	D7,#ERSGJIP	COMP.B	(A4),#CR	; ligne vide ?	JUMP,EQ 90$		; oui => 90$	CLR.W	D7		; D7 <-- ligne  fusionner	TEST.B	(A5)		; fusionne tout ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A1,A5	CLR.B	D320$:	COMP.B	D3,#'"		; chane tait commence par guillemet ?	JUMP',NE 24$		; non => 24$	LOAD.W	D7,#ERSGJIP22$:	LOAD.B	D3,(A4+)	JUMP',EQ 90$	COMP.B	D3,#CR	JUMP',EQ 90$	COMP.B	D3,#'"	JUMP,NE 22$	DEC.L	A424$:	LOAD.L	A3,A4	LIB	?SKPNAM		; A4 <-- ^nom suivant dans ligne	JUMP',NE 80$	LOAD.L	A4,A3	LOAD.B	D3,(A4)	COMP.B	D3,#'"	JUMP',NE 26$	INC.L	A4		; A4 <-- saute le guillemet26$:	LOAD.L	A5,A130$:	LOAD.L	A3,A5	LIB	?SKPNAM		; A5 <-- ^paramtre suivant	JUMP',NE 90$	LOAD.L	A5,A3;	LOAD.L	A3,A5	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	JUMP,NS 30$	JUMP	20$80$:	CLR.W	D7		; D7 <-- ligne  fusionner90$:	POPM.L	D3,A1..A5	TEST.W	D7		; retour EQ/NE	RETTERM$:	.B	SPACE,TAB,'",CR,0,-1	.EVEN;--------\\; APPLINE >;--------/; Adapte une ligne si ncessaire.; in	A4.L	^ligne source; out	A3.L	^ligne adapte;	D7.W	erreur; mod	D7.W, A3.LAPPLINE:	PUSHM.L	D3,D4,A4	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^buffer pour ligne adapte	LOAD.B	D3,(A4)	CALL	MINMAJ	COMP.B	D3,#'J	JUMP',NE 50$	INC.L	A4		; A4 <-- saute le "j"	CALL	GETANUM		; D4 <-- code de l'icne JIP24	LOAD.B	D3,D4	CALL	APPLINK		; D3 <-- icne correspondante	JUMP',NE 90$	LOAD.B	(A3+),#'j	EX.L	A3,A4	CLR.W	D4	LOAD.B	D4,D3	CALL	PUTANUM		; OBUDIS <-- nouveau numro	EX.L	A4,A350$:	LOAD.B	D3,(A4+)	JUMP',EQ 52$	COMP.B	D3,#CR	JUMP',EQ 52$	LOAD.B	(A3+),D3	; OBUDIS <-- copie la ligne	JUMP	50$52$:	LOAD.B	(A3+),#CR	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^ligne adapte	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; APPINSERT >;----------/; Insre une ligne dans la destination, seulement si elle n'y; est pas dj.; in	A3.L	^ligne  insrer; out	-; mod	D7.WAPPINSERT:	PUSHM.L	A1..A4	LOAD.L	A4,(A6)+OAPDT	; A4 <-- ^texte destination10$:	TEST.B	(A4)		; fin texte destination ?	JUMP',EQ 50$		; oui => 50$	LOAD.L	A1,A3	LOAD.L	A2,A420$:	COMP.B	(A1),#CR	JUMP',EQ 24$	COMP.B	(A1+),(A2+)	; ligne dj dans destination ?	JUMP,EQ 20$22$:	CALL	__NEXTINFO	; A4 <-- ^ligne destination suivante	JUMP	10$24$:	COMP.B	(A2),#CR	JUMP',EQ 90$	JUMP	22$50$:	LOAD.B	(A4+),(A3+)	; texte destination <-- texte source	JUMP,NE 50$90$:	POPM.L	A1..A4	RET;--------\\; APPLINK >;========/; Effectue une correspondance entre une icne source et; une icne destination.; in	D3.B	icne source; out	D3.B	icne destination correspondante;	D7.W	erreur; mod	D3.L, D7.WAPPLINK:	PUSH.W	D4	LOAD.B	D4,D3	CALL	APPCOMP		; existe-t-il une icne identique ?	JUMP',EQ 90$		; oui => 90$	LOAD.B	D3,D4	CALL	APPFREE		; existe-t-il une icne libre ?90$:	POP.W	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; APPCOMP >;--------/; Cherche une icne libre dans la destination.; in	D3.B	icne source; out	D3.B	icne destination identique;	D7.W	erreur; mod	D3.L, D7.WAPPCOMP:	PUSHM.L	D4,A1..A4	CALL	APPSPTIC	; A4 <-- ^matrice icne source	JUMP',NE 90$	LOAD.L	A2,A4	CLR.B	D3	CALL	APPDPTIC	; A4 <-- ^matrice destination10$:	LOAD.W	D7,#ERSGJIP	INC.B	D3		; D3 <-- icne suivante	COMP.B	D3,#128	JUMP',HS 90$	LOAD.L	A4,#(A4)+GCIIX*GCIIY/8 ; A4 <-- ^matrice suivante	LOAD.L	A1,A2	LOAD.L	A3,A4	LOAD.W	D4,#((GCIIX*GCIIY/8)/4)-120$:	COMP.L	(A1+),(A3+)	; matrices identiques ?	JUMP,NE 10$		; non => 10$	DECJ.W,NMO D4,20$	CLR.W	D7		; D7 <-- youpie, trouv90$:	POPM.L	D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; APPFREE >;--------/; Cherche une icne libre dans la destination.; in	D3.B	icne source; out	D3.B	icne destination rendue identique;	D7.W	erreur; mod	D3.L, D7.WAPPFREE:	PUSHM.L	D4,A2..A4	CALL	APPSPTIC	; A4 <-- ^matrice icne source	JUMP',NE 90$	LOAD.L	A2,A4	CLR.B	D3	CALL	APPDPTIC	; A4 <-- ^matrice destination10$:	LOAD.W	D7,#ERSGJIP	INC.B	D3		; D3 <-- icne suivante	COMP.B	D3,#128	JUMP',HS 90$	LOAD.L	A4,#(A4)+GCIIX*GCIIY/8 ; A4 <-- ^matrice suivante	LOAD.L	A3,A4	LOAD.W	D4,#((GCIIX*GCIIY/8)/4)-120$:	TEST.L	(A3+)		; matrice toute vide ?	JUMP,NE 10$		; non => 10$	DECJ.W,NMO D4,20$	LOAD.W	D4,#((GCIIX*GCIIY/8)/4)-140$:	LOAD.L	(A4+),(A2+)	; icne destination <-- icne source	DECJ.W,NMO D4,40$	CLR.W	D7		; D7 <-- youpie, trouv90$:	POPM.L	D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; APPSPTIC >;---------/; Cherche la matrice d'une icne source.; in	D3.B	code d'une icne; out	A4.L	^matrice de l'icne;	D7.W	erreur; mod	D7.W, A4.LAPPSPTIC:	PUSH.L	D3	LOAD.W	D7,#ERSGJIP	COMP.B	D3,(A6)+OBUHEAD+OGCLCA	JUMP',HI 90$	SUB.B	D3,(A6)+OBUHEAD+OGCFCA	JUMP',LO 90$	LOAD.L	A4,(A6)+OAPSI	; A4 <-- ^matrices source	AND.W	D3,#H'007F	MUL.WU	D3,#GCIIX*GCIIY/8	ADD.L	A4,D3		; A4 <-- ^bonne matrice	CLR.W	D7		; D7 <-- ok90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; APPDPTIC >;---------/; Cherche la matrice d'une icne destination.; in	D3.B	code d'une icne; out	A4.L	^matrice de l'icne; mod	D7.W, A4.LAPPDPTIC:	PUSH.L	D3	LOAD.L	A4,(A6)+OAPDI	; A4 <-- ^gencar destination	LOAD.L	A4,#(A4)+256+OGCWID+(128*3)	AND.W	D3,#H'007F	MUL.WU	D3,#GCIIX*GCIIY/8	ADD.L	A4,D3		; A4 <-- ^bonne matrice	POP.L	D3	RET;---------\\; APPSRDIC >;---------/; Lit le gencar des icnes source.; in	A1.L	^nom fichier source; out	D7.W	erreur; mod	D7.WAPPSRDIC:	PUSHM.L	D1,D3,D4,D6,A3,A4	LOAD.L	A3,A1		; A3 <-- ^nom unit source	LOAD.L	A4,#R16"APPNIC	; A4 <-- ^nom de fichier	CALL	APPNAME		; A3 <-- ^nom complet	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE 90$	CLR.W	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute l'en-tte binaire	JUMP',NE 85$	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D4,#OGCWID	FOS	?RDBYTE		; lit l'en-tte gencar	JUMP',NE 85$	CLR.W	D4	LOAD.B	D4,(A4)+OGCLCA	SUB.B	D4,(A4)+OGCFCA	INC.B	D4		; D4 <-- nb de caractres	LOAD.W	D3,D4	MUL.WU	D4,#GCIIX*GCIIY/8	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour matrices	JUMP',NE 85$	LOAD.L	D1,D4	LOAD.W	D4,D3	MUL.WU	D4,#3	ADD.L	D4,#256+OGCWID	CLR.W	D3	FOS	?SPOS		; saute les z'en-ttes	JUMP',NE 80$	LOAD.L	D4,D1	FOS	?RDBYTE		; lit les matrices	JUMP',NE 80$	LOAD.L	(A6)+OAPSI,A4	; OAPSI <-- ^matrices des icnes source	JUMP'	85$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; demande mmoire pour fichier complet	POP.W	D785$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; APPDRDIC >;---------/; Lit le gencar des icnes destination.; in	A2.L	^nom fichier destination; out	D7.W	erreur; mod	D7.WAPPDRDIC:	PUSHM.L	D1,D3,D4,D6,A1..A4	LOAD.L	D4,#256+OGCWID+(128*3)+(GCIIX*GCIIY/8*128)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour gencar complet	JUMP,NE 90$	LOAD.L	A1,A4	SR.L	D4,#2		; D4 <-- /4 car .L	DEC.W	D4		; D4 <-- -1 car NMO10$:	CLR.L	(A4+)		; met tout  zro	DECJ.W,NMO D4,10$	LOAD.L	A3,A2		; A3 <-- ^nom unit destination	LOAD.L	A4,#R16"APPNIC	; A4 <-- ^nom de fichier	CALL	APPNAME		; A3 <-- ^nom complet	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le gencar JIP24	JUMP',EQ 20$	COMP.W	D7,#ERFDNE	JUMP,NE 85$	LOAD.L	(A6)+OAPDI,A1	; OAPDI <-- ^gencar des icnes destination	CLR.W	D7		; D7 <-- ok	JUMP	90$20$:	LOAD.L	A4,A1	LOAD.L	D4,#256+OGCWID	FOS	?RDBYTE		; lit les en-ttes	JUMP,NE 80$	LOAD.W	D7,#ERSGJIP	; D7 <-- dimensions incompatibles	COMP.B	(A1)+256+OGCMWB,#GCIIX/8	JUMP,NE 80$	COMP.W	(A1)+256+OGCMHD,#GCIIY	JUMP,NE 80$	CLR.L	D4	LOAD.B	D4,(A1)+256+OGCLCA	SUB.B	D4,(A1)+256+OGCFCA	INC.B	D4		; D4 <-- nb de caractres	LOAD.L	A4,#(A1)+256+OGCWID+(128*0)	CLR.W	D3	LOAD.B	D3,(A1)+256+OGCFCA	ADD.W	A4,D3	FOS	?RDBYTE		; lit la table des largeurs	JUMP',NE 80$	LOAD.L	A4,#(A1)+256+OGCWID+(128*1)	CLR.W	D3	LOAD.B	D3,(A1)+256+OGCFCA	ADD.W	A4,D3	FOS	?RDBYTE		; lit la table des h1	JUMP',NE 80$	LOAD.L	A4,#(A1)+256+OGCWID+(128*2)	CLR.W	D3	LOAD.B	D3,(A1)+256+OGCFCA	ADD.W	A4,D3	FOS	?RDBYTE		; lit la table des h2	JUMP',NE 80$	MUL.WU	D4,#GCIIX*GCIIY/8	LOAD.L	A4,#(A1)+256+OGCWID+(128*3)	CLR.W	D3	LOAD.B	D3,(A1)+256+OGCFCA	MUL.WU	D3,#GCIIX*GCIIY/8	ADD.L	A4,D3	FOS	?RDBYTE		; lit toutes les matrices	JUMP',NE 80$	FOS	?CLOSE	JUMP',NE 85$	LOAD.L	(A6)+OAPDI,A1	; OAPDI <-- ^gencar des icnes destination	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D785$:	PUSH.W	D7	LOAD.L	A4,A1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; demande mmoire pour gencar complet	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; APPSRDTX >;---------/; Lit le texte des dfinitions source.; in	A1.L	^nom fichier source; out	D7.W	erreur; mod	D7.WAPPSRDTX:	PUSHM.L	D1,D3,D4,D6,A3,A4	LOAD.L	A3,A1		; A3 <-- ^nom unit source	LOAD.L	A4,#R16"APPNTX	; A4 <-- ^nom de fichier	CALL	APPNAME		; A3 <-- ^nom complet	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE 90$	LOAD.W	D3,#-1	LOAD.L	D4,#-1	FOS	?SPOS		; va tout  la fin	LOAD.L	D1,D4		; D1 <-- longueur du fichier	CLR.W	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP',NE 85$	LOAD.L	D4,D1	INC.L	D4		; D4 <-- place pour <0> terminateur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour fichier complet	JUMP',NE 85$	DEC.L	D4	FOS	?RDBYTE	JUMP',NE 80$	CLR.B	(A4)+(D4.L)	; met <0> terminateur	LOAD.L	(A6)+OAPST,A4	; OAPST <-- ^texte source	JUMP'	85$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; demande mmoire pour fichier complet	POP.W	D785$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; APPDRDTX >;---------/; Lit le texte des dfinitions destination.; in	A2.L	^nom fichier destination; out	D7.W	erreur; mod	D7.WAPPDRDTX:	PUSHM.L	D1,D3,D4,D6,A3,A4	LOAD.L	A3,A2		; A3 <-- ^nom unit destination	LOAD.L	A4,#R16"APPNTX	; A4 <-- ^nom de fichier	CALL	APPNAME		; A3 <-- ^nom complet	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',EQ 20$	COMP.W	D7,#ERFDNE	JUMP,NE 90$	LOAD.L	A3,(A6)+OAPST	LOAD.L	D4,#20010$:	INC.L	D4		; D4 <-- supplment pour insrer	TEST.B	(A3+)	JUMP,NE 10$	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour fichier complet	JUMP,NE 90$	CLR.B	(A4)		; met <0> terminateur	LOAD.L	(A6)+OAPDT,A4	; OAPDT <-- ^texte destination	JUMP	90$20$:	LOAD.W	D3,#-1	LOAD.L	D4,#-1	FOS	?SPOS		; va tout  la fin	LOAD.L	D1,D4		; D1 <-- longueur du fichier	CLR.W	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP',NE 85$	LOAD.L	A3,(A6)+OAPST	LOAD.L	D3,#20030$:	INC.L	D3		; D3 <-- supplment pour insrer	TEST.B	(A3+)	JUMP,NE 30$	LOAD.L	D4,D1	ADD.L	D4,D3		; D4 <-- place pour insrer	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour fichier complet	JUMP',NE 85$	SUB.L	D4,D3	FOS	?RDBYTE	JUMP',NE 80$	CLR.B	(A4)+(D4.L)	; met <0> terminateur	LOAD.L	(A6)+OAPDT,A4	; OAPDT <-- ^texte destination	JUMP'	85$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; demande mmoire pour fichier complet	POP.W	D785$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; APPDWRIC >;---------/; Met  jour les icnes destination.; in	A2.L	^nom fichier destination; out	-; mod	D7.WAPPDWRIC:	PUSHM.L	D1,D3,D4,D6,A1..A4	LOAD.L	A3,A2		; A3 <-- ^nom unit destination	LOAD.L	A4,#R16"APPNIC	; A4 <-- ^nom de fichier	CALL	APPNAME		; A3 <-- ^nom complet	FOS	?DELETE	JUMP',EQ 20$	COMP.W	D7,#ERFDNE	JUMP,NE 90$20$:	CALL	APPLAST		; D4 <-- nb d'icnes	CLR.W	D7		; D7 <-- ok	TEST.W	D4		; au moins une icne ?	JUMP,EQ 90$		; non => 90$; Met  jour l'en-tte du gencar des icnes.	LOAD.L	A4,(A6)+OAPDI	; A4 <-- ^icnes destination	LOAD.W	D3,#((256+OGCWID)/4)-130$:	CLR.L	(A4+)		; efface les en-ttes	DECJ.W,NMO D3,30$	LOAD.L	A4,(A6)+OAPDI	; A4 <-- ^icnes destination	LOAD.W	(A4)+OBXTYP,#2^BBXREL	LOAD.W	D3,D4	MUL.WU	D3,#(GCIIX*GCIIY/8)+3	ADD.L	D3,#OGCWID	LOAD.L	(A4)+OBXLG,D3	LOAD.W	(A4)+256+OGCMSB,#GCIIX*GCIIY/8	LOAD.W	(A4)+256+OGCMHD,#GCIIY	LOAD.B	(A4)+256+OGCMWB,#GCIIX/8	LOAD.B	D3,D4	DEC.B	D3	LOAD.B	(A4)+256+OGCLCA,D3	LOAD.W	(A4)+256+OGCBLI,#GCIIB	LOAD.W	(A4)+256+OGCMH1,#GCIIY-GCIIB	LOAD.W	(A4)+256+OGCMH2,#GCIIB	LOAD.W	(A4)+256+OGCMWI,#GCIIX	LOAD.W	(A4)+256+OGCISP,#GCIIY	LOAD.W	D3,D4	LOAD.W	(A4)+256+OGCPH1,D3	ADD.W	D3,D4	LOAD.W	(A4)+256+OGCPH2,D3	ADD.W	D3,D4	LOAD.W	(A4)+256+OGCPMX,D3	LOAD.L	A1,#R16"IDE$	LOAD.L	A2,#(A4)+256+OGCIDE33$:	LOAD.B	(A2+),(A1+)	; OGCIDE <-- identificateur	JUMP,NE 33$	LOAD.L	A1,#R16"TXT$	LOAD.L	A2,#(A4)+256+OGCTXT34$:	LOAD.B	(A2+),(A1+)	; OGCTXT <-- texte	JUMP,NE 34$	LOAD.L	A2,#(A4)+256+OGCWID+(128*0)	LOAD.W	D3,#128-135$:	LOAD.B	(A2+),#GCIIX	; table des largeurs	DECJ.W,NMO D3,35$	LOAD.W	D3,#128-136$:	LOAD.B	(A2+),#GCIIY-GCIIB ; table des h1	DECJ.W,NMO D3,36$	LOAD.W	D3,#128-137$:	LOAD.B	(A2+),#GCIIB	; table des h2	DECJ.W,NMO D3,37$	CLR.L	D1	LOAD.W	D1,D4		; D1 <-- nb d'icnes	LOAD.L	A1,A4		; A1 <-- ^gencar	LOAD.L	D3,#DEFATT-(2^BATTL)-(2^BATTC)	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE 90$;	LOAD.L	A4,#(A1)+0	LOAD.L	D4,#256+OGCWID	FOS	?WRBYTE		; crit les en-ttes	JUMP',NE 80$	LOAD.L	A4,#(A1)+256+OGCWID+(128*0)	LOAD.L	D4,D1	FOS	?WRBYTE		; crit la table des largeurs	JUMP',NE 80$	LOAD.L	A4,#(A1)+256+OGCWID+(128*1)	LOAD.L	D4,D1	FOS	?WRBYTE		; crit la table des h1	JUMP',NE 80$	LOAD.L	A4,#(A1)+256+OGCWID+(128*2)	LOAD.L	D4,D1	FOS	?WRBYTE		; crit la table des h2	JUMP',NE 80$	LOAD.L	A4,#(A1)+256+OGCWID+(128*3)	LOAD.L	D4,D1	MUL.WU	D4,#GCIIX*GCIIY/8	FOS	?WRBYTE		; crit la table des matrices	JUMP',NE 80$	FOS	?CLOSE	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RETIDE$:	.ASCIZ	"START"TXT$:	.ASCIZ	"(C) 1988, Daniel ROUX et EPSITEC-system sa"	.EVEN;--------\\; APPLAST >;--------/; Cherche quelle est la dernire matrice utilise.; in	-; out	D4.W	nb d'icnes destination; mod	D4.L, D7.WAPPLAST:	PUSHM.L	D3,A3,A4	LOAD.B	D3,#127	CALL	APPDPTIC	; A4 <-- ^dernire matrice destination10$:	LOAD.W	D4,#((GCIIX*GCIIY/8)/4)-1	LOAD.L	A3,A420$:	TEST.L	(A3+)		; matrice utilise ?	JUMP',NE 50$		; oui => 50$	DECJ.W,NMO D4,20$	LOAD.L	A4,#(A4)-GCIIX*GCIIY/8 ; A4 <-- ^matrice prcdente	DEC.B	D3	JUMP,NC 10$50$:	CLR.W	D4	LOAD.B	D4,D3	INC.W	D4		; D4 <-- nb d'icnes	POPM.L	D3,A3,A4	RET;---------\\; APPDWRTX >;---------/; Met  jour le texte destination.; in	A2.L	^nom fichier destination; out	-; mod	D7.WAPPDWRTX:	PUSHM.L	D1,D3,D4,D6,A3,A4	LOAD.L	A3,A2		; A3 <-- ^nom unit destination	LOAD.L	A4,#R16"APPNTX	; A4 <-- ^nom de fichier	CALL	APPNAME		; A3 <-- ^nom complet	FOS	?DELETE	JUMP',EQ 20$	COMP.W	D7,#ERFDNE	JUMP',NE 90$20$:	LOAD.L	D3,#DEFATT-(2^BATTL)-(2^BATTC)	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE 90$	LOAD.L	A4,(A6)+OAPDT	; A4 <-- ^texte destination	LOAD.L	A3,A4	LOAD.L	D4,#-140$:	INC.L	D4		; D4 <-- longueur du fichier	TEST.B	(A3+)	JUMP,NE 40$	FOS	?WRBYTE	JUMP',NE 80$	FOS	?CLOSE	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; APPSCLIC >;---------/; Ferme les icnes source.; in	-; out	-; mod	D7.WAPPSCLIC:	PUSHM.L	D1,A4	TEST.L	(A6)+OAPSI	JUMP',EQ 90$	LOAD.L	A4,(A6)+OAPSI	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OAPSI90$:	POPM.L	D1,A4	RET;---------\\; APPDCLIC >;---------/; Ferme les icnes destination.; in	-; out	-; mod	D7.WAPPDCLIC:	PUSHM.L	D1,A4	TEST.L	(A6)+OAPDI	JUMP',EQ 90$	LOAD.L	A4,(A6)+OAPDI	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OAPDI90$:	POPM.L	D1,A4	RET;---------\\; APPSCLTX >;---------/; Ferme le texte source.; in	-; out	-; mod	D7.WAPPSCLTX:	PUSHM.L	D1,A4	TEST.L	(A6)+OAPST	JUMP',EQ 90$	LOAD.L	A4,(A6)+OAPST	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OAPST90$:	POPM.L	D1,A4	RET;---------\\; APPDCLTX >;---------/; Ferme le texte destination.; in	-; out	-; mod	D7.WAPPDCLTX:	PUSHM.L	D1,A4	TEST.L	(A6)+OAPDT	JUMP',EQ 90$	LOAD.L	A4,(A6)+OAPDT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OAPDT90$:	POPM.L	D1,A4	RET;--------\\; APPNAME >;--------/; Construit un nom de fichier.; in	A3.L	^unit;	A4.L	^nom; out	A3.L	^nom; mod	A3.LAPPNAME:	PUSHM.L	A2,A4	LOAD.L	A2,#(A6)+OBUFIT10$:	LOAD.B	(A2+),(A3+)	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBUFIT	CALL	__SKIPREP20$:	LOAD.B	(A3+),(A4+)	JUMP,NE 20$	LOAD.L	A3,#(A6)+OBUFIT	POPM.L	A2,A4	RETAPPNIC:	.ASCIZ	"SMA_JIP24.GENC"APPNTX:	.ASCIZ	"START_USER.INFO"	.EVEN	.END