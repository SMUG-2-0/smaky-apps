	.SBTTL	FCOPYIO.ASI;---------\\; COPYGREY >;=========/; Cherche quels sont les options impossibles.; in	-; out	(A6)+OGREY.B	options impossibles; mod	D7.WCOPYGREY:	PUSHM.L	D0,D3,D4,A3,A4	CLR.B	D0		; D0 <-- rien de gris	LOAD.L	A3,#R16"FLO1$	CLR.W	D3	FOS	?VASSIGN	JUMP',EQ 20$	TSET.L	D0:#1		; D0 <-- grise "floppy0 --> floppy1"	TSET.L	D0:#2		; D0 <-- grise "floppy0 <-- floppy1"20$:	LOAD.B	(A6)+OGREY,D0	POPM.L	D0,D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RETFLO1$:	.ASCIZ	"$FLO_1"	.EVEN;--------\\; COPYEX  >;========/; Effectue une copie quelconque ...; in	A1.L	^nom source;	A2.L	^nom destination; out	D7.W	erreur; mod	D7.WCOPYEX:	PUSHM.L	D2..D4,A1..A5	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A5,#0		; A5 <-- nil	LOAD.W	(A6)+OCPERR,#-1	CLR.W	(A6)+OCPCHR	CLR.W	(A6)+OCPCHW	LOAD.L	A3,A1		; A3 <-- ^nom unit source	CALL	IFTYPFLO	; unit source = floppy ?	JUMP',NE 40$		; non => 40$	LOAD.L	A3,A2		; A3 <-- ^nom unit destination	CALL	IFTYPFLO	; unit destination = floppy ?	JUMP',NE 30$		; non => 30$	LOAD.L	A3,A1		; A3 <-- ^nom unit source	LOAD.L	A4,A2		; A4 <-- ^nom unit destination20$:	TEST.B	(A3)	JUMP',EQ 22$	COMP.B	(A3+),(A4+)	; unit source = unit destination ?	JUMP,EQ 20$	JUMP'	24$		; non => 24$22$:	TEST.B	(A4)	JUMP',EQ 26$		; oui => 26$24$:	CALL	COPYFF		; copie floppy --> floppy ...	JUMP'	80$26$:	CALL	COPYSI		; copie avec un seul lecteur ...	JUMP'	80$30$:	CALL	COPYFW		; copie floppy --> winch ...	JUMP'	80$40$:	LOAD.L	A3,A2		; A3 <-- ^nom unit destination	CALL	IFTYPFLO	; unit destination = floppy ?	JUMP',NE 70$		; non => 70$	CALL	COPYWF		; copie winch --> floppy ...	JUMP'	80$70$:	LOAD.W	D7,#ERUTYP	; D7 <-- type d'unit incorrect80$:	PUSH.W	D7	CALL	FMCLOSE		; libre la mmoire	LOAD.L	A3,A1		; A3 <-- ^nom unit source	CALL	FRCLOSE		; ferme l'unit source	CALL	FWCLOSE		; ferme l'unit destination	CALL	CLRFIFO		; vide le fifo du clavier	POP.W	D7	POPM.L	D2..D4,A1..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; COPYSI  >;========/; Effectue une copie avec un seul floppy.; in	A1.L	^nom unit source = nom unit destination; out	D7.W	erreur;	A3.L	^nom du fichier ayant caus l'erreur; mod	D7.W, A3.LCOPYSI:	PUSHM.L	D0..D6,A4	CLR.L	D6		; D6 <-- flags	CALL	DBOXCOPYSI	; demande confirmation ...	JUMP,NE 90$	COMP.W	D3,#F1		; (COPIE) ?	JUMP,NE 90$		; non => 90$	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A3,A1		; A3 <-- ^nom unit source	LOAD.L	D3,#2^BEAUTOM	; D3 <-- signal BAL comme enter automatique	FOS	?LRELEASE	; tente un release de l'unit	LOAD.W	(A6)+OCPERR,D7	; mm. si release ok	CALL	FWOPEN		; ouvre l'unit source	JUMP,NE 90$	CALL	FWNBBLK		; D4 <-- nb de blocs source	JUMP,NE 90$	CALL	FMOPENALL	; A5/D5 <-- ^buffer/nb blocs	JUMP,NE 90$	LOAD.L	D0,#-16		; D0 <-- premier bloc	LOAD.L	D1,D4		; D1 <-- nombre de blocs	COMP.L	D5,D1		; buffer plus grand qu'un floppy ?	JUMP',LS 30$		; non => 30$	LOAD.L	D5,D1		; oui => limite !!30$:	LOAD.L	D4,D1	ADD.L	D4,D5	DEC.L	D4	DIV.WU	D4,D5		; D4 <-- nb de tranches	SWAP.W	D6	LOAD.W	D6,D4	SWAP.W	D640$:	TCLR.L	D6:#0	JUMP',BC 42$	CALL	DBOXCOPYSX	; demande la disquette source ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP,NE 80$42$:	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A4,A5		; A4 <-- ^buffer	LOAD.L	D4,D0		; D4 <-- premier bloc	LOAD.L	A3,A1		; A3 <-- ^nom unit source	PUSH.W	(A6)+OCPCHR	LOAD.W	(A6)+OCPCHR,(A6)+OCPCHW	CALL	FRDATA		; lit une tranche sur la source	POP.W	(A6)+OCPCHR	TEST.W	D7	JUMP,NE 90$	TSET.L	D6:#0	CALL	DBOXCOPYSX	; demande la disquette destination ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP,NE 80$	CALL	WAITMOUSE	; souris: met le sablier	TSET.L	D6:#1		; dj format ?	JUMP',BS 52$		; oui => 52$	CLR.W	D3		; D3 <-- mode sans formatage	TEST.B	(A6)+OCPFFF+3:#0	JUMP',BC 50$	LOAD.W	D3,#'F		; D3 <-- mode avec formatage50$:	CALL	FWFORMAT	; formate l'unit destination	JUMP,NE 90$52$:	LOAD.L	D4,D0		; D4 <-- premier bloc	LOAD.L	A3,A1		; A3 <-- ^nom unit source	CALL	FWDATA		; crit une tranche sur la destination	JUMP',NE 90$	SWAP.W	D6	DEC.W	D6		; D6 <-- il reste une tranche de moins	SWAP.W	D6	TEST.L	D1		; reste qq chose ?	JUMP',EQ 70$		; non => 70$	ADD.L	D0,D5		; D0 <-- no bloc next tranche	SUB.L	D1,D5		; D1 <-- nb restant	COMP.L	D1,D5	JUMP,HS 40$	LOAD.L	D5,D1		; D5 <-- lg dernire tranche	JUMP',EQ 70$	CLR.L	D1		; D1 <-- restera plus rien	JUMP	40$70$:	LOAD.W	D3,#BIPDONE	LIB	?BEEP		; p'tite musique	CLR.W	D7		; D7 <-- parfait	JUMP'	90$80$:	LOAD.W	D7,#ERTRSTO	; D7 <-- "transfert stopp"90$:	PUSHM.L	D7,A3	CALL	FWCLOSE		; ferme v. la disquette	TCLR.L	D6:#0		; disquette source dans le lecteur ?	JUMP',BC 92$		; oui => 92$	CALL	DBOXCOPYSE	; non => redemande la disquette source ...92$:	LOAD.L	A3,A1		; A3 <-- ^nom unit	TEST.W	(A6)+OCPERR	; release ok ?	JUMP',NE 95$		; non => 95$				; oui =>	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	D3,#2^BEAUTOM	; D3 <-- signal BAL comme enter automatique	FOS	?NENTER		; refait un ENTER95$:	POPM.L	D7,A3	POPM.L	D0..D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; COPYFF  >;========/; Effectue une copie floppy --> floppy.; in	A1.L	^nom unit source;	A2.L	^nom unit destination; out	D7.W	erreur;	A3.L	^nom du fichier ayant caus l'erreur; mod	D7.W, A3.LCOPYFF:	PUSHM.L	D0..D5,A4	LOAD.L	A3,A2		; A3 <-- ^nom unit destination10$:	COMP.B	(A3+),#':	JUMP,NE 10$	CLR.B	(A3)		; garde juste "#MM1:"	CALL	DBOXCOPYFF	; demande confirmation ...	JUMP,NE 90$	COMP.W	D3,#F1		; (COPIE) ?	JUMP,NE 90$		; non => 90$	CALL	WAITDBOX	; ouvre la dbox d'attente	JUMP,NE 90$	LOAD.L	A3,A1		; A3 <-- ^nom unit source	CALL	FROPEN		; ouvre l'unit source	JUMP,NE 90$	LOAD.L	A3,A2		; A3 <-- ^nom unit destination	CALL	FWOPEN		; ouvre l'unit destination	JUMP,NE 90$	CALL	FRNBBLK		; D4 <-- nb de blocs source	JUMP,NE 90$	LOAD.L	D3,D4	CALL	FWNBBLK		; D4 <-- nb de blocs destination	JUMP,NE 90$	LOAD.W	D7,#ERTYPC	; D7 <-- copie impossible	COMP.L	D3,D4		; mme nb de blocs ?	JUMP,NE 90$		; non => 90$	CLR.W	D3		; D3 <-- mode sans formatage	TEST.B	(A6)+OCPFFF+3:#0	JUMP',BC 20$	LOAD.W	D3,#'F		; D3 <-- mode avec formatage	LOAD.L	A3,#R16"TXFORM	CALL	AFFTDBOX	; affiche texte dans la dbox d'attente20$:	CALL	FWFORMAT	; formate l'unit destination	JUMP,NE 90$	LOAD.L	A3,#R16"TYFORM	CALL	AFFTDBOX	; efface texte dans la dbox d'attente	CALL	FMOPEN		; A5/D5 <-- ^buffer/nb blocs	JUMP,NE 90$	LOAD.L	D0,#-16		; D0 <-- premier bloc	LOAD.L	D1,D4		; D1 <-- nombre de blocs	COMP.L	D5,D1		; buffer plus grand qu'un floppy ?	JUMP',LS 40$		; non => 40$	LOAD.L	D5,D1		; oui => limite !!40$:	CALL	AFFNDBOX	; affiche nb blocs dans la dbox d'attente	LOAD.B	D3,#'L	CALL	AFFCDBOX	; affiche "L" dans l'ascenseur	LOAD.L	A4,A5		; A4 <-- ^buffer	LOAD.L	D4,D0		; D4 <-- premier bloc	LOAD.L	A3,A1		; A3 <-- ^nom unit source	CALL	FRDATA		; lit une tranche sur la source	JUMP',NE 90$	LOAD.B	D3,#'E	CALL	AFFCDBOX	; affiche "E" dans l'ascenseur	LOAD.L	D4,D0		; D4 <-- premier bloc	LOAD.L	A3,A2		; A3 <-- ^nom unit destination	CALL	FWDATA		; crit une tranche sur la destination	JUMP',NE 90$	TEST.L	D1		; reste qq chose ?	JUMP',EQ 70$		; non => 70$	ADD.L	D0,D5		; D0 <-- no bloc next tranche	SUB.L	D1,D5		; D1 <-- nb restant	COMP.L	D1,D5	JUMP,HS 40$	LOAD.L	D5,D1		; D5 <-- lg dernire tranche	JUMP',EQ 70$	CLR.L	D1		; D1 <-- restera plus rien	JUMP	40$70$:	LOAD.W	D3,#BIPDONE	LIB	?BEEP		; p'tite musique	CLR.W	D7		; D7 <-- parfait90$:	PUSH.W	D7	CALL	NORMDBOX	; ferme la dbox d'attente	POP.W	D7	POPM.L	D0..D5,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; COPYWF  >;========/; Effectue une copie winch --> floppy.; in	A1.L	^nom unit source;	A2.L	^nom unit destination; out	D7.W	erreur;	A3.L	^nom du fichier ayant caus l'erreur; mod	D7.W, A3.LCOPYWF:	PUSHM.L	D0..D6,A4	CLR.W	D6		; D6 <-- canal fichier .DI	LOAD.L	A3,#(A6)+OCPNAM	CALL	DBOXPREND	; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP,NE 90$	LOAD.L	A1,A3		; A1 <-- ^nom du fichier source .DI	CALL	DBOXCOPYFF	; demande confirmation ...	JUMP,NE 90$	COMP.W	D3,#F1		; (COPIE) ?	JUMP,NE 90$		; non => 90$	CALL	WAITDBOX	; ouvre la dbox d'attente	JUMP,NE 90$	LOAD.L	A3,A1		; A3 <-- ^nom unit source	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier .DI source	JUMP,NE 90$	LOAD.L	A3,A2		; A3 <-- ^nom unit destination	CALL	FWOPEN		; ouvre l'unit destination	JUMP,NE 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; D4 <-- taille du fichier [bytes]	PUSH.L	D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	POP.L	D3		; D3 <-- taille du fichier [bytes]	DIV.WU	D3,#256		; D3 <-- taille du fichier [blocs]	AND.L	D3,#H'FFFF	CALL	FWNBBLK		; D4 <-- nb de blocs destination	JUMP,NE 90$	LOAD.W	D7,#ERTYPC	; D7 <-- copie impossible	COMP.L	D3,D4		; mme nb de blocs ?	JUMP,NE 90$		; non => 90$	CLR.W	D3		; D3 <-- mode sans formatage	TEST.B	(A6)+OCPFFF+3:#0	JUMP',BC 20$	LOAD.W	D3,#'F		; D3 <-- mode avec formatage	LOAD.L	A3,#R16"TXFORM	CALL	AFFTDBOX	; affiche texte dans la dbox d'attente20$:	CALL	FWFORMAT	; formate l'unit destination	JUMP,NE 90$	LOAD.L	A3,#R16"TYFORM	CALL	AFFTDBOX	; efface texte dans la dbox d'attente	CALL	FMOPEN		; A5/D5 <-- ^buffer/nb blocs	JUMP,NE 90$	LOAD.L	D0,#-16		; D0 <-- premier bloc	LOAD.L	D1,D4		; D1 <-- nombre de blocs	COMP.L	D5,D1		; buffer plus grand qu'un floppy ?	JUMP',LS 40$		; non => 40$	LOAD.L	D5,D1		; oui => limite !!40$:	CALL	AFFNDBOX	; affiche nb blocs dans la dbox d'attente	LOAD.B	D3,#'L	CALL	AFFCDBOX	; affiche "L" dans l'ascenseur	LOAD.L	A4,A5		; A4 <-- ^buffer	LOAD.L	D4,D5		; D4 <-- nb de blocs	MUL.WU	D4,#256		; D4 <-- nb de bytes	FOS	?RDBYTE		; lit une tranche sur la source	JUMP,NE 90$	LOAD.B	D3,#'E	CALL	AFFCDBOX	; affiche "E" dans l'ascenseur	LOAD.L	D4,D0		; D4 <-- premier bloc	LOAD.L	A3,A2		; A3 <-- ^nom unit destination	CALL	FWDATA		; crit une tranche sur la destination	JUMP',NE 90$	TEST.L	D1		; reste qq chose ?	JUMP',EQ 70$		; non => 70$	ADD.L	D0,D5		; D0 <-- no bloc next tranche	SUB.L	D1,D5		; D1 <-- nb restant	COMP.L	D1,D5	JUMP,HS 40$	LOAD.L	D5,D1		; D5 <-- lg dernire tranche	JUMP',EQ 70$	CLR.L	D1		; D1 <-- restera plus rien	JUMP	40$70$:	LOAD.W	D3,#BIPDONE	LIB	?BEEP		; p'tite musique	CLR.W	D7		; D7 <-- parfait90$:	PUSH.W	D7	TEST.W	D6	JUMP',EQ 92$	FOS	?CLOSE		; ferme le fichier .DI92$:	CALL	NORMDBOX	; ferme la dbox d'attente	POP.W	D7	POPM.L	D0..D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; COPYFW  >;========/; Effectue une copie floppy --> winch.; in	A1.L	^nom unit source;	A2.L	^nom unit destination; out	D7.W	erreur;	A3.L	^nom du fichier ayant caus l'erreur; mod	D7.W, A3.LCOPYFW:	PUSHM.L	D0..D6,A4	CLR.W	D6		; D6 <-- canal fichier .DI10$:	LOAD.L	A3,#(A6)+OCPNAM	CALL	DBOXSAUVE	; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP,NE 90$	LOAD.L	A2,A3		; A2 <-- ^nom du fichier destination .DI20$:	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A3,A2		; A3 <-- ^nom du fichier	LOAD.L	D3,#DEFATT	; D3 <-- attributs	LOAD.W	D4,#TYPRAND	; D4 <-- tpe	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier .DI	JUMP',EQ 25$	COMP.W	D7,#ERFAEX	JUMP,NE 90$	CALL	DBOXDELETE	; demande s'il faut supprimer ... ?	JUMP,NE 10$		; si rponse "non" => 10$	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; si rponse "oui" => dtruit-le	JUMP	20$25$:	CALL	DBOXCOPYFW	; demande confirmation ...	JUMP',NE 27$	COMP.W	D3,#F1		; (COPIE) ?	JUMP',EQ 30$27$:	PUSH.W	D7	FOS	?DELETE		; dtruit le fichier .DI juste cr	POP.W	D7	JUMP	90$30$:	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier .DI destination	JUMP,NE 90$	LOAD.L	A3,A1		; A3 <-- ^nom unit source	CALL	FROPEN		; ouvre l'unit source	JUMP,NE 90$	CALL	FRNBBLK		; D4 <-- nb de blocs source	JUMP,NE 90$	CALL	WAITDBOX	; ouvre la dbox d'attente	JUMP,NE 90$	CALL	FMOPEN		; A5/D5 <-- ^buffer/nb blocs	JUMP,NE 90$	LOAD.L	D0,#-16		; D0 <-- premier bloc	LOAD.L	D1,D4		; D1 <-- nombre de blocs	COMP.L	D5,D1		; buffer plus grand qu'un floppy ?	JUMP',LS 40$		; non => 40$	LOAD.L	D5,D1		; oui => limite !!40$:	CALL	AFFNDBOX	; affiche nb blocs dans la dbox d'attente	LOAD.B	D3,#'L	CALL	AFFCDBOX	; affiche "L" dans l'ascenseur	LOAD.L	A4,A5		; A4 <-- ^buffer	LOAD.L	D4,D0		; D4 <-- premier bloc	LOAD.L	A3,A1		; A3 <-- ^nom unit source	CALL	FRDATA		; lit une tranche sur la source	JUMP',NE 90$	LOAD.B	D3,#'E	CALL	AFFCDBOX	; affiche "E" dans l'ascenseur	LOAD.L	D4,D5		; D4 <-- nb de blocs	MUL.WU	D4,#256		; D4 <-- nb de bytes	FOS	?WRBYTE		; crit une tranche sur la destination	JUMP,NE 90$	TEST.L	D1		; reste qq chose ?	JUMP',EQ 70$		; non => 70$	ADD.L	D0,D5		; D0 <-- no bloc next tranche	SUB.L	D1,D5		; D1 <-- nb restant	COMP.L	D1,D5	JUMP,HS 40$	LOAD.L	D5,D1		; D5 <-- lg dernire tranche	JUMP',EQ 70$	CLR.L	D1		; D1 <-- restera plus rien	JUMP	40$70$:	LOAD.W	D3,#BIPDONE	LIB	?BEEP		; p'tite musique	CLR.W	D7		; D7 <-- parfait90$:	PUSH.W	D7	TEST.W	D6	JUMP',EQ 92$	FOS	?CLOSE		; ferme le fichier .DI92$:	CALL	NORMDBOX	; ferme la dbox d'attente	POP.W	D7	POPM.L	D0..D6,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; IFTYPFLO >;=========/; Regarde si une unit est de type "floppy".; in	A3.L	^nom d'unit; out	D7.W	EQ si $FLO_*; mod	D7.WIFTYPFLO:	PUSHM.L	D3,D4,A2..A4	CLR.W	D3		; D3 <-- global	FOS	?VASSIGN	; A4 <-- ^nom physique	JUMP',NE 90$	LOAD.L	A3,#R16"01$	; A3 <-- ^chane avec "*"	LOAD.L	A2,#R16"02$	; A2 <-- ^terminateurs <-1>	LIB	?CPSTRING	; est un floppy ?	JUMP',NC 80$		; oui => 80$70$:				; non =>	LOAD.W	D7,#1		; D7 <-- c'est autre chose	JUMP'	90$80$:	CLR.W	D7		; D7 <-- c'est un floppy90$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	"$FLO_*"02$:	.B	0,CR,SPACE,-1	.EVEN;----------\\; FMOPENALL >;==========/; Ouvre le grand buffer mmoire pour la copie.; Prend le plus de mmoire possible, tout en conservant; 20 Kbytes pour sauver le fond des dbox, etc. !!!; in	-; out	A5.L	^grand buffer;	D5.L	nb de blocs;	D7.W	erreur; mod	D5.L, D7.W, A5.LFMOPENALL:	PUSHM.L	D1,D3,D4,A3,A4	LOAD.W	D1,#MTYPCP	LOAD.L	D4,#20000	GESMEM	?GETMEM		; rserve 20 Kbytes !	JUMP,NE 90$	LOAD.L	A3,A4		; A3 <-- ^rserve	LOAD.W	D3,#16		; D3 <-- le tout (!)	LOAD.L	D4,#256*500	; D4 <-- mimimum (assez grand)	LOAD.L	D5,#256*5000	; D5 <-- maximum (trs grand)	GESMEM	?GETPMEM	; demande trs grand buffer	JUMP',NE 90$	LOAD.L	A5,A4		; A5 <-- ^buffer	LOAD.L	D5,D4	DIV.WU	D5,#256		; D5 <-- nb de blocs	AND.L	D5,#H'FFFF	LOAD.L	A4,A3		; A4 <-- ^rserve	GESMEM	?GIVMEM		; rend la rserve	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; FMOPEN  >;========/; Ouvre le grand buffer mmoire pour la copie.; Prend beaucoup de mmoire, mais sans exagration !; in	-; out	A5.L	^grand buffer;	D5.L	nb de blocs;	D7.W	erreur; mod	D5.L, D7.W, A5.LFMOPEN:	PUSHM.L	D1,D3,D4,A4	LOAD.W	D3,#16/2	; D3 <-- la moiti	LOAD.L	D4,#256*32	; D4 <-- mimimum	LOAD.L	D5,#256*256	; D5 <-- maximum	LOAD.W	D1,#MTYPCP	GESMEM	?GETPMEM	; demande trs grand buffer	JUMP',NE 90$	LOAD.L	A5,A4		; A5 <-- ^buffer	LOAD.L	D5,D4	DIV.WU	D5,#256		; D5 <-- nb de blocs	AND.L	D5,#H'FFFF90$:	POPM.L	D1,D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; FMCLOSE >;========/; Ferme le grand buffer mmoire pour la copie.; in	A5.L	^grand buffer; out	-; mod	D7.WFMCLOSE:	PUSHM.L	D1,A4	COMP.L	A5,#0	JUMP',EQ 90$	LOAD.L	A4,A5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le trs grand buffer90$:	POPM.L	D1,A4	RET;--------\; FROPEN  >;========/; Ouvre le driver floppy en lecture.; in	A3.L	^nom de l'unit; out	D7.W	erreur; mod	D7.WFROPEN:	PUSHM.L	D0,D3,D6	LOAD.L	D3,#2^BEAUTOM	; D3 <-- signal BAL comme enter automatique	FOS	?LRELEASE	; tente un release de l'unit	LOAD.W	(A6)+OCPERR,D7	; mm. si release ok	LOAD.L	D3,#2^BOPEXTEND!2^BOPMMUNIT!2^BOPRD!2^BOPWR!2^BOPEXWR	LOAD.L	D0,#FOS?ARGSOPEN	CALL	ERCALL	JUMP',NE 90$	LOAD.W	(A6)+OCPCHR,D690$:	POPM.L	D0,D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\; FWOPEN  >;========/; Ouvre le driver floppy en criture.; in	A3.L	^nom de l'unit; out	D7.W	erreur; mod	D7.WFWOPEN:	PUSHM.L	D0,D3,D6	LOAD.L	D3,#2^BOPEXTEND!2^BOPMMUNIT!2^BOPRD!2^BOPWR!2^BOPEXWR	LOAD.L	D0,#FOS?ARGSOPEN	CALL	ERCALL	JUMP',NE 90$	LOAD.W	(A6)+OCPCHW,D690$:	POPM.L	D0,D3,D6	TEST.W	D7		; retour EQ/NE	RET;---------\; FWFORMAT >;=========/; Formate le driver floppy en criture.; in	D3.W	mode (F=formate); out	D7.W	erreur; mod	D7.WFWFORMAT:	PUSHM.L	D4,D6,A3,A4	LOAD.W	D6,(A6)+OCPCHW	COMP.W	D3,#'F	JUMP',NE 50$	NTREL	?GETMACHINE	RL.L	D4,#8		; D4 <-- type de la machine	COMP.B	D4,#SMAKY8	; est-on sur Smaky 8 ?	JUMP',EQ 50$		; oui => 50$ (formatage pralable inutile)				; non =>	LOAD.L	A4,#R16"COMFOF	LOAD.W	D3,#TYPMM	; D3 <-- type mmoire de masse	FOS	?COMMAND	; formate la disquette	JUMP',NE 90$50$:	LOAD.L	A4,#R16"COMFOW	LOAD.W	D3,#TYPMM	; D3 <-- type mmoire de masse	FOS	?COMMAND	; envoie commande(s)90$:	POPM.L	D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; FRNBBLK >;========/; Donne le nombre de blocs d'un floppy.; in	D6.W	canal du driver; out	D4.L	nb de blocs;	D7.W	erreur; mod	D4.L, D7.WFRNBBLK:	PUSHM.L	D3,D6,A4	LOAD.W	D6,(A6)+OCPCHR	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D4,#LGMAM0	LOAD.W	D3,#TYPMM	FOS	?RSTATUS	JUMP',NE 90$	LOAD.W	D7,#ERUTYP	; D7 <-- "type unit incorrect"	COMP.B	(A4)+OMTYPE,#MTFLO ; type floppy-disque ?	JUMP',NE 90$		; non => 90$	LOAD.L	D4,(A4)+OMNBLK	; D4 <-- nb de blocs	ADD.L	D4,#16		; compte la premire piste !	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; FWNBBLK >;========/; Donne le nombre de blocs d'un floppy.; in	D6.W	canal du driver; out	D4.L	nb de blocs;	D7.W	erreur; mod	D4.L, D7.WFWNBBLK:	PUSHM.L	D3,D6,A4	LOAD.W	D6,(A6)+OCPCHW	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D4,#LGMAM0	LOAD.W	D3,#TYPMM	FOS	?RSTATUS	JUMP',NE 90$	LOAD.W	D7,#ERUTYP	; D7 <-- "type unit incorrect"	COMP.B	(A4)+OMTYPE,#MTFLO ; type floppy-disque ?	JUMP',NE 90$		; non => 90$	LOAD.L	D4,(A4)+OMNBLK	; D4 <-- nb de blocs	ADD.L	D4,#16		; compte la premire piste !	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; FRDATA  >;========/; Lit une tranche de blocs.; in	D4.L	premier bloc;	D5.L	nb de blocs;	A4.L	^buffer;	A3.L	^nom de l'unit; out	D7.W	erreur; mod	D7.WFRDATA:	PUSHM.L	D2..D4,D6,A4	LOAD.W	D6,(A6)+OCPCHR	LOAD.L	D2,D4		; D2 <-- premier bloc	LOAD.L	D3,D4	RL.L	D3,#8	SL.L	D4,#8	FOS	?SPOS	JUMP',NE 90$	LOAD.L	D4,D5	SL.L	D4,#8	FOS	?RDBYTE	JUMP',NE 90$	TEST.L	D2		; est-ce que la tranche contient le bloc zro ?	JUMP',GT 90$		; non => 90$	LOAD.L	D3,D2	ADD.L	D3,D5	JUMP',LE 90$	NEG.L	D2	SL.L	D2,#8	ADD.L	A4,D2		; A4 <-- ^bloc zro	FOS	?INFODISK	; relit spcialement le bloc zro	JUMP',NE 90$	CLR.B	(A4)+OBK0CHANGE	; pas de RECUP lors 1re utilisation !90$:	POPM.L	D2..D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; FWDATA  >;========/; Ecrit une tranche de blocs.; in	D4.L	premier bloc;	D5.L	nb de blocs;	A4.L	^buffer;	A3.L	^nom de l'unit; out	D7.W	erreur; mod	D7.WFWDATA:	PUSHM.L	D3,D4,D6,A3	LOAD.W	D6,(A6)+OCPCHW	LOAD.L	D3,D4		; est-ce que la tranche contient le bloc zro ?	JUMP',GT 30$		; non => 30$	ADD.L	D3,D5	JUMP',LE 30$	LOAD.L	D3,D4	NEG.L	D3	SL.L	D3,#8	LOAD.L	A3,#(A4)+(D3.L)	; A3 <-- ^bloc zro	LOAD.B	(A3)+OBK0CHANGE,#-1 ; force un RECUP lors 1re utilisation !30$:	LOAD.L	D3,D4	RL.L	D3,#8	SL.L	D4,#8	FOS	?SPOS	JUMP',NE 90$	LOAD.L	D4,D5	SL.L	D4,#8	FOS	?WRBYTE90$:	POPM.L	D3,D4,D6,A3	TEST.W	D7		; retour EQ/NE	RET;--------\; FRCLOSE >;========/; Ferme le driver floppy en lecture.; in	A3.L	^nom de l'unit; out	D7.W	erreur; mod	D7.WFRCLOSE:	PUSHM.L	D3,D6,A4	CLR.W	D7		; D7 <-- ok	LOAD.W	D6,(A6)+OCPCHR	JUMP',EQ 50$	LOAD.L	A4,#R16"COMFCW	LOAD.W	D3,#TYPMM	; D3 <-- type mmoire de masse	FOS	?COMMAND	; envoie commande(s)	FOS	?CLOSE		; ferme	CLR.W	(A6)+OCPCHR50$:	TEST.W	(A6)+OCPERR	; release ok ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	D3,#2^BEAUTOM	; D3 <-- signal BAL comme enter automatique	FOS	?NENTER		; refait un ENTER90$:	POPM.L	D3,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\; FWCLOSE >;========/; Ferme le driver floppy en criture.; in	-; out	D7.W	erreur; mod	D7.WFWCLOSE:	PUSHM.L	D3,D6,A4	CLR.W	D7		; D7 <-- ok	LOAD.W	D6,(A6)+OCPCHW	JUMP',EQ 90$	LOAD.L	A4,#R16"COMFCW	LOAD.W	D3,#TYPMM	; D3 <-- type mmoire de masse	FOS	?COMMAND	; envoie commande(s)	FOS	?CLOSE		; ferme	CLR.W	(A6)+OCPCHW90$:	POPM.L	D3,D6,A4	TEST.W	D7		; retour EQ/NE	RET; Textes; ------; 'F		formatage; 'N!2^7	pas de vrif avant criture; 'V!2^7	lect de vrif avant critureCOMFOF:	.B	'F,0		; commande formatCOMFOW:	.B	'N!2^7,0	; commande open-writeCOMFCW:	.B	'V!2^7,0	; commande close-writeTXFORM:	.ASCIZ	"        Formatage physique ..."TYFORM:	.ASCIZ	""TXDI:	.ASCIZ	".DI"		; extension	.EVEN	.END