	.SBTTL	STARTIO;--------\\; RDUSER  >;========/; Lit le fichier START_USER.INFO; in	-; out	D7.W	erreur; mod	D7.WRDUSER:	PUSHM.L	D1,D3,D4,D6,A3,A4	CALL	WAITMOUSE	; souris: met le sablier	TEST.L	(A6)+OPUSER	; START_USER.INFO dj lu ?	JUMP',EQ 20$		; non => 20$	LOAD.L	A4,(A6)+OPUSER	; oui =>	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OPUSER20$:	LOAD.L	A3,#R16"NFUSER	LOAD.W	D3,#2^BOPRD!2^BOPSYS	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	POPM.L	D0	JUMP,NE 90$	LOAD.W	D3,#-1	LOAD.L	D4,#-1	FOS	?SPOS		; va tout  la fin	LOAD.L	D1,D4		; D1 <-- longueur du fichier	CLR.W	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP,NE 85$	LOAD.L	D4,D1	INC.L	D4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; rserve de la mmoire	JUMP',NE 85$	LOAD.L	(A6)+OPUSER,A4	DEC.L	D4	FOS	?RDBYTE		; lit le fichier	JUMP',NE 80$	CLR.B	(A4)+(D4.L)	; termine le fichier par <0>	FOS	?CLOSE		; ferme le fichier	JUMP',EQ 90$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OPUSER	POP.W	D785$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D790$:	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDINFO  >;========/; Lit le fichier START.INFO; in	-; out	D7.W	erreur; mod	D7.WRDINFO:	PUSHM.L	D1,D3,D4,D6,A3,A4	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#R16"01$	LOAD.L	A4,#(A6)+OMALIST	LOAD.W	D4,#(4*MAXMA)-110$:	LOAD.B	(A4+),(A3+)	; OMALIST <-- noms par dfaut	DECJ.W,NMO D4,10$	LOAD.L	A3,#R16"NFINFO	LOAD.L	D3,#DEFATT	TCLR.L	D3:#BATTC	TCLR.L	D3:#BATTX	TCLR.L	D3:#BATTL	TCLR.L	D3:#BATTW	FOS	?CHATR		; empche la modification de START.INFO !	LOAD.W	D3,#2^BOPRD!2^BOPSYS	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	POPM.L	D0	JUMP,NE 90$	LOAD.W	D3,#-1	LOAD.L	D4,#-1	FOS	?SPOS		; va tout  la fin	LOAD.L	D1,D4		; D1 <-- longueur du fichier	CLR.W	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP',NE 40$	LOAD.L	D4,D1	INC.L	D4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; rserve de la mmoire	JUMP',NE 40$	LOAD.L	(A6)+OPINFO,A4	DEC.L	D4	FOS	?RDBYTE		; lit le fichier	JUMP',NE 40$	CLR.B	(A4)+(D4.L)	; termine le fichier par <0>40$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7	JUMP,NE 90$; Cherche tous les noms de machines donns.	LOAD.L	A4,(A6)+OPINFO	; A4 <-- ^contenu de START.INFO	LOAD.L	A3,#R16"02$	CALL	SRCPSEUDO	; A4 <-- ^pseudo .MACHINE trouve	JUMP',NE 80$	LOAD.L	A3,A4	LOAD.L	A4,#(A6)+OMALIST	LOAD.W	D4,#MAXMA-150$:	CLR.L	(A4+)		; OMALIST <-- efface tout	DECJ.W,NMO D4,50$	LOAD.L	A4,#(A6)+OMALIST	LOAD.W	D4,#MAXMA-160$:	LIB	?SKPNAM		; A3 <-- ^nom d'imprimante trouve	JUMP',NE 80$	LOAD.B	(A4+),(A3)+0	LOAD.B	(A4+),(A3)+1	LOAD.B	(A4+),(A3)+2	; OMALIST <-- un nom de machine	CLR.B	(A4+)	DECJ.W,NMO D4,60$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	"SYS"	.ASCIZ	"100"	.ASCIZ	"324"	.ASCIZ	"32P"	.B	0,0,0,0	.B	0,0,0,0	.B	0,0,0,0	.B	0,0,0,0	.B	0,0,0,0	.B	0,0,0,002$:	.ASCIZ	".MACHINE"	.EVEN;----------\\; SRCPSEUDO >;==========/; Cherche une pseudo-instruction dans les informations.; in	A3.L	^pseudo-instruction cherche;	A4.L	^premire ligne o chercher; out	A4.L	^dbut ligne;	D7.W	erreur; mod	D7.W, A4.LSRCPSEUDO:	PUSHM.L	D3,A2,A3	LOAD.L	A2,#R16"00$10$:	COMP.B	(A4),#'.	; pseudo au dbut de la ligne ?	JUMP',NE 60$		; non => 60$				; oui =>	LIB	?CPSTRING	; pseudo trouve ?	JUMP',NS 60$		; non => 60$				; oui =>	CLR.W	D7		; D7 <-- ok	JUMP'	90$60$:	LOAD.B	D3,(A4)	JUMP',EQ 80$	INC.L	A4		; A4 <-- ^ligne suivante	COMP.B	D3,#CR	JUMP,NE 60$	JUMP	10$80$:	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POPM.L	D3,A2,A3	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0,CR,SPACE,TAB,-1	.EVEN;---------\\; SKIPINFO >;=========/; Saute les pseudo-instructions (.MACHINE et .PRINTEXT) au dbut; d'un fichier .INFO; in	A4.L	^o chercher; out	A4.L	^aprs les pseudo-instructions; mod	D7.W, A4.LSKIPINFO:	PUSH.L	D3	LOAD.L	D3,A4		; ^nil ?	JUMP,EQ 90$		; oui => 90$10$:	LOAD.B	D3,(A4)	JUMP,EQ 90$	COMP.B	D3,#CR	JUMP',EQ 20$	COMP.B	D3,#'.		; pseudo en dbut de ligne ?	JUMP,NE 90$		; non => 90$20$:				; oui =>	LOAD.B	D3,(A4)	JUMP,EQ 90$	INC.L	A4		; A4 <-- ^ligne suivante	COMP.B	D3,#CR	JUMP,NE 20$	JUMP	10$90$:	POP.L	D3	RET;---------\\; SRCFINFO >;=========/; Cherche un nom de programme dans les informations.; in	A3.L	^programme cherch;	A4.L	^premire ligne o chercher; out	A4.L	^dbut ligne;	D7.W	erreur; mod	D7.W, A4.LSRCFINFO:	PUSHM.L	D3,D4,A1	LOAD.L	D3,A4		; ^nil ?	JUMP,EQ 80$		; oui => 80$	LOAD.L	A1,A420$:	CALL	SRC1INFO	; mot trouv ?	JUMP',EQ 50$		; oui => 50$25$:	TEST.B	(A4)		; encore qq chose ?	JUMP',EQ 80$		; non => 80$	CALL	SRC2INFO	; A4 <-- ^mot suivant	JUMP	20$50$:	COMP.L	A4,A1	JUMP',EQ 52$	COMP.B	(-A4),#CR	; A4 <-- revient au dbut de la ligne	JUMP,NE 50$	INC.L	A452$:	CLR.W	D7		; D7 <-- trouv	JUMP'	90$80$:	LOAD.W	D7,#ERSYNT	; D7 <-- pas trouv90$:	POPM.L	D3,D4,A1	TEST.W	D7		; retour EQ/NE	RET;---------\\; SRCEINFO >;=========/; Cherche une extension dans les informations.; in	A3.L	^extension cherche;	A4.L	^premire ligne o chercher; out	A4.L	^dbut ligne;	D7.W	erreur; mod	D7.W, A4.LSRCEINFO:	PUSHM.L	D3,D4,A1	LOAD.L	D3,A4		; ^nil ?	JUMP,EQ 80$		; oui => 80$	LOAD.L	A1,A4	CLR.W	D4		; D4 <-- rang dans la ligne20$:	CALL	SRC1INFO	; mot trouv ?	JUMP',EQ 40$		; oui => 40$25$:	TEST.B	(A4)		; encore qq chose ?	JUMP',EQ 80$		; non => 80$	CALL	SRC2INFO	; A4 <-- ^mot suivant	JUMP	20$40$:	COMP.W	D4,#1		; premier mot de la ligne ?	JUMP,LS 25$		; oui => 25$50$:	COMP.L	A4,A1	JUMP',EQ 52$	COMP.B	(-A4),#CR	; A4 <-- revient au dbut de la ligne	JUMP,NE 50$	INC.L	A452$:	CLR.W	D7		; D7 <-- trouv	JUMP'	90$80$:	LOAD.W	D7,#ERSYNT	; D7 <-- pas trouv90$:	POPM.L	D3,D4,A1	TEST.W	D7		; retour EQ/NE	RET;---------\\; SRC1INFO >;---------/; Cherche si on a trouv un nom dans les informations.; in	A3.L	^nom cherch;	A4.L	^o chercher; out	D7.W	ok/erreur; mod	D7.WSRC1INFO:	PUSHM.L	D3,A3,A4	LOAD.W	D7,#ERSYNT	; D7 <-- pas trouv20$:	COMP.B	(A4),#'"	JUMP',NE 21$	INC.L	A4		; A4 <-- saute le guillemet21$:	COMP.B	(A3),#'!	JUMP',NE 25$	COMP.B	(A4),#'!	JUMP,EQ 80$25$:	COMP.B	(A4),#'.	JUMP',NE 30$	INC.L	A4		; A4 <-- saute le "."30$:	LOAD.B	D3,(A3+)	JUMP',EQ 50$	COMP.B	D3,#CR	JUMP',EQ 50$	COMP.B	D3,#SPACE	JUMP',EQ 50$	COMP.B	D3,#'.	JUMP',EQ 50$	COMP.B	D3,(A4+)	JUMP,EQ 30$	JUMP'	90$50$:	LOAD.B	D3,(A4)	JUMP',EQ 80$	COMP.B	D3,#CR	JUMP',EQ 80$	COMP.B	D3,#SPACE	JUMP',EQ 80$	COMP.B	D3,#TAB	JUMP',EQ 80$	COMP.B	D3,#'/	JUMP',EQ 80$	COMP.B	D3,#'"	JUMP',NE 90$80$:	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; SRC2INFO >;---------/; Cherche le nom suivant dans les informations.; in	A4.L	^o chercher;	D4.W	rang dans la ligne; out	A4.L	^o chercher le suivant;	D4.L	rang suivant dans la ligne; mod	D4.L, D7.W, A4.LSRC2INFO:	PUSH.W	D3	INC.W	D4		; D4 <-- rang suivant	COMP.B	(A4),#'"	JUMP',NE 40$	INC.L	A4		; A4 <-- saute le premier guillemet20$:				; texte entre guillemets =>	LOAD.B	D3,(A4)	JUMP,EQ 90$	INC.L	A4	COMP.B	D3,#'"	JUMP',EQ 24$	COMP.B	D3,#CR	JUMP,NE 20$23$:	CLR.W	D4		; D4 <-- dbut d'une nouvelle ligne	JUMP'	25$24$:	LOAD.B	D3,(A4)	COMP.B	D3,#'/	JUMP',NE 25$	ADD.L	A4,#2	JUMP	24$25$:	LOAD.B	D3,(A4)	JUMP,EQ 90$	INC.L	A4	COMP.B	D3,#SPACE	JUMP,EQ 25$	COMP.B	D3,#TAB	JUMP,EQ 25$	COMP.B	D3,#CR	JUMP,EQ 23$	DEC.L	A4	JUMP	90$40$:				; pas de guillemet =>	LOAD.B	D3,(A4)	JUMP',EQ 90$	INC.L	A4	COMP.B	D3,#SPACE	JUMP',EQ 44$	COMP.B	D3,#TAB	JUMP',EQ 44$	COMP.B	D3,#CR	JUMP,NE 40$43$:	CLR.W	D4		; D4 <-- dbut d'une nouvelle ligne44$:	LOAD.B	D3,(A4)	JUMP',EQ 90$	INC.L	A4	COMP.B	D3,#SPACE	JUMP,EQ 44$	COMP.B	D3,#TAB	JUMP,EQ 44$	COMP.B	D3,#CR	JUMP,EQ 43$	DEC.L	A490$:	POP.W	D3	RET;---------\\; NEXTINFO >;=========/; Cherche la ligne suivante dans START.INFO; in	A4.L	^ligne dans START.INFO; out	A4.L	^ligne suivante; mod	A4.LNEXTINFO:	PUSH.W	D310$:	LOAD.B	D3,(A4)	JUMP',EQ 90$	INC.L	A4	COMP.B	D3,#CR	JUMP,NE 10$90$:	POP.W	D3	RET;----------\\; RDDIRINFO >;==========/; Lit l'ventuel fichier START_DIR.INFO associ  une unit ou  un dossier.; in	A5.L	^description de l'unit; out	-; mod	D7.WRDDIRINFO:	PUSHM.L	D3,D4,D6,A3,A4	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,#(A5)+OUNNAM10$:	LOAD.B	(A3+),(A4+)	; OBUFIT <-- unit:rep:rep:*	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBUFIT	CALL	SKIPREP	LOAD.L	A4,#R16"NDINFO15$:	LOAD.B	(A3+),(A4+)	; OBUFIT <-- unit:rep:rep:START_DIR.INFO	JUMP,NE 15$	LOAD.L	A3,#(A6)+OBUFIT	LOAD.W	D3,#2^BOPRD	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	POPM.L	D0	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUDIN	LOAD.L	D4,#LDI	FOS	?RDBYTE		; lit le fichier	JUMP,NE 80$	COMP.B	(A4)+ODIIDE,#H'80	JUMP',NE 50$				; nouveau fichier =>	LOAD.L	(A5)+OUNFALI,(A4)+ODIFA ; OUNFALI <-- fanions du fichier	LOAD.L	A4,#(A4)+ODINAM	LOAD.L	A3,#(A5)+OUNNAM	CALL	SKIPREP35$:	LOAD.B	(A3+),(A4+)	; OUNNAM <-- critre du fichier	JUMP,NE 35$	JUMP	70$50$:				; ancien fichier =>	LOAD.L	(A5)+OUNFALI,(A4)+OODIFA ; OUNFALI <-- fanions du fichier	LOAD.L	A4,#(A4)+OODINAM	LOAD.L	A3,#(A5)+OUNNAM	CALL	SKIPREP55$:	LOAD.B	(A3+),(A4+)	; OUNNAM <-- critre du fichier	JUMP,NE 55$70$:	CALL	DIMICO		; recalcul les dimensions d'une icne80$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D790$:	POPM.L	D3,D4,D6,A3,A4	RET;----------\\; WRDIRINFO >;==========/; Ecrit le fichier START_DIR.INFO associ  une unit ou  un dossier.; in	A5.L	^description de l'unit; out	A3.L	^fichier ayant caus l'erreur;	D7.W	erreur; mod	D7.W, A3.LWRDIRINFO:	PUSHM.L	D3,D4,D6,A4	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,#(A5)+OUNNAM10$:	LOAD.B	(A3+),(A4+)	; OBUFIT <-- unit:rep:rep:*	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBUFIT	CALL	SKIPREP	LOAD.L	A4,#R16"NDINFO15$:	LOAD.B	(A3+),(A4+)	; OBUFIT <-- unit:rep:rep:START_DIR.INFO	JUMP,NE 15$	LOAD.L	A3,#(A6)+OBUFIT	PUSH.L	D0	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	POPM.L	D0	LOAD.L	D3,#DEFATT	; D3 <-- attributs standards	TCLR.L	D3:#BATTL	; D3 <-- enlve l'attribut "L"	LOAD.W	D4,#TYPRAND	PUSH.L	D0	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	POPM.L	D0	JUMP,NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	POPM.L	D0	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUDIN+LDI	LOAD.W	D4,#LDI-120$:	CLR.B	(-A4)		; met tout  zro	DECJ.W,NMO D4,20$	LOAD.B	(A4)+ODIIDE,#H'80 ; ODIIDE <-- identificateur (nouveau)	LOAD.L	(A4)+ODIFA,(A5)+OUNFALI ; ODIFA <-- fanions	PUSH.L	A3	LOAD.L	A4,#(A4)+ODINAM	LOAD.L	A3,#(A5)+OUNNAM	CALL	SKIPREP30$:	LOAD.B	(A4+),(A3+)	; ODINAM <-- critre	JUMP,NE 30$	POP.L	A3	LOAD.L	A4,#(A6)+OBUDIN	LOAD.L	D4,#LDI	FOS	?WRBYTE		; crit le fichier	JUMP',NE 80$	FOS	?CLOSE		; ferme le fichier	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D790$:	POPM.L	D3,D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDLIST  >;========/; Lit sur disque tous les noms de fichiers.; in	A5.L	^description de l'unit; out	D7.W	erreur; mod	D7.WRDLIST:	PUSHM.L	D0..D6,A2..A4	CALL	WAITMOUSE	; souris: met le sablier; Libre l'ancienne mmoire utilise si ce n'est pas dj fait.	TEST.L	(A5)+OUNPLI	JUMP',EQ 10$	LOAD.L	A4,(A5)+OUNPLI	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la liste	CLR.L	(A5)+OUNPLI10$:	TEST.L	(A5)+OUNPIN	JUMP',EQ 12$	LOAD.L	A4,(A5)+OUNPIN	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'index	CLR.L	(A5)+OUNPIN12$:	LOAD.L	A3,#(A5)+OUNNAM	; A3 <-- ^nom	COMP.W	(A3),#H'100*'$	JUMP,EQ 50$; Liste tous les noms de fichiers de l'unit ou du rpertoire.	LOAD.L	A4,#(A5)+OUNNAM	; A4 <-- ^unit:rep:rep:critre	LOAD.L	A3,#(A6)+OBUFIT16$:	LOAD.B	(A3+),(A4+)	; OBUFIT <-- unit:rep:rep:critre	JUMP,NE 16$	LOAD.L	A3,#(A6)+OBUFIT	CALL	SKIPREP	CLR.B	(A3+)		; OBUFIT <-- unit:rep:rep:	LOAD.L	A4,A3	LOAD.B	(A3+),#'*	; OBUFIT <-- critre "*"	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	D3,#2^BOPEXTEND!2^BOPIDENT ; D3 <-- mode d'ouverture	FOS	?LISTOPEN	; D4 <-- nb fichiers, D6 <-- canal	JUMP,NE 90$	LOAD.L	(A5)+OUNIDE,D5	ADD.W	D4,#100		; D4 <-- rserve pour 100 nouveaux fichiers	LOAD.W	(A5)+OUNNBM,D4	MUL.WU	D4,#LFL		; D4 <-- taille mmoire ncessaire	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire dfinitive pour liste	JUMP',NE 40$	LOAD.L	(A5)+OUNPLI,A4	CALL	CLRMEM		; efface tout	LOAD.L	A2,A4		; A2 <-- ^buffer pour liste des noms	CLR.W	(A5)+OUNNBT	CLR.W	(A5)+OUNNBL20$:	FOS	?LISTNXT	; A3 <-- ^nom et A4 <-- ^arguments	JUMP',NE 40$		; y'en a plus => 40$	CALL	IFSYSTEM	; fichier du genre SYS_LIST ?	JUMP,EQ 20$		; oui => 20$				; non =>	CALL	PUTFILIST	; liste <-- nom et arguments	INC.W	(A5)+OUNNBT	LOAD.L	A2,#(A2)+LFL	; A2 <-- ^suivant	JUMP	20$40$:	PUSH.W	D7	FOS	?LISTCLOSE	; ferme le canal de liste	POP.W	D7	COMP.W	D7,#EROUTF	; fin normale ?	JUMP,NE 90$		; non => 90$	JUMP'	80$		; oui => 80$; Liste tous les noms d'units physiques de type mmoire de masse.50$:	LOAD.L	D4,#LFL*MAXUPH	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour liste	JUMP,NE 90$	LOAD.L	(A5)+OUNPLI,A4	CALL	CLRMEM		; efface tout	LOAD.L	A2,A4		; A2 <-- ^buffer pour liste des noms	LOAD.W	(A5)+OUNNBM,#MAXUPH	CLR.W	(A5)+OUNNBT	CLR.W	(A5)+OUNNBL;	LOAD.L	A3,#(A5)+OUNNAM	; A3 <-- ^nom "$"	LIST_	OPEN		; D6 <-- canal	JUMP',NE 80$54$:	LIST_	NEXT		; A3/A4 <-- ^nom/^arguments	JUMP',NE 56$	CALL	PUTMMLIST	; liste <-- nom et arguments	LOAD.L	A2,#(A2)+LFL	; A2 <-- ^suivant	INC.W	(A5)+OUNNBT	COMP.W	(A5)+OUNNBT,#MAXUPH-1	JUMP,LO	54$56$:	LIST_	CLOSE		; ferme la liste80$:	CLR.L	D4	LOAD.W	D4,(A5)+OUNNBM	SL.L	D4,#1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour index	JUMP',NE 90$	LOAD.L	(A5)+OUNPIN,A4	CALL	CLRMEM		; efface tout	JUMP'	95$90$:	TEST.L	(A5)+OUNPLI	JUMP',EQ 95$	PUSH.W	D7	LOAD.L	A4,(A5)+OUNPLI	GESMEM	?GIVMEM		; rend la mmoire de la liste	CLR.L	(A5)+OUNPLI	POP.W	D795$:	POPM.L	D0..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; PUTFILIST >;----------/; Met dans la liste un nom de fichier avec ses arguments.; in	A2.L	^dans liste;	A3.L	^nom;	A4.L	^arguments; out	-; mod	D7.WPUTFILIST:	PUSHM.L	D3,A1,A3	LOAD.L	A1,#(A2)+OFLNAM	LOAD.W	D3,#(LGNAME/4)-105$:	CLR.L	(A1+)		; met tout  zro	DECJ.W,NMO D3,05$	LOAD.L	A1,#(A2)+OFLNAM10$:	LOAD.B	(A1+),(A3+)	; OFLNAM <-- nom	JUMP,NE	10$	LOAD.L	A3,#(A2)+OFLNAM	CALL	IFDIR		; fichier .DIR ?	JUMP',NE 25$		; non => 25$20$:				; oui =>	TEST.B	(A3+)	JUMP,NE 20$	LOAD.B	(A3)-5,#':	; transforme "rep.dir" en "rep:"	CLR.B	(A3)-4	CLR.B	(A3)-325$:	LOAD.L	(A2)+OFLLG,(A4)+OBALGF	LOAD.L	(A2)+OFLATT,(A4)+OBAATT	LOAD.B	(A2)+OFLCD+0,(A4)+OBACD+0	LOAD.B	(A2)+OFLCD+1,(A4)+OBACD+1	LOAD.B	(A2)+OFLCD+2,(A4)+OBACD+2	LOAD.B	(A2)+OFLCH+0,(A4)+OBACH+0	LOAD.B	(A2)+OFLCH+1,(A4)+OBACH+1	LOAD.B	(A2)+OFLCH+2,(A4)+OBACH+2	LOAD.B	(A2)+OFLWD+0,(A4)+OBAWD+0	LOAD.B	(A2)+OFLWD+1,(A4)+OBAWD+1	LOAD.B	(A2)+OFLWD+2,(A4)+OBAWD+2	LOAD.B	(A2)+OFLWH+0,(A4)+OBAWH+0	LOAD.B	(A2)+OFLWH+1,(A4)+OBAWH+1	LOAD.B	(A2)+OFLWH+2,(A4)+OBAWH+2	LOAD.B	(A2)+OFLRD+0,(A4)+OBARD+0	LOAD.B	(A2)+OFLRD+1,(A4)+OBARD+1	LOAD.B	(A2)+OFLRD+2,(A4)+OBARD+2	LOAD.B	(A2)+OFLRH+0,(A4)+OBARH+0	LOAD.B	(A2)+OFLRH+1,(A4)+OBARH+1	LOAD.B	(A2)+OFLRH+2,(A4)+OBARH+2	LOAD.B	(A2)+OFLOPE,(A4)+OBAOPE	LOAD.W	(A2)+OFLRAF,#-1	; signal icne  repeindre	POPM.L	D3,A1,A3	RET;----------\\; PUTMMLIST >;----------/; Met dans la liste un nom d'unit physique avec ses arguments.; in	A2.L	^dans liste;	A3.L	^nom;	A4.L	^arguments; out	-; mod	D7.WPUTMMLIST:	PUSHM.L	D2,A1..A3	LOAD.L	A1,#(A2)+OFLNAM10$:	LOAD.B	D3,(A3+)	JUMP',EQ 14$	COMP.B	D3,#'/	JUMP',NE 12$	CLR.B	D3		; D3 <-- remplace les "/" par <0>12$:	LOAD.B	(A1+),D3	; OFLNAM <-- nom	JUMP	10$14$:	CLR.B	(A1)	LOAD.L	A1,#(A2)+OFLTYP	LOAD.L	A3,#(A4)+OBALG	; A3 <-- ^nom physique40$:	LOAD.B	D2,(A3+)	JUMP',EQ 45$	COMP.B	D2,#':	JUMP',EQ 45$	COMP.B	D2,#'_		; pour $FLO_1	JUMP',EQ 45$	COMP.B	D2,#'.		; pour @NANET.123	JUMP',EQ 45$	COMP.B	D2,#'-		; pour @NANET-123	JUMP',EQ 45$	LOAD.B	(A1+),D2	; OFLTYP <-- nom physique	JUMP	40$45$:	CLR.B	(A1)	LOAD.L	(A2)+OFLATT,#2^BATTL ; met l'attribut "L" !	LOAD.W	(A2)+OFLRAF,#-1	; signal icne  repeindre	POPM.L	D2,A1..A3	RET;---------\\; SORTALL  >;=========/; Trie dans l'ordre choisi tous les noms de fichiers.; in	A5.L	^description unit; out	-; mod	D7.WSORTALL:	PUSHM.L	D2,D3,A2,A3	CALL	WAITMOUSE	; souris: met le sablier; Cherche le pointeur au dbut du critre "*" ou autre.; Ceci autorise ensuite l'emploi de SORTONEQUICK !	LOAD.L	A3,#(A5)+OUNNAM	CALL	SKIPREP	LOAD.L	(A5)+OUNPCR,A3; Trie en prenant les fichiers un par un et les introduisant; dans l'index.	CLR.W	(A5)+OUNNBL	LOAD.L	A2,(A5)+OUNPLI	; A2 <-- ^premier nom	LOAD.W	D2,(A5)+OUNNBM	JUMP',EQ 90$40$:	CALL	SORTONEQUICK	; trie un fichier	LOAD.L	A2,#(A2)+LFL	; A2 <-- ^nom suivant	DEC.W	D2	JUMP,NE 40$90$:	POPM.L	D2,D3,A2,A3	RET;--------\\; SORTONE >;========/; Ajouter un fichier dans la liste/index trie, en cherchant; rapidement le bon emplacement par bissection.; in	A5.L	^description unit;	A2.L	^fichier; out	-; mod	D7.WSORTONE:	PUSH.L	A3	LOAD.L	A3,#(A5)+OUNNAM	CALL	SKIPREP	LOAD.L	(A5)+OUNPCR,A3	; OUNPCR <-- ^dbut critre "*" ou autre	POP.L	A3SORTONEQUICK:	PUSHM.L	D0..D3,A1,A3,A4	CALL	SORTVISU	; fichier visible ?	JUMP,NE 90$		; non => 90$; Cherche o mettre le fichier dans l'index par bissection.	CLR.W	D2	CLR.W	D0		; D0 <-- borne infrieure	LOAD.W	D1,(A5)+OUNNBL	; D1 <-- borne suprieure	JUMP,EQ 50$20$:	LOAD.W	D2,D1	SUB.W	D2,D0	SR.W	D2,#1	ADD.W	D2,D0		; D2 <-- entre les deux bornes	DEC.W	D1	COMP.W	D0,D1		; borne infrieure juste avant borne suprieure ?	JUMP,EQ 40$		; oui => 40$	INC.W	D1	LOAD.W	D3,D2	SL.W	D3,#1	LOAD.L	A3,(A5)+OUNPIN	; A3 <-- ^index	LOAD.W	D3,(A3)+(D3.W)	MUL.WU	D3,#LFL	LOAD.L	A3,(A5)+OUNPLI	ADD.L	A3,D3	CALL	SORTCOMP	; compare ...	TEST.W	D7	JUMP,EQ 50$	COMP.W	D7,#1	JUMP',EQ 30$				; plus grand =>	LOAD.W	D0,D2		; borne infrieure <-- milieu	JUMP	20$30$:				; plus petit =>	LOAD.W	D1,D2		; borne suprieure <-- milieu	JUMP	20$40$:	LOAD.W	D3,D2	SL.W	D3,#1	LOAD.L	A3,(A5)+OUNPIN	; A3 <-- ^index	LOAD.W	D3,(A3)+(D3.W)	MUL.WU	D3,#LFL	LOAD.L	A3,(A5)+OUNPLI	ADD.L	A3,D3	CALL	SORTCOMP	; compare ...	TEST.W	D7	JUMP',EQ 50$	COMP.W	D7,#1	JUMP',EQ 50$	INC.W	D2; Ajoute le fichier dans l'index, qui doit tre dcal; jusqu' la fin.50$:	LOAD.W	D3,(A5)+OUNNBL	SL.W	D3,#1	LOAD.L	A3,(A5)+OUNPIN	ADD.W	A3,D3		; A3 <-- ^fin index	LOAD.L	A4,#(A3)+2	LOAD.W	D3,(A5)+OUNNBL	SUB.W	D3,D2	JUMP',EQ 65$	DEC.W	D360$:	LOAD.W	(-A4),(-A3)	; pousse	DECJ.W,NMO D3,60$65$:	LOAD.L	D3,A2	SUB.L	D3,(A5)+OUNPLI	DIV.WU	D3,#LFL		; D3 <-- rang du nouveau	LOAD.W	(A3),D3		; index <-- rang	INC.W	(A5)+OUNNBL	; un index de plus90$:	POPM.L	D0..D3,A1,A3,A4	RET;---------\\; SORTCOMP >;---------/; Compare deux fichiers.; in	A5.L	^description unit;	A2.L	^premier fichier;	A3.L	^deuxime fichier; out	D7.W	1 => LO;		0 => EQ;		2 => HI; mod	D7.WSORTCOMP:; Compare selon le premier critre de classement.	TEST.B	(A5)+OUNFAC1:#BFLC1E	JUMP',BS 22$	TEST.B	(A5)+OUNFAC1:#BFLC1C	JUMP',BS 23$	TEST.B	(A5)+OUNFAC1:#BFLC1W	JUMP',BS 24$	TEST.B	(A5)+OUNFAC1:#BFLC1R	JUMP',BS 25$	TEST.B	(A5)+OUNFAC1:#BFLC1T	JUMP',BS 26$	CALL	SORTNOM		; compare selon noms	JUMP'	29$22$:	CALL	SORTEXT		; compare selon extensions	JUMP'	29$23$:	CALL	SORTDATEC	; compare selon dates cration	JUMP'	29$24$:	CALL	SORTDATEW	; compare selon dates modifications	JUMP'	29$25$:	CALL	SORTDATER	; compare selon dates utilisations	JUMP'	29$26$:	CALL	SORTLG		; compare selon tailles;	JUMP'	29$29$:	TEST.W	D7		; EQ ?	JUMP,NE 90$; En cas d'galit, compare selon le deuxime critre.	TEST.B	(A5)+OUNFAC2:#BFLC2E-8	JUMP',BS 32$	TEST.B	(A5)+OUNFAC2:#BFLC2C-8	JUMP',BS 33$	TEST.B	(A5)+OUNFAC2:#BFLC2W-8	JUMP',BS 34$	TEST.B	(A5)+OUNFAC2:#BFLC2R-8	JUMP',BS 35$	TEST.B	(A5)+OUNFAC2:#BFLC2T-8	JUMP',BS 36$	CALL	SORTNOM		; compare selon noms	JUMP'	39$32$:	CALL	SORTEXT		; compare selon extensions	JUMP'	39$33$:	CALL	SORTDATEC	; compare selon dates cration	JUMP'	39$34$:	CALL	SORTDATEW	; compare selon dates modifications	JUMP'	39$35$:	CALL	SORTDATER	; compare selon dates utilisations	JUMP'	39$36$:	CALL	SORTLG		; compare selon tailles;	JUMP'	39$39$:90$:	RET;---------\\; SORTVISU >;---------/; Vrifie si un fichier doit tre visible.; in	A2.L	^fichier; out	D7.W	EQ => fichier visible;		NE => fichier invisible; mod	D7.WSORTVISU:	PUSHM.L	D2,A2..A4; Si le fichier n'existe pas (trou), il est invisible.	TEST.B	(A2)		; fichier existe ?	JUMP,EQ 85$		; non => 85$; Selon "cach", vrifie si l'attribut "L" est prsent.	TEST.B	(A5)+OUNFALI:#BFLCAC-24	JUMP',BS 30$	LOAD.L	D2,(A2)+OFLATT	; D2 <-- attributs	TEST.L	D2:#BATTL	; attribut "L" prsent ?	JUMP,BC 85$		; non => 85$; Selon "systme", vrifie si le fichier commence par "100_" ou "SYS_".30$:	TEST.B	(A5)+OUNFALI:#BFLSYS-24	JUMP',BS 40$	LOAD.L	A3,A2	CALL	IF100_		; fichier dit "systme" ?	JUMP,EQ 85$		; oui => 85$; Selon ".CODE", vrifie si le fichier est termin par ".CODE".40$:	TEST.B	(A5)+OUNFALI:#BFLNCOD-24	JUMP',BS 50$	PUSH.L	A2	LOAD.L	A3,#R16"04$	LOAD.L	A4,A2		; A4 <-- ^nom du fichier	LOAD.L	A2,#R16"00$	; A2 <-- ^liste de terminateurs	LIB	?CPSTRING	; fichier .CODE ?	POP.L	A2	JUMP,NC 80$		; oui => 80$; Selon "dossier", vrifie si le fichier est termin par ":".50$:	TEST.B	(A5)+OUNFALI:#BFLNDIR-24	JUMP',BS 60$	PUSH.L	A2	LOAD.L	A3,#R16"05$	LOAD.L	A4,A2		; A4 <-- ^nom du fichier	LOAD.L	A2,#R16"00$	; A2 <-- ^liste de terminateurs	LIB	?CPSTRING	; dossier ?	POP.L	A2	JUMP,NC 80$		; oui => 80$; Vrifie selon la chane "*" ou autre.60$:	LOAD.L	A4,A2		; A4 <-- ^nom du fichier	LOAD.L	A3,(A5)+OUNPCR	; A3 <-- ^critre	TEST.B	(A3)+1	JUMP',NE 62$	COMP.B	(A3),#'*	; critre "*" ?	JUMP,EQ 80$		; oui => 80$	COMP.B	(A3),#'$	JUMP,EQ 80$62$:	LOAD.L	A2,#R16"00$	; A2 <-- ^liste de terminateurs	LIB	?CPSTRING	; correspond au critre ?	JUMP',NC 80$		; oui => 80$64$:				; non =>	LOAD.B	D3,(A3+)	JUMP',EQ 85$	COMP.B	D3,#'|		; encore un critre ?	JUMP,EQ 62$		; oui => 62$	COMP.B	D3,#SPACE	JUMP,EQ 62$	JUMP	64$80$:	CLR.W	D7		; D7 <-- fichier visible	JUMP'	90$85$:	LOAD.W	D7,#1		; D7 <-- fichier invisible;	JUMP'	90$90$:	POPM.L	D2,A2..A4	TEST.W	D7		; retour EQ/NE	RET00$:	.B	0,'|,SPACE,-104$:	.ASCIZ	"*.CODE"05$:	.ASCIZ	"*:"	.EVEN;--------\\; SORTNOM >;--------/; Compare deux noms de fichiers.; in	A2.L	^premier fichier;	A3.L	^deuxime fichier; out	D7.W	1 => LO;		0 => EQ;		2 => HI; mod	D7.WSORTNOM:	PUSHM.L	D3,A2,A340$:	LOAD.B	D3,(A2+)	COMP.B	D3,(A3+)	JUMP',LO 81$	JUMP',HI 82$	TEST.B	D3	JUMP',EQ 80$	COMP.B	D3,#'.	JUMP',EQ 80$	COMP.B	D3,#'!	JUMP',NE 40$80$:	CLR.W	D7		; D7 <-- EQ	JUMP'	90$81$:	LOAD.W	D7,#1		; D7 <-- LO	JUMP'	90$82$:	LOAD.W	D7,#2		; D7 <-- HI;	JUMP'	90$90$:	POPM.L	D3,A2,A3	RET;--------\\; SORTEXT >;--------/; Compare deux extensions de fichiers.; in	A2.L	^premier fichier;	A3.L	^deuxime fichier; out	D7.W	1 => LO;		0 => EQ;		2 => HI; mod	D7.WSORTEXT:	PUSHM.L	D3,A2,A310$:	LOAD.B	D3,(A2+)	JUMP',EQ 12$	COMP.B	D3,#'.	JUMP',EQ 12$	COMP.B	D3,#'!	JUMP,NE 10$12$:	DEC.L	A2		; A2 <-- ^extension20$:	LOAD.B	D3,(A3+)	JUMP',EQ 22$	COMP.B	D3,#'.	JUMP',EQ 22$	COMP.B	D3,#'!	JUMP,NE 20$22$:	DEC.L	A3		; A3 <-- ^extension	COMP.B	(A2)-1,#':	JUMP',NE 30$	LOAD.L	A2,#R16"REP$	JUMP'	34$30$:	TEST.B	(A2)	JUMP',NE 32$	LOAD.L	A2,#R16"SEXT$	JUMP'	34$32$:	COMP.B	(A2)+0,#'.	JUMP',NE 34$	COMP.B	(A2)+1,#'C	JUMP',NE 34$	COMP.B	(A2)+2,#'O	JUMP',NE 34$	COMP.B	(A2)+3,#'D	JUMP',NE 34$	COMP.B	(A2)+4,#'E	JUMP',NE 34$	TEST.B	(A2)+5	JUMP',NE 34$	LOAD.L	A2,#R16"CODE$34$:	COMP.B	(A3)-1,#':	JUMP',NE 40$	LOAD.L	A3,#R16"REP$	JUMP'	44$40$:	TEST.B	(A3)	JUMP',NE 42$	LOAD.L	A3,#R16"SEXT$	JUMP'	44$42$:	COMP.B	(A3)+0,#'.	JUMP',NE 44$	COMP.B	(A3)+1,#'C	JUMP',NE 44$	COMP.B	(A3)+2,#'O	JUMP',NE 44$	COMP.B	(A3)+3,#'D	JUMP',NE 44$	COMP.B	(A3)+4,#'E	JUMP',NE 44$	TEST.B	(A3)+5	JUMP',NE 44$	LOAD.L	A3,#R16"CODE$44$:60$:	LOAD.B	D3,(A2+)	COMP.B	D3,(A3+)	JUMP',LO 81$	JUMP',HI 82$	TEST.B	D3	JUMP,NE	60$80$:	CLR.W	D7		; D7 <-- EQ	JUMP'	90$81$:	LOAD.W	D7,#1		; D7 <-- LO	JUMP'	90$82$:	LOAD.W	D7,#2		; D7 <-- HI;	JUMP'	90$90$:	POPM.L	D3,A2,A3	RETREP$:	.B	1,0		; d'abord les dossiers ..CODE$:	.B	2,0		; .. puis les programmes !SEXT$:	.B	255,0		; les sans extension tout  la fin	.EVEN;----------\\; SORTDATEC >;----------/; Compare deux dates/heures de crations.; in	A2.L	^premier fichier;	A3.L	^deuxime fichier; out	D7.W	1 => LO;		0 => EQ;		2 => HI; mod	D7.WSORTDATEC:	PUSHM.L	D2,D3	CLR.L	D2	LOAD.B	D2,(A2)+OFLCD+2	SL.L	D2,#8	LOAD.B	D2,(A2)+OFLCD+1	SL.L	D2,#8	LOAD.B	D2,(A2)+OFLCD+0	CLR.L	D3	LOAD.B	D3,(A3)+OFLCD+2	SL.L	D3,#8	LOAD.B	D3,(A3)+OFLCD+1	SL.L	D3,#8	LOAD.B	D3,(A3)+OFLCD+0	COMP.L	D2,D3	JUMP',LO 81$	JUMP',HI 82$	CLR.L	D2	LOAD.B	D2,(A2)+OFLCH+0	SL.L	D2,#8	LOAD.B	D2,(A2)+OFLCH+1	SL.L	D2,#8	LOAD.B	D2,(A2)+OFLCH+2	CLR.L	D3	LOAD.B	D3,(A3)+OFLCH+0	SL.L	D3,#8	LOAD.B	D3,(A3)+OFLCH+1	SL.L	D3,#8	LOAD.B	D3,(A3)+OFLCH+2	COMP.L	D2,D3	JUMP',LO 81$	JUMP',HI 82$80$:	CLR.W	D7		; D7 <-- EQ	JUMP'	90$81$:	LOAD.W	D7,#1		; D7 <-- LO	JUMP'	90$82$:	LOAD.W	D7,#2		; D7 <-- HI;	JUMP'	90$90$:	POPM.L	D2,D3	RET;----------\\; SORTDATEW >;----------/; Compare deux dates/heures de modifications.; in	A2.L	^premier fichier;	A3.L	^deuxime fichier; out	D7.W	1 => LO;		0 => EQ;		2 => HI; mod	D7.WSORTDATEW:	PUSHM.L	D2,D3	CLR.L	D2	LOAD.B	D2,(A2)+OFLWD+2	SL.L	D2,#8	LOAD.B	D2,(A2)+OFLWD+1	SL.L	D2,#8	LOAD.B	D2,(A2)+OFLWD+0	CLR.L	D3	LOAD.B	D3,(A3)+OFLWD+2	SL.L	D3,#8	LOAD.B	D3,(A3)+OFLWD+1	SL.L	D3,#8	LOAD.B	D3,(A3)+OFLWD+0	COMP.L	D2,D3	JUMP',LO 81$	JUMP',HI 82$	CLR.L	D2	LOAD.B	D2,(A2)+OFLWH+0	SL.L	D2,#8	LOAD.B	D2,(A2)+OFLWH+1	SL.L	D2,#8	LOAD.B	D2,(A2)+OFLWH+2	CLR.L	D3	LOAD.B	D3,(A3)+OFLWH+0	SL.L	D3,#8	LOAD.B	D3,(A3)+OFLWH+1	SL.L	D3,#8	LOAD.B	D3,(A3)+OFLWH+2	COMP.L	D2,D3	JUMP',LO 81$	JUMP',HI 82$80$:	CLR.W	D7		; D7 <-- EQ	JUMP'	90$81$:	LOAD.W	D7,#1		; D7 <-- LO	JUMP'	90$82$:	LOAD.W	D7,#2		; D7 <-- HI;	JUMP'	90$90$:	POPM.L	D2,D3	RET;----------\\; SORTDATER >;----------/; Compare deux dates/heures d'utilisations.; in	A2.L	^premier fichier;	A3.L	^deuxime fichier; out	D7.W	1 => LO;		0 => EQ;		2 => HI; mod	D7.WSORTDATER:	PUSHM.L	D2,D3	CLR.L	D2	LOAD.B	D2,(A2)+OFLRD+2	SL.L	D2,#8	LOAD.B	D2,(A2)+OFLRD+1	SL.L	D2,#8	LOAD.B	D2,(A2)+OFLRD+0	CLR.L	D3	LOAD.B	D3,(A3)+OFLRD+2	SL.L	D3,#8	LOAD.B	D3,(A3)+OFLRD+1	SL.L	D3,#8	LOAD.B	D3,(A3)+OFLRD+0	COMP.L	D2,D3	JUMP',LO 81$	JUMP',HI 82$	CLR.L	D2	LOAD.B	D2,(A2)+OFLRH+0	SL.L	D2,#8	LOAD.B	D2,(A2)+OFLRH+1	SL.L	D2,#8	LOAD.B	D2,(A2)+OFLRH+2	CLR.L	D3	LOAD.B	D3,(A3)+OFLRH+0	SL.L	D3,#8	LOAD.B	D3,(A3)+OFLRH+1	SL.L	D3,#8	LOAD.B	D3,(A3)+OFLRH+2	COMP.L	D2,D3	JUMP',LO 81$	JUMP',HI 82$80$:	CLR.W	D7		; D7 <-- EQ	JUMP'	90$81$:	LOAD.W	D7,#1		; D7 <-- LO	JUMP'	90$82$:	LOAD.W	D7,#2		; D7 <-- HI;	JUMP'	90$90$:	POPM.L	D2,D3	RET;--------\\; SORTLG  >;--------/; Compare deux tailles.; in	A2.L	^premier fichier;	A3.L	^deuxime fichier; out	D7.W	1 => LO;		0 => EQ;		2 => HI; mod	D7.WSORTLG:	PUSH.L	D2	LOAD.L	D2,(A2)+OFLLG	COMP.L	D2,(A3)+OFLLG	JUMP',LO 81$	JUMP',HI 82$80$:	CLR.W	D7		; D7 <-- EQ	JUMP'	90$81$:	LOAD.W	D7,#1		; D7 <-- LO	JUMP'	90$82$:	LOAD.W	D7,#2		; D7 <-- HI;	JUMP'	90$90$:	POP.L	D2	RET	.END