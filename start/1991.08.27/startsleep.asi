	.SBTTL	STARTSLEEP;--------\\; SLEEP   >;========/; Passe en mode sleep ...; in	-; out	D7.W	erreur; mod	D7.WSLEEP:	PUSHM.L	D1..D6,A0,A2..A4	CLR.W	D3		; D3 <-- global	FOS	?RENTER		; release tous les enter	JUMP,NE	EXIT$	CALL	__BALWAIT	; traite les messages du FOS ...	CALL	COUPSAC		; coup de sac du gnrateur alatoire	LIB	?VASSKEY	LOAD.W	(A6)+OSLK2,D3	; OSLK2 <-- clavier actuel	CLR.W	D3	LIB	?ASSKEY		; assigne le clavier  START	LIB	?GETDIM	LOAD.L	(A6)+OSLDY,D4	LIB	?GCHDIS	LOAD.W	(A6)+OSLCH,D6	LOAD.L	A3,#R16"SLDIS0	LOAD.W	D3,#2^BOPWR!2^BOPRD	FOS	?OPEN		; ouvre le bitmap complet $DIS_0	JUMP,NE EXIT$	LOAD.W	D3,#TYPDIS	; D3 <-- type bitmap complet	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OSLPD	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERROR$	LOAD.L	A0,(A6)+OSLPD	; A0 <-- ^descripteur de $DIS_0;;?	LOAD.W	(A6)+OSLDX,(A0)+ODFDX	LOAD.W	(A6)+OSLDY,(A0)+ODFDY	COMP.B	(A6)+OMACHINE,#SMAKY8	JUMP',NE NOSM8$	LOAD.W	(A6)+OSLDX,#832	; OSLDX <-- largeur visible (beurk !!!)	LOAD.W	(A6)+OSLDY,#512	; OSLDY <-- hauteur visible (beurk !!!)NOSM8$:	LOAD.L	D4,(A6)+OSLDY	SR.W	D4,#1	SWAP.W	D4	SR.W	D4,#1	SWAP.W	D4	CALL	PMOUSE		; positionne la souris au milieu	LOAD.W	D4,#2	NTREL	?DELMS	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la flche de la souris	LIB	?PCHDIS		; utilise maintenant $DIS_0	CLR.W	D4	LOAD.B	D4,(A0)+ODFCNP	; D4 <-- nb de bits/pixel (1,4)	MUL.WU	D4,(A6)+OSLDX	SR.L	D4,#3	MUL.WU	D4,(A6)+OSLDY	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour sauver le bitmap	JUMP,NE ERROR$	LOAD.L	(A6)+OSLPM,A4	CLR.L	D3		; D3 <-- origine source	LOAD.L	A3,#0		; A3 <-- ^source (cran)	CLR.L	D4		; D4 <-- origine destination	LOAD.W	D6,(A6)+OSLDX	SR.W	D6,#3		; D6 <-- Iy destination;	LOAD.L	A4,(A6)+OSLPM	; A4 <-- ^destination	LOAD.L	D2,(A6)+OSLDY	; D2 <-- dimensions	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	CALL	SLEEPRASTER	; buffer <-- sauve tout l'cran	LOAD.L	A4,#R16"SLCLKI	CALL	CLKCOMM		; stoppe l'horloge	LOAD.L	A4,#R16"SLKEYI	CALL	KEYCOMM		; bloque le clavier;;?	LOAD.L	(A6)+OSLI1,_VINCIDL;;?	LOAD.L	A4,#(A6)+OSLI2;;?	LOAD.L	_VINCIDL,A4	; dtourne l'IDLE du droit chemin	LOAD.W	D2,#CLRDOT	CLR.L	D3	CLR.L	D4	TEST.B	(A0)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP',BC NOWHITE$	; non => NOWHITE$	LOAD.W	D2,#SETDOT	LOAD.L	D3,#-1	LOAD.L	D4,D3NOWHITE$:	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A6)+OSLDY	LIB	?DRTRAME	; efface tout le bitmap	SET.B	(A6)+OSLEEP	CALL	CLOCK		; dessine l'horloge ...	CLR.B	(A6)+OSLEEP	CLR.L	D3		; D3 <-- origine source	LOAD.L	A3,(A6)+OSLPM	; A3 <-- ^source	LOAD.W	D5,(A6)+OSLDX	SR.W	D5,#3		; D5 <-- Iy destination	CLR.L	D4		; D4 <-- origine destination	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	LOAD.L	D2,(A6)+OSLDY	; D2 <-- dimensions	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL;	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	CALL	SLEEPRASTER	; restitue tout le bitmap	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend mmoire pour sauver le bitmap	LOAD.L	A4,#R16"SLCLKO	CALL	CLKCOMM		; affiche de nouveau l'horloge	LOAD.L	A4,#R16"SLKEYO	CALL	KEYCOMM		; dbloque le clavier;;?	LOAD.L	_VINCIDL,(A6)+OSLI1 ; remet l'IDLE	FOS	?CLOSE		; ferme le bitmap complet $DIS_0	LOAD.W	D6,(A6)+OSLCH	LIB	?PCHDIS		; r-utilise la fentre normale	LOAD.B	D3,#AFSCMO	LIB	?AFCAR		; remet la flche de la souris	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	FOS	?CLOSEEXIT$:	PUSH.W	D7	LOAD.W	D3,(A6)+OSLK2	LIB	?ASSKEY		; r-assigne le clavier au programme initial	POP.W	D7	POPM.L	D1..D6,A0,A2..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; SLEEPRASTER >;------------/; Comme GRA_RASTER, mais en grant la couleur.; in	comme GRA_RASTER; out	-; mod	D7.WSLEEPRASTER:	PUSHM.L	D0,D5,D6	CLR.W	D0	LOAD.B	D0,(A0)+ODFCNP	; D0 <-- nb de bits/pixel (1,4)	COMP.W	D0,#1	JUMP',NE COUL$	GRA_	RASTER		; raster noir/blanc	JUMP'	EXIT$COUL$:	TEST.L	D1:#BSRCCOUL	JUMP',BC CSRC$	MUL.WU	D5,D0		; D5 <-- Iy sourceCSRC$:	TEST.L	D1:#BDSTCOUL	JUMP',BC CDST$	MUL.WU	D6,D0		; D6 <-- Iy destinationCDST$:	GRA_	CRASTER		; raster couleurEXIT$:	POPM.L	D0,D5,D6	RET;--------\\; CLKCOMM >;========/; Envoie une commande  l'horloge.; in	A4.L	^commande; out	-; mod	D7.WCLKCOMM:	PUSHM.L	D3,D6,A3	LOAD.L	A3,#R16"SLCLK	LOAD.W	D3,#2^BOPRD!2^BOPWR	FOS	?OPEN		; ouvre l'horloge	JUMP',NE EXIT$	LOAD.W	D3,#TYPIO	FOS	?COMMAND	; envoie la commande	FOS	?CLOSE		; ferme l'horlogeEXIT$:	POPM.L	D3,D6,A3	RET;--------\\; KEYCOMM >;========/; Envoie une commande au clavier.; in	A4.L	^commande; out	-; mod	D7.WKEYCOMM:	PUSHM.L	D3,D6,A3	LIB	?GCHKEY	LOAD.W	D3,#TYPKEY	FOS	?COMMAND	; envoie la commande	POPM.L	D3,D6,A3	RET;-------\\; CLOCK  >;=======/; Affiche l'horloge jusqu' ce qu'une touche soit presse.; L'horloge change de position toutes les minutes, pour; viter de trop bouziller le phosphore de l'cran !; in	-; out	-; mod	D7.WCLOCK:	PUSHM.L	D0..D5,A3	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_STSLEEP	LIB	?COLORCR10$:	LOAD.W	D3,#50		; D3 <-- rayon minimal	LOAD.W	D4,(A6)+OSLDX	COMP.W	D4,(A6)+OSLDY	JUMP',LO 11$	LOAD.W	D4,(A6)+OSLDY11$:	SR.W	D4,#2		; D4 <-- rayon maximal	COMP.W	D4,#120	JUMP',LS 12$	LOAD.W	D4,#12012$:	CALL	MMHAZARD	; D4 <-- nombre alatoire	LOAD.W	(A6)+OSLRA,D4	LOAD.W	D3,D4	ADD.W	D3,#10	LOAD.W	D4,(A6)+OSLDX	SUB.W	D4,D3	CALL	MMHAZARD	; D4 <-- nombre alatoire	LOAD.W	(A6)+OSLCE+2,D4	LOAD.W	D4,(A6)+OSLDY	SUB.W	D4,(A0)+ODFCY	SUB.W	D4,(A0)+ODFCY	SUB.W	D4,(A0)+ODFCY	SUB.W	D4,D3	CALL	MMHAZARD	; D4 <-- nombre alatoire	LOAD.W	(A6)+OSLCE+0,D4	CALL	SLRDCLOCK	; D3/D4/D5 <-- heure/minute/seconde	CALL	DESCLOCK	; dessine l'horloge	CALL	DESHOUR		; dessine l'aiguille des heures	CALL	DESMINUTE	; dessine l'aiguille des minutes	CALL	DESSECOND	; dessine l'aiguille des secondes	PUSHM.L	D3,D4	LOAD.L	D3,(A6)+OSLCE	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#30	SR.W	D4,#1	SUB.W	D3,D4		; trop  gauche ?	JUMP',HS 15$	CLR.W	D315$:	LOAD.W	D2,(A6)+OSLDX	SUB.W	D2,D4	SUB.W	D2,D4	COMP.W	D3,D2		; trop  droite ?	JUMP',LO 16$	LOAD.W	D3,D216$:	SWAP.W	D3	ADD.W	D3,(A6)+OSLRA	ADD.W	D3,#5	ADD.W	D3,(A0)+ODFCY	ADD.W	D3,(A0)+ODFCY	SWAP.W	D3	LIB	?SETCURS	TEST.B	(A0)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP',BC 18$		; non => 18$	LIB	?AFTIM	.B	AFINV,0		; passe en vido inverse	.EVEN18$:	LOAD.L	A3,#R16"TEXT1$	LIB	?AFTEXT		; affiche la 1re ligne	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A3,#R16"TEXT2$	LIB	?AFTEXT		; affiche la 2me ligne	CALL	SLAFMACHINE	LOAD.L	A3,#R16"TEXT3$	LIB	?AFTEXT		; affiche la 2me ligne	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; repasse en vido normale	POPM.L	D3,D420$:	CALL	__BALWAIT	; traite les messages du FOS ...	JUMP,NE EXIT$		; si message(s) reu(s) => EXIT$	PUSH.L	D3	CLR.W	D2	LIB	?IFCAR		; une touche presse ?	JUMP',NE 22$	LOAD.W	D2,D3		; D2 <-- touche presse22$:	POPM.L	D3	COMP.W	D2,#SPACE	; barre d'espace appuye ?	JUMP,EQ EXIT$		; oui => EXIT$	TEST.B	(A6)+OSLEEP	; est-ce que le SMAKY dort ?	JUMP,F	EXIT$		; non => EXIT$	PUSH.L	D4	LOAD.L	D4,(A6)+OSLDY	SR.W	D4,#1	SWAP.W	D4	SR.W	D4,#1	SWAP.W	D4	CALL	PMOUSE		; positionne la souris au milieu	POP.L	D4	PUSH.W	D4	LOAD.W	D4,#50-2	NTREL	?DELMS		; attend une seconde ...	POP.W	D4	LOAD.W	D0,D3	LOAD.W	D1,D4	LOAD.W	D2,D5	COMP.W	D5,#60-1	JUMP,HS 50$	INC.W	D5		; D5 <-- une seconde de plus;;?	EX.L	D3,D0;;?	EX.L	D4,D1;;?	EX.L	D5,D2;;?	CALL	DESHOUR		; efface l'aiguille des heures;;?	EX.L	D3,D0;;?	EX.L	D4,D1;;?	EX.L	D5,D2;;?	CALL	DESHOUR		; dessine l'aiguille des heures	EX.L	D3,D0	EX.L	D4,D1	EX.L	D5,D2	CALL	DESMINUTE	; efface l'aiguille des minutes	EX.L	D3,D0	EX.L	D4,D1	EX.L	D5,D2	CALL	DESMINUTE	; dessine l'aiguille des minutes	EX.L	D3,D0	EX.L	D4,D1	EX.L	D5,D2	CALL	DESSECOND	; efface l'aiguille des secondes	EX.L	D3,D0	EX.L	D4,D1	EX.L	D5,D2	CALL	DESSECOND	; dessine l'aiguille des secondes	JUMP	20$50$:;;?	CALL	DESHOUR		; efface l'aiguille des heures;;?	CALL	DESMINUTE	; efface l'aiguille des minutes;;?	CALL	DESSECOND	; efface l'aiguille des secondes;;?	CALL	DESCLOCK	; efface l'horloge	LOAD.W	D2,#CLRDOT	CLR.L	D3	CLR.L	D4	TEST.B	(A0)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP',BC 60$		; non => 60$	LOAD.W	D2,#SETDOT	LOAD.L	D3,#-1	LOAD.L	D4,D360$:	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A6)+OSLDY	LIB	?DRTRAME	; efface tout le bitmap	JUMP	10$EXIT$:	LIB	?COLORPOP	POPM.L	D0..D5,A3	RETTEXT1$:	.ASCIZ	"Appuyez sur la barre d'espace"TEXT2$:	.ASCIZ	"pour rveiller le "TEXT3$:	.ASCIZ	" ..."	.EVEN;------------\\; SLAFMACHINE >;------------/; Affiche le nom de la machine.; in	-; out	-; mod	D7.WSLAFMACHINE:	PUSHM.L	D3,D4,A3	NTREL	?GETMACHINE	; A3/D4 <-- ^nom de la machine20$:	TEST.B	(A3+)		; A3 <-- saute le premier .ASCIZ	JUMP,NE 20$30$:	LOAD.B	D3,(A3+)	JUMP',EQ EXIT$	COMP.B	D3,#SPACE	JUMP',EQ EXIT$	LIB	?MINMAJ	LIB	?AFCAR		; affiche le nom de la machine	JUMP	30$EXIT$:	POPM.L	D3,D4,A3	RET;----------\\; SLRDCLOCK >;==========/; Lit l'horloge du SMAKY.; in	-; out	D3.W	heures (0..23);	D4.W	minutes (0..59);	D5.W	secondes (0..59);	D7.W	erreur; mod	D3.L, D4.L, D5.L, D7.WSLRDCLOCK:	PUSH.L	D2	LIB	?RDCLOCK	; D3/D4 <-- heure/date	JUMP',NE EXIT$	LOAD.L	D2,D3	LOAD.L	D4,D2	SWAP.W	D4	AND.L	D4,#H'000000FF	LIB	?BCDBIN		; D4 <-- heures	PUSH.W	D4	LOAD.L	D4,D2	SR.W	D4,#8	AND.L	D4,#H'000000FF	LIB	?BCDBIN		; D4 <-- minutes	PUSH.W	D4	LOAD.L	D4,D2	AND.L	D4,#H'000000FF	LIB	?BCDBIN		; D4 <-- secondes	LOAD.W	D5,D4	POP.W	D4	POP.W	D3EXIT$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; DESHOUR >;========/; Dessine l'aiguille des heures.; in	D3.W	heures (0..23);	D4.W	minutes (0..59); out	-; mod	D7.WDESHOUR:	PUSHM.L	D1..D4	LOAD.W	D2,D3	MUL.WU	D2,#60	ADD.W	D2,D4		; D2 <-- temps en minutes	DIV.WU	D2,#60/30	; D2 <-- angle	LOAD.L	D3,(A6)+OSLCE	SWAP.W	D3	SUB.W	D3,(A6)+OSLRA	CLR.L	D1	LOAD.W	D1,(A6)+OSLRA	DIV.WU	D1,#2	ADD.W	D3,D1	SWAP.W	D3	CALL	QTOURNE	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OSLCE	SWAP.W	D3	CLR.L	D1	LOAD.W	D1,(A6)+OSLRA	DIV.WU	D1,#10	SUB.W	D3,D1	SWAP.W	D3	CALL	QTOURNE	LOAD.W	D1,#3	CALL	DRLINE		; dessine l'aiguille des heures	POPM.L	D1..D4	RET;----------\\; DESMINUTE >;==========/; Dessine l'aiguille des minutes.; in	D4.W	minutes (0..59);	D5.W	secondes (0..59); out	-; mod	D7.WDESMINUTE:	PUSHM.L	D1..D4	LOAD.W	D2,D4	MUL.WU	D2,#60	ADD.W	D2,D5		; D2 <-- temps en secondes	DIV.WU	D2,#10		; D2 <-- angle	LOAD.L	D3,(A6)+OSLCE	SWAP.W	D3	SUB.W	D3,(A6)+OSLRA	CLR.L	D1	LOAD.W	D1,(A6)+OSLRA	DIV.WU	D1,#20	ADD.W	D3,D1	ADD.W	D3,#4	SWAP.W	D3	CALL	QTOURNE	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OSLCE	SWAP.W	D3	CLR.L	D1	LOAD.W	D1,(A6)+OSLRA	DIV.WU	D1,#10	SUB.W	D3,D1	SWAP.W	D3	CALL	QTOURNE	LOAD.W	D1,#2	CALL	DRLINE		; dessine l'aiguille des minutes	POPM.L	D1..D4	RET;----------\\; DESSECOND >;==========/; Dessine l'aiguille des secondes.; in	D5.W	secondes (0..59); out	-; mod	D7.WDESSECOND:	PUSHM.L	D1..D4	LOAD.W	D2,D5	MUL.WU	D2,#360/60	; D2 <-- angle	LOAD.L	D3,(A6)+OSLCE	SWAP.W	D3	SUB.W	D3,(A6)+OSLRA	CLR.L	D1	LOAD.W	D1,(A6)+OSLRA	DIV.WU	D1,#20	ADD.W	D3,D1	ADD.W	D3,#4	SWAP.W	D3	CALL	QTOURNE	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OSLCE	SWAP.W	D3	CLR.L	D1	LOAD.W	D1,(A6)+OSLRA	DIV.WU	D1,#10	SUB.W	D3,D1	SWAP.W	D3	CALL	QTOURNE	LOAD.W	D1,#1	CALL	DRLINE		; dessine l'aiguille des secondes	ADD.W	D2,#180	LOAD.L	D3,(A6)+OSLCE	SWAP.W	D3	CLR.L	D1	LOAD.W	D1,(A6)+OSLRA	DIV.WU	D1,#4	SUB.W	D3,D1	SWAP.W	D3	CALL	QTOURNE	LOAD.L	D4,D3	LOAD.L	D3,(A6)+OSLCE	SWAP.W	D3	CLR.L	D1	LOAD.W	D1,(A6)+OSLRA	DIV.WU	D1,#10	SUB.W	D3,D1	SWAP.W	D3	CALL	QTOURNE	LOAD.W	D1,#1	CALL	DRLINE		; dessine l'arrire de l'aiguille	POPM.L	D1..D4	RET;--------\\; DRLINE  >;--------/; Dessine une droite en mode inverse.; in	D3.L	origine (y;x);	D4.L	arrive (y;x);	D1.W	paisseur (1..n); out	-; mod	D7.WDRLINE:	PUSHM.L	D0..D4	LOAD.W	D2,#INVDOT	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D410$:	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	PUSH.L	D4	INC.W	D3	LOAD.L	D0,D4	SWAP.W	D0	TEST.W	D0	JUMP',NC 40$	NEG.W	D040$:	TEST.W	D4	JUMP',NC 42$	NEG.W	D442$:	COMP.W	D0,D4	JUMP',HS 50$	DEC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D350$:	POP.L	D4	DEC.W	D1	JUMP,NE 10$	POPM.L	D0..D4	RET;---------\\; DESCLOCK >;=========/; Dessine l'horloge sans aiguilles.; in	-; out	-; mod	D7.WDESCLOCK:	PUSHM.L	D0..D4	LIB	?BUCAR	LOAD.L	D3,(A6)+OSLCE	LOAD.W	D4,(A6)+OSLRA	LOAD.W	D2,#INVDOT	LIB	?DRCERCLE	; dessine le cercle extrieur	ADD.W	D4,#2	LIB	?DRCERCLE	ADD.W	D4,#8	LIB	?DRCERCLE	CLR.L	D4	LOAD.W	D4,(A6)+OSLRA	DIV.WU	D4,#10	DEC.W	D4	LIB	?DRCERCLE	; dessine le cercle tout au centre	SUB.W	D4,#2	COMP.W	D4,#5	JUMP',LT 10$	LIB	?DRCERCLE10$:	CLR.W	D2		; D2 <-- angle initial20$:	LOAD.L	D3,(A6)+OSLCE	SWAP.W	D3	SUB.W	D3,(A6)+OSLRA	CLR.L	D1	LOAD.W	D1,(A6)+OSLRA	DIV.WU	D1,#20	ADD.W	D3,D1	SWAP.W	D3	LOAD.L	D1,D3	CALL	QTOURNE	LOAD.L	D4,D3	LOAD.L	D3,D1	SWAP.W	D3	ADD.W	D3,#4	CLR.L	D1	LOAD.W	D1,D2	DIV.WU	D1,#360/60*5	SWAP.W	D1	TEST.W	D1		; sparateur pour 5 minutes ?	JUMP',NE 30$		; non => 30$	CLR.L	D1	LOAD.W	D1,(A6)+OSLRA	DIV.WU	D1,#8	ADD.W	D3,D130$:	SWAP.W	D3	CALL	QTOURNE	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	PUSH.W	D2	LOAD.W	D2,#INVDOT	LIB	?DRSEG		; dessine un sparateur des minutes	POP.W	D2	ADD.W	D2,#360/60	; D2 <-- angle suivant	COMP.W	D2,#360	JUMP,LO 20$	LIB	?NOBUCAR	POPM.L	D0..D4	RET;--------\\; QTOURNE >;--------/; Tourne un point d'un angle quelconque selon la; formule magique suivante :;;	x' = x*cos(a) - y*sin(a);	y' = x*sin(a) + y*cos(a);; OSLCE.L contient la coordonne du centre de symtrie.; in	D2.W	angle en degrs;	D3.L	coordonne (y;x); out	D3.L	coordonne (y;x); mod	D3.LQTOURNE:	PUSHM.L	D1,D2,D4	LOAD.W	D1,D2		; D1 <-- angle	LOAD.L	D4,D3		; D4 <-- point  tourner	LOAD.L	D3,(A6)+OSLCE	; D3 <-- centre	LIB	?CALCPSYM	; D4 <-- point tourn	LOAD.L	D3,D4		; D3 <-- point tourn	POPM.L	D1,D2,D4	RET; Tirage de nombres alatoires; ----------------------------;--------\\; COUPSAC >;========/; Coup de sac pour le gnrateur alatoire.; in	-; out	-; mod	D7.WCOUPSAC:	PUSHM.L	D3,D4	LIB	?RDCLOCK	; D3/D4 <-- date et heure	RR.L	D3,#3	RL.L	D4,#7		; savante cuisine	NOT.L	D3	XOR.L	D4,D3	LOAD.L	(A6)+OSLHA+0,D3	LOAD.L	(A6)+OSLHA+4,D4	LOAD.W	D3,#10-120$:	CALL	HAZARD		; tire qq nombres	DECJ.W,NMO D3,20$	POPM.L	D3,D4	RET;---------\\; MMHAZARD >;=========/; Tire un nombre alatoire (16 bits) compris entre deux bornes.; in	D3.W	+/- borne infrieure (min);	D4.W	+/- borne suprieure (max+1); out	D4.W	+/- nombre alatoire: D3 <= n < D4; mod	D4.L, D7.WMMHAZARD:	PUSH.W	D2	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- sup - inf	CALL	HAZARD	AND.L	D4,#H'FFFF	DIV.WU	D4,D2	SWAP.W	D4		; D4 <-- reste de la division	ADD.W	D4,D3	POP.W	D2	RET;--------\\; HAZARD  >;========/; Tire un nombre alatoire de 32 bits.; On utilise un registre  dcalage de 63 bits, avec un XNOR entre; les bits 0 et 60 pour calculer le nouveau bit inject.; in	-; out	D4.L	nombre; mod	D4.L, D7.WHAZARD:	PUSHM.L	D2,D3	LOAD.W	D2,#32-1	LOAD.L	D3,(A6)+OSLHA+0	LOAD.L	D4,(A6)+OSLHA+410$:	TEST.L	D4:#1	JUMP,BC 20$	TEST.L	D3:#30	JUMP,BC 35$	JUMP	30$20$:	TEST.L	D3:#30	JUMP,BS 35$30$:	CLRX	RRX.L	D3,#1	RRX.L	D4,#1	JUMP	40$35$:	SETX	RRX.L	D3,#1	RRX.L	D4,#140$:	LOAD.L	(A6)+OSLHA+0,D3	LOAD.L	(A6)+OSLHA+4,D4	DECJ.W,NMO D2,10$	POPM.L	D2,D3	RETSLDIS0:	.ASCIZ	"$DIS_0"SLCLK:	.ASCIZ	"#CLOCK"SLCLKI:	.B	'M,0		; clock: n'affiche plus rienSLCLKO:	.B	'R,0		; clock: affiche de nouveau normalementSLKEYI:	.B	KEYACT,SPACE,0SLKEYO:	.B	KEYACT,0	.EVEN	.END