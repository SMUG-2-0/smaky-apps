	.SBTTL	DISKMISC.ASI;--------\\; OPEVAR  >;========/; Ouvre les variables globales.; in	A3.L	^nom du disque; out	A6.L	^variables;	A0.L	^descripteur fentre;	D7.W	erreur; mod	D7.W, A0.L, A6.LOPEVAR:	PUSHM.L	D1,D4,A3,A4	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP',NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	A4,#(A6)+OBUNAMXFER$:	LOAD.B	(A4+),(A3+)	; OBUNAM <-- nom du disque	JUMP,NE XFER$	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentreEXIT$:	POPM.L	D1,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CLOVAR  >;========/; Ferme les variables globales.; in	A6.L	^variables; out	-; mod	-CLOVAR:	PUSHM.L	D1,D7,A4	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend mmoire pour variables	POPM.L	D1,D7,A4	RET;-------------\\; CALCPOURCENT >;=============/; Calcul le pourcentage utilis connaissant la quantit utilise; et la quantit restante.;	      U;	P = ----- * 100;	     U+R; in	D0.L	reste;	D1.L	utilis; out	D4.L	pourcent (0..100); mod	D4.L, D7.WCALCPOURCENT:	PUSHM.L	D0..D2	ADD.L	D0,D1		; D0 <-- U+R, D1 <-- U	CLR.W	D2	COMP.L	D0,#10000	JUMP',LO 20$		;	  0 ..   9'999 => /1	LOAD.W	D2,#3		;    10'000 ..  99'999 => /8	COMP.L	D0,#100000	;   100'000 .. 999'999 => /64	JUMP',LO 20$		; 1'000'000 .. infini  => /512	LOAD.W	D2,#6	COMP.L	D0,#1000000	JUMP',LO 20$	LOAD.W	D2,#920$:	SR.L	D0,D2		; D0 <-- R/1 ou R/8 ou R/64	SR.L	D1,D2		; D1 <-- U/1 ou U/8 ou U/64	MUL.WU	D1,#100	DIV.WU	D1,D0		; D1 <-- (U*100)/(U+R)	CLR.L	D4	LOAD.W	D4,D1		; D4 <-- utilis en %	POPM.L	D0..D2	RET;--------\\; DBOXRSK >;--------/; Refait les soft-keys.; in	A2.L	^table DBOX; out	-; mod	-DBOXRSK:	PUSHM.L	D3,D7,A3	LOAD.W	D3,(A2)+2	LOAD.L	A3,#(A2)+(D3.W)	LIB	?AFMENU		; refait les soft-keys	POPM.L	D3,D7,A3	RET;--------\\; ERCALL  >;========/; Essaye de rsoudre une erreur.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,A2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.L	A2,#0		; A2 <-- mode "tendu";;?	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,A2	TEST.W	D7		; retour EQ/NE	RETERCALL2:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel;;?	LOAD.L	A2,#0		; A2 <-- mode "tendu"	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs DBOX_EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A3LOOP$:	TEST.B	(A3+)	JUMP',EQ EXIT$	COMP.B	(A3)-1,#CR	JUMP,NE LOOP$	CLR.B	(A3)-1		; remplace le <CR> par <0>EXIT$:	POP.L	A3	RET;--------\\; PUTANUM >;========/; Met un nombre dcimal dans un buffer.; in	D4.W	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	AND.L	D4,#H'FFFF	; D4 <-- nombre binaire	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	POPM.L	D2,D3,D4	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RET	.END