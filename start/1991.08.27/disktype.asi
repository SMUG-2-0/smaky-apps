	.SBTTL	DISKTYPE.ASI;-----------\\; _DISK_TYPE >;===========/; Choix d'un format pour un disque.; in	A3.L	^nom du disque;	D3.W	operating system (DISKOS*, 0=tous); out	D3.W	dernire touche (F0/F1);	D7.W	erreur; mod	D3.L, D7.W_DISK_TYPE:	PUSHM.L	D0..D2,D4,D5,A1..A6	CALL	OPEVAR		; A6 <-- ^variables globales	JUMP,NE QUIT$	LOAD.W	(A6)+OOS,D3	; OOS <-- operating system	CLR.W	(A6)+OOP	; OOP <-- normal	LOAD.L	A3,#(A6)+OBUNAM	; A3 <-- ^nom du disque	CALL	FMTSTATUS	; A4 <-- ^status	JUMP,NE EXIT$	LOAD.W	D7,#ERUTYP	; D7 <-- type d'unit incorrect	TEST.W	(A4)+OMNBFMTREC	; au moins un format FMT ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.L	A2,#R16"TDBOX_TYPE	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	CALL	DBTYPSLDRAW	; dessine la scroll-liste	CALL	NORMMOUSE	; souris: enlve le sablierLOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_TYPE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#F1	JUMP',EQ MODIF$	COMP.W	D3,#F0	JUMP',EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	CALL	DBTYPSLMOVE	; dplace la scroll-liste ...	JUMP,NE BIP$	JUMP	LOOP$MODIF$:	LOAD.W	D1,(A6)+OSLVAR+OSLCYS	COMP.W	D1,(A6)+OSLVAR+OSLCYN	JUMP,HS BIP$	DBOX_	CLOSE		; ferme la DBOX	LOAD.W	D4,(A6)+OSLVAR+OSLCYS	CALL	FMTSEARCH	; A4 <-- ^format FMT	JUMP',NE EXIT$	LOAD.L	A3,#(A6)+OBUNAM	; A3 <-- ^nom du disque	CALL	FMTFORMAT	; choix du format	JUMP'	EXIT$CANCEL$:			; ANNULE =>	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D7EXIT$:	CALL	CLOVAR		; rend les variables globalesQUIT$:	POPM.L	D0..D2,D4,D5,A1..A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBTYPSLDRAW >;------------/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WDBTYPSLDRAW:	PUSHM.L	D2..D4,A4,A5	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables scroll-liste	LOAD.W	D2,#2^BDBGCLABEL!11	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#2^BDBGCLABEL!10	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#10	ADD.W	D4,#10	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A5)+OSLPOS,D3	LOAD.L	(A5)+OSLDIM,D4;;?	SET.B	(A5)+OSLASV+OSCPAGE ; met les pages	SCROLL_	LDRAW		; dessine la scroll-liste vide	LOAD.W	D4,#1000	CALL	FMTSEARCH	; D4 <-- dernier rang trouv	LOAD.W	(A5)+OSLCYN,D4	JUMP',EQ EXIT$	LOAD.W	(A5)+OSLCYS,D4	CALL	FMTUSE		; A4/D4 <-- ^format FMT actuel/rang	JUMP',NE DRAW$	LOAD.W	(A5)+OSLCYS,D4DRAW$:	LOAD.L	A4,#R16"DBTYPSLCASE	LOAD.L	(A5)+OSLADL,A4	SCROLL_	LUPDATE		; dessine le contenu de la scroll-listeEXIT$:	POPM.L	D2..D4,A4,A5	RET;------------\\; DBTYPSLCASE >;------------/; Donne le texte contenu dans une case.; in	D3.W	rang de la case (0..n); out	A3.L	^contenu;	D3.W	zro; mod	D3.L, D7.W, A3.LDBTYPSLCASE:	PUSHM.L	D4,A2,A4	LOAD.W	D4,D3	CALL	FMTSEARCH	; A4 <-- ^format FMT	LOAD.L	A2,A4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,#R16"TBEG$BXFER$:	LOAD.B	(A3+),(A4+)	; OBUDIS <-- "Format "	JUMP,NE BXFER$	DEC.L	A3	TEST.W	(A6)+OOS	; tous les operating system ?	JUMP',NE SIZE$		; non => SIZE$	LOAD.L	A4,#R16"TDOS$	COMP.B	(A2)+OMFMTOS,#DISKOSDOS	JUMP',EQ TXFER$	LOAD.L	A4,#R16"TMAC$	COMP.B	(A2)+OMFMTOS,#DISKOSMAC	JUMP',EQ TXFER$	LOAD.L	A4,#R16"TSMA$OXFER$:	LOAD.B	(A3+),(A4+)	; OBUDIS <-- nom de l'operating system	JUMP,NE OXFER$	DEC.L	A3SIZE$:	LOAD.W	D4,(A2)+OMFMTFACE	MUL.WU	D4,(A2)+OMFMTCYL	MUL.WU	D4,(A2)+OMFMTSECT ; D4 <-- taille en nb de blocs	LOAD.W	D3,#2	COMP.W	(A2)+OMFMTLGSECT,#256	JUMP',EQ DIV$	LOAD.W	D3,#1	COMP.W	(A2)+OMFMTLGSECT,#512	JUMP',EQ DIV$	CLR.W	D3DIV$:	SR.L	D4,D3		; D4 <-- taille en kilos	EX.L	A3,A4	CALL	PUTANUM		; OBUDIS <-- nb de kilos	EX.L	A3,A4	LOAD.L	A4,#R16"TKBY$KXFER$:	LOAD.B	(A3+),(A4+)	; OBUDIS <-- "Koctets"	JUMP,NE KXFER$	DEC.L	A3	COMP.B	(A2)+OMFMTOS,#DISKOSSMAKY	JUMP,NE END$	LOAD.L	A4,#R16"TABLE$TLOOP$:	TEST.W	(A4)		; fin de la table ?	JUMP',EQ END$		; oui => END$	COMP.W	D4,(A4)+0	; taille totale correcte ?	JUMP',NE TNEXT$	LOAD.W	D3,(A2)+OMFMTLGSECT	COMP.W	D3,(A4)+2	; taille d'un bloc correcte ?	JUMP',NE TNEXT$	ADD.L	A4,#2+2TXFER$:	LOAD.B	(A3+),(A4+)	; OBUDIS <-- texte spcial	JUMP,NE TXFER$;	DEC.L	A3	JUMP'	END$TNEXT$:	ADD.L	A4,#2+2		; A4 <-- saute .W (2x)TSKIP$:	TEST.B	(A4+)		; A4 <-- saute .ASCIZ	JUMP,NE TSKIP$	LOAD.L	D3,A4	INC.L	D3	TCLR.L	D3:#0		; A4 <-- saute .EVEN	LOAD.L	A4,D3	JUMP	TLOOP$END$:	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^contenu	POPM.L	D4,A2,A4	CLR.W	D3		; D3 <-- pas de ligne	CLR.W	D7		; retour EQ	RETTBEG$:	.ASCIZ	"Format "TSMA$:	.ASCIZ	"SMAKY "TDOS$:	.ASCIZ	"DOS   "TMAC$:	.ASCIZ	"MAC   "TKBY$:	.ASCIZ	" Koctets  "	.EVENTABLE$:	.W	720,256	.ASCIZE	"(systme 6)"	.W	720,512	.ASCIZE	"(systme 7)"	.W	0;------------\\; DBTYPSLMOVE >;------------/; Dplace la scroll-liste.; in	-; out	D7.W	erreur; mod	D7.WDBTYPSLMOVE:	PUSHM.L	D3,D4,A5	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE EXIT$	SUB.W	D4,(A0)+ODFFX	JUMP',LO EXIT$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',LO EXIT$	SWAP.W	D4	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables scroll-liste	LOAD.W	D7,#1	TEST.W	(A5)+OSLCYN	JUMP',EQ EXIT$	SCROLL_	LMOVE		; dplace la scroll-liste ...EXIT$:	POPM.L	D3,D4,A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_TYPE:	.W	10$-TDBOX_TYPE	.W	20$-TDBOX_TYPE	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"Choix du format pour le disque :"	.B	ODBCR,ODBCR	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,40	.B	ODBLABEL,11	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" CHOIX "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Choix"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_TYPE:	.W	F1,F2,F3,0		DOKF1-TKEY_TYPE	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_TYPE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_TYPE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_TYPE	.W	0	.END