	.SBTTL	DISKIO.ASI;----------\\; FMTFORMAT >;==========/; Choix d'un format FMT.; in	A3.L	^nom du disque;	A4.L	^format FMT; out	D7.W	erreur; mod	D7.WFMTFORMAT:	PUSHM.L	D0,D3,D6,A4	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	(A6)+OBUDIS,(A4)+OMFMTMODECMD	CLR.B	(A6)+OBUDIS+4	LOAD.L	D3,#2^BOPEXTEND!2^BOPMMUNIT!2^BOPRSTATUS	LOAD.L	D0,#FOS?ARGSOPEN	CALL	ERCALL		; ouvre le floppy	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D3,#TYPMM	FOS	?COMMAND	; envoie la commande	PUSH.W	D7	FOS	?CLOSE		; ferme le floppy	POP.W	D7EXIT$:	POPM.L	D0,D3,D6,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; FMTSEARCH >;==========/; Cherche un format de disque FMT; in	D4.W	rang (0..n); out	D4.W	rang trouv (0..n);	A4.L	^format trouv;	D7.W	erreur; mod	D4.L, D7.W, A4.LFMTSEARCH:	PUSHM.L	D1..D3	LOAD.L	A4,#(A6)+OBUSTA	; A4 <-- ^status	LOAD.W	D1,(A6)+OOS	; D1 <-- operating system	LOAD.W	D3,D4		; D3 <-- rang cherch	CLR.W	D4		; D4 <-- rang actuel	LOAD.W	D2,(A4)+OMNBFMTREC	LOAD.L	A4,#(A4)+LGMAM3	; A4 <-- ^premier format FMT	TEST.W	D2	JUMP',EQ ERROR$	CLR.W	D7		; D7 <-- trouvLOOP$:	COMP.W	(A6)+OOP,#1	; formate ?	JUMP',NE FORM$		; non => FORM$	TEST.B	(A4)+OMFMTFLAG:#BMFMTNOFORM ; formatage impossible ?	JUMP',BS NEXT$		; oui => NEXT$FORM$:	TEST.W	D1		; tous les operating system ?	JUMP',EQ COMP$		; oui => COMP$	COMP.B	D1,(A4)+OMFMTOS	; est-ce le bon operating system ?	JUMP',NE NEXT$		; non => NEXT$COMP$:	COMP.W	D3,D4	JUMP',EQ EXIT$	INC.W	D4		; D4 <-- rang suivantNEXT$:	LOAD.L	A4,#(A4)+LGMFMTREC ; A4 <-- ^format FMT suivant	DEC.W	D2	JUMP,NE LOOP$ERROR$:	LOAD.W	D7,#1		; D7 <-- pas trouvEXIT$:	POPM.L	D1..D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; FMTUSE  >;========/; Cherche le format FMT actuellement utilis.; in	-; out	A4.L	^format FMT actuel;	D4.W	rang (0..n);	D7.W	erreur; mod	D4.L, D7.W, A4.LFMTUSE:	PUSHM.L	D1,D3	LOAD.L	A4,#(A6)+OBUSTA	; A4 <-- ^status	LOAD.W	D7,#1		; D7 <-- pas trouv	CLR.W	D4		; D4 <-- rang	LOAD.W	D3,(A4)+OMNBFMTREC	LOAD.L	A4,#(A4)+LGMAM3	; A4 <-- ^premier format FMT	TEST.W	D3	JUMP',EQ EXIT$	LOAD.W	D1,(A6)+OOS	; D1 <-- operating systemLOOP$:	COMP.W	(A6)+OOP,#1	; formate ?	JUMP',NE FORM$		; non => FORM$	TEST.B	(A4)+OMFMTFLAG:#BMFMTNOFORM ; formatage impossible ?	JUMP',BS NEXT$		; oui => NEXT$FORM$:	TEST.W	D1		; tous les operating system ?	JUMP',EQ COMP$		; oui => COMP$	COMP.B	D1,(A4)+OMFMTOS	; est-ce le bon operating system ?	JUMP',NE NEXT$		; non => NEXT$COMP$:	TEST.B	(A4)+OMFMTFLAG:#BMFMTCURMODE ; pilote dans ce mode ?	JUMP',BS OK$		; oui => OK$	INC.W	D4		; D4 <-- rang suivantNEXT$:	LOAD.L	A4,#(A4)+LGMFMTREC ; A4 <-- ^format FMT suivant	DEC.W	D3	JUMP,NE LOOP$	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- trouvEXIT$:	POPM.L	D1,D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; FMTSTATUS >;==========/; Lit le status complet d'un disque.; in	A3.L	^nom du disque; out	A4.L	^status complet;	D7.W	erreur; mod	D7.W, A4.LFMTSTATUS:	PUSHM.L	D0,D3,D4,D6	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	D3,#2^BOPEXTEND!2^BOPMMUNIT!2^BOPRSTATUS	LOAD.L	D0,#FOS?ARGSOPEN ; ouvre le disque	CALL	ERCALL	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OBUSTA	; A4 <-- ^buffer	LOAD.L	D4,#LGMAM3	LOAD.W	D3,#TYPMM	FOS	?RSTATUS	; lit le status sans les records FMT	JUMP',NE CLOSE$	LOAD.W	D4,(A4)+OMNBFMTREC ; D4 <-- nb de records FMT	JUMP',EQ CLOSE$	COMP.W	D4,#MAXFMT	JUMP',LS MAX$	LOAD.W	D4,#MAXFMTMAX$:	MUL.WU	D4,#LGMFMTREC	ADD.L	D4,#LGMAM3;	LOAD.W	D3,#TYPMM	FOS	?RSTATUS	; relit le status avec les records FMTCLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le disque	POP.W	D7EXIT$:	POPM.L	D0,D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; MINSTATUS >;==========/; Lit le status minimum d'un disque (pas d'accs physique).; in	A3.L	^nom du disque; out	A4.L	^status minimal;	D7.W	erreur; mod	D7.W, A4.LMINSTATUS:	PUSHM.L	D0,D3,D4,D6	LOAD.L	D3,#2^BOPEXTEND!2^BOPMMUNIT!2^BOPRSTATUS	LOAD.L	D0,#FOS?ARGSOPEN ; ouvre le disque	CALL	ERCALL	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OBUSTA	; A4 <-- ^buffer	LOAD.L	D4,#LGMAM3	LOAD.W	D3,#TYPMM	FOS	?RSTATUS	; lit le status sans les records FMT	JUMP',EQ CLOSE$	GESMEM	?CLEARMEM	LOAD.L	D4,#LGMAM0;	LOAD.W	D3,#TYPMM	FOS	?RSTATUS	; lit le status le plus simple !CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le disque	POP.W	D7EXIT$:	POPM.L	D0,D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; PFORMAT >;========/; Formate physiquement une disquette.; in	A3.L	^nom du disque; out	D7.W	erreur; mod	D7.WPFORMAT:	PUSHM.L	D0,D3,D6,A4	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	D3,#2^BOPEXTEND!2^BOPMMUNIT!2^BOPRSTATUS	LOAD.L	D0,#FOS?ARGSOPEN	CALL	ERCALL		; ouvre le floppy	JUMP',NE EXIT$	LOAD.L	A4,#R16"COM$	LOAD.W	D3,#TYPMM	FOS	?COMMAND	; envoie la commande	PUSH.W	D7	FOS	?CLOSE		; ferme le floppy	POP.W	D7EXIT$:	POPM.L	D0,D3,D6,A4	TEST.W	D7		; retour EQ/NE	RETCOM$:	.ASCIZ	"F"		; commande de formatage	.EVEN;--------\\; LFORMAT >;========/; Formate logiquement une disquette.; in	A3.L	^nom du disque;	A4.L	^nom logique; out	D7.W	erreur; mod	D7.WLFORMAT:	PUSHM.L	D0,D3,D4,A2..A4	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A2,A4		; A2 <-- ^nom de la disquette	LOAD.W	D4,#HACHE	; D4 <-- valeur de hachage standard	LOAD.L	A5,#R16"NDSYS$	; A5 <-- ^nom du dossier systme	LOAD.L	D3,#2^BFRLIST!2^BFRNAME!2^BFRSYS	LOAD.L	D0,#FOS?NFORMAT	CALL	ERCALL2		; format software de l'unit ...	JUMP',NE EXIT$	LOAD.L	A4,A3		; A4 <-- ^nom du disqueSKIP$:	TEST.B	(A4+)	JUMP,NE SKIP$	DEC.L	A4	LOAD.L	A2,#R16"NDVIDE$XFER$:	LOAD.B	(A4+),(A2+)	; nom du disque <-- ajoute "DOSSIER:"	JUMP,NE XFER$	LOAD.W	D3,#1		; D3 <-- valeur de hachage minimale	CLR.L	D4		; D4 <-- lg max	FOS	?CDIR		; crer le dossier vide "DOSSIER:"	JUMP',NE EXIT$	LOAD.L	A4,A3END$:	TEST.B	(A4+)	JUMP,NE END$	LOAD.B	(A4)-2,#'.	LOAD.B	(A4)-1,#'D	LOAD.B	(A4)+0,#'I	LOAD.B	(A4)+1,#'R	CLR.B	(A4)+2	LOAD.L	D3,#2^BATTM!2^BATTS!2^BATTG!2^BATTA!2^BATTZ!2^BATTP!2^BATTL	FOS	?CHATR		; enlve les attributs "R", "W" et "C"EXIT$:	POPM.L	D0,D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETNDSYS$:	.ASCIZ	""		; dossier systmeNDVIDE$:.ASCIZ	"DOSSIER:"	; dossier toujours prsent	.EVEN	.END