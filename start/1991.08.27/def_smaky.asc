	.TITLE	DEF_SMAKY.ASC;	--------------------------------------;		(C) 1991 - Daniel Roux;	--------------------------------------;	Source du programme DEF_SMAKY.CODE	.PROC	M680002	.RADIX	10.	.HEXDEFREV	=	1		; rvisionDEFVERS	=	1		; version;	Date		Amliorations; --------------------------------------------------------------------------------------------------; 1.1	23.05.91	priorit plus leve (23 -> 11); 1.0	16.05.91	premire version	.REF	SMAKY	.REF	MODULES;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;SMAKY300 = 7OINVOL = OINSTA+4		; volume du h-p dans 100_INFO;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.REV	DEFREV,DEFVERS;;?	.HEADER	OBXSOVER.L OVERLAY	; faire "HEADER DEF_SMAKY.CODE 16/O" !!!	.CODE	800,11,B'100111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LBUDIS	=	20KEYDBOX	=	H'7E00		; "touche" pour dbox; Fanions pour OINSTA; -------------------BINFK10	=	0		; dbox info:  l'enfoncementBINFK11	=	1		; dbox info: BINFK12	=	2		; dbox info: BINFK13	=	3		; dbox info: BINFK20	=	4		; dbox info: par la suiteBINFK21	=	5		; dbox info: BINFK22	=	6		; dbox info: BINFK23	=	7		; dbox info: BINFS0	=	8		; dbox info: sleep jamaisBINFS5	=	9		; dbox info: sleep 5'BINFS15	=	10		; dbox info: sleep 15'BINFS60	=	11		; dbox info: sleep 60'BINFMD0	=	16		; dbox info: dplacement sourisBINFMD1	=	17		; dbox info: BINFMD2	=	18		; dbox info: BINFMA0	=	19		; dbox info: acclration sourisBINFMA1	=	20		; dbox info: BINFMA2	=	21		; dbox info: BINFDIA	=	24		; dbox info: diaposBINFLRD	=	25		; dbox info: liste rduite dans les dossiers (voir module LIST)BINFBSA	=	26		; dbox info: beep selon 300_SYNT.AUDIO; Variables; ---------	.LOC	0OPLCOM:	.BLKB	4		; ^ligne de commandeOBUDIS:	.BLKB	LBUDIS		; buffer temporaireOMOUSE:	.BLKB	1		; mode souris initialOMACHINE:.BLKB	1		; type de la machine (SMAKY*)	.EVENOCHMENU:.BLKB	4		; canal des soft-keysLGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	CALL	OVERLAY	LIB	?CLOLIB	FOS	?STOPOVERLAY:	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE EXIT$	GESMEM	?CLEARMEM	; met TOUTES les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; OPLCOM <-- ^ligne de commande	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	NTREL	?GETMACHINE	RL.L	D4,#8	LOAD.B	(A6)+OMACHINE,D4	LOAD.L	A3,(A6)+OPLCOM	LOAD.B	D3,#'I	LIB	?IFSWITCH	; excut avec /i ?	JUMP',EQ INIT$		; oui => INIT$	CALL	DBOXMAIN	; appel dbox principale ...	JUMP',EQ END$	JUMP'	NOOVER$INIT$:	CALL	INFOREAD	; D4/D2 <-- fanions/volume	CALL	INFOMAJ		; met  jour selon les informations	JUMP'	END$NOOVER$:	LOAD.W	D7,#-1		; D7 <-- demande une excution normaleEND$:	PUSH.W	D7	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre les variables	POP.W	D7EXIT$:	RET;---------\\; DBOXMAIN >;=========/; Modifie quelques informations gnrales sur la machine.; in	-; out	D7.W	erreur; mod	D7.WDBOXMAIN:	PUSHM.L	D0..D6,A1..A5	LIB	?PUSHMENU	; sauve les soft-keys	LOAD.L	(A6)+OCHMENU,D5	LIB	?GMOUSE	LOAD.B	(A6)+OMOUSE,D3	LOAD.W	D3,#2	LIB	?MOUSE		; souris par le clavier	CALL	NORMMOUSE	; souris: enlve le sablier	CALL	INFOREAD	; D4/D2 <-- fanions/volume	CLR.W	D0		; D0 <-- nb de modificationsOPEN$:	PUSH.L	D2	LOAD.L	A2,#R16"TDBOX_MAIN	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	POPM.L	D2	JUMP,NE	EXIT$	PUSH.W	D2	LOAD.L	A4,#R16"IECRAN	LOAD.W	D2,#F1!2^BDBGCLABEL	CALL	DRAWICO	LOAD.L	A4,#R16"ICLAVIER	LOAD.W	D2,#F2!2^BDBGCLABEL	CALL	DRAWICO	LOAD.L	A4,#R16"ISOURIS	LOAD.W	D2,#F3!2^BDBGCLABEL	CALL	DRAWICO	LOAD.L	A4,#R16"IAUDIO	LOAD.W	D2,#F4!2^BDBGCLABEL	CALL	DRAWICO	POP.W	D2	COMP.B	(A6)+OMACHINE,#SMAKY300	JUMP',EQ LOOP$	PUSHM.L	D2,D4	LOAD.W	D2,#F4!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	POPM.L	D2,D4LOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_MAIN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	LOAD.L	D6,D4		; D6 <-- fanions	LOAD.L	D1,D2		; D1 <-- volume	COMP.W	D3,#F1	JUMP',EQ ECR$	COMP.W	D3,#F2	JUMP',EQ CLA$	COMP.W	D3,#F3	JUMP',EQ SOU$	COMP.W	D3,#F4	JUMP',EQ HP$	COMP.W	D3,#F0	JUMP,EQ END$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ECR$:	DBOX_	CLOSE		; ferme la DBOX	CALL	DBOXECRAN	; choix pour l'cran ...	JUMP'	MAJ$CLA$:	DBOX_	CLOSE		; ferme la DBOX	CALL	DBOXCLAVIER	; choix pour le clavier ...	JUMP'	MAJ$SOU$:	DBOX_	CLOSE		; ferme la DBOX	CALL	DBOXSOURIS	; choix pour la souris ...	JUMP'	MAJ$HP$:	COMP.B	(A6)+OMACHINE,#SMAKY300	JUMP,NE BIP$	DBOX_	CLOSE		; ferme la DBOX	CALL	DBOXAUDIO	; choix pour le haut-parleur ...;	JUMP'	MAJ$MAJ$:	JUMP',NE CANCEL$	COMP.W	D3,#F1	JUMP',NE CANCEL$	INC.W	D0		; D0 <-- une modification de plus	JUMP	OPEN$CANCEL$:	LOAD.L	D4,D6		; D4 <-- anciens fanions	LOAD.L	D2,D1		; D2 <-- ancien volume	CALL	INFOMAJ		; met  jour selon les anciennes informations	JUMP	OPEN$END$:				; ANNULE =>	TEST.W	D0		; y a-t-il eu des modifications ?	JUMP',EQ END2$		; non => END2$	CALL	INFOWRITE	; crit les informationsEND2$:	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D7EXIT$:	PUSH.W	D7	LOAD.B	D3,(A6)+OMOUSE	LIB	?MOUSE		; remet le mode souris initial	LOAD.L	D5,(A6)+OCHMENU	LIB	?POPMENU	; restitue les soft-keys	CALL	NORMMOUSE	; souris: enlve le sablier	POP.W	D7	POPM.L	D0..D6,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_MAIN:	.W	10$-TDBOX_MAIN	.W	20$-TDBOX_MAIN	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"Dfinitions gnrales du SMAKY :"	.B	ODBCR,ODBCR,ODBCR2	.B	ODBLABEL,F1	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"   ECRAN    "	.B	ODBCR,ODBCR,ODBCR2	.B	ODBLABEL,F2	.B	ODBBOX,0,F2,TDBMEV	.ASCIZ	"  CLAVIER   "	.B	ODBCR,ODBCR,ODBCR2	.B	ODBLABEL,F3	.B	ODBBOX,0,F3,TDBMEV	.ASCIZ	"   SOURIS   "	.B	ODBCR,ODBCR,ODBCR2	.B	ODBLABEL,F4	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	"HAUT-PARLEUR"	.B	ODBTABX,25	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" TERMINE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	"       Cla-  Sou-"	.ASCIZ	"Ecran  vier  ris "		;     ;     ;     ;	.ASCIZ	" Haut-           "	.ASCIZ	"parleur          "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Termine"	.EVENTKEY_MAIN:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_MAIN	.W	F1,0			DOKF1-TKEY_MAIN	.W	F2,0			DOKF2-TKEY_MAIN	.W	F3,0			DOKF3-TKEY_MAIN	.W	F4,0			DOKF4-TKEY_MAIN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MAIN	.W	0;----------\\; DBOXECRAN >;==========/; Modifie quelques informations gnrales sur l'cran.; in	D4.L	fanions; out	D4.L	fanions;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXECRAN:	PUSHM.L	D1,D2,D5,A1..A5	LOAD.L	A2,#R16"TDBOX_ECRAN	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$LOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_ECRAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP,EQ MODIF$	COMP.W	D3,#F0	JUMP,EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$MODIF$:				; MODIFIE =>CANCEL$:			; ANNULE =>	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_ECRAN:	.W	10$-TDBOX_ECRAN	.W	20$-TDBOX_ECRAN	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"Endort le SMAKY:"	.B	ODBTABX,18	.B	ODBLCIRCLE,BINFS5	.ASCIZ	" aprs  5' d'inactivit"	.B	ODBCR	.B	ODBTABX,18	.B	ODBLCIRCLE,BINFS15	.ASCIZ	" aprs 15' d'inactivit"	.B	ODBCR	.B	ODBTABX,18	.B	ODBLCIRCLE,BINFS60	.ASCIZ	" aprs 60' d'inactivit"	.B	ODBCR	.B	ODBTABX,18	.B	ODBLCIRCLE,BINFS0	.ASCIZ	" jamais"	.B	ODBCR,ODBCR	.B	ODBSQUARE,BINFDIA	.ASCIZ	" commutation de fentre rapide"	.B	ODBCR,ODBCR	.B	ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_ECRAN:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_ECRAN	.W	F1,F2,F3,CR,0		DOKF1-TKEY_ECRAN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_ECRAN	.W	0;------------\\; DBOXCLAVIER >;============/; Modifie quelques informations gnrales sur le clavier.; in	D4.L	fanions; out	D4.L	fanions;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXCLAVIER:	PUSHM.L	D0..D2,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_CLAVIER	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	CLR.B	(A4)LOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_CLAVIER	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP',EQ MODIF$	COMP.W	D3,#F0	JUMP',EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#KEYDBOX+BINFK10	JUMP',LO BIP$	COMP.W	D3,#KEYDBOX+BINFK13	JUMP',LS PREM$	COMP.W	D3,#KEYDBOX+BINFK20	JUMP',LO BIP$	COMP.W	D3,#KEYDBOX+BINFK23	JUMP',LS SUITE$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$PREM$:	AND.W	D4,#-1-(2^BINFK10!2^BINFK11!2^BINFK12!2^BINFK13)	JUMP'	MAJ$SUITE$:	AND.W	D4,#-1-(2^BINFK20!2^BINFK21!2^BINFK22!2^BINFK23)MAJ$:	TSET.L	D4:D3	CALL	INFOMAJCLAVIER	; met  jour le clavier	JUMP	UNDO$MODIF$:				; MODIFIE =>CANCEL$:			; ANNULE =>	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D0..D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CLAVIER:	.W	10$-TDBOX_CLAVIER	.W	20$-TDBOX_CLAVIER	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"    - Rptition du clavier -"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"A l'enfoncement :"	.B	ODBTABX,20	.B	ODBTEXT	.ASCIZ	"Par la suite : "	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,BINFK10!2^7!2^6,KEYDBOX/H'100,BINFK10	.ASCIZ	" aucune"	.B	ODBTABX,20	.B	ODBLCIRCLE,BINFK20!2^7!2^6,KEYDBOX/H'100,BINFK20	.ASCIZ	" aucune"	.B	ODBCR	.B	ODBLCIRCLE,BINFK11!2^7!2^6,KEYDBOX/H'100,BINFK11	.ASCIZ	" lente"	.B	ODBTABX,20	.B	ODBLCIRCLE,BINFK21!2^7!2^6,KEYDBOX/H'100,BINFK21	.ASCIZ	" lente"	.B	ODBCR	.B	ODBLCIRCLE,BINFK12!2^7!2^6,KEYDBOX/H'100,BINFK12	.ASCIZ	" normale"	.B	ODBTABX,20	.B	ODBLCIRCLE,BINFK22!2^7!2^6,KEYDBOX/H'100,BINFK22	.ASCIZ	" normale"	.B	ODBCR	.B	ODBLCIRCLE,BINFK13!2^7!2^6,KEYDBOX/H'100,BINFK13	.ASCIZ	" rapide"	.B	ODBTABX,20	.B	ODBLCIRCLE,BINFK23!2^7!2^6,KEYDBOX/H'100,BINFK23	.ASCIZ	" rapide"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Pour essayer : "	.B	ODBCLINE,16	.B	ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CLAVIER:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_CLAVIER	.W	F1,F2,F3,CR,0		DOKF1-TKEY_CLAVIER	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CLAVIER	.W	0;-----------\\; DBOXSOURIS >;===========/; Modifie quelques informations gnrales sur la souris.; in	D4.L	fanions; out	D4.L	fanions;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXSOURIS:	PUSHM.L	D0..D2,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_SOURIS	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	COMP.B	(A6)+OMACHINE,#SMAKY100	JUMP',NE LOOP$	PUSH.L	D4	LOAD.W	D2,#101!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BINFMA0!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BINFMA1!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BINFMA2!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	POP.L	D4	AND.L	D4,#-1-(2^BINFMA0!2^BINFMA1!2^BINFMA2)LOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_SOURIS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP',EQ MODIF$	COMP.W	D3,#F0	JUMP',EQ CANCEL$	COMP.W	D3,#KEYDBOX+BINFMD0	JUMP',LO BIP$	COMP.W	D3,#KEYDBOX+BINFMD2	JUMP',LS DEPL$	COMP.W	D3,#KEYDBOX+BINFMA0	JUMP',LO BIP$	COMP.W	D3,#KEYDBOX+BINFMA2	JUMP',LS ACC$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$DEPL$:	AND.L	D4,#-1-(2^BINFMD0!2^BINFMD1!2^BINFMD2)	JUMP'	MAJ$ACC$:	AND.L	D4,#-1-(2^BINFMA0!2^BINFMA1!2^BINFMA2)MAJ$:	TSET.L	D4:D3	CALL	INFOMAJSOURIS	; change la souris	JUMP	LOOP$MODIF$:				; MODIFIE =>CANCEL$:			; ANNULE =>	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D0..D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_SOURIS:	.W	10$-TDBOX_SOURIS	.W	20$-TDBOX_SOURIS	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"- Dfinitions pour la souris -  "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Dplacement :"	.B	ODBTABX,17	.B	ODBLABEL,101	.B	ODBTEXT	.ASCIZ	"Acclration :"	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,BINFMD0!2^7!2^6,KEYDBOX/H'100,BINFMD0	.ASCIZ	" court"	.B	ODBTABX,17	.B	ODBLABEL,BINFMA0	.B	ODBLCIRCLE,BINFMA0!2^7!2^6,KEYDBOX/H'100,BINFMA0	.ASCIZ	" nulle"	.B	ODBCR	.B	ODBLCIRCLE,BINFMD1!2^7!2^6,KEYDBOX/H'100,BINFMD1	.ASCIZ	" normal"	.B	ODBTABX,17	.B	ODBLABEL,BINFMA1	.B	ODBLCIRCLE,BINFMA1!2^7!2^6,KEYDBOX/H'100,BINFMA1	.ASCIZ	" normale"	.B	ODBCR	.B	ODBLCIRCLE,BINFMD2!2^7!2^6,KEYDBOX/H'100,BINFMD2	.ASCIZ	" long"	.B	ODBTABX,17	.B	ODBLABEL,BINFMA2	.B	ODBLCIRCLE,BINFMA2!2^7!2^6,KEYDBOX/H'100,BINFMA2	.ASCIZ	" forte"	.B	ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_SOURIS:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_SOURIS	.W	F1,F2,F3,CR,0		DOKF1-TKEY_SOURIS	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_SOURIS	.W	0;----------\\; DBOXAUDIO >;==========/; Modifie quelques informations gnrales sur l'audio.; in	D2.B	volume;	D4.L	fanions; out	D2.B	volume;	D4.L	fanions;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.WDBOXAUDIO:	PUSHM.L	D0,D1,D5,A1..A4	LOAD.L	D0,D4		; D0 <-- fanions originaux	LOAD.W	D4,#2^0	TEST.B	D2	JUMP',EQ INIT$	SL.W	D4,#1	COMP.B	D2,#64	JUMP',LO INIT$	SL.W	D4,#1	COMP.B	D2,#128	JUMP',LO INIT$	SL.W	D4,#1	COMP.B	D2,#192	JUMP',LO INIT$	SL.W	D4,#1		; D4 <-- fanionsINIT$:	PUSH.L	D2	LOAD.L	A2,#R16"TDBOX_AUDIO	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	POPM.L	D2	JUMP,NE	EXIT$LOOP$:	CALL	NORMMOUSE	; souris: enlve le sablier	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_AUDIO	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP',EQ MODIF$	COMP.W	D3,#F0	JUMP',EQ CANCEL$	COMP.W	D3,#KEYDBOX+BINFBSA	JUMP',EQ TESTF$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ TESTV$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$TESTV$:	CALL	AUDIOPUT	; D2 <-- volume	CALL	INFOMAJAUDI1	; modifie le volume	LIB	?BUZZ		; p'tite exprience !	JUMP	LOOP$TESTF$:	CALL	WAITMOUSE	; souris: met le sablier	CALL	INFOMAJAUDI2	; modifie selon les fanions	LIB	?BUZZ		; p'tite exprience !	JUMP	LOOP$MODIF$:				; MODIFIE =>	CALL	AUDIOPUT	; D2 <-- volume	LOAD.W	D4,D0		; D4 <-- fanionsCANCEL$:			; ANNULE =>	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D0,D1,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_AUDIO:	.W	10$-TDBOX_AUDIO	.W	20$-TDBOX_AUDIO	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"Niveau du haut-parleur : "	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,0!2^7,KEYDBOX/H'100,0	.ASCIZ	" 0 (silence)"	.B	ODBCR	.B	ODBLCIRCLE,1!2^7,KEYDBOX/H'100,1	.ASCIZ	" 1"	.B	ODBCR	.B	ODBLCIRCLE,2!2^7,KEYDBOX/H'100,2	.ASCIZ	" 2"	.B	ODBCR	.B	ODBLCIRCLE,3!2^7,KEYDBOX/H'100,3	.ASCIZ	" 3"	.B	ODBCR	.B	ODBLCIRCLE,4!2^7,KEYDBOX/H'100,4	.ASCIZ	" 4 (maximum)"	.B	ODBCR,ODBCR2	.B	ODBSQUARE,BINFBSA!2^7,KEYDBOX/H'100,BINFBSA	.ASCIZ	" bips selon 300_SYNT.AUDIO"	.B	ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_AUDIO:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_AUDIO	.W	F1,F2,F3,CR,0		DOKF1-TKEY_AUDIO	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_AUDIO	.W	0;---------\\; AUDIOPUT >;---------/; in	D4.L	fanions; out	D2.B	volume; mod	D2.L, D7.WAUDIOPUT:	PUSH.W	D4	CLR.B	D2	RR.W	D4,#1	JUMP',CS EXIT$	LOAD.B	D2,#32	RR.W	D4,#1	JUMP',CS EXIT$	LOAD.B	D2,#96	RR.W	D4,#1	JUMP',CS EXIT$	LOAD.B	D2,#160	RR.W	D4,#1	JUMP',CS EXIT$	LOAD.B	D2,#224EXIT$:	POP.W	D4	RET;---------\\; INFOREAD >;=========/; Lit les informations.; in	-; out	D4.L	fanions;	D2.W	volume; mod	D2.L, D4.L, D7.WINFOREAD:	PUSHM.L	D3,A4	FOS	?OPINFO		; A4 <-- ^contenu de SYS_INFO	LOAD.L	D3,(A4)+OINSTA	; D3 <-- informations pour START	LOAD.B	D2,(A4)+OINVOL	; D2 <-- volume h-p	CLR.W	D4		; D4 <-- pas de mise  jour	FOS	?CLINFO	LOAD.L	D4,D3		; D4 <-- fanions	TEST.L	D4	JUMP',NE INIT2$	LOAD.L	D4,#2^BINFK12!2^BINFK23INIT2$:	TEST.L	D4:#BINFS0	JUMP',BS INIT4$;	TEST.L	D4:#BINFS5;	JUMP',BS INIT4$	TEST.L	D4:#BINFS15	JUMP',BS INIT4$	TEST.L	D4:#BINFS60	JUMP',BS INIT4$	TSET.L	D4:#BINFS5INIT4$:	TEST.L	D4:#BINFMD0	JUMP',BS INIT6$;	TEST.L	D4:#BINFMD1;	JUMP',BS INIT6$	TEST.L	D4:#BINFMD2	JUMP',BS INIT6$	TSET.L	D4:#BINFMD1INIT6$:	TEST.L	D4:#BINFMA0	JUMP',BS INIT7$;	TEST.L	D4:#BINFMA1;	JUMP',BS INIT7$	TEST.L	D4:#BINFMA2	JUMP',BS INIT7$	TSET.L	D4:#BINFMA1INIT7$:	POPM.L	D3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; INFOWRITE >;==========/; Ecrit les informations.; in	D4.L	fanions;	D2.W	volume; out	D7.W	erreur; mod	D7.WINFOWRITE:	PUSHM.L	D4,A4	CALL	WAITMOUSE	; souris: met le sablier	FOS	?OPINFO		; A4 <-- ^contenu de SYS_INFO	LOAD.L	(A4)+OINSTA,D4	LOAD.B	(A4)+OINVOL,D2	LOAD.W	D4,#1		; D4 <-- mise  jour	FOS	?CLINFOEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; INFOMAJ >;========/; Met tout  jour selon les informations.; in	D4.L	fanions;	D2.W	volume; out	-; mod	D7.WINFOMAJ:	CALL	INFOMAJCLAVIER	; mise  jour le clavier	CALL	INFOMAJSOURIS	; mise  jour la souris	CALL	INFOMAJAUDI1	; mise  jour le volume	CALL	INFOMAJAUDI2	; mise  jour l'audio	CLR.W	D7		; D7 <-- ok	RET;---------------\\; INFOMAJCLAVIER >;===============/; Met  jour le clavier en fonction des fanions.; in	D4.L	fanions; out	-; mod	D7.WINFOMAJCLAVIER:	PUSHM.L	D2..D4	LOAD.L	D2,D4	LOAD.W	D3,#20	TEST.L	D2:#BINFK13	JUMP',BS KEY1$	LOAD.W	D3,#40	TEST.L	D2:#BINFK12	JUMP',BS KEY1$	LOAD.W	D3,#80	TEST.L	D2:#BINFK11	JUMP',BS KEY1$	LOAD.W	D3,#-1KEY1$:	LOAD.W	D4,#2!2^15	TEST.L	D2:#BINFK23	JUMP',BS KEY2$	LOAD.W	D4,#6!2^15	TEST.L	D2:#BINFK22	JUMP',BS KEY2$	LOAD.W	D4,#16!2^15	TEST.L	D2:#BINFK21	JUMP',BS KEY2$	LOAD.W	D4,#255!2^15KEY2$:	LIB	?REPKEY	POPM.L	D2..D4	RET;--------------\\; INFOMAJSOURIS >;==============/; Met  jour la souris en fonction des fanions.; in	D4.L	fanions; out	-; mod	D7.WINFOMAJSOURIS:	PUSHM.L	D2..D4,D6,A4	LOAD.L	D2,D4	CLR.W	D3	TEST.L	D2:#BINFMD0	JUMP',BS MOUSD$	LOAD.W	D3,#2	TEST.L	D2:#BINFMD2	JUMP',BS MOUSD$	LOAD.W	D3,#1MOUSD$:	LOAD.W	D4,#H'100*10+10	TEST.L	D2:#BINFMA0	JUMP',BS MOUSA$	LOAD.W	D4,#H'100*2+4	TEST.L	D2:#BINFMA2	JUMP',BS MOUSA$	LOAD.W	D4,#H'100*5+5MOUSA$:	LIB	?GCHMOU		; D6 <-- canal de la souris 	LOAD.L	A4,#(A6)+OBUDIS+1	LOAD.B	(A4)+0,#'S	; <S>	LOAD.B	(A4)+1,D3	CLR.B	(A4)+2	COMP.B	(A6)+OMACHINE,#SMAKY100	JUMP',EQ COMM$	LOAD.B	(A4)+2,#'A	; <A>	LOAD.W	(A4)+3,D4	CLR.B	(A4)+5COMM$:	LOAD.W	D3,#TYPIO	; D3 <-- type du driver souris	FOS	?COMMAND	; change la vitesse de la souris	POPM.L	D2..D4,D6,A4	RET;-------------\\; INFOMAJAUDI1 >;=============/; Met  jour le haut-parleur en fonction du volume.; in	D2.B	volume; out	-; mod	D7.WINFOMAJAUDI1:	PUSHM.L	D3,D6,A3,A4	LOAD.L	A3,#R16"NAUDIO$	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre #AUDIO:	JUMP',NE EXIT$ 	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#'L	LOAD.B	(A4)+1,D2	CLR.B	(A4)+2	LOAD.W	D3,#TYPIO	; D3 <-- type du driver	FOS	?COMMAND	; change le volume	FOS	?CLOSE		; ferme #AUDIO:EXIT$:	POPM.L	D3,D6,A3,A4	RETNAUDIO$:.ASCIZ	"#AUDIO:"	.EVEN;-------------\\; INFOMAJAUDI2 >;=============/; Met  jour le haut-parleur en fonction des fanions.; in	D4.L	fanions; out	-; mod	D7.WINFOMAJAUDI2:	PUSHM.L	D3,D6,A3,A4	COMP.B	(A6)+OMACHINE,#SMAKY300	JUMP',NE EXIT$	LOAD.L	A3,#R16"NSYNT$	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre #SYNTHESIZER:	JUMP',NE EXIT$ 	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#'F	LOAD.B	(A4)+1,#'+	TEST.L	D4:#BINFBSA	JUMP',BS AUDIO$	LOAD.B	(A4)+1,#'-AUDIO$:	CLR.B	(A4)+2	LOAD.W	D3,#TYPIO	; D3 <-- type du driver	FOS	?COMMAND	; utilise ou pas 300_SYNT.AUDIO	FOS	?CLOSE		; ferme #SYNTHESIZER:EXIT$:	POPM.L	D3,D6,A3,A4	RETNSYNT$:	.ASCIZ	"#SYNTHESIZER:"	.EVEN;--------\\; DRAWICO >;========/; Affiche une icne dans une dbox.; in	A4.L	^dx,dy,matrice icne;	D2.W	rang dans dbox;	D5.L	canal dbox; out	-; mod	D7.WDRAWICO:	PUSHM.L	D3,D4,A3	DBOX_	GETCO	ADD.W	D4,#20	SWAP.W	D4	SUB.W	D4,#24-7;	SWAP.W	D4	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	LOAD.L	(A3)+1,D4	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#SETDOT	LOAD.W	D3,#10	LIB	?STRING	POPM.L	D3,D4,A3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETIECRAN:								; icne #2 de XXP24	.B	32,24        .B      B'00111111,B'11111111,B'11111111,B'11111100        .B      B'01111111,B'11111111,B'11111111,B'11111110        .B      B'01011111,B'11111111,B'11111111,B'11111010        .B      B'01101111,B'11111111,B'11111111,B'11110010        .B      B'01011000,B'00000000,B'00000000,B'00010010        .B      B'01101000,B'00000000,B'10100000,B'00010010        .B      B'01011011,B'11111111,B'11111111,B'11010010        .B      B'01101000,B'00000000,B'00000000,B'00010010        .B      B'01011000,B'00000000,B'00000000,B'00010010        .B      B'01101000,B'00000000,B'00000000,B'00010010        .B      B'01011000,B'00000000,B'00000000,B'00010010        .B      B'01101000,B'00000000,B'00000000,B'00010010        .B      B'01011000,B'00000000,B'00000000,B'00010010        .B      B'01101000,B'00000000,B'00000000,B'00010010        .B      B'01011000,B'00000000,B'00000000,B'00010010        .B      B'01101011,B'11111111,B'11111111,B'11010010        .B      B'01011010,B'01010101,B'01010101,B'01010010        .B      B'01101011,B'11111111,B'11111111,B'11010010        .B      B'01011000,B'00000000,B'00000000,B'00010010        .B      B'01101111,B'11111111,B'11111111,B'11100010        .B      B'01010000,B'00000000,B'00000000,B'00000010        .B      B'01100000,B'00000000,B'00000000,B'00000010        .B      B'00111111,B'11111111,B'11111111,B'11111100        .B      B'00000000,B'00000000,B'00000000,B'00000000ICLAVIER:							; icne #3 de XXP24	.B	32,24        .B      B'00000000,B'00000000,B'00000000,B'00000000        .B      B'00000000,B'00000000,B'00000000,B'00000000        .B      B'00000000,B'00000000,B'00000000,B'00000000        .B      B'01111111,B'11111111,B'11111111,B'10110000        .B      B'01000010,B'01001001,B'00100100,B'00000000        .B      B'01000010,B'01001001,B'00100100,B'00000000        .B      B'01111111,B'11111111,B'11111111,B'01010000        .B      B'01000001,B'00100100,B'10010010,B'00000000        .B      B'01000001,B'00100100,B'10010010,B'00000000        .B      B'01111111,B'11111111,B'11111111,B'11110100        .B      B'00100100,B'10010010,B'01001001,B'00000000        .B      B'00100100,B'10010010,B'01001001,B'00000000        .B      B'00111111,B'11111111,B'11111111,B'11100000        .B      B'00100001,B'00100100,B'10010010,B'00000000        .B      B'00100001,B'00100100,B'10010010,B'00000000        .B      B'00111111,B'11111111,B'11111111,B'10010000        .B      B'00100001,B'00100000,B'00000000,B'00000000        .B      B'00100001,B'00100000,B'00000000,B'00000000        .B      B'00111111,B'11111111,B'11111111,B'11011000        .B      B'00000000,B'00000000,B'00000000,B'00000000        .B      B'00000000,B'00000000,B'00000000,B'00000000        .B      B'00000000,B'00000000,B'00000000,B'00000000        .B      B'00000000,B'00000000,B'00000000,B'00000000        .B      B'00000000,B'00000000,B'00000000,B'00000000ISOURIS:							; icne #4 de XXP24	.B	32,24        .B      B'00000000,B'00000001,B'11000000,B'00010000        .B      B'00000000,B'00000111,B'11100000,B'00100100        .B      B'00000000,B'00000111,B'11110000,B'00101000        .B      B'00000000,B'00010111,B'11111111,B'11110000        .B      B'00000000,B'00110111,B'11111001,B'11111100        .B      B'00000000,B'00111011,B'11111001,B'11111100        .B      B'00000000,B'00111100,B'11111111,B'11111100        .B      B'00000000,B'00011101,B'11111111,B'11110000        .B      B'00000000,B'00001101,B'11111111,B'10101000        .B      B'00000000,B'00000011,B'11111110,B'00100100        .B      B'00000000,B'00000111,B'11011100,B'00000000        .B      B'00000000,B'00000111,B'11100000,B'01110000        .B      B'00000000,B'00000111,B'01111111,B'11110000        .B      B'00000000,B'00001111,B'10011111,B'10010000        .B      B'00000000,B'00001111,B'11100000,B'00000000        .B      B'00000000,B'00001111,B'11111100,B'00000000        .B      B'00000000,B'00001111,B'11111110,B'00000000        .B      B'00000000,B'00001111,B'11111110,B'00000000        .B      B'00000001,B'11111111,B'11111110,B'00000000        .B      B'00011110,B'00001111,B'11111110,B'00000000        .B      B'01100000,B'00000011,B'11111100,B'00000000        .B      B'10000000,B'00000001,B'10110000,B'00000000        .B      B'10000000,B'00000011,B'01111111,B'11100000        .B      B'01111111,B'11100111,B'01111111,B'11100000IAUDIO:								; icne #5 de XXP24	.B	32,24        .B      B'00000111,B'10111101,B'11110000,B'00000000        .B      B'00001000,B'11000110,B'00111000,B'00000000        .B      B'00010110,B'00111000,B'11011000,B'00000000        .B      B'00010110,B'11000110,B'11011000,B'00000000        .B      B'00010001,B'11100011,B'00011000,B'00000000        .B      B'00001011,B'11110001,B'10110100,B'00000000        .B      B'00010111,B'11111001,B'11011010,B'11111000        .B      B'00010111,B'11111111,B'11011001,B'00100100        .B      B'00101111,B'11111101,B'01101100,B'10100100        .B      B'00101111,B'11111010,B'10101100,B'10010010        .B      B'00101111,B'11110101,B'01101100,B'01010010        .B      B'00101000,B'00011010,B'10101101,B'01011110        .B      B'00101111,B'11110101,B'01101110,B'11010010        .B      B'00101000,B'00011010,B'10101101,B'01111110        .B      B'00101000,B'00001101,B'01101111,B'11011110        .B      B'00101000,B'00011010,B'11101111,B'10111100        .B      B'00010100,B'00101111,B'11011111,B'11111100        .B      B'00010100,B'01010111,B'11011110,B'11111000        .B      B'00001011,B'10101111,B'10111100,B'00000000        .B      B'00010001,B'01011111,B'00011000,B'00000000        .B      B'00010110,B'11111110,B'11011000,B'00000000        .B      B'00010110,B'00111000,B'11011000,B'00000000        .B      B'00001000,B'11000110,B'00111000,B'00000000        .B      B'00000111,B'10111101,B'11110000,B'00000000	.EVEN	.END	START