rateur OU avec "|" ou espace;			accs: cre un code nul avec date 00/00/00 !;			accs: dplace/duplique absents dans mmenu;			SYSTEM.CODE de longueur 1 (anciennement 0); 4.5			duplique: enlve toujours l'attribut N;			#MM1: et #TOTO: --> $FLO_0 possible;			accs: nouvelle opration pour les .CODE;			ferme: fait un release de l'unit physique;			LISTE: flags ".CODE" et "dossier";			LISTE: oprateur "|" OU;			TOUT: nouvelle case  gauche de REFAIT;			excute: mmenu si extension multi-rfrence; 4.4			duplique AB!TEXT gnre AB1!TEXT (au lieu de AB!TEXT1);			!code: instruction .GENBOOT; 4.3			modifie: file!code ok;			imprimante: choix du format du papier; 4.2			.files --> !code (et !n'importe_quoi);			dtruit: demande toujours une confirmation;			ddd: si erreur dans dbox => appuyez une touche ...;			.files: TOTO/N => pas d'erreur si TOTO n'existe pas;			.files: si pas attribut "D" fichier cliqu => erreur;			dp/dup: vise position d'arrive plus facile;			excute SYSTEM.CODE => erreur "dj en excution";			LISTE: si rien => "*";			mmenu: cases "blanches" si opration impossible;			type TYPDOSSIER spcialement pour DOSSIER:;			modifie: impossible de donner le nom DOSSIER:;			DOSSIER: ne peut qu'tre dupliqu;			arrt: nouvelle touche (QUITTE); 4.1	01.08.86	swdo des transferts: met mode ROLL;			swdo des transferts: plus large;			ne plante plus si dtruit ".ext";			LISTE: case mmorise => fichier START_DIR.INFO;			paramtres: donne la rvision et le texte "ident";			ligne de commande: nom d'une unit  ouvrir;			ouverture DOSSIER: ou floppy vide: erreur tout de suite;			messages d'erreurs plus clairs;			AUTRE: installe le driver rseau si ncessaire;			maximas: 8 fentres et 32 units physiques;			routine CLRMEM super-rapide;			fentres plus serres verticalement; 4.0			milieu: mise  l'heure/date;			case REFAIT en haut de chaque fentre;			fonction dite utilisant le module EPRO;			utilise FOS,?NAMERROR;			.files: instructions .IFEQ/.ELSE/.ENDIF; 0.3			.files: comparaison dates pour "... pas ncessaire" ok;			arrt: aussi dans case sup/gauche wdo units physiques; 0.2			DOSSIER.DIR avec h=1;			si noms, tailles et dates => ouverture dossier ok;			duplique DOSSIER: ok;			destruction fichier en fin de liste ok;			milieu: fonction "arrt";			re-dessin d'une fentre => conserve position verticale;			dplace: si destination dans wdo units physiques => bip;			milieu: fonction "imprimante";			.files: +/- attributs possible; 0.1			premire version	.REF	SMAKY	.REF	BIOSDRIV	.REF	MODULES	.REF	PLAN	.REF	TCOLOR	.REF	ICOLOR	.REF	COLORS	.REF	DISK;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;FOS?UNAMDRIV = FOS_BASE+41FOS?MMVASSIGN = FOS_BASE+110OBK0CHANGE = H'ECBATTWPR = 30EPRO_EXTEND = 16'A84FEPRO_GETPDBUFF = 1BEPROMOUSE = 5BEPROAFCR = 7BEPROAFLF = 8BEPROAFTAB = 9OEPROSTATUS = H'1BBEPROFILMOD = 0GRA_CRASTER = H'A899		; raster-op couleurBSRCCOUL = 11BDSTCOUL = 12SMAKY300 = 7OINVOL = OINSTA+4		; volume du h-p dans 100_INFO;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;STARTREV=	7		; rvisionSTARTVERS=	0		; version	.REV	STARTREV,STARTVERS;;?	.CODE	800,11,B'0111,600,2000,300,2000,2,'N,'R,'F,09	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'R,'F,09	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LMFILE	=	100		; lg max d'un nom de fichierHACHE	=	31		; valeur "h" standardMARGEX	=	6		; marges autour de la grande fentreMARGEY	=	10		; marges autour de la grande fentreEPCADIC	=	3		; paisseur du cadre autour d'une icneNLITIC	=	3		; nb de lignes pour une icneTRAGRIS	=	H'22882288	; trame griseLBUDIS	=	800		; lg max de OBUDISNBFIFO	=	20		; nb max d'images dans le fifoLGFIFO	=	4		; taille d'un lment dans le fifo (.L)MAXMA	=	10		; nb max de machines diffrentesGCTXF	=	'N		; fonte du texte  NRF09GCTXS	=	'R!2^7		; style/chasse du texteGCTXT	=	09		; taille du texteGCIIF	=	'