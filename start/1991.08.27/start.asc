DDDDA:	.BLKB	1		; dtruit tout	.EVENODDDIN:	.BLKB	2		; .IFEQ: rang imbrication (0..n)ODDDIC:	.BLKB	20		; .IFEQ: pile des conditions	.EVENODDDER:	.BLKB	2		; nb d'erreursODDDNB:	.BLKB	2		; rangODDDBE:	.BLKB	LER*MAXER	; buffer pour les erreursODDDAP:	.BLKB	4		; attributs  ajouter (+)ODDDAM:	.BLKB	4		; attributs  enlever (-)ODDDSTK:.BLKB	4*20		; stack pour MXFERORDCH:	.BLKB	2		; canal de lectureOWRCH:	.BLKB	2		; canal d'critureOBUARGT:.BLKB	64		; buffer temporaire pour FOS,?ARGSOBUARGS:.BLKB	LFL		; buffer pour les arguments (source)OBUARGD:.BLKB	LFL		; buffer pour les arguments (destination)OAPST:	.BLKB	4		; appendic: ^texte sourceOAPSI:	.BLKB	4		; appendic: ^icnes sourceOAPDT:	.BLKB	4		; appendic: ^texte destinationOAPDI:	.BLKB	4		; appendic: ^icnes destinationODDDPU:	.BLKB	4		; destination dplace/duplique: ^unitODDDRA:	.BLKB	2		; destination dplace/duplique: rangOSELNB:	.BLKB	2		; slection: nombre (0..n)OSELPU:	.BLKB	4		; slection: ^unitOPBIG:	.BLKB	4		; coin sup/gauche grande fentreODBIG:	.BLKB	4		; dimensions grande fentreODCARY:	.BLKB	2		; hauteur d'un caractreODCARX:	.BLKB	2		; largeur d'un caractreODCASY:	.BLKB	2		; hauteur des cases en haut du cadreODICYS:	.BLKB	2		; divers: case slectionneOTYPST:	.BLKB	4		; type: ^statusOCPFFF:	.BLKB	4		; copie: fanions floppy-floppyOCPCDB:	.BLKB	4		; copie: canal dbox waitOCPNAM:	.BLKB	LMFILE		; copie: nom du fichier .DIOCPCHR:	.BLKB	2		; copie: canal driver source (read)OCPCHW:	.BLKB	2		; copie: canal driver destination (write)OCPERR:	.BLKB	2		; copie: ok/erreur lors d'ouvertureOCPASC:	.BLKB	LSCVAR		; copie: ascenseurOVIFABO:.BLKB	1		; visu: 1 => fin du processus filsOVIFNET:.BLKB	1		; visu: 1 => rseau	.EVENOVIFTYP:.BLKB	2		; visu: type du fichierOVIFEXT:.BLKB	16		; visu: extensionOVIFPU:	.BLKB	4		; visu: ^description unitOVIFRA:	.BLKB	2		; visu: rangOHEAD:	.BLKB	2		; fifo: ^tteOTAIL:	.BLKB	2		; fifo: ^queueOFIFO:	.BLKB	LGFIFO*NBFIFO	; fifo: contenuOCOPOS:	.BLKB	4		; couleur: position (y;x)OSLK2:	.BLKB	2		; sleep: clavier du programme interrompuOSLCH:	.BLKB	2		; sleep: canal de l'cran normalOSLPD:	.BLKB	4		; sleep: ^descripteur de $DIS_0OSLPM:	.BLKB	4		; sleep: ^sauvetage du bitmapOSLDY:	.BLKB	2		; sleep: hauteur du bitmapOSLDX:	.BLKB	2		; sleep: largeur du bitmapOSLI1:	.BLKB	4		; sleep: sauvetage de _VINCIDLOSLI2:	.BLKB	4		; sleep: _VINCIDL bidon (invisible)OSLCE:	.BLKB	4		; sleep: centre de l'horlogeOSLRA:	.BLKB	2		; sleep: rayon de l'horlogeOSLHA:	.BLKB	8		; sleep: registre 63 bits gn. alatoireLGVAR:; Programme; ---------	.LOC	0; Noms des modules; ----------------NMDBOX:	.ASCIZ	"DBOX"NMSCROLL:.ASCIZ	"SCROLL"NMLIST:	.ASCIZ	"LIST"NMEPRO:	.ASCIZ	"EPRO"NMDISK:	.ASCIZ	"DISK"NMSTRET:.ASCIZ	"STRETCH"NMICOL:	.ASCIZ	"ICOLOR"NMPLAN:.ASCIZ	"PLANA"NMPRINT:.ASCIZ	"PRINTA"; Erreurs fatales; ---------------TXERFATREV:	.ASCIZ	"La rvision du systme est incompatible"TXERFATMEM:	.ASCIZ	"Problme avec la mmoire"TXERFATDIS:	.ASCIZ	"Driver d'cran incompatible"TXERFATGRA:	.ASCIZ	"Module GRA incompatible"TXERFATTXT:	.ASCIZ	"Erreur avec le gencar NRF09"TXERFATIIC:	.ASCIZ	"Erreur avec le gencar IIP24"TXERFATINF:	.ASCIZ	"Erreur avec START.INFO"		.EVENSTART:;;?	CLR.L	H'900		; SPOS[0] pour le moniteur !!!	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CALL	_WAITMOUSE	; met le sablier	LOAD.B	D3,#NOCURS	LIB	?AFCAR		; enlve le curseur	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	; met TOUTES les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	LIB	?SWITCH		; D3 <-- switchs trouvs	LOAD.L	(A6)+OSWITCH,D3	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*7+0	JUMP,LO ERFAT2	CALL	RELDOC		; fait un REL *	NTREL	?GETMACHINE	RL.L	D4,#8	LOAD.B	(A6)+OMACHINE,D4	LOAD.B	(A6)+OMANAME+0,(A3+) ; OMANAME <-- nom de la machine (SYS,100,324,etc.)	LOAD.B	(A6)+OMANAME+1,(A3+)	LOAD.B	(A6)+OMANAME+2,(A3+);	CLR.B	(A6)+OMANAME+3	LOAD.L	A3,#R16"TXERFATDIS	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT2	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	D0,#GCTXF	; D0 <-- fonte	LOAD.L	D1,#GCTXS	; D1 <-- style	LOAD.B	D2,#GCTXT	; D2 <-- taille	CALL	USEGENCAR	; charge les caractres standard	LOAD.L	A3,#R16"TXERFATTXT	TEST.W	D7	JUMP,NE ERFAT2	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	D0,#GCIIF	; D0 <-- fonte	LOAD.L	D1,#GCIIS	; D1 <-- style	LOAD.B	D2,#GCIIT	; D2 <-- taille	CALL	USEGENCAR	; charge les icnes standard	LOAD.L	A3,#R16"TXERFATIIC	TEST.W	D7	JUMP,NE ERFAT2	LOAD.L	A1,#R16"TXERFATGRA	LOAD.W	D3,#GRA_QXDOT	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OQXDOT,A3	LOAD.W	D3,#GRA_CLEAR	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OCLEAR,A3	LOAD.W	D3,#GRA_SET	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OSET,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OINV,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMEPRO	LOAD.W	D3,#EPRO_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHEPRO,D1	LOAD.L	A3,#R16"NMDISK	LOAD.W	D3,#DISK_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDISK,D1	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	LOAD.L	A3,#R16"NMICOL	LOAD.W	D3,#ICOL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHICOL,D1NOCOUL$:	LOAD.L	A3,#R16"NMPRINT	LOAD.W	D3,#PRINTA_FIRST	LIB_	OPEN	JUMP',NE 52$	LOAD.W	(A6)+OCHPRINT,D1	LOAD.L	D3,(A6)+OSWITCH	TEST.L	D3:#('I-'A)	; START/I ?	JUMP',BC 50$		; non => 50$	TSET.L	D3:#BPRNOMODIF	; oui => plus de modifications50$:	PRINTA_	OPEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OCAPRINT,A252$:	LOAD.W	(A6)+OCHSTRET,#-1	LOAD.W	(A6)+OCHPLAN,#-1	NTREL	?GETPRIO	; D4 <-- priorit de START	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATINF	CALL	_RDINFO		; lit le fichier START.INFO	JUMP,NE ERFAT2	CALL	_RDUSER		; lit le fichier START_USER.INFO	CALL	_MAJSTATUS	; mj. selon informations de 100_INFO	CALL	_DBDEFINIT	; mj. selon .DEFINE nom/I	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	CALL	_AFMENU		; dessine les soft-keys	CALL	INIICONE	; init selon l'chelle	CALL	CALCUL		; qq calculs de dimensionnement	CALL	CADRE		; dessine le cadre60$:	CALL	_DBOXOKPASS	; demande v. le mot de passe ...	JUMP',NE 62$	COMP.W	D3,#F13	JUMP',NE 62$	LOAD.W	D0,#1		; D0 <-- depuis "mot de passe"	CALL	ARRET		; demande comment arrter ...	JUMP	60$62$:	LOAD.L	A5,#0		; A5 <-- pas de pre, snif	CALL	OPEWDO		; ouvre une premire fentre	JUMP,NE ERFAT2	LOAD.L	A3,#(A5)+OUNNAM	LOAD.B	(A3+),#'$	; nom pour units physiques	CLR.B	(A3)	CALL	_RDLIST	JUMP,NE ERFAT2	CALL	ALLREFAIT	; redessine toute la fentre	FOS	?BALOPEN	; A5 <-- ouvre une bal dans le FOS	JUMP,NE ERFAT2	LOAD.L	(A6)+OBALPT,A5	; OBALPT <-- ^bal; Ouvre l'unit ventuellement spcifie dans la ligne de commande.	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ligne de commande	LIB	?SKPNAM	JUMP,NE LOOP	LOAD.L	A4,#(A6)+OBUFIT70$:	LOAD.B	D3,(A3+)	JUMP',EQ 75$	COMP.B	D3,#CR	JUMP',EQ 75$	COMP.B	D3,#SPACE	JUMP',EQ 75$	COMP.B	D3,#TAB	JUMP',EQ 75$	COMP.B	D3,#'/	JUMP',EQ 75$	CALL	_MINMAJ	LOAD.B	(A4+),D3	; OBUFIT <-- nom de l'unit  ouvrir	JUMP	70$75$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUFIT	; A3 <-- ^nom de l'unit  ouvrir	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^descripteur pre (units physiques)	LOAD.L	A2,#(A5)+OUNNAM	; A2 <-- ^nom du pre	JUMP	EXECUNIT0	; ouvre l'unit physique ...; Dbut de la boucle principale de tout le programme.LOOP:	CALL	BALWAIT		; traite les messages du FOS ...	LOAD.W	D2,#1		; D2 <-- annule les slections	CALL	BALAFF		; affiche les fentre modifiesLOOPSEL:	CALL	_NORMMOUSE	; enlve le sablier10$:	LOAD.W	D4,#50*1	NTREL	?SETTIM		; met timeout d'une seconde	LIB	?GETCAR		; attend clavier/souris ...	JUMP',EQ 20$	CALL	BALWAIT		; traite les messages du FOS ...	CLR.W	D2		; D2 <-- n'annule pas les slections	CALL	BALAFF		; affiche les fentre modifies	JUMP	10$20$:	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	COMP.B	D3,#F0+SHIFT	JUMP',LO 22$	COMP.B	D3,#F15+SHIFT	JUMP',HI 22$	SUB.B	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)22$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOPSEL	COMP.W	D3,#KEYMMR	JUMP,EQ LOOPSEL	COMP.W	D3,#KEYMDR	JUMP,EQ LOOPSEL	COMP.W	D3,#KEYMGP	JUMP,EQ CLICGAUCHE	COMP.W	D3,#KEYMMP	JUMP,EQ CLICMILIEU	COMP.W	D3,#KEYMDP	JUMP,EQ CLICDROITE	COMP.W	D3,#UNDO	JUMP,EQ LOOP	COMP.W	D3,#CLEAR	JUMP,EQ LOOP	COMP.W	D3,#KEYSLEEP	JUMP,EQ AUTOSLEEP	COMP.W	D3,#H'100*(2^BPROGRA)+'S	JUMP,EQ AUTOSLEEP	COMP.W	D3,#H'100*(2^BPROGRA)+'s	JUMP,EQ AUTOSLEEP	COMP.W	D3,#F0	JUMP,EQ FINI	COMP.W	D3,#END	JUMP,EQ FINIBIP:				; erreur =>	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPBIPSEL:				; erreur =>	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPSELBIGBIP:				; erreur =>	LOAD.W	D3,#BIPERR	LIB	?BEEP		; grand bruit	JUMP	LOOPERROR:	TEST.W	D7	JUMP,EQ LOOP	CALL	_DBOXERROR	; affiche l'erreur	JUMP	LOOPFINI:	LOAD.W	D4,#50/7	NTREL	?SETTIM	LIB	?GETCAR		; 2me touche rapidement ?	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE	BIP		; non => BIP	COMP.B	D3,#END	JUMP',EQ ERFAT	COMP.B	D3,#F0	JUMP',EQ ERFAT	COMP.B	D3,#F0+SHIFT	JUMP',EQ ERFAT	JUMP	BIPERFAT:	TEST.L	(A6)+OBALPT	JUMP',EQ 10$	LOAD.L	A5,(A6)+OBALPT	; A5 <-- ^bal	FOS	?BALCLOSE	; ferme la bal du FOS10$:	SET.B	(A6)+OABORT	; signal la fin au processus fils	NTREL	?WFABDESC	; attend leurs fins ...	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHEPRO	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDISK	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHICOL	LIB_	CLOSE	TEST.L	(A6)+OCAPRINT	JUMP',EQ ERFAT1	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	CLOSE	LOAD.W	D1,(A6)+OCHPRINT	LIB_	CLOSEERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	EOP,NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT; Processus fils de START; -----------------------NFILS1:	.ASCIZ	"START_SLEEP"	.EVENPFILS1:	FOS	?OPINFO		; A4 <-- ^contenu de 100_INFO	CLR.W	D4	FOS	?CLINFO10$:	CLR.W	D1		; D1 <-- nb de secondes inactives12$:	TEST.B	(A6)+OABORT	; fin ?	JUMP,T	90$		; oui => 90$				; non =>	NTREL	?GETSYTIME	LOAD.L	D0,D2		; D0 <-- temps processeur inutilis	LOAD.W	D4,#50	NTREL	?DELMS		; attend une seconde	LOAD.L	D4,(A4)+OINSTA	; D4 <-- informations de 100_INFO	TEST.L	D4:#BINFS0	; ne s'endort plus jamais ?	JUMP,BS 10$		; oui => 10$				; non =>	NTREL	?GETSYTIME	SUB.L	D2,D0		; D2 <-- dure d'excution de IDLE	LOAD.L	D4,#H'1980	; mesur = H'1A82 (SMAKY8)    voir (*)	COMP.B	(A6)+OMACHINE,#SMAKY8	JUMP',EQ 16$	LOAD.L	D4,#H'1D80	; mesur = H'1E17 (SMAKY324)  voir (*)	COMP.B	(A6)+OMACHINE,#SMAKY324	JUMP',EQ 16$	LOAD.L	D4,#H'1400	; mesur = H'1530 (SMAKY100)  voir (*)16$:	COMP.L	D2,D4		; IDLE beaucoup excut ?	JUMP,LO	10$		; non => 10$				; oui =>	LOAD.L	D4,(A4)+OINSTA	; D4 <-- informations de 100_INFO	CLR.W	D3	TEST.L	D4:#BINFS0	JUMP',BS 20$	LOAD.W	D3,#60*15	TEST.L	D4:#BINFS15	JUMP',BS 20$	LOAD.W	D3,#60*60	TEST.L	D4:#BINFS60	JUMP',BS 20$	LOAD.W	D3,#60*520$:	INC.W	D1		; D1 <-- une seconde d'inactivit de plus	COMP.W	D1,D3	JUMP,LO 12$	TEST.B	(A6)+OSLEEP	; est-ce que le SMAKY dort ?	JUMP,T	10$		; oui => 10$				; non =>	LOAD.L	D3,#KEYSLEEP	LIB	?WRKEY		; envoie l'vnement au pre !	JUMP	10$90$:	NTREL	?ABORT; (*)	Cette valeur est mesure avec le programme CALIBRE.ASCAUTOSLEEP:	CALL	_SLEEP		; le SMAKY d'endort ...	JUMP	LOOPCLICGAUCHE:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIPSEL	CALL	DETASCENSEUR	; dans un ascenseur ?	JUMP,EQ LOOPSEL		; oui => LOOPSEL	CALL	MOVECADRE	; dans une case du cadre ?	JUMP,EQ CLICCASE	; oui => CLICCASE	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP,NE BIPSEL		; oui => BIPSEL	CALL	DEXICONE	; D4 <-- rang o est la souris	JUMP,NE BIPSEL	COMP.W	D4,(A5)+OUNNBL	; icne existe ?	JUMP,HS BIPSEL		; non => BIPSEL	CALL	LOLISCADIC	; allume l'icne	LOAD.W	D2,D4		; D2 <-- icne allume20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 40$		; non => 40$				; oui =>	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	DETICONE	; D4 <-- rang o est la souris	JUMP',NE 30$	COMP.W	D4,(A5)+OUNNBL	; icne existe ?	JUMP',LO 30$		; oui => 30$	LOAD.W	D4,#-130$:	COMP.W	D4,D2		; toujours dans la mme icne ?	JUMP,EQ 20$		; oui => 20$				; non =>	EX.L	D2,D4	CALL	LOLICCADIC	; teint l'ancienne icne	LOAD.W	D4,D2	CALL	LOLISCADIC	; allume la nouvelle icne	JUMP	20$40$:	LOAD.W	D4,D2	COMP.W	D4,#-1	JUMP,EQ BIP	LOAD.L	A2,#(A5)+OUNNAM	CALL	GETPFILE	; A3 <-- ^nom du fichier	CALL	GETTYPE		; D3 <-- type du fichier	COMP.W	D3,#TYPCODE	JUMP,EQ EXECCODE	COMP.W	D3,#TYPSYSC	JUMP,EQ EXECSYSC	COMP.W	D3,#TYPDIR	JUMP,EQ EXECDIR	COMP.W	D3,#TYPDOSSIER	JUMP,EQ EXECDOSSIER	COMP.W	D3,#TYPUNIT	JUMP,EQ EXECUNITEXECAUTRE:	CALL	DIRDOC		; fait un DIR pour le document	JUMP',NE 80$	CALL	PREPFIX		; A3 <-- ^ligne de commande	JUMP',NE 80$	CALL	PREPFIXW	; A3 <-- ^ligne de commande avec {n}	JUMP',NE 80$	CALL	PREPFIXM	; demande s'il faut excuter une nime fois ...	JUMP',NE 80$	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.L	D0,#FOS?EXECUTE	CALL	_ERCALL		; excute le programme80$:	PUSH.W	D7	CALL	LOLICCADIC	; teint l'icne	CALL	RELDOC		; annule les DIRs prcdents	POP.W	D7	JUMP	ERROREXECCODE:	CALL	LOLICCADIC	; teint l'icne	CALL	_WAITMOUSE	; souris: met le sablier	CALL	DIRDOC		; fait un DIR pour le document	JUMP',NE 80$	LOAD.L	A4,#(A6)+OBUFIT	CALL	GETPFILE	; A3 <-- ^nom20$:	LOAD.B	(A4+),(A3+)	JUMP,NE 20$	LOAD.L	A3,#(A6)+OBUFIT	CALL	PREPFIXW	; A3 <-- ^ligne de commande avec {n}	JUMP',NE 80$	CALL	PREPFIXM	; demande s'il faut excuter une nime fois ...	JUMP',NE 80$	LOAD.L	D0,#FOS?EXECUTE	CALL	_ERCALL		; excute le programme80$:	PUSH.W	D7	CALL	RELDOC		; annule les DIRs prcdents	POP.W	D7	JUMP	ERROREXECSYSC:	CALL	LOLICCADIC	; teint l'icne	LOAD.W	D7,#ERSSYST	; D7 <-- SYSTEM.CODE dj en excution !	JUMP	ERROREXECDIR:EXECUNIT:	CALL	LOLICCADIC	; teint l'icneEXECUNIT0:	CALL	_WAITMOUSE	; souris: met le sablier	CALL	NEWOPNAME	; A3 <-- nouveau nom	CALL	IFEQUUSE	; unit dj utilise ?	JUMP,NE ERROR	LOAD.L	D3,#2^BEAUTOM	; D3 <-- signal BAL comme enter automatique	LOAD.L	D0,#FOS?NENTER	CALL	_ERCALL		; fait tout de suite un "enter"	JUMP',EQ 18$	COMP.W	D7,#ERUUSE	; "enter" tait dj fait ?	JUMP',EQ 18$		; oui => 18$	COMP.W	D7,#ERATTR	; lecture impossible ?	JUMP,NE ERROR		; non => ERROR	LOAD.W	D7,#ERSDOSL	; oui => met une erreur spciale	JUMP	ERROR18$:	COMP.W	(A2),#H'100*'$	JUMP',EQ 20$	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BKILL	; touche (KILL) enfonce ?	JUMP',BS 30$		; oui => 30$20$:				; non =>	CALL	OPEWDOS		; A5 <-- ^nouvelle unit (ne redessine pas)	JUMP,NE ERROR30$:	LOAD.L	A4,#(A5)+OUNNAM32$:	LOAD.B	(A4+),(A3+)	; OUNNAM <-- nom du dossier	JUMP,NE 32$	LOAD.B	(A4)-1,#'*	; OUNNAM <-- tous les fichiers	CLR.B	(A4)	CALL	MAJWDO		; redessine les fentre modifies	CALL	_RDDIRINFO	; lit START_DIR.INFO s'il existe	CALL	_RDLIST		; lit la liste des noms de fichiers	JUMP',NE 90$	CALL	ALLREFAIT	; redessine toute la fentre	JUMP	LOOP90$:	PUSH.W	D7	CALL	CLOWDO		; ferme la fentre	POP.W	D7	JUMP	ERROREXECDOSSIER:	CALL	LOLICCADIC	; teint l'icne	LOAD.W	D7,#ERSDOSS	; D7 <-- erreur spciale	JUMP	ERRORCLICMILIEU:	CALL	_GTMCMILIEU	; A3 <-- ^TMCMILIEU	CLR.W	D3	LOAD.W	D2,#TYPMILIEU	CALL	_WAITMMENU	; choix selon mmenu ...	JUMP,NE BIP	.IF	MPRINT	COMP.W	D3,#1	JUMP,EQ IMPRIMANTE	COMP.W	D3,#2	JUMP,EQ CLEF	COMP.W	D3,#3	JUMP,EQ STATUS	COMP.W	D3,#4	JUMP,EQ XY11	COMP.W	D3,#5	JUMP,EQ XY12	COMP.W	D3,#6	JUMP,EQ XY22	COMP.W	D3,#7	JUMP,EQ PASSWORD	COMP.W	D3,#8	JUMP,EQ DOARRET	.ELSE	COMP.W	D3,#1	JUMP,EQ CLEF	COMP.W	D3,#2	JUMP,EQ IMPRIMANTE	COMP.W	D3,#3	JUMP,EQ XY11	COMP.W	D3,#4	JUMP,EQ XY12	COMP.W	D3,#5	JUMP,EQ XY22	COMP.W	D3,#6	JUMP,EQ PASSWORD	COMP.W	D3,#7	JUMP,EQ DOARRET	.ENDIF	JUMP	LOOPSELCLEF:	CALL	_DBOXCLEF	; choix de la clef ...	JUMP	ERRORPASSWORD:	CALL	_DBOXPASS	; choix du mot de passe ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	TEST.L	D4:#2		; bloque tout de suite ?	JUMP,BC LOOP		; non => LOOP				; oui =>	CALL	CADRE		; dessine le cadre50$:	CALL	_DBOXOKPASS	; demande v. le mot de passe ...	JUMP',NE 52$	COMP.W	D3,#F13	JUMP',NE 52$	LOAD.W	D0,#1		; D0 <-- depuis "mot de passe"	CALL	ARRET		; demande comment arrter ...	JUMP	50$52$:	CALL	SCALEWDO	; redessine toutes les fentres	JUMP	LOOP	.IF	MPRINTIMPRIMANTE:	CLR.L	D3		; D3 <-- mode	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	SELECTION	; slection pour l'imprimante ...	PUSH.W	D7	CALL	_AFMENU		; dessine les soft-keys	POP.W	D7	JUMP	ERROR	.ELSEIMPRIMANTE:	CALL	_DBOXPRINT	; choix de l'imprimante ...	JUMP	ERROR	.ENDIFSTATUS:	CALL	_DBOXDEFINE	; affiche quelques informations ...	JUMP	ERRORXY11:	PUSH.B	(A6)+ODEMIX	PUSH.B	(A6)+ODEMIY	CLR.B	(A6)+ODEMIX	CLR.B	(A6)+ODEMIY	JUMP'	XYALLXY12:	PUSH.B	(A6)+ODEMIX	PUSH.B	(A6)+ODEMIY	CLR.B	(A6)+ODEMIX	SET.B	(A6)+ODEMIY	JUMP'	XYALLXY22:	PUSH.B	(A6)+ODEMIX	PUSH.B	(A6)+ODEMIY	SET.B	(A6)+ODEMIX	SET.B	(A6)+ODEMIY;	JUMP'	XYALLXYALL:	CALL	INIICONE	; init selon l'chelle	CALL	TOOMUCHWDO	; trop de swdo ?	JUMP',NE 90$		; oui => 90$	CALL	SCALEWDO	; modifie les fentres	POP.B	D3	POP.B	D3		; corrige le stack	JUMP	LOOPSEL90$:	POP.B	(A6)+ODEMIY	POP.B	(A6)+ODEMIX	; reprend l'chelle d'origine	PUSH.W	D7	CALL	INIICONE	; rinit selon l'chelle d'origine	POP.W	D7	JUMP	ERRORDOARRET:	CLR.W	D0		; D0 <-- appel normal	CALL	ARRET		; demande comment arrter ...	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	SET.B	(A5)+OUNMOD	; faudra la dessiner	CALL	MAJWDO		; redessine la fentre des units physiques	JUMP	LOOP; in	D0.W	1 => appel depuis "mot de passe"; out	seulement si ANNULE; mod	toutARRET:	LOAD.L	D3,(A6)+OSWITCH	TEST.L	D3:#('Q-'A)	; START/Q ?	JUMP,BS ERFAT		; oui => quitte tout de suiteRELLOOP$:	CALL	_WAITMOUSE	; souris: met le sablier	LOAD.L	A4,#R16"ED$	FOS	?PARAM		; fos: enter disable	CLR.W	D3		; D3 <-- global	FOS	?RENTER		; release tous les enter	JUMP',EQ RELOK$		; ok => RELOK$				; erreur =>	CALL	_DBOXIFARRET	; faut-il vraiment arrter ?	JUMP,NE	ERROR$	COMP.W	D3,#'O	JUMP,NE ERROR$	LOAD.L	A4,#R16"CE$	FOS	?PARAM		; fos: close enable	JUMP	RELLOOP$RELOK$:	LOAD.L	A5,#(A6)+OUNIT+LUN ; A5 <-- ^deuxime unitCLOLOOP$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP',F	CLOEND$		; non => CLOEND$				; oui =>	CALL	CLOWDOS		; ferme cette fentre, sans rafficher	JUMP	CLOLOOP$CLOEND$:	CALL	CADRE		; dessine le cadre	CALL	_DBOXARRET	; demande comment arrter ...	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP',EQ RESET$	LOAD.L	A4,#R16"NORM$	FOS	?PARAM		; fos: remet le mode normal				; ANNULE =>	RETRESET$:				; REDEMARRE =>	CLR.W	D4		; D4 <-- mode redmarre	NTREL	?HARDRESET	JUMP'	ERROR$BIP$:	PUSH.W	D7	LOAD.L	A4,#R16"NORM$	FOS	?PARAM		; fos: remet le mode normal	POP.W	D7	TEST.W	D0		; appel depuis "mot de passe" ?	JUMP,EQ	BIP		; non => BIP	RETERROR$:	PUSH.W	D7	LOAD.L	A4,#R16"NORM$	FOS	?PARAM		; fos: remet le mode normal	POP.W	D7	TEST.W	D0		; appel depuis "mot de passe" ?	JUMP,EQ	ERROR		; non => ERROR	RETED$:	.ASCIZ	"ED"		; enter disableCE$:	.ASCIZ	"CE"		; close enableNORM$:	.ASCIZ	"EECD"		; enter enable, close disable (normal)	.EVENCLICDROITE:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIPSEL	CALL	DETASCENSEUR	; dans un ascenseur ?	JUMP,EQ LOOPSEL		; oui => LOOPSEL	CALL	MOVECADRE	; dans une case du cadre ?	JUMP,EQ CLICCASE	; oui => CLICCASE	CALL	DEXICONE	; D4 <-- rang o est la souris	JUMP,NE BIPSEL	COMP.W	D4,(A5)+OUNNBL	; icne existe ?	JUMP,HS CLICRECT	; non => CLICRECT	CALL	HILIICONE	; allume l'icne	LOAD.W	D2,D4		; D2 <-- icne allume20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE 40$		; non => 40$				; oui =>	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	DETICONE	; D4 <-- rang o est la souris	JUMP',NE 30$	COMP.W	D4,(A5)+OUNNBL	; icne existe ?	JUMP',LO 30$		; oui => 30$	LOAD.W	D4,#-130$:	COMP.W	D4,D2		; toujours dans la mme icne ?	JUMP,EQ 20$		; oui => 20$				; non =>	EX.L	D2,D4	CALL	HILIICONE	; teint l'ancienne icne	LOAD.W	D4,D2	CALL	HILIICONE	; allume la nouvelle icne	JUMP	20$40$:	LOAD.W	D4,D2	COMP.W	D4,#-1	JUMP,EQ BIPSEL	CALL	GETPFILE	; A3 <-- ^nom du fichier	CALL	GETTYPE		; D3 <-- type du fichier	LOAD.W	D2,D3	COMP.W	D2,#TYPUNIT	JUMP,EQ 70$	PUSH.L	D3	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCOPY	; touche (COPY) enfonce ?	POPM.L	D3	JUMP,BS SELECTONE	; oui => SELECTONE	TEST.W	(A6)+OSELNB	; une slection en cours ?	JUMP',EQ 45$		; non => 45$				; oui =>	COMP.L	A5,(A6)+OSELPU	; dans la mme unit ?	JUMP,NE 85$		; non => 85$	COMP.W	D2,#TYPSYSC	; fichier SYSTEM.CODE ?	JUMP,EQ 85$		; oui => 85$	COMP.W	D2,#TYPDOSSIER	; DOSSIER: ?	JUMP,EQ 85$		; oui => 85$	INC.W	(A6)+OSELNB	; une icne de plus	TSET.B	(A3)+OFLATT+0:#BATTSEL-24 ; icne slectionne ?	JUMP,BC 65$		; non => 65$	DEC.W	(A6)+OSELNB	CALL	HILIICONE	; rallume l'icne	JUMP	65$45$:	COMP.W	D2,#TYPDIR	JUMP,EQ 60$	COMP.W	D2,#TYPDOSSIER	JUMP,EQ 60$	COMP.W	D2,#TYPCODE	JUMP,EQ 55$	COMP.W	D2,#TYPSYSC	JUMP,EQ 55$				; document =>	LOAD.L	A3,#R16"TMCAUTRE	COMP.W	D2,#TYPDI	JUMP',NE 46$	LOAD.L	A3,#R16"TMCDI46$:	CLR.W	D3	CALL	_WAITMMENU	; choix selon mmenu ...	JUMP,NE 90$	LOAD.W	(A6)+ODDDOP,D3	; ODDDOP <-- opration	COMP.W	D3,#1	JUMP,EQ DETRUITICONE	COMP.W	D3,#2	JUMP,EQ DEPDUPICONE	COMP.W	D3,#3	JUMP,EQ DEPDUPICONE	COMP.W	D3,#4	JUMP,EQ MODIFICONE	COMP.W	D3,#5	JUMP,EQ COLORICONE	COMP.W	D3,#6	JUMP,EQ EDITICONE	COMP.W	D3,#7	JUMP,EQ VISUICONE	COMP.W	D3,#8	JUMP,EQ PRINTICONE	COMP.W	D3,#9	JUMP,EQ VERROUICONE	COMP.W	D3,#10	JUMP,EQ COPYUNIT	JUMP	80$55$:				; programme =>	LOAD.L	A3,#R16"TMCCODE	CLR.W	D3	CALL	_WAITMMENU	; choix selon mmenu ...	JUMP,NE 90$	LOAD.W	(A6)+ODDDOP,D3	; ODDDOP <-- opration	COMP.W	D3,#1	JUMP,EQ DETRUITICONE	COMP.W	D3,#2	JUMP,EQ DEPDUPICONE	COMP.W	D3,#3	JUMP,EQ DEPDUPICONE	COMP.W	D3,#4	JUMP,EQ DEPDUPICONE	COMP.W	D3,#5	JUMP,EQ MODIFICONE	COMP.W	D3,#6	JUMP,EQ COLORICONE	COMP.W	D3,#7	JUMP,EQ PARAMICONE	JUMP	80$60$:				; dossier =>	LOAD.L	A3,#R16"TMCDIR	CLR.W	D3	CALL	_WAITMMENU	; choix selon mmenu ...	JUMP,NE 90$	LOAD.W	(A6)+ODDDOP,D3	; ODDDOP <-- opration	COMP.W	D3,#1	JUMP,EQ DETRUITICONE	COMP.W	D3,#2	JUMP,EQ DEPDUPICONE	COMP.W	D3,#3	JUMP,EQ DEPDUPICONE	COMP.W	D3,#4	JUMP,EQ MODIFICONE	COMP.W	D3,#5	JUMP,EQ COLORICONE	JUMP	80$65$:				; slection =>	LOAD.W	(A3)+OFLRAF,#-1	; signal icne  redessiner	LOAD.L	A3,#R16"TMCSELECT	CLR.W	D3	LOAD.W	D2,#TYPSELECT	CALL	_WAITMMENU	; choix selon mmenu ...	JUMP,NE 90$	LOAD.W	(A6)+ODDDOP,D3	; ODDDOP <-- opration	COMP.W	D3,#1	JUMP,EQ DETRUITICONE	COMP.W	D3,#2	JUMP,EQ DEPDUPICONE	COMP.W	D3,#3	JUMP,EQ DEPDUPICONE	COMP.W	D3,#4	JUMP,EQ DEPDUPICONE	COMP.W	D3,#5	JUMP,EQ CHATRICONE	COMP.W	D3,#6	JUMP,EQ CHCOLICONE	JUMP	80$70$:				; unit physique =>	LOAD.L	A3,#R16"TMCUNIT	CLR.W	D3	CALL	_WAITMMENU	; choix selon mmenu ...	JUMP,NE 90$	COMP.W	D3,#1	JUMP,EQ INFOUNIT	COMP.W	D3,#2	JUMP,EQ NAMEUNIT	COMP.W	D3,#3	JUMP,EQ TYPEUNIT	COMP.W	D3,#4	JUMP,EQ FORMATUNIT	COMP.W	D3,#5	JUMP,EQ COPYUNIT	COMP.W	D3,#6	JUMP,EQ SYSTEMUNIT	COMP.W	D3,#7	JUMP,EQ DEINSTALLUNIT	CALL	HILIICONE	; teint l'icne	JUMP	LOOP80$:	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP,NE LOOP		; oui => LOOP	CALL	HILIICONE	; teint l'icne	JUMP	LOOP85$:	CALL	HILIICONE	; teint l'icne	JUMP	BIPSEL90$:	CALL	HILIICONE	; teint l'icne	JUMP	BIPCLICRECT:	TEST.B	(A5)+OUNPHY	; fentre des units physiques ?	JUMP,T	BIPSEL		; oui => BIPSEL	TEST.W	(A6)+OSELNB	; une slection en cours ?	JUMP',EQ 10$		; non => 10$	COMP.L	A5,(A6)+OSELPU	; dans la mme unit ?	JUMP,NE BIPSEL		; non => BIPSEL10$:	LIB	?IFMOUSE	LOAD.L	D1,D4		; D1 <-- origine	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; <map>	.B	1		; <chelle>	.B	0	.EVEN	CLR.L	D2		; D2 <-- arrive20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 30$		; non => 30$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	CLICRECTINV	; efface l'ancien	LOAD.L	D2,D4		; D2 <-- arrive	CALL	CLICRECTINV	; allume le nouveau	JUMP	20$30$:	CALL	CLICRECTINV	; efface l'ancien	TEST.L	D2	JUMP,EQ BIPSEL	CALL	SELECTRECT	; slectionne toute la zone	TEST.W	(A6)+OSELNB	JUMP,EQ BIPSEL	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCOPY	; touche (COPY) enfonce ?	JUMP,BS LOOPSEL		; oui => LOOPSEL	LOAD.L	A3,#R16"TMCSELECT	CLR.W	D3	LOAD.W	D2,#TYPSELECT	CALL	_WAITMMENU	; choix selon mmenu ...	JUMP,NE LOOPSEL	LOAD.W	(A6)+ODDDOP,D3	; ODDDOP <-- opration	COMP.W	D3,#1	JUMP,EQ DETRUITICONE	COMP.W	D3,#2	JUMP,EQ DEPDUPICONE	COMP.W	D3,#3	JUMP,EQ DEPDUPICONE	COMP.W	D3,#4	JUMP,EQ DEPDUPICONE	COMP.W	D3,#5	JUMP,EQ CHATRICONE	COMP.W	D3,#6	JUMP,EQ CHCOLICONE	JUMP	LOOP; in	D1.L	origine (y;x);	D2.L	arrive (y;x); out	-; mod	D7.WCLICRECTINV:	PUSHM.L	D2..D4	TEST.L	D2	JUMP',EQ 90$	LOAD.L	D3,D1	LOAD.L	D4,D2	SUB.W	D4,D3		; D4 <-- dx	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dy	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT		; inverse le rectangle90$:	POPM.L	D2..D4	RETDETRUITICONE:	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP,NE DEPDUPICONE	; oui => DEPDUPICONE				; non =>	CALL	HILIICONE	; teint l'icne	LOAD.L	A4,#(A5)+OUNNAM	; nom unit source = destination	CALL	DDDEX		; dtruit le fichier	JUMP	ERRORDEPDUPICONE:	LOAD.W	D5,#-1	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP',NE 10$		; oui => 10$	CALL	HILIICONE	; teint l'icne	LOAD.W	D5,D4		; D5 <-- rang icne source	COMP.W	(A6)+ODDDOP,#2	; dplace ?	JUMP',NE 10$		; non => 10$	CALL	EFFICONE	; oui => efface l'icne10$:	LOAD.L	A4,A5	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP,EQ 44$		; oui => 44$				; non =>	CALL	POSICONE	; D4 <-- coin sup/gauche icne	LOAD.L	D1,D4	LIB	?IFMOUSE	EX.L	D1,D4	SUB.W	D1,D4	SWAP.W	D1	SWAP.W	D4	SUB.W	D1,D4	SWAP.W	D1	SWAP.W	D4	CALL	LOLIICONE	; dessine en traitill	LOAD.L	D2,D4	CLR.L	(A6)+ODDDPU	LOAD.W	(A6)+ODDDRA,#-120$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 30$		; non => 30$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	DEDICONE	; allume/teint v. unit/dossier destination	EX.L	D4,D2	CALL	LOLIICONE	; teint l'ancien	EX.L	D2,D4	SUB.W	D4,D1	SWAP.W	D1	SWAP.W	D4	SUB.W	D4,D1	SWAP.W	D1	SWAP.W	D4	CALL	LOLIICONE	; allume le nouveau	LOAD.L	D2,D4	JUMP	20$30$:	LOAD.L	D4,D2	CALL	LOLIICONE	; teint l'ancien	PUSHM.L	D4,A5	LOAD.L	A5,(A6)+ODDDPU	LOAD.W	D4,(A6)+ODDDRA	CALL	HILICCADIC	; teint l'ancien unit/dossier destination	POPM.L	D4,A5	COMP.W	(A6)+ODDDRA,#-1	; unit/dossier de destination existe ?	JUMP',EQ 40$		; non => 40$				; oui =>	PUSH.L	A5	LOAD.L	A5,(A6)+ODDDPU	LOAD.W	D4,(A6)+ODDDRA	CALL	PREPDDU		; A4 <-- ^nom unit/dossier destination	LOAD.L	A2,#0		; A2 <-- ^descripteur unit/dossier destination	POP.L	A5	LOAD.W	D4,D5		; D4 <-- rang icne source	JUMP	45$40$:	PUSH.L	A5	ADD.W	D4,D1	SWAP.W	D1	SWAP.W	D4	ADD.W	D4,D1	SWAP.W	D1	SWAP.W	D4	CALL	DEYICONE	; A5 <-- ^description unit selon souris en Y	LOAD.L	A4,A5		; A4 <-- ^description unit destination	LOAD.W	D4,D5		; D4 <-- rang icne source	POP.L	A5	TEST.W	D7	JUMP,NE 70$	LOAD.W	D7,#ERBIP	; D7 <-- juste un p'tit "bip"	LOAD.L	A3,#(A6)+OUNIT	; A3 <-- ^premire unit	COMP.L	A4,A3		; destination dans la fentre des units physiques ?	JUMP,EQ 80$		; oui => 80$	COMP.W	(A6)+ODDDOP,#2	; dplace ?	JUMP',EQ 43$		; oui => 43$	COMP.W	(A6)+ODDDOP,#4	; accs ?	JUMP',NE 44$		; non => 44$43$:	COMP.L	A4,A5		; dplace dans la mme unit ?	JUMP,EQ 80$		; oui => 80$44$:	LOAD.L	A2,A4		; A2 <-- ^descripteur unit destination	LOAD.L	A4,#(A4)+OUNNAM	; A4 <-- ^nom unit destination45$:	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP',NE 50$		; oui => 50$				; non =>	CALL	DDDEX		; dplace/duplique le fichier	JUMP,NE 75$	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP,EQ LOOP		; oui => LOOP	COMP.L	A2,#0	JUMP,NE LOOP	CALL	DDDRELEASE	; release l'unit destination	JUMP	LOOP50$:				; slection multiple =>	CALL	_DBOXMULDDD	; demande confirmation ...	JUMP',NE 52$;;?	LOAD.W	D7,#ERANNULE	; D7 <-- annule;;?	COMP.W	D3,#F1		; rponse positive ?;;?	JUMP',NE 52$		; non => 52$	COMP.W	D3,#F1		; rponse positive ?	JUMP,NE LOOP		; non => LOOP				; oui =>	TEST.L	D4:#1		; tous les fichiers associs ?	JUMP',BC 51$		; non => 51$	SET.B	(A6)+ODDDAL51$:	CALL	DDDEXMUL	; dtruit/dplace/duplique toute la slection	CLR.B	(A6)+ODDDAL52$:	PUSH.W	D7	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 55$		; oui => 55$	COMP.L	A2,#0	JUMP',NE 55$	CALL	BALWAIT		; traite les messages du FOS ...	LOAD.W	D2,#1		; D2 <-- annule les slections	CALL	BALAFF		; affiche les fentre modifies	CALL	DDDRELEASE	; release l'unit destination55$:	POP.W	D7	JUMP',NE 80$	JUMP	LOOP70$:	CLR.W	D7		; D7 <-- ok (opration annule)	JUMP'	80$75$:	COMP.L	A2,#0	JUMP',NE 80$	CALL	DDDRELEASE	; release l'unit destination80$:	PUSH.W	D7	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP',NE 84$		; oui => 84$	COMP.W	(A6)+ODDDOP,#2	; dplace ?	JUMP',NE 84$		; non => 84$	LOAD.W	D2,#SETDOT	; oui =>	CALL	DESICONE	; redessine l'icne source84$:	POP.W	D7	JUMP	ERRORCHCOLICONE:	LOAD.W	D2,#-1	CALL	_DBOXCOLOR	; choix d'une couleur ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	SL.W	D2,#4	SWAP.W	D2	AND.L	D2,#H'00700000	LOAD.L	(A6)+ODDDAP,D2	NOT.L	D2	AND.L	D2,#H'00700000	LOAD.L	(A6)+ODDDAM,D2	LOAD.W	(A6)+ODDDOP,#5	; ODDOP <-- modifie	CALL	DDDEXMUL	; chatr toute la slection	JUMP	ERRORCHCOLTOUT:	CALL	SELECTALLAFF	; slectionne tout	JUMP	CHCOLICONECHATRICONE:	CALL	_DBOXCHATR	; demande les attributs ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	DDDEXMUL	; chatr toute la slection	JUMP	ERRORCHATRTOUT:	CALL	SELECTALLAFF	; slectionne tout	JUMP	CHATRICONESELECTTOUT:	CALL	SELECTALLAFF	; slectionne tout	JUMP	LOOPSELCLEARTOUT:	CALL	_DBOXCLEAR	; libre tout ...	JUMP,NE ERROR	COMP.W	D3,#'O	JUMP,NE LOOP	CALL	CLEARALL	; libre tous les fichiers	JUMP	ERRORDDDTOUT:	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP,EQ 44$		; oui => 44$				; non =>	LOAD.W	D5,#-1	LOAD.W	D2,#NOCNOM	CALL	POSCADRE	; D3 <-- coin sup/gauche rectangle	LOAD.L	D1,D3	LIB	?IFMOUSE	EX.L	D1,D4	SUB.W	D1,D4	SWAP.W	D1	SWAP.W	D4	SUB.W	D1,D4	SWAP.W	D1	SWAP.W	D4	CALL	LOLITOUT	; dessine en traitill	LOAD.L	D2,D4	CLR.L	(A6)+ODDDPU	LOAD.W	(A6)+ODDDRA,#-120$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 30$		; non => 30$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	DEDICONE	; allume/teint v. unit/dossier destination	EX.L	D4,D2	CALL	LOLITOUT	; teint l'ancien	EX.L	D2,D4	SUB.W	D4,D1	SWAP.W	D1	SWAP.W	D4	SUB.W	D4,D1	SWAP.W	D1	SWAP.W	D4	CALL	LOLITOUT	; allume le nouveau	LOAD.L	D2,D4	JUMP	20$30$:	LOAD.L	D4,D2	CALL	LOLITOUT	; teint l'ancien	PUSHM.L	D4,A5	LOAD.L	A5,(A6)+ODDDPU	LOAD.W	D4,(A6)+ODDDRA	CALL	HILICCADIC	; teint l'ancien unit/dossier destination	POPM.L	D4,A5	COMP.W	(A6)+ODDDRA,#-1	; unit/dossier de destination existe ?	JUMP',EQ 40$		; non => 40$				; oui =>	PUSH.L	A5	LOAD.L	A5,(A6)+ODDDPU	LOAD.W	D4,(A6)+ODDDRA	CALL	PREPDDU		; A4 <-- ^nom unit/dossier destination	LOAD.L	A2,#0		; A2 <-- ^descripteur unit/dossier destination	POP.L	A5	LOAD.W	D4,D5		; D4 <-- rang icne source	JUMP	45$40$:	PUSH.L	A5	ADD.W	D4,D1	SWAP.W	D1	SWAP.W	D4	ADD.W	D4,D1	SWAP.W	D1	SWAP.W	D4	CALL	DEYICONE	; A5 <-- ^description unit selon souris en Y	LOAD.L	A4,A5		; A4 <-- ^description unit destination	LOAD.W	D4,D5		; D4 <-- rang icne source	POP.L	A5	TEST.W	D7	JUMP,NE LOOP	LOAD.W	D7,#ERBIP	; D7 <-- juste un p'tit "bip"	LOAD.L	A3,#(A6)+OUNIT	; A3 <-- ^premire unit	COMP.L	A4,A3		; destination dans la fentre des units physiques ?	JUMP,EQ ERROR		; oui => ERROR	COMP.L	A4,A5		; dplace/duplique dans la mme unit ?	JUMP,EQ ERROR		; oui => ERROR44$:	LOAD.L	A2,A4		; A2 <-- ^descripteur unit destination	LOAD.L	A4,#(A4)+OUNNAM	; A4 <-- ^nom unit destination45$:	CALL	SELECTALLAFF	; slectionne tout	CALL	_DBOXALLDDD	; demande confirmation ...	JUMP',NE 52$	LOAD.W	D7,#ERANNULE	; D7 <-- annule	COMP.W	D3,#F1		; rponse positive ?	JUMP',NE 52$		; non => 52$				; oui =>	TEST.L	D4:#1	JUMP',BS 50$	CALL	DDDEXMUL	; dtruit/dplace/duplique toute la slection	JUMP'	52$50$:	CALL	DDDEXALL	; dtruit/dplace/duplique tous les fichiers52$:	PUSH.W	D7	COMP.W	(A6)+ODDDOP,#1	; dtruit ?	JUMP',EQ 55$		; oui => 55$	COMP.L	A2,#0	JUMP',NE 55$	CALL	DDDRELEASE	; release l'unit destination55$:	POP.W	D7	JUMP	ERRORSELECTONE:	CALL	GETPFILE	; A3 <-- ^nom du fichier	TEST.B	(A3)+OFLATT+0:#BATTSEL-24 ; icne slectionne ?	JUMP',BS 15$		; oui => 15$				; non =>	COMP.W	D2,#TYPSYSC	; fichier SYSTEM.CODE ?	JUMP',EQ 10$		; oui => 10$	COMP.W	D2,#TYPDOSSIER	; DOSSIER: ?	JUMP',NE 15$		; non => 15$10$:				; oui =>	CALL	HILIICONE	; teint l'icne	JUMP	BIPSEL15$:	TEST.W	(A6)+OSELNB	; dj une slection en cours ?	JUMP',NE 50$		; oui => 50$				; non =>	INC.W	(A6)+OSELNB	LOAD.L	(A6)+OSELPU,A5	TSET.B	(A3)+OFLATT+0:#BATTSEL-24 ; slectionne l'icne	LOAD.W	(A3)+OFLRAF,#-1	; signal icne  redessiner	JUMP	LOOPSEL50$:	COMP.L	A5,(A6)+OSELPU	; dans la mme unit ?	JUMP,NE 10$		; non => 10$	TSET.B	(A3)+OFLATT+0:#BATTSEL-24 ; slectionne l'icne	JUMP',BS 60$	LOAD.W	(A3)+OFLRAF,#-1	; signal icne  redessiner	INC.W	(A6)+OSELNB	; une icne de plus	JUMP	LOOPSEL60$:	TCLR.B	(A3)+OFLATT+0:#BATTSEL-24 ; d-slectionne l'icne	DEC.W	(A6)+OSELNB	; une icne de moins	JUMP	LOOPSELMODIFICONE:	CALL	_DBOXMODIF	; modifie le fichier ...	PUSH.W	D7	CALL	HILIICONE	; teint l'icne	POP.W	D7	JUMP	ERRORCOLORICONE:	CALL	_DBOXCOLOR1	; choix de la couleur ...	PUSH.W	D7	CALL	HILIICONE	; teint l'icne	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CALL	DESICONE	; affiche l'icne	POP.W	D7	JUMP	ERRORPARAMICONE:	CALL	PREPFIS		; A3 <-- ^nom du fichier	CALL	_DBOXHEADER	; modifie l'en-tte	PUSH.W	D7	CALL	HILIICONE	; teint l'icne	POP.W	D7	JUMP	ERROREDITICONE:	CALL	PREPFIC		; A3 <-- ^nom du fichier (avec la clef)	JUMP',NE 90$	CALL	EDITE		; dite le fichier ...90$:	PUSH.W	D7	CALL	HILIICONE	; teint l'icne	POP.W	D7	JUMP	ERRORVISUICONE:	CALL	PREPFIC		; A3 <-- ^nom du fichier (avec la clef)	JUMP',NE 90$	CALL	VISUALISE	; viualise le fichier ...90$:	PUSH.W	D7	CALL	HILIICONE	; teint l'icne	POP.W	D7	JUMP,NE	ERROR	TEST.W	(A6)+OSELNB	; a-t-on fait une slection multiple ?	JUMP,EQ LOOP		; non => LOOP	CALL	ALLICONE	; oui => redessine toutes les icnes	JUMP	LOOPSELPRINTICONE:	.IF	MPRINT	PUSHM.L	D4,A5	CALL	DIRDOC		; fait un DIR pour le document	JUMP,NE 90$	CALL	PREPFIC		; A3 <-- ^nom du fichier  imprimer (avec la clef)	JUMP,NE 90$; Demande comment imprimer ...	CLR.L	D3		; D3 <-- mode	TSET.L	D3:#BPRNOFILE	; D3 <-- pas de fichier en sortie	TSET.L	D3:#BPRCHOIX	; D3 <-- (CHOIX) actif	COMP.W	D2,#TYPIMAGE	; fichier image ?	JUMP',EQ 10$		; oui => 10$	COMP.W	D2,#TYPCOLOR	; fichier color ?	JUMP',NE 12$		; non => 12$10$:	TSET.L	D3:#BPRNOINTERV	; D3 <-- pas de page de ..  ..12$:;	LOAD.L	A3,A3		; A3 <-- ^nom du fichier	LOAD.L	A4,#(A6)+OBUFIT	; A4 <-- ^nom de la prsentation	CLR.B	(A4)	LOAD.L	A5,#R16"00$	; A5 <-- ^nom du logiciel	LOAD.L	A1,#(A6)+OBUFIU	; A1 <-- ^nom du fichier en sortie	CLR.B	(A1)	CLR.L	D2		; D2 <-- longueur du document (!)	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	OPPRINT		; ouvre l'impression	JUMP,NE 90$	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier source	JUMP,NE 85$; Demande la mmoire temporaire pour effectuer le transfert.	LOAD.W	D3,#16/2	; D3 <-- la moiti	LOAD.L	D4,#256*1	; D4 <-- mimimum	LOAD.L	D5,#256*256	; D5 <-- maximum	LOAD.W	D1,#MTYPCP	GESMEM	?GETPMEM	; demande grand buffer	JUMP,NE 80$	LOAD.L	A5,A4		; A5 <-- ^grand buffer	LOAD.L	D5,D4		; D5 <-- lg grand buffer; Effectue le transfert par tranches.30$:	LOAD.L	A4,A5		; A4 <-- ^trs grand buffer	LOAD.L	D4,D5		; D4 <-- longueur buffer	FOS	?RDBYTE		; lit une grande tranche ...	LOAD.W	D0,D7	JUMP',EQ 40$		; ok => 40$	COMP.W	D7,#EROUTF	JUMP',NE 70$40$:	PRINTA_	WRPRINT		; imprime une grande tranche ...	JUMP',NE 70$		; erreur => 70$	TEST.W	D0		; EOF rencontr en lecture ?	JUMP,EQ 30$		; non => 30$; Libre la mmoire temporaire.70$:	PUSH.W	D7	LOAD.L	A4,A5		; A4 <-- ^zone mmoire	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le grand buffer	POP.W	D780$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier source	POP.W	D785$:	LOAD.W	D6,D7	PRINTA_	CLPRINT		; ferme l'impression	COMP.W	D7,D6	JUMP',HS 90$	LOAD.W	D7,D690$:	POPM.L	D4,A5	PUSH.W	D7	CALL	HILIICONE	; teint l'icne	CALL	RELDOC		; annule les DIRs prcdents	CALL	_AFMENU		; dessine les soft-keys	POP.W	D7	JUMP	ERROR00$:	.ASCIZ	"START"	.EVEN	.ELSE	CALL	DIRDOC		; fait un DIR pour le document	JUMP,NE 90$	CALL	PREPFIC		; A3 <-- ^nom du fichier  imprimer (avec la clef)	JUMP,NE 90$	CALL	_WAITDBOX	; ouvre la dbox d'attente	JUMP,NE 90$	LOAD.L	A3,#R16"00$	CALL	_AFFTDBOX	; affiche "attendez un instant ..."	LOAD.W	(A6)+ODDDOP,#3	; opration "duplique"	LOAD.W	(A6)+ODDDXF,#XFPRINT	CLR.B	(A6)+ODDDSW	; pas de switchs trouvs	CLR.L	(A6)+ODDDAP	; pas d'attributs  ajouter (+)	CLR.L	(A6)+ODDDAM	; pas d'attributs  enlever (-)	CALL	DDDDISK		; imprime ...90$:	CALL	_NORMDBOX	; ferme la dbox d'attente95$:	PUSH.W	D7	CALL	HILIICONE	; teint l'icne	CALL	RELDOC		; annule les DIRs prcdents	POP.W	D7	JUMP	ERROR00$:	.ASCIZ	"       Attendez un instant ...      "	.EVEN	.ENDIFVERROUICONE:	CALL	_IFDBOXCLEF	; demande la clef ...	JUMP',NE 80$	LOAD.W	D7,#ERANNULE	COMP.W	D3,#F1		; D'ACCORD ?	JUMP',NE 80$		; non => 80$				; oui =>	CALL	GETPFILE	; A3 <-- ^nom	LOAD.L	D3,(A3)+OFLATT	; D3 <-- attributs	TEST.L	D3:#BATTQ	; fichier verrouill ?	JUMP',BS 40$		; oui => 40$				; non =>	TEST.W	(A6)+ONBCLE	; premire utilisation de la clef ?	JUMP',NE 30$		; non => 30$	CALL	_DBOXCONFCLEF	; oui => demande confirmation de la clef ...	JUMP',NE 80$	COMP.W	D3,#F1		; VERROUILLE ?	JUMP',NE 80$		; non => 80$30$:	CALL	LOCKEX		; verrouille le fichier	JUMP'	80$40$:	CALL	UNLOCKEX	; dverrouille le fichier80$:	PUSH.W	D7	CALL	HILIICONE	; teint l'icne	POP.W	D7	JUMP	ERRORDEINSTALLUNIT:	CALL	HILIICONE	; teint l'icne	CALL	GETPFILE	; A3 <-- ^nom	CALL	IFUUSE		; unit utilise ?	JUMP,NE ERROR	COMP.B	(A3)+OFLTYP,#'@	JUMP',EQ 50$	CALL	_WAITMOUSE	; souris: met le sablier	FOS	?RELEASE	; libre l'unit	CLR.W	D3		; D3 <-- global	FOS	?DEINSTALL	; deinstalle l'unit	JUMP	ERROR50$:	CLR.W	D3		; D3 <-- global	FOS	?DEASSIGN	; deassigne l'unit	JUMP	ERRORTYPEUNIT:	CALL	GETPFILE	; A3 <-- ^nom	CALL	IFUUSE		; unit utilise ?	JUMP',NE 90$	LOAD.W	D7,#ERSFORM	COMP.B	(A3)+OFLTYP,#'@	JUMP',EQ 90$	FOS	?RELEASE	CALL	_DBOXTYPE	; choix du type pour la disquette ...	CALL	HILIICONE	; teint l'icne	JUMP	LOOP90$:	PUSH.W	D7	CALL	HILIICONE	; teint l'icne	POP.W	D7	JUMP	ERRORFORMATUNIT:	CALL	GETPFILE	; A3 <-- ^nom	CALL	IFUUSE		; unit utilise ?	JUMP',NE 90$	LOAD.W	D7,#ERSFORM	COMP.B	(A3)+OFLTYP,#'@	JUMP',EQ 90$	FOS	?RELEASE	CALL	_DBOXFORMAT	; demande comment formater ...	PUSH.W	D7	FOS	?RELEASE	POP.W	D7	JUMP',NE 90$	CALL	HILIICONE	; teint l'icne	JUMP	LOOP90$:	PUSH.W	D7	CALL	HILIICONE	; teint l'icne	POP.W	D7	JUMP	ERRORCOPYUNIT:	CALL	HILIICONE	; teint l'icne	LOAD.W	D5,D4		; D5 <-- rang icne source	CALL	POSICONE	; D4 <-- coin sup/gauche icne	LOAD.L	D1,D4	LIB	?IFMOUSE	EX.L	D1,D4	SUB.W	D1,D4	SWAP.W	D1	SWAP.W	D4	SUB.W	D1,D4	SWAP.W	D1	SWAP.W	D4	CALL	LOLIICONE	; dessine en traitill	LOAD.L	D2,D4	CLR.L	(A6)+ODDDPU	LOAD.W	(A6)+ODDDRA,#-120$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 30$		; non => 30$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	PUSHM.L	D5,A5	LOAD.L	A5,#0		; A5/D5 <-- source = destination possible !	LOAD.W	D5,#-1	CALL	DEDICONE	; allume/teint v. unit/dossier destination	POPM.L	D5,A5	EX.L	D4,D2	CALL	LOLIICONE	; teint l'ancien	EX.L	D2,D4	SUB.W	D4,D1	SWAP.W	D1	SWAP.W	D4	SUB.W	D4,D1	SWAP.W	D1	SWAP.W	D4	CALL	LOLIICONE	; allume le nouveau	LOAD.L	D2,D4	JUMP	20$30$:	LOAD.L	D4,D2	CALL	LOLIICONE	; teint l'ancien	PUSHM.L	D4,A5	LOAD.L	A5,(A6)+ODDDPU	LOAD.W	D4,(A6)+ODDDRA	CALL	HILICCADIC	; teint l'ancien unit/dossier destination	POPM.L	D4,A5	COMP.W	(A6)+ODDDRA,#-1	; unit/dossier de destination existe ?	JUMP',EQ 40$		; non => 40$				; oui =>	PUSH.L	A5	LOAD.L	A5,(A6)+ODDDPU	LOAD.W	D4,(A6)+ODDDRA	CALL	PREPDDU		; A4 <-- ^nom unit/dossier destination	LOAD.L	A2,#0		; A2 <-- ^descripteur unit/dossier destination	POP.L	A5	LOAD.W	D4,D5		; D4 <-- rang icne source	JUMP	45$40$:	PUSH.L	A5	ADD.W	D4,D1	SWAP.W	D1	SWAP.W	D4	ADD.W	D4,D1	SWAP.W	D1	SWAP.W	D4	CALL	DEYICONE	; A5 <-- ^description unit selon souris en Y	LOAD.L	A4,A5		; A4 <-- ^description unit destination	LOAD.W	D4,D5		; D4 <-- rang icne source	POP.L	A5	TEST.W	D7	JUMP,NE LOOP	LOAD.W	D7,#ERBIP	; D7 <-- juste un p'tit "bip"	LOAD.L	A3,#(A6)+OUNIT	; A3 <-- ^premire unit	COMP.L	A4,A3		; destination dans la fentre des units physiques ?	JUMP,EQ ERROR		; oui => ERROR	LOAD.L	A2,A4		; A2 <-- ^descripteur unit destination	LOAD.L	A4,#(A4)+OUNNAM	; A4 <-- ^nom unit destination45$:	CALL	COPYEX		; dplace/duplique le fichier	JUMP,NE ERROR	JUMP	LOOPINFOUNIT:	CALL	GETPFILE	; A3 <-- ^nom	LOAD.L	D3,#2^BEAUTOM	; D3 <-- signal BAL comme enter automatique	LOAD.L	D0,#FOS?NENTER	CALL	_ERCALL		; essaye un ENTER	COMP.W	D7,#ERKSTO	JUMP',EQ 80$	LOAD.W	D6,D7		; D6 <-- enter ok/erreur	CALL	_DBOXDISK	; affiche les infos ...	PUSH.W	D7	TEST.W	D6		; enter ok ?	JUMP',NE 60$		; non => 60$	LOAD.L	D3,#2^BEAUTOM	; D3 <-- signal BAL comme enter automatique	LOAD.L	D0,#FOS?LRELEASE	CALL	_ERCALL60$:	CALL	HILIICONE	; teint l'icne	POP.W	D7	JUMP	ERROR80$:	CALL	HILIICONE	; teint l'icne	JUMP	LOOPNAMEUNIT:	CALL	GETPFILE	; A3 <-- ^nom	LOAD.L	D3,#2^BEAUTOM	; D3 <-- signal BAL comme enter automatique	LOAD.L	D0,#FOS?NENTER	CALL	_ERCALL		; essaye un ENTER	COMP.W	D7,#ERKSTO	JUMP',EQ 80$	LOAD.W	D6,D7		; D6 <-- enter ok/erreur	CALL	_DBOXNAME	; demande le nom ...	PUSH.W	D7	TEST.W	D6		; enter ok ?	JUMP',NE 60$		; non => 60$	LOAD.L	D3,#2^BEAUTOM	; D3 <-- signal BAL comme enter automatique	LOAD.L	D0,#FOS?LRELEASE	CALL	_ERCALL60$:	CALL	HILIICONE	; teint l'icne	POP.W	D7	JUMP	ERROR80$:	CALL	HILIICONE	; teint l'icne	JUMP	LOOPSYSTEMUNIT:	CALL	HILIICONE	; teint l'icne	CALL	_WAITMOUSE	; souris: met le sablier	CALL	GETPFILE	; A3 <-- ^nom	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D0,#FOS?INFODISK	CALL	_ERCALL		; OBUHEAD <-- informations du disque	JUMP,NE ERROR	LOAD.L	A4,#(A6)+OBUFIT20$:	LOAD.B	(A4+),(A3+)	; OBUFIT <-- nom de l'unit	JUMP,NE 20$	DEC.L	A4	LOAD.L	A3,#(A6)+OBUHEAD+OBK0SYS22$:	LOAD.B	(A4+),(A3+)	; OBUFIT <-- nom du dossier systme	JUMP,NE 22$	LOAD.L	A3,#(A6)+OBUFIT	CLR.W	D4	FOS	?SDIR		; spcifie le rpertoire systme	JUMP,NE ERROR	CALL	INFO		; affiche les infos tout en haut	JUMP	LOOPCLICCASE:			; clic dans une case en haut wdo =>	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP,NE EXIT$		; oui => EXIT$	TEST.B	(A5)+OUNPHY	; fentre des units physiques ?	JUMP,T	PHYS$		; oui => PHYS$				; non =>	COMP.W	D2,#NOCFERME	JUMP',EQ FERME$	COMP.W	D2,#NOCTOUT	JUMP,EQ TOUT$	COMP.W	D2,#NOCNOM	JUMP,EQ NOM$	COMP.W	D2,#NOCCOMPTE	JUMP,EQ COMPTE$	COMP.W	D2,#NOCREFAIT	JUMP,EQ REFAIT$	COMP.W	D2,#NOCLISTE	JUMP,EQ LISTE$	JUMP	EXIT$FERME$:				; case de fermeture =>	CALL	INVCADRE	; teint la dernire case	PUSH.L	D3	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BKILL	; touche (KILL) enfonce ?	POPM.L	D3	JUMP',BS FERMEK$	; oui => FERMEK$FERME2$:			; non =>	CALL	IFRELEASE	; release si plus de fils	CALL	CLOWDO		; ferme la fentre	JUMP	LOOPFERMEK$:	LOAD.L	A3,#(A5)+OUNNAM	LOAD.L	A4,#(A6)+OBUFIS	; A4 <-- ^bufferFERME4$:	LOAD.B	(A4+),(A3+)	; OBUFIS <-- nom complet	JUMP,NE FERME4$	LOAD.L	A3,#(A6)+OBUFIS	; A3 <-- ^nom complet	LOAD.L	A4,A3	CALL	SKIPREP	DEC.L	A3FERME5$:	COMP.L	A3,A4	JUMP,EQ FERME2$	COMP.B	(-A3),#':	JUMP,NE FERME5$	LOAD.B	(A3)+1,#'*	; unit:rep:rep:* --> unit:rep:*	CLR.B	(A3)+2	LOAD.L	A3,#(A6)+OBUFIS	CALL	IFEQUUSE	; unit dj utilise ?	JUMP,NE	ERROR		; oui => ERROR	LOAD.L	A4,#(A5)+OUNNAMFERME7$:	LOAD.B	(A4+),(A3+)	; OUNNAM <-- nouveau nom	JUMP,NE FERME7$	CALL	_RDDIRINFO	; lit START_DIR.INFO s'il existe	CALL	_RDLIST		; lit la liste des noms de fichiers	JUMP,NE FERME2$	CALL	ALLREFAIT	; redessine toute la fentre	JUMP	LOOPTOUT$:				; case TOUT =>	CALL	INVCADRE	; teint la dernire case	CALL	ENDWDO		; met cette fentre tout  la fin	JUMP	LOOPNOM$:				; case NOM =>	TEST.W	(A5)+OUNNBT	; au moins un fichier ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.L	A3,#R16"TMCALLWDO	CLR.W	D3	PUSH.L	D2	LOAD.W	D2,#TYPALLWDO	CALL	_WAITMMENU	; choix selon mmenu ...	POPM.L	D2	JUMP,NE EXIT$	CALL	INVCADRE	; teint la dernire case	COMP.W	D3,#4	JUMP',LO 30$	INC.W	D3		; D3 <-- #5 pour "modifie"30$:	LOAD.W	(A6)+ODDDOP,D3	; ODDDOP <-- opration	COMP.W	D3,#1	JUMP,EQ DDDTOUT	COMP.W	D3,#2	JUMP,EQ DDDTOUT	COMP.W	D3,#3	JUMP,EQ DDDTOUT	COMP.W	D3,#5	JUMP,EQ CHATRTOUT	COMP.W	D3,#6	JUMP,EQ CHCOLTOUT	COMP.W	D3,#7	JUMP,EQ SELECTTOUT	COMP.W	D3,#8	JUMP,EQ CLEARTOUT	JUMP	LOOPCOMPTE$:			; case COMPTE =>	CALL	_DBOXCOMPTE	; faites vos comptes ...	CALL	INVCADRE	; teint la dernire case	JUMP	LOOPREFAIT$:			; REFAIT =>	CALL	INVCADRE	; teint la dernire case	CALL	_RDLIST		; relit la liste des fichiers	JUMP,NE ERROR	CALL	ALLREFAIT	; redessine toute la fentre	JUMP	LOOPLISTE$:				; LISTE =>	CALL	_DBOXLISTE	; change de liste ...	CALL	INVCADRE	; teint la dernire case	COMP.W	D3,#F0		; (ANNULE) ?	JUMP,EQ LOOP		; oui => LOOP	CALL	DIMICO		; recalcul les dimensions d'une icne	CALL	ALLREFAIT	; redessine toute la fentre	COMP.W	D3,#F4		; (MEMORISE) ?	JUMP,NE LOOP		; non => LOOP	CALL	WRDIRINFO	; oui => crit START_DIR.INFO	JUMP	ERRORPHYS$:				; units physiques =>	COMP.W	D2,#NOCFERME	JUMP',EQ PFERME$	COMP.W	D2,#NOCREFAIT	JUMP',EQ PREFAIT$	COMP.W	D2,#NOCLISTE	JUMP,EQ PLISTE$	JUMP	EXIT$PFERME$:			; case de fermeture =>	CALL	INVCADRE	; teint la dernire case	JUMP	DOARRETPREFAIT$:			; REFAIT =>	CALL	INVCADRE	; teint la dernire case	CALL	_RDUSER		; relit START_USER.INFO	CALL	_RDLIST		; relit la liste des units physiques	JUMP,NE ERROR	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-1PREFAIT2$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP,F	LOOP		; non => LOOP	CALL	ALLREFAIT	; oui => redessine toute la fentre	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,PREFAIT2$	JUMP	LOOPPLISTE$:			; AUTRE =>	LOAD.L	D3,(A6)+OSWITCH	TEST.L	D3:#('A-'A)	; START/A ?	JUMP,BS EXIT$		; oui => EXIT$	CALL	_DBOXINSTALL	; installe une unit physique ...	PUSH.W	D7	CALL	INVCADRE	; teint la dernire case	POP.W	D7	JUMP	ERROREXIT$:	CALL	INVCADRE	; teint la dernire case	JUMP	BIP	.INS	STARTEDIT.ASI	.INS	STARTICO.ASI	.INS	STARTAFF.ASI	.INS	STARTFILE.ASI	.INS	STARTIND1.ASI	.INS	STARTLIST.ASI	.INS	STARTCOPY.ASI	.INS	STARTIO.ASI	.INS	STARTMENU.ASI	.INS	STARTDBOX.ASI	.INS	STARTIND2.ASI	.INS	STARTDBOXT.ASI	.INS	STARTERROR.ASI	.INS	STARTMISC.ASI	.INS	STARTSLEEP.ASI	.INS	STARTAPP.ASI	.END	START