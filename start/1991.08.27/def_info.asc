	.TITLE	DEF_INFO.ASC;	--------------------------------------;		(C) 1991 - Daniel Roux;	--------------------------------------;	Source du programme DEF_INFO.CODE	.PROC	M680002	.RADIX	10.	.HEXDEFREV	=	1		; rvisionDEFVERS	=	1		; version;	Date		Amliorations; --------------------------------------------------------------------------------------------------; 1.1	23.05.91	priorit plus leve (23 -> 11); 1.0	16.05.91	premire version	.REF	SMAKY	.REF	MODULES;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;SMAKY300 = 7OINVOL = OINSTA+4		; volume du h-p dans 100_INFO;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.REV	DEFREV,DEFVERS;;?	.HEADER	OBXSOVER.L OVERLAY	; faire "HEADER DEF_INFO.CODE 16/O" !!!	.CODE	800,11,B'100111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LBUDIS	=	20KEYDBOX	=	H'7E00		; "touche" pour dbox; Variables; ---------	.LOC	0OPLCOM:	.BLKB	4		; ^ligne de commandeOBUDIS:	.BLKB	LBUDIS		; buffer temporaireOMOUSE:	.BLKB	1		; mode souris initialOMACHINE:.BLKB	1		; type de la machine (SMAKY*)	.EVENOCHMENU:.BLKB	4		; canal des soft-keysLGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	CALL	OVERLAY	LIB	?CLOLIB	FOS	?STOPOVERLAY:	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE EXIT$	GESMEM	?CLEARMEM	; met TOUTES les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; OPLCOM <-- ^ligne de commande	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	NTREL	?GETMACHINE	RL.L	D4,#8	LOAD.B	(A6)+OMACHINE,D4	LOAD.L	A3,(A6)+OPLCOM	LOAD.B	D3,#'I	LIB	?IFSWITCH	; excut avec /i ?	JUMP',EQ INIT$		; oui => INIT$	CALL	DBOXMAIN	; appel dbox principale ...	JUMP',EQ END$	JUMP'	NOOVER$INIT$:;	...	JUMP'	END$NOOVER$:	LOAD.W	D7,#-1		; D7 <-- demande une excution normaleEND$:	PUSH.W	D7	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre les variables	POP.W	D7EXIT$:	RET;---------\\; DBOXMAIN >;=========/; Modifie quelques informations gnrales sur la machine.; in	-; out	D7.W	erreur; mod	D7.WDBOXMAIN:	PUSHM.L	D0..D6,A1..A5	LIB	?PUSHMENU	; sauve les soft-keys	LOAD.L	(A6)+OCHMENU,D5	LIB	?GMOUSE	LOAD.B	(A6)+OMOUSE,D3	LOAD.W	D3,#2	LIB	?MOUSE		; souris par le clavier	CALL	NORMMOUSE	; souris: enlve le sablier	LOAD.L	A2,#R16"TDBOX_MAIN	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	PUSH.W	D4	SR.W	D4,#8	AND.L	D4,#H'FF	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche la rvision	LOAD.B	D3,#'.	LIB	?AFCAR	POP.W	D4	AND.L	D4,#H'FF	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche la version	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	NTREL	?GETMACHINE10$:	TEST.B	(A3+)	JUMP,NE 10$	LIB	?AFTEXT		; affiche "Smaky 100"	LIB	?AFTIM	.ASCIZ	" numro "	.EVEN	AND.L	D4,#H'FFFFFF	LOAD.B	D3,#5		; D3 <-- 5 digits au maximum	LOAD.B	D2,#2^BAFDCM!2^BAFDSP ; D2 <-- compact + '	LIB	?AFDEC		; affiche en dcimal	LOAD.W	D2,#4!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	PUSH.L	D5	GESMEM	?ARGLGM		; D4 <-- total  D5 <-- user	POP.L	D5	LOAD.B	D3,#8	LOAD.B	D2,#2^BAFDSP	; D2 <-- '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	" octets"	.EVEN	LOAD.W	D2,#5!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	PUSH.L	D5	GESMEM	?ARGMEM		; D4 <-- total  D5 <-- user	LOAD.L	D1,D5	POP.L	D5	LOAD.B	D3,#8	LOAD.B	D2,#2^BAFDSP	; D2 <-- '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	" octets"	.EVEN	LOAD.W	D2,#6!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,D1	LOAD.B	D3,#8	LOAD.B	D2,#2^BAFDSP	; D2 <-- '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	" octets"	.EVEN	POP.L	D4LOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_MAIN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP',EQ END$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$END$:				; VU =>	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D7EXIT$:	PUSH.W	D7	LOAD.B	D3,(A6)+OMOUSE	LIB	?MOUSE		; remet le mode souris initial	LOAD.L	D5,(A6)+OCHMENU	LIB	?POPMENU	; restitue les soft-keys	CALL	NORMMOUSE	; souris: enlve le sablier	POP.W	D7	POPM.L	D0..D6,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_MAIN:	.W	10$-TDBOX_MAIN	.W	20$-TDBOX_MAIN	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"Systme rvision "	.B	ODBLABEL,2	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR	.B	ODBLABEL,3	.B	ODBTEXT	.ASCIZ	""	;	 Smaky 100 numro 12'345	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Capacit mmoire: "	.B	ODBLABEL,4	.B	ODBTEXT	.ASCIZ	""	;	 1'000'000 octets	.B	ODBTABX,18+19	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Mmoire libre:    "	.B	ODBLABEL,5	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Plus grand trou:  "	.B	ODBLABEL,6	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"   VU   "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Vu"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_MAIN:	.W	F1,F2,F3,0		DOKF1-TKEY_MAIN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MAIN	.W	0;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RET	.END	START