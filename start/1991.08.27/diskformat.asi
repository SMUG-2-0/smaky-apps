	.SBTTL	DISKFORMAT.ASI;-------------\\; _DISK_FORMAT >;=============/; Demande s'il faut formater un disque.; in	A3.L	^nom du disque;	D3.W	operating system (DISKOS*, 0=tous); out	D3.W	dernire touche (F0/F1);	D7.W	erreur; mod	D3.L, D7.W_DISK_FORMAT:	PUSHM.L	D0..D2,D4,D5,A1..A6	CALL	OPEVAR		; A6 <-- ^variables globales	JUMP,NE QUIT$	LOAD.W	(A6)+OOS,D3	; OOS <-- operating system	LOAD.W	(A6)+OOP,#1	; OOP <-- formate;	CLR.B	(A6)+OBUNLO	; pas de nom logique connu	LOAD.L	A3,#(A6)+OBUNAM	; A3 <-- ^nom du disque	CALL	FMTSTATUS	; A4 <-- ^status	JUMP,NE EXIT$	LOAD.L	A2,#R16"TDBOX_FORMAT	LOAD.L	D4,#B'11	; D4 <-- fanions	COMP.W	(A6)+OOS,#DISKOSSMAKY	JUMP',EQ OPEN$	LOAD.L	A2,#R16"TDBOX_FORMPH	LOAD.L	D4,#B'01	; D4 <-- fanions (seulement physique)OPEN$:	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUNAM	; A3 <-- ^nom du disque	CLR.W	D3		; D3 <-- global	FOS	?VASSIGN	; A4 <-- ^nom physique ($...)	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le nom physique	LIB	?AFTIM	.ASCIZ	" comme suit :"	.EVEN	POP.L	D4;;?	COMP.W	(A6)+OBUSTA+OMNBFMTREC,#1	CALL	DBTYPSLDRAW	; dessine la scroll-liste	LOAD.L	A3,#(A6)+OBUNLO	LOAD.L	A4,A3LEND$:	TEST.B	(A4+)	JUMP,NE LEND$	DEC.L	A4	CALL	NORMMOUSE	; souris: enlve le sablierLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_FORMAT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ FORMAT$	COMP.W	D3,#F0	JUMP,EQ CLOSE$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	LOOP$CLIC$:	CALL	DBTYPSLMOVE	; dplace la scroll-liste ...	JUMP,NE BIP$	JUMP	LOOP$FORMAT$:			; D'ACCORD =>	LOAD.W	D1,(A6)+OSLVAR+OSLCYS	COMP.W	D1,(A6)+OSLVAR+OSLCYN	JUMP,HS BIP$	TEST.L	D4		; qq chose  faire ?	JUMP,EQ BIP$		; non => BIP$;;?	TEST.L	D4:#1		; formatage software ?;;?	JUMP',BC 62$		; non => 62$;;?	TEST.B	(A3)		; nom du disque existe ?;;?	JUMP,EQ BIP$		; non => BIP$;;?62$:				; oui =>	CALL	WAITMOUSE	; souris: met le sablier	DBOX_	CLOSE		; ferme la DBOX	LOAD.W	D1,#DBOX_OPWAIT	LOAD.W	D2,#2^BDBEXTEND	DBOX_	EXTEND		; affiche "attendez un instant ..."	JUMP,NE EXIT$	LOAD.L	D2,D4		; D2 <-- fanions	LOAD.W	D4,(A6)+OSLVAR+OSLCYS	CALL	FMTSEARCH	; A4 <-- ^format FMT	JUMP',NE FEND$	LOAD.L	A3,#(A6)+OBUNAM	; A3 <-- ^nom du disque	CALL	FMTFORMAT	; choix du format	JUMP',NE FEND$	TEST.L	D2:#0		; formatage physique ?	JUMP',BC FSOFT$		; non => FSOFT$				; oui =>	LOAD.L	A3,#(A6)+OBUNAM	; A3 <-- ^nom du disque	CALL	PFORMAT		; format physique de l'unit ...	JUMP',NE FEND$FSOFT$:	TEST.L	D2:#1		; formatage software ?	JUMP',BC FEND$		; non => FEND$				; oui =>	LOAD.L	A3,#(A6)+OBUNAM	; A3 <-- ^nom du disque	LOAD.L	A4,#(A6)+OBUNLO	; A4 <-- ^nom logique du disque	CALL	LFORMAT		; format logique de l'unit ...FEND$:	PUSH.W	D7	LOAD.W	D1,#DBOX_CLWAIT	LOAD.W	D2,#2^BDBEXTEND	DBOX_	EXTEND		; enlve "attendez un instant ..."	POP.W	D7	JUMP'	EXIT$CLOSE$:				; ANNULE =>	DBOX_	CLOSE		; ferme la DBOXEXIT$:	CALL	CLOVAR		; rend les variables globalesQUIT$:	POPM.L	D0..D2,D4,D5,A1..A6	TEST.W	D7		; retour EQ/NE	RETTDBOX_FORMAT:	.W	10$-TDBOX_FORMAT	.W	20$-TDBOX_FORMAT	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"Formate le disque "	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Nom du disque "	.B	ODBLINE,14+2	.B	ODBCR,ODBCR	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,40	.B	ODBLABEL,11	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCR,ODBCR	.B	ODBSQUARE,0	.ASCIZ	" formatage physique (disque neuf)"	.B	ODBCR	.B	ODBSQUARE,1	.ASCIZ	" formatage logique"	.B	ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	" FORMATE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBMEV	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Formate"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTDBOX_FORMPH:	.W	10$-TDBOX_FORMPH	.W	20$-TDBOX_FORMPH	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"Formate le disque "	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,40	.B	ODBLABEL,11	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	" FORMATE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBMEV	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Formate"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_FORMAT:	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_FORMAT	.W	F1,F2,F3,0		DOKF1-TKEY_FORMAT	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_FORMAT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_FORMAT	.W	0	.END