	.TITLE	DEF_COLOR.ASC;	--------------------------------------;		(C) 1991 - Daniel Roux;	--------------------------------------;	Source du programme DEF_COLOR.CODE	.PROC	M680002	.RADIX	10.	.HEXDEFREV	=	1		; rvisionDEFVERS	=	2		; version;	Date		Amliorations; --------------------------------------------------------------------------------------------------; 1.2	01.07.91	couleurs pour scroll-liste; 1.1	23.05.91	priorit plus leve (23 -> 11); 1.0	16.05.91	premire version	.REF	SMAKY	.REF	MODULES	.REF	TCOLOR	.REF	ICOLOR	.REF	COLORS;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;SMAKY300 = 7OINVOL = OINSTA+4		; volume du h-p dans 100_INFO;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.REV	DEFREV,DEFVERS;;?	.HEADER	OBXSOVER.L OVERLAY	; faire "HEADER DEF_COLOR.CODE 16/O" !!!	.CODE	800,11,B'100111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LBUDIS	=	20KEYDBOX	=	H'7E00		; "touche" pour dbox; Variables; ---------	.LOC	0OPLCOM:	.BLKB	4		; ^ligne de commandeOBUDIS:	.BLKB	LBUDIS		; buffer temporaireOMOUSE:	.BLKB	1		; mode souris initialOMACHINE:.BLKB	1		; type de la machine (SMAKY*)	.EVENOCHMENU:.BLKB	4		; canal des soft-keysLGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	CALL	OVERLAY	LIB	?CLOLIB	FOS	?STOPOVERLAY:	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE EXIT$	GESMEM	?CLEARMEM	; met TOUTES les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; OPLCOM <-- ^ligne de commande	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	NTREL	?GETMACHINE	RL.L	D4,#8	LOAD.B	(A6)+OMACHINE,D4	LOAD.L	A3,(A6)+OPLCOM	LOAD.B	D3,#'I	LIB	?IFSWITCH	; excut avec /i ?	JUMP',EQ INIT$		; oui => INIT$	CALL	DBOXMAIN	; appel dbox principale ...	JUMP',EQ END$	JUMP'	NOOVER$INIT$:;	...	JUMP'	END$NOOVER$:	LOAD.W	D7,#-1		; D7 <-- demande une excution normaleEND$:	PUSH.W	D7	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre les variables	POP.W	D7EXIT$:	RET;---------\\; DBOXMAIN >;=========/; Modifie quelques informations gnrales sur la machine.; in	-; out	D7.W	erreur; mod	D7.WDBOXMAIN:	PUSHM.L	D0..D6,A1..A5	LIB	?PUSHMENU	; sauve les soft-keys	LOAD.L	(A6)+OCHMENU,D5	LIB	?GMOUSE	LOAD.B	(A6)+OMOUSE,D3	LOAD.W	D3,#2	LIB	?MOUSE		; souris par le clavier	CALL	NORMMOUSE	; souris: enlve le sablier	CALL	SEARCHD0	; A1 <-- ^descripteur de $DIS_0	LOAD.L	A3,#R16"NMSYS$	LOAD.L	A5,#R16"TCOUL$	LOAD.L	D5,(A1)+ODFCPR	; D5 <-- id. CRET globale	LOAD.L	D4,#2^BICMPAL!2^BTCGLOB	ICOL_	MODCRET		; modifie la CRET ...	JUMP',NE EXIT$	LOAD.L	(A1)+ODFCPR,D5	LOAD.L	A3,(A6)+OPLCOMRLOOP$:	LOAD.B	D3,#'Z	LIB	?IFSWITCH	; "^12345678/Z" trouv ?	JUMP',EQ RFOUND$	; oui => RFOUND$	LIB	?SKPNAM	JUMP,EQ RLOOP$	JUMP'	OK$RFOUND$:	COMP.B	(A3+),#'^	JUMP',NE OK$	LOAD.L	A4,A3	CALL	GETHNUM		; D4 <-- adresse o mettre la rponse	LOAD.L	A4,D4	LOAD.B	(A4),#'R	; zone rponse <-- refait toutOK$:	CLR.W	D7		; D7 <-- okEXIT$:	PUSH.W	D7	LOAD.B	D3,(A6)+OMOUSE	LIB	?MOUSE		; remet le mode souris initial	LOAD.L	D5,(A6)+OCHMENU	LIB	?POPMENU	; restitue les soft-keys	CALL	NORMMOUSE	; souris: enlve le sablier	POP.W	D7	POPM.L	D0..D6,A1..A5	TEST.W	D7		; retour EQ/NE	RETNMSYS$:	.ASCIZ	"%M_%N"		; 300_6152 (par exemple)	.EVENTCOUL$:	.L	COLOR_PPCLEAR	.W	-1,-1,-1	.ASCIZE	"Gnral:    fond"	.L	COLOR_PPSET	.W	0,0,0	.B	1	.ASCIZE	"Gnral:    dessin"	.L	COLOR_PPHILI	.W	-1,-1,0	.B	1	.ASCIZE	"Gnral:    mises en vidence"	.L	COLOR_PPCMOUSE	.W	-1,-1,-1	.ASCIZE	"Gnral:    pourtour de la souris"	.L	COLOR_PPSMOUSE	.W	-1,0,0	.B	2	.ASCIZE	"Gnral:    intrieur de la souris"	.L	COLOR_MMCLEAR	.W	-1,-1,-1	.ASCIZE	"Menu:       fond"	.L	COLOR_MMSET	.W	0,0,0	.ASCIZE	"Menu:       contenu"	.L	COLOR_MMCADRE	.W	0,0,0	.ASCIZE	"Menu:       cadre"	.L	COLOR_MMSEP	.W	0,0,0	.B	2	.ASCIZE	"Menu:       sparations"	.L	COLOR_DBCLEAR	.W	-1,-1,-1	.ASCIZE	"Dialogue:   fond"	.L	COLOR_DBSET	.W	0,0,0	.ASCIZE	"Dialogue:   contenu"	.L	COLOR_DBCADRE	.W	0,0,0	.ASCIZE	"Dialogue:   cadre"	.L	COLOR_DBKHELP	.W	0,0,0	.ASCIZE	"Dialogue:   raccourcis clavier"	.L	COLOR_DBTITLE	.W	0,0,0	.ASCIZE	"Dialogue:   titre en haut"	.L	COLOR_DBTRAME	.W	0,0,0	.ASCIZE	"Dialogue:   trame de fond"	.L	COLOR_DBSEL	.W	-1,0,0	.ASCIZE	"Dialogue:   boutons slectionns"	.L	COLOR_DBERROR	.W	0,0,0	.ASCIZE	"Dialogue:   erreurs"	.L	COLOR_DBICOCADRE	.W	0,0,0	.ASCIZE	"Dialogue:   cadre des icnes"	.L	COLOR_DBICODESS	.W	-1,-1,-1	.B	2	.ASCIZE	"Dialogue:   dessin des icnes"	.L	COLOR_SCCLEAR	.W	-1,-1,-1	.ASCIZE	"Ascenseur:  fond"	.L	COLOR_SCSET	.W	0,0,0	.ASCIZE	"Ascenseur:  cadre et contenu"	.L	COLOR_SCOBJ	.W	0,0,0	.ASCIZE	"Ascenseur:  flches"	.L	COLOR_SCPOS	.W	-1,-1,-1	.ASCIZE	"Ascenseur:  fond de la cabine"	.L	COLOR_SCSCALE	.W	0,0,0	.B	2	.ASCIZE	"Ascenseur:  chelles"	.L	COLOR_SLCLEAR	.W	-1,-1,-1	.ASCIZE	"Liste:      fond"	.L	COLOR_SLSET	.W	0,0,0	.ASCIZE	"Liste:      cadre"	.L	COLOR_SLTEXT	.W	0,0,0	.ASCIZE	"Liste:      texte contenu"	.L	COLOR_SLHILI	.W	-1,-1,0	.B	2	.ASCIZE	"Liste:      case mise en vidence"	.L	COLOR_RUCLEAR	.W	-1,-1,-1	.ASCIZE	"Rgle:      fond"	.L	COLOR_RUSET	.W	0,0,0	.ASCIZE	"Rgle:      contenu"	.L	COLOR_RULINE	.W	0,0,0	.ASCIZE	"Rgle:      graduations"	.L	COLOR_RUCAR	.W	0,0,0	.ASCIZE	"Rgle:      caractres"	.L	COLOR_RUMARK	.W	0,0,0	.B	2	.ASCIZE	"Rgle:      marques"	.L	COLOR_STEXEC	.W	-1,0,0	.B	1	.ASCIZE	"START:      slection pour excuter";;?	.L	COLOR_STSLEEP;;?	.W	-1,-1,-1;;?	.B	1;;?	.ASCIZE	"START:      si endormi (horloge)"	.L	COLOR_STCOL1	.W	0,0,0	.ASCIZE	"START:      couleur 1 (noir)"	.L	COLOR_STCOL2	.W	0,0,0	.ASCIZE	"START:      couleur 2"	.L	COLOR_STCOL3	.W	0,0,0	.ASCIZE	"START:      couleur 3"	.L	COLOR_STCOL4	.W	0,0,0	.ASCIZE	"START:      couleur 4"	.L	COLOR_STCOL5	.W	0,0,0	.ASCIZE	"START:      couleur 5"	.L	COLOR_STCOL6	.W	0,0,0	.ASCIZE	"START:      couleur 6"	.L	COLOR_STCOL7	.W	0,0,0	.ASCIZE	"START:      couleur 7"	.L	COLOR_STCOL8	.W	0,0,0	.ASCIZE	"START:      couleur 8"	.L	0;---------\\; SEARCHD0 >;---------/; Cherche le descripteur de $DIS_0.; in	-; out	A1.L	^descripteur $DIS_0;	D7.W	erreur; mod	D7.W, A1.LSEARCHD0:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,#R16"NPDIS$	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre $DIS_0	JUMP',NE EXIT$	LOAD.W	D3,#TYPDIS	; D3 <-- type spcial pour $DIS_0 !	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP',NE CLOSE$	LOAD.L	A1,(A4)		; A1 <-- ^descripteur de $DIS_0CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme $DIS_0	POP.W	D7EXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RETNPDIS$:	.ASCIZ	"$DIS_0"	.EVEN;--------\\; GETHNUM >;========/; Lit un nombre hexadcimal.; in	A4.L	^nombre hexa; out	D4.L	nombre hexa; mod	D4.L, D7.WGETHNUM:	PUSH.W	D3	CLR.L	D4LOOP$:	LOAD.B	D3,(A4)	SUB.B	D3,#'0	JUMP',LO EXIT$	COMP.B	D3,#9	JUMP',LS PUT$	SUB.B	D3,#'A-'9-1	JUMP',LO EXIT$	COMP.B	D3,#15	JUMP',HI EXIT$PUT$:	SL.L	D4,#4	OR.B	D4,D3		; D4 <-- nouveau digit	INC.L	A4	JUMP	LOOP$EXIT$:	POP.W	D3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RET	.END	START