	.SBTTL	STARTSYS; Gestion du fichier "xxx_SYSTEM.BIN" pour le bootstrap rapide; ------------------------------------------------------------;----------\\; CRESYSTEM >;==========/; Cre le fichier "xxx_SYSTEM.BIN" sur l'unit destination.; in	A2.L	^nom fichier destination; out	D7.W	erreur; mod	D7.WCRESYSTEM:	PUSHM.L	D3,D4,D6,A1,A3,A4	CLR.W	(A6)+OCSYS	; pas de canal	CLR.W	(A6)+ONSYS	CLR.W	D7		; D7 <-- ok	COMP.W	(A6)+ODDDTY,#TYPSYSC ; fichier SYSTEM.CODE ?	JUMP,NE 90$		; non => 90$	COMP.W	(A6)+ODDDOP,#3	; duplique ?	JUMP,NE 90$		; non => 90$	LOAD.L	A1,A2		; A1 <-- ^nom destination	CALL	NAMSYSTEM	; A3 <-- ^nom "REP:xxx_SYSTEM.BIN"	PUSH.L	A3	CALL	DDDAFIMB	; affiche <CR> puis qq espaces	LIB	?AFTIM	.ASCIZ	"Cre "	.EVEN	LIB	?AFTEXT		; affiche le nom du fichier  crer	LIB	?AFSPACE	POP.L	A3	FOS	?DELETE		; dtruit le fichier systme	COMP.W	D7,#ERATTD	JUMP,EQ 90$	LOAD.L	D3,#DEFATT-2^BATTL-2^BATTC	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier systme	JUMP,NE 90$	LOAD.W	D3,#2^BOPRD!2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier systme	JUMP,NE 90$	LOAD.W	(A6)+OCSYS,D6	; OCSYS <-- canal	CLR.L	D3	LOAD.L	D4,#256	FOS	?SPOSPLUS	; gnre une en-tte bidon90$:	CALL	DDDERROR	; affiche v. l'erreur	POPM.L	D3,D4,D6,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; MHDSYSTEM >;==========/; Dans le cas d'un transfert fichier normal --> "xxx_SYSTEM.BIN",; met  jour l'en-tte.; in	A4.L	^en-tte binaire; out	-; mod	D7.WMHDSYSTEM:	PUSHM.L	D4,A3,A4	LOAD.L	A3,#(A6)+OBUARGS ; A3 <-- ^arguments fichier source	LOAD.L	D4,(A3)+OFLATT	OR.L	D4,(A6)+ODDDAP	; D4 <-- ajoute qq attributs	NOT.L	D4	OR.L	D4,(A6)+ODDDAM	; D4 <-- enlve qq attributs	NOT.L	D4	LOAD.L	(A4)+OBXIDE+OBOOTATT,D4	LOAD.B	(A4)+OBXIDE+OBOOTDATE+0,(A3)+OFLCD+0	LOAD.B	(A4)+OBXIDE+OBOOTDATE+1,(A3)+OFLCD+1	LOAD.B	(A4)+OBXIDE+OBOOTDATE+2,(A3)+OFLCD+2	LOAD.B	(A4)+OBXIDE+OBOOTHEURE+0,(A3)+OFLCH+0	LOAD.B	(A4)+OBXIDE+OBOOTHEURE+1,(A3)+OFLCH+1	LOAD.B	(A4)+OBXIDE+OBOOTHEURE+2,(A3)+OFLCH+2	LOAD.L	D4,(A3)+OFLLG	; D4 <-- lg du binaire avec l'en-tte	ADD.L	D4,#4-1	AND.B	D4,#B'11111100	; D4 <-- arrondi au multiple de 4 suprieur	LOAD.L	(A4)+OBXIDE+OBOOTLGFILE,D4;	LOAD.L	A3,#(A3)+OFLNAM	LOAD.L	A4,#(A4)+OBXIDE+OBOOTNAME30$:	LOAD.B	(A4+),(A3+)	JUMP,NE 30$	POPM.L	D4,A3,A4	RET;----------\\; TERSYSTEM >;==========/; Termine la cration du fichier "xxx_SYSTEM.BIN", notament en mettant;  jour son en-tte.; in	-; out	D7.W	erreur; mod	D7.WTERSYSTEM:	PUSHM.L	D1..D4,D6,A2..A4	CLR.W	D7		; D7 <-- ok	LOAD.W	D6,(A6)+OCSYS	; D6 <-- canal	JUMP,EQ 90$	FOS	?GPOS	JUMP,NE 80$	LOAD.L	D2,D4	SUB.L	D2,#256		; D2 <-- longueur, sans l'en-tte	CLR.W	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP,NE 80$	LOAD.L	A4,#(A6)+OBUHEAD+256	LOAD.W	D4,#(256/4)-130$:	CLR.L	(-A4)		; OBUHEAD <-- met tout  zro	DECJ.W,NMO D4,30$	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	LOAD.W	D1,D4	LOAD.B	(A4)+OBXTYP,#BBXREL	LOAD.L	(A4)+OBXLG,D2	LOAD.W	(A4)+OBXREV,D1	LOAD.W	(A4)+OBXVAR,#-1	LOAD.W	(A4)+OBXIDE+OBOOTNBFILE,(A6)+ONSYS	LOAD.L	A2,#(A4)+OBXIDE	LOAD.L	A3,#R16"IDE$40$:	LOAD.B	(A2+),(A3+)	; OBXIDE <-- "Systme rvision "	JUMP,NE 40$	PUSH.L	A4	LOAD.L	A4,#(A2)-1	LOAD.W	D4,D1	SR.W	D4,#8	CALL	PUTANUM		; OBXIDE <-- numro de rvision	LOAD.B	(A4+),#'.	LOAD.W	D4,D1	AND.W	D4,#H'00FF	CALL	PUTANUM		; OBXIDE <-- numro de version	CLR.B	(A4)	POP.L	A4	LOAD.L	D4,#256	FOS	?WRBYTE		; crit l'en-tte dfinitive80$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier systme	POP.W	D7	CLR.W	(A6)+OCSYS	; plus de canal ( sec)90$:	POPM.L	D1..D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETIDE$:	.ASCIZ	"Systme rvision "	.EVEN;----------\\; OPESYSTEM >;==========/; Charge en mmoire le fichier "xxx_SYSTEM.BIN".; in	A1.L	^nom fichier source; out	D7.W	erreur; mod	D7.WOPESYSTEM:	PUSHM.L	D1,D3,D4,D6,A3,A4	CLR.W	D7		; D7 <-- ok	COMP.W	(A6)+ODDDTY,#TYPSYSC ; fichier SYSTEM.CODE ?	JUMP,NE 90$		; non => 90$	COMP.W	(A6)+ODDDOP,#3	; duplique ?	JUMP,NE 90$		; non => 90$	CALL	WAITMOUSE	; souris: met le sablier	CALL	CLOSYSTEM	; libre v. l'ancien systme	CALL	NAMSYSTEM	; A3 <-- ^nom "REP:xxx_SYSTEM.BIN"	PUSH.L	A3	LOAD.L	A4,#(A6)+ORSYS20$:	LOAD.B	(A4+),(A3+)	JUMP,NE 20$	LOAD.L	A3,#(A6)+ORSYS	; ORSYS <-- nom du dossier o est "xxx_SYSTEM.BIN"	CALL	SKIPREP	CLR.B	(A3)	POP.L	A3	LOAD.W	D3,#2^BOPRD	PUSH.L	D0	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier systme	POPM.L	D0	JUMP,NE 90$	CALL	WAITDBOX	; met la dbox d'attente	JUMP,NE 85$	LOAD.L	A3,#R16"TEXT$	CALL	AFFTDBOX	; affiche un petit texte	LOAD.W	D3,#-1	LOAD.L	D4,#-1	FOS	?SPOS		; va tout  la fin	LOAD.L	D1,D4		; D1 <-- longueur du fichier systme	CLR.W	D3	CLR.L	D4	FOS	?SPOS		; revient au dbut	JUMP,NE 85$	LOAD.L	D4,D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; rserve de la mmoire	JUMP',NE 85$	LOAD.L	(A6)+OPSYS,A4	FOS	?RDBYTE		; lit le fichier systme ...	JUMP',NE 80$	FOS	?CLOSE		; ferme le fichier systme	JUMP',EQ 90$80$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OPSYS	POP.W	D785$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier systme	POP.W	D790$:	CALL	NORMDBOX	; enlve la dbox d'attente	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RETTEXT$:	.ASCIZ	"       Attendez un instant ...      "	.EVEN;----------\\; CLOSYSTEM >;==========/; Libre le fichier "xxx_SYSTEM.BIN".; in	-; out	-; mod	-CLOSYSTEM:	PUSHM.L	D1,D7,A4	TEST.L	(A6)+OPSYS	; fichier systme dj lu ?	JUMP',EQ 90$		; non => 90$				; oui =>	LOAD.L	A4,(A6)+OPSYS	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OPSYS90$:	POPM.L	D1,D7,A4	RET;----------\\; SEASYSTEM >;==========/; Cherche un fichier dans "xxx_SYSTEM.BIN", presque comme s'il; tait normalement sur disque.; in	A3.L	^nom du fichier cherch; out	A4.L	^description (OFL...);	D7.W	erreur; mod	D7.W, A4.LSEASYSTEM:	PUSHM.L	D3,D4,A1..A3	LOAD.L	A2,A3		; A2 <-- ^nom complet	CLR.L	(A6)+ODSYS	LOAD.W	D7,#ERNEMEM	; D7 <-- mmoire pleine	TEST.L	(A6)+OPSYS	; fichier systme en mmoire ?	JUMP,EQ 90$		; non => 90$				; oui =>	LOAD.W	D7,#ERUNNI	; D7 <-- pas la bonne unit	LOAD.L	A4,A3	CALL	SKIPREP	LOAD.L	D3,A3	SUB.L	D3,A4		; D3 <-- nb de caractres	DEC.W	D3		; D3 <-- -1  cause NMO	LOAD.L	A3,#(A6)+ORSYS	; A3 <-- ^dossier o est "xxx_SYSTEM.BIN"10$:	COMP.B	(A3+),(A4+)	; fichier dans le mme dossier ?	JUMP,NE 90$		; non => 90$	DECJ.W,NMO D3,10$	TEST.B	(A3)	JUMP,NE 90$	LOAD.L	A3,A4		; A3 <-- ^nom aprs "unit:rep:"	LOAD.L	A4,(A6)+OPSYS	; A4 <-- ^fichier systme	LOAD.W	D4,(A4)+OBXIDE+OBOOTNBFILE ; D4 <-- nb de fichiers contenus	LOAD.L	A4,#(A4)+256	; A4 <-- ^aprs l'en-tte binaire20$:	PUSHM.L	A2,A4	LOAD.L	A4,#(A4)+OBXIDE+OBOOTNAME	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; nom trouv ?	POPM.L	A2,A4	JUMP,NE 60$		; non => 60$				; oui =>	LOAD.L	A1,#(A6)+OBUARGX+LFL	LOAD.W	D3,#(LFL/2)-130$:	CLR.W	(-A1)		; arguments <-- met tout  zro	DECJ.W,NMO D3,30$	LOAD.L	(A1)+OFLATT,(A4)+OBXIDE+OBOOTATT	LOAD.B	(A1)+OFLCD+0,(A4)+OBXIDE+OBOOTDATE+0	LOAD.B	(A1)+OFLCD+1,(A4)+OBXIDE+OBOOTDATE+1	LOAD.B	(A1)+OFLCD+2,(A4)+OBXIDE+OBOOTDATE+2	LOAD.B	(A1)+OFLCH+0,(A4)+OBXIDE+OBOOTHEURE+0	LOAD.B	(A1)+OFLCH+1,(A4)+OBXIDE+OBOOTHEURE+1	LOAD.B	(A1)+OFLCH+2,(A4)+OBXIDE+OBOOTHEURE+2	LOAD.L	(A6)+ODSYS,A4	; ODSYS <-- ^data du fichier	LOAD.L	A4,A1		; A4 <-- ^arguments	CLR.W	D7		; D7 <-- ok	JUMP'	90$60$:	ADD.L	A4,(A4)+OBXIDE+OBOOTLGFILE ; A4 <-- ^fichier suivant	DEC.W	D4		; encore un fichier ?	JUMP,NE 20$		; oui => 20$	LOAD.W	D7,#ERFDNE	; D7 <-- fichier n'existe pas90$:	COMP.W	D7,#ERFDNE	JUMP',NE 95$	LOAD.L	A3,A2		; A3 <-- ^nom complet	PUSH.W	D7	FOS	?NAMERROR	; donne le nom du fichier au FOS	POP.W	D795$:	POPM.L	D3,D4,A1..A3	TEST.W	D7		; retour EQ/NE	RETTERM$:	.B	0,-1	.EVEN;----------\\; NAMSYSTEM >;----------/; Construit le nom du fichier systme "xxx_SYSTEM.BIN".; in	A1.L	^nom fichier source; out	A3.L	^nom fichier systme; mod	D7.W, A3.LNAMSYSTEM:	PUSHM.L	D3,A4	LOAD.L	A3,#(A6)+OBUFIT	LOAD.L	A4,A110$:	LOAD.B	(A3+),(A4+)	; OBUFIT <-- nom "REP:SYSTEM.CODE"	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBUFIT	CALL	SKIPREP		; A3 <-- saute unit:rps:	LOAD.B	(A3+),(A6)+OMANAME+0	LOAD.B	(A3+),(A6)+OMANAME+1	LOAD.B	(A3+),(A6)+OMANAME+2	LOAD.L	A4,#R16"NAME$15$:	LOAD.B	(A3+),(A4+)	; OBUFIT <-- nom "REP:xxx_SYSTEM.BIN"	JUMP,NE 15$	LOAD.L	A3,#(A6)+OBUFIT	; A3 <-- ^nom	POPM.L	D3,A4	RETNAME$:	.ASCIZ	"_SYSTEM.BIN"	.EVEN	.END