	.SBTTL	STARTICO;-----------\\; SELECTRECT >;===========/; Slectionne tous les fichiers inclus dans un rectangle.; in	A5.L	^description unit;	D1.L	origine (y;x);	D2.L	arrive (y;x); out	-; mod	D7.WSELECTRECT:	PUSHM.L	D0..D4,A3	COMP.W	D1,D2	JUMP',LO 10$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D310$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,D2	JUMP',LO 12$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D312$:	SWAP.W	D1	SWAP.W	D2	LOAD.W	D3,(A5)+OUNASC+OSCPOSV	MUL.WU	D3,(A5)+OUNNBX	; D3 <-- rang initial selon ascenseur20$:	LOAD.W	D4,D3		; D4 <-- rang du fichier	PUSH.B	(A5)+OUNFAAF	TCLR.B	(A5)+OUNFAAF:#BFLAI-16	CALL	POSICONE	; D4 <-- position coin sup/gauche	POP.B	(A5)+OUNFAAF	TEST.W	D7	JUMP,NE EXIT$	LOAD.W	D0,#20	TEST.B	(A6)+ODEMIX	JUMP',F 30$	SR.W	D0,#130$:	ADD.W	D4,D0	COMP.W	D4,D2	JUMP',HS 62$	ADD.W	D4,(A5)+OUNLGX	SUB.W	D4,D0	SUB.W	D4,D0	COMP.W	D4,D1	JUMP',LO 62$	SWAP.W	D1	SWAP.W	D2	SWAP.W	D4	LOAD.W	D0,#5	TEST.B	(A6)+ODEMIY	JUMP',F 40$	SR.W	D0,#140$:	ADD.W	D4,D0	COMP.W	D4,D2	JUMP',HS 60$	ADD.W	D4,(A5)+OUNLGY	SUB.W	D4,D0	SUB.W	D4,D0	COMP.W	D4,D1	JUMP',LO 60$	LOAD.W	D4,D3	CALL	GETPFILE	; A3 <-- ^nom du fichier	JUMP',NE 60$	CALL	SELECTIF	; possible de slectionner ?	JUMP',NE 60$		; non => 60$	TSET.B	(A3)+OFLATT+0:#BATTSEL-24 ; slectionne l'icne	JUMP',BS 60$	LOAD.W	(A3)+OFLRAF,#-1	; signal icne  redessiner	INC.W	(A6)+OSELNB	LOAD.L	(A6)+OSELPU,A5	CALL	HILIICONE	; allume l'icne60$:	SWAP.W	D1	SWAP.W	D262$:	INC.W	D3		; D3 <-- fichier suivant	JUMP	20$EXIT$:	POPM.L	D0..D4,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; SELECTALL >;==========/; Slectionne tous les fichiers visibles.; in	A5.L	^description unit; out	-; mod	D7.WSELECTALL:	PUSHM.L	D4,A3	CLR.W	D410$:	CALL	GETPFILE	; A3 <-- ^nom du fichier	JUMP',NE 50$	CALL	SELECTIF	; possible de slectionner ?	JUMP',NE 50$		; non => 50$	TSET.B	(A3)+OFLATT+0:#BATTSEL-24 ; slectionne l'icne	LOAD.W	(A3)+OFLRAF,#-1	; signal icne  redessiner50$:	INC.W	D4		; D4 <-- rang suivant	COMP.W	D4,(A5)+OUNNBL	JUMP,LO 10$	LOAD.W	(A6)+OSELNB,D4	LOAD.L	(A6)+OSELPU,A5	POPM.L	D4,A3	RET;-------------\\; SELECTALLAFF >;=============/; Slectionne tous les fichiers visibles, et allume toutes; les icnes.; in	A5.L	^description unit; out	-; mod	D7.WSELECTALLAFF:	PUSHM.L	D4,A3	CLR.W	D410$:	CALL	GETPFILE	; A3 <-- ^nom du fichier	JUMP',NE 20$	CALL	SELECTIF	; possible de slectionner ?	JUMP',NE 20$		; non => 20$	TSET.B	(A3)+OFLATT+0:#BATTSEL-24 ; slectionne l'icne	JUMP',BS 20$	CALL	HILIICONE	; allume l'icne20$:	LOAD.W	(A3)+OFLRAF,#-1	; signal icne  redessiner	INC.W	D4		; D4 <-- rang suivant	COMP.W	D4,(A5)+OUNNBL	JUMP,LO 10$	LOAD.W	(A6)+OSELNB,D4	LOAD.L	(A6)+OSELPU,A5	POPM.L	D4,A3	RET;---------\\; SELECTIF >;---------/; Vrifie si un fichier peut tre slectionn.; in	A3.L	^nom du fichier; out	D7.W	ok/erreur; mod	D7.WSELECTIF:	PUSH.L	D3	LOAD.W	D7,#1	TEST.B	(A3)+OFLOPE	; fichier ouvert en exclusif ?	JUMP',NS EXIT$		; oui => EXIT$				; non =>	CALL	GETTYPE		; D3 <-- type de l'icne	LOAD.W	D7,#1	COMP.W	D3,#TYPSYSC	; fichier SYSTEM.CODE ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.W	D3,#TYPDOSSIER	; DOSSIER: ?	JUMP',EQ EXIT$		; oui => EXIT$	CLR.W	D7EXIT$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; SELECTTYPE >;===========/; Donne le type d'une slection multiple.; in	A5.L	^description unit; out	D3.W	type;	D7.W	erreur (si diffrents types); mod	D3.L, D7.WSELECTTYPE:	PUSHM.L	D2,D4,A3	LOAD.W	D2,#-1		; D2 <-- type inconnu	CLR.W	D410$:	CALL	GETPFILE	; A3 <-- ^nom du fichier	TEST.B	(A3)+OFLATT+0:#BATTSEL-24 ; icne slectionne ?	JUMP',BC 40$	CALL	GETTYPE		; D3 <-- type de l'icne	COMP.W	D2,#-1	JUMP',EQ 30$	LOAD.W	D7,#1		; D7 <-- diffrents types	COMP.W	D3,D2		; est-ce le mme type ?	JUMP',NE EXIT$		; non => EXIT$30$:	LOAD.W	D2,D3		; D2 <-- type40$:	INC.W	D4		; D4 <-- rang suivant	COMP.W	D4,(A5)+OUNNBL	JUMP,LO 10$	CLR.W	D7		; D7 <-- tous les types sont identiquesEXIT$:	POPM.L	D2,D4,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; SELECTUNDO >;===========/; Annule compltement une slection multiple.; in	A5.L	^description unit; out	-; mod	D7.WSELECTUNDO:	PUSHM.L	D4,A3	CLR.W	(A6)+OSELNB	CLR.W	D410$:	CALL	GETPFILE	; A3 <-- ^nom du fichier	TCLR.B	(A3)+OFLATT+0:#BATTSEL-24 ; d-slectionne l'icne	JUMP',BC 20$	LOAD.W	(A3)+OFLRAF,#-1	; signal icne  redessiner20$:	INC.W	D4		; D4 <-- rang suivant	COMP.W	D4,(A5)+OUNNBL	JUMP,LO 10$	POPM.L	D4,A3	RET;--------------\\; SELECTUNDOAFF >;==============/; Annule compltement une slection multiple, et teint; les icnes allumes.; in	A5.L	^description unit; out	-; mod	D7.WSELECTUNDOAFF:	PUSHM.L	D4,A3	CLR.W	(A6)+OSELNB	CLR.W	D410$:	CALL	GETPFILE	; A3 <-- ^nom du fichier	TCLR.B	(A3)+OFLATT+0:#BATTSEL-24 ; d-slectionne l'icne	JUMP',BC 20$	CALL	HILIICONE	; teint l'icne20$:	INC.W	D4		; D4 <-- rang suivant	COMP.W	D4,(A5)+OUNNBL	JUMP,LO 10$	POPM.L	D4,A3	RET;-------------\\; DETASCENSEUR >;=============/; Dtecte et agit si la souris est dans un ascenseur.; in	D4.L	position de la souris (y;x); out	D7.W	EQ => on tait dans un ascenseur;		NE => souris ailleurs; mod	D7.WDETASCENSEUR:	PUSHM.L	D1..D4,A4,A5	LOAD.L	D2,D4		; D2 <-- position de la souris	LOAD.L	A4,#(A6)+OUNIT	; A4 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-110$:	TEST.B	(A4)+OUNUSE	; unit utilise ?	JUMP,F	80$		; non => 80$				; oui =>	LOAD.L	A5,#(A4)+OUNASC	; A5 <-- ^variables de l'ascenseur	TEST.W	(A5)+OSCHTV	; cabine dessine ?	JUMP',EQ 50$		; non => 50$	LOAD.L	D4,D2		; D4 <-- position de la souris	LOAD.W	(A5)+OSCINC,(A4)+OUNNBY	LOAD.W	D1,(A5)+OSCPOSV	; D1 <-- position actuelle	SCROLL_	MOVE		; dans l'ascenseur ?	JUMP',NE 50$		; non => 50$				; oui =>	COMP.W	D1,(A5)+OSCPOSV	; ascenseur dplac ?	JUMP',EQ 40$		; non => 40$	LOAD.L	A5,A4		; A5 <-- ^description unit	CALL	WDOICONE	; redessine toutes les icnes40$:	CLR.W	D7		; D7 <-- ok, dans l'ascenseur	JUMP'	EXIT$50$:	LOAD.L	A4,#(A4)+LUN	; A4 <-- ^unit suivante	DECJ.W,NMO D5,10$80$:	LOAD.W	D7,#ERDIOUT	; D7 <-- pas dans un ascenseurEXIT$:	POPM.L	D1..D4,A4,A5	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DESASCENSEUR >;=============/; Dessine l'ascenseur  droite d'une fentre, avec; ou sans cabine selon la longueur de la liste.; in	A5.L	^description unit; out	-; mod	D7.WDESASCENSEUR:	PUSHM.L	D3,D4,A4,A5	LOAD.L	A4,A5	LOAD.L	A5,#(A4)+OUNASC	; A5 <-- ^variables de l'ascenseur	LOAD.W	D4,(A4)+OUNPOS+0	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A4)+OUNPOS+2	ADD.W	D4,(A4)+OUNDIM+2	SUB.W	D4,#LGSCROLL-1	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A4)+OUNDIM+0	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	SCROLL_	DRAW		; dessine la cage de l'ascenseur	CLR.B	(A5)+OSCCAB	; pas de cabine;;?	CLR.W	(A5)+OSCPOSV;;?	CLR.W	(A5)+OSCHTV	POPM.L	D3,D4,A4,A5	RET;-------------\\; MAJASCENSEUR >;=============/; Met  jour l'ascenseur  droite d'une fentre, avec; ou sans cabine selon la longueur de la liste.; in	A5.L	^description unit; out	-; mod	D7.WMAJASCENSEUR:	PUSHM.L	D3,D4,A4,A5	LOAD.L	A4,A5	LOAD.L	A5,#(A4)+OUNASC	; A5 <-- ^variables de l'ascenseur	CLR.W	(A5)+OSCHTV	CLR.L	D4	LOAD.W	D4,(A4)+OUNNBL	DIV.WU	D4,(A4)+OUNNBX	; D4 <-- nb de lignes ncessaires	SWAP.W	D4	TEST.W	D4	JUMP',EQ 20$	ADD.L	D4,#H'10000	; D4 <-- arrondi  l'unit suprieure20$:	SWAP.W	D4	SUB.W	D4,(A4)+OUNNBY	JUMP,LE 50$	INC.W	D4; Dessine un ascenseur avec une cabine.	TEST.B	(A5)+OSCCAB	; cabine dessine ?	JUMP',F	30$		; non => 30$				; oui =>	COMP.W	D4,(A5)+OSCHTV	; mme hauteur ?	JUMP,EQ EXIT$		; oui => EXIT$30$:	LOAD.W	(A5)+OSCHTV,D4	DEC.W	D4		; D4 <-- position maximale	COMP.W	D4,(A5)+OSCPOSV	JUMP',HS 35$	LOAD.W	(A5)+OSCPOSV,D435$:	SCROLL_	UPDATE		; dessine la cabine de l'ascenseur	SET.B	(A5)+OSCCAB	; cabine dessine	JUMP'	EXIT$; Dessine un ascenseur sans cabine.50$:	CLR.W	(A5)+OSCPOSV	CLR.W	(A5)+OSCHTV	TEST.B	(A5)+OSCCAB	; cabine dessine ?	JUMP',F	60$		; non => 60$	SCROLL_	DRAW		; oui => efface la cabine60$:	CLR.B	(A5)+OSCCAB	; pas de cabineEXIT$:	POPM.L	D3,D4,A4,A5	RET;---------\\; INIICONE >;=========/; Initialise les variables en fonction de l'chelle.; in	-; out	-; mod	D7.WINIICONE:	PUSH.L	D4	LOAD.W	(A6)+OGCIIX,#GCIIX	LOAD.W	(A6)+OGCIIMX,#GCIIMX	TEST.B	(A6)+ODEMIX	JUMP',F 20$	LOAD.W	(A6)+OGCIIX,#GCIIX/2	LOAD.W	(A6)+OGCIIMX,#GCIIMX/220$:	LOAD.W	(A6)+OGCIIY,#GCIIY	LOAD.W	(A6)+OGCIIB,#GCIIB	LOAD.W	(A6)+OGCIIMY,#GCIIMY	LOAD.W	(A6)+OGCIIMT,#GCIIMT	TEST.B	(A6)+ODEMIY	JUMP',F 30$	LOAD.W	(A6)+OGCIIY,#GCIIY/2	LOAD.W	(A6)+OGCIIB,#GCIIB/2	LOAD.W	(A6)+OGCIIMY,#GCIIMY/230$:	CALL	USETEXTE	; utilise le gencar du texte	LOAD.W	(A6)+OTDFCX,(A0)+ODFCX	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	LOAD.W	(A6)+OTDFCY,D4	LOAD.W	(A6)+OTDFC1Y,(A0)+ODFC1Y	LOAD.W	(A6)+OTDFC2Y,(A0)+ODFC2Y	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0 ; remet le gencar standard	.EVEN	POP.L	D4	RET;----------\\; ALLREFAIT >;==========/; Retrie et redessine toute une fentre.; in	A5.L	^description unit; out	-; mod	D7.WALLREFAIT:	CALL	SORTALL		; trie tout	CLR.W	(A5)+OUNASC+OSCPOSV	CALL	MAJASCENSEUR	; dessine l'ascenseur  droite;	CALL	ALLICONE	; dessine toutes les icnes;	RET;---------\\; ALLICONE >;=========/; Redessine toute une fentre.; in	A5.L	^description unit; out	-; mod	D7.WALLICONE:	CALL	WDOREFAIT	; signal que tout est  redessiner	CALL	WDOICONE	; redessine les icnes	CALL	WDONAME		; redessine le nom	CALL	WDONBF		; redessine le nombre de fichiers	RET;----------\\; WDOREFAIT >;==========/; Signal que toutes les icnes d'une fentre doivent tre; redessines.; in	A5.L	^description unit; out	-; mod	D7.WWDOREFAIT:	PUSHM.L	D2..D4,A4; Efface l'intrieur de la grande fentre.	LOAD.W	D2,#CLRDOT	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A5)+OUNPOS	INC.W	D3	SWAP.W	D3	ADD.W	D3,(A6)+ODCASY	ADD.W	D3,#2	SWAP.W	D3	LOAD.L	D4,(A5)+OUNDIM	SUB.W	D4,#LGSCROLL-1+2	SWAP.W	D4	SUB.W	D4,(A6)+ODCASY	SUB.W	D4,#3	SWAP.W	D4	LIB	?DRTRAME; Marque toutes les icnes de la liste.	TEST.L	(A5)+OUNPLI	; liste existe ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A4,(A5)+OUNPLI	LOAD.L	A4,#(A4)+OFLRAF	LOAD.W	D4,(A5)+OUNNBM	JUMP',EQ EXIT$	DEC.W	D4		; D4 <-- -1  cause NMO	LOAD.W	D3,#-120$:	LOAD.W	(A4),D3		; OFLRAF <-- #-1	LOAD.L	A4,#(A4)+LFL	; A4 <-- ^suivant	DECJ.W,NMO D4,20$EXIT$:	POPM.L	D2..D4,A4	RET;---------\\; WDOICONE >;=========/; Redessine toutes les icnes d'une fentre.; in	A5.L	^description unit; out	-; mod	D7.WWDOICONE:	PUSHM.L	D0..D4,A3; Dessine toutes les icnes.	TEST.L	(A5)+OUNPLI	; liste existe ?	JUMP,EQ EXIT$		; non => EXIT$	CLR.W	D4	LOAD.W	D1,(A5)+OUNASC+OSCPOSV	MUL.WU	D1,(A5)+OUNNBX	; D1 <-- rang initial selon ascenseur	JUMP',EQ 30$20$:	CALL	GETPFILE	; A3 <-- ^nom du fichier	JUMP',NE 22$	LOAD.W	(A3)+OFLRAF,#-122$:	INC.W	D4		; D4 <-- rang suivant	DEC.W	D1	JUMP,NE 20$30$:	CALL	_BUCAR		; met le mode rapide	LOAD.W	D1,(A5)+OUNNBX	MUL.WU	D1,(A5)+OUNNBY	CLR.W	D040$:	CALL	GETPFILE	; A3 <-- ^nom du fichier	JUMP',NE 43$	COMP.W	D0,(A3)+OFLRAF	; icne dj dessine ?	JUMP',EQ 45$		; oui => 45$	LOAD.W	(A3)+OFLRAF,D0	; non =>	CALL	EFFICONE	; efface l'emplacement	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CALL	DESICONE	; affiche l'icne	JUMP'	45$43$:	CALL	EFFICONE	; efface l'emplacement45$:	INC.W	D4		; D4 <-- rang suivant	INC.W	D0	DEC.W	D1	JUMP,NE	40$	CALL	_NOBUCAR	; remet le mode normal50$:	CALL	GETPFILE	; A3 <-- ^nom du fichier	JUMP',NE EXIT$	LOAD.W	(A3)+OFLRAF,#-1	INC.W	D4		; D4 <-- rang suivant	JUMP	50$EXIT$:	POPM.L	D0..D4,A3	RET;---------\\; WDONAME  >;=========/; Redessine le nom d'une fentre.; in	A5.L	^description unit; out	-; mod	D7.WWDONAME:	PUSHM.L	D2..D4,A3,A4; Dessine les noms d'units et/ou rpertoires.	LOAD.L	A4,#(A5)+OUNNAM	; A4 <-- ^nom de l'unit	COMP.W	(A4),#H'100*'$	JUMP',NE 25$	LOAD.L	A4,#R16"00$	; A4 <-- ^nom "Units physiques"25$:	LOAD.W	D2,#2	CALL	POSCADRE	ADD.W	D3,(A0)+ODFCX	SWAP.W	D3	INC.W	D3	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LIB	?SETCURS	AND.L	D4,#H'FFFF	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb max de caractres	DEC.W	D4	LOAD.L	A3,A4	LOAD.W	D3,#-130$:	INC.W	D3		; D3 <-- nb caractre dans le nom	TEST.B	(A3+)	JUMP,NE 30$	COMP.W	D3,D4		; dpasse  gauche ?	JUMP',LS 35$		; non => 35$	LOAD.W	D3,D4		; oui => tronque35$:	LOAD.L	A3,A4	LIB	?STRING		; affiche le nom	SUB.W	D4,D3	JUMP',EQ EXIT$	LOAD.B	D3,#MSPACE	LIB	?AFCAR		; efface la fin du nom	LOAD.B	D3,D4	LIB	?AFCAREXIT$:	POPM.L	D2..D4,A3,A4	RET00$:	.ASCIZ	"Units physiques"	.EVEN;---------\\; WDONBF   >;=========/; Redessine le nombre de fichier d'une fentre.; in	A5.L	^description unit; out	-; mod	D7.WWDONBF:	PUSHM.L	D2..D4; Dessine le nombre de fichiers.	LOAD.W	D2,#3	CALL	POSCADRE	ADD.W	D3,(A0)+ODFCX	SWAP.W	D3	INC.W	D3	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A5)+OUNNBL	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le nombre visible (0..n)	TEST.B	(A5)+OUNPHY	; fentre des units physiques ?	JUMP',T	42$		; oui => 42$	LOAD.B	D3,#'/	LIB	?AFCAR	CLR.L	D4	LOAD.W	D4,(A5)+OUNNBT	LOAD.W	D3,#4;	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le nombre total (0..n)	LIB	?AFTIM	.ASCIZ	" fichier"	.EVEN	JUMP'	45$42$:	LIB	?AFTIM	.ASCIZ	" unit"	.EVEN45$:	COMP.W	D4,#1	JUMP',LS 48$	LOAD.B	D3,#'s	LIB	?AFCAR		; affiche le pluriel48$:	LIB	?AFTIM	.ASCIZ	"    "	.EVEN	POPM.L	D2..D4	RET;---------\\; DEDICONE >;=========/; Dtecte si la souris est dans une unit ou un dossier pour la; destination lors d'un dplace/duplique.; in	D4.L	position de la souris (y;x);	A5.L	^description unit source;	D5.W	rang source (0..n); out	-; mod	D7.WDEDICONE:	PUSHM.L	D3..D6,A3..A5	LOAD.L	A4,A5		; A4/D5 <-- ^description/rang source	CALL	DEXICONE	; A5/D4 <-- ^description/rang o est la souris	COMP.L	A5,A4	JUMP',NE 20$	COMP.W	D4,D5		; est-on dans l'icne source ?	JUMP',EQ 30$		; oui => 30$20$:	COMP.L	A5,#0	JUMP',EQ 30$	CALL	GETPFILE	; A3 <-- ^fichier	JUMP',NE 30$	CALL	GETTYPE		; D3 <-- type	COMP.W	D3,#TYPUNIT	JUMP',EQ 40$	COMP.W	D3,#TYPDIR	JUMP',EQ 40$30$:	LOAD.W	D4,#-1		; D4 <-- rang -140$:	COMP.L	A5,(A6)+ODDDPU	; mme unit ?	JUMP',NE 60$	COMP.W	D4,(A6)+ODDDRA	; mme rang ?	JUMP',EQ EXIT$		; oui => EXIT$60$:	PUSHM.L	D4,A5	LOAD.L	A5,(A6)+ODDDPU	LOAD.W	D4,(A6)+ODDDRA	CALL	HILICCADIC	; teint l'ancienne l'icne	POPM.L	D4,A5	CALL	HILISCADIC	; allume la nouvelle l'icne	LOAD.L	(A6)+ODDDPU,A5	LOAD.W	(A6)+ODDDRA,D4EXIT$:	POPM.L	D3..D6,A3..A5	RET;---------\\; DEYICONE >;=========/; Dtecte dans quelle fentre d'unit est la souris.; in	D4.L	position de la souris (y:x); out	D7.W	ok;	 A5.L	 ^description unit;	D7.W	erreur; mod	D7.W, A5.LDEYICONE:	PUSHM.L	D3..D5	SWAP.W	D4		; D4 <-- position de la souris en Y	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-1	CLR.W	D7		; D7 <-- trouv20$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP',F	80$		; non => 80$				; oui =>	LOAD.W	D3,(A5)+OUNPOS+0	COMP.W	D4,D3		; trop haut ?	JUMP',LO 50$	ADD.W	D3,(A5)+OUNDIM+0	COMP.W	D4,D3		; trop bas ?	JUMP',LO EXIT$50$:	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,20$80$:	LOAD.W	D7,#ERDIOUT	; D7 <-- pas dans une icneEXIT$:	POPM.L	D3..D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DEXICONE >;=========/; Dtecte dans quelle icne est la souris, ; dans n'importe quelle fentre d'unit.; in	D4.L	position de la souris (y:x); out	D7.W	ok;	 A5.L	 ^description unit;	 D4.W	 rang (0..n);	D7.W	erreur;	 A5.L	 nil;	 D4.W	 -1; mod	D4.L ,D7.W, A5.LDEXICONE:	PUSHM.L	D2,D5	LOAD.L	D2,D4		; D2 <-- position de la souris	LOAD.L	A5,#(A6)+OUNIT	; A5 <-- ^premire unit	LOAD.W	D5,#MAXUNIT-120$:	TEST.B	(A5)+OUNUSE	; unit utilise ?	JUMP',F	80$		; non => 80$				; oui =>	LOAD.L	D4,D2		; D4 <-- position de la souris	CALL	DETICONE	; souris dans une icne ?	JUMP',EQ EXIT$		; oui => EXIT$				; non =>	LOAD.L	A5,#(A5)+LUN	; A5 <-- ^unit suivante	DECJ.W,NMO D5,20$80$:	LOAD.L	A5,#0		; A5 <-- nil	LOAD.W	D4,#-1		; D4 <-- rang -1	LOAD.W	D7,#ERDIOUT	; D7 <-- pas dans une icneEXIT$:	POPM.L	D2,D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DETICONE >;=========/; Dtecte dans quelle icne est la souris.; in	A5.L	^description unit;	D4.L	position de la souris (y:x); out	D7.W	ok;	 D4.W	 rang (0..n);	D7.W	erreur;	 D4.W	 -1; mod	D4.L ,D7.WDETICONE:	PUSHM.L	D0..D3,D5,D6,A3	LOAD.L	D0,D4		; D0 <-- position de la souris	CLR.L	D3	LOAD.W	D3,D4		; D3 <-- position en X	CLR.W	D4	SWAP.W	D4		; D4 <-- position en Y	SUB.W	D3,(A5)+OUNPOS+2	JUMP,LO 80$	DIV.WU	D3,(A5)+OUNLGX	COMP.W	D3,(A5)+OUNNBX	JUMP,HS 80$	SUB.W	D4,(A5)+OUNPOS+0	JUMP,LO 80$	SUB.W	D4,(A6)+ODCASY	JUMP,LO 75$	DIV.WU	D4,(A5)+OUNLGY	COMP.W	D4,(A5)+OUNNBY	JUMP,HS 80$	MUL.WU	D4,(A5)+OUNNBX	ADD.W	D4,D3		; D4 <-- rang (0..n)	LOAD.W	D3,(A5)+OUNASC+OSCPOSV	MUL.WU	D3,(A5)+OUNNBX	; D3 <-- rang initial selon ascenseur	ADD.W	D4,D3; Regarde encore si la souris est bien dans le "chapeau".	LOAD.W	D1,D4	CALL	RCTSICONE	; D3/D4 <-- r1 et D5/D6 <-- r2	JUMP,NE 75$	LOAD.L	D2,D0		; D2 <-- position de la souris	SUB.W	D2,D3		; trop  gauche ?	JUMP',LO 40$	COMP.W	D2,D4		; trop  droite ?	JUMP',HS 40$	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SUB.W	D2,D3		; trop en haut ?	JUMP',LO 40$	COMP.W	D2,D4		; trop en bas ?	JUMP',LO 70$40$:	TEST.L	D5	JUMP',EQ 75$	LOAD.L	D2,D0		; D2 <-- position de la souris	SUB.W	D2,D5		; trop  gauche ?	JUMP',LO 75$	COMP.W	D2,D6		; trop  droite ?	JUMP',HS 75$	SWAP.W	D2	SWAP.W	D5	SWAP.W	D6	SUB.W	D2,D5		; trop en haut ?	JUMP',LO 75$	COMP.W	D2,D6		; trop en bas ?	JUMP',HS 75$70$:	LOAD.W	D4,D1		; D4 <-- rang de l'icne	CALL	GETPFILE	; A3 <-- ^nom du fichier	JUMP',NE 75$	TEST.B	(A3)+OFLOPE	; fichier ouvert en exclusif ?	JUMP',NS 75$		; oui => 75$				; non =>	CLR.W	D7		; D7 <-- souris dans une icne	JUMP'	EXIT$75$:	LOAD.W	D4,#-1	CLR.W	D7		; D7 <-- souris dans cette fentre	JUMP'	EXIT$80$:	LOAD.W	D4,#-1	LOAD.W	D7,#ERDIOUT	; D7 <-- pas dans une icneEXIT$:	POPM.L	D0..D3,D5,D6,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DESICONE >;=========/; Dessine une icne.; in	A5.L	^description unit;	D4.W	rang (0..n);	D2.W	mode de dessin; out	-; mod	D7.WDESICONE:	PUSHM.L	D1..D4,A2,A3	LOAD.W	D1,D4		; D1 <-- rang	CALL	GETPFILE	; A3 <-- ^nom du fichier	JUMP,NE EXIT$	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; oui => NOCOUL$	LIB	?COLORPUSH	LOAD.L	D3,(A3)+OFLATT	; D3 <-- attributs	SWAP.W	D3	SR.W	D3,#4	AND.L	D3,#B'111	; D3 <-- couleur (0..7)	ADD.W	D3,#COLOR_STCOL1	LIB	?COLORSRNOCOUL$:	TEST.B	(A5)+OUNFAAF:#BFLAI-16	JUMP',BC NAME$	LOAD.L	A2,A3	CALL	DESFORME	; dessine la forme autour	CALL	DESICOINT	; dessine l'icne dans la forme	LOAD.L	A3,A2	CALL	DESTEXTE	; dessine le nom sous l'icne	JUMP'	IFSEL$NAME$:	CALL	DESFILE		; dessine juste le nomIFSEL$:	TEST.B	(A3)+OFLATT+0:#BATTSEL-24 ; icne slectionne ?	JUMP',BC END$		; non => END$				; oui =>	LOAD.W	D4,D1		; D4 <-- rang	CALL	HILIICONE	; inverse l'icneEND$:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ EXIT$		; oui => EXIT$	LIB	?COLORPOPEXIT$:	POPM.L	D1..D4,A2,A3	RET;---------\\; DESFORME >;---------/; Dessine la forme autour d'une icne.; in	A5.L	^description unit;	A3.L	^nom du fichier;	D4.L	coordonne coin sup/gauche;	D2.W	mode de dessin; out	A3.L	^nom pour icne dans la forme; mod	D7.W, A3.LDESFORME:	PUSHM.L	D2..D4,A4	CALL	GETTYPE		; D3 <-- type	COMP.W	D3,#TYPUNIT	JUMP,EQ 40$	TEST.B	(A3)+OFLOPE	; fichier ouvert en exclusif ?	JUMP',NC 05$		; non => 05$	OR.W	D2,#TTTDOT	; D2 <-- mode avec traitill05$:	COMP.W	D3,#TYPDIR	JUMP',EQ 30$	COMP.W	D3,#TYPDOSSIER	JUMP',EQ 30$	COMP.W	D3,#TYPCODE	JUMP',EQ 20$	COMP.W	D3,#TYPSYSC	JUMP',EQ 20$10$:				; autre =>	LOAD.B	D3,(A3)	JUMP',EQ 15$	COMP.B	D3,#'!	JUMP',EQ 15$	INC.L	A3		; A3 <-- ^extension	COMP.B	D3,#'.	JUMP,NE 10$15$:	LOAD.L	A4,#R16"TMAUTRE	JUMP'	60$20$:				; fichier .CODE =>	LOAD.L	A4,#R16"TMCODE	TEST.L	(A3)+OFLLG	; longueur nulle ?	JUMP',NE 60$		; non => 60$				; oui => accs	OR.W	D2,#TTTDOT	; D2 <-- mode avec traitill	JUMP'	60$30$:				; fichier rpertoire =>	TEST.B	(A3+)	JUMP,NE 30$	DEC.L	A3		; A3 <-- ^nil	LOAD.L	A4,#R16"TMDIR	JUMP'	60$40$:				; fichier unit =>	LOAD.L	A3,#(A3)+OFLTYP	; A3 <-- ^type ($FLO, $MEM, etc.)	LOAD.L	A4,#R16"TMUNIT;	JUMP'	60$60$:	TEST.L	D2:#BTTTDOT	; mode avec traitill ?	JUMP',BC 62$		; non => 62$	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; <m>: traitill	.B	1		; <e>: chelle	.B	0	.EVEN62$:	EX.L	D3,D4		; D3 <-- coordonne initiale	CALL	DESEMOTIF	; dessine la forme	COMP.W	D4,#TYPDIR	JUMP',EQ 65$	COMP.W	D4,#TYPDOSSIER	JUMP,NE EXIT$65$:				; dossier =>	PUSH.L	D3	LOAD.L	D3,#H'11441144	COMP.W	D4,#TYPDOSSIER	JUMP',NE 70$	NOT.L	D370$:	COMP.W	D2,#CLRDOT	JUMP',NE 71$	NOT.L	D371$:	LOAD.L	D4,D3	LIB	?DRMDEF	POP.L	D3	TEST.B	(A6)+ODEMIX	JUMP',T	73$	SUB.W	D3,#GCIIMX	LOAD.W	D4,#GCIIMX+GCIIX+GCIIMX	JUMP'	74$73$:	SUB.W	D3,#GCIIMX/2	LOAD.W	D4,#(GCIIMX+GCIIX+GCIIMX)/274$:	SWAP.W	D3	SWAP.W	D4	TEST.B	(A6)+ODEMIY	JUMP',T 75$	ADD.W	D3,#4	LOAD.W	D4,#GCIIMY+GCIIY+GCIIMY-6	JUMP'	76$75$:	ADD.W	D3,#4/2	LOAD.W	D4,#(GCIIMY+GCIIY+GCIIMY-6)/276$:	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME	; grise dans le dossierEXIT$:	POPM.L	D2..D4,A4	RET;--------\\; GETTYPE >;--------/; Donne le type d'un nom de fichier.; Le nom doit tre seul (pas de unit:rep:rep:) !; in	A3.L	^nom du fichier; out	D3.W	type; mod	D3.L, D7.WGETTYPE:	PUSHM.L	D2,A2..A4	LOAD.L	A4,A3	CLR.W	D2		; D2 <-- nb de ":"10$:	COMP.B	(A4),#':	JUMP',NE 11$	INC.W	D2		; D2 <-- un ":" de plus11$:	TEST.B	(A4+)	JUMP',EQ 12$	COMP.B	(A4)-1,#'/	JUMP,NE 10$12$:	COMP.B	(A4)-2,#':	; unit ou rpertoire ?	JUMP,NE 20$		; non => 20$				; oui =>	COMP.W	D2,#1		; plus d'un ":" (#MM1:REP:) ?	JUMP',HI 13$		; oui => 13$	LOAD.W	D3,#TYPUNIT	COMP.B	(A3),#'#	JUMP,EQ EXIT$	COMP.B	(A3),#'@	JUMP,EQ EXIT$13$:	LOAD.W	D3,#TYPDIR	SUB.L	A4,#214$:	COMP.L	A4,A3	JUMP',EQ 15$	COMP.B	(-A4),#':	JUMP,NE 14$	INC.L	A415$:	LOAD.L	A3,#R16"NDVIDE	LOAD.L	A2,#R16"00$	LIB	?CPSTRING	; est-ce DOSSIER: ?	JUMP,NS EXIT$		; non => EXIT$	LOAD.W	D3,#TYPDOSSIER	JUMP	EXIT$20$:	LOAD.W	D3,#TYPAUTRE	LOAD.L	A4,A330$:	LOAD.B	D2,(A3+)	JUMP,EQ EXIT$	COMP.B	D2,#'.	JUMP,NE 30$	LOAD.L	A2,#R16"TXCODE+1	LOAD.W	D3,#TYPCODE	CALL	COMPEXT		; fichier .CODE ?	JUMP,EQ 50$	LOAD.L	A2,#R16"TXDRIV+1	LOAD.W	D3,#TYPDRIV	CALL	COMPEXT		; fichier .DRIV ?	JUMP,EQ EXIT$	LOAD.L	A2,#R16"TXIMA+1	LOAD.W	D3,#TYPIMAGE	CALL	COMPEXT		; fichier .IMAGE ?	JUMP,EQ EXIT$	LOAD.L	A2,#R16"TXCOL+1	LOAD.W	D3,#TYPCOLOR	CALL	COMPEXT		; fichier .COLOR ?	JUMP,EQ EXIT$	LOAD.L	A2,#R16"TXPLAN+1	LOAD.W	D3,#TYPPLAN	CALL	COMPEXT		; fichier .PLAN ?	JUMP,EQ EXIT$	LOAD.L	A2,#R16"TXGENC+1	LOAD.W	D3,#TYPGENCAR	CALL	COMPEXT		; fichier .GENC ?	JUMP,EQ EXIT$	LOAD.L	A2,#R16"TXDI+1	LOAD.W	D3,#TYPDI	CALL	COMPEXT		; fichier .DI ?	JUMP,EQ EXIT$	LOAD.W	D3,#TYPAUTRE	JUMP'	EXIT$50$:	LOAD.L	A3,A4	CALL	SKIPREP		; A3 <-- saute unit:rep:rep:	LOAD.L	A4,#R16"NPSYS	LOAD.L	A2,#R16"00$	LIB	?CPSTRING	; fichier SYSTEM.CODE ?	JUMP',NS EXIT$		; non => EXIT$				; oui =>	LOAD.W	D3,#TYPSYSCEXIT$:	POPM.L	D2,A2..A4	RET00$:	.B	0,CR,'/,-1	.EVEN;--------\\; COMPEXT >;--------/; Compare deux extensions.; in	A3.L	^extension;	A2.L	^extension; out	D7.W	EQ/NE; mod	D7.WCOMPEXT:	PUSHM.L	A2,A3	LOAD.W	D7,#1		; D7 <-- retour NE10$:	TEST.B	(A2)	JUMP',EQ 20$	COMP.B	(A2+),(A3+)	JUMP,EQ 10$	JUMP'	EXIT$20$:	TEST.B	(A3)	JUMP',NE EXIT$80$:	CLR.W	D7		; D7 <-- retour EQEXIT$:	POPM.L	A2,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DESMOTIF >;---------/; Dessine un motif constitu de lignes droites.; in	D3.L	coordonne initiale;	D2.W	mode de dessin;	A4.L	^table (dy;dx); out	-; mod	D7.WDESMOTIF:	PUSHM.L	D3,D4,A4	SWAP.W	D3	ADD.W	D3,(A4+)	; saute au dpart	SWAP.W	D3	ADD.W	D3,(A4+)10$:	LOAD.L	D4,(A4+)	JUMP',EQ EXIT$	LIB	?DRSEG	JUMP	10$EXIT$:	POPM.L	D3,D4,A4	RET;----------\\; DESEMOTIF >;----------/; Dessine un motif  l'chelle constitu de lignes droites.; in	D3.L	coordonne initiale;	D2.W	mode de dessin;	A4.L	^table (dy;dx); out	-; mod	D7.WDESEMOTIF:	PUSHM.L	D3,D4,A4	CALL	01$		; D4 <-- dy;dx	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; saute au dpart	SWAP.W	D4	SWAP.W	D3	ADD.W	D3,D410$:	TEST.L	(A4)	JUMP',EQ EXIT$	CALL	01$		; D4 <-- dy;dx	LIB	?DRSEG	JUMP	10$EXIT$:	POPM.L	D3,D4,A4	RET01$:	LOAD.L	D4,(A4)+0	; D4 <-- dy;dx si chelle 1:1	TEST.B	(A6)+ODEMIX	JUMP',F 02$	LOAD.W	D4,(A4)+6	; D4 <-- dx si chelle 1:102$:	TEST.B	(A6)+ODEMIY	JUMP',F 03$	SWAP.W	D4	LOAD.W	D4,(A4)+4	; D4 <-- dy si chelle 1:2	SWAP.W	D403$:	ADD.L	A4,#8	RET;----------\\; DESICOINT >;----------/; Dessine l'icne dans la forme.; in	A5.L	^description unit;	A3.L	^nom du fichier (pour dterminer l'icne);	A2.L	^nom du fichier (OFL...);	D4.L	coordonne coin sup/gauche;	D2.W	mode de dessin; out	-; mod	D7.WDESICOINT:	PUSHM.L	D2,A4	TEST.B	(A2)+OFLOPE	; fichier ouvert en exclusif ?	JUMP',NC FULL$		; non => FULL$	TSET.L	D2:#15		; D2 <-- dessine grisFULL$:	TEST.B	(A3)	JUMP',EQ EXIT$	COMP.B	(A3),#'$	; unit physique ?	JUMP',NE NORM$		; non => NORM$	CALL	DESICOMM	; dessine une icne spciale selon (M0) ou (M1)	JUMP',EQ EXIT$NORM$:	LOAD.L	A4,(A6)+OPUSER	; A4 <-- ^fichier START_USER.INFO	CALL	SKIPINFO	; A4 <-- ^aprs les pseudo-instructions	CALL	SRCFINFO	; A4 <- ^ligne dans START_USER.INFO	JUMP',EQ INFO$	LOAD.L	A4,(A6)+OPINFO	; A4 <-- ^fichier START.INFO	CALL	SKIPINFO	; A4 <-- ^aprs les pseudo-instructions	CALL	SRCFINFO	; A4 <- ^ligne dans START.INFO	JUMP',NE EXIT$INFO$:	CALL	DESICONUM	; dessine l'icneEXIT$:	POPM.L	D2,A4	RET;---------\\; DESICOMM >;---------/; Dessine une icne spciale pour une mmoire de masse; assigne aux touches (M0) ou (M1).; in	A2.L	^nom du fichier (OFL...);	D4.L	coordonne coin sup/gauche;	D2.W	mode de dessin; out	D7.W	erreur; mod	D7.WDESICOMM:	PUSHM.L	D0..D4,A2..A4	LOAD.L	D1,D4		; D1 <-- coordonne	LOAD.L	A3,A2		; A3 <-- ^nom logique	CLR.W	D3		; D3 <-- global	FOS	?VASSIGN	; A4 <-- ^nom physique	JUMP,NE EXIT$	LOAD.L	A2,A4	CLR.W	D4LOOP$:	FOS	?MMVASSIGN	; A3/D3 <-- ^nom/type	JUMP,NE NEXT$	COMP.W	D3,#4	JUMP,HS NEXT$	CALL	COMPEXT		; nom trouv ?	JUMP,NE NEXT$		; non => NEXT$	LOAD.W	D0,D3		; D0 <-- type	TEST.B	(A6)+ODEMIX	JUMP',T ICON$	LOAD.L	A4,#R16"ICON0$	DEC.W	D4	JUMP',NS KEY$	LOAD.L	A4,#R16"ICON1$	DEC.W	D4	JUMP',NS KEY$	LOAD.L	A4,#R16"ICON2$	DEC.W	D4	JUMP',NS KEY$	LOAD.L	A4,#R16"ICON3$KEY$:	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	LOAD.L	D4,D1	ADD.W	D4,#GCIIX	SWAP.W	D4	TEST.B	(A6)+ODEMIY	JUMP',T POS$	ADD.W	D4,#GCIIY-12POS$:	LOAD.L	(A3)+1,D4	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,D2	LOAD.W	D3,#10	LIB	?STRING		; affiche la touche associeICON$:	LOAD.L	A3,#R16"TABLE$	LOAD.B	D3,(A3)+(D0.W)	; D3 <-- ICOFLOPPY?	LOAD.B	D0,#GCIIF	; D0 <-- fonte par dfaut	LOAD.L	D4,D1	CALL	DESICONUM2	; dessine l'icne spciale	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$NEXT$:	INC.W	D4	COMP.W	D4,#6	JUMP,LO LOOP$	LOAD.W	D7,#1		; D7 <-- pas trouvEXIT$:	POPM.L	D0..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.B	ICOFLOPPY5	.B	ICOFLOPPY3	.B	ICOFLOPPYH	.B	ICOFLOPPYXICON0$:	.B	24,12	.B	B'00111111,B'11111100,B'00000000	.B	B'01000000,B'00000010,B'00000000	.B	B'01000000,B'00000011,B'00000000	.B	B'01010001,B'00110011,B'00000000	.B	B'01011011,B'01001011,B'00000000	.B	B'01010101,B'01001011,B'00000000	.B	B'01010001,B'01001011,B'00000000	.B	B'01010001,B'00110011,B'00000000	.B	B'01000000,B'00000011,B'00000000	.B	B'01000000,B'00000011,B'00000000	.B	B'00111111,B'11111111,B'00000000	.B	B'00011111,B'11111110,B'00000000ICON1$:	.B	24,12	.B	B'00111111,B'11111100,B'00000000	.B	B'01000000,B'00000010,B'00000000	.B	B'01000000,B'00000011,B'00000000	.B	B'01010001,B'00010011,B'00000000	.B	B'01011011,B'00110011,B'00000000	.B	B'01010101,B'00010011,B'00000000	.B	B'01010001,B'00010011,B'00000000	.B	B'01010001,B'00111011,B'00000000	.B	B'01000000,B'00000011,B'00000000	.B	B'01000000,B'00000011,B'00000000	.B	B'00111111,B'11111111,B'00000000	.B	B'00011111,B'11111110,B'00000000ICON2$:	.B	32,12	.L	B'00111111111000011111111111100000	.L	B'01000000000100100000000000010000	.L	B'01000010000110100000000000011000	.L	B'01000111000110101000100110011000	.L	B'01001111100110101101101001011000	.L	B'01000010000111101010101001011000	.L	B'01000010000111101000101001011000	.L	B'01000010000110101000100110011000	.L	B'01000010000110100000000000011000	.L	B'01000000000110100000000000011000	.L	B'00111111111110011111111111111000	.L	B'00011111111100001111111111110000ICON3$:	.B	32,12	.L	B'00111111111000011111111111100000	.L	B'01000000000100100000000000010000	.L	B'01000010000110100000000000011000	.L	B'01000111000110101000100010011000	.L	B'01001111100110101101100110011000	.L	B'01000010000111101010100010011000	.L	B'01000010000111101000100010011000	.L	B'01000010000110101000100111011000	.L	B'01000010000110100000000000011000	.L	B'01000000000110100000000000011000	.L	B'00111111111110011111111111111000	.L	B'00011111111100001111111111110000;----------\\; DESICONUM >;----------/; Dessine l'icne dans la forme.; in	A4.L	^icne (ex. "j45");	D4.L	coordonne coin sup/gauche;	D2.W	mode de dessin (si 2^15 -> gris); out	-; mod	D7.WDESICONUM:	PUSHM.L	D0,D1,D3,A4	LOAD.B	D0,#GCIIF	; D0 <-- fonte par dfaut	LOAD.B	D3,(A4)	CALL	_MINMAJ		; D3 <-- premier caractre du "nombre"	COMP.B	D3,#'A	JUMP',LO NUM$	COMP.B	D3,#'Z		; est-ce une lettre ?	JUMP',HI NUM$		; non => NUM$	LOAD.B	D0,D3		; D0 <-- fonte spciale	INC.L	A4		; A4 <-- saute la lettreNUM$:	CLR.W	D3		; D3 <-- code de l'icneNLOOP$:	CLR.W	D1	LOAD.B	D1,(A4+)	SUB.B	D1,#'0	JUMP',LO DRAW$	COMP.B	D1,#10	JUMP',HS DRAW$	MUL.WU	D3,#10		; D3 <-- pousse d'un digit	ADD.W	D3,D1		; D3 <-- ajoute nouveau digit	JUMP	NLOOP$DRAW$:	CALL	DESICONUM2	; dessine l'icne	POPM.L	D0,D1,D3,A4	RET;-----------\\; DESICONUM2 >;-----------/; Dessine l'icne dans la forme.; in	D0.B	fonte;	D3.B	icne;	D4.L	coordonne coin sup/gauche;	D2.W	mode de dessin (si 2^15 -> gris); out	-; mod	D7.WDESICONUM2:	PUSHM.L	D0..D4,A3	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3+),#NUL	LOAD.B	(A3+),#TYPOAX	; positionnement en X	LOAD.W	(A3+),D4	LOAD.B	(A3+),#NUL	LOAD.B	(A3+),#TYPOAY	; positionnement en Y	SWAP.W	D4	ADD.W	D4,(A6)+OGCIIY	SUB.W	D4,(A6)+OGCIIB	LOAD.W	(A3+),D4	PUSH.L	D2	LOAD.L	D1,#GCIIS	; D1 <-- style	LOAD.B	D2,#GCIIT	; D2 <-- taille	CALL	USEGENCAR	; (A3+) <-- pour utiliser le gencar	POPM.L	D2	JUMP,NE EXIT$	COMP.B	D2,#SETDOT	JUMP',NE 30$	TEST.L	D2:#15		; affiche en gris ?	JUMP',BC 30$		; non => 30$	LOAD.B	(A3+),#AFGREY	; oui => affiche en gris	JUMP'	35$30$:	LOAD.B	(A3+),#MODCAR	OR.B	D2,#PENDOT	LOAD.B	(A3+),D235$:	LOAD.B	(A3+),#AFTOUT	LOAD.B	(A3+),D3	LOAD.B	(A3+),#AFNORM	LOAD.B	(A3+),#MODCAR	LOAD.B	(A3+),#SETDOT	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCTXF	LOAD.B	(A3+),#GCTXS	LOAD.B	(A3+),#GCTXT	LOAD.B	(A3+),#AFFULL	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS	SUB.L	D3,A3	LIB	?STRING		; affiche l'icneEXIT$:	POPM.L	D0..D4,A3	RET;---------\\; DESTEXTE >;---------/; Dessine le nom du fichier sous l'icne.; in	A5.L	^description unit;	A3.L	^nom du fichier;	D4.L	coordonne coin sup/gauche;	D2.W	mode de dessin; out	-; mod	D7.WDESTEXTE:	PUSHM.L	D1..D4,A3,A4	CALL	USETEXTE	; utilise le gencar du texte	JUMP,NE EXIT$	LOAD.L	D3,D4		; D3 <-- coin sup/gauche	LOAD.L	A4,#(A6)+OBUDIS	COMP.W	D2,#SETDOT	JUMP',NE 05$	TEST.B	(A3)+OFLOPE	; fichier ouvert en exclusif ?	JUMP',NC 05$		; non => 05$	LOAD.B	(A4+),#AFGREY	; oui => affiche en gris	JUMP'	07$05$:	LOAD.B	(A4+),#MODCAR	OR.B	D2,#PENDOT	LOAD.B	(A4+),D207$:	LOAD.W	D4,#-110$:	INC.W	D4		; D4 <-- nb caractres	LOAD.B	(A4+),(A3+)	JUMP,NE 10$	COMP.W	D4,#LGNAME-1	JUMP',HS 12$	TEST.B	(A3)		; encore un nom aprs le <0> ?	JUMP',EQ 12$		; non => 12$	LOAD.B	(A4)-1,#'/	JUMP	10$12$:	COMP.B	(A4)-2,#':	JUMP',NE 15$	DEC.W	D4		; D4 <-- ne compte pas le ":"15$:	LOAD.B	(A4+),#MODCAR	LOAD.B	(A4+),#SETDOT	LOAD.B	(A4+),#AFFULL	LOAD.W	D1,(A6)+OGCIIX	SR.W	D1,#1	ADD.W	D3,D1	MUL.WU	D4,(A6)+OTDFCX	; D4 <-- largeur totale	SR.W	D4,#1	SUB.W	D3,D4	TEST.B	(A6)+ODEMIX	JUMP',T 30$	INC.W	D330$:	SWAP.W	D3	ADD.W	D3,(A6)+OGCIIY	ADD.W	D3,(A6)+OGCIIMY	ADD.W	D3,(A6)+OGCIIMT	ADD.W	D3,(A6)+OTDFC1Y	TEST.B	(A6)+ODEMIY	JUMP',F 35$	INC.W	D335$:	SWAP.W	D3	LIB	?SETCURS	LOAD.L	D3,A4	LOAD.L	A3,#(A6)+OBUDIS	SUB.L	D3,A3	LIB	?STRING		; affiche le texte	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0 ; remet le gencar initial	.EVENEXIT$:	POPM.L	D1..D4,A3,A4	RET;---------\\; DESFILE  >;---------/; Dessine juste le nom du fichier sans icne.; in	A5.L	^description unit;	A3.L	^nom du fichier;	D4.L	coordonne coin sup/gauche;	D2.W	mode de dessin; out	-; mod	D7.WDESFILE:	PUSHM.L	D1..D4,A2..A4	CALL	USETEXTE	; utilise le gencar du texte	JUMP,NE EXIT$	LOAD.L	A2,A3		; A2 <-- ^nom	LOAD.L	D3,D4		; D3 <-- coin sup/gauche	LOAD.L	A4,A3	LOAD.W	D4,#-110$:	INC.W	D4		; D4 <-- nb caractres	TEST.B	(A4+)	JUMP',EQ 15$	COMP.B	(A4)-1,#':	JUMP,NE 10$	INC.W	D415$:	ADD.W	D3,#2	SWAP.W	D3	LOAD.W	D1,(A5)+OUNLGY	SUB.W	D1,(A6)+OTDFCY	SR.W	D1,#1	ADD.W	D3,D1	ADD.W	D3,(A6)+OTDFC1Y	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A4,A3		; A4 <-- ^texte	LOAD.L	A3,#(A6)+OBUDIS	COMP.W	D2,#SETDOT	JUMP',NE 17$	TEST.B	(A2)+OFLOPE	; fichier ouvert en exclusif ?	JUMP',NC 17$		; non => 17$	LOAD.B	(A3+),#AFGREY	; oui => affiche en gris	JUMP'	18$17$:	LOAD.B	(A3+),#MODCAR	OR.B	D2,#PENDOT	LOAD.B	(A3+),D218$:	LOAD.W	D1,D420$:	LOAD.B	(A3+),(A4+)	; OBUDIS <-- texte	DEC.W	D1	JUMP,NE 20$	LOAD.W	D1,#15	SUB.W	D1,D4	JUMP',LE 24$22$:	LOAD.B	(A3+),#SPACE	; OBUDIS <-- espaces	DEC.W	D1	JUMP,NE 22$24$:	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS	SUB.L	D3,A3	LIB	?STRING		; affiche le nom	TEST.B	(A5)+OUNFAAF:#BFLAT-16	JUMP,BC 80$	LOAD.L	D4,(A2)+OFLLG	; D4 <-- taille	LOAD.W	D3,#8		; D3 <-- nb max de digits	LOAD.W	D2,#2^BAFDSP	; D2 <-- mode ' tous les 3 digits	LIB	?AFDEC	LIB	?AFSPACE	LOAD.L	A3,#(A2)+OFLCD	CALL	CHECKDATE	; date/heure de cration correcte ?	JUMP',EQ 40$		; oui => 40$				; non =>	LIB	?AFTIM	.B	SPACE,AFINV	.ASCII	" Date ou heure de cration incorrecte !       "	;	"01/01/80 12:00  01/01/80 12:00  01/01/80 12:00"	.B	AFDIR,0	.EVEN	JUMP	60$40$:	LOAD.L	A4,#(A2)+OFLCD	LOAD.B	D3,#'/	CALL	DESDATE	LOAD.L	A4,#(A2)+OFLCH	LOAD.B	D3,#':	CALL	DESHEURE	LIB	?AFSPACE	LOAD.L	A4,#(A2)+OFLWD	LOAD.B	D3,#'/	CALL	DESDATE	LOAD.L	A4,#(A2)+OFLWH	LOAD.B	D3,#':	CALL	DESHEURE	LIB	?AFSPACE	LOAD.L	A4,#(A2)+OFLRD	LOAD.B	D3,#'/	CALL	DESDATE	LOAD.L	A4,#(A2)+OFLRH	LOAD.B	D3,#':	CALL	DESHEURE60$:	LOAD.L	D3,(A2)+OFLATT	; D3 <-- attributs	TEST.L	D3:#BATTQ	; fichier verrouill ?	JUMP',BC 80$		; non => 80$				; oui =>	LIB	?AFTIM	.ASCIZ	" V"		; affiche le "verrou"	.EVEN80$:	LIB	?AFTIM	.B	MODCAR,SETDOT,AFFULL,0	.EVEN	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0 ; remet le gencar initial	.EVENEXIT$:	POPM.L	D1..D4,A2..A4	RET;--------\\; DESDATE >;--------/; Affiche une date ou une heure.; in	A4.L	^trois bytes BCD;	D3.B	caractre de sparation; out	-; mod	D4.L, D7.WDESDATE:	LIB	?AFSPACE	LOAD.B	D4,(A4)+0	LIB	?AFX2		; jour	LIB	?AFCAR	LOAD.B	D4,(A4)+1	LIB	?AFX2		; mois	LIB	?AFCAR	LOAD.B	D4,(A4)+2	LIB	?AFX2		; anne	RET;---------\\; DESHEURE >;---------/; Affiche une date ou une heure.; in	A4.L	^trois bytes BCD;	D3.B	caractre de sparation; out	-; mod	D4.L, D7.WDESHEURE:	LIB	?AFSPACE	LOAD.B	D4,(A4)+0	LIB	?AFX2		; heure	LIB	?AFCAR	LOAD.B	D4,(A4)+1	LIB	?AFX2		; minute	RET;---------\\; USETEXTE >;=========/; Utilise le gencar pour le texte.; in	-; out	D7.W	erreur; mod	D7.WUSETEXTE:	PUSHM.L	D0..D3,A3	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	D0,#GCTXF	LOAD.L	D1,#GCTXS	LOAD.B	D2,#GCTXT	CALL	USEGENCAR	; charge le gencar si ncessaire	JUMP',NE EXIT$	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS	SUB.L	D3,A3		; D3 <-- longueur	LIB	?STRING		; utilise le gencar	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; USEGENCAR >;==========/; Utilise un gencar quelconque, selon l'chelle.; Si ce n'est pas dj fait, le gencar est charg.; Le buffer reoit ce qu'il faut pour utiliser le gencar.; in	D0.B	fonte;	D1.L	style;	D2.B	taille;	A3.L	^dans buffer; out	A3.L	^plus loin;	D7.W	erreur; mod	D7.W, A3.LUSEGENCAR:	PUSHM.L	D0..D4,A4	TSET.L	D0:#7	TSET.L	D1:#8+BGCDEMIX	TSET.L	D1:#8+BGCDEMIY	TEST.B	(A6)+ODEMIX	JUMP',T 20$	TCLR.L	D1:#8+BGCDEMIX	TEST.B	(A6)+ODEMIY	JUMP',T 20$	TCLR.L	D0:#7	TCLR.L	D1:#8+BGCDEMIY; Cherche si ce gencar est dj charg.20$:	LOAD.L	A4,#(A6)+OTAGCI	LOAD.W	D4,#MAXGCI-130$:	TEST.B	(A4)+OGCIF	; emplacement libre ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D0,(A4)+OGCIF	; fonte trouve ?	JUMP',NE 40$		; non => 40$	COMP.L	D1,(A4)+OGCIS	; style trouv ?	JUMP',NE 40$		; non => 40$	COMP.B	D2,(A4)+OGCIT	; taille trouve ?	JUMP',EQ 70$		; oui => 70$40$:	LOAD.L	A4,#(A4)+LGCI	; A4 <-- gencar suivant	DECJ.W,NMO D4,30$; Cherche un emplacement libre pour charger le gencar.	LOAD.L	A4,#(A6)+OTAGCI	LOAD.W	D4,#MAXGCI-150$:	TEST.B	(A4)+OGCIF	; emplacement libre ?	JUMP',EQ 60$		; oui => 60$	LOAD.L	A4,#(A4)+LGCI	; A4 <-- gencar suivant	DECJ.W,NMO D4,50$	LOAD.W	D7,#1		; D7 <-- crac, y'a plus d'place !	JUMP	EXIT$; Charge effectivement le nouveau gencar.60$:	LOAD.B	(A4)+OGCIF,D0	; mm. la fonte	LOAD.L	(A4)+OGCIS,D1	; mm. le style	LOAD.B	(A4)+OGCIT,D2	; mm. la taille	LOAD.B	D4,(A6)+OBUCAR	; D4 <-- mode bufferis ou pas	CALL	_NOBUCAR	; enlve le mode bufferis	PUSH.L	A3	LOAD.L	A3,#(A6)+OBUDIS+LBUDIS-20	LOAD.B	(A3+),#NEWGC	LOAD.B	(A3+),#LOADGC	LOAD.B	(A3+),D0	; buffer <-- fonte	RL.L	D1,#8	LOAD.B	(A3+),D1	RL.L	D1,#8	LOAD.B	(A3+),D1	RL.L	D1,#8	LOAD.B	(A3+),D1	RL.L	D1,#8	LOAD.B	(A3+),D1	; buffer <-- style	LOAD.B	(A3+),D2	; buffer <-- taille	LOAD.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+LBUDIS-20	SUB.L	D3,A3		; D3 <-- longueur	LIB	?STRING		; charge le gencar	POP.L	A3	LOAD.W	(A4)+OGCIER,D7	; mm. ok/erreur	TEST.B	D4	JUMP',EQ 70$	CALL	_BUCAR		; remet le mode bufferis; Met en (A3) les caractres pour permettre d'utiliser le gencar.70$:	LOAD.W	D7,(A4)+OGCIER	; D7 <-- ok/erreur prcdente	JUMP',NE EXIT$		; erreur => EXIT$				; ok =>	LOAD.B	(A3+),#NEWGC	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),D0	; buffer <-- fonte	RL.L	D1,#8	LOAD.B	(A3+),D1	RL.L	D1,#8	LOAD.B	(A3+),D1	RL.L	D1,#8	LOAD.B	(A3+),D1	RL.L	D1,#8	LOAD.B	(A3+),D1	; buffer <-- style	LOAD.B	(A3+),D2	; buffer <-- tailleEXIT$:	POPM.L	D0..D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EFFICONE >;=========/; Efface une icne.; in	A5.L	^description unit;	D4.W	rang (0..n); out	-; mod	D7.WEFFICONE:	PUSHM.L	D2..D4	COMP.W	D4,#-1	JUMP',EQ EXIT$	PUSH.W	D4	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	POP.W	D4	TSET.L	D4:#15		; D4 <-- efface mme si icne inexistante	LOAD.W	D2,#CLRDOT	CALL	SURFICONE	; efface toute l'icneEXIT$:	POPM.L	D2..D4	RET;----------\\; HILIICONE >;==========/; Met en vidence une icne.; in	A5.L	^description unit;	D4.W	rang (0..n); out	-; mod	D7.WHILIICONE:	PUSHM.L	D2..D4	COMP.W	D4,#-1	JUMP',EQ EXIT$	PUSH.W	D4	LOAD.L	D4,#-1	LOAD.L	D3,D4	LIB	?DRMDEF	POP.W	D4	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_PPHILI	LIB	?COLORSR	LOAD.W	D2,#INVDOT	CALL	SURFICONE	; inverse le texte	LIB	?COLORPOPEXIT$:	POPM.L	D2..D4	RET;----------\\; SURFICONE >;----------/; Inverse ou efface toute la surface d'une icne.; in	A5.L	^description unit;	D4.W	rang (0..n);	D2.W	mode de dessin; out	-; mod	D7.WSURFICONE:	PUSHM.L	D3..D6	CALL	RCTSICONE	; D3/D4 <-- r1 et D5/D6 <-- r2	JUMP',NE EXIT$	COMP.B	D2,#CLRDOT	JUMP',EQ CLR$NORM$:	LIB	?DRTRAME	; surface de l'icne (r1)	LOAD.L	D3,D5	LOAD.L	D4,D6	JUMP',EQ EXIT$	LIB	?DRTRAME	; surface du texte (r2)	JUMP'	EXIT$CLR$:	TEST.L	D6	JUMP,EQ NORM$	LOAD.W	D3,D5	LOAD.W	D4,D6	SWAP.W	D4	SWAP.W	D6	ADD.W	D4,D6	SWAP.W	D4	LIB	?DRTRAME	; efface la surface totale !EXIT$:	POPM.L	D3..D6	RET;-----------\\; HILISCADIC >;===========/; Allume/teint le cadre d'une icne.; in	A5.L	^description unit;	D4.W	rang (0..n); out	-; mod	D7.WHILISCADIC:HILICCADIC:	PUSHM.L	D0..D4	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_PPHILI	LIB	?COLORSR	COMP.L	A5,#0	JUMP,EQ EXIT$	COMP.W	D4,#-1	JUMP,EQ 50$	LOAD.W	D1,D4	LOAD.L	D4,#-1	LOAD.L	D3,D4	LIB	?DRMDEF		; dfinit une trame noire	LOAD.W	D4,D1	LOAD.W	D2,#INVDOT	TCLR.L	D2:#16		; D2 <-- pas de marge autour	CALL	SURFCADIC	; inverse le cadre	JUMP	EXIT$50$:	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF		; dfinit une trame noire	LOAD.L	D0,(A5)+OUNPOS	; D0 <-- position fentre	LOAD.L	D1,(A5)+OUNDIM	; D1 <-- dimensions fentre	ADD.W	D0,#EPCADIC	SUB.W	D1,#LGSCROLL+2+EPCADIC	SWAP.W	D0	ADD.W	D0,(A6)+ODCASY	ADD.W	D0,#1+EPCADIC	SWAP.W	D0	SWAP.W	D1	SUB.W	D1,(A6)+ODCASY	SUB.W	D1,#4+EPCADIC	SWAP.W	D1	LOAD.W	D2,#INVDOT	LOAD.L	D3,D0	SUB.W	D3,#EPCADIC	SWAP.W	D3	SUB.W	D3,#EPCADIC	SWAP.W	D3	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D1	ADD.W	D4,#EPCADIC*2	LIB	?DRTRAME	; surface (1)	LOAD.L	D3,D0	ADD.W	D3,D1	LOAD.L	D4,D1	LOAD.W	D4,#EPCADIC	LIB	?DRTRAME	; surface (2)	LOAD.L	D3,D0	SWAP.W	D3	SWAP.W	D1	ADD.W	D3,D1	SWAP.W	D1	SWAP.W	D3	SUB.W	D3,#EPCADIC	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D1	ADD.W	D4,#EPCADIC*2	LIB	?DRTRAME	; surface (3)	LOAD.L	D3,D0	SUB.W	D3,#EPCADIC	LOAD.L	D4,D1	LOAD.W	D4,#EPCADIC	LIB	?DRTRAME	; surface (4)EXIT$:	LIB	?COLORPOP	POPM.L	D0..D4	RET;-----------\\; LOLISCADIC >;===========/; Allume le cadre d'une icne.; in	A5.L	^description unit;	D4.W	rang (0..n); out	-; mod	D7.WLOLISCADIC:	PUSHM.L	D1..D4	COMP.W	D4,#-1	JUMP',EQ EXIT$	LOAD.W	D1,D4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COUL$		; oui => COUL$	LOAD.L	D4,#H'AA55AA55	LOAD.L	D3,D4	LIB	?DRMDEF		; dfinit une trame grise	LOAD.W	D4,D1	LOAD.W	D2,#INVDOT	TSET.L	D2:#16		; D2 <-- petite marge autour	CALL	SURFCADIC	; inverse le cadre;	LOAD.W	D4,D1	LOAD.W	D2,#SETDOT	CALL	SURFICONE	; grise le contenu	JUMP'	EXIT$COUL$:	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_STEXEC	LIB	?COLORSR	LOAD.L	D4,#-1	LOAD.L	D3,D4	LIB	?DRMDEF		; dfinit une trame pleine	LOAD.W	D4,D1	LOAD.W	D2,#INVDOT	TSET.L	D2:#16		; D2 <-- petite marge autour	CALL	SURFCADIC	; inverse le cadre;	LOAD.W	D4,D1;	LOAD.W	D2,#INVDOT	CALL	SURFICONE	; inverse le contenu	LIB	?COLORPOPEXIT$:	POPM.L	D1..D4	RET;-----------\\; LOLICCADIC >;===========/; Eteint le cadre d'une icne.; in	A5.L	^description unit;	D4.W	rang (0..n); out	-; mod	D7.WLOLICCADIC:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE LOLISCADIC	; oui => LOLISCADIC	PUSHM.L	D1..D4	COMP.W	D4,#-1	JUMP,EQ EXIT$	LOAD.W	D1,D4	LOAD.L	D4,#H'AA55AA55	LOAD.L	D3,D4	LIB	?DRMDEF		; dfinit une trame grise	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_STEXEC	LIB	?COLORSR	LOAD.W	D4,D1	LOAD.W	D2,#INVDOT	TSET.L	D2:#16		; D2 <-- petite marge autour	CALL	SURFCADIC	; inverse le cadre;	LOAD.W	D4,D1;	LOAD.W	D2,#INVDOT	CALL	SURFICONE	; inverse le contenu	LIB	?COLORPOP;	LOAD.W	D4,D1	LOAD.W	D2,#SETDOT	CALL	DESICONE	; redessine le contenuEXIT$:	POPM.L	D1..D4	RET;----------\\; SURFCADIC >;----------/; Inverse ou efface tout le cadre d'une icne.;	                (1);	            |----|----|;	            |         |;	        (8)-|         |-(2);	        (7) |         | (3);	      |--|--|         |--|--|;	  (6)-|                     |-(4);	      |----------|----------|;	                (5); in	A5.L	^description unit;	D4.W	rang (0..n);	D2.W	mode de dessin;		:#16 = 1 --> petite marge autour; out	-; mod	D7.WSURFCADIC:	PUSHM.L	D0..D6	CALL	RCTSICONE	; D3/D4 <-- r1 et D5/D6 <-- r2	JUMP,NE EXIT$	LOAD.L	D0,D3	LOAD.L	D1,D4	TEST.L	D6	JUMP,EQ 50$; Corrige D0/D1 et D5/D6 pour laisser un petit filet blanc.	TEST.L	D2:#16		; petite marge autour ?	JUMP',BC 20$		; non => 20$				; oui =>	DEC.W	D0	SWAP.W	D0	DEC.W	D0	SWAP.W	D0	ADD.W	D1,#2	DEC.W	D5	SWAP.W	D5	DEC.W	D5	SWAP.W	D5	ADD.W	D6,#2	SWAP.W	D6	ADD.W	D6,#2	SWAP.W	D6	JUMP'	25$20$:	INC.W	D5	SUB.W	D6,#2	SWAP.W	D6	DEC.W	D6	SWAP.W	D6;	JUMP'	25$; Dessine les 8 surfaces tout autour (voir dessin ci-dessus).25$:	LOAD.L	D3,D0	SUB.W	D3,#EPCADIC	SWAP.W	D3	SUB.W	D3,#EPCADIC	SWAP.W	D3	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D1	ADD.W	D4,#EPCADIC*2	LIB	?DRTRAME	; surface (1)	LOAD.L	D3,D0	ADD.W	D3,D1	LOAD.L	D4,D1	LOAD.W	D4,#EPCADIC	LIB	?DRTRAME	; surface (2)	LOAD.L	D3,D5	SWAP.W	D3	SUB.W	D3,#EPCADIC	SWAP.W	D3	LOAD.W	D3,D0	ADD.W	D3,D1	ADD.W	D3,#EPCADIC	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D5	ADD.W	D4,D6	SUB.W	D4,D0	SUB.W	D4,D1	LIB	?DRTRAME	; surface (3)	LOAD.L	D3,D5	ADD.W	D3,D6	LOAD.L	D4,D6	LOAD.W	D4,#EPCADIC	LIB	?DRTRAME	; surface (4)	LOAD.L	D3,D5	SWAP.W	D3	SWAP.W	D6	ADD.W	D3,D6	SWAP.W	D6	SWAP.W	D3	SUB.W	D3,#EPCADIC	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D6	ADD.W	D4,#EPCADIC*2	LIB	?DRTRAME	; surface (5)	LOAD.L	D3,D5	SUB.W	D3,#EPCADIC	LOAD.L	D4,D6	LOAD.W	D4,#EPCADIC	LIB	?DRTRAME	; surface (6)	LOAD.L	D3,D5	SUB.W	D3,#EPCADIC	SWAP.W	D3	SUB.W	D3,#EPCADIC	SWAP.W	D3	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D0	SUB.W	D4,D5	LIB	?DRTRAME	; surface (7)	LOAD.L	D3,D0	SUB.W	D3,#EPCADIC	LOAD.L	D4,D1	LOAD.W	D4,#EPCADIC	LIB	?DRTRAME	; surface (8)	JUMP	EXIT$50$:	TEST.L	D2:#16		; petite marge autour ?	JUMP',BC 60$		; non => 60$				; oui =>	DEC.W	D0	SWAP.W	D0	DEC.W	D0	SWAP.W	D0	ADD.W	D1,#2	SWAP.W	D1	ADD.W	D1,#2	SWAP.W	D1	JUMP'	65$60$:	INC.W	D0	SWAP.W	D0	INC.W	D0	SWAP.W	D0	SUB.W	D1,#4	SWAP.W	D1	SUB.W	D1,#3	SWAP.W	D165$:	LOAD.L	D3,D0	SUB.W	D3,#EPCADIC	SWAP.W	D3	SUB.W	D3,#EPCADIC	SWAP.W	D3	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D1	ADD.W	D4,#EPCADIC*2	LIB	?DRTRAME	; surface (1)	LOAD.L	D3,D0	ADD.W	D3,D1	LOAD.L	D4,D1	LOAD.W	D4,#EPCADIC	LIB	?DRTRAME	; surface (2)	LOAD.L	D3,D0	SWAP.W	D3	SWAP.W	D1	ADD.W	D3,D1	SWAP.W	D1	SWAP.W	D3	SUB.W	D3,#EPCADIC	LOAD.W	D4,#EPCADIC	SWAP.W	D4	LOAD.W	D4,D1	ADD.W	D4,#EPCADIC*2	LIB	?DRTRAME	; surface (3)	LOAD.L	D3,D0	SUB.W	D3,#EPCADIC	LOAD.L	D4,D1	LOAD.W	D4,#EPCADIC	LIB	?DRTRAME	; surface (4)EXIT$:	POPM.L	D0..D6	RET;----------\\; RCTSICONE >;----------/; Donne les positions/dimensions des deux rectangles pour; englober une icne.;	         D3 o---------|;	            |         |;	            |<-- D4 ->|;	            |         |;	   D5 o-----|---------|-----|;	      |<-------- D6 ------->|;	      |---------------------|; in	A5.L	^description unit;	D4.W	rang (0..n); out	D3.L	r1: position (y;x);	D4.L	r1: dimensions (dy;dx);	D5.L	r2: position (y;x);	D6.L	r3: dimensions (dy;dx); mod	D3.L, D4.L, D5.L, D6.L, D7.WRCTSICONE:	PUSHM.L	D0,D1	CALL	POSICONE	; D4 <-- position coin sup/gauche	JUMP,NE EXIT$	TEST.B	(A5)+OUNFAAF:#BFLAI-16	JUMP,BC 50$	LOAD.L	D1,D4	LOAD.L	D3,D4	SUB.W	D3,(A6)+OGCIIMX	DEC.W	D3	SWAP.W	D3	SUB.W	D3,(A6)+OGCIIMY	DEC.W	D3	SWAP.W	D3	LOAD.W	D4,(A6)+OGCIIMY	SL.W	D4,#1	ADD.W	D4,(A6)+OGCIIY	ADD.W	D4,#2	SWAP.W	D4	LOAD.W	D4,(A6)+OGCIIMX	SL.W	D4,#1	ADD.W	D4,(A6)+OGCIIX	ADD.W	D4,#3	TEST.B	(A6)+ODEMIX	JUMP',F 20$	DEC.W	D3	INC.W	D420$:	TEST.B	(A6)+ODEMIY	JUMP',F 25$	SWAP.W	D3	SWAP.W	D4	DEC.W	D3	INC.W	D4	SWAP.W	D4	SWAP.W	D325$:	LOAD.L	D5,D3	LOAD.L	D6,D4	LOAD.L	D3,D1	LOAD.W	D0,(A6)+OGCIIX	SR.W	D0,#1	ADD.W	D3,D0	LOAD.W	D1,(A6)+OTDFCX	MUL.WU	D1,#15	LOAD.W	D4,D1	SR.W	D1,#1	SUB.W	D3,D1	TEST.B	(A6)+ODEMIX	JUMP',F 30$	DEC.W	D3	INC.W	D430$:	SWAP.W	D3	ADD.W	D3,(A6)+OGCIIY	ADD.W	D3,(A6)+OGCIIMY	INC.W	D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,(A6)+OTDFCY	ADD.W	D4,(A6)+OGCIIMT	SWAP.W	D4	EX.L	D3,D5	EX.L	D4,D6	JUMP'	EXIT$50$:	LOAD.L	D3,D4	SWAP.W	D3	INC.W	D3	LOAD.W	D4,(A5)+OUNLGY	SUB.W	D4,#3	TEST.B	(A6)+ODEMIY	JUMP',F 60$	SUB.W	D3,#2	ADD.W	D4,#260$:	SWAP.W	D4	SWAP.W	D3	LOAD.W	D4,(A5)+OUNLGX	TEST.B	(A5)+OUNFAAF:#BFLAN-16	JUMP',BC 65$	INC.W	D3	DEC.W	D465$:	CLR.L	D5		; D5/D6 <-- pas de deuxime rectangle	CLR.L	D6EXIT$:	POPM.L	D0,D1	TEST.W	D7		; retour EQ/NE	RET;----------\\; LOLIICONE >;==========/; Met en pointill une icne, n'importe o dans l'cran !; in	A5.L	^description unit;	D4.L	coordonne coin sup/gauche icne; out	-; mod	D7.WLOLIICONE:	PUSHM.L	D2..D5	LIB	?AFTIM	.B	MAPTT	.B	B'01010101	; <map>	.B	1		; <chelle>	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT	CLR.W	D5		; D5 <-- pas d'ombre	CALL	LOLIONEICONE	; inverse l'icne	TEST.W	(A6)+OSELNB	; slection multiple ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.W	D5,#6		; D5 <-- profondeur de l'ombre	TEST.B	(A6)+ODEMIY	JUMP',F 40$	LOAD.W	D5,#340$:	SUB.W	D4,D5	SWAP.W	D4	SUB.W	D4,D5	SWAP.W	D4	CALL	LOLIONEICONE	; inverse l'ombreEXIT$:	POPM.L	D2..D5	RET;-------------\\; LOLIONEICONE >;-------------/; Met en pointill une icne, n'importe o dans l'cran !;	                (1);	            |----|----|;	            |         |;	        (8)-|         |-(2);	        (7) |         | (3);	      |--|--|         |--|--|;	  (6)-|                     |-(4);	      |----------|----------|;	                (5); in	A5.L	^description unit;	D2.W	mode;	D4.L	coordonne coin sup/gauche icne;	D5.W	profondeur de l'ombre; out	-; mod	D7.WLOLIONEICONE:	PUSHM.L	D0..D4	LOAD.W	D2,#INVDOT!TTTDOT	TEST.B	(A5)+OUNFAAF:#BFLAI-16	JUMP,BC 50$	LOAD.W	D1,(A6)+OTDFCX	MUL.WU	D1,#15	LOAD.W	D0,(A6)+OGCIIMX	SL.W	D0,#1	ADD.W	D0,(A6)+OGCIIX	ADD.W	D0,#3	SUB.W	D1,D0	SR.W	D1,#1	LOAD.L	D3,D4	SUB.W	D3,(A6)+OGCIIMX	DEC.W	D3	SWAP.W	D3	SUB.W	D3,(A6)+OGCIIMY	DEC.W	D3	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A6)+OGCIIMX	SL.W	D4,#1	ADD.W	D4,(A6)+OGCIIX	ADD.W	D4,#3	LIB	?DRSEG		; (1) horizontale dessus	OR.W	D2,#NCTDOT	; D2 <-- plus de rz du traitill	LOAD.W	D4,(A6)+OGCIIMY	SL.W	D4,#1	ADD.W	D4,(A6)+OGCIIY	INC.W	D4	SWAP.W	D4	CLR.W	D4	CALL	LOLIONESEG2	; (2)	CLR.L	D4	LOAD.W	D4,D1	CALL	LOLIONESEG3	; (3)	LOAD.W	D4,(A6)+OTDFCY	ADD.W	D4,(A6)+OGCIIMT	SWAP.W	D4	CLR.W	D4	CALL	LOLIONESEG4	; (4)	LOAD.W	D4,(A6)+OTDFCX	MUL.WU	D4,#15	NEG.W	D4	CALL	LOLIONESEG5	; (5) horizontale dessous	LOAD.W	D4,(A6)+OTDFCY	ADD.W	D4,(A6)+OGCIIMT	NEG.W	D4	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; (6)	CLR.L	D4	LOAD.W	D4,D1	LIB	?DRSEG		; (7)	LOAD.W	D4,(A6)+OGCIIMY	SL.W	D4,#1	ADD.W	D4,(A6)+OGCIIY	INC.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; (8)	JUMP	EXIT$50$:	LOAD.L	D3,D4	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.W	D4,(A5)+OUNLGY	SUB.W	D4,#3	SWAP.W	D4	LOAD.W	D4,(A5)+OUNLGX	TEST.W	D5	JUMP',NE 60$	LIB	?DRRECT		; simple rectangle	JUMP'	EXIT$60$:	LOAD.L	D1,D4	AND.L	D4,#H'FFFF	LIB	?DRSEG	LOAD.L	D4,D1	CLR.W	D4	CALL	LOLIONESEG2	CLR.L	D4	LOAD.W	D4,D1	NEG.W	D4	CALL	LOLIONESEG5	LOAD.L	D4,D1	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CLR.W	D4	LIB	?DRSEGEXIT$:	POPM.L	D0..D4	RET;------------\\; LOLIONESEG2 >;------------/;------------\\; LOLIONESEG4 >;------------/; Dessine le segment (2) ou (4).; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D5.W	ombre; out	D3.L	nouvelle origine (y;x); mod	D3.L, D4.L, D7.WLOLIONESEG2:LOLIONESEG4:	TEST.W	D5	JUMP',NE 50$	LIB	?DRSEG	RET50$:	PUSHM.L	D3,D4	SWAP.W	D4	LOAD.W	D4,D5	SWAP.W	D4	LIB	?DRSEG	POPM.L	D3,D4	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	RET;------------\\; LOLIONESEG3 >;------------/; Dessine le segment (3).; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D5.W	ombre; out	D3.L	nouvelle origine (y;x); mod	D3.L, D4.L, D7.WLOLIONESEG3:	TEST.W	D5	JUMP',NE 50$	LIB	?DRSEG	RET50$:	PUSHM.L	D3,D4	ADD.W	D3,D5	SUB.W	D4,D5	LIB	?DRSEG	POPM.L	D3,D4	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	RET;------------\\; LOLIONESEG5 >;------------/; Dessine le segment (5).; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D5.W	ombre; out	D3.L	nouvelle origine (y;x); mod	D3.L, D4.L, D7.WLOLIONESEG5:	TEST.W	D5	JUMP',NE 50$	LIB	?DRSEG	RET50$:	PUSHM.L	D3,D4	ADD.W	D3,D4	ADD.W	D3,D5	LOAD.W	D4,D5	NEG.W	D4	LIB	?DRSEG	POPM.L	D3,D4	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	RET;---------\\; LOLITOUT >;=========/; Met en pointill le rectangle du tout, n'importe o dans l'cran !; in	A5.L	^description unit;	D4.L	coordonne coin sup/gauche icne; out	-; mod	D7.WLOLITOUT:	PUSHM.L	D2..D4	LIB	?AFTIM	.B	MAPTT	.B	B'01010101	; <map>	.B	1		; <chelle>	.B	0	.EVEN	PUSH.L	D4	LOAD.W	D2,#NOCNOM	CALL	POSCADRE	; D4 <-- dimensions	POP.L	D3		; D3 <-- coin sup/gauche	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT		; rectangle pointill	POPM.L	D2..D4	RET;---------\\; POSICONE >;---------/; Donne la position d'une icne.;	;	            |---------|;	    ici __  |         |;	          \ |         |;	           \|         |;	      |-----O         |-----|;	      |                     |;	      |---------------------|;; in	A5.L	^description unit;	D4.W	rang (0..n);		:#15 --> ok mme si icne inexistante; out	D4.L	position du coin sup/gauche de l'icne;	D7.W	erreur si invisible; mod	D4.L, D7.WPOSICONE:	PUSHM.L	D2,D3	LOAD.W	D7,#1		; D7 <-- icne invisible	TCLR.L	D4:#15	JUMP',BS 10$	COMP.W	D4,(A5)+OUNNBL	JUMP,HS EXIT$10$:	LOAD.W	D3,(A5)+OUNASC+OSCPOSV	MUL.WU	D3,(A5)+OUNNBX	; D3 <-- rang initial selon ascenseur	SUB.W	D4,D3	JUMP,LO EXIT$	LOAD.W	D3,(A5)+OUNNBX	MUL.WU	D3,(A5)+OUNNBY	COMP.W	D4,D3	JUMP,HS EXIT$	AND.L	D4,#H'FFFF	DIV.WU	D4,(A5)+OUNNBX	; D4 <-- rang en Y	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- rang en X	TEST.B	(A5)+OUNFAAF:#BFLAI-16	JUMP,BC 50$	MUL.WU	D3,(A5)+OUNLGX	LOAD.W	D2,(A5)+OUNLGX	SUB.W	D2,(A6)+OGCIIX	SR.W	D2,#1	ADD.W	D3,D2	ADD.W	D3,(A5)+OUNPOS+2	INC.W	D3		 ; D3 <-- position en X	MUL.WU	D4,(A5)+OUNLGY	LOAD.W	D2,(A6)+OGCIIMY	ADD.W	D2,(A6)+OGCIIY	ADD.W	D2,(A6)+OGCIIMY	ADD.W	D2,(A6)+OGCIIMT	ADD.W	D2,(A6)+OTDFCY	; D2 <-- hauteur pour une icne	SUB.W	D2,(A5)+OUNLGY	NEG.W	D2	SR.W	D2,#1	ADD.W	D2,(A6)+OGCIIMY	ADD.W	D4,D2	ADD.W	D4,(A5)+OUNPOS+0	ADD.W	D4,(A6)+ODCASY	INC.W	D4		; D4 <-- position en Y	SWAP.W	D4	LOAD.W	D4,D3	JUMP'	80$50$:	MUL.WU	D3,(A5)+OUNLGX	ADD.W	D3,(A5)+OUNPOS+2	INC.W	D3		 ; D3 <-- position en X	MUL.WU	D4,(A5)+OUNLGY	ADD.W	D4,(A5)+OUNPOS+0	ADD.W	D4,(A6)+ODCASY	INC.W	D4		; D4 <-- position en Y	TEST.B	(A6)+ODEMIY	JUMP',F 60$	INC.W	D4		; D4 <-- p'tits caractres pas trop haut !60$:	SWAP.W	D4	LOAD.W	D4,D380$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RET	.END