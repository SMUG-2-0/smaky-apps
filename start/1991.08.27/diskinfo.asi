	.SBTTL	DISKINFO.ASI;-----------\\; _DISK_INFO >;===========/; Donne quelques informations sur un disque.; in	A3.L	^nom du disque; out	D7.W	erreur; mod	D7.W_DISK_INFO:	PUSHM.L	D0..D5,A1..A6	CALL	OPEVAR		; A6 <-- ^variables globales	JUMP,NE QUIT$	LOAD.L	A2,#R16"TDBOX_INFO	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$	CALL	WAITMOUSE	; souris: met le sablier	CLR.W	D3		; D3 <-- global	FOS	?VASSIGN	; A4 <-- ^nom phsique	JUMP,NE CLOSE$; Affiche les noms physiques et logiques.	PUSHM.L	A3,A4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche le nom logique	LOAD.W	D2,#2!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le nom physique	POPM.L	A3,A4; Affiche le nom du disque et le dossier systme.	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D0,#FOS?INFODISK	CALL	ERCALL		; OBUHEAD <-- informations du disque	JUMP',NE NEND$	LOAD.W	D2,#3!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A4)+OBK0NLO	LIB	?AFTEXT		; affiche le nom du disque	LOAD.W	D2,#4!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A4)+OBK0SYS	LIB	?AFTEXT		; affiche le dossier systmeNEND$:	POPM.L	A3,A4; Affiche le mode lecture/criture.	COMP.B	(A4),#'@	; nom physique rseau ?	JUMP,EQ MGREY$		; oui => MGREY$				; non =>	PUSH.L	A4	LOAD.L	D0,#FOS?GETUNIT	CALL	ERCALL		; D4 <-- info et A4 <-- ^bitmap	POP.L	A4	JUMP,NE CLOSE$	LOAD.L	D0,D4	LOAD.W	D2,#5!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	TEST.L	D0:#0	JUMP',BS MREAD$MRW$:	LIB	?AFTIM	.ASCIZ	"lecture et criture"	.EVEN	JUMP'	MFORM$MREAD$:	LIB	?AFTIM	.ASCIZ	"<AFINV> lecture seulement <AFDIR>"	.EVENMFORM$:	PUSHM.L	A3,A4	CLR.W	(A6)+OOS	; OOS <-- tous les operating system	CLR.W	(A6)+OOP	; OOP <-- normal	LOAD.L	A3,A4		; A3 <-- ^nom du disque	CALL	FMTSTATUS	; A4 <-- ^status	JUMP',NE MFEND$	CALL	FMTUSE		; A4/D4 <-- ^format/rang actuel	JUMP',NE MFEND$	LOAD.W	D3,D4	CALL	DBTYPSLCASE	; A3 <-- ^texte du format	LOAD.L	A3,#(A3)+7	; A3 <-- saute "Format "	LOAD.W	D2,#9!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche le formatMFEND$:	POPM.L	A3,A4	JUMP'	MEND$MGREY$:	LOAD.W	D2,#10+5!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO		; grise la ligne "Mode:"	LOAD.W	D2,#10+9!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO		; grise la ligne "Format:"MEND$:; Affiche le type fixe/amovible.	LOAD.W	D2,#6!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	COMP.B	(A4),#'@	; nom physique rseau ?	JUMP',EQ TNET$		; oui => TNET$				; non =>	PUSH.L	A4	CALL	MINSTATUS	; A4 <-- ^status minimal	LOAD.B	D4,(A4)+OMTYPE	; D4 <-- MT*	POP.L	A4	TEST.W	D7	JUMP',NE TERROR$	COMP.B	D4,#MTFLO	JUMP',EQ TFLO$	COMP.B	D4,#MTMEM	JUMP',EQ TMEM$	COMP.B	D4,#MTMEM+1	; ?	JUMP',EQ TMEM$TFIX$:	LIB	?AFTIM	.ASCIZ	"disque fixe"	.EVEN	JUMP'	TEND$TFLO$:	LIB	?AFTIM	.ASCIZ	"disque amovible"	.EVEN	JUMP'	TEND$TMEM$:	LIB	?AFTIM	.ASCIZ	"disque virtuel (en mmoire)"	.EVEN	JUMP'	TEND$TNET$:	LIB	?AFTIM	.ASCIZ	"disque  distance (rseau)"	.EVEN	JUMP'	TEND$TERROR$:	LIB	?AFTIM	.ASCIZ	"inconnu"	.EVEN;	JUMP'	TEND$TEND$:; Affiche la place restante/utilise.	LOAD.L	D0,#FOS?DISK	CALL	ERCALL	JUMP,NE CLOSE$	LOAD.L	D0,D3		; D0 <-- reste	LOAD.L	D1,D4		; D1 <-- utilis	LOAD.W	D2,#7!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,D0		; D4 <-- reste en blocs	SL.L	D4,#8		; D4 <-- reste en bytes	LOAD.B	D3,#10		; D3 <-- 10 digits au maximum	LOAD.B	D2,#2^BAFDSP	; D2 <-- compact + '	LIB	?AFDEC		; affiche en dcimal	LOAD.W	D2,#8!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,D1		; D4 <-- utilis en blocs	SL.L	D4,#8		; D4 <-- utilis en bytes	LOAD.B	D3,#10		; D3 <-- 10 digits au maximum	LOAD.B	D2,#2^BAFDSP	; D2 <-- compact + '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	" ou "	.EVEN	CALL	CALCPOURCENT	; D4 <-- 0..100	LOAD.B	D3,#3		; D3 <-- 3 digits au maximum	LOAD.B	D2,#2^BAFDCM	; D2 <-- compact sans '	LIB	?AFDEC		; affiche en dcimal	LIB	?AFTIM	.ASCIZ	"%"	.EVEN	CALL	NORMMOUSE	; souris: enlve le sablierLOOP$:	CLR.L	D4		; D4 <-- fanions	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_INFO	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP',EQ CLOSE$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLOSE$:				; VU =>	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D7EXIT$:	CALL	CLOVAR		; rend les variables globalesQUIT$:	POPM.L	D0..D5,A1..A6	TEST.W	D7		; retour EQ/NE	RETTDBOX_INFO:	.W	10$-TDBOX_INFO	.W	20$-TDBOX_INFO	.W	0	.W	010$:	.B	ODBTEXT	.ASCIZ	"Nom logique:     "	.B	ODBLABEL,1	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,17+31	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Nom physique:    "	.B	ODBLABEL,2	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Nom du disque:   "	.B	ODBLABEL,3	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Dossier systme: "	.B	ODBLABEL,4	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Type:"	.B	ODBTABX,17	.B	ODBLABEL,6	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR	.B	ODBLABEL,10+5	.B	ODBTEXT	.ASCIZ	"Mode:"	.B	ODBTABX,17	.B	ODBLABEL,5	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR	.B	ODBLABEL,10+9	.B	ODBTEXT	.ASCIZ	"Format:"	.B	ODBTABX,17	.B	ODBLABEL,9	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Place restante:  "	.B	ODBLABEL,7	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Place utilise:  "	.B	ODBLABEL,8	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"   VU   "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"VU"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_INFO:	.W	F1,F2,F3,CR,END,0	DOKF1-TKEY_INFO	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_INFO	.W	0	.END