	.SBTTL	STARTMATRIX.ASIIIXICONES =	7;--------\\; GETPICO >;========/; Donne le pointeur a la bonne matrice.; in	D3.W	type;	A3.L	^nom du fichier; out	A4.L	^dx,dy,matrice; mod	A4.LGETPICO:	TEST.B	(A6)+ODEMIX	JUMP,T	22$	TEST.B	(A6)+ODEMIY	JUMP,T	12$11$:	LOAD.L	A4,#R16"IUNIT11	COMP.W	D3,#TYPUNIT	JUMP,EQ EXIT$	LOAD.L	A4,#R16"IDIR11	COMP.W	D3,#TYPDIR	JUMP,EQ EXIT$	LOAD.L	A4,#R16"IDOSSIER11	COMP.W	D3,#TYPDOSSIER	JUMP,EQ EXIT$	LOAD.L	A4,#R16"ICODE11	COMP.W	D3,#TYPCODE	JUMP',EQ CODE11$	COMP.W	D3,#TYPSYSC	JUMP',EQ CODE11$	LOAD.L	A4,#R16"IDOC11	JUMP	EXIT$CODE11$:	TEST.L	(A3)+OFLLG	; longueur nulle ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.L	A4,#R16"IACCES11	JUMP	EXIT$12$:	LOAD.L	A4,#R16"IUNIT12	COMP.W	D3,#TYPUNIT	JUMP,EQ EXIT$	LOAD.L	A4,#R16"IDIR12	COMP.W	D3,#TYPDIR	JUMP,EQ EXIT$	LOAD.L	A4,#R16"IDOSSIER12	COMP.W	D3,#TYPDOSSIER	JUMP,EQ EXIT$	LOAD.L	A4,#R16"ICODE12	COMP.W	D3,#TYPCODE	JUMP',EQ CODE12$	COMP.W	D3,#TYPSYSC	JUMP',EQ CODE12$	LOAD.L	A4,#R16"IDOC12	JUMP	EXIT$CODE12$:	TEST.L	(A3)+OFLLG	; longueur nulle ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.L	A4,#R16"IACCES12	JUMP	EXIT$22$:	LOAD.L	A4,#R16"IUNIT22	COMP.W	D3,#TYPUNIT	JUMP',EQ EXIT$	LOAD.L	A4,#R16"IDIR22	COMP.W	D3,#TYPDIR	JUMP',EQ EXIT$	LOAD.L	A4,#R16"IDOSSIER22	COMP.W	D3,#TYPDOSSIER	JUMP',EQ EXIT$	LOAD.L	A4,#R16"ICODE22	COMP.W	D3,#TYPCODE	JUMP',EQ CODE22$	COMP.W	D3,#TYPSYSC	JUMP',EQ CODE22$	LOAD.L	A4,#R16"IDOC22	JUMP'	EXIT$CODE22$:	TEST.L	(A3)+OFLLG	; longueur nulle ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.L	A4,#R16"IACCES22;	JUMP'	EXIT$EXIT$:	RETIUNIT11:	.B	51,31        .B      B'00000000,B'00000000,B'00000000,B'00000000,B'00000000,B'00000000,B'00000000        .B      B'01111111,B'11111111,B'11111111,B'11111111,B'11111111,B'11111111,B'11000000        .B      B'01000000,B'00000000,B'00000000,B'00000000,B'00000000,B'00000000,B'01000000        .B      B'01000000,B'00000000,B'00000000,B'00000000,B'00000000,B'000000