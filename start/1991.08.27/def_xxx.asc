	.TITLE	DEF_XXX.ASC;	--------------------------------------;		(C) 1991 - Daniel Roux;	--------------------------------------;	Source du programme DEF_XXX.CODE;	Ce fichier sert  fabriquer un programme DEF_*.CODE,;	en remplaant les "XXX" par le nom (6 caractres au;	maximum), et en compltant partout o cela est;	ncessaire ...	.PROC	M680002	.RADIX	10.	.HEXDEFREV	=	1		; rvisionDEFVERS	=	0		; version;	Date		Amliorations; --------------------------------------------------------------------------------------------------; 1.0	16.05.91	premire version	.REF	SMAKY	.REF	MODULES;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;SMAKY300 = 7;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.REV	DEFREV,DEFVERS;;?	.HEADER	OBXSOVER.L OVERLAY	; faire "HEADER DEF_XXX.CODE 16/O" !!!	.CODE	800,11,B'100111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LBUDIS	=	20KEYDBOX	=	H'7E00		; "touche" pour dbox; Variables; ---------	.LOC	0OPLCOM:	.BLKB	4		; ^ligne de commandeOBUDIS:	.BLKB	LBUDIS		; buffer temporaireOMOUSE:	.BLKB	1		; mode souris initialOMACHINE:.BLKB	1		; type de la machine (SMAKY*)	.EVENOCHMENU:.BLKB	4		; canal des soft-keys;	...LGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	CALL	OVERLAY	LIB	?CLOLIB	FOS	?STOPOVERLAY:	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE EXIT$	GESMEM	?CLEARMEM	; met TOUTES les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; OPLCOM <-- ^ligne de commande	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	NTREL	?GETMACHINE	RL.L	D4,#8	LOAD.B	(A6)+OMACHINE,D4	LOAD.L	A3,(A6)+OPLCOM	LOAD.B	D3,#'I	LIB	?IFSWITCH	; excut avec /i ?	JUMP',EQ INIT$		; oui => INIT$	CALL	DBOXMAIN	; appel dbox principale ...	JUMP',EQ END$	JUMP'	NOOVER$INIT$:;	...			; initialisation au dmarrage (sans dialogue)	JUMP'	END$NOOVER$:	LOAD.W	D7,#-1		; D7 <-- demande une excution normaleEND$:	PUSH.W	D7	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre les variables	POP.W	D7EXIT$:	RET;---------\\; DBOXMAIN >;=========/; Modifie quelques informations gnrales sur la machine.; in	-; out	D7.W	erreur; mod	D7.WDBOXMAIN:	PUSHM.L	D0..D6,A1..A5	LIB	?PUSHMENU	; sauve les soft-keys	LOAD.L	(A6)+OCHMENU,D5	LIB	?GMOUSE	LOAD.B	(A6)+OMOUSE,D3	LOAD.W	D3,#2	LIB	?MOUSE		; souris par le clavier	CALL	NORMMOUSE	; souris: enlve le sablier	LOAD.L	A2,#R16"TDBOX_MAIN	LOAD.W	D2,#2^BDBSAV	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	EXIT$LOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_MAIN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#F1	JUMP,EQ DACCORD$	COMP.W	D3,#F0	JUMP,EQ ANNULE$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$DACCORD$:			; D'ACCORD =>;	...ANNULE$:			; ANNULE =>	PUSH.W	D7	DBOX_	CLOSE		; ferme la DBOX	POP.W	D7EXIT$:	PUSH.W	D7	LOAD.B	D3,(A6)+OMOUSE	LIB	?MOUSE		; remet le mode souris initial	LOAD.L	D5,(A6)+OCHMENU	LIB	?POPMENU	; restitue les soft-keys	CALL	NORMMOUSE	; souris: enlve le sablier	POP.W	D7	POPM.L	D0..D6,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_MAIN:	.W	10$-TDBOX_MAIN	.W	20$-TDBOX_MAIN	.W	0	.W	010$:	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_MAIN:	.W	F1,F2,F3,0		DOKF1-TKEY_MAIN	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_MAIN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MAIN	.W	0;--------\\; RETURN  >;========/; Retourne un paramtre au programme appelant.; Le programme appelant doit excuter une ligne de commande;	DEF_XXX.CODE ^ad/Z; o "ad" est l'adresse (hexadcimale) o mettre le paramtre; en retour.; START ne gnre le "^ad/Z" que si le fichier START.INFO; contient un /R (par exemple "DEF_COLOR"/R) !; Actuellement, START accepte les paramtres suivants :;	"R"	redessine toute la fentre; in	D3.B	paramtre  retourner; out	-; mod	D7.WRETURN:	PUSHM.L	D2..D4,A3,A4	LOAD.B	D2,D3		; D2 <-- paramtre	LOAD.L	A3,(A6)+OPLCOMLOOP$:	LOAD.B	D3,#'Z	LIB	?IFSWITCH	; "^12345678/Z" trouv ?	JUMP',EQ FOUND$		; oui => FOUND$	LIB	?SKPNAM	JUMP,EQ LOOP$	JUMP'	EXIT$FOUND$:	COMP.B	(A3+),#'^	; commence par "^" ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.L	A4,A3	CALL	GETHNUM		; D4 <-- adresse o mettre la rponse	LOAD.L	A4,D4	LOAD.B	(A4),D2		; zone rponse <-- paramtreEXIT$:	POPM.L	D2..D4,A3,A4	RET;--------\\; GETHNUM >;========/; Lit un nombre hexadcimal.; in	A4.L	^nombre hexa; out	D4.L	nombre hexa; mod	D4.L, D7.WGETHNUM:	PUSH.W	D3	CLR.L	D4LOOP$:	LOAD.B	D3,(A4)	SUB.B	D3,#'0	JUMP',LO EXIT$	COMP.B	D3,#9	JUMP',LS PUT$	SUB.B	D3,#'A-'9-1	JUMP',LO EXIT$	COMP.B	D3,#15	JUMP',HI EXIT$PUT$:	SL.L	D4,#4	OR.B	D4,D3		; D4 <-- nouveau digit	INC.L	A4	JUMP	LOOP$EXIT$:	POP.W	D3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RET	.END	START