	.SBTTL	FILMMOVEDOMOVE:	LIB	?AFTIM	.B	EOP		; efface tout	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	TEST.B	(A6)+OFANION+3:#BNEGATIF	JUMP,BC NEGATIF$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	LIB	?GETDIM	CLR.L	D3	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; allume toute le fentreNEGATIF$:	LOAD.W	(A6)+OINC,#+1	CLR.W	(A6)+OSTOP	CALL	SOFTKEY	CALL	TRANSCREATE	; gnre les images intermdiaires	JUMP,NE DOERROR	CLR.L	D4		; D4 <-- numro de l'image	CLR.W	D5		; D5 <-- numro de la position	CLR.L	(A6)+OLSTPI	; OLSTPI <-- ^dernire image affiche	CLR.L	(A6)+OLSTPO	; OLSTPO <-- dernire position	CLR.B	(A6)+OMSS	CALL	NORMMOUSE	; enlve le sablierLOOP$:	LIB	?IFCAR	JUMP,NE MOVE$	COMP.W	D3,#F0+SHIFT	JUMP',LO 10$	COMP.W	D3,#F15+SHIFT	JUMP',HI 10$	SUB.W	D3,#SHIFT10$:	COMP.W	D3,#END	JUMP,EQ DOMAIN	COMP.W	D3,#F0	JUMP,EQ DOMAIN	COMP.W	D3,#F1	JUMP,EQ VITAM$	COMP.W	D3,#F2	JUMP,EQ VITAD$	COMP.W	D3,#F3	JUMP,EQ VITAP$	COMP.W	D3,#F4	JUMP,EQ VITMM$	COMP.W	D3,#F5	JUMP,EQ VITMD$	COMP.W	D3,#F6	JUMP,EQ VITMP$	COMP.W	D3,#F7	JUMP,EQ INV$	COMP.W	D3,#F8	JUMP,EQ INV$	COMP.W	D3,#F9	JUMP,EQ INV$	COMP.W	D3,#F10	JUMP,EQ PAUSE$	COMP.W	D3,#F11	JUMP,EQ PAUSE$	COMP.W	D3,#F12	JUMP,EQ PAUSE$	COMP.W	D3,#F13	JUMP,EQ STEP$	COMP.W	D3,#F14	JUMP,EQ STEP$	COMP.W	D3,#F15	JUMP,EQ STEP$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$VITAM$:	LOAD.L	A2,#R16"TAVITA	LOAD.W	D2,(A6)+OVITA	CALL	VITPREV	JUMP,NE BIP$	LOAD.W	(A6)+OVITA,D2	CALL	SOFTKEY	JUMP	LOOP$VITAP$:	LOAD.L	A2,#R16"TAVITA	LOAD.W	D2,(A6)+OVITA	CALL	VITNEXT	JUMP,NE BIP$	LOAD.W	(A6)+OVITA,D2	CALL	SOFTKEY	JUMP	LOOP$VITAD$:	LOAD.L	A2,#R16"TAVITA	CALL	VITMOYE	LOAD.W	(A6)+OVITA,D2	CALL	SOFTKEY	JUMP	LOOP$VITMM$:	LOAD.L	A2,#R16"TAVITM	LOAD.W	D2,(A6)+OVITM	CALL	VITPREV	JUMP,NE BIP$	LOAD.W	(A6)+OVITM,D2	CALL	SOFTKEY	JUMP	LOOP$VITMP$:	LOAD.L	A2,#R16"TAVITM	LOAD.W	D2,(A6)+OVITM	CALL	VITNEXT	JUMP,NE BIP$	LOAD.W	(A6)+OVITM,D2	CALL	SOFTKEY	JUMP	LOOP$VITMD$:	LOAD.L	A2,#R16"TAVITM	CALL	VITMOYE	LOAD.W	(A6)+OVITM,D2	CALL	SOFTKEY	JUMP	LOOP$INV$:				; inverse =>;;?	CLR.W	(A6)+OSTOP	NEG.W	(A6)+OINC	CALL	SOFTKEY	JUMP	LOOP$PAUSE$:				; pause =>	TEST.W	(A6)+OSTOP	JUMP',EQ PAUSE2$	CLR.W	(A6)+OSTOP	CALL	SOFTKEY	JUMP	LOOP$PAUSE2$:	LOAD.W	(A6)+OSTOP,#-1	CALL	SOFTKEY	JUMP	LOOP$STEP$:				; step =>	LOAD.W	(A6)+OSTOP,#+1	CALL	SOFTKEY	JUMP	LOOP$MOVE$:	COMP.W	(A6)+OSTOP,#-1	JUMP,EQ STOP$	TEST.W	(A6)+OSTOP	JUMP,EQ ONE$	COMP.W	(A6)+OSTOP,#+1	JUMP,NE ONE$	LOAD.W	(A6)+OSTOP,#-1ONE$:	LOAD.L	D3,D4	SWAP.W	D3	TEST.W	D3		; effet en cours ?	JUMP,NE NEFFET$		; oui => NEFFET$NEXT$:	ADD.W	D4,(A6)+OINC	; D4 <-- image suivante	JUMP,NC NEXT3$	LOAD.W	D4,(A6)+ONBPRG	DEC.W	D4NEXT3$:	COMP.W	D4,(A6)+ONBPRG	JUMP,LO NEXT4$	CLR.W	D4NEXT4$:	LOAD.L	A2,#(A6)+OTAPRG	CLR.W	D3	LOAD.B	D3,(A2)+(D4.W)	TEST.L	D3:#BEFFET	JUMP,BS FEFFET$	LOAD.L	A2,#(A6)+OTAIMA	SL.W	D3,#2	LOAD.L	A2,(A2)+(D3.W)	; A2 <-- ^image	CALL	NEXTPOS		; D2 <-- position	CALL	IMAGEAFF	; affiche une image	LOAD.L	(A6)+OLSTPI,A2	; OLSTPI <-- ^dernire image afficheDEL$:	COMP.W	(A6)+OSTOP,#-1	JUMP,EQ LOOP$	PUSH.L	D4	LOAD.W	D4,(A6)+OVITA	COMP.W	D4,#1	JUMP,EQ DEL4$	NTREL	?DELMSDEL4$:	POP.L	D4	JUMP	LOOP$STOP$:	PUSH.L	D4	LOAD.W	D4,#50/10	NTREL	?DELMS	POP.L	D4	JUMP	LOOP$FEFFET$:	TEST.L	D3:#BTRANS	JUMP,BS FTRANS$	TEST.L	D3:#BMSS	JUMP,BS FMSS$	RL.L	D4,#8	LOAD.B	D4,D3		; D4 <-- [31..24] opration	RR.L	D4,#8	AND.W	D3,#H'000F	LOAD.W	D2,#50/4	DEC.W	D3	JUMP',NS FDELAI$	LOAD.W	D2,#50/2	DEC.W	D3	JUMP',NS FDELAI$	LOAD.W	D2,#50*1	DEC.W	D3	JUMP',NS FDELAI$	LOAD.W	D2,#50*2	DEC.W	D3	JUMP',NS FDELAI$	LOAD.W	D2,#50*4	DEC.W	D3	JUMP',NS FDELAI$	LOAD.W	D2,#50*8FDELAI$:	LOAD.W	D3,D2	AND.L	D2,#H'FFFF	DIV.WU	D2,(A6)+OVITA	COMP.W	D2,#1	JUMP,LS FDELAIF$	COMP.W	D2,#256	JUMP,HS FDELAIF$	SWAP.W	D4	LOAD.B	D4,D2		; D4 <-- [23..16] compteur	SWAP.W	D4	JUMP	NEFFET$FDELAIF$:	PUSH.L	D4	LOAD.W	D4,D3	NTREL	?DELMS	POP.L	D4	JUMP	LEFFET$FTRANS$:	RL.L	D4,#8	LOAD.B	D4,D3		; D4 <-- [31..24] opration	RR.L	D4,#8	SWAP.W	D4	CLR.B	D4		; D4 <-- [23..16] compteur	SWAP.W	D4	JUMP	NEFFET$FMSS$:	AND.W	D3,#H'000F	DEC.W	D3	JUMP,NS FMSS1$	DEC.W	D3	JUMP,NS FMSS2$	JUMP	NEXT$FMSS1$:	SET.B	(A6)+OMSS	JUMP	NEXT$FMSS2$:	CLR.B	(A6)+OMSS	JUMP	NEXT$NEFFET$:	TEST.L	D4:#BTRANS+24	JUMP,BC NDELAI$	LOAD.L	D3,D4	RL.L	D3,#8	CALL	TRANSGETNP	; D1/D2 <-- pas/nb images	SWAP.W	D4	ADD.B	D4,D1	COMP.B	D4,#32	JUMP,HS LEFFET$	LOAD.B	D1,D4	SWAP.W	D4	CALL	PRGIMADA	; D2 <-- images dpart/arrive |-|d|a|-|	JUMP,NE LOOP$	LOAD.B	D2,D1		; D2 <--                       |-|d|a|i|	CALL	TRANSGETPI	; A2 <-- ^image intermdiaire	JUMP,NE LOOP$	LOAD.L	D2,(A6)+OLSTPO	; D2 <-- dernire position	TEST.B	(A6)+ODPL:#BDPLIMT	JUMP,BS NTRANS2$	CALL	NEXTPOS		; D2 <-- positionNTRANS2$:	CALL	IMAGEAFF	; affiche une image intermdiaire	LOAD.L	(A6)+OLSTPI,A2	; OLSTPI <-- ^dernire image affiche	JUMP	DEL$NDELAI$:	SWAP.W	D4	DEC.B	D4	JUMP,EQ LEFFET$	SWAP.W	D4	TEST.L	(A6)+OLSTPI	JUMP,EQ NDELAI3$	LOAD.L	A2,(A6)+OLSTPI	; A2 <-- ^dernire image affiche	LOAD.L	D2,(A6)+OLSTPO	; D2 <-- dernire position	TEST.B	(A6)+ODPL:#BDPLIMD	JUMP,BS NDELAI2$	LOAD.L	D3,D2	CALL	NEXTPOS		; D2 <-- position	COMP.L	D3,(A6)+OLSTPO	JUMP,EQ NDELAI3$NDELAI2$:	CALL	IMAGEAFF	; affiche une imageNDELAI3$:	PUSH.L	D4	LOAD.W	D4,(A6)+OVITA	NTREL	?DELMS		; attend un peu	POP.L	D4	JUMP	LOOP$LEFFET$:	CLR.W	D4	SWAP.W	D4	JUMP	NEXT$;--------\\; NEXTPOS >;========/; ; in	D5.W	numro de la position; out	D5.W	numro suivant;	D2.L	position (y;x); mod	D2.L, D5.L, D7.WNEXTPOS:	PUSHM.L	D3,D4	TEST.B	(A6)+OMSS	JUMP,T	40$	LOAD.W	D4,(A6)+OVITM	MUL.WU	D4,(A6)+OINC	CLR.L	D3	LOAD.W	D3,D5	ADD.W	D5,D4		; D5 <-- position suivante	JUMP,VC 40$	SUB.L	D3,#H'10000	NEG.L	D3	ADD.W	D5,D3		; D5 <-- compense l'overflow !40$:	CALL	CALCPOS		; D2 <-- position	LOAD.L	(A6)+OLSTPO,D2	POPM.L	D3,D4	RET;---------\\; PRGIMADA >;=========/; Cherche dans le programme les images avant et aprs une; opration de transformation.; in	D4.W	rang dans le script; out	D2.L	images dpart/arrive |-|d|a|-|;	D7.W	erreur; mod	D2.L, D7.WPRGIMADA:	PUSHM.L	D1,D3	LOAD.W	D7,#1	COMP.W	(A6)+ONBPRG,#2	JUMP,LO 90$	CLR.L	D2	LOAD.W	D3,(A6)+OINC	NEG.W	D3		; D3 <-- -INC	CALL	PRGIMADA1	JUMP,NE 90$	SWAP.W	D2	LOAD.B	D2,D1		; D2 <-- d	SWAP.W	D2	LOAD.W	D3,(A6)+OINC	; D3 <-- +INC	CALL	PRGIMADA1	JUMP,NE 90$	RR.L	D2,#8	LOAD.B	D2,D1		; D2 <-- a	RL.L	D2,#8	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; PRGIMADA1 >;----------/; Cherche dans le programme les images avant et aprs une; opration de transformation.; in	D4.W	rang dans le script;	D3.W	+1/-1; out	D1.B	numro image;	D7.W	erreur; mod	D1.L, D7.WPRGIMADA1:	PUSHM.L	D2,D4,A2	CLR.W	D7		; D7 <-- trouv	LOAD.L	A2,#(A6)+OTAPRG	LOAD.W	D2,(A6)+ONBPRG	DEC.W	D220$:	ADD.W	D4,D3	JUMP,NC 30$	LOAD.W	D4,(A6)+ONBPRG	DEC.W	D430$:	COMP.W	D4,(A6)+ONBPRG	JUMP,LO 32$	CLR.W	D432$:	LOAD.B	D1,(A2)+(D4.W)	TEST.L	D1:#BEFFET	JUMP,BC 90$	DEC.W	D2	JUMP,NE 20$	LOAD.W	D7,#1		; D7 <-- erreur90$:	POPM.L	D2,D4,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; SOFTKEY >;========/; Affiche les barres sous les soft-keys.; in	-; out	-; mod	D7.WSOFTKEY:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#R16"TMENU_MOVE	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D3,#12-110$:	LOAD.B	(A4+),(A3+)	JUMP,NE 10$	DECJ.W,NMO D3,10$	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,#(A3)+6+6+18+6	LOAD.W	D4,(A6)+OVITA	CALL	SOFTKEYPUTD	LOAD.L	A4,#(A3)+6+6+18+18+18+6	LOAD.W	D4,(A6)+OVITM	CALL	SOFTKEYPUTN	LIB	?AFMENU	TEST.W	(A6)+OINC	JUMP,NC 30$	LOAD.W	D3,#7	LIB	?SETBARRE	INC.W	D3	LIB	?SETBARRE	INC.W	D3	LIB	?SETBARRE30$:	TEST.W	(A6)+OSTOP	JUMP,EQ 90$	LOAD.W	D3,#10	LIB	?SETBARRE	INC.W	D3	LIB	?SETBARRE	INC.W	D3	LIB	?SETBARRE90$:	POPM.L	D3,D4,A3,A4	RET;------------\\; SOFTKEYPUTN >;------------/; ; in	A4.L	^buffer;	D4.W	valeur; out	-; mod	D7.WSOFTKEYPUTN:	PUSHM.L	D2..D4,A4	AND.L	D4,#H'FFFF	LOAD.W	D3,#3	CLR.W	D2	LIB	?PUTDEC	LOAD.B	(A4),#SPACE	POPM.L	D2..D4,A4	RET;------------\\; SOFTKEYPUTD >;------------/; ; in	A4.L	^buffer;	D4.W	valeur; out	-; mod	D7.WSOFTKEYPUTD:	PUSHM.L	D3,D4	LOAD.B	(A4)+0,#SPACE	LOAD.B	(A4)+1,#'0	LOAD.B	(A4)+2,#'.	LOAD.B	(A4)+3,#'0	LOAD.L	D3,#500	DIV.WU	D3,D4	AND.L	D3,#H'FFFF	DIV.WU	D3,#100	TEST.B	D3	JUMP,EQ 20$	ADD.B	D3,#'0	LOAD.B	(A4)+0,D320$:	SWAP.W	D3	AND.L	D3,#H'FFFF	DIV.WU	D3,#10	ADD.B	D3,#'0	LOAD.B	(A4)+1,D3	SWAP.W	D3	ADD.B	D3,#'0	LOAD.B	(A4)+3,D3	POPM.L	D3,D4	RET;--------\\; VITNEXT >;========/; Cherche la vitesse suprieure.; in	A2.L	^table;	D2.W	vitesse actuelle; out	D2.W	nouvelle vitesse;	D7.W	erreur; mod	D2.L, D7.WVITNEXT:	PUSHM.L	D3,A2	LOAD.W	D7,#110$:	LOAD.W	D3,(A2+)	COMP.W	D3,#-1	JUMP,EQ 90$	COMP.W	D2,D3	JUMP,NE 10$	LOAD.W	D2,(A2)-4	COMP.W	D2,#-1	JUMP,EQ 90$	CLR.W	D790$:	POPM.L	D3,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; VITPREV >;========/; Cherche la vitesse infrieure.; in	A2.L	^table;	D2.W	vitesse actuelle; out	D2.W	nouvelle vitesse;	D7.W	erreur; mod	D2.L, D7.WVITPREV:	PUSHM.L	D3,A2	LOAD.W	D7,#110$:	LOAD.W	D3,(A2+)	COMP.W	D3,#-1	JUMP,EQ 90$	COMP.W	D2,D3	JUMP,NE 10$	LOAD.W	D2,(A2)	COMP.W	D2,#-1	JUMP,EQ 90$	CLR.W	D790$:	POPM.L	D3,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; VITMOYE >;========/; Cherche la vitesse moyenne.; in	A2.L	^table; out	D2.W	vitesse moyenne; mod	D2.L, D7.WVITMOYE:	PUSH.L	A2	LOAD.W	D2,#-110$:	INC.W	D2	COMP.W	(A2+),#-1	JUMP,NE 10$	SR.W	D2,#1	ADD.W	D2,#2	SL.W	D2,#1	NEG.W	D2	LOAD.W	D2,(A2)+(D2.W)	POP.L	A2	RET	.W	-1TAVITA:	.W	1	.W	2	.W	4	.W	5	.W	6	.W	8	.W	10	.W	12	.W	16	.W	24	.W	32	.W	50	.W	64	.W	100	.W	-1	.W	-1TAVITM:	.W	200	.W	180	.W	160	.W	140	.W	120	.W	100	.W	80	.W	60	.W	50	.W	40	.W	30	.W	25	.W	20	.W	15	.W	12	.W	10	.W	8	.W	6	.W	4	.W	3	.W	2	.W	1	.W	0	.W	-1TMENU_MOVE:	.ASCIZ	"     "	.ASCIZ	" Fin "		;     ;     ;     ;	.ASCIZ	" Images/seconde  "	.ASCIZ	"  -           +  "		;     ;     ;     ;	.ASCIZ	"    Mouvement    "	.ASCIZ	"  -           +  "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" Marche arrire  "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" Arrt sur image "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" Image suivante  "		;     ;     ;     ;	.EVEN	.END