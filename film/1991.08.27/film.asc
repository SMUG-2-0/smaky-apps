	.TITLE	FILM.ASC;	--------------------------------------;		(C) 1987 - Daniel Roux;	--------------------------------------	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES;----------------------------------------------------------------------------------------- PROVLIB?DRELLIPSE	=	LIB_BASE+129	; dessine une ellipseLIB?CALCPELLI	=	LIB_BASE+134	; calcule un point sur une ellipse;----------------------------------------------------------------------------------------- PROVFILMREV	=	1		; rvisionFILMVERS=	2		; version;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 1.2	27.05.88	case (FIN) dans la dbox principale;			pendant calculs transitions --> arrt possible; 1.1	18.05.88	200 --> 500 pas pour le script;			ngatif; 1.0	16.05.88	interraction avec images/effets/script; 0.0	11.12.87	premire version sans interraction	.REV	FILMREV,FILMVERS	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------MAXPRG	=	500		; nb max de pas pour le scriptMAXIMA	=	100		; nb max d'images possiblesMAXIIMA	=	100		; nb max d'images intermdiairesLBUFILE	=	64KEYDBOX	=	H'7E00		; "touche" spciale pour dbox; Oprations; ----------BEFFET	=	7BTRANS	=	6BMSS	=	5; Fanions; -------BINSERT	=	0BREPLACE=	1BAFIMA	=	2BNEGATIF=	3BDPLIMD	=	0BDPLIMT	=	1BDPLTRA	=	2BIOFILM	=	15BIOIMAGE=	14; En-tte d'un fichier .FILM; --------------------------	.LOC	0OHFTYP:	.BLKB	2		; type (-1 si nouveau)OHFVITA:.BLKB	2		; vitesse animationOHFVITM:.BLKB	2		; vitesse mouvement	.BLKB	10OHFOBJ:	.BLKB	2		; mouvement: objetOHFP1:	.BLKB	4		; mouvement: P1OHFP2:	.BLKB	4		; mouvement: P2OHFDPL:	.BLKB	1		; mode de dplacementLHF	=	256; En-tte d'un fichier .IMAGE; ---------------------------	.LOC	0OIMTYP:	.BLKB	1		; H'01 = indique type imageOIMCOD:	.BLKB	1		; H'00 = indique pas de codageOIMBIP:	.BLKB	1		; H'01 = 1 bit par pointOIMDIR:	.BLKB	1		; H'02 = coord. X-Y comme cranOIMDLX:	.BLKB	2		; largeur image en pointsOIMDLY:	.BLKB	2		; hauteur image en pointsOIMNBB:	.BLKB	4		; nb de byte pour l'image	.BLKB	20		; rserveLGHIMA:	.LOC	0OHVPI:	.BLKB	4		; ^bitmap de l'imageOHVNO:	.BLKB	4		; numro de l'imageOHVFL:	.BLKB	1		; flags BHVINV	=  0			;  image inverse	.BLKB	7		; rserveLHV:; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHSTRETCH:.BLKB 2		; canal module STRETCHOSTRETCH:.BLKB	ST_LGTRECT	; variables pour le module STRETCHOPLCOM:	.BLKB	4		; ^ligne de commandeOMACHINE:.BLKB	1		; type de la machine (SMAKY8/SMAKY100)	.EVENOPDDIS:	.BLKB	4		; ^descripteur de la fentreOITL:	.BLKB	2		; interligne standardOBUDIS:	.BLKB	200		; buffer write-displayOLINE:	.BLKB	4		; adresse de GRA_LINEOINV:	.BLKB	4		; adresse de GRA_INVOCLEAR:	.BLKB	4		; adresse de GRA_CLEAROSET:	.BLKB	4		; adresse de GRA_SETOELLI:	.BLKB	4		; adresse de GRA_ELLIPSEOCIRC:	.BLKB	4		; adresse de GRA_CIRCLEORAST:	.BLKB	4		; adresse de GRA_RASTEROFANION:.BLKB	4		; fanionsODPL:	.BLKB	1		; mode de dplacement	.EVENOSLIMA:	.BLKB	LSLVAR		; scroll-liste des imagesOSLEFF:	.BLKB	LSLVAR		; scroll-liste des effetsOSLPRG:	.BLKB	LSLVAR		; scroll-liste du scriptOSIPTM:	.BLKB	4		; ^zone mmoire pour stretch/rasterOSIPOS:	.BLKB	4		; image: positionOSIDIM:	.BLKB	4		; image: dimensionsOSEPOS:	.BLKB	4		; effet: positionOSEDIM:	.BLKB	4		; effet: dimensionsONBIMA:	.BLKB	2		; nb d'imagesOTAIMA:	.BLKB	4*MAXIMA	; ^s aux zimagesOTIIMA:	.BLKB	4*MAXIIMA	; ^s aux zimages zintermdiairesONBPRG:	.BLKB	2		; nb de pas de programme \   dans cetOTAPRG:	.BLKB	MAXPRG		; programme              /   ordre !OBUNAM:	.BLKB	LBUFILE		; nom du filmOBUREP:	.BLKB	LBUFILE		; nom des rpertoiresOBUCRI:	.BLKB	LBUFILE		; nom du critreOBUTMP:	.BLKB	LBUFILE		; nom temporaireOHF:	.BLKB	LHF		; en-tte .FILMOMVOBJ:	.BLKB	2		; mouvement: objetOMVP1:	.BLKB	4		; mouvement: P1OMVP2:	.BLKB	4		; mouvement: P2OLSTPI:	.BLKB	4		; ^dernire image afficheOLSTPO:	.BLKB	4		; dernire positionOVITA:	.BLKB	2		; vitesse animationOVITM:	.BLKB	2		; vitesse mouvementOINC:	.BLKB	2		; incrment (+/- 1)OSTOP:	.BLKB	2		; arrt sur imageOMSS:	.BLKB	1		; start/stop mouvement	.EVENOCLRP1:	.BLKB	4		; P1(y;x) o effacerOCLRP2:	.BLKB	4		; P2(y;x) o effacerOTRNBI:	.BLKB	2		; transitions: nb d'images  calculerOTRCNT:	.BLKB	1		; transitions: compte/calcul	.EVENOWDCDB:	.BLKB	4		; wait: canal dbox waitOWDASC:	.BLKB	LSCVAR		; wait: ascenseurOWDDIV:	.BLKB	2		; wait: facteur de divisionOWDCSK:	.BLKB	4		; wait: canal soft-keysLGVAR:	.LOC	0; Programme; ---------START:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LOAD.L	(A6)+OPLCOM,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT1	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT1	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT1	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMSTRETCH	LOAD.W	D3,#ST_FIRST	LIB_	OPEN	JUMP,NE ERFAT1	LOAD.W	(A6)+OCHSTRETCH,D1	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT1	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	JUMP,NE ERFAT1	LOAD.L	(A6)+OLINE,A3	LOAD.W	D3,#GRA_INV	LIB_	GETAD	JUMP,NE ERFAT1	LOAD.L	(A6)+OINV,A3	LOAD.W	D3,#GRA_CLEAR	LIB_	GETAD	JUMP,NE ERFAT1	LOAD.L	(A6)+OCLEAR,A3	LOAD.W	D3,#GRA_SET	LIB_	GETAD	JUMP,NE ERFAT1	LOAD.L	(A6)+OSET,A3	LOAD.W	D3,#GRA_ELLIPSE	LIB_	GETAD	JUMP,NE ERFAT1	LOAD.L	(A6)+OELLI,A3	LOAD.W	D3,#GRA_CIRCLE	LIB_	GETAD	JUMP,NE ERFAT1	LOAD.L	(A6)+OCIRC,A3	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE ERFAT1	LOAD.L	(A6)+ORAST,A3	LOAD.L	(A6)+OFANION,#2^BINSERT!2^BAFIMA	TEST.B	(A0)+ODFMOD:#BFBLANC	JUMP,BS 40$	TSET.B	(A6)+OFANION+3:#BNEGATIF40$:	LOAD.L	A2,#R16"TAVITA	CALL	VITMOYE	LOAD.W	(A6)+OVITA,D2	LOAD.L	A2,#R16"TAVITM	CALL	VITMOYE	LOAD.W	(A6)+OVITM,D2	LOAD.L	A3,(A6)+OPLCOM	LIB	?SKPNAM	JUMP,NE DOMAIN	LOAD.L	A4,#(A6)+OBUTMP50$:	LOAD.B	D3,(A3+)	JUMP,EQ 52$	COMP.B	D3,#SPACE	JUMP,EQ 52$	COMP.B	D3,#CR	JUMP,EQ 52$	COMP.B	D3,#'/	JUMP,EQ 52$	LOAD.B	(A4+),D3	JUMP	50$52$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUTMP	LOAD.L	A4,#R16"EXT$	LOAD.W	D3,#1	LIB	?ADDEXT	CALL	OPFILM		; essaye de lire le fichier .FILM	JUMP,NE	DOMAIN	JUMP	DOMOVEEXT$:	.ASCIZ	".FILM"	.EVENERFAT1:	LOAD.B	D3,#EOP	LIB	?AFCAR	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSTRETCH	LIB_	CLOSE	LIB	?CLOLIB	FOS	?STOP	.INS	FILMMOVE.ASI	.INS	FILMDRAW.ASI	.INS	FILMBASE.ASI	.INS	FILMDBOX.ASI	.INS	FILMIO.ASI	.INS	FILMTRANS.ASI	.INS	FILMMISC.ASI; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMSTRETCH:	.ASCIZ	"STRETCH"	.EVEN	.END	START