  100 For RANG=0 To 9  110 Let I=RANG*9*Pi/180   120 Eop  130 Print I*180/Pi  140 -- Typnt(3)  150 Let AX=10*Pi/180  160 Let AY=45*Pi/180  170 Let AZ=0*Pi/180  180 FX=2000 : FY=2000 : FZ=1000  190 Coor(500,400)  200 -- Gosub Label_CUBE3V(-100,-100,-100,100,100,100,40)  210 -- Gosub Label_CUBE3OP(-50,-50,-50,50,50,50)  220 Let C=50  230 Gosub Label_CUBE3TC(C*3,C*1,C*1,I)  240 Gosub Label_CUBE3TC(C*1,C*3,C*1,I)  250 Gosub Label_CUBE3TC(C*1,C*1,C*3,I)  260 Copy Image("FILM"+Num$(RANG),280,180,280+430,180+430)  270 Next RANG  280 End  290 Label_CUBE3TC(DX,DY,DZ,A)  300 Gosub Label_TOURNE(-DX,-DY,A)  310 Let T1X = TTX  320 Let T1Y = TTY  330 Gosub Label_TOURNE(+DX,-DY,A)  340 Let T2X = TTX  350 Let T2Y = TTY  360 Gosub Label_TOURNE(+DX,+DY,A)  370 Let T3X = TTX  380 Let T3Y = TTY  390 Gosub Label_TOURNE(-DX,+DY,A)  400 Let T4X = TTX  410 Let T4Y = TTY  420 Gosub Label_CUBE3T(T1X,T1Y,T2X,T2Y,T3X,T3Y,T4X,T4Y,-DZ,+DZ)  430 Return  440 Label_TOURNE(TX,TY,A)  450 Let TTX = TX*Cos(A)-TY*Sin(A)  460 Let TTY = TX*Sin(A)+TY*Cos(A)  470 Return  480 --  490 Label_CUBE3T(T1X,T1Y,T2X,T2Y,T3X,T3Y,T4X,T4Y,T1Z,T2Z)  495 Let ALIM=50*Pi/180  500 If A>ALIM Then Gosub Label_LINE3(T1X,T1Y,T1Z,T2X,T2Y,T1Z)  510 Gosub Label_LINE3(T2X,T2Y,T1Z,T3X,T3Y,T1Z)  520 If A<ALIM Then Gosub Label_LINE3(T3X,T3Y,T1Z,T4X,T4Y,T1Z)  530 -- Gosub Label_LINE3(T4X,T4Y,T1Z,T1X,T1Y,T1Z)  540 Gosub Label_LINE3(T1X,T1Y,T2Z,T2X,T2Y,T2Z)  550 Gosub Label_LINE3(T2X,T2Y,T2Z,T3X,T3Y,T2Z)  560 Gosub Label_LINE3(T3X,T3Y,T2Z,T4X,T4Y,T2Z)  570 Gosub Label_LINE3(T4X,T4Y,T2Z,T1X,T1Y,T2Z)  580 If A>ALIM Then Gosub Label_LINE3(T1X,T1Y,T1Z,T1X,T1Y,T2Z)  590 Gosub Label_LINE3(T2X,T2Y,T1Z,T2X,T2Y,T2Z)  600 Gosub Label_LINE3(T3X,T3Y,T1Z,T3X,T3Y,T2Z)  610 If A<ALIM Then Gosub Label_LINE3(T4X,T4Y,T1Z,T4X,T4Y,T2Z)  620 Return  630 Label_CUBE3V(VX1,VY1,VZ1,VX2,VY2,VZ2,ARR)  640 Gosub Label_CUBE3OP(VX1,VY1,VZ1,VX2,VY1+ARR,VZ1+ARR)  650 Gosub Label_CUBE3OP(VX2-ARR,VY1,VZ1,VX2,VY2,VZ1+ARR)  660 Gosub Label_CUBE3OP(VX1,VY2-ARR,VZ1,VX2,VY2,VZ1+ARR)  670 Gosub Label_CUBE3OP(VX1,VY1,VZ1,VX1+ARR,VY2,VZ1+ARR)  680 Gosub Label_CUBE3OP(VX1,VY1,VZ2-ARR,VX2,VY1+ARR,VZ2)  690 Gosub Label_CUBE3OP(VX2-ARR,VY1,VZ2-ARR,VX2,VY2,VZ2)  700 Gosub Label_CUBE3OP(VX1,VY2-ARR,VZ2-ARR,VX2,VY2,VZ2)  710 Gosub Label_CUBE3OP(VX1,VY1,VZ2-ARR,VX1+ARR,VY2,VZ2)  720 Gosub Label_CUBE3OP(VX1,VY1,VZ1,VX1+ARR,VY1+ARR,VZ2)  730 Gosub Label_CUBE3OP(VX2-ARR,VY1,VZ1,VX2,VY1+ARR,VZ2)  740 Gosub Label_CUBE3OP(VX2-ARR,VY2-ARR,VZ1,VX2,VY2,VZ2)  750 Gosub Label_CUBE3OP(VX1,VY2-ARR,VZ1,VX1+ARR,VY2,VZ2)  760 Return  770 Label_CUBE3OP(CX1,CY1,CZ1,CX2,CY2,CZ2)  780 -- Gosub Label_LINE3(CX1,CY1,CZ1,CX2,CY1,CZ1) -- FOND  790 Gosub Label_LINE3(CX2,CY1,CZ1,CX2,CY2,CZ1)  800 Gosub Label_LINE3(CX2,CY2,CZ1,CX1,CY2,CZ1)  810 -- Gosub Label_LINE3(CX1,CY2,CZ1,CX1,CY1,CZ1) -- FOND  820 Gosub Label_LINE3(CX1,CY1,CZ2,CX2,CY1,CZ2)  830 Gosub Label_LINE3(CX2,CY1,CZ2,CX2,CY2,CZ2)  840 Gosub Label_LINE3(CX2,CY2,CZ2,CX1,CY2,CZ2)  850 Gosub Label_LINE3(CX1,CY2,CZ2,CX1,CY1,CZ2)  860 -- Gosub Label_LINE3(CX1,CY1,CZ1,CX1,CY1,CZ2) -- FOND  870 Gosub Label_LINE3(CX2,CY1,CZ1,CX2,CY1,CZ2)  880 Gosub Label_LINE3(CX1,CY2,CZ1,CX1,CY2,CZ2)  890 Gosub Label_LINE3(CX2,CY2,CZ1,CX2,CY2,CZ2)  900 Return  910 --  920 Label_LINE3(X1,Y1,Z1,X2,Y2,Z2)  930 Gosub Label_CONV32(X1,Y1,Z1)  940 Skipto(PX,PY)  950 Gosub Label_CONV32(X2,Y2,Z2)  960 Moveto(PX,PY)  970 Return  980 --  990 Label_CONV32(X,Y,Z) 1000 Let XX=X*(1+Y/FY)*(1+Z/FZ)  1010 Let YY=Y*(1+X/FX)*(1+Z/FZ)  1020 Let ZZ=Z*(1+X/FX)*(1+Y/FY)  1030 Let PX=XX*Cos(AX)-YY*Sin(AY) 1040 Let PY=-XX*Sin(AX)-YY*Cos(AY)+ZZ 1050 Return