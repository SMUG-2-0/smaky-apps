	.SBTTL	FILMDBOX;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre (prend).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXBEGIN	; prpare pour afficher une dbox	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_EDITI	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"01$	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXTM	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXEND		; remet en tat aprs l'affichage d'une dbox90$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	".FILM"	.ASCIZ	".IMAGE"	.EVENTDBOX_EDITI:	.B	LDBOX_EDITI	.B	ODBLCIRCLE,BIOFILM!2^7,0,1	.ASCIZ	" fichier  *.FILM"	.B	ODBCR	.B	ODBLCIRCLE,BIOIMAGE!2^7,0,1	.ASCIZ	" fichiers *nn.IMAGE (nn=numro)"	.B	ODBCRLDBOX_EDITI	=	.-TDBOX_EDITI-1	.EVEN;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie (sauve).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F0/F1/F4);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITO:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXBEGIN	; prpare pour afficher une dbox	LOAD.L	A4,#R16"01$	LOAD.W	D3,#1		; D3 <-- force	LIB	?ADDEXT	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_EDITO	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"01$	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXEND		; remet en tat aprs l'affichage d'une dbox90$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET01$:	.ASCIZ	".FILM"	.EVENTDBOX_EDITO:	.B	LDBOX_EDITO	.B	ODBSQUARE,0	.ASCIZ	" sauve les images de transition"	.B	ODBCRLDBOX_EDITO	=	.-TDBOX_EDITO-1	.EVEN;-----------\\; DBOXQUITTE >;===========/; Demande si l'on veut quitter DESSIN.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXQUITTE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXBEGIN	; prpare pour afficher une dbox	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXEND		; remet en tat aprs l'affichage d'une dbox90$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXDRAW >;=========/; Choix de l'objet pour le mouvement.; in	D4.W	objet; out	D4.W	objet;	D3.W	F0/F1; mod	D3.L, D4.L, D7.WDBOXDRAW:	PUSHM.L	D1,D2,D5,A1..A4	LOAD.W	D3,D4	CLR.L	D4	LOAD.B	D4,(A6)+ODPL	SWAP.W	D4	LOAD.B	D4,#B'1000000010$:	RL.B	D4,#1	DEC.W	D3	JUMP,NC 10$	LOAD.L	A2,#R16"TDBOX_DRAW	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_DRAW	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP,EQ 60$	COMP.W	D3,#F0	JUMP,EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$60$:	SWAP.W	D4	LOAD.B	(A6)+ODPL,D4	SWAP.W	D4	LOAD.B	D2,D4	LOAD.W	D4,#-162$:	INC.W	D4	RR.B	D2,#1	JUMP,CC 62$80$:	DBOX_	CLOSE		; ferme la DBOX90$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_DRAW:	.W	10$-TDBOX_DRAW	.W	20$-TDBOX_DRAW	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Le dessin d'une droite ou d'une ellipse permet"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"de dfinir un dplacement de l'animation dans"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"l'cran, pour simuler un mouvement."	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,0	.ASCIZ	" immobile"	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" droite  (simple course)"	.B	ODBCR	.B	ODBLCIRCLE,2	.ASCIZ	" droite  (aller et retour)"	.B	ODBCR	.B	ODBLCIRCLE,3	.ASCIZ	" ellipse (sens des aiguilles d'une montre)"	.B	ODBCR	.B	ODBLCIRCLE,4	.ASCIZ	" ellipse (sens inverse)"	.B	ODBCR,ODBCR	.B	ODBSQUARE,16+BDPLIMD	.ASCIZ	" immobile pendant les dlais"	.B	ODBCR	.B	ODBSQUARE,16+BDPLIMT	.ASCIZ	" immobile pendant les transitions"	.B	ODBCR	.B	ODBSQUARE,16+BDPLTRA	.ASCIZ	" laisse une trane"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" DESSINE "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Dessine"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DRAW:	.W	F1,F2,F3,0		DOKF1-TKEY_DRAW	.W	F0,F13,F14,F15,0	DOKF0-TKEY_DRAW	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DRAW	.W	0;----------\\; DBOXGEBIN >;==========/; Prpare pour afficher une dbox.; in	-; out	-; mod	-DBOXBEGIN:	PUSH.W	D7	LIB	?AFTIM	.B	AFSCMO		; remet la souris	.B	0	.EVEN	CALL	NORMMOUSE	; remet la flche	CALL	ILFULL		; remet le plein-interligne	POP.W	D7	RET;--------\\; DBOXEND >;========/; Remet en tat aprs l'affichage d'une dbox.; in	-; out	-; mod	-DBOXEND:	PUSH.W	D7	CALL	ILDEMI		; met le demi-interligne	CALL	AFBMENU		; remet les soft-keys	POP.W	D7	RET; Gestion de la dbox d'attente; ----------------------------;---------\\; WAITDBOX >;=========/; Met la dbox d'attente.; in	-; out	D7.W	erreur; mod	D7.WWAITDBOX:	PUSHM.L	D2..D5,A2	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LIB	?PUSHMENU	; sauve les soft-keys	LOAD.L	(A6)+OWDCSK,D5	TEST.W	D7	JUMP',NE 90$	LOAD.L	A2,#R16"TDBOX_WAIT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE 80$	LOAD.L	(A6)+OWDCDB,D5	CLR.W	(A6)+OWDASC+OSCHTV ; ascenseur pas dessin	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	D5,(A6)+OWDCSK	LIB	?POPMENU	; refait les soft-keys	POP.W	D790$:	POPM.L	D2..D5,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; AFFNDBOX >;=========/; Affiche le nb de blocs restant dans la dbox d'attente.; in	D0.W	nb de blocs restant; out	-; mod	D7.WAFFNDBOX:	PUSHM.L	D2..D5,A5	TEST.L	(A6)+OWDCDB	; dbox existe ?	JUMP,EQ 90$		; non => 90$	LOAD.L	A5,#(A6)+OWDASC	; A5 <-- ^variables de l'ascenseur	TEST.W	(A5)+OSCHTV	; ascenseur dj dessin ?	JUMP,NE 50$		; oui => 50$				; non => 	LOAD.L	D5,(A6)+OWDCDB	; D5 <-- canal dbox	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	LOAD.W	(A5)+OSCDEBL,D3	SWAP.W	D3	LOAD.W	(A5)+OSCDEBO,D3	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,D3	SUB.W	D4,D3	LOAD.W	(A5)+OSCHTR,D4	LOAD.W	(A5)+OSCHTV,D0	SET.B	(A5)+OSCHOR	SCROLL_	DRAW		; dessine l'ascenseur	LOAD.W	(A6)+OWDDIV,#2	COMP.W	D0,D4	JUMP',LS 50$	PUSH.L	D0	AND.L	D0,#H'FFFF	DIV.WU	D0,D4	SL.W	D0,#2	LOAD.W	(A6)+OWDDIV,D0	POP.L	D050$:	CLR.L	D2	LOAD.W	D2,D0	DIV.WU	D2,(A6)+OWDDIV	SWAP.W	D2	TEST.W	D2	JUMP',NE 90$	LOAD.W	D3,(A5)+OSCHTV	SUB.W	D3,D0	LOAD.W	(A5)+OSCPOSV,D3	SCROLL_	UPDATE		; dplace l'ascenseur90$:	POPM.L	D2..D5,A5	RET;---------\\; NORMDBOX >;=========/; Enlve la dbox d'attente.; in	-; out	-; mod	-NORMDBOX:	PUSHM.L	D5,D7	LOAD.L	D5,(A6)+OWDCDB	JUMP',EQ 90$	DBOX_	CLOSE		; ferme la DBOX	LOAD.L	D5,(A6)+OWDCSK	LIB	?POPMENU	; refait les soft-keys	CLR.L	(A6)+OWDCDB90$:	POPM.L	D5,D7	RETTDBOX_WAIT:	.W	10$-TDBOX_WAIT	.W	20$-TDBOX_WAIT	.W	0,010$:	.B	ODBCR,ODBCR	.B	ODBLABEL,1	.B	ODBTEXT	.ASCIZ	""	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"       Attendez un instant ...      "	.B	ODBCR,ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	"Arrt"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTDBOX_IO:	.ASCIZ	"FILM"		; nom du logiciel	.ASCIZ	"Mfilm"		; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN	.END