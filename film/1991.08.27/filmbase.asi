	.SBTTL	FILMBASEPOSIMAX	=	160POSIMAY	=	44DIMIMAX	=	136DIMIMAY	=	112POSEFFX	=	160POSEFFY	=	172DIMEFFX	=	136DIMEFFY	=	112POSPRGX	=	336POSPRGY	=	44DIMPRGX	=	136DIMPRGY	=	228DOMAIN:	CLR.W	D7		; D7 <-- okDOERROR:	LOAD.W	D0,D7		; D0 <-- erreur ventuelle	LIB	?AFTIM	.B	EOP		; efface tout	.B	AFSCMO		; remet la souris	.B	0	.EVEN	CALL	ILDEMI		; met le demi-interligne	LOAD.L	D3,#H'11441144	LOAD.L	D4,D3	LIB	?DRMDEF	LIB	?GETDIM	CLR.L	D3	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise toute la fentre	LOAD.L	A2,#R16"TDBOX_MAIN	LOAD.W	D2,#2^BDBMAX!2^BDBCAS	LOAD.L	D4,(A6)+OFANION	; D4 <-- fanions	DBOX_	OPEN	JUMP,NE ERFAT1	LOAD.L	D2,D4	CALL	DBOXTITLE	CALL	SLIMADRAW	CALL	SLEFFDRAW	CALL	SLPRGDRAW	CALL	SLIMAUPDATE	CALL	SLEFFUPDATE	CALL	SLPRGUPDATE	CALL	SLIMASHOW	; montre l'image	CALL	SLEFFSHOW	; montre l'effet	CALL	DBOXGREY	; grise qq bricoles	CALL	DBOXINFO	; affiche qq infos	LOAD.W	D7,D0		; y'a-t-il une erreur  afficher ?	JUMP,NE ERROR$		; oui => ERROR$GREY$:	CALL	DBOXGREY	; grise qq bricoles	CALL	DBOXINFO	; affiche qq infosLOOP$:	CALL	NORMMOUSE	; enlve le sablier	LOAD.L	D4,D2	DBOX_	EDIT		; attend action ...	LOAD.L	D2,D4	LOAD.L	A1,#R16"TKEY_MAIN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	JUMP,EQ	LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ	CLIC$	COMP.W	D3,#CLEAR	JUMP,EQ SUPPRIME$	COMP.W	D3,#F0	JUMP,EQ QUITTE$	COMP.W	D3,#F1	JUMP,EQ PREND$	COMP.W	D3,#F3	JUMP,EQ SAUVE$	COMP.W	D3,#F5	JUMP,EQ DRAW$	COMP.W	D3,#F8	JUMP,EQ MOVE$	COMP.W	D3,#F14	JUMP,EQ EFFACE$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ERROR$:	TEST.W	D7	JUMP,EQ LOOP$	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP$	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	CALL	DBOXBEGIN	; prpare pour afficher une dbox	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	POP.L	D2	CALL	DBOXEND		; remet en tat aprs l'affichage d'une dbox	JUMP	GREY$KEYDBOX$:	COMP.B	D3,#BREPLACE	JUMP,LS KEYMODE$	COMP.B	D3,#BAFIMA	JUMP,EQ KEYAFIMA$	JUMP	LOOP$KEYMODE$:	TCLR.L	D2:#BINSERT	TCLR.L	D2:#BREPLACE	TSET.L	D2:D3	JUMP	LOOP$KEYAFIMA$:	CALL	SLIMASHOW	; montre l'image	JUMP	LOOP$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	CALL	SLIMAMOVE	JUMP,EQ IMAGE$	COMP.W	D7,#1		; dans l'ascenseur ?	JUMP,EQ LOOP$	CALL	SLEFFMOVE	JUMP,EQ EFFET$	COMP.W	D7,#1		; dans l'ascenseur ?	JUMP,EQ LOOP$	CALL	SLPRGMOVE	JUMP,EQ GREY$	COMP.W	D7,#1		; dans l'ascenseur ?	JUMP,EQ LOOP$	JUMP	BIP$IMAGE$:	LOAD.W	D3,(A6)+OSLIMA+OSLCYS	DEC.W	D3	JUMP,NC	INSERT$	LOAD.W	D1,(A6)+OSLIMA+OSLCYN	DEC.W	D1	CLR.W	D3TOUT$:	LOAD.W	D4,(A6)+OSLPRG+OSLCYS	CALL	PRGINSERT	INC.W	(A6)+OSLPRG+OSLCYS	INC.W	D3	DEC.W	D1	JUMP,NE TOUT$	CALL	SLPRGUPDATE	JUMP	GREY$EFFET$:	LOAD.W	D3,(A6)+OSLEFF+OSLCYS	COMP.W	D3,#NDELAI	JUMP,HS TRANS$	TSET.L	D3:#BEFFET	JUMP	INSERT$TRANS$:	SUB.W	D3,#NDELAI	COMP.W	D3,#NTRANS	JUMP,HS MSS$	TSET.L	D3:#BEFFET	TSET.L	D3:#BTRANS	JUMP	INSERT$MSS$:	SUB.W	D3,#NTRANS	TSET.L	D3:#BEFFET	TSET.L	D3:#BMSS	JUMP	INSERT$INSERT$:	LOAD.W	D4,(A6)+OSLPRG+OSLCYS	TEST.L	D2:#BINSERT	JUMP,BC REMPLACE$INSERT2$:	CALL	PRGINSERT	JUMP,NE BIP$	INC.W	(A6)+OSLPRG+OSLCYS	CALL	SLPRGUPDATE	JUMP	GREY$REMPLACE$:	COMP.W	D4,(A6)+ONBPRG	JUMP,EQ INSERT2$	LOAD.L	A3,#(A6)+OTAPRG	LOAD.B	(A3)+(D4.W),D3	CALL	SLPRGUPDATE	JUMP	GREY$SUPPRIME$:	LOAD.W	D4,(A6)+OSLPRG+OSLCYS	CALL	PRGDELETE	JUMP,NE BIP$	CALL	SLPRGUPDATE	JUMP	GREY$EFFACE$:	CLR.W	(A6)+ONBPRG	CLR.W	(A6)+OSLPRG+OSLCYS	CALL	SLPRGUPDATE	JUMP	GREY$PREND$:	LOAD.L	A3,#(A6)+OBUNAM	CLR.B	(A3)	LOAD.L	D4,#2^BIOFILM	; D4 <-- fanions	CALL	DBOXEDITI	; demande le nom ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	TEST.L	D4:#BIOIMAGE	JUMP,BS PRENDI$	CLR.W	(A6)+OSLIMA+OSLCYS	CLR.W	(A6)+OSLPRG+OSLCYS	CLR.W	(A6)+ONBPRG	; plus de programme	LOAD.L	(A6)+OFANION,D2	CALL	OPFILM		; lit le film	LOAD.L	D2,(A6)+OFANION	PUSH.W	D7	CALL	SLIMAUPDATE	CALL	SLPRGUPDATE	CALL	SLIMASHOW	; montre l'image	POP.W	D7	JUMP,NE ERROR$	JUMP	GREY$PRENDI$:	CLR.W	(A6)+OSLIMA+OSLCYS	CLR.W	(A6)+OSLPRG+OSLCYS	CLR.W	(A6)+ONBPRG	; plus de programme	CALL	OPIMAGES	; lit les images	PUSH.W	D7	CALL	SLIMAUPDATE	CALL	SLPRGUPDATE	CALL	SLIMASHOW	; montre l'image	POP.W	D7	JUMP,NE ERROR$	JUMP	GREY$SAUVE$:	LOAD.L	(A6)+OFANION,D2	CALL	WRFILM		; crit le film	JUMP,NE ERROR$	JUMP	LOOP$QUITTE$:	CALL	DBOXQUITTE	; demande s'il faut quitter ...	COMP.W	D3,#F1	JUMP,NE LOOP$	DBOX_	CLOSE	CALL	ILFULL		; remet le plein-interligne	JUMP	ERFAT1DRAW$:	DBOX_	CLOSE	CALL	ILFULL		; remet le plein-interligne	JUMP	DODRAWMOVE$:	TEST.W	(A6)+ONBPRG	JUMP,EQ BIP$	LOAD.L	(A6)+OFANION,D2	DBOX_	CLOSE	CALL	ILFULL		; remet le plein-interligne	JUMP	DOMOVE;----------\\; DBOXTITLE >;----------/; Affiche le titre dans la dbox.; in	-; out	-; mod	D7.WDBOXTITLE:	PUSHM.L	D2..D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.W	D4,(A0)+ODFCY	SL.W	D4,#1	SWAP.W	D4	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	AFINV	.ASCII	"  FILM "	.B	FILMREV+'0,'.	.IF	FILMVERS<10	.B	FILMVERS+'0	.ELSE	.B	(FILMVERS/10)+'0,(FILMVERS-((FILMVERS/10)*10))+'0	.ENDIF	.ASCII	"  "	.B	AFDIR	.B	0	.EVEN	POPM.L	D2..D4	RET;---------\\; DBOXINFO >;---------/; Affiche qq info dans la dbox.; in	-; out	-; mod	D7.WDBOXINFO:	PUSHM.L	D2..D4,A2..A4	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#20	LIB	?SETCURS	LIB	?AFTIM	.B	TRUNC	.B	AFINV	.B	0	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+ONBIMA	JUMP,EQ 80$	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LOAD.L	A3,#(A6)+OTIIMA	LOAD.W	D3,#MAXIIMA-1	CLR.L	D410$:	TEST.L	(A3+)	JUMP',EQ 12$	INC.W	D412$:	DECJ.W,NMO D3,10$	TEST.W	D4	JUMP,EQ 20$	LOAD.B	D3,#'+	LIB	?AFCAR	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC20$:	LIB	?AFTIM	.ASCIZ	" images occupant "	.EVEN	CLR.L	D4	LOAD.L	A3,#(A6)+OTAIMA	LOAD.W	D3,(A6)+ONBIMA30$:	LOAD.L	A2,(A3+)	CALL	DBOXINFOTI	; D4 <-- taille	DEC.W	D3	JUMP,NE 30$	LOAD.L	A3,#(A6)+OTIIMA	LOAD.W	D3,#MAXIIMA-134$:	TEST.L	(A3+)	JUMP',EQ 36$	LOAD.L	A2,(A3)-4	CALL	DBOXINFOTI	; D4 <-- taille36$:	DECJ.W,NMO D3,34$	SR.L	D4,#8	SR.L	D4,#2		; D4 <-- /1024	INC.L	D4	LOAD.W	D3,#6	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" Koctets"	.EVEN80$:	LIB	?AFTIM	.B	MSPACE,100	.B	AFDIR	.B	0	.EVEN	POPM.L	D2..D4,A2..A4	RET;-----------\\; DBOXINFOTI >;-----------/; ; in	A2.L	^image;	D4.L	taille; out	D4.L	taille; mod	D4.L, D7.WDBOXINFOTI:	PUSHM.L	D2,A2	LOAD.W	D2,(A2)+LHV+OIMDLX	ADD.W	D2,#8-1	SR.W	D2,#3	MUL.WU	D2,(A2)+LHV+OIMDLY	ADD.L	D2,#LHV+LGHIMA+IMLBUF	ADD.L	D4,D2	POPM.L	D2,A2	RET;---------\\; DBOXGREY >;---------/; Grise ou dgrise, c'est selon ...; in	-; out	-; mod	D7.WDBOXGREY:	PUSHM.L	D2..D4	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCFULL	LOAD.W	D4,(A6)+OSLPRG+OSLCYS	COMP.W	D4,(A6)+ONBPRG	JUMP',NE 20$	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCGREY20$:	DBOX_	GETCO	LOAD.W	D2,#11!2^BDBGCLABEL!2^BDBGCFULL	TEST.W	(A6)+ONBPRG	JUMP',NE 30$	LOAD.W	D2,#11!2^BDBGCLABEL!2^BDBGCGREY30$:	DBOX_	GETCO	POPM.L	D2..D4	RET;----------\\; PRGINSERT >;==========/; Ajoute une opration.; in	D4.W	rang;	D3.B	opration; out	D7.W	erreur; mod	D7.WPRGINSERT:	PUSHM.L	D2..D4,A3	LOAD.W	D7,#2	COMP.W	(A6)+ONBPRG,#MAXPRG	JUMP,HS 90$	LOAD.L	A3,#(A6)+OTAPRG	LOAD.W	D2,(A6)+ONBPRG	ADD.W	A3,D2	SUB.W	D2,D4	JUMP',EQ 50$	DEC.W	D220$:	LOAD.B	(A3),(A3)-1	DEC.L	A3	DECJ.W,NMO D2,20$50$:	LOAD.B	(A3),D3	INC.W	(A6)+ONBPRG	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; PRGDELETE >;==========/; Supprime une opration.; in	D4.W	rang; out	D7.W	erreur; mod	D7.WPRGDELETE:	PUSHM.L	D2..D4,A3	LOAD.W	D7,#2	TEST.W	(A6)+ONBPRG	JUMP,EQ 90$	LOAD.L	A3,#(A6)+OTAPRG	ADD.W	A3,D4	LOAD.W	D2,(A6)+ONBPRG	SUB.W	D2,D4	JUMP',EQ 90$	DEC.W	D2	JUMP',EQ 50$	DEC.W	D220$:	LOAD.B	(A3),(A3)+1	INC.L	A3	DECJ.W,NMO D2,20$50$:	DEC.W	(A6)+ONBPRG	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; SLIMADRAW >;==========/; Dessine la scroll-liste des images.; in	-; out	-; mod	D7.WSLIMADRAW:	PUSHM.L	D2..D4,A3,A5	LOAD.L	A5,#(A6)+OSLIMA	LOAD.L	(A5)+OSLPOS,#H'10000*POSIMAY+POSIMAX	LOAD.L	(A5)+OSLDIM,#H'10000*DIMIMAY+DIMIMAX	SCROLL_	LDRAW	LOAD.L	D3,(A5)+OSLPOS	ADD.W	D3,#LGSCROLL	SWAP.W	D3	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#2	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A3,#R16"00$	LIB	?AFTEXT	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	CALL	SLFLECHE;	LOAD.L	D3,(A5)+OSLPOS;	LOAD.L	D4,(A5)+OSLDIM	SUB.W	D3,D4	SUB.W	D3,#8	LOAD.W	D2,#SETDOT	LIB	?DRRECT	LOAD.L	(A6)+OSIPOS,D3	LOAD.L	(A6)+OSIDIM,D4	POPM.L	D2..D4,A3,A5	RET00$:	.ASCIZ	"Images :"	.EVEN;------------\\; SLIMAUPDATE >;============/; Met  jour la scroll-liste des images.; in	-; out	-; mod	D7.WSLIMAUPDATE:	PUSHM.L	A4,A5	LOAD.L	A5,#(A6)+OSLIMA	LOAD.L	A4,#R16"SLIMAGETTEXT	LOAD.L	(A5)+OSLADL,A4	LOAD.W	(A5)+OSLCYN,(A6)+ONBIMA	JUMP,EQ 40$	INC.W	(A5)+OSLCYN40$:	SCROLL_	LUPDATE	POPM.L	A4,A5	RET;-------------\\; SLIMAGETTEXT >;-------------/; in	D3.W	rang de la case (0..OSLCYN-1); out	D3.W	zro;	A3.L	^contenu de la case termin par <0> ou <CR>;	D7.W	erreur si la case est vide; mod	D3.L, D7.W, A3.L;SLIMAGETTEXT:	LOAD.L	A3,#R16"TOUT$	DEC.W	D3	JUMP,NS 90$	LOAD.L	A3,#(A6)+OTAIMA	SL.W	D3,#2	LOAD.L	A3,(A3)+(D3.W)	; A3 <-- ^image	LOAD.L	D3,(A3)+OHVNO	; D3 <-- numro de l'image	CALL	SLGETTEXT90$:	CLR.W	D3	CLR.W	D7		; retour EQ	RETTOUT$:	.ASCIZ	"Tout ..."	.EVEN;----------\\; SLIMAMOVE >;==========/; Dplace la scroll-liste des images.; in	D4.L	position de la souris (y;x);	D2.L	fanions; out	D7.W	erreur; mod	D7.WSLIMAMOVE:	PUSHM.L	D3,A5	LOAD.L	A5,#(A6)+OSLIMA	SCROLL_	LMOVE	JUMP',NE 90$	CALL	SLIMASHOW	CLR.W	D7	LOAD.W	D3,(A5)+OSLPOS+2	ADD.W	D3,#LGSCROLL	COMP.W	D4,D3	JUMP',HS 90$	LOAD.W	D7,#1		; D7 <-- dans l'ascenseur90$:	POPM.L	D3,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; SLIMASHOW >;==========/; Affiche la petite image.; in	D2.L	fanions; out	-; mod	D7.WSLIMASHOW:	PUSHM.L	D3,A2	LOAD.L	A2,#0	LOAD.W	D3,(A6)+OSLIMA+OSLCYS	DEC.W	D3	JUMP,NS 50$	LOAD.L	A2,#(A6)+OTAIMA	SL.W	D3,#2	LOAD.L	A2,(A2)+(D3.W)	; A2 <-- ^image50$:	CALL	IMAGESHOW	; montre l'image en petit	POPM.L	D3,A2	RET;----------\\; SLEFFDRAW >;==========/; Dessine la scroll-liste des effets.; in	-; out	-; mod	D7.WSLEFFDRAW:	PUSHM.L	D2..D4,A3,A5	LOAD.L	A5,#(A6)+OSLEFF	LOAD.L	(A5)+OSLPOS,#H'10000*POSEFFY+POSEFFX	LOAD.L	(A5)+OSLDIM,#H'10000*DIMEFFY+DIMEFFX	SCROLL_	LDRAW	LOAD.L	D3,(A5)+OSLPOS	ADD.W	D3,#LGSCROLL	SWAP.W	D3	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#2	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A3,#R16"00$	LIB	?AFTEXT	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	CALL	SLFLECHE;	LOAD.L	D3,(A5)+OSLPOS;	LOAD.L	D4,(A5)+OSLDIM	SUB.W	D3,D4	SUB.W	D3,#8	LOAD.W	D2,#SETDOT	LIB	?DRRECT	LOAD.L	(A6)+OSEPOS,D3	LOAD.L	(A6)+OSEDIM,D4	POPM.L	D2..D4,A3,A5	RET00$:	.ASCIZ	"Effets :"	.EVEN;------------\\; SLEFFUPDATE >;============/; Met  jour la scroll-liste des effets.; in	-; out	-; mod	D7.WSLEFFUPDATE:	PUSHM.L	A4,A5	LOAD.L	A5,#(A6)+OSLEFF	LOAD.L	A4,#R16"SLEFFGETTEXT	LOAD.L	(A5)+OSLADL,A4	LOAD.W	(A5)+OSLCYN,#NDELAI+NTRANS+NMSS	SCROLL_	LUPDATE	POPM.L	A4,A5	RET;-------------\\; SLEFFGETTEXT >;-------------/; in	D3.W	rang de la case (0..OSLCYN-1); out	D3.W	zro;	A3.L	^contenu de la case termin par <0> ou <CR>;	D7.W	erreur si la case est vide; mod	D3.L, D7.W, A3.L;SLEFFGETTEXT:	COMP.W	D3,#NDELAI	JUMP',HS 20$	TSET.L	D3:#BEFFET	JUMP'	50$20$:	SUB.W	D3,#NDELAI	COMP.W	D3,#NTRANS	JUMP',HS 30$	TSET.L	D3:#BEFFET	TSET.L	D3:#BTRANS	JUMP'	50$30$:	SUB.W	D3,#NTRANS	TSET.L	D3:#BEFFET	TSET.L	D3:#BMSS50$:	CALL	SLGETTEXT	CLR.W	D3	CLR.W	D7		; retour EQ	RET;----------\\; SLEFFMOVE >;==========/; Dplace la scroll-liste des effets.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WSLEFFMOVE:	PUSHM.L	D3,A5	LOAD.L	A5,#(A6)+OSLEFF	SCROLL_	LMOVE	JUMP',NE 90$	CALL	SLEFFSHOW	CLR.W	D7	LOAD.W	D3,(A5)+OSLPOS+2	ADD.W	D3,#LGSCROLL	COMP.W	D4,D3	JUMP',HS 90$	LOAD.W	D7,#1		; D7 <-- dans l'ascenseur90$:	POPM.L	D3,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; SLEFFSHOW >;==========/; Affiche le texte pour les effets.; in	-; out	-; mod	D7.WSLEFFSHOW:	PUSHM.L	D2..D4,A3,A4	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A6)+OSEPOS	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.L	D4,(A6)+OSEDIM	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface l'ancien texte	LOAD.L	A3,#R16"TABLE$	LOAD.W	D3,(A6)+OSLEFF+OSLCYS20$:	DEC.W	D3	JUMP,NS 30$22$:	TEST.B	(A3+)	JUMP,NE 22$	JUMP	20$30$:	LOAD.W	D4,(A6)+OSEPOS+0	INC.W	D4	ADD.W	D4,(A0)+ODFC1Y	SWAP.W	D432$:	TEST.B	(A3)	JUMP,EQ 90$	LOAD.W	D4,(A6)+OSEPOS+2	ADD.W	D4,(A0)+ODFCX	ADD.W	D4,(A0)+ODFCX	LOAD.L	D3,D4	LIB	?SETCURS	LOAD.L	A4,A3	LOAD.W	D3,#-140$:	INC.W	D3	COMP.B	(A4+),#CR	JUMP,NE	40$	TEST.W	D3	JUMP,EQ 50$	LIB	?STRING50$:	LOAD.L	A3,A4	SWAP.W	D4	ADD.W	D4,(A0)+ODFCY	ADD.W	D4,(A0)+ODFCY	SWAP.W	D4	JUMP	32$90$:	POPM.L	D2..D4,A3,A4	RETTABLE$:	.ASCII	"Attend un<CR>"	.ASCII	"quart de<CR>"	.ASCII	"seconde<CR>"	.ASCII	"avant de<CR>"	.ASCII	"poursuivre<CR>"	.ASCII	"le script.<CR>"	.B	0	.ASCII	"<CR>"	.ASCII	"Attend une<CR>"	.ASCII	"demi seconde<CR>"	.ASCII	"avant de<CR>"	.ASCII	"poursuivre<CR>"	.ASCII	"le script.<CR>"	.B	0	.ASCII	"<CR>"	.ASCII	"Attend<CR>"	.ASCII	"une seconde<CR>"	.ASCII	"avant de<CR>"	.ASCII	"poursuivre<CR>"	.ASCII	"le script.<CR>"	.B	0	.ASCII	"<CR>"	.ASCII	"Attend<CR>"	.ASCII	"deux secondes<CR>"	.ASCII	"avant de<CR>"	.ASCII	"poursuivre<CR>"	.ASCII	"le script.<CR>"	.B	0	.ASCII	"<CR>"	.ASCII	"Attend<CR>"	.ASCII	"quatre secondes<CR>"	.ASCII	"avant de<CR>"	.ASCII	"poursuivre<CR>"	.ASCII	"le script.<CR>"	.B	0	.ASCII	"<CR>"	.ASCII	"Attend<CR>"	.ASCII	"huit secondes<CR>"	.ASCII	"avant de<CR>"	.ASCII	"poursuivre<CR>"	.ASCII	"le script.<CR>"	.B	0	.ASCII	"Gnre auto-<CR>"	.ASCII	"matiquement<CR>"	.ASCII	"une image<CR>"	.ASCII	"entre la pr-<CR>"	.ASCII	"cdente et la<CR>"	.ASCII	"suivante.<CR>"	.B	0	.ASCII	"Gnre auto-<CR>"	.ASCII	"matiquement<CR>"	.ASCII	"trois images<CR>"	.ASCII	"entre la pr-<CR>"	.ASCII	"cdente et la<CR>"	.ASCII	"suivante.<CR>"	.B	0	.ASCII	"Gnre auto-<CR>"	.ASCII	"matiquement<CR>"	.ASCII	"sept images<CR>"	.ASCII	"entre la pr-<CR>"	.ASCII	"cdente et la<CR>"	.ASCII	"suivante.<CR>"	.B	0	.ASCII	"Gnre auto-<CR>"	.ASCII	"matiquement<CR>"	.ASCII	"quinze images<CR>"	.ASCII	"entre la pr-<CR>"	.ASCII	"cdente et la<CR>"	.ASCII	"suivante.<CR>"	.B	0	.ASCII	"Gnre auto-<CR>"	.ASCII	"matiquement<CR>"	.ASCII	"31 images<CR>"	.ASCII	"entre la pr-<CR>"	.ASCII	"cdente et la<CR>"	.ASCII	"suivante.<CR>"	.B	0	.ASCII	"<CR>"	.ASCII	"<CR>"	.ASCII	"Stoppe le<CR>"	.ASCII	"mouvement.<CR>"	.ASCII	"<CR>"	.ASCII	"<CR>"	.B	0	.ASCII	"<CR>"	.ASCII	"<CR>"	.ASCII	"Redmarre le<CR>"	.ASCII	"mouvement.<CR>"	.ASCII	"<CR>"	.ASCII	"<CR>"	.B	0	.B	0	.EVEN	;----------\\; SLPRGDRAW >;==========/; Dessine la scroll-liste du script.; in	-; out	-; mod	D7.WSLPRGDRAW:	PUSHM.L	D3,A3,A5	LOAD.L	A5,#(A6)+OSLPRG	LOAD.L	(A5)+OSLPOS,#H'10000*POSPRGY+POSPRGX	LOAD.L	(A5)+OSLDIM,#H'10000*DIMPRGY+DIMPRGX	SCROLL_	LDRAW	LOAD.L	D3,(A5)+OSLPOS	ADD.W	D3,#LGSCROLL	SWAP.W	D3	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#2	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A3,#R16"00$	LIB	?AFTEXT	POPM.L	D3,A3,A5	RET00$:	.ASCIZ	"Script :"	.EVEN;------------\\; SLPRGUPDATE >;============/; Met  jour la scroll-liste du script.; in	-; out	-; mod	D7.WSLPRGUPDATE:	PUSHM.L	A4,A5	LOAD.L	A5,#(A6)+OSLPRG	LOAD.L	A4,#R16"SLPRGGETTEXT	LOAD.L	(A5)+OSLADL,A4	LOAD.W	(A5)+OSLCYN,(A6)+ONBPRG	INC.W	(A5)+OSLCYN	; place pour "Recommence"	SCROLL_	LUPDATE	POPM.L	A4,A5	RET;-------------\\; SLPRGGETTEXT >;-------------/; in	D3.W	rang de la case (0..OSLCYN-1); out	D3.W	zro;	A3.L	^contenu de la case termin par <0> ou <CR>;	D7.W	erreur si la case est vide; mod	D3.L, D7.W, A3.L;SLPRGGETTEXT:	PUSHM.L	A5	LOAD.L	A3,#R16"SUITE$	LOAD.L	A5,#(A6)+OSLPRG	INC.W	D3	COMP.W	D3,(A5)+OSLCYN	; dernire case ?	JUMP,EQ 90$		; oui => 90$	DEC.W	D3	LOAD.L	A3,#(A6)+OTAPRG	LOAD.B	D3,(A3)+(D3.W)	TEST.L	D3:#BEFFET	JUMP,BS 50$	LOAD.L	A3,#(A6)+OTAIMA	AND.W	D3,#H'00FF	SL.W	D3,#2	LOAD.L	A3,(A3)+(D3.W)	; A3 <-- ^image	LOAD.L	D3,(A3)+OHVNO	; D3 <-- numro de l'image50$:	CALL	SLGETTEXT90$:	POPM.L	A5	CLR.W	D3	CLR.W	D7		; retour EQ	RETSUITE$:	.ASCIZ	"Recommence"	.EVEN;----------\\; SLPRGMOVE >;==========/; Dplace la scroll-liste du script.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WSLPRGMOVE:	PUSHM.L	A5	LOAD.L	A5,#(A6)+OSLPRG	SCROLL_	LMOVE	POPM.L	A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; SLFLECHE >;---------/; ; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WSLFLECHE:	PUSHM.L	D2..D4,A3	ADD.W	D3,D4	ADD.W	D3,#4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LOAD.L	A3,#R16"TAFLRIGHT	LOAD.W	D2,#SETDOT	CALL	DESMOTIF	POPM.L	D2..D4,A3	RET;---------\\; DESMOTIF >;---------/; Dessine un motif constitu de lignes droites.; in	D3.L	coordonne initiale;	D2.W	mode;	A3.L	^table (dy;dx); out	-; mod	D7.WDESMOTIF:	PUSHM.L	D3,D4,A3	SWAP.W	D3	ADD.W	D3,(A3+)	; saute au dpart	SWAP.W	D3	ADD.W	D3,(A3+)10$:	LOAD.L	D4,(A3+)	JUMP',EQ 90$	LIB	?DRSEG	JUMP	10$90$:	POPM.L	D3,D4,A3	RETTAFLRIGHT:			; flche ->	.W	0,0	.W	10,0	.W	0,10	.W	10,0	.W	-20,20	.W	-20,-20	.W	10,0	.W	0,-10	.W	10,0	.W	0,0;----------\\; SLGETTEXT >;----------/; ; in	D3.B	opration; out	A3.L	^texte; mod	A3.LSLGETTEXT:	PUSHM.L	D2..D4,A4	LOAD.L	A4,#(A6)+OBUDIS	TCLR.L	D3:#BEFFET	JUMP,BS 40$	LOAD.L	A3,#R16"IMAGE$20$:	LOAD.B	(A4+),(A3+)	JUMP,NE 20$	DEC.L	A4	CLR.L	D4	LOAD.B	D4,D3	LOAD.W	D3,#2	CLR.W	D2	LIB	?PUTDEC	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUDIS	JUMP	90$40$:	TCLR.L	D3:#BTRANS	JUMP',BS 50$	TCLR.L	D3:#BMSS	JUMP',BS 60$	LOAD.L	A3,#R16"DELAI$	AND.W	D3,#H'000F	MUL.WU	D3,#LDELAI	ADD.L	A3,D3	JUMP'	90$50$:	LOAD.L	A3,#R16"TRANS$	AND.W	D3,#H'000F	MUL.WU	D3,#LTRANS	ADD.L	A3,D3	JUMP'	90$60$:	LOAD.L	A3,#R16"MSS$	AND.W	D3,#H'000F	MUL.WU	D3,#LMSS	ADD.L	A3,D3;	JUMP'	90$90$:	POPM.L	D2..D4,A4	RETIMAGE$:	.ASCIZ	"Image "DELAI$:	.ASCIZ	"Attend 1/4 s"	.ASCIZ	"Attend 1/2 s"	.ASCIZ	"Attend 1 s  "	.ASCIZ	"Attend 2 s  "	.ASCIZ	"Attend 4 s  "	.ASCIZ	"Attend 8 s  "LDELAI	=	13NDELAI	=	6TRANS$:	.ASCIZ	"1 transition  "	.ASCIZ	"3 transitions "	.ASCIZ	"7 transitions "	.ASCIZ	"15 transitions"	.ASCIZ	"31 transitions"LTRANS	=	15NTRANS	=	5MSS$:	.ASCIZ	"Stoppe mouvem."	.ASCIZ	"Dpart mouvem."LMSS	=	15NMSS	=	2	.EVEN;--------\\; AFBMENU >;========/; ; in	-; out	-; mod	D7.WAFBMENU:	PUSH.L	A3	LOAD.L	A3,#R16"TMENU_MAIN	LIB	?AFMENU	POP.L	A3	RETTDBOX_MAIN:	.W	10$-TDBOX_MAIN	.W	TMENU_MAIN-TDBOX_MAIN	.W	0,010$:	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,5	.B	ODBSQUARE,BAFIMA!2^7!2^6,KEYDBOX/H'100,BAFIMA	.ASCIZ	" affiche"	.B	ODBTABX,77	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,61	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	"   PREND   "	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,61	.B	ODBBOX,0,F3,TDBNORM	.ASCIZ	"   SAUVE   "	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBTABX,61	.B	ODBBOX,0,F5,TDBNORM	.ASCIZ	" MOUVEMENT "	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,61	.B	ODBLABEL,11	.B	ODBBOX,0,F8,TDBMEV	.ASCIZ	"   ANIME   "	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,61+1	.B	ODBSQUARE,BNEGATIF	.ASCIZ	" ngatif"	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,2	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" FIN "	.B	ODBTABX,20	.B	ODBCIRCLE,BINSERT!2^7!2^6,KEYDBOX/H'100,BINSERT	.ASCIZ	" insre"	.B	ODBTABX,31	.B	ODBCIRCLE,BREPLACE!2^7!2^6,KEYDBOX/H'100,BREPLACE	.ASCIZ	" remplace"	.B	ODBTABX,45	.B	ODBLABEL,10	.B	ODBBOX,0,CLEAR,TDBNORM	.ASCIZ	" SUPPRIME "	.B	ODBTABX,61	.B	ODBBOX,0,F14,TDBNORM	.ASCIZ	"  EFFACE  "	.B	0TMENU_MAIN:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	"   Dfinition    "	.ASCIZ	"  du mouvement   "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"     Anime ...   "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"      Efface     "	.EVENTKEY_MAIN:	.W	F0,0			DOKF0-TKEY_MAIN	.W	F1,0			DOKF1-TKEY_MAIN	.W	F3,0			DOKF3-TKEY_MAIN	.W	F4,F5,F6,0		DOKF5-TKEY_MAIN	.W	F7,F8,F9,0		DOKF8-TKEY_MAIN	.W	F14,0			DOKF14-TKEY_MAIN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MAIN	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_MAIN	.W	0DOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RET	.END