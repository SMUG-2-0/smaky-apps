  100 Delete "ellipse.move"  110 Open File(1),"ellipse.move",7  120 Let T%=360/5  130 Put File(1),T%  140 For I=0 To 360-5 Step 5  150 Gosub Label_CALCULE(200,0,I)  160 Next I  170 Close File(1)  180 End  190 Label_CALCULE(X,Y,A)   200 Let A1=A*Pi/180  210 Let X1=(X*Cos(A1)-Y*Sin(A1))*1  220 Let Y1=(X*Sin(A1)+Y*Cos(A1))*.5  230 Print X1,Y1  240 Let T%=Y1  250 Put File(1),T%  260 Let T%=X1   270 Put File(1),T%  280 Return