	.SBTTL	FILMTRANS;------------\\; TRANSCREATE >;============/; Gnre toutes les images intermdiaires ncessaires.; in	-; out	D7.W	erreur; mod	D7.WTRANSCREATE:	PUSH.L	D4	SET.B	(A6)+OTRCNT	CLR.W	(A6)+OTRNBI	CALL	TRANSPASS	; compte le nb d'images  gnrer	CLR.W	D7	TEST.W	(A6)+OTRNBI	JUMP,EQ 90$	CALL	WAITDBOX	; met le dbox d'attente	CLR.B	(A6)+OTRCNT	LOAD.W	D4,(A6)+OTRNBI	MUL.WU	D4,#10	LOAD.W	(A6)+OTRNBI,D4	CALL	TRANSPASS	; cette fois, c'est pour de bon !	CALL	NORMDBOX	; enlve la dbox d'attente90$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; TRANSPASS >;----------/; Gnre toutes les images intermdiaires ncessaires.; in	-; out	D7.W	erreur; mod	D7.WTRANSPASS:	PUSHM.L	D2..D4,A4	PUSH.W	(A6)+OINC	LOAD.W	(A6)+OINC,#+1	TEST.W	(A6)+ONBPRG	JUMP,EQ 90$	LOAD.L	A4,#(A6)+OTAPRG	CLR.W	D4		; D4 <-- rang dans le programme10$:	LOAD.B	D3,(A4+)	TEST.L	D3:#BEFFET	JUMP,BC 60$	TEST.L	D3:#BTRANS	JUMP,BC 60$	CALL	PRGIMADA	; D2 <-- images dpart/arrive |-|d|a|-|	JUMP,NE 60$	CALL	TRANSSUITE	; cre les images intermdiaires	JUMP,NE 90$60$:	INC.W	D4	COMP.W	D4,(A6)+ONBPRG	JUMP,LO 10$90$:	POP.W	(A6)+OINC	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TRANSSUITE >;-----------/; Cre une suite d'images intermdiaires.; in	D3.B	opration de transformation;	D2.L	images dpart/arrive |-|d|a|-|; out	D7.W	erreur; mod	D7.WTRANSSUITE:	PUSHM.L	D0..D3	AND.W	D3,#H'000F	LOAD.L	D0,D2	LOAD.B	D0,#0	LOAD.L	D1,D2	LOAD.B	D1,#32	CALL	TRANSONE	; gnre l'image intermdiaire 16	JUMP,NE 90$	DEC.W	D3	JUMP,NS 90$	LOAD.L	D0,D2	LOAD.B	D0,#0	LOAD.L	D1,D2	LOAD.B	D1,#16	CALL	TRANSONE	; gnre l'image intermdiaire 8	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#16	LOAD.L	D1,D2	LOAD.B	D1,#32	CALL	TRANSONE	; gnre l'image intermdiaire 24	JUMP,NE 90$	DEC.W	D3	JUMP,NS 90$	LOAD.L	D0,D2	LOAD.B	D0,#0	LOAD.L	D1,D2	LOAD.B	D1,#8	CALL	TRANSONE	; gnre l'image intermdiaire 4	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#8	LOAD.L	D1,D2	LOAD.B	D1,#16	CALL	TRANSONE	; gnre l'image intermdiaire 12	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#16	LOAD.L	D1,D2	LOAD.B	D1,#24	CALL	TRANSONE	; gnre l'image intermdiaire 20	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#24	LOAD.L	D1,D2	LOAD.B	D1,#32	CALL	TRANSONE	; gnre l'image intermdiaire 28	JUMP,NE 90$	DEC.W	D3	JUMP,NS 90$	LOAD.L	D0,D2	LOAD.B	D0,#0	LOAD.L	D1,D2	LOAD.B	D1,#4	CALL	TRANSONE	; gnre l'image intermdiaire 2	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#4	LOAD.L	D1,D2	LOAD.B	D1,#8	CALL	TRANSONE	; gnre l'image intermdiaire 6	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#8	LOAD.L	D1,D2	LOAD.B	D1,#12	CALL	TRANSONE	; gnre l'image intermdiaire 10	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#12	LOAD.L	D1,D2	LOAD.B	D1,#16	CALL	TRANSONE	; gnre l'image intermdiaire 14	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#16	LOAD.L	D1,D2	LOAD.B	D1,#20	CALL	TRANSONE	; gnre l'image intermdiaire 18	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#20	LOAD.L	D1,D2	LOAD.B	D1,#24	CALL	TRANSONE	; gnre l'image intermdiaire 22	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#24	LOAD.L	D1,D2	LOAD.B	D1,#28	CALL	TRANSONE	; gnre l'image intermdiaire 26	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#28	LOAD.L	D1,D2	LOAD.B	D1,#32	CALL	TRANSONE	; gnre l'image intermdiaire 30	JUMP,NE 90$	DEC.W	D3	JUMP,NS 90$	LOAD.L	D0,D2	LOAD.B	D0,#0	LOAD.L	D1,D2	LOAD.B	D1,#2	CALL	TRANSONE	; gnre l'image intermdiaire 1	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#2	LOAD.L	D1,D2	LOAD.B	D1,#4	CALL	TRANSONE	; gnre l'image intermdiaire 3	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#4	LOAD.L	D1,D2	LOAD.B	D1,#6	CALL	TRANSONE	; gnre l'image intermdiaire 5	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#6	LOAD.L	D1,D2	LOAD.B	D1,#8	CALL	TRANSONE	; gnre l'image intermdiaire 7	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#8	LOAD.L	D1,D2	LOAD.B	D1,#10	CALL	TRANSONE	; gnre l'image intermdiaire 9	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#10	LOAD.L	D1,D2	LOAD.B	D1,#12	CALL	TRANSONE	; gnre l'image intermdiaire 11	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#12	LOAD.L	D1,D2	LOAD.B	D1,#14	CALL	TRANSONE	; gnre l'image intermdiaire 13	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#14	LOAD.L	D1,D2	LOAD.B	D1,#16	CALL	TRANSONE	; gnre l'image intermdiaire 15	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#16	LOAD.L	D1,D2	LOAD.B	D1,#18	CALL	TRANSONE	; gnre l'image intermdiaire 17	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#18	LOAD.L	D1,D2	LOAD.B	D1,#20	CALL	TRANSONE	; gnre l'image intermdiaire 19	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#20	LOAD.L	D1,D2	LOAD.B	D1,#22	CALL	TRANSONE	; gnre l'image intermdiaire 21	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#22	LOAD.L	D1,D2	LOAD.B	D1,#24	CALL	TRANSONE	; gnre l'image intermdiaire 23	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#24	LOAD.L	D1,D2	LOAD.B	D1,#26	CALL	TRANSONE	; gnre l'image intermdiaire 25	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#26	LOAD.L	D1,D2	LOAD.B	D1,#28	CALL	TRANSONE	; gnre l'image intermdiaire 27	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#28	LOAD.L	D1,D2	LOAD.B	D1,#30	CALL	TRANSONE	; gnre l'image intermdiaire 29	JUMP,NE 90$	LOAD.L	D0,D2	LOAD.B	D0,#30	LOAD.L	D1,D2	LOAD.B	D1,#32	CALL	TRANSONE	; gnre l'image intermdiaire 31	JUMP,NE 90$;	DEC.W	D3;	JUMP,NS 90$90$:	POPM.L	D0..D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; TRANSONE >;---------/; Gnre une image intermdiaire.; in	D0.L	numro de l'image de dpart  |-|d|a|i|;	D1.L	numro de l'image d'arrive  |-|d|a|i|; out	D7.W	erreur; mod	D7.WTRANSONE:	PUSHM.L	D0..D5,A0..A4; Calcule le numro de la nouvelle image intermdiaire.	LOAD.L	D2,D1	SUB.B	D2,D0	SR.B	D2,#1	ADD.B	D2,D0		; D2 <-- numro pour la nouvelle image	CALL	TRANSGETPI	; image dj calcule ?	JUMP,EQ 90$		; oui => 90$	TEST.B	(A6)+OTRCNT	; compte ?	JUMP,F	05$		; non => 05$				; oui =>	INC.W	(A6)+OTRNBI	CLR.W	D7	JUMP	90$05$:	PUSH.W	D0	LOAD.W	D0,(A6)+OTRNBI	CALL	AFFNDBOX	; montre ce qui reste	SUB.W	(A6)+OTRNBI,#10	POP.W	D0	LOAD.L	D3,D2; Cherche le pointeur  l'image de dpart.	COMP.B	D0,#0	JUMP,EQ 10$	LOAD.L	D2,D0	CALL	TRANSGETPI	JUMP,NE 90$	JUMP	15$10$:	LOAD.L	A2,#(A6)+OTAIMA	LOAD.L	D2,D0	SWAP.W	D2	AND.W	D2,#H'00FF	SL.W	D2,#2	LOAD.L	A2,(A2)+(D2.W)15$:	TEST.B	(A2)+OHVFL:#BHVINV	JUMP,BC 17$	CALL	IMAGEINV	; met l'image en positif17$:	LOAD.L	A0,A2		; A0 <-- ^image de dpart; Cherche le pointeur  l'image d'arrive.	COMP.B	D1,#32	JUMP,EQ 20$	LOAD.L	D2,D1	CALL	TRANSGETPI	JUMP,NE 90$	JUMP	25$20$:	LOAD.L	A2,#(A6)+OTAIMA	LOAD.L	D2,D1	RR.W	D2,#8	AND.W	D2,#H'00FF	SL.W	D2,#2	LOAD.L	A2,(A2)+(D2.W)25$:	TEST.B	(A2)+OHVFL:#BHVINV	JUMP,BC 27$	CALL	IMAGEINV	; met l'image en positif27$:	LOAD.L	A1,A2		; A1 <-- ^image d'arrive; Demande de la mmoire pour l'en-tte de la nouvelle image.	LOAD.L	D4,#LHV+LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour le nom et l'en-tte	JUMP,NE 90$	LOAD.L	A2,A4		; A2 <-- ^nouvelle en-tte	LOAD.L	A3,A0	SR.W	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMO30$:	LOAD.W	(A4+),(A3+)	DECJ.W,NMO D4,30$	LOAD.L	(A2)+OHVNO,D3; Demande de la mmoire pour le data de la nouvelle image.	LOAD.W	D4,(A2)+LHV+OIMDLX	ADD.W	D4,#8-1	SR.W	D4,#3	MUL.WU	D4,(A2)+LHV+OIMDLY	ADD.L	D4,#IMLBUF+4	; D4 <-- rserve pour codage	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'image	JUMP,NE 90$	LOAD.L	A4,#(A4)+IMLBUF	; A4 <-- ^image	LOAD.L	(A2)+OHVPI,A4	SUB.L	D4,#IMLBUF+4	; D4 <-- rserve pour codage	SR.L	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMO40$:	CLR.W	(A4+)	DECJ.W,NMO D4,40$; Calcule le data de la nouvelle image.	CLR.L	D3		; D3 <-- origine	LOAD.W	D4,(A2)+LHV+OIMDLY	SWAP.W	D4	LOAD.W	D4,(A2)+LHV+OIMDLX	LOAD.W	D5,D4	ADD.W	D5,#8-1	SR.W	D5,#3		; D5 <-- Iy	PUSHM.L	A0..A2	LOAD.L	A0,(A0)+OHVPI	; A0 <-- ^matrice de dpart	LOAD.L	A1,(A1)+OHVPI	; A1 <-- ^matrice d'arrive	LOAD.L	A2,(A2)+OHVPI	; A2 <-- ^matrice  calculer	CALL	MOVETRANS	; gnre la nouvelle image	POPM.L	A0..A2	TEST.W	D7	JUMP,NE 80$	CALL	TRANSPUTPI	; enregistre la nouvelle image	JUMP,EQ 90$80$:	PUSH.W	D7	CALL	IMAGECLOSE	; libre la mmoire de l'image	POP.W	D790$:	POPM.L	D0..D5,A0..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TRANSCLOSE >;===========/; Libre toutes les images intermdiaires.; in	-; out	-; mod	D7.WTRANSCLOSE:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OTIIMA	LOAD.W	D3,#MAXIIMA-110$:	TEST.L	(A3)	JUMP',EQ 30$	LOAD.L	A2,(A3)	CALL	IMAGECLOSE	; libre la mmoire30$:	CLR.L	(A3+)	DECJ.W,NMO D3,10$	POPM.L	D3,A3	RET;-----------\\; TRANSPUTPI >;===========/; Enregistre une nouvelle image intermdiaire.; in	A2.L	^image; out	D7.W	erreur; mod	D7.WTRANSPUTPI:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OTIIMA	LOAD.W	D3,#MAXIIMA-110$:	TEST.L	(A3+)	JUMP',EQ 50$	DECJ.W,NMO D3,10$	LOAD.W	D7,#1		; D7 <-- zut, c'est plein	JUMP'	90$50$:	LOAD.L	(A3)-4,A2	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TRANSGETPI >;===========/; Cherche une image intermdiaire.; in	D2.L	numro de l'image |-|d|a|i|; out	A2.L	^image;	D7.W	erreur; mod	D7.W, A2.LTRANSGETPI:	PUSH.L	D2	CALL	TRANSGETPJ	; cherche l'image	JUMP,EQ 90$	CALL	TRANSINVNI	; D2 <-- inverse	CALL	TRANSGETPJ	; cherche l'inverse90$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TRANSGETPJ >;-----------/; Cherche une image intermdiaire.; in	D2.L	numro de l'image |-|d|a|i|; out	A2.L	^image;	D7.W	erreur; mod	D7.W, A2.LTRANSGETPJ:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OTIIMA	LOAD.W	D3,#MAXIIMA-110$:	TEST.L	(A3+)	JUMP',EQ 20$	LOAD.L	A2,(A3)-4	; A2 <-- ^image	COMP.L	D2,(A2)+OHVNO	; est-ce le bon numro ?	JUMP',EQ 50$		; oui => 50$20$:	DECJ.W,NMO D3,10$	LOAD.W	D7,#1		; D7 <-- zut, pas trouv	JUMP'	90$50$:	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TRANSINVNI >;-----------/; Inverse le numro d'une image.; in	D2.L	numro de l'image |-|d|a|i|; out	D2.L	numro de l'image |-|a|d|j|  j=32-i; mod	D2.L, D7.WTRANSINVNI:	RR.L	D2,#8	RR.W	D2,#8	RL.L	D2,#8	SUB.B	D2,#32	NEG.B	D2	RET;-----------\\; TRANSGETNP >;===========/; Calcule qq valeurs selon une opration de transformation.; in	D3.B	opration de transformation; out	D2.W	nb d'images intermdiaires;	D1.W	pas; mod	D1.L, D2.L, D7.WTRANSGETNP:	PUSHM.L	D3,A3	LOAD.L	A3,#R16"TABLE$	AND.W	D3,#H'000F	SL.W	D3,#2	LOAD.W	D2,(A3)+(D3.W)+0	LOAD.W	D1,(A3)+(D3.W)+2	POPM.L	D3,A3	RETTABLE$:	.W	1,16	.W	3,8	.W	7,4	.W	15,2	.W	31,1; Variables temporaires sur le stack; ----------------------------------OMVPTD	=	-4		; ^matrice de dpartOMVPTA	=	-8		; ^matrice d'arriveOMVPTI	=	-12		; ^matrice intermdiaireOMVPOS	=	-16		; position (y;x)OMVDIM	=	-20		; dimensions (dy;dx)LMV	=	-20; Macros rapides; --------------;MOVED_INCX:	.MACRO	MOVED_INCX	.LOCALMACRO END	DEC.B	D0		; x <-- x+1	JUMP',PL END	LOAD.L	D0,#7	INC.L	A0END:	.ENDMACRO;MOVED_DECX:	.MACRO	MOVED_DECX	.LOCALMACRO END	INC.B	D0		; x <-- x-1	COMP.B	D0,#8	JUMP',LT END	CLR.B	D0	DEC.L	A0END:	.ENDMACRO;MOVED_INCY:	.MACRO	MOVED_INCY	ADD.W	A0,A3		; y <-- y+1	.ENDMACRO;MOVED_DECY:	.MACRO	MOVED_DECY	SUB.W	A0,A3		; y <-- y-1	.ENDMACRO;MOVEA_INCX:	.MACRO	MOVEA_INCX	.LOCALMACRO END	DEC.B	D1		; x <-- x+1	JUMP',PL END	LOAD.L	D1,#7	INC.L	A1END:	.ENDMACRO;MOVEA_DECX:	.MACRO	MOVEA_DECX	.LOCALMACRO END	INC.B	D1		; x <-- x-1	COMP.B	D1,#8	JUMP',LT END	CLR.B	D1	DEC.L	A1END:	.ENDMACRO;MOVEA_INCY:	.MACRO	MOVEA_INCY	ADD.W	A1,A3		; y <-- y+1	.ENDMACRO;MOVEA_DECY:	.MACRO	MOVEA_DECY	SUB.W	A1,A3		; y <-- y-1	.ENDMACRO;----------\\; MOVETRANS >;==========/; ; in	A0.L	^matrice de dpart;	A1.L	^matrice d'arrive;	A2.L	^matrice intermdiaire ( calculer);	D3.L	origine (y;x);	D4.L	dimensions (dy;dx);	D5.W	Iy; out	D7.W	erreur; mod	D7.WMOVETRANS:	PUSHM.L	D0..D6,A0..A3	LINK	A6,#LMV		; A6 <-- ^variables temporaires	LOAD.L	(A6)+OMVPTD,A0	LOAD.L	(A6)+OMVPTA,A1	LOAD.L	(A6)+OMVPTI,A2	LOAD.L	(A6)+OMVPOS,D3	LOAD.L	(A6)+OMVDIM,D4	LOAD.W	A3,D5		; A3 <-- Iy	CALL	MOVESCAN	JUMP,NE 80$	LOAD.L	A0,(A6)+OMVPTD	LOAD.L	(A6)+OMVPTD,(A6)+OMVPTA	LOAD.L	(A6)+OMVPTA,A0	CALL	MOVESCAN80$:	UNLINK	A6		; ajuste le stack	POPM.L	D0..D6,A0..A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; MOVESCAN >;---------/; ; in	-; out	D7.W	erreur; mod	D7.WMOVESCAN:	PUSHM.L	D0..D6,A0..A3	LOAD.L	A0,(A6)+OMVPTA	CALL	MOVEPB	LOAD.L	A1,A0	LOAD.W	D1,D0		; A1/D1 <-- origine dans arrive	LOAD.L	A0,(A6)+OMVPTD	CALL	MOVEPB		; A0/D0 <-- origine dans dpart	LOAD.L	D2,(A6)+OMVPOS	LOAD.L	D3,D2	LOAD.W	D5,(A6)+OMVDIM+0 ; D5 <-- hauteur	DEC.W	D510$:	PUSHM.L	D0,D1,D2,D3,D5,A0,A1	LOAD.W	D5,(A6)+OMVDIM+2 ; D5 <-- largeur	DEC.W	D520$:	TEST.B	(A0):D0		; point dans dpart ?	JUMP',BC 30$		; non => 30$	CALL	MOVESEARCH	; D4 <-- point le plus proche dans arrive	JUMP',NE 30$	CALL	MOVEPUT		; met point dans intermdiaire30$:	MOVED_INCX		; A0/D0 <-- x+1	INC.W	D2		; D2 <-- x+1	MOVEA_INCX		; A1/D1 <-- x+1	INC.W	D3		; D3 <-- x+1	DECJ.W,NMO D5,20$	POPM.L	D0,D1,D2,D3,D5,A0,A1	MOVED_INCY		; A0/D0 <-- y+1	SWAP.W	D2	INC.W	D2		; D2 <-- y+1	SWAP.W	D2	MOVEA_INCY		; A1/D1 <-- y+1	SWAP.W	D3	INC.W	D3		; D3 <-- y+1	SWAP.W	D3	PUSH.L	D3	SWAP.W	D3	AND.W	D3,#H'0007	; toutes les 8 lignes ?	JUMP',NE 50$		; non => 50$	LIB	?IFCAR		; une touche presse ?	JUMP',NE 50$		; non => 50$	COMP.W	D3,#END	JUMP',EQ 80$	COMP.W	D3,#F0	JUMP',EQ 80$	COMP.W	D3,#F0+SHIFT	JUMP',EQ 80$50$:	POP.L	D3	DECJ.W,NMO D5,10$	CLR.W	D7		; D7 <-- ok	JUMP	90$80$:	POP.L	D3		; ajuste le stack	LOAD.W	D7,#ERKSTO	; D7 <-- erreur90$:	POPM.L	D0..D6,A0..A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MOVESEARCH >;-----------/; Cherche le point le plus proche d'un autre, en parcourant; une spirale concentrique rectangulaire.;;	      ^;	      |;	      |       i+1;	  i+2 |      o--->|;	      |    D3     | i+1;	      |           V;	      |<-----------;	           i+2; in	D3.L	centre (y;x);	A1/D1	centre (^/bit);	A3.W	Iy; out	D4.L	point trouv (y;x);	D7.W	ok/erreur; mod	D4.L, D7.WMOVESEARCH:	TEST.B	(A1):D1	JUMP',BC BEGIN$	LOAD.L	D4,D3		; D4 <-- point trouv	CLR.W	D7		; D7 <-- ok	RETBEGIN$:	PUSHM.L	D0,D1,D2,D3,D5,D6,A0,A1,A2	LOAD.L	D4,D3		; D3 <-- x	SWAP.W	D4		; D4 <-- y	LOAD.L	D0,(A6)+OMVPOS	LOAD.L	D2,(A6)+OMVDIM	; D0 <-- min x	ADD.W	D2,D0		; D2 <-- max x	SWAP.W	D0	SWAP.W	D2	ADD.W	D2,D0	LOAD.W	A0,D0		; A0 <-- min y	LOAD.W	A2,D2		; A2 <-- max y	SWAP.W	D0	SWAP.W	D2	CLR.W	D5		; D5 <-- iSPIRAL$:; Avance vers la droite.	LOAD.W	D6,D5RIGHT2$:	COMP.W	D3,D0		; dpasse  gauche ?	JUMP',LT RIGHT3$	COMP.W	D3,D2		; dpasse  droite ?	JUMP',GE RIGHT3$	COMP.W	D4,A0		; dpasse en haut ?	JUMP',LT RIGHT3$	COMP.W	D4,A2		; dpasse en bas ?	JUMP',GE RIGHT3$	TEST.B	(A1):D1	JUMP,BS FOUND$RIGHT3$:	MOVEA_INCX		; A1/D1 <-- x+1	INC.W	D3		; D3 <-- x+1	DECJ.W,NMO D6,RIGHT2$; Avance vers le bas.	LOAD.W	D6,D5DOWN2$:	COMP.W	D3,D0		; dpasse  gauche ?	JUMP',LT DOWN3$	COMP.W	D3,D2		; dpasse  droite ?	JUMP',GE DOWN3$	COMP.W	D4,A0		; dpasse en haut ?	JUMP',LT DOWN3$	COMP.W	D4,A2		; dpasse en bas ?	JUMP',GE DOWN3$	TEST.B	(A1):D1	JUMP,BS FOUND$DOWN3$:	MOVEA_INCY		; A1/D1 <-- y+1	INC.W	D4		; D3 <-- y+1	DECJ.W,NMO D6,DOWN2$; Avance vers la gauche.	INC.W	D5		; D5 <-- i+1	LOAD.W	D6,D5LEFT2$:	COMP.W	D3,D0		; dpasse  gauche ?	JUMP',LT LEFT3$	COMP.W	D3,D2		; dpasse  droite ?	JUMP',GE LEFT3$	COMP.W	D4,A0		; dpasse en haut ?	JUMP',LT LEFT3$	COMP.W	D4,A2		; dpasse en bas ?	JUMP',GE LEFT3$	TEST.B	(A1):D1	JUMP,BS FOUND$LEFT3$:	MOVEA_DECX		; A1/D1 <-- x-1	DEC.W	D3		; D3 <-- x-1	DECJ.W,NMO D6,LEFT2$; Avance vers le haut.	LOAD.W	D6,D5UP2$:	COMP.W	D3,D0		; dpasse  gauche ?	JUMP',LT UP3$	COMP.W	D3,D2		; dpasse  droite ?	JUMP',GE UP3$	COMP.W	D4,A0		; dpasse en haut ?	JUMP',LT UP3$	COMP.W	D4,A2		; dpasse en bas ?	JUMP',GE UP3$	TEST.B	(A1):D1	JUMP,BS FOUND$UP3$:	MOVEA_DECY		; A1/D1 <--y-1	DEC.W	D4		; D3 <-- y-1	DECJ.W,NMO D6,UP2$; Incrmente encore une fois (total = 2) le paramtre "i".	INC.W	D5		; D5 <-- i+1	COMP.W	D5,#100	JUMP,LO SPIRAL$	LOAD.W	D7,#1		; D7 <-- pas trouv	JUMP'	EXIT$FOUND$:	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- point trouv (y;x)	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0,D1,D2,D3,D5,D6,A0,A1,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; MOVEPUT >;--------/; Met un point dans le rsultat.; in	D3.L	point dpart (y;x);	D4.L	point arrive (y;x); out	-; mod	D7.WMOVEPUT:	PUSHM.L	D0,D3,D4,A0	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LOAD.L	A0,(A6)+OMVPTI	LOAD.B	D0,D3	NOT.B	D0	SR.W	D3,#3		; dcale coordonne X	ADD.W	A0,D3	SWAP.W	D3	LOAD.W	D4,A3		; D4 <-- Iy	MUL.WU	D3,D4		; dcale coordonne Y	ADD.L	A0,D3		; A0 <-- ^bitmap	TSET.B	(A0):D0	POPM.L	D0,D3,D4,A0	RET;--------\\; MOVEPB  >;--------/; ; in	D3.L	coordonne (y;x);	A0.L	^matrice;	A3.W	Iy; out	A0/D0	point (^/bit); mod	D0.L, A0.LMOVEPB:	PUSHM.L	D3,D4	LOAD.B	D0,D3	NOT.B	D0	AND.W	D0,#B'111	; D0 <-- no du bit dans le byte	SR.W	D3,#3		; dcale coordonne X	ADD.W	A0,D3	SWAP.W	D3	LOAD.W	D4,A3		; D4 <-- Iy	MUL.WU	D3,D4		; dcale coordonne Y	ADD.L	A0,D3		; A0 <-- ^bitmap	POPM.L	D3,D4	RET	.END