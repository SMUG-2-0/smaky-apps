	.SBTTL	FILMDRAWDODRAW:	LIB	?AFTIM	.B	EOP		; efface tout	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	LIB	?AFTIM	.B	MAPTT	.B	B'00000001	; <map>	.B	1		; <chelle>	.B	0	.EVEN	CLR.L	D3	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#1	LOAD.W	D4,(A0)+ODFDY	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT!TTTDOT	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFDY	SR.W	D3,#1	SWAP.W	D3	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFDX	LOAD.W	D2,#SETDOT!TTTDOT	LIB	?DRSEG	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	; <map>	.B	1		; <chelle>	.B	0	.EVEN	LOAD.L	D3,(A6)+OMVP1	LOAD.L	D4,(A6)+OMVP2	LOAD.W	D2,#SETDOT!TTTDOT	CALL	DRAWOBJ		; dessine l'ancien objet en pointill	LOAD.W	D4,(A6)+OMVOBJ	CALL	DBOXDRAW	; demande l'objet ...	JUMP,NE DOMAIN	COMP.W	D3,#F1	JUMP,NE DOMAIN	LOAD.W	(A6)+OMVOBJ,D4	JUMP,EQ DOMAIN	LOAD.L	A3,#R16"TMENU_DRAW	LIB	?AFMENU	CALL	DRAWTITLELOOP$:	LIB	?GETCAR		; attend une action ...	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ DOMAIN	COMP.W	D3,#F0+SHIFT	JUMP,EQ DOMAIN	COMP.W	D3,#END	JUMP,EQ DOMAINBIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	CALL	IFMOUSE	JUMP,NE BIP$	LOAD.L	(A6)+OMVP1,D4	LOAD.L	(A6)+OMVP2,D4DRAW$:	LIB	?GETKEY		; attend un dplacement de la souris ...	COMP.W	D3,#KEYMPO	JUMP,NE END$	CALL	IFMOUSE	JUMP,NE DRAW$	LOAD.L	D1,D4	LOAD.L	D4,(A6)+OMVP2	LOAD.L	D3,(A6)+OMVP1	LOAD.W	D2,#INVDOT	CALL	DRAWOBJ		; efface l'ancien objet	LOAD.L	D4,D1	LOAD.L	(A6)+OMVP2,D4	CALL	DRAWOBJ		; dessine le nouvel objet	CALL	DRAWINFO	; dessine les informations	JUMP	DRAW$END$:	JUMP	DOMAIN;----------\\; DRAWTITLE >;==========/; ; in	-; out	-; mod	D7.WDRAWTITLE:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#R16"LINE$	COMP.W	(A6)+OMVOBJ,#1	JUMP,EQ 10$	COMP.W	(A6)+OMVOBJ,#2	JUMP,EQ 10$	LOAD.L	A3,#R16"ELLI$10$:	LOAD.L	A4,A3	LOAD.W	D3,#-120$:	INC.W	D3	TEST.B	(A4+)	JUMP,NE 20$	MUL.WU	D3,(A0)+ODFCX	; D3 <-- largeur du texte	SUB.W	D3,(A0)+ODFDX	NEG.W	D3	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,(A0)+ODFCY	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTEXT	POPM.L	D3,D4,A3,A4	RETLINE$:	.ASCIZ	"Dessinez une droite avec la souris ..."ELLI$:	.ASCIZ	"Dessinez une ellipse avec la souris ..."	.EVEN;--------\\; DRAWOBJ >;========/; Dessine un objet pour le mouvement.; in	D3.L	P1 (y;x);	D4.L	P2 (y;x);	D2.W	mode; out	-; mod	D7.WDRAWOBJ:	PUSHM.L	D1..D4	COMP.L	D3,D4	JUMP,EQ 90$	LOAD.W	D1,(A6)+OMVOBJ	JUMP,EQ 90$	COMP.W	D1,#1	JUMP,EQ 40$	COMP.W	D1,#2	JUMP,EQ 40$	SUB.W	D4,D3	JUMP,NC 20$	NEG.W	D420$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP,NC 22$	NEG.W	D422$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,#-1	LIB	?DRELLIPSE	PUSH.L	D3	SUB.W	D3,#10	LOAD.L	D4,#10+10	LIB	?DRSEG	POP.L	D3	SWAP.W	D3	SUB.W	D3,#10	SWAP.W	D3	LOAD.W	D4,#10+10	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	JUMP	90$40$:	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG90$:	POPM.L	D1..D4	RET;---------\\; DRAWINFO >;=========/; ; in	D3.L	P1 (y;x);	D4.L	P2 (y;x); out	-; mod	D7.WDRAWINFO:	PUSHM.L	D1..D4	SUB.W	D3,D4	JUMP,NC 10$	NEG.W	D310$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	JUMP,NC 12$	NEG.W	D312$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	D1,D3	LOAD.W	D3,(A0)+ODFDY	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#6+1+6	SUB.W	D3,D4	SR.W	D3,#1	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"dX="	.EVEN	CLR.L	D4	LOAD.W	D4,D1	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDALL	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" dY="	.EVEN	LOAD.L	D4,D1	CLR.W	D4	SWAP.W	D4	LOAD.W	D3,#3	LOAD.W	D2,#2^BAFDALL	LIB	?AFDEC	POPM.L	D1..D4	RET;--------\\; CALCPOS >;========/; ; in	D5.W	numro de la position; out	D2.L	position (y;x); mod	D2.L, D7.WCALCPOS:	COMP.W	(A6)+OMVOBJ,#1	JUMP,EQ 20$	COMP.W	(A6)+OMVOBJ,#2	JUMP,EQ 20$	COMP.W	(A6)+OMVOBJ,#3	JUMP,EQ 30$	COMP.W	(A6)+OMVOBJ,#4	JUMP,EQ 30$	CLR.L	D2	JUMP	90$20$:	CALL	CALCPOSLINE	JUMP	90$30$:	CALL	CALCPOSELLI	JUMP	90$90$:	RET;------------\\; CALCPOSLINE >;------------/; ; in	D5.W	numro de la position; out	D2.L	position (y;x); mod	D2.L, D7.WCALCPOSLINE:	PUSHM.L	D3..D5	PUSH.L	(A6)+OMVP1	PUSH.L	(A6)+OMVP2	LOAD.L	D3,(A6)+OMVP1	LOAD.L	D4,(A6)+OMVP2	SUB.W	D4,D3	JUMP,NC 10$	NEG.W	D4		; D4 <-- |dx|10$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	JUMP,NC 12$	NEG.W	D3		; D3 <-- |dy|12$:	SWAP.W	D4	COMP.W	D3,D4	JUMP,HI 50$				; droite plutt horizontale =>	CLR.L	D2	TEST.W	D4	JUMP,EQ 90$	AND.L	D5,#H'FFFF	DIV.WU	D5,D4	COMP.W	(A6)+OMVOBJ,#2	JUMP,NE 30$	TEST.L	D5:#0	JUMP,BC 30$	LOAD.L	D4,(A6)+OMVP1	LOAD.L	(A6)+OMVP1,(A6)+OMVP2	LOAD.L	(A6)+OMVP2,D430$:	SWAP.W	D5	LOAD.W	D4,(A6)+OMVP2+2	COMP.W	D4,(A6)+OMVP1+2	JUMP,HS 32$	NEG.W	D532$:	CLR.L	D2	LOAD.W	D2,D5	LOAD.W	D4,(A6)+OMVP2+0	SUB.W	D4,(A6)+OMVP1+0	MUL.WA	D5,D4	LOAD.W	D4,(A6)+OMVP2+2	SUB.W	D4,(A6)+OMVP1+2	JUMP,EQ 70$	DIV.WA	D5,D4	SWAP.W	D2	LOAD.W	D2,D5	SWAP.W	D2	JUMP	70$50$:				; droite plutt verticale =>	CLR.L	D2	TEST.W	D3	JUMP,EQ 90$	AND.L	D5,#H'FFFF	DIV.WU	D5,D3	COMP.W	(A6)+OMVOBJ,#2	JUMP,NE 60$	TEST.L	D5:#0	JUMP,BC 60$	LOAD.L	D4,(A6)+OMVP1	LOAD.L	(A6)+OMVP1,(A6)+OMVP2	LOAD.L	(A6)+OMVP2,D460$:	SWAP.W	D5	LOAD.W	D4,(A6)+OMVP2+0	COMP.W	D4,(A6)+OMVP1+0	JUMP,HS 62$	NEG.W	D562$:	LOAD.W	D2,D5	SWAP.W	D2	CLR.W	D2	LOAD.W	D4,(A6)+OMVP2+2	SUB.W	D4,(A6)+OMVP1+2	MUL.WA	D5,D4	LOAD.W	D4,(A6)+OMVP2+0	SUB.W	D4,(A6)+OMVP1+0	JUMP,EQ 70$	DIV.WA	D5,D4	LOAD.W	D2,D5	JUMP	70$70$:	ADD.W	D2,(A6)+OMVP1+2	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#1	SUB.W	D2,D3	SWAP.W	D2	ADD.W	D2,(A6)+OMVP1+0	LOAD.W	D3,(A0)+ODFDY	SR.W	D3,#1	SUB.W	D2,D3	SWAP.W	D290$:	POP.L	(A6)+OMVP2	POP.L	(A6)+OMVP1	POPM.L	D3..D5	RET;------------\\; CALCPOSELLI >;------------/; ; in	D5.W	numro de la position; out	D2.L	position (y;x); mod	D2.L, D7.WCALCPOSELLI:	PUSHM.L	D1,D3..D5	AND.L	D5,#H'FFFF	DIV.WU	D5,#360	SWAP.W	D5	LOAD.W	D1,D5	COMP.W	(A6)+OMVOBJ,#3	JUMP,EQ 20$	SUB.W	D1,#360	NEG.W	D120$:	LOAD.L	D3,(A6)+OMVP1	LOAD.L	D4,(A6)+OMVP2	SUB.W	D4,D3	JUMP,NC 30$	NEG.W	D430$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP,NC 32$	NEG.W	D432$:	SWAP.W	D3	SWAP.W	D4	LIB	?CALCPELLI	LOAD.L	D2,D5	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#1	SUB.W	D2,D3	SWAP.W	D2	LOAD.W	D3,(A0)+ODFDY	SR.W	D3,#1	SUB.W	D2,D3	SWAP.W	D2	POPM.L	D1,D3..D5	RETTMENU_DRAW:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN	.END