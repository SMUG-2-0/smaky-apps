	.SBTTL	FILMIO;--------\\; WRFILM  >;========/; Ecrit tout le film sur disque.; in	-; out	D7.W	erreur; mod	D7.WWRFILM:	PUSHM.L	D2..D6,A2..A4	LOAD.L	D5,#B'1		; D5 <-- fanions10$:	LOAD.L	A3,#(A6)+OBUNAM	LOAD.L	D4,D5	CALL	DBOXEDITO	; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F0	JUMP,EQ 90$	LOAD.W	D2,D3		; D2 <-- F1/F4	LOAD.L	D5,D4		; D5 <-- fanions	TEST.L	D5:#0		; sauve les images de transition ?	JUMP,BC 12$		; non => 12$	CALL	TRANSCREATE	; gnre les images intermdiaires12$:	CALL	WAITMOUSE	; met le sablier	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier .FILM	JUMP,EQ 20$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE 90$	COMP.W	D2,#F4		; touche (MET A JOUR) ?	JUMP,EQ 15$		; oui => 15$	CALL	NORMMOUSE	; remet la flche	CALL	DBOXBEGIN	; prpare pour afficher une dbox	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	CALL	DBOXEND		; remet en tat aprs l'affichage d'une dbox	TEST.W	D7	JUMP,NE 90$	COMP.W	D3,#'O	JUMP,NE 10$15$:	FOS	?DELETE		; dtruit le fichier	JUMP,NE 90$	JUMP	12$20$:	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier .FILM	JUMP,NE 90$	CALL	HEADWRITE	; crit l'en-tte	JUMP,NE 80$	CALL	PRGWRITE	; crit le script	JUMP,NE 80$	LOAD.L	A4,#(A6)+OTAIMA	LOAD.W	D4,(A6)+ONBIMA30$:	LOAD.L	A2,(A4+)	; A2 <-- ^image	CALL	IMAGEFWRITE	; crit une image	JUMP,NE 80$	DEC.W	D4	JUMP,NE 30$	TEST.L	D5:#0		; sauve les images de transition ?	JUMP,BC 80$		; non => 80$	LOAD.L	A4,#(A6)+OTIIMA	LOAD.W	D4,#MAXIIMA40$:	TEST.L	(A4+)	JUMP,EQ 45$	LOAD.L	A2,(A4)-4	; A2 <-- ^image	CALL	IMAGEFWRITE	; crit une image	JUMP,NE 80$45$:	DEC.W	D4	JUMP,NE 40$80$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier .FILM	POP.W	D790$:	POPM.L	D2..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; HEADWRITE >;----------/; Ecrit l'en-tte.; in	D6.W	canal FOS; out	D7.W	erreur; mod	D7.WHEADWRITE:	PUSHM.L	D3,D4,A4	LOAD.L	A4,#(A6)+OHF+LHF	LOAD.W	D4,#(LHF/2)-110$:	CLR.W	(-A4)	DECJ.W,NMO D4,10$	LOAD.W	(A4)+OHFTYP,#-1	LOAD.W	(A4)+OHFVITA,(A6)+OVITA	LOAD.W	(A4)+OHFVITM,(A6)+OVITM	LOAD.W	(A4)+OHFOBJ,(A6)+OMVOBJ	LOAD.B	(A4)+OHFDPL,(A6)+ODPL	LOAD.W	D3,(A0)+ODFDY	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#1	LOAD.L	D4,(A6)+OMVP1	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A4)+OHFP1,D4	LOAD.L	D4,(A6)+OMVP2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A4)+OHFP2,D4	LOAD.L	D4,#LHF	FOS	?WRBYTE		; crit l'en-tte	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; PRGWRITE >;---------/; Ecrit le script.; in	D6.W	canal FOS; out	D7.W	erreur; mod	D7.WPRGWRITE:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+ONBPRG	CLR.L	D4	LOAD.W	D4,(A4)	ADD.W	D4,#2	FOS	?WRBYTE	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IMAGEFWRITE >;-----------/; Ecrit une image dans un fichier .FILM; in	D6.W	canal;	A2.L	^image; out	D7.W	erreur; mod	D7.WIMAGEFWRITE:	PUSHM.L	D3,D4,A1..A4	LOAD.L	A1,A2		; A1 <-- ^image	LOAD.L	A2,#(A1)+LHV	; A2 <-- ^en-tte;;?	LOAD.W	D3,(A2)+OIMDLX;;?	ADD.W	D3,#8+1;;?	SR.W	D3,#3;;?	MUL.WU	D3,(A2)+OIMDLY;;?	LOAD.L	(A2)+OIMNBB,D3	LOAD.L	A3,(A1)+OHVPI	; A3 <-- ^image dcode	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^pour image code	GRA_	CODEIMA		; code l'image ...	JUMP,NE 50$; Ecrit une image code.	LOAD.L	A4,A1	LOAD.L	D4,#LHV+LGHIMA	FOS	?WRBYTE		; crit l'en-tte	JUMP,NE 40$	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^image code	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- nb total de bytes	FOS	?WRBYTE		; crit l'image code40$:	PUSH.W	D7	LOAD.L	A4,#(A3)-IMLBUF	; A4 <-- ^image code	GRA_	DECOIMA		; re-dcode l'image !	POP.W	D7	JUMP	90$; Ecrit une image telle quelle, c'est--dire dcode.50$:	LOAD.L	A4,A1	LOAD.L	D4,#LHV+LGHIMA	FOS	?WRBYTE		; crit l'en-tte	JUMP,NE 90$	LOAD.L	A4,A3		; A4 <-- ^matrice principale	LOAD.L	D4,D3		; D4 <-- nb total de bytes	FOS	?WRBYTE		; crit le data de l'image90$:	POPM.L	D3,D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; OPFILM  >;========/; Lit tout le film sur disque.; in	A3.L	^nom d'un fichier .FILM; out	D7.W	erreur; mod	D7.WOPFILM:	PUSHM.L	D2..D6,A2..A4	CALL	WAITMOUSE	; met le sablier	CALL	CLIMAGES	; libre toutes les images	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier .FILM	JUMP,NE 90$	CALL	HEADREAD	; lit l'en-tte	JUMP,EQ 20$	COMP.W	D7,#ERBINA	JUMP,NE 80$	CALL	OPFILMOLD	; lit un ancien fichier .FILM	JUMP	90$20$:	CALL	PRGOPEN		; lit le script	JUMP,NE 80$	LOAD.L	A4,#(A6)+OTAIMA	CLR.W	(A6)+ONBIMA30$:	CALL	IMAGEFOPEN	; lit une image	JUMP,NE 70$	LOAD.L	D4,(A2)+OHVNO	; D4 <-- numro de l'image	COMP.L	D4,#H'00000080	JUMP,HS 40$	LOAD.L	(A4+),A2	INC.W	(A6)+ONBIMA	JUMP	30$40$:	LOAD.L	A4,#(A6)+OTIIMA42$:	LOAD.L	(A4+),A2	CALL	IMAGEFOPEN	; lit une image	JUMP,EQ 42$70$:	COMP.W	D7,#EROUTF	JUMP,NE 80$	FOS	?CLOSE		; ferme le fichier .FILM	JUMP	90$80$:	PUSH.W	D7	CALL	CLIMAGES	; libre toutes les images	CLR.W	(A6)+ONBPRG	FOS	?CLOSE		; ferme le fichier .FILM	POP.W	D790$:	POPM.L	D2..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; HEADREAD >;---------/; Lit l'en-tte.; in	D6.W	canal; out	D7.W	erreur; mod	D7.WHEADREAD:	PUSHM.L	D2..D4,A2,A4	LOAD.L	A4,#(A6)+OHF	LOAD.L	D4,#LHF	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 90$	LOAD.W	D7,#ERBINA	COMP.W	(A4)+OHFTYP,#-1	JUMP,NE 90$	LOAD.W	(A6)+OVITA,(A4)+OHFVITA	TEST.W	(A6)+OVITA	JUMP,NE 30$	LOAD.L	A2,#R16"TAVITA	CALL	VITMOYE	LOAD.W	(A6)+OVITA,D230$:	LOAD.W	(A6)+OVITM,(A4)+OHFVITM	TEST.W	(A6)+OVITM	JUMP,NE 32$	LOAD.L	A2,#R16"TAVITM	CALL	VITMOYE	LOAD.W	(A6)+OVITM,D232$:	LOAD.W	(A6)+OMVOBJ,(A4)+OHFOBJ	LOAD.B	(A6)+ODPL,(A4)+OHFDPL	LOAD.W	D3,(A0)+ODFDY	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#1	LOAD.L	D4,(A4)+OHFP1	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	HEADREADCP	LOAD.L	(A6)+OMVP1,D4	LOAD.L	D4,(A4)+OHFP2	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	HEADREADCP	LOAD.L	(A6)+OMVP2,D4	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; HEADREADCP >;-----------/; Ramne un point dans l'cran.; in	D4.L	points; out	D4.L	points; mod	D4.LHEADREADCP:	TEST.W	D4	JUMP,NC 10$	CLR.W	D410$:	COMP.W	D4,(A0)+ODFDX	JUMP,LO 12$	LOAD.W	D4,(A0)+ODFDX12$:	SWAP.W	D4	TEST.W	D4	JUMP,NC 20$	CLR.W	D420$:	COMP.W	D4,(A0)+ODFDY	JUMP,LO 22$	LOAD.W	D4,(A0)+ODFDY22$:	SWAP.W	D4	RET;--------\\; PRGOPEN >;--------/; Lit le script.; in	D6.W	canal; out	D7.W	erreur; mod	D7.WPRGOPEN:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+ONBPRG	LOAD.L	D4,#2	FOS	?RDBYTE	JUMP,NE 90$	LOAD.W	D7,#ERBINA	CLR.L	D4	LOAD.W	D4,(A6)+ONBPRG	COMP.W	D4,#MAXPRG	JUMP,HS 90$	LOAD.L	A4,#(A6)+OTAPRG	FOS	?RDBYTE90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; OPFILMOLD >;----------/; Lit un ancien fichier .FILM; in	D6.W	canal FOS; out	D7.W	erreur; mod	D7.WOPFILMOLD:	PUSHM.L	D3,D4,D6,A2..A4	CLR.L	D4	CLR.W	D3	FOS	?SPOS		; revient au dbut	JUMP,NE 80$	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D4,#2	FOS	?RDBYTE		; lit la longueur	JUMP,NE 80$	CLR.L	D4	LOAD.W	D4,(A4)	JUMP,EQ 20$	SL.L	D4,#2	ADD.L	D4,#2	CLR.W	D3	FOS	?SPOS		; saute la table des mouvements	JUMP,NE 80$20$:	LOAD.L	A4,#(A6)+OTAIMA	CLR.W	(A6)+ONBIMA	LOAD.L	A3,#(A6)+OTAPRG	CLR.W	(A6)+ONBPRG	CLR.L	D450$:	CALL	IMAGEOPEN	; lit une image	JUMP',NE 55$	LOAD.L	(A2)+OHVNO,D4	; OHVNO <-- numro de l'image	LOAD.L	(A4+),A2	INC.W	(A6)+ONBIMA	LOAD.B	(A3+),D4	INC.B	D4	INC.W	(A6)+ONBPRG	JUMP	50$55$:	FOS	?CLOSE		; ferme le .FILM	JUMP	90$80$:	PUSH.W	D7	CALL	CLIMAGES	; libre toutes les images	CLR.W	(A6)+ONBPRG	FOS	?CLOSE		; ferme le .FILM	POP.W	D790$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; OPIMAGES >;=========/; Lit toutes les images ayant le mme nom suivi d'un numro de 2 digits.; in	A3.L	^nom d'un fichier .IMAGE; out	D7.W	erreur; mod	D7.WOPIMAGES:	PUSHM.L	D3,D4,D6,A1..A4	CALL	WAITMOUSE	; met le sablier	CALL	CLIMAGES	; libre toutes les images	LOAD.L	A4,#(A6)+OBUREP10$:	LOAD.B	(A4+),(A3+)	; OBUREP <-- rpertoires	JUMP,NE 10$	LOAD.L	A3,#(A6)+OBUREP	CALL	SKIPREP	LOAD.L	A4,#(A6)+OBUCRI20$:	LOAD.B	(A4+),(A3+)	; OBUCRI <-- nom	JUMP,NE 20$	LOAD.L	A3,#(A6)+OBUCRI	CALL	GETINUM	LOAD.B	(A3+),#'?	LOAD.B	(A3+),#'?	LOAD.B	(A3+),#'.	LOAD.B	(A3+),#'I	LOAD.B	(A3+),#'M	LOAD.B	(A3+),#'A	LOAD.B	(A3+),#'G	LOAD.B	(A3+),#'E	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBUREP	CALL	SKIPREP	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBUREP	; A3 <-- ^rpertoires	LOAD.L	A4,#(A6)+OBUCRI	; A4 <-- ^critre	CLR.L	D3		; D3 <-- mode	FOS	?LISTOPEN	; D6 <-- canal	JUMP,NE 90$	LOAD.L	A1,#(A6)+OTAIMA	CLR.W	(A6)+ONBIMA40$:	FOS	?LISTNXT	; A3/A4 <-- ^nom/^arguments	JUMP',NE 60$	CALL	OPIMAGE		; lit une image	JUMP,NE 40$	LOAD.L	(A1+),A2	; OTAIMA <-- ^image	INC.W	(A6)+ONBIMA	JUMP	40$60$:	FOS	?LISTCLOSE90$:	POPM.L	D3,D4,D6,A1..A4	RET;--------\\; OPIMAGE >;--------/; Lit une image.; in	A3.L	^nom de l'image; out	A2.L	^image;	D7.W	erreur; mod	D7.W, A2.LOPIMAGE:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A4,#(A6)+OBUTMP	LOAD.L	A2,#(A6)+OBUREP10$:	LOAD.B	(A4+),(A2+)	; OBUTMP <-- rpertoires	JUMP,NE 10$	DEC.L	A412$:	LOAD.B	(A4+),(A3+)	; OBUTMP <-- nom de l'image	JUMP,NE 12$	LOAD.L	A3,#(A6)+OBUTMP	CALL	SKIPREP	CALL	GETINUM		; D4 <-- numro de l'image	JUMP',NE 90$	LOAD.L	A3,#(A6)+OBUTMP	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE 90$	CALL	IMAGEOPEN	; lit l'image	LOAD.L	(A2)+OHVNO,D4	; OHVNO <-- numro de l'image	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; CLIMAGES >;=========/; Libre toutes les images lues.; in	-; out	-; mod	D7.WCLIMAGES:	PUSHM.L	D4,A2,A4	CALL	TRANSCLOSE	; libre les images intermdiaires	LOAD.L	A4,#(A6)+OTAIMA	LOAD.W	D4,(A6)+ONBIMA	JUMP',EQ 90$20$:	LOAD.L	A2,(A4)	CALL	IMAGECLOSE	CLR.L	(A4+)	DEC.W	D4	JUMP,NE 20$	CLR.W	(A6)+ONBIMA90$:	POPM.L	D4,A2,A4	RET;----------\\; IMAGEOPEN >;==========/; Lit une image sur disque, sans l'afficher.; in	D6.W	canal FOS; out	A2.L	^image;	D7.W	erreur; mod	D7.W, A2.LIMAGEOPEN:	PUSHM.L	D0..D4,A1,A3,A4	FOS	?GPOS	JUMP,NE 90$	LOAD.L	D2,D4		; D2 <-- position actuelle	LOAD.L	D4,#LHV+LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour le nom et l'en-tte	JUMP,NE 90$	LOAD.L	A2,A4		; A2 <-- ^en-tte10$:	CLR.B	(A4+)	DEC.W	D4	JUMP,NE 10$	LOAD.L	A4,#(A2)+LHV	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$	COMP.B	(A2)+LHV+OIMTYP,#H'82 ; image du LAMI ?	JUMP',NE 20$		; non => 20$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	ADD.L	D4,D2	FOS	?SPOS		; saute la stupide en-tte de 256 bytes !	JUMP,NE 82$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$20$:	LOAD.W	D0,(A2)+LHV+OIMDLX ; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+LHV+OIMDLY ; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF+4	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE 82$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	(A2)+OHVPI,A1	LOAD.L	D4,(A2)+LHV+OIMNBB ; D4 <-- longueur  lire	TEST.B	(A2)+LHV+OIMCOD	; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP',NE 80$	JUMP'	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 80$	LOAD.L	A3,A1	PUSH.L	A2	LOAD.L	A2,#(A2)+LHV	; A2 <-- ^en-tte image	GRA_	DECOIMA		; dcode l'image ...	POP.L	A2	TEST.W	D7	JUMP',NE 80$35$:	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D782$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POP.W	D790$:	TEST.W	D7	JUMP',EQ 95$	LOAD.L	A2,#095$:	POPM.L	D0..D4,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IMAGEFOPEN >;===========/; Lit une image contenue dans un fichier .FILM, sans l'afficher.; in	D6.W	canal FOS; out	A2.L	^image;	D7.W	erreur; mod	D7.W, A2.LIMAGEFOPEN:	PUSHM.L	D0..D4,A1,A3,A4	LOAD.L	D4,#LHV+LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour le nom et l'en-tte	JUMP,NE 90$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.L	A4,A2	LOAD.L	D4,#LHV+LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$	LOAD.W	D0,(A2)+LHV+OIMDLX ; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+LHV+OIMDLY ; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF+4	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE 82$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	(A2)+OHVPI,A1	LOAD.L	D4,(A2)+LHV+OIMNBB ; D4 <-- longueur  lire	TEST.B	(A2)+LHV+OIMCOD	; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP',NE 80$	JUMP'	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 80$	LOAD.L	A3,A1	PUSH.L	A2	LOAD.L	A2,#(A2)+LHV	; A2 <-- ^en-tte image	GRA_	DECOIMA		; dcode l'image ...	POP.L	A2	TEST.W	D7	JUMP',NE 80$35$:	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D782$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POP.W	D790$:	TEST.W	D7	JUMP',EQ 95$	LOAD.L	A2,#095$:	POPM.L	D0..D4,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; IMAGEAFF >;=========/; Affiche une image quelconque.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie centrale.; in	A2.L	^image;	D2.L	dcalage (+/- y;x); out	-; mod	D7.WIMAGEAFF:	PUSHM.L	D3,D4,A3	COMP.L	A2,#0	JUMP,EQ 90$	TEST.B	(A6)+OFANION+3:#BNEGATIF	JUMP,BS 12$	TEST.B	(A2)+OHVFL:#BHVINV	JUMP,BC 14$	CALL	IMAGEINV	; met l'image en positif	JUMP	14$12$:	TEST.B	(A2)+OHVFL:#BHVINV	JUMP,BS 14$	CALL	IMAGEINV	; met l'image en ngatif14$:	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la souris	LOAD.L	A3,#(A6)+OBUDIS+1 ; A3 <-- ^buffer pour DRAWRASTER	LOAD.W	D4,(A2)+LHV+OIMDLY ; D4 <-- hauteur de l'image	SWAP.W	D4	LOAD.W	D4,(A2)+LHV+OIMDLX ; D4 <-- largeur de l'image	CALL	IMAGEPOS	; D3/D4 <-- positions cran/image	SWAP.W	D3	LOAD.L	(A3)+11,D3	; destination: <xx> et <yy>	SWAP.W	D4	LOAD.L	(A3)+1,D4	; source: <xx> et <yy>	LOAD.W	D3,(A3)+11	COMP.W	D3,(A0)+ODFFDX	JUMP,HS 50$	LOAD.W	D4,(A2)+LHV+OIMDLX ; D4 <-- largeur de l'image	SUB.W	D4,(A3)+1	JUMP,LE 50$	LOAD.W	D3,(A0)+ODFFDX	SUB.W	D3,(A3)+11	COMP.W	D4,D3	JUMP,LS 20$	LOAD.W	D4,D320$:	LOAD.W	(A3)+21,D4	; image: <dxx>	LOAD.W	D3,(A3)+13	COMP.W	D3,(A0)+ODFFDY	JUMP,HS 50$	LOAD.W	D4,(A2)+LHV+OIMDLY ; D4 <-- hauteur de l'image	SUB.W	D4,(A3)+3	JUMP,LE 50$	LOAD.W	D3,(A0)+ODFFDY	SUB.W	D3,(A3)+13	COMP.W	D4,D3	JUMP,LS 25$	LOAD.W	D4,D325$:	LOAD.W	(A3)+23,D4	; image: <dyy>	LOAD.W	D3,(A2)+LHV+OIMDLX ; D3 <-- largeur de l'image	SR.W	D3,#3	LOAD.W	(A3)+9,D3	; source: <ii>	CLR.W	(A3)+19		; destination: <ii>	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+5,(A2)+OHVPI ; source: <pppp>	CLR.L	(A3)+15		 ; destination: <pppp>	LOAD.B	(A3)+25,#LOADDOT ; image: <mode>	LOAD.W	D3,#26		; D3 <-- longueur	LIB	?STRING		; affiche l'image50$:	TEST.W	(A6)+OMVOBJ	JUMP,EQ 80$	TEST.B	(A6)+ODPL:#BDPLTRA	JUMP,BS 80$	LOAD.L	D3,(A3)+11	SWAP.W	D3	LOAD.L	D4,(A3)+21	SWAP.W	D4	CALL	CLEARPLUS	; efface le surplus80$:	LOAD.B	D3,#AFSCMO	LIB	?AFCAR		; remet la souris90$:	POPM.L	D3,D4,A3	RET;---------\\; IMAGEPOS >;---------/; Calcule la position dans l'cran et dans l'image.; in	D2.L	dcalage (+/- y;x);	D4.L	dimensions de l'image (dy;dx); out	D3.L	position dans l'cran (y;x);	D4.L	position dans l'image (y;x); mod	D3.L, D4.L, D7.WIMAGEPOS:	LOAD.W	D3,(A0)+ODFFDX	SR.W	D3,#1	ADD.W	D3,D2	SR.W	D4,#1	SUB.W	D3,D4	CLR.W	D4	TEST.W	D3	JUMP,NC 20$	NEG.W	D3	LOAD.W	D4,D3	CLR.W	D320$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A0)+ODFFDY	SR.W	D3,#1	ADD.W	D3,D2	SR.W	D4,#1	SUB.W	D3,D4	CLR.W	D4	TEST.W	D3	JUMP,NC 40$	NEG.W	D3	LOAD.W	D4,D3	CLR.W	D340$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	RET;----------\\; IMAGESHOW >;==========/; Affiche une image en petit.; in	A2.L	^image;	D2.L	fanions; out	-; mod	D7.WIMAGESHOW:	PUSHM.L	D1..D5,A0..A4	TEST.L	D2:#BAFIMA	JUMP,BC 70$	COMP.L	A2,#0	JUMP,EQ 70$	TEST.B	(A2)+OHVFL:#BHVINV	JUMP,BC 10$	CALL	IMAGEINV	; met l'image en positif10$:	TEST.L	(A6)+OSIPTM	JUMP',NE 20$	LOAD.W	D4,(A6)+OSIDIM+2	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	MUL.WU	D4,(A6)+OSIDIM+0	ADD.L	D4,#200		; ?	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE 70$	LOAD.L	(A6)+OSIPTM,A420$:	LOAD.L	A4,(A6)+OSIPTM	LOAD.W	D4,(A6)+OSIDIM+2	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	MUL.WU	D4,(A6)+OSIDIM+0	SR.L	D4,#230$:	CLR.L	(A4+)		; efface tout	DECJ.W,NMO D4,30$	LOAD.L	A1,A0		; A1 <-- ^descripteur	LOAD.L	A0,#(A6)+OSTRETCH	LOAD.L	(A0)+OSTRSPT,(A2)+OHVPI	LOAD.W	D4,(A2)+LHV+OIMDLX	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.W	(A0)+OSTRSDX,D4;	CLR.L	(A0)+OSTRS0	LOAD.W	D4,(A2)+LHV+OIMDLY	DEC.W	D4	SWAP.W	D4	LOAD.W	D4,(A2)+LHV+OIMDLX	DEC.W	D4	LOAD.L	(A0)+OSTRS2,D4	LOAD.L	(A0)+OSTRDPT,(A6)+OSIPTM	LOAD.W	D4,(A6)+OSIDIM+2	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	LOAD.W	(A0)+OSTRDDX,D4	LOAD.W	D4,(A6)+OSIDIM+2	DEC.W	D4	LOAD.W	(A0)+OSTRD1+2,D4	LOAD.W	(A0)+OSTRD2+2,D4	LOAD.W	D4,(A6)+OSIDIM+0	DEC.W	D4	LOAD.W	(A0)+OSTRD2+0,D4	LOAD.W	(A0)+OSTRD3+0,D4	ST_	RECT		; et hop ...	LOAD.L	A3,(A0)+OSTRDPT	; A3 <-- ^source	CLR.L	D3		; D3 <-- position source	LOAD.W	D5,(A0)+OSTRDDX	; D5 <-- Iy source	LOAD.L	A4,#0		; A4 <-- ^destination (dans l'cran)	LOAD.L	D4,(A6)+OSIPOS	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4		; D4 <-- position destination	LOAD.L	D2,(A0)+OSTRD2	; D2 <-- dimensions	LOAD.W	D1,#LOADDOT	; D1 <-- mode	LOAD.L	A2,A1		; A2 <-- ^descripteur	LOAD.L	A0,(A6)+ORAST	CALL	(A0)		; appel de GRA_RASTER	JUMP	90$70$:	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A6)+OSIPOS	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.L	D4,(A6)+OSIDIM	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface l'ancienne image90$:	POPM.L	D1..D5,A0..A4	RET;---------\\; IMAGEINV >;---------/; Inverse une image.; in	A2.L	^image; out	-; mod	D7.WIMAGEINV:	PUSHM.L	D3,D4,A3	LOAD.W	D3,(A2)+LHV+OIMDLX	ADD.W	D3,#8-1	SR.W	D3,#3	MUL.WU	D3,(A2)+LHV+OIMDLY	LOAD.L	A3,(A2)+OHVPI	LOAD.L	D4,D3	SR.L	D3,#2		; D3 <-- /4 car .L	DEC.W	D3		; D3 <-- -1 car NMO20$:	NOT.L	(A3+)	DECJ.W,NMO D3,20$	AND.W	D4,#B'1130$:	DEC.W	D4	JUMP,NS 40$	NOT.B	(A3+)	JUMP	30$40$:	TNOT.B	(A2)+OHVFL:#BHVINV	POPM.L	D3,D4,A3	RET;-----------\\; IMAGECLOSE >;===========/; Libre la mmoire utilise par une image.; in	A2.L	^image; out	-; mod	D7.WIMAGECLOSE:	PUSHM.L	D1,A1,A4	COMP.L	A2,#0	JUMP',EQ 90$	LOAD.L	A1,(A2)+OHVPI	; A1 <-- ^image	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	LOAD.L	A4,A2;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete90$:	POPM.L	D1,A1,A4	RET;----------\\; CLEARPLUS >;==========/; Efface le surplus d'une zone rectangulaire.; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WCLEARPLUS:	PUSHM.L	D1..D6	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	CLIPRECT	; clipping	JUMP',EQ NOCLIP$	LOAD.L	D3,#-1	LOAD.L	D4,D3NOCLIP$:	LOAD.L	D5,D3		; D5 <-- new P1(y;x)	LOAD.L	D6,D4		; D6 <-- new P2(y;x)	TEST.L	(A6)+OCLRP1	JUMP',NE CLIP$	TEST.L	(A6)+OCLRP2	JUMP,EQ EXIT$CLIP$:	COMP.L	(A6)+OCLRP1,#-1	JUMP',NE JUSTOLD$	COMP.L	D5,#-1	JUMP,EQ EXIT$	LOAD.L	D3,D5	LOAD.L	D4,D6	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4;;?	CALL	CLEARTRAME	; allume la nouvelle zone	JUMP	EXIT$JUSTOLD$:	COMP.L	D5,#-1	JUMP',NE IFSEP$	LOAD.L	D3,(A6)+OCLRP1	LOAD.L	D4,(A6)+OCLRP2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	CLEARTRAME	; efface l'ancienne zone	JUMP	EXIT$IFSEP$:	LOAD.L	D3,D5	COMP.W	D3,(A6)+OCLRP2+2	JUMP',HS SEP$	SWAP.W	D3	COMP.W	D3,(A6)+OCLRP2+0	JUMP',HS SEP$	LOAD.L	D3,D6	COMP.W	D3,(A6)+OCLRP1+2	JUMP',LS SEP$	SWAP.W	D3	COMP.W	D3,(A6)+OCLRP1+0	JUMP,HI CLR1$SEP$:	LOAD.L	D3,(A6)+OCLRP1	LOAD.L	D4,(A6)+OCLRP2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	CLEARTRAME	; efface l'ancienne zone	LOAD.L	D3,D5	LOAD.L	D4,D6	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4;;?	CALL	CLEARTRAME	; allume la nouvelle zone	JUMP	EXIT$CLR1$:	LOAD.W	D3,(A6)+OCLRP1+0	SWAP.W	D5	LOAD.W	D4,D5	SWAP.W	D5	SUB.W	D4,D3	JUMP',LE CLR2$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OCLRP1+2	LOAD.W	D4,(A6)+OCLRP2+2	SUB.W	D4,D3	JUMP',LE CLR2$	CALL	CLEARTRAME	; efface la zone (1)CLR2$:	SWAP.W	D5	LOAD.W	D3,D5	SWAP.W	D5	COMP.W	D3,(A6)+OCLRP1+0	JUMP',HS CLR2A$	LOAD.W	D3,(A6)+OCLRP1+0CLR2A$:	SWAP.W	D6	LOAD.W	D4,D6	SWAP.W	D6	COMP.W	D4,(A6)+OCLRP2+0	JUMP',LS CLR2B$	LOAD.W	D4,(A6)+OCLRP2+0CLR2B$:	SUB.W	D4,D3	JUMP',LE CLR3$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OCLRP1+2	LOAD.W	D4,D5	SUB.W	D4,D3	JUMP',LE CLR3$	CALL	CLEARTRAME	; efface la zone (2)CLR3$:	SWAP.W	D5	LOAD.W	D3,D5	SWAP.W	D5	COMP.W	D3,(A6)+OCLRP1+0	JUMP',HS CLR3A$	LOAD.W	D3,(A6)+OCLRP1+0CLR3A$:	SWAP.W	D6	LOAD.W	D4,D6	SWAP.W	D6	COMP.W	D4,(A6)+OCLRP2+0	JUMP',LS CLR3B$	LOAD.W	D4,(A6)+OCLRP2+0CLR3B$:	SUB.W	D4,D3	JUMP',LE CLR4$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,D6	LOAD.W	D4,(A6)+OCLRP2+2	SUB.W	D4,D3	JUMP',LE CLR4$	CALL	CLEARTRAME	; efface la zone (3)CLR4$:	SWAP.W	D6	LOAD.W	D3,D6	SWAP.W	D6	LOAD.W	D4,(A6)+OCLRP2+0	SUB.W	D4,D3	JUMP',LE SET1$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OCLRP1+2	LOAD.W	D4,(A6)+OCLRP2+2	SUB.W	D4,D3	JUMP',LE SET1$	CALL	CLEARTRAME	; efface la zone (4)SET1$:	SWAP.W	D5	LOAD.W	D3,D5	SWAP.W	D5	LOAD.W	D4,(A6)+OCLRP1+0	SUB.W	D4,D3	JUMP',LE SET2$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,D5	LOAD.W	D4,D6	SUB.W	D4,D3;;?	JUMP',LE SET2$;;?	CALL	CLEARTRAME	; allume la zone (1)SET2$:	LOAD.W	D3,(A6)+OCLRP1+0	LOAD.L	D1,D5	SWAP.W	D1	COMP.W	D3,D1	JUMP',HS SET2A$	LOAD.W	D3,D1SET2A$:	LOAD.W	D4,(A6)+OCLRP2+0	LOAD.L	D1,D6	SWAP.W	D1	COMP.W	D4,D1	JUMP',LS SET2B$	LOAD.W	D4,D1SET2B$:	SUB.W	D4,D3	JUMP',LE SET3$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,D5	LOAD.W	D4,(A6)+OCLRP1+2	SUB.W	D4,D3;;?	JUMP',LE SET3$;;?	CALL	CLEARTRAME	; allume la zone (2)SET3$:	LOAD.W	D3,(A6)+OCLRP1+0	LOAD.L	D1,D5	SWAP.W	D1	COMP.W	D3,D1	JUMP',HS SET3A$	LOAD.W	D3,D1SET3A$:	LOAD.W	D4,(A6)+OCLRP2+0	LOAD.L	D1,D6	SWAP.W	D1	COMP.W	D4,D1	JUMP',LS SET3B$	LOAD.W	D4,D1SET3B$:	SUB.W	D4,D3	JUMP',LE SET4$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OCLRP2+2	LOAD.W	D4,D6	SUB.W	D4,D3;;?	JUMP',LE SET4$;;?	CALL	CLEARTRAME	; allume la zone (3)SET4$:	LOAD.W	D3,(A6)+OCLRP2+0	SWAP.W	D6	LOAD.W	D4,D6	SWAP.W	D6	SUB.W	D4,D3	JUMP',LE EXIT$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,D5	LOAD.W	D4,D6	SUB.W	D4,D3;;?	JUMP',LE EXIT$;;?	CALL	CLEARTRAME	; allume la zone (4)EXIT$:	LOAD.L	(A6)+OCLRP1,D5	LOAD.L	(A6)+OCLRP2,D6	POPM.L	D1..D6	RET;-----------\; CLEARTRAME >;===========/; Efface une zone rectangulaire.; in	D3.L	origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WCLEARTRAME:	PUSHM.L	D2..D4,A1,A2	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	CLIPRECT	; clipping	JUMP',NE 90$	SUB.W	D4,D3	JUMP',LE 90$	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',LE 90$	SWAP.W	D3	SWAP.W	D4	EX.L	D3,D4	LOAD.L	A2,A0	LOAD.L	A1,(A6)+OCLEAR	TEST.B	(A6)+OFANION+3:#BNEGATIF	JUMP',BC 50$	LOAD.L	A1,(A6)+OSET50$:	CALL	(A1)		; appel de GRA_CLEAR ou GRA_SET90$:	POPM.L	D2..D4,A1,A2	RET;---------\\; CLIPRECT >;---------/; Clipping d'une zone rectangulaire.; in	D3.L	P1(y;x);	D4.L	P2(y;x); out	D3.L	P1(y;x);	D4.L	P2(y;x);	D7.W	erreur (rien  dessiner); mod	D3.L, D4.L, D7.WCLIPRECT:	PUSH.L	D2	LOAD.W	D7,#ERDIOUT	LOAD.W	D2,#0	COMP.W	D3,D2		; P1 en dehors ?	JUMP',GE 10$	COMP.W	D4,D2		; P2 en dehors ?	JUMP',GE 15$	JUMP	90$10$:	COMP.W	D4,D2		; P2 en dehors ?	JUMP',GE 20$				; P2 en dehors =>	LOAD.W	D4,D2	JUMP'	20$15$:				; P1 en dehors =>	LOAD.W	D3,D220$:	ADD.W	D2,(A0)+ODFFDX	COMP.W	D3,D2		; P1 en dehors ?	JUMP',LT 25$	COMP.W	D4,D2		; P2 en dehors ?	JUMP',LT 30$	JUMP	90$25$:	COMP.W	D4,D2		; P2 en dehors ?	JUMP',LT 35$				; P2 en dehors =>	LOAD.W	D4,D2	JUMP'	35$30$:				; P1 en dehors =>	LOAD.W	D3,D235$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#0	COMP.W	D3,D2		; P1 en dehors ?	JUMP',GE 50$	COMP.W	D4,D2		; P2 en dehors ?	JUMP',GE 55$	JUMP	90$50$:	COMP.W	D4,D2		; P2 en dehors ?	JUMP',GE 60$				; P2 en dehors =>	LOAD.W	D4,D2	JUMP'	60$55$:				; P1 en dehors =>	LOAD.W	D3,D260$:	ADD.W	D2,(A0)+ODFFDY	COMP.W	D3,D2		; P1 en dehors ?	JUMP',LT 65$	COMP.W	D4,D2		; P2 en dehors ?	JUMP',LT 70$	JUMP	90$65$:	COMP.W	D4,D2		; P2 en dehors ?	JUMP',LT 75$				; P2 en dehors =>	LOAD.W	D4,D2	JUMP'	75$70$:				; P1 en dehors =>	LOAD.W	D3,D275$:	SWAP.W	D3	SWAP.W	D4	CLR.W	D7		; D7 <-- ok90$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETINUM >;--------/; ; in	A3.L	^nom d'un fichier image; out	A3.L	^dbut du numro;	D4.L	numro;	D7.W	erreur; mod	D4.L, D7.W, A3.LGETINUM:	PUSHM.L	D2,D3,A4	LOAD.L	A4,A310$:	COMP.B	(A3+),#'.	JUMP,NE 10$	DEC.L	A320$:	COMP.L	A3,A4	JUMP',EQ 30$	LOAD.B	D3,(-A3)	COMP.B	D3,#'0	JUMP',LO 26$	COMP.B	D3,#'9	JUMP,LS 20$26$:	INC.L	A330$:	LOAD.L	A4,A3	CLR.L	D4		; D4 <-- pour construire le nombre	CLR.W	D2		; D2 <-- nb de digits40$:	CLR.W	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	MUL.WU	D4,#10	SUB.B	D3,#'0	ADD.L	D4,D3	INC.W	D2		; D2 <-- un digit de plus	JUMP	40$50$:	LOAD.W	D7,#1	COMP.W	D2,#2		; 2 digits ?	JUMP',NE 90$		; non => 90$	CLR.W	D790$:	POPM.L	D2,D3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SKIPREP >;--------/; Saute tous les noms d'units et de rpertoires devant; un nom de fichier.; in	A3.L	^unit:rp:rp:nom.ext; out	A3.L	^nom.ext; mod	A3.LSKIPREP:	PUSH.W	D3	CLR.W	D310$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE 10$20$:	DEC.W	D3	JUMP',NS 90$	COMP.B	(-A3),#':	JUMP,NE 20$	INC.L	A390$:	POP.W	D3	RET	.END