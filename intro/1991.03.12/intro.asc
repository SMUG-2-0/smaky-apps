	.TITLE	INTRO;	--------------------------------------;		(C) 1986 - Daniel Roux;	--------------------------------------;	PSos		Amliorations; -----------------------------------------------------------------------; 1.3	02.02.90	cherche les images dans le dossier systme; 1.2	4.4		tourne avec START, sur un winch, etc.;			images compresses; 1.1			ftes d'ortografe !; 1.0			premire version distribue	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULESMAJREV	=	1		; rvisionMINREV	=	3		; version	.REV	MAJREV,MINREV	.CODE	800,11,B'1111,600,2000,300,2000,3,'N,'E,'F,11; Constantes; ----------GCTXF	=	'N		; fonte du texte  NEF11GCTXS	=	'E!2^7		; style/chasse du texteGCTXT	=	11		; taille du texteGCTBF	=	'T!2^7		; fonte du texte-bulle  T(B)14GCTBS	=	2^BGCBOLD	; style/chasse du texte-bulleGCTBT	=	14		; taille du texte-bulleGCICF	=	'I		; fonte des icnes  IIP32GCICS	=	'I		; style/chasse des icnesGCICT	=	32		; taille des icnesGCICX	=	32		; largeur d'une icneGCICY	=	GCICT		; hauteur d'une icneGCICB	=	8		; position ligne de base; Codes des icnes de IIP32; -------------------------ICOVIDE	=	0		; icne videICOSOURISD=	1		; souris  droiteICOMAIN	=	2		; mainICOSOURISG=	3		; souris  gaucheICODETRUIT=	16		; quelques icnes de DESSIN :ICODEPLACE=	17		;ICODUPLIQUE=	18		;ICOBLOCNOTES=	19		;ICOZOOM	=	20		;ICOTOURNE=	21		;ICOMIROIR=	22		;ICOCONTOUR=	23		;ICONEGATIF=	24		;; Variables; ---------	.LOC	0OPDDIS:	.BLKB	4		; ^descripteur de la fentreOBUDIS:	.BLKB	100		; buffer pour write displayOBUICO:	.BLKB	GCICY*GCICX/8+4	; buffer pour une icneOCHOIX:	.BLKB	2		; dernier choix (1..4)LGVAR:; Programme; ---------	.LOC	0START:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT	LOAD.L	A6,A4		; A6 <-- ^variables10$:	CLR.B	(A4+)		; met TOUTES les variables  zro	DEC.L	D4	JUMP,NE 10$	LIB	?GCHDIS		; D6 <-- canal cran	LOAD.W	D3,#TYPWDO	; D3 <-- type fentre cran	LOAD.L	D4,#4		; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OPDDIS	; A4 <-- ^buffer	FOS	?RSTATUS	; demande le ^rel !	JUMP,NE ERFAT	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP,NE ERFAT	LIB	?AFTIM	.B	LOADGC,GCTBF,GCTBS,GCTBT	.B	0	.EVEN	JUMP,NE ERFAT	LOAD.L	A3,#R16"TXIMA1	CALL	AFIMAGE	CALL	WAITKEY	JUMP	SOURISCHOIX:	LOAD.L	A3,#R16"TMCHOIX	LIB	?AFMENU	LOAD.L	A3,#R16"TXIMA2	CALL	AFIMAGE	LOAD.W	D3,(A6)+OCHOIX	CALL	AFCHOIX20$:	CALL	WAITQQ22$:	COMP.W	D3,#'1	JUMP,EQ SOURIS	COMP.W	D3,#F1	JUMP,EQ SOURIS	COMP.W	D3,#F2	JUMP,EQ SOURIS	COMP.W	D3,#F3	JUMP,EQ SOURIS	COMP.W	D3,#'2	JUMP,EQ CLAVIER	COMP.W	D3,#F4	JUMP,EQ CLAVIER	COMP.W	D3,#F5	JUMP,EQ CLAVIER	COMP.W	D3,#F6	JUMP,EQ CLAVIER	COMP.W	D3,#'3	JUMP,EQ CONNECTEURS	COMP.W	D3,#F7	JUMP,EQ CONNECTEURS	COMP.W	D3,#F8	JUMP,EQ CONNECTEURS	COMP.W	D3,#F9	JUMP,EQ CONNECTEURS	COMP.W	D3,#'4	JUMP,EQ FIN	COMP.W	D3,#F0	JUMP,EQ FIN	COMP.W	D3,#END	JUMP,EQ FIN	COMP.W	D3,#KEYMGP	JUMP,EQ 40$	COMP.W	D3,#KEYMMP	JUMP,EQ 40$	COMP.W	D3,#KEYMDP	JUMP,EQ 40$	COMP.W	D3,#(2^BPROGRA)*H'100+END	JUMP,EQ ERFAT30$:				; erreur =>	LOAD.B	D3,#BIPERR	LIB	?BEEP	JUMP	20$40$:				; clic =>	LIB	?IFMOUSE	JUMP,NE 30$	COMP.W	D4,#71	JUMP,LO 30$	COMP.W	D4,#300	JUMP,HS 30$	SWAP.W	D4	LOAD.W	D3,#'1	COMP.W	D4,#147	JUMP,LO 30$	COMP.W	D4,#147+30	JUMP,LS 22$	LOAD.W	D3,#'2	COMP.W	D4,#192	JUMP,LO 30$	COMP.W	D4,#192+30	JUMP,LS 22$	LOAD.W	D3,#'3	COMP.W	D4,#236	JUMP,LO 30$	COMP.W	D4,#236+30	JUMP,LS 22$	LOAD.W	D3,#'4	COMP.W	D4,#278	JUMP,LO 30$	COMP.W	D4,#278+30	JUMP,LS 22$	JUMP	30$SOURIS:	LOAD.W	(A6)+OCHOIX,#1	LOAD.L	A3,#R16"TMVIDE	LIB	?AFMENU	LOAD.L	A3,#R16"TXIMAS0	CALL	AFIMAGE	CALL	WAITSPACE	CALL	LABYRINTHE	CALL	VOITURE	CALL	CLIC	CALL	MENU	JUMP	CHOIXCLAVIER:	LOAD.W	(A6)+OCHOIX,#2	LOAD.L	A3,#R16"TMSUITE	LIB	?AFMENU	LOAD.L	A3,#R16"TXIMAC1	CALL	AFIMAGE	LOAD.L	D4,#H'10000*301+527	CALL	WAITTFONC	COMP.W	D3,#F0	JUMP,EQ CHOIX	LOAD.L	A3,#R16"TXIMAC2	CALL	AFIMAGE	LOAD.L	D4,#H'10000*299+443	CALL	WAITTFONC	COMP.W	D3,#F0	JUMP,EQ CHOIX	LOAD.L	A3,#R16"TXIMAC3	CALL	AFIMAGE	LOAD.L	D4,#H'10000*302+467	CALL	WAITTFONC	COMP.W	D3,#F0	JUMP,EQ CHOIX	LOAD.L	A3,#R16"TXIMAC4	CALL	AFIMAGE	CALL	WAITFONC	COMP.W	D3,#F0	JUMP,EQ CHOIX	LOAD.L	A3,#R16"TXIMAC5	CALL	AFIMAGE	CALL	WAITFONC	COMP.W	D3,#F0	JUMP,EQ CHOIX	JUMP	CHOIXCONNECTEURS:	LOAD.W	(A6)+OCHOIX,#3	LOAD.L	A3,#R16"TMSUITE	LIB	?AFMENU	LOAD.L	A3,#R16"TXIMAH0	CALL	AFIMAGE	CALL	WAITFONC	COMP.W	D3,#F0	JUMP,EQ CHOIX	LOAD.L	A3,#R16"TXIMAH1	CALL	AFIMAGE	CALL	WAITFONC	COMP.W	D3,#F0	JUMP,EQ CHOIX	LOAD.L	A3,#R16"TXIMAH2	CALL	AFIMAGE	CALL	WAITFONC	COMP.W	D3,#F0	JUMP,EQ CHOIX	JUMP	CHOIXFIN:	LOAD.W	(A6)+OCHOIX,#4	LOAD.L	A3,#R16"TMVIDE	LIB	?AFMENU	LOAD.L	A3,#R16"TXIMA3	CALL	AFIMAGE	CALL	WAITKEYERFAT:	LIB	?CLOLIB	FOS	?STOP	EXIT	.INS	INTROLAB	.INS	INTROVOIT	.INS	INTROCLIC	.INS	INTROMENU;--------\\; AFCHOIX >;========/; Montre le dernier choix effectu.; in	D3.W	dernier choix effectu (1..4); out	-; mod	D7.WAFCHOIX:	PUSHM.L	D2..D4	LOAD.W	D4,#147-131+15	DEC.W	D3	JUMP,EQ 20$	LOAD.W	D4,#192-131+15	DEC.W	D3	JUMP,EQ 20$	LOAD.W	D4,#236-131+15	DEC.W	D3	JUMP,EQ 20$	LOAD.W	D4,#278-131+1520$:	SWAP.W	D4	CLR.W	D4	LOAD.L	D3,#H'10000*131+48	LOAD.W	D2,#CLRDOT	LIB	?DRSEG	LOAD.L	D4,#69-48	LIB	?DRSEG	LOAD.W	D4,#-5	SWAP.W	D4	LOAD.W	D4,#-5	PUSH.L	D3	LIB	?DRSEG	POP.L	D3	LOAD.W	D4,#+5	SWAP.W	D4	LOAD.W	D4,#-5	LIB	?DRSEG	POPM.L	D2..D4	RET;--------\\; AFIMAGE >;========/; Affiche une image dans la fentre.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie suprieure gauche.; in	A3.L	^nom de l'image; out	D7.W	erreur; mod	D7.WAFIMAGE:	PUSHM.L	D0,D1,D3,D4,D6,A1..A4	LIB	?AFTIM	.B	NOCURS;;?	.B	EOP	.B	0	.EVEN	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE 90$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE 84$;	LOAD.L	A4,A2	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$	COMP.B	(A4)+OIMTYP,#H'82 ; image du LAMI ?	JUMP,NE 20$		; non => 20$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute la stupide en-tte de 256 bytes !	JUMP,NE 82$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$20$:	LOAD.W	D0,(A4)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A4)+OIMDLY	; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF	; D4 <-- ajoute rserve pour dcodage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE 82$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	TEST.B	(A2)+OIMCOD	; image code ?	JUMP,NE	30$		; oui => 30$				; non =>	LOAD.L	A4,A1	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- nb de bytes rel	FOS	?RDBYTE		; lit toute l'image	JUMP,NE	80$	JUMP	40$30$:	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- nb de bytes rel	FOS	?RDBYTE		; lit toute l'image	JUMP,NE	80$	LOAD.L	A3,A1		; A3 <-- ^image dcode	GRA_	DECOIMA		; dcode l'image ...	JUMP,NE	80$40$:	LOAD.L	A3,A2		; A3 <-- prend buffer en-tte pour STRING	LOAD.W	D3,D0	SR.W	D3,#3	LOAD.W	(A3)+10,D3	; source: <ii>	CLR.W	(A3)+20		; destination: <ii>	LIB	?GETDIM		; D4 <-- dimensions de la fentre	COMP.W	D0,D4		; image trop large ?	JUMP,HI 50$		; oui => 50$	CLR.W	(A3)+2		; source: <xx>	LOAD.W	(A3)+22,D0	; image: <dxx>	SUB.W	D4,D0	SR.W	D4,#1;;?	LOAD.W	(A3)+12,D4	; destination: <xx>	JUMP	55$50$:	CLR.W	(A3)+2		; source: <xx>	CLR.W	(A3)+12		; destination: <xx>	LOAD.W	(A3)+22,D4	; image: <dxx>55$:	SWAP.W	D4	COMP.W	D1,D4		; image trop haute ?	JUMP,HI 60$		; oui => 60$	CLR.W	(A3)+4		; source: <yy>	LOAD.W	(A3)+24,D1	; image: <dyy>	SUB.W	D4,D1	SR.W	D4,#1;;?	LOAD.W	(A3)+14,D4	; destination: <yy>	JUMP	65$60$:	CLR.W	(A3)+4		; source: <yy>	CLR.W	(A3)+14		; destination: <yy>	LOAD.W	(A3)+24,D4	; image: <dyy>65$:	LOAD.W	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+6,A1	; source: <pppp>	CLR.L	(A3)+16		; destination: <pppp>	LOAD.B	(A3)+26,#LOADDOT; image: <mode>	LOAD.W	D3,#1+26	; D3 <-- longueur	LIB	?STRING		; affiche l'image	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D784$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POP.W	D790$:	POPM.L	D0,D1,D3,D4,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WAITKEY >;========/; Attend une touche, mais pas plus de 8 secondes.; in	-; out	-; mod	D7.WWAITKEY:	PUSHM.L	D3,D4	CALL	CLRFIFO		; vide le FIFO du clavier	LOAD.W	D4,#50*8	NTREL	?SETTIM	CALL	GETCAR		; attend ...	LOAD.W	D4,#-1	NTREL	?SETTIM	POPM.L	D3,D4	RET;--------\\; WAITQQ  >;========/; Attend une touche quelconque, et converti les (SHIFT-Fn).; in	-; out	D3.W	touche; mod	D3.L, D7.WWAITQQ:	CALL	CLRFIFO		; vide le FIFO du clavier10$:	CALL	GETCAR		; attend ...	COMP.W	D3,#KEYMGR	JUMP,EQ 10$	COMP.W	D3,#KEYMMR	JUMP,EQ 10$	COMP.W	D3,#KEYMDR	JUMP,EQ 10$	COMP.W	D3,#F0+SHIFT	JUMP,LO 50$	COMP.W	D3,#F15+SHIFT	JUMP,HI 50$	SUB.W	D3,#SHIFT50$:	RET;---------\\; WAITFONC >;=========/; Attend une touche fonction, et converti les (SHIFT-Fn).; in	-; out	D3.W	touche; mod	D3.L, D7.WWAITFONC:	CALL	CLRFIFO		; vide le FIFO du clavier10$:	CALL	GETCAR		; attend ...	COMP.W	D3,#KEYMGR	JUMP,EQ 10$	COMP.W	D3,#KEYMMR	JUMP,EQ 10$	COMP.W	D3,#KEYMDR	JUMP,EQ 10$	COMP.W	D3,#F0+SHIFT	JUMP,LO 50$	COMP.W	D3,#F15+SHIFT	JUMP,HI 50$	SUB.W	D3,#SHIFT50$:	COMP.W	D3,#F0	JUMP,LO 10$	COMP.W	D3,#F15	JUMP,HI 10$	RET;----------\\; WAITTFONC >;==========/; Attend une touche fonction, et converti les (SHIFT-Fn).; in	-; out	D3.W	touche; mod	D3.L, D7.WWAITTFONC:	CALL	CLRFIFO		; vide le FIFO du clavier10$:	CALL	GETCAR		; attend ...	COMP.W	D3,#KEYMGR	JUMP,EQ 10$	COMP.W	D3,#KEYMMR	JUMP,EQ 10$	COMP.W	D3,#KEYMDR	JUMP,EQ 10$	CALL	AFFKEY	COMP.W	D3,#F0+SHIFT	JUMP,LO 50$	COMP.W	D3,#F15+SHIFT	JUMP,HI 50$	SUB.W	D3,#SHIFT50$:	COMP.W	D3,#F0	JUMP,LO 10$	COMP.W	D3,#F15	JUMP,HI 10$	RET;----------\\; WAITSPACE >;==========/; Attend la barre d'espace.; in	-; out	D3.W	touche; mod	D3.L, D7.WWAITSPACE:	CALL	CLRFIFO		; vide le FIFO du clavier10$:	CALL	GETCAR		; attend ...	COMP.W	D3,#SPACE	JUMP,NE 10$	RET;--------\\; AFFKEY  >;========/; Affiche une touche dans le carr des essais.; in	D4.L	coordonne;	D3.W	caractre; out	-; mod	D7.WAFFKEY:	PUSHM.L	D2..D4	CLR.L	(A0)+ODFTRA+0	; ??	CLR.L	(A0)+ODFTRA+4	PUSHM.L	D3,D4	LOAD.L	D3,D4	LOAD.L	D4,#H'10000*30+30	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface l'ancien	POPM.L	D3,D4	LIB	?AFTIM	.B	USEGC,GCTBF,GCTBS,GCTBT	.B	0	.EVEN	LOAD.L	D2,D4	LIB	?LGXCAR	EX.L	D2,D4		; D2 <-- largeur du caractre	EX.L	D3,D4	SUB.W	D2,#32	NEG.W	D2	SR.W	D2,#1	ADD.W	D3,D2	SWAP.W	D3	LOAD.W	D2,#32	SUB.W	D2,(A0)+ODFC1Y	SUB.W	D2,(A0)+ODFC2Y	SR.W	D2,#1	ADD.W	D2,(A0)+ODFC1Y	ADD.W	D3,D2	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,#8		; D3 <-- haut	COMP.W	D4,#H'100*(2^BCURSOR)+'R	JUMP,EQ 50$	COMP.W	D4,#H'100*(2^BCURSOR)+'r	JUMP,EQ 50$	LOAD.B	D3,#11		; D3 <-- gauche	COMP.W	D4,#H'100*(2^BCURSOR)+'D	JUMP,EQ 50$	COMP.W	D4,#H'100*(2^BCURSOR)+'d	JUMP,EQ 50$	LOAD.B	D3,#9		; D3 <-- droite	COMP.W	D4,#H'100*(2^BCURSOR)+'F	JUMP,EQ 50$	COMP.W	D4,#H'100*(2^BCURSOR)+'f	JUMP,EQ 50$	LOAD.B	D3,#10		; D3 <-- bas	COMP.W	D4,#H'100*(2^BCURSOR)+'C	JUMP,EQ 50$	COMP.W	D4,#H'100*(2^BCURSOR)+'c	JUMP,EQ 50$	COMP.W	D4,#'	JUMP,LO 60$	COMP.W	D4,#H'7F	JUMP,HS 60$	LOAD.B	D3,D450$:	LIB	?AFCODE60$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	POPM.L	D2..D4	RET;--------\\; GETCAR  >;========/; Attend une touche ...; in	-; out	D3.W	touche; mod	D3.L, D7.WGETCAR:	PUSHM.L	D2,D4,D510$:	LIB	?GETCAR	COMP.W	D3,#(2^BPROGRA)*H'100+'P	JUMP,EQ 50$	COMP.W	D3,#(2^BPROGRA)*H'100+'p	JUMP,NE 90$50$:				; affiche la position de la souris =>	CLR.L	D3	LIB	?SETCURS	LOAD.B	D3,#AFINV	LIB	?AFCAR	LIB	?IFMOUSE	LOAD.L	D5,D4	AND.L	D4,#H'FFFF	LOAD.W	D3,#5	CLR.W	D2	LIB	?AFDEC	LOAD.L	D4,D5	CLR.W	D4	SWAP.W	D4	LIB	?AFDEC	LOAD.B	D3,#AFDIR	LIB	?AFCAR	JUMP	10$90$:	POPM.L	D2,D4,D5	RET;--------\\; CLRFIFO >;========/; Vide le FIFO du clavier.; in	-; out	-; mod	D7.WCLRFIFO:	PUSH.L	D310$:	LIB	?IFCAR		; vide le FIFO du clavier	JUMP,EQ 10$	POP.L	D3	RET;---------\\; OPEMOUSE >;=========/; Ouvre le lutin pour la souris.; in	D3.W	code de l'icne;	D4.L	position initiale; out	-; mod	D7.WOPEMOUSE:	PUSHM.L	D2..D4,A3,A4	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN	LOAD.L	D2,D4	LOAD.L	A4,(A0)+ODFPGC	; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D3	ADD.L	D4,#OGCWID	CLR.W	D3	LOAD.B	D3,(A4)+OGCLCA	SUB.B	D3,(A4)+OGCFCA	INC.B	D3	MUL.WU	D3,#3	ADD.L	D4,D3	ADD.L	A4,D4		; A4 <-- ^bonne matrice	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWOSPRITE	SWAP.W	D2	LOAD.L	(A3)+1,D2	; <xx> et <yy>	LOAD.W	(A3)+5,#GCICX	; <dxx>	LOAD.W	(A3)+7,#GCICY	; <dyy>	LOAD.L	(A3)+9,A4	; <ssss> matrice chair	CLR.L	(A3)+13		; <cccc> matrice fond automatique	CLR.B	(A3)+17		; <n>	LOAD.W	D3,#18	LIB	?STRING	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	POPM.L	D2..D4,A3,A4	RET;---------\\; MOVMOUSE >;=========/; Dplace le lutin pour la souris.; in	D4.L	position; out	-; mod	D7.WMOVMOUSE:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMSPRITE	SWAP.W	D4	LOAD.L	(A3)+1,D4	; <xx> et <yy>	CLR.B	(A3)+5		; <n>	LOAD.W	D3,#6	LIB	?STRING	POPM.L	D3,D4,A3	RET;---------\\; CLOMOUSE >;=========/; Ferme le lutin pour la souris.; in	-; out	-; mod	D7.WCLOMOUSE:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWCSPRITE	CLR.B	(A3)+1		; <n>	LOAD.W	D3,#2	LIB	?STRING	POPM.L	D3,A3	RET;---------\\; ICOMOUSE >;=========/; Utilise une icne comme lutin pour la souris.; in	D3.W	code de l'icne; out	-; mod	D7.WICOMOUSE:	PUSHM.L	D2..D4,A3,A4	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN	LOAD.L	A4,#0	TEST.B	D3	JUMP',EQ 40$	LOAD.L	A4,(A0)+ODFPGC	; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	LOAD.W	D2,D4	MUL.WU	D4,D3	ADD.L	D4,#OGCWID	CLR.W	D3	LOAD.B	D3,(A4)+OGCLCA	SUB.B	D3,(A4)+OGCFCA	INC.B	D3	MUL.WU	D3,#3	ADD.L	D4,D3	ADD.L	A4,D4		; A4 <-- ^bonne matrice	LOAD.L	A3,#(A6)+OBUICO	LOAD.B	(A3+),#GCICX	LOAD.B	(A3+),#GCICY30$:	LOAD.B	(A3+),(A4+)	DEC.W	D2	JUMP,NE 30$	LOAD.L	A4,#(A6)+OBUICO40$:	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	LOAD.L	(A3)+1,A4	; <ssss> matrice chair	CLR.L	(A3)+5		; <cccc> matrice fond automatique	LOAD.W	D3,#9	LIB	?STRING	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	POPM.L	D2..D4,A3,A4	RET;--------\\; PMOUSE  >;========/; Positionne la souris en (y;x).; in	D4.L	nouvelle position y;x; out	-; mod	D7.WPMOUSE:	PUSHM.L	D3,D4,D6,A4; Calcul la position absolue dans le grand bitmap $DIS_0.	ADD.W	D4,(A0)+ODFX	SWAP.W	D4	ADD.W	D4,(A0)+ODFY	SWAP.W	D4		; D4 <-- position dans $DIS_0 !; Envoie la commande secrte et mystrieuse de positionnement. 	LOAD.L	A4,#(A6)+OBUDIS+1	LOAD.B	(A4)+0,#'P	; <P>	LOAD.L	(A4)+1,D4	; <yy> <xx>	CLR.B	(A4)+5	LOAD.W	D3,#TYPIO	; D3 <-- type du driver souris	LIB	?GCHMOU		; D6 <-- canal souris	FOS	?COMMAND	POPM.L	D3,D4,D6,A4	RET; Textes; ------TMVIDE:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TMCHOIX:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Souris"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Clavier"		;     ;     ;     ;	.ASCIZ	"Dtails"	.ASCIZ	"techniques"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TMSUITE:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"      Suite...   "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;TXIMA1:	.ASCIZ	"intro1.image"TXIMA2:	.ASCIZ	"intro2.image"TXIMA3:	.ASCIZ	"intro3.image"TXIMAS0:.ASCIZ	"intros0.image"TXIMAS1:.ASCIZ	"intros1.image"TXIMAS2:.ASCIZ	"intros2.image"TXIMAS3:.ASCIZ	"intros3.image"TXIMAS4:.ASCIZ	"intros4.image"TXIMAS41:.ASCIZ	"intros41.image"TXIMAS42:.ASCIZ	"intros42.image"TXIMAS43:.ASCIZ	"intros43.image"TXIMAS44:.ASCIZ	"intros44.image"TXIMAC1:.ASCIZ	"introc1.image"TXIMAC2:.ASCIZ	"introc2.image"TXIMAC3:.ASCIZ	"introc3.image"TXIMAC4:.ASCIZ	"introc4.image"TXIMAC5:.ASCIZ	"introc5.image"TXIMAH0:.ASCIZ	"introh0.image"TXIMAH1:.ASCIZ	"introh1.image"TXIMAH2:.ASCIZ	"introh2.image"	.EVEN	.END	START