	.SBTTL	AUDDBOX.ASI;-----------\\; DBOXEDITIF >;===========/; Edite un nom de fichier en entre (prend).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITIF:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOB	LOAD.L	A4,#R16"TFEXT	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1!2^BDBIOFULL	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEDITAF >;===========/; Edite un nom de fichier en entre (ajoute).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITAF:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO1	LOAD.L	A4,#R16"TFEXT	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1!2^BDBIOFULL	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEDITOF >;===========/; Edite un nom de fichier en sortie (sauve).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F0/F1/F4);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITOF:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOB	LOAD.L	A4,#R16"TFEXT	LOAD.W	D1,#DBOX_EXTRAIT ; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEDITEF >;===========/; Edite un nom de fichier en sortie (extrait).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITEF:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO1	LOAD.L	A4,#R16"TFEXT	LOAD.W	D1,#DBOX_EXTRAIT ; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXDETRUIT >;============/; Demande s'il faut dtruire.; in	A3.L	^nom; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDETRUIT:	PUSHM.L	D1,D2,D4,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3	LOAD.L	A4,#R16"TFEXT	LOAD.L	A3,#R16"TDBOX_IOB	CLR.L	D3	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_DETRUIT	DBOX_	EXTEND	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande si l'on veut quitter DESSIN.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXQUITTE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IOB	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer le dessin.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXEFFACE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	LOAD.L	A5,#(A6)+OBUNAME ; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOB	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXVOL >;========/; Choix du volume.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXVOL:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	(A6)+ODBPA1,(A6)+OVODEB	LOAD.W	(A6)+ODBPA2,(A6)+OVOFIN	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	; mj ^table dbox	LOAD.L	A2,#R16"TDBOX_VOL	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#2	JUMP,LO AFF$	CLR.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	DBOXZEROCR	; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_VOL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$CLIC$:	CALL	DBOXCLIC	JUMP,EQ NLINE$	JUMP	BIP$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	BIP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$OK$:	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.W	(A6)+OVODEB,(A6)+ODBPA1	LOAD.W	(A6)+OVOFIN,(A6)+ODBPA2END$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBPA1,DBTYPN,0,200,10,2^BDBGCLABEL!100,0,3+2	.W	ODBPA2,DBTYPN,0,200,10,2^BDBGCLABEL!101,1,3+2	.W	-1TDBOX_VOL:	.W	10$-TDBOX_VOL	.W	20$-TDBOX_VOL	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Amplitude au dbut : "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  % "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Amplitude  la fin : "	.B	ODBLABEL,101	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  % "	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_VOL:	.W	F1,F2,F3,0		DOKF1-TKEY_VOL	.W	F0,F13,F14,F15,0	DOKF0-TKEY_VOL	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_VOL	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_VOL	.W	0;---------\\; DBOXCODE >;=========/; Choix du codage.; in	A4.L	^son; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCODE:	PUSHM.L	D1,D2,D4,D5,A1..A4	CALL	DBCODGET	; D4 <-- fanions	LOAD.L	A2,#R16"TDBOX_CODE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#2!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#3!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#4!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#5!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	POP.L	D4NBK$:	CALL	DBCODNBK	; affiche le nombre de kilosLOOP$:	CALL	NORMMOUSE	; remet la flche	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_CODE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#DEFINE	JUMP',EQ PLAY$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$KEYDBOX$:	LOAD.L	D1,#H'FFFF0000	COMP.B	D3,#16	JUMP',LO MASK$	SWAP.W	D1MASK$:	AND.L	D4,D1	TSET.L	D4:D3	JUMP	NBK$PLAY$:	PUSH.W	(A4)+OADHFREQ	PUSH.W	(A4)+OADHCOD	CALL	DBCODPUT	; mj le son	CALL	MAINPLAY	; fait entendre	POP.W	(A4)+OADHCOD	POP.W	(A4)+OADHFREQ	TEST.W	D7	JUMP,NE BIP$	JUMP	LOOP$OK$:	CALL	DBCODPUT	; mj le sonEND$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CODE:	.W	10$-TDBOX_CODE	.W	20$-TDBOX_CODE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Codage du son :   "	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,0!2^7!2^6,KEYDBOX/H'100,0	.ASCIZ	" aucun"	.B	ODBTABX,13	.B	ODBLCIRCLE,16!2^7!2^6,KEYDBOX/H'100,16	.ASCIZ	" 35.000 KHz"	.B	ODBCR	.B	ODBLABEL,1	.B	ODBLCIRCLE,1!2^7!2^6,KEYDBOX/H'100,1	.ASCIZ	" idem"	.B	ODBTABX,13	.B	ODBLCIRCLE,17!2^7!2^6,KEYDBOX/H'100,17	.ASCIZ	" 17.500 KHz"	.B	ODBCR	.B	ODBLABEL,2	.B	ODBLCIRCLE,2!2^7!2^6,KEYDBOX/H'100,2	.ASCIZ	" delta 1"	.B	ODBTABX,13	.B	ODBLCIRCLE,18!2^7!2^6,KEYDBOX/H'100,18	.ASCIZ	"  8.750 KHz"	.B	ODBCR	.B	ODBLABEL,3	.B	ODBLCIRCLE,3!2^7!2^6,KEYDBOX/H'100,3	.ASCIZ	" delta 2"	.B	ODBTABX,13	.B	ODBLCIRCLE,19!2^7!2^6,KEYDBOX/H'100,19	.ASCIZ	"  4.375 KHz"	.B	ODBCR	.B	ODBLABEL,4	.B	ODBLCIRCLE,4!2^7!2^6,KEYDBOX/H'100,4	.ASCIZ	" delta 4"	.B	ODBCR	.B	ODBLABEL,5	.B	ODBLCIRCLE,5!2^7!2^6,KEYDBOX/H'100,5	.ASCIZ	" 4 bits"	.B	ODBTABX,13	.B	ODBBOX,0,DEFINE,TDBOMBRE	.ASCIZ	" ECOUTE "	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  CODE  "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Code"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CODE:	.W	F1,F2,F3,0		DOKF1-TKEY_CODE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CODE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CODE	.W	0;---------\\; DBCODGET >;---------/; in	A4.L	^son; out	D4.L	fanions; mod	D4.L, D7.WDBCODGET:	PUSHM.L	D1	LOAD.L	D4,#2^19	COMP.W	(A4)+OADHFREQ,#ADFREQ/8	JUMP',EQ FREQ$	LOAD.L	D4,#2^18	COMP.W	(A4)+OADHFREQ,#ADFREQ/4	JUMP',EQ FREQ$	LOAD.L	D4,#2^17	COMP.W	(A4)+OADHFREQ,#ADFREQ/2	JUMP',EQ FREQ$	LOAD.L	D4,#2^16FREQ$:	LOAD.W	D4,#H'8000	LOAD.W	D1,(A4)+OADHCOD	; D1 <-- type de codageCODE$:	RL.W	D4,#1	DEC.W	D1	JUMP,NC CODE$	POPM.L	D1	RET;---------\\; DBCODPUT >;---------/; in	A4.L	^son;	D4.L	fanions; out	-; mod	D7.WDBCODPUT:	PUSHM.L	D1,D4	LOAD.W	(A4)+OADHFREQ,#ADFREQ/8	TEST.L	D4:#19	JUMP',BS FREQ$	LOAD.W	(A4)+OADHFREQ,#ADFREQ/4	TEST.L	D4:#18	JUMP',BS FREQ$	LOAD.W	(A4)+OADHFREQ,#ADFREQ/2	TEST.L	D4:#17	JUMP',BS FREQ$	LOAD.W	(A4)+OADHFREQ,#ADFREQFREQ$:	LOAD.W	D1,#-1CODE$:	INC.W	D1	RR.W	D4,#1	JUMP,CC CODE$	LOAD.W	(A4)+OADHCOD,D1	POPM.L	D1,D4	RET;---------\\; DBCODNBK >;---------/; Affiche le nombre de kilos du son.; in	A4.L	^son;	D4.L	fanions; out	-; mod	D7.WDBCODNBK:	PUSHM.L	D1..D4	LOAD.L	D1,D4		; D1 <-- fanions	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.B	D3,#'(	LIB	?AFCAR	LOAD.L	D4,(A4)+OADHLG	LOAD.W	D3,#3	TEST.L	D1:#19	JUMP',BS DRAW$	LOAD.W	D3,#2	TEST.L	D1:#18	JUMP',BS DRAW$	LOAD.W	D3,#1	TEST.L	D1:#17	JUMP',BS DRAW$	CLR.W	D3DRAW$:	SR.L	D4,D3	SR.L	D4,#8	SR.L	D4,#2		; D4 <-- /1024	INC.L	D4	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCII	"k)"	.B	EFLI,0	.EVEN	POPM.L	D1..D4	RET; Tables; ------TFEXT:	.ASCIZ	".AUDIO"TDBOX_IOB:	.ASCIZ	"AUDIO"			; nom du logiciel	.ASCIZ	"Fbanque de sons"	; [M,F] nom des lments manipuls	.ASCIZ	""			; [M,F] nom du contenant	.B	0TDBOX_IO1:	.ASCIZ	"AUDIO"			; nom du logiciel	.ASCIZ	"Mson"			; [M,F] nom des lments manipuls	.ASCIZ	""			; [M,F] nom du contenant	.B	0	.EVEN	.END