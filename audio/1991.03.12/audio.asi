	.SBTTL	AUDIO.ASI;--------\\; IOPLAY  >;========/; Fait entendre une partie de son.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	D7.W	erreur; mod	D7.WIOPLAY:	PUSHM.L	D1..D4,D6,A2..A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	A2,A4		; A2 <-- ^son dcod	CALL	IOCODE		; A3 <-- ^son cod	JUMP',NE EXIT$	LOAD.L	A4,A3		; A4 <-- ^son cod	CALL	IOCODELG	; D1/D2 <-- temps cods	LOAD.L	A3,#R16"NAME$	LOAD.W	D3,#2^BOPWR	FOS	?OPEN	JUMP',NE GIVE$	LOAD.L	D4,#LADH	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE GIVE$	PUSH.L	A4	LOAD.L	A4,#(A4)+(D1.L)+LADH	LOAD.L	D4,D2	SUB.L	D4,D1	FOS	?WRBYTE		; crit le data	POPM.L	A4	JUMP',NE GIVE$	FOS	?CLOSEGIVE$:	COMP.L	A4,A2	JUMP',EQ EXIT$	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le son cod	POP.W	D7EXIT$:	POPM.L	D1..D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETNAME$:	.ASCIZ	"#AUDIO:"	.EVEN;--------\\; IOADD   >;========/; Ajoute un fichier .AUDIO; in	A3.L	^nom du fichier .AUDIO; out	D7.W	erreur; mod	D7.WIOADD:	PUSHM.L	D2..D4,D6,A2,A4	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier	JUMP,NE EXIT$	LOAD.L	A2,#(A6)+OPSON	; ^^sons	CLR.W	D2LOOP$:	TEST.L	(A2)		; emplacement libre ?	JUMP',NE NEXT$		; non => NEXT$	CALL	IOREADONE	; lit un son	JUMP',NE CLOSE$NEXT$:	ADD.L	A2,#4		; A2 <-- ^^suivant	INC.W	D2	COMP.W	D2,#MAXSON	JUMP,LO LOOP$	COMP.W	D2,#MAXSON	JUMP,LO LOOP$CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7	COMP.W	D7,#EROUTF	JUMP',NE EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOREAD  >;========/; Lit tout un fichier .AUDIO; in	A3.L	^nom du fichier .AUDIO; out	D7.W	erreur; mod	D7.WIOREAD:	PUSHM.L	D2..D4,D6,A2,A4	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier	JUMP,NE EXIT$	CALL	IOFLUSH		; libre tous les sons	LOAD.L	A2,#(A6)+OPSON	; ^^sons	CLR.W	D2LOOP$:	CALL	IOREADONE	; lit un son	JUMP',NE CLOSE$	ADD.L	A2,#4		; A2 <-- ^^suivant	INC.W	D2	COMP.W	D2,#MAXSON	JUMP,LO LOOP$	COMP.W	D2,#MAXSON	JUMP,LO LOOP$CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7	COMP.W	D7,#EROUTF	JUMP',NE EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOREADONE >;----------/; Lit un son en mmoire.; in	A2.L	^^son;	A3.L	^nom du fichier;	D6.W	canal FOS; out	D7.W	erreur; mod	D7.WIOREADONE:	PUSHM.L	D1,D3,D4,A1,A3,A4	LOAD.L	A1,A3		; A1 <-- ^nom du fichier	LOAD.L	A4,#(A6)+OBHEAD	LOAD.L	D4,#LADH	FOS	?RDBYTE		; lit une en-tte	JUMP,NE EXIT$	LOAD.L	A3,A4		; A3 <-- ^en-tte	COMP.B	(A3)+OADHTYP,#ADHTYPE	JUMP',NE OTHER$	TEST.B	(A3)+OADHTYP+1	JUMP',NE OTHER$	LOAD.L	D3,(A3)+OADHLG	ADD.L	D4,D3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP,NE EXIT$	LOAD.L	(A2),A4		; OPSON <-- ^son	LOAD.W	D4,#(LADH/2)-1HXFER$:	LOAD.W	(A4+),(A3+)	; buffer <-- en-tte	DECJ.W,NMO D4,HXFER$	LOAD.L	D4,D3	FOS	?RDBYTE		; lit un son	JUMP,NE EXIT$	LOAD.L	A4,(A2)	CALL	IODECODE	; A3 <-- ^son dcod	JUMP,NE EXIT$	COMP.L	A4,A3	JUMP,EQ NAME$	LOAD.L	(A2),A3		; OPSON <-- ^son dcod	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le son cod	JUMP	NAME$OTHER$:	FOS	?GPOS		; D4 <-- position actuelle	SUB.L	D4,#LADH	; D4 <-- position dbut chantillons	LOAD.L	D1,D4	LOAD.L	D4,#-1	LOAD.B	D3,D4	FOS	?SPOS		; D4 <-- position fin	EX.L	D1,D4	CLR.B	D3	FOS	?SPOS		; revient au dbut	SUB.L	D1,D4	LOAD.L	D4,D1		; D4 <-- longueur jusqu' la fin	ADD.L	D4,#LADH	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP',NE EXIT$	LOAD.L	(A2),A4		; OPSON <-- ^son	LOAD.L	A3,A4	SUB.L	D4,#LADH	LOAD.W	D1,#(LADH/2)-1CLR$:	CLR.W	(A4+)	DECJ.W,NMO D1,CLR$	LOAD.B	(A3)+OADHTYP,#ADHTYPE	LOAD.L	(A3)+OADHLG,D4	LOAD.W	(A3)+OADHFREQ,#ADFREQ	FOS	?RDBYTE		; lit les chantillons	JUMP',NE EXIT$NAME$:	LOAD.L	A4,(A2)		; A4 <-- ^son	TEST.B	(A4)+OADHNAME	; nom existe dj ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.L	A3,A1		; A3 <-- ^nom de fichier	CALL	SKIPREP		; A3 <-- saute rep(s):	LOAD.L	A4,#(A4)+OADHNAME	LOAD.W	D4,#LADHNAMENXFER$:	DEC.W	D4	JUMP',NS NEND$	COMP.B	(A3),#'.	JUMP',EQ NEND$	LOAD.B	(A4+),(A3+)	; OADHNAME <-- nom du fichier !	JUMP,NE NXFER$NEND$:	CLR.B	(A4)EXIT$:	POPM.L	D1,D3,D4,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOEXTRAIT >;==========/; Ecrit un seul son dans un fichier .AUDIO; in	A3.L	^nom du fichier .AUDIO;	A4.L	^son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	D7.W	erreur; mod	D7.WIOEXTRAIT:	PUSHM.L	D3,D4,D6	CALL	WAITMOUSE	; met le sablier	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier	JUMP',NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP',NE EXIT$	CALL	IOWRITEONE	; crit un son	JUMP',NE CLOSE$	FOS	?CLOSE	CALL	IOCOMMAND	; envoye v. la commande "F+"	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7EXIT$:	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOWRITE >;========/; Ecrit tout un fichier .AUDIO; in	A3.L	^nom du fichier .AUDIO; out	D7.W	erreur; mod	D7.WIOWRITE:	PUSHM.L	D0..D4,D6,A2,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier	JUMP,NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP,NE EXIT$	LOAD.L	A2,#(A6)+OPSON	; ^^sons	LOAD.W	D0,#MAXSON-1LOOP$:	TEST.L	(A2)		; son existe ?	JUMP',EQ NEXT$		; non => EXIT$	LOAD.L	A4,(A2)		; A4 <-- ^en-tte + son	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	IOWRITEONE	; crit un son	JUMP',NE CLOSE$NEXT$:	ADD.L	A2,#4	DECJ.W,NMO D0,LOOP$	FOS	?CLOSE	CALL	IOCOMMAND	; envoye v. la commande "F+"	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7EXIT$:	POPM.L	D0..D4,D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IOWRITEONE >;-----------/; Ecrit un son.; in	A4.L	^son;	D6.W	canal FOS;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	D7.W	erreur; mod	D7.WIOWRITEONE:	PUSHM.L	D1,D2,D4,A3,A4	CALL	IOCODE		; A3 <-- ^son cod	JUMP',NE EXIT$	EX.L	A3,A4		; A3/A4 <-- ^son dcod/cod	CALL	IOCODELG	; D1/D2 <-- temps cods	SUB.L	D2,D1	PUSH.L	(A4)+OADHLG	LOAD.L	(A4)+OADHLG,D2	LOAD.L	D4,#LADH	FOS	?WRBYTE		; crit en-tte	POP.L	(A4)+OADHLG	TEST.W	D7	JUMP',NE EXIT$	LOAD.L	D4,D2	PUSH.L	A4	LOAD.L	A4,#(A4)+(D1.L)+LADH	FOS	?WRBYTE		; crit son cod	POPM.L	A4	JUMP',NE EXIT$	COMP.L	A4,A3	JUMP',EQ EXIT$	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le son codEXIT$:	POPM.L	D1,D2,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOCOMMAND >;==========/; Envoie une commande F+ au synthtiseur si le fichier; a le nom "300_SYNT.AUDIO".; in	A3.L	^nom du fichier; out	-; mod	D7.WIOCOMMAND:	PUSHM.L	D3,D6,A2..A4	LOAD.L	A4,A3	LOAD.L	A3,#R16"NFILE$	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; fichier 300_SYNT.AUDIO ?	JUMP',NS EXIT$		; non => EXIT$	LOAD.L	A3,#R16"NSYNT$	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre #SYNTHESIZER:	JUMP',NE EXIT$ 	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#'F	LOAD.B	(A4)+1,#'+	CLR.B	(A4)+2	LOAD.W	D3,#TYPIO	; D3 <-- type du driver	FOS	?COMMAND	; utilise ou pas 300_SYNT.AUDIO	FOS	?CLOSE		; ferme #SYNTHESIZER:EXIT$:	POPM.L	D3,D6,A2..A4	RETNFILE$:	.ASCIZ	"*300_SYNT.AUDIO"NSYNT$:	.ASCIZ	"#SYNTHESIZER:"TERM$:	.B	0,SPACE,TAB,CR,-1	.EVEN;--------\\; IOFLUSH >;========/; Libre tous les sons.; in	-; out	-; mod	D7.WIOFLUSH:	PUSHM.L	D1,D2,A2,A4	LOAD.L	A2,#(A6)+OPSON	; ^^sons	LOAD.W	D2,#MAXSON-1LOOP$:	TEST.L	(A2)	JUMP',EQ NEXT$	LOAD.L	A4,(A2)	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A2)NEXT$:	ADD.L	A2,#4	DECJ.W,NMO D2,LOOP$	POPM.L	D1,D2,A2,A4	RET;-----------\\; IOFLUSHONE >;===========/; Libre un son.; in	D3.W	rang du son (0..n); out	-; mod	D7.WIOFLUSHONE:	PUSHM.L	D1,D3,A2,A4	LOAD.L	A2,#(A6)+OPSON	; ^^sons	SL.W	D3,#2	ADD.W	A2,D3	TEST.L	(A2)	JUMP',EQ EXIT$	LOAD.L	A4,(A2)	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A2)EXIT$:	POPM.L	D1,D3,A2,A4	RET;---------\\; IODECODE >;=========/; Dcode un son.; in	A4.L	^en-tte + son (cod); out	A3.L	^en-tte + son (dcod);	D7.W	erreur; mod	D7.W, A3.LIODECODE:	PUSHM.L	D0..D4,A1,A2,A4,A5	LOAD.L	A2,A4		; A2 <-- ^son cod	LOAD.L	D2,#H'10000*1+0	COMP.W	(A2)+OADHFREQ,#ADFREQ	JUMP',EQ MEM1$	LOAD.L	D2,#H'10000*2+1	COMP.W	(A2)+OADHFREQ,#ADFREQ/2	JUMP',EQ MEM1$	LOAD.L	D2,#H'10000*4+2	COMP.W	(A2)+OADHFREQ,#ADFREQ/4	JUMP',EQ MEM1$	LOAD.L	D2,#H'10000*8+3	COMP.W	(A2)+OADHFREQ,#ADFREQ/8	JUMP,NE SAME$MEM1$:	TEST.W	D2	JUMP,EQ SAME$	LOAD.L	D4,(A2)+OADHLG	SL.L	D4,D2	ADD.L	D4,#LADH	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP,NE EXIT$	LOAD.L	A3,A4	LOAD.L	A1,A2;	LOAD.L	A4,A3	LOAD.W	D3,#(LADH/2)-1XHEAD$:	LOAD.W	(A4+),(A1+)	DECJ.W,NMO D3,XHEAD$	LOAD.L	D3,(A3)+OADHLG	SL.L	D3,D2	LOAD.L	(A3)+OADHLG,D3	SUB.L	D4,#LADH	SR.L	D4,D2XDATA$:	LOAD.B	D0,(A1+)	LOAD.L	D1,D2	SWAP.W	D1		; D1 <-- 1, 2, 4 ou 8XREP$:	LOAD.B	(A4+),D0	DEC.W	D1	JUMP,NE XREP$	DEC.L	D4	JUMP,NE XDATA$	JUMP'	OK$SAME$:	LOAD.L	A3,A2		; A3 <-- son dcod = son cod !OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A1,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOCODE  >;========/; Code un son.; in	A4.L	^en-tte + son (dcod); out	A3.L	^en-tte + son (cod);	D7.W	erreur; mod	D7.W, A3.LIOCODE:	PUSHM.L	D0..D4,A1,A2,A4,A5	LOAD.L	A2,A4		; A2 <-- ^son dcod	LOAD.L	D2,#H'10000*1+0	COMP.W	(A2)+OADHFREQ,#ADFREQ	JUMP',EQ MEM1$	LOAD.L	D2,#H'10000*2+1	COMP.W	(A2)+OADHFREQ,#ADFREQ/2	JUMP',EQ MEM1$	LOAD.L	D2,#H'10000*4+2	COMP.W	(A2)+OADHFREQ,#ADFREQ/4	JUMP',EQ MEM1$	LOAD.L	D2,#H'10000*8+3	COMP.W	(A2)+OADHFREQ,#ADFREQ/8	JUMP,NE SAME$MEM1$:	TEST.W	D2	JUMP,EQ SAME$	LOAD.L	D4,(A2)+OADHLG	SR.L	D4,D2	ADD.L	D4,#LADH	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP,NE EXIT$	LOAD.L	A3,A4	LOAD.L	A1,A2;	LOAD.L	A4,A3	LOAD.W	D3,#(LADH/2)-1XHEAD$:	LOAD.W	(A4+),(A1+)	DECJ.W,NMO D3,XHEAD$	LOAD.L	D3,(A3)+OADHLG	SR.L	D3,D2	LOAD.L	(A3)+OADHLG,D3	SUB.L	D4,#LADHXDATA$:	LOAD.L	D1,D2	SWAP.W	D1		; D1 <-- 2 ou 4	CLR.L	D0XSUM$:	CLR.L	D3	LOAD.B	D3,(A1+)	ADD.L	D0,D3		; D0 <-- somme des chantillons	DEC.W	D1	JUMP,NE XSUM$	SR.L	D0,D2		; D0 <-- moyenne des chantillons	LOAD.B	(A4+),D0	DEC.L	D4	JUMP,NE XDATA$	JUMP'	OK$SAME$:	LOAD.L	A3,A2		; A3 <-- son cod = son dcod !OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A1,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; IOCODELG >;=========/; Modifie les temps en fonction du codage.; in	A4.L	^en-tte + son (cod);	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	D1.L	temps dbut [e];	D2.L	temps fin   [e]; mod	D1.L, D2.L, D7.WIOCODELG:	PUSHM.L	D3	CLR.W	D3		; D3 <-- /1	COMP.W	(A4)+OADHFREQ,#ADFREQ	JUMP',EQ CODE$	LOAD.W	D3,#1		; D3 <-- /2	COMP.W	(A4)+OADHFREQ,#ADFREQ/2	JUMP',EQ CODE$	LOAD.W	D3,#2		; D3 <-- /4	COMP.W	(A4)+OADHFREQ,#ADFREQ/4	JUMP',EQ CODE$	LOAD.W	D3,#3		; D3 <-- /8	COMP.W	(A4)+OADHFREQ,#ADFREQ/8	JUMP',NE EXIT$CODE$:	TEST.W	D3	JUMP',EQ EXIT$	SR.L	D1,D3	SR.L	D2,D3EXIT$:	POPM.L	D3	RET	.END