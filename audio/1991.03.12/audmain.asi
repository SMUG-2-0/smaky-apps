	.SBTTL	AUDMAIN.ASI;---------\\; DBOXMAIN >;=========/; Programme principal.; in	-; out	D7.W	erreur; mod	D7.WDBOXMAIN:	PUSHM.L	D1..D5,A1..A4	CALL	DESCADRE	; dessine le cadre	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_MAIN	CLR.W	D2	LOAD.L	D4,(A6)+OFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#51!2^BDBGCLABEL	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#50!2^BDBGCLABEL	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	SUB.W	D4,#4	SWAP.W	D3	SUB.W	D3,#10	SWAP.W	D3	LOAD.L	(A6)+OVSPOS,D3	LOAD.W	(A6)+OVSDIM+2,D4	LOAD.W	(A6)+OVSDIM+0,#128	CALL	VISUEMPTY	; dessine la zone de visualisation	CALL	MAINSLDRAW	; dessine la scroll-listeUPDATE0$:	INC.W	(A6)+OSLNCH	; faudra afficher la scroll-listeUPDATE1$:	CLR.W	(A6)+OSLVAR+OSCPOSVUPDATE2$:	CALL	MAINVIDRAW	; affiche le sonNAME$:	TEST.W	(A6)+OSLNCH	; nom chang ?	JUMP',EQ NAME2$		; non => NAME2$	CALL	MAINSLUPDATE	; met  jour la scroll-listeNAME2$:	CALL	MAINGETNAME	; A3/A4 <-- ^dbut/fin nomLOOP$:	CALL	MAINGREY	; grise/dgrise	CALL	NORMMOUSE	; remet la flche	CLR.W	D3	COMP.L	A3,#0	JUMP',NE MEDIT$	LOAD.W	D3,#-1MEDIT$:	DBOX_	MEDIT	LOAD.L	D4,(A6)+OFAN	; D4 <-- fanions	DBOX_	EDIT		; attend une action ...	LOAD.L	(A6)+OFAN,D4	COMP.L	A3,#0	JUMP',EQ ZERO$	CALL	DBOXZEROCRZERO$:	LOAD.L	A1,#R16"TKEY_MAIN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYDBOX	JUMP,EQ UPDATE2$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ CLEAR$	COMP.W	D3,#DEFINE	JUMP,EQ	PLAY$	COMP.W	D3,#H'100*(2^BPROGRA)+'C	JUMP,EQ CODE$	COMP.W	D3,#H'100*(2^BPROGRA)+'S	JUMP,EQ SUPP$	COMP.W	D3,#F0	JUMP,EQ QUIT$	COMP.W	D3,#F1	JUMP,EQ PREND$	COMP.W	D3,#F2	JUMP,EQ AJOUTE$	COMP.W	D3,#F3	JUMP,EQ SAUVE$	COMP.W	D3,#F4	JUMP,EQ EXTRAIT$	COMP.W	D3,#F14	JUMP,EQ EFFACE$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	NAME$ERROR$:	PUSH.W	D7	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	AFMENU		; refait les soft-keys	JUMP	UPDATE0$CLEAR$:				; CLEAR =>	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$UNDO$:				; UNDO =>	CALL	MAINBACK	; revient en arrire	JUMP,NE BIP$	JUMP	LOOP$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	CALL	MAINPUTNAME	; met  jour le nom	CALL	MAINSELECT	; slectionne le signal ...	JUMP,EQ NAME$	CALL	MAINVIMOVE	; dplace le signal ...	JUMP,EQ LOOP$	CALL	MAINSLMOVE	; dplace la scroll-liste ...	JUMP,NE BIP$	JUMP	UPDATE1$PLAY$:	CALL	MAINPLAY	; fait entendre	JUMP,NE BIP$	JUMP	LOOP$CODE$:	CALL	MAINCODE	; choix du codage ...	JUMP,NE BIP$	JUMP	LOOP$SUPP$:	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	CALL	IOFLUSHONE	; efface un son	JUMP	UPDATE0$PREND$:	CALL	MAINPUTNAME	; met  jour le nom	LOAD.L	A3,#(A6)+OBUNAME	CLR.L	D4	CALL	DBOXEDITIF	; demande un nom ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE UPDATE0$	CALL	IOREAD		; lit un fichier .AUDIO	JUMP,NE ERROR$	CLR.W	(A6)+OSLVAR+OSLCYS	JUMP	UPDATE0$AJOUTE$:	CALL	MAINPUTNAME	; met  jour le nom	LOAD.L	A3,#(A6)+OBUNADD	CLR.L	D4	CALL	DBOXEDITAF	; demande un nom ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE UPDATE0$	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	CALL	IOADD		; ajoute un fichier .AUDIO	JUMP,NE ERROR$	JUMP	UPDATE0$SAUVE$:	CALL	MAINPUTNAME	; met  jour le nomSAUVE2$:	LOAD.L	A3,#(A6)+OBUNAME	CLR.L	D4	CALL	DBOXEDITOF	; demande un nom ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE NAME$SAUVE4$:	CALL	IOWRITE		; crit un fichier .AUDIO	JUMP,EQ NAME$	COMP.W	D7,#ERFAEX	JUMP,NE ERROR$	CALL	DBOXDETRUIT	; faut-il dtruire ?	COMP.W	D3,#F1	JUMP,NE SAUVE2$	FOS	?DELETE	JUMP	SAUVE4$EXTRAIT$:	CALL	MAINPUTNAME	; met  jour le nom	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE BIP$EXTRAIT2$:	LOAD.L	A3,#(A6)+OBUNADD	CLR.L	D4	CALL	DBOXEDITEF	; demande un nom ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE NAME$EXTRAIT4$:	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	IOEXTRAIT	; crit un fichier .AUDIO	JUMP,EQ NAME$	COMP.W	D7,#ERFAEX	JUMP,NE ERROR$	CALL	DBOXDETRUIT	; faut-il dtruire ?	COMP.W	D3,#F1	JUMP,NE EXTRAIT2$	FOS	?DELETE	JUMP	EXTRAIT4$EFFACE$:	CALL	DBOXEFFACE	; faut-il effacer ?	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	IOFLUSH		; efface tous les sons	CLR.W	(A6)+OSLVAR+OSLCYS	JUMP	UPDATE0$QUIT$:	CALL	DBOXQUITTE	; demande s'il faut quitter ...	COMP.W	D3,#F1	JUMP,NE LOOP$	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_MAIN:	.W	10$-TDBOX_MAIN	.W	TXMENU-TDBOX_MAIN	.W	0,010$:	.B	ODBLABEL,50	; coin sup/gauche visualisation	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,72	.B	ODBLABEL,51	; coin inf/droite visualisation	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBLABEL,60	; coin sup/gauche scroll-liste	.B	ODBTEXT,0	.B	ODBCR2	.B	ODBTABX,28	.B	ODBCIRCLE,0!2^7,KEYDBOX/H'100,0	.ASCIZ	"x1"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,1!2^7,KEYDBOX/H'100,0	.ASCIZ	"x5"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,2!2^7,KEYDBOX/H'100,0	.ASCIZ	"x10"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,3!2^7,KEYDBOX/H'100,0	.ASCIZ	"x50"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,4!2^7,KEYDBOX/H'100,0	.ASCIZ	"x100"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,5!2^7,KEYDBOX/H'100,0	.ASCIZ	"x500"	.B	ODBCR	.B	ODBCR	.B	ODBTABX,28	.B	ODBLABEL,10	.B	ODBTEXT	.ASCIZ	"Nom du son "	.B	ODBLABEL,11	.B	ODBLINE,LADHNAME+1	.B	ODBCR2	.B	ODBCR	.B	ODBCR	.B	ODBTABX,25	.B	ODBLABEL,61	; coin inf/droite scroll-liste	.B	ODBTEXT,0	.B	ODBTABX,28	.B	ODBLABEL,12	.B	ODBBOX,0,DEFINE,TDBNORM	.ASCIZ	" ECOUTE "	.B	ODBLABEL,13	.B	ODBBOX,2^BPROGRA,'C,TDBNORM	.ASCIZ	" CODAGE "	.B	ODBLABEL,20	.B	ODBBOX,0,UNDO,TDBNORM	.ASCIZ	" UNDO "	.B	ODBTABX,72-12	.B	ODBLABEL,14	.B	ODBBOX,2^BPROGRA,'S,TDBNORM	.ASCIZ	" SUPPRIME "	.B	0TXMENU:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"      Ajoute     "	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Extrait          "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"      Efface     "	.EVENTKEY_MAIN:	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MAIN	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_MAIN	.W	0;---------\\; MAINPLAY >;=========/; Fait entendre tout le son.; in	-; out	D7.W	erreur; mod	D7.WMAINPLAY:	PUSHM.L	D1,D2,A4	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE EXIT$	CLR.L	D1		; D1 <-- temps dbut	LOAD.L	D2,(A4)+OADHLG	; D2 <-- temps fin	CALL	IOPLAY		; fait entendre la partie de sonEXIT$:	POPM.L	D1,D2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MAINCODE >;=========/; Choix du codage pour tout le son.; in	-; out	D7.W	erreur; mod	D7.WMAINCODE:	PUSHM.L	D3,A4	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE EXIT$	CALL	DBOXCODE	; choix du codageEXIT$:	POPM.L	D3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MAINSELECT >;===========/; Action sur une zone slectionne.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WMAINSELECT:	PUSHM.L	D3..D5,A2..A4	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE EXIT$	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCURSOR	JUMP',BS CURSOR$	CALL	VISUSELECT	; slectionne le signal ...	JUMP,NE EXIT$	LOAD.W	D7,#1	COMP.L	D1,D2	JUMP,EQ EXIT$	LOAD.L	(A6)+OSELTD,D1	LOAD.L	(A6)+OSELTF,D2	JUMP'	SELECT$CURSOR$:	LOAD.L	D1,(A6)+OSELTD	LOAD.L	D2,(A6)+OSELTF	CALL	VISUINV		; allume la zone slectionneSELECT$:	LOAD.L	A2,A4		; A2 <-- ^son	LOAD.L	A4,#(A6)+OMMPS	; A4 <-- ^paramtres	TSET.B	(A4)+(LMM*0)+OMMINA+3:#2 ; grise dplace	TSET.B	(A4)+(LMM*0)+OMMINA+3:#3 ; grise duplique	LOAD.L	A3,#R16"MMENU$	; A3 <-- ^mmenu	CLR.L	D5		; D5 <-- mode	LIB	?MMENUS		; choix dans mmenu	PUSH.W	D7	CALL	VISUINV		; efface la zone slectionne	POP.W	D7	JUMP,NE EXIT$	LOAD.W	D3,(A4)+OMMSEL	; D3 <-- case slectionne	LOAD.L	A4,A2		; A4 <-- ^son	COMP.W	D3,#1	JUMP',EQ DETR$	COMP.W	D3,#2	JUMP',EQ DEPL$	COMP.W	D3,#3	JUMP',EQ DUPL$	COMP.W	D3,#4	JUMP',EQ VOL$	COMP.W	D3,#5	JUMP',EQ SAVE$	COMP.W	D3,#6	JUMP',EQ PLAY$	JUMP	OK$DETR$:	CALL	VISUDETRUIT	; supprime une partie	JUMP	OK$DEPL$:DUPL$:VOL$:	CALL	DBOXVOL		; choix des volumes ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	CALL	VISUVOL		; modifie le volume	CALL	VISUDRAW	; montre le signal	JUMP	OK$SAVE$:SAVE2$:	LOAD.L	A3,#(A6)+OBUNADD	CLR.L	D4	CALL	DBOXEDITEF	; demande un nom ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE OK$SAVE4$:	CALL	IOEXTRAIT	; crit un fichier .AUDIO	JUMP',EQ OK$	COMP.W	D7,#ERFAEX	JUMP',NE EXIT$	CALL	DBOXDETRUIT	; faut-il dtruire ?	COMP.W	D3,#F1	JUMP,NE SAVE2$	FOS	?DELETE	JUMP	SAVE4$PLAY$:	CALL	IOPLAY		; fait entendre la partie de son	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RETMMENU$:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODETRUIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEPLACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  dplace  "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPRESS	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODUPLIQUE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  duplique "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPRESS	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	-1;	.BW	-2,????$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOVOLUME	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  volume.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSAUVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  sauve.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOECOUTE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  coute"	.B	0	.EVEN;---------\\; MAINBACK >;=========/; Revient en arrire en fonction de la dernire opration effectue.; in	-; out	D7.W	erreur; mod	D7.WMAINBACK:	PUSH.L	A4	LOAD.W	D7,#1	TEST.L	(A6)+OUNPT	; y'a-t-il qq chose  dfaire ?	JUMP',EQ EXIT$		; non => EXIT$	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE EXIT$	CALL	VISUBACK	; revient en arrire	CALL	VISUDRAW	; montre le signal	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MAINVIDRAW >;-----------/; Affiche le son.; in	-; out	-; mod	D7.WMAINVIDRAW:	PUSH.L	A4	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE RIEN$	CALL	VISUDRAW	; dessine le son	JUMP'	EXIT$RIEN$:	CALL	VISUEMPTY	; dessine une zone videEXIT$:	POP.L	A4	RET;-----------\\; MAINVIMOVE >;-----------/; Dplace le son.; in	-; out	D7.W	erreur; mod	D7.WMAINVIMOVE:	PUSH.L	A4	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE EXIT$	CALL	VISUMOVE	; dplace le son ...EXIT$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MAINGREY >;---------/; Grise ou dgrise dans la dbox.; in	-; out	-; mod	D7.WMAINGREY:	PUSHM.L	D2..D4,A4	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE GREY$	LOAD.W	D2,#20!2^BDBGCLABEL!2^BDBGCFULL	TEST.L	(A6)+OUNPT	; y'a-t-il qq chose  dfaire ?	JUMP',NE UNDO$		; oui => UNDO$GREY$:	LOAD.W	D2,#20!2^BDBGCLABEL!2^BDBGCGREYUNDO$:	DBOX_	GETCO	POPM.L	D2..D4,A4	RET;------------\\; MAINGETNAME >;------------/; Cherche le nom slectionn.; in	-; out	A3.L	^nom du son;	A4.L	^fin du nom; mod	D7.W, A3.L, A4.LMAINGETNAME:	PUSHM.L	D2..D4	LOAD.W	D2,#11!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.B	MSPACE,LADHNAME,0	.EVEN	LOAD.L	A3,#(A6)+OSLNAM	CLR.B	(A3)	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE RIEN$	LOAD.L	A4,#(A4)+OADHNAMEXFER$:	LOAD.B	(A3+),(A4+)	JUMP,NE XFER$	LOAD.L	A4,#(A3)-1	; A4 <-- ^fin du nom	LOAD.L	A3,#(A6)+OSLNAM	; A3 <-- ^dbut du nom	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#11!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#12!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#13!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#14!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	JUMP'	EXIT$RIEN$:	LOAD.L	A3,#0		; A3 <-- y'a pas de nom	LOAD.W	D2,#10!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#11!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#12!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#13!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#14!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCOEXIT$:	CLR.W	(A6)+OSLNCH	POPM.L	D2..D4	RET;------------\\; MAINPUTNAME >;------------/; Met  jour le nom dit.; in	A3.L	^nom; out	D7.W	EQ si nom inchang; mod	D7.WMAINPUTNAME:	PUSHM.L	D3,D4,A3,A4	CLR.W	D4	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE NCH$	LOAD.L	A4,#(A4)+OADHNAMEXFER$:	COMP.B	(A4+),(A3+)	JUMP',EQ SAME$	INC.W	D4		; D4 <-- une diffrence de plusSAME$:	LOAD.B	(A4)-1,(A3)-1	JUMP,NE XFER$NCH$:	LOAD.W	(A6)+OSLNCH,D4	LOAD.W	D7,D4	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MAINSLDRAW >;-----------/; Dessine la scroll-liste vide.; in	-; out	-; mod	D7.WMAINSLDRAW:	PUSHM.L	D2..D4,A5	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables scroll-liste	LOAD.W	D2,#61!2^BDBGCLABEL	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#60!2^BDBGCLABEL	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	DEC.W	D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,(A0)+ODFC2Y	SUB.W	D4,D3	INC.W	D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A5)+OSLPOS,D3	LOAD.L	(A5)+OSLDIM,D4	SCROLL_	LDRAW		; dessine la scroll-liste	POPM.L	D2..D4,A5	RET;-------------\\; MAINSLUPDATE >;-------------/; Dessine le contenu de la scroll-liste.; in	-; out	-; mod	D7.WMAINSLUPDATE:	PUSHM.L	D2..D4,A4,A5	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables scroll-liste	LOAD.W	(A5)+OSLCYN,#MAXSON	LOAD.L	A4,#R16"MAINSLTEXT	LOAD.L	(A5)+OSLADL,A4	SCROLL_	LUPDATE		; dessine le contenu	POPM.L	D2..D4,A4,A5	RET;-----------\\; MAINSLMOVE >;-----------/; Dplace la scroll-liste.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WMAINSLMOVE:	PUSH.L	A5	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables scroll-liste	SCROLL_	LMOVE		; dplace ...	JUMP',NE EXIT$	CALL	VISUFLUSH	; copie plus valable	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	A5	RET;-----------\\; MAINSLTEXT >;-----------/; Donne le texte contenu dans une case.; in	D3.W	rang (0..n); out	A3.L	^texte;	D3.W	trait;	D7.W	erreur; mod	D3.L, D7.L, A3.LMAINSLTEXT:	PUSHM.L	D2,D4,A4	LOAD.L	A4,#(A6)+OBUDIS	CLR.L	D4	LOAD.W	D4,D3	INC.W	D4		; D4 <-- 1..n	LOAD.W	D3,#3	CLR.W	D2	LIB	?PUTDEC		; OBUDIS <-- numro	LOAD.B	(A4+),#':	LOAD.B	(A4+),#SPACE	CLR.B	(A4)	LOAD.L	A3,#(A6)+OPSON	DEC.W	D4	SL.W	D4,#2	LOAD.L	D3,(A3)+(D4.W)	JUMP',EQ FREE$	LOAD.L	A3,D3		; A3 <-- ^en-tte	LOAD.L	A3,#(A3)+OADHNAME ; A3 <-- ^nom	JUMP'	XFER$FREE$:	LOAD.L	A3,#R16"TXFREE$XFER$:	LOAD.B	(A4+),(A3+)	; OBUDIS <-- nom	JUMP,NE XFER$OK$:	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^texte	CLR.W	D3		; D3 <-- pas de trait	POPM.L	D2,D4,A4	CLR.W	D7		; D7 <-- ok	RETTXFREE$:.ASCIZ	"<'<> crer<'>>"	.EVEN;---------\\; MAINPSON >;=========/; Cherche le son slectionn dans la scroll-liste.; in	-; out	A4.L	^son;	D7.W	erreur; mod	D7.W, A4.LMAINPSON:	PUSH.L	D4	LOAD.W	D7,#1	LOAD.W	D4,(A6)+OSLVAR+OSLCYS	SL.W	D4,#2	LOAD.L	A4,#(A6)+OPSON	LOAD.L	D4,(A4)+(D4.W)	JUMP',EQ EXIT$	LOAD.L	A4,D4		; A4 <-- ^son	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET	.END