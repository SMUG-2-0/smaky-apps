	.SBTTL	AUDCADRE.ASI;---------\\; DESCADRE >;=========/; Grise toute la fentre et place les icnes.; in	-; out	-; mod	D7.WDESCADRE:	PUSHM.L	D2..D4	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface toute la fentre	CALL	DESMDEF		; D4 <-- trame grise pour le fond	CALL	DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#SETDOT	LIB	?DRMATRIX	; grise toute la fentre	PUSH.L	D4	LOAD.L	D4,#-1	CALL	DRMDEF	POP.L	D4	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LIB	?DRTRAME	; dessine une bande blanche en haut	CALL	DESINFO		; affiche les informations	POPM.L	D2..D4	RET;--------\\; DESMDEF >;========/; Dtermine la trame grise pour le fond.; in	-; out	D4.L	trame grise; mod	D4.L, D7.WDESMDEF:	LOAD.L	D4,#H'88882222	; D4 <-- trame pour cran entrelac	COMP.B	(A6)+OMACHINE,#SMAKY8	JUMP',EQ EXIT$	LOAD.L	D4,#H'88228822	; D4 <-- trame pour joli cranEXIT$:	RET;--------\\; DESINFO >;========/; Dessine les informations.; in	-; out	-; mod	D7.WDESINFO:	PUSHM.L	D3,D4,A3	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	AFINV		; vido inverse	.ASCII	" AUDIO "	.B	AUDREV+'0,'.	.IF	AUDVERS<10	.B	AUDVERS+'0	.ELSE	.B	(AUDVERS/10)+'0,(AUDVERS-((AUDVERS/10)*10))+'0	.ENDIF	.B	AUDPROV	.B	0	.EVEN	LOAD.B	D3,#AFDIR	LIB	?AFCAR	POPM.L	D3,D4,A3	RET	.END