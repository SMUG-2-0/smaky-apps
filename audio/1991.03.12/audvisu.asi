	.SBTTL	AUDVISU.ASI; Les units utilises sont :;;	[p]	-->	point dans l'cran;	[e]	-->	chantillon (28.6us pour 35KHz);	[e/64]	-->	pour l'ascenseur (OSCHTV et OSCPOSV);; Si OSCHTV=2^16-1, cela donne Tmax=120s (2 minutes) !;------------\\; VISUDETRUIT >;============/; Supprime une partie d'un signal.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	-; mod	D7.WVISUDETRUIT:	LOAD.W	(A6)+OUNOP,#OPUNINS	CALL	VISUCOPY	; copie ce qui sera dtruit	CALL	VISUDELETE	; supprime une partie	CALL	VISUDRAW	; montre le signal	RET;--------\\; VISUVOL >;========/; Modifie le volume d'une partie du signal.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	-; mod	D7.WVISUVOL:	PUSHM.L	D0..D4,A3	LOAD.W	(A6)+OUNOP,#OPUNREPL	CALL	VISUCOPY	; copie ce qui sera modifi	LOAD.L	A3,#(A4)+(D1.L)+LADH	SUB.L	D2,D1		; D2 <-- Tf-Td	LOAD.L	D0,D2		; D0 <-- dcompteur	CLR.L	D1		; D1 <-- nLOOP$:	LOAD.W	D3,(A6)+OVOFIN	SUB.W	D3,(A6)+OVODEB	MUL.WA	D3,D1	DIV.WA	D3,D2	ADD.W	D3,(A6)+OVODEB	; D3 <-- facteur en %	CLR.W	D4	LOAD.B	D4,(A3)	SUB.W	D4,#ADNIVZERO	; D4 <-- +/- amplitude	MUL.WA	D4,D3	DIV.WA	D4,#100	ADD.W	D4,#ADNIVZERO	; D4 <-- amplitude "recentre"	JUMP',NC MIN$	CLR.W	D4MIN$:	COMP.W	D4,#ADNIVMAX	JUMP',LS MAX$	LOAD.W	D4,#ADNIVMAXMAX$:	LOAD.B	(A3+),D4	INC.L	D1	DEC.L	D0	JUMP,NE LOOP$	POPM.L	D0..D4,A3	RET;---------\\; VISUBACK >;=========/; Annule la dernire opration effectue.; in	A4.L	^en-tte + son; out	A4.L	^en-tte + son; mod	D7.W, A4.LVISUBACK:	PUSHM.L	D1,D2,A2,A3	TEST.L	(A6)+OUNPT	; copie existe ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.L	A3,(A6)+OUNPT	; A3 <-- ^copie	LOAD.L	D1,(A6)+OUNTD	; D1 <-- temps dbut	LOAD.L	D2,(A6)+OUNTF	; D2 <-- temps fin	COMP.W	(A6)+OUNOP,#OPUNINS	JUMP,EQ INS$	LOAD.L	A2,#(A4)+(D1.L)+LADH	SUB.L	D2,D1RXFER$:	LOAD.B	(A2+),(A3+)	; son <-- remplace par copie	DEC.L	D2	JUMP,NE RXFER$	JUMP'	EXIT$INS$:	CALL	VISUINSERT	; son <-- insre copie;	JUMP'	EXIT$EXIT$:	CALL	VISUFLUSH	; copie plus valable	POPM.L	D1,D2,A2,A3	RET;---------\\; VISUCOPY >;=========/; Copie une partie d'un son.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	D7.W	erreur; mod	D7.WVISUCOPY:	PUSHM.L	D1,D4,A3,A4	CALL	VISUFLUSH	; annule la dernire copie	LOAD.L	(A6)+OUNTD,D1	LOAD.L	(A6)+OUNTF,D2	LOAD.L	A3,#(A4)+(D1.L)+LADH	LOAD.L	D4,D2	SUB.L	D4,D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour copie	JUMP',NE EXIT$	LOAD.L	(A6)+OUNPT,A4LOOP$:	LOAD.B	(A4+),(A3+)	DEC.L	D4	JUMP,NE LOOP$EXIT$:	POPM.L	D1,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; VISUFLUSH >;==========/; Annule la dernire copie.; in	-; out	-; mod	D7.WVISUFLUSH:	PUSHM.L	D1,A4	TEST.L	(A6)+OUNPT	JUMP',EQ EXIT$	LOAD.L	A4,(A6)+OUNPT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire	CLR.L	(A6)+OUNPTEXIT$:	POPM.L	D1,A4	RET;-----------\\; VISUDELETE >;===========/; Supprime une partie d'un signal.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	-; mod	D7.WVISUDELETE:	PUSHM.L	D4,A2,A3	LOAD.L	A3,#(A4)+(D1.L)+LADH	LOAD.L	A2,#(A4)+(D2.L)+LADH	LOAD.L	D4,(A4)+OADHLG	SUB.L	D4,D2	JUMP',EQ TRUNC$XFER$:	LOAD.B	(A3+),(A2+)	DEC.L	D4	JUMP,NE XFER$TRUNC$:	LOAD.L	D4,(A4)+OADHLG	ADD.L	D4,#LADH	ADD.L	D4,D1	SUB.L	D4,D2		; D4 <-- nouvelle longueur	GESMEM	?TRUNCMEM	; mmoire plus courte	ADD.L	(A4)+OADHLG,D1	SUB.L	(A4)+OADHLG,D2	POPM.L	D4,A2,A3	RET;-----------\\; VISUINSERT >;===========/; Insre une partie d'un signal.; in	A4.L	^en-tte + son;	A3.L	^chantillons  insrer;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	A4.L	^en-tte + son;	D7.W	erreur; mod	D7.W, A4.LVISUINSERT:	PUSHM.L	D0..D4,A1..A3,A5	LOAD.L	A2,A4		; A2 <-- ^en-tte + son	LOAD.L	D0,D1	LOAD.L	D4,(A2)+OADHLG	ADD.L	D4,#LADH	ADD.L	D4,D2	SUB.L	D4,D0	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouvelle mmoire	JUMP,NE EXIT$	LOAD.L	A1,A2	LOAD.L	A5,A4	LOAD.L	D4,D0	ADD.L	D4,#LADHXFER1$:	LOAD.B	(A5+),(A1+)	; nouveau <-- dbut	DEC.L	D4	JUMP,NE XFER1$	LOAD.L	D4,D2	SUB.L	D4,D0XFER2$:	LOAD.B	(A5+),(A3+)	; nouveau <-- nouvelle partie	DEC.L	D4	JUMP,NE XFER2$	LOAD.L	D4,(A2)+OADHLG	SUB.L	D4,D0	JUMP',EQ XEND$XFER3$:	LOAD.B	(A5+),(A1+)	; nouveau <-- fin	DEC.L	D4	JUMP,NE XFER3$XEND$:	ADD.L	(A4)+OADHLG,D2	SUB.L	(A4)+OADHLG,D0	EX.L	A2,A4	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancien son	LOAD.L	A3,#(A6)+OPSONSRC$:	COMP.L	A4,(A3+)	JUMP,NE SRC$	LOAD.L	(A3)-4,A2	CLR.W	D7		; D7 <-- okEXIT$:	LOAD.L	A4,A2		; A4 <-- ^nouveau son	POPM.L	D0..D4,A1..A3,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; VISUSELECT >;===========/; Slectionne une partie de signal.; in	A4.L	^en-tte + son;	D4.L	position de la souris (y;x); out	D1.L	temps dbut [e];	D2.L	temps fin   [e];	D7.W	erreur; mod	D1.L, D2.L, D7.WVISUSELECT:	PUSHM.L	D0,D3..D5,A5	LOAD.L	A5,#(A6)+OSCVAR	CALL	VISUGETFACT	; D0 <-- facteur de rduction	CALL	VISUDET		; D1 <-- temps dbut	JUMP,NE EXIT$	LOAD.L	D2,D1LOOP$:	CLR.W	D4	NTREL	?SETTIM		; met timeout trs court	LIB	?GETKEY		; attend souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	JUMP',NE DET$	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,NE END$		; non => END$DET$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	LOAD.L	D3,D1	CALL	VISUDET		; D3 <-- temps fin	EX.L	D1,D3	JUMP,NE LOOP$	TEST.W	(A5)+OSCHTV	; ascenseur actif ?	JUMP',EQ CHG$		; non => CHG$	TEST.B	(A6)+OVSDET	; dpasse  gauche ou  droite ?	JUMP',NE MOVE$		; oui => MOVE$CHG$:	COMP.L	D3,D2		; position change ?	JUMP,EQ LOOP$		; non => LOOP$	CALL	VISUINV		; efface l'ancienne zone	LOAD.L	D2,D3	CALL	VISUINV		; allume la nouvelle zone	JUMP	LOOP$MOVE$:	LOAD.L	D2,D3		; D2 <-- nouveau temps fin	LOAD.W	D5,#10	MUL.WU	D5,D0	SR.L	D5,#6	JUMP',NE MOK$	INC.W	D5MOK$:	TEST.B	(A6)+OVSDET:#1	; dpasse  droite ?	JUMP',BS MGO$	NEG.W	D5MGO$:	LOAD.W	D3,(A5)+OSCPOSV	ADD.W	D3,D5	JUMP',NC MMIN$	CLR.W	D3MMIN$:	COMP.W	D3,(A5)+OSCHTV	JUMP',LO MMAX$	LOAD.W	D3,(A5)+OSCHTV	DEC.W	D3MMAX$:	LOAD.W	(A5)+OSCPOSV,D3	SCROLL_	UPDATE		; mj l'ascenseur	CALL	VISUSIGNAL	; dessine le signal audio	CALL	VISUINV		; allume la nouvelle zone	JUMP	LOOP$END$:	COMP.L	D1,D2	JUMP',LS OK$	EX.L	D1,D2OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0,D3..D5,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; VISUDET >;========/; Dtecte o est la souris.; in	A4.L	^en-tte + son;	D4.L	position de la souris (y;x); out	D1.L	temps [e];	D7.W	erreur; mod	D1.L, D7.WVISUDET:	PUSHM.L	D0,D4	LOAD.W	D7,#1	SWAP.W	D4	SUB.W	D4,(A6)+OVSPOS+0	JUMP',NS EXIT$	COMP.W	D4,(A6)+OVSDIM+0	JUMP',HS EXIT$	SWAP.W	D4	CLR.B	(A6)+OVSDET	; ne dpasse pas	SUB.W	D4,(A6)+OVSPOS+2	JUMP',NC MIN$	CLR.W	D4	TSET.B	(A6)+OVSDET:#0	; dpasse  gaucheMIN$:	COMP.W	D4,(A6)+OVSDIM+2	JUMP',LS MAX$	LOAD.W	D4,(A6)+OVSDIM+2	TSET.B	(A6)+OVSDET:#1	; dpasse  droiteMAX$:	CALL	VISUGETFACT	; D0 <-- facteur de rduction	MUL.WU	D4,D0	CLR.L	D1	LOAD.W	D1,(A6)+OSCVAR+OSCPOSV ; D1 <-- position dbut [e/64]	SL.L	D1,#6		; D1 <-- position dbut [e]	ADD.L	D1,D4	COMP.L	D1,(A4)+OADHLG	JUMP',LS OK$	LOAD.L	D1,(A4)+OADHLGOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; VISUINV >;========/; Inverse une zone.; in	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	-; mod	D7.WVISUINV:	PUSHM.L	D1..D4	LIB	?COLORPUSH	LOAD.L	D3,#COLOR_PPHILI	LIB	?COLORSR	LOAD.L	D4,#-1	CALL	DRMDEF	COMP.L	D1,D2	JUMP',LS NORM$	EX.L	D1,D2NORM$:	CALL	VISUPOS		; D3 <-- position dbut (y;x)	LOAD.L	D4,D3	LOAD.L	D1,D2	CALL	VISUPOS		; D3 <-- position fin (y;x)	EX.L	D3,D4	COMP.W	D3,D4	JUMP',EQ EXIT$	SUB.W	D4,D3	SWAP.W	D4	LOAD.W	D4,(A6)+OVSDIM+0	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse une zoneEXIT$:	LIB	?COLORPOP	POPM.L	D1..D4	RET;--------\\; VISUPOS >;--------/; Cherche la position [p] en fonction d'un temps [e].; in	D1.L	temps [e]; out	D3.L	position (y;x); mod	D3.L, D7.WVISUPOS:	PUSHM.L	D0,D1	CALL	VISUGETFACT	; D0 <-- facteur de rduction	CLR.L	D3	LOAD.W	D3,(A6)+OSCVAR+OSCPOSV ; D3 <-- position dbut [e/64]	SL.L	D3,#6		; D3 <-- position dbut [e]	SUB.L	D1,D3	JUMP',NC MIN$	CLR.L	D1		; D1 <-- tout  gaucheMIN$:	DIV.WU	D1,D0		; D1 <-- position [p]	JUMP',VS OVER$	COMP.W	D1,(A6)+OVSDIM+2	JUMP',LS MAX$OVER$:	LOAD.W	D1,(A6)+OVSDIM+2 ; D1 <-- tout  droiteMAX$:	LOAD.L	D3,(A6)+OVSPOS	ADD.W	D3,D1	POPM.L	D0,D1	RET;----------\\; VISUEMPTY >;==========/; Dessine la zone de visualisation vide.; in	-; out	-; mod	D7.WVISUEMPTY:	PUSHM.L	D2..D4,A5	LOAD.L	D3,(A6)+OVSPOS	LOAD.L	D4,(A6)+OVSDIM	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine rectangle autour	CLR.L	D4	CALL	DRMDEF	LOAD.L	D3,(A6)+OVSPOS	LOAD.L	D4,(A6)+OVSDIM	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'intrieur	LOAD.L	A5,#(A6)+OSCVAR	LOAD.W	D3,(A6)+OVSPOS+2	DEC.W	D3	LOAD.W	(A5)+OSCDEBO,D3	LOAD.W	D3,(A6)+OVSPOS+0	ADD.W	D3,(A6)+OVSDIM+0	LOAD.W	(A5)+OSCDEBL,D3	LOAD.W	D3,(A6)+OVSDIM+2	ADD.W	D3,#2	LOAD.W	(A5)+OSCHTR,D3	SET.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	SCROLL_	DRAW		; dessine l'ascenseur	POPM.L	D2..D4,A5	RET;---------\\; VUSUDRAW >;=========/; Dessine l 'ascenseur et le signal initiaux.; in	A4.L	^en-tte + son; out	-; mod	D7.WVISUDRAW:	PUSHM.L	D0,D3,D4,A5	LOAD.L	A5,#(A6)+OSCVAR	CALL	VISUGETFACT	; D0 <-- facteur de rduction	LOAD.L	D4,(A4)+OADHLG	; D4 <-- lg max [e]	DIV.WU	D4,D0		; D4 <-- lg max [p]	JUMP',VS FULL$	COMP.W	D4,(A6)+OVSDIM+2	JUMP',LS EMPTY$FULL$:	LOAD.L	D4,(A4)+OADHLG	; D4 <-- lg max [e]	SR.L	D4,#6		; D4 <-- lg max [e/64]	LOAD.W	D3,(A6)+OVSDIM+2	MUL.WU	D3,D0		; D3 <-- lg visible [e]	SR.L	D3,#6		; D3 <-- lg visible [e/64]	SUB.W	D3,#2	SUB.W	D4,D3	LOAD.W	(A5)+OSCHTV,D4	LOAD.W	D3,(A5)+OSCPOSV	COMP.W	D3,D4	JUMP',LO UPD$	LOAD.W	D3,D4	DEC.W	D3	LOAD.W	(A5)+OSCPOSV,D3UPD$:	SCROLL_	UPDATE		; met  jour l'ascenseur	JUMP'	SIGNAL$EMPTY$:	CLR.W	(A5)+OSCPOSV	CLR.W	(A5)+OSCHTV	SCROLL_	DRAW		; dessine l'ascenseur videSIGNAL$:	CALL	VISUSIGNAL	; dessine le signal audio	POPM.L	D0,D3,D4,A5	RET;---------\\; VISUMOVE >;=========/; Dplace la partie de l'chantillon visible.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WVISUMOVE:	PUSHM.L	D0..D4,A5	LOAD.L	A5,#(A6)+OSCVAR	SCROLL_	MOVE		; dplace l'ascenseur	JUMP,NE EXIT$	CALL	VISUGETFACT	; D0 <-- facteur de rduction	LOAD.W	D1,#10	MUL.WU	D1,D0	SR.L	D1,#6	JUMP',NE FLECHE$	INC.W	D1FLECHE$:	COMP.W	D4,#SCROLLFDOWN	JUMP',EQ PRESS$	NEG.W	D1	COMP.W	D4,#SCROLLFUP	JUMP',EQ PRESS$	LOAD.W	D1,(A6)+OVSDIM+2 ; D1 <-- largeur visible [p]	MUL.WU	D1,D0		; D1 <-- largeur visible [e]	SR.L	D1,#6		; D1 <-- largeur visible [e/64]	COMP.W	D4,#SCROLLPDOWN	JUMP',EQ PRESS$	NEG.W	D1	COMP.W	D4,#SCROLLPUP	JUMP',EQ PRESS$	CALL	VISUSIGNAL	; dessine le signal audio	JUMP'	OK$PRESS$:	SCROLL_	PRESS		; allume l'icneLOOP$:	LOAD.W	D3,(A5)+OSCPOSV	ADD.W	D3,D1	JUMP',NC MIN$	CLR.W	D3MIN$:	COMP.W	D3,(A5)+OSCHTV	JUMP',LO MAX$	LOAD.W	D3,(A5)+OSCHTV	DEC.W	D3MAX$:	LOAD.W	(A5)+OSCPOSV,D3	SCROLL_	UPDATE		; mj l'ascenseur	CALL	VISUSIGNAL	; dessine le signal audio	LIB	?IFCAR		; attend souris ...	JUMP,NE LOOP$	SCROLL_	PRESS		; teint l'icneOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; VISUSIGNAL >;===========/; Dessine le son dans la zone de visualisation.; in	A4.L	^en-tte + son; out	-; mod	D7.WVISUSIGNAL:	PUSHM.L	D0..D6,A1..A4	CALL	CCMO		; enlve la souris	CLR.L	D4	CALL	DRMDEF	LOAD.L	D3,(A6)+OVSPOS	LOAD.L	D4,(A6)+OVSDIM	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'intrieur	CALL	VISUGETFACT	; D0 <-- facteur de rduction	LOAD.L	A1,(A6)+OLINE	; A1 <-- ^routine GRA_LINE	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	LOAD.L	A3,#(A4)+LADH	; A3 <-- ^premier chantillon	CLR.L	D3	LOAD.W	D3,(A6)+OSCVAR+OSCPOSV ; D3 <-- position dbut [e/64]	SL.L	D3,#6		; D3 <-- position dbut [e]	ADD.L	A3,D3		; A3 <-- ^dbut  visualiser	LOAD.W	D3,(A6)+OVSPOS+0	ADD.W	D3,#ADNIVZERO/2	SWAP.W	D3	LOAD.W	D3,(A6)+OVSPOS+2	LOAD.W	D2,(A6)+OVSDIM+2	CLR.L	D1	LOAD.W	D1,(A6)+OSCVAR+OSCPOSV	SL.L	D1,#6		; D1 <-- position dbut [e]	SUB.L	D1,(A4)+OADHLG	NEG.L	D1		; D1 <-- lg max [e]	DIV.WU	D1,D0		; D1 <-- lg max [p]	COMP.W	D2,D1		; dpasse  droite ?	JUMP',LS GO$		; non => GO$	LOAD.W	D2,D1		; D2 <-- lg max [p]GO$:	COMP.W	D0,#10	JUMP,HI ELOOP$MLOOP$:	CLR.L	D1	LOAD.W	D7,D0MSUM$:	CLR.L	D6	LOAD.B	D6,(A3+)	ADD.L	D1,D6		; D1 <-- somme des chantillons	DEC.W	D7	JUMP,NE MSUM$	DIV.WU	D1,D0		; D1 <-- moyenne des chantillons	LOAD.L	D4,D3	INC.W	D4	SWAP.W	D4	LOAD.W	D4,D1	SR.W	D4,#1	ADD.W	D4,(A6)+OVSPOS+0	SWAP.W	D4	PUSH.L	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	EX.L	D3,D4	LOAD.W	D1,#SETDOT	CALL	(A1)		; appel de GRA_LINE	POP.L	D3	DEC.W	D2	JUMP,NE MLOOP$	JUMP	END$ELOOP$:	LOAD.W	D5,#255		; D5 <-- min	CLR.W	D6		; D6 <-- max	LOAD.W	D7,D0ESUM$:	LOAD.B	D1,(A3+)	COMP.B	D5,D1	JUMP',LS EMIN$	LOAD.B	D5,D1		; D5 <-- minEMIN$:	COMP.B	D6,D1	JUMP',HS EMAX$	LOAD.B	D6,D1		; D6 <-- maxEMAX$:	DEC.W	D7	JUMP,NE ESUM$	SUB.W	D6,D5	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,D5	SR.W	D4,#1	ADD.W	D4,(A6)+OVSPOS+0	LOAD.W	D3,D6	SR.W	D3,#1	SWAP.W	D4	SWAP.W	D3	LOAD.W	D4,D3	CLR.W	D3	LOAD.W	D1,#SETDOT	CALL	(A1)		; appel de GRA_LINE	LOAD.W	D3,D4	INC.W	D3	DEC.W	D2	JUMP,NE ELOOP$;	JUMP'	END$END$:	CALL	SCMO		; remet la souris	POPM.L	D0..D6,A1..A4	RET;------------\\; VISUGETFACT >;============/; Donne le facteur de rduction.; in	-; out	D0.W	facteur de rduction (1,5,10,50,100,500); mod	D0.LVISUGETFACT:	LOAD.W	D0,#500	TEST.B	(A6)+OFAN+3:#5	JUMP',BS EXIT$	LOAD.W	D0,#100	TEST.B	(A6)+OFAN+3:#4	JUMP',BS EXIT$	LOAD.W	D0,#50	TEST.B	(A6)+OFAN+3:#3	JUMP',BS EXIT$	LOAD.W	D0,#10	TEST.B	(A6)+OFAN+3:#2	JUMP',BS EXIT$	LOAD.W	D0,#5	TEST.B	(A6)+OFAN+3:#1	JUMP',BS EXIT$	LOAD.W	D0,#1EXIT$:	RET	.END