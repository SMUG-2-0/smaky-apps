	.TITLE	AUDIO.ASD;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du pilote 300_AUDIO.DRIV	.PROC	M680002	.REF	SMAKY	.REF	BIOSDRIV	.REF	AUDIO	.RADIX	10.	.HEX;	Date		Amliorations; --------------------------------------------------------------------------; 0.2	09.11.90	correction bug; 0.1	01.11.90	premire versionMAJREV	=	0		; rvisionMINREV	=	2		; version	.REV	MAJREV,MINREV; Constantes; ----------ADLGPAGE =	480+3+3+39	; taille d'un buffer correspondant  un balayage cranADNBPAGE =	16*3		; environ 1 secondes (doit tre multiple de 16)_INITINTSON =	H'24VIDEOSOUND =	H'2001014ADMODESONFORT=	H'1000C18ADMODESONMOY=	H'1000C10; Variables; ---------	.LOC	0OPSEM:	.BLKB	4		; ^smaphoreOPBUF:	.BLKB	4		; pointeur d'critureOLEVEL:	.BLKB	1		; niveau (0..255)ONPLAY:	.BLKB	1		; nb de sons en cours	.EVENOLRSTH:	.BLKB	2		; lg restant  lire pour l'en-tteOLRSTB:	.BLKB	4		; lg restant  lire pour le bufferOHEAD:	.BLKB	LADH		; buffer pour en-tteOREL:	.BLKB	ADNIVZERO	; buffer pour le retour  zroOPTA:	.BLKL	(ADNBPAGE/2)+1	; ^liste pour un demi bufferOPTB:	.BLKL	(ADNBPAGE/2)+1OBUF:	.BLKB	ADNBPAGE*ADLGPAGE ; grand bufferLGVAR:	.LOC	0DEBUT:	.W	0,S0BASE	.W	2^7; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;			DRIVER $AUDIO_0		No H'4F; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=S0ID:	.W	S0OPEN-S0BASE	.W	S0COMMAND-S0BASE	.W	-1			; S0RSTATUS-S0BASE	.W	-1			; S0READ-S0BASE	.W	S0WRITE-S0BASE	.W	S0CLOSE-S0BASE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	-1			; AVORTTR	.W	-1			; S0AUX1-S0BASE	.W	-1			; S0AUX2-S0BASE	.W	S0RESET-S0BASE	.W	S0KILL-S0BASE	.W	-1			; S0STRT-S0BASE	.W	-1			; S0TSTRT-S0BASE	.W	-1			; S0START-S0BASES0NAB:	.ASCII	"AUDIO_0"		; nom driverS0NAF:	.FILLB	LGDNAM-(S0NAF-S0NAB),0	.B	H'4F			; numro driver	.B	TYPIO			; type streamer	.B	MAJREV,MINREV		; rvision - version	.B	0			; priorit	.B	0			; rserve	.B	0			; attribut 1	.B	2^BDWROK!2^BDNORT	; attribut 0	.FILLB	LGDDESC-(.-S0ID),0	; le resteS0BASE:;--------\\; S0RESET >;========/; Initialisation du pilote.; in	-; out	A6.L	^variables globales;	D7.W	erreur; mod	D7.W, A6.LS0RESET:	PUSHM.L	D4,A1,A4,A5	LOAD.L	A4,#R16"DEBUT	LOAD.L	D4,#LGVAR	FOS	?GETCOMMEM	JUMP',NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables globales;	CLR.B	(A6)+ONPLAY	; dbut	LOAD.B	(A6)+OLEVEL,#128	CLR.W	D4	NTREL	?CRESEM		; A5 <-- cration du smaphore	JUMP',NE EXIT$	LOAD.L	(A6)+OPSEM,A5	LOAD.L	A1,#R16"INTSON	; A1 <-- ^routine d'interruption	LOAD.L	A4,_INDSHI	CALL	(A4)+_INITINTSONEXIT$:	POPM.L	D4,A1,A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; INTSON  >;--------/; Routine d'interruption excute lorsque l'cran a compltement; termin l'envoi d'une liste de buffers (donne dans VIDEOSOUND).; in	A0.L	^variables globales; out	-; mod	D0.L, D1.L, A0.L, A1.LINTSON:	LOAD.L	A1,(A0)+OPSEM	; A1 <-- ^smaphore	CALLA	_ISIGNEV	; signal la fin	RET;--------\\; S0OPEN  >;========/; Ouverture d'un son.; in	A6.L	^variables globales; out	D7.W	erreur; mod	D7.WS0OPEN:	PUSHM.L	D4,A3..A5	TEST.B	(A6)+ONPLAY	JUMP',EQ OPEN$WAIT$:	LOAD.L	A5,(A6)+OPSEM	; A5 <-- ^smaphore	NTREL	?WAITEV		; attend le SIGNAL de la routine d'interruption ...	DEC.B	(A6)+ONPLAY	JUMP,NE WAIT$OPEN$:	LOAD.L	A3,#(A6)+OBUF	; A3 <-- dbut du buffer	LOAD.L	(A6)+OPBUF,A3	; init pointeur d'criture	LOAD.W	D4,#ADNBPAGE/2	; D4 <-- nombre de pointeurs	LOAD.L	A4,#(A6)+OPTAFILLA$:	LOAD.L	(A4+),A3	; liste <-- met un pointeur	LOAD.L	A3,#(A3)+ADLGPAGE ; A3 <-- ^page suivante	DEC.W	D4	JUMP,NE FILLA$	CLR.L	(A4)		; liste <-- terminateur	LOAD.W	D4,#ADNBPAGE/2	; D4 <-- nombre de pointeurs	LOAD.L	A4,#(A6)+OPTBFILLB$:	LOAD.L	(A4+),A3	; liste <-- met un pointeur	LOAD.L	A3,#(A3)+ADLGPAGE ; A3 <-- ^page suivante	DEC.W	D4	JUMP,NE FILLB$	CLR.L	(A4)		; liste <-- terminateur	LOAD.W	(A6)+OLRSTH,#LADH ; il faudra lire une en-tte	POPM.L	D4,A3..A5	CLR.W	D7		; retour EQ	RET;--------\\; S0WRITE >;========/; Ecrit un son.; in	A6.L	^variables globales;	A4.L	^data;	D5.L	lg data; out	D7.W	erreur; mod	D7.WS0WRITE:	PUSHM.L	D0..D6,A3,A4	TEST.B	(A6)+OLEVEL	; niveau zro ?	JUMP,EQ OK$		; oui => OK$ (silence total)	LOAD.W	D0,#ADNIVZERO	; D0 <-- dernier data crit !BEGIN$:	TEST.L	D5		; reste qq chose  crire ?	JUMP,EQ OK$		; non => OK$	LOAD.W	D4,(A6)+OLRSTH	; D4 <-- lg en-tte restant  lire	JUMP',EQ DATA$	LOAD.L	A3,#(A6)+OHEAD	; A3 <-- ^buffer pour en-tte	LOAD.W	D3,#LADH	SUB.W	D3,D4	ADD.W	A3,D3HLOOP$:	LOAD.B	(A3+),(A4+)	; OHEAD <-- un byte	DEC.L	D5	DEC.W	D4	JUMP',EQ HEND$	TEST.L	D5		; encore un byte ?	JUMP,NE HLOOP$		; oui => HLOOP$	LOAD.W	(A6)+OLRSTH,D4	JUMP	OK$HEND$:	CLR.W	(A6)+OLRSTH	; en-tte entirement lue	COMP.B	(A6)+OHEAD+OADHTYP,#ADHTYPE	JUMP',NE ERROR$	LOAD.L	(A6)+OLRSTB,(A6)+OHEAD+OADHLGDATA$:	LOAD.L	D4,(A6)+OLRSTB	; D4 <-- lg data restant  lire	JUMP',NE DGO$	LOAD.W	(A6)+OLRSTH,#LADH ; il faudra lire une en-tte	JUMP	BEGIN$DGO$:	TEST.L	D5		; reste qq chose  crire ?	JUMP,EQ OK$		; non => OK$	CALL	WRGETP		; A3/D3 <-- ^o crire	LOAD.W	D1,(A6)+OHEAD+OADHFREQ ; D1 <-- frquence d'chantillonage	COMP.W	D1,#ADFREQ	JUMP',EQ F1$	COMP.W	D1,#ADFREQ/2	JUMP,EQ F2$	COMP.W	D1,#ADFREQ/4	JUMP,EQ F4$	COMP.W	D1,#ADFREQ/8	JUMP,EQ F8$ERROR$:	LOAD.W	D7,#ERBINA	; D7 <-- data incorrect	JUMP	EXIT$F1$:	LOAD.L	D1,D3	COMP.L	D1,D4	JUMP',LS F1MIN1$	LOAD.L	D1,D4F1MIN1$:	COMP.L	D1,D5	JUMP',LS F1MIN2$	LOAD.L	D1,D5		; D1 <-- MIN (D3,D4,D5)F1MIN2$:	SUB.L	D3,D1		; D3 <-- lg restante dans demi-buffer	SUB.L	D4,D1		; D4 <-- lg restante dans data	SUB.L	D5,D1		; D5 <-- lg restante  crireF1XFER$:	LOAD.B	(A3+),(A4+)	; copie qq chantillons	DEC.L	D1	JUMP,NE F1XFER$	JUMP	END$F2$:	LOAD.W	D1,D3	AND.W	D1,#B'1	JUMP',EQ F2AEND$F2ALOOP$:	LOAD.B	(A3+),#ADNIVZERO	DEC.L	D3	DEC.W	D1	JUMP,NE F2ALOOP$F2AEND$:	TEST.L	D3	JUMP,EQ END$	SR.L	D3,#1	LOAD.L	D1,D3	COMP.L	D1,D4	JUMP',LS F2MIN1$	LOAD.L	D1,D4F2MIN1$:	COMP.L	D1,D5	JUMP',LS F2MIN2$	LOAD.L	D1,D5		; D1 <-- MIN (D3,D4,D5)F2MIN2$:	SUB.L	D3,D1		; D3 <-- lg restante dans demi-buffer	SUB.L	D4,D1		; D4 <-- lg restante dans data	SUB.L	D5,D1		; D5 <-- lg restante  crire	SL.L	D3,#1F2XFER$:	CLR.W	D6	LOAD.B	D6,(A4+)	LOAD.W	D7,D0	ADD.W	D7,D6	SR.W	D7,#1		; D7 <-- 0.5	LOAD.B	(A3+),D7	LOAD.B	(A3+),D6	LOAD.W	D0,D6		; D0 <-- data prcdent	DEC.L	D1	JUMP,NE F2XFER$	JUMP	END$F4$:	LOAD.W	D1,D3	AND.W	D1,#B'11	JUMP',EQ F4AEND$F4ALOOP$:	LOAD.B	(A3+),#ADNIVZERO	DEC.L	D3	DEC.W	D1	JUMP,NE F4ALOOP$F4AEND$:	TEST.L	D3	JUMP,EQ END$	SR.L	D3,#2	LOAD.L	D1,D3	COMP.L	D1,D4	JUMP',LS F4MIN1$	LOAD.L	D1,D4F4MIN1$:	COMP.L	D1,D5	JUMP',LS F4MIN2$	LOAD.L	D1,D5		; D1 <-- MIN (D3,D4,D5)F4MIN2$:	SUB.L	D3,D1		; D3 <-- lg restante dans demi-buffer	SUB.L	D4,D1		; D4 <-- lg restante dans data	SUB.L	D5,D1		; D5 <-- lg restante  crire	SL.L	D3,#2F4XFER$:	CLR.W	D6	LOAD.B	D6,(A4+)	LOAD.W	D7,D6	SUB.W	D7,D0	ASR.W	D7,#2	ADD.W	D7,D0		; D7 <-- 0.25	LOAD.B	(A3+),D7	LOAD.W	D7,D0	ADD.W	D7,D6	SR.W	D7,#1		; D7 <-- 0.5	LOAD.B	(A3+),D7	LOAD.W	D7,D6	SUB.W	D7,D0	MUL.WA	D7,#3	ASR.W	D7,#2	ADD.W	D7,D0		; D7 <-- 0.75	LOAD.B	(A3+),D7	LOAD.B	(A3+),D6	LOAD.W	D0,D6		; D0 <-- data prcdent	DEC.L	D1	JUMP,NE F4XFER$	JUMP	END$F8$:	LOAD.W	D1,D3	AND.W	D1,#B'111	JUMP',EQ F8AEND$F8ALOOP$:	LOAD.B	(A3+),#ADNIVZERO	DEC.L	D3	DEC.W	D1	JUMP,NE F8ALOOP$F8AEND$:	TEST.L	D3	JUMP,EQ END$	SR.L	D3,#3	LOAD.L	D1,D3	COMP.L	D1,D4	JUMP',LS F8MIN1$	LOAD.L	D1,D4F8MIN1$:	COMP.L	D1,D5	JUMP',LS F8MIN2$	LOAD.L	D1,D5		; D1 <-- MIN (D3,D4,D5)F8MIN2$:	SUB.L	D3,D1		; D3 <-- lg restante dans demi-buffer	SUB.L	D4,D1		; D4 <-- lg restante dans data	SUB.L	D5,D1		; D5 <-- lg restante  crire	SL.L	D3,#3F8XFER$:	CLR.W	D6	LOAD.B	D6,(A4+)	LOAD.W	D7,D6	SUB.W	D7,D0	ASR.W	D7,#3	ADD.W	D7,D0		; D7 <-- 0.125	LOAD.B	(A3+),D7	LOAD.W	D7,D6	SUB.W	D7,D0	ASR.W	D7,#2	ADD.W	D7,D0		; D7 <-- 0.25	LOAD.B	(A3+),D7	LOAD.W	D7,D6	SUB.W	D7,D0	MUL.WA	D7,#3	ASR.W	D7,#3	ADD.W	D7,D0		; D7 <-- 0.375	LOAD.B	(A3+),D7	LOAD.W	D7,D0	ADD.W	D7,D6	SR.W	D7,#1		; D7 <-- 0.5	LOAD.B	(A3+),D7	LOAD.W	D7,D6	SUB.W	D7,D0	MUL.WA	D7,#5	ASR.W	D7,#3	ADD.W	D7,D0		; D7 <-- 0.625	LOAD.B	(A3+),D7	LOAD.W	D7,D6	SUB.W	D7,D0	MUL.WA	D7,#3	ASR.W	D7,#2	ADD.W	D7,D0		; D7 <-- 0.75	LOAD.B	(A3+),D7	LOAD.W	D7,D6	SUB.W	D7,D0	MUL.WA	D7,#7	ASR.W	D7,#3	ADD.W	D7,D0		; D7 <-- 0.875	LOAD.B	(A3+),D7	LOAD.B	(A3+),D6	LOAD.W	D0,D6		; D0 <-- data prcdent	DEC.L	D1	JUMP,NE F8XFER$;	JUMP'	END$END$:	TEST.L	D3		; demi-buffer plein ?	JUMP',NE END2$		; non => END2$	CALL	WRPLAY		; fait entendre une partieEND2$:	LOAD.L	(A6)+OPBUF,A3	; OPBUF <-- ^data	LOAD.L	(A6)+OLRSTB,D4	JUMP	DATA$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRGETP  >;--------/; Donne le pointeur o crire le data.; in	-; out	A3.L	^o crire le data;	D3.L	lg restante; mod	D3.L, A3.LWRGETP:	PUSH.L	A2	LOAD.L	A3,(A6)+OPBUF	; A3 <-- pointeur d'criture	LOAD.L	A2,#(A6)+OBUF	ADD.L	A2,#ADLGPAGE*ADNBPAGE/2 ; A2 <-- ^fin premier demi-buffer	COMP.L	A3,A2		; est-on dans le premier demi-buffer ?	JUMP',LO DEMI$		; oui => DEMI$	ADD.L	A2,#ADLGPAGE*ADNBPAGE/2 ; A2 <-- ^fin deuxime demi-bufferDEMI$:	LOAD.L	D3,A2	SUB.L	D3,A3		; D3 <-- reste dans demi-buffer	CALL	WAITVIDEO	; attend si ncessaire ...	POP.L	A2	RET;--------\\; WRPLAY  >;--------/; Fait entendre le data dj crit.; in	A3.L	^o crire le data;	D3.L	lg restante; out	A3.L	^o crire le data;	D3.L	lg restante; mod	D3.L, A3.LWRPLAY:	PUSH.L	A2	LOAD.L	A2,#(A6)+OBUF	ADD.L	A2,#ADLGPAGE*ADNBPAGE/2 ; A2 <-- ^fin premier demi-buffer	COMP.L	A3,A2	JUMP',HI SECOND$FIRST$:	LOAD.L	A2,#(A6)+OPTA	; A2 <-- ^liste des pages	JUMP'	PLAY$SECOND$:	LOAD.L	A3,#(A6)+OBUF	; A3 <-- on reprend au dbut	LOAD.L	A2,#(A6)+OPTB	; A2 <-- ^liste des pages;	JUMP'	PLAY$PLAY$:	CALL	INITVIDEO	; musique !	LOAD.L	D3,#ADLGPAGE*ADNBPAGE/2 ; D3 <-- reste dans demi-buffer	POP.L	A2	RET;--------\\; S0CLOSE >;========/; Termine le son, attend sa fin et ferme tout.; in	A6.L	^variables globales; out	D7.W	erreur; mod	D7.WS0CLOSE:	PUSHM.L	D3,D4,A2..A4	CALL	WAITVIDEO	; attend si ncessaire ...	LOAD.L	A2,#(A6)+OPTB	; A2 <-- ^liste deuxime moiti	LOAD.L	A3,(A6)+OPBUF	; A3 <-- pointeur d'criture	LOAD.L	A4,#(A6)+OBUF	ADD.L	A4,#ADLGPAGE*ADNBPAGE/2 ; A4 <-- ^dbut deuxime moiti	COMP.L	A3,A4		; est-on dans la deuxime moiti ?	JUMP',HS DEMI$		; oui => DEMI$	SUB.L	A4,#ADLGPAGE*ADNBPAGE/2 ; A4 <-- ^dbut deuxime moiti	LOAD.L	A2,#(A6)+OPTA	; A2 <-- ^liste premire moitiDEMI$:	LOAD.L	D3,A3	SUB.L	D3,A4		; D3 <-- solde du demi-buffer	JUMP',EQ EXIT$		; plus rien => EXIT$	DIV.WU	D3,#ADLGPAGE	; D3 <-- solde en nombre de pages	LOAD.W	D4,D3	SWAP.W	D3		; D3 <-- solde dans page	TEST.W	D3		; dernire tranche vide ?	JUMP',EQ FINLISTE$	INC.W	D4		; D4 <-- il faudra envoyer la dernire pageZERO$:	LOAD.B	(A3+),#ADNIVZERO	INC.W	D3	COMP.W	D3,#ADLGPAGE	JUMP,NE ZERO$FINLISTE$:			; termine la liste	SL.W	D4,#2		; D4 <-- *4 car .L	CLR.L	(A2)+(D4.W)	; indique la dernire tranche	CALL	INITVIDEO	; joue la finEXIT$:	POPM.L	D3,D4,A2..A4	RET;----------\\; INITVIDEO >;==========/; Joue une liste de buffers.; in	A2.L	^liste des pointeurs aux buffers; out	-; mod	D7.WINITVIDEO:	PUSH.L	A5WAIT$:	TEST.L	VIDEOSOUND	; VIDEOSOUND lu par l'cran ?	JUMP,NE WAIT$		; non => WAIT$	LOAD.L	VIDEOSOUND,A2	; musique !	INC.B	(A6)+ONPLAY	POP.L	A5	RET;----------\\; WAITVIDEO >;==========/; Attend si ncessaire la libration d'un demi-buffer.; in	-; out	-; mod	D7.WWAITVIDEO:	PUSH.L	A5	COMP.B	(A6)+ONPLAY,#2	JUMP',LO EXIT$	LOAD.L	A5,(A6)+OPSEM	; A5 <-- ^smaphore	NTREL	?WAITEV		; attend le SIGNAL de la routine d'interruption ...	DEC.B	(A6)+ONPLAYEXIT$:	POP.L	A5	RET;----------\\; S0COMMAND >;==========/; Excute une liste de commandes.; in	A6.L	^variables globales;	A4.L	^table des commandes termine par zro; out	D7.W	erreur; mod	D7.WS0COMMAND:	PUSHM.L	A4	CLR.W	D7		; D7 <-- okLOOP$:	TEST.B	(A4)		; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	CALL	WRONEC		; excute une commande	JUMP,EQ	LOOP$EXIT$:	POPM.L	A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRONEC  >;========/; Excute une commande.; in	A4.L	^commande; out	A4.L	^commande suivante;	D7.W	erreur; mod	D7.W, A4.LWRONEC:	PUSHM.L	D4	LOAD.B	D4,(A4+)	; D4 <-- commande	COMP.B	D4,#'L	JUMP',EQ LEVEL$	LOAD.W	D7,#ERDIIL	; D7 <-- "commande illgale"	JUMP'	EXIT$LEVEL$:	LOAD.B	D4,(A4+)	; D4 <-- volume (0..255)	CALL	COMVOLUME	; choix du volume	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; COMVOLUME >;----------/; Met le niveau gnral (0..3).; in	D4.B	niveau (0..255); out	-; mod	D7.WCOMVOLUME:	LOAD.B	(A6)+OLEVEL,D4	COMP.B	D4,#64*1	JUMP',HS V1$	LOAD.B	ADMODESONFORT,#0	LOAD.B	ADMODESONMOY,#0	JUMP'	EXIT$V1$:	COMP.B	D4,#64*2	JUMP',HS V2$	LOAD.B	ADMODESONFORT,#0	LOAD.B	ADMODESONMOY,#1	JUMP'	EXIT$V2$:	COMP.B	D4,#64*3	JUMP',HS V3$	LOAD.B	ADMODESONFORT,#1	LOAD.B	ADMODESONMOY,#0	JUMP'	EXIT$V3$:;	COMP.B	D4,#64*4;	JUMP',HS EXIT$	LOAD.B	ADMODESONFORT,#1	LOAD.B	ADMODESONMOY,#1;	JUMP'	EXIT$EXIT$:	RET;--------\\; S0KILL  >;========/; Libration du pilote.; in	A6.L	^variables globales; out	D7.W	erreur; mod	D7.W, A6.LS0KILL:	PUSHM.L	A5	LOAD.L	A5,(A6)+OPSEM	NTREL	?KILLSEM	; dtruit le smaphore	POPM.L	A5	CLR.W	D7		; retour EQ	RET	.END