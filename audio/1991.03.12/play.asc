	.TITLE	PLAYFILE.ASC	.PROC	M68030F	.REF	SMAKY	.REF	SHIDRIV300	.REF	INDROM300	.REF	SM300HARD	.REF	BIOSDRIV	.REF	GESMEM	.START	Start;----------------------------------------; Programme de test du son sur Smaky-300; Joue des fichier d'chantillons; J.-F. Gruet et ESPITEC-System S.A.; Septembre 1990;-----------------------------------------; Historique :;-------------;	...;	PYR 15.09.90 : tude des tic !; Constantes :;-------------LgBufSon	= 480+3+3+39	; taille d'un buffer correspondant				;  un balayage d'cranNbBufLi		= 400		; nombre de buffer par listeLgBuf		= (((NbBufLi*LgBufSon)+255)/256)*256	; Conditions d'assemblage :;--------------------------AvecSmile	= 1; Macros de debug :;------------------.MACRO Af				; message et attente clavier	pushm.32	d7|d3	lib		?aftim	.ascize		" (%1) "	lib	?getcar	popm.32		d7|d3.endmacro; Variables :;------------	.LOC	0oChanFile:	.BLK.32	1		; canal du fichier sonoListeBufA:	.BLK.32	NbBufLi+1 	; liste A des ^aux buffers de sonoAdBufA:	.BLK.32	1		; adresse du buffer AoAdXferAB:	.BLK.32	1		; dbut de la zone  transf. A -> BoLgXferAB:	.BLK.32	1		; Longueur du transfertoListeBufB:	.BLK.32	NbBufLi+1	; liste B des ^aux buffers de sonoAdBufB:	.BLK.32	1		; adresse du buffer BoAdXferBA:	.BLK.32	1		; dbut de la zone  transf. B -> AoLgXferBA:	.BLK.32	1		; Longueur du transfertoSemIntSon:	.BLK.32	1		; smaphore avertissant qu'une liste					; de buffers de son a t joueoBufArgs:	.BLK.8	LgArgs		; buffer pour les arg. du fichieroFlags:		.BLK.8	1		; fanions divers BitToutLu	=	0 BitFirstA	=	1 BitFirstB	=	1.ALIGN	4LgVar:; Programme  principal :;-----------------------	.LOC	0Start:	.IF	AvecSmile	.ELSE	LIB		?OpeLib		; ouverture librairie (pour .CODE)	.ENDIF	MOVE.16		#MTYPCP, D1	MOVE.32		#LgVar, D4	GESMEM		?GetMem		; mmoire pour les variables	JUMP,NE		ErFatDeb	GESMEM		?ClearMem	MOVE.32		A4, A6	MOVE.32		#LgBuf, D4	MOVE.16		#MTYPCP, D1	GESMEM		?GETMEM		; mmoire pour les sone	JUMP,NE		ErFatDeb	MOVE.32		A4, {A6}+oAdBufA ; buffer A	GESMEM		?GETMEM		; buffer B	JUMP,NE		ErFatDeb	MOVE.32		A4, {A6}+oAdBufB	CALL	MONITEUR	CLR.16		D4	NTREL		?CreSem	JUMP,NE		ErFatDeb	MOVE.32		A5, {A6}+OSemIntSon	MOVE.32		#R16^IntSon, A1	CALL		{_IndShi}+_InitIntSon	MOVE.32		#R16^SendListe, A5	NTREL		?IEP15TRP	.IF	AvecSmile	MOVE.32		#R16^NamSon, A3	; nom au bas du fichier	.ELSE	PUSH.32		A3			; ligne de commande	LIB		?AFTEXT			; affiche	POP.32		A3	LIB		?SKPNAM			; saute le nom du .CODE	.ENDIF;;	MOVE.32		#2**BOPRD+2**BopExtend+2**BopMMUNIt, D3	MOVE.32		#2**BOPRD+2**BopExtend, D3	FOS		?ARGSOPEN	JUMP,NE		ErFat;;	CALL	VOLUME; Transfert de B vers ALoop$:	MOVE.32		#LgBuf, D0	MOVE.32		{A6}+oAdBufA, A4	MOVE.32		{A6}+oAdXferBA, A3	MOVE.32		{A6}+oLgXferBA, D4	JUMP,EQ		FillBufA$	GESMEM		?CopyMem	TEST.8		{A6}+oFlags:#BitToutLu	JUMP,BC		FillBufA$	ADD.32		D4, A4	MOVE.32		#LgBufSon, D0	SUB.32		D4, D0	MOVE.32		D0, D4	GESMEM		?ClearMem	MOVE.16		#1, D1	JUMP		FinA$FillBufA$:	ADD.32		D4, A4	SUB.32		D4, D0	CLR.8		D0	MOVE.32		D0, D4	FOS		?RDBYTE		; lit quelques blocs	JUMP,EQ		RdAOk$	COMP.16		#EROUTF, D7	JUMP,NE		ErRead;Af EroutfA	TSET.8		{A6}+oFlags:#BitToutLu	MOVE.32		D4, D0		; nombre de bytes effectivement lus --> D0.32	ADD.32		{A6}+oLgXferBA, D0	; nombre de bytes de son dans le buffer --> D0.32	MOVE.32		D0, D1	ADD.32		#LgBufSon-1, D0	DIV.16		#LgBufSon, D0	MUL.16		#LgBufSon, D0	COMP.32		#LgBuf, D0	; hors du buffer en le compltant par des zros ?	JUMP,LS		ClearA$		; non => on complte					; oui =>	MOVE.32		{A6}+oAdBufA, {A6}+oAdXferAB	SUB.32		#LgBufSon, D0	ADD.32		D0, {A6}+oAdXferAB	SUB.32		D0, D1	MOVE.32		D1, {A6}+oLgXferAB	DIV.16		#LgBufSon, D0	MOVE.16		D0, D2	DEC.16		D2	MOVE.32		#{A6}+oListeBufA, A1Af InitLastListeAL00$:	MOVE.32		A0, {A1+}	ADD.32		#LgBufSon, A0	DJ.16,NMO	D2, L00$	CLR.32		{A1+}	JUMP		SendListeA$ClearA$:	MOVE.32		D0, D1	DIV.16		#LgBufSon, D1	; nombre de buffer --> D1.32	SUB.32		D4, D0	ADD.32		D4, A4	MOVE.32		D0, D4	GESMEM		?ClearMem	; complte avec des zrosFinA$:	MOVE.32		{A6}+oAdBufA, A0	MOVE.32		#{A6}+oListeBufA, A1	MOVE.16		D1, D2	DEC.16		D2L01$:	MOVE.32		A0, {A1+}	ADD.32		#LgBufSon, A0	DJ.16,NMO	D2, L01$	CLR.32		{A1+}	CALL		SendListeA		; envoie la liste A	JUMP		Fin	RdAOk$:;Af RdAOk	ADD.32		{A6}+oLgXferBA, D0	; nbre de bytes de son --> D0.32	MOVE.32		D0, D1	DIV.16		#LgBufSon, D1; initialisation de la liste A des pointeurs aux buffers	MOVE.32		{A6}+oAdBufA, A0	MOVE.32		#{A6}+oListeBufA, A1	MOVE.16		D1, D2	DEC.16		D2InitListeA$:	MOVE.32		A0, {A1+}	ADD.32		#LgBufSon, A0	DJ.16,NMO	D2, InitListeA$	CLR.32		{A1+}	MUL.16		#LgBufSon, D1	MOVE.32		{A6}+oAdBufA, {A6}+oAdXferAB	ADD.32		D1, {A6}+oAdXferAB	SUB.32		D1, D0	MOVE.32		D0, {A6}+oLgXferAB	; nombre de bytes  transfrer de A vers BSendListeA$:	CALL		SendListeA; Cas de la liste B; -----------------	MOVE.32		#LgBuf, D0	MOVE.32		{A6}+oAdXferAB, A3	MOVE.32		{A6}+oAdBufB, A4	MOVE.32		{A6}+oLgXferAB, d4	JUMP,EQ		FillBufB$	GESMEM		?CopyMem	TEST.8		{A6}+oFlags:#BitToutLu	JUMP,BC		FillBufB$	ADD.32		D4, A4	MOVE.32		#LgBufSon, D0	SUB.32		D4, D0	MOVE.32		D0, D4	GESMEM		?ClearMem	MOVE.16		#1, D1	JUMP		FinB$FillBufB$:	ADD.32		D4, A4	SUB.32		D4, D0	CLR.8		D0	MOVE.32		D0, D4	FOS		?RDBYTE		; lit quelques blocs	JUMP,EQ		RdBOk$	COMP.16		#EROUTF, D7	JUMP,NE		ErRead;Af EroutfB	TSET.8		{A6}+oFlags:#BitToutLu	MOVE.32		D4, D0		; nombre de bytes effectivement lus --> D0.32	ADD.32		{A6}+oLgXferAB, D0	; nombre de bytes de son dans le buffer --> D0.32	MOVE.32		D0, D1	ADD.32		#LgBufSon-1, D0	DIV.16		#LgBufSon, D0	MUL.16		#LgBufSon, D0	COMP.32		#LgBuf, D0	; hors du buffer en le compltant par des zros ?	JUMP,LS		ClearB$		; non => on complte					; oui =>	MOVE.32		{A6}+oAdBufB, {A6}+oAdXferBA	SUB.32		#LgBufSon, D0	ADD.32		D0, {A6}+oAdXferBA	SUB.32		D0, D1	MOVE.32		D1, {A6}+oLgXferBA	DIV.16		#LgBufSon, D0	MOVE.16		D0, D2	DEC.16		D2L02$:	MOVE.32		A0, {A1+}	ADD.32		#LgBufSon, A0	DJ.16,NMO	D2, L02$	CLR.32		{A1+}	JUMP		SendListeB$ClearB$:	MOVE.32		D0, D1	DIV.16		#LgBufSon, D1	; nombre de buffer --> D1.32	SUB.32		D4, D0	ADD.32		D4, A4	MOVE.32		D0, D4	GESMEM		?ClearMem	; complte avec des zrosFinB$:	MOVE.32		{A6}+oAdBufB, A0	MOVE.32		#{A6}+oListeBufB, A1	MOVE.16		D1, D2	DEC.16		D2L03$:	MOVE.32		A0, {A1+}	ADD.32		#LgBufSon, A0	DJ.16,NMO	D2, L03$	CLR.32		{A1+}	CALL		SendListeB		; envoie la liste B	JUMP		Fin	RdBOk$:;Af RdBOk	ADD.32		{a6}+oLgXferAB, D0	MOVE.32		D0, D1	DIV.16		#LgBufSon, D1; initialisation de la liste B des pointeurs aux buffers	MOVE.32		{A6}+oAdBufB, A0	MOVE.32		#{A6}+oListeBufB, A1	MOVE.16		D1, D2	DEC.16		D2InitListeB$:	MOVE.32		A0, {A1+}	ADD.32		#LgBufSon, A0	DJ.16,NMO	D2, InitListeB$	CLR.32		{A1+}	MUL.16		#LgBufSon, D1	MOVE.32		{A6}+oAdBufA, {A6}+oAdXferBA	ADD.32		D1, {A6}+oAdXferBA	SUB.32		D1, D0	MOVE.32		D0, {A6}+oLgXferBA	; nombre de bytes  transfrer de B vers ASendListeB$:	CALL		SendListeB	JUMP		LOOP$; Sortie du programme;---------------------Fin:	move.32		{a6}+oSemIntSon, A5	LIB		?aftim	.ascize		"<CR>WaitEvA"	NTREL		?WaitEv; +++ jmp	move.8		#0,adson	move.32		#50,d4	ntrel		?delms	move.8		#0,adson; +++ jmp	MOVE.8		#0,AdCioPortC		; Dconnecte le son.	LIB		?AFTIM	.ASCIZE		"<cr>WaitEvB";	ntrel		?WaitEv	FOS		?CLOSE	MOVE.32		{A6}+oSemIntSon, A5	NTREL		?KILLSEM	MOVE.16		#Mtypcp, D1	MOVE.32		{A6}+oAdBufA, A4	GESMEM		?GIVMEM	MOVE.32		{A6}+oAdBufB, A4	GESMEM		?GIVMEM	MOVE.32		A6, A4	GESMEM		?GIVMEMSort:	LIB		?AFTIM	.ASCIZE		"<CR> Fin du programme !"	.IF	AvecSmile	EXIT	.ELSE	LIB		?CLOLIB	FOS		?STOP	.ENDIF	SendListeA:CALL	VOLUME	PUSHM.32	A4|A5	MOVE.32		{A6}+oSemIntSon, a5	Tset.8		{A6}+oFlags:#BitFirstA	jump,bc		S$	ntrel		?WaitEvS$:	MOVE.32		#{A6}+oListeBufA, A4	TRAP		#15	POPM.32		A4|A5	RETSendlisteB:CALL	VOLUME	PUSHM.32	A4|A5	MOVE.32		{A6}+oSemIntSon, a5	tset.8		{a6}+oFlags:#BitFirstB	JUMP,BC		S$	ntrel		?WaitEvS$:	MOVE.32		#{A6}+oListeBufB, A4	TRAP		#15	POPM.32		A4|A5	RETSendListe:	MOVE.32		A4, VideoSoundFirst	POPM.32		D0|A0	RETSF; Reprise des erreurs :;----------------------ErFatDeb:				; avant l'installation du smaphore	PUSH.16		D7	LIB		?AFTIM	.ASCIZE		"<CR>Erreur fatale: "	POP.16		D7	LIB		?AFERROR	JUMP		Sort		; sortie directeErFat:					; Erreur dans le programme	PUSH.16		D7	LIB		?AFTIM	.ASCIZE		"<CR>Erreur fatale: "	POP.16		D7	LIB		?AFERROR	JUMP		FinErRead:					; lors de la lecture	PUSH.16		D7	LIB		?AFTIM	.ASCIZE		"<CR>Erreur lors du Read: "	POP.16		D7	LIB		?AFERROR	JUMP		FinVOLUME:					; initialisation du volume max	MOVE.8		#1, AdModeSonFort	MOVE.8		#1, AdModeSonMoy	MOVE.8		#1,AdCioPortC	; Connecte le son.	RET; Routine d'interruption :;-------------------------IntSon:	MOVE.32		{A0}+oSemIntSon, A1	CALL		A16^_ISIGNEV	RET; Moniteur :;-----------Moniteur:LOOP$:	LIB		?GETCAR	LIB		?MINMAJ	COMP.8		#"0",D3	JUMP,EQ		OFF$	COMP.8		#"1",D3	JUMP,EQ		ON$	COMP.8		#END,D3	JUMP,EQ		FIN$	JUMP		LOOP$ON$:	MOVE.8		#1,AdCioPortC	; Connecte le son.	JUMP		LOOP$OFF$:	MOVE.8		#0,AdCioPortC	; Connecte le son.	JUMP		LOOP$FIN$:	RET	.IF AvecSmileNamSon:	.ASCIZE	"jmp03.SND"		; nom du ficher	.ENDIF	.END