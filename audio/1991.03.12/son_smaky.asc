	.TITLE	SON_SMAKY.ASC	.PROC	M68020	.BASE	10'10	.REF	SMAKY	.REF	BIOSDRIV	.REF	SM324HARD;;	.REF	SHIDRIV324	.REF	MON; Programme de test de l'interface son des Smakys 8,100,324, et 300; -----------------------------------------------------------------; B. Brunner et G. van Ruymbeke, mars 1990; modifs du 22.5.90:	GVR+JMP.; Essais P.-Y. Rochat, septembre 1990; constantes; ----------; adresse de base priphrique (A5 ^):AdSound		=	ADMUBUS; offsets priphriques (accs byte):OSNDIntmask	=	10'36	; R+W:	masque d'interruption: 0: masqu, 1: non-masqu BSNDIntMOut	=	 7	;	  en sortie... BSNDIntMIn	=	 6	;	  en entre...OSNDStatus	=	10'32	; R:	status des fifos BSNDSTOutOk	=	 7	;	  en sortie: /OHF BSNDSTInOk	=	 6	;	  en entre: IHFOSNDData	=	8	; R+W:	registre parallle de communicationOSNDRzFIFO	=	10'12	; W:	reset des FIFOSOSNDVolume	=	10'32	; W:	Volume en sortie BVolHigh	=	 7	; Bit de poid fort. BVolLow	=	 6	; Bit de poid fort.; pour le debug:LGMYMEM		=	35000*5	; longueur bufffer pour acquisionLGTRF		=	512LGNAMEBUF	=	128; variables; ---------		.LOC	0	; pour l'exploitation:OADHARD:	.BLK.32	1	; adresse de base priphrique sound pour routine d'interruptionOSEMAINT:	.BLK.32	1	; smaphore d'interruptionOWRADR:		.BLK.32	1	; adresse courante d'missionOWRLG:		.BLK.32	1	; longueur courante d'missionORDADR:		.BLK.32	1	; adresse courante de rceptionORDLG:		.BLK.32	1	; longueur courante de rception	; pour le debug:OMYMEM:		.BLK.32	1	; ^buffer de LGMYMEM bytesONAMEBUF:	.BLK.8	LGNAMEBUFLGVAR:; programme	.START	START	.LOC	0START:	MOVE.32	A4,A6	MOVE.32	#ADSOUND,A5	MOVE.32	A5,{A6}+OADHARD			; mmorise pour routine d'interruption	MOVE.8	#0,{A5}+OSNDIntMask		; clear toutes les interruptions	MOVE.8	#16'0FF,{A5}+OSNDRzFIFO		; reset les FIFOS	MOVE.8	#0,{A5}+OSNDRzFIFO	MOVE.8	#16'0FF,{A5}+OSNDVolume		; Volume maximum en sortie	MOVE.16	#MTYPCP,D1	MOVE.32	#LGMYMEM,D4	GESMEM	?GETMEM	JUMP,NE	ERFAT1	MOVE.32	A4,{A6}+OMYMEMLOOP:	LIB	?AFTIM	.ASCII	"<CR>PROGRAMME DE TEST SON SMAKY 400<CR>"	.ASCII	"0) Ecriture continue de RzFIFO<CR>"	.ASCII	"1) Test accs status + mask<CR>"	.ASCII	"2) Une seconde de sinus en criture par polling<CR>"	.ASCII	"3) Enregistrement de 5 secondes<CR>"	.ASCII	"4) Restitution de 5 secondes<CR>"	.ASCII	"5) Test des interruptions<CR>"	.ASCII	"6) Test acquisition par interruption<CR>"	.ASCII	"7) Test rendu par interruption<CR>"	.ASCII	"9) Remplit un motif de test dans la ram du smaky<CR>"	.ASCII	"R) Lecture d'un fichier de parole dans la ram du smaky<CR>"	.ASCII	"W) Ecriture de la ram du smaky dans un fichier<CR>"	.ASCII	"END) Fin<CR>"	.ASCIZE	"Votre choix: "	LIB	?GETCAR,?MINMAJ,?AFCAR,?AFCR,?AFCR	clr.16	d7	COMP.8	#"0",D3	JUMP,EQ	TEST0	COMP.8	#"1",D3	JUMP,EQ	TEST1	COMP.8	#"2",D3	JUMP,EQ	TEST2	COMP.8	#"3",D3	JUMP,EQ	TEST3	COMP.8	#"4",D3	JUMP,EQ	TEST4	COMP.8	#"5",D3	JUMP,EQ	TEST5	COMP.8	#"6",D3	JUMP,EQ	TEST6	COMP.8	#"7",D3	JUMP,EQ	TEST7	COMP.8	#"9",D3	JUMP,EQ	TEST9	COMP.8	#"R",D3	JUMP,EQ	READFILE	COMP.8	#"W",D3	JUMP,EQ	WRITEFILE	COMP.8	#END,D3	JUMP,EQ	FIN	JUMP	LOOPFIN:	MOVE.32	{A6}+OMYMEM,A4	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM	JUMP,NE	ERFAT1EXXIT:	MOVE.8	#0,{A5}+OSNDIntMask	EXIT	JUMP	LOOPERFAT:	LIB	?AFERROR	JUMP	FINERFAT1:	LIB	?AFERROR	JUMP	EXXITTEST0:	MOVE.32	#1000000,D0LO$:	MOVE.8	#16'0FF,{A5}+OSNDRzFIFO		; reset les FIFOS	MOVE.8	#0,{A5}+OSNDRzFIFO	MOVE.8	#16'0,{A5}+OSNDVolume		; @@@	MOVE.8	#16'0FF,{A5}+OSNDVolume		; @@@	DEC.32	D0	JUMP,NE	LO$	JUMP	LOOPTEST1:	MOVE.8	{A5}+OSNDStatus,D4	LIB	?AFX2,?AFSPACE	MOVE.8	{A5}+OSNDIntMask,D4	LIB	?AFX2,?AFSPACE	JUMP	LOOPTEST2:	MOVE.8	#16'0FF,{A5}+OSNDRzFIFO		; reset les FIFOS	MOVE.8	#0,{A5}+OSNDRzFIFO	MOVE.16	#35000/LGTRF-1,D2	MOVE.32	{A6}+OMYMEM,A1LOP2$:	MOVE.16	#LGTRF/(256/8)-1,D1LOP1$:	MOVE.32	#R16^TABSIN,A0	MOVE.16	#(256/8)-1,D0LOP$:	MOVE.8	{A0},{A5}+OSNDData	MOVE.8	{A0},{A1+}	ADD.32	#256/(256/8),A0	DJ.16,NMO D0,LOP$	DJ.16,NMO D1,LOP1$	MOVE.32	#1000000,D3LOP0$:	TEST.8	{A5}+OSNDStatus:#BSNDSTOutOk	JUMP,BS LOP0ok$	DEC.32	D3	JUMP,NE	LOP0$LOP0ok$:	SKIP,BC	DJ.16,NMO D2,LOP2$	; BC = EQ	JUMP	LOOPTEST9:	MOVE.32	{A6}+OMYMEM,A1	MOVE.16	#35000/2/LGTRF-1,D2LOP2$:	MOVE.16	#LGTRF/(256/8)-1,D1LOP1$:	MOVE.32	#R16^TABSIN,A0	MOVE.16	#(256/8)-1,D0LOP$:	MOVE.8	{A0},{A1+}	ADD.32	#256/(256/8),A0	DJ.16,NMO D0,LOP$	DJ.16,NMO D1,LOP1$	DJ.16,NMO D2,LOP2$	MOVE.16	#35000/2/LGTRF-1,D2ALOP2$:	MOVE.16	#LGTRF/(256/16)-1,D1ALOP1$:	MOVE.32	#R16^TABSIN,A0	MOVE.16	#(256/16)-1,D0ALOP$:	MOVE.8	{A0},{A1+}	ADD.32	#256/(256/16),A0	DJ.16,NMO D0,ALOP$	DJ.16,NMO D1,ALOP1$	DJ.16,NMO D2,ALOP2$	MOVE.16	#35000/2/LGTRF-1,D2DLOP2$:	MOVE.16	#LGTRF/(256/32)-1,D1DLOP1$:	MOVE.32	#R16^TABSIN,A0	MOVE.16	#(256/32)-1,D0DLOP$:	MOVE.8	{A0},{A1+}	ADD.32	#256/(256/32),A0	DJ.16,NMO D0,DLOP$	DJ.16,NMO D1,DLOP1$	DJ.16,NMO D2,DLOP2$	MOVE.16	#35000/2/LGTRF-1,D2ELOP2$:	MOVE.16	#LGTRF/(256/64)-1,D1ELOP1$:	MOVE.32	#R16^TABSIN,A0	MOVE.16	#(256/64)-1,D0ELOP$:	MOVE.8	{A0},{A1+}	ADD.32	#256/(256/64),A0	DJ.16,NMO D0,ELOP$	DJ.16,NMO D1,ELOP1$	DJ.16,NMO D2,ELOP2$	MOVE.16	#35000/2/LGTRF-1,D2FLOP2$:	MOVE.16	#LGTRF/(256/84)-1,D1FLOP1$:	MOVE.32	#R16^TABSIN+256/(256/84),A0	MOVE.16	#(256/84)-1,D0FLOP$:	MOVE.8	{A0},{A1+}	ADD.32	#256/(256/84),A0	DJ.16,NMO D0,FLOP$	DJ.16,NMO D1,FLOP1$	DJ.16,NMO D2,FLOP2$	MOVE.16	#35000/2/LGTRF-1,D2BLOP2$:	MOVE.16	#LGTRF/(256/4)-1,D1BLOP1$:	MOVE.32	#R16^TABSIN,A0	MOVE.16	#(256/4)-1,D0BLOP$:	MOVE.8	{A0},{A1+}	ADD.32	#256/(256/4),A0	DJ.16,NMO D0,BLOP$	DJ.16,NMO D1,BLOP1$	DJ.16,NMO D2,BLOP2$	MOVE.16	#35000/2/LGTRF-1,D2CLOP2$:	MOVE.16	#LGTRF/(256/8)-1,D1CLOP1$:	MOVE.32	#R16^TABSIN,A0	MOVE.16	#(256/8)-1,D0CLOP$:	MOVE.8	{A0},{A1+}	ADD.32	#256/(256/8),A0	DJ.16,NMO D0,CLOP$	DJ.16,NMO D1,CLOP1$	DJ.16,NMO D2,CLOP2$	JUMP	LOOPTEST3:	MOVE.8	#16'0FF,{A5}+OSNDRzFIFO		; reset les FIFOS	MOVE.8	#0,{A5}+OSNDRzFIFO	MOVE.32	#1000000,D3LP$:	TEST.8	{A5}+OSNDStatus:#BSNDSTInOk	JUMP,BS ok$	DEC.32	D3	JUMP,NE	LP$ok$:	MOVE.32	{A6}+OMYMEM,A1	MOVE.16	#LGMYMEM/LGTRF-1,D2LOP2$:	MOVE.16	#LGTRF/4/4-1,D1LOP1$:.IF	1					;@@@	MOVE.32	{A5}+OSNDData,{A1+}	MOVE.32	{A5}+OSNDData,{A1+}	MOVE.32	{A5}+OSNDData,{A1+}	MOVE.32	{A5}+OSNDData,{A1+}.ELSE	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}	MOVE.8	{A5}+OSNDData,D0	MOVE.8	{D0}+R16^TABIDATA,D0	MOVE.8	D0,{A1+}.ENDIF	DJ.16,NMO D1,LOP1$	MOVE.32	#1000000,D3LOP0$:	TEST.8	{A5}+OSNDStatus:#BSNDSTInOk	JUMP,BS LOP0ok$	DEC.32	D3	JUMP,NE	LOP0$LOP0ok$:	SKIP,BC	DJ.16,NMO D2,LOP2$	; BC = EQ	JUMP	LOOPTEST4:	MOVE.8	#16'0FF,{A5}+OSNDRzFIFO		; reset les FIFOS	MOVE.8	#0,{A5}+OSNDRzFIFO	MOVE.32	{A6}+OMYMEM,A1	MOVE.16	#LGMYMEM/LGTRF-1,D2LOP2$:	MOVE.16	#LGTRF/3/4-1,D1LOP1$:	MOVE.8	{A1},{A5}+OSNDData	MOVE.8	{A1+},{A5}+OSNDData	MOVE.8	{A1+},{A5}+OSNDData	MOVE.8	{A1},{A5}+OSNDData	MOVE.8	{A1+},{A5}+OSNDData	MOVE.8	{A1+},{A5}+OSNDData	MOVE.8	{A1},{A5}+OSNDData	MOVE.8	{A1+},{A5}+OSNDData	MOVE.8	{A1+},{A5}+OSNDData	DJ.16,NMO D1,LOP1$	MOVE.32	#1000000,D3LOP0$:	TEST.8	{A5}+OSNDStatus:#BSNDSTOutOk	JUMP,BS LOP0ok$	DEC.32	D3	JUMP,NE	LOP0$LOP0ok$:	SKIP,BC	DJ.16,NMO D2,LOP2$	; BC = EQ	JUMP	LOOPREADFILE:	PUSH.32	A5	LIB	?AFTIM	.ASCIZE	"Lire: Quel fichier ? "	MOVE.32	#{A6}+ONAMEBUF,A3	MOVE.32	A3,A4	MOVE.32	#0,A5	MOVE.32	#LGNAMEBUF,D3	MOVE.8	#0,{A4}	LIB	?GETFILE	COMP.8	#CR,D3	JUMP,NE	RTN$	MOVE.32	#2**BOPRD,D3	FOS	?OPEN	JUMP,NE	RTNER$	MOVE.32	{A6}+OMYMEM,A4	MOVE.32	#LGMYMEM,D4	FOS	?RDBYTE	PUSH.16	D7	FOS	?CLOSE	POP.16	D7	JUMP,EQ	RTN$RTNER$:	LIB	?AFERRORRTN$:	LIB	?AFCR	POP.32	A5	JUMP	LOOPWRITEFILE:	PUSH.32	A5	LIB	?AFTIM	.ASCIZE	"Ecrire: Quel fichier ? "	MOVE.32	#{A6}+ONAMEBUF,A3	MOVE.32	A3,A4	MOVE.32	#0,A5	MOVE.8	#0,{A4}	MOVE.32	#LGNAMEBUF,D3	LIB	?GETFILE	COMP.8	#CR,D3	JUMP,NE	RTN$	MOVE.32	#DEFATT,D3	LIB	?FCREATE	JUMP,NE	RTNER$	MOVE.32	{A6}+OMYMEM,A4	MOVE.32	#LGMYMEM,D4	FOS	?WRBYTE	PUSH.16	D7	FOS	?CLOSE	POP.16	D7	JUMP,EQ	RTN$RTNER$:	LIB	?AFERRORRTN$:	LIB	?AFCR	POP.32	A5	JUMP	LOOPTEST5:	PUSH.32	A5	MOVE.32	#R16^SUPER$,A5	NTREL	?IEP15TRP	POP.32	A5	TRAP	#15	JUMP	USER$SUPER$:	MOVE.32	#R16^TESTINTERRUPT,A1	MOVE.32	#16'64,A0	MOVE.32	_INDNTR,A2	CALL	{A2}+OIN_INITVECTOR	POPM.32	D0|A0	RETSFUSER$:	TSET.8	{A5}+OSNDIntMask:#BSNDIntMOut	NOP	NOP	NOP	NOP	NOP	NOP	TSET.8	{A5}+OSNDIntMask:#BSNDIntMIn	NOP	NOP	NOP	NOP	NOP	NOP	MOVE.8	#0,{A5}+OSNDIntMask	LIB	?AFTIM	.ASCIZE	"S'il n'y a pas de message ici, c'est que l'interruption dconne...<CR>"	JUMP	LOOPTESTINTERRUPT:	PUSHM.32 A5|A6	MOVE.32	A0,A6	MOVE.32	{A6}+OADHARD,A5	MOVE.8	{A5}+OSNDIntMask,D0	MOVE.8	#0,{A5}+OSNDIntMask	TEST.32	D0:#BSNDIntMOut	JUMP,BC	LECTURE$	MON	?AFTIM	.ASCIZE	"COUCOU, INTERRUPTION ECRITURE !<CR>"LECTURE$:	TEST.32	D0:#BSNDIntMIn	JUMP,BC	RTN$	MON	?AFTIM	.ASCIZE	"COUCOU, INTERRUPTION LECTURE !"RTN$:	POPM.32	A5|A6	RETTEST6:	MOVE.8	#16'0FF,{A5}+OSNDRzFIFO		; reset les FIFOS	MOVE.8	#0,{A5}+OSNDRzFIFO	CALL	INIINT	JUMP,NE	ERFAT	MOVE.32	{A6}+OMYMEM,A4	MOVE.32	#LGMYMEM,D4	CALL	INIRCVBYTES	CALL	WAITRCVBYTES	push.16	d7	CALL	STOPINT	JUMP,NE	ERFAT	pop.16	d7	JUMP,NE	ERFAT	JUMP	LOOPTEST7:	MOVE.8	#16'0FF,{A5}+OSNDRzFIFO		; reset les FIFOS	MOVE.8	#0,{A5}+OSNDRzFIFO	CALL	INIINT	JUMP,NE	ERFAT	MOVE.32	{A6}+OMYMEM,A4	MOVE.32	#LGMYMEM,D4	CALL	SENDBYTES	push.16	d7	CALL	STOPINT	JUMP,NE	ERFAT	pop.16	d7	JUMP,NE	ERFAT	JUMP	LOOP;-----------\\;  INIINT    >;===========/; initialise l'interruption; N'appeller qu'une fois; in	-; out	D7.16	erreur;	F; mod	-INIINT:	PUSHM.32 A0|A1|A2|D0|D1|D7	MOVE.8	#0,{A5}+OSNDINTMASK	; masque les interruptions	MOVE.16	#0,D4	PUSH.32	A5	NTREL	?CRESEM	MOVE.32	A5,{A6}+OSEMAINT	POP.32	A5	TEST.16	D7	JUMP,NE	RTN$	PUSH.32	A5	MOVE.32	#R16^SUPER$,A5	NTREL	?IEP15TRP	POP.32	A5	TRAP	#15	JUMP	USER$SUPER$:	MOVE.32	#R16^INTERRUPT,A1	MOVE.32	#16'64,A0	MOVE.32	_INDNTR,A2	CALL	{A2}+OIN_INITVECTOR	POPM.32	D0|A0	RETSFUSER$:RTN$:	POPM.32	A0|A1|A2|D0|D1|D7	TEST.16	D7	RET;-----------\\;  STOPINT    >;===========/; masque l'interruption; N'appeller qu'une fois; in	-; out	D7.16	erreur;	F; mod	-STOPINT:	PUSHM.32 A0|A1|A2|D0|D1|D7	MOVE.8	#0,{A5}+OSNDINTMASK	; masque l'interruption	MOVE.16	#0,D4	PUSH.32	A5	MOVE.32	{A6}+OSEMAINT,A5	NTREL	?KILLSEM	POP.32	A5	PUSH.32	A5	MOVE.32	#R16^SUPER$,A5	NTREL	?IEP15TRP	POP.32	A5	TRAP	#15	JUMP	USER$SUPER$:	MOVE.32	#0,A1	MOVE.32	#16'64,A0	MOVE.32	_INDNTR,A2	CALL	{A2}+OIN_INITVECTOR	POPM.32	D0|A0	RETSFUSER$:RTN$:	POPM.32	A0|A1|A2|D0|D1|D7	TEST.16	D7	RET;--------------\\;  SENDBYTES    >;==============/; Envoie quelques bytes; in	A4	^bytes;	D4.32	nombre de bytes; out	D7.16	si problme de transmission (ERTIMO);	F	EQ; mod	D7.16SENDBYTES:	PUSHM.32 A4|D4	CLR.16	D7	TEST.32	D4	JUMP,EQ	RTN$	MOVE.32	A4,{A6}+OWRADR	MOVE.32	D4,{A6}+OWRLG	MOVE.8	#16'0FF,{A5}+OSNDRzFIFO		; reset les FIFOS	MOVE.8	#0,{A5}+OSNDRzFIFO	TSET.8	{A5}+OSNDIntMask:#BSNDIntMOut	SR.32	#8,D4	ADD.16	#10,D4move.32 #20*50,d4	NTREL	?MODTIM	PUSH.32	A5	MOVE.32	{A6}+OSEMAINT,A5	NTREL	?WAITEV	POP.32	A5	PUSH.16	D7	NTREL	?SETTIM	POP.16	D7	TCLR.8	{A5}+OSNDIntMask:#BSNDIntMOut	MOVE.32	#0,{A6}+OWRLGRTN$:	POPM.32	A4|D4	TEST.16	D7	RET;-----------------\\;  INIRCVBYTES     >;=================/; Prpare la rception de quelques bytes; in	A4	^buffer;	D4.32	nombre de bytes; out	D7.16	?;	F	EQ; mod	D7.16INIRCVBYTES:	CLR.16	D7	TEST.32	D4	JUMP,EQ	RTN$	MOVE.32	A4,{A6}+ORDADR	MOVE.32	D4,{A6}+ORDLG	MOVE.8	#16'0FF,{A5}+OSNDRzFIFO		; reset les FIFOS	MOVE.8	#0,{A5}+OSNDRzFIFO	NOP	TSET.8	{A5}+OSNDIntMask:#BSNDIntMInRTN$:	TEST.16	D7	RET;-----------------\\;  WAITRCVBYTES    >;=================/; Attend la fin de la rception des quelques bytes; in	D4.32	nombre de bytes (pour calcul timeout; out	D7.16	si problme de transmission (ERTIMO);	F	EQ; mod	D7.16WAITRCVBYTES:	PUSHM.32 A4|D4	CLR.16	D7	TEST.32	D4	JUMP,EQ	RTN$	SR.32	#8,D4	ADD.16	#10,D4move.32 #60*50,d4	NTREL	?MODTIM	PUSH.32	A5	MOVE.32	{A6}+OSEMAINT,A5	NTREL	?WAITEV	POP.32	A5	PUSH.16	D7	NTREL	?SETTIM	POP.16	D7	TCLR.8	{A5}+OSNDIntMask:#BSNDIntMIn	MOVE.32	#0,{A6}+ORDLGRTN$:	POPM.32	A4|D4	TEST.16	D7	RETINTERRUPT:	PUSHM.32 D7|A5|A6	MOVE.32	A0,A6	MOVE.32	{A6}+OADHARD,A5	TEST.8	{A5}+OSNDIntMask:#BSNDIntMOut	JUMP,BC	LECTURE$	TEST.8	{A5}+OSNDStatus:#BSNDSTOutOk	JUMP,BC	LECTURE$; Interruption prt criture:	MOVE.32	{A6}+OWRADR,A0	MOVE.32	{A0+},{A5}+OSNDDATA	MOVE.32	A0,{A6}+OWRADR	SUB.32	#4,{A6}+OWRLG	JUMP,NE	RTN$	TCLR.8	{A5}+OSNDIntMask:#BSNDIntMOutSIGNEV$:	MOVE.32	{A6}+OSEMAINT,A1	CALL	A16^_ISIGNEV	JUMP	RTN$LECTURE$:; Interruption lecture:	TEST.8	{A5}+OSNDIntMask:#BSNDIntMIn	JUMP,BC	INTKO$	TEST.8	{A5}+OSNDStatus:#BSNDSTInOk	JUMP,BC	INTKO$	MOVE.32	{A6}+ORDADR,A0	MOVE.32	{A5}+OSNDDATA,{A0+}	MOVE.32	A0,{A6}+ORDADR	SUB.32	#4,{A6}+ORDLG	JUMP,NE	RTN$	TCLR.8	{A5}+OSNDIntMask:#BSNDIntMIn	JUMP	SIGNEV$INTKO$:;;	MON	?AFTIM;;	.ASCIZE	"Interruption SOUND sans raisons !";;	TRAP	#1;;	MOVE.8	#0,{a5}+osndintmaskRTN$:	POPM.32	D7|A5|A6	RET	.BASE	10'16TABSIN:.8	080,083,086,089,08C,08F,092,095,098,09B,09E,0A1,0A4,0A7,0AA,0AD.8	0B0,0B3,0B6,0B9,0BB,0BE,0C1,0C3,0C6,0C9,0CB,0CE,0D0,0D2,0D5,0D7.8	0D9,0DB,0DE,0E0,0E2,0E4,0E6,0E7,0E9,0EB,0EC,0EE,0F0,0F1,0F2,0F4.8	0F5,0F6,0F7,0F8,0F9,0FA,0FB,0FB,0FC,0FD,0FD,0FE,0FE,0FE,0FE,0FE.8	0FF,0FE,0FE,0FE,0FE,0FE,0FD,0FD,0FC,0FB,0FB,0FA,0F9,0F8,0F7,0F6.8	0F5,0F4,0F2,0F1,0F0,0EE,0EC,0EB,0E9,0E7,0E6,0E4,0E2,0E0,0DE,0DB.8	0D9,0D7,0D5,0D2,0D0,0CE,0CB,0C9,0C6,0C3,0C1,0BE,0BB,0B9,0B6,0B3.8	0B0,0AD,0AA,0A7,0A4,0A1,09E,09B,098,095,092,08F,08C,089,086,083.8	080,07C,079,076,073,070,06D,06A,067,064,061,05E,05B,058,055,052.8	04F,04C,049,046,044,041,03E,03C,039,036,034,031,02F,02D,02A,028.8	026,024,021,01F,01D,01B,019,018,016,014,013,011,00F,00E,00D,00B.8	00A,009,008,007,006,005,004,004,003,002,002,001,001,001,001,001.8	001,001,001,001,001,001,002,002,003,004,004,005,006,007,008,009.8	00A,00B,00D,00E,00F,011,013,014,016,018,019,01B,01D,01F,021,024.8	026,028,02A,02D,02F,031,034,036,039,03C,03E,041,044,046,049,04C.8	04F,052,055,058,05B,05E,061,064,067,06A,06D,070,073,076,079,07CTABIDATA:.8	000,080,040,0C0,020,0A0,060,0E0,010,090,050,0D0,030,0B0,070,0F0.8	008,088,048,0C8,028,0A8,068,0E8,018,098,058,0D8,038,0B8,078,0F8.8	004,084,044,0C4,024,0A4,064,0E4,014,094,054,0D4,034,0B4,074,0F4.8	00C,08C,04C,0CC,02C,0AC,06C,0EC,01C,09C,05C,0DC,03C,0BC,07C,0FC.8	002,082,042,0C2,022,0A2,062,0E2,012,092,052,0D2,032,0B2,072,0F2.8	00A,08A,04A,0CA,02A,0AA,06A,0EA,01A,09A,05A,0DA,03A,0BA,07A,0FA.8	006,086,046,0C6,026,0A6,066,0E6,016,096,056,0D6,036,0B6,076,0F6.8	00E,08E,04E,0CE,02E,0AE,06E,0EE,01E,09E,05E,0DE,03E,0BE,07E,0FE.8	001,081,041,0C1,021,0A1,061,0E1,011,091,051,0D1,031,0B1,071,0F1.8	009,089,049,0C9,029,0A9,069,0E9,019,099,059,0D9,039,0B9,079,0F9.8	005,085,045,0C5,025,0A5,065,0E5,015,095,055,0D5,035,0B5,075,0F5.8	00D,08D,04D,0CD,02D,0AD,06D,0ED,01D,09D,05D,0DD,03D,0BD,07D,0FD.8	003,083,043,0C3,023,0A3,063,0E3,013,093,053,0D3,033,0B3,073,0F3.8	00B,08B,04B,0CB,02B,0AB,06B,0EB,01B,09B,05B,0DB,03B,0BB,07B,0FB.8	007,087,047,0C7,027,0A7,067,0E7,017,097,057,0D7,037,0B7,077,0F7.8	00F,08F,04F,0CF,02F,0AF,06F,0EF,01F,09F,05F,0DF,03F,0BF,07F,0FF	.BASE	10'10	.END