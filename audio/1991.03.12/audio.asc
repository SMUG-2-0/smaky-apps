	.TITLE	AUDIO.ASC;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du programme AUDIO.CODE;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 0.3	15.11.90	signal: visualisation meilleur si x50..500; 0.2	09.11.90	commande "F+" au synth si crit "300_SYNT.AUDIO";			CURSOR-clic: reprend ancienne slection;			slection: sauve..; 0.1	02.11.90	premire version	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	COLORS	.REF	AUDIOAUDREV	=	0		; rvisionAUDVERS	=	3		; version;AUDPROV=	'a		; rvision.version provisoireAUDPROV=	SPACE		; rvision.version dfinitive	.REV	AUDREV,AUDVERS	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------MAXSON	=	200		; nb max de sons par fichierLBUDIS	=	100		; lg max de OBUDISLBUNAME	=	50		; lg max d'un nom de fichierKEYDBOX	=	H'7E00		; "touche" spcialeGCTXF	=	'N		; fonte du texte NEF11GCTXS	=	'E!2^BGCFIX	; style/chasse du texteGCTXT	=	11		; taille du texteGCICF	=	'I		; fonte des icnes IAP20GCICS	=	'A		; style/chasse des icnesGCICT	=	20		; taille des icnes; Codes des icnes de IAP20; -------------------------ICOVIDE	=	1		; demi-icne videICODETRUIT =	2		; dtruitICODEPLACE =	3		; dplaceICODUPLIQUE =	4		; dupliqueICOVOLUME =	5		; volumeICOECOUTE =	6		; couteICOSAUVE =	7		; sauveICOPRESS =	127		; presse le bouton; Oprations pour annuler; -----------------------OPUNREPL =	1		; remplaceOPUNINS	=	2		; insre; Descripteur pour une ligne ditable dans une DBOX; -------------------------------------------------	.LOC	0ODBOFF:	.BLKB	2		; offset variableODBTYP:	.BLKB	2		; type DBTYPN =  0			;  nombre entier positif DBTYPNS=  1			;  nombre entier sign (+/-) DBTYPNF=  2			;  nombre entier positif facultatif DBTYPA =  10			;  chane alphanumriqueODBMIN:	.BLKB	2		; valeur minimaleODBMAX:	.BLKB	2		; valeur maximaleODBINC:	.BLKB	2		; incrmentODBRGC:	.BLKB	2		; rang pour DBOX_GETCOODBRED:	.BLKB	2		; rang pour DBOX_MEDITODBNBC:	.BLKB	2		; nb de caractresLDB:; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOPLCOM:	.BLKB	4		; ^ligne de commandeOPDDIS:	.BLKB	4		; ^descripteur de la fentreOLINE:	.BLKB	4		; adresse de GRA_LINEOBUDIS:	.BLKB	LBUDIS		; buffer write-displayOCCMO:	.BLKB	1		; 1 => souris enleveOMACHINE:.BLKB	1		; machine utilise (SMAKY*)	.EVENOFAN:	.BLKB	4		; fanionsOVSPOS:	.BLKB	4		; visu-son: positionOVSDIM:	.BLKB	4		; visu-son: dimensionsOVSDET:	.BLKB	1		; visu-son: flags de dtectopn	.EVENOSCVAR:	.BLKB	LSCVAR		; ascenseur: variablesOSLVAR:	.BLKB	LSLVAR		; scroll-liste: variablesOSLNAM:	.BLKB	LADHNAME	; scroll-liste: nom du sonOSLNCH:	.BLKB	2		; scroll-liste: 1 => nom changOSELTD:	.BLKB	4		; slection: TdbutOSELTF:	.BLKB	4		; slection: TfinOMMPS:	.BLKB	LMM*10		; mmenu: paramtresOVODEB:	.BLKB	2		; volume: dbutOVOFIN:	.BLKB	2		; volume: finODBLIN:	.BLKB	50		; dbox: ligne en ditionODBPTE:	.BLKB	4		; dbox: ^table des objets ditablesODBPA1:	.BLKB	2		; dbox: paramtre 1ODBPA2:	.BLKB	2		; dbox: paramtre 2ODBPA3:	.BLKB	2		; dbox: paramtre 3ODBPA4:	.BLKB	2		; dbox: paramtre 4OBUNAME:.BLKB	LBUNAME		; nom du fichier .SOUNDOBUNADD:.BLKB	LBUNAME		; nom du fichier  ajouterOUNOP:	.BLKB	2		; undo: opration pour annulerOUNTD:	.BLKB	4		; undo: temps dbutOUNTF:	.BLKB	4		; undo: temps finOUNPT:	.BLKB	4		; undo: ^copieOPSON:	.BLKB	4*(MAXSON+1)	; ^sonsOBHEAD:	.BLKB	LADH		; buffer pour en-tteLGVAR:; Programme; ---------	.LOC	0	JUMP	START; Erreurs fatales; ---------------TXERFATTXT:	.ASCIZ	"Erreur avec le gencar NEF11"TXERFATICO:	.ASCIZ	"Erreur avec le gencar IAP20"; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"		.EVENSTART:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CALL	WAITMOUSE	; met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	LOAD.L	(A6)+OPDDIS,A0	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	LOAD.L	A3,#R16"TXERFATTXT	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT,0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATICO	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT,0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0	.EVEN	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OLINE,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	(A6)+OFAN,#2^3	; OFAN <-- x50 par dfaut	LOAD.W	(A6)+OVODEB,#100	LOAD.W	(A6)+OVOFIN,#100	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SKPNAM	JUMP',NE MAIN$	CALL	IOREAD		; lit le fichier .SOUNDMAIN$:	CALL	DBOXMAIN	; dbox principale ...ERFAT:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSEERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	AUDMAIN.ASI	.INS	AUDVISU.ASI	.INS	AUDIO.ASI	.INS	AUDCADRE.ASI	.INS	AUDDBOX.ASI	.INS	AUDDBOXT.ASI	.INS	AUDMISC.ASI	.END	START