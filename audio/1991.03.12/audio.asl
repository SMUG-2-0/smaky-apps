	.TITLE	AUDIO.ASL	.PROC	M68030F;------------------------------------------------; Librairie AUDIO SMAKY-300; Joue des fichier d'chantillons; P.-Y. Rochat et ESPITEC-System S.A.; Octobre 1990;-------------------------------------------------	.REF	SMAKY	.REF	AUDIO	.REF	SHIDRIV300	.REF	INDROM300	.REF	SM300HARD	.REF	BIOSDRIV	.REF	DOLIB; Historique :;-------------; 	25.10.90 : 0.0MAJREV	=	0		; rvisionMINREV	=	0		; version	.REV	MAJREV,MINREVNiveauZero =	128		; niveau moyen; Variables :;------------; Descripteur d'un canal son :oSonSemInt:	.BLK.32	1		; smaphore avertissant qu'une liste					; de buffers de son a t joueoSonPoiBu:	.BLK.32	1		; pointeur d'critureoSonEnCours:	.BLK.8	1		; marque du dbut		.EVENoSonListeA:	.BLK.32	(SonNbPage/2)+1	; liste pour un demi bufferoSonListeB:	.BLK.32	(SonNbPage/2)+1oSonBuffer:	.BLK.8	SonNbPage*SonLgPageoSonRel:	.BLK.8	NiveauZro	; pour le retour  zroLgVarAudio:	.LOC	0; En-tte du module LIB; ---------------------	.LOC	0	AUDIO_	FIRST		; code du premier appel	AUDIO_	LAST		; code du dernier appel	.8	0		; nombre d'installations	.FILL.8	(OHLREV-APC),0	.8	MAJREV,MINREV	; rvision.version	.16	0,EndAudio	; longueur	.16	(PATHLIB.AND.16'FFFF0000)/(H'10000) ; pattern de dbut	.16	PATHLIB.AND.16'FFFF	; pattern de dbut	.FILL.8	(OHLNAM-APC),0	.ASCII	"AUDIO"		; nom du module	.FILL.8	(LGHLIB-APC),0	.16	_OpenAudio	.16	_PlayAudio	.16	_CloseAudio	.16	_AudioRel	.16	_AudioMelody	.16	_AudioAccord	.16	_AudioVolume;----------\\; OpenAudio >;==========/;; Ouvre le canal son;; In	-; Out	EQ : ok;	A5.32 : canal (^variables);	NE : D7.16 = erreur; Mod	A5.32, D7.16;_OpenAudio:	PUSHM.32	D4|A1|A4|A6;  faire : exclusion ...	MOVE.16		#MTYPCP, D1	MOVE.32		#LgVarAudio, D4	GESMEM		?GetMem		; mmoire pour les variables	JUMP,NE		Exit$	MOVE.32		A4, A6		; A6.32 <-- ^variables	CLR.16		D4	NTREL		?CreSem			; cration du smaphore	JUMP,NE		EXIT$			; qui signale la fin des listes	MOVE.32		A5, {A6}+oSonSemInt	MOVE.32		#{A6}+oSonBuffer, A1	; dbut du buffer -->	MOVE.32		A1, {A6}+oSonPoiBu	; --> pointeur d'criture	MOVE.32		#{A6}+oSonBuffer, A1	; dbut du buffer	MOVE.32		#SonNbPage/2, D4	; nombre de pointeurs	MOVE.32		#{A6}+oSonListeA, A4FillA$:	MOVE.32		A1, {A4+}	ADD.32		#SonLgPage, A1	DEC.32		D4	JUMP,NE		FillA$	CLR.32		{A4}			; terminateur de liste	MOVE.32		#SonNbPage/2, D4	; nombre de pointeurs	MOVE.32		#{A6}+oSonListeB, A4FillB$:	MOVE.32		A1, {A4+}	ADD.32		#SonLgPage, A1	DEC.32		D4	JUMP,NE		FillB$	CLR.32		{A4}			; terminateur de liste	CLR.8		{A6}+oSonEnCours	; dbut	MOVE.32		#R16^IntSon, A1	CALL		{_IndShi}+_InitIntSon	MOVE.32		#R16^SendListe, A5	NTREL		?IEP15TRPExit$:	MOVE.32		A6, A5			; A5.32 <-- "canal"	POPM.32		D4|A1|A4|A6	TEST.16		D7	RET; Routine d'interruption   la fin d'une liste:IntSon:	MOVE.32		{A0}+oSonSemInt, A1	CALL		A16^_ISIGNEV	RET; Routine d'activation d'une liste, excute par TRAP #15SendListe:	MOVE.32		A4, VideoSoundFirst	POPM.32		D0|A0	RETSF;----------\\; PlayAudio >;==========/;; Lance un son.;; In	A5.32	canal (^variables);	A4.32	^chantillons 8 bits;	D4.32	nombre d'chantillons; Out	EQ : ok;	NE : D7.16 = erreur; Mod	D7.16;_PlayAudio:	PUSHM.32	D1..D4|A2..A6	MOVE.32		A5, A6			; A6.32 <-- ^variables	MOVE.32		A4, A2			; A2.32 <-- ^data	CLR.32		D2			; premier demi-buffer ?	MOVE.32		{A6}+oSonPoiBu, A3	; pointeur d'criture	MOVE.32		#{A6}+oSonBuffer+(SonLgPage*SonNbPage/2), A5 ; demi-buffer	COMP.32		A5, A3	JUMP,LO 	Demi$	ADD.32		#SonLgPage*SonNbPage/2, A5	INC.32		D2			; second buffer !Demi$:	MOVE.32		A5, D3	SUB.32		A3, D3			; D3.32 <-- reste du demi-bufferCopie$:	MOVE.8		{A2+}, {A3+}		; copie un chantillon	DEC.32		D3			; fin d'un demi buffer ?	JUMP,NE		Suiv$						; --> demi-buffer atteint !	TEST.8		{A6}+oSonEnCours	JUMP,EQ		Done$			; pas d'attente la 1re fois	CALL		WaitAudio		; attend la fin du demi buffer prcdentDone$:	MOVE.8		#1, {A6}+oSonEnCours	TEST.32		D2			; premier demi-buffer ?	JUMP,NE		Second$	MOVE.32		#{A6}+oSonListeA, A4	; on transmet le ^  la liste	INC.32		D2			; le suivant est le second	JUMP		Joue$Second$:	CLR.32		D2	MOVE.32		#{A6}+oSonBuffer, A3	; on reprend au dbut	MOVE.32		A3, {A6}+oSonPoiBu	MOVE.32		#{A6}+oSonListeB, A4	; on transmet le ^  la listeJoue$:	TRAP		#15			; MUSIQUE !	MOVE.32		#SonLgPage*SonNbPage/2, D3 ; suite...Suiv$:	DEC.32		D4			; chantillon suivant	JUMP,NE		Copie$	MOVE.32		A3, {A6}+oSonPoiBu	; pointeur pour la prochaine fois	CLR.16		D7Exit$:	POPM.32		D1..D4|A2..A6	TEST.16		D7	RET;----------\\; WaitAudio >;----------/;; Attend l'excution de la liste prcdente;; In	A6.32	canal (^variables); Out	EQ : ok;	NE : D7.16 = erreur; Mod	D7.16;WaitAudio:	PUSHM.32	A5	MOVE.32		{A6}+oSonSemInt, A5	NTREL		?WAITEV	POPM.32		A5	RET;-----------\\; CloseAudio >;===========/;; Termine le son, attend sa fin et ferme tout;; In	-; Out	EQ : ok;	NE : D7.16 = erreur; Mod	D7.16;_CloseAudio:	PUSHM.32	D1..D2|A4..A6	MOVE.32		A5, A6			; A6.32 ^variables	TEST.8		{A6}+oSonEnCours	JUMP,EQ		Done1$	CALL		WaitAudio		; termine le sonDone1$:	MOVE.32		#{A6}+oSonListeB, A4	; seconde moiti ?	MOVE.32		{A6}+oSonPoiBu, A3	; pointeur d'criture	MOVE.32		#{A6}+oSonBuffer+(SonLgPage*SonNbPage/2), A5 ; milieu	COMP.32		A5, A3	JUMP,HS 	Demi$	SUB.32		#SonLgPage*SonNbPage/2, A5	MOVE.32		#{A6}+oSonListeA, A4	; liste A, premire moiti !Demi$:	MOVE.32		A3, D3	SUB.32		A5, D3			; D3.32 <-- solde du demi-buffer	JUMP,EQ		Done2$			; Plus rien ?	DIV.16		#SonLgPage, D3		; solde en page	MOVE.32		D3, D4	SWAP.32		D3			; D3.16 reste	TEST.16		D3			; dernire tranche vide ?	JUMP,EQ		FinLi$	INC.32		D4			; il fautra envoyer la dernire !Zero$:	MOVE.8		#NiveauZero, {A3+}	INC.16		D3	COMP.16		#SonLgPage, D3	JUMP,NE		Zero$FinLi$:						; termine la liste	AND.32		#H'FFFF, D4		; nombre de tranches	MUL.32		#4, D4			; en .32	MOVE.32		A4, A5	ADD.32		D4, A5			; pointeur de la dernire tranche	CLR.32		{A5}	TRAP		#15			; envoie liste {A6}!	MOVE.8		#1, {A6}+oSonEnCoursWait$:						; plus qu' attendre ...	TEST.8		{A6}+oSonEnCours	JUMP,EQ		Done2$	CALL		WaitAudio		; termine le sonDone2$:	MOVE.32		{A6}+oSonSemInt, A5	NTREL		?KILLSEM		; dtruit le smaphore	MOVE.16		#MTYPCP, D1		; libre les variables	MOVE.32		A6, A4	GESMEM		?GIVMEM	POPM.32		D1..D2|A4..A6	RET;------------\\; AUDIO_REL   >;============/;; Replace doucement le niveau "0" (H'80);; In	A5.32	canal (^variables); Out	EQ : ok;	NE : D7.16 = erreur; Mod	D7.16;_AudioRel:	PUSHM.32	D3..D4|A4..A6	MOVE.32		A5, A6			; A6.32 ^variables	MOVE.32		{A6}+oSonPoiBu, A3	; pointeur d'criture	MOVE.32		#{A6}+oSonBuffer, A4	; dbut	COMP.32		A3, A4			; y est-on ?	JUMP,NE		Suite$	MOVE.32		#{A6}+oSonBuffer+(SonLgPage*SonNbPage), A3 ; finSuite$:	MOVE.8		{A3}-1, D3	SUB.8		#NiveauZero, {A3}-1	; dj  zro ?	JUMP,EQ		Ok$						; D3.8 contient la correction	MOVE.8		D3, D4			; D4.8 aussi	TEST.8		D4	JUMP,PL		Pos$	NEG.8		D4Pos$:	MOVE.32		#{A6}+oSonRel, A4Fill$:	TEST.8		D3	JUMP,PL		Plus$	INC.8		D3	INC.8		D3Plus$:	DEC.8		D3	MOVE.8		D3, {A4+}	JUMP,NE		Fill$	MOVE.32		#{A6}+oSonRel, A4	; dbut	CALL		_PlayAudio		; "joue" le retour  zro	JUMP,NE		Exit$Ok$:	CLR.16	D7Exit$: 	POPM.32		D3..D4|A4..A6	RET;---------------\\; AUDIO_ACCORD   >;===============/;; Joue un accord, compatible avec l'appel LIB ?ACCORD;; In	D0.16		premire note;	D1.16		seconde note;	D2.16		troisme note;	D4.16		dure en [20ms];	D4.32H		enveloppe en [20ms];	A4.32		destination; Out	D4.32		longueur; Mod	D4.32, D7.16_AudioAccord:	PUSHM.32	D0..D3|D5..D6|A4	MOVE.32		D4, D7	SWAP.32		D7	MUL.16		#35000/50, D4		; D4.16 <- longueur	PUSH.32		D4	MOVE.16		#SonNivMax/3, D5	; coefficient	MUL.16		#35000/50, D7		; D7.32 <- enveloppe	DIV.16		#SonNivMax/3, D7	MOVE.16		D7, D6	SWAP.32		D7	MOVE.16		D6, D7			; copie dans high word	TCLR.32		D6:#19	TEST.16		D0	JUMP,EQ		S1$	TSET.32		D6:#19S1$:	SWAP.32		D0			; mmorise dans le high word	MOVE.16		#1, D0			; rechargement au coup suivant	TCLR.32		D6:#20	TEST.16		D1	JUMP,EQ		S2$	TSET.32		D6:#20S2$:	SWAP.32		D1			; idem pour les 3 notes	MOVE.16		#1, D1	TCLR.32		D6:#21	TEST.16		D2	JUMP,EQ		S3$	TSET.32		D6:#21S3$:	SWAP.32		D2	MOVE.16		#1, D2	TCLR.32		D6:#16			; dpart  zro	TSET.32		D6:#17	TCLR.32		D6:#18Echant$:					; boucle des chantillons	DEC.16		D0	JUMP,NE		E1$	;AF	1	TNOT.32		D6:#16	SWAP.32		D0			; recharge le low word	MOVE.16		D0, D6	SWAP.32		D0	MOVE.16		D6, D0E1$:	DEC.16		D1	JUMP,NE		E2$	;AF	2	TNOT.32		D6:#17	SWAP.32		D1			; recharge le low word	MOVE.16		D1, D6	SWAP.32		D1	MOVE.16		D6, D1E2$:	DEC.16		D2	JUMP,NE		E3$	;AF	3	TNOT.32		D6:#18	SWAP.32		D2			; recharge le low word	MOVE.16		D2, D6	SWAP.32		D2	MOVE.16		D6, D2E3$:	DEC.16		D7	JUMP,NE		Val$	;AF	C	DEC.16		D5			; coef. diminue	SWAP.32		D7			; recharge le low word	MOVE.16		D7, D6	SWAP.32		D7	MOVE.16		D6, D7Val$:	MOVE.16		D5, D3	SR.16		D3			; 1/2 coef -> D3	NEG.16		D3	ADD.16		#SonNivMax/2, D3	; + niveau "zro"	TEST.32		D6:#19	JUMP,BC		B1$	TEST.32		D6:#16 			; calcul de la valeur	JUMP,BC		B1$	ADD.16		D5, D3B1$:	TEST.32		D6:#20	JUMP,BC		B2$	TEST.32		D6:#17	JUMP,BC		B2$	ADD.16		D5, D3B2$:	TEST.32		D6:#21	JUMP,BC		B3$	TEST.32		D6:#18	JUMP,BC		B3$	ADD.16		D5, D3B3$:	MOVE.8		D3, {A4+}		; crit l'chantillon !!	DEC.32		D4			; compteur de dure	JUMP,NE		Echant$	POP.32		D4	POPM.32		D0..D3|D5..D6|A4	RET;---------------\\; AUDIO_MELODY   >;===============/;; Joue une mlodie, compatible avec l'appel LIB ?PLAY;; In	A5.32	canal (^variables);	A4.32	^table d'accords; Out	EQ : ok;	NE : D7.16 = erreur; Mod	D7.16;_AudioMelody:	PUSHM.32	D0..D6|A4..A6	CLR.16	D7	POPM.32		D0..D6|A4..A6	RET;---------------\\; AUDIO_VOLUME   >;===============/;;; Met le niveau gnral (0-3);; In	D3.16	bits 0 et 1 : niveau gnral; Out	-; Mod	D7.16;_AudioVolume:	COMP.8		#0, D3	JUMP,NE		V1$	MOVE.8		#0, ADMODESONFORT	MOVE.8		#0, ADMODESONMOY	JUMP		Ok$V1$:	COMP.8		#1, D3	JUMP,NE		V2$	MOVE.8		#0, ADMODESONFORT	MOVE.8		#1, ADMODESONMOY	JUMP		Ok$V2$:	COMP.8		#2, D3	JUMP,NE		V3$	MOVE.8		#1, ADMODESONFORT	MOVE.8		#0, ADMODESONMOY	JUMP		Ok$V3$:	COMP.8		#3, D3	JUMP,NE		Er$	MOVE.8		#1, ADMODESONFORT	MOVE.8		#1, ADMODESONMOY	JUMP		Ok$Er$:	MOVE.16		#1, D6	JUMP		EXIT$Ok$:	CLR.16		D7Exit$:	RETEndAudio:	.END