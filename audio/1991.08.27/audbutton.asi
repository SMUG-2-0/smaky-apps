	.SBTTL	AUDBUTTON.ASI;-----------\\; BUTRELEASE >;===========/; Relche tous les boutons qui ne peuvent rester press.; in	-; out	-; mod	D7.WBUTRELEASE:	PUSHM.L	D2,A2	LOAD.L	A2,#R16"TABLE$LOOP$:	LOAD.W	D2,(A2+)	COMP.W	D2,#-1	JUMP',EQ EXIT$	CALL	BUTCLR		; relche un bouton	JUMP	LOOP$EXIT$:	POPM.L	D2,A2	RETTABLE$:	.W	BUTPLAY	.W	BUTREC	.W	BUTFILTRE	.W	BUTCOUPE	.W	BUTCOPIE	.W	BUTCOLLED	.W	BUTCOLLEF	.W	BUTCLASSEUR	.W	BUTPREND	.W	BUTAJOUTE	.W	BUTSAUVE	.W	BUTEXTRAIT	.W	BUTANNULE	.W	BUTSUPPRIME	.W	BUTEFFACE	.W	-1;--------\\; BUTMOVE >;========/; Tente de presser sur un bouton.; in	-; out	D2.W	rang bouton (0..n);	D7.W	erreur; mod	D2.L, D7.WBUTMOVE:	PUSHM.L	D1,D3,D4	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE EXIT$	CALL	BUTDET		; D2 <-- bouton press	JUMP,NE EXIT$	CALL	BUTINV		; inverse le bouton	LOAD.W	D1,D2LOOP$:	CALL	SCMO		; remet la souris	LIB	?GETKEY		; attend souris/clavier	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	BUTDET		; D2 <-- bouton press	COMP.W	D2,D1		; est-on toujours dans le mme bouton ?	JUMP,EQ LOOP$		; oui => LOOP$	CALL	BUTINV		; inverse le nouveau bouton	EX.L	D1,D2	CALL	BUTINV		; inverse l'ancien bouton	JUMP	LOOP$END$:	LOAD.W	D2,D1	CALL	BUTPOSDIM	; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	CALL	BUTTEST		; D4 <-- tat du bouton	LOAD.W	D7,#1	COMP.W	D4,#2		; bouton inactif ?	JUMP',EQ EXIT$		; oui => EXIT$	CALL	BUTLOGIC	; action sur d'autres boutons v.	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; BUTLOGIC >;=========/; Relche d'autres boutons si ncessaire.; in	D2.W	rang bouton (0..n); out	-; mod	D7.WBUTLOGIC:	PUSHM.L	D2,D4,A2	LOAD.L	A2,#R16"TABLE$LOOP$:	COMP.W	(A2),#-1	JUMP',EQ EXIT$	COMP.W	D2,(A2+)	JUMP',EQ FOUND$SKIP$:	COMP.W	(A2+),#-1	JUMP,NE SKIP$	JUMP	LOOP$FOUND$:	CALL	BUTTEST		; D4 <-- tat du bouton	TEST.W	D4	JUMP',NE CLR$	CALL	BUTSET		; represse le bouton !	JUMP'	EXIT$CLR$:	LOAD.W	D2,(A2+)	COMP.W	D2,#-1	JUMP',EQ EXIT$	CALL	BUTCLR		; relche un bouton	JUMP	CLR$EXIT$:	POPM.L	D2,D4,A2	RETTABLE$:	.W	BUTX1	.W	BUTX5,BUTX10,BUTX50,BUTX100,BUTX500,-1	.W	BUTX5	.W	BUTX1,BUTX10,BUTX50,BUTX100,BUTX500,-1	.W	BUTX10	.W	BUTX1,BUTX5,BUTX50,BUTX100,BUTX500,-1	.W	BUTX50	.W	BUTX1,BUTX5,BUTX10,BUTX100,BUTX500,-1	.W	BUTX100	.W	BUTX1,BUTX5,BUTX10,BUTX50,BUTX500,-1	.W	BUTX500	.W	BUTX1,BUTX5,BUTX10,BUTX50,BUTX100,-1	.W	BUT35KHZ	.W	BUT22KHZ,BUT17KHZ,BUT8KHZ,BUT4KHZ,-1	.W	BUT22KHZ	.W	BUT35KHZ,BUT17KHZ,BUT8KHZ,BUT4KHZ,-1	.W	BUT17KHZ	.W	BUT35KHZ,BUT22KHZ,BUT8KHZ,BUT4KHZ,-1	.W	BUT8KHZ	.W	BUT35KHZ,BUT22KHZ,BUT17KHZ,BUT4KHZ,-1	.W	BUT4KHZ	.W	BUT35KHZ,BUT22KHZ,BUT17KHZ,BUT8KHZ,-1	.W	-1;--------\\; BUTDET  >;========/; Dtecte dans quel bouton est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	rang bouton (0..n);	D7.W	erreur; mod	D2.L, D7.WBUTDET:	PUSHM.L	D0,D1,D3,D4	LOAD.W	D0,D4	LOAD.L	D1,D4	SWAP.W	D1	CLR.W	D2LOOP$:	CALL	BUTPOSDIM	; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	COMP.W	D0,D3	JUMP',LT NEXT$	ADD.W	D3,D4	COMP.W	D0,D3	JUMP',GE NEXT$	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,D3	JUMP',LT NEXT$	ADD.W	D3,D4	COMP.W	D1,D3	JUMP',GE NEXT$	CLR.W	D7	JUMP'	EXIT$NEXT$:	INC.W	D2	JUMP	LOOP$EXIT$:	POPM.L	D0,D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; BUTTEST >;========/; Donne l'tat d'un bouton.; in	D2.W	rang du bouton (0..n); out	D4.W	tat (0,1,2); mod	D4.L, D7.WBUTTEST:	PUSH.L	A4	CLR.W	D4	COMP.W	D2,#NBBUT	JUMP',HS EXIT$	LOAD.L	A4,#(A6)+OBUTTON	LOAD.B	D4,(A4)+(D2.W)	; D4 <-- tat (0,1,2)EXIT$:	POP.L	A4	RET;--------\\; BUTGREY >;========/; Grise (rend inactif) un bouton.; in	D2.W	rang du bouton (0..n); out	-; mod	D7.WBUTGREY:	PUSH.L	A4	COMP.W	D2,#NBBUT	JUMP',HS EXIT$	LOAD.L	A4,#(A6)+OBUTTON	COMP.B	(A4)+(D2.W),#2	; bouton inactif ?	JUMP',EQ EXIT$	LOAD.B	(A4)+(D2.W),#2	CALL	BUTDRAW		; dessine le boutonEXIT$:	POP.L	A4	RET;--------\\; BUTFULL >;========/; Dgrise un bouton.; in	D2.W	rang du bouton (0..n); out	-; mod	D7.WBUTFULL:	PUSH.L	A4	COMP.W	D2,#NBBUT	JUMP',HS EXIT$	LOAD.L	A4,#(A6)+OBUTTON	COMP.B	(A4)+(D2.W),#2	; bouton inactif ?	JUMP',NE EXIT$	CLR.B	(A4)+(D2.W)	CALL	BUTDRAW		; dessine le boutonEXIT$:	POP.L	A4	RET;--------\\; BUTSET  >;========/; Presse un bouton.; in	D2.W	rang du bouton (0..n); out	-; mod	D7.WBUTSET:	PUSH.L	A4	COMP.W	D2,#NBBUT	JUMP',HS EXIT$	LOAD.L	A4,#(A6)+OBUTTON	COMP.B	(A4)+(D2.W),#2	; bouton inactif ?	JUMP',EQ EXIT$	TEST.B	(A4)+(D2.W)	JUMP',NE EXIT$	INC.B	(A4)+(D2.W)	CALL	BUTDRAW		; dessine le boutonEXIT$:	POP.L	A4	RET;--------\\; BUTCLR  >;========/; Relche un bouton.; in	D2.W	rang du bouton (0..n); out	-; mod	D7.WBUTCLR:	PUSH.L	A4	COMP.W	D2,#NBBUT	JUMP',HS EXIT$	LOAD.L	A4,#(A6)+OBUTTON	COMP.B	(A4)+(D2.W),#2	; bouton inactif ?	JUMP',EQ EXIT$	TEST.B	(A4)+(D2.W)	JUMP',EQ EXIT$	CLR.B	(A4)+(D2.W)	CALL	BUTDRAW		; dessine le boutonEXIT$:	POP.L	A4	RET;--------\\; BUTINV  >;========/; Inverse un bouton.; in	D2.W	rang du bouton (0..n); out	-; mod	D7.WBUTINV:	PUSH.L	A4	COMP.W	D2,#NBBUT	JUMP',HS EXIT$	LOAD.L	A4,#(A6)+OBUTTON	COMP.B	(A4)+(D2.W),#2	; bouton inactif ?	JUMP',EQ EXIT$	TNOT.B	(A4)+(D2.W):#0	CALL	BUTDRAW		; dessine le boutonEXIT$:	POP.L	A4	RET;--------\\; BUTDRAW >;========/; Affiche un bouton press ou relch.; in	D2.W	rang du bouton (0..n); out	-; mod	D7.WBUTDRAW:	PUSHM.L	D1..D4,A4	CALL	BUTPOSDIM	; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OBUTTON	LOAD.B	D1,(A4)+(D2.W)	; D1 <-- tat du bouton (0,1,2);;?	COMP.B	D1,#2		; bouton inactif ?;;?	JUMP',EQ GREY$		; oui => GREY$	LOAD.L	A4,(A6)+OPIMD0	TEST.B	D1	JUMP',EQ DRAW$	LOAD.L	A4,(A6)+OPIMD1	COMP.B	D1,#1	JUMP',EQ DRAW$	LOAD.L	A4,(A6)+OPIMD2DRAW$:	LOAD.L	D2,D3	CALL	SHOWIMAGE	; affiche un bout d'image	JUMP'	EXIT$GREY$:	PUSHM.L	D3,D4	LIB	?COLORPUSH	LOAD.L	D3,#COLORFBUT	LIB	?COLORSR	LOAD.L	D4,#-1	CALL	DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface le bouton	LIB	?COLORPOPEXIT$:	POPM.L	D1..D4,A4	RET;----------\\; BUTPOSDIM >;----------/; Donne la position et les dimensions d'un bouton.; in	D2.W	rang du bouton (0..n); out	D3.L	coin sup/gauche (y;x); mod	D4.L	dimensions (dy;dx)BUTPOSDIM:	PUSHM.L	D2,A2	LOAD.W	D7,#1		; D7 <-- pas trouv	CLR.L	D3	CLR.L	D4	COMP.W	D2,#NBBUT	JUMP',HS EXIT$	LOAD.L	A2,#R16"TABLE$	MUL.WU	D2,#8	ADD.L	A2,D2		; A2 <-- ^x,y' dx,dy	LOAD.W	D3,#LYWDO+1	SUB.W	D3,(A2)+2	SWAP.W	D3	LOAD.W	D3,(A2)+0	LOAD.W	D4,(A2)+6	INC.W	D4	SWAP.W	D4	LOAD.W	D4,(A2)+4	INC.W	D4	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,A2	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	253,127	41,41	; PLAY	.W	301,127	41,41	; REC	.W	349,127	41,41	; FILTRE	.W	253,80	33,22	; COUPE	.W	289,80	33,22	; COPIE	.W	325,80	33,22	; COLLE <	.W	361,80	33,22	; COLLE >	.W	397,80	33,22	; CLASSEUR	.W	481,80	61,15	; PREND	.W	481,63	61,15	; AJOUTE	.W	481,46	61,15	; SAUVE	.W	481,29	61,15	; EXTRAIT	.W	551,80	73,29	; ANNULE	.W	551,46	73,15	; SUPPRIME	.W	551,29	73,15	; EFFACE	.W	408,107	16,14	; 35 KHz	.W	426,107	16,14	; 22 KHz	.W	444,107	16,14	; 17 KHz	.W	462,107	16,14	;  8 KHz	.W	480,107	16,14	;  4 KHz	.W	523,114	12,17	; x1	.W	539,114	12,17	; x5	.W	555,114	12,17	; x10	.W	571,114	12,17	; x50	.W	587,114	12,17	; x100	.W	603,114	12,17	; x500NBBUT	=	(.-TABLE$)/8;-----------\\; BUTINFOSEC >;===========/; Affiche un nombre de secondes dans les informations.; in	D1.L	temps; out	-; mod	D7.WBUTINFOSEC:	PUSHM.L	D2..D4	COMP.L	D1,(A6)+OLTIME	JUMP,EQ EXIT$	LOAD.L	(A6)+OLTIME,D1	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORFSEG	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLORCSEG	LIB	?COLORSR	; donne la couleur du dessin	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT,0	.EVEN	TEST.B	(A6)+OINV	JUMP',T INV$	LOAD.B	D3,#AFINV	LIB	?AFCARINV$:	COMP.L	D1,#-1	JUMP,EQ RIEN$	LOAD.L	D4,D1	DIV.WU	D4,#ADFREQ/1000	; D4 <-- chiffre *1000	AND.L	D4,#H'FFFF	LIB	?BINBCD	LOAD.L	D2,D4	LOAD.L	D4,#H'10000*(LYWDO-19-1)	LOAD.L	D3,D2	SWAP.W	D3	AND.B	D3,#B'1111	JUMP',NE DIZ$	LOAD.B	D3,#ICONUMV-ICONUMDIZ$:	LOAD.W	D4,#400	CALL	BUTINFOCAR	; affiche la dizaine	LOAD.L	D3,D2	RL.W	D3,#4	LOAD.W	D4,#407	CALL	BUTINFOCAR	; affiche l'unit	LOAD.L	D3,D2	RR.W	D3,#8	LOAD.W	D4,#417	CALL	BUTINFOCAR	; affiche le premire dcimale	LOAD.L	D3,D2	RR.W	D3,#4	LOAD.W	D4,#424	CALL	BUTINFOCAR	; affiche la deuxime dcimale	LOAD.L	D3,D2	LOAD.W	D4,#431	CALL	BUTINFOCAR	; affiche la troisime dcimale	JUMP'	END$RIEN$:	LOAD.L	D4,#H'10000*(LYWDO-19-1)	LOAD.W	D3,#ICONUMV-ICONUM	LOAD.W	D4,#400	CALL	BUTINFOCAR	; affiche la dizaine	LOAD.W	D4,#407	CALL	BUTINFOCAR	; affiche l'unit	LOAD.W	D4,#417	CALL	BUTINFOCAR	; affiche le premire dcimale	LOAD.W	D4,#424	CALL	BUTINFOCAR	; affiche la deuxime dcimale	LOAD.W	D4,#431	CALL	BUTINFOCAR	; affiche la troisime dcimaleEND$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0	.EVEN	LIB	?COLORPOPEXIT$:	POPM.L	D2..D4	RET;-----------\\; BUTINFOCAR >;-----------/; Affiche un digit.; in	D3.B	0..9;	D4.L	coin sup/gauche (y;x); out	-; mod	D7.WBUTINFOCAR:	PUSHM.L	D3,D4	EX.L	D3,D4	LIB	?SETCURS	LOAD.B	D3,D4	AND.B	D3,#B'1111	ADD.B	D3,#ICONUM	LIB	?AFCAR		; affiche un chiffre  7 segments	POPM.L	D3,D4	RET	.END