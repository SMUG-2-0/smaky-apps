	.TITLE	AUDIO.ASL;	--------------------------------------;		(C) 1991 - Daniel Roux;	--------------------------------------;	Source du module SMA_AUDIO.LIB;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 0.2	04.07.91	AUDIO_ERROR: nouvel appel; 0.1	21.06.91	dbut des travaux ...	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal	.REF	SMAKY	.REF	MODULES	.REF	AUDIO;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;SMAKY300	=	7;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;MAJREV	=	0MINREV	=	2	.REV	MAJREV,MINREV	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LBIGB	=	200000		; lg max du big-buffer; Variables globales; ------------------	.LOC	0OMACHINE:.BLKB	1		; type de la machine (SMAKYxxx)	.EVENOGCNT:	.BLKB	2		; nb d'ouvertures (0..n)OAUDIO:	.BLKB	1		; 1 => pilote AUDIO en fonctionOGINST:	.BLKB	1		; 1 => INSTALL fait par le module	.EVENLGVGLOB:; Variables locales; -----------------	.LOC	0OLPGLOB:.BLKB	4		; ^variables globalesOLPBIGB:.BLKB	4		; ^big-bufferLGVLOC:; En-tte du module LIB; ---------------------	.LOC	0DEBUT:	AUDIO_	FIRST		; code du premier appel	AUDIO_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	MAJREV,MINREV	; rvision.version	.W	0,END_AUDIO	; longueur	.L	PATHLIB		; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"AUDIO"		; nom du module	.FILLB	(LGHLIB-.),0	.W	_AUDIO_OPEN	.W	_AUDIO_CLOSE	.W	_AUDIO_CACHE	.W	_AUDIO_UNCACHE	.W	_AUDIO_MUSIC	.W	_AUDIO_INFO	.W	_AUDIO_PLAY	.W	_AUDIO_ERROR; Codes des appels; ----------------;------------\\; _AUDIO_OPEN >;============/; Ouvre le module AUDIO. Si le pilote #AUDIO n'existe pas (ex. SMAKY324),; l'ouverture ne rend pas d'erreur (D7=0), mais l'informe avec D4=1. Les; appels AUDIO_CACHE et AUDIO_MUSIC n'auront aucun effet. En revanche,; AUDIO_PLAY fonctionnera normalement.; in	-; out	D6.L	canal gnral;	D4.W	0 => pilote #AUDIO en fonction;		1 => pilote #AUDIO hors service (ex. SMAKY324);	D7.W	erreur; mod	D4.L, D6.L, D7.W_AUDIO_OPEN:	PUSHM.L	D1..D3,A2..A6	LOAD.L	A4,#R16"DEBUT	LOAD.L	D4,#LGVGLOB	FOS	?GETCOMMEM	; demande variables globales	JUMP,NE EXIT$	LOAD.L	A6,A4		; A6 <-- ^variables globales	TEST.B	(A6)+OMACHINE	JUMP',NE MACHINE$	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4MACHINE$:	LOAD.L	D4,#LGVLOC	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande variables locales	JUMP',NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A5,A4		; A5 <-- ^variables locales	LOAD.L	(A5)+OLPGLOB,A6	; OLGGLOB <-- ^variables globales	TEST.W	(A6)+OGCNT	; est-ce la premire ouverture ?	JUMP',NE BIG$		; non => BIG$	SET.B	(A6)+OAUDIO	; pilote AUDIO en fonction	CLR.B	(A6)+OGINST	; INSTALL dj fait	LOAD.L	A3,#R16"NLAUDIO	LOAD.L	A4,#R16"NPAUDIO	LOAD.L	A2,#R16"NIL$	CLR.W	D3	FOS	?INSTALL	; installe le pilote #AUDIO	JUMP',EQ INST$	COMP.W	D7,#ERUUSE	; dj install ?	JUMP',EQ BIG$		; oui => BIG$	CLR.B	(A6)+OAUDIO	; pilote AUDIO hors service	JUMP'	BIG$INST$:	SET.B	(A6)+OGINST	; INSTALL fait par le moduleBIG$:	TEST.B	(A6)+OAUDIO	; pilote AUDIO en fonction ?	JUMP',F INC$		; non => INC$	LOAD.L	D4,#LBIGB	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour big-buffer	JUMP',NE INC$	LOAD.L	(A5)+OLPBIGB,A4INC$:	INC.W	(A6)+OGCNT	; OGCNT <-- une ouverture de plus	CLR.W	D4		; D4 <-- pilote AUDIO en fonction	TEST.B	(A6)+OAUDIO	; pilote AUDIO en fonction ?	JUMP',T ONOFF$	INC.W	D4		; D4 <-- pilote AUDIO hors serviceONOFF$:	LOAD.L	D6,A5		; D6 <-- canal gnral	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D3,A2..A6	TEST.W	D7		; retour EQ/NE	RETNIL$:	.B	0	.EVEN;-------------\\; _AUDIO_CLOSE >;=============/; Ferme le module AUDIO.; in	D6.L	canal gnral; out	-; mod	D7.W_AUDIO_CLOSE:	PUSHM.L	D1..D4,A3..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	TEST.L	(A5)+OLPBIGB	JUMP',EQ BIG$	LOAD.L	A4,(A5)+OLPBIGB	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le big-buffer	CLR.L	(A5)+OLPBIGBBIG$:	TEST.W	(A6)+OGCNT	JUMP',EQ CNT$	DEC.W	(A6)+OGCNT	; OGCNT <-- une ouverture de moinsCNT$:	TEST.W	(A6)+OGCNT	; est-ce la dernire fermeture ?	JUMP',NE END$		; non => END$	TEST.B	(A6)+OAUDIO	; pilote AUDIO en fonction ?	JUMP',F END$		; non => END$	TEST.B	(A6)+OGINST	; INSTALL fait par le module ?	JUMP',F END$		; non => END$	LOAD.L	A3,#R16"NLAUDIO	CLR.W	D3	FOS	?DEINSTALL	; dinstalle le pilote #AUDIOEND$:	LOAD.L	A4,A5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre les variables localesEXIT$:	POPM.L	D1..D4,A3..A6	CLR.W	D7		; retour EQ	RET;-------------\\; _AUDIO_CACHE >;=============/; Cache en mmoire un fichier .AUDIO pouvant contenir plusieurs sons.; Si le pilote #AUDIO n'est pas en fonction (ex. SMAKY324), cet appel; ne fait rien et retourne D7=0 !; in	D6.L	canal gnral;	A3.L	^nom du fichier .AUDIO; out	D4.W	nb de sons contenus (1..n);	D5.L	canal du son;	D7.W	erreur; mod	D4.L, D5.L, D7.W_AUDIO_CACHE:	PUSHM.L	D1,D3,D6,A4..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	CLR.W	D4	CLR.L	D5		; D5 <-- "canal" si erreur	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OAUDIO	; pilote AUDIO en fonction ?	JUMP,F	EXIT$		; non => EXIT$	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier	JUMP,NE EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; D4 <-- longueur	PUSH.L	D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS	POP.L	D4	INC.L	D4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour le son	JUMP,NE CLOSE$	DEC.L	D4	FOS	?RDBYTE		; lit tout le fichier	JUMP,NE ERROR$	CLR.B	(A4)+(D4.L)	; met le <0> terminateur	LOAD.L	D5,A4		; D5 <-- canal du son	CLR.W	D4		; D4 <-- nb de sons contenusCNT$:	COMP.B	(A4)+OADHTYP,#ADHTYPE	JUMP',NE CLOSE$;	LOAD.L	D3,(A4)+OADHLG	; D3 <-- lg	LOAD.B	D3,(A4)+OADHLG+0	SL.L	D3,#8	LOAD.B	D3,(A4)+OADHLG+1	SL.L	D3,#8	LOAD.B	D3,(A4)+OADHLG+2	SL.L	D3,#8	LOAD.B	D3,(A4)+OADHLG+3	LOAD.L	A4,#(A4)+(D3.L)+LADH ; A4 <-- ^suivant	INC.W	D4		; D4 <-- un son de plus	JUMP	CNT$ERROR$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D7CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7EXIT$:	POPM.L	D1,D3,D6,A4..A6	TEST.W	D7		; retour EQ/NE	RET;---------------\\; _AUDIO_UNCACHE >;===============/; Dcache un fichier .AUDIO; Si le pilote #AUDIO n'est pas en fonction (ex. SMAKY324), cet appel; ne fait rien.; in	D6.L	canal gnral;	D5.L	canal du son; out	D7.W	erreur; mod	D7.W_AUDIO_UNCACHE:	PUSHM.L	D1,A4..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	TEST.L	D5	JUMP',EQ EXIT$	LOAD.L	A4,D5		; A4 <-- ^son	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le fichierEXIT$:	POPM.L	D1,A4..A6	CLR.W	D7		; retour EQ/NE	RET;-------------\\; _AUDIO_MUSIC >;=============/; Joue un son contenu dans un fichier .AUDIO cach.; Si le pilote #AUDIO n'est pas en fonction (ex. SMAKY324), cet appel; ne fait rien et retourne l'erreur D7=1 !; in	D6.L	canal gnral;	D5.L	canal du son;	D4.W	numro du son (0..n); out	D7.W	erreur; mod	D7.W_AUDIO_MUSIC:	PUSHM.L	D3,D4,D6,A3..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	TEST.L	D5	JUMP,EQ ERROR$	LOAD.L	A4,D5		; A4 <-- ^son	LOAD.W	D3,D4SRC$:	COMP.B	(A4)+OADHTYP,#ADHTYPE	JUMP,NE ERROR$	DEC.W	D3	JUMP',NS FOUND$;	LOAD.L	D4,(A4)+OADHLG	; D4 <-- lg	LOAD.B	D4,(A4)+OADHLG+0	SL.L	D4,#8	LOAD.B	D4,(A4)+OADHLG+1	SL.L	D4,#8	LOAD.B	D4,(A4)+OADHLG+2	SL.L	D4,#8	LOAD.B	D4,(A4)+OADHLG+3	LOAD.L	A4,#(A4)+(D4.L)+LADH ; A4 <-- ^suivant	JUMP	SRC$FOUND$:	LOAD.L	A3,#R16"NLAUDIO	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre #AUDIO:	JUMP',NE EXIT$;	LOAD.L	D4,(A4)+OADHLG	; D4 <-- lg	LOAD.B	D4,(A4)+OADHLG+0	SL.L	D4,#8	LOAD.B	D4,(A4)+OADHLG+1	SL.L	D4,#8	LOAD.B	D4,(A4)+OADHLG+2	SL.L	D4,#8	LOAD.B	D4,(A4)+OADHLG+3	ADD.L	D4,#LADH	FOS	?WRBYTE		; joue l'chantillon	FOS	?CLOSE		; ferme #AUDIO:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#ERADSDNE	; D7 <-- son pas trouvEXIT$:	POPM.L	D3,D4,D6,A3..A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; _AUDIO_INFO >;============/; Donne quelques informations sur un son contenu dans un fichier .AUDIO cach.; in	D6.L	canal gnral;	D5.L	canal du son;	D4.W	numro du son (0..n); out	A4.L	^en-tte du son (OADH*);	D7.W	erreur; mod	D7.W, A4.L_AUDIO_INFO:	PUSHM.L	D3,D4,A5,A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	TEST.L	D5	JUMP',EQ ERROR$	LOAD.L	A4,D5		; A4 <-- ^son	LOAD.W	D3,D4SRC$:	COMP.B	(A4)+OADHTYP,#ADHTYPE	JUMP',NE ERROR$	DEC.W	D3	JUMP',NS FOUND$;	LOAD.L	D4,(A4)+OADHLG	; D4 <-- lg	LOAD.B	D4,(A4)+OADHLG+0	SL.L	D4,#8	LOAD.B	D4,(A4)+OADHLG+1	SL.L	D4,#8	LOAD.B	D4,(A4)+OADHLG+2	SL.L	D4,#8	LOAD.B	D4,(A4)+OADHLG+3	LOAD.L	A4,#(A4)+(D4.L)+LADH ; A4 <-- ^suivant	JUMP	SRC$FOUND$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#ERADSDNE	; D7 <-- son pas trouvEXIT$:	POPM.L	D3,D4,A5,A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; _AUDIO_PLAY >;============/; Joue une musique, comme avec l'appel LIB,?PLAY.; in	D6.L	canal gnral;	A4.L	^table; out	-; mod	D7.W_AUDIO_PLAY:	PUSHM.L	D0..D4,D6,A3..A6	LOAD.L	A5,D6		; A5 <-- ^variables locales	LOAD.L	A6,(A5)+OLPGLOB	; A6 <-- ^variables globales	TEST.B	(A6)+OAUDIO	; pilote AUDIO en fonction ?	JUMP,F	LIB$		; non => LIB$	COMP.B	(A6)+OMACHINE,#SMAKY100	JUMP,EQ LIB$	TEST.L	(A5)+OLPBIGB	; big-buffer existe ?	JUMP,EQ LIB$		; non => LIB$	LOAD.L	A3,#R16"NLAUDIO	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre #AUDIO:	JUMP,NE EXIT$	LOAD.L	A3,A4LOOP$:	TEST.W	(A3)		; fin de la table ?	JUMP,EQ CLOSE$		; oui => CLOSE$	CALL	CALCNOTE	; D2 <-- note	LOAD.W	D0,D2	CALL	CALCNOTE	; D2 <-- note	LOAD.W	D1,D2	CALL	CALCNOTE	; D2 <-- note;;?CLR.L D1	; <<<<<<< PARCE QUE LES ACCORDS SONNENT FAUX !!!!!CLR.L D2;;?	CLR.W	D4	LOAD.B	D4,(A3+)	; D4 <-- enveloppe	CLR.W	D3	LOAD.B	D3,(A3+)	; D3 <-- dure	JUMP',NE PLAY$	LOAD.W	D3,D4PLAY$:	SWAP.W	D4	LOAD.W	D4,D3	LOAD.L	A4,(A5)+OLPBIGB	; A4 <-- ^big-buffer	LOAD.W	D3,#(LADH/2)-1ZERO$:	CLR.W	(A4+)		; rempli l'en-tte de zro	DECJ.W,NMO D3,ZERO$	CALL	CALCACCORD	; calcule un accord	LOAD.L	A4,#(A4)-LADH	; A4 <-- ^en-tte	LOAD.B	(A4)+OADHTYP,#ADHTYPE	LOAD.L	(A4)+OADHLG,D4	LOAD.W	(A4)+OADHFREQ,#ADFREQ	ADD.L	D4,#LADH	FOS	?WRBYTE		; joue l'chantillon	JUMP	LOOP$CLOSE$:	FOS	?CLOSE		; ferme #AUDIO:	JUMP'	EXIT$LIB$:	LIB	?PLAY		; joue  travers la librairieEXIT$:	POPM.L	D0..D4,D6,A3..A6	CLR.W	D7		; retour EQ	RET;---------\\; CALCNOTE >;=========/; Calcule une note.; in	A3.L	^note; out	A3.L	^plus loin;	D2.W	priode; mod	D2.LCALCNOTE:	PUSH.L	A2	CLR.L	D2	LOAD.W	D2,(A3+)	; D2 <-- note de la table	TCLR.L	D2:#15	JUMP',BS SB$NP$:				; NOTE/PERIODE =>	TCLR.L	D2:#14	JUMP',BS PER$	LOAD.L	A2,#R16"TABLE$	SL.W	D2,#1	LOAD.W	D2,(A2)+(D2.W)	; D2 <-- priodePER$:	DIV.WU	D2,#3	JUMP'	EXIT$SB$:				; SILENCE/BRUIT =>	CLR.W	D2		; D2 <-- silenceEXIT$:	POP.L	A2	RET; Table des priodes pour les notes de la gamme tempre :TABLE$:	.W	3822.	3608.	3405.	3214.	3034.	2864.	.W	2703.	2551.	2408.	2273.	2145.	2025.	.W	1911.	1804.	1703.	1607.	1517.	1432.	.W	1351.	1276.	1204.	1136.	1073.	1012.	.W	956.	902.	851.	804.	758.	716.	.W	676.	638.	602.	568.	536.	506.	.W	478.	451.	426.	402.	379.	358.	.W	338.	319.	301.	284.	268.	253.	.W	239.	225.	213.	201.	190.	179.	.W	169.	159.	150.	142.	134.	127.	.W	119.	113.	106.	100.	95.	89.	.W	84.	80.	75.	71.	67.	63.	.W	60.	56.	53.	50.	47.	45.	.W	42.	40.	38.	36.	34.	32.	.W	30.	28.	27.	25.	24.	22.	.W	21.	20.	19.	18.	17.	16.	.W	15.	14.	13.	13.	12.	11.	.W	11.	10.	9.	9.	8.	8.	.W	7.	7.	7.	6.	6.	6.	.W	5.	5.	5.	4.	4.	4.	.W	4.	4.	3.	3.	3.	3.	.W	3.	2.	2.	2.	2.	2.	.W	2.	2.	2.	2.	1.	1.	.W	1.	1.	1.	1.	1.	1.	.W	1.	1.	1.	1.	1.	1.	.W	1.	1.	1.	1.	1.	1.;-----------\\; CALCACCORD >;===========/; Calcule un accord, compatible avec l'appel LIB ?ACCORD; in	D0.W	premire note;	D1.W	seconde note;	D2.W	troisme note;	D4.W	dure en [20ms];	D4.LH	enveloppe en [20ms];	A4.L	^destination; out	D4.L	longueur utilise; mod	D4.L, D7.WCALCACCORD:	PUSHM.L	D0..D3,D5,D6,A4	LOAD.L	D7,D4	SWAP.W	D7		; D7 <-- enveloppe	MUL.WU	D7,#ADFREQ/50	DIV.WU	D7,#ADNIVMAX/6	LOAD.W	D6,D7	SWAP.W	D7	LOAD.W	D7,D6		; D7 <-- copie dans high word	MUL.WU	D4,#ADFREQ/50	; D4 <-- longueur	PUSH.L	D4	LOAD.W	D5,#ADNIVMAX/6	; D5 <-- coefficient	CLR.L	D6		; D6 <-- clear flags	TEST.W	D0	JUMP',NE S1$	TSET.L	D6:#19		; D6 <-- la note 0 est un silenceS1$:	SWAP.W	D0		; D0 <-- mmorise dans le high word	LOAD.W	D0,#1		; D0 <-- rechargement au coup suivant	TEST.W	D1	JUMP',NE S2$	TSET.L	D6:#20		; D6 <-- la note 1 est un silenceS2$:	SWAP.W	D1		; D1 <-- mmorise dans le high word	LOAD.W	D1,#1		; D1 <-- rechargement au coup suivant	TEST.W	D2	JUMP',NE S3$	TSET.L	D6:#21		; D6 <-- la note 2 est un silenceS3$:	SWAP.W	D2		; D2 <-- mmorise dans le high word	LOAD.W	D2,#1		; D2 <-- rechargement au coup suivantLOOP$:	DEC.W	D0	JUMP',NE E1$	TNOT.L	D6:#16	SWAP.W	D0	LOAD.W	D6,D0	SWAP.W	D0	LOAD.W	D0,D6		; D0 <-- recharge le low wordE1$:	DEC.W	D1	JUMP',NE E2$	TNOT.L	D6:#17	SWAP.W	D1	LOAD.W	D6,D1	SWAP.W	D1	LOAD.W	D1,D6		; D1 <-- recharge le low wordE2$:	DEC.W	D2	JUMP',NE E3$	TNOT.L	D6:#18	SWAP.W	D2	LOAD.W	D6,D2	SWAP.W	D2	LOAD.W	D2,D6		; D2 <-- recharge le low wordE3$:	DEC.W	D7	JUMP',NE VAL$	TEST.W	D5	JUMP',EQ VAL$	DEC.W	D5		; D5 <-- coefficient diminue	SWAP.W	D7	LOAD.W	D6,D7	SWAP.W	D7	LOAD.W	D7,D6		; D7 <-- recharge le low wordVAL$:	LOAD.W	D3,#ADNIVMAX/2	; D3 <-- niveau "zro"	TEST.L	D6:#19		; note 0 = silence ?	JUMP',BS B1$	SUB.W	D3,D5	TEST.L	D6:#16	JUMP',BC B1$	ADD.W	D3,D5	ADD.W	D3,D5B1$:	TEST.L	D6:#20		; note 1 = silence ?	JUMP',BS B2$	SUB.W	D3,D5	TEST.L	D6:#17	JUMP',BC B2$	ADD.W	D3,D5	ADD.W	D3,D5B2$:	TEST.L	D6:#21		; note 2 = silence ?	JUMP',BS B3$	SUB.W	D3,D5	TEST.L	D6:#18	JUMP',BC B3$	ADD.W	D3,D5	ADD.W	D3,D5B3$:	LOAD.B	(A4+),D3	; buffer <-- crit l'chantillon	DEC.L	D4		; D4 <-- compteur de dure	JUMP,NE	LOOP$	POP.L	D4	POPM.L	D0..D3,D5,D6,A4	RET;-------------\\; _AUDIO_ERROR >;=============/; Donne le texte d'une erreur interne  AUDIO.; in	D4.W	erreur; out	A3.L	^message d'erreur;	D7.W	erreur; mod	D7.W, A3.L_AUDIO_ERROR:	PUSH.L	D3	LOAD.W	D7,#1		; D7 <-- pas trouv	LOAD.W	D3,D4	SR.W	D3,#8	COMP.B	D3,#ERAUDIO/H'100 ; erreur interne  AUDIO ?	JUMP',NE EXIT$		; non => EXIT$				; oui =>	LOAD.L	A3,#R16"TABLE$LOOP$:	TEST.W	(A3+)		; fin de la table ?	JUMP',EQ OK$		; oui => OK$	COMP.W	D4,(A3)-2	; erreur trouve ?	JUMP',EQ OK$		; oui => OK$NEXT$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE	NEXT$	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- saute comme .EVEN	LOAD.L	A3,D3	JUMP	LOOP$OK$:	CLR.W	D7		; D7 <-- trouvEXIT$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	ERADFREQ	.ASCIZ	/Frquence inconnue !/	.EVEN	.W	ERADILCO	.ASCIZ	/Commande incorrecte !/	.EVEN	.W	ERADRDLG	.ASCIZ	/Longueur trop courte !/	.EVEN	.W	ERADRDIN	.ASCII	/L'interface DIGISON pour l'acquisition<CR>/	.ASCIZ	/des sons n'est pas connecte !/	.EVEN	.W	ERADSDNE	.ASCIZ	/Son inexistant !/	.EVEN	.W	0	.ASCIZ	/Erreur avec le logiciel AUDIO !/	.EVENNLAUDIO:.ASCIZ	"#AUDIO:"	; nom logiqueNPAUDIO:.ASCIZ	"$AUDIO:"	; nom physique	.EVENEND_AUDIO:	.END