	.TITLE	T.ASC	.PROC	M680002	.REF	SMAKY	.LOC	0START:	LIB	?OPELIB	LOAD.L	A3,#R16"NAME	LOAD.W	D3,#2^BOPWR	FOS	?OPEN	JUMP,NE ERROR	LOAD.L	A4,#R16"DATA	LOAD.L	D4,#LDATA	FOS	?WRBYTE	JUMP,NE ERROR	FOS	?CLOSE	JUMP	FINIERROR:	LIB	?AFERRORFINI:	LIB	?AFTIM	.ASCIZ	"<CR>Appuyez sur une touche ..."	.EVEN	LIB	?GETCAR	LIB	?CLOLIB	FOS	?STOPNAME:	.ASCIZ	"#TOTO"DATA:	.B	BIPACCORD	.W	NOTE+SGDO+OCTAVE*3,SILENCE,SILENCE	.B	100,50	.B	BIPACCORD	.W	NOTE+SGMI+OCTAVE*3,SILENCE,SILENCE	.B	100,50	.B	BIPACCORD	.W	NOTE+SGSOL+OCTAVE*3,SILENCE,SILENCE	.B	100,50	.B	BIPACCORD	.W	NOTE+SGDO+OCTAVE*4,NOTE+SGDO+OCTAVE*3,NOTE+SGSOL+OCTAVE*3	.B	100,50	.B	BIPACCORD	.W	NOTE+SGDO+OCTAVE*3,SILENCE,SILENCE	.B	10,10	.B	BIPACCORD	.W	NOTE+SGMI+OCTAVE*3,SILENCE,SILENCE	.B	10,10	.B	BIPACCORD	.W	NOTE+SGSOL+OCTAVE*3,SILENCE,SILENCE	.B	10,10	.B	BIPACCORD	.W	NOTE+SGDO+OCTAVE*4,NOTE+SGDO+OCTAVE*3,NOTE+SGSOL+OCTAVE*3	.B	10,10	.B	BIPLIT	.B	BIPEND	.B	BIPYES	.B	BIPBIG	.B	BIPERR	.B	BIPFAT	.B	BIPDONELDATA	=	.-DATA	.END	START