	.TITLE	SON.ASC	.PROC	M68000;------------------------------------------------; Programme de test du son sur Smaky-300; Joue des fichier d'chantillons, test du hard.; J.-F. Gruet, P.-Y. Rochat et ESPITEC-System S.A.; Septembre 1990;-------------------------------------------------	.REF	SMAKY	.REF	AUDIO	.START	Start; Historique :;-------------; PYR	15.09.90 : reprise de PLAY.ASC (pour SMUG...); 	25.10.90 : librairie (pour confrence de presse...); Conditions d'assemblage :;--------------------------AvecSmile	= 1; Macros de debug :;------------------.MACRO Af				; message et attente clavier	pushm.32	d7|d3	lib		?aftim	.ascize		" (%1) ";	lib	?getcar	popm.32		d7|d3.endmacro; Variables :;------------LgBuffer	=	5*35*1024SonDeciHz	=	10	.LOC	0oCanLib:	.BLK.16	1		; canal librairue AUDIOoAdBuffer:	.BLK.32	1		; ^ buffer des chantillonsoNbEchant:	.BLK.32	1		; nb. d'chantillons chargsoDeb:		.BLK.32	1		; longueur  sauter LgNomFichier	= 48oNomFichier:	.BLK.8	LgNomFichierLgVar:	.LOC	0	;=====================; Programme de test :;=====================START:	.IF	AvecSmile	.ELSE	LIB		?OpeLib		; ouverture librairie (pour .CODE)	.ENDIF	MOVE.16		#MTYPCP, D1	MOVE.32		#LgVar, D4	GESMEM		?GetMem		; mmoire pour les variables	JUMP,NE		FatEr	GESMEM		?ClearMem	; TOUTES les variables  zro !	MOVE.32		A4, A6	MOVE.32		#R16^NomAudio, A3	; ouverture librairie AUDIO	MOVE.16		#AUDIO_FIRST, D3	LIB_		OPEN	JUMP,NE		FatEr	MOVE.16		D1, {A6}+oCanLib	MOVE.32		#LgBuffer, D4	MOVE.16		#MTYPCP, D1	GESMEM		?GETMEM		; mmoire pour les sons	JUMP,NE		FatEr	GESMEM		?ClearMem	MOVE.32		A4, {A6}+oAdBuffer; Attente des commande (moniteur de test);-----------------------------------------AtCom:	LIB		?AFTIM	.ASCII		"<EOP><AFINV> SON 0.3 <AFDIR>  Moniteur de test du son pour Smaky 300"	.ASCII		"<CR><CR>(0) (1) (2) (3)  Rglage du volume"	.ASCII		"<CR>(S) Son 'ON'  (X) Son 'OFF' (bit BUZ)"	.ASCII		"<CR>(C) Charge le dbut d'un fichier d'chantillons"	.ASCII		"<CR>(J) Joue le fichier charg,  ([) et (]) coupe"	.ASCII		"<CR>(F) Sauve le fichier"	.ASCII		"<CR>(Y) Synthse d'un chantillon  (X) dmo"	.ASCII		"<CR>(M) Montre le dbut de l'chantillon  (N) Notes"	.ASCII		"<CR>(END) termine."	.ASCIZE		"<CR><CR>Votre choix ? "AtCar$:	LIB		?GETCAR,?MINMAJ	COMP.8		#END, D3	JUMP,EQ		Fin	COMP.8		#F0, D3	JUMP,EQ		Fin	COMP.8		#"0", D3	JUMP,EQ		Vol0	COMP.8		#"1", D3	JUMP,EQ		Vol1	COMP.8		#"2", D3	JUMP,EQ		Vol2	COMP.8		#"3", D3	JUMP,EQ		Vol3	COMP.8		#"X", D3	JUMP,EQ		Demo	COMP.8		#"C", D3	JUMP,EQ		Charge	COMP.8		#"J", D3	JUMP,EQ		Joue	COMP.8		#"F", D3	JUMP,EQ		Sauve	COMP.8		#"S", D3	JUMP,EQ		SonOn	COMP.8		#"X", D3	JUMP,EQ		SonOff	COMP.8		#"M", D3	JUMP,EQ		Montre	COMP.8		#"Y", D3	JUMP,EQ		Synth	COMP.8		#"[", D3	JUMP,EQ		Deb	COMP.8		#"]", D3	JUMP,EQ		Coupe	COMP.8		#"N", D3	JUMP,EQ		Notes;;	MOVE.16		#BIPLIT, D3;;	LIB		?BEEP	JUMP		AtCar$; Excution des commandes :;--------------------------Vol0:					; initialisation du volume 0	MOVE.16		#0, D3	AUDIO_		VOLUME	JUMP		AtComVol1:					; initialisation du volume 1	MOVE.16		#1, D3	AUDIO_		VOLUME	JUMP		AtComVol2:					; initialisation du volume 2	MOVE.16		#2, D3	AUDIO_		VOLUME	JUMP		AtComVol3:					; initialisation du volume 3	MOVE.16		#3, D3	AUDIO_		VOLUME	JUMP		AtComSonOn:;	MOVE.8		#1,AdCioPortC	; Connecte le son.	JUMP		AtComSonOff:;	MOVE.8		#0,AdCioPortC	; Connecte le son.	JUMP		AtComCharge:	LIB		?AFTIM	.ASCIZE		"<CR><CR>Nom du fichier  lire ? "	MOVE.32		{A6}+oNomFichier, A3 ; buffer pour le nom	CLR.8		{A3}		; nom vide	MOVE.32		A3, A4		; curseur au dbut	MOVE.32		#LgNomFichier, D4	LIB		?GETFILE	MOVE.32		#2**BOPRD+2**BopExtend, D3	FOS		?ARGSOPEN	JUMP,NE		Erreur	MOVE.32		#LgBuffer, D4	; longueur du buffer	MOVE.32		{A6}+oAdBuffer, A4 ; ^ buffer	FOS		?RDBYTE		; lit ce qu'on peut...	JUMP,EQ		OK$	COMP.16		#EROUTF, D7	JUMP,NE		ErreurOK$:	MOVE.32		D4, {A6}+oNbEchant	FOS		?CLOSE	CLR.32		{A6}+oDeb	; prend le dbut	JUMP		AtComSauve:	LIB		?AFTIM	.ASCIZE		"<CR><CR>Nom  donner au fichier ? "	MOVE.32		{A6}+oNomFichier, A3 ; buffer pour le nom	CLR.8		{A3}		; nom vide	MOVE.32		A3, A4		; curseur au dbut	MOVE.32		#LgNomFichier, D4	LIB		?GETFILE	MOVE.32		#DEFATT, D3	LIB		?FCREATE	MOVE.32		{A6}+oNbEchant, D4	MOVE.32		{A6}+oAdBuffer, A4	ADD.32		{a6}+oDeb, A4	FOS		?WRBYTE		; crit	FOS		?CLOSE	JUMP		AtComJoue:	MOVE.32		{A6}+oNbEchant, D4	JUMP,EQ		AtCom		; Snif, rien  jouer !	AUDIO_		OPEN	JUMP,NE		Erreur	MOVE.32		{A6}+oAdBuffer, A4	ADD.32		{A6}+oDeb, A4	; saute le dbut	MOVE.32		{A6}+oNbEchant, D4	AUDIO_		PLAY	JUMP,NE		Erreur	AUDIO_		CLOSE	JUMP,NE		Erreur	JUMP		AtComDeb:	LIB		?AFTIM	.ASCIZE		"Coupe au dbut : "	LIB		?GETDEC	MOVE.32		D4,{A6}+oDeb	JUMP		AtComCoupe:	LIB		?AFTIM	.ASCIZE		"Longueur utile : "	LIB		?GETDEC	MOVE.32		D4,{A6}+oNbEchant	JUMP		AtComMontre:	MOVE.8		#EOP, D3	LIB		?AFCAR	MOVE.32		{A6}+oAdBuffer, A4	MOVE.32		#300*H'10000, D3		; coordonne Y=300	MOVE.16		#300, D1loop$:	CLR.32		D4	MOVE.8		{A4+}, D4	SWAP.32		D3			; Y	MOVE.16		#300, D3	SUB.16		D4, D3	SWAP.32		D3	MOVE.32		#4*H'10000, D4		; petit segment vertical	MOVE.16		#SETDOT, D2	PUSH.32		D3	LIB		?DRSEG	POP.32		D3	INC.32		D3			; x:=x+1	LIB		?DRSEG	INC.32		D3			; x:=x+1	DEC.16 		D1	JUMP,NE		loop$	LIB		?GETCAR	JUMP		AtComSynth:						; Synthse d'chantillons	LIB		?AFTIM	.ASCIZE		"(A)joute ou (N)ouvel chantillon ? "AjNv$:	LIB		?GETCAR, ?MINMAJ	COMP.8		#"A", D3	JUMP,EQ		Aj$	COMP.8		#"N", D3	JUMP,NE		AjNv$	MOVE.32		{A6}+oAdBuffer, A4	MOVE.32		#LgBuffer, D4Nv$:	MOVE.8		#SonNivMax/2, {A4+}	DEC.32		D4	JUMP,NE		Nv$Aj$:	LIB		?AFTIM	.ASCIZE		"<CR>Donnez la frquence en diximes de Hertz : "	LIB		?GETDEC	MOVE.32		D4, D0			; D0.16 : frquence	LIB		?AFTIM	.ASCIZE		"Donnez le niveau  (de 0  255) : "	LIB		?GETDEC	MOVE.32	D4, D2			; D2.16 : niveau		LIB		?AFTIM	.ASCIZE		"(S)inus (C)arr (T)riangle (D)ent de scie ? "	LIB		?GETCAR, ?MINMAJ, ?AFCAR, ?AFCR	COMP.8		#"C", D3	JUMP,EQ 	c$	COMP.8		#"T", D3	JUMP,EQ 	t$	COMP.8		#"D", D3	JUMP,EQ 	d$	COMP.8		#END, D3	JUMP,EQ 	AtCom	ADD.32		#(SonMode*SonSinus), D2 ; D2.32 mode sur le high Word	JUMP	z$c$:	ADD.32		#(SonMode*SonSquare), D2	JUMP	z$t$:	ADD.32		#(SonMode*SonTriangle), D2	JUMP	z$d$:	ADD.32		#(SonMode*SonDentScie), D2z$:	MOVE.32		{A6}+oAdBuffer, A4	; A4.32 ^buffer	MOVE.32		#LgBuffer, D4		; D4.32 longueur	MOVE.32		D4, {A6}+oNbEchant	MOVE.32		D0, D3			; D3.32 frquence	CALL		CreSound		; cre le son	JUMP		AtCom; Dmonstration :;----------------Demo:	LIB		?AFTIM	.ASCIZE		"<CR>Quel son de dmonstration (DEMO0x.SND) ? "	LIB		?GETCAR	COMP.16		#"0", D3	JUMP,EQ		X0	COMP.16		#"1", D3	JUMP,EQ		X1	COMP.16		#"2", D3	JUMP,EQ		X2	COMP.16		#"3", D3	JUMP,EQ		X3	COMP.16		#"4", D3	JUMP,EQ		X4	COMP.16		#"5", D3	JUMP,EQ		X5	COMP.16		#"6", D3	JUMP,EQ		X6	COMP.16		#"7", D3	JUMP,EQ		X7	COMP.16		#"8", D3	JUMP,EQ		X8	COMP.16		#"9", D3	JUMP,EQ		X9	JUMP		AtComT0:	.ASCIZE		"DEMO00.SND"X0:	MOVE.32		#R16^T0, A3	JUMP		X99T1:	.ASCIZE		"DEMO01.SND"X1:	MOVE.32		#R16^T1, A3	JUMP		X99T2:	.ASCIZE		"DEMO02.SND"X2:	MOVE.32		#R16^T2, A3	JUMP		X99T3:	.ASCIZE		"DEMO03.SND"X3:	MOVE.32		#R16^T3, A3	JUMP		X99T4:	.ASCIZE		"DEMO04.SND"X4:	MOVE.32		#R16^T4, A3	JUMP		X99T5:	.ASCIZE		"DEMO05.SND"X5:	MOVE.32		#R16^T5, A3	JUMP		X99T6:	.ASCIZE		"DEMO06.SND"X6:	MOVE.32		#R16^T6, A3	JUMP		X99T7:	.ASCIZE		"DEMO07.SND"X7:	MOVE.32		#R16^T7, A3	JUMP		X99T8:	.ASCIZE		"DEMO08.SND"X8:	MOVE.32		#R16^T8, A3	JUMP		X99T9:	.ASCIZE		"DEMO09.SND"X9:	MOVE.32		#R16^T9, A3X99:	MOVE.32		#2**BOPRD+2**BopExtend, D3	FOS		?ARGSOPEN	JUMP,NE		Erreur	MOVE.32		#LgBuffer, D4	; longueur du buffer	MOVE.32		{A6}+oAdBuffer, A4 ; ^ buffer	FOS		?RDBYTE		; lit ce qu'on peut...	JUMP,EQ		OK$	COMP.16		#EROUTF, D7	JUMP,NE		ErreurOK$:	MOVE.32		D4, {A6}+oNbEchant	FOS		?CLOSE	CLR.32		{A6}+oDeb	; prend le dbut	MOVE.32		{A6}+oNbEchant, D4	JUMP,EQ		AtCom		; Snif, rien  jouer !	AUDIO_		OPEN	JUMP,NE		Erreur	MOVE.32		{A6}+oAdBuffer, A4	ADD.32		{A6}+oDeb, A4	; saute le dbut	MOVE.32		{A6}+oNbEchant, D4	AUDIO_		PLAY	JUMP,NE		Erreur	AUDIO_		CLOSE	JUMP,NE		Erreur	JUMP		Demo; Sortie du programme;---------------------Fin:	MOVE.32		#MTYPCP, D1	MOVE.32		{A6}+oAdBuffer, A4	GESMEM		?GIVMEMFatEr:	MOVE.32		A6, A4	GESMEM		?GIVMEMSort:	.IF	AvecSmile	EXIT	.ELSE	LIB		?CLOLIB	FOS		?STOP	.ENDIF	; Reprise des erreurs :;----------------------Erreur:					; Erreur dans le programme	PUSH.16		D7	LIB		?AFTIM	.ASCIZE		"<CR>Erreur : "	POP.16		D7	LIB		?AFERROR	LIB		?AFTIM	.ASCIZE		"<CR> Pressez sur une touche... "	LIB		 ?GETCAR	JUMP		AtCom; Cration de notes (TESTS)Notes:		MOVE.16		#40, D0	MOVE.16		#0, D1	MOVE.16		#20, D2	MOVE.32		#5,D4			; D4.16 : dure	MOVE.32		#10, D7			; enveloppe; In	D0.16		premire note;	D1.16		seconde note;	D2.16		troisme note;	D4.16		dure en [20ms];	D7.16		enveloppe en [20ms]; Out	-; Mod	Accord:	MUL.16		#35000/50, D4		; D4.16 <- longueurMOVE.32		D4, {A6}+oNbEchant	MOVE.16		#SonNivMax/3, D5	; coefficient	MUL.16		#35000/50, D7		; D7.32 <- enveloppe	DIV.16		#SonNivMax/3, D7	MOVE.16		D7, D6	SWAP.32		D7	MOVE.16		D6, D7			; copie dans high word	TCLR.32		D6:#19	TEST.16		D0	JUMP,EQ		S1$	TSET.32		D6:#19S1$:	SWAP.32		D0			; mmorise dans le high word	MOVE.16		#1, D0			; rechargement au coup suivant	TCLR.32		D6:#20	TEST.16		D1	JUMP,EQ		S2$	TSET.32		D6:#20S2$:	SWAP.32		D1			; idem pour les 3 notes	MOVE.16		#1, D1	TCLR.32		D6:#21	TEST.16		D2	JUMP,EQ		S3$	TSET.32		D6:#21S3$:	SWAP.32		D2	MOVE.16		#1, D2	TCLR.32		D6:#16			; dpart  zro	TSET.32		D6:#17	TCLR.32		D6:#18Echant$:					; boucle des chantillons	DEC.16		D0	JUMP,NE		E1$	;AF	1	TNOT.32		D6:#16	SWAP.32		D0			; recharge le low word	MOVE.16		D0, D6	SWAP.32		D0	MOVE.16		D6, D0E1$:	DEC.16		D1	JUMP,NE		E2$	;AF	2	TNOT.32		D6:#17	SWAP.32		D1			; recharge le low word	MOVE.16		D1, D6	SWAP.32		D1	MOVE.16		D6, D1E2$:	DEC.16		D2	JUMP,NE		E3$	;AF	3	TNOT.32		D6:#18	SWAP.32		D2			; recharge le low word	MOVE.16		D2, D6	SWAP.32		D2	MOVE.16		D6, D2E3$:	DEC.16		D7	JUMP,NE		Val$	;AF	C	DEC.16		D5			; coef. diminue	SWAP.32		D7			; recharge le low word	MOVE.16		D7, D6	SWAP.32		D7	MOVE.16		D6, D7Val$:	MOVE.16		D5, D3	SR.16		D3			; 1/2 coef -> D3	NEG.16		D3	ADD.16		#SonNivMax/2, D3	; + niveau "zro"	TEST.32		D6:#19	JUMP,BC		B1$	TEST.32		D6:#16 			; calcul de la valeur	JUMP,BC		B1$	ADD.16		D5, D3B1$:	TEST.32		D6:#20	JUMP,BC		B2$	TEST.32		D6:#17	JUMP,BC		B2$	ADD.16		D5, D3B2$:	TEST.32		D6:#21	JUMP,BC		B3$	TEST.32		D6:#18	JUMP,BC		B3$	ADD.16		D5, D3B3$:	MOVE.8		D3, {A4+}		; crit l'chantillon !!	DEC.32		D4			; compteur de dure	JUMP,NE		Echant$	;JUMP	ATCOM	JUMP		Joue;=================; Synthse de son;=================;---------\\; CreSound >;=========/; Cration d'un son; S'ajoute au contenu du buffer (Faire ClearMem pour un nouveau son);; In	D3.16	frquence (en diximes de Hertz);	A4.32	^destination;	D4.32	nombre d'chantilllon ( dure = nb. de lignes cran !! );	D2.32	high word : mode  (SonSinus, SonSquare, SonTriange);		low word : niveau (0-255); Out	-; Mod	-;CreSound:	PUSHM.32	D0|D1|D4|D5|A4	AND.32		#H'FFFF, D3	; D3.32 <-- frq. dur 32 bits	CLR.32		D1		; D1.32 varie de 0  SonFreqEchant-1Fill$:	CALL		Echantillon	 ; D0.16 : l'chantillon	SUB.16		#SonNivMax/2, D0 ; en +/-	MUL.16		D2, D0		 ; * le niveau	SR.32		#8, D0		 ; sur 8 bits	ADD.32		#SonNivMax/2, D0 ; offset	AND.32		#H'FF, D0	 ; seulement 8 bits	CLR.16		D5	MOVE.8		{A4}, D5	; D5.16 ancienne valeur	ADD.16		D5, D0		; totalise	SUB.16		#SonNivMax/2, D0 ; tient compte de l'offset	JUMP,MI 	Nul$		; dpassement ngatif	COMP.16		#SonNivMax, D0	; dpassement positif	JUMP,LO		Val$	MOVE.16		#SonNivMax-1, D0	JUMP		Val$Nul$:	CLR.16		D0	JUMP		VAL$Val$:	MOVE.8		D0, {A4+}	; charge l'chantillon	ADD.32		D3, D1		; position suivante dans la priode	COMP.32		#SonFreqEchant*SonDeciHz, D1	JUMP,LO		EnCours$	SUB.32		#SonFreqEchant*SonDeciHz, D1 ; priodicit !EnCours$:	DEC.32		D4		; chantillon suivant	JUMP,NE	Fill$	POPM.32		D0|D1|D4|D5|A4	RET;------------\\; Echantillon >;------------/; Calcul d'un chantillon; In	D1.32 position dans la priode (entre 0 et SonFreqEchant-1);	D2.32 type et niveau du son; Out	D0.8 valeur; Mod	D0.8;Echantillon:	PUSHM.32	D2|D3	SWAP.32		D2			; type de son dans D2.16	COMP.16		#SonSinus, D2	JUMP,EQ 	Sinus$	COMP.16		#SonSquare, D2	JUMP,EQ 	Carre$	COMP.16		#SonTriangle, D2	JUMP,EQ 	Triangle$Dent$:	MOVE.32		D1, D0	DIV.16		#(SonFreqEchant*SonDeciHz/SonNivMax), D0	JUMP		Exit$Sinus$:	COMP.32		#(SonFreqEchant*SonDeciHz/4), D1	; permier quadrant	JUMP,LO		SinQ1$	COMP.32		#(SonFreqEchant*SonDeciHz/2), D1	; 2eme quadrant	JUMP,LO		SinQ2$	COMP.32		#(3*SonFreqEchant*SonDeciHz/4), D1 ; 3eme quadrant	JUMP,LO		SinQ3$SinQ4$:	MOVE.32		#SonFreqEchant*SonDeciHz, D3	MOVE.32		D1, D0	SUB.32		D0, D3	DIV.16		#SonDeciHz/2, D3		; la table est 5 fois moins prcise	CALL		Sinus	SR.32		#1, D3			; demi-valeur	MOVE.32		#SonNivMax/2, D0	SUB.32		D3, D0	JUMP	Exit$SinQ3$:	MOVE.32		D1, D3	SUB.32		#SonFreqEchant*SonDeciHz/2, D3	DIV.16		#SonDeciHz/2, D3		; la table est 5 fois moins prcise	CALL		Sinus	SR.32		#1, D3			; demi-valeur	MOVE.32		#SonNivMax/2, D0	SUB.32		D3, D0	JUMP		Exit$SinQ2$:	MOVE.32		#SonFreqEchant*SonDeciHz/2, D3	MOVE.32		D1, D0	SUB.32		D0, D3	DIV.16		#SonDeciHz/2, D3		; la table est 5 fois moins prcise	CALL		Sinus	MOVE.32		D3, D0	SR.32		#1, D0			; demi-valeur	ADD.32		#SonNivMax/2, D0	JUMP	Exit$SinQ1$:	MOVE.32		D1, D3	DIV.16		#SonDeciHz/2, D3		; la table est 5 fois moins prcise	CALL		Sinus	MOVE.32		D3, D0	SR.32		#1, D0			; demi-valeur	ADD.32		#SonNivMax/2, D0	JUMP		Exit$Carre$:	MOVE.32		#SonNivMax, D0		; tout ...	COMP.32		#SonFreqEchant*SonDeciHz/2, D1	JUMP,LO		Exit$	CLR.32		D0			; ... ou rien !	JUMP		Exit$Triangle$:	MOVE.32		D1, D0	DIV.16		#(SonFreqEchant*SonDeciHz/SonNivMax),D0						; d'abord une dent de scie	SL.32		#1, D0			; encore plus raide !	ADD.32		#(SonNivMax/2), D0	; origine au milieu	COMP.32		#(SonFreqEchant*SonDeciHz/4), D1	; premier quadrant ?	JUMP,LO		Exit$			; oui -> ok !	COMP.32		#((3*SonFreqEchant*SonDeciHz)/4), D1 ; dernier quadrant ?	JUMP,LO		TrMilieu$		; non -> milieu	SUB.32		#2*SonNivMax, D0	; dernire remonte	JUMP		Exit$TrMilieu$:	MOVE.32		#2*SonNivMax, D2	; D2 est libre	SUB.32		D0, D2			; redescente	MOVE.32		D2, D0	JUMP		Exit$	Exit$:	POPM.32		D2|D3	RET;------\\; Sinus >;------/; Calcul du Sinus, par bissection d'une table d'ArcSinus;; In	D3.16 : valeur de 0  8750; Out	D3.16 : sinus (de 0  255); Mod	D3.W;Sinus:	PUSHM.32	D0..D1|A0	MOVE.32		#128*2, D0	MOVE.32		#R16^TableArcSinus, A0	CLR.32		D1		; futur rsultatBiSec$:					; boucle de "bissection"	COMP.16		{A0}+{D0}, D3	JUMP,LO		Bas$	ADD.32		D0, A0		; partie "suprieure"	ADD.32		D0, D1		; affinage du rsultatBas$:	SR.32		D0		; plus fin !	COMP.32		#1, D0	JUMP,NE		BiSec$	SR.32		D1		; rsultat 0-255	MOVE.32		D1, D3		; D3.16 ; <- le rsultat	POPM.32		D0..D1|A0	RET; Table des ArcSin du premier cadran (pour 35000/2 chantillons);-----------------------------------TableArcSinus:	.16	44, 87, 131, 174, 218, 261, 305, 348, 392, 435	.16	479, 522, 566, 610, 653, 697, 740, 784, 828, 871	.16	915, 959, 1002, 1046, 1090, 1133, 1177, 1221, 1265, 1309	.16	1352, 1396, 1440, 1484, 1528, 1572, 1616, 1660, 1704, 1748	.16	1792, 1836, 1880, 1924, 1969, 2013, 2057, 2101, 2146, 2190	.16	2234, 2279, 2323, 2368, 2412, 2457, 2502, 2546, 2591, 2636	.16	2680, 2725, 2770, 2815, 2860, 2905, 2950, 2995, 3040, 3086	.16	3131, 3176, 3222, 3267, 3313, 3358, 3404, 3449, 3495, 3541	.16	3587, 3633, 3679, 3725, 3771, 3817, 3863, 3909, 3956, 4002	.16	4049, 4095, 4142, 4189, 4236, 4283, 4329, 4377, 4424, 4471	.16	4518, 4566, 4613, 4661, 4708, 4756, 4804, 4852, 4900, 4948	.16	4996, 5045, 5093, 5142, 5190, 5239, 5288, 5337, 5386, 5435	.16	5485, 5534, 5584, 5633, 5683, 5733, 5783, 5833, 5884, 5934	.16	5985, 6035, 6086, 6137, 6188, 6240, 6291, 6343, 6394, 6446	.16	6498, 6551, 6603, 6656, 6708, 6761, 6814, 6868, 6921, 6975	.16	7028, 7082, 7137, 7191, 7246, 7300, 7355, 7410, 7466, 7522	.16	7577, 7633, 7690, 7746, 7803, 7860, 7917, 7975, 8033, 8091	.16	8149, 8208, 8267, 8326, 8385, 8445, 8505, 8566, 8626, 8687	.16	8749, 8811, 8873, 8935, 8998, 9061, 9124, 9188, 9253, 9317	.16	9383, 9448, 9514, 9581, 9648, 9715, 9783, 9851, 9920, 9990	.16	10060, 10130, 10201, 10273, 10345, 10418, 10492, 10566, 10641, 10717	.16	10793, 10871, 10949, 11028, 11107, 11188, 11270, 11352, 11436, 11520	.16	11606, 11693, 11781, 11870, 11960, 12052, 12146, 12241, 12337, 12435	.16	12535, 12637, 12741, 12848, 12956, 13067, 13181, 13297, 13417, 13540	.16	13667, 13799, 13934, 14075, 14222, 14376, 14537, 14707, 14889, 15083	.16	15294, 15528, 15793, 16106, 16515, 17500NomAudio:	.ASCIZE	"AUDIO"	.END