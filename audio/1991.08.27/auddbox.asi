	.SBTTL	AUDDBOX.ASI;-----------\\; DBOXEDITIF >;===========/; Edite un nom de fichier en entre (prend).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITIF:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOB	LOAD.L	A4,#R16"TFEXT	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1!2^BDBIOFULL	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEDITAF >;===========/; Edite un nom de fichier en entre (ajoute).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITAF:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO1	LOAD.L	A4,#R16"TFEXT	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1!2^BDBIOFULL	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEDITOF >;===========/; Edite un nom de fichier en sortie (sauve).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F0/F1/F4);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITOF:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOB	LOAD.L	A4,#R16"TFEXT	LOAD.W	D1,#DBOX_EXTRAIT ; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEDITEF >;===========/; Edite un nom de fichier en sortie (extrait).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITEF:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO1	LOAD.L	A4,#R16"TFEXT	LOAD.W	D1,#DBOX_EXTRAIT ; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXDETRUIT >;============/; Demande s'il faut dtruire.; in	A3.L	^nom; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDETRUIT:	PUSHM.L	D1,D2,D4,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3	LOAD.L	A4,#R16"TFEXT	LOAD.L	A3,#R16"TDBOX_IOB	CLR.L	D3	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_DETRUIT	DBOX_	EXTEND	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande si l'on veut quitter DESSIN.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXQUITTE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IOB	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer le dessin.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXEFFACE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	LOAD.L	A5,#(A6)+OBUNAME ; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOB	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXBLOC >;=========/; Accs au classeur.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXBLOC:	PUSHM.L	D2	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN1	BLOC_	VISU		; accs au classeur ...	CALL	DBOXCLOSE1	; refait les soft-keysEXIT$:	POPM.L	D2	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXCOLOR >;==========/; Choix des couleurs.; in	-; out	D7.W	erreur; mod	D7.WDBOXCOLOR:	PUSHM.L	D3..D5,A3..A5	CALL	DBOXOPEN1	LOAD.L	A3,#R16"NMLOG	LOAD.L	A5,#R16"TCOUL	LOAD.L	D5,(A6)+OIDCRET	LOAD.L	D4,#2^BICMPAL	; D4 <-- mode local	ICOL_	MODCRET		; modifie la CRET ...	PUSH.W	D7	CALL	DBOXCLOSE1	; refait les soft-keys	POP.W	D7	JUMP',NE EXIT$	LOAD.L	(A6)+OIDCRET,D5	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3..D5,A3..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXAMORCE >;===========/; Choix de la longueur de l'amorce.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXAMORCE:	PUSHM.L	A1,A2,A5	LOAD.L	(A6)+ODBPA1,(A6)+OAMLG	LOAD.W	(A6)+OSLVAR2+OSLCYS,(A6)+OAMCYS	LOAD.L	A1,#R16"TDBOX_AMORCE	LOAD.L	A2,#R16"TPARA_AMORCE	LOAD.L	A5,#R16"TSLST_AMORCE	CALL	DBOXPASL	; choix ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	LOAD.L	(A6)+OAMLG,(A6)+ODBPA1	LOAD.W	(A6)+OAMCYS,(A6)+OSLVAR2+OSLCYSEXIT$:	POPM.L	A1,A2,A5	TEST.W	D7		; retour EQ/NE	RETTSLST_AMORCE:	.ASCIZE	"0.01s"	.W	10*ADFREQ/1000	.ASCIZE	"0.05s"	.W	50*ADFREQ/1000	.ASCIZE	"0.1s"	.W	100*ADFREQ/1000	.ASCIZE	"0.5s"	.W	500*ADFREQ/1000	.ASCIZE	"1s"	.W	1000*ADFREQ/1000	.B	0	.EVEN	.W	1TPARA_AMORCE:	.W	ODBPA1,DBTYPS,0,ADFREQ*1,ADFREQ/10,2^BDBGCLABEL!100,0,6+2	.W	-1TDBOX_AMORCE:	.W	10$-TDBOX_AMORCE	.W	20$-TDBOX_AMORCE	.W	0,010$:	.B	ODBLABEL,50	.B	ODBTEXT,0	.B	ODBTABX,10+4	.B	ODBTEXT	.ASCIZ	"Ajoute un silence."	.B	ODBCR,ODBCR,ODBCR2	.B	ODBTABX,10+4	.B	ODBTEXT	.ASCIZ	"Dure du silence : "	.B	ODBLABEL,100	.B	ODBCLINE,(6+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  [s] "	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBTABX,10	.B	ODBLABEL,51	.B	ODBTEXT,0	.B	ODBTABX,10+4	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" SILENCE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Silence"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_AMORCE:	.W	F1,F2,F3,0		DOKF1-TKEY_AMORCE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_AMORCE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_AMORCE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_AMORCE	.W	0;--------\\; DBOXVOL >;========/; Choix du volume.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXVOL:	PUSHM.L	A1,A2,A5	LOAD.W	(A6)+ODBPA1,(A6)+OVODEB	LOAD.W	(A6)+ODBPA2,(A6)+OVOFIN	LOAD.W	(A6)+OSLVAR2+OSLCYS,(A6)+OVOCYS	LOAD.L	A1,#R16"TDBOX_VOL	LOAD.L	A2,#R16"TPARA_VOL	LOAD.L	A5,#R16"TSLST_VOL	CALL	DBOXPASL	; choix ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	LOAD.W	(A6)+OVODEB,(A6)+ODBPA1	LOAD.W	(A6)+OVOFIN,(A6)+ODBPA2	LOAD.W	(A6)+OVOCYS,(A6)+OSLVAR2+OSLCYSEXIT$:	POPM.L	A1,A2,A5	TEST.W	D7		; retour EQ/NE	RETTSLST_VOL:	.ASCIZE	"<1>Rien"	.W	100,100	.ASCIZE	"Diminue 1"	.W	90,90	.ASCIZE	"Diminue 2"	.W	75,75	.ASCIZE	"<1>Diminue 3"	.W	50,50	.ASCIZE	"Augmente 1"	.W	120,120	.ASCIZE	"Augmente 2"	.W	150,150	.ASCIZE	"<1>Augmente 3"	.W	200,200	.ASCIZE	"Attaque 1"	.W	120,100	.ASCIZE	"Attaque 2"	.W	150,100	.ASCIZE	"<1>Attaque 3"	.W	200,100	.ASCIZE	"Sustain 1"	.W	100,75	.ASCIZE	"Sustain 2"	.W	100,50	.ASCIZE	"Sustain 3"	.W	100,0	.B	0	.EVEN	.W	2TPARA_VOL:	.W	ODBPA1,DBTYPN,0,200,10,2^BDBGCLABEL!100,0,3+2	.W	ODBPA2,DBTYPN,0,200,10,2^BDBGCLABEL!101,1,3+2	.W	-1TDBOX_VOL:	.W	10$-TDBOX_VOL	.W	20$-TDBOX_VOL	.W	0,010$:	.B	ODBLABEL,50	.B	ODBTEXT,0	.B	ODBTABX,20+4	.B	ODBTEXT	.ASCIZ	"Modification de l'amplitude."	.B	ODBCR,ODBCR,ODBCR2	.B	ODBTABX,20+4	.B	ODBTEXT	.ASCIZ	"Amplitude au dbut : "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  % "	.B	ODBCR,ODBCR	.B	ODBTABX,20+4	.B	ODBTEXT	.ASCIZ	"Amplitude  la fin : "	.B	ODBLABEL,101	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  % "	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBTABX,20	.B	ODBLABEL,51	.B	ODBTEXT,0	.B	ODBTABX,20+4	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" VOLUME "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Volume"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_VOL:	.W	F1,F2,F3,0		DOKF1-TKEY_VOL	.W	F0,F13,F14,F15,0	DOKF0-TKEY_VOL	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_VOL	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_VOL	.W	0;----------\\; DBOXBRUIT >;==========/; Choix du bruit.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXBRUIT:	PUSHM.L	A1,A2,A5	LOAD.W	(A6)+ODBPA1,(A6)+OBRLEV	LOAD.L	(A6)+ODBPA2,(A6)+OBRPER	LOAD.W	(A6)+OSLVAR2+OSLCYS,(A6)+OBRCYS	LOAD.L	A1,#R16"TDBOX_BRUIT	LOAD.L	A2,#R16"TPARA_BRUIT	LOAD.L	A5,#R16"TSLST_BRUIT	CALL	DBOXPASL	; choix ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	LOAD.W	(A6)+OBRLEV,(A6)+ODBPA1	LOAD.L	(A6)+OBRPER,(A6)+ODBPA2	LOAD.W	(A6)+OBRCYS,(A6)+OSLVAR2+OSLCYSEXIT$:	POPM.L	A1,A2,A5	TEST.W	D7		; retour EQ/NE	RETTSLST_BRUIT:	.ASCIZE	"Trs-faible"	.W	5,ADFREQ/100	.ASCIZE	"Faible"	.W	10,ADFREQ/100	.ASCIZE	"Moyen"	.W	20,ADFREQ/100	.ASCIZE	"Fort"	.W	30,ADFREQ/100	.ASCIZE	"Trs fort"	.W	40,ADFREQ/100	.B	0	.EVEN	.W	2TPARA_BRUIT:	.W	ODBPA1,DBTYPN,0,127,1,2^BDBGCLABEL!100,0,3+2	.W	ODBPA2,DBTYPS,0,ADFREQ/10,ADFREQ/1000,2^BDBGCLABEL!101,1,6+2	.W	-1TDBOX_BRUIT:	.W	10$-TDBOX_BRUIT	.W	20$-TDBOX_BRUIT	.W	0,010$:	.B	ODBLABEL,50	.B	ODBTEXT,0	.B	ODBTABX,20+4	.B	ODBTEXT	.ASCIZ	"Filtre les bruits trop faibles."	.B	ODBCR,ODBCR,ODBCR2	.B	ODBTABX,20+4	.B	ODBTEXT	.ASCIZ	"Seuil du bruit : "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBCR,ODBCR	.B	ODBTABX,20+4	.B	ODBTEXT	.ASCIZ	"Priode :     "	.B	ODBLABEL,101	.B	ODBCLINE,(6+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  [s] "	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBTABX,20	.B	ODBLABEL,51	.B	ODBTEXT,0	.B	ODBTABX,20+4	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" FILTRE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Filtre"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVEN;---------\\; DBOXECHO >;=========/; Choix de l'cho.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXECHO:	PUSHM.L	A1,A2,A5	LOAD.W	(A6)+ODBPA1,(A6)+OECRAT	LOAD.L	(A6)+ODBPA2,(A6)+OECPER	LOAD.W	(A6)+OSLVAR2+OSLCYS,(A6)+OECCYS	LOAD.L	A1,#R16"TDBOX_ECHO	LOAD.L	A2,#R16"TPARA_ECHO	LOAD.L	A5,#R16"TSLST_ECHO	CALL	DBOXPASL	; choix ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	LOAD.W	(A6)+OECRAT,(A6)+ODBPA1	LOAD.L	(A6)+OECPER,(A6)+ODBPA2	LOAD.W	(A6)+OECCYS,(A6)+OSLVAR2+OSLCYSEXIT$:	POPM.L	A1,A2,A5	TEST.W	D7		; retour EQ/NE	RETTSLST_ECHO:	.ASCIZE	"Tunnel 1"	.W	80,2*ADFREQ/1000	.ASCIZE	"Tunnel 2"	.W	80,4*ADFREQ/1000	.ASCIZE	"Tunnel 3"	.W	80,10*ADFREQ/1000	.ASCIZE	"<1>Tunnel 4"	.W	90,10*ADFREQ/1000	.ASCIZE	"Rverbration 1"	.W	50,20*ADFREQ/1000	.ASCIZE	"Rverbration 2"	.W	50,30*ADFREQ/1000	.ASCIZE	"Rverbration 3"	.W	55,35*ADFREQ/1000	.ASCIZE	"<1>Rverbration 4"	.W	60,40*ADFREQ/1000	.ASCIZE	"Cathdrale 1"	.W	50,100*ADFREQ/1000	.ASCIZE	"Cathdrale 2"	.W	55,120*ADFREQ/1000	.ASCIZE	"Cathdrale 3"	.W	60,140*ADFREQ/1000	.ASCIZE	"<1>Cathdrale 4"	.W	65,160*ADFREQ/1000	.ASCIZE	"Echo 1"	.W	50,200*ADFREQ/1000	.ASCIZE	"Echo 2"	.W	60,250*ADFREQ/1000	.ASCIZE	"Echo 3"	.W	70,300*ADFREQ/1000	.ASCIZE	"Echo 4"	.W	80,400*ADFREQ/1000	.B	0	.EVEN	.W	2TPARA_ECHO:	.W	ODBPA1,DBTYPN,10,95,5,2^BDBGCLABEL!100,0,3+2	.W	ODBPA2,DBTYPS,0,ADFREQ,ADFREQ/100,2^BDBGCLABEL!101,1,6+2	.W	-1TDBOX_ECHO:	.W	10$-TDBOX_ECHO	.W	20$-TDBOX_ECHO	.W	0,010$:	.B	ODBLABEL,50	.B	ODBTEXT,0	.B	ODBTABX,20+4	.B	ODBTEXT	.ASCIZ	"Ajoute un cho au signal."	.B	ODBCR,ODBCR,ODBCR2	.B	ODBTABX,20+4	.B	ODBTEXT	.ASCIZ	"Taux de rinjection : "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  % "	.B	ODBCR,ODBCR	.B	ODBTABX,20+4	.B	ODBTEXT	.ASCIZ	"Priode :          "	.B	ODBLABEL,101	.B	ODBCLINE,(6+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  [s] "	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBTABX,20	.B	ODBLABEL,51	.B	ODBTEXT,0	.B	ODBTABX,20+4	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  ECHO  "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Echo"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVEN;---------\\; DBOXFREQ >;=========/; Choix de la frquence.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXFREQ:	PUSHM.L	A1,A2,A5	LOAD.W	(A6)+ODBPA1,(A6)+OFRFAC	LOAD.W	(A6)+ODBPA2,(A6)+OFRPEN	LOAD.W	(A6)+OSLVAR2+OSLCYS,(A6)+OFRCYS	LOAD.L	A1,#R16"TDBOX_FREQ	LOAD.L	A2,#R16"TPARA_FREQ	LOAD.L	A5,#R16"TSLST_FREQ	CALL	DBOXPASL	; choix ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	LOAD.W	(A6)+OFRFAC,(A6)+ODBPA1	LOAD.W	(A6)+OFRPEN,(A6)+ODBPA2	LOAD.W	(A6)+OFRCYS,(A6)+OSLVAR2+OSLCYSEXIT$:	POPM.L	A1,A2,A5	TEST.W	D7		; retour EQ/NE	RETTSLST_FREQ:	.ASCIZE	"-12 demi-tons (do)"	.W	-100,0	.ASCIZE	"-11 demi-tons (do#)"	.W	-89,0	.ASCIZE	"-10 demi-tons (r)"	.W	-78,0	.ASCIZE	" -9 demi-tons (r#)"	.W	-68,0	.ASCIZE	" -8 demi-tons (mi)"	.W	-59,0	.ASCIZE	" -7 demi-tons (fa)"	.W	-50,0	.ASCIZE	" -6 demi-tons (fa#)"	.W	-41,0	.ASCIZE	" -5 demi-tons (sol)"	.W	-33,0	.ASCIZE	" -4 demi-tons (sol#)"	.W	-26,0	.ASCIZE	" -3 demi-tons (la)"	.W	-19,0	.ASCIZE	" -2 demi-tons (la#)"	.W	-12,0	.ASCIZE	"<1> -1 demi-ton  (si)"	.W	-6,0	.ASCIZE	"<1>  0 demi-ton  (do)"	.W	0,0	.ASCIZE	" +1 demi-ton  (do#)"	.W	+100-89,0	.ASCIZE	" +2 demi-tons (r)"	.W	+100-78,0	.ASCIZE	" +3 demi-tons (r#)"	.W	+100-68,0	.ASCIZE	" +4 demi-tons (mi)"	.W	+100-59,0	.ASCIZE	" +5 demi-tons (fa)"	.W	+100-50,0	.ASCIZE	" +6 demi-tons (fa#)"	.W	+100-41,0	.ASCIZE	" +7 demi-tons (sol)"	.W	+100-33,0	.ASCIZE	" +8 demi-tons (sol#)"	.W	+100-26,0	.ASCIZE	" +9 demi-tons (la)"	.W	+100-19,0	.ASCIZE	"+10 demi-tons (la#)"	.W	+100-12,0	.ASCIZE	"+11 demi-tons (si)"	.W	+100-6,0	.ASCIZE	"<1>+12 demi-tons (do)"	.W	+100-0,0	.ASCIZE	"Monte 1"	.W	0,+10	.ASCIZE	"Monte 2"	.W	0,+20	.ASCIZE	"Monte 3"	.W	0,+50	.ASCIZE	"<1>Monte 4"	.W	0,+100	.ASCIZE	"Descend 1"	.W	0,-10	.ASCIZE	"Descend 2"	.W	0,-20	.ASCIZE	"Descend 3"	.W	0,-50	.ASCIZE	"Descend 4"	.W	0,-100	.B	0	.EVEN	.W	2TPARA_FREQ:	.W	ODBPA1,DBTYPNS,-100,+100,10,2^BDBGCLABEL!100,0,4+2	.W	ODBPA2,DBTYPNS,-100,+100,10,2^BDBGCLABEL!101,1,4+2	.W	-1TDBOX_FREQ:	.W	10$-TDBOX_FREQ	.W	20$-TDBOX_FREQ	.W	0,010$:	.B	ODBLABEL,50	.B	ODBTEXT,0	.B	ODBTABX,24+4	.B	ODBTEXT	.ASCIZ	"Modifie la frquence du signal."	.B	ODBCR,ODBCR,ODBCR2	.B	ODBTABX,24+4	.B	ODBTEXT	.ASCIZ	"Modification  : "	.B	ODBLABEL,100	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  % "	.B	ODBCR,ODBCR	.B	ODBTABX,24+4	.B	ODBTEXT	.ASCIZ	"Pente :         "	.B	ODBLABEL,101	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  % "	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBTABX,24	.B	ODBLABEL,51	.B	ODBTEXT,0	.B	ODBTABX,24+4	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" FREQUENCE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Frquence"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVEN;---------\\; DBOXPASL >;=========/; Choix dans une dbox avec paramtres et scroll-liste.; in	A1.L	^table de la dbox	(TDBOX_*);	A2.L	^table des paramtres	(TPARA_*);	A5.L	^table scroll-liste	(TSLST_*); out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPASL:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D0,(A2)-2	; D0 <-- nb de paramtres	CALL	DBOXMEMPT	; mj ^table dbox	LOAD.L	(A6)+ODBPTS,A5	; ODBPTS <-- ^table scroll-liste	LOAD.L	A2,A1	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	CALL	DBPASLDRAW	; affiche la scroll-listeQLINE$:	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,D0	JUMP,LO AFF$	CLR.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	DBOXZEROCR	; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_PASL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,D0	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$CLIC$:	CALL	DBOXCLIC	; clic dans paramtre ...	JUMP,EQ NLINE$	CALL	DBPASLMOVE	; clic dans scroll-liste ...	JUMP,EQ QLINE$	JUMP	BIP$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	BIP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$OK$:	CALL	DBOXPUT	JUMP,NE BIP$END$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTKEY_PASL:	.W	F1,F2,F3,0		DOKF1-TKEY_PASL	.W	F0,F13,F14,F15,0	DOKF0-TKEY_PASL	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_PASL	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_PASL	.W	0;-----------\\; DBPASLDRAW >;-----------/; Dessine la scroll-liste vide.; in	-; out	-; mod	D7.WDBPASLDRAW:	PUSHM.L	D2..D4,A3..A5	LOAD.L	A5,#(A6)+OSLVAR2 ; A5 <-- ^variables scroll-liste	LOAD.W	D2,#51!2^BDBGCLABEL	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#50!2^BDBGCLABEL	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	DEC.W	D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,(A0)+ODFC2Y	SUB.W	D4,D3	INC.W	D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A5)+OSLPOS,D3	LOAD.L	(A5)+OSLDIM,D4	SCROLL_	LDRAW		; dessine la scroll-liste	LOAD.W	D3,#-1	CALL	DBPASLSEARCH	; D3 <-- nb de lignes	LOAD.W	(A5)+OSLCYN,D3	LOAD.L	A4,#R16"DBPASLTEXT	LOAD.L	(A5)+OSLADL,A4	SCROLL_	LUPDATE		; dessine le contenu	POPM.L	D2..D4,A3..A5	RET;-----------\\; DBPASLMOVE >;-----------/; Dplace la scroll-liste.; in	-; out	D7.W	erreur; mod	D7.WDBPASLMOVE:	PUSHM.L	D3,D4,A2..A5	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE EXIT$	LOAD.L	A5,#(A6)+OSLVAR2 ; A5 <-- ^variables scroll-liste	SCROLL_	LMOVE		; dplace ...	JUMP,NE EXIT$	LOAD.W	D3,(A5)+OSLCYS	CALL	DBPASLSEARCH	; A3 <-- ^ligneCSKIP$:	TEST.B	(A3+)		; A3 <-- sauve .ASCIZ	JUMP,NE CSKIP$	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- sauve .EVEN	LOAD.L	A3,D3	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table TPARA_*	LOAD.W	D4,(A2)-2	; D4 <-- nb de paramtres	LOAD.L	A4,#(A6)+ODBPA1MLOOP$:	COMP.W	(A2)+ODBTYP,#DBTYPS	JUMP',EQ MLONG$	LOAD.W	(A4)+0,(A3+)	; ODBPAn <-- nouvelle valeur	JUMP'	MNEXT$MLONG$:	CLR.W	(A4)+0	LOAD.W	(A4)+2,(A3+)	; ODBPAn <-- nouvelle valeurMNEXT$:	LOAD.L	A2,#(A2)+LDB	ADD.L	A4,#4	DEC.W	D4	JUMP,NE MLOOP$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A2..A5	RET;-----------\\; DBPASLTEXT >;-----------/; Donne le texte contenu dans une case.; in	D3.W	rang (0..n); out	A3.L	^texte;	D3.W	trait;	D7.W	erreur; mod	D3.L, D7.L, A3.LDBPASLTEXT:	CALL	DBPASLSEARCH	; A3 <-- ^ligne	CLR.W	D3		; D3 <-- pas de trait	COMP.B	(A3),#10	JUMP',HS EXIT$	LOAD.B	D3,(A3+)	; D3 <-- trait selon tableEXIT$:	CLR.W	D7		; D7 <-- ok	RET;-------------\\; DBPASLSEARCH >;-------------/; Cherche une ligne.; in	D3.W	ligne cherche (0..n); out	D3.W	ligne trouve (0..n);	A3.L	^ligne trouve; mod	D3.L, D7.W, A3.LDBPASLSEARCH:	PUSHM.L	D1,D2,D4	LOAD.L	A3,(A6)+ODBPTE	LOAD.W	D1,(A3)-2	; D1 <-- nb de paramtres	LOAD.L	A3,(A6)+ODBPTS	; A3 <-- ^table scroll-liste	LOAD.W	D2,D3	CLR.W	D3CLOOP$:	TEST.W	D2		; ligne atteinte ?	JUMP',EQ CEND$		; oui => CEND$	TEST.B	(A3)		; fin de la table ?	JUMP',EQ CEND$		; oui => CEND$CSKIP$:	TEST.B	(A3+)		; A3 <-- sauve .ASCIZ	JUMP,NE CSKIP$	LOAD.L	D4,A3	INC.L	D4	TCLR.L	D4:#0		; A3 <-- sauve .EVEN	LOAD.L	A3,D4	ADD.W	A3,D1	ADD.W	A3,D1		; A3 <-- sauve .W des paramtres	INC.W	D3	DEC.W	D2	JUMP	CLOOP$CEND$:	POPM.L	D1,D2,D4	RET;--------\\; DBOXREC >;========/; Choix des paramtres pour enregistrer.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXREC:	PUSHM.L	D0..D2,D4,D5,A1..A4	GESMEM	?ARGMEM		; D4/D5 <-- total/plus grand trou	LOAD.W	D7,#ERNEMEM	SR.L	D5,#1		; D5 <-- la moiti	SUB.L	D5,#20000	; D5 <-- garde toujours une marge de 20 kbytes	JUMP,LO EXIT$	DIV.WU	D5,#ADFREQ	; D5 <-- plus grand trou [s]	COMP.W	D5,#2	JUMP,LO EXIT$	LOAD.W	(A6)+ORCLGH,D5	LOAD.W	D4,(A6)+ORCLGS	COMP.W	D4,D5	JUMP',LS LGS$	LOAD.W	D4,D5LGS$:	LOAD.W	(A6)+ODBPA1,D4	LOAD.W	(A6)+ODBPA2,(A6)+ORCNIV	LOAD.W	(A6)+ODBPA3,(A6)+ORCTIMOPEN$:	LOAD.L	A2,#R16"TPARA_REC	LOAD.W	D0,(A2)-2	; D0 <-- nb de paramtres	CALL	DBOXMEMPT	; mj ^table dbox	LOAD.L	A2,#R16"TDBOX_REC	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!50	CALL	DBOXHLINE	LOAD.W	D2,#2^BDBGCLABEL!51	CALL	DBOXHLINE	LOAD.W	D2,#2^BDBGCLABEL!52	CALL	DBOXHLINEQLINE$:	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,D0	JUMP,LO AFF$	CLR.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	DBOXZEROCR	; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_REC	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F4	JUMP,EQ TEST$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,D0	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$CLIC$:	CALL	DBOXCLIC	; clic dans paramtre ...	JUMP,EQ NLINE$	JUMP	BIP$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	BIP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$TEST$:	CALL	DBOXCLOSE	; ferme la DBOX	CALL	TESTVU		; VU-METER ...	JUMP	OPEN$OK$:	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.W	(A6)+ORCLGS,(A6)+ODBPA1	LOAD.W	(A6)+ORCNIV,(A6)+ODBPA2	LOAD.W	(A6)+ORCTIM,(A6)+ODBPA3END$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET	.W	3TPARA_REC:	.W	ODBPA1,DBTYPN!2^15,1,ORCLGH,1,2^BDBGCLABEL!100,0,3+2	.W	ODBPA2,DBTYPN,0,100,2,2^BDBGCLABEL!101,1,3+2	.W	ODBPA3,DBTYPN,1,10,1,2^BDBGCLABEL!102,2,3+2	.W	-1TDBOX_REC:	.W	10$-TDBOX_REC	.W	20$-TDBOX_REC	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix des paramtres pour l'acquisition de"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"sons avec l'interface DIGISON."	.B	ODBCR,ODBCR	.B	ODBLABEL,50	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Dure :           "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  [s] "	.B	ODBCR	.B	ODBLABEL,51	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Conditions pour le dbut de l'enregistrement"	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Niveau du bruit : "	.B	ODBLABEL,101	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Temps limite :    "	.B	ODBLABEL,102	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBTEXT	.ASCIZ	"  [s] "	.B	ODBCR	.B	ODBLABEL,52	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" ENREGISTRE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" REGLAGE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Enregistre"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Rglage"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_REC:	.W	F1,F2,F3,0		DOKF1-TKEY_REC	.W	F4,F5,F6,0		DOKF4-TKEY_REC	.W	F0,F13,F14,F15,0	DOKF0-TKEY_REC	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_REC	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_REC	.W	0TDBOX_TESTV:	.W	10$-TDBOX_TESTV	.W	20$-TDBOX_TESTV	.W	0,010$:	.B	ODBTEXT	.ASCIZ	" Rglez le niveau  l'aide du potentiomtre"	.B	ODBTABX,44	.B	ODBCR	.B	ODBTEXT	.ASCIZE	" plac sur l'interface DIGISON :"	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"FIN"	.B	020$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTDBOX_TESTR:	.W	10$-TDBOX_TESTR	.W	20$-TDBOX_TESTR	.W	0,010$:	.B	ODBTABX,9	.B	ODBTEXT	.ASCIZ	"Enregistrement en cours ..."	.B	ODBTABX,44	.B	ODBCR	.B	ODBLABEL,1	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVEN;---------\\; DBOXCODE >;=========/; Choix du codage.; in	A4.L	^son; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCODE:	PUSHM.L	D1,D2,D4,D5,A1..A4	CALL	DBCODGET	; D4 <-- fanions	LOAD.L	A2,#R16"TDBOX_CODE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#2!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#3!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#4!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#5!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	POP.L	D4NBK$:	CALL	DBCODNBK	; affiche le nombre de kilosLOOP$:	CALL	NORMMOUSE	; remet la flche	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_CODE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#DEFINE	JUMP',EQ PLAY$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$KEYDBOX$:	LOAD.L	D1,#H'FFFF0000	COMP.B	D3,#16	JUMP',LO MASK$	SWAP.W	D1MASK$:	AND.L	D4,D1	TSET.L	D4:D3	JUMP	NBK$PLAY$:	PUSH.W	(A4)+OADHFREQ	PUSH.W	(A4)+OADHCOD	CALL	DBCODPUT	; mj le son	CALL	MAINPLAY	; fait entendre	POP.W	(A4)+OADHCOD	POP.W	(A4)+OADHFREQ	TEST.W	D7	JUMP,NE BIP$	JUMP	LOOP$OK$:	CALL	DBCODPUT	; mj le sonEND$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CODE:	.W	10$-TDBOX_CODE	.W	20$-TDBOX_CODE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Codage du son :   "	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,0!2^7!2^6,KEYDBOX/H'100,0	.ASCIZ	" aucun"	.B	ODBTABX,13	.B	ODBLCIRCLE,16!2^7!2^6,KEYDBOX/H'100,16	.ASCIZ	" 35.000 KHz"	.B	ODBCR	.B	ODBLABEL,1	.B	ODBLCIRCLE,1!2^7!2^6,KEYDBOX/H'100,1	.ASCIZ	" idem"	.B	ODBTABX,13	.B	ODBLCIRCLE,17!2^7!2^6,KEYDBOX/H'100,17	.ASCIZ	" 17.500 KHz"	.B	ODBCR	.B	ODBLABEL,2	.B	ODBLCIRCLE,2!2^7!2^6,KEYDBOX/H'100,2	.ASCIZ	" delta 1"	.B	ODBTABX,13	.B	ODBLCIRCLE,18!2^7!2^6,KEYDBOX/H'100,18	.ASCIZ	"  8.750 KHz"	.B	ODBCR	.B	ODBLABEL,3	.B	ODBLCIRCLE,3!2^7!2^6,KEYDBOX/H'100,3	.ASCIZ	" delta 2"	.B	ODBTABX,13	.B	ODBLCIRCLE,19!2^7!2^6,KEYDBOX/H'100,19	.ASCIZ	"  4.375 KHz"	.B	ODBCR	.B	ODBLABEL,4	.B	ODBLCIRCLE,4!2^7!2^6,KEYDBOX/H'100,4	.ASCIZ	" delta 4"	.B	ODBCR	.B	ODBLABEL,5	.B	ODBLCIRCLE,5!2^7!2^6,KEYDBOX/H'100,5	.ASCIZ	" 4 bits"	.B	ODBTABX,13	.B	ODBBOX,0,DEFINE,TDBOMBRE	.ASCIZ	" ECOUTE "	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  CODE  "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Code"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CODE:	.W	F1,F2,F3,0		DOKF1-TKEY_CODE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CODE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CODE	.W	0;---------\\; DBCODGET >;---------/; in	A4.L	^son; out	D4.L	fanions; mod	D4.L, D7.WDBCODGET:	PUSHM.L	D1	LOAD.L	D4,#2^19	COMP.W	(A4)+OADHFREQ,#ADFREQ/8	JUMP',EQ FREQ$	LOAD.L	D4,#2^18	COMP.W	(A4)+OADHFREQ,#ADFREQ/4	JUMP',EQ FREQ$	LOAD.L	D4,#2^17	COMP.W	(A4)+OADHFREQ,#ADFREQ/2	JUMP',EQ FREQ$	LOAD.L	D4,#2^16FREQ$:	LOAD.W	D4,#H'8000	LOAD.W	D1,(A4)+OADHCOD	; D1 <-- type de codageCODE$:	RL.W	D4,#1	DEC.W	D1	JUMP,NC CODE$	POPM.L	D1	RET;---------\\; DBCODPUT >;---------/; in	A4.L	^son;	D4.L	fanions; out	-; mod	D7.WDBCODPUT:	PUSHM.L	D1,D4	LOAD.W	(A4)+OADHFREQ,#ADFREQ/8	TEST.L	D4:#19	JUMP',BS FREQ$	LOAD.W	(A4)+OADHFREQ,#ADFREQ/4	TEST.L	D4:#18	JUMP',BS FREQ$	LOAD.W	(A4)+OADHFREQ,#ADFREQ/2	TEST.L	D4:#17	JUMP',BS FREQ$	LOAD.W	(A4)+OADHFREQ,#ADFREQFREQ$:	LOAD.W	D1,#-1CODE$:	INC.W	D1	RR.W	D4,#1	JUMP,CC CODE$	LOAD.W	(A4)+OADHCOD,D1	POPM.L	D1,D4	RET;---------\\; DBCODNBK >;---------/; Affiche le nombre de kilos du son.; in	A4.L	^son;	D4.L	fanions; out	-; mod	D7.WDBCODNBK:	PUSHM.L	D1..D4	LOAD.L	D1,D4		; D1 <-- fanions	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.B	D3,#'(	LIB	?AFCAR	LOAD.L	D4,(A4)+OADHLG	LOAD.W	D3,#3	TEST.L	D1:#19	JUMP',BS DRAW$	LOAD.W	D3,#2	TEST.L	D1:#18	JUMP',BS DRAW$	LOAD.W	D3,#1	TEST.L	D1:#17	JUMP',BS DRAW$	CLR.W	D3DRAW$:	SR.L	D4,D3	SR.L	D4,#8	SR.L	D4,#2		; D4 <-- /1024	INC.L	D4	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC	LIB	?AFTIM	.ASCII	"k)"	.B	EFLI,0	.EVEN	POPM.L	D1..D4	RET;----------\\; DBOXERROR >;==========/; Affiche une erreur.; in	D7.W	erreur; out	-; mod	D7.WDBOXERROR:	PUSHM.L	D2..D4,A3	LOAD.W	D4,D7		; D4 <-- code de l'erreur	JUMP',EQ OK$	COMP.W	D7,#ERKNO	JUMP',EQ OK$	COMP.W	D7,#ERKSTO	JUMP',NE OPEN$OK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$OPEN$:	CALL	DBOXOPEN1	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	AUDIO_	ERROR		; A3 <-- ^texte	JUMP',EQ INTERN$	LOAD.W	D7,D4		; D7 <-- code de l'erreur	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur "externe" ...	JUMP'	CLOSE$INTERN$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur "interne" ...CLOSE$:	CALL	DBOXCLOSE1	; refait les soft-keysEXIT$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET; Tables; ------TFEXT:	.ASCIZ	".AUDIO"TDBOX_IOB:	.ASCIZ	"AUDIO"			; nom du logiciel	.ASCIZ	"Fbanque de sons"	; [M,F] nom des lments manipuls	.ASCIZ	""			; [M,F] nom du contenant	.B	0TDBOX_IO1:	.ASCIZ	"AUDIO"			; nom du logiciel	.ASCIZ	"Mson"			; [M,F] nom des lments manipuls	.ASCIZ	""			; [M,F] nom du contenant	.B	0	.EVEN	.END