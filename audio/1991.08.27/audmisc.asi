	.SBTTL	AUDMISC.ASI;--------\\; SKIPREP >;========/; Saute tous les noms d'units et de rpertoires devant; un nom de fichier.; in	A3.L	^unit:rp:rp:nom.ext; out	A3.L	^nom.ext; mod	A3.LSKIPREP:	PUSH.W	D3	CLR.W	D3END$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE END$BEGIN$:	DEC.W	D3	JUMP',NS EXIT$	COMP.B	(-A3),#':	JUMP,NE BEGIN$	INC.L	A3EXIT$:	POP.W	D3	RET;--------\\; PUTSNUM >;========/; Met un nombre de secondes dans un buffer.; in	D4.L	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTSNUM:	PUSHM.L	D3,D4	DIV.WU	D4,#ADFREQ/1000	; D4 <-- chiffre *1000	AND.L	D4,#H'FFFF	LIB	?BINBCD	LOAD.L	D3,D4	SWAP.W	D3	AND.B	D3,#B'1111	JUMP',EQ UNIT$	ADD.B	D3,#'0	LOAD.B	(A4+),D3	; buffer <-- dizaineUNIT$:	LOAD.L	D3,D4	RL.W	D3,#4	AND.B	D3,#B'1111	ADD.B	D3,#'0	LOAD.B	(A4+),D3	; buffer <-- unit	LOAD.B	(A4+),#'.	; buffer <-- point dcimal	LOAD.L	D3,D4	RR.W	D3,#8	AND.B	D3,#B'1111	ADD.B	D3,#'0	LOAD.B	(A4+),D3	; buffer <-- premire dcimale	LOAD.L	D3,D4	RR.W	D3,#4	AND.B	D3,#B'1111	ADD.B	D3,#'0	LOAD.B	(A4+),D3	; buffer <-- deuxime dcimale	LOAD.L	D3,D4	AND.B	D3,#B'1111	ADD.B	D3,#'0	LOAD.B	(A4+),D3	; buffer <-- troisime dcimale	POPM.L	D3,D4	RET;--------\\; GETSNUM >;========/; Donne un nombre de secondes.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETSNUM:	PUSHM.L	D2,D3	CLR.L	D4	CLR.W	D2		; D2 <-- nb de dcimales trouvesILOOP$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'.	JUMP',EQ FLOOP$	SUB.B	D3,#'0	JUMP',LO END$	COMP.B	D3,#9	JUMP',HI END$	SL.L	D4,#4	OR.B	D4,D3	JUMP	ILOOP$FLOOP$:	LOAD.B	D3,(A4+)	SUB.B	D3,#'0	JUMP',LO END$	COMP.B	D3,#9	JUMP',HI END$	SL.L	D4,#4	OR.B	D4,D3	INC.W	D2		; D2 <-- une dcimale de plus	JUMP	FLOOP$END$:	COMP.W	D2,#3	JUMP',EQ CONV$	JUMP',HI TOO$FILL$:	SL.L	D4,#4	INC.W	D2	COMP.W	D2,#3	JUMP,LO FILL$	JUMP'	CONV$TOO$:	SR.L	D4,#4	DEC.W	D2	COMP.W	D2,#3	JUMP,HI TOO$CONV$:	LIB	?BCDBIN	MUL.WU	D4,#ADFREQ/1000	; D4 <-- nombre	DEC.L	A4	POPM.L	D2,D3	RET;--------\\; PUTANUM >;========/; Met un nombre dcimal dans un buffer.; in	D4.W	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	AND.L	D4,#H'FFFF	; D4 <-- nombre binaire	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	CLR.B	(A4)	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;========/; Donne un nombre dcimal.; OK jusqu' 32 bits !; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSHM.L	D2,D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	SL.L	D4,#1	LOAD.L	D2,D4	SL.L	D4,#2	ADD.L	D4,D2		; D4 <-- pousse d'un digit (*10)	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POPM.L	D2,D3	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE EXIT$	SUB.W	D4,(A0)+ODFFX	JUMP',HS OKX$	CLR.W	D4	LOAD.W	D7,#ERDIOUTOKX$:	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',HS OKY$	CLR.W	D4	LOAD.W	D7,#ERDIOUTOKY$:	SWAP.W	D4EXIT$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMOUSE  >;========/; Positionne la souris en (y;x).; in	D4.L	nouvelle position y;x; out	-; mod	D7.WPMOUSE:	LIB	?PMOUSE		; positionne la souris	RET;--------\\; INVMODE >;========/; Inverse le mode de dessin si ncessaire.; in	D2.W	mode; out	D2.W	mode v. invers; mod	D2.L, D7.WINVMODE:	TEST.B	(A6)+OINV	JUMP',T EXIT$	COMP.B	D2,#SETDOT	JUMP',EQ SET$	COMP.B	D2,#CLRDOT	JUMP',NE EXIT$CLR$:	LOAD.B	D2,#SETDOT	JUMP'	EXIT$SET$:	LOAD.B	D2,#CLRDOT;	JUMP'	EXIT$EXIT$:	RET;---------\\; INVTRAME >;=========/; Inverse la trame si ncessaire.; in	D4.L	trame; out	D4.L	trame v. invers; mod	D4.L, D7.WINVTRAME:	TEST.B	(A6)+OINV	JUMP',T EXIT$	NOT.L	D4		; D4 <-- trame inverseEXIT$:	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	RET;--------\\; CCMO    >;========/; Enlve la souris.; in	-; out	-; mod	D7.WCCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',T EXIT$	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	SET.B	(A6)+OCCMOEXIT$:	POP.W	D3	RET;--------\\; SCMO    >;========/; Remet la souris.; in	-; out	-; mod	D7.WSCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',F EXIT$	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	CLR.B	(A6)+OCCMOEXIT$:	POP.W	D3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	-; out	-; mod	D7.WAFMENU:	PUSH.L	A3	LOAD.L	A3,#R16"TXMENU$	LIB	?AFMENU	POP.L	A3	RETTXMENU$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"      Ajoute     "	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"      Efface     "		;     ;     ;     ;	.EVEN	.END