	.SBTTL	AUDIO.ASI;--------\\; IOIFREC >;========/; Vrifie si l'interface pour l'acquisition des sons est connecte.; in	-; out	D7.W	erreur; mod	D7.WIOIFREC:	PUSHM.L	D1,D3,D4,D6,A3,A4	LOAD.L	D4,#ADFREQ/10	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE EXIT$	LOAD.L	A3,#R16"NPAUDIO	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE GIVE$	PUSH.L	A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#'R	LOAD.B	(A4)+1,#'L	LOAD.W	(A4)+2,#0	LOAD.B	(A4)+4,#'R	LOAD.B	(A4)+5,#'T	LOAD.L	(A4)+6,#ADFREQ	CLR.B	(A4)+10	FOS	?COMMAND	; spcifie niveau et timeout	POP.L	A4	FOS	?RDBYTE		; lit le son ...CLOSE$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7GIVE$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	POP.W	D7EXIT$:	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOREC   >;========/; Enregistre un son.; in	A4.L	^en-tte + son;	D4.L	lg  lire; out	D7.W	erreur; mod	D7.WIOREC:	PUSHM.L	D3,D4,D6,A3,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	A3,#R16"NPAUDIO	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP,NE EXIT$	PUSH.L	A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#'R	LOAD.B	(A4)+1,#'L	LOAD.W	(A4)+2,(A6)+ORCNIV	LOAD.B	(A4)+4,#'R	LOAD.B	(A4)+5,#'T	LOAD.W	D3,(A6)+ORCTIM	MUL.WU	D3,#ADFREQ	LOAD.L	(A4)+6,D3	CLR.B	(A4)+10	FOS	?COMMAND	; spcifie niveau et timeout	POP.L	A4	CALL	IOVUOPEN	; dessine le VU-METER	JUMP',NE CLOSE$	FOS	?RDBYTE		; lit le son ...	PUSH.W	D7	CALL	IOVUCLOSE	; enlve le VU-METER	POP.W	D7CLOSE$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; IOVUOPEN >;---------/; Cre le processus fils pour le suivit pendant l'enregistrement.; in	D4.L	lg  lire;	A4.L	^buffer; out	-; mod	D7.WIOVUOPEN:	PUSHM.L	D3..D5,A3..A5	LOAD.L	(A6)+OPFLG,D4	LOAD.L	(A6)+OPFPT,A4	CLR.L	(A4)+OADHLG	LOAD.L	A2,#R16"TDBOX_TESTR	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE EXIT$	LOAD.L	(A6)+OOPCDB,D5	CLR.W	(A6)+OOPASC+OSCHTV ; ascenseur pas dessin	CALL	TESTDRAW	; dessine le VU-METER vide	CLR.B	(A6)+OPFAB	NTREL	?GETPRIO	; D4 <-- priorit de START	INC.B	D4		; fils moins prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS2	LOAD.L	A3,#R16"NFILS2	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils	LOAD.W	D4,#2	NTREL	?DELMS		; attend un poil ...EXIT$:	POPM.L	D3..D5,A3..A5	RETNFILS2:	.ASCIZE	"AUDIO_VU"PFILS2:	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	LIB	?COLORPUSH	LOAD.L	D3,#COLORTESTA	LIB	?COLORSR	LOAD.L	D3,#COLORTEST0	LIB	?COLORCR	CLR.L	(A6)+OPFT1	CLR.W	D4	CALL	TESTAINV	; allume l'aiguille	LOAD.W	D2,D4	LOAD.W	D1,#-1LOOP$:	TEST.B	(A6)+OPFAB	; abort ?	JUMP',T END$		; oui => END$	LOAD.W	D4,#50/10	NTREL	?DELMS		; attend 0.1 seconde ...	LOAD.L	D0,(A6)+OPFLG	SUB.L	D0,#LADH+(ADFREQ/10)	SUB.L	D0,(A6)+OPFT1	JUMP',HS MIN$	CLR.L	D0MIN$:	DIV.WU	D0,#ADFREQ/10	COMP.W	D0,D1	JUMP',EQ READ$	CALL	AFFNDBOX	; avance l'ascenseur	LOAD.W	D1,D0READ$:	CALL	IOVUREAD	; D4 <-- niveau	COMP.W	D4,D2		; est-ce que le niveau baisse ?	JUMP',HS COMP$		; non => COMP$				; oui =>	LOAD.W	D3,D2	SUB.W	D3,D4		; D3 <-- diminution	COMP.W	D3,#TESTVIT	JUMP',LO COMP$	LOAD.W	D4,D2	SUB.W	D4,#TESTVIT	; D4 <-- redescend pas trop videCOMP$:	COMP.W	D4,D2		; niveau chang ?	JUMP',EQ LOOP$		; non => LOOP$	EX.L	D4,D2	CALL	TESTAINV	; teint l'aiguille	LOAD.W	D4,D2	CALL	TESTAINV	; allume l'aiguille	CALL	TESTOVER	; dessine l'overflow	JUMP	LOOP$END$:	LIB	?COLORPOP	NTREL	?ABORT;---------\\; IOVUREAD >;---------/; Lit le niveau du VU-METER.; in	-; out	D4.W	niveau (0..128); mod	D4.L, D7.WIOVUREAD:	PUSHM.L	D2,D3,D6,A4	CLR.W	D4		; D4 <-- niveau	LOAD.L	A4,(A6)+OPFPT	; A4 <-- ^buffer de lecture	LOAD.L	D3,(A4)+OADHLG	; D3 <-- nb de bytes dj lus	LOAD.L	D2,(A6)+OPFT1	LOAD.L	(A6)+OPFT1,D3	SUB.L	D3,D2	JUMP',LS EXIT$	LOAD.L	A4,#(A4)+(D2.L)+LADHLOOP$:	CLR.W	D2	LOAD.B	D2,(A4+)	SUB.W	D2,#ADNIVZERO	JUMP',NC SUM$	NEG.W	D2SUM$:	COMP.W	D4,D2	JUMP',HS NEXT$	LOAD.W	D4,D2		; D4 <-- maximum	COMP.W	D4,#ADNIVZERO	JUMP',HS EXIT$NEXT$:	DEC.L	D3	JUMP,NE LOOP$EXIT$:	POPM.L	D2,D3,D6,A4	RET;----------\\; IOVUCLOSE >;----------/; Enlve le VU-METER.; in	-; out	-; mod	D7.WIOVUCLOSE:	PUSHM.L	D5	SET.B	(A6)+OPFAB	NTREL	?WFABDESC	; attend la fin du processus fils ...	LOAD.L	D5,(A6)+OOPCDB	JUMP',EQ WAIT$	CALL	DBOXCLOSE	; ferme la dbox	CLR.L	(A6)+OOPCDBWAIT$:	POPM.L	D5	RET;--------\\; IOPLAY  >;========/; Fait entendre une partie de son.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	D7.W	erreur; mod	D7.WIOPLAY:	PUSHM.L	D1..D4,D6,A2..A4	CLR.W	D7		; D7 <-- ok	COMP.L	D1,D2	JUMP,HS EXIT$	CALL	WAITMOUSE	; met le sablier	LOAD.L	A2,A4		; A2 <-- ^son dcod	CALL	IOCODE		; A3 <-- ^son cod	JUMP,NE EXIT$	LOAD.L	A4,A3		; A4 <-- ^son cod	LOAD.L	A3,#R16"NPAUDIO	LOAD.W	D3,#2^BOPWR	FOS	?OPEN	JUMP',NE GIVE$	CALL	IOMARKOPEN	; dmarre le marquage ...	CALL	IOCODELG	; D1/D2 <-- temps cods	LOAD.L	D4,#LADH	FOS	?WRBYTE		; crit l'en-tte	JUMP',NE GIVE$	PUSH.L	A4	LOAD.L	A4,#(A4)+(D1.L)+LADH	LOAD.L	D4,D2	SUB.L	D4,D1	FOS	?WRBYTE		; crit le data	POPM.L	A4	JUMP',NE GIVE$	FOS	?CLOSEGIVE$:	COMP.L	A4,A2	JUMP',EQ EXIT$	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le son cod	POP.W	D7EXIT$:	PUSH.W	D7	CALL	IOMARKCLOSE	; termine le marquage ...	POP.W	D7	POPM.L	D1..D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IOMARKOPEN >;-----------/; Cre le processus fils pour le suivit pendant l'coute.; in	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	-; mod	D7.WIOMARKOPEN:	PUSHM.L	D0,D3..D5,A3..A5	COMP.B	(A6)+OMACHINE,#SMAKY100	JUMP',EQ EXIT$	CALL	VISUGETFACT	; D0 <-- facteur de rduction	COMP.W	D0,#50	JUMP',LO EXIT$	LOAD.L	D3,D2	SUB.L	D3,D1		; D3 <-- dure	COMP.L	D3,#ADFREQ/4	; moins d'un quart de seconde ?	JUMP',LO EXIT$		; oui => EXIT$	LOAD.L	(A6)+OPFT1,D1	LOAD.L	(A6)+OPFT2,D2	NTREL	?GETPRIO	; D4 <-- priorit de START	INC.B	D4		; fils moins prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus filsEXIT$:	POPM.L	D0,D3..D5,A3..A5	RETNFILS1:	.ASCIZE	"AUDIO_MARK"PFILS1:	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.W	D4,#2	NTREL	?DELMS	CALL	VISUGETFACT	; D0 <-- facteur de rduction	LOAD.L	D1,(A6)+OPFT1	; D1 <-- temps dbut	LOAD.L	D2,(A6)+OPFT2	; D2 <-- temps fin	CLR.L	D5	LOAD.W	D5,(A6)+OSCVAR+OSCPOSV ; D5 <-- position dbut [e/64]	SL.L	D5,#6		; D5 <-- position dbut [e]	LOAD.W	D6,(A6)+OVSDIM+2	MUL.WU	D6,D0	ADD.L	D6,D5		; D6 <-- position fin [e]	CALL	IOMARKINV	; allume la premire marqueLOOP$:	COMP.L	D1,D2	JUMP',HS END$	COMP.L	D1,D6	JUMP',HS END$	CALL	IOMARKINV	; teint la marque	ADD.L	D1,#ADFREQ/1000*40	CALL	IOMARKINV	; allume la marque	LOAD.W	D4,#2	NTREL	?DELMS		; attend 40ms ...	JUMP	LOOP$END$:	CALL	IOMARKINV	; teint la dernire marque	NTREL	?ABORT;----------\\; IOMARKINV >;----------/; Inverse une marque de temps.; in	D1.L	temps;	D0.W	facteur de rduction;	D5.L	dbut visible;	D6.L	fin visible; out	-; mod	D7.WIOMARKINV:	PUSHM.L	D2..D4	COMP.L	D1,D5	JUMP',LO EXIT$	COMP.L	D1,D6	JUMP',HS EXIT$	LOAD.L	D3,D1	SUB.L	D3,D5	DIV.WU	D3,D0	ADD.W	D3,(A6)+OVSPOS+2	SWAP.W	D3	LOAD.W	D3,(A6)+OVSPOS+0	SWAP.W	D3	LOAD.W	D4,(A6)+OVSDIM+0	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRSEG		; inverse une barre verticaleEXIT$:	POPM.L	D2..D4	RET;------------\\; IOMARKCLOSE >;============/; Termine le marquage.; in	-; out	-; mod	D7.WIOMARKCLOSE:	NTREL	?WFABDESC	; attend la fin du processus fils ...	RET;--------\\; IOADD   >;========/; Ajoute un fichier .AUDIO; in	A3.L	^nom du fichier .AUDIO; out	D7.W	erreur; mod	D7.WIOADD:	PUSHM.L	D2..D4,D6,A2,A4	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier	JUMP,NE EXIT$	LOAD.L	A2,#(A6)+OPSON	; ^^sons	CLR.W	D2LOOP$:	TEST.L	(A2)		; emplacement libre ?	JUMP',NE NEXT$		; non => NEXT$	CALL	IOREADONE	; lit un son	JUMP',NE CLOSE$NEXT$:	ADD.L	A2,#4		; A2 <-- ^^suivant	INC.W	D2	COMP.W	D2,#MAXSON	JUMP,LO LOOP$	COMP.W	D2,#MAXSON	JUMP,LO LOOP$CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7	COMP.W	D7,#EROUTF	JUMP',NE EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOREAD  >;========/; Lit tout un fichier .AUDIO; in	A3.L	^nom du fichier .AUDIO; out	D7.W	erreur; mod	D7.WIOREAD:	PUSHM.L	D2..D4,D6,A2,A4	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPRD	FOS	?OPEN		; ouvre le fichier	JUMP,NE EXIT$	CALL	IOFLUSH		; libre tous les sons	LOAD.L	A2,#(A6)+OPSON	; ^^sons	CLR.W	D2LOOP$:	CALL	IOREADONE	; lit un son	JUMP',NE CLOSE$	ADD.L	A2,#4		; A2 <-- ^^suivant	INC.W	D2	COMP.W	D2,#MAXSON	JUMP,LO LOOP$	COMP.W	D2,#MAXSON	JUMP,LO LOOP$CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7	COMP.W	D7,#EROUTF	JUMP',NE EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOREADONE >;----------/; Lit un son en mmoire.; in	A2.L	^^son;	A3.L	^nom du fichier;	D6.W	canal FOS; out	D7.W	erreur; mod	D7.WIOREADONE:	PUSHM.L	D1,D3,D4,A1,A3,A4	LOAD.L	A1,A3		; A1 <-- ^nom du fichier	LOAD.L	A4,#(A6)+OBHEAD	LOAD.L	D4,#LADH	FOS	?RDBYTE		; lit une en-tte	JUMP,NE EXIT$	LOAD.L	A3,A4		; A3 <-- ^en-tte	COMP.B	(A3)+OADHTYP,#ADHTYPE	JUMP',NE OTHER$	TEST.B	(A3)+OADHTYP+1	JUMP',NE OTHER$	LOAD.L	D3,(A3)+OADHLG	ADD.L	D4,D3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP,NE EXIT$	LOAD.L	(A2),A4		; OPSON <-- ^son	LOAD.W	D4,#(LADH/2)-1HXFER$:	LOAD.W	(A4+),(A3+)	; buffer <-- en-tte	DECJ.W,NMO D4,HXFER$	LOAD.L	D4,D3	FOS	?RDBYTE		; lit un son	JUMP,NE EXIT$	LOAD.L	A4,(A2)	CALL	IODECODE	; A3 <-- ^son dcod	JUMP,NE EXIT$	COMP.L	A4,A3	JUMP,EQ NAME$	LOAD.L	(A2),A3		; OPSON <-- ^son dcod	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le son cod	JUMP	NAME$OTHER$:	FOS	?GPOS		; D4 <-- position actuelle	SUB.L	D4,#LADH	; D4 <-- position dbut chantillons	LOAD.L	D1,D4	LOAD.L	D4,#-1	LOAD.B	D3,D4	FOS	?SPOS		; D4 <-- position fin	EX.L	D1,D4	CLR.B	D3	FOS	?SPOS		; revient au dbut	SUB.L	D1,D4	LOAD.L	D4,D1		; D4 <-- longueur jusqu' la fin	ADD.L	D4,#LADH	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP',NE EXIT$	LOAD.L	(A2),A4		; OPSON <-- ^son	LOAD.L	A3,A4	SUB.L	D4,#LADH	LOAD.W	D1,#(LADH/2)-1CLR$:	CLR.W	(A4+)	DECJ.W,NMO D1,CLR$	LOAD.B	(A3)+OADHTYP,#ADHTYPE	LOAD.L	(A3)+OADHLG,D4	LOAD.W	(A3)+OADHFREQ,#ADFREQ	FOS	?RDBYTE		; lit les chantillons	JUMP',NE EXIT$NAME$:	LOAD.L	A4,(A2)		; A4 <-- ^son	TEST.B	(A4)+OADHNAME	; nom existe dj ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.L	A3,A1		; A3 <-- ^nom de fichier	CALL	SKIPREP		; A3 <-- saute rep(s):	LOAD.L	A4,#(A4)+OADHNAME	LOAD.W	D4,#LADHNAMENXFER$:	DEC.W	D4	JUMP',NS NEND$	COMP.B	(A3),#'.	JUMP',EQ NEND$	LOAD.B	(A4+),(A3+)	; OADHNAME <-- nom du fichier !	JUMP,NE NXFER$NEND$:	CLR.B	(A4)EXIT$:	POPM.L	D1,D3,D4,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; IOCREATEONE >;============/; Cre un son vide de longueur nulle.; in	A2.L	^^son; out	D7.W	erreur; mod	D7.WIOCREATEONE:	PUSHM.L	D1,D4,A4	LOAD.L	D4,#LADH	; D4 <-- juste l'en-tte	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour nouveau son	JUMP',NE EXIT$	LOAD.L	(A2),A4		; OPSON <-- ^nouveau son	GESMEM	?CLEARMEM	LOAD.B	(A4)+OADHTYP,#ADHTYPE	LOAD.W	(A4)+OADHFREQ,#ADFREQEXIT$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOEXTRAIT >;==========/; Ecrit un seul son dans un fichier .AUDIO; in	A3.L	^nom du fichier .AUDIO;	A4.L	^son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	D7.W	erreur; mod	D7.WIOEXTRAIT:	PUSHM.L	D3,D4,D6	CALL	WAITMOUSE	; met le sablier	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier	JUMP',NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP',NE EXIT$	CALL	IOWRITEONE	; crit un son	JUMP',NE CLOSE$	FOS	?CLOSE	CALL	IOCOMMAND	; envoye v. la commande "F+"	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7EXIT$:	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOWRITE >;========/; Ecrit tout un fichier .AUDIO; in	A3.L	^nom du fichier .AUDIO; out	D7.W	erreur; mod	D7.WIOWRITE:	PUSHM.L	D0..D4,D6,A2,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE		; cre le fichier	JUMP,NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier	JUMP,NE EXIT$	LOAD.L	A2,#(A6)+OPSON	; ^^sons	LOAD.W	D0,#MAXSON-1LOOP$:	TEST.L	(A2)		; son existe ?	JUMP',EQ NEXT$		; non => EXIT$	LOAD.L	A4,(A2)		; A4 <-- ^en-tte + son	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	IOWRITEONE	; crit un son	JUMP',NE CLOSE$NEXT$:	ADD.L	A2,#4	DECJ.W,NMO D0,LOOP$	FOS	?CLOSE	CALL	IOCOMMAND	; envoye v. la commande "F+"	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier	POP.W	D7EXIT$:	POPM.L	D0..D4,D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IOWRITEONE >;-----------/; Ecrit un son.; in	A4.L	^son;	D6.W	canal FOS;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	D7.W	erreur; mod	D7.WIOWRITEONE:	PUSHM.L	D1,D2,D4,A3,A4	CALL	IOCODE		; A3 <-- ^son cod	JUMP',NE EXIT$	EX.L	A3,A4		; A3/A4 <-- ^son dcod/cod	CALL	IOCODELG	; D1/D2 <-- temps cods	SUB.L	D2,D1	PUSH.L	(A4)+OADHLG	LOAD.L	(A4)+OADHLG,D2	LOAD.L	D4,#LADH	FOS	?WRBYTE		; crit en-tte	POP.L	(A4)+OADHLG	TEST.W	D7	JUMP',NE EXIT$	LOAD.L	D4,D2	PUSH.L	A4	LOAD.L	A4,#(A4)+(D1.L)+LADH	FOS	?WRBYTE		; crit son cod	POPM.L	A4	JUMP',NE EXIT$	COMP.L	A4,A3	JUMP',EQ EXIT$	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le son codEXIT$:	POPM.L	D1,D2,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOCOMMAND >;==========/; Envoie une commande F+ au synthtiseur si le fichier; a le nom "300_SYNT.AUDIO".; in	A3.L	^nom du fichier; out	-; mod	D7.WIOCOMMAND:	PUSHM.L	D3,D6,A2..A4	LOAD.L	A4,A3	LOAD.L	A3,#R16"NFILE$	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; fichier 300_SYNT.AUDIO ?	JUMP',NS EXIT$		; non => EXIT$	LOAD.L	A3,#R16"NSYNT$	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre #SYNTHESIZER:	JUMP',NE EXIT$ 	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#'F	LOAD.B	(A4)+1,#'+	CLR.B	(A4)+2	LOAD.W	D3,#TYPIO	; D3 <-- type du driver	FOS	?COMMAND	; utilise ou pas 300_SYNT.AUDIO	FOS	?CLOSE		; ferme #SYNTHESIZER:EXIT$:	POPM.L	D3,D6,A2..A4	RETNFILE$:	.ASCIZ	"*300_SYNT.AUDIO"NSYNT$:	.ASCIZ	"#SYNTHESIZER:"TERM$:	.B	0,SPACE,TAB,CR,-1	.EVEN;--------\\; IOFLUSH >;========/; Libre tous les sons.; in	-; out	-; mod	D7.WIOFLUSH:	PUSHM.L	D1,D2,A2,A4	LOAD.L	A2,#(A6)+OPSON	; ^^sons	LOAD.W	D2,#MAXSON-1LOOP$:	TEST.L	(A2)	JUMP',EQ NEXT$	LOAD.L	A4,(A2)	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A2)NEXT$:	ADD.L	A2,#4	DECJ.W,NMO D2,LOOP$	POPM.L	D1,D2,A2,A4	RET;-----------\\; IOFLUSHONE >;===========/; Libre un son.; in	D3.W	rang du son (0..n); out	-; mod	D7.WIOFLUSHONE:	PUSHM.L	D1,D3,A2,A4	LOAD.L	A2,#(A6)+OPSON	; ^^sons	SL.W	D3,#2	ADD.W	A2,D3	TEST.L	(A2)	JUMP',EQ EXIT$	LOAD.L	A4,(A2)	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A2)EXIT$:	POPM.L	D1,D3,A2,A4	RET;---------\\; IODECODE >;=========/; Dcode un son.; in	A4.L	^en-tte + son (cod); out	A3.L	^en-tte + son (dcod);	D7.W	erreur; mod	D7.W, A3.LIODECODE:	PUSHM.L	D0..D4,A1,A2,A4,A5	LOAD.L	A2,A4		; A2 <-- ^son cod	LOAD.L	D2,#H'10000*1+0	COMP.W	(A2)+OADHFREQ,#ADFREQ	JUMP',EQ MEM1$	LOAD.L	D2,#H'10000*2+1	COMP.W	(A2)+OADHFREQ,#ADFREQ/2	JUMP',EQ MEM1$	LOAD.L	D2,#H'10000*4+2	COMP.W	(A2)+OADHFREQ,#ADFREQ/4	JUMP',EQ MEM1$	LOAD.L	D2,#H'10000*8+3	COMP.W	(A2)+OADHFREQ,#ADFREQ/8	JUMP',EQ MEM1$	COMP.W	(A2)+OADHFREQ,#MACFREQ	JUMP,EQ MAC$	JUMP	SAME$; Dcodage d'un son dont la frquence est multiple de 35'000 KHz.MEM1$:	TEST.W	D2	JUMP,EQ SAME$	LOAD.L	D4,(A2)+OADHLG	SL.L	D4,D2	ADD.L	D4,#LADH	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP,NE EXIT$	LOAD.L	A3,A4	LOAD.L	A1,A2;	LOAD.L	A4,A3	LOAD.W	D3,#(LADH/2)-1XHEAD$:	LOAD.W	(A4+),(A1+)	DECJ.W,NMO D3,XHEAD$	LOAD.L	D3,(A3)+OADHLG	SL.L	D3,D2	LOAD.L	(A3)+OADHLG,D3	SUB.L	D4,#LADH	SR.L	D4,D2XDATA$:	LOAD.B	D0,(A1+)	LOAD.L	D1,D2	SWAP.W	D1		; D1 <-- 1, 2, 4 ou 8XREP$:	LOAD.B	(A4+),D0	DEC.W	D1	JUMP,NE XREP$	DEC.L	D4	JUMP,NE XDATA$	JUMP	OK$; Dcodage d'un son dont la frquence est de 22'000 KHz.MAC$:	LOAD.L	D4,(A2)+OADHLG	CALL	CONV5TO8	ADD.L	D4,#LADH	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP,NE EXIT$	LOAD.L	A3,A4	LOAD.L	A1,A2;	LOAD.L	A4,A3	LOAD.W	D3,#(LADH/2)-1MXHEAD$:	LOAD.W	(A4+),(A1+)	DECJ.W,NMO D3,MXHEAD$	LOAD.L	D4,(A3)+OADHLG	CALL	CONV5TO8	LOAD.L	(A3)+OADHLG,D4	SR.L	D4,#3MXDATA$:	LOAD.B	(A4+),(A1+)	LOAD.B	D0,(A1+)	LOAD.B	(A4+),D0	LOAD.B	(A4+),D0	LOAD.B	(A4+),(A1+)	LOAD.B	D0,(A1+)	LOAD.B	(A4+),D0	LOAD.B	(A4+),D0	LOAD.B	D0,(A1+)	LOAD.B	(A4+),D0	LOAD.B	(A4+),D0	DEC.L	D4	JUMP,NE MXDATA$	JUMP'	OK$SAME$:	LOAD.L	A3,A2		; A3 <-- son dcod = son cod !OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A1,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOCODE  >;========/; Code un son.; in	A4.L	^en-tte + son (dcod); out	A3.L	^en-tte + son (cod);	D7.W	erreur; mod	D7.W, A3.LIOCODE:	PUSHM.L	D0..D4,A1,A2,A4,A5	LOAD.L	A2,A4		; A2 <-- ^son dcod	LOAD.L	D2,#H'10000*1+0	COMP.W	(A2)+OADHFREQ,#ADFREQ	JUMP',EQ MEM1$	LOAD.L	D2,#H'10000*2+1	COMP.W	(A2)+OADHFREQ,#ADFREQ/2	JUMP',EQ MEM1$	LOAD.L	D2,#H'10000*4+2	COMP.W	(A2)+OADHFREQ,#ADFREQ/4	JUMP',EQ MEM1$	LOAD.L	D2,#H'10000*8+3	COMP.W	(A2)+OADHFREQ,#ADFREQ/8	JUMP',EQ MEM1$	COMP.W	(A2)+OADHFREQ,#MACFREQ	JUMP,EQ MAC$	JUMP	SAME$; Codage d'un son dont la frquence est multiple de 35'000 KHz.MEM1$:	TEST.W	D2	JUMP,EQ SAME$	LOAD.L	D4,(A2)+OADHLG	SR.L	D4,D2	ADD.L	D4,#LADH	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP,NE EXIT$	LOAD.L	A3,A4	LOAD.L	A1,A2;	LOAD.L	A4,A3	LOAD.W	D3,#(LADH/2)-1XHEAD$:	LOAD.W	(A4+),(A1+)	DECJ.W,NMO D3,XHEAD$	LOAD.L	D3,(A3)+OADHLG	SR.L	D3,D2	LOAD.L	(A3)+OADHLG,D3	SUB.L	D4,#LADHXDATA$:	LOAD.L	D1,D2	SWAP.W	D1		; D1 <-- 2 ou 4	CLR.L	D0XSUM$:	CLR.L	D3	LOAD.B	D3,(A1+)	ADD.L	D0,D3		; D0 <-- somme des chantillons	DEC.W	D1	JUMP,NE XSUM$	SR.L	D0,D2		; D0 <-- moyenne des chantillons	LOAD.B	(A4+),D0	DEC.L	D4	JUMP,NE XDATA$	JUMP	OK$; Codage d'un son dont la frquence est de 22'000 KHz.MAC$:	LOAD.L	D4,(A2)+OADHLG	CALL	CONV8TO5	ADD.L	D4,#LADH	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP,NE EXIT$	LOAD.L	A3,A4	LOAD.L	A1,A2;	LOAD.L	A4,A3	LOAD.W	D3,#(LADH/2)-1MXHEAD$:	LOAD.W	(A4+),(A1+)	DECJ.W,NMO D3,MXHEAD$	LOAD.L	D4,(A3)+OADHLG	CALL	CONV8TO5	LOAD.L	(A3)+OADHLG,D4	LOAD.L	D0,D4	CLR.L	D1	LOAD.L	D2,#5	CALL	INTDIV32	LOAD.L	D4,D3		; D4 <-- /5MXDATA$:	LOAD.B	(A4+),(A1+)	LOAD.B	(A4+),(A1+)	INC.L	A1	LOAD.B	(A4+),(A1+)	LOAD.B	(A4+),(A1+)	INC.L	A1	LOAD.B	(A4+),(A1+)	INC.L	A1	DEC.L	D4	JUMP,NE MXDATA$	JUMP'	OK$SAME$:	LOAD.L	A3,A2		; A3 <-- son cod = son dcod !OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A1,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; IOCODELG >;=========/; Modifie les temps en fonction du codage.; in	A4.L	^en-tte + son (cod);	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	D1.L	temps dbut [e];	D2.L	temps fin   [e]; mod	D1.L, D2.L, D7.WIOCODELG:	PUSHM.L	D3	CLR.W	D3		; D3 <-- /1	COMP.W	(A4)+OADHFREQ,#ADFREQ	JUMP',EQ CODE$	LOAD.W	D3,#1		; D3 <-- /2	COMP.W	(A4)+OADHFREQ,#ADFREQ/2	JUMP',EQ CODE$	LOAD.W	D3,#2		; D3 <-- /4	COMP.W	(A4)+OADHFREQ,#ADFREQ/4	JUMP',EQ CODE$	LOAD.W	D3,#3		; D3 <-- /8	COMP.W	(A4)+OADHFREQ,#ADFREQ/8	JUMP',EQ CODE$	COMP.W	(A4)+OADHFREQ,#MACFREQ	JUMP',EQ MAC$	JUMP'	EXIT$CODE$:	TEST.W	D3	JUMP',EQ EXIT$	SR.L	D1,D3	SR.L	D2,D3	JUMP'	EXIT$MAC$:	EX.L	D4,D1	CALL	CONV8TO5	EX.L	D1,D4	EX.L	D4,D2	CALL	CONV8TO5	EX.L	D2,D4EXIT$:	POPM.L	D3	RETNPAUDIO:.ASCIZ	"#AUDIO:"	.EVEN	.END