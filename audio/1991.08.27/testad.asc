	.TITLE	TESTAD.ASC	.PROC	M680002	.REF	SMAKYSM100ADMUBUS =	H'FFFF8000SM324ADMUBUS =	H'FFFFA800SM300ADMUBUS =	H'01000000MADSTART =	H'20MADREAD	=	H'20	.LOC	0LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VARLOOP$:	LOAD.B	SM324ADMUBUS+MADSTART,D4	LOAD.B	D4,SM324ADMUBUS+MADREAD	LIB	?AFX2	LIB	?AFSPACE	LIB	?IFCAR	JUMP,NE LOOP$	EXITVAR:	.FILLB	LGVAR,0	.END	START