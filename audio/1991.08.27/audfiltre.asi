	.SBTTL	AUDFILTRE.ASI;----------\\; FILAMORCE >;==========/; Ajoute un morceau de silence dans un son.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	A4.L	^en-tte + son;	D7.W	erreur; mod	D7.W, A4.LFILAMORCE:	PUSHM.L	D0..D4,A1..A3,A5	COMP.L	D1,D2	JUMP,EQ OK$	LOAD.L	A2,A4		; A2 <-- ^en-tte + son	LOAD.L	D0,D1	LOAD.L	D4,(A2)+OADHLG	ADD.L	D4,#LADH	ADD.L	D4,D2	SUB.L	D4,D0	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouvelle mmoire	JUMP,NE EXIT$	LOAD.L	A1,A2	LOAD.L	A5,A4	LOAD.L	D4,D0	ADD.L	D4,#LADHXFER1$:	LOAD.B	(A5+),(A1+)	; nouveau <-- dbut	DEC.L	D4	JUMP,NE XFER1$	LOAD.L	D4,D2	SUB.L	D4,D0	LOAD.B	D3,#ADNIVZEROXFER2$:	LOAD.B	(A5+),D3	; nouveau <-- silence	DEC.L	D4	JUMP,NE XFER2$	LOAD.L	D4,(A2)+OADHLG	SUB.L	D4,D0	JUMP',EQ XEND$XFER3$:	LOAD.B	(A5+),(A1+)	; nouveau <-- fin	DEC.L	D4	JUMP,NE XFER3$XEND$:	ADD.L	(A4)+OADHLG,D2	SUB.L	(A4)+OADHLG,D0	LOAD.L	D1,D0	LOAD.W	(A6)+OUNOP,#OPUNDEL	CALL	VISUCOPY	; indique ce qui a t ajout	EX.L	A2,A4	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancien son	LOAD.L	A3,#(A6)+OPSONSRC$:	COMP.L	A4,(A3+)	JUMP,NE SRC$	LOAD.L	(A3)-4,A2OK$:	CLR.W	D7		; D7 <-- okEXIT$:	LOAD.L	A4,A2		; A4 <-- ^nouveau son	POPM.L	D0..D4,A1..A3,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; FILSILENCE >;===========/; Rduit au silence une partie du signal.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	-; mod	D7.WFILSILENCE:	PUSHM.L	D2,D3,A3	CALL	WAITMOUSE	; met le sablier	LOAD.W	(A6)+OUNOP,#OPUNREPL	CALL	VISUCOPY	; copie ce qui sera modifi	LOAD.L	A3,#(A4)+(D1.L)+LADH	SUB.L	D2,D1		; D2 <-- Tf-Td	LOAD.B	D3,#ADNIVZEROLOOP$:	LOAD.B	(A3+),D3	; signal <-- niveau "zro"	DEC.L	D2	JUMP,NE LOOP$	POPM.L	D2,D3,A3	RET;----------\\; FILVOLUME >;==========/; Modifie le volume d'une partie du signal.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	-; mod	D7.WFILVOLUME:	PUSHM.L	D0..D6,A3	CALL	WAITMOUSE	; met le sablier	LOAD.W	(A6)+OUNOP,#OPUNREPL	CALL	VISUCOPY	; copie ce qui sera modifi	LOAD.L	A3,#(A4)+(D1.L)+LADH	SUB.L	D2,D1		; D2 <-- Tf-Td	LOAD.L	D0,D2		; D0 <-- dcompteur	CLR.W	D1		; D1 <-- n	LOAD.W	D5,#10		; D5 <-- #10	COMP.L	D2,#2^24	JUMP',HS GO$	DEC.W	D5		; D5 <-- #9	COMP.L	D2,#2^23	JUMP',HS GO$	DEC.W	D5		; D5 <-- #8	COMP.L	D2,#2^22	JUMP',HS GO$	DEC.W	D5		; D5 <-- #7	COMP.L	D2,#2^21	JUMP',HS GO$	DEC.W	D5		; D5 <-- #6	COMP.L	D2,#2^20	JUMP',HS GO$	DEC.W	D5		; D5 <-- #5	COMP.L	D2,#2^19	JUMP',HS GO$	DEC.W	D5		; D5 <-- #4	COMP.L	D2,#2^18	JUMP',HS GO$	DEC.W	D5		; D5 <-- #3	COMP.L	D2,#2^17	JUMP',HS GO$	DEC.W	D5		; D5 <-- #2	COMP.L	D2,#2^16	JUMP',HS GO$	DEC.W	D5		; D5 <-- #1	COMP.L	D2,#2^15	JUMP',HS GO$	DEC.W	D5		; D5 <-- #0GO$:	SR.L	D2,D5		; D2 <-- toujours < 2^16 !	LOAD.W	D6,#1	SL.W	D6,D5		; D6 <-- compteur (1,2,4,8,16,etc.)	LOAD.W	D5,D6LOOP$:	LOAD.W	D3,(A6)+OVOFIN	SUB.W	D3,(A6)+OVODEB	MUL.WA	D3,D1	DIV.WA	D3,D2	ADD.W	D3,(A6)+OVODEB	; D3 <-- facteur en %	CLR.W	D4	LOAD.B	D4,(A3)	SUB.W	D4,#ADNIVZERO	; D4 <-- +/- amplitude	MUL.WA	D4,D3	DIV.WA	D4,#100	ADD.W	D4,#ADNIVZERO	; D4 <-- amplitude "recentre"	JUMP',NC MIN$	CLR.W	D4MIN$:	COMP.W	D4,#ADNIVMAX	JUMP',LS MAX$	LOAD.W	D4,#ADNIVMAXMAX$:	LOAD.B	(A3+),D4	DEC.W	D5	JUMP',NE NEXT$	LOAD.W	D5,D6	INC.W	D1		; D1 <-- n+1NEXT$:	DEC.L	D0	JUMP,NE LOOP$	POPM.L	D0..D6,A3	RET;---------\\; FILBRUIT >;=========/; Supprime le bruit d'une partie du signal.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	-; mod	D7.WFILBRUIT:	PUSHM.L	D0..D5,A2,A3	CALL	WAITMOUSE	; met le sablier	LOAD.L	D4,D2	SUB.L	D4,D1	COMP.L	D4,#50000	JUMP',LO OPEN$	CALL	WAITDBOX	; met la dbox d'attenteOPEN$:	LOAD.W	(A6)+OUNOP,#OPUNREPL	CALL	VISUCOPY	; copie ce qui sera modifi	LOAD.L	A3,#(A4)+(D1.L)+LADH	LOAD.L	A2,A3	SUB.L	D2,D1		; D2 <-- Tf-Td	LOAD.W	D5,(A6)+OBRLEV	; D5 <-- seuil du bruitLOOP$:	TEST.L	(A6)+OOPCDB	JUMP',EQ AFFN$	LOAD.L	D0,D2	AND.W	D0,#B'1111	JUMP',NE AFFN$	LOAD.L	D0,D2	SR.L	D0,#4	CALL	AFFNDBOX	; avance la dbox d'attenteAFFN$:	LOAD.L	D0,(A6)+OBRPER	JUMP',NE PER$	INC.L	D0PER$:	ADD.L	D0,A3	SUB.L	D0,A2		; D0 <-- diminue selon l'avance de A2	LOAD.L	D4,(A4)+OADHLG	SUB.L	D4,D1		; D4 <-- dure maximale	COMP.L	D0,D4	JUMP',LS SRC$	LOAD.L	D0,D4SRC$:	CLR.W	D4	LOAD.B	D4,(A2)	SUB.W	D4,#ADNIVZERO	; D4 <-- +/- amplitude	JUMP',NC POS$	NEG.W	D4		; D4 <-- |amplitude|POS$:	COMP.W	D4,D5		; dpasse le seuil du bruit ?	JUMP',HI NEXT$		; oui => NEXT$	INC.L	A2	DEC.L	D0	JUMP,NE SRC$	LOAD.B	(A3),#ADNIVZERONEXT$:	INC.L	A3		; A3 <-- ^chantillon suivant	COMP.L	A2,A3		; est-ce que A2 s'est fait dpass ?	JUMP',HS A2OK$		; non => A2OK$	LOAD.L	A2,A3		; A2 <-- avance au moins jusqu' A3A2OK$:	INC.L	D1	DEC.L	D2	JUMP,NE LOOP$	CALL	NORMDBOX	; enlve la dbox d'attente	POPM.L	D0..D5,A2,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; FILECHO >;========/; Ajoute de l'cho dans une partie du signal.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	A4.L	^en-tte + son; mod	D7.W, A4.LFILECHO:	PUSHM.L	D0..D6,A1..A3,A5	CALL	WAITMOUSE	; met le sablier; Calcule tous les niveaux (jusqu' l'extinction complte); et la longueur maximale  ajouter aprs la fin de la; partie slectionne (jusqu' extinction de l'cho).	LOAD.L	A5,#(A6)+OBUDIS	CALL	FILECHOLEV	; OBUDIS <-- niveaux	MUL.WU	D4,(A6)+OECPER+2	LOAD.L	D5,D4		; D5 <-- Ls (longueur supplmentaire); Ouvre un buffer temporaire d'une longueur de (Tf-Td)+Ls.	LOAD.L	D4,D2	SUB.L	D4,D1	ADD.L	D4,D5	CALL	FILOPTEMP	; A2 <-- ^buffer temporaire	JUMP,NE EXIT$	LOAD.L	D4,D2	SUB.L	D4,D1	ADD.L	D4,D5	COMP.L	D4,#50000	JUMP',LO OPEN$	CALL	WAITDBOX	; met la dbox d'attenteOPEN$:	LOAD.W	(A6)+OUNOP,#OPUNALL	CALL	VISUCOPY	; copie ce qui sera modifi; Pour chaque chantillon, calcule les valeurs correspondantes; dans le buffer temporaire.	PUSHM.L	D1,D2	LOAD.L	A1,A2	LOAD.L	A3,#(A4)+(D1.L)+LADH	SUB.L	D2,D1		; D2 <-- Tf-Td	LOAD.L	D0,D2		; D0 <-- dcompteurLOOP$:	TEST.L	(A6)+OOPCDB	JUMP',EQ AFFN$	LOAD.L	D4,D0	AND.W	D4,#B'1111	JUMP',NE AFFN$	PUSH.L	D0	SR.L	D0,#4	CALL	AFFNDBOX	; avance la dbox d'attente	POP.L	D0AFFN$:	CLR.W	D4	LOAD.B	D4,(A3)	SUB.W	D4,#ADNIVZERO	; D4 <-- +/- amplitude initiale	LOAD.L	A5,#(A6)+OBUDIS	; A5 <-- ^niveaux	CLR.L	D3		; D3 <-- T'TLOOP$:	LOAD.W	D2,(A5+)	; D2 <-- niveau	JUMP',EQ NEXT$	LOAD.W	D1,D4		; D1 <-- amplitude initiale	MUL.WA	D1,D2	DIV.WA	D1,#100	CALL	FILADTEMP	; buffer temporaire <-- ajoute valeur	ADD.L	D3,(A6)+OECPER	; D3 <-- T' suivant	JUMP	TLOOP$NEXT$:	INC.L	A3	INC.L	A1	DEC.L	D0	JUMP,NE LOOP$	POPM.L	D1,D2; Ajoute  la fin du buffer temporaire les chantillons originaux.	PUSHM.L	D1,D2	LOAD.L	D4,D5	LOAD.L	D3,(A4)+OADHLG	SUB.L	D3,D2	COMP.L	D4,D3	JUMP',LS LGO$	LOAD.L	D4,D3LGO$:	TEST.L	D4	JUMP',EQ LEND$LLOOP$:	CLR.W	D1	LOAD.B	D1,(A3)	SUB.W	D1,#ADNIVZERO	; D1 <-- +/- amplitude	CLR.L	D3	CALL	FILADTEMP	; buffer temporaire <-- ajoute valeur	INC.L	A3	INC.L	A1	DEC.L	D4	JUMP,NE LLOOP$LEND$:	POPM.L	D1,D2; Ignore les chantillons nuls  la fin du buffer temporaire.	LOAD.L	A1,A2	ADD.L	A1,D2	SUB.L	A1,D1	ADD.L	A1,D5ZLOOP$:	COMP.B	(-A1),#ADNIVZERO	JUMP',NE INS$	DEC.L	D5	JUMP,NE ZLOOP$; Insre le buffer temporaire dans le son principal.INS$:	PUSH.L	D2	ADD.L	D2,D5	COMP.L	D2,(A4)+OADHLG	JUMP',LS DEL$	LOAD.L	D2,(A4)+OADHLGDEL$:	CALL	VISUDELETE	; supprime la partie sans cho	POP.L	D2	ADD.L	D2,D5	LOAD.L	A3,A2	CALL	VISUINSERT	; insre la partie avec choCLOSE$:	PUSH.W	D7	CALL	NORMDBOX	; enlve la dbox d'attente	CALL	FILCLTEMP	; libre le buffer temporaire	POP.W	D7EXIT$:	POPM.L	D0..D6,A1..A3,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; FILECHOLEV >;-----------/; Prpare tous les niveaux intermdiaires (100..0%).; in	A5.L	^buffer; out	(A5)++	niveaux 100..0 (.W);	D4.W	nb de niveaux (0..n); mod	D4.L, D7.WFILECHOLEV:	PUSHM.L	D2,D3,A5	LOAD.W	D3,#100		; D3 <-- niveau initial	LOAD.W	D2,D3	SUB.W	D2,(A6)+OECRAT	; D2 <-- perte	CLR.W	D4LOOP$:	LOAD.W	(A5+),D3	; buffer <-- niveau	INC.W	D4		; D4 <-- un niveau de plus	SUB.W	D3,D2		; D3 <-- nouveau niveau (plus faible)	JUMP,GT LOOP$	CLR.W	(A5)		; buffer <-- terminateur	POPM.L	D2,D3,A5	RET;--------\\; FILFREQ >;========/; Modifie la frquence d'une partie du signal.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	A4.L	^en-tte + son; mod	D7.W, A4.LFILFREQ:	PUSHM.L	D0..D6,A1..A3,A5	CALL	WAITMOUSE	; met le sablier; Calcule la nouvelle longueur du buffer temporaire Ln.	LOAD.L	D4,D2	SUB.L	D4,D1		; D4 <-- La (longueur actuelle)	LOAD.W	D3,#8	COMP.L	D4,#2^22	JUMP',HS LFAC$	LOAD.W	D3,#7	COMP.L	D4,#2^21	JUMP',HS LFAC$	LOAD.W	D3,#6	COMP.L	D4,#2^20	JUMP',HS LFAC$	LOAD.W	D3,#5	COMP.L	D4,#2^19	JUMP',HS LFAC$	LOAD.W	D3,#4	COMP.L	D4,#2^18	JUMP',HS LFAC$	LOAD.W	D3,#3	COMP.L	D4,#2^17	JUMP',HS LFAC$	LOAD.W	D3,#2	COMP.L	D4,#2^16	JUMP',HS LFAC$	LOAD.W	D3,#1	COMP.L	D4,#2^15	JUMP',HS LFAC$	CLR.W	D3LFAC$:	LOAD.W	D5,(A6)+OFRFAC	JUMP',NS LGRAVE$LAIGU$:	NEG.W	D5		; D5 <-- 0..-100	ADD.W	D5,#200		; D5 <-- 200..100	SR.L	D4,D3	MUL.WU	D5,D4	DIV.WU	D5,#200		; D5 <-- (La*FAC)/200	AND.L	D5,#H'FFFF	SL.L	D5,D3		; D5 <-- Ln	JUMP'	OPEN$LGRAVE$:	NEG.W	D5		; D5 <-- 0..100	ADD.W	D5,#100		; D5 <-- 100..200	SR.L	D4,D3	MUL.WU	D5,D4	DIV.WU	D5,#100		; D5 <-- (La*FAC)/100	AND.L	D5,#H'FFFF	SL.L	D5,D3		; D5 <-- Ln; Ouvre un buffer temporaire d'une longueur de Ln.OPEN$:	LOAD.L	D4,D5	CALL	FILOPTEMP	; A2 <-- ^buffer temporaire	JUMP,NE EXIT$	LOAD.W	(A6)+OUNOP,#OPUNALL	CALL	VISUCOPY	; copie ce qui sera modifi	LOAD.L	A1,A2	LOAD.L	A3,#(A4)+(D1.L)+LADH	LOAD.L	D3,D2	SUB.L	D3,D1		; D3 <-- La; Calcule la longueur D3P en fonction de la pente de croissance.; D3P est toujours plus petit ou gal  D3 !	PUSHM.L	D1..D3	CLR.L	D2	LOAD.W	D2,(A6)+OFRPEN	JUMP',NC PPOS$	NEG.W	D2PPOS$:	CALL	INTMUL32	; D1D0 <-- PEN*D3	LOAD.L	D2,#200	CALL	INTDIV32	; D3 <-- D1D0/200	LOAD.L	D6,D3		; D6 <-- D3P selon PEN	POPM.L	D1..D3	COMP.L	D3,#H'FFFF	; valeur La sur 16 bits ?	JUMP,HI BIG$		; non => BIG$	COMP.L	D5,#H'FFFF	; valeur Ln sur 16 bits ?	JUMP,HI BIG$		; non => BIG$	PUSHM.L	D1,D2	CLR.L	D4		; D4 <-- compteurQLOOP$:	PUSH.L	D3	TEST.W	(A6)+OFRPEN	JUMP,EQ QFAC$	JUMP',NS QNPEN$	LOAD.W	D0,D3	LOAD.W	D3,D6		; D3 <-- D3P (D3 selon PEN)	MUL.WU	D3,D4	DIV.WU	D3,D5		; D3 <-- d	ADD.W	D3,D0	SUB.W	D3,D6	JUMP'	QFAC$QNPEN$:	LOAD.W	D0,D3	LOAD.L	D3,D6	LOAD.W	D2,D5	SUB.W	D2,D4	MUL.WU	D3,D2	DIV.WU	D3,D5		; D3 <-- d	ADD.W	D3,D0	SUB.W	D3,D6QFAC$:	MUL.WU	D3,D4	DIV.WU	D3,D5	AND.L	D3,#H'FFFF	LOAD.B	(A1+),(A3)+(D3.L)	POP.L	D3	INC.W	D4	COMP.W	D4,D5	JUMP,LO QLOOP$	POPM.L	D1,D2	JUMP	INS$BIG$:	PUSHM.L	D1,D2	CALL	WAITDBOX	; met la dbox d'attente	CLR.L	D4		; D4 <-- compteur	LOAD.L	D2,D5		; D2 <-- dcompteur (pour dbox d'attente)BLOOP$:	PUSHM.L	D2..D4	LOAD.L	D0,D2	AND.W	D0,#B'1111	JUMP',NE AFFN$	LOAD.L	D0,D2	SR.L	D0,#4	CALL	AFFNDBOX	; avance la dbox d'attenteAFFN$:	TEST.W	(A6)+OFRPEN	JUMP,EQ BFAC$	JUMP',NS BNPEN$	LOAD.L	D0,D3	PUSHM.L	D0,D4	LOAD.L	D3,D6		; D3 <-- D3P (D3 selon PEN)	LOAD.L	D2,D4	CALL	INTMUL32	LOAD.L	D2,D5	CALL	INTDIV32	; D3 <-- d	POPM.L	D0,D4	ADD.L	D3,D0	SUB.L	D3,D6	JUMP'	BFAC$BNPEN$:	LOAD.L	D0,D3	PUSHM.L	D0,D4	LOAD.L	D3,D6		; D3 <-- D3P (D3 selon PEN)	LOAD.L	D2,D5	SUB.L	D2,D4	CALL	INTMUL32	LOAD.L	D2,D5	CALL	INTDIV32	; D3 <-- d	POPM.L	D0,D4	ADD.L	D3,D0	SUB.L	D3,D6BFAC$:	LOAD.L	D2,D4	CALL	INTMUL32	; D0D1 <-- compteur*La	LOAD.L	D2,D5	CALL	INTDIV32	; D3/D4 <-- division/reste	LOAD.B	(A1+),(A3)+(D3.L)	POPM.L	D2..D4	DEC.L	D2	INC.L	D4	COMP.L	D4,D5	JUMP,LO BLOOP$	POPM.L	D1,D2	CALL	NORMDBOX	; enlve la dbox d'attente; Insre le buffer temporaire dans le son principal.INS$:	CALL	VISUDELETE	; supprime la partie originale	LOAD.L	D2,D1	ADD.L	D2,D5	LOAD.L	A3,A2	CALL	VISUINSERT	; insre la partie modifieCLOSE$:	PUSH.W	D7	CALL	FILCLTEMP	; libre le buffer temporaire	POP.W	D7EXIT$:	POPM.L	D0..D6,A1..A3,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; FILREVERSE >;===========/; Inverse une partie du signal.; in	A4.L	^en-tte + son;	D1.L	temps dbut [e];	D2.L	temps fin   [e]; out	-; mod	D7.WFILREVERSE:	PUSHM.L	D1,D2,A2,A3	CALL	WAITMOUSE	; met le sablier	LOAD.W	(A6)+OUNOP,#OPUNREPL	CALL	VISUCOPY	; copie ce qui sera modifi	SUB.L	D2,D1		; D2 <-- dure	LOAD.L	A3,#(A4)+(D1.L)+LADH	LOAD.L	A2,#(A3)+(D2.L)	SR.L	D2,#1	JUMP',EQ EXIT$LOOP$:	LOAD.B	D1,(A3)	LOAD.B	(A3+),(-A2)	LOAD.B	(A2),D1	DEC.L	D2	JUMP,NE LOOP$EXIT$:	POPM.L	D1,D2,A2,A3	RET;----------\\; FILADTEMP >;----------/; Ajoute une valeur dans le buffer temporaire.; in	A1.L	^dans buffer temporaire;	D3.L	offset;	D1.W	valeur  ajouter; out	-; mod	D7.WFILADTEMP:	PUSH.W	D4	CLR.W	D4	LOAD.B	D4,(A1)+(D3.L)	SUB.W	D4,#ADNIVZERO	; D4 <-- +/- amplitude	ADD.W	D4,D1	ADD.W	D4,#ADNIVZERO	; D4 <-- amplitude "recentre"	JUMP',NC MIN$	CLR.W	D4MIN$:	COMP.W	D4,#ADNIVMAX	JUMP',LS MAX$	LOAD.W	D4,#ADNIVMAXMAX$:	LOAD.B	(A1)+(D3.L),D4	POP.W	D4	RET;----------\\; FILOPTEMP >;----------/; Rserve le buffer temporaire.; in	D4.L	longueur; out	A2.L	^buffer temporaire;	D7.W	erreur; mod	D7.W, A2.LFILOPTEMP:	PUSHM.L	D1,D4,A4	ADD.L	D4,#100		; D4 <-- rserve !	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP',NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^buffer temporaire	LOAD.W	D1,#ADNIVZEROLOOP$:	LOAD.B	(A4+),D1	; met partout le niveau zro	DEC.L	D4	JUMP,NE LOOP$EXIT$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; FILCLTEMP >;----------/; Libre le buffer temporaire.; in	A2.L	^buffer temporaire; out	-; mod	D7.WFILCLTEMP:	PUSHM.L	D1,A4	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	POPM.L	D1,A4	RET	.END