	.TITLE	AUDIO.ASD;	---------------------------------;	 Source du pilote 300_AUDIO.DRIV;	---------------------------------	.PROC	M68030F	.REF	SMAKY	.REF	SHIDRIV300	.REF	INDROM300	.REF	SM300HARD	.REF	BIOSDRIV	.REF	AUDIO;	Date		Amliorations; --------------------------------------------------------------------------; 0.1	30.10.90	premire versionMAJREV	=	0		; rvisionMINREV	=	1		; version	.REV	MAJREV,MINREV; Constantes; ----------NiveauZero =	128		; niveau moyen; Variables; ---------oSonSemInt:	.BLK.32	1		; smaphore avertissant qu'une liste					; de buffers de son a t joueoSonPoiBu:	.BLK.32	1		; pointeur d'critureoSonEnCours:	.BLK.8	1		; marque du dbut		.EVENoSonListeA:	.BLK.32	(SonNbPage/2)+1	; liste pour un demi bufferoSonListeB:	.BLK.32	(SonNbPage/2)+1oSonBuffer:	.BLK.8	SonNbPage*SonLgPageoSonRel:	.BLK.8	NiveauZro	; pour le retour  zroLgVar:	.LOC	0DEBUT:	.16	0,S0BASE	.16	2**7; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;			DRIVER $AUDIO_0		No 16'4F; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=S0ID:	.16	S0OPEN-S0BASE	.16	S0COMMAND-S0BASE	.16	-1			; S0RSTATUS-S0BASE	.16	-1			; S0READ-S0BASE	.16	S0WRITE-S0BASE	.16	S0CLOSE-S0BASE	.16	-1			; STOPTR	.16	-1			; STARTR	.16	-1			; AVORTTR	.16	-1			; S0AUX1-S0BASE	.16	-1			; S0AUX2-S0BASE	.16	S0RESET-S0BASE	.16	S0KILL-S0BASE	.16	-1			; S0STRT-S0BASE	.16	-1			; S0TSTRT-S0BASE	.16	-1			; S0START-S0BASES0NAB:	.ASCII	"AUDIO_0"		; nom driverS0NAF:	.FILL.8	LGDNAM-(S0NAF-S0NAB),0	.8	16'4F			; numro driver	.8	TYPIO			; type streamer	.8	MAJREV,MINREV		; rvision - version	.8	0			; priorit	.8	0			; rserve	.8	0			; attribut 1	.8	2**BDWROK.OR.2**BDNORT	; attribut 0	.FILL.8	LGDDESC-(APC-S0ID),0	; le resteS0BASE:;--------\\; S0RESET >;========/; Initialisation du pilote.; in	-; out	A6.32	^variables globales;	D7.16	erreur; mod	D7.16, A6.32S0RESET:	PUSHM.32	D4|A4	MOVE.32		#R16^DEBUT,A4	MOVE.32		#LgVar,D4	FOS		?GETCOMMEM	JUMP,NE 	EXIT$	MOVE.32		A4,A6		; A6 <-- ^variables globalesEXIT$:	POPM.32		D4|A4	TEST.16		D7		; retour EQ/NE	RET;--------\\; S0OPEN  >;========/; ; in	A6.32	^variables globales; out	D7.16	erreur; mod	D7.16S0OPEN:	PUSHM.32	D4|A1|A4|A5	CLR.16		D4	NTREL		?CreSem			; cration du smaphore	JUMP,NE		EXIT$			; qui signale la fin des listes	MOVE.32		A5, {A6}+oSonSemInt	MOVE.32		#{A6}+oSonBuffer, A1	; dbut du buffer -->	MOVE.32		A1, {A6}+oSonPoiBu	; --> pointeur d'criture	MOVE.32		#{A6}+oSonBuffer, A1	; dbut du buffer	MOVE.32		#SonNbPage/2, D4	; nombre de pointeurs	MOVE.32		#{A6}+oSonListeA, A4FillA$:	MOVE.32		A1, {A4+}	ADD.32		#SonLgPage, A1	DEC.32		D4	JUMP,NE		FillA$	CLR.32		{A4}			; terminateur de liste	MOVE.32		#SonNbPage/2, D4	; nombre de pointeurs	MOVE.32		#{A6}+oSonListeB, A4FillB$:	MOVE.32		A1, {A4+}	ADD.32		#SonLgPage, A1	DEC.32		D4	JUMP,NE		FillB$	CLR.32		{A4}			; terminateur de liste	CLR.8		{A6}+oSonEnCours	; dbut	MOVE.32		#R16^IntSon, A1	CALL		{_IndShi}+_InitIntSonExit$:	POPM.32		D4|A1|A4|A5	TEST.16		D7	RET; Routine d'interruption  la fin d'une liste :IntSon:	MOVE.32		{A0}+oSonSemInt, A1	CALL		A16^_ISIGNEV	RET;--------\\; S0WRITE >;========/; Lance un son.; in	A6.32	^variables globales;	A4.32	^chantillons 8 bits;	D5.32	nombre d'chantillons; out	D7.16	erreur; mod	D7.16S0WRITE:	PUSHM.32	D1..D5|A2..A5	MOVE.32		A4, A2			; A2.32 <-- ^data	CLR.32		D2			; premier demi-buffer ?	MOVE.32		{A6}+oSonPoiBu, A3	; pointeur d'criture	MOVE.32		#{A6}+oSonBuffer+(SonLgPage*SonNbPage/2), A5 ; demi-buffer	COMP.32		A5, A3	JUMP,LO 	Demi$	ADD.32		#SonLgPage*SonNbPage/2, A5	INC.32		D2			; second buffer !Demi$:	MOVE.32		A5, D3	SUB.32		A3, D3			; D3.32 <-- reste du demi-bufferCopie$:	MOVE.8		{A2+}, {A3+}		; copie un chantillon	DEC.32		D3			; fin d'un demi buffer ?	JUMP,NE		Suiv$						; --> demi-buffer atteint !	TEST.8		{A6}+oSonEnCours	JUMP,EQ		Done$			; pas d'attente la 1re fois	CALL		WaitAudio		; attend la fin du demi buffer prcdentDone$:	MOVE.8		#1, {A6}+oSonEnCours	TEST.32		D2			; premier demi-buffer ?	JUMP,NE		Second$	MOVE.32		#{A6}+oSonListeA, A4	; on transmet le ^  la liste	INC.32		D2			; le suivant est le second	JUMP		Joue$Second$:	CLR.32		D2	MOVE.32		#{A6}+oSonBuffer, A3	; on reprend au dbut	MOVE.32		A3, {A6}+oSonPoiBu	MOVE.32		#{A6}+oSonListeB, A4	; on transmet le ^  la listeJoue$:	MOVE.32		A4, VideoSoundFirst	; MUSIQUE !	MOVE.32		#SonLgPage*SonNbPage/2, D3 ; suite...Suiv$:	DEC.32		D5			; chantillon suivant	JUMP,NE		Copie$	MOVE.32		A3, {A6}+oSonPoiBu	; pointeur pour la prochaine fois	CLR.16		D7Exit$:	POPM.32		D1..D5|A2..A5	TEST.16		D7	RET;----------\\; WaitAudio >;----------/; Attend l'excution de la liste prcdente.; In	A6.32	canal (^variables); out	D7.16	erreur; mod	D7.16;WaitAudio:	PUSHM.32	A5	MOVE.32		{A6}+oSonSemInt, A5	NTREL		?WAITEV	POPM.32		A5	RET;--------\\; S0CLOSE >;========/; Termine le son, attend sa fin et ferme tout.; in	A6.32	^variables globales; out	D7.16	erreur; mod	D7.16S0CLOSE:	PUSHM.32	D1..D2|A4..A5	TEST.8		{A6}+oSonEnCours	JUMP,EQ		Done1$	CALL		WaitAudio		; termine le sonDone1$:	MOVE.32		#{A6}+oSonListeB, A4	; seconde moiti ?	MOVE.32		{A6}+oSonPoiBu, A3	; pointeur d'criture	MOVE.32		#{A6}+oSonBuffer+(SonLgPage*SonNbPage/2), A5 ; milieu	COMP.32		A5, A3	JUMP,HS 	Demi$	SUB.32		#SonLgPage*SonNbPage/2, A5	MOVE.32		#{A6}+oSonListeA, A4	; liste A, premire moiti !Demi$:	MOVE.32		A3, D3	SUB.32		A5, D3			; D3.32 <-- solde du demi-buffer	JUMP,EQ		Done2$			; Plus rien ?	DIV.16		#SonLgPage, D3		; solde en page	MOVE.32		D3, D4	SWAP.32		D3			; D3.16 reste	TEST.16		D3			; dernire tranche vide ?	JUMP,EQ		FinListe$	INC.32		D4			; il fautra envoyer la dernire !Zero$:	MOVE.8		#NiveauZero, {A3+}	INC.16		D3	COMP.16		#SonLgPage, D3	JUMP,NE		Zero$FinLi$:						; termine la liste	AND.32		#H'FFFF, D4		; nombre de tranches	MUL.32		#4, D4			; en .32	MOVE.32		A4, A5	ADD.32		D4, A5			; pointeur de la dernire tranche	CLR.32		{A5}	MOVE.32		A4, VideoSoundFirst	; envoie liste {A6}!	MOVE.8		#1, {A6}+oSonEnCoursWait$:						; plus qu' attendre ...	TEST.8		{A6}+oSonEnCours	JUMP,EQ		Done2$	CALL		WaitAudio		; termine le sonDone2$:	MOVE.32		{A6}+oSonSemInt, A5	NTREL		?KILLSEM		; dtruit le smaphore	POPM.32		D1..D2|A4..A5	RET;------------\\; AUDIO_REL   >;============/;; Replace doucement le niveau "0" (H'80);; In	A6.32	^variables globales; Out	EQ : ok;	NE : D7.16 = erreur; Mod	D7.16;_AudioRel:	PUSHM.32	D3..D4|A4|A5	MOVE.32		{A6}+oSonPoiBu, A3	; pointeur d'criture	MOVE.32		#{A6}+oSonBuffer, A4	; dbut	COMP.32		A3, A4			; y est-on ?	JUMP,NE		Suite$	MOVE.32		#{A6}+oSonBuffer+(SonLgPage*SonNbPage), A3 ; finSuite$:	MOVE.8		{A3}-1, D3	SUB.8		#NiveauZero, {A3}-1	; dj  zro ?	JUMP,EQ		Ok$						; D3.8 contient la correction	MOVE.8		D3, D4			; D4.8 aussi	TEST.8		D4	JUMP,PL		Pos$	NEG.8		D4Pos$:	MOVE.32		#{A6}+oSonRel, A4Fill$:	TEST.8		D3	JUMP,PL		Plus$	INC.8		D3	INC.8		D3Plus$:	DEC.8		D3	MOVE.8		D3, {A4+}	JUMP,NE		Fill$	MOVE.32		#{A6}+oSonRel, A4	; dbut;;?	CALL		_PlayAudio		; "joue" le retour  zro	JUMP,NE		Exit$Ok$:	CLR.16		D7Exit$: 	POPM.32		D3..D4|A4|A5	RET;----------\\; S0COMMAND >;==========/; Excute une liste de commandes.; in	A6.32	^variables globales;	A4.32	^table des commandes termine par zro; out	D7.16	erreur; mod	D7.16S0COMMAND:	PUSHM.32	A4	CLR.16		D7		; D7 <-- okLOOP$:	TEST.8		{A4}		; fin de la table ?	JUMP,EQ		EXIT$		; oui => EXIT$	CALL		WRONEC		; excute une commande	JUMP,EQ		LOOP$EXIT$:	POPM.32		A4	TEST.16		D7		; retour EQ/NE	RET;--------\\; WRONEC  >;========/; Excute une commande.; in	A4.32	^commande; out	A4.32	^commande suivante;	D7.16	erreur; mod	D7.16, A4.32WRONEC:	PUSHM.32	D4	MOVE.8		{A4+},D4	; D4 <-- commande	COMP.8		#"L",D4	JUMP,EQ		LEVEL$	MOVE.16		#ERDIIL,D7	; D7 <-- "commande illgale"	JUMP		EXIT$LEVEL$:	MOVE.8		{A4+},D4	; D4 <-- volume (0..255)	CALL		COMVOLUME	; choix du volume	CLR.16		D7		; D7 <-- okEXIT$:	POPM.32		D4	TEST.16		D7		; retour EQ/NE	RET;----------\\; COMVOLUME >;----------/; Met le niveau gnral (0..3).; in	D4.8	niveau (0..255); out	-; mod	D7.16COMVOLUME:	COMP.8		#64*1, D4	JUMP,HS		V1$	MOVE.8		#0, ADMODESONFORT	MOVE.8		#0, ADMODESONMOY	JUMP		EXIT$V1$:	COMP.8		#64*2, D4	JUMP,HS		V2$	MOVE.8		#0, ADMODESONFORT	MOVE.8		#1, ADMODESONMOY	JUMP		EXIT$V2$:	COMP.8		#64*3, D4	JUMP,HS		V3$	MOVE.8		#1, ADMODESONFORT	MOVE.8		#0, ADMODESONMOY	JUMP		EXIT$V3$:;	COMP.8		#64*4, D4;	JUMP,HS		EXIT$	MOVE.8		#1, ADMODESONFORT	MOVE.8		#1, ADMODESONMOY;	JUMP		EXIT$EXIT$:	RET;--------\\; S0KILL  >;========/; Libration du pilote.; in	A6.32	^variables globales; out	D7.16	erreur; mod	D7.16, A6.32S0KILL:	CLR.16	D7		; retour EQ	RET	.END