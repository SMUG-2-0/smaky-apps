	.SBTTL	AUDCADRE.ASI;---------\\; DESCADRE >;=========/; Grise toute la fentre et place les icnes.; in	-; out	-; mod	D7.WDESCADRE:	PUSHM.L	D2..D4	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface toute la fentre	CALL	DESMDEF		; D4 <-- trame grise pour le fond	CALL	DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	; grise toute la fentre	CALL	INFOOPEN	; prpare l'affichage	PUSH.L	D4	LOAD.L	D4,#-1	CALL	DRMDEF	POP.L	D4	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LIB	?DRTRAME	; dessine une bande blanche en haut	CALL	INFOCLOSE	; termine l'affichage	CALL	DESINFO		; affiche les informations	POPM.L	D2..D4	RET;--------\\; DESMDEF >;========/; Dtermine la trame grise pour le fond.; in	-; out	D4.L	trame grise; mod	D4.L, D7.WDESMDEF:	LOAD.L	D4,#H'88882222	; D4 <-- trame pour cran entrelac	COMP.B	(A6)+OMACHINE,#SMAKY8	JUMP',EQ EXIT$	LOAD.L	D4,#H'88228822	; D4 <-- trame pour joli cranEXIT$:	RET;--------\\; DESINFO >;========/; Dessine les informations.; in	-; out	-; mod	D7.WDESINFO:	PUSHM.L	D3,D4,A3	CALL	INFOOPEN	; prpare l'affichage	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	AFINV		; vido inverse	.ASCII	" AUDIO "	.B	AUDREV+'0,'.	.IF	AUDVERS<10	.B	AUDVERS+'0	.ELSE	.B	(AUDVERS/10)+'0,(AUDVERS-((AUDVERS/10)*10))+'0	.ENDIF	.B	AUDPROV	.B	AFDIR	.B	0	.EVEN	CALL	INFOCLOSE	; termine l'affichage	CALL	DESINFFREQ	; info: affiche la frquence	CALL	DESINFFILE	; info: nom du fichier	CALL	DESINF3B	; info: boutons de la souris	POPM.L	D3,D4,A3	RET;---------\\; DESINF3B >;=========/; Affiche les fonctions des trois boutons de la souris.; in	-; out	-; mod	D7.WDESINF3B:	PUSHM.L	D3,A3,A4	CALL	INFOOPEN	; prpare l'affichage	LOAD.L	A3,#R16"TMOD$	LOAD.W	D3,#LIHELP	MUL.WU	D3,(A0)+ODFCX	SUB.W	D3,(A0)+ODFDX	NEG.W	D3	CONV.LA.WA D3	LIB	?SETCURS	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4+),#AFINV	LOAD.B	(A4+),#AFTOUTXFER$:	LOAD.B	(A4+),(A3+)	JUMP,NE XFER$	DEC.L	A4	LOAD.B	(A4+),#AFNORM	LOAD.B	(A4+),#AFDIR	CLR.B	(A4+)	LOAD.L	A3,#(A6)+OBUDIS	LIB	?AFTEXT		; affiche les 3 boutons de la souris	CALL	INFOCLOSE	; termine l'affichage	POPM.L	D3,A3,A4	RETTMOD$:	.ASCIZ	"|action|divers|slection|"LIHELP	=	.-TMOD$	.EVEN;-----------\\; DESINFFREQ >;===========/; Affiche la frquence d'chantillonage.; in	-; out	-; mod	D7.WDESINFFREQ:	PUSHM.L	D2..D4,A4	CALL	INFOOPEN	; prpare l'affichage	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSFREQ	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	LIB	?AFTIM	.B	MSPACE,POSFILE-POSFREQ	.B	0	.EVEN	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE END$	LOAD.W	D3,#POSFREQ	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A4)+OADHFREQ	DIV.WU	D4,#1000	AND.L	D4,#H'FFFF	LOAD.W	D3,#2	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche la frquence	LIB	?AFTIM	.ASCIZ	"KHz,"	.EVEN	LOAD.L	D4,(A4)+OADHLG	LOAD.W	D3,#3	COMP.W	(A4)+OADHFREQ,#ADFREQ/8	JUMP',EQ DRAW$	LOAD.W	D3,#2	TEST.L	D1:#18	COMP.W	(A4)+OADHFREQ,#ADFREQ/4	JUMP',EQ DRAW$	LOAD.W	D3,#1	TEST.L	D1:#17	COMP.W	(A4)+OADHFREQ,#ADFREQ/2	JUMP',EQ DRAW$	CLR.W	D3DRAW$:	SR.L	D4,D3	SR.L	D4,#8	SR.L	D4,#2		; D4 <-- /1024	INC.L	D4	LOAD.W	D3,#5	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le nb de kilos	LIB	?AFTIM	.ASCIZ	"k"	.EVENEND$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	CALL	INFOCLOSE	; termine l'affichage	POPM.L	D2..D4,A4	RET;----------\\; DESINFSEL >;==========/; Affiche la dure de l'chantillon slectionn.; in	D1.L	temps dbut;	D2.L	temps fin; out	-; mod	D7.WDESINFSEL:	PUSHM.L	D1..D4,A3,A4	CALL	INFOOPEN	; prpare l'affichage	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSFREQ	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	A3,A4	LOAD.W	D3,#POSFILE-POSFREQ-1CLR$:	LOAD.B	(A3+),#SPACE	; OBUDIS <-- rempli d'espaces	DECJ.W,NMO D3,CLR$	COMP.L	D1,D2	JUMP',LS EX$	EX.L	D1,D2EX$:	LOAD.L	D4,D1	CALL	PUTSNUM		; OBUDIS <-- temps du dbut	LOAD.B	(A4+),#';	; OBUDIS <-- ";"	LOAD.L	D4,D2	SUB.L	D4,D1	CALL	PUTSNUM		; OBUDIS <-- dure	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	D3,#POSFILE-POSFREQ	LIB	?STRING		; affiche les tempsEND$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	CALL	INFOCLOSE	; termine l'affichage	POPM.L	D1..D4,A3,A4	RET;-----------\\; DESINFFILE >;===========/; Affiche le nom du fichier dans les informations.; in	-; out	-; mod	D7.WDESINFFILE:	PUSHM.L	D2..D4,A3,A4	CALL	INFOOPEN	; prpare l'affichage	LOAD.L	A3,#(A6)+OBUNAME	LIB	?BUCAR		; mode rapide	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSFILE	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A0)+ODFDX	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb car dans toute la largeur	SUB.W	D4,#POSFILE	SUB.W	D4,#LIHELP+1	; D4 <-- nb car restants pour le nom	TEST.B	(A3)	JUMP',EQ 50$	COMP.B	(A3),#CR	JUMP',EQ 50$	LIB	?AFTIM	.B	'"		; guillemet au dbut	.B	AFTOUT	.B	0	.EVEN	SUB.W	D4,#2	LOAD.L	A4,#(A6)+OBUDIS	CALL	PUTINFFILE	; OBUDIS <-- nom du fichier	COMP.W	D3,D4	JUMP',LS 30$	ADD.W	A4,D3	SUB.W	A4,D4		; A4 <-- saute le dbut du nom	LOAD.B	(A4),#5		; dbut de nom <-- triangle "<"	LOAD.W	D3,D430$:	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le nom, ou seulement la fin	SUB.W	D4,D3		; D4 <-- lg restante	LIB	?AFTIM	.B	AFNORM	.B	'"		; guillemet  la fin	.B	0	.EVEN50$:	TEST.W	D4	JUMP',EQ 80$	LOAD.B	D3,#MSPACE	LIB	?AFCAR		; efface la fin	LOAD.B	D3,D4	LIB	?AFCAR80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?NOBUCAR	; mode normal	CALL	INFOCLOSE	; termine l'affichage	POPM.L	D2..D4,A3,A4	RET;-----------\\; PUTINFFILE >;-----------/; Prpare le nom du fichier  afficher.; in	A3.L	^nom;	A4.L	^buffer; out	D3.W	nb de caractres; mod	D3.L, D7.WPUTINFFILE:	PUSHM.L	D1,D2,A4	LOAD.W	D2,#2^BAFXMI	; D2 <-- affiche en minuscules	LOAD.W	D3,#100		; D3 <-- lg max	LOAD.L	D1,A4	LIB	?PUTXFILE	; OBUDIS <-- nom du fichier20$:	COMP.L	A4,D1	JUMP',EQ 30$	LOAD.B	D3,(-A4)	COMP.B	D3,#':	JUMP',EQ 30$	COMP.B	D3,#'.	JUMP,NE 20$	CLR.B	(A4)		; enlve l'extension30$:	LOAD.L	A4,D1	LOAD.W	D3,#-140$:	INC.W	D3	TEST.B	(A4+)	JUMP,NE 40$	POPM.L	D1,D2,A4	RET;---------\\; INFOOPEN >;=========/; Prpare l'affichage.; in	-; out	-; mod	D7.WINFOOPEN:	PUSHM.L	D5	CLR.W	D5	LIB	?USEWDO	LIB	?COLORPUSH	LOAD.L	D3,#COLORFINFO	LIB	?COLORSR	LOAD.L	D3,#COLORCINFO	LIB	?COLORCR	POPM.L	D5	RET;----------\\; INFOCLOSE >;==========/; Termine l'affichage.; in	-; out	-; mod	D7.WINFOCLOSE:	PUSHM.L	D5	LIB	?COLORPOP	LOAD.W	D5,(A6)+ONWDO	LIB	?USEWDO	POPM.L	D5	RET	.END