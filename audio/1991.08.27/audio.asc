	.TITLE	AUDIO.ASC;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du programme AUDIO.CODE;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 2.0	21.06.91	nouveau look !;			possibilit d'enregistrer avec l'interface DIGISON;			rgle gradue en secondes;			silence.. : nouvelle opration;			silence:    nouvelle opration;			cho: priode en secondes (nombre fractionnaire);			bruit: choix de la priode;			divers informations dans la ligne tout en haut;			grise la partie des sons qui dpasse;			choix des couleurs ...;			compatible avec 22'000 KHz;			utilise le module SMA_AUDIO.LIB; 1.2	14.06.91	version ok pour SMAKY100; 1.1	23.04.91	inverse: nouvelle opration;			colle permet d'ajouter (mixage) le son; 1.0	15.04.91	volume: ok si >65536 bytes;			utilise le bloc-notes;			menu avec le bouton du milieu;			bruit:     nouvelle opration ...;			cho:      nouvelle opration ...;			frquence: nouvelle opration ...; 0.3	15.11.90	signal: visualisation meilleure si x50..500; 0.2	09.11.90	commande "F+" au synth si crit "300_SYNT.AUDIO";			CURSOR-clic: reprend ancienne slection;			slection: sauve..; 0.1	02.11.90	premire version	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	ICOLOR	.REF	TCOLOR	.REF	COLORS	.REF	AUDIO	.REF	BLOC;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;GRA_CRASTER = H'A899		; raster-op couleurGRA_GDOT = H'A89A		; get-dotBSRCCOUL = 11BDSTCOUL = 12SMAKY300 = 7;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AUDREV	=	2		; rvisionAUDVERS	=	0		; version;AUDPROV=	'a		; rvision.version provisoireAUDPROV=	SPACE		; rvision.version dfinitive	.REV	AUDREV,AUDVERS	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------MACFREQ	=	22000		; frquence spcialeLXWDO	=	640		; largeur de l'cranLYWDO	=	340		; hauteur de l'cranBNTAUDI =	H'1000000*'A+H'10000*'U+H'100*'D+H'1*'IMAXSON	=	200		; nb max de sons par fichierLBUDIS	=	100		; lg max de OBUDISLBUNAME	=	50		; lg max d'un nom de fichierCIRCON	=	'^		; circonflxeTREMA	=	'"		; trmaKCIRCON	=	'		; touche circonflxeKTREMA	=	'		; touche trmaKEYDBOX	=	H'7E00		; "touche" spcialeGCTXF	=	'N		; fonte du texte NEF11GCTXS	=	'E!2^BGCFIX	; style/chasse du texteGCTXT	=	11		; taille du texteGCICF	=	'I		; fonte des icnes IAP20GCICS	=	'A		; style/chasse des icnesGCICT	=	20		; taille des icnesLXCAR	=	4		; rgle: largeur caractreLYCAR	=	7		; rgle: hauteur caractre; Codes des icnes de IAP20; -------------------------ICOVIDE	=	1		; demi-icne videICODETRUIT =	2		; dtruitICOECOUTE =	6		; couteICOFILTRE =	8		; filtreICOVOLUME =	9		; volumeICOBRUIT =	10		; bruitICOECHO =	11		; choICOFREQ =	12		; frquenceICOREVERSE =	13		; inverseICOSILENCE =	14		; silenceICOCOUPE =	16		; coupeICOCOPIE =	17		; copieICOCOLLE =	18		; colleICOCLASSEUR =	19		; classeurICOCOLLEP=	20		; colle +ICOUNDO =	21		; annuleICOQUITTE =	22		; quitteICOPREND =	23		; prendICOAJOUTE =	24		; ajouteICOSAUVE =	25		; sauveICOEXTRAIT =	26		; extraitICOSUPPRIME =	27		; supprimeICOEFFACE =	28		; effaceICOAMORCE =	29		; amorceICOCOLOR =	30		; couleursICOFILE =	32		; fichier >ICOEDIT =	33		; dition >ICOSHOW =	34		; vue >ICOCODE =	35		; codageICONUM	=	48		; chiffre 0..9ICONUMV	=	58		; chiffre videICOPRESS =	127		; presse le bouton; Couleurs; --------COLORBASE=	H'8000COLORFEDIT=	COLORBASE+0	; fond ditionCOLORCEDIT=	COLORBASE+1	; chair ditionCOLORIEDIT=	COLORBASE+2	; curseur ditionCOLORFSND=	COLORBASE+3	; fond sonCOLORCSND=	COLORBASE+4	; chair sonCOLORFSEG=	COLORBASE+5	; fond 7 segmentsCOLORCSEG=	COLORBASE+6	; chair 7 segmentsCOLORFREG=	COLORBASE+7	; fond rgleCOLORCREG=	COLORBASE+8	; chair rgleCOLORLREG=	COLORBASE+9	; lignes rgleCOLORGREG=	COLORBASE+10	; graduations rgleCOLORFBUT=	COLORBASE+11	; fond des boutonsCOLORFWDO=	COLORBASE+12	; fond de la fentreCOLORCDISK=	COLORBASE+13	; taille du sonCOLORTEST0=	COLORBASE+20	; test 0COLORTEST1=	COLORBASE+21	; test 1COLORTEST2=	COLORBASE+22	; test 2COLORTEST3=	COLORBASE+23	; test 3COLORTEST4=	COLORBASE+24	; test 4COLORTEST5=	COLORBASE+25	; test 5COLORTESTA=	COLORBASE+26	; test aiguilleCOLORTESTG=	COLORBASE+27	; test graduationCOLORTESTO=	COLORBASE+28	; test overflow; Ligne d'informations; --------------------	.LOC	0	.BLKB	12		; AUDIO 1.0POSFREQ:.BLKB	14		; 17KHz,46kPOSFILE:.BLKB	20		; "fichier"; Boutons actifs; --------------		.LOC	0BUTPLAY:	.BLKB	1BUTREC:		.BLKB	1BUTFILTRE:	.BLKB	1BUTCOUPE:	.BLKB	1BUTCOPIE:	.BLKB	1BUTCOLLED:	.BLKB	1BUTCOLLEF:	.BLKB	1BUTCLASSEUR:	.BLKB	1BUTPREND:	.BLKB	1BUTAJOUTE:	.BLKB	1BUTSAUVE:	.BLKB	1BUTEXTRAIT:	.BLKB	1BUTANNULE:	.BLKB	1BUTSUPPRIME:	.BLKB	1BUTEFFACE:	.BLKB	1BUT35KHZ:	.BLKB	1BUT22KHZ:	.BLKB	1BUT17KHZ:	.BLKB	1BUT8KHZ:	.BLKB	1BUT4KHZ:	.BLKB	1BUTX1:		.BLKB	1BUTX5:		.BLKB	1BUTX10:		.BLKB	1BUTX50:		.BLKB	1BUTX100:	.BLKB	1BUTX500:	.BLKB	1; Oprations pour annuler; -----------------------OPUNREPL =	1		; remplaceOPUNINS	=	2		; insreOPUNDEL =	3		; dtruitOPUNALL =	4		; tout; Descripteur pour une ligne ditable dans une DBOX; -------------------------------------------------	.LOC	0ODBOFF:	.BLKB	2		; offset variableODBTYP:	.BLKB	2		; type DBTYPN =  0			;  nombre entier positif DBTYPNS=  1			;  nombre entier sign (+/-) DBTYPNF=  2			;  nombre entier positif facultatif DBTYPS	=  3			;  nombre en secondes (.L) DBTYPA =  10			;  chane alphanumriqueODBMIN:	.BLKB	2		; valeur minimaleODBMAX:	.BLKB	2		; valeur maximaleODBINC:	.BLKB	2		; incrmentODBRGC:	.BLKB	2		; rang pour DBOX_GETCOODBRED:	.BLKB	2		; rang pour DBOX_MEDITODBNBC:	.BLKB	2		; nb de caractresLDB:; Descripteur d'une rgle; -----------------------	.LOC	0ORGPO:	.BLKB	4		; coin sup/gaucheORGLG:	.BLKB	2		; longueurORGOFF:	.BLKB	4		; offsetORGPAS:	.BLKB	2		; pas *2ORGFAC:	.BLKB	2		; facteur (1,5,10,50,100,500)ORGDEC:	.BLKB	2		; nb de dcimales (0..3)LRG:; En-tte d'un fichier .IMAGE/.COLOR; ----------------------------------	.LOC	0	.BLKB	1		; OIMTYP: H'82	.BLKB	1		; OIMCOD: 0 ou 4	.BLKB	1		; OIMBIP: 4 bits/pixel	.BLKB	1		; OIMDIR: 2	.BLKB	2		; OIMDLX: largeur (multiple de 16)	.BLKB	2		; OIMDLY: hauteur	.BLKB	4		; OIMNBB: longueur du dataOIMSIZ:	.BLKB	2		; taille d'un pixel (4)OIMCNT:	.BLKB	2		; nb de pixels (1)OIMLGC:	.BLKB	4		; longueur de la CLUT	.BLKB	12		; rserve				; LGHIMA: longueur de l'en-tte; Variables; ---------	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHBLOC:.BLKB	2		; canal module BLOCOCHICOLOR:.BLKB	2		; canal module ICOLOROCHAUDI:.BLKB	2		; canal module AUDIOOCAAUDI:.BLKB	4		; canal variables AUDIOOPLCOM:	.BLKB	4		; ^ligne de commandeOPDDIS:	.BLKB	4		; ^descripteur de la fentreOIDCRET:.BLKB	4		; identificateur de la CRETOADRASTER:	.BLKB	4	;  adresse de GRA_RASTEROADCRASTER:	.BLKB	4	;  adresse de GRA_CRASTEROADLINE:	.BLKB	4	;  adresse de GRA_LINEOBUDIS:	.BLKB	LBUDIS		; buffer write-displayOINV:	.BLKB	1		; 1 => fond de l'cran blancOCCMO:	.BLKB	1		; 1 => souris enleveOAUDIO:	.BLKB	1		; 1 => #AUDIO en fonctionOMACHINE:.BLKB	1		; machine utilise (SMAKY*)	.EVENONWDO:	.BLKB	2		; swdo principaleOPIMC0:	.BLKB	4		; ^image code 0OPIMD0:	.BLKB	4		; ^image dcode 0OPIMC1:	.BLKB	4		; ^image code 1OPIMD1:	.BLKB	4		; ^image dcode 1OPIMC2:	.BLKB	4		; ^image code 2OPIMD2:	.BLKB	4		; ^image dcode 2OBUTTON:.BLKB	100		; tats des boutonsOLTIME:	.BLKB	4		; dernier temps affichOVSPOS:	.BLKB	4		; visu-son: positionOVSDIM:	.BLKB	4		; visu-son: dimensionsOVSDET:	.BLKB	1		; visu-son: flags de dtectopn	.EVENOSCVAR:	.BLKB	LSCVAR		; ascenseur: variablesORGVAR:	.BLKB	LRG		; rgle: variablesOSLVAR:	.BLKB	LSLVAR		; scroll-liste: variablesOSLNCH:	.BLKB	2		; scroll-liste: 1 => nom changOEDNAM:	.BLKB	LADHNAME	; edit: nom du sonOEDCUR:	.BLKB	2		; edit: position du curseur d'insertionOEDNBC:	.BLKB	2		; edit: nb de caractresOEDACC:	.BLKB	1		; edit: frappe accent flottant en cours	.EVENOSLVAR2:.BLKB	LSLVAR		; scroll-liste: variables secondairesOSELTD:	.BLKB	4		; slection: TdbutOSELTF:	.BLKB	4		; slection: TfinOSELALL:.BLKB	1		; 1 => tout slectionn	.EVENOMMPS:	.BLKB	LMM*10		; mmenu: paramtres slectionOMMPM:	.BLKB	LMM*10		; mmenu: paramtres diversOMMPF:	.BLKB	LMM*10		; mmenu: paramtres filtreORCLGS:	.BLKB	2		; record: lg en secondesORCNIV:	.BLKB	2		; record: niveau du bruitORCTIM:	.BLKB	2		; record: timeoutORCLGH:	.BLKB	2		; record: lg maximaleOTTPOS:	.BLKB	4		; test: coin sup/gaucheOTTDIM:	.BLKB	4		; test: dimensionsOTTPTB:	.BLKB	4		; test: ^buffer pour testOTTOVE:	.BLKB	2		; test: dernier tat de l'indicateur d'overflowOAMLG:	.BLKB	4		; amorce: longueur [s]OAMCYS:	.BLKB	2		; amorce: case slectionneOVODEB:	.BLKB	2		; volume: dbut [%]OVOFIN:	.BLKB	2		; volume: fin   [%]OVOCYS:	.BLKB	2		; volume: case slectionneOBRLEV:	.BLKB	2		; bruit: niveauOBRPER:	.BLKB	4		; bruit: priodeOBRCYS:	.BLKB	2		; bruit: case slectionneOECRAT:	.BLKB	2		; cho: taux de rinjection [%]OECPER:	.BLKB	4		; cho: priode [s]OECCYS:	.BLKB	2		; cho: case slectionneOFRFAC:	.BLKB	2		; frquence: facteur [+/-%]OFRPEN:	.BLKB	2		; frquence: pente [+/-%]OFRCYS:	.BLKB	2		; frquence: case slectionneODBLIN:	.BLKB	50		; dbox: ligne en ditionODBPTE:	.BLKB	4		; dbox: ^table des objets ditablesODBPTS:	.BLKB	4		; dbox: ^table pour scroll-listeODBPA1:	.BLKB	4		; dbox: paramtre 1ODBPA2:	.BLKB	4		; dbox: paramtre 2ODBPA3:	.BLKB	4		; dbox: paramtre 3ODBPA4:	.BLKB	4		; dbox: paramtre 4OBUNAME:.BLKB	LBUNAME		; nom du fichier .AUDIOOBUNADD:.BLKB	LBUNAME		; nom du fichier  ajouterOUNOP:	.BLKB	2		; undo: opration pour annulerOUNTD:	.BLKB	4		; undo: temps dbutOUNTF:	.BLKB	4		; undo: temps finOUNPT:	.BLKB	4		; undo: ^copieOPSON:	.BLKB	4*(MAXSON+1)	; ^sonsOBHEAD:	.BLKB	LADH		; buffer pour en-tteOOPCDB:	.BLKB	4		; wait: canal dbox waitOOPASC:	.BLKB	LSCVAR		; wait: ascenseurOOPDIV:	.BLKB	2		; wait: facteur de divisionOPFCDB:	.BLKB	4		; processus fils: canal dboxOPFPT:	.BLKB	4		; processus fils: ^dataOPFLG:	.BLKB	4		; processus fils: lg dataOPFBUS:	.BLKB	4		; processus fils: buffer statusOPFT1:	.BLKB	4		; processus fils: t1OPFT2:	.BLKB	4		; processus fils: t2OPFAB:	.BLKB	1		; processus fils: 1 => abort	.EVENLGVAR:; Programme; ---------	.LOC	0	JUMP	START; Erreurs fatales; ---------------TXERFATTXT:	.ASCIZ	"Erreur avec le gencar NEF11"TXERFATICO:	.ASCIZ	"Erreur avec le gencar IAP20"; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMBLOC:		.ASCIZ	"BLOC"NMICOLOR:	.ASCIZ	"ICOLOR"NMAUDIO:	.ASCIZ	"AUDIO"NMLOG:		.ASCIZ	"AUDIO"NMIMA0NB:	.ASCIZ	"(:,#:)AUDIO_F0.IMAGE"NMIMA0C:	.ASCIZ	"(:,#:)AUDIO_F0.COLOR"NMIMA1NB:	.ASCIZ	"(:,#:)AUDIO_F1.IMAGE"NMIMA1C:	.ASCIZ	"(:,#:)AUDIO_F1.COLOR"NMIMA2NB:	.ASCIZ	"(:,#:)AUDIO_F2.IMAGE"NMIMA2C:	.ASCIZ	"(:,#:)AUDIO_F2.COLOR"		.EVEN; Tables des couleurs relatives; -----------------------------TCOUL:	.L	COLORFSND	.W	-1,-1,-1	.ASCIZE	"signal:    fond"	.L	COLORCSND	.W	0,0,0	.ASCIZE	"signal:    contenu"	.L	COLORFEDIT	.W	-1,-1,-1	.ASCIZE	"dition:   fond"	.L	COLORCEDIT	.W	0,0,0	.ASCIZE	"dition:   contenu"	.L	COLORIEDIT	.W	0,0,0	.ASCIZE	"dition:   curseur"	.L	COLORFSEG	.W	-1,-1,-1	.ASCIZE	"temps:     fond"	.L	COLORCSEG	.W	0,0,0	.ASCIZE	"temps:     contenu"	.L	COLORFREG	.W	-1,-1,-1	.ASCIZE	"rgle:     fond"	.L	COLORCREG	.W	0,0,0	.ASCIZE	"rgle:     cadre"	.L	COLORLREG	.W	0,0,0	.ASCIZE	"rgle:     graduations"	.L	COLORGREG	.W	0,0,0	.ASCIZE	"rgle:     indication des secondes"	.L	COLOR_SCCLEAR	.W	-1,-1,-1	.ASCIZE	"ascenseur: fond"	.L	COLOR_SCSET	.W	0,0,0	.ASCIZE	"ascenseur: contenu"	.L	COLOR_SCOBJ	.W	0,0,0	.ASCIZE	"ascenseur: flches"	.L	COLOR_SCPOS	.W	0,0,0	.ASCIZE	"ascenseur: cabine"	.L	COLOR_SLCLEAR	.W	-1,-1,-1	.ASCIZE	"liste:     fond"	.L	COLOR_SLSET	.W	0,0,0	.ASCIZE	"liste:     cadre"	.L	COLOR_SLTEXT	.W	0,0,0	.ASCIZE	"liste:     noms des sons"	.L	COLOR_SLHILI	.W	0,0,0	.ASCIZE	"liste:     son slectionn"	.L	COLOR_MMCLEAR	.W	-1,-1,-1	.ASCIZE	"menu:      fond"	.L	COLOR_MMSET	.W	0,0,0	.ASCIZE	"menu:      contenu"	.L	COLOR_MMCADRE	.W	0,0,0	.ASCIZE	"menu:      cadre"	.L	COLOR_MMSEP	.W	0,0,0	.ASCIZE	"menu:      sparations"	.L	COLOR_DBCLEAR	.W	-1,-1,-1	.ASCIZE	"dialogue:  fond"	.L	COLOR_DBSET	.W	0,0,0	.ASCIZE	"dialogue:  contenu"	.L	COLOR_DBCADRE	.W	0,0,0	.ASCIZE	"dialogue:  cadre"	.L	COLOR_DBSEL	.W	-1,0,0	.ASCIZE	"dialogue:  boutons slectionns"	.L	COLORFBUT	.W	-1,-1,-1	.ASCIZE	"boutons:   fond"	.L	COLORFWDO	.W	-1,-1,-1	.ASCIZE	"fentre:   fond"	.L	COLORCDISK	.W	0,0,0	.ASCIZE	"disque :   taille"	.L	COLORTEST0	.W	-1,-1,-1	.ASCIZE	"VU-METER:  fond 0"	.L	COLORTEST1	.W	-1,-1,-1	.ASCIZE	"VU-METER:  fond 1"	.L	COLORTEST2	.W	-1,-1,-1	.ASCIZE	"VU-METER:  fond 2"	.L	COLORTEST3	.W	-1,-1,-1	.ASCIZE	"VU-METER:  fond 3"	.L	COLORTEST4	.W	-1,-1,-1	.ASCIZE	"VU-METER:  fond 4"	.L	COLORTEST5	.W	-1,-1,-1	.ASCIZE	"VU-METER:  fond 5"	.L	COLORTESTA	.W	0,0,0	.ASCIZE	"VU-METER:  aiguille"	.L	COLORTESTG	.W	0,0,0	.ASCIZE	"VU-METER:  graduations"	.L	COLORTESTO	.W	0,0,0	.ASCIZE	"VU-METER:  overflow"	.L	0; Dbut de programme; ------------------START:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CALL	WAITMOUSE	; met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	LOAD.L	(A6)+OPDDIS,A0	SET.B	(A6)+OINV	; le fond de l'cran est blanc	TEST.B	(A0)+ODFCMD	JUMP',NE INV$	TEST.B	(A0)+ODFMOD:#BFBLANC	JUMP',BS INV$	CLR.B	(A6)+OINV	; le fond de l'cran est noir (ex. SMAKY100)INV$:	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; mode graphique avec clipping	.B	0	.EVEN	LOAD.L	A3,#R16"TXERFATTXT	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT,0	.EVEN	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATICO	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT,0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0	.EVEN	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADRASTER,A3	LOAD.W	D3,#GRA_CRASTER	LIB_	GETAD	LOAD.L	(A6)+OADCRASTER,A3	LOAD.W	D3,#GRA_LINE	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OADLINE,A3	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMBLOC	LOAD.W	D3,#BLOC_FIRST	LIB_	OPEN	JUMP',NE NOBLOC$	LOAD.W	(A6)+OCHBLOC,D1	BLOC_	OPEN		; ouverture globaleNOBLOC$:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	LOAD.L	A3,#R16"NMICOLOR	LOAD.W	D3,#ICOL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHICOLOR,D1NOCOUL$:	LOAD.L	A3,#R16"NMAUDIO	LOAD.W	D3,#AUDIO_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHAUDI,D1	AUDIO_	OPEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OCAAUDI,D6	SET.B	(A6)+OAUDIO	TEST.W	D4	JUMP',EQ AUDIO$	CLR.B	(A6)+OAUDIOAUDIO$:	LOAD.B	(A6)+OBUTTON+BUTX50,#1 ; mode x50 par dfaut	LOAD.L	A3,#R16"NMIMA0NB	TEST.B	(A0)+ODFCMD	JUMP',EQ LOAD0$	LOAD.L	A3,#R16"NMIMA0CLOAD0$:	CALL	LOADIMAGE	; charge AUDIO_F0.IMAGE/COLOR	JUMP,NE ERFAT2	LOAD.L	(A6)+OPIMC0,A4	CALL	DECOIMAGE	JUMP,NE ERFAT2	LOAD.L	(A6)+OPIMD0,A4	LOAD.L	A3,#R16"NMIMA1NB	TEST.B	(A0)+ODFCMD	JUMP',EQ LOAD1$	LOAD.L	A3,#R16"NMIMA1CLOAD1$:	CALL	LOADIMAGE	; charge AUDIO_F1.IMAGE/COLOR	JUMP,NE ERFAT2	LOAD.L	(A6)+OPIMC1,A4	CALL	DECOIMAGE	JUMP,NE ERFAT2	LOAD.L	(A6)+OPIMD1,A4	LOAD.L	A3,#R16"NMIMA2NB	TEST.B	(A0)+ODFCMD	JUMP',EQ LOAD2$	LOAD.L	A3,#R16"NMIMA2CLOAD2$:	CALL	LOADIMAGE	; charge AUDIO_F2.IMAGE/COLOR	JUMP,NE ERFAT2	LOAD.L	(A6)+OPIMC2,A4	CALL	DECOIMAGE	JUMP,NE ERFAT2	LOAD.L	(A6)+OPIMD2,A4	LOAD.W	(A6)+ORCLGS,#5	LOAD.W	(A6)+ORCNIV,#10	LOAD.W	(A6)+ORCTIM,#5	LOAD.L	(A6)+OAMLG,#100*ADFREQ/1000	LOAD.W	(A6)+OAMCYS,#2	LOAD.W	(A6)+OVODEB,#100	LOAD.W	(A6)+OVOFIN,#100	LOAD.W	(A6)+OVOCYS,#0	LOAD.W	(A6)+OBRLEV,#20	LOAD.L	(A6)+OBRPER,#ADFREQ/100	LOAD.W	(A6)+OBRCYS,#2	LOAD.W	(A6)+OECRAT,#65	LOAD.L	(A6)+OECPER,#160*ADFREQ/1000	LOAD.W	(A6)+OECCYS,#11	LOAD.W	(A6)+OFRFAC,#0	LOAD.W	(A6)+OFRPEN,#0	LOAD.W	(A6)+OFRCYS,#12	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCRET$	; non => NOCRET$	LOAD.L	A3,#R16"NMLOG	LOAD.L	A5,#R16"TCOUL	LOAD.L	D3,#2^BICCRET	ICOL_	INIT		; charge AUDIO.CRET	LOAD.L	(A6)+OIDCRET,D5NOCRET$:	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SKPNAM	JUMP',NE MAIN$	CALL	IOREAD		; lit le fichier .SOUNDMAIN$:	CALL	DBOXMAIN	; dbox principale ...ERFAT:	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHBLOC	JUMP',EQ NOBLOC$	BLOC_	CLOSE		; fermeture globale	JUMP',NE NOBLOC$	LIB_	CLOSENOBLOC$:	LOAD.W	D1,(A6)+OCHICOLOR	LIB_	CLOSE	LOAD.L	D6,(A6)+OCAAUDI	AUDIO_	CLOSE	LOAD.W	D1,(A6)+OCHAUDI	LIB_	CLOSEERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	AUDMAIN.ASI	.INS	AUDEDIT.ASI	.INS	AUDBUTTON.ASI	.INS	AUDVISU.ASI	.INS	AUDREGLE.ASI	.INS	AUDFILTRE.ASI	.INS	AUDIO.ASI	.INS	AUDTEST.ASI	.INS	AUDDBOX.ASI	.INS	AUDDBOXT.ASI	.INS	AUDIMAGE.ASI	.INS	AUDMATH.ASI	.INS	AUDMISC.ASI	.END	START