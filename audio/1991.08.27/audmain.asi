	.SBTTL	AUDMAIN.ASI;---------\\; DBOXMAIN >;=========/; Programme principal.; in	-; out	D7.W	erreur; mod	D7.WDBOXMAIN:	PUSHM.L	D1..D5,A1..A4; Cre la swdo principale.	LIB	?COLORPUSH	LOAD.L	D3,#COLORFWDO	LIB	?COLORCR	CLR.L	D4	CALL	INVTRAME	CALL	DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFDY	LOAD.W	D2,#CLRDOT	CALL	INVMODE	LIB	?DRTRAME	; efface toute le fentre	LIB	?COLORPOP	LOAD.W	D4,#LYWDO	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,D4	SR.W	D3,#1	AND.B	D3,#B'11111110	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,#LXWDO	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,D4	SR.W	D3,#1	AND.B	D3,#B'11110000	LIB	?CREWDO		; cre swdo (utile si grand cran)	LOAD.W	(A6)+ONWDO,D5	LIB	?USEWDO	LIB	?BUZZ; Affiche l'image de base.BEGIN$:	LOAD.L	A4,(A6)+OPIMD0	CLR.L	D2	CLR.L	D3	LOAD.L	D4,#H'10000*LYWDO+LXWDO	CALL	SHOWIMAGE	; affiche l'image principale	LOAD.L	A4,(A6)+OPIMC0	CALL	CLUTIMAGE	; change la CLUT	LOAD.W	D2,#BUTX1	CALL	BUTDRAW	LOAD.W	D2,#BUTX5	CALL	BUTDRAW	LOAD.W	D2,#BUTX10	CALL	BUTDRAW	LOAD.W	D2,#BUTX50	CALL	BUTDRAW	LOAD.W	D2,#BUTX100	CALL	BUTDRAW	LOAD.W	D2,#BUTX500	CALL	BUTDRAW	LOAD.L	(A6)+OVSPOS,#H'10000*50+35	LOAD.L	(A6)+OVSDIM,#H'10000*128+572	LOAD.L	(A6)+OSLVAR+OSLPOS,#H'10000*222+25	LOAD.L	(A6)+OSLVAR+OSLDIM,#H'10000*97+200	CALL	VISUEMPTY	; dessine la zone de visualisation	CALL	MAINSLDRAW	; dessine la scroll-liste	CALL	AFMENU		; dessine les touches fonctionsUPDATE0$:	INC.W	(A6)+OSLNCH	; faudra afficher la scroll-listeUPDATE1$:	CLR.W	(A6)+OSLVAR+OSCPOSVUPDATE2$:	CALL	MAINVIDRAW	; affiche le sonNAME$:	TEST.W	(A6)+OSLNCH	; nom chang ?	JUMP',EQ NAME2$		; non => NAME2$	CALL	MAINSLUPDATE	; met  jour la scroll-liste	CLR.W	(A6)+OSLNCHNAME2$:	CALL	MAINOPEN	; init selon le signal slectionnLOOP$:	CALL	BUTRELEASE	; relche tous les boutons inutiles	CALL	MAINGREY	; grise qq boutons	CALL	MAINCLRALL	; dslectionne le signal si ncessaire	CALL	SCMO		; remet la souris	CALL	NORMMOUSE	; remet la flcheLOOP3$:	LIB	?GETKEY		; attend clavier/souris ...	TEST.L	D3:#BKPSEUDO	JUMP,BS LOOP3$	COMP.W	D3,#KEYMPO	; souris juste dplace ?	JUMP,EQ MPO$		; oui => MPO$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP3$	COMP.W	D3,#KEYMMR	; bouton de la souris relch ?	JUMP,EQ LOOP3$		; oui => LOOP3$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP3$	CALL	EDITEVENT	; vnement d'dition ?	JUMP,EQ LOOP3$		; oui => LOOP3$	CALL	MAINCLOSE	; met  jour le son	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ MISC$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$KEY$:	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#DEFINE	JUMP,EQ	PLAY$	COMP.W	D3,#H'100*(2^BKILL)+'S	JUMP,EQ SUPP$	COMP.W	D3,#H'100*(2^BCHANGE)+'C	JUMP,EQ COLOR$	COMP.W	D3,#H'100*(2^BPROGRA)+'S	JUMP,EQ SILENCE$	COMP.W	D3,#H'100*(2^BPROGRA)+'V	JUMP,EQ VOL$	COMP.W	D3,#H'100*(2^BPROGRA)+'B	JUMP,EQ BRUIT$	COMP.W	D3,#H'100*(2^BPROGRA)+'E	JUMP,EQ ECHO$	COMP.W	D3,#H'100*(2^BPROGRA)+'F	JUMP,EQ FREQ$	COMP.W	D3,#H'100*(2^BPROGRA)+'I	JUMP,EQ REVERSE$	COMP.W	D3,#F0	JUMP,EQ QUIT$	COMP.W	D3,#F0+SHIFT	JUMP,EQ QUIT$	COMP.W	D3,#F1	JUMP,EQ PREND$	COMP.W	D3,#F2	JUMP,EQ AJOUTE$	COMP.W	D3,#F3	JUMP,EQ SAUVE$	COMP.W	D3,#F14	JUMP,EQ EFFACE$	COMP.W	D3,#H'100*(2^BKILL)+SPACE	JUMP,EQ COUPE$	COMP.W	D3,#H'100*(2^BKILL!2^BPROGRA)+SPACE	JUMP,EQ COUPE$	COMP.W	D3,#H'100*(2^BCOPY)+SPACE	JUMP,EQ COPIE$	COMP.W	D3,#H'100*(2^BCOPY!2^BPROGRA)+SPACE	JUMP,EQ COPIE$	COMP.W	D3,#H'100*(2^BCURSOR!2^BCOPY)+SPACE	JUMP,EQ COLLED$	COMP.W	D3,#H'100*(2^BCURSOR)+SPACE	JUMP,EQ COLLEF$	COMP.W	D3,#H'100*(2^BSHOW)+SPACE	JUMP,EQ CLASSEUR$	JUMP	BIP$MPO$:	LOAD.L	D1,#-1	CALL	IFMOUSE	JUMP',NE MPO2$	SWAP.W	D4	SUB.W	D4,(A6)+OVSPOS+0	JUMP',LO MPO2$	COMP.W	D4,(A6)+OVSDIM+0	JUMP',HS MPO2$	SWAP.W	D4	SUB.W	D4,(A6)+OVSPOS+2	JUMP',LO MPO2$	COMP.W	D4,(A6)+OVSDIM+2	JUMP',HS MPO2$	CALL	VISUGETFACT	; D0 <-- facteur de rduction	MUL.WU	D4,D0	CLR.L	D1	LOAD.W	D1,(A6)+OSCVAR+OSCPOSV ; D1 <-- position dbut [e/64]	SL.L	D1,#6		; D1 <-- position dbut [e]	ADD.L	D1,D4MPO2$:	CALL	BUTINFOSEC	; affiche le temps	JUMP	LOOP3$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	CALL	BUTMOVE		; presse un bouton ...	JUMP,EQ BUTTON$	CALL	MAINSELECT	; slectionne le signal ...	JUMP,EQ NAME$	CALL	MAINVIMOVE	; dplace le signal ...	JUMP,EQ LOOP$	CALL	MAINSLMOVE	; dplace la scroll-liste ...	JUMP,EQ UPDATE1$	JUMP	BIP$BUTTON$:	CALL	MAINBUTMAJ	; met  jour le son v.	COMP.W	D2,#BUTPLAY	JUMP,EQ PLAY$	COMP.W	D2,#BUTREC	JUMP,EQ REC$	COMP.W	D2,#BUTFILTRE	JUMP,EQ FILTRE$	COMP.W	D2,#BUTX1	JUMP,EQ UPDATE2$	COMP.W	D2,#BUTX5	JUMP,EQ UPDATE2$	COMP.W	D2,#BUTX10	JUMP,EQ UPDATE2$	COMP.W	D2,#BUTX50	JUMP,EQ UPDATE2$	COMP.W	D2,#BUTX100	JUMP,EQ UPDATE2$	COMP.W	D2,#BUTX500	JUMP,EQ UPDATE2$	COMP.W	D2,#BUTCOUPE	JUMP,EQ COUPE$	COMP.W	D2,#BUTCOPIE	JUMP,EQ COPIE$	COMP.W	D2,#BUTCOLLED	JUMP,EQ COLLED$	COMP.W	D2,#BUTCOLLEF	JUMP,EQ COLLEF$	COMP.W	D2,#BUTCLASSEUR	JUMP,EQ CLASSEUR$	COMP.W	D2,#BUTPREND	JUMP,EQ PREND$	COMP.W	D2,#BUTAJOUTE	JUMP,EQ AJOUTE$	COMP.W	D2,#BUTSAUVE	JUMP,EQ SAUVE$	COMP.W	D2,#BUTEXTRAIT	JUMP,EQ EXTRAIT$	COMP.W	D2,#BUTANNULE	JUMP,EQ UNDO$	COMP.W	D2,#BUTSUPPRIME	JUMP,EQ SUPP$	COMP.W	D2,#BUTEFFACE	JUMP,EQ EFFACE$	CALL	INFOTAILLE	; affiche la taille du son	JUMP	LOOP$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ERROR$:	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	UPDATE0$UNDO$:				; UNDO =>	CALL	MAINBACK	; revient en arrire	JUMP,NE BIP$	CALL	INFOTAILLE	; affiche la taille du son	JUMP	LOOP$MISC$:	CALL	MAINMISC	; choix dans mmenu ...	JUMP,NE BIP$	TEST.W	D3	JUMP,EQ LOOP$	JUMP	KEY$FILTRE$:	CALL	MAINFILTRE	; choix dans mmenu ...	JUMP,NE BIP$	TEST.W	D3	JUMP,EQ LOOP$	JUMP	KEY$PLAY2$:	CALL	MAINVIDRAW	; affiche le sonPLAY$:	CALL	MAINPLAY	; fait entendre ...	JUMP,NE BIP$	JUMP	LOOP$REC$:	CALL	IOIFREC		; interface connecte ?	JUMP,NE ERROR$		; non => ERROR$	CALL	DBOXREC		; choix des paramtres ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	MAINREC		; enregistre un son ...	JUMP,NE ERROR$	JUMP	UPDATE0$SUPP$:	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	CALL	IOFLUSHONE	; efface un son	JUMP	UPDATE0$PREND$:	LOAD.L	A3,#(A6)+OBUNAME	CLR.L	D4	CALL	DBOXEDITIF	; demande un nom ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE UPDATE0$	CALL	IOREAD		; lit un fichier .AUDIO	JUMP,NE ERROR$	CLR.W	(A6)+OSLVAR+OSLCYS	JUMP	UPDATE0$AJOUTE$:	LOAD.L	A3,#(A6)+OBUNADD	CLR.L	D4	CALL	DBOXEDITAF	; demande un nom ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE UPDATE0$	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	CALL	IOADD		; ajoute un fichier .AUDIO	JUMP,NE ERROR$	JUMP	UPDATE0$SAUVE$:	LOAD.L	A3,#(A6)+OBUNAME	CLR.L	D4	CALL	DBOXEDITOF	; demande un nom ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE NAME$SAUVE4$:	CALL	IOWRITE		; crit un fichier .AUDIO	JUMP,EQ NAME$	COMP.W	D7,#ERFAEX	JUMP,NE ERROR$	CALL	DBOXDETRUIT	; faut-il dtruire ?	COMP.W	D3,#F1	JUMP,NE SAUVE$	FOS	?DELETE	JUMP	SAUVE4$EXTRAIT$:	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE BIP$EXTRAIT2$:	LOAD.L	A3,#(A6)+OBUNADD	CLR.L	D4	CALL	DBOXEDITEF	; demande un nom ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE NAME$EXTRAIT4$:	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	IOEXTRAIT	; crit un fichier .AUDIO	JUMP,EQ NAME$	COMP.W	D7,#ERFAEX	JUMP,NE ERROR$	CALL	DBOXDETRUIT	; faut-il dtruire ?	COMP.W	D3,#F1	JUMP,NE EXTRAIT2$	FOS	?DELETE	JUMP	EXTRAIT4$EFFACE$:	CALL	DBOXEFFACE	; faut-il effacer ?	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	IOFLUSH		; efface tous les sons	CLR.W	(A6)+OSLVAR+OSLCYS	CLR.B	(A6)+OBUNAME	JUMP	UPDATE0$COUPE$:	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE BIP$	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	VISUCOPYBLOC	; bloc-notes <-- tout le son	JUMP,NE BIP$	JUMP	SUPP$COPIE$:	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE BIP$	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	VISUCOPYBLOC	; bloc-notes <-- tout le son	JUMP,NE BIP$	JUMP	NAME$COLLED$:	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE COLLEV$	CLR.L	D1		; D1 <-- au dbut	CALL	VISUPASTBLOC	; colle un son du bloc-notes	JUMP,NE BIP$	JUMP	UPDATE2$COLLEF$:	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE COLLEV$	LOAD.L	D1,(A4)+OADHLG	; D1 <--  la fin	CALL	VISUPASTBLOC	; colle un son du bloc-notes	JUMP,NE BIP$	JUMP	UPDATE2$COLLEV$:	CALL	MAINPCREATE	; A4 <-- ^nouveau son vide	JUMP,NE BIP$	CLR.L	D1		; D1 <-- au dbut	CALL	VISUPASTBLOC	; colle un son du bloc-notes	JUMP,NE BIP$	JUMP	UPDATE0$CLASSEUR$:	CALL	DBOXBLOC	; accs au classeur ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP	COLLEF$SILENCE$:	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE BIP$	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	FILSILENCE	; met le volume  zro	JUMP	UPDATE2$VOL$:	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE BIP$	CALL	DBOXVOL		; choix des volumes ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE NAME$	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	FILVOLUME	; modifie le volume	JUMP	PLAY2$BRUIT$:	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE BIP$	CALL	DBOXBRUIT	; choix des paramtres ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE NAME$	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	FILBRUIT	; modifie le son	JUMP	PLAY2$ECHO$:	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE BIP$	CALL	DBOXECHO	; choix des paramtres ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE NAME$	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	FILECHO		; modifie le son	JUMP	PLAY2$FREQ$:	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE BIP$	CALL	DBOXFREQ	; choix des paramtres ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE NAME$	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	FILFREQ		; modifie le son	JUMP	PLAY2$REVERSE$:	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE BIP$	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	FILREVERSE	; modifie le son	JUMP	PLAY2$COLOR$:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,EQ BIP$		; non => BIP$	CALL	DBOXCOLOR	; choix des couleurs ...	JUMP	BEGIN$QUIT$:	CALL	DBOXQUITTE	; demande s'il faut quitter ...	COMP.W	D3,#F1	JUMP,NE LOOP$	CLR.W	D5	LIB	?USEWDO	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MAINOPEN >;=========/; Initialise les boutons en fonction du son slectionn dans la scroll-liste.; in	-; out	-; mod	D7.WMAINOPEN:	PUSHM.L	D2,A3,A4	CALL	EDITCLEAR	; efface le nom en dition	LOAD.W	D2,#BUT35KHZ	CALL	BUTCLR	LOAD.W	D2,#BUT22KHZ	CALL	BUTCLR	LOAD.W	D2,#BUT17KHZ	CALL	BUTCLR	LOAD.W	D2,#BUT8KHZ	CALL	BUTCLR	LOAD.W	D2,#BUT4KHZ	CALL	BUTCLR		; relche tous les boutons des frquences	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE RIEN$	LOAD.W	D2,#BUTPLAY	CALL	BUTFULL;;?	LOAD.W	D2,#BUTREC;;?	CALL	BUTGREY	LOAD.W	D2,#BUTFILTRE	CALL	BUTFULL	LOAD.W	D2,#BUTCOUPE	CALL	BUTFULL	LOAD.W	D2,#BUTCOPIE	CALL	BUTFULL	LOAD.W	D2,#BUTEXTRAIT	CALL	BUTFULL	LOAD.W	D2,#BUTSUPPRIME	CALL	BUTFULL	LOAD.W	D2,#BUT4KHZ	COMP.W	(A4)+OADHFREQ,#ADFREQ/8	JUMP',EQ FREQ$	LOAD.W	D2,#BUT8KHZ	COMP.W	(A4)+OADHFREQ,#ADFREQ/4	JUMP',EQ FREQ$	LOAD.W	D2,#BUT17KHZ	COMP.W	(A4)+OADHFREQ,#ADFREQ/2	JUMP',EQ FREQ$	LOAD.W	D2,#BUT22KHZ	COMP.W	(A4)+OADHFREQ,#MACFREQ	JUMP',EQ FREQ$	LOAD.W	D2,#BUT35KHZFREQ$:	CALL	BUTSET		; presse le bouton de la frquence	LOAD.L	A3,#(A6)+OEDNAM	LOAD.L	A4,#(A4)+OADHNAME	LOAD.W	D2,#-1XFER$:	INC.W	D2	LOAD.B	(A3+),(A4+)	; OSLNAM <-- nom du son	JUMP,NE XFER$	LOAD.W	(A6)+OEDCUR,D2	; OSLCUR <-- curseur  la fin	JUMP'	EXIT$RIEN$:	LOAD.W	D2,#BUTPLAY	CALL	BUTGREY;;?	LOAD.W	D2,#BUTREC;;?	CALL	BUTFULL	LOAD.W	D2,#BUTFILTRE	CALL	BUTGREY	LOAD.W	D2,#BUTCOUPE	CALL	BUTGREY	LOAD.W	D2,#BUTCOPIE	CALL	BUTGREY	LOAD.W	D2,#BUTEXTRAIT	CALL	BUTGREY	LOAD.W	D2,#BUTSUPPRIME	CALL	BUTGREYEXIT$:	CALL	EDITDRAW	; affiche le nom	POPM.L	D2,A3,A4	RET;-----------\\; MAINBUTMAJ >;===========/; Initialise le son en fonction des boutons presss.; in	-; out	-; mod	D7.WMAINBUTMAJ:	PUSHM.L	D2,D4,A4	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE EXIT$	LOAD.W	(A4)+OADHFREQ,#ADFREQ/8	LOAD.W	D2,#BUT4KHZ	CALL	BUTTEST	TEST.W	D4	JUMP',NE FREQ$	LOAD.W	(A4)+OADHFREQ,#ADFREQ/4	LOAD.W	D2,#BUT8KHZ	CALL	BUTTEST	TEST.W	D4	JUMP',NE FREQ$	LOAD.W	(A4)+OADHFREQ,#ADFREQ/2	LOAD.W	D2,#BUT17KHZ	CALL	BUTTEST	TEST.W	D4	JUMP',NE FREQ$	LOAD.W	(A4)+OADHFREQ,#MACFREQ	LOAD.W	D2,#BUT22KHZ	CALL	BUTTEST	TEST.W	D4	JUMP',NE FREQ$	LOAD.W	(A4)+OADHFREQ,#ADFREQFREQ$:EXIT$:	POPM.L	D2,D4,A4	RET;----------\\; MAINCLOSE >;==========/; Initialise le son avant de passer au nouveau.; in	-; out	-; mod	D7.WMAINCLOSE:	PUSHM.L	D4,A3,A4	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE EXIT$	LOAD.L	A3,#(A6)+OEDNAM	LOAD.L	A4,#(A4)+OADHNAMEXFER$:	COMP.B	(A4+),(A3+)	JUMP',EQ SAME$	INC.W	(A6)+OSLNCH	; OSLNCH <-- une diffrence de plusSAME$:	LOAD.B	(A4)-1,(A3)-1	JUMP,NE XFER$EXIT$:	POPM.L	D4,A3,A4	RET;---------\\; MAINGREY >;=========/; Grise qq boutons.; in	-; out	-; mod	D7.WMAINGREY:	PUSHM.L	D2	TEST.W	(A6)+OUNOP	; y'a-t-il qq chose  dfaire ?	JUMP',NE UNDO$		; oui => UNDO$	LOAD.W	D2,#BUTANNULE	CALL	BUTGREY		; ANNULE devient inactif	JUMP'	EXIT$UNDO$:	LOAD.W	D2,#BUTANNULE	CALL	BUTFULL		; ANNULE devient actif;	JUMP'	EXIT$EXIT$:	POPM.L	D2	RET;---------\\; MAINMISC >;=========/; Choix dans le mmenu du milieu.; in	-; out	D3.W	touche prese;	D7.W	erreur; mod	D3.L, D7.WMAINMISC:	PUSHM.L	D1,D2,D4,D5,A3,A4	CALL	MAINSETALL	; slectionne tout le son	LOAD.L	A4,#(A6)+OMMPM	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	CLR.L	(A4)+(LMM*1)+OMMINA	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA	TSET.B	(A4)+(LMM*0)+OMMINA+3:#3 ; grise "vue"	TEST.W	(A6)+OUNOP	; y'a-t-il qq chose  dfaire ?	JUMP',NE UNDO$		; oui => UNDO$	TSET.B	(A4)+(LMM*2)+OMMINA+3:#0 ; grise "annule"UNDO$:	PUSH.L	A4	CALL	MAINPSON	; A4 <-- ^son	POPM.L	A4	JUMP',EQ FULL$	TSET.B	(A4)+(LMM*1)+OMMINA+3:#3 ; grise "extrait"	TSET.B	(A4)+(LMM*2)+OMMINA+3:#2 ; grise "supprime"	TSET.B	(A4)+(LMM*2)+OMMINA+3:#3 ; grise "coupe"	TSET.B	(A4)+(LMM*2)+OMMINA+3:#4 ; grise "copie"FULL$:	LOAD.L	A3,#R16"MMENU$	; A3 <-- ^mmenu	CLR.L	D5		; D5 <-- mode	LIB	?MMENUS		; choix dans mmenu ...	JUMP,NE EXIT$	LOAD.W	D4,(A4)+(LMM*0)+OMMSEL	LOAD.L	A3,#R16"KFILE$	LOAD.W	D3,(A4)+(LMM*1)+OMMSEL	COMP.W	D4,#1	JUMP',EQ KEY$	LOAD.L	A3,#R16"KEDIT$	LOAD.W	D3,(A4)+(LMM*2)+OMMSEL	COMP.W	D4,#2	JUMP',EQ KEY$	LOAD.L	A3,#R16"KMAIN$	LOAD.W	D3,D4KEY$:	SL.W	D3,#1	LOAD.W	D3,(A3)+(D3.W)	; D3 <-- touche presse	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2,D4,D5,A3,A4	TEST.W	D7		; retour EQ/NE	RETKMAIN$:	.W	0	.W	0	.W	0	.W	0KFILE$:	.W	F1	.W	F2	.W	F3	.W	F4	.W	F0KEDIT$:	.W	UNDO	.W	F14	.W	H'100*(2^BKILL)+'S	.W	H'100*(2^BKILL)+SPACE	.W	H'100*(2^BCOPY)+SPACE	.W	H'100*(2^BCURSOR!2^BCOPY)+SPACE	.W	H'100*(2^BCURSOR)+SPACE	.W	H'100*(2^BSHOW)+SPACEMMENU$:	.ASCIZ	" "	.B	-1	.BW	-2,MFILE$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOFILE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  fichier"	.BW	-2,MEDIT$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOEDIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dition";	.BW	-2,MSHOW$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSHOW	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  vue"	.B	0MFILE$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPREND	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  prend.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOAJOUTE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  ajoute.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSAUVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  sauve.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOEXTRAIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  extrait.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOQUITTE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  quitte.."	.B	0MEDIT$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUNDO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  annule"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOEFFACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  efface.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSUPPRIME	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  supprime"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOCOUPE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  coupe"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOCOPIE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  copie"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOCOLLE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  colle <'<>"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOCOLLE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  colle <'>>"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOCLASSEUR	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  classeur.."	.B	0	.EVEN;-----------\\; MAINFILTRE >;===========/; Choix d'une opration pour le filtre.; in	-; out	D3.W	touche prese;	D7.W	erreur; mod	D3.L, D7.WMAINFILTRE:	PUSHM.L	D1,D2,D4,D5,A3,A4	CALL	MAINSETALL	; slectionne tout le son	LOAD.L	A4,#(A6)+OMMPF	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	LOAD.L	A3,#R16"MMENU$	; A3 <-- ^mmenu	CLR.L	D5		; D5 <-- mode	LIB	?MMENUS		; choix dans mmenu ...	JUMP',NE EXIT$	LOAD.L	A3,#R16"KMAIN$	LOAD.W	D3,(A4)+(LMM*0)+OMMSEL	SL.W	D3,#1	LOAD.W	D3,(A3)+(D3.W)	; D3 <-- touche presse	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2,D4,D5,A3,A4	TEST.W	D7		; retour EQ/NE	RETKMAIN$:	.W	0	.W	H'100*(2^BPROGRA)+'S	.W	H'100*(2^BPROGRA)+'V	.W	H'100*(2^BPROGRA)+'B	.W	H'100*(2^BPROGRA)+'E	.W	H'100*(2^BPROGRA)+'F	.W	H'100*(2^BPROGRA)+'IMMENU$:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSILENCE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  silence"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOVOLUME	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  volume.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOBRUIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  bruit.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOECHO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  cho.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOFREQ	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  frquence.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOREVERSE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  inverse"	.B	0	.EVEN;-----------\\; MAINSETALL >;===========/; Slectionne tout le signal.; in	-; out	-; mod	D7.WMAINSETALL:	CALL	MAININVALL	; inverse tout le signal	SET.B	(A6)+OSELALL	RET;-----------\\; MAINCLRALL >;===========/; Dslectionne tout le signal.; in	-; out	-; mod	D7.WMAINCLRALL:	TEST.B	(A6)+OSELALL	JUMP',F EXIT$	CALL	MAININVALL	; inverse tout le signal	CLR.B	(A6)+OSELALLEXIT$:	RET;-----------\\; MAININVALL >;===========/; Inverse tout le signal.; in	-; out	-; mod	D7.WMAININVALL:	PUSHM.L	D1,D2,A4	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE EXIT$	CLR.L	D1	LOAD.L	D2,(A4)+OADHLG	CALL	VISUINV		; inverse tout le signalEXIT$:	POPM.L	D1,D2,A4	RET;---------\\; MAINPLAY >;=========/; Fait entendre tout le son.; in	-; out	D7.W	erreur; mod	D7.WMAINPLAY:	PUSHM.L	D1,D2,A4	LOAD.W	D7,#1	TEST.B	(A6)+OAUDIO	; #AUDIO en fonction ?	JUMP',F EXIT$		; non => EXIT$	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE EXIT$	CALL	MAINSETALL	; slectionne tout le signal	CLR.L	D1		; D1 <-- temps dbut	LOAD.L	D2,(A4)+OADHLG	; D2 <-- temps fin	CALL	IOPLAY		; fait entendre la partie de sonEXIT$:	POPM.L	D1,D2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; MAINREC >;========/; Enregistre un son.; in	-; out	D7.W	erreur; mod	D7.WMAINREC:	PUSHM.L	D1..D4,A2..A4	LOAD.W	D7,#1	TEST.B	(A6)+OAUDIO	; #AUDIO en fonction ?	JUMP',F EXIT$		; non => EXIT$	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	CALL	IOFLUSHONE	; efface le son actuel	SL.W	D3,#2	LOAD.L	A2,#(A6)+OPSON	ADD.W	A2,D3	LOAD.W	D4,(A6)+ORCLGS	MUL.WU	D4,#ADFREQ	ADD.L	D4,#LADH	; D4 <-- ajoute place pour l'en-tte	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour nouveau son	JUMP',NE EXIT$	LOAD.L	(A2),A4		; OPSON <-- ^nouveau son	CALL	IOREC		; enregistre ...EXIT$:	POPM.L	D1..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MAINSELECT >;===========/; Action sur une zone slectionne.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WMAINSELECT:	PUSHM.L	D3..D5,A2..A4	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE EXIT$	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCURSOR	JUMP',BS CURSOR$	CALL	VISUSELECT	; slectionne le signal ...	JUMP,NE EXIT$	LOAD.L	(A6)+OSELTD,D1	LOAD.L	(A6)+OSELTF,D2	JUMP'	SELECT$CURSOR$:	LOAD.L	D1,(A6)+OSELTD	LOAD.L	D2,(A6)+OSELTF	CALL	VISUINV		; allume la zone slectionneSELECT$:	LOAD.L	A2,A4		; A2 <-- ^son	LOAD.L	A4,#(A6)+OMMPS	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	CLR.L	(A4)+(LMM*1)+OMMINA	COMP.L	D1,D2	JUMP',NE MENU$	TSET.B	(A4)+(LMM*0)+OMMINA+3:#1-0 ; grise "dtruit"	TSET.B	(A4)+(LMM*0)+OMMINA+3:#2-0 ; grise "coupe"	TSET.B	(A4)+(LMM*0)+OMMINA+3:#3-0 ; grise "copie"	TSET.B	(A4)+(LMM*0)+OMMINA+3:#7-0 ; grise "filtre"	TSET.B	(A4)+(LMM*0)+OMMINA+2:#8-8 ; grise "extrait"	TSET.B	(A4)+(LMM*0)+OMMINA+2:#9-8 ; grise "coute"MENU$:	LOAD.L	A3,#R16"MMENU$	; A3 <-- ^mmenu	CLR.L	D5		; D5 <-- mode	LIB	?MMENUS		; choix dans mmenu	PUSH.W	D7	CALL	VISUINV		; efface la zone slectionne	POP.W	D7	JUMP,NE EXIT$	LOAD.W	D3,(A4)+OMMSEL	; D3 <-- case slectionne	EX.L	A4,A2		; A4 <-- ^son	COMP.W	D3,#1	JUMP',EQ DETR$	COMP.W	D3,#2	JUMP',EQ COUPE$	COMP.W	D3,#3	JUMP',EQ COPIE$	COMP.W	D3,#4	JUMP',EQ COLLE$	COMP.W	D3,#5	JUMP',EQ COLLEP$	COMP.W	D3,#6	JUMP,EQ AMORCE$	COMP.W	D3,#7	JUMP,EQ FILTRE$	COMP.W	D3,#8	JUMP,EQ SAVE$	COMP.W	D3,#9	JUMP,EQ PLAY$	JUMP	OK$DETR$:	CALL	VISUDETRUIT	; supprime une partie	JUMP	OK$COUPE$:	CALL	VISUCOPYBLOC	; copie dans le bloc-notes	JUMP,NE EXIT$	JUMP	DETR$COPIE$:	CALL	VISUCOPYBLOC	; copie dans le bloc-notes	JUMP	EXIT$COLLE$:	CALL	VISUPASTBLOC	; colle le bloc-notes dans le son	JUMP,NE EXIT$	CALL	VISUDRAW	; montre le signal	CALL	INFOTAILLE	; affiche la taille du son	JUMP	OK$COLLEP$:	CALL	VISUPADDBLOC	; ajoute le bloc-notes dans le son	JUMP,NE EXIT$	CALL	VISUDRAW	; montre le signal	CALL	INFOTAILLE	; affiche la taille du son	JUMP	OK$AMORCE$:	CALL	DBOXAMORCE	; choix de la dure du silence ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$	LOAD.L	D2,(A6)+OAMLG	ADD.L	D2,D1	CALL	FILAMORCE	; ajoute une amorce (un silence)	CALL	VISUDRAW	; montre le signal	CALL	INFOTAILLE	; affiche la taille du son	JUMP	OK$FILTRE$:	LOAD.W	D3,(A2)+(LMM*1)+OMMSEL	JUMP,EQ SILENCE$	COMP.W	D3,#1	JUMP,EQ VOL$	COMP.W	D3,#2	JUMP,EQ BRUIT$	COMP.W	D3,#3	JUMP,EQ ECHO$	COMP.W	D3,#4	JUMP,EQ FREQ$	COMP.W	D3,#5	JUMP,EQ REVERSE$	JUMP	OK$SILENCE$:	CALL	FILSILENCE	; modifie le volume	CALL	VISUDRAW	; montre le signal	JUMP	OK$VOL$:	CALL	DBOXVOL		; choix des volumes ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$	CALL	FILVOLUME	; modifie le volume	CALL	VISUDRAW	; montre le signal	JUMP	OK$BRUIT$:	CALL	DBOXBRUIT	; choix des paramtres ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$	CALL	FILBRUIT	; modifie le son	CALL	VISUDRAW	; montre le signal	JUMP	OK$ECHO$:	CALL	DBOXECHO	; choix des paramtres ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$	CALL	FILECHO		; modifie le son	CALL	VISUDRAW	; montre le signal	CALL	INFOTAILLE	; affiche la taille du son	JUMP	OK$FREQ$:	CALL	DBOXFREQ	; choix des paramtres ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$	CALL	FILFREQ		; modifie le son	CALL	VISUDRAW	; montre le signal	CALL	INFOTAILLE	; affiche la taille du son	JUMP	OK$REVERSE$:	CALL	FILREVERSE	; modifie le son	CALL	VISUDRAW	; montre le signal	JUMP	OK$SAVE$:SAVE2$:	LOAD.L	A3,#(A6)+OBUNADD	CLR.L	D4	CALL	DBOXEDITEF	; demande un nom ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE OK$SAVE4$:	CALL	IOEXTRAIT	; crit un fichier .AUDIO	JUMP',EQ OK$	COMP.W	D7,#ERFAEX	JUMP',NE EXIT$	CALL	DBOXDETRUIT	; faut-il dtruire ?	COMP.W	D3,#F1	JUMP,NE SAVE2$	FOS	?DELETE	JUMP	SAVE4$PLAY$:	CALL	IOPLAY		; fait entendre la partie de son	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RETMMENU$:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODETRUIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOCOUPE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  coupe"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOCOPIE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  copie"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOCOLLE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  colle"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOCOLLEP	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  superpose "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOAMORCE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  silence.."	.B	-1	.BW	-2,MFILTRE$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOFILTRE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  filtre"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOEXTRAIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  extrait.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOECOUTE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  coute"	.B	0MFILTRE$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSILENCE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  silence"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOVOLUME	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  volume.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOBRUIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  bruit.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOECHO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  cho.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOFREQ	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  frquence.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOREVERSE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  inverse"	.B	0	.EVEN;---------\\; MAINBACK >;=========/; Revient en arrire en fonction de la dernire opration effectue.; in	-; out	D7.W	erreur; mod	D7.WMAINBACK:	PUSHM.L	A4	LOAD.W	D7,#1	TEST.W	(A6)+OUNOP	; y'a-t-il qq chose  dfaire ?	JUMP',EQ EXIT$		; non => EXIT$	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE EXIT$	CALL	VISUBACK	; revient en arrire	CALL	VISUDRAW	; montre le signal	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MAINVIDRAW >;-----------/; Affiche le son.; in	-; out	-; mod	D7.WMAINVIDRAW:	PUSH.L	A4	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE RIEN$	CALL	VISUDRAW	; dessine le son	JUMP'	EXIT$RIEN$:	CALL	VISUEMPTY	; dessine une zone videEXIT$:	CALL	INFOTAILLE	; affiche la taille du son	POP.L	A4	RET;-----------\\; MAINVIMOVE >;-----------/; Dplace le son.; in	-; out	D7.W	erreur; mod	D7.WMAINVIMOVE:	PUSH.L	A4	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE EXIT$	CALL	VISUMOVE	; dplace le son ...EXIT$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MAINSLDRAW >;-----------/; Dessine la scroll-liste vide.; in	-; out	-; mod	D7.WMAINSLDRAW:	PUSHM.L	A5	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables scroll-liste	SCROLL_	LDRAW		; dessine la scroll-liste	POPM.L	A5	RET;-------------\\; MAINSLUPDATE >;-------------/; Dessine le contenu de la scroll-liste.; in	-; out	-; mod	D7.WMAINSLUPDATE:	PUSHM.L	D2..D4,A4,A5	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables scroll-liste	LOAD.W	(A5)+OSLCYN,#MAXSON	LOAD.L	A4,#R16"MAINSLTEXT	LOAD.L	(A5)+OSLADL,A4	SCROLL_	LUPDATE		; dessine le contenu	POPM.L	D2..D4,A4,A5	RET;-----------\\; MAINSLMOVE >;-----------/; Dplace la scroll-liste.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WMAINSLMOVE:	PUSH.L	A5	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables scroll-liste	SCROLL_	LMOVE		; dplace ...	JUMP',NE EXIT$	CALL	VISUFLUSH	; copie plus valable	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	A5	RET;-----------\\; MAINSLTEXT >;-----------/; Donne le texte contenu dans une case.; in	D3.W	rang (0..n); out	A3.L	^texte;	D3.W	trait;	D7.W	erreur; mod	D3.L, D7.L, A3.LMAINSLTEXT:	PUSHM.L	D2,D4,A4	LOAD.L	A4,#(A6)+OBUDIS	CLR.L	D4	LOAD.W	D4,D3	INC.W	D4		; D4 <-- 1..n	LOAD.W	D3,#3	CLR.W	D2	LIB	?PUTDEC		; OBUDIS <-- numro	LOAD.B	(A4+),#':	LOAD.B	(A4+),#SPACE	CLR.B	(A4)	LOAD.L	A3,#(A6)+OPSON	DEC.W	D4	SL.W	D4,#2	LOAD.L	D3,(A3)+(D4.W)	JUMP',EQ FREE$	LOAD.L	A3,D3		; A3 <-- ^en-tte	LOAD.L	A3,#(A3)+OADHNAME ; A3 <-- ^nom	JUMP'	XFER$FREE$:	LOAD.L	A3,#R16"TXFREE$XFER$:	LOAD.B	(A4+),(A3+)	; OBUDIS <-- nom	JUMP,NE XFER$OK$:	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^texte	CLR.W	D3		; D3 <-- pas de trait	POPM.L	D2,D4,A4	CLR.W	D7		; D7 <-- ok	RETTXFREE$:.ASCIZ	"<'<> crer<'>>"	.EVEN;---------\\; MAINPSON >;=========/; Cherche le son slectionn dans la scroll-liste.; in	-; out	A4.L	^son;	D7.W	erreur; mod	D7.W, A4.LMAINPSON:	PUSH.L	D4	LOAD.W	D7,#1	LOAD.W	D4,(A6)+OSLVAR+OSLCYS	SL.W	D4,#2	LOAD.L	A4,#(A6)+OPSON	LOAD.L	D4,(A4)+(D4.W)	JUMP',EQ EXIT$	LOAD.L	A4,D4		; A4 <-- ^son	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; MAINPCREATE >;============/; Cre un son vide dans la scroll-liste.; in	-; out	A4.L	^son;	D7.W	erreur; mod	D7.W, A4.LMAINPCREATE:	PUSHM.L	D4,A2	LOAD.W	D4,(A6)+OSLVAR+OSLCYS	SL.W	D4,#2	LOAD.L	A2,#(A6)+OPSON	ADD.W	A2,D4	CALL	IOCREATEONE	; cre un son vide	JUMP',NE EXIT$	LOAD.L	A4,(A2)		; A4 <-- ^son videEXIT$:	POPM.L	D4,A2	TEST.W	D7		; retour EQ/NE	RET	.END