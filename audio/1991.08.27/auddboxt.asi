	.SBTTL	AUDDBOXT.ASI;---------\\; DBOXOPEN >;---------/; Ouvre une dbox.; in	A2.L	table;	D2.W	mode; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WDBOXOPEN:	PUSH.L	D3	CALL	DBOXOPEN1	DBOX_	OPEN		; ouvre la dbox	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETDBOXOPEN1:	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	RET;----------\\; DBOXCLOSE >;----------/; Ferme une dbox.; in	D5.L	canal; out	D7.W	erreur; mod	D7.WDBOXCLOSE:	PUSH.W	D7	DBOX_	CLOSE		; ferme la dbox	POP.W	D7DBOXCLOSE1:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	RET;-----------\\; DBOXZEROCR >;===========/; Remplace le terminateur <CR> par <0>.; Utile aprs DBOX_EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-DBOXZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ EXIT$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>EXIT$:	POP.L	A3	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXMEMPT >;==========/; Donne le ^ la table de la dbox.; in	A2.L	^table de la dbox; out	-; mod	D7.WDBOXMEMPT:	LOAD.L	(A6)+ODBPTE,A2	; ODBPTE <-- ^table dbox	RET;----------\\; DBOXMEDIT >;==========/; Donne la bonne valeur  DBOX_MEDIT.; in	D2.W	rang (0..n);	D5.L	canal dbox; out	-; mod	D7.WDBOXMEDIT:	PUSHM.L	D2,D3,A2	LOAD.W	D3,D2	COMP.W	D3,#-1	JUMP',EQ 50$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D3,(A2)+ODBRED50$:	DBOX_	MEDIT	POPM.L	D2,D3,A2	RET;---------\\; DBOXCLIC >;=========/; Incrmente v. un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox; out	D2.W	rang (0..n);	A3.L	^dbut ligne;	A4.L	^curseur dans ligne; mod	D2.L, D7.W, A3.L, A4.LDBOXCLIC:	PUSHM.L	D0,D1,D3,D4,A0,A2	PUSH.W	D2	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	CALL	DBOXPUT		; mj. paramtre ditable	JUMP,NE ERROR$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE ERROR$	SUB.W	D4,(A0)+ODFFX	JUMP,LO ERROR$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP,LO ERROR$	SWAP.W	D4	LOAD.L	D1,D4		; D1 <-- position de la souris	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	CLR.W	D0		; D0 <-- rangLOOP$:	COMP.W	(A2),#-1	JUMP,EQ ERROR$	TEST.W	(A2)+ODBINC	JUMP',EQ NEXT2$	LOAD.W	D2,(A2)+ODBRGC	DBOX_	GETCO	ADD.W	D4,(A0)+ODFCX	ADD.W	D4,#6	COMP.W	D1,D4	JUMP',LO NEXT2$	ADD.W	D4,#12+4	COMP.W	D1,D4	JUMP',HS NEXT2$	SWAP.W	D1	SWAP.W	D4	SUB.W	D4,#6+12	COMP.W	D1,D4	JUMP',LO NEXT1$	ADD.W	D4,#12	COMP.W	D1,D4	JUMP',LO INC$	ADD.W	D4,#12	COMP.W	D1,D4	JUMP',LO DEC$NEXT1$:	SWAP.W	D1NEXT2$:	LOAD.L	A2,#(A2)+LDB	; A2 <-- ^suivant	INC.W	D0		; D0 <-- rang suivant	JUMP	LOOP$INC$:	LOAD.W	D1,(A2)+ODBINC	; D1 <-- +incrment	JUMP'	MOD$DEC$:	LOAD.W	D1,(A2)+ODBINC	NEG.W	D1		; D1 <-- -incrment;	JUMP'	MOD$MOD$:	PUSH.L	D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	POP.L	D3	SUB.W	D3,#12	SWAP.W	D3	SUB.W	D3,#12+1+4	LOAD.L	D4,#H'10000*13+15	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; allume +/-	PUSHM.L	D3,D4	CALL	DBOXCLICINC	; incrmente le paramtre	LOAD.W	D2,#20		; D2 <-- premier dlaiMLOOP$:	LOAD.W	D4,D2	NTREL	?SETTIM	LIB	?GETCAR		; attend souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP',EQ MEND$	CALL	DBOXCLICINC	; incrmente le paramtre	LOAD.W	D2,#8		; D2 <-- dlai de rptition	JUMP	MLOOP$MEND$:	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; teint +/-	LOAD.W	D2,D0		; D2 <-- rang	CALL	DBOXMEDIT	ADD.L	SP,#2		; POP.W D2 bidon	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	POP.W	D2	CALL	DBOXGET		; A3/A4 <-- ^dbut/ligne	LOAD.W	D7,#1		; D7 <-- erreurEXIT$:	POPM.L	D0,D1,D3,D4,A0,A2	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXCLICINC >;------------/; Incrmente un paramtre.; in	A2.L	^dans table dbox;	D5.L	canal dbox;	D1.W	+/- incrment;	D0.W	rang; out	A3.L	^dbut ligne;	A4.L	^curseur dans ligne; mod	D7.W, A3.L, A4.LDBOXCLICINC:	PUSHM.L	D2..D4	LOAD.W	D2,(A2)+ODBOFF	; D2 <-- offset variable	COMP.B	(A2)+ODBTYP+1,#DBTYPS	JUMP,EQ SEC$	LOAD.W	D4,(A6)+(D2.W)	; D4 <-- nombre initial	COMP.B	(A2)+ODBTYP+1,#DBTYPNF	JUMP',NE NUMF2$NUMF1$:	COMP.W	D4,#-1	JUMP',NE NUMF2$	CLR.W	D4NUMF2$:	ADD.W	D4,D1		; D4 <-- +/- incrment	LOAD.W	D3,(A2)+ODBMIN	TEST.B	(A2)+ODBTYP+0:#14-8	JUMP',BC PUTNUM1$	LOAD.W	D3,(A6)+(D3.W)PUTNUM1$:	COMP.W	D4,D3	JUMP',GE PUTNUM2$	LOAD.W	D4,D3PUTNUM2$:	LOAD.W	D3,(A2)+ODBMAX	TEST.B	(A2)+ODBTYP+0:#15-8	JUMP',BC PUTNUM3$	LOAD.W	D3,(A6)+(D3.W)PUTNUM3$:	COMP.W	D4,D3	JUMP',LE PUTNUM4$	LOAD.W	D4,D3PUTNUM4$:	COMP.B	(A2)+ODBTYP+1,#DBTYPNF	JUMP',NE NUMF4$NUMF3$:	TEST.W	D4	JUMP',NE NUMF4$	DEC.W	D4		; D4 <-- -1NUMF4$:	COMP.W	D4,(A6)+(D2.W)	JUMP,EQ EXIT$	LOAD.W	(A6)+(D2.W),D4	; mj. le nombre	JUMP	DRAW$SEC$:	LOAD.L	D4,(A6)+(D2.W)	; D4 <-- nombre initial	CONV.LA.WA D1	ADD.L	D4,D1		; D4 <-- +/- incrment	CLR.L	D3	LOAD.W	D3,(A2)+ODBMIN	TEST.B	(A2)+ODBTYP+0:#14-8	JUMP',BC SEC1$	LOAD.L	D3,(A6)+(D3.W)SEC1$:	COMP.L	D4,D3	JUMP',GE SEC2$	LOAD.L	D4,D3SEC2$:	CLR.L	D3	LOAD.W	D3,(A2)+ODBMAX	TEST.B	(A2)+ODBTYP+0:#15-8	JUMP',BC SEC3$	LOAD.L	D3,(A6)+(D3.W)SEC3$:	COMP.L	D4,D3	JUMP',LE SEC4$	LOAD.L	D4,D3SEC4$:	COMP.L	D4,(A6)+(D2.W)	JUMP',EQ EXIT$	LOAD.L	(A6)+(D2.W),D4	; mj. le nombreDRAW$:	LOAD.W	D2,D0		; D2 <-- rang	CALL	DBOXGET		; A3/A4 <-- ^dbut/ligne	PUSH.W	(A2)+ODBINC	CLR.W	(A2)+ODBINC	; pour ne pas rafficher +/- !	CALL	DBOXAFF		; affiche la nouvelle valeur	POP.W	(A2)+ODBINCEXIT$:	POPM.L	D2..D4	RET;--------\\; DBOXAFF >;========/; Affiche un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox; out	-; mod	D7.WDBOXAFF:	PUSHM.L	D2..D4,A0,A2..A4	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	COMP.W	D2,#-1	JUMP,EQ EXIT$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D2,(A2)+ODBRGC	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A4,A3	LOAD.W	D3,#-1CNT$:	INC.W	D3		; D3 <-- nombre de caractres	TEST.B	(A4+)	JUMP,NE CNT$	COMP.W	D3,(A2)+ODBNBC	; y'a-t-il assez de place pour tout afficher ?	JUMP',HS LONG$		; non => LONG$	LIB	?AFTEXT		; affiche le texte	LOAD.W	D2,(A2)+ODBNBC	SUB.W	D2,D3	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D2	LIB	?AFCAR		; efface la fin	JUMP'	INC$LONG$:	SUB.W	D3,(A2)+ODBNBC	ADD.W	D3,#1+1	ADD.W	A3,D3		; A3 <-- saute le dbut	LOAD.B	D3,#5!2^7	LIB	?AFCODE		; affiche "<" invers	LOAD.W	D3,(A2)+ODBNBC	SUB.W	D3,#1+1	LIB	?STRING		; affiche la fin du texte	LIB	?AFSPACEINC$:	TEST.W	(A2)+ODBINC	; +/- incrment existe ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	ADD.W	D4,(A0)+ODFCX	ADD.W	D4,#5	SWAP.W	D4	SUB.W	D4,#6+12;	SWAP.W	D4	LOAD.L	(A3)+1,D4	LOAD.L	A4,#R16"MATRIX$	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#SETDOT	LOAD.W	D3,#10	LIB	?STRINGEXIT$:	POPM.L	D2..D4,A0,A2..A4	RETMATRIX$:	.B	16,25	.W	B'0000000100000000	.W	B'0000001010000000	.W	B'0000010001000000	.W	B'0000100000100000	.W	B'0001000000010000	.W	B'0010000000001000	.W	B'0111100000111100	.W	B'0000100100100000	.W	B'0000101110100000	.W	B'0000100100100000	.W	B'0000100000100000	.W	B'0000111111100000	.W	B'0000000000000000	.W	B'0000111111100000	.W	B'0000100000100000	.W	B'0000100000100000	.W	B'0000101110100000	.W	B'0000100000100000	.W	B'0111100000111100	.W	B'0010000000001000	.W	B'0001000000010000	.W	B'0000100000100000	.W	B'0000010001000000	.W	B'0000001010000000	.W	B'0000000100000000;--------\\; DBOXGET >;========/; Donne le contenu d'un paramtre ditable.; in	D2.W	rang (0..n);	D5.L	canal dbox; out	A3.L	^dbut ligne;	A4.L	^curseur dans ligne; mod	D7.W, A3.L, A4.LDBOXGET:	PUSHM.L	D2..D4,D6,A1,A2	LOAD.L	A3,#(A6)+ODBLIN	LOAD.L	A4,A3	CLR.B	(A4)	COMP.W	D2,#-1	JUMP,EQ EXIT$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D2,(A2)+ODBOFF	; D2 <-- offset variable	COMP.B	(A2)+ODBTYP+1,#DBTYPN	JUMP',EQ NUM$	COMP.B	(A2)+ODBTYP+1,#DBTYPNS	JUMP',EQ NUMS$	COMP.B	(A2)+ODBTYP+1,#DBTYPNF	JUMP,EQ NUMF$	COMP.B	(A2)+ODBTYP+1,#DBTYPS	JUMP,EQ SEC$	COMP.B	(A2)+ODBTYP+1,#DBTYPA	JUMP,EQ ALPHA$	JUMP	EXIT$NUM$:	CLR.L	D4	LOAD.W	D4,(A6)+(D2.W)	; D4 <-- nombre	CALL	PUTANUM		; ODBLIN <-- nombre	CLR.B	(A4)	JUMP	EXIT$NUMS$:	LOAD.B	D3,#'+	CLR.L	D4	LOAD.W	D4,(A6)+(D2.W)	; D4 <-- nombre	JUMP',NC NUMSP$	NEG.W	D4	LOAD.B	D3,#'-NUMSP$:	LOAD.B	(A4+),D3	; ODBLIN <-- signe (+/-)	CALL	PUTANUM		; ODBLIN <-- nombre	CLR.B	(A4)	JUMP	EXIT$NUMF$:	CLR.L	D4	LOAD.W	D4,(A6)+(D2.W)	; D4 <-- nombre	JUMP',NS NUMF2$	CALL	PUTANUM		; ODBLIN <-- nombreNUMF2$:	CLR.B	(A4)	JUMP'	EXIT$SEC$:	LOAD.L	D4,(A6)+(D2.W)	; D4 <-- nombre	CALL	PUTSNUM		; ODBLIN <-- nombre	CLR.B	(A4)	JUMP'	EXIT$ALPHA$:	LOAD.L	A1,#(A6)+(D2.W)	; A1 <-- ^chaneALPHA1$:	LOAD.B	(A4+),(A1+)	; ODBLIN <-- chane	JUMP,NE ALPHA1$	DEC.L	A4;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4,D6,A1,A2	RET;--------\\; DBOXPUT >;========/; Met  jour un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox; out	D7.W	erreur; mod	D7.WDBOXPUT:	CALL	DBOXMAJ		; met  jour	JUMP',NE EXIT$	PUSHM.L	A3,A4	CALL	DBOXGET		; A3 <-- ^paramtre	CALL	DBOXAFF		; raffiche correctement	POPM.L	A3,A4	CLR.W	D7		; D7 <-- okEXIT$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXMAJ >;--------/; Met  jour un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox; out	D7.W	erreur; mod	D7.WDBOXMAJ:	PUSHM.L	D2..D4,D6,A2..A4	CLR.W	D7		; D7 <-- ok	COMP.W	D2,#-1	JUMP,EQ EXIT$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D2,(A2)+ODBOFF	; D2 <-- offset variable	COMP.B	(A2)+ODBTYP+1,#DBTYPN	JUMP',EQ NUM$	COMP.B	(A2)+ODBTYP+1,#DBTYPNS	JUMP,EQ NUMS$	COMP.B	(A2)+ODBTYP+1,#DBTYPNF	JUMP,EQ NUMF$	COMP.B	(A2)+ODBTYP+1,#DBTYPS	JUMP,EQ SEC$	COMP.B	(A2)+ODBTYP+1,#DBTYPA	JUMP,EQ ALPHA$	LOAD.W	D7,#ERSYNT	; D7 <-- erreur	JUMP	EXIT$NUM$:	LOAD.L	A4,A3	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$PUTNUM$:	LOAD.W	D3,(A2)+ODBMIN	TEST.B	(A2)+ODBTYP+0:#14-8	JUMP',BC PUTNUM1$	LOAD.W	D3,(A6)+(D3.W)PUTNUM1$:	COMP.W	D4,D3	JUMP',GE PUTNUM2$	LOAD.W	D4,D3PUTNUM2$:	LOAD.W	D3,(A2)+ODBMAX	TEST.B	(A2)+ODBTYP+0:#15-8	JUMP',BC PUTNUM3$	LOAD.W	D3,(A6)+(D3.W)PUTNUM3$:	COMP.W	D4,D3	JUMP',LE PUTNUM4$	LOAD.W	D4,D3PUTNUM4$:	LOAD.W	(A6)+(D2.W),D4	; mj. le nombre	CLR.W	D7		; D7 <-- ok	JUMP	EXIT$NUMS$:	LOAD.L	A4,A3	LOAD.B	D3,#'-	COMP.B	D3,(A4+)	JUMP',EQ NUMS2$	LOAD.B	D3,#'+	COMP.B	D3,(A4)-1	JUMP',EQ NUMS2$	DEC.L	A4NUMS2$:	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$	COMP.B	D3,#'-	JUMP,NE PUTNUM$	NEG.W	D4	JUMP	PUTNUM$NUMF$:	LOAD.L	A4,A3	LOAD.W	D4,#-1	TEST.B	(A4)	JUMP,EQ PUTNUM4$	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$	JUMP	PUTNUM$SEC$:	LOAD.L	A4,A3	CALL	GETSNUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$	CLR.L	D3	LOAD.W	D3,(A2)+ODBMIN	TEST.B	(A2)+ODBTYP+0:#14-8	JUMP',BC SEC1$	LOAD.L	D3,(A6)+(D3.W)SEC1$:	COMP.L	D4,D3	JUMP',GE SEC2$	LOAD.L	D4,D3SEC2$:	CLR.L	D3	LOAD.W	D3,(A2)+ODBMAX	TEST.B	(A2)+ODBTYP+0:#15-8	JUMP',BC SEC3$	LOAD.L	D3,(A6)+(D3.W)SEC3$:	COMP.L	D4,D3	JUMP',LE SEC4$	LOAD.L	D4,D3SEC4$:	LOAD.L	(A6)+(D2.W),D4	; mj. le nombre	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ALPHA$:	LOAD.L	A4,#(A6)+(D2.W)	; A4 <-- ^chaneALPHA1$:	LOAD.B	(A4+),(A3+)	; mj. chane	JUMP,NE ALPHA1$	CLR.W	D7		; D7 <-- ok;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\; DBOXHLINE >;==========/; Trace une ligne horizontale dans une dbox.; in	D2.W	rang de l'objet; out	D3.L	position d'arrive; mod	D3.L, D7.WDBOXHLINE:	PUSHM.L	D2,D4,A4	LIB	?GETPDIS	; A4 <-- ^descripteur fentre	DBOX_	GETCO	CLR.W	D3	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A4)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2,D4,A4	RET;--------\\; DBOXRSK >;========/; Refait les soft-keys.; in	A2.L	^table DBOX; out	-; mod	D7.WDBOXRSK:	PUSHM.L	D3,A3	LOAD.W	D3,(A2)+2	LOAD.L	A3,#(A2)+(D3.W)	LIB	?AFMENU		; refait les soft-keys	POPM.L	D3,A3	RET; Gestion de la dbox d'attente; ----------------------------;---------\\; WAITDBOX >;=========/; Met la dbox d'attente.; in	-; out	D7.W	erreur; mod	D7.WWAITDBOX:	PUSHM.L	D2..D5,A2	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A2,#R16"TDBOX_WAIT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP',NE EXIT$	LOAD.L	(A6)+OOPCDB,D5	CLR.W	(A6)+OOPASC+OSCHTV ; ascenseur pas dessinEXIT$:	POPM.L	D2..D5,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; AFFNDBOX >;=========/; Affiche le nb de blocs restant dans la dbox d'attente.; in	D0.W	nb de blocs restant; out	-; mod	D7.WAFFNDBOX:	PUSHM.L	D2..D5,A5	TEST.L	(A6)+OOPCDB	; dbox existe ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.L	A5,#(A6)+OOPASC	; A5 <-- ^variables de l'ascenseur	TEST.W	(A5)+OSCHTV	; ascenseur dj dessin ?	JUMP,NE 50$		; oui => 50$				; non => 	LOAD.L	D5,(A6)+OOPCDB	; D5 <-- canal dbox	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	LOAD.W	(A5)+OSCDEBL,D3	SWAP.W	D3	LOAD.W	(A5)+OSCDEBO,D3	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,D3	SUB.W	D4,D3	LOAD.W	(A5)+OSCHTR,D4	LOAD.W	(A5)+OSCHTV,D0	SET.B	(A5)+OSCHOR	SCROLL_	DRAW		; dessine l'ascenseur	LOAD.W	(A6)+OOPDIV,#2	COMP.W	D0,D4	JUMP',LS 50$	PUSH.W	D0	AND.L	D0,#H'FFFF	DIV.WU	D0,D4	SL.W	D0,#2	LOAD.W	(A6)+OOPDIV,D0	POP.W	D050$:	CLR.L	D2	LOAD.W	D2,D0	DIV.WU	D2,(A6)+OOPDIV	SWAP.W	D2	TEST.W	D2	JUMP',NE EXIT$	LOAD.W	D3,(A5)+OSCHTV	SUB.W	D3,D0	LOAD.W	(A5)+OSCPOSV,D3	SCROLL_	UPDATE		; dplace l'ascenseurEXIT$:	POPM.L	D2..D5,A5	RET;---------\\; NORMDBOX >;=========/; Enlve la dbox d'attente.; in	-; out	-; mod	-NORMDBOX:	PUSHM.L	D5,D7	LOAD.L	D5,(A6)+OOPCDB	JUMP',EQ EXIT$	DBOX_	CLOSE		; ferme la DBOX	CALL	AFMENU		; refait les soft-keys	CLR.L	(A6)+OOPCDBEXIT$:	POPM.L	D5,D7	RETTDBOX_WAIT:	.W	10$-TDBOX_WAIT	.W	20$-TDBOX_WAIT	.W	0,010$:	.B	ODBCR,ODBCR	.B	ODBLABEL,1	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"       Attendez un instant ...      "	.B	ODBCR,ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENDOKCR:	LOAD.W	D3,#CR	RETDOKEND:	LOAD.W	D3,#END	RETDOKOUI:	LOAD.W	D3,#'O	RETDOKNON:	LOAD.W	D3,#'N	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RET	.END