	.SBTTL	AUDREGLE.ASI;----------\\; DRAWREGLE >;==========/; Dessine une jolie rgle horizontale gradue en secondes.; in	A5.L	^descripteur rgle (ORG*); out	-; mod	D7.WDRAWREGLE:	PUSHM.L	D2..D4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORFREG	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLORCREG	LIB	?COLORSR	; donne la couleur du dessin	CLR.L	D4	CALL	INVTRAME	CALL	DRMDEF		; dfini trame pour effacer	LOAD.L	D3,(A5)+ORGPO	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	LOAD.W	D4,#LGREGLE	SWAP.W	D4	LOAD.W	D4,(A5)+ORGLG	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRRECT		; met le rectangle autour	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	CALL	INVMODE	LIB	?DRTRAME	; efface toute la rgle; Dessine les lignes des graduations.	LOAD.L	D3,#COLORLREG	LIB	?COLORSR	; donne la couleur des lignes	LOAD.L	D3,(A5)+ORGOFF	DIV.WU	D3,(A5)+ORGPAS	MUL.WU	D3,(A5)+ORGPAS	; D3 <-- temps dbut	LOAD.W	D4,(A5)+ORGLG	MUL.WU	D4,(A5)+ORGFAC	ADD.L	D4,(A5)+ORGOFF	; D4 <-- temps maximalLLOOP$:	CALL	LINEREGLE	; dessine une ligne	CLR.L	D2	LOAD.W	D2,(A5)+ORGPAS	ADD.L	D3,D2		; D3 <-- temps suivant	COMP.L	D3,D4	JUMP',LO LLOOP$; Dessine les chiffres des graduations.	LOAD.L	D3,#COLORGREG	LIB	?COLORSR	; donne la couleur des caractres	LOAD.L	D3,(A5)+ORGOFF	DIV.WU	D3,(A5)+ORGPAS	MUL.WU	D3,(A5)+ORGPAS	; D3 <-- temps dbut	LOAD.W	D4,(A5)+ORGLG	MUL.WU	D4,(A5)+ORGFAC	ADD.L	D4,(A5)+ORGOFF	; D4 <-- temps maximalGLOOP$:	CALL	GRADREGLE	; dessine un chiffre	CLR.L	D2	LOAD.W	D2,(A5)+ORGPAS	ADD.L	D3,D2		; D3 <-- temps suivant	COMP.L	D3,D4	JUMP',LO GLOOP$	LIB	?COLORPOP	; restitue les couleurs	POPM.L	D2..D4	RET;----------\\; LINEREGLE >;----------/; Dessine une ligne pour indiquer une fraction de seconde.; in	D3.L	temps; out	-; mod	D7.WLINEREGLE:	PUSHM.L	D2..D4	LOAD.L	D2,D3	DIV.WU	D2,(A5)+ORGPAS	; D2 <-- rang de la graduation	SUB.L	D3,(A5)+ORGOFF	JUMP',LO EXIT$	DIV.WU	D3,(A5)+ORGFAC	ADD.W	D3,(A5)+ORGPO+2	SWAP.W	D3	LOAD.W	D3,(A5)+ORGPO+0	ADD.W	D3,#LGREGLE-2	SWAP.W	D3	LOAD.W	D4,#-(LGREGLE-1); D4 <-- toute la hauteur	AND.L	D2,#H'FFFF	DIV.WU	D2,#10		; D2 <-- rang/10	SWAP.W	D2		; D2 <-- reste de la division	TEST.W	D2	JUMP',EQ DRAW$	LOAD.W	D4,#-6		; D4 <-- hauteur moyenne	COMP.W	D2,#5	JUMP',EQ DRAW$	LOAD.W	D4,#-3		; D4 <-- petite hauteurDRAW$:	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRSEG		; dessine une barrette verticaleEXIT$:	POPM.L	D2..D4	RET;----------\\; GRADREGLE >;----------/; Dessine un chiffre dans la graduation.; in	D3.L	temps; out	-; mod	D7.WGRADREGLE:	PUSHM.L	D1..D5	LOAD.L	D2,D3	DIV.WU	D2,(A5)+ORGPAS	; D2 <-- rang de la graduation	AND.L	D2,#H'FFFF	DIV.WU	D2,#10	SWAP.W	D2	TEST.W	D2		; est-ce une dizaine (0,1,2,3...) ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.L	D4,D3	SUB.L	D4,(A5)+ORGOFF	JUMP',LO EXIT$	DIV.WU	D4,(A5)+ORGFAC	ADD.W	D4,(A5)+ORGPO+2	ADD.W	D4,#2	SWAP.W	D4	LOAD.W	D4,(A5)+ORGPO+0	INC.W	D4	SWAP.W	D4	LOAD.L	D2,D3	DIV.WU	D2,#ADFREQ/1000	; D2 <-- chiffre *1000	AND.L	D2,#H'FFFF	EX.L	D2,D4	LIB	?BINBCD	EX.L	D2,D4	LOAD.L	D3,D2	SWAP.W	D3	AND.B	D3,#B'1111	JUMP',EQ UNIT$	CALL	REGLECAR	; affiche la dizaine	ADD.W	D4,#LXCAR+1UNIT$:	LOAD.L	D3,D2	RL.W	D3,#4	CALL	REGLECAR	; affiche l'unit	ADD.W	D4,#LXCAR+1	TEST.W	(A5)+ORGDEC	JUMP',EQ EXIT$	LOAD.B	D3,#10	CALL	REGLECAR	; affiche le point	ADD.W	D4,#3	LOAD.L	D3,D2	RR.W	D3,#8	CALL	REGLECAR	; affiche le premire dcimale	ADD.W	D4,#LXCAR+1	COMP.W	(A5)+ORGDEC,#1	JUMP',EQ EXIT$	LOAD.L	D3,D2	RR.W	D3,#4	CALL	REGLECAR	; affiche la deuxime dcimale	ADD.W	D4,#LXCAR+1	COMP.W	(A5)+ORGDEC,#2	JUMP',EQ EXIT$	LOAD.L	D3,D2	CALL	REGLECAR	; affiche la troisime dcimaleEXIT$:	POPM.L	D1..D5	RET;-----------\\; INFOTAILLE >;===========/; Affiche la taille du son.; in	-; out	-; mod	D7.WINFOTAILLE:	PUSHM.L	D2..D4,A3..A5	LOAD.L	A5,#(A6)+ORGVAR	; A5 <-- ^variables rgle !	LIB	?COLORPUSH	LOAD.L	D3,#COLORCDISK	LIB	?COLORSR	LOAD.L	D3,#COLORFBUT	LIB	?COLORCR	CLR.L	D4	CALL	INVTRAME	CALL	DRMDEF	LOAD.L	D3,#H'10000*(LYWDO-36-1)+456	LOAD.L	D4,#H'10000*LYCAR+((LXCAR+1)*5)	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'ancienne taille	CALL	MAINPSON	; A4 <-- ^son	JUMP,NE END$	LOAD.L	D4,(A4)+OADHLG	COMP.W	(A4)+OADHFREQ,#MACFREQ	JUMP',EQ MAC$	LOAD.W	D3,#3	COMP.W	(A4)+OADHFREQ,#ADFREQ/8	JUMP',EQ SHIFT$	LOAD.W	D3,#2	COMP.W	(A4)+OADHFREQ,#ADFREQ/4	JUMP',EQ SHIFT$	LOAD.W	D3,#1	COMP.W	(A4)+OADHFREQ,#ADFREQ/2	JUMP',EQ SHIFT$	CLR.W	D3SHIFT$:	SR.L	D4,D3	JUMP'	DRAW$MAC$:	CALL	CONV8TO5DRAW$:	SR.L	D4,#8	SR.L	D4,#2		; D4 <-- /1024	INC.L	D4	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LOAD.L	A4,#(A6)+OBUDIS+20	LIB	?PUTDEC		; OBUDIS <--  nb de kilos	LOAD.W	D3,D4	LOAD.L	D4,#H'10000*(LYWDO-36-1)+456	COMP.W	D3,#1000	JUMP',HS POS$	ADD.W	D4,#LXCAR	COMP.W	D3,#10	JUMP',HS POS$	ADD.W	D4,#LXCARPOS$:	LOAD.L	A4,#(A6)+OBUDIS+20LOOP$:	LOAD.B	D3,(A4+)	SUB.B	D3,#'0	JUMP',LO KILO$	COMP.B	D3,#9	JUMP',HI KILO$	CALL	REGLECAR	ADD.W	D4,#LXCAR+1	JUMP	LOOP$KILO$:	LOAD.W	D3,#11		; D3 <-- "k"	CALL	REGLECAREND$:	LIB	?COLORPOP	POPM.L	D2..D4,A3..A5	RET;---------\\; REGLECAR >;---------/; Affiche un chiffre (graduation) dans une rgle.; in	D3.B	chiffre (0..9, 10=".", 11="k");	D4.L	coin sup/gauche (y;x); out	-; mod	D7.WREGLECAR:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,#R16"TCHIFFRES	AND.W	D3,#B'1111	MUL.WU	D3,#2+7	ADD.L	A4,D3	CLR.W	D3	LOAD.B	D3,(A4)+0	; D3 <-- largeur	ADD.W	D3,D4	LOAD.W	D2,(A5)+ORGPO+2	ADD.W	D2,(A5)+ORGLG	COMP.W	D3,D2		; dpasse  droite ?	JUMP',HI EXIT$		; oui => EXIT$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	SWAP.W	D4	LOAD.L	(A3)+1,D4	; <xx> et <yy>	LOAD.L	(A3)+5,A4	; <pppp>	LOAD.W	D2,#SETDOT	CALL	INVMODE	OR.W	D2,#PENDOT	LOAD.B	(A3)+9,D2	; <m>	LOAD.W	D3,#10	LIB	?STRING		; affiche un chiffreEXIT$:	POPM.L	D2..D4,A3,A4	RETTCHIFFRES:			; 0	.B	LXCAR,LYCAR	.B	B'01100000	.B	B'10010000	.B	B'10010000	.B	B'10010000	.B	B'10010000	.B	B'10010000	.B	B'01100000				; 1	.B	LXCAR,LYCAR	.B	B'00100000	.B	B'01100000	.B	B'00100000	.B	B'00100000	.B	B'00100000	.B	B'00100000	.B	B'01110000				; 2	.B	LXCAR,LYCAR	.B	B'01100000	.B	B'10010000	.B	B'00010000	.B	B'00100000	.B	B'01000000	.B	B'10000000	.B	B'11110000				; 3	.B	LXCAR,LYCAR	.B	B'01100000	.B	B'10010000	.B	B'00010000	.B	B'00100000	.B	B'00010000	.B	B'10010000	.B	B'01100000				; 4	.B	LXCAR,LYCAR	.B	B'00010000	.B	B'00110000	.B	B'01010000	.B	B'10010000	.B	B'11110000	.B	B'00010000	.B	B'00010000				; 5	.B	LXCAR,LYCAR	.B	B'11110000	.B	B'10000000	.B	B'11100000	.B	B'00010000	.B	B'00010000	.B	B'10010000	.B	B'01100000				; 6	.B	LXCAR,LYCAR	.B	B'01100000	.B	B'10010000	.B	B'10000000	.B	B'11100000	.B	B'10010000	.B	B'10010000	.B	B'01100000				; 7	.B	LXCAR,LYCAR	.B	B'11110000	.B	B'00010000	.B	B'00100000	.B	B'00100000	.B	B'01000000	.B	B'01000000	.B	B'01000000				; 8	.B	LXCAR,LYCAR	.B	B'01100000	.B	B'10010000	.B	B'10010000	.B	B'01100000	.B	B'10010000	.B	B'10010000	.B	B'01100000				; 9	.B	LXCAR,LYCAR	.B	B'01100000	.B	B'10010000	.B	B'10010000	.B	B'01110000	.B	B'00010000	.B	B'10010000	.B	B'01100000				; .	.B	3,LYCAR	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'01000000	.B	B'01000000				; k	.B	LXCAR,LYCAR	.B	B'10000000	.B	B'10000000	.B	B'10010000	.B	B'10100000	.B	B'11000000	.B	B'10100000	.B	B'10010000	.EVEN	.END