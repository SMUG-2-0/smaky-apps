	.SBTTL	AUDTEST.ASITESTMGX	=	90		; marge droite/gaucheTESTMGY	=	60		; marge haut/basTESTVIT	=	14		; vitesse pour redescendre l'aiguille;-------\\; TESTVU >;=======/; Fait bouger un "VU-METER" en fonction du micro.; in	-; out	-; mod	D7.WTESTVU:	PUSHM.L	D2..D5	LOAD.L	A2,#R16"TDBOX_TESTV	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	CALL	TESTOPEN	; ouvre AUDIO	JUMP,NE CLOSE$	CALL	TESTDRAW	; dessine le VU-METER vide	LIB	?COLORPUSH	LOAD.L	D3,#COLORTESTA	LIB	?COLORSR	LOAD.L	D3,#COLORTEST0	LIB	?COLORCR	CLR.W	D4	CALL	TESTAINV	; allume l'aiguille	LOAD.W	D2,D4LOOP$:	LIB	?IFCAR		; une touche presse ?	JUMP',EQ END$	CALL	TESTREAD	; D4 <-- niveau	COMP.W	D4,D2		; est-ce que le niveau baisse ?	JUMP',HS COMP$		; non => COMP$				; oui =>	LOAD.W	D3,D2	SUB.W	D3,D4		; D3 <-- diminution	COMP.W	D3,#TESTVIT	JUMP',LO COMP$	LOAD.W	D4,D2	SUB.W	D4,#TESTVIT	; D4 <-- redescend pas trop videCOMP$:	COMP.W	D4,D2		; niveau chang ?	JUMP',EQ LOOP$		; non => LOOP$	EX.L	D4,D2	CALL	TESTAINV	; teint l'aiguille	LOAD.W	D4,D2	CALL	TESTAINV	; allume l'aiguille	CALL	TESTOVER	; dessine l'overflow	JUMP	LOOP$END$:	LIB	?COLORPOPCLOSE$:	CALL	TESTCLOSE	; ferme AUDIO	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D2..D5	RET;---------\\; TESTDRAW >;---------/; Dessine le VU-METER vide.; in	-; out	-; mod	D7.WTESTDRAW:	PUSHM.L	D0..D4,A4	LOAD.L	D4,#-1	CALL	DRMDEF	LOAD.W	D2,#SETDOT	LOAD.L	D3,#H'10000*(TESTMGY+38)+TESTMGX	LOAD.L	D4,(A0)+ODFFDY	SUB.W	D4,#TESTMGX+TESTMGX	SWAP.W	D4	SUB.W	D4,#32+TESTMGY+TESTMGY+30	SWAP.W	D4	LOAD.L	(A6)+OTTPOS,D3	LOAD.L	(A6)+OTTDIM,D4	LOAD.L	A4,#R16"TABLE$-6RLOOP$:	ADD.L	A4,#6	LOAD.W	D0,(A4)	JUMP,NS REND$	LOAD.L	D3,(A6)+OTTPOS	SUB.W	D3,D0	SWAP.W	D3	SUB.W	D3,D0	SWAP.W	D3	LOAD.L	D4,(A6)+OTTDIM	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D4	ADD.W	D4,D0	ADD.W	D4,D0	ADD.W	D4,#30+1	SWAP.W	D4	LOAD.W	D1,(A4)+2	TEST.B	(A0)+ODFCMD	JUMP',EQ NOCOL$	LIB	?COLORPUSH	PUSH.L	D3	CLR.L	D3	LOAD.W	D3,(A4)+4	LIB	?COLORSR	POP.L	D3	LIB	?DRTRAMEA	; colorie le fond du rectangle	LIB	?COLORPOPNOCOL$:	LIB	?DRRECTA	; dessine le rectangle	JUMP	RLOOP$REND$:	LOAD.L	D3,(A6)+OTTPOS	LOAD.L	D4,(A6)+OTTDIM	ADD.L	D4,#H'10000*1	TEST.B	(A0)+ODFCMD	JUMP',EQ NOCOL2$	LIB	?COLORPUSH	PUSH.L	D3	LOAD.L	D3,#COLORTEST0	LIB	?COLORSR	POP.L	D3	LIB	?DRTRAMEA	; colorie le fond du rectangle	LIB	?COLORPOPNOCOL2$:	LIB	?DRRECT	LIB	?COLORPUSH	LOAD.L	D3,#COLORTESTG	LIB	?COLORSR	CLR.W	D4GLOOP$:	CALL	TESTGRAD	; dessine une graduation	ADD.W	D4,#ADNIVZERO/32	COMP.W	D4,#ADNIVZERO	JUMP,LS GLOOP$	LOAD.L	D3,#COLORTEST1	LIB	?COLORCR	LOAD.W	D3,(A6)+OTTPOS+0	ADD.W	D3,(A6)+OTTDIM+0	ADD.W	D3,#20	SWAP.W	D3	LOAD.W	D3,(A6)+OTTDIM+2	SR.W	D3,#1	SUB.W	D3,#10*8/2	ADD.W	D3,(A6)+OTTPOS+2	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"MICRO/LINE"	.EVEN	LIB	?COLORPOP	LOAD.W	(A6)+OTTOVE,#-1	CALL	TESTOVER	; dessine l'overflow	POPM.L	D0..D4,A4	RETTABLE$:	;	d,r	.W	27,3	COLORTEST5	.W	13,12	COLORTEST4	.W	10,8	COLORTEST3	.W	3,3	COLORTEST2	.W	0,0	COLORTEST1	.W	-1;---------\\; TESTGRAD >;---------/; Dessine une graduation.; in	D4.W	niveau (0..128); out	-; mod	D7.WTESTGRAD:	PUSHM.L	D0..D4	CLR.L	D0	LOAD.W	D0,D4	DIV.WU	D0,#ADNIVZERO/8	SWAP.W	D0	LOAD.W	D1,D4	LOAD.W	D3,(A6)+OTTDIM+0	SUB.W	D3,#10	CALL	TESTROT	PUSH.L	D4	ADD.L	D4,#H'10000*1	TEST.W	D0	JUMP',NE ROT$	SUB.W	D3,#12	CALL	TESTROTROT$:	POP.L	D3	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	INC.W	D3		; D3 <-- dcale lgrement !	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D0..D4	RET;---------\\; TESTOVER >;---------/; Dessine l'indicateur d'overflow.; in	D4.W	niveau (0..128); out	-; mod	D7.WTESTOVER:	PUSHM.L	D1..D4	LOAD.W	D1,D4	COMP.W	D1,#ADNIVZERO	JUMP',EQ CHG$	CLR.W	D1CHG$:	COMP.W	D1,(A6)+OTTOVE	; indicateur chang ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.W	(A6)+OTTOVE,D1	LIB	?COLORPUSH	LOAD.L	D3,#COLORTESTG	LIB	?COLORSR	LOAD.W	D3,(A6)+OTTPOS+0	ADD.W	D3,#12	SWAP.W	D3	LOAD.W	D3,(A6)+OTTPOS+2	ADD.W	D3,(A6)+OTTDIM+2	SUB.W	D3,#20	LOAD.L	D4,#H'10000*10+10	LOAD.W	D2,#SETDOT	LIB	?DRRECT	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	TEST.B	(A0)+ODFCMD	JUMP',NE COLOR$	PUSH.L	D4	CLR.L	D4	TEST.W	D1	JUMP',EQ DRMDEF$	LOAD.L	D4,#H'55AA55AADRMDEF$:	CALL	DRMDEF	POP.L	D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	JUMP'	END$COLOR$:	PUSH.L	D3	LOAD.L	D3,#COLORTEST0	TEST.W	D1	JUMP',EQ CSR$	LOAD.L	D3,#COLORTESTOCSR$:	LIB	?COLORSR	POP.L	D3	PUSH.L	D4	LOAD.L	D4,#-1	CALL	DRMDEF	POP.L	D4	LOAD.W	D2,#LOADDOT	LIB	?DRTRAMEEND$:	LIB	?COLORPOPEXIT$:	POPM.L	D1..D4	RET;---------\\; TESTAINV >;---------/; Inverse l'aiguille.; in	D4.W	niveau (0..128); out	-; mod	D7.WTESTAINV:	PUSHM.L	D1..D4	LOAD.W	D1,D4	LOAD.W	D3,(A6)+OTTDIM+0	SUB.W	D3,#10	CALL	TESTROT	LOAD.W	D3,(A6)+OTTPOS+0	ADD.W	D3,(A6)+OTTDIM+0	SWAP.W	D3	LOAD.W	D3,(A6)+OTTDIM+2	SR.W	D3,#1	ADD.W	D3,(A6)+OTTPOS+2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRSEG	POPM.L	D1..D4	RET;--------\\; TESTROT >;--------/; Tourne un point.; in	D1.W	niveau (0..128);	D3.W	rayon; out	D4.L	P(y;x); mod	D4.L, D7.WTESTROT:	PUSHM.L	D1..D3	LOAD.W	D2,D3	MUL.WU	D1,#90	DIV.WU	D1,#ADNIVZERO	ADD.W	D1,#180+45	LOAD.W	D3,(A6)+OTTPOS+0	ADD.W	D3,(A6)+OTTDIM+0	SWAP.W	D3	LOAD.W	D3,(A6)+OTTDIM+2	SR.W	D3,#1	ADD.W	D3,(A6)+OTTPOS+2	LOAD.L	D4,D3	ADD.W	D4,D2	LIB	?CALCPSYM	POPM.L	D1..D3	RET;---------\\; TESTOPEN >;---------/; Initialise le pilote AUDIO pour le test du niveau.; in	-; out	D6.W	canal;	D7.W	erreur; mod	D6.L, D7.WTESTOPEN:	PUSHM.L	D1,D3,D4,A3,A4	LOAD.L	D4,#LADH+(ADFREQ/10)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour buffer	JUMP',NE EXIT$	LOAD.L	(A6)+OTTPTB,A4	LOAD.L	A3,#R16"NPAUDIO	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#'R	LOAD.B	(A4)+1,#'L	LOAD.W	(A4)+2,#0	; niveau du bruit nul	LOAD.B	(A4)+4,#'R	LOAD.B	(A4)+5,#'T	LOAD.L	(A4)+6,#ADFREQ	; timeout de 1 seconde	CLR.B	(A4)+10	FOS	?COMMAND	; spcifie niveau et timeoutEXIT$:	POPM.L	D1,D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TESTREAD >;---------/; Lit le niveau du pilote AUDIO.; in	D6.W	canal; out	D4.W	valeur lue (0..128); mod	D4.L, D7.WTESTREAD:	PUSHM.L	D2,D3,A4	LOAD.L	A4,(A6)+OTTPTB	LOAD.L	D4,#LADH+(ADFREQ/10)	FOS	?RDBYTE	JUMP',NE EXIT$	LOAD.L	A4,#(A4)+LADH	LOAD.W	D3,#(ADFREQ/10)-1	CLR.W	D4LOOP$:	CLR.W	D2	LOAD.B	D2,(A4+)	SUB.W	D2,#ADNIVZERO	JUMP',NC SUM$	NEG.W	D2SUM$:	COMP.W	D4,D2	JUMP',HS NEXT$	LOAD.W	D4,D2		; D4 <-- maximum	COMP.W	D4,#ADNIVZERO	JUMP',HS EXIT$NEXT$:	DECJ.W,NMO D3,LOOP$EXIT$:	POPM.L	D2,D3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; TESTCLOSE >;----------/; Ferme le pilote AUDIO.; in	D6.W	canal; out	-; mod	D7.WTESTCLOSE:	PUSHM.L	D1,A4	FOS	?CLOSE	TEST.L	(A6)+OTTPTB	JUMP',EQ EXIT$	LOAD.L	A4,(A6)+OTTPTB	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le buffer	CLR.L	(A6)+OTTPTBEXIT$:	POPM.L	D1,A4	RET	.END