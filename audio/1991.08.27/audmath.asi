	.SBTTL	AUDMATH.ASU;---------\\; CONV8TO5 >;=========/; Conversion d'une valeur dans un rapport de 8  5.; in	D4.L	n; out	D4.L	n/8*5; mod	D4.L, D7.WCONV8TO5:	PUSH.L	D3	SR.L	D4,#3		; D4 <-- /8	LOAD.L	D3,D4	SL.L	D4,#2	ADD.L	D4,D3		; D4 <-- *5 (*4 puis +1)	POP.L	D3	RET;---------\\; CONV5TO8 >;=========/; Conversion d'une valeur dans un rapport de 5  8.; in	D4.L	n; out	D4.L	n/5*8; mod	D4.L, D7.WCONV5TO8:	PUSHM.L	D0..D3	LOAD.L	D0,D4	CLR.L	D1	LOAD.L	D2,#5	CALL	INTDIV32	LOAD.L	D4,D3		; D4 <-- /5	SL.L	D4,#3		; D4 <-- *8	POPM.L	D0..D3	RET;---------\\; INTMUL32 >;=========/; Module de multiplication 32*32 --> 64 bits (non-sign).;	-------------------;	 D1&D0 <-- D2 * D3;	-------------------; in	D2.L	multiplicande (32 bits non-sign);	D3.L	multiplicateur (32 bits non-sign); out	D1&D0.L	rsultat (64 bits non-sign); mod	D0.L, D1.LINTMUL32:	PUSHM.L D4,D5	LOAD.W	D0,D3	MUL.WU	D0,D2		; D0 low longword <-- low word * low word	SWAP.W	D2	LOAD.W	D5,D3		; D5 mid longword <-- high word * low word	MUL.WU	D5,D2	SWAP.W	D3	LOAD.W	D1,D3		; D1 high long <-- high word * high word	MUL.WU	D1,D2	SWAP.W	D2	LOAD.W	D4,D3		; D4 mid long <-- high word * low word	MUL.WU	D4,D2	SWAP.W	D3	SWAP.W	D1	ADD.L	D4,D5		; ADD.L D4,D5 avec report sur D1 si ncessessaire	CLR.W	D5	ADDX.W	D1,D5	SWAP.W	D1	ADDX.W	D1,D5	LOAD.W	D5,D1		; ADD.64 D1&D0,D4*(2^16)	SWAP.W	D5	SWAP.W	D0	LOAD.W	D5,D0	ADD.L	D5,D4	LOAD.W	D0,D5	SWAP.W	D0	SWAP.W	D5	LOAD.W	D1,D5	SWAP.W	D1	CLR.L	D5	ADDX.L	D1,D5	SWAP.W	D1	POPM.L	D4,D5	RET;---------\\; INTDIV32 >;=========/; Module de division 64/32 --> 32 bits (non-sign).;	-------------------;	 D3 <-- D1&D0 / D2;	 D4 <-- reste;	-------------------; ATTENTION: pas de test de division par zro !; in	D1&D0.L	numrateur (64 bits non-sign);	D2.L	dnominateur (32 bits non-sign); out	D3.L	rsultat (32 bits non-sign);	D4.L	reste (32 bits non-sign);	VS	overflow; mod	D3.L, D4.LINTDIV32:	PUSHM.L D0,D1	LOAD.W	D4,#32-1	; D4 <-- dcompteur de bouclesLOOP$:	SETX	RLX.L	D0	RLX.L	D1	JUMP',CS ERROR$	SUB.L	D1,D2	JUMP',HS NEXT$	ADD.L	D1,D2	TCLR.L	D0:#0		; bit 0 si rtablissementNEXT$:	DECJ.W,NMO D4,LOOP$	COMP.L	D1,D2		; reste >= diviseur ?	JUMP',HS ERROR$	LOAD.L	D3,D0		; D3 <-- quotient	LOAD.L	D4,D1		; D4 <-- reste,	 F <-- V=0	JUMP'	EXIT$ERROR$:	SETV			; F <-- V=1EXIT$:	POPM.L	D0,D1	RET	.END