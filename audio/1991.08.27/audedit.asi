	.SBTTL	AUDEDIT.ASI;----------\\; EDITEVENT >;==========/; Traite une touche presse.; in	D3.W	touche presse; out	D7.W	erreur; mod	D7.WEDITEVENT:	PUSHM.L	D2..D4	CALL	EDITNBC		; OEDNBC <-- nb de caractres	LOAD.W	D2,D3	LIB	?MINMAJ	EX.L	D2,D3	LOAD.W	D7,#1	COMP.W	D3,#'	JUMP',LO MOVE$	COMP.W	D3,#H'7F	JUMP,LO INS$MOVE$:	CLR.B	(A6)+OEDACC	COMP.W	D2,#H'100*(2^BCURSOR)+'D	JUMP,EQ RECULE$	COMP.W	D2,#H'100*(2^BCURSOR)+'F	JUMP,EQ AVANCE$	COMP.W	D2,#H'100*(2^BCURSOR)+'S	JUMP,EQ BEGIN$	COMP.W	D2,#H'100*(2^BCURSOR)+'E	JUMP,EQ BEGIN$	COMP.W	D2,#H'100*(2^BCURSOR)+'R	JUMP,EQ BEGIN$	COMP.W	D2,#H'100*(2^BCURSOR)+'T	JUMP,EQ BEGIN$	COMP.W	D2,#H'100*(2^BCURSOR)+'G	JUMP,EQ END$	COMP.W	D2,#H'100*(2^BCURSOR)+'X	JUMP,EQ END$	COMP.W	D2,#H'100*(2^BCURSOR)+'C	JUMP,EQ END$	COMP.W	D2,#H'100*(2^BCURSOR)+'V	JUMP,EQ END$	COMP.W	D2,#H'100*(2^BCURSOR!2^BKILL)+'D	JUMP,EQ DEL$	COMP.W	D2,#DEL	JUMP,EQ DEL$	COMP.W	D2,#H'100*(2^BCURSOR!2^BKILL)+'F	JUMP,EQ BS$	COMP.W	D2,#BS	JUMP,EQ BS$	COMP.W	D2,#CLEAR	JUMP,EQ CLEAR$	JUMP	EXIT$CLEAR$:	CALL	EDITCLEAR	; efface le nom en dition	JUMP	DRAW2$INS$:	TEST.B	(A6)+OEDACC	; frappe accent flottant en cours ?	JUMP',NE ACC$		; oui => ACC$	COMP.B	D3,#KCIRCON	JUMP',EQ CIRCON$	COMP.B	D3,#KTREMA	JUMP',EQ TREMA$INS2$:	CALL	EDITINS	JUMP	DRAW$ACC$:	PUSH.W	D3	CALL	EDITAVANCE	; saute l'accent	POP.W	D3	LOAD.B	D4,(A6)+OEDACC	CLR.B	(A6)+OEDACC	CALL	EDITACC		; D3 <-- lettre accentue	JUMP,NE INS2$	CALL	EDITDEL		; dtruit l'accent seul	JUMP	INS2$CIRCON$:	LOAD.B	D3,#CIRCON	JUMP'	NEWACC$TREMA$:	LOAD.B	D3,#TREMANEWACC$:	LOAD.B	(A6)+OEDACC,D3	CALL	EDITINS		; insre l'accent flottant	JUMP,NE DRAW$	CALL	EDITRECULE	; recule sur l'accent	JUMP	DRAW$BS$:	CALL	EDITAVANCE	JUMP,NE DRAW$DEL$:	CALL	EDITDEL	JUMP	DRAW$AVANCE$:	CALL	EDITAVANCE	JUMP'	DRAW$RECULE$:	CALL	EDITRECULE	JUMP'	DRAW$BEGIN$:	TEST.W	(A6)+OEDCUR	JUMP',EQ DRAW$	CLR.W	(A6)+OEDCUR	JUMP'	DRAW2$END$:	LOAD.W	D3,(A6)+OEDNBC	COMP.W	D3,(A6)+OEDCUR	JUMP',EQ DRAW$	LOAD.W	(A6)+OEDCUR,D3	JUMP'	DRAW2$DRAW$:	TEST.W	D7	JUMP',NE EXIT$DRAW2$:	CALL	EDITDRAW	; affiche la ligne	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; EDITACC >;--------/; Calcul le code correspondant  une lettre (a,e,i,o,u) et ; un accent (^,").; in	D4.B	accent (^,");	D3.B	caractre; out	D7.W	zro => ok (lettre accentue existe);	 D3.B	 lettre accentue;	D7.W	un => lettre accentue n'existe pas;	 D3.B	 caractre qui devait aller sous l'accent; mod	D7.W, D3.BEDITACC:	PUSH.L	A1	LOAD.L	A1,#R16"TABMIN$-3LOOP$:	ADD.L	A1,#3		; A1 <-- ^suivant dans table	TEST.B	(A1)		; fin de la table ?	JUMP',EQ ERROR$		; oui => ERROR$	COMP.B	D3,(A1)		; lettre trouve dans table ?	JUMP,NE LOOP$		; non => LOOP$				; oui =>	COMP.B	D4,#CIRCON	JUMP',EQ CIRCON$	COMP.B	D4,#TREMA	JUMP',NE ERROR$TREMA$:	LOAD.B	D3,(A1)+2	; D3 <-- lettre accentue (")	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$CIRCON$:	LOAD.B	D3,(A1)+1	; D3 <-- lettre accentue (^)	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1		; D7 <-- erreur quelconqueEXIT$:	POP.L	A1	TEST.W	D7		; retour EQ/NE	RETTABMIN$:	.B	'a	' '	.B	'e	' '	.B	'i	' '	.B	'o	' '	.B	'u	' '	.B	SPACE	'^ '"	.B	KCIRCON	'^ '^	.B	KTREMA	'" '"	.B	0	.EVEN;-----------\\; EDITAVANCE >;-----------/; Avance le curseur.; in	-; out	D3.B	caractre avanc;	D7.W	erreur; mod	D3.L, D7.WEDITAVANCE:	PUSHM.L	D4,A3	LOAD.W	D7,#1	CALL	EDITNBC	LOAD.W	D4,(A6)+OEDNBC	LOAD.W	D3,(A6)+OEDCUR	COMP.W	D3,D4	JUMP',HS EXIT$	LOAD.L	A3,#(A6)+OEDNAM	LOAD.B	D3,(A3)+(D3.W)	INC.W	(A6)+OEDCUR	; avance le curseur	CLR.W	D7EXIT$:	POPM.L	D4,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; EDITRECULE >;-----------/; Recule le curseur.; in	-; out	D3.B	caractre recul;	D7.W	erreur; mod	D3.L, D7.WEDITRECULE:	PUSHM.L	D4,A3	LOAD.W	D7,#1	LOAD.W	D3,(A6)+OEDCUR	JUMP',EQ EXIT$	LOAD.L	A3,#(A6)+OEDNAM	LOAD.B	D3,(A3)+(D3.W)-1	DEC.W	(A6)+OEDCUR	; recule le curseur	CLR.W	D7EXIT$:	POPM.L	D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; EDITINS >;--------/; Insre un caractre.; in	D3.B	caractre  insrer; out	D7.W	erreur; mod	D7.WEDITINS:	PUSHM.L	D4,A3,A4	LOAD.W	D7,#1	CALL	EDITNBC	LOAD.W	D4,(A6)+OEDNBC	COMP.W	D4,#LADHNAME-1	JUMP',HS EXIT$	LOAD.L	A3,#(A6)+OEDNAM	ADD.W	A3,D4	INC.L	A3	LOAD.L	A4,#(A3)+1	SUB.W	D4,(A6)+OEDCUR	INC.W	D4XFER$:	LOAD.B	(-A4),(-A3)	DEC.W	D4	JUMP,NE XFER$	LOAD.B	(A3),D3	INC.W	(A6)+OEDCUR	; avance le curseur	INC.W	(A6)+OEDNBC	; un caractre de plus	CLR.W	D7EXIT$:	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; EDITDEL >;--------/; Supprime un caractre.; in	-; out	D7.W	erreur; mod	D7.WEDITDEL:	PUSHM.L	D4,A3,A4	LOAD.W	D7,#1	LOAD.L	A3,#(A6)+OEDNAM	LOAD.W	D4,(A6)+OEDCUR	JUMP',EQ EXIT$	ADD.W	A3,D4	LOAD.L	A4,#(A3)-1XFER$:	LOAD.B	(A4+),(A3+)	JUMP,NE XFER$	DEC.W	(A6)+OEDCUR	; recule le curseur	DEC.W	(A6)+OEDNBC	; un caractre de moins	CLR.W	D7EXIT$:	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; EDITCLEAR >;==========/; Efface tout le nom en dition.; in	-; out	-; mod	D7.WEDITCLEAR:	CLR.B	(A6)+OEDNAM	; plus de nom	CLR.W	(A6)+OEDCUR	; curseur au dbut	CLR.B	(A6)+OEDACC	; plus d'accent en cours	RET;---------\\; EDITDRAW >;=========/; Affiche le nom en dition, avec le curseur.; in	-; out	-; mod	D7.WEDITDRAW:	PUSHM.L	D2..D4,A3,A4	LIB	?COLORPUSH	; sauve les couleurs	LOAD.L	D3,#COLORFEDIT	LIB	?COLORCR	; donne la couleur du fond	LOAD.L	D3,#COLORCEDIT	LIB	?COLORSR	; donne la couleur du dessin	LOAD.L	D2,#H'10000*319+258	LOAD.L	D3,D2	LIB	?SETCURS	TEST.B	(A6)+OINV	JUMP',T INV$	LOAD.B	D3,#AFINV	LIB	?AFCARINV$:	CALL	MAINPSON	; A4 <-- ^son	JUMP',NE RIEN$	LOAD.L	A3,#(A6)+OEDNAM	; A3 <-- ^nom	CALL	EDITNBC	LOAD.W	D3,(A6)+OEDNBC	JUMP',EQ EOL$	LIB	?STRING		; affiche le nomEOL$:	LOAD.W	D4,#LADHNAME	SUB.W	D4,D3	JUMP',LS CURS$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin du nomCURS$:	LOAD.L	D3,#COLORIEDIT	LIB	?COLORSR	; donne la couleur du dessin	LOAD.L	D3,D2	LOAD.W	D2,(A6)+OEDCUR	MUL.WU	D2,(A0)+ODFCX	ADD.W	D3,D2	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	CALL	INVMODE	LIB	?DRSEG		; affiche le curseur (|)	JUMP'	EXIT$RIEN$:	LIB	?AFTIM	.B	MSPACE,LADHNAME	; efface tout	.B	0	.EVENEXIT$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LIB	?COLORPOP	POPM.L	D2..D4,A3,A4	RET;--------\\; EDITNBC >;--------/; Cherche le nombre de caractre de la chane en dition.; in	-; out	-; mod	D7.WEDITNBC:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OEDNAM	LOAD.W	D3,#-1CNT$:	INC.W	D3		; D3 <-- nb de caractres du nom	TEST.B	(A3+)	JUMP,NE CNT$	LOAD.W	(A6)+OEDNBC,D3	COMP.W	D3,(A6)+OEDCUR	JUMP',HS EXIT$	LOAD.W	(A6)+OEDCUR,D3EXIT$:	POPM.L	D3,A3	RET	.END