	.TITLE	SYNT.ASD;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du pilote 300_SYNT.DRIV;	Installe et utilise le pilote $AUDIO !	.PROC	M680002	.REF	SMAKY	.REF	AUDIO	.REF	BIOS	.REF	BIOSDRIV	.RADIX	10.	.HEXTOTO	=	0		; 1 => pilote de test (300_TOTO.DRIV); Constantes; ----------MAXPIL	=	14		; nb max de pilotes $SYNTMAXNIV	=	256		; niveau maximumMAXSON	=	5		; 5 secondes au maximum !MAXFIFO	=	100		; nb max de bytes dans fifo	.IF	TOTONOBASE	=	H'E0		; numro de base	.ELSENOBASE	=	H'40		; numro de base	.ENDIFBIPAUDIO =	H'FE		; son audioBIPCLOSE =	H'FF		; ferme le pilote AUDIO; Dfinition de l'entte d'un FIFO; --------------------------------	.LOC	0OFIHEAD:.BLKB	4		; ^tteOFITAIL:.BLKB	4		; ^queueOFIBEG:	.BLKB	4		; adresse absolue dbut bufferOFIEND:	.BLKB	4		; adresse absolue fin bufferLGFIFO:;   (A0)---|;	   |--->|-------|;   OFIHEAD	|	|	^tte;		|-------|;   OFITAIL	|	|	^queue;		|-------|;   OFIBEG	|	|-------|;		|-------|	|;   OFIEND	|	|-------+-------|;		|-------|	|	|;		|	|<------|	|;		|	|		|;		|   F	|		|;		|   I	|		|;		|   F	|		|;		|   O	|		|;		|	|		|;		|	|		|;		|-------|		|;			 <--------------|; Dfinition des variables globales; ---------------------------------	.LOC	0OFIFO:	.BLKB	LGFIFO+MAXFIFO	; fifo pour les commandesOPSEM0:	.BLKB	4		; ^smaphore d'exclusionOPSEM1:	.BLKB	4		; ^smaphore pour write fifoOPSEM2:	.BLKB	4		; ^smaphore synhro avec filsOVLOC:	.BLKB	4*MAXPIL	; ^variables locales des pilotes $SYNT_nOCHA:	.BLKB	2		; canal #AUDIO:OAUDPF:	.BLKB	4		; audio: ^fichierOAUDLF:	.BLKB	4		; audio: lg fichier	.BLKB	LADH		; buffer pour en-tte (juste avant OBBUFF)OBBUFF:	.BLKB	ADFREQ*MAXSON	; big buffer pour sonsLGGLOB:; Dfinition des variables locales; --------------------------------	.LOC	0OLEVHP:	.BLKB	1		; "niveau" du haut-parleurOFLAG0:	.BLKB	1		; flags diversONWAIT:	.BLKB	2		; nb de bytes attendusLGVAR:	.LOC	0DEBUT:	.W	0,S0BASE	.W	1,S1BASE	.W	2,S2BASE	.W	3,S3BASE	.W	4,S4BASE	.W	5,S5BASE	.W	6,S6BASE	.W	7,S7BASE	.W	8,S8BASE	.W	9,S9BASE	.W	10,S10BASE	.W	11,S11BASE	.W	12,S12BASE	.W	13,S13BASE	.W	2^7; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;			DRIVER $SYNT0		No H'40; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=S0ID:				; Adresse routines	.W	S0OPEN-S0BASE	.W	S0COMMAND-S0BASE	.W	S0RSTATUS-S0BASE	.W	-1			; S0READ-S0BASE	.W	S0WRITE-S0BASE	.W	S0CLOSE-S0BASE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	-1			; AVORTTR	.W	-1			; S0AUX1-S0BASE	.W	-1			; S0AUX2-S0BASE	.W	S0RESET-S0BASE	.W	S0KILL-S0BASE	.W	-1			; S0STRT-S0BASE	.W	-1			; S0TSTRT-S0BASE	.W	-1			; S0START-S0BASE	.IF	TOTOS0NAB:	.ASCII	"TOTO_0"		; Nom driver	.ELSES0NAB:	.ASCII	"SYNT_0"		; Nom driver	.ENDIFS0NAF:	.FILLB	LGDNAM-(S0NAF-S0NAB) 0	.B	NOBASE+0		; Numro driver	.B	TYPIO			; Type: Streamer	.B	0,0			; Rvision - version -	.W	0			; - Variante	.B	0			; Attribut 1	.B	2^BDWROK!2^BDNORT	; Attribut 0	.FILLB	LGDDESC-(.-S0ID) 0	; Le reste.S0BASE:; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;			DRIVER $SYNT1		No H'41; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=S1ID:				; Adresse routines	.W	S1OPEN-S1BASE	.W	S1COMMAND-S1BASE	.W	S1RSTATUS-S1BASE	.W	-1			; S1READ-S1BASE	.W	S1WRITE-S1BASE	.W	S1CLOSE-S1BASE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	-1			; AVORTTR	.W	-1			; S1AUX1-S1BASE	.W	-1			; S1AUX2-S1BASE	.W	S1RESET-S1BASE	.W	S1KILL-S1BASE	.W	-1			; S1STRT-S1BASE	.W	-1			; S1TSTRT-S1BASE	.W	-1			; S1START-S1BASE	.IF	TOTOS1NAB:	.ASCII	"TOTO_1"		; Nom driver	.ELSES1NAB:	.ASCII	"SYNT_1"		; Nom driver	.ENDIFS1NAF:	.FILLB	LGDNAM-(S1NAF-S1NAB) 0	.B	NOBASE+1		; Numro driver	.B	TYPIO			; Type: Streamer	.B	0,0			; Rvision - version -	.W	0			; - Variante	.B	0			; Attribut 1	.B	2^BDWROK!2^BDNORT	; Attribut 0	.FILLB	LGDDESC-(.-S1ID) 0	; Le reste.S1BASE:; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;			DRIVER $SYNT2		No H'42; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=S2ID:				; Adresse routines	.W	S2OPEN-S2BASE	.W	S2COMMAND-S2BASE	.W	S2RSTATUS-S2BASE	.W	-1			; S2READ-S2BASE	.W	S2WRITE-S2BASE	.W	S2CLOSE-S2BASE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	-1			; AVORTTR	.W	-1			; S2AUX1-S2BASE	.W	-1			; S2AUX2-S2BASE	.W	S2RESET-S2BASE	.W	S2KILL-S2BASE	.W	-1			; S2STRT-S2BASE	.W	-1			; S2TSTRT-S2BASE	.W	-1			; S2START-S2BASE	.IF	TOTOS2NAB:	.ASCII	"TOTO_2"		; Nom driver	.ELSES2NAB:	.ASCII	"SYNT_2"		; Nom driver	.ENDIFS2NAF:	.FILLB	LGDNAM-(S2NAF-S2NAB) 0	.B	NOBASE+2		; Numro driver	.B	TYPIO			; Type: Streamer	.B	0,0			; Rvision - version -	.W	0			; - Variante	.B	0			; Attribut 1	.B	2^BDWROK!2^BDNORT	; Attribut 0	.FILLB	LGDDESC-(.-S2ID) 0	; Le reste.S2BASE:; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;			DRIVER $SYNT3		No H'43; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=S3ID:				; Adresse routines	.W	S3OPEN-S3BASE	.W	S3COMMAND-S3BASE	.W	S3RSTATUS-S3BASE	.W	-1			; S3READ-S3BASE	.W	S3WRITE-S3BASE	.W	S3CLOSE-S3BASE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	-1			; AVORTTR	.W	-1			; S3AUX1-S3BASE	.W	-1			; S3AUX2-S3BASE	.W	S3RESET-S3BASE	.W	S3KILL-S3BASE	.W	-1			; S3STRT-S3BASE	.W	-1			; S3TSTRT-S3BASE	.W	-1			; S3START-S3BASE	.IF	TOTOS3NAB:	.ASCII	"TOTO_3"		; Nom driver	.ELSES3NAB:	.ASCII	"SYNT_3"		; Nom driver	.ENDIFS3NAF:	.FILLB	LGDNAM-(S3NAF-S3NAB) 0	.B	NOBASE+3		; Numro driver	.B	TYPIO			; Type: Streamer	.B	0,0			; Rvision - version -	.W	0			; - Variante	.B	0			; Attribut 1	.B	2^BDWROK!2^BDNORT	; Attribut 0	.FILLB	LGDDESC-(.-S3ID) 0	; Le reste.S3BASE:; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;			DRIVER $SYNT4		No H'44; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=S4ID:				; Adresse routines	.W	S4OPEN-S4BASE	.W	S4COMMAND-S4BASE	.W	S4RSTATUS-S4BASE	.W	-1			; S4READ-S4BASE	.W	S4WRITE-S4BASE	.W	S4CLOSE-S4BASE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	-1			; AVORTTR	.W	-1			; S4AUX1-S4BASE	.W	-1			; S4AUX2-S4BASE	.W	S4RESET-S4BASE	.W	S4KILL-S4BASE	.W	-1			; S4STRT-S4BASE	.W	-1			; S4TSTRT-S4BASE	.W	-1			; S4START-S4BASE	.IF	TOTOS4NAB:	.ASCII	"TOTO_4"		; Nom driver	.ELSES4NAB:	.ASCII	"SYNT_4"		; Nom driver	.ENDIFS4NAF:	.FILLB	LGDNAM-(S4NAF-S4NAB) 0	.B	NOBASE+4		; Numro driver	.B	TYPIO			; Type: Streamer	.B	0,0			; Rvision - version -	.W	0			; - Variante	.B	0			; Attribut 1	.B	2^BDWROK!2^BDNORT	; Attribut 0	.FILLB	LGDDESC-(.-S4ID) 0	; Le reste.S4BASE:; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;			DRIVER $SYNT5		No H'45; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=S5ID:				; Adresse routines	.W	S5OPEN-S5BASE	.W	S5COMMAND-S5BASE	.W	S5RSTATUS-S5BASE	.W	-1			; S5READ-S5BASE	.W	S5WRITE-S5BASE	.W	S5CLOSE-S5BASE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	-1			; AVORTTR	.W	-1			; S5AUX1-S5BASE	.W	-1			; S5AUX2-S5BASE	.W	S5RESET-S5BASE	.W	S5KILL-S5BASE	.W	-1			; S5STRT-S5BASE	.W	-1			; S5TSTRT-S5BASE	.W	-1			; S5START-S5BASE	.IF	TOTOS5NAB:	.ASCII	"TOTO_5"		; Nom driver	.ELSES5NAB:	.ASCII	"SYNT_5"		; Nom driver	.ENDIFS5NAF:	.FILLB	LGDNAM-(S5NAF-S5NAB) 0	.B	NOBASE+5		; Numro driver	.B	TYPIO			; Type: Streamer	.B	0,0			; Rvision - version -	.W	0			; - Variante	.B	0			; Attribut 1	.B	2^BDWROK!2^BDNORT	; Attribut 0	.FILLB	LGDDESC-(.-S5ID) 0	; Le reste.S5BASE:; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;			DRIVER $SYNT6		No H'46; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=S6ID:				; Adresse routines	.W	S6OPEN-S6BASE	.W	S6COMMAND-S6BASE	.W	S6RSTATUS-S6BASE	.W	-1			; S6READ-S6BASE	.W	S6WRITE-S6BASE	.W	S6CLOSE-S6BASE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	-1			; AVORTTR	.W	-1			; S6AUX1-S6BASE	.W	-1			; S6AUX2-S6BASE	.W	S6RESET-S6BASE	.W	S6KILL-S6BASE	.W	-1			; 