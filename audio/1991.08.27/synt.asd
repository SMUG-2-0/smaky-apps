		; D4 <-- valeur "e" initiale	NTREL	?CRESEMA	; cre un smaphore	JUMP',NE EXIT$	LOAD.L	(A6)+OPSEM2,A5	; init ^au smaphore	LOAD.L	A5,#R16"PROCFILS	LOAD.L	A3,#R16"NAMEFILS	LOAD.W	D4,#3		; D4 <-- priorit	LOAD.L	D5,#100		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus filsEXIT$:	POPM.L	D3..D6,A2..A5	RETNIL$:	.B	0	.EVENS1RESET:	LOAD.W	D0,#OVLOC+(4*1)	LOAD.L	A1,#R16"S1BASE	JUMP'	SnRESETS2RESET:	LOAD.W	D0,#OVLOC+(4*2)	LOAD.L	A1,#R16"S2BASE	JUMP'	SnRESETS3RESET:	LOAD.W	D0,#OVLOC+(4*3)	LOAD.L	A1,#R16"S3BASE	JUMP'	SnRESETS4RESET:	LOAD.W	D0,#OVLOC+(4*4)	LOAD.L	A1,#R16"S4BASE	JUMP'	SnRESETS5RESET:	LOAD.W	D0,#OVLOC+(4*5)	LOAD.L	A1,#R16"S5BASE	JUMP'	SnRESETS6RESET:	LOAD.W	D0,#OVLOC+(4*6)	LOAD.L	A1,#R16"S6BASE	JUMP'	SnRESETS7RESET:	LOAD.W	D0,#OVLOC+(4*7)	LOAD.L	A1,#R16"S7BASE	JUMP'	SnRESETS8RESET:	LOAD.W	D0,#OVLOC+(4*8)	LOAD.L	A1,#R16"S8BASE	JUMP'	SnRESETS9RESET:	LOAD.W	D0,#OVLOC+(4*9)	LOAD.L	A1,#R16"S9BASE	JUMP'	SnRESETS10RESET:	LOAD.W	D0,#OVLOC+(4*10)	LOAD.L	A1,#R16"S10BASE	JUMP'	SnRESETS11RESET:	LOAD.W	D0,#OVLOC+(4*11)	LOAD.L	A1,#R16"S11BASE	JUMP'	SnRESETS12RESET:	LOAD.W	D0,#OVLOC+(4*12)	LOAD.L	A1,#R16"S12BASE	JUMP'	SnRESETS13RESET:	LOAD.W	D0,#OVLOC+(4*13)	LOAD.L	A1,#R16"S13BASE;	JUMP'	SnRESETSnRESET:	PUSHM.L	D4,A4	LOAD.L	A4,#R16"DEBUT	LOAD.L	D4,#LGGLOB	FOS	?GETCOMMEM	; demande mmoire globale	JUMP',NE EXIT$	LOAD.L	A6,A4		; A6 <-- ^variables globales	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPBD	GESMEM	?GETMEM	JUMP',NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	(A6)+(D0.W),A4	; OVLOC <-- mm ^variables locales	LOAD.L	A0,A4		; A0 <-- ^variables locales	LOAD.B	(A0)+OLEVHP,#SGLEV2 ; init par dfaut	LOAD.L	D0,A2		; A2 = zro ?	JUMP',EQ LEVEL$		; oui => LEVEL$	LOAD.B	(A0)+OLEVHP,(A2)+1 ; non => init selon userLEVEL$:;	CLR.B	(A0)+OFLAG0;	CLR.W	(A0)+ONWAIT	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\;  SnKILL  >;=========/; in	-; out	D7.W	erreur; mod	D0..A1, D7.WS0KILL:	LOAD.W	D7,#ERILLO	; KILL $SYNT_0 impossible !!!	RETS1KILL:	LOAD.L	A0,(A6)+OVLOC+(4*1) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S1BASE	JUMP'	SnKILLS2KILL:	LOAD.L	A0,(A6)+OVLOC+(4*2) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S2BASE	JUMP'	SnKILLS3KILL:	LOAD.L	A0,(A6)+OVLOC+(4*3) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S3BASE	JUMP'	SnKILLS4KILL:	LOAD.L	A0,(A6)+OVLOC+(4*4) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S4BASE	JUMP'	SnKILLS5KILL:	LOAD.L	A0,(A6)+OVLOC+(4*5) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S5BASE	JUMP'	SnKILLS6KILL:	LOAD.L	A0,(A6)+OVLOC+(4*6) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S6BASE	JUMP'	SnKILLS7KILL:	LOAD.L	A0,(A6)+OVLOC+(4*7) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S7BASE	JUMP'	SnKILLS8KILL:	LOAD.L	A0,(A6)+OVLOC+(4*8) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S8BASE	JUMP'	SnKILLS9KILL:	LOAD.L	A0,(A6)+OVLOC+(4*9) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S9BASE	JUMP'	SnKILLS10KILL:	LOAD.L	A0,(A6)+OVLOC+(4*10) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S10BASE	JUMP'	SnKILLS11KILL:	LOAD.L	A0,(A6)+OVLOC+(4*11) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S11BASE	JUMP'	SnKILLS12KILL:	LOAD.L	A0,(A6)+OVLOC+(4*12) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S12BASE	JUMP'	SnKILLS13KILL:	LOAD.L	A0,(A6)+OVLOC+(4*13) ; A0 <-- ^variables locales	LOAD.L	A1,#R16"S13BASE;	JUMP'	SnKILLSnKILL:	PUSHM.L	A4	TEST.W	(A0)+ONWAIT	; ordre multiple attendu ?	JUMP',NE FATKIL		; oui => c'est grve ...	LOAD.L	A4,A0	LOAD.W	D1,#MTYPBD	GESMEM	?GIVMEM		; libre les variables locales	POPM.L	A4	CLR.W	D7		; D7 <-- ok	RETFATKIL:	.W	H'A042	.ASCIZ	"$SYNT: Erreur fatale dans KILL<CR>"	.EVEN	TRAP	#0;------------\\;  SnCOMMAND  >;============/; Excute une liste de commandes.;;	0,1,2,3	-->	niveau des bips systmes;	F+	-->	bips systmes selon 300_SYNT.AUDIO;	F-	-->	bits systmes tous simples; in	A4.L	^table des commandes termine par zro; out	D7.W	erreur; mod	D0..A1, D7.WS0COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*0) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS1COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*1) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS2COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*2) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS3COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*3) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS4COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*4) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS5COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*5) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS6COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*6) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS7COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*7) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS8COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*8) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS9COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*9) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS10COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*10) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS11COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*11) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS12COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*12) ; A0 <-- ^variables locales	JUMP'	SnCOMMANDS13COMMAND:	LOAD.L	A0,(A6)+OVLOC+(4*13) ; A0 <-- ^variables locales;	JUMP'	SnCOMMANDSnCOMMAND:	PUSHM.L	D3,A4LOOP$:	LOAD.B	D3,(A4+)	; D3 <-- une commande	JUMP',EQ EXIT$	CALL	WRONEC		; excute une commande	JUMP,EQ LOOP$EXIT$:	POPM.L	D3,A4	RET;---------\\;  SnOPEN  >;=========/; in	-; out	D7.W	erreur; mod	D0..A1, D7.WS0OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*0) ; A0 <-- ^variables locales	JUMP'	SnOPENS1OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*1) ; A0 <-- ^variables locales	JUMP'	SnOPENS2OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*2) ; A0 <-- ^variables locales	JUMP'	SnOPENS3OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*3) ; A0 <-- ^variables locales	JUMP'	SnOPENS4OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*4) ; A0 <-- ^variables locales	JUMP'	SnOPENS5OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*5) ; A0 <-- ^variables locales	JUMP'	SnOPENS6OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*6) ; A0 <-- ^variables locales	JUMP'	SnOPENS7OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*7) ; A0 <-- ^variables locales	JUMP'	SnOPENS8OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*8) ; A0 <-- ^variables locales	JUMP'	SnOPENS9OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*9) ; A0 <-- ^variables locales	JUMP'	SnOPENS10OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*10) ; A0 <-- ^variables locales	JUMP'	SnOPENS11OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*11) ; A0 <-- ^variables locales	JUMP'	SnOPENS12OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*12) ; A0 <-- ^variables locales	JUMP'	SnOPENS13OPEN:	LOAD.L	A0,(A6)+OVLOC+(4*13) ; A0 <-- ^variables locales;	JUMP'	SnOPENSnOPEN:	RET;----------\\;  SnCLOSE  >;==========/; in	-; out	D7.W	erreur; mod	D0..A1, D7.WS0CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*0) ; A0 <-- ^variables locales	JUMP'	SnCLOSES1CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*1) ; A0 <-- ^variables locales	JUMP'	SnCLOSES2CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*2) ; A0 <-- ^variables locales	JUMP'	SnCLOSES3CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*3) ; A0 <-- ^variables locales	JUMP'	SnCLOSES4CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*4) ; A0 <-- ^variables locales	JUMP'	SnCLOSES5CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*5) ; A0 <-- ^variables locales	JUMP'	SnCLOSES6CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*6) ; A0 <-- ^variables locales	JUMP'	SnCLOSES7CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*7) ; A0 <-- ^variables locales	JUMP'	SnCLOSES8CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*8) ; A0 <-- ^variables locales	JUMP'	SnCLOSES9CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*9) ; A0 <-- ^variables locales	JUMP'	SnCLOSES10CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*10) ; A0 <-- ^variables locales	JUMP'	SnCLOSES11CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*11) ; A0 <-- ^variables locales	JUMP'	SnCLOSES12CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*12) ; A0 <-- ^variables locales	JUMP'	SnCLOSES13CLOSE:	LOAD.L	A0,(A6)+OVLOC+(4*13) ; A0 <-- ^variables locales;	JUMP'	SnCLOSESnCLOSE:	CALL	D0LOCK		; dbut zone critique !	LOAD.W	D0,#BIPCLOSE	CALL	WRFIFO		; met byte dans le fifo	CALL	D2SIGNAL	; signal nouvel ordre l	CALL	D0UNLOCK	; fin zone critique !	CLR.W	D7		; D7 <-- ok	RET;------------\\;  SnRSTATUS  >;============/; in	A4.L	^buffer;	D4.L	longueur buffer; out	D4.L	longueur rendue effectivement;	D7.W	erreur; mod	D0..A1, D7.WS0RSTATUS:S1RSTATUS:S2RSTATUS:S3RSTATUS:S4RSTATUS:S5RSTATUS:S6RSTATUS:S7RSTATUS:S8RSTATUS:S9RSTATUS:S10RSTATUS:S11RSTATUS:S12RSTATUS:S13RSTATUS:	LOAD.W	D7,#ERILLO	; D7 <-- "commande illgale"	RET;----------\\;  SnWRITE  >;==========/; in	A4.L	^buffer;	A1.L	^liste de terminateurs;	D5.L	nombre de bytes  crire; out	D5.L	nombre de bytes crits;	D7.W	erreur; mod	D0..A1, D7.W, D5.LS0WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*0) ; A0 <-- ^variables locales	JUMP'	SnWRITES1WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*1) ; A0 <-- ^variables locales	JUMP'	SnWRITES2WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*2) ; A0 <-- ^variables locales	JUMP'	SnWRITES3WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*3) ; A0 <-- ^variables locales	JUMP'	SnWRITES4WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*4) ; A0 <-- ^variables locales	JUMP'	SnWRITES5WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*5) ; A0 <-- ^variables locales	JUMP'	SnWRITES6WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*6) ; A0 <-- ^variables locales	JUMP'	SnWRITES7WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*7) ; A0 <-- ^variables locales	JUMP'	SnWRITES8WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*8) ; A0 <-- ^variables locales	JUMP'	SnWRITES9WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*9) ; A0 <-- ^variables locales	JUMP'	SnWRITES10WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*10) ; A0 <-- ^variables locales	JUMP'	SnWRITES11WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*11) ; A0 <-- ^variables locales	JUMP'	SnWRITES12WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*12) ; A0 <-- ^variables locales	JUMP'	SnWRITES13WRITE:	LOAD.L	A0,(A6)+OVLOC+(4*13) ; A0 <-- ^variables locales;	JUMP'	SnWRITESnWRITE:	PUSHM.L	D3,D4,A4	LOAD.L	D4,D5	JUMP',EQ EXIT$LOOP$:	CLR.W	D3	LOAD.B	D3,(A4+)	; D3 <-- un caractre	CALL	WRONEB		; crit un byte	DEC.L	D4	JUMP,NE LOOP$EXIT$:	SUB.L	D5,D4		; D5 <-- nb caractres crits	POPM.L	D3,D4,A4	CLR.W	D7		; D7 <-- retour EQ	RET;--------\\; WRONEC  >;========/; in	D3.B	commande  effectuer;	A4.L	^commandes; out	A4.L	^plus loin;	D7.W	erreur; mod	D3.B, D7.W, A4.LWRONEC:	PUSHM.L	D1,D4,A1,A2..A4	LOAD.L	A2,A4		; A2 <-- ^commandes	LOAD.W	D7,#ERILLO	; D7 <-- commande incorrecte	COMP.B	D3,#'F	JUMP',EQ FILE$	COMP.B	D3,#SGLEV3	JUMP',LS LEVEL$	SUB.B	D3,#'0	JUMP',LO EXIT$	COMP.B	D3,#SGLEV3	JUMP',HI EXIT$LEVEL$:	LOAD.B	(A0)+OLEVHP,D3	JUMP'	OK$FILE$:	TEST.L	(A6)+OAUDPF	JUMP',EQ FREAD$	LOAD.L	A4,(A6)+OAUDPF	LOAD.L	A1,#R16"S0BASE	LOAD.W	D1,#MTYPBD	GESMEM	?GIVMEM		; libre le fichier prcdent	CLR.L	(A6)+OAUDPFFREAD$:	COMP.B	(A2+),#'+	JUMP',NE OK$	LOAD.L	A3,#R16"NMAUDIO	CALL	AUDIOREAD	; lit le fichier 300_SYNT.AUDIO	JUMP',NE EXIT$	LOAD.L	(A6)+OAUDPF,A4	LOAD.L	(A6)+OAUDLF,D4OK$:	CLR.W	D7		; D7 <-- okEXIT$:	LOAD.L	A4,A2		; A4 <-- ^commandes	POPM.L	D1,D4,A1,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRONEB  >;========/; in	D3.W	byte  crire;	A0.L	^variables; out	-; mod	D0,D1,A1.L, D7.WWRONEB:	PUSH.L	A3	CLR.W	D7		; D7 <-- ok	TEST.W	(A0)+ONWAIT	; ordre multiple attendu ?	JUMP,NE MULTI$		; oui => MULTI$	TEST.B	D3		; ordre zro ?	JUMP,EQ EXIT$		; oui => EXIT$	LOAD.W	D0,#2+1+1	COMP.B	D3,#BIPNOTE	JUMP,EQ WNOTE$	LOAD.W	D0,#2+2+2+1+1	COMP.B	D3,#BIPACCORD	JUMP,EQ WNOTE$	LOAD.L	A1,#R16"TBIPLIT	COMP.B	D3,#BIPLIT	JUMP,EQ WBIP$	LOAD.L	A1,#R16"TBIPEND	COMP.B	D3,#BIPEND	JUMP,EQ WBIP$	LOAD.L	A1,#R16"TBIPYES	COMP.B	D3,#BIPYES	JUMP,EQ WBIP$	LOAD.L	A1,#R16"TBIPBIG	COMP.B	D3,#BIPBIG	JUMP,EQ WBIP$	LOAD.L	A1,#R16"TBIPERR	COMP.B	D3,#BIPERR	JUMP,EQ WBIP$	LOAD.L	A1,#R16"TBIPFAT	COMP.B	D3,#BIPFAT	JUMP,EQ WBIP$	LOAD.L	A1,#R16"TBIPDONE	COMP.B	D3,#BIPDONE	JUMP,EQ WBIP$	LOAD.L	A1,#R16"TBIPNIL	COMP.B	D3,#99	JUMP,LS WBIP$;;	LOAD.W	D7,#ER...	JUMP	EXIT$WNOTE$:	CALL	D0LOCK		; dbut zone critique !	LOAD.W	(A0)+ONWAIT,D0	; init nb de bytes attendus	LOAD.B	D0,D3		; D0 <-- commande	CALL	WRFIFO		; envoie une commande	JUMP	EXIT$MULTI$:	LOAD.B	D0,D3	CALL	WRFIFO		; met byte dans le fifo	DEC.W	(A0)+ONWAIT	; encore qq chose attendu ?	JUMP,NE EXIT$		; oui => EXIT$				; non =>	CALL	D2SIGNAL	; signal nouvel ordre l	CALL	D0UNLOCK	; fin zone critique !	JUMP	EXIT$WBIP$:	CALL	AUDIOSEARCH	; A3 <-- ^son dans 300_SYNT.AUDIO	JUMP',EQ WAUDIO$	COMP.B	(A0)+OLEVHP,#SGLEV1	JUMP',EQ WBLOOP$	CALL	NXTPT		; A1 <-- ^2me lment	COMP.B	(A0)+OLEVHP,#SGLEV2	JUMP',EQ WBLOOP$	CALL	NXTPT		; A1 <-- ^3me lment	COMP.B	(A0)+OLEVHP,#SGLEV3	JUMP,NE EXIT$WBLOOP$:	TEST.W	(A1)		; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$				; non =>	CALL	D0LOCK		; dbut zone critique !	LOAD.B	D0,#BIPACCORD	CALL	WRFIFO		; fifo <-- BIPACCORD	LOAD.W	D1,#2+2+2+1+1WBXFER$:	LOAD.B	D0,(A1+)	CALL	WRFIFO		; fifo <-- nn nn nn e t	DEC.W	D1	JUMP,NE WBXFER$	CALL	D2SIGNAL	; signal nouvel ordre l	CALL	D0UNLOCK	; fin zone critique !	JUMP	WBLOOP$WAUDIO$:	CALL	D0LOCK		; dbut zone critique !	LOAD.B	D0,#BIPAUDIO	CALL	WRFIFO		; fifo <-- BIPAUDIO	LOAD.L	D0,A3	LOAD.W	D1,#4-1WAXFER$:	RL.L	D0,#8	CALL	WRFIFO		; fifo <-- pppp	DECJ.W,NMO D1,WAXFER$	CALL	D2SIGNAL	; signal nouvel ordre l	CALL	D0UNLOCK	; fin zone critique !EXIT$:	POP.L	A3	RET;--------\\; NXTPT   >;--------/; in	A1.L	^dans TBIPxxx; out	A1.L	^suivant; mod	A1.LNXTPT:	TEST.W	(A1+)		; A1 <-- saute .W	JUMP',EQ EXIT$	ADD.L	A1,#2+2+1+1	; A1 <-- saute .WWBB	JUMP	NXTPTEXIT$:	RETTBIPLIT:	.W	0	.W	NOTE+OCTAVE*7+SGDO,SILENCE,SILENCE,H'100*1+1	.W	0	.W	NOTE+OCTAVE*7+SGDO,NOTE+OCTAVE*8+SGDO,SILENCE,H'100*2+2	.W	0TBIPEND:	.W	NOTE+OCTAVE*4+SGDO,SILENCE,SILENCE,H'100*1+1	.W	0	.W	NOTE+OCTAVE*5+SGDO,SILENCE,SILENCE,H'100*4+4	.W	0	.W	NOTE+OCTAVE*5+SGDO,NOTE+OCTAVE*6+SGDO,SILENCE,H'100*4+4	.W	0TBIPYES:	.W	NOTE+OCTAVE*6+SGDO,SILENCE,SILENCE,H'100*1+1	.W	0	.W	NOTE+OCTAVE*6+SGDO,SILENCE,SILENCE,H'100*2+2	.W	NOTE+OCTAVE*5+SGDO,SILENCE,SILENCE,H'100*2+2	.W	0	.W	NOTE+OCTAVE*4+SGDO,NOTE+OCTAVE*5+SGDO,NOTE+OCTAVE*6+SGDO,H'100*3+3	.W	NOTE+OCTAVE*2+SGDO,NOTE+OCTAVE*3+SGDO,NOTE+OCTAVE*4+SGDO,H'100*3+3	.W	0TBIPBIG:	.W	NOTE+OCTAVE*4+SGDO,SILENCE,SILENCE,H'100*5+5	.W	0	.W	PERIODE+150,PERIODE+152,SILENCE,H'100*15+15	.W	0	.W	PERIODE+150,PERIODE+152,SILENCE,H'100*25+25	.W	0TBIPERR:	.W	NOTE+OCTAVE*2+SGDO,SILENCE,SILENCE,H'100*13+13	.W	0	.W	NOTE+OCTAVE*2+SGDO,SILENCE,SILENCE,H'100*20+20	.W	0	.W	BRUIT+8,NOTE+OCTAVE*1+SGDO,SILENCE,H'100*20+20	.W	0TBIPFAT:	.W	BRUIT+8,SILENCE,SILENCE,H'100*15+15	.W	0	.W	BRUIT+8,SILENCE,SILENCE,H'100*30+30	.W	BRUIT+16,SILENCE,SILENCE,H'100*30+30	.W	0	.W	NOTE+OCTAVE*2+SGDO,SILENCE,SILENCE,H'100*50+15	.W	NOTE+OCTAVE*2+SGDO-1,SILENCE,SILENCE,H'100*50+15	.W	NOTE+OCTAVE*2+SGDO-2,SILENCE,SILENCE,H'100*50+15	.W	NOTE+OCTAVE*2+SGDO-3,SILENCE,SILENCE,H'100*50+50	.W	0TBIPDONE:	.W	NOTE+OCTAVE*4+SGDO,SILENCE,SILENCE,H'100*2+1	.W	NOTE+OCTAVE*5+SGDO,SILENCE,SILENCE,H'100*2+10	.W	0	.W	NOTE+OCTAVE*4+SGDO,SILENCE,SILENCE,H'100*2+1	.W	NOTE+OCTAVE*4+SGMI,SILENCE,SILENCE,H'100*2+1	.W	NOTE+OCTAVE*4+SGSOL,SILENCE,SILENCE,H'100*2+1	.W	NOTE+OCTAVE*5+SGDO,SILENCE,SILENCE,H'100*2+10	.W	0	.W	NOTE+OCTAVE*4+SGDO,SILENCE,SILENCE,H'100*6+2	.W	NOTE+OCTAVE*4+SGRE,SILENCE,SILENCE,H'100*6+2	.W	NOTE+OCTAVE*4+SGMI,SILENCE,SILENCE,H'100*6+2	.W	NOTE+OCTAVE*4+SGFA,SILENCE,SILENCE,H'100*6+2	.W	NOTE+OCTAVE*4+SGSOL,SILENCE,SILENCE,H'100*6+2	.W	NOTE+OCTAVE*4+SGLA,SILENCE,SILENCE,H'100*6+2	.W	NOTE+OCTAVE*4+SGSI,SILENCE,SILENCE,H'100*6+2	.W	NOTE+OCTAVE*5+SGDO,SILENCE,SILENCE,H'100*6+20	.W	0TBIPNIL:	.W	0	.W	0	.W	0;	*********************************;	*				*;	*	 PROCESSUS FILS 	*;	*				*;	*********************************NAMEFILS:	.ASCIZ	"SYNT_CONTROL"	.EVENPROCFILS:LOOP$:	CALL	D2WAIT		; attend un ordre	CALL	RDFIFO		; lit un byte dans le fifo	LOAD.W	D3,D0		; D3 <-- byte lu	LOAD.L	A1,#R16"TACOMMSEARCH$:	ADD.L	A1,#2+2		; A1 <-- ^suivant dans TACOMM	TEST.W	(A1)-4		; fin de la table ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	D3,(A1)-4	; ordre trouv ?	JUMP,NE SEARCH$		; non => SEARCH$				; oui =>	CLR.L	D1	LOAD.W	D1,(A1)-2	; D1 <-- adr relative routine	LOAD.L	A1,#R16"DEBUT	; A1 <-- adr absolue du driver	ADD.L	A1,D1		; A1 <-- adr absolue routine	CALL	(A1)		; excute un bip quelconque ...	JUMP	LOOP$TACOMM:	.W	BIPNOTE,DONOTE	.W	BIPACCORD,DOACCORD	.W	BIPAUDIO,DOAUDIO	.W	BIPCLOSE,DOCLOSE	.W	0; ----	BIPNOTE  ----DONOTE:	CALL	RDFIFO		; D0 <-- note (high)	LOAD.B	D1,D0	SL.W	D1,#8	CALL	RDFIFO		; D0 <-- note (low)	LOAD.B	D1,D0	LOAD.W	D2,#SILENCE	LOAD.W	D3,#SILENCE	CALL	RDFIFO		; D0 <-- enveloppe	LOAD.W	D4,D0	CALL	RDFIFO		; D0 <-- dure	LOAD.W	D5,D0	JUMP	ACCORD		; fait entendre la note; ----	BIPACCORD  ----DOACCORD:	CALL	RDFIFO		; D0 <-- note (high)	LOAD.B	D1,D0	SL.W	D1,#8	CALL	RDFIFO		; D0 <-- note (low)	LOAD.B	D1,D0	CALL	RDFIFO		; D0 <-- note (high)	LOAD.B	D2,D0	SL.W	D2,#8	CALL	RDFIFO		; D0 <-- note (low)	LOAD.B	D2,D0	CALL	RDFIFO		; D0 <-- note (high)	LOAD.B	D3,D0	SL.W	D3,#8	CALL	RDFIFO		; D0 <-- note (low)	LOAD.B	D3,D0	CALL	RDFIFO		; D0 <-- enveloppe	LOAD.W	D4,D0	CALL	RDFIFO		; D0 <-- dure	LOAD.W	D5,D0	JUMP	ACCORD		; fait entendre l'accord; ----	BIPAUDIO  ----DOAUDIO:	CLR.L	D1	LOAD.W	D2,#4-1LOOP$:	RL.L	D1,#8	CALL	RDFIFO		; D0 <-- pppp	LOAD.B	D1,D0	DECJ.W,NMO D2,LOOP$	LOAD.L	A4,D1		; A4 <-- ^en-tte + son	TEST.W	(A6)+OCHA	; dj ouvert ?	JUMP',NE WRITE$		; oui => WRITE$	LOAD.L	A3,#R16"NMLO	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre #AUDIO:	JUMP',NE EXIT$	LOAD.W	(A6)+OCHA,D6WRITE$:	LOAD.L	D4,(A4)+OADHLG	ADD.L	D4,#LADH	LOAD.W	D6,(A6)+OCHA	FOS	?WRBYTE		; joue le son audio	FOS	?CLOSE		; ferme #AUDIO:	CLR.W	(A6)+OCHAEXIT$:	RET; ----	BIPCLOSE  ----DOCLOSE:	LOAD.W	D6,(A6)+OCHA	JUMP',EQ EXIT$	FOS	?CLOSE		; ferme #AUDIO:	CLR.W	(A6)+OCHAEXIT$:	RET;--------\\; ACCORD  >;========/; Fait entendre un accord de trois notes au maximum.; Exemples de notes:;	RE			r de la premire octave;	OCTAVE*4+SOL		sol de la 4me octave;	OCTAVE*3+SI+BEMOL	si bmol de la 3me octave;	PERIODE+2500.		priode de 2500.;	BRUIT+12.		bruit de "frquence" 12.;	SILENCE			gnrateur inutilis; in	D1.W	premire note;	D2.W	deuxime note;	D3.W	troisime note;	D4.W	enveloppe (en ms);	D5.W	dure (en ms); out	-; mod	toutACCORD:	LOAD.L	A2,#R16"TABLE$	LOAD.W	D0,#SILENCE	TEST.L	D1:#15		; bruit ou silence ?	JUMP',BS NOTE0$		; oui => NOTE0$	LOAD.W	D0,D1	TCLR.L	D0:#14		; priode ?	JUMP',BS NOTE0$		; oui => NOTE0$	SL.W	D0,#1	LOAD.W	D0,(A2)+(D0.W)NOTE0$:	LOAD.W	D1,#SILENCE	TEST.L	D2:#15		; bruit ou silence ?	JUMP',BS NOTE1$		; oui => NOTE1$	LOAD.W	D1,D2	TCLR.L	D1:#14		; priode ?	JUMP',BS NOTE1$		; oui => NOTE1$	SL.W	D1,#1	LOAD.W	D1,(A2)+(D1.W)NOTE1$:	LOAD.W	D2,#SILENCE	TEST.L	D3:#15		; bruit ou silence ?	JUMP',BS NOTE2$		; oui => NOTE2$	LOAD.W	D2,D3	TCLR.L	D2:#14		; priode ?	JUMP',BS NOTE2$		; oui => NOTE2$	SL.W	D2,#1	LOAD.W	D2,(A2)+(D2.W)NOTE2$:	TEST.W	D5		; dure nulle ?	JUMP',NE PLAY$		; non => PLAY$	LOAD.W	D4,D5		; D4 <-- enveloppe !PLAY$:	LOAD.W	D3,D0	OR.W	D3,D1	OR.W	D3,D2		; trois silences ?	JUMP',EQ WAIT$		; oui => WAIT$	TEST.W	D4	JUMP',EQ WAIT$	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- enveloppe/dure	JUMP',EQ WAIT$	COMP.W	D4,#MAXSON*50	JUMP',LO ACCORD$	LOAD.W	D4,#MAXSON*50	; D4 <-- dure maximale possible !ACCORD$:	LOAD.L	A4,#(A6)+OBBUFF	; A4 <-- ^big buffer	CALL	CALCACCORD	; calcule l'accord	TEST.L	D4	JUMP',EQ EXIT$	TEST.W	(A6)+OCHA	; dj ouvert ?	JUMP',NE WRITE$		; oui => WRITE$	LOAD.L	A3,#R16"NMLO	LOAD.W	D3,#2^BOPWR	FOS	?OPEN		; ouvre #AUDIO:	JUMP',NE EXIT$	LOAD.W	(A6)+OCHA,D6WRITE$:	LOAD.L	A4,#(A4)-LADH	; A4 <-- ^en-tte	LOAD.B	(A4)+OADHTYP,#ADHTYPE	LOAD.L	(A4)+OADHLG,D4	LOAD.W	(A4)+OADHFREQ,#ADFREQ;	CLR.W	(A4)+OADHCOD	ADD.L	D4,#LADH	LOAD.W	D6,(A6)+OCHA	FOS	?WRBYTE		; joue le son	JUMP'	EXIT$WAIT$:	TEST.W	D4	JUMP',EQ EXIT$	NTREL	?DELMS		; attend ...EXIT$:	RET; Table des priodes pour les notes de la gamme tempre :TABLE$:	.W	3822.	3608.	3405.	3214.	3034.	2864.	.W	2703.	2551.	2408.	2273.	2145.	2025.	.W	1911.	1804.	1703.	1607.	1517.	1432.	.W	1351.	1276.	1204.	1136.	1073.	1012.	.W	956.	902.	851.	804.	758.	716.	.W	676.	638.	602.	568.	536.	506.	.W	478.	451.	426.	402.	379.	358.	.W	338.	319.	301.	284.	268.	253.	.W	239.	225.	213.	201.	190.	179.	.W	169.	159.	150.	142.	134.	127.	.W	119.	113.	106.	100.	95.	89.	.W	84.	80.	75.	71.	67.	63.	.W	60.	56.	53.	50.	47.	45.	.W	42.	40.	38.	36.	34.	32.	.W	30.	28.	27.	25.	24.	22.	.W	21.	20.	19.	18.	17.	16.	.W	15.	14.	13.	13.	12.	11.	.W	11.	10.	9.	9.	8.	8.	.W	7.	7.	7.	6.	6.	6.	.W	5.	5.	5.	4.	4.	4.	.W	4.	4.	3.	3.	3.	3.	.W	3.	2.	2.	2.	2.	2.	.W	2.	2.	2.	2.	1.	1.	.W	1.	1.	1.	1.	1.	1.	.W	1.	1.	1.	1.	1.	1.	.W	1.	1.	1.	1.	1.	1.;-----------\\; CALCACCORD >;===========/; Calcule le signal carr d'un accord de trois notes au maximum.; in	D0.W	premire note;	D1.W	seconde note;	D2.W	troisime note;	D4.W	dure en [20ms];	D4.LH	enveloppe en [20ms];	A4.L	destination; out	D4.L	longueur; mod	D4.L, D7.WCALCACCORD:	PUSHM.L	D0..D3,D5,D6,A4	LOAD.L	D7,D4	SWAP.W	D7		; D7 <-- enveloppe	MUL.WU	D7,#35000/50	DIV.WU	D7,#MAXNIV/6	LOAD.W	D6,D7	SWAP.W	D7	LOAD.W	D7,D6		; D7 <-- copie dans high word	MUL.WU	D4,#35000/50	; D4 <-- longueur	PUSH.L	D4	LOAD.W	D5,#MAXNIV/6	; D5 <-- coefficient	CLR.L	D6		; D6 <-- clear flags	TEST.W	D0	JUMP',EQ S1$	AND.L	D0,#H'FFFF	DIV.WU	D0,#3	TSET.L	D6:#19		; D6 <-- la note 0 existeS1$:	SWAP.W	D0		; D0 <-- mmorise dans le high word	LOAD.W	D0,#1		; D0 <-- rechargement au coup suivant	TEST.W	D1	JUMP',EQ S2$	AND.L	D1,#H'FFFF	DIV.WU	D1,#3	TSET.L	D6:#20		; D6 <-- la note 1 existeS2$:	SWAP.W	D1		; D1 <-- mmorise dans le high word	LOAD.W	D1,#1		; D1 <-- rechargement au coup suivant	TEST.W	D2	JUMP',EQ S3$	AND.L	D2,#H'FFFF	DIV.WU	D2,#3	TSET.L	D6:#21		; D6 <-- la note 2 existeS3$:	SWAP.W	D2		; D2 <-- mmorise dans le high word	LOAD.W	D2,#1		; D2 <-- rechargement au coup suivantLOOP$:	DEC.W	D0	JUMP',NE E1$	TNOT.L	D6:#16	SWAP.W	D0	LOAD.W	D6,D0	SWAP.W	D0	LOAD.W	D0,D6		; D0 <-- recharge le low wordE1$:	DEC.W	D1	JUMP',NE E2$	TNOT.L	D6:#17	SWAP.W	D1	LOAD.W	D6,D1	SWAP.W	D1	LOAD.W	D1,D6		; D1 <-- recharge le low wordE2$:	DEC.W	D2	JUMP',NE E3$	TNOT.L	D6:#18	SWAP.W	D2	LOAD.W	D6,D2	SWAP.W	D2	LOAD.W	D2,D6		; D2 <-- recharge le low wordE3$:	DEC.W	D7	JUMP',NE VAL$	TEST.W	D5	JUMP',EQ VAL$	DEC.W	D5		; D5 <-- coefficient diminue	SWAP.W	D7	LOAD.W	D6,D7	SWAP.W	D7	LOAD.W	D7,D6		; D7 <-- recharge le low wordVAL$:	LOAD.W	D3,#MAXNIV/2	; D3 <-- niveau "zro"	TEST.L	D6:#19		; note 0 existe ?	JUMP',BC B1$	SUB.W	D3,D5	TEST.L	D6:#16	JUMP',BC B1$	ADD.W	D3,D5	ADD.W	D3,D5B1$:	TEST.L	D6:#20		; note 1 existe ?	JUMP',BC B2$	SUB.W	D3,D5	TEST.L	D6:#17	JUMP',BC B2$	ADD.W	D3,D5	ADD.W	D3,D5B2$:	TEST.L	D6:#21		; note 2 existe ?	JUMP',BC B3$	SUB.W	D3,D5	TEST.L	D6:#18	JUMP',BC B3$	ADD.W	D3,D5	ADD.W	D3,D5B3$:	LOAD.B	(A4+),D3	; buffer <-- crit l'chantillon	DEC.L	D4		; D4 <-- compteur de dure	JUMP,NE	LOOP$	POP.L	D4	POPM.L	D0..D3,D5,D6,A4	RET; Gestion du fifo; ---------------;--------\\; INIFIFO >;========/; Initialise un nouveau fifo vide.; in	-; out	-; mod	-INIFIFO:	PUSHM.L	A1,A4	LOAD.L	A1,#(A6)+OFIFO	; A1 <-- ^fifo	LOAD.L	A4,#(A1)+LGFIFO	; A4 <-- ^dbut data dans fifo	LOAD.L	(A1)+OFIHEAD,A4	; init ^tte	LOAD.L	(A1)+OFITAIL,A4	; init ^queue (= ^tte)	LOAD.L	(A1)+OFIBEG,A4	; init ^dbut fifo	LOAD.L	A4,#(A4)+MAXFIFO	LOAD.L	(A1)+OFIEND,A4	; init ^fin fifo	POPM.L	A1,A4	RET;--------\\; RDFIFO  >;========/; Lit un lment dans un fifo quelconque.;	TAIL = HEAD ?		oui => fifo vide;	D0.B <-- (TAIL)		lit le data;	TAIL <-- TAIL+1		avance le ^de queue; in	-; out	D0.B	data lu; mod	D0.LRDFIFO:	PUSHM.L	A1,A2	LOAD.L	A1,#(A6)+OFIFO	; A1 <-- ^fifo	LOAD.L	A2,(A1)+OFITAIL	COMP.L	A2,(A1)+OFIHEAD	; TAIL = HEAD  ?	JUMP',EQ FATAL$		; oui => fifo vide	CLR.L	D0	LOAD.B	D0,(A2+)	; lit un byte	COMP.L	A2,(A1)+OFIEND	JUMP',NE TAIL$	LOAD.L	A2,(A1)+OFIBEGTAIL$:	LOAD.L	(A1)+OFITAIL,A2	; mj TAIL	CALL	D1UNLOCK	; un lment lu	POPM.L	A1,A2	RETFATAL$:	.W	H'A042	.ASCIZ	"Erreur fatale $SYNT: fifo vide<CR>"	.EVEN	TRAP	#0;--------\\; WRFIFO  >;========/; Ajoute un lment dans un fifo quelconque.;	HEAD <-- HEAD+1		avance le ^de tte;	HEAD = TAIL ?		oui => fifo plein;	(HEAD) <-- D0.B		crit le data; in	D0.B	lment  crire; out	-; mod	-WRFIFO:	PUSHM.L	A0..A2	CALL	D1LOCK		; attend si fifo plein ...	LOAD.L	A1,#(A6)+OFIFO	; A1 <-- ^fifo	LOAD.L	A2,(A1)+OFIHEAD	LOAD.L	A0,A2	INC.L	A2		; avance HEAD	COMP.L	A2,(A1)+OFIEND	JUMP',NE HEAD$	LOAD.L	A2,(A1)+OFIBEGHEAD$:	COMP.L	A2,(A1)+OFITAIL	; HEAD = TAIL  ?	JUMP',EQ FATAL$		; oui => fifo plein	LOAD.L	(A1)+OFIHEAD,A2	; mj HEAD	LOAD.B	(A0),D0		; crit un byte	POPM.L	A0..A2	RETFATAL$:	.W	H'A042	.ASCIZ	"Erreur fatale $SYNT: fifo plein<CR>"	.EVEN	TRAP	#0; Le smaphore zro permet de faire de l'exclusion mutuelle; lors de l'envoi d'une commande de plusieurs bytes (BIPNOTE; ou BIPACCORD) pour que personne ne puisse intercaler une; autre commande.;--------\\; D0LOCK  >;========/; in	-; out	-; mod	-D0LOCK:	PUSHM.L	D7,A5	LOAD.L	A5,(A6)+OPSEM0	; A5 <-- ^smaphore	NTREL	?LOCK		; attend ...	POPM.L	D7,A5	RET;---------\\; D0UNLOCK >;=========/; in	-; out	-; mod	-D0UNLOCK:	PUSHM.L	D7,A5	LOAD.L	A5,(A6)+OPSEM0	; A5 <-- ^smaphore	NTREL	?UNLOCK		; signal fin zone critique	POPM.L	D7,A5	RET; Le smaphore un est initialis avec e=maxfifo. Il permet; de suspendre le processus appelant le driver lorsque le; fifo est plein.;--------\\; D1LOCK  >;========/; in	-; out	-; mod	-D1LOCK:	PUSHM.L	D7,A5	LOAD.L	A5,(A6)+OPSEM1	; A5 <-- ^smaphore	NTREL	?LOCK		; attend si fifo plein ...	POPM.L	D7,A5	RET;---------\\; D1UNLOCK >;=========/; in	-; out	-; mod	-D1UNLOCK:	PUSHM.L	D7,A5	LOAD.L	A5,(A6)+OPSEM1	; A5 <-- ^smaphore	NTREL	?UNLOCK		; signal fifo pas plein	POPM.L	D7,A5	RET; Le smaphore deux permet la communication entre le processus; appelant le driver et le processus fils du driver.; Lorsqu'une commande est dans le fifo, le processus appelant; fait un SIGNAL. Le fils attend sur un WAIT, excute une; commande (un son), fait ventuellement un dlai, puis; recommence.;--------\\; D2WAIT  >;========/; in	-; out	-; mod	-D2WAIT:	PUSHM.L	D7,A5	LOAD.L	A5,(A6)+OPSEM2	; A5 <-- ^smaphore	NTREL	?WAITEV		; attend une commande ...	POPM.L	D7,A5	RET;---------\\; D2SIGNAL >;=========/; in	-; out	-; mod	-D2SIGNAL:	PUSHM.L	D7,A5	LOAD.L	A5,(A6)+OPSEM2	; A5 <-- ^smaphore	NTREL	?SIGNEV		; signal commande dans fifo	POPM.L	D7,A5	RET;----------\\; AUDIOREAD >;==========/; Lit un fichier *.AUDIO en mmoire.; in	A3.L	^nom; out	A4.L	^data;	D4.L	lg data;	D7.W	erreur; mod	D4.L, D7.W, A4.LAUDIOREAD:	PUSHM.L	D1,D3,D6,A1	LOAD.W	D3,#2^BOPRD!2^BOPSYS	FOS	?OPEN	JUMP',NE EXIT$	LOAD.L	D3,#-1	LOAD.L	D4,D3	FOS	?SPOS		; D4 <-- longueur	PUSH.L	D4	CLR.L	D3	CLR.L	D4	FOS	?SPOS	POP.L	D4	LOAD.L	A1,#R16"S0BASE	LOAD.W	D1,#MTYPBD	GESMEM	?GETMEM	JUMP',NE CLOSE$	FOS	?RDBYTE		; lit le fichier .AUDIOCLOSE$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	POPM.L	D1,D3,D6,A1	TEST.W	D7		; retour EQ/NE	RET;------------\\; AUDIOSEARCH >;============/; Cherche un son audio dans 300_SYNT.AUDIO; in	D3.B	BIP* cherch; out	A3.L	^son;	D7.W	erreur; mod	D7.W, A3.LAUDIOSEARCH:	PUSHM.L	D1..D4	TEST.L	(A6)+OAUDPF	; fichier 300_SYNT.AUDIO charg ?	JUMP',EQ ERROR$	COMP.B	D3,#99	JUMP',HI ERROR$	LOAD.L	A3,(A6)+OAUDPF	; A3 <-- ^fichier	LOAD.L	D4,(A6)+OAUDLF	; D4 <-- lg totaleLOOP$:	TEST.L	D4		; reste qq chose ?	JUMP',LE ERROR$		; non => ERROR$	CLR.W	D2	LOAD.B	D2,(A3)+OADHNAME+0	SUB.B	D2,#'0	JUMP',LO NEXT$	COMP.B	D2,#9	JUMP',HI NEXT$	LOAD.B	D1,(A3)+OADHNAME+1	SUB.B	D1,#'0	JUMP',LO M10$	COMP.B	D1,#9	JUMP',HI M10$	MUL.WU	D2,#10	ADD.B	D2,D1M10$:	COMP.B	D2,D3	JUMP',EQ FOUND$NEXT$:	LOAD.L	D2,(A3)+OADHLG	ADD.L	D2,#LADH	; D2 <-- lg avec en-tte	SUB.L	D4,D2		; D4 <-- lg restante	ADD.L	A3,D2		; A3 <-- ^son suivant	JUMP	LOOP$FOUND$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1		; D7 <-- pas trouvEXIT$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET; Textes; ------NMAUDIO:.ASCIZ	"#:300_SYNT.AUDIO"NMLO:	.ASCIZ	"#AUDIO"NMPH:	.ASCIZ	"$AUDIO_0"	.EVEN	.END