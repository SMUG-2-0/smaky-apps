	.SBTTL	TRAINCEL.ASI;----------\\; CELASMOVE >;==========/; Dplace les ascenseurs.; in	D4.L	position de la souris; out	D7.W	erreur; mod	D7.WCELASMOVE:	PUSHM.L	D3..D5,A5	LOAD.L	D5,D4	LOAD.L	A5,#(A6)+OASHOR	TEST.W	(A5)+OSCHTV	JUMP',EQ VERT$	LOAD.W	(A5)+OSCINC,#1;	LOAD.L	D4,D5	SCROLL_	MOVE	JUMP',EQ DRAW$VERT$:	LOAD.L	A5,#(A6)+OASVER	TEST.W	(A5)+OSCHTV	JUMP',EQ EXIT$	LOAD.W	(A5)+OSCINC,#1	LOAD.L	D4,D5	SCROLL_	MOVE	JUMP',NE EXIT$DRAW$:	CALL	CELUPDATE	CLR.W	D7EXIT$:	POPM.L	D3..D5,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; CELUPDATE >;==========/; Met  jour le contenu de la fentre.; in	-; out	-; mod	D7.WCELUPDATE:	PUSHM.L	D0..D4,A4,A5	LOAD.L	A5,#(A6)+OASHOR	LOAD.W	D4,(A6)+OCELNX	SUB.W	D4,(A6)+OCELVX	JUMP',LE HLITTLE$	INC.W	D4	LOAD.W	(A5)+OSCHTV,D4	SCROLL_	UPDATE	JUMP'	HEND$HLITTLE$:	CLR.W	(A5)+OSCHTV	CLR.W	(A5)+OSCPOSVHEND$:	LOAD.L	A5,#(A6)+OASVER	LOAD.W	D4,(A6)+OCELNY	SUB.W	D4,(A6)+OCELVY	JUMP',LE VLITTLE$	INC.W	D4	LOAD.W	(A5)+OSCHTV,D4	SCROLL_	UPDATE	JUMP'	VEND$VLITTLE$:	CLR.W	(A5)+OSCHTV	CLR.W	(A5)+OSCPOSVVEND$:	CLR.W	D0LOOPY$:	CLR.W	D2LOOPX$:	LOAD.W	D1,D0	ADD.W	D1,(A6)+OASVER+OSCPOSV	MUL.WU	D1,(A6)+OCELNX	ADD.W	D1,D2	ADD.W	D1,(A6)+OASHOR+OSCPOSV	CALL	CELGETP		; A4 <-- ^cellule	JUMP',NE NEXT$	CALL	CELDRAW		; dessine une celluleNEXT$:	INC.W	D2	COMP.W	D2,(A6)+OCELVX	JUMP,LO LOOPX$	INC.W	D0	COMP.W	D0,(A6)+OCELVY	JUMP,LO LOOPY$	POPM.L	D0..D4,A4,A5	RET;---------\\; CELCADRE >;=========/; Dessine la cadre et les ascenseurs.; in	-; out	-; mod	D7.WCELCADRE:	PUSHM.L	D2..D4,A5	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.L	D3,#H'10000*COLORFCADRE+COLORCCADRE	CALL	DESCOLOR	LOAD.L	D3,#H'88228822	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; grise toute la fentre	PUSH.L	D3	LOAD.L	D3,#H'10000*COLORCINFO+COLORFINFO	CALL	DESCOLOR	POP.L	D3	PUSHM.L	D3,D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	POPM.L	D3,D4	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LIB	?DRTRAME	; dessine une bande blanche en haut	CALL	DESINFO		; affiche les informations	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A6)+OCELPY	LOAD.L	D4,(A6)+OCELDY	SUB.W	D3,#LGSCROLL-1	ADD.W	D4,#LGSCROLL-1	SWAP.W	D4	ADD.W	D4,#LGSCROLL-1	SWAP.W	D4	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	PUSH.L	D3	LOAD.L	D3,#H'10000*COLORFDRAW+COLORCCADRE	CALL	DESCOLOR	POP.L	D3	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface toute la fentre	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour fentre	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	LOAD.L	A5,#(A6)+OASHOR	LOAD.W	D4,(A6)+OCELPX	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OCELPY	ADD.W	D4,(A6)+OCELDY	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OCELDX	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	SCROLL_	DRAW		; dessine la cage horizontale	LOAD.L	A5,#(A6)+OASVER	LOAD.W	D4,(A6)+OCELPY	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OCELPX	SUB.W	D4,#LGSCROLL	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OCELDY	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	CLR.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	SCROLL_	DRAW		; dessine la cage verticale	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D2..D4,A5	RET;--------\\; CELMOVE >;========/; Action dans un carr.; in	D4.L	position de la souris (y;x); out	D1.W	rang (0..n);	D7.W	erreur; mod	D1.L, D7.WCELMOVE:	PUSHM.L	D2..D4,A2,A4	CALL	CELDET		; D1 <-- carr o est la souris	JUMP,NE EXIT$	LOAD.W	D2,D1	CALL	CELMOD		; modifie	CALL	CELINV		; allume le premierLOOP$:	CALL	SCMO		; remet la souris	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	CELDET		; D1 <-- carr o est la souris	COMP.W	D1,D2	JUMP,EQ LOOP$	EX.L	D1,D2	CALL	CELINV		; teint l'ancien	CALL	CELMOD		; modifie	LOAD.W	D1,D2	CALL	CELINV		; allume le nouveau	JUMP	LOOP$END$:	LOAD.W	D1,D2	CALL	CELINV		; teint le dernier	CALL	CELPOS		; D3/D4 <-- position/dimensions	JUMP,NE EXIT$	COMP.W	(A6)+OPALNIV,#ICOLOCO	JUMP,EQ LOCO$	COMP.W	(A6)+OPALNIV,#ICOMOD	JUMP,NE EXIT$	CALL	CELIFUNIT	; est-ce une unit ?	JUMP,NE EXIT$	CALL	CELGETP		; A4 <-- ^cellule	JUMP,NE EXIT$	CALL	IFLOCKUNITP	; unit bloque pour l'instant ?	JUMP,NE EXIT$		; oui => EXIT$	LOAD.B	D3,(A4)+OCEICO	COMP.B	D3,#ICORHR	JUMP,EQ DET$	COMP.B	D3,#ICORVR	JUMP,EQ DET$	COMP.B	D3,#ICORHC	JUMP,EQ IND$	COMP.B	D3,#ICORVC	JUMP,EQ IND$	TEST.W	(A4)+OCEUNI	; y a-t-il un numro d'unit ?	JUMP',NE CHANGE$	; oui => CHANGE$	LOAD.W	D7,#1	TEST.B	(A6)+OMANU	; bouge aussi les aiguillages manuels ?	JUMP,F	EXIT$		; non => EXIT$CHANGE$:	TEST.B	(A4)+OCEETA	JUMP',EQ ZERO$	CLR.B	(A4)+OCEETA	JUMP'	ETAT$ZERO$:	LOAD.B	(A4)+OCEETA,#1;	JUMP'	ETAT$ETAT$:	CALL	CELDRAW		; dessine la nouvelle situation	CALL	ALGOSND		; excute un ventuel script !	CALL	MAJUNITRC	; met  jour l'tat	COMP.B	D3,#ICORHUR	JUMP',EQ AIG$	COMP.B	D3,#ICORHUL	JUMP',EQ AIG$	COMP.B	D3,#ICORHDR	JUMP',EQ AIG$	COMP.B	D3,#ICORHDL	JUMP',EQ AIG$	COMP.B	D3,#ICORVUR	JUMP',EQ AIG$	COMP.B	D3,#ICORVUL	JUMP',EQ AIG$	COMP.B	D3,#ICORVDR	JUMP',EQ AIG$	COMP.B	D3,#ICORVDL	JUMP',EQ AIG$	COMP.B	D3,#ICORTJD1	JUMP',EQ AIG$	COMP.B	D3,#ICORTJD2	JUMP',NE OK$AIG$:	CALL	LOCOSEARCH	; A2 <-- ^loco/wagon sur l'aiguillage	JUMP',NE OK$	CALL	LOCOCRASH	; destruction du train !OK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$IND$:	LOAD.W	D7,#1	TEST.B	(A6)+OAIND	; action dans les indicateurs ?	JUMP',F EXIT$		; non => EXIT$	JUMP	CHANGE$DET$:	LOAD.W	D7,#1	TEST.B	(A6)+OADET	; action dans les dtecteurs ?	JUMP',F EXIT$		; non => EXIT$	CALL	ALGOSND		; simule le passage d'un train sur un dtecteur !	JUMP'	EXIT$LOCO$:	LOAD.W	D2,#8	COMP.W	(A6)+OLNBW,#20	JUMP',EQ LNEW$	LOAD.W	D2,#4	COMP.W	(A6)+OLNBW,#19	JUMP',EQ LNEW$	CLR.W	D2LNEW$:	CALL	LOCONEW		; cre un nouveau train (locomotive/wagons)EXIT$:	POPM.L	D2..D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; CELMOD >;-------/; Modifie une ligne de cellules.; in	D1.W	ancien rang (0..n);	D2.W	nouveau rang (0..n); out	-; mod	D7.WCELMOD:	PUSHM.L	D1,D3	COMP.W	(A6)+OPALNIV,#ICODRAW	JUMP',NE EXIT$	LOAD.W	D3,(A6)+ORAIL	CALL	RANGICO		; D3 <-- icne du rail slectionn	LOAD.W	D1,D2	CALL	CELMODONE	; modifie une celluleEXIT$:	POPM.L	D1,D3	RET;----------\\; CELMODONE >;----------/; Modifie une cellule.; in	D1.W	rang (0..n);	D3.W	nouvelle icne; out	-; mod	D7.WCELMODONE:	PUSHM.L	D3,D4,A3,A4	CALL	CELGETP		; A4 <-- ^cellule	CLR.W	D4	LOAD.B	D4,(A4)+OCEICO	; D4 <-- icne du rail actuel	COMP.W	D3,D4	JUMP,EQ EXIT$	LOAD.L	A3,#R16"TABLE$-(3*2)SRC$:	ADD.L	A3,#(3*2)	TEST.W	(A3)	JUMP',EQ NOT$	COMP.W	D3,(A3)+0	JUMP,NE SRC$	COMP.W	D4,(A3)+2	JUMP,NE SRC$	LOAD.W	D3,(A3)+4NOT$:	LOAD.B	(A4)+OCEICO,D3	; change l'icne	CLR.B	(A4)+OCEETA	CLR.W	(A4)+OCEUNI	CLR.B	(A4)+OCEPOR	CLR.B	(A4)+OCEPAR	CALL	CELDRAW		; dessine la nouvelle situationEXIT$:	POPM.L	D3,D4,A3,A4	RET	;	slectionn,actuelTABLE$:	.W	ICORH,ICORUL		ICORHUL	.W	ICORH,ICORUR		ICORHUR	.W	ICORH,ICORDL		ICORHDL	.W	ICORH,ICORDR		ICORHDR	.W	ICORUL,ICORH		ICORHUL	.W	ICORUR,ICORH		ICORHUR	.W	ICORDL,ICORH		ICORHDL	.W	ICORDR,ICORH		ICORHDR	.W	ICORV,ICORUL		ICORVUL	.W	ICORV,ICORUR		ICORVUR	.W	ICORV,ICORDL		ICORVDL	.W	ICORV,ICORDR		ICORVDR	.W	ICORUL,ICORV		ICORVUL	.W	ICORUR,ICORV		ICORVUR	.W	ICORDL,ICORV		ICORVDL	.W	ICORDR,ICORV		ICORVDR	.W	ICORH,ICORV		ICORHV	.W	ICORV,ICORH		ICORHV	.W	ICORHV,ICORUL		ICORTJD1	.W	ICORHV,ICORDR		ICORTJD1	.W	ICORUL,ICORHV		ICORTJD1	.W	ICORDR,ICORHV		ICORTJD1	.W	ICORHV,ICORUR		ICORTJD2	.W	ICORHV,ICORDL		ICORTJD2	.W	ICORUR,ICORHV		ICORTJD2	.W	ICORDL,ICORHV		ICORTJD2	.W	ICORHV,ICORTJD1		ICORHV	.W	ICORHV,ICORTJD2		ICORHV	.W	ICORHS,ICORV		ICORVS	.W	ICORHS,ICORVS		ICORVS	.W	ICORHS,ICORVD		ICORVS	.W	ICORHS,ICORVC		ICORVS	.W	ICORHS,ICORVR		ICORVS	.W	ICORHD,ICORV		ICORVD	.W	ICORHD,ICORVS		ICORVD	.W	ICORHD,ICORVD		ICORVD	.W	ICORHD,ICORVC		ICORVD	.W	ICORHD,ICORVR		ICORVD	.W	ICORHC,ICORV		ICORVC	.W	ICORHC,ICORVS		ICORVC	.W	ICORHC,ICORVD		ICORVC	.W	ICORHC,ICORVC		ICORVC	.W	ICORHC,ICORVR		ICORVC	.W	ICORHR,ICORV		ICORVR	.W	ICORHR,ICORVS		ICORVR	.W	ICORHR,ICORVD		ICORVR	.W	ICORHR,ICORVC		ICORVR	.W	ICORHR,ICORVR		ICORVR	.W	0;----------\\; CELTXTYPE >;==========/; Donne le type d'une cellule.; in	D3.B	icne d'une cellule; out	A3.L	^texte du type;	D7.W	erreur; mod	D7.W, A3.LCELTXTYPE:	CLR.W	D7	LOAD.L	A3,#R16"TXTYPA$	COMP.B	D3,#ICORHUR	JUMP,EQ EXIT$	COMP.B	D3,#ICORHUL	JUMP,EQ EXIT$	COMP.B	D3,#ICORHDR	JUMP,EQ EXIT$	COMP.B	D3,#ICORHDL	JUMP,EQ EXIT$	COMP.B	D3,#ICORVUR	JUMP,EQ EXIT$	COMP.B	D3,#ICORVUL	JUMP,EQ EXIT$	COMP.B	D3,#ICORVDR	JUMP,EQ EXIT$	COMP.B	D3,#ICORVDL	JUMP,EQ EXIT$	LOAD.L	A3,#R16"TXTYPT$	COMP.B	D3,#ICORTJD1	JUMP,EQ EXIT$	COMP.B	D3,#ICORTJD2	JUMP,EQ EXIT$	LOAD.L	A3,#R16"TXTYPS$	COMP.B	D3,#ICORHS	JUMP,EQ EXIT$	COMP.B	D3,#ICORVS	JUMP,EQ EXIT$	LOAD.L	A3,#R16"TXTYPD$	COMP.B	D3,#ICORHD	JUMP,EQ EXIT$	COMP.B	D3,#ICORVD	JUMP,EQ EXIT$	LOAD.L	A3,#R16"TXTYPC$	COMP.B	D3,#ICORHC	JUMP',EQ EXIT$	COMP.B	D3,#ICORVC	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TXTYPR$	COMP.B	D3,#ICORHR	JUMP',EQ EXIT$	COMP.B	D3,#ICORVR	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TXTYPG$	COMP.B	D3,#ICORGO	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TXTYPI$	COMP.B	D3,#ICORINV	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TXTYPK$	COMP.B	D3,#ICORCLA	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TXTYPM$	COMP.B	D3,#ICORMAN	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TXTYPL$	COMP.B	D3,#ICORLI	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TXTYPJ$	COMP.B	D3,#ICORSW	JUMP',EQ EXIT$	LOAD.L	A3,#TXNIL$	LOAD.W	D7,#1EXIT$:	TEST.W	D7		; retour EQ/NE	RETTXTYPA$:.ASCIZ	"Aiguillage"TXTYPT$:.ASCIZ	"TJD"TXTYPS$:.ASCIZ	"Secteur"TXTYPD$:.ASCIZ	"Dteleur"TXTYPC$:.ASCIZ	"Compteur"TXTYPR$:.ASCIZ	"Dtecteur"TXTYPG$:.ASCIZ	"Marche/arrt"TXTYPI$:.ASCIZ	"Avant/arrire"TXTYPK$:.ASCIZ	"Clavier"TXTYPM$:.ASCIZ	"Manoeuvre"TXTYPL$:.ASCIZ	"Eclairage"TXTYPJ$:.ASCIZ	"Interrupteur"TXNIL$:	.ASCIZ	""	.EVEN;----------\\; CELIFUNIT >;==========/; Regarde si une cellule est une unit.; in	D1.W	rang cellule; out	D7.W	erreur si pas une unit; mod	D7.WCELIFUNIT:	PUSHM.L	D4,A4	CALL	CELGETP		; A4 <-- ^cellule	JUMP',NE EXIT$	LOAD.B	D4,(A4)+OCEICO	; D4 <-- icne de la cellule	LOAD.L	A4,#R16"TABLE$	LOAD.W	D7,#1LOOP$:	TEST.B	(A4)	JUMP',EQ EXIT$	COMP.B	D4,(A4+)	JUMP,NE LOOP$	CLR.W	D7EXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.B	ICORHUR	.B	ICORHUL	.B	ICORHDR	.B	ICORHDL	.B	ICORVUR	.B	ICORVUL	.B	ICORVDR	.B	ICORVDL	.B	ICORTJD1	.B	ICORTJD2	.B	ICORHS	.B	ICORVS	.B	ICORHD	.B	ICORVD	.B	ICORHC	.B	ICORVC	.B	ICORHR	.B	ICORVR	.B	ICORGO	.B	ICORINV	.B	ICORCLA	.B	ICORMAN	.B	ICORLI	.B	ICORSW	.B	0	.EVEN;-------\\; CELDET >;-------/; Dtecte dans quel carr est la souris.; in	D4.L	position de la souris (y;x); out	D1.W	rang (0..n);	D7.W	erreur; mod	D1.L, D7.WCELDET:	PUSHM.L	D2,D3	LOAD.W	D7,#1	LOAD.W	D1,#-1	CLR.L	D3	LOAD.W	D3,D4	SUB.W	D3,(A6)+OCELPX	JUMP',LO EXIT$	DIV.WU	D3,(A6)+OCELDIM	COMP.W	D3,(A6)+OCELVX	JUMP',HS EXIT$	COMP.W	D3,(A6)+OCELNX	JUMP',HS EXIT$	ADD.W	D3,(A6)+OASHOR+OSCPOSV	LOAD.L	D2,D4	CLR.W	D2	SWAP.W	D2	SUB.W	D2,(A6)+OCELPY	JUMP',LO EXIT$	DIV.WU	D2,(A6)+OCELDIM	COMP.W	D2,(A6)+OCELVY	JUMP',HS EXIT$	COMP.W	D2,(A6)+OCELNY	JUMP',HS EXIT$	ADD.W	D2,(A6)+OASVER+OSCPOSV	MUL.WU	D2,(A6)+OCELNX	LOAD.W	D1,D3	ADD.W	D1,D2		; D1 <-- rang	CLR.W	D7EXIT$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; CELDRAW >;--------/; Dessine une icne.; in	D1.W	rang (0..n);	A4.L	^cellule; out	-; mod	D7.WCELDRAW:	PUSHM.L	D0..D4,A2,A3	CALL	CELPOS		; D3/D4 <-- position/dimensions	JUMP,NE EXIT$	LOAD.L	D4,D3		; D4 <-- position	CLR.W	D3	LOAD.B	D3,(A4)+OCEICO	LOAD.W	D0,D3	CLR.W	D2	LOAD.B	D2,(A4)+OCEETA	; D2 <-- tat	JUMP',EQ DRAW$	COMP.W	D2,#4	JUMP',HS ERROR$	LOAD.L	A3,#R16"TABLE$-8SRC$:	ADD.L	A3,#8		; A3 <-- ^suivant	TEST.W	(A3)	JUMP',EQ ERROR$	COMP.W	D3,(A3)	JUMP,NE SRC$	SL.W	D2,#1	LOAD.W	D3,(A3)+(D2.W)	JUMP',NE DRAW$ERROR$:	LOAD.W	D3,#ICORERR	; D3 <-- icne "?"DRAW$:	CALL	DESICONE	; dessine l'icne	TEST.B	(A6)+OGRILLE	JUMP',F GRILLE$	LOAD.W	D1,#SETDOT	LOAD.L	A2,A0	GRA_	DOT		; met un point de la grilleGRILLE$:	TEST.B	(A6)+OZOOM	JUMP,F	LOCO$	LOAD.W	D3,#ICORH	COMP.W	D0,#ICORH	JUMP',EQ UR$	COMP.W	D0,#ICORHUR	JUMP',EQ UR$	COMP.W	D0,#ICORHUL	JUMP',EQ UR$	COMP.W	D0,#ICORHDR	JUMP',EQ UR$	COMP.W	D0,#ICORHDL	JUMP',EQ UR$	COMP.W	D0,#ICORVUR	JUMP',EQ UR$	COMP.W	D0,#ICORVDR	JUMP',EQ UR$	COMP.W	D0,#ICORHS	JUMP',EQ UR$	COMP.W	D0,#ICORHD	JUMP',EQ UR$	COMP.W	D0,#ICORHC	JUMP',EQ UR$	COMP.W	D0,#ICORHR	JUMP',EQ UR$	COMP.W	D0,#ICORUR	JUMP',EQ UR$	COMP.W	D0,#ICORDR	JUMP',EQ UR$	COMP.W	D0,#ICORBR	JUMP',EQ UR$	COMP.W	D0,#ICORHV	JUMP',EQ UR$	COMP.W	D0,#ICORHVH	JUMP',EQ UR$	COMP.W	D0,#ICORHVV	JUMP',EQ UR$	COMP.W	D0,#ICORTJD1	JUMP',EQ UR$	COMP.W	D0,#ICORTJD2	JUMP',EQ UR$	LOAD.W	D3,#ICORVIDEUR$:	ADD.W	D4,#CELDIM	CALL	DESICONE	; dessine l'icne	LOAD.W	D3,#ICORV	COMP.W	D0,#ICORV	JUMP',EQ DL$	COMP.W	D0,#ICORVUR	JUMP',EQ DL$	COMP.W	D0,#ICORVUL	JUMP',EQ DL$	COMP.W	D0,#ICORVDR	JUMP',EQ DL$	COMP.W	D0,#ICORVDL	JUMP',EQ DL$	COMP.W	D0,#ICORHDR	JUMP',EQ DL$	COMP.W	D0,#ICORHDL	JUMP',EQ DL$	COMP.W	D0,#ICORVS	JUMP',EQ DL$	COMP.W	D0,#ICORVD	JUMP',EQ DL$	COMP.W	D0,#ICORVC	JUMP',EQ DL$	COMP.W	D0,#ICORVR	JUMP',EQ DL$	COMP.W	D0,#ICORDR	JUMP',EQ DL$	COMP.W	D0,#ICORDL	JUMP',EQ DL$	COMP.W	D0,#ICORBD	JUMP',EQ DL$	COMP.W	D0,#ICORHV	JUMP',EQ DL$	COMP.W	D0,#ICORHVH	JUMP',EQ DL$	COMP.W	D0,#ICORHVV	JUMP',EQ DL$	COMP.W	D0,#ICORTJD1	JUMP',EQ DL$	COMP.W	D0,#ICORTJD2	JUMP',EQ DL$	LOAD.W	D3,#ICORVIDEDL$:	SUB.W	D4,#CELDIM	SWAP.W	D4	ADD.W	D4,#CELDIM	SWAP.W	D4	CALL	DESICONE	; dessine l'icne	LOAD.W	D3,#ICORVIDE	ADD.W	D4,#CELDIM	CALL	DESICONE	; dessine l'icne	LOAD.W	D3,(A4)+OCEUNI	JUMP',EQ LOCO$	SUB.W	D4,#4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	CALL	DESCHIFFRE	; dessine le chiffreLOCO$:	CLR.W	D2	LOAD.B	D2,(A4)+OCENLO	; D2 <-- locomotive sur la cellule	JUMP',EQ EXIT$	CALL	LOCORD		; A2 <-- ^descripteur locomotive	CALL	LOCOINVONE	; dessine loco/wagonEXIT$:	POPM.L	D0..D4,A2,A3	RETTABLE$:	.W	ICORHS,ICORHS!2^7,0,0	.W	ICORVS,ICORVS!2^7,0,0	.W	ICORHD,ICORHD!2^7,0,0	.W	ICORVD,ICORVD!2^7,0,0	.W	ICORHC,ICORHC!2^7,ICORHC23,ICORHC23!2^7	.W	ICORVC,ICORVC!2^7,ICORVC23,ICORVC23!2^7	.W	ICORHR,ICORHR!2^7,0,0	.W	ICORVR,ICORVR!2^7,0,0	.W	ICORHUL,ICORHUL!2^7,0,0	.W	ICORHUR,ICORHUR!2^7,0,0	.W	ICORHDL,ICORHDL!2^7,0,0	.W	ICORHDR,ICORHDR!2^7,0,0	.W	ICORVUL,ICORVUL!2^7,0,0	.W	ICORVUR,ICORVUR!2^7,0,0	.W	ICORVDL,ICORVDL!2^7,0,0	.W	ICORVDR,ICORVDR!2^7,0,0	.W	ICORTJD1,ICORTJD1!2^7,0,0	.W	ICORTJD2,ICORTJD2!2^7,0,0	.W	ICORGO,ICORGO!2^7,0,0	.W	ICORINV,ICORINV!2^7,0,0	.W	ICORCLA,ICORCLA!2^7,0,0	.W	ICORMAN,ICORMAN!2^7,0,0	.W	ICORLI,ICORLI!2^7,0,0	.W	ICORSW,ICORSW!2^7,0,0	.W	0	.EVEN;-------\\; CELINV >;-------/; Inverse un carr.; in	D1.W	rang (0..n); out	-; mod	D7.WCELINV:	PUSHM.L	D2..D4	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.L	D3,#H'10000*COLORFDRAW+COLOR_PPHILI	CALL	DESCOLOR	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	CELPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	ADD.W	D3,#1	SWAP.W	D3	ADD.W	D3,#1	SWAP.W	D3	SUB.W	D4,#1	SWAP.W	D4	SUB.W	D4,#1	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse le contrleEXIT$:	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D2..D4	RET;--------\\; CELPOS  >;--------/; Donne la position et les dimensions d'une icne.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WCELPOS:	PUSH.L	D1	LOAD.W	D7,#1	COMP.W	D1,#-1	JUMP',EQ EXIT$	AND.L	D1,#H'FFFF	DIV.WU	D1,(A6)+OCELNX	; D1 <-- rang (x;y)	LOAD.L	D3,(A6)+OCELPY	LOAD.W	D4,D1	SUB.W	D4,(A6)+OASVER+OSCPOSV	JUMP',LO EXIT$	COMP.W	D4,(A6)+OCELVY	JUMP',HS EXIT$	MUL.WU	D4,(A6)+OCELDIM	SWAP.W	D3	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	D4,D1	SWAP.W	D4	SUB.W	D4,(A6)+OASHOR+OSCPOSV	JUMP',LO EXIT$	COMP.W	D4,(A6)+OCELVX	JUMP',HS EXIT$	MUL.WU	D4,(A6)+OCELDIM	ADD.W	D3,D4	LOAD.W	D4,(A6)+OCELDIM	SWAP.W	D4	LOAD.W	D4,(A6)+OCELDIM	CLR.W	D7EXIT$:	POP.L	D1	TEST.W	D7		; retour EQ/NE	RET;--------\\; CELMAJ >;========/; Cherche toutes les units spciales dessines.; in	-; out	-; mod	D7.WCELMAJ:	CALL	CELMAJDET	CALL	CELMAJCLA	CALL	CELMAJGO	RET;----------\\; CELMAJDET >;----------/; Cherche tous les dtecteurs dessins.; in	-; out	-; mod	D7.WCELMAJDET:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A3,#(A6)+OTADET	CLR.W	D3	LOAD.L	A4,(A6)+OPCEL	LOAD.W	D4,(A6)+OCELNX	MUL.WU	D4,(A6)+OCELNY	; D4 <-- nb de cellules	DEC.W	D4		; D4 <-- -1  cause NMO	CLR.W	D2LOOP$:	COMP.B	(A4)+OCEICO,#ICORHR	JUMP',EQ DET$	COMP.B	(A4)+OCEICO,#ICORVR	JUMP',NE NEXT$DET$:	TEST.W	(A4)+OCEUNI	JUMP',EQ NEXT$	LOAD.W	(A3)+ODETUNI,(A4)+OCEUNI	LOAD.W	(A3)+ODETRAN,D2	LOAD.B	(A3)+ODETPOR,(A4)+OCEPOR	ADD.L	A3,#LDET	; A3 <-- ^dtecteur suivant	INC.W	D3	COMP.W	D3,#MAXDET-1	JUMP',HS END$NEXT$:	INC.W	D2	ADD.L	A4,#LCE		; A4 <-- ^cellule suivante	DECJ.W,NMO D4,LOOP$END$:	CLR.W	(A3)+ODETUNI	POPM.L	D2..D4,A3,A4	RET;----------\\; CELMAJCLA >;----------/; Cherche tous les claviers dessins.; in	-; out	-; mod	D7.WCELMAJCLA:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A3,#(A6)+OTACLA	CLR.W	D3	LOAD.L	A4,(A6)+OPCEL	LOAD.W	D4,(A6)+OCELNX	MUL.WU	D4,(A6)+OCELNY	; D4 <-- nb de cellules	DEC.W	D4		; D4 <-- -1  cause NMO	CLR.W	D2LOOP$:	COMP.B	(A4)+OCEICO,#ICORCLA	JUMP',NE NEXT$	TEST.W	(A4)+OCEUNI	JUMP',EQ NEXT$	LOAD.W	(A3)+OCLAUNI,(A4)+OCEUNI	LOAD.W	(A3)+OCLARAN,D2	LOAD.B	(A3)+OCLAPOR,(A4)+OCEPOR	ADD.L	A3,#LCLA	; A3 <-- ^clavier suivant	INC.W	D3	COMP.W	D3,#MAXCLA-1	JUMP',HS END$NEXT$:	INC.W	D2	ADD.L	A4,#LCE		; A4 <-- ^cellule suivante	DECJ.W,NMO D4,LOOP$END$:	CLR.W	(A3)+OCLAUNI	POPM.L	D2..D4,A3,A4	RET;---------\\; CELMAJGO >;---------/; Cherche tous les marche/arrt globaux dessins.; in	-; out	-; mod	D7.WCELMAJGO:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#(A6)+OTAGO	CLR.W	D3	LOAD.L	A4,(A6)+OPCEL	LOAD.W	D4,(A6)+OCELNX	MUL.WU	D4,(A6)+OCELNY	; D4 <-- nb de cellules	DEC.W	D4		; D4 <-- -1  cause NMOLOOP$:	COMP.B	(A4)+OCEICO,#ICORGO	JUMP',NE NEXT$	TEST.W	(A4)+OCEUNI	JUMP',EQ NEXT$	LOAD.W	(A3)+OGOUNI,(A4)+OCEUNI	ADD.L	A3,#LGO		; A3 <-- ^clavier suivant	INC.W	D3	COMP.W	D3,#MAXGO-1	JUMP',HS END$NEXT$:	ADD.L	A4,#LCE		; A4 <-- ^cellule suivante	DECJ.W,NMO D4,LOOP$END$:	CLR.W	(A3)+OGOUNI	POPM.L	D3,D4,A3,A4	RET;--------\\; CELGETP >;========/; Donne le pointeur  une cellule dans la matrice.; in	D1.W	rang (0..n); out	A4.L	^cellule (OCE*);	D7.W	erreur; mod	D7.W, A4.LCELGETP:	PUSHM.L	D1,D2	LOAD.W	D7,#1		; D7 <-- erreur	AND.L	D1,#H'FFFF	DIV.WU	D1,(A6)+OCELNX	; D1 <-- rang (x;y)	LOAD.L	D2,D1	SWAP.W	D2	COMP.W	D2,(A6)+OCELNX	JUMP',HS EXIT$	COMP.W	D1,(A6)+OCELNY	JUMP',HS EXIT$	MUL.WU	D1,(A6)+OCELNX	ADD.W	D2,D1	LOAD.L	A4,(A6)+OPCEL	MUL.WU	D2,#LCE	ADD.L	A4,D2	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;----------\\; CELCHGDIM >;==========/; Change le nombre de cellules horizontal/vertical.; in	D4.L	nouvelles dimensions (dy;dx); out	D7.W	erreur; mod	D7.WCELCHGDIM:	PUSHM.L	D0..D4,A3,A4	LOAD.L	A3,(A6)+OPCEL	; A3 <-- ^anciennes cellules	LOAD.L	D3,(A6)+OCELNY	; D3 <-- anciennes dimensions	CALL	CELNEW	JUMP,NE EXIT$	LOAD.L	A4,(A6)+OPCEL	; A4 <-- ^nouvelles cellules	PUSH.L	A3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,D3	COMP.W	D0,D4	JUMP',LS VERT$	LOAD.W	D0,D4VERT$:	DEC.W	D0	SWAP.W	D4	SWAP.W	D3VLOOP$:	PUSHM.L	A3,A4	LOAD.W	D1,D3	COMP.W	D1,D4	JUMP',LS LINE$	LOAD.W	D1,D4LINE$:	DEC.W	D1HLOOP$:	LOAD.W	D2,#LCE-1XFER$:	LOAD.B	(A4+),(A3+)	; nouvelle cellule <-- ancienne cellule	DECJ.W,NMO D2,XFER$	DECJ.W,NMO D1,HLOOP$	POPM.L	A3,A4	LOAD.W	D2,D3	MUL.WU	D2,#LCE	ADD.L	A3,D2		; A3 <-- ^ancienne ligne suivante	LOAD.W	D2,D4	MUL.WU	D2,#LCE	ADD.L	A4,D2		; A4 <-- ^nouvelle ligne suivante	DECJ.W,NMO D0,VLOOP$	POP.L	A4	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre les anciennes cellules	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CELNEW  >;========/; ; in	D4.L	dimensions (dy;dx); out	D7.W	erreur; mod	D7.WCELNEW:	PUSHM.L	D1,D3,D4,A4	LOAD.L	D3,D4	SWAP.W	D4	MUL.WU	D4,D3	MUL.WU	D4,#LCE	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- demande de la mmoire	JUMP',NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	(A6)+OPCEL,A4	LOAD.L	(A6)+OCELNY,D3	LOAD.W	D4,(A6)+OCELNX	MUL.WU	D4,(A6)+OCELNYINIT$:	CALL	CELKILL		; dtruit la cellule	ADD.L	A4,#LCE	DEC.L	D4	JUMP,NE INIT$EXIT$:	POPM.L	D1,D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CELKILL >;========/; Dtruit une cellule.; in	A4.L	^cellule; out	-; mod	D7.WCELKILL:	PUSHM.L	D1,A3,A4	LOAD.B	(A4)+OCEICO,#ICORVIDE	CLR.B	(A4)+OCEETA	CLR.W	(A4)+OCEUNI	CLR.B	(A4)+OCEPOR	CLR.B	(A4)+OCEPAR	LOAD.B	(A4)+OCEFAN,#2^BCEFMBB	TEST.L	(A4)+OCEPSC	; script existe ?	JUMP',EQ NAME$		; non => NAME$	LOAD.L	A3,A4	LOAD.L	A4,(A4)+OCEPSC	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le script	CLR.L	(A3)+OCEPSCNAME$:	TEST.L	(A4)+OCEPNM	; nom existe ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A3,A4	LOAD.L	A4,(A4)+OCEPNM	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le nom	CLR.L	(A3)+OCEPNMEXIT$:	POPM.L	D1,A3,A4	TEST.W	D7		; retour EQ/NE	RET	.END