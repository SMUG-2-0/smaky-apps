  	.TITLE	LGB_SLAVE.ASC;	--------------------------------------;		(C) 1989 - Daniel Roux;	--------------------------------------;	Source du programme LGB_MASTER;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 0.1	20.12.89	premier essai sur la base des travaux de GVR	.PROC	M6805			; Motorola 68705P3 et 68705R3 (2-4 Kbyte d'EPROM)	.BASE	10'10REV	=	0			; rvisionVER	=	1			; version; Assemblage conditionnel; -----------------------PROCHI	=	0			; processeur HITACHI HD68P05V07					; avec mulateur d'EPROM 2732 (4 Kbyte)PROCR3	=	0			; processeur MC68705R3 (4 Kbyte d'EPROM); Adresses fixes; --------------	.IF	PROCHIADRAM	=	16'0020			; dbut de la RAM de l'mulateur HITACHI HD68P05V07VECTINT	=	16'0FF8			; vecteurs interruptions et RESET mulateur HD68P05V07	.ELSEADRAM	=	16'0010			; dbut de la RAM processeurs: MC68705P3, R3	.IF	PROCR3VECTINT	=	16'0FF8			; vecteurs d'interruptions et de RESET du MC68705R3	.ELSEVECTINT	=	16'07F8			; vecteurs d'interruptions et de RESET du MC68705P3	.ENDIF	.ENDIF	.IF	PROCR3MAXCODE	=	16'0F38-2		; fin du code: protection et Mask Option Register MC68705R3	.ELSEMAXCODE	=	16'0784-2		; fin du code: protection et Mask Option Register MC68705P3	.ENDIF; Protocole; ---------;	4 bytes: <op> <id> <data_A> <data_B>OPIDENT	=	16'01			; identifie le processeurOPCHANGE=	16'02			; change l'identificationOPDIREC	=	16'03			; direction des ports A et BOPDATA	=	16'04			; data pour les ports A et B (in et/ou out)BOPTAKE	=	7			; information prise en compte; Dfinions; ---------RATE	=	9600			; baud-rate par dfautCR	=	16'0D			; code du caractre CRLGFIFO	=	20			; lg max du fifo; Touches du clavier; ------------------ENTER	=	16'98CLEAR	=	16'9FF1	=	16'81F2	=	16'82F3	=	16'83; Instructions; ------------iMOVEAAD =	16'C7			; pseudo-code: MOVE A,{R_AD_H+L}iMOVEADA =	16'D6			; pseudo-code: MOVE {OEXADH+L},AiJUMP	=	16'CC			; pseudo-code: JUMP {R_AD_H+L}iRET	=	16'81			; pseudo-code: RET; Instructions bidons; -------------------;	NOP				; [2];	TEST	X			; [4];	MOVE	A,8^PORTD		; [5];	TEST	{X}			; [6]; Variables et ports d'accs; --------------------------	.LOC	0PORTA:	.BLK.8	1			; accs au port APORTB:	.BLK.8	1			; accs au port BPORTC:	.BLK.8	1			; accs au port CPORTD:	.BLK.8	1			; accs au port DDDRA:	.BLK.8	1			; direction du port A, voir (*)DDRB:	.BLK.8	1			; direction du port B, voir (*)DDRC:	.BLK.8	1			; direction du port C, voir (*)DDRD:	.BLK.8	1			; direction du port D, voir (*)TDR:	.BLK.8	1			; data du timerTCR:	.BLK.8	1			; contrle du timer	.BLK.8	1PCR:	.BLK.8	1			; program control register; (*)	0 = input;	1 = output; Cblage de la transmission RS232; --------------------------------RDPORT	=	PORTC			; port de lecture pour transmission RS232WRPORT	=	PORTC			; port d'criture pour transmission RS232WRBIT	=	0			; bit d'criture pour transmission RS232; Positions mmoires en RAM; -------------------------	.LOC	ADRAM			; dbut de la RAMOEXINS:	.BLK.8	1			; pseudo-code pour l'excution d'une instructionOEXADH:	.BLK.8	1			; adresse de move highOEXADL:	.BLK.8	1			; adresse de move lowOEXRET:	.BLK.8	1			; pseudo-code pour l'excution du RETORST1:	.BLK.8	1			; position mmoire utilise pour la transmission RS232ORST2:	.BLK.8	1			; position mmoire utilise pour la transmission RS232ORST3:	.BLK.8	1			; position mmoire utilise pour la transmission RS232ORSD1:	.BLK.8	1			; dlai entre deux bitsORSD4:	.BLK.8	1			; dlai entre deux bits /4OIDENT:	.BLK.8	1			; identificateur du processeurOCONF:	.BLK.8	1			; configuration de la carteODATA1:	.BLK.8	1			; data 1ODATA2:	.BLK.8	1			; data 2ODATA3:	.BLK.8	1			; data 3ODATA4:	.BLK.8	1			; data 4ODIRA:	.BLK.8	1			; direction du port AODIRB:	.BLK.8	1			; direction du port BODIRBi:	.BLK.8	1			; direction du port B inverseOMEMB:	.BLK.8	1			; data captur sur le port BOKEY:	.BLK.8	1			; touche presseOHEAD:	.BLK.8	1			; ^tteOTAIL:	.BLK.8	1			; ^queueOFIFO:	.BLK.8	LGFIFO			; data du fifoLGRAM:	.LOC	0	.FILL.8	VECTINT+8,16'FF		; EPROM remplie de 1; Adresses restart user privilgies; ----------------------------------	.LOC	16'80_RCVCAR:JUMP	16^RCVCAR		; lecture d'un caractre depuis l'USART_SNDCAR:JUMP	16^SNDCAR		; envoi d'un caractre sur l'USART_SNDHEX:JUMP	16^SNDHEX		; envoi d'un byte en hexadcimal_SNDDEC:JUMP	16^SNDDEC		; envoi d'un byte en dcimal_SNDTXT:JUMP	16^SNDTXT		; envoi d'une chane ASCIZ; Dbut du code; -------------	.LOC	16'100START:	IOFF				; power-up start	RESET	SP	.IF	PROCHI	CALL	TEST			; fait clignotter les LEDs	.ENDIF	CALL	JEXISTE			; montre que le processeur tourne ...	MOVE	8^PORTC,A	MOVE	A,8^OCONF		; OCONF <-- configuration (port C)	CALL	RSINIT			; initialise les ports RS232	MOVE	#0,A	CALL	8^_SNDCAR	MOVE	#0,A	MOVE	A,8^OIDENT		; OIDENT <-- zro	MOVE	A,8^OKEY		; OKEY <-- zro	MOVE	#16'FF,A	MOVE	A,8^OMEMB		; OMEMB <-- un	CALL	INIFIFO			; vide le fifo; Attente active de rception d'un caractre.; Pendant l'attente, on peut faire n'importe quoi, mais il ne faut pas oublier; d'excuter un "jump,ih RCVCARi" de temps en temps !LOOP:	TESTJUMP,BS 8^OCONF:#3,CLA$	; carte avec clavier ?WAIT$:					jump,ih	RCVCARi$	MOVE	8^PORTB,A	AND	8^OMEMB,A	MOVE	A,8^OMEMB	JUMP	WAIT$CLA$:	MOVE	8^OKEY,A	JUMP,NE CLAR$CLAP$:					jump,ih	RCVCARi$	CALL	BALCLA			; A <-- touche presse	COMP	#0,A	JUMP,EQ CLAP$					jump,ih	RCVCARi$	CALL	PUTFIFO	MOVE	A,8^OKEYCLAR$:					jump,ih	RCVCARi$	CALL	BALCLA			; A <-- touche presse	COMP	#0,A	JUMP,NE CLAR$					jump,ih	RCVCARi$	MOVE	#0,A	MOVE	A,8^OKEY	JUMP	CLAP$;;?	OR	8^OKEY,A		; A <-- somme touches presses;;?	MOVE	A,8^OKEY		; OKEY <-- touche presse;;?	JUMP	CLA$RCVCARi$:	JUMP	RCVCARi; On arrive ici aprs RCVCARi, c'est--dire aprs la rception du premier; caractre.FIRST:	MOVE	A,8^ODATA1		; ODATA1 <-- premier byte	JUMP,NE SECOND$	CALL	8^_SNDCAR		; renvoie le byte zro !	JUMP	LOOPSECOND$:	CALL	8^_RCVCAR		; A <-- attend un caractre	MOVE	A,8^ODATA2		; ODATA2 <-- deuxime byte	CALL	8^_RCVCAR		; A <-- attend un caractre	MOVE	A,8^ODATA3		; ODATA3 <-- troisime byte	CALL	8^_RCVCAR		; A <-- attend un caractre	MOVE	A,8^ODATA4		; ODATA4 <-- quatrime byte	MOVE	8^ODATA1,A		; A <-- premier byte	COMP	#OPDATA,A	JUMP,EQ	DATA$	COMP	#OPIDENT,A	JUMP,EQ	IDENT$	COMP	#OPCHANGE,A	JUMP,EQ	CHANGE$	COMP	#OPDIREC,A	JUMP,EQ	DIREC$	JUMP	SEND$; Commande d'identification. On transmet le numro +1  la carte suivante.IDENT$:	MOVE	8^ODATA2,A		; A <-- identificateur	INC	A	MOVE	A,8^ODATA2		; ODATA2 <-- identificateur suivant	MOVE	A,8^OIDENT		; OIDENT <-- identificateur	JUMP	SEND$; Commande de changement d'identification.CHANGE$:	MOVE	8^ODATA2,A		; A <-- nouvel identificateur	MOVE	A,8^OIDENT		; OIDENT <-- identificateur	JUMP	TAKE$; Commande d'initialisation de la direction des ports A et B.DIREC$:	MOVE	8^ODATA2,A		; A <-- identificateur	COMP	8^OIDENT,A		; est-ce pour ce processeur ?	JUMP,NE	SEND$			; non => SEND$	TESTJUMP,BS 8^OCONF:#3,DIRK$	; carte avec clavier ?	MOVE	8^ODATA3,A		; A <-- data	MOVE	A,8^DDRA		; crit la direction du port A	MOVE	A,8^ODIRA	JUMP	R8^DIRB$DIRK$:	MOVE	#16'0F,A		; A <-- bits 0..3 en sortie	MOVE	A,8^DDRA		; crit la direction du port A	MOVE	A,8^ODIRA	MOVE	A,8^ODATA3;	JUMP	R8^DIRB$DIRB$:	MOVE	8^ODATA4,A		; A <-- data	MOVE	A,8^DDRB		; crit la direction du port B	MOVE	A,8^ODIRB	NOT	A	MOVE	A,8^ODIRBi	JUMP	TAKE$; Commande de lecture et d'criture dans les ports A et B.DATA$:	MOVE	8^ODATA2,A		; A <-- identificateur	COMP	8^OIDENT,A		; est-ce pour ce processeur ?	JUMP,NE	SEND$			; non => SEND$	TESTJUMP,BS 8^OCONF:#3,DATAK$	; carte avec clavier ?	MOVE	8^ODATA3,A		; A <-- data	MOVE	A,8^PORTA		; port A <-- data	MOVE	8^PORTA,A		; A <-- port A	MOVE	A,8^ODATA3		; ODATA3 <-- data port A	JUMP	R8^DATAB$DATAK$:	CALL	GETFIFO			; A <-- zro/touche presse	MOVE	A,8^ODATA3		; ODATA3 <-- touche presse;	JUMP	R8^DATAB$DATAB$:	MOVE	8^ODATA4,A		; A <-- data	MOVE	A,8^PORTB		; port B <-- data	OR	8^ODIRBi,A	MOVE	A,8^ODATA4	MOVE	8^OMEMB,A	OR	8^ODIRB,A	AND	8^ODATA4,A	MOVE	A,8^ODATA4		; ODATA4 <-- data port B	MOVE	#16'FF,A	MOVE	A,8^OMEMB		; OMEMB <-- un;	JUMP	TAKE$; Met le bit indiquant que la commande a t traite correctement.TAKE$:	MOVE	8^ODATA1,A	OR	#2**BOPTAKE,A		; ODATA1 <-- met le bit BOPTAKE	MOVE	A,8^ODATA1; Renvoie les quatre bytes  la carte suivante.SEND$:	MOVE	8^ODATA1,A	CALL	8^_SNDCAR		; renvoie le premier byte	MOVE	8^ODATA2,A	CALL	8^_SNDCAR		; renvoie le deuxime byte	MOVE	8^ODATA3,A	CALL	8^_SNDCAR		; renvoie le troisime byte	MOVE	8^ODATA4,A	CALL	8^_SNDCAR		; renvoie le quatrime byte	JUMP	LOOP;--------\\; JEXISTE >;========/; Montre que le processeur tourne.; in	-; out	-; mod	A,XJEXISTE:	MOVE	#16'FF,A	MOVE	A,8^DDRB	MOVE	#2,XLOOP$:	MOVE	#16'FF,A	MOVE	A,8^PORTB	CALL	WAITBIG	MOVE	#16'00,A	MOVE	A,8^PORTB	CALL	WAITBIG	DEC	X	JUMP,NE LOOP$	MOVE	#0,A	MOVE	A,8^DDRB	RET;--------\\; WAITBIG >;--------/; Attend assez longtemps.; in	-; out	-; mod	-WAITBIG:	MOVE	A,8^ORST1	MOVE	X,8^ORST2	MOVE	#30,XDEL1$:	MOVE	#0,ADEL2$:	DEC	A	JUMP,NE DEL2$	DEC	X	JUMP,NE DEL1$	MOVE	8^ORST2,X	MOVE	8^ORST1,A	RET	.IF	PROCHI;--------\\; TEST    >;========/; Fait clignotter les LEDs du port D (HITACHI).; in	-; out	-; mod	A,XTEST:	MOVE	#16'F0,A	; Leds actives en sortie (mulateur).	MOVE	A,8^DDRC	CLR	8^PORTCLOOP$:	MOVE	#16'10,XL$:	DEC	A	JUMP,NE	L$	DEC	X	JUMP,NE	L$	MOVE	#16'10,A	ADD	8^PORTC,A	MOVE	A,8^PORTC	AND	#16'F0,A	JUMP,NE	LOOP$	RET	.ENDIF; Routines d'mission et de rception sur ligne RS232; ---------------------------------------------------;--------\\; RSINIT  >;========/; Initialisation des ports RS232.; in	-; out	-; mod	ARSINIT:	MOVE	#2**WRBIT,A		; A <-- WRBIT en sortie	MOVE	A,8^DDRC		; crit la direction du port C	MOVE	#(1000000/RATE-52+4)/13,A	MOVE	A,8^ORSD1		; dlai entre deux bits	MOVE	#(1000000/RATE-52+4)/13/4,A	MOVE	A,8^ORSD4		; dlai entre deux bits /4	RET;--------\\; GETBAUD >;========/; Cherche le baud-rate de la ligne srie, avec un CR par exemple.; in	-; out	ORSD1	dlai entre deux bits;	ORSD4	dlai entre deux bits /4; mod	A,XGETBAUD:	CLR	XWAIT$:	TEST	{X}			; [6]  (bidon)	JUMP,IH WAIT$;	TESTJUMP,BS 8^RDPORT:#RDBIT,WAIT$	MOVE	8^RDPORT,ACLR$:	TEST	{X}			; [6]  (bidon)	JUMP,IL CLR$;	TESTJUMP,BC 8^RDPORT:#RDBIT,CLR$SET$:	INC	X			; [4] \	COMP	16^RDPORT,A		; [5]  > = 13 us	JUMP,NE	SET$			; [4] /	MOVE	X,A	SUB	#4,A	MOVE	A,8^ORSD1		; ORSD1 <-- dlai	SR	A	SR	A	MOVE	A,8^ORSD4		; ORSD4 <-- dlai /4	MOVE	#8,A			; attend la fin du caractreEND$:	CALL	WAIT	DEC	A	JUMP,NE	END$;	JUMP	SNDBAUD;--------\\; SNDBAUD >;--------/; Envoie le baud-rate trouv.; in	ORSD4	dlai entre deux bits /4; out	-; mod	A,XSNDBAUD:	CLR	A	CLR	XT$:	INC	X	INC	A	ADD	8^ORSD4,A	COMP	#192,A	JUMP,LO	T$	MOVE	X,A	CALL	8^_SNDDEC	MOVE	#T_BDS/16'100,A	MOVE	A,8^OEXADH	MOVE	#T_BDS.AND.16'0FF,A	MOVE	A,8^OEXADL	JUMP	8^_SNDTXTT_BDS:	.ASCIZ	"00 bauds<CR>";--------\\; SNDTXT  >;========/; Envoie un texte termin par zro.; in	OEXADH	^texte (high);	OEXADL	^texte (low); out	-; mod	A,XSNDTXT:	CLR	X			; envoi d'un texte	MOVE	#iMOVEADA,A		; pseudo-code: MOVE {OEXADH+L},A	MOVE	A,8^OEXINS	MOVE	#iRET,A			; pseudo-code: RET	MOVE	A,8^OEXRETTXT$:	CALL	8^OEXINS		; MOVE	{X}+16^TEXT,A	JUMP,EQ	FTXT$	CALL	SNDCAR			; envoi d'un caractre	INC	X	JUMP	R8^TXT$FTXT$:	RET;--------\\; SNDHEX  >;========/; Envoi une valeur haxadcimale.; in	A	valeur hexadcimale; out	-; mod	ASNDHEX:	MOVE	A,8^ORST1	SR	A	SR	A	SR	A	SR	A	CALL	SNDDIGIT		; envoi 4 bits high	MOVE	8^ORST1,A	AND	#16'0F,A	JUMP	SNDDIGIT		; envoi 4 bits low;--------\\; SNDDEC  >;========/; Envoi d'un byte en dcimal avec conversion BIN-BCD.; in	A	valeur binaire (0..99); out	-; mod	ASNDDEC:	MOVE	X,8^ORST1		; ORST1 <-- X initial	MOVE	A,X	MOVE	{X}+16^BINBCD$,A	; conversion BIN --> BCD	MOVE	8^ORST1,X		; X <-- reprend valeur initiale	MOVE	A,8^ORST1		; envoi d'un byte en hexa	SR	A	SR	A	SR	A	SR	A	AND	#16'0F,A	JUMP,EQ	S$	CALL	R8^SNDDIGITS$:	MOVE	8^ORST1,A	AND	#16'0F,A	JUMP	R8^SNDDIGITBINBCD$:				; table de conversion BIN --> BCD	.8	16'00,16'01,16'02,16'03,16'04,16'05,16'06,16'07,16'08,16'09	.8	16'10,16'11,16'12,16'13,16'14,16'15,16'16,16'17,16'18,16'19	.8	16'20,16'21,16'22,16'23,16'24,16'25,16'26,16'27,16'28,16'29	.8	16'30,16'31,16'32,16'33,16'34,16'35,16'36,16'37,16'38,16'39	.8	16'40,16'41,16'42,16'43,16'44,16'45,16'46,16'47,16'48,16'49	.8	16'50,16'51,16'52,16'53,16'54,16'55,16'56,16'57,16'58,16'59	.8	16'60,16'61,16'62,16'63,16'64,16'65,16'66,16'67,16'68,16'69	.8	16'70,16'71,16'72,16'73,16'74,16'75,16'76,16'77,16'78,16'79	.8	16'80,16'81,16'82,16'83,16'84,16'85,16'86,16'87,16'88,16'89	.8	16'90,16'91,16'92,16'93,16'94,16'95,16'96,16'97,16'98,16'99;---------\\; SNDDIGIT >;---------/; Envoi d'un digit hexadcimal.; in	A	valeur (0..15); out	-; mod	ASNDDIGIT:	SUB	#9,A	JUMP,LS	HS$	ADD	#"A"-"0"-9-1,AHS$:	ADD	#"0"+9,A;	JUMP	R8^SNDCAR;--------\\; SNDCAR  >;========/; Envoi d'un caractre sur la ligne srie.; in	A	caractre  envoyer; out	-; mod	ASNDCAR:	MOVE	X,8^ORST2		; ORST2 <-- X initial	XOR	#16'FF,A		; A <-- complment  un	MOVE	#8+2,X			; 8 bits + 2 stop-bits	MOVE	X,8^ORST3		; ORST3 <-- compteur	CLR	8^WRPORT:#WRBIT		; repos de la ligne	CALL	R8^WAIT	SET	8^WRPORT:#WRBIT		; start bitLOOP$:	MOVE	16^ORST1,X		; [5]  (bidon)	CALL	R8^WAIT			; [8]	SR	A			; [4]	JUMP,CC	CLR$			; [4]SET$:	SET	8^WRPORT:#WRBIT		; [7]	JUMP	R8^SUITE$		; [4]CLR$:	CLR	8^WRPORT:#WRBIT		; [7]	JUMP	R8^SUITE$		; [4]SUITE$:	DEC	8^ORST3			; [6]	JUMP,NE	LOOP$			; [4]  total=42+6+4=52	MOVE	8^ORST2,X		; X <-- reprend valeur initiale	RET;--------\\; RCVCAR  >;========/; Rception d'un caractre de la ligne srie.; in	-; out	A	caractre reu; mod	ARCVCAR:	MOVE	X,8^ORST2		; ORST2 <-- sauvetage de X	MOVE	#8,X			; X <-- 8 bits	MOVE	X,8^ORST3HIGH$:	TEST	{X}			; [6]  (bidon)	JUMP,IH HIGH$;	TESTJUMP,BS 8^RDPORT:#RDBIT,HIGH$LOW$:	TEST	{X}			; [6]  (bidon)	JUMP,IL LOW$;	TESTJUMP,BC 8^RDPORT:#RDBIT,LOW$	CALL	R8^WAIT4LOOP$:	MOVE	8^ORST1,X		; [4]  (bidon)	CALL	R8^WAIT			; [8]	TEST	{X}			; [6]  (bidon)	JUMP,IL CLR$;	TESTJUMP,BC 8^RDPORT:#RDBIT,CLR$ ; [10]SET$:	SETC				; [2]	JUMP	R8^SUITE$		; [4]CLR$:	CLRC				; [2]	JUMP	R8^SUITE$		; [4]SUITE$:	RRC	A			; [4]  A <-- un bit du caractre reu	DEC	8^ORST3			; [6]	JUMP,NE	LOOP$			; [4]  total=42+6+4=52	MOVE	8^ORST2,X		; X <-- remet valeur initiale	XOR	#16'FF,A		; A <-- complment  un	RET;--------\\; RCVCARi >;========/; Rception d'un caractre de la ligne srie.; On arrive ici aprs un "jump,ih RCVCARi", et on saute aprs en "FIRST" !; in	-; out	A	caractre reu; mod	ARCVCARi:	MOVE	#8,X			; X <-- 8 bits	MOVE	X,8^ORST3	CALL	R8^WAIT4LOOP$:	MOVE	8^ORST1,X		; [4]  (bidon)	CALL	R8^WAIT			; [8]	TEST	{X}			; [6]  (bidon)	JUMP,IL CLR$;	TESTJUMP,BC 8^RDPORT:#RDBIT,CLR$ ; [10]SET$:	SETC				; [2]	JUMP	R8^SUITE$		; [4]CLR$:	CLRC				; [2]	JUMP	R8^SUITE$		; [4]SUITE$:	RRC	A			; [4]	DEC	8^ORST3			; [6]	JUMP,NE	LOOP$			; [4]  total=42+6+4=52	XOR	#16'FF,A		; A <-- complment  un	RESET	SP			; remet le stack en 16'7F !	JUMP	FIRST;--------\\; WAIT    >;--------/; Attente entre deux bits.; in	ORSD1	dlai entre deux bits; out	-; mod	XWAIT:	MOVE	8^ORSD1,X		; X <-- dlai entre deux bits;	MOVE	#(1000000/RATE-52+4)/13,X;	NOPLOOP$:	MOVE	A,8^PORTD		; [5] \  (bidon)	DEC	X			; [4]  > = 13 us	JUMP,NE	LOOP$			; [4] /	RET;--------\\; WAIT4   >;--------/; Attente entre deux bits /4.; in	ORSD1	dlai entre deux bits /4; out	-; mod	XWAIT4:	MOVE	8^ORSD4,X		; X <-- dlai entre deux bits /4;	MOVE	#(1000000/RATE-52+4)/13/4,X;	NOPLOOP$:	MOVE	A,8^PORTD		; [5] \  (bidon)	DEC	X			; [4]  > = 13 us	JUMP,NE	LOOP$			; [4] /	RET; Routines de lecture du clavier balay; -------------------------------------;--------\\; BALCLA  >;--------/; Balaye le clavier pour trouver la premire touche presse.; in	-; out	A	touche presse; mod	A,XBALCLA:					jump,ih	RCVCARi	MOVE	#16'FE,A		; A <-- premire colonne	MOVE	#0,XLOOP$:	MOVE	A,8^PORTA		; slectionne une colonne					jump,ih	RCVCARi	TESTJUMP,BC 8^PORTA:#7,PRESS$	; bit dans ligne 4 ?	INC	X					jump,ih	RCVCARi	TESTJUMP,BC 8^PORTA:#6,PRESS$	; bit dans ligne 3 ?	INC	X					jump,ih	RCVCARi	TESTJUMP,BC 8^PORTA:#5,PRESS$	; bit dans ligne 2 ?	INC	X					jump,ih	RCVCARi	TESTJUMP,BC 8^PORTA:#4,PRESS$	; bit dans ligne 1 ?	INC	X					jump,ih	RCVCARi	SETC	RLC	A			; A <-- colonne suivante	COMP	#16'EF,A	JUMP,NE LOOP$					jump,ih	RCVCARi	MOVE	#0,A			; A <-- aucune touche presse	JUMP	R8^EXIT$PRESS$:	MOVE	{X}+TAKEY$,A		; A <-- touche presseEXIT$:					jump,ih	RCVCARi	RETTAKEY$:	.8	0,"1","4","7"		; colonne 1	.8	"0","2","5","8"		; colonne 2	.8	ENTER,F1,F2,F3		; colonne 3	.8	CLEAR,"3","6","9"	; colonne 4;--------\\; INIFIFO >;========/; Vide le fifo.; in	-; out	-; mod	AINIFIFO:	MOVE	#OFIFO,A	MOVE	A,8^OHEAD	MOVE	A,8^OTAIL	RET;--------\\; PUTFIFO >;========/; Met un byte dans le fifo.; in	A	byte  mettre dans le fifo; out	-; mod	XPUTFIFO:					jump,ih	RCVCARi$	MOVE	8^OHEAD,X		; X <-- ^tte	MOVE	A,{X}			; fifo <-- byte  crire	INC	X			; X <-- avance la tte					jump,ih	RCVCARi$	COMP	#OFIFO+LGFIFO,X	JUMP,NE	HEAD$	MOVE	#OFIFO,XHEAD$:					jump,ih	RCVCARi$	COMP	8^OTAIL,X		; HEAD = TAIL (fifo plein) ?	JUMP,EQ	EXIT$			; oui => EXIT$	MOVE	X,8^OHEAD		; OHEAD <-- mj. la tteEXIT$:	RETRCVCARi$:	JUMP	RCVCARi;--------\\; GETFIFO >;========/; Prend un byte dans le fifo.; in	-; out	A	byte lu dans le fifo;	EQ	si fifo vide; mod	A,XGETFIFO:	MOVE	#0,A			; A <-- zro	MOVE	8^OTAIL,X		; X <-- ^queue	COMP	8^OHEAD,X		; TAIL = HEAD (fifo vide) ?	JUMP,EQ EXIT$			; oui => EXIT$	MOVE	{X},A			; A <-- byte lu	INC	X	COMP	#OFIFO+LGFIFO,X	JUMP,NE	TAIL$	MOVE	#OFIFO,XTAIL$:	MOVE	X,8^OTAIL		; OTAIL <-- mj. la queueEXIT$:	RETENDCODE:	.IF	MAXCODE.LO.ENDCODECODE TROP LONG !!!	.ENDIF	.LOC	MAXCODE	.8	16'20,16'FE		; version protge					; registre d'options masquables	.8	2'01101000		; 2^7=0 --> oscillateur  quartz					; 2^6=1 --> mulation version masque					; 2^5=1 --> clock du timer externe					; 2^3=1 --> version soft protge					; 2^2-2^0: --> pas de pr-comptage du timer	.LOC	VECTINT	.16	-1			; interruption du timer	.16	-1			; interruption externe	.16	-1			; interruption software	.16	START			; reset	.START	START	.END