	.SBTTL	RHBAUTO.ASI;--------\\; SNDDET  >;========/; Action selon un dtecteur reu.; in	D4.W	unit dtecteur; out	D7.W	erreur; mod	D7.WSNDDET:	TEST.B	(A6)+OAUTO	JUMP',F	EXIT$	COMP.W	D4,#10	JUMP,EQ SNDDET10	COMP.W	D4,#11	JUMP,EQ SNDDET11	COMP.W	D4,#12	JUMP,EQ SNDDET12	COMP.W	D4,#13	JUMP,EQ SNDDET13	COMP.W	D4,#14	JUMP,EQ SNDDET14	COMP.W	D4,#15	JUMP,EQ SNDDET15	COMP.W	D4,#16	JUMP,EQ SNDDET16	COMP.W	D4,#17	JUMP,EQ SNDDET17	COMP.W	D4,#18	JUMP,EQ SNDDET18	COMP.W	D4,#19	JUMP,EQ SNDDET19	COMP.W	D4,#20	JUMP,EQ SNDDET20	COMP.W	D4,#21	JUMP,EQ SNDDET21	COMP.W	D4,#22	JUMP,EQ SNDDET22EXIT$:	LOAD.W	D7,#ERMEVENT	; D7 <-- rien trouv	RET;---------\\; SNDDET10 >;---------/; Entre dans la gare 1.; in	-; out	-; mod	D7.WSNDDET10:	PUSHM.L	D3,D4	LOAD.W	D3,#502	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP,NE EXIT$		; non => EXIT$	TEST.W	(A6)+OG1TVA	JUMP',NE VAAB$	TEST.W	(A6)+OG1TVB	JUMP',NE VB$RIEN$:				; aucun train	JUMP'	END$VB$:				; train sur la voie B	LOAD.W	D3,#50	LOAD.W	D4,#1	CALL	PUTUNIT		; met l'aiguillage vers la voie A	JUMP'	END$VAAB$:	TEST.W	(A6)+OG1TVB	JUMP',NE VAB$VA$:				; train sur la voie A	LOAD.W	D3,#50	CLR.W	D4	CALL	PUTUNIT		; met l'aiguillage vers la voie B	JUMP'	END$VAB$:				; trains sur les voies A et B	TEST.W	(A6)+OG3TVA	JUMP',EQ VAB1$	LOAD.W	D3,#46		; D3 <-- aiguillage 46 (sortie gare 2)	CALL	GETUNIT		; D4 <-- tat de l'aiguillage	TEST.W	D4	JUMP',NE VABS$VAB1$:	LOAD.W	D3,#50	CALL	GETUNIT		; D4 <-- position de l'aiguillage	LOAD.W	D3,#140		; D3 <-- voie A	TEST.W	D4	JUMP',NE VAB2$	LOAD.W	D3,#141		; D3 <-- voie BVAB2$:	CLR.W	D4	CALL	PUTUNIT		; fait partir le train en voie A ou B	JUMP'	END$VABS$:	LOAD.W	D3,#503	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le circuit extrieur !;	JUMP'	END$END$:	LOAD.W	D3,#50	CALL	GETUNIT		; D4 <-- position de l'aiguillage	TEST.W	D4	JUMP',EQ ENDB$	INC.W	(A6)+OG1TVA	LOAD.W	D3,#1000	CALL	IFETAT	LOAD.W	D3,#54	LOAD.W	D4,#1	CALL	PUTUNIT		; met l'aiguillage vers la voie A	JUMP'	EXIT$ENDB$:	INC.W	(A6)+OG1TVB	LOAD.W	D3,#1001	CALL	IFETAT	LOAD.W	D3,#54	CLR.W	D4	CALL	PUTUNIT		; met l'aiguillage vers la voie B;	JUMP'	EXIT$EXIT$:	POPM.L	D3,D4	RET;---------\\; SNDDET11 >;---------/; Sortie de la gare 1.; in	-; out	-; mod	D7.WSNDDET11:	PUSHM.L	D3,D4	LOAD.W	D3,#502	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.W	D3,#140		; D3 <-- voie A	CALL	GETUNIT		; D4 <-- tat de la voie A	TEST.W	D4	JUMP',NE VA$	TEST.W	(A6)+OG1TVA	JUMP',EQ VA$	DEC.W	(A6)+OG1TVA	JUMP',EQ VA$	LOAD.W	(A6)+OG1TVA,#1;	LOAD.W	D3,#140		; D3 <-- voie A	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le train en voie AVA$:	LOAD.W	D3,#1000	CALL	IFETAT	LOAD.W	D3,#141		; D3 <-- voie B	CALL	GETUNIT		; D4 <-- tat de la voie B	TEST.W	D4	JUMP',NE VB$	TEST.W	(A6)+OG1TVB	JUMP',EQ VB$	DEC.W	(A6)+OG1TVB	JUMP',EQ VB$	LOAD.W	(A6)+OG1TVB,#1;	LOAD.W	D3,#141		; D3 <-- voie B	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le train en voie BVB$:	LOAD.W	D3,#1001	CALL	IFETAT	INC.W	(A6)+OG3TVA	LOAD.W	D3,#1020	CALL	IFETAT	COMP.W	(A6)+OG3TVA,#2	JUMP',LO EXIT$	LOAD.W	D3,#46		; D3 <-- aiguillage 46 (sortie gare 2)	CALL	GETUNIT		; D4 <-- tat de l'aiguillage	TEST.W	D4	JUMP',EQ EXIT$	LOAD.W	D3,#503	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le circuit extrieur !EXIT$:	POPM.L	D3,D4	RET;---------\\; SNDDET12 >;---------/; Entre dans la gare 2.; in	-; out	-; mod	D7.WSNDDET12:	PUSHM.L	D3,D4	LOAD.W	D3,#502	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP,NE EXIT$		; non => EXIT$	TEST.W	(A6)+OG2TVA	JUMP',NE VAAB$	TEST.W	(A6)+OG2TVB	JUMP',NE VB$RIEN$:				; aucun train	JUMP'	END$VB$:				; train sur la voie B	LOAD.W	D3,#22	LOAD.W	D4,#1	CALL	PUTUNIT		; met l'aiguillage vers la voie A	JUMP'	END$VAAB$:	TEST.W	(A6)+OG2TVB	JUMP',NE VAB$VA$:				; train sur la voie A	LOAD.W	D3,#22	CALL	GETUNIT		; D4 <-- position de l'aiguillage	TEST.W	D4	JUMP',EQ END$	LOAD.W	D3,#134		; D3 <-- voie A	CLR.W	D4	CALL	PUTUNIT		; fait partir le train en voie A	JUMP'	VS$VAB$:				; trains sur les voies A et B	LOAD.W	D3,#22	CALL	GETUNIT		; D4 <-- position de l'aiguillage	LOAD.W	D3,#134		; D3 <-- voie A	TEST.W	D4	JUMP',NE VAB2$	LOAD.W	D3,#135		; D3 <-- voie BVAB2$:	CLR.W	D4	CALL	PUTUNIT		; fait partir le train en voie A ou B;	JUMP'	VS$VS$:	TEST.W	(A6)+OG3TVA	JUMP',EQ END$	LOAD.W	D3,#46	CLR.W	D4	CALL	PUTUNIT		; met l'aiguilage 46 tout droitEND$:	LOAD.W	D3,#22	CALL	GETUNIT		; D4 <-- position de l'aiguillage	TEST.W	D4	JUMP',EQ ENDB$	INC.W	(A6)+OG2TVA	LOAD.W	D3,#1010	CALL	IFETAT	JUMP'	EXIT$ENDB$:	INC.W	(A6)+OG2TVB	LOAD.W	D3,#1011	CALL	IFETAT;	JUMP'	EXIT$EXIT$:	POPM.L	D3,D4	RET;---------\\; SNDDET13 >;---------/; Sortie de la gare 2.; in	-; out	-; mod	D7.WSNDDET13:	PUSHM.L	D3,D4	LOAD.W	D3,#502	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.W	D3,#134		; D3 <-- voie A	CALL	GETUNIT		; D4 <-- tat de la voie A	TEST.W	D4	JUMP',NE VA$	TEST.W	(A6)+OG2TVA	JUMP',EQ VA$	DEC.W	(A6)+OG2TVA	JUMP',EQ VA$	LOAD.W	(A6)+OG2TVA,#1;	LOAD.W	D3,#134		; D3 <-- voie A	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le train en voie AVA$:	LOAD.W	D3,#1010	CALL	IFETAT	LOAD.W	D3,#135		; D3 <-- voie B	CALL	GETUNIT		; D4 <-- tat de la voie B	TEST.W	D4	JUMP',NE VB$	TEST.W	(A6)+OG2TVB	JUMP',EQ VB$	DEC.W	(A6)+OG2TVB	JUMP',EQ VB$	LOAD.W	(A6)+OG2TVB,#1;	LOAD.W	D3,#135		; D3 <-- voie B	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le train en voie BVB$:	LOAD.W	D3,#1011	CALL	IFETAT	LOAD.W	D3,#46		; D3 <-- aiguillage 46 (sortie gare 2)	CALL	GETUNIT		; D4 <-- tat de l'aiguillage	TEST.W	D4	JUMP',EQ VC$	INC.W	(A6)+OG3TVA	LOAD.W	D3,#1020	CALL	IFETAT	COMP.W	(A6)+OG3TVA,#2	JUMP',LO EXIT$	LOAD.W	D3,#503	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le circuit extrieur !	JUMP'	EXIT$VC$:	INC.W	(A6)+OG1TVC	LOAD.W	D3,#1004	CALL	IFETAT	COMP.W	(A6)+OG1TVC,#2	JUMP',LO EXIT$	LOAD.W	D3,#150	CLR.W	D4	CALL	PUTUNIT		; fait partir le train;	JUMP'	EXIT$EXIT$:	POPM.L	D3,D4	RET;---------\\; SNDDET14 >;---------/; Sortie de la gare 3.; in	-; out	-; mod	D7.WSNDDET14:	PUSHM.L	D3,D4	LOAD.W	D3,#502	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP',NE EXIT$		; non => EXIT$	INC.W	(A6)+OG3TVB	LOAD.W	D3,#1021	CALL	IFETAT	TEST.W	(A6)+OG3TVA	JUMP',EQ EXIT$	DEC.W	(A6)+OG3TVA	LOAD.W	D3,#1020	CALL	IFETATEXIT$:	POPM.L	D3,D4	RET;---------\\; SNDDET15 >;---------/; Entre dans la gare 4 par la gauche.; in	-; out	-; mod	D7.WSNDDET15:	PUSHM.L	D3,D4	LOAD.W	D3,#502	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP,NE EXIT$		; non => EXIT$	TEST.W	(A6)+OG1TVC	JUMP',EQ VC$	DEC.W	(A6)+OG1TVC	LOAD.W	D3,#1004	CALL	IFETAT	TEST.W	(A6)+OG1TVC	JUMP',EQ VC$	LOAD.W	D3,#150	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe partir le trainVC$:	INC.W	(A6)+OG4TVA	LOAD.W	D3,#1022	CALL	IFETAT	TEST.W	(A6)+OG4TVB	JUMP',EQ VL2$	LOAD.W	D3,#100	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le train	JUMP'	EXIT$VL2$:	COMP.W	(A6)+OG4TVA,#2	JUMP',LO EXIT$	LOAD.W	D3,#100	CLR.W	D4	CALL	PUTUNIT		; fait partir le trainEXIT$:	POPM.L	D3,D4	RET;---------\\; SNDDET16 >;---------/; Entre dans la gare 4 par la droite.; in	-; out	-; mod	D7.WSNDDET16:	PUSHM.L	D3,D4	LOAD.W	D3,#502	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.W	D3,#10	CALL	GETUNIT	TEST.W	D4		; aiguillage tourn ?	JUMP',NE TURN$		; oui => TURN$	LOAD.W	D3,#100	CALL	GETUNIT	TEST.W	D4		; secteur 100 stopp ?	JUMP',NE VR2$		; oui => VR2$	TEST.W	(A6)+OG4TVA	JUMP',EQ VR2$	LOAD.W	D3,#10	LOAD.W	D4,#1	CALL	PUTUNIT		; tourne l'aiguillage	JUMP'	EXIT$VR2$:	INC.W	(A6)+OG4TVB	LOAD.W	D3,#1023	CALL	IFETAT	JUMP'	EXIT$TURN$:	LOAD.W	D3,#16	CALL	GETUNIT	TEST.W	D4		; aiguillage tourn ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.W	D3,#124	CALL	GETUNIT	TEST.W	D4		; train stopp ?	JUMP',EQ EXIT$		; non => EXIT$	TEST.W	(A6)+OG5TVD	JUMP',EQ EXIT$	LOAD.W	D3,#16	LOAD.W	D4,#1	CALL	PUTUNIT		; tourne l'aiguillageEXIT$:	POPM.L	D3,D4	RET;---------\\; SNDDET17 >;---------/; Sortie de la gare 4.; in	-; out	-; mod	D7.WSNDDET17:	PUSHM.L	D3,D4	LOAD.W	D3,#502	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP',NE EXIT$		; non => EXIT$	TEST.W	(A6)+OG4TVB	JUMP',EQ VA$	DEC.W	(A6)+OG4TVB	LOAD.W	D3,#1023	CALL	IFETAT	JUMP'	EXIT$VA$:	TEST.W	(A6)+OG4TVA	JUMP',EQ EXIT$	DEC.W	(A6)+OG4TVA	LOAD.W	D3,#1022	CALL	IFETAT	TEST.W	(A6)+OG4TVA	JUMP',EQ EXIT$	LOAD.W	D3,#100	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le train;	JUMP'	EXIT$EXIT$:	POPM.L	D3,D4	RET;---------\\; SNDDET18 >;---------/; Entre dans la gare 5.; in	-; out	-; mod	D7.WSNDDET18:	PUSHM.L	D3,D4	LOAD.W	D3,#500	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.W	D3,#28	CALL	GETUNIT	TEST.W	D4		; aiguillage tourn ?	JUMP,NE EXIT$		; oui => EXIT$	TEST.W	(A6)+OG5TVA	; y a-t-il dj un train ?	JUMP',NE TURN$		; oui => TURN$	LOAD.W	D3,#123	CALL	GETUNIT		; stoppe ?	TEST.W	D4	JUMP',NE END$		; oui => END$	LOAD.W	D3,#122	CALL	GETUNIT		; stoppe ?	TEST.W	D4	JUMP',NE END$		; oui => END$	TEST.W	(A6)+OG5TVB	; y a-t-il un train ?	JUMP',NE STOP$		; oui => STOP$	TEST.W	(A6)+OG5TVC	; y a-t-il un train ?	JUMP',NE STOP$		; oui => STOP$	JUMP'	END$TURN$:	LOAD.W	D3,#28	LOAD.W	D4,#1	CALL	PUTUNIT		; dvie le train	JUMP'	EXIT$STOP$:	LOAD.W	D3,#123	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le trainEND$:	INC.W	(A6)+OG5TVA	LOAD.W	D3,#1030	CALL	IFETATEXIT$:	POPM.L	D3,D4	RET;---------\\; SNDDET19 >;---------/; Entre dans la gare 1.; in	-; out	-; mod	D7.WSNDDET19:	PUSHM.L	D3,D4	LOAD.W	D3,#502	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.W	D3,#30	CALL	GETUNIT	TEST.W	D4		; aiguillage tourn ?	JUMP',NE INT$		; oui => INT$EXT$:	LOAD.W	D3,#124	CALL	GETUNIT		; stoppe ?	TEST.W	D4	JUMP',NE EEND$		; oui => EEND$	TEST.W	(A6)+OG3TVB	JUMP',EQ EEND$	LOAD.W	D3,#124	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le trainEEND$:	INC.W	(A6)+OG5TVD	LOAD.W	D3,#1036	CALL	IFETAT	JUMP	EXIT$INT$:	TEST.W	(A6)+OG5TVA	JUMP',EQ IOK$	LOAD.W	D3,#30	CLR.W	D4	CALL	PUTUNIT		; dvie le train	JUMP	EXT$IOK$:	LOAD.W	D3,#123	CALL	GETUNIT		; stoppe ?	TEST.W	D4	JUMP',NE IEND$		; oui => IEND$	LOAD.W	D3,#122	CALL	GETUNIT		; stoppe ?	TEST.W	D4	JUMP',NE IEND$		; oui => IEND$	TEST.W	(A6)+OG5TVB	; y a-t-il un train ?	JUMP',NE ISTOP$		; oui => ISTOP$	TEST.W	(A6)+OG5TVC	; y a-t-il un train ?	JUMP',NE ISTOP$		; oui => ISTOP$	JUMP'	IEND$ISTOP$:	LOAD.W	D3,#123	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le trainIEND$:	INC.W	(A6)+OG5TVA	LOAD.W	D3,#1030	CALL	IFETATEXIT$:	POPM.L	D3,D4	RET;---------\\; SNDDET20 >;---------/; Entre dans la gare 1.; in	-; out	-; mod	D7.WSNDDET20:	PUSHM.L	D3,D4	LOAD.W	D3,#500	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.W	D3,#24	CALL	GETUNIT	TEST.W	D4		; aiguillage tourn ?	JUMP',EQ LEFT$		; oui => LEFT$RIGHT$:	LOAD.W	D3,#122	CALL	GETUNIT		; stoppe ?	TEST.W	D4	JUMP',NE REND$		; oui => REND$	TEST.W	(A6)+OG5TVA	JUMP',EQ REND$RSTOP$:	LOAD.W	D3,#122	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le trainREND$:	INC.W	(A6)+OG5TVB	LOAD.W	D3,#1032	CALL	IFETAT	JUMP	EXIT$LEFT$:	LOAD.W	D3,#122	CALL	GETUNIT		; stoppe ?	TEST.W	D4	JUMP',NE LEND$		; oui => LEND$	TEST.W	(A6)+OG5TVA	JUMP',NE LSTOP$	TEST.W	(A6)+OG5TVD	JUMP',NE LSTOP$	TEST.W	(A6)+OG3TVA	JUMP',NE LSTOP$	TEST.W	(A6)+OG3TVB	JUMP',EQ LEND$LSTOP$:	LOAD.W	D3,#122	LOAD.W	D4,#1	CALL	PUTUNIT		; stoppe le trainLEND$:	INC.W	(A6)+OG5TVC	LOAD.W	D3,#1033	CALL	IFETATEXIT$:	POPM.L	D3,D4	RET;---------\\; SNDDET21 >;---------/; Entre dans la gare 1.; in	-; out	-; mod	D7.WSNDDET21:	PUSHM.L	D3,D4	LOAD.W	D3,#500	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.W	D3,#104	CALL	GETUNIT		; y a-t-il un train stopp ?	TEST.W	D4	JUMP',EQ OK$	LOAD.W	D3,#20	LOAD.W	D4,#1	CALL	PUTUNIT		; tourne l'aiguillage !OK$:	LOAD.W	D3,#123	CALL	GETUNIT	TEST.W	D4	JUMP',NE NO5TVA$	TEST.W	(A6)+OG5TVA	JUMP',EQ NO5TVA$	DEC.W	(A6)+OG5TVA	LOAD.W	D3,#1030	CALL	IFETATNO5TVA$:	LOAD.W	D3,#122	CALL	GETUNIT	TEST.W	D4	JUMP',NE NO5TVB$	LOAD.W	D3,#24	CALL	GETUNIT	TEST.W	D4	JUMP',EQ NO5TVB$	TEST.W	(A6)+OG5TVB	JUMP',EQ NO5TVB$	DEC.W	(A6)+OG5TVB	LOAD.W	D3,#1032	CALL	IFETATNO5TVB$:EXIT$:	POPM.L	D3,D4	RET;---------\\; SNDDET22 >;---------/; Entre dans la gare 1.; in	-; out	-; mod	D7.WSNDDET22:	PUSHM.L	D3,D4	LOAD.W	D3,#502	CALL	GETUNIT	COMP.W	D4,#1		; marche avant ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.W	D3,#122	CALL	GETUNIT	TEST.W	D4	JUMP',NE NO5TVC$	LOAD.W	D3,#24	CALL	GETUNIT	TEST.W	D4	JUMP',NE NO5TVC$	TEST.W	(A6)+OG5TVC	JUMP',EQ NO5TVC$	DEC.W	(A6)+OG5TVC	LOAD.W	D3,#1033	CALL	IFETATNO5TVC$:	LOAD.W	D3,#124	CALL	GETUNIT	TEST.W	D4	JUMP',NE NO5TVD$	TEST.W	(A6)+OG5TVD	JUMP',EQ NO5TVD$	DEC.W	(A6)+OG5TVD	LOAD.W	D3,#1036	CALL	IFETATNO5TVD$:	TEST.W	(A6)+OG3TVB	JUMP',EQ NO3TVB$	DEC.W	(A6)+OG3TVB	LOAD.W	D3,#1021	CALL	IFETATNO3TVB$:EXIT$:	POPM.L	D3,D4	RET;--------\\; RCVDET  >;========/; Cherche le numro du dtecteur selon un message reu.; in	D3.L	message |op|id|data|data|; out	D3.L	message |op|id|data|data|;	D4.W	unit dtecteur;	D7.W	erreur; mod	D3.L, D4.L, D7.WRCVDET:	PUSHM.L	D1,D2,A4BEGIN$:	LOAD.W	D7,#ERMEVENT	; D7 <-- rien trouv	LOAD.L	D4,D3	RL.L	D4,#8		; D4 <-- op	COMP.B	D4,#OPDATA!2^BOPTAKE	JUMP',NE EXIT$	LOAD.L	D4,D3	SWAP.W	D4	AND.W	D4,#H'00FF	; D4 <-- id	LOAD.L	A4,#R16"TADET-6SRC$:	ADD.L	A4,#6		; A4 <-- ^suivant	TEST.W	(A4)		; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.W	D4,(A4)		; est-ce le bon id ?	JUMP,NE SRC$	LOAD.W	D2,(A4)+2	; est-ce le bon bit ?	TSET.L	D3:D2	JUMP,BS SRC$	LOAD.W	D1,(A4)+4	; D1 <-- no unit	LOAD.L	A4,#(A6)+OTATDET	ADD.W	A4,D1	ADD.W	A4,D1		; A4 <-- ^dernier temps	CALL	GETTIME		; D4 <-- temps actuel	LOAD.W	D2,D4	SUB.W	D2,(A4)		; D2 <-- temps coul	LOAD.W	(A4),D4	COMP.W	D2,#20/2	; s'est-il coul au moins 2.0 seconde ?	JUMP,LE BEGIN$		; non => BEGIN$	LOAD.W	D4,D1		; D4 <-- no unit	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2,A4	TEST.W	D7		; retour EQ/NE	RET	.END