	.SBTTL	RHBUSART.ASI;---------\\; PUTEVENT >;=========/; Traite un vnement en provenance d'un clavier quelconque.; in	D3.L	vnement |id.clavier|code|; out	D7.W	erreur; mod	D7.WPUTEVENT:	PUSHM.L	D2..D4,A4	LOAD.W	D7,#ERMEVENT	LOAD.L	D2,D3		; D2 <-- |id.clavier|-|	LOAD.L	D4,D3	SWAP.W	D4		; D4 <-- clavier	SL.W	D4,#2	LOAD.L	A4,#(A6)+OBUEV	ADD.W	A4,D4		; A4 <-- ^buffer vnement	COMP.W	D3,#F1	JUMP,EQ F1$	COMP.W	D3,#F2	JUMP,EQ F2$	COMP.W	D3,#F3	JUMP,EQ F3$	COMP.W	D3,#ENTER	JUMP,EQ ENTER$	COMP.W	D3,#CLEAR	JUMP,EQ CLEAR$	SUB.W	D3,#'0	JUMP,LO ERROR$	COMP.W	D3,#9	JUMP,HI ERROR$	TCLR.B	(A4)+2:#0	; nouveau chiffre ?	JUMP',BS NEW$		; oui => NEW$	LOAD.W	D4,(A4)		; D4 <-- chiffre actuel	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.W	D4,D3		; D4 <-- ajoute nouveau digit	LOAD.W	(A4),D4	JUMP	OK$NEW$:	LOAD.W	(A4),D3	LOAD.L	D3,D2		; D3 <-- |id.clavier|-|	LOAD.W	D3,#H'1110	; D3 <-- teint(rouge), teint(vert)	CALL	SNDBITS		; teint/allume les LEDs	JUMP	OK$F1$:	TSET.B	(A4)+2:#0	; met le bit "chiffre termin"	LOAD.W	D4,#1	LOAD.W	D3,#501	CALL	PUTUNIT		; stoppe le circuit intrieur	LOAD.W	D3,#503	CALL	PUTUNIT		; stoppe le circuit extrieur	LOAD.L	D3,D2		; D3 <-- |id.clavier|-|	LOAD.W	D3,#H'0100	; D3 <-- allume(rouge), allume(vert)	CALL	SNDBITS		; teint/allume les LEDs	JUMP	OK$F2$:	LOAD.W	D4,#1	JUMP'	FX$F3$:	LOAD.W	D4,#0;	JUMP'	FX$FX$:	LOAD.W	D3,(A4)	TSET.B	(A4)+2:#0	; met le bit "chiffre termin"	CALL	PUTUNIT		; envoie la commande	JUMP'	LEDMAJ$ENTER$:	LOAD.W	D3,(A4)	TSET.B	(A4)+2:#0	; met le bit "chiffre termin"	CALL	GETUNIT		; D4 <-- tat (0,1);	JUMP'	LEDMAJ$LEDMAJ$:	TEST.W	D7	JUMP',NE ERROR$	LOAD.L	D3,D2		; D3 <-- |id.clavier|-|	LOAD.W	D3,#H'1100	; D3 <-- allume(rouge), teint(vert)	COMP.W	D4,#0	JUMP',EQ LEDBIT$	LOAD.W	D3,#H'0110	; D3 <-- teint(rouge), allume(vert);	COMP.W	D4,#1;	JUMP',EQ LEDBIT$LEDBIT$:	CALL	SNDBITS		; teint/allume les LEDs	JUMP'	EXIT$CLEAR$:	CLR.W	(A4)	LOAD.L	D3,D2		; D3 <-- |id.clavier|-|	LOAD.W	D3,#H'1110	; D3 <-- teint(rouge), teint(vert)	CALL	SNDBITS		; teint/allume les LEDs	JUMP'	OK$ERROR$:	TSET.B	(A4)+2:#0	; met le bit "chiffre termin"	PUSH.W	D7	LOAD.L	D3,D2		; D3 <-- |id.clavier|-|	LOAD.W	D3,#H'0100	; D3 <-- allume(rouge), allume(vert)	CALL	SNDBITS		; teint/allume les LEDs	POP.W	D7	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; INIUNIT >;========/; Initialise toutes les units dans un tat initial.; in	-; out	-; mod	D7.WINIUNIT:	PUSHM.L	D3,D4,A4	LOAD.L	A4,#(A6)+OTAETAT	LOAD.W	D4,#MAXUNIT-1INIT$:	LOAD.B	(A4+),#-1	DECJ.W,NMO D4,INIT$	LOAD.L	A4,#R16"TAUNIT-8LOOP$:	ADD.L	A4,#8	LOAD.W	D3,(A4)	JUMP',EQ LED$	LOAD.W	D4,#1		; D4 <-- feu rouge	CALL	PUTUNIT	LOAD.W	D4,#5	NTREL	?DELMS	JUMP	LOOP$LED$:	LOAD.L	A4,#R16"TACLALLOOP$:	CLR.W	D3	LOAD.B	D3,(A4+)	JUMP',EQ FOND$	SWAP.W	D3	LOAD.W	D3,#H'0100	; D3 <-- allume(rouge), allume(vert)	CALL	SNDBITS		; teint/allume les LEDs	JUMP	LLOOP$FOND$:	LOAD.L	A4,#R16"TAIFOND-LTIFFLOOP$:	LOAD.L	A4,#(A4)+LTIF	; A4 <-- ^suivant	TEST.W	(A4)	JUMP',EQ EXIT$	COMP.W	(A4)+OTIFNF,#FLAUTO	JUMP,NE FLOOP$	LOAD.W	D3,(A4)+OTIFUN	CALL	IFETAT		; allume un automatisme	JUMP	FLOOP$EXIT$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PUTUNIT >;========/; Modifie l'tat d'une unit.; in	D3.W	numro de l'unit;	D4.W	tat (0,1); out	D7.W	erreur; mod	D7.WPUTUNIT:	PUSHM.L	D2,D3,A3,A4	CALL	IFETAT		; inverse l'tat dans l'image de fond	LOAD.W	D7,#ERMUNIT	COMP.W	D3,#MAXUNIT	JUMP,HS EXIT$	LOAD.L	A3,#(A6)+OTAETAT	LOAD.B	(A3)+(D3.W),D4	; mmorise l'tat	LOAD.L	A4,#R16"TAUNIT-8SEARCH$:	ADD.L	A4,#8	LOAD.W	D2,(A4)	JUMP,EQ EXIT$	COMP.W	D2,D3	JUMP,NE	SEARCH$	LOAD.W	D3,(A4)+4	; D3 <-- id	SWAP.W	D3	COMP.W	(A4)+2,#TYPAIG	JUMP',EQ AIG$SEC$:	LOAD.W	D3,#-1	LOAD.B	D3,(A4)+6+1	COMP.W	D4,#1	JUMP',EQ SND$	TSET.L	D3:#4	JUMP'	SND$AIG$:	LOAD.B	D3,(A4)+6+1	ADD.B	D3,#8+0	RL.W	D3,#8	LOAD.B	D3,(A4)+6+1	ADD.B	D3,#8+1	TSET.L	D3:#0+4;	TCLR.L	D3:#8+4	TEST.W	D4	JUMP',EQ SND$	TCLR.L	D3:#0+4	TSET.L	D3:#8+4;	JUMP'	SND$SND$:	CALL	SNDBITSEXIT$:	POPM.L	D2,D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETUNIT >;========/; Donne l'tat d'une unit.; in	D3.W	numro de l'unit; out	D7.W	erreur;	D4.W	tat (0,1); mod	D4.L, D7.WGETUNIT:	PUSH.L	A3	LOAD.W	D7,#ERMUNIT	COMP.W	D3,#MAXUNIT	JUMP',HS EXIT$	LOAD.L	A3,#(A6)+OTAETAT	CLR.W	D4	LOAD.B	D4,(A3)+(D3.W)	COMP.B	D4,#-1	JUMP',EQ EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; MESOPEN >;========/; Prpare pour la rception de messages.; in	-; out	D7.W	erreur; mod	D7.WMESOPEN:	PUSHM.L	D1..D5,A3..A5LIB ?AFTIM.ASCIZE "SYNC-SEND "	LOAD.W	D4,#50/10	NTREL	?SETTIM	LOAD.W	D2,#20-1SSND$:	CLR.B	D3	CALL	USARTWRITE1	; envoye un byte de synchronisation	JUMP,NE EXIT$	LOAD.W	D4,#2	NTREL	?DELMS	DECJ.W,NMO D2,SSND$SRCV$:	CALL	USARTREAD1	; lit un byte de synchronisation	JUMP,NE SEND$	JUMP	SRCV$SEND$:LIB ?AFTIM.ASCIZE "SYNC-OK "	LOAD.W	D4,#-1	NTREL	?SETTIM	LOAD.W	D4,#PRIORCV	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS2	LOAD.L	A3,#R16"NFILS2	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils de rception	JUMP,NE EXIT$	LOAD.W	D4,#2	NTREL	?DELMS	LOAD.L	D3,#H'1000000*OPIDENT	CALL	MESHAND		; identifie tous les processeurs ...	JUMP',NE ERROR$	SWAP.W	D3	AND.W	D3,#H'00FF	; D3 <-- nb de processeurs connects	LOAD.W	(A6)+ONBPROC,D3	CLR.W	D2DIREC$:	COMP.W	D2,#PROCREL-1	; carte spciale avec 8 relais ?	JUMP',EQ DOUT$		; oui => DOUT$	LOAD.W	D3,#H'100*OPDIREC ; D3 <-- <op>	LOAD.B	D3,D2	INC.B	D3		; D3 <-- <id>	SWAP.W	D3	LOAD.W	D3,#H'FFF0	; D3 <-- <data> (A=out, B=in/out)	CALL	MESHAND		; donne la direction	JUMP',NE ERROR$	COMP.W	D3,#H'0FF0	; est-ce un esclave clavier ?	JUMP',NE DNEXT$		; non => DNEXT$DOUT$:	LOAD.W	D3,#H'100*OPDIREC ; D3 <-- <op>	LOAD.B	D3,D2	INC.B	D3		; D3 <-- <id>	SWAP.W	D3	LOAD.W	D3,#H'FFFF	; D3 <-- <data> (A=out, B=out)	CALL	MESHAND		; donne la direction	JUMP',NE ERROR$DNEXT$:	INC.W	D2	COMP.W	D2,(A6)+ONBPROC	JUMP,LO DIREC$	NTREL	?GETPRIO	; D4 <-- priorit du pre	DEC.B	D4		; fils plus prioritaire !	AND.W	D4,#H'FF	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#500		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils d'mission	JUMP',EQ EXIT$ERROR$:	PUSH.W	D7	CALL	MESCLOSE	POP.W	D7EXIT$:	POPM.L	D1..D5,A3..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; MESCLOSE >;=========/; Termine la rception de messages.; in	-; out	-; mod	D7.WMESCLOSE:	SET.B	(A6)+OABORT	CALL	USARTABORT	; indique la fin au fils	.IF	~ASSMILE	NTREL	?WFABDESC	; attend la fin des fils ...	.ELSE	PUSH.L	D4	LOAD.W	D4,#50	NTREL	?DELMS	POP.L	D4	.ENDIF	RET;--------\\; MESHAND >;========/; Envoie un message d'initialisation, et attend la rponse.; in	D3.L	message  envoyer |op|id|data|data|; out	D3.L	message reu      |op|id|data|data|;	D7.W	erreur; mod	D3.L, D7.WMESHAND:	PUSHM.L	D4,D5,A1	CALL	USARTWRITE4	; envoye le message	JUMP',NE EXIT$	LOAD.W	D5,#20WAIT$:	LOAD.W	D4,#2	NTREL	?DELMS		; attend un peu ...	LOAD.L	A1,#(A6)+OFFRCV	CALL	GETFIFO		; D3 <-- message reu	JUMP',EQ EXIT$	DEC.W	D5	JUMP,NE WAIT$EXIT$:	POPM.L	D4,D5,A1	TEST.W	D7		; retour EQ/NE	RET;--------\\; SNDBITS >;========/; Envoie deux bits  allumer ou  teindre.;;	|   bit  |;	|76543210|;	    |<-->;	    | no;	   0,1; in	D3.L	message |-|id|bit|bit|; out	D7.W	erreur; mod	D7.WSNDBITS:	PUSH.L	A1	LOAD.L	A1,#(A6)+OFFSND	CALL	PUTFIFO		; D3 <-- message	POP.L	A1	TEST.W	D7		; retour EQ/NE	RET;---------\\; RCVEVENT >;=========/; Reoit un vnement en provenance d'un processeur.; in	-; out	D3.L	message |op|id|data|data|;	D7.W	erreur; mod	D3.L, D7.WRCVEVENT:	PUSHM.L	A1	LOAD.L	A1,#(A6)+OFFRCV	CALL	GETFIFO		; D3 <-- message reuEXIT$:	POPM.L	A1	TEST.W	D7		; retour EQ/NE	RET; Processus d'mission vers l'usart; ---------------------------------NFILS1:	.ASCIZ	"USART_SND"	.EVENPFILS1:	CLR.L	(A6)+OTIME	; OTIME <-- rz la mesure du tempsINIT$:	LOAD.L	A2,#(A6)+OTADOUT+2	LOAD.W	D2,#1LOOP$:	INC.L	(A6)+OTIME	; OTIME <-- inc la mesure du temps	TEST.B	(A6)+OABORT	; fin des fils ?	JUMP,NE END$		; oui => END$	LOAD.W	D4,#DELSND	NTREL	?DELMS		; attend un peu ...	TEST.B	(A6)+OSUSPW	; criture suspendue ?	JUMP,T	LOOP$		; oui => LOOP$	LOAD.L	A1,#(A6)+OFFSND	CALL	GETFIFO		; D3 <-- message	JUMP,NE WRITE$	LOAD.L	A4,#(A6)+OTADOUT	LOAD.L	D4,D3	SWAP.W	D4	AND.W	D4,#H'00FF	; D4 <-- <id> processeur	SL.W	D4,#1	LOAD.W	D1,(A4)+(D4.W)	COMP.B	D3,#-1	JUMP',EQ BIT0$	TEST.L	D3:#4	JUMP',BS SET0$;	AND.B	D3,#B'00001111	TCLR.L	D1:D3	JUMP'	BIT0$SET0$:	AND.B	D3,#B'00001111	TSET.L	D1:D3;	JUMP'	BIT0$BIT0$:	RR.W	D3,#8	COMP.B	D3,#-1	JUMP',EQ BIT1$	TEST.L	D3:#4	JUMP',BS SET1$;	AND.B	D3,#B'00001111	TCLR.L	D1:D3	JUMP'	BIT1$SET1$:	AND.B	D3,#B'00001111	TSET.L	D1:D3;	JUMP'	BIT1$BIT1$:	LOAD.W	(A4)+(D4.W),D1	; OTAPROC <-- nouveau dataWRITE$:	TEST.B	(A2)+0		; message pour aiguillage ?	JUMP',EQ NOWAIT$	; non => NOWAIT$	COMP.B	D2,(A6)+OLADAT+1 ; est-ce toujours pour le mme processeur ?	JUMP',NE NOWAIT$	; non => NOWAIT$	LOAD.B	D3,(A2)+0	OR.B	D3,(A6)+OLADAT+2	AND.B	D3,#B'11110000	CALL	CNTBITS	COMP.W	D3,#2		; est-ce sur le mme condensateur ?	JUMP',HS WAIT$		; oui => WAIT$	LOAD.B	D3,(A2)+0	OR.B	D3,(A6)+OLADAT+2	AND.B	D3,#B'00001111	CALL	CNTBITS	COMP.W	D3,#2		; est-ce sur le mme condensateur ?	JUMP',LO NOWAIT$	; non => NOWAIT$WAIT$:	LOAD.L	D4,(A6)+OTIME	SUB.L	D4,(A6)+OLATIM	; D4 <-- temps coul	COMP.L	D4,#DELCON/DELSND	JUMP',HS NOWAIT$	MUL.WU	D4,#DELSND	NTREL	?DELMS		; attend que le condensateur se recharge ...NOWAIT$:	LOAD.W	D3,#H'100*OPDATA ; D3 <-- <op>	LOAD.B	D3,D2		; D3 <-- <id>	SWAP.W	D3	LOAD.W	D3,(A2)		; D3 <-- <data>	CALL	USARTWRITE4	; envoye le message	AND.W	D3,#H'FF00	; message pour aiguillage ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	(A6)+OLADAT,D3	LOAD.L	(A6)+OLATIM,(A6)+OTIME	LOAD.W	D4,#DELAIG	NTREL	?DELMS		; attend un peu ...	LOAD.W	D3,(A2)		; D3 <-- <data>	AND.W	D3,#H'00FF	CALL	USARTWRITE4	; envoye le message de fin d'impulsion	LOAD.W	(A2),D3NEXT$:	ADD.L	A2,#2		; A2 <-- ^suivant	INC.W	D2		; D2 <-- processeur suivant	COMP.W	D2,(A6)+ONBPROC	JUMP,LS LOOP$	JUMP	INIT$END$:	NTREL	?ABORT; Processus de rception de l'usart; ---------------------------------NFILS2:	.ASCIZ	"USART_RCV"	.EVENPFILS2:	LOAD.L	A2,#(A6)+OTADIN	; A2 <-- ^table des datasLOOP$:	TEST.B	(A6)+OABORT	; fin des fils ?	JUMP,NE END$		; oui => END$	CALL	USARTREAD4	; D3 <-- message lu ...	JUMP',EQ RDOK$	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$RDOK$:	LOAD.L	D4,D3	RL.L	D4,#8	COMP.B	D4,#OPDATA!2^BOPTAKE	JUMP',NE PUT$	CALL	IFCLAVIER	; message reu d'un clavier ?	JUMP',EQ KEY$		; oui => KEY$	AND.W	D3,#H'000F	; D3 <-- ne conserve que les entres (bits 0..3 du port B)	LOAD.L	D4,D3	SWAP.W	D4	AND.W	D4,#H'00FF	; D4 <-- <id> processeur	SL.W	D4,#1	COMP.W	D3,(A2)+(D4.W)	; data chang ?	JUMP,EQ LOOP$		; non => LOOP$	LOAD.W	(A2)+(D4.W),D3	JUMP'	PUT$KEY$:	AND.W	D3,#H'FF00	; D3 <-- ne conserve que la touche (bits 0..7 du port A)	JUMP,EQ LOOP$;	JUMP'	PUT$PUT$:	LOAD.L	A1,#(A6)+OFFRCV	CALL	PUTFIFO		; fifo <-- message	JUMP	LOOP$END$:	NTREL	?ABORT;--------\\; CNTBITS >;--------/; Compte le nombre de bits contenus dans un byte.; in	D3.B	valeur; out	D3.W	nb de bits contenus; mod	D3.LCNTBITS:	PUSHM.L	D1,D2	LOAD.B	D1,D3	LOAD.W	D2,#8-1	CLR.W	D3LOOP$:	RR.B	D1	JUMP',CC NEXT$	INC.W	D3NEXT$:	DECJ.W,NMO D2,LOOP$	POPM.L	D1,D2	RET;----------\\; IFCLAVIER >;==========/; Regarde si la commande vient d'un processeur "SLAVE-K".; in	D3.L	|-|id|-|-|; out	D7.W	erreur si pas clavier; mod	D7.WIFCLAVIER:	PUSHM.L	D3,A3	LOAD.W	D7,#1	SWAP.W	D3	LOAD.L	A3,#R16"TACLASEARCH$:	TEST.B	(A3)	JUMP',EQ EXIT$	COMP.B	D3,(A3+)	JUMP,NE SEARCH$	CLR.W	D7EXIT$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; USARTWRITE4 >;============/; Envoye un message de 4 bytes dans l'usart.; in	D3.L	message  envoyer; out	D7.W	erreur; mod	D7.WUSARTWRITE4:	PUSHM.L	D4,D6,A4	PUSH.L	D4		; place pour p'tit buffer	LOAD.L	A4,SP		; A4 <-- ^p'tit buffer	LOAD.L	(A4),D3		; buffer <-- message	LOAD.W	D6,(A6)+OUSCHO	; D6 <-- canal	LOAD.L	D4,#4	FOS	?WRBYTE		; crit 4 bytes ...	POP.L	D4		; ajuste le stack	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; USARTWRITE1 >;============/; Envoye un seul byte dans l'usart.; in	D3.B	byte  envoyer; out	D7.W	erreur; mod	D7.WUSARTWRITE1:	PUSHM.L	D4,D6,A4	PUSH.W	D4		; place pour p'tit buffer	LOAD.L	A4,SP		; A4 <-- ^p'tit buffer	LOAD.B	(A4),D3		; buffer <-- byte	LOAD.W	D6,(A6)+OUSCHO	; D6 <-- canal	LOAD.L	D4,#1	FOS	?WRBYTE		; crit 1 byte ...	POP.W	D4		; ajuste le stack	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; USARTREAD4 >;===========/; Reoit un message de 4 bytes de l'usart.; in	-; out	D3.L	message reu;	D7.W	erreur; mod	D3.L, D7.WUSARTREAD4:	PUSHM.L	D4,D6,A4	PUSH.L	D4		; place pour p'tit buffer	LOAD.L	A4,SP		; A4 <-- ^p'tit buffer	LOAD.W	D6,(A6)+OUSCHI	; D6 <-- canal	LOAD.L	D4,#4	FOS	?RDBYTE		; lit 4 bytes ...	JUMP',NE EXIT$	LOAD.L	D3,(A4)		; D3 <-- message luEXIT$:	POP.L	D4		; ajuste le stack	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; USARTREAD1 >;===========/; Reoit un seul byte de l'usart.; in	-; out	D3.B	byte reu;	D7.W	erreur; mod	D3.L, D7.WUSARTREAD1:	PUSHM.L	D4,D6,A4	PUSH.W	D4		; place pour p'tit buffer	LOAD.L	A4,SP		; A4 <-- ^p'tit buffer	LOAD.W	D6,(A6)+OUSCHI	; D6 <-- canal	LOAD.L	D4,#1	FOS	?RDBYTE		; lit 1 byte ...	JUMP',NE EXIT$	LOAD.B	D3,(A4)		; D3 <-- byte luEXIT$:	POP.W	D4		; ajuste le stack	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; USARTABORT >;===========/; Aborte l'usart en entre.; in	-; out	D7.W	erreur; mod	D7.WUSARTABORT:	PUSHM.L	D6	LOAD.W	D6,(A6)+OUSCHI	FOS	?AVORT	POPM.L	D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; USARTOPEN >;==========/; Ouvre l'usart.; in	-; out	D7.W	erreur; mod	D7.WUSARTOPEN:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,#R16"TUSIN1	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE EXIT$	LOAD.W	(A6)+OUSCHI,D6	LOAD.L	A3,#R16"TUSOUT1	LOAD.W	D3,#2^BOPWR	FOS	?OPEN	JUMP',NE EXIT$	LOAD.W	(A6)+OUSCHO,D6	LOAD.L	A4,#R16"TCMIN	LOAD.W	D3,#TYPIO	LOAD.W	D6,(A6)+OUSCHI	FOS	?COMMAND;	JUMP',NE EXIT$	LOAD.L	A4,#R16"TCMOUT	LOAD.W	D3,#TYPIO	LOAD.W	D6,(A6)+OUSCHO	FOS	?COMMAND;	JUMP',NE EXIT$EXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; USARTCLOSE >;===========/; Ferme l'usart.; in	-; out	-; mod	-USARTCLOSE:	PUSHM.L	D6,D7	LOAD.W	D6,(A6)+OUSCHI	JUMP',EQ IN$	FOS	?CLOSEIN$:	LOAD.W	D6,(A6)+OUSCHO	JUMP',EQ OUT$	FOS	?CLOSEOUT$:	CLR.W	(A6)+OUSCHI	CLR.W	(A6)+OUSCHO	POPM.L	D6,D7	RET;--------\\; PUTFIFO >;========/; Met un caractre dans le fifo.; in	D3.L	caractre;	A1.L	^fifo; out	D7.W	erreur; mod	D7.WPUTFIFO:	PUSHM.L	D4,A4	LOAD.L	A4,#(A1)+OFFDATA	LOAD.W	D4,(A1)+OFFHEAD	ADD.W	A4,D4	LOAD.L	(A4+),D3	ADD.W	D4,#LGFIFO	COMP.W	D4,#LGFIFO*NBFIFO	JUMP',LO 30$	CLR.W	D430$:	LOAD.W	D7,#ERMFULL	; D7 <-- fifo plein	COMP.W	D4,(A1)+OFFTAIL	JUMP',EQ EXIT$	LOAD.W	(A1)+OFFHEAD,D4	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETFIFO >;========/; Prend un caractre dans le fifo.; in	A1.L	^fifo; out	D3.L	caractre;	D7.W	erreur; mod	D3.L, D7.WGETFIFO:	PUSHM.L	D4,A4	LOAD.W	D7,#ERMEMPTY	; D7 <-- fifo vide	CLR.L	D3	LOAD.W	D4,(A1)+OFFTAIL	COMP.W	D4,(A1)+OFFHEAD	JUMP',EQ EXIT$	LOAD.L	A4,#(A1)+OFFDATA	ADD.W	A4,D4	LOAD.L	D3,(A4+)	ADD.W	D4,#LGFIFO	COMP.W	D4,#LGFIFO*NBFIFO	JUMP',LO 30$	CLR.W	D430$:	LOAD.W	(A1)+OFFTAIL,D4	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RETTUSIN1:	.ASCIZ	"#PR"TUSOUT1:.ASCIZ	"#PP"TCMIN:;;?	.B	'N		; mode standard	.BB	'M,'R	.BB	'M,'H,'D	.BB	'L,'8		; 8 bits	.BB	'P,'D		; pas de parit	.BB	'S,'2		; 2 stop bits	.BW	'V,9600		; baud-rate	.BB	'Y,'D		; timeout par commande;;?	.BW	'W,50*4		; timeout de 4 secondes	.BB	'F,'E		; fifo enable	.B	0TCMOUT:	.BB	'L,'8		; 8 bits	.BW	'V,9600		; baud-rate	.BB	'Y,'D		; timeout par commande;;?	.BW	'W,50*4		; timeout de 4 secondes;;?	.BB	'F,'E		; fifo enable	.B	0	.EVEN	.END