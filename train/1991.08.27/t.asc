	.PROC	M680002	.REF	SMAKYSM324ADMUBUS =	H'FFFFA800BASE	=	H'08MBDATA	=	0MBADR	=	1 BOE	=  6 BWR	=  7MBCTRL	=	2	.LOC	0START:	CLR.L	D0	CLR.B	D1LOOP$:	LOAD.W	D2,#0	CALL	READ	NOT.B	D3	JUMP,EQ WRITE$	LOAD.B	D4,D3	LIB	?AFX2	LIB	?AFSPACEWRITE$:	LOAD.W	D3,D0	AND.W	D3,#B'1111111	JUMP,NE NEXT$	LOAD.W	D2,#0	LOAD.B	D3,D1	CALL	WRITE	INC.B	D1NEXT$:	INC.L	D0	LIB	?IFCAR	JUMP,NE LOOP$END$:	EXIT;--------\\; READ    >;========/; ; in	D2.W	adresse; out	D3.B	data; mod	D3.L, D7.WREAD:	PUSHM.L	D2	OR.B	D2,#2^BWR!2^BOE	LOAD.B	SM324ADMUBUS+BASE+MBADR,D2	LOAD.B	SM324ADMUBUS+BASE+MBCTRL,D2	LOAD.B	D3,SM324ADMUBUS+BASE+MBDATAEXIT$:	POPM.L	D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRITE   >;========/; ; in	D2.W	adresse;	D3.B	data; out	-; mod	D7.WWRITE:	PUSHM.L	D2,D3	LOAD.B	SM324ADMUBUS+BASE+MBADR,D2	LOAD.B	SM324ADMUBUS+BASE+MBDATA,D3	LOAD.B	SM324ADMUBUS+BASE+MBCTRL,D2EXIT$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RET	.END	START