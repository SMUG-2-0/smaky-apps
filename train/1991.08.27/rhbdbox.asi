	.SBTTL	RHBDBOX.ASI;----------\\; DBOXPREND >;==========/; Demande un nom gnral  prendre.; in	-; out	A3.L	^nom;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.W, A3.LDBOXPREND:	PUSHM.L	D1,D2,D4,A2,A4,A5	LOAD.L	A5,#(A6)+OBUNAM	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_PREND	DBOX_	EXTEND	JUMP',NE EXIT$	LOAD.L	A3,A5		; A3 <-- ^nomEXIT$:	CALL	AFMENU	POPM.L	D1,D2,D4,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXSAUVE >;==========/; Demande un nom gnral  sauver.; in	-; out	A3.L	^nom;	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.W, A3.LDBOXSAUVE:	PUSHM.L	D1,D2,D4,A2,A4,A5	LOAD.L	A5,#(A6)+OBUNAM	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_EXTRAIT	DBOX_	EXTEND	JUMP',NE EXIT$	LOAD.L	A3,A5		; A3 <-- ^nomEXIT$:	CALL	AFMENU	POPM.L	D1,D2,D4,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXDETRUIT >;============/; Demande s'il faut dtruire.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDETRUIT:	PUSHM.L	D1,D2,D4,A2..A5	LOAD.L	A5,#(A6)+OBUNAM	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A3,#R16"TDBOX_IO	CLR.L	D3	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_DETRUIT	DBOX_	EXTENDEXIT$:	CALL	AFMENU	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Quitte le logiciel ?; in	-; out	D3.W	F1/F4; mod	D7.WDBOXQUITTE:	PUSHM.L	D0..D2,D4..D6,A3..A5	LOAD.W	D1,#DBOX_QUITTE	LOAD.L	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	DBOX_	EXTEND		; demande s'il faut quitter ...	CALL	AFMENU		; refait les soft-keys	POPM.L	D0..D2,D4..D6,A3..A5	RETTEXT_IO:	.ASCIZ	".RHB"		; extensionTDBOX_IO:	.ASCIZ	"RHB"		; nom du logiciel	.ASCIZ	"Fmmoire"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN	.END