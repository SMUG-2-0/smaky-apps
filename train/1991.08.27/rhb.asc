	.TITLE	RHB.ASC;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du programme RHB.CODE;	Date		Amliorations; --------------------------------------------------------------------------	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULESASSMILE	=	0		; 1 => test avec SMILE2MAJREV	=	0		; rvisionMINREV	=	1		; version	.REV	MAJREV,MINREV	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'R,'F,07	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;BEPROTXT = 3BEPROQUITTE = 4BEPROMOUSE = 5BEPROAFCR = 7BEPROAFLF = 8BEPROAFTAB = 9EPRO_EXTEND = 16'A84FEPRO_GETPDBUFF = 1OEPROPDB = 0OEPROPDT = 4OEPROPFT = 8OEPROPFB = 12OEPROSTATUS = H'1BBEPROFILMOD = 0;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; Constantes; ----------NBFIFO	=	200		; lg max du fifoLGFIFO	=	4		; taille d'un lment dans le fifo (.L)KEYDBOX	=	H'7E00		; "touche" spciale pour dboxMAXPROC	=	50		; nb max de processeursMAXUNIT	=	600		; nb max d'unitsMAXDET	=	100		; nb max de dtecteursPROCREL	=	12		; id du processeur ayant les 8 relaisPRIORCV	=	2		; priorit du processus de rceptionDELSND	=	2		; dlai entre deux missionsDELAIG	=	2		; dlai pour une impulsion de commande d'aiguillageDELCON	=	50*2		; dlai pour recharger un condensateur d'aiguillage; L'unit est de 20ms pour toutes les constantes DEL* !IDIMX	=	640		; largeur de l'imageIDIMY	=	340		; hauteur de l'imageLBUNAM	=	50		; lg max d'un nom de fichierLMMNLI	=	500		; mmory: lg max nouvel itinraireGCT1F	=	'NGCT1S	=	'R!2^7GCT1T	=	07GCT2F	=	'NGCT2S	=	'E!2^7GCT2T	=	11; Types d'units; --------------TYPSEC	=	1		; type secteurTYPAIG	=	2		; type aiguillage; Types des flches; -----------------FLRIEN	=	0FLN	=	1FLNNE	=	2FLNE	=	3FLENE	=	4FLE	=	5FLESE	=	6FLSE	=	7FLSSE	=	8FLS	=	9FLSSO	=	10FLSO	=	11FLOSO	=	12FLO	=	13FLONO	=	14FLNO	=	15FLNNO	=	16FLBLOC	=	20FLDT0	=	30FLDT1	=	31FLBLANC	=	40FLAV	=	41FLAR	=	42FLSTOP	=	43FLGO	=	44FL0	=	50FL1	=	51FL2	=	52FL3	=	53FL4	=	54FL5	=	55FL6	=	56FL7	=	57FL8	=	58FL9	=	59FL00	=	60FLAUTO	=	100; Table pour l'image de fond; --------------------------	.LOC	0OTIFUN:	.BLKB	2		; numro de l'unitOTIFRP:	.BLKB	4		; rouge: position (x;yi)OTIFRF:	.BLKB	2		; rouge: flcheOTIFVP:	.BLKB	4		; vert:  position (x;yi)OTIFVF:	.BLKB	2		; vert:  flcheOTIFNF:	.BLKB	2		; non:   flcheOTIFDP:	.BLKB	4		; dtection: position (x;yi)OTIFDD:	.BLKB	4		; dtection: dimensions (dx;dy)LTIF:;	(x;yi)	-->	Position x-y comme elle est affiche par;			DESSIN4 sous la forme X=... Y=...; Erreurs; -------ERMEMPTY=	H'F001		; fifo videERMFULL	=	H'F002		; fifo pleinERMPROC	=	H'F003		; processeur absentERMUNIT	=	H'F004		; unit inexistanteERMEVENT=	H'F005		; vnement incorrect; Protocole; ---------;	4 bytes: <op> <id> <data_A> <data_B>OPIDENT	=	H'01			; identifie le processeurOPCHANGE=	H'02			; change l'identificationOPDIREC	=	H'03			; direction des ports A et BOPDATA	=	H'04			; data pour les ports A et B (in et/ou out)BOPTAKE	=	7			; information prise en compte;	Processeur "SLAVE-444" :;	;	|76543210|76543210|;	 <------> <--><-->;	    M      R   E     (M=moteur, R=relai, E=entre);	Processeur "SLAVE-K" :;	;	|76543210|76543210|;	 <------>       ||;	    T           RV   (T=touche, R=LED rouge, V=LED verte); Descripteur d'un fifo; ---------------------	.LOC	0OFFHEAD:.BLKB	2		; ^tteOFFTAIL:.BLKB	2		; ^queueOFFDATA:.BLKB	LGFIFO*NBFIFO	; contenuLFF:; Variables; ---------LBUDIS	=	50	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHEPRO:.BLKB	2		; canal module EPROOMACHINE:.BLKB	1		; machine	.EVENOPLCOM:	.BLKB	4		; ^ligne de commandeOPDDIS:	.BLKB	4		; ^descripteur de la fentreOBUDIS:	.BLKB	LBUDIS		; buffer pour "write-display"OINV:	.BLKB	1		; 1 => affichage inversOAUTO:	.BLKB	1		; 1 => fonctionnement automatique	.EVENOPSEM:	.BLKB	4		; ^smaphoreOSUSPW:	.BLKB	1		; 1 => suspend l'critureOABORT:	.BLKB	1		; 1 => fin du processus fils	.EVENOUSCHI:	.BLKB	2		; usart: canal usart "in"OUSCHO:	.BLKB	2		; usart: canal usart "out"OFFSND:	.BLKB	LFF		; fifo d'missionOFFRCV:	.BLKB	LFF		; fifo de rceptionONBPROC:.BLKB	2		; nb de processeurs connectsOTADOUT:.BLKB	2*MAXPROC	; table des valeurs  crireOTADIN:	.BLKB	2*MAXPROC	; table des valeurs luesOTAETAT:.BLKB	1*MAXUNIT	; table des tats des unitsOTATDET:.BLKB	2*MAXDET	; table des temps des dtecteursOBUEV:	.BLKB	4*MAXPROC	; buffer des vnementsOTIME:	.BLKB	4		; temps absolu (32 bits suffisent pour 994 jours !)OLATIM:	.BLKB	4		; dernier aiguillage: temps absoluOLADAT:	.BLKB	4		; dernier aiguillage: dataOIFPDA:	.BLKB	4		; image fond: ^dataOIFDIM:	.BLKB	4		; image fond: dimensionsOG1TVA:	.BLKB	2		; gare 1: train sur la voie AOG1TVB:	.BLKB	2		; gare 1: train sur la voie BOG1TVC:	.BLKB	2		; gare 1: train sur la voie COG2TVA:	.BLKB	2		; gare 2: train sur la voie AOG2TVB:	.BLKB	2		; gare 2: train sur la voie BOG3TVA:	.BLKB	2		; gare 3: train sur la voie AOG3TVB:	.BLKB	2		; gare 3: train sur la voie BOG4TVA:	.BLKB	2		; gare 4: train sur la voie AOG4TVB:	.BLKB	2		; gare 4: train sur la voie BOG5TVA:	.BLKB	2		; gare 5: train sur la voie AOG5TVB:	.BLKB	2		; gare 5: train sur la voie BOG5TVC:	.BLKB	2		; gare 5: train sur la voie COG5TVD:	.BLKB	2		; gare 5: train sur la voie DOMMPTX:	.BLKB	4		; mmory: ^texteOMMLGM:	.BLKB	4		; mmory: lg max du texteOMMNLI:	.BLKB	LMMNLI		; mmory: nouvelle ligneOSLVAR:	.BLKB	LSLVAR		; variables scroll-listeOBUNAM:	.BLKB	LBUNAM		; nom de fichierLGVAR:; Programme; ---------	.LOC	0ADCODE:	JUMP	START; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMEPRO:		.ASCIZ	"EPRO"; Erreurs fatales; ---------------TXERFATUSA:	.ASCIZ	"Problme avec #PR/#PP"TXERFATMES:	.ASCIZ	"Problme avec les cartes esclaves"; Noms de fichiers; ----------------TFDEF:		.ASCIZ	"RHB.RHB"		.EVENSTART:	.IF	~ASSMILE	LIB	?OPELIB	.ENDIF	LOAD.W	D3,#2	LIB	?MOUSE	LIB	?AFTIM	.B	NOCURS	.B	NOEFLI	.B	0	.EVEN	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LIB	?GETPDIS	LOAD.L	(A6)+OPDDIS,A4	LOAD.L	A0,A4	LIB	?AFTIM	.B	LOADGC	.B	GCT1F	.B	GCT1S	.B	GCT1T	.B	0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	LOADGC	.B	GCT2F	.B	GCT2S	.B	GCT2T	.B	0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC	.B	GCT1F	.B	GCT1S	.B	GCT1T	.B	0	.EVEN	SET.B	(A6)+OAUTO	; mode automatique	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMEPRO	LOAD.W	D3,#EPRO_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHEPRO,D1	LOAD.W	D4,#1	NTREL	?CRESEM		; cre un smaphore d'exclusion	JUMP,NE ERFAT2	LOAD.L	(A6)+OPSEM,A5	LOAD.L	A3,#R16"NMIFOND	CALL	IMAGELOAD	; charge l'image de fond	JUMP,NE ERFAT2	LOAD.L	(A6)+OIFPDA,A4	LOAD.L	(A6)+OIFDIM,D4	CALL	MMTXOPEN	; ouvre le texte pour le mmory	LOAD.L	A3,#R16"TXERFATUSA	CALL	USARTOPEN	; ouvre l'usart;;?	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATMES	CALL	MESOPEN		; ouvre la messagerie;;?	JUMP,NE ERFAT2LIB ?AFCRLOAD.W D4,(A6)+ONBPROCLIB ?AFX4LIB ?AFTIM.ASCIZE " esclaves connects."	LOAD.L	A4,(A6)+OIFPDA	LOAD.L	D4,(A6)+OIFDIM	CLR.L	D3	CALL	IMAGESHOW	; affiche l'image de fond	CALL	MMSLDRAW	; dessine la scroll-liste	TEST.B	(A6)+OAUTO	JUMP',F NOINV$	LOAD.W	D2,#6	CALL	MMICINV		; allume l'icne "automatique"NOINV$:	CALL	INIUNIT		; met toutes les units dans un tat initial	LOAD.L	A3,#R16"TFDEF	CALL	MMTXREAD	; lit le fichier RHB.RHB	CALL	AFMENU		; affiche les soft-keysLOOP:	LOAD.W	D4,#50/10	NTREL	?SETTIM	LIB	?GETCAR		; attend clavier/souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE	TIMO$	COMP.W	D3,#KEYMGR	JUMP,EQ	LOOP	COMP.W	D3,#KEYMMR	JUMP,EQ	LOOP	COMP.W	D3,#KEYMDR	JUMP,EQ	LOOP	COMP.W	D3,#KEYMGP	JUMP,EQ	CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ	CLIC$	COMP.W	D3,#KEYMDP	JUMP,EQ	CLIC$	COMP.W	D3,#F0	JUMP,EQ	FINI	COMP.W	D3,#END	JUMP,EQ	FINI	COMP.W	D3,#F1	JUMP,EQ PREND$	COMP.W	D3,#F3	JUMP,EQ SAUVE$	COMP.W	D3,#F12	JUMP,EQ NEGATIF$	COMP.W	D3,#SPACE	JUMP,EQ STOP$	COMP.W	D3,#'S	JUMP,EQ SIMDET$	COMP.W	D3,#'s	JUMP,EQ SIMDET$;;?COMP.W D3,#'DJUMP,EQ DIREC$COMP.W D3,#'eJUMP,EQ DIREC$	AND.L	D3,#H'FF	LOAD.B	D4,D3	LOAD.B	D3,#F1	COMP.B	D4,#TRIZERO	JUMP',EQ PUT$	LOAD.B	D3,#F2	COMP.B	D4,#CLEAR	JUMP',EQ PUT$	LOAD.B	D3,#F3	COMP.B	D4,#DELETE	JUMP',EQ PUT$	LOAD.B	D3,#CLEAR	COMP.B	D4,#POINT	JUMP',EQ PUT$	LOAD.B	D3,D4PUT$:	CALL	PUTEVENT	JUMP,NE	BIP	JUMP	LOOPSIMDET$:	LOAD.L	D3,#300	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Det = "	.EVEN	LIB	?GETCURS	LIB	?AFTIM	.ASCIZ	"    "	.EVEN	LIB	?SETCURS	LIB	?GETDEC	PUSH.L	D3	LOAD.L	D3,#300	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"          "	.EVEN	POP.L	D3	COMP.W	D3,#CR	JUMP,NE LOOP	CALL	SNDDET	JUMP	LOOP;;?DIREC$:	LOAD.W	D3,#H'100*OPDIREC ; D3 <-- <op>	LOAD.B	D3,#1		; D3 <-- <id>	SWAP.W	D3	LOAD.W	D3,#H'FFF0	; D3 <-- <data> (A=out, B=in/out)	CALL	USARTWRITE4	; envoye le message	JUMP,NE ERROR	LIB	?BUZZ	JUMP	LOOP;;?TIMO$:	CALL	RCVEVENT	; D3 <-- message |op|id|data|data|	JUMP',NE COMM$	CALL	IFCLAVIER	; message reu d'un clavier ?	JUMP',EQ EVCLA$		; oui => EVCLA$PUSH.L D3LOAD.L D3,#300LIB ?SETCURSPOP.L D3LOAD.L D4,D3LIB ?AFX8DET$:	CALL	RCVDET		; D4 <-- unit dtecteur	JUMP',NE COMM$	CALL	SNDDET		; action selon un dtecteur	JUMP	DET$EVCLA$:	RR.W	D3,#8	AND.L	D3,#H'00FF00FF	TEST.B	D3	JUMP',EQ COMM$	CALL	PUTEVENT	JUMP,NE BIP;	JUMP'	COMM$COMM$:	JUMP	LOOPCLIC$:	LIB	?IFMOUSE	; D4 <-- position de la souris	CALL	IFMOVE		; D3 <-- unit clique	JUMP,EQ CUNIT$	CALL	MMICMOVE	; D2 <-- icne clique	JUMP',EQ CICONE$	CALL	MMSLMOVE	; dans la scroll-liste	JUMP,EQ LOOP	JUMP	BIPCICONE$:	COMP.W	D2,#0	JUMP,EQ STOP$	COMP.W	D2,#1	JUMP,EQ CICINIT$	COMP.W	D2,#2	JUMP,EQ CICKILL$	COMP.W	D2,#3	JUMP,EQ CICEDIT$	COMP.W	D2,#6	JUMP,EQ CICAUTO$	JUMP	BIPCICINIT$:	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	COMP.W	D3,#-1	JUMP',EQ CICCREE$	CALL	MMSLINIT	JUMP	LOOPCICCREE$:	CALL	MMSLCREE	JUMP	LOOPCICKILL$:	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	COMP.W	D3,#-1	JUMP,EQ BIP	CALL	MMSLDELLI	CALL	MMSLUPDATE	JUMP	LOOPCICEDIT$:	CALL	MMTXEDIT	; dite le texte	JUMP	LOOPCICAUTO$:	CALL	MMICINV	NOT.B	(A6)+OAUTO	JUMP	LOOPCUNIT$:	CALL	IFSEARCH	; A4 <-- ^OTIF*	JUMP,NE BIP	COMP.W	(A4)+OTIFNF,#FLAUTO	JUMP',EQ CAUTO$	CALL	GETUNIT		; D4 <-- tat (0,1)	JUMP,NE BIP	DEC.W	D4	JUMP',EQ CINV$	LOAD.W	D4,#1CINV$:	CALL	PUTUNIT		; envoie l'tat invers	JUMP,NE BIP	JUMP	LOOPCAUTO$:	LOAD.W	D4,(A4)+OTIFRF	; D4 <-- offset variable	TEST.W	(A6)+(D4.W)	JUMP',EQ CAUTO1$	CLR.W	(A6)+(D4.W)	CALL	IFETAT	JUMP	LOOPCAUTO1$:	INC.W	(A6)+(D4.W)	CALL	IFETAT	JUMP	LOOPSTOP$:				; arrt d'urgence :	LOAD.W	D4,#1	LOAD.W	D3,#501	CALL	PUTUNIT		; stoppe le circuit intrieur	LOAD.W	D3,#503	CALL	PUTUNIT		; stoppe le circuit extrieur	JUMP	LOOPPREND$:	CALL	DBOXPREND	; demande le nom ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	MMTXREAD	JUMP,NE ERROR	JUMP	LOOPSAUVE$:	CALL	DBOXSAUVE	; demande le nom ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	MMTXWRITE	JUMP,NE ERROR	JUMP	LOOPNEGATIF$:	NOT.B	(A6)+OINV	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse tout	CALL	MMSLDRAW	; redessine la scroll-liste	JUMP	LOOPBIP:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPBIGBIP:				; erreur =>	LOAD.B	D3,#BIPERR	LIB	?BEEP		; grand bruit	JUMP	LOOPERROR:	TEST.W	D7	JUMP,EQ LOOP	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	AFMENU		; refait les soft-keys	JUMP	LOOPFINI:	CALL	DBOXQUITTE	; quitte le logiciel ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOPERFAT:	CALL	MMTXCLOSE	; ferme le texte pour le mmory	LOAD.L	A4,(A6)+OIFPDA	LOAD.L	D4,(A6)+OIFDIM	CALL	IMAGEKILL	; libre l'image de fond	CALL	MESCLOSE	; ferme la messagerie	CALL	USARTCLOSE	; ferme l'usart	LOAD.L	A5,(A6)+OPSEM	NTREL	?KILLSEM	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHEPRO	LIB_	CLOSE	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend les variablesERFAT1:	.IF	~ASSMILE	LIB	?CLOLIB	FOS	?STOP	.ELSE	EXIT	.ENDIFERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	RHBMEMORY.ASI	.INS	RHBAUTO.ASI	.INS	RHBDBOX.ASI	.INS	RHBIMAGE.ASI	.INS	RHBUSART.ASI	.INS	RHBMISC.ASI	.INS	RHBTABLE.ASI	.END	START