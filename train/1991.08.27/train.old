	.TITLE	TRAIN.ASD;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du pilote SMA_TRAIN.DRIV	.PROC	M680002	.REF	SMAKY	.REF	BIOSDRIV;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;SMAKY300 = 7;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.RADIX	10.	.HEX;	Date		Amliorations; --------------------------------------------------------------------------; 0.1	19.12.90	premire versionMAJREV	=	0		; rvisionMINREV	=	1		; version	.REV	MAJREV,MINREV; Constantes; ----------DRIVNUM	=	H'E0		; numro du driverPRIODET	=	6		; priorit du processus des dtecteursSM100ADMUBUS =	H'FFFF8000SM324ADMUBUS =	H'FFFFA800SM300ADMUBUS =	H'01000000MAXCARTES=	16		; nb max de cartes connectables simultanmentMBWREL	=	0		; write: relaisMBWROW	=	1		; write: slection colonneMBWLINE	=	2		; write: slection ligne + enable BENLINE =	 6		;  bit enable line BENROW	=	 7		;  bit enable rowMBRDET	=	0		; read: dtecteursMBRRAZ	=	1		; read: rz dtecteurs; Erreurs; -------ERTRAIN	=	H'DA00		; valeur de base (DA comme DAniel !)ERTMACH	=	ERTRAIN+1	; machine illgaleERTIWLG	=	ERTRAIN+2	; longueur incorrecteERTICOM	=	ERTRAIN+3	; commande incorrecteERTRNOD	=	ERTRAIN+4	; rien  lire; Structure du data; -----------------	.LOC	0ODACOM:	.BLKB	2		; data: commandeODAUNI:	.BLKB	2		; data: numro de l'unitODANUM:	.BLKB	2		; data: valeurODAPAR:	.BLKB	2		; data: paramtreLDA:; Variables; ---------	.LOC	0OMBAD:	.BLKB	4		; adresse de base de MUBUSOMBI:	.BLKB	2		; incrment MUBUS (1,2)OMBI4:	.BLKB	2		; OMBI*4OMBWREL:.BLKB	2		; write: relaisOMBWROW:.BLKB	2		; write: slection colonneOMBWLINE:.BLKB	2		; write: slection ligne + enableOMBRDET:.BLKB	2		; read: dtecteursOMBRRAZ:.BLKB	2		; read: rz dtecteursOACTIV:	.BLKB	2		; bits  1 -> cartes prsentesOMBREL:	.BLKB	MAXCARTES	; tats des relaisOMBDET:	.BLKB	MAXCARTES*2	; tats des dtecteursLGVAR:	.LOC	0DEBUT:	.W	0,S0BASE	.W	2^7; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;			DRIVER $TRAIN_0		No H'E0; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=S0ID:	.W	S0OPEN-S0BASE	.W	S0COMMAND-S0BASE	.W	-1			; S0RSTATUS-S0BASE	.W	S0READ-S0BASE	.W	S0WRITE-S0BASE	.W	S0CLOSE-S0BASE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	-1			; AVORTTR	.W	-1			; S0AUX1-S0BASE	.W	-1			; S0AUX2-S0BASE	.W	S0RESET-S0BASE	.W	S0KILL-S0BASE	.W	-1			; S0STRT-S0BASE	.W	-1			; S0TSTRT-S0BASE	.W	-1			; S0START-S0BASES0NAB:	.ASCII	"TRAIN_0"		; nom driverS0NAF:	.FILLB	LGDNAM-(S0NAF-S0NAB),0	.B	DRIVNUM			; numro driver	.B	TYPIO			; type streamer	.B	MAJREV,MINREV		; rvision - version	.B	0			; priorit	.B	0			; rserve	.B	0			; attribut 1	.B	2^BDWROK!2^BDRDOK!2^BDNORT ; attribut 0	.FILLB	LGDDESC-(.-S0ID),0	; le resteS0BASE:;--------\\; S0RESET >;========/; Initialisation du pilote.; in	-; out	A6.L	^variables globales;	D7.W	erreur; mod	D7.W, A6.LS0RESET:	PUSHM.L	D3..D5,A1,A3..A5	LOAD.L	A4,#R16"DEBUT	LOAD.L	D4,#LGVAR	FOS	?GETCOMMEM	; demande variables globales	JUMP,NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables globales	NTREL	?GETMACHINE	RL.L	D4,#8		; D4 <-- SMAKY*	COMP.B	D4,#SMAKY100	JUMP',EQ SM100$	COMP.B	D4,#SMAKY324	JUMP',EQ SM324$	COMP.B	D4,#SMAKY300	JUMP',EQ SM300$	LOAD.W	D7,#ERTMACH	; D7 <-- machine illgale !	JUMP	EXIT$SM100$:	LOAD.L	(A6)+OMBAD,#SM100ADMUBUS	LOAD.W	(A6)+OMBI,#2	JUMP'	INIT$SM324$:	LOAD.L	(A6)+OMBAD,#SM324ADMUBUS	LOAD.W	(A6)+OMBI,#1	JUMP'	INIT$SM300$:	LOAD.L	(A6)+OMBAD,#SM300ADMUBUS	LOAD.W	(A6)+OMBI,#1;	JUMP'	INIT$INIT$:	LOAD.W	D4,(A6)+OMBI	LOAD.W	D3,#MBWREL	MUL.WU	D3,D4	LOAD.W	(A6)+OMBWREL,D3	LOAD.W	D3,#MBWROW	MUL.WU	D3,D4	LOAD.W	(A6)+OMBWROW,D3	LOAD.W	D3,#MBWLINE	MUL.WU	D3,D4	LOAD.W	(A6)+OMBWLINE,D3	LOAD.W	D3,#MBRDET	MUL.WU	D3,D4	LOAD.W	(A6)+OMBRDET,D3	LOAD.W	D3,#MBRRAZ	MUL.WU	D3,D4	LOAD.W	(A6)+OMBRRAZ,D3;	LOAD.W	D4,(A6)+OMBI	SL.W	D4,#2	LOAD.W	(A6)+OMBI4,D4	CALL	INIT		; initialise tout	LOAD.W	D4,#PRIODET	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#100		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils de lecture des dtecteurs	JUMP',NE EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3..D5,A1,A3..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; S0OPEN  >;========/; Ouverture du pilote.; in	A6.L	^variables globales; out	D7.W	erreur; mod	D7.WS0OPEN:	CLR.W	D7		; D7 <-- ok	RET;--------\\; S0WRITE >;========/; Ecrit du data.; in	A6.L	^variables globales;	A4.L	^data;	D5.L	lg data; out	D7.W	erreur; mod	D7.WS0WRITE:	PUSHM.L	D3..D6,A4	LOAD.W	D7,#ERTIWLG	; D7 <-- longueur incorrecte	LOAD.L	D4,D5	DIV.WU	D4,#LDA	SWAP.W	D4	TEST.W	D4		; longueur multiple de LDA ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.L	D6,D5		; D6 <-- longueurLOOP$:	TEST.L	D6		; reste qq chose ?	JUMP,EQ OK$		; non => OK$	LOAD.W	D4,(A4)+ODACOM	; D4 <-- commande	COMP.W	D4,#H'100*'A+'B	JUMP',EQ AB$	COMP.W	D4,#H'100*'A+'C	JUMP',EQ AC$	COMP.W	D4,#H'100*'R+'L	JUMP',EQ RL$	LOAD.W	D7,#ERTICOM	; D7 <-- commande illgale	JUMP	EXIT$AB$:	LOAD.W	D3,(A4)+ODAUNI	; D3 <-- unit	LOAD.W	D4,(A4)+ODANUM	; D4 <-- valeur	LOAD.W	D5,(A4)+ODAPAR	; D5 <-- paramtres	CALL	WRITEAIGBBT	JUMP,NE EXIT$	JUMP'	NEXT$AC$:	LOAD.W	D3,(A4)+ODAUNI	; D3 <-- unit	LOAD.W	D4,(A4)+ODANUM	; D4 <-- valeur	LOAD.W	D5,(A4)+ODAPAR	; D5 <-- paramtres	CALL	WRITEAIGCCT	JUMP,NE EXIT$	JUMP'	NEXT$RL$:	LOAD.W	D3,(A4)+ODAUNI	; D3 <-- unit	LOAD.W	D4,(A4)+ODANUM	; D4 <-- valeur	LOAD.W	D5,(A4)+ODAPAR	; D5 <-- paramtres	CALL	WRITEREL	JUMP,NE EXIT$;	JUMP'	NEXT$NEXT$:	ADD.L	A4,#LDA		; A4 <-- ^data suivant	SUB.L	D6,#LDA	JUMP	LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3..D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; S0READ  >;========/; Lit du data.; in	A6.L	^variables globales;	A4.L	^data;	D5.L	lg data; out	D5.L	lg data lu;	D7.W	erreur; mod	D5.L, D7.WS0READ:	PUSHM.L	D3,D4,A4	LOAD.L	D4,D5		; D4 <-- lg  lire	CLR.L	D5		; D5 <-- lg lueLOOP$:	CALL	READDET		; D3 <-- unit actionne	JUMP',NE OK$	LOAD.W	(A4+),D3	; buffer <-- dtecteur lu	ADD.L	D5,#2		; D5 <-- lg lue	SUB.L	D4,#2		; D4 <-- lg restant  lire	JUMP,NE LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; S0CLOSE >;========/; Termine et ferme tout.; in	A6.L	^variables globales; out	D7.W	erreur; mod	D7.WS0CLOSE:	CLR.W	D7		; D7 <-- ok	RET;----------\\; S0COMMAND >;==========/; Excute une liste de commandes.; in	A6.L	^variables globales;	A4.L	^table des commandes termine par zro; out	D7.W	erreur; mod	D7.WS0COMMAND:	PUSHM.L	A4	CLR.W	D7		; D7 <-- okLOOP$:	TEST.B	(A4)		; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	CALL	WRONEC		; excute une commande	JUMP,EQ	LOOP$EXIT$:	POPM.L	A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRONEC  >;========/; Excute une commande.; in	A4.L	^commande; out	A4.L	^commande suivante;	D7.W	erreur; mod	D7.W, A4.LWRONEC:	PUSH.L	D4	LOAD.B	D4,(A4+)	; D4 <-- commande	COMP.B	D4,#'I	JUMP',EQ INIT$	LOAD.W	D7,#ERDIIL	; D7 <-- "commande illgale"	JUMP'	EXIT$INIT$:	CALL	INIT		; initialise tout	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; S0KILL  >;========/; Libration du pilote.; in	A6.L	^variables globales; out	D7.W	erreur; mod	D7.W, A6.LS0KILL:	CLR.W	D7		; retour EQ	RET;--------\\; INIT    >;========/; Initialise un peu tout.; in	-; out	-; mod	D7.WINIT:	PUSHM.L	D1..D4,A4	LOAD.L	A4,(A6)+OMBAD	; A4 <-- ^base de MUBUS	CLR.W	D3	CLR.W	D2LOOP$:	LOAD.W	D1,(A6)+OMBRRAZ	LOAD.B	D4,(A4)+(D1.W)	; rz des latches	LOAD.W	D1,(A6)+OMBRDET	LOAD.B	D4,(A4)+(D1.W)	; D4 <-- data lu dans les latches	COMP.B	D4,#-1		; carte existe ?	JUMP',EQ NEXT$		; non => NEXT$	TSET.L	D2:D3		; D2 <-- une carte prsente de plusNEXT$:	ADD.W	A4,(A6)+OMBI4	; A4 <-- ^adresse suivante	INC.W	D3	COMP.W	D3,#MAXCARTES	JUMP,LO LOOP$	LOAD.W	(A6)+OACTIV,D2	POPM.L	D1..D4,A4	RET;--------\\; READDET >;========/; Lit une entre quelconque.; in	-; out	D3.W	unit (0..255);	D7.W	erreur; mod	D7.WREADDET:	PUSHM.L	D0..D2,D4,A3,A4BEGIN$:	LOAD.L	A3,#(A6)+OMBDET	CLR.W	D3	LOAD.W	D2,(A6)+OACTIV	; D2 <-- cartes prsentesMLOOP$:	TEST.L	D2:D3		; carte prsente ?	JUMP',BC MNEXT$		; non => MNEXT$	TEST.B	(A3)+0		; data lu prcdemment ?	JUMP',NE DATA$		; oui => DATA$MNEXT$:	ADD.L	A3,#2		; A3 <-- ^data suivant	INC.W	D3	COMP.W	D3,#MAXCARTES	JUMP,LO MLOOP$	JUMP'	READ$DATA$:	CLR.W	D1		; D1 <-- bit  testerDLOOP$:	TCLR.B	(A3)+0:D1	; data lu ?	JUMP',BC DNEXT$		; non => DNEXT$	TSET.B	(A3)+1:D1	; dbut dynamique ?	JUMP',BC DOUT$		; oui => DOUT$DNEXT$:	INC.W	D1		; D1 <-- bit suivant	COMP.W	D1,#8	JUMP,LO DLOOP$	JUMP	MNEXT$DOUT$:	SL.W	D3,#3	ADD.W	D3,D1		; D3 <-- unit	CLR.W	D7	JUMP'	EXIT$READ$:	LOAD.L	A4,(A6)+OMBAD	; A4 <-- ^base de MUBUS	LOAD.L	A3,#(A6)+OMBDET	CLR.W	D3	LOAD.W	D2,(A6)+OACTIV	; D2 <-- cartes prsentes	CLR.W	D1RLOOP$:	TEST.L	D2:D3		; carte prsente ?	JUMP',BC RNEXT$		; non => RNEXT$	LOAD.W	D0,(A6)+OMBRDET	LOAD.B	D4,(A4)+(D0.W)	; D4 <-- lit les latches	LOAD.B	(A3)+0,D4	; mmorise le data lu	AND.B	(A3)+1,D4	; clear la dynamique si ncessaire	TEST.B	D4	JUMP',EQ RNEXT$	LOAD.W	D0,(A6)+OMBRRAZ	LOAD.B	D4,(A4)+(D0.W)	; rz les latches	INC.W	D1		; qq chose luRNEXT$:	ADD.W	A4,(A6)+OMBI4	; A4 <-- ^adresse suivante	ADD.L	A3,#2		; A3 <-- ^data suivant	INC.W	D3	COMP.W	D3,#MAXCARTES	JUMP,LO RLOOP$	TEST.W	D1	JUMP,NE BEGIN$	LOAD.W	D7,#ERTRNOD	; D7 <-- rien  lireEXIT$:	POPM.L	D0..D2,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; WRITEREL >;=========/; Bouge un relai pour un secteur.; in	D3.W	unit (0..255);	D4.W	data (0..1); out	D7.W	erreur; mod	D7.WWRITEREL:	PUSHM.L	D2..D4,A3,A4	LOAD.W	D7,#1		; D7 <-- erreur	LOAD.L	A3,#(A6)+OMBREL	LOAD.W	D2,D3	AND.W	D2,#H'0078	SR.W	D2,#3	ADD.W	A3,D2		; A3 <-- ^tat actuel	LOAD.L	A4,(A6)+OMBAD	; A4 <-- ^base de MUBUS	LOAD.W	D2,D3	AND.W	D2,#H'0078	SR.W	D2,#3	MUL.WU	D2,(A6)+OMBI4	ADD.W	A4,D2		; A4 <-- ^la bonne carte	COMP.W	D4,#2	JUMP',HS EXIT$	LOAD.W	D2,D3	AND.W	D2,#H'0007	; D2 <-- 0..7	LOAD.B	D3,(A3)		; D3 <-- tat actuel	TCLR.L	D3:D2	TEST.W	D4	JUMP',BC WRITE$	TSET.L	D3:D2WRITE$:	LOAD.W	D2,(A6)+OMBWREL	LOAD.B	(A4)+(D2.W),D3	LOAD.B	(A3),D3		; mj le nouvel tat actuel	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; WRITEAIGBBT >;============/; Bouge un aiguillage (BB).; in	D3.W	unit (0..255);	D4.W	data (0,1);	D5.W	dure [ms]; out	D7.W	erreur; mod	D7.WWRITEAIGBBT:	PUSH.L	D4	COMP.W	D4,#1	JUMP',EQ ACTION$	LOAD.W	D4,#2		; D4 <-- 1,2ACTION$:	CALL	WRITEAIGBB	; actionne	JUMP',NE EXIT$	LOAD.W	D4,D5	NTREL	?DELMS		; attend ...	CLR.W	D4	CALL	WRITEAIGBB	; reposEXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; WRITEAIGBB >;===========/; Ecrit une information d'aiguillage (BB).; in	D3.W	unit (0..255);	D4.W	data (0..2); out	D7.W	erreur; mod	D7.WWRITEAIGBB:	PUSHM.L	D0..D4,A4	LOAD.W	D7,#1		; D7 <-- erreur	LOAD.L	A4,(A6)+OMBAD	; A4 <-- ^base de MUBUS	LOAD.W	D2,D3	AND.W	D2,#H'00F0	SR.W	D2,#4	MUL.WU	D2,(A6)+OMBI4	ADD.W	A4,D2		; A4 <-- ^la bonne carte	DEC.W	D4	JUMP',NS ZERO$	COMP.W	D4,#2	JUMP',HS EXIT$	LOAD.W	D2,D3	AND.W	D2,#H'0003	; D2 <-- 0,1,2,3	SL.W	D2,#1		; D2 <-- 0,2,4,6	ADD.W	D2,D4	LOAD.B	D1,#-1	TCLR.L	D1:D2		; D1 <-- data slection colonne (ex. 11101111)	LOAD.W	D0,(A6)+OMBWROW	LOAD.B	(A4)+(D0.W),D1	LOAD.W	D2,D3	AND.W	D2,#H'000C	SR.W	D2,#2	LOAD.B	D1,#2^BENLINE!2^BENROW	TSET.L	D1:D2		; D1 <-- data slection ligne (ex. 0010)	LOAD.W	D0,(A6)+OMBWLINE	LOAD.B	(A4)+(D0.W),D1	JUMP'	OK$ZERO$:	LOAD.W	D0,(A6)+OMBWLINE	LOAD.B	(A4)+(D0.W),#0	LOAD.W	D0,(A6)+OMBWROW	LOAD.B	(A4)+(D0.W),#0OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; WRITEAIGCCT >;============/; Bouge un aiguillage (CC).; in	D3.W	unit (0..255);	D4.W	data (0,1);	D5.W	dure [ms]; out	D7.W	erreur; mod	D7.WWRITEAIGCCT:	PUSH.L	D4	INC.W	D4		; D4 <-- 1,2	CALL	WRITEAIGCC	; actionne	JUMP',NE EXIT$	LOAD.W	D4,D5	NTREL	?DELMS		; attend ...	CLR.W	D4	CALL	WRITEAIGCC	; reposEXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; WRITEAIGCC >;===========/; Ecrit une information d'aiguillage (CC).; in	D3.W	unit (0..255);	D4.W	data (0..2); out	D7.W	erreur; mod	D7.WWRITEAIGCC:	PUSHM.L	D1..D3,A3,A4	LOAD.W	D7,#1		; D7 <-- erreur	LOAD.L	A4,(A6)+OMBAD	; A4 <-- ^base de MUBUS	LOAD.W	D2,D3	AND.W	D2,#H'00F0	SR.W	D2,#4	MUL.WU	D2,(A6)+OMBI4	ADD.W	A4,D2		; A4 <-- ^la bonne carte	TEST.W	D4	JUMP,EQ ZERO$	LOAD.L	A3,#R16"TABLE$	AND.W	D3,#H'000F	SL.W	D3,#2	LOAD.W	D2,(A3)+(D3.W)+0 ; D2 <-- adresse	JUMP,EQ EXIT$	LOAD.W	D3,(A3)+(D3.W)+2 ; D3 <-- bit	COMP.W	D4,#2	JUMP',EQ INV$	COMP.W	D4,#1	JUMP,NE EXIT$NORM$:	COMP.W	D2,#MBWLINE	JUMP',EQ NLINE$	LOAD.W	D1,(A6)+OMBWROW	LOAD.B	(A4)+(D1.W),D3	LOAD.W	D1,(A6)+OMBWLINE	LOAD.B	(A4)+(D1.W),#2^BENLINE!2^BENROW	JUMP'	OK$NLINE$:	LOAD.W	D1,(A6)+OMBWROW	LOAD.B	(A4)+(D1.W),#B'00000000	OR.B	D3,#2^BENLINE!2^BENROW	LOAD.W	D1,(A6)+OMBWLINE	LOAD.B	(A4)+(D1.W),D3	JUMP'	OK$INV$:	COMP.W	D2,#MBWLINE	JUMP',EQ NINV$	NOT.B	D3	LOAD.W	D1,(A6)+OMBWROW	LOAD.B	(A4)+(D1.W),D3	LOAD.W	D1,(A6)+OMBWLINE	LOAD.B	(A4)+(D1.W),#B'1111!2^BENLINE!2^BENROW	JUMP'	OK$NINV$:	LOAD.W	D1,(A6)+OMBWROW	LOAD.B	(A4)+(D1.W),#B'11111111	NOT.B	D3	AND.B	D3,#B'00001111	OR.B	D3,#2^BENLINE!2^BENROW	LOAD.W	D1,(A6)+OMBWLINE	LOAD.B	(A4)+(D1.W),D3	JUMP'	OK$ZERO$:	LOAD.W	D1,(A6)+OMBWLINE	LOAD.B	(A4)+(D1.W),#0	LOAD.W	D1,(A6)+OMBWROW	LOAD.B	(A4)+(D1.W),#0OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D3,A3,A4	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	MBWROW,2^2	;  0: a1-a5	.W	MBWLINE,2^0	;  1: b1-a8	.W	MBWROW,2^1	;  2: a2-a3	.W	MBWLINE,2^1	;  3: a9-a16	.W	MBWROW,2^4	;  4: b9-b10	.W	MBWROW,2^3	;  5: a10-a14	.W	MBWROW,2^6	;  6: a17-b21	.W	MBWROW,2^5	;  7: b17-b19	.W	MBWLINE,2^2	;  8: a18-a24	.W	MBWLINE,2^3	;  9: a25-a32	.W	MBWROW,2^7	; 10: b25-b30	.W	0,0	.W	0,0	.W	0,0	.W	0,0	.W	0,0	.END