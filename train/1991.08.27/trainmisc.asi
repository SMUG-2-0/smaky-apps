	.SBTTL	TRAINMISC.ASI;--------\\; MINMAJ  >;========/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMINMAJ:	TEST.L	D3:#7		; code "supplmentaire" ?	JUMP',NE 20$		; oui => 20$	COMP.B	D3,#SPACE-2	; lettre accentue ?	JUMP',LO 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+70$  ; D3 <-- lettre majuscule	POP.W	D0	RET70$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4;;?	CLR.L	(A0)+ODFTPM	; annule XTRAME	RET;----------\\; OPEDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	-; out	-; mod	D7.WOPEDISMAT:	LOAD.L	(A6)+OSDDIS+ODFABS,(A0)+ODFABS	LOAD.W	(A6)+OSDDIS+ODFIIX,(A0)+ODFIIX	LOAD.W	(A6)+OSDDIS+ODFIIY,(A0)+ODFIIY	LOAD.L	(A6)+OSDDIS+ODFY,(A0)+ODFY	LOAD.L	(A6)+OSDDIS+ODFDY,(A0)+ODFDY	LOAD.L	(A6)+OSDDIS+ODFFY,(A0)+ODFFY	LOAD.L	(A6)+OSDDIS+ODFFDY,(A0)+ODFFDY	LOAD.L	(A6)+OSDDIS+ODFWBY,(A0)+ODFWBY	LOAD.L	(A6)+OSDDIS+ODFWEY,(A0)+ODFWEY	RET;----------\\; NEWDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	A4.L	^matrice o dessiner;	D4.L	^dimensions (dy;dx); out	-; mod	D7.WNEWDISMAT:	PUSH.L	D4	LOAD.L	(A0)+ODFABS,A4	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	LOAD.W	(A0)+ODFIIX,#1	SR.W	D4,#3	LOAD.W	(A0)+ODFIIY,D4	POP.L	D4	RET;----------\\; CLODISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.WCLODISMAT:	LOAD.L	(A0)+ODFABS,(A6)+OSDDIS+ODFABS	LOAD.W	(A0)+ODFIIX,(A6)+OSDDIS+ODFIIX	LOAD.W	(A0)+ODFIIY,(A6)+OSDDIS+ODFIIY	LOAD.L	(A0)+ODFY,(A6)+OSDDIS+ODFY	LOAD.L	(A0)+ODFDY,(A6)+OSDDIS+ODFDY	LOAD.L	(A0)+ODFFY,(A6)+OSDDIS+ODFFY	LOAD.L	(A0)+ODFFDY,(A6)+OSDDIS+ODFFDY	LOAD.L	(A0)+ODFWBY,(A6)+OSDDIS+ODFWBY	LOAD.L	(A0)+ODFWEY,(A6)+OSDDIS+ODFWEY	RET;--------\\; PUTANUM >;========/; Met un nombre dcimal dans un buffer.; in	D4.W	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	AND.L	D4,#H'FFFF	; D4 <-- nombre binaire	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	CLR.B	(A4)	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;========/; Donne un nombre dcimal.; OK jusqu' 32 bits !; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSHM.L	D2,D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	SL.L	D4,#1	LOAD.L	D2,D4	SL.L	D4,#2	ADD.L	D4,D2		; D4 <-- pousse d'un digit (*10)	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POPM.L	D2,D3	RET;--------\\; GETTIME >;========/; Donne le temps absolu.; in	-; out	D4.W	temps actuel (unit = 200ms); mod	D4.L, D7.WGETTIME:	PUSHM.L	D2,D3,D5	NTREL	?GETSYTIME	DIV.WU	D4,#200000/128	POPM.L	D2,D3,D5	RET; Gestion de la souris; --------------------;--------\\; MMENU   >;========/; Choix selon un mmenu.; in	A3.L	^mmenu;	D3.W	case initiale (0..n);	D4.L	cases grises; out	D3.W	case choisie  (0..n);	D7.W	erreur; mod	D3.L, D7.WMMENU:	PUSHM.L	D4,D5	PUSH.W	D3	CLR.W	D3	CALL	SELMO		; outil = flche	POP.W	D3	LOAD.L	D5,D4	CALL	IFMOUSE	EX.L	D4,D5	LIB	?MMENU		; choix selon mmenu ...	PUSH.W	D7	LOAD.L	D4,D5	CALL	PMOUSE	LOAD.W	D4,#2	NTREL	?DELMS		; attend positionnement !	POP.W	D7	POPM.L	D4,D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; CCMO    >;========/; Enlve la flche de la souris.; in	-; out	-; mod	-CCMO:	PUSHM.L	D3,D7	TEST.B	(A6)+OCCMO	JUMP',T EXIT$	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	SET.B	(A6)+OCCMOEXIT$:	POPM.L	D3,D7	RET;--------\\; SCMO    >;========/; Remet la flche de la souris.; in	-; out	-; mod	-SCMO:	PUSHM.L	D3,D7	TEST.B	(A6)+OCCMO	JUMP',F EXIT$	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	CLR.B	(A6)+OCCMOEXIT$:	POPM.L	D3,D7	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	ADD.W	D4,(A6)+OLUPX	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	ADD.W	D4,(A6)+OLUPY	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMOUSE  >;========/; Met la souris dans la fentre.; in	D4.L	position (y;x); out	-; mod	D7.WPMOUSE:	PUSH.L	D4	SUB.W	D4,(A6)+OLUPX	ADD.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A6)+OLUPY	ADD.W	D4,(A0)+ODFFY	SWAP.W	D4	LIB	?PMOUSE		; positionne la souris	POP.L	D4	RET;--------\\; SELMO   >;========/; Slectionne un nouveau lutin pour la souris.; in	D3.W	outil; out	-; mod	D7.WSELMO:	PUSHM.L	D2..D6,A2..A5	LOAD.W	D2,D3	CLR.W	D3		; D3 <-- flche	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE EXIT$	LOAD.L	D6,D4	SUB.W	D4,(A6)+OCELPX	JUMP',LO FOUND$	COMP.W	D4,(A6)+OCELDX	JUMP',HS FOUND$	SWAP.W	D4	SUB.W	D4,(A6)+OCELPY	JUMP',LO FOUND$	COMP.W	D4,(A6)+OCELDY	JUMP',HS FOUND$	LOAD.L	A3,#R16"TABLE$-8SRC$:	LOAD.L	A3,#(A3)+8	; A3 <-- ^suivant	TEST.W	(A3)		; fin de la table ?	JUMP',EQ FOUND$		; oui => FOUND$	COMP.W	D2,(A3)	JUMP,NE SRC$	LOAD.W	D3,(A3)+2FOUND$:	COMP.W	D3,(A6)+OLUTIN	; toujours le mme lutin ?	JUMP,EQ EXIT$		; oui => EXIT$	LOAD.W	(A6)+OLUTIN,D3	LOAD.L	A4,#0		; A4 <-- chair	LOAD.L	A5,#0		; A5 <-- fond	CLR.L	(A6)+OLUPY	TEST.W	D3		; est-ce la flche normale ?	JUMP',EQ INIT$		; oui => INIT$	LOAD.L	(A6)+OLUPY,(A3)+4	LOAD.L	A2,#(A6)+OLUMAM	TNOT.B	(A6)+OLUFLG:#BLUMAN	JUMP',BC BUFOK$	LOAD.L	A2,#(A6)+OLUMANBUFOK$:	CALL	CMOUTIL		; A4/A5 <-- chair/fondINIT$:	NTREL	?GETPRIO	LOAD.W	D5,D4		; D5 <-- priorit actuelle	LOAD.W	D4,#1	NTREL	?SETPRIO	; met une trs forte priorit	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	LOAD.L	(A3)+1,A4	; <ssss> matrice chair	LOAD.L	(A3)+5,A5	; <cccc> matrice fond	LOAD.W	D3,#9	LIB	?STRING	LOAD.L	D4,D6	CALL	PMOUSE		; positionne pour ne pas bouger la "pointe"	LOAD.W	D4,D5	NTREL	?SETPRIO	; remet la priorit initiale	LOAD.W	D4,#2	NTREL	?DELMS		; attend le changement/positionnement !EXIT$:	POPM.L	D2..D6,A2..A5	RETTABLE$:	.W	ICODRAW,ICODRAW,16,4	.W	ICOLOCO,ICOLOCO,8,8	.W	0;--------\\; CMOUTIL >;--------/; Construit la matrice d'un outil quelconque d'aprs; une icne contenue dans ITP17; La matrice construite possde un point de plus de tous; les cts, pour permettre un calcul correct de la matrice; automatique de fond.; in	D3.W	code de l'icne;	A2.L	^buffer pour matrice; out	A4.L	^dx,dy,matrice chair;	A5.L	^dx,dy,matrice fond; mod	D7.W, A4.L, A5.LCMOUTIL:	PUSHM.L	D1..D4,A3	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	A4,(A6)+OPGICO	; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D3	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^bonne matrice	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#32/8	; source: <ii>	LOAD.L	A4,(A6)+OPGICO	; A4 <-- ^gencar des icnes	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D2,#1+CELDIM+1	; D2 <-- hauteur	SWAP.W	D2	CLR.W	D2	LOAD.B	D2,(A4)+(D3.W)	ADD.W	D2,#1+1		; D2 <-- largeur	LOAD.W	D1,D2	ADD.W	D1,#8-1	SR.W	D1,#3		; D1 <-- largeur en bytes	LOAD.W	(A3)+12,#1	; destination: <xx>	LOAD.W	(A3)+14,#1	; destination: <yy>	LOAD.L	A4,A2		; A4 <-- ^buffer pour matrice	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,D1	; destination: <ii>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D440$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,40$	SUB.W	D2,#2	LOAD.W	(A3)+22,D2	; <dxx>	SWAP.W	D2	SUB.W	D2,#2	LOAD.W	(A3)+24,D2	; <dyy>	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne	LOAD.L	A4,A2		; A4 <-- ^dx,dy,matrice	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	POPM.L	D1..D4,A3	RET; Gestion du clavier; ------------------;----------\\; RACCOURCI >;==========/; Cherche un raccourci clavier.; in	D2.W	touche clavier; out	D3.W	icne;	D1.W	rang (0..n);	D7.W	erreur; mod	D1.L, D3.L, D7.WRACCOURCI:	PUSHM.L	A3	LOAD.W	D7,#1		; D7 <-- pas trouv	LOAD.L	A3,#R16"TRCMOD$-4	COMP.W	(A6)+OPALNIV,#ICOMOD	JUMP',EQ LOOP$	LOAD.L	A3,#R16"TRCDRAW$-4	COMP.W	(A6)+OPALNIV,#ICODRAW	JUMP',EQ LOOP$	LOAD.L	A3,#R16"TRCLOCO$-4LOOP$:	ADD.L	A3,#4		; A3 <-- ^suivant	TEST.W	(A3)		; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.W	D2,(A3)	JUMP,NE LOOP$	LOAD.W	D3,(A3)+2	; D3 <-- icne	CALL	ICORANG		; D1 <-- rang (0..n)	CLR.W	D7		; D7 <-- trouvEXIT$:	POPM.L	A3	TEST.W	D7		; retour EQ/NE	RETTRCMOD$:	.W	'F	ICOMOD	.W	'C	ICODRAW	.W	'L	ICOLOCO	.W	'G	ICOGRILLE	.W	'Z	ICOZOOM	.W	'P	ICOLOCOSTEP	.W	'D	ICOLOCOMOVE	.W	SPACE	ICOSTOP	.W	0TRCDRAW$:	.W	'F	ICOMOD	.W	'C	ICODRAW	.W	'L	ICOLOCO	.W	'G	ICOGRILLE	.W	'Z	ICOZOOM	.W	'-	ICORH	.W	'$	ICORV	.W	'!	ICORV	.W	'|	ICORV	.W	'E	ICORDR	.W	'T	ICORDL	.W	'X	ICORUR	.W	'V	ICORUL	.W	'B	ICORVIDE	.W	'S	ICORHS	.W	'D	ICORHR	.W	'I	ICORHC	.W	SPACE	ICOSTOP	.W	0TRCLOCO$:	.W	'F	ICOMOD	.W	'C	ICODRAW	.W	'L	ICOLOCO;;?	.W	'G	ICOGRILLE	.W	'Z	ICOZOOM	.W	'H	ICOLOCOU	.W	'B	ICOLOCOD	.W	'G	ICOLOCOL	.W	'D	ICOLOCOR	.W	'0	ICOLOCOW0	.W	'4	ICOLOCOW4	.W	'8	ICOLOCOW8	.W	SPACE	ICOSTOP	.W	0;--------\\; CLRFIFO >;========/; Vide le fifo du clavier.; in	-; out	-; mod	D7.WCLRFIFO:	PUSH.L	D3LOOP$:	LIB	?IFCAR	JUMP,EQ LOOP$	POP.L	D3	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	-; out	-; mod	-AFMENU:	PUSHM.L	D3,D7,A3	LOAD.L	A3,#R16"TXMENU$	LIB	?AFMENU	POPM.L	D3,D7,A3	RETTXMENU$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	"                 "	.ASCIZ	" Df.            "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"      Efface     "		;     ;     ;     ;	.EVEN	.END