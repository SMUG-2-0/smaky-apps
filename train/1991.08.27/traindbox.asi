	.SBTTL	TRAINDBOX.ASI;----------\\; DBOXPREND >;==========/; Demande un nom gnral  prendre.; in	-; out	A3.L	^nom;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.W, A3.LDBOXPREND:	PUSHM.L	D1,D2,D4,A2,A4,A5	CALL	DBOXOPEN1	LOAD.L	A5,#(A6)+OBUNAM	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_PREND	DBOX_	EXTEND	JUMP',NE EXIT$	LOAD.L	A3,A5		; A3 <-- ^nomEXIT$:	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXSAUVE >;==========/; Demande un nom gnral  sauver.; in	-; out	A3.L	^nom;	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.W, A3.LDBOXSAUVE:	PUSHM.L	D1,D2,D4,A2,A4,A5	CALL	DBOXOPEN1	LOAD.L	A5,#(A6)+OBUNAM	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_EXTRAIT	DBOX_	EXTEND	JUMP',NE EXIT$	LOAD.L	A3,A5		; A3 <-- ^nomEXIT$:	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXSIMAGE >;===========/; Demande un nom d'image  sauver.; in	-; out	A3.L	^nom;	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.W, A3.LDBOXSIMAGE:	PUSHM.L	D1,D2,D4,A2,A4,A5	CALL	DBOXOPEN1	LOAD.L	A5,#(A6)+OBUNIM	LOAD.L	A4,#R16"TEXT_IM	LOAD.L	A3,#R16"TDBOX_IM	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_EXTRAIT	DBOX_	EXTEND	JUMP',NE EXIT$	LOAD.L	A3,A5		; A3 <-- ^nomEXIT$:	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXSTEXT >;==========/; Demande un nom de texte  sauver.; in	-; out	A3.L	^nom;	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.W, A3.LDBOXSTEXT:	PUSHM.L	D1,D2,D4,A2,A4,A5	CALL	DBOXOPEN1	LOAD.L	A5,#(A6)+OBUNTX	LOAD.L	A4,#R16"TEXT_TX	LOAD.L	A3,#R16"TDBOX_TX	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1!2^BDBIOFULL	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_EXTRAIT	DBOX_	EXTEND	JUMP',NE EXIT$	LOAD.L	A3,A5		; A3 <-- ^nomEXIT$:	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXDETRUIT >;============/; Demande s'il faut dtruire.; in	A3.L	^nom; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXDETRUIT:	PUSHM.L	D1,D2,D4,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3	LOAD.L	A4,#R16"TEXT_IO	LOAD.L	A3,#R16"TDBOX_IO	CLR.L	D3	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.W	D1,#DBOX_DETRUIT	DBOX_	EXTENDEXIT$:	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer le dessin.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXEFFACE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	LOAD.L	A5,#(A6)+OBUNAM	; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Quitte le logiciel ?; in	-; out	D3.W	F1/F4; mod	D7.WDBOXQUITTE:	PUSHM.L	D0..D2,D4..D6,A3..A5	CALL	DBOXOPEN1	LOAD.W	D1,#DBOX_QUITTE	LOAD.L	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	DBOX_	EXTEND		; demande s'il faut quitter ...	CALL	DBOXCLOSE1	POPM.L	D0..D2,D4..D6,A3..A5	RET;----------\\; DBOXCOLOR >;==========/; Choix des couleurs.; in	-; out	D7.W	erreur; mod	D7.WDBOXCOLOR:	PUSHM.L	D3..D5,A3..A5	LOAD.L	A3,#R16"NMTRAIN	LOAD.L	A5,#R16"TCOUL	LOAD.L	D5,(A6)+OIDCRET	LOAD.L	D4,#2^BICMPAL	; D4 <-- mode local	ICOL_	MODCRET		; modifie la CRET ...	PUSH.W	D7	CALL	DBOXCLOSE1	; refait les soft-keys	POP.W	D7	JUMP',NE EXIT$	LOAD.L	(A6)+OIDCRET,D5	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3..D5,A3..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXCEL >;========/; Modifie une cellule.; in	D1.W	rang cellule  modifier (0..n); out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCEL:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D0,D1		; D0 <-- rang	CALL	CELGETP		; A4 <-- ^cellule	JUMP,NE EXIT$	LOAD.B	D3,(A4)+OCEICO	; D3 <-- icne de la cellule	CALL	CELTXTYPE	; A3 <-- ^type	JUMP,NE EXIT$	LOAD.W	(A6)+ODBPA1,(A4)+OCEUNI	CLR.W	(A6)+ODBPA2	LOAD.B	(A6)+ODBPA2+1,(A4)+OCEPOR	CLR.W	(A6)+ODBPA3	LOAD.B	(A6)+ODBPA3+1,(A4)+OCEPAR	CLR.B	(A6)+ODBPAT	TEST.L	(A4)+OCEPNM	JUMP',EQ FAN$	LOAD.L	A2,(A4)+OCEPNM	LOAD.L	A1,#(A6)+ODBPATINAME$:	LOAD.B	(A1+),(A2+)	; ODBPAT <-- nom	JUMP,NE INAME$FAN$:	CLR.L	D4	LOAD.B	D4,(A4)+OCEFAN	; D4 <-- fanions	LOAD.W	D3,D4	AND.W	D3,#2^BCEFMBB!2^BCEFMCC!2^BCEFREL	JUMP',NE DEF$	TSET.L	D4:#BCEFMBBDEF$:	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	; mj ^table dbox	LOAD.L	A2,#R16"TDBOX_CEL	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche le type de la cellule	POP.L	D4	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#4	JUMP,LO AFF$	CLR.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	DBOXZEROCR	; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_CEL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#DEFINE	JUMP',EQ SEARCH$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#4	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$SEARCH$:			; DEFINE =>	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.W	D3,(A6)+ODBPA1	CALL	DBCESEARCH	; D3 <-- premier numro libre	LOAD.W	(A6)+ODBPA1,D3	CLR.W	D2	JUMP	NLINE$CLIC$:	CALL	DBOXCLIC	JUMP,EQ NLINE$	JUMP	BIP$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	BIP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$EXIST$:	LOAD.W	D7,D3	CALL	DBOXERROR	; affiche une erreur ...	LOAD.L	A2,#R16"TDBOX_CEL	CALL	DBOXRSK		; remet les soft-keys	JUMP	NLINE$OK$:	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.W	D1,D0		; D1 <-- rang	CALL	CELGETP		; A4 <-- ^cellule	JUMP,NE END$	TEST.W	(A6)+ODBPA1	JUMP',EQ OK4$	PUSH.W	(A4)+OCEUNI	CLR.W	(A4)+OCEUNI	PUSH.L	A4	LOAD.W	D3,(A6)+ODBPA1	CALL	GETPTCEL	; A4/D1 <-- ^cellule/rang	POP.L	A4	POP.W	(A4)+OCEUNI	CLR.W	D2	LOAD.W	D3,#ERMUUSE	TEST.W	D7	JUMP,EQ EXIST$OK4$:	TEST.B	(A6)+ODBPAT	JUMP',EQ OK5$	CALL	DBCEPSYN	; syntaxe du nom correcte ?	LOAD.W	D2,#1	LOAD.W	D3,D7	JUMP,NE EXIST$	PUSH.L	(A4)+OCEPNM	CLR.L	(A4)+OCEPNM	PUSH.L	A4	LOAD.L	A3,#(A6)+ODBPAT	CALL	ALGONAMEPC	; A4/D1 <-- ^cellule/rang	POP.L	A4	POP.L	(A4)+OCEPNM	LOAD.W	D2,#1	LOAD.W	D3,#ERMNUSE	TEST.W	D7	JUMP,EQ EXIST$OK5$:	CALL	DBCEPNAM	; cellule <-- nom	LOAD.W	(A4)+OCEUNI,(A6)+ODBPA1	LOAD.B	(A4)+OCEPOR,(A6)+ODBPA2+1	LOAD.B	(A4)+OCEPAR,(A6)+ODBPA3+1	LOAD.B	(A4)+OCEFAN,D4	LOAD.W	D3,#F1		; D3 <-- D'ACCORDEND$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBPA1,DBTYPN,0,MAXUNIT,1,2^BDBGCLABEL!100,0,3+2	.W	ODBPAT,DBTYPA,0,0,0,2^BDBGCLABEL!101,1,20	.W	ODBPA2,DBTYPN,0,255,1,2^BDBGCLABEL!102,2,3+2	.W	ODBPA3,DBTYPN,0,50,1,2^BDBGCLABEL!103,3,3+2	.W	-1;-----------\\; DBCESEARCH >;-----------/; Cherche un numro inutilis.; in	D0.W	rang cellule;	D3.W	numro actuel; out	D3.W	numro inutilis; mod	D3.L, D7.WDBCESEARCH:	PUSHM.L	D1,D4,A4BEGIN$:	LOAD.L	A4,(A6)+OPCEL	LOAD.W	D4,(A6)+OCELNX	MUL.WU	D4,(A6)+OCELNY	DEC.W	D4		; D4 <-- -1  cause NMO	CLR.W	D1LOOP$:	COMP.W	D1,D0	JUMP',EQ NEXT$	COMP.W	D3,(A4)+OCEUNI	JUMP',EQ OTHER$NEXT$:	INC.W	D1		; D1 <-- rang suivant	LOAD.L	A4,#(A4)+LCE	; A4 <-- ^cellule suivante	DECJ.W,NMO D4,LOOP$	JUMP'	EXIT$OTHER$:	INC.W	D3		; D3 <-- numro suivant	JUMP	BEGIN$EXIT$:	POPM.L	D1,D4,A4	RET;---------\\; DBCEPSYN >;---------/; Vrifie si la syntaxe du nom est correcte.; in	-; out	D7.W	erreur; mod	D7.WDBCEPSYN:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+ODBPAT	LOAD.B	D3,(A3)	CALL	MINMAJ	COMP.B	D3,#'A		; commence par une lettre ?	JUMP',LO SYNT$		; non => SYNT$	COMP.B	D3,#'Z	JUMP',HI SYNT$LOOP$:	LOAD.B	D3,(A3+)	JUMP',EQ OK$	COMP.B	D3,#SPACE	JUMP',NE NOSP$	LOAD.B	(A3)-1,#'_	JUMP	LOOP$NOSP$:	CALL	MINMAJ	COMP.B	D3,#'_	JUMP,EQ LOOP$	COMP.B	D3,#'.	JUMP,EQ LOOP$	COMP.B	D3,#'0	JUMP',LO SYNT$	COMP.B	D3,#'9	JUMP,LS LOOP$	COMP.B	D3,#'A	JUMP',LO SYNT$	COMP.B	D3,#'Z	JUMP,LS LOOP$SYNT$:	LOAD.W	D7,#ERMSALO	; D7 <-- erreur de syntaxe	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBCEPNAM >;---------/; Met  jour le nom dans la cellule.; in	A4.L	^cellule; out	-; mod	D7.WDBCEPNAM:	PUSHM.L	D1,D3,D4,A2..A4	LOAD.L	A2,A4		; A2 <-- ^cellule	TEST.L	(A2)+OCEPNM	; ancien nom existe ?	JUMP',EQ NEW$		; non => NEW$	LOAD.L	A4,(A2)+OCEPNM	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le nom	CLR.L	(A2)+OCEPNMNEW$:	TEST.B	(A6)+ODBPAT	; nouveau nom existe ?	JUMP',EQ OK$		; non => OK$	LOAD.L	A3,#(A6)+ODBPAT	CLR.L	D4LG$:	INC.W	D4		; D4 <-- lg du nom	TEST.B	(A3+)	JUMP,NE LG$	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouveau nom	JUMP',NE EXIT$	LOAD.L	(A2)+OCEPNM,A4	LOAD.L	A3,#(A6)+ODBPATLOOP$:	LOAD.B	(A4+),(A3+)	JUMP,NE LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CEL:	.W	10$-TDBOX_CEL	.W	20$-TDBOX_CEL	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Type de l'objet :      "	.B	ODBLABEL,1	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Numro de l'objet :   $"	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,DEFINE,TDBNORM	.ASCIZ	" CHERCHE "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Nom de l'objet :       "	.B	ODBLABEL,101	.B	ODBXLINE,20,LGNOM-1,0,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Port physique :        "	.B	ODBLABEL,102	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Dure :                "	.B	ODBLABEL,103	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBTEXT	.ASCIZ	"  [20ms]"	.B	ODBCR,ODBCR2	.B	ODBSQUARE,BCEFINV	.ASCIZ	" action inverse"	.B	ODBTABX,23	.B	ODBLCIRCLE,BCEFMBB	.ASCIZ	" 2 bobines [A]"	.B	ODBCR	.B	ODBTABX,23	.B	ODBLCIRCLE,BCEFMCC	.ASCIZ	" 1 bobine  [A]"	.B	ODBCR	.B	ODBTABX,23	.B	ODBLCIRCLE,BCEFREL	.ASCIZ	" relais    [S]"	.B	ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CEL:	.W	F1,F2,F3,0		DOKF1-TKEY_CEL	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CEL	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_CEL	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CEL	.W	0;--------\\; DBOXDEF >;========/; Dfinitions gnrales.; in	-; out	D4.L	nouvelles dimensions (dy;dx);	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D4.L, D3.L, D7.WDBOXDEF:	PUSHM.L	D0..D2,D5,A1..A4	LOAD.W	(A6)+ODBPA1,(A6)+OCELNX	LOAD.W	(A6)+ODBPA2,(A6)+OCELNY	LOAD.W	(A6)+ODBPA3,(A6)+ODDEL	LOAD.W	(A6)+ODBPA4,(A6)+OLVIT	LOAD.L	D4,(A6)+OFAN	; D4 <-- fanions	JUMP',NE FAN$	LOAD.L	D4,#2^BFFRANFAN$:	TNOT.L	D4:#BFNHIC	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	; mj ^table dbox	LOAD.L	A2,#R16"TDBOX_DEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#4	JUMP,LO AFF$	CLR.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	DBOXZEROCR	; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_DEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#4	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$CLIC$:	CALL	DBOXCLIC	JUMP,EQ NLINE$	JUMP	BIP$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	BIP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$OK$:	CALL	DBOXPUT	JUMP,NE BIP$	TNOT.L	D4:#BFNHIC	LOAD.L	(A6)+OFAN,D4	LOAD.W	(A6)+OLVIT,(A6)+ODBPA4	LOAD.W	(A6)+ODDEL,(A6)+ODBPA3	LOAD.W	D4,(A6)+ODBPA2	SWAP.W	D4	LOAD.W	D4,(A6)+ODBPA1	CALL	MUBUSCOMMAND	; met le bon modeEND$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBPA1,DBTYPN,0,200,1,2^BDBGCLABEL!100,0,3+2	.W	ODBPA2,DBTYPN,0,200,1,2^BDBGCLABEL!101,1,3+2	.W	ODBPA3,DBTYPN,1,255,10,2^BDBGCLABEL!102,2,3+2	.W	ODBPA4,DBTYPN,1,10,1,2^BDBGCLABEL!103,3,3+2	.W	-1TDBOX_DEF:	.W	10$-TDBOX_DEF	.W	20$-TDBOX_DEF	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Nombre de cellules  H="	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"   V="	.B	ODBLABEL,101	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBCR,ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Dlai dtecteurs :    "	.B	ODBLABEL,102	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBTEXT	.ASCIZ	"  [20ms]"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Dlai locomotives :   "	.B	ODBLABEL,103	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBCR,ODBCR	.B	ODBSQUARE,BFMBL	.ASCIZ	" adapteur MUBUS-LONG"	.B	ODBTABX,26	.B	ODBLCIRCLE,BFFRAN	.ASCIZ	" scripts en franais"	.B	ODBCR	.B	ODBSQUARE,BFNHIC	.ASCIZ	" aide dans les icnes"	.B	ODBTABX,26	.B	ODBLCIRCLE,BFANGL	.ASCIZ	" scripts en anglais"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEF:	.W	F1,F2,F3,0		DOKF1-TKEY_DEF	.W	F0,F13,F14,F15,0	DOKF0-TKEY_DEF	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_DEF	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEF	.W	0;----------\\; DBOXERROR >;==========/; Affiche une erreur.; in	D7.W	erreur; out	D7.W	erreur; mod	D7.WDBOXERROR:	PUSHM.L	D2..D4,A3	LOAD.W	D4,D7	JUMP',EQ OK$	COMP.W	D7,#ERKNO	JUMP',EQ OK$	COMP.W	D7,#ERKSTO	JUMP',NE OPEN$OK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$OPEN$:	CALL	DBOXOPEN1	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	CALL	DBERTEXT	; A3 <-- ^message interne  TRAIN	JUMP',EQ INTERN$	LOAD.W	D7,D4		; D7 <-- code de l'erreur	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur "externe" ...	JUMP'	CLOSE$INTERN$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur "interne" ...CLOSE$:	CALL	DBOXCLOSE1	; remet les soft-keysEXIT$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBERTEXT >;---------/; Donne le texte d'une erreur interne  TRAIN.; in	D4.W	erreur; out	A3.L	^message d'erreur;	D7.W	erreur; mod	D7.W, A3.LDBERTEXT:	PUSH.L	D3	LOAD.W	D7,#1		; D7 <-- pas trouv	LOAD.W	D3,D4	SR.W	D3,#8	COMP.B	D3,#ERTRAIN/H'100 ; erreur interne  TRAIN ?	JUMP',NE EXIT$		; non => EXIT$				; oui =>	LOAD.L	A3,#R16"TABLE$LOOP$:	TEST.W	(A3+)		; fin de la table ?	JUMP',EQ OK$		; oui => OK$	COMP.W	D4,(A3)-2	; erreur trouve ?	JUMP',EQ OK$		; oui => OK$NEXT$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE	NEXT$	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- saute comme .EVEN	LOAD.L	A3,D3	JUMP	LOOP$OK$:	CLR.W	D7		; D7 <-- trouvEXIT$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	ERMFILE	.ASCIZ	/Fichier incompatible !/	.EVEN	.W	ERMEMPTY	.ASCIZ	/Fifo vide !/	.EVEN	.W	ERMFULL	.ASCIZ	/Fifo plein !/	.EVEN	.W	ERMPROC	.ASCIZ	/Processeur absent !/	.EVEN	.W	ERMUNIT	.ASCIZ	/Objet inexistant !/	.EVEN	.W	ERMEVENT	.ASCIZ	/Evnement incorrect !/	.EVEN	.W	ERMNDDET	.ASCII	/Rception d'un vnement correspondant<CR>/	.ASCIZ	/ un dtecteur inexistant !/	.EVEN	.W	ERMUUSE	.ASCIZ	/Numro d'objet dj utilis !/	.EVEN	.W	ERMULOK	.ASCIZ	/Objet bloqu !/	.EVEN	.W	ERMNUSE	.ASCIZ	/Nom d'objet dj utilis !/	.EVEN	.W	ERMSYNT	.ASCIZ	/Erreur de syntaxe !/	.EVEN	.W	ERMSALO	.ASCIZ	/"ALORS" attendu !/	.EVEN	.W	ERMSASS	.ASCIZ	/":=" attendu !/	.EVEN	.W	ERMSEOL	.ASCIZ	/Fin de ligne attendue !/	.EVEN	.W	ERMSUNI	.ASCII	/Objet attendu !<CR>/	.ASCIZ	/Par exemple "$10"/	.EVEN	.W	ERMSVAL	.ASCII	/Valeur attendue !<CR>/	.ASCIZ	/Par exemple "0", "Stop" ou "$10"/	.EVEN	.W	ERMSPAO	.ASCIZ	/"(" attendu !/	.EVEN	.W	ERMSPAF	.ASCIZ	/"," ou ")" attendu !/	.EVEN	.W	ERMLOCO	.ASCII	/Les locomotives disponibles/	.ASCIZ	/sont dj toutes utilises !/	.EVEN	.W	ERMCOLL	.ASCIZ	/Collision entre deux locomotives !/	.EVEN	.W	0	.ASCIZ	/Erreur avec le logiciel TRAIN !/	.EVENTEXT_IO:.ASCIZ	".TRAIN"TEXT_IM:.ASCIZ	".IMAGE"TEXT_TX:.ASCIZ	".TEXT"	.EVEN	.END