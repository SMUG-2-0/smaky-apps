	.SBTTL	TRAINHELP.ASI;---------\\; HELPTEXT >;=========/; Affiche le texte d'aide d'une icne dans la fentre.; in	D3.W	icne;	D4.L	position (y;x); out	-; mod	D7.WHELPTEXT:	PUSHM.L	D3,D4,A3	TEST.B	(A6)+OFAN+3:#BFNHIC-0	JUMP',BS EXIT$	TEST.L	(A6)+OPHELP	; fichier d'aide charg ?	JUMP',EQ EXIT$		; non => EXIT$	TEST.W	D3	JUMP',EQ EXIT$	CALL	HELPSEARCH	; A3 <-- ^texte	LOAD.L	D3,D4		; D3 <-- position	CALL	HELPAFF		; affiche le texteEXIT$:	POPM.L	D3,D4,A3	RET;--------\\; HELPAFF >;--------/; Affiche le texte d'aide d'une icne dans la fentre.; in	D3.L	position (y;x);	A3.L	^texte; out	D7.W	erreur; mod	D7.WHELPAFF:	PUSHM.L	D0..D4,A3,A4	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF; Calcule la position des 5 points de la "flche".	LOAD.L	(A6)+OHP0,D3	; OHP0 <-- pointe de la flche	LOAD.L	D2,D3	CALL	HELPNBXY	; D4 <-- ny;nx	LOAD.W	D3,D4	MUL.WU	D3,(A0)+ODFCX	ADD.W	D3,#10+10	; D3 <-- largeur	SWAP.W	D4	MUL.WU	D4,(A0)+ODFCY	ADD.W	D4,#10+10	; D4 <-- hauteur	SR.W	D4,#1	SWAP.W	D2	ADD.W	D2,D4	ADD.W	D2,#5	COMP.W	D2,(A0)+ODFDY	JUMP',LO MAXY$	LOAD.W	D2,(A0)+ODFDYMAXY$:	SUB.W	D2,#5	SUB.W	D2,D4	SUB.W	D2,D4	SUB.W	D2,#5	JUMP',NC MINY$	CLR.W	D2MINY$:	ADD.W	D2,#5	LOAD.W	(A6)+OHP1+0,D2	LOAD.W	(A6)+OHP2+0,D2	ADD.W	D2,D4	ADD.W	D2,D4	LOAD.W	(A6)+OHP3+0,D2	LOAD.W	(A6)+OHP4+0,D2	SWAP.W	D2	ADD.W	D2,#20	LOAD.W	(A6)+OHP1+2,D2	LOAD.W	(A6)+OHP4+2,D2	ADD.W	D2,D3	LOAD.W	(A6)+OHP2+2,D2	LOAD.W	(A6)+OHP3+2,D2; Affiche la flche en effaant dessous puis en mettant un cadre.	CALL	HELPOPEN	; sauve l'cran	LOAD.L	D3,#H'10000*COLORFHELP+COLORCHELP	CALL	DESCOLOR	CLR.L	D4	CALL	DRMDEF		; trame pour effacer	CALL	DRPOLYOPEN	JUMP,NE COUT$	LOAD.L	D3,(A6)+OHP0	LOAD.L	D4,(A6)+OHP1	CALL	DRPOLYLINE	JUMP,NE COUT$	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP2	CALL	DRPOLYLINE	JUMP,NE COUT$	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP3	CALL	DRPOLYLINE	JUMP,NE COUT$	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP4	CALL	DRPOLYLINE	JUMP,NE COUT$	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP0	CALL	DRPOLYLINE	JUMP,NE COUT$	LOAD.W	D2,#CLRDOT	CALL	DRPOLYCLOSE	; efface l'intrieur	JUMP',NE COUT$	LOAD.W	D2,#SETDOT	LOAD.L	D3,(A6)+OHP0	LOAD.L	D4,(A6)+OHP1	CALL	DRLINE	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP2	CALL	DRLINE	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP3	CALL	DRLINE	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP4	CALL	DRLINE	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP0	CALL	DRLINE		; dessine le cadre	CLR.W	D7COUT$:	TEST.W	D7	JUMP,NE EXIT$; Affiche le texte dans la flche.	LOAD.B	(A0)+ODFMCA,#SETDOT!PENDOT ; dessine seulement la chair	LOAD.L	D4,#-1	CALL	DRMDEF		; trame pour inverser	LOAD.L	D1,(A6)+OHP1	ADD.W	D1,#10	SWAP.W	D1	ADD.W	D1,#10	ADD.W	D1,(A0)+ODFC1Y	SWAP.W	D1	CLR.W	D0		; D0 <-- style roman et normal	LOAD.L	A4,A3LOOP$:	LOAD.L	(A0)+ODFPY,D1	; met le curseur au dbut de la ligneLOOP2$:	LOAD.L	A3,A4		; A3 <-- ^dbut  afficher	CLR.W	D3		; D3 <-- nb de caractres  afficherCNT$:	LOAD.B	D4,(A4)	JUMP',EQ CNT2$	INC.L	A4	COMP.B	D4,#CR	JUMP',EQ CNT2$	COMP.B	D4,#-1	JUMP',EQ CNT2$	COMP.B	D4,#-4	JUMP',EQ CNT2$	INC.W	D3		; D3 <-- un caractre de plus	JUMP	CNT$CNT2$:	TEST.W	D3	JUMP,EQ SPEC$	LOAD.L	D2,(A0)+ODFPY	; D2 <-- position dbut de la ligne	LIB	?STRING		; affiche une ligne	TEST.L	D0:#0		; affiche en bold ?	JUMP',BC CADRE$		; non => CADRE$				; oui =>	PUSH.L	(A0)+ODFPY	INC.W	D2	LOAD.L	(A0)+ODFPY,D2	; positionne avec un dcalage en X de 1	LIB	?STRING		; affiche en gras	POP.L	(A0)+ODFPYCADRE$:	TEST.L	D0:#1		; affiche en inverse ?	JUMP',BC SPEC$		; non => SPEC$				; oui =>	PUSH.L	D4	LOAD.L	D3,D2	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,#3	SWAP.W	D3	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#3	SWAP.W	D4	LOAD.W	D4,(A0)+ODFPX	SUB.W	D4,D3	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse tout le texte affich	POP.L	D4SPEC$:	TEST.B	D4		; encore qq chose ?	JUMP',EQ END$		; non => END$	COMP.B	D4,#-1		; commande roman/bold ?	JUMP',EQ BOLD$		; oui => BOLD$	COMP.B	D4,#-4		; commande normal/inv ?	JUMP',NE NLINE$		; non => NLINE$	TNOT.L	D0:#1		; D0 <-- passe de normal  invBOLD$:	TNOT.L	D0:#0		; D0 <-- passe de roman  bold	JUMP	LOOP2$NLINE$:	SWAP.W	D1	ADD.W	D1,(A0)+ODFCY	; D1 <-- position dbut ligne suivante	SWAP.W	D1	JUMP	LOOP$END$:	LOAD.B	(A0)+ODFMCA,#LOADDOT!PENDOT ; dessine seulement la chair	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D0..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; HELPNBXY >;---------/; Calcule le nombre de lignes/colonnes dans le texte donn en entre.; in	A3.L	^texte; out	D4.L	nb de lignes/colonnes (ny;nx); mod	D4.L, D7.WHELPNBXY:	PUSHM.L	D2,D3,A3	LOAD.L	D4,#H'FFFF0000	; D4 <-- (dy;dx)CNTY$:	ADD.L	D4,#H'10000	; D4 <-- une ligne de plus (+dy)	CLR.W	D2CNTX$:	LOAD.B	D3,(A3+)	JUMP,NS CNTX$		; ignore les AFINV, AFDIR, etc.	JUMP',EQ CNT3$	INC.W	D2		; D2 <-- une colonne de plus (+dx)	COMP.B	D3,#CR	JUMP,NE CNTX$	DEC.W	D2CNT3$:	COMP.W	D4,D2	JUMP',HS CNT4$	LOAD.W	D4,D2		; D4 <-- ligne la plus large (>dx)CNT4$:	TEST.B	D3	JUMP,NE CNTY$	POPM.L	D2,D3,A3	RET;---------\\; HELPOPEN >;---------/; Sauve une partie de l'cran.; in	-; out	D7.W	erreur; mod	D7.WHELPOPEN:	PUSHM.L	D1..D6,A2..A4	LOAD.W	D2,(A6)+OHP2+2	SUB.W	D2,(A6)+OHP0+2	INC.W	D2		; D2 <-- largeur	LOAD.W	D4,D2	ADD.W	D4,#16-1	SR.W	D4,#3+1	SL.W	D4,#1	TEST.B	(A0)+ODFCMD	JUMP',EQ NOCOUL$	SL.W	D4,#2		; D4 <-- largeur *4NOCOUL$:	LOAD.W	D6,D4		; D6 <-- largeur en bytes	SWAP.W	D2	LOAD.W	D2,(A6)+OHP4+0	SUB.W	D2,(A6)+OHP1+0	INC.W	D2		; D2 <-- hauteur	MUL.WU	D4,D2	SWAP.W	D2	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP',NE EXIT$	LOAD.L	(A6)+OHPSAV,A4	CALL	CCMO		; enlve la souris	LOAD.L	D3,(A6)+OHP1	LOAD.W	D3,(A6)+OHP0+2	; D3 <-- position source	LOAD.L	A3,#0		; A3 <-- ^source (dans l'cran)	CLR.L	D4	LOAD.L	A2,A0	TEST.B	(A0)+ODFCMD	JUMP',NE COUL$	LOAD.W	D1,#LOADDOT	GRA_	RASTER		; sauve l'cran	JUMP'	OK$COUL$:	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	GRA_	CRASTER		; sauve l'cran couleurOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; HELPCLOSE >;----------/; Restitue l'cran.; in	-; out	-; mod	D7.WHELPCLOSE:	PUSHM.L	D1..D6,A2..A4	TEST.L	(A6)+OHPSAV	; y a-t-il qq chose de sauv ?	JUMP,EQ EXIT$		; non => EXIT$	CALL	CCMO		; enlve la souris	LOAD.W	D2,(A6)+OHP4+0	SUB.W	D2,(A6)+OHP1+0	INC.W	D2		; D2 <-- hauteur	SWAP.W	D2	LOAD.W	D2,(A6)+OHP2+2	SUB.W	D2,(A6)+OHP0+2	INC.W	D2		; D2 <-- largeur	LOAD.W	D5,D2	ADD.W	D5,#16-1	SR.W	D5,#3+1	SL.W	D5,#1		; D5 <-- largeur en bytes	TEST.B	(A0)+ODFCMD	JUMP',EQ NOCOUL$	SL.W	D5,#2		; D5 <-- largeur *4NOCOUL$:	CLR.L	D3	LOAD.L	A3,(A6)+OHPSAV	LOAD.L	D4,(A6)+OHP1	LOAD.W	D4,(A6)+OHP0+2	; D4 <-- position destination	LOAD.L	A4,#0		; A4 <-- ^destination (dans l'cran)	LOAD.L	A2,A0	TEST.B	(A0)+ODFCMD	JUMP',NE COUL$	LOAD.W	D1,#LOADDOT	GRA_	RASTER		; restitue l'cran	JUMP'	GIVE$COUL$:	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	GRA_	CRASTER		; restitue l'cran couleurGIVE$:	LOAD.L	A4,(A6)+OHPSAV	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OHPSAV	; y'a plus rien de sauv !EXIT$:	POPM.L	D1..D6,A2..A4	RET;-----------\\; HELPSEARCH >;===========/; Cherche le texte correspondant  une icne.; in	D3.W	icne; out	A3.L	^texte correspondant; mod	D7.W, A3.LHELPSEARCH:	PUSHM.L	D0..D4,A4; Cherche le texte d'une icne standard.	TEST.L	(A6)+OPHELP	JUMP',EQ ERROR$	LOAD.L	A3,(A6)+OPHELP	; A3 <-- ^fichier d'aide	LOAD.W	D4,(A3)+8	; D4 <-- ^relatif	ADD.W	A3,D4		; A3 <-- ^dbut de la tableLOOP$:	LOAD.W	D4,(A3+)	JUMP',EQ ERROR$	COMP.W	D3,D4	JUMP',EQ OK$NEXT$:	TEST.B	(A3+)		; A3 <-- ^texte suivant	JUMP,NE NEXT$	LOAD.L	D4,A3	TEST.L	D4:#0	JUMP,BC LOOP$	INC.L	A3		; A3 <-- saute le .EVEN	JUMP	LOOP$ERROR$:	LOAD.L	A3,#R16"TXERR$	; A3 <-- ^texte si rien trouv d'autreOK$:	POPM.L	D0..D4,A4	RETTXERR$:	.ASCII	"<-1>Montrez une icne<-1><CR>"	.ASCII	"avec la souris ...<CR>"	.B	0	.EVEN;---------\\; HELPLOAD >;=========/; Charge le fichier d'aide si ncessaire.; in	-; out	D7.W	erreur; mod	D7.WHELPLOAD:	PUSHM.L	D3,D4,A3,A4	TEST.L	(A6)+OPHELP	; fichier dj charg ?	JUMP',NE OK$		; oui => OK$	LOAD.L	A3,#R16"NMHELP	LOAD.L	D3,#2^BEXNHEAD	FOS	?CLOAD		; A4/D4 <-- ^fichier/lg	JUMP',NE EXIT$	LOAD.L	(A6)+OPHELP,A4OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; HELPUNLOAD >;===========/; Dcharge le fichier d'aide si ncessaire.; in	-; out	-; mod	D7.WHELPUNLOAD:	PUSH.L	A3	TEST.L	(A6)+OPHELP	; fichier charg ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A3,#R16"NMHELP	FOS	?CUNLOAD	; dcharge le fichier	CLR.L	(A6)+OPHELPEXIT$:	POP.L	A3	RET; Routines graphiques; -------------------;-------\\; DRLINE >;=======/; Dessine une ligne droite.; in	D3.L	dpart (y;x);	D4.L	arrive (y;x);	D2.W	mode de dessin; out	-; mod	D7.WDRLINE:	PUSHM.L	D1..D4,A2	CALL	CCMO		; enlve la souris	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	EX.L	D3,D4	LOAD.W	D1,D2		; D1 <-- mode de dessin	GRA2_	LINE		; dessine une ligneEXIT$:	POPM.L	D1..D4,A2	RET;-----------\\; DRPOLYOPEN >;===========/; Dbute le dessin d'un polygone rempli.; in	-; out	D7.W	erreur; mod	D7.WDRPOLYOPEN:	PUSHM.L	D3,A2	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	SP,#(SP)-(8+2)	; rserve place pour cliprect+erreur	LOAD.L	D3,(A2)+ODFFY	LOAD.L	(SP)+2,D3	ADD.W	D3,(A2)+ODFFDX	SWAP.W	D3	ADD.W	D3,(A2)+ODFFDY	SWAP.W	D3	LOAD.L	(SP)+2+4,D3	PUSH.L	(A6)+ORGNID	; stack <-- ^identificateur rgion	PUSH.W	#GFILLXOR+GFILLINTERIOR ; stack <-- mode	PUSH.L	#(SP)+2+4+2	; stack <-- ^cliprect	GMI_	OPENRGN	POP.W	D7		; D7 <-- erreur	ADD.L	SP,#8		; SP <-- reprend place pour cliprectEXIT$:	POPM.L	D3,A2;	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DRPOLYLINE >;===========/; Dfini une nouvelle ligne d'un polygone rempli.; in	D3.L	dpart (y;x);	D4.L	arrive (y;x); out	D7.W	erreur; mod	D7.WDRPOLYLINE:	PUSHM.L	D3,D4,A2,A5	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	ADD.W	D3,(A2)+ODFFX	SWAP.W	D3	ADD.W	D3,(A2)+ODFFY	SWAP.W	D3	ADD.W	D4,(A2)+ODFFX	SWAP.W	D4	ADD.W	D4,(A2)+ODFFY	SWAP.W	D4	SUB.L	SP,#2	PUSH.L	(A6)+ORGNID	PUSH.L	D3	PUSH.L	D4	GMI_	PUTLINE	POP.W	D7EXIT$:	POPM.L	D3,D4,A2,A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DRPOLYCLOSE >;============/; Dessine le polygone rempli dfini.; in	D2.W	mode de dessin; out	D7.W	erreur; mod	D7.WDRPOLYCLOSE:	PUSHM.L	D0..D4,A2..A4	SUB.L	SP,#2	PUSH.L	(A6)+ORGNID	GMI_	CLOSERGN	POP.W	D7	JUMP',NE EXIT$	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	(A2)+ODFCRG,(A6)+ORGNID	LOAD.L	A4,#(A2)+ODFTRA	; A4 <-- ^trame utilisateur	CLR.L	D4	LOAD.L	D3,(A2)+ODFFDY	LOAD.W	D1,D2		; D1 <-- mode de dessin	GRA2_	TRAME		; dessine la trame	CLR.L	(A2)+ODFCRGEXIT$:	POPM.L	D0..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETNMHELP:	.ASCIZ	"TRAIN_F.HELP"	.EVEN	.END