	.SBTTL	TRAINPAL.ASI;----------\\; PALUPDATE >;==========/; Dessine toute la palette d'icne.; in	-; out	-; mod	D7.WPALUPDATE:	PUSHM.L	D1..D4,A3	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.L	D3,#H'10000*COLORFCADRE+COLORCCADRE	CALL	DESCOLOR	LOAD.L	D3,#H'88228822	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D3,(A6)+OPALPY	LOAD.L	D4,#H'10000*((PALNBY*PALDIM)+2)+((PALNBX*PALDIM)+2)	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; grise toutes les anciennes icnes	LOAD.L	D3,#H'10000*COLORFDRAW+COLORCICO	CALL	DESCOLOR	CALL	PALPTICO	; A3 <-- ^icnes	CLR.W	D1LOOP$:	LOAD.W	D3,(A3+)	JUMP',EQ NEXT$	CALL	PALDRAWNEXT$:	INC.W	D1	COMP.W	D1,#PALNBX*PALNBY	JUMP,LO LOOP$	COMP.W	(A6)+OPALNIV,#ICODRAW	JUMP,EQ DRAW$	COMP.W	(A6)+OPALNIV,#ICOLOCO	JUMP,EQ LOCO$	CLR.W	D1	CALL	PALINV		; allume la souris	TEST.B	(A6)+OGRILLE	JUMP',F GRILLE$	LOAD.W	D1,#6	CALL	PALINV		; allume la grilleGRILLE$:	TEST.B	(A6)+OZOOM	JUMP',F ZOOM$	LOAD.W	D1,#7	CALL	PALINV		; allume le zoomZOOM$:	TEST.B	(A6)+OAUTO	JUMP',F AUTO$	LOAD.W	D1,#12	CALL	PALINV		; allume l'automatismeAUTO$:	TEST.B	(A6)+OLOCK	JUMP',F LOCK$	LOAD.W	D1,#13	CALL	PALINV		; allume l'automatismeLOCK$:	TEST.B	(A6)+OMANU	JUMP',F MANU$	LOAD.W	D1,#14	CALL	PALINV		; allume manuelMANU$:	TEST.B	(A6)+OAIND	JUMP',F AIND$	LOAD.W	D1,#15	CALL	PALINV		; allume action indicateursAIND$:	TEST.B	(A6)+OADET	JUMP',F ADET$	LOAD.W	D1,#16	CALL	PALINV		; allume action dtecteursADET$:	TEST.B	(A6)+OLMOVE	JUMP',F ALMOVE$	LOAD.W	D1,#34	CALL	PALINV		; allume le mouvement des locomotivesALMOVE$:	JUMP'	EXIT$DRAW$:	LOAD.W	D1,#2	CALL	PALINV		; allume le crayon	LOAD.W	D1,(A6)+ORAIL	CALL	PALINV		; allume le rail slectionn	JUMP'	EXIT$LOCO$:	LOAD.W	D1,#1	CALL	PALINV		; allume la loco	LOAD.W	D1,(A6)+OLOCO	CALL	PALINV		; allume la loco slectionne	LOAD.W	D1,(A6)+OLNBW	CALL	PALINV		; allume le nb de wagons;	JUMP'	EXIT$EXIT$:	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D1..D4,A3	RET;---------\\; PALPTICO >;---------/; Donne les icnes pour la palette.; in	-; out	A3.L	^table des icnes pour la palette; mod	A3.LPALPTICO:	LOAD.L	A3,#R16"TAPALM$	COMP.W	(A6)+OPALNIV,#ICOMOD	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TAPALD$	COMP.W	(A6)+OPALNIV,#ICODRAW	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TAPALL$EXIT$:	RETTAPALM$:	.W	ICOMOD,ICOLOCO,ICODRAW	.W	0,0,0	.W	ICOGRILLE,ICOZOOM,0	.W	0,0,0	.W	ICOAUTO,ICOLOCK,ICOMANU	.W	ICOAIND,ICOADET,0	.W	0,0,0	.W	0,0,0	.W	0,0,0	.W	0,0,0	.W	0,0,0	.W	ICOLOCOSTEP,ICOLOCOMOVE,ICOSTOPTAPALD$:	.W	ICOMOD,ICOLOCO,ICODRAW	.W	0,0,0	.W	ICORDR,ICORH,ICORDL	.W	ICORV,ICORVIDE,ICORV	.W	ICORUR,ICORH,ICORUL	.W	ICORHVH,ICORBD,ICORHVV	.W	ICORBR,ICORHV,ICORBL	.W	0,ICORBU,0	.W	ICORHS,ICORHD,ICORHC	.W	0,0,ICORHR	.W	ICORGO,ICORINV,ICORCLA	.W	ICORMAN,ICORLI,ICORSWTAPALL$:	.W	ICOMOD,ICOLOCO,ICODRAW	.W	0,0,0	.W	0,ICOLOCOU,0	.W	ICOLOCOL,0,ICOLOCOR	.W	0,ICOLOCOD,0	.W	0,0,0	.W	ICOLOCOW0,ICOLOCOW4,ICOLOCOW8	.W	0,0,0	.W	0,0,0	.W	0,0,0	.W	0,0,0	.W	0,0,ICOLOCOKILL;--------\\; PALMOVE >;========/; Action dans un carr.; in	D4.L	position de la souris (y;x); out	D1.W	rang (0..n);	D7.W	erreur; mod	D1.L, D7.WPALMOVE:	PUSHM.L	D2..D4	CALL	PALDET		; D1 <-- carr o est la souris	JUMP,NE EXIT$	CALL	PALINV		; allume le premier	LOAD.W	D2,D1	JUMP	HELP$LOOP$:	CALL	SCMO		; remet la souris	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP,NE END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	PALDET		; D1 <-- carr o est la souris	COMP.W	D1,D2	JUMP,EQ LOOP$	CALL	HELPCLOSE	; restitue l'cran prcdent	EX.L	D1,D2	CALL	PALINV		; teint l'ancien	LOAD.W	D1,D2	CALL	PALINV		; allume le nouveauHELP$:	CALL	PALPOS		; D3/D4 <-- position/dimensions	JUMP,NE LOOP$	ADD.W	D3,D4	DEC.W	D3	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LOAD.L	D4,D3		; D4 <-- position (y;x)	LOAD.W	D3,D1	CALL	RANGICO		; D3 <-- icne	CALL	HELPTEXT	; affiche le texte	JUMP	LOOP$END$:	LOAD.W	D1,D2	CALL	PALINV		; teint le dernier	CALL	PALPOS		; D3/D4 <-- position/dimensionsEXIT$:	PUSH.W	D7	CALL	HELPCLOSE	; restitue l'cran (si oubli)	POP.W	D7	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; PALDET >;-------/; Dtecte dans quel carr est la souris.; in	D4.L	position de la souris (y;x); out	D1.W	rang (0..n);	D7.W	erreur; mod	D1.L, D7.WPALDET:	PUSHM.L	D0,D2..D4,A3	LOAD.W	D0,D4		; D0 <-- position en X	LOAD.L	D2,D4	SWAP.W	D2		; D2 <-- position en Y	CALL	PALPTICO	; A3 <-- ^icnes	LOAD.W	D1,#-1LOOP$:	INC.W	D1	CALL	PALPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	TEST.W	(A3+)		; y a-t-il une icne ?	JUMP,EQ LOOP$		; non => LOOP$	COMP.W	D0,D3	JUMP,LO LOOP$	ADD.W	D3,D4	COMP.W	D0,D3	JUMP,HS LOOP$	SWAP.W	D3	SWAP.W	D4	COMP.W	D2,D3	JUMP,LO LOOP$	ADD.W	D3,D4	COMP.W	D2,D3	JUMP,HS LOOP$EXIT$:	POPM.L	D0,D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PALDRAW >;--------/; Dessine une icne.; in	D1.W	rang (0..n);	D3.W	icne; out	-; mod	D7.WPALDRAW:	PUSHM.L	D0..D4	LOAD.W	D0,D3	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	CALL	PALPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'icne	LOAD.W	D2,#SETDOT	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LIB	?DRRECT		; dessine le cadre	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LIB	?DRRECT	ADD.W	D3,#(PALDIM-CELDIM)/2	SWAP.W	D3	ADD.W	D3,#(PALDIM-CELDIM)/2	SWAP.W	D3	LOAD.L	D4,D3	LOAD.W	D3,D0	CALL	DESICONE	; dessine l'icneEXIT$:	POPM.L	D0..D4	RET;---------\\; PALINVIF >;=========/; Inverse un carr si l'on est dans le bon niveau.; in	D1.W	rang (0..n);	D2.W	icne niveau; out	-; mod	D7.WPALINVIF:	COMP.W	D2,(A6)+OPALNIV	JUMP',NE EXIT$	CALL	PALINVEXIT$:	RET;-------\\; PALINV >;-------/; Inverse un carr.; in	D1.W	rang (0..n); out	-; mod	D7.WPALINV:	PUSHM.L	D2..D4	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	PALPOS		; D3/D4 <-- position/dimensions	JUMP,NE EXIT$	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE COLOR$		; oui => COLOR$	ADD.W	D3,#3	SWAP.W	D3	ADD.W	D3,#3	SWAP.W	D3	SUB.W	D4,#4	SWAP.W	D4	SUB.W	D4,#4	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse le contrle	JUMP	EXIT$COLOR$:	PUSH.L	D3	LOAD.L	D3,#H'10000*COLORFDRAW+COLOR1ICO	CALL	DESCOLOR	POP.L	D3	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LOAD.W	D2,#INVDOT	PUSHM.L	D3,D4	LOAD.W	D4,#2	LIB	?DRTRAME	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,D4	SUB.W	D3,#2	LOAD.W	D4,#2	LIB	?DRTRAME	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,#2	SUB.W	D4,#2+2	SWAP.W	D4	LOAD.W	D4,#2	SWAP.W	D4	LIB	?DRTRAME	POPM.L	D3,D4;	PUSHM.L	D3,D4	ADD.W	D3,#2	SUB.W	D4,#2+2	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SUB.W	D3,#2	LOAD.W	D4,#2	SWAP.W	D4	SWAP.W	D3	LIB	?DRTRAME;	POPM.L	D3,D4EXIT$:	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D2..D4	RET;--------\\; PALPOS  >;--------/; Donne la position et les dimensions d'une icne.; in	D1.W	rang (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WPALPOS:	PUSHM.L	D1	LOAD.W	D7,#1	COMP.W	D1,#-1	JUMP',EQ EXIT$	AND.L	D1,#H'FFFF	DIV.WU	D1,#PALNBX		; D1 <-- rang (x;y)	LOAD.L	D3,(A6)+OPALPY	LOAD.W	D4,D1	COMP.W	D4,#PALNBY	JUMP',HS EXIT$	MUL.WU	D4,#PALDIM	SWAP.W	D3	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	D4,D1	SWAP.W	D4	MUL.WU	D4,#PALDIM	ADD.W	D3,D4	LOAD.L	D4,#H'10000*PALDIM+PALDIM	CLR.W	D7EXIT$:	POPM.L	D1	TEST.W	D7		; retour EQ/NE	RET;--------\\; RANGICO >;========/; Cherche l'icne correspondant  un rang.; in	D3.W	rang (0..n); out	D3.W	icne correspondante; mod	D3.LRANGICO:	PUSH.L	A3	CALL	PALPTICO	; A3 <-- ^icnes	SL.W	D3,#1	LOAD.W	D3,(A3)+(D3.W)	POP.L	A3	RET;--------\\; ICORANG >;========/; Cherche le rang d'une icne.; in	D3.W	icne; out	D1.W	rang correspondant (0..n);	D7.W	erreur; mod	D1.L, D7.WICORANG:	PUSHM.L	D2,A3	CALL	PALPTICO	; A3 <-- ^icnes	LOAD.W	D2,#(PALNBX*PALNBY)-1	CLR.W	D1	CLR.W	D7LOOP$:	COMP.W	D3,(A3+)	JUMP',EQ EXIT$	INC.W	D1		; D1 <-- rang suivant	DECJ.W,NMO D2,LOOP$	LOAD.W	D7,#1EXIT$:	POPM.L	D2,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; RANGXY  >;========/; in	D1.W	rang (0..n); out	D1.L	rang (y;x); mod	D1.LRANGXY:	AND.L	D1,#H'FFFF	DIV.WU	D1,(A6)+OCELNX	; D1 <-- rang (x;y)	SWAP.W	D1	RET;--------\\; XYRANG  >;========/; in	D1.L	rang (y;x); out	D1.W	rang (0..n); mod	D1.LXYRANG:	PUSH.W	D2	LOAD.W	D2,D1	SWAP.W	D1	MUL.WU	D1,(A6)+OCELNX	ADD.W	D1,D2	POP.W	D2	RET;--------\\; ICINIT  >;========/; Initialise pour la fentre principale.; in	-; out	-; mod	D7.WICINIT:	PUSHM.L	D4	LOAD.W	(A6)+OCELDIM,#CELDIM	TEST.B	(A6)+OZOOM	JUMP',F ZOOM$	LOAD.W	(A6)+OCELDIM,#CELDIM*2ZOOM$:	LOAD.W	D4,#8	LOAD.W	(A6)+OPALPX,D4	ADD.W	D4,#(PALDIM*3)+8+LGSCROLL	LOAD.W	(A6)+OCELPX,D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#8	LOAD.W	(A6)+OCELPY,D4	SUB.W	D4,#2	LOAD.W	(A6)+OPALPY,D4	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,#8+DBGLX	SUB.W	D4,(A6)+OCELPX	DIV.WU	D4,(A6)+OCELDIM	LOAD.W	(A6)+OCELVX,D4	MUL.WU	D4,(A6)+OCELDIM	LOAD.W	(A6)+OCELDX,D4	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDY	SUB.W	D4,#8+LGSCROLL	SUB.W	D4,(A6)+OCELPY	DIV.WU	D4,(A6)+OCELDIM	LOAD.W	(A6)+OCELVY,D4	MUL.WU	D4,(A6)+OCELDIM	LOAD.W	(A6)+OCELDY,D4	POPM.L	D4	RET;--------\\; DESINFO >;========/; Dessine les informations tout en haut.; in	-; out	-; mod	D7.WDESINFO:	PUSHM.L	D3,D4,A3	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.L	D3,#H'10000*COLORCINFO+COLORFINFO	CALL	DESCOLOR	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	AFINV		; vido inverse	.ASCII	" TRAIN "	.B	MAJREV+'0,'.	.IF	MINREV<10	.B	MINREV+'0	.ELSE	.B	(MINREV/10)+'0,(MINREV-((MINREV/10)*10))+'0	.ENDIF	.B	AFDIR	.B	0	.EVEN	CALL	DESINFFILE	; info: nom du fichier	CALL	DESINF3B	; info: boutons de la souris	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D3,D4,A3	RET;---------\\; DESINF3B >;=========/; Affiche les fonctions des trois boutons de la souris.; in	-; out	-; mod	D7.WDESINF3B:	PUSHM.L	D3,A3,A4	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.L	D3,#H'10000*COLORCINFO+COLORFINFO	CALL	DESCOLOR	LOAD.L	A3,#R16"TMOD$	COMP.W	(A6)+OPALNIV,#ICOMOD	JUMP',EQ DRAW$	LOAD.L	A3,#R16"TDRAW$	COMP.W	(A6)+OPALNIV,#ICODRAW	JUMP',EQ DRAW$	LOAD.L	A3,#R16"TLOCO$DRAW$:	LOAD.W	D3,#LIHELP	MUL.WU	D3,(A0)+ODFCX	SUB.W	D3,(A0)+ODFDX	NEG.W	D3	CONV.LA.WA D3	LIB	?SETCURS	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4+),#AFINV	LOAD.B	(A4+),#AFTOUTXFER$:	LOAD.B	(A4+),(A3+)	JUMP,NE XFER$	DEC.L	A4	LOAD.B	(A4+),#AFNORM	LOAD.B	(A4+),#AFDIR	CLR.B	(A4+)	LOAD.L	A3,#(A6)+OBUDIS	LIB	?AFTEXT		; affiche les 3 boutons de la souris	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D3,A3,A4	RETTMOD$:	.ASCIZ	"| actionne | divers | modifie |"TDRAW$:	.ASCIZ	"| dessine  | divers | modifie |"TLOCO$:	.ASCIZ	"|   pose   | divers | modifie |"LIHELP	=	.-TLOCO$	.EVEN;-----------\\; DESINFFILE >;===========/; Affiche le nom du fichier dans les informations.; in	-; out	-; mod	D7.WDESINFFILE:	PUSHM.L	D2..D4,A3,A4	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.L	D3,#H'10000*COLORCINFO+COLORFINFO	CALL	DESCOLOR	LOAD.L	A3,#(A6)+OBUNAM	LIB	?BUCAR		; mode rapide	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSFILE	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A0)+ODFDX	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb car dans toute la largeur	SUB.W	D4,#POSFILE	SUB.W	D4,#LIHELP+1	; D4 <-- nb car restants pour le nom	TEST.B	(A3)	JUMP',EQ 50$	COMP.B	(A3),#CR	JUMP',EQ 50$	LIB	?AFTIM	.B	'"		; guillemet au dbut	.B	AFTOUT	.B	0	.EVEN	SUB.W	D4,#2	LOAD.L	A4,#(A6)+OBUDIS	CALL	PUTINFFILE	; OBUDIS <-- nom du fichier	COMP.W	D3,D4	JUMP',LS 30$	ADD.W	A4,D3	SUB.W	A4,D4		; A4 <-- saute le dbut du nom	LOAD.B	(A4),#5		; dbut de nom <-- triangle "<"	LOAD.W	D3,D430$:	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le nom, ou seulement la fin	SUB.W	D4,D3		; D4 <-- lg restante	LIB	?AFTIM	.B	AFNORM	.B	'"		; guillemet  la fin	.B	0	.EVEN50$:	TEST.W	D4	JUMP',EQ 80$	LOAD.B	D3,#MSPACE	LIB	?AFCAR		; efface la fin	LOAD.B	D3,D4	LIB	?AFCAR80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?NOBUCAR	; mode normal	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D2..D4,A3,A4	RET;-----------\\; PUTINFFILE >;-----------/; Prpare le nom du fichier  afficher.; in	A3.L	^nom;	A4.L	^buffer; out	D3.W	nb de caractres; mod	D3.L, D7.WPUTINFFILE:	PUSHM.L	D1,D2,A4	LOAD.W	D2,#2^BAFXMI	; D2 <-- affiche en minuscules	LOAD.W	D3,#100		; D3 <-- lg max	LOAD.L	D1,A4	LIB	?PUTXFILE	; OBUDIS <-- nom du fichier20$:	COMP.L	A4,D1	JUMP',EQ 30$	LOAD.B	D3,(-A4)	COMP.B	D3,#':	JUMP',EQ 30$	COMP.B	D3,#'.	JUMP,NE 20$	CLR.B	(A4)		; enlve l'extension30$:	LOAD.L	A4,D1	LOAD.W	D3,#-140$:	INC.W	D3	TEST.B	(A4+)	JUMP,NE 40$	POPM.L	D1,D2,A4	RET;---------\\; DESICONE >;=========/; Dessine une icne.; in	D3.W	icne;	D4.L	position (y;x); out	-; mod	D7.WDESICONE:	PUSHM.L	D0..D6,A2..A4	CALL	CCMO		; enlve la souris	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	LOAD.L	A3,#R16"TCOLOR$	LOAD.W	D2,D3	AND.W	D2,#H'7F	SL.W	D2,#2	LOAD.W	D6,(A3)+(D2.W)+0 ; D6 <-- couleur de fond	TEST.L	D3:#7	JUMP',BC COLOR$	LOAD.W	D6,(A3)+(D2.W)+2 ; D6 <-- couleur de fondCOLOR$:	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	LOAD.L	A3,(A6)+OPGICO	LOAD.W	D2,D3	LOAD.W	D0,D3	AND.W	D0,#H'7F	MUL.WU	D0,(A3)+OGCMSB	ADD.L	D0,#OGCWID+(3*128)	ADD.L	A3,D0		; A3 <-- ^source (dans ITP17)	CLR.L	D3	TEST.L	D2:#7	JUMP',BC POSX$	LOAD.W	D3,#CELDIMPOSX$:	LOAD.W	D5,#32/8	; D5 <-- Iy source	PUSH.L	D3	LOAD.L	D3,#H'10000*COLORFDRAW+COLORCICO	CALL	DESCOLOR	POP.L	D3	LOAD.L	D2,#H'10000*CELDIM+CELDIM	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; dessine l'icne	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A3,(A6)+OPFICO	ADD.L	A3,D0		; A3 <-- ^source (dans ITP18)	PUSH.L	D3	LOAD.L	D3,#H'10000*COLORFDRAW	LOAD.W	D3,D6	CALL	DESCOLOR	POP.L	D3	LOAD.W	D1,#SETDOT	LOAD.L	A2,A0	GRA_	RASTER		; dessine le fond de l'icneEXIT$:	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D0..D6,A2..A4	RETTCOLOR$:	.W	COLORFICO,COLORFICO	; 0	.W	COLORFICO,COLORFICO	.W	COLOR0ICO,COLOR1ICO	.W	COLOR0ICO,COLOR1ICO	.W	COLORFICO,COLOR1ICO	.W	COLORFICO,COLOR1ICO	.W	COLORFICO,COLORVICO	.W	COLORFICO,COLORVICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	; 16	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLOR1ICO	.W	COLORFICO,COLOR1ICO	.W	COLOR0ICO,COLOR1ICO	.W	COLOR0ICO,COLOR1ICO	.W	COLOR2ICO,COLOR2ICO	.W	COLOR2ICO,COLOR2ICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLOR0ICO,COLOR1ICO	.W	COLOR0ICO,COLOR1ICO	.W	COLOR0ICO,COLOR1ICO	.W	COLORFICO,COLORFICO	; 32	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLOR0ICO,COLOR0ICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLOREICO,COLOREICO	.W	COLORFICO,COLORFICO	; 48	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLOR0ICO,COLOR0ICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORLOCO,COLORLOCO	; 64	.W	COLORLOCO,COLORLOCO	.W	COLORLOCO,COLORLOCO	.W	COLORLOCO,COLORLOCO	.W	COLORLOCO,COLORLOCO	.W	COLORLOCO,COLORLOCO	.W	COLORLOCO,COLORLOCO	.W	COLORLOCO,COLORLOCO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	; 80	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	; 96	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	; 112	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO	.W	COLORFICO,COLORFICO;-----------\\; DESCHIFFRE >;===========/; Dessine un petit chiffre.; in	D3.W	chiffre (0..9999);	D4.L	position (y;x); out	-; mod	D7.WDESCHIFFRE:	PUSHM.L	D1..D4	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	PUSH.L	D3	LOAD.L	D3,#H'10000*COLORFDRAW+COLORUNIT	CALL	DESCOLOR	POP.L	D3	LOAD.L	D2,D4	CLR.L	D4	LOAD.W	D4,D3	LIB	?BINBCD		; D4 <-- chiffre en BCD	EX.L	D2,D4	LOAD.L	D1,#4LOOP$:	RL.W	D2,#4		; D2 <-- pousse d'un digit	LOAD.W	D3,D2	AND.W	D3,#B'1111	; D3 <-- digit	JUMP',NE DIGIT$	COMP.W	D1,#1		; est-ce le dernier digit (units) ?	JUMP',EQ DIGIT$		; oui => DIGIT$	TEST.L	D1:#16		; dj affich qq chose ?	JUMP',BC NEXT$		; non => NEXT$DIGIT$:	CALL	DESDIGIT	; dessine un digit	ADD.W	D4,#6+1		; D4 <-- position suivante	TSET.L	D1:#16		; D1 <-- signale affich qq choseNEXT$:	DEC.W	D1	JUMP,NE LOOP$	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSF	POPM.L	D1..D4	RET;---------\\; DESDIGIT >;---------/; Dessine un digit.; in	D3.W	chiffre (0..9);	D4.L	position (y;x); out	-; mod	D7.WDESDIGIT:	PUSHM.L	D1..D5,A2..A4	CALL	CCMO		; enlve la souris	LOAD.L	A3,#R16"MAT09$	MUL.WU	D3,#11	ADD.L	A3,D3		; A3 <-- ^matrice du chiffre	CLR.L	D3	LOAD.W	D5,#1	LOAD.L	A4,#0	LOAD.L	D2,#H'10000*11+6	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; dessine le digit	POPM.L	D1..D5,A2..A4	RETMAT09$:	.B	B'01111000	.B	B'11111100	.B	B'11001100	.B	B'11001100	.B	B'11001100	.B	B'11001100	.B	B'11001100	.B	B'11001100	.B	B'11001100	.B	B'11111100	.B	B'01111000	.B	B'00110000	.B	B'01110000	.B	B'11110000	.B	B'11110000	.B	B'00110000	.B	B'00110000	.B	B'00110000	.B	B'00110000	.B	B'00110000	.B	B'11111100	.B	B'11111100	.B	B'01111000	.B	B'11111100	.B	B'11001100	.B	B'11001100	.B	B'00011100	.B	B'00011000	.B	B'00111000	.B	B'01110000	.B	B'11100000	.B	B'11111100	.B	B'11111100	.B	B'01111000	.B	B'11111100	.B	B'11001100	.B	B'00001100	.B	B'00111000	.B	B'00111000	.B	B'00001100	.B	B'00001100	.B	B'11001100	.B	B'11111100	.B	B'01111000	.B	B'00011000	.B	B'00011000	.B	B'00111000	.B	B'00111000	.B	B'01111000	.B	B'01011000	.B	B'11011000	.B	B'11111100	.B	B'11111100	.B	B'00011000	.B	B'00011000	.B	B'11111000	.B	B'11111000	.B	B'11000000	.B	B'11000000	.B	B'11111000	.B	B'11111100	.B	B'11001100	.B	B'00001100	.B	B'11001100	.B	B'11111100	.B	B'01111000	.B	B'01111000	.B	B'11111100	.B	B'11001100	.B	B'11000000	.B	B'11111000	.B	B'11111100	.B	B'11001100	.B	B'11001100	.B	B'11001100	.B	B'11111100	.B	B'01111000	.B	B'11111100	.B	B'11111100	.B	B'00001100	.B	B'00001100	.B	B'00011000	.B	B'00011000	.B	B'00011000	.B	B'00110000	.B	B'00110000	.B	B'00110000	.B	B'00110000	.B	B'01111000	.B	B'11111100	.B	B'11001100	.B	B'11001100	.B	B'01111000	.B	B'01111000	.B	B'11001100	.B	B'11001100	.B	B'11001100	.B	B'11111100	.B	B'01111000	.B	B'01111000	.B	B'11111100	.B	B'11001100	.B	B'11001100	.B	B'11001100	.B	B'11111100	.B	B'01111100	.B	B'00001100	.B	B'11001100	.B	B'11111100	.B	B'01111000.IF 0	.B	B'01100000	.B	B'10010000	.B	B'10010000	.B	B'10010000	.B	B'10010000	.B	B'10010000	.B	B'01100000	.B	B'00100000	.B	B'01100000	.B	B'00100000	.B	B'00100000	.B	B'00100000	.B	B'00100000	.B	B'01110000	.B	B'01100000	.B	B'10010000	.B	B'00010000	.B	B'00100000	.B	B'01000000	.B	B'10000000	.B	B'11110000	.B	B'01100000	.B	B'10010000	.B	B'00010000	.B	B'01100000	.B	B'00010000	.B	B'10010000	.B	B'01100000	.B	B'00100000	.B	B'01100000	.B	B'10100000	.B	B'10100000	.B	B'11110000	.B	B'00100000	.B	B'00100000	.B	B'11100000	.B	B'10000000	.B	B'10000000	.B	B'11100000	.B	B'00010000	.B	B'00010000	.B	B'11100000	.B	B'01100000	.B	B'10010000	.B	B'10000000	.B	B'11100000	.B	B'10010000	.B	B'10010000	.B	B'01100000	.B	B'11110000	.B	B'00010000	.B	B'00100000	.B	B'00100000	.B	B'01000000	.B	B'01000000	.B	B'01000000	.B	B'01100000	.B	B'10010000	.B	B'10010000	.B	B'01100000	.B	B'10010000	.B	B'10010000	.B	B'01100000	.B	B'01100000	.B	B'10010000	.B	B'10010000	.B	B'01110000	.B	B'00010000	.B	B'10010000	.B	B'01100000.ENDIF	.EVEN;---------\\; DESCOLOR >;=========/; Spcifie les couleurs pour dessiner.; in	D3.L	couleurs (clear;set); out	-; mod	D7.WDESCOLOR:	PUSHM.L	D3,A3	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A3,#(A6)+OBUCOL	COMP.W	D3,#COLORBASE	JUMP',LO SSYS$	COMP.W	D3,#COLORBASE+NBRCOUL	JUMP',HS SSYS$	SUB.W	D3,#COLORBASE	; D3 <-- 0..n	SL.W	D3,#2	LOAD.L	(A0)+ODFCSF,(A3)+(D3.W)	JUMP'	CLEAR$SSYS$:	PUSH.L	D3	AND.L	D3,#H'FFFF	LIB	?COLORSR	POP.L	D3CLEAR$:	SWAP.W	D3	COMP.W	D3,#COLORBASE	JUMP',LO CSYS$	COMP.W	D3,#COLORBASE+NBRCOUL	JUMP',HS CSYS$	SUB.W	D3,#COLORBASE	; D3 <-- 0..n	SL.W	D3,#2	LOAD.L	(A0)+ODFCCF,(A3)+(D3.W)	JUMP'	EXIT$CSYS$:	AND.L	D3,#H'FFFF	LIB	?COLORCREXIT$:	POPM.L	D3,A3	RET;--------\\; DESINIT >;========/; Initialise la table des fausses couleurs.; in	-; out	-; mod	D7.WDESINIT:	PUSHM.L	D3,A3	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ EXIT$		; non => EXIT$	PUSH.L	(A0)+ODFCSF	LOAD.L	A3,#(A6)+OBUCOL	LOAD.L	D3,#COLORBASELOOP$:	LIB	?COLORSR	LOAD.L	(A3+),(A0)+ODFCSF	INC.W	D3	COMP.W	D3,#COLORBASE+NBRCOUL	JUMP,LO LOOP$	POP.L	(A0)+ODFCSFEXIT$:	POPM.L	D3,A3	RET	.END