	.TITLE	TRAIN.ASD;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du pilote SMA_TRAIN.DRIV	.PROC	M680002	.REF	SMAKY	.REF	BIOSDRIV;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;SMAKY300 = 7;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	.RADIX	10.	.HEX;	Date		Amliorations; ------------------------------------------------------------------------------------; 0.4	21.06.91	processus fils en mode superviseur (pour SMAKY300); 0.3	12.03.91	adaptation aux nouvelles cartes  10 relais (au lieu de 8); 0.2	25.02.91	commande L[0..1.B] pour adapteur MUBUS-LONG; 0.1	19.12.90	premire versionMAJREV	=	0		; rvisionMINREV	=	4		; version	.REV	MAJREV,MINREVPROTODR	=	0; Constantes; ----------DRIVNUM	=	H'E0		; numro du driverPRIODET	=	6		; priorit du processus des dtecteursSM100ADMUBUS =	H'FFFF8000SM324ADMUBUS =	H'FFFFA800SM300ADMUBUS =	H'01000000	.IF	PROTODRMBLDATA	=	H'08		; MUBUS-LONG: dataMBLADR	=	H'09		; MUBUS-LONG: adresseMBLCTRL	=	H'0A		; MUBUS-LONG: contrle	.ELSEMBLDATA	=	H'10		; MUBUS-LONG: dataMBLADR	=	H'11		; MUBUS-LONG: adresse	.ENDIFMAXCARTES=	16		; nb max de cartes connectables simultanmentMBWREL	=	0		; write: relaisMBWROW	=	1		; write: slection colonneMBWLINE	=	2		; write: slection ligne + enable BENLINE =	 4		;  bit enable line BENROW	=	 5		;  bit enable row BREL8	=	 6		;  bit relais 8 BREL9	=	 7		;  bit relais 9MBRDET	=	0		; read: dtecteurs; Erreurs; -------ERTRAIN	=	H'DA00		; valeur de base (DA comme DAniel, bof !)ERTMACH	=	ERTRAIN+1	; machine illgaleERTIWLG	=	ERTRAIN+2	; longueur incorrecteERTICOM	=	ERTRAIN+3	; commande incorrecteERTRNOD	=	ERTRAIN+4	; rien  lire; Structure du data (criture); ----------------------------	.LOC	0ODACOM:	.BLKB	2		; data: commandeODAUNI:	.BLKB	2		; data: numro de l'unitODANUM:	.BLKB	2		; data: valeurODAPAR:	.BLKB	2		; data: paramtreLDA:; Descripteur pour 8 dtecteurs; -----------------------------	.LOC	0OD8DATA:.BLKB	1		; dtecteurs: dataOD8FLAN:.BLKB	1		; dtecteurs: flansOD8TIME:.BLKB	4*8		; dtecteurs: temps relatifsLD8:; Variables; ---------	.LOC	0OABORT:	.BLKB	1		; 1 => fils des processus filsOLONG:	.BLKB	1		; 1 => adaptateur MUBUS-LONG	.EVENOPSEM:	.BLKB	4		; ^smaphore d'exclusionOTIME:	.BLKB	4		; temps relatif [20ms] (32 bits suffisent pour ~3ans)OTDET:	.BLKB	4		; temps entre deux dtecteursOMBAD:	.BLKB	4		; adresse de base de MUBUSOMBI:	.BLKB	2		; incrment MUBUS (1,2)OMBLDATA:.BLKB	2		; MUBUS-LONG: dataOMBLADR:.BLKB	2		; MUBUS-LONG: adresse	.IF	PROTODROMBLCTRL:.BLKB	2		; MUBUS-LONG: contrle	.ENDIFOMBREL:	.BLKB	MAXCARTES*2	; tats des relaisOMBDET:	.BLKB	MAXCARTES*LD8	; tats des dtecteursLGVAR:	.LOC	0DEBUT:	.W	0,S0BASE	.W	2^7; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=;			DRIVER $TRAIN_0		No H'E0; =+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=S0ID:	.W	S0OPEN-S0BASE	.W	S0COMMAND-S0BASE	.W	-1			; S0RSTATUS-S0BASE	.W	S0READ-S0BASE	.W	S0WRITE-S0BASE	.W	S0CLOSE-S0BASE	.W	-1			; STOPTR	.W	-1			; STARTR	.W	-1			; AVORTTR	.W	-1			; S0AUX1-S0BASE	.W	-1			; S0AUX2-S0BASE	.W	S0RESET-S0BASE	.W	S0KILL-S0BASE	.W	-1			; S0STRT-S0BASE	.W	-1			; S0TSTRT-S0BASE	.W	-1			; S0START-S0BASES0NAB:	.ASCII	"TRAIN_0"		; nom driverS0NAF:	.FILLB	LGDNAM-(S0NAF-S0NAB),0	.B	DRIVNUM			; numro driver	.B	TYPIO			; type streamer	.B	MAJREV,MINREV		; rvision - version	.B	0			; priorit	.B	0			; rserve	.B	0			; attribut 1	.B	2^BDWROK!2^BDRDOK!2^BDNORT ; attribut 0	.FILLB	LGDDESC-(.-S0ID),0	; le resteS0BASE:;--------\\; S0RESET >;========/; Initialisation du pilote.; in	-; out	A6.L	^variables globales;	D7.W	erreur; mod	D7.W, A6.LS0RESET:	PUSHM.L	D3,D4,A3..A5	LOAD.L	A4,#R16"DEBUT	LOAD.L	D4,#LGVAR	FOS	?GETCOMMEM	; demande variables globales	JUMP,NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables globales	LOAD.W	D4,#1	NTREL	?CRESEM		; cre le smaphore d'exclusion	JUMP,NE EXIT$	LOAD.L	(A6)+OPSEM,A5	NTREL	?GETMACHINE	RL.L	D4,#8		; D4 <-- SMAKY*	COMP.B	D4,#SMAKY100	JUMP',EQ SM100$	COMP.B	D4,#SMAKY324	JUMP',EQ SM324$	COMP.B	D4,#SMAKY300	JUMP',EQ SM300$	LOAD.W	D7,#ERTMACH	; D7 <-- machine illgale !	JUMP	EXIT$SM100$:	LOAD.L	(A6)+OMBAD,#SM100ADMUBUS	LOAD.W	(A6)+OMBI,#2	JUMP'	INIT$SM324$:	LOAD.L	(A6)+OMBAD,#SM324ADMUBUS	LOAD.W	(A6)+OMBI,#1	JUMP'	INIT$SM300$:	LOAD.L	(A6)+OMBAD,#SM300ADMUBUS	LOAD.W	(A6)+OMBI,#1;	JUMP'	INIT$INIT$:	LOAD.W	D4,(A6)+OMBI	LOAD.W	D3,#MBLDATA	MUL.WU	D3,D4	LOAD.W	(A6)+OMBLDATA,D3	LOAD.W	D3,#MBLADR	MUL.WU	D3,D4	LOAD.W	(A6)+OMBLADR,D3	.IF	PROTODR	LOAD.W	D3,#MBLCTRL	MUL.WU	D3,D4	LOAD.W	(A6)+OMBLCTRL,D3	.ENDIF	CLR.B	(A6)+OLONG	; MUBUS-COURT	LOAD.L	(A6)+OTDET,#50*2 ; OTDET <-- temps minimum de 2 secondes	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A3..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; S0OPEN  >;========/; Ouverture du pilote.; in	A6.L	^variables globales; out	D7.W	erreur; mod	D7.WS0OPEN:	PUSHM.L	D4,D5,A3..A5	CALL	INIT		; initialise tout	LOAD.W	D4,#PRIODET!2^BTDRIV ; excute le processus en mode superviseur !	LOAD.L	A5,#R16"PFILS1	LOAD.L	A3,#R16"NFILS1	LOAD.L	D5,#100		; D5 <-- lg stack	NTREL	?CRETASK	; cre le processus fils de lecture des dtecteursEXIT$:	POPM.L	D4,D5,A3..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; S0WRITE >;========/; Ecrit du data.; in	A6.L	^variables globales;	A4.L	^data;	D5.L	lg data; out	D7.W	erreur; mod	D7.WS0WRITE:	PUSHM.L	D3..D6,A4	LOAD.W	D7,#ERTIWLG	; D7 <-- longueur incorrecte	LOAD.L	D4,D5	DIV.WU	D4,#LDA	SWAP.W	D4	TEST.W	D4		; longueur multiple de LDA ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.L	D6,D5		; D6 <-- longueurLOOP$:	TEST.L	D6		; reste qq chose ?	JUMP,EQ OK$		; non => OK$	LOAD.W	D4,(A4)+ODACOM	; D4 <-- commande	COMP.W	D4,#H'100*'A+'B	JUMP',EQ AB$	COMP.W	D4,#H'100*'A+'C	JUMP',EQ AC$	COMP.W	D4,#H'100*'R+'L	JUMP',EQ RL$	LOAD.W	D7,#ERTICOM	; D7 <-- commande illgale	JUMP	EXIT$AB$:	LOAD.W	D3,(A4)+ODAUNI	; D3 <-- unit	LOAD.W	D4,(A4)+ODANUM	; D4 <-- valeur	LOAD.W	D5,(A4)+ODAPAR	; D5 <-- paramtres	CALL	WRITEAIGBBT	JUMP,NE EXIT$	JUMP'	NEXT$AC$:	LOAD.W	D3,(A4)+ODAUNI	; D3 <-- unit	LOAD.W	D4,(A4)+ODANUM	; D4 <-- valeur	LOAD.W	D5,(A4)+ODAPAR	; D5 <-- paramtres	CALL	WRITEAIGCCT	JUMP,NE EXIT$	JUMP'	NEXT$RL$:	LOAD.W	D3,(A4)+ODAUNI	; D3 <-- unit	LOAD.W	D4,(A4)+ODANUM	; D4 <-- valeur;	LOAD.W	D5,(A4)+ODAPAR	; D5 <-- paramtres	CALL	WRITEREL	JUMP,NE EXIT$;	JUMP'	NEXT$NEXT$:	ADD.L	A4,#LDA		; A4 <-- ^data suivant	SUB.L	D6,#LDA	JUMP	LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3..D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; S0READ  >;========/; Lit du data.; in	A6.L	^variables globales;	A4.L	^data;	D5.L	lg data; out	D5.L	lg data lu;	D7.W	erreur; mod	D5.L, D7.WS0READ:	PUSHM.L	D3,D4,A4	LOAD.L	D4,D5		; D4 <-- lg  lire	CLR.L	D5		; D5 <-- lg lueLOOP$:	CALL	READDET		; D3 <-- unit actionne	JUMP',NE OK$	LOAD.W	(A4+),D3	; buffer <-- dtecteur lu	ADD.L	D5,#2		; D5 <-- lg lue	SUB.L	D4,#2		; D4 <-- lg restant  lire	JUMP,NE LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; S0CLOSE >;========/; Termine et ferme tout.; in	A6.L	^variables globales; out	D7.W	erreur; mod	D7.WS0CLOSE:	PUSHM.L	D3,D4	CLR.W	D3	CLR.W	D4LOOP$:	CALL	WRITEREL	; relche un relai	INC.W	D3	COMP.W	D3,#8*MAXCARTES	JUMP,LO LOOP$	SET.B	(A6)+OABORT	; stoppe les fils	LOAD.W	D4,#5	NTREL	?DELMS		; attend la fin des processus fils ...	POPM.L	D3,D4	CLR.W	D7		; D7 <-- ok	RET;----------\\; S0COMMAND >;==========/; Excute une liste de commandes.; in	A6.L	^variables globales;	A4.L	^table des commandes termine par zro; out	D7.W	erreur; mod	D7.WS0COMMAND:	PUSHM.L	A4	CLR.W	D7		; D7 <-- okLOOP$:	TEST.B	(A4)		; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	CALL	WRONEC		; excute une commande	JUMP,EQ	LOOP$EXIT$:	POPM.L	A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRONEC  >;========/; Excute une commande.; in	A4.L	^commande; out	A4.L	^commande suivante;	D7.W	erreur; mod	D7.W, A4.LWRONEC:	PUSH.L	D4	LOAD.B	D4,(A4+)	; D4 <-- commande	COMP.B	D4,#'I	JUMP',EQ INIT$	COMP.B	D4,#'D	JUMP',EQ TDET$	COMP.B	D4,#'L	JUMP',EQ LONG$ERROR$:	LOAD.W	D7,#ERDIIL	; D7 <-- "commande illgale"	JUMP'	EXIT$INIT$:	CALL	INIT		; initialise tout	JUMP'	OK$TDET$:	CLR.L	D4	LOAD.B	D4,(A4+)	; D4 <-- temps entre deux dtecteurs	LOAD.L	(A6)+OTDET,D4	JUMP'	OK$LONG$:	LOAD.B	(A6)+OLONG,(A4+);	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; S0KILL  >;========/; Libration du pilote.; in	A6.L	^variables globales; out	D7.W	erreur; mod	D7.W, A6.LS0KILL:	PUSHM.L	A5	LOAD.L	A5,(A6)+OPSEM	NTREL	?KILLSEM	; dtruit le smaphore	POPM.L	A5	CLR.W	D7		; retour EQ	RET; Processus de lecture des dtecteurs; -----------------------------------NFILS1:	.ASCIZ	"TRAIN_RDDET"	.EVENPFILS1:BEGIN$:	INC.L	(A6)+OTIME	; OTIME <-- temps relatif	TEST.B	(A6)+OABORT	; fin du processus ?	JUMP',NE END$		; oui => END$	LOAD.B	D0,(A6)+OLONG	; adaptateur MUBUS-LONG ?	JUMP',EQ SCAN$		; non => SCAN$	LOAD.L	A5,(A6)+OPSEM	NTREL	?LOCKSCAN$:	LOAD.L	A3,#(A6)+OMBDET	CLR.W	D1		; D1 <-- carte initialeLOOP$:	CALL	READDATA	; D3 <-- data lu (dtecteurs)	NOT.B	D3		; D3 <-- actif  1	OR.B	(A3)+OD8DATA,D3	ADD.L	A3,#LD8		; A3 <-- ^data suivant	INC.W	D1	COMP.W	D1,#MAXCARTES	JUMP,LO LOOP$	TEST.B	D0		; adaptateur MUBUS-LONG ?	JUMP',EQ WAIT$		; non => WAIT$;	LOAD.L	A5,(A6)+OPSEM	NTREL	?UNLOCKWAIT$:	LOAD.W	D4,#1	NTREL	?DELMS		; attend 20ms ...	JUMP	BEGIN$END$:	NTREL	?ABORT;--------\\; INIT    >;========/; Initialise tout.; in	-; out	-; mod	D7.WINIT:	PUSHM.L	D3,D4,A4	LOAD.L	A4,#(A6)+OMBDET	LOAD.W	D4,#((MAXCARTES*LD8)/2)-1DCLR$:	CLR.W	(A4+)	DECJ.W,NMO D4,DCLR$	LOAD.L	A4,#(A6)+OMBREL	LOAD.W	D4,#((MAXCARTES*2)/2)-1RCLR$:	CLR.W	(A4+)	DECJ.W,NMO D4,RCLR$	CLR.W	D3RLOOP$:	CLR.W	D4	CALL	WRITEREL	; dcolle 8 relais	ADD.W	D3,#16	COMP.W	D3,#256	JUMP,LO RLOOP$	POPM.L	D3,D4,A4	RET;--------\\; READDET >;========/; Lit une entre quelconque.; in	-; out	D3.W	unit (0..255);	D7.W	erreur; mod	D7.WREADDET:	PUSHM.L	D0..D2,A2,A3	LOAD.L	A3,#(A6)+OMBDET	CLR.W	D3CLOOP$:	TEST.B	(A3)+OD8DATA	; dtecteur(s) actionn(s) ?	JUMP,EQ CCLR$		; non => CCLR$	LOAD.L	A2,#(A3)+OD8TIME	CLR.W	D2		; D2 <-- bit  testerDLOOP$:	TCLR.B	(A3)+OD8DATA:D2	; data lu ?	JUMP',BC DCLR$		; non => DCLR$	TSET.B	(A3)+OD8FLAN:D2	; dbut du flan ?	JUMP',BS DNEXT$		; non => DNEXT$	LOAD.L	D0,(A6)+OTIME	; D0 <-- temps actuel	LOAD.L	D1,D0	SUB.L	D1,(A2)		; D1 <-- temps coul	LOAD.L	(A2),D0	COMP.L	D1,(A6)+OTDET	; s'est-il coul le temps minimum ?	JUMP',LE DNEXT$		; non => DNEXT$	SL.W	D3,#4	ADD.W	D3,D2		; D3 <-- unit	CLR.W	D7	JUMP'	EXIT$DCLR$:	TCLR.B	(A3)+OD8FLAN:D2	; fin du flanDNEXT$:	ADD.L	A2,#4		; A2 <-- ^temps suivant	INC.W	D2		; D2 <-- bit suivant	COMP.W	D2,#8	JUMP,LO DLOOP$	JUMP'	CNEXT$CCLR$:	CLR.B	(A3)+OD8FLAN	; fin de tous les flansCNEXT$:	ADD.L	A3,#LD8		; A3 <-- ^data suivant	INC.W	D3	COMP.W	D3,#MAXCARTES	JUMP,LO CLOOP$	LOAD.W	D7,#ERTRNOD	; D7 <-- rien  lireEXIT$:	POPM.L	D0..D2,A2,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; WRITEREL >;=========/; Bouge un relai pour un secteur.; in	D3.W	unit (0..255);	D4.W	data (0..1); out	D7.W	erreur; mod	D7.WWRITEREL:	PUSHM.L	D0..D4,A3	LOAD.W	D7,#1		; D7 <-- erreur	LOAD.L	A3,#(A6)+OMBREL	LOAD.W	D2,D3	AND.W	D2,#H'00F8	SR.W	D2,#3	ADD.W	A3,D2		; A3 <-- ^tat actuel	LOAD.W	D1,D3	AND.W	D1,#H'00F0	SR.W	D1,#4		; D1 <-- carte (0..15)	COMP.W	D4,#2	JUMP',HS EXIT$	LOAD.W	D2,D3	AND.W	D2,#H'000F	; D2 <-- 0..15	LOAD.W	D0,#MBWREL	TCLR.L	D2:#3		; relais 0..7 ?	JUMP',BC PART$		; oui => PART$	COMP.W	D2,#2		; relais 8..9 ?	JUMP',HS EXIT$		; non => EXIT$	ADD.W	D2,#BREL8	; D2 <-- bits 6 et 7 !	LOAD.W	D0,#MBWLINEPART$:	LOAD.B	D3,(A3)		; D3 <-- tat actuel	TCLR.L	D3:D2	TEST.W	D4	JUMP',BC WRITE$	TSET.L	D3:D2WRITE$:	LOAD.W	D2,D0		; D2 <-- MBWREL/MBWLINE	CALL	WRITEDATA	; MUBUS <-- data	LOAD.B	(A3),D3		; mj le nouvel tat actuel	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; WRITEAIGBBT >;============/; Bouge un aiguillage (BB).; in	D3.W	unit (0..255);	D4.W	data (0,1);	D5.W	dure [ms]; out	D7.W	erreur; mod	D7.WWRITEAIGBBT:	PUSH.L	D4	COMP.W	D4,#1	JUMP',EQ ACTION$	LOAD.W	D4,#2		; D4 <-- 1,2ACTION$:	CALL	WRITEAIGBB	; actionne	JUMP',NE EXIT$	LOAD.W	D4,D5	NTREL	?DELMS		; attend ...	CLR.W	D4	CALL	WRITEAIGBB	; reposEXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; WRITEAIGBB >;===========/; Ecrit une information d'aiguillage (BB).; in	D3.W	unit (0..255);	D4.W	data (0..2); out	D7.W	erreur; mod	D7.WWRITEAIGBB:	PUSHM.L	D0..D4,A4	LOAD.W	D7,#1		; D7 <-- erreur	LOAD.W	D1,D3	AND.W	D1,#H'00F0	SR.W	D1,#4		; D1 <-- carte (0..15)	LOAD.L	A4,#(A6)+OMBREL+1	ADD.W	A4,D1	ADD.W	A4,D1		; A4 <-- ^tat actuel des relais 8 et 9	DEC.W	D4	JUMP',NS ZERO$	COMP.W	D4,#2	JUMP',HS EXIT$	LOAD.W	D0,D3	LOAD.W	D2,D0	AND.W	D2,#H'0003	; D2 <-- 0,1,2,3	SL.W	D2,#1		; D2 <-- 0,2,4,6	ADD.W	D2,D4	LOAD.B	D3,#-1	TCLR.L	D3:D2		; D3 <-- data slection colonne (ex. 11101111)	LOAD.W	D2,#MBWROW	CALL	WRITEDATA	; MUBUS <-- data	LOAD.W	D2,D0	AND.W	D2,#H'000C	SR.W	D2,#2	LOAD.B	D3,#2^BENLINE!2^BENROW	TSET.L	D3:D2		; D3 <-- data slection ligne (ex. 0010)	OR.B	D3,(A4)		; D3 <-- ajoute l'tat des relais 8 et 9	LOAD.W	D2,#MBWLINE	CALL	WRITEDATA	; MUBUS <-- data	JUMP'	OK$ZERO$:	LOAD.B	D3,(A4)		; D3 <-- tat des relais 8 et 9	LOAD.W	D2,#MBWLINE	CALL	WRITEDATA	; MUBUS <-- data	CLR.B	D3	LOAD.W	D2,#MBWROW	CALL	WRITEDATA	; MUBUS <-- dataOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; WRITEAIGCCT >;============/; Bouge un aiguillage (CC).; in	D3.W	unit (0..255);	D4.W	data (0,1);	D5.W	dure [ms]; out	D7.W	erreur; mod	D7.WWRITEAIGCCT:	PUSH.L	D4	INC.W	D4		; D4 <-- 1,2	CALL	WRITEAIGCC	; actionne	JUMP',NE EXIT$	LOAD.W	D4,D5	NTREL	?DELMS		; attend ...	CLR.W	D4	CALL	WRITEAIGCC	; reposEXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; WRITEAIGCC >;===========/; Ecrit une information d'aiguillage (CC).; in	D3.W	unit (0..255);	D4.W	data (0..2); out	D7.W	erreur; mod	D7.WWRITEAIGCC:	PUSHM.L	D1..D3,A3,A4	LOAD.W	D7,#1		; D7 <-- erreur	LOAD.W	D1,D3	AND.W	D1,#H'00F0	SR.W	D1,#4		; D1 <-- carte (0..15)	LOAD.L	A4,#(A6)+OMBREL+1	ADD.W	A4,D1	ADD.W	A4,D1		; A4 <-- ^tat actuel des relais 8 et 9	TEST.W	D4	JUMP,EQ ZERO$	LOAD.L	A3,#R16"TABLE$	AND.W	D3,#H'000F	SL.W	D3,#2	LOAD.W	D2,(A3)+(D3.W)+0 ; D2 <-- adresse	JUMP,EQ EXIT$	LOAD.W	D3,(A3)+(D3.W)+2 ; D3 <-- bit	COMP.W	D4,#2	JUMP',EQ INV$	COMP.W	D4,#1	JUMP,NE EXIT$NORM$:	COMP.W	D2,#MBWLINE	JUMP',EQ NLINE$	LOAD.W	D2,#MBWROW	CALL	WRITEDATA	; MUBUS <-- data	LOAD.B	D3,#2^BENLINE!2^BENROW	OR.B	D3,(A4)		; D3 <-- ajoute l'tat des relais 8 et 9	LOAD.W	D2,#MBWLINE	CALL	WRITEDATA	; MUBUS <-- data	JUMP'	OK$NLINE$:	PUSH.W	D3	LOAD.W	D2,#MBWROW	LOAD.B	D3,#B'00000000	CALL	WRITEDATA	; MUBUS <-- data	POP.W	D3	OR.B	D3,#2^BENLINE!2^BENROW	OR.B	D3,(A4)		; D3 <-- ajoute l'tat des relais 8 et 9	LOAD.W	D2,#MBWLINE	CALL	WRITEDATA	; MUBUS <-- data	JUMP'	OK$INV$:	COMP.W	D2,#MBWLINE	JUMP',EQ NINV$	NOT.B	D3	LOAD.W	D2,#MBWROW	CALL	WRITEDATA	; MUBUS <-- data	LOAD.B	D3,#B'1111!2^BENLINE!2^BENROW	OR.B	D3,(A4)		; D3 <-- ajoute l'tat des relais 8 et 9	LOAD.W	D2,#MBWLINE	CALL	WRITEDATA	; MUBUS <-- data	JUMP'	OK$NINV$:	PUSH.W	D3	LOAD.B	D3,#B'11111111	LOAD.W	D2,#MBWROW	CALL	WRITEDATA	; MUBUS <-- data	POP.W	D3	NOT.B	D3	AND.B	D3,#B'00001111	OR.B	D3,#2^BENLINE!2^BENROW	OR.B	D3,(A4)		; D3 <-- ajoute l'tat des relais 8 et 9	LOAD.W	D2,#MBWLINE	CALL	WRITEDATA	; MUBUS <-- data	JUMP'	OK$ZERO$:	LOAD.B	D3,(A4)		; D3 <-- tat des relais 8 et 9	LOAD.W	D2,#MBWLINE	CALL	WRITEDATA	; MUBUS <-- data	CLR.B	D3	LOAD.W	D2,#MBWROW	CALL	WRITEDATA	; MUBUS <-- dataOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D3,A3,A4	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	MBWROW,2^2	;  0: a1-a5	.W	MBWLINE,2^0	;  1: b1-a8	.W	MBWROW,2^1	;  2: a2-a3	.W	MBWLINE,2^1	;  3: a9-a16	.W	MBWROW,2^4	;  4: b9-b10	.W	MBWROW,2^3	;  5: a10-a14	.W	MBWROW,2^6	;  6: a17-b21	.W	MBWROW,2^5	;  7: b17-b19	.W	MBWLINE,2^2	;  8: a18-a24	.W	MBWLINE,2^3	;  9: a25-a32	.W	MBWROW,2^7	; 10: b25-b30	.W	0,0	.W	0,0	.W	0,0	.W	0,0	.W	0,0;---------\\; READDATA >;=========/; Lit une valeur dans un priphrique MUBUS.; in	D1.W	carte (0..15); out	D3.B	data; mod	D3.L, D7.WREADDATA:	PUSHM.L	D1,D2,A4	LOAD.L	A4,(A6)+OMBAD	; A4 <-- ^base de MUBUS	SL.W	D1,#2		; D1 <-- carte *4	ADD.W	D1,#MBRDET	TEST.B	(A6)+OLONG	; adaptateur MUBUS-LONG ?	JUMP',NE LONG$		; oui => LONG$	MUL.WU	D1,(A6)+OMBI	LOAD.B	D3,(A4)+(D1.W)	; D3 <-- data	JUMP'	EXIT$LONG$:	.IF	PROTODR	LOAD.W	D2,(A6)+OMBLADR	OR.B	D1,#2^7!2^6	; D1 <-- WR=0 et OE=0	LOAD.B	(A4)+(D2.W),D1	LOAD.W	D2,(A6)+OMBLCTRL	LOAD.B	(A4)+(D2.W),D3	; gnre le signal PP	LOAD.W	D2,(A6)+OMBLDATA	LOAD.B	D3,(A4)+(D2.W)	; D3 <-- lit le data	.ELSE	LOAD.W	D2,(A6)+OMBLADR	LOAD.B	(A4)+(D2.W),D1	LOAD.W	D2,(A6)+OMBLDATA	LOAD.B	D3,(A4)+(D2.W)	; D3 <-- lit le data	.ENDIFEXIT$:	POPM.L	D1,D2,A4	RET;----------\\; WRITEDATA >;==========/; Ecrit une valeur dans un priphrique MUBUS.; in	D1.W	carte (0..15);	D2.W	adresse (0..3);	D3.B	data; out	-; mod	D7.WWRITEDATA:	PUSHM.L	D1,D2,A4,A5	LOAD.L	A4,(A6)+OMBAD	; A4 <-- ^base de MUBUS	SL.W	D1,#2		; D1 <-- carte *4	ADD.W	D1,D2	TEST.B	(A6)+OLONG	; adaptateur MUBUS-LONG ?	JUMP',NE LONG$		; oui => LONG$	MUL.WU	D1,(A6)+OMBI	LOAD.B	(A4)+(D1.W),D3	JUMP'	EXIT$LONG$:	LOAD.L	A5,(A6)+OPSEM	NTREL	?LOCK	.IF	PROTODR	LOAD.W	D2,(A6)+OMBLADR;	AND.B	D1,#-1-(2^7!2^6) ; D1 <-- WR=1 et OE=1	LOAD.B	(A4)+(D2.W),D1	LOAD.W	D2,(A6)+OMBLDATA	LOAD.B	(A4)+(D2.W),D3	; crit le data	LOAD.W	D2,(A6)+OMBLCTRL	LOAD.B	(A4)+(D2.W),D3	; gnre le signal PP	.ELSE	LOAD.W	D2,(A6)+OMBLADR	LOAD.B	(A4)+(D2.W),D1	LOAD.W	D2,(A6)+OMBLDATA	LOAD.B	(A4)+(D2.W),D3	; crit le data	LOAD.W	D2,(A6)+OMBLADR	LOAD.B	(A4)+(D2.W),D1	.ENDIF;	LOAD.L	A5,(A6)+OPSEM	NTREL	?UNLOCKEXIT$:	POPM.L	D1,D2,A4,A5	RET	.END