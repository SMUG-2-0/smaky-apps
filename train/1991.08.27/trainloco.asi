	.SBTTL	TRAINLOCO.ASI;----------\\; LOCOZDETR >;==========/; Dtruit toutes les locomotives d'une zone.; in	D1.W	rang dbut (0..n);	D2.W	rang fin   (0..n); out	-; mod	D7.WLOCOZDETR:	PUSHM.L	D1,D2,A2	PUSH.L	D1	CALL	RANGXY		; D1 <-- dbut (y;x)	EX.L	D1,D2	CALL	RANGXY		; D2 <-- fin (y;x)	EX.L	D2,D1	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	POP.L	D1LOOPY$:	PUSHM.L	D1,D2	SWAP.W	D2LOOPX$:	PUSH.L	D1	CALL	XYRANG		; D1 <-- rang (0..n)	CALL	LOCOSEARCH	; A2 <-- ^descripteur loco/wagon	JUMP',NE NEXT$	CALL	LOCOKILLONE	; supprime un train (ou une partie)NEXT$:	POP.L	D1	INC.W	D1		; D1 <-- cellule suivante en X	DEC.W	D2	JUMP,NE LOOPX$	POPM.L	D1,D2	ADD.W	D1,(A6)+OCELNX	; D1 <-- cellule suivante en Y	DEC.W	D2	JUMP,NE LOOPY$	POPM.L	D1,D2,A2	RET;-----------\\; LOCOSEARCH >;===========/; Cherche une locomotive ou un wagon d'aprs son rang.; in	D1.W	rang (0..n); out	A2.L	^descripteur loco/wagon;	D7.W	erreur; mod	D7.W, A2.LLOCOSEARCH:	PUSHM.L	D2,A4	LOAD.L	A2,#(A6)+ODLOC	LOAD.W	D2,#MAXLOCO-1LOOP$:	TEST.W	(A2)+OLOICO	JUMP',EQ NEXT$	COMP.W	D1,(A2)+OLORAN	JUMP',EQ FOUND$NEXT$:	LOAD.L	A2,#(A2)+LLO	; A2 <-- ^descripteur suivant	DECJ.W,NMO D2,LOOP$ERROR$:	LOAD.W	D7,#1		; D7 <-- pas trouv	JUMP	EXIT$FOUND$:	CALL	CELGETP		; A4 <-- ^cellule sous la loco	JUMP',NE OK$	COMP.B	(A4)+OCEICO,#ICORHVV	JUMP',EQ VERTI$	COMP.B	(A4)+OCEICO,#ICORHVH	JUMP',NE OK$HORIZ$:	COMP.W	(A2)+OLOICO,#ICOLOCOU	JUMP,EQ ERROR$	COMP.W	(A2)+OLOICO,#ICOLOCOD	JUMP,EQ ERROR$	JUMP'	OK$VERTI$:	COMP.W	(A2)+OLOICO,#ICOLOCOL	JUMP,EQ ERROR$	COMP.W	(A2)+OLOICO,#ICOLOCOR	JUMP,EQ ERROR$;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; LOCOCLR >;========/; Enlve toutes les locomotives, si ncessaire.; in	-; out	-; mod	D7.WLOCOCLR:	PUSHM.L	D2,A2	COMP.W	(A6)+OPALNIV,#ICODRAW	JUMP',EQ EXIT$	TEST.B	(A6)+OLDRAW	; locomotives dj enleves ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.L	A2,#(A6)+ODLOC	LOAD.W	D2,#MAXLOCO-1LOOP$:	TEST.W	(A2)+OLOICO	JUMP',EQ NEXT$	TEST.W	(A2)+OLONPW	; est-ce la locomotive ?	JUMP',NE NEXT$	CALL	LOCOINV		; efface le train (loco/wagons)NEXT$:	LOAD.L	A2,#(A2)+LLO	; A2 <-- ^descripteur suivant	DECJ.W,NMO D2,LOOP$	CLR.B	(A6)+OLDRAWEXIT$:	POPM.L	D2,A2	RET;--------\\; LOCOSET >;========/; Remet toutes les locomotives, si ncessaire.; in	-; out	-; mod	D7.WLOCOSET:	PUSHM.L	D2,A2	COMP.W	(A6)+OPALNIV,#ICODRAW	JUMP',EQ EXIT$	TEST.B	(A6)+OLDRAW	; locomotives dj dessines ?	JUMP',NE EXIT$		; oui => EXIT$	SET.B	(A6)+OLDRAW	LOAD.L	A2,#(A6)+ODLOC	LOAD.W	D2,#MAXLOCO-1LOOP$:	TEST.W	(A2)+OLOICO	JUMP',EQ NEXT$	TEST.W	(A2)+OLONPW	; est-ce la locomotive ?	JUMP',NE NEXT$	CALL	LOCOINV		; dessine le train (loco/wagons)NEXT$:	LOAD.L	A2,#(A2)+LLO	; A2 <-- ^descripteur suivant	DECJ.W,NMO D2,LOOP$EXIT$:	POPM.L	D2,A2	RET;--------\\; LOCONEW >;========/; Pose un nouveau train avec une locomotive et plusieurs wagons.; in	D1.W	rang cellule (0..n);	D2.W	nb de wagons souhaits (0..n); out	D7.W	erreur; mod	D7.WLOCONEW:	PUSHM.L	D0..D4,A1..A5	LOAD.W	D0,D2		; D0 <-- nb de wagons	LOAD.W	D4,(A6)+OLOCO	; D4 <-- icne slectionne	LOAD.L	A3,#R16"TRAILH$	LOAD.W	D3,#ICOLOCOL	COMP.W	D4,#9	JUMP',EQ PUT$	LOAD.W	D3,#ICOLOCOR	COMP.W	D4,#11	JUMP',EQ PUT$	LOAD.L	A3,#R16"TRAILV$	LOAD.W	D3,#ICOLOCOU	COMP.W	D4,#7	JUMP',EQ PUT$	LOAD.W	D3,#ICOLOCODPUT$:	CALL	CELGETP		; A4 <-- ^cellule sous la loco	JUMP,NE EXIT$	CLR.W	D2	LOAD.B	D2,(A4)+OCEICO	LOAD.W	D7,#1		; D7 <-- impossibleSLOOP$:	LOAD.W	D4,(A3+)	JUMP,EQ EXIT$	COMP.W	D4,D2	JUMP,NE SLOOP$	CALL	LOCONEWONE	; cre la locomotive	JUMP,NE EXIT$	LOAD.L	A5,A2		; A5 <-- ^locomotive	TEST.W	D0	JUMP,EQ DRAW$WLOOP$:	LOAD.L	A1,A2		; A1 <-- ^pre	CALL	LOCOSTEPROT	; D2 <-- icne loco tourne	JUMP,EQ DRAW$	PUSH.W	(A2)+OLOICO	CALL	LOCOREVERSE	CALL	LOCOSTEPLIN	; D2 <-- rang pour wagon	POP.W	(A2)+OLOICO	TEST.W	D7	JUMP',NE DRAW$	LOAD.W	D1,D2	CALL	LOCONEWONE	; A2 <-- cre un wagon	JUMP',NE DRAW$	CALL	LOCODR		; D2 <-- numro du wagon cr	LOAD.W	(A1)+OLONNW,D2	; (pre) <-- no du wagon fils	EX.L	A1,A2	CALL	LOCODR		; D2 <-- numro du wagon pre	EX.L	A2,A1	LOAD.W	(A2)+OLONPW,D2	; (fils) <-- no du wagon pre	DEC.W	D0	JUMP,NE WLOOP$DRAW$:	LOAD.L	A2,A5		; A2 <-- ^locomotive	CALL	LOCOINV		; dessine la loco et les wagons	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A1..A5	TEST.W	D7		; retour EQ/NE	RETTRAILH$:	.W	ICORH	.W	ICORHS	.W	ICORHD	.W	ICORHC	.W	ICORHR	.W	ICORHV	.W	0TRAILV$:	.W	ICORV	.W	ICORVS	.W	ICORVD	.W	ICORVC	.W	ICORVR	.W	ICORHV	.W	0;-----------\\; LOCONEWONE >;-----------/; Pose une nouvelle locomotive ou un nouveau wagon.; in	D1.W	rang cellule (0..n);	D3.W	icne (ICOLOCO?); out	A2.L	^descripteur;	D7.W	erreur; mod	D7.W, A2.LLOCONEWONE:	PUSHM.L	D2	LOAD.L	A2,#(A6)+ODLOC	LOAD.W	D2,#MAXLOCO-1LOOP$:	TEST.W	(A2)+OLOICO	; libre ?	JUMP',EQ NEW$		; oui => NEW	LOAD.L	A2,#(A2)+LLO	; A2 <-- ^descripteur suivant	DECJ.W,NMO D2,LOOP$	LOAD.W	D7,#ERMLOCO	; D7 <-- y'a plus !	JUMP'	EXIT$NEW$:	CALL	LOCOIFOCC	; position dj occupe ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.W	(A2)+OLOICO,D3	LOAD.W	(A2)+OLORAN,D1	CLR.W	(A2)+OLONNW	; pas de suivant	CLR.W	(A2)+OLONPW	; pas de prcdent	CLR.B	(A2)+OLOFLG	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2	TEST.W	D7		; retour EQ/NE	RET;------------\\; LOCOREVERSE >;============/; Retourne un locomotive.; in	A2.L	^descripteur loco; out	-; mod	D7.WLOCOREVERSE:	PUSHM.L	D2,D3	LOAD.W	D2,(A2)+OLOICO	LOAD.W	D3,#ICOLOCOL	COMP.W	D2,#ICOLOCOR	JUMP',EQ REV$	LOAD.W	D3,#ICOLOCOR	COMP.W	D2,#ICOLOCOL	JUMP',EQ REV$	LOAD.W	D3,#ICOLOCOD	COMP.W	D2,#ICOLOCOU	JUMP',EQ REV$	LOAD.W	D3,#ICOLOCOU	COMP.W	D2,#ICOLOCOD	JUMP',NE EXIT$REV$:	LOAD.W	(A2)+OLOICO,D3EXIT$:	POPM.L	D2,D3	RET;---------\\; LOCOHEAD >;=========/; Cherche la locomotive d'un train.; in	A2.L	^descripteur loco/wagon; out	A2.L	^descripteur loco; mod	D7.W, A2.LLOCOHEAD:LOOP$:	CALL	LOCOPREV	; A2 <-- ^descripteur prcdent	JUMP,EQ LOOP$	RET;---------\\; LOCOKILL >;=========/; Enlve toutes les locomotives.; in	-; out	-; mod	D7.WLOCOKILL:	PUSHM.L	D2,A2	LOAD.L	A2,#(A6)+ODLOC	LOAD.W	D2,#MAXLOCO-1LOOP$:	TEST.W	(A2)+OLOICO	JUMP',EQ NEXT$	TEST.W	(A2)+OLONPW	; est-ce la locomotive ?	JUMP',NE NEXT$	CALL	LOCOKILLONE	; supprime un trainNEXT$:	LOAD.L	A2,#(A2)+LLO	; A2 <-- ^descripteur suivant	DECJ.W,NMO D2,LOOP$	POPM.L	D2,A2	RET;------------\\; LOCOKILLONE >;============/; Supprime une locomotive est tous ses wagons, ou seulement; quelques wagons.; in	A2.L	^descripteur loco/wagon; out	-; mod	D7.WLOCOKILLONE:	PUSHM.L	A2,A3	LOAD.L	A3,A2	CALL	LOCOPREV	; A3 <-- ^descripteur wagon prcdent	EX.L	A2,A3	JUMP',NE LOOP$	CLR.W	(A3)+OLONNW	; le pre n'a plus de suivantLOOP$:	CALL	LOCOINVONE	; efface loco/wagon	CLR.W	(A2)+OLOICO	; supprime loco/wagon	CALL	LOCONEXT	; A2 <-- ^descripteur wagon suivant	JUMP,EQ LOOP$	POPM.L	A2,A3	RET;---------\\; LOCOSTEP >;=========/; Avance toutes les locomotives.; in	-; out	-; mod	D7.WLOCOSTEP:	PUSHM.L	D0..D2,A2,A4	NOT.B	(A6)+OLDEMI	; demi-avance suivante	CLR.W	D0		; D0 <-- nb de collisions	LOAD.L	A2,#(A6)+ODLOC	LOAD.W	D2,#MAXLOCO-1LOOP$:	TEST.W	(A2)+OLOICO	JUMP,EQ NEXT$	TEST.W	(A2)+OLONPW	; est-ce la locomotive ?	JUMP,NE NEXT$; Si la loco est sur un secteur stopp, n'avance pas.	TEST.B	(A2)+OLOFLG:#BLODAV	JUMP',BS PASS$	LOAD.W	D1,(A2)+OLORAN	CALL	CELGETP		; A4 <-- ^cellule sous la loco	JUMP,NE NEXT$	COMP.B	(A4)+OCEICO,#ICORHS	JUMP',EQ SECT$	COMP.B	(A4)+OCEICO,#ICORVS	JUMP',NE PASS$SECT$:	TEST.B	(A4)+OCEETA	; secteur stopp ?	JUMP,EQ NEXT$		; oui => NEXT$; Avance tout le train (loco/wagons).PASS$:	PUSH.L	A2WLOOP$:	CALL	LOCOSTEPONE	; avance locomotive/wagon	JUMP',NE CRASH$	CALL	LOCONEXT	; A2 <-- ^wagon suivant	JUMP,EQ WLOOP$	POP.L	A2	JUMP'	NEXT$CRASH$:	POP.L	A2	CALL	LOCOCRASH	; paf, collision ...	INC.W	D0		; D0 <-- une collision de plusNEXT$:	LOAD.L	A2,#(A2)+LLO	; A2 <-- ^descripteur suivant	DECJ.W,NMO D2,LOOP$	TEST.W	D0		; y a-t-il eu des collisions ?	JUMP',EQ NOSTOP$	; non => NOSTOP$	CALL	LOCOSTOP	; stoppe le mouvement des locomotivesNOSTOP$:	TEST.B	(A6)+OLDEMI	; demi-avance ?	JUMP',T EXIT$	CALL	LOCOCELPOS	; mj position locos/wagons	CALL	LOCOSTEPDET	; simule le passage sur les dtecteursEXIT$:	POPM.L	D0..D2,A2,A4	RET;------------\\; LOCOSTEPDET >;------------/; Simule le passage des locomotives sur les dtecteurs.; in	-; out	-; mod	D7.WLOCOSTEPDET:	PUSHM.L	D1,D2,A2,A4	LOAD.L	A2,#(A6)+ODLOC	LOAD.W	D2,#MAXLOCO-1LOOP$:	TEST.W	(A2)+OLOICO	JUMP',EQ NEXT$	TEST.W	(A2)+OLONPW	; est-ce la locomotive ?	JUMP',NE NEXT$	LOAD.W	D1,(A2)+OLORAN	CALL	CELGETP		; A4 <-- ^cellule sous la loco	JUMP',NE NEXT$	COMP.B	(A4)+OCEICO,#ICORHR	JUMP',EQ DET$	COMP.B	(A4)+OCEICO,#ICORVR	JUMP',NE NEXT$DET$:	CALL	ALGOSND		; simule le passage d'un train sur un dtecteur !NEXT$:	LOAD.L	A2,#(A2)+LLO	; A2 <-- ^descripteur suivant	DECJ.W,NMO D2,LOOP$	POPM.L	D1,D2,A2,A4	RET;------------\\; LOCOSTEPONE >;------------/; Avance une locomotive ou un wagon.; in	A2.L	^descripteur loco; out	D7.W	erreur; mod	D7.WLOCOSTEPONE:	PUSHM.L	D1,D2,A4	TEST.B	(A6)+OLDEMI	; demi-avance en cours ?	JUMP,T	DEMI$; Essaye d'avancer la loco tout droit.	TEST.B	(A2)+OLOFLG:#BLODAV	JUMP,BC OK$	CALL	LOCOSTEPLIN	; D2 <-- rang loco avance	JUMP,NE CRASH$	LOAD.W	D1,D2	CALL	LOCOIFOCC	; position dj occupe ?	JUMP,NE CRASH$		; oui => CRASH$	TSET.B	(A2)+OLOFLG:#BLODAV	CALL	LOCOINVONE	; enlve loco/wagon	LOAD.W	(A2)+OLORAN,D2	TCLR.B	(A2)+OLOFLG:#BLODAV	CALL	LOCOINVONE	; remet loco/wagon	JUMP	OK$; Avance la loco d'un demi-pas, pour obtenir un mouvement plus fluide.DEMI$:	TEST.B	(A2)+OLOFLG:#BLODAV	JUMP,BS OK$	TCLR.B	(A2)+OLOFLG:#BLODAV	CALL	LOCOINVONE	; enlve loco/wagon	CALL	LOCOSTEPROT	; D2 <-- icne loco tourne	JUMP',NE DAVANCE$	LOAD.W	(A2)+OLOICO,D2DAVANCE$:	TSET.B	(A2)+OLOFLG:#BLODAV	CALL	LOCOINVONE	; remet loco/wagon	JUMP'	OK$; Et voil la fin d'une belle locomotive !CRASH$:	LOAD.W	D7,#ERMCOLL	; D7 <-- collision	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; LOCOSTEPROT >;------------/; Essaye de tourner une locomotive (rail courbe, aiguillage, etc.).; in	A2.L	^descripteur loco; out	D2.W	nouvelle icne;	D7.W	erreur; mod	D2.L, D7.WLOCOSTEPROT:	PUSHM.L	D1,D3,A3,A4	LOAD.W	D3,(A2)+OLOICO	; D3 <-- icne de la locomotive	LOAD.L	A3,#R16"TTLOCOR$	COMP.W	D3,#ICOLOCOR	JUMP',EQ TOURNE$	LOAD.L	A3,#R16"TTLOCOL$	COMP.W	D3,#ICOLOCOL	JUMP',EQ TOURNE$	LOAD.L	A3,#R16"TTLOCOD$	COMP.W	D3,#ICOLOCOD	JUMP',EQ TOURNE$	LOAD.L	A3,#R16"TTLOCOU$	COMP.W	D3,#ICOLOCOU	JUMP,NE ERROR$TOURNE$:	LOAD.W	D1,(A2)+OLORAN	CALL	CELGETP		; A4 <-- ^cellule sous la loco	JUMP,NE ERROR$TLOOP$:	CLR.W	D3	LOAD.B	D3,(A4)+OCEICO	COMP.W	D3,(A3)+0	JUMP',EQ TFOUND$	ADD.L	A3,#6	TEST.W	(A3)	JUMP,NE TLOOP$	JUMP'	ERROR$TFOUND$:	COMP.W	(A3)+2,#-1	JUMP',EQ TGO$	CLR.W	D3	LOAD.B	D3,(A4)+OCEETA	COMP.W	D3,(A3)+2	JUMP',NE ERROR$TGO$:	LOAD.W	D2,(A3)+4	; D2 <-- icne locomotive tourne	CLR.W	D7		; D7 <-- loco tourne	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1		; D7 <-- rotation impossibleEXIT$:	POPM.L	D1,D3,A3,A4	TEST.W	D7		; retour EQ/NE	RETTTLOCOR$:	.W	ICORUL	-1	ICOLOCOU	.W	ICORDL	-1	ICOLOCOD	.W	ICORHUL	0	ICOLOCOU	.W	ICORHDL	0	ICOLOCOD	.W	ICORVUL	-1	ICOLOCOU	.W	ICORVDL	-1	ICOLOCOD	.W	ICORTJD1 0	ICOLOCOU	.W	ICORTJD2 0	ICOLOCOD	.W	0TTLOCOL$:	.W	ICORUR	-1	ICOLOCOU	.W	ICORDR	-1	ICOLOCOD	.W	ICORHUR	0	ICOLOCOU	.W	ICORHDR	0	ICOLOCOD	.W	ICORVUR	-1	ICOLOCOU	.W	ICORVDR	-1	ICOLOCOD	.W	ICORTJD1 0	ICOLOCOD	.W	ICORTJD2 0	ICOLOCOU	.W	0TTLOCOD$:	.W	ICORUR	-1	ICOLOCOR	.W	ICORUL	-1	ICOLOCOL	.W	ICORHUR	-1	ICOLOCOR	.W	ICORHUL	-1	ICOLOCOL	.W	ICORVUR	0	ICOLOCOR	.W	ICORVUL	0	ICOLOCOL	.W	ICORTJD1 0	ICOLOCOL	.W	ICORTJD2 0	ICOLOCOR	.W	0TTLOCOU$:	.W	ICORDR	-1	ICOLOCOR	.W	ICORDL	-1	ICOLOCOL	.W	ICORHDR	-1	ICOLOCOR	.W	ICORHDL	-1	ICOLOCOL	.W	ICORVDR	0	ICOLOCOR	.W	ICORVDL	0	ICOLOCOL	.W	ICORTJD1 0	ICOLOCOR	.W	ICORTJD2 0	ICOLOCOL	.W	0;------------\\; LOCOSTEPLIN >;------------/; Essaye d'avancer une locomotive (rail droit, aiguillage, etc.).; in	A2.L	^descripteur loco; out	D2.W	nouveau rang;	D7.W	erreur; mod	D2.L, D7.WLOCOSTEPLIN:	PUSHM.L	D1,D3,A3,A4	LOAD.W	D3,(A2)+OLOICO	; D3 <-- icne de la locomotive	LOAD.L	A3,#R16"TALOCOR$	LOAD.W	D2,#+1		; D2 <-- +1 en X	COMP.W	D3,#ICOLOCOR	JUMP',EQ DEVANT$	LOAD.L	A3,#R16"TALOCOL$	NEG.W	D2		; D2 <-- -1 en X	COMP.W	D3,#ICOLOCOL	JUMP',EQ DEVANT$	LOAD.L	A3,#R16"TALOCOD$	LOAD.W	D2,(A6)+OCELNX	; D2 <-- +1 en Y	COMP.W	D3,#ICOLOCOD	JUMP',EQ DEVANT$	LOAD.L	A3,#R16"TALOCOU$	NEG.W	D2		; D2 <-- -1 en Y	COMP.W	D3,#ICOLOCOU	JUMP',NE ERROR$DEVANT$:	LOAD.W	D1,(A2)+OLORAN	ADD.W	D1,D2		; D1 <-- rang cellule devant la loco	CALL	CELGETP		; A4 <-- ^cellule devant la loco	JUMP',NE ERROR$ALOOP$:	CLR.W	D3	LOAD.B	D3,(A4)+OCEICO	COMP.W	D3,(A3)+0	JUMP',EQ AFOUND$	ADD.L	A3,#2	TEST.W	(A3)	JUMP,NE ALOOP$	JUMP'	ERROR$AFOUND$:	LOAD.W	D2,D1		; D2 <-- rang locomotive avance	CLR.W	D7		; D7 <-- loco avance	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1		; D7 <-- avance impossibleEXIT$:	POPM.L	D1,D3,A3,A4	TEST.W	D7		; retour EQ/NE	RETTALOCOR$:	.W	ICORH	.W	ICORUL	.W	ICORDL	.W	ICORVUL	.W	ICORVDL	.W	ICORHS	.W	ICORHD	.W	ICORHC	.W	ICORHR	.W	ICORHUR	.W	ICORHUL	.W	ICORHDR	.W	ICORHDL	.W	ICORTJD1	.W	ICORTJD2	.W	ICORHV	.W	ICORHVH	.W	ICORHVV	.W	0TALOCOL$:	.W	ICORH	.W	ICORUR	.W	ICORDR	.W	ICORVUR	.W	ICORVDR	.W	ICORHS	.W	ICORHD	.W	ICORHC	.W	ICORHR	.W	ICORHUR	.W	ICORHUL	.W	ICORHDR	.W	ICORHDL	.W	ICORTJD1	.W	ICORTJD2	.W	ICORHV	.W	ICORHVH	.W	ICORHVV	.W	0TALOCOD$:	.W	ICORV	.W	ICORUR	.W	ICORUL	.W	ICORHUR	.W	ICORHUL	.W	ICORVS	.W	ICORVD	.W	ICORVC	.W	ICORVR	.W	ICORVUR	.W	ICORVUL	.W	ICORVDR	.W	ICORVDL	.W	ICORTJD1	.W	ICORTJD2	.W	ICORHV	.W	ICORHVH	.W	ICORHVV	.W	0TALOCOU$:	.W	ICORV	.W	ICORDR	.W	ICORDL	.W	ICORHDR	.W	ICORHDL	.W	ICORVS	.W	ICORVD	.W	ICORVC	.W	ICORVR	.W	ICORVUR	.W	ICORVUL	.W	ICORVDR	.W	ICORVDL	.W	ICORTJD1	.W	ICORTJD2	.W	ICORHV	.W	ICORHVH	.W	ICORHVV	.W	0;----------\\; LOCOIFOCC >;----------/; Vrifie si une position est occupe par une locomotive ou un wagon.; in	D1.W	rang cherch (0..n); out	D7.W	erreur si occup; mod	D7.WLOCOIFOCC:	PUSHM.L	A2,A4	CALL	CELGETP		; A4 <-- ^cellule sous la loco	JUMP',NE OK$	COMP.B	(A4)+OCEICO,#ICORHVV	JUMP',EQ OK$	COMP.B	(A4)+OCEICO,#ICORHVH	JUMP',EQ OK$	CALL	LOCOSEARCH	; A2 <-- ^descripteur loco/wagon	JUMP',NE OK$	LOAD.W	D7,#ERMCOLL	; D7 <-- occup	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- libreEXIT$:	POPM.L	A2,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; LOCOCRASH >;==========/; Collision avec une locomotive.; in	A2.L	^descripteur loco/wagon; out	-; mod	D7.WLOCOCRASH:	PUSHM.L	D0..D4,A2	LOAD.B	D3,#BIPERR	LIB	?BEEP		; grand bruit	LOAD.W	D1,(A2)+OLORAN	; D1 <-- rang	CALL	CELPOS		; D3/D4 <-- position/dimensions	JUMP,NE KILL$	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	PUSH.L	D3	LOAD.L	D3,#H'10000*COLORFDRAW+COLORCRASH	CALL	DESCOLOR	POP.L	D3	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4		; D3 <-- centre de la cellule	SWAP.W	D3;	SWAP.W	D4	LOAD.W	D0,#(4*2)-1GLOOP$:	LOAD.W	D4,#5		; D4 <-- rayon initial	CLR.W	D1CLOOP$:	LOAD.W	D2,#INVDOT	LIB	?DRCERCLE	; dessine un cercle	INC.W	D1	ADD.W	D4,D1		; D4 <-- rayon suivant	COMP.W	D4,#200	JUMP,LO CLOOP$	DECJ.W,NMO D0,GLOOP$	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSFKILL$:	CALL	LOCOHEAD	; A2 <-- ^locomotive	CALL	LOCOKILLONE	; supprime tout le train !!!	POPM.L	D0..D4,A2	RET;---------\\; LOCOSTOP >;=========/; Stoppe le mouvement des locomotives.; in	-; out	-; mod	D7.WLOCOSTOP:	PUSHM.L	D1,D2	CALL	PUTSTOP		; stoppe tout	TEST.B	(A6)+OLMOVE	JUMP',EQ EXIT$	CLR.B	(A6)+OLMOVE	; stoppe le mouvement des locomotives	LOAD.W	D2,#ICOMOD	LOAD.W	D1,#34	CALL	PALINVIF	; inverse l'icneEXIT$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; LOCODEMI >;=========/; Fini la demi-avance en cours si ncessaire.; in	-; out	-; mod	D7.WLOCODEMI:	TEST.B	(A6)+OLDEMI	; demi-avance ?	JUMP',F EXIT$	CALL	LOCOSTEP	; fin de la demi-avanceEXIT$:	RET;-----------\\; LOCOCELPOS >;===========/; Informe toutes les cellules qui ont une locomotive ou un wagon.; in	-; out	-; mod	D7.WLOCOCELPOS:	PUSHM.L	D1..D4,A2,A4; Enlve les locomotives dans toutes les cellules.	LOAD.L	A4,(A6)+OPCEL	LOAD.W	D4,(A6)+OCELNX	MUL.WU	D4,(A6)+OCELNY	DEC.W	D4CLOOP$:	CLR.B	(A4)+OCENLO	; y'a rien	LOAD.L	A4,#(A4)+LCE	; A4 <-- ^cellule suivante	DECJ.W,NMO D4,CLOOP$; Met toutes les locomotives dans les cellules.	LOAD.L	A2,#(A6)+ODLOC	LOAD.W	D2,#MAXLOCO-1	LOAD.W	D3,#1		; D3 <-- rang initialLOOP$:	TEST.W	(A2)+OLOICO	JUMP',EQ NEXT$	LOAD.W	D1,(A2)+OLORAN	CALL	CELGETP		; A4 <-- ^cellule devant la loco	JUMP',NE NEXT$	COMP.B	(A4)+OCEICO,#ICORHVV	JUMP',EQ VERTI$	COMP.B	(A4)+OCEICO,#ICORHVH	JUMP',NE MAJ$HORIZ$:	COMP.W	(A2)+OLOICO,#ICOLOCOU	JUMP',EQ NEXT$	COMP.W	(A2)+OLOICO,#ICOLOCOD	JUMP',EQ NEXT$	JUMP'	MAJ$VERTI$:	COMP.W	(A2)+OLOICO,#ICOLOCOL	JUMP',EQ NEXT$	COMP.W	(A2)+OLOICO,#ICOLOCOR	JUMP',EQ NEXT$;	JUMP'	MAJ$MAJ$:	LOAD.B	(A4)+OCENLO,D3	; OCENLO <-- rang locomotive sur la celluleNEXT$:	INC.W	D3	LOAD.L	A2,#(A2)+LLO	; A2 <-- ^descripteur suivant	DECJ.W,NMO D2,LOOP$	POPM.L	D1..D4,A2,A4	RET;--------\\; LOCOINV >;========/; Inverse tout un train (locomotive et wagons).; in	A2.L	^descripteur loco; out	-; mod	D7.WLOCOINV:	PUSH.L	A2	COMP.W	(A6)+OPALNIV,#ICODRAW	JUMP',EQ EXIT$	TEST.B	(A6)+OLDRAW	JUMP',F EXIT$LOOP$:	CALL	LOCOINVONE	; inverse locomotive/wagon	CALL	LOCONEXT	; A2 <-- ^wagon suivant	JUMP,EQ LOOP$EXIT$:	POP.L	A2	RET;-----------\\; LOCOINVONE >;-----------/; Inverse une locomotive ou un wagon.; in	A2.L	^descripteur loco/wagon; out	-; mod	D7.WLOCOINVONE:	PUSHM.L	D0..D6,A2..A4	COMP.W	(A6)+OPALNIV,#ICODRAW	JUMP,EQ EXIT$	TEST.B	(A6)+OLDRAW	JUMP,F EXIT$	TEST.B	(A2)+OLOFLG:#BLODAV ; demi-avance ?	JUMP',BS POS$		; oui => POS$	LOAD.W	D1,(A2)+OLORAN	; D1 <-- rang	CALL	CELGETP		; A4 <-- ^cellule sous la loco	JUMP',NE POS$	COMP.B	(A4)+OCEICO,#ICORHVV	JUMP',EQ VERTI$	COMP.B	(A4)+OCEICO,#ICORHVH	JUMP',NE POS$HORIZ$:	COMP.W	(A2)+OLOICO,#ICOLOCOU	JUMP,EQ EXIT$	COMP.W	(A2)+OLOICO,#ICOLOCOD	JUMP,EQ EXIT$	JUMP'	POS$VERTI$:	COMP.W	(A2)+OLOICO,#ICOLOCOL	JUMP,EQ EXIT$	COMP.W	(A2)+OLOICO,#ICOLOCOR	JUMP,EQ EXIT$;	JUMP'	POS$POS$:	LOAD.W	D1,(A2)+OLORAN	; D1 <-- rang	CALL	CELPOS		; D3/D4 <-- position/dimensions	JUMP,NE EXIT$	LOAD.L	D2,D4		; D2 <-- dimensions	LOAD.L	D4,D3		; D4 <-- position (y;x)	LOAD.W	D3,(A2)+OLOICO	; D3 <-- icne	JUMP,EQ EXIT$	PUSH.L	(A0)+ODFCSF	PUSH.L	(A0)+ODFCCF	PUSH.L	D3	LOAD.L	D3,#H'10000*COLORFDRAW+COLORLOCO	CALL	DESCOLOR	POP.L	D3	TEST.B	(A2)+OLOFLG:#BLODAV ; demi-avance ?	JUMP,BC DRAW$		; non => DRAW$	SR.W	D2,#1		; D2 <-- demi-distance	COMP.W	D3,#ICOLOCOR	JUMP',EQ LOCOR$	COMP.W	D3,#ICOLOCOL	JUMP',EQ LOCOL$	COMP.W	D3,#ICOLOCOU	JUMP',EQ LOCOU$LOCOD$:	SWAP.W	D4	ADD.W	D4,D2	SWAP.W	D4	JUMP'	DRAW$LOCOU$:	SWAP.W	D4	SUB.W	D4,D2	SWAP.W	D4	JUMP'	DRAW$LOCOL$:	SUB.W	D4,D2	JUMP'	DRAW$LOCOR$:	ADD.W	D4,D2;	JUMP'	DRAW$DRAW$:	TEST.W	(A2)+OLONPW	; est-ce la locomotive ?	JUMP',EQ LOCO$		; oui => LOCO$	ADD.W	D3,#4		; D3 <-- icne wagonLOCO$:	CALL	CCMO		; enlve la souris	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	LOAD.L	A3,(A6)+OPGICO	LOAD.W	D2,D3	LOAD.W	D0,D3	AND.W	D0,#H'7F	MUL.WU	D0,(A3)+OGCMSB	ADD.L	D0,#OGCWID+(3*128)	ADD.L	A3,D0		; A3 <-- ^source (dans ITP17)	CLR.L	D3	TEST.L	D2:#7	JUMP',BC POSX$	LOAD.W	D3,#CELDIMPOSX$:	LOAD.W	D5,#32/8	; D5 <-- Iy source	LOAD.L	D2,#H'10000*CELDIM+CELDIM	LOAD.W	D1,#INVDOT	LOAD.L	A2,A0	GRA_	RASTER		; inverse la locomotive	POP.L	(A0)+ODFCCF	POP.L	(A0)+ODFCSFEXIT$:	POPM.L	D0..D6,A2..A4	RET;---------\\; LOCONEXT >;=========/; Cherche le descripteur suivant.; in	A2.L	^descripteur loco/wagon; out	A2.L	^descripteur loco/wagon suivant;	D7.W	erreur; mod	D7.W, A2.LLOCONEXT:	PUSH.L	D2	LOAD.W	D7,#1		; D7 <-- y'a pas	LOAD.W	D2,(A2)+OLONNW	; y a-t-il un wagon suivant ?	JUMP',EQ EXIT$	CALL	LOCORD		; A2 <-- ^descripteur wagon	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;---------\\; LOCOPREV >;=========/; Cherche le descripteur prcdent.; in	A2.L	^descripteur loco/wagon; out	A2.L	^descripteur loco/wagon prcdent;	D7.W	erreur; mod	D7.W, A2.LLOCOPREV:	PUSH.L	D2	LOAD.W	D7,#1		; D7 <-- y'a pas	LOAD.W	D2,(A2)+OLONPW	; y a-t-il un wagon prcdent ?	JUMP',EQ EXIT$	CALL	LOCORD		; A2 <-- ^descripteur wagon	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; LOCODR  >;========/; Cherche le numro d'aprs un descripteur.; in	A2.L	^descripteur loco/wagon; out	D2.W	numro (1..n); mod	D2.L, D7.WLOCODR:	PUSH.L	A2	LOAD.L	D2,A2	LOAD.L	A2,#(A6)+ODLOC	SUB.L	D2,A2	DIV.WU	D2,#LLO	INC.W	D2		; D2 <-- numro	POP.L	A2	RET;--------\\; LOCORD  >;========/; Cherche le descripteur d'aprs un numro.; in	D2.W	numro (1..n); out	A2.L	^descripteur; mod	D7.W, A2.LLOCORD:	PUSH.L	D2	LOAD.L	A2,#(A6)+ODLOC	DEC.W	D2	MUL.WU	D2,#LLO	ADD.L	A2,D2		; A2 <-- ^descripteur loco/wagon	POP.L	D2	RET	.END