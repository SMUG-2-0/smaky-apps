PROGRAM Testtrain;	{ Permet un test de la carte TRAIN SDA }			{ M. Oggier }{$I pas_ntrel.bib}{$I pas_libgra.bib}{$I pas_libmisc.bib}{$I pas_libmk.bib}CONSTAdcarte= $3C;					{ sans cavalier }Ad_w0= Adcarte;					Ad_w1= Adcarte+1;Ad_w2= Adcarte+2;Ad_r0= Adcarte;VAR Admubus,Ns,Key: LongInt; X,Y,Tm,Fact,Index: Integer; P,M: String; Ev: Keyevent; Code,Pcode: Char; Sshift: Setsupershift; Masque0,Masque1,Masque2: Byte; {---------------------------------------------} PROCEDURE Affmenu1 ;VAR M: Menu; BEGIN M[1] := ''; M[2] := 'Fin'; M[3] := ''; M[4] := '    Secteurs     '; M[5] := ''; M[6] := '   Aiguillages   '; M[7] := ''; M[8] := '   Dtecteurs    '; M[9] := ''; M[10]:= '   Test continu  '; M[11]:= ''; M[12]:= ''; Lib_afmenu (M);END;{ affmenu1}{----------------------------------------------}PROCEDURE Cadre;BEGIN Lib_drrect(0,0,638,335,Setdot); Lib_drrect(2,2,634,331,Setdot);END; {procedure cadre}{----------------------------------------}PROCEDURE Secteurs; BEGIN  Lib_setcurs(100,150); Write('Teste les 10 secteurs (relais ERNI)');  Masque0:= $00; Masque2:= $00; Poke(Admubus+Fact*Ad_w0,Masque0);			{ dclenche tous les relais } Poke(Admubus+Fact*Ad_w2,Masque2); Delay(300);  Index:= 0;  FOR X:= 0 TO 7 DO					{ 1  8 }  BEGIN   SetBit(Masque0,Index);   Poke(Admubus+Fact*Ad_w0,Masque0);   Delay(300);   Inc(Index);  END;   Index:= 6; FOR X:= 0 TO 1 DO					{ 9 et 10 }  BEGIN   SetBit(Masque2,Index);   Poke(Admubus+Fact*Ad_w2,Masque2);   Delay(300);   Inc(Index);  END;  Delay(500);  Index:=0; FOR X:= 0 TO 7 DO  BEGIN   ClrBit(Masque0,Index);   Poke(Admubus+Fact*Ad_w0,Masque0);   Delay(300);   Inc(Index);  END;   Index:= 6; FOR X:= 0 TO 1 DO  BEGIN   ClrBit(Masque2,Index);   Poke(Admubus+Fact*Ad_w2,Masque2);   Delay(300);   Inc(Index);  END;   Lib_setcurs(100,150); Write('                                    ');  Lib_beep(Bipend);END; { Secteurs }{----------------------------------------------------}PROCEDURE Aiguillages;PROCEDURE En_disable(Del:Integer);		{ drivers ON-pause-OFF } BEGIN   SetBit(Masque2,4);  SetBit(Masque2,5);  Poke(Admubus+Fact*Ad_w2,Masque2);  Delay(Del);  ClrBit(Masque2,4);  ClrBit(Masque2,5);  Poke(Admubus+Fact*Ad_w2,Masque2);  END; { En_disable }PROCEDURE Colonne; BEGIN  Poke(Admubus+Fact*Ad_w2,Masque2);  FOR Index:= 0 TO 7 DO   BEGIN   ClrBit(Masque1,Index);   Poke(Admubus+Fact*Ad_w1,Masque1);   En_disable(300);   SetBit(Masque1,Index);  END;   Masque1:= $00;					{ toutes les LED de la ligne } Poke(Admubus+Fact*Ad_w1,Masque1); En_disable(1000); Masque1:= $FF; END; { Colonne }BEGIN						{ Aiguillages } Masque0:= $00; Masque1:= $FF; Masque2:= $00;  Lib_setcurs(100,150); Write('Teste les 16 aiguillages (L293B)'); SetBit(Masque2,0);					{ ligne 0 } Colonne; ClrBit(Masque2,0);  SetBit(Masque2,1);					{ ligne 1 } Colonne; ClrBit(Masque2,1);  SetBit(Masque2,2);					{ ligne 2 } Colonne; ClrBit(Masque2,2);  SetBit(Masque2,3);					{ ligne 3 } Colonne; ClrBit(Masque2,3); FOR Index:= 0 TO 5 DO  BEGIN   Masque1:= $00;					       { toutes les LED }   Masque2:= $0F;   Poke(Admubus+Fact*Ad_w1,Masque1);   Poke(Admubus+Fact*Ad_w2,Masque2);   En_disable(300);   Masque1:= $FF;   Masque2:= $00;   Poke(Admubus+Fact*Ad_w1,Masque1);   Poke(Admubus+Fact*Ad_w2,Masque2);   En_disable(300);  END;  Lib_setcurs(100,150); Write('                                           '); Lib_beep(Bipend); END; { Aiguillages }{----------------------------------}PROCEDURE Detecteurs;VARData: Byte;Index: Integer;PROCEDURE Lit;VARIndex: Integer; BEGIN  Data:=Peek(Admubus+Fact*Ad_r0);  Lib_setcurs(200,200);   FOR Index:= 0 TO 7 DO					{ crit rsultat }   BEGIN    IF TstBit(Data,Index) THEN     Write('1  ')    ELSE Write('0  ');   END;  Delay(300); END; { Lit }BEGIN							{ Dtecteurs } Lib_setcurs(50,150); Write('Teste 6 fois les 8 dtecteurs (74HC541) -- Utilise IC6 (O1/O2) ! --');  FOR Index:= 1 TO 6 DO  BEGIN   Masque2:= $11;   Poke(Admubus+Fact*Ad_w2,Masque2);			{ utilise les lignes  1 et 2 }   Lit;   Masque2:= $00;   Poke(Admubus+Fact*Ad_w2,Masque2);   Lit;   Masque2:= $12;					{ inverse le sens  (2me diode) }   Poke(Admubus+Fact*Ad_w2,Masque2);   Lit;   Masque2:= $00;   Poke(Admubus+Fact*Ad_w2,Masque2);   Lit;  END;   Lib_setcurs(50,150); Write('                                                                         '); Lib_setcurs(200,200); Write('                                 ');  Lib_beep(Bipend);END; { Detecteurs }{---------------------------------}PROCEDURE Test; BEGIN  Lib_setcurs(10,100);  Write('En test continu (Sortie en fin de cycle si une touche a t presse)');    REPEAT   Secteurs;   Aiguillages;   Detecteurs;  UNTIL KeyPressed;    Lib_setcurs(10,100);  Write('                                                                      ');  Lib_beep(Bipend);   END; { Test }{---------------------------------------------------------------------} BEGIN						{ programme principal } Page; Init_libgraphic;  Ntr_getmachine(P,M,Tm,Ns); CASE Tm OF  1: BEGIN       Admubus:= $3C0+1;	 		{ SM8   vrifier }       Fact:= 2;     END;  2: BEGIN       Admubus:= $FFFF8000;			{ SM100 }       Fact:= 2;     END;  6: BEGIN       Admubus:= $FFFF8000;			{ SM196   vrifier }       Fact:= 1;     END;  7: BEGIN       Admubus:= $01000000;			{ SM300 }       Fact:= 1;     END;  3: BEGIN       Admubus:= $FFFF6800;			{ SM324 }       Fact:= 1;     END; ELSE :  BEGIN   WriteLn;   WriteLn('Je ne connais pas l''adresse MUBUS pour cette machine');   Lib_beep(Biperr);   Delay(2000);   Exit;  END;END; Page; Affmenu1; Cadre; Lib_setcurs(80,20); Lib_afcar(Chr($91)); Write('Ce programme permet le test d''une carte TRAIN SDA'); Lib_afcar(Chr($90)); Lib_setcurs(10,60); WriteLn('Carte sans cavalier d''adressage  --16me carte (adresse $3C)--  ');  Masque0:= $00;				{ RAZ } Masque1:= $00; Masque2:= $00; Poke(Admubus+Fact*Ad_W0,Masque0); Poke(Admubus+Fact*Ad_W1,Masque1); Poke(Admubus+Fact*Ad_W2,Masque2); REPEAT					{ boucle } Lib_getkey(Key,Ev,X,Y); Lib_key(Key,Code,Pcode,Sshift);   CASE Ord(Code) OF   F1,F2,F3 :  BEGIN                Lib_clrmenu;                Secteurs;                Affmenu1;               END;   F4,F5,F6 :  BEGIN   	        Lib_clrmenu;                Aiguillages;                Affmenu1;               END;   F7,F8,F9 :   BEGIN                 Lib_clrmenu;                 Detecteurs;                 Affmenu1;                END;   F10,F11,F12: BEGIN                 Lib_clrmenu;                 Test;                 Affmenu1;                END;  END;  UNTIL Ord(Code)= F0; Page; Lib_beep(Bipend); END.