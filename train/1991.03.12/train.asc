	.TITLE	TRAIN.ASC;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du programme TRAIN.CODE;	Date		Amliorations; --------------------------------------------------------------------------; 0.7	25.02.91	adapteur MUBUS-LONG;			algorithme --> script;			unit --> objet;			chaque objet peut avoir un nom;			couleur sur SMAKY-300; 0.5	19.12.90	utilise l'interface universelle TRAIN-16-8-8; 0.1	01.11.89	dbut des travaux (interface SLAVE-444)	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	ICOLOR	.REF	COLORS;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;EPRO_EXTEND = H'A84FEPRO_GETPDBUFF = 1BEPROTXT = 3BEPROMOUSE = 5BEPROAFCR = 7BEPROAFLF = 8BEPROAFTAB = 9OEPROSTATUS = H'1BBEPROFILMOD = 0;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;ASSMILE	=	0		; 1 => test avec SMILE2DEBUG	=	0		; 1 => debug avec fentre  droite pour les dtecteursMAJREV	=	0		; rvisionMINREV	=	7		; version	.REV	MAJREV,MINREV	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LGNOM	=	50		; lg max d'un nom d'unit	.IF	DEBUGDBGLX	=	72		; largeur fentre de debug	.ELSEDBGLX	=	0		; pas de fentre de debug	.ENDIFPALNBX	=	3		; palette: nb d'icnes horizontalementPALNBY	=	12		; palette: nb d'icnes verticalementLBUNAM	=	50		; lg max d'un nom de fichierLTMIO	=	256*8		; lg buffer tampon pour i/oKEYDBOX	=	H'7E00		; "touche" spciale pour dbox; Gnrateurs de caractres; -------------------------GCTXF	=	'N		; NEF11GCTXS	=	'E!2^7GCTXT	=	11GCICF	=	'I		; ITP17+18GCICS	=	'TGCICT	=	17CELDIM	=	16		; largeur/hauteur d'une icne dans les cellulesPALDIM	=	4+CELDIM+4	; largeur/hauteur d'une icne dans la paletteICORVIDE=	1		; rail videICORHS	=	2		; rail secteurICORVS	=	3		; rail ICORHD	=	4		; rail dteleurICORVD	=	5		; rail ICORHC	=	6		; rail capteurICORVC	=	7		; rail ICORHUR	=	8		; rail aiguillageICORHUL	=	9		; rail ICORHDR	=	10		; rail ICORHDL	=	11		; rail ICORVUR	=	12		; rail ICORVUL	=	13		; rail ICORVDR	=	14		; rail ICORVDL	=	15		; rail ICORH	=	16		; rail droit horizontalICORV	=	17		; rail droit verticalICORHR	=	18		; rail dtecteur reedICORVR	=	19		; rail ICORGO	=	20		; rail dpartICORINV	=	21		; rail inverseurICORHC23=	22		; rail capteur si 2 ou 3ICORVC23=	23		; rail ICORTJD1=	24		; rail TJD1ICORTJD2=	25		; rail TJD2ICORMAN	=	30		; rail manoeuvreICORCLA	=	31		; rail clavierICORUR	=	32		; rail courbe ICORUL	=	33		; rail ICORDR	=	34		; rail ICORDL	=	35		; rail ICORBL	=	36		; rail ICORBR	=	37		; rail ICORBU	=	38		; rail ICORBD	=	39		; rail ICORHV	=	40		; rail ICORERR	=	47		; rail erreurICOMOD	=	48		; modifieICODRAW	=	49		; dessineICOGRILLE=	50		; grilleICOZOOM	=	51		; zoomICOAUTO	=	52		; automatiqueICOMANU	=	53		; manuelICOAIND =	54		; action dans indicateursICOADET =	55		; action dans dtecteursICOLOCK	=	56		; bloqueICODETRUIT=	97ICODEPLACE=	98ICODUPLIQUE=	99ICOSZERO=	100ICOSUN	=	101ICOAZERO=	102ICOAUN	=	103ICOUNIT	=	104ICOALGO	=	105ICOPRESS=	111; Couleurs; --------COLORBASE=	H'8000COLORFCADRE=	COLORBASE+0	; fond cadreCOLORCCADRE=	COLORBASE+1	; chair cadreCOLORFDRAW=	COLORBASE+2	; fond dessinCOLORCICO=	COLORBASE+3	; chair icnesCOLORFICO=	COLORBASE+4	; fond icnesCOLOR0ICO=	COLORBASE+5	; fond icnes =0COLOR1ICO=	COLORBASE+6	; fond icnes =1COLORVICO=	COLORBASE+7	; fond icnes voies occupesCOLORUNIT=	COLORBASE+8	; chair numros d'unitsCOLORFINFO=	COLORBASE+9	; fond infoCOLORCINFO=	COLORBASE+10	; chair infoCOLOR2ICO=	COLORBASE+11	; fond icnes >1COLOREICO=	COLORBASE+12	; fond icnes faussesCOLORLAST=	COLORBASE+13NBRCOUL	=	COLORLAST-COLORBASE; Pr-compilation; ---------------PCNUM	=	129		; <<valeur>>PCUNIT	=	130		; $ <<numro>>PCSI	=	140		; SiPCALORS	=	141		; AlorsPCSINON	=	142		; SinonPCFIN	=	143		; FinPCET	=	150		; EtPCOU	=	151		; OuPCASS	=	160		; :=PCEGAL	=	161		; =PCDIFF	=	162		; <>PCADD	=	170		; +PCSUB	=	171		; -PCSTOP	=	180		; StopPCPASSE	=	181		; PassePCDEVIE	=	182		; DviPCDROIT	=	183		; DroitPCBLOQUE=	190		; Bloque <<numro>> <<temps>>PCLIBERE=	191		; Libre <<numro>>; Erreurs; -------ERTRAIN	=	H'F000ERMFILE	=	H'F001		; fichier incompatibleERMEMPTY=	H'F011		; fifo videERMFULL	=	H'F012		; fifo pleinERMPROC	=	H'F013		; processeur absentERMUNIT	=	H'F014		; unit inexistanteERMEVENT=	H'F015		; vnement incorrectERMNDDET=	H'F016		; dtecteur non dclarERMUUSE	=	H'F020		; unit dj utiliseERMULOK	=	H'F021		; unit bloqueERMNUSE	=	H'F022		; nom d'unit existe djERMSYNT	=	H'F030		; erreur de syntaxeERMSALO	=	H'F031		; ALORS attenduERMSASS	=	H'F032		; := attenduERMSEOL	=	H'F033		; fin de ligne attendueERMSUNI	=	H'F034		; unit attendueERMSVAL	=	H'F035		; valeur attendueERMSPAO	=	H'F036		; ( attenduERMSPAF	=	H'F037		; ) ou , attendu; Constantes du hard; ------------------MAXUNIT	=	1000		; nb max d'units (3 digits)MAXDET	=	200+1		; nb max de dtecteursMAXCLA	=	10+1		; nb max de claviersMAXGO	=	10+1		; nb max de marche/arrt globaux; Descripteur d'un fifo; ---------------------NBFIFO	=	200		; lg max du fifoLGFIFO	=	4		; taille d'un lment dans le fifo (.L)	.LOC	0OFFHEAD:.BLKB	2		; ^tteOFFTAIL:.BLKB	2		; ^queueOFFDATA:.BLKB	LGFIFO*NBFIFO	; contenuLFF:; En-tte d'un fichier .TRAIN; ---------------------------	.LOC	0OHDID:	.BLKB	4		; identificateur	.BLKB	4		; rserveOHDREV:	.BLKB	2		; rvision.version	.BLKB	6		; rserveOHDNBX:	.BLKB	2		; nb de cellules en XOHDNBY:	.BLKB	2		; nb de cellules en YOHDLCE:	.BLKB	2		; valeur de la constante LCEOHDFAN:	.BLKB	4		; fanionsOHDDEL:	.BLKB	2		; dlai dtecteursLHEAD	=	256; Descripteur d'un dtecteur; --------------------------	.LOC	0ODETUNI:.BLKB	2		; numro de l'unitODETRAN:.BLKB	2		; rangODETPOR:.BLKB	1		; port physique du dtecteur	.BLKB	1ODETTIM:.BLKB	2		; dernier tempsLDET:; Descripteur d'un clavier; ------------------------	.LOC	0OCLAUNI:.BLKB	2		; numro de l'unitOCLARAN:.BLKB	2		; rangOCLAPOR:.BLKB	1		; port physique du clavier	.BLKB	1LCLA:; Descripteur d'un marche/arrt global; ------------------------------------	.LOC	0OGOUNI:	.BLKB	2		; numro de l'unitLGO:; Description d'une cellule; -------------------------	.LOC	0OCEICO:	.BLKB	1		; icneOCEETA:	.BLKB	1		; tatOCEUNI:	.BLKB	2		; numro de l'unitOCEPOR:	.BLKB	1		; port physiqueOCEPAR:	.BLKB	1		; paramtreOCEFAN:	.BLKB	1		; fanions BCEFINV=  0			;  action inverse BCEFMCC=  1			;  moteur CC BCEFMBB=  2			;  moteur BB BCEFREL=  3			;  relais	.BLKB	1		; rserveOCEPSC:	.BLKB	4		; ^script associOCETIM:	.BLKB	2		; temps jusqu'o bloquOCEPNM:	.BLKB	4		; ^nomLCE:; Descripteur pour une ligne ditable dans une DBOX; -------------------------------------------------	.LOC	0ODBOFF:	.BLKB	2		; offset variableODBTYP:	.BLKB	2		; type DBTYPN =  0			;  nombre entier positif DBTYPNS=  1			;  nombre entier sign (+/-) DBTYPNF=  2			;  nombre entier positif facultatif DBTYPA =  10			;  chane alphanumriqueODBMIN:	.BLKB	2		; valeur minimaleODBMAX:	.BLKB	2		; valeur maximaleODBINC:	.BLKB	2		; incrmentODBRGC:	.BLKB	2		; rang pour DBOX_GETCOODBRED:	.BLKB	2		; rang pour DBOX_MEDITODBNBC:	.BLKB	2		; nb de caractresLDB:; Variables; ---------LBUDIS	=	50	.LOC	0OCHDBOX:.BLKB	2		; canal module DBOXOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHEPRO:.BLKB	2		; canal module EPROOCHICOLOR:.BLKB	2		; canal du module ICOLOROMACHINE:.BLKB	1		; machine	.EVENOPLCOM:	.BLKB	4		; ^ligne de commandeOPDDIS:	.BLKB	4		; ^descripteur de la fentreOSDDIS:	.BLKB	LGDIS6		; copie du descripteur de la fentreOPGICO:	.BLKB	4		; ^gencar ITP17OPFICO:	.BLKB	4		; ^gencar ITP18OIDCRET:.BLKB	4		; identificateur de la CRETOBUCOL:	.BLKB	NBRCOUL*4	; fausses couleursOBUDIS:	.BLKB	LBUDIS		; buffer pour "write-display"ODBGWD:	.BLKB	2		; no swdo de debugOINV:	.BLKB	1		; 1 => affichage inversOCCMO:	.BLKB	1		; 1 => souris enleveOGRILLE:.BLKB	1		; 1 => grille prsenteOZOOM:	.BLKB	1		; 1 => 2 fois plus grandOAUTO:	.BLKB	1		; 1 => automatiqueOLOCK:	.BLKB	1		; 1 => bloqueOMANU:	.BLKB	1		; 1 => manuelOAIND:	.BLKB	1		; 1 => action dans indicateursOADET:	.BLKB	1		; 1 => action dans dtecteurs	.EVENOPILCH:	.BLKB	2		; pilote TRAIN: canal FOSOPILBU:	.BLKB	8		; pilote TRAIN: bufferOFAN:	.BLKB	4		; fanions BFMBL	=  0			;  adapteur MUBUS-LONG BFFRAN	=  8			;  scripts en franais BFANGL	=  9			;  scripts en anglaisODDEL:	.BLKB	2		; dlai pour les dtecteursOPCEL:	.BLKB	4		; ^cellules du circuitORAIL:	.BLKB	2		; rail slectionn dans la paletteOPALNIV:.BLKB	2		; palette: niveauOPALPY:	.BLKB	2		; palette: position (y)OPALPX:	.BLKB	2		; palette: position (x)OCELDIM:.BLKB	2		; cellules: dimension (dx ou dy)OCELPY:	.BLKB	2		; cellules: position (y)OCELPX:	.BLKB	2		; cellules: position (x)OCELDY:	.BLKB	2		; cellules: dimensions (dy)OCELDX:	.BLKB	2		; cellules: dimensions (dx)OCELNY:	.BLKB	2		; cellules: nb total (y)OCELNX:	.BLKB	2		; cellules: nb total (x)OCELVY:	.BLKB	2		; cellules: nb visibles (y)OCELVX:	.BLKB	2		; cellules: nb visibles (x)OASHOR:	.BLKB	LSCVAR		; variables ascenseur horizontalOASVER:	.BLKB	LSCVAR		; variables ascenseur verticalOMMDDD:	.BLKB	2		; mmenu: dernire case "dtruit/dplace/duplique"ODBLIN:	.BLKB	LGNOM		; dbox: ligne en ditionODBPTE:	.BLKB	4		; dbox: ^table des objets ditablesODBPA1:	.BLKB	2		; dbox: paramtre 1ODBPA2:	.BLKB	2		; dbox: paramtre 2ODBPA3:	.BLKB	2		; dbox: paramtre 3ODBPA4:	.BLKB	2		; dbox: paramtre 4ODBPAT:	.BLKB	LGNOM		; dbox: paramtre texteONBREC:	.BLKB	2		; nb de rcursionsOSUSPW:	.BLKB	1		; 1 => suspend l'critureOABORT:	.BLKB	1		; 1 => fin du processus fils	.EVENOFFSND:	.BLKB	LFF		; fifo d'missionOFFRCV:	.BLKB	LFF		; fifo de rceptionOBUEV:	.BLKB	4*16		; buffer des vnementsOTADET:	.BLKB	LDET*MAXDET	; table des dtecteursOTACLA:	.BLKB	LCLA*MAXCLA	; table des claviersOTAGO:	.BLKB	LGO*MAXGO	; table des marche/arrt globauxOTIME:	.BLKB	4		; temps absolu (32 bits suffisent pour 994 jours !)OLATIM:	.BLKB	4		; dernier aiguillage: temps absoluOLADAT:	.BLKB	4		; dernier aiguillage: dataOBUNAM:	.BLKB	LBUNAM		; nom de fichier .TRAINOBUNIM:	.BLKB	LBUNAM		; nom de fichier imageOBUNTX:	.BLKB	LBUNAM		; nom de fichier texteOIOCH:	.BLKB	2		; canal pour entre/sortieOIOBH:	.BLKB	LHEAD		; buffer pour en-tteOIOTM:	.BLKB	LTMIO		; buffer tamponOIOPT:	.BLKB	2		; ^relatif dans OTMIOOIONB:	.BLKB	2		; reste dans OTMIOLGVAR:; Programme; ---------	.LOC	0ADCODE:	JUMP	START; Tables des couleurs relatives; -----------------------------TCOUL:	.L	COLORFCADRE	.W	-1,-1,-1	.ASCIZE	"fond du cadre"	.L	COLORCCADRE	.W	0,0,0	.ASCIZE	"chair du cadre"	.L	COLORFDRAW	.W	-1,-1,-1	.ASCIZE	"<1>fond du dessin"	.L	COLORCICO	.W	0,0,0	.ASCIZE	"chair des icnes"	.L	COLORFICO	.W	-1,-1,0	.ASCIZE	"fond des icnes inactives"	.L	COLOR0ICO	.W	-1,0,0	.ASCIZE	"fond des icnes dclenches (=0)"	.L	COLOR1ICO	.W	0,-1,0	.ASCIZE	"fond des icnes enclenches (=1)"	.L	COLOR2ICO	.W	0,-1,0	.ASCIZE	"fond des icnes enclenches (<'>>1)"	.L	COLOREICO	.W	0,-1,0	.ASCIZE	"fond des icnes fausses"	.L	COLORVICO	.W	0,-1,0	.ASCIZE	"fond des icnes des voies occupes"	.L	COLORUNIT	.W	0,0,-1	.ASCIZE	"<1>numros des objets ($...)"	.L	COLORFINFO	.W	-1,-1,0	.ASCIZE	"fond des informations (ligne en haut)"	.L	COLORCINFO	.W	-1,0,0	.ASCIZE	"contenu des informations"	.L	0; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMEPRO:		.ASCIZ	"EPRO"NMICOLOR:	.ASCIZ	"ICOLOR"NMTRAIN:	.ASCIZ	"TRAIN"		.EVENSTART:	.IF	~ASSMILE	LIB	?OPELIB	.ENDIF	LOAD.W	D3,#2	LIB	?MOUSE	LIB	?AFTIM	.B	NOCURS	.B	NOEFLI	.B	0	.EVEN	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour var.	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LIB	?GETPDIS	LOAD.L	(A6)+OPDDIS,A4	LOAD.L	A0,A4		; A0 <-- ^descripteur (toujours) !	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT,0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT,0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT,0	.EVEN	LOAD.L	(A6)+OPGICO,(A0)+ODFPGC	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT+1,0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT+1,0	.EVEN	LOAD.L	(A6)+OPFICO,(A0)+ODFPGC	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT,0	.EVEN	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMEPRO	LOAD.W	D3,#EPRO_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHEPRO,D1	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	LOAD.L	A3,#R16"NMICOLOR	LOAD.W	D3,#ICOL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHICOLOR,D1NOCOUL$:	LOAD.L	(A6)+OFAN,#2^BFFRAN	LOAD.W	(A6)+ODDEL,#50*2	LOAD.W	(A6)+OPALNIV,#ICOMOD	LOAD.W	(A6)+ORAIL,#10	LOAD.L	D4,#H'10000*50+100	CALL	CELNEW	JUMP,NE ERFAT2	CALL	MUBUSOPEN	; ouvre le pilote	CALL	MUBUSCOMMAND	; met le bon mode	.IF	DEBUG	LOAD.W	D3,(A0)+ODFCY	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SUB.W	D3,#DBGLX	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,(A0)+ODFCY	SWAP.W	D4	LOAD.W	D4,#DBGLX	LIB	?CREWDO	LOAD.W	(A6)+ODBGWD,D5	.ENDIF	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCRET$	; non => NOCRET$	LOAD.L	A3,#R16"NMTRAIN	LOAD.L	A5,#R16"TCOUL	LOAD.L	D3,#2^BICCRET	ICOL_	INIT		; charge TRAIN.CRET	LOAD.L	(A6)+OIDCRET,D5	CALL	DESINIT		; initialise la table des fausses couleursNOCRET$:	CALL	ICINIT		; calcule le cadre	CALL	CELCADRE	; dessine le cadre des cellules	CALL	CELUPDATE	; dessine le contenu des cellules	CALL	PALUPDATE	; dessine le contenu de la palette	CALL	CELMAJ		; mj les units spciales	CALL	INIUNIT		; met toutes les units dans un tat initial	CALL	AFMENU		; met les soft-keys	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SKPNAM	JUMP,NE LOOP	LOAD.L	A4,#(A6)+OBUNAMXFFIL2$:	LOAD.B	D3,(A3+)	JUMP',EQ XFFIL4$	COMP.B	D3,#CR	JUMP',EQ XFFIL4$	COMP.B	D3,#SPACE	JUMP',EQ XFFIL4$	COMP.B	D3,#'/	JUMP',EQ XFFIL4$	LOAD.B	(A4+),D3	JUMP	XFFIL2$XFFIL4$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUNAM	JUMP	DOPRENDFLOOP:	CALL	SCMO		; remet la souris	LOAD.W	D4,#50/10	NTREL	?SETTIM	LIB	?GETCAR		; attend clavier/souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE	TIMO$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ FINI	COMP.W	D3,#END	JUMP,EQ FINI	COMP.W	D3,#F1	JUMP,EQ DOPREND	COMP.W	D3,#F3	JUMP,EQ DOSAUVE	COMP.W	D3,#F4	JUMP,EQ DODEF	COMP.W	D3,#F5	JUMP,EQ DOCOLOR	COMP.W	D3,#F11	JUMP,EQ DOIMAGE	COMP.W	D3,#F12	JUMP,EQ DOALGO	AND.L	D3,#H'FF	LOAD.B	D4,D3	LOAD.B	D3,#F1	COMP.B	D4,#TRIZERO	JUMP',EQ PUT$	COMP.B	D4,#SPACE	JUMP',EQ PUT$	LOAD.B	D3,#F2	COMP.B	D4,#CLEAR	JUMP',EQ PUT$	LOAD.B	D3,#F3	COMP.B	D4,#DELETE	JUMP',EQ PUT$	LOAD.B	D3,#CLEAR	COMP.B	D4,#POINT	JUMP',EQ PUT$	LOAD.B	D3,D4PUT$:	CALL	PUTEVENT	JUMP,NE	BIP$	JUMP	LOOP	.IF	DEBUGTIMO$:	CALL	RCVEVENT	; D1 <--rang unit dtecteur	JUMP',EQ TIMO2$	COMP.W	D7,#ERMEVENT	JUMP,EQ LOOP	LOAD.W	D4,D7	LOAD.W	D5,(A6)+ODBGWD	LIB	?USEWDO	LIB	?AFTIM	.B	AFINV,0	LIB	?AFX4	LIB	?AFSPACE	LOAD.W	D4,D3	LIB	?AFX4	LIB	?AFCR	LIB	?AFTIM	.B	AFDIR,0	CLR.W	D5	LIB	?USEWDO	JUMP	TIMO$TIMO2$:	LOAD.W	D5,(A6)+ODBGWD	LIB	?USEWDO	CALL	CELGETP		; A4 <-- ^cellule	CLR.L	D4	LOAD.W	D4,(A4)+OCEUNI	LOAD.W	D3,#3	CLR.W	D2	LIB	?AFDEC	LIB	?AFSPACE	LIB	?AFX4	LIB	?AFCR	CLR.W	D5	LIB	?USEWDO	CALL	ALGOSND		; action selon un dtecteur	JUMP	TIMO$	.ELSETIMO$:	CALL	RCVEVENT	; D1 <--rang unit dtecteur	JUMP,NE LOOP	CALL	ALGOSND		; action selon un dtecteur	JUMP	TIMO$	.ENDIFBIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPCLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	CALL	PALMOVE		; D1 <-- rang (0..n)	JUMP,EQ PAL$	CALL	CELASMOVE	; dplace les ascenseurs	JUMP,EQ LOOP	COMP.W	D3,#KEYMGP	JUMP,EQ CLICG$	COMP.W	D3,#KEYMDP	JUMP,EQ CLICD$	JUMP	BIP$CLICG$:	CALL	CELMOVE		; D1 <-- rang (0..n)	JUMP,EQ LOOP	JUMP	BIP$CLICD$:	CALL	ZONMOVE		; D1/D2 <-- zone	JUMP,EQ ZONE$	JUMP	BIP$PAL$:	LOAD.W	D3,D1	CALL	RANGICO		; D3 <-- icne clique	COMP.W	D3,#ICOMOD	JUMP,EQ PALNIV$	COMP.W	D3,#ICODRAW	JUMP,EQ PALNIV$	COMP.W	(A6)+OPALNIV,#ICODRAW	JUMP,EQ PALDRAW$PALMOD$:	COMP.W	D3,#ICOGRILLE	JUMP',EQ PALGRI$	COMP.W	D3,#ICOZOOM	JUMP',EQ PALZOOM$	COMP.W	D3,#ICOAUTO	JUMP',EQ PALAUTO$	COMP.W	D3,#ICOLOCK	JUMP',EQ PALLOCK$	COMP.W	D3,#ICOMANU	JUMP,EQ PALMANU$	COMP.W	D3,#ICOAIND	JUMP,EQ PALAIND$	COMP.W	D3,#ICOADET	JUMP,EQ PALADET$	COMP.W	D3,#ICORGO	JUMP,EQ PALSTOP$	JUMP	LOOPPALGRI$:	NOT.B	(A6)+OGRILLE	LOAD.W	D1,#6	CALL	PALINV		; inverse l'icne	CALL	CELUPDATE	; dessine le contenu des cellules	JUMP	LOOPPALZOOM$:	NOT.B	(A6)+OZOOM	LOAD.W	D1,#7	CALL	PALINV		; inverse l'icne	CALL	ICINIT		; calcule le cadre	CALL	CELCADRE	; dessine le cadre des cellules	CALL	CELUPDATE	; dessine le contenu des cellules	CALL	PALUPDATE	; dessine le contenu de la palette	JUMP	LOOPPALAUTO$:	NOT.B	(A6)+OAUTO	LOAD.W	D1,#12	CALL	PALINV		; inverse l'icne	JUMP	LOOPPALLOCK$:	NOT.B	(A6)+OLOCK	LOAD.W	D1,#13	CALL	PALINV		; inverse l'icne	TEST.B	(A6)+OLOCK	JUMP,F	LOOP	TEST.B	(A6)+OAUTO	JUMP,T	LOOP	JUMP	PALAUTO$PALMANU$:	NOT.B	(A6)+OMANU	LOAD.W	D1,#14	CALL	PALINV		; inverse l'icne	JUMP	LOOPPALAIND$:	NOT.B	(A6)+OAIND	LOAD.W	D1,#15	CALL	PALINV		; inverse l'icne	TEST.B	(A6)+OAIND	JUMP,F	LOOP	TEST.B	(A6)+OAUTO	JUMP,T	LOOP	JUMP	PALAUTO$PALADET$:	NOT.B	(A6)+OADET	LOAD.W	D1,#16	CALL	PALINV		; inverse l'icne	TEST.B	(A6)+OADET	JUMP,F	LOOP	TEST.B	(A6)+OAUTO	JUMP,T	LOOP	JUMP	PALAUTO$PALSTOP$:	CALL	PUTSTOP		; stoppe tout	JUMP	LOOPPALDRAW$:	COMP.W	D1,(A6)+ORAIL	JUMP,EQ LOOP	LOAD.W	D2,D1	LOAD.W	D1,(A6)+ORAIL	CALL	PALINV		; teint l'ancien	LOAD.W	D1,D2	CALL	PALINV		; allume le nouveau	LOAD.W	(A6)+ORAIL,D1	JUMP	LOOPPALNIV$:	LOAD.W	(A6)+OPALNIV,D3	CALL	PALUPDATE	; redessine les icnes	CALL	CELMAJ		; mj les units spciales	JUMP	LOOPZONE$:	LOAD.L	A3,#R16"TMDDD	LOAD.W	D3,(A6)+OMMDDD	TSET.L	D3:#15	CLR.L	D4	COMP.W	(A6)+OPALNIV,#ICODRAW	JUMP',EQ ZMENU1$	LOAD.B	D4,#B'1110	; D4 <-- grise dtruit/dplace/dupliqueZMENU1$:	TSET.L	D4:#8		; D4 <-- grise "objet.."	TSET.L	D4:#9		; D4 <-- grise "script.."	CALL	ZONIFONE	; une seule cellule ?	JUMP',NE ZMENU2$	CALL	CELIFUNIT	; est-ce une unit ?	JUMP',NE ZMENU2$	TCLR.L	D4:#8		; D4 <-- dgrise "objet.."	TCLR.L	D4:#9		; D4 <-- dgrise "script.."ZMENU2$:	CALL	MMENU		; choix selon mmenu ...	LOAD.W	(A6)+OMMDDD,D3	DEC.W	D3	JUMP,EQ ZDETR$	DEC.W	D3	JUMP,EQ ZDEPL$	DEC.W	D3	JUMP,EQ ZDUPL$	CLR.W	D4	DEC.W	D3	JUMP,EQ ZSETAT$	INC.W	D4	DEC.W	D3	JUMP,EQ ZSETAT$	CLR.W	D4	DEC.W	D3	JUMP,EQ ZAETAT$	INC.W	D4	DEC.W	D3	JUMP,EQ ZAETAT$	DEC.W	D3	JUMP,EQ ZUNIT$	DEC.W	D3	JUMP,EQ ZALGO$	CALL	ZONINV		; teint la zone	JUMP	LOOPZDETR$:	CALL	ZONINV		; teint la zone	CALL	ZONDETR		; dtruit les cellules	JUMP	LOOPZDEPL$:	LOAD.W	D3,D1	LOAD.W	D4,D2	CALL	ZONDEPL		; dplace la zone	CALL	ZONINV		; teint la zone	COMP.W	D1,D3	JUMP,EQ BIP$	EX.L	D1,D3	EX.L	D2,D4	CLR.W	D0		; D0 <-- dplace	CALL	ZONDUPL1	; tampon <-- cellules	JUMP,NE BIP$	CALL	ZONDETR		; dtruit les cellules	LOAD.W	D1,D3	LOAD.W	D2,D4	CALL	ZONDUPL2	; cellules <-- tampon	JUMP	LOOPZDUPL$:	LOAD.W	D3,D1	LOAD.W	D4,D2	CALL	ZONDEPL		; dplace la zone	CALL	ZONINV		; teint la zone	COMP.W	D1,D3	JUMP,EQ BIP$	EX.L	D1,D3	EX.L	D2,D4	LOAD.W	D0,#1		; D0 <-- duplique	CALL	ZONDUPL1	; tampon <-- cellules	JUMP,NE BIP$	LOAD.W	D1,D3	LOAD.W	D2,D4	CALL	ZONDUPL2	; cellules <-- tampon	JUMP	LOOPZSETAT$:	CALL	ZONINV		; teint la zone	CALL	ZONSETAT	; modifie l'tat	JUMP	LOOPZAETAT$:	CALL	ZONINV		; teint la zone	CALL	ZONAETAT	; modifie l'tat	JUMP	LOOPZUNIT$:	CALL	ZONINV		; teint la zone	CALL	DBOXCEL		; modifie la cellule ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	CELGETP		; A4 <-- ^cellule	CALL	CELDRAW		; dessine la cellule	CALL	ALGOSND		; excute un ventuel script !	CALL	MAJUNITRC	; met  jour l'tat	JUMP	LOOPZALGO$:	CALL	ZONINV		; teint la zone	CALL	CELGETP		; A4 <-- ^cellule	JUMP,NE BIP$	LOAD.L	A2,A4		; A2 <-- ^cellule	LOAD.L	A3,(A2)+OCEPSC	LOAD.L	A4,A3	CALL	ALGOEDIT	; dite le script ...	JUMP,NE BIP$	LOAD.L	(A2)+OCEPSC,A3	JUMP	LOOPDODEF:	CALL	DBOXDEF		; choix des dfinitions ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	CELCHGDIM	; change les dimensions	JUMP,NE ERROR	CALL	ICINIT		; calcule le cadre	CALL	CELCADRE	; dessine le cadre des cellules	CALL	CELUPDATE	; dessine le contenu des cellules	CALL	PALUPDATE	; dessine le contenu de la palette	JUMP	LOOPDOCOLOR:	CALL	DBOXCOLOR	; choix des couleurs ...	JUMP,NE ERROR	CALL	DESINIT		; initialise la table des fausses couleurs	CALL	CELCADRE	; dessine le cadre des cellules	CALL	CELUPDATE	; dessine le contenu des cellules	CALL	PALUPDATE	; dessine le contenu de la palette	JUMP	LOOPBIGBIP:				; erreur =>	LOAD.B	D3,#BIPERR	LIB	?BEEP		; grand bruit	JUMP	LOOPERROR:	TEST.W	D7	JUMP,EQ LOOP	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP	CALL	DBOXERROR	; affiche une erreur ...	JUMP	LOOPFINI:	CALL	DBOXQUITTE	; quitte ?	COMP.W	D3,#F1	JUMP,NE LOOPERFAT:	CALL	MUBUSCLOSE	; ferme le pilote	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHEPRO	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHICOLOR	LIB_	CLOSE	LOAD.L	A4,A6	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend les variablesERFAT1:	.IF	~ASSMILE	LIB	?CLOLIB	FOS	?STOP	.ELSE	EXIT	.ENDIFERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFATTMDDD:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODETRUIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEPLACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  dplace   "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPRESS	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODUPLIQUE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  duplique  "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPRESS	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSZERO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  stoppe"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSUN	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  passe"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOAZERO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dvi"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOAUN	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  droit"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUNIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  objet.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOALGO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  script.."	.B	0	.EVEN	.INS	TRAINPAL.ASI	.INS	TRAINSCRI.ASI	.INS	TRAINZONE.ASI	.INS	TRAINCEL.ASI	.INS	TRAINDBOX.ASI	.INS	TRAINDBOXT.ASI	.INS	TRAINIO.ASI	.INS	TRAINMUBUS.ASI	.INS	TRAINMISC.ASI	.END	START