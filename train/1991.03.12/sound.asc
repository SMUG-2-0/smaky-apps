WAIT$:	JUMP,IH	CONV$				; [4]PUTFIFO$:	MOVE	8^HEAD,A			; [5]	AND	#2'00111111,A			; [4]	MOVE	A,X				; [2]	MOVE	8^TIMER,A			; [5]	AND	#2'00111111,A			; [4]	COMP	X,A				; [2]	JUMP,EQ	CONV$				; [4]	MOVE	PORT_IO,A			; [5]	MOVE	A,{X}+8^ADFIFO			; [6]	SET	8^PORT_HAND:#BLINE_OUT		; [6]	CLR	8^PORT_HAND:#BLINE_OUT		; [6]CONV$:	MOVE	8^TIMER,A			; [5]	AND	#2'00111111,A			; [4]	MOVE	A,X				; [2]	MOVE	{X}+8^ADFIFO,A			; [6]	MOVE	A,PORT_DA			; [5]	JUMP	WAIT$				; [4]