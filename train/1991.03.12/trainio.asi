	.SBTTL	TRAINIO.ASIDOPREND:	SET.B	(A6)+OSUSPW	; suspend l'criture	CALL	DBOXPREND	; demande le nom ...	JUMP',NE DOPERROR	COMP.W	D3,#F1	JUMP,NE DOPLOOPDOPRENDF:	SET.B	(A6)+OSUSPW	; suspend l'criture	CALL	WAITMOUSE	CALL	RDOPEN	JUMP',NE DOPERROR	CALL	RDHEAD		; lit l'en-tte	JUMP',NE CLOSE$	CALL	RDCEL		; lit les cellulesCLOSE$:	CALL	RDCLOSEDOPERROR:	CALL	NORMMOUSE	CLR.B	(A6)+OSUSPW	; reprend l'criture	TEST.W	D7	JUMP,NE ERROR	CLR.W	(A6)+OASVER+OSCPOSV	CLR.W	(A6)+OASHOR+OSCPOSV	CALL	ICINIT		; calcule le cadre	CALL	CELCADRE	; dessine le cadre des cellules	CALL	CELUPDATE	; dessine le contenu des cellules	CALL	PALUPDATE	; dessine le contenu de la palette	CALL	CELMAJ		; mj les units spciales	PUSH.B	(A6)+OAUTO	CLR.B	(A6)+OAUTO	; plus d'automatismes !	CALL	INIUNIT		; met toutes les units dans un tat initial	POP.B	(A6)+OAUTODOPLOOP:	CLR.B	(A6)+OSUSPW	; reprend l'criture	JUMP	LOOPDOSAUVE:	SET.B	(A6)+OSUSPW	; suspend l'criture	CALL	DBOXSAUVE	; demande le nom ...	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE LOOP$CREATE$:	CALL	WAITMOUSE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',EQ OPEN$	COMP.W	D7,#ERFAEX	JUMP,NE ERROR$	CALL	NORMMOUSE	CALL	DBOXDETRUIT	; faut-il dtruire ?	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	WAITMOUSE	FOS	?DELETE	JUMP',NE ERROR$	JUMP	CREATE$OPEN$:	CALL	WROPEN	JUMP',NE ERROR$	CALL	WRHEAD		; crit l'en-tte	JUMP',NE CLOSE$	CALL	WRCEL		; crit les cellulesCLOSE$:	CALL	WRCLOSEERROR$:LOOP$:	CALL	NORMMOUSE	CLR.B	(A6)+OSUSPW	; reprend l'criture	TEST.W	D7	JUMP,NE ERROR	JUMP	LOOPDOIMAGE:	SET.B	(A6)+OSUSPW	; suspend l'criture	CALL	DBOXSIMAGE	; demande le nom de l'image ...	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE LOOP$CREATE$:	CALL	WAITMOUSE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',EQ OPEN$	COMP.W	D7,#ERFAEX	JUMP,NE ERROR$	CALL	NORMMOUSE	CALL	DBOXDETRUIT	; faut-il dtruire ?	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	WAITMOUSE	FOS	?DELETE	JUMP',NE ERROR$	JUMP	CREATE$OPEN$:	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',NE ERROR$	CALL	IMACREATE	; cre l'imageERROR$:LOOP$:	CALL	NORMMOUSE	CLR.B	(A6)+OSUSPW	; reprend l'criture	TEST.W	D7	JUMP,NE ERROR	JUMP	LOOPDOALGO:	SET.B	(A6)+OSUSPW	; suspend l'criture	CALL	DBOXSTEXT	; demande le nom du texte ...	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE LOOP$CREATE$:	CALL	WAITMOUSE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',EQ OPEN$	COMP.W	D7,#ERFAEX	JUMP,NE ERROR$	CALL	NORMMOUSE	CALL	DBOXDETRUIT	; faut-il dtruire ?	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	WAITMOUSE	FOS	?DELETE	JUMP',NE ERROR$	JUMP	CREATE$OPEN$:	CALL	WROPEN	JUMP',NE ERROR$	CALL	TEXTCREATE	; cre le texteCLOSE$:	CALL	WRCLOSEERROR$:LOOP$:	CALL	NORMMOUSE	CLR.B	(A6)+OSUSPW	; reprend l'criture	TEST.W	D7	JUMP,NE ERROR	JUMP	LOOP;----------\\; IMACREATE >;==========/; Cre une image contenant tout le dessin.; in	D6.W	canal FOS; out	D7.W	erreur; mod	D7.WIMACREATE:	PUSHM.L	D0..D2,D4,A2..A4	LOAD.W	D0,(A6)+OCELNX	MUL.WU	D0,(A6)+OCELDIM	; D0 <-- largeur ncessaire	LOAD.W	D2,(A6)+OCELNY	MUL.WU	D2,(A6)+OCELDIM	; D2 <-- hauteur ncessaire	LOAD.W	D4,D0	MUL.WU	D4,D2	SR.L	D4,#3	ADD.L	D4,#LGHIMA+IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour bitmap	JUMP,NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.L	A3,#(A4)+LGHIMA+IMLBUF ; A3 <-- ^bitmap	LOAD.B	(A2)+OIMTYP,#H'81	LOAD.B	(A2)+OIMBIP,#H'01	LOAD.B	(A2)+OIMDIR,#H'02	LOAD.W	(A2)+OIMDLX,D0	LOAD.W	(A2)+OIMDLY,D2	LOAD.W	D4,D0	MUL.WU	D4,D2	SR.L	D4,#3	LOAD.L	(A2)+OIMNBB,D4	PUSH.L	(A6)+OCELPY	PUSH.L	(A6)+OCELVY	PUSH.W	(A6)+OASVER+OSCPOSV	PUSH.W	(A6)+OASHOR+OSCPOSV	CLR.L	(A6)+OCELPY	LOAD.W	(A6)+OCELVX,(A6)+OCELNX	LOAD.W	(A6)+OCELVY,(A6)+OCELNY	CLR.W	(A6)+OASVER+OSCPOSV	CLR.W	(A6)+OASHOR+OSCPOSV	CALL	OPEDISMAT	; sauve le descripteur de fentre	LOAD.L	A4,A3		; A4 <-- ^bitmap	LOAD.W	D4,D2		; D4 <-- hauteur	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- largeur	CALL	NEWDISMAT	; dessine dans le bitmap	CLR.W	D0LOOPY$:	CLR.W	D2LOOPX$:	LOAD.W	D1,D0	MUL.WU	D1,(A6)+OCELNX	ADD.W	D1,D2	CALL	CELGETP		; A4 <-- ^cellule	JUMP',NE NEXT$	CALL	CELDRAW		; dessine une celluleNEXT$:	INC.W	D2	COMP.W	D2,(A6)+OCELNX	JUMP,LO LOOPX$	INC.W	D0	COMP.W	D0,(A6)+OCELNY	JUMP,LO LOOPY$	CALL	CLODISMAT	; restitue le descripteur de fentre	POP.W	(A6)+OASHOR+OSCPOSV	POP.W	(A6)+OASVER+OSCPOSV	POP.L	(A6)+OCELVY	POP.L	(A6)+OCELPY	LOAD.L	A4,#(A3)-IMLBUF	GRA_	CODEIMA		; code l'image	JUMP',NE ERROR$	LOAD.L	A4,A2	LOAD.L	D4,(A2)+OIMNBB	ADD.L	D4,#LGHIMA	FOS	?WRBYTE		; crit l'image	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7ERROR$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le bitmap	POP.W	D7EXIT$:	POPM.L	D0..D2,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TEXTCREATE >;===========/; Cre le texte contenant tous les scripts.; in	-; out	D7.W	erreur; mod	D7.WTEXTCREATE:	PUSHM.L	D1..D4,A1..A5	LOAD.L	D4,#2000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP,NE ERFAT$	LOAD.L	A1,A4		; A1 <-- ^buffer de 2 Kbytes	LOAD.L	A3,#R16"THEAD1$	CALL	WRTEXT	JUMP,NE EXIT$	LOAD.L	A3,#(A6)+OBUNAM	CALL	WRTEXT	JUMP,NE EXIT$	LOAD.L	A3,#R16"THEAD2$	CALL	WRTEXT	JUMP,NE EXIT$	LOAD.L	A3,#R16"TSEP$	CALL	WRTEXT	JUMP,NE EXIT$; Ecrit toutes les units.	CLR.W	D2CLOOP$:	LOAD.W	D3,D2	CALL	GETPTCEL	; A4/D1 <-- ^cellule/rang	JUMP,NE CNEXT$	LOAD.W	D4,(A4)+OCEUNI	JUMP,EQ CNEXT$	LOAD.B	D3,#'$	CALL	WRONE	JUMP,NE EXIT$	CALL	WRNUM		; crit le numro de l'unit	JUMP,NE EXIT$	LOAD.B	D3,#TAB	CALL	WRONE	JUMP,NE EXIT$	CLR.W	D4	TEST.L	(A4)+OCEPNM	JUMP',EQ CNAM2$	LOAD.L	A3,(A4)+OCEPNMCNAM1$:	LOAD.B	D3,(A3+)	JUMP',EQ CNAM2$	CALL	WRONE	JUMP,NE EXIT$	INC.W	D4	COMP.W	D4,#16-1	JUMP,LO CNAM1$CNAM2$:	COMP.W	D4,#8	JUMP',HS CNAM3$	LOAD.B	D3,#TAB	CALL	WRONE	JUMP,NE EXIT$CNAM3$:	LOAD.B	D3,#TAB	CALL	WRONE	JUMP,NE EXIT$	CLR.W	D4	LOAD.B	D4,(A4)+OCEPOR	CALL	WRNUM		; crit le port physique	JUMP,NE EXIT$	LOAD.B	D3,#TAB	CALL	WRONE	JUMP,NE EXIT$	TEST.B	(A4)+OCEPOR	JUMP',EQ CBIT$	CLR.W	D4	LOAD.B	D4,(A4)+OCEPAR	CALL	WRNUM		; crit le paramtre	JUMP,NE EXIT$CBIT$:	LOAD.B	D3,#TAB	CALL	WRONE	JUMP,NE EXIT$	LOAD.W	D3,#H'100*'B+'B	TEST.B	(A4)+OCEFAN:#BCEFMBB	JUMP',BS CTYP2$	LOAD.W	D3,#H'100*'C+'C	TEST.B	(A4)+OCEFAN:#BCEFMCC	JUMP',BS CTYP2$	LOAD.W	D3,#H'100*'L+'RCTYP2$:	CALL	WRONE	JUMP,NE EXIT$	SR.W	D3,#8	CALL	WRONE	JUMP,NE EXIT$	TEST.B	(A4)+OCEFAN:#BCEFINV	JUMP',BC CTYP4$	LOAD.B	D3,#'i	CALL	WRONE	JUMP,NE EXIT$CTYP4$:	LOAD.B	D3,#TAB	CALL	WRONE	JUMP,NE EXIT$	TEST.L	(A4)+OCEPSC	JUMP',EQ CALGO$	LOAD.L	A3,#R16"TALGO$	CALL	WRTEXT	JUMP,NE EXIT$CALGO$:	LOAD.B	D3,#TAB	CALL	WRONE	JUMP,NE EXIT$	LOAD.B	D3,(A4)+OCEICO	CALL	CELTXTYPE	CALL	WRTEXT	JUMP,NE EXIT$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE EXIT$CNEXT$:	INC.W	D2	COMP.W	D2,#MAXUNIT	JUMP,LO CLOOP$; Ecrit tous les scripts.	CLR.W	D2ALOOP$:	LOAD.W	D3,D2	CALL	GETPTCEL	; A4/D1 <-- ^cellule/rang	JUMP,NE ANEXT$	LOAD.W	D4,(A4)+OCEUNI	JUMP,EQ ANEXT$	TEST.L	(A4)+OCEPSC	JUMP,EQ ANEXT$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE EXIT$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE EXIT$	LOAD.L	A3,#R16"TSEP$	CALL	WRTEXT	JUMP,NE EXIT$	LOAD.B	D3,#'$	CALL	WRONE	JUMP,NE EXIT$	CALL	WRNUM		; crit le numro de l'unit	JUMP,NE EXIT$	LOAD.B	D3,#TAB	CALL	WRONE	JUMP,NE EXIT$	TEST.L	(A4)+OCEPNM	JUMP',EQ ANAME$	LOAD.B	D3,#'(	CALL	WRONE	JUMP,NE EXIT$	LOAD.L	A3,(A4)+OCEPNM	CALL	WRTEXT	JUMP,NE EXIT$	LOAD.B	D3,#')	CALL	WRONE	JUMP,NE EXIT$	LOAD.B	D3,#TAB	CALL	WRONE	JUMP,NE EXIT$ANAME$:	LOAD.B	D3,(A4)+OCEICO	CALL	CELTXTYPE	CALL	WRTEXT	JUMP,NE EXIT$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE EXIT$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^cellule	LOAD.L	A3,(A2)+OCEPSC	LOAD.L	A5,A3	LOAD.L	A4,A1		; A4 <-- ^buffer de 2 Kbytes	CALL	ALGOFORMAT	; formate tout le script en ASCII	LOAD.L	A3,A4	CALL	WRTEXT		; crit tout le script	JUMP,NE EXIT$ANEXT$:	INC.W	D2	COMP.W	D2,#MAXUNIT	JUMP,LO ALOOP$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE EXIT$	LOAD.B	D3,#CR	CALL	WRONE	JUMP,NE EXIT$	LOAD.L	A3,#R16"TSEP$	CALL	WRTEXT	JUMP,NE EXIT$	LOAD.L	A3,#R16"TEND$	CALL	WRTEXT;	JUMP,NE EXIT$EXIT$:	PUSH.W	D7	LOAD.L	A4,A1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le grand buffer	POP.W	D7ERFAT$:	POPM.L	D1..D4,A1..A5	TEST.W	D7		; retour EQ/NE	RETTHEAD1$:.ASCIZ	"Contenu du fichier "THEAD2$:	.B	CR,CR	.ASCII	"objet<TAB>"	.ASCII	"nom<TAB><TAB>"	.ASCII	"port<TAB>"	.ASCII	"dure<TAB>"	.ASCII	"type<TAB>"	.ASCII	"script<CR>"	.B	0TSEP$:	.ASCIZ	"-------------------------------------------------------------------------------<CR>"TALGO$:	.ASCIZ	"script"TEND$:	.ASCIZ	"Fin du fichier.<CR>"	.EVEN;--------\\; WRHEAD  >;========/; Ecrit l'en-tte.; in	-; out	D7.W	erreur; mod	D7.WWRHEAD:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OIOBH+LHEAD	LOAD.W	D4,#LHEAD-1CLR$:	CLR.B	(-A4)	DECJ.W,NMO D4,CLR$	LOAD.L	(A4)+OHDID,#H'FADABABA	LOAD.B	(A4)+OHDREV+0,#MAJREV	LOAD.B	(A4)+OHDREV+1,#MINREV	LOAD.W	(A4)+OHDNBX,(A6)+OCELNX	LOAD.W	(A4)+OHDNBY,(A6)+OCELNY	LOAD.W	(A4)+OHDLCE,#LCE	LOAD.L	(A4)+OHDFAN,(A6)+OFAN	LOAD.W	(A4)+OHDDEL,(A6)+ODDEL	LOAD.W	D4,#LHEAD	CALL	WRMANY	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRCEL   >;========/; Ecrit toutes les cellules.; in	-; out	D7.W	erreur; mod	D7.WWRCEL:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,(A6)+OPCEL	; A3 <-- ^cellules	LOAD.W	D3,(A6)+OCELNX	MUL.WU	D3,(A6)+OCELNY	; D3 <-- nb total de cellulesLOOP$:	LOAD.W	D4,#LCE	CALL	WRWORD		; crit la longueur de la cellule	JUMP,NE EXIT$	LOAD.L	A4,A3	CALL	WRMANY		; crit le data de la cellule	JUMP,NE EXIT$SCRIPT$:	CLR.W	D4	TEST.L	(A3)+OCEPSC	JUMP',EQ NOSC$	LOAD.L	A4,(A3)+OCEPSC	CALL	ALGOGETLG	; D4 <-- longueur du scriptNOSC$:	CALL	WRWORD		; crit la longueur du script	JUMP',NE EXIT$	TEST.W	D4	JUMP',EQ NAME$	LOAD.L	A4,(A3)+OCEPSC	CALL	WRMANY		; crit le data du script	JUMP',NE EXIT$NAME$:	CLR.W	D4	TEST.L	(A3)+OCEPNM	JUMP',EQ NONM$	LOAD.L	A4,(A3)+OCEPNMLGNM$:	INC.W	D4		; D4 <-- longueur du nom	TEST.B	(A4+)	JUMP,NE  LGNM$NONM$:	CALL	WRWORD		; crit la longueur du nom	JUMP',NE EXIT$	TEST.W	D4	JUMP',EQ NEXT$	LOAD.L	A4,(A3)+OCEPNM	CALL	WRMANY		; crit le data du nom	JUMP',NE EXIT$NEXT$:	LOAD.L	A3,#(A3)+LCE	; A3 <-- ^cellule suivante	DEC.W	D3	JUMP,NE LOOP$EXIT$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDHEAD  >;========/; Lit l'en-tte.; in	-; out	A4.L	^en-tte;	D7.W	erreur; mod	D7.WRDHEAD:	PUSHM.L	D4	LOAD.L	A4,#(A6)+OIOBH	LOAD.W	D4,#LHEAD	CALL	RDMANY		; lit l'en-tte	JUMP',NE EXIT$	LOAD.W	D7,#ERMFILE	; D7 <-- fichier incompatible	COMP.L	(A4)+OHDID,#H'FADABABA	JUMP',NE EXIT$	COMP.B	(A4)+OHDREV+0,#MAJREV	JUMP',HI EXIT$	COMP.B	(A4)+OHDREV+1,#MINREV	JUMP',HI EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDCEL   >;========/; Lit toutes les cellules.; in	A4.L	^en-tte; out	D7.W	erreur; mod	D7.WRDCEL:	PUSHM.L	D1..D4,A1..A4	LOAD.L	A3,A4		; A3 <-- ^en-tte	LOAD.W	D4,(A3)+OHDNBX	MUL.WU	D4,(A3)+OHDNBY	MUL.WU	D4,#LCE	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- demande mmoire pour cellules	JUMP,NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A1,A4	LOAD.L	A2,A4		; A2 <-- ^o lire les cellules	LOAD.W	D2,(A3)+OHDNBX	MUL.WU	D2,(A3)+OHDNBY	; D2 <-- nb total de cellules  lireLOOP$:	CALL	RDWORD		; D4 <-- longueur de la cellule	JUMP,NE ERROR$	LOAD.L	A4,A2	CALL	RDMANY		; lit la cellule	JUMP,NE ERROR$	CLR.L	(A2)+OCEPSC	CLR.L	(A2)+OCEPNM	CALL	RDWORD		; D4 <-- longueur du script	JUMP,NE ERROR$	TEST.W	D4		; script existe ?	JUMP',EQ NAME$		; non => NAME$	AND.L	D4,#H'FFFF;	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour script	JUMP,NE ERROR$	CALL	RDMANY		; lit le script	JUMP,NE ERROR$	LOAD.L	(A2)+OCEPSC,A4	; OCEPSC <-- ^sur le script luNAME$:	COMP.W	(A6)+OIOBH+OHDREV,#H'100*0+7	JUMP',LO NEXT$	CALL	RDWORD		; D4 <-- longueur du nom	JUMP,NE ERROR$	TEST.W	D4		; nom existe ?	JUMP',EQ NEXT$		; non => NEXT$	AND.L	D4,#H'FFFF;	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour nom	JUMP',NE ERROR$	CALL	RDMANY		; lit le nom	JUMP',NE ERROR$	LOAD.L	(A2)+OCEPNM,A4	; OCEPNM <-- ^sur le nom luNEXT$:	CLR.W	(A2)+OCETIM	LOAD.L	A2,#(A2)+LCE	; A2 <-- ^cellule suivante	DEC.W	D2	JUMP,NE LOOP$	CALL	EFFCEL		; efface toutes les cellules	LOAD.L	A4,(A6)+OPCEL	; A4 <-- ^anciennes cellules;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre les anciennes cellules	LOAD.L	(A6)+OPCEL,A1	LOAD.W	(A6)+OCELNX,(A3)+OHDNBX	LOAD.W	(A6)+OCELNY,(A3)+OHDNBY	LOAD.L	(A6)+OFAN,(A3)+OHDFAN	TEST.W	(A3)+OHDDEL	JUMP',EQ COMM$	LOAD.W	(A6)+ODDEL,(A3)+OHDDELCOMM$:	CALL	MUBUSCOMMAND	; met le bon mode	JUMP'	EXIT$ERROR$:	PUSH.W	D7	LOAD.L	A4,A1;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D7EXIT$:	POPM.L	D1..D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; EFFCEL  >;========/; Efface toutes les cellules.; in	-; out	-; mod	D7.WEFFCEL:	PUSHM.L	D4,A4	LOAD.L	A4,(A6)+OPCEL	; A4 <-- ^cellules	LOAD.W	D4,(A6)+OCELNX	MUL.WU	D4,(A6)+OCELNYLOOP$:	CALL	CELKILL		; dtruit la cellule	LOAD.L	A4,#(A4)+LCE	; A4 <-- ^cellule suivante	DEC.W	D4	JUMP,NE LOOP$	POPM.L	D4,A4	RET; Routines de bas niveau pour bufferiser les entres/sorties; ----------------------------------------------------------;--------\\; RDOPEN  >;========/; Ouvre le fichier en entre.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WRDOPEN:	PUSHM.L	D0,D3,D6	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',NE EXIT$	LOAD.W	(A6)+OIOCH,D6	; mm. canal	LOAD.W	(A6)+OIOPT,#LTMIOEXIT$:	POPM.L	D0,D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDWORD  >;========/; Lit un word (16 bits).; in	-; out	D4.W	nombre lu;	D7.W	erreur; mod	D4.L, D7.WRDWORD:	PUSH.L	D3	CALL	RDONE		; D3 <-- high byte	JUMP',NE EXIT$	LOAD.B	D4,D3	SL.W	D4,#8	CALL	RDONE		; D3 <-- low byte	JUMP',NE EXIT$	LOAD.B	D4,D3EXIT$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDMANY  >;========/; Lit plusieurs bytes dans le fichier en entre.; in	A4.L	^buffer;	D4.W	nombre de bytes  lire; out	(A4)++	bytes lus;	D4.W	nombre de bytes lus;	D7.W	erreur; mod	D4.L, D7.WRDMANY:	PUSHM.L	D2,D3,A4	CLR.W	D7		; D7 <-- ok	LOAD.W	D2,D4		; D2 <-- nb de bytes  lire	JUMP',EQ EXIT$	CLR.W	D4		; D4 <-- nb de bytes lusLOOP$:	CALL	RDONE		; D3 <-- lit un byte	JUMP',NE EXIT$	LOAD.B	(A4+),D3	INC.W	D4	DEC.W	D2	JUMP,NE LOOP$EXIT$:	POPM.L	D2,D3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDONE   >;========/; Lit un byte dans le fichier d'entre.; in	-; out	D3.B	byte lu;	D7.W	erreur; mod	D3.L, D7.WRDONE:	PUSHM.L	D4,D6,A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer tampon	COMP.W	(A6)+OIOPT,#LTMIO ; reste qq chose ?	JUMP',LO 50$		; oui => 50$				; non =>	LOAD.L	D4,#LTMIO	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?RDBYTE		; lit tout le buffer	LOAD.W	(A6)+OIONB,#-1	CLR.W	(A6)+OIOPT	; buffer vide	TEST.W	D7		; lecture ok ?	JUMP',EQ 50$		; oui => 50$	COMP.W	D7,#EROUTF	; fin du fichier ?	JUMP',NE EXIT$		; non => EXIT$	CLR.W	D7		; D7 <-- ok pour l'instant	LOAD.W	(A6)+OIONB,D4	; mm. lg dernire tranche50$:	TEST.W	(A6)+OIONB	; reste qq chose ?	JUMP',NE 60$		; oui => 60$	LOAD.W	D7,#EROUTF	; D7 <-- fin du fichier	JUMP'	EXIT$60$:	LOAD.W	D4,(A6)+OIOPT	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- un byte du buffer	INC.W	(A6)+OIOPT	; avance "pointeur"	DEC.W	(A6)+OIONB	; diminue resteEXIT$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDCLOSE >;========/; Ferme le fichier en entre.; in	D7.W	ok/erreur; out	D7.W	erreur; mod	D7.WRDCLOSE:	PUSHM.L	D5,D6	LOAD.W	D5,D7		; D5 <-- ok/erreur	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?CLOSE		; ferme le fichier	COMP.W	D7,D5	JUMP',HS EXIT$	LOAD.W	D7,D5		; D7 <-- erreur la plus grve !EXIT$:	POPM.L	D5,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; WROPEN  >;========/; Ouvre le fichier en sortie.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WWROPEN:	PUSHM.L	D0,D3,D6	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',NE EXIT$	LOAD.W	(A6)+OIOCH,D6	; mm. canal	CLR.W	(A6)+OIOPT	; buffer videEXIT$:	POPM.L	D0,D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRNUM   >;========/; Ecrit un nombre dans le fichier de sortie.; in	D4.W	nombre; out	D7.W	erreur; mod	D7.WWRNUM:	PUSHM.L	A3,A4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	CALL	PUTANUM	CALL	WRTEXT	POPM.L	A3,A4	RET;--------\\; WRTEXT  >;========/; Ecrit un texte (.ASCIZ) dans le fichier de sortie.; in	A3.L	^texte termin par <0>; out	D7.W	erreur; mod	D7.WWRTEXT:	PUSHM.L	D4,A3,A4	LOAD.L	A4,A3	LOAD.W	D4,#-110$:	INC.W	D4	TEST.B	(A3+)	JUMP,NE 10$	CALL	WRMANY		; crit tout le .ASCIZ	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRWORD  >;========/; Ecrit un word (16 bits).; in	D4.W	nombre  crire; out	D7.W	erreur; mod	D7.WWRWORD:	PUSH.W	D3	LOAD.W	D3,D4	SR.W	D3,#8	CALL	WRONE		; crit le high byte	JUMP',NE EXIT$	LOAD.B	D3,D4	CALL	WRONE		; crit le low byteEXIT$:	POP.W	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRMANY  >;========/; Ecrit plusieurs bytes dans le fichier de sortie.; in	A4.L	^bytes  crire;	D4.W	nombre de bytes  crire; out	D7.W	erreur; mod	D7.WWRMANY:	PUSHM.L	D3,D4,D6,A2..A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A3,A4		; A3 <-- ^bytes  crire	LOAD.W	D3,D4		; D3 <-- nombre	JUMP',EQ EXIT$LOOP$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OIOPT	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrerXFER$:	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ WRITE$	LOAD.B	(A4+),(A3+)	; buffer <-- un byte	INC.W	D4		; D4 <-- un byte de plus	DEC.W	D3	JUMP,NE	XFER$	LOAD.W	(A6)+OIOPT,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$WRITE$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE EXIT$		; erreur => EXIT$	CLR.W	(A6)+OIOPT	; signal buffer vide	JUMP	LOOP$EXIT$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRONE   >;========/; Ecrit un byte dans le fichier de sortie.; in	D3.B	byte  crire; out	D7.W	erreur; mod	D7.WWRONE:	PUSHM.L	D4,D6,A2,A4LOOP$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OIOPT	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ WRITE$	LOAD.B	(A4),D3		; buffer <-- le byte	INC.W	D4		; D4 <-- un byte de plus	LOAD.W	(A6)+OIOPT,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$WRITE$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE EXIT$		; erreur => EXIT$	CLR.W	(A6)+OIOPT	; signal buffer vide	JUMP	LOOP$EXIT$:	POPM.L	D4,D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRCLOSE >;========/; Ecrit le reste du fichier de sortie, puis ferme.; in	D7.W	ok/erreur; out	D7.W	erreur; mod	D7.WWRCLOSEX:	LOAD.W	D7,D5WRCLOSE:	PUSHM.L	D4..D6,A4	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	LOAD.W	D5,D7		; D5 <-- ok/erreur	JUMP',NE 50$		; erreur => 50$				; ok =>	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer tampon	CLR.L	D4	LOAD.W	D4,(A6)+OIOPT	; D4 <-- nb bytes dans buffer	JUMP',EQ 50$		; si vide => 50$				; si reste qq chose =>	FOS	?WRBYTE		; crit tout le buffer	LOAD.W	D5,D750$:	FOS	?CLOSE		; ferme le fichier	COMP.W	D7,D5	JUMP',HS EXIT$	LOAD.W	D7,D5		; D7 <-- erreur la plus grve !EXIT$:	POPM.L	D4..D6,A4	TEST.W	D7		; retour EQ/NE	RET	.END