	.SBTTL	RHBIMAGE.ASI;--------\\; IFMOVE  >;========/; Cherche dans quelle unit est la souris.; in	D4.L	position de la souris (y;x); out	D3.W	numro de l'unit;	D7.W	erreur; mod	D3.L, D7.WIFMOVE:	PUSHM.L	D2,D4	CALL	IFDET		; D3 <-- unit o est la souris	JUMP',NE EXIT$	CALL	IFINV		; allume l'unit montre	LOAD.W	D2,D3LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	IFDET		; D3 <-- unit o est la souris	COMP.W	D3,D2		; toujours dans la mme unit ?	JUMP,EQ LOOP$		; oui => LOOP$	EX.L	D2,D3	CALL	IFINV		; teint l'ancienne	LOAD.W	D3,D2	CALL	IFINV		; allume la nouvelle	JUMP	LOOP$END$:	LOAD.W	D3,D2	CALL	IFINV		; teint la dernire	TEST.W	D3	JUMP',NE EXIT$	LOAD.W	D7,#1EXIT$:	POPM.L	D2,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFDET   >;--------/; Cherche dans quelle unit est la souris.; in	D4.L	position de la souris (y;x); out	D3.W	numro de l'unit (zro si ailleurs);	D7.W	erreur; mod	D3.L, D7.WIFDET:	PUSHM.L	D2,D4,A4	LOAD.W	D3,D4		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	LOAD.L	A4,#R16"TAIFOND-LTIFLOOP$:	LOAD.L	A4,#(A4)+LTIF	; A4 <-- ^suivant	TEST.W	(A4)	JUMP',EQ ERROR$	LOAD.W	D2,(A4)+OTIFDP+0	COMP.W	D3,D2	JUMP,LO LOOP$	ADD.W	D2,(A4)+OTIFDD+0	COMP.W	D3,D2	JUMP,HI LOOP$	LOAD.W	D2,#IDIMY-1	SUB.W	D2,(A4)+OTIFDP+2	COMP.W	D4,D2	JUMP,LO LOOP$	ADD.W	D2,(A4)+OTIFDD+2	COMP.W	D4,D2	JUMP,HI LOOP$	LOAD.W	D3,(A4)		; D3 <-- numro de l'unit	CLR.W	D7	JUMP'	EXIT$ERROR$:	CLR.W	D3	LOAD.W	D7,#1EXIT$:	POPM.L	D2,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFINV   >;--------/; Inverse la zone de dtection d'une unit.; in	D3.W	numro de l'unit; out	-; mod	D7.WIFINV:	PUSHM.L	D2..D4,A4	TEST.W	D3	JUMP',EQ EXIT$	CALL	IFSEARCH	; A4 <-- ^OTIF*	JUMP',NE EXIT$	LOAD.W	D3,#IDIMY-1	SUB.W	D3,(A4)+OTIFDP+2	SUB.W	D3,#3	SWAP.W	D3	LOAD.W	D3,(A4)+OTIFDP+0	SUB.W	D3,#3	LOAD.W	D4,(A4)+OTIFDD+2	ADD.W	D4,#6	SWAP.W	D4	LOAD.W	D4,(A4)+OTIFDD+0	ADD.W	D4,#6	LOAD.W	D2,#INVDOT	LIB	?DRRECTEXIT$:	POPM.L	D2..D4,A4	RET;--------\\; IFETAT  >;========/; Met  jour les icnes d'une unit selon un tat.; in	D3.W	numro de l'unit;	D4.W	tat (0,1); out	-; mod	D7.WIFETAT:	PUSHM.L	D2..D4,A4	CALL	IFSEARCH	; A4 <-- ^OTIF*	JUMP,NE EXIT$	COMP.W	(A4)+OTIFNF,#FLAUTO	JUMP,EQ AUTO$	TEST.W	D4	JUMP',NE ROUGE$VERT$:	LOAD.L	D3,(A4)+OTIFRP	LOAD.W	D4,(A4)+OTIFRF	LOAD.W	D2,#CLRDOT	CALL	IFMATRIX;	LOAD.L	D3,(A4)+OTIFRP	LOAD.W	D4,(A4)+OTIFNF	LOAD.W	D2,#SETDOT	CALL	IFMATRIX	LOAD.L	D3,(A4)+OTIFVP	LOAD.W	D4,(A4)+OTIFNF	LOAD.W	D2,#CLRDOT	CALL	IFMATRIX;	LOAD.L	D3,(A4)+OTIFVP	LOAD.W	D4,(A4)+OTIFVF	LOAD.W	D2,#SETDOT	CALL	IFMATRIX	JUMP	EXIT$ROUGE$:	LOAD.L	D3,(A4)+OTIFRP	LOAD.W	D4,(A4)+OTIFNF	LOAD.W	D2,#CLRDOT	CALL	IFMATRIX;	LOAD.L	D3,(A4)+OTIFRP	LOAD.W	D4,(A4)+OTIFRF	LOAD.W	D2,#SETDOT	CALL	IFMATRIX	LOAD.L	D3,(A4)+OTIFVP	LOAD.W	D4,(A4)+OTIFVF	LOAD.W	D2,#CLRDOT	CALL	IFMATRIX;	LOAD.L	D3,(A4)+OTIFVP	LOAD.W	D4,(A4)+OTIFNF	LOAD.W	D2,#SETDOT	CALL	IFMATRIX	JUMP'	EXIT$AUTO$:	LOAD.W	D4,#FL00	LOAD.L	D3,(A4)+OTIFRP	LOAD.W	D2,#CLRDOT	CALL	IFMATRIX	LOAD.W	D4,(A4)+OTIFRF	; D4 <-- offset variable	LOAD.W	D4,(A6)+(D4.W)	; D4 <-- valeur variable	ADD.W	D4,#FL0	COMP.W	D4,#FL9	JUMP',LS AUTOM$	LOAD.W	D4,#FL9AUTOM$:;	LOAD.L	D3,(A4)+OTIFRP	LOAD.W	D2,#SETDOT	CALL	IFMATRIX;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4,A4	RET;---------\\; IFMATRIX >;---------/; Dessine une matrice de flche.; in	D4.W	type de la flche (FL*);	D3.L	centre (x;yi);	D2.W	mode de dessin; out	-; mod	D7.WIFMATRIX:	PUSHM.L	D3,A3,A4	TEST.L	D3	JUMP,EQ	EXIT$	LOAD.L	A3,#R16"TABLE$-4SRC$:	ADD.L	A3,#4	TEST.W	(A3)	JUMP',NS EXIT$	COMP.W	D4,(A3)	JUMP,NE SRC$	LOAD.L	A4,#R16"ADCODE	CLR.L	D4	LOAD.W	D4,(A3)+2	ADD.L	A4,D4		; A4 <-- ^dx,dy,matrice	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	SUB.W	D3,#IDIMY-1	NEG.W	D3	SUB.W	D3,#2	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LOAD.L	(A3)+1,D3	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,D2	TEST.B	(A6)+OINV	; affichage invers ?	JUMP',F	DRAW$	LOAD.B	(A3)+9,#SETDOT	COMP.B	D2,#CLRDOT	JUMP',EQ DRAW$	LOAD.B	(A3)+9,#CLRDOTDRAW$:	TSET.B	(A3)+9:#BPENDOT	LOAD.W	D3,#10	LIB	?STRINGEXIT$:	POPM.L	D3,A3,A4	RETTABLE$:	.W	FLN,MATN$	.W	FLNNE,MATNNE$	.W	FLNE,MATNE$	.W	FLENE,MATENE$	.W	FLE,MATE$	.W	FLESE,MATESE$	.W	FLSE,MATSE$	.W	FLSSE,MATSSE$	.W	FLS,MATS$	.W	FLSSO,MATSSO$	.W	FLSO,MATSO$	.W	FLOSO,MATOSO$	.W	FLO,MATO$	.W	FLONO,MATONO$	.W	FLNO,MATNO$	.W	FLNNO,MATNNO$	.W	FLBLOC,MATBLOC$	.W	FLDT0,MATDT0$	.W	FLDT1,MATDT1$	.W	FLAV,MATAV$	.W	FLAR,MATAR$	.W	FLSTOP,MATSTOP$	.W	FLGO,MATGO$	.W	FLRIEN,MATRIEN$	.W	FLBLANC,MATBLANC$	.W	FL00,MAT00$	.W	FL0,MAT0$	.W	FL1,MAT1$	.W	FL2,MAT2$	.W	FL3,MAT3$	.W	FL4,MAT4$	.W	FL5,MAT5$	.W	FL6,MAT6$	.W	FL7,MAT7$	.W	FL8,MAT8$	.W	FL9,MAT9$	.W	-1MATN$:	.B	5,6	.B	B'00100000	.B	B'01110000	.B	B'11111000	.B	B'00100000	.B	B'00100000	.B	B'00100000	.B	B'00000000	.B	B'00000000MATE$:	.B	6,5	.B	B'00010000	.B	B'00011000	.B	B'11111100	.B	B'00011000	.B	B'00010000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATS$:	.B	5,6	.B	B'00100000	.B	B'00100000	.B	B'00100000	.B	B'11111000	.B	B'01110000	.B	B'00100000	.B	B'00000000	.B	B'00000000MATO$:	.B	6,5	.B	B'00100000	.B	B'01100000	.B	B'11111100	.B	B'01100000	.B	B'00100000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATNE$:	.B	5,5	.B	B'01111000	.B	B'00111000	.B	B'00111000	.B	B'01001000	.B	B'10000000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATSE$:	.B	5,5	.B	B'10000000	.B	B'01001000	.B	B'00111000	.B	B'00111000	.B	B'01111000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATSO$:	.B	5,5	.B	B'00001000	.B	B'10010000	.B	B'11100000	.B	B'11100000	.B	B'11110000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATNO$:	.B	5,5	.B	B'11110000	.B	B'11100000	.B	B'11100000	.B	B'10010000	.B	B'00001000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATNNE$:	.B	5,6	.B	B'00110000	.B	B'01110000	.B	B'11111000	.B	B'00101000	.B	B'01000000	.B	B'01000000	.B	B'00000000	.B	B'00000000MATENE$:	.B	6,5	.B	B'00110000	.B	B'00011100	.B	B'00111100	.B	B'11011000	.B	B'00010000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATESE$:	.B	6,5	.B	B'00010000	.B	B'11011000	.B	B'00111100	.B	B'00011100	.B	B'00110000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATSSE$:	.B	5,6	.B	B'01000000	.B	B'01000000	.B	B'00101000	.B	B'11111000	.B	B'01110000	.B	B'00110000	.B	B'00000000	.B	B'00000000MATSSO$:	.B	5,6	.B	B'00010000	.B	B'00010000	.B	B'10100000	.B	B'11111000	.B	B'01110000	.B	B'01100000	.B	B'00000000	.B	B'00000000MATOSO$:	.B	6,5	.B	B'00100000	.B	B'01101100	.B	B'11110000	.B	B'11100000	.B	B'00110000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATONO$:	.B	6,5	.B	B'00110000	.B	B'11100000	.B	B'11110000	.B	B'01101100	.B	B'00100000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATNNO$:	.B	5,6	.B	B'01100000	.B	B'01110000	.B	B'11111000	.B	B'10100000	.B	B'00010000	.B	B'00010000	.B	B'00000000	.B	B'00000000MATRIEN$:	.B	5,5	.B	B'00000000	.B	B'01010000	.B	B'00100000	.B	B'01010000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATBLOC$:	.B	5,5	.B	B'01110000	.B	B'11111000	.B	B'00000000	.B	B'11111000	.B	B'01110000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATDT0$:	.B	5,5	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'01010000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATDT1$:	.B	5,5	.B	B'00100000	.B	B'00100000	.B	B'01110000	.B	B'01110000	.B	B'11111000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATBLANC$:	.B	8,8	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000MATAV$:	.B	8,8	.B	B'00001000	.B	B'00001100	.B	B'00001110	.B	B'11111111	.B	B'11111111	.B	B'00001110	.B	B'00001100	.B	B'00001000MATAR$:	.B	8,8	.B	B'00010000	.B	B'00110000	.B	B'01011111	.B	B'10000001	.B	B'10000001	.B	B'01011111	.B	B'00110000	.B	B'00010000MATSTOP$:	.B	8,8	.B	B'00111100	.B	B'01111110	.B	B'11111111	.B	B'10000001	.B	B'10000001	.B	B'11111111	.B	B'01111110	.B	B'00111100MATGO$:	.B	8,8	.B	B'00000000	.B	B'11100100	.B	B'01100100	.B	B'11111110	.B	B'11111111	.B	B'11111110	.B	B'01101111	.B	B'01101101MAT00$:	.B	8,8	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111	.B	B'11111111MAT0$:	.B	8,8	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000MAT1$:	.B	8,8	.B	B'00000000	.B	B'11100100	.B	B'01100100	.B	B'11111110	.B	B'11111111	.B	B'11111110	.B	B'01101111	.B	B'01101101MAT2$:	.B	8,8	.B	B'00111100	.B	B'01100110	.B	B'01100110	.B	B'00001110	.B	B'00011100	.B	B'00111000	.B	B'01110010	.B	B'01111110MAT3$:	.B	8,8	.B	B'00111100	.B	B'01100110	.B	B'00000110	.B	B'00011100	.B	B'00000110	.B	B'00000110	.B	B'01100110	.B	B'00111100MAT4$:	.B	8,8	.B	B'00001100	.B	B'00011100	.B	B'00111100	.B	B'01101100	.B	B'11001100	.B	B'11111110	.B	B'00001100	.B	B'00011110MAT5$:	.B	8,8	.B	B'01111100	.B	B'01100000	.B	B'01100000	.B	B'01111100	.B	B'00000110	.B	B'00000110	.B	B'01100110	.B	B'00111100MAT6$:	.B	8,8	.B	B'00111100	.B	B'01100110	.B	B'01100000	.B	B'01111100	.B	B'01100110	.B	B'01100110	.B	B'01100110	.B	B'00111100MAT7$:	.B	8,8	.B	B'01111110	.B	B'01100110	.B	B'00000110	.B	B'00001100	.B	B'00001100	.B	B'00011000	.B	B'00011000	.B	B'00011000MAT8$:	.B	8,8	.B	B'00111100	.B	B'01100110	.B	B'01100110	.B	B'00111100	.B	B'01100110	.B	B'01100110	.B	B'01100110	.B	B'00111100MAT9$:	.B	8,8	.B	B'00111100	.B	B'01100110	.B	B'01100110	.B	B'01100110	.B	B'00111110	.B	B'00000110	.B	B'01100110	.B	B'00111100	.EVEN;---------\\; IFSEARCH >;---------/; Cherche les paramtres d'une unit dans l'image de fond.; in	D3.W	numro de l'unit; out	A4.L	^OTIF*;	D7.W	erreur; mod	D7.W, A4.LIFSEARCH:	LOAD.L	A4,#R16"TAIFOND-LTIF	LOAD.W	D7,#1LOOP$:	LOAD.L	A4,#(A4)+LTIF	; A4 <-- ^suivant	TEST.W	(A4)	JUMP',EQ EXIT$	COMP.W	D3,(A4)	JUMP,NE LOOP$	CLR.W	D7EXIT$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGELOAD >;==========/; Charge une image en mmoire.; in	A3.L	^nom de l'image; out	A4.L	^image;	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	A4.L, D7.W, A4.LIMAGELOAD:	PUSHM.L	D0,D1,D3,D6,A1..A3,A5	LOAD.L	A5,A3		; A5 <-- ^nom de l'image	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE 84$	LOAD.L	A4,A2	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$	COMP.B	(A2)+OIMTYP,#H'82 ; image du LAMI ?	JUMP',NE 20$		; non => 20$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute la stupide en-tte de 256 bytes !	JUMP,NE 82$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$20$:	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE 82$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP',NE 80$	JUMP'	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 80$	LOAD.L	A3,A1	GRA_	DECOIMA		; dcode l'image ...	JUMP',NE 80$35$:	LOAD.L	A4,A1		; A4 <-- ^image	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions de l'image	CLR.W	D7		; D7 <-- ok	JUMP'	82$80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D784$:	PUSHM.L	D7,A4	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POPM.L	D7,A4EXIT$:	POPM.L	D0,D1,D3,D6,A1..A3,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; IMAGESHOW >;==========/; Affiche une image dans la (sous-)fentre.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie centrale.; in	A4.L	^image;	D4.L	dimensions (dy;dx);	D3.L	coin sup/gauche (y;x); out	-; mod	D7.WIMAGESHOW:	PUSHM.L	D0,D1,D3,D4,A3	LOAD.W	D0,D4		; D0 <-- largeur de l'image	SWAP.W	D4	LOAD.W	D1,D4		; D1 <-- hauteur de l'image	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^buffer pour DRAWRASTER	LOAD.W	(A3)+12,D3	; destination: <xx>	SWAP.W	D3	LOAD.W	(A3)+14,D3	; destination: <yy>	LOAD.W	D3,D0	SR.W	D3,#3	LOAD.W	(A3)+10,D3	; source: <ii>	CLR.W	(A3)+20		; destination: <ii>	CLR.W	(A3)+2		; source: <xx>	LOAD.W	(A3)+22,D0	; image: <dxx>	CLR.W	(A3)+4		; source: <yy>	LOAD.W	(A3)+24,D1	; image: <dyy>	LOAD.W	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+6,A4	; source: <pppp>	CLR.L	(A3)+16		; destination: <pppp>	LOAD.B	(A3)+26,#LOADDOT	TEST.B	(A6)+OINV	; affichage invers ?	JUMP',F DRAW$	LOAD.B	(A3)+26,#LOADDOT!CPLDOTDRAW$:	LOAD.W	D3,#1+26	; D3 <-- longueur	LIB	?STRING		; affiche l'image	POPM.L	D0,D1,D3,D4,A3	RET;----------\\; IMAGEKILL >;==========/; Libre la mmoire d'une image.; in	A4.L	^image; out	-; mod	-IMAGEKILL:	PUSHM.L	D1,D7,A4	COMP.L	A4,#0	JUMP',EQ EXIT$	LOAD.L	A4,#(A4)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'imageEXIT$:	POPM.L	D1,D7,A4	RET	.END