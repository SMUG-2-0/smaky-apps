	.SBTTL	TRAINALGO.ASI;--------\\; ALGOSND >;========/; Excute l'algorithme associ  une cellule.; in	D1.W	rang (0..n); out	-; mod	D7.WALGOSND:	CLR.W	(A6)+ONBRECALGOSND0:	PUSHM.L	D3,A2..A4	TEST.B	(A6)+OAUTO	; automatismes ?	JUMP',F EXIT$		; non => EXIT$	COMP.W	(A6)+ONBREC,#2	JUMP',HS EXIT$	INC.W	(A6)+ONBREC	CALL	CELGETP		; A4 <-- ^cellule	JUMP',NE DEC$	TEST.L	(A4)+OCEPAL	; y a-t-il un algorithme ?	JUMP',EQ DEC$		; non => DEC$	LOAD.L	A2,A4		; A2 <-- ^cellule	LOAD.L	A3,(A2)+OCEPAL	; A3 <-- ^algorithme	CALL	ALGOEXEC	; excute l'algorithme	JUMP',EQ DEC$	PUSH.W	D7	CALL	PUTSTOP		; stoppe tout !	POP.W	D7	CALL	DBOXERROR	; signal une erreur ...	LOAD.L	A4,A3		; A4 <-- ^sur l'erreur	LOAD.L	A3,(A2)+OCEPAL	; A3 <-- ^algorithme	CALL	ALGOEDIT	; dite l'algorithme faux ...	JUMP',NE DEC$	LOAD.L	(A2)+OCEPAL,A3	; mj ^algorithmeDEC$:	DEC.W	(A6)+ONBRECEXIT$:	POPM.L	D3,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; ALGOEXEC >;=========/; Excute un algorithme.; in	A3.L	^algorithme; out	A3.L	^sur l'erreur;	D7.W	erreur; mod	D7.W, A3.LALGOEXEC:	PUSHM.L	D3,D4,A2LOOP$:	LOAD.L	A2,A3	CALL	ALGOXGETPC	; D3 <-- PC* ou autre	TEST.B	D3	JUMP',EQ OK$	COMP.B	D3,#PCSI	JUMP',EQ IF$	LOAD.L	A3,A2	LOAD.W	D4,#1		; D4 <-- TRUE	CALL	ALGOXOP4	; excute une instruction simple	JUMP',NE EXIT$	JUMP	LOOP$IF$:	LOAD.W	D4,#1		; D4 <-- TRUE	CALL	ALGOXOP5	; excute un "SI..ALORS..SINON..FIN"	JUMP',NE EXIT$	JUMP	LOOP$OK$:	CLR.W	D7EXIT$:	POPM.L	D3,D4,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; ALGOXOP5 >;---------/; Effectue une opration "Si .. Alors .. Sinon .. Fin".; in	A3.L	^dans l'algorithme (aprs le PCSI);	D4.W	0 => FALSE; out	A3.L	^plus loin;	D7.W	erreur; mod	D7.W, A3.LALGOXOP5:	PUSHM.L	D1..D4,A2	LOAD.W	D2,D4		; D2 <-- TRUE/FALSE	CALL	ALGOXOP3	; D4 <-- valeur entre SI et ALORS	JUMP,NE EXIT$	LOAD.W	D1,D4		; D1 <-- valeur du test	CALL	ALGOXGETPC	; D3 <-- PC* ou autre	LOAD.W	D7,#ERMSALO	COMP.B	D3,#PCALORS	JUMP,NE EXIT$IFLOOP$:	LOAD.L	A2,A3	CALL	ALGOXGETPC	; D3 <-- PC* ou autre	COMP.B	D3,#PCSI	JUMP',EQ RECURS$	COMP.B	D3,#PCSINON	JUMP',EQ ELSE$	COMP.B	D3,#PCFIN	JUMP',EQ END$	LOAD.L	A3,A2	LOAD.W	D4,D1	AND.W	D4,D2		; D4 <-- rsultat du test	CALL	ALGOXOP4	; excute une instruction aprs ALORS	JUMP',NE EXIT$	JUMP	IFLOOP$RECURS$:	LOAD.W	D4,D1	AND.W	D4,D2		; D4 <-- rsultat du test	CALL	ALGOXOP5	; appel rcursif !	JUMP',NE EXIT$	JUMP	IFLOOP$ELSE$:	TEST.W	D1	JUMP',EQ ETRUE$	CLR.W	D1		; D1 <-- FALSE	JUMP	IFLOOP$ETRUE$:	INC.W	D1		; D1 <-- TRUE (#1)	JUMP	IFLOOP$END$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; ALGOXOP4 >;---------/; Effectue une opration "$100:=0" ou "Bloque($100,2)".; in	A3.L	^dans l'algorithme;	D4.W	0 => FALSE; out	A3.L	^plus loin;	D7.W	erreur; mod	D7.W, A3.LALGOXOP4:	PUSHM.L	D1..D4,A2,A4	LOAD.W	D2,D4		; D2 <-- TRUE/FALSE	CALL	ALGOXUNIT	; D4 <-- unit	JUMP',NE OPER$	CALL	ALGOXGETPC	; D3 <-- PC* ou autre	LOAD.W	D7,#ERMSASS	COMP.B	D3,#PCASS	JUMP,NE EXIT$	LOAD.W	D3,D4	CALL	ALGOXOP3	; D4 <-- valeur	JUMP,NE EXIT$	TEST.W	D2		; rsultat du test = FALSE ?	JUMP,EQ OK$		; oui => OK$	CALL	GETPTCEL	; D1/A4 <-- rang/^cellule	JUMP,NE EXIT$	LOAD.B	(A4)+OCEETA,D4	; mmorise l'tat	CALL	CELDRAW		; dessine le nouvel tat	CALL	ALGOSND0	; excute un ventuel algorithme !	CALL	MAJUNITRC	; met  jour l'tat	JUMP	OK$OPER$:	LOAD.L	A2,A3	CALL	ALGOXGETPC	; D3 <-- PC* ou autre	COMP.B	D3,#PCBLOQUE	JUMP',EQ LOCK$	COMP.B	D3,#PCLIBERE	JUMP',EQ UNLOCK$	LOAD.L	A3,A2	LOAD.W	D7,#ERMSYNT	JUMP'	EXIT$LOCK$:	LOAD.B	D3,(A3+)	SL.W	D3,#8	LOAD.B	D3,(A3+)	; D3 <-- numro de l'unit	LOAD.B	D4,(A3+)	SL.W	D4,#8	LOAD.B	D4,(A3+)	; D4 <-- temps	TEST.W	D2		; rsultat du test = FALSE ?	JUMP',EQ OK$		; oui => OK$	CALL	LOCKUNIT	; bloque une unit	JUMP'	OK$UNLOCK$:	LOAD.B	D3,(A3+)	SL.W	D3,#8	LOAD.B	D3,(A3+)	; D3 <-- numro de l'unit	TEST.W	D2		; rsultat du test = FALSE ?	JUMP',EQ OK$		; oui => OK$	CALL	UNLOCKUNIT	; dbloque une unit;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; ALGOXOP3 >;---------/; Calcule les oprations "ET" et "OU".; in	A3.L	^dans l'algorithme; out	A3.L	^plus loin;	D4.W	rsultat;	D7.W	erreur; mod	D4.L, D7.W, A3.LALGOXOP3:	PUSHM.L	D3,D5,A2	CALL	ALGOXOP2	; D4 <-- valeur	JUMP,NE EXIT$LOOP$:	LOAD.L	A2,A3	CALL	ALGOXGETPC	; D3 <-- PC* ou autre	COMP.B	D3,#PCET	JUMP',EQ OP$	COMP.B	D3,#PCOU	JUMP',EQ OP$	LOAD.L	A3,A2	CLR.W	D7	JUMP'	EXIT$OP$:	LOAD.W	D5,D4	CALL	ALGOXOP2	; D4 <-- valeur	JUMP',NE EXIT$	COMP.B	D3,#PCOU	JUMP',EQ OU$ET$:	AND.W	D4,D5	JUMP	LOOP$OU$:	OR.W	D4,D5	JUMP	LOOP$EXIT$:	POPM.L	D3,D5,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; ALGOXOP2 >;---------/; Calcule les oprations "=" et "<>".; in	A3.L	^dans l'algorithme; out	A3.L	^plus loin;	D4.W	rsultat;	D7.W	erreur; mod	D4.L, D7.W, A3.LALGOXOP2:	PUSHM.L	D3,D5,A2	CALL	ALGOXOP1	; D4 <-- valeur	JUMP,NE EXIT$LOOP$:	LOAD.L	A2,A3	CALL	ALGOXGETPC	; D3 <-- PC* ou autre	COMP.B	D3,#PCEGAL	JUMP',EQ OP$	COMP.B	D3,#PCDIFF	JUMP',EQ OP$	LOAD.L	A3,A2	CLR.W	D7	JUMP'	EXIT$OP$:	LOAD.W	D5,D4	CALL	ALGOXOP1	; D4 <-- valeur	JUMP',NE EXIT$	COMP.B	D3,#PCDIFF	JUMP',EQ DIFF$EGAL$:	COMP.W	D4,D5	JUMP',EQ TRUE$	JUMP	FALSE$DIFF$:	COMP.W	D4,D5	JUMP',NE TRUE$	JUMP	FALSE$TRUE$:	LOAD.W	D4,#1		; D4 <-- TRUE	JUMP	LOOP$FALSE$:	CLR.W	D4		; D4 <-- FALSE	JUMP	LOOP$EXIT$:	POPM.L	D3,D5,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; ALGOXOP1 >;---------/; Calcule les oprations "+" et "-".; in	A3.L	^dans l'algorithme; out	A3.L	^plus loin;	D4.W	rsultat;	D7.W	erreur; mod	D4.L, D7.W, A3.LALGOXOP1:	PUSHM.L	D3,D5,A2	CALL	ALGOXVAL	; D4 <-- valeur	JUMP,NE EXIT$LOOP$:	LOAD.L	A2,A3	CALL	ALGOXGETPC	; D3 <-- PC* ou autre	COMP.B	D3,#PCADD	JUMP',EQ OP$	COMP.B	D3,#PCSUB	JUMP',EQ OP$	LOAD.L	A3,A2	CLR.W	D7	JUMP'	EXIT$OP$:	LOAD.W	D5,D4	CALL	ALGOXVAL	; D4 <-- valeur	JUMP',NE EXIT$	COMP.B	D3,#PCSUB	JUMP',EQ SUB$ADD$:	ADD.W	D4,D5	JUMP	LOOP$SUB$:	SUB.W	D5,D4	LOAD.W	D4,D5	JUMP	LOOP$EXIT$:	POPM.L	D3,D5,A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; ALGOXUNIT >;----------/; Donne le numro d'une unit.; Par exemple, "$10" donnera 10.; in	A3.L	^dans l'algorithme; out	A3.L	^plus loin;	D4.W	unit;	D7.W	erreur; mod	D4.L, D7.W, A3.LALGOXUNIT:	PUSHM.L	D3,A2	LOAD.L	A2,A3		; A2 <-- A3 initial	CALL	ALGOXGETPC	; D3 <-- PC* ou autre	COMP.B	D3,#PCUNIT	JUMP',EQ UNIT$	LOAD.L	A3,A2		; A3 <-- inchang	LOAD.W	D7,#ERMSUNI	JUMP'	EXIT$UNIT$:	LOAD.B	D4,(A3+)	SL.W	D4,#8	LOAD.B	D4,(A3+)	; D4 <-- numro de l'unit	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; ALGOXVAL >;---------/; Donne la valeur d'une cellule "$10" ou d'une constante "Stop".; in	A3.L	^dans l'algorithme; out	A3.L	^plus loin;	D4.W	valeur;	D7.W	erreur; mod	D4.L, D7.W, A3.LALGOXVAL:	PUSHM.L	D1,D3,A2,A4	LOAD.L	A2,A3		; A2 <-- A3 initial	CALL	ALGOXGETPC	; D3 <-- PC* ou autre	COMP.B	D3,#PCSTOP	JUMP',EQ ZERO$	COMP.B	D3,#PCPASSE	JUMP',EQ UN$	COMP.B	D3,#PCDEVIE	JUMP',EQ ZERO$	COMP.B	D3,#PCDROIT	JUMP',EQ UN$	COMP.B	D3,#PCNUM	JUMP',EQ NUM$	COMP.B	D3,#PCUNIT	JUMP',EQ UNIT$	LOAD.L	A3,A2		; A3 <-- inchang	LOAD.W	D7,#ERMSVAL	JUMP'	EXIT$NUM$:	LOAD.B	D4,(A3+)	SL.W	D4,#8	LOAD.B	D4,(A3+)	; D4 <-- valeur	JUMP'	OK$UNIT$:	LOAD.B	D3,(A3+)	SL.W	D3,#8	LOAD.B	D3,(A3+)	; D3 <-- numro de l'unit	CALL	GETPTCEL	; A4/D1 <-- ^cellule/rang	JUMP',NE EXIT$	CLR.W	D4	LOAD.B	D4,(A4)+OCEETA	; D4 <-- tat de la cellule	JUMP'	OK$ZERO$:	CLR.W	D4		; D4 <-- constante #0	JUMP'	OK$UN$:	LOAD.W	D4,#1		; D4 <-- constante #1;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D3,A2,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ALGOXGETPC >;-----------/; Donne le byte significatif suivant.; in	A3.L	^dans l'algorithme; out	A3.L	^plus loin;	D3.B	opration (PC*); mod	D3.L, D7.W, A3.LALGOXGETPC:LOOP$:	LOAD.B	D3,(A3+)	COMP.B	D3,#SPACE	JUMP,EQ LOOP$	COMP.B	D3,#TAB	JUMP,EQ LOOP$	COMP.B	D3,#CR	JUMP,EQ LOOP$	RET;----------\\; ALGOGETLG >;==========/; Cherche la longueur d'un algorithme.; in	A4.L	^algorithme; out	D4.L	longueur avec le terminateur; mod	D4.L, D7.WALGOGETLG:	PUSHM.L	D3,A4	CLR.L	D4LOOP$:	INC.W	D4	LOAD.B	D3,(A4+)	JUMP',EQ EXIT$	COMP.B	D3,#PCNUM	JUMP',EQ NUM1$	COMP.B	D3,#PCUNIT	JUMP',EQ NUM1$	COMP.B	D3,#PCBLOQUE	JUMP',EQ NUM2$	COMP.B	D3,#PCLIBERE	JUMP',EQ NUM1$	JUMP	LOOP$NUM1$:	ADD.L	A4,#2	ADD.W	D4,#2	JUMP	LOOP$NUM2$:	ADD.L	A4,#4	ADD.W	D4,#4	JUMP	LOOP$EXIT$:	POPM.L	D3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; ALGOEDIT >;=========/; Edite l'algorithme.; in	A2.L	^cellule;	A3.L	^algorithme;	A4.L	^position o lettre le curseur; out	A3.L	^algorithme;	D7.W	erreur; mod	D7.W, A3.LALGOEDIT:	PUSHM.L	D3..D6,A4	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+ODBLIN	LOAD.L	A3,#R16"TXUNI$PTX2$:	LOAD.B	(A4+),(A3+)	JUMP,NE PTX2$	DEC.L	A4	LOAD.W	D4,(A2)+OCEUNI	CALL	PUTANUM	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'(	LOAD.B	D3,(A2)+OCEICO	; D3 <-- icne de la cellule	CALL	CELTXTYPE	; A3 <-- ^typePTX4$:	LOAD.B	(A4+),(A3+)	JUMP,NE PTX4$	DEC.L	A4	LOAD.B	(A4+),#')	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#SPACE	CLR.B	(A4)	POPM.L	A3,A4	CALL	ALGOOPEBUF	; A3/A4/D3 <-- ^buffer/^curseur/lg	JUMP,NE EXIT$EDIT$:	PUSH.L	A3	LOAD.L	A3,#R16"TXMENU$	LIB	?AFMENU		; affiche les soft-keys	POP.L	A3	CALL	ALGOOPEWDO	; ouvre le sous-fentre	JUMP,NE CLOBUF$	LOAD.W	D4,#2^BEPROMOUSE!2^BEPROAFCR!2^BEPROAFLF!2^BEPROAFTAB!2^BEPROTXT	PUSHM.L	A0..A2	LOAD.L	A1,#(A6)+ODBLIN	LOAD.L	A0,#R16"TXNIL$	LOAD.L	A2,#R16"TXNIL$	EPRO_	OPEN		; D6 <-- canal de l'dition	POPM.L	A0..A2	JUMP,NE CLOWDO$LOOP$:	LOAD.L	A4,#R16"TERM$	; A4 <-- ^touches terminatrices	EPRO_	MAIN		; dite ...	JUMP,NE	BIP$	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#END	JUMP,EQ	END$	COMP.W	D3,#F0	JUMP,EQ	END$	COMP.W	D3,#F0+SHIFT	JUMP,EQ	END$	LOAD.L	A3,#R16"TINSD$	COMP.W	D3,#'$	JUMP,EQ INSERT$	LOAD.L	A3,#R16"TINSE$	COMP.W	D3,#'=	JUMP,EQ INSERT$	LOAD.L	A3,#R16"TINS1$	COMP.W	D3,#F1	JUMP,EQ INSERT$	LOAD.L	A3,#R16"TINS2$	COMP.W	D3,#F2	JUMP,EQ INSERT$	LOAD.L	A3,#R16"TINT2$	COMP.W	D3,#F2+SHIFT	JUMP,EQ INSERT$	LOAD.L	A3,#R16"TINS4$	COMP.W	D3,#F4	JUMP,EQ INSERT$	LOAD.L	A3,#R16"TINS5$	COMP.W	D3,#F5	JUMP,EQ INSERT$	LOAD.L	A3,#R16"TINS6$	COMP.W	D3,#F6	JUMP,EQ INSERT$	LOAD.L	A3,#R16"TINS7$	COMP.W	D3,#F7	JUMP,EQ INSERT$	LOAD.L	A3,#R16"TINS8$	COMP.W	D3,#F8	JUMP,EQ INSERT$	LOAD.L	A3,#R16"TINS9$	COMP.W	D3,#F9	JUMP,EQ INSERT$	LOAD.L	A3,#R16"TINS10$	COMP.W	D3,#F10	JUMP',EQ INSERT$	LOAD.L	A3,#R16"TINT10$	COMP.W	D3,#F10+SHIFT	JUMP',EQ INSERT$	LOAD.L	A3,#R16"TINS11$	COMP.W	D3,#F11	JUMP',EQ INSERT$	LOAD.L	A3,#R16"TINT11$	COMP.W	D3,#F11+SHIFT	JUMP',EQ INSERT$	LOAD.L	A3,#R16"TINS13$	COMP.W	D3,#F13	JUMP',EQ INSERT$	LOAD.L	A3,#R16"TINS14$	COMP.W	D3,#F14	JUMP',EQ INSERT$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$INSERT$:			; insre un mot-cl =>	LOAD.B	D3,(A3)	CALL	ALGOIFALPHA	; chane  insrer commence par une lettre ?	JUMP',NE ILOOP$		; non => ILOOP$	CALL	ALGOLAST	; D3 <-- caractre prcdent	JUMP',NE ILOOP$	CALL	ALGOIFALPHA	; caractre prcdent est une lettre ?	JUMP',NE ILOOP$		; non => ILOOP$	LOAD.B	D3,#SPACE	EPRO_	INSERT		; insre un espaceILOOP$:	LOAD.B	D3,(A3+)	JUMP,EQ	LOOP$	EPRO_	INSERT		; insre un caractre	JUMP	ILOOP$END$:	EPRO_	CLOSECLOWDO$:	CALL	ALGOCLOWDO	; ferme la sous-fentreCLOBUF$:	CALL	ALGOCLOBUF	; A3 <-- ^texte<0>	JUMP',EQ EXIT$	CALL	DBOXERROR	; signal une erreur ...	JUMP	EDIT$EXIT$:	CALL	AFMENU		; refait les soft-keys	POPM.L	D3..D6,A4	TEST.W	D7		; retour EQ/NE	RETTXUNI$:	.ASCIZ	"  Algorithme de l'unit $"TXNIL$:	.ASCIZ	""	.EVENTERM$:;	.BB	0,END	.BB	0,'$	.BB	0,'=	.W	0TINSD$:	.ASCIZ	"$"TINSE$:	.ASCIZ	"="TINS1$:	.ASCIZ	"Si"TINS2$:	.ASCIZ	"Et"TINT2$:	.ASCIZ	"Ou"TINS4$:	.ASCIZ	"Alors"TINS5$:	.ASCIZ	"Sinon"TINS6$:	.ASCIZ	"Fin"TINS7$:	.ASCIZ	"="TINS8$:	.ASCIZ	"<'<><'>>"TINS9$:	.ASCIZ	":="TINS10$:.ASCIZ	"Stop"TINT10$:.ASCIZ	"Dvi"TINS11$:.ASCIZ	"Passe"TINT11$:.ASCIZ	"Droit"TINS13$:.ASCIZ	"Bloque($,)"TINS14$:.ASCIZ	"Libre($)"TXMENU$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"       Ou        "	.ASCIZ	"  Si   Et        "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Alors Sinon  Fin "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"  =     <'<><'>>   :=  "		;     ;     ;     ;	.ASCIZ	"Dvi Droit      "	.ASCIZ	"Stop  Passe      "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Bloq.  Lib.      "		;     ;     ;     ;	.EVEN;---------\\; ALGOLAST >;---------/; Cherche le caractre prcdent.; in	-; out	D3.B	caractre prcdent;	D7.W	erreur; mod	D3.L, D7.WALGOLAST:	EPRO_	RECULE	JUMP',NE EXIT$	EPRO_	AVANCEEXIT$:	TEST.W	D7		; retour EQ/NE	RET;------------\\; ALGOIFALPHA >;------------/; Teste si un caractre un alphanumrique.; in	D3.B	caractre; out	D7.W	EQ si lettre ou chiffre; mod	D3.L, D7.WALGOIFALPHA:	LIB	?MINMAJ	LOAD.W	D7,#1		; D7 <-- ni chiffre ni lettre	COMP.B	D3,#'$	JUMP',EQ OK$	COMP.B	D3,#'0	JUMP',LO EXIT$	COMP.B	D3,#'9	JUMP',LS OK$	COMP.B	D3,#'A	JUMP',LO EXIT$	COMP.B	D3,#'Z	JUMP',HI EXIT$OK$:	CLR.W	D7		; D7 <-- chiffre ou lettreEXIT$:	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ALGOOPEBUF >;-----------/; Ouvre le buffer de texte.; in	A3.L	nil/^texte termin par <0>;	A4.L	^o mettre le curseur; out	A3.L	^buffer;	A4.L	^curseur;	D3.L	lg du buffer;	D7.W	erreur; mod	D3.L, D7.W, A3.L, A4.LALGOOPEBUF:	PUSHM.L	D1,D4,A5	LOAD.L	A5,A4		; A5 <-- ^o mettre le curseur	CLR.L	D4	COMP.L	A3,#0	JUMP',EQ MEM$	LOAD.L	A4,A3	CALL	ALGOGETLG	; D4 <-- lg de l'algorithmeMEM$:	MUL.WU	D4,#6		; D4 <-- multiplie par la longueur du plus long mot-cl	ADD.L	D4,#500		; D4 <-- ajoute rserve d'dition	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer	JUMP',NE EXIT$	CLR.B	(A4)	COMP.L	A3,#0	JUMP',EQ RIEN$	CALL	ALGOFORMAT	; buffer <-- algorithme en ASCII	PUSH.L	A4	LOAD.L	A4,A3;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le texte en entre	POP.L	A4	LOAD.L	A3,A4		; A3 <-- ^buffer	LOAD.L	A4,A5		; A4 <-- ^curseur	JUMP'	OK$RIEN$:	LOAD.L	A3,A4		; A3 <-- ^bufferOK$:	LOAD.L	D3,D4		; D3 <-- lg bufferEXIT$:	POPM.L	D1,D4,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ALGOCLOBUF >;-----------/; Ferme le buffer de texte.; in	A3.L	^buffer;	D3.L	lg du buffer; out	D7.W	ok;	 A3.L	 nil/^texte termin par <0>;	D7.W	erreur;	 A3.L	 idem;	 A4.L	 ^sur l'erreur; mod	D7.W, A3.L, A4.LALGOCLOBUF:	PUSHM.L	D1,D3,D4,A2	LOAD.L	A2,A3		; A2 <-- A3 initial	LOAD.L	A4,A3	CLR.L	D4CNT$:	INC.L	D4		; D4 <-- longueur du texte	TEST.B	(A4+)	JUMP,NE CNT$	LOAD.L	A4,#0	COMP.L	D4,#1	JUMP',EQ GIVE$	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^texte	JUMP',NE EXIT$	CALL	ALGOCOMPILE	; texte <-- algorithme compil	JUMP',EQ GIVE$	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le texte	POP.W	D7	LOAD.L	A4,A3		; A4 <-- ^sur l'erreur	LOAD.L	A3,A2		; A3 <-- inchang	JUMP'	EXIT$GIVE$:	PUSH.L	A4	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le buffer	POP.L	A3		; A3 <-- ^texteEXIT$:	POPM.L	D1,D3,D4,A2	TEST.W	D7		; retour EQ/NE	RET;------------\\; ALGOCOMPILE >;============/; Pr-compile un algorithme en ASCII.; in	A3.L	^algorithme en clair (source);	A4.L	^buffer (destination); out	A3.L	^plus loin;	D7.W	erreur; mod	D7.W, A3.LALGOCOMPILE:	PUSHM.L	D3,D4,A4LOOP$:	LOAD.B	D3,(A3)	JUMP,EQ END$	COMP.B	D3,#SPACE	JUMP,EQ ONE$	COMP.B	D3,#TAB	JUMP,EQ ONE$	COMP.B	D3,#CR	JUMP,EQ ONE$	COMP.B	D3,#'0	JUMP',LO SEARCH$	COMP.B	D3,#'9	JUMP,LS NUM$SEARCH$:	CALL	ALGOCSEARCH	; D3 <-- PC*	JUMP,NE EXIT$	LOAD.B	(A4+),D3	; buffer <-- PC*	COMP.B	D3,#PCUNIT	JUMP',EQ UNIT$	COMP.B	D3,#PCBLOQUE	JUMP',EQ LOCK$	COMP.B	D3,#PCLIBERE	JUMP,EQ UNLOCK$	JUMP	LOOP$UNIT$:	EX.L	A4,A3	CALL	GETANUM		; D4 <-- nombre	EX.L	A3,A4	RR.W	D4,#8	LOAD.B	(A4+),D4	; buffer <-- high byte	RR.W	D4,#8	LOAD.B	(A4+),D4	; buffer <-- low byte	JUMP	LOOP$LOCK$:	LOAD.W	D7,#ERMSPAO	COMP.B	(A3+),#'(	JUMP,NE EXIT$	LOAD.W	D7,#ERMSUNI	COMP.B	(A3+),#'$	JUMP,NE EXIT$	EX.L	A4,A3	CALL	GETANUM		; D4 <-- nombre	EX.L	A3,A4	RR.W	D4,#8	LOAD.B	(A4+),D4	; buffer <-- high byte	RR.W	D4,#8	LOAD.B	(A4+),D4	; buffer <-- low byte	CLR.W	D4	COMP.B	(A3),#',	JUMP',NE LOCKT$	INC.L	A3	EX.L	A4,A3	CALL	GETANUM		; D4 <-- nombre	EX.L	A3,A4LOCKT$:	RR.W	D4,#8	LOAD.B	(A4+),D4	; buffer <-- high byte	RR.W	D4,#8	LOAD.B	(A4+),D4	; buffer <-- low byte	LOAD.W	D7,#ERMSPAF	COMP.B	(A3+),#')	JUMP,NE EXIT$	JUMP	LOOP$UNLOCK$:	LOAD.W	D7,#ERMSPAO	COMP.B	(A3+),#'(	JUMP,NE EXIT$	LOAD.W	D7,#ERMSUNI	COMP.B	(A3+),#'$	JUMP,NE EXIT$	EX.L	A4,A3	CALL	GETANUM		; D4 <-- nombre	EX.L	A3,A4	RR.W	D4,#8	LOAD.B	(A4+),D4	; buffer <-- high byte	RR.W	D4,#8	LOAD.B	(A4+),D4	; buffer <-- low byte	LOAD.W	D7,#ERMSPAF	COMP.B	(A3+),#')	JUMP,NE EXIT$	JUMP	LOOP$NUM$:	LOAD.B	(A4+),#PCNUM	; buffer <-- PCNUM	JUMP	UNIT$ONE$:	LOAD.B	(A4+),(A3+)	; buffer <-- un caractre	JUMP	LOOP$END$:	CLR.B	(A4+)		; buffer <-- terminateur	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; ALGOCSEARCH >;------------/; Cherche un mot-cl.; in	A3.L	^mot-cl; out	A3.L	^plus loin;	D3.B	PC*;	D7.W	erreur; mod	D3.L, D7.W, A3.LALGOCSEARCH:	PUSHM.L	D4,A4	COMP.B	(A3),#'$	JUMP',EQ UNIT$	LOAD.L	A4,#R16"TABLE$	; A4 <-- ^dans tableLOOP$:	CALL	ALGOCCOMP	; mot-cl trouv ?	JUMP',EQ FOUND$		; oui => FOUND$	INC.L	A4		; A4 <-- ^aprs le PC*	TEST.B	(A4)		; fin de la table ?	JUMP,NE LOOP$		; non => LOOP$	LOAD.W	D7,#ERMSYNT	; D7 <-- pas trouv	JUMP'	EXIT$UNIT$:	INC.L	A3	LOAD.B	D3,#PCUNIT	JUMP'	OK$FOUND$:	LOAD.B	D3,(A4)		; D3 <-- PC*OK$:	CLR.W	D7		; D7 <-- trouvEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.ASCIZ	"SI"	.B	PCSI	.ASCIZ	"IF"	.B	PCSI	.ASCIZ	"ALORS"	.B	PCALORS	.ASCIZ	"THEN"	.B	PCALORS	.ASCIZ	"SINON"	.B	PCSINON	.ASCIZ	"ELSE"	.B	PCSINON	.ASCIZ	"FIN"	.B	PCFIN	.ASCIZ	"END"	.B	PCFIN	.ASCIZ	"ET"	.B	PCET	.ASCIZ	"AND"	.B	PCET	.ASCIZ	"OU"	.B	PCOU	.ASCIZ	"OR"	.B	PCOU	.ASCIZ	":="	.B	PCASS	.ASCIZ	"="	.B	PCEGAL	.ASCIZ	"<'<><'>>"	.B	PCDIFF	.ASCIZ	"+"	.B	PCADD	.ASCIZ	"-"	.B	PCSUB	.ASCIZ	"STOP"	.B	PCSTOP	.ASCIZ	"PASSE"	.B	PCPASSE	.ASCIZ	"PASS"	.B	PCPASSE	.ASCIZ	"DROIT"	.B	PCDROIT	.ASCIZ	"DEVIE"	.B	PCDEVIE	.ASCIZ	"BLOQUE"	.B	PCBLOQUE	.ASCIZ	"LOCK"	.B	PCBLOQUE	.ASCIZ	"LIBERE"	.B	PCLIBERE	.ASCIZ	"UNLOCK"	.B	PCLIBERE	.B	0	.EVEN;----------\\; ALGOCCOMP >;----------/; Compare deux mots-cl.; in	A3.L	^mot-cl cherch;	A4.L	^mot-cl de rfrence; out	D7.W	0 => mots-cl quivalents;	 A3.L	 ^plus loin;	 A4.L	 ^suivant;	D7.W	1 => mots-cl diffrents;	 A3.L	 inchang;	 A4.L	 ^suivant; mod	D7.W, A3.L, A4.LALGOCCOMP:	PUSHM.L	D3,A1,A2	LOAD.L	A1,A3		; A1 <-- A3 initial	LOAD.L	A2,#R16"ALPHA$	; A2 <-- terminateur alphanumrique	LOAD.B	D3,(A3)	LIB	?MINMAJ	COMP.B	D3,#'0	JUMP',LO LOOP$	COMP.B	D3,#'9	JUMP',LS AZ09$	COMP.B	D3,#'A	JUMP',LO LOOP$	COMP.B	D3,#'Z	JUMP',HI LOOP$AZ09$:	LOAD.L	A2,#R16"NOALPHA$ ; A2 <-- terminateur non-alphanumriqueLOOP$:	LOAD.B	D3,(A3+)	LIB	?MINMAJ	CALL	ALGOCTERM	; est-ce un terminateur ?	JUMP',EQ TERM$		; oui => TERM$	COMP.B	D3,(A4+)	JUMP,EQ LOOP$	JUMP'	DIFF$TERM$:	TEST.B	(A4+)		; chane de rfrence aussi termine ?	JUMP',NE DIFF$		; non => DIFF$	DEC.L	A3		; A3 <-- ^sur le terminateur	CLR.W	D7		; D7 <-- trouv	JUMP'	EXIT$DIFF$:	TEST.B	(A4+)		; A4 <-- ^mot-cl de rfrence suivant	JUMP,NE DIFF$	LOAD.L	A3,A1		; A3 <-- inchang	LOAD.W	D7,#ERMSYNT	; D7 <-- pas trouvEXIT$:	POPM.L	D3,A1,A2	TEST.W	D7		; retour EQ/NE	RETNOALPHA$:	.B	0,'0	.B	'9+1,'A	.B	'Z+1,-1	.W	0ALPHA$:	.B	TAB,TAB+1	.B	CR,CR+1	.B	SPACE,SPACE+1	.B	'$,'$+1	.B	'0,'9+1	.B	'A,'Z+1	.W	0;----------\\; ALGOCTERM >;----------/; Regarde si un caractre est un terminateur.; in	D3.B	caractre;	A2.L	^table des intervales; out	D7.W	0 => terminateur; mod	D7.WALGOCTERM:	PUSH.L	A2	LOAD.W	D7,#1		; D7 <-- pas un terminateurLOOP$:	TEST.W	(A2)	JUMP',EQ EXIT$	COMP.B	D3,(A2+)	JUMP',LO EXIT$	COMP.B	D3,(A2+)	JUMP,HS LOOP$	CLR.W	D7		; D7 <-- terminateurEXIT$:	POP.L	A2	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ALGOFORMAT >;===========/; D-compile un algorithme pr-compil.; in	A3.L	^algorithme pr-compil (source);	A4.L	^buffer (destination);	A5.L	^o mettre le curseur; out	A5.L	^curseur dans le buffer (A4); mod	D7.W, A5.LALGOFORMAT:	PUSHM.L	D1..D4,A2..A4	CLR.L	D2	LOAD.L	D1,A4LOOP$:	TEST.L	D2		; curseur dj trouv ?	JUMP',NE CURS$		; oui => CURS$	COMP.L	A3,A5	JUMP',LO CURS$	LOAD.L	D2,A4		; D2 <-- ^curseurCURS$:	LOAD.B	D3,(A3+)	JUMP,EQ END$	COMP.B	D3,#SPACE	JUMP,EQ OTHER$	COMP.B	D3,#TAB	JUMP,EQ OTHER$	COMP.B	D3,#CR	JUMP,EQ OTHER$	COMP.B	D3,#PCNUM	JUMP,EQ UNIT$	LOAD.L	A2,#R16"TABLE$SEARCH$:	TEST.B	(A2)		; fin de la table ?	JUMP',EQ OTHER$		; oui => OTHER$	COMP.B	D3,(A2)	JUMP',EQ FOUND$NEXT$:	TEST.B	(A2+)		; A2 <-- ^suivant dans la table	JUMP,NE NEXT$	JUMP	SEARCH$FOUND$:	INC.L	A2PUT$:	LOAD.B	(A4+),(A2+)	; buffer <-- mot-cl	JUMP,NE PUT$	DEC.L	A4	COMP.B	D3,#PCUNIT	JUMP',EQ UNIT$	COMP.B	D3,#PCBLOQUE	JUMP',EQ LOCK$	COMP.B	D3,#PCLIBERE	JUMP',EQ UNLOCK$	JUMP	LOOP$UNIT$:	LOAD.B	D4,(A3+)	SL.W	D4,#8	LOAD.B	D4,(A3+)	CALL	PUTANUM		; buffer <-- numro de l'unit	JUMP	LOOP$LOCK$:	LOAD.B	D4,(A3+)	SL.W	D4,#8	LOAD.B	D4,(A3+)	CALL	PUTANUM		; buffer <-- numro de l'unit	LOAD.B	D4,(A3+)	SL.W	D4,#8	LOAD.B	D4,(A3+)	TEST.W	D4	JUMP',EQ LOCKT$	LOAD.B	(A4+),#',	CALL	PUTANUM		; buffer <-- tempsLOCKT$:	LOAD.B	(A4+),#')	JUMP	LOOP$UNLOCK$:	LOAD.B	D4,(A3+)	SL.W	D4,#8	LOAD.B	D4,(A3+)	CALL	PUTANUM		; buffer <-- numro de l'unit	LOAD.B	(A4+),#')	JUMP	LOOP$OTHER$:	LOAD.B	(A4+),D3	JUMP	LOOP$END$:	CLR.B	(A4+)		; buffer <-- terminateur	LOAD.L	A5,D2		; A5 <-- ^curseur	TEST.L	D2	JUMP',NE EXIT$	LOAD.L	A5,D1		; A5 <-- ^curseur (au dbut)EXIT$:	POPM.L	D1..D4,A2..A4	RETTABLE$:	.B	PCUNIT	.ASCIZ	"$"	.B	PCSI	.ASCIZ	"Si"	.B	PCALORS	.ASCIZ	"Alors"	.B	PCSINON	.ASCIZ	"Sinon"	.B	PCFIN	.ASCIZ	"Fin"	.B	PCET	.ASCIZ	"Et"	.B	PCOU	.ASCIZ	"Ou"	.B	PCASS	.ASCIZ	":="	.B	PCEGAL	.ASCIZ	"="	.B	PCDIFF	.ASCIZ	"<'<><'>>"	.B	PCADD	.ASCIZ	"+"	.B	PCSUB	.ASCIZ	"-"	.B	PCSTOP	.ASCIZ	"Stop"	.B	PCPASSE	.ASCIZ	"Passe"	.B	PCDROIT	.ASCIZ	"Droit"	.B	PCDEVIE	.ASCIZ	"Dvi"	.B	PCBLOQUE	.ASCIZ	"Bloque($"	.B	PCLIBERE	.ASCIZ	"Libre($"	.B	0	.EVEN;-----------\\; ALGOOPEWDO >;-----------/; Ouvre la sous-fentre d'dition.; in	-; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WALGOOPEWDO:	PUSHM.L	D2..D4	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,#64*2	; D4 <-- hauteur	SWAP.W	D4	LOAD.W	D4,(A0)+ODFDX	SUB.W	D4,#16*2	; D4 <-- largeur	LOAD.W	D2,#2^BDBSAV	; D2 <-- sauve le fond	DBOX_	CADRE		; D5 <-- canal du cadre	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ALGOCLOWDO >;-----------/; Ferme la sous-fentre d'dition.; in	D5.L	canal; out	-; mod	D7.WALGOCLOWDO:	DBOX_	CLOSE		; ferme le cadre	RET	.END