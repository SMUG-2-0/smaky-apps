	.SBTTL	TRAINMUBUS.ASI;---------\\; RCVEVENT >;=========/; Reoit un vnement, s'il y en a un en attente.; in	-; out	D1.W	rang (0..n);	D3.W	dtecteur lu;	D7.W	erreur; mod	D1.L, D3.L, D7.WRCVEVENT:	PUSHM.L	D2,D4,A4BEGIN$:	CALL	MUBUSREAD	; D3 <-- dtecteur lu	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OTADET-LDETSRC$:	ADD.L	A4,#LDET	; A4 <-- ^suivant	LOAD.W	D7,#ERMNDDET	; D7 <-- dtecteur non dclar	TEST.W	(A4)+ODETUNI	; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.B	D3,(A4)+ODETPOR	; est-ce le bon port ?	JUMP,NE SRC$	LOAD.W	D1,(A4)+ODETRAN	; D1 <-- rang	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; PUTEVENT >;=========/; Traite un vnement en provenance d'un clavier quelconque.; in	D3.L	vnement |id.clavier|code|; out	D7.W	erreur; mod	D7.WPUTEVENT:	PUSHM.L	D2..D4,A4	LOAD.W	D7,#ERMEVENT	LOAD.L	D2,D3		; D2 <-- |id.clavier|-|	LOAD.L	D4,D3	SWAP.W	D4		; D4 <-- clavier	SL.W	D4,#2	LOAD.L	A4,#(A6)+OBUEV	ADD.W	A4,D4		; A4 <-- ^buffer vnement	COMP.W	D3,#F1	JUMP,EQ F1$	COMP.W	D3,#F2	JUMP,EQ F2$	COMP.W	D3,#F3	JUMP,EQ F3$	COMP.W	D3,#ENTER	JUMP,EQ ENTER$	COMP.W	D3,#CLEAR	JUMP,EQ CLEAR$	SUB.W	D3,#'0	JUMP,LO ERROR$	COMP.W	D3,#9	JUMP,HI ERROR$	TCLR.B	(A4)+2:#0	; nouveau chiffre ?	JUMP',BS NEW$		; oui => NEW$	LOAD.W	D4,(A4)		; D4 <-- chiffre actuel	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.W	D4,D3		; D4 <-- ajoute nouveau digit	LOAD.W	(A4),D4	JUMP	OK$NEW$:	LOAD.W	(A4),D3	JUMP	OK$F1$:				; touche blanche =>	TSET.B	(A4)+2:#0	; met le bit "chiffre termin"	CALL	PUTSTOP		; stoppe tout	JUMP	OK$F2$:				; touche rouge =>	LOAD.W	D4,#0	JUMP'	FX$F3$:				; touche verte =>	LOAD.W	D4,#1;	JUMP'	FX$FX$:	LOAD.W	D3,(A4)	TSET.B	(A4)+2:#0	; met le bit "chiffre termin"	CALL	IFLOCKUNIT	; unit bloque pour l'instant ?	JUMP,NE ERROR$		; oui => ERROR$	CALL	PUTUNIT		; envoie la commande	JUMP'	EXIT$ENTER$:	LOAD.W	D3,(A4)	TSET.B	(A4)+2:#0	; met le bit "chiffre termin"	CALL	GETUNIT		; D4 <-- tat (0,1)	JUMP'	EXIT$CLEAR$:	CLR.W	(A4)	JUMP'	OK$ERROR$:	TSET.B	(A4)+2:#0	; met le bit "chiffre termin"	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PUTSTOP >;--------/; Stoppe toutes les cellules marche/arrt globales.; in	-; out	-; mod	D7.WPUTSTOP:	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OTAGO-LGOLOOP$:	ADD.L	A3,#LGO	LOAD.W	D3,(A3)+OGOUNI	JUMP',EQ EXIT$	CLR.W	D4	CALL	PUTUNIT		; stoppe un circuit complet	JUMP	LOOP$EXIT$:	POPM.L	D3,A3	RET;--------\\; INIUNIT >;========/; Initialise toutes les units dans un tat initial.; in	-; out	-; mod	D7.WINIUNIT:	PUSHM.L	D2..D4,A4	LOAD.L	A4,(A6)+OPCEL	LOAD.W	D2,(A6)+OCELNX	MUL.WU	D2,(A6)+OCELNY	DEC.W	D2		; D2 <-- -1  cause NMOLOOP$:	LOAD.W	D3,(A4)+OCEUNI	JUMP',EQ NEXT$	CLR.W	D4	LOAD.B	D4,(A4)+OCEETA	CALL	PUTUNIT		; initialise une unitNEXT$:	ADD.L	A4,#LCE		; A4 <-- ^cellule suivante	DECJ.W,NMO D2,LOOP$EXIT$:	POPM.L	D2..D4,A4	RET;--------\\; PUTUNIT >;========/; Modifie l'tat d'une unit.; in	D3.W	numro de l'unit;	D4.W	tat (0,1); out	D7.W	erreur; mod	D7.WPUTUNIT:	PUSHM.L	D1,A4	CALL	GETPTCEL	; D1/A4 <-- rang/^cellule	JUMP',NE EXIT$	LOAD.B	(A4)+OCEETA,D4	; mmorise l'tat	CALL	CELDRAW		; dessine le nouvel tat	CALL	ALGOSND		; excute un ventuel algorithme !	CALL	MAJUNITRC	; met  jour l'tatEXIT$:	POPM.L	D1,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; MAJUNITRC >;==========/; Modifie l'tat d'une unit.; in	D1.W	rang (0..n);	A4.L	^cellule; out	D7.W	erreur; mod	D7.WMAJUNITRC:	PUSHM.L	D2..D5	CLR.W	D3	LOAD.B	D3,(A4)+OCEPOR	; D3 <-- port physique	CLR.W	D5	LOAD.B	D5,(A4)+OCEPAR	; D5 <-- paramtre	CLR.W	D4	LOAD.B	D4,(A4)+OCEETA	; D4 <-- tat	TEST.B	(A4)+OCEFAN:#BCEFINV	JUMP',BC INV$	DEC.B	D4	JUMP',EQ INV$	LOAD.B	D4,#1INV$:	LOAD.B	D2,(A4)+OCEICO	; D2 <-- icne de la cellule	COMP.B	D2,#ICORHUR	JUMP',EQ WRITE$	COMP.B	D2,#ICORHUL	JUMP',EQ WRITE$	COMP.B	D2,#ICORHDR	JUMP',EQ WRITE$	COMP.B	D2,#ICORHDL	JUMP',EQ WRITE$	COMP.B	D2,#ICORVUR	JUMP',EQ WRITE$	COMP.B	D2,#ICORVUL	JUMP',EQ WRITE$	COMP.B	D2,#ICORVDR	JUMP',EQ WRITE$	COMP.B	D2,#ICORVDL	JUMP',EQ WRITE$	COMP.B	D2,#ICORHD	JUMP',EQ WRITE$	COMP.B	D2,#ICORVD	JUMP',EQ WRITE$	COMP.B	D2,#ICORHS	JUMP',EQ WRITE$	COMP.B	D2,#ICORVS	JUMP',EQ WRITE$	COMP.B	D2,#ICORGO	JUMP',EQ WRITE$	COMP.B	D2,#ICORINV	JUMP',EQ WRITE$	COMP.B	D2,#ICORTJD1	JUMP',EQ WRITE$	COMP.B	D2,#ICORTJD2	JUMP',EQ WRITE$	JUMP'	EXIT$WRITE$:	LOAD.W	D2,#H'100*'A+'C	TEST.B	(A4)+OCEFAN:#BCEFMCC ; moteur CC ?	JUMP',BS WRITE2$	LOAD.W	D2,#H'100*'A+'B	TEST.B	(A4)+OCEFAN:#BCEFMBB ; moteur BB ?	JUMP',BS WRITE2$	LOAD.W	D2,#H'100*'R+'LWRITE2$:	CALL	MUBUSWRITE;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETUNIT >;========/; Donne l'tat d'une unit.; in	D3.W	numro de l'unit; out	D7.W	erreur;	D4.W	tat (0,1); mod	D4.L, D7.WGETUNIT:	PUSHM.L	D1,A4	CALL	GETPTCEL	; D1/A4 <-- rang/^cellule	JUMP',NE EXIT$	CLR.W	D4	LOAD.B	D4,(A4)+OCEETA	; D4 <-- tatEXIT$:	POPM.L	D1,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; LOCKUNIT >;=========/; Bloque une cellule pour un certain temps.; in	D3.W	numro de l'unit;	D4.W	dure [1s]; out	D7.W	erreur; mod	D7.WLOCKUNIT:	PUSHM.L	D1,D3,D4,A4	CALL	GETPTCEL	; D1/A4 <-- rang/^cellule	JUMP',NE EXIT$	LOAD.W	D3,D4	LOAD.W	D4,#-1	TEST.W	D3	JUMP',EQ TIME$	CALL	GETTIME		; D4 <-- temps actuel [200ms]	MUL.WU	D3,#5	ADD.W	D4,D3TIME$:	LOAD.W	(A4)+OCETIM,D4EXIT$:	POPM.L	D1,D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; UNLOCKUNIT >;===========/; Libre une cellule.; in	D3.W	numro de l'unit; out	D7.W	erreur; mod	D7.WUNLOCKUNIT:	PUSHM.L	D1,A4	CALL	GETPTCEL	; D1/A4 <-- rang/^cellule	JUMP',NE EXIT$	CLR.W	(A4)+OCETIMEXIT$:	POPM.L	D1,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; IFLOCKUNIT >;===========/; Regarde si une cellule est bloqu.; in	D3.W	numro de l'unit; out	D7.W	erreur (si bloque); mod	D7.WIFLOCKUNIT:	PUSHM.L	D1,A4	CALL	GETPTCEL	; D1/A4 <-- rang/^cellule	JUMP',NE EXIT$	CALL	IFLOCKUNITP	; cellule bloque ?EXIT$:	POPM.L	D1,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; IFLOCKUNITP >;============/; Regarde si une cellule est bloqu.; in	A4.L	^cellule; out	D7.W	erreur (si bloque); mod	D7.WIFLOCKUNITP:	PUSHM.L	D3,D4	TEST.B	(A6)+OLOCK	; bloque ?	JUMP',F OK$		; non => OK$	LOAD.W	D3,(A4)+OCETIM	; D3 <-- temps jusqu'o bloqu	JUMP',EQ OK$	CALL	GETTIME		; D4 <-- temps actuel	LOAD.W	D7,#ERMULOK	; D7 <-- unit bloque	COMP.W	D3,D4	JUMP',HS EXIT$OK$:	CLR.W	(A4)+OCETIM	CLR.W	D7		; D7 <-- unit libreEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; GETPTCEL >;---------/; Cherche une cellule d'aprs son numro d'unit.; in	D3.W	numro de l'unit; out	A4.L	^cellule (OCE*);	D1.W	rang (0..n);	D7.W	erreur; mod	D1.L, D7.W, A4.LGETPTCEL:	PUSH.L	D4	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,(A6)+OPCEL	ADD.L	A4,#OCEUNI	; A4 <-- ^sur OCEUNI (+ rapide)	LOAD.W	D4,(A6)+OCELNX	MUL.WU	D4,(A6)+OCELNY	DEC.W	D4		; D4 <-- -1  cause NMO	CLR.W	D1LOOP$:	COMP.W	D3,(A4)		; compare avec (A4)+OCEUNI !	JUMP',EQ EXIT$	INC.W	D1		; D1 <-- rang suivant	LOAD.L	A4,#(A4)+LCE	; A4 <-- ^cellule suivante	DECJ.W,NMO D4,LOOP$	LOAD.W	D7,#ERMUNIT	; D7 <-- pas trouvEXIT$:	SUB.L	A4,#OCEUNI	; A4 <-- ^dbut de la cellule	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MUBUSWRITE >;===========/; Ecrit une information dans le pilote TRAIN.; in	D2.W	commande;	D3.W	unit;	D4.W	valeur;	D5.W	paramtre; out	D7.W	erreur; mod	D7.WMUBUSWRITE:	PUSHM.L	D4,D6,A4	LOAD.L	A4,#(A6)+OPILBU	LOAD.W	(A4+),D2	LOAD.W	(A4+),D3	LOAD.W	(A4+),D4	LOAD.W	(A4+),D5	LOAD.L	A4,#(A6)+OPILBU	LOAD.L	D4,#8	LOAD.W	D6,(A6)+OPILCH	FOS	?WRBYTE	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; MUBUSREAD >;==========/; Lit une information dans le pilote TRAIN.; in	-; out	D3.W	unit dtecteur lue;	D7.W	erreur; mod	D3.L, D7.WMUBUSREAD:	PUSHM.L	D4,D6,A4	LOAD.L	A4,#(A6)+OPILBU	LOAD.L	D4,#2	LOAD.W	D6,(A6)+OPILCH	FOS	?RDBYTE	JUMP',NE EXIT$	LOAD.W	D7,#ERMEVENT	; D7 <-- rien trouv	COMP.L	D4,#2		; lu les 2 bytes demands ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.W	D3,(A4)		; D3 <-- unit lue	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; MUBUSCOMMAND >;=============/; Envoie les bonnes commandes au pilote TRAIN.; in	-; out	-; mod	D7.WMUBUSCOMMAND:	PUSHM.L	D3,D6,A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4)+0,#'D	LOAD.B	(A4)+1,(A6)+ODDEL+1	LOAD.B	(A4)+2,#'L	LOAD.B	(A4)+3,#1	TEST.B	(A6)+OFAN+3:#BFMBL-0	JUMP',BS LONG$	CLR.B	(A4)+3LONG$:	CLR.B	(A4)+4	LOAD.W	D3,#TYPIO	LOAD.W	D6,(A6)+OPILCH	FOS	?COMMAND	POPM.L	D3,D6,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; MUBUSOPEN >;==========/; Installe et ouvre le pilote TRAIN.; in	-; out	D7.W	erreur; mod	D7.WMUBUSOPEN:	PUSHM.L	D3,D6,A2..A4	LOAD.L	A3,#R16"NMLO	LOAD.L	A4,#R16"NMPH	LOAD.L	A2,#R16"PARAM$	CLR.W	D3	FOS	?INSTALL	JUMP',NE EXIT$;	LOAD.L	A3,#R16"NMLO	LOAD.W	D3,#2^BOPRD!2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE EXIT$	LOAD.W	(A6)+OPILCH,D6EXIT$:	POPM.L	D3,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETPARAM$:	.B	0	.EVEN;-----------\\; MUBUSCLOSE >;===========/; Ferme et dinstalle le pilote TRAIN.; in	-; out	-; mod	D7.WMUBUSCLOSE:	PUSHM.L	D3,D6,A3	LOAD.W	D6,(A6)+OPILCH	JUMP',EQ DEINS$	FOS	?CLOSEDEINS$:	LOAD.L	A3,#R16"NMLO	CLR.W	D3	FOS	?DEINSTALLEXIT$:	POPM.L	D3,D6,A3	RET;--------\\; PUTFIFO >;========/; Met un caractre dans le fifo.; in	D3.L	caractre;	A1.L	^fifo; out	D7.W	erreur; mod	D7.WPUTFIFO:	PUSHM.L	D4,A4	LOAD.L	A4,#(A1)+OFFDATA	LOAD.W	D4,(A1)+OFFHEAD	ADD.W	A4,D4	LOAD.L	(A4+),D3	ADD.W	D4,#LGFIFO	COMP.W	D4,#LGFIFO*NBFIFO	JUMP',LO 30$	CLR.W	D430$:	LOAD.W	D7,#ERMFULL	; D7 <-- fifo plein	COMP.W	D4,(A1)+OFFTAIL	JUMP',EQ EXIT$	LOAD.W	(A1)+OFFHEAD,D4	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETFIFO >;========/; Prend un caractre dans le fifo.; in	A1.L	^fifo; out	D3.L	caractre;	D7.W	erreur; mod	D3.L, D7.WGETFIFO:	PUSHM.L	D4,A4	LOAD.W	D7,#ERMEMPTY	; D7 <-- fifo vide	CLR.L	D3	LOAD.W	D4,(A1)+OFFTAIL	COMP.W	D4,(A1)+OFFHEAD	JUMP',EQ EXIT$	LOAD.L	A4,#(A1)+OFFDATA	ADD.W	A4,D4	LOAD.L	D3,(A4+)	ADD.W	D4,#LGFIFO	COMP.W	D4,#LGFIFO*NBFIFO	JUMP',LO 30$	CLR.W	D430$:	LOAD.W	(A1)+OFFTAIL,D4	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RETNMLO:	.ASCIZ	"#TRAIN:"NMPH:	.ASCIZ	"$TRAIN:"	.EVEN	.END