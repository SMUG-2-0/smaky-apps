	.TITLE	LOGIDULE.ASC	.PROC	M680002	.REF	SMAKY; Constantes; ----------SM324ADMUBUS =	H'FFFFA800SM100ADMUBUS =	H'FFFF8000ADMUBUS	=	SM100ADMUBUSDI	=	2MBWREL	=	0*DI		; write: relaisMBWROW	=	1*DI		; write: slection colonneMBWLINE	=	2*DI		; write: slection ligne + enable BENLINE =	 6		;  bit enable line BENROW	=	 7		;  bit enable rowMBRDET	=	0*DI		; read: dtecteursMBRRAZ	=	1*DI		; read: rz dtecteurs; Variables; ---------	.LOC	0OUNIT:	.BLKB	2ODATA:	.BLKB	2ODEL:	.BLKB	4OTYPE:	.BLKB	2OACTIV:	.BLKB	2		; cartes prsentesOMBREL:	.BLKB	16		; tats des relaisOMBDET:	.BLKB	16		; tats des dtecteursLGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.W	D3,#6	LOAD.W	D4,#1	CALL	WRITERELLOOP$:	LIB	?IFCAR	JUMP,EQ FINI	LOAD.W	D3,#7	LOAD.W	D4,#0	CALL	WRITEREL	CALL	READ	LOAD.W	D4,#20	NTREL	?DELMS	LOAD.W	D3,#7	LOAD.W	D4,#1	CALL	WRITEREL	CALL	READ	LOAD.W	D4,#20	NTREL	?DELMS	JUMP	LOOP$FINI:	EXITREAD:	PUSHM.L	D3,D4,A4	LOAD.L	A4,#ADMUBUS	; A4 <-- ^base de MUBUS	LOAD.B	D4,(A4)+MBRDET	JUMP,EQ EXIT$	LIB	?AFX2	LIB	?AFSPACE	LOAD.W	D3,#BIPLIT	LIB	?BEEP	LOAD.B	D4,(A4)+MBRRAZEXIT$:	POPM.L	D3,D4,A4	RET;--------\\; INIT    >;========/; Initialise un peu tout.; in	-; out	-; mod	D7.WINIT:	PUSHM.L	D2..D4,A4	LOAD.L	A4,#ADMUBUS	; A4 <-- ^base de MUBUS	CLR.W	D3	CLR.W	D2LOOP$:	LOAD.B	D4,(A4)+MBRRAZ	; rz des latches	LOAD.B	D4,(A4)+MBRDET	; D4 <-- data lu dans les latchesLIB ?AFX2LIB ?AFSPACE	COMP.B	D4,#-1		; carte existe ?	JUMP',EQ NEXT$		; non => NEXT$	TSET.L	D2:D3		; D2 <-- une carte prsente de plusNEXT$:	ADD.L	A4,#4		; A4 <-- ^adresse suivante	INC.W	D3	COMP.W	D3,#16	JUMP,LO LOOP$	LOAD.W	(A6)+OACTIV,D2	POPM.L	D2..D4,A4	RET;--------\\; READDET >;========/; Lit une entre quelconque.; in	-; out	D3.W	unit (0..255);	D7.W	erreur; mod	D7.WREADDET:	PUSHM.L	D1,D2,D4,A3,A4BEGIN$:	LOAD.L	A3,#(A6)+OMBDET	CLR.W	D3	LOAD.W	D2,(A6)+OACTIV	; D2 <-- cartes prsentesMLOOP$:	TEST.L	D2:D3		; carte prsente ?	JUMP',BC MNEXT$		; non => MNEXT$	LOAD.B	D4,(A3)		; D4 <-- data lu prcdemment	JUMP',NE DATA$MNEXT$:	INC.L	A3		; A3 <-- ^data suivant	INC.W	D3	COMP.W	D3,#16	JUMP,LO MLOOP$	JUMP'	READ$DATA$:	LOAD.B	D2,D4	LOAD.W	D1,#-1DLOOP$:	INC.W	D1	RR.B	D2,#1	JUMP,CC DLOOP$	TCLR.L	D4:D1	LOAD.B	(A3),D4	SL.W	D3,#3	ADD.W	D3,D1		; D3 <-- unit	CLR.W	D7	JUMP	EXIT$READ$:	LOAD.L	A4,#ADMUBUS	; A4 <-- ^base de MUBUS	LOAD.L	A3,#(A6)+OMBDET	CLR.W	D3	LOAD.W	D2,(A6)+OACTIV	; D2 <-- cartes prsentes	CLR.W	D1RLOOP$:	TEST.L	D2:D3		; carte prsente ?	JUMP',BC RNEXT$		; non => RNEXT$	LOAD.B	(A3),(A4)+MBRDET ; lit les latches	JUMP',EQ RNEXT$	LOAD.B	D4,(A4)+MBRRAZ	; rz les latches	INC.W	D1		; qq chose luRNEXT$:	ADD.L	A4,#4		; A4 <-- ^adresse suivante	INC.L	A3		; A3 <-- ^data suivant	INC.W	D3	COMP.W	D3,#16	JUMP,LO RLOOP$	TEST.W	D1	JUMP,NE BEGIN$	LOAD.W	D7,#1		; D7 <-- erreurEXIT$:	POPM.L	D1,D2,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; WRITEREL >;=========/; Bouge un relai pour un secteur.; in	D3.W	unit (0..255);	D4.W	data (0..1); out	D7.W	erreur; mod	D7.WWRITEREL:	PUSHM.L	D2..D4,A3,A4	LOAD.W	D7,#1		; D7 <-- erreur	LOAD.L	A3,#(A6)+OMBREL	LOAD.W	D2,D3	AND.W	D2,#H'0078	SR.W	D2,#3	ADD.W	A3,D2		; A3 <-- ^tat actuel	LOAD.L	A4,#ADMUBUS	; A4 <-- ^base de MUBUS	LOAD.W	D2,D3	AND.W	D2,#H'0078	SR.W	D2,#1	ADD.W	A4,D2		; A4 <-- ^la bonne carte	COMP.W	D4,#2	JUMP',HS EXIT$	LOAD.W	D2,D3	AND.W	D2,#H'0007	; D2 <-- 0..7	LOAD.B	D3,(A3)		; D3 <-- tat actuel	TCLR.L	D3:D2	TEST.W	D4	JUMP',BC WRITE$	TSET.L	D3:D2WRITE$:	LOAD.B	(A4)+MBWREL,D3	LOAD.B	(A3),D3	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; WRITEAIGBBT >;============/; Bouge un aiguillage (BB).; in	D3.W	unit (0..255);	D4.W	data (0..2);	D5.L	dures [ms]; out	D7.W	erreur; mod	D7.WWRITEAIGBBT:	PUSH.L	D4	CALL	WRITEAIGBB	; actionne	JUMP',NE EXIT$	LOAD.W	D4,D5	NTREL	?DELMS		; attend ...	CLR.W	D4	CALL	WRITEAIGBB	; repos	LOAD.L	D4,D5	SWAP.W	D4	NTREL	?DELMS		; attend ...EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; WRITEAIGBB >;===========/; Ecrit une information d'aiguillage (BB).; in	D3.W	unit (0..255);	D4.W	data (0..2); out	D7.W	erreur; mod	D7.WWRITEAIGBB:	PUSHM.L	D1..D4,A4	LOAD.W	D7,#1		; D7 <-- erreur	LOAD.L	A4,#ADMUBUS	; A4 <-- ^base de MUBUS	LOAD.W	D2,D3	AND.W	D2,#H'00F0	SR.W	D2,#2	ADD.W	A4,D2		; A4 <-- ^la bonne carte	DEC.W	D4	JUMP,NS ZERO$	COMP.W	D4,#2	JUMP',HS EXIT$	LOAD.W	D2,D3	AND.W	D2,#H'0003	; D2 <-- 0,1,2,3	SL.W	D2,#1		; D2 <-- 0,2,4,6	ADD.W	D2,D4	LOAD.B	D1,#-1	TCLR.L	D1:D2	LOAD.B	(A4)+MBWROW,D1	LOAD.W	D2,D3	AND.W	D2,#H'000C	SR.W	D2,#2	LOAD.B	D1,#2^BENLINE!2^BENROW	TSET.L	D1:D2	LOAD.B	(A4)+MBWLINE,D1	JUMP'	OK$ZERO$:	LOAD.B	(A4)+MBWLINE,#0	LOAD.B	(A4)+MBWROW,#0OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; WRITEAIGCCT >;============/; Bouge un aiguillage (CC).; in	D3.W	unit (0..255);	D4.W	data (0..2);	D5.L	dures [ms]; out	D7.W	erreur; mod	D7.WWRITEAIGCCT:	PUSH.L	D4	CALL	WRITEAIGCC	; actionne	JUMP',NE EXIT$	LOAD.W	D4,D5	NTREL	?DELMS		; attend ...	CLR.W	D4	CALL	WRITEAIGCC	; repos	LOAD.L	D4,D5	SWAP.W	D4	NTREL	?DELMS		; attend ...EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; WRITEAIGCC >;===========/; Ecrit une information d'aiguillage (CC).; in	D3.W	unit (0..255);	D4.W	data (0..2); out	D7.W	erreur; mod	D7.WWRITEAIGCC:	PUSHM.L	D2,D3,A3,A4	LOAD.W	D7,#1		; D7 <-- erreur	LOAD.L	A4,#ADMUBUS	; A4 <-- ^base de MUBUS	LOAD.W	D2,D3	AND.W	D2,#H'00F0	SR.W	D2,#2	ADD.W	A4,D2		; A4 <-- ^la bonne carte	TEST.W	D4	JUMP,EQ ZERO$	LOAD.L	A3,#R16"TABLE$	AND.W	D3,#H'000F	SL.W	D3,#2	LOAD.W	D2,(A3)+(D3.W)+0 ; D2 <-- adresse	JUMP',EQ EXIT$	LOAD.W	D3,(A3)+(D3.W)+2 ; D3 <-- bit	COMP.W	D4,#2	JUMP',EQ INV$	COMP.W	D4,#1	JUMP',NE EXIT$NORM$:	COMP.W	D2,#MBWLINE	JUMP',EQ NLINE$	LOAD.B	(A4)+MBWROW,D3	LOAD.B	(A4)+MBWLINE,#2^BENLINE!2^BENROW	JUMP'	OK$NLINE$:	LOAD.B	(A4)+MBWROW,#B'00000000	OR.B	D3,#2^BENLINE!2^BENROW	LOAD.B	(A4)+MBWLINE,D3	JUMP'	OK$INV$:	COMP.W	D2,#MBWLINE	JUMP',EQ NINV$	NOT.B	D3	LOAD.B	(A4)+MBWROW,D3	LOAD.B	(A4)+MBWLINE,#B'1111!2^BENLINE!2^BENROW	JUMP'	OK$NINV$:	LOAD.B	(A4)+MBWROW,#B'11111111	NOT.B	D3	AND.B	D3,#B'00001111	OR.B	D3,#2^BENLINE!2^BENROW	LOAD.B	(A4)+MBWLINE,D3	JUMP'	OK$ZERO$:	LOAD.B	(A4)+MBWLINE,#0	LOAD.B	(A4)+MBWROW,#0OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D3,A3,A4	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	MBWROW,2^2	;  0: a1-a5	.W	MBWLINE,2^0	;  1: b1-a8	.W	MBWROW,2^1	;  2: a2-a3	.W	MBWLINE,2^1	;  3: a9-a16	.W	MBWROW,2^4	;  4: b9-b10	.W	MBWROW,2^3	;  5: a10-a14	.W	MBWROW,2^6	;  6: a17-b21	.W	MBWROW,2^5	;  7: b17-b19	.W	MBWLINE,2^2	;  8: a18-a24	.W	MBWLINE,2^3	;  9: a25-a32	.W	MBWROW,2^7	; 10: b25-b30	.W	0,0	.W	0,0	.W	0,0	.W	0,0	.W	0,0VAR:	.FILLB	LGVAR,0	.END	START