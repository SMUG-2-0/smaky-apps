	.SBTTL	TRAINZONE.ASI;---------\\; ZONSETAT >;=========/; Modifie l'tat de toutes les cellules "secteur" d'une zone.; in	D1.W	rang dbut (0..n);	D2.W	rang fin   (0..n);	D4.W	nouvel tat (0,1); out	-; mod	D7.WZONSETAT:	PUSHM.L	D1..D3,A4	PUSH.L	D1	CALL	RANGXY		; D1 <-- dbut (y;x)	EX.L	D1,D2	CALL	RANGXY		; D2 <-- fin (y;x)	EX.L	D2,D1	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	POP.L	D1LOOPY$:	PUSHM.L	D1,D2	SWAP.W	D2LOOPX$:	CALL	CELGETP		; A4 <-- ^cellule	LOAD.B	D3,(A4)+OCEICO	COMP.B	D3,#ICORHS	JUMP',EQ MOD$	COMP.B	D3,#ICORVS	JUMP',NE NEXT$MOD$:	LOAD.B	(A4)+OCEETA,D4	CALL	CELDRAW		; dessine une cellule	CALL	ALGOSND		; excute un ventuel script !	CALL	MAJUNITRC	; met  jour l'tatNEXT$:	INC.W	D1		; D1 <-- cellule suivante en X	DEC.W	D2	JUMP,NE LOOPX$	POPM.L	D1,D2	ADD.W	D1,(A6)+OCELNX	; D1 <-- cellule suivante en Y	DEC.W	D2	JUMP,NE LOOPY$	POPM.L	D1..D3,A4	RET;---------\\; ZONAETAT >;=========/; Modifie l'tat de toutes les cellules "aiguillage" d'une zone.; in	D1.W	rang dbut (0..n);	D2.W	rang fin   (0..n);	D4.W	nouvel tat (0,1); out	-; mod	D7.WZONAETAT:	PUSHM.L	D1..D3,A4	PUSH.L	D1	CALL	RANGXY		; D1 <-- dbut (y;x)	EX.L	D1,D2	CALL	RANGXY		; D2 <-- fin (y;x)	EX.L	D2,D1	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	POP.L	D1LOOPY$:	PUSHM.L	D1,D2	SWAP.W	D2LOOPX$:	CALL	CELGETP		; A4 <-- ^cellule	LOAD.B	D3,(A4)+OCEICO	COMP.B	D3,#ICORHUL	JUMP',EQ MOD$	COMP.B	D3,#ICORHUR	JUMP',EQ MOD$	COMP.B	D3,#ICORHDL	JUMP',EQ MOD$	COMP.B	D3,#ICORHDR	JUMP',EQ MOD$	COMP.B	D3,#ICORVUL	JUMP',EQ MOD$	COMP.B	D3,#ICORVUR	JUMP',EQ MOD$	COMP.B	D3,#ICORVDL	JUMP',EQ MOD$	COMP.B	D3,#ICORVDR	JUMP',EQ MOD$	COMP.B	D3,#ICORTJD1	JUMP',EQ MOD$	COMP.B	D3,#ICORTJD2	JUMP',NE NEXT$MOD$:	LOAD.B	(A4)+OCEETA,D4	CALL	CELDRAW		; dessine une cellule	CALL	ALGOSND		; excute un ventuel script !	CALL	MAJUNITRC	; met  jour l'tatNEXT$:	INC.W	D1		; D1 <-- cellule suivante en X	DEC.W	D2	JUMP,NE LOOPX$	POPM.L	D1,D2	ADD.W	D1,(A6)+OCELNX	; D1 <-- cellule suivante en Y	DEC.W	D2	JUMP,NE LOOPY$	POPM.L	D1..D3,A4	RET;--------\\; ZONDETR >;========/; Dtruit toutes les cellules d'une zone.; in	D1.W	rang dbut (0..n);	D2.W	rang fin   (0..n); out	-; mod	D7.WZONDETR:	PUSHM.L	D1,D2,A4	PUSH.L	D1	CALL	RANGXY		; D1 <-- dbut (y;x)	EX.L	D1,D2	CALL	RANGXY		; D2 <-- fin (y;x)	EX.L	D2,D1	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	POP.L	D1LOOPY$:	PUSHM.L	D1,D2	SWAP.W	D2LOOPX$:	CALL	CELGETP		; A4 <-- ^cellule	CALL	CELKILL		; dtruit la cellule	CALL	CELDRAW		; dessine la cellule	INC.W	D1		; D1 <-- cellule suivante en X	DEC.W	D2	JUMP,NE LOOPX$	POPM.L	D1,D2	ADD.W	D1,(A6)+OCELNX	; D1 <-- cellule suivante en Y	DEC.W	D2	JUMP,NE LOOPY$	POPM.L	D1,D2,A4	RET;---------\\; ZONDUPL1 >;=========/; Duplique toutes les cellules d'une zone dans un tampon.; in	D0.W	0=dplace, 1=duplique;	D1.W	rang dbut (0..n);	D2.W	rang fin   (0..n); out	A3.L	^tampon;	D7.W	erreur; mod	D7.W, A3.LZONDUPL1:	PUSHM.L	D1..D4,A2,A4	PUSH.L	D1	CALL	RANGXY		; D1 <-- dbut (y;x)	EX.L	D1,D2	CALL	RANGXY		; D2 <-- fin (y;x)	EX.L	D2,D1	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	POP.L	D1	PUSH.L	D1	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D2		; D4 <-- nb de cellules	MUL.WU	D4,#LCE	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	LOAD.L	A3,A4		; A3 <-- ^mmoire tampon	POP.L	D1	TEST.W	D7	JUMP,NE EXIT$	LOAD.L	A2,A3LOOPY$:	PUSHM.L	D1,D2	SWAP.W	D2LOOPX$:	CALL	CELGETP		; A4 <-- ^cellule	PUSHM.L	A2,A3	LOAD.L	A3,A2		; A3 <-- ^destination	LOAD.L	A2,A4		; A2 <-- ^source	CALL	ZONDUPLC	; tampon <-- cellule	POPM.L	A2,A3	LOAD.L	A2,#(A2)+LCE	INC.W	D1		; D1 <-- cellule suivante en X	DEC.W	D2	JUMP,NE LOOPX$	POPM.L	D1,D2	ADD.W	D1,(A6)+OCELNX	; D1 <-- cellule suivante en Y	DEC.W	D2	JUMP,NE LOOPY$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; ZONDUPL2 >;=========/; Duplique toutes les cellules d'un tampon dans une zone.; in	D1.W	rang dbut (0..n);	D2.W	rang fin   (0..n);	A3.L	^tampon; out	-; mod	D7.WZONDUPL2:	PUSHM.L	D1..D4,A1..A4	PUSH.L	D1	CALL	RANGXY		; D1 <-- dbut (y;x)	EX.L	D1,D2	CALL	RANGXY		; D2 <-- fin (y;x)	EX.L	D2,D1	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	POP.L	D1	LOAD.L	A2,A3LOOPY$:	PUSHM.L	D1,D2	SWAP.W	D2LOOPX$:	CALL	CELGETP		; A4 <-- ^cellule	LOAD.L	A1,A4	LOAD.W	D4,#(LCE/2)-1XFER$:	LOAD.W	(A1+),(A2+)	; cellule <-- tampon	DECJ.W,NMO D4,XFER$	CALL	CELDRAW		; dessine une cellule	INC.W	D1		; D1 <-- cellule suivante en X	DEC.W	D2	JUMP,NE LOOPX$	POPM.L	D1,D2	ADD.W	D1,(A6)+OCELNX	; D1 <-- cellule suivante en Y	DEC.W	D2	JUMP,NE LOOPY$	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le tampon	POPM.L	D1..D4,A1..A4	RET;---------\\; ZONDUPLC >;---------/; Duplique une cellule.; in	D0.W	0=dplace, 1=duplique;	A2.L	^cellule source;	A3.L	^cellule destination; out	D7.W	erreur; mod	D7.WZONDUPLC:	PUSHM.L	D1,D4,A1,A4	LOAD.L	A1,A2	LOAD.L	A4,A3	LOAD.W	D4,#(LCE/2)-1XFER$:	LOAD.W	(A4+),(A1+)	; duplique la cellule	DECJ.W,NMO D4,XFER$	CLR.L	(A3)+OCEPSC	CLR.L	(A3)+OCEPNMSCRIPT$:	TEST.L	(A2)+OCEPSC	; y'a-t-il un script ?	JUMP',EQ NAME$		; non => NAME$	LOAD.L	A4,(A2)+OCEPSC	CALL	ALGOGETLG	; D4 <-- lg du script	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouveau script	JUMP',NE EXIT$	LOAD.L	(A3)+OCEPSC,A4	LOAD.L	A1,(A2)+OCEPSCSLOOP$:	LOAD.B	(A4+),(A1+)	; duplique le script	DEC.W	D4	JUMP,NE SLOOP$NAME$:	TEST.L	(A2)+OCEPNM	; y'a-t-il un nom ?	JUMP',EQ OK$		; non => OK$	LOAD.L	A4,(A2)+OCEPNM	CLR.L	D4NLG$:	INC.W	D4		; D4 <-- lg du nom	TEST.B	(A4+)	JUMP,NE NLG$	TEST.W	D0		; dplace ?	JUMP',EQ NMEM$		; oui => NMEM$	ADD.W	D4,#9		; D4 <-- ajoute lg pour "Copie_de_"NMEM$:	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouveau nom	JUMP',NE EXIT$	LOAD.L	(A3)+OCEPNM,A4	TEST.W	D0		; dplace ?	JUMP',EQ NNAME$		; oui => NNAME$	LOAD.L	A1,#R16"TCOPY$NCOPY$:	LOAD.B	(A4+),(A1+)	JUMP,NE NCOPY$	DEC.L	A4NNAME$:	LOAD.L	A1,(A2)+OCEPNMNLOOP$:	LOAD.B	(A4+),(A1+)	; duplique le nom	JUMP,NE NLOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D4,A1,A4	TEST.W	D7		; retour EQ/NE	RETTCOPY$:	.ASCIZ	"Copie_de_"	.EVEN;--------\\; ZONDEPL >;========/; Dplace une zone.; in	D1.W	rang dbut (0..n);	D2.W	rang fin   (0..n); out	D1.W	rang dbut (0..n);	D2.W	rang fin   (0..n);	D7.W	erreur; mod	D1.L, D2.L, D7.WZONDEPL:	PUSHM.L	D0,D3,D4	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE EXIT$	PUSH.W	D1	CALL	ZONDET		; D1 <-- rang dbut	LOAD.W	D0,D1	POP.W	D1	TEST.W	D7	JUMP,NE EXIT$LOOP$:	CALL	SCMO		; remet la souris	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	PUSH.W	D1	CALL	ZONDET		; D1 <-- rang dbut	LOAD.W	D3,D1	POP.W	D1	TEST.W	D7	JUMP,NE LOOP$	COMP.W	D3,D0	JUMP,EQ LOOP$	CALL	ZONINV		; efface l'ancien	LOAD.W	D4,D3	SUB.W	D4,D0	ADD.W	D1,D4	ADD.W	D2,D4	CALL	ZONINV		; allume le nouveau	LOAD.W	D0,D3	JUMP	LOOP$END$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZONMOVE >;========/; Slectionne une zone rectangulaire.; in	D4.L	position de la souris (y;x); out	D1.W	rang dbut (0..n);	D2.W	rang fin   (0..n);	D7.W	erreur; mod	D1.L, D2.L, D7.WZONMOVE:	PUSHM.L	D3,D4	CALL	ZONDET		; D1 <-- rang dbut	JUMP,NE EXIT$	LOAD.W	D2,D1LOOP$:	CALL	SCMO		; remet la souris	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	PUSH.W	D1	CALL	ZONDET		; D1 <-- rang dbut	LOAD.W	D3,D1	POP.W	D1	TEST.W	D7	JUMP,NE LOOP$	COMP.W	D2,D3	JUMP,EQ LOOP$	CALL	ZONINV		; efface l'ancien	LOAD.W	D2,D3	CALL	ZONINV		; allume le nouveau	JUMP	LOOP$END$:	COMP.W	D1,D2	JUMP',NE NOONE$	CALL	CELDET		; D1 <-- cellule o est la souris	JUMP,NE EXIT$	CALL	RANGXY		; D1 <-- rang (y;x)	LOAD.L	D2,D1	INC.W	D2	SWAP.W	D2	INC.W	D2	SWAP.W	D2	JUMP'	END8$NOONE$:	CALL	ZONINV		; teint la dernire zone	LOAD.W	D7,#1		; D7 <-- erreur	CALL	RANGXY		; D1 <-- rang (y;x)	EX.L	D1,D2	CALL	RANGXY		; D2 <-- rang (y;x)	EX.L	D2,D1	COMP.W	D1,D2	JUMP',EQ EXIT$	JUMP',LO OKX$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D3OKX$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,D2	JUMP',EQ EXIT$	JUMP',LO OKY$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D3OKY$:	SWAP.W	D1	SWAP.W	D2END8$:	CALL	XYRANG		; D1 <-- rang (0..n)	EX.L	D1,D2	CALL	XYRANG		; D2 <-- rang (0..n)	EX.L	D2,D1	CALL	ZONINV		; allume la zoneOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; ZONIFONE >;=========/; Regarde s'il y a une seule cellule slectionne.; in	D1.W	rang dbut (0..n);	D2.W	rang fin   (0..n); out	EQ	si une seule; mod	D7.WZONIFONE:	PUSHM.L	D1,D2	CALL	RANGXY		; D1 <-- rang (y;x)	EX.L	D1,D2	CALL	RANGXY		; D2 <-- rang (y;x)	EX.L	D2,D1	DEC.W	D2	COMP.W	D1,D2	JUMP',NE EXIT$	SWAP.W	D1	SWAP.W	D2	DEC.W	D2	COMP.W	D1,D2EXIT$:	POPM.L	D1,D2	RET;-------\\; ZONINV >;-------/; Inverse toute une zone.; in	D1.W	rang dbut (0..n);	D2.W	rang fin   (0..n); out	-; mod	D7.WZONINV:	PUSHM.L	D1..D5	PUSH.W	(A6)+OCELVX	PUSH.W	(A6)+OCELVY	INC.W	(A6)+OCELVX	INC.W	(A6)+OCELVY	COMP.W	D1,D2	JUMP',EQ EXIT$	CALL	CELPOS		; D3/D4 <-- position dbut	JUMP',NE EXIT$	LOAD.L	D5,D3	LOAD.W	D1,D2	CALL	CELPOS		; D3/D4 <-- position fin	JUMP',NE EXIT$	LOAD.L	D4,D3	LOAD.L	D3,D5	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRRECTEXIT$:	POP.W	(A6)+OCELVY	POP.W	(A6)+OCELVX	POPM.L	D1..D5	RET;-------\\; ZONDET >;-------/; Dtecte dans quel carr est la souris.; in	D4.L	position de la souris (y;x); out	D1.W	rang (0..n);	D7.W	erreur; mod	D1.L, D7.WZONDET:	PUSHM.L	D0,D2,D3	LOAD.W	D7,#1	LOAD.W	D1,#-1	LOAD.W	D0,(A6)+OCELDIM	SR.W	D0,#1	CLR.L	D3	LOAD.W	D3,D4	SUB.W	D3,(A6)+OCELPX	JUMP',LO EXIT$	ADD.W	D3,D0	DIV.WU	D3,(A6)+OCELDIM	COMP.W	D3,(A6)+OCELVX	JUMP',HI EXIT$	ADD.W	D3,(A6)+OASHOR+OSCPOSV	COMP.W	D3,(A6)+OCELNX	JUMP',HI EXIT$	LOAD.L	D2,D4	CLR.W	D2	SWAP.W	D2	SUB.W	D2,(A6)+OCELPY	JUMP',LO EXIT$	ADD.W	D2,D0	DIV.WU	D2,(A6)+OCELDIM	COMP.W	D2,(A6)+OCELVY	JUMP',HI EXIT$	ADD.W	D2,(A6)+OASVER+OSCPOSV	COMP.W	D2,(A6)+OCELNY	JUMP',HI EXIT$	MUL.WU	D2,(A6)+OCELNX	LOAD.W	D1,D3	ADD.W	D1,D2		; D1 <-- rang	CLR.W	D7EXIT$:	POPM.L	D0,D2,D3	TEST.W	D7		; retour EQ/NE	RET	.END