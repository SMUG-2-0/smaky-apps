	.SBTTL	RHBMEMORY.ASIMMSLPX	=	306MMSLPY	=	IDIMY-1-183MMSLDX	=	216MMSLDY	=	112MMICPX	=	304MMICPY	=	IDIMY-1-67MMICDX	=	25MMICDY	=	25MMICEX	=	32;---------\\; MMTXREAD >;=========/; Lit un fichier .RHB; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WMMTXREAD:	PUSHM.L	D1..D6,A3,A4	CALL	WAITMOUSE	SET.B	(A6)+OSUSPW	; suspend l'criture	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE EXIT$	CALL	MMTXCLOSE	LOAD.L	D4,#-1	LOAD.L	D3,D4	FOS	?SPOS	LOAD.L	D2,D4	CLR.L	D4	CLR.L	D3	FOS	?SPOS	LOAD.L	D4,D2	ADD.L	D4,#2000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP',NE ERROR$	LOAD.L	(A6)+OMMPTX,A4	LOAD.L	(A6)+OMMLGM,D4	CLR.B	(A4)	SUB.L	D4,#2000	FOS	?RDBYTE	JUMP',NE ERROR$	CLR.B	(A4)+(D4.L)ERROR$:	PUSH.W	D7	FOS	?CLOSE	CALL	MMSLDRAW	; refait la scroll-liste	POP.W	D7EXIT$:	CALL	NORMMOUSE	CLR.B	(A6)+OSUSPW	; remet l'criture	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; MMTXWRITE >;==========/; ; in	A3.L	^nom de fichier; out	D7.W	erreur; mod	D7.WMMTXWRITE:	PUSHM.L	D3..D6,A3,A4	SET.B	(A6)+OSUSPW	; suspend l'criture	CLR.W	D7	TEST.L	(A6)+OMMPTX	JUMP,EQ EXIT$CREATE$:	CALL	WAITMOUSE	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',EQ OPEN$	CALL	NORMMOUSE	CALL	DBOXDETRUIT	; demande s'il faut dtruire ...	COMP.W	D3,#F1	JUMP,NE EXIT$	FOS	?DELETE	JUMP	CREATE$OPEN$:	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE EXIT$	LOAD.L	A4,(A6)+OMMPTX	LOAD.L	D4,#-1CNT$:	INC.L	D4	TEST.B	(A4+)	JUMP,NE CNT$	LOAD.L	A4,(A6)+OMMPTX	FOS	?WRBYTE	JUMP',NE ERROR$	FOS	?CLOSE	JUMP'	EXIT$ERROR$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	CALL	NORMMOUSE	CLR.B	(A6)+OSUSPW	; remet l'criture	POPM.L	D3..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MMTXOPEN >;=========/; ; in	-; out	-; mod	D7.WMMTXOPEN:	PUSHM.L	D1,D4,A4	CALL	MMTXCLOSE	LOAD.L	D4,#2000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP',NE EXIT$	LOAD.L	(A6)+OMMPTX,A4	LOAD.L	(A6)+OMMLGM,D4	CLR.B	(A4)EXIT$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; MMTXCLOSE >;==========/; ; in	-; out	-; mod	D7.WMMTXCLOSE:	PUSHM.L	D1,A4	LOAD.L	A4,(A6)+OMMPTX	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OMMPTX	POPM.L	D1,A4	RET;---------\\; MMSLCREE >;=========/; Cre une nouvelle ligne pour un itnraire.; in	-; out	D7.W	erreur; mod	D7.WMMSLCREE:	PUSHM.L	D1..D4,A1..A5	LOAD.L	A5,#(A6)+OSLVAR	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface toute la scroll-liste	ADD.W	D3,#10	SWAP.W	D3	ADD.W	D3,#10	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Donnez le nom du nouvel"	.EVEN	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"itinraire :"	.EVEN	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	SWAP.W	D3	LIB	?SETCURS	LOAD.L	A3,#(A6)+OMMNLI	CLR.L	D3	LOAD.W	D3,(A5)+OSLDIM+2	SUB.W	D3,#10+10	DIV.WU	D3,(A0)+ODFCX	LIB	?GETLINE	; demande le nom ...	LIB	?AFTIM	.B	NOCURS,0	.EVEN	COMP.W	D3,#CR	JUMP,NE END$	LOAD.L	A1,A3NAME$:	COMP.B	(A1),#SPACE	JUMP',NE NOSPA$	LOAD.B	(A1),#'_NOSPA$:	COMP.B	(A1+),#CR	JUMP,NE NAME$	DEC.L	A1	CLR.W	D1	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A5)+OSLPOS	LOAD.L	D4,(A5)+OSLDIM	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface toute la scroll-liste	ADD.W	D3,#10	SWAP.W	D3	ADD.W	D3,#40	ADD.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Cliquez sur les aiguillages et"	.EVEN	SWAP.W	D3	ADD.W	D3,(A0)+ODFCY	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"les secteurs  mmoriser ..."	.EVENLOOP$:	LIB	?GETCAR		; attend clavier/souris ...	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$BIP$:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	CALL	IFMOVE		; D3 <-- unit clique	JUMP',EQ UNIT$	CALL	MMICMOVE	; D2 <-- icne clique	JUMP',EQ ICONE$	JUMP	BIP$ICONE$:	COMP.W	D2,#0	JUMP,EQ CREE$	JUMP	BIP$UNIT$:	LOAD.L	A4,A1	LOAD.B	(A4+),#SPACE	LOAD.W	D4,D3	CALL	PUTANUM		; OMMNLI <-- " unit="	LOAD.B	(A4+),#'=	LOAD.L	A3,A4	CALL	IFSEARCH	; A4 <-- ^OTIF*	EX.L	A3,A4	JUMP,NE BIP$	LOAD.W	D4,(A3)+OTIFNF	COMP.W	D4,#FLRIEN	JUMP',EQ UAIG$	COMP.W	D4,#FLBLOC	JUMP',EQ UBLOC$	COMP.W	D4,#FLDT0	JUMP',EQ UDET$	COMP.W	D4,#FLBLANC	JUMP',EQ USENS$	COMP.W	D4,#FLSTOP	JUMP',EQ UBLOC$	COMP.W	D4,#FLAUTO	JUMP',EQ UAUTO$	CALL	GETUNIT		; D4 <-- tat (0,1)	JUMP,NE BIP$	CALL	PUTANUM	JUMP'	UEND$UAIG$:	CALL	GETUNIT		; D4 <-- tat (0,1)	JUMP,NE BIP$	LOAD.B	D3,#'D		; droit	TEST.W	D4	JUMP',EQ UCAR$	LOAD.B	D3,#'T		; tourne	JUMP'	UCAR$UBLOC$:	CALL	GETUNIT		; D4 <-- tat (0,1)	JUMP,NE BIP$	LOAD.B	D3,#'M		; marche	TEST.W	D4	JUMP',EQ UCAR$	LOAD.B	D3,#'A		; arrt	JUMP'	UCAR$UDET$:	CALL	GETUNIT		; D4 <-- tat (0,1)	JUMP,NE BIP$	LOAD.B	D3,#'H		; haut	TEST.W	D4	JUMP',EQ UCAR$	LOAD.B	D3,#'B		; bas	JUMP'	UCAR$USENS$:	CALL	GETUNIT		; D4 <-- tat (0,1)	JUMP,NE BIP$	LOAD.B	D3,#'<		; arrire	TEST.W	D4	JUMP',EQ UCAR$	LOAD.B	D3,#'>		; avant	JUMP'	UCAR$UAUTO$:	LOAD.W	D4,(A3)+OTIFRF	; D4 <-- offset variable	LOAD.W	D4,(A6)+(D4.W)	CALL	PUTANUM	JUMP'	UEND$UCAR$:	LOAD.B	(A4+),D3UEND$:	LOAD.L	A1,A4	INC.W	D1	JUMP	LOOP$CREE$:	TEST.W	D1	JUMP,EQ END$	CLR.B	(A1)	LOAD.W	D3,(A5)+OSLCYN	LOAD.W	(A5)+OSLCYS,D3	LOAD.L	A3,#(A6)+OMMNLI	CALL	MMSLINSLIEND$:	CALL	MMSLDRAW	; redessine la scroll-liste	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,A1..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; MMSLINIT >;=========/; Initialise les unit selon la ligne slectionne.; in	D3.W	rang de la ligne; out	-; mod	D7.WMMSLINIT:	PUSHM.L	D2..D4,A3,A4	CALL	WAITMOUSE	CALL	MMSLSRCLI	; A3 <-- ^ligne slectionneLOOP$:	LOAD.B	D3,(A3+)	JUMP,EQ EXIT$	COMP.B	D3,#CR	JUMP,EQ EXIT$	COMP.B	D3,#SPACE	JUMP,NE LOOP$	LOAD.L	A4,A3	CALL	GETANUM		; D4 <-- unit	LOAD.W	D3,D4		; D3 <-- unit	COMP.B	(A4+),#'=	JUMP,NE EXIT$	LOAD.B	D2,(A4+)	EX.L	D3,D2	LIB	?MINMAJ	EX.L	D2,D3	CLR.W	D4	COMP.B	D2,#'D	JUMP',EQ VAL$	COMP.B	D2,#'M	JUMP',EQ VAL$	COMP.B	D2,#'H	JUMP',EQ VAL$	COMP.B	D2,#'<	JUMP',EQ VAL$	INC.W	D4	COMP.B	D2,#'T	JUMP',EQ VAL$	COMP.B	D2,#'A	JUMP',EQ VAL$	COMP.B	D2,#'B	JUMP',EQ VAL$	COMP.B	D2,#'>	JUMP',EQ VAL$	DEC.L	A4	CALL	GETANUM		; D4 <-- valeurVAL$:	LOAD.W	D2,D4		; D2 <-- valeur	LOAD.L	A3,A4	CALL	IFSEARCH	; A4 <-- ^OTIF*	JUMP,NE LOOP$	COMP.W	(A4)+OTIFNF,#FLAUTO	JUMP',EQ AUTO$	CALL	GETUNIT	JUMP,NE LOOP$	COMP.W	D4,D2	JUMP,EQ LOOP$	LOAD.W	D4,D2	CALL	PUTUNIT	LOAD.W	D4,#5	NTREL	?DELMS	JUMP	LOOP$AUTO$:	LOAD.W	D4,(A4)+OTIFRF	; D4 <-- offset variable	LOAD.W	(A6)+(D4.W),D2	CALL	IFETAT	JUMP	LOOP$EXIT$:	CALL	NORMMOUSE	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MMTXEDIT >;=========/; Edite le texte.; in	-; out	D7.W	erreur; mod	D7.WMMTXEDIT:	PUSHM.L	D3..D6,A0..A4	LOAD.W	D7,#1	TEST.L	(A6)+OMMPTX	JUMP,EQ EXIT$	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve tout l'cran	JUMP,NE EXIT$	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface tout l'cran	LIB	?AFTIM	.B	USEGC	.B	GCT2F	.B	GCT2S	.B	GCT2T	.B	0	.EVEN	LOAD.W	D3,(A6)+OSLVAR+OSLCYS	CALL	MMSLSRCLI	; A3 <-- ^ligne slectionne	LOAD.L	A4,A3	LOAD.L	A3,(A6)+OMMPTX	LOAD.L	D3,(A6)+OMMLGM	LOAD.W	D4,#2^BEPROTXT!2^BEPROMOUSE!2^BEPROAFCR!2^BEPROAFLF!2^BEPROAFTAB	LOAD.L	A0,#R16"TEXT0$	LOAD.L	A1,#R16"TEXT1$	LOAD.L	A2,#R16"TEXT2$	EPRO_	OPEN		; D6 <-- canal de l'dition	JUMP,NE END$	LOAD.L	A0,(A6)+OPDDIS	LOAD.L	A3,#R16"TXMENU$	LIB	?AFMENULOOP$:	LOAD.L	A4,#R16"TERM$	; A4 <-- ^touches terminatrices	EPRO_	MAIN		; dite ...	JUMP',NE BIP$	COMP.W	D3,#KEYMGR	; bouton souris relch ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#F0	JUMP',EQ CLOSE$	COMP.W	D3,#END	JUMP',EQ CLOSE$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLOSE$:	EPRO_	CLOSEEND$:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	LIB	?AFTIM	.B	USEGC	.B	GCT1F	.B	GCT1S	.B	GCT1T	.B	0	.EVEN	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue l'cran	CALL	MMSLUPDATE	; met  jour la scroll-liste	POP.W	D7EXIT$:	POPM.L	D3..D6,A0..A4	TEST.W	D7		; retour EQ/NE	RETTEXT0$:	.ASCIZ	""TEXT1$:	.ASCIZ	" MEMORY   "TEXT2$:	.ASCIZ	""	.EVENTERM$:;	.BB	0,END	.W	0TXMENU$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN;----------\\; MMSLDRAW  >;==========/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WMMSLDRAW:	PUSHM.L	A3,A5	LOAD.L	A5,#(A6)+OSLVAR	LOAD.L	(A5)+OSLPOS,#H'10000*MMSLPY+MMSLPX	LOAD.L	(A5)+OSLDIM,#H'10000*MMSLDY+MMSLDX	SET.B	(A5)+OSLVID	LOAD.L	A3,#R16"VIDE$	SCROLL_	LDRAW		; dessine la scroll liste	CALL	MMSLUPDATE	POPM.L	A3,A5	RETVIDE$:	.ASCIZ	"<'<>nouveau<'>>"	.EVEN;-----------\\; MMSLUPDATE >;===========/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WMMSLUPDATE:	PUSHM.L	D3,D4,A3,A5	LOAD.L	A5,#(A6)+OSLVAR	TEST.L	(A6)+OMMPTX	JUMP',EQ EXIT$	LOAD.L	A3,(A6)+OMMPTX	CALL	MMSLCNTLI	; D3 <-- nb de lignes	LOAD.W	(A5)+OSLCYN,D3	LOAD.W	D3,(A5)+OSLCYS	JUMP',NS UPDATE$	COMP.W	D3,(A5)+OSLCYN	JUMP',LO UPDATE$	LOAD.W	D3,(A5)+OSLCYN	DEC.W	D3	LOAD.W	(A5)+OSLCYS,D3UPDATE$:	LOAD.L	A3,#R16"MMSLGETLI	LOAD.L	(A5)+OSLADL,A3	SCROLL_	LUPDATEEXIT$:	POPM.L	D3,D4,A3,A5	RET;---------\\; MMSLMOVE >;=========/; Dplace la scroll-liste.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WMMSLMOVE:	PUSH.L	A5	LOAD.L	A5,#(A6)+OSLVAR	SCROLL_	LMOVE	POP.L	A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; MMSLINSLI >;----------/; Insre une nouvelle ligne.; in	A3.L	^ligne  insrer <0>;	D3.W	rang o insrer; out	D7.W	erreur; mod	D7.WMMSLINSLI:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A4,A3		; A4 <-- ^ligne  insrer	CLR.W	D4CNT1$:	INC.W	D4		; D4 <-- lg ligne  insrer	TEST.B	(A3+)	JUMP,NE CNT1$	CALL	MMSLSRCLI	; A3 <-- ^o insrer	CLR.W	D3CNT2$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE CNT2$	LOAD.L	A2,#(A3)+(D4.W)HOLE$:	LOAD.B	(-A2),(-A3)	DEC.W	D3	JUMP,NE HOLE$INS$:	LOAD.B	(A3+),(A4+)	JUMP,NE INS$	LOAD.B	(A3)-1,#CREXIT$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; MMSLDELLI >;----------/; Supprime une ligne.; in	D3.W	rang de la ligne; out	-; mod	D7.WMMSLDELLI:	PUSHM.L	D3,A3,A4	CALL	MMSLSRCLI	; A3 <-- ^ligne  dtruire	LOAD.L	A4,A3SRC2$:	TEST.B	(A4)	JUMP',EQ SRC3$	COMP.B	(A4+),#CR	JUMP,NE SRC2$SRC3$:	LOAD.B	(A3+),(A4+)	JUMP,NE SRC3$	POPM.L	D3,A3,A4	RET;----------\\; MMSLGETLI >;----------/; Cherche le nom d'une ligne donne (appel par SCROLL_LUPDATE); in	D3.W	rang de la ligne (0..n); out	A3.L	^ligne;	D3.W	zro;	D7.W	erreur; mod	D3.L, D7.W, A3.LMMSLGETLI:	PUSH.L	A4	CALL	MMSLSRCLI	; A3 <-- ^ligne slectionne	LOAD.L	A4,#(A6)+OBUDISXFER$:	LOAD.B	D3,(A3+)	JUMP',EQ END$	COMP.B	D3,#CR	JUMP',EQ END$	COMP.B	D3,#SPACE	JUMP',EQ END$	LOAD.B	(A4+),D3	JUMP	XFER$END$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OBUDIS	CLR.W	D3	POP.L	A4	CLR.W	D7		; retour EQ/NE	RET;----------\\; MMSLSRCLI >;----------/; Cherche une ligne donne.; in	D3.W	rang de la ligne (0..n); out	A3.L	^ligne; mod	D7.W, A3.LMMSLSRCLI:	PUSH.W	D3	LOAD.L	A3,(A6)+OMMPTXLOOP$:	DEC.W	D3	JUMP',NS EXIT$NEXT$:	TEST.B	(A3)	JUMP',EQ EXIT$	COMP.B	(A3+),#CR	JUMP,NE NEXT$	JUMP	LOOP$EXIT$:	POP.W	D3	RET;----------\\; MMSLCNTLI >;----------/; Compte le nombre de lignes.; in	A3.L	^texte; out	D3.W	nombre de lignes (0..n); mod	D3.L, D7.WMMSLCNTLI:	PUSH.L	A3	CLR.W	D3LOOP$:	TEST.B	(A3)	JUMP',EQ EXIT$	COMP.B	(A3+),#CR	JUMP,NE LOOP$	INC.W	D3	JUMP	LOOP$EXIT$:	POP.L	A3	RET;---------\\; MMICMOVE >;=========/; Cherche dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	rang de l'icne (0..n,-1);	D7.W	erreur; mod	D2.L, D7.WMMICMOVE:	PUSHM.L	D1,D3,D4	CALL	MMICDET		; D2 <-- icne o est la souris	JUMP',NE EXIT$	CALL	MMICINV		; allume l'icne montre	LOAD.W	D1,D2LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE END$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	MMICDET		; D2 <-- icne o est la souris	COMP.W	D2,D1		; toujours dans la mme icne ?	JUMP,EQ LOOP$		; oui => LOOP$	EX.L	D1,D2	CALL	MMICINV		; teint l'ancienne	LOAD.W	D2,D1	CALL	MMICINV		; allume la nouvelle	JUMP	LOOP$END$:	LOAD.W	D2,D1	CALL	MMICINV		; teint la dernire	COMP.W	D2,#-1	JUMP',NE EXIT$	LOAD.W	D7,#1EXIT$:	POPM.L	D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; MMICDET >;--------/; Cherche dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	rang de l'icne (0..n,-1);	D7.W	erreur; mod	D2.L, D7.WMMICDET:	PUSH.L	D4	LOAD.W	D7,#1	LOAD.W	D2,#-1	SWAP.W	D4	SUB.W	D4,#MMICPY	JUMP',LO EXIT$	COMP.W	D4,#MMICDY	JUMP',HS EXIT$	CLR.W	D4	SWAP.W	D4	SUB.W	D4,#MMICPX	JUMP',LO EXIT$	DIV.WU	D4,#MMICEX	SWAP.W	D4	COMP.W	D4,#MMICDX	JUMP',HS EXIT$	SWAP.W	D4	COMP.W	D4,#7	JUMP',HS EXIT$	LOAD.W	D2,D4	CLR.W	D7EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; MMICINV >;========/; Inverse une icne.; in	D2.W	rang de l'icne; out	-; mod	D7.WMMICINV:	PUSHM.L	D2..D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	MMICPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	SUB.W	D3,#2	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	ADD.W	D4,#2+3	SWAP.W	D4	ADD.W	D4,#2+3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRMATRIX	; inverse l'icneEXIT$:	POPM.L	D2..D4	RET;--------\\; MMICPOS >;--------/; Donne la position d'une icne.; in	D2.W	rang de l'icne; out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WMMICPOS:	PUSH.L	D2	LOAD.W	D7,#1	COMP.W	D2,#7	JUMP',HS EXIT$	LOAD.L	D3,#H'10000*MMICPY+MMICPX	LOAD.L	D4,#H'10000*MMICDY+MMICDX	MUL.WU	D2,#MMICEX	ADD.W	D3,D2	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET	.END