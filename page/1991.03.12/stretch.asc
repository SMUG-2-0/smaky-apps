	.TITLE	STRETCH.ASC	.PROC	M680002	.REF	SMAKY	.REF	MATH64	.LOC	0OSTPS0:	.BLKB	4		; source: S0OSTPS2:	.BLKB	4		; source: S2OSTPD0:	.BLKB	4		; destination: D0OSTPD1:	.BLKB	4		; destination: D1OSTPD2:	.BLKB	4		; destination: D2OSTPD3:	.BLKB	4		; destination: D3OSTPIN:	.BLKB	4OSTPOU:	.BLKB	4LSTP:	.LOC	0OSTMD1Y:.BLKB	8		; D1yOSTMD1X:.BLKB	8		; D1xOSTMD3Y:.BLKB	8		; D3yOSTMD3X:.BLKB	8		; D3xOSTMT1Y:.BLKB	8		; T1yOSTMT1X:.BLKB	8		; T1xLSTM:	.LOC	0OCHMATH:.BLKB	2		; canal du module math64OCIMATH:.BLKB	4		; canal interne de math64OPTS:	.BLKB	LSTPLGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.W	D3,#2	LIB	?MOUSE	LIB	?AFTIM	.B	NOCURS	.B	0	.EVEN	LOAD.L	A3,#R16"NMMATH64	LOAD.W	D3,#MATH64_FIRST	LIB_	OPEN		; charge le module MATH64	JUMP,NE ERFAT	LOAD.W	(A6)+OCHMATH,D1	CLR.L	D0		; D0 <-- mode par dfaut	MATH64_	OPEN		; ouvre le module MATH64	JUMP,NE ERFAT	LOAD.L	(A6)+OCIMATH,A5	LOAD.L	A4,#(A6)+OPTS	LOAD.W	(A4)+OSTPS0+2,#100	LOAD.W	(A4)+OSTPS0+0,#100	LOAD.W	(A4)+OSTPS2+2,#300	LOAD.W	(A4)+OSTPS2+0,#200	LOAD.W	(A4)+OSTPD0+2,#200	LOAD.W	(A4)+OSTPD0+0,#400	LOAD.W	(A4)+OSTPD1+2,#300	LOAD.W	(A4)+OSTPD1+0,#400	LOAD.W	(A4)+OSTPD2+2,#300	LOAD.W	(A4)+OSTPD2+0,#500	LOAD.W	(A4)+OSTPD3+2,#200	LOAD.W	(A4)+OSTPD3+0,#500	LOAD.W	(A4)+OSTPIN+2,#150	LOAD.W	(A4)+OSTPIN+0,#150	CALL	STRETCHQ	CALL	CADRESLOOP$:	LIB	?GETCAR	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#END	JUMP,EQ FINI$	JUMP	LOOP$CLIC$:	LIB	?IFMOUSE	CALL	MOVE	JUMP	LOOP$FINI$:	LOAD.L	A5,(A6)+OCIMATH	; A5 <-- canal interne de math64	MATH64_	CLOSE		; ferme le module MATH64	LOAD.W	D1,(A6)+OCHMATH	LIB_	CLOSE		; libre le module MATH64ERFAT:	EXIT;--------\\; MOVE    >;========/; ; in	; out	; mod	MOVE:	PUSHM.L	D2..D4	CALL	DET	JUMP,NE EXIT$LOOP$:	LIB	?GETKEY	COMP.W	D3,#KEYMPO	JUMP,NE END$	LIB	?IFMOUSE	CALL	CADRES	LOAD.L	(A4)+(D2.L),D4	CALL	STRETCHQ	CALL	CADRES	JUMP	LOOP$END$:	CLR.W	D7EXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DET     >;========/; ; in	D4.L	souris;	A4.L	^paramtres; out	D2.W	offset;	D7.W	erreur; mod	DET:	PUSHM.L	D1,D3,D4	LOAD.W	D3,D4	SWAP.W	D4	CLR.W	D2	CLR.W	D7LOOP$:	LOAD.W	D1,(A4)+(D2.W)+2	SUB.W	D1,#5	COMP.W	D3,D1	JUMP,LO NEXT$	ADD.W	D1,#5+5	COMP.W	D3,D1	JUMP,HS NEXT$	LOAD.W	D1,(A4)+(D2.W)+0	SUB.W	D1,#5	COMP.W	D4,D1	JUMP,LO NEXT$	ADD.W	D1,#5+5	COMP.W	D4,D1	JUMP,LO EXIT$NEXT$:	ADD.W	D2,#4	COMP.W	D2,#4*(2+4+1)	JUMP,LO LOOP$	LOAD.W	D7,#1EXIT$:	POPM.L	D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DOT     >;========/; ; in	D4.L	P (y;x); out	; mod	DOT:	PUSHM.L	D3,D4	LOAD.L	D3,D4	SUB.W	D3,#5	ADD.W	D4,#5	CALL	LINE	ADD.W	D3,#5	SUB.W	D4,#5	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#5	ADD.W	D4,#5	SWAP.W	D3	SWAP.W	D4	CALL	LINE	POPM.L	D3,D4	RET;--------\\; CADRES  >;========/; ; in	A4.L	^paramtres (OSTP*); out	; mod	CADRES:	PUSHM.L	D3,D4	LOAD.L	D3,(A4)+OSTPS0	LOAD.L	D4,(A4)+OSTPS2	CALL	RECT	LOAD.L	D3,(A4)+OSTPD0	LOAD.L	D4,(A4)+OSTPD1	CALL	LINE	LOAD.L	D3,(A4)+OSTPD1	LOAD.L	D4,(A4)+OSTPD2	CALL	LINE	LOAD.L	D3,(A4)+OSTPD2	LOAD.L	D4,(A4)+OSTPD3	CALL	LINE	LOAD.L	D3,(A4)+OSTPD3	LOAD.L	D4,(A4)+OSTPD0	CALL	LINE	LOAD.L	D4,(A4)+OSTPIN	CALL	DOT	LOAD.L	D4,(A4)+OSTPOU	CALL	DOT	POPM.L	D3,D4	RET;--------\\; RECT    >;========/; ; in	; out	; mod	RECT:	PUSHM.L	D2..D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRRECT	POPM.L	D2..D4	RET;--------\\; LINE    >;========/; ; in	; out	; mod	LINE:	PUSHM.L	D2..D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRSEG	POPM.L	D2..D4	RET;---------\\; STRETCHQ >;=========/; Calcule un point "stretch".; in	A4.L	^paramtres (OSTP*);	D4.L	P (y;x); out	D4.L	P'(y;x); mod	D4.L, D7.WSTRETCHQ:	PUSHM.L	D0..D3,D5,D6LOAD.L D4,(A4)+OSTPIN;;?	LOAD.L	D5,D4	SWAP.W	D5	SUB.W	D4,(A4)+OSTPS0+2 ; D4 <-- X	SUB.W	D5,(A4)+OSTPS0+0 ; D5 <-- Y	LOAD.W	D0,(A4)+OSTPS2+2	SUB.W	D0,(A4)+OSTPS0+2 ; D0 <-- S2x	LOAD.W	D1,(A4)+OSTPS2+0	SUB.W	D1,(A4)+OSTPS0+0 ; D1 <-- S2y; Calcule la coordonne X du point de sortie.;	X' = D3x*Y/S2y + D1x*X/S2x + (D2x-D3x-D1x)*Y/S2y*X/S2x	CLR.W	D2	TEST.W	D1	JUMP',EQ X1$	LOAD.W	D3,(A4)+OSTPD3+2	SUB.W	D3,(A4)+OSTPD0+2	MUL.WA	D3,D5	DIV.WA	D3,D1	ADD.W	D2,D3X1$:	TEST.W	D0	JUMP',EQ X2$	LOAD.W	D3,(A4)+OSTPD1+2	SUB.W	D3,(A4)+OSTPD0+2	MUL.WA	D3,D4	DIV.WA	D3,D0	ADD.W	D2,D3X2$:	TEST.W	D0	JUMP',EQ X3$	TEST.W	D1	JUMP',EQ X3$	LOAD.W	D3,(A4)+OSTPD2+2	SUB.W	D3,(A4)+OSTPD3+2	SUB.W	D3,(A4)+OSTPD1+2	ADD.W	D3,(A4)+OSTPD0+2	MUL.WA	D3,D4	DIV.WA	D3,D0	MUL.WA	D3,D5	DIV.WA	D3,D1	ADD.W	D2,D3		; D2 <-- X'X3$:; Calcule la coordonne Y du point de sortie.;	Y' = D3y*Y/S2y + D1y*X/S2x + (D2y-D3y-D1y)*Y/S2y*X/S2x	CLR.W	D6	TEST.W	D1	JUMP',EQ Y1$	LOAD.W	D3,(A4)+OSTPD3+0	SUB.W	D3,(A4)+OSTPD0+0	MUL.WA	D3,D5	DIV.WA	D3,D1	ADD.W	D6,D3Y1$:	TEST.W	D0	JUMP',EQ Y2$	LOAD.W	D3,(A4)+OSTPD1+0	SUB.W	D3,(A4)+OSTPD0+0	MUL.WA	D3,D4	DIV.WA	D3,D0	ADD.W	D6,D3Y2$:	TEST.W	D0	JUMP',EQ Y3$	TEST.W	D1	JUMP',EQ Y3$	LOAD.W	D3,(A4)+OSTPD2+0	SUB.W	D3,(A4)+OSTPD3+0	SUB.W	D3,(A4)+OSTPD1+0	ADD.W	D3,(A4)+OSTPD0+0	MUL.WA	D3,D4	DIV.WA	D3,D0	MUL.WA	D3,D5	DIV.WA	D3,D1	ADD.W	D6,D3		; D6 <-- Y'Y3$:; Met X' et Y' absolus dans le registre D4.L	LOAD.W	D4,D6	ADD.W	D4,(A4)+OSTPD0+0	SWAP.W	D4	LOAD.W	D4,D2	ADD.W	D4,(A4)+OSTPD0+2LOAD.L (A4)+OSTPOU,D4;;?	POPM.L	D0..D3,D5,D6	RET;--------\\; STRETCH >;========/; Calcule un point "stretch".; in	A4.L	^paramtres (OSTP*);	D4.L	P (y;x); out	D4.L	P'(y;x); mod	D4.L, D7.WSTRETCH:	PUSHM.L	D0..D3,D5,D6,A5	LOAD.L	SP,#(SP)-LSTM	; SP <-- ^variables	LOAD.L	D0,D4		; D0 <-- PinLOAD.L D0,(A4)+OSTPIN;;?	LOAD.L	A5,(A6)+OCIMATH	; A5 <-- canal interne de MATH64	LOAD.W	D4,(A4)+OSTPD1+2	SUB.W	D4,(A4)+OSTPD0+2	CONV.LA.WA D4	MATH64_	BINFP	LOAD.L	(SP)+OSTMD1X+0,D3	LOAD.L	(SP)+OSTMD1X+4,D4	LOAD.W	D4,(A4)+OSTPD1+0	SUB.W	D4,(A4)+OSTPD0+0	CONV.LA.WA D4	MATH64_	BINFP	LOAD.L	(SP)+OSTMD1Y+0,D3	LOAD.L	(SP)+OSTMD1Y+4,D4	LOAD.W	D4,(A4)+OSTPD3+2	SUB.W	D4,(A4)+OSTPD0+2	CONV.LA.WA D4	MATH64_	BINFP	LOAD.L	(SP)+OSTMD3X+0,D3	LOAD.L	(SP)+OSTMD3X+4,D4	LOAD.W	D4,(A4)+OSTPD3+0	SUB.W	D4,(A4)+OSTPD0+0	CONV.LA.WA D4	MATH64_	BINFP	LOAD.L	(SP)+OSTMD3Y+0,D3	LOAD.L	(SP)+OSTMD3Y+4,D4; Calcule le point T1 comme suit :;	T1x = INx * S2x;	T1y = INy * S2y	LOAD.W	D4,(A4)+OSTPS2+2	SUB.W	D4,(A4)+OSTPS0+2	CONV.LA.WA D4	MATH64_	BINFP	LOAD.L	D1,D3	LOAD.L	D2,D4			; D1D2 <-- S2x	LOAD.W	D4,D0	SUB.W	D4,(A4)+OSTPS0+2	CONV.LA.WA D4	MATH64_	BINFP			; D3D4 <-- INx	MATH64_	DIV	LOAD.L	(SP)+OSTMT1X+0,D3	LOAD.L	(SP)+OSTMT1X+4,D4	LOAD.W	D4,(A4)+OSTPS2+0	SUB.W	D4,(A4)+OSTPS0+0	CONV.LA.WA D4	MATH64_	BINFP	LOAD.L	D1,D3	LOAD.L	D2,D4			; D1D2 <-- S2y	LOAD.L	D4,D0	SWAP.W	D4	SUB.W	D4,(A4)+OSTPS0+0	CONV.LA.WA D4	MATH64_	BINFP			; D3D4 <-- INy	MATH64_	DIV	LOAD.L	(SP)+OSTMT1Y+0,D3	LOAD.L	(SP)+OSTMT1Y+4,D4; Calcule la coordonne X du point de sortie.;	OUx = D3x*T1y + D1x*T1x + (D2x-D3x-D1x)*T1y*T1x	LOAD.L	D3,(SP)+OSTMD3X+0	LOAD.L	D4,(SP)+OSTMD3X+4	LOAD.L	D1,(SP)+OSTMT1Y+0	LOAD.L	D2,(SP)+OSTMT1Y+4	MATH64_	MUL	LOAD.L	D5,D3	LOAD.L	D6,D4	LOAD.L	D3,(SP)+OSTMD1X+0	LOAD.L	D4,(SP)+OSTMD1X+4	LOAD.L	D1,(SP)+OSTMT1X+0	LOAD.L	D2,(SP)+OSTMT1X+4	MATH64_	MUL	LOAD.L	D1,D5	LOAD.L	D2,D6	MATH64_	ADD	LOAD.L	D5,D3	LOAD.L	D6,D4	LOAD.W	D4,(A4)+OSTPD2+2	SUB.W	D4,(A4)+OSTPD0+2	CONV.LA.WA D4	MATH64_	BINFP			; D3D4 <-- D2x	LOAD.L	D1,(SP)+OSTMD3X+0	LOAD.L	D2,(SP)+OSTMD3X+4	MATH64_	SUB	LOAD.L	D1,(SP)+OSTMD1X+0	LOAD.L	D2,(SP)+OSTMD1X+4	MATH64_	SUB	LOAD.L	D1,(SP)+OSTMT1X+0	LOAD.L	D2,(SP)+OSTMT1X+4	MATH64_	MUL	LOAD.L	D1,(SP)+OSTMT1Y+0	LOAD.L	D2,(SP)+OSTMT1Y+4	MATH64_	MUL	LOAD.L	D1,D5	LOAD.L	D2,D6	MATH64_	ADD	MATH64_	FPBIN	ADD.W	D4,(A4)+OSTPD0+2	LOAD.W	D0,D4			; D0 <-- Poutx; Calcule la coordonne Y du point de sortie.;	OUy = D3y*T1y + D1y*T1x + (D2y-D3y-D1y)*T1y*T1x	LOAD.L	D3,(SP)+OSTMD3Y+0	LOAD.L	D4,(SP)+OSTMD3Y+4	LOAD.L	D1,(SP)+OSTMT1Y+0	LOAD.L	D2,(SP)+OSTMT1Y+4	MATH64_	MUL	LOAD.L	D5,D3	LOAD.L	D6,D4	LOAD.L	D3,(SP)+OSTMD1Y+0	LOAD.L	D4,(SP)+OSTMD1Y+4	LOAD.L	D1,(SP)+OSTMT1X+0	LOAD.L	D2,(SP)+OSTMT1X+4	MATH64_	MUL	LOAD.L	D1,D5	LOAD.L	D2,D6	MATH64_	ADD	LOAD.L	D5,D3	LOAD.L	D6,D4	LOAD.W	D4,(A4)+OSTPD2+0	SUB.W	D4,(A4)+OSTPD0+0	CONV.LA.WA D4	MATH64_	BINFP			; D3D4 <-- D2y	LOAD.L	D1,(SP)+OSTMD3Y+0	LOAD.L	D2,(SP)+OSTMD3Y+4	MATH64_	SUB	LOAD.L	D1,(SP)+OSTMD1Y+0	LOAD.L	D2,(SP)+OSTMD1Y+4	MATH64_	SUB	LOAD.L	D1,(SP)+OSTMT1X+0	LOAD.L	D2,(SP)+OSTMT1X+4	MATH64_	MUL	LOAD.L	D1,(SP)+OSTMT1Y+0	LOAD.L	D2,(SP)+OSTMT1Y+4	MATH64_	MUL	LOAD.L	D1,D5	LOAD.L	D2,D6	MATH64_	ADD	MATH64_	FPBIN	ADD.W	D4,(A4)+OSTPD0+0	SWAP.W	D4	LOAD.W	D4,D0			; D4 <-- PoutLOAD.L (A4)+OSTPOU,D4;;?	LOAD.L	SP,#(SP)+LSTM		; ajuste le stack	POPM.L	D0..D3,D5,D6,A5	RETNMMATH64:.ASCIZ	"MATH64"	.EVENVAR:	.FILLB	LGVAR,0	.END	START