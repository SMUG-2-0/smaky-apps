	.SBTTL	PAGEMISC.ASI;--------\\; MMENUS  >;========/; Attend un choix selon un mmenu hirarchique.; in	A3.L	^mmenu;	A4.L	^paramtres; out	D7.W	erreur; mod	D7.WMMENUS:	PUSHM.L	D3..D5,A0	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	CALL	SCMO		; remet la souris	CLR.W	D3	CALL	SELMO		; outil = flche	LIB	?IFMOUSE	; D4 <-- position de la souris	PUSH.L	(A0)+ODFFY	PUSH.L	(A0)+ODFFDY	PUSH.L	(A0)+ODFWBY	PUSH.L	(A0)+ODFWEY	TEST.B	(A6)+ODEF+1:#BDEFMDC-0	JUMP',BS 50$	CLR.W	(A4)+OMMSEL	; slectionne la premire case50$:	CLR.L	D5		; D5 <-- flags	LIB	?MMENUS		; choix selon mmenu hirarchique ...	POP.L	(A0)+ODFWEY	POP.L	(A0)+ODFWBY	POP.L	(A0)+ODFFDY	POP.L	(A0)+ODFFY	PUSH.W	D7	CALL	PMOUSE		; remet la souris o elle tait	LOAD.W	D4,#2	NTREL	?DELMS		; attend le positionnement	POP.W	D7	POPM.L	D3..D5,A0	TEST.W	D7		; retour EQ/NE	RET;----------\\; TESTEVENT >;==========/; Teste si un vnement est l, sans le lire.; in	-; out	D3.L	touche presse;	D4.L	position souris (si D3=KEYM?P);	D7.W	erreur; mod	D3.L, D4.L, D7.WTESTEVENT:	LOAD.L	D3,(A6)+OEVKEY	; dj un vnement lu ?	JUMP',NE OK$		; oui => OK$	LIB	?IFCAR		; D3 <-- touche presse ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.L	(A6)+OEVKEY,D3	CLR.L	(A6)+OEVPOS	COMP.W	D3,#KEYMGP	JUMP',EQ POS$	COMP.W	D3,#KEYMMP	JUMP',EQ POS$	COMP.W	D3,#KEYMDP	JUMP',NE OK$POS$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE OK$	LOAD.L	(A6)+OEVPOS,D4OK$:	LOAD.L	D4,(A6)+OEVPOS	; D4 <-- position de la souris	CLR.W	D7		; D7 <-- y'a un vnementEXIT$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; WAITEVENT >;==========/; Attend un vnement, avec timeout.; in	D3.W	timeout; out	D3.L	touche presse;	D4.L	position souris (si D3=KEYM?P);	D7.W	NE si timeout; mod	D3.L, D4.L, D7.WWAITEVENT:	TEST.L	(A6)+OEVKEY	; dj un vnement lu ?	JUMP',EQ WAIT$		; non => WAIT$	LOAD.L	D3,(A6)+OEVKEY	; D3 <-- vnement dj lu	CLR.L	(A6)+OEVKEY	; y'en a plus	JUMP'	OK$WAIT$:	CALL	WAITMOVET	; attend vnement ...	JUMP',NE EXIT$	CLR.L	(A6)+OEVPOS	COMP.W	D3,#KEYMGP	JUMP',EQ POS$	COMP.W	D3,#KEYMMP	JUMP',EQ POS$	COMP.W	D3,#KEYMDP	JUMP',NE OK$POS$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE OK$	LOAD.L	(A6)+OEVPOS,D4OK$:	LOAD.L	D4,(A6)+OEVPOS	; D4 <-- position de la souris	CLR.W	D7		; D7 <-- y'a un vnementEXIT$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; WAITPRESS >;----------/; Attend une pression d'une touche ou d'un bouton.; in	-; out	D3.L	touche presse; mod	D3.L, D7.WWAITPRESS:	PUSH.L	D410$:	LIB	?GETKEY		; attend souris ...	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP,BS 10$		; non => 10$	COMP.W	D3,#KEYMPO	; dplacement ?	JUMP,EQ 10$		; oui => 10$	POP.L	D4	RET;----------\\; WAITMOVET >;----------/; Attend un vnement, avec timeout.; in	D3.W	timeout; out	D3.L	touche presse;	D7.W	NE si timeout; mod	D3.L, D7.WWAITMOVET:	PUSH.L	D4	LOAD.W	D4,D3	NTREL	?SETTIM		; init le timeoutLOOP$:	LIB	?GETKEY		; attend souris ...	JUMP',NE EXIT$	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP,BS LOOP$		; non => LOOP$EXIT$:	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet un timeout infini (normal)	POP.W	D7	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; WAITMOVES >;----------/; Attend les dplacements de la souris, mme si elle ne bouge pas.; in	-; out	D3.L	touche presse;	D7.W	EQ si souris dplace; mod	D3.L, D7.WWAITMOVES:	PUSH.L	D4	CLR.W	D4	NTREL	?SETTIM		; met timeout nul (trs trs court)	CALL	WAITMOVE	; attend dplacement souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; WAITMOVE >;---------/; Attend un dplacement de la souris.; in	-; out	D3.L	touche presse;	D7.W	EQ si souris dplace; mod	D3.L, D7.WWAITMOVE:10$:	LIB	?GETKEY		; attend souris ...	JUMP',NE 20$		; si timeout => 20$	TEST.L	D3:#BKRELEAS	; touche relche ?	JUMP',BC 30$		; non => 30$	JUMP	10$20$:	LOAD.W	D3,#KEYMPO	; D3 <-- dplacement	CLR.W	D7		; D7 <-- souris bouge	JUMP'	90$30$:	LOAD.W	D7,#1		; D7 <-- fin du dplacement	COMP.W	D3,#KEYMGP	JUMP',EQ 90$	COMP.W	D3,#KEYMMP	JUMP',EQ 90$	COMP.W	D3,#KEYMDP	JUMP',EQ 90$	COMP.W	D3,#KEYMGR	JUMP',EQ 90$	COMP.W	D3,#KEYMMR	JUMP',EQ 90$	COMP.W	D3,#KEYMDR	JUMP',EQ 90$	CLR.W	D7		; D7 <-- souris bouge90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; NBMOUSE >;========/; Donne le nombre de boutons presss sur la souris.; in	-; out	D3.W	nombre de boutons presss (0..3); mod	D3.L, D7.WNBMOUSE:	PUSH.L	D4	LIB	?IFMOUSE	; D3/D4 <-- boutons/position	LOAD.W	D4,D3	CLR.W	D3	TEST.L	D4:#BMOLEFT	JUMP',BC LEFT$	INC.W	D3LEFT$:	TEST.L	D4:#BMOCENT	JUMP',BC CENT$	INC.W	D3CENT$:	TEST.L	D4:#BMORIGHT	JUMP',BC RIGHT$	INC.W	D3RIGHT$:	POP.L	D4	RET;---------\\; IFMOUSEW >;=========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSEW:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE 90$	COMP.W	D4,(A6)+OWDOX2	JUMP',LO 20$	LOAD.W	D4,(A6)+OWDOX2	DEC.W	D4	LOAD.W	D7,#ERDIOUT20$:	SUB.W	D4,(A6)+OWDOX1	JUMP',HS 22$	CLR.W	D4	LOAD.W	D7,#ERDIOUT22$:	SWAP.W	D4	COMP.W	D4,(A6)+OWDOY2	JUMP',LO 30$	LOAD.W	D4,(A6)+OWDOY2	DEC.W	D4	LOAD.W	D7,#ERDIOUT30$:	SUB.W	D4,(A6)+OWDOY1	JUMP',HS 32$	CLR.W	D4	LOAD.W	D7,#ERDIOUT32$:	SWAP.W	D490$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la wdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSHM.L	D3,A0	LIB	?IFMOUSE	JUMP',NE 90$	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	ADD.W	D4,(A6)+OLUPX	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	ADD.W	D4,(A6)+OLUPY	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POPM.L	D3,A0	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMOUSE  >;========/; Positionne la souris en (y;x).; in	D4.L	nouvelle position y;x; out	-; mod	D7.WPMOUSE:	LIB	?PMOUSE		; positionne la souris	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	CLR.L	(A0)+ODFTPM	; annule XTRAME	RET;--------\\; CCMO    >;========/; Enlve la souris.; in	-; out	-; mod	D7.WCCMO:	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP',T	EXIT$		; oui => EXIT$	TEST.B	(A6)+OCCMO	JUMP',T EXIT$	COMP.W	(A6)+OLUTIN,#ICORETICULE	JUMP',EQ RETI$	PUSH.W	D3	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	POP.W	D3	SET.B	(A6)+OCCMO	JUMP'	EXIT$RETI$:	PUSH.L	D4	LOAD.L	D4,(A6)+OPRETI	CALL	RETICULEINV	; efface le dernier rticule	LOAD.L	(A6)+OPRETI,#-1	POP.L	D4	SET.B	(A6)+OCCMOEXIT$:	RET;--------\\; SCMO    >;========/; Remet la souris.; in	-; out	-; mod	D7.WSCMO:	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP',T	EXIT$		; oui => EXIT$	TEST.B	(A6)+OCCMO	JUMP',F EXIT$	COMP.W	(A6)+OLUTIN,#ICORETICULE	JUMP',EQ RETI$	PUSH.W	D3	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	POP.W	D3	CLR.B	(A6)+OCCMO	JUMP'	EXIT$RETI$:	CLR.B	(A6)+OCCMO	CALL	RETICULEMOVE	; met le rticuleEXIT$:	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; SELMO   >;========/; Slectionne un nouveau lutin pour la souris.; in	D3.W	outil en fonction; out	-; mod	D7.WSELMO:	PUSHM.L	D1..D5,A2..A5	LOAD.L	A3,#R16"TABLE$	LOAD.W	D2,D3	CLR.W	D3		; D3 <-- pas d'outil; Vrifie si la souris est dans la zone de dessin.; Si non, n'utilise pas l'outil slectionn.	LOAD.L	D1,#-1		; D1 <-- hors de la fentre	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE TABLOOP$	LOAD.L	D1,D4		; D1 <-- position initiale	COMP.W	D4,(A6)+OWDOX2	JUMP',HS TABLOOP$	SUB.W	D4,(A6)+OWDOX1	JUMP',LO TABLOOP$	SWAP.W	D4	COMP.W	D4,(A6)+OWDOY2	JUMP',HS TABLOOP$	SUB.W	D4,(A6)+OWDOY1	JUMP',LO TABLOOP$	LOAD.W	D3,D2		; D3 <-- outil slectionnTABLOOP$:	TEST.W	(A3)+0		; fin de la table ?	JUMP',EQ TABEND$	COMP.W	D3,(A3)+0	; outil trouv ?	JUMP',EQ TABEND$	ADD.L	A3,#10		; A3 <-- ^suivant dans table	JUMP	TABLOOP$TABEND$:	LOAD.W	D3,(A3)+2	; D3 <-- code de l'icne	LOAD.W	(A6)+OLUPX,(A3)+6	LOAD.W	(A6)+OLUPY,(A3)+8	TEST.B	(A6)+ODEF+1:#BDEFRET-0	JUMP',BC NORET$	TEST.W	D3	JUMP',EQ NORET$	LOAD.W	D3,#ICORETICULE	; D3 <-- force le rticule	CLR.W	(A6)+OLUPX	CLR.W	(A6)+OLUPYNORET$:	COMP.W	D3,(A6)+OLUTIN	; toujours le mme outil ?	JUMP',NE NEW$		; non => NEW$				; oui =>	COMP.W	D3,#ICORETICULE	JUMP,NE EXIT$	CALL	RETICULEMOVE	; dplace le rticule	JUMP	EXIT$NEW$:	COMP.W	(A6)+OLUTIN,#ICORETICULE	JUMP',NE RETI2$	CALL	RETICULECLOSE	; efface le dernier rticuleRETI2$:	COMP.W	D3,#ICORETICULE	JUMP',NE RETI4$	CALL	RETICULEOPEN	; ouvre un nouveau rticuleRETI4$:	LOAD.W	(A6)+OLUTIN,D3	COMP.W	D3,#ICORETICULE	JUMP',NE RETI8$	CALL	CMPMOUSE	; positionne pour ne pas bouger la "pointe"	LOAD.W	D4,#2	NTREL	?DELMS		; attend le changement/positionnement !	JUMP	EXIT$RETI8$:	LOAD.L	A2,#(A6)+OLUMAM	TNOT.B	(A6)+OLUFLG:#BLUMAN	JUMP',BC BUFOK$	LOAD.L	A2,#(A6)+OLUMANBUFOK$:	LOAD.L	A4,#0		; A4 <-- utilise la flche normale	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	TEST.W	D3	JUMP',EQ NORM$	LOAD.W	D4,(A3)+4	JUMP',NE FOND$CHAIR$:	CALL	CMOUTIL		; A4/A5 <-- ^dx,dy,matrice de l'outil	JUMP'	NORM$FOND$:	CALL	CMOUTILFOND	; A4/A5 <-- ^dx,dy,matrice chair/fond;	JUMP'	NORM$NORM$:	NTREL	?GETPRIO	LOAD.W	D5,D4		; D5 <-- priorit actuelle	LOAD.W	D4,#1	NTREL	?SETPRIO	; met une trs forte priorit	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	LOAD.L	(A3)+1,A4	; <ssss> matrice chair	LOAD.L	(A3)+5,A5	; <cccc> matrice fond	LOAD.W	D3,#9	LIB	?STRING	CALL	CMPMOUSE	; positionne pour ne pas bouger la "pointe"	LOAD.W	D4,D5	NTREL	?SETPRIO	; remet la priorit initiale	LOAD.W	D4,#2	NTREL	?DELMS		; attend le changement/positionnement !EXIT$:	POPM.L	D1..D5,A2..A5	RETTABLE$:	;						x,y	.W	ICOOCRAYON,ICOOCRAYON,0			6+1,19+1	.W	ICOOFLECHE,0,0				0,0	.W	ICOOEDIT,ICOOEDIT,0			11+1,10+1	.W	ICOOLOUPE,ICOOLOUPE,0			11+1,6+1	.W	ICOOMAIN,ICOOMAIN,ICOOMAIN+1		12+1,10+1	.W	ICOOOPER,0,0				0,0	.W	ICOOGROUPE,ICOHGROUPE,0			2+1,0+1	.W	ICOOPLAN,ICOOPLANM,0			2+1,5+1	.W	ICOHMOVE,ICOHMOVE,0			5+1,3+1	.W	ICOHADD,ICOHADD,0			5+1,3+1	.W	ICOHSUB,ICOHSUB,0			5+1,3+1	.W	ICOHNEW,ICOHNEW,0			5+1,3+1	.W	ICOHLINE,ICOHLINE,0			12+1,1+1	.W	ICOHCURVE,ICOHCURVE,0			12+1,1+1	.W	ICOOSUITE,ICOOSUITE,0			11+1,18+1	.W	ICOOAIDE,ICOOAIDE,0			11+1,12+1	.W	ICORETICULE,ICORETICULE,0		0,0	.W	0,0,0					0,0	.EVEN;---------\\; CMPMOUSE >;---------/; Positionne la souris en fonction du nouvel outil.; in	D1.L	position initiale; out	-; mod	D7.WCMPMOUSE:	PUSHM.L	D4,A2	COMP.L	D1,#-1		; hors de la fentre ?	JUMP',EQ OUT$		; oui => OUT$				; non =>	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE OUT$	SUB.W	D4,D1	JUMP',NC POS$	NEG.W	D4		; D4 <-- |dplacement horizontal|POS$:	COMP.W	D4,#30		; souris beaucoup bouge "entre temps" ?	JUMP',HS OUT$		; oui => OUT$ (crac, pas de positionnement !!!)	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	D4,D1	SUB.W	D4,(A6)+OLUPX	ADD.W	D4,(A2)+ODFFX	SWAP.W	D4	SUB.W	D4,(A6)+OLUPY	ADD.W	D4,(A2)+ODFFY	SWAP.W	D4	CALL	PMOUSE		; positionne pour ne pas bouger la "pointe"OUT$:	POPM.L	D4,A2	RET;--------\\; CMOUTIL >;--------/; Construit la matrice d'un outil quelconque d'aprs; une icne contenue dans IPP21.; La matrice construite possde un point de plus de tous; les cts, pour permettre un calcul correct de la matrice; automatique de fond.; in	D3.W	code de l'icne;	A2.L	^buffer pour matrice; out	A4.L	^dx,dy,matrice chair;	A5.L	^dx,dy,matrice fond; mod	D7.W, A4.L, A5.LCMOUTIL:	PUSHM.L	D1..D4,A1,A3	LOAD.L	A1,(A6)+OPGICO	; A1 <-- ^gencar des icnes IPP21	TCLR.L	D3:#7	JUMP',BC 20$	LOAD.L	A1,(A6)+OPHICO	; A1 <-- ^gencar des icnes IPP2220$:	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D3	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^bonne matrice	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#GCICX/8 ; source: <ii>	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D2,#1+GCICY+1	; D2 <-- hauteur	SWAP.W	D2	CLR.W	D2	LOAD.B	D2,(A4)+(D3.W)	ADD.W	D2,#2		; D2 <-- largeur	LOAD.W	D1,D2	ADD.W	D1,#8-1	SR.W	D1,#3		; D1 <-- largeur en bytes	LOAD.W	(A3)+12,#1	; destination: <xx>	LOAD.W	(A3)+14,#1	; destination: <yy>	LOAD.L	A4,A2		; A4 <-- ^buffer pour matrice	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,D1	; destination: <ii>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D440$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,40$	SUB.W	D2,#2	LOAD.W	(A3)+22,D2	; <dxx>	SWAP.W	D2	SUB.W	D2,#2	LOAD.W	(A3)+24,D2	; <dyy>	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne	LOAD.L	A4,A2		; A4 <-- ^dx,dy,matrice	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	POPM.L	D1..D4,A1,A3	RET;------------\\; CMOUTILFOND >;------------/; Construit les matrices chair et fond d'un outil quelconque d'aprs; une icne et la suivante contenue dans IPP21.; in	D3.W	code de l'icne chair;	D4.W	code de l'icne fond;	A2.L	^buffer pour matrice; out	A4.L	^dx,dy,matrice chair;	A5.L	^dx,dy,matrice fond; mod	D7.W, A4.L, A5.LCMOUTILFOND:	PUSHM.L	D0..D5,A1,A3	LOAD.L	A1,(A6)+OPGICO	; A1 <-- ^gencar des icnes IPP21	TCLR.L	D3:#7	JUMP',BC 20$	LOAD.L	A1,(A6)+OPHICO	; A1 <-- ^gencar des icnes IPP22	TCLR.L	D4:#720$:	LOAD.W	D0,D3		; D0 <-- code de l'icne chair	LOAD.W	D5,D4		; D0 <-- code de l'icne fond	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D0	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^matrice chair	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#GCICX/8 ; source: <ii>	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D2,#GCICY	; D2 <-- hauteur	SWAP.W	D2	CLR.W	D2	LOAD.B	D2,(A4)+(D0.W)	; D2 <-- largeur	LOAD.W	D1,D2	ADD.W	D1,#8-1	SR.W	D1,#3		; D1 <-- largeur en bytes	CLR.L	(A3)+12		; destination: <xx> et <yy>	LOAD.L	A4,A2		; A4 <-- ^buffer pour matrice	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx chair	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy chair	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,D1	; destination: <ii>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D440$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,40$	SWAP.W	D2	LOAD.L	(A3)+22,D2	; <dxx> et <dyy>	SWAP.W	D2	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne chair	LOAD.L	A5,A4		; A5 <-- ^futur dx,dy,matrice fond	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D5	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^matrice suivante (fond)	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.L	A4,A5	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx fond	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy fond	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D460$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,60$	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne fond	LOAD.L	A4,A2		; A4 <-- ^dx,dy,matrice chair	POPM.L	D0..D5,A1,A3	RET;-------------\\; RETICULEOPEN >;=============/; Prpare l'affichage du rticule.; in	-; out	-; mod	D7.WRETICULEOPEN:	RET;-------------\\; RETICULEMOVE >;=============/; Dplace le rticule selon la souris.; in	-; out	-; mod	D7.WRETICULEMOVE:	PUSHM.L	D3,D4	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE EXIT$	COMP.L	D4,(A6)+OPRETI	JUMP',EQ EXIT$	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OPRETI	CALL	RETICULEINV	; efface l'ancien rticule	LOAD.L	D4,D3	CALL	RETICULEINV	; allume le nouveau rticule	LOAD.L	(A6)+OPRETI,D4EXIT$:	POPM.L	D3,D4	RET;--------------\\; RETICULECLOSE >;==============/; Termine l'affichage du rticule.; in	-; out	-; mod	D7.WRETICULECLOSE:	PUSHM.L	D3,D4	LOAD.L	D4,(A6)+OPRETI	CALL	RETICULEINV	; efface le dernier rticule	LOAD.L	(A6)+OPRETI,#-1	LOAD.B	D3,#AFSCMO	LIB	?AFCAR		; remet la souris	POPM.L	D3,D4	RET;------------\\; RETICULEINV >;------------/; Inverse le rticule.; ATTENTION:	Cette routine peut tre appels alors qu'une sous-fentre;		est cre. Il faut alors utiliser la fentre principale;		avant d'inverser le rticule !; in	D4.L	position (y;x); out	-; mod	D7.WRETICULEINV:	PUSH.L	A0	COMP.L	D4,#-1	JUMP',EQ EXIT$	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	TEST.L	(A0)+ODFFY	; utilise une swdo spciale ?	JUMP',EQ SIMPLE$	; non => SIMPLE$				; oui =>	PUSH.W	(A6)+OWUSE	LOAD.W	(A6)+OWUSE,#1	CALL	__WDOCLOSE	; utilise tout l'cran	CALL	RETICULELINE	; inverse les lignes	CALL	__WDOOPEN	; rutilise la swdo initiale	POP.W	(A6)+OWUSE	JUMP'	EXIT$SIMPLE$:	CALL	RETICULELINE	; inverse les lignesEXIT$:	POP.L	A0	RET;-------------\\; RETICULELINE >;-------------/; Inverse les deux lignes du rticule.; in	D4.L	position (y;x); out	-; mod	D7.WRETICULELINE:	PUSHM.L	D1..D4,A1,A2	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la souris	LOAD.W	D1,#INVDOT	; D1 <-- mode de dessin	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OLINE	LOAD.L	D2,D4	LOAD.W	D4,(A6)+OWDIX1	CLR.L	D3	LOAD.W	D3,(A6)+OWDIX2	SUB.W	D3,D4	CALL	(A1)		; GRA2_LINE, dessine une ligne horizontale	LOAD.L	D4,D2	SWAP.W	D4	LOAD.W	D4,(A6)+OWDIY1	LOAD.W	D3,(A6)+OWDIY2	SUB.W	D3,D4	SWAP.W	D4	SWAP.W	D3	CLR.W	D3	CALL	(A1)		; GRA2_LINE, dessine une ligne verticale	POPM.L	D1..D4,A1,A2	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	A2.L	^table des soft-keys (si NICOxxx); out	-; mod	D7.WAFMENU:	PUSHM.L	D3,A3	LOAD.L	A3,#R16"TXMENU$	LOAD.W	D3,(A6)+OICONIV	JUMP',EQ AFF$	COMP.W	D3,#NICOEDIT	JUMP',EQ PS$	COMP.W	D3,#NICOCREATE	JUMP',EQ PS$	LOAD.L	A3,#R16"TXMENU0$	COMP.W	D3,#NICOSUITE	JUMP',EQ AFF$;	LOAD.L	A3,#R16"TXMENU0$	COMP.W	(A6)+OOUTIL,#ICOOFLECHE	JUMP',NE AFF$	COMP.W	(A6)+OSELNB,#1	JUMP',NE AFF$PS$:	LOAD.L	A3,(A6)+OICOPS	; A3 <-- ^table des soft-keysAFF$:	LIB	?AFMENU	POPM.L	D3,A3	RETTXMENU$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	"      Ajoute     "	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	"Echelle"	.ASCIZ	"  -    100%   +  "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"      Grille     "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Tout  Efface Imp."		;     ;     ;     ;TXMENU0$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN	.END