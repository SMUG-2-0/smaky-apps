	.SBTTL	PAGEPRINT.ASINBLPRINT =	200		; imprime par tranches de 100 lignesDOIMPRIME:	CALL	PRINTALL	; imprime tout ...	JUMP,NE _ERROR	JUMP	_LOOP;---------\\; PRINTALL >;=========/; Imprime toute la page.; in	-; out	D7.W	erreur; mod	D7.WPRINTALL:	PUSHM.L	D1..D6,A2..A5	PUSH.L	(A6)+OVUE	PUSH.L	(A6)+OGRID	PUSH.L	(A6)+OCALQUE	PUSH.L	(A6)+OWDIY1	PUSH.L	(A6)+OWDIY2	PUSH.L	(A6)+OWDOY1	PUSH.L	(A6)+OWDOY2	PUSH.L	(A6)+ODESY1	PUSH.L	(A6)+ODESY2	SET.B	(A6)+OIFPRI	; impression en cours	LOAD.W	D7,#ERPAILOP	TEST.L	(A6)+OCAPRINT	JUMP,EQ EXIT$	CALL	DBOXPRINT	; demande comment imprimer ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$	LOAD.W	(A6)+OCALQUE+2,(A6)+OPRINT+2	LOAD.L	(A6)+OVUE,#-1	LOAD.L	(A6)+OGRID,#2^BGRIDPAN!2^BGRIDMU4!2^BGRIDGRN	TEST.B	(A6)+OPRINT+0:#BPRIPS-24 ; impression PostScript ?	JUMP,BS PS$		; oui => PS$	CLR.L	D3		; D3 <-- mode	TSET.L	D3:#BPRNOFILE	; D3 <-- pas de fichier en sortie	TSET.L	D3:#BPRNOINTERV	; D3 <-- pas de page de ..  ..	TSET.L	D3:#BPRCHOIX	; D3 <-- case (CHOIX) active	LOAD.L	A3,#(A6)+OBUNAME ; A3 <-- ^nom du fichier	LOAD.L	A4,#(A6)+OBUPRES ; A4 <-- ^nom de la prsentation	CLR.B	(A4)	LOAD.L	A5,#R16"NAME$	; A5 <-- ^nom du logiciel	CLR.L	D2		; D2 <-- longueur du document (!)	LOAD.L	A2,(A6)+OCAPRINT	CALL	DBOXOPEN1	PRINTA_	OPPRINT		; ouvre l'impression ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	JUMP,NE EXIT$	CALL	GETPRIDIM	; D4/D3/D2 <-- dimensions/marges papier	JUMP,NE CLOSE$	LOAD.L	D1,D3	COMP.W	(A6)+OVPSTA+OPRZ,#1	JUMP',EQ OKZOOM$	CALL	DBOXZPRINT	; avertissement ...	JUMP,NE CLOSE$	COMP.W	D3,#F1	JUMP,NE CLOSE$OKZOOM$:	LOAD.L	D3,D1	CALL	PRINTBOA	; imprime les "boa"	JUMP,NE CLOSE$	LOAD.L	D5,(A6)+ODESYD	; D5 <-- dimensions dessin	COMP.W	D4,D5	JUMP',HS RNDX$	LOAD.W	D1,D5	SUB.W	D1,#10*FACMMPT	COMP.W	D4,D1	JUMP',LO RNDX$	LOAD.W	D5,D4		; D5 <-- largeur dessin -1mmRNDX$:	SUB.W	D4,D2	SUB.W	D5,D2	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	COMP.W	D4,D5	JUMP',HS RNDY$	LOAD.W	D1,D5	SUB.W	D1,#10*FACMMPT	COMP.W	D4,D1	JUMP',LO RNDY$	LOAD.W	D5,D4		; D5 <-- hauteur dessin -1mmRNDY$:	SUB.W	D4,D2	SUB.W	D5,D2LOOPY$:	COMP.W	D4,D5	JUMP',LS OKY$	LOAD.W	D4,D5OKY$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	PUSHM.L	D3,D4LOOPX$:	COMP.W	D4,D5	JUMP',LS OKX$	LOAD.W	D4,D5OKX$:	CALL	PRINTPAGE	; imprime une page	JUMP',NE CLOSEP$	CALL	PRINTEOP	; imprime une fin de page	JUMP',NE CLOSEP$	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- largeur imprime	ADD.W	D3,D2	ADD.W	D4,D2	COMP.W	D3,D5	JUMP,LO LOOPX$	POPM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- hauteur imprime	ADD.W	D3,D2	ADD.W	D4,D2	COMP.W	D3,D5	JUMP,LO LOOPY$	JUMP'	CLOSE$CLOSEP$:	POPM.L	D3,D4CLOSE$:	PUSH.W	D7	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	CLPRINT		; ferme l'imprimante	POP.W	D7	JUMP'	EXIT$PS$:	CALL	PRINTPS		; impression PostScriptEXIT$:	CLR.B	(A6)+OIFPRI	; fin de l'impression	POP.L	(A6)+ODESY2	POP.L	(A6)+ODESY1	POP.L	(A6)+OWDOY2	POP.L	(A6)+OWDOY1	POP.L	(A6)+OWDIY2	POP.L	(A6)+OWDIY1	POP.L	(A6)+OCALQUE	POP.L	(A6)+OGRID	POP.L	(A6)+OVUE	POPM.L	D1..D6,A2..A5	TEST.W	D7		; retour EQ/NE	RETNAME$:	.ASCIZ	"PAGE"	.EVEN;---------\\; PRINTBOA >;---------/; Imprime les commandes "boa" pour les marges.; in	-; out	D7.W	erreur; mod	D7.WPRINTBOA:	PUSHM.L	D4,A2..A4	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer	LOAD.L	A3,#R16"TXMG$	CALL	PUTTX$	CLR.L	D4	LOAD.W	D4,(A6)+OVPSTA+OPRMGGH	CALL	PUTANUM	LOAD.L	A3,#R16"TXLG$	CALL	PUTTX$	CLR.L	D4	LOAD.W	D4,(A6)+OVPSTA+OPRLGPH	SUB.W	D4,(A6)+OVPSTA+OPRMGGH	SUB.W	D4,(A6)+OVPSTA+OPRMGDH	CALL	PUTANUM	LOAD.L	A3,#R16"TXMS$	CALL	PUTTX$	CLR.L	D4	LOAD.W	D4,(A6)+OVPSTA+OPRMGSH	CALL	PUTANUM	LOAD.L	A3,#R16"TXMI$	CALL	PUTTX$	CLR.L	D4	LOAD.W	D4,(A6)+OVPSTA+OPRMGIH	CALL	PUTANUM	LOAD.L	A3,#R16"TXEND$	CALL	PUTTX$	LOAD.L	D4,A4	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer	SUB.L	D4,A4		; D4 <-- lg	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	WRPRINT		; crit les commandes boa	POPM.L	D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETPUTTX$:	LOAD.B	(A4+),(A3+)	JUMP,NE PUTTX$	DEC.L	A4	RETTXMG$:	.ASCIZ	"<BOA>marge "TXLG$:	.ASCIZ	"p;<BOA>large "TXMS$:	.ASCIZ	"p;<BOA>marsup "TXMI$:	.ASCIZ	"p;<BOA>marinf "TXEND$:	.ASCIZ	"p;"	.EVEN;---------\\; PRINTEOP >;---------/; Imprime une fin de page.; in	-; out	D7.W	erreur; mod	D7.WPRINTEOP:	PUSHM.L	D4,A2,A4	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer	LOAD.B	(A4),#EOP	LOAD.L	D4,#1		; D4 <-- lg	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	WRPRINT		; crit une fin de page	POPM.L	D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; PRINTPAGE >;----------/; Imprime une page en plusieurs parties.; in	D3.L	coin sup/gauche;	D4.L	coin inf/droite; out	D7.W	erreur; mod	D7.WPRINTPAGE:	PUSHM.L	D3..D6	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- jusqu'o aller	EX.L	D5,D4	LOAD.W	D4,#NBLPRINT	CALL	SCALEN		; D5 <-- hauteur d'une tranche	EX.L	D4,D5LOOP$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,D3	ADD.W	D4,D5		; D4 <-- bas de la tranche	COMP.W	D4,D6		; tranche trop haute ?	JUMP',LO TRUNC$		; non => TRUNC$	LOAD.W	D4,D6		; D4 <-- position maximaleTRUNC$:	SWAP.W	D4	SWAP.W	D3	CALL	PRINTPART	; imprime une tranche	JUMP',NE EXIT$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,D4		; D3 <-- haut de la tranche suivante	COMP.W	D3,D6		; est-on arriv tout en bas ?	JUMP',HS EXIT$		; oui => EXIT$	SWAP.W	D4	SWAP.W	D3	JUMP	LOOP$EXIT$:	POPM.L	D3..D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; PRINTPART >;----------/; Imprime une partie de page.; in	D3.L	coin sup/gauche;	D4.L	coin inf/droite; out	D7.W	erreur; mod	D7.WPRINTPART:	PUSHM.L	D1..D6,A0,A2,A4	LOAD.L	(A6)+ODESY1,D3	LOAD.L	(A6)+ODESY2,D4	EX.L	D4,D3	CALL	SCALEP	EX.L	D3,D4	CALL	SCALEP	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D6,D4		; D6 <-- dimensions (dy;dx)	ADD.W	D6,#16-1	SR.W	D6,#4	SL.W	D6,#4		; D6 <-- largeur modulo 16	LOAD.W	D5,D6	SR.W	D5,#3		; D5 <-- largeur en bytes	LOAD.L	D4,D6	SWAP.W	D4	MUL.WU	D4,D5		; D4 <-- taille ncesssaire	ADD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer d'impression	JUMP,NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	PUSH.L	(A0)+ODFABS	PUSH.L	(A0)+ODFY	PUSH.L	(A0)+ODFDY	PUSH.L	(A0)+ODFFY	PUSH.L	(A0)+ODFFDY	PUSH.L	(A0)+ODFWBY	PUSH.L	(A0)+ODFWEY	PUSH.W	(A0)+ODFIIX	PUSH.W	(A0)+ODFIIY	LOAD.L	A4,#(A4)+LGHIMA	LOAD.L	(A0)+ODFABS,A4	CLR.L	(A6)+OWDIY1	LOAD.L	(A6)+OWDIY2,D6	CLR.L	(A6)+OWDOY1	LOAD.L	(A6)+OWDOY2,D6	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D6	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D6	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D6	LOAD.W	(A0)+ODFIIX,#1	LOAD.W	(A0)+ODFIIY,D5	CALL	DESOBJETS	; dessine tous les objets	POP.W	(A0)+ODFIIY	POP.W	(A0)+ODFIIX	POP.L	(A0)+ODFWEY	POP.L	(A0)+ODFWBY	POP.L	(A0)+ODFFDY	POP.L	(A0)+ODFFY	POP.L	(A0)+ODFDY	POP.L	(A0)+ODFY	POP.L	(A0)+ODFABS	LOAD.L	A4,#(A4)-LGHIMA	; A4 <-- ^buffer	LOAD.B	(A4)+OIMTYP,#H'81	LOAD.B	(A4)+OIMCOD,#H'00	LOAD.B	(A4)+OIMBIP,#H'01	LOAD.B	(A4)+OIMDIR,#H'02	LOAD.W	(A4)+OIMDLX,D6	LOAD.L	D4,D6	SWAP.W	D4	LOAD.W	(A4)+OIMDLY,D4	MUL.WU	D4,D5	LOAD.L	(A4)+OIMNBB,D4	ADD.L	D4,#LGHIMA	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	WRPRINT		; crit une tranche	PUSH.W	D7	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le buffer d'impression	POP.W	D7EXIT$:	POPM.L	D1..D6,A0,A2,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; GETPRIDIP >;==========/; Donne les dimensions et les marges de la prsentations.; in	-; out	D4.L	dimensions de la feuille    [obj];	D3.L	marges (suprieure;gauche)  [obj];	D2.L	marges (infrieure;droite)  [obj];	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.WGETPRIDIP:	PUSHM.L	D1,A4	PUSH.B	(A6)+OIFPRI	SET.B	(A6)+OIFPRI	; impression en cours	CALL	GETRESOL	; D3 <-- facteurs d'chelle (P2;P1)	JUMP,NE EXIT$	LOAD.W	(A6)+OSCAP1X,D3	LOAD.W	(A6)+OSCAP1Y,D3	SWAP.W	D3	LOAD.W	(A6)+OSCAP2X,D3	LOAD.W	(A6)+OSCAP2Y,D3	LOAD.L	A4,#(A6)+OVPSTA	; A4 <-- ^buffer	LOAD.W	D4,(A4)+OPRMGI	ADD.W	D4,(A4)+OPRITL	; hlas ncessaire !	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- marge infrieure (pp)	LOAD.W	D1,(A4)+OPRMGD	MUL.WU	D1,#8	DIV.WU	D1,(A4)+OPRGLX	LOAD.W	D4,D1		; D4 <-- marge droite (pp)	CALL	SCALEN		; D4 <-- marges [obj]	LOAD.L	D2,D4	LOAD.W	D4,(A4)+OPRMGS	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- marge suprieure (pp)	LOAD.W	D1,(A4)+OPRMGG	MUL.WU	D1,#8	DIV.WU	D1,(A4)+OPRGLX	LOAD.W	D4,D1		; D4 <-- marge gauche (pp)	CALL	SCALEN		; D4 <-- marges [obj]	LOAD.L	D3,D4	LOAD.W	D4,(A4)+OPRHTP	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- hauteur (pp)	LOAD.W	D1,(A4)+OPRLGPH	MUL.WU	D1,#8	DIV.WU	D1,(A4)+OPRGLX	LOAD.W	D4,D1		; D4 <-- largeur (pp)	CALL	SCALEN		; D4 <-- dimensions page [obj]	CLR.W	D7		; D7 <-- okEXIT$:	POP.B	(A6)+OIFPRI	POPM.L	D1,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; GETPRIDIM >;==========/; Donne les dimensions et les marges minimales (hard) de la feuille.; in	-; out	D4.L	dimensions de la feuille    [obj];	D3.L	marges (suprieure;gauche)  [obj];	D2.L	marges (infrieure;droite)  [obj];	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.WGETPRIDIM:	PUSHM.L	D1,A4	PUSH.B	(A6)+OIFPRI	SET.B	(A6)+OIFPRI	; impression en cours	CALL	GETRESOL	; D3 <-- facteurs d'chelle (P2;P1)	JUMP,NE EXIT$	LOAD.W	(A6)+OSCAP1X,D3	LOAD.W	(A6)+OSCAP1Y,D3	SWAP.W	D3	LOAD.W	(A6)+OSCAP2X,D3	LOAD.W	(A6)+OSCAP2Y,D3	LOAD.L	A4,#(A6)+OVPSTA	; A4 <-- ^buffer	LOAD.W	D4,(A4)+OPRMGIH	ADD.W	D4,(A4)+OPRITL	; hlas ncessaire !	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- marge infrieure (pp)	LOAD.W	D1,(A4)+OPRMGDH	MUL.WU	D1,#8	DIV.WU	D1,(A4)+OPRGLX	LOAD.W	D4,D1		; D4 <-- marge droite (pp)	CALL	SCALEN		; D4 <-- marges [obj]	LOAD.L	D2,D4	LOAD.W	D4,(A4)+OPRMGSH	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- marge suprieure (pp)	LOAD.W	D1,(A4)+OPRMGGH	MUL.WU	D1,#8	DIV.WU	D1,(A4)+OPRGLX	LOAD.W	D4,D1		; D4 <-- marge gauche (pp)	CALL	SCALEN		; D4 <-- marges [obj]	LOAD.L	D3,D4	LOAD.W	D4,(A4)+OPRHTP	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- hauteur (pp)	LOAD.W	D1,(A4)+OPRLGPH	MUL.WU	D1,#8	DIV.WU	D1,(A4)+OPRGLX	LOAD.W	D4,D1		; D4 <-- largeur (pp)	CALL	SCALEN		; D4 <-- dimensions page [obj]	CLR.W	D7		; D7 <-- okEXIT$:	POP.B	(A6)+OIFPRI	POPM.L	D1,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; GETRESOL >;=========/; Lit le status de l'imprimante.;	       Xpt * 1600;	Xpp = ------------;	       UMX * GLX;	;	P1 = 1600 /8;	P2 = (UMX * GLX) /8; in	-; out	D3.L	facteurs d'chelle (P2;P1);	D7.W	erreur; mod	D3.L, D7.WGETRESOL:	PUSHM.L	D4,A2..A4	LOAD.L	A2,(A6)+OCAPRINT	LOAD.L	D4,#LGPRI1	; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OVPSTA	; A4 <-- ^buffer	PRINTA_	RSTATUS		; OPRSTA <-- status de l'imprimante	JUMP',NE EXIT$	LOAD.W	D3,(A4)+OPRUMX+2	MUL.WU	D3,(A4)+OPRGLX	; D3 <-- P2	DIV.WU	D3,#8	SWAP.W	D3	LOAD.W	D3,#1600/8	; D3 <-- P1	TEST.W	(A6)+OPRSC1	JUMP',LE EXIT$	TEST.W	(A6)+OPRSC2	JUMP',LE EXIT$	LOAD.W	D4,D3	MUL.WU	D4,(A6)+OPRSC2	DIV.WU	D4,(A6)+OPRSC1	; D3 <-- P1 selon un v. changement d'chelle	LOAD.W	D3,D4EXIT$:	POPM.L	D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; GETPRINT >;=========/; Donne le mode d'impression.; in	-; out	D4.L	mode d'impression (BPRIxxx); mod	D4.L, D7.WGETPRINT:	CLR.L	D4		; D4 <-- mode normal	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP',F EXIT$		; non => EXIT$	LOAD.L	D4,(A6)+OPRINT	; D4 <-- mode d'impressionEXIT$:	RET;--------\\; PRINTPS >;========/; Impression PostScript.; in	-; out	D7.W	erreur; mod	D7.WPRINTPS:	PUSHM.L	D1,D3,D4,D6,A2..A4	CALL	WAITMOUSE	; souris: met le sablier	SET.B	(A6)+OIFPPS	; dbut impression PostScript	LOAD.L	A3,#R16"NMPAGEPS	LOAD.W	D3,#PPS_FIRST	LIB_	OPEN	JUMP,NE EXIT9$	LOAD.W	(A6)+OCHPAGEPS,D1	LOAD.L	D4,(A6)+ODESYD	PPS_	OPEN		; A2 <-- "canal"	JUMP,NE EXIT8$	LOAD.L	(A6)+OCAPAGEPS,A2	LOAD.L	D6,(A6)+ODFACH	; D6 <-- canal	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE DEND$DLOOP$:	PUSH.L	A4	LOAD.W	D4,(A4)+OobjIDENT ; D4 <-- identificateur	LOAD.L	A4,(A4)+OobjPDATA ; A4 <-- ^data de l'objet;	LOAD.L	A2,(A6)+OCAPAGEPS	PPS_	INITDEF		; donne un objet de dfinition	POPM.L	A4	JUMP',NE EXIT7$	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ DLOOP$DEND$:	CLR.L	(A6)+ODESY1	LOAD.L	(A6)+ODESY2,(A6)+ODESYD	CLR.L	(A6)+OWDOY1	LOAD.L	(A6)+OWDOY2,(A6)+ODESYD	CLR.L	(A6)+OWDIY1	LOAD.L	(A6)+OWDIY2,(A6)+ODESYD	CALL	DESOBJETS	; dessine tous les objetsEXIT7$:	PUSH.W	D7;	LOAD.L	A2,(A6)+OCAPAGEPS	PPS_	CLOSE	POP.W	D7EXIT8$:	PUSH.W	D7	LOAD.W	D1,(A6)+OCHPAGEPS	LIB_	CLOSE	POP.W	D7EXIT9$:	CLR.B	(A6)+OIFPPS	; fin impression PostScript	CALL	NORMMOUSE	; souris: enlve le sablier	POPM.L	D1,D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETNMPAGEPS:	.ASCIZ	"PAGEPS"		.EVEN	.END