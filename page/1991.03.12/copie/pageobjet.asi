	.SBTTL	PAGEOBJET.ASI;---------\\; OBJGETID >;=========/; Cherche l'identificateur d'un objet ditable (TYPOBEDIT); en fonction de son rang.; in	D0.W	rang de l'icne; out	D0.W	identificateur;	D7.W	erreur; mod	D0.L, D7.WOBJGETID:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OTAMO	LOAD.W	D4,D0	CLR.W	D0	CLR.W	D7		; D7 <-- okLOOP$:	TEST.L	(A4)+OMOCOD	; objet en fonction ?	JUMP',EQ NEXT$		; non => NEXT$	COMP.W	(A4)+OMOTYP,#TYPOBEDIT	JUMP',NE NEXT$	DEC.W	D4	JUMP',NS EXIT$NEXT$:	ADD.L	A4,#LMO		; A4 <-- ^suivant dans OTAMO	INC.W	D0		; D0 <-- identificateur suivant	COMP.W	D0,#MAXMO	JUMP,LO LOOP$	LOAD.W	D7,#ERPOBPC	; D7 <-- objet pas connectEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DFSEARCH >;=========/; Cherche un objet de dfinition.; in	D4.W	identificateur; out	A4.L	^objet;	D7.W	erreur; mod	D7.W, A4.LDFSEARCH:	PUSH.L	D6	PUSH.L	(A6)+OAPOS	LOAD.L	D6,(A6)+ODFACH	; D6 <-- canal	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	COMP.W	D4,(A4)+OobjIDENT	JUMP',EQ EXIT$	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POP.L	(A6)+OAPOS	POP.L	D6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DFGETULIST >;===========/; Donne la liste des tats d'utilisation; in	D3.W	identificateur;	A4.L	^buffer pour tats (0=pas utilis);	D4.W	lg buffer; out	-; mod	D7.WDFGETULIST:	PUSHM.L	D0..D6,A2..A4	PUSH.L	(A6)+OAPOS	CONV.LA.WA D4	GESMEM	?CLEARMEM	; rempli le buffer de zro	LOAD.L	A3,A4		; A3 <-- ^buffer	LOAD.W	D5,D4		; D5 <-- lg buffer	CLR.W	D2		; D2 <-- premier calqueCLOOP$:	PUSH.W	(A6)+OCALACT	LOAD.W	(A6)+OCALACT,D2	CALL	GETACH		; D6 <-- canal de l'arbre des objets	POP.W	(A6)+OCALACT	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE CNEXT$OLOOP$:	LOAD.W	D0,(A4)+OobjIDENT	LOAD.W	D1,#opGETDEF	CALL	OBJCALLD	; D4 <-- tat utilis	JUMP',EQ ONE$	COMP.W	D7,#ERPLDEF	; utilise opGETLDEF ?	JUMP',NE ONEXT$		; non => ONEXT$;	LOAD.W	D0,(A4)+OobjIDENT	LOAD.W	D1,#opGETLDEF	LOAD.L	A2,#(A6)+OBUDIS	; A2 <-- ^buffer	LOAD.W	D2,#LBUDIS	; D2 <-- lg max buffer	CALL	OBJCALLD	; A2 <-- ^tats utiliss	JUMP',NE ONEXT$LIST$:	LOAD.W	D4,(A2+)	JUMP',NS ONEXT$	COMP.W	D4,D5	JUMP,HS LIST$	SET.B	(A3)+(D4.W)	; buffer <-- indique l'utilisation	JUMP	LIST$ONE$:	COMP.W	D4,D5	JUMP',HS ONEXT$	SET.B	(A3)+(D4.W)	; buffer <-- indique l'utilisationONEXT$:	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ OLOOP$CNEXT$:	INC.W	D2	COMP.W	D2,#MAXCALQUE	JUMP,LO CLOOP$	POP.L	(A6)+OAPOS	POPM.L	D0..D6,A2..A4	RET;-----------\\; OBJCONNECT >;===========/; Met en fonction tous les modules-objets (*.OPAGE) donns dans une liste.; in	A3.L	^noms des objets; out	D7.W	erreur; mod	D7.WOBJCONNECT:	PUSHM.L	D0..D4,D6,A0..A5	LOAD.L	A5,A3		; A5 <-- ^liste des noms d'objets; Libre tous les objets inutiles, c'est--dire qui ne sont pas; donns dans la liste des noms.	LOAD.L	A2,#(A6)+OTAMO	CLR.W	D0FLOOP$:	TEST.L	(A2)+OMOCOD	; objet en fonction ?	JUMP',EQ FNEXT$		; non => FNEXT$	COMP.W	(A2)+OMOTYP,#TYPOBEDIT ; objet ditable ?	JUMP',NE FNEXT$		; non => FNEXT$	LOAD.W	D1,#opGETNAME	CALL	OBJCALL		; A3 <-- ^nom du fichier	ADD.L	A3,#4		; A3 <-- saute "GRA_"	LOAD.L	A4,A5		; A4 <-- ^liste des noms d'objetsFCOMP$:	TEST.B	(A4)	JUMP',EQ FFREE$	CALL	OBJCPNAME	; objet donn dans la liste ?	JUMP',EQ FNEXT$		; oui => FNEXT$FNAME$:	TEST.B	(A4+)		; A4 <-- ^nom suivant	JUMP,NE FNAME$	JUMP	FCOMP$FFREE$:	LOAD.L	A0,(A2)+OMOCH	; A0  <-- canal	LOAD.W	D1,#opCLOSE	CALL	OBJCALL		; ferme les variables globales	LOAD.W	D1,#opGETNAME	CALL	OBJCALL		; A3 <-- ^nom du fichier	FOS	?CUNLOAD	; libre le module	CLR.L	(A2)+OMOCOD	CLR.L	(A2)+OMOCHFNEXT$:	ADD.L	A2,#LMO		; A2 <-- ^suivant dans OTAMO	INC.W	D0		; D0 <-- identificateur suivant	COMP.W	D0,#MAXMO	JUMP,LO FLOOP$; Connecte tous les objets donns dans la liste qui ne le sont pas encore.CLOOP$:	TEST.B	(A5)		; encore un objet  connecter ?	JUMP,EQ LIB$		; non => LIB$	LOAD.L	A3,A5	LOAD.W	D3,#TYPOBEDIT	CALL	OBJIFCON	; objet dj connect ?	JUMP,EQ CNEXT$		; oui => CNEXT$	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	A2,#R16"PREF$CPREF$:	LOAD.B	(A4+),(A2+)	; OBUDIS <-- "GRA_"	JUMP,NE CPREF$	DEC.L	A4CNAME$:	LOAD.B	(A4+),(A3+)	; OBUDIS <-- nom	JUMP,NE CNAME$	DEC.L	A4	LOAD.L	A2,#R16"POST$CPOST$:	LOAD.B	(A4+),(A2+)	; OBUDIS <-- ".OPAGE"	JUMP,NE CPOST$	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^nom	CALL	OBJCONONE	; connecte l'objet	JUMP',NE CNEXT$	LOAD.W	D1,#opGETNAMEDEF	CALL	OBJCALL		; A3 <-- ^noms des fichiers de dfinition	JUMP',NE CNEXT$CDLOOP$:	TEST.B	(A3)	JUMP',EQ CNEXT$	ADD.L	A3,#4		; A4 <-- saute "DEF_"	LOAD.W	D3,#TYPOBDEF	CALL	OBJIFCON	; objet dj connect ?	JUMP',EQ CDNEXT$	; oui => CDNEXT$	SUB.L	A3,#4		; A4 <-- ^sur "DEF_"	CALL	OBJCONONE	; connecte l'objet de dfinitionCDNEXT$:	TEST.B	(A3+)	JUMP,NE CDNEXT$	JUMP	CDLOOP$CNEXT$:	TEST.B	(A5+)		; A5 <-- ^nom suivant	JUMP,NE CNEXT$	JUMP	CLOOP$LIB$:	CALL	OBJLIBDEF	; libre les objets de dfinition inutiles	POPM.L	D0..D4,D6,A0..A5	CLR.W	D7		; retour EQ	RETPREF$:	.ASCIZ	"GRA_"POST$:	.ASCIZ	".OPAGE"	.EVEN;----------\\; OBJCONONE >;----------/; Connecte un objet d'aprs son nom.; in	A3.L	^nom; out	D0.W	identificateur;	D7.W	erreur; mod	D0.L, D7.WOBJCONONE:	PUSHM.L	D1..D4,D6,A0..A4	LOAD.L	D3,#2^BEXNHEAD	; D3 <-- pas d'en-tte	FOS	?CLOAD		; charge le module de gestion d'objet	JUMP,NE EXIT$	COMP.W	(A4)+opIDENT,#H'ABCD ; identificateur correct ?	JUMP,NE ERROR$		; non => ERROR$	LOAD.L	A1,A4	CLR.L	D3	LOAD.W	D3,(A4)+opGETIDENT	ADD.L	A1,D3	CALL	(A1)		; D4 <-- identificateur (*)	COMP.W	D4,#MAXMO	JUMP,HS ERROR$	LOAD.W	D0,D4		; D0 <-- identificateur	LOAD.L	A2,#(A6)+OTAMO	MUL.WU	D4,#LMO	ADD.L	A2,D4		; A2 <-- ^dans OTAMO	TEST.L	(A2)+OMOCOD	; y'a-t-il dj un objet avec cet identificateur ?	JUMP,NE ERROR$		; oui => ERROR$	LOAD.L	(A2)+OMOCOD,A4	; OMOCOD <-- ^module	LOAD.L	A1,A4	CLR.L	D3	LOAD.W	D3,(A4)+opOPEN	ADD.L	A1,D3	CALL	(A1)		; A0 <-- canal (*)	JUMP',NE ERROR$	LOAD.L	(A2)+OMOCH,A0	; OMOCH  <-- canal	LOAD.L	A1,A4	CLR.L	D3	LOAD.W	D3,(A4)+opGETTYPE	ADD.L	A1,D3	CALL	(A1)		; D4 <-- type (*)	JUMP',NE ERROR$	LOAD.W	(A2)+OMOTYP,D4	; OMOTYP <-- type	COMP.W	D4,#TYPOBDEF	; objet de dfinition ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.W	D1,#opCRGETLG	CALL	OBJCALL		; D4 <-- longueur ncessaire	JUMP',NE ERROR$	PUSH.L	A3	LOAD.L	A3,#0	LOAD.L	A4,#0	LOAD.L	D6,(A6)+ODFACH	; D6 <-- canal	CALL	LSTA_INSERT	; A4 <-- ^objet  la tte	POPM.L	A3	JUMP',NE ERROR$	LOAD.W	(A4)+OobjIDENT,D0	LOAD.W	D1,#opCRINIT	CALL	OBJCALLD	; initialise l'objet	JUMP',NE ERROR$	LOAD.W	D1,#opDPUTDEF	CALL	OBJCALLD	; donne l'objet par dfaut	JUMP',EQ EXIT$ERROR$:	CLR.L	(A2)+OMOCOD	CLR.L	(A2)+OMOCH	PUSH.W	D7	FOS	?CUNLOAD	; dcharge le module incorrect	POP.W	D7EXIT$:	POPM.L	D1..D4,D6,A0..A4	TEST.W	D7		; retour EQ/NE	RET; (*)	N'utilise pas OBJCALL, car le module n'est pas;	encore charg !;---------\\; OBJIFCON >;=========/; Regarde si un objet est connect.; in	A3.L	^nom cherch;	D3.W	type (TYPOBEDIT/DEF); out	D0.W	identificateur;	D7.W	erreur; mod	D0.L, D7.WOBJIFCON:	PUSHM.L	D1,A2..A4	LOAD.L	A4,A3	LOAD.L	A2,#(A6)+OTAMO	CLR.W	D0LOOP$:	TEST.L	(A2)+OMOCOD	; objet en fonction ?	JUMP',EQ NEXT$		; non => NEXT$	COMP.W	D3,(A2)+OMOTYP	; objet du bon type ?	JUMP',NE NEXT$		; non => NEXT$	LOAD.W	D1,#opGETNAME	CALL	OBJCALL		; A3 <-- ^nom du fichier	ADD.L	A3,#4		; A3 <-- saute "GRA_" ou "DEF_"	CALL	OBJCPNAME	; nom trouv ?	JUMP',EQ EXIT$NEXT$:	ADD.L	A2,#LMO		; A2 <-- ^suivant dans OTAMO	INC.W	D0		; D0 <-- identificateur suivant	COMP.W	D0,#MAXMO	JUMP,LO LOOP$	LOAD.W	D7,#ERPOBPC	; D7 <-- objet pas connectEXIT$:	POPM.L	D1,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; OBJLIBDEF >;----------/; Libre les objets de dfinition qui ne sont plus utiliss.; in	-; out	-; mod	D7.WOBJLIBDEF:	PUSHM.L	D0,D1,D4,D6,A0,A2..A4	LOAD.L	A2,#(A6)+OTAMO	CLR.W	D0LOOP$:	TEST.L	(A2)+OMOCOD	; objet en fonction ?	JUMP',EQ NEXT$		; non => NEXT$	COMP.W	(A2)+OMOTYP,#TYPOBDEF ; objet de dfinition ?	JUMP',NE NEXT$		; non => NEXT$	LOAD.W	D1,#opGETNAME	CALL	OBJCALL		; A3 <-- ^nom du fichier	LOAD.L	A4,#(A3)+4	; A4 <-- saute "DEF_"	CALL	OBJLIBDEFONE	; objet utilis ?	JUMP',EQ NEXT$		; oui => NEXT$	LOAD.W	D4,D0	CALL	DFSEARCH	; A4 <-- ^objet	JUMP',NE NEXT$	LOAD.W	D1,#opCRCLOSE	CALL	OBJCALLD	; ferme l'objet	LOAD.L	D6,(A6)+ODFACH	; D6 <-- canal	CALL	LSTA_REMOVE	; supprime l'objet dans la liste	LOAD.L	A0,(A2)+OMOCH	; A0  <-- canal	LOAD.W	D1,#opCLOSE	CALL	OBJCALL		; ferme les variables globales	LOAD.W	D1,#opGETNAME	CALL	OBJCALL		; A3 <-- ^nom du fichier	FOS	?CUNLOAD	; libre le module	CLR.L	(A2)+OMOCOD	CLR.L	(A2)+OMOCHNEXT$:	ADD.L	A2,#LMO		; A2 <-- ^suivant dans OTAMO	INC.W	D0		; D0 <-- identificateur suivant	COMP.W	D0,#MAXMO	JUMP,LO LOOP$	POPM.L	D0,D1,D4,D6,A0,A2..A4	RET;-------------\\; OBJLIBDEFONE >;-------------/; Regarde si un objet de dfinition est utilis.; in	A4.L	^nom de l'objet de dfinition; out	D7.W	erreur (si pas utilis); mod	D7.WOBJLIBDEFONE:	PUSHM.L	D0,D1,A2,A3	LOAD.L	A2,#(A6)+OTAMO	CLR.W	D0LOOP$:	TEST.L	(A2)+OMOCOD	; objet en fonction ?	JUMP',EQ NEXT$		; non => NEXT$	COMP.W	(A2)+OMOTYP,#TYPOBEDIT ; objet ditable ?	JUMP',NE NEXT$		; non => NEXT$	LOAD.W	D1,#opGETNAMEDEF	CALL	OBJCALL		; A3 <-- ^noms des fichiers de dfinition	JUMP',NE NEXT$NAME$:	TEST.B	(A3)		; encore un nom ?	JUMP',EQ NEXT$		; non => NEXT$	ADD.L	A3,#4		; A3 <-- saute "DEF_"	CALL	OBJCPNAME	JUMP',EQ EXIT$SKIP$:	TEST.B	(A3+)		; A3 <-- ^nom suivant	JUMP,NE SKIP$	JUMP	NAME$NEXT$:	ADD.L	A2,#LMO		; A2 <-- ^suivant dans OTAMO	INC.W	D0		; D0 <-- identificateur suivant	COMP.W	D0,#MAXMO	JUMP,LO LOOP$	LOAD.W	D7,#ERPOBPC	; D7 <-- objet pas connectEXIT$:	POPM.L	D0,D1,A2,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; OBJCPNAME >;----------/; Compare deux noms d'objets.; in	A3.L	^nom;	A4.L	^nom; out	D7.W	erreur; mod	D7.WOBJCPNAME:	PUSH.L	A2	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	POP.L	A2	TEST.W	D7		; retour EQ/NE	RETTERM$:	.B	0,SPACE,'.,-1	.EVEN;-------------\\; OBJDECONNECT >;=============/; Libre tous les modules-objets en fonction.; in	-; out	-; mod	D7.WOBJDECONNECT:	PUSHM.L	D0,D1,A0,A3,A4	LOAD.L	A4,#(A6)+OTAMO	CLR.W	D0LOOP$:	TEST.L	(A4)+OMOCOD	; objet en fonction ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	A0,(A4)+OMOCH	; A0  <-- canal	LOAD.W	D1,#opCLOSE	CALL	OBJCALL		; ferme les variables globales	LOAD.W	D1,#opGETNAME	CALL	OBJCALL		; A3 <-- ^nom du fichier	FOS	?CUNLOAD	; libre le module	CLR.L	(A4)+OMOCOD	CLR.L	(A4)+OMOCHNEXT$:	ADD.L	A4,#LMO		; A4 <-- ^suivant dans OTAMO	INC.W	D0		; D0 <-- identificateur suivant	COMP.W	D0,#MAXMO	JUMP,LO LOOP$	POPM.L	D0,D1,A0,A3,A4	RET;----------\\; OBJCALLDF >;==========/; Appel identique  OBJCALLD, mais appelle galement tous les fils.; in	D1.W	mthode;	A4.L	^racine de l'objet;	+	selon mthode; out	+	selon mthode;	D7.W	erreur; mod	D7.W, +OBJCALLDF:	PUSH.L	A4	SUB.L	SP,#2		; SP <-- ^variables sur le stack	LOAD.W	(SP),(A4)+OobjNB	CALL	LSTA_POS	; met  jour OAPOSLOOP$:	CALL	OBJCALLD	; appel la mthode de l'objet	JUMP',NE EXIT$	DEC.W	(SP)		; encore un fils ?	JUMP',NS EXIT$		; non => EXIT$	CALL	LSTA_NEXT	; A4 <-- ^fils suivant	JUMP,EQ LOOP$EXIT$:	ADD.L	SP,#2		; SP <-- ajuste le stack	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; OBJCALLD >;=========/; Appel identique  OBJCALL, mais pour une mthode utilisant; le pointeur  l'objet.; in	D1.W	mthode;	A4.L	^racine de l'objet;	+	selon mthode; out	+	selon mthode;	D7.W	erreur; mod	D7.W, +OBJCALLD:	PUSHM.L	D0,D1,A0,A1,A4	LOAD.W	D0,(A4)+OobjIDENT ; D0 <-- identificateur	LOAD.L	A4,(A4)+OobjPDATA ; A4 <-- ^data de l'objet	LOAD.L	A1,#(A6)+OTAMO	MUL.WU	D0,#LMO	ADD.L	A1,D0		; A1 <-- ^dans OTAMO	LOAD.L	A0,(A1)+OMOCH	; A0 <-- canal	LOAD.L	A1,(A1)+OMOCOD	; A1 <-- ^module	LOAD.L	D0,A1		; module charg ?	JUMP',EQ ERROR$		; non => ERROR$	COMP.W	D1,(A1)+opNBCALL ; mthode existe ?	JUMP',HS ERROR$		; non => ERROR$	CLR.L	D0	LOAD.W	D0,(A1)+(D1.W)	; D0 <-- ^relatif	JUMP',EQ ERROR$	ADD.L	A1,D0		; A1 <-- ^absolu	CALL	(A1)		; appel la mthode	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#ERPMDNE	; D7 <-- mthode n'existe pasEXIT$:	POPM.L	D0,D1,A0,A1,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; OBJCALL >;========/; Appelle une mthode d'un module-objet.; Une erreur est rendue si la mthode n'existe pas,; ou si le module-objet n'est pas connect.; in	D0.W	identificateur du module-objet;	D1.W	mthode;	+	selon mthode; out	+	selon mthode;	D7.W	erreur; mod	D7.W, +OBJCALL:	PUSHM.L	D0,D1,A0,A1	LOAD.L	A1,#(A6)+OTAMO	MUL.WU	D0,#LMO	ADD.L	A1,D0		; A1 <-- ^dans OTAMO	LOAD.L	A0,(A1)+OMOCH	; A0 <-- canal	LOAD.L	A1,(A1)+OMOCOD	; A1 <-- ^module	LOAD.L	D0,A1		; module charg ?	JUMP',EQ ERROR$		; non => ERROR$	COMP.W	D1,(A1)+opNBCALL ; mthode existe ?	JUMP',HS ERROR$		; non => ERROR$	CLR.L	D0	LOAD.W	D0,(A1)+(D1.W)	; D0 <-- ^relatif	JUMP',EQ ERROR$	ADD.L	A1,D0		; A1 <-- ^absolu	CALL	(A1)		; appel la mthode	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#ERPMDNE	; D7 <-- mthode n'existe pasEXIT$:	POPM.L	D0,D1,A0,A1	TEST.W	D7		; retour EQ/NE	RET	.END