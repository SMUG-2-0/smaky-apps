	.TITLE	PAGEPS.ASL;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du module SMA_PAGEPS.LIB;	Date		Amliorations; ---------------------------------------------------------------------------------------; 1.0	04.04.90	premire version pour MW	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal	.REF	SMAKY	.REF	MODULES	.REF	PAGE	.REF	PAGEPS; Constantes; ----------PAGEREV	=	1		; rvisionPAGEVERS=	0		; version	.REV	PAGEREV,PAGEVERS; Variable; --------	.LOC	0ODIMY:	.BLKB	2		; hauteur d'une pageODIMX:	.BLKB	2		; largeurd'une pageLGVAR:	.LOC	0DEBUT:; En-tte du module LIB; ---------------------	.LOC	0	PPS_	FIRST		; code du premier appel	PPS_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	PAGEREV,PAGEVERS ; rvision.version	.W	0,END_PAGEPS	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"PAGEPS"	; nom du module	.FILLB	(LGHLIB-.),0	.W	_PPS_OPEN	.W	_PPS_CLOSE	.W	_PPS_INITDEF	.W	_PPS_DRLINE	.W	_PPS_DRBEZIER	.W	_PPS_DRPOLYOPEN	.W	_PPS_DRPOLYLINE	.W	_PPS_DRPOLYBEZIER	.W	_PPS_DRPOLYCLOSE	.W	_PPS_DRCHAR;----------\\; _PPS_OPEN >;==========/; Dbut d'une impression PostScript.; in	D4.L	dimensions d'une page (dy;dx); out	A2.L	"canal";	D7.W	erreur; mod	D7.W, A2.L_PPS_OPEN:	PUSHM.L	D1,D3,D4,A4,A6.W H'A042.ASCIZE "PS_OPEN "	LOAD.L	D3,D4	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP',NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+ODIMY,D3	; ODIMY <-- dimensions d'une page	LOAD.L	A2,A6		; A2 <-- "canal"EXIT$:	POPM.L	D1,D3,D4,A4,A6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; _PPS_CLOSE >;===========/; Fin d'une impression PostScript.; in	A2.L	"canal"; out	D7.W	erreur; mod	D7.W_PPS_CLOSE:	PUSHM.L	D1,A4.W H'A042.ASCIZE "PS_CLOSE "	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire pour variablesEXIT$:	POPM.L	D1,A4	CLR.W	D7		; retour EQ	RET;-------------\\; _PPS_INITDEF >;=============/; Initialisation selon un objet de dfinition.; in	A2.L	"canal";	A4.L	^data de l'objet de dfinition;	D4.W	identificateur (IDENT*); out	D7.W	erreur; mod	D7.W_PPS_INITDEF:	PUSHM.L	A6.W H'A042.ASCIZE "PS_INITDEF "	LOAD.L	A6,A2		; A6 <-- ^variables	COMP.W	D4,#IDENTCHAR	JUMP,EQ CHAR$	COMP.W	D4,#IDENTPEN	JUMP,EQ PEN$	COMP.W	D4,#IDENTTRAME	JUMP,EQ TRAME$	CLR.W	D7	JUMP	EXIT$CHAR$:PEN$:TRAME$:EXIT$:	POPM.L	A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; _PPS_DRLINE >;============/; Impression d'une ligne droite.; in	A2.L	"canal";	D3.L	dpart (y;x);	D4.L	arrive (y;x);	D2.W	mode de dessin;	D1.W	numro du pinceau (0..39); out	D7.W	erreur; mod	D7.W_PPS_DRLINE:	PUSHM.L	D4,A6.W H'A042.ASCIZE "PS_LINE "LOAD.W D4,D1.W H'A036,H'A024	LOAD.L	A6,A2		; A6 <-- ^variablesEXIT$:	POPM.L	D4,A6	TEST.W	D7		; retour EQ/NE	RET;--------------\\; _PPS_DRBEZIER >;==============/; Impression d'une courbe de Bzier.; in	A2.L	"canal";	D3.L	P1 (y;x);	D4.L	C1 (y;x);	D5.L	C2 (y;x);	D6.L	P2 (y;x);	D2.W	mode de dessin;	D1.W	numro du pinceau (0..39); out	D7.W	erreur; mod	D7.W_PPS_DRBEZIER:	PUSHM.L	D4,A6.W H'A042.ASCIZE "PS_BEZIER "LOAD.W D4,D1.W H'A036,H'A024	LOAD.L	A6,A2		; A6 <-- ^variablesEXIT$:	POPM.L	D4,A6	TEST.W	D7		; retour EQ/NE	RET;----------------\\; _PPS_DRPOLYOPEN >;================/; Dbut de dfinition d'un polygone rempli.; in	A2.L	"canal"; out	D7.W	erreur; mod	D7.W_PPS_DRPOLYOPEN:	PUSHM.L	A6.W H'A042.ASCIZE "PS_POLYOPEN "	LOAD.L	A6,A2		; A6 <-- ^variablesEXIT$:	POPM.L	A6	TEST.W	D7		; retour EQ/NE	RET;----------------\\; _PPS_DRPOLYLINE >;================/; Dfinition d'une droite supplmentaire pour un polygone rempli.; in	A2.L	"canal";	D3.L	dpart (y;x);	D4.L	arrive (y;x); out	D7.W	erreur; mod	D7.W_PPS_DRPOLYLINE:	PUSHM.L	A6.W H'A042.ASCIZE "PS_POLYLINE "	LOAD.L	A6,A2		; A6 <-- ^variablesEXIT$:	POPM.L	A6	TEST.W	D7		; retour EQ/NE	RET;------------------\\; _PPS_DRPOLYBEZIER >;==================/; Dfinition d'une courbe de Bzier supplmentaire pour un polygone rempli.; in	A2.L	"canal";	D3.L	P1 (y;x);	D4.L	C1 (y;x);	D5.L	C2 (y;x);	D6.L	P2 (y;x); out	D7.W	erreur; mod	D7.W_PPS_DRPOLYBEZIER:	PUSHM.L	A6.W H'A042.ASCIZE "PS_POLYBEZIER "	LOAD.L	A6,A2		; A6 <-- ^variablesEXIT$:	POPM.L	A6	TEST.W	D7		; retour EQ/NE	RET;-----------------\\; _PPS_DRPOLYCLOSE >;=================/; Impression d'un polygone rempli.; in	A2.L	"canal";	D2.L	mode de dessin;	D1.W	numro de la trame (0..39); out	D7.W	erreur; mod	D7.W_PPS_DRPOLYCLOSE:	PUSHM.L	D4,A6.W H'A042.ASCIZE "PS_POLYCLOSE "LOAD.W D4,D1.W H'A036,H'A024	LOAD.L	A6,A2		; A6 <-- ^variablesEXIT$:	POPM.L	D4,A6	TEST.W	D7		; retour EQ/NE	RET;------------\\; _PPS_DRCHAR >;============/; Impression d'un caractre.; in	A2.L	"canal";	D3.W	code du caractre (0..255);	D4.L	position du centre (y;x);	D2.L	mode de dessin;	D1.W	numro du caractre (0..15);	A4.L	^gencar bitmap (oxcbm*); out	D7.W	erreur; mod	D7.W_PPS_DRCHAR:	PUSHM.L	D4,A6.W H'A042.ASCIZE "PS_CHAR "LOAD.W D4,D1.W H'A036,H'A024	LOAD.L	A6,A2		; A6 <-- ^variablesEXIT$:	POPM.L	D4,A6	TEST.W	D7		; retour EQ/NE	RETEND_PAGEPS:	.END