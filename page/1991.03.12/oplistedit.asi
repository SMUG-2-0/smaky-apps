	.SBTTL	OPLISTEDIT.ASITXPREL:				; base pour ^relatifs;----------\\; EDITMMENU >;==========/; Agit dans le texte selon le mmenu traditionnel (ddd).; in	A1.L	^objet liste; out	D7.W	erreur; mod	D7.WEDITMMENU:	PUSHM.L	D1..D5,A2..A4	LOAD.L	A3,#R16"ITABLE$ILOOP$:	LOAD.W	D3,(A3+)	; D3 <-- code de l'icne interne	JUMP',EQ IEND$	CALL	XopGETICONE	; A4 <-- ^matrice	LOAD.W	D3,(A3+)	; D3 <-- code de l'icne PAGE	LOAD.W	D7,#DR_PUTICO	PAGE_	DRAW		; IPP21 <-- matrice de l'icne	JUMP	ILOOP$IEND$:	LOAD.L	D4,#2000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour construire mmenu	JUMP,NE CLEAR$	LOAD.L	D5,A4	LOAD.L	A3,D5		; A3 <-- ^buffer pour construire m-menu	LOAD.L	A2,D5	LOAD.L	A4,#R16"MMENU$	CALL	MENUBUF		; buffer <-- menu principal	CALL	MENUAJUST	; buffer <-- tous les sous-(sous-)menus	LOAD.L	A3,D5		; A3 <-- ^buffer avec m-menu	LOAD.L	A4,#(A5)+OMPATX	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	LOAD.L	(A4)+(LMM*1)+OMMINA,(A5)+OMCHG	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA	LOAD.W	D1,(A5)+OAFIC1+2	COMP.W	D1,(A5)+OAFIC2+2	JUMP',EQ SERIE$	LOAD.W	D1,(A5)+OAFIC1+0	COMP.W	D1,(A5)+OAFIC2+0	JUMP',EQ SERIE$	TSET.B	(A4)+(LMM*3)+OMMINA+3:#0 ; grise la case "srie"SERIE$:	LOAD.W	D1,(A5)+OAFIC1+2	COMP.W	D1,(A5)+OAFIC2+2	JUMP',NE EGALX$	TSET.B	(A4)+(LMM*2)+OMMINA+3:#2 ; grise la case "vertical"	TSET.B	(A4)+(LMM*3)+OMMINA+3:#1 ; grise la case "galise"EGALX$:	LOAD.W	D1,(A5)+OAFIC1+0	COMP.W	D1,(A5)+OAFIC2+0	JUMP',NE EGALY$	TSET.B	(A4)+(LMM*2)+OMMINA+3:#3 ; grise la case "horizontal"	TSET.B	(A4)+(LMM*3)+OMMINA+3:#2 ; grise la case "galise"EGALY$:	LOAD.W	D7,#MI_MMENUS	PAGE_	MISC		; attend choix selon mmenus ...	PUSHM.L	D7,A4	LOAD.L	A4,D5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire pour construire mmenu	POPM.L	D7,A4	TEST.W	D7	JUMP,NE CLEAR$	LOAD.W	D2,(A4)+(LMM*0)+OMMSEL	COMP.W	D2,#1	JUMP',EQ OPER$	COMP.W	D2,#2	JUMP',EQ OPER$	COMP.W	D2,#3	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*1)+OMMSEL	COMP.W	D2,#4	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*2)+OMMSEL	COMP.W	D2,#5	JUMP',EQ OPER$	COMP.W	D2,#6	JUMP',EQ OPER$	COMP.W	D2,#7	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*3)+OMMSEL	COMP.W	D2,#8	JUMP',EQ OPER$	JUMP'	CLEAR$OPER$:	PUSHM.L	D2,D3	LOAD.L	D1,(A5)+OAFIC1	LOAD.L	D2,(A5)+OAFIC2	CALL	AFFINVCEL	; teint les cellules	COMP.W	D1,D2	JUMP',LS OPER2$	LOAD.W	D3,D1	LOAD.W	D1,D2	LOAD.W	D2,D3OPER2$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,D2	JUMP',LS OPER3$	LOAD.W	D3,D1	LOAD.W	D1,D2	LOAD.W	D2,D3OPER3$:	SWAP.W	D1	SWAP.W	D2	LOAD.L	(A5)+OAFIC1,D1	LOAD.L	(A5)+OAFIC2,D2	POPM.L	D2,D3	CALL	EDITOPMOUSE	; effectue une action dans le texte	JUMP'	EXIT$CLEAR$:	PUSH.W	D7	LOAD.L	D1,(A5)+OAFIC1	LOAD.L	D2,(A5)+OAFIC2	CALL	AFFINVCEL	; teint les cellules	POP.W	D7EXIT$:	LOAD.W	(A5)+OEDITO,#1	; affiche tout	POPM.L	D1..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RETITABLE$:	.W	ICOGENCAR,ICOUSER+0	.W	ICOJUST,ICOUSER+1	.W	ICOOPTX,ICOUSER+2	.W	ICOSERIE,ICOUSER+3	.W	ICOEGALX,ICOUSER+4	.W	ICOEGALY,ICOUSER+5	.W	ICOTRAIT,ICOUSER+6	.W	ICOTRAME,ICOUSER+7	.W	ICOTPARTOUT,ICOUSER+8	.W	ICOTVERTICAL,ICOUSER+9	.W	ICOTHORIZONTAL,ICOUSER+10	.W	ICOTCONTOUR,ICOUSER+11	.W	ICOTGAUCHE,ICOUSER+12	.W	ICOTDROITE,ICOUSER+13	.W	ICOTHAUT,ICOUSER+14	.W	ICOTBAS,ICOUSER+15	.W	0MMENU$:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOEFFACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOCOUPE&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  coupe"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOCOPIE&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  copie"	.B	-1	.BW	-2,-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+0	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  caractre"	.BW	-2,MMTRAIT$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+6	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  trait"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  trame.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+1	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  justification.."	.B	-1	.BW	-2,MMOPER$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+2	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  opration"	.B	0MMTRAIT$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+8	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  partout.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+11	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  contour.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+9	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  vertical.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+10	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  horizontal.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+12	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  gauche.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+13	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  droite.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+14	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  haut.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+15	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  bas.."	.B	0MMOPER$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+3	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  srie.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+4	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  galise les colonnes"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+5	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  galise les lignes"	.B	0	.EVEN;----------\\; MENUAJUST >;----------/; Ajuste les pointeurs relatifs du menu pre qui vient d'tre; mis dans le buffer.; in	A2.L	^dbut du menu pre;	A3.L	^buffer;	A4.L	^mmenu; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LMENUAJUST:	PUSHM.L	D3,D4,A1,A2	LOAD.L	A1,A220$:	TEST.B	(A2)		; fin du mmenu ?	JUMP,EQ EXIT$		; oui => EXIT$30$:	LOAD.B	D3,(A2+)	JUMP,EQ 20$	COMP.B	D3,#-2	JUMP,NE 30$				; ^sous-menu =>	LOAD.B	D3,(A2+)	SL.W	D3,#8	LOAD.B	D3,(A2+)	; D3 <-- ^relatif	LOAD.L	D4,A3	SUB.L	D4,A1	LOAD.B	(A2)-1,D4	RR.W	D4,#8	LOAD.B	(A2)-2,D4	; buffer <-- ^relatif au sous-menu	RR.W	D4,#8	PUSH.L	A2	PUSH.L	A3	TEST.W	D3		; .BW -2,-n  ?	JUMP',NS 50$		; oui => 50$				; non =>	CALL	MENUBUF		; buffer <-- sous-menu	JUMP'	52$50$:	CALL	MENUSPEC	; buffer <-- sous-menu52$:	POP.L	A2	CALL	MENUAJUST	; paf, rcursif !!!	POP.L	A2	JUMP	30$EXIT$:	POPM.L	D3,D4,A1,A2	RET;--------\\; MENUBUF >;--------/; Met un mmenu dans un buffer.; in	A3.L	^buffer;	A4.L	^mmenu; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LMENUBUF:	PUSH.W	D310$:	TEST.B	(A4)		; fin du mmenu ?	JUMP',EQ 80$20$:	LOAD.B	D3,(A4+)	LOAD.B	(A3+),D3	; buffer <-- .ASCIZ	JUMP,EQ 10$	COMP.B	D3,#-2	JUMP,NE	20$	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-high>	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-low>	JUMP	20$80$:	INC.L	A4	CLR.B	(A3+)		; buffer <-- terminateur	POP.W	D3	RET;---------\\; MENUSPEC >;---------/; Met un mmenu spcial dans un buffer.; in	D3.W	type du menu spcial (-);	D4.W	^relatif;	A2.L	^pour mj. ^relatif;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LMENUSPEC:	PUSHM.L	D0,D1,D3,A4	COMP.W	D3,#-1	JUMP',EQ CHAR$	JUMP'	EXIT$; Construit le sous-menu des caractres.CHAR$:	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETMENU	PAGE_	OBJCALL		; construit le mmenu	LOAD.L	(A5)+OMCHG,D3	; OMCHG <-- cases grises;	JUMP	EXIT$EXIT$:	POPM.L	D0,D1,D3,A4	RET;------------\\; EDITOPMOUSE >;============/; Effectue une opration selon le mmenu texte.; in	A1.L	^objet liste;	D2.W	opration (dtruit, dplace, etc.);	D3.W	sous-opration (selon sous-menu); out	D7.W	erreur; mod	D7.WEDITOPMOUSE:	PUSHM.L	D0..D5,A0,A2..A4	COMP.W	D2,#1	JUMP',EQ DETR$	COMP.W	D2,#2	JUMP,EQ COUPE$	COMP.W	D2,#3	JUMP,EQ COPIE$	COMP.W	D2,#4	JUMP,EQ CAR$	COMP.W	D2,#5	JUMP,EQ TRAIT$	COMP.W	D2,#6	JUMP,EQ TRAME$	COMP.W	D2,#7	JUMP,EQ JUST$	COMP.W	D2,#8	JUMP,EQ EGAL$	JUMP	EXIT$DETR$:	CALL	EDITOPKILL	; dtruit les caractres	JUMP	OK$COUPE$:	CALL	EDITOPCOPY	; bloc-notes <-- caractres	JUMP,NE EXIT$	CALL	EDITOPKILL	; dtruit les caractres	JUMP	OK$COPIE$:	CALL	EDITOPCOPY	; bloc-notes <-- caractres	JUMP	EXIT$CAR$:	LOAD.W	D4,#OCECAR	JUMP	OPER$TRAIT$:	LOAD.W	D5,D3	LOAD.L	D1,(A5)+OAFIC1	CALL	TXGETPCE	; A2 <-- ^cellule (OCE*)	JUMP,NE EXIT$	CLR.W	D2	LOAD.B	D2,(A2)+OCETRB	; D2 <-- pinceau de la premire cellule	COMP.W	D5,#7	JUMP',EQ TRDIAL$	LOAD.B	D2,(A2)+OCETRH	; D2 <-- pinceau de la premire cellule	COMP.W	D5,#6	JUMP',EQ TRDIAL$	LOAD.B	D2,(A2)+OCETRD	; D2 <-- pinceau de la premire cellule	COMP.W	D5,#5	JUMP',EQ TRDIAL$	LOAD.B	D2,(A2)+OCETRG	; D2 <-- pinceau de la premire celluleTRDIAL$:	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTPEN	LOAD.W	D1,#opDTSELECT	PAGE_	OBJCALL		; slectionne temporairement un pinceau ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$	LOAD.B	D3,D2		; D3 <-- pinceau choisi	LOAD.W	D4,D5	CALL	EDITOPTRAIT	; modifie les traits	JUMP	OK$TRAME$:	LOAD.L	D1,(A5)+OAFIC1	CALL	TXGETPCE	; A2 <-- ^cellule (OCE*)	JUMP,NE EXIT$	CLR.W	D2	LOAD.B	D2,(A2)+OCETRA	; D2 <-- trame de la premire cellule	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTTRAME	LOAD.W	D1,#opDTSELECT	PAGE_	OBJCALL		; slectionne temporairement une trame ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$	LOAD.B	D3,D2	LOAD.W	D4,#OCETRA	JUMP	OPER$JUST$:	LOAD.L	A4,A1		; A4 <-- ^objet	CALL	DBOXJUST	; choix de la justification ...	JUMP	EXIT$EGAL$:	COMP.W	D3,#1	JUMP',EQ EGALX$	COMP.W	D3,#2	JUMP',EQ EGALY$SERIE$:	LOAD.L	A4,A1		; A4 <-- ^objet	CALL	DBOXSERIE	; choix de la srie ...	CLR.W	(A5)+OTECUR	; remet le curseur au dbut	JUMP	EXIT$EGALX$:	LOAD.W	D1,(A5)+OAFIC1+2	LOAD.W	D2,(A5)+OAFIC2+2	LOAD.L	A4,(A1)+OOBPLX	CALL	DIMEGAL		; galise	JUMP	OK$EGALY$:	LOAD.W	D1,(A5)+OAFIC1+0	LOAD.W	D2,(A5)+OAFIC2+0	LOAD.L	A4,(A1)+OOBPLY	CALL	DIMEGAL		; galise	JUMP	OK$OPER$:	LOAD.L	D1,(A5)+OAFIC1OPERY$:	LOAD.W	D1,(A5)+OAFIC1+2OPERX$:	CALL	TXGETPCE	; A2 <-- ^cellule (OCE*)	JUMP',NE OPERN$	LOAD.B	(A2)+(D4.W),D3OPERN$:	INC.W	D1	COMP.W	D1,(A5)+OAFIC2+2	JUMP,LS OPERX$	SWAP.W	D1	INC.W	D1	LOAD.W	D2,D1	SWAP.W	D1	COMP.W	D2,(A5)+OAFIC2+0	JUMP,LS OPERY$;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D5,A0,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; EDITOPKILL >;===========/; Dtruit toutes les cellules slectionnes.; in	A1.L	^objet liste; out	-; mod	D7.WEDITOPKILL:	PUSHM.L	D1,D2,A2	PUSH.L	(A5)+OTEPCE	LOAD.L	D1,(A5)+OAFIC1LOOPY$:	LOAD.W	D1,(A5)+OAFIC1+2LOOPX$:	CALL	TXGETPCE	; A2 <-- ^cellule (OCE*)	JUMP',NE NEXT$	LOAD.L	(A5)+OTEPCE,A2	CALL	TXFLUSH		; efface la celluleNEXT$:	INC.W	D1	COMP.W	D1,(A5)+OAFIC2+2	JUMP,LS LOOPX$	SWAP.W	D1	INC.W	D1	LOAD.W	D2,D1	SWAP.W	D1	COMP.W	D2,(A5)+OAFIC2+0	JUMP,LS LOOPY$	POP.L	(A5)+OTEPCE	POPM.L	D1,D2,A2	RET;-----------\\; EDITOPCOPY >;-----------/; Copie dans le bloc-notes tous les caractres de la zone.; in	A1.L	^objet liste; out	D7.W	erreur; mod	D7.WEDITOPCOPY:	PUSHM.L	D1..D4,A2..A4	PUSH.L	(A5)+OTEPCE	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	A3,#R16"NAME$	LOAD.L	D3,#BNTTEXT	; D3 <-- type "TEXT"	LOAD.L	D4,#1000	; D4 <-- nb de caractres (!)	BLOC_	WROPEN		; ouvre le bloc-notes	JUMP,NE EXIT$	LOAD.L	D1,(A5)+OAFIC1LOOPY$:	LOAD.W	D1,(A5)+OAFIC1+2LOOPX$:	CALL	TXGETPCE	; A2 <-- ^cellule (OCE*)	JUMP',NE NEXTX$	LOAD.L	(A5)+OTEPCE,A2	CALL	EDITOPCOPYCEL	; bloc-notes <-- une cellule	JUMP,NE CLOSE$NEXTX$:	INC.W	D1	COMP.W	D1,(A5)+OAFIC2+2	JUMP',HI NEXTY$	LOAD.L	A4,#(A5)+OBUIO	LOAD.B	(A4),#TAB	; OBUIO <-- TAB	LOAD.L	D4,#1	LOAD.L	D3,#BNTTEXT	; D3 <-- type "TEXT"	BLOC_	WRDATA		; met un TAB dans le bloc-notes	JUMP',NE CLOSE$	JUMP	LOOPX$NEXTY$:	LOAD.L	A4,#(A5)+OBUIO	LOAD.B	(A4),#CR	; OBUIO <-- CR	LOAD.L	D4,#1	LOAD.L	D3,#BNTTEXT	; D3 <-- type "TEXT"	BLOC_	WRDATA		; met un CR dans le bloc-notes	JUMP',NE CLOSE$	SWAP.W	D1	INC.W	D1	LOAD.W	D2,D1	SWAP.W	D1	COMP.W	D2,(A5)+OAFIC2+0	JUMP,LS LOOPY$	CLR.W	D7		; D7 <-- okCLOSE$:	PUSH.W	D7	BLOC_	WRCLOSE		; ferme le bloc-notes	POP.W	D7EXIT$:	CLR.W	(A5)+OTECUR	; remet le curseur au dbut	POP.L	(A5)+OTEPCE	POPM.L	D1..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETNAME$:	.ASCIZ	"PAGE"	.EVEN;--------------\\; EDITOPCOPYCEL >;--------------/; Copie une cellule dans le bloc-notes.; in	-; out	D7.W	erreur; mod	D7.WEDITOPCOPYCEL:	PUSHM.L	D3..D5,A4	CALL	TXINFO		; D4/D5 <-- position/utilis	LOAD.L	D5,D4		; D5 <-- position	CLR.L	D4	CALL	TXPOSITIONNE	; va au dbut	LOAD.L	A4,#(A5)+OBUIOLOOP$:	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP',NE OK$	LOAD.B	(A4),D3		; OBUIO <-- caractre	LOAD.L	D4,#1	LOAD.L	D3,#BNTTEXT	; D3 <-- type "TEXT"	BLOC_	WRDATA		; met un caractre dans le bloc-notes	JUMP',NE END$	JUMP	LOOP$OK$:	CLR.W	D7		; D7 <-- okEND$:	PUSH.W	D7	LOAD.L	D5,D4	CALL	TXPOSITIONNE	; revient o l'on tait	POP.W	D7	POPM.L	D3..D5,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; EDITOPPAST >;===========/; Colle tout le contenu du bloc-notes.; in	A1.L	^objet liste; out	D7.W	erreur; mod	D7.WEDITOPPAST:	PUSHM.L	D1..D4,A2..A4	PUSH.L	(A5)+OTEPCE	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D3,#BNTTEXT	; D3 <-- type "TEXT"	BLOC_	RDOPEN		; ouvre le bloc-notes "PATX"	JUMP,NE EXIT$	LOAD.L	D1,(A5)+OAFIC1LOOPY$:	LOAD.W	D1,(A5)+OAFIC1+2LOOPX$:	CALL	TXGETPCE	; A2 <-- ^cellule (OCE*)	JUMP',NE NEXTX$	LOAD.L	(A5)+OTEPCE,A2	CALL	EDITOPPASTCEL	; cellule <-- bloc-notes	JUMP',NE CLOSE$	TEST.B	D3	JUMP',EQ OK$	COMP.B	D3,#CR	JUMP',EQ NEXTY$NEXTX$:	INC.W	D1	COMP.W	D1,(A5)+OAFIC2+2	JUMP,LS LOOPX$	CALL	EDITOPPASTSKIP	; saute jusqu'au CR	TEST.B	D3	JUMP',EQ OK$NEXTY$:	SWAP.W	D1	INC.W	D1	LOAD.W	D2,D1	SWAP.W	D1	COMP.W	D2,(A5)+OAFIC2+0	JUMP,LS LOOPY$OK$:	CLR.W	D7		; D7 <-- okCLOSE$:	PUSH.W	D7	BLOC_	RDCLOSE		; ferme le bloc-notes	POP.W	D7EXIT$:	CLR.W	(A5)+OTECUR	; remet le curseur au dbut	POP.L	(A5)+OTEPCE	POPM.L	D1..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------------\\; EDITOPPASTCEL >;--------------/; Met le contenu du bloc-notes dans la cellule courante.; in	-; out	D3.B	dernier caractre lu;	D7.W	erreur; mod	D3.L, D7.WEDITOPPASTCEL:	PUSHM.L	D2,D4,A4	CLR.W	D2		; D2 <-- cellule pas encore effaceLOOP$:	LOAD.L	A4,#(A5)+OBUIO	LOAD.L	D4,#1	BLOC_	RDDATA		; lit un caractre	JUMP',NE EOF$	LOAD.B	D3,(A4)		; D3 <-- caractre lu	BLOC_	CAR87		; D3 <-- caractre < 128	TEST.B	D3	JUMP',EQ OK$	COMP.B	D3,#TAB	JUMP',EQ OK$	COMP.B	D3,#CR	JUMP',EQ OK$	TEST.W	D2		; cellule dj efface ?	JUMP',NE INS$		; oui => INS$	CALL	TXFLUSH		; efface la cellule	INC.W	D2		; D2 <-- cellule effaceINS$:	CALL	TXINSERE	; cellule <-- caractre	JUMP',NE EXIT$	JUMP	LOOP$EOF$:	CLR.B	D3		; D3 <-- EOFOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------------\\; EDITOPPASTSKIP >;---------------/; Lit le contenu du bloc-notes jusqu' un CR.; in	-; out	D3.B	dernier caractre lu; mod	D3.L, D7.WEDITOPPASTSKIP:	PUSHM.L	D4,A4LOOP$:	LOAD.L	A4,#(A5)+OBUIO	LOAD.L	D4,#1	BLOC_	RDDATA		; lit un caractre	JUMP',NE EOF$	LOAD.B	D3,(A4)		; D3 <-- caractre lu	JUMP',EQ EXIT$	COMP.B	D3,#CR	JUMP',EQ EXIT$	JUMP	LOOP$EOF$:	CLR.B	D3		; D3 <-- EOFEXIT$:	POPM.L	D4,A4	RET;------------\\; EDITOPTRAIT >;------------/; Modifie le trait de toutes les cellules d'une zone.; in	A1.L	^objet;	D3.B	nouveau pinceau (0..n);	D4.W	opration (0..7); out	-; mod	D7.WEDITOPTRAIT:	PUSHM.L	D1..D5	LOAD.W	D5,D4		; D5 <-- opration	LOAD.W	D2,(A5)+OAFIC1+0LOOPY$:	LOAD.W	D1,(A5)+OAFIC1+2LOOPX$:	SWAP.W	D1	LOAD.W	D1,D2	SWAP.W	D1	TEST.W	D5		; opration "partout" ?	JUMP,EQ ALL$		; oui => ALL$	CLR.W	D4	COMP.W	D5,#4		; opration "gauche" ?	JUMP,EQ ONE$		; oui => ONE$	INC.W	D4	COMP.W	D5,#5		; opration "droite" ?	JUMP,EQ ONE$		; oui => ONE$	INC.W	D4	COMP.W	D5,#6		; opration "haut" ?	JUMP,EQ ONE$		; oui => ONE$	INC.W	D4	COMP.W	D5,#7		; opration "bas" ?	JUMP,EQ ONE$		; oui => ONE$	COMP.W	D1,(A5)+OAFIC1+2	JUMP',NE CADG$	CLR.W	D4	CALL	EDITOPTRONE	; met un trait  gaucheCADG$:	COMP.W	D1,(A5)+OAFIC2+2	JUMP',NE CADD$	LOAD.W	D4,#1	CALL	EDITOPTRONE	; met un trait  droiteCADD$:	COMP.W	D2,(A5)+OAFIC1+0	JUMP',NE CADH$	LOAD.W	D4,#2	CALL	EDITOPTRONE	; met un trait en hautCADH$:	COMP.W	D2,(A5)+OAFIC2+0	JUMP',NE CADB$	LOAD.W	D4,#3	CALL	EDITOPTRONE	; met un trait en basCADB$:	COMP.W	D5,#1		; opration "contour" ?	JUMP,EQ NEXT$		; oui => NEXT$	COMP.W	D5,#2		; opration "vertical" ?	JUMP',EQ VERT$		; oui => VERT$HORI$:	COMP.W	D2,(A5)+OAFIC2+0	JUMP',EQ NEXT$	LOAD.W	D4,#3	CALL	EDITOPTRONE	; met un trait en bas	JUMP'	NEXT$VERT$:	COMP.W	D1,(A5)+OAFIC2+2	JUMP',EQ NEXT$	LOAD.W	D4,#1	CALL	EDITOPTRONE	; met un trait  droite	JUMP'	NEXT$ALL$:	CLR.W	D4	CALL	EDITOPTRONE	; met un trait  gauche	LOAD.W	D4,#1	CALL	EDITOPTRONE	; met un trait  droite	LOAD.W	D4,#2	CALL	EDITOPTRONE	; met un trait en haut	LOAD.W	D4,#3ONE$:	CALL	EDITOPTRONE	; met un trait en basNEXT$:	INC.W	D1	COMP.W	D1,(A5)+OAFIC2+2	JUMP,LS LOOPX$	INC.W	D2	COMP.W	D2,(A5)+OAFIC2+0	JUMP,LS LOOPY$	POPM.L	D1..D5	RET;------------\\; EDITOPTRONE >;------------/; Modifie le trait d'une cellule.; in	A1.L	^objet;	D1.L	coordonne cellule (y;x);	D3.B	nouveau pinceau (0..n);	D4.W	opration (0=gauche, 1=droite, 2=haut, 3=bas); out	-; mod	D7.WEDITOPTRONE:	PUSHM.L	D0..D2,A2	CALL	TXGETPCE	; A2 <-- ^cellule	JUMP,NE EXIT$	TEST.W	D4	JUMP',NE NOTG$	LOAD.W	D0,#OCETRG	LOAD.W	D2,#OCETRD	DEC.W	D1NOTG$:	COMP.W	D4,#1	JUMP',NE NOTD$	LOAD.W	D0,#OCETRD	LOAD.W	D2,#OCETRG	INC.W	D1NOTD$:	COMP.W	D4,#2	JUMP',NE NOTH$	LOAD.W	D0,#OCETRH	LOAD.W	D2,#OCETRB	SWAP.W	D1	DEC.W	D1	SWAP.W	D1NOTH$:	COMP.W	D4,#3	JUMP',NE NOTB$	LOAD.W	D0,#OCETRB	LOAD.W	D2,#OCETRH	SWAP.W	D1	INC.W	D1	SWAP.W	D1NOTB$:	LOAD.B	(A2)+(D0.W),D3	CALL	TXGETPCE	; A2 <-- ^cellule	JUMP',NE EXIT$	LOAD.B	(A2)+(D2.W),D3EXIT$:	POPM.L	D0..D2,A2	RET;----------\\; EDITEVENT >;==========/; Edite un pav de texte selon une touche presse.; in	A1.L	^objet liste;	D3.L	touche presse;	D4.L	position de la souris (si D3=KEYM?P); out	D7.W	erreur; mod	D7.WEDITEVENT:	PUSHM.L	D1..D4,A0,A2; Dbranchements principaux selon les touches super-shift.	COMP.W	D3,#H'80	JUMP',HS NOACCENT$	COMP.B	D3,#DEL	JUMP',EQ NOACCENT$	COMP.B	D3,#BS	JUMP',NE ACCENT$NOACCENT$:	CALL	NOACCENT	; plus de frappe d'accent flottantACCENT$:	CALL	EXFONC	.WW	CURSOR,KCURS$-TXPREL	.WW	CURSOR!KILL,KCUKI$-TXPREL	.WW	COPY,KCOPY$-TXPREL	.WW	KILL,KKILL$-TXPREL	.WW	SHOW,KSHOW$-TXPREL	.WW	KEYMGP/H'100,KMOUSE$-TXPREL	.WW	0,KEY$-TXPRELKEY$:	CALL	EXKEY	.WW	CR,VNEXT$-TXPREL	.WW	SCR,VPREV$-TXPREL	.WW	TAB,HNEXT$-TXPREL	.WW	STAB,HPREV$-TXPREL	.WW	DELETE,KDEL$-TXPREL	.WW	DEL,KDEL$-TXPREL	.WW	BS,KBS$-TXPREL	.WW	CCIRCON,KCIRCON$-TXPREL	.WW	CTREMA,KTREMA$-TXPREL	.WW	TRIZERO,KTRIZERO$-TXPREL	.WW	POINT,KPOINT$-TXPREL	.WW	FNCT,KFLIP$-TXPREL	.WW	CLEAR,KCLEAR$-TXPREL	.WW	F1,KPREND$-TXPREL	.WW	F3,KSAUVE$-TXPREL	.WW	0,INSERT$-TXPREL; Actions spciales, sans touches super-shift.KMOUSE$:	CALL	EXKEY	.WW	KEYMGP&H'FF,CLIC$-TXPREL	.WW	KEYMGR&H'FF,OK$-TXPREL	.WW	KEYMMR&H'FF,OK$-TXPREL	.WW	KEYMDR&H'FF,OK$-TXPREL	.WW	0,BIP$-TXPRELCLIC$:	CLR.L	(A5)+OTECCE	CLR.W	(A5)+OTECUR	LOAD.L	(A5)+OTEPCE,(A1)+OOBPCE	CALL	AFFDETCEL	; D1/D2 <-- cellule o est la souris	JUMP',NE CLMAJ$	CALL	TXGETPCE	; A2 <-- ^cellule	JUMP',NE CLMAJ$	LOAD.L	(A5)+OTECCE,D1	LOAD.W	(A5)+OTECUR,D2	LOAD.L	(A5)+OTEPCE,A2CLMAJ$:	CLR.L	D2	CALL	AFFCELS		; calcule la position du curseur	LOAD.W	(A5)+OEDITO,#1	; affiche tout la premire fois	JUMP	OK2$KPREND$:	CALL	IORALL		; lit un texte	LOAD.W	(A5)+OEDITO,#1	; affiche tout	JUMP	OK2$KSAUVE$:	CALL	IOWALL		; crit un texte	JUMP	OK$; Insertion des caractres, avec gestion du pav numrique.INSERT$:	COMP.W	D3,#H'80	JUMP,HS BIP$	CALL	ACCENT		; va sous un accent flottant ?	JUMP,EQ OK$		; oui => OK$	CALL	TXINSERE	JUMP,NE EXIT$	JUMP	OK$KTRIZERO$:			; insre 3x zro =>	LOAD.B	D3,#'0	CALL	TXINSERE	JUMP,NE EXIT$	CALL	TXINSERE	JUMP,NE EXIT$	CALL	TXINSERE	JUMP,NE EXIT$	JUMP	OK$KPOINT$:			; insre un "." =>	LOAD.B	D3,#'.	CALL	TXINSERE	JUMP,NE EXIT$	JUMP	OK$KCIRCON$:	LOAD.W	D4,#CIRCON	; met un circonflxe	JUMP'	KACCENT$KTREMA$:	LOAD.W	D4,#TREMA	; met qq chose comme un trma;	JUMP'	KACCENT$KACCENT$:	TEST.B	(A1)+OOBACC	JUMP',T KACCENT6$	CALL	TXDONNE		; D3 <-- car "sous" le curseur	JUMP',NE KACCENT5$	; rien => KACCENT5$	CALL	GETACCENT	; calcul lettre accentue	JUMP',NE KACCENT5$	; n'existe pas => KACCENT5$				; existe =>	TEST.B	D3	JUMP',EQ KACCENT5$	PUSH.L	D3	CALL	TXAVANCE	CALL	TXDETRUIT	; dtruit lettre non accentue	POP.L	D3	CALL	TXINSERE	; remplace par lettre accentue	JUMP	OK$KACCENT5$:	LOAD.B	D3,D4		; D3 <-- accent	CALL	TXINSERE	; insert un accent tout seul	CALL	TXRECULE	; puis recule "dessus"	SET.B	(A1)+OOBACC	JUMP	OK$KACCENT6$:	CALL	NOACCENT	; plus de frappe d'accent flottant	JUMP	OK$KFLIP$:				; permute deux caractres =>	CALL	TXDETRUIT	JUMP,NE BIP$	LOAD.W	D4,D3	CALL	TXAVANCE	LOAD.W	D3,D4	CALL	TXINSERE	CALL	TXRECULE	JUMP	OK$KCLEAR$:	CALL	TXRECULE	JUMP,EQ KCLEAR$	LOAD.B	D3,#'V	JUMP	ECUKI$KBS$:	LOAD.B	D3,#'F	JUMP	ECUKI$KDEL$:	LOAD.B	D3,#'D	JUMP	ECUKI$; Table pour les diffrentes combinaisons de touches super-shift.KCURS$:	CALL	EXKEY	.WW	'E,ECURS$-TXPREL	.WW	'R,ECURS$-TXPREL	.WW	'T,ECURS$-TXPREL	.WW	'S,ECURS$-TXPREL	.WW	'D,ECURS$-TXPREL	.WW	'F,ECURS$-TXPREL	.WW	'G,ECURS$-TXPREL	.WW	'X,ECURS$-TXPREL	.WW	'C,ECURS$-TXPREL	.WW	'V,ECURS$-TXPREL	.WW	SPACE,ECOLLE$-TXPREL	.WW	0,BIP$-TXPRELKCUKI$:	CALL	EXKEY	.WW	'E,ECUKI$-TXPREL	.WW	'R,ECUKI$-TXPREL	.WW	'T,ECUKI$-TXPREL	.WW	'S,ECUKI$-TXPREL	.WW	'D,ECUKI$-TXPREL	.WW	'F,ECUKI$-TXPREL	.WW	'G,ECUKI$-TXPREL	.WW	'X,ECUKI$-TXPREL	.WW	'C,ECUKI$-TXPREL	.WW	'V,ECUKI$-TXPREL	.WW	0,BIP$-TXPRELKCOPY$:	CALL	EXKEY	.WW	SPACE,ECOPIE$-TXPREL	.WW	0,BIP$-TXPRELKKILL$:	CALL	EXKEY	.WW	SPACE,ECOUPE$-TXPREL	.WW	0,BIP$-TXPRELKSHOW$:	CALL	EXKEY	.WW	SPACE,ECLASSEUR$-TXPREL	.WW	0,BIP$-TXPREL; (CURSOR) = Dplacement du curseur.ECURS$:	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP',NE ECURS1$	COMP.B	D3,#'E	JUMP,EQ VPREV$	COMP.B	D3,#'R	JUMP,EQ VPREV$	COMP.B	D3,#'T	JUMP,EQ VPREV$	COMP.B	D3,#'S	JUMP,EQ HPREV$	COMP.B	D3,#'D	JUMP,EQ HPREV$	COMP.B	D3,#'F	JUMP,EQ HNEXT$	COMP.B	D3,#'G	JUMP,EQ HNEXT$	COMP.B	D3,#'X	JUMP,EQ VNEXT$	COMP.B	D3,#'C	JUMP,EQ VNEXT$	COMP.B	D3,#'V	JUMP,EQ VNEXT$ECURS1$:	TEST.L	D2	JUMP,EQ BIP$	JUMP',NS ECURS4$ECURS2$:	CALL	TXAVANCE	DEC.L	D2	JUMP,NE ECURS2$	JUMP	OK$ECURS4$:	CALL	TXRECULE	INC.L	D2	JUMP,NE ECURS4$	JUMP	OK$; (CURSOR-KILL) = destructions autour du curseur.ECUKI$:	CALL	EFLECHE		; D2 <-- +/- dplacementECUKI1$:	TEST.L	D2	JUMP,EQ BIP$	JUMP',NS ECUKI4$ECUKI2$:	CALL	TXAVANCE	JUMP,NE EXIT$	CALL	TXDETRUIT	JUMP,NE EXIT$	DEC.L	D2	JUMP,NE ECUKI2$	JUMP	OK$ECUKI4$:	CALL	TXDETRUIT	JUMP,NE EXIT$	INC.L	D2	JUMP,NE ECUKI4$	JUMP	OK$HNEXT$:	LOAD.W	D1,(A5)+OTECCE+2	INC.W	D1	COMP.W	D1,(A1)+OOBNBX	JUMP,HS BIP$	INC.W	(A5)+OTECCE+2	JUMP'	NCEL$HPREV$:	TEST.W	(A5)+OTECCE+2	JUMP,EQ BIP$	DEC.W	(A5)+OTECCE+2	JUMP'	PCEL$VNEXT$:	LOAD.W	D1,(A5)+OTECCE+0	INC.W	D1	COMP.W	D1,(A1)+OOBNBY	JUMP,HS BIP$	INC.W	(A5)+OTECCE+0	JUMP'	NCEL$VPREV$:	TEST.W	(A5)+OTECCE+0	JUMP,EQ BIP$	DEC.W	(A5)+OTECCE+0	JUMP'	PCEL$NCEL$:	LOAD.L	D1,(A5)+OTECCE	CALL	TXGETPCE	; A2 <-- ^cellule	JUMP,NE BIP$	LOAD.L	(A5)+OTECCE,D1	LOAD.L	(A5)+OTEPCE,A2	CLR.W	(A5)+OTECUR	JUMP	OK$PCEL$:	LOAD.L	D1,(A5)+OTECCE	CALL	TXGETPCE	; A2 <-- ^cellule	JUMP,NE BIP$	LOAD.L	(A5)+OTECCE,D1	LOAD.L	(A5)+OTEPCE,A2	CLR.W	(A5)+OTECUR	TEST.L	(A2)+OCEPTX	JUMP,EQ OK$	LOAD.L	A2,(A2)+OCEPTX	LOAD.W	(A5)+OTECUR,(A2)+OTXNBC	JUMP	OK$; (...-SPACE) = bloc-notes.ECOUPE$:	CLR.L	(A5)+OAFIC1	LOAD.W	(A5)+OAFIC2+2,(A1)+OOBNBX	DEC.W	(A5)+OAFIC2+2	LOAD.W	(A5)+OAFIC2+0,(A1)+OOBNBY	DEC.W	(A5)+OAFIC2+0	CALL	EDITOPCOPY	; bloc-notes <-- objet	JUMP,NE BIP$	CALL	EDITOPKILL	; efface tout	JUMP	OK$ECOPIE$:	CLR.L	(A5)+OAFIC1	LOAD.W	(A5)+OAFIC2+2,(A1)+OOBNBX	DEC.W	(A5)+OAFIC2+2	LOAD.W	(A5)+OAFIC2+0,(A1)+OOBNBY	DEC.W	(A5)+OAFIC2+0	CALL	EDITOPCOPY	; bloc-notes <-- objet	JUMP,NE BIP$	JUMP	OK$ECOLLE$:	LOAD.L	(A5)+OAFIC1,(A5)+OTECCE	LOAD.W	(A5)+OAFIC2+2,(A1)+OOBNBX	DEC.W	(A5)+OAFIC2+2	LOAD.W	(A5)+OAFIC2+0,(A1)+OOBNBY	DEC.W	(A5)+OAFIC2+0	CALL	EDITOPPAST	; objet <-- bloc-notes	JUMP,NE BIP$	JUMP	OK$ECLASSEUR$:	LOAD.W	D2,#2^BDBSAV	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	LOAD.W	D7,#DB_POS3	PAGE_	DBOX		; D3 <-- centre de la dbox	BLOC_	VISU		; accs au classeur ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	JUMP	ECOLLE$OK$:	CLR.W	(A5)+OEDITO	; n'affiche pas les traits/tramesOK2$:	CLR.W	D7		; D7 <-- action effectue correctement	JUMP'	EXIT$BIP$:	LOAD.W	D7,#ERPBIP	; D7 <-- rien  faire avec cette toucheEXIT$:	POPM.L	D1..D4,A0,A2	TEST.W	D7		; retour EQ/NE	RET;---------\\; EFLECHE  >;---------/; Calcul l'amplitude d'un dplacement/destruction en fonction; d'une touche flche.; in	D3.B	touche flche; out	D3.B	touche flche;	D2.L	dplacement (+/-n);	D7.W	erreur; mod	D2.L, D3.L, D7.WEFLECHE:	PUSHM.L	D1,D4..D6,A3	PUSH.W	(A5)+OTECUR	; stack <-- position du curseur	CLR.L	D2		; D2 <-- dplacement	COMP.B	D3,#'A-H'40	JUMP',LO NOCTRL$	COMP.B	D3,#'Z-H'40	JUMP',HI NOCTRL$	ADD.B	D3,#H'40NOCTRL$:	LIB	?MINMAJ	LOAD.B	D1,D3	COMP.B	D3,#'F	JUMP,EQ AONE$	COMP.B	D3,#'D	JUMP,EQ RONE$	LOAD.W	D6,#1		; D6 <-- une fois	LOAD.L	A3,#R16"TWORD	; A3 <-- ^terminateurs de mots	COMP.B	D3,#'G	JUMP,EQ ALIST$	COMP.B	D3,#'S	JUMP,EQ RLIST$	LOAD.L	A3,#R16"TLINE	; A3 <-- ^terminateurs de lignes	COMP.B	D3,#'C	JUMP,EQ ALIST$	COMP.B	D3,#'R	JUMP,EQ RLIST$	LOAD.W	D6,#4		; D6 <-- quatre fois	COMP.B	D3,#'X	JUMP,EQ ALIST$	COMP.B	D3,#'E	JUMP,EQ RLIST$	COMP.B	D3,#'V	JUMP,EQ AEND$	COMP.B	D3,#'T	JUMP,EQ REND$	LOAD.W	D7,#1	JUMP	EXIT$AONE$:				; +1 caractre =>	CALL	TXAVANCE	JUMP,NE EXIT$	INC.L	D2	JUMP	EXIT$RONE$:				; -1 caractre =>	CALL	TXRECULE	JUMP,NE EXIT$	DEC.L	D2	JUMP	EXIT$ALIST$:				; +1 mot/ligne =>	CALL	TXAVANCE	JUMP,NE EXIT$	INC.L	D2	CALL	ETESTCAR	JUMP',NE ALIST2$	COMP.B	(A3),#CR	JUMP,NE ALIST$ALIST2$:	CALL	TXAVANCE	JUMP,NE EXIT$	INC.L	D2	CALL	ETESTCAR	JUMP,NE ALIST2$	CALL	TXRECULE	DEC.L	D2	DEC.W	D6	JUMP,NE ALIST$	JUMP	EXIT$RLIST$:				; -1 mot/ligne =>	CALL	TXRECULE	JUMP,NE EXIT$	DEC.L	D2	CALL	ETESTCAR	JUMP',NE RLIST2$	COMP.B	(A3),#CR	JUMP,NE RLIST$RLIST2$:	CALL	TXRECULE	JUMP,NE EXIT$	DEC.L	D2	CALL	ETESTCAR	JUMP,NE RLIST2$	CALL	TXAVANCE	INC.L	D2	DEC.W	D6	JUMP,NE RLIST$	JUMP	EXIT$AEND$:				; fin =>	CALL	TXINFO		; D4 <-- position, D5 <-- nb caractres	LOAD.L	D2,D5	SUB.L	D2,D4	JUMP'	EXIT$REND$:				; dbut =>	CALL	TXINFO		; D4 <-- position, D5 <-- nb caractres	LOAD.L	D2,D4	NEG.L	D2;	JUMP'	EXIT$EXIT$:	LOAD.B	D3,D1	POP.W	(A5)+OTECUR	; remet le curseur o il tait	POPM.L	D1,D4..D6,A3	TEST.W	D7		; retour EQ/NE	RETTWORD:	.B	SPACE		; terminateurs de mots	.B	TAB	.B	'+	.B	'-	.B	'*	.B	'/	.B	'^	.B	'(	.B	')	.B	'.	.B	':	.B	',	.B	';	.B	'!	.B	'?TLINE:	.B	CR		; terminateurs de lignes	.B	LF	.B	0	.EVEN;---------\\; ETESTCAR >;---------/; Test si le caractre dans D3.B est un terminateur.; in	D3.B	caractre;	A3.L	^liste de terminateurs; out	EQ	terminateur;	NE	autre chose; mod	FETESTCAR:	PUSH.L	A310$:	TEST.B	(A3)	NOTZ	JUMP',NE EXIT$	COMP.B	D3,(A3+)	JUMP,NE 10$EXIT$:	POP.L	A3	RET;--------\\; ACCENT  >;========/; Caractre aprs un accent flottant frapp.; in	D3.B	caractre aprs accent; out	D7.W	erreur; mod	D7.WACCENT:	PUSHM.L	D3,D4	LOAD.W	D7,#ERPBIP	TEST.B	(A1)+OOBACC	JUMP',F EXIT$	CLR.B	(A1)+OOBACC	LOAD.L	D4,D3	CALL	TXDONNE		; D3 <-- cherche car prcdent tap	EX.L	D3,D4		; D4 <-- accent, D3 <-- car qui ira "sous"	CALL	GETACCENT	; accent existe ?	JUMP',NE 40$		; non => 40$				; oui =>	TEST.B	D3		; laisse l'accent seul ?	JUMP',EQ 40$		; oui => 40$				; non =>	PUSH.L	D3	CALL	TXAVANCE	CALL	TXDETRUIT	; dtruit l'accent seul	POP.L	D3	CALL	TXINSERE	; remplace par lettre accentue	JUMP'	EXIT$40$:	PUSH.W	D7	CALL	TXAVANCE	; saute '^' ou '"'	POP.W	D7EXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; GETACCENT >;----------/; Calcul le code correspondant  une lettre (a,e,i,o,u) et ; un accent (^,").; in	D4.B	accent (^,");	D3.B	caractre; out	D7.W	zro => ok (lettre accentue existe);	 D3.B	 lettre accentue;	D7.W	EREOUTB => lettre accentue n'existe pas;	 D3.B	 caractre qui devait aller sous l'accent; mod	D3.B, D7.WGETACCENT:	PUSH.L	A3	LOAD.L	A3,#R16"ACCENT$-310$:	ADD.L	A3,#3		; A3 <-- ^suivant dans table	TEST.B	(A3)		; fin de la table ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,(A3)		; lettre trouve dans table ?	JUMP,NE 10$		; non => 10$				; oui =>	COMP.B	D4,#CIRCON	JUMP',EQ 30$	COMP.B	D4,#TREMA	JUMP',NE 50$	LOAD.B	D3,(A3)+2	; D3 <-- lettre accentue (")	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$30$:	LOAD.B	D3,(A3)+1	; D3 <-- lettre accentue (^)	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$50$:	LOAD.W	D7,#ERPBIP	; D7 <-- erreurEXIT$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RETACCENT$:	.B	'a	' '	.B	'e	' '	.B	'i	' '	.B	'o	' '	.B	'u	' '	.B	SPACE	 0  0	.B	0	.EVEN;---------\\; NOACCENT >;=========/; Annule l'effet d'un ventuel accent flottant tap, alors; que la lettre devant aller "dessous" n'a pas encore t; tape.NOACCENT:	TEST.B	(A1)+OOBACC	JUMP',F EXIT$	CLR.B	(A1)+OOBACC	PUSH.L	D3	CALL	TXAVANCE	; saute l'accent flottant	POP.L	D3EXIT$:	RET;--------\\; EXKEY   >;========/; in	D3.B	touche presse; out	-; mod	A0.LEXKEY:	POP.L	A0		; A0 <-- ^table des .WW	PUSH.L	D3	COMP.B	D3,#'a		; minuscule ?	JUMP',LO 10$		; non => 10$	COMP.B	D3,#'z	JUMP',HI 10$	SUB.B	D3,#'a-'A	; oui => transforme10$:	COMP.B	D3,#F0+SHIFT	JUMP',LO 12$	COMP.B	D3,#F15+SHIFT	JUMP',HI 12$	SUB.B	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)12$:	SUB.L	A0,#4		; A0 <-- recule .WW20$:	ADD.L	A0,#4		; A0 <-- saute .WW	TEST.W	(A0)		; table termine ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.B	D3,(A0)+1	; code touche trouve ?	JUMP,NE	20$		; non => 20$50$:	LOAD.W	D3,(A0)+2	; D3 <-- adresse relative	LOAD.L	A0,#R16"TXPREL	ADD.W	A0,D3		; A0 <-- adresse absolue	POP.L	D3	JUMP	(A0)		; excute ...;--------\\; EXFONC  >;========/; in	D3.W	touche fonction (dans high); out	-; mod	A0.LEXFONC:	POP.L	A0		; A0 <-- ^table des .WW	PUSH.L	D3	SR.W	D3,#8		; D3 <-- touche fonction	SUB.L	A0,#4		; A0 <-- recule .WW20$:	ADD.L	A0,#4		; A0 <-- saute .WW	TEST.W	(A0)		; table termine ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.B	D3,(A0)+1	; code touche fonction trouv ?	JUMP,NE	20$		; non => 20$50$:	LOAD.W	D3,(A0)+2	; D3 <-- adresse relative	LOAD.L	A0,#R16"TXPREL	ADD.W	A0,D3		; A0 <-- adresse absolue	POP.L	D3	JUMP	(A0)		; excute ...	.END