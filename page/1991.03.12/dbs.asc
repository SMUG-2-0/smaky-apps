	.TITLE	DBS.ASC	.PROC	M680002	.REF	SMAKY	.LOC	0OSBPS0:	.BLKB	4		; source: S0OSBPS2:	.BLKB	4		; source: S2OSBPD0:	.BLKB	4		; destination: D0OSBPC01:.BLKB	4		; destination: C01OSBPC10:.BLKB	4		; destination: C10OSBPD1:	.BLKB	4		; destination: D1OSBPC12:.BLKB	4		; destination: C12OSBPC21:.BLKB	4		; destination: C21OSBPD2:	.BLKB	4		; destination: D2OSBPC23:.BLKB	4		; destination: C23OSBPC32:.BLKB	4		; destination: C32OSBPD3:	.BLKB	4		; destination: D3OSBPC30:.BLKB	4		; destination: C30OSBPC03:.BLKB	4		; destination: C03LSBP:	.LOC	0OVAR:	.BLKB	LSBPLGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.L	A4,#(A6)+OVAR	LOAD.L	(A4)+OSBPS0,#H'10000*100+100	LOAD.L	(A4)+OSBPS2,#H'10000*200+300	LOAD.L	(A4)+OSBPC03,#H'10000*(120-50)+(100-50)	LOAD.L	(A4)+OSBPD0,#H'10000*(100-50)+(100-50)	LOAD.L	(A4)+OSBPC01,#H'10000*(100-50)+(140-50)	LOAD.L	(A4)+OSBPC10,#H'10000*100+260	LOAD.L	(A4)+OSBPD1,#H'10000*100+300	LOAD.L	(A4)+OSBPC12,#H'10000*120+300	LOAD.L	(A4)+OSBPC21,#H'10000*180+300	LOAD.L	(A4)+OSBPD2,#H'10000*200+300	LOAD.L	(A4)+OSBPC23,#H'10000*200+260	LOAD.L	(A4)+OSBPC32,#H'10000*200+140	LOAD.L	(A4)+OSBPD3,#H'10000*200+100	LOAD.L	(A4)+OSBPC30,#H'10000*180+100	LOAD.L	D4,#H'10000*100+100	LOAD.L	D5,#H'10000*0+40	CALL	STRETCHBS	EXIT;----------\\; STRETCHBS >;----------/; Calcule une distance "stretche" dans quatre courbes de Bzier.; in	A4.L	^paramtres (OSBP*);	D4.L	P (y;x);	D5.L	D (dy;dx); out	D5.L	D'(dy;dx); mod	D5.L, D7.WSTRETCHBS:	PUSHM.L	D0..D3; Calcule le premier terme de dx.	LOAD.W	D3,(A4)+OSBPC01+2	SUB.W	D3,(A4)+OSBPD0+2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	LOAD.W	D1,D3	LOAD.W	D3,(A4)+OSBPC10+2	SUB.W	D3,(A4)+OSBPD1+2	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	SUB.W	D1,D3	LOAD.W	D3,(A4)+OSBPC23+2	SUB.W	D3,(A4)+OSBPD2+2	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	SUB.W	D1,D3	LOAD.W	D3,(A4)+OSBPC32+2	SUB.W	D3,(A4)+OSBPD3+2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	ADD.W	D1,D3	MUL.WA	D1,D5	CLR.L	D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D2,#3	DIV.WA	D1,D2; Calcule le deuxime terme de dx.	LOAD.W	D3,(A4)+OSBPC03+2	SUB.W	D3,(A4)+OSBPD0+2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	LOAD.W	D0,D3	LOAD.W	D3,(A4)+OSBPC12+2	SUB.W	D3,(A4)+OSBPD1+2	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	ADD.W	D0,D3	LOAD.W	D3,(A4)+OSBPC21+2	SUB.W	D3,(A4)+OSBPD2+2	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	SUB.W	D0,D3	LOAD.W	D3,(A4)+OSBPC30+2	SUB.W	D3,(A4)+OSBPD3+2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	SUB.W	D0,D3	SWAP.W	D5	MUL.WA	D0,D5	SWAP.W	D5	CLR.L	D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D2,#3	DIV.WA	D0,D2	ADD.W	D0,D1	PUSH.W	D0; Calcule le premier terme de dy.	LOAD.W	D3,(A4)+OSBPC01+0	SUB.W	D3,(A4)+OSBPD0+0	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	LOAD.W	D1,D3	LOAD.W	D3,(A4)+OSBPC10+0	SUB.W	D3,(A4)+OSBPD1+0	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	SUB.W	D1,D3	LOAD.W	D3,(A4)+OSBPC23+0	SUB.W	D3,(A4)+OSBPD2+0	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	SUB.W	D1,D3	LOAD.W	D3,(A4)+OSBPC32+0	SUB.W	D3,(A4)+OSBPD3+0	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	ADD.W	D1,D3	MUL.WA	D1,D5	CLR.L	D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D2,#3	DIV.WA	D1,D2; Calcule le deuxime terme de dy.	LOAD.W	D3,(A4)+OSBPC03+0	SUB.W	D3,(A4)+OSBPD0+0	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	LOAD.W	D0,D3	LOAD.W	D3,(A4)+OSBPC12+0	SUB.W	D3,(A4)+OSBPD1+0	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	ADD.W	D0,D3	LOAD.W	D3,(A4)+OSBPC21+0	SUB.W	D3,(A4)+OSBPD2+0	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	SUB.W	D0,D3	LOAD.W	D3,(A4)+OSBPC30+0	SUB.W	D3,(A4)+OSBPD3+0	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	SUB.W	D0,D3	SWAP.W	D5	MUL.WA	D0,D5	SWAP.W	D5	CLR.L	D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D2,#3	DIV.WA	D0,D2	ADD.W	D0,D1	LOAD.W	D5,D0	SWAP.W	D5	POP.W	D5	POPM.L	D0..D3	RETVAR:	.FILLB	LGVAR,0	.END	START