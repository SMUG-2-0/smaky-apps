	.SBTTL	OPCADRDRAW.ASI;----------\\; DRAWTESTE >;==========/; Affiche un petit cadre (juste le coin sup/gauche) de test dans un rectangle.; in	A1.L	^objet;	D3.L	origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRAWTESTE:	PUSHM.L	D0..D5	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	.B	1	.B	0	.EVEN	LOAD.L	D1,D4	LOAD.W	D4,#1	LOAD.W	D7,#DR_CHGSCALE	PAGE_	DRAW		; met l'chelle 100%	PUSH.W	D4	CLR.L	D4	CALL	DRMDEF		; trame pour effacer	LOAD.L	D4,D1	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine le pourtour	ADD.W	D3,(A0)+ODFFX	INC.W	D3	DEC.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,(A0)+ODFFY	INC.W	D3	DEC.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#DR_WDOUOPEN	PAGE_	DRAW		; ouvre swdo de dessin	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'intrieur	LOAD.W	D5,(A1)+OOBDI	ADD.W	D5,(A1)+OOBE	COMP.W	D5,(A5)+ODBP1	JUMP',HS MAX$	LOAD.W	D5,(A5)+ODBP1MAX$:	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDY	DIV.WU	D4,#6	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- selon chelle	LOAD.W	(A5)+OCOPP+0,D4	LOAD.W	(A5)+OCOPP+2,D4	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDY	DIV.WU	D4,#6	MUL.WU	D4,#4	MUL.WU	D4,(A5)+ODBP1	DIV.WU	D4,D5	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- selon chelle	LOAD.W	(A5)+OCOD,D4	LOAD.W	D4,(A5)+ODBP2	; D4 <-- coins (0..n)	LOAD.W	D2,#SETDOT	CALL	DRAWTESTONE	; dessine le coin sup/gauche extrieur	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDY	DIV.WU	D4,#6	MUL.WU	D4,#4	MUL.WU	D4,(A1)+OOBE	DIV.WU	D4,D5	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- selon chelle	ADD.W	(A5)+OCOPP+0,D4	ADD.W	(A5)+OCOPP+2,D4	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDY	DIV.WU	D4,#6	MUL.WU	D4,#4	MUL.WU	D4,(A1)+OOBDI	DIV.WU	D4,D5	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- selon chelle	LOAD.W	(A5)+OCOD,D4	LOAD.W	D4,(A1)+OOBCOI	; D4 <-- coins (0..n)	LOAD.W	D2,#SETDOT!TTTDOT	CALL	DRAWTESTONE	; dessine le coin sup/gauche intrieur	LOAD.W	D7,#DR_WDOUCLOSE	PAGE_	DRAW		; ferme swdo de dessin	POP.W	D4	LOAD.W	D7,#DR_PUTSCALE	PAGE_	DRAW		; remet l'chelle couranteEXIT$:	POPM.L	D0..D5	RET;----------\\; DRAWTESTI >;==========/; Affiche un petit cadre (juste le coin sup/gauche) de test dans un rectangle.; in	A1.L	^objet;	D3.L	origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRAWTESTI:	PUSHM.L	D0..D5	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	.B	1	.B	0	.EVEN	LOAD.L	D1,D4	LOAD.W	D4,#1	LOAD.W	D7,#DR_CHGSCALE	PAGE_	DRAW		; met l'chelle 100%	PUSH.W	D4	CLR.L	D4	CALL	DRMDEF		; trame pour effacer	LOAD.L	D4,D1	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine le pourtour	ADD.W	D3,(A0)+ODFFX	INC.W	D3	DEC.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,(A0)+ODFFY	INC.W	D3	DEC.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#DR_WDOUOPEN	PAGE_	DRAW		; ouvre swdo de dessin	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'intrieur	LOAD.W	D5,(A5)+ODBP1	ADD.W	D5,(A5)+ODBP3	COMP.W	D5,(A1)+OOBDE	JUMP',HS MAX$	LOAD.W	D5,(A1)+OOBDEMAX$:	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDY	DIV.WU	D4,#6	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- selon chelle	LOAD.W	(A5)+OCOPP+0,D4	LOAD.W	(A5)+OCOPP+2,D4	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDY	DIV.WU	D4,#6	MUL.WU	D4,#4	MUL.WU	D4,(A1)+OOBDE	DIV.WU	D4,D5	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- selon chelle	LOAD.W	(A5)+OCOD,D4	LOAD.W	D4,(A1)+OOBCOE	; D4 <-- coins (0..n)	LOAD.W	D2,#SETDOT!TTTDOT	CALL	DRAWTESTONE	; dessine le coin sup/gauche extrieur	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDY	DIV.WU	D4,#6	MUL.WU	D4,#4	MUL.WU	D4,(A5)+ODBP1	DIV.WU	D4,D5	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- selon chelle	ADD.W	(A5)+OCOPP+0,D4	ADD.W	(A5)+OCOPP+2,D4	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDY	DIV.WU	D4,#6	MUL.WU	D4,#4	MUL.WU	D4,(A5)+ODBP3	DIV.WU	D4,D5	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- selon chelle	LOAD.W	(A5)+OCOD,D4	LOAD.W	D4,(A5)+ODBP2	; D4 <-- coins (0..n)	LOAD.W	D2,#SETDOT	CALL	DRAWTESTONE	; dessine le coin sup/gauche intrieur	LOAD.W	D7,#DR_WDOUCLOSE	PAGE_	DRAW		; ferme swdo de dessin	POP.W	D4	LOAD.W	D7,#DR_PUTSCALE	PAGE_	DRAW		; remet l'chelle couranteEXIT$:	POPM.L	D0..D5	RET;-----------\\; DRAWTESTSL >;===========/; Affiche un petit cadre (juste le coin sup/gauche) de test dans un rectangle.; in	D2.W	type des coins;		 si 2^17 -> inverse;	D3.L	origine (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WDRAWTESTSL:	PUSHM.L	D0..D4	LOAD.L	D0,D2		; D0 <-- bits	LOAD.L	D1,D4	LOAD.W	D4,#1	LOAD.W	D7,#DR_CHGSCALE	PAGE_	DRAW		; met l'chelle 100%	PUSH.W	D4	CLR.L	D4	TEST.L	D0:#17	JUMP',BC MDEF$	NOT.L	D4MDEF$:	CALL	DRMDEF		; trame pour effacer	LOAD.L	D4,D1	ADD.W	D3,(A0)+ODFFX	INC.W	D3	DEC.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,(A0)+ODFFY	INC.W	D3	DEC.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#DR_WDOUOPEN	PAGE_	DRAW		; ouvre swdo de dessin	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; efface l'intrieur	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDY	DIV.WU	D4,#6	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- selon chelle	LOAD.W	(A5)+OCOPP+0,D4	LOAD.W	(A5)+OCOPP+2,D4	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDY	DIV.WU	D4,#6	MUL.WU	D4,#4	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- selon chelle	LOAD.W	(A5)+OCOD,D4	LOAD.W	D2,#SETDOT	TEST.L	D0:#17	JUMP',BC MODE$	LOAD.W	D2,#CLRDOTMODE$:	LOAD.W	D4,D0		; D4 <-- coins (0..n)	CALL	DRAWTESTONE	; dessine le coin sup/gauche	LOAD.W	D7,#DR_WDOUCLOSE	PAGE_	DRAW		; ferme swdo de dessin	POP.W	D4	LOAD.W	D7,#DR_PUTSCALE	PAGE_	DRAW		; remet l'chelle couranteEXIT$:	POPM.L	D0..D4	RET;------------\\; DRAWTESTONE >;------------/; Dessine le coin sup/gauche dans la swdo.; in	(A5)+OCOPP.L	P1 (y;x);	(A5)+OCOD.W	distance;	A3.L		^table d'un coin;	D4.W		coins (0..n);	D2.W		mode de dessin; out	-; mod	D7.WDRAWTESTONE:	PUSHM.L	D2..D4,A3	CALL	DRAWTABLE	; A3 <-- ^table	JUMP,NE EXIT$	CLR.L	(A5)+OCOA	CLR.W	(A5)+OCOR	LOAD.W	(A5)+OMDESS,#MDLINE	CALL	DRAWDEPART	; D3 <-- dpart	LOAD.W	D4,(A0)+ODFFDY	SWAP.W	D4	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- selon chelle	LOAD.W	D4,D3	EX.L	D3,D4	CALL	DRAWCOTE	; dessine le ct vertical	CALL	DRAWCOIN	; dessine le coin sup/gauche	LOAD.L	D3,D4	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- selon chelle	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,D3	SWAP.W	D4	SWAP.W	D3	CALL	DRAWCOTE	; dessine le ct horizontalEXIT$:	POPM.L	D2..D4,A3	RET;-----------\\; DRAWCADREE >;===========/; Dessine tout un cadre extrieur.; in	A4.L		^objet;	D2.W		mode de dessin;	(A5)+OMDESS.W	mode de dessin (MD*); out	-; mod	D7.WDRAWCADREE:	PUSHM.L	D1..D4,A3	LOAD.L	(A5)+OCOPR,(A4)+OOBP1	LOAD.L	(A5)+OCOA,(A4)+OOBA	LOAD.L	D3,(A4)+OOBP1	LOAD.L	D4,(A4)+OOBP3	COMP.L	D3,D4	JUMP,EQ EXIT$	CALL	ORDONNE		; D3/D4 <-- dans l'ordre	LOAD.L	(A5)+OCOP1,D3	LOAD.L	(A5)+OCOP3,D4	LOAD.W	D1,(A4)+OOBDI	ADD.W	D1,(A4)+OOBE	COMP.W	D1,(A4)+OOBDE	JUMP',HS MAX$	LOAD.W	D1,(A4)+OOBDEMAX$:	SUB.W	D4,D3	SR.W	D4,#1	COMP.W	D4,D1	JUMP',LS ERROR$	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SR.W	D4,#1	COMP.W	D4,D1	JUMP',LS ERROR$	LOAD.W	(A5)+OCOD,(A4)+OOBDE	LOAD.W	D4,(A4)+OOBCOE	CALL	DRAWTABLE	; A3 <-- ^table	JUMP',NE ERROR$	CALL	DRAWCADREONE	; dessine le cadre extrieur	JUMP	EXIT$ERROR$:	CALL	GETP1	LOAD.L	D1,D4	LOAD.L	D3,D4		; D3 <-- P1	CALL	GETP2		; D4 <-- P2	CALL	DRAWDROITE	LOAD.L	D3,D4		; D3 <-- P2	CALL	GETP3		; D4 <-- P3	CALL	DRAWDROITE	LOAD.L	D3,D4		; D3 <-- P3	CALL	GETP4		; D4 <-- P4	CALL	DRAWDROITE	LOAD.L	D3,D4		; D3 <-- P4	LOAD.L	D4,D1		; D4 <-- P1	CALL	DRAWDROITE	COMP.W	(A5)+OMDESS,#MDFILL	JUMP',EQ EXIT$	CALL	GETP1	LOAD.L	D3,D4		; D3 <-- P1	CALL	GETP3		; D4 <-- P3	CALL	DRAWDROITE	CALL	GETP2	LOAD.L	D3,D4		; D3 <-- P2	CALL	GETP4		; D4 <-- P4	CALL	DRAWDROITEEXIT$:	POPM.L	D1..D4,A3	RET;-----------\\; DRAWCADREI >;===========/; Dessine tout un cadre intrieur.; in	A4.L		^objet;	D2.W		mode de dessin;	(A5)+OMDESS.W	mode de dessin (MD*); out	-; mod	D7.WDRAWCADREI:	PUSHM.L	D1..D4,A3	LOAD.L	(A5)+OCOPR,(A4)+OOBP1	LOAD.L	(A5)+OCOA,(A4)+OOBA	LOAD.L	D3,(A4)+OOBP1	LOAD.L	D4,(A4)+OOBP3	COMP.L	D3,D4	JUMP,EQ EXIT$	CALL	ORDONNE		; D3/D4 <-- dans l'ordre	LOAD.L	(A5)+OCOP1,D3	LOAD.L	(A5)+OCOP3,D4	LOAD.W	D1,(A4)+OOBDI	ADD.W	D1,(A4)+OOBE	COMP.W	D1,(A4)+OOBDE	JUMP',HS MAX$	LOAD.W	D1,(A4)+OOBDEMAX$:	SUB.W	D4,D3	SR.W	D4,#1	COMP.W	D4,D1	JUMP',LS EXIT$	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SR.W	D4,#1	COMP.W	D4,D1	JUMP',LS EXIT$	LOAD.W	D4,(A4)+OOBE	ADD.W	(A5)+OCOP1+0,D4	ADD.W	(A5)+OCOP1+2,D4	SUB.W	(A5)+OCOP3+0,D4	SUB.W	(A5)+OCOP3+2,D4	LOAD.W	(A5)+OCOD,(A4)+OOBDI	LOAD.W	D4,(A4)+OOBCOI	CALL	DRAWTABLE	; A3 <-- ^table	JUMP',NE EXIT$	CALL	DRAWCADREONE	; dessine le cadre intrieurEXIT$:	POPM.L	D1..D4,A3	RET;-------------\\; DRAWCADREONE >;-------------/; Dessine un cadre.; in	(A5)+OCOPP.L	P1 (y;x);	(A5)+OCOPR.L	Pr (y;x);	(A5)+OCOA.L	angle de rotation;	(A5)+OCOD.W	distance;	(A5)+OCOR.W	nb de quart de tours (0..3);	A3.L		^table d'un coin;	D2.W		mode de dessin; out	D2.W		mode de dessin; mod	D2.L, D7.WDRAWCADREONE:	PUSHM.L	D1,D3,D4	LOAD.L	(A5)+OCOPP,(A5)+OCOP1	CLR.W	(A5)+OCOR	CALL	DRAWDEPART	LOAD.L	D1,D3	CALL	DRAWCOIN	; dessine le coin sup/gauche	LOAD.W	(A5)+OCOPP+2,(A5)+OCOP3+2	LOAD.W	(A5)+OCOPP+0,(A5)+OCOP1+0	INC.W	(A5)+OCOR	CALL	DRAWDEPART	EX.L	D3,D4	CALL	DRAWCOTE	; dessine le ct en haut	CALL	DRAWCOIN	; dessine le coin sup/droite	LOAD.L	(A5)+OCOPP,(A5)+OCOP3	INC.W	(A5)+OCOR	CALL	DRAWDEPART	EX.L	D3,D4	CALL	DRAWCOTE	; dessine le ct  droite	CALL	DRAWCOIN	; dessine le coin inf/droite	LOAD.W	(A5)+OCOPP+2,(A5)+OCOP1+2	LOAD.W	(A5)+OCOPP+0,(A5)+OCOP3+0	INC.W	(A5)+OCOR	CALL	DRAWDEPART	EX.L	D3,D4	CALL	DRAWCOTE	; dessine le ct en bas	CALL	DRAWCOIN	; dessine le coin inf/gauche	LOAD.L	D3,D4	LOAD.L	D4,D1	CALL	DRAWCOTE	; dessine le ct  gauche	POPM.L	D1,D3,D4	RET;-----------\\; DRAWDEPART >;-----------/; Trouve le premier point d'un coin.; in	(A5)+OCOPP.L	P1 (y;x);	(A5)+OCOPR.L	Pr (y;x);	(A5)+OCOA.L	angle de rotation;	(A5)+OCOD.W	distance;	(A5)+OCOR.W	nb de quart de tours (0..3);	A3.L		^table d'un coin; out	D3.L		dpart (y;x); mod	D3.L, D7.WDRAWDEPART:	PUSH.L	D1	LOAD.L	D1,(A3)+2	; D1 <-- P juste aprs le premier OPMOVETO	CALL	DRAWCOINPT	LOAD.L	D3,D1	POP.L	D1	RET;---------\\; DRAWCOIN >;---------/; Dessine tout un coin.; in	(A5)+OCOPP.L	P1 (y;x);	(A5)+OCOPR.L	Pr (y;x);	(A5)+OCOA.L	angle de rotation;	(A5)+OCOD.W	distance;	(A5)+OCOR.W	nb de quart de tours (0..3);	A3.L		^table d'un coin;	D2.W		mode de dessin; out	D2.W		mode de dessin;	D4.L		arrive (y;x); mod	D2.L, D4.L, D7.WDRAWCOIN:	PUSHM.L	D1,D3,D5,D6,A3	CLR.L	D3LOOP$:	LOAD.W	D1,(A3+)	JUMP,EQ EXIT$	COMP.W	D1,#OPMOVETO	JUMP',EQ MOVETO$	COMP.W	D1,#OPLINETO	JUMP',EQ LINETO$	COMP.W	D1,#OPCURVETO	JUMP',EQ CURVETO$	JUMP	EXIT$MOVETO$:	LOAD.L	D1,(A3+)	CALL	DRAWCOINPT	LOAD.L	D3,D1	JUMP	LOOP$LINETO$:	LOAD.L	D1,(A3+)	CALL	DRAWCOINPT	LOAD.L	D4,D1	CALL	DRAWDROITE	LOAD.L	D3,D4	JUMP	LOOP$CURVETO$:	LOAD.L	D1,(A3+)	CALL	DRAWCOINPT	LOAD.L	D4,D1	LOAD.L	D1,(A3+)	CALL	DRAWCOINPT	LOAD.L	D5,D1	LOAD.L	D1,(A3+)	CALL	DRAWCOINPT	LOAD.L	D6,D1	CALL	DRAWCURVE	LOAD.L	D3,D6	JUMP	LOOP$EXIT$:	LOAD.L	D4,D3		; D4 <-- arrive	POPM.L	D1,D3,D5,D6,A3	RET;-----------\\; DRAWCOINPT >;-----------/; Calcule un point.; in	(A5)+OCOPP.L	P1 (y;x);	(A5)+OCOPR.L	Pr (y;x);	(A5)+OCOA.L	angle de rotation;	(A5)+OCOD.W	distance;	(A5)+OCOR.W	nb de quart de tours (0..3);	D1.L		P  (y;x)  (0..FRAMAX); out	D1.L		P  (y;x)  (0..distance); mod	D1.L, D7.WDRAWCOINPT:	PUSHM.L	D2..D4	LOAD.W	D2,D1	MUL.WU	D2,(A5)+OCOD	DIV.WU	D2,#FRAMAX	; D2 <-- X	SWAP.W	D1	MUL.WU	D1,(A5)+OCOD	DIV.WU	D1,#FRAMAX	; D1 <-- Y	LOAD.W	D3,(A5)+OCOR	; D3 <-- nb de quart de tours	JUMP',EQ REND$RLOOP$:	EX.L	D1,D2		; D1/D2 <-- un quart de tour (clockwise)	NEG.W	D2	DEC.W	D3	JUMP,NE RLOOP$REND$:	ADD.W	D2,(A5)+OCOPP+2	ADD.W	D1,(A5)+OCOPP+0	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D2	LOAD.W	D1,(A5)+OCOA+0	; D1 <-- angle	JUMP',EQ ROT$	LOAD.L	D3,(A5)+OCOPR	; D3 <-- centre	LIB	?CALCPSYM	; D4 <-- P4 tourn autour du centreROT$:	LOAD.L	D1,D4	POPM.L	D2..D4	RET;---------\\; DRAWCOTE >;=========/; Dessine un ct du cadre.; in	D3.L	dpart  (y;x);	D4.L	arrive (y;x);	D2.W	mode de dessin; out	D2.W	mode de dessin; mod	D2.L, D7.WDRAWCOTE:;	JUMP	DRAWDROITE;-----------\\; DRAWDROITE >;===========/; Dessine une ligne doite.; in	D3.L		P1 (y;x);	D4.L		P2 (y;x);	D2.W		mode de dessin; out	D2.W		mode de dessin; mod	D2.L, D7.WDRAWDROITE:	COMP.W	(A5)+OMDESS,#MDFILL	JUMP',EQ FILL$	LOAD.W	D7,#DR_LINE	PAGE_	DRAW	TSET.L	D2:#BNCTDOT	JUMP'	EXIT$FILL$:	LOAD.W	D7,#DR_POLYLINE	PAGE_	DRAW;	JUMP'	EXIT$EXIT$:	RET;----------\\; DRAWCURVE >;==========/; Dessine une courbe de Bzier.; in	D3.L		P1 (y;x);	D4.L		C1 (y;x);	D5.L		C2 (y;x);	D6.L		P2 (y;x);	D2.W		mode de dessin; out	D2.W		mode de dessin; mod	D2.L, D7.WDRAWCURVE:	COMP.W	(A5)+OMDESS,#MDFILL	JUMP',EQ FILL$	LOAD.W	D7,#DR_BEZIER	PAGE_	DRAW	TSET.L	D2:#BNCTDOT	JUMP'	EXIT$FILL$:	LOAD.W	D7,#DR_POLYBEZIER	PAGE_	DRAW;	JUMP'	EXIT$EXIT$:	RET;----------\\; DRAWTABLE >;----------/; Cherche la table d'un coin.; in	D4.W	numro du coin (0..n); out	A3.L	^table;	D7.W	erreur; mod	D7.W, A3.LDRAWTABLE:	PUSHM.L	D3,D4	LOAD.W	D7,#1	COMP.W	D4,#MAXCOIN	JUMP',HS EXIT$	LOAD.L	A3,#R16"TACOIN	SL.W	D4,#1	CLR.L	D3	LOAD.W	D3,(A3)+(D4.W)	; D4 <-- adresse relative	LOAD.L	A3,#R16"DEBUT	ADD.L	A3,D3		; A3 <-- adresse absolue	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RETTACOIN:	.W	A0$,A1$,A2$,A3$	.W	B1$,B2$,B3$	.W	C1$,C2$,C3$	.W	D1$,D2$	.W	F1$,F2$,F3$	.W	G1$,G2$	.W	I2$,I3$,I1$	.W	E1$,E2$,E3$,E4$	.W	H1$	.W	J1$,J2$,J3$	.W	K1$,K2$,K3$	.W	L1$,L2$,L3$	.W	M1$,M2$,M3$,M4$MAXCOIN	=	(.-TACOIN)/2A0$:	.W	OPMOVETO	0,0	.W	OPENDA1$:	.W	OPMOVETO	10000,0	.W	OPLINETO	0,10000	.W	OPENDA2$:	.W	OPMOVETO	10000,0	.W	OPLINETO	2000,2000	.W	OPLINETO	0,10000	.W	OPENDA3$:	.W	OPMOVETO	10000,0	.W	OPLINETO	8000,8000	.W	OPLINETO	0,10000	.W	OPENDB1$:	.W	OPMOVETO	10000,0	.W	OPCURVETO	4600,0		0,4600		0,10000	.W	OPENDB2$:	.W	OPMOVETO	10000,0	.W	OPCURVETO	7300,0		5000,2300	5000,5000	.W	OPCURVETO	2300,5000	0,7300		0,10000	.W	OPENDB3$:	.W	OPMOVETO	5000,0	.W	OPCURVETO	2300,0		0,2300		0,5000	.W	OPMOVETO	5000,2000	.W	OPCURVETO	3380,2000	2000,3380	2000,5000	.W	OPCURVETO	2000,6620	3380,8000	5000,8000	.W	OPCURVETO	6620,8000	8000,6620	8000,5000	.W	OPCURVETO	8000,3380	6620,2000	5000,2000	.W	OPMOVETO	0,5000	.W	OPENDC1$:	.W	OPMOVETO	10000,0	.W	OPCURVETO	10000,5400	5400,10000	0,10000	.W	OPENDC2$:	.W	OPMOVETO	10000,0	.W	OPCURVETO	10000,2700	7700,5000	5000,5000	.W	OPCURVETO	5000,7700	2700,10000	0,10000	.W	OPENDC3$:	.W	OPMOVETO	10000,5000	.W	OPCURVETO	10000,7700	7700,10000	5000,10000	.W	OPMOVETO	5000,2000	.W	OPCURVETO	3380,2000	2000,3380	2000,5000	.W	OPCURVETO	2000,6620	3380,8000	5000,8000	.W	OPCURVETO	6620,8000	8000,6620	8000,5000	.W	OPCURVETO	8000,3380	6620,2000	5000,2000	.W	OPMOVETO	5000,10000	.W	OPENDD1$:	.W	OPMOVETO	10000,0	.W	OPLINETO	10000,10000	.W	OPLINETO	0,10000	.W	OPENDD2$:	.W	OPMOVETO	10000,0	.W	OPLINETO	10000,5000	.W	OPLINETO	5000,5000	.W	OPLINETO	5000,10000	.W	OPLINETO	0,10000	.W	OPENDF1$:	.W	OPMOVETO	10000,0	.W	OPLINETO	10000,5000	.W	OPCURVETO	10000,2300	7700,0		5000,0	.W	OPCURVETO	2300,0		0,2300		0,5000	.W	OPCURVETO	0,7700		2300,10000	5000,10000	.W	OPLINETO	0,10000	.W	OPENDF2$:	.W	OPMOVETO	10000,0	.W	OPLINETO	10000,5000	.W	OPCURVETO	10000,2300	7700,0		5000,0	.W	OPCURVETO	2300,0		0,2300		0,5000	.W	OPCURVETO	0,7700		2300,10000	5000,10000	.W	OPLINETO	0,10000	.W	OPMOVETO	5000,2000	.W	OPCURVETO	3380,2000	2000,3380	2000,5000	.W	OPCURVETO	2000,6620	3380,8000	5000,8000	.W	OPCURVETO	6620,8000	8000,6620	8000,5000	.W	OPCURVETO	8000,3380	6620,2000	5000,2000	.W	OPMOVETO	0,10000	.W	OPENDF3$:	.W	OPMOVETO	1000