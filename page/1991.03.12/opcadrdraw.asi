.L, D7.WORDONNE:	PUSH.L	D2	COMP.W	D3,D4	JUMP',LE SWAPX$	LOAD.W	D2,D3	LOAD.W	D3,D4	LOAD.W	D4,D2SWAPX$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',LE SWAPY$	LOAD.W	D2,D3	LOAD.W	D3,D4	LOAD.W	D4,D2SWAPY$:	SWAP.W	D3	SWAP.W	D4	POP.L	D2	RET	.END